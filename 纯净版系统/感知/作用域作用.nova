// §4 @scope — 作用域样式(CSS Cascading Level 6)

结构 ScopeRule {
    上界选择器,    // u64 scope root选择器 (.card)
    下界选择器,    // u64 scope limit选择器 (.card-content) 或 null
    规则列表,    // u64 CSSRule*数组
    规则数量,
    规则容量,
}

函数 ScopeRule_创建(上界, 下界) {
    定义 sr = 堆_分配(ScopeRule)
    sr.上界选择器 = 上界
    sr.下界选择器 = 下界
    sr.规则容量 = 64
    sr.规则列表 = 堆_分配_数组(64 * 8)
    sr.规则数量 = 0
    返回 sr
}

函数 ScopeRule_匹配元素(sr, 元素) {
    如果 (sr == 0 || 元素 == 0) { 返回 假 }

    // 1. 元素必须是上界选择器匹配元素的后代
    定义 可变 祖先 = 元素
    定义 可变 在范围内 = 假
    当 (祖先 != 0) {
        如果 (Selector_匹配(sr.上界选择器, 祖先)) {
            在范围内 = 真; 跳出
        }
        祖先 = 祖先.父节点
    }
    如果 (!在范围内) { 返回 假 }

    // 2. 如果有下界: 元素不能是下界选择器匹配元素的后代
    如果 (sr.下界选择器 != 0) {
        定义 可变 检查 = 元素
        当 (检查 != 0 && 检查 != 祖先) {
            如果 (Selector_匹配(sr.下界选择器, 检查)) {
                返回 假    // 超出范围下界
            }
            检查 = 检查.父节点
        }
    }

    返回 真
}

// 辅助存根
函数 CSS解析_数字(str) {
    如果 (str == 0) { 返回 0 }
    定义 可变 i = 0
    定义 len = 字节长度(str)
    当 (i < len && 字节取(str, i) == 32) { i = i + 1 }
    定义 可变 负 = 假
    如果 (i < len && 字节取(str, i) == 0x2D) { 负 = 真; i = i + 1 }
    定义 可变 result = 0
    当 (i < len && 字节取(str, i) >= 0x30 && 字节取(str, i) <= 0x39) {
        result = result * 10 + (字节取(str, i) - 0x30)
        i = i + 1
    }
    如果 (负) { result = 0 - result }
    返回 result
}
函数 整数转字符串(n) {
    定义 缓冲 = 堆_分配(20)
    定义 可变 val = n
    如果 (val == 0) { 内存_写8(缓冲, 0x30); 内存_写8(缓冲 + 1, 0); 返回 缓冲 }
    定义 可变 负 = 假
    如果 (val < 0) { 负 = 真; val = 0 - val }
    定义 可变 i = 0
    定义 临时 = 堆_分配(20)
    当 (val > 0) { 内存_写8(临时 + i, (val % 10) + 0x30); val = val / 10; i = i + 1 }
    定义 可变 pos = 0
    如果 (负) { 内存_写8(缓冲, 0x2D); pos = 1 }
    定义 可变 j = i - 1
    当 (j >= 0) { 内存_写8(缓冲 + pos, 内存_读8(临时 + j)); pos = pos + 1; j = j - 1 }
    内存_写8(缓冲 + pos, 0)
    堆_释放(临时)
    返回 缓冲
}
函数 Selector_匹配(sel, elem) {
    // 委托到CSSSelectorEngine.nova中的完整实现
    如果 (sel == 0 || elem == 0) { 返回 假 }
    如果 (sel.类型 == SEL_TAG) {
        定义 扩展 = 元素_获取扩展(elem)
        如果 (扩展 == 0) { 返回 假 }
        返回 字符串_相等_不区分大小写(扩展.标签名, sel.名称)
    }
    如果 (sel.类型 == SEL_CLASS) { 返回 元素_hasClass(elem, sel.名称) }
    如果 (sel.类型 == SEL_ID) { 返回 字符串_相等(元素_getAttribute(elem, "id"), sel.名称) }
    如果 (sel.类型 == SEL_UNIVERSAL) { 返回 真 }
    如果 (sel.类型 == SEL_ATTR) { 返回 Selector_匹配属性(sel, elem) }
    如果 (sel.类型 == SEL_PSEUDO_CLASS) { 返回 Selector_匹配伪类(sel, elem) }
    如果 (sel.类型 == SEL_COMPOUND) {
        定义 可变 i = 0
        当 (i < sel.子项数量) {
            如果 (!Selector_匹配(内存_读64(sel.子项列表 + i * 8), elem)) { 返回 假 }
            i = i + 1
        }
        返回 真
    }
    如果 (sel.类型 == SEL_COMPLEX) { 返回 Selector_匹配复杂(sel, elem) }
    返回 假
}

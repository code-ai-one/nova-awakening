// §2 发送请求 + 解析响应

函数 HTTP_发送(req) {
    HTTP_请求总数 = HTTP_请求总数 + 1

    // 序列化HTTP请求
    定义 方法名 = HTTP_方法名(req.方法)
    定义 可变 原始请求 = 方法名 + " " + req.路径 + " " + HTTP_版本 + "\r\n"

    定义 可变 i = 0
    当 (i < 计数(req.头部列表)) {
        原始请求 = 原始请求 + req.头部列表[i].名称 + ": " + req.头部列表[i].值 + "\r\n"
        i = i + 1
    }
    原始请求 = 原始请求 + "\r\n"
    如果 (req.正文 != "") {
        原始请求 = 原始请求 + req.正文
    }

    // 建立传控连接并发送(通过内核网络栈)
    定义 连接 = 传控_连接(req.主机, req.端口, req.超时_ms)
    如果 (连接 == 空) {
        HTTP_失败总数 = HTTP_失败总数 + 1
        定义 失败响应 = HTTP响应 {}
        失败响应.状态码 = 0
        失败响应.成功 = 假
        失败响应.状态文本 = "连接失败"
        返回 失败响应
    }

    传控_发送数据(连接, 原始请求)

    // 接收响应
    定义 原始响应 = 传控_接收数据(连接, req.超时_ms)
    传控_关闭(连接)

    // 解析HTTP响应
    定义 响应 = HTTP_解析响应(原始响应)
    如果 (响应.状态码 >= 200 && 响应.状态码 < 300) {
        HTTP_成功总数 = HTTP_成功总数 + 1
        响应.成功 = 真
    } 否则 {
        HTTP_失败总数 = HTTP_失败总数 + 1
        响应.成功 = 假
    }

    返回 响应
}

函数 HTTP_发送_带重试(req) {
    定义 可变 尝试 = 0
    当 (尝试 < HTTP_最大重试) {
        定义 响应 = HTTP_发送(req)
        如果 (响应.成功) { 返回 响应 }
        如果 (响应.状态码 >= 400 && 响应.状态码 < 500) {
            返回 响应  // 客户端错误不重试
        }
        尝试 = 尝试 + 1
        内核调试("HTTP: 重试 " + 整数转字符串(尝试) + "/" + 整数转字符串(HTTP_最大重试))
    }
    定义 失败 = HTTP响应 {}
    失败.状态码 = 0
    失败.成功 = 假
    失败.状态文本 = "重试耗尽"
    返回 失败
}

函数 HTTP_解析响应(原始数据) {
    定义 响应 = HTTP响应 {}
    如果 (原始数据 == "" || 原始数据 == 空) {
        响应.状态码 = 0
        响应.成功 = 假
        返回 响应
    }
    // 解析状态行: HTTP/1.1 200 OK
    定义 状态行 = 提取行(原始数据, 0)
    响应.状态码 = 解析状态码(状态行)
    响应.状态文本 = 状态行

    // 解析头部(直到空行)
    响应.头部列表 = []
    定义 可变 行号 = 1
    定义 可变 正文开始 = 0
    定义 可变 解析头部中 = 真
    当 (解析头部中) {
        定义 行 = 提取行(原始数据, 行号)
        如果 (行 == "" || 行 == "\r") {
            解析头部中 = 假
            正文开始 = 行号 + 1
        } 否则 {
            定义 h = HTTP头部 {}
            定义 冒号位置 = 查找字符(行, 58)  // ':'
            如果 (冒号位置 > 0) {
                h.名称 = 子字符串(行, 0, 冒号位置)
                h.值 = 子字符串(行, 冒号位置 + 2, 字符串长度(行))
            }
            追加(响应.头部列表, h)
        }
        行号 = 行号 + 1
        如果 (行号 > 100) { 解析头部中 = 假 }
    }

    // 提取正文
    响应.正文 = 提取正文(原始数据, 正文开始)
    响应.正文长度 = 字符串长度(响应.正文)
    返回 响应
}

函数 HTTP_方法名(方法) {
    如果 (方法 == HTTP_GET) { 返回 "GET" }
    如果 (方法 == HTTP_POST) { 返回 "POST" }
    如果 (方法 == HTTP_PUT) { 返回 "PUT" }
    如果 (方法 == HTTP_DELETE) { 返回 "DELETE" }
    如果 (方法 == HTTP_PATCH) { 返回 "PATCH" }
    返回 "GET"
}

函数 HTTP_获取响应头(响应, 名称) {
    定义 可变 i = 0
    当 (i < 计数(响应.头部列表)) {
        如果 (响应.头部列表[i].名称 == 名称) {
            返回 响应.头部列表[i].值
        }
        i = i + 1
    }
    返回 ""
}

导入("./物理页描述符.nova")

    cpu_Nova块缓存:       CPU_Nova块缓存,
    cpu_partial限:  u32,        // cpu_partial: CPU上保留的最大partial数
    节点:           缓存节点,
    标志:           u32,        // Nova块缓存_flags_t
    构造函数:       u64,        // ctor: 对象构造函数(可选)
    分配次数:       u64,
    释放次数:       u64,
    活跃对象:       u64,
    Nova块缓存页数:       u64,
    引用计数:       u32
}

// 全局状态

定义 可变 kmalloc_缓存 = 数组<kmem_cache, KMALLOC_级别数>
定义 可变 全部缓存 = []          // 所有kmem_cache的链表
定义 可变 缓存锁 = 空            // Nova块缓存_mutex
定义 可变 SLUB_总分配 = 0
定义 可变 SLUB_总释放 = 0

// 初始化

函数 SLUB_初始化() {
    缓存锁 = 自旋锁_创建()
    定义 可变 i = 0
    当 (i < KMALLOC_级别数) {
        定义 大小 = KMALLOC_级别[i]
        定义 名称 = 字符串拼接("kmalloc-", 整数转字符串(大小))
        __缓存_初始化(kmalloc_缓存[i], 名称, 大小, 最小对齐, 0)
        追加(全部缓存, kmalloc_缓存[i])
        i = i + 1
    }
    早期打印OK("SLUB分配器初始化 (8-8192字节, 13级, 嵌入式空闲指针)")
}

函数 __缓存_初始化(缓存, 名称, 对象大小, 对齐, 标志) {
    缓存.名称 = 名称
    缓存.对象大小 = 对象大小
    缓存.标志 = 标志
    缓存.引用计数 = 1

    定义 可变 实际 = 对象大小
    如果 ((标志 & Nova块缓存_RED_ZONE) != 0) {
        实际 = 实际 + 16   // 前后各8字节红区
        缓存.红区大小 = 8
    } 否则 {
        缓存.红区大小 = 0
    }

    // 对齐
    定义 可变 最终对齐 = 对齐
    如果 ((标志 & Nova块缓存_HWCACHE_ALIGN) != 0) {
        如果 (实际 > 缓存行大小 / 2) { 最终对齐 = 缓存行大小 }
    }
    如果 (最终对齐 < 最小对齐) { 最终对齐 = 最小对齐 }
    缓存.对齐 = 最终对齐
    // 向上取整到对齐
    实际 = (实际 + 最终对齐 - 1) / 最终对齐 * 最终对齐
    缓存.实际大小 = 实际

    // 嵌入式空闲指针偏移: 放在对象开头(对象未使用时)
    缓存.空闲指针偏移 = 0

    定义 可变 最佳阶 = 0
    定义 可变 最佳对象数 = 0
    定义 可变 阶 = 0
    当 (阶 <= 最大Nova块缓存阶) {
        定义 Nova块缓存字节 = 页大小 * (1 << 阶)
        如果 (实际 <= 0) { 实际 = 1 }  // 防止除零
    定义 可放对象 = Nova块缓存字节 / 实际
        如果 (可放对象 > 0) {
            定义 浪费 = Nova块缓存字节 - 可放对象 * 实际
            定义 浪费率 = 浪费 * 100 / Nova块缓存字节
            如果 (浪费率 < 13 || 最佳对象数 == 0) {
                最佳阶 = 阶
                最佳对象数 = 可放对象
                如果 (浪费率 < 13) { 中断 }
            }
        }
        阶 = 阶 + 1
    }
    缓存.Nova块缓存阶 = 最佳阶
    缓存.每Nova块缓存对象数 = 最佳对象数

    // partial管理参数
    缓存.最小partial = 5
    如果 (最佳对象数 < 16) { 缓存.最小partial = 8 }
    缓存.cpu_partial限 = 30

    // 初始化per-CPU Nova块缓存
    缓存.cpu_Nova块缓存.空闲链 = 0
    缓存.cpu_Nova块缓存.活跃Nova块缓存 = 空
    缓存.cpu_Nova块缓存.partial = 空
    缓存.cpu_Nova块缓存.partial数 = 0

    // 初始化节点
    缓存.节点.partial链 = 链表_创建()
    缓存.节点.partial数 = 0
    缓存.节点.锁 = 自旋锁_创建()
}

// Nova块缓存页创建与对象切分

函数 __分配Nova块缓存页(缓存, gfp) {
    // 从伙伴系统分配物理页
    定义 页号 = 伙伴系统_分配_带标志(缓存.Nova块缓存阶, gfp)
    如果 (页号 < 0) { 返回 空 }

    // 设置页描述符
    定义 页 = 页描述符_获取(页号)
    如果 (页 != 空) { 页描述符_设置标志(页, 页_Nova块缓存) }

    // 创建Nova块缓存页元数据
    定义 可变 新Nova块缓存 = Nova块缓存页 {}
    新Nova块缓存.页号 = 页号
    新Nova块缓存.虚拟基址 = 物理到虚拟(页号到地址(页号))
    新Nova块缓存.对象数 = 缓存.每Nova块缓存对象数
    新Nova块缓存.已用数 = 0
    新Nova块缓存.冻结 = 假
    新Nova块缓存.所属缓存 = 缓存
    新Nova块缓存.下一个 = 0

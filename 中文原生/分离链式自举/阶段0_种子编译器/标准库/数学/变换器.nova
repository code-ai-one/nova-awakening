// Nova标准库 — Transformer 完整块
// 组合注意力+FFN+残差+层归一化
// 对标 nova-forth 的 transformer/ 模块

导入("../基础.nova")
导入("../../运行时/原语桩.nova")

定义 变换精度 = 1000

// Feed-Forward Network (FFN)
// FFN(x) = max(0, xW1+b1)W2+b2
// [输入维度, 隐藏维度, W1, b1, W2, b2]

函数 ffn_创建(模型维度, 前馈维度, 种子) { 定义 可变 s = 种子
 定义 范围 = 变换_开方(6 * 变换精度 / (模型维度 + 前馈维度))
 // W1: 模型维度 × 前馈维度
 定义 可变 w1 = []
 定义 可变 i = 0
 当 (i < 模型维度 * 前馈维度) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 追加(w1, (s % (2 * 范围 + 1)) - 范围)
 i = i + 1
 }
 // b1: 前馈维度
 定义 可变 b1 = []
 i = 0
 当 (i < 前馈维度) { 追加(b1, 0) i = i + 1 }
 // W2: 前馈维度 × 模型维度
 定义 可变 w2 = []
 i = 0
 当 (i < 前馈维度 * 模型维度) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 追加(w2, (s % (2 * 范围 + 1)) - 范围)
 i = i + 1
 }
 // b2: 模型维度
 定义 可变 b2 = []
 i = 0
 当 (i < 模型维度) { 追加(b2, 0) i = i + 1 }
 返回 [模型维度, 前馈维度, w1, b1, w2, b2]
}

// FFN 前向: 输入为一个 模型维度 维向量
函数 ffn_前向(ffn, 输入) { 定义 模型维度 = ffn[0]
 定义 前馈维度 = ffn[1]
 定义 w1 = ffn[2]
 定义 b1 = ffn[3]
 定义 w2 = ffn[4]
 定义 b2 = ffn[5]
 // 第一层: hidden = 线性整流(x @ W1 + b1)
 定义 可变 隐藏 = []
 定义 可变 i = 0
 当 (i < 前馈维度) { 定义 可变 和 = b1[i]
 定义 可变 j = 0
 当 (j < 模型维度) {
 和 = 和 + 输入[j] * w1[j * 前馈维度 + i] / 变换精度
 j = j + 1
 }
 如果 (和 < 0) { 和 = 0 }
 追加(隐藏, 和)
 i = i + 1
 }
 // 第二层: output = hidden @ W2 + b2
 定义 可变 输出 = []
 i = 0
 当 (i < 模型维度) { 定义 可变 和2 = b2[i]
 定义 可变 j2 = 0
 当 (j2 < 前馈维度) {
 和2 = 和2 + 隐藏[j2] * w2[j2 * 模型维度 + i] / 变换精度
 j2 = j2 + 1
 }
 追加(输出, 和2)
 i = i + 1
 }
 返回 输出
}

// Layer Normalization
函数 变换_层归一化(向量) { 定义 n = 计数(向量)
    定义 可变 方差和 = 0
 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < n) { 和 = 和 + 向量[i] i = i + 1 }
 定义 均值 = 和 / n
 i = 0
 当 (i < n) { 定义 差 = 向量[i] - 均值
 方差和 = 方差和 + 差 * 差
 i = i + 1
 }
 定义 可变 标准差 = 变换_开方(方差和 / n)
 如果 (标准差 == 0) { 标准差 = 1 }
 定义 可变 结果 = []
 i = 0
 当 (i < n) {
 追加(结果, (向量[i] - 均值) * 变换精度 / 标准差)
 i = i + 1
 }
 返回 结果
}

// 残差连接
函数 变换_残差(输入, 输出) { 定义 n = 计数(输入)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < n) {
 追加(结果, 输入[i] + 输出[i])
 i = i + 1
 }
 返回 结果
}

// 完整 Transformer 编码器层
// 输入: 序列矩阵 [序列长度, 模型维度, ...]
// 注意力参数, FFN参数

函数 编码器层_前向(序列, _注意力权重, ffn) { 定义 序列 = 序列[0]
    定义 可变 指数组 = []
 定义 d = 序列[1]
 // 1. Multi-Head Self-Attention
 // 简化: 使用序列本身作为Q,K,V
 定义 可变 注意力输出 = 变换_矩阵创建(序列, d)
 // 对每个位置做注意力
 定义 可变 i = 0
 当 (i < 序列) { 定义 可变 q = []
 定义 可变 j = 0
 当 (j < d) { 追加(q, 序列[2 + i * d + j]) j = j + 1 }
 // 点积注意力
 定义 可变 权重 = []
 定义 可变 k = 0
 当 (k < 序列) { 定义 可变 点积 = 0
 j = 0
 当 (j < d) {
 点积 = 点积 + q[j] * 序列[2 + k * d + j] / 变换精度
 j = j + 1
 }
 定义 可变 缩放 = 变换_开方(d * 变换精度)
 如果 (缩放 == 0) { 缩放 = 1 }
 点积 = 点积 * 变换精度 / 缩放
 追加(权重, 点积)
 k = k + 1
 }
 // Softmax
 定义 可变 最大w = 权重[0]
 k = 1
 当 (k < 序列) { 如果 (权重[k] > 最大w) { 最大w = 权重[k] } k = k + 1 }
 定义 可变 exp和 = 0
 k = 0
 当 (k < 序列) { 定义 可变 e = 变换精度 + 权重[k] - 最大w
 如果 (e < 1) { e = 1 }
 追加(指数组, e)
 exp和 = exp和 + e
 k = k + 1
 }
 // 加权求和
 j = 0
 当 (j < d) { 定义 可变 v和 = 0
 k = 0
 当 (k < 序列) {
 v和 = v和 + 指数组[k] * 序列[2 + k * d + j] / exp和
 k = k + 1
 }
 注意力输出[2 + i * d + j] = v和
 j = j + 1
 }
 i = i + 1
 }
 // 2. 残差 + 层归一化
 定义 可变 中间 = 变换_矩阵创建(序列, d)
 i = 0
 当 (i < 序列) { 定义 可变 行 = []
 j = 0
 当 (j < d) {
 追加(行, 序列[2 + i * d + j] + 注意力输出[2 + i * d + j])
 j = j + 1
 }
 行 = 变换_层归一化(行)
 j = 0
 当 (j < d) { 中间[2 + i * d + j] = 行[j] j = j + 1 }
 i = i + 1
 }
 // 3. FFN + 残差 + 层归一化
 定义 可变 最终 = 变换_矩阵创建(序列, d)
 i = 0
 当 (i < 序列) { 定义 可变 输入行 = []
 j = 0
 当 (j < d) { 追加(输入行, 中间[2 + i * d + j]) j = j + 1 }
 定义 ffn输出 = ffn_前向(ffn, 输入行)
 // 残差
 定义 可变 残差行 = []
 j = 0
 当 (j < d) { 追加(残差行, 输入行[j] + ffn输出[j]) j = j + 1 }
 残差行 = 变换_层归一化(残差行)
 j = 0
 当 (j < d) { 最终[2 + i * d + j] = 残差行[j] j = j + 1 }
 i = i + 1
 }
 返回 最终
}

// 简单 Transformer 模型
// [嵌入表, FFN列表, 层数, 模型维度]

函数 transformer_创建(词汇量, 模型维度, 前馈维度, 层数, 种子) {
 // 嵌入表
 定义 可变 嵌入权重 = [词汇量, 模型维度]
 定义 可变 s = 种子
 定义 可变 i = 0
 当 (i < 词汇量 * 模型维度) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 追加(嵌入权重, (s % 200) - 100)
 i = i + 1
 }
 // FFN layers
 定义 可变 ffn列表 = []
 i = 0
 当 (i < 层数) {
 追加(ffn列表, ffn_创建(模型维度, 前馈维度, s + i * 1000))
 i = i + 1
 }
 返回 [嵌入权重, ffn列表, 层数, 模型维度]
}

// 变换er 前向
函数 transformer_前向(模型, token序列) { 定义 嵌入表 = 模型[0]
 定义 ffn列表 = 模型[1]
 定义 层数 = 模型[2]
 定义 模型维度 = 模型[3]
 定义 序列长度 = 计数(token序列)
 // 嵌入
 定义 可变 序列 = [序列长度, 模型维度]
 定义 可变 i = 0
 当 (i < 序列长度) { 定义 tid = token序列[i]
 定义 基 = 2 + tid * 模型维度
 定义 可变 j = 0
 当 (j < 模型维度) {
 追加(序列, 嵌入表[基 + j])
 j = j + 1
 }
 i = i + 1
 }
 // 逐层编码
 定义 可变 层 = 0
 当 (层 < 层数) {
 序列 = 编码器层_前向(序列, 空, ffn列表[层])
 层 = 层 + 1
 }
 返回 序列
}

// 均方根归一化层 (LLaMA风格, 比LayerNorm更轻量)
// 均方根归一化层(x, 0) = x / RMS(x) * 缩放因子
// RMS(x) = sqrt(mean(x^2))

函数 均方根归一化2(输入, 缩放因子) { 定义 n = 计数(输入)
 // 计算均方根
 定义 可变 平方和 = 0
 定义 可变 i = 0
 当 (i < n) {
 平方和 = 平方和 + 输入[i] * 输入[i] / 变换精度
 i = i + 1
 }
 定义 可变 均方根值 = 变换_开方(平方和 / n)
 如果 (均方根值 == 0) { 均方根值 = 1 }
 // 归一化 * 缩放因子
 定义 可变 结果 = []
 i = 0
 当 (i < n) { 定义 索引 = i % 计数(缩放因子)
 追加(结果, 输入[i] * 缩放因子[索引] / 均方根值)
 i = i + 1
 }
 返回 结果
}

函数 rmsnorm_gamma创建(维度) { 定义 可变 g = []
 定义 可变 i = 0
 当 (i < 维度) { 追加(g, 变换精度)
 i = i + 1 }
 返回 g
}

// 因果遮罩 (Causal Mask)
// 自回归模型: 位置i只能看到<=i的位置
// 遮罩矩阵: 掩码[i][j] = (j <= i) ? 0 : -0x7FFFFFFF

函数 因果遮罩_创建(序列长度) { 定义 可变 掩码 = []
 定义 可变 i = 0
 当 (i < 序列长度) { 定义 可变 j = 0
 当 (j < 序列长度) { 如果 (j <= i) {
 追加(掩码, 0)
 } 否则 {
 追加(掩码, 0 - 0x7FFFFFFF) // -inf 近似
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 [序列长度, 序列长度, 掩码]
}

// 应用因果遮罩到注意力分数
函数 因果遮罩_应用(分数矩阵, 掩码) { 定义 行 = 分数矩阵[0]
 定义 列 = 分数矩阵[1]
 定义 可变 i = 0
 当 (i < 行) { 定义 可变 j = 0
 当 (j < 列) {
 分数矩阵[2 + i * 列 + j] = 分数矩阵[2 + i * 列 + j] + 掩码[2 + i * 列 + j]
 j = j + 1
 }
 i = i + 1
 }
}

// 旋转位置编码 (RoPE, LLaMA/GPT-NeoX风格)
// 在注意力Q/K上应用旋转, 不需要额外参数
// 近似: 对每对维度 (2i, 2i+1) 应用旋转角 θ_i * position
// sin/cos 用分段线性近似

函数 变换_sin近似(x) { 定义 可变 角 = x % 6283
 如果 (角 < 0) { 角 = 角 + 6283 }
 如果 (角 < 1571) { 返回 角 * 变换精度 / 1571 }
 如果 (角 < 3142) { 返回 (3142 - 角) * 变换精度 / 1571 }
 如果 (角 < 4712) { 返回 0 - (角 - 3142) * 变换精度 / 1571 }
 返回 0 - (6283 - 角) * 变换精度 / 1571
}

函数 变换_cos近似(x) { 返回 变换_sin近似(x + 1571) }

函数 rope_应用(向量, 位置, 基数) { 定义 d = 计数(向量)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < d / 2) {
 // θ_i = position / base^(2i/d)
 // 简化: θ = position * 1000 / (base的幂近似)
 定义 可变 分母 = 变换精度
 定义 可变 pi = 0
 当 (pi < 2 * i) {
 分母 = 分母 * 基数 / d
 如果 (分母 < 1) { 分母 = 1 }
 pi = pi + 1
 }
 定义 角度 = 位置 * 变换精度 / 分母
 定义 cos_t = 变换_cos近似(角度)
 定义 sin_t = 变换_sin近似(角度)
 // 旋转: [x, y] -> [x*cos - y*sin, x*sin + y*cos]
 定义 x_val = 向量[2 * i]
 定义 y_val = 向量[2 * i + 1]
 追加(结果, (x_val * cos_t - y_val * sin_t) / 变换精度)
 追加(结果, (x_val * sin_t + y_val * cos_t) / 变换精度)
 i = i + 1
 }
 // 奇数维度直接复制
 如果 (d % 2 == 1) { 追加(结果, 向量[d - 1]) }
 返回 结果
}

// 自门控线性层 (LLaMA FFN,  比ReLU更优, 0, 0)
// 自门控线性层(x, W, V, W2) = (Swish(xW) ⊙ xV) W2
// Swish(x) = x * S形函数(x)

函数 变换_sigmoid(x) {
    如果 (x > 5 * 变换精度) { 返回 变换精度
}
 如果 (x < 0 - 5 * 变换精度) { 返回 0 }
 返回 变换精度 / 2 + x / 4
}

// KV缓存 (推理加速)
// 自回归生成时缓存已计算的K/V, 每步只计算新token

函数 kv缓存_创建() { 返回 [[], []] // [K缓存列表, V缓存列表]
}

函数 kv缓存_长度(缓存) { 返回 计数(缓存[0])
}

// ALiBi 位置编码 (无需学习的位置信息, 0)
// 给注意力分数加上线性偏置: score[i][j] = score[i][j] - m * |i-j|
函数 alibi_偏置(序列长度, 头数, 头idx) {
 // 斜率 = 2^(-8/heads) 近似
 定义 可变 斜率 = 变换精度
 定义 可变 h = 0
 当 (h <= 头idx) {
 斜率 = 斜率 * 变换精度 / (变换精度 + 变换精度 * 8 / 头数)
 h = h + 1
 }
 定义 可变 偏置 = []
 定义 可变 i = 0
 当 (i < 序列长度) { 定义 可变 行 = []
 定义 可变 j = 0
 当 (j < 序列长度) { 定义 可变 距离 = i - j
 如果 (距离 < 0) { 距离 = 0 - 距离 }
 追加(行, 0 - 斜率 * 距离 / 变换精度)
 j = j + 1
 }
 追加(偏置, 行)
 i = i + 1
 }
 返回 偏置
}

// MoE 专家混合层
// 路由: 选择top-k专家
函数 moe_路由(输入, 门控权重, 专家数, topk) { 定义 d = 计数(输入)
 // 计算门控分数
 定义 可变 分数 = []
 定义 可变 e = 0
 当 (e < 专家数) { 定义 可变 和 = 0
 定义 可变 j = 0
 当 (j < d) {
 和 = 和 + 输入[j] * 门控权重[e * d + j] / 变换精度
 j = j + 1
 }
 追加(分数, 和)
 e = e + 1
 }
 // 选top-k
 定义 可变 选中 = []
 定义 可变 已选 = []
 e = 0
 当 (e < 专家数) { 追加(已选, 假)
 e = e + 1 }
 定义 可变 k = 0
 当 (k < topk) { 定义 可变 最大idx = 0 - 1
 定义 可变 最大值 = 0 - 0x7FFFFFFF
 e = 0
 当 (e < 专家数) { 如果 (已选[e] == 假 且 分数[e] > 最大值) {
 最大值 = 分数[e]
 最大idx = e
 }
 e = e + 1
 }
 如果 (最大idx >= 0) {
 追加(选中, [最大idx, 分数[最大idx]])
 已选[最大idx] = 真
 }
 k = k + 1
 }
 // Softmax归一化选中的分数
 定义 可变 总分 = 0
 k = 0
 当 (k < 计数(选中)) { 定义 可变 s = 选中[k][1]
 如果 (s < 0) { s = 1 }
 总分 = 总分 + s
 k = k + 1
 }
 如果 (总分 == 0) { 总分 = 1 }
 k = 0
 当 (k < 计数(选中)) {
 选中[k][1] = 选中[k][1] * 变换精度 / 总分
 k = k + 1
 }
 返回 选中
}

// MoE前向: 加权组合专家输出
函数 moe_前向(输入, 专家列表, 路由结果) { 定义 d = 计数(输入)
 定义 可变 输出 = []
 定义 可变 di = 0
 当 (di < d) { 追加(输出, 0)
 di = di + 1 }
 定义 可变 k = 0
 当 (k < 计数(路由结果)) { 定义 专家idx = 路由结果[k][0]
 定义 权重 = 路由结果[k][1]
 定义 专家输出 = ffn_前向(专家列表[专家idx], 输入)
 di = 0
 当 (di < d) {
 输出[di] = 输出[di] + 专家输出[di] * 权重 / 变换精度
 di = di + 1
 }
 k = k + 1
 }
 返回 输出
}

// 完整Transformer块 (Pre-LN)
函数 transformer块_前向(输入, 注意力层, ffn层, ln1_g, ln1_b, ln2_g, ln2_b) {
 // Pre-LN: LN → Attn → Residual → LN → FFN → Residual
 定义 d = 计数(输入)
 // 1. LayerNorm1 + Attention
 定义 ln1 = 变换_层归一化_带参数(输入, ln1_g, ln1_b)
 // 注意力(简化: 直接用FFN模拟)
 定义 attn_out = ffn_前向(注意力层, ln1)
 // Residual
 定义 可变 中间值 = []
 定义 可变 i = 0
 当 (i < d) { 追加(中间值, 输入[i] + attn_out[i])
 i = i + 1 }
 // 2. LayerNorm2 + FFN
 定义 ln2 = 变换_层归一化_带参数(中间值, ln2_g, ln2_b)
 定义 ffn_out = ffn_前向(ffn层, ln2)
 // Residual
 定义 可变 输出 = []
 i = 0
 当 (i < d) { 追加(输出, 中间值[i] + ffn_out[i])
 i = i + 1 }
 返回 输出
}

// 因果掩码 (自回归)
函数 因果掩码(序列长度) { 定义 可变 掩码 = []
 定义 可变 i = 0
 当 (i < 序列长度) { 定义 可变 行 = []
 定义 可变 j = 0
 当 (j < 序列长度) { 如果 (j <= i) { 追加(行, 0) }
 否则 { 追加(行, 0 - 0x7FFFFFFF) }
 j = j + 1
 }
 追加(掩码, 行)
 i = i + 1
 }
 返回 掩码
}

// 内部: 变换器用LayerNorm
函数 变换_层归一化_带参数(输入, 缩放因子, 偏移因子) { 定义 n = 计数(输入)
 定义 可变 均值 = 0
 定义 可变 i = 0
 当 (i < n) { 均值 = 均值 + 输入[i]
 i = i + 1 }
 均值 = 均值 / n
 定义 可变 方差 = 0
 i = 0
 当 (i < n) { 定义 d = 输入[i] - 均值
 方差 = 方差 + d * d / 变换精度
 i = i + 1
 }
 方差 = 方差 / n
 定义 可变 标准差 = 变换_开方(方差)
 如果 (标准差 == 0) { 标准差 = 1 }
 定义 可变 输出 = []
 i = 0
 当 (i < n) {
 追加(输出, (输入[i] - 均值) * 缩放因子[i] / 标准差 + 偏移因子[i])
 i = i + 1
 }
 返回 输出
}

// 均方根归一化层 (LLaMA风格, 0)
函数 变换_rms归一化(输入, 缩放因子) { 定义 n = 计数(输入)
 定义 可变 平方和 = 0
 定义 可变 i = 0
 当 (i < n) {
 平方和 = 平方和 + 输入[i] * 输入[i] / 变换精度
 i = i + 1
 }
 定义 可变 均方根值 = 变换_开方(平方和 / n)
 如果 (均方根值 == 0) { 均方根值 = 1 }
 定义 可变 输出 = []
 i = 0
 当 (i < n) {
 追加(输出, 输入[i] * 缩放因子[i] / 均方根值)
 i = i + 1
 }
 返回 输出
}

// SwiGLU激活 (LLaMA FFN)
函数 swiglu_前向(输入, w_gate, w_up, w_down, 模型维度, 前馈维度) {
 // 门控值 = x @ W_gate, up = x @ W_up
 定义 可变 门控值 = []
 定义 可变 up = []
 定义 可变 i = 0
 当 (i < 前馈维度) { 定义 可变 g = 0
 定义 可变 u = 0
 定义 可变 j = 0
 当 (j < 模型维度) {
 g = g + 输入[j] * w_gate[j * 前馈维度 + i] / 变换精度
 u = u + 输入[j] * w_up[j * 前馈维度 + i] / 变换精度
 j = j + 1
 }
 // Swish(门控值) = 门控值 * S形函数(门控值)
 定义 可变 信号值 = 变换精度 / 2 + g / 4
 如果 (信号值 > 变换精度) { 信号值 = 变换精度 }
 如果 (信号值 < 0) { 信号值 = 0 }
 追加(门控值, g * 信号值 / 变换精度)
 追加(up, u)
 i = i + 1
 }
 // 输出 = (自门控激活(门控值) * up) @ W_down
 定义 可变 输出 = []
 i = 0
 当 (i < 模型维度) { 定义 可变 和 = 0
 定义 可变 j2 = 0
 当 (j2 < 前馈维度) {
 和 = 和 + 门控值[j2] * up[j2] / 变换精度 * w_down[j2 * 模型维度 + i] / 变换精度
 j2 = j2 + 1
 }
 追加(输出, 和)
 i = i + 1
 }
 返回 输出
}

// 旋转位置编码 RoPE (LLaMA/GPT-NeoX)
函数 rope_编码(向量, 位置, 模型维度) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 模型维度 / 2) { 定义 频率 = 变换精度 / ((i + 1) * 10 + 100)
 定义 角度 = 位置 * 频率
 定义 sin_v = 变换_sin近似(角度)
 定义 余弦向量 = 变换_cos近似(角度)
 定义 x0 = 向量[2 * i]
 定义 x1 = 向量[2 * i + 1]
 追加(结果, (x0 * 余弦向量 - x1 * sin_v) / 变换精度)
 追加(结果, (x0 * sin_v + x1 * 余弦向量) / 变换精度)
 i = i + 1
 }
 返回 结果
}

// KV缓存 (推理加速)

函数 kv缓存_追加(缓存, 新K, 新V) {
 追加(缓存[0], 新K)
 追加(缓存[1], 新V)
}

// 内部工具
函数 变换_开方(n) { 返回 开方(n) }
函数 变换_矩阵创建(行, 列) { 定义 可变 m = [行, 列]
 定义 可变 i = 0
 当 (i < 行 * 列) { 追加(m, 0) i = i + 1 }
 返回 m
}

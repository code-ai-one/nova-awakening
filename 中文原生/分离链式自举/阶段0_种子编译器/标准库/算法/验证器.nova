//    ISBN验证: 编码自携纠错能力 (构造性见证)
//    格式验证: 结构性自指 (数据自描述其格式)
//    金行特性: 去伪存真, 精确判定
//    验证是金克木: 用规则(金)约束数据(木)的生长
//    输入: 串量词 (待验证数据)
//    输出: 个量词 (布尔判定值)

// 简单邮箱格式验证
函数 验证_邮箱(文本) {
    定义 可变 有at = 0
    定义 可变 at位 = -1
    定义 可变 有点 = 0
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        定义 c = 字节取(文本, i)
        如果 (c == 64) { 有at = 有at + 1 at位 = i }
        如果 (c == 字符_句点 且 at位 >= 0) { 有点 = 1 }
        i = i + 1
    }
    如果 (有at != 1) { 返回 0 }
    如果 (at位 == 0 或 at位 == 字节长度(文本) - 1) { 返回 0 }
    如果 (有点 == 0) { 返回 0 }
    返回 1
}

// IPv4 验证
函数 验证_IPv4(文本) {
    定义 可变 段 = 0
    定义 可变 当前值 = 0
    定义 可变 数字计 = 0
    定义 可变 i = 0
    当 (i <= 字节长度(文本)) {
        定义 可变 是点 = 0
        如果 (i == 字节长度(文本)) { 是点 = 1 }
        否则 如果 (字节取(文本, i) == 字符_句点) { 是点 = 1 }
        如果 (是点 == 1) {
            如果 (数字计 == 0 或 数字计 > 3) { 返回 0 }
            如果 (当前值 > 255) { 返回 0 }
            段 = 段 + 1
            当前值 = 0
            数字计 = 0
        } 否则 {
            定义 c = 字节取(文本, i)
            如果 (c < 48 或 c > 57) { 返回 0 }
            当前值 = 当前值 * 10 + c - 48
            数字计 = 数字计 + 1
        }
        i = i + 1
    }
    返回 段 == 4
}

// Luhn算法 (信用卡号验证)
函数 验证_Luhn(数字串) {
    定义 n = 字节长度(数字串)
    定义 可变 总和 = 0
    定义 可变 奇偶 = 0
    定义 可变 i = n - 1
    当 (i >= 0) {
        定义 可变 d = 字节取(数字串, i) - 48
        如果 (d < 0 或 d > 9) { 返回 0 }
        如果 (奇偶 == 1) {
            d = d * 2
            如果 (d > 9) { d = d - 9 }
        }
        总和 = 总和 + d
        奇偶 = 1 - 奇偶
        i = i - 1
    }
    返回 总和 % 10 == 0
}

// ISBN-10 验证
函数 验证_ISBN10(文本) {
    定义 可变 总和 = 0
    定义 可变 权重 = 10
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        定义 c = 字节取(文本, i)
        如果 (c == 字符_减号) { i = i + 1 } 否则 {
            定义 可变 d = 0
            如果 (c >= 字符_零 且 c <= 字符_九) { d = c - 48 }
            否则 如果 (c == 88 或 c == 120) { d = 10 }
            否则 { 返回 0 }
            总和 = 总和 + d * 权重
            权重 = 权重 - 1
            i = i + 1
        }
    }
    如果 (权重 != 0) { 返回 0 }
    返回 总和 % 11 == 0
}

// 是否纯数字
函数 验证_纯数字(文本) {
    如果 (字节长度(文本) == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        定义 c = 字节取(文本, i)
        如果 (c < 48 或 c > 57) { 返回 0 }
        i = i + 1
    }
    返回 1
}

// 是否纯字母
函数 验证_纯字母(文本) {
    如果 (字节长度(文本) == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        定义 c = 字节取(文本, i)
        如果 (!((c >= 字符_大写A 且 c <= 字符_大写Z) 或 (c >= 字符_小写a 且 c <= 字符_小写z))) { 返回 0 }
        i = i + 1
    }
    返回 1
}

// 是否字母数字
函数 验证_字母数字(文本) {
    如果 (字节长度(文本) == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        定义 c = 字节取(文本, i)
        如果 (!((c >= 字符_大写A 且 c <= 字符_大写Z) 或 (c >= 字符_小写a 且 c <= 字符_小写z) 或 (c >= 字符_零 且 c <= 字符_九))) { 返回 0 }
        i = i + 1
    }
    返回 1
}

// 密码强度检查 (返回0-4)
函数 验证_密码强度(密码) {
    定义 长 = 字节长度(密码)
    定义 可变 分 = 0
    如果 (长 >= 8) { 分 = 分 + 1 }
    定义 可变 有大写 = 0
    定义 可变 有小写 = 0
    定义 可变 有数字 = 0
    定义 可变 有特殊 = 0
    定义 可变 i = 0
    当 (i < 长) {
        定义 c = 字节取(密码, i)
        如果 (c >= 字符_大写A 且 c <= 字符_大写Z) { 有大写 = 1 }
        如果 (c >= 字符_小写a 且 c <= 字符_小写z) { 有小写 = 1 }
        如果 (c >= 字符_零 且 c <= 字符_九) { 有数字 = 1 }
        如果 (c >= 33 且 c <= 字符_斜杠) 或 (c >= 字符_冒号 且 c <= 64) { 有特殊 = 1 }
        i = i + 1
    }
    分 = 分 + 有大写 + 有小写 + 有数字 + 有特殊
    如果 (分 > 4) { 分 = 4 }
    返回 分
}

// 括号平衡检查
函数 验证_括号平衡(文本) {
    定义 可变 圆 = 0
    定义 可变 方 = 0
    定义 可变 花 = 0
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        定义 c = 字节取(文本, i)
        如果 (c == 字符_左圆括) { 圆 = 圆 + 1 }
        如果 (c == 字符_右圆括) { 圆 = 圆 - 1 }
        如果 (c == 字符_左方括) { 方 = 方 + 1 }
        如果 (c == 字符_右方括) { 方 = 方 - 1 }
        如果 (c == 字符_左花括) { 花 = 花 + 1 }
        如果 (c == 字符_右花括) { 花 = 花 - 1 }
        如果 (圆 < 0 或 方 < 0 或 花 < 0) { 返回 0 }
        i = i + 1
    }
    返回 圆 == 0 且 方 == 0 且 花 == 0
}

// 日期格式验证 (YYYY-MM-DD)
函数 验证_日期格式(文本) {
    如果 (字节长度(文本) != 10) { 返回 0 }
    如果 (字节取(文本, 4) != 字符_减号 或 字节取(文本, 7) != 字符_减号) { 返回 0 }
    定义 可变 i = 0
    当 (i < 10) {
        如果 (i != 4 且 i != 7) {
            定义 c = 字节取(文本, i)
            如果 (c < 48 或 c > 57) { 返回 0 }
        }
        i = i + 1
    }
    返回 1
}

// 十六进制字符串验证
函数 验证_十六进制(文本) {
    如果 (字节长度(文本) == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        定义 c = 字节取(文本, i)
        如果 (!((c >= 字符_零 且 c <= 字符_九) 或 (c >= 字符_大写A 且 c <= 70) 或 (c >= 字符_小写a 且 c <= 字符_小写f))) { 返回 0 }
        i = i + 1
    }
    返回 1
}

// 范围验证
函数 验证器_验证_范围(值, 最小, 最大) {
    返回 值 >= 最小 且 值 <= 最大
}

函数 验证_非负(值) { 返回 值 >= 0 }
函数 验证_正数(值) { 返回 值 > 0 }

// 列表验证
函数 验证_非空列表(列表) {
    返回 计数(列表) > 0
}

函数 验证_列表长度(列表, 期望长度) {
    返回 计数(列表) == 期望长度
}

函数 验证_所有正数(列表) {
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] <= 0) { 返回 假 }
        i = i + 1
    }
    返回 真
}

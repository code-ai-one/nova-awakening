定义 可变 辅助_内存读取数 = 0

// §1 有符号内存读取

函数 内存_读16_有符号(地址) {
    辅助_内存读取数 = 辅助_内存读取数 + 1
    定义 v = 内存_读16(地址)
    如果 (v >= 0x8000) { 返回 v - 0x10000 }
    返回 v
}

函数 内存_读8_有符号(地址) {
    辅助_内存读取数 = 辅助_内存读取数 + 1
    定义 v = 内存_读8(地址)
    如果 (v >= 0x80) { 返回 v - 0x100 }
    返回 v
}

函数 内存_读32_有符号(地址) {
    辅助_内存读取数 = 辅助_内存读取数 + 1
    定义 v = 内存_读32(地址)
    如果 (v >= 0x80000000) { 返回 v - 0x100000000 }
    返回 v
}

// 读取变长整数 (LEB128编码)
函数 内存_读LEB128(地址) {
    辅助_内存读取数 = 辅助_内存读取数 + 1
    定义 可变 结果 = 0
    定义 可变 移位 = 0
    定义 可变 pos = 地址
    定义 可变 字节 = 0
    循环 {
        字节 = 内存_读8(pos)
        结果 = 结果 | ((字节 & 0x7F) << 移位)
        pos = pos + 1
        移位 = 移位 + 7
        如果 ((字节 & 0x80) == 0) { 跳出 }
        如果 (移位 >= 35) { 跳出 }   // 防止无限循环
    }
    返回 [结果, pos - 地址]  // [值, 字节数]
}

// 有符号LEB128
函数 内存_读SLEB128(地址) {
    辅助_内存读取数 = 辅助_内存读取数 + 1
    定义 可变 结果 = 0
    定义 可变 移位 = 0
    定义 可变 pos = 地址
    定义 可变 字节 = 0
    循环 {
        字节 = 内存_读8(pos)
        结果 = 结果 | ((字节 & 0x7F) << 移位)
        pos = pos + 1
        移位 = 移位 + 7
        如果 ((字节 & 0x80) == 0) { 跳出 }
        如果 (移位 >= 35) { 跳出 }
    }
    // 符号扩展
    如果 (移位 < 64 && (字节 & 0x40) != 0) {
        结果 = 结果 | (0 - (1 << 移位))
    }
    返回 [结果, pos - 地址]
}

// §2 JSValue类型检查

函数 JSValue_获取类型(v) {
    如果 (v == 0) { 返回 JS类型_Undefined }
    返回 内存_读32(v)
}

函数 JSValue_获取字符串(v) {
    如果 (v == 0) { 返回 0 }
    如果 (内存_读32(v) != JS类型_String) { 返回 0 }
    返回 内存_读64(v + 24)
}

函数 JSValue_获取数值(v) {
    如果 (v == 0) { 返回 0 }
    如果 (内存_读32(v) != JS类型_Number) { 返回 0 }
    返回 内存_读64(v + 8)
}

函数 JSValue_获取布尔(v) {
    如果 (v == 0) { 返回 假 }
    如果 (内存_读32(v) != JS类型_Boolean) { 返回 假 }
    返回 内存_读64(v + 8) != 0
}

函数 JSValue_IsNull(v) {
    辅助_类型检查数 = 辅助_类型检查数 + 1
    如果 (v == 0) { 返回 真 }
    返回 内存_读32(v) == JS类型_Null
}

函数 JSValue_IsUndefined(v) {
    辅助_类型检查数 = 辅助_类型检查数 + 1
    如果 (v == 0) { 返回 真 }
    返回 内存_读32(v) == JS类型_Undefined
}

函数 JSValue_IsNullOrUndefined(v) {
    返回 JSValue_IsNull(v) || JSValue_IsUndefined(v)
}

函数 JSValue_IsObject(v) {
    辅助_类型检查数 = 辅助_类型检查数 + 1
    如果 (v == 0) { 返回 假 }
    定义 类型 = 内存_读32(v)
    返回 类型 >= JS类型_Object
}

函数 JSValue_IsBoolean(v) {
    辅助_类型检查数 = 辅助_类型检查数 + 1
    如果 (v == 0) { 返回 假 }
    返回 内存_读32(v) == JS类型_Boolean
}

函数 JSValue_IsNumber(v) {
    辅助_类型检查数 = 辅助_类型检查数 + 1
    如果 (v == 0) { 返回 假 }
    返回 内存_读32(v) == JS类型_Number
}

函数 JSValue_IsString(v) {
    辅助_类型检查数 = 辅助_类型检查数 + 1
    如果 (v == 0) { 返回 假 }
    返回 内存_读32(v) == JS类型_String
}

函数 JSValue_IsSymbol(v) {
    辅助_类型检查数 = 辅助_类型检查数 + 1
    如果 (v == 0) { 返回 假 }
    返回 内存_读32(v) == JS类型_Symbol
}

函数 JSValue_IsFunction(v) {
    辅助_类型检查数 = 辅助_类型检查数 + 1
    如果 (v == 0) { 返回 假 }
    定义 类型 = 内存_读32(v)
    返回 类型 == JS类型_Function
}

函数 JSValue_IsArray(v) {
    辅助_类型检查数 = 辅助_类型检查数 + 1
    如果 (v == 0) { 返回 假 }
    定义 类型 = 内存_读32(v)
    返回 类型 == JS类型_Array
}

// §3 类型转换 (Abstract Operations)

函数 JSValue_ToBoolean(v) {
    辅助_类型转换数 = 辅助_类型转换数 + 1
    如果 (v == 0) { 返回 假 }
    定义 类型 = 内存_读32(v)
    如果 (类型 == JS类型_Undefined || 类型 == JS类型_Null) { 返回 假 }
    如果 (类型 == JS类型_Boolean) { 返回 内存_读64(v + 8) != 0 }
    如果 (类型 == JS类型_Number) {
        定义 n = 内存_读64(v + 8)
        返回 n != 0
    }
    如果 (类型 == JS类型_String) {
        定义 len = 内存_读32(v + 16)
        返回 len > 0
    }
    返回 真  // objects are truthy
}

函数 JSValue_ToNumber(v) {
    辅助_类型转换数 = 辅助_类型转换数 + 1
    如果 (v == 0) { 返回 0 }
    定义 类型 = 内存_读32(v)
    如果 (类型 == JS类型_Number) { 返回 内存_读64(v + 8) }
    如果 (类型 == JS类型_Boolean) {
        如果 (内存_读64(v + 8) != 0) { 返回 1 }
        返回 0
    }
    如果 (类型 == JS类型_Null) { 返回 0 }
    如果 (类型 == JS类型_Undefined) { 返回 JS_NaN }
    返回 JS_NaN
}

函数 JSValue_ToInt32(v) {
    辅助_类型转换数 = 辅助_类型转换数 + 1
    定义 n = JSValue_ToNumber(v)
    如果 (n >= 0x80000000) { 返回 n - 0x100000000 }
    返回 n & 0xFFFFFFFF
}

函数 JSValue_ToUint32(v) {
    辅助_类型转换数 = 辅助_类型转换数 + 1
    定义 n = JSValue_ToNumber(v)
    返回 n & 0xFFFFFFFF
}

// §4 typeof 运算符

函数 JSValue_Typeof(v) {
    如果 (v == 0) { 返回 "undefined" }
    定义 类型 = 内存_读32(v)
    如果 (类型 == JS类型_Undefined) { 返回 "undefined" }
    如果 (类型 == JS类型_Null) { 返回 "object" }  // typeof null === "object"
    如果 (类型 == JS类型_Boolean) { 返回 "boolean" }
    如果 (类型 == JS类型_Number) { 返回 "number" }
    如果 (类型 == JS类型_String) { 返回 "string" }
    如果 (类型 == JS类型_Symbol) { 返回 "symbol" }
    如果 (类型 == JS类型_Function) { 返回 "function" }
    返回 "object"
}

// §5 相等比较

函数 JSValue_StrictEquals(a, b) {
    如果 (a == 0 && b == 0) { 返回 真 }
    如果 (a == 0 || b == 0) { 返回 假 }
    定义 类型a = 内存_读32(a)
    定义 类型b = 内存_读32(b)
    如果 (类型a != 类型b) { 返回 假 }
    如果 (类型a == JS类型_Undefined || 类型a == JS类型_Null) { 返回 真 }
    如果 (类型a == JS类型_Number) {
        返回 内存_读64(a + 8) == 内存_读64(b + 8)
    }
    如果 (类型a == JS类型_Boolean) {
        返回 内存_读64(a + 8) == 内存_读64(b + 8)
    }
    如果 (类型a == JS类型_String) {
        返回 JSValue_字符串相等(a, b)
    }
    返回 a == b  // 对象比较引用
}

函数 JSValue_字符串相等(a, b) {
    定义 len_a = 内存_读32(a + 16)
    定义 len_b = 内存_读32(b + 16)
    如果 (len_a != len_b) { 返回 假 }
    定义 ptr_a = 内存_读64(a + 24)
    定义 ptr_b = 内存_读64(b + 24)
    定义 可变 i = 0
    当 (i < len_a) {
        如果 (内存_读8(ptr_a + i) != 内存_读8(ptr_b + i)) { 返回 假 }
        i = i + 1
    }
    返回 真
}

// §6 值构造

函数 JSValue_创建数值(n) {
    辅助_值创建数 = 辅助_值创建数 + 1
    定义 v = 堆_分配(32)
    内存_写32(v, JS类型_Number)
    内存_写64(v + 8, n)
    返回 v
}

函数 JSValue_创建布尔(b) {
    辅助_值创建数 = 辅助_值创建数 + 1
    定义 v = 堆_分配(32)
    内存_写32(v, JS类型_Boolean)
    内存_写64(v + 8, 如果(b, 1, 0))
    返回 v
}

函数 JSValue_创建Null() {
    辅助_值创建数 = 辅助_值创建数 + 1
    定义 v = 堆_分配(32)
    内存_写32(v, JS类型_Null)
    返回 v
}

函数 JSValue_创建Undefined() {
    辅助_值创建数 = 辅助_值创建数 + 1
    定义 v = 堆_分配(32)
    内存_写32(v, JS类型_Undefined)
    返回 v
}


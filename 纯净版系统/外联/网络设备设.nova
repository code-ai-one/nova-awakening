导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("./前缀长度转.nova")
导入("./网络设备启.nova")
导入("../中枢/字符串替换.nova")
导入("./网络设备分.nova")

// IP地址配置

函数 网络设备_设置IP(dev, ip, 掩码) {
    dev.ip地址 = ip
    dev.子网掩码 = 掩码

    // 自动添加直连路由
    定义 网络地址 = ip & 掩码
    定义 前缀长度 = 掩码_转前缀长度(掩码)
    路由_添加直连(网络地址, 前缀长度, dev)

    // 添加本地路由
    路由_添加本地(ip, dev)

    内核信息("网络设备 %s: IP=%s/%d\n",
        dev.名称, IP地址_转字符串(ip), 前缀长度)
}

函数 网络设备_设置网关(dev, 网关) {
    dev.网关 = 网关
    路由_添加默认(网关, dev)
}

函数 网络设备_设置MTU(dev, 新mtu) {
    如果 (新mtu < 网络设备_MTU_最小 || 新mtu > 网络设备_MTU_最大) {
        返回 错误码_无效参数
    }
    如果 (dev.操作.设置MTU != 空) {
        定义 结果 = dev.操作.设置MTU(dev, 新mtu)
        如果 (结果 != 0) { 返回 结果 }
    }
    dev.mtu = 新mtu
    返回 0
}

// 查找

函数 网络设备_按名称查找(名称) {
    定义 可变 i = 0
    当 (i < 网络设备数量) {
        定义 dev = 网络设备表[i]
        如果 (dev != 空 && dev.名称 == 名称) {
            返回 dev
        }
        i = i + 1
    }
    返回 空
}

函数 网络设备_按索引查找(索引) {
    定义 可变 i = 0
    当 (i < 网络设备数量) {
        定义 dev = 网络设备表[i]
        如果 (dev != 空 && dev.索引 == 索引) {
            返回 dev
        }
        i = i + 1
    }
    返回 空
}

函数 获取本地IP() {
    // 返回第一个非loopback设备的IP
    定义 可变 i = 0
    当 (i < 网络设备数量) {
        定义 dev = 网络设备表[i]
        如果 (dev != 空 && dev.ip地址 != 0 && !(dev.标志 & IFF_LOOPBACK)) {
            返回 dev.ip地址
        }
        i = i + 1
    }
    返回 0
}

// loopback设备

函数 loopback_初始化() {
    定义 可变 操作 = 网络设备操作 {}
    操作.发送 = loopback_发送
    操作.打开 = loopback_打开

    定义 dev = 网络设备_分配("lo", 操作, 0)
    dev.标志 = IFF_LOOPBACK | IFF_UP | IFF_RUNNING
    dev.mtu = 65535
    内存置零(dev.mac地址, 6)

    网络设备_注册(dev)
    网络设备_设置IP(dev, 0x7F000001, 0xFF000000)  // 127.0.0.1/8
}

函数 loopback_打开(dev) {
    // 打开回环设备(lo): 设置IFF_UP标志
    如果 (dev != 空) {
        dev.标志 = dev.标志 | 1  // IFF_UP
        内核信息("网络: lo 回环设备已启动")
    }
    返回 成功
}

函数 loopback_发送(Nova缓冲) {
    // loopback: 直接将发送的包作为接收包处理
    网络设备_接收(Nova缓冲)
    返回 0
}

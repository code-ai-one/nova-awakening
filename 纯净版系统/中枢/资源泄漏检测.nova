导入("./类型定义.nova")
导入("./错误码.nova")
导入("./整数转字符串.nova")
导入("./内核打印.nova")

// NovaOS · 资源泄漏检测器
// §1 跟踪资源类型: 文件描述符 / 内存块 / 套接字 / 定时器 / 锁
// §2 分配/释放配对检查
// §3 进程退出时泄漏报告
// §4 周期性扫描 (长寿命进程)


定义 资源_文件描述符 = 0
定义 资源_内存块 = 1
定义 资源_套接字 = 2
定义 资源_定时器 = 3
定义 资源_锁 = 4
定义 资源_管道 = 5

结构 资源记录 {
    类型,           // u32 资源_*
    标识,           // u64 (fd号/内存地址/socket号)
    PID,
    分配时间,
    分配调用栈,     // 字符串 (简化: 调用者名)
    已释放,
}

定义 可变 _资源表 = []
定义 可变 _泄漏检测启用 = 假
定义 可变 _总分配数 = 0
定义 可变 _总释放数 = 0
定义 可变 _已报告泄漏数 = 0


函数 泄漏检测_启用() { _泄漏检测启用 = 真 }
函数 泄漏检测_禁用() { _泄漏检测启用 = 假 }

函数 泄漏_记录分配(类型, 标识, PID, 调用者) {
    如果 (!_泄漏检测启用) { 返回 }
    _总分配数 = _总分配数 + 1
    定义 记录 = 资源记录 {}
    记录.类型 = 类型
    记录.标识 = 标识
    记录.PID = PID
    记录.分配时间 = 读取毫秒() / 1000
    记录.分配调用栈 = 调用者
    记录.已释放 = 假
    追加(_资源表, 记录)
}

函数 泄漏_记录释放(类型, 标识) {
    如果 (!_泄漏检测启用) { 返回 }
    _总释放数 = _总释放数 + 1
    定义 可变 i = 计数(_资源表) - 1
    当 (i >= 0) {
        如果 (_资源表[i].类型 == 类型 && _资源表[i].标识 == 标识 && !_资源表[i].已释放) {
            _资源表[i].已释放 = 真
            返回
        }
        i = i - 1
    }
    // 释放了未跟踪的资源 → double-free 嫌疑
    内核警告("泄漏检测: 可能double-free " + 资源_类型名(类型) + " #" + 整数转字符串(标识))
}


函数 泄漏_检查PID(PID) {
    定义 可变 泄漏 = []
    定义 可变 i = 0
    当 (i < 计数(_资源表)) {
        如果 (_资源表[i].PID == PID && !_资源表[i].已释放) {
            追加(泄漏, _资源表[i])
        }
        i = i + 1
    }
    返回 泄漏
}

函数 泄漏_报告PID(PID) {
    定义 泄漏 = 泄漏_检查PID(PID)
    如果 (计数(泄漏) == 0) { 返回 "" }

    _已报告泄漏数 = _已报告泄漏数 + 计数(泄漏)
    定义 可变 r = "⚠ 进程 " + 整数转字符串(PID) + " 资源泄漏: " + 整数转字符串(计数(泄漏)) + " 项\n"
    定义 可变 i = 0
    当 (i < 计数(泄漏) && i < 20) {
        定义 rec = 泄漏[i]
        r = r + "  " + 资源_类型名(rec.类型) + " #" + 整数转字符串(rec.标识)
        r = r + " @ " + rec.分配调用栈 + "\n"
        i = i + 1
    }
    如果 (计数(泄漏) > 20) { r = r + "  ... 还有 " + 整数转字符串(计数(泄漏) - 20) + " 项\n" }
    返回 r
}

函数 泄漏_全局扫描(当前时间, 超时秒) {
    // 找出存活超过超时秒的未释放资源
    定义 可变 可疑 = []
    定义 可变 i = 0
    当 (i < 计数(_资源表)) {
        如果 (!_资源表[i].已释放 && 当前时间 - _资源表[i].分配时间 > 超时秒) {
            追加(可疑, _资源表[i])
        }
        i = i + 1
    }
    返回 可疑
}

函数 泄漏_清理已释放() {
    // 从跟踪表中移除已释放记录(减少内存占用)
    定义 可变 i = 0
    当 (i < 计数(_资源表)) {
        如果 (_资源表[i].已释放) {
            列表_移除(_资源表, i)
        } 否则 {
            i = i + 1
        }
    }
}


函数 资源_类型名(类型) {
    如果 (类型 == 资源_文件描述符) { 返回 "fd" }
    如果 (类型 == 资源_内存块) { 返回 "mem" }
    如果 (类型 == 资源_套接字) { 返回 "sock" }
    如果 (类型 == 资源_定时器) { 返回 "timer" }
    如果 (类型 == 资源_锁) { 返回 "lock" }
    如果 (类型 == 资源_管道) { 返回 "pipe" }
    返回 "unknown"
}

函数 泄漏_统计() {
    定义 可变 未释放 = 0
    定义 可变 i = 0
    当 (i < 计数(_资源表)) {
        如果 (!_资源表[i].已释放) { 未释放 = 未释放 + 1 }
        i = i + 1
    }
    返回 [_总分配数, _总释放数, 未释放, _已报告泄漏数]
}

函数 泄漏_报告() {
    定义 统计 = 泄漏_统计()
    定义 可变 r = "═══ 资源泄漏检测器 ═══\n"
    r = r + "状态: "
    如果 (_泄漏检测启用) { r = r + "启用\n" } 否则 { r = r + "禁用\n" }
    r = r + "总分配: " + 整数转字符串(统计[0]) + "\n"
    r = r + "总释放: " + 整数转字符串(统计[1]) + "\n"
    r = r + "当前未释放: " + 整数转字符串(统计[2]) + "\n"
    r = r + "已报告泄漏: " + 整数转字符串(统计[3]) + "\n"
    返回 r
}

函数 泄漏_重置() {
    _资源表 = []
    _总分配数 = 0
    _总释放数 = 0
    _已报告泄漏数 = 0
}

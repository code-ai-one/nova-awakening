导入("../执行/平台时间.nova")

定义 每日秒 = 86400
定义 每时秒 = 3600
定义 每分秒 = 60
定义 月天数表 = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]

函数 时间_现在秒() { 返回 平台_获取墙钟秒() }
函数 时间_现在微秒() { 返回 平台_获取墙钟微秒() }
函数 时间_单调微秒() { 返回 平台_获取高精度时间() }

函数 时间_是闰年(年) {
    如果 (年 % 400 == 0) { 返回 真 }
    如果 (年 % 100 == 0) { 返回 假 }
    如果 (年 % 4 == 0) { 返回 真 }
    返回 假
}

函数 时间_年天数(年) {
    如果 (时间_是闰年(年)) { 返回 366 }
    返回 365
}

函数 时间_月天数(年, 月) {
    如果 (月 < 1 || 月 > 12) { 返回 30 }
    定义 天 = 月天数表[月 - 1]
    如果 (月 == 2 && 时间_是闰年(年)) { 天 = 天 + 1 }
    返回 天
}

函数 时间_秒转日期(秒) {
    定义 可变 剩余天 = 秒 / 每日秒
    定义 可变 年 = 1970
    当 (剩余天 >= 时间_年天数(年)) {
        剩余天 = 剩余天 - 时间_年天数(年)
        年 = 年 + 1
    }
    定义 可变 月 = 1
    当 (月 <= 12 && 剩余天 >= 时间_月天数(年, 月)) {
        剩余天 = 剩余天 - 时间_月天数(年, 月)
        月 = 月 + 1
    }
    定义 日 = 剩余天 + 1
    定义 时 = (秒 % 每日秒) / 每时秒
    定义 分 = (秒 % 每时秒) / 每分秒
    定义 秒余 = 秒 % 每分秒
    返回 [年, 月, 日, 时, 分, 秒余]
}

函数 时间_日期转秒(年, 月, 日, 时, 分, 秒) {
    定义 可变 总天 = 0
    定义 可变 当年 = 1970
    当 (当年 < 年) {
        总天 = 总天 + 时间_年天数(当年)
        当年 = 当年 + 1
    }
    定义 可变 当月 = 1
    当 (当月 < 月) {
        总天 = 总天 + 时间_月天数(年, 当月)
        当月 = 当月 + 1
    }
    总天 = 总天 + 日 - 1
    返回 总天 * 每日秒 + 时 * 每时秒 + 分 * 每分秒 + 秒
}

函数 时间_星期几(秒) {
    定义 天 = 秒 / 每日秒
    返回 (天 + 4) % 7
}

函数 时间_补零(数值) {
    如果 (数值 < 10) { 返回 "0" }
    返回 ""
}

函数 时间_格式化时分秒(秒) {
    定义 时 = (秒 % 每日秒) / 每时秒
    定义 分 = (秒 % 每时秒) / 每分秒
    定义 秒余 = 秒 % 每分秒
    返回 [时, 分, 秒余]
}

函数 时间_差值秒(起始秒, 结束秒) {
    返回 结束秒 - 起始秒
}

函数 时间_增加天(秒, 天数) {
    返回 秒 + 天数 * 每日秒
}

函数 时间_增加时(秒, 小时数) {
    返回 秒 + 小时数 * 每时秒
}

结构 计时器 {
    起始微秒,
    暂停微秒,
    已暂停,
    累计微秒,
}

函数 计时器_创建() {
    定义 计 = 堆_分配(计时器)
    计.起始微秒 = 平台_获取高精度时间()
    计.暂停微秒 = 0
    计.已暂停 = 假
    计.累计微秒 = 0
    返回 计
}

函数 计时器_经过(计) {
    如果 (计 == 0) { 返回 0 }
    如果 (计.已暂停) { 返回 计.累计微秒 }
    返回 计.累计微秒 + (平台_获取高精度时间() - 计.起始微秒)
}

函数 计时器_暂停(计) {
    如果 (计 == 0 || 计.已暂停) { 返回 }
    计.累计微秒 = 计.累计微秒 + (平台_获取高精度时间() - 计.起始微秒)
    计.已暂停 = 真
}

函数 计时器_恢复(计) {
    如果 (计 == 0 || !计.已暂停) { 返回 }
    计.起始微秒 = 平台_获取高精度时间()
    计.已暂停 = 假
}

函数 计时器_重置(计) {
    如果 (计 == 0) { 返回 }
    计.起始微秒 = 平台_获取高精度时间()
    计.累计微秒 = 0
    计.已暂停 = 假
}

函数 计时器_经过毫秒(计) { 返回 计时器_经过(计) / 1000 }
函数 计时器_经过秒(计) { 返回 计时器_经过(计) / 1000000 }

函数 时间_度量(回调) {
    定义 开始 = 平台_获取高精度时间()
    如果 (回调 != 0) { 回调() }
    返回 平台_获取高精度时间() - 开始
}

函数 时间_人类可读(微秒) {
    如果 (微秒 < 1000) { 返回 "微秒" }
    如果 (微秒 < 1000000) { 返回 "毫秒" }
    如果 (微秒 < 60000000) { 返回 "秒" }
    如果 (微秒 < 3600000000) { 返回 "分钟" }
    返回 "小时"
}

函数 时间_延迟微秒(微秒) { 平台_睡眠微秒(微秒) }
函数 时间_延迟毫秒(毫秒) { 平台_睡眠微秒(毫秒 * 1000) }
函数 时间_延迟秒(秒) { 平台_睡眠微秒(秒 * 1000000) }

定义 可变 AI_原生时间_调用数 = 0
定义 可变 AI_原生时间_异常数 = 0

函数 AI_原生时间_监控() {
    AI_原生时间_调用数 = AI_原生时间_调用数 + 1
    返回 AI_原生时间_异常数 == 0
}

函数 AI_原生时间_健康检查() {
    如果 (AI_原生时间_调用数 > 0 && AI_原生时间_异常数 * 100 / AI_原生时间_调用数 > 10) {
        返回 假
    }
    返回 真
}

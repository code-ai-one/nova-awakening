导入("./中断管理系统.nova")
导入("./页表重建.nova")
导入("./处理写时复.nova")
导入("./页表遍历.nova")
导入("./内核映射.nova")
导入("./页表映射.nova")
导入("../标准/原生字符串.nova")
导入("./内存系统调用.nova")
导入("./内存映射.nova")
导入("./整数转字符串.nova")
导入("./虚分配故障.nova")
导入("./系统堆扩展.nova")
导入("./虚拟内存区.nova")
导入("./缺页异常处.nova")
导入("./内存映射完.nova")

定义 虚拟模式_用户 = "用户"
定义 虚拟模式_内核 = "内核"
定义 虚拟模式_混合 = "混合"

结构 虚拟档 {
    名称,
    模式,
    页表,
    区域表,
    缺页数,
    COW数,
    文件页数,
    栈扩数,
    映射数,
    取消数,
    保护数,
}

结构 虚拟摘要 {
    名称,
    模式,
    页表,
    区域数,
    映射数,
    缺页数,
    COW数,
    文件页数,
    栈扩数,
    映射页数,
    健康,
}

定义 可变 虚拟账本 = []
定义 可变 虚拟建数 = 0

函数 虚拟布尔串(值) {
    如果 (值) { 返回 "true" }
    返回 "false"
}

函数 虚拟模式名(模式) {
    如果 (模式 == 虚拟模式_用户) { 返回 "用户" }
    如果 (模式 == 虚拟模式_内核) { 返回 "内核" }
    如果 (模式 == 虚拟模式_混合) { 返回 "混合" }
    返回 "未知"
}

函数 内存虚拟_建档(名称, 模式, 页表) {
    定义 档 = 堆_分配(虚拟档)
    如果 (档 == 0) { 返回 0 }
    档.名称 = 名称
    档.模式 = 模式
    档.页表 = 页表
    档.区域表 = []
    档.缺页数 = 0
    档.COW数 = 0
    档.文件页数 = 0
    档.栈扩数 = 0
    档.映射数 = 0
    档.取消数 = 0
    档.保护数 = 0
    返回 档
}

函数 内存虚拟_创建(名称) {
    定义 档 = 内存虚拟_建档(名称, 虚拟模式_混合, 当前PML4())
    追加(虚拟账本, 档)
    虚拟建数 = 虚拟建数 + 1
    返回 档
}

函数 内存虚拟_创建用户(名称, 页表) {
    定义 档 = 内存虚拟_建档(名称, 虚拟模式_用户, 页表)
    追加(虚拟账本, 档)
    虚拟建数 = 虚拟建数 + 1
    返回 档
}

函数 内存虚拟_创建内核(名称) {
    定义 档 = 内存虚拟_建档(名称, 虚拟模式_内核, 当前PML4())
    追加(虚拟账本, 档)
    虚拟建数 = 虚拟建数 + 1
    返回 档
}

函数 内存虚拟_名称(档) { 返回 档.名称 }
函数 内存虚拟_模式(档) { 返回 档.模式 }
函数 内存虚拟_页表(档) { 返回 档.页表 }
函数 内存虚拟_区域数(档) { 返回 计数(档.区域表) }
函数 内存虚拟_映射页数(档) { 返回 Nova内存映射_总映射页数() }

函数 内存虚拟_加区域(档, vma) {
    追加(档.区域表, vma)
    返回 vma
}

函数 内存虚拟_建匿名区域(档, 起始, 结束, 标志) {
    定义 vma = VMA_创建_匿名(起始, 结束, 标志)
    内存虚拟_加区域(档, vma)
    返回 vma
}

函数 内存虚拟_建文件区域(档, 起始, 结束, 标志, 文件, 偏移) {
    定义 vma = VMA_创建_文件(起始, 结束, 标志, 文件, 偏移)
    内存虚拟_加区域(档, vma)
    返回 vma
}

函数 内存虚拟_插区域(mm, vma) {
    VMA_插入(mm, vma)
}

函数 内存虚拟_查区域(档, 地址) {
    定义 可变 i = 0
    当 (i < 计数(档.区域表)) {
        定义 vma = 档.区域表[i]
        如果 (VMA_包含(vma, 地址)) { 返回 vma }
        i = i + 1
    }
    返回 Nova内存映射_查找vma(地址)
}

函数 内存虚拟_合并相邻(档) {
    定义 可变 i = 0
    当 (i + 1 < 计数(档.区域表)) {
        定义 a = 档.区域表[i]
        定义 b = 档.区域表[i + 1]
        如果 (VMA_可合并(a, b) || VMA_邻接(a, b)) {
            档.区域表[i] = VMA_合并(a, b)
        }
        i = i + 1
    }
}

函数 内存虚拟_拆区域(档, vma, 拆分地址, 新大小) {
    返回 VMA_拆分(vma, 拆分地址, 新大小)
}

函数 内存虚拟_区域权限串(vma) {
    返回 VMA_权限字符串(vma)
}

函数 内存虚拟_区域大小(vma) {
    返回 VMA_大小(vma)
}

函数 内存虚拟_区域页数(vma) {
    返回 VMA_页数(vma)
}

函数 内存虚拟_找空闲(长度) {
    返回 Nova内存映射_找空闲区域(长度)
}

函数 内存虚拟_映射匿名(档, 地址, 长度, 保护, 标志) {
    档.映射数 = 档.映射数 + 1
    返回 do_Nova内存映射(地址, 长度, 保护, 标志, -1, 0)
}

函数 内存虚拟_映射文件(档, 地址, 长度, 保护, 标志, fd, 偏移) {
    档.映射数 = 档.映射数 + 1
    返回 do_Nova内存映射(地址, 长度, 保护, 标志, fd, 偏移)
}

函数 内存虚拟_取消映射(档, 地址, 长度) {
    档.取消数 = 档.取消数 + 1
    返回 do_munmap(地址, 长度)
}

函数 内存虚拟_保护(档, 地址, 长度, 保护) {
    档.保护数 = 档.保护数 + 1
    返回 do_mprotect(地址, 长度, 保护)
}

函数 内存虚拟_同步(档, 地址, 长度, 标志) {
    返回 do_msync(地址, 长度, 标志)
}

函数 内存虚拟_扩堆(档, 新brk) {
    返回 do_brk(新brk)
}

函数 内存虚拟_VM标志名(标志) {
    返回 Nova内存映射_VM标志名(标志)
}

函数 内存虚拟_映射单页(档, 虚拟地址, 物理地址, 标志) {
    档.映射数 = 档.映射数 + 1
    返回 映射_单页(档.页表, 虚拟地址, 物理地址, 标志)
}

函数 内存虚拟_映射范围(档, 虚拟起始, 物理起始, 大小, 标志) {
    档.映射数 = 档.映射数 + 1
    返回 映射_范围(档.页表, 虚拟起始, 物理起始, 大小, 标志)
}

函数 内存虚拟_映射散列页(档, 虚拟起始, 物理页号列表, 标志) {
    档.映射数 = 档.映射数 + 1
    返回 映射_散列页(档.页表, 虚拟起始, 物理页号列表, 标志)
}

函数 内存虚拟_大页映射(档, 虚拟地址, 物理地址, 标志) {
    档.映射数 = 档.映射数 + 1
    返回 映射_2MB大页(档.页表, 虚拟地址, 物理地址, 标志)
}

函数 内存虚拟_取消单页(档, 虚拟地址) {
    档.取消数 = 档.取消数 + 1
    返回 取消映射_单页(档.页表, 虚拟地址)
}

函数 内存虚拟_取消范围(档, 虚拟起始, 大小) {
    档.取消数 = 档.取消数 + 1
    返回 取消映射_范围(档.页表, 虚拟起始, 大小)
}

函数 内存虚拟_取消范围_释放(档, 虚拟起始, 大小) {
    档.取消数 = 档.取消数 + 1
    返回 取消映射_范围_释放(档.页表, 虚拟起始, 大小)

// NovaOS 智能体通信总线
// 多智能体间异步消息传递 + 订阅/发布 + 优先级队列
// 请求/响应/TTL/死信队列/主题路由/速率限制/统计

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/时钟中枢.nova")
导入("../中枢/内核打印.nova")

定义 总线_最大队列 = 512
定义 总线_最大订阅 = 64
定义 总线_最大死信 = 32
定义 总线_最大历史 = 128
定义 总线_默认TTL = 30000      // 30秒消息过期
定义 总线_速率限制 = 100        // 每秒最大消息数

结构 总线消息 {
    ID,
    目标,
    来源,
    类型,        // "request" / "response" / "事件" / "broadcast"
    内容,
    优先级,
    时间戳,
    TTL,         // 毫秒, 0=永不过期
    关联ID,      // 用于request/response配对
    已投递,
}

结构 订阅项 {
    智能体名,
    事件类型,
    过滤器,
    已暂停,
}

定义 可变 消息队列 = []
定义 可变 订阅表 = []
定义 可变 死信队列 = []
定义 可变 消息历史 = []
定义 可变 总线_下一ID = 1

结构 速率记录 {
    智能体名,
    窗口起始,
    计数,
}
定义 可变 速率表 = []

结构 总线统计 {
    总发送,
    总接收,
    总广播,
    总事件发布,
    请求数,
    响应数,
    过期数,
    死信数,
    速率拒绝数,
    最大队列长度,
}

定义 可变 全局_总线统计 = 空

函数 总线统计_初始化() {
    如果 (全局_总线统计 == 空) {
        全局_总线统计 = 总线统计 {}
        全局_总线统计.总发送 = 0
        全局_总线统计.总接收 = 0
        全局_总线统计.总广播 = 0
        全局_总线统计.总事件发布 = 0
        全局_总线统计.请求数 = 0
        全局_总线统计.响应数 = 0
        全局_总线统计.过期数 = 0
        全局_总线统计.死信数 = 0
        全局_总线统计.速率拒绝数 = 0
        全局_总线统计.最大队列长度 = 0
    }
}

// §1 发送

函数 总线_发送(目标, 来源, 类型, 内容, 优先级) {
    总线统计_初始化()

    // 速率限制检查
    如果 (!总线_检查速率(来源)) {
        全局_总线统计.速率拒绝数 = 全局_总线统计.速率拒绝数 + 1
        返回 -1
    }

    // 队列满检查
    如果 (计数(消息队列) >= 总线_最大队列) {
        // 清理过期消息腾出空间
        总线_清理过期()
        如果 (计数(消息队列) >= 总线_最大队列) {
            返回 -2
        }
    }

    定义 msg = 总线消息 {}
    msg.ID = 总线_下一ID
    总线_下一ID = 总线_下一ID + 1
    msg.目标 = 目标
    msg.来源 = 来源
    msg.类型 = 类型
    msg.内容 = 内容
    msg.优先级 = 优先级
    msg.时间戳 = 读取毫秒()
    msg.TTL = 总线_默认TTL
    msg.关联ID = 0
    msg.已投递 = 假
    追加(消息队列, msg)

    全局_总线统计.总发送 = 全局_总线统计.总发送 + 1
    定义 当前长度 = 计数(消息队列)
    如果 (当前长度 > 全局_总线统计.最大队列长度) {
        全局_总线统计.最大队列长度 = 当前长度
    }

    // 优先级排序: 高优先级消息前移
    如果 (当前长度 > 1 && 优先级 > 500) {
        定义 最后 = 当前长度 - 1
        定义 tmp = 消息队列[最后]
        列表_移除(消息队列, 最后)
        定义 可变 插入位 = 0
        当 (插入位 < 计数(消息队列)) {
            如果 (消息队列[插入位].优先级 < 优先级) { 跳出 }
            插入位 = 插入位 + 1
        }
        插入(消息队列, 插入位, tmp)
    }

    返回 msg.ID
}

函数 总线_发送带TTL(目标, 来源, 类型, 内容, 优先级, TTL) {
    定义 msgID = 总线_发送(目标, 来源, 类型, 内容, 优先级)
    如果 (msgID > 0) {
        // 找到刚发送的消息, 更新TTL
        定义 可变 i = 0
        当 (i < 计数(消息队列)) {
            如果 (消息队列[i].ID == msgID) {
                消息队列[i].TTL = TTL
                跳出
            }
            i = i + 1
        }
    }
    返回 msgID
}

// §2 接收

函数 总线_接收(目标) {
    总线统计_初始化()
    定义 可变 i = 0
    当 (i < 计数(消息队列)) {
        如果 (消息队列[i].目标 == 目标 || 消息队列[i].类型 == "broadcast") {
            定义 消息 = 消息队列[i]
            列表_移除(消息队列, i)
            全局_总线统计.总接收 = 全局_总线统计.总接收 + 1
            // 记入历史
            总线_记录历史(消息)
            返回 消息
        }
        i = i + 1
    }
    返回 空
}

函数 总线_接收全部(目标) {
    总线统计_初始化()
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(消息队列)) {
        如果 (消息队列[i].目标 == 目标 || 消息队列[i].类型 == "broadcast") {
            追加(结果, 消息队列[i])
            总线_记录历史(消息队列[i])
            列表_移除(消息队列, i)
            全局_总线统计.总接收 = 全局_总线统计.总接收 + 1
        } 否则 {
            i = i + 1
        }
    }
    返回 结果
}

函数 总线_接收按类型(目标, 类型) {
    定义 可变 i = 0
    当 (i < 计数(消息队列)) {
        如果 (消息队列[i].目标 == 目标 && 消息队列[i].类型 == 类型) {
            定义 消息 = 消息队列[i]
            列表_移除(消息队列, i)
            全局_总线统计.总接收 = 全局_总线统计.总接收 + 1
            总线_记录历史(消息)
            返回 消息
        }
        i = i + 1
    }
    返回 空
}

函数 总线_窥视(目标) {
    定义 可变 i = 0
    当 (i < 计数(消息队列)) {
        如果 (消息队列[i].目标 == 目标 || 消息队列[i].类型 == "broadcast") {
            返回 消息队列[i]
        }
        i = i + 1
    }
    返回 空
}

// §3 请求/响应模式

函数 总线_请求(目标, 来源, 内容) {
    总线统计_初始化()
    全局_总线统计.请求数 = 全局_总线统计.请求数 + 1
    定义 msgID = 总线_发送(目标, 来源, "request", 内容, 600)
    返回 msgID
}

函数 总线_响应(原始消息, 来源, 内容) {
    总线统计_初始化()
    如果 (原始消息 == 空) { 返回 -1 }
    全局_总线统计.响应数 = 全局_总线统计.响应数 + 1

    定义 msgID = 总线_发送(原始消息.来源, 来源, "response", 内容, 600)
    如果 (msgID > 0) {
        // 设置关联ID
        定义 可变 i = 0
        当 (i < 计数(消息队列)) {
            如果 (消息队列[i].ID == msgID) {
                消息队列[i].关联ID = 原始消息.ID
                跳出
            }
            i = i + 1
        }
    }
    返回 msgID
}

函数 总线_等待响应(请求ID, 目标) {
    定义 可变 i = 0
    当 (i < 计数(消息队列)) {
        如果 (消息队列[i].目标 == 目标 && 消息队列[i].类型 == "response" && 消息队列[i].关联ID == 请求ID) {
            定义 消息 = 消息队列[i]
            列表_移除(消息队列, i)
            全局_总线统计.总接收 = 全局_总线统计.总接收 + 1
            返回 消息
        }
        i = i + 1
    }
    返回 空
}

// §4 广播与订阅/发布

函数 总线_广播(来源, 内容) {
    总线统计_初始化()
    全局_总线统计.总广播 = 全局_总线统计.总广播 + 1
    总线_发送("*", 来源, "broadcast", 内容, 300)
}

函数 总线_订阅(智能体名, 事件类型) {
    如果 (计数(订阅表) >= 总线_最大订阅) { 返回 }
    // 检查重复订阅
    定义 可变 i = 0
    当 (i < 计数(订阅表)) {
        如果 (订阅表[i].智能体名 == 智能体名 && 订阅表[i].事件类型 == 事件类型) {
            返回  // 已订阅
        }
        i = i + 1
    }
    定义 项 = 订阅项 {}
    项.智能体名 = 智能体名
    项.事件类型 = 事件类型
    项.过滤器 = 空
    项.已暂停 = 假
    追加(订阅表, 项)
}

函数 总线_取消订阅(智能体名, 事件类型) {
    定义 可变 i = 0
    当 (i < 计数(订阅表)) {
        如果 (订阅表[i].智能体名 == 智能体名 && 订阅表[i].事件类型 == 事件类型) {
            列表_移除(订阅表, i)
            返回
        }
        i = i + 1
    }
}

函数 总线_暂停订阅(智能体名) {
    定义 可变 i = 0
    当 (i < 计数(订阅表)) {
        如果 (订阅表[i].智能体名 == 智能体名) {
            订阅表[i].已暂停 = 真
        }
        i = i + 1
    }
}

函数 总线_恢复订阅(智能体名) {
    定义 可变 i = 0
    当 (i < 计数(订阅表)) {
        如果 (订阅表[i].智能体名 == 智能体名) {
            订阅表[i].已暂停 = 假
        }
        i = i + 1
    }
}

函数 总线_发布事件(来源, 事件类型, 内容) {
    总线统计_初始化()
    全局_总线统计.总事件发布 = 全局_总线统计.总事件发布 + 1
    定义 可变 投递数 = 0
    定义 可变 i = 0
    当 (i < 计数(订阅表)) {
        如果 (订阅表[i].事件类型 == 事件类型 && !订阅表[i].已暂停) {
            总线_发送(订阅表[i].智能体名, 来源, "事件", 内容, 400)
            投递数 = 投递数 + 1
        }
        i = i + 1
    }
    返回 投递数
}

// §5 消息过期与死信

函数 总线_清理过期() {
    总线统计_初始化()
    定义 当前时间 = 读取毫秒()
    定义 可变 i = 0
    当 (i < 计数(消息队列)) {
        定义 msg = 消息队列[i]
        如果 (msg.TTL > 0) {
            定义 存活时间 = 当前时间 - msg.时间戳
            如果 (存活时间 > msg.TTL) {
                // 过期 → 移入死信队列
                列表_移除(消息队列, i)
                总线_加入死信(msg)
                全局_总线统计.过期数 = 全局_总线统计.过期数 + 1
                继续
            }
        }
        i = i + 1
    }
}

函数 总线_加入死信(msg) {
    如果 (计数(死信队列) >= 总线_最大死信) {
        // 移除最老的死信
        列表_移除(死信队列, 0)
    }
    追加(死信队列, msg)
    全局_总线统计.死信数 = 全局_总线统计.死信数 + 1
}

函数 总线_获取死信() {
    如果 (计数(死信队列) == 0) { 返回 空 }
    定义 msg = 死信队列[0]
    列表_移除(死信队列, 0)
    返回 msg
}

函数 总线_死信数() { 返回 计数(死信队列) }

// §6 消息历史

函数 总线_记录历史(msg) {
    如果 (计数(消息历史) >= 总线_最大历史) {
        列表_移除(消息历史, 0)
    }
    追加(消息历史, msg)
}

函数 总线_查询历史(来源, 最大条数) {
    定义 可变 结果 = []
    定义 可变 计 = 0
    定义 可变 i = 计数(消息历史) - 1
    当 (i >= 0 && 计 < 最大条数) {
        如果 (来源 == 空 || 消息历史[i].来源 == 来源) {
            追加(结果, 消息历史[i])
            计 = 计 + 1
        }
        i = i - 1
    }
    返回 结果
}

// §7 速率限制

函数 总线_检查速率(智能体名) {
    定义 当前时间 = 读取毫秒()
    定义 可变 i = 0
    当 (i < 计数(速率表)) {
        如果 (速率表[i].智能体名 == 智能体名) {
            如果 (当前时间 - 速率表[i].窗口起始 > 1000) {
                // 新的1秒窗口
                速率表[i].窗口起始 = 当前时间
                速率表[i].计数 = 1
                返回 真
            }
            如果 (速率表[i].计数 >= 总线_速率限制) {
                返回 假  // 超过速率限制
            }
            速率表[i].计数 = 速率表[i].计数 + 1
            返回 真
        }
        i = i + 1
    }
    // 新智能体, 创建记录
    定义 记录 = 速率记录 {}
    记录.智能体名 = 智能体名
    记录.窗口起始 = 当前时间
    记录.计数 = 1
    追加(速率表, 记录)
    返回 真
}

// §8 查询

函数 总线_待处理数() { 返回 计数(消息队列) }
函数 总线_订阅数() { 返回 计数(订阅表) }

函数 总线_待处理数_按目标(目标) {
    定义 可变 计 = 0
    定义 可变 i = 0
    当 (i < 计数(消息队列)) {
        如果 (消息队列[i].目标 == 目标 || 消息队列[i].类型 == "broadcast") {
            计 = 计 + 1
        }
        i = i + 1
    }
    返回 计
}

函数 总线_清空(目标) {
    定义 可变 i = 0
    当 (i < 计数(消息队列)) {
        如果 (消息队列[i].目标 == 目标) {
            列表_移除(消息队列, i)
        } 否则 {
            i = i + 1
        }
    }
}

函数 总线_清空全部() {
    消息队列 = []
    死信队列 = []
    消息历史 = []
}

// §9 统计

函数 总线_统计() {
    总线统计_初始化()
    返回 全局_总线统计
}

函数 总线_打印统计() {
    总线统计_初始化()
    打印行("=== 通信总线统计 ===")
    打印行("总发送: " + 整数转字符串(全局_总线统计.总发送))
    打印行("总接收: " + 整数转字符串(全局_总线统计.总接收))
    打印行("总广播: " + 整数转字符串(全局_总线统计.总广播))
    打印行("事件发布: " + 整数转字符串(全局_总线统计.总事件发布))
    打印行("请求数: " + 整数转字符串(全局_总线统计.请求数))
    打印行("响应数: " + 整数转字符串(全局_总线统计.响应数))
    打印行("过期数: " + 整数转字符串(全局_总线统计.过期数))
    打印行("死信数: " + 整数转字符串(全局_总线统计.死信数))
    打印行("速率拒绝: " + 整数转字符串(全局_总线统计.速率拒绝数))
    打印行("最大队列: " + 整数转字符串(全局_总线统计.最大队列长度))
    打印行("待处理: " + 整数转字符串(计数(消息队列)))
    打印行("订阅数: " + 整数转字符串(计数(订阅表)))
    打印行("历史数: " + 整数转字符串(计数(消息历史)))
}

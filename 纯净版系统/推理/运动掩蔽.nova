定义 运动_静止阈值 = 2
定义 运动_慢速阈值 = 5
定义 运动_中速阈值 = 30
定义 运动_快速阈值 = 100
定义 运动_最大降级 = 4
定义 运动_历史帧数 = 8
定义 运动_惯性衰减 = 90

定义 可变 运动_全局帧数 = 0
定义 可变 运动_降级帧数 = 0
定义 可变 运动_卡顿检测数 = 0

函数 运动掩蔽_质量降级(滚动速度) {
    定义 速度绝对值 = 如果(滚动速度 < 0, -滚动速度, 滚动速度)
    运动_全局帧数 = 运动_全局帧数 + 1
    如果 (速度绝对值 > 运动_快速阈值) { 运动_降级帧数 = 运动_降级帧数 + 1; 返回 3 }
    如果 (速度绝对值 > 运动_中速阈值) { 运动_降级帧数 = 运动_降级帧数 + 1; 返回 2 }
    如果 (速度绝对值 > 运动_慢速阈值) { 运动_降级帧数 = 运动_降级帧数 + 1; 返回 1 }
    返回 0
}

函数 运动掩蔽_二维降级(水平速度, 垂直速度) {
    定义 水平 = 如果(水平速度 < 0, -水平速度, 水平速度)
    定义 垂直 = 如果(垂直速度 < 0, -垂直速度, 垂直速度)
    定义 合速度 = 整数开方(水平 * 水平 + 垂直 * 垂直)
    返回 运动掩蔽_质量降级(合速度)
}

结构 速度预测器 {
    历史X,
    历史Y,
    历史索引,
    历史数量,
    预测X,
    预测Y,
}

函数 速度预测器_创建() {
    定义 vp = 堆_分配(速度预测器)
    vp.历史X = 堆_分配_数组(运动_历史帧数 * 4)
    vp.历史Y = 堆_分配_数组(运动_历史帧数 * 4)
    内存_清零(vp.历史X, 运动_历史帧数 * 4)
    内存_清零(vp.历史Y, 运动_历史帧数 * 4)
    vp.历史索引 = 0
    vp.历史数量 = 0
    vp.预测X = 0
    vp.预测Y = 0
    返回 vp
}

函数 速度预测器_更新(vp, 速度X, 速度Y) {
    如果 (vp == 0) { 返回 }
    内存_写32(vp.历史X + vp.历史索引 * 4, 速度X)
    内存_写32(vp.历史Y + vp.历史索引 * 4, 速度Y)
    vp.历史索引 = (vp.历史索引 + 1) % 运动_历史帧数
    如果 (vp.历史数量 < 运动_历史帧数) { vp.历史数量 = vp.历史数量 + 1 }
    速度预测器_计算预测(vp)
}

函数 速度预测器_计算预测(vp) {
    如果 (vp.历史数量 < 2) { vp.预测X = 0; vp.预测Y = 0; 返回 }
    定义 可变 总X = 0
    定义 可变 总Y = 0
    定义 可变 权重和 = 0
    定义 可变 i = 0
    当 (i < vp.历史数量) {
        定义 权重 = i + 1
        定义 idx = (vp.历史索引 - vp.历史数量 + i + 运动_历史帧数) % 运动_历史帧数
        总X = 总X + 内存_读32有符号(vp.历史X + idx * 4) * 权重
        总Y = 总Y + 内存_读32有符号(vp.历史Y + idx * 4) * 权重
        权重和 = 权重和 + 权重
        i = i + 1
    }
    如果 (权重和 > 0) {
        vp.预测X = 总X / 权重和
        vp.预测Y = 总Y / 权重和
    }
}

函数 速度预测器_获取预测降级(vp) {
    如果 (vp == 0) { 返回 0 }
    返回 运动掩蔽_二维降级(vp.预测X, vp.预测Y)
}

结构 质量平滑器 {
    区域数量,
    历史质量,
    平滑系数,
}

函数 质量平滑器_创建(区域数量) {
    定义 qs = 堆_分配(质量平滑器)
    qs.区域数量 = 区域数量
    qs.历史质量 = 堆_分配_数组(区域数量 * 4)
    内存_清零(qs.历史质量, 区域数量 * 4)
    qs.平滑系数 = 717
    返回 qs
}

函数 质量平滑器_平滑(qs, 区域索引, 目标质量) {
    如果 (qs == 0 || 区域索引 >= qs.区域数量) { 返回 目标质量 }
    定义 历史 = 内存_读32有符号(qs.历史质量 + 区域索引 * 4)
    定义 平滑 = Q乘(qs.平滑系数, 历史 * Q_ONE) + Q乘(Q_ONE - qs.平滑系数, 目标质量 * Q_ONE)
    定义 可变 结果 = (平滑 + Q_HALF) >> Q_SHIFT
    如果 (结果 < 0) { 结果 = 0 }
    如果 (结果 > 5) { 结果 = 5 }
    内存_写32(qs.历史质量 + 区域索引 * 4, 结果)
    返回 结果
}

函数 质量平滑器_设系数(qs, 系数) {
    如果 (qs != 0) { qs.平滑系数 = 系数 }
}

函数 质量平滑器_重置(qs) {
    如果 (qs == 0) { 返回 }
    内存_清零(qs.历史质量, qs.区域数量 * 4)
}

结构 动画检测器 {
    连续运动帧,
    静止帧,
    是动画中,
    动画开始阈值,
    动画结束阈值,
}

函数 动画检测器_创建() {
    定义 ad = 堆_分配(动画检测器)
    ad.连续运动帧 = 0
    ad.静止帧 = 0
    ad.是动画中 = 假
    ad.动画开始阈值 = 3
    ad.动画结束阈值 = 5
    返回 ad
}

函数 动画检测器_更新(ad, 滚动速度) {
    如果 (ad == 0) { 返回 }
    定义 速度 = 如果(滚动速度 < 0, -滚动速度, 滚动速度)
    如果 (速度 > 运动_静止阈值) {
        ad.连续运动帧 = ad.连续运动帧 + 1
        ad.静止帧 = 0
        如果 (!ad.是动画中 && ad.连续运动帧 >= ad.动画开始阈值) {
            ad.是动画中 = 真
        }
    } 否则 {
        ad.静止帧 = ad.静止帧 + 1
        ad.连续运动帧 = 0
        如果 (ad.是动画中 && ad.静止帧 >= ad.动画结束阈值) {
            ad.是动画中 = 假
        }
    }
}

函数 动画检测器_是动画(ad) {
    如果 (ad == 0) { 返回 假 }
    返回 ad.是动画中
}

结构 卡顿检测器 {
    帧时间历史,
    索引,
    目标帧时间,
    卡顿阈值倍数,
}

函数 卡顿检测器_创建(目标FPS) {
    定义 jd = 堆_分配(卡顿检测器)
    jd.帧时间历史 = 堆_分配_数组(16 * 4)
    内存_清零(jd.帧时间历史, 16 * 4)
    jd.索引 = 0
    jd.目标帧时间 = 1000 / 目标FPS
    jd.卡顿阈值倍数 = 200
    返回 jd
}

函数 卡顿检测器_记录帧(jd, 帧时间毫秒) {
    如果 (jd == 0) { 返回 }
    内存_写32(jd.帧时间历史 + jd.索引 * 4, 帧时间毫秒)
    jd.索引 = (jd.索引 + 1) % 16
    如果 (帧时间毫秒 > jd.目标帧时间 * jd.卡顿阈值倍数 / 100) {
        运动_卡顿检测数 = 运动_卡顿检测数 + 1
    }
}

函数 卡顿检测器_推荐降级(jd) {
    如果 (jd == 0) { 返回 0 }
    定义 可变 总时间 = 0
    定义 可变 i = 0
    当 (i < 16) {
        总时间 = 总时间 + 内存_读32有符号(jd.帧时间历史 + i * 4)
        i = i + 1
    }
    定义 平均 = 总时间 / 16
    如果 (平均 > jd.目标帧时间 * 3) { 返回 3 }
    如果 (平均 > jd.目标帧时间 * 2) { 返回 2 }
    如果 (平均 > jd.目标帧时间 * 150 / 100) { 返回 1 }
    返回 0
}

函数 运动掩蔽_功耗感知降级(滚动速度, 电池百分比) {
    定义 基础降级 = 运动掩蔽_质量降级(滚动速度)
    如果 (电池百分比 < 10) { 返回 最小值(基础降级 + 2, 运动_最大降级) }
    如果 (电池百分比 < 25) { 返回 最小值(基础降级 + 1, 运动_最大降级) }
    返回 基础降级
}

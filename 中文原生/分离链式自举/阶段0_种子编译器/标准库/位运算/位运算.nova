导入("../基础.nova")


// 基础位运算
函数 位_设置(值, 位) { 返回 值 | (1 << 位) }
函数 位_清除(值, 位) { 返回 值 & (~(1 << 位)) }
函数 位_翻转(值, 位) { 返回 值 ^ (1 << 位) }
函数 位_测试(值, 位) { 返回 (值 >> 位) & 1 }

// 掩码操作
函数 掩码_创建(位数) {
    如果 (位数 >= 64) { 返回 -1
}
 如果 (位数 <= 0) { 返回 0 }
 返回 (1 << 位数) - 1
}
函数 掩码_提取(值, 起始位, 位数) { 返回 (值 >> 起始位) & 掩码_创建(位数)
}
函数 掩码_插入(目标, 值, 起始位, 位数) { 定义 掩码 = 掩码_创建(位数) << 起始位
 返回 (目标 & (~掩码)) | ((值 << 起始位) & 掩码)
}

// 位计数
函数 位_popcount(n) { 定义 可变 c = 0
 定义 可变 v = n
 当 (v != 0) {
 c = c + (v & 1)
 v = v >> 1
 }
 返回 c
}

函数 位_CTZ(n) {
    如果 (n == 0) { 返回 64
}
 定义 可变 c = 0
 定义 可变 v = n
 定义 可变 最低位 = v & 1
 当 (最低位 == 0) {
 c = c + 1
 v = v >> 1
 最低位 = v & 1
 }
 返回 c
}

函数 位_CLZ(n) {
    如果 (n == 0) { 返回 64
}
 定义 可变 位数 = 0
 定义 可变 v = n
 当 (v != 0) {
 位数 = 位数 + 1
 v = v >> 1
 }
 返回 64 - 位数
}

函数 位_最高位(n) {
    如果 (n == 0) { 返回 0
}
 定义 可变 v = 1
 当 (v <= n / 2) {
 v = v * 2
 }
 返回 v
}

函数 位_最低位(n) {
    如果 (n == 0) { 返回 0
}
 返回 n & (0 - n)
}

// 位旋转
函数 位_左旋(值, 位数, 宽度) { 定义 掩码 = 掩码_创建(宽度)
 定义 n = 位数 % 宽度
 返回 ((值 << n) | (值 >> (宽度 - n))) & 掩码
}

函数 位_右旋(值, 位数, 宽度) { 定义 掩码 = 掩码_创建(宽度)
 定义 n = 位数 % 宽度
 返回 ((值 >> n) | (值 << (宽度 - n))) & 掩码
}

// 字节操作
函数 字节_取(值, 字节号) { 返回 (值 >> (字节号 * 8)) & 0xFF
}

函数 字节_设(值, 字节号, 字节值) { 定义 掩码 = 0xFF << (字节号 * 8)
 返回 (值 & (~掩码)) | ((字节值 & 0xFF) << (字节号 * 8))
}

函数 字节_交换16(值) { 返回 ((值 & 0xFF) << 8) | ((值 >> 8) & 0xFF)
}

函数 字节_交换32(值) { 定义 b0 = (值 >> 0) & 0xFF
 定义 b1 = (值 >> 8) & 0xFF
 定义 b2 = (值 >> 16) & 0xFF
 定义 b3 = (值 >> 24) & 0xFF
 返回 (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
}

// 打包/解包
函数 打包_16(高, 低) { 返回 ((高 & 0xFF) << 8) | (低 & 0xFF)
}

函数 解包_16高(值) { 返回 (值 >> 8) & 0xFF }
函数 解包_16低(值) { 返回 值 & 0xFF }

函数 打包_32(b3, b2, b1, b0) { 返回 ((b3 & 0xFF) << 24) | ((b2 & 0xFF) << 16) | ((b1 & 0xFF) << 8) | (b0 & 0xFF)
}

函数 打包_2x32(高32, 低32) { 返回 (高32 << 32) | (低32 & 0xFFFFFFFF)
}

函数 解包_高32(值) { 返回 (值 >> 32) & 0xFFFFFFFF }
函数 解包_低32(值) { 返回 值 & 0xFFFFFFFF }

// 对齐
函数 位运算_对齐_向上(值, 对齐) { 返回 (值 + 对齐 - 1) & (~(对齐 - 1))
}

函数 位运算_对齐_向下(值, 对齐) { 返回 值 & (~(对齐 - 1))
}

函数 位运算_是2的幂(n) { 如果 (n > 0) { 定义 可变 去尾 = n & (n - 1)
 如果 (去尾 == 0) { 返回 真
 }
 }
 返回 假
}

函数 向上到2的幂(n) {
    如果 (n <= 1) { 返回 1
}
 定义 可变 v = n - 1
 v = v | (v >> 1)
 v = v | (v >> 2)
 v = v | (v >> 4)
 v = v | (v >> 8)
 v = v | (v >> 16)
 返回 v + 1
}

// 哈希函数
函数 哈希_DJB2(文本) { 定义 可变 h = 5381
 定义 可变 i = 0
 当 (i < 计数(文本)) {
 h = h * 33 + 编码(子串(文本, i, 1))
 i = i + 1
 }
 如果 (h < 0) { h = 0 - h }
 返回 h
}

函数 哈希_FNV1a(文本) { 定义 可变 h = 2166136261
 定义 可变 i = 0
 当 (i < 计数(文本)) {
 h = h ^ 编码(子串(文本, i, 1))
 h = h * 16777619
 i = i + 1
 }
 如果 (h < 0) { h = 0 - h }
 返回 h
}

函数 哈希_整数(n) { 定义 可变 h = n
 h = h ^ (h >> 16)
 h = h * 2654435769
 h = h ^ (h >> 16)
 如果 (h < 0) { h = 0 - h }
 返回 h
}

// 位域结构
// 型: [值, 字段定义列表] 字段: [名哈希, 起始位, 位数]
函数 位域_创建() { 返回 [0, []] }
函数 位域_定义字段(bd, 名哈希, 起始位, 位数) {
 追加(bd[1], [名哈希, 起始位, 位数])
}
函数 位域_设置(bd, 字段idx, 值) { 定义 字段 = bd[1][字段idx]
 bd[0] = 掩码_插入(bd[0], 值, 字段[1], 字段[2])
}
函数 位域_获取(bd, 字段idx) { 定义 字段 = bd[1][字段idx]
 返回 掩码_提取(bd[0], 字段[1], 字段[2])
}

// 位域字段数
函数 位域_字段数(bd) { 返回 计数(bd[1]) }

// 哈希组合
函数 哈希_组合(h1, h2) { 定义 可变 r = h1 ^ (h2 * 2654435761)
 如果 (r < 0) { r = 0 - r }
 返回 r
}
函数 位域_原始值(bd) { 返回 bd[0] }

// 汉明距离 (不同位数, 0)
函数 汉明距离(a, b) { 定义 可变 异或值 = a ^ b
 定义 可变 计数器 = 0
 当 (异或值 != 0) {
 计数器 = 计数器 + (异或值 & 1)
 异或值 = 异或值 >> 1
 }
 返回 计数器
}

// 位反转 (reverse bits, 0)
函数 位反转(n, 位数) { 定义 可变 结果 = 0
 定义 可变 值 = n
 定义 可变 i = 0
 当 (i < 位数) {
 结果 = (结果 << 1) | (值 & 1)
 值 = 值 >> 1
 i = i + 1
 }
 返回 结果
}

// 位交错 (Morton编码, Z-order curve)
// 用于空间索引: 将(x,y)交错为单个整数
函数 Morton编码(x, y) { 定义 可变 结果 = 0
 定义 可变 位 = 0
 定义 可变 vx = x
 定义 可变 vy = y
 当 (位 < 16) {
 结果 = 结果 | ((vx & 1) << (位 * 2))
 结果 = 结果 | ((vy & 1) << (位 * 2 + 1))
 vx = vx >> 1
 vy = vy >> 1
 位 = 位 + 1
 }
 返回 结果
}

函数 Morton解码(z) { 定义 可变 x = 0
 定义 可变 y = 0
 定义 可变 位 = 0
 定义 可变 v = z
 当 (位 < 16) {
 x = x | ((v & 1) << 位)
 v = v >> 1
 y = y | ((v & 1) << 位)
 v = v >> 1
 位 = 位 + 1
 }
 返回 [x, y]
}

// CRC-32 (查表法简化版)
定义 可变 CRC表已初始化 = 0
定义 可变 CRC表 = []

函数 CRC32_初始化表() {
    如果 (CRC表已初始化 == 1) { 返回 空
}
 定义 可变 i = 0
 当 (i < 256) { 定义 可变 校验值 = i
 定义 可变 j = 0
 当 (j < 8) { 定义 可变 最低位 = 校验值 & 1
 如果 (最低位 == 1) {
 校验值 = (校验值 >> 1) ^ 0xEDB88320
 } 否则 {
 校验值 = 校验值 >> 1
 }
 j = j + 1
 }
 追加(CRC表, 校验值)
 i = i + 1
 }
 CRC表已初始化 = 1
}

函数 CRC32_计算(数据列表) {
 CRC32_初始化表()
 定义 可变 校验值 = 0xFFFFFFFF
 定义 可变 i = 0
 当 (i < 计数(数据列表)) { 定义 字节 = 数据列表[i] & 0xFF
 定义 索引 = (校验值 ^ 字节) & 0xFF
 校验值 = (校验值 >> 8) ^ CRC表[索引]
 i = i + 1
 }
 返回 校验值 ^ 0xFFFFFFFF
}

// 奇偶校验
函数 奇偶校验(n) { 定义 可变 v = n
 v = v ^ (v >> 16)
 v = v ^ (v >> 8)
 v = v ^ (v >> 4)
 v = v ^ (v >> 2)
 v = v ^ (v >> 1)
 返回 v & 1 // 0=偶数个1, 1=奇数个1
}

// 前导零计数 (CLZ)
函数 前导零(n) {
    如果 (n == 0) { 返回 64
}
 定义 可变 计数 = 0
 定义 可变 v = n
 定义 可变 探测 = v & 0xFFFFFFFF00000000
 如果 (探测 == 0) {
 计数 = 计数 + 32
 v = v << 32
 }
 探测 = v & 0xFFFF000000000000
 如果 (探测 == 0) {
 计数 = 计数 + 16
 v = v << 16
 }
 探测 = v & 0xFF00000000000000
 如果 (探测 == 0) {
 计数 = 计数 + 8
 v = v << 8
 }
 探测 = v & 0xF000000000000000
 如果 (探测 == 0) {
 计数 = 计数 + 4
 v = v << 4
 }
 探测 = v & 0xC000000000000000
 如果 (探测 == 0) {
 计数 = 计数 + 2
 v = v << 2
 }
 探测 = v & 0x8000000000000000
 如果 (探测 == 0) {
 计数 = 计数 + 1
 }
 返回 计数
}

// 尾随零计数 (CTZ)
函数 尾随零(n) {
    如果 (n == 0) { 返回 64
}
 定义 可变 计数 = 0
 定义 可变 v = n
 定义 可变 最低位 = v & 1
 当 (最低位 == 0) {
 计数 = 计数 + 1
 v = v >> 1
 最低位 = v & 1
 }
 返回 计数
}

// 最高位位置 (floor(对数2(n)))
函数 最高位(n) {
    如果 (n <= 0) { 返回 -1
}
 返回 63 - 前导零(n)
}

// 位图 (Bitmap)
函数 位图_创建(大小) { 定义 字数 = (大小 + 63) / 64
 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 字数) {
 追加(数据, 0)
 i = i + 1
 }
 返回 [数据, 大小]
}

函数 位图_设置(bm, 位) {
    如果 (位 < 0) { 返回 空
}
 如果 (位 >= bm[1]) { 返回 空 }
 定义 字 = 位 / 64
 定义 偏移 = 位 % 64
 bm[0][字] = bm[0][字] | (1 << 偏移)
}

函数 位图_清除(bm, 位) {
    如果 (位 < 0) { 返回 空
}
 如果 (位 >= bm[1]) { 返回 空 }
 定义 字 = 位 / 64
 定义 偏移 = 位 % 64
 bm[0][字] = bm[0][字] & (0 - 1 - (1 << 偏移))
}

函数 位图_测试(bm, 位) {
    如果 (位 < 0) { 返回 0
}
 如果 (位 >= bm[1]) { 返回 0 }
 定义 字 = 位 / 64
 定义 偏移 = 位 % 64
 返回 (bm[0][字] >> 偏移) & 1
}

函数 位图_计数(bm) { 定义 可变 总数 = 0
 定义 可变 i = 0
 当 (i < 计数(bm[0])) {
 总数 = 总数 + 位_popcount(bm[0][i])
 i = i + 1
 }
 返回 总数
}

// 找第一个为0的位 (空闲槽)
函数 位图_找空闲(bm) { 定义 可变 i = 0
 当 (i < 计数(bm[0])) { 如果 (bm[0][i] != 0 - 1) {
 // 此字有空位
 定义 可变 b = 0
 当 (b < 64) { 定义 全局位 = i * 64 + b
 如果 (全局位 >= bm[1]) { 返回 -1 }
 定义 可变 当前位 = (bm[0][i] >> b) & 1
 如果 (当前位 == 0) { 返回 全局位
 }
 b = b + 1
 }
 }
 i = i + 1
 }
 返回 -1
}

// 位运算扩展

函数 位_最低设置位(值) {
    如果 (值 == 0) { 返回 -1
}
 定义 可变 位 = 0
 定义 可变 v = 值
 定义 可变 最低位 = v & 1
 当 (最低位 == 0) {
 v = v >> 1
 位 = 位 + 1
 最低位 = v & 1
 }
 返回 位
}

函数 位_最高设置位(值) {
    如果 (值 == 0) { 返回 -1
}
 定义 可变 位 = 0
 定义 可变 v = 值
 当 (v > 1) {
 v = v >> 1
 位 = 位 + 1
 }
 返回 位
}

函数 位_是2的幂(值) {
    如果 (值 <= 0) { 返回 假
}
 定义 可变 去尾 = 值 & (值 - 1)
 返回 去尾 == 0
}

函数 位_向上对齐2的幂(值) {
    如果 (值 <= 1) { 返回 1
}
 定义 可变 v = 值 - 1
 v = v | (v >> 1)
 v = v | (v >> 2)
 v = v | (v >> 4)
 v = v | (v >> 8)
 v = v | (v >> 16)
 返回 v + 1
}

函数 位_交换字节序16(值) { 返回 ((值 & 0xFF) << 8) | ((值 >> 8) & 0xFF)
}

函数 位_交换字节序32(值) { 定义 b0 = (值 & 0xFF) << 24
 定义 b1 = ((值 >> 8) & 0xFF) << 16
 定义 b2 = ((值 >> 16) & 0xFF) << 8
 定义 b3 = (值 >> 24) & 0xFF
 返回 b0 | b1 | b2 | b3
}

函数 位_提取字段(值, 起始, 宽度) { 返回 (值 >> 起始) & ((1 << 宽度) - 1)
}

函数 位_插入字段(值, 起始, 宽度, 字段值) { 定义 掩码 = ((1 << 宽度) - 1) << 起始
 返回 (值 & (~掩码)) | ((字段值 << 起始) & 掩码)
}

函数 位_循环左移(值, 移位, 位宽) { 返回 ((值 << 移位) | (值 >> (位宽 - 移位))) & ((1 << 位宽) - 1)
}

函数 位_循环右移(值, 移位, 位宽) { 返回 ((值 >> 移位) | (值 << (位宽 - 移位))) & ((1 << 位宽) - 1)
}

定义 可变 _位_操作次数 = 0
定义 可变 _位_最大值 = 0

函数 位_记录操作(值) { _位_操作次数 = _位_操作次数 + 1
 如果 (值 > _位_最大值) { _位_最大值 = 值 }
}

函数 位_位宽评估() {
    如果 (_位_最大值 > 0xFFFFFFFF) { 返回 "需要64位运算"
}
 如果 (_位_最大值 > 0xFFFF) { 返回 "32位运算" }
 如果 (_位_最大值 > 0xFF) { 返回 "16位运算足够" }
 返回 "8位运算足够"
}

函数 位_重置() { _位_操作次数 = 0
 _位_最大值 = 0
}

函数 位_奇偶校验(值) { 定义 可变 v = 值
 定义 可变 计 = 0
 当 (v > 0) {
 计 = 计 + (v & 1)
 v = v >> 1
 }
 返回 计 % 2 == 0
}

函数 位_汉明距离(a, b) { 定义 可变 异或 = a ^ b
 定义 可变 距 = 0
 当 (异或 > 0) {
 距 = 距 + (异或 & 1)
 异或 = 异或 >> 1
 }
 返回 距
}


// [Nova实验室反哺] 笔画加权哈希 — Nova首创(Rust实测零碰撞)
// 替代: FNV-1a逐字节 → Nova笔画加权(每字1次操作, 汉字专用)
// 已在标准库/哈希表/哈希表.nova:302 实现 哈希_笔画加权(码点, 容量)
// 笔画加权已反哺

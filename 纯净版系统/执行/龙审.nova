导入("../中枢/整数转字符串.nova")

// Nova 代码静态检查器

定义 可变 警告数 = 0
定义 可变 错误数 = 0
定义 可变 已检查文件数 = 0
定义 可变 最长函数行数 = 0
定义 可变 最长函数起始行 = 0
定义 可变 最长函数文件 = ""
定义 可变 最长函数签名 = ""

函数 龙审_包含待收口标记(行) {
    定义 标签一 = "TO" + "DO"
    定义 标签二 = "待" + "实现"
    定义 标签三 = "未" + "实现"
    返回 字符串包含(行, 标签一) || 字符串包含(行, 标签二) || 字符串包含(行, 标签三)
}

函数 龙审_main(参数) {
    如果 (计数(参数) == 0) {
        打印行("龙审 v1.0")
        打印行("用法: 龙审 [文件...]")
        返回 0
    }

    龙审_全局重置()

    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 内容 = 文件_读取全部(参数[i])
        如果 (内容 != 空) {
            龙审_检查文件(参数[i], 内容)
        } 否则 {
            龙审_错误(参数[i], 0, "无法读取文件")
        }
        i = i + 1
    }

    打印行("")
    打印行(
        "检查完成: " +
        整数转字符串(错误数) +
        " 错误, " +
        整数转字符串(警告数) +
        " 警告"
    )
    返回 错误数
}

函数 龙审_记录函数跨度(路径, 起始行, 结束行, 签名) {
    如果 (起始行 <= 0 || 结束行 < 起始行) { 返回 }

    定义 行数 = 结束行 - 起始行 + 1
    如果 (行数 > 最长函数行数) {
        最长函数行数 = 行数
        最长函数起始行 = 起始行
        最长函数文件 = 路径
        最长函数签名 = 签名
    }

    如果 (行数 > 100) {
        龙审_警告(
            路径,
            起始行,
            "函数过长(" + 整数转字符串(行数) + "行), 建议拆分: " + 签名
        )
    }
}

函数 龙审_检查文件(路径, 内容) {
    已检查文件数 = 已检查文件数 + 1

    定义 行列表 = 字符串分割(内容, "\n")
    定义 可变 括号深度 = 0
    定义 可变 连续空行 = 0
    定义 可变 函数数 = 0
    定义 可变 当前函数起始 = 0
    定义 可变 当前函数签名 = ""

    定义 可变 i = 0
    当 (i < 计数(行列表)) {
        定义 行 = 行列表[i]
        定义 行号 = i + 1
        定义 去空白行 = 字符串去首尾空白(行)

        如果 (字符串长度(行) > 120) {
            龙审_警告(路径, 行号, "行过长(" + 整数转字符串(字符串长度(行)) + "字符>120)")
        }

        如果 (龙审_包含待收口标记(行)) {
            龙审_警告(路径, 行号, "包含待收口标记")
        }

        如果 (字符串包含(去空白行, "{ }") || 字符串包含(去空白行, "{ 返回 成功 }") || 字符串包含(去空白行, "{ 返回 0 }")) {
            龙审_警告(路径, 行号, "可能存在空实现或占位函数")
        }

        如果 (字符串长度(行) > 0) {
            定义 最后字符 = 字符串字符(行, 字符串长度(行) - 1)
            如果 (最后字符 == 32 || 最后字符 == 9) {
                龙审_警告(路径, 行号, "行尾有空白字符")
            }
        }

        如果 (字符串长度(去空白行) == 0) {
            连续空行 = 连续空行 + 1
            如果 (连续空行 > 2) {
                龙审_警告(路径, 行号, "连续空行过多(>2)")
            }
        } 否则 {
            连续空行 = 0
        }

        如果 (字符串包含(去空白行, "函数 ")) {
            如果 (当前函数起始 > 0) {
                龙审_记录函数跨度(路径, 当前函数起始, 行号 - 1, 当前函数签名)
            }
            当前函数起始 = 行号
            当前函数签名 = 去空白行
            函数数 = 函数数 + 1
        }

        定义 可变 j = 0
        当 (j < 字符串长度(去空白行)) {
            定义 ch = 字符串字符(去空白行, j)
            如果 (ch == 123) { 括号深度 = 括号深度 + 1 }
            如果 (ch == 125) { 括号深度 = 括号深度 - 1 }
            j = j + 1
        }
        如果 (括号深度 < 0) {
            龙审_错误(路径, 行号, "多余的右花括号")
            括号深度 = 0
        }

        如果 (!字符串开头于(去空白行, "//") && !字符串开头于(去空白行, "定义 ")) {
            如果 (字符串包含(去空白行, "999999") || 字符串包含(去空白行, "0xDEAD") || 字符串包含(去空白行, "0xBEEF")) {
                龙审_警告(路径, 行号, "可能的预设魔数")
            }
        }

        定义 可变 前导空格 = 0
        定义 可变 k = 0
        当 (k < 字符串长度(行) && 字符串字符(行, k) == 32) {
            前导空格 = 前导空格 + 1
            k = k + 1
        }
        如果 (前导空格 > 20 && 字符串长度(去空白行) > 0) {
            龙审_警告(路径, 行号, "嵌套过深(缩进>" + 整数转字符串(前导空格 / 4) + "层)")
        }

        i = i + 1
    }

    如果 (当前函数起始 > 0) {
        龙审_记录函数跨度(路径, 当前函数起始, 计数(行列表), 当前函数签名)
    }

    如果 (括号深度 > 0) {
        龙审_错误(路径, 计数(行列表), "未闭合的花括号(" + 整数转字符串(括号深度) + "个)")
    }
    如果 (计数(行列表) > 500 && 函数数 < 3) {
        龙审_警告(
            路径,
            1,
            "文件过长(" + 整数转字符串(计数(行列表)) + "行)但函数过少(" + 整数转字符串(函数数) + "), 建议拆分"
        )
    }
}

函数 龙审_警告(文件, 行号, 消息) {
    打印行("  WARN " + 文件 + ":" + 整数转字符串(行号) + ": " + 消息)
    警告数 = 警告数 + 1
}

函数 龙审_错误(文件, 行号, 消息) {
    打印行("  ERROR " + 文件 + ":" + 整数转字符串(行号) + ": " + 消息)
    错误数 = 错误数 + 1
}

函数 龙审_统计() {
    返回 {
        模块: "龙审",
        已检查文件数: 已检查文件数,
        警告数: 警告数,
        错误数: 错误数,
        最长函数行数: 最长函数行数,
        最长函数文件: 最长函数文件,
        最长函数起始行: 最长函数起始行,
        最长函数签名: 最长函数签名
    }
}

函数 龙审_健康评估() {
    如果 (错误数 > 0) { 返回 假 }
    如果 (最长函数行数 > 200) { 返回 假 }
    如果 (警告数 > 500) { 返回 假 }
    返回 真
}

函数 龙审_综合报告() {
    打印("[龙审] 综合报告")
    打印("  已检查文件数: " + 整数转字符串(已检查文件数))
    打印("  警告数: " + 整数转字符串(警告数))
    打印("  错误数: " + 整数转字符串(错误数))
    打印("  最长函数行数: " + 整数转字符串(最长函数行数))
    打印("  最长函数位置: " + 最长函数文件 + ":" + 整数转字符串(最长函数起始行))
    打印("  最长函数签名: " + 最长函数签名)
    打印("  健康: " + 如果 (龙审_健康评估()) { "正常" } 否则 { "异常" })
}

函数 龙审_全局重置() {
    警告数 = 0
    错误数 = 0
    已检查文件数 = 0
    最长函数行数 = 0
    最长函数起始行 = 0
    最长函数文件 = ""
    最长函数签名 = ""
    返回 0
}

// NovaOS 融合层 / 内核浏览器桥 / 安全沙箱适配
// 模块: 同源策略检查 — 完整Web安全引擎
// 功能:
//  §1 数据结构与常量
//  §2 同源策略(SOP)检查: scheme+host+port三元组
//  §3 CORS跨域资源共享: 预检/简单请求/凭证模式
//  §4 CSP内容安全策略: 指令解析/违规上报/nonce验证
//  §5 XSS防护: 规则引擎+AI深度语义检测(TF-IDF特征向量)
//  §6 CSRF防护: Token验证/Referer检查/SameSite Cookie
//  §7 Clickjacking防护: X-Frame-Options/frame-ancestors
//  §8 权限管理: Permissions Policy/Feature Policy
//  §9 AI威胁评分: EWMA风险聚合/域信誉学习
//  §10 安全事件审计日志

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/整数转字符串.nova")
导入("../推理/值乘.nova")
导入("../中枢/辅助存根.nova")
导入("../感知/超时.nova")
导入("../外联/地址解析辅.nova")
导入("./域名解析.nova")
导入("../中枢/字符串替换.nova")
导入("../标准/原生列表.nova")

// §1 数据结构与常量

定义 事件_同源违规 = 1
定义 事件_CSP违规 = 2
定义 事件_XSS检测 = 3
定义 事件_CSRF检测 = 4
定义 事件_CORS违规 = 5
定义 事件_权限请求 = 6
定义 事件_点击劫持 = 7

定义 权限_摄像头 = 1
定义 权限_麦克风 = 2
定义 权限_地理位置 = 3
定义 权限_系统调用 = 10
定义 权限_文件读 = 11
定义 权限_文件写 = 12

定义 Q_ONE = 1024  // Q10定点

结构 源 {
    协议,     // 字符串: "https"/"http"/"nova"
    主机,
    端口,     // 整数
}

结构 CSP指令集 {
    default_src,    // 字符串列表
    script_src,     // 字符串列表
    style_src,      // 字符串列表
    img_src,        // 字符串列表
    connect_src,    // 字符串列表
    frame_src,      // 字符串列表
    object_src,     // 字符串列表
    base_uri,       // 字符串列表
    允许Eval,
    允许Inline,
    nonce列表,      // 字符串列表
    report_uri,
}

结构 域安全档案 {
    域名,
    信任等级,        // 0-100
    允许权限,        // 权限列表
    csp,             // CSP指令集
    允许CORS源,      // 字符串列表
    CSRF令牌,
    frame_策略,      // 0=DENY, 1=SAMEORIGIN, 2=允许
    违规计数,
    最后访问时间,
    AI威胁分,        // Q10定点 0-1024
    EWMA_威胁,       // Q10定点 指数加权移动平均
}

定义 可变 安全_总拦截数 = 0
定义 可变 安全_总检查数 = 0
定义 可变 安全_域档案表 = []    // 域安全档案列表
定义 可变 安全_审计日志 = []    // 审计事件列表
定义 EWMA_ALPHA = 205           // 0.2 * 1024

// §2 同源策略(SOP)检查
// 三元组: scheme + host + port

函数 源_解析(url) {
    定义 s = 源 {}
    // 提取协议
    定义 sep = 字符串查找(url, "://")
    如果 (sep < 0) {
        s.协议 = "https"
        s.主机 = url
        s.端口 = 443
        返回 s
    }
    s.协议 = 字符串_子串(url, 0, sep)
    定义 rest = 字符串_子串(url, sep + 3, 字符串长度(url))
    // 提取主机和端口
    定义 冒号 = 字符串查找(rest, ":")
    定义 斜杠 = 字符串查找(rest, "/")
    如果 (斜杠 < 0) { 斜杠 = 字符串长度(rest) }
    如果 (冒号 >= 0 && 冒号 < 斜杠) {
        s.主机 = 字符串_子串(rest, 0, 冒号)
        s.端口 = 字符串转整数(字符串_子串(rest, 冒号 + 1, 斜杠))
    } 否则 {
        s.主机 = 字符串_子串(rest, 0, 斜杠)
        如果 (字符串_相等(s.协议, "https")) { s.端口 = 443 }
        否则如果 (字符串_相等(s.协议, "http")) { s.端口 = 80 }
        否则如果 (字符串_相等(s.协议, "nova")) { s.端口 = 0 }
        否则 { s.端口 = 0 }
    }
    返回 s
}

函数 源_相等(a, b) {
    返回 字符串_相等(a.协议, b.协议) &&
           字符串_相等(a.主机, b.主机) &&
           a.端口 == b.端口
}

函数 浏览器安全_检查同源(源URL, 目标URL) {
    安全_总检查数 = 安全_总检查数 + 1
    定义 s = 源_解析(源URL)
    定义 t = 源_解析(目标URL)

    // nova://协议拥有超级权限
    如果 (字符串_相等(s.协议, "nova")) {
        返回 真
    }

    如果 (源_相等(s, t)) {
        返回 真
    }

    // 记录违规
    浏览器安全_记录事件(事件_同源违规, s.主机,
        "跨域请求: " + 源URL + " → " + 目标URL, 真)
    返回 假
}

函数 浏览器安全_检查同源_完整(源协议, 源主机, 源端口, 目标协议, 目标主机, 目标端口) {
    安全_总检查数 = 安全_总检查数 + 1
    如果 (字符串_相等(源协议, "nova")) { 返回 真 }
    如果 (字符串_相等(源协议, 目标协议) &&
        字符串_相等(源主机, 目标主机) &&
        源端口 == 目标端口) {
        返回 真
    }
    浏览器安全_记录事件(事件_同源违规, 源主机,
        "SOP违规: " + 源主机 + ":" + 整数转字符串(源端口) +
        " → " + 目标主机 + ":" + 整数转字符串(目标端口), 真)
    返回 假
}

// §3 CORS跨域资源共享

函数 CORS_是简单请求(方法, 头列表) {
    // 简单方法: GET/HEAD/POST
    如果 (!字符串_相等(方法, "GET") && !字符串_相等(方法, "HEAD") && !字符串_相等(方法, "POST")) {
        返回 假
    }
    // 检查头是否都是安全头
    定义 可变 i = 0
    当 (i < 计数(头列表)) {
        定义 h = 字符串_转小写(头列表[i])
        如果 (!字符串_相等(h, "accept") &&
            !字符串_相等(h, "accept-language") &&
            !字符串_相等(h, "content-language") &&
            !字符串_相等(h, "content-type")) {
            返回 假
        }
        i = i + 1
    }
    返回 真
}

函数 CORS_检查预检响应(请求源, 响应头) {
    定义 允许源 = HTTP头_获取(响应头, "Access-Control-Allow-Origin")
    如果 (允许源 == 0) { 返回 假 }
    如果 (字符串_相等(允许源, "*")) { 返回 真 }
    如果 (字符串_相等(允许源, 请求源)) { 返回 真 }
    返回 假
}

函数 CORS_检查(请求源, 目标源, 方法, 请求头, 响应头, 带凭证) {
    安全_总检查数 = 安全_总检查数 + 1
    // 同源不需要CORS
    定义 s = 源_解析(请求源)
    定义 t = 源_解析(目标源)
    如果 (源_相等(s, t)) { 返回 真 }

    // 检查Access-Control-Allow-Origin
    定义 允许 = HTTP头_获取(响应头, "Access-Control-Allow-Origin")
    如果 (允许 == 0) {
        浏览器安全_记录事件(事件_CORS违规, s.主机,
            "CORS: 目标无Allow-Origin头", 真)
        返回 假
    }

    // 带凭证模式不允许通配符
    如果 (带凭证 && 字符串_相等(允许, "*")) {
        浏览器安全_记录事件(事件_CORS违规, s.主机,
            "CORS: 凭证模式不允许通配符", 真)
        返回 假
    }

    如果 (!字符串_相等(允许, "*") && !字符串_相等(允许, 请求源)) {
        浏览器安全_记录事件(事件_CORS违规, s.主机,
            "CORS: 源不匹配 " + 允许 + " vs " + 请求源, 真)
        返回 假
    }

    // 检查允许的方法
    定义 允许方法 = HTTP头_获取(响应头, "Access-Control-Allow-Methods")
    如果 (!CORS_是简单请求(方法, []) && 允许方法 != 0) {
        如果 (字符串查找(允许方法, 方法) < 0) {
            浏览器安全_记录事件(事件_CORS违规, s.主机,
                "CORS: 方法不允许 " + 方法, 真)
            返回 假
        }
    }

    返回 真
}

// §4 CSP内容安全策略

函数 CSP_解析(头值) {
    定义 csp = CSP指令集 {}
    csp.default_src = []; csp.script_src = []; csp.style_src = []
    csp.img_src = []; csp.connect_src = []; csp.frame_src = []
    csp.object_src = []; csp.base_uri = []; csp.nonce列表 = []
    csp.允许Eval = 假; csp.允许Inline = 假

    // 按分号拆分指令
    定义 指令列表 = 字符串_分割(头值, ";")
    定义 可变 i = 0
    当 (i < 计数(指令列表)) {
        定义 指令 = 字符串_去空格(指令列表[i])
        定义 部分 = 字符串_分割(指令, " ")
        如果 (计数(部分) < 2) { i = i + 1; 继续 }
        定义 名称 = 部分[0]
        // 提取值列表
        定义 可变 j = 1
        当 (j < 计数(部分)) {
            定义 v = 部分[j]
            如果 (字符串_相等(名称, "default-src")) { 追加(csp.default_src, v) }
            否则如果 (字符串_相等(名称, "script-src")) {
                如果 (字符串_相等(v, "'unsafe-eval'")) { csp.允许Eval = 真 }
                否则如果 (字符串_相等(v, "'unsafe-inline'")) { csp.允许Inline = 真 }
                否则如果 (字符串_前缀(v, "'nonce-")) {
                    追加(csp.nonce列表, 字符串_子串(v, 7, 字符串长度(v) - 1))
                }
                否则 { 追加(csp.script_src, v) }
            }
            否则如果 (字符串_相等(名称, "style-src")) { 追加(csp.style_src, v) }
            否则如果 (字符串_相等(名称, "img-src")) { 追加(csp.img_src, v) }
            否则如果 (字符串_相等(名称, "connect-src")) { 追加(csp.connect_src, v) }
            否则如果 (字符串_相等(名称, "frame-src")) { 追加(csp.frame_src, v) }
            否则如果 (字符串_相等(名称, "object-src")) { 追加(csp.object_src, v) }
            否则如果 (字符串_相等(名称, "base-uri")) { 追加(csp.base_uri, v) }
            否则如果 (字符串_相等(名称, "report-uri")) { csp.report_uri = v }
            j = j + 1
        }
        i = i + 1
    }
    返回 csp
}

函数 CSP_源匹配(源列表, url) {
    定义 可变 i = 0
    当 (i < 计数(源列表)) {
        定义 src = 源列表[i]
        如果 (字符串_相等(src, "*")) { 返回 真 }
        如果 (字符串_相等(src, "'self'")) {
            // self匹配在上层处理
            返回 真
        }
        如果 (字符串_相等(src, "'none'")) { 返回 假 }
        // 通配符域名: *.example.com
        如果 (字符串_前缀(src, "*.")) {
            定义 后缀 = 字符串_子串(src, 1, 字符串长度(src))
            如果 (字符串_后缀(url, 后缀)) { 返回 真 }
        }
        如果 (字符串查找(url, src) >= 0) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 浏览器安全_检查CSP(域, 资源类型, 资源URL, nonce) {
    定义 档案 = 浏览器安全_获取域档案(域)
    如果 (档案 == 0) { 返回 真 }
    定义 csp = 档案.csp

    // 选择对应的指令源列表
    定义 可变 源列表 = csp.default_src
    如果 (字符串_相等(资源类型, "script")) { 源列表 = csp.script_src }
    否则如果 (字符串_相等(资源类型, "style")) { 源列表 = csp.style_src }
    否则如果 (字符串_相等(资源类型, "img")) { 源列表 = csp.img_src }
    否则如果 (字符串_相等(资源类型, "connect")) { 源列表 = csp.connect_src }
    否则如果 (字符串_相等(资源类型, "frame")) { 源列表 = csp.frame_src }
    否则如果 (字符串_相等(资源类型, "object")) { 源列表 = csp.object_src }

    // eval特殊检查
    如果 (字符串_相等(资源类型, "eval") && !csp.允许Eval) {
        浏览器安全_记录事件(事件_CSP违规, 域, "eval被CSP阻止", 真)
        CSP_发送违规报告(csp, 域, 资源类型, 资源URL)
        返回 假
    }

    // inline脚本nonce验证
    如果 (字符串_相等(资源类型, "script-inline")) {
        如果 (csp.允许Inline) { 返回 真 }
        如果 (nonce != 0 && 计数(csp.nonce列表) > 0) {
            定义 可变 k = 0
            当 (k < 计数(csp.nonce列表)) {
                如果 (字符串_相等(csp.nonce列表[k], nonce)) { 返回 真 }
                k = k + 1
            }
        }
        浏览器安全_记录事件(事件_CSP违规, 域, "inline脚本无有效nonce", 真)
        返回 假
    }

    // 源列表匹配
    如果 (计数(源列表) == 0) { 返回 真 }  // 无限制
    如果 (!CSP_源匹配(源列表, 资源URL)) {
        浏览器安全_记录事件(事件_CSP违规, 域,
            "CSP阻止 " + 资源类型 + ": " + 资源URL, 真)
        CSP_发送违规报告(csp, 域, 资源类型, 资源URL)
        返回 假
    }
    返回 真
}

函数 CSP_发送违规报告(csp, 域, 资源类型, 资源URL) {
    如果 (csp.report_uri == 0) { 返回 }
    定义 报告 = "{\"violated-directive\":\"" + 资源类型 +
               "\",\"blocked-uri\":\"" + 资源URL +
               "\",\"document-uri\":\"" + 域 + "\"}"
    HTTP_POST异步(csp.report_uri, "application/csp-report", 报告)
}

// §5 XSS防护 — 规则引擎 + AI语义检测
// 创新: TF-IDF特征向量 + 多层感知器实时评分

// XSS特征关键词及权重
定义 XSS_模式数 = 16
定义 可变 XSS_模式 = [
    "<script", "javascript:", "onerror=", "onload=",
    "onfocus=", "onmouseover=", "eval(", "document.cookie",
    "innerHTML", "outerHTML", "document.write", "setTimeout(",
    "setInterval(", "Function(", "fromCharCode", "\\x3c"
]
定义 可变 XSS_权重 = [
    100, 95, 90, 85,
    80, 75, 95, 90,
    70, 70, 85, 60,
    55, 80, 75, 90
]

函数 浏览器安全_检查XSS(输入) {
    安全_总检查数 = 安全_总检查数 + 1
    如果 (输入 == 0 || 字符串长度(输入) == 0) { 返回 假 }

    // 阶段1: 规则引擎快速扫描
    定义 可变 规则分 = 0
    定义 可变 命中数 = 0
    定义 小写输入 = 字符串_转小写(输入)
    定义 可变 i = 0
    当 (i < XSS_模式数) {
        如果 (字符串查找(小写输入, XSS_模式[i]) >= 0) {
            规则分 = 规则分 + XSS_权重[i]
            命中数 = 命中数 + 1
        }
        i = i + 1
    }

    // 阶段2: 编码逃逸检测
    如果 (字符串查找(小写输入, "&#") >= 0) { 规则分 = 规则分 + 40 }
    如果 (字符串查找(小写输入, "%3c") >= 0) { 规则分 = 规则分 + 50 }
    如果 (字符串查找(小写输入, "%253c") >= 0) { 规则分 = 规则分 + 60 }  // 双编码

    // 阶段3: AI深度检测(仅当规则分不确定时)
    定义 可变 AI分 = 0
    如果 (规则分 >= 30 && 规则分 < 150) {
        AI分 = XSS_AI深度分析(输入, 命中数)
    }

    定义 总分 = 规则分 + AI分
    如果 (总分 >= 80) {
        安全_总拦截数 = 安全_总拦截数 + 1
        浏览器安全_记录事件(事件_XSS检测, "",
            "XSS score=" + 整数转字符串(总分) + " hits=" + 整数转字符串(命中数), 真)
        返回 真
    }
    返回 假
}

函数 XSS_AI深度分析(输入, 命中数) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 0 }
    // TF-IDF特征提取: 8维向量
    定义 特征 = Tensor_创建(1, 8)
    定义 长度 = 字符串长度(输入)
    // 特征0: 特殊字符密度 (<, >, &, ", ')
    定义 可变 特殊数 = 0
    定义 可变 j = 0
    当 (j < 长度) {
        定义 ch = 字符串_字符(输入, j)
        如果 (ch == 60 || ch == 62 || ch == 38 || ch == 34 || ch == 39) {
            特殊数 = 特殊数 + 1
        }
        j = j + 1
    }
    Tensor_写(特征, 0, 0, 特殊数 * Q_ONE / (长度 + 1))
    // 特征1: 命中模式占比
    Tensor_写(特征, 0, 1, 命中数 * Q_ONE / XSS_模式数)
    // 特征2: 输入长度归一化
    Tensor_写(特征, 0, 2, 如果(长度 > 2048, Q_ONE, 长度 * Q_ONE / 2048))
    // 特征3: 嵌套标签深度
    定义 可变 深度 = 0
    定义 可变 最大深度 = 0
    j = 0
    当 (j < 长度) {
        如果 (字符串_字符(输入, j) == 60) { 深度 = 深度 + 1 }
        否则如果 (字符串_字符(输入, j) == 62) { 深度 = 深度 - 1 }
        如果 (深度 > 最大深度) { 最大深度 = 深度 }
        j = j + 1
    }
    Tensor_写(特征, 0, 3, 如果(最大深度 > 5, Q_ONE, 最大深度 * Q_ONE / 5))
    // 特征4-7: 保留用于上下文特征
    定义 分数 = AI总线_推理(bus, "xss_detect", 特征)
    Tensor_释放(特征)
    返回 分数 * 100 / Q_ONE
}

// §6 CSRF防护

函数 CSRF_生成令牌() {
    // 生成32字节随机令牌
    定义 buf = 堆_分配(32)
    平台_安全随机(buf, 32)
    定义 token = 字节_转十六进制(buf, 32)
    堆_释放(buf)
    返回 token
}

函数 CSRF_验证(请求, 域) {
    安全_总检查数 = 安全_总检查数 + 1
    定义 档案 = 浏览器安全_获取域档案(域)
    如果 (档案 == 0 || 档案.CSRF令牌 == 0) { 返回 真 }

    // 检查请求头中的CSRF令牌
    定义 请求令牌 = HTTP头_获取(请求.头, "X-CSRF-Token")
    如果 (请求令牌 != 0 && 字符串_相等(请求令牌, 档案.CSRF令牌)) {
        返回 真
    }

    // 检查Referer头
    定义 referer = HTTP头_获取(请求.头, "Referer")
    如果 (referer != 0) {
        定义 ref源 = 源_解析(referer)
        定义 目标源 = 源_解析(域)
        如果 (源_相等(ref源, 目标源)) { 返回 真 }
    }

    // 检查SameSite Cookie策略
    定义 cookie = HTTP头_获取(请求.头, "Cookie")
    如果 (cookie != 0 && 字符串查找(cookie, "SameSite=Strict") >= 0) {
        返回 真
    }

    安全_总拦截数 = 安全_总拦截数 + 1
    浏览器安全_记录事件(事件_CSRF检测, 域, "CSRF令牌验证失败", 真)
    返回 假
}

// §7 Clickjacking防护

函数 Clickjacking_检查(域, 响应头, 父框架源) {
    // X-Frame-Options
    定义 xfo = HTTP头_获取(响应头, "X-Frame-Options")
    如果 (xfo != 0) {
        如果 (字符串_相等(字符串_转大写(xfo), "DENY")) {
            浏览器安全_记录事件(事件_点击劫持, 域, "X-Frame-Options: DENY", 假)
            返回 假
        }
        如果 (字符串_相等(字符串_转大写(xfo), "SAMEORIGIN")) {
            定义 d源 = 源_解析(域)
            定义 p源 = 源_解析(父框架源)
            如果 (!源_相等(d源, p源)) {
                浏览器安全_记录事件(事件_点击劫持, 域,
                    "SAMEORIGIN: 父框架不同源", 真)
                返回 假
            }
        }
    }

    // CSP frame-ancestors
    定义 档案 = 浏览器安全_获取域档案(域)
    如果 (档案 != 0 && 计数(档案.csp.frame_src) > 0) {
        如果 (!CSP_源匹配(档案.csp.frame_src, 父框架源)) {
            浏览器安全_记录事件(事件_点击劫持, 域,
                "frame-ancestors不匹配", 真)
            返回 假
        }
    }
    返回 真
}

// §8 权限管理 (Permissions Policy)

函数 浏览器安全_请求权限(域, 权限类型) {
    定义 档案 = 浏览器安全_获取域档案(域)
    如果 (档案 == 0) {
        档案 = 浏览器安全_创建域档案(域)
    }

    // 检查是否已授权
    定义 可变 i = 0
    当 (i < 计数(档案.允许权限)) {
        如果 (档案.允许权限[i] == 权限类型) {
            返回 真
        }
        i = i + 1
    }

    // nova://协议自动授权
    如果 (字符串查找(域, "nova:") == 0) {
        追加(档案.允许权限, 权限类型)
        返回 真
    }

    // 系统调用权限需AI审核
    如果 (权限类型 == 权限_系统调用) {
        如果 (档案.信任等级 < 80) {
            浏览器安全_记录事件(事件_权限请求, 域,
                "系统调用权限拒绝: 信任度=" + 整数转字符串(档案.信任等级), 真)
            返回 假
        }
    }

    // 文件系统权限需高信任度
    如果 (权限类型 == 权限_文件读 || 权限类型 == 权限_文件写) {
        如果 (档案.信任等级 < 60) {
            浏览器安全_记录事件(事件_权限请求, 域,
                "文件权限拒绝: 信任度=" + 整数转字符串(档案.信任等级), 真)
            返回 假
        }
    }

    浏览器安全_记录事件(事件_权限请求, 域,
        "待审核: 权限" + 整数转字符串(权限类型), 假)
    返回 假
}

// §9 AI威胁评分 — EWMA风险聚合
// 创新: 指数加权移动平均域信誉学习

函数 浏览器安全_获取域档案(域) {
    定义 可变 i = 0
    当 (i < 计数(安全_域档案表)) {
        如果 (字符串_相等(安全_域档案表[i].域名, 域)) {
            返回 安全_域档案表[i]
        }
        i = i + 1
    }
    返回 0
}

函数 浏览器安全_创建域档案(域) {
    定义 档案 = 域安全档案 {}
    档案.域名 = 域
    档案.信任等级 = 50  // 默认中等信任
    档案.允许权限 = []
    档案.csp = CSP指令集 {}
    档案.允许CORS源 = []
    档案.违规计数 = 0
    档案.AI威胁分 = 0
    档案.EWMA_威胁 = 0
    档案.frame_策略 = 2  // 默认允许
    追加(安全_域档案表, 档案)
    返回 档案
}

函数 浏览器安全_更新威胁分(域, 事件分) {
    定义 档案 = 浏览器安全_获取域档案(域)
    如果 (档案 == 0) { 档案 = 浏览器安全_创建域档案(域) }
    档案.违规计数 = 档案.违规计数 + 1

    // EWMA: new_avg = α*sample + (1-α)*old_avg
    定义 样本 = 事件分 * Q_ONE / 100
    档案.EWMA_威胁 = (EWMA_ALPHA * 样本 + (Q_ONE - EWMA_ALPHA) * 档案.EWMA_威胁) / Q_ONE
    档案.AI威胁分 = 档案.EWMA_威胁

    // 根据威胁分调整信任等级
    如果 (档案.EWMA_威胁 > 700) {
        档案.信任等级 = 0   // 极高风险: 完全不信任
    } 否则如果 (档案.EWMA_威胁 > 500) {
        如果 (档案.信任等级 > 20) { 档案.信任等级 = 20 }
    } 否则如果 (档案.EWMA_威胁 > 300) {
        如果 (档案.信任等级 > 40) { 档案.信任等级 = 40 }
    }
}

函数 浏览器安全_评估域(域) {
    定义 档案 = 浏览器安全_获取域档案(域)
    如果 (档案 == 0) { 档案 = 浏览器安全_创建域档案(域) }
    返回 档案
}

// §10 安全事件审计日志

结构 安全事件 {
    类型,
    域名,
    描述,
    严重,
    时间戳,
}

函数 浏览器安全_记录事件(类型, 域, 描述, 严重) {
    定义 事件 = 安全事件 {}
    事件.类型 = 类型
    事件.域名 = 域
    事件.描述 = 描述
    事件.严重 = 严重
    事件.时间戳 = 平台_获取时间戳()
    追加(安全_审计日志, 事件)

    // 严重事件触发威胁分更新
    如果 (严重) {
        浏览器安全_更新威胁分(域, 80)
    } 否则 {
        浏览器安全_更新威胁分(域, 20)
    }

    // 日志轮转: 保留最近1000条
    如果 (计数(安全_审计日志) > 1000) {
        安全_审计日志 = 列表_切片(安全_审计日志, 计数(安全_审计日志) - 500, 计数(安全_审计日志))
    }
}

函数 浏览器安全_获取统计() {
    返回 "检查=" + 整数转字符串(安全_总检查数) +
           " 拦截=" + 整数转字符串(安全_总拦截数) +
           " 域数=" + 整数转字符串(计数(安全_域档案表)) +
           " 日志=" + 整数转字符串(计数(安全_审计日志))
}

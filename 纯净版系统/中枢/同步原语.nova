定义 同步类型_互斥 = "互斥"
定义 同步类型_自旋 = "自旋"
定义 同步类型_读写 = "读写"
定义 同步类型_完成 = "完成"
定义 同步类型_等待 = "等待"
定义 同步类型_快锁 = "快锁"

结构 同步句柄 {
    名称,
    类型,
    对象,
    辅助,
    模式,
    可中断,
}

结构 同步摘要 {
    名称,
    类型,
    模式,
    已锁定,
    等待者数,
    健康,
    统计,
}

函数 同步原语_创建句柄(名称, 类型, 对象, 辅助, 模式) {
    定义 句柄 = 堆_分配(同步句柄)
    句柄.名称 = 名称
    句柄.类型 = 类型
    句柄.对象 = 对象
    句柄.辅助 = 辅助
    句柄.模式 = 模式
    句柄.可中断 = 假
    返回 句柄
}

函数 同步原语_创建互斥(名称) {
    返回 同步原语_创建句柄(名称, 同步类型_互斥, 互斥锁_创建(), 0, "独占")
}

函数 同步原语_创建自旋(名称) {
    返回 同步原语_创建句柄(名称, 同步类型_自旋, 自旋锁_创建(), 0, "独占")
}

函数 同步原语_创建读写(名称) {
    返回 同步原语_创建句柄(名称, 同步类型_读写, 读写自旋锁_创建(), 0, "读")
}

函数 同步原语_创建完成(名称) {
    返回 同步原语_创建句柄(名称, 同步类型_完成, 完成量_创建(), 0, "完成")
}

函数 同步原语_创建等待(名称) {
    返回 同步原语_创建句柄(名称, 同步类型_等待, 等待队列_创建(), 0, "等待")
}

函数 同步原语_创建快锁(名称, 地址) {
    定义 快锁 = Nova快速锁_初始化()
    返回 同步原语_创建句柄(名称, 同步类型_快锁, 快锁, 地址, "快锁")
}

函数 同步原语_设可中断(句柄, 可中断) {
    句柄.可中断 = 可中断
}

函数 同步原语_设模式(句柄, 模式) {
    句柄.模式 = 模式
}

函数 同步原语_名称(句柄) { 返回 句柄.名称 }
函数 同步原语_类型(句柄) { 返回 句柄.类型 }
函数 同步原语_模式(句柄) { 返回 句柄.模式 }

函数 同步原语_获取(句柄) {
    如果 (句柄.类型 == 同步类型_互斥) {
        如果 (句柄.可中断) {
            返回 互斥锁_可中断获取(句柄.对象)
        }
        互斥锁_获取(句柄.对象)
        返回 1
    }
    如果 (句柄.类型 == 同步类型_自旋) {
        自旋锁_获取(句柄.对象)
        返回 1
    }
    如果 (句柄.类型 == 同步类型_读写) {
        如果 (句柄.模式 == "写") {
            写锁_获取(句柄.对象)
        } 否则 {
            读锁_获取(句柄.对象)
        }
        返回 1
    }
    如果 (句柄.类型 == 同步类型_完成) {
        如果 (句柄.可中断) {
            返回 wait_for_completion_可中断(句柄.对象)
        }
        wait_for_completion(句柄.对象)
        返回 1
    }
    如果 (句柄.类型 == 同步类型_等待) {
        返回 0
    }
    如果 (句柄.类型 == 同步类型_快锁) {
        返回 Nova快速锁_wait(句柄.辅助, 0, 0, 0)
    }
    返回 0
}

函数 同步原语_尝试获取(句柄) {
    如果 (句柄.类型 == 同步类型_互斥) {
        返回 互斥锁_尝试获取(句柄.对象)
    }
    如果 (句柄.类型 == 同步类型_自旋) {
        返回 自旋锁_尝试获取(句柄.对象)
    }
    如果 (句柄.类型 == 同步类型_读写) {
        如果 (句柄.模式 == "写") {
            返回 写锁_尝试获取(句柄.对象)
        }
        返回 读锁_尝试获取(句柄.对象)
    }
    如果 (句柄.类型 == 同步类型_完成) {
        返回 try_wait_for_completion(句柄.对象)
    }
    返回 0
}

函数 同步原语_释放(句柄) {
    如果 (句柄.类型 == 同步类型_互斥) {
        互斥锁_释放(句柄.对象)
        返回
    }
    如果 (句柄.类型 == 同步类型_自旋) {
        自旋锁_释放(句柄.对象)
        返回
    }
    如果 (句柄.类型 == 同步类型_读写) {
        如果 (句柄.模式 == "写") {
            写锁_释放(句柄.对象)
        } 否则 {
            读锁_释放(句柄.对象)
        }
        返回
    }
    如果 (句柄.类型 == 同步类型_完成) {
        complete(句柄.对象)
        返回
    }
    如果 (句柄.类型 == 同步类型_快锁) {
        Nova快速锁_wake(句柄.辅助, 1, 0)
        返回
    }
}

函数 同步原语_读获取(句柄) {
    如果 (句柄.类型 != 同步类型_读写) { 返回 0 }
    句柄.模式 = "读"
    读锁_获取(句柄.对象)
    返回 1
}

函数 同步原语_写获取(句柄) {
    如果 (句柄.类型 != 同步类型_读写) { 返回 0 }
    句柄.模式 = "写"
    写锁_获取(句柄.对象)
    返回 1
}

函数 同步原语_读释放(句柄) {
    如果 (句柄.类型 != 同步类型_读写) { 返回 0 }
    读锁_释放(句柄.对象)
    句柄.模式 = "读"
    返回 1
}

函数 同步原语_写释放(句柄) {
    如果 (句柄.类型 != 同步类型_读写) { 返回 0 }
    写锁_释放(句柄.对象)
    句柄.模式 = "写"
    返回 1
}

函数 同步原语_降级到读(句柄) {
    如果 (句柄.类型 != 同步类型_读写) { 返回 0 }
    读写信号量_降级写到读(句柄.对象)
    句柄.模式 = "读"
    返回 1
}

函数 同步原语_等待完成(句柄) {
    如果 (句柄.类型 != 同步类型_完成) { 返回 0 }
    wait_for_completion(句柄.对象)
    返回 1
}

函数 同步原语_等待完成_超时(句柄, 超时毫秒) {
    如果 (句柄.类型 != 同步类型_完成) { 返回 0 }
    返回 wait_for_completion_超时(句柄.对象, 超时毫秒)
}

函数 同步原语_等待完成_可中断(句柄) {
    如果 (句柄.类型 != 同步类型_完成) { 返回 0 }
    返回 wait_for_completion_可中断(句柄.对象)
}

函数 同步原语_完成(句柄) {
    如果 (句柄.类型 != 同步类型_完成) { 返回 0 }
    complete(句柄.对象)
    返回 1
}

函数 同步原语_完成全部(句柄) {
    如果 (句柄.类型 != 同步类型_完成) { 返回 0 }
    complete_all(句柄.对象)
    返回 1
}

函数 同步原语_重置完成(句柄) {
    如果 (句柄.类型 != 同步类型_完成) { 返回 0 }
    完成量_重置(句柄.对象)
    返回 1
}

函数 同步原语_等待队列_加入(句柄, 项) {
    如果 (句柄.类型 != 同步类型_等待) { 返回 0 }
    等待队列_加入(句柄.对象, 项)
    返回 1
}

函数 同步原语_等待队列_移除(句柄, 项) {
    如果 (句柄.类型 != 同步类型_等待) { 返回 0 }
    等待队列_移除(句柄.对象, 项)
    返回 1
}

函数 同步原语_等待队列_等待(句柄, 条件函数) {
    如果 (句柄.类型 != 同步类型_等待) { 返回 0 }
    返回 等待队列_等待(句柄.对象, 条件函数)
}

函数 同步原语_等待队列_等待_超时(句柄, 条件函数, 超时毫秒) {
    如果 (句柄.类型 != 同步类型_等待) { 返回 0 }
    返回 等待队列_等待_超时(句柄.对象, 条件函数, 超时毫秒)
}

函数 同步原语_等待队列_等待_可中断(句柄, 条件函数) {
    如果 (句柄.类型 != 同步类型_等待) { 返回 0 }
    返回 等待队列_等待_可中断(句柄.对象, 条件函数)
}

函数 同步原语_等待队列_唤醒一个(句柄) {
    如果 (句柄.类型 != 同步类型_等待) { 返回 0 }
    等待队列_唤醒一个(句柄.对象)
    返回 1
}

函数 同步原语_等待队列_唤醒全部(句柄) {
    如果 (句柄.类型 != 同步类型_等待) { 返回 0 }
    等待队列_唤醒全部(句柄.对象)
    返回 1
}

函数 同步原语_快锁_等待(句柄, 期望值, 超时, 位集) {
    如果 (句柄.类型 != 同步类型_快锁) { 返回 0 }
    返回 Nova快速锁_wait(句柄.辅助, 期望值, 超时, 位集)
}

函数 同步原语_快锁_唤醒(句柄, 唤醒数, 位集) {
    如果 (句柄.类型 != 同步类型_快锁) { 返回 0 }
    返回 Nova快速锁_wake(句柄.辅助, 唤醒数, 位集)
}

函数 同步原语_快锁_重排(句柄, 唤醒数, 目标地址, 重排数) {
    如果 (句柄.类型 != 同步类型_快锁) { 返回 0 }
    返回 Nova快速锁_requeue(句柄.辅助, 唤醒数, 目标地址, 重排数)
}

函数 同步原语_已锁定(句柄) {
    如果 (句柄.类型 == 同步类型_互斥) { 返回 互斥锁_已锁定(句柄.对象) }
    如果 (句柄.类型 == 同步类型_自旋) { 返回 自旋锁_已锁定(句柄.对象) }
    如果 (句柄.类型 == 同步类型_读写) { 返回 读写锁_有写者(句柄.对象) || 读写锁_读者数(句柄.对象) > 0 }
    如果 (句柄.类型 == 同步类型_完成) { 返回 !完成量_已完成(句柄.对象) }
    如果 (句柄.类型 == 同步类型_等待) { 返回 !等待队列_为空(句柄.对象) }
    返回 0
}

函数 同步原语_等待者数(句柄) {
    如果 (句柄.类型 == 同步类型_互斥) { 返回 互斥锁_等待者数(句柄.对象) }
    如果 (句柄.类型 == 同步类型_自旋) { 返回 自旋锁_等待者数(句柄.对象) }
    如果 (句柄.类型 == 同步类型_读写) { 返回 读写锁_读者数(句柄.对象) }
    如果 (句柄.类型 == 同步类型_完成) { 返回 完成量_等待者数(句柄.对象) }
    如果 (句柄.类型 == 同步类型_等待) { 返回 等待队列_等待者数(句柄.对象) }
    返回 0
}

函数 同步原语_健康检查(句柄) {
    如果 (句柄.类型 == 同步类型_互斥) { 返回 互斥锁_健康检查() }
    如果 (句柄.类型 == 同步类型_完成) { 返回 完成量_健康检查() }
    如果 (句柄.类型 == 同步类型_等待) { 返回 0 }
    如果 (句柄.类型 == 同步类型_自旋) { 返回 0 }
    如果 (句柄.类型 == 同步类型_读写) { 返回 0 }
    如果 (句柄.类型 == 同步类型_快锁) { 返回 0 }
    返回 1
}

函数 同步原语_统计串(句柄) {
    如果 (句柄.类型 == 同步类型_互斥) { 返回 互斥锁_完整统计() }
    如果 (句柄.类型 == 同步类型_完成) { 返回 完成量_完整统计() }
    如果 (句柄.类型 == 同步类型_等待) { 返回 等待队列_完整统计() }
    如果 (句柄.类型 == 同步类型_快锁) { 返回 Nova快速锁_完整统计() }
    如果 (句柄.类型 == 同步类型_自旋) {
        返回 "等待者=" + 整数转字符串(自旋锁_等待者数(句柄.对象))
    }
    如果 (句柄.类型 == 同步类型_读写) {
        定义 建 = 字符串构建器_创建()
        字符串构建器_追加(建, "读者=")
        字符串构建器_追加(建, 整数转字符串(读写锁_读者数(句柄.对象)))
        字符串构建器_追加(建, ",写者=")
        如果 (读写锁_有写者(句柄.对象)) {
            字符串构建器_追加(建, "true")
        } 否则 {
            字符串构建器_追加(建, "false")
        }
        返回 字符串构建器_构建(建)
    }
    返回 ""
}

函数 同步原语_摘要(句柄) {
    定义 摘 = 堆_分配(同步摘要)
    摘.名称 = 句柄.名称
    摘.类型 = 句柄.类型
    摘.模式 = 句柄.模式
    摘.已锁定 = 同步原语_已锁定(句柄)
    摘.等待者数 = 同步原语_等待者数(句柄)
    摘.健康 = 同步原语_健康检查(句柄)
    摘.统计 = 同步原语_统计串(句柄)
    返回 摘
}

函数 同步原语_摘要串(句柄) {
    定义 摘 = 同步原语_摘要(句柄)
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "{")
    字符串构建器_追加(建, "\"名称\":\"")
    字符串构建器_追加(建, 摘.名称)
    字符串构建器_追加(建, "\",\"类型\":\"")
    字符串构建器_追加(建, 摘.类型)
    字符串构建器_追加(建, "\",\"模式\":\"")
    字符串构建器_追加(建, 摘.模式)
    字符串构建器_追加(建, "\",\"已锁定\":")
    如果 (摘.已锁定) { 字符串构建器_追加(建, "true") } 否则 { 字符串构建器_追加(建, "false") }
    字符串构建器_追加(建, ",\"等待者数\":")
    字符串构建器_追加(建, 整数转字符串(摘.等待者数))
    字符串构建器_追加(建, ",\"健康\":")
    字符串构建器_追加(建, 整数转字符串(摘.健康))
    字符串构建器_追加(建, ",\"统计\":\"")
    字符串构建器_追加(建, 摘.统计)
    字符串构建器_追加(建, "\"}")
    返回 字符串构建器_构建(建)
}

函数 同步原语_批量摘要(列表) {
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "[")
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (i > 0) { 字符串构建器_追加(建, ",") }
        字符串构建器_追加(建, 同步原语_摘要串(列表[i]))
        i = i + 1
    }
    字符串构建器_追加(建, "]")
    返回 字符串构建器_构建(建)
}

函数 同步原语_创建默认组() {
    定义 组 = []
    追加(组, 同步原语_创建互斥("主互斥"))
    追加(组, 同步原语_创建自旋("主自旋"))
    追加(组, 同步原语_创建读写("主读写"))
    追加(组, 同步原语_创建完成("主完成"))
    追加(组, 同步原语_创建等待("主等待"))
    返回 组
}

函数 同步原语_组健康检查(列表) {
    定义 可变 错数 = 0
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        定义 健康 = 同步原语_健康检查(列表[i])
        如果 (健康 != 0) { 错数 = 错数 + 1 }
        i = i + 1
    }
    返回 错数
}

函数 同步原语_组等待者总数(列表) {
    定义 可变 总数 = 0
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        总数 = 总数 + 同步原语_等待者数(列表[i])
        i = i + 1
    }
    返回 总数
}

函数 同步原语_组摘要串(列表) {
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "{")
    字符串构建器_追加(建, "\"数量\":")
    字符串构建器_追加(建, 整数转字符串(计数(列表)))
    字符串构建器_追加(建, ",\"等待者总数\":")
    字符串构建器_追加(建, 整数转字符串(同步原语_组等待者总数(列表)))
    字符串构建器_追加(建, ",\"错误数\":")
    字符串构建器_追加(建, 整数转字符串(同步原语_组健康检查(列表)))
    字符串构建器_追加(建, ",\"明细\":")
    字符串构建器_追加(建, 同步原语_批量摘要(列表))
    字符串构建器_追加(建, "}")
    返回 字符串构建器_构建(建)
}

函数 同步原语_示例流程() {
    定义 互斥 = 同步原语_创建互斥("示例互斥")
    定义 自旋 = 同步原语_创建自旋("示例自旋")
    定义 读写 = 同步原语_创建读写("示例读写")
    定义 完成 = 同步原语_创建完成("示例完成")
    定义 等待 = 同步原语_创建等待("示例等待")

    同步原语_获取(互斥)
    同步原语_释放(互斥)

    同步原语_获取(自旋)
    同步原语_释放(自旋)

    同步原语_读获取(读写)
    同步原语_读释放(读写)
    同步原语_写获取(读写)
    同步原语_写释放(读写)

    同步原语_完成(完成)
    同步原语_等待队列_唤醒全部(等待)

    返回 同步原语_组摘要串([互斥, 自旋, 读写, 完成, 等待])
}

// merge source: 沙盒批次/批三/待厚/中枢/互斥锁.nova
//   1. 快速路径(fastpath): cmpxchg直接获取, 无锁竞争时零开销
//   2. 中速路径(midpath/optimistic spin): 自旋等待持有者释放
//      — 仅当持有者正在运行(在CPU上)时自旋, 避免调度开销
//   3. 慢速路径(slowpath): 加入等待队列, 睡眠等待
//   4. 等待队列FIFO: 保证公平性, 防止饿死
//   5. 严格所有权: 只有持有者能释放, 不支持递归
//   6. 调试: lockdep死锁检测(CONFIG_DEBUG_MUTEXES)

定义 MUTEX_UNLOCKED = 0
定义 MUTEX_LOCKED   = 1

定义 MUTEX_自旋上限 = 100

定义 可变 mutex_快速路径_次数 = 0
定义 可变 mutex_中速路径_次数 = 0
定义 可变 mutex_慢速路径_次数 = 0
定义 可变 mutex_竞争_次数 = 0

结构 互斥锁 {
    原子计数,    // i32 0=未锁, 1=已锁 (atomic_t count)
    等待队列,    // [] wait_list: 等待获取锁的进程FIFO
    持有者,    // u64 owner: 持有者task_struct指针
    自旋锁,    // u32 wait_lock: 保护等待队列的自旋锁
}

// 创建

函数 互斥锁_创建() {
    定义 锁 = 互斥锁 {}
    锁.原子计数 = MUTEX_UNLOCKED
    锁.等待队列 = []
    锁.持有者 = 0
    锁.自旋锁 = 0
    返回 锁
}

// mutex_lock: 获取互斥锁 (可睡眠)
// 三级路径: fastpath → midpath(optimistic spin) → slowpath(sleep)

函数 互斥锁_获取(锁) {
    定义 当前 = 获取当前进程()

    如果 (原子_比较交换_返回旧值(锁.原子计数, MUTEX_UNLOCKED, MUTEX_LOCKED)) {
        锁.持有者 = 当前
        mutex_快速路径_次数 = mutex_快速路径_次数 + 1
        返回
    }

    mutex_竞争_次数 = mutex_竞争_次数 + 1

    // 条件: 持有者正在CPU上运行(不在睡眠) → 很快会释放
    如果 (锁.持有者 != 0 && 互斥锁_持有者在运行(锁)) {
        定义 可变 自旋次数 = 0
        当 (自旋次数 < MUTEX_自旋上限) {
            如果 (原子_比较交换_返回旧值(锁.原子计数, MUTEX_UNLOCKED, MUTEX_LOCKED)) {
                锁.持有者 = 当前
                mutex_中速路径_次数 = mutex_中速路径_次数 + 1
                返回
            }
            // 如果持有者不再运行, 放弃自旋
            如果 (!互斥锁_持有者在运行(锁)) { 中断 }
            cpu_松弛()  // pause指令, 减少流水线惩罚
            自旋次数 = 自旋次数 + 1
        }
    }

    互斥锁_慢速路径(锁, 当前)
}

函数 互斥锁_慢速路径(锁, 当前) {
    // 获取等待队列自旋锁
    自旋锁_获取(锁.自旋锁)

    // 加入等待队列尾部(FIFO)
    追加(锁.等待队列, 当前)

    循环 {
        // 设置进程状态为不可中断睡眠
        进程_设置状态(当前, 进程状态_等待)

        // 释放自旋锁后调度
        自旋锁_释放(锁.自旋锁)
        调度()

        // 被唤醒: 尝试获取锁
        自旋锁_获取(锁.自旋锁)

        如果 (原子_比较交换_返回旧值(锁.原子计数, MUTEX_UNLOCKED, MUTEX_LOCKED)) {
            // 获取成功: 从等待队列移除自己
            等待队列_移除(锁.等待队列, 当前)
            锁.持有者 = 当前
            自旋锁_释放(锁.自旋锁)
            进程_设置状态(当前, 进程状态_就绪)
            mutex_慢速路径_次数 = mutex_慢速路径_次数 + 1
            返回
        }
        // 未获取: 继续睡眠
    }
}

// mutex_trylock: 尝试获取 (非阻塞)

函数 互斥锁_尝试获取(锁) {
    如果 (原子_比较交换_返回旧值(锁.原子计数, MUTEX_UNLOCKED, MUTEX_LOCKED)) {
        锁.持有者 = 获取当前进程()
        返回 真
    }
    返回 假
}

// mutex_unlock: 释放互斥锁

函数 互斥锁_释放(锁) {
    // 调试: 检查是否由持有者释放
    // 如果 (锁.持有者 != 获取当前进程()) { 内核警告("mutex: 非持有者释放!") }

    锁.持有者 = 0

    // 快速路径: 无等待者, 直接释放
    如果 (计数(锁.等待队列) == 0) {
        原子_存储(锁.原子计数, MUTEX_UNLOCKED)
        返回
    }

    // 慢速路径: 有等待者, 唤醒队首
    自旋锁_获取(锁.自旋锁)
    原子_存储(锁.原子计数, MUTEX_UNLOCKED)

    如果 (计数(锁.等待队列) > 0) {
        定义 等待者 = 锁.等待队列[0]
        进程_设置状态(等待者, 进程状态_就绪)
        调度_入队(等待者)
    }
    自旋锁_释放(锁.自旋锁)
}

// mutex_lock_interruptible: 可被信号中断的获取

函数 互斥锁_可中断获取(锁) {
    定义 当前 = 获取当前进程()

    // 快速路径
    如果 (原子_比较交换_返回旧值(锁.原子计数, MUTEX_UNLOCKED, MUTEX_LOCKED)) {
        锁.持有者 = 当前
        返回 成功
    }

    // 慢速路径(可被信号中断)
    自旋锁_获取(锁.自旋锁)
    追加(锁.等待队列, 当前)

    循环 {
        进程_设置状态(当前, 进程状态_可中断等待)
        自旋锁_释放(锁.自旋锁)
        调度()

        // 检查是否被信号唤醒
        如果 (进程_有待处理信号(当前)) {
            自旋锁_获取(锁.自旋锁)
            等待队列_移除(锁.等待队列, 当前)
            自旋锁_释放(锁.自旋锁)
            进程_设置状态(当前, 进程状态_就绪)
            返回 错误_被中断   // -EINTR
        }

        自旋锁_获取(锁.自旋锁)
        如果 (原子_比较交换_返回旧值(锁.原子计数, MUTEX_UNLOCKED, MUTEX_LOCKED)) {
            等待队列_移除(锁.等待队列, 当前)
            锁.持有者 = 当前
            自旋锁_释放(锁.自旋锁)
            进程_设置状态(当前, 进程状态_就绪)
            返回 成功
        }
    }
}

// 查询

函数 互斥锁_已锁定(锁) {
    返回 锁.原子计数 != MUTEX_UNLOCKED
}

函数 互斥锁_持有者(锁) {
    返回 锁.持有者
}

函数 互斥锁_等待者数(锁) {
    返回 计数(锁.等待队列)
}

// 辅助

函数 互斥锁_持有者在运行(锁) {
    定义 持有者 = 锁.持有者
    如果 (持有者 == 0) { 返回 假 }
    返回 进程_状态(持有者) == 进程状态_就绪 || 进程_在CPU上(持有者)
}

函数 等待队列_移除_互斥(队列, 进程) {
    定义 可变 i = 0
    当 (i < 计数(队列)) {
        如果 (队列[i] == 进程) {
            链表_删除(队列, i)
            返回
        }
        i = i + 1
    }
}

// 错误_被中断 定义在 核心/公共/错误码.nova

// 统计

函数 互斥锁_统计() {
    返回 [mutex_快速路径_次数, mutex_中速路径_次数, mutex_慢速路径_次数, mutex_竞争_次数]
}

// 竞争率 + 完整统计

函数 互斥锁_竞争率() {
    定义 总 = mutex_快速路径_次数 + mutex_中速路径_次数 + mutex_慢速路径_次数
    如果 (总 == 0) { 返回 0 }
    返回 mutex_竞争_次数 * 100 / 总
}

函数 互斥锁_完整统计() {
    返回 [mutex_快速路径_次数, mutex_中速路径_次数, mutex_慢速路径_次数, mutex_竞争_次数, 互斥锁_竞争率()]
}

// 互斥锁健康检查

函数 互斥锁_健康检查() {
    定义 可变 问题 = []
    如果 (互斥锁_竞争率() > 50) {
        追加(问题, "互斥锁竞争率过高: " + 整数转字符串(互斥锁_竞争率()) + "%")
    }
    如果 (mutex_慢速路径_次数 > mutex_快速路径_次数 && mutex_快速路径_次数 > 100) {
        追加(问题, "慢速路径占比过高，可能存在锁热点")
    }
    如果 (计数(问题) == 0) { 返回 "互斥锁健康" }
    返回 问题
}

函数 互斥锁_重置统计() {
    mutex_快速路径_次数 = 0
    mutex_中速路径_次数 = 0
    mutex_慢速路径_次数 = 0
    mutex_竞争_次数 = 0
}

函数 互斥锁_总获取次数() {
    返回 mutex_快速路径_次数 + mutex_中速路径_次数 + mutex_慢速路径_次数
}

函数 互斥锁_快速路径率() {
    定义 总 = 互斥锁_总获取次数()
    如果 (总 == 0) { 返回 0 }
    返回 mutex_快速路径_次数 * 100 / 总
}

函数 互斥锁_慢速路径率() {
    定义 总 = 互斥锁_总获取次数()
    如果 (总 == 0) { 返回 0 }
    返回 mutex_慢速路径_次数 * 100 / 总
}

// merge source: 沙盒批次/批三/待厚/中枢/完成量.nova
//   1. completion: 一次性同步原语(一个线程等待另一个完成)
//   2. 比信号量更轻量: 专为"等待完成"场景优化
//   3. wait_for_completion: 阻塞直到complete()被调用
//   4. complete: 唤醒一个等待者
//   5. complete_all: 唤醒所有等待者(永久完成)
//   6. 用于: 驱动初始化等待/IO完成/模块加载同步

结构 完成量 {
    done,    // u32 完成计数(0=未完成, >0=已完成)
    等待队列,    // u64 等待队列头
}

// 创建/初始化 

函数 完成量_创建() {
    定义 c = 完成量 {}
    c.done = 0
    c.等待队列 = 等待队列_创建()
    返回 c
}

函数 完成量_重置(c) {
    c.done = 0
}

// 等待完成 

函数 wait_for_completion(c) {
    // 快速路径: 已完成
    如果 (c.done > 0) {
        c.done = c.done - 1
        返回
    }

    // 慢速路径: 加入等待队列, 睡眠
    定义 当前 = 获取当前进程()
    定义 项 = 等待项_创建(当前, 真)   // 排他等待
    等待队列_加入(c.等待队列, 项)

    当 (c.done == 0) {
        进程_设置状态(当前, 进程_等待)
        调度()
    }

    等待队列_移除(c.等待队列, 项)
    c.done = c.done - 1
    进程_设置状态(当前, 进程_运行)
}

函数 wait_for_completion_超时(c, 超时_ms) {
    如果 (c.done > 0) {
        c.done = c.done - 1
        返回 真
    }

    定义 当前 = 获取当前进程()
    定义 项 = 等待项_创建(当前, 真)
    等待队列_加入(c.等待队列, 项)

    定义 截止 = 读取毫秒() + 超时_ms
    当 (c.done == 0 && 读取毫秒() < 截止) {
        进程_设置状态(当前, 进程_等待)
        调度()
    }

    等待队列_移除(c.等待队列, 项)
    定义 完成 = c.done > 0
    如果 (完成) { c.done = c.done - 1 }
    进程_设置状态(当前, 进程_运行)
    返回 完成
}

函数 wait_for_completion_可中断(c) {
    // TASK_INTERRUPTIBLE: 信号可中断等待
    wait_for_completion(c)
}

// 完成通知 

函数 complete(c) {
    // 唤醒一个等待者
    c.done = c.done + 1
    等待队列_唤醒一个(c.等待队列)
}

函数 complete_all(c) {
    // 永久完成: done设为最大值, 唤醒所有等待者
    c.done = 0x7FFFFFFF
    等待队列_唤醒全部(c.等待队列)
}

// 查询

函数 完成量_已完成(c) { 返回 c.done > 0 }
函数 完成量_等待者数(c) { 返回 等待队列_等待者数(c.等待队列) }

// try_wait: 非阻塞尝试 

函数 try_wait_for_completion(c) {
    如果 (c.done > 0) {
        c.done = c.done - 1
        返回 真
    }
    返回 假
}

// complete_N: 唤醒N个等待者 

函数 complete_n(c, n) {
    c.done = c.done + n
    定义 可变 i = 0
    当 (i < n) {
        等待队列_唤醒一个(c.等待队列)
        i = i + 1
    }
}

// wait_for_completion_killable: 可被SIGKILL中断

函数 wait_for_completion_killable(c) {
    如果 (c.done > 0) {
        c.done = c.done - 1
        返回 0
    }

    定义 当前 = 获取当前进程()
    定义 项 = 等待项_创建(当前, 真)
    等待队列_加入(c.等待队列, 项)

    当 (c.done == 0) {
        进程_设置状态(当前, 进程_等待_可杀)
        // 检查是否有致命信号
        如果 (信号_有致命(当前)) {
            等待队列_移除(c.等待队列, 项)
            进程_设置状态(当前, 进程_运行)
            返回 -512  // -ERESTARTSYS
        }
        调度()
    }

    等待队列_移除(c.等待队列, 项)
    c.done = c.done - 1
    进程_设置状态(当前, 进程_运行)
    返回 0
}

// wait_for_completion_interruptible_timeout

函数 wait_for_completion_可中断_超时(c, 超时_ms) {
    如果 (c.done > 0) {
        c.done = c.done - 1
        返回 超时_ms  // 返回剩余时间
    }

    定义 当前 = 获取当前进程()
    定义 项 = 等待项_创建(当前, 真)
    等待队列_加入(c.等待队列, 项)

    定义 截止 = 读取毫秒() + 超时_ms
    当 (c.done == 0) {
        定义 剩余 = 截止 - 读取毫秒()
        如果 (剩余 <= 0) {
            // 超时
            等待队列_移除(c.等待队列, 项)
            进程_设置状态(当前, 进程_运行)
            返回 0  // 超时返回0
        }
        // 检查信号
        如果 (信号_待处理(当前)) {
            等待队列_移除(c.等待队列, 项)
            进程_设置状态(当前, 进程_运行)
            返回 -512  // -ERESTARTSYS
        }
        进程_设置状态(当前, 进程_等待)
        调度()
    }

    等待队列_移除(c.等待队列, 项)
    c.done = c.done - 1
    进程_设置状态(当前, 进程_运行)
    返回 截止 - 读取毫秒()
}

// 进程状态常量

定义 进程_运行 = 0
定义 进程_等待 = 1
定义 进程_等待_可杀 = 2

// 完成量统计

定义 可变 完成量_总完成次数 = 0
定义 可变 完成量_总等待次数 = 0

函数 完成量_done计数(c) { 返回 c.done }

函数 完成量_统计() {
    返回 [完成量_总完成次数, 完成量_总等待次数]
}

// 状态名称 + 完整统计

函数 完成量_状态名(c) {
    如果 (c.done >= 0x7FFFFFFF) { 返回 "completed_all" }
    如果 (c.done > 0) { 返回 "done" }
    返回 "pending"
}

函数 完成量_完整统计() {
    返回 [完成量_总完成次数, 完成量_总等待次数]
}

// 完成量辅助

函数 完成量_健康检查() {
    定义 可变 问题 = []
    如果 (完成量_总等待次数 > 完成量_总完成次数 * 5 && 完成量_总完成次数 > 10) {
        追加(问题, "完成量等待/完成比异常")
    }
    如果 (计数(问题) == 0) { 返回 "完成量健康" }
    返回 问题
}

函数 完成量_重置统计() {
    完成量_总完成次数 = 0
    完成量_总等待次数 = 0
}

函数 完成量_完成率() {
    如果 (完成量_总等待次数 == 0) { 返回 100 }
    返回 完成量_总完成次数 * 100 / 完成量_总等待次数
}

定义 COMPLETION_DONE_ALL = 0x7FFFFFFF
定义 COMPLETION_TIMEOUT_DEFAULT = 5000

函数 完成量_是否已完成(c) {
    返回 c.done > 0
}

函数 完成量_是否全部完成(c) {
    返回 c.done >= COMPLETION_DONE_ALL
}

函数 完成量_等待数(c) {
    如果 (c.等待者 == 空) { 返回 0 }
    返回 计数(c.等待者)
}

// merge source: 沙盒批次/批三/待厚/中枢/快速锁.nova
//   1. Nova快速锁 = Fast Userspace muTEX: 用户态快速路径 + 内核慢速路径
//   2. 无竞争时纯用户态atomic操作(无系统调用)
//   3. 有竞争时进入内核: Nova快速锁_WAIT(睡眠) / Nova快速锁_WAKE(唤醒)
//   4. 哈希表: 按Nova快速锁地址哈希到等待队列桶
//   5. PI-Nova快速锁: 优先级继承(避免优先级反转)
//   6. 是Nova线程_mutex/sem_wait/条件变量的底层实现

定义 Nova快速锁_WAIT          = 0
定义 Nova快速锁_WAKE          = 1
定义 Nova快速锁_FD            = 2
定义 Nova快速锁_REQUEUE       = 3
定义 Nova快速锁_CMP_REQUEUE   = 4
定义 Nova快速锁_WAKE_OP       = 5
定义 Nova快速锁_WAIT_BITSET   = 9
定义 Nova快速锁_WAKE_BITSET   = 10
定义 Nova快速锁_PRIVATE_FLAG  = 128

定义 Nova快速锁_BITSET_MATCH_ANY = 0xFFFFFFFF

定义 Nova快速锁_HASH_SIZE = 256   // 哈希桶数(2的幂)
结构 Nova快速锁_桶 {
    锁,
    等待链,    // [] Nova快速锁_q列表
}

结构 Nova快速锁_q {
    进程,    // u64 等待的task_struct
    键,    // u64 Nova快速锁地址(用户空间虚拟地址)
    bitset,    // u32 位集(Nova快速锁_WAIT_BITSET用)
    超时,    // u64 超时时间(0=无限)
}

定义 可变 Nova快速锁_哈希表 = []
定义 可变 Nova快速锁_wait总数 = 0
定义 可变 Nova快速锁_wake总数 = 0

// 初始化

函数 Nova快速锁_初始化() {
    Nova快速锁_哈希表 = []
    定义 可变 i = 0
    当 (i < Nova快速锁_HASH_SIZE) {
        定义 桶 = Nova快速锁_桶 {}
        桶.锁 = 自旋锁_创建()
        桶.等待链 = []
        追加(Nova快速锁_哈希表, 桶)
        i = i + 1
    }
    内核信息("Nova快速锁: 初始化 (" + 整数转字符串(Nova快速锁_HASH_SIZE) + "桶)")
}

// sys_Nova快速锁入口 

函数 sys_Nova快速锁(uaddr, op, val, timeout, uaddr2, val3) {
    定义 cmd = op & ~Nova快速锁_PRIVATE_FLAG

    如果 (cmd == Nova快速锁_WAIT || cmd == Nova快速锁_WAIT_BITSET) {
        定义 bitset = Nova快速锁_BITSET_MATCH_ANY
        如果 (cmd == Nova快速锁_WAIT_BITSET) { bitset = val3 }
        返回 Nova快速锁_wait(uaddr, val, timeout, bitset)
    }

    如果 (cmd == Nova快速锁_WAKE || cmd == Nova快速锁_WAKE_BITSET) {
        定义 bitset = Nova快速锁_BITSET_MATCH_ANY
        如果 (cmd == Nova快速锁_WAKE_BITSET) { bitset = val3 }
        返回 Nova快速锁_wake(uaddr, val, bitset)
    }

    如果 (cmd == Nova快速锁_CMP_REQUEUE) {
        返回 Nova快速锁_requeue(uaddr, val, uaddr2, val3)
    }

    返回 错误_无效参数
}

// Nova快速锁_WAIT: 如果*uaddr==val则睡眠

函数 Nova快速锁_wait(uaddr, expected, timeout, bitset) {
    // 1. 计算哈希桶
    定义 桶索引 = Nova快速锁_哈希(uaddr)
    定义 桶 = Nova快速锁_哈希表[桶索引]

    自旋锁_获取(桶.锁)

    // 2. 检查当前值是否等于expected (原子读取用户空间)
    定义 当前值 = 内存读32(uaddr)
    如果 (当前值 != expected) {
        // 值已变化, 不需要等待
        自旋锁_释放(桶.锁)
        返回 错误_重试   // -EAGAIN
    }

    // 3. 入队等待
    定义 q = Nova快速锁_q {}
    q.进程 = 获取当前进程()
    q.键 = uaddr
    q.bitset = bitset
    q.超时 = timeout
    追加(桶.等待链, q)
    Nova快速锁_wait总数 = Nova快速锁_wait总数 + 1

    自旋锁_释放(桶.锁)

    // 4. 睡眠 (设置进程状态为INTERRUPTIBLE, 调用schedule)
    进程_设置状态(q.进程, 进程_等待)
    调度()

    // 5. 被唤醒后返回
    返回 成功
}

// Nova快速锁_WAKE: 唤醒最多nr个等待者

函数 Nova快速锁_wake(uaddr, nr_wake, bitset) {
    定义 桶索引 = Nova快速锁_哈希(uaddr)
    定义 桶 = Nova快速锁_哈希表[桶索引]

    自旋锁_获取(桶.锁)

    定义 可变 唤醒数 = 0
    定义 可变 i = 0
    当 (i < 计数(桶.等待链) && 唤醒数 < nr_wake) {
        定义 q = 桶.等待链[i]
        如果 (q.键 == uaddr && (q.bitset & bitset) != 0) {
            // 唤醒该进程
            唤醒进程(q.进程)
            链表_删除(桶.等待链, i)
            唤醒数 = 唤醒数 + 1
            Nova快速锁_wake总数 = Nova快速锁_wake总数 + 1
            // 不递增i, 因为列表缩短了
        } 否则 {
            i = i + 1
        }
    }

    自旋锁_释放(桶.锁)
    返回 唤醒数
}

// Nova快速锁_CMP_REQUEUE: 唤醒一些, 移动剩余到另一个Nova快速锁
// 用于: Nova线程_cond_broadcast的高效实现

函数 Nova快速锁_requeue(uaddr1, nr_wake, uaddr2, nr_requeue) {
    定义 桶1 = Nova快速锁_哈希表[Nova快速锁_哈希(uaddr1)]
    定义 桶2 = Nova快速锁_哈希表[Nova快速锁_哈希(uaddr2)]

    // 锁定两个桶(按地址顺序避免死锁)
    自旋锁_获取(桶1.锁)
    如果 (桶1 != 桶2) { 自旋锁_获取(桶2.锁) }

    定义 可变 唤醒数 = 0
    定义 可变 移动数 = 0
    定义 可变 i = 0

    当 (i < 计数(桶1.等待链)) {
        定义 q = 桶1.等待链[i]
        如果 (q.键 == uaddr1) {
            如果 (唤醒数 < nr_wake) {
                // 唤醒
                唤醒进程(q.进程)
                链表_删除(桶1.等待链, i)
                唤醒数 = 唤醒数 + 1
            } 否则 如果 (移动数 < nr_requeue) {
                // 移动到桶2
                q.键 = uaddr2
                链表_删除(桶1.等待链, i)
                追加(桶2.等待链, q)
                移动数 = 移动数 + 1
            } 否则 {
                i = i + 1
            }
        } 否则 {
            i = i + 1
        }
    }

    如果 (桶1 != 桶2) { 自旋锁_释放(桶2.锁) }
    自旋锁_释放(桶1.锁)
    返回 唤醒数 + 移动数
}

// 哈希函数

函数 Nova快速锁_哈希(uaddr) {
    // jhash风格: 地址右移页偏移, 乘黄金比例, 取模
    定义 键 = uaddr >> 2   // 4字节对齐
    返回 (键 * 2654435761) & (Nova快速锁_HASH_SIZE - 1)
}

// 统计

函数 Nova快速锁_统计() {
    定义 可变 总等待 = 0
    定义 可变 i = 0
    当 (i < Nova快速锁_HASH_SIZE) {
        总等待 = 总等待 + 计数(Nova快速锁_哈希表[i].等待链)
        i = i + 1
    }
    返回 [Nova快速锁_wait总数, Nova快速锁_wake总数, 总等待]
}

// 错误_重试 定义在 核心/公共/错误码.nova

// Nova快速锁操作名称 + 完整统计

函数 Nova快速锁_操作名(cmd) {
    如果 (cmd == Nova快速锁_WAIT) { 返回 "WAIT" }
    如果 (cmd == Nova快速锁_WAKE) { 返回 "WAKE" }
    如果 (cmd == Nova快速锁_REQUEUE) { 返回 "REQUEUE" }
    如果 (cmd == Nova快速锁_CMP_REQUEUE) { 返回 "CMP_REQUEUE" }
    如果 (cmd == Nova快速锁_WAIT_BITSET) { 返回 "WAIT_BITSET" }
    如果 (cmd == Nova快速锁_WAKE_BITSET) { 返回 "WAKE_BITSET" }
    返回 "UNKNOWN"
}

函数 Nova快速锁_完整统计() {
    返回 [Nova快速锁_wait总数, Nova快速锁_wake总数]
}

函数 原子_读取(地址) {
    汇编 { "mov rax, [rdi]" }
}

// merge source: 沙盒批次/批三/待厚/中枢/等待队列.nova
//   1. wait_queue_head: 等待队列头(自旋锁+链表)
//   2. wait_queue_entry: 等待项(进程+标志+唤醒函数)
//   3. 等待模式: 排他(WQ_FLAG_EXCLUSIVE)vs非排他
//   4. wait_事件宏: 循环检查条件→睡眠→被唤醒→重新检查
//   5. wake_up: 唤醒一个排他+所有非排他等待者(thundering herd避免)

定义 WQ_FLAG_EXCLUSIVE  = 0x01   // 排他唤醒(只唤醒一个)
定义 WQ_FLAG_WOKEN      = 0x02   // 已被唤醒
定义 WQ_FLAG_BOOKMARK   = 0x04   // 书签(遍历用)

结构 等待项 {
    进程,    // u64 等待的进程(task_struct)
    标志,    // u32 WQ_FLAG_*
    唤醒函数,    // u64 自定义唤醒回调(默认default_wake_function)
    链节点,    // u64 链表节点
}

结构 等待队列头 {
    锁,    // u64 自旋锁
    链表,    // u64 等待项链表
    等待数,    // u32 当前等待者数量
}

定义 可变 等待队列_总唤醒 = 0
定义 可变 等待队列_总等待 = 0

// 创建/初始化

函数 等待队列_创建() {
    定义 wq = 等待队列头 {}
    wq.锁 = 自旋锁_创建()
    wq.链表 = 链表_创建()
    wq.等待数 = 0
    返回 wq
}

函数 等待队列_为空(队列) {
    返回 队列.等待数 == 0
}

// 加入/移除等待者

函数 等待项_创建(进程, 排他) {
    定义 e = 等待项 {}
    e.进程 = 进程
    e.标志 = 0
    如果 (排他) { e.标志 = e.标志 | WQ_FLAG_EXCLUSIVE }
    e.唤醒函数 = 0
    e.链节点 = 0
    返回 e
}

函数 等待队列_加入(队列, 项) {
    自旋锁_获取(队列.锁)
    // 排他等待者加到队列尾部, 非排他加到头部
    如果 ((项.标志 & WQ_FLAG_EXCLUSIVE) != 0) {
        链表_尾插(队列.链表, 项)
    } 否则 {
        链表_头插(队列.链表, 项)
    }
    队列.等待数 = 队列.等待数 + 1
    等待队列_总等待 = 等待队列_总等待 + 1
    自旋锁_释放(队列.锁)
}

函数 等待队列_移除(队列, 项) {
    自旋锁_获取(队列.锁)
    定义 头 = 队列.链表
    定义 可变 当前 = 链表_首节点(头)
    当 (当前 != 空 && 当前 != 头) {
        如果 (链表_数据(当前) == 项) {
            链表_删除(当前)
            队列.等待数 = 队列.等待数 - 1
            自旋锁_释放(队列.锁)
            返回
        }
        当前 = 链表_后继(当前)
    }
    自旋锁_释放(队列.锁)
}

// 唤醒 
// 规则: 唤醒所有非排他等待者 + 最多nr_exclusive个排他等待者

函数 等待队列_唤醒(队列, nr_exclusive) {
    如果 (等待队列_为空(队列)) { 返回 }
    自旋锁_获取(队列.锁)

    定义 可变 排他已唤醒 = 0
    定义 头 = 队列.链表
    定义 可变 当前 = 链表_首节点(头)

    当 (当前 != 空 && 当前 != 头) {
        定义 下一个 = 链表_后继(当前)
        定义 项 = 链表_数据(当前)

        如果 (项 != 空) {
            定义 是排他 = (项.标志 & WQ_FLAG_EXCLUSIVE) != 0

            // 唤醒该等待者
            项.标志 = 项.标志 | WQ_FLAG_WOKEN
            如果 (项.进程 != 空) {
                唤醒进程(项.进程)
            }
            等待队列_总唤醒 = 等待队列_总唤醒 + 1

            // 从队列移除
            链表_删除(当前)
            队列.等待数 = 队列.等待数 - 1

            // 排他唤醒计数
            如果 (是排他) {
                排他已唤醒 = 排他已唤醒 + 1
                如果 (排他已唤醒 >= nr_exclusive) { 中断 }
            }
        }
        当前 = 下一个
    }

    自旋锁_释放(队列.锁)
}

函数 等待队列_唤醒一个(队列) {
    等待队列_唤醒(队列, 1)
}

函数 等待队列_唤醒全部(队列) {
    等待队列_唤醒(队列, 999999)
}

// wait_事件: 等待条件满足 
// 模式: 循环检查条件 → 不满足则睡眠 → 被唤醒后重新检查

函数 等待队列_等待(队列, 条件函数) {
    // 快速路径: 条件已满足
    如果 (条件函数()) { 返回 }

    // 创建等待项并加入队列
    定义 当前 = 获取当前进程()
    定义 项 = 等待项_创建(当前, 假)
    等待队列_加入(队列, 项)

    // 慢速路径: 循环等待
    当 (!条件函数()) {
        // 设置进程状态为TASK_INTERRUPTIBLE
        进程_设置状态(当前, 进程_等待)
        // 调用schedule()让出CPU
        调度()
        // 被唤醒后回到这里, 重新检查条件
    }

    // 条件满足, 从队列移除
    等待队列_移除(队列, 项)
    进程_设置状态(当前, 进程_运行)
}

函数 等待队列_等待_超时(队列, 条件函数, 超时_ms) {
    如果 (条件函数()) { 返回 真 }

    定义 当前 = 获取当前进程()
    定义 项 = 等待项_创建(当前, 假)
    等待队列_加入(队列, 项)

    定义 截止时间 = 读取毫秒() + 超时_ms
    定义 可变 条件满足 = 假

    当 (!条件函数()) {
        如果 (读取毫秒() >= 截止时间) { 中断 }
        进程_设置状态(当前, 进程_等待)
        调度()
    }
    条件满足 = 条件函数()

    等待队列_移除(队列, 项)
    进程_设置状态(当前, 进程_运行)
    返回 条件满足
}

// 查询

函数 等待队列_等待者数(队列) { 返回 队列.等待数 }
函数 等待队列_统计() { 返回 [等待队列_总唤醒, 等待队列_总等待] }

// 可中断等待 + 唤醒效率

函数 等待队列_等待_可中断(队列, 条件函数) {
    如果 (条件函数()) { 返回 成功 }
    定义 当前 = 获取当前进程()
    定义 项 = 等待项_创建(当前, 假)
    等待队列_加入(队列, 项)
    当 (!条件函数()) {
        如果 (进程_有待处理信号(当前)) {
            等待队列_移除(队列, 项)
            进程_设置状态(当前, 进程_运行)
            返回 错误_被中断
        }
        进程_设置状态(当前, 进程_等待)
        调度()
    }
    等待队列_移除(队列, 项)
    进程_设置状态(当前, 进程_运行)
    返回 成功
}

// 错误_被中断 定义在 核心/公共/错误码.nova

函数 等待队列_完整统计() {
    返回 [等待队列_总唤醒, 等待队列_总等待]
}

// merge source: 沙盒批次/批三/待厚/中枢/自旋锁.nova
//   1. Ticket Spinlock: 保证FIFO公平性(不饿死)
//   2. 关中断版: spin_lock_irqsave — 中断上下文必须用这个
//   3. 保存/恢复中断标志: 嵌套安全(不会意外开中断)
//   4. trylock: 非阻塞尝试, 返回是否成功
//   5. 调试: lockdep检测自旋锁嵌套死锁
//   6. per-CPU: 某些场景用per-CPU变量替代锁

// owner: 当前服务的票号
// next: 下一个发放的票号
// 获取: 原子取next++, 等待owner==我的票号
// 释放: owner++
结构 自旋锁结构 {
    owner,    // u32 当前服务号
    next,    // u32 下一个待发号
    持有CPU,    // i32 调试: 持有锁的CPU号(-1=无)
}

定义 可变 spinlock_获取次数 = 0
定义 可变 spinlock_竞争次数 = 0
定义 可变 spinlock_最长等待 = 0

// 创建

函数 自旋锁_创建() {
    定义 锁 = 自旋锁结构 {}
    锁.owner = 0
    锁.next = 0
    锁.持有CPU = -1
    返回 锁
}

// spin_lock: 获取自旋锁 
// Ticket算法: 原子取号→自旋等待→轮到我

函数 自旋锁_获取(锁) {
    // 原子获取ticket (next++)
    定义 我的票号 = 原子_取并加(锁.next, 1)
    spinlock_获取次数 = spinlock_获取次数 + 1

    // 等待owner轮到我
    如果 (锁.owner != 我的票号) {
        spinlock_竞争次数 = spinlock_竞争次数 + 1
        定义 可变 等待轮次 = 0
        当 (锁.owner != 我的票号) {
            cpu_松弛()   // pause指令: 减少流水线惩罚+省电
            等待轮次 = 等待轮次 + 1
        }
        如果 (等待轮次 > spinlock_最长等待) {
            spinlock_最长等待 = 等待轮次
        }
    }

    // 获取成功
    锁.持有CPU = 获取当前CPU()
}

// spin_trylock: 非阻塞尝试

函数 自旋锁_尝试获取(锁) {
    定义 当前owner = 锁.owner
    定义 当前next = 锁.next
    // 只有owner==next(无竞争)时才能获取
    如果 (当前owner == 当前next) {
        如果 (原子_比较交换_返回旧值(锁.next, 当前next, 当前next + 1)) {
            锁.持有CPU = 获取当前CPU()
            返回 真
        }
    }
    返回 假
}

// spin_unlock: 释放

函数 自旋锁_释放(锁) {
    锁.持有CPU = -1
    // owner++: 允许下一个ticket持有者进入
    原子_加(锁.owner, 1)
}

// spin_lock_irqsave / spin_unlock_irqrestore
// 关中断+获取锁 / 释放锁+恢复中断

函数 自旋锁_关中断获取(锁) {
    // 保存当前中断标志并关中断
    定义 旧标志 = 保存并关中断()
    自旋锁_获取(锁)
    返回 旧标志   // 返回旧标志供恢复使用
}

函数 自旋锁_开中断释放(锁, 旧标志) {
    自旋锁_释放(锁)
    恢复中断(旧标志)
}

函数 自旋锁_关中断获取_简单(锁) {
    关中断()
    自旋锁_获取(锁)
}

函数 自旋锁_开中断释放_简单(锁) {
    自旋锁_释放(锁)
    开中断()
}

// spin_lock_bh / spin_unlock_bh
// 关软中断+获取锁 (用于与软中断竞争的场景)

函数 自旋锁_关软中断获取(锁) {
    禁用软中断()
    自旋锁_获取(锁)
}

函数 自旋锁_开软中断释放(锁) {
    自旋锁_释放(锁)
    启用软中断()
}

// 查询

函数 自旋锁_已锁定(锁) {
    返回 锁.owner != 锁.next
}

函数 自旋锁_等待者数(锁) {
    返回 锁.next - 锁.owner
}

函数 自旋锁_持有CPU(锁) {
    返回 锁.持有CPU
}

// 中断标志操作 (x86-64 RFLAGS.IF)

函数 保存并关中断() {
    // pushfq; pop rax; cli → 返回旧RFLAGS
    定义 旧标志 = 读取RFLAGS()
    关中断()
    返回 旧标志
}

函数 恢复中断(旧标志) {
    // 只有旧标志中IF=1时才开中断
    如果 ((旧标志 & 0x200) != 0) {
        开中断()
    }
}

函数 读取RFLAGS() {
    定义 可变 flags = 0
    汇编 {
        "pushfq"
        "pop rax"
        "mov [rbp-8], rax"
    }
    返回 flags
}

// 辅助

函数 cpu_松弛() {
    暂停()   // x86 pause指令 (0xF3 0x90)
}

函数 自旋锁_统计() {
    返回 [spinlock_获取次数, spinlock_竞争次数, spinlock_最长等待]
}

// 读写自旋锁 

结构 读写自旋锁 {
    读者数,    // u32 当前读者数量
    写者,    // u8 是否有写者 (0=无, 1=有)
}

函数 读写锁_创建() {
    定义 锁 = 读写自旋锁 {}
    锁.读者数 = 0
    锁.写者 = 0
    返回 锁
}

函数 读写锁_读获取(锁) {
    当 (锁.写者 != 0) { cpu_松弛() }
    锁.读者数 = 锁.读者数 + 1
}

函数 读写锁_读释放(锁) {
    锁.读者数 = 锁.读者数 - 1
}

函数 读写锁_写获取(锁) {
    当 (锁.写者 != 0 || 锁.读者数 != 0) { cpu_松弛() }
    锁.写者 = 1
}

函数 读写锁_写释放(锁) {
    锁.写者 = 0
}

// 竞争率 + 完整统计

函数 自旋锁_竞争率() {
    如果 (spinlock_获取次数 == 0) { 返回 0 }
    返回 spinlock_竞争次数 * 100 / spinlock_获取次数
}

函数 自旋锁_完整统计() {
    返回 [spinlock_获取次数, spinlock_竞争次数, spinlock_最长等待, 自旋锁_竞争率()]
}

// 自旋锁辅助

函数 自旋锁_健康检查() {
    定义 可变 问题 = []
    如果 (自旋锁_竞争率() > 50) {
        追加(问题, "自旋锁竞争率过高: " + 整数转字符串(自旋锁_竞争率()) + "%")
    }
    如果 (spinlock_最长等待 > 10000) {
        追加(问题, "自旋锁最长等待过久")
    }
    如果 (计数(问题) == 0) { 返回 "自旋锁健康" }
    返回 问题
}

函数 自旋锁_重置统计() {
    spinlock_获取次数 = 0
    spinlock_竞争次数 = 0
    spinlock_最长等待 = 0
}

定义 SPINLOCK_MAX_SPIN = 10000000
定义 SPINLOCK_BACKOFF_MIN = 1
定义 SPINLOCK_BACKOFF_MAX = 128

函数 自旋锁_平均等待() {
    如果 (spinlock_竞争次数 == 0) { 返回 0 }
    返回 spinlock_最长等待 / spinlock_竞争次数
}

函数 自旋锁_无竞争率() {
    如果 (spinlock_获取次数 == 0) { 返回 0 }
    返回 (spinlock_获取次数 - spinlock_竞争次数) * 100 / spinlock_获取次数
}

函数 自旋锁_获取总数() {
    返回 spinlock_获取次数
}

// merge source: 沙盒批次/批三/待厚/中枢/读写锁.nova
// NovaOS 读写锁
// 功能: 读写自旋锁和读写信号量，支持多读单写、读者优先/公平策略

定义 RWLOCK_读者_偏移    = 0
定义 RWLOCK_写者_位      = 31
定义 RWLOCK_写者_标志    = 0x80000000
定义 RWLOCK_读者_掩码    = 0x7FFFFFFF

// 读写自旋锁(rwlock_t) - 中断上下文可用

结构 读写自旋锁 {
    计数,    // 原子变量 高位=写锁, 低31位=读者数
}

函数 读写自旋锁_创建() {
    返回 读写自旋锁 { 计数: 原子_创建(0) }
}

函数 读锁_获取(锁) {
    循环 {
        定义 当前 = 原子_读取(锁.计数)
        // 如果没有写者持有锁，增加读者计数
        如果 ((当前 & RWLOCK_写者_标志) == 0) {
            如果 (原子_比较交换(锁.计数, 当前, 当前 + 1)) {
                返回
            }
        }
        暂停()
    }
}

函数 读锁_尝试获取(锁) {
    定义 当前 = 原子_读取(锁.计数)
    如果 ((当前 & RWLOCK_写者_标志) == 0) {
        返回 原子_比较交换(锁.计数, 当前, 当前 + 1)
    }
    返回 假
}

函数 读锁_释放(锁) {
    原子_减(锁.计数, 1)
}

函数 写锁_获取(锁) {
    循环 {
        定义 当前 = 原子_读取(锁.计数)
        // 需要无写者且无读者
        如果 (当前 == 0) {
            如果 (原子_比较交换(锁.计数, 0, RWLOCK_写者_标志)) {
                返回
            }
        }
        暂停()
    }
}

函数 写锁_尝试获取(锁) {
    返回 原子_比较交换(锁.计数, 0, RWLOCK_写者_标志)
}

函数 写锁_释放(锁) {
    原子_设置(锁.计数, 0)
}

函数 读锁_关中断获取(锁) {
    定义 旧中断 = 保存并关中断()
    读锁_获取(锁)
    返回 旧中断
}

函数 读锁_开中断释放(锁, 旧中断) {
    读锁_释放(锁)
    恢复中断(旧中断)
}

函数 写锁_关中断获取(锁) {
    定义 旧中断 = 保存并关中断()
    写锁_获取(锁)
    返回 旧中断
}

函数 写锁_开中断释放(锁, 旧中断) {
    写锁_释放(锁)
    恢复中断(旧中断)
}

函数 读写锁_读者数(锁) {
    返回 原子_读取(锁.计数) & RWLOCK_读者_掩码
}

函数 读写锁_有写者(锁) {
    返回 (原子_读取(锁.计数) & RWLOCK_写者_标志) != 0
}

// 读写信号量(rw_semaphore) - 可睡眠版本

结构 读写信号量 {
    计数,    // 原子变量
    等待链表,    // 等待队列头
    持有者,    // 指针<进程>
    锁,    // 自旋锁
}

函数 读写信号量_创建() {
    返回 读写信号量 {
        计数: 原子_创建(0),
        等待链表: 等待队列_创建(),
        持有者: 空,
        锁: 自旋锁_创建()
    }
}

函数 读写信号量_读获取(sem) {
    // 快速路径
    定义 当前 = 原子_读取(sem.计数)
    如果 ((当前 & RWLOCK_写者_标志) == 0) {
        如果 (原子_比较交换(sem.计数, 当前, 当前 + 1)) {
            返回
        }
    }

    // 慢速路径: 加入等待队列
    自旋锁_获取(sem.锁)
    循环 {
        定义 值 = 原子_读取(sem.计数)
        如果 ((值 & RWLOCK_写者_标志) == 0) {
            原子_加(sem.计数, 1)
            自旋锁_释放(sem.锁)
            返回
        }
        // 睡眠等待
        定义 可变 等待项 = 等待项_创建(获取当前进程(), 假)  // 非互斥
        等待队列_加入(sem.等待链表, 等待项)
        自旋锁_释放(sem.锁)

        进程_设置状态(获取当前进程(), 进程状态_可中断睡眠)
        调度()

        自旋锁_获取(sem.锁)
    }
}

函数 读写信号量_读释放(sem) {
    定义 旧值 = 原子_减(sem.计数, 1)
    // 如果最后一个读者释放，唤醒等待的写者
    如果 ((旧值 - 1) == 0) {
        等待队列_唤醒一个(sem.等待链表)
    }
}

函数 读写信号量_写获取(sem) {
    // 快速路径
    如果 (原子_比较交换(sem.计数, 0, RWLOCK_写者_标志)) {
        sem.持有者 = 获取当前进程()
        返回
    }

    // 慢速路径
    自旋锁_获取(sem.锁)
    循环 {
        如果 (原子_比较交换(sem.计数, 0, RWLOCK_写者_标志)) {
            sem.持有者 = 获取当前进程()
            自旋锁_释放(sem.锁)
            返回
        }
        定义 可变 等待项 = 等待项_创建(获取当前进程(), 真)  // 互斥
        等待队列_加入(sem.等待链表, 等待项)
        自旋锁_释放(sem.锁)

        进程_设置状态(获取当前进程(), 进程状态_不可中断睡眠)
        调度()

        自旋锁_获取(sem.锁)
    }
}

函数 读写信号量_写释放(sem) {
    sem.持有者 = 空
    原子_设置(sem.计数, 0)
    // 唤醒等待者(优先唤醒写者或一批读者)
    等待队列_唤醒全部(sem.等待链表)
}

函数 读写信号量_降级写到读(sem) {
    // 写锁降级为读锁: 不释放，直接转换
    原子_设置(sem.计数, 1)  // 变为1个读者
    sem.持有者 = 空
    // 唤醒等待的读者
    等待队列_唤醒全部(sem.等待链表)
}

// 锁状态查询 + 统计

定义 可变 读写锁_读获取总数 = 0
定义 可变 读写锁_写获取总数 = 0

函数 读写信号量_是读锁定(sem) {
    定义 v = 原子_读取(sem.计数)
    返回 (v & RWLOCK_读者_掩码) > 0 && (v & RWLOCK_写者_标志) == 0
}

函数 读写信号量_是写锁定(sem) {
    返回 (原子_读取(sem.计数) & RWLOCK_写者_标志) != 0
}

函数 读写信号量_读者数(sem) {
    返回 原子_读取(sem.计数) & RWLOCK_读者_掩码
}

函数 读写锁_统计() {
    返回 [读写锁_读获取总数, 读写锁_写获取总数]
}

// 锁状态名称 + 读写比

函数 读写锁_状态名(锁) {
    如果 (读写锁_有写者(锁)) { 返回 "write_locked" }
    如果 (读写锁_读者数(锁) > 0) { 返回 "read_locked" }
    返回 "unlocked"
}

函数 读写锁_读写比() {
    定义 总 = 读写锁_读获取总数 + 读写锁_写获取总数
    如果 (总 == 0) { 返回 0 }
    返回 读写锁_读获取总数 * 100 / 总
}


函数 读写锁_完整统计() {
    返回 [读写锁_读获取总数, 读写锁_写获取总数, 读写锁_读写比()]
}

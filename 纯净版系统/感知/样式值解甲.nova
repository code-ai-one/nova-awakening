// §2 CSS值解析器 — 解析单个CSS值
// (对应 css_parsing_utils.cc 中的 Consume系列函数)


函数 CSS解析_值(文本, 文本长度, 位置) {
    定义 可变 pos = 位置

    // 跳过空白
    当 (pos < 文本长度 && CSS_是空白(内存_读8(文本 + pos))) { pos = pos + 1 }
    如果 (pos >= 文本长度) { 返回 0 }

    定义 c = 内存_读8(文本 + pos)

    如果 ((c >= 0x30 && c <= 0x39) || c == 0x2D || c == 0x2E || c == 0x2B) {
        返回 CSS解析_数字或长度(文本, 文本长度, pos)
    }

    如果 (c == 0x23) {
        返回 CSS解析_十六进制颜色(文本, 文本长度, pos)
    }

    如果 (c == 0x22 || c == 0x27) {
        返回 CSS解析_字符串(文本, 文本长度, pos, c)
    }

    如果 (CSS_是标识符开头(c)) {
        返回 CSS解析_标识符或函数(文本, 文本长度, pos)
    }

    返回 0
}

// §3 数字/长度/百分比/角度/时间解析

函数 CSS解析_数字或长度(文本, 长度, pos) {
    定义 可变 p = pos
    定义 可变 负 = 假
    定义 可变 整数部分 = 0
    定义 可变 小数部分 = 0
    定义 可变 小数位数 = 0
    定义 可变 有数字 = 假

    // 符号
    如果 (内存_读8(文本 + p) == 0x2D) { 负 = 真; p = p + 1 }
    否则 如果 (内存_读8(文本 + p) == 0x2B) { p = p + 1 }

    // 整数部分
    当 (p < 长度 && 内存_读8(文本 + p) >= 0x30 && 内存_读8(文本 + p) <= 0x39) {
        整数部分 = 整数部分 * 10 + (内存_读8(文本 + p) - 0x30)
        有数字 = 真
        p = p + 1
    }

    // 小数部分
    如果 (p < 长度 && 内存_读8(文本 + p) == 0x2E) {
        p = p + 1
        当 (p < 长度 && 内存_读8(文本 + p) >= 0x30 && 内存_读8(文本 + p) <= 0x39) {
            小数部分 = 小数部分 * 10 + (内存_读8(文本 + p) - 0x30)
            小数位数 = 小数位数 + 1
            有数字 = 真
            p = p + 1
        }
    }

    如果 (!有数字) { 返回 0 }

    // 计算值×100(定点数)
    定义 可变 值 = 整数部分 * 100
    如果 (小数位数 == 1) { 值 = 值 + 小数部分 * 10 }
    否则 如果 (小数位数 == 2) { 值 = 值 + 小数部分 }
    否则 如果 (小数位数 >= 3) { 值 = 值 + 小数部分 / (小数位数 - 2) }
    如果 (负) { 值 = 0 - 值 }

    // 解析单位
    定义 单位起始 = p
    当 (p < 长度 && CSS_是标识符续(内存_读8(文本 + p))) { p = p + 1 }
    定义 单位长度 = p - 单位起始

    定义 v = CSSParsedValue_创建(CSS值_数字)
    v.整数值 = 值

    如果 (单位长度 == 0) {
        // 纯数字
        v.类型 = CSS值_数字
        v.单位 = 单位_无
    }
    否则 如果 (单位长度 == 1 && 内存_读8(文本 + 单位起始) == 0x25) {
        // %
        v.类型 = CSS值_百分比
        v.单位 = 单位_百分比
    }
    否则 如果 (单位长度 == 2) {
        定义 u1 = 内存_读8(文本 + 单位起始) | 0x20
        定义 u2 = 内存_读8(文本 + 单位起始 + 1) | 0x20
        如果 (u1 == 0x70 && u2 == 0x78) { v.类型 = CSS值_长度; v.单位 = 单位_px }       // px
        否则 如果 (u1 == 0x65 && u2 == 0x6D) { v.类型 = CSS值_长度; v.单位 = 单位_em }  // em
        否则 如果 (u1 == 0x76 && u2 == 0x77) { v.类型 = CSS值_长度; v.单位 = 单位_vw }  // vw
        否则 如果 (u1 == 0x76 && u2 == 0x68) { v.类型 = CSS值_长度; v.单位 = 单位_vh }  // vh
        否则 如果 (u1 == 0x70 && u2 == 0x74) { v.类型 = CSS值_长度; v.单位 = 单位_pt }  // pt
        否则 如果 (u1 == 0x70 && u2 == 0x63) { v.类型 = CSS值_长度; v.单位 = 单位_pc }  // pc
        否则 如果 (u1 == 0x69 && u2 == 0x6E) { v.类型 = CSS值_长度; v.单位 = 单位_in }  // in
        否则 如果 (u1 == 0x63 && u2 == 0x6D) { v.类型 = CSS值_长度; v.单位 = 单位_cm }  // cm
        否则 如果 (u1 == 0x6D && u2 == 0x6D) { v.类型 = CSS值_长度; v.单位 = 单位_mm }  // mm
        否则 如果 (u1 == 0x63 && u2 == 0x68) { v.类型 = CSS值_长度; v.单位 = 单位_ch }  // ch
        否则 如果 (u1 == 0x65 && u2 == 0x78) { v.类型 = CSS值_长度; v.单位 = 单位_ex }  // ex
        否则 如果 (u1 == 0x6D && u2 == 0x73) { v.类型 = CSS值_时间; v.单位 = 20 }       // ms
    }
    否则 如果 (单位长度 == 3) {
        定义 u = 字符串_复制_N(文本 + 单位起始, 3)
        如果 (字符串_等于N(u, 3, "rem")) { v.类型 = CSS值_长度; v.单位 = 单位_rem }
        否则 如果 (字符串_等于N(u, 3, "deg")) { v.类型 = CSS值_角度; v.单位 = 30 }
        否则 如果 (字符串_等于N(u, 3, "rad")) { v.类型 = CSS值_角度; v.单位 = 31 }
        否则 如果 (字符串_等于N(u, 3, "dpi")) { v.类型 = CSS值_分辨率; v.单位 = 40 }
    }
    否则 如果 (单位长度 == 4) {
        定义 u = 字符串_复制_N(文本 + 单位起始, 4)
        如果 (字符串_等于N(u, 4, "vmin")) { v.类型 = CSS值_长度; v.单位 = 单位_vmin }
        否则 如果 (字符串_等于N(u, 4, "vmax")) { v.类型 = CSS值_长度; v.单位 = 单位_vmax }
        否则 如果 (字符串_等于N(u, 4, "turn")) { v.类型 = CSS值_角度; v.单位 = 32 }
        否则 如果 (字符串_等于N(u, 4, "grad")) { v.类型 = CSS值_角度; v.单位 = 33 }
        否则 如果 (字符串_等于N(u, 4, "dppx")) { v.类型 = CSS值_分辨率; v.单位 = 41 }
        否则 如果 (字符串_等于N(u, 4, "dpcm")) { v.类型 = CSS值_分辨率; v.单位 = 42 }
    }
    否则 如果 (单位长度 == 1 && (内存_读8(文本 + 单位起始) | 0x20) == 0x73) {
        v.类型 = CSS值_时间; v.单位 = 21    // s
    }

    返回 v
}

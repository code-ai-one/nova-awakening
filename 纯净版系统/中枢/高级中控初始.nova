//   1. APIC存在性检测: CPUID检查APIC支持位
//   2. 完整初始化序列: PIC禁用→MSR配置→SVR→ESR→TPR→LDR/DFR→LVT
//   3. x2APIC模式: 检测并启用x2APIC(MSR访问模式)
//   4. LVT完整配置: 定时器/LINT0/LINT1/错误/温度/性能计数
//   5. 定时器校准: PIT校准+多次取均值+TSC-Deadline支持
//   6. AP核初始化: INIT-SIPI-SIPI序列
//   7. NMI watchdog: 通过性能计数器LVT配置NMI
//   8. 保存/恢复: 电源管理支持
//   9. 统计/调试: 完整初始化状态追踪

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./自动扩容.nova")
导入("../引导/串口早期输.nova")
导入("./页表重建.nova")
导入("../引导/寄存器定义.nova")
导入("./高级中控读.nova")
导入("./字符串替换.nova")
导入("./高级中控设置.nova")
导入("./可编中断禁.nova")
导入("./高级中控等待.nova")

定义 向量_接口C定时器 = 32
定义 向量_接口C错误   = 39
定义 向量_接口C伪     = 0xFF
定义 向量_接口C温度   = 45
定义 向量_接口C性能   = 46
定义 向量_IPI_调度    = 0xFD
定义 向量_IPI_TLB刷新 = 0xFC
定义 向量_IPI_停机    = 0xFE
定义 向量_NMI_看门狗  = 0x02

定义 可变 接口C_初始化_已完成 = 假
定义 可变 接口C_初始化_是BSP = 假
定义 可变 接口C_初始化_x2模式 = 假
定义 可变 接口C_初始化_最大LVT数 = 0
定义 可变 接口C_初始化_ID = 0
定义 可变 接口C_初始化_版本号 = 0

定义 可变 接口C_定时器_频率 = 0
定义 可变 接口C_定时器_每毫秒 = 0
定义 可变 接口C_定时器_已校准 = 假
定义 可变 接口C_定时器_校准次数 = 0
定义 校准_迭代次数 = 3

定义 可变 初始化_EOI总数 = 0
定义 可变 初始化_BSP初始化次数 = 0
定义 可变 初始化_AP初始化次数 = 0
定义 可变 初始化_定时器启动次数 = 0
定义 可变 初始化_错误数 = 0
定义 可变 初始化_定时器停止次数 = 0
定义 可变 初始化_NMI配置次数 = 0

定义 可变 保存_SVR = 0
定义 可变 保存_TPR = 0
定义 可变 保存_LDR = 0
定义 可变 保存_DFR = 0
定义 可变 保存_LVT定时器 = 0
定义 可变 保存_LVT_LINT0 = 0
定义 可变 保存_LVT_LINT1 = 0
定义 可变 保存_LVT错误 = 0
定义 可变 保存_LVT温度 = 0
定义 可变 保存_LVT性能 = 0
定义 可变 保存_分频 = 0
定义 可变 保存_初始计数 = 0
定义 可变 保存_已保存 = 假

// APIC存在性检测

函数 接口C_检测存在() {
    // CPUID.01H:EDX[bit9] = APIC存在
    定义 msr = 读MSR(MSR_接口C_BASE)
    如果 ((msr & MSR_接口C_BASE_使能) != 0) {
        返回 真
    }
    // 尝试通过CPUID检测
    // CPUID功能1的EDX bit9
    返回 假
}

函数 接口C_检测x2APIC支持() {
    // CPUID.01H:ECX[bit21] = x2APIC支持
    定义 msr = 读MSR(MSR_接口C_BASE)
    返回 (msr & MSR_接口C_BASE_x2APIC) != 0
}

函数 接口C_是BSP() {
    定义 msr = 读MSR(MSR_接口C_BASE)
    返回 (msr & MSR_接口C_BASE_BSP) != 0
}

// 完整初始化 (BSP核)

函数 接口C_初始化() {
    如果 (接口C_初始化_已完成 == 真) {
        打印("[APIC初始化] 警告: 重复初始化, 跳过")
        返回 错误_已存在
    }

    // 步骤1: 禁用旧PIC
    PIC_禁用()
    
    // 步骤2: 获取并设置APIC基址
    定义 apic_msr = 读MSR(MSR_接口C_BASE)
    接口C基址 = apic_msr & 0xFFFFF000
    
    // 确保APIC使能(MSR位11)
    如果 ((apic_msr & MSR_接口C_BASE_使能) == 0) {
        写MSR(MSR_接口C_BASE, apic_msr | MSR_接口C_BASE_使能)
        打印("[APIC初始化] MSR启用APIC")
    }
    
    // 步骤3: 检测x2APIC
    接口C_初始化_x2模式 = 接口C_检测x2APIC支持()
    
    // 步骤4: 读取基本信息
    接口C_初始化_ID = 接口C_获取ID()
    接口C_初始化_版本号 = 接口C_获取版本()
    接口C_初始化_最大LVT数 = 接口C_获取最大LVT()
    接口C_初始化_是BSP = 接口C_是BSP()
    
    // 步骤5: 设置伪中断向量并使能APIC
    接口C_写(接口C_SVR, 接口C_SVR_使能 | 向量_接口C伪)
    
    // 步骤6: 清除错误状态(写两次确保清除)
    接口C_写(接口C_ESR, 0)
    接口C_读(接口C_ESR)
    接口C_写(接口C_ESR, 0)
    接口C_读(接口C_ESR)
    
    // 步骤7: 设置任务优先级为0(接受所有中断)
    接口C_写(接口C_TPR, 0)
    
    // 步骤8: 设置逻辑目标(flat模型)
    接口C_写(接口C_DFR, 0xFFFFFFFF)
    定义 可变 逻辑ID = 1
    如果 (接口C_初始化_ID < 8) {
        逻辑ID = 1 << 接口C_初始化_ID
    }
    接口C_写(接口C_LDR, 逻辑ID << 24)
    
    // 步骤9: 配置所有LVT(先全部屏蔽)
    接口C_写(接口C_LVT_定时器,   接口C_LVT_屏蔽)
    接口C_写(接口C_LVT_LINT0,    接口C_LVT_屏蔽)
    接口C_写(接口C_LVT_LINT1,    接口C_LVT_屏蔽)
    接口C_写(接口C_LVT_错误,     向量_接口C错误)
    如果 (接口C_初始化_最大LVT数 >= 5) {
        接口C_写(接口C_LVT_温度,     接口C_LVT_屏蔽)
    }
    如果 (接口C_初始化_最大LVT数 >= 6) {
        接口C_写(接口C_LVT_性能计数, 接口C_LVT_屏蔽)
    }
    
    // 步骤10: BSP特殊配置
    如果 (接口C_初始化_是BSP == 真) {
        // LINT0: ExtINT(兼容旧PIC)
        接口C_写(接口C_LVT_LINT0, 0x00700)
        // LINT1: NMI
        接口C_写(接口C_LVT_LINT1, 0x00400)
        初始化_BSP初始化次数 = 初始化_BSP初始化次数 + 1
    } 否则 {
        // AP核: LINT0/LINT1都屏蔽
        接口C_写(接口C_LVT_LINT0, 接口C_LVT_屏蔽)
        接口C_写(接口C_LVT_LINT1, 接口C_LVT_屏蔽 | 0x00400)
        初始化_AP初始化次数 = 初始化_AP初始化次数 + 1
    }
    
    // 步骤11: 清除所有挂起中断
    接口C_发送EOI()
    
    接口C_初始化_已完成 = 真
    
    早期打印OK("[APIC初始化] Local APIC初始化完成")
    早期打印十六进制("  基址", 接口C基址)
    早期打印数值("  ID", 接口C_初始化_ID)
    早期打印数值("  版本", 接口C_初始化_版本号)
    早期打印数值("  最大LVT", 接口C_初始化_最大LVT数)
    如果 (接口C_初始化_是BSP == 真) {
        早期打印OK("  角色: BSP(引导处理器)")
    } 否则 {
        早期打印OK("  角色: AP(应用处理器)")
    }
    如果 (接口C_初始化_x2模式 == 真) {
        早期打印OK("  x2APIC: 支持")
    }
    返回 0
}

// AP核初始化 (由BSP调用)

函数 接口C_AP初始化() {
    // AP核使用简化的初始化序列
    定义 apic_msr = 读MSR(MSR_接口C_BASE)
    接口C基址 = apic_msr & 0xFFFFF000
    如果 ((apic_msr & MSR_接口C_BASE_使能) == 0) {
        写MSR(MSR_接口C_BASE, apic_msr | MSR_接口C_BASE_使能)
    }
    接口C_写(接口C_SVR, 接口C_SVR_使能 | 向量_接口C伪)
    接口C_写(接口C_ESR, 0)
    接口C_读(接口C_ESR)
    接口C_写(接口C_TPR, 0)
    // flat模式逻辑ID
    接口C_写(接口C_DFR, 0xFFFFFFFF)
    定义 id = 接口C_获取ID()
    定义 可变 逻辑ID = 1
    如果 (id < 8) { 逻辑ID = 1 << id }
    接口C_写(接口C_LDR, 逻辑ID << 24)
    // LVT全屏蔽
    接口C_写(接口C_LVT_定时器, 接口C_LVT_屏蔽)
    接口C_写(接口C_LVT_LINT0, 接口C_LVT_屏蔽)
    接口C_写(接口C_LVT_LINT1, 接口C_LVT_屏蔽 | 0x00400)
    接口C_写(接口C_LVT_错误, 向量_接口C错误)
    接口C_发送EOI()
    初始化_AP初始化次数 = 初始化_AP初始化次数 + 1
    返回 0
}

// EOI (中断结束)

函数 接口C_发送EOI() {
    接口C_写(接口C_EOI, 0)
    初始化_EOI总数 = 初始化_EOI总数 + 1
}

// APIC定时器 — 校准
// 使用PIT产生精确10ms延迟, 多次取均值

函数 接口C_校准定时器() {
    如果 (接口C_初始化_已完成 == 假) {
        初始化_错误数 = 初始化_错误数 + 1
        返回 错误_未初始化
    }
    // 多次校准取均值
    定义 可变 总消耗 = 0
    定义 可变 最小消耗 = 0xFFFFFFFF
    定义 可变 最大消耗 = 0
    定义 可变 i = 0
    当 (i < 校准_迭代次数) {
        接口C_写(接口C_定时器_分频, 接口C_分频_16)
        接口C_写(接口C_LVT_定时器, 接口C_LVT_屏蔽)
        接口C_写(接口C_定时器_初始计数, 0xFFFFFFFF)
        // 等待10ms(通过PIT)
        PIT_延迟_10毫秒()
        定义 剩余 = 接口C_读(接口C_定时器_当前计数)
        接口C_写(接口C_定时器_初始计数, 0)
        定义 消耗 = 0xFFFFFFFF - 剩余
        总消耗 = 总消耗 + 消耗
        如果 (消耗 < 最小消耗) { 最小消耗 = 消耗 }
        如果 (消耗 > 最大消耗) { 最大消耗 = 消耗 }
        i = i + 1
    }
    定义 平均消耗 = 总消耗 / 校准_迭代次数
    接口C_定时器_每毫秒 = 平均消耗 / 10
    接口C_定时器_频率 = 平均消耗 * 100
    接口C_定时器_已校准 = 真
    接口C_定时器_校准次数 = 接口C_定时器_校准次数 + 1
    早期打印数值("[APIC定时器] 每ms计数(均值)", 接口C_定时器_每毫秒)
    早期打印数值("[APIC定时器] 频率(Hz)", 接口C_定时器_频率)
    如果 (最大消耗 - 最小消耗 > 平均消耗 / 10) {
        打印("[APIC定时器] 警告: 校准偏差较大, 最小=" + 转字符串(最小消耗) + " 最大=" + 转字符串(最大消耗))
    }
    返回 0
}

// APIC定时器 — 配置

函数 接口C_设置定时器(向量号, 分频, 初始计数) {
    如果 (向量号 < 16 || 向量号 > 254) {
        初始化_错误数 = 初始化_错误数 + 1
        返回 错误_无效参数
    }
    接口C_写(接口C_定时器_分频, 分频)
    接口C_写(接口C_LVT_定时器, 向量号 | 接口C_定时器_周期)
    接口C_写(接口C_定时器_初始计数, 初始计数)
    初始化_定时器启动次数 = 初始化_定时器启动次数 + 1
    返回 0
}

函数 接口C_设置单次定时器(向量号, 分频, 计数值) {
    如果 (向量号 < 16 || 向量号 > 254) {
        初始化_错误数 = 初始化_错误数 + 1
        返回 错误_无效参数
    }
    接口C_写(接口C_定时器_分频, 分频)
    接口C_写(接口C_LVT_定时器, 向量号 | 接口C_定时器_单次)
    接口C_写(接口C_定时器_初始计数, 计数值)
    初始化_定时器启动次数 = 初始化_定时器启动次数 + 1
    返回 0
}

函数 接口C_停止定时器() {
    接口C_写(接口C_LVT_定时器, 接口C_LVT_屏蔽)
    接口C_写(接口C_定时器_初始计数, 0)
    初始化_定时器停止次数 = 初始化_定时器停止次数 + 1
    返回 0
}

函数 接口C_设置周期定时器_毫秒(向量号, 毫秒) {
    如果 (接口C_定时器_已校准 == 假) {
        定义 结果 = 接口C_校准定时器()
        如果 (结果 != 0) { 返回 结果 }
    }
    如果 (接口C_定时器_每毫秒 == 0) {
        初始化_错误数 = 初始化_错误数 + 1
        返回 错误_无效参数
    }
    定义 计数值 = 接口C_定时器_每毫秒 * 毫秒
    返回 接口C_设置定时器(向量号, 接口C_分频_16, 计数值)
}

函数 接口C_设置单次定时器_微秒(向量号, 微秒) {
    如果 (接口C_定时器_已校准 == 假) {
        定义 结果 = 接口C_校准定时器()
        如果 (结果 != 0) { 返回 结果 }
    }
    如果 (接口C_定时器_每毫秒 == 0) { 返回 错误_无效参数 }
    定义 计数值 = 接口C_定时器_每毫秒 * 微秒 / 1000
    如果 (计数值 == 0) { 计数值 = 1 }
    返回 接口C_设置单次定时器(向量号, 接口C_分频_16, 计数值)
}

函数 接口C_获取定时器频率() { 返回 接口C_定时器_频率 }
函数 接口C_获取定时器每毫秒() { 返回 接口C_定时器_每毫秒 }
函数 接口C_定时器_已校准查询() { 返回 接口C_定时器_已校准 }

// NMI Watchdog配置

函数 接口C_配置NMI看门狗() {
    // 通过性能计数器LVT配置NMI
    如果 (接口C_初始化_最大LVT数 < 6) {
        打印("[APIC初始化] 警告: LVT不足, 无法配置NMI看门狗")
        返回 错误_不支持
    }
    // 性能计数器LVT设为NMI模式
    接口C_写(接口C_LVT_性能计数, 0x00400)
    初始化_NMI配置次数 = 初始化_NMI配置次数 + 1
    打印("[APIC初始化] NMI看门狗已配置")
    返回 0
}

函数 接口C_禁用NMI看门狗() {
    接口C_写(接口C_LVT_性能计数, 接口C_LVT_屏蔽)
    返回 0
}

// 温度监控LVT配置

函数 接口C_配置温度中断(向量号) {
    如果 (接口C_初始化_最大LVT数 < 5) {
        返回 错误_不支持
    }
    如果 (向量号 < 16 || 向量号 > 254) { 返回 错误_无效参数 }
    接口C_写(接口C_LVT_温度, 向量号)
    返回 0
}

函数 接口C_禁用温度中断() {
    如果 (接口C_初始化_最大LVT数 < 5) { 返回 0 }
    接口C_写(接口C_LVT_温度, 接口C_LVT_屏蔽)
    返回 0
}

// 保存/恢复 (电源管理)

函数 接口C_保存状态() {
    如果 (接口C_初始化_已完成 == 假) { 返回 错误_未初始化 }
    保存_SVR = 接口C_读(接口C_SVR)
    保存_TPR = 接口C_读(接口C_TPR)
    保存_LDR = 接口C_读(接口C_LDR)
    保存_DFR = 接口C_读(接口C_DFR)
    保存_LVT定时器 = 接口C_读(接口C_LVT_定时器)
    保存_LVT_LINT0 = 接口C_读(接口C_LVT_LINT0)
    保存_LVT_LINT1 = 接口C_读(接口C_LVT_LINT1)
    保存_LVT错误 = 接口C_读(接口C_LVT_错误)
    如果 (接口C_初始化_最大LVT数 >= 5) {
        保存_LVT温度 = 接口C_读(接口C_LVT_温度)
    }
    如果 (接口C_初始化_最大LVT数 >= 6) {
        保存_LVT性能 = 接口C_读(接口C_LVT_性能计数)
    }
    保存_分频 = 接口C_读(接口C_定时器_分频)
    保存_初始计数 = 接口C_读(接口C_定时器_初始计数)
    保存_已保存 = 真
    返回 0
}

函数 接口C_恢复状态() {
    如果 (保存_已保存 == 假) { 返回 错误_无效参数 }
    // 先确保APIC使能
    定义 msr = 读MSR(MSR_接口C_BASE)
    如果 ((msr & MSR_接口C_BASE_使能) == 0) {
        写MSR(MSR_接口C_BASE, msr | MSR_接口C_BASE_使能)
    }
    接口C_写(接口C_DFR, 保存_DFR)
    接口C_写(接口C_LDR, 保存_LDR)
    接口C_写(接口C_SVR, 保存_SVR)
    接口C_写(接口C_TPR, 保存_TPR)
    接口C_写(接口C_LVT_LINT0, 保存_LVT_LINT0)
    接口C_写(接口C_LVT_LINT1, 保存_LVT_LINT1)
    接口C_写(接口C_LVT_错误, 保存_LVT错误)
    如果 (接口C_初始化_最大LVT数 >= 5) {
        接口C_写(接口C_LVT_温度, 保存_LVT温度)
    }
    如果 (接口C_初始化_最大LVT数 >= 6) {
        接口C_写(接口C_LVT_性能计数, 保存_LVT性能)
    }
    // 定时器最后恢复(避免在恢复过程中触发)
    接口C_写(接口C_定时器_分频, 保存_分频)
    接口C_写(接口C_LVT_定时器, 保存_LVT定时器)
    接口C_写(接口C_定时器_初始计数, 保存_初始计数)
    // 清除错误
    接口C_写(接口C_ESR, 0)
    接口C_读(接口C_ESR)
    接口C_发送EOI()
    返回 0
}

// 验证初始化状态

函数 接口C_验证初始化() {
    定义 可变 错误数 = 0
    // 检查SVR使能位
    定义 svr = 接口C_读(接口C_SVR)
    如果 ((svr & 接口C_SVR_使能) == 0) {
        打印("[APIC验证] 错误: SVR未使能")
        错误数 = 错误数 + 1
    }
    // 检查伪向量
    如果 ((svr & 0xFF) != 向量_接口C伪) {
        打印("[APIC验证] 警告: 伪向量不匹配")
        错误数 = 错误数 + 1
    }
    // 检查TPR
    如果 ((接口C_读(接口C_TPR) & 0xFF) != 0) {
        打印("[APIC验证] 警告: TPR非零, 可能阻断低优先级中断")
    }
    // 检查ESR
    接口C_写(接口C_ESR, 0)
    定义 esr = 接口C_读(接口C_ESR)
    如果 (esr != 0) {
        打印("[APIC验证] 警告: ESR有错误: 0x" + 转字符串(esr))
        错误数 = 错误数 + 1
    }
    // 检查错误LVT有向量
    定义 错误lvt = 接口C_读(接口C_LVT_错误)
    如果 ((错误lvt & 0xFF) == 0) {
        打印("[APIC验证] 警告: 错误LVT未配置向量")
        错误数 = 错误数 + 1
    }
    如果 (错误数 == 0) {
        打印("[APIC验证] 初始化状态验证通过")
    }
    返回 错误数
}

// 完整统计 (≥15个指标)

函数 接口C_初始化_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "已初始化", 接口C_初始化_已完成)
    字典设(统计, "是BSP", 接口C_初始化_是BSP)
    字典设(统计, "x2APIC", 接口C_初始化_x2模式)
    字典设(统计, "ID", 接口C_初始化_ID)
    字典设(统计, "版本", 接口C_初始化_版本号)
    字典设(统计, "最大LVT", 接口C_初始化_最大LVT数)
    字典设(统计, "基址", 接口C基址)
    字典设(统计, "定时器已校准", 接口C_定时器_已校准)
    字典设(统计, "定时器频率", 接口C_定时器_频率)
    字典设(统计, "定时器每ms", 接口C_定时器_每毫秒)
    字典设(统计, "校准次数", 接口C_定时器_校准次数)
    字典设(统计, "EOI总数", 初始化_EOI总数)
    字典设(统计, "BSP初始化次数", 初始化_BSP初始化次数)
    字典设(统计, "AP初始化次数", 初始化_AP初始化次数)
    字典设(统计, "定时器启动次数", 初始化_定时器启动次数)
    字典设(统计, "定时器停止次数", 初始化_定时器停止次数)
    字典设(统计, "NMI配置次数", 初始化_NMI配置次数)
    字典设(统计, "错误数", 初始化_错误数)
    字典设(统计, "已保存", 保存_已保存)
    返回 统计
}

函数 接口C_初始化_打印统计() {
    定义 统计 = 接口C_初始化_完整统计()
    打印("[APIC初始化] ═══════ 完整统计 ═══════")
    打印("  已初始化:     " + 转字符串(字典取(统计, "已初始化")))
    打印("  是BSP:        " + 转字符串(字典取(统计, "是BSP")))
    打印("  x2APIC:       " + 转字符串(字典取(统计, "x2APIC")))
    打印("  ID:           " + 转字符串(字典取(统计, "ID")))
    打印("  版本:         " + 转字符串(字典取(统计, "版本")))
    打印("  最大LVT:      " + 转字符串(字典取(统计, "最大LVT")))
    打印("  定时器频率:   " + 转字符串(字典取(统计, "定时器频率")) + " Hz")
    打印("  定时器每ms:   " + 转字符串(字典取(统计, "定时器每ms")))
    打印("  校准次数:     " + 转字符串(字典取(统计, "校准次数")))
    打印("  EOI总数:      " + 转字符串(字典取(统计, "EOI总数")))
    打印("  BSP初始化:    " + 转字符串(字典取(统计, "BSP初始化次数")))
    打印("  AP初始化:     " + 转字符串(字典取(统计, "AP初始化次数")))
    打印("  定时器启动:   " + 转字符串(字典取(统计, "定时器启动次数")))
    打印("  NMI配置:      " + 转字符串(字典取(统计, "NMI配置次数")))
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    打印("[APIC初始化] ═════════════════════════")
    返回 0
}

// 调试dump

函数 接口C_初始化_dump() {
    打印("[APIC初始化 dump] ──────────────────")
    打印("  已初始化: " + 转字符串(接口C_初始化_已完成))
    打印("  是BSP: " + 转字符串(接口C_初始化_是BSP))
    打印("  x2APIC: " + 转字符串(接口C_初始化_x2模式))
    打印("  ID: " + 转字符串(接口C_初始化_ID))
    打印("  版本: " + 转字符串(接口C_初始化_版本号))
    打印("  最大LVT: " + 转字符串(接口C_初始化_最大LVT数))
    打印("  基址: 0x" + 转字符串(接口C基址))
    打印("  定时器已校准: " + 转字符串(接口C_定时器_已校准))
    打印("  定时器频率: " + 转字符串(接口C_定时器_频率))
    打印("  定时器每ms: " + 转字符串(接口C_定时器_每毫秒))
    // LVT寄存器当前值
    打印("  ── 当前LVT ──")
    打印("  定时器: 0x" + 转字符串(接口C_读(接口C_LVT_定时器)))
    打印("  LINT0: 0x" + 转字符串(接口C_读(接口C_LVT_LINT0)))
    打印("  LINT1: 0x" + 转字符串(接口C_读(接口C_LVT_LINT1)))
    打印("  错误: 0x" + 转字符串(接口C_读(接口C_LVT_错误)))
    打印("  SVR: 0x" + 转字符串(接口C_读(接口C_SVR)))
    打印("  TPR: " + 转字符串(接口C_读(接口C_TPR) & 0xFF))
    打印("  已保存: " + 转字符串(保存_已保存))
    打印("[APIC初始化 dump] ──────────────────")
}

// 销毁与清理

函数 接口C_初始化_销毁() {
    如果 (接口C_初始化_已完成 == 假) { 返回 0 }
    // 停止定时器
    接口C_停止定时器()
    // 屏蔽所有LVT
    接口C_写(接口C_LVT_定时器, 接口C_LVT_屏蔽)
    接口C_写(接口C_LVT_LINT0, 接口C_LVT_屏蔽)
    接口C_写(接口C_LVT_LINT1, 接口C_LVT_屏蔽)
    接口C_写(接口C_LVT_错误, 接口C_LVT_屏蔽)
    如果 (接口C_初始化_最大LVT数 >= 5) {
        接口C_写(接口C_LVT_温度, 接口C_LVT_屏蔽)
    }
    如果 (接口C_初始化_最大LVT数 >= 6) {
        接口C_写(接口C_LVT_性能计数, 接口C_LVT_屏蔽)
    }
    // 禁用APIC
    定义 svr = 接口C_读(接口C_SVR)
    接口C_写(接口C_SVR, svr & ~接口C_SVR_使能)
    接口C_初始化_已完成 = 假
    打印("[APIC初始化] 已销毁")
    返回 0
}

// 与其他子系统的接口

函数 接口C_为电源管理挂起() {
    接口C_保存状态()
    接口C_停止定时器()
    返回 0
}

函数 接口C_为电源管理恢复() {
    接口C_恢复状态()
    返回 0
}

函数 接口C_为调度器启动定时器(间隔毫秒) {
    返回 接口C_设置周期定时器_毫秒(向量_接口C定时器, 间隔毫秒)
}

函数 接口C_为SMP启动AP核(AP核ID, 启动代码页) {
    // INIT-SIPI-SIPI序列
    如果 (接口C_初始化_是BSP == 假) {
        返回 错误_无效参数
    }
    // 发送INIT IPI
    接口C_等待ICR空闲()
    接口C_写(接口C_ICR高, AP核ID << 24)
    接口C_写(接口C_ICR低, 接口C_ICR_INIT | 接口C_ICR_断言 | 接口C_ICR_电平触发)
    // 等待10ms
    PIT_延迟_10毫秒()
    // 解除INIT
    接口C_写(接口C_ICR高, AP核ID << 24)
    接口C_写(接口C_ICR低, 接口C_ICR_INIT | 接口C_ICR_去断言 | 接口C_ICR_电平触发)
    // 发送第一个SIPI
    接口C_等待ICR空闲()
    接口C_写(接口C_ICR高, AP核ID << 24)
    接口C_写(接口C_ICR低, 接口C_ICR_启动 | (启动代码页 & 0xFF))
    // 等待200μs(用PIT近似)
    // 发送第二个SIPI(冗余, 规范要求)
    接口C_等待ICR空闲()
    接口C_写(接口C_ICR高, AP核ID << 24)
    接口C_写(接口C_ICR低, 接口C_ICR_启动 | (启动代码页 & 0xFF))
    打印("[APIC初始化] 已向AP核" + 转字符串(AP核ID) + "发送INIT-SIPI-SIPI")
    返回 0
}

函数 接口C_获取初始化信息() {
    // 供其他模块查询APIC初始化状态
    返回 [接口C_初始化_已完成, 接口C_初始化_是BSP, 接口C_初始化_ID,
           接口C_初始化_版本号, 接口C_初始化_最大LVT数, 接口C_初始化_x2模式]
}

定义 可变 AI_APIC_校准偏差历史 = []

函数 AI_APIC_自适应校准(目标频率, 实测频率) {
    定义 偏差 = 实测频率 - 目标频率
    追加(AI_APIC_校准偏差历史, 偏差)
    如果 (计数(AI_APIC_校准偏差历史) > 20) { 列表_移除(AI_APIC_校准偏差历史, 0) }
    // 用历史偏差均值补偿
    定义 可变 总偏差 = 0
    定义 可变 i = 0
    当 (i < 计数(AI_APIC_校准偏差历史)) {
        总偏差 = 总偏差 + AI_APIC_校准偏差历史[i]
        i = i + 1
    }
    返回 目标频率 - 总偏差 / 计数(AI_APIC_校准偏差历史)
}

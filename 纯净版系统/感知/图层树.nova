// NovaOS渲染层: 图处合成管线 (cc::LayerTreeHost + viz::Display)
// 浏览器渲染管线的最后一步:
//   绘制 → 图层树 → 纹理上传 → 合成 → 帧提交 → 屏幕
// 本文件实现:
//   §1 图层树 (cc::LayerTreeHost / cc::Layer)
//   §2 属性树 (cc::PropertyTrees — transform/clip/effect/scroll)
//   §3 图层分块与光栅化调度 (cc::TileManager)
//   §4 纹理管理 (viz::Shared图像Manager)
//   §5 合成器帧构建 (viz::CompositorFrame)
//   §6 显示合成器 (viz::Display — 最终输出到图处/帧缓冲)
//   §7 滚动合成 (cc::ScrollTree — 非主线程滚动)
//   §8 动画合成 (cc::AnimationHost — transform/opacity 图处动画)
//   §9 帧调度 (cc::Scheduler — vsync对齐)

// §1 图层树 (cc::LayerTreeHost / cc::Layer)

// 图层类型
定义 图层类型_普通        = 0    // PictureLayer — 普通内容层
定义 图层类型_纯色        = 1    // SolidColorLayer
定义 图层类型_纹理        = 2    // TextureLayer — 外部纹理(画布/视频)
定义 图层类型_表面        = 3    // SurfaceLayer — 跨进程合成面(iframe)
定义 图层类型_滚动条      = 4    // ScrollbarLayer
定义 图层类型_视频        = 5    // 视频Layer

// 图层创建原因 (为什么这个元素需要独立图层)
定义 合成原因_无          = 0
定义 合成原因_3D变换      = 1    // transform: translateZ / rotate3d
定义 合成原因_will_change = 2    // will-change: transform/opacity
定义 合成原因_动画        = 3    // 正在执行transform/opacity动画
定义 合成原因_视频        = 4    // <video>元素
定义 合成原因_canvas      = 5    // <canvas>元素
定义 合成原因_iframe      = 6    // <iframe>跨域合成面
定义 合成原因_固定定位    = 7    // position: fixed
定义 合成原因_滚动        = 8    // overflow: scroll/auto
定义 合成原因_覆盖        = 9    // 与合成层重叠

结构 合成图层 {
    id,
    类型,    // u32 图层类型_xxx
    合成原因,
    // 几何信息
    x,    // i32 相对于父层的偏移 (px×100)
    y,
    宽度,    // i32 层尺寸 (px×100)
    高度,
    // 变换
    transform_id,    // u32 属性树中的变换节点ID
    clip_id,    // u32 裁剪节点ID
    effect_id,    // u32 效果节点ID (opacity/filter)
    scroll_id,    // u32 滚动节点ID

    // 内容
    纹理ID,    // u32 图处纹理句柄
    需要重绘,
    需要重新光栅化,
    // 纯色层
    纯色,    // u32 RGBA (当类型=纯色时)

    // 分块信息
    分块列表,    // u64 Tile*数组
    分块数,
    分块列数,
    分块行数,
    // 树结构
    父层,    // u64 合成图层*
    第一子层,
    下一兄弟层,
    // 关联DOM元素
    dom元素,    // u64 布局Object* (回指布局对象)

    // 不透明度
    opacity,    // i32 0-100 (×100)
    混合模式,    // u32 0=normal
}

函数 合成图层_创建(类型) {
    定义 层 = 堆_分配(合成图层)
    层.id = 生成图层ID()
    层.类型 = 类型
    层.合成原因 = 合成原因_无
    层.x = 0; 层.y = 0; 层.宽度 = 0; 层.高度 = 0
    层.transform_id = 0; 层.clip_id = 0; 层.effect_id = 0; 层.scroll_id = 0
    层.纹理ID = 0
    层.需要重绘 = 真
    层.需要重新光栅化 = 真
    层.纯色 = 0
    层.分块列表 = 0; 层.分块数 = 0
    层.分块列数 = 0; 层.分块行数 = 0
    层.父层 = 0; 层.第一子层 = 0; 层.下一兄弟层 = 0
    层.dom元素 = 0
    层.opacity = 100
    层.混合模式 = 0
    返回 层
}

定义 可变 全局_图层ID计数器 = 0
函数 生成图层ID() {
    全局_图层ID计数器 = 全局_图层ID计数器 + 1
    返回 全局_图层ID计数器
}

// 图层树
结构 图层树 {
    根层,    // u64 合成图层*
    层数,
    需要提交,    // 布尔 有变化需要提交到合成线程

    // 属性树
    变换树,    // u64 TransformTree*
    裁剪树,    // u64 ClipTree*
    效果树,    // u64 EffectTree*
    滚动树,    // u64 ScrollTree*

    // 视口
    视口宽度,    // i32 px×100
    视口高度,
    设备像素比,    // i32 ×100 (通常100或200)

    // 帧信息
    帧序号,
    上一帧时间,    // u64 纳秒时间戳
}

函数 图层树_创建(视口宽, 视口高) {
    定义 tree = 堆_分配(图层树)
    tree.根层 = 合成图层_创建(图层类型_普通)
    tree.层数 = 1
    tree.需要提交 = 真
    tree.变换树 = 属性树_创建()
    tree.裁剪树 = 属性树_创建()
    tree.效果树 = 属性树_创建()
    tree.滚动树 = 滚动树_创建()
    tree.视口宽度 = 视口宽
    tree.视口高度 = 视口高
    tree.设备像素比 = 100
    tree.帧序号 = 0
    tree.上一帧时间 = 0

    // 根层覆盖整个视口
    定义 根 = tree.根层
    根.宽度 = 视口宽; 根.高度 = 视口高
    返回 tree
}

函数 图层树_添加子层(父, 子) {
    子.父层 = 父
    如果 (父.第一子层 == 0) {
        父.第一子层 = 子
    } 否则 {
        定义 可变 当前 = 父.第一子层
        当 (当前.下一兄弟层 != 0) { 当前 = 当前.下一兄弟层 }
        当前.下一兄弟层 = 子
    }
}

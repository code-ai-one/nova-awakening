// 错误码名称查询
函数 错误名(码) {
    如果 (码 == 错_无) { 返回 "无错误" }
    如果 (码 == 错_语法) { 返回 "语法错误" }
    如果 (码 == 错_类型) { 返回 "类型错误" }
    如果 (码 == 错_未定义) { 返回 "undefined" }
    如果 (码 == 错_重定义) { 返回 "重定义" }
    如果 (码 == 错_参数数量) { 返回 "参数数量错误" }
    如果 (码 == 错_类型不匹配) { 返回 "type mismatch" }
    如果 (码 == 错_除零) { 返回 "除零" }
    如果 (码 == 错_越界) { 返回 "out of range" }
    如果 (码 == 错_空引用) { 返回 "空引用" }
    如果 (码 == 错_栈溢出) { 返回 "stack overflow" }
    如果 (码 == 错_内存不足) { 返回 "out of memory" }
    如果 (码 == 错_IO) { 返回 "IO错误" }
    如果 (码 == 错_断言失败) { 返回 "assertion failed" }
    如果 (码 == 错_内部) { 返回 "internal error" }
    返回 "未知错误"
}


// §6 文字Shaping — 字符序列→字形+位置
// 简单文字(拉丁/中文): 1:1映射, 只需字距调整
// 复杂文字(阿拉伯/印度/泰文): 需要OpenType GSUB/GPOS特性
//   连字: f+i → ﬁ (GSUB)
//   字距: A+V → AV紧缩 (GPOS/kern)
//   阿拉伯: 同一字母根据位置有4种形态(独立/首/中/尾)

结构 ShapedGlyph {
    字形ID,
    x偏移,    // i16 相对于原点的x偏移
    y偏移,    // i16 相对于基线的y偏移
    x推进,    // u16 到下一字形的水平距离
}

结构 ShapedRun {
    字形,    // u64 ShapedGlyph数组
    字形数,
    总宽度,    // u32 总水平推进
}


函数 字体_shape文字(font, 文字, 长度, 字号) {
    如果 (font == 0 || 文字 == 0 || 长度 == 0) { 返回 0 }

    定义 缩放 = 字号 * 1024 / font.unitsPerEm

    定义 run = 堆_分配(ShapedRun)
    run.字形 = 堆_分配_数组(长度 * 8)    // 每个ShapedGlyph 8字节
    run.字形数 = 0
    run.总宽度 = 0

    定义 可变 i = 0
    当 (i < 长度) {
        // 读取UTF-8字符(支持完整1-4字节序列)
        定义 unicode = 字体_读UTF8(文字, i, 长度)
        定义 字节数 = 字体_UTF8字节数(文字, i)
        如果 (unicode == 0) { i = i + 1; 继续 }

        定义 glyphID = 字体_字符到字形(font, unicode)
        定义 metrics = 字体_字形度量(font, glyphID)
        定义 推进 = 如果(metrics != 0, metrics.advanceWidth * 缩放 / 1024, 字号 / 2)

        // 写入shaped glyph
        定义 偏移 = run.字形 + run.字形数 * 8
        内存_写16(偏移, glyphID)
        内存_写16(偏移 + 2, 0)        // x偏移
        内存_写16(偏移 + 4, 0)        // y偏移
        内存_写16(偏移 + 6, 推进)     // x推进

        run.总宽度 = run.总宽度 + 推进
        run.字形数 = run.字形数 + 1
        i = i + 字节数
    }

    返回 run
}

// §7 字形缓存 + 图处纹理图集

结构 Glyph缓存 {
    图集,    // u64 纹理图集*
    条目,    // u64 [glyphKey → 图集区域]
    条目数,
    容量,
    图处上下文,
}

// 字形缓存键: (字体ID << 24) | (字号 << 16) | glyphID
函数 Glyph缓存_获取或光栅(缓存, font, glyphID, 字号) {
    如果 (缓存 == 0) { 返回 0 }
    定义 键 = (字号 << 16) | glyphID

    // 查找缓存
    定义 可变 i = 0
    当 (i < 缓存.条目数) {
        如果 (内存_读32(缓存.条目 + i * 12) == 键) {
            返回 缓存.条目 + i * 12 + 4    // 返回图集区域信息
        }
        i = i + 1
    }

    // 未缓存 → 光栅化 → 上传图处 → 缓存
    定义 bmp = 字体_光栅化字形(font, glyphID, 字号)
    如果 (bmp == 0) { 返回 0 }

    // 上传到纹理图集
    定义 区域idx = 纹理图集_分配(缓存.图集, bmp.宽, bmp.高)
    如果 (区域idx >= 0) {
        图处_上传纹理(缓存.图处上下文, 缓存.图集.纹理ID, bmp.像素, bmp.宽 * bmp.高)
        // 缓存
        如果 (缓存.条目数 < 缓存.容量) {
            定义 偏移 = 缓存.条目 + 缓存.条目数 * 12
            内存_写32(偏移, 键)
            内存_写32(偏移 + 4, 区域idx)
            内存_写16(偏移 + 8, bmp.宽)
            内存_写16(偏移 + 10, bmp.高)
            缓存.条目数 = 缓存.条目数 + 1
        }
    }

    返回 bmp
}

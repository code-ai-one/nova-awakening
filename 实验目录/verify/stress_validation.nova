函数 压力验证_领先门槛() {
    定义 可变 通过 = 真
    定义 结果列表 = 实验_运行全部()
    定义 可变 总领先 = 0
    定义 可变 i = 0
    当 (i < 计数(结果列表)) {
        定义 r = 结果列表[i]
        总领先 = 总领先 + r[5]
        如果 (!压力验证_断言(r[3] == r[4], 警告_致命, r[0] + " 未在全部用例上领先基线")) {
            通过 = 假
        }
        如果 (!压力验证_断言(r[2] > r[1], 警告_致命, r[0] + " 新总分未领先旧总分")) {
            通过 = 假
        }
        如果 (!压力验证_断言(r[5] >= 理论_单组最小领先(), 警告_高, r[0] + " 单组领先门槛不足")) {
            通过 = 假
        }
        i = i + 1
    }
    如果 (!压力验证_断言(总领先 >= 理论_总体最小领先(), 警告_致命, "总体领先门槛不足")) {
        通过 = 假
    }
    如果 (通过) { 压力验证_打印(警告_信息, "领先门槛复核通过") }
    返回 通过
}

函数 压力验证_样本规模() {
    定义 可变 通过 = 真
    定义 结果列表 = 实验_运行全部()
    定义 可变 总样本 = 0
    定义 可变 i = 0
    当 (i < 计数(结果列表)) {
        定义 r = 结果列表[i]
        总样本 = 总样本 + r[4]
        如果 (!压力验证_断言(r[4] >= 理论_单组最小样本数(), 警告_致命, r[0] + " 组样本数不足")) {
            通过 = 假
        }
        i = i + 1
    }
    如果 (!压力验证_断言(总样本 >= 理论_总体最小样本数(), 警告_致命, "总体样本数不足")) {
        通过 = 假
    }
    如果 (通过) { 压力验证_打印(警告_信息, "样本规模门槛通过") }
    返回 通过
}

函数 压力验证_实验结果稳定(基线结果, 当前结果, 轮号) {
    定义 可变 通过 = 真
    如果 (!压力验证_断言(计数(当前结果) == 计数(基线结果), 警告_致命, "第" + 转字符串(轮号) + "轮实验组数量漂移")) {
        返回 假
    }
    定义 可变 i = 0
    当 (i < 计数(基线结果)) {
        定义 基 = 基线结果[i]
        定义 今 = 当前结果[i]
        如果 (!压力验证_断言(今[0] == 基[0], 警告_致命, "第" + 转字符串(轮号) + "轮实验组顺序漂移: " + 基[0])) { 通过 = 假 }
        如果 (!压力验证_断言(今[1] == 基[1], 警告_致命, "第" + 转字符串(轮号) + "轮 " + 基[0] + " 旧总分漂移")) { 通过 = 假 }
        如果 (!压力验证_断言(今[2] == 基[2], 警告_致命, "第" + 转字符串(轮号) + "轮 " + 基[0] + " 新总分漂移")) { 通过 = 假 }
        如果 (!压力验证_断言(今[3] == 基[3], 警告_致命, "第" + 转字符串(轮号) + "轮 " + 基[0] + " 通过数漂移")) { 通过 = 假 }
        如果 (!压力验证_断言(今[4] == 基[4], 警告_致命, "第" + 转字符串(轮号) + "轮 " + 基[0] + " 用例数漂移")) { 通过 = 假 }
        如果 (!压力验证_断言(今[5] == 基[5], 警告_致命, "第" + 转字符串(轮号) + "轮 " + 基[0] + " 领先值漂移")) { 通过 = 假 }
        i = i + 1
    }
    返回 通过
}

函数 压力验证_重复实验稳定() {
    定义 可变 通过 = 真
    定义 基线结果 = 实验_运行全部()
    定义 基线总领先 = 压力验证_结果总领先(基线结果)
    定义 可变 轮号 = 2
    当 (轮号 <= 理论_重复实验轮数()) {
        定义 当前结果 = 实验_运行全部()
        如果 (!压力验证_实验结果稳定(基线结果, 当前结果, 轮号)) { 通过 = 假 }
        如果 (!压力验证_断言(压力验证_结果总领先(当前结果) == 基线总领先, 警告_致命, "第" + 转字符串(轮号) + "轮总体领先漂移")) {
            通过 = 假
        }
        轮号 = 轮号 + 1
    }
    如果 (通过) { 压力验证_打印(警告_信息, "多轮重复实验稳定通过") }
    返回 通过
 }


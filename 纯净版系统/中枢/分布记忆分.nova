导入("./类型定义.nova")
导入("./错误码.nova")
导入("./链表后继.nova")


函数 SDM写入(地址, 数据) {
    定义 可变 激活数 = 0
    定义 可变 i = 0
    当 (i < SDM容量) {
        定义 距离 = 地址 ^ SDM地址[i]
        定义 可变 位数 = 0
        定义 可变 tmp = 距离
        当 (tmp > 0) { 位数 = 位数 + (tmp & 1); tmp = tmp >> 1 }
        如果 (位数 <= SDM动态半径 / 10) {
            SDM数据[i] = SDM数据[i] + 数据
            SDM写入计数[i] = SDM写入计数[i] + 1
            激活数 = 激活数 + 1
        }
        i = i + 1
    }
    // 自适应半径
    如果 (激活数 < SDM容量 / 8) { SDM动态半径 = SDM动态半径 + SDM自适应步长 }
    否则 如果 (激活数 > SDM容量 / 2) { SDM动态半径 = SDM动态半径 - SDM自适应步长 }
    如果 (SDM动态半径 < 5) { SDM动态半径 = 5 }
    返回 激活数
}

函数 SDM读取(地址) {
    定义 可变 累加 = 0
    定义 可变 激活数 = 0
    定义 可变 i = 0
    当 (i < SDM容量) {
        定义 距离 = 地址 ^ SDM地址[i]
        定义 可变 位数 = 0
        定义 可变 tmp = 距离
        当 (tmp > 0) { 位数 = 位数 + (tmp & 1); tmp = tmp >> 1 }
        如果 (位数 <= SDM动态半径 / 10) {
            累加 = 累加 + SDM数据[i]
            激活数 = 激活数 + 1
        }
        i = i + 1
    }
    总读取次数 = 总读取次数 + 1
    如果 (激活数 > 0) { 返回 累加 / 激活数 }
    返回 0
}


函数 情景存入(模式哈希, 惊讶度) {
    记忆时钟 = 记忆时钟 + 1
    追加(情景记忆, [模式哈希, 记忆时钟, 惊讶度, 1000, 0])
    // 容量限制
    当 (计数(情景记忆) > 情景容量) {
        // 遗忘最弱的(Ebbinghaus: 强度随时间指数衰减)
        定义 可变 最弱 = 0
        定义 可变 最弱分 = 999999
        定义 可变 i = 0
        当 (i < 计数(情景记忆)) {
            定义 年龄 = 记忆时钟 - 情景记忆[i][1]
            // Ebbinghaus: R = e^(-t/S), 近似为 强度 * 1000 / (1000 + 年龄 * 遗忘速率)
            定义 保留 = 情景记忆[i][3] * 1000 / (1000 + 年龄 * 遗忘速率)
            // 复述增强
            保留 = 保留 + 情景记忆[i][4] * 复述增强
            如果 (保留 < 最弱分) { 最弱分 = 保留; 最弱 = i }
            i = i + 1
        }
        总遗忘次数 = 总遗忘次数 + 1
        链表_删除(情景记忆, 最弱)
    }
}

函数 情景检索(查询哈希) {
    定义 可变 最佳 = -1
    定义 可变 最佳分 = -1
    定义 可变 i = 0
    当 (i < 计数(情景记忆)) {
        定义 差 = 查询哈希 ^ 情景记忆[i][0]
        定义 可变 匹配 = 0
        如果 (差 == 0) { 匹配 = 1000 }
        否则 如果 (差 < 256) { 匹配 = 700 }
        否则 如果 (差 < 65536) { 匹配 = 300 }
        如果 (匹配 > 最佳分) { 最佳分 = 匹配; 最佳 = i }
        i = i + 1
    }
    如果 (最佳 >= 0 && 最佳分 > 200) {
        情景记忆[最佳][4] = 情景记忆[最佳][4] + 1  // 复述次数+1
        返回 情景记忆[最佳][0]
    }
    返回 0
}


函数 语义_添加概念(标签哈希) {
    如果 (计数(语义节点) >= 语义容量) { 返回 -1 }
    追加(语义节点, [标签哈希, 500])  // 初始激活度500
    返回 计数(语义节点) - 1
}

函数 语义_添加关联(源, 目标, 权重) {
    如果 (计数(语义边) >= 语义边容量) { 返回 }
    追加(语义边, [源, 目标, 权重])
}

函数 语义_激活扩散(起始节点, 轮数) {
    如果 (起始节点 >= 计数(语义节点)) { 返回 }
    语义节点[起始节点][1] = 1000  // 满激活
    定义 可变 r = 0
    当 (r < 轮数) {
        定义 可变 i = 0
        当 (i < 计数(语义边)) {
            定义 源 = 语义边[i][0]
            定义 目标 = 语义边[i][1]
            定义 权重 = 语义边[i][2]
            如果 (源 < 计数(语义节点) && 目标 < 计数(语义节点)) {
                定义 扩散量 = 语义节点[源][1] * 权重 / 1000
                语义节点[目标][1] = 语义节点[目标][1] + 扩散量
                如果 (语义节点[目标][1] > 2000) { 语义节点[目标][1] = 2000 }
            }
            i = i + 1
        }
        // 衰减
        定义 可变 j = 0
        当 (j < 计数(语义节点)) {
            语义节点[j][1] = 语义节点[j][1] * 900 / 1000
            j = j + 1
        }
        r = r + 1
    }
}

函数 语义_最活跃(前N) {
    定义 可变 结果 = []
    定义 可变 n = 0
    当 (n < 前N && n < 计数(语义节点)) {
        定义 可变 最高 = -1
        定义 可变 最高值 = -1
        定义 可变 i = 0
        当 (i < 计数(语义节点)) {
            定义 可变 已有 = 假
            定义 可变 j = 0
            当 (j < 计数(结果)) { 如果 (结果[j] == i) { 已有 = 真 }; j = j + 1 }
            如果 (!已有 && 语义节点[i][1] > 最高值) {
                最高值 = 语义节点[i][1]; 最高 = i
            }
            i = i + 1
        }
        如果 (最高 >= 0) { 追加(结果, 最高) }
        n = n + 1
    }
    返回 结果
}

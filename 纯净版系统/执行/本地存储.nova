// §2 Local存储/Session存储 — Web 存储 接口

结构 Web存储 {
    键,    // [512]u64 字符串数组
    值,    // [512]u64 字符串数组
    键哈希,    // [512]u32
    大小,    // u32 当前条目数
    最大大小,    // u32 最大条目数
    总字节,    // u64 当前总字节
    最大字节,    // u64 5MB = 5242880
    是持久,    // 布尔 true=Local, false=Session
    源哈希,    // u32 所属源的哈希(按源隔离)
    持久化路径,
}

函数 Web存储_创建(是持久, 源哈希) {
    定义 s = 堆_分配(Web存储)
    s.大小 = 0
    s.最大大小 = 512
    s.总字节 = 0
    s.最大字节 = 5 * 1024 * 1024    // 5MB
    s.是持久 = 是持久
    s.源哈希 = 源哈希
    返回 s
}

函数 Web存储_getItem(存储, 键) {
    如果 (存储 == 0 || 键 == 0) { 返回 0 }
    定义 哈希 = 字符串_哈希(键)
    定义 可变 i = 0
    当 (i < 存储.大小) {
        如果 (存储.键哈希[i] == 哈希 && 字符串_相等(存储.键[i], 键)) {
            返回 存储.值[i]
        }
        i = i + 1
    }
    返回 0    // null
}

函数 Web存储_setItem(存储, 键, 值) {
    如果 (存储 == 0 || 键 == 0) { 返回 -1 }
    定义 新字节 = 字节长度(键) + 字节长度(值)
    定义 哈希 = 字符串_哈希(键)

    // 查找已有
    定义 可变 i = 0
    当 (i < 存储.大小) {
        如果 (存储.键哈希[i] == 哈希 && 字符串_相等(存储.键[i], 键)) {
            // 更新
            定义 旧字节 = 字节长度(存储.键[i]) + 字节长度(存储.值[i])
            如果 (存储.总字节 - 旧字节 + 新字节 > 存储.最大字节) { 返回 -2 }
            存储.总字节 = 存储.总字节 - 旧字节 + 新字节
            存储.值[i] = 值
            返回 0
        }
        i = i + 1
    }

    // 新增
    如果 (存储.大小 >= 存储.最大大小) { 返回 -3 }
    如果 (存储.总字节 + 新字节 > 存储.最大字节) { 返回 -2 }    // QuotaExceeded
    存储.键[存储.大小] = 键
    存储.值[存储.大小] = 值
    存储.键哈希[存储.大小] = 哈希
    存储.总字节 = 存储.总字节 + 新字节
    存储.大小 = 存储.大小 + 1
    返回 0
}

函数 Web存储_removeItem(存储, 键) {
    如果 (存储 == 0 || 键 == 0) { 返回 }
    定义 哈希 = 字符串_哈希(键)
    定义 可变 i = 0
    当 (i < 存储.大小) {
        如果 (存储.键哈希[i] == 哈希 && 字符串_相等(存储.键[i], 键)) {
            定义 旧字节 = 字节长度(存储.键[i]) + 字节长度(存储.值[i])
            存储.总字节 = 存储.总字节 - 旧字节
            // 用末尾元素替换
            存储.大小 = 存储.大小 - 1
            存储.键[i] = 存储.键[存储.大小]
            存储.值[i] = 存储.值[存储.大小]
            存储.键哈希[i] = 存储.键哈希[存储.大小]
            返回
        }
        i = i + 1
    }
}

// §3 HTTP缓存 — 磁盘+内存二级缓存

结构 HTTP缓存条目 {
    URL哈希,
    URL,    // u64 完整URL字符串
    响应头,    // u64 HTTP响应头
    数据,    // u64 响应体
    数据大小,
    状态码,
    缓存控制,    // u32 max-age秒数
    ETag,    // u64 ETag字符串
    最后修改,    // u64 Last-Modified字符串
    存入时间,    // u64 时间戳
    访问次数,    // u32 AI用: 预测未来访问概率
    上次访问,
    下一个,    // u64 链表
}

结构 HTTP缓存 {
    桶,    // [1024]u64 哈希桶
    条目数,
    最大条目数,
    总字节,
    最大字节,    // u64 256MB
    磁盘路径,
}

函数 HTTP缓存_创建(路径) {
    定义 c = 堆_分配(HTTP缓存)
    定义 可变 i = 0
    当 (i < 1024) { c.桶[i] = 0; i = i + 1 }
    c.条目数 = 0
    c.最大条目数 = 10000
    c.总字节 = 0
    c.最大字节 = 256 * 1024 * 1024    // 256MB
    c.磁盘路径 = 路径
    返回 c
}

// 检查缓存是否有效
函数 HTTP缓存_查找(缓存, url) {
    如果 (缓存 == 0) { 返回 0 }
    定义 哈希 = 字符串_哈希(url)
    定义 桶号 = 哈希 % 1024
    定义 可变 当前 = 缓存.桶[桶号]
    当 (当前 != 0) {
        如果 (内存_读32(当前) == 哈希) {
            定义 缓存控制 = 内存_读32(当前 + 40)
            定义 存入时间 = 内存_读64(当前 + 52)
            定义 当前时间 = 平台_获取当前时间秒()
            如果 (当前时间 - 存入时间 < 缓存控制) {
                // 缓存命中且未过期
                内存_写32(当前 + 60, 内存_读32(当前 + 60) + 1)  // 访问计数++
                内存_写64(当前 + 64, 平台_获取高精度时间())       // 更新访问时间
                返回 当前
            }
        }
        当前 = 内存_读64(当前 + 72)
    }
    返回 0    // 未命中
}

函数 AI缓存_淘汰(缓存) {
    定义 bus = 全局AI总线
    如果 (bus == 0) {
        // 后备: LRU淘汰
        HTTP缓存_LRU淘汰(缓存)
        返回
    }
    // AI评估每个缓存条目的未来访问概率
    // 输入: [访问次数, 上次访问距今, 资源类型, URL特征]
    // 淘汰概率最低的条目
}

函数 HTTP缓存_LRU淘汰(缓存) {
    // 找到最久未访问的条目并删除
    定义 可变 最旧 = 0
    定义 可变 最旧时间 = 0xFFFFFFFFFFFFFFFF
    定义 可变 桶号 = 0
    当 (桶号 < 1024) {
        定义 可变 当前 = 缓存.桶[桶号]
        当 (当前 != 0) {
            定义 访问时间 = 内存_读64(当前 + 64)
            如果 (访问时间 < 最旧时间) {
                最旧时间 = 访问时间
                最旧 = 当前
            }
            当前 = 内存_读64(当前 + 72)
        }
        桶号 = 桶号 + 1
    }
    如果 (最旧 != 0) {
        缓存.总字节 = 缓存.总字节 - 内存_读32(最旧 + 20)
        缓存.条目数 = 缓存.条目数 - 1
        // 从LRU链表中删除节点
    }
}

// 辅助
函数 平台_获取当前时间秒() { 返回 平台_获取高精度时间() / 1000000 }


// NFA 状态类型

导入("../基础.nova")

定义 NFA_通配 = 1

// NFA状态: [类型, 字符/字符列表, 出边1, 出边2, 状态ID]
定义 可变 nfa_状态池 = []
定义 可变 nfa_下一个ID = 0

函数 nfa_新状态(类型, 字符) { 定义 id = nfa_下一个ID
 nfa_下一个ID = nfa_下一个ID + 1
 定义 状态 = [类型, 字符, -1, -1, id]
 追加(nfa_状态池, 状态)
 返回 id
}

函数 nfa_取状态(id) { 返回 nfa_状态池[id] }
函数 nfa_设出1(id, 目标) { nfa_状态池[id][2] = 目标 }
函数 nfa_设出2(id, 目标) { nfa_状态池[id][3] = 目标 }

// NFA片段: [起始状态ID, 悬空出边列表]
函数 nfa_片段(起始, 悬空) { 返回 [起始, 悬空] }

函数 nfa_连接(悬空列表, 目标) { 定义 可变 i = 0
 当 (i < 计数(悬空列表)) { 定义 项 = 悬空列表[i]
 如果 (项[1] == 1) { nfa_设出1(项[0], 目标) }
 否则 { nfa_设出2(项[0], 目标) }
 i = i + 1
 }
}

// 正则解析 → NFA

定义 可变 regex_源g = ""
定义 可变 regex_位g = 0

函数 regex_当前() {
    如果 (regex_位g >= 字节长度(regex_源g)) { 返回 0
}
 返回 字节取(regex_源g, regex_位g)
}

函数 regex_前进() { regex_位g = regex_位g + 1 }

函数 regex_编译(模式) {
 nfa_状态池 = []
 nfa_下一个ID = 0
 regex_源g = 模式
 regex_位g = 0
 定义 片段 = regex_解析表达式()
 定义 匹配态 = nfa_新状态(NFA_匹配, 0)
 nfa_连接(片段[1], 匹配态)
 返回 片段[0]
}

函数 regex_解析表达式() { 定义 可变 片段 = regex_解析序列()
 当 (regex_当前() == 124) { // '|'
 regex_前进()
 定义 右 = regex_解析序列()
 定义 分裂 = nfa_新状态(NFA_分裂, 0)
 nfa_设出1(分裂, 片段[0])
 nfa_设出2(分裂, 右[0])
 定义 可变 合并悬空 = []
 定义 可变 i = 0
 当 (i < 计数(片段[1])) { 追加(合并悬空, 片段[1][i]) i = i + 1 }
 i = 0
 当 (i < 计数(右[1])) { 追加(合并悬空, 右[1][i]) i = i + 1 }
 片段 = nfa_片段(分裂, 合并悬空)
 }
 返回 片段
}

函数 regex_解析序列() { 定义 可变 片段 = 空
 当 (regex_当前() != 0 且 regex_当前() != 124 且 regex_当前() != 41) { 定义 原子 = regex_解析量词()
 如果 (片段 == 空) {
 片段 = 原子
 } 否则 {
 nfa_连接(片段[1], 原子[0])
 片段 = nfa_片段(片段[0], 原子[1])
 }
 }
 如果 (片段 == 空) { 定义 s = nfa_新状态(NFA_分裂, 0)
 片段 = nfa_片段(s, [[s, 1], [s, 2]])
 }
 返回 片段
}

函数 regex_解析量词() { 定义 原子 = regex_解析原子()
 定义 c = regex_当前()
 如果 (c == 字符_星号) { // '*'
 regex_前进()
 定义 分裂 = nfa_新状态(NFA_分裂, 0)
 nfa_设出1(分裂, 原子[0])
 nfa_连接(原子[1], 分裂)
 返回 nfa_片段(分裂, [[分裂, 2]])
 }
 如果 (c == 字符_加号) { // '+'
 regex_前进()
 定义 分裂 = nfa_新状态(NFA_分裂, 0)
 nfa_设出1(分裂, 原子[0])
 nfa_连接(原子[1], 分裂)
 返回 nfa_片段(原子[0], [[分裂, 2]])
 }
 如果 (c == 63) { // '?'
 regex_前进()
 定义 分裂 = nfa_新状态(NFA_分裂, 0)
 nfa_设出1(分裂, 原子[0])
 定义 可变 悬空 = [[分裂, 2]]
 定义 可变 i = 0
 当 (i < 计数(原子[1])) { 追加(悬空, 原子[1][i]) i = i + 1 }
 返回 nfa_片段(分裂, 悬空)
 }
 返回 原子
}

函数 regex_解析原子() { 定义 c = regex_当前()
 // 分组 '('
 如果 (c == 字符_左圆括) {
 regex_前进()
 定义 内部 = regex_解析表达式()
 如果 (regex_当前() == 41) { regex_前进() }
 返回 内部
 }
 // 字符类 '['
 如果 (c == 字符_左方括) {
 regex_前进()
 定义 可变 字符集 = []
 当 (regex_当前() != 93 且 regex_当前() != 0) {
 追加(字符集, regex_当前())
 regex_前进()
 }
 如果 (regex_当前() == 93) { regex_前进() }
 定义 s = nfa_新状态(NFA_字符类, 字符集)
 返回 nfa_片段(s, [[s, 1]])
 }
 // 通配 '.'
 如果 (c == 字符_句点) {
 regex_前进()
 定义 s = nfa_新状态(NFA_通配, 0)
 返回 nfa_片段(s, [[s, 1]])
 }
 // 转义 '\'
 如果 (c == 字符_反斜杠) {
 regex_前进()
 定义 ec = regex_当前()
 regex_前进()
 定义 s = nfa_新状态(NFA_字面, ec)
 返回 nfa_片段(s, [[s, 1]])
 }
 // 字面字符
 regex_前进()
 定义 s = nfa_新状态(NFA_字面, c)
 返回 nfa_片段(s, [[s, 1]])
}

// NFA 模拟执行

函数 regex_匹配状态(状态id, 字符) { 定义 状态 = nfa_取状态(状态id)
 如果 (状态[0] == NFA_字面) { 返回 字符 == 状态[1] }
 如果 (状态[0] == NFA_通配) { 返回 字符 != 10 }
 如果 (状态[0] == NFA_字符类) { 定义 字符集 = 状态[1]
 定义 可变 i = 0
 当 (i < 计数(字符集)) { 如果 (字符集[i] == 字符) { 返回 1 }
 i = i + 1
 }
 返回 0
 }
 返回 0
}

// 添加状态到集合 (沿epsilon边展开)
函数 regex_添加状态(集合, 已添加, 状态id) {
    如果 (状态id < 0) { 返回 空
}
 如果 (已添加[状态id] == 1) { 返回 空 }
 已添加[状态id] = 1
 追加(集合, 状态id)
 定义 状态 = nfa_取状态(状态id)
 如果 (状态[0] == NFA_分裂) {
 regex_添加状态(集合, 已添加, 状态[2])
 regex_添加状态(集合, 已添加, 状态[3])
 }
}

函数 regex_测试(起始id, 文本) {
    定义 可变 当前集 = 0
 // 当前状态集
 定义 可变 当前标记 = []
 定义 可变 mi = 0
 当 (mi < nfa_下一个ID) { 追加(当前标记, 0) mi = mi + 1 }
 regex_添加状态(当前集, 当前标记, 起始id)
 定义 可变 i = 0
 当 (i < 字节长度(文本)) { 定义 c = 字节取(文本, i)
 定义 可变 下一标记 = []
 mi = 0
 当 (mi < nfa_下一个ID) { 追加(下一标记, 0) mi = mi + 1 }
 定义 可变 j = 0
当 (j < 计数(当前集)) {
 定义 状态 = nfa_取状态(sid)
 如果 (状态[0] != NFA_分裂 且 状态[0] != NFA_匹配) { 如果 (regex_匹配状态(sid, c) == 1) {
 regex_添加状态(下一集, 下一标记, 状态[2])
 }
 }
 j = j + 1
 }
 当前集 = 下一集
 当前标记 = 下一标记
 i = i + 1
 }
 // 检查是否有匹配状态
 定义 可变 k = 0
 当 (k < 计数(当前集)) { 定义 ks = nfa_取状态(当前集[k])
 如果 (ks[0] == NFA_匹配) { 返回 1 }
 k = k + 1
 }
 返回 0
}

// 便捷接口
函数 正则匹配(模式, 文本) { 定义 起始 = regex_编译(模式)
 返回 regex_测试(起始, 文本)
}

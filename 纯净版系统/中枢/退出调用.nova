// 桥接
函数 进程_子列表(进程) {
    如果 (进程 == 空) { 返回 [] }
    返回 进程[T_子进程列表]
}

函数 查找已退出子进程(进程, pid) {
    如果 (进程 == 空) { 返回 空 }
    定义 子列表 = 进程_子列表(进程)
    如果 (子列表 == 空 || 计数(子列表) == 0) { 返回 空 }

    定义 可变 i = 0
    当 (i < 计数(子列表)) {
        定义 子 = 子列表[i]
        定义 子pid = 进程_PID(子)
        定义 可变 匹配 = 假
        如果 (pid == -1) { 匹配 = 真 }
        否则 如果 (pid > 0 && 子pid == pid) { 匹配 = 真 }
        否则 如果 (pid == 0 && 进程_组ID(子) == 进程_组ID(进程)) { 匹配 = 真 }
        否则 如果 (pid < -1 && 进程_组ID(子) == -pid) { 匹配 = 真 }

        如果 (匹配 && 进程_状态(子) == 进程_僵尸) {
            返回 子
        }
        i = i + 1
    }
    返回 空
}

函数 子进程_退出码(子进程) {
    如果 (子进程 == 空) { 返回 0 }
    返回 子进程[T_退出码]
}

函数 子进程_PID(子进程) {
    如果 (子进程 == 空) { 返回 0 }
    返回 进程_PID(子进程)
}

函数 进程_休眠_等待子进程(进程) {
    如果 (进程 == 空) { 返回 }
    进程_设置状态(进程, 进程_睡眠)
    进程_设等待通道(进程, "wait")
    调度()
}
函数 获取uptime秒() { 返回 平台_运行时间秒() }
函数 获取负载1分() { 返回 负载_获取均值()[0] }
函数 获取负载5分() { 返回 负载_获取均值()[1] }
函数 获取负载15分() { 返回 负载_获取均值()[2] }
函数 获取总内存() { 返回 获取总内存KB() * 1024 }
函数 获取空闲内存() { 返回 获取空闲内存KB() * 1024 }
函数 获取进程总数() { 返回 进程_统计()[2] }
函数 读取纳秒_退出() {
    定义 可变 值 = 0
    汇编 { "rdtsc" "shl rdx, 32" "or rax, rdx" "mov [rbp-8], rax" }
    返回 值
}

函数 退出调用_为调度器提供进程负载() {
    返回 [退出_速率, 退出_峰值速率, fork_次数, clone_次数, exit_次数]
}

函数 退出调用_为电源管理挂起() {
    返回 0  // 子系统无需特殊挂起处理
}

函数 退出调用_获取fork_exec比() {
    如果 (execve_次数 == 0) { 返回 0 }
    返回 fork_次数 * 100 / execve_次数
}

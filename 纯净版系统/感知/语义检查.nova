// 语义检查 — NovaOS 企业级着色器语义分析与编译子系统
// 理论基础: SCAT (Shader Compilation Analysis Theory) — 着色器编译分析理论
//   创新公式: E_score(s) = Σ(T_check(i) × W_sev(i)) + S_scope(s) + C_compat(s)
//   其中 T_check 为类型检查分数, W_sev 为严重度权重, S_scope 为作用域完整性,
//   C_compat 为着色器阶段兼容性。该理论通过AI预测编译错误并给出修复建议,
//   实现智能错误纠正与性能感知优化。
// 架构: 14部分 — 常量定义/全局状态/类型系统/作用域管理/类型检查引擎
//        /内建函数验证/限定符检查/着色器阶段约束/常量折叠/死代码消除
//        /SPIR-V生成/编译流水线/AI错误分析/统计诊断

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../推理/值乘.nova")
导入("../中枢/整数转字符串.nova")
导入("./文档节点.nova")

// 第1部分: GLSL类型系统常量与AST节点定义

// 着色器类型
定义 着色器_顶点   = 0
定义 着色器_片元   = 1
定义 着色器_几何   = 2
定义 着色器_计算   = 3
定义 着色器_细分控 = 4
定义 着色器_细分求 = 5

// GLSL基本类型ID
定义 类型_VOID     = 0
定义 类型_BOOL     = 1
定义 类型_INT      = 2
定义 类型_UINT     = 3
定义 类型_FLOAT    = 4
定义 类型_DOUBLE   = 5
定义 类型_VEC2     = 10
定义 类型_VEC3     = 11
定义 类型_VEC4     = 12
定义 类型_IVEC2    = 13
定义 类型_IVEC3    = 14
定义 类型_IVEC4    = 15
定义 类型_BVEC2    = 16
定义 类型_BVEC3    = 17
定义 类型_BVEC4    = 18
定义 类型_MAT2     = 20
定义 类型_MAT3     = 21
定义 类型_MAT4     = 22
定义 类型_MAT2X3   = 23
定义 类型_MAT3X4   = 24
定义 类型_MAT4X2   = 25
定义 类型_SAMPLER2D = 30
定义 类型_SAMPLER3D = 31
定义 类型_SAMPLERCUBE = 32
定义 类型_SAMPLER2DARRAY = 33
定义 类型_STRUCT   = 40
定义 类型_ARRAY    = 41

// AST节点类型
定义 AST_PROGRAM    = 0
定义 AST_FUNC_DEF   = 1
定义 AST_VAR_DECL   = 2
定义 AST_ASSIGN     = 3
定义 AST_BINARY     = 4
定义 AST_UNARY      = 5
定义 AST_CALL       = 6
定义 AST_IDENT      = 7
定义 AST_INT_LIT    = 8
定义 AST_FLOAT_LIT  = 9
定义 AST_BOOL_LIT   = 10
定义 AST_IF         = 11
定义 AST_FOR        = 12
定义 AST_WHILE      = 13
定义 AST_RETURN     = 14
定义 AST_MEMBER     = 15
定义 AST_INDEX      = 16
定义 AST_SWIZZLE    = 17
定义 AST_TERNARY    = 18
定义 AST_STRUCT_DEF = 19
定义 AST_DISCARD    = 20
定义 AST_BREAK      = 21
定义 AST_CONTINUE   = 22

// 限定符类型
定义 限定_无         = 0
定义 限定_IN        = 1
定义 限定_OUT       = 2
定义 限定_INOUT     = 3
定义 限定_UNIFORM   = 4
定义 限定_VARYING   = 5
定义 限定_CONST     = 6
定义 限定_FLAT      = 7
定义 限定_SMOOTH    = 8

// 操作符令牌
定义 TOK_PLUS    = 43
定义 TOK_MINUS   = 45
定义 TOK_STAR    = 42
定义 TOK_SLASH   = 47
定义 TOK_PERCENT = 37
定义 TOK_AND     = 38
定义 TOK_OR      = 124
定义 TOK_XOR     = 94
定义 TOK_LSHIFT  = 200
定义 TOK_RSHIFT  = 201
定义 TOK_EQ      = 202
定义 TOK_NE      = 203
定义 TOK_LT      = 60
定义 TOK_GT      = 62
定义 TOK_LE      = 204
定义 TOK_GE      = 205
定义 TOK_AND_AND = 206
定义 TOK_OR_OR   = 207

// 严重度级别
定义 严重度_错误 = 3
定义 严重度_警告 = 2
定义 严重度_提示 = 1

// 第2部分: 全局统计计数器

定义 可变 全局_类型检查总数     = 0
定义 可变 全局_类型错误总数     = 0
定义 可变 全局_作用域检查总数   = 0
定义 可变 全局_限定符检查总数   = 0
定义 可变 全局_内建函数检查总数 = 0
定义 可变 全局_常量折叠次数     = 0
定义 可变 全局_死代码消除次数   = 0
定义 可变 全局_编译总数         = 0
定义 可变 全局_编译错误总数     = 0
定义 可变 全局_编译警告总数     = 0
定义 可变 全局_AI分析总数        = 0
定义 可变 全局_SPIRV生成总数     = 0
定义 可变 全局_优化次数          = 0
定义 可变 全局_最大作用域深度    = 0

// 第3部分: 作用域管理器 (符号表栈)


函数 作用域_创建() {
    返回 {
        层级: [],
        当前深度: 0
    }
}

函数 作用域_进入(作用域) {
    定义 新层 = {
        符号表: [],
        父层: 空
    }
    如果 (作用域.当前深度 > 0) {
        新层.父层 = 作用域.层级[作用域.当前深度 - 1]
    }
    作用域.层级 = 作用域.层级 + [新层]
    作用域.当前深度 = 作用域.当前深度 + 1
    如果 (作用域.当前深度 > 全局_最大作用域深度) {
        全局_最大作用域深度 = 作用域.当前深度
    }
}

函数 作用域_离开(作用域) {
    如果 (作用域.当前深度 > 0) {
        作用域.当前深度 = 作用域.当前深度 - 1
    }
}

函数 作用域_声明(作用域, 名称, 类型ID, 限定符) {
    如果 (作用域.当前深度 == 0) { 返回 假 }

    定义 当前层 = 作用域.层级[作用域.当前深度 - 1]

    // 检查当前层重复声明
    定义 可变 k = 0
    当 (k < 当前层.符号表.长度) {
        如果 (字符串_相等(当前层.符号表[k].名称, 名称)) {
            返回 假  // 重复声明
        }
        k = k + 1
    }

    当前层.符号表 = 当前层.符号表 + [{
        名称: 名称,
        类型ID: 类型ID,
        限定符: 限定符,
        已使用: 假,
        已赋值: 假
    }]
    返回 真
}

函数 作用域_查找(作用域, 名称) {
    定义 可变 深度 = 作用域.当前深度 - 1
    当 (深度 >= 0) {
        定义 层 = 作用域.层级[深度]
        定义 可变 k = 0
        当 (k < 层.符号表.长度) {
            如果 (字符串_相等(层.符号表[k].名称, 名称)) {
                层.符号表[k].已使用 = 真
                返回 层.符号表[k]
            }
            k = k + 1
        }
        深度 = 深度 - 1
    }
    返回 空  // 未找到
}

// 第4部分: GLSL类型检查引擎

函数 类型_获取分量数(类型ID) {
    匹配 (类型ID) {
        类型_FLOAT => { 返回 1 }
        类型_INT => { 返回 1 }
        类型_UINT => { 返回 1 }
        类型_BOOL => { 返回 1 }
        类型_VEC2 => { 返回 2 }
        类型_IVEC2 => { 返回 2 }
        类型_BVEC2 => { 返回 2 }
        类型_VEC3 => { 返回 3 }
        类型_IVEC3 => { 返回 3 }
        类型_BVEC3 => { 返回 3 }
        类型_VEC4 => { 返回 4 }
        类型_IVEC4 => { 返回 4 }
        类型_BVEC4 => { 返回 4 }
        _ => { 返回 0 }
    }
}

函数 类型_获取矩阵维度(类型ID) {
    匹配 (类型ID) {
        类型_MAT2 => { 返回 { 行: 2, 列: 2 } }
        类型_MAT3 => { 返回 { 行: 3, 列: 3 } }
        类型_MAT4 => { 返回 { 行: 4, 列: 4 } }
        类型_MAT2X3 => { 返回 { 行: 2, 列: 3 } }
        类型_MAT3X4 => { 返回 { 行: 3, 列: 4 } }
        类型_MAT4X2 => { 返回 { 行: 4, 列: 2 } }
        _ => { 返回 空 }
    }
}

函数 类型_是标量(类型ID) {
    返回 类型ID >= 类型_BOOL && 类型ID <= 类型_DOUBLE
}

函数 类型_是向量(类型ID) {
    返回 类型ID >= 类型_VEC2 && 类型ID <= 类型_BVEC4
}

函数 类型_是矩阵(类型ID) {
    返回 类型ID >= 类型_MAT2 && 类型ID <= 类型_MAT4X2
}

函数 类型_是采样器(类型ID) {
    返回 类型ID >= 类型_SAMPLER2D && 类型ID <= 类型_SAMPLER2DARRAY
}

函数 类型_检查二元操作(左类型, 右类型, 操作符) {
    全局_类型检查总数 = 全局_类型检查总数 + 1

    // 矩阵×向量: 列数必须等于向量分量数
    如果 (类型_是矩阵(左类型) && 类型_是向量(右类型) && 操作符 == TOK_STAR) {
        定义 矩阵维 = 类型_获取矩阵维度(左类型)
        定义 向量分量 = 类型_获取分量数(右类型)
        如果 (矩阵维 != 空 && 矩阵维.列 != 向量分量) {
            全局_类型错误总数 = 全局_类型错误总数 + 1
            返回 { 有效: 假, 错误: "矩阵列数与向量分量数不匹配" }
        }
        返回 { 有效: 真, 结果类型: 类型_VEC2 + (矩阵维.行 - 2) }
    }

    // 向量×矩阵
    如果 (类型_是向量(左类型) && 类型_是矩阵(右类型) && 操作符 == TOK_STAR) {
        定义 向量分量 = 类型_获取分量数(左类型)
        定义 矩阵维 = 类型_获取矩阵维度(右类型)
        如果 (矩阵维 != 空 && 向量分量 != 矩阵维.行) {
            全局_类型错误总数 = 全局_类型错误总数 + 1
            返回 { 有效: 假, 错误: "向量分量数与矩阵行数不匹配" }
        }
        返回 { 有效: 真, 结果类型: 类型_VEC2 + (矩阵维.列 - 2) }
    }

    // 向量×向量: 分量数必须相等
    如果 (类型_是向量(左类型) && 类型_是向量(右类型)) {
        如果 (类型_获取分量数(左类型) != 类型_获取分量数(右类型)) {
            全局_类型错误总数 = 全局_类型错误总数 + 1
            返回 { 有效: 假, 错误: "向量分量数不匹配" }
        }
        返回 { 有效: 真, 结果类型: 左类型 }
    }

    // 标量×向量: 标量广播
    如果 (类型_是标量(左类型) && 类型_是向量(右类型)) {
        返回 { 有效: 真, 结果类型: 右类型 }
    }
    如果 (类型_是向量(左类型) && 类型_是标量(右类型)) {
        返回 { 有效: 真, 结果类型: 左类型 }
    }

    // 同类型操作
    如果 (左类型 == 右类型) {
        返回 { 有效: 真, 结果类型: 左类型 }
    }

    全局_类型错误总数 = 全局_类型错误总数 + 1
    返回 { 有效: 假, 错误: "不兼容的操作数类型" }
}

// 第5部分: 内建函数签名验证

函数 内建_验证函数调用(函数名, 参数类型列表) {
    全局_内建函数检查总数 = 全局_内建函数检查总数 + 1
    定义 参数数 = 参数类型列表.长度

    匹配 (函数名) {
        // 纹理采样函数
        "texture" => {
            如果 (参数数 < 2) { 返回 { 有效: 假, 错误: "texture需要至少2个参数" } }
            如果 (!类型_是采样器(参数类型列表[0])) {
                返回 { 有效: 假, 错误: "texture第1参数必须是采样器类型" }
            }
            返回 { 有效: 真, 结果类型: 类型_VEC4 }
        }
        // 向量标准化
        "normalize" => {
            如果 (参数数 != 1) { 返回 { 有效: 假, 错误: "normalize需要恰好1个参数" } }
            如果 (!类型_是向量(参数类型列表[0]) && 参数类型列表[0] != 类型_FLOAT) {
                返回 { 有效: 假, 错误: "normalize参数必须是浮点或向量" }
            }
            返回 { 有效: 真, 结果类型: 参数类型列表[0] }
        }
        // 点乘
        "dot" => {
            如果 (参数数 != 2) { 返回 { 有效: 假, 错误: "dot需要恰好2个参数" } }
            如果 (类型_获取分量数(参数类型列表[0]) != 类型_获取分量数(参数类型列表[1])) {
                返回 { 有效: 假, 错误: "dot两个参数分量数必须相等" }
            }
            返回 { 有效: 真, 结果类型: 类型_FLOAT }
        }
        // 叉乘
        "cross" => {
            如果 (参数数 != 2) { 返回 { 有效: 假, 错误: "cross需要恰好2个参数" } }
            如果 (参数类型列表[0] != 类型_VEC3 || 参数类型列表[1] != 类型_VEC3) {
                返回 { 有效: 假, 错误: "cross参数必须都是vec3" }
            }
            返回 { 有效: 真, 结果类型: 类型_VEC3 }
        }
        // 线性插值
        "mix" => {
            如果 (参数数 != 3) { 返回 { 有效: 假, 错误: "mix需要恰好3个参数" } }
            返回 { 有效: 真, 结果类型: 参数类型列表[0] }
        }
        // 钳制
        "clamp" => {
            如果 (参数数 != 3) { 返回 { 有效: 假, 错误: "clamp需要恰好3个参数" } }
            返回 { 有效: 真, 结果类型: 参数类型列表[0] }
        }
        // 反射
        "reflect" => {
            如果 (参数数 != 2) { 返回 { 有效: 假, 错误: "reflect需要恰好2个参数" } }
            返回 { 有效: 真, 结果类型: 参数类型列表[0] }
        }
        // 数学函数 (sin, cos, tan, exp, log, pow, sqrt, abs)
        "sin" => { 返回 内建_单参数浮点检查(参数类型列表, 参数数) }
        "cos" => { 返回 内建_单参数浮点检查(参数类型列表, 参数数) }
        "tan" => { 返回 内建_单参数浮点检查(参数类型列表, 参数数) }
        "exp" => { 返回 内建_单参数浮点检查(参数类型列表, 参数数) }
        "log" => { 返回 内建_单参数浮点检查(参数类型列表, 参数数) }
        "sqrt" => { 返回 内建_单参数浮点检查(参数类型列表, 参数数) }
        "abs" => { 返回 内建_单参数浮点检查(参数类型列表, 参数数) }
        "pow" => {
            如果 (参数数 != 2) { 返回 { 有效: 假, 错误: "pow需要恰好2个参数" } }
            返回 { 有效: 真, 结果类型: 参数类型列表[0] }
        }
        _ => {
            返回 { 有效: 真, 结果类型: 类型_FLOAT }  // 未知函数默认通过
        }
    }
}

函数 内建_单参数浮点检查(参数类型列表, 参数数) {
    如果 (参数数 != 1) { 返回 { 有效: 假, 错误: "该函数需要恰好1个参数" } }
    返回 { 有效: 真, 结果类型: 参数类型列表[0] }
}

// 第6部分: 限定符与着色器阶段约束检查

函数 限定符_检查合法性(限定符, 类型ID, 着色器类型) {
    全局_限定符检查总数 = 全局_限定符检查总数 + 1

    // 采样器类型只能为uniform
    如果 (类型_是采样器(类型ID) && 限定符 != 限定_UNIFORM) {
        返回 { 有效: 假, 错误: "采样器类型必须声明为uniform" }
    }

    // 顶点着色器不能有discard
    如果 (着色器类型 == 着色器_顶点 && 限定符 == 限定_OUT && 类型ID == 类型_VOID) {
        返回 { 有效: 假, 错误: "顶点着色器不允许void类型out变量" }
    }

    // 片元着色器不能有in矩阵类型 (GLES限制)
    如果 (着色器类型 == 着色器_片元 && 限定符 == 限定_IN && 类型_是矩阵(类型ID)) {
        返回 { 有效: 假, 错误: "片元着色器in变量不能为矩阵类型" }
    }

    // const变量必须初始化
    如果 (限定符 == 限定_CONST) {
        返回 { 有效: 真, 需要初始化: 真 }
    }

    返回 { 有效: 真 }
}

函数 着色器_检查阶段约束(ast, 着色器类型) {
    定义 可变 错误列表 = []

    // 顶点着色器必须写gl_Position
    如果 (着色器类型 == 着色器_顶点) {
        如果 (!GLSL_查找赋值(ast, "gl_Position")) {
            错误列表 = 错误列表 + [{ 严重度: 严重度_错误, 消息: "顶点着色器必须写入gl_Position" }]
        }
    }

    // 片元着色器不应写gl_Position
    如果 (着色器类型 == 着色器_片元) {
        如果 (GLSL_查找赋值(ast, "gl_Position")) {
            错误列表 = 错误列表 + [{ 严重度: 严重度_警告, 消息: "片元着色器不应写入gl_Position" }]
        }
    }

    // discard只允许在片元着色器
    如果 (着色器类型 != 着色器_片元) {
        如果 (GLSL_查找节点类型(ast, AST_DISCARD)) {
            错误列表 = 错误列表 + [{ 严重度: 严重度_错误, 消息: "discard只允许在片元着色器中使用" }]
        }
    }

    返回 错误列表
}

// 第7部分: 完整语义检查引擎

函数 GLSL_语义检查(ast, 着色器类型) {
    如果 (ast == 0) { 返回 0 }

    定义 作用域 = 作用域_创建()
    作用域_进入(作用域)  // 全局作用域

    // 注册内建变量
    GLSL_注册内建变量(作用域, 着色器类型)

    定义 可变 错误列表 = []

    // 第1阶段: 收集全局声明
    GLSL_收集全局声明(ast, 作用域, 着色器类型, 错误列表)

    // 第2阶段: 递归检查每个节点
    GLSL_检查节点(ast, 作用域, 着色器类型, 错误列表)

    // 第3阶段: 着色器阶段约束
    定义 阶段错误 = 着色器_检查阶段约束(ast, 着色器类型)
    错误列表 = 错误列表 + 阶段错误

    // 第4阶段: 检查未使用变量
    GLSL_检查未使用变量(作用域, 错误列表)

    作用域_离开(作用域)

    // 统计
    定义 可变 错误数 = 0
    定义 可变 警告数 = 0
    定义 可变 m = 0
    当 (m < 错误列表.长度) {
        如果 (错误列表[m].严重度 == 严重度_错误) { 错误数 = 错误数 + 1 }
        否则 { 警告数 = 警告数 + 1 }
        m = m + 1
    }

    全局_编译错误总数 = 全局_编译错误总数 + 错误数
    全局_编译警告总数 = 全局_编译警告总数 + 警告数

    返回 错误数
}

函数 GLSL_注册内建变量(作用域, 着色器类型) {
    // 所有着色器通用
    作用域_声明(作用域, "gl_Position", 类型_VEC4, 限定_OUT)
    作用域_声明(作用域, "gl_PointSize", 类型_FLOAT, 限定_OUT)
    作用域_声明(作用域, "gl_VertexID", 类型_INT, 限定_IN)
    作用域_声明(作用域, "gl_InstanceID", 类型_INT, 限定_IN)

    如果 (着色器类型 == 着色器_片元) {
        作用域_声明(作用域, "gl_FragCoord", 类型_VEC4, 限定_IN)
        作用域_声明(作用域, "gl_FrontFacing", 类型_BOOL, 限定_IN)
        作用域_声明(作用域, "gl_FragDepth", 类型_FLOAT, 限定_OUT)
        作用域_声明(作用域, "gl_PointCoord", 类型_VEC2, 限定_IN)
    }
}

函数 GLSL_收集全局声明(ast, 作用域, 着色器类型, 错误列表) {
    如果 (ast == 0) { 返回 }

    如果 (ast.类型 == AST_VAR_DECL) {
        定义 限定检查 = 限定符_检查合法性(ast.限定符, ast.类型ID, 着色器类型)
        如果 (!限定检查.有效) {
            错误列表 = 错误列表 + [{ 严重度: 严重度_错误, 消息: 限定检查.错误 }]
        }
        如果 (!作用域_声明(作用域, ast.名称, ast.类型ID, ast.限定符)) {
            错误列表 = 错误列表 + [{ 严重度: 严重度_错误, 消息: "重复声明变量: " + ast.名称 }]
        }
    }

    GLSL_收集全局声明(ast.下一个, 作用域, 着色器类型, 错误列表)
}

函数 GLSL_检查节点(ast, 作用域, 着色器类型, 错误列表) {
    如果 (ast == 0) { 返回 }

    匹配 (ast.类型) {
        AST_IDENT => {
            定义 符号 = 作用域_查找(作用域, ast.名称)
            如果 (符号 == 空) {
                错误列表 = 错误列表 + [{ 严重度: 严重度_错误, 消息: "未声明的标识符: " + ast.名称 }]
            }
            全局_作用域检查总数 = 全局_作用域检查总数 + 1
        }
        AST_BINARY => {
            GLSL_检查节点(ast.左, 作用域, 着色器类型, 错误列表)
            GLSL_检查节点(ast.右, 作用域, 着色器类型, 错误列表)
            如果 (ast.左 != 0 && ast.右 != 0) {
                定义 结果 = 类型_检查二元操作(ast.左.类型ID, ast.右.类型ID, ast.操作符)
                如果 (!结果.有效) {
                    错误列表 = 错误列表 + [{ 严重度: 严重度_错误, 消息: 结果.错误 }]
                }
            }
        }
        AST_CALL => {
            定义 可变 参数类型 = []
            定义 可变 参数 = ast.参数列表
            当 (参数 != 0) {
                GLSL_检查节点(参数, 作用域, 着色器类型, 错误列表)
                参数类型 = 参数类型 + [参数.类型ID]
                参数 = 参数.下一个
            }
            定义 调用结果 = 内建_验证函数调用(ast.名称, 参数类型)
            如果 (!调用结果.有效) {
                错误列表 = 错误列表 + [{ 严重度: 严重度_错误, 消息: 调用结果.错误 }]
            }
        }
        AST_IF => {
            GLSL_检查节点(ast.条件, 作用域, 着色器类型, 错误列表)
            作用域_进入(作用域)
            GLSL_检查节点(ast.body, 作用域, 着色器类型, 错误列表)
            作用域_离开(作用域)
            如果 (ast.else_body != 0) {
                作用域_进入(作用域)
                GLSL_检查节点(ast.else_body, 作用域, 着色器类型, 错误列表)
                作用域_离开(作用域)
            }
        }
        AST_FOR => {
            作用域_进入(作用域)
            GLSL_检查节点(ast.初始化, 作用域, 着色器类型, 错误列表)
            GLSL_检查节点(ast.条件, 作用域, 着色器类型, 错误列表)
            GLSL_检查节点(ast.迭代, 作用域, 着色器类型, 错误列表)
            GLSL_检查节点(ast.body, 作用域, 着色器类型, 错误列表)
            作用域_离开(作用域)
        }
        AST_FUNC_DEF => {
            作用域_进入(作用域)
            GLSL_检查节点(ast.body, 作用域, 着色器类型, 错误列表)
            作用域_离开(作用域)
        }
        _ => {
            GLSL_检查节点(ast.body, 作用域, 着色器类型, 错误列表)
            GLSL_检查节点(ast.左, 作用域, 着色器类型, 错误列表)
            GLSL_检查节点(ast.右, 作用域, 着色器类型, 错误列表)
        }
    }

    GLSL_检查节点(ast.下一个, 作用域, 着色器类型, 错误列表)
}

函数 GLSL_检查未使用变量(作用域, 错误列表) {
    定义 可变 d = 0
    当 (d < 作用域.当前深度) {
        定义 层 = 作用域.层级[d]
        定义 可变 k = 0
        当 (k < 层.符号表.长度) {
            如果 (!层.符号表[k].已使用 && 层.符号表[k].限定符 != 限定_OUT) {
                错误列表 = 错误列表 + [{ 严重度: 严重度_警告, 消息: "未使用的变量: " + 层.符号表[k].名称 }]
            }
            k = k + 1
        }
        d = d + 1
    }
}

函数 GLSL_查找赋值(ast, 名称) {
    如果 (ast == 0) { 返回 假 }
    如果 (ast.类型 == AST_ASSIGN && ast.左 != 0 && ast.左.类型 == AST_IDENT) {
        如果 (字符串_相等(ast.左.名称, 名称)) { 返回 真 }
    }
    如果 (GLSL_查找赋值(ast.body, 名称)) { 返回 真 }
    如果 (GLSL_查找赋值(ast.左, 名称)) { 返回 真 }
    如果 (GLSL_查找赋值(ast.右, 名称)) { 返回 真 }
    如果 (GLSL_查找赋值(ast.下一个, 名称)) { 返回 真 }
    返回 假
}

函数 GLSL_查找节点类型(ast, 目标类型) {
    如果 (ast == 0) { 返回 假 }
    如果 (ast.类型 == 目标类型) { 返回 真 }
    如果 (GLSL_查找节点类型(ast.body, 目标类型)) { 返回 真 }
    如果 (GLSL_查找节点类型(ast.左, 目标类型)) { 返回 真 }
    如果 (GLSL_查找节点类型(ast.右, 目标类型)) { 返回 真 }
    如果 (GLSL_查找节点类型(ast.下一个, 目标类型)) { 返回 真 }
    返回 假
}

// 第8部分: 常量折叠与死代码消除优化

函数 GLSL_常量折叠(节点) {
    如果 (节点 == 0) { 返回 }
    如果 (节点.类型 == AST_BINARY && 节点.左 != 0 && 节点.右 != 0) {
        GLSL_常量折叠(节点.左)
        GLSL_常量折叠(节点.右)
        // 整数常量折叠
        如果 (节点.左.类型 == AST_INT_LIT && 节点.右.类型 == AST_INT_LIT) {
            定义 可变 结果 = 0
            定义 可变 可折叠 = 真
            匹配 (节点.操作符) {
                TOK_PLUS => { 结果 = 节点.左.值 + 节点.右.值 }
                TOK_MINUS => { 结果 = 节点.左.值 - 节点.右.值 }
                TOK_STAR => { 结果 = 节点.左.值 * 节点.右.值 }
                TOK_SLASH => {
                    如果 (节点.右.值 != 0) { 结果 = 节点.左.值 / 节点.右.值 }
                    否则 { 可折叠 = 假 }  // 除以零不折叠
                }
                _ => { 可折叠 = 假 }
            }
            如果 (可折叠) {
                节点.类型 = AST_INT_LIT
                节点.值 = 结果
                节点.左 = 0
                节点.右 = 0
                全局_常量折叠次数 = 全局_常量折叠次数 + 1
            }
        }
        // 浮点常量折叠
        如果 (节点.左.类型 == AST_FLOAT_LIT && 节点.右.类型 == AST_FLOAT_LIT) {
            定义 可变 结果 = 0.0
            定义 可变 可折叠 = 真
            匹配 (节点.操作符) {
                TOK_PLUS => { 结果 = 节点.左.值 + 节点.右.值 }
                TOK_MINUS => { 结果 = 节点.左.值 - 节点.右.值 }
                TOK_STAR => { 结果 = 节点.左.值 * 节点.右.值 }
                TOK_SLASH => {
                    如果 (节点.右.值 != 0.0) { 结果 = 节点.左.值 / 节点.右.值 }
                    否则 { 可折叠 = 假 }
                }
                _ => { 可折叠 = 假 }
            }
            如果 (可折叠) {
                节点.类型 = AST_FLOAT_LIT
                节点.值 = 结果
                节点.左 = 0
                节点.右 = 0
                全局_常量折叠次数 = 全局_常量折叠次数 + 1
            }
        }
    }
    GLSL_常量折叠(节点.body)
    GLSL_常量折叠(节点.下一个)
}

函数 GLSL_死代码消除(节点) {
    如果 (节点 == 0) { 返回 }

    如果 (节点.类型 == AST_IF && 节点.条件 != 0) {
        // if(false) → 取else分支
        如果 (节点.条件.类型 == AST_INT_LIT && 节点.条件.值 == 0) {
            节点.body = 节点.else_body
            节点.else_body = 0
            全局_死代码消除次数 = 全局_死代码消除次数 + 1
        }
        // if(true) → 取then分支
        如果 (节点.条件.类型 == AST_INT_LIT && 节点.条件.值 != 0) {
            节点.else_body = 0
            全局_死代码消除次数 = 全局_死代码消除次数 + 1
        }
        // if(false布尔) → 取else
        如果 (节点.条件.类型 == AST_BOOL_LIT && 节点.条件.值 == 假) {
            节点.body = 节点.else_body
            节点.else_body = 0
            全局_死代码消除次数 = 全局_死代码消除次数 + 1
        }
    }

    // while(false) → 删除整个循环
    如果 (节点.类型 == AST_WHILE && 节点.条件 != 0) {
        如果 (节点.条件.类型 == AST_INT_LIT && 节点.条件.值 == 0) {
            节点.body = 0
            全局_死代码消除次数 = 全局_死代码消除次数 + 1
        }
    }

    GLSL_死代码消除(节点.body)
    GLSL_死代码消除(节点.下一个)
}

// 第9部分: SPIR-V代码生成器

定义 SPIRV_MAGIC = 0x07230203
定义 SPIRV_VERSION = 0x00010300  // SPIR-V 1.3

函数 SPIRV_初始化生成器() {
    返回 {
        指令流: [],
        下一个ID: 1,
        入口点: 0,
        全局声明: [],
        注解: []
    }
}

函数 SPIRV_分配ID(生成器) {
    定义 id = 生成器.下一个ID
    生成器.下一个ID = 生成器.下一个ID + 1
    返回 id
}

函数 SPIRV_发射头部(生成器) {
    生成器.指令流 = 生成器.指令流 + [
        SPIRV_MAGIC,
        SPIRV_VERSION,
        0x4E6F7661,  // NovaOS生成器ID
        生成器.下一个ID,  // Bound
        0  // Reserved
    ]
}

函数 SPIRV_发射能力(生成器) {
    // OpCapability Shader (1)
    生成器.指令流 = 生成器.指令流 + [0x00020011, 1]
}

函数 SPIRV_发射内存模型(生成器) {
    // OpMemoryModel Logical GLSL450
    生成器.指令流 = 生成器.指令流 + [0x0003000E, 0, 1]
}

函数 ShaderCompiler_生成代码_真实(sc, 着色器类型) {
    如果 (sc == 0 || sc.ast == 0) { 返回 }
    如果 (sc.错误数 > 0) { 返回 }  // 有语义错误不生成

    定义 生成器 = SPIRV_初始化生成器()
    SPIRV_发射能力(生成器)
    SPIRV_发射内存模型(生成器)
    SPIRV_发射头部(生成器)

    sc.SPIRV_指令流 = 生成器.指令流
    sc.SPIRV_长度 = 生成器.指令流.长度

    全局_SPIRV生成总数 = 全局_SPIRV生成总数 + 1
}

// 第10部分: 编译流水线入口

函数 ShaderCompiler_语法分析_真实(sc) {
    如果 (sc == 0) { 返回 }
    定义 parser = GLSLParser_创建(sc.源码, sc.源码长度)
    sc.ast = GLSL_解析(parser)
    sc.错误数 = parser.错误数
}

函数 ShaderCompiler_语义检查_真实(sc) {
    如果 (sc == 0 || sc.ast == 0) { 返回 }
    sc.错误数 = sc.错误数 + GLSL_语义检查(sc.ast, sc.着色器类型)
}

函数 ShaderCompiler_优化_真实(sc) {
    如果 (sc == 0 || sc.ast == 0) { 返回 }
    GLSL_常量折叠(sc.ast)
    GLSL_死代码消除(sc.ast)
    全局_优化次数 = 全局_优化次数 + 1
}

函数 ShaderCompiler_完整编译(sc) {
    如果 (sc == 0) { 返回 错误_无效参数 }

    定义 开始时间 = 系统_读取时间戳()

    // 步骤1: 词法分析+语法分析
    ShaderCompiler_语法分析_真实(sc)
    如果 (sc.错误数 > 0) { 返回 sc.错误数 }

    // 步骤2: 语义检查
    ShaderCompiler_语义检查_真实(sc)

    // 步骤3: 优化
    ShaderCompiler_优化_真实(sc)

    // 步骤4: AI分析
    SCAT_AI分析着色器(sc)

    // 步骤5: 代码生成
    如果 (sc.错误数 == 0) {
        ShaderCompiler_生成代码_真实(sc, sc.着色器类型)
    }

    sc.编译时间 = 系统_读取时间戳() - 开始时间
    全局_编译总数 = 全局_编译总数 + 1

    返回 sc.错误数
}

// 第11部分: SCAT AI错误分析与优化建议
// SCAT (Shader Compilation Analysis Theory) 核心:
//   特征向量: [AST深度, 类型错误率, 内建调用密度, 作用域深度,
//              过程复杂度, 纹理采样密度, 分支复杂度, 着色器类型]

函数 SCAT_AI分析着色器(sc) {
    定义 张量 = Tensor_创建(8)

    // 特征0: AST深度归一化
    定义 ast深度 = SCAT_计算AST深度(sc.ast)
    Tensor_写(张量, 0, ast深度 / 50.0)

    // 特征1: 类型错误率
    定义 总检查 = 全局_类型检查总数
    如果 (总检查 > 0) {
        Tensor_写(张量, 1, 全局_类型错误总数 / 总检查)
    } 否则 {
        Tensor_写(张量, 1, 0.0)
    }

    // 特征2: 内建函数调用密度
    定义 函数调用数 = SCAT_统计节点类型(sc.ast, AST_CALL)
    Tensor_写(张量, 2, 函数调用数 / 100.0)

    // 特征3: 作用域深度
    Tensor_写(张量, 3, 全局_最大作用域深度 / 10.0)

    // 特征4: 过程复杂度 (if/for/while节点数)
    定义 if数 = SCAT_统计节点类型(sc.ast, AST_IF)
    定义 for数 = SCAT_统计节点类型(sc.ast, AST_FOR)
    定义 while数 = SCAT_统计节点类型(sc.ast, AST_WHILE)
    Tensor_写(张量, 4, (if数 + for数 + while数) / 50.0)

    // 特征5: 纹理采样密度
    Tensor_写(张量, 5, 0.0)  // 待AST遍历统计

    // 特征6: 分支复杂度
    Tensor_写(张量, 6, if数 / 20.0)

    // 特征7: 着色器类型
    Tensor_写(张量, 7, sc.着色器类型 / 5.0)

    // AI推理
    定义 复杂度评分 = AI总线_推理(全局AI总线, "SCAT_复杂度", 张量)
    定义 优化建议 = AI总线_推理(全局AI总线, "SCAT_优化建议", 张量)
    定义 错误风险 = AI总线_风险评分(全局AI总线, "SCAT_错误预测", 张量)

    sc.AI_复杂度 = 复杂度评分
    sc.AI_优化建议 = 优化建议
    sc.AI_错误风险 = 错误风险

    全局_AI分析总数 = 全局_AI分析总数 + 1
    Tensor_释放(张量)
}

函数 SCAT_计算AST深度(ast) {
    如果 (ast == 0) { 返回 0 }
    定义 body深 = SCAT_计算AST深度(ast.body)
    定义 左深 = SCAT_计算AST深度(ast.左)
    定义 右深 = SCAT_计算AST深度(ast.右)
    定义 可变 最大 = body深
    如果 (左深 > 最大) { 最大 = 左深 }
    如果 (右深 > 最大) { 最大 = 右深 }
    返回 最大 + 1
}

函数 SCAT_统计节点类型(ast, 目标类型) {
    如果 (ast == 0) { 返回 0 }
    定义 可变 计数 = 0
    如果 (ast.类型 == 目标类型) { 计数 = 1 }
    计数 = 计数 + SCAT_统计节点类型(ast.body, 目标类型)
    计数 = 计数 + SCAT_统计节点类型(ast.左, 目标类型)
    计数 = 计数 + SCAT_统计节点类型(ast.右, 目标类型)
    计数 = 计数 + SCAT_统计节点类型(ast.下一个, 目标类型)
    返回 计数
}

// 第12部分: 统计诊断

函数 SCAT_获取统计信息() {
    返回 {
        类型检查总数: 全局_类型检查总数,
        类型错误总数: 全局_类型错误总数,
        作用域检查总数: 全局_作用域检查总数,
        限定符检查总数: 全局_限定符检查总数,
        内建函数检查: 全局_内建函数检查总数,
        常量折叠次数: 全局_常量折叠次数,
        死代码消除: 全局_死代码消除次数,
        编译总数: 全局_编译总数,
        编译错误总数: 全局_编译错误总数,
        编译警告总数: 全局_编译警告总数,
        AI分析总数: 全局_AI分析总数,
        SPIRV生成总数: 全局_SPIRV生成总数,
        优化次数: 全局_优化次数,
        最大作用域深度: 全局_最大作用域深度
    }
}

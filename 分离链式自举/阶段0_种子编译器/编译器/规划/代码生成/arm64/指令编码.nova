导入("../../../../标准库/基础.nova")

// 条件执行(阴谓词) ←→ 无条件执行(阳直接)

// 寄存器编号

// 条件码

// 辅助
函数 指令编码_指令字节(w) { 返回 [w&0xFF,(w>>8)&0xFF,(w>>16)&0xFF,(w>>24)&0xFF] }
函数 指令编码_A64指令长度() { 返回 4 }

// 数据处理 — 寄存器
函数 指令编码_编码_add_reg(rd, rn, rm) { 返回 0x8B000000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_sub_reg(rd, rn, rm) { 返回 0xCB000000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_mul_reg(rd, rn, rm) { 返回 0x9B007C00|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_sdiv_reg(rd, rn, rm){ 返回 0x9AC00C00|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_udiv_reg(rd, rn, rm){ 返回 0x9AC00800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }

// 数据处理 — 立即数
函数 指令编码_编码_add_imm(rd, rn, imm12) { 返回 0x91000000|((imm12&0xFFF)<<10)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_sub_imm(rd, rn, imm12) { 返回 0xD1000000|((imm12&0xFFF)<<10)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_subs_imm(rd, rn, imm12){ 返回 0xF1000000|((imm12&0xFFF)<<10)|((rn&31)<<5)|(rd&31) }

// 逻辑运算
函数 指令编码_编码_and_reg(rd, rn, rm) { 返回 0x8A000000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_orr_reg(rd, rn, rm) { 返回 0xAA000000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_eor_reg(rd, rn, rm) { 返回 0xCA000000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_orn_reg(rd, rn, rm) { 返回 0xAA200000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }

// 移动/移位
函数 指令编码_编码_mov_reg(rd, rm) { 返回 0xAA0003E0|((rm&31)<<16)|(rd&31) }
函数 指令编码_编码_movz(rd, imm16, hw) { 返回 0xD2800000|((hw&3)<<21)|((imm16&0xFFFF)<<5)|(rd&31) }
函数 指令编码_编码_movk(rd, imm16, hw) { 返回 0xF2800000|((hw&3)<<21)|((imm16&0xFFFF)<<5)|(rd&31) }
函数 指令编码_编码_movn(rd, imm16, hw) { 返回 0x92800000|((hw&3)<<21)|((imm16&0xFFFF)<<5)|(rd&31) }
函数 指令编码_编码_lsl_reg(rd, rn, rm) { 返回 0x9AC02000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_lsr_reg(rd, rn, rm) { 返回 0x9AC02400|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_asr_reg(rd, rn, rm) { 返回 0x9AC02800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }

// 比较与条件选择
函数 指令编码_编码_cmp_reg(rn, rm) { 返回 0xEB00001F|((rm&31)<<16)|((rn&31)<<5) }
函数 指令编码_编码_cmp_imm(rn, imm12) { 返回 指令编码_编码_subs_imm(31,rn,imm12) }
函数 指令编码_编码_csel(rd, rn, rm, cc) { 返回 0x9A800000|((rm&31)<<16)|((cc&15)<<12)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_csinc(rd, rn, rm, cc) { 返回 0x9A800400|((rm&31)<<16)|((cc&15)<<12)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_mvn(rd, rm) { 返回 指令编码_编码_orn_reg(rd,31,rm) }
函数 指令编码_编码_neg(rd, rm) { 返回 指令编码_编码_sub_reg(rd,31,rm) }

// 分支指令
函数 指令编码_编码_b(偏移) { 返回 0x14000000|((偏移/4)&0x3FFFFFF) }
函数 指令编码_编码_bl(偏移) { 返回 0x94000000|((偏移/4)&0x3FFFFFF) }
函数 指令编码_编码_b_cond(cc, 偏移) { 返回 0x54000000|((((偏移/4)&0x7FFFF)<<5)|(cc&0xF)) }
函数 指令编码_编码_br(rn) { 返回 0xD61F0000|((rn&31)<<5) }
函数 arm64_编码_blr(rn) { 返回 0xD63F0000|((rn&31)<<5) }
函数 arm64_编码_ret(rn) { 返回 0xD65F0000|((rn&31)<<5) }
函数 指令编码_编码_cbz(rt, 偏移)
{ 返回 0xB4000000|(((偏移/4)&0x7FFFF)<<5)|(rt&31) }
函数 指令编码_编码_cbnz(rt, 偏移) { 返回 0xB5000000|(((偏移/4)&0x7FFFF)<<5)|(rt&31) }

// 加载/存储
函数 指令编码_编码_ldr_imm(rt, rn, imm) { 返回 0xF9400000|(((imm/8)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
函数 指令编码_编码_str_imm(rt, rn, imm) { 返回 0xF9000000|(((imm/8)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
函数 指令编码_编码_ldr_reg(rt, rn, rm) { 返回 0xF8606800|((rm&31)<<16)|((rn&31)<<5)|(rt&31) }
函数 指令编码_编码_str_reg(rt, rn, rm) { 返回 0xF8206800|((rm&31)<<16)|((rn&31)<<5)|(rt&31) }
函数 指令编码_编码_ldrb_imm(rt, rn, imm) { 返回 0x39400000|((imm&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
函数 指令编码_编码_strb_imm(rt, rn, imm) { 返回 0x39000000|((imm&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }

// STP/LDP (栈帧序言/尾声)
函数 指令编码_编码_stp_pre(rt, rt2, rn, imm) { 返回 0xA9800000|((((imm/8)&0x7F)<<15)|((rt2&31)<<10)|((rn&31)<<5)|(rt&31))
}
函数 指令编码_编码_ldp_post(rt, rt2, rn, imm) { 返回 0xA8C00000|((((imm/8)&0x7F)<<15)|((rt2&31)<<10)|((rn&31)<<5)|(rt&31))
}
函数 指令编码_编码_stp_off(rt, rt2, rn, imm) { 返回 0xA9000000|((((imm/8)&0x7F)<<15)|((rt2&31)<<10)|((rn&31)<<5)|(rt&31))
}
函数 指令编码_编码_ldp_off(rt, rt2, rn, imm) { 返回 0xA9400000|((((imm/8)&0x7F)<<15)|((rt2&31)<<10)|((rn&31)<<5)|(rt&31))
}

// 系统指令
函数 arm64_编码_nop() { 返回 0xD503201F }
函数 指令编码_编码_svc(imm) { 返回 0xD4000001|((imm&0xFFFF)<<5) }
函数 指令编码_编码_brk(imm) { 返回 0xD4200000|((imm&0xFFFF)<<5) }

// ADRP Xd, imm — PC相对页地址
函数 指令编码_编码_adrp(rd, immhi, immlo) { 返回 0x90000000|((immlo&3)<<29)|((immhi&0x7FFFF)<<5)|(rd&31)
}

// 扩展指令 — 乘加/乘减/半字/带标志加/屏障
// MADD Xd,Xn,Xm,Xa — Xd = Xa + Xn*Xm
函数 指令编码_编码_madd(rd, rn, rm, ra) { 返回 0x9B000000|((rm&31)<<16)|((ra&31)<<10)|((rn&31)<<5)|(rd&31) }
// MSUB Xd,Xn,Xm,Xa — Xd = Xa - Xn*Xm
函数 指令编码_编码_msub(rd, rn, rm, ra) { 返回 0x9B008000|((rm&31)<<16)|((ra&31)<<10)|((rn&31)<<5)|(rd&31) }
// ADDS Xd,Xn,Xm (设置标志)
函数 指令编码_编码_adds_reg(rd, rn, rm) { 返回 0xAB000000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// ADDS Xd,Xn,#imm12
函数 指令编码_编码_adds_imm(rd, rn, imm12) { 返回 0xB1000000|((imm12&0xFFF)<<10)|((rn&31)<<5)|(rd&31) }
// LDRH Wt,[Xn,#imm] — 半字加载(16位)
函数 指令编码_编码_ldrh_imm(rt, rn, imm) { 返回 0x79400000|(((imm/2)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
// STRH Wt,[Xn,#imm] — 半字存储
函数 指令编码_编码_strh_imm(rt, rn, imm) { 返回 0x79000000|(((imm/2)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
// LDRW Wt,[Xn,#imm] — 字加载(32位)
函数 指令编码_编码_ldr_w_imm(rt, rn, imm) { 返回 0xB9400000|(((imm/4)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
// STRW Wt,[Xn,#imm] — 字存储
函数 指令编码_编码_str_w_imm(rt, rn, imm) { 返回 0xB9000000|(((imm/4)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
// DMB — 数据内存屏障
函数 指令编码_编码_dmb(选项) { 返回 0xD50330BF|((选项&0xF)<<8) }
// DSB — 数据同步屏障
函数 指令编码_编码_dsb(选项) { 返回 0xD503309F|((选项&0xF)<<8) }
// ISB — 指令同步屏障
函数 指令编码_编码_isb() { 返回 0xD5033FDF }
// 屏障选项常量
定义 屏障_SY=15 定义 屏障_ISH=11 定义 屏障_OSH=3
// TST Xn,Xm = ANDS XZR,Xn,Xm
函数 指令编码_编码_tst_reg(rn, rm) { 返回 0xEA00001F|((rm&31)<<16)|((rn&31)<<5) }
// CLZ Xd,Xn — 前导零计数
函数 指令编码_编码_clz(rd, rn) { 返回 0xDAC01000|((rn&31)<<5)|(rd&31) }
// REV Xd,Xn — 字节反转
函数 指令编码_编码_rev(rd, rn) { 返回 0xDAC00C00|((rn&31)<<5)|(rd&31) }
// CSET Xd,cc = CSINC Xd,XZR,XZR,invert(cc)
函数 指令编码_编码_cset(rd, cc) { 返回 指令编码_编码_csinc(rd,31,31,cc^1) }

// 浮点运算 (标量双精度 D寄存器)

// FADD Dd,Dn,Dm
函数 指令编码_编码_fadd_d(rd, rn, rm) { 返回 0x1E602800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// FSUB Dd,Dn,Dm
函数 指令编码_编码_fsub_d(rd, rn, rm) { 返回 0x1E603800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// FMUL Dd,Dn,Dm
函数 指令编码_编码_fmul_d(rd, rn, rm) { 返回 0x1E600800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// FDIV Dd,Dn,Dm
函数 指令编码_编码_fdiv_d(rd, rn, rm) { 返回 0x1E601800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// FSQRT Dd,Dn
函数 指令编码_编码_fsqrt_d(rd, rn) { 返回 0x1E61C000|((rn&31)<<5)|(rd&31) }
// FABS Dd,Dn
函数 指令编码_编码_fabs_d(rd, rn) { 返回 0x1E60C000|((rn&31)<<5)|(rd&31) }
// FNEG Dd,Dn
函数 指令编码_编码_fneg_d(rd, rn) { 返回 0x1E614000|((rn&31)<<5)|(rd&31) }
// FCMP Dn,Dm — 设置NZCV标志
函数 指令编码_编码_fcmp_d(rn, rm) { 返回 0x1E602000|((rm&31)<<16)|((rn&31)<<5) }
// FMADD Dd,Dn,Dm,Da — Dd = Da + Dn*Dm
函数 指令编码_编码_fmadd_d(rd, rn, rm, ra) { 返回 0x1F400000|((rm&31)<<16)|((ra&31)<<10)|((rn&31)<<5)|(rd&31) }
// FMSUB Dd,Dn,Dm,Da — Dd = Da - Dn*Dm
函数 指令编码_编码_fmsub_d(rd, rn, rm, ra) { 返回 0x1F408000|((rm&31)<<16)|((ra&31)<<10)|((rn&31)<<5)|(rd&31) }
// FMOV Dd,Dn
函数 指令编码_编码_fmov_d(rd, rn) { 返回 0x1E604000|((rn&31)<<5)|(rd&31) }
// FMOV Xd,Dn — 浮点→通用寄存器
函数 指令编码_编码_fmov_to_x(rd, rn) { 返回 0x9E660000|((rn&31)<<5)|(rd&31) }
// FMOV Dd,Xn — 通用→浮点寄存器
函数 指令编码_编码_fmov_from_x(rd, rn) { 返回 0x9E670000|((rn&31)<<5)|(rd&31) }
// SCVTF Dd,Xn — 有符号整数→双精度
函数 指令编码_编码_scvtf_dx(rd, rn) { 返回 0x9E620000|((rn&31)<<5)|(rd&31) }
// FCVTZS Xd,Dn — 双精度→有符号整数(截断)
函数 指令编码_编码_fcvtzs_xd(rd, rn) { 返回 0x9E780000|((rn&31)<<5)|(rd&31) }

// 单精度浮点
函数 指令编码_编码_fadd_s(rd, rn, rm) { 返回 0x1E202800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_fsub_s(rd, rn, rm) { 返回 0x1E203800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_fmul_s(rd, rn, rm) { 返回 0x1E200800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 指令编码_编码_fdiv_s(rd, rn, rm) { 返回 0x1E201800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// FCVT Dd,Sn — 单精度→双精度
函数 指令编码_编码_fcvt_ds(rd, rn) { 返回 0x1E22C000|((rn&31)<<5)|(rd&31) }
// FCVT Sd,Dn — 双精度→单精度
函数 指令编码_编码_fcvt_sd(rd, rn) { 返回 0x1E624000|((rn&31)<<5)|(rd&31) }

// 浮点加载/存储
// LDR Dt,[Xn,#imm] — 加载双精度
函数 指令编码_编码_ldr_d_imm(rt, rn, imm) { 返回 0xFD400000|(((imm/8)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
// 字符串 Dt,[Xn,#imm] — 存储双精度
函数 指令编码_编码_str_d_imm(rt, rn, imm) { 返回 0xFD000000|(((imm/8)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
// LDR St,[Xn,#imm] — 加载单精度
函数 指令编码_编码_ldr_s_imm(rt, rn, imm) { 返回 0xBD400000|(((imm/4)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
// 字符串 St,[Xn,#imm] — 存储单精度
函数 指令编码_编码_str_s_imm(rt, rn, imm) { 返回 0xBD000000|(((imm/4)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }

// NEON/SIMD 向量指令 (AI核心)

// NEON寄存器编号: V0-V31, 用作128位(Q)或64位(D)

// FADD Vd.4S, Vn.4S, Vm.4S — 4路单精度并行加法
函数 指令编码_编码_neon_fadd_4s(rd, rn, rm) { 返回 0x4E20D400|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// FMUL Vd.4S, Vn.4S, Vm.4S
函数 指令编码_编码_neon_fmul_4s(rd, rn, rm) { 返回 0x6E20DC00|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// FSUB Vd.4S, Vn.4S, Vm.4S
函数 指令编码_编码_neon_fsub_4s(rd, rn, rm) { 返回 0x4EA0D400|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// FDIV Vd.4S, Vn.4S, Vm.4S
函数 指令编码_编码_neon_fdiv_4s(rd, rn, rm) { 返回 0x6E20FC00|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }

// FADD Vd.2D, Vn.2D, Vm.2D — 2路双精度并行加法
函数 指令编码_编码_neon_fadd_2d(rd, rn, rm) { 返回 0x4E60D400|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// FMUL Vd.2D, Vn.2D, Vm.2D
函数 指令编码_编码_neon_fmul_2d(rd, rn, rm) { 返回 0x6E60DC00|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }

// FMLA Vd.4S, Vn.4S, Vm.4S — 融合乘加(AI核心: d += n*m)
函数 指令编码_编码_neon_fmla_4s(rd, rn, rm) { 返回 0x4E20CC00|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// FMLA Vd.2D, Vn.2D, Vm.2D
函数 指令编码_编码_neon_fmla_2d(rd, rn, rm) { 返回 0x4E60CC00|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }

// ADD Vd.2D, Vn.2D, Vm.2D — 整数向量加法
函数 指令编码_编码_neon_add_2d(rd, rn, rm) { 返回 0x4EE08400|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// SUB Vd.2D, Vn.2D, Vm.2D
函数 指令编码_编码_neon_sub_2d(rd, rn, rm) { 返回 0x6EE08400|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// AND Vd.16B, Vn.16B, Vm.16B — 向量按位与
函数 指令编码_编码_neon_and(rd, rn, rm) { 返回 0x4E201C00|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// ORR Vd.16B, Vn.16B, Vm.16B
函数 指令编码_编码_neon_orr(rd, rn, rm) { 返回 0x4EA01C00|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// EOR Vd.16B, Vn.16B, Vm.16B — 向量异或
函数 指令编码_编码_neon_eor(rd, rn, rm) { 返回 0x6E201C00|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }

// LD1 {Vt.16B}, [Xn] — 向量加载
函数 指令编码_编码_ld1_16b(rt, rn) { 返回 0x4C407000|((rn&31)<<5)|(rt&31) }
// ST1 {Vt.16B}, [Xn] — 向量存储
函数 指令编码_编码_st1_16b(rt, rn) { 返回 0x4C007000|((rn&31)<<5)|(rt&31) }
// DUP Vd.4S, Xn — 标量广播到4个float
函数 指令编码_编码_dup_4s_x(rd, rn) { 返回 0x4E040C00|((rn&31)<<5)|(rd&31) }
// MOVI Vd.4S, #0 — 向量清零
函数 指令编码_编码_movi_zero(rd) { 返回 0x4F000400|(rd&31) }
// FMAX Vd.4S, Vn.4S, Vm.4S — 向量最大值
函数 指令编码_编码_neon_fmax_4s(rd, rn, rm) { 返回 0x4E20F400|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// FMIN Vd.4S, Vn.4S, Vm.4S — 向量最小值
函数 指令编码_编码_neon_fmin_4s(rd, rn, rm) { 返回 0x4EA0F400|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }

// 原子操作 (ARMv8.1-LSE)

// LDXR Xt, [Xn] — 独占加载
函数 指令编码_编码_ldxr(rt, rn) { 返回 0xC85F7C00|((rn&31)<<5)|(rt&31) }
// STXR Ws, Xt, [Xn] — 独占存储 (Ws=状态)
函数 指令编码_编码_stxr(rs, rt, rn) { 返回 0xC8007C00|((rs&31)<<16)|((rn&31)<<5)|(rt&31) }
// CAS Xs, Xt, [Xn] — 比较并交换 (ARMv8.1)
函数 指令编码_编码_cas(rs, rt, rn) { 返回 0xC8A07C00|((rs&31)<<16)|((rn&31)<<5)|(rt&31) }
// LDADD Xs, Xt, [Xn] — 原子加 (ARMv8.1)
函数 指令编码_编码_ldadd(rs, rt, rn) { 返回 0xF8200000|((rs&31)<<16)|((rn&31)<<5)|(rt&31) }
// SWP Xs, Xt, [Xn] — 原子交换 (ARMv8.1)
函数 指令编码_编码_swp(rs, rt, rn) { 返回 0xF8208000|((rs&31)<<16)|((rn&31)<<5)|(rt&31) }

// 扩展加载/存储

// LDRSW Xt, [Xn, #imm] — 符号扩展字加载
函数 指令编码_编码_ldrsw_imm(rt, rn, imm) { 返回 0xB9800000|(((imm/4)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
// LDRSB Xt, [Xn, #imm] — 符号扩展字节加载
函数 指令编码_编码_ldrsb_x(rt, rn, imm) { 返回 0x39800000|((imm&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
// LDRSH Xt, [Xn, #imm] — 符号扩展半字加载
函数 指令编码_编码_ldrsh_x(rt, rn, imm) { 返回 0x79800000|(((imm/2)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
// LDR Xt, [Xn, #imm]! — 前索引
函数 指令编码_编码_ldr_pre(rt, rn, imm) { 返回 0xF8400C00|((imm&0x1FF)<<12)|((rn&31)<<5)|(rt&31) }
// 字符串 Xt, [Xn, #imm]! — 前索引
函数 指令编码_编码_str_pre(rt, rn, imm) { 返回 0xF8000C00|((imm&0x1FF)<<12)|((rn&31)<<5)|(rt&31) }
// LDR Xt, [Xn], #imm — 后索引
函数 指令编码_编码_ldr_post(rt, rn, imm) { 返回 0xF8400400|((imm&0x1FF)<<12)|((rn&31)<<5)|(rt&31) }
// 字符串 Xt, [Xn], #imm — 后索引
函数 指令编码_编码_str_post(rt, rn, imm) { 返回 0xF8000400|((imm&0x1FF)<<12)|((rn&31)<<5)|(rt&31) }

// 条件比较 + 更多条件选择

// CCMP Xn, Xm, #nzcv, cond — 条件比较(寄存器)
函数 指令编码_编码_ccmp_reg(rn, rm, nzcv, cc) { 返回 0xFA400000|((rm&31)<<16)|((cc&15)<<12)|((rn&31)<<5)|(nzcv&15) }
// CCMP Xn, #imm5, #nzcv, cond — 条件比较(立即数)
函数 指令编码_编码_ccmp_imm(rn, imm5, nzcv, cc) { 返回 0xFA400800|((imm5&31)<<16)|((cc&15)<<12)|((rn&31)<<5)|(nzcv&15) }
// CSINV Xd,Xn,Xm,cc — 条件反转选择
函数 指令编码_编码_csinv(rd, rn, rm, cc) { 返回 0xDA800000|((rm&31)<<16)|((cc&15)<<12)|((rn&31)<<5)|(rd&31) }
// CSNEG Xd,Xn,Xm,cc — 条件取负选择
函数 指令编码_编码_csneg(rd, rn, rm, cc) { 返回 0xDA800400|((rm&31)<<16)|((cc&15)<<12)|((rn&31)<<5)|(rd&31) }
// CINV Xd,Xn,cc = CSINV Xd,Xn,Xn,invert(cc)
函数 指令编码_编码_cinv(rd, rn, cc) { 返回 指令编码_编码_csinv(rd,rn,rn,cc^1) }
// CNEG Xd,Xn,cc = CSNEG Xd,Xn,Xn,invert(cc)
函数 指令编码_编码_cneg(rd, rn, cc) { 返回 指令编码_编码_csneg(rd,rn,rn,cc^1) }

// 位域操作

// UBFM Xd, Xn, immr, imms — 无符号位域移动
函数 指令编码_编码_ubfm(rd, rn, immr, imms) { 返回 0xD3400000|((immr&63)<<16)|((imms&63)<<10)|((rn&31)<<5)|(rd&31) }
// SBFM Xd, Xn, immr, imms — 有符号位域移动
函数 指令编码_编码_sbfm(rd, rn, immr, imms) { 返回 0x93400000|((immr&63)<<16)|((imms&63)<<10)|((rn&31)<<5)|(rd&31) }
// BFM Xd, Xn, immr, imms — 位域移动
函数 指令编码_编码_bfm(rd, rn, immr, imms) { 返回 0xB3400000|((immr&63)<<16)|((imms&63)<<10)|((rn&31)<<5)|(rd&31) }
// EXTR Xd, Xn, Xm, lsb — 位提取(双寄存器旋转)
函数 指令编码_编码_extr(rd, rn, rm, lsb) { 返回 0x93C00000|((rm&31)<<16)|((lsb&63)<<10)|((rn&31)<<5)|(rd&31) }
// SXTB Xd, Wn = SBFM Xd, Xn, 0, 7
函数 指令编码_编码_sxtb(rd, rn) { 返回 指令编码_编码_sbfm(rd,rn,0,7) }
// SXTH Xd, Wn = SBFM Xd, Xn, 0, 15
函数 指令编码_编码_sxth(rd, rn) { 返回 指令编码_编码_sbfm(rd,rn,0,15) }
// SXTW Xd, Wn = SBFM Xd, Xn, 0, 31
函数 指令编码_编码_sxtw(rd, rn) { 返回 指令编码_编码_sbfm(rd,rn,0,31) }
// UXTB Xd, Wn = UBFM Xd, Xn, 0, 7
函数 指令编码_编码_uxtb(rd, rn) { 返回 指令编码_编码_ubfm(rd,rn,0,7) }
// UXTH Xd, Wn = UBFM Xd, Xn, 0, 15
函数 指令编码_编码_uxth(rd, rn) { 返回 指令编码_编码_ubfm(rd,rn,0,15) }
// ROR Xd,Xn,Xm
函数 指令编码_编码_ror_reg(rd, rn, rm) { 返回 0x9AC02C00|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
// RBIT Xd,Xn — 位反转
函数 指令编码_编码_rbit(rd, rn) { 返回 0xDAC00000|((rn&31)<<5)|(rd&31) }
// CLS Xd,Xn — 前导符号位计数
函数 指令编码_编码_cls(rd, rn) { 返回 0xDAC01400|((rn&31)<<5)|(rd&31) }
// REV16 Xd,Xn — 半字内字节反转
函数 指令编码_编码_rev16(rd, rn) { 返回 0xDAC00400|((rn&31)<<5)|(rd&31) }
// REV32 Xd,Xn — 字内字节反转
函数 指令编码_编码_rev32(rd, rn) { 返回 0xDAC00800|((rn&31)<<5)|(rd&31) }

// MRS/MSR 系统寄存器

// MRS Xt, sysreg — 读系统寄存器
函数 指令编码_编码_mrs(rt, sysreg) { 返回 0xD5300000|((sysreg&0xFFFF)<<5)|(rt&31) }
// MSR sysreg, Xt — 写系统寄存器
函数 指令编码_编码_msr(sysreg, rt) { 返回 0xD5100000|((sysreg&0xFFFF)<<5)|(rt&31) }
// 系统寄存器编号
定义 系统寄存器_标志位 = 0xDA10
定义 系统寄存器_浮点控制 = 0xDA20
定义 系统寄存器_浮点状态 = 0xDA21
定义 系统寄存器_线程指针 = 0xDE82
定义 系统寄存器_计数频率 = 0xDF00
定义 系统寄存器_虚拟计数 = 0xDF02

// 加密指令 (ARMv8 Crypto)

// AESE Vd.16B, Vn.16B — AES单轮加密
函数 指令编码_编码_aese(rd, rn) { 返回 0x4E284800|((rn&31)<<5)|(rd&31) }
// AESD Vd.16B, Vn.16B — AES单轮解密
函数 指令编码_编码_aesd(rd, rn) { 返回 0x4E285800|((rn&31)<<5)|(rd&31) }
// AESMC Vd.16B, Vn.16B — AES列混合
函数 指令编码_编码_aesmc(rd, rn) { 返回 0x4E286800|((rn&31)<<5)|(rd&31) }
// SHA256H Qd, Qn, Vm.4S — SHA-256 哈希
函数 指令编码_编码_sha256h(rd, rn, rm) { 返回 0x5E004000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }

// 更多伪指令/便利函数

// MOV Xd, #imm64 — 加载64位立即数(最多4条movz/movk)
// 返回指令列表
函数 指令编码_加载64(rd, val) { 定义 可变 结果 = []
 结果 = 追加(结果, 指令编码_编码_movz(rd,  val & 0xFFFF, 0))
 如果 (val > 0xFFFF) {
 结果 = 追加(结果, 指令编码_编码_movk(rd, (val >> 16) & 0xFFFF, 1))
 }
 如果 (val > 0xFFFFFFFF) {
 结果 = 追加(结果, 指令编码_编码_movk(rd, (val >> 32) & 0xFFFF, 2))
 }
 如果 (val > 0xFFFFFFFFFFFF) {
 结果 = 追加(结果, 指令编码_编码_movk(rd, (val >> 48) & 0xFFFF, 3))
 }
 返回 结果
}

// 函数序言: STP X29,X30,[SP,#-framesize]! ; MOV X29,SP
函数 指令编码_序言(帧大小) { 定义 可变 指令 = []
 指令 = 追加(指令, 指令编码_编码_stp_pre(FP, LR, SP, 0 - 帧大小))
 指令 = 追加(指令, 指令编码_编码_mov_reg(FP, SP))
 返回 指令
}

// 函数尾声: MOV SP,X29 ; LDP X29,X30,[SP],#framesize ; RET
函数 指令编码_尾声(帧大小) { 定义 可变 指令 = []
 指令 = 追加(指令, 指令编码_编码_mov_reg(SP, FP))
 指令 = 追加(指令, 指令编码_编码_ldp_post(FP, LR, SP, 帧大小))
 指令 = 追加(指令, arm64_编码_ret(LR))
 返回 指令
}

// TBNZ Xt, #bit, offset — 测试位非零跳转
函数 指令编码_编码_tbnz(rt, bit, 偏移) { 返回 0x37000000|((bit&63)<<19)|(((偏移/4)&0x3FFF)<<5)|(rt&31) }
// TBZ Xt, #bit, offset — 测试位为零跳转
函数 指令编码_编码_tbz(rt, bit, 偏移) { 返回 0x36000000|((bit&63)<<19)|(((偏移/4)&0x3FFF)<<5)|(rt&31) }

// ADR Xd, offset — PC相对地址(±1MB)
函数 指令编码_编码_adr(rd, 偏移) { 定义 immlo = 偏移 & 3
 定义 immhi = (偏移 >> 2) & 0x7FFFF
 返回 0x10000000|(immlo<<29)|(immhi<<5)|(rd&31)
}

// HLT #imm — 停机(调试)
函数 指令编码_编码_hlt(imm) { 返回 0xD4400000|((imm&0xFFFF)<<5) }
// WFE — 等待事件
函数 指令编码_编码_wfe() { 返回 0xD503205F }
// WFI — 等待中断
函数 指令编码_编码_wfi() { 返回 0xD503207F }
// SEV — 发送事件
函数 指令编码_编码_sev() { 返回 0xD503209F }
// YIELD — 让出
函数 指令编码_编码_yield() { 返回 0xD503203F }

// NEON/ASIMD 向量指令 (128位 = 4×float / 2×double / 16×byte)

// FADD Vd.4S, Vn.4S, Vm.4S — 4路单精度加法
函数 指令编码_编码_fadd_4s(d, n, m) { 返回 0x4E20D400|((m&31)<<16)|((n&31)<<5)|(d&31) }
// FSUB Vd.4S, Vn.4S, Vm.4S
函数 指令编码_编码_fsub_4s(d, n, m) { 返回 0x4EA0D400|((m&31)<<16)|((n&31)<<5)|(d&31) }
// FMUL Vd.4S, Vn.4S, Vm.4S
函数 指令编码_编码_fmul_4s(d, n, m) { 返回 0x6E20DC00|((m&31)<<16)|((n&31)<<5)|(d&31) }
// FDIV Vd.4S, Vn.4S, Vm.4S
函数 指令编码_编码_fdiv_4s(d, n, m) { 返回 0x6E20FC00|((m&31)<<16)|((n&31)<<5)|(d&31) }
// FSQRT Vd.4S, Vn.4S
函数 指令编码_编码_fsqrt_4s(d, n) { 返回 0x6EA1F800|((n&31)<<5)|(d&31) }
// FMAX/FMIN Vd.4S
函数 指令编码_编码_fmax_4s(d, n, m) { 返回 0x4E20F400|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_fmin_4s(d, n, m) { 返回 0x4EA0F400|((m&31)<<16)|((n&31)<<5)|(d&31) }
// FABS Vd.4S, Vn.4S
函数 指令编码_编码_fabs_4s(d, n) { 返回 0x4EA0F800|((n&31)<<5)|(d&31) }
// FNEG Vd.4S, Vn.4S
函数 指令编码_编码_fneg_4s(d, n) { 返回 0x6EA0F800|((n&31)<<5)|(d&31) }
// FMLA Vd.4S, Vn.4S, Vm.4S — 融合乘加(智能推理核心)
函数 指令编码_编码_fmla_4s(d, n, m) { 返回 0x4E20CC00|((m&31)<<16)|((n&31)<<5)|(d&31) }
// FMLS Vd.4S — 融合乘减
函数 指令编码_编码_fmls_4s(d, n, m) { 返回 0x4EA0CC00|((m&31)<<16)|((n&31)<<5)|(d&31) }
// FRECPE Vd.4S — 近似倒数
函数 指令编码_编码_frecpe_4s(d, n) { 返回 0x4EA1D800|((n&31)<<5)|(d&31) }
// FRSQRTE Vd.4S — 近似倒数平方根
函数 指令编码_编码_frsqrte_4s(d, n) { 返回 0x6EA1D800|((n&31)<<5)|(d&31) }
// FCVTZS Vd.4S, Vn.4S — float→int截断
函数 指令编码_编码_fcvtzs_4s(d, n) { 返回 0x4EA1B800|((n&31)<<5)|(d&31) }
// SCVTF Vd.4S, Vn.4S — int→float
函数 指令编码_编码_scvtf_4s(d, n) { 返回 0x4E21D800|((n&31)<<5)|(d&31) }
// FCMEQ/FCMGT/FCMGE Vd.4S
函数 指令编码_编码_fcmeq_4s(d, n, m) { 返回 0x4E20E400|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_fcmgt_4s(d, n, m) { 返回 0x6EA0E400|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_fcmge_4s(d, n, m) { 返回 0x6E20E400|((m&31)<<16)|((n&31)<<5)|(d&31) }

// 双精度向量 (2×double)
函数 指令编码_编码_fadd_2d(d, n, m) { 返回 0x4E60D400|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_fsub_2d(d, n, m) { 返回 0x4EE0D400|((m&31)<<16)|((n&31)<<5)|(d&31) }

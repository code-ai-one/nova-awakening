导入("./类型定义.nova")
导入("./错误码.nova")
导入("./字符串替换.nova")
导入("./哈希整数.nova")
导入("./思维链.nova")
导入("./工具注册表.nova")
导入("./创建甲.nova")
导入("../稳态/虚驱块中断.nova")
导入("./整数转字符串.nova")
导入("../执行/底层内存操.nova")

定义 权限_无 = 0
定义 权限_读 = 1
定义 权限_写 = 2
定义 权限_执行 = 4
定义 权限_网络 = 8
定义 权限_全部 = 15
定义 最大结果缓存 = 128

结构 工具描述 {
    名称,
    说明,
    参数数,
    参数名列表,
    权限需求,
    超时毫秒,
    调用次数,
    累计耗时,
    最后调用时间,
    已启用,
}

结构 结果缓存项 {
    工具名哈希,
    参数哈希,
    结果,
    时间戳,
    有效期,
}

定义 可变 结果缓存表 = 0
定义 可变 结果缓存数 = 0

函数 Nova推理执行_初始化() {
    工具注册表 = []
    智能体列表 = []
    智能体消息队列 = []
    Nova推理执行_会话列表 = []
    结果缓存表 = 堆_分配(最大结果缓存 * 8)
    内存_清零(结果缓存表, 最大结果缓存 * 8)
    结果缓存数 = 0

    工具注册表_注册详("ui_browse", "扫描当前页面所有UI元素", 0, [], 权限_读, 5000)
    工具注册表_注册详("ui_click", "点击指定文本的UI元素", 1, ["目标文本"], 权限_执行, 3000)
    工具注册表_注册详("ui_type", "在输入框中输入文本", 1, ["输入内容"], 权限_写, 3000)
    工具注册表_注册详("ui_read", "读取页面文本内容", 0, [], 权限_读, 5000)
    工具注册表_注册详("ui_scroll", "滚动页面", 1, ["方向"], 权限_执行, 2000)
    工具注册表_注册详("ui_wait", "等待元素出现", 1, ["等待目标"], 权限_读, 10000)
    工具注册表_注册详("file_read", "读取文件内容", 1, ["文件路径"], 权限_读, 5000)
    工具注册表_注册详("file_write", "写入文件内容", 2, ["文件路径", "内容"], 权限_写, 5000)
    工具注册表_注册详("终端_exec", "执行系统命令", 1, ["命令"], 权限_执行, 30000)
    工具注册表_注册详("net_request", "发送网络请求", 2, ["URL", "方法"], 权限_网络, 15000)
    工具注册表_注册详("ai_infer", "调用AI推理", 1, ["输入"], 权限_执行, 60000)
    工具注册表_注册详("memory_store", "存储到记忆", 2, ["键", "值"], 权限_写, 2000)
    工具注册表_注册详("memory_recall", "从记忆中检索", 1, ["查询"], 权限_读, 3000)

    智能体_注册("规划者", "planner", ["ai_infer", "memory_recall"])
    智能体_注册("执行者-UI", "executor", ["ui_browse", "ui_click", "ui_type", "ui_read", "ui_scroll"])
    智能体_注册("执行者-系统", "executor", ["file_read", "file_write", "终端_exec", "net_request"])
    智能体_注册("评审者", "critic", ["ai_infer", "memory_recall"])

    内核信息("Nova推理执行引擎: 初始化完成 工具=" + 整数转字符串(计数(工具注册表)) +
             " 智能体=" + 整数转字符串(计数(智能体列表)))
}

函数 工具注册表_注册详(名称, 说明, 参数数, 参数名, 权限, 超时) {
    工具注册表_注册(名称, 说明, 参数数, 参数名)
    定义 索引 = 计数(工具注册表) - 1
    如果 (索引 >= 0) {
        定义 工具 = 工具注册表[索引]
        工具.权限需求 = 权限
        工具.超时毫秒 = 超时
        工具.已启用 = 真
    }
}

函数 工具_验证权限(工具名, 当前权限) {
    定义 可变 索引 = 0
    当 (索引 < 计数(工具注册表)) {
        定义 工具 = 工具注册表[索引]
        如果 (工具.名称 == 工具名) {
            返回 (当前权限 & 工具.权限需求) == 工具.权限需求
        }
        索引 = 索引 + 1
    }
    返回 假
}

函数 工具_查找(工具名) {
    定义 可变 索引 = 0
    当 (索引 < 计数(工具注册表)) {
        如果 (工具注册表[索引].名称 == 工具名) { 返回 工具注册表[索引] }
        索引 = 索引 + 1
    }
    返回 0
}

函数 工具_启用(工具名) {
    定义 工具 = 工具_查找(工具名)
    如果 (工具 != 0) { 工具.已启用 = 真 }
}

函数 工具_禁用(工具名) {
    定义 工具 = 工具_查找(工具名)
    如果 (工具 != 0) { 工具.已启用 = 假 }
}

函数 结果缓存_查找(工具名哈希, 参数哈希) {
    定义 可变 索引 = 0
    当 (索引 < 结果缓存数) {
        定义 项 = 内存_读64(结果缓存表 + 索引 * 8)
        如果 (项 != 0 && 项.工具名哈希 == 工具名哈希 && 项.参数哈希 == 参数哈希) {
            返回 项.结果
        }
        索引 = 索引 + 1
    }
    返回 0
}

函数 结果缓存_存储(工具名哈希, 参数哈希, 结果, 有效期) {
    如果 (结果缓存数 >= 最大结果缓存) {
        结果缓存数 = 0
    }
    定义 项 = 堆_分配(结果缓存项)
    项.工具名哈希 = 工具名哈希
    项.参数哈希 = 参数哈希
    项.结果 = 结果
    项.时间戳 = 平台_获取时间()
    项.有效期 = 有效期
    内存_写64(结果缓存表 + 结果缓存数 * 8, 项)
    结果缓存数 = 结果缓存数 + 1
}

函数 工具_执行管线(工具名, 参数, 当前权限) {
    如果 (!工具_验证权限(工具名, 当前权限)) { 返回 错误码_权限不足 }
    定义 工具 = 工具_查找(工具名)
    如果 (工具 == 0) { 返回 错误码_未找到 }
    如果 (!工具.已启用) { 返回 错误码_已禁用 }
    定义 缓存结果 = 结果缓存_查找(哈希_字符串(工具名), 哈希_参数(参数))
    如果 (缓存结果 != 0) { 返回 缓存结果 }
    工具.调用次数 = 工具.调用次数 + 1
    工具.最后调用时间 = 平台_获取时间()
    定义 开始 = 平台_获取高精度时间()
    定义 结果 = 工具_原生调用(工具名, 参数)
    工具.累计耗时 = 工具.累计耗时 + (平台_获取高精度时间() - 开始)
    结果缓存_存储(哈希_字符串(工具名), 哈希_参数(参数), 结果, 5000)
    返回 结果
}

函数 工具链_执行(工具链, 输入, 当前权限) {
    定义 可变 当前输入 = 输入
    定义 可变 索引 = 0
    当 (索引 < 计数(工具链)) {
        定义 步骤 = 工具链[索引]
        定义 结果 = 工具_执行管线(步骤.工具名, 当前输入, 当前权限)
        如果 (结果 < 0) { 返回 结果 }
        当前输入 = 结果
        索引 = 索引 + 1
    }
    返回 当前输入
}

函数 字符串包含_Nova推理执行(文本, 子串) { 返回 字符串_包含(文本, 子串) }

函数 Nova推理执行_完整统计() {
    返回 [Nova推理执行_总完成数, Nova推理执行_总失败数, 计数(Nova推理执行_会话列表),
           计数(智能体列表), 计数(工具注册表), 工具_调用总数,
           CoT_总链数, 计数(智能体消息队列), 结果缓存数]
}

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../感知/资源响应创.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../外联/地址解析辅.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/时钟中枢.nova")
导入("../中枢/整数转字符串.nova")

定义 SSH_版本 = "SSH-2.0-NovaOS_0.2"
定义 SSH_默认端口 = 22
定义 SSH_超时毫秒 = 30000
定义 SSH_重试次数 = 3
定义 SSH_心跳间隔 = 60000

定义 SSH认证_密码 = 1
定义 SSH认证_密钥 = 2
定义 SSH认证_键盘交互 = 3

结构 SSH会话 {
    连接句柄,
    用户,
    主机,
    端口,
    密钥文件,
    认证方式,
    已认证,
    会话ID,
    远端版本,
    压缩,
    转发列表,
    超时,
}

结构 SSH转发 {
    本地端口,
    远程主机,
    远程端口,
    方向,
}

定义 可变 ssh_已知主机 = []

函数 ssh_main(参数) {
    定义 可变 端口 = SSH_默认端口
    定义 可变 密钥文件 = ""
    定义 可变 目标 = ""
    定义 可变 命令 = ""
    定义 可变 详细 = 假
    定义 可变 压缩 = 假
    定义 可变 转发列表 = []
    定义 可变 跳过主机检查 = 假
    定义 可变 超时 = SSH_超时毫秒

    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 a = 参数[i]
        如果 (a == "-p" && i + 1 < 计数(参数)) {
            i = i + 1; 端口 = 字符串转整数(参数[i])
        } 否则 如果 (a == "-i" && i + 1 < 计数(参数)) {
            i = i + 1; 密钥文件 = 参数[i]
        } 否则 如果 (a == "-v") { 详细 = 真 }
        否则 如果 (a == "-C") { 压缩 = 真 }
        否则 如果 (a == "-o" && i + 1 < 计数(参数)) {
            i = i + 1
            如果 (参数[i] == "StrictHostKeyChecking=no") { 跳过主机检查 = 真 }
        }
        否则 如果 (a == "-L" && i + 1 < 计数(参数)) {
            i = i + 1
            定义 转发 = ssh_解析转发(参数[i], "本地")
            如果 (转发 != 空) { 追加(转发列表, 转发) }
        }
        否则 如果 (a == "-R" && i + 1 < 计数(参数)) {
            i = i + 1
            定义 转发 = ssh_解析转发(参数[i], "远程")
            如果 (转发 != 空) { 追加(转发列表, 转发) }
        }
        否则 如果 (a == "-t" && i + 1 < 计数(参数)) {
            i = i + 1; 超时 = 字符串转整数(参数[i]) * 1000
        }
        否则 如果 (a == "--help" || a == "-h") { ssh_显示帮助(); 返回 0 }
        否则 如果 (目标 == "") { 目标 = a }
        否则 {
            如果 (命令 != "") { 命令 = 命令 + " " }
            命令 = 命令 + a
        }
        i = i + 1
    }

    如果 (目标 == "") {
        ssh_显示帮助()
        返回 1
    }

    定义 可变 用户 = "root"
    定义 可变 主机 = 目标
    定义 at位 = 字符串查找(目标, "@")
    如果 (at位 >= 0) {
        用户 = 字符串子串(目标, 0, at位)
        主机 = 字符串子串(目标, at位 + 1, 字符串长度(目标))
    }

    定义 冒号位 = 字符串查找(主机, ":")
    如果 (冒号位 >= 0) {
        端口 = 字符串转整数(字符串子串(主机, 冒号位 + 1, 字符串长度(主机)))
        主机 = 字符串子串(主机, 0, 冒号位)
    }

    如果 (详细) { 打印行("ssh: 连接 " + 用户 + "@" + 主机 + ":" + 整数转字符串(端口)) }

    如果 (!跳过主机检查) {
        定义 检查结果 = ssh_检查已知主机(主机, 端口)
        如果 (检查结果 == -1) {
            打印行("ssh: 警告 - 远程主机标识已更改!")
            打印行("ssh: 可能遭受中间人攻击, 连接已拒绝")
            返回 1
        }
    }

    定义 可变 连接 = 空
    定义 可变 重试 = 0
    当 (重试 < SSH_重试次数) {
        连接 = 网络_传控连接(主机, 端口)
        如果 (连接 != 空) { 跳出 }
        重试 = 重试 + 1
        如果 (详细) { 打印行("ssh: 重试连接... (" + 整数转字符串(重试) + ")") }
    }

    如果 (连接 == 空) {
        打印行("ssh: 连接 " + 主机 + " 端口 " + 整数转字符串(端口) + " 失败")
        返回 1
    }

    网络_发送(连接, SSH_版本 + "\r\n")
    定义 远端版本 = 网络_接收(连接)
    如果 (详细 && 远端版本 != 空) {
        打印行("ssh: 远端版本: " + 远端版本)
    }

    定义 会话 = SSH会话 {
        连接句柄: 连接,
        用户: 用户,
        主机: 主机,
        端口: 端口,
        密钥文件: 密钥文件,
        认证方式: 如果 (密钥文件 != "") { SSH认证_密钥 } 否则 { SSH认证_密码 },
        已认证: 假,
        会话ID: 读取毫秒(),
        远端版本: 远端版本,
        压缩: 压缩,
        转发列表: 转发列表,
        超时: 超时
    }

    定义 认证结果 = ssh_认证(会话, 详细)
    如果 (认证结果 != 0) {
        打印行("ssh: 认证失败")
        网络_关闭(连接)
        返回 1
    }
    会话.已认证 = 真

    ssh_添加已知主机(主机, 端口)

    定义 可变 fi = 0
    当 (fi < 计数(转发列表)) {
        如果 (详细) {
            打印行("ssh: 建立端口转发 " + 整数转字符串(转发列表[fi].本地端口) + " -> " + 转发列表[fi].远程主机 + ":" + 整数转字符串(转发列表[fi].远程端口))
        }
        fi = fi + 1
    }

    如果 (命令 != "") {
        返回 ssh_执行命令(会话, 命令, 详细)
    }

    返回 ssh_交互会话(会话, 详细)
}

函数 ssh_显示帮助() {
    打印行("用法: ssh [-p 端口] [-i 密钥] [-vC] [user@]host [命令]")
    打印行("选项:")
    打印行("  -p 端口      指定端口 (默认22)")
    打印行("  -i 密钥文件  使用密钥认证")
    打印行("  -v           详细模式")
    打印行("  -C           启用压缩")
    打印行("  -L 本地:远程主机:远程端口  本地端口转发")
    打印行("  -R 远程:本地主机:本地端口  远程端口转发")
    打印行("  -o 选项      配置选项")
}

函数 ssh_认证(会话, 详细) {
    如果 (详细) { 打印行("ssh: 开始认证 用户=" + 会话.用户) }
    如果 (会话.认证方式 == SSH认证_密钥) {
        如果 (详细) { 打印行("ssh: 使用密钥文件: " + 会话.密钥文件) }
        返回 0
    }
    如果 (详细) { 打印行("ssh: 使用密码认证") }
    返回 0
}

函数 ssh_执行命令(会话, 命令, 详细) {
    如果 (详细) { 打印行("ssh: 执行远程命令: " + 命令) }
    网络_发送(会话.连接句柄, 命令)
    定义 响应 = 网络_接收(会话.连接句柄)
    如果 (响应 != 空) { 标准输出(响应) }
    网络_关闭(会话.连接句柄)
    返回 0
}

函数 ssh_交互会话(会话, 详细) {
    打印行("已连接 " + 会话.用户 + "@" + 会话.主机)
    打印行("交互式SSH会话 (输入exit退出)")

    当 (真) {
        标准输出(会话.用户 + "@" + 会话.主机 + "$ ")
        定义 输入 = 标准输入_读行()
        如果 (输入 == 空 || 输入 == "exit" || 输入 == "logout") { 跳出 }
        网络_发送(会话.连接句柄, 输入 + "\n")
        定义 响应 = 网络_接收(会话.连接句柄)
        如果 (响应 != 空) { 标准输出(响应) }
    }

    打印行("连接已关闭")
    网络_关闭(会话.连接句柄)
    返回 0
}

函数 ssh_解析转发(文本, 方向) {
    定义 部分 = 字符串分割(文本, ":")
    如果 (计数(部分) < 3) { 返回 空 }
    返回 SSH转发 {
        本地端口: 字符串转整数(部分[0]),
        远程主机: 部分[1],
        远程端口: 字符串转整数(部分[2]),
        方向: 方向
    }
}

函数 ssh_检查已知主机(主机, 端口) {
    定义 可变 i = 0
    当 (i < 计数(ssh_已知主机)) {
        如果 (ssh_已知主机[i][0] == 主机 && ssh_已知主机[i][1] == 端口) {
            返回 0
        }
        i = i + 1
    }
    返回 1
}

函数 ssh_添加已知主机(主机, 端口) {
    定义 可变 i = 0
    当 (i < 计数(ssh_已知主机)) {
        如果 (ssh_已知主机[i][0] == 主机 && ssh_已知主机[i][1] == 端口) { 返回 }
        i = i + 1
    }
    追加(ssh_已知主机, [主机, 端口])
}

定义 可变 AI_远程连_热点函数 = []

函数 AI_远程连_JIT候选(函数名, 调用次数) {
    如果 (调用次数 > 100) {
        追加(AI_远程连_热点函数, 函数名)
        返回 真
    }
    返回 假
}

函数 AI_远程连_内联建议(函数体大小, 调用次数) {
    如果 (函数体大小 < 30 && 调用次数 > 50) { 返回 "内联" }
    返回 "不内联"
}

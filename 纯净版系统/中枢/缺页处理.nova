//   1. CR2寄存器: 硬件保存触发缺页的虚拟地址
//   2. 错误码bit位: P(存在)/W(写)/U(用户)/RSVD(保留位)/I(取指)/PK(保护键)/SS/SGX
//   3. 缺页分类: 内核oops / 用户SIGSEGV / COW / 按需分配 / 换入
//   4. VMA查找: find_vma确定故障地址是否在合法映射范围内
//   5. handle_mm_fault: 分配物理页并建立映射

定义 PF_存在     = 1 << 0    // P: 页存在时违规(权限)
定义 PF_写       = 1 << 1    // W/R: 写访问触发
定义 PF_用户     = 1 << 2    // U/S: 用户态触发
定义 PF_保留位   = 1 << 3    // RSVD: PTE保留位被设置
定义 PF_取指     = 1 << 4    // I/D: 取指令触发(NX违规)
定义 PF_保护键   = 1 << 5    // PK: Protection Key违规
定义 PF_影子栈   = 1 << 6    // SS: Shadow Stack
定义 PF_SGX      = 1 << 15   // SGX相关

定义 VM_FAULT_MINOR   = 0    // 次要缺页(无需IO)
定义 VM_FAULT_MAJOR   = 1    // 主要缺页(需要磁盘IO)
定义 VM_FAULT_OOM     = 2    // 内存不足
定义 VM_FAULT_SIGBUS  = 3    // 总线错误
定义 VM_FAULT_SIGSEGV = 4    // 段错误

定义 可变 缺页_总次数 = 0
定义 可变 缺页_次要次数 = 0    // minor: 页在内存中, 只需建立映射
定义 可变 缺页_主要次数 = 0    // major: 需要从磁盘读入
定义 可变 缺页_COW次数 = 0
定义 可变 缺页_SIGSEGV次数 = 0

// 缺页异常入口 
// 由IDT #14处理程序调用

函数 缺页处理(错误码, 帧) {
    定义 故障地址 = 读CR2()
    缺页_总次数 = 缺页_总次数 + 1

    定义 是写   = (错误码 & PF_写) != 0
    定义 是用户 = (错误码 & PF_用户) != 0
    定义 页存在 = (错误码 & PF_存在) != 0
    定义 是取指 = (错误码 & PF_取指) != 0

    如果 ((错误码 & PF_保留位) != 0) {
        pte_保留位错误(故障地址, 错误码)
        返回
    }

    如果 (!是用户) {
        内核缺页处理(故障地址, 错误码, 是写)
        返回
    }

    用户缺页处理(故障地址, 错误码, 是写, 是取指)
}

// 内核缺页 

函数 内核缺页处理(故障地址, 错误码, 是写) {
    // vmalloc区域缺页: 同步内核页表
    如果 (是vmalloc地址(故障地址)) {
        // vmalloc lazy映射: 从init_mm同步PGD到当前进程
        定义 结果 = vmalloc_fault(故障地址)
        如果 (结果 == 成功) { 返回 }
    }

    // 无法处理的内核缺页 → oops
    内核打印(日志_错误, "")
    内核打印(日志_错误, "BUG: unable to handle page fault at " + 整数转十六进制(故障地址))
    内核打印(日志_错误, "错误码: " + 缺页错误码描述(错误码))

    定义 当前 = 获取当前进程()
    如果 (当前 != 空) {
        内核打印(日志_错误, "IP: " + 整数转十六进制(0))
        内核打印(日志_错误, "进程: " + 进程_名称(当前) + " PID: " + 整数转字符串(进程_PID(当前)))
    }

    dump_stack()
    内核恐慌("Oops: 内核空间缺页, 无法恢复")
}

// 用户缺页 

函数 用户缺页处理(故障地址, 错误码, 是写, 是取指) {
    // 1. 查找VMA (find_vma)
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) {
        发送SIGSEGV(故障地址)
        返回
    }

    定义 vma = 查找VMA(当前, 故障地址)

    // 2. 地址不在任何VMA中 → SIGSEGV
    如果 (vma == 空) {
        // 可能是栈扩展: 地址在栈VMA下方
        如果 (故障地址 >= 栈扩展下限(当前)) {
            // 尝试扩展栈
            vma = 扩展栈(当前, 故障地址)
        }
        如果 (vma == 空) {
            缺页_SIGSEGV次数 = 缺页_SIGSEGV次数 + 1
            发送SIGSEGV(故障地址)
            返回
        }
    }

    // 3. 检查权限
    如果 (是写 && !VMA_可写(vma)) {
        缺页_SIGSEGV次数 = 缺页_SIGSEGV次数 + 1
        发送SIGSEGV(故障地址)
        返回
    }
    如果 (是取指 && !VMA_可执行(vma)) {
        缺页_SIGSEGV次数 = 缺页_SIGSEGV次数 + 1
        发送SIGSEGV(故障地址)
        返回
    }

    // 4. 处理缺页 (handle_mm_fault)
    定义 结果 = handle_mm_fault(vma, 故障地址, 是写)

    如果 (结果 == VM_FAULT_OOM) {
        // 内存不足 → 杀死进程
        内核警告("OOM: 缺页分配失败")
        返回
    }
    如果 (结果 == VM_FAULT_SIGSEGV) {
        缺页_SIGSEGV次数 = 缺页_SIGSEGV次数 + 1
        发送SIGSEGV(故障地址)
        返回
    }
}

// handle_mm_fault: 分配页并建立映射

函数 handle_mm_fault(vma, 故障地址, 是写) {
    定义 页对齐地址 = 故障地址 & ~0xFFF

    // 情况1: 写时复制(COW)
    如果 (是写 && VMA_是COW(vma, 页对齐地址)) {
        缺页_COW次数 = 缺页_COW次数 + 1
        返回 do_cow_fault(vma, 页对齐地址)
    }

    // 情况2: 匿名页按需分配 (anonymous demand paging)
    如果 (VMA_是匿名(vma)) {
        缺页_次要次数 = 缺页_次要次数 + 1
        返回 do_anonymous_page(vma, 页对齐地址, 是写)
    }

    // 情况3: 文件映射页 (Nova内存映射 file)
    缺页_主要次数 = 缺页_主要次数 + 1
    返回 do_file_page(vma, 页对齐地址)
}

函数 do_anonymous_page(vma, 地址, 是写) {
    // 分配一个物理页
    定义 新页 = 伙伴系统_分配(0)
    如果 (新页 < 0) { 返回 VM_FAULT_OOM }

    // 清零(安全: 防止信息泄露)
    内存清零(页号到地址(新页), 页大小)

    // 建立页表映射
    定义 标志 = PTE_存在 | PTE_用户
    如果 (是写) { 标志 = 标志 | PTE_可写 }
    映射页(当前PML4(), 地址, 新页 * 页大小, 标志)

    返回 VM_FAULT_MINOR
}

函数 do_cow_fault(vma, 地址) {
    // 1. 分配新页
    定义 新页 = 伙伴系统_分配(0)
    如果 (新页 < 0) { 返回 VM_FAULT_OOM }
    // 2. 复制旧页内容
    内存复制(页号到地址(新页), 地址, 页大小)
    // 3. 重新映射为可写
    映射页(当前PML4(), 地址, 新页 * 页大小, PTE_存在 | PTE_可写 | PTE_用户)
    // 4. 旧页引用计数-1
    返回 VM_FAULT_MINOR
}

函数 do_file_page(vma, 地址) {
    // 从磁盘读取文件页 (page cache / Nova内存映射文件)
    定义 文件 = VMA_获取文件(vma)
    如果 (文件 == 空) { 返回 VM_FAULT_SIGBUS }

    // 计算文件内偏移
    定义 页偏移 = (地址 - vma[VMA_起始]) / 页大小
    定义 文件偏移 = vma[VMA_文件偏移] + 页偏移

    // 1. 尝试从page cache查找
    定义 缓存页 = page_cache_查找(文件, 文件偏移)
    如果 (缓存页 != 空) {
        映射页(当前PML4(), 地址, 缓存页 * 页大小, PTE_存在 | PTE_用户)
        返回 VM_FAULT_MINOR
    }

    // 2. 分配新页并从磁盘读取
    定义 新页 = 伙伴系统_分配(0)
    如果 (新页 < 0) { 返回 VM_FAULT_OOM }

    定义 读取结果 = vfs_read_page(文件, 文件偏移, 页号到地址(新页))
    如果 (读取结果 < 0) {
        伙伴系统_释放(新页, 0)
        返回 VM_FAULT_SIGBUS
    }

    // 3. 加入page cache并映射
    page_cache_添加(文件, 文件偏移, 新页)
    定义 权限 = PTE_存在 | PTE_用户
    如果 (vma[VMA_标志] & VM_WRITE) { 权限 = 权限 | PTE_可写 }
    映射页(当前PML4(), 地址, 新页 * 页大小, 权限)
    返回 VM_FAULT_MAJOR
}

// vmalloc缺页 (内核页表同步)

定义 可变 缺页_次要错误数 = 0
定义 可变 缺页_主要错误数 = 0
定义 可变 缺页_段错误数 = 0
定义 可变 缺页_COW触发数 = 0

函数 缺页_健康检查() {
    定义 可变 问题 = []
    如果 (缺页_段错误数 > 10) {
        追加(问题, "段错误过多: " + 整数转字符串(缺页_段错误数))
    }
    如果 (缺页_主要错误数 > 缺页_次要错误数 * 10 && 缺页_次要错误数 > 100) {
        追加(问题, "主要缺页比例过高，磁盘IO可能瓶颈")
    }
    如果 (计数(问题) == 0) { 返回 "缺页处理健康" }
    返回 问题
}

函数 缺页_统计() {
    返回 {
        次要: 缺页_次要错误数,
        主要: 缺页_主要错误数,
        段错误: 缺页_段错误数,
        COW: 缺页_COW触发数,
    }
}

函数 缺页_完整统计() {
    返回 [缺页_次要错误数, 缺页_主要错误数, 缺页_段错误数, 缺页_COW触发数]
}

函数 缺页_重置统计() {
    缺页_次要错误数 = 0
    缺页_主要错误数 = 0
    缺页_段错误数 = 0
    缺页_COW触发数 = 0
}

定义 VM_FAULT_MINOR = 0
定义 VM_FAULT_MAJOR = 1
定义 VM_FAULT_SIGBUS = 2
定义 VM_FAULT_SIGSEGV = 3
定义 VM_FAULT_OOM = 4

函数 缺页_错误类型名(类型) {
    如果 (类型 == VM_FAULT_MINOR) { 返回 "MINOR" }
    如果 (类型 == VM_FAULT_MAJOR) { 返回 "MAJOR" }
    如果 (类型 == VM_FAULT_SIGBUS) { 返回 "SIGBUS" }
    如果 (类型 == VM_FAULT_SIGSEGV) { 返回 "SIGSEGV" }
    如果 (类型 == VM_FAULT_OOM) { 返回 "OOM" }
    返回 "UNKNOWN"
}

定义 可变 AI_缺页处理_运行指标 = 0
定义 可变 AI_缺页处理_异常指标 = 0

函数 AI_缺页处理_自诊断() {
    AI_缺页处理_运行指标 = 缺页_总次数
    返回 AI_缺页处理_运行指标
}

函数 AI_缺页处理_优化建议() {
    定义 指标 = AI_缺页处理_自诊断()
    如果 (AI_缺页处理_运行指标 > 10000) { 返回 "缺页处理负载较高" }
    返回 "缺页处理状态正常"
}

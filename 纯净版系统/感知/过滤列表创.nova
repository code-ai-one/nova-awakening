//       css_filter_value.cc (~300行)
//       fe_gaussian_blur.cc (~400行) fe_color_matrix.cc (~300行)
//       filter_operations.cc (~600行)
//       graphics_types.cc (blend modes ~200行)
// CSS filter属性:
//   filter: blur(5px) brightness(1.2) contrast(0.8) grayscale(1)
//           hue-rotate(90deg) invert(1) opacity(0.5) saturate(2)
//           sepia(1) drop-shadow(2px 4px 6px black)
//   backdrop-filter: blur(10px)   (背景模糊)
// CSS mix-blend-mode / background-blend-mode:
//   normal/multiply/screen/overlay/darken/lighten/color-dodge/color-burn
//   hard-light/soft-light/difference/exclusion/hue/saturation/color/luminosity
// 本文件实现:
//   1. 滤镜函数解析
//   2. 卷积模糊(高斯模糊)
//   3. 颜色矩阵(brightness/contrast/grayscale/sepia/hue-rotate/invert/saturate)
//   4. 混合模式像素运算
//   5. 滤镜管线(多滤镜串联)

// §1 滤镜操作类型

定义 FILTER_BLUR          = 1
定义 FILTER_BRIGHTNESS     = 2
定义 FILTER_CONTRAST       = 3
定义 FILTER_GRAYSCALE      = 4
定义 FILTER_HUE_ROTATE     = 5
定义 FILTER_INVERT         = 6
定义 FILTER_OPACITY        = 7
定义 FILTER_SATURATE       = 8
定义 FILTER_SEPIA          = 9
定义 FILTER_DROP_SHADOW    = 10

结构 FilterOp {
    类型,    // u32 FILTER_xxx
    参数1,    // i32 主参数(×100)
    参数2,    // i32 辅助(如阴影偏移)
    参数3,
    颜色,    // u32 阴影颜色
}

结构 FilterList {
    操作,    // u64 FilterOp*数组
    数量,
    容量,
}


函数 FilterList_创建() {
    定义 fl = 堆_分配(FilterList)
    fl.容量 = 16
    fl.操作 = 堆_分配_数组(16 * 8)
    fl.数量 = 0
    返回 fl
}

函数 FilterList_添加(fl, 类型, 参数1, 参数2, 参数3, 颜色) {
    如果 (fl.数量 >= fl.容量) { 返回 }
    定义 op = 堆_分配(FilterOp)
    op.类型 = 类型; op.参数1 = 参数1; op.参数2 = 参数2; op.参数3 = 参数3; op.颜色 = 颜色
    内存_写64(fl.操作 + fl.数量 * 8, op)
    fl.数量 = fl.数量 + 1
}

// §2 颜色矩阵滤镜
// 将RGBA通过5x4矩阵变换: [R' G' B' A'] = M × [R G B A 1]^T
// 值范围: 0-255

函数 Filter_颜色矩阵应用(像素, 宽, 高, 矩阵) {
    // 矩阵: 20个i32(×100), 5x4行优先
    定义 可变 y = 0
    当 (y < 高) {
        定义 可变 x = 0
        当 (x < 宽) {
            定义 偏移 = (y * 宽 + x) * 4
            定义 r = 内存_读8(像素 + 偏移)
            定义 g = 内存_读8(像素 + 偏移 + 1)
            定义 b = 内存_读8(像素 + 偏移 + 2)
            定义 a = 内存_读8(像素 + 偏移 + 3)

            定义 新r = (内存_读32(矩阵) * r + 内存_读32(矩阵+4) * g + 内存_读32(矩阵+8) * b + 内存_读32(矩阵+12) * a + 内存_读32(矩阵+16) * 255) / 100
            定义 新g = (内存_读32(矩阵+20) * r + 内存_读32(矩阵+24) * g + 内存_读32(矩阵+28) * b + 内存_读32(矩阵+32) * a + 内存_读32(矩阵+36) * 255) / 100
            定义 新b = (内存_读32(矩阵+40) * r + 内存_读32(矩阵+44) * g + 内存_读32(矩阵+48) * b + 内存_读32(矩阵+52) * a + 内存_读32(矩阵+56) * 255) / 100
            定义 新a = (内存_读32(矩阵+60) * r + 内存_读32(矩阵+64) * g + 内存_读32(矩阵+68) * b + 内存_读32(矩阵+72) * a + 内存_读32(矩阵+76) * 255) / 100

            内存_写8(像素 + 偏移, 钳制(新r, 0, 255))
            内存_写8(像素 + 偏移 + 1, 钳制(新g, 0, 255))
            内存_写8(像素 + 偏移 + 2, 钳制(新b, 0, 255))
            内存_写8(像素 + 偏移 + 3, 钳制(新a, 0, 255))

            x = x + 1
        }
        y = y + 1
    }
}

函数 Filter_brightness矩阵(b) {
    // brightness(b): b×100, 100=不变 200=两倍亮
    定义 m = 堆_分配_数组(80)
    内存_清零(m, 80)
    内存_写32(m, b); 内存_写32(m+24, b); 内存_写32(m+48, b); 内存_写32(m+72, 100)
    返回 m
}

函数 Filter_contrast矩阵(c) {
    // contrast(c): c×100
    定义 m = 堆_分配_数组(80)
    内存_清零(m, 80)
    定义 截距 = (100 - c) * 128 / 100    // (1-c)*0.5*255
    内存_写32(m, c); 内存_写32(m+16, 截距)
    内存_写32(m+24, c); 内存_写32(m+36, 截距)
    内存_写32(m+48, c); 内存_写32(m+56, 截距)
    内存_写32(m+72, 100)
    返回 m
}

函数 Filter_grayscale矩阵(g) {
    // grayscale(g): g=0-100 (0=彩色 100=灰度)
    定义 m = 堆_分配_数组(80)
    内存_清零(m, 80)
    定义 inv = 100 - g
    // 灰度系数: R=0.2126 G=0.7152 B=0.0722
    内存_写32(m, 21 * g / 100 + inv)       // R→R
    内存_写32(m+4, 72 * g / 100)            // G→R
    内存_写32(m+8, 7 * g / 100)             // B→R
    内存_写32(m+20, 21 * g / 100)           // R→G
    内存_写32(m+24, 72 * g / 100 + inv)     // G→G
    内存_写32(m+28, 7 * g / 100)            // B→G
    内存_写32(m+40, 21 * g / 100)           // R→B
    内存_写32(m+44, 72 * g / 100)           // G→B
    内存_写32(m+48, 7 * g / 100 + inv)      // B→B
    内存_写32(m+72, 100)
    返回 m
}

函数 Filter_sepia矩阵(s) {
    // sepia(s): 棕褐色
    定义 m = 堆_分配_数组(80)
    内存_清零(m, 80)
    定义 inv = 100 - s
    内存_写32(m, inv + 39 * s / 100)        // 0.393
    内存_写32(m+4, 77 * s / 100)             // 0.769
    内存_写32(m+8, 19 * s / 100)             // 0.189
    内存_写32(m+20, 35 * s / 100)            // 0.349
    内存_写32(m+24, inv + 69 * s / 100)      // 0.686
    内存_写32(m+28, 17 * s / 100)            // 0.168
    内存_写32(m+40, 27 * s / 100)            // 0.272
    内存_写32(m+44, 53 * s / 100)            // 0.534
    内存_写32(m+48, inv + 13 * s / 100)      // 0.131
    内存_写32(m+72, 100)
    返回 m
}

函数 Filter_invert矩阵(v) {
    // invert(v): v=0-100
    定义 m = 堆_分配_数组(80)
    内存_清零(m, 80)
    定义 k = 100 - 2 * v    // 1-2v
    内存_写32(m, k); 内存_写32(m+16, v * 255 / 100)
    内存_写32(m+24, k); 内存_写32(m+36, v * 255 / 100)
    内存_写32(m+48, k); 内存_写32(m+56, v * 255 / 100)
    内存_写32(m+72, 100)
    返回 m
}

函数 Filter_opacity矩阵(o) {
    // opacity(o): o=0-100
    定义 m = 堆_分配_数组(80)
    内存_清零(m, 80)
    内存_写32(m, 100); 内存_写32(m+24, 100); 内存_写32(m+48, 100)
    内存_写32(m+72, o)
    返回 m
}

函数 Filter_saturate矩阵(s) {
    // saturate(s): s×100 (100=不变 0=灰度 200=超饱和)
    返回 Filter_grayscale矩阵(100 - s)    // saturate是grayscale的逆
}

定义 可变 AI_过滤列表创_调用数 = 0
定义 可变 AI_过滤列表创_异常数 = 0

函数 AI_过滤列表创_监控() {
    AI_过滤列表创_调用数 = AI_过滤列表创_调用数 + 1
    返回 AI_过滤列表创_异常数 == 0
}

函数 AI_过滤列表创_健康检查() {
    如果 (AI_过滤列表创_调用数 > 0 && AI_过滤列表创_异常数 * 100 / AI_过滤列表创_调用数 > 10) {
        返回 假
    }
    返回 真
}

// NovaOS 设备注册表与健康监控 — 觉醒理论·统一设备监控
// 原创理论: NovaDevHealth — 设备注册表 + 健康评分 + AI异常检测
// §1 设备注册表: 注册/移除/查找/枚举
// §2 请求记录: 响应时间追踪/错误计数
// §3 健康评分: 基于错误率和响应时间的自适应评分
// §4 功耗管理: 设备功耗级别/总功耗查询
// §5 批量操作: 批量状态查询/批量功耗设置
// §6 AI异常检测: 基于历史模式检测异常设备
// §7 完整统计: 15+指标
// 四阶段AI演进: 本模块属于第二阶段（设备接口层）

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./日志中枢.nova")
导入("./字符串替换.nova")

定义 设备_未知 = 0
定义 设备_就绪 = 1
定义 设备_忙碌 = 2
定义 设备_错误 = 3
定义 设备_离线 = 4
定义 设备_挂起 = 5
定义 最大设备数 = 256

结构 设备信息 {
    标识,
    类型,
    状态,
    驱动名,
    中断号,
    基地址,
    错误计数,
    请求计数,
    响应总时,
    最近响应,
    健康分数,
    功耗级别,
}

定义 可变 设备表 = []
定义 可变 设备数 = 0
定义 可变 热插拔次数 = 0
定义 可变 总错误数 = 0

函数 设备_注册(类型, 驱动名, 中断号, 基地址) {
    如果 (设备数 >= 最大设备数) { 返回 -1 }
    定义 设备 = 设备信息 {}
    设备.标识 = 设备数
    设备.类型 = 类型
    设备.状态 = 设备_就绪
    设备.驱动名 = 驱动名
    设备.中断号 = 中断号
    设备.基地址 = 基地址
    设备.错误计数 = 0
    设备.请求计数 = 0
    设备.响应总时 = 0
    设备.最近响应 = 0
    设备.健康分数 = 1024
    设备.功耗级别 = 1
    追加(设备表, 设备)
    设备数 = 设备数 + 1
    返回 设备.标识
}

函数 设备_移除(标识) {
    如果 (标识 >= 设备数) { 返回 错误_无效参数 }
    设备表[标识].状态 = 设备_离线
    热插拔次数 = 热插拔次数 + 1
    返回 0
}

函数 设备_记录请求(标识, 响应时间) {
    如果 (标识 >= 设备数) { 返回 }
    定义 设备 = 设备表[标识]
    设备.请求计数 = 设备.请求计数 + 1
    设备.响应总时 = 设备.响应总时 + 响应时间
    设备.最近响应 = 响应时间
}

函数 设备_记录错误(标识) {
    如果 (标识 >= 设备数) { 返回 }
    设备表[标识].错误计数 = 设备表[标识].错误计数 + 1
    总错误数 = 总错误数 + 1
    设备表[标识].健康分数 = 设备表[标识].健康分数 * 95 / 100
    如果 (设备表[标识].健康分数 < 100) {
        设备表[标识].状态 = 设备_错误
    }
}

函数 设备_获取健康(标识) {
    如果 (标识 >= 设备数) { 返回 0 }
    返回 设备表[标识].健康分数
}

函数 设备_平均响应(标识) {
    如果 (标识 >= 设备数) { 返回 0 }
    如果 (设备表[标识].请求计数 == 0) { 返回 0 }
    返回 设备表[标识].响应总时 / 设备表[标识].请求计数
}

函数 设备_设功耗(标识, 级别) {
    如果 (标识 >= 设备数) { 返回 }
    设备表[标识].功耗级别 = 级别
}

函数 设备_总功耗() {
    定义 可变 总 = 0
    定义 可变 序号 = 0
    当 (序号 < 设备数) {
        如果 (设备表[序号].状态 != 设备_离线) {
            总 = 总 + 设备表[序号].功耗级别
        }
        序号 = 序号 + 1
    }
    返回 总
}

函数 设备_在线数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 设备数) {
        如果 (设备表[序号].状态 != 设备_离线) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 设备_错误数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 设备数) {
        如果 (设备表[序号].状态 == 设备_错误) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

定义 错误_无效参数 = 0 - 22
定义 AI异常窗口 = 16
定义 健康恢复速率 = 5
定义 健康最大值 = 1024
定义 响应超时阈值 = 10000
定义 异常错误率阈值 = 10

结构 监控统计 {
    注册次数: 整数,
    移除次数: 整数,
    请求记录次数: 整数,
    错误记录次数: 整数,
    健康查询次数: 整数,
    响应查询次数: 整数,
    功耗设置次数: 整数,
    功耗查询次数: 整数,
    批量查询次数: 整数,
    健康恢复次数: 整数,
    AI异常检测次数: 整数,
    AI异常发现数: 整数,
    枚举次数: 整数,
    状态转换次数: 整数,
    重置次数: 整数,
    错误次数: 整数,
}

定义 可变 全局统计 = 监控统计 {}
定义 可变 监控模块已初始化 = 假
定义 可变 AI错误历史 = []
定义 可变 AI错误位置 = 0


函数 监控模块_初始化() {
    如果 (监控模块已初始化 == 真) { 返回 0 - 17 }
    设备表 = []
    设备数 = 0
    热插拔次数 = 0
    总错误数 = 0
    AI错误历史 = []
    定义 可变 i = 0
    当 (i < AI异常窗口) {
        追加(AI错误历史, 0)
        i = i + 1
    }
    AI错误位置 = 0
    监控模块已初始化 = 真
    打印("[设备监控] 初始化完成")
    返回 0
}

函数 监控模块_销毁() {
    如果 (监控模块已初始化 == 假) { 返回 0 }
    设备表 = []
    设备数 = 0
    AI错误历史 = []
    监控模块已初始化 = 假
    打印("[设备监控] 已销毁")
    返回 0
}


函数 设备_安全注册(类型, 驱动名, 中断号, 基地址) {
    全局统计.注册次数 = 全局统计.注册次数 + 1
    返回 设备_注册(类型, 驱动名, 中断号, 基地址)
}

函数 设备_安全移除(标识) {
    全局统计.移除次数 = 全局统计.移除次数 + 1
    返回 设备_移除(标识)
}


函数 设备_枚举所有() {
    全局统计.枚举次数 = 全局统计.枚举次数 + 1
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 设备数) {
        追加(结果, [设备表[i].标识, 设备表[i].类型, 设备表[i].状态, 设备表[i].驱动名])
        i = i + 1
    }
    返回 结果
}

函数 设备_按类型枚举(类型) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 设备数) {
        如果 (设备表[i].类型 == 类型 && 设备表[i].状态 != 设备_离线) {
            追加(结果, 设备表[i].标识)
        }
        i = i + 1
    }
    返回 结果
}

函数 设备_按状态枚举(状态) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 设备数) {
        如果 (设备表[i].状态 == 状态) {
            追加(结果, 设备表[i].标识)
        }
        i = i + 1
    }
    返回 结果
}

函数 设备_查找按驱动名(驱动名) {
    定义 可变 i = 0
    当 (i < 设备数) {
        如果 (设备表[i].驱动名 == 驱动名) { 返回 设备表[i].标识 }
        i = i + 1
    }
    返回 0 - 1
}


函数 设备_健康恢复(标识) {
    如果 (标识 >= 设备数) { 返回 }
    设备表[标识].健康分数 = 设备表[标识].健康分数 + 健康恢复速率
    如果 (设备表[标识].健康分数 > 健康最大值) {
        设备表[标识].健康分数 = 健康最大值
    }
    如果 (设备表[标识].健康分数 > 300 && 设备表[标识].状态 == 设备_错误) {
        设备表[标识].状态 = 设备_就绪
        全局统计.健康恢复次数 = 全局统计.健康恢复次数 + 1
    }
}

函数 设备_健康Tick() {
    // 每次Tick恢复所有设备健康
    定义 可变 i = 0
    当 (i < 设备数) {
        如果 (设备表[i].状态 != 设备_离线) {
            设备_健康恢复(i)
        }
        i = i + 1
    }
}

函数 设备_最不健康() {
    定义 可变 最差标识 = 0 - 1
    定义 可变 最差分数 = 健康最大值 + 1
    定义 可变 i = 0
    当 (i < 设备数) {
        如果 (设备表[i].状态 != 设备_离线 && 设备表[i].健康分数 < 最差分数) {
            最差分数 = 设备表[i].健康分数
            最差标识 = i
        }
        i = i + 1
    }
    返回 最差标识
}

函数 设备_平均健康() {
    定义 可变 总分 = 0
    定义 在线 = 设备_在线数()
    如果 (在线 == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < 设备数) {
        如果 (设备表[i].状态 != 设备_离线) {
            总分 = 总分 + 设备表[i].健康分数
        }
        i = i + 1
    }
    返回 总分 / 在线
}


函数 设备_设置状态(标识, 新状态) {
    如果 (标识 >= 设备数) { 返回 错误_无效参数 }
    设备表[标识].状态 = 新状态
    全局统计.状态转换次数 = 全局统计.状态转换次数 + 1
    返回 0
}

函数 设备_获取状态(标识) {
    如果 (标识 >= 设备数) { 返回 设备_未知 }
    返回 设备表[标识].状态
}

函数 设备_状态名(状态) {
    如果 (状态 == 设备_就绪) { 返回 "就绪" }
    如果 (状态 == 设备_忙碌) { 返回 "忙碌" }
    如果 (状态 == 设备_错误) { 返回 "错误" }
    如果 (状态 == 设备_离线) { 返回 "离线" }
    如果 (状态 == 设备_挂起) { 返回 "挂起" }
    返回 "未知"
}

函数 设备_重置(标识) {
    如果 (标识 >= 设备数) { 返回 错误_无效参数 }
    设备表[标识].错误计数 = 0
    设备表[标识].请求计数 = 0
    设备表[标识].响应总时 = 0
    设备表[标识].最近响应 = 0
    设备表[标识].健康分数 = 健康最大值
    设备表[标识].状态 = 设备_就绪
    全局统计.重置次数 = 全局统计.重置次数 + 1
    返回 0
}


函数 设备_批量查询健康() {
    全局统计.批量查询次数 = 全局统计.批量查询次数 + 1
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 设备数) {
        追加(结果, [设备表[i].标识, 设备表[i].健康分数, 设备表[i].状态])
        i = i + 1
    }
    返回 结果
}

函数 设备_批量设功耗(级别) {
    定义 可变 i = 0
    当 (i < 设备数) {
        如果 (设备表[i].状态 != 设备_离线) {
            设备表[i].功耗级别 = 级别
        }
        i = i + 1
    }
    全局统计.功耗设置次数 = 全局统计.功耗设置次数 + 1
}

函数 设备_批量重置错误() {
    定义 可变 重置数 = 0
    定义 可变 i = 0
    当 (i < 设备数) {
        如果 (设备表[i].状态 == 设备_错误) {
            设备_重置(i)
            重置数 = 重置数 + 1
        }
        i = i + 1
    }
    返回 重置数
}


函数 AI_记录错误率(错误率) {
    设置(AI错误历史, AI错误位置, 错误率)
    AI错误位置 = (AI错误位置 + 1) % AI异常窗口
    全局统计.AI异常检测次数 = 全局统计.AI异常检测次数 + 1
}

函数 AI_检测异常设备() {
    // 检查哪些设备的错误率超过阈值
    定义 可变 异常列表 = []
    定义 可变 i = 0
    当 (i < 设备数) {
        如果 (设备表[i].状态 == 设备_离线) { i = i + 1  继续 }
        如果 (设备表[i].请求计数 > 10) {
            定义 错误率 = (设备表[i].错误计数 * 100) / 设备表[i].请求计数
            如果 (错误率 > 异常错误率阈值) {
                追加(异常列表, [设备表[i].标识, 错误率])
                全局统计.AI异常发现数 = 全局统计.AI异常发现数 + 1
            }
            AI_记录错误率(错误率)
        }
        i = i + 1
    }
    返回 异常列表
}

函数 AI_预测下次故障() {
    // 查找错误率趋势上升最快的设备
    定义 可变 最差标识 = 0 - 1
    定义 可变 最高错误率 = 0
    定义 可变 i = 0
    当 (i < 设备数) {
        如果 (设备表[i].状态 == 设备_离线 || 设备表[i].请求计数 < 5) {
            i = i + 1
            继续
        }
        定义 错误率 = (设备表[i].错误计数 * 100) / 设备表[i].请求计数
        如果 (错误率 > 最高错误率) {
            最高错误率 = 错误率
            最差标识 = i
        }
        i = i + 1
    }
    返回 最差标识
}

函数 AI_建议预防措施() {
    定义 异常 = AI_检测异常设备()
    如果 (计数(异常) == 0) { 返回 "所有设备正常" }
    如果 (计数(异常) == 1) { 返回 "1个设备异常，建议检查" }
    返回 字符串拼接(转字符串(计数(异常)), "个设备异常，建议立即排查")
}


函数 设备监控_转储() {
    打印("[设备监控] ═══ 状态转储 ═══")
    打印(字符串拼接("  总设备数: ", 转字符串(设备数)))
    打印(字符串拼接("  在线数: ", 转字符串(设备_在线数())))
    打印(字符串拼接("  错误数: ", 转字符串(设备_错误数())))
    打印(字符串拼接("  平均健康: ", 转字符串(设备_平均健康())))
    打印(字符串拼接("  总功耗: ", 转字符串(设备_总功耗())))
    打印(字符串拼接("  热插拔: ", 转字符串(热插拔次数)))
    定义 可变 i = 0
    当 (i < 设备数) {
        打印(字符串拼接("  [", 转字符串(i)))
        打印(字符串拼接("    驱动: ", 转字符串(设备表[i].驱动名)))
        打印(字符串拼接("    状态: ", 设备_状态名(设备表[i].状态)))
        打印(字符串拼接("    健康: ", 转字符串(设备表[i].健康分数)))
        i = i + 1
    }
    返回 0
}

函数 设备管理_完整统计() {
    返回 [设备数, 设备_在线数(), 设备_错误数(), 热插拔次数, 总错误数, 设备_总功耗()]
}


函数 监控模块_打印统计() {
    打印("[设备监控] ═══ 运行统计 ═══")
    打印(字符串拼接("  注册次数: ", 转字符串(全局统计.注册次数)))
    打印(字符串拼接("  移除次数: ", 转字符串(全局统计.移除次数)))
    打印(字符串拼接("  请求记录: ", 转字符串(全局统计.请求记录次数)))
    打印(字符串拼接("  错误记录: ", 转字符串(全局统计.错误记录次数)))
    打印(字符串拼接("  健康查询: ", 转字符串(全局统计.健康查询次数)))
    打印(字符串拼接("  响应查询: ", 转字符串(全局统计.响应查询次数)))
    打印(字符串拼接("  功耗设置: ", 转字符串(全局统计.功耗设置次数)))
    打印(字符串拼接("  批量查询: ", 转字符串(全局统计.批量查询次数)))
    打印(字符串拼接("  健康恢复: ", 转字符串(全局统计.健康恢复次数)))
    打印(字符串拼接("  AI异常检测: ", 转字符串(全局统计.AI异常检测次数)))
    打印(字符串拼接("  AI异常发现: ", 转字符串(全局统计.AI异常发现数)))
    打印(字符串拼接("  枚举次数: ", 转字符串(全局统计.枚举次数)))
    打印(字符串拼接("  状态转换: ", 转字符串(全局统计.状态转换次数)))
    打印(字符串拼接("  重置次数: ", 转字符串(全局统计.重置次数)))
    打印(字符串拼接("  错误次数: ", 转字符串(全局统计.错误次数)))
    打印(字符串拼接("  总设备: ", 转字符串(设备数)))
    打印(字符串拼接("  在线: ", 转字符串(设备_在线数())))
    返回 0
}


函数 监控模块_注册到内核(内核上下文) {
    如果 (监控模块已初始化 == 假) { 返回 0 - 1 }
    打印("[设备监控] 已注册到内核上下文")
    返回 0
}

函数 监控模块_查询状态() {
    如果 (监控模块已初始化 == 假) { 返回 0 }
    返回 1
}

函数 监控模块_健康检查() {
    如果 (监控模块已初始化 == 假) { 返回 假 }
    如果 (全局统计.错误次数 * 10 > 全局统计.注册次数 + 全局统计.请求记录次数) {
        返回 假
    }
    返回 真
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./原生系统块分.nova")
导入("./链表后继.nova")
导入("../引导/端口输入.nova")
导入("./恐慌.nova")
导入("./同步原语.nova")
导入("./字符串替换.nova")
导入("./伙伴系统释放.nova")

    // 每个空闲对象的开头存放下一个空闲对象的地址

    定义 基址 = 新Nova块缓存.虚拟基址
    定义 对象大小 = 缓存.实际大小
    定义 偏移 = 缓存.空闲指针偏移
    定义 可变 i = 0
    当 (i < 新Nova块缓存.对象数 - 1) {
        定义 当前 = 基址 + i * 对象大小
        定义 下个 = 基址 + (i + 1) * 对象大小
        内存写64(当前 + 偏移, 下个)   // obj->next = next_obj
        // 投毒(调试模式)
        如果 ((缓存.标志 & Nova块缓存_POISON) != 0) {
            内存填充(当前 + 8, POISON_FREE, 对象大小 - 8)
        }
        i = i + 1
    }
    // 最后一个对象的next = 0 (链尾)
    定义 最后 = 基址 + (新Nova块缓存.对象数 - 1) * 对象大小
    内存写64(最后 + 偏移, 0)
    新Nova块缓存.空闲链 = 基址    // freelist指向第一个空闲对象

    缓存.Nova块缓存页数 = 缓存.Nova块缓存页数 + 1
    返回 新Nova块缓存
}

函数 __释放Nova块缓存页(缓存, Nova块缓存) {
    // 归还Nova块缓存的物理页给伙伴系统
    伙伴系统_释放(Nova块缓存.页号, 缓存.Nova块缓存阶)
    缓存.Nova块缓存页数 = 缓存.Nova块缓存页数 - 1
}

// 嵌入式空闲指针操作

函数 获取空闲下个(缓存, 对象地址) {
    返回 内存读64(对象地址 + 缓存.空闲指针偏移)
}

函数 设置空闲下个(缓存, 对象地址, 下个) {
    内存写64(对象地址 + 缓存.空闲指针偏移, 下个)
}

// 分配核心: 三层快慢路径 

函数 Nova块缓存_alloc(缓存, gfp) {
    如果 (缓存.cpu_Nova块缓存.空闲链 != 0) {
        定义 对象 = 缓存.cpu_Nova块缓存.空闲链
        缓存.cpu_Nova块缓存.空闲链 = 获取空闲下个(缓存, 对象)
        缓存.cpu_Nova块缓存.活跃Nova块缓存.已用数 = 缓存.cpu_Nova块缓存.活跃Nova块缓存.已用数 + 1
        缓存.分配次数 = 缓存.分配次数 + 1
        缓存.活跃对象 = 缓存.活跃对象 + 1
        SLUB_总分配 = SLUB_总分配 + 1
        返回 对象
    }

    如果 (缓存.cpu_Nova块缓存.partial != 空) {
        定义 可变 新Nova块缓存 = 缓存.cpu_Nova块缓存.partial
        缓存.cpu_Nova块缓存.partial = 新Nova块缓存.下一个
        缓存.cpu_Nova块缓存.partial数 = 缓存.cpu_Nova块缓存.partial数 - 1
        // 冻结这个Nova块缓存(变为CPU私有)
        新Nova块缓存.冻结 = 真
        // 如果旧的cpu_Nova块缓存还有价值, 放回节点 partial
        如果 (缓存.cpu_Nova块缓存.活跃Nova块缓存 != 空) {
            __放回节点_partial(缓存, 缓存.cpu_Nova块缓存.活跃Nova块缓存)
        }
        缓存.cpu_Nova块缓存.活跃Nova块缓存 = 新Nova块缓存
        缓存.cpu_Nova块缓存.空闲链 = 新Nova块缓存.空闲链
        // 递归快速路径
        返回 Nova块缓存_alloc(缓存, gfp)
    }

    自旋锁_获取(缓存.节点.锁)
    如果 (缓存.节点.partial数 > 0) {
        // 从节点 partial链取一个Nova块缓存
        定义 可变 节点 = 链表_首节点_或空(缓存.节点.partial链)
        如果 (节点 != 空 && 节点 != 缓存.节点.partial链) {
            定义 Nova块缓存 = 链表_数据(节点)
            链表_删除(节点)
            缓存.节点.partial数 = 缓存.节点.partial数 - 1
            自旋锁_释放(缓存.节点.锁)
            // 安装为cpu_Nova块缓存
            如果 (缓存.cpu_Nova块缓存.活跃Nova块缓存 != 空) {
                __放回节点_partial(缓存, 缓存.cpu_Nova块缓存.活跃Nova块缓存)
            }
            Nova块缓存.冻结 = 真
            缓存.cpu_Nova块缓存.活跃Nova块缓存 = Nova块缓存
            缓存.cpu_Nova块缓存.空闲链 = Nova块缓存.空闲链
            返回 Nova块缓存_alloc(缓存, gfp)
        }
    }
    自旋锁_释放(缓存.节点.锁)

    定义 新Nova块缓存 = __分配Nova块缓存页(缓存, gfp)
    如果 (新Nova块缓存 == 空) {
        如果 ((缓存.标志 & Nova块缓存_PANIC) != 0) {
            内核恐慌("SLUB: 分配Nova块缓存页失败")
        }
        返回 0
    }
    新Nova块缓存.冻结 = 真
    如果 (缓存.cpu_Nova块缓存.活跃Nova块缓存 != 空) {
        __放回节点_partial(缓存, 缓存.cpu_Nova块缓存.活跃Nova块缓存)
    }
    缓存.cpu_Nova块缓存.活跃Nova块缓存 = 新Nova块缓存
    缓存.cpu_Nova块缓存.空闲链 = 新Nova块缓存.空闲链
    返回 Nova块缓存_alloc(缓存, gfp)
}

函数 __放回节点_partial(缓存, Nova块缓存) {
    Nova块缓存.冻结 = 假
    Nova块缓存.空闲链 = 0  // 将由__Nova块缓存_free更新
    // 如果Nova块缓存完全空闲, 释放回伙伴系统
    如果 (Nova块缓存.已用数 == 0) {
        __释放Nova块缓存页(缓存, Nova块缓存)
        返回
    }
    // 否则放入节点 partial
    自旋锁_获取(缓存.节点.锁)
    链表_尾插(缓存.节点.partial链, Nova块缓存)
    缓存.节点.partial数 = 缓存.节点.partial数 + 1
    自旋锁_释放(缓存.节点.锁)
}

// 释放核心 

函数 Nova块缓存_free(缓存, 对象地址) {
    如果 (对象地址 == 0) { 返回 }

    // 查找对象所在的Nova块缓存页
    定义 Nova块缓存 = __查找Nova块缓存(缓存, 对象地址)
    如果 (Nova块缓存 == 空) {
        内核警告("SLUB: kfree()无法找到Nova块缓存页")
        返回
    }

    // 投毒(调试模式)
    如果 ((缓存.标志 & Nova块缓存_POISON) != 0) {
        内存填充(对象地址, POISON_FREE, 缓存.对象大小)
    }

定义 可变 AI_释放块缓存_运行指标 = 0
定义 可变 AI_释放块缓存_异常指标 = 0

函数 AI_释放块缓存_自诊断() {
    AI_释放块缓存_运行指标 = 0
    返回 AI_释放块缓存_运行指标
}

函数 AI_释放块缓存_优化建议() {
    定义 指标 = AI_释放块缓存_自诊断()
    返回 "释放块缓存状态正常"
}

// 最小复现: 3 次浮点加法链 bug
函数 主程序() {
    // 仅 3 浮点
    定义 a = 6.333
    定义 b = 0.667
    定义 r = a + b
    打印(字符串拼接("2加 a+b=", 转字符串(r)))  // 期望 ~7.0
    
    定义 c = 0.0
    定义 r3 = a + b + c
    打印(字符串拼接("3加 a+b+c=", 转字符串(r3)))  // 期望 ~7.0
    
    // 4 加
    定义 d = 0.0
    定义 r4 = a + b + c + d
    打印(字符串拼接("4加 a+b+c+d=", 转字符串(r4)))
    
    // 5 加 (exp_approx 模式)
    定义 e = 0.0
    定义 r5 = 1.0 + 2.0 + 2.0 + 1.333 + 0.667
    打印(字符串拼接("5加 字面量=", 转字符串(r5)))
    
    // 5加变量
    定义 p1 = 1.0
    定义 p2 = 2.0
    定义 p3 = 2.0
    定义 p4 = 1.333
    定义 p5 = 0.667
    定义 r6 = p1 + p2 + p3 + p4 + p5
    打印(字符串拼接("5加 变量=", 转字符串(r6)))
    
    返回 0
}

// NovaOS 内核字符串工具

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./硬链接.nova")
导入("./字符串替换.nova")
导入("../外联/地址解析辅.nova")

函数 整数转字符串(数值) {
    如果 (数值 == 0) { 返回 "0" }
    定义 可变 结果 = ""
    定义 可变 n = 数值
    定义 可变 负数 = 假
    如果 (n < 0) { 负数 = 真  n = 0 - n }
    当 (n > 0) {
        定义 余 = n % 10
        结果 = 字符串拼接(转字符串(余), 结果)
        n = n / 10
    }
    如果 (负数) { 结果 = 字符串拼接("-", 结果) }
    返回 结果
}

函数 整数转十六进制(数值) {
    如果 (数值 == 0) { 返回 "0x0" }
    定义 hex字符 = "0123456789ABCDEF"
    定义 可变 结果 = ""
    定义 可变 n = 数值
    当 (n > 0) {
        定义 低4位 = n & 0xF
        结果 = 字符串拼接(字符串子串(hex字符, 低4位, 低4位 + 1), 结果)
        n = n >> 4
    }
    返回 字符串拼接("0x", 结果)
}

函数 字符串转整数(文本) {
    定义 长度 = 字符串长度(文本)
    如果 (长度 == 0) { 返回 0 }
    定义 可变 结果 = 0
    定义 可变 i = 0
    定义 可变 负数 = 假
    如果 (字符串取字符(文本, 0) == "-") { 负数 = 真  i = 1 }
    当 (i < 长度) {
        定义 字符 = 编码(字符串取字符(文本, i))
        如果 (字符 >= 48 && 字符 <= 57) {
            结果 = 结果 * 10 + (字符 - 48)
        }
        i = i + 1
    }
    如果 (负数) { 返回 0 - 结果 }
    返回 结果
}

函数 字符串重复(文本, 次数) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 次数) {
        结果 = 字符串拼接(结果, 文本)
        i = i + 1
    }
    返回 结果
}

函数 字符串左填充(文本, 宽度, 填充字符) {
    定义 长度 = 字符串长度(文本)
    如果 (长度 >= 宽度) { 返回 文本 }
    返回 字符串拼接(字符串重复(填充字符, 宽度 - 长度), 文本)
}

函数 格式化字节大小(字节数) {
    如果 (字节数 < 1024) {
        返回 字符串拼接(整数转字符串(字节数), " B")
    }
    如果 (字节数 < 1048576) {
        返回 字符串拼接(整数转字符串(字节数 / 1024), " KB")
    }
    如果 (字节数 < 1073741824) {
        返回 字符串拼接(整数转字符串(字节数 / 1048576), " MB")
    }
    返回 字符串拼接(整数转字符串(字节数 / 1073741824), " GB")
}

函数 字节到字符串(数据) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 长度(数据)) {
        如果 (数据[i] == 0) { 中断 }
        结果 = 结果 + 字符(数据[i])
        i = i + 1
    }
    返回 结果
}

// 字符串比较与搜索

函数 字符串_相等(a, b) { 返回 a == b }

函数 字符串_开头是(s, 前缀) {
    定义 前缀长 = 字符串长度(前缀)
    如果 (字符串长度(s) < 前缀长) { 返回 假 }
    返回 字符串子串(s, 0, 前缀长) == 前缀
}

函数 字符串_结尾是(s, 后缀) {
    定义 s长 = 字符串长度(s)
    定义 后缀长 = 字符串长度(后缀)
    如果 (s长 < 后缀长) { 返回 假 }
    返回 字符串子串(s, s长 - 后缀长, 后缀长) == 后缀
}

// 字符串_包含 已统一定义在 字符串替换.nova

函数 字符串_去首尾空白(s) {
    定义 长度 = 字符串长度(s)
    如果 (长度 == 0) { 返回 s }
    定义 可变 起始 = 0
    当 (起始 < 长度) {
        定义 c = 编码(字符串取字符(s, 起始))
        如果 (c != 32 && c != 9 && c != 10 && c != 13) { 中断 }
        起始 = 起始 + 1
    }
    定义 可变 结束 = 长度 - 1
    当 (结束 > 起始) {
        定义 c = 编码(字符串取字符(s, 结束))
        如果 (c != 32 && c != 9 && c != 10 && c != 13) { 中断 }
        结束 = 结束 - 1
    }
    返回 字符串子串(s, 起始, 结束 - 起始 + 1)
}

函数 字符串_转大写(s) {
    定义 长度 = 字符串长度(s)
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 编码(字符串取字符(s, i))
        如果 (c >= 97 && c <= 122) { c = c - 32 }  // a-z → A-Z
        结果 = 结果 + 字符(c)
        i = i + 1
    }
    返回 结果
}

函数 字符串_转小写(s) {
    定义 长度 = 字符串长度(s)
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 编码(字符串取字符(s, i))
        如果 (c >= 65 && c <= 90) { c = c + 32 }  // A-Z → a-z
        结果 = 结果 + 字符(c)
        i = i + 1
    }
    返回 结果
}

// 字符串分割与连接

函数 字符串_分割(s, 分隔符) {
    定义 可变 结果 = []
    定义 可变 起始 = 0
    定义 分隔符长 = 字符串长度(分隔符)
    定义 s长 = 字符串长度(s)

    当 (起始 <= s长) {
        定义 位置 = 字符串查找_从(s, 分隔符, 起始)
        如果 (位置 < 0) {
            追加(结果, 字符串子串(s, 起始, s长 - 起始))
            中断
        }
        追加(结果, 字符串子串(s, 起始, 位置 - 起始))
        起始 = 位置 + 分隔符长
    }
    返回 结果
}

函数 字符串_连接(列表, 分隔符) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (i > 0) { 结果 = 结果 + 分隔符 }
        结果 = 结果 + 列表[i]
        i = i + 1
    }
    返回 结果
}

函数 字符串查找_从(s, 子串, 起始) {
    定义 s长 = 字符串长度(s)
    定义 子长 = 字符串长度(子串)
    如果 (子长 == 0) { 返回 起始 }
    定义 可变 i = 起始
    当 (i <= s长 - 子长) {
        如果 (字符串子串(s, i, 子长) == 子串) { 返回 i }
        i = i + 1
    }
    返回 0 - 1
}

定义 AI格式窗口 = 16
定义 格式_十进制 = 0
定义 格式_十六进制 = 1
定义 格式_二进制 = 2
定义 格式_八进制 = 3

结构 转换统计 {
    整数转字符串次数: 整数,
    十六进制转换次数: 整数,
    二进制转换次数: 整数,
    八进制转换次数: 整数,
    字符串转整数次数: 整数,
    字符串重复次数: 整数,
    格式化字节次数: 整数,
    左填充次数: 整数,
    右填充次数: 整数,
    分割次数: 整数,
    连接次数: 整数,
    比较次数: 整数,
    批量转换次数: 整数,
    AI预测次数: 整数,
    AI预测命中: 整数,
    错误次数: 整数,
}

定义 可变 全局统计 = 转换统计 {}
定义 可变 转换模块已初始化 = 假
定义 可变 AI格式历史 = []
定义 可变 AI格式位置 = 0


函数 转换模块_初始化() {
    如果 (转换模块已初始化 == 真) { 返回 0 - 17 }
    AI格式历史 = []
    定义 可变 i = 0
    当 (i < AI格式窗口) {
        追加(AI格式历史, 0)
        i = i + 1
    }
    AI格式位置 = 0
    转换模块已初始化 = 真
    打印("[整数转换] 初始化完成")
    返回 0
}

函数 转换模块_销毁() {
    如果 (转换模块已初始化 == 假) { 返回 0 }
    AI格式历史 = []
    转换模块已初始化 = 假
    打印("[整数转换] 已销毁")
    返回 0
}


函数 整数转二进制(数值) {
    全局统计.二进制转换次数 = 全局统计.二进制转换次数 + 1
    AI_记录格式(格式_二进制)
    如果 (数值 == 0) { 返回 "0b0" }
    定义 可变 结果 = ""
    定义 可变 n = 数值
    如果 (n < 0) { n = 0 - n }
    当 (n > 0) {
        如果 ((n & 1) == 1) {
            结果 = 字符串拼接("1", 结果)
        } 否则 {
            结果 = 字符串拼接("0", 结果)
        }
        n = n >> 1
    }
    如果 (数值 < 0) { 返回 字符串拼接("-0b", 结果) }
    返回 字符串拼接("0b", 结果)
}

函数 整数转八进制(数值) {
    全局统计.八进制转换次数 = 全局统计.八进制转换次数 + 1
    AI_记录格式(格式_八进制)
    如果 (数值 == 0) { 返回 "0o0" }
    定义 可变 结果 = ""
    定义 可变 n = 数值
    如果 (n < 0) { n = 0 - n }
    当 (n > 0) {
        定义 余 = n % 8
        结果 = 字符串拼接(字符(48 + 余), 结果)
        n = n / 8
    }
    如果 (数值 < 0) { 返回 字符串拼接("-0o", 结果) }
    返回 字符串拼接("0o", 结果)
}

函数 整数_安全转字符串(数值) {
    全局统计.整数转字符串次数 = 全局统计.整数转字符串次数 + 1
    AI_记录格式(格式_十进制)
    返回 整数转字符串(数值)
}

函数 整数_格式化(数值, 格式) {
    如果 (格式 == 格式_十六进制) { 返回 整数转十六进制(数值) }
    如果 (格式 == 格式_二进制) { 返回 整数转二进制(数值) }
    如果 (格式 == 格式_八进制) { 返回 整数转八进制(数值) }
    返回 整数转字符串(数值)
}


函数 字符串_是有效整数(文本) {
    如果 (文本 == 空) { 返回 假 }
    定义 长度 = 字符串长度(文本)
    如果 (长度 == 0) { 返回 假 }
    定义 可变 i = 0
    如果 (编码(字符串取字符(文本, 0)) == 45) { i = 1 }
    如果 (i >= 长度) { 返回 假 }
    当 (i < 长度) {
        定义 c = 编码(字符串取字符(文本, i))
        如果 (c < 48 || c > 57) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 字符串_是有效十六进制(文本) {
    如果 (文本 == 空) { 返回 假 }
    定义 长度 = 字符串长度(文本)
    定义 可变 起始 = 0
    如果 (长度 >= 2 && 字符串子串(文本, 0, 2) == "0x") { 起始 = 2 }
    如果 (起始 >= 长度) { 返回 假 }
    定义 可变 i = 起始
    当 (i < 长度) {
        定义 c = 编码(字符串取字符(文本, i))
        如果 (!((c >= 48 && c <= 57) || (c >= 65 && c <= 70) || (c >= 97 && c <= 102))) {
            返回 假
        }
        i = i + 1
    }
    返回 真
}


函数 格式化_千位分隔(数值) {
    定义 文本 = 整数转字符串(数值)
    定义 长度 = 字符串长度(文本)
    如果 (长度 <= 3) { 返回 文本 }
    定义 可变 结果 = ""
    定义 可变 计数 = 0
    定义 可变 i = 长度 - 1
    定义 可变 负号 = 假
    如果 (编码(字符串取字符(文本, 0)) == 45) { 负号 = 真 }
    当 (i >= 0) {
        如果 (负号 == 真 && i == 0) {
            结果 = 字符串拼接("-", 结果)
            止
        }
        结果 = 字符串拼接(字符串子串(文本, i, 1), 结果)
        计数 = 计数 + 1
        如果 (计数 % 3 == 0 && i > 0) {
            如果 (负号 == 假 || i > 1) {
                结果 = 字符串拼接(",", 结果)
            }
        }
        i = i - 1
    }
    返回 结果
}

函数 格式化_百分比(分子, 分母) {
    如果 (分母 == 0) { 返回 "0%" }
    定义 百分 = (分子 * 100) / 分母
    返回 字符串拼接(整数转字符串(百分), "%")
}

函数 格式化_时间差(毫秒) {
    如果 (毫秒 < 1000) {
        返回 字符串拼接(整数转字符串(毫秒), "ms")
    }
    如果 (毫秒 < 60000) {
        返回 字符串拼接(整数转字符串(毫秒 / 1000), "s")
    }
    如果 (毫秒 < 3600000) {
        返回 字符串拼接(整数转字符串(毫秒 / 60000), "m")
    }
    返回 字符串拼接(整数转字符串(毫秒 / 3600000), "h")
}

函数 字符串右填充(文本, 宽度, 填充字符) {
    定义 长度 = 字符串长度(文本)
    如果 (长度 >= 宽度) { 返回 文本 }
    返回 字符串拼接(文本, 字符串重复(填充字符, 宽度 - 长度))
}


函数 批量_整数转字符串(数值列表) {
    如果 (数值列表 == 空) { 返回 [] }
    全局统计.批量转换次数 = 全局统计.批量转换次数 + 1
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(数值列表)) {
        追加(结果, 整数转字符串(数值列表[i]))
        i = i + 1
    }
    返回 结果
}

函数 批量_字符串转整数(字符串列表) {
    如果 (字符串列表 == 空) { 返回 [] }
    全局统计.批量转换次数 = 全局统计.批量转换次数 + 1
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(字符串列表)) {
        追加(结果, 字符串转整数(字符串列表[i]))
        i = i + 1
    }
    返回 结果
}


函数 AI_记录格式(格式) {
    设置(AI格式历史, AI格式位置, 格式)
    AI格式位置 = (AI格式位置 + 1) % AI格式窗口
    全局统计.AI预测次数 = 全局统计.AI预测次数 + 1
}

函数 AI_预测下次格式() {
    定义 可变 最频格式 = 0
    定义 可变 最频次 = 0
    定义 可变 i = 0
    当 (i < AI格式窗口) {
        定义 当前 = AI格式历史[i]
        定义 可变 频 = 0
        定义 可变 j = 0
        当 (j < AI格式窗口) {
            如果 (AI格式历史[j] == 当前) { 频 = 频 + 1 }
            j = j + 1
        }
        如果 (频 > 最频次) { 最频次 = 频  最频格式 = 当前 }
        i = i + 1
    }
    如果 (最频次 > AI格式窗口 / 3) {
        全局统计.AI预测命中 = 全局统计.AI预测命中 + 1
    }
    返回 最频格式
}

函数 AI_格式名(格式) {
    如果 (格式 == 格式_十进制) { 返回 "十进制" }
    如果 (格式 == 格式_十六进制) { 返回 "十六进制" }
    如果 (格式 == 格式_二进制) { 返回 "二进制" }
    如果 (格式 == 格式_八进制) { 返回 "八进制" }
    返回 "未知"
}


函数 转换模块_转储() {
    打印("[整数转换] ═══ 状态转储 ═══")
    打印(字符串拼接("  AI预测下次格式: ", AI_格式名(AI_预测下次格式())))
    返回 0
}


函数 转换模块_打印统计() {
    打印("[整数转换] ═══ 运行统计 ═══")
    打印(字符串拼接("  整数转字符串: ", 整数转字符串(全局统计.整数转字符串次数)))
    打印(字符串拼接("  十六进制转换: ", 整数转字符串(全局统计.十六进制转换次数)))
    打印(字符串拼接("  二进制转换: ", 整数转字符串(全局统计.二进制转换次数)))
    打印(字符串拼接("  八进制转换: ", 整数转字符串(全局统计.八进制转换次数)))
    打印(字符串拼接("  字符串转整数: ", 整数转字符串(全局统计.字符串转整数次数)))
    打印(字符串拼接("  字符串重复: ", 整数转字符串(全局统计.字符串重复次数)))
    打印(字符串拼接("  格式化字节: ", 整数转字符串(全局统计.格式化字节次数)))
    打印(字符串拼接("  左填充: ", 整数转字符串(全局统计.左填充次数)))
    打印(字符串拼接("  分割次数: ", 整数转字符串(全局统计.分割次数)))
    打印(字符串拼接("  连接次数: ", 整数转字符串(全局统计.连接次数)))
    打印(字符串拼接("  比较次数: ", 整数转字符串(全局统计.比较次数)))
    打印(字符串拼接("  批量转换: ", 整数转字符串(全局统计.批量转换次数)))
    打印(字符串拼接("  AI预测: ", 整数转字符串(全局统计.AI预测次数)))
    打印(字符串拼接("  AI命中: ", 整数转字符串(全局统计.AI预测命中)))
    打印(字符串拼接("  错误次数: ", 整数转字符串(全局统计.错误次数)))
    返回 0
}


函数 转换模块_注册到内核(内核上下文) {
    如果 (转换模块已初始化 == 假) { 返回 0 - 1 }
    打印("[整数转换] 已注册到内核上下文")
    返回 0
}

函数 转换模块_查询状态() {
    如果 (转换模块已初始化 == 假) { 返回 0 }
    返回 1
}

函数 转换模块_健康检查() {
    如果 (转换模块已初始化 == 假) { 返回 假 }
    如果 (全局统计.错误次数 * 10 > 全局统计.整数转字符串次数) { 返回 假 }
    返回 真
}

// NovaOS · 图处统一驱动接口 — 抽象厂商差异, 一套接口驱动所有图处
// 上层(窗口合成器/渲染管线/AI引擎)只调用本文件的统一函数
// 本文件根据图处厂商自动分派到 NVIDIA驱动.nova 或 AMD驱动.nova
//  ┌──────────────────────────────┐
//  │   窗口合成器 / AI推理引擎    │  ← 调用统一接口
//  ├──────────────────────────────┤
//  │    图处统一接口 (本文件)       │  ← 自动分派
//  ├──────────┬───────────────────┤
//  │ NVIDIA驱动│    AMD驱动       │  ← 厂商实现
//  ├──────────┴───────────────────┤
//  │   图处识别 + 图处智能驱动(通用) │  ← PCI枚举/内存管理
//  └──────────────────────────────┘

导入("./图处显示.nova")
导入("../中枢/日志中枢.nova")
导入("../推理/值乘.nova")
导入("./完整图处型.nova")
导入("./图处驱动初.nova")
导入("./命令包格式.nova")
导入("./双初始化.nova")
导入("./图处枚举.nova")
导入("./初始化.nova")
导入("./图处内存管.nova")
导入("./帧率统计.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/字符串替换.nova")
导入("./稳态丙.nova")
导入("../感知/内核直连层.nova")

// NGUI理论 — Nova图处统一接口 (Nova GPU Unified Interface)
// 创新点: 厂商无关抽象层 + 指令队列池 + 自适应电源策略 + AI性能预测
// 统一处理GPU探测/显存/命令提交/围栏/电源/多图处/热插拔/故障恢复

定义 NGUI_最大图处数 = 4
定义 NGUI_最大命令池 = 16
定义 NGUI_命令缓冲大小 = 65536  // 64KB
定义 NGUI_最大围栏数 = 256

定义 可变 NGUI_命令提交总数 = 0
定义 可变 NGUI_围栏总数 = 0
定义 可变 NGUI_显存分配总数 = 0
定义 可变 NGUI_错误总数 = 0
定义 可变 NGUI_恢复总数 = 0


// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 图处_统一打印状态() {
    如果 (当前图处 == 空) {
        内核信息("  图处状态: 无图处 (纯CPU渲染模式)")
        返回
    }
    内核信息("  图处状态: 驱动类型=" + NGUI_驱动类型名(当前驱动类型))
    内核信息("  厂商ID=0x" + 整数转十六进制(当前图处.厂商ID))
    内核信息("  设备ID=0x" + 整数转十六进制(当前图处.设备ID))
    如果 (当前图处.显存大小 > 0) {
        内核信息("  显存=" + (当前图处.显存大小 / 1048576) + "MB")
    }
}

函数 NGUI_驱动类型名(类型) {
    如果 (类型 == DRV_NVIDIA) { 返回 "NVIDIA" }
    如果 (类型 == DRV_AMD) { 返回 "AMD" }
    如果 (类型 == DRV_INTEL) { 返回 "Intel" }
    如果 (类型 == DRV_VIRTIO) { 返回 "VirtIO" }
    如果 (类型 == DRV_GENERIC) { 返回 "Generic" }
    返回 "None"
}


结构 NGUI_显示模式 {
    宽,             // 像素
    高,             // 像素
    深度,           // 位数 (24/32)
    刷新率,         // Hz
}

函数 NGUI_设置显示模式(宽, 高, 深度, 刷新率) {
    如果 (当前图处 == 空) { 返回 假 }
    // 验证参数
    如果 (宽 < 320 || 宽 > 7680) { 返回 假 }
    如果 (高 < 240 || 高 > 4320) { 返回 假 }
    如果 (深度 != 24 && 深度 != 32) { 深度 = 32 }
    如果 (刷新率 < 30 || 刷新率 > 360) { 刷新率 = 60 }

    定义 可变 结果 = 假
    如果 (当前驱动类型 == DRV_NVIDIA) {
        结果 = NV_设置显示模式(当前图处, 宽, 高, 深度, 刷新率)
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        结果 = AMD_设置显示模式(当前图处, 宽, 高, 深度, 刷新率)
    } 否则 {
        结果 = 图处驱动_设置模式(当前图处, 宽, 高, 深度)
    }

    如果 (结果) {
        渲染管线_更新大小(宽, 高)
        内核信息("  显示模式: " + 宽 + "x" + 高 + "@" + 刷新率 + "Hz")
    }
    返回 结果
}

函数 NGUI_获取显示模式(输出) {
    如果 (当前图处 == 空 || 输出 == 0) { 返回 假 }
    如果 (当前驱动类型 == DRV_NVIDIA) {
        返回 NV_获取显示模式(当前图处, 输出)
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        返回 AMD_获取显示模式(当前图处, 输出)
    }
    返回 图处驱动_获取模式(当前图处, 输出)
}


函数 NGUI_显存分配(大小, 对齐, 标志) {
    如果 (当前图处 == 空 || 大小 == 0) { 返回 0 }
    定义 可变 地址 = 0
    如果 (当前驱动类型 == DRV_NVIDIA) {
        地址 = NV_显存分配(当前图处, 大小, 对齐)
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        地址 = AMD_显存分配(当前图处, 大小, 对齐)
    } 否则 {
        地址 = 图处驱动_分配显存(当前图处, 大小)
    }
    如果 (地址 != 0) { NGUI_显存分配总数 = NGUI_显存分配总数 + 1 }
    返回 地址
}

函数 NGUI_显存释放(地址) {
    如果 (当前图处 == 空 || 地址 == 0) { 返回 }
    如果 (当前驱动类型 == DRV_NVIDIA) {
        NV_显存释放(当前图处, 地址)
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        AMD_显存释放(当前图处, 地址)
    } 否则 {
        图处驱动_释放显存(当前图处, 地址)
    }
}

函数 NGUI_获取显存总量() {
    如果 (当前图处 == 空) { 返回 0 }
    返回 当前图处.显存大小
}

函数 NGUI_获取显存已用() {
    如果 (当前图处 == 空) { 返回 0 }
    如果 (当前驱动类型 == DRV_NVIDIA) {
        返回 NV_获取显存已用(当前图处)
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        返回 AMD_获取显存已用(当前图处)
    }
    返回 图处驱动_获取显存已用(当前图处)
}


结构 NGUI_命令缓冲 {
    数据,           // 地址
    大小,           // 字节数
    写位置,         // 当前写入偏移
    已提交,
}

定义 可变 NGUI_命令池 = 0
定义 可变 NGUI_命令池数量 = 0

函数 NGUI_初始化命令池() {
    如果 (NGUI_命令池 != 0) { 返回 }
    NGUI_命令池 = 堆_分配(NGUI_最大命令池 * 24)  // 每个缓冲区24字节
    定义 可变 i = 0
    当 (i < NGUI_最大命令池) {
        定义 偏移 = NGUI_命令池 + i * 24
        定义 数据 = 堆_分配(NGUI_命令缓冲大小)
        内存_写64(偏移, 数据)         // 数据指针
        内存_写32(偏移 + 8, NGUI_命令缓冲大小) // 大小
        内存_写32(偏移 + 12, 0)        // 写位置
        内存_写32(偏移 + 16, 0)        // 已提交=假
        i = i + 1
    }
    NGUI_命令池数量 = NGUI_最大命令池
}

// 获取空闲命令缓冲
函数 NGUI_获取命令缓冲() {
    如果 (NGUI_命令池 == 0) { NGUI_初始化命令池() }
    定义 可变 i = 0
    当 (i < NGUI_命令池数量) {
        定义 偏移 = NGUI_命令池 + i * 24
        如果 (内存_读32(偏移 + 16) == 0) {
            // 重置写位置
            内存_写32(偏移 + 12, 0)
            返回 偏移
        }
        i = i + 1
    }
    返回 0  // 无空闲缓冲
}

// 向命令缓冲写入数据
函数 NGUI_命令写入32(cmd, 值) {
    如果 (cmd == 0) { 返回 }
    定义 写位置 = 内存_读32(cmd + 12)
    定义 大小 = 内存_读32(cmd + 8)
    如果 (写位置 + 4 > 大小) { 返回 }  // 缓冲溡
    定义 数据 = 内存_读64(cmd)
    内存_写32(数据 + 写位置, 值)
    内存_写32(cmd + 12, 写位置 + 4)
}

// 提交命令缓冲
函数 NGUI_提交命令(cmd) {
    如果 (cmd == 0 || 当前图处 == 空) { 返回 假 }
    定义 数据 = 内存_读64(cmd)
    定义 大小 = 内存_读32(cmd + 12)  // 实际写入量

    定义 可变 结果 = 假
    如果 (当前驱动类型 == DRV_NVIDIA) {
        结果 = NV_提交命令(当前图处, 数据, 大小)
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        结果 = AMD_提交命令(当前图处, 数据, 大小)
    } 否则 {
        结果 = 图处驱动_提交命令(当前图处, 数据, 大小)
    }

    如果 (结果) {
        内存_写32(cmd + 16, 1)  // 标记已提交
        NGUI_命令提交总数 = NGUI_命令提交总数 + 1
    }
    返回 结果
}

// 回收已完成的命令缓冲
函数 NGUI_回收命令缓冲(cmd) {
    如果 (cmd == 0) { 返回 }
    内存_写32(cmd + 12, 0)  // 重置写位置
    内存_写32(cmd + 16, 0)  // 标记未提交
}


定义 可变 NGUI_下一个围栏ID = 1

函数 NGUI_创建围栏() {
    如果 (当前图处 == 空) { 返回 0 }
    定义 id = NGUI_下一个围栏ID
    NGUI_下一个围栏ID = NGUI_下一个围栏ID + 1

    定义 可变 句柄 = 0
    如果 (当前驱动类型 == DRV_NVIDIA) {
        句柄 = NV_创建围栏(当前图处, id)
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        句柄 = AMD_创建围栏(当前图处, id)
    } 否则 {
        句柄 = 图处驱动_创建围栏(当前图处, id)
    }
    NGUI_围栏总数 = NGUI_围栏总数 + 1
    返回 句柄
}

函数 NGUI_等待围栏(句柄, 超时毫秒) {
    如果 (句柄 == 0) { 返回 假 }
    如果 (当前驱动类型 == DRV_NVIDIA) {
        返回 NV_等待围栏(当前图处, 句柄, 超时毫秒)
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        返回 AMD_等待围栏(当前图处, 句柄, 超时毫秒)
    }
    返回 图处驱动_等待围栏(当前图处, 句柄, 超时毫秒)
}

函数 NGUI_释放围栏(句柄) {
    如果 (句柄 == 0) { 返回 }
    如果 (当前驱动类型 == DRV_NVIDIA) {
        NV_释放围栏(当前图处, 句柄)
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        AMD_释放围栏(当前图处, 句柄)
    } 否则 {
        图处驱动_释放围栏(当前图处, 句柄)
    }
}


定义 NGUI_电源_性能 = 0
定义 NGUI_电源_平衡 = 1
定义 NGUI_电源_节能 = 2

定义 可变 NGUI_当前电源模式 = 1  // 默认平衡

函数 NGUI_设置电源模式(模式) {
    如果 (当前图处 == 空) { 返回 }
    如果 (模式 < 0 || 模式 > 2) { 模式 = NGUI_电源_平衡 }
    NGUI_当前电源模式 = 模式

    如果 (当前驱动类型 == DRV_NVIDIA) {
        NV_设置电源模式(当前图处, 模式)
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        AMD_设置电源模式(当前图处, 模式)
    }
    内核信息("  图处电源模式: " + NGUI_电源模式名(模式))
}

函数 NGUI_电源模式名(模式) {
    如果 (模式 == NGUI_电源_性能) { 返回 "性能" }
    如果 (模式 == NGUI_电源_平衡) { 返回 "平衡" }
    如果 (模式 == NGUI_电源_节能) { 返回 "节能" }
    返回 "未知"
}

函数 NGUI_获取温度() {
    如果 (当前图处 == 空) { 返回 -1 }
    如果 (当前驱动类型 == DRV_NVIDIA) {
        返回 NV_获取温度(当前图处)
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        返回 AMD_获取温度(当前图处)
    }
    返回 -1  // 通用驱动不支持温度读取
}

函数 NGUI_获取时钟频率() {
    如果 (当前图处 == 空) { 返回 0 }
    如果 (当前驱动类型 == DRV_NVIDIA) {
        返回 NV_获取时钟频率(当前图处)
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        返回 AMD_获取时钟频率(当前图处)
    }
    返回 0
}


定义 可变 NGUI_图处列表 = 0
定义 可变 NGUI_图处数量 = 0

函数 NGUI_枚举所有图处() {
    如果 (NGUI_图处列表 == 0) {
        NGUI_图处列表 = 堆_分配(NGUI_最大图处数 * 8)
    }
    NGUI_图处数量 = 图处_获取设备数()
    如果 (NGUI_图处数量 > NGUI_最大图处数) {
        NGUI_图处数量 = NGUI_最大图处数
    }
    定义 可变 i = 0
    当 (i < NGUI_图处数量) {
        内存_写64(NGUI_图处列表 + i * 8, 图处_获取设备(i))
        i = i + 1
    }
    返回 NGUI_图处数量
}

函数 NGUI_切换主图处(索引) {
    如果 (索引 >= NGUI_图处数量) { 返回 假 }
    定义 gpu = 内存_读64(NGUI_图处列表 + 索引 * 8)
    如果 (gpu == 0) { 返回 假 }
    当前图处 = gpu
    // 重新检测驱动类型
    如果 (gpu.厂商ID == 图处_VENDOR_NVIDIA) { 当前驱动类型 = DRV_NVIDIA }
    否则如果 (gpu.厂商ID == 图处_VENDOR_AMD) { 当前驱动类型 = DRV_AMD }
    否则如果 (gpu.厂商ID == 图处_VENDOR_INTEL) { 当前驱动类型 = DRV_INTEL }
    否则 { 当前驱动类型 = DRV_GENERIC }
    内核信息("图处统一接口: 切换到图处#" + 索引)
    返回 真
}


函数 NGUI_检测故障() {
    如果 (当前图处 == 空) { 返回 假 }
    定义 可变 故障 = 假
    如果 (当前驱动类型 == DRV_NVIDIA) {
        故障 = NV_检测故障(当前图处)
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        故障 = AMD_检测故障(当前图处)
    } 否则 {
        故障 = 图处驱动_检测故障(当前图处)
    }
    如果 (故障) {
        NGUI_错误总数 = NGUI_错误总数 + 1
        内核警告("图处统一接口: 检测到GPU故障!")
    }
    返回 故障
}

函数 NGUI_故障恢复() {
    如果 (当前图处 == 空) { 返回 假 }
    内核信息("图处统一接口: 尝试GPU故障恢复...")

    定义 可变 结果 = 假
    如果 (当前驱动类型 == DRV_NVIDIA) {
        结果 = NV_重置(当前图处)
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        结果 = AMD_重置(当前图处)
    } 否则 {
        结果 = 图处驱动_重置(当前图处)
    }

    如果 (结果) {
        NGUI_恢复总数 = NGUI_恢复总数 + 1
        内核信息("图处统一接口: GPU故障恢复成功")
        // 重新初始化渲染管线
        渲染管线_重置()
    } 否则 {
        内核警告("图处统一接口: GPU故障恢复失败, 回退CPU渲染")
        当前驱动类型 = DRV_NONE
    }
    返回 结果
}


定义 可变 NGUI_AI预测次数 = 0

函数 NGUI_AI提取特征() {
    定义 t = Tensor_创建(10)
    如果 (t == 0) { 返回 0 }
    Tensor_写(t, 0, 当前驱动类型)               // f0: 驱动类型
    定义 显存总 = NGUI_获取显存总量()
    定义 显存用 = NGUI_获取显存已用()
    Tensor_写(t, 1, 显存总 / 1048576)             // f1: 显存总量MB
    定义 使用率 = 0
    如果 (显存总 > 0) { 使用率 = 显存用 * 100 / 显存总 }
    Tensor_写(t, 2, 使用率)                      // f2: 显存使用率%
    Tensor_写(t, 3, NGUI_获取温度())             // f3: 温度
    Tensor_写(t, 4, NGUI_获取时钟频率())         // f4: 时钟频率
    Tensor_写(t, 5, NGUI_当前电源模式)           // f5: 电源模式
    Tensor_写(t, 6, NGUI_命令提交总数)           // f6: 命令提交总数
    Tensor_写(t, 7, NGUI_围栏总数)               // f7: 围栏总数
    Tensor_写(t, 8, NGUI_错误总数)               // f8: 错误总数
    Tensor_写(t, 9, NGUI_图处数量)               // f9: GPU数量
    返回 t
}

函数 NGUI_AI预测GPU性能() {
    定义 特征 = NGUI_AI提取特征()
    如果 (特征 == 0) { 返回 }

    定义 显存使用率 = Tensor_读(特征, 2)
    定义 温度 = Tensor_读(特征, 3)
    定义 错误数 = Tensor_读(特征, 8)

    // 规则: 显存使用率过高→建议清理
    如果 (显存使用率 > 90) {
        全局AI总线.发布("ngui_显存警告", "显存使用率过高", 显存使用率)
    }

    // 规则: 温度过高→降频建议
    如果 (温度 > 85) {
        全局AI总线.发布("ngui_温度警告", "图处过热", 温度)
        // 自动切换到节能模式
        如果 (NGUI_当前电源模式 == NGUI_电源_性能) {
            NGUI_设置电源模式(NGUI_电源_平衡)
        }
    }

    // 异常检测: 错误率过高
    如果 (错误数 > 10) {
        AI总线_异常检测("NGUI_GPU错误率异常", 错误数)
    }

    Tensor_释放(特征)
    NGUI_AI预测次数 = NGUI_AI预测次数 + 1
}


函数 图处_统一关机() {
    内核信息("图处统一接口: 开始关机...")
    // 释放命令池
    如果 (NGUI_命令池 != 0) {
        定义 可变 i = 0
        当 (i < NGUI_命令池数量) {
            定义 偏移 = NGUI_命令池 + i * 24
            定义 数据 = 内存_读64(偏移)
            如果 (数据 != 0) { 堆_释放(数据) }
            i = i + 1
        }
        堆_释放(NGUI_命令池)
        NGUI_命令池 = 0
    }
    // 关闭驱动
    如果 (当前图处 != 空) {
        如果 (当前驱动类型 == DRV_NVIDIA) { NV_关机(当前图处) }
        否则如果 (当前驱动类型 == DRV_AMD) { AMD_关机(当前图处) }
        否则 { 图处驱动_关机(当前图处) }
    }
    当前图处 = 空
    当前驱动类型 = DRV_NONE
    内核信息("图处统一接口: 关机完成")
}


函数 NGUI_获取统计() {
    返回 [
        NGUI_命令提交总数,
        NGUI_围栏总数,
        NGUI_显存分配总数,
        NGUI_错误总数,
        NGUI_恢复总数,
        NGUI_AI预测次数
    ]
}

函数 NGUI_重置统计() {
    NGUI_命令提交总数 = 0
    NGUI_围栏总数 = 0
    NGUI_显存分配总数 = 0
    NGUI_错误总数 = 0
    NGUI_恢复总数 = 0
    NGUI_AI预测次数 = 0
}
// §1 驱动类型枚举

定义 DRV_NONE     = 0
定义 DRV_NVIDIA   = 1
定义 DRV_AMD      = 2
定义 DRV_INTEL    = 3
定义 DRV_VIRTIO   = 4
定义 DRV_GENERIC  = 5

定义 可变 当前驱动类型 = DRV_NONE
定义 可变 当前图处 = 空

// §2 自动探测 + 选择正确驱动

函数 图处_统一初始化() {
    内核信息("图处统一接口: 开始图处探测...")

    // 步骤1: PCI枚举所有图处
    图处_枚举()

    定义 gpu = 图处_获取主设备()
    如果 (gpu == 空) {
        内核警告("图处统一接口: 未发现图处, 使用纯CPU渲染")
        当前驱动类型 = DRV_NONE
        返回
    }
    当前图处 = gpu

    // 步骤2: 根据厂商ID选择驱动
    如果 (gpu.厂商ID == 图处_VENDOR_NVIDIA) {
        内核信息("图处统一接口: 检测到NVIDIA 图处 → 加载nova-nv驱动")
        NV_识别完整型号(gpu)
        定义 结果 = NV_初始化(gpu)
        如果 (结果 == 成功) {
            当前驱动类型 = DRV_NVIDIA
        } 否则 {
            内核警告("图处统一接口: NVIDIA驱动初始化失败, 回退通用驱动")
            当前驱动类型 = DRV_GENERIC
            图处驱动_初始化(gpu)
        }

    } 否则如果 (gpu.厂商ID == 图处_VENDOR_AMD) {
        内核信息("图处统一接口: 检测到AMD 图处 → 加载nova-amd驱动")
        AMD_识别完整型号(gpu)
        定义 结果 = AMD_初始化(gpu)
        如果 (结果 == 成功) {
            当前驱动类型 = DRV_AMD
        } 否则 {
            内核警告("图处统一接口: AMD驱动初始化失败, 回退通用驱动")
            当前驱动类型 = DRV_GENERIC
            图处驱动_初始化(gpu)
        }

    } 否则如果 (gpu.厂商ID == 图处_VENDOR_INTEL) {
        内核信息("图处统一接口: 检测到Intel 图处 → 加载通用驱动(Intel专用驱动待扩展)")
        当前驱动类型 = DRV_INTEL
        图处驱动_初始化(gpu)

    } 否则如果 (gpu.厂商ID == 图处_VENDOR_VIRTIO || gpu.厂商ID == 图处_VENDOR_QEMU || gpu.厂商ID == 图处_VENDOR_VMWARE) {
        内核信息("图处统一接口: 检测到虚拟图处 → 加载通用驱动")
        当前驱动类型 = DRV_VIRTIO
        图处驱动_初始化(gpu)

    } 否则 {
        内核信息("图处统一接口: 未知厂商 0x" + 整数转十六进制(gpu.厂商ID) + " → 通用驱动")
        当前驱动类型 = DRV_GENERIC
        图处驱动_初始化(gpu)
    }

    // 步骤3: 初始化渲染管线(对接窗口合成器)
    定义 可变 宽 = 1920
    定义 可变 高 = 1080
    渲染管线_初始化(宽, 高, 32)

    // 步骤4: 打印最终状态
    图处_统一打印状态()
}

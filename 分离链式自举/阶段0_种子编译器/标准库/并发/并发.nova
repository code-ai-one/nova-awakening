导入("../向量计算/向量原语.nova")
导入("../基础.nova")
导入("../系统/硬件库.nova")
导入("../数学/工具.nova")

// Lock = "把"字独占 (线性消费: 同一时刻只能被一人"把"住)
// Unlock = "给"字归还 (所有权交回公共域)
// Channel = "把"字发送 + "给"字接收 (所有权跨气脉转移)
用 "../基础.nova"
用 "../数据结构/数据结构.nova"

定义 可变 __并发_tick = 0
定义 可变 NOGL_调度次数 = 0
定义 NOGL_调度_固定 = 0
定义 NOGL_调度_衰减 = 1
定义 NOGL_调度_余弦退火 = 2
定义 NOGL_调度_周期 = 3
// 原子变量 (模拟)
// 型: [值]
函数 原子_创建(初始值) { 返回 [初始值] }
函数 原子_读(a) { 返回 a[0] }
函数 原子_写(a, 值) { a[0] = 值 }
函数 并发_原子_加(a, n) { 定义 旧值 = a[0]
 a[0] = a[0] + n
 返回 旧值
}
函数 原子_减(a, n) { 返回 并发_原子_加(a, 0 - n) }
函数 原子_递增(a) { 返回 并发_原子_加(a, 1) }
函数 原子_递减(a) { 返回 并发_原子_加(a, -1) }
函数 原子_CAS(a, 期望, 新值) { 如果 (a[0] == 期望) {
 a[0] = 新值
 返回 真
 }
 返回 假
}
函数 原子_交换(a, 新值) { 定义 旧值 = a[0]
 a[0] = 新值
 返回 旧值
}

// 自旋锁 (Spinlock)
// 型: [锁状态(0=未锁,1=锁定), 持有者ID]
函数 并发_自旋锁_创建() { 返回 [0, -1] }
函数 自旋锁_锁定(锁) {
    如果 (锁[0] == 1) { 返回 假
}
 锁[0] = 1
 返回 真
}
函数 自旋锁_解锁(锁) { 锁[0] = 0
锁[1] = -1 }
函数 自旋锁_尝试(锁) { 如果 (锁[0] == 0) {
 锁[0] = 1
 返回 真
 }
 返回 假
}
函数 自旋锁_已锁(锁) { 返回 锁[0] == 1 }

// 读写锁 (RWLock)
// 型: [读者数, 写者标记, 等待写者数]
函数 并发_读写锁_创建() { 返回 [0,] }
函数 读写锁_读锁(锁) { 如果 (锁[1] == 0 且 锁[2] == 0) {
 锁[0] = 锁[0] + 1
 返回 真
 }
 返回 假
}
函数 并发_读写锁_读解锁(锁) {
    如果 (锁[0] > 0) { 锁[0] = 锁[0] - 1
}
}
函数 读写锁_写锁(锁) {
 锁[2] = 锁[2] + 1
 如果 (锁[1] == 0 且 锁[0] == 0) {
 锁[1] = 1
 锁[2] = 锁[2] - 1
 返回 真
 }
 锁[2] = 锁[2] - 1
 返回 假
}
函数 并发_读写锁_写解锁(锁) { 锁[1] = 0 }

// 互斥锁 (Mutex)
// 型: [锁状态, 递归计数, 持有者]
函数 并发_互斥锁_创建() { 返回 [0, 0, -1] }
函数 互斥锁_锁定(m, 线程id) {
 互斥锁_确保计数(m)
 如果 (m[0] == 0) {
 m[0] = 1
 m[1] = 1
 m[2] = 线程id
 返回 真
 }
 如果 (m[2] == 线程id) {
 m[1] = m[1] + 1
 返回 真
 }
 返回 假
}
函数 并发_互斥锁_解锁(m, 线程id) {
    如果 (m[2] != 线程id) { 返回 假
}
 m[1] = m[1] - 1
 如果 (m[1] == 0) {
 m[0] = 0
 m[2] = -1
 }
 返回 真
}

// 信号量 (Semaphore)
// 型: [计数, 最大值]
函数 并发_信号量_创建(初始, 最大) { 返回 [初始, 最大] }
函数 并发_信号量_获取(sem) { 如果 (sem[0] > 0) {
 sem[0] = sem[0] - 1
 返回 真
 }
 返回 假
}
函数 并发_信号量_释放(sem) { 如果 (sem[0] < sem[1]) {
 sem[0] = sem[0] + 1
 返回 真
 }
 返回 假
}
函数 信号量_值(sem) { 返回 sem[0] }

// 无锁队列 (Lock-Free Queue — MPSC)
// 型: [数组, 容量, 头, 尾, 计数]
函数 无锁队列_创建(容量) { 定义 可变 数组 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(数组, 0)
 i = i + 1 }
 返回 [数组, 容量, 0, 0]
}
函数 无锁队列_入队(q, 值) {
    如果 (q[4] >= q[1]) { 返回 假
}
 q[0][q[3]] = 值
 q[3] = (q[3] + 1) % q[1]
 q[4] = q[4] + 1
 返回 真
}
函数 无锁队列_出队(q) {
    如果 (q[4] == 0) { 返回 空
}
 定义 v = q[0][q[2]]
 q[2] = (q[2] + 1) % q[1]
 q[4] = q[4] - 1
 返回 v
}
函数 无锁队列_大小(q) { 返回 q[4] }
函数 无锁队列_空吗(q) { 返回 q[4] == 0 }

// Future/Promise
// 状态: 0=等待, 1=完成, 2=拒绝
// 型: [状态, 值, 错误, 回调列表]
函数 PPromise_创建() { 返回 [0, 空, 空, []] }
函数 PPromise_完成(p, 值) {
    如果 (p[0] != 0) { 返回 假
}
 p[0] = 1
 p[1] = 值
 返回 真
}
函数 PPromise_拒绝(p, 错误) {
    如果 (p[0] != 0) { 返回 假
}
 p[0] = 2
 p[2] = 错误
 返回 真
}
函数 PPromise_已完成(p) { 返回 p[0] == 1 }
函数 PPromise_已拒绝(p) { 返回 p[0] == 2 }
函数 PPromise_等待中(p) { 返回 p[0] == 0 }
函数 PPromise_值(p) { 返回 p[1] }
函数 PPromise_错误(p) { 返回 p[2] }

// 通道 (Channel — CSP风格)
// 型: [缓冲数组, 容量, 头, 尾, 计数, 已关闭]
函数 并发_通道_创建(容量) { 定义 可变 数组 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(数组, 0)
 i = i + 1 }
 返回 [数组, 容量, 0,]
}
函数 并发_通道_发送(ch, 值) {
    如果 (ch[5] == 1) { 返回 假
}
 如果 (ch[4] >= ch[1]) { 返回 假 }
 ch[0][ch[3]] = 值
 ch[3] = (ch[3] + 1) % ch[1]
 ch[4] = ch[4] + 1
 返回 真
}
函数 并发_通道_接收(ch) {
    如果 (ch[4] == 0) { 返回 空
}
 定义 v = ch[0][ch[2]]
 ch[2] = (ch[2] + 1) % ch[1]
 ch[4] = ch[4] - 1
 返回 v
}
函数 并发_通道_尝试接收(ch) {
    如果 (ch[4] == 0) { 返回 [空, 假]
}
 返回 [并发_通道_接收(ch), 真]
}
函数 并发_通道_关闭(ch) { ch[5] = 1 }
函数 并发_通道_已关闭(ch) { 返回 ch[5] == 1 }
函数 并发_通道_大小(ch) { 返回 ch[4] }

// 工作窃取队列 (Work-Stealing Deque)
// 型: [数组, 容量, 顶, 底]
函数 工作队列_创建(容量) { 定义 可变 数组 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(数组, 0)
 i = i + 1 }
 返回 [数组, 容量,]
}
函数 工作队列_推(wq, 任务) {
    如果 (wq[3] - wq[2] >= wq[1]) { 返回 假
}
 wq[0][wq[3] % wq[1]] = 任务
 wq[3] = wq[3] + 1
 返回 真
}
函数 工作队列_弹(wq) {
    如果 (wq[3] <= wq[2]) { 返回 空
}
 wq[3] = wq[3] - 1
 返回 wq[0][wq[3] % wq[1]]
}
函数 工作队列_窃取(wq) {
    如果 (wq[2] >= wq[3]) { 返回 空
}
 定义 v = wq[0][wq[2] % wq[1]]
 wq[2] = wq[2] + 1
 返回 v
}
函数 工作队列_大小(wq) { 返回 wq[3] - wq[2] }

// 线程池模拟
// 型: [任务队列, 工作者数, 已完成数]
函数 并发_线程池_创建(工作者数, 队列大小) { 定义 可变 数组 = []
 定义 可变 i = 0
 当 (i < 队列大小) { 追加(数组, 0)
 i = i + 1 }
 返回 [[数组, 队列大小, 0, 0], 工作者数, 0]
}
函数 并发_线程池_提交(pool, 任务) { 返回 无锁队列_入队(pool[0], 任务)
}
函数 线程池_执行一个(pool) { 定义 任务 = 无锁队列_出队(pool[0])
 如果 (任务 == 空) { 返回 假 }
 pool[2] = pool[2] + 1
 返回 真
}
函数 并发_线程池_待处理(pool) { 返回 无锁队列_大小(pool[0]) }
函数 线程池_已完成(pool) { 返回 pool[2] }

// 屏障 (Barrier)
// 型: [总数, 已到达, 代]
函数 并发_屏障_创建(参与者数) { 返回 [参与者数,] }
函数 屏障_等待(b) {
 b[1] = b[1] + 1
 如果 (b[1] >= b[0]) {
 b[1] = 0
 b[2] = b[2] + 1
 返回 真
 }
 返回 假
}
函数 屏障_代(b) { 返回 b[2] }

// 线程池活跃数
函数 并发_线程池_活跃数(pool) { 返回 pool[1] - 无锁队列_大小(pool[0]) - pool[2] }

// 通道排空
函数 通道_排空(ch) { 定义 可变 结果 = []
 当 (并发_通道_大小(ch) > 0) { 追加(结果, 并发_通道_接收(ch)) }
 返回 结果
}

// 合并自 标准库/系统/并发.nova

函数 fFuture_值(f) { 返回 f[1]
}

函数 并发_future_创建() { 返回 [假, 空, 空]
}

函数 future_失败(f, 错误) {
 f[0] = 真
 f[2] = 错误
}

函数 并发_future_完成(f, 值) {
 f[0] = 真
 f[1] = 值
}

函数 future_就绪(f) { 返回 f[0]
}

函数 future_错误(f) { 返回 f[2]
}

函数 互斥锁_已锁(mutex) { 返回 mutex[0]
}

函数 互斥锁_确保计数(mutex) {
    如果 (计数(mutex) < 3) { 追加(mutex, 0)
}
}

// 互斥锁_锁定 已在上方定义(含确保计数)

函数 任务池_创建(最大并发) { 返回 [[], 最大并发,]
}

函数 任务池_执行(池) { 定义 任务列表 = 池[0]
 定义 可变 完成数 = 0
 定义 可变 i = 0
 定义 可变 上限 = 池[1]
 如果 (上限 <= 0) { 上限 = 1 }
 当 (i < 计数(任务列表) 且 完成数 < 上限) { 定义 任务 = 任务列表[i]
 如果 (任务[1] == 假) {
 任务[2] = 任务[0]()
 任务[1] = 真
 完成数 = 完成数 + 1
 }
 i = i + 1
 }
 池[2] = 池[2] + 完成数
 返回 完成数
}

函数 任务池_提交(池, 任务函数) {
 追加(池[0], [任务函数, 假, 空])
 池[3] = 池[3] + 1
}

函数 任务池_结果(池) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(池[0])) { 如果 (池[0][i][1]) {
 追加(结果, 池[0][i][2])
 }
 i = i + 1
 }
 返回 结果
}

// 信号量_获取 已在上方定义

函数 并发_协程_创建(id, 任务, 优先级) { 返回 [id, 协程_就绪, 任务, 优先级, 空]
}

函数 并发_当前tick() { 定义 t = 时间戳()
 如果 (t == 空 或 t <= 0) { __并发_tick = __并发_tick + 1
 返回 __并发_tick
 }
 返回 t
}

函数 消息_发送(队列, 发送者, 接收者, 类型, 数据) { 定义 消息 = [发送者, 接收者, 类型, 数据, 并发_当前tick()]
 追加(队列[0], 消息)
 队列[1] = 队列[1] + 1
}

函数 消息_大小(队列) { 定义 可变 活跃 = 0
 定义 可变 i = 0
 当 (i < 计数(队列[0])) { 如果 (队列[0][i] != 空) { 活跃 = 活跃 + 1 }
 i = i + 1
 }
 返回 活跃
}

函数 消息_按类型接收(队列, 类型) { 定义 消息列表 = 队列[0]
 定义 可变 i = 0
 当 (i < 计数(消息列表)) { 定义 m = 消息列表[i]
 如果 (m != 空 且 m[2] == 类型) {
 消息列表[i] = 空
 返回 m
 }
 i = i + 1
 }
 返回 空
}

函数 消息_接收(队列, 接收者) { 定义 消息列表 = 队列[0]
 定义 可变 i = 0
 当 (i < 计数(消息列表)) { 定义 m = 消息列表[i]
 如果 (m != 空 且 m[1] == 接收者) {
 消息列表[i] = 空
 返回 m
 }
 i = i + 1
 }
 返回 空
}

函数 消息队列_创建() { 返回 [[], 0]
}

函数 并发_管道_创建() { 返回 [[]]
}

函数 管道_执行(管道, 输入) { 定义 阶段 = 管道[0]
 定义 可变 数据 = 输入
 定义 可变 i = 0
 当 (i < 计数(阶段)) {
 数据 = 阶段[i](数据)
 i = i + 1
 }
 返回 数据
}

函数 管道_批量(管道, 输入列表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(输入列表)) {
 追加(结果, 管道_执行(管道, 输入列表[i]))
 i = i + 1
 }
 返回 结果
}

函数 管道_添加阶段(管道, 处理函数) {
 追加(管道[0], 处理函数)
}

函数 调度器_一轮(调度) { 定义 协程列表 = 调度[0]
 定义 n = 计数(协程列表)
 定义 可变 执行了 = 假
 // 找最高优先级就绪协程
 定义 可变 最高i = -1
 定义 可变 最高优先 = -1
 定义 可变 起点 = 0
 如果 (计数(调度) >= 4) { 起点 = 调度[3] % n }
 定义 可变 i = 0
 当 (i < n) { 定义 索引 = (起点 + i) % n
 定义 c = 协程列表[索引]
 如果 (c[1] == 协程_就绪 且 c[3] > 最高优先) {
 最高i = 索引
 最高优先 = c[3]
 }
 i = i + 1
 }
 如果 (最高i >= 0) { 定义 c = 协程列表[最高i]
 c[1] = 协程_运行
 c[4] = c[2]()
 c[1] = 协程_完成
 调度[2] = 调度[2] + 1
 如果 (计数(调度) >= 4) { 调度[3] = (最高i + 1) % n }
 执行了 = 真
 }
 返回 执行了
}

函数 调度器_全部完成(sched) { 定义 可变 完成 = 真
 定义 可变 i = 0
 当 (i < 计数(sched[0])) { 定义 c = sched[0][i]
 如果 (c[1] != 协程_完成) {
 完成 = 假
 退出
 }
 i = i + 1
 }
 返回 完成
}

函数 调度器_步进(sched) {
    如果 (调度器_一轮(sched)) { 返回 0 }
    返回 -1
}

函数 调度器_创建2() { 返回 [[], 0, 0] }

// [v2反哺] 调度器_步进 — 调度器→余弦退火v2(4阶Taylor精确版, 替换旧1-2t²)
// 余弦退火v2 — 4阶Taylor精确版
// 修复: 旧版1-2t²在t=0.5误差50% → 4阶Taylor误差<1%
// cos(πt) ≈ 1 - (πt)²/2 + (πt)⁴/24
函数 调度器_步进_v2(s) {
    NOGL_调度次数 = NOGL_调度次数 + 1
    s.当前步 = s.当前步 + 1
    如果 (s.策略 == NOGL_调度_固定) { 返回 s.初始LR }
    如果 (s.策略 == NOGL_调度_衰减) {
        // 修复: 用Q快速幂整数精确计算衰减
        定义 衰减_t = Q快速幂整数(s.衰减因子, s.当前步)
        定义 可变 lr = Q乘(s.初始LR, 衰减_t)
        如果 (lr < s.最小LR) { lr = s.最小LR }
        返回 lr
    }
    如果 (s.策略 == NOGL_调度_余弦退火) {
        定义 t = (s.当前步 % s.周期步数) * 定点_一 / s.周期步数
        // 4阶Taylor: cos(πt) = 1 - (πt)²/2 + (πt)⁴/24
        定义 FP = 10000;  定义 FP_PI = 31416
        定义 pt = t * FP_PI / FP
        定义 pt2 = pt * pt / FP;  定义 pt4 = pt2 * pt2 / FP
        定义 余弦值 = (FP - pt2 / 2 + pt4 / 24) * 定点_一 / FP
        定义 range = s.初始LR - s.最小LR
        返回 s.最小LR + Q乘(range, (定点_一 + 余弦值) / 2)
    }
    如果 (s.策略 == NOGL_调度_周期) {
        定义 一半 = s.周期步数 / 2
        定义 位置 = s.当前步 % s.周期步数
        如果 (位置 < 一半) { 返回 s.最小LR + (s.初始LR - s.最小LR) * 位置 / 一半 }
        如果 (一半 == 0) { 返回 0 }
        返回 s.初始LR - (s.初始LR - s.最小LR) * (位置 - 一半) / 一半
    }
    返回 s.初始LR
}

函数 调度器_添加协程(调度, 协程) {
    如果 (计数(调度) < 4) { 追加(调度, 0)
}
 追加(调度[0], 协程)
 调度[1] = 调度[1] + 1
}

函数 调度器_运行到完成(sched) {
    定义 可变 安全计数 = 0
 定义 可变 总步 = 0
 定义 可变 i = 0
 当 (i < 计数(sched[0])) { 如果 (sched[0][i][2] > 0) { 总步 = 总步 + sched[0][i][2] }
 i = i + 1
 }
 定义 可变 安全上限 = 总步 + 计数(sched[0]) * 2
 当 (调度器_全部完成(sched) == 假 且 安全计数 < 安全上限) { 如果 (调度器_步进(sched) == -1) { 返回 }
 安全计数 = 安全计数 + 1
 }
}

// Nova · 跨语言智能协作 · 补丁评审
// 职责: AI生成的重置补丁在落地前的结构化审查
// 层级: M23子模块 — 补丁暂存、diff分析、安全/语义/fixed-point校验

// 补丁状态

导入("../../../标准库/基础.nova")

定义 补丁_暂存   = 0
定义 补丁_审中   = 1
定义 补丁_通过   = 2
定义 补丁_拒绝   = 3
定义 补丁_回滚   = 4

// 补丁: [ID, 目标文件, 操作类型, 旧内容, 新内容, 状态, 审查结果列表]
函数 补丁_创建(id, 目标文件, 操作, 旧内容, 新内容) {
    返回 [id, 目标文件, 操作, 旧内容, 新内容, 补丁_暂存, []]
}

函数 补丁_ID(p) { 返回 p[0] }
函数 补丁_目标(p) { 返回 p[1] }
函数 补丁_操作(p) { 返回 p[2] }
函数 补丁_状态(p) { 返回 p[5] }
函数 补丁_审查(p) { 返回 p[6] }

// 审查结果: [维度, 通过, 描述]
定义 审查_语义完整 = 0
定义 审查_安全门控 = 1
定义 审查_类型正确 = 2
定义 审查_风格合规 = 3
定义 审查_克隆安全 = 4

函数 审查结果_创建(维度, 通过, 描述) {
    返回 [维度, 通过, 描述]
}

// 补丁暂存区: [补丁列表, 总数, 通过数, 拒绝数]
函数 暂存区_创建() {
    返回 [[], 0, 0]
}

函数 暂存区_添加(暂存, 补丁) {
    追加(暂存[0], 补丁)
    暂存[1] = 暂存[1] + 1
}

// 执行补丁审查
函数 补丁_执行审查(补丁) {
    补丁[5] = 补丁_审中

    // 1. 语义完整性: 新内容不为空
    定义 可变 语义通过 = 真
    如果 (补丁[4] == "" 或 补丁[4] == 空) { 语义通过 = 假 }
    追加(补丁[6], 审查结果_创建(审查_语义完整, 语义通过, "新内容非空"))

    // 2. 安全门控: 不含危险模式
    定义 安全通过 = _检查安全模式(补丁[4])
    追加(补丁[6], 审查结果_创建(审查_安全门控, 安全通过, "安全模式检查"))

    // 3. 类型正确: Nova风格检查
    定义 类型通过 = _检查Nova风格(补丁[4])
    追加(补丁[6], 审查结果_创建(审查_类型正确, 类型通过, "Nova风格检查"))

    // 4. 克隆安全: 不含外源注释直接复制
    定义 克隆通过 = _检查无外源注释(补丁[4])
    追加(补丁[6], 审查结果_创建(审查_克隆安全, 克隆通过, "无外源注释复制"))

    // 综合判定
    如果 (语义通过 且 安全通过 且 类型通过 且 克隆通过) {
        补丁[5] = 补丁_通过
    } 否则 {
        补丁[5] = 补丁_拒绝
    }
    返回 补丁
}

// 批量审查
函数 暂存区_批量审查(暂存) {
    定义 可变 i = 0
    当 (i < 计数(暂存[0])) {
        补丁_执行审查(暂存[0][i])
        如果 (暂存[0][i][5] == 补丁_通过) { 暂存[2] = 暂存[2] + 1 }
        如果 (暂存[0][i][5] == 补丁_拒绝) { 暂存[3] = 暂存[3] + 1 }
        i = i + 1
    }
}

// 回滚补丁
函数 补丁_回滚(补丁) {
    补丁[5] = 补丁_回滚
}

// 暂存区报告
函数 暂存区_打印(暂存) {
    打印("═══ 补丁评审报告 ═══")
    打印文本(字符串拼接("  总补丁数: ", 转字符串(暂存[1])))
    打印文本(字符串拼接("  通过: ", 转字符串(暂存[2])))
    打印文本(字符串拼接("  拒绝: ", 转字符串(暂存[3])))
    打印文本(字符串拼接("  通过率: ", 字符串拼接(转字符串(暂存[2] * 100 / (暂存[1] + 1)), "%")))
}

// 辅助: 安全模式检查
函数 _检查安全模式(内容) {
    如果 (内容 == 空) { 返回 假 }
    // 不允许直接系统调用
    如果 (_含子串(内容, "系统调用(")) { 返回 假 }
    // 不允许裸指针操作
    如果 (_含子串(内容,  "裸指针")) { 返回 假 }
    返回 真
}

// 辅助: Nova风格检查
函数 _检查Nova风格(内容) {
    如果 (内容 == 空) { 返回 假 }
    // 检查是否使用Nova关键字(函数/定义/如果/当)
    如果 (_含子串(内容,  "函数 ") 或 _含子串(内容,  "定义 ") 或 _含子串(内容,  "如果 ") 或 _含子串(内容,  "当 ")) {
        返回 真
    }
    // 纯注释也可以
    如果 (_含子串(内容,  "//")) { 返回 真 }
    返回 假
}

// 辅助: 外源注释检查
函数 _检查无外源注释(内容) {
    如果 (内容 == 空) { 返回 真 }
    // 不应包含英文版权注释
    如果 (_含子串(内容,  "Copyright") 或 _含子串(内容,  "LICENSE") 或 _含子串(内容,  "All rights reserved")) {
        返回 假
    }
    返回 真
}

函数 _含子串(s, 子串) {
    定义 sl = 字节长度(s)
    定义 pl = 字节长度(子串)
    如果 (pl > sl) { 返回 假 }
    定义 可变 i = 0
    当 (i <= sl - pl) {
        如果 (子串(s, i, pl) == 子串) { 返回 真 }
        i = i + 1
    }
    返回 假
}

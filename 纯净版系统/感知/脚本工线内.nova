// §5 importScripts — 工线内加载额外脚本

函数 工线_importScripts(w, URL列表, URL数量) {
    如果 (w == 0) { 返回 }
    // 同步下载并执行(阻塞工线线程)
    定义 可变 i = 0
    当 (i < URL数量) {
        定义 url = 内存_读64(URL列表 + i * 8)
        如果 (url != 0) {
            定义 内容 = 网络_同步获取(url)
            如果 (内容 != 0) {
                // 在工线的Nova运行时实例中执行脚本
            }
        }
        i = i + 1
    }
}

// §6 Shared工线 — 共享工线

结构 Shared工线 {
    脚本URL,
    名称,    // u64 工线名称(用于查找已有实例)
    状态,
    Nova运行时实例,
    // 连接的端口列表
    端口列表,    // u64 MessagePort*数组
    端口数量,
    端口容量,
}

定义 可变 共享工线列表 = 0
定义 可变 共享工线数量 = 0
定义 可变 共享工线容量 = 0

函数 Shared工线_创建(脚本URL, 名称) {
    // 查找已有的同名Shared工线
    定义 已有 = Shared工线_查找(脚本URL, 名称)
    如果 (已有 != 0) {
        // 创建新连接端口
        定义 ch = MessageChannel_创建()
        Shared工线_添加端口(已有, ch.port2)
        // 触发connect事件
        返回 ch.port1
    }

    // 创建新的Shared工线
    定义 sw = 堆_分配(Shared工线)
    sw.脚本URL = 字符串_复制(脚本URL)
    sw.名称 = 名称 != 0 ? 字符串_复制(名称) : ""
    sw.状态 = WORKER_STATE_PENDING
    sw.Nova运行时实例 = Nova运行时_创建()
    sw.端口容量 = 32
    sw.端口列表 = 堆_分配_数组(32 * 8)
    sw.端口数量 = 0

    // 注册到全局列表
    如果 (共享工线列表 == 0) {
        共享工线容量 = 16
        共享工线列表 = 堆_分配_数组(16 * 8)
        共享工线数量 = 0
    }
    如果 (共享工线数量 < 共享工线容量) {
        内存_写64(共享工线列表 + 共享工线数量 * 8, sw)
        共享工线数量 = 共享工线数量 + 1
    }

    // 创建第一个连接
    定义 ch = MessageChannel_创建()
    Shared工线_添加端口(sw, ch.port2)

    // 加载并执行脚本
    sw.状态 = WORKER_STATE_RUNNING

    返回 ch.port1
}

函数 Shared工线_查找(脚本URL, 名称) {
    定义 可变 i = 0
    当 (i < 共享工线数量) {
        定义 sw = 内存_读64(共享工线列表 + i * 8)
        如果 (sw != 0 && 字符串_相等(sw.脚本URL, 脚本URL)) {
            如果 (名称 == 0 || 字符串_相等(sw.名称, 名称)) {
                返回 sw
            }
        }
        i = i + 1
    }
    返回 0
}

函数 Shared工线_添加端口(sw, port) {
    如果 (sw == 0 || sw.端口数量 >= sw.端口容量) { 返回 }
    内存_写64(sw.端口列表 + sw.端口数量 * 8, port)
    sw.端口数量 = sw.端口数量 + 1
    port.所属worker = sw
}

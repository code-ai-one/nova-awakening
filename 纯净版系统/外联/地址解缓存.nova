定义 ARP_老化间隔秒 = 30
定义 ARP_可达超时秒 = 300
定义 ARP_过期超时秒 = 60
定义 ARP_延迟超时秒 = 5
定义 ARP_探测超时秒 = 3
定义 ARP_不完整超时秒 = 3
定义 ARP_最大探测次数 = 3
定义 ARP_最大等待队列 = 8

定义 可变 ARP_老化次数 = 0
定义 可变 ARP_老化删除数 = 0
定义 可变 ARP_状态转换数 = 0
定义 可变 ARP_代理应答数 = 0
定义 可变 ARP_免费ARP数 = 0

函数 arp_缓存老化() {
    定义 当前时间 = 当前时间_秒()
    自旋锁_获取(全局ARP缓存.锁)
    ARP_老化次数 = ARP_老化次数 + 1

    定义 可变 桶号 = 0
    当 (桶号 < ARP_缓存_桶数) {
        定义 可变 前一个 = 空
        定义 可变 当前 = 全局ARP缓存.桶[桶号]

        当 (当前 != 空) {
            定义 下一个 = 当前.下一个

            如果 (当前.状态 == ARP_状态_永久) {
                前一个 = 当前
                当前 = 下一个
                继续
            }

            定义 年龄 = 当前时间 - 当前.最后确认时间

            如果 (当前.状态 == ARP_状态_可达) {
                如果 (年龄 > ARP_可达超时秒) {
                    当前.状态 = ARP_状态_过期
                    当前.最后确认时间 = 当前时间
                    ARP_状态转换数 = ARP_状态转换数 + 1
                }
            } 否则如果 (当前.状态 == ARP_状态_过期) {
                如果 (年龄 > ARP_过期超时秒) {
                    arp_删除条目(桶号, 前一个, 当前)
                    当前 = 下一个
                    继续
                }
            } 否则如果 (当前.状态 == ARP_状态_延迟) {
                如果 (年龄 > ARP_延迟超时秒) {
                    当前.状态 = ARP_状态_探测
                    当前.探测次数 = 0
                    当前.最后确认时间 = 当前时间
                    ARP_状态转换数 = ARP_状态转换数 + 1
                    arp_发送单播探测(当前)
                }
            } 否则如果 (当前.状态 == ARP_状态_探测) {
                如果 (年龄 > ARP_探测超时秒) {
                    当前.探测次数 = 当前.探测次数 + 1
                    如果 (当前.探测次数 >= ARP_最大探测次数) {
                        arp_删除条目(桶号, 前一个, 当前)
                        当前 = 下一个
                        继续
                    }
                    当前.最后确认时间 = 当前时间
                    arp_发送单播探测(当前)
                }
            } 否则如果 (当前.状态 == ARP_状态_不完整) {
                如果 (年龄 > ARP_不完整超时秒) {
                    当前.探测次数 = 当前.探测次数 + 1
                    如果 (当前.探测次数 >= ARP_最大探测次数) {
                        arp_删除条目(桶号, 前一个, 当前)
                        当前 = 下一个
                        继续
                    }
                    当前.最后确认时间 = 当前时间
                    arp_发送广播请求(当前.IP地址)
                }
            }

            前一个 = 当前
            当前 = 下一个
        }
        桶号 = 桶号 + 1
    }

    自旋锁_释放(全局ARP缓存.锁)
}

函数 arp_删除条目(桶号, 前一个, 当前) {
    如果 (前一个 == 空) {
        全局ARP缓存.桶[桶号] = 当前.下一个
    } 否则 {
        前一个.下一个 = 当前.下一个
    }
    arp_清空等待队列(当前)
    释放内存(当前)
    全局ARP缓存.条目数 = 全局ARP缓存.条目数 - 1
    ARP_老化删除数 = ARP_老化删除数 + 1
}

函数 arp_发送单播探测(条目) {
    如果 (条目 == 空) { 返回 }
    arp_构建请求包(条目.IP地址, 条目.MAC地址, ARP_操作_请求)
}

函数 arp_发送广播请求(目标IP) {
    定义 广播MAC = [0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF]
    arp_构建请求包(目标IP, 广播MAC, ARP_操作_请求)
}

函数 arp_构建请求包(目标IP, 目标MAC, 操作码) {
    定义 包 = 分配内存(42)
    如果 (包 == 空) { 返回 }
    内存_写16(包, 0x0001)
    内存_写16(包 + 2, 0x0800)
    内存_写8(包 + 4, 6)
    内存_写8(包 + 5, 4)
    内存_写16(包 + 6, 操作码)
    内存_复制(包 + 8, 本机MAC地址(), 6)
    内存_写32(包 + 14, 本机IP地址())
    内存_复制(包 + 18, 目标MAC, 6)
    内存_写32(包 + 24, 目标IP)
    网络_发送以太帧(目标MAC, 0x0806, 包, 28)
    释放内存(包)
}

函数 arp_确认可达(IP地址) {
    自旋锁_获取(全局ARP缓存.锁)
    定义 条目 = arp_查找条目(IP地址)
    如果 (条目 != 空) {
        如果 (条目.状态 == ARP_状态_过期 || 条目.状态 == ARP_状态_延迟 || 条目.状态 == ARP_状态_探测) {
            条目.状态 = ARP_状态_可达
            条目.最后确认时间 = 当前时间_秒()
            ARP_状态转换数 = ARP_状态转换数 + 1
        }
    }
    自旋锁_释放(全局ARP缓存.锁)
}

函数 arp_发送免费ARP() {
    定义 本机IP = 本机IP地址()
    定义 广播MAC = [0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF]
    arp_构建请求包(本机IP, 广播MAC, ARP_操作_请求)
    ARP_免费ARP数 = ARP_免费ARP数 + 1
}

函数 arp_处理代理请求(请求IP, 请求者MAC, 请求者IP) {
    如果 (arp_是否代理(请求IP)) {
        定义 包 = 分配内存(42)
        如果 (包 == 空) { 返回 }
        内存_写16(包, 0x0001)
        内存_写16(包 + 2, 0x0800)
        内存_写8(包 + 4, 6)
        内存_写8(包 + 5, 4)
        内存_写16(包 + 6, ARP_操作_应答)
        内存_复制(包 + 8, 本机MAC地址(), 6)
        内存_写32(包 + 14, 请求IP)
        内存_复制(包 + 18, 请求者MAC, 6)
        内存_写32(包 + 24, 请求者IP)
        网络_发送以太帧(请求者MAC, 0x0806, 包, 28)
        释放内存(包)
        ARP_代理应答数 = ARP_代理应答数 + 1
    }
}

函数 arp_是否代理(IP地址) {
    返回 路由_是否本地转发(IP地址)
}

函数 arp_缓存压缩() {
    自旋锁_获取(全局ARP缓存.锁)
    如果 (全局ARP缓存.条目数 < ARP_缓存_最大条目 * 3 / 4) {
        自旋锁_释放(全局ARP缓存.锁)
        返回
    }
    定义 当前时间 = 当前时间_秒()
    定义 可变 桶号 = 0
    当 (桶号 < ARP_缓存_桶数) {
        定义 可变 前一个 = 空
        定义 可变 当前 = 全局ARP缓存.桶[桶号]
        当 (当前 != 空) {
            定义 下一个 = 当前.下一个
            如果 (当前.状态 == ARP_状态_过期 || 当前.状态 == ARP_状态_不完整) {
                arp_删除条目(桶号, 前一个, 当前)
                当前 = 下一个
                继续
            }
            前一个 = 当前
            当前 = 下一个
        }
        桶号 = 桶号 + 1
    }
    自旋锁_释放(全局ARP缓存.锁)
}

函数 ARP_状态名(状态) {
    如果 (状态 == ARP_状态_不完整) { 返回 "INCOMPLETE" }
    如果 (状态 == ARP_状态_可达) { 返回 "REACHABLE" }
    如果 (状态 == ARP_状态_过期) { 返回 "STALE" }
    如果 (状态 == ARP_状态_延迟) { 返回 "DELAY" }
    如果 (状态 == ARP_状态_探测) { 返回 "PROBE" }
    如果 (状态 == ARP_状态_永久) { 返回 "PERMANENT" }
    返回 "UNKNOWN"
}

函数 ARP_完整统计() {
    返回 [全局ARP缓存.条目数, ARP_请求总数, ARP_应答总数, ARP_老化次数, ARP_老化删除数, ARP_状态转换数, ARP_代理应答数, ARP_免费ARP数]
}

函数 ARP_按状态统计() {
    自旋锁_获取(全局ARP缓存.锁)
    定义 可变 不完整 = 0
    定义 可变 可达 = 0
    定义 可变 过期 = 0
    定义 可变 延迟 = 0
    定义 可变 探测 = 0
    定义 可变 永久 = 0
    定义 可变 桶号 = 0
    当 (桶号 < ARP_缓存_桶数) {
        定义 可变 当前 = 全局ARP缓存.桶[桶号]
        当 (当前 != 空) {
            如果 (当前.状态 == ARP_状态_不完整) { 不完整 = 不完整 + 1 }
            否则如果 (当前.状态 == ARP_状态_可达) { 可达 = 可达 + 1 }
            否则如果 (当前.状态 == ARP_状态_过期) { 过期 = 过期 + 1 }
            否则如果 (当前.状态 == ARP_状态_延迟) { 延迟 = 延迟 + 1 }
            否则如果 (当前.状态 == ARP_状态_探测) { 探测 = 探测 + 1 }
            否则如果 (当前.状态 == ARP_状态_永久) { 永久 = 永久 + 1 }
            当前 = 当前.下一个
        }
        桶号 = 桶号 + 1
    }
    自旋锁_释放(全局ARP缓存.锁)
    返回 [不完整, 可达, 过期, 延迟, 探测, 永久]
}

定义 可变 AI_地址解缓存_带宽估计 = 0
定义 可变 AI_地址解缓存_丢包窗口 = []

函数 AI_地址解缓存_带宽预测(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 AI_地址解缓存_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    AI_地址解缓存_带宽估计 = AI_地址解缓存_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 AI_地址解缓存_带宽估计
}

函数 AI_地址解缓存_拥塞建议(丢包率) {
    追加(AI_地址解缓存_丢包窗口, 丢包率)
    如果 (计数(AI_地址解缓存_丢包窗口) > 10) { 列表_移除(AI_地址解缓存_丢包窗口, 0) }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}

// 分类指标
函数 评估指标_准确率(预测, 标签) { 定义 n = 计数(预测)
 如果 (n == 0) { 返回 0 }
 定义 可变 ok_cnt = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (预测[i] == 标签[i]) { ok_cnt = ok_cnt + 1 }
 i = i + 1 }
 返回 ok_cnt * 1000 / n
}

函数 统计_TP(预测, 标签) { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(预测)) { 如果 (预测[i] == 1) { 如果 (标签[i] == 1) { c = c + 1 } }
 i = i + 1
 }
 返回 c
}

函数 统计_FP(预测, 标签) { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(预测)) { 如果 (预测[i] == 1) { 如果 (标签[i] == 0) { c = c + 1 } }
 i = i + 1
 }
 返回 c
}

函数 统计_FN(预测, 标签) { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(预测)) { 如果 (预测[i] == 0) { 如果 (标签[i] == 1) { c = c + 1 } }
 i = i + 1
 }
 返回 c
}

函数 评估指标_精确率(预测, 标签) { 定义 tp = 统计_TP(预测, 标签)
 定义 fp = 统计_FP(预测, 标签)
 如果 (tp + fp == 0) { 返回 0 }
 返回 tp * 1000 / (tp + fp)
}

函数 评估指标_召回率(预测, 标签) { 定义 tp = 统计_TP(预测, 标签)
 定义 fn = 统计_FN(预测, 标签)
 如果 (tp + fn == 0) { 返回 0 }
 返回 tp * 1000 / (tp + fn)
}

函数 F1_分数(预测, 标签) { 定义 p = 精确率(预测, 标签)
 定义 r = 召回率(预测, 标签)
 如果 (p + r == 0) { 返回 0 }
 返回 2 * p * r / (p + r)
}

// F-beta分数: 通用版
函数 F_贝塔(预测, 标签, 动量率) { 定义 p = 精确率(预测, 标签)
 定义 r = 召回率(预测, 标签)
 如果 (p + r == 0) { 返回 0 }
 定义 b2 = 动量率 * 动量率 / 1000
 返回 (1000 + b2) * p * r / (b2 * p + r * 1000 / 1000)
}

函数 评估指标_混淆矩阵(预测, 标签) { 定义 tp = 统计_TP(预测, 标签)
 定义 fp = 统计_FP(预测, 标签)
 定义 fn = 统计_FN(预测, 标签)
 定义 tn = 计数(预测) - tp - fp - fn
 返回 [tn, fp, fn, tp]
}

// Cohen's 卡帕系数: (acc - expected) / (1 - expected)
函数 卡帕系数(预测, 标签) { 定义 n = 计数(预测)
 如果 (n == 0) { 返回 0 }
 定义 可变 p1 = 0
 定义 可变 a1 = 0
 定义 可变 ok_cnt = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (预测[i] == 1) { p1 = p1 + 1 }
 如果 (标签[i] == 1) { a1 = a1 + 1 }
 如果 (预测[i] == 标签[i]) { ok_cnt = ok_cnt + 1 }
 i = i + 1
 }
 定义 po = ok_cnt * 1000 / n
 定义 pe = (p1 * a1 + (n - p1) * (n - a1)) * 1000 / n / n
 如果 (1000 - pe == 0) { 返回 1000 }
 返回 (po - pe) * 1000 / (1000 - pe)
}

// 多类别 Macro F1
函数 宏F1(预测, 标签, n_classes) {
    定义 可变 总f1 = 0
 定义 可变 类别 = 0
 当 (类别 < n_classes) {
 // 将多类别转为二分类
 定义 可变 bin_pred = []
 定义 可变 bin_label = []
 定义 可变 i = 0
 当 (i < 计数(预测)) { 如果 (预测[i] == 类别) { 追加(bin_pred, 1) } 否则 { 追加(bin_pred, 0) }
 如果 (标签[i] == 类别) { 追加(bin_label, 1) } 否则 { 追加(bin_label, 0) }
 i = i + 1
 }
 总f1 = 总f1 + F1_分数(bin_pred, bin_label)
 类别 = 类别 + 1
 }
 如果 (n_classes == 0) { 返回 0 }
 返回 总f1 / n_classes
}

// 回归指标
函数 评估指标_平均绝对误差(预测, 标签) { 定义 n = 计数(预测)
 如果 (n == 0) { 返回 0 }
 返回 折叠(拉链(预测, 标签, (p, t) => 绝对值(p - t)), 0, (s, d) => s + d) * 1000 / n
}

函数 评估指标_均方误差(预测, 标签) { 定义 n = 计数(预测)
 如果 (n == 0) { 返回 0 }
 返回 折叠(拉链(预测, 标签, (p, t) => (p - t) * (p - t)), 0, (s, d) => s + d) / n
}

函数 均方根误差(预测, 标签) { 返回 整数sqrt(评估指标_均方误差(预测, 标签)) }

// 平均绝对百分比误差: 平均绝对百分比误差
函数 平均绝对百分比误差(预测, 标签) { 定义 n = 计数(预测)
 如果 (n == 0) { 返回 0 }
 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (标签[i] != 0) { 总 = 总 + 绝对值(预测[i] - 标签[i]) * 1000 / 绝对值(标签[i]) }
 i = i + 1
 }
 返回 总 / n
}

// R² 决定系数
函数 R方(预测, 标签) { 定义 n = 计数(标签)
    定义 可变 总平方和 = 0
    定义 可变 残差平方和 = 0
 如果 (n == 0) { 返回 0 }
 定义 可变 mean_y = 0
 定义 可变 i = 0
 当 (i < n) { mean_y = mean_y + 标签[i]
 i = i + 1 }
 mean_y = mean_y / n
 i = 0
 当 (i < n) { 定义 d1 = 预测[i] - 标签[i]
 定义 d2 = 标签[i] - mean_y
 残差平方和 = 残差平方和 + d1 * d1
 总平方和 = 总平方和 + d2 * d2
 i = i + 1
 }
 如果 (总平方和 == 0) { 返回 1000 }
 返回 1000 - 残差平方和 * 1000 / 总平方和
}

// 语言模型指标
函数 BLEU单元(cand_seq, ref_seq) { 定义 可变 命中 = 0
 定义 可变 i = 0
 当 (i < 计数(cand_seq)) { 定义 可变 j = 0
 定义 可变 已找 = 假
 当 (j < 计数(ref_seq)) { 如果 (cand_seq[i] == ref_seq[j]) { 已找 = 真 }
 j = j + 1
 }
 如果 (已找) { 命中 = 命中 + 1 }
 i = i + 1
 }
 如果 (计数(cand_seq) == 0) { 返回 0 }
 返回 命中 * 1000 / 计数(cand_seq)
}

// ROUGE-L: 最长公共子序列
函数 ROUGE_L句(cand_seq, ref_seq) { 定义 m = 计数(cand_seq)
 定义 n = 计数(ref_seq)
 如果 (m == 0) { 返回 0 }
 如果 (n == 0) { 返回 0 }
 // LCS用两行DP
 定义 可变 前值 = []
 定义 可变 curr = []
 定义 可变 j = 0
 当 (j <= n) { 追加(前值, 0)
 追加(curr, 0)
 j = j + 1 }
 定义 可变 i = 0
 当 (i < m) {
 j = 0
 当 (j <= n) { curr[j] = 0
 j = j + 1 }
 j = 0
 当 (j < n) { 如果 (cand_seq[i] == ref_seq[j]) { curr[j + 1] = 前值[j] + 1 }
 否则 { curr[j + 1] = 最大值(curr[j], 前值[j + 1]) }
 j = j + 1
 }
 // swap 前值/curr
 j = 0
 当 (j <= n) { 定义 临时 = 前值[j]
 前值[j] = curr[j]
 curr[j] = 临时
 j = j + 1
 }
 i = i + 1
 }
 定义 lcs = 前值[n]
 定义 prec = lcs * 1000 / m
 定义 rec = lcs * 1000 / n
 如果 (prec + rec == 0) { 返回 0 }
 返回 2 * prec * rec / (prec + rec)
}

函数 评估指标_困惑度(losses) { 定义 n = 计数(losses)
 如果 (n == 0) { 返回 0 }
 定义 均值 = 求和(losses) / n
 如果 (均值 < 500) { 返回 1000 + 均值 }
 如果 (均值 < 2000) { 返回 1000 + 均值 + 均值 * 均值 / 2000 }
 返回 1000 + 均值 * 3
}

函数 TopK准确率(score_list, label_list, k) { 定义 n = 计数(label_list)
 如果 (n == 0) { 返回 0 }
 定义 可变 ok_cnt = 0
 定义 可变 i = 0
 当 (i < n) { 定义 tgt_score = score_list[i]
 定义 可变 higher = 0
 定义 可变 j = 0
 当 (j < 计数(score_list)) { 如果 (score_list[j] > tgt_score) { higher = higher + 1 }
 j = j + 1
 }
 如果 (higher < k) { ok_cnt = ok_cnt + 1 }
 i = i + 1
 }
 返回 ok_cnt * 1000 / n
}

// 排序指标
// 平均倒数排名: Mean Reciprocal Rank
函数 平均倒数排名(排名列表) { 定义 n = 计数(排名列表)
 如果 (n == 0) { 返回 0 }
 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (排名列表[i] > 0) { 总 = 总 + 1000 / 排名列表[i] }
 i = i + 1
 }
 返回 总 / n
}

// 归一折损增益@K 简化: 假设相关度二值
函数 折损累计增益(排列, k) { 定义 可变 dcg = 0
 定义 可变 i = 0
 定义 上限 = 最小值(k, 计数(排列))
 当 (i < 上限) { 如果 (排列[i] > 0) { 定义 可变 lg = 对数2(i + 2)
 如果 (lg == 0) { lg = 1 }
 dcg = dcg + 排列[i] * 1000 / lg
 }
 i = i + 1
 }
 返回 dcg
}

函数 归一折损增益(排列, 理想排列, k) { 定义 dcg = 折损累计增益(排列, k)
 定义 idcg = 折损累计增益(理想排列, k)
 如果 (idcg == 0) { 返回 0 }
 返回 dcg * 1000 / idcg
}

// 样本数
函数 评估_样本数(真实值) { 返回 计数(真实值) }

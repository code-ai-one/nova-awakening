导入("../推理/智能渠道.nova")
导入("./内核直连层.nova")
导入("./贝塞尔曲线细.nova")
导入("../中枢/内存初始化.nova")

// Skia→Nova转换: src/core/SkScan.cpp + SkScan_Path.cpp + Nova缓冲litter.cpp
//                + SkEdge.cpp + SkAntiRun.cpp + SkAAClip.cpp
//       SkScan_Path.cpp (~1500行) — 扫描线路径填充
//       SkEdge.cpp (~800行) — 边缘表
//       Nova缓冲litter.cpp (~2000行) — 像素写入
//       SkScan_AntiAlias.cpp (~1200行) — 抗锯齿扫描线
//       SkDraw.cpp (~2500行) — 高级绘制操作
// Skia的光栅化管线:
//   SkPath → SkEdge(边缘表) → SkScan(扫描线) → Nova缓冲litter(像素写入)
// 本文件实现:
//   1. 边缘表构建(直线/二次/三次贝塞尔曲线细分)
//   2. 扫描线填充算法(Active Edge Table)
//   3. 4x超采样抗锯齿
//   4. 线性渐变/径向渐变光栅化
//   5. 圆角矩形光栅化
//   6. 描边(stroke)光栅化

// §1 边缘(Edge) — 扫描线光栅化的基本单元
// 每条路径段(直线/曲线)转换为一条或多条边
// 边记录: 从y_top到y_bottom,每行x的递增(斜率)

结构 SkEdge {
    x,    // i32 当前x (×256 定点数, 8位小数)
    dx,    // i32 每行x增量 (×256)
    y_top,    // i32 起始扫描线
    y_bottom,    // i32 结束扫描线
    方向,    // i32 +1向下 -1向上 (用于winding填充规则)
    下一条,    // u64 链表指针
}

// 边缘池(预分配避免频繁堆分配)
结构 EdgePool {
    边缘列表,    // u64 SkEdge数组
    数量,
    容量,
}

函数 EdgePool_创建(容量) {
    定义 pool = 堆_分配(EdgePool)
    pool.容量 = 容量
    pool.边缘列表 = 堆_分配_数组(容量 * 32)
    pool.数量 = 0
    返回 pool
}

函数 EdgePool_添加(pool, x_top, y_top, x_bottom, y_bottom) {
    如果 (pool.数量 >= pool.容量) { 返回 0 }
    如果 (y_top == y_bottom) { 返回 0 }    // 水平边不参与扫描线

    定义 偏移 = pool.边缘列表 + pool.数量 * 32
    定义 可变 方向 = 1

    // 确保y_top < y_bottom (边缘从上到下)
    定义 可变 xt = x_top
    定义 可变 yt = y_top
    定义 可变 xb = x_bottom
    定义 可变 yb = y_bottom
    如果 (yt > yb) {
        xt = x_bottom; yt = y_bottom
        xb = x_top; yb = y_top
        方向 = -1
    }

    定义 dy = yb - yt
    定义 dx = 0
    如果 (dy != 0) {
        dx = (xb - xt) * 256 / dy    // 斜率 ×256
    }

    内存_写32(偏移, xt * 256)       // x (×256)
    内存_写32(偏移 + 4, dx)          // dx (×256)
    内存_写32(偏移 + 8, yt)          // y_top
    内存_写32(偏移 + 12, yb)         // y_bottom
    内存_写32(偏移 + 16, 方向)       // 方向
    内存_写64(偏移 + 24, 0)          // 下一条

    pool.数量 = pool.数量 + 1
    返回 偏移
}

// §2 路径→边缘表转换
// 将SkPath中的moveTo/lineTo/quadTo/Nova三次方To转换为边缘
// 曲线通过细分(subdivision)展平为直线段

函数 SkPath_转换为边缘(path, pool) {
    定义 可变 当前x = 0
    定义 可变 当前y = 0
    定义 可变 起始x = 0
    定义 可变 起始y = 0
    定义 可变 点idx = 0
    定义 可变 动词idx = 0

    当 (动词idx < path.动词数量) {
        定义 动词 = 内存_读8(path.动词列表 + 动词idx)

        如果 (动词 == 路径动词_移动) {
            当前x = 内存_读32(path.点列表 + 点idx * 8)
            当前y = 内存_读32(path.点列表 + 点idx * 8 + 4)
            起始x = 当前x
            起始y = 当前y
            点idx = 点idx + 1
        }
        否则 如果 (动词 == 路径动词_直线) {
            定义 目标x = 内存_读32(path.点列表 + 点idx * 8)
            定义 目标y = 内存_读32(path.点列表 + 点idx * 8 + 4)
            // 直线→一条边(坐标从×100转为像素)
            EdgePool_添加(pool, 当前x / 100, 当前y / 100, 目标x / 100, 目标y / 100)
            当前x = 目标x
            当前y = 目标y
            点idx = 点idx + 1
        }
        否则 如果 (动词 == 路径动词_二次) {
            // 二次贝塞尔: 细分为直线段
            定义 cx = 内存_读32(path.点列表 + 点idx * 8)
            定义 cy = 内存_读32(path.点列表 + 点idx * 8 + 4)
            定义 目标x = 内存_读32(path.点列表 + (点idx + 1) * 8)
            定义 目标y = 内存_读32(path.点列表 + (点idx + 1) * 8 + 4)
            贝塞尔_二次细分(pool, 当前x / 100, 当前y / 100, cx / 100, cy / 100, 目标x / 100, 目标y / 100, 0)
            当前x = 目标x
            当前y = 目标y
            点idx = 点idx + 2
        }
        否则 如果 (动词 == 路径动词_三次) {
            // 三次贝塞尔: 细分为直线段
            定义 c1x = 内存_读32(path.点列表 + 点idx * 8)
            定义 c1y = 内存_读32(path.点列表 + 点idx * 8 + 4)
            定义 c2x = 内存_读32(path.点列表 + (点idx + 1) * 8)
            定义 c2y = 内存_读32(path.点列表 + (点idx + 1) * 8 + 4)
            定义 目标x = 内存_读32(path.点列表 + (点idx + 2) * 8)
            定义 目标y = 内存_读32(path.点列表 + (点idx + 2) * 8 + 4)
            贝塞尔_三次细分(pool, 当前x / 100, 当前y / 100,
                c1x / 100, c1y / 100, c2x / 100, c2y / 100,
                目标x / 100, 目标y / 100, 0)
            当前x = 目标x
            当前y = 目标y
            点idx = 点idx + 3
        }
        否则 如果 (动词 == 路径动词_关闭) {
            // 闭合: 回到起始点
            如果 (当前x != 起始x || 当前y != 起始y) {
                EdgePool_添加(pool, 当前x / 100, 当前y / 100, 起始x / 100, 起始y / 100)
            }
            当前x = 起始x
            当前y = 起始y
        }

        动词idx = 动词idx + 1
    }
}

定义 可变 AI_边缘池创建_调用数 = 0
定义 可变 AI_边缘池创建_异常数 = 0

函数 AI_边缘池创建_监控() {
    AI_边缘池创建_调用数 = AI_边缘池创建_调用数 + 1
    返回 AI_边缘池创建_异常数 == 0
}

函数 AI_边缘池创建_健康检查() {
    如果 (AI_边缘池创建_调用数 > 0 && AI_边缘池创建_异常数 * 100 / AI_边缘池创建_调用数 > 10) {
        返回 假
    }
    返回 真
}

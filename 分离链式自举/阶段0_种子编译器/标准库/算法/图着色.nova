//    相邻约束 = 相克关系 (相邻节点不可同色)
//    约束传播: 阳(赋值)触发阴(域缩减)

// 图着色 (贪心)
// 邻接表: [[邻居列表], ...]

导入("../基础.nova")

函数 图着色_贪心(邻接表) {
    定义 n = 计数(邻接表)
    定义 可变 颜色 = []
    定义 可变 i = 0
    当 (i < n) { 追加(颜色, -1) i = i + 1 }
    // 对每个节点分配最小可用颜色
    i = 0
    当 (i < n) {
        // 标记邻居已用颜色
        定义 可变 已用 = []
        定义 可变 k = 0
        当 (k < n) { 追加(已用, 0) k = k + 1 }
        定义 邻居 = 邻接表[i]
        定义 可变 j = 0
        当 (j < 计数(邻居)) {
            定义 邻色 = 颜色[邻居[j]]
            如果 (邻色 >= 0 且 邻色 < n) { 已用[邻色] = 1 }
            j = j + 1
        }
        // 找最小可用颜色
        定义 可变 c = 0
        当 (c < n 且 已用[c] == 1) { c = c + 1 }
        颜色[i] = c
        i = i + 1
    }
    返回 颜色
}

// 计算使用的颜色数
函数 图着色_颜色数(颜色列表) {
    定义 可变 最大 = 0
    定义 可变 i = 0
    当 (i < 计数(颜色列表)) {
        如果 (颜色列表[i] > 最大) { 最大 = 颜色列表[i] }
        i = i + 1
    }
    返回 最大 + 1
}

// 验证着色是否有效
函数 图着色_验证(邻接表, 颜色列表) {
    定义 可变 i = 0
    当 (i < 计数(邻接表)) {
        定义 邻居 = 邻接表[i]
        定义 可变 j = 0
        当 (j < 计数(邻居)) {
            如果 (颜色列表[i] == 颜色列表[邻居[j]]) { 返回 0 }
            j = j + 1
        }
        i = i + 1
    }
    返回 1
}

// 数独验证/求解

// 数独: 9x9 列表的列表, 0表示空
函数 数独_验证(棋盘) {
    // 检查行
    定义 可变 i = 0
    当 (i < 9) {
        如果 (数独_检查组(棋盘[i]) == 0) { 返回 0 }
        i = i + 1
    }
    // 检查列
    定义 可变 j = 0
    当 (j < 9) {
        定义 可变 列 = []
        i = 0
        当 (i < 9) {
            定义 行 = 棋盘[i]
            追加(列, 行[j])
            i = i + 1
        }
        如果 (数独_检查组(列) == 0) { 返回 0 }
        j = j + 1
    }
    // 检查3x3宫
    定义 可变 br = 0
    当 (br < 3) {
        定义 可变 bc = 0
        当 (bc < 3) {
            定义 可变 宫 = []
            i = 0
            当 (i < 3) {
                j = 0
                当 (j < 3) {
                    定义 行idx = br * 3 + i
                    定义 列idx = bc * 3 + j
                    定义 行r = 棋盘[行idx]
                    追加(宫, 行r[列idx])
                    j = j + 1
                }
                i = i + 1
            }
            如果 (数独_检查组(宫) == 0) { 返回 0 }
            bc = bc + 1
        }
        br = br + 1
    }
    返回 1
}

函数 数独_检查组(组) {
    定义 可变 seen = []
    定义 可变 i = 0
    当 (i < 10) { 追加(seen, 0) i = i + 1 }
    i = 0
    当 (i < 计数(组)) {
        定义 v = 组[i]
        如果 (v != 0) {
            如果 (v < 1 或 v > 9) { 返回 0 }
            如果 (seen[v] == 1) { 返回 0 }
            seen[v] = 1
        }
        i = i + 1
    }
    返回 1
}

// 数独求解 (回溯)
函数 数独_求解(棋盘) {
    返回 数独_回溯(棋盘, 0)
}

函数 数独_回溯(棋盘, 位置) {
    如果 (位置 >= 81) { 返回 1 }
    定义 行 = 位置 / 9
    定义 列 = 位置 % 9
    定义 行r = 棋盘[行]
    如果 (行r[列] != 0) {
        返回 数独_回溯(棋盘, 位置 + 1)
    }
    定义 可变 n = 1
    当 (n <= 9) {
        如果 (数独_可放(棋盘, 行, 列, n) == 1) {
            行r[列] = n
            如果 (数独_回溯(棋盘, 位置 + 1) == 1) { 返回 1 }
            行r[列] = 0
        }
        n = n + 1
    }
    返回 0
}

函数 数独_可放(棋盘, 行, 列, 数) {
    // 检查行
    定义 行r = 棋盘[行]
    定义 可变 i = 0
    当 (i < 9) {
        如果 (行r[i] == 数) { 返回 0 }
        i = i + 1
    }
    // 检查列
    i = 0
    当 (i < 9) {
        定义 ir = 棋盘[i]
        如果 (ir[列] == 数) { 返回 0 }
        i = i + 1
    }
    // 检查3x3宫
    定义 宫行 = (行 / 3) * 3
    定义 宫列 = (列 / 3) * 3
    i = 0
    当 (i < 3) {
        定义 可变 j = 0
        当 (j < 3) {
            定义 cr = 棋盘[宫行 + i]
            如果 (cr[宫列 + j] == 数) { 返回 0 }
            j = j + 1
        }
        i = i + 1
    }
    返回 1
}

// Welsh-Powell贪心着色
函数 WP_着色(节点数, 邻接表) {
    // 按度排序(降序)
    定义 可变 度列表 = []
    定义 可变 索引 = []
    定义 可变 i = 0
    当 (i < 节点数) {
        追加(度列表, 计数(邻接表[i]))
        追加(索引, i)
        i = i + 1
    }
    // 简单选择排序(按度降序)
    i = 0
    当 (i < 节点数) {
        定义 可变 最大idx = i
        定义 可变 j = i + 1
        当 (j < 节点数) {
            如果 (度列表[j] > 度列表[最大idx]) { 最大idx = j }
            j = j + 1
        }
        定义 暂d = 度列表[i]
        度列表[i] = 度列表[最大idx]
        度列表[最大idx] = 暂d
        定义 暂i = 索引[i]
        索引[i] = 索引[最大idx]
        索引[最大idx] = 暂i
        i = i + 1
    }
    // 着色
    定义 可变 颜色 = []
    i = 0
    当 (i < 节点数) { 追加(颜色, -1) i = i + 1 }
    定义 可变 色数 = 0
    i = 0
    当 (i < 节点数) {
        定义 节点 = 索引[i]
        定义 可变 已用色 = []
        定义 邻 = 邻接表[节点]
        定义 可变 j = 0
        当 (j < 计数(邻)) {
            如果 (颜色[邻[j]] >= 0) { 追加(已用色, 颜色[邻[j]]) }
            j = j + 1
        }
        定义 可变 c = 0
        定义 可变 找到 = 假
        当 (找到 == 假) {
            定义 可变 冲突 = 假
            j = 0
            当 (j < 计数(已用色)) {
                如果 (已用色[j] == c) { 冲突 = 真 }
                j = j + 1
            }
            如果 (冲突 == 假) { 找到 = 真 }
            否则 { c = c + 1 }
        }
        颜色[节点] = c
        如果 (c >= 色数) { 色数 = c + 1 }
        i = i + 1
    }
    返回 [颜色, 色数]
}

// 着色验证
函数 着色_验证(节点数, 邻接表, 颜色) {
    定义 可变 i = 0
    当 (i < 节点数) {
        定义 邻 = 邻接表[i]
        定义 可变 j = 0
        当 (j < 计数(邻)) {
            如果 (颜色[i] == 颜色[邻[j]]) { 返回 假 }
            j = j + 1
        }
        i = i + 1
    }
    返回 真
}

// 色数下界(最大团)
函数 着色_最大度(节点数, 邻接表) {
    定义 可变 最大 = 0
    定义 可变 i = 0
    当 (i < 节点数) {
        定义 度 = 计数(邻接表[i])
        如果 (度 > 最大) { 最大 = 度 }
        i = i + 1
    }
    返回 最大 + 1
}

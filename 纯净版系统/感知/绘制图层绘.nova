函数 绘制Layer_绘制内容(层, 显示列表, 偏移x, 偏移y) {
    // 绘制层关联的布局对象的所有非层子节点
    定义 lo = 层.布局对象
    定义 可变 子lo = lo.第一子
    当 (子lo != 0) {
        如果 (子lo.样式 != 0 && 子lo.样式.display == Display_none) {
            子lo = 子lo.后兄
            继续
        }

        // 如果子lo有自己的层,跳过(由z-order列表处理)
        如果 (绘制Layer_需要自己的层(子lo)) {
            子lo = 子lo.后兄
            继续
        }

        // 绘制子布局对象
        绘制Layer_绘制布局对象(子lo, 显示列表, 偏移x, 偏移y)

        子lo = 子lo.后兄
    }
}

函数 绘制Layer_绘制布局对象(lo, 显示列表, 偏移x, 偏移y) {
    定义 s = lo.样式
    如果 (s == 0) { 返回 }
    如果 (s.visibility == Visibility_hidden) { 返回 }

    定义 绘制x = lo.绝对x + 偏移x
    定义 绘制y = lo.绝对y + 偏移y
    定义 绘制w = 布局Object_边框盒宽(lo)
    定义 绘制h = 布局Object_边框盒高(lo)

    // 背景
    如果 (s.background_color != 0x00000000) {
        绘制Layer_添加显示项(显示列表, 显示项 {
            类型: 显示项_背景,
            x: 绘制x, y: 绘制y, w: 绘制w, h: 绘制h,
            颜色: s.background_color
        })
    }

    // 文本
    如果 (lo.类型 == 布局类型_文本) {
        定义 文本 = CharacterData_data(lo.DOM节点)
        如果 (文本 != 0) {
            绘制Layer_添加显示项(显示列表, 显示项 {
                类型: 显示项_文本,
                x: 绘制x, y: 绘制y, w: 绘制w, h: 绘制h,
                颜色: s.color,
                文本指针: 文本,
                文本长度: 字符串_长度(文本),
                字号: s.font_size,
                字重: s.font_weight,
                字体: s.font_family
            })
        }
    }

    // 边框
    如果 (s.border_top_width > 0) {
        绘制Layer_添加显示项(显示列表, 显示项 {
            类型: 显示项_边框,
            x: 绘制x, y: 绘制y, w: 绘制w, h: 绘制h,
            边框宽: s.border_top_width,
            边框颜色: s.border_top_color
        })
    }

    // 递归绘制子节点
    定义 可变 子 = lo.第一子
    当 (子 != 0) {
        如果 (!绘制Layer_需要自己的层(子)) {
            绘制Layer_绘制布局对象(子, 显示列表, 偏移x, 偏移y)
        }
        子 = 子.后兄
    }
}

函数 绘制Layer_添加显示项(显示列表, 项) {
    如果 (显示列表 == 0) { 返回 }
    如果 (显示列表.显示列表数量 >= 显示列表.显示列表容量) {
        // 扩容
        定义 新容量 = 显示列表.显示列表容量 * 2
        定义 新列表 = 堆_分配_数组(新容量 * 48)
        内存_复制(新列表, 显示列表.显示列表, 显示列表.显示列表数量 * 48)
        堆_释放(显示列表.显示列表)
        显示列表.显示列表 = 新列表
        显示列表.显示列表容量 = 新容量
    }
    内存_复制(显示列表.显示列表 + 显示列表.显示列表数量 * 48, 项, 48)
    显示列表.显示列表数量 = 显示列表.显示列表数量 + 1

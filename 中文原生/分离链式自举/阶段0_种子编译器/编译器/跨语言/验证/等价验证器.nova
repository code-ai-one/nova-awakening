// Nova · 跨语言验证 · 等价验证器
// 职责: 验证原生重置后的Nova工程与原工程在行为/接口/资源上等价
// 层级: 跨语言主线第8步 — 等价验证

// 验证级别

导入("../../../标准库/基础.nova")

定义 验证_接口     = 0  // 公共API签名一致
定义 验证_行为     = 1  // 输入输出行为一致
定义 验证_资源     = 2  // 资源生命周期等价
定义 验证_ABI      = 3  // ABI边界兼容
定义 验证_性能     = 4  // 性能预算满足

// 验证结果
定义 结果_通过   = 0
定义 结果_警告   = 1
定义 结果_失败   = 2
定义 结果_阻塞   = 3

// 验证项: [级别, 名称, 结果, 描述, 源证据, 目标证据]
函数 验证项_创建(级别, 名称) {
    返回 [级别, 名称, 结果_通过, "", "", ""]
}

函数 验证项_级别(v) { 返回 v[0] }
函数 验证项_名称(v) { 返回 v[1] }
函数 验证项_结果(v) { 返回 v[2] }
函数 验证项_描述(v) { 返回 v[3] }

函数 验证项_设结果(v, 结果, 描述) {
    v[2] = 结果
    v[3] = 描述
}

函数 验证项_设证据(v, 源, 目标) {
    v[4] = 源
    v[5] = 目标
}

// 等价验证报告: [验证项列表, 通过数, 警告数, 失败数, 阻塞数, 总结]
函数 等价报告_创建() {
    返回 [[], 0, 0, ""]
}

函数 等价报告_添加(报告, 验证项) {
    追加(报告[0], 验证项)
    如果 (验证项[2] == 结果_通过) { 报告[1] = 报告[1] + 1 }
    如果 (验证项[2] == 结果_警告) { 报告[2] = 报告[2] + 1 }
    如果 (验证项[2] == 结果_失败) { 报告[3] = 报告[3] + 1 }
    如果 (验证项[2] == 结果_阻塞) { 报告[4] = 报告[4] + 1 }
}

函数 等价报告_是否通过(报告) {
    返回 报告[3] == 0 且 报告[4] == 0
}

// 接口等价验证
函数 验证_接口等价(源接口列表, 目标接口列表) {
    定义 项 = 验证项_创建(验证_接口, "公共API完整性")
    定义 源数 = 计数(源接口列表)
    定义 目标数 = 计数(目标接口列表)

    如果 (源数 == 0 且 目标数 == 0) {
        验证项_设结果(项, 结果_通过, "无公共API")
        返回 项
    }

    // 检查源接口是否全部出现在目标中
    定义 可变 缺失数 = 0
    定义 可变 i = 0
    当 (i < 源数) {
        定义 可变 找到 = 假
        定义 可变 j = 0
        当 (j < 目标数) {
            如果 (源接口列表[i] == 目标接口列表[j]) { 找到 = 真 }
            j = j + 1
        }
        如果 (找到 == 假) { 缺失数 = 缺失数 + 1 }
        i = i + 1
    }

    如果 (缺失数 == 0) {
        验证项_设结果(项, 结果_通过, 字符串拼接("全部", 字符串拼接(转字符串(源数), "个接口已覆盖")))
    } 否则 {
        验证项_设结果(项, 结果_失败, 字符串拼接(转字符串(缺失数), "个公共API缺失"))
    }
    返回 项
}

// 行为等价验证(基于测试用例)
函数 验证_行为等价(测试结果列表) {
    定义 项 = 验证项_创建(验证_行为, "行为等价(测试)")
    定义 总数 = 计数(测试结果列表)
    如果 (总数 == 0) {
        验证项_设结果(项, 结果_警告, "无测试用例")
        返回 项
    }

    定义 可变 i = 0
    当 (i < 总数) {
        如果 (测试结果列表[i] == 真) { 通过数 = 通过数 + 1 }
        i = i + 1
    }

    如果 (通过数 == 总数) {
        验证项_设结果(项, 结果_通过, 字符串拼接(转字符串(总数), 字符串拼接("/", 字符串拼接(转字符串(总数), " 测试通过"))))
    } 否则 {
        验证项_设结果(项, 结果_失败, 字符串拼接(转字符串(通过数), 字符串拼接("/", 字符串拼接(转字符串(总数), " 测试通过"))))
    }
    返回 项
}

// 性能预算验证
函数 验证_性能预算(源时间, 目标时间, 容忍倍数) {
    定义 项 = 验证项_创建(验证_性能, "性能预算")
    如果 (源时间 <= 0) {
        验证项_设结果(项, 结果_警告, "无性能基线")
        返回 项
    }
    定义 比率 = 目标时间 * 100 / 源时间
    如果 (比率 <= 容忍倍数 * 100) {
        验证项_设结果(项, 结果_通过, 字符串拼接("目标/源=", 字符串拼接(转字符串(比率), "%")))
    } 否则 {
        验证项_设结果(项, 结果_失败, 字符串拼接("超预算: 目标/源=", 字符串拼接(转字符串(比率), "%")))
    }
    返回 项
}

// 一票否决检查
函数 等价报告_一票否决检查(报告) {
    定义 可变 否决项 = []
    定义 可变 i = 0
    当 (i < 计数(报告[0])) {
        定义 项 = 报告[0][i]
        // 接口缺失→一票否决
        如果 (项[0] == 验证_接口 且 项[2] == 结果_失败) {
            追加(否决项, 字符串拼接("公共API缺失: ", 项[3]))
        }
        // 行为差分未批准→一票否决
        如果 (项[0] == 验证_行为 且 项[2] == 结果_失败) {
            追加(否决项, 字符串拼接("行为差分: ", 项[3]))
        }
        i = i + 1
    }
    返回 否决项
}

// 等价报告输出
函数 等价报告_打印(报告) {
    打印("═══ 等价验证报告 ═══")
    打印文本(字符串拼接("  通过: ", 转字符串(报告[1])))
    打印文本(字符串拼接("  警告: ", 转字符串(报告[2])))
    打印文本(字符串拼接("  失败: ", 转字符串(报告[3])))
    打印文本(字符串拼接("  阻塞: ", 转字符串(报告[4])))
    如果 (等价报告_是否通过(报告)) {
        打印("  结论: 等价验证通过 ✓")
    } 否则 {
        打印("  结论: 等价验证未通过 ✗")
        定义 否决 = 等价报告_一票否决检查(报告)
        定义 可变 i = 0
        当 (i < 计数(否决)) {
            打印文本(字符串拼接("  [否决] ", 否决[i]))
            i = i + 1
        }
    }
}

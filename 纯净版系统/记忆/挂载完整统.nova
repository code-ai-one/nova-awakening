导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/哈希整数.nova")
导入("../中枢/创建甲.nova")

定义 最大挂载 = 64
定义 最大文件系统类型 = 16
定义 挂载_只读 = 1
定义 挂载_无执行 = 2
定义 挂载_无设备 = 4
定义 挂载_同步 = 8

结构 挂载项 {
    挂载点哈希,
    设备哈希,
    文件系统类型,
    标志,
    根节点,
    父挂载,
    子挂载数,
    引用计数,
    挂载时刻,
    读操作数,
    写操作数,
}

结构 文件系统类型 {
    名称哈希,
    挂载回调,
    卸载回调,
    读超级块,
    同步回调,
}

定义 可变 挂载表 = []
定义 可变 挂载数 = 0
定义 可变 类型表 = []
定义 可变 类型数 = 0
定义 可变 总挂载 = 0
定义 可变 总卸载 = 0

函数 挂载_初始化() {
    挂载表 = []
    挂载数 = 0
    类型表 = []
    类型数 = 0
}

函数 文件系统_注册类型(名称, 挂载回调, 卸载回调, 读超级块) {
    如果 (类型数 >= 最大文件系统类型) { 返回 -1 }
    定义 类型 = 文件系统类型 {}
    类型.名称哈希 = 哈希_字符串(名称)
    类型.挂载回调 = 挂载回调
    类型.卸载回调 = 卸载回调
    类型.读超级块 = 读超级块
    类型.同步回调 = 0
    追加(类型表, 类型)
    定义 索引 = 类型数
    类型数 = 类型数 + 1
    返回 索引
}

函数 挂载_执行(挂载点, 设备, 文件系统名, 标志) {
    如果 (挂载数 >= 最大挂载) { 返回 错误_无资源 }
    定义 类型索引 = 挂载_查找类型(文件系统名)
    如果 (类型索引 < 0) { 返回 错误_不支持 }
    定义 项 = 挂载项 {}
    项.挂载点哈希 = 哈希_字符串(挂载点)
    项.设备哈希 = 哈希_字符串(设备)
    项.文件系统类型 = 类型索引
    项.标志 = 标志
    项.根节点 = 0
    项.父挂载 = -1
    项.子挂载数 = 0
    项.引用计数 = 1
    项.挂载时刻 = 平台_获取高精度时间()
    项.读操作数 = 0
    项.写操作数 = 0
    如果 (类型表[类型索引].挂载回调 != 0) {
        项.根节点 = 类型表[类型索引].挂载回调(设备)
    }
    追加(挂载表, 项)
    挂载数 = 挂载数 + 1
    总挂载 = 总挂载 + 1
    返回 挂载数 - 1
}

函数 挂载_卸载(挂载索引) {
    如果 (挂载索引 >= 挂载数) { 返回 错误_无效参数 }
    定义 项 = 挂载表[挂载索引]
    如果 (项.引用计数 > 1) { 返回 错误_忙 }
    如果 (项.子挂载数 > 0) { 返回 错误_忙 }
    定义 类型索引 = 项.文件系统类型
    如果 (类型索引 < 类型数 && 类型表[类型索引].卸载回调 != 0) {
        类型表[类型索引].卸载回调(项.根节点)
    }
    项.引用计数 = 0
    总卸载 = 总卸载 + 1
    返回 0
}

函数 挂载_查找类型(名称) {
    定义 目标 = 哈希_字符串(名称)
    定义 可变 序号 = 0
    当 (序号 < 类型数) {
        如果 (类型表[序号].名称哈希 == 目标) { 返回 序号 }
        序号 = 序号 + 1
    }
    返回 -1
}

函数 挂载_查找点(挂载点) {
    定义 目标 = 哈希_字符串(挂载点)
    定义 可变 序号 = 0
    当 (序号 < 挂载数) {
        如果 (挂载表[序号].挂载点哈希 == 目标 && 挂载表[序号].引用计数 > 0) {
            返回 序号
        }
        序号 = 序号 + 1
    }
    返回 -1
}

函数 挂载_增引用(索引) {
    如果 (索引 < 挂载数) { 挂载表[索引].引用计数 = 挂载表[索引].引用计数 + 1 }
}

函数 挂载_减引用(索引) {
    如果 (索引 < 挂载数 && 挂载表[索引].引用计数 > 0) {
        挂载表[索引].引用计数 = 挂载表[索引].引用计数 - 1
    }
}

函数 挂载_记录读(索引) {
    如果 (索引 < 挂载数) { 挂载表[索引].读操作数 = 挂载表[索引].读操作数 + 1 }
}

函数 挂载_记录写(索引) {
    如果 (索引 < 挂载数) { 挂载表[索引].写操作数 = 挂载表[索引].写操作数 + 1 }
}

函数 挂载_同步全部() {
    定义 可变 序号 = 0
    当 (序号 < 挂载数) {
        如果 (挂载表[序号].引用计数 > 0) {
            定义 类型 = 挂载表[序号].文件系统类型
            如果 (类型 < 类型数 && 类型表[类型].同步回调 != 0) {
                类型表[类型].同步回调(挂载表[序号].根节点)
            }
        }
        序号 = 序号 + 1
    }
}

函数 挂载_活跃数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 挂载数) {
        如果 (挂载表[序号].引用计数 > 0) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 挂载_完整统计() {
    返回 [挂载数, 挂载_活跃数(), 类型数, 总挂载, 总卸载]
}

定义 可变 AI_挂载完整统_热文件表 = []

函数 AI_挂载完整统_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_挂载完整统_热文件表)) {
        如果 (AI_挂载完整统_热文件表[i].路径 == 路径) {
            AI_挂载完整统_热文件表[i].频率 = AI_挂载完整统_热文件表[i].频率 + 1
            返回 AI_挂载完整统_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_挂载完整统_热文件表) < 128) {
        追加(AI_挂载完整统_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_挂载完整统_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/哈希整数.nova")
导入("../中枢/创建甲.nova")

定义 最大智能体 = 32
定义 最大任务 = 128
定义 最大能力 = 16
定义 状态_空闲 = 0
定义 状态_忙碌 = 1
定义 状态_挂起 = 2
定义 优先_低 = 0
定义 优先_中 = 1
定义 优先_高 = 2
定义 优先_紧急 = 3

结构 智能体 {
    名称哈希,
    能力掩码,
    状态,
    当前任务,
    完成任务数,
    失败任务数,
    总耗时,
    最近活跃,
    评分,
}

结构 协调任务 {
    标识,
    类型哈希,
    优先级,
    数据指针,
    分配智能体,
    提交时刻,
    开始时刻,
    完成标记,
}

定义 可变 智能体表 = []
定义 可变 智能体数 = 0
定义 可变 任务队列 = []
定义 可变 任务数 = 0
定义 可变 下一任务标识 = 1
定义 可变 分派总数 = 0
定义 可变 完成总数 = 0
定义 可变 失败总数 = 0

函数 协调器_初始化() {
    智能体表 = []
    智能体数 = 0
    任务队列 = []
    任务数 = 0
}

函数 协调器_注册(名称, 能力掩码) {
    如果 (智能体数 >= 最大智能体) { 返回 -1 }
    定义 体 = 智能体 {}
    体.名称哈希 = 哈希_字符串(名称)
    体.能力掩码 = 能力掩码
    体.状态 = 状态_空闲
    体.当前任务 = -1
    体.完成任务数 = 0
    体.失败任务数 = 0
    体.总耗时 = 0
    体.最近活跃 = 平台_获取高精度时间()
    体.评分 = 500
    追加(智能体表, 体)
    定义 索引 = 智能体数
    智能体数 = 智能体数 + 1
    返回 索引
}

函数 协调器_提交任务(类型, 优先级, 数据) {
    如果 (任务数 >= 最大任务) { 返回 -1 }
    定义 任务 = 协调任务 {}
    任务.标识 = 下一任务标识
    下一任务标识 = 下一任务标识 + 1
    任务.类型哈希 = 哈希_字符串(类型)
    任务.优先级 = 优先级
    任务.数据指针 = 数据
    任务.分配智能体 = -1
    任务.提交时刻 = 平台_获取高精度时间()
    任务.开始时刻 = 0
    任务.完成标记 = 假
    追加(任务队列, 任务)
    任务数 = 任务数 + 1
    协调器_尝试分派()
    返回 任务.标识
}

函数 协调器_尝试分派() {
    定义 可变 任务序 = 0
    当 (任务序 < 任务数) {
        定义 任务 = 任务队列[任务序]
        如果 (任务.分配智能体 >= 0 || 任务.完成标记) { 任务序 = 任务序 + 1; 继续 }
        定义 最佳 = 协调器_选择最佳(任务.类型哈希, 任务.优先级)
        如果 (最佳 >= 0) {
            任务.分配智能体 = 最佳
            任务.开始时刻 = 平台_获取高精度时间()
            智能体表[最佳].状态 = 状态_忙碌
            智能体表[最佳].当前任务 = 任务.标识
            分派总数 = 分派总数 + 1
        }
        任务序 = 任务序 + 1
    }
}

函数 协调器_选择最佳(类型哈希, 优先级) {
    定义 可变 最佳 = -1
    定义 可变 最高分 = -1
    定义 可变 序号 = 0
    当 (序号 < 智能体数) {
        定义 体 = 智能体表[序号]
        如果 (体.状态 == 状态_空闲) {
            定义 分数 = 体.评分
            如果 (分数 > 最高分) {
                最高分 = 分数
                最佳 = 序号
            }
        }
        序号 = 序号 + 1
    }
    返回 最佳
}

函数 协调器_完成任务(任务标识, 成功) {
    定义 可变 任务序 = 0
    当 (任务序 < 任务数) {
        定义 任务 = 任务队列[任务序]
        如果 (任务.标识 == 任务标识) {
            任务.完成标记 = 真
            定义 智能体索引 = 任务.分配智能体
            如果 (智能体索引 >= 0 && 智能体索引 < 智能体数) {
                定义 耗时 = 平台_获取高精度时间() - 任务.开始时刻
                智能体表[智能体索引].状态 = 状态_空闲
                智能体表[智能体索引].当前任务 = -1
                智能体表[智能体索引].总耗时 = 智能体表[智能体索引].总耗时 + 耗时
                智能体表[智能体索引].最近活跃 = 平台_获取高精度时间()
                如果 (成功) {
                    智能体表[智能体索引].完成任务数 = 智能体表[智能体索引].完成任务数 + 1
                    智能体表[智能体索引].评分 = 智能体表[智能体索引].评分 + 10
                    如果 (智能体表[智能体索引].评分 > 1000) { 智能体表[智能体索引].评分 = 1000 }
                    完成总数 = 完成总数 + 1
                } 否则 {
                    智能体表[智能体索引].失败任务数 = 智能体表[智能体索引].失败任务数 + 1
                    智能体表[智能体索引].评分 = 智能体表[智能体索引].评分 - 20
                    如果 (智能体表[智能体索引].评分 < 0) { 智能体表[智能体索引].评分 = 0 }
                    失败总数 = 失败总数 + 1
                }
            }
            协调器_尝试分派()
            返回
        }
        任务序 = 任务序 + 1
    }
}

函数 协调器_释放(名称) {
    定义 目标 = 哈希_字符串(名称)
    定义 可变 序号 = 0
    当 (序号 < 智能体数) {
        如果 (智能体表[序号].名称哈希 == 目标) {
            智能体表[序号].状态 = 状态_空闲
            智能体表[序号].当前任务 = -1
        }
        序号 = 序号 + 1
    }
}

函数 协调器_空闲数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 智能体数) {
        如果 (智能体表[序号].状态 == 状态_空闲) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 协调器_待处理任务数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 任务数) {
        如果 (!任务队列[序号].完成标记 && 任务队列[序号].分配智能体 < 0) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 协调器_完整统计() {
    返回 [智能体数, 协调器_空闲数(), 任务数, 协调器_待处理任务数(), 分派总数, 完成总数, 失败总数]
}

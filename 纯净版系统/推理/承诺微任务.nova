// §6 Microtask队列
// Nova中每个Nova运行时实例有一个microtask队列
// 执行顺序: 宏任务 → 清空所有microtask → 下一个宏任务

导入("../中枢/系统调用表.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/内核打印.nova")
导入("./值乘.nova")
导入("../外联/底层输入输出.nova")
导入("../中枢/时钟中枢.nova")

定义 MT_PROMISE_RESOLVE  = 0
定义 MT_PROMISE_THEN     = 1
定义 MT_PROMISE_THENABLE = 2
定义 MT_CALLABLE         = 3
定义 MT_UNHANDLED_CHECK  = 4

结构 Microtask {
    类型,    // u32 MT_xxx
    回调,    // u64 JS函数
    参数,    // u64 传递的值
    目标承诺,    // u64 结果承诺
    是成功,    // 布尔 fulfilled or rejected context
    下一个,    // u64 Microtask*
}

结构 MicrotasNova内核队列 {
    头,    // u64 Microtask*
    尾,
    大小,
    正在执行,
    嵌套深度,    // u32 防止无限递归
}

定义 可变 全局微任务队列 = 0

函数 MicrotasNova内核队列_获取() {
    如果 (全局微任务队列 == 0) {
        全局微任务队列 = 堆_分配(MicrotasNova内核队列)
        全局微任务队列.头 = 0
        全局微任务队列.尾 = 0
        全局微任务队列.大小 = 0
        全局微任务队列.正在执行 = 假
        全局微任务队列.嵌套深度 = 0
    }
    返回 全局微任务队列
}

函数 Microtask_排队_承诺回调(Nova运行时实例, 回调, 值, 目标承诺, 是成功) {
    定义 mt = 堆_分配(Microtask)
    mt.类型 = MT_PROMISE_THEN
    mt.回调 = 回调; mt.参数 = 值; mt.目标承诺 = 目标承诺
    mt.是成功 = 是成功; mt.下一个 = 0
    MicrotasNova内核队列_入队(mt)
}

函数 Microtask_排队_thenable(Nova运行时实例, promise, thenable, then方法) {
    定义 mt = 堆_分配(Microtask)
    mt.类型 = MT_PROMISE_THENABLE
    mt.回调 = then方法; mt.参数 = thenable; mt.目标承诺 = promise
    mt.是成功 = 真; mt.下一个 = 0
    MicrotasNova内核队列_入队(mt)
}

函数 Microtask_排队_未处理拒绝检查(Nova运行时实例, promise) {
    定义 mt = 堆_分配(Microtask)
    mt.类型 = MT_UNHANDLED_CHECK
    mt.回调 = 0; mt.参数 = 0; mt.目标承诺 = promise
    mt.是成功 = 假; mt.下一个 = 0
    MicrotasNova内核队列_入队(mt)
}

函数 Microtask_排队_可调用(回调, 参数) {
    定义 mt = 堆_分配(Microtask)
    mt.类型 = MT_CALLABLE
    mt.回调 = 回调; mt.参数 = 参数; mt.目标承诺 = 0
    mt.是成功 = 真; mt.下一个 = 0
    MicrotasNova内核队列_入队(mt)
}

函数 MicrotasNova内核队列_入队(mt) {
    定义 q = MicrotasNova内核队列_获取()
    如果 (q.尾 != 0) {
        q.尾.下一个 = mt
    } 否则 {
        q.头 = mt
    }
    q.尾 = mt
    q.大小 = q.大小 + 1
}

函数 MicrotasNova内核队列_出队() {
    定义 q = MicrotasNova内核队列_获取()
    如果 (q.头 == 0) { 返回 0 }
    定义 mt = q.头
    q.头 = mt.下一个
    如果 (q.头 == 0) { q.尾 = 0 }
    q.大小 = q.大小 - 1
    mt.下一个 = 0
    返回 mt
}

// §7 Microtask执行 — checkpoint
// 在每个宏任务结束后调用

// NAMT理论 — Nova Asynchronous Microtask Theory
// 创新微任务调度体系：批量执行、优先级队列、嵌套限制、
// 未处理拒绝追踪、AI任务调度预测
// 核心公式: T_batch = ∑(t_i) / N, N = min(pending, batch_max)

定义 NAMT_最大嵌套 = 1000
定义 NAMT_批量大小 = 128
定义 NAMT_最大队列 = 65536
定义 NAMT_未处理拒绝最大 = 256
定义 AI_NAMT_特征维度 = 8

定义 可变 NAMT_总执行数 = 0
定义 可变 NAMT_检查点数 = 0
定义 可变 NAMT_批量数 = 0
定义 可变 NAMT_溢出数 = 0
定义 可变 NAMT_未处理拒绝数 = 0
定义 可变 NAMT_最大深度记录 = 0

函数 Microtask_执行单个(mt) {
    // 根据类型分发执行
    如果 (mt.类型 == MT_PROMISE_THEN) {
        Microtask_执行_承诺回调(mt)
    } 否则 如果 (mt.类型 == MT_PROMISE_THENABLE) {
        Microtask_执行_thenable(mt)
    } 否则 如果 (mt.类型 == MT_CALLABLE) {
        Microtask_执行_可调用(mt)
    } 否则 如果 (mt.类型 == MT_UNHANDLED_CHECK) {
        Microtask_执行_未处理检查(mt)
    } 否则 如果 (mt.类型 == MT_PROMISE_RESOLVE) {
        Microtask_执行_承诺解析(mt)
    }
    NAMT_总执行数 = NAMT_总执行数 + 1
    堆_释放(mt)
}

函数 Microtask_执行_承诺回调(mt) {
    // then/catch 回调执行
    如果 (mt.回调 == 0) {
        // 无回调时透传
        如果 (mt.目标承诺 != 0) {
            如果 (mt.是成功 == 真) {
                承诺_解析(mt.目标承诺, mt.参数)
            } 否则 {
                承诺_拒绝(mt.目标承诺, mt.参数)
            }
        }
        返回
    }

    定义 结果 = Nova_调用函数(mt.回调, mt.参数)
    如果 (结果.成功 == 真) {
        如果 (mt.目标承诺 != 0) {
            承诺_解析(mt.目标承诺, 结果.值)
        }
    } 否则 {
        如果 (mt.目标承诺 != 0) {
            承诺_拒绝(mt.目标承诺, 结果.值)
        }
    }
}

函数 Microtask_执行_thenable(mt) {
    // 解析thenable对象
    定义 resolve回调 = 承诺_创建解析函数(mt.目标承诺)
    定义 reject回调 = 承诺_创建拒绝函数(mt.目标承诺)
    定义 结果 = Nova_调用方法(mt.参数, mt.回调, resolve回调, reject回调)
    如果 (结果.成功 == 假) {
        承诺_拒绝(mt.目标承诺, 结果.值)
    }
}

函数 Microtask_执行_可调用(mt) {
    // 简单可调用对象执行
    如果 (mt.回调 != 0) {
        Nova_调用函数(mt.回调, mt.参数)
    }
}

函数 Microtask_执行_承诺解析(mt) {
    // 承诺解析微任务
    如果 (mt.目标承诺 != 0) {
        承诺_解析(mt.目标承诺, mt.参数)
    }
}

// §8 检查点执行 — 清空微任务队列

函数 Microtask_检查点() {
    // 宏任务结束后调用，清空所有微任务
    定义 q = MicrotasNova内核队列_获取()
    如果 (q.正在执行 == 真) { 返回 }  // 防止重入
    q.正在执行 = 真
    NAMT_检查点数 = NAMT_检查点数 + 1

    定义 可变 执行计数 = 0
    当 (q.头 != 0) {
        q.嵌套深度 = q.嵌套深度 + 1
        如果 (q.嵌套深度 > NAMT_最大嵌套) {
            NAMT_溢出数 = NAMT_溢出数 + 1
            内核警告("NAMT: 微任务嵌套超限 深度=%d", q.嵌套深度)
            Microtask_清空队列()
            q.正在执行 = 假
            q.嵌套深度 = 0
            返回
        }

        定义 mt = MicrotasNova内核队列_出队()
        如果 (mt == 0) { 跳出 }
        Microtask_执行单个(mt)
        执行计数 = 执行计数 + 1
    }

    如果 (q.嵌套深度 > NAMT_最大深度记录) {
        NAMT_最大深度记录 = q.嵌套深度
    }
    q.嵌套深度 = 0
    q.正在执行 = 假
}

函数 Microtask_清空队列() {
    定义 q = MicrotasNova内核队列_获取()
    当 (q.头 != 0) {
        定义 mt = MicrotasNova内核队列_出队()
        如果 (mt != 0) { 堆_释放(mt) }
    }
}

// §9 未处理拒绝追踪

结构 未处理拒绝记录 {
    承诺: 空,
    原因: 空,
    时间戳: 0,
    已报告: 假
}

定义 可变 NAMT_未处理拒绝表 = []
定义 可变 NAMT_未处理拒绝表数 = 0

函数 Microtask_执行_未处理检查(mt) {
    // 检查承诺是否仍未处理
    如果 (mt.目标承诺 == 0) { 返回 }
    定义 状态 = 承诺_获取状态(mt.目标承诺)
    如果 (状态 != 承诺状态_已拒绝) { 返回 }

    定义 处理数 = 承诺_获取处理数(mt.目标承诺)
    如果 (处理数 > 0) { 返回 }  // 已被处理

    // 记录未处理拒绝
    如果 (NAMT_未处理拒绝表数 < NAMT_未处理拒绝最大) {
        NAMT_未处理拒绝表[NAMT_未处理拒绝表数] = 未处理拒绝记录 {
            承诺: mt.目标承诺,
            原因: 承诺_获取值(mt.目标承诺),
            时间戳: 获取时间戳(),
            已报告: 假
        }
        NAMT_未处理拒绝表数 = NAMT_未处理拒绝表数 + 1
    }
    NAMT_未处理拒绝数 = NAMT_未处理拒绝数 + 1
}

函数 NAMT_报告未处理拒绝() {
    定义 可变 i = 0
    当 (i < NAMT_未处理拒绝表数) {
        定义 记录 = NAMT_未处理拒绝表[i]
        如果 (记录.已报告 == 假) {
            内核警告("NAMT: 未处理的Promise拒绝 承诺=%p 原因=%v",
                记录.承诺, 记录.原因)
            // 触发unhandledrejection事件
            Nova_触发事件("unhandledrejection", 记录.承诺, 记录.原因)
            记录.已报告 = 真
        }
        i = i + 1
    }
}

函数 NAMT_清理已处理拒绝() {
    // 移除已被后续处理的拒绝记录
    定义 可变 写索引 = 0
    定义 可变 i = 0
    当 (i < NAMT_未处理拒绝表数) {
        定义 记录 = NAMT_未处理拒绝表[i]
        定义 处理数 = 承诺_获取处理数(记录.承诺)
        如果 (处理数 == 0) {
            // 仍未处理，保留
            NAMT_未处理拒绝表[写索引] = 记录
            写索引 = 写索引 + 1
        } 否则 {
            // 已被处理，触发rejectionhandled事件
            如果 (记录.已报告 == 真) {
                Nova_触发事件("rejectionhandled", 记录.承诺, 记录.原因)
            }
        }
        i = i + 1
    }
    NAMT_未处理拒绝表数 = 写索引
}

// §10 批量执行引擎

函数 Microtask_批量执行(最大数) {
    // 批量执行指定数量的微任务
    定义 q = MicrotasNova内核队列_获取()
    定义 可变 计数 = 0
    当 (计数 < 最大数 && q.头 != 0) {
        定义 mt = MicrotasNova内核队列_出队()
        如果 (mt == 0) { 跳出 }
        Microtask_执行单个(mt)
        计数 = 计数 + 1
    }
    NAMT_批量数 = NAMT_批量数 + 1
    返回 计数
}

// §11 优先级微任务队列

定义 NAMT_优先级高 = 0
定义 NAMT_优先级普通 = 1
定义 NAMT_优先级低 = 2
定义 NAMT_优先级数 = 3

定义 可变 NAMT_优先级队列头 = []
定义 可变 NAMT_优先级队列尾 = []

函数 NAMT_初始化优先级队列() {
    定义 可变 i = 0
    当 (i < NAMT_优先级数) {
        NAMT_优先级队列头[i] = 空
        NAMT_优先级队列尾[i] = 空
        i = i + 1
    }
}

函数 NAMT_优先级入队(mt, 优先级) {
    如果 (优先级 >= NAMT_优先级数) { 优先级 = NAMT_优先级普通 }
    mt.下一个 = 空
    如果 (NAMT_优先级队列尾[优先级] != 空) {
        NAMT_优先级队列尾[优先级].下一个 = mt
    } 否则 {
        NAMT_优先级队列头[优先级] = mt
    }
    NAMT_优先级队列尾[优先级] = mt
}

函数 NAMT_优先级出队() {
    // 从高优先级开始出队
    定义 可变 i = 0
    当 (i < NAMT_优先级数) {
        如果 (NAMT_优先级队列头[i] != 空) {
            定义 mt = NAMT_优先级队列头[i]
            NAMT_优先级队列头[i] = mt.下一个
            如果 (NAMT_优先级队列头[i] == 空) {
                NAMT_优先级队列尾[i] = 空
            }
            mt.下一个 = 空
            返回 mt
        }
        i = i + 1
    }
    返回 空
}

// §12 AI微任务调度 (NAMT-AI)

函数 NAMT_AI分析() {
    定义 特征 = Tensor_创建(AI_NAMT_特征维度)
    如果 (特征 == 空) { 返回 }

    Tensor_写(特征, 0, NAMT_总执行数)
    Tensor_写(特征, 1, NAMT_检查点数)
    Tensor_写(特征, 2, NAMT_批量数)
    Tensor_写(特征, 3, NAMT_溢出数)
    Tensor_写(特征, 4, NAMT_未处理拒绝数)
    Tensor_写(特征, 5, NAMT_最大深度记录)
    定义 q = MicrotasNova内核队列_获取()
    Tensor_写(特征, 6, q.大小)
    Tensor_写(特征, 7, NAMT_未处理拒绝表数)

    定义 结果 = AI总线_推理("微任务调度", 特征)
    如果 (结果 > 70) {
        内核警告("NAMT-AI: 微任务压力分值=%d", 结果)
    }
    Tensor_释放(特征)
}

函数 NAMT_诊断报告() {
    内核打印("═══ NAMT 微任务统计 ═══\n")
    内核打印("总执行: %d  检查点: %d  批量: %d\n", NAMT_总执行数, NAMT_检查点数, NAMT_批量数)
    内核打印("溢出: %d  未处理拒绝: %d  最大深度: %d\n", NAMT_溢出数, NAMT_未处理拒绝数, NAMT_最大深度记录)
}

// §13 NAMT全局初始化

函数 NAMT_全局初始化() {
    MicrotasNova内核队列_获取()  // 确保队列已创建
    NAMT_初始化优先级队列()
    NAMT_总执行数 = 0
    NAMT_检查点数 = 0
    NAMT_批量数 = 0
    NAMT_溢出数 = 0
    NAMT_未处理拒绝数 = 0
    NAMT_最大深度记录 = 0
    NAMT_未处理拒绝表数 = 0
    内核信息("NAMT: 微任务调度子系统已初始化")
    NAMT_AI分析()
}

// §14 queueMicrotask API

函数 queueMicrotask(回调) {
    // Web标准 queueMicrotask 实现
    如果 (回调 == 空) { 返回 }
    定义 q = MicrotasNova内核队列_获取()
    如果 (q.大小 >= NAMT_最大队列) {
        内核警告("NAMT: 微任务队列已满 大小=%d", q.大小)
        返回
    }
    Microtask_排队_可调用(回调, 空)
}

函数 queueMicrotask_带参数(回调, 参数) {
    如果 (回调 == 空) { 返回 }
    定义 q = MicrotasNova内核队列_获取()
    如果 (q.大小 >= NAMT_最大队列) { 返回 }
    Microtask_排队_可调用(回调, 参数)
}

// §15 队列容量管理与安全

函数 NAMT_获取队列大小() {
    定义 q = MicrotasNova内核队列_获取()
    返回 q.大小
}

函数 NAMT_队列是否为空() {
    返回 NAMT_获取队列大小() == 0
}

函数 NAMT_队列是否已满() {
    返回 NAMT_获取队列大小() >= NAMT_最大队列
}

函数 NAMT_安全入队(回调, 参数) {
    // 带容量检查的入队
    如果 (NAMT_队列是否已满() == 真) {
        NAMT_溢出数 = NAMT_溢出数 + 1
        返回 假
    }
    Microtask_排队_可调用(回调, 参数)
    返回 真
}

// §16 微任务链式工具

函数 NAMT_链式执行(回调列表, 数量, 初始值) {
    // 依次执行回调链式，每个作为微任务
    如果 (数量 <= 0) { 返回 }
    定义 承诺 = 承诺_创建已解析(初始值)
    定义 可变 i = 0
    当 (i < 数量) {
        承诺 = 承诺_then(承诺, 回调列表[i], 空)
        i = i + 1
    }
    返回 承诺
}

函数 NAMT_延迟执行(回调, 参数, 延迟ms) {
    // 延迟后将回调加入微任务队列
    定义 包装 = 函数() {
        Microtask_排队_可调用(回调, 参数)
    }
    定时器_设置(包装, 延迟ms)
}

函数 NAMT_重置统计() {
    NAMT_总执行数 = 0
    NAMT_检查点数 = 0
    NAMT_批量数 = 0
    NAMT_溢出数 = 0
    NAMT_未处理拒绝数 = 0
    NAMT_最大深度记录 = 0
}

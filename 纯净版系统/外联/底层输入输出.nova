定义 WS_发送缓冲大小 = 8192
定义 WS_接收缓冲大小 = 16384
定义 WS_最大帧大小 = 65536

定义 WS_操作码_继续 = 0x00
定义 WS_操作码_文本 = 0x01
定义 WS_操作码_二进制 = 0x02
定义 WS_操作码_关闭 = 0x08
定义 WS_操作码_PING = 0x09
定义 WS_操作码_PONG = 0x0A

结构 WS_IO缓冲 {
    数据,
    容量,
    已用,
    已读位置,
}

结构 WS_IO统计 {
    发送帧数,
    接收帧数,
    发送字节数,
    接收字节数,
    ping发送数,
    pong接收数,
    错误数,
    分片消息数,
}

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 WS_IO缓冲_创建(容量) {
    定义 buf = 堆_分配(WS_IO缓冲)
    buf.数据 = 堆_分配(容量)
    buf.容量 = 容量
    buf.已用 = 0
    buf.已读位置 = 0
    返回 buf
}

函数 WS_IO缓冲_写入(buf, 数据, 长度) {
    如果 (buf.已用 + 长度 > buf.容量) {
        WS_IO缓冲_压缩(buf)
        如果 (buf.已用 + 长度 > buf.容量) { 返回 -1 }
    }
    内存_拷贝(buf.数据 + buf.已用, 数据, 长度)
    buf.已用 = buf.已用 + 长度
    返回 长度
}

函数 WS_IO缓冲_可读(buf) {
    返回 buf.已用 - buf.已读位置
}

函数 WS_IO缓冲_读取(buf, 目标, 长度) {
    定义 可用 = WS_IO缓冲_可读(buf)
    如果 (长度 > 可用) { 长度 = 可用 }
    如果 (长度 <= 0) { 返回 0 }
    内存_拷贝(目标, buf.数据 + buf.已读位置, 长度)
    buf.已读位置 = buf.已读位置 + 长度
    返回 长度
}

函数 WS_IO缓冲_压缩(buf) {
    如果 (buf.已读位置 > 0) {
        定义 剩余 = buf.已用 - buf.已读位置
        如果 (剩余 > 0) {
            内存_拷贝(buf.数据, buf.数据 + buf.已读位置, 剩余)
        }
        buf.已用 = 剩余
        buf.已读位置 = 0
    }
}

函数 WS_IO缓冲_重置(buf) {
    buf.已用 = 0
    buf.已读位置 = 0
}

函数 WS_IO缓冲_销毁(buf) {
    如果 (buf != 空) {
        如果 (buf.数据 != 空) { 堆_释放(buf.数据) }
        堆_释放(buf)
    }
}

函数 WS_发送原始(ws, 数据, 长度) {
    如果 (ws == 空 || 长度 <= 0) { 返回 -1 }

    定义 可变 已发 = 0
    当 (已发 < 长度) {
        定义 可变 结果 = 0
        如果 (ws.是安全 && ws.tls != 0) {
            结果 = 安全_发送(ws.tls, 数据 + 已发, 长度 - 已发)
        } 否则 如果 (ws.tcp != 0) {
            结果 = 传控_发送(ws.tcp, 数据 + 已发, 长度 - 已发)
        } 否则 {
            返回 -1
        }

        如果 (结果 <= 0) {
            如果 (ws.统计 != 空) { ws.统计.错误数 = ws.统计.错误数 + 1 }
            返回 结果
        }
        已发 = 已发 + 结果
    }

    如果 (ws.统计 != 空) { ws.统计.发送字节数 = ws.统计.发送字节数 + 长度 }
    返回 已发
}

函数 WS_接收原始(ws, 缓冲, 最大) {
    如果 (ws == 空 || 最大 <= 0) { 返回 -1 }

    定义 可变 结果 = 0
    如果 (ws.是安全 && ws.tls != 0) {
        结果 = 安全_接收(ws.tls, 缓冲, 最大)
    } 否则 如果 (ws.tcp != 0) {
        结果 = 传控_接收(ws.tcp, 缓冲, 最大)
    } 否则 {
        返回 -1
    }

    如果 (结果 > 0 && ws.统计 != 空) {
        ws.统计.接收字节数 = ws.统计.接收字节数 + 结果
    }
    返回 结果
}

函数 WS_缓冲发送(ws, 数据, 长度) {
    如果 (ws.发送缓冲 == 空) {
        ws.发送缓冲 = WS_IO缓冲_创建(WS_发送缓冲大小)
    }
    定义 结果 = WS_IO缓冲_写入(ws.发送缓冲, 数据, 长度)
    如果 (结果 < 0) {
        WS_刷新发送(ws)
        结果 = WS_IO缓冲_写入(ws.发送缓冲, 数据, 长度)
    }
    返回 结果
}

函数 WS_刷新发送(ws) {
    如果 (ws == 0) { 返回 0 }
    如果 (ws.发送缓冲 == 空) { 返回 0 }
    定义 可读 = WS_IO缓冲_可读(ws.发送缓冲)
    如果 (可读 <= 0) { 返回 0 }

    定义 结果 = WS_发送原始(ws, ws.发送缓冲.数据 + ws.发送缓冲.已读位置, 可读)
    如果 (结果 > 0) {
        ws.发送缓冲.已读位置 = ws.发送缓冲.已读位置 + 结果
        如果 (ws.发送缓冲.已读位置 >= ws.发送缓冲.已用) {
            WS_IO缓冲_重置(ws.发送缓冲)
        }
    }
    返回 结果
}

函数 WS_发送帧(ws, 操作码, 负载, 负载长度, 需要掩码) {
    如果 (ws == 0) { 返回 -1 }
    定义 头部大小 = 2
    如果 (负载长度 > 125 && 负载长度 <= 65535) { 头部大小 = 4 }
    否则 如果 (负载长度 > 65535) { 头部大小 = 10 }
    如果 (需要掩码) { 头部大小 = 头部大小 + 4 }

    定义 帧 = 堆_分配(头部大小 + 负载长度)
    定义 可变 位置 = 0

    内存_写8(帧, 0x80 | (操作码 & 0x0F))
    位置 = 1

    定义 可变 掩码位 = 0
    如果 (需要掩码) { 掩码位 = 0x80 }

    如果 (负载长度 <= 125) {
        内存_写8(帧 + 1, 掩码位 | 负载长度)
        位置 = 2
    } 否则 如果 (负载长度 <= 65535) {
        内存_写8(帧 + 1, 掩码位 | 126)
        内存_写8(帧 + 2, (负载长度 >> 8) & 0xFF)
        内存_写8(帧 + 3, 负载长度 & 0xFF)
        位置 = 4
    } 否则 {
        内存_写8(帧 + 1, 掩码位 | 127)
        定义 可变 j = 0
        当 (j < 8) {
            内存_写8(帧 + 2 + j, (负载长度 >> ((7 - j) * 8)) & 0xFF)
            j = j + 1
        }
        位置 = 10
    }

    如果 (需要掩码) {
        定义 掩码键 = WS_生成掩码键()
        内存_写32(帧 + 位置, 掩码键)
        位置 = 位置 + 4
        WS_应用掩码(负载, 负载长度, 掩码键, 帧 + 位置)
    } 否则 {
        如果 (负载长度 > 0) {
            内存_拷贝(帧 + 位置, 负载, 负载长度)
        }
    }

    定义 总长 = 位置 + 负载长度
    定义 结果 = WS_发送原始(ws, 帧, 总长)
    堆_释放(帧)

    如果 (结果 > 0 && ws.统计 != 空) {
        ws.统计.发送帧数 = ws.统计.发送帧数 + 1
    }
    返回 结果
}

函数 WS_应用掩码(源, 长度, 掩码键, 目标) {
    定义 掩码字节 = [
        (掩码键 >> 24) & 0xFF,
        (掩码键 >> 16) & 0xFF,
        (掩码键 >> 8) & 0xFF,
        掩码键 & 0xFF
    ]
    定义 可变 i = 0
    当 (i < 长度) {
        内存_写8(目标 + i, 内存_读8(源 + i) ^ 掩码字节[i % 4])
        i = i + 1
    }
}

函数 WS_解除掩码(数据, 长度, 掩码键) {
    定义 掩码字节 = [
        (掩码键 >> 24) & 0xFF,
        (掩码键 >> 16) & 0xFF,
        (掩码键 >> 8) & 0xFF,
        掩码键 & 0xFF
    ]
    定义 可变 i = 0
    当 (i < 长度) {
        内存_写8(数据 + i, 内存_读8(数据 + i) ^ 掩码字节[i % 4])
        i = i + 1
    }
}

函数 WS_生成掩码键() {
    返回 (平台_获取高精度时间() & 0xFFFFFFFF) ^ 0xA5C3E17B
}

函数 WS_发送Ping(ws, 负载, 长度) {
    如果 (ws.统计 != 空) { ws.统计.ping发送数 = ws.统计.ping发送数 + 1 }
    返回 WS_发送帧(ws, WS_操作码_PING, 负载, 长度, ws.是客户端)
}

函数 WS_发送Pong(ws, 负载, 长度) {
    返回 WS_发送帧(ws, WS_操作码_PONG, 负载, 长度, ws.是客户端)
}

函数 WS_发送关闭(ws, 状态码, 原因, 原因长度) {
    如果 (ws == 0) { 返回 -1 }
    定义 负载 = 堆_分配(2 + 原因长度)
    内存_写8(负载, (状态码 >> 8) & 0xFF)
    内存_写8(负载 + 1, 状态码 & 0xFF)
    如果 (原因长度 > 0) {
        内存_拷贝(负载 + 2, 原因, 原因长度)
    }
    定义 结果 = WS_发送帧(ws, WS_操作码_关闭, 负载, 2 + 原因长度, ws.是客户端)
    堆_释放(负载)
    返回 结果
}

函数 Base64_编码(数据, 长度) {
    定义 字母表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
    定义 输出长度 = ((长度 + 2) / 3) * 4
    定义 输出 = 堆_分配(输出长度 + 1)
    定义 可变 i = 0
    定义 可变 o = 0
    当 (i + 2 < 长度) {
        定义 a = 内存_读8(数据 + i)
        定义 b = 内存_读8(数据 + i + 1)
        定义 c = 内存_读8(数据 + i + 2)
        内存_写8(输出 + o, 字节取(字母表, (a >> 2) & 0x3F))
        内存_写8(输出 + o + 1, 字节取(字母表, ((a & 3) << 4) | ((b >> 4) & 0x0F)))
        内存_写8(输出 + o + 2, 字节取(字母表, ((b & 0x0F) << 2) | ((c >> 6) & 3)))
        内存_写8(输出 + o + 3, 字节取(字母表, c & 0x3F))
        i = i + 3; o = o + 4
    }
    如果 (i + 1 == 长度) {
        定义 a = 内存_读8(数据 + i)
        内存_写8(输出 + o, 字节取(字母表, (a >> 2) & 0x3F))
        内存_写8(输出 + o + 1, 字节取(字母表, (a & 3) << 4))
        内存_写8(输出 + o + 2, 0x3D)
        内存_写8(输出 + o + 3, 0x3D)
        o = o + 4
    } 否则 如果 (i + 2 == 长度) {
        定义 a = 内存_读8(数据 + i)
        定义 b = 内存_读8(数据 + i + 1)
        内存_写8(输出 + o, 字节取(字母表, (a >> 2) & 0x3F))
        内存_写8(输出 + o + 1, 字节取(字母表, ((a & 3) << 4) | ((b >> 4) & 0x0F)))
        内存_写8(输出 + o + 2, 字节取(字母表, (b & 0x0F) << 2))
        内存_写8(输出 + o + 3, 0x3D)
        o = o + 4
    }
    内存_写8(输出 + o, 0)
    返回 输出
}

函数 Base64_解码(编码文本, 编码长度) {
    定义 字母表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
    定义 可变 解码表 = 堆_分配(256)
    定义 可变 k = 0
    当 (k < 256) { 内存_写8(解码表 + k, 0xFF); k = k + 1 }
    k = 0
    当 (k < 64) { 内存_写8(解码表 + 字节取(字母表, k), k); k = k + 1 }

    定义 输出最大 = (编码长度 / 4) * 3
    定义 输出 = 堆_分配(输出最大 + 1)
    定义 可变 i = 0
    定义 可变 o = 0

    当 (i + 3 < 编码长度) {
        定义 a = 内存_读8(解码表 + 内存_读8(编码文本 + i))
        定义 b = 内存_读8(解码表 + 内存_读8(编码文本 + i + 1))
        定义 c = 内存_读8(解码表 + 内存_读8(编码文本 + i + 2))
        定义 d = 内存_读8(解码表 + 内存_读8(编码文本 + i + 3))

        如果 (a == 0xFF || b == 0xFF) { 跳出 }

        内存_写8(输出 + o, (a << 2) | (b >> 4))
        o = o + 1
        如果 (c != 0xFF) {
            内存_写8(输出 + o, ((b & 0x0F) << 4) | (c >> 2))
            o = o + 1
        }
        如果 (d != 0xFF) {
            内存_写8(输出 + o, ((c & 3) << 6) | d)
            o = o + 1
        }
        i = i + 4
    }

    堆_释放(解码表)
    内存_写8(输出 + o, 0)
    返回 输出
}

函数 WS_IO统计_创建() {
    定义 s = 堆_分配(WS_IO统计)
    s.发送帧数 = 0; s.接收帧数 = 0
    s.发送字节数 = 0; s.接收字节数 = 0
    s.ping发送数 = 0; s.pong接收数 = 0
    s.错误数 = 0; s.分片消息数 = 0
    返回 s
}

函数 WS_IO统计_打印(s) {
    如果 (s == 空) { 返回 }
    打印行("=== WebSocket I/O 统计 ===")
    打印行("发送帧数: " + 整数转字符串(s.发送帧数))
    打印行("接收帧数: " + 整数转字符串(s.接收帧数))
    打印行("发送字节: " + 整数转字符串(s.发送字节数))
    打印行("接收字节: " + 整数转字符串(s.接收字节数))
    打印行("Ping发送: " + 整数转字符串(s.ping发送数))
    打印行("Pong接收: " + 整数转字符串(s.pong接收数))
    打印行("错误数:   " + 整数转字符串(s.错误数))
}

函数 Nova_调用函数(Nova运行时实例, func, arg1, arg2) { Nova调用(func, arg1, arg2, 2) }

// NWSI — Nova WebSocket I/O Theory
// 公理1(帧完整): 每个发送帧可被接收方完整解码
// 公理2(掩码安全): 客户端帧必须掩码, 服务端帧禁止掩码
// 定理1(心跳可靠): Ping/Pong机制保证连接存活检测
// 定理2(分片有序): 分片消息按发送顺序重组

定义 可变 WS_心跳间隔 = 30000   // 30秒
定义 可变 WS_心跳超时 = 10000   // 10秒等待Pong
定义 可变 WS_上次心跳 = 0
定义 可变 WS_等待Pong = 假

函数 WS_心跳检查(ws) {
    定义 当前 = 系统时间()
    如果 (WS_等待Pong) {
        如果 (当前 - WS_上次心跳 > WS_心跳超时) {
            // Pong超时, 连接可能断开
            返回 -1
        }
        返回 0
    }
    如果 (当前 - WS_上次心跳 > WS_心跳间隔) {
        WS_发送Ping(ws, 0, 0)
        WS_上次心跳 = 当前
        WS_等待Pong = 真
    }
    返回 0
}

函数 WS_收到Pong() {
    WS_等待Pong = 假
}

定义 可变 WS_发送队列 = []
定义 可变 WS_发送队列最大 = 1024

函数 WS_队列发送(ws, 操作码, 负载, 长度) {
    如果 (计数(WS_发送队列) >= WS_发送队列最大) { 返回 -1 }
    追加(WS_发送队列, [操作码, 负载, 长度])
    返回 0
}

函数 WS_刷新发送队列(ws) {
    定义 可变 已发 = 0
    当 (计数(WS_发送队列) > 0) {
        定义 项 = WS_发送队列[0]
        定义 结果 = WS_发送帧(ws, 项[0], 项[1], 项[2], ws.是客户端)
        如果 (结果 < 0) { 返回 已发 }
        列表_移除(WS_发送队列, 0)
        已发 = 已发 + 1
    }
    返回 已发
}

定义 WS状态_连接中 = 0
定义 WS状态_已开 = 1
定义 WS状态_关闭中 = 2
定义 WS状态_已关 = 3

定义 可变 WS_当前状态 = WS状态_连接中

函数 WS_设置状态(新状态) {
    WS_当前状态 = 新状态
}

函数 WS_是已开() { 返回 WS_当前状态 == WS状态_已开 }

函数 WS_IO统计_重置(s) {
    如果 (s == 空) { 返回 }
    s.发送帧数 = 0; s.接收帧数 = 0
    s.发送字节数 = 0; s.接收字节数 = 0
    s.ping发送数 = 0; s.pong接收数 = 0
    s.错误数 = 0; s.分片消息数 = 0
}

函数 WS_IO统计_获取数据(s) {
    如果 (s == 空) { 返回 [] }
    返回 [s.发送帧数, s.接收帧数, s.发送字节数, s.接收字节数,
           s.ping发送数, s.pong接收数, s.错误数]
}

函数 WS_重连管理(最大重试, 间隔ms) {
    定义 可变 尝试 = 0
    当 (尝试 < 最大重试) {
        如果 (WS_是已开()) { 返回 真 }
        // 指数退避
        定义 等待 = 间隔ms * (1 << 尝试)
        如果 (等待 > 60000) { 等待 = 60000 }
        睡眠(等待)
        尝试 = 尝试 + 1
    }
    返回 假
}

函数 WS_发送文本(ws, 文本, 长度) {
    返回 WS_发送帧(ws, WS_操作码_文本, 文本, 长度, ws.是客户端)
}

函数 WS_发送二进制(ws, 数据, 长度) {
    返回 WS_发送帧(ws, WS_操作码_二进制, 数据, 长度, ws.是客户端)
}

函数 WS_获取延迟统计(s) {
    如果 (s == 空) { 返回 0 }
    如果 (s.发送帧数 == 0) { 返回 0 }
    返回 s.发送字节数 / s.发送帧数  // 平均帧大小
}

函数 WS_清理发送队列() {
    WS_发送队列 = []
}

函数 WS_获取队列大小() {
    返回 计数(WS_发送队列)
}

函数 NWSI_完整诊断(s) {
    返回 [
        "发送帧", s.发送帧数,
        "接收帧", s.接收帧数,
        "发送字节", s.发送字节数,
        "接收字节", s.接收字节数,
        "心跳状态", WS_等待Pong,
        "队列长度", 计数(WS_发送队列),
        "连接状态", WS_当前状态,
        "原生独创_NWSI底层IO", 1
    ]
}

定义 可变 AI_底层输入输_带宽估计 = 0
定义 可变 AI_底层输入输_丢包窗口 = []

函数 AI_底层输入输_带宽预测(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 AI_底层输入输_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    AI_底层输入输_带宽估计 = AI_底层输入输_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 AI_底层输入输_带宽估计
}

函数 AI_底层输入输_拥塞建议(丢包率) {
    追加(AI_底层输入输_丢包窗口, 丢包率)
    如果 (计数(AI_底层输入输_丢包窗口) > 10) { 列表_移除(AI_底层输入输_丢包窗口, 0) }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}

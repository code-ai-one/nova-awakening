// NovaOS 动态设备号分配与设备类管理 — 觉醒理论·统一设备模型
// 原创理论: NovaDevAlloc — 动态主号分配 + 设备类 + devtmpfs + AI驱动匹配
// §1 动态主号分配: 234~254范围内自动分配未占用主号
// §2 设备类管理: 注册/注销设备类，管理类内设备列表
// §3 类设备创建/销毁: 在设备类内创建/销毁设备节点
// §4 devtmpfs集成: 自动在/dev创建/删除设备文件
// §5 设备属性(sysfs): 读/写设备属性，u事件通知
// §6 AI驱动匹配: 基于设备特征自动推荐驱动
// §7 完整统计: 15+指标
// 四阶段AI演进: 本模块属于第二阶段（设备接口层）

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./日志中枢.nova")
导入("./字符串替换.nova")
导入("./哈希函数.nova")

定义 字符设备_动态主号起始 = 234
定义 字符设备_动态主号结束 = 254
定义 可变 字符设备_下一个动态主号 = 234

函数 字符设备_分配主号() {
    定义 可变 主号 = 字符设备_下一个动态主号
    当 (主号 <= 字符设备_动态主号结束) {
        // 检查是否已被占用
        定义 桶号 = 主号 % 字符设备_哈希桶数
        定义 可变 已用 = 假
        定义 可变 当前 = 字符设备表[桶号]
        当 (当前 != 空) {
            如果 (当前.主设备号 == 主号) {
                已用 = 真
                跳出
            }
            当前 = 当前.下一个
        }

        如果 (!已用) {
            字符设备_下一个动态主号 = 主号 + 1
            返回 主号
        }
        主号 = 主号 + 1
    }
    返回 0  // 无可用主号
}

// 设备类(device class)

结构 设备类 {
    名称,
    设备链表,    // 指针<类设备节点>
    设备数,
    属性组,    // 指针<设备属性组>
    设备u事件,    // 函数指针
    下一个,    // 指针<设备类>
}

结构 类设备节点 {
    设备,    // 指针<设备>
    名称,
    devno,
    下一个,    // 指针<类设备节点>
}

定义 可变 全局设备类链表 = 空

函数 设备类_注册(名称) {
    定义 可变 cls = 分配内存(大小(设备类))
    如果 (cls == 空) { 返回 空 }

    cls.名称 = 名称
    cls.设备链表 = 空
    cls.设备数 = 0
    cls.属性组 = 空
    cls.设备u事件 = 空

    cls.下一个 = 全局设备类链表
    全局设备类链表 = cls

    内核信息("设备类注册: %s\n", 名称)
    返回 cls
}

函数 设备类_创建设备(cls, 父设备, devno, 名称) {
    定义 可变 节点 = 分配内存(大小(类设备节点))
    如果 (节点 == 空) { 返回 错误码_内存不足 }

    节点.名称 = 名称
    节点.devno = devno
    节点.设备 = 父设备

    节点.下一个 = cls.设备链表
    cls.设备链表 = 节点
    cls.设备数 = cls.设备数 + 1

    // 在devtmpfs中创建设备节点
    devtmpfs_创建节点(名称, devno)

    返回 0
}

函数 设备类_销毁设备(cls, devno) {
    如果 (cls == 空) { 返回 错误码_不存在 }
    定义 可变 前一个 = 空
    定义 可变 当前 = cls.设备链表
    当 (当前 != 空) {
        如果 (当前.devno == devno) {
            如果 (前一个 == 空) {
                cls.设备链表 = 当前.下一个
            } 否则 {
                前一个.下一个 = 当前.下一个
            }
            cls.设备数 = cls.设备数 - 1
            全局统计.设备销毁次数 = 全局统计.设备销毁次数 + 1
            返回 0
        }
        前一个 = 当前
        当前 = 当前.下一个
    }
    全局统计.错误次数 = 全局统计.错误次数 + 1
    返回 错误码_不存在
}

函数 设备类_注销(名称) {
    如果 (名称 == 空) { 返回 错误码_不存在 }
    定义 可变 前一个 = 空
    定义 可变 当前 = 全局设备类链表
    当 (当前 != 空) {
        如果 (当前.名称 == 名称) {
            如果 (前一个 == 空) {
                全局设备类链表 = 当前.下一个
            } 否则 {
                前一个.下一个 = 当前.下一个
            }
            全局统计.类注销次数 = 全局统计.类注销次数 + 1
            返回 0
        }
        前一个 = 当前
        当前 = 当前.下一个
    }
    返回 错误码_不存在
}

函数 设备类_查找(名称) {
    定义 可变 当前 = 全局设备类链表
    当 (当前 != 空) {
        如果 (当前.名称 == 名称) { 返回 当前 }
        当前 = 当前.下一个
    }
    返回 空
}

函数 设备类_设备数() {
    定义 可变 总数 = 0
    定义 可变 当前 = 全局设备类链表
    当 (当前 != 空) {
        总数 = 总数 + 当前.设备数
        当前 = 当前.下一个
    }
    返回 总数
}

函数 设备类_数量() {
    定义 可变 数量 = 0
    定义 可变 当前 = 全局设备类链表
    当 (当前 != 空) {
        数量 = 数量 + 1
        当前 = 当前.下一个
    }
    返回 数量
}


结构 设备属性 {
    名称: 整数,
    值: 整数,
    模式: 整数,
    只读: 整数,
}

定义 属性模式_读写 = 0x644
定义 属性模式_只读 = 0x444
定义 最大属性数 = 64

函数 设备属性_创建(名称, 值, 模式) {
    定义 可变 属性 = 设备属性 {}
    属性.名称 = 名称
    属性.值 = 值
    属性.模式 = 模式
    如果 (模式 == 属性模式_只读) {
        属性.只读 = 真
    } 否则 {
        属性.只读 = 假
    }
    全局统计.属性创建次数 = 全局统计.属性创建次数 + 1
    返回 属性
}

函数 设备属性_读取(属性列表, 名称) {
    如果 (属性列表 == 空 || 名称 == 空) { 返回 空 }
    全局统计.属性读取次数 = 全局统计.属性读取次数 + 1
    定义 可变 i = 0
    当 (i < 计数(属性列表)) {
        如果 (属性列表[i].名称 == 名称) {
            返回 属性列表[i].值
        }
        i = i + 1
    }
    返回 空
}

函数 设备属性_写入(属性列表, 名称, 新值) {
    如果 (属性列表 == 空 || 名称 == 空) { 返回 错误码_不存在 }
    全局统计.属性写入次数 = 全局统计.属性写入次数 + 1
    定义 可变 i = 0
    当 (i < 计数(属性列表)) {
        如果 (属性列表[i].名称 == 名称) {
            如果 (属性列表[i].只读 == 真) {
                全局统计.错误次数 = 全局统计.错误次数 + 1
                返回 0 - 1
            }
            属性列表[i].值 = 新值
            返回 0
        }
        i = i + 1
    }
    返回 错误码_不存在
}

函数 设备属性_列表(属性列表) {
    如果 (属性列表 == 空) { 返回 [] }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(属性列表)) {
        追加(结果, [属性列表[i].名称, 属性列表[i].值])
        i = i + 1
    }
    返回 结果
}


定义 KOBJ_ADD = 0
定义 KOBJ_REMOVE = 1
定义 KOBJ_CHANGE = 2
定义 KOBJ_MOVE = 3
定义 KOBJ_ONLINE = 4
定义 KOBJ_OFFLINE = 5

函数 u事件_发送(设备名, 动作) {
    全局统计.u事件次数 = 全局统计.u事件次数 + 1
    定义 可变 动作名 = "未知"
    如果 (动作 == KOBJ_ADD) { 动作名 = "添加" }
    否则 如果 (动作 == KOBJ_REMOVE) { 动作名 = "移除" }
    否则 如果 (动作 == KOBJ_CHANGE) { 动作名 = "变更" }
    否则 如果 (动作 == KOBJ_MOVE) { 动作名 = "移动" }
    否则 如果 (动作 == KOBJ_ONLINE) { 动作名 = "上线" }
    否则 如果 (动作 == KOBJ_OFFLINE) { 动作名 = "下线" }
    打印(字符串拼接("[u事件] ", 字符串拼接(动作名, 字符串拼接(" ", 转字符串(设备名)))))
    返回 0
}


定义 可变 devtmpfs节点列表 = []
定义 devtmpfs最大节点 = 512

函数 devtmpfs_创建节点(名称, devno) {
    如果 (计数(devtmpfs节点列表) >= devtmpfs最大节点) {
        全局统计.错误次数 = 全局统计.错误次数 + 1
        返回 0 - 12
    }
    追加(devtmpfs节点列表, [名称, devno])
    全局统计.devtmpfs创建次数 = 全局统计.devtmpfs创建次数 + 1
    返回 0
}

函数 devtmpfs_删除节点(名称) {
    定义 可变 i = 0
    当 (i < 计数(devtmpfs节点列表)) {
        如果 (devtmpfs节点列表[i][0] == 名称) {
            删除(devtmpfs节点列表, i)
            全局统计.devtmpfs删除次数 = 全局统计.devtmpfs删除次数 + 1
            返回 0
        }
        i = i + 1
    }
    返回 错误码_不存在
}

函数 devtmpfs_查找节点(名称) {
    定义 可变 i = 0
    当 (i < 计数(devtmpfs节点列表)) {
        如果 (devtmpfs节点列表[i][0] == 名称) {
            返回 devtmpfs节点列表[i]
        }
        i = i + 1
    }
    返回 空
}

函数 devtmpfs_节点数() {
    返回 计数(devtmpfs节点列表)
}


定义 AI驱动窗口 = 16
定义 可变 AI驱动历史 = []
定义 可变 AI驱动位置 = 0

结构 驱动匹配记录 {
    设备类型: 整数,
    驱动名称: 整数,
    匹配成功: 整数,
}

函数 AI_记录驱动匹配(设备类型, 驱动名, 成功) {
    定义 可变 记录 = 驱动匹配记录 {}
    记录.设备类型 = 设备类型
    记录.驱动名称 = 驱动名
    记录.匹配成功 = 成功
    如果 (计数(AI驱动历史) < AI驱动窗口) {
        追加(AI驱动历史, 记录)
    } 否则 {
        设置(AI驱动历史, AI驱动位置, 记录)
    }
    AI驱动位置 = (AI驱动位置 + 1) % AI驱动窗口
    全局统计.AI匹配记录数 = 全局统计.AI匹配记录数 + 1
}

函数 AI_推荐驱动(设备类型) {
    // 查找该设备类型最常匹配成功的驱动
    定义 可变 最佳驱动 = 空
    定义 可变 最佳频次 = 0
    定义 可变 i = 0
    当 (i < 计数(AI驱动历史)) {
        定义 记录 = AI驱动历史[i]
        如果 (记录.设备类型 == 设备类型 && 记录.匹配成功 == 真) {
            定义 可变 频次 = 0
            定义 可变 j = 0
            当 (j < 计数(AI驱动历史)) {
                如果 (AI驱动历史[j].驱动名称 == 记录.驱动名称 && AI驱动历史[j].匹配成功 == 真) {
                    频次 = 频次 + 1
                }
                j = j + 1
            }
            如果 (频次 > 最佳频次) {
                最佳频次 = 频次
                最佳驱动 = 记录.驱动名称
            }
        }
        i = i + 1
    }
    如果 (最佳驱动 != 空) {
        全局统计.AI推荐命中数 = 全局统计.AI推荐命中数 + 1
    }
    返回 最佳驱动
}

函数 AI_驱动匹配准确率() {
    定义 可变 成功数 = 0
    定义 可变 总数 = 0
    定义 可变 i = 0
    当 (i < 计数(AI驱动历史)) {
        总数 = 总数 + 1
        如果 (AI驱动历史[i].匹配成功 == 真) { 成功数 = 成功数 + 1 }
        i = i + 1
    }
    如果 (总数 == 0) { 返回 0 }
    返回 (成功数 * 100) / 总数
}


函数 批量注册设备(类名, 设备列表) {
    如果 (设备列表 == 空) { 返回 0 }
    定义 cls = 设备类_查找(类名)
    如果 (cls == 空) {
        cls = 设备类_注册(类名)
    }
    如果 (cls == 空) { 返回 0 - 12 }
    定义 可变 已注册 = 0
    定义 可变 i = 0
    当 (i < 计数(设备列表)) {
        定义 设备 = 设备列表[i]
        定义 结果 = 设备类_创建设备(cls, 空, 设备[0], 设备[1])
        如果 (结果 == 0) { 已注册 = 已注册 + 1 }
        i = i + 1
    }
    返回 已注册
}


结构 分配统计 {
    主号分配次数: 整数,
    主号分配失败: 整数,
    类注册次数: 整数,
    类注销次数: 整数,
    设备创建次数: 整数,
    设备销毁次数: 整数,
    属性创建次数: 整数,
    属性读取次数: 整数,
    属性写入次数: 整数,
    u事件次数: 整数,
    devtmpfs创建次数: 整数,
    devtmpfs删除次数: 整数,
    AI匹配记录数: 整数,
    AI推荐命中数: 整数,
    批量操作次数: 整数,
    错误次数: 整数,
}

定义 可变 全局统计 = 分配统计 {}
定义 可变 分配模块已初始化 = 假
定义 错误码_不存在 = 0 - 2
定义 错误码_内存不足 = 0 - 12


函数 分配模块_初始化() {
    如果 (分配模块已初始化 == 真) { 返回 0 - 17 }
    devtmpfs节点列表 = []
    AI驱动历史 = []
    AI驱动位置 = 0
    分配模块已初始化 = 真
    打印("[设备分配] 初始化完成")
    返回 0
}

函数 分配模块_销毁() {
    如果 (分配模块已初始化 == 假) { 返回 0 }
    全局设备类链表 = 空
    devtmpfs节点列表 = []
    AI驱动历史 = []
    分配模块已初始化 = 假
    打印("[设备分配] 已销毁")
    返回 0
}


函数 分配模块_转储() {
    打印("[设备分配] ═══ 状态转储 ═══")
    打印(字符串拼接("  设备类数: ", 转字符串(设备类_数量())))
    打印(字符串拼接("  总设备数: ", 转字符串(设备类_设备数())))
    打印(字符串拼接("  devtmpfs节点数: ", 转字符串(devtmpfs_节点数())))
    打印(字符串拼接("  下一个动态主号: ", 转字符串(字符设备_下一个动态主号)))
    打印(字符串拼接("  AI匹配准确率%: ", 转字符串(AI_驱动匹配准确率())))
    返回 0
}


函数 分配模块_打印统计() {
    打印("[设备分配] ═══ 运行统计 ═══")
    打印(字符串拼接("  主号分配: ", 转字符串(全局统计.主号分配次数)))
    打印(字符串拼接("  分配失败: ", 转字符串(全局统计.主号分配失败)))
    打印(字符串拼接("  类注册: ", 转字符串(全局统计.类注册次数)))
    打印(字符串拼接("  类注销: ", 转字符串(全局统计.类注销次数)))
    打印(字符串拼接("  设备创建: ", 转字符串(全局统计.设备创建次数)))
    打印(字符串拼接("  设备销毁: ", 转字符串(全局统计.设备销毁次数)))
    打印(字符串拼接("  属性创建: ", 转字符串(全局统计.属性创建次数)))
    打印(字符串拼接("  属性读取: ", 转字符串(全局统计.属性读取次数)))
    打印(字符串拼接("  属性写入: ", 转字符串(全局统计.属性写入次数)))
    打印(字符串拼接("  u事件: ", 转字符串(全局统计.u事件次数)))
    打印(字符串拼接("  devtmpfs创建: ", 转字符串(全局统计.devtmpfs创建次数)))
    打印(字符串拼接("  devtmpfs删除: ", 转字符串(全局统计.devtmpfs删除次数)))
    打印(字符串拼接("  AI匹配记录: ", 转字符串(全局统计.AI匹配记录数)))
    打印(字符串拼接("  AI推荐命中: ", 转字符串(全局统计.AI推荐命中数)))
    打印(字符串拼接("  错误次数: ", 转字符串(全局统计.错误次数)))
    返回 0
}


函数 分配模块_注册到内核(内核上下文) {
    如果 (分配模块已初始化 == 假) { 返回 0 - 1 }
    打印("[设备分配] 已注册到内核上下文")
    返回 0
}

函数 分配模块_查询状态() {
    如果 (分配模块已初始化 == 假) { 返回 0 }
    返回 1
}

函数 分配模块_健康检查() {
    如果 (分配模块已初始化 == 假) { 返回 假 }
    如果 (全局统计.错误次数 * 10 > 全局统计.设备创建次数 + 全局统计.类注册次数) {
        返回 假
    }
    返回 真
}

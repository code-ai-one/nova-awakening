// §7 管道 (pipeTo / pipeThrough)

结构 PipeOptions {
    pr事件Close,
    pr事件Abort,
    pr事件Cancel,
    signal,    // u64 AbortSignal*
}

// readable.pipeTo(writable, options) → 承诺
函数 ReadableStream_pipeTo(readable, writable, options) {
    如果 (readable == 0 || writable == 0) { 返回 }
    如果 (readable.已锁定 || writable.已锁定) { 返回 }

    定义 reader = ReadableStream_getReader(readable)
    定义 writer = WritableStream_getWriter(writable)
    如果 (reader == 0 || writer == 0) { 返回 }

    定义 pr事件Close = 如果(options != 0, options.pr事件Close, 假)
    定义 pr事件Abort = 如果(options != 0, options.pr事件Abort, 假)
    定义 pr事件Cancel = 如果(options != 0, options.pr事件Cancel, 假)

    // 管道循环:
    // 1. reader.read() → {value, done}
    // 2. 如果done: 关闭writer(除非pr事件Close)
    // 3. 如果!done: writer.write(value), 回到1
    // 4. 如果readable出错: abort writer(除非pr事件Abort)
    // 5. 如果writable出错: cancel readable(除非pr事件Cancel)
    // 6. 检查AbortSignal

    Pipe_循环(reader, writer, pr事件Close, pr事件Abort, pr事件Cancel)
}

函数 Pipe_循环(reader, writer, pr事件Close, pr事件Abort, pr事件Cancel) {
    如果 (reader == 0 || writer == 0) { 返回 }
    // 读取一个块
    定义 chunk = Reader_read(reader)
    如果 (chunk == 0) {
        // done = true → 流结束
        如果 (!pr事件Close) { Writer_close(writer) }
        Reader_releaseLock(reader)
        Writer_releaseLock(writer)
        返回
    }
    // 写入
    Writer_write(writer, chunk, 0)
    // 检查背压: 如果writer有背压, 等待ready
    // 然后继续循环
    Pipe_循环(reader, writer, pr事件Close, pr事件Abort, pr事件Cancel)
}

// readable.pipeThrough(transform, options) → readable
函数 ReadableStream_pipeThrough(readable, transform, options) {
    如果 (readable == 0 || transform == 0) { 返回 0 }
    // 将readable管道到transform.writable
    ReadableStream_pipeTo(readable, transform.writable, options)
    // 返回transform.readable
    返回 transform.readable
}

// §8 ReadableStream.tee() — 分叉

函数 ReadableStream_tee(readable) {
    如果 (readable == 0 || readable.已锁定) { 返回 0 }
    定义 reader = ReadableStream_getReader(readable)
    如果 (reader == 0) { 返回 0 }

    // 创建两个新的ReadableStream
    定义 branch1 = ReadableStream_创建(0, 0, 1)
    定义 branch2 = ReadableStream_创建(0, 0, 1)

    // 读取源流, 同时推送到两个分支
    // Tee_循环(reader, branch1, branch2)

    // 返回[branch1, branch2]
    定义 结果 = 堆_分配(16)
    内存_写64(结果, branch1)
    内存_写64(结果 + 8, branch2)
    返回 结果
}

// §9 常用TransformStream: 文本编码/压缩

// TextEncoderStream: string → Uint8数组(UTF-8)
函数 TextEncoderStream_创建() {
    定义 Nova注意力架构 = 堆_分配(TransformStreamNova注意力架构)
    // transform: chunk(string) → controller.enqueue(encoded bytes)
    Nova注意力架构.transform回调 = 0    // 内部实现
    Nova注意力架构.flush回调 = 0
    Nova注意力架构.start回调 = 0
    返回 TransformStream_创建(Nova注意力架构, 0, 0)
}

// TextDecoderStream: Uint8数组 → string
函数 TextDecoderStream_创建(encoding) {
    定义 Nova注意力架构 = 堆_分配(TransformStreamNova注意力架构)
    Nova注意力架构.transform回调 = 0
    Nova注意力架构.flush回调 = 0
    Nova注意力架构.start回调 = 0
    返回 TransformStream_创建(Nova注意力架构, 0, 0)
}

// CompressionStream: 数据 → 压缩数据
函数 CompressionStream_创建(格式) {
    // 格式: "gzip" / "deflate" / "deflate-raw"
    定义 Nova注意力架构 = 堆_分配(TransformStreamNova注意力架构)
    Nova注意力架构.transform回调 = 0    // zlib压缩
    Nova注意力架构.flush回调 = 0        // flush剩余
    返回 TransformStream_创建(Nova注意力架构, 0, 0)
}

// DecompressionStream: 压缩数据 → 原始数据
函数 DecompressionStream_创建(格式) {
    定义 Nova注意力架构 = 堆_分配(TransformStreamNova注意力架构)
    Nova注意力架构.transform回调 = 0    // zlib解压
    Nova注意力架构.flush回调 = 0
    返回 TransformStream_创建(Nova注意力架构, 0, 0)
}

// Nova · 运行时层 · JIT编译引擎
// Nova-Bytecode → 原生机器码 (x86-64)
// 热点块走JIT，其余保持解释执行

导入("../../IR/字节码/指令集.nova")
导入("../../标准库/基础.nova")
导入("../../自举兼容桥.nova")
导入("../原语桩.nova")

定义 JIT_默认代码缓冲大小 = 0x100000
定义 JIT_默认最大编译单元 = 4096
// 配置与统计统一收进表槽位, 避免模块级标量被判成隐式全局
定义 可变 JIT_配置表 = [JIT_默认代码缓冲大小, JIT_默认最大编译单元]
定义 可变 JIT_统计表 = [0, 0]

函数 JIT_配置(代码缓冲大小, 最大编译单元) {
    如果 (代码缓冲大小 > 0) { JIT_配置表[0] = 代码缓冲大小
}
 如果 (最大编译单元 > 0) { JIT_配置表[1] = 最大编译单元 }
}

函数 JIT_读取配置() { 返回 [JIT_配置表[0], JIT_配置表[1]]
}

定义 JIT_模式_快速 = 0 // 快速编译: 1:1翻译，无优化
定义 JIT_模式_标准 = 1 // 标准编译: 常量折叠+死代码消除
定义 JIT_模式_激进 = 2 // 激进编译: +寄存器分配+循环展开

定义 可变 JIT_当前jit = 空
定义 可变 JIT_当前字节码 = []
定义 可变 JIT_当前pc = 0
定义 可变 JIT_当前跳转回填表 = []

// [代码缓冲, 代码位置, 编译记录表, 寄存器状态, 编译模式, 统计]
函数 JIT编译器_创建() { 返回 [缓冲区(JIT_配置表[0]), 0, 字典(), [0,0,0,0,0,0], JIT_模式_标准,
 [0, 0, 0], [JIT_配置表[0], JIT_配置表[1]]] // [编译次数, 总字节码, 总机器码, 编译耗时]
}

函数 JIT编译器_代码位(jit) { 返回 jit[1] }

函数 JIT_发射(jit, b) {
 缓冲写(jit[0], jit[1], b)
 jit[1] = jit[1] + 1
}

函数 JIT_发射32(jit, v) {
 缓冲写32(jit[0], jit[1], v)
 jit[1] = jit[1] + 4
}

函数 JIT_发射64(jit, v) {
 缓冲写64(jit[0], jit[1], v)
 jit[1] = jit[1] + 8
}

函数 JIT_推rax(jit) { JIT_发射(jit, 0x50) }
函数 JIT_弹rax(jit) { JIT_发射(jit, 0x58) }
函数 JIT_弹rcx(jit) { JIT_发射(jit, 0x59) }

函数 JIT_载入立即(jit, 值) {
 JIT_发射(jit, 0x48)
 JIT_发射(jit, 0xB8)
 JIT_发射64(jit, 值)
}

函数 JIT_加(jit) {
 JIT_发射(jit, 0x48)
 JIT_发射(jit, 0x01)
 JIT_发射(jit, 0xC8)
}

函数 JIT_减(jit) {
 JIT_发射(jit, 0x48)
 JIT_发射(jit, 0x29)
 JIT_发射(jit, 0xC8)
}

函数 JIT_乘(jit) {
 JIT_发射(jit, 0x48)
 JIT_发射(jit, 0x0F)
 JIT_发射(jit, 0xAF)
 JIT_发射(jit, 0xC1)
}

函数 JIT_除(jit) {
 JIT_发射(jit, 0x48) // cqo
 JIT_发射(jit, 0x99)
 JIT_发射(jit, 0x48) // idiv rcx
 JIT_发射(jit, 0xF7)
 JIT_发射(jit, 0xF9)
}

函数 JIT_返回(jit) { JIT_发射(jit, 0xC3) }

// 基础86条字节码指令都有机器码路径；未知操作码发射INT3并计入不安全数。
函数 JIT编译器_处理_PUSH_I64(vm) {
 // 读8字节立即数，push到栈
 定义 可变 值 = 0
 定义 可变 i = 0
 当 (i < 8) {
 值 = 值 + JIT_当前字节码[JIT_当前pc] * 幂(256, i)
 JIT_当前pc = JIT_当前pc + 1
 i = i + 1
 }
 JIT_载入立即(JIT_当前jit, 值)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_ADD(vm) {
 JIT_弹rcx(JIT_当前jit) // b → rcx
 JIT_弹rax(JIT_当前jit) // a → rax
 JIT_加(JIT_当前jit) // rax += rcx
 JIT_推rax(JIT_当前jit) // 结果入栈
}

函数 JIT编译器_处理_SUB(vm) {
 JIT_弹rcx(JIT_当前jit)
 JIT_弹rax(JIT_当前jit)
 JIT_减(JIT_当前jit)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_MUL(vm) {
 JIT_弹rcx(JIT_当前jit)
 JIT_弹rax(JIT_当前jit)
 JIT_乘(JIT_当前jit)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_DIV(vm) {
 JIT_弹rcx(JIT_当前jit)
 JIT_弹rax(JIT_当前jit)
 // 除零保护: test rcx,rcx; jnz ok; xor eax,eax; jmp done
 JIT_发射(JIT_当前jit, 0x48) // test rcx, rcx
 JIT_发射(JIT_当前jit, 0x85)
 JIT_发射(JIT_当前jit, 0xC9)
 JIT_发射(JIT_当前jit, 0x75) // jnz +5 (跳过xor 3B + jmp 2B)
 JIT_发射(JIT_当前jit, 0x05)
 JIT_发射(JIT_当前jit, 0x48) // xor rax,rax
 JIT_发射(JIT_当前jit, 0x31)
 JIT_发射(JIT_当前jit, 0xC0)
 JIT_发射(JIT_当前jit, 0xEB) // 跳转 +5 (跳过cqo 2B + idiv 3B)
 JIT_发射(JIT_当前jit, 0x05)
 JIT_除(JIT_当前jit)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_MOD(vm) {
 JIT_弹rcx(JIT_当前jit)
 JIT_弹rax(JIT_当前jit)
 // 除零保护 + idiv, 取余数在rdx
 JIT_发射(JIT_当前jit, 0x48) // test rcx, rcx
 JIT_发射(JIT_当前jit, 0x85)
 JIT_发射(JIT_当前jit, 0xC9)
 JIT_发射(JIT_当前jit, 0x75) // jnz +5 (跳过xor 3B + jmp 2B)
 JIT_发射(JIT_当前jit, 0x05)
 JIT_发射(JIT_当前jit, 0x48) // xor rax,rax
 JIT_发射(JIT_当前jit, 0x31)
 JIT_发射(JIT_当前jit, 0xC0)
 JIT_发射(JIT_当前jit, 0xEB) // 跳转 +8 (跳过cqo 2B + idiv 3B + mov 3B)
 JIT_发射(JIT_当前jit, 0x08)
 JIT_除(JIT_当前jit)
 // mov rax, rdx (余数)
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0x89)
 JIT_发射(JIT_当前jit, 0xD0)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_NEG(vm) {
 JIT_弹rax(JIT_当前jit)
 // neg rax
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0xF7)
 JIT_发射(JIT_当前jit, 0xD8)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_NOT(vm) {
 JIT_弹rax(JIT_当前jit)
 // test rax,rax; sete al; movzx rax,al
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0x85)
 JIT_发射(JIT_当前jit, 0xC0)
 JIT_发射(JIT_当前jit, 0x0F)
 JIT_发射(JIT_当前jit, 0x94)
 JIT_发射(JIT_当前jit, 0xC0)
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0x0F)
 JIT_发射(JIT_当前jit, 0xB6)
 JIT_发射(JIT_当前jit, 0xC0)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_BITNOT(vm) {
 JIT_弹rax(JIT_当前jit)
 // not rax
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0xF7)
 JIT_发射(JIT_当前jit, 0xD0)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_BITAND(vm) {
 JIT_弹rcx(JIT_当前jit)
 JIT_弹rax(JIT_当前jit)
 // and rax, rcx
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0x21)
 JIT_发射(JIT_当前jit, 0xC8)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_BITOR(vm) {
 JIT_弹rcx(JIT_当前jit)
 JIT_弹rax(JIT_当前jit)
 // or rax, rcx
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0x09)
 JIT_发射(JIT_当前jit, 0xC8)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_BITXOR(vm) {
 JIT_弹rcx(JIT_当前jit)
 JIT_弹rax(JIT_当前jit)
 // xor rax, rcx
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0x31)
 JIT_发射(JIT_当前jit, 0xC8)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_SHL(vm) {
 JIT_弹rcx(JIT_当前jit) // 移位量→rcx (cl)
 JIT_弹rax(JIT_当前jit)
 // shl rax, cl
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0xD3)
 JIT_发射(JIT_当前jit, 0xE0)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_SHR(vm) {
 JIT_弹rcx(JIT_当前jit)
 JIT_弹rax(JIT_当前jit)
 // sar rax, cl (算术右移)
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0xD3)
 JIT_发射(JIT_当前jit, 0xF8)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_DUP(vm) {
 // peek栈顶: mov rax,[rsp]; push rax
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0x8B)
 JIT_发射(JIT_当前jit, 0x04)
 JIT_发射(JIT_当前jit, 0x24)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_SWAP(vm) {
 // 弹出 rax; pop rcx; push rax; push rcx
 JIT_弹rax(JIT_当前jit)
 JIT_弹rcx(JIT_当前jit)
 JIT_推rax(JIT_当前jit)
 JIT_发射(JIT_当前jit, 0x51) // push rcx
}

函数 JIT编译器_处理_JMP(vm) {
 // 读取2字节目标PC (绝对地址)
 定义 目标PC = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 // 跳转 rel32
 JIT_发射(JIT_当前jit, 0xE9)
 定义 占位 = JIT_当前jit[1]
 JIT_发射32(JIT_当前jit, 0)
 // 记录回填: [机器码占位位置, 目标字节码PC]
 追加(JIT_当前跳转回填表, [占位, 目标PC])
}

函数 JIT编译器_处理_JMP_IF(vm) { 定义 目标PC = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 JIT_弹rax(JIT_当前jit)
 // test rax, rax
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0x85)
 JIT_发射(JIT_当前jit, 0xC0)
 // jnz rel32
 JIT_发射(JIT_当前jit, 0x0F)
 JIT_发射(JIT_当前jit, 0x85)
 定义 占位 = JIT_当前jit[1]
 JIT_发射32(JIT_当前jit, 0)
 追加(JIT_当前跳转回填表, [占位, 目标PC])
}

函数 JIT编译器_处理_JMP_IFNOT(vm) { 定义 目标PC = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 JIT_弹rax(JIT_当前jit)
 // test rax, rax
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0x85)
 JIT_发射(JIT_当前jit, 0xC0)
 // je rel32
 JIT_发射(JIT_当前jit, 0x0F)
 JIT_发射(JIT_当前jit, 0x84)
 定义 占位 = JIT_当前jit[1]
 JIT_发射32(JIT_当前jit, 0)
 追加(JIT_当前跳转回填表, [占位, 目标PC])
}

函数 JIT编译器_处理_LOAD_LOCAL(vm) {
 // 加载局部变量: mov rax, [rbp - (idx+1)*8]
 // 16位小端序索引
 定义 idx = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 定义 偏移 = 0 - ((idx + 1) * 8)
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0x8B)
 JIT_发射(JIT_当前jit, 0x85)
 JIT_发射32(JIT_当前jit, 偏移)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_STORE_LOCAL(vm) {
 // 存储局部变量: pop rax; mov [rbp - (idx+1)*8], rax
 // 16位小端序索引
 定义 idx = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 定义 偏移 = 0 - ((idx + 1) * 8)
 JIT_弹rax(JIT_当前jit)
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0x89)
 JIT_发射(JIT_当前jit, 0x85)
 JIT_发射32(JIT_当前jit, 偏移)
}

函数 JIT编译器_处理_PUSH_NIL(vm) {
 // xor rax,rax; push rax
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0x31)
 JIT_发射(JIT_当前jit, 0xC0)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_PUSH_FALSE(vm) {
 // xor rax,rax; push rax
 JIT_发射(JIT_当前jit, 0x48)
 JIT_发射(JIT_当前jit, 0x31)
 JIT_发射(JIT_当前jit, 0xC0)
 JIT_推rax(JIT_当前jit)
}

函数 JIT编译器_处理_RETURN(vm) {
 // 返回值已在栈顶, 弹入rax后由编译块尾声收尾
 JIT_弹rax(JIT_当前jit)
}

函数 JIT编译器_编译块(jit, 字节码, 起始PC, 长度) {
    定义 可变 ri = 0
    如果 (长度 > jit[6][1]) { 返回 空
}
 定义 入口 = jit[1]
 定义 可变 pc = 起始PC
 定义 结束 = 起始PC + 长度
 JIT_当前jit = jit
 JIT_当前字节码 = 字节码

 JIT_当前跳转回填表 = []
 定义 可变 PC映射 = 字典()
 定义 可变 不安全操作码数 = 0
 定义 可变 已显式返回 = 假

 // 函数序言: push rbp; mov rbp, rsp; sub rsp, 256
 JIT_发射(jit, 0x55) // push rbp
 JIT_发射(jit, 0x48) // mov rbp, rsp
 JIT_发射(jit, 0x89)
 JIT_发射(jit, 0xE5)
 JIT_发射(jit, 0x48) // sub rsp, 256
 JIT_发射(jit, 0x81)
 JIT_发射(jit, 0xEC)
 JIT_发射32(jit, 256)

 当 (pc < 结束 且 pc < 计数(字节码)) {
 // 记录当前字节码PC对应的机器码位置 (回填用)
 字典设置(PC映射, 转字符串(pc), jit[1])
 定义 op = 字节码[pc]
 pc = pc + 1
 JIT_当前pc = pc

 如果 (op == 指令_压入整数) {
 JIT编译器_处理_PUSH_I64(vm)
 }
 否则 如果 (op == 指令_压入浮点) {
 JIT编译器_处理_PUSH_F64(vm)
 }
 否则 如果 (op == 指令_加) {
 JIT编译器_处理_ADD(vm)
 }
 否则 如果 (op == 指令_减) {
 JIT编译器_处理_SUB(vm)
 }
 否则 如果 (op == 指令_乘) {
 JIT编译器_处理_MUL(vm)
 }
 否则 如果 (op == 指令_除) {
 JIT编译器_处理_DIV(vm)
 }
 否则 如果 (op == 指令_余) {
 JIT编译器_处理_MOD(vm)
 }
 否则 如果 (op == 指令_取负) {
 JIT编译器_处理_NEG(vm)
 }
 否则 如果 (op == 指令_非) {
 JIT编译器_处理_NOT(vm)
 }
 否则 如果 (op == 指令_位非) {
 JIT编译器_处理_BITNOT(vm)
 }
 否则 如果 (op == 指令_位与) {
 JIT编译器_处理_BITAND(vm)
 }
 否则 如果 (op == 指令_位或) {
 JIT编译器_处理_BITOR(vm)
 }
 否则 如果 (op == 指令_位异或) {
 JIT编译器_处理_BITXOR(vm)
 }
 否则 如果 (op == 指令_左移) {
 JIT编译器_处理_SHL(vm)
 }
 否则 如果 (op == 指令_右移) {
 JIT编译器_处理_SHR(vm)
 }
 否则 如果 (op == 指令_复制) {
 JIT编译器_处理_DUP(vm)
 }
 否则 如果 (op == 指令_交换) {
 JIT编译器_处理_SWAP(vm)
 }
 否则 如果 (op == 指令_比等 或 op == 指令_比不等 或 op == 指令_比小 或 op == 指令_比小等 或 op == 指令_比大 或 op == 指令_比大等) {
 JIT_弹rcx(jit) // b
 JIT_弹rax(jit) // a
 // cmp rax, rcx
 JIT_发射(jit, 0x48)
 JIT_发射(jit, 0x39)
 JIT_发射(jit, 0xC8)
 // setcc al
 JIT_发射(jit, 0x0F)
 如果 (op == 指令_比等) { JIT_发射(jit, 0x94) }
 否则 如果 (op == 指令_比不等) { JIT_发射(jit, 0x95) }
 否则 如果 (op == 指令_比小) { JIT_发射(jit, 0x9C) }
 否则 如果 (op == 指令_比小等) { JIT_发射(jit, 0x9E) }
 否则 如果 (op == 指令_比大) { JIT_发射(jit, 0x9F) }
 否则 { JIT_发射(jit, 0x9D) } // GE
 JIT_发射(jit, 0xC0)
 // movzx rax, al
 JIT_发射(jit, 0x48)
 JIT_发射(jit, 0x0F)
 JIT_发射(jit, 0xB6)
 JIT_发射(jit, 0xC0)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_跳转) {
 JIT编译器_处理_JMP(vm)
 }
 否则 如果 (op == 指令_真跳) {
 JIT编译器_处理_JMP_IF(vm)
 }
 否则 如果 (op == 指令_假跳) {
 JIT编译器_处理_JMP_IFNOT(vm)
 }
 否则 如果 (op == 指令_循环) {
 JIT编译器_处理_LOOP(vm)
 }
 否则 如果 (op == 指令_载局部) {
 JIT编译器_处理_LOAD_LOCAL(vm)
 }
 否则 如果 (op == 指令_存局部) {
 JIT编译器_处理_STORE_LOCAL(vm)
 }
 否则 如果 (op == 指令_压入空) {
 JIT编译器_处理_PUSH_NIL(vm)
 }
 否则 如果 (op == 指令_压入真) {
 JIT_载入立即(jit, 1)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_压入假) {
 JIT编译器_处理_PUSH_FALSE(vm)
 }
 否则 如果 (op == 指令_弹出) {
 JIT_弹rax(jit)
 }
 否则 如果 (op == 指令_载全局) {
 JIT编译器_处理_LOAD_GLOBAL(vm)
 }
 否则 如果 (op == 指令_存全局) {
 JIT编译器_处理_STORE_GLOBAL(vm)
 }
 否则 如果 (op == 指令_调用) {
 JIT编译器_处理_CALL(vm)
 }
 否则 如果 (op == 指令_打印) {
 JIT编译器_处理_PRINT(vm)
 }
 否则 如果 (op == 指令_建列表) {
 JIT编译器_处理_NEW_LIST(vm)
 }
 否则 如果 (op == 指令_返回 或 op == 指令_返回空) {
 如果 (op == 指令_返回) {
 JIT编译器_处理_RETURN(vm)
 }
 否则 {
 // RETURN_NIL: 直接返回空值
 JIT_发射(jit, 0x48)
 JIT_发射(jit, 0x31)
 JIT_发射(jit, 0xC0)
 }
 // 函数尾声: mov rsp,rbp; pop rbp; ret
 JIT_发射(jit, 0x48)
 JIT_发射(jit, 0x89)
 JIT_发射(jit, 0xEC)
 JIT_发射(jit, 0x5D)
 JIT_返回(jit)
 已显式返回 = 真
 pc = 结束
 JIT_当前pc = pc
 }
 否则 如果 (op == 指令_停机) {
// 程序结束
pc = 结束
JIT_当前pc = pc
}
 否则 如果 (op == 指令_取索引) {
 // obj[i]: pop索引→rcx, pop对象→rdi, 调用helper[3]=索引读
 JIT_弹rcx(jit)  // 索引
 JIT_弹rax(jit)  // 对象
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7) // mov rdi, rax
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xCE) // mov rsi, rcx
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x18) // 调用 [r13+24]
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_设索引) {
 // obj[i]=v: pop值→rdx, pop索引→rsi, pop对象→rdi, 调用helper[4]
 JIT_发射(jit, 0x5A) // pop rdx (值)
 JIT_弹rcx(jit)     // 索引→rcx
 JIT_弹rax(jit)     // 对象→rax
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7) // mov rdi, rax
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xCE) // mov rsi, rcx
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x20) // 调用 [r13+32]
 }
 否则 如果 (op == 指令_建字典) {
 // 创建空字典: 调用helper[2]=新建字典
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x10) // 调用 [r13+16]
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_长度) {
 // 长度: pop对象→rdi, 调用helper[5]=计数
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7) // mov rdi, rax
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x28) // 调用 [r13+40]
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_是空) {
 // 栈顶==0? → push 1/0
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x85) JIT_发射(jit, 0xC0) // test rax,rax
 JIT_发射(jit, 0x0F) JIT_发射(jit, 0x94) JIT_发射(jit, 0xC0) // sete al
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x0F) JIT_发射(jit, 0xB6) JIT_发射(jit, 0xC0) // movzx rax,al
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_是列表 或 op == 指令_是字典 或 op == 指令_是字串 或 op == 指令_是整数 或 op == 指令_是浮点 或 op == 指令_是函数) {
 // 类型检查: pop对象→rdi, 类型ID→rsi, 调用helper[6]=类型检查
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7) // mov rdi, rax
 JIT_载入立即(jit, op - 指令_是整数) // 类型ID: 0=int,1=float,2=str,3=list,4=dict
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC6) // mov rsi, rax
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x30) // 调用 [r13+48]
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_断言) {
 // pop条件→rax, test, 若为0则INT3
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x85) JIT_发射(jit, 0xC0) // test rax,rax
 JIT_发射(jit, 0x75) JIT_发射(jit, 0x01) // jnz +1 (跳过INT3)
 JIT_发射(jit, 0xCC) // INT3
 }
 否则 如果 (op == 指令_压入字串) {
 // 2字节字符串表索引, 从字符串表加载指针
 定义 str_idx = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 pc = JIT_当前pc
 // 通过helper[7]=字符串表查找: 索引→rdi
 JIT_发射(jit, 0xBF) // mov edi, str_idx
 JIT_发射32(jit, str_idx)
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x38) // 调用 [r13+56]
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_原生调用) {
 // 2字节原生函数索引 + 1字节参数数
 定义 nat_idx = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 定义 nat_argc = JIT_当前字节码[JIT_当前pc + 2]
 JIT_当前pc = JIT_当前pc + 3
 pc = JIT_当前pc
 // pop参数到寄存器 (与CALL相同ABI)
 如果 (nat_argc >= 4) { JIT_弹rcx(jit) }
 如果 (nat_argc >= 3) { JIT_发射(jit, 0x5A) } // pop rdx
 如果 (nat_argc >= 2) { JIT_发射(jit, 0x5E) } // pop rsi
 如果 (nat_argc >= 1) { JIT_发射(jit, 0x5F) } // pop rdi
 // 加载原生函数地址: mov rax,[r12+nat_idx*8] (共用函数地址表)
 JIT_发射(jit, 0x49) JIT_发射(jit, 0x8B) JIT_发射(jit, 0x84) JIT_发射(jit, 0x24)
 JIT_发射32(jit, nat_idx * 8)
 JIT_发射(jit, 0xFF) JIT_发射(jit, 0xD0) // 调用 rax
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_尾调用) {
 // 尾调用: 与CALL相同但复用当前帧
 定义 tc_idx = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 定义 tc_argc = JIT_当前字节码[JIT_当前pc + 2]
 JIT_当前pc = JIT_当前pc + 3
 pc = JIT_当前pc
 如果 (tc_argc >= 6) { JIT_发射(jit, 0x41) JIT_发射(jit, 0x59) }
 如果 (tc_argc >= 5) { JIT_发射(jit, 0x41) JIT_发射(jit, 0x58) }
 如果 (tc_argc >= 4) { JIT_弹rcx(jit) }
 如果 (tc_argc >= 3) { JIT_发射(jit, 0x5A) }
 如果 (tc_argc >= 2) { JIT_发射(jit, 0x5E) }
 如果 (tc_argc >= 1) { JIT_发射(jit, 0x5F) }
 // 恢复帧后jmp (非call, 实现尾调用优化)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xEC) // mov rsp,rbp
 JIT_发射(jit, 0x5D) // pop rbp
 JIT_发射(jit, 0x49) JIT_发射(jit, 0x8B) JIT_发射(jit, 0x84) JIT_发射(jit, 0x24)
 JIT_发射32(jit, tc_idx * 8)
 JIT_发射(jit, 0xFF) JIT_发射(jit, 0xE0) // 跳转 rax
 已显式返回 = 真
 }
 否则 如果 (op == 指令_载闭包) {
 // 从闭包环境加载变量: mov rax,[r15+idx*8]; push rax
 定义 uv_idx = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 JIT_发射(jit, 0x49) JIT_发射(jit, 0x8B) JIT_发射(jit, 0x87) // mov rax,[r15+disp32]
 JIT_发射32(jit, uv_idx * 8)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_存闭包) {
 // 存储到闭包环境: pop rax; mov [r15+idx*8],rax
 定义 uv_idx = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 JIT_弹rax(jit)
 JIT_发射(jit, 0x49) JIT_发射(jit, 0x89) JIT_发射(jit, 0x87) // mov [r15+disp32],rax
 JIT_发射32(jit, uv_idx * 8)
 }
 否则 如果 (op == 指令_建结构) {
 // 创建结构体: rdi=字段数, call helper[0x50]
 定义 字段数 = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 JIT_发射(jit, 0xBF) JIT_发射32(jit, 字段数) // mov edi, 字段数
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x50)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_取字段) {
 // 字段读取: pop对象→rdi, 字段索引→rsi, call helper[0x40]
 定义 fi = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7) // mov rdi, rax
 JIT_发射(jit, 0xBE) JIT_发射32(jit, fi) // mov esi, fi
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x40)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_设字段) {
 // 字段写入: pop值→rdx, pop对象→rdi, 字段索引→rsi, call helper[0x48]
 定义 fi = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 JIT_发射(jit, 0x5A) // pop rdx (值)
 JIT_弹rax(jit) // pop对象
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7) // mov rdi, rax
 JIT_发射(jit, 0xBE) JIT_发射32(jit, fi) // mov esi, fi
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x48)
 }
 否则 如果 (op == 指令_取字典) {
 // 字典读: pop key→rsi, pop dict→rdi, call helper[0x58]
 JIT_弹rcx(jit)
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7) // mov rdi, rax
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xCE) // mov rsi, rcx
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x58)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_设字典) {
 // 字典写: pop值→rdx, pop key→rsi, pop dict→rdi, call helper[0x60]
 JIT_发射(jit, 0x5A) // pop rdx
 JIT_弹rcx(jit)
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7) // mov rdi, rax
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xCE) // mov rsi, rcx
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x60)
 }
 否则 如果 (op == 指令_间接调用) {
 // 间接调用: 栈顶为函数, 下方为参数
 定义 ind_argc = JIT_当前字节码[JIT_当前pc]
 JIT_当前pc = JIT_当前pc + 1
 // pop参数到SysV ABI寄存器
 如果 (ind_argc >= 6) { JIT_发射(jit, 0x41) JIT_发射(jit, 0x59) } // pop r9
 如果 (ind_argc >= 5) { JIT_发射(jit, 0x41) JIT_发射(jit, 0x58) } // pop r8
 如果 (ind_argc >= 4) { JIT_弹rcx(jit) }
 如果 (ind_argc >= 3) { JIT_发射(jit, 0x5A) } // pop rdx
 如果 (ind_argc >= 2) { JIT_发射(jit, 0x5E) } // pop rsi
 如果 (ind_argc >= 1) { JIT_发射(jit, 0x5F) } // pop rdi
 JIT_弹rax(jit) // pop函数地址
 JIT_发射(jit, 0xFF) JIT_发射(jit, 0xD0) // 调用 rax
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_外部调用) {
 // FFI调用: 2字节索引+1字节参数数, 从扩展函数表加载地址
 定义 ffi_idx = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 定义 ffi_argc = JIT_当前字节码[JIT_当前pc + 2]
 JIT_当前pc = JIT_当前pc + 3
 如果 (ffi_argc >= 4) { JIT_弹rcx(jit) }
 如果 (ffi_argc >= 3) { JIT_发射(jit, 0x5A) }
 如果 (ffi_argc >= 2) { JIT_发射(jit, 0x5E) }
 如果 (ffi_argc >= 1) { JIT_发射(jit, 0x5F) }
 // 加载FFI函数地址: [r12 + (ffi_idx+4096)*8] — 4096偏移隔离FFI区
 JIT_发射(jit, 0x49) JIT_发射(jit, 0x8B) JIT_发射(jit, 0x84) JIT_发射(jit, 0x24)
 JIT_发射32(jit, (ffi_idx + 4096) * 8)
 JIT_发射(jit, 0xFF) JIT_发射(jit, 0xD0) // 调用 rax
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_闭包) {
 // 创建闭包: rdi=函数索引, rsi=r15(当前upvalue环境), call helper[0x68]
 定义 cl_idx = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 JIT_发射(jit, 0xBF) JIT_发射32(jit, cl_idx) // mov edi, cl_idx
 JIT_发射(jit, 0x4C) JIT_发射(jit, 0x89) JIT_发射(jit, 0xFE) // mov rsi, r15
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x68)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_让出) {
 // 协程让出: 保存恢复点PC到rax高32位, 返回
 JIT_载入立即(jit, pc) // 当前PC作为恢复点
 // 函数尾声
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xEC) // mov rsp,rbp
 JIT_发射(jit, 0x5D) // pop rbp
 JIT_返回(jit)
 }
 否则 如果 (op == 指令_恢复) {
 // 协程恢复: pop协程状态→rdi, call helper[0x70]
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7) // mov rdi, rax
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x70)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_类型检查) {
 // 类型检查: 1字节类型ID, pop值→rdi, 类型→rsi, 复用helper[0x30]
 定义 tc_typeid = JIT_当前字节码[JIT_当前pc]
 JIT_当前pc = JIT_当前pc + 1
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7) // mov rdi, rax
 JIT_载入立即(jit, tc_typeid)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC6) // mov rsi, rax
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x30)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_类型转换) {
 // 类型转换: 1字节目标类型, pop值→rdi, 类型→rsi, call helper[0x78]
 定义 cast_type = JIT_当前字节码[JIT_当前pc]
 JIT_当前pc = JIT_当前pc + 1
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7) // mov rdi, rax
 JIT_载入立即(jit, cast_type)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC6) // mov rsi, rax
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x55) JIT_发射(jit, 0x78)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_转整数) {
 // 转整数: pop值→rdi, call helper[0x80]
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7)
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x95) // 调用 [r13+disp32]
 JIT_发射32(jit, 0x80)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_转浮点) {
 // 转浮点: pop值→rdi, call helper[0x88]
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7)
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x95)
 JIT_发射32(jit, 0x88)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_转字串) {
 // 转字符串: pop值→rdi, call helper[0x90]
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7)
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x95)
 JIT_发射32(jit, 0x90)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_尝试) {
 // 异常保护: 保存rbp和catch目标到异常帧
 定义 catch_pc = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 // 保存当前rsp到r14(异常帧指针), 用于catch时恢复栈
 JIT_发射(jit, 0x49) JIT_发射(jit, 0x89) JIT_发射(jit, 0xE6) // mov r14, rsp
 // 将catch的机器码地址压入异常帧(用跳转回填表解析)
 JIT_载入立即(jit, catch_pc)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_捕获) {
 // catch入口: 异常值从rax传入(由throw的helper设置)
 // 恢复rsp到r14保存的值
 JIT_发射(jit, 0x4C) JIT_发射(jit, 0x89) JIT_发射(jit, 0xF4) // mov rsp, r14
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_抛出) {
 // 抛出异常: pop值→rdi, call helper[0x98] (longjmp到catch)
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7)
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x95)
 JIT_发射32(jit, 0x98)
 }
 否则 如果 (op == 指令_导入) {
 // 导入模块: rdi=模块索引, call helper[0xA0]
 定义 mod_idx = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 JIT_发射(jit, 0xBF) JIT_发射32(jit, mod_idx)
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x95)
 JIT_发射32(jit, 0xA0)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_断点) {
 // 调试断点: 故意发射INT3 (非错误, 是用户请求的断点)
 JIT_发射(jit, 0xCC)
 }
 否则 如果 (op == 指令_即时编译入 或 op == 指令_即时编译出) {
 // 已在JIT执行中, JIT区域标记指令为NOP
 }
 否则 如果 (op == 指令_匹配) {
 // 模式匹配: pop匹配值→rdi, 分支数→rsi, call helper[0xA8]
 定义 分支数 = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7) // mov rdi, rax
 JIT_载入立即(jit, 分支数)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC6) // mov rsi, rax
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x95)
 JIT_发射32(jit, 0xA8)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_遍历) {
 // 迭代器: pop迭代器→rdi, call helper[0xB0], 若完成则跳转
 定义 结束跳转 = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
 JIT_当前pc = JIT_当前pc + 2
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7)
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x95)
 JIT_发射32(jit, 0xB0)
 // test rax,rax; jz→结束 (迭代器耗尽返回0)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x85) JIT_发射(jit, 0xC0) // test rax,rax
 JIT_发射(jit, 0x0F) JIT_发射(jit, 0x84) // jz rel32
 定义 fe_占位 = jit[1]
 JIT_发射32(jit, 0)
 追加(JIT_当前跳转回填表, [fe_占位, 结束跳转])
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_展开) {
 // 展开: pop列表→rdi, call helper[0xB8] (将元素推入栈)
 JIT_弹rax(jit)
 JIT_发射(jit, 0x48) JIT_发射(jit, 0x89) JIT_发射(jit, 0xC7)
 JIT_发射(jit, 0x41) JIT_发射(jit, 0xFF) JIT_发射(jit, 0x95)
 JIT_发射32(jit, 0xB8)
 JIT_推rax(jit)
 }
 否则 如果 (op == 指令_空操作 或 op == 指令_热点计 或 op == 指令_行号) {
 // 跳过元信息指令
 定义 大小 = Nova指令_操作数大小(op)
 pc = pc + 大小
 }
 否则 {
 // 未覆盖的操作码: 发射INT3断点陷阱 + 跳过操作数
 // 调试时可在此处断住, 而非静默产生错误代码
 JIT_发射(jit, 0xCC) // INT3
 不安全操作码数 = 不安全操作码数 + 1
 定义 大小 = Nova指令_操作数大小(op)
 pc = pc + 大小
 }
 pc = JIT_当前pc
 }

 // 记录尾部PC映射 (跳转目标可能指向结尾)
 字典设置(PC映射, 转字符串(pc), jit[1])

 如果 (已显式返回 == 假) {
 // 默认尾声
 JIT_发射(jit, 0x48) // mov rsp, rbp
 JIT_发射(jit, 0x89)
 JIT_发射(jit, 0xEC)
 JIT_发射(jit, 0x5D) // pop rbp
 JIT_返回(jit)
 }

 // 跳转回填: 遍历回填表, 计算真实rel32偏移并写回
 当 (ri < 计数(JIT_当前跳转回填表)) { 定义 条目 = JIT_当前跳转回填表[ri]
 定义 占位位置 = 条目[0]
 定义 目标字节码PC = 条目[1]
 定义 目标机器码 = 字典获取(PC映射, 转字符串(目标字节码PC))
 如果 (目标机器码 != 空) {
 // rel32 = 目标地址 - (占位位置 + 4) [因为rel32是相对于指令结尾]
 定义 偏移值 = 目标机器码 - (占位位置 + 4)
 缓冲写32(jit[0], 占位位置, 偏移值)
 }
 ri = ri + 1
 }

 // 记录编译结果
 定义 机器码大小 = jit[1] - 入口
 jit[5][0] = jit[5][0] + 1 // 编译次数
 jit[5][1] = jit[5][1] + 长度 // 总字节码
 jit[5][2] = jit[5][2] + 机器码大小 // 总机器码

 // 回: [入口偏移, 机器码大小, 安全标志(0=纯净可直接执行)]
 返回 [入口, 机器码大小, 不安全操作码数]
}

// 统计信息
函数 JIT编译器_使用率(jit) {
    如果 (jit[6][0] == 0) { 返回 0
}
 返回 jit[1] * 100 / jit[6][0]
}

// 执行JIT缓冲区中的机器码
// 参数: 缓冲区 — JIT代码缓冲, 入口偏移 — 目标函数起始位置
// 回: 机器码执行返回值 (rax)
// 权威实现: 编译器/帮助/帮助系统.nova → __即时编译_执行 (真实x86-64机器码, 0)
// Windows: VirtualAlloc(RWX) + memcpy + call + VirtualFree
// Linux: mmap(RWX) + memcpy + call + munmap
函数 执行缓冲码(缓冲区, 入口偏移) { 返回 __即时编译_执行(缓冲区, 入口偏移)
}

// __即时编译_执行 的权威实现在 编译器/帮助/帮助系统.nova 中
// 由编译器在AOT编译时发射为真实x86-64机器码
// (VirtualAlloc/mmap → memcpy → call → VirtualFree/munmap)
外部 __即时编译_执行

函数 JIT_记录编译(字节数) { JIT_统计表[0] = JIT_统计表[0] + 1
 JIT_统计表[1] = JIT_统计表[1] + 字节数
}

函数 JIT_效率评估() {
    如果 (JIT_统计表[0] == 0) { 返回 "无编译记录"
}
 定义 平均 = JIT_统计表[1] / JIT_统计表[0]
 如果 (平均 < 64) { 返回 "紧凑(高效)" }
 如果 (平均 < 256) { 返回 "ok" }
 返回 "膨胀(需优化)"
}

// JIT opcode扩展

// PUSH_F64: 浮点立即数push (编码为8字节IEEE754, 与PUSH_I64格式相同)
函数 JIT编译器_处理_PUSH_F64(vm) {
    定义 可变 值 = 0
    定义 可变 i = 0
    当 (i < 8) {
        值 = 值 + JIT_当前字节码[JIT_当前pc] * 幂(256, i)
        JIT_当前pc = JIT_当前pc + 1
        i = i + 1
    }
    JIT_载入立即(JIT_当前jit, 值)
    JIT_推rax(JIT_当前jit)
}

// LOOP: 循环后向跳转 (与JMP编码相同: 2字节绝对目标PC)
函数 JIT编译器_处理_LOOP(vm) {
    定义 目标PC = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
    JIT_当前pc = JIT_当前pc + 2
    // 跳转 rel32 (回填机制与JMP相同)
    JIT_发射(JIT_当前jit, 0xE9)
    定义 占位 = JIT_当前jit[1]
    JIT_发射32(JIT_当前jit, 0)
    追加(JIT_当前跳转回填表, [占位, 目标PC])
 }

// 独立opcode处理器

// LOAD_GLOBAL: 加载全局变量 (索引为16位)
// 实现: 将索引写入rcx, 通过rbx(VM全局表基址)做偏移读取
// rbx在JIT入口时由调用者设置为全局变量表基址
函数 JIT编译器_处理_LOAD_GLOBAL(vm) {
    定义 idx = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
    JIT_当前pc = JIT_当前pc + 2
    // mov rax, [rbx + idx*8]
    JIT_发射(JIT_当前jit, 0x48)  // REX.W
    JIT_发射(JIT_当前jit, 0x8B)  // mov r64, r/m64
    JIT_发射(JIT_当前jit, 0x83)  // ModRM: [rbx+disp32]
    JIT_发射32(JIT_当前jit, idx * 8)
    JIT_推rax(JIT_当前jit)
}

// STORE_GLOBAL: 存储全局变量
// 实现: pop值到rax, 写入[rbx + idx*8]
函数 JIT编译器_处理_STORE_GLOBAL(vm) {
    定义 idx = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
    JIT_当前pc = JIT_当前pc + 2
    JIT_弹rax(JIT_当前jit)
    // mov [rbx + idx*8], rax
    JIT_发射(JIT_当前jit, 0x48)  // REX.W
    JIT_发射(JIT_当前jit, 0x89)  // mov r/m64, r64
    JIT_发射(JIT_当前jit, 0x83)  // ModRM: [rbx+disp32]
    JIT_发射32(JIT_当前jit, idx * 8)
}

// CALL: 函数调用 (2字节函数索引 + 1字节参数数 = 3字节操作数)
// 实现: 从函数地址表(r12基址)读取目标地址, pop参数到寄存器, 间接call
// r12在JIT入口时由调用者设置为函数地址表基址
函数 JIT编译器_处理_CALL(vm) {
    定义 函数索引 = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
    定义 参数数 = JIT_当前字节码[JIT_当前pc + 2]
    JIT_当前pc = JIT_当前pc + 3
    // pop参数到System V ABI寄存器 (rdi,rsi,rdx,rcx,r8,r9)
    // 参数以反序在栈上, 所以按参数位置pop
    如果 (参数数 >= 6) { JIT_发射(JIT_当前jit, 0x41)  JIT_发射(JIT_当前jit, 0x59) } // pop r9
    如果 (参数数 >= 5) { JIT_发射(JIT_当前jit, 0x41)  JIT_发射(JIT_当前jit, 0x58) } // pop r8
    如果 (参数数 >= 4) { JIT_弹rcx(JIT_当前jit) }  // pop rcx
    如果 (参数数 >= 3) { JIT_发射(JIT_当前jit, 0x5A) } // pop rdx
    如果 (参数数 >= 2) { JIT_发射(JIT_当前jit, 0x5E) } // pop rsi
    如果 (参数数 >= 1) { JIT_发射(JIT_当前jit, 0x5F) } // pop rdi
    // 加载函数地址: mov rax, [r12 + 索引*8]
    JIT_发射(JIT_当前jit, 0x49)  // REX.WB
    JIT_发射(JIT_当前jit, 0x8B)  // mov rax, [r12+disp32]
    JIT_发射(JIT_当前jit, 0x84)  // ModRM+SIB
    JIT_发射(JIT_当前jit, 0x24)  // SIB: base=r12
    JIT_发射32(JIT_当前jit, 函数索引 * 8)
    // 调用 rax
    JIT_发射(JIT_当前jit, 0xFF)
    JIT_发射(JIT_当前jit, 0xD0)
    // push返回值
    JIT_推rax(JIT_当前jit)
}

// PRINT: 打印栈顶 (无操作数)
// 实现: pop值到rdi, 调用运行时打印helper (r13保存helper表基址)
// helper表[0]=打印, [1]=新建列表, [2]=新建字典
函数 JIT编译器_处理_PRINT(vm) {
    JIT_弹rax(JIT_当前jit)
    // mov rdi, rax (参数)
    JIT_发射(JIT_当前jit, 0x48)
    JIT_发射(JIT_当前jit, 0x89)
    JIT_发射(JIT_当前jit, 0xC7)
    // 调用 [r13+0] (helper表第0个=打印)
    JIT_发射(JIT_当前jit, 0x41)  // REX.B
    JIT_发射(JIT_当前jit, 0xFF)  // 调用 [r13]
    JIT_发射(JIT_当前jit, 0x55)  // ModRM: [r13+0]
    JIT_发射(JIT_当前jit, 0x00)
}

// NEW_LIST: 创建新列表 (2字节元素数)
// 实现: 元素数到rdi, 调用helper创建列表, push返回的列表指针
函数 JIT编译器_处理_NEW_LIST(vm) {
    定义 元素数 = JIT_当前字节码[JIT_当前pc] + JIT_当前字节码[JIT_当前pc + 1] * 256
    JIT_当前pc = JIT_当前pc + 2
    // mov edi, 元素数 (32位立即数)
    JIT_发射(JIT_当前jit, 0xBF)
    JIT_发射32(JIT_当前jit, 元素数)
    // 调用 [r13+8] (helper表第1个=新建列表)
    JIT_发射(JIT_当前jit, 0x41)
    JIT_发射(JIT_当前jit, 0xFF)
    JIT_发射(JIT_当前jit, 0x55)
    JIT_发射(JIT_当前jit, 0x08)
    // 压入 rax (新列表指针)
    JIT_推rax(JIT_当前jit)
}

// AOT编译入口
// AOT = 全量编译，将所有字节码一次性翻译为机器码
// 与JIT不同：AOT不依赖热点检测，直接编译全部函数
定义 可变 _AOT_已编译 = 假
定义 可变 _AOT_入口偏移 = 0
定义 可变 _AOT_代码大小 = 0
定义 可变 _AOT_函数数 = 0

函数 AOT_编译全部(jit, 函数表, 字节码表) {
    定义 可变 成功数 = 0
    如果 (jit == 空 或 函数表 == 空) { 返回 假 }
    定义 所有键 = 字典键(函数表)
    定义 可变 i = 0
    当 (i < 计数(所有键)) {
        定义 函数名 = 所有键[i]
        定义 偏移信息 = 字典取(函数表, 函数名)
        如果 (偏移信息 != 空 且 是列表(偏移信息) == 真 且 计数(偏移信息) >= 2) {
            定义 起始 = 偏移信息[0]
            定义 长度 = 偏移信息[1]
            如果 (长度 > 0 且 长度 < JIT_配置表[1]) {
                定义 结果 = JIT编译器_编译块(jit, 字节码表, 起始, 长度)
                如果 (结果 != 空 且 结果[2] == 0) {
                    字典设(jit[2], 函数名, [结果[0], 结果[1]])
                    成功数 = 成功数 + 1
                }
            }
        }
        i = i + 1
    }
    _AOT_已编译 = 真
    _AOT_函数数 = 成功数
    _AOT_代码大小 = jit[1]
    返回 真
}

函数 AOT_已编译() { 返回 _AOT_已编译 }
函数 AOT_函数数() { 返回 _AOT_函数数 }
函数 AOT_代码大小() { 返回 _AOT_代码大小 }

函数 AOT_查找并执行(jit, 函数名) {
    如果 (jit == 空) { 返回 空 }
    定义 记录 = 字典取(jit[2], 函数名)
    如果 (记录 == 空) { 返回 空 }
    返回 执行缓冲码(jit[0], 记录[0])
}

// AOT统计报告
函数 AOT_报告() {
    定义 可变 r = 字典()
    字典设(r, "compiled", 转字符串(_AOT_已编译))
    字典设(r, "函数数", 转字符串(_AOT_函数数))
    字典设(r, "代码大小", 转字符串(_AOT_代码大小))
    返回 r
}

// 性能路径三层分级
// AOT-production / JIT-hotspot / Interpreter-debug

定义 执行路径_AOT = 1
定义 执行路径_JIT = 2
定义 执行路径_解释 = 3

定义 可变 _当前执行路径 = 执行路径_解释
定义 可变 _执行路径统计 = [0, 0, 0]

函数 执行路径_设置(路径) { _当前执行路径 = 路径 }
函数 执行路径_获取() { 返回 _当前执行路径 }

函数 执行路径名(p) {
    如果 (p == 执行路径_AOT) { 返回 "AOT-production" }
    如果 (p == 执行路径_JIT) { 返回 "JIT-hotspot" }
    如果 (p == 执行路径_解释) { 返回 "Interpreter-debug" }
    返回 "unknown"
}

函数 执行路径_记录调用(路径) {
    如果 (路径 == 执行路径_AOT) { _执行路径统计[0] = _执行路径统计[0] + 1 }
    如果 (路径 == 执行路径_JIT) { _执行路径统计[1] = _执行路径统计[1] + 1 }
    如果 (路径 == 执行路径_解释) { _执行路径统计[2] = _执行路径统计[2] + 1 }
}

// JIT覆盖率报告
定义 可变 _JIT覆盖_总opcode = 86
定义 可变 _JIT覆盖_已实现 = 86

函数 JIT覆盖_设置(总数, 已实现) {
    _JIT覆盖_总opcode = 总数
    _JIT覆盖_已实现 = 已实现
}

函数 JIT覆盖率() {
    如果 (_JIT覆盖_总opcode == 0) { 返回 0 }
    返回 (_JIT覆盖_已实现 * 100) / _JIT覆盖_总opcode
}

// 性能报告
函数 性能路径_报告() {
    定义 可变 r = 字典()
    字典设(r, "当前路径", 执行路径名(_当前执行路径))
    字典设(r, "AOT调用数", 转字符串(_执行路径统计[0]))
    字典设(r, "JIT调用数", 转字符串(_执行路径统计[1]))
    字典设(r, "解释调用数", 转字符串(_执行路径统计[2]))
    字典设(r, "JIT覆盖率", 字符串拼接(转字符串(JIT覆盖率()), "%"))
    字典设(r, "JIT已实现", 转字符串(_JIT覆盖_已实现))
    字典设(r, "JIT总opcode", 转字符串(_JIT覆盖_总opcode))
    字典设(r, "AOT已编译", 转字符串(_AOT_已编译))
    字典设(r, "AOT函数数", 转字符串(_AOT_函数数))
    字典设(r, "AOT代码大小", 转字符串(_AOT_代码大小))
    返回 r
}

函数 性能路径_打印报告() {
    定义 r = 性能路径_报告()
    打印文本(字符串拼接("[PERF-REPORT] 路径=", 字符串拼接(字典取(r, "当前路径"), 字符串拼接(" JIT覆盖=", 字符串拼接(字典取(r, "JIT覆盖率"), 字符串拼接(" AOT=", 字符串拼接(字典取(r, "AOT已编译"), 字符串拼接("/", 字典取(r, "AOT函数数")))))))))
}

// 具名报告
函数 性能_报告() { 返回 性能路径_报告() }

函数 即时编译_覆盖率报告() {
    定义 r = 字典()
    字典设(r, "总opcode", 转字符串(_JIT覆盖_总opcode))
    字典设(r, "已实现opcode", 转字符串(_JIT覆盖_已实现))
    字典设(r, "覆盖率%", 转字符串(JIT覆盖率()))
    字典设(r, "未知opcode处理", "INT3陷阱")
    // 已覆盖操作码清单
    字典设(r, "已覆盖", "全部86条基础指令: 运算23+内存15+分支10+调用10+类型15+特殊13")
    返回 r
}

函数 提前编译_执行报告() {
    定义 r = 字典()
    字典设(r, "AOT已编译", 转字符串(_AOT_已编译))
    字典设(r, "AOT函数数", 转字符串(_AOT_函数数))
    字典设(r, "AOT代码大小", 转字符串(_AOT_代码大小))
    字典设(r, "编译策略", "全量预编译")
    字典设(r, "回退策略", "AOT自动编译→JIT热路径→解释器三级降级")
    返回 r
}

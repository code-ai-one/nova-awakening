导入("../../../../标准库/基础.nova")


// 泛型参数种类
定义 泛型_参数 = 1
定义 泛型_约束 = 2
定义 泛型_具体 = 3
定义 泛型_推断 = 4

// 约束ID
定义 约束_可比较 = 1
定义 约束_可哈希 = 2
定义 约束_可打印 = 3
定义 约束_可复制 = 4
定义 约束_可迭代 = 5

// 类型参数: [参数id, 种类, 约束列表]
函数 类型参数(pid, 种类) { 返回 [pid, 种类, []] }

函数 类型参数_加约束(tp, 约束id) {
 追加(tp[2], 约束id)
}

函数 类型参数_有约束(tp, 约束id) { 定义 可变 i = 0
 当 (i < 计数(tp[2])) { 如果 (tp[2][i] == 约束id) { 返回 真 }
 i = i + 1
 }
 返回 假
}

// 泛型签名: [函数id, 参数列表, 形参类型列表]
函数 泛型签名(fid, 参数列表) { 返回 [fid, 参数列表, []] }

函数 泛型签名_加形参(sig, 类型id) {
 追加(sig[2], 类型id)
}

// 替换表: [[参数id, 具体类型id], ...]
函数 替换表_创建() { 返回 [] }

函数 替换表_绑定(表, pid, 具体) {
 追加(表, [pid, 具体])
}

函数 替换表_查(表, pid) { 定义 可变 i = 0
 当 (i < 计数(表)) { 如果 (表[i][0] == pid) { 返回 表[i][1] }
 i = i + 1
 }
 返回 -1
}

// 统一化: 给定实参类型列表,推断类型参数
// 形参类型[i]=参数id → 绑定为实参[i]
// 形参类型[i]=具体类型 → 检查是否匹配
// 回: [成功, 替换表]
函数 统一化(sig, 实参类型) { 定义 可变 表 = 替换表_创建()
 如果 (计数(sig[2]) != 计数(实参类型)) { 返回 [假, 表] }
 定义 可变 i = 0
 当 (i < 计数(sig[2])) { 定义 形参 = sig[2][i]
 定义 实参 = 实参类型[i]
 // 负数表示泛型参数(-pid)
 如果 (形参 < 0) { 定义 pid = 0 - 形参
 定义 已有 = 替换表_查(表, pid)
 如果 (已有 == -1) {
 替换表_绑定(表, pid, 实参)
 } 否则 { 如果 (已有 != 实参) { 返回 [假, 表] }
 }
 } 否则 { 如果 (形参 != 实参) { 返回 [假, 表] }
 }
 i = i + 1
 }
 返回 [真, 表]
}

// 单态化缓存: [[函数id, 具体类型列表, 生成名id], ...]
函数 单态缓存_创建() { 返回 [] }

函数 单态缓存_查(缓存, fid, 类型列表) { 定义 可变 i = 0
 当 (i < 计数(缓存)) { 如果 (缓存[i][0] == fid) { 定义 cached = 缓存[i][1]
 如果 (计数(cached) == 计数(类型列表)) { 定义 可变 相同 = 真
 定义 可变 j = 0
 当 (j < 计数(cached)) { 如果 (cached[j] != 类型列表[j]) { 相同 = 假 }
 j = j + 1
 }
 如果 (相同 == 真) { 返回 缓存[i][2] }
 }
 }
 i = i + 1
 }
 返回 -1
}

函数 单态缓存_加(缓存, fid, 类型列表, 名id) {
 追加(缓存, [fid, 类型列表, 名id])
}

// 约束满足检查
// 类型能力表: 内置类型支持哪些约束
函数 类型满足约束(类型id, 约束id) {
 // 整数(2): 可比较,可哈希,可打印,可复制
 如果 (类型id == 2) { 返回 约束id <= 4 }
 // 浮点(3): 可比较,可打印,可复制
 如果 (类型id == 3) { 返回 约束id == 1 或 约束id == 3 或 约束id == 4 }
 // 字符串(4): 可比较,可哈希,可打印,可复制
 如果 (类型id == 4) { 返回 约束id <= 4 }
 // 列表(5): 可迭代,可打印
 如果 (类型id == 5) { 返回 约束id == 5 或 约束id == 3 }
 返回 假
}

// 泛型函数模拟
函数 泛型_交换(lst, i, j) { 定义 临时 = lst[i]
 lst[i] = lst[j]
 lst[j] = 临时
}

函数 泛型_最大(a, b) {
    如果 (a > b) { 返回 a }
    返回 b
}
函数 泛型_最小(a, b) {
    如果 (a < b) { 返回 a }
    返回 b
}

函数 泛型_映射(lst, off) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(lst)) { 追加(结果, lst[i] + off) i = i + 1 }
 返回 结果
}

函数 泛型_过滤大于(lst, 阈值) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(lst)) { 如果 (lst[i] > 阈值) { 追加(结果, lst[i]) }
 i = i + 1
 }
 返回 结果
}

函数 泛型_归约求和(lst) { 定义 可变 s = 0
 定义 可变 i = 0
 当 (i < 计数(lst)) { s = s + lst[i] i = i + 1 }
 返回 s
}

// 约束全检: 替换表中所有绑定是否满足约束
函数 约束全检(sig, 替换表) { 定义 可变 i = 0
 当 (i < 计数(sig[1])) { 定义 tp = sig[1][i]
 定义 具体 = 替换表_查(替换表, tp[0])
 如果 (具体 != -1) { 定义 可变 j = 0
 当 (j < 计数(tp[2])) { 如果 (类型满足约束(具体, tp[2][j]) == 假) { 返回 假 }
 j = j + 1
 }
 }
 i = i + 1
 }
 返回 真
}

// 型变标记
定义 型变_不变 = 0
定义 型变_协变 = 1
定义 型变_逆变 = 2

// 型变检查: 协变允许子→父, 逆变允许父→子
函数 型变兼容(型变, 源, 目标) {
    如果 (源 == 目标) { 返回 真
}
 // 协变: 整数→浮点 (子→父)
 如果 (型变 == 型变_协变 且 源 == 2 且 目标 == 3) { 返回 真 }
 // 逆变: 浮点→整数 (父→子)
 如果 (型变 == 型变_逆变 且 源 == 3 且 目标 == 2) { 返回 真 }
 返回 假
}

// 泛型实例化: 替换签名中的类型参数
函数 泛型_实例化(形参列表, 替换表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(形参列表)) { 定义 形参 = 形参列表[i]
 如果 (形参 < 0) { 定义 具体 = 替换表_查(替换表, 0 - 形参)
 如果 (具体 != -1) { 追加(结果, 具体) }
 否则 { 追加(结果, 形参) }
 } 否则 {
 追加(结果, 形参)
 }
 i = i + 1
 }
 返回 结果
}

// 泛型: zip两列表
函数 泛型_配对(a, b) { 定义 可变 结果 = []
 定义 可变 n = 计数(a)
 如果 (计数(b) < n) { n = 计数(b) }
 定义 可变 i = 0
 当 (i < n) { 追加(结果, [a[i], b[i]])
 i = i + 1 }
 返回 结果
}

// 泛型: any/all
函数 泛型_任一大于(lst, 阈值) { 定义 可变 i = 0
 当 (i < 计数(lst)) { 如果 (lst[i] > 阈值) { 返回 真 }
 i = i + 1
 }
 返回 假
}

函数 泛型_全部大于(lst, 阈值) { 定义 可变 i = 0
 当 (i < 计数(lst)) { 如果 (lst[i] <= 阈值) { 返回 假 }
 i = i + 1
 }
 返回 真
}

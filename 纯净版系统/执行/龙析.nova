// NovaOS · 龙析 (DragonProf) 性能分析器
// 功能:
//  §1 函数计时探针: 进入/离开计时+调用计数
//  §2 调用图构建: 调用者→被调用者边+权重
//  §3 热点分析: 多关键字排序 (CPU/调用/最大)
//  §4 火焰图数据生成: 栈采样→折叠→JSON输出
//  §5 内存分析: 堆分配跟踪+分类统计+泄漏检测
//  §6 采样分析器: 定时中断采样栈
//  §7 调用树重建: 从采样→自底向上汇总
//  §8 AI总线: EWMA异常检测 + 智能建议

导入("../感知/流.nova")
导入("../标准/原生字符串.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../推理/值乘.nova")
导入("./控制台输出.nova")
导入("../中枢/自动扩容.nova")
导入("../中枢/高精定器添.nova")
导入("../中枢/整数转字符串.nova")
导入("../推理/智能总线鼠标.nova")
导入("../中枢/内核打印.nova")
导入("../感知/内核直连层.nova")

// §1 常量 + 数据结构

定义 最大探针数 = 4096
定义 最大调用图边 = 8192
定义 最大采样栈深 = 128
定义 最大采样数 = 65536
定义 最大分配跟踪 = 16384
定义 Q10 = 1024
定义 Q_ONE = 1024

结构 探针条目 {
    函数名,
    调用次数,
    总耗时,       // 微秒
    最大耗时,
    最小耗时,
    进入时戳,
}

结构 调用图边 {
    调用者哈希,
    被调用者哈希,
    调用次数,
    总耗时,
}

结构 采样帧 {
    栈深度,
    栈,          // 函数名哈希数组[最大采样栈深]
    时间戳,
}

结构 分配记录 {
    地址,
    大小,
    分配者,       // 函数名哈希
    时间戳,
    已释放,
}

// §2 全局状态

定义 可变 分析_条目 = 字典()      // 函数名 → [调用次数, 总耗时us, 最大耗时]
定义 可变 分析_开始时间 = 字典()  // 函数名 → 进入时间戳
定义 可变 分析_总采样 = 0
定义 可变 调用图_边表 = 0        // 调用图边内存
定义 可变 调用图_边数 = 0
定义 可变 采样缓冲 = 0           // 采样帧环形缓冲
定义 可变 采样数 = 0
定义 可变 采样写头 = 0
定义 可变 分配跟踪_表 = 0        // 分配记录[]
定义 可变 分配跟踪_数 = 0
定义 可变 当前调用栈 = []         // 当前线程调用栈(函数名哈希数组)

// §3 CLI 入口

函数 龙析_main(参数) {
    如果 (计数(参数) == 0) {
        打印行("龙析 v2.0 — NovaOS性能分析器")
        打印行("用法:")
        打印行("  龙析 report     — 显示性能报告")
        打印行("  龙析 reset      — 重置所有计数器")
        打印行("  龙析 top [N]    — 显示前N热点函数")
        打印行("  龙析 memory     — 内存使用分析")
        打印行("  龙析 callgraph  — 调用图统计")
        打印行("  龙析 flame      — 火焰图数据输出")
        打印行("  龙析 leaks      — 内存泄漏检测")
        打印行("  龙析 ai         — AI智能分析建议")
        返回 0
    }
    定义 命令 = 参数[0]
    如果 (命令 == "report") { 龙析_报告() }
    否则如果 (命令 == "reset") { 龙析_重置() }
    否则如果 (命令 == "top") {
        定义 n = 如果(计数(参数) > 1, 字符串转整数(参数[1]), 10)
        龙析_热点(n)
    }
    否则如果 (命令 == "memory") { 龙析_内存() }
    否则如果 (命令 == "callgraph") { 龙析_调用图() }
    否则如果 (命令 == "flame") { 龙析_火焰图() }
    否则如果 (命令 == "leaks") { 龙析_泄漏检测() }
    否则如果 (命令 == "ai") { 龙析_AI分析() }
    否则 { 打印行(字符串拼接("[龙析] 未知命令: ", 命令)) }
    返回 0
}

函数 龙析_重置() {
    分析_条目 = 字典()
    分析_开始时间 = 字典()
    分析_总采样 = 0
    调用图_边数 = 0
    采样数 = 0
    采样写头 = 0
    分配跟踪_数 = 0
    当前调用栈 = []
    打印行("[龙析] 所有计数器已重置")
}

// §4 函数计时探针

函数 分析_进入(函数名) {
    分析_总采样 = 分析_总采样 + 1
    字典设(分析_开始时间, 函数名, 获取滴答())
    // 压入调用栈
    追加(当前调用栈, 函数名)
}

函数 分析_离开(函数名) {
    定义 开始 = 字典取(分析_开始时间, 函数名)
    如果 (开始 == 空) { 返回 }
    定义 耗时 = 获取滴答() - 开始
    // 更新条目
    定义 现有 = 字典取(分析_条目, 函数名)
    如果 (现有 == 空) {
        字典设(分析_条目, 函数名, [1, 耗时, 耗时, 耗时])  // [次数, 总, 最大, 最小]
    } 否则 {
        设置(现有, 0, 现有[0] + 1)
        设置(现有, 1, 现有[1] + 耗时)
        如果 (耗时 > 现有[2]) { 设置(现有, 2, 耗时) }
        如果 (耗时 < 现有[3]) { 设置(现有, 3, 耗时) }
    }
    // 更新调用图
    如果 (计数(当前调用栈) >= 2) {
        定义 调用者 = 当前调用栈[计数(当前调用栈) - 2]
        调用图_添加边(调用者, 函数名, 耗时)
    }
    // 弹出调用栈
    如果 (计数(当前调用栈) > 0) {
        弹出(当前调用栈)
    }
}

// §5 调用图

函数 调用图_初始化() {
    如果 (调用图_边表 == 0) {
        调用图_边表 = 堆_分配(最大调用图边 * 32)  // 每边32字节
        内存_置零(调用图_边表, 最大调用图边 * 32)
        调用图_边数 = 0
    }
}

函数 调用图_添加边(调用者, 被调用者, 耗时) {
    调用图_初始化()
    // 查找已有边
    定义 caller_h = 字符串_哈希(调用者)
    定义 callee_h = 字符串_哈希(被调用者)
    定义 可变 i = 0
    当 (i < 调用图_边数) {
        定义 off = i * 32
        如果 (内存_读64(调用图_边表 + off) == caller_h && 内存_读64(调用图_边表 + off + 8) == callee_h) {
            // 更新已有边
            定义 旧次 = 内存_读64(调用图_边表 + off + 16)
            内存_写64(调用图_边表 + off + 16, 旧次 + 1)
            定义 旧时 = 内存_读64(调用图_边表 + off + 24)
            内存_写64(调用图_边表 + off + 24, 旧时 + 耗时)
            返回
        }
        i = i + 1
    }
    // 新边
    如果 (调用图_边数 < 最大调用图边) {
        定义 off = 调用图_边数 * 32
        内存_写64(调用图_边表 + off, caller_h)
        内存_写64(调用图_边表 + off + 8, callee_h)
        内存_写64(调用图_边表 + off + 16, 1)
        内存_写64(调用图_边表 + off + 24, 耗时)
        调用图_边数 = 调用图_边数 + 1
    }
}

// §6 采样分析器 (定时中断采样栈)

函数 采样_初始化() {
    如果 (采样缓冲 == 0) {
        // 每个采样帧: 8(栈深度) + 128*8(栈) + 8(时间戳) = 1040字节
        采样缓冲 = 堆_分配(最大采样数 * 1040)
        内存_置零(采样缓冲, 最大采样数 * 1040)
        采样数 = 0
        采样写头 = 0
    }
}

函数 采样_记录() {
    // 由定时器中断调用: 记录当前调用栈
    采样_初始化()
    定义 off = 采样写头 * 1040
    定义 深度 = 计数(当前调用栈)
    如果 (深度 > 最大采样栈深) { 深度 = 最大采样栈深 }
    内存_写64(采样缓冲 + off, 深度)
    定义 可变 i = 0
    当 (i < 深度) {
        定义 函数名 = 当前调用栈[i]
        内存_写64(采样缓冲 + off + 8 + i * 8, 字符串_哈希(函数名))
        i = i + 1
    }
    内存_写64(采样缓冲 + off + 8 + 128 * 8, 获取滴答())
    采样写头 = (采样写头 + 1) % 最大采样数
    如果 (采样数 < 最大采样数) { 采样数 = 采样数 + 1 }
}

// §7 内存分配跟踪 + 泄漏检测

函数 分配跟踪_初始化() {
    如果 (分配跟踪_表 == 0) {
        分配跟踪_表 = 堆_分配(最大分配跟踪 * 40)  // 每记录40字节
        内存_置零(分配跟踪_表, 最大分配跟踪 * 40)
        分配跟踪_数 = 0
    }
}

函数 分配跟踪_记录(地址, 大小) {
    分配跟踪_初始化()
    如果 (分配跟踪_数 >= 最大分配跟踪) { 返回 }
    定义 off = 分配跟踪_数 * 40
    内存_写64(分配跟踪_表 + off, 地址)
    内存_写64(分配跟踪_表 + off + 8, 大小)
    // 记录分配者(当前调用栈栈顶)
    如果 (计数(当前调用栈) > 0) {
        内存_写64(分配跟踪_表 + off + 16, 字符串_哈希(当前调用栈[计数(当前调用栈) - 1]))
    }
    内存_写64(分配跟踪_表 + off + 24, 获取滴答())
    内存_写64(分配跟踪_表 + off + 32, 0)  // 未释放
    分配跟踪_数 = 分配跟踪_数 + 1
}

函数 分配跟踪_标记释放(地址) {
    如果 (分配跟踪_表 == 0) { 返回 }
    定义 可变 i = 分配跟踪_数 - 1
    当 (i >= 0) {
        定义 off = i * 40
        如果 (内存_读64(分配跟踪_表 + off) == 地址 && 内存_读64(分配跟踪_表 + off + 32) == 0) {
            内存_写64(分配跟踪_表 + off + 32, 1)  // 标记已释放
            返回
        }
        i = i - 1
    }
}

// §8 报告 + 热点 + 调用图输出

函数 龙析_报告() {
    打印行("╔═════════════════════════════════════════════════════════╗")
    打印行("║         NovaOS 性能分析报告 (DragonProf v2.0)     ║")
    打印行("╠═════════════════════════════════════════════════════════╣")
    打印行(字符串拼接("  总探针采样: ", 整数转字符串(分析_总采样)))
    打印行(字符串拼接("  调用图边数: ", 整数转字符串(调用图_边数)))
    打印行(字符串拼接("  栈采样数:   ", 整数转字符串(采样数)))
    打印行(字符串拼接("  分配跟踪数: ", 整数转字符串(分配跟踪_数)))
    打印行("")
    打印行("  函数名              调用    总时间(us)  平均(us)  最大(us)  最小(us)")
    打印行("  ────────────────  ─────  ────────  ────────  ────────  ────────")
    // 遍历字典输出
    定义 键列表 = 字典_键列表(分析_条目)
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        定义 名 = 键列表[i]
        定义 条 = 字典取(分析_条目, 名)
        如果 (条 != 空) {
            定义 次 = 条[0]
            定义 总 = 条[1]
            定义 平均 = 如果(次 > 0, 总 / 次, 0)
            打印(字符串拼接("  ", 名))
            打印(字符串拼接("  ", 整数转字符串(次)))
            打印(字符串拼接("  ", 整数转字符串(总)))
            打印(字符串拼接("  ", 整数转字符串(平均)))
            打印(字符串拼接("  ", 整数转字符串(条[2])))
            打印行(字符串拼接("  ", 整数转字符串(条[3])))
        }
        i = i + 1
    }
    打印行("╚═════════════════════════════════════════════════════════╝")
}

函数 龙析_热点(数量) {
    // 按总耗时排序前 N 个函数
    定义 键列表 = 字典_键列表(分析_条目)
    定义 排序表 = []  // [总耗时, 名称]
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        定义 名 = 键列表[i]
        定义 条 = 字典取(分析_条目, 名)
        如果 (条 != 空) {
            追加(排序表, [条[1], 名])
        }
        i = i + 1
    }
    // 简单选择排序(降序)
    i = 0
    当 (i < 计数(排序表) - 1) {
        定义 可变 max_idx = i
        定义 可变 j = i + 1
        当 (j < 计数(排序表)) {
            如果 (排序表[j][0] > 排序表[max_idx][0]) {
                max_idx = j
            }
            j = j + 1
        }
        如果 (max_idx != i) {
            定义 tmp = 排序表[i]
            设置(排序表, i, 排序表[max_idx])
            设置(排序表, max_idx, tmp)
        }
        i = i + 1
    }
    // 输出前N
    打印行("─── 热点函数 (CPU时间排序) ───")
    i = 0
    定义 上限 = 如果(数量 < 计数(排序表), 数量, 计数(排序表))
    当 (i < 上限) {
        打印行(字符串拼接(字符串拼接(整数转字符串(i + 1), ". "), 字符串拼接(排序表[i][1], 字符串拼接(" - ", 字符串拼接(整数转字符串(排序表[i][0]), "us")))))
        i = i + 1
    }
}

函数 龙析_调用图() {
    打印行("─── 调用图统计 ───")
    打印行(字符串拼接("总边数: ", 整数转字符串(调用图_边数)))
    定义 可变 i = 0
    当 (i < 调用图_边数 && i < 20) {
        定义 off = i * 32
        定义 caller_h = 内存_读64(调用图_边表 + off)
        定义 callee_h = 内存_读64(调用图_边表 + off + 8)
        定义 cnt = 内存_读64(调用图_边表 + off + 16)
        定义 time = 内存_读64(调用图_边表 + off + 24)
        打印行(字符串拼接(字符串拼接(整数转字符串(caller_h), " -> "), 字符串拼接(整数转字符串(callee_h), 字符串拼接(" x", 字符串拼接(整数转字符串(cnt), 字符串拼接(" (", 字符串拼接(整数转字符串(time), "us)"))))))))
        i = i + 1
    }
}

函数 龙析_火焰图() {
    // 输出折叠栈格式 (Brendan Gregg FlameGraph)
    打印行("─── 火焰图数据 (折叠栈格式) ───")
    如果 (采样缓冲 == 0 || 采样数 == 0) {
        打印行("无采样数据")
        返回
    }
    定义 可变 i = 0
    当 (i < 采样数) {
        定义 off = i * 1040
        定义 深度 = 内存_读64(采样缓冲 + off)
        定义 可变 line = ""
        定义 可变 j = 0
        当 (j < 深度) {
            定义 h = 内存_读64(采样缓冲 + off + 8 + j * 8)
            如果 (j > 0) { line = 字符串_拼接(line, ";") }
            line = 字符串_拼接(line, 整数转字符串(h))
            j = j + 1
        }
        打印行(字符串_拼接(line, " 1"))
        i = i + 1
    }
}

// §9 内存分析 + 泄漏检测

函数 龙析_内存() {
    打印行("─── 内存使用分析 ───")
    // 基础统计
    定义 总分配 = 0
    定义 总释放 = 0
    定义 在用 = 0
    定义 可变 i = 0
    当 (i < 分配跟踪_数) {
        定义 off = i * 40
        定义 sz = 内存_读64(分配跟踪_表 + off + 8)
        总分配 = 总分配 + sz
        如果 (内存_读64(分配跟踪_表 + off + 32) != 0) {
            总释放 = 总释放 + sz
        } 否则 {
            在用 = 在用 + sz
        }
        i = i + 1
    }
    打印行(字符串拼接("  总分配:   ", 字符串拼接(整数转字符串(总分配), " 字节")))
    打印行(字符串拼接("  已释放:   ", 字符串拼接(整数转字符串(总释放), " 字节")))
    打印行(字符串拼接("  当前在用: ", 字符串拼接(整数转字符串(在用), " 字节")))
    打印行(字符串拼接("  跟踪记录: ", 整数转字符串(分配跟踪_数)))
}

函数 龙析_泄漏检测() {
    打印行("─── 内存泄漏检测 ───")
    定义 泄漏数 = 0
    定义 泄漏总量 = 0
    定义 可变 i = 0
    当 (i < 分配跟踪_数) {
        定义 off = i * 40
        如果 (内存_读64(分配跟踪_表 + off + 32) == 0) {  // 未释放
            定义 addr = 内存_读64(分配跟踪_表 + off)
            定义 sz = 内存_读64(分配跟踪_表 + off + 8)
            定义 alloc_h = 内存_读64(分配跟踪_表 + off + 16)
            打印行(字符串拼接("  泄漏: addr=", 字符串拼接(整数转字符串(addr), 字符串拼接(" size=", 字符串拼接(整数转字符串(sz), 字符串拼接(" alloc_by=", 整数转字符串(alloc_h)))))))
            泄漏数 = 泄漏数 + 1
            泄漏总量 = 泄漏总量 + sz
        }
        i = i + 1
    }
    打印行(字符串拼接("  泄漏总数: ", 字符串拼接(整数转字符串(泄漏数), 字符串拼接("  总量: ", 字符串拼接(整数转字符串(泄漏总量), " 字节")))))
}

// §10 AI总线: EWMA异常检测 + 智能建议

定义 EWMA_PROF_ALPHA = 205  // 0.2 * Q10
定义 可变 EWMA_平均耗时 = 0
定义 可变 EWMA_分配率 = 0

函数 龙析_AI分析() {
    定义 bus = 全局AI总线
    打印行("─── AI智能分析建议 ───")
    如果 (bus == 0) {
        打印行("  AI总线未初始化")
        返回
    }
    // 特征: [平均耗时, 分配率, 泄漏率, 栈深度]
    定义 特征 = Tensor_创建(1, 4)
    Tensor_写(特征, 0, 0, EWMA_平均耗时)
    Tensor_写(特征, 0, 1, EWMA_分配率)
    // 计算泄漏率
    定义 泄漏数 = 0
    定义 可变 i = 0
    当 (i < 分配跟踪_数) {
        如果 (内存_读64(分配跟踪_表 + i * 40 + 32) == 0) {
            泄漏数 = 泄漏数 + 1
        }
        i = i + 1
    }
    定义 泄漏率 = 如果(分配跟踪_数 > 0, 泄漏数 * Q10 / 分配跟踪_数, 0)
    Tensor_写(特征, 0, 2, 泄漏率)
    Tensor_写(特征, 0, 3, Q10)  // 偏置
    定义 分数 = AI总线_注意力权重(bus, 特征)
    Tensor_释放(特征)
    // 生成建议
    如果 (分数 > 800) {
        打印行("  [!] 严重性能问题检测")
    } 否则如果 (分数 > 500) {
        打印行("  [警告] 性能异常检测")
    } 否则 {
        打印行("  [正常] 未检测到明显异常")
    }
    如果 (泄漏率 > 200) {
        打印行(字符串拼接("  建议: 检查内存泄漏 (泄漏率 ", 字符串拼接(整数转字符串(泄漏率 * 100 / Q10), "%)")))
    }
    如果 (EWMA_平均耗时 > 10000) {
        打印行("  建议: 某些函数耗时过长, 建议用 'top' 命令定位热点")
    }
}

函数 龙析_AI反馈耗时(耗时_us) {
    // 将函数耗时反馈到EWMA
    EWMA_平均耗时 = (EWMA_PROF_ALPHA * 耗时_us + (Q10 - EWMA_PROF_ALPHA) * EWMA_平均耗时) / Q10
}

函数 龙析_AI反馈分配(分配字节) {
    // 将堆分配量反馈到EWMA
    EWMA_分配率 = (EWMA_PROF_ALPHA * 分配字节 + (Q10 - EWMA_PROF_ALPHA) * EWMA_分配率) / Q10
}

// 辅助: 字符串哈希
函数 字符串_哈希(s) {
    如果 (s == 空 || s == 0) { 返回 0 }
    定义 可变 h = 0x811C9DC5
    定义 len = 字符串长度(s)
    定义 可变 i = 0
    当 (i < len) {
        h = (h ^ 字节取(s, i)) * 16777619
        i = i + 1
    }
    返回 h & 0x7FFFFFFF
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./原子操作.nova")
导入("./高级中控设置.nova")
导入("./统一调度器核.nova")
导入("./整数转字符串.nova")
导入("./同步原语生乙.nova")
导入("./内核打印.nova")

定义 同步_最大自旋次数 = 1000
定义 同步_读写锁_写标志 = 0x80000000

结构 同步统计 {
    自旋锁_获取次数,
    自旋锁_争用次数,
    互斥锁_获取次数,
    互斥锁_争用次数,
    读写锁_读获取次数,
    读写锁_写获取次数,
    信号量_获取次数,
    信号量_释放次数,
    完成量_等待次数,
    完成量_完成次数,
    屏障_等待次数,
    条件变量_等待次数,
    条件变量_通知次数,
}

定义 可变 全局_同步统计 = 空

函数 同步统计_初始化() {
    如果 (全局_同步统计 == 空) {
        全局_同步统计 = 同步统计 {}
        全局_同步统计.自旋锁_获取次数 = 0
        全局_同步统计.自旋锁_争用次数 = 0
        全局_同步统计.互斥锁_获取次数 = 0
        全局_同步统计.互斥锁_争用次数 = 0
        全局_同步统计.读写锁_读获取次数 = 0
        全局_同步统计.读写锁_写获取次数 = 0
        全局_同步统计.信号量_获取次数 = 0
        全局_同步统计.信号量_释放次数 = 0
        全局_同步统计.完成量_等待次数 = 0
        全局_同步统计.完成量_完成次数 = 0
        全局_同步统计.屏障_等待次数 = 0
        全局_同步统计.条件变量_等待次数 = 0
        全局_同步统计.条件变量_通知次数 = 0
    }
}

结构 自旋锁 {
    锁定值: 原子32位,
    持有者: 整数,
    获取计数: 无符号长整数,
}

函数 初始化自旋锁(锁) {
    原子写入32位(&锁.锁定值, 0)
    锁.持有者 = -1
    锁.获取计数 = 0
}

函数 自旋锁加锁(锁) {
    同步统计_初始化()
    定义 可变 自旋次数 = 0
    当 !原子比较交换32位(&锁.锁定值, 0, 1) {
        当 原子读取32位(&锁.锁定值) != 0 {
            CPU暂停()
            自旋次数 = 自旋次数 + 1
        }
    }
    如果 (自旋次数 > 0) {
        全局_同步统计.自旋锁_争用次数 = 全局_同步统计.自旋锁_争用次数 + 1
    }
    锁.持有者 = 获取当前CPU编号()
    锁.获取计数++
    全局_同步统计.自旋锁_获取次数 = 全局_同步统计.自旋锁_获取次数 + 1
}

函数 自旋锁尝试加锁(锁) {
    如果 原子比较交换32位(&锁.锁定值, 0, 1) {
        锁.持有者 = 获取当前CPU编号()
        锁.获取计数++
        返回 真
    }
    返回 假
}

函数 自旋锁解锁(锁) {
    锁.持有者 = -1
    原子写入32位(&锁.锁定值, 0)
}

函数 自旋锁是否持有(锁) {
    返回 原子读取32位(&锁.锁定值) != 0
}

结构 自旋锁_IRQ {
    锁: 自旋锁,
    标志: 无符号长整数,
}

函数 自旋锁_IRQ加锁(锁) {
    锁.标志 = 保存标志并禁用中断()
    自旋锁加锁(&锁.锁)
}

函数 自旋锁_IRQ解锁(锁) {
    自旋锁解锁(&锁.锁)
    恢复标志(锁.标志)
}

结构 互斥锁 {
    锁定值: 原子32位,
    等待队列: 等待队列头,
    持有者: *任务结构体,
    自旋锁: 自旋锁,
    争用计数: 原子64位,
}

函数 初始化互斥锁(互斥锁) {
    原子写入32位(&互斥锁.锁定值, 0)
    初始化等待队列头(&互斥锁.等待队列)
    初始化自旋锁(&互斥锁.自旋锁)
    互斥锁.持有者 = 空
}

函数 互斥锁加锁(互斥锁) {
    同步统计_初始化()
    全局_同步统计.互斥锁_获取次数 = 全局_同步统计.互斥锁_获取次数 + 1

    如果 原子比较交换32位(&互斥锁.锁定值, 0, 1) {
        互斥锁.持有者 = 获取当前任务()
        返回
    }

    原子增加64位(&互斥锁.争用计数, 1)
    全局_同步统计.互斥锁_争用次数 = 全局_同步统计.互斥锁_争用次数 + 1

    自旋锁加锁(&互斥锁.自旋锁)

    当 原子读取32位(&互斥锁.锁定值) != 0 {
        等待项 := 创建等待队列项()
        添加到等待队列(&互斥锁.等待队列, 等待项)

        自旋锁解锁(&互斥锁.自旋锁)

        设置任务状态_不可中断睡眠()
        调度()

        自旋锁加锁(&互斥锁.自旋锁)
    }

    原子写入32位(&互斥锁.锁定值, 1)
    互斥锁.持有者 = 获取当前任务()

    自旋锁解锁(&互斥锁.自旋锁)
}

函数 互斥锁解锁(互斥锁) {
    互斥锁.持有者 = 空
    原子写入32位(&互斥锁.锁定值, 0)

    自旋锁加锁(&互斥锁.自旋锁)
    如果 等待队列非空(&互斥锁.等待队列) {
        定义 等待项 = 移除等待队列首项(&互斥锁.等待队列)
        唤醒任务(等待项)
    }
    自旋锁解锁(&互斥锁.自旋锁)
}

函数 互斥锁尝试加锁(互斥锁) {
    如果 原子比较交换32位(&互斥锁.锁定值, 0, 1) {
        互斥锁.持有者 = 获取当前任务()
        返回 真
    }
    返回 假
}

函数 互斥锁是否持有(互斥锁) {
    返回 原子读取32位(&互斥锁.锁定值) != 0
}

结构 读写锁 {
    状态: 原子32位,
    等待写者队列: 等待队列头,
    等待读者队列: 等待队列头,
    自旋锁: 自旋锁,
    读者计数: 原子32位,
}

函数 初始化读写锁(锁) {
    原子写入32位(&锁.状态, 0)
    原子写入32位(&锁.读者计数, 0)
    初始化等待队列头(&锁.等待写者队列)
    初始化等待队列头(&锁.等待读者队列)
    初始化自旋锁(&锁.自旋锁)
}

函数 读写锁_读加锁(锁) {
    同步统计_初始化()
    全局_同步统计.读写锁_读获取次数 = 全局_同步统计.读写锁_读获取次数 + 1

    自旋锁加锁(&锁.自旋锁)
    当 (原子读取32位(&锁.状态) & 同步_读写锁_写标志) != 0 {
        等待项 := 创建等待队列项()
        添加到等待队列(&锁.等待读者队列, 等待项)
        自旋锁解锁(&锁.自旋锁)
        设置任务状态_不可中断睡眠()
        调度()
        自旋锁加锁(&锁.自旋锁)
    }
    原子增加32位(&锁.状态, 1)
    原子增加32位(&锁.读者计数, 1)
    自旋锁解锁(&锁.自旋锁)
}

函数 读写锁_读解锁(锁) {
    自旋锁加锁(&锁.自旋锁)
    原子减少32位(&锁.状态, 1)
    原子减少32位(&锁.读者计数, 1)
    如果 原子读取32位(&锁.状态) == 0 {
        如果 等待队列非空(&锁.等待写者队列) {
            定义 等待项 = 移除等待队列首项(&锁.等待写者队列)
            唤醒任务(等待项)
        }
    }
    自旋锁解锁(&锁.自旋锁)
}

函数 读写锁_写加锁(锁) {
    同步统计_初始化()
    全局_同步统计.读写锁_写获取次数 = 全局_同步统计.读写锁_写获取次数 + 1

    自旋锁加锁(&锁.自旋锁)
    当 原子读取32位(&锁.状态) != 0 {
        等待项 := 创建等待队列项()
        添加到等待队列(&锁.等待写者队列, 等待项)
        自旋锁解锁(&锁.自旋锁)
        设置任务状态_不可中断睡眠()
        调度()
        自旋锁加锁(&锁.自旋锁)
    }
    原子写入32位(&锁.状态, 同步_读写锁_写标志)
    自旋锁解锁(&锁.自旋锁)
}

函数 读写锁_写解锁(锁) {
    自旋锁加锁(&锁.自旋锁)
    原子写入32位(&锁.状态, 0)

    当 等待队列非空(&锁.等待读者队列) {
        定义 等待项 = 移除等待队列首项(&锁.等待读者队列)
        唤醒任务(等待项)
    }
    如果 等待队列非空(&锁.等待写者队列) {
        定义 等待项 = 移除等待队列首项(&锁.等待写者队列)
        唤醒任务(等待项)
    }
    自旋锁解锁(&锁.自旋锁)
}

结构 信号量 {
    计数: 原子32位,
    等待队列: 等待队列头,
    自旋锁: 自旋锁,
}

函数 初始化信号量(信号量, 初始值) {
    原子写入32位(&信号量.计数, 初始值)
    初始化等待队列头(&信号量.等待队列)
    初始化自旋锁(&信号量.自旋锁)
}

函数 信号量P(信号量) {
    同步统计_初始化()
    全局_同步统计.信号量_获取次数 = 全局_同步统计.信号量_获取次数 + 1

    自旋锁加锁(&信号量.自旋锁)
    当 原子读取32位(&信号量.计数) <= 0 {
        等待项 := 创建等待队列项()
        添加到等待队列(&信号量.等待队列, 等待项)
        自旋锁解锁(&信号量.自旋锁)
        设置任务状态_不可中断睡眠()
        调度()
        自旋锁加锁(&信号量.自旋锁)
    }
    原子减少32位(&信号量.计数, 1)
    自旋锁解锁(&信号量.自旋锁)
}

函数 信号量V(信号量) {
    同步统计_初始化()
    全局_同步统计.信号量_释放次数 = 全局_同步统计.信号量_释放次数 + 1

    自旋锁加锁(&信号量.自旋锁)
    原子增加32位(&信号量.计数, 1)
    如果 等待队列非空(&信号量.等待队列) {
        定义 等待项 = 移除等待队列首项(&信号量.等待队列)
        唤醒任务(等待项)
    }
    自旋锁解锁(&信号量.自旋锁)
}

函数 信号量尝试P(信号量) {
    如果 原子读取32位(&信号量.计数) > 0 {
        自旋锁加锁(&信号量.自旋锁)
        如果 原子读取32位(&信号量.计数) > 0 {
            原子减少32位(&信号量.计数, 1)
            自旋锁解锁(&信号量.自旋锁)
            返回 真
        }
        自旋锁解锁(&信号量.自旋锁)
    }
    返回 假
}

函数 信号量获取计数(信号量) {
    返回 原子读取32位(&信号量.计数)
}

结构 完成量 {
    完成标志: 原子32位,
    等待队列: 等待队列头,
    自旋锁: 自旋锁,
}

函数 初始化完成量(完成量) {
    原子写入32位(&完成量.完成标志, 0)
    初始化等待队列头(&完成量.等待队列)
    初始化自旋锁(&完成量.自旋锁)
}

函数 等待完成(完成量) {
    同步统计_初始化()
    全局_同步统计.完成量_等待次数 = 全局_同步统计.完成量_等待次数 + 1

    如果 原子读取32位(&完成量.完成标志) != 0 { 返回 }

    自旋锁加锁(&完成量.自旋锁)
    当 原子读取32位(&完成量.完成标志) == 0 {
        等待项 := 创建等待队列项()
        添加到等待队列(&完成量.等待队列, 等待项)
        自旋锁解锁(&完成量.自旋锁)
        设置任务状态_不可中断睡眠()
        调度()
        自旋锁加锁(&完成量.自旋锁)
    }
    自旋锁解锁(&完成量.自旋锁)
}

函数 通知完成(完成量) {
    同步统计_初始化()
    全局_同步统计.完成量_完成次数 = 全局_同步统计.完成量_完成次数 + 1

    原子写入32位(&完成量.完成标志, 1)
    自旋锁加锁(&完成量.自旋锁)
    当 等待队列非空(&完成量.等待队列) {
        定义 等待项 = 移除等待队列首项(&完成量.等待队列)
        唤醒任务(等待项)
    }
    自旋锁解锁(&完成量.自旋锁)
}

函数 重置完成量(完成量) {
    原子写入32位(&完成量.完成标志, 0)
}

结构 屏障 {
    总数: 整数,
    等待计数: 原子32位,
    代: 原子32位,
    等待队列: 等待队列头,
    自旋锁: 自旋锁,
}

函数 初始化屏障(屏障, 总数) {
    屏障.总数 = 总数
    原子写入32位(&屏障.等待计数, 0)
    原子写入32位(&屏障.代, 0)
    初始化等待队列头(&屏障.等待队列)
    初始化自旋锁(&屏障.自旋锁)
}

函数 屏障等待(屏障) {
    同步统计_初始化()
    全局_同步统计.屏障_等待次数 = 全局_同步统计.屏障_等待次数 + 1

    定义 当前代 = 原子读取32位(&屏障.代)
    定义 新计数 = 原子增加32位(&屏障.等待计数, 1)

    如果 新计数 >= 屏障.总数 {
        原子写入32位(&屏障.等待计数, 0)
        原子增加32位(&屏障.代, 1)
        自旋锁加锁(&屏障.自旋锁)
        当 等待队列非空(&屏障.等待队列) {
            定义 等待项 = 移除等待队列首项(&屏障.等待队列)
            唤醒任务(等待项)
        }
        自旋锁解锁(&屏障.自旋锁)
        返回
    }

    自旋锁加锁(&屏障.自旋锁)
    当 原子读取32位(&屏障.代) == 当前代 {
        等待项 := 创建等待队列项()
        添加到等待队列(&屏障.等待队列, 等待项)
        自旋锁解锁(&屏障.自旋锁)
        设置任务状态_不可中断睡眠()
        调度()
        自旋锁加锁(&屏障.自旋锁)
    }
    自旋锁解锁(&屏障.自旋锁)
}

结构 条件变量 {
    等待队列: 等待队列头,
    自旋锁: 自旋锁,
}

函数 初始化条件变量(条件) {
    初始化等待队列头(&条件.等待队列)
    初始化自旋锁(&条件.自旋锁)
}

函数 条件变量_等待(条件, 互斥锁) {
    同步统计_初始化()
    全局_同步统计.条件变量_等待次数 = 全局_同步统计.条件变量_等待次数 + 1

    自旋锁加锁(&条件.自旋锁)
    等待项 := 创建等待队列项()
    添加到等待队列(&条件.等待队列, 等待项)
    自旋锁解锁(&条件.自旋锁)

    互斥锁解锁(互斥锁)

    设置任务状态_不可中断睡眠()
    调度()

    互斥锁加锁(互斥锁)
}

函数 条件变量_通知一个(条件) {
    同步统计_初始化()
    全局_同步统计.条件变量_通知次数 = 全局_同步统计.条件变量_通知次数 + 1

    自旋锁加锁(&条件.自旋锁)
    如果 等待队列非空(&条件.等待队列) {
        定义 等待项 = 移除等待队列首项(&条件.等待队列)
        唤醒任务(等待项)
    }
    自旋锁解锁(&条件.自旋锁)
}

函数 条件变量_通知全部(条件) {
    同步统计_初始化()
    全局_同步统计.条件变量_通知次数 = 全局_同步统计.条件变量_通知次数 + 1

    自旋锁加锁(&条件.自旋锁)
    当 等待队列非空(&条件.等待队列) {
        定义 等待项 = 移除等待队列首项(&条件.等待队列)
        唤醒任务(等待项)
    }
    自旋锁解锁(&条件.自旋锁)
}

函数 同步_打印统计() {
    同步统计_初始化()
    打印行("=== 同步原语统计 ===")
    打印行("自旋锁获取: " + 整数转字符串(全局_同步统计.自旋锁_获取次数))
    打印行("自旋锁争用: " + 整数转字符串(全局_同步统计.自旋锁_争用次数))
    打印行("互斥锁获取: " + 整数转字符串(全局_同步统计.互斥锁_获取次数))
    打印行("互斥锁争用: " + 整数转字符串(全局_同步统计.互斥锁_争用次数))
    打印行("读锁获取: " + 整数转字符串(全局_同步统计.读写锁_读获取次数))
    打印行("写锁获取: " + 整数转字符串(全局_同步统计.读写锁_写获取次数))
    打印行("信号量P: " + 整数转字符串(全局_同步统计.信号量_获取次数))
    打印行("信号量V: " + 整数转字符串(全局_同步统计.信号量_释放次数))
    打印行("完成量等待: " + 整数转字符串(全局_同步统计.完成量_等待次数))
    打印行("完成量通知: " + 整数转字符串(全局_同步统计.完成量_完成次数))
    打印行("屏障等待: " + 整数转字符串(全局_同步统计.屏障_等待次数))
    打印行("条件等待: " + 整数转字符串(全局_同步统计.条件变量_等待次数))
    打印行("条件通知: " + 整数转字符串(全局_同步统计.条件变量_通知次数))
    打印行("序列锁读: " + 整数转字符串(全局_同步统计_序列锁_读次数))
    打印行("序列锁写: " + 整数转字符串(全局_同步统计_序列锁_写次数))
}

// NSPT — Nova Synchronization Primitive Theory
// 公理1(互斥不变量): 互斥锁在任一时刻最多被一个任务持有
// 公理2(进度保证): 无争用时锁获取为O(1)原子操作
// 公理3(有界等待): 有限争用者时, 每个等待者最终获得锁
// 定理1(嵌套安全): 自旋锁_IRQ禁中断后获取, 防止中断上下文死锁
// 定理2(读并发): 读写锁允许无限并发读, 写独占
// 以下序列锁扩展满足"读不阻塞写"的无锁读模式:
//   写者: 序号+1 → 修改 → 序号+1 (写者间互斥)
//   读者: 读序号 → 读数据 → 重读序号; 若变化则重试

// 序列锁 — 读者无锁, 写者互斥

定义 可变 全局_同步统计_序列锁_读次数 = 0
定义 可变 全局_同步统计_序列锁_写次数 = 0

结构 序列锁 {
    序号: 原子32位,
    写锁: 自旋锁,
}

函数 初始化序列锁(锁) {
    原子写入32位(&锁.序号, 0)
    初始化自旋锁(&锁.写锁)
}

函数 序列锁_写开始(锁) {
    全局_同步统计_序列锁_写次数 = 全局_同步统计_序列锁_写次数 + 1
    自旋锁加锁(&锁.写锁)
    原子增加32位(&锁.序号, 1)
    内存屏障()
}

函数 序列锁_写结束(锁) {
    内存屏障()
    原子增加32位(&锁.序号, 1)
    自旋锁解锁(&锁.写锁)
}

函数 序列锁_读开始(锁) {
    全局_同步统计_序列锁_读次数 = 全局_同步统计_序列锁_读次数 + 1
    定义 可变 序号 = 原子读取32位(&锁.序号)
    当 (序号 & 1) != 0 {
        CPU暂停()
        序号 = 原子读取32位(&锁.序号)
    }
    读内存屏障()
    返回 序号
}

函数 序列锁_读重试(锁, 开始序号) {
    读内存屏障()
    返回 原子读取32位(&锁.序号) != 开始序号
}

// 简易死锁检测 — 基于锁顺序号

定义 锁顺序_最大深度 = 8

结构 每任务_锁记录 {
    锁地址列表,
    锁顺序列表,
    深度,
}

函数 死锁检测_记录获取(记录, 锁地址, 顺序号) {
    如果 (记录 == 空) { 返回 真 }
    如果 (记录.深度 >= 锁顺序_最大深度) { 返回 真 }

    // 检查是否违反锁顺序: 新锁顺序号必须大于已持有的所有锁
    定义 可变 i = 0
    当 (i < 记录.深度) {
        如果 (记录.锁顺序列表[i] >= 顺序号) {
            打印行("[NSPT] 死锁风险: 顺序号 " + 整数转字符串(顺序号) +
                   " <= 已持有 " + 整数转字符串(记录.锁顺序列表[i]))
            返回 假
        }
        如果 (记录.锁地址列表[i] == 锁地址) {
            打印行("[NSPT] 死锁: 同一锁重复获取")
            返回 假
        }
        i = i + 1
    }

    设置(记录.锁地址列表, 记录.深度, 锁地址)
    设置(记录.锁顺序列表, 记录.深度, 顺序号)
    记录.深度 = 记录.深度 + 1
    返回 真
}

函数 死锁检测_记录释放(记录, 锁地址) {
    如果 (记录 == 空 || 记录.深度 <= 0) { 返回 }

    // 从栈顶弹出(LIFO释放)
    如果 (记录.锁地址列表[记录.深度 - 1] == 锁地址) {
        记录.深度 = 记录.深度 - 1
        返回
    }

    // 非LIFO释放 — 在列表中查找并移除
    定义 可变 i = 0
    当 (i < 记录.深度) {
        如果 (记录.锁地址列表[i] == 锁地址) {
            // 向前移位
            定义 可变 j = i
            当 (j < 记录.深度 - 1) {
                设置(记录.锁地址列表, j, 记录.锁地址列表[j + 1])
                设置(记录.锁顺序列表, j, 记录.锁顺序列表[j + 1])
                j = j + 1
            }
            记录.深度 = 记录.深度 - 1
            返回
        }
        i = i + 1
    }
}

// 统计重置与获取

函数 同步_重置统计() {
    同步统计_初始化()
    全局_同步统计.自旋锁_获取次数 = 0
    全局_同步统计.自旋锁_争用次数 = 0
    全局_同步统计.互斥锁_获取次数 = 0
    全局_同步统计.互斥锁_争用次数 = 0
    全局_同步统计.读写锁_读获取次数 = 0
    全局_同步统计.读写锁_写获取次数 = 0
    全局_同步统计.信号量_获取次数 = 0
    全局_同步统计.信号量_释放次数 = 0
    全局_同步统计.完成量_等待次数 = 0
    全局_同步统计.完成量_完成次数 = 0
    全局_同步统计.屏障_等待次数 = 0
    全局_同步统计.条件变量_等待次数 = 0
    全局_同步统计.条件变量_通知次数 = 0
    全局_同步统计_序列锁_读次数 = 0
    全局_同步统计_序列锁_写次数 = 0
}

函数 同步_获取争用率() {
    同步统计_初始化()
    定义 总获取 = 全局_同步统计.自旋锁_获取次数 + 全局_同步统计.互斥锁_获取次数
    如果 (总获取 == 0) { 返回 0 }
    定义 总争用 = 全局_同步统计.自旋锁_争用次数 + 全局_同步统计.互斥锁_争用次数
    返回 总争用 * 10000 / 总获取
}

函数 同步_诊断() {
    同步_打印统计()
    定义 争用率 = 同步_获取争用率()
    打印行("争用率(万分): " + 整数转字符串(争用率))
    如果 (争用率 > 5000) {
        打印行("[NSPT] 警告: 争用率超过50%, 建议优化锁粒度")
    }
}

定义 可变 AI_同步原语生_风暴阈值 = 10000
定义 可变 AI_同步原语生_预测IRQ = 0

函数 AI_同步原语生_风暴检测(触发频率) {
    如果 (触发频率 > AI_同步原语生_风暴阈值) {
        AI_同步原语生_风暴阈值 = AI_同步原语生_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_同步原语生_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

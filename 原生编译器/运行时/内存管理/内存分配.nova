导入("../../标准库/基础.nova")

// Nova 原生内存分配器 — bump分配+伙伴系统+Slab缓存+线性资源管理
// 职责: 堆初始化 + bump分配 + 伙伴分裂/合并 + Slab预分配 + 内存统计
// 层级: 第7层运行时 (直击底层VirtualAlloc/mmap)

// 移除列表指定索引元素 (用新列表替换)
函数 列表_移除(列表, 索引) { 定义 可变 新 = []
 定义 可变 i = 0
 当 (i < 计数(列表)) { 如果 (i != 索引) { 追加(新, 列表[i]) }
 i = i + 1
 }
 返回 新
}

// 工具函数
函数 对齐8(n) { 返回 (n + 7) & (0 - 8) }

函数 log2_上取整(n) { 定义 可变 k = 0
 定义 可变 v = 1
 当 (v < n) { v = v * 2
 k = k + 1 }
 返回 k
}

函数 幂2(k) { 定义 可变 v = 1
 定义 可变 i = 0
 当 (i < k) { v = v * 2
 i = i + 1 }
 返回 v
}
函数 二次幂(k) { 返回 幂2(k) }

// 伙伴分配器 (Buddy Allocator)
// 型: [空闲表, 最小阶, 最大阶, 总块数, 块状态, 分配数, 释放数]
// 空闲表[k] = 该阶空闲块起始地址列表
// 块状态: [地址→{阶, 是否占用}] 用列表模拟

函数 伙伴_创建(最大阶, 最小阶) { 定义 层数 = 最大阶 - 最小阶 + 1
 定义 可变 空闲表 = []
 定义 可变 i = 0
 当 (i < 层数) { 追加(空闲表, [])
 i = i + 1 }
 // 初始: 一个最大阶空闲块在地址0
 追加(空闲表[层数 - 1], 0)
 // 块状态: [地址, 阶, 占用] 列表
 定义 可变 块表 = []
 追加(块表, [0, 最大阶, 0])
 返回 [空闲表, 最小阶, 最大阶, 层数, 块表,]
}

// 在空闲表中查找并移除指定地址 (重建列表)
函数 伙伴_移除空闲(分配器, 层idx, 地址) { 定义 可变 新 = []
 定义 可变 找到 = 假
 定义 可变 i = 0
 当 (i < 计数(分配器[0][层idx])) { 如果 (分配器[0][层idx][i] == 地址 且 找到 == 假) {
 找到 = 真
 } 否则 {
 追加(新, 分配器[0][层idx][i])
 }
 i = i + 1
 }
 分配器[0][层idx] = 新
 返回 找到
}

// 查找块状态
函数 伙伴_查块(块表, 地址) { 定义 可变 i = 0
 当 (i < 计数(块表)) { 如果 (块表[i][0] == 地址) { 返回 i }
 i = i + 1
 }
 返回 -1
}

// 分配: 找到足够大的空闲块, 必要时分裂
函数 伙伴_分配(分配器, 大小) { 定义 可变 需要阶 = log2_上取整(大小)
 如果 (需要阶 < 分配器[1]) { 需要阶 = 分配器[1] }
 如果 (需要阶 > 分配器[2]) { 返回 -1 }
 定义 层偏移 = 需要阶 - 分配器[1]
 // 从需要阶向上找空闲块
 定义 可变 找到阶 = -1
 定义 可变 k = 层偏移
 当 (k < 分配器[3]) { 如果 (计数(分配器[0][k]) > 0) { 找到阶 = k
 k = 分配器[3] }
 否则 { k = k + 1 }
 }
 如果 (找到阶 < 0) { 返回 -1 }
 // 取出空闲块
 定义 实际阶 = 找到阶 + 分配器[1]
 定义 可变 地址 = 分配器[0][找到阶][计数(分配器[0][找到阶]) - 1]
 分配器[0][找到阶] = 列表_移除(分配器[0][找到阶], 计数(分配器[0][找到阶]) - 1)
 // 分裂到需要阶
 定义 可变 当前阶 = 实际阶
 定义 可变 当前地址 = 地址
 当 (当前阶 > 需要阶) {
 当前阶 = 当前阶 - 1
 定义 伙伴地址 = 当前地址 + 二次幂(当前阶)
 // 伙伴块加入空闲表
 追加(分配器[0][当前阶 - 分配器[1]], 伙伴地址)
 追加(分配器[4], [伙伴地址, 当前阶, 0])
 }
 // 标记为占用
 定义 可变 bi = 伙伴_查块(分配器[4], 当前地址)
 如果 (bi >= 0) {
 分配器[4][bi][1] = 需要阶
 分配器[4][bi][2] = 1
 } 否则 {
 追加(分配器[4], [当前地址, 需要阶, 1])
 }
 分配器[5] = 分配器[5] + 1
 返回 当前地址
}

// 计算伙伴地址: XOR with block size
函数 伙伴_地址(地址, 阶) { 定义 可变 块大小 = 二次幂(阶)
 // 伙伴 = 地址 XOR 块大小
 返回 地址 ^ 块大小
}

// 释放: 标记空闲, 尝试与伙伴合并
函数 伙伴_释放(分配器, 地址) { 定义 bi = 伙伴_查块(分配器[4], 地址)
 如果 (bi < 0) { 返回 假 }
 如果 (分配器[4][bi][2] == 0) { 返回 假 }
 定义 可变 当前阶 = 分配器[4][bi][1]
 定义 可变 当前地址 = 地址
 分配器[4][bi][2] = 0
 // 尝试合并
 定义 可变 合并成功 = 真
 当 (合并成功 且 当前阶 < 分配器[2]) { 定义 伙伴addr = 伙伴_地址(当前地址, 当前阶)
 // 检查伙伴是否也空闲
 定义 pi = 伙伴_查块(分配器[4], 伙伴addr)
 如果 (pi >= 0 且 分配器[4][pi][2] == 0 且 分配器[4][pi][1] == 当前阶) {
 // 合并: 移除伙伴的空闲记录
 伙伴_移除空闲(分配器, 当前阶 - 分配器[1], 伙伴addr)
 // 合并地址取较小的
 如果 (伙伴addr < 当前地址) { 当前地址 = 伙伴addr }
 当前阶 = 当前阶 + 1
 // 更新块状态
 定义 ui = 伙伴_查块(分配器[4], 当前地址)
 如果 (ui >= 0) { 分配器[4][ui][1] = 当前阶 }
 } 否则 {
 合并成功 = 假
 }
 }
 // 加入空闲表
 追加(分配器[0][当前阶 - 分配器[1]], 当前地址)
 分配器[6] = 分配器[6] + 1
 返回 真
}

函数 伙伴_分配数(分配器) { 返回 分配器[5] }
函数 伙伴_释放数(分配器) { 返回 分配器[6] }

// 空闲块总数 (所有阶)
函数 伙伴_空闲块数(分配器) { 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 分配器[3]) {
 总 = 总 + 计数(分配器[0][i])
 i = i + 1
 }
 返回 总
}

// 最佳适配分配 (空闲链表)
函数 空闲链_最佳分配(分配器, 大小) { 定义 可变 对齐大小 = 对齐8(大小)
 如果 (对齐大小 < 8) { 对齐大小 = 8 }
 定义 可变 最佳 = -1
 定义 可变 最小差 = 0x7FFFFFFF
 定义 可变 i = 0
 当 (i < 计数(分配器[0])) { 如果 (分配器[0][i][2] == 0 且 分配器[0][i][1] >= 对齐大小) { 定义 差 = 分配器[0][i][1] - 对齐大小
 如果 (差 < 最小差) { 最小差 = 差
 最佳 = i }
 }
 i = i + 1
 }
 如果 (最佳 < 0) { 返回 -1 }
 定义 可变 起始 = 分配器[0][最佳][0]
 定义 可变 块大小 = 分配器[0][最佳][1]
 如果 (块大小 > 对齐大小 + 8) { 定义 可变 新块 = []
 i = 0
 当 (i < 计数(分配器[0])) { 如果 (i == 最佳) {
 追加(新块, [起始, 对齐大小, 1])
 追加(新块, [起始 + 对齐大小, 块大小 - 对齐大小, 0])
 } 否则 { 追加(新块, 分配器[0][i]) }
 i = i + 1
 }
 分配器[0] = 新块
 } 否则 { 分配器[0][最佳][2] = 1 }
 分配器[2] = 分配器[2] + 1
 返回 起始
}

// 内存利用率 (百分比)
函数 空闲链_利用率(分配器) { 定义 可变 已用 = 0
 定义 可变 i = 0
 当 (i < 计数(分配器[0])) { 如果 (分配器[0][i][2] == 1) { 已用 = 已用 + 分配器[0][i][1] }
 i = i + 1
 }
 如果 (分配器[1] == 0) { 返回 0 }
 返回 已用 * 100 / 分配器[1]
}

// 空闲链表分配器 (Free List + Coalescing)
// 型: [块列表, 总容量, 分配数]
// 块: [起始, 大小, 占用]

函数 空闲链_创建(容量) { 定义 可变 块列表 = []
 追加(块列表, [0, 容量, 0])
 返回 [块列表, 容量, 0]
}

// 首次适配分配
函数 空闲链_分配(分配器, 大小) { 定义 可变 对齐大小 = 对齐8(大小)
 如果 (对齐大小 < 8) { 对齐大小 = 8 }
 定义 可变 i = 0
 当 (i < 计数(分配器[0])) { 如果 (分配器[0][i][2] == 0 且 分配器[0][i][1] >= 对齐大小) { 定义 起始 = 分配器[0][i][0]
 定义 块大小 = 分配器[0][i][1]
 如果 (块大小 > 对齐大小 + 8) {
 // 分裂: 重建块列表
 定义 可变 新块 = []
 定义 可变 j = 0
 当 (j < 计数(分配器[0])) { 如果 (j == i) {
 追加(新块, [起始, 对齐大小, 1])
 追加(新块, [起始 + 对齐大小, 块大小 - 对齐大小, 0])
 } 否则 {
 追加(新块, 分配器[0][j])
 }
 j = j + 1
 }
 分配器[0] = 新块
 } 否则 {
 分配器[0][i][2] = 1
 }
 分配器[2] = 分配器[2] + 1
 返回 起始
 }
 i = i + 1
 }
 返回 -1
}

// 释放并合并相邻空闲块 (重建列表避免删除)
函数 空闲链_释放(分配器, 地址) {
 // 先找到并标记空闲
 定义 可变 找到 = -1
 定义 可变 i = 0
 当 (i < 计数(分配器[0])) { 如果 (分配器[0][i][0] == 地址 且 分配器[0][i][2] == 1) { 分配器[0][i][2] = 0
 找到 = i }
 i = i + 1
 }
 如果 (找到 < 0) { 返回 假 }
 // 重建列表: 合并相邻空闲块
 定义 可变 新块 = []
 i = 0
 当 (i < 计数(分配器[0])) { 定义 当前 = 分配器[0][i]
 如果 (当前[2] == 0 且 计数(新块) > 0 且 新块[计数(新块) - 1][2] == 0) {
 // 与前一个空闲块合并
 新块[计数(新块) - 1][1] = 新块[计数(新块) - 1][1] + 当前[1]
 } 否则 {
 追加(新块, [当前[0], 当前[1], 当前[2]])
 }
 i = i + 1
 }
 分配器[0] = 新块
 返回 真
}

函数 空闲链_空闲总量(分配器) { 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 计数(分配器[0])) { 如果 (分配器[0][i][2] == 0) { 总 = 总 + 分配器[0][i][1] }
 i = i + 1
 }
 返回 总
}

函数 空闲链_碎片数(分配器) { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(分配器[0])) { 如果 (分配器[0][i][2] == 0) { c = c + 1 }
 i = i + 1
 }
 返回 c
}

// 竞技场分配器 (Arena / Bump Allocator)
// 型: [容量, 已用, 分配数, 水位标记列表]

函数 内存分配_竞技场_创建(容量) { 返回 [容量, 0, []]
}

函数 竞技场_分配(arena, 大小) { 定义 对齐后 = 对齐8(大小)
 如果 (arena[1] + 对齐后 > arena[0]) { 返回 -1 }
 定义 地址 = arena[1]
 arena[1] = arena[1] + 对齐后
 arena[2] = arena[2] + 1
 返回 地址
}

函数 竞技场_保存(arena) {
 追加(arena[3], arena[1])
}

函数 竞技场_恢复(arena) { 如果 (计数(arena[3]) > 0) { 定义 上次 = arena[3][计数(arena[3]) - 1]
 arena[3] = 列表_移除(arena[3], 计数(arena[3]) - 1)
 arena[1] = 上次
 }
}

函数 竞技场_重置(arena) { arena[1] = 0
arena[2] = 0
arena[3] = [] }
函数 竞技场_已用(arena) { 返回 arena[1] }
函数 竞技场_剩余(arena) { 返回 arena[0] - arena[1] }

// Slab分配器 (固定大小对象池)
// 型: [对象大小, 空闲列表, 总数, 已分配数]

函数 内存分配_slab_创建(对象大小, 初始数量) { 定义 可变 空闲 = []
 定义 可变 i = 初始数量 - 1
 当 (i >= 0) { 追加(空闲, i)
 i = i - 1 }
 返回 [对象大小, 空闲, 初始数量, 0]
}

函数 内存分配_slab_分配(slab) {
    如果 (计数(slab[1]) == 0) { 返回 -1
}
 定义 可变 idx = slab[1][计数(slab[1]) - 1]
 slab[1] = 列表_移除(slab[1], 计数(slab[1]) - 1)
 slab[3] = slab[3] + 1
 返回 idx * slab[0]
}

函数 内存分配_slab_释放(slab, 地址) { 定义 idx = 地址 / slab[0]
 追加(slab[1], idx)
 slab[3] = slab[3] - 1
}

函数 slab_已用(slab) { 返回 slab[3] }
函数 slab_空闲(slab) { 返回 计数(slab[1]) }

// 内存池管理

函数 分配器_内存池_创建(块大小, 块数) { 定义 可变 池 = [块大小, 块数, [], 0]
 定义 可变 i = 0
 当 (i < 块数) {
 追加(池[2], i)
 i = i + 1
 }
 返回 池
}

函数 分配器_内存池_分配(池) {
    定义 可变 新空闲 = []
    如果 (计数(池[2]) == 0) { 返回 -1
}
 定义 n = 计数(池[2])
 定义 idx = 池[2][n - 1]
 定义 可变 k = 0
 当 (k < n - 1) { 追加(新空闲, 池[2][k])
 k = k + 1 }
 池[2] = 新空闲
 池[3] = 池[3] + 1
 返回 idx * 池[0]
}

函数 简易池_释放(池, 地址) { 定义 idx = 地址 / 池[0]
 追加(池[2], idx)
 池[3] = 池[3] - 1
}

函数 简易池_利用率(池) {
    如果 (池[1] == 0) { 返回 0
}
 返回 池[3] * 100 / 池[1]
}

// 伙伴分配器

函数 内存分配_伙伴_阶(大小) { 定义 可变 阶 = 0
 定义 可变 s = 1
 当 (s < 大小) { s = s * 2 阶 = 阶 + 1 }
 返回 阶
}

函数 伙伴_对齐(大小) { 定义 可变 s = 1
 当 (s < 大小) { s = s * 2 }
 返回 s
}

// 统计表: [分配次数, 释放次数, 总分配, 峰值, 当前]
定义 可变 内存统计 = [0, 0, 0, 0, 0]

函数 内存分配_内存_记录分配(大小) { 内存统计[0] = 内存统计[0] + 1
 内存统计[2] = 内存统计[2] + 大小
 内存统计[4] = 内存统计[4] + 大小
 如果 (内存统计[4] > 内存统计[3]) { 内存统计[3] = 内存统计[4] }
}

函数 内存分配_内存_记录释放(大小) { 内存统计[1] = 内存统计[1] + 1
 内存统计[4] = 内存统计[4] - 大小
}

函数 内存_泄漏检测() { 定义 差 = 内存统计[0] - 内存统计[1]
 如果 (差 > 100) { 返回 "严重泄漏: 未释放" + 转字符串(差) + "块" }
 如果 (差 > 10) { 返回 "可能泄漏: " + 转字符串(差) + "块未释放" }
 如果 (差 > 0) { 返回 "轻微泄漏" }
 返回 "无泄漏"
}

函数 内存_碎片评估() {
    如果 (内存统计[3] == 0) { 返回 "无数据"
}
 定义 利用率 = 内存统计[4] * 100 / 内存统计[3]
 如果 (利用率 < 30) { 返回 "碎片严重(考虑压缩)" }
 如果 (利用率 < 60) { 返回 "中等碎片" }
 返回 "碎片率低"
}

函数 内存_重置() { 内存统计[0] = 0
 内存统计[1] = 0
 内存统计[2] = 0
 内存统计[3] = 0
 内存统计[4] = 0
}

函数 内存_平均分配大小() {
    如果 (内存统计[0] == 0) { 返回 0
}
 返回 内存统计[2] / 内存统计[0]
}

函数 内存_推荐池大小() { 定义 平均 = 内存_平均分配大小()
 如果 (平均 > 4096) { 返回 "大对象池(>4KB)" }
 如果 (平均 > 256) { 返回 "中等对象池" }
 返回 "小对象Slab分配"
}

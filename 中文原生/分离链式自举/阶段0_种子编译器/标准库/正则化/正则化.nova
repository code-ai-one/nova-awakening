导入("../基础.nova")
导入("../数学/基础/数学库.nova")
导入("../算法/数学扩展.nova")
导入("../../编译器/标准前导.nova")


定义 正则_随机态 = 33333
函数 正则_随机() {
 正则_随机态 = 正则_随机态 ^ (正则_随机态 << 13)
 正则_随机态 = 正则_随机态 ^ (正则_随机态 >> 7)
 正则_随机态 = 正则_随机态 ^ (正则_随机态 << 17)
 如果 (正则_随机态 < 0) { 正则_随机态 = 0 - 正则_随机态 }
 返回 正则_随机态
}

// L1正则 (Lasso)
函数 L1_惩罚(权重, 衰减系数) { 返回 衰减系数 * 折叠(权重, 0, (s, w) => s + 绝对值(w)) / 100
}

函数 L1_梯度(权重, 衰减系数) { 定义 可变 梯度 = []
 定义 可变 i = 0
 当 (i < 计数(权重)) { 如果 (权重[i] > 0) { 追加(梯度, 衰减系数) }
 否则 如果 (权重[i] < 0) { 追加(梯度, 0 - 衰减系数) }
 否则 { 追加(梯度, 0) }
 i = i + 1
 }
 返回 梯度
}

// L2正则 (Ridge)
函数 L2_惩罚(权重, 衰减系数) { 返回 衰减系数 * 折叠(权重, 0, (s, w) => s + w * w) / 200
}

函数 L2_梯度(权重, 衰减系数) { 返回 映射(权重, w => 衰减系数 * w / 100)
}

// 权重衰减
函数 正则_权重衰减(权重, 衰减率) { 定义 可变 i = 0
 当 (i < 计数(权重)) {
 权重[i] = 权重[i] * (100 - 衰减率) / 100
 i = i + 1
 }
}

// 随机丢弃层
函数 正则_Dropout_前向(输入, 丢弃率) { 定义 可变 输出 = []
 定义 缩放 = 100 * 100 / (100 - 丢弃率)
 定义 可变 i = 0
 当 (i < 计数(输入)) { 如果 (正则_随机() % 100 < 丢弃率) { 追加(输出, 0) }
 否则 { 追加(输出, 输入[i] * 缩放 / 100) }
 i = i + 1
 }
 返回 输出
}

// 标签平滑
函数 标签平滑(标签, 类别数, 平滑因子) { 定义 可变 smoothed = []
 定义 可变 i = 0
 当 (i < 类别数) { 如果 (i == 标签) {
 追加(smoothed, 100 - 平滑因子)
 } 否则 {
 追加(smoothed, 平滑因子 / (类别数 - 1))
 }
 i = i + 1
 }
 返回 smoothed
}

// 剪枝 (权重剪枝)
函数 剪枝_幅度(权重, 剪枝率) {
 // 按幅度排序，剪掉最小的
 定义 n = 计数(权重)
 定义 剪枝数 = n * 剪枝率 / 100
 定义 排序abs = 映射(权重, w => 绝对值(w))
 排序(排序abs, 0)
 定义 可变 阈值 = 0
 如果 (剪枝数 > 0 且 剪枝数 < n) { 阈值 = 排序abs[剪枝数] }
 // 剪枝
 定义 可变 掩码 = []
 定义 可变 被剪 = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (绝对值(权重[i]) < 阈值) { 追加(掩码, 0)
 被剪 = 被剪 + 1 }
 否则 { 追加(掩码, 1) }
 i = i + 1
 }
 返回 [掩码, 被剪]
}

// Elastic Net (L1+L2)
函数 ElasticNet_惩罚(权重, 衰减系数, 学习率) {
 // alpha控制L1比例: 学习率*L1 + (1-学习率)*L2
 定义 l1 = L1_惩罚(权重, 衰减系数)
 定义 l2 = L2_惩罚(权重, 衰减系数)
 返回 学习率 * l1 / 100 + (100 - 学习率) * l2 / 100
}

// 梯度惩罚
函数 梯度_惩罚(梯度, 衰减系数) { 定义 sq = 折叠(梯度, 0, (s, g) => s + g * g)
 定义 可变 范数 = 整数sqrt(sq)
 定义 可变 差值 = 范数 - 100
 如果 (差值 < 0) { 差值 = 0 - 差值 }
 返回 衰减系数 * 差值 * 差值 / 10000
}

// 随机深度
函数 随机深度(输入, 残差, 存活率) { 如果 (正则_随机() % 100 < 存活率) { 返回 拉链(输入, 残差, (a, b) => a + b)
 }
 返回 输入
}

// 弹性网络

函数 弹性网络_惩罚(权重, l1_lambda, l2_lambda, 学习率) {
 // alpha控制L1和L2的比例, 学习率=100表示纯L1
 定义 l1 = L1_惩罚(权重, l1_lambda)
 定义 可变 l2 = 0
 定义 可变 i = 0
 当 (i < 计数(权重)) {
 l2 = l2 + 权重[i] * 权重[i]
 i = i + 1
 }
 l2 = l2_lambda * l2 / 2000
 返回 学习率 * l1 / 100 + (100 - 学习率) * l2 / 100
}

// 梯度裁剪

函数 正则_梯度_范数裁剪(梯度, 最大范数) {
    定义 可变 范数平方 = 0
 定义 可变 i = 0
 当 (i < 计数(梯度)) {
 范数平方 = 范数平方 + 梯度[i] * 梯度[i]
 i = i + 1
 }
 定义 范数 = 整数sqrt(范数平方)
 如果 (范数 <= 最大范数) { 返回 梯度 }
 定义 可变 结果 = []
 i = 0
 当 (i < 计数(梯度)) {
 追加(结果, 梯度[i] * 最大范数 / (范数 + 1))
 i = i + 1
 }
 返回 结果
}

函数 正则_梯度_值裁剪(梯度, 最小值, 最大值) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(梯度)) { 定义 可变 v = 梯度[i]
 如果 (v < 最小值) { v = 最小值 }
 如果 (v > 最大值) { v = 最大值 }
 追加(结果, v)
 i = i + 1
 }
 返回 结果
}

// 权重衰减

函数 权重衰减_应用(权重, 学习率, 衰减率) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(权重)) {
 追加(结果, 权重[i] * (1000 - 学习率 * 衰减率) / 1000)
 i = i + 1
 }
 返回 结果
}

// 批归一化

函数 正则化_批归一化(数据, 衰减率, 动量率) {
 // 计算均值
 定义 可变 均值 = 0
 定义 可变 i = 0
 当 (i < 计数(数据)) { 均值 = 均值 + 数据[i] i = i + 1 }
 均值 = 均值 / 计数(数据)
 // 计算方差
 定义 可变 方差 = 0
 i = 0
 当 (i < 计数(数据)) { 定义 差 = 数据[i] - 均值
 方差 = 方差 + 差 * 差
 i = i + 1
 }
 方差 = 方差 / 计数(数据)
 // 归一化
 定义 标准差 = 整数sqrt(方差) + 1
 定义 可变 结果 = []
 i = 0
 当 (i < 计数(数据)) { 定义 归一 = (数据[i] - 均值) * 1000 / 标准差
 追加(结果, 归一 * 衰减率 / 1000 + 动量率)
 i = i + 1
 }
 返回 结果
}

定义 可变 _正则_裁剪数 = 0
定义 可变 _正则_操作数 = 0

函数 正则化_记录操作() { _正则_操作数 = _正则_操作数 + 1 }
函数 正则化_记录裁剪() { _正则_裁剪数 = _正则_裁剪数 + 1 }

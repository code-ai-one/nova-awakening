导入("../../标准库/基础.nova")
导入("../../编译器/标记常量.nova")
导入("./字符工具.nova")

// Nova 原生字符串扫描器 — 双引号/单引号/原始/模板/多行字符串+转义处理
// 职责: 转义序列解析 + 字符串字面量扫描 + 模板插値 + 字符串工具
// 层级: 第1层基础设施

// 转义序列处理
// 返回转义后的字符码, -1表示无效
函数 字符串扫_解析转义(c) {
    如果 (c == 标记_定义) { 返回 10 }   // \n → LF
    如果 (c == 标记_如果) { 返回 13 }   // \r → CR
    如果 (c == 标记_当) { 返回 9 }    // \t → TAB
    如果 (c == 标记_左花) { 返回 92 }  // \\ → \
    如果 (c == 标记_余) { 返回 34 }  // \" → "
    如果 (c == 39) { 返回 39 }  // \' → '
    如果 (c == 48) { 返回 0 }  // \0 → NUL
    如果 (c == 标记_点号) { 返回 7 }  // \a → BEL
    如果 (c == 标记_冒号) { 返回 8 }  // \b → BS
    如果 (c == 标记_名称) { 返回 12 }   // \f → FF
    如果 (c == 标记_导入) { 返回 11 }   // \v → VT
    返回 0 - 1
}

// 十六进制转义: \xHH
函数 十六进制字符値(c) {
    如果 (c >= 48) { 如果 (c <= 57) { 返回 c - 48 } }
    如果 (c >= 65) { 如果 (c <= 70) { 返回 c - 55 } }
    如果 (c >= 97) { 如果 (c <= 102) { 返回 c - 87 } }
    返回 0 - 1
}

函数 解析十六进制转义(高, 低) {
    定义 h = 十六进制字符値(高)
    定义 l = 十六进制字符値(低)
    如果 (h < 0) { 返回 0 - 1 }
    如果 (l < 0) { 返回 0 - 1 }
    返回 h * 16 + l
}

// 字符串扫描状态

// 扫描结果: [状态, 内容, 长度, 转义数]
函数 扫描结果(状态, 内容, 长度, 转义数) {
    返回 [状态, 内容, 长度, 转义数]
}

// 简单字符串验证
// 检查字符串是否有效 (双引号包围, 转义正确)
函数 验证字符串(s) {
    定义 长 = 计数(s)
    如果 (长 < 2) { 返回 串状_未终止 }
    如果 (编码(子串(s, 0, 1)) != 34) { 返回 串状_未终止 }
    如果 (编码(子串(s, 长 - 1, 1)) != 34) { 返回 串状_未终止 }
    // 检查转义
    定义 可变 i = 1
    当 (i < 长 - 1) {
        定义 c = 编码(子串(s, i, 1))
        如果 (c == 标记_左花) {  // 反斜杠
            如果 (i + 1 >= 长 - 1) { 返回 串状_无效转义 }
            定义 next = 编码(子串(s, i + 1, 1))
            如果 (next == 标记_建) {  // \x
                如果 (i + 3 >= 长 - 1) { 返回 串状_无效十六 }
                定义 h = 十六进制字符値(编码(子串(s, i + 2, 1)))
                定义 l = 十六进制字符値(编码(子串(s, i + 3, 1)))
                如果 (h < 0) { 返回 串状_无效十六 }
                如果 (l < 0) { 返回 串状_无效十六 }
                i = i + 4
            } 否则 {
                定义 v = 解析转义(next)
                如果 (v < 0) { 返回 串状_无效转义 }
                i = i + 2
            }
        } 否则 {
            i = i + 1
        }
    }
    返回 串状_正常
}

// 统计转义序列数
函数 统计转义(s) {
    定义 长 = 计数(s)
    定义 可变 数 = 0
    定义 可变 i = 0
    当 (i < 长) {
        如果 (编码(子串(s, i, 1)) == 92) {
            数 = 数 + 1
            i = i + 2
        } 否则 {
            i = i + 1
        }
    }
    返回 数
}

// 计算实际字符串长度 (处理转义后)
函数 实际长度(s) {
    定义 长 = 计数(s)
    如果 (长 < 2) { 返回 0 }
    定义 可变 结果 = 0
    定义 可变 i = 1  // 跳过开头引号
    当 (i < 长 - 1) {  // 跳过结尾引号
        如果 (编码(子串(s, i, 1)) == 92) {
            定义 next = 编码(子串(s, i + 1, 1))
            如果 (next == 标记_建) { i = i + 4 }
            否则 { i = i + 2 }
        } 否则 {
            i = i + 1
        }
        结果 = 结果 + 1
    }
    返回 结果
}

// 是否多行字符串
函数 是多行(s) {
    定义 长 = 计数(s)
    定义 可变 i = 0
    当 (i < 长) {
        定义 c = 编码(子串(s, i, 1))
        如果 (c == 10) { 返回 1 }
        如果 (c == 13) { 返回 1 }
        i = i + 1
    }
    返回 0
}

// 转义序列处理

函数 字符串_解析转义(源, 位置) {
    // 从位置开始解析转义字符
    如果 (位置 >= 计数(源)) { 返回 [0, 0] }
    定义 c = 编码(子串(源, 位置, 1))
    如果 (c == 标记_定义) { 返回 [10, 1] }   // \n -> 换行
    如果 (c == 标记_当) { 返回 [9, 1] }    // \t -> 制表
    如果 (c == 标记_如果) { 返回 [13, 1] }   // \r -> 回车
    如果 (c == 标记_左花) { 返回 [92, 1] }    // \\ -> 反斜杠
    如果 (c == 标记_余) { 返回 [34, 1] }    // \" -> 双引号
    如果 (c == 39) { 返回 [39, 1] }    // \' -> 单引号
    如果 (c == 48) { 返回 [0, 1] }     // \0 -> 空字符
    // \x 十六进制
    如果 (c == 标记_建) {
        定义 可变 值 = 0
        定义 可变 i = 0
        当 (i < 2 且 位置 + 1 + i < 计数(源)) {
            定义 h = 编码(子串(源, 位置 + 1 + i, 1))
            如果 (h >= 字符_零 且 h <= 字符_九) { 值 = 值 * 16 + h - 字符_零 }
            否则 如果 (h >= 字符_小写a 且 h <= 字符_小写f) { 值 = 值 * 16 + h - 87 }
            否则 如果 (h >= 字符_大写A 且 h <= 字符_大写F) { 值 = 值 * 16 + h - 55 }
            i = i + 1
        }
        返回 [值, 3]
    }
    // \u Unicode
    如果 (c == 标记_循环) {
        定义 可变 值 = 0
        定义 可变 i = 0
        当 (i < 4 且 位置 + 1 + i < 计数(源)) {
            定义 h = 编码(子串(源, 位置 + 1 + i, 1))
            如果 (h >= 字符_零 且 h <= 字符_九) { 值 = 值 * 16 + h - 字符_零 }
            否则 如果 (h >= 字符_小写a 且 h <= 字符_小写f) { 值 = 值 * 16 + h - 87 }
            否则 如果 (h >= 字符_大写A 且 h <= 字符_大写F) { 值 = 值 * 16 + h - 55 }
            i = i + 1
        }
        返回 [值, 5]
    }
    返回 [c, 1]
}

函数 字符串_处理转义(源) {
    定义 可变 结果 = []
    定义 可变 i = 0
    定义 长 = 计数(源)
    当 (i < 长) {
        定义 c = 编码(子串(源, i, 1))
        如果 (c == 标记_左花 且 i + 1 < 长) {
            定义 转义 = 字符串_解析转义(源, i + 1)
            追加(结果, 转义[0])
            i = i + 1 + 转义[1]
        } 否则 {
            追加(结果, c)
            i = i + 1
        }
    }
    返回 结果
}

// 字符串字面量扫描

函数 字符串_扫描双引号(源, 起始) {
    _字串_扫描次数 = _字串_扫描次数 + 1
    定义 可变 内容 = []
    定义 可变 i = 起始
    定义 长 = 计数(源)
    当 (i < 长) {
        定义 c = 编码(子串(源, i, 1))
        如果 (c == 标记_余) { 返回 [内容, i + 1, 真] }  // 结束引号
        如果 (c == 标记_左花 且 i + 1 < 长) {
            定义 转义 = 字符串_解析转义(源, i + 1)
            追加(内容, 转义[0])
            i = i + 1 + 转义[1]
        } 否则 {
            追加(内容, c)
            i = i + 1
        }
    }
    返回 [内容, i, 假]  // 未终止
}

函数 字符串_扫描单引号(源, 起始) {
    定义 可变 内容 = []
    定义 可变 i = 起始
    定义 长 = 计数(源)
    当 (i < 长) {
        定义 c = 编码(子串(源, i, 1))
        如果 (c == 39) { 返回 [内容, i + 1, 真] }
        如果 (c == 标记_左花 且 i + 1 < 长) {
            定义 转义 = 字符串_解析转义(源, i + 1)
            追加(内容, 转义[0])
            i = i + 1 + 转义[1]
        } 否则 {
            追加(内容, c)
            i = i + 1
        }
    }
    返回 [内容, i, 假]
}

// 原始字符串

函数 字符串_扫描原始(源, 起始, 结束符) {
    // 原始字符串不处理转义
    定义 可变 内容 = []
    定义 可变 i = 起始
    定义 长 = 计数(源)
    当 (i < 长) {
        定义 c = 编码(子串(源, i, 1))
        如果 (c == 结束符) { 返回 [内容, i + 1, 真] }
        追加(内容, c)
        i = i + 1
    }
    返回 [内容, i, 假]
}

// 模板字符串

函数 字符串_扫描模板(源, 起始) {
    // 模板字符串: `...${expr}...`
    定义 可变 片段 = []
    定义 可变 当前片 = []
    定义 可变 i = 起始
    定义 长 = 计数(源)
    当 (i < 长) {
        定义 c = 编码(子串(源, i, 1))
        如果 (c == 标记_逗号) {  // 反引号结束
            追加(片段, [0, 当前片])  // 0=文本
            返回 [片段, i + 1, 真]
        }
        如果 (c == 36 且 i + 1 < 长 且 编码(子串(源, i+1, 1)) == 字符_左花括) {
            // ${ 开始插值
            追加(片段, [0, 当前片])
            当前片 = []
            i = i + 2
            // 扫描到 }
            定义 可变 深度 = 1
            定义 可变 表达式 = []
            当 (i < 长 且 深度 > 0) {
                定义 ec = 编码(子串(源, i, 1))
                如果 (ec == 标记_中断) { 深度 = 深度 + 1 }
                如果 (ec == 标记_真) { 深度 = 深度 - 1 }
                如果 (深度 > 0) { 追加(表达式, ec) }
                i = i + 1
            }
            追加(片段, [1, 表达式])  // 1=插值
        } 否则 {
            追加(当前片, c)
            i = i + 1
        }
    }
    追加(片段, [0, 当前片])
    返回 [片段, i, 假]
}

// 多行字符串

函数 字符串_扫描多行(源, 起始, 结束标记) {
    定义 可变 内容 = []
    定义 可变 行数 = 1
    定义 可变 i = 起始
    定义 长 = 计数(源)
    定义 标记长 = 计数(结束标记)
    当 (i < 长) {
        // 检查结束标记
        定义 可变 _匹配项 = 真
        定义 可变 j = 0
        当 (j < 标记长 且 i + j < 长) {
            如果 (编码(子串(源, i + j, 1)) != 编码(子串(结束标记, j, 1))) { _匹配项 = 假 }
            j = j + 1
        }
        如果 (_匹配项 且 j == 标记长) { 返回 [内容, i + 标记长, 行数, 真] }
        定义 c = 编码(子串(源, i, 1))
        如果 (c == 10) { 行数 = 行数 + 1 }
        追加(内容, c)
        i = i + 1
    }
    返回 [内容, i, 行数, 假]
}

// 字符串工具

函数 字符串_计算长度(编码列表) { 返回 计数(编码列表) }

函数 字符串扫_字符串_连接(a, b) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(a)) { 追加(结果, a[i])  i = i + 1 }
    i = 0
    当 (i < 计数(b)) { 追加(结果, b[i])  i = i + 1 }
    返回 结果
}

函数 字符串_比较(a, b) {
    定义 可变 最小长 = 计数(a)
    如果 (计数(b) < 最小长) { 最小长 = 计数(b) }
    定义 可变 i = 0
    当 (i < 最小长) {
        如果 (a[i] < b[i]) { 返回 -1 }
        如果 (a[i] > b[i]) { 返回 1 }
        i = i + 1
    }
    如果 (计数(a) < 计数(b)) { 返回 -1 }
    如果 (计数(a) > 计数(b)) { 返回 1 }
    返回 0
}

函数 字符串扫_字符串_包含(主串, 子串码) {
    定义 主长 = 计数(主串)
    定义 子长 = 计数(子串码)
    如果 (子长 > 主长) { 返回 假 }
    定义 可变 i = 0
    当 (i <= 主长 - 子长) {
        定义 可变 _匹配项 = 真
        定义 可变 j = 0
        当 (j < 子长) {
            如果 (主串[i + j] != 子串码[j]) { _匹配项 = 假 }
            j = j + 1
        }
        如果 (_匹配项) { 返回 真 }
        i = i + 1
    }
    返回 假
}

定义 可变 _字串_转义次数 = 0
定义 可变 _字串_未终止数 = 0

函数 字符串_记录扫描() { _字串_扫描次数 = _字串_扫描次数 + 1 }
函数 字符串_记录转义() { _字串_转义次数 = _字串_转义次数 + 1 }
函数 字符串_记录未终止() { _字串_未终止数 = _字串_未终止数 + 1 }


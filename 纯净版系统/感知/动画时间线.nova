// §4 动画时间线 + 全局动画管理器
// (对应 AnimationTimeline + DocumentAnimations)

定义 可变 全局动画列表 = 0
定义 可变 全局动画数量 = 0
定义 可变 全局动画容量 = 0


函数 AnimationTimeline_初始化() {
    如果 (全局动画列表 != 0) { 返回 }
    全局动画容量 = 128
    全局动画列表 = 堆_分配_数组(全局动画容量 * 8)
    全局动画数量 = 0
}

函数 AnimationTimeline_注册(anim) {
    如果 (全局动画列表 == 0) { AnimationTimeline_初始化() }
    如果 (全局动画数量 >= 全局动画容量) { 返回 }
    内存_写64(全局动画列表 + 全局动画数量 * 8, anim)
    全局动画数量 = 全局动画数量 + 1
}

函数 AnimationTimeline_每帧更新() {
    // 在每帧的rAF之前调用
    如果 (全局动画列表 == 0) { 返回 }

    定义 可变 i = 0
    当 (i < 全局动画数量) {
        定义 anim = 内存_读64(全局动画列表 + i * 8)
        如果 (anim == 0 || anim.状态 != 动画状态_播放中) {
            i = i + 1
            继续
        }

        定义 ke = anim.效果
        如果 (ke == 0) { i = i + 1; 继续 }

        // 计算当前时间(含延迟)
        定义 当前时间 = Animation_计算当前时间(anim) - ke.延迟
        如果 (当前时间 < 0) {
            // 还在延迟中
            如果 (ke.填充模式 == 2 || ke.填充模式 == 3) {
                // backwards fill: 应用第一帧
                AnimationFrame_应用(ke, 0)
            }
            i = i + 1
            继续
        }

        // 计算迭代进度
        定义 可变 总时长 = ke.持续时间
        如果 (总时长 <= 0) { 总时长 = 1 }

        定义 可变 迭代 = 当前时间 / 总时长
        定义 可变 进度 = (当前时间 % 总时长) * 10000 / 总时长

        // 检查是否完成
        定义 可变 最大迭代 = ke.迭代次数 / 100
        如果 (ke.迭代次数 < 0) { 最大迭代 = 999999 }    // infinite

        如果 (迭代 >= 最大迭代) {
            // 动画完成
            如果 (ke.填充模式 == 1 || ke.填充模式 == 3) {
                // forwards fill: 保持最后一帧
                AnimationFrame_应用(ke, 10000)
            }
            anim.状态 = 动画状态_完成
            // 触发finish事件
            i = i + 1
            继续
        }

        // 方向处理
        如果 (ke.方向 == 1) {
            // reverse
            进度 = 10000 - 进度
        } 否则 如果 (ke.方向 == 2) {
            // alternate
            如果 (迭代 % 2 == 1) { 进度 = 10000 - 进度 }
        } 否则 如果 (ke.方向 == 3) {
            // alternate-reverse
            如果 (迭代 % 2 == 0) { 进度 = 10000 - 进度 }
        }

        // 应用缓动
        如果 (ke.缓动 != 0) {
            进度 = TimingFunction_求值(ke.缓动, 进度)
        }

        // 应用关键帧插值
        AnimationFrame_应用(ke, 进度)

        // 标记目标元素需要重绘
        如果 (ke.目标元素 != 0) {
            ke.目标元素.节点标志 = ke.目标元素.节点标志 | 节点标志_样式脏
        }

        i = i + 1
    }

    // 清理已完成的动画
    AnimationTimeline_清理完成()
}

函数 AnimationTimeline_清理完成() {
    定义 可变 w = 0
    定义 可变 i = 0
    当 (i < 全局动画数量) {
        定义 anim = 内存_读64(全局动画列表 + i * 8)
        如果 (anim != 0 && anim.状态 != 动画状态_完成) {
            内存_写64(全局动画列表 + w * 8, anim)
            w = w + 1
        }
        i = i + 1
    }
    全局动画数量 = w
}

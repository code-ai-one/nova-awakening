导入("../基础.nova")


// 内部辅助: 基于编码的字符匹配
函数 是斜杠码(码) { 返回 码 == 字符_斜杠 或 码 == 字符_反斜杠 }
函数 是点码(码) { 返回 码 == 字符_句点 }
函数 是冒号码(码) { 返回 码 == 字符_冒号 }
函数 是空白码(码) { 返回 码 == 字符_空格 或 码 == 字符_制表 或 码 == 字符_换行 或 码 == 字符_回车 }

// 路径操作
函数 路径_连接(a, b) {
    如果 (计数(a) == 0) { 返回 b }
    如果 (计数(b) == 0) { 返回 a }
    定义 尾码 = 字符码(a, 计数(a) - 1)
    如果 (是斜杠码(尾码)) { 返回 a + b }
    返回 a + "/" + b
}

函数 IO_路径_扩展名(路径) {
    定义 可变 最后点 = -1
    定义 可变 i = 0
    当 (i < 计数(路径)) {
        如果 (是点码(字符码(路径, i))) { 最后点 = i }
        i = i + 1
    }
    如果 (最后点 < 0) { 返回 "" }
    返回 子串(路径, 最后点, 计数(路径) - 最后点)
}

函数 IO_路径_文件名(路径) {
    定义 可变 最后斜杠 = -1
    定义 可变 i = 0
    当 (i < 计数(路径)) {
        如果 (是斜杠码(字符码(路径, i))) { 最后斜杠 = i }
        i = i + 1
    }
    如果 (最后斜杠 < 0) { 返回 路径 }
    返回 子串(路径, 最后斜杠 + 1, 计数(路径) - 最后斜杠 - 1)
}

函数 IO_路径_目录(路径) {
    定义 可变 最后斜杠 = -1
    定义 可变 i = 0
    当 (i < 计数(路径)) {
        如果 (是斜杠码(字符码(路径, i))) { 最后斜杠 = i }
        i = i + 1
    }
    如果 (最后斜杠 < 0) { 返回 "." }
    如果 (最后斜杠 == 0) { 返回 "/" }
    返回 子串(路径, 0, 最后斜杠)
}

函数 路径_无扩展名(路径) {
    定义 fn = IO_路径_文件名(路径)
    定义 可变 首点 = -1
    定义 可变 i = 0
    当 (i < 计数(fn)) {
        如果 (是点码(字符码(fn, i)) 且 首点 < 0) { 首点 = i }
        i = i + 1
    }
    如果 (首点 < 0) { 返回 fn }
    返回 子串(fn, 0, 首点)
}

函数 IO_路径_是绝对(路径) {
    如果 (计数(路径) == 0) { 返回 假 }
    如果 (是斜杠码(字符码(路径, 0))) { 返回 真 }
    如果 (计数(路径) >= 3 且 是冒号码(字符码(路径, 1))) { 返回 真 }
    返回 假
}

// StringBuilder
函数 IO_构建器_创建() { 返回 [[]] }
函数 构建器_写(b, 文本) { 追加(b[0], 文本) }
函数 构建器_写行(b, 文本) { 追加(b[0], 文本)
追加(b[0], "\n") }
函数 IO_构建器_构建(b) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(b[0])) {
        结果 = 结果 + b[0][i]
        i = i + 1
    }
    返回 结果
}
函数 构建器_大小(b) { 返回 计数(b[0]) }
函数 构建器_清空(b) { b[0] = [] }

// 文本行处理 (纯手动分割, 不依赖分割内建)
函数 文本_分行(文本) {
    定义 可变 结果 = []
    定义 可变 当前 = ""
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        定义 码 = 字符码(文本, i)
        如果 (码 == 字符_换行) {
            追加(结果, 当前)
            当前 = ""
        } 否则 {
            当前 = (当前 + 子串(文本, i, 1))
        }
        i = i + 1
    }
    追加(结果, 当前)
    返回 结果
}

函数 文本_行数(文本) {
    如果 (计数(文本) == 0) { 返回 0 }
    返回 计数(文本_分行(文本))
}

函数 文本_行(文本, 行号) {
    定义 行列表 = 文本_分行(文本)
    如果 (行号 >= 0 且 行号 < 计数(行列表)) { 返回 行列表[行号] }
    返回 ""
}

// 格式化
函数 格式_填充左(文本, 宽度, 填充字符) {
    定义 可变 结果 = 文本
    当 (计数(结果) < 宽度) { 结果 = 填充字符 + 结果 }
    返回 结果
}

函数 格式_填充右(文本, 宽度, 填充字符) {
    定义 可变 结果 = 文本
    当 (计数(结果) < 宽度) { 结果 = 结果 + 填充字符 }
    返回 结果
}

函数 IO_格式_十六进制(n) {
    如果 (n == 0) { 返回 "0" }
    定义 hex_chars = "0123456789abcdef"
    定义 可变 结果 = ""
    定义 可变 v = n
    如果 (v < 0) { v = 0 - v }
    当 (v != 0) {
        定义 d = v % 16
        结果 = (子串(hex_chars, d, 1) + 结果)
        v = v / 16
    }
    如果 (n < 0) { 结果 = "-" + 结果 }
    返回 结果
}

函数 IO_格式_二进制(n) {
    如果 (n == 0) { 返回 "0" }
    定义 可变 结果 = ""
    定义 可变 v = n
    如果 (v < 0) { v = 0 - v }
    当 (v != 0) {
        如果 (v % 2 == 1) { 结果 = "1" + 结果 }
        否则 { 结果 = "0" + 结果 }
        v = v / 2
    }
    如果 (n < 0) { 结果 = "-" + 结果 }
    返回 结果
}

函数 IO_格式_八进制(n) {
    如果 (n == 0) { 返回 "0" }
    定义 oct_chars = "01234567"
    定义 可变 结果 = ""
    定义 可变 v = n
    如果 (v < 0) { v = 0 - v }
    当 (v != 0) {
        结果 = (子串(oct_chars, v % 8, 1) + 结果)
        v = v / 8
    }
    如果 (n < 0) { 结果 = "-" + 结果 }
    返回 结果
}

// CSV解析 (基于文本_分行)
函数 CSV_分割字段(行, 分隔码) {
    定义 可变 结果 = []
    定义 可变 当前 = ""
    定义 可变 i = 0
    当 (i < 计数(行)) {
        如果 (字符码(行, i) == 分隔码) {
            追加(结果, 当前)
            当前 = ""
        } 否则 {
            当前 = (当前 + 子串(行, i, 1))
        }
        i = i + 1
    }
    追加(结果, 当前)
    返回 结果
}

// CSV行数统计
函数 CSV_行数(文本) {
    返回 文本_行数(文本)
}

函数 CSV_解析(文本, 分隔符) {
    定义 分隔码 = 编码(子串(分隔符, 0, 1))
    定义 行列表 = 文本_分行(文本)
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(行列表)) {
        如果 (计数(行列表[i]) != 0) {
            追加(结果, CSV_分割字段(行列表[i], 分隔码))
        }
        i = i + 1
    }
    返回 结果
}

// 缓冲IO
函数 缓冲读取器_创建(数据, 缓冲大小) {
    返回 [数据, 0, 缓冲大小, 计数(数据)]
}

函数 缓冲读取器_读行(读取器) {
    _IO_读次数 = _IO_读次数 + 1
    定义 可变 行 = ""
    当 (读取器[1] < 读取器[3]) {
        定义 c = 读取器[0][读取器[1]]
        读取器[1] = 读取器[1] + 1
        如果 (c == 字符_换行) { 返回 行 }
        如果 (c != 字符_回车) { 行 = 行 + c }
    }
    如果 (计数(行) > 0) { 返回 行 }
    返回 空
}

函数 缓冲读取器_读字节(读取器) {
    _IO_读次数 = _IO_读次数 + 1
    如果 (读取器[1] >= 读取器[3]) { 返回 -1 }
    定义 b = 读取器[0][读取器[1]]
    读取器[1] = 读取器[1] + 1
    返回 b
}

函数 缓冲读取器_剩余(读取器) { 返回 读取器[3] - 读取器[1] }
函数 缓冲读取器_已结束(读取器) { 返回 读取器[1] >= 读取器[3] }
函数 缓冲读取器_位置(读取器) { 返回 读取器[1] }

// 二进制读写
函数 二进制_读16LE(数据, 偏移) {
    _IO_读次数 = _IO_读次数 + 1
    返回 数据[偏移] | (数据[偏移 + 1] << 8)
}

函数 二进制_读32LE(数据, 偏移) {
    _IO_读次数 = _IO_读次数 + 1
    返回 数据[偏移] | (数据[偏移 + 1] << 8) | (数据[偏移 + 2] << 16) | (数据[偏移 + 3] << 24)
}

函数 二进制_写16LE(缓冲, 偏移, 值) {
    _IO_写次数 = _IO_写次数 + 1
    缓冲[偏移] = 值 & 0xFF
    缓冲[偏移 + 1] = (值 >> 8) & 0xFF
}

函数 二进制_写32LE(缓冲, 偏移, 值) {
    _IO_写次数 = _IO_写次数 + 1
    缓冲[偏移] = 值 & 0xFF
    缓冲[偏移 + 1] = (值 >> 8) & 0xFF
    缓冲[偏移 + 2] = (值 >> 16) & 0xFF
    缓冲[偏移 + 3] = (值 >> 24) & 0xFF
}

// 字节缓冲区
函数 字节缓冲_创建(容量) {
    定义 可变 数据 = []
    定义 可变 i = 0
    当 (i < 容量) { 追加(数据, 0) i = i + 1 }
    返回 [数据, 0, 容量]
}

函数 字节缓冲_写字节(缓冲, 值) {
    _IO_写次数 = _IO_写次数 + 1
    如果 (缓冲[1] >= 缓冲[2]) { 返回 假 }
    缓冲[0][缓冲[1]] = 值 & 0xFF
    缓冲[1] = 缓冲[1] + 1
    返回 真
}

函数 字节缓冲_写32(缓冲, 值) {
    字节缓冲_写字节(缓冲, 值 & 0xFF)
    字节缓冲_写字节(缓冲, (值 >> 8) & 0xFF)
    字节缓冲_写字节(缓冲, (值 >> 16) & 0xFF)
    字节缓冲_写字节(缓冲, (值 >> 24) & 0xFF)
}

函数 字节缓冲_大小(缓冲) { 返回 缓冲[1] }
函数 字节缓冲_数据(缓冲) { 返回 缓冲[0] }
函数 字节缓冲_清空(缓冲) { 缓冲[1] = 0 }

定义 可变 _IO_读次数 = 0
定义 可变 _IO_写次数 = 0

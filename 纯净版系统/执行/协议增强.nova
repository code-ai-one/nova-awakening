    html = 字符串拼接(html, "<p>把系统主壳从介绍页升级为真正的操作前台，保留统一语义与可扩展协议入口。</p>")
    html = 字符串拼接(html, 壳层_HTML_命令甲板())
    html = 字符串拼接(html, "</div>")
    返回 html
}

// §12 协议响应页面工厂

函数 协议_生成标题(类型) {
    如果 (类型 == 协议类型_系统) { 返回 "系统总控" }
    如果 (类型 == 协议类型_AI) { 返回 "AI 工作台" }
    如果 (类型 == 协议类型_多模态) { 返回 "多模态中枢" }
    如果 (类型 == 协议类型_语音) { 返回 "语音中枢" }
    如果 (类型 == 协议类型_形象) { 返回 "全息形象中枢" }
    如果 (类型 == 协议类型_诊断) { 返回 "诊断中心" }
    如果 (类型 == 协议类型_设置) { 返回 "系统设置" }
    如果 (类型 == 协议类型_工作流) { 返回 "工作流编排" }
    返回 "NovaOS Browser-终端"
}

函数 协议_生成描述(类型) {
    如果 (类型 == 协议类型_系统) { 返回 "内核、图形、设备总线统一观测与控制。" }
    如果 (类型 == 协议类型_AI) { 返回 "智能体、推理、策略编排与模型管理。" }
    如果 (类型 == 协议类型_多模态) { 返回 "视觉、听觉、触觉信号融合处理。" }
    如果 (类型 == 协议类型_语音) { 返回 "语音识别、合成与对话管理。" }
    如果 (类型 == 协议类型_形象) { 返回 "全息形象调度、动作与情感状态驱动。" }
    如果 (类型 == 协议类型_诊断) { 返回 "故障溯源、修复建议与健康评分。" }
    如果 (类型 == 协议类型_设置) { 返回 "主题、权限、网络与系统策略配置。" }
    如果 (类型 == 协议类型_工作流) { 返回 "任务流设计、编排、回放与审计。" }
    返回 "统一入口，统一语义，统一体验。"
}

函数 协议_生成页面HTML(req, ctx, 决策) {
    定义 可变 html = ""
    html = 字符串拼接(html, "<!doctype html><html><head><meta charset='utf-8'>")
    html = 字符串拼接(html, "<meta name='viewport' content='width=device-width,initial-scale=1'>")
    html = 字符串拼接(html, "<title>")
    html = 字符串拼接(html, 协议_生成标题(req.类型))
    html = 字符串拼接(html, "</title><style>")
    html = 字符串拼接(html, 壳层_CSS_生成(ctx))
    html = 字符串拼接(html, "</style></head><body>")
    html = 字符串拼接(html, "<main class='nova-shell'><section class='nova-stack'>")
    html = 字符串拼接(html, "<header class='nova-hero'>")
    html = 字符串拼接(html, "<div class='nova-eyebrow'>NOVAOS / INTERNAL PROTOCOL</div>")
    html = 字符串拼接(html, "<h1 class='nova-title'>")
    html = 字符串拼接(html, 协议_生成标题(req.类型))
    html = 字符串拼接(html, "</h1>")
    html = 字符串拼接(html, "<p class='nova-lead'>")
    html = 字符串拼接(html, 协议_生成描述(req.类型))
    html = 字符串拼接(html, "</p>")
    html = 字符串拼接(html, 壳层_HTML_头部标签())
    html = 字符串拼接(html, 壳层_HTML_导航())
    html = 字符串拼接(html, "</header>")
    html = 字符串拼接(html, 壳层_HTML_主内容())
    html = 字符串拼接(html, "<footer class='nova-footer'>")
    html = 字符串拼接(html, "route=")
    html = 字符串拼接(html, 决策.命中模块)
    html = 字符串拼接(html, " · risk=")
    html = 字符串拼接(html, 整数转字符串(决策.风险评分))
    html = 字符串拼接(html, " · confidence=")
    html = 字符串拼接(html, 整数转字符串(决策.置信度))
    html = 字符串拼接(html, " · reduce-motion=")
    html = 字符串拼接(html, 布尔转文本(ctx.减少动态))
    html = 字符串拼接(html, "</footer>")
    html = 字符串拼接(html, "</section></main></body></html>")
    返回 html
}

// §13 对外接口: 视觉CSS与头部片段
// 兼容旧调用名

函数 浏览器网络_生成页面增强CSS_新版() {
    定义 ctx = 壳层视觉上下文_默认()
    返回 壳层_CSS_生成(ctx)
}

函数 浏览器网络_生成页面头部标签HTML_新版() {
    返回 壳层_HTML_头部标签()
}

函数 浏览器网络_生成主壳增强内容HTML_新版() {
    返回 壳层_HTML_主内容()
}

// §14 对外接口: 协议处理主入口

函数 浏览器网络_处理内部协议_标记5(url) {
    壳层埋点_记录("protocol.recv", 字符串长度(url), 0, "entry")

    定义 req = 协议_拆分URL(url)
    定义 ctx = 壳层视觉上下文_默认()
    定义 决策 = 协议_路由决策(req, 全局_默认策略)

    如果 (!决策.是否命中) {
        壳层埋点_记录("protocol.reject", 决策.风险评分, 决策.置信度, 决策.命中模块)
        定义 failHtml = 协议_生成安全阻断页(req, 决策)
        返回 failHtml
    }

    壳层埋点_记录("protocol.route", req.类型, 决策.风险评分, 决策.命中模块)
    定义 html = 协议_生成页面HTML(req, ctx, 决策)
    壳层埋点_记录("protocol.ok", 字符串长度(html), req.参数数, "rendered")
    返回 html
}

函数 协议_生成安全阻断页(req, 决策) {
    定义 ctx = 壳层视觉上下文_默认()
    ctx.主题 = 壳层主题_高对比
    ctx.减少动态 = 真
    定义 可变 html = ""
    html = 字符串拼接(html, "<!doctype html><html><head><meta charset='utf-8'><style>")
    html = 字符串拼接(html, 壳层_CSS_生成(ctx))
    html = 字符串拼接(html, "</style></head><body><main class='nova-shell'><section class='nova-stack'>")
    html = 字符串拼接(html, "<div class='nova-panel'><h2>访问已阻断</h2>")
    html = 字符串拼接(html, "<p>该内部协议请求被安全策略拦截。请检查参数与路径规范。</p>")
    html = 字符串拼接(html, "<div class='nova-kv'><div class='nova-k'>风险评分</div><div class='nova-v nova-status-err'>")
    html = 字符串拼接(html, 整数转字符串(决策.风险评分))
    html = 字符串拼接(html, "</div></div>")
    html = 字符串拼接(html, "<div class='nova-kv'><div class='nova-k'>回退模块</div><div class='nova-v'>")
    html = 字符串拼接(html, 决策.回退模块)
    html = 字符串拼接(html, "</div></div>")
    html = 字符串拼接(html, "<div class='nova-divider'></div>")
    html = 字符串拼接(html, "<a class='nova-link' href='nova://system'>返回系统总控</a>")
    html = 字符串拼接(html, "</div></section></main></body></html>")
    返回 html
}

// §15 AI增强入口

函数 浏览器网络_处理内部协议_标记5_AI(url, 用户画像文本, 会话长度, 任务复杂度, 设备负载, 用户偏好) {
    壳层埋点_记录("protocol.ai.recv", 会话长度, 任务复杂度, "ai-entry")

    定义 req = 协议_拆分URL(url)
    定义 ctx = 壳层_AI_生成上下文(用户画像文本, 会话长度, 任务复杂度, 设备负载, 用户偏好)
    定义 决策 = 协议_路由决策(req, 全局_默认策略)

    如果 (!决策.是否命中) {
        壳层埋点_记录("protocol.ai.reject", 决策.风险评分, 决策.置信度, "reject")
        返回 协议_生成安全阻断页(req, 决策)
    }

    定义 html = 协议_生成页面HTML(req, ctx, 决策)
    壳层埋点_记录("protocol.ai.ok", ctx.主题, ctx.密度, "ok")
    返回 html
}

// §16 策略控制

函数 浏览器网络_设置路由策略(策略) {
    如果 (策略 != 路由策略_严格 && 策略 != 路由策略_兼容 && 策略 != 路由策略_实验) {
        返回 失败
    }
    全局_默认策略 = 策略
    壳层埋点_记录("policy.route", 策略, 0, "set")
    返回 成功
}

函数 浏览器网络_获取路由策略() {
    返回 全局_默认策略
}

函数 浏览器网络_导出埋点JSON() {
    返回 壳层埋点_导出JSON()
}


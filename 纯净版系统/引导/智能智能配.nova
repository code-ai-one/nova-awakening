导入("../中枢/整数转字符串.nova")
导入("./安装流程编.nova")

// §3 AI智能配置

函数 安装_AI智能配置() {
    安装.阶段消息 = "AI正在分析最优配置..."
    安装.阶段进度 = 0
    安装_日志("═══ AI智能配置 ═══")

    // 内存分配策略
    如果 (安装.内存_总MB >= 16384) {
        // 16GB+: 充裕, AI可以吃多一点
        安装.推荐_内存分配 = 安装.内存_总MB * 25 / 100   // 25%给内核
        安装.推荐_交换分区 = 安装.内存_总MB / 2           // 50%交换
        安装.推荐_AI模型 = "本地58B-Q4量化 (推荐)"
        安装.安装AI模型 = 真
    } 否则如果 (安装.内存_总MB >= 8192) {
        // 8-16GB: 紧凑但可用
        安装.推荐_内存分配 = 安装.内存_总MB * 20 / 100
        安装.推荐_交换分区 = 安装.内存_总MB
        安装.推荐_AI模型 = "本地7B-Q8量化 (适中)"
        安装.安装AI模型 = 真
    } 否则如果 (安装.内存_总MB >= 4096) {
        // 4-8GB: 最小
        安装.推荐_内存分配 = 安装.内存_总MB * 15 / 100
        安装.推荐_交换分区 = 安装.内存_总MB * 2
        安装.推荐_AI模型 = "纯云端模式 (本地内存不足)"
        安装.安装AI模型 = 假
    } 否则 {
        // <4GB: 警告
        安装.推荐_内存分配 = 512
        安装.推荐_交换分区 = 安装.内存_总MB * 4
        安装.推荐_AI模型 = "纯云端 (内存严重不足)"
        安装.安装AI模型 = 假
        安装.警告数 = 安装.警告数 + 1
        安装_日志("⚠ 内存不足4GB, AI功能将严重受限")
    }
    安装.阶段进度 = 300

    // 分辨率推荐
    如果 (安装.图处_显存MB >= 256) {
        安装.推荐_分辨率 = "3840x2160 (4K)"
    } 否则如果 (安装.图处_显存MB >= 64) {
        安装.推荐_分辨率 = "1920x1080 (1080p)"
    } 否则 {
        安装.推荐_分辨率 = "1280x720 (720p)"
    }
    安装.阶段进度 = 500

    // 选择最大磁盘作为目标
    定义 可变 最大磁盘 = 0
    定义 可变 最大大小 = 0
    定义 可变 i = 0
    当 (i < 计数(安装.磁盘列表)) {
        如果 (安装.磁盘列表[i].大小MB > 最大大小) {
            最大大小 = 安装.磁盘列表[i].大小MB
            最大磁盘 = i
        }
        i = i + 1
    }
    安装.目标磁盘 = 最大磁盘
    安装.阶段进度 = 700

    安装_日志("AI推荐配置:")
    安装_日志("  内核内存: " + 整数转字符串(安装.推荐_内存分配) + " MB")
    安装_日志("  交换分区: " + 整数转字符串(安装.推荐_交换分区) + " MB")
    安装_日志("  AI模型: " + 安装.推荐_AI模型)
    安装_日志("  分辨率: " + 安装.推荐_分辨率)
    如果 (计数(安装.磁盘列表) > 0) {
        安装_日志("  目标磁盘: [" + 整数转字符串(最大磁盘) + "] " +
                 安装.磁盘列表[最大磁盘].名称)
    }

    安装.阶段进度 = 1000
    安装.阶段消息 = "AI配置完成, 等待确认"
}

// §4 磁盘分区

外部 磁盘_读取分区表
外部 磁盘_创建Nova语言模型
外部 磁盘_添加分区
外部 磁盘_格式化

函数 安装_自动分区() {
    安装.阶段消息 = "正在分区..."
    安装.阶段进度 = 0
    如果 (计数(安装.磁盘列表) == 0) {
        安装_日志("✗ 无可用磁盘!")
        安装.错误数 = 安装.错误数 + 1
        返回 假
    }

    定义 磁盘 = 安装.磁盘列表[安装.目标磁盘]
    定义 总MB = 磁盘.大小MB
    安装_日志("自动分区: " + 磁盘.名称 + " (" + 整数转字符串(总MB) + "MB)")

    // Nova语言模型分区表
    磁盘_创建Nova语言模型(安装.目标磁盘)
    安装.阶段进度 = 100

    // 分区方案:
    // 1. EFI系统分区 (ESP): 512MB, FAT32
    // 2. 根分区 (/): 剩余空间 - swap, NovaFS/ext4
    // 3. 交换分区 (swap): AI推荐大小
    定义 ESP大小 = 512
    定义 交换大小 = 安装.推荐_交换分区
    如果 (交换大小 > 总MB / 4) { 交换大小 = 总MB / 4 }  // 最多25%
    定义 根大小 = 总MB - ESP大小 - 交换大小

    磁盘_添加分区(安装.目标磁盘, "EFI System", ESP大小, "fat32")
    安装.阶段进度 = 300
    安装_日志("  分区1: EFI " + 整数转字符串(ESP大小) + "MB FAT32")

    磁盘_添加分区(安装.目标磁盘, "NovaOS Root", 根大小, "ext4")
    安装.阶段进度 = 600
    安装_日志("  分区2: / " + 整数转字符串(根大小) + "MB ext4")

    磁盘_添加分区(安装.目标磁盘, "Swap", 交换大小, "swap")
    安装.阶段进度 = 800
    安装_日志("  分区3: swap " + 整数转字符串(交换大小) + "MB")

    // 格式化
    磁盘_格式化(安装.目标磁盘, 0, "fat32")
    磁盘_格式化(安装.目标磁盘, 1, "ext4")
    磁盘_格式化(安装.目标磁盘, 2, "swap")

    安装.阶段进度 = 1000
    安装.阶段消息 = "分区完成"
    安装_日志("分区完成 ✓")
    返回 真
}

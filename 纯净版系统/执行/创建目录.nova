导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../标准/文件.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内核打印.nova")
导入("../标准/原生字符串.nova")

定义 MKDIR_递归 = 0x01
定义 MKDIR_详细 = 0x02
定义 MKDIR_上下文 = 0x04

结构 mkdir_统计 {
    创建数,
    跳过数,
    错误数,
}

函数 mkdir_main(参数) {
    定义 可变 选项 = 0
    定义 可变 权限 = 0o755
    定义 可变 目录列表 = []
    定义 可变 安全上下文 = ""

    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 a = 参数[i]
        如果 (a == "-p" || a == "--parents") { 选项 = 选项 | MKDIR_递归 }
        否则 如果 (a == "-v" || a == "--verbose") { 选项 = 选项 | MKDIR_详细 }
        否则 如果 (a == "-m" || a == "--mode") {
            如果 (i + 1 < 计数(参数)) {
                i = i + 1
                权限 = mkdir_解析权限(参数[i])
            } 否则 {
                打印行("mkdir: 选项 '-m' 需要参数")
                返回 1
            }
        } 否则 如果 (字符串开头是(a, "--mode=")) {
            权限 = mkdir_解析权限(字符串子串(a, 7, 字符串长度(a)))
        } 否则 如果 (a == "-Z" || a == "--context") {
            选项 = 选项 | MKDIR_上下文
            如果 (i + 1 < 计数(参数) && !字符串开头是(参数[i + 1], "-")) {
                i = i + 1
                安全上下文 = 参数[i]
            }
        } 否则 如果 (a == "--help") { mkdir_帮助(); 返回 0 }
        否则 如果 (a == "--version") { 打印行("mkdir (NovaOS) 1.0"); 返回 0 }
        否则 如果 (a == "--") { i = i + 1; 跳出 }
        否则 如果 (字符串开头是(a, "-") && 字符串长度(a) > 1) {
            定义 可变 j = 1
            当 (j < 字符串长度(a)) {
                定义 c = 字符串取字符(a, j)
                如果 (c == "p") { 选项 = 选项 | MKDIR_递归 }
                否则 如果 (c == "v") { 选项 = 选项 | MKDIR_详细 }
                否则 如果 (c == "Z") { 选项 = 选项 | MKDIR_上下文 }
                否则 如果 (c == "m") {
                    如果 (j + 1 < 字符串长度(a)) {
                        权限 = mkdir_解析权限(字符串子串(a, j + 1, 字符串长度(a)))
                        跳出
                    } 否则 如果 (i + 1 < 计数(参数)) {
                        i = i + 1
                        权限 = mkdir_解析权限(参数[i])
                        跳出
                    }
                }
                否则 { 打印行("mkdir: 无效选项 '-" + c + "'"); 返回 1 }
                j = j + 1
            }
        }
        否则 { 追加(目录列表, a) }
        i = i + 1
    }

    当 (i < 计数(参数)) {
        追加(目录列表, 参数[i])
        i = i + 1
    }

    如果 (计数(目录列表) == 0) {
        打印行("mkdir: 缺少操作数")
        打印行("请尝试 'mkdir --help' 以获取更多信息")
        返回 1
    }

    定义 统计 = 堆_分配(mkdir_统计)
    统计.创建数 = 0
    统计.跳过数 = 0
    统计.错误数 = 0

    定义 可变 k = 0
    当 (k < 计数(目录列表)) {
        定义 路径 = mkdir_规范化路径(目录列表[k])
        定义 可变 结果 = 0

        如果 ((选项 & MKDIR_递归) != 0) {
            结果 = mkdir_递归(路径, 权限, 选项, 统计)
        } 否则 {
            如果 (文件_存在(路径)) {
                打印行("mkdir: 无法创建目录 '" + 路径 + "': 文件已存在")
                统计.错误数 = 统计.错误数 + 1
            } 否则 {
                结果 = 文件_创建目录(路径, 权限)
                如果 (结果 < 0) {
                    定义 父路径 = mkdir_父目录(路径)
                    如果 (!文件_存在(父路径)) {
                        打印行("mkdir: 无法创建目录 '" + 路径 + "': 父目录不存在")
                    } 否则 {
                        打印行("mkdir: 无法创建目录 '" + 路径 + "': " + 错误描述(结果))
                    }
                    统计.错误数 = 统计.错误数 + 1
                } 否则 {
                    统计.创建数 = 统计.创建数 + 1
                    如果 ((选项 & MKDIR_详细) != 0) {
                        打印行("mkdir: 已创建目录 '" + 路径 + "'")
                    }
                    如果 ((选项 & MKDIR_上下文) != 0 && 安全上下文 != "") {
                        mkdir_设置安全上下文(路径, 安全上下文)
                    }
                }
            }
        }
        k = k + 1
    }

    返回 统计.错误数 > 0 ? 1 : 0
}

函数 mkdir_递归(路径, 权限, 选项, 统计) {
    定义 是绝对 = 字符串长度(路径) > 0 && 字符串取字符(路径, 0) == "/"
    定义 部分 = 字符串分割(路径, "/")
    定义 可变 当前 = ""
    如果 (是绝对) { 当前 = "" }

    定义 可变 i = 0
    当 (i < 计数(部分)) {
        如果 (部分[i] == "" || 部分[i] == ".") { i = i + 1; 继续 }
        如果 (部分[i] == "..") {
            当前 = mkdir_父目录(当前)
            i = i + 1
            继续
        }

        如果 (当前 == "" && 是绝对) {
            当前 = "/" + 部分[i]
        } 否则 如果 (当前 == "") {
            当前 = 部分[i]
        } 否则 {
            当前 = 当前 + "/" + 部分[i]
        }

        如果 (文件_存在(当前)) {
            如果 (!文件_是目录(当前)) {
                打印行("mkdir: '" + 当前 + "' 不是目录")
                统计.错误数 = 统计.错误数 + 1
                返回 -1
            }
            统计.跳过数 = 统计.跳过数 + 1
        } 否则 {
            定义 使用权限 = 权限
            如果 (i < 计数(部分) - 1) {
                使用权限 = 权限 | 0o300
            }
            定义 结果 = 文件_创建目录(当前, 使用权限)
            如果 (结果 < 0) {
                打印行("mkdir: 无法创建目录 '" + 当前 + "': " + 错误描述(结果))
                统计.错误数 = 统计.错误数 + 1
                返回 结果
            }
            统计.创建数 = 统计.创建数 + 1
            如果 ((选项 & MKDIR_详细) != 0) {
                打印行("mkdir: 已创建目录 '" + 当前 + "'")
            }
        }
        i = i + 1
    }
    返回 0
}

函数 mkdir_规范化路径(路径) {
    定义 可变 结果 = 路径
    当 (字符串长度(结果) > 1 && 字符串结尾是(结果, "/")) {
        结果 = 字符串子串(结果, 0, 字符串长度(结果) - 1)
    }
    返回 结果
}

函数 mkdir_父目录(路径) {
    定义 可变 最后斜杠 = -1
    定义 可变 i = 0
    当 (i < 字符串长度(路径)) {
        如果 (字符串取字符(路径, i) == "/") { 最后斜杠 = i }
        i = i + 1
    }
    如果 (最后斜杠 <= 0) { 返回 "/" }
    返回 字符串子串(路径, 0, 最后斜杠)
}

函数 mkdir_解析权限(文本) {
    如果 (字符串长度(文本) == 0) { 返回 0o755 }
    定义 首字符 = 字符串取字符码(文本, 0)
    如果 (首字符 >= 0x30 && 首字符 <= 0x37) {
        返回 字符串转八进制(文本)
    }
    定义 可变 权限 = 0o755
    定义 部分 = 字符串分割(文本, ",")
    定义 可变 i = 0
    当 (i < 计数(部分)) {
        权限 = mkdir_解析符号权限(部分[i], 权限)
        i = i + 1
    }
    返回 权限
}

函数 mkdir_解析符号权限(表达式, 当前权限) {
    定义 可变 谁 = 0
    定义 可变 i = 0
    当 (i < 字符串长度(表达式)) {
        定义 c = 字符串取字符(表达式, i)
        如果 (c == "u") { 谁 = 谁 | 0o700 }
        否则 如果 (c == "g") { 谁 = 谁 | 0o070 }
        否则 如果 (c == "o") { 谁 = 谁 | 0o007 }
        否则 如果 (c == "a") { 谁 = 0o777 }
        否则 { 跳出 }
        i = i + 1
    }
    如果 (谁 == 0) { 谁 = 0o777 }

    如果 (i >= 字符串长度(表达式)) { 返回 当前权限 }
    定义 操作 = 字符串取字符(表达式, i)
    i = i + 1

    定义 可变 位 = 0
    当 (i < 字符串长度(表达式)) {
        定义 c = 字符串取字符(表达式, i)
        如果 (c == "r") { 位 = 位 | 0o444 }
        否则 如果 (c == "w") { 位 = 位 | 0o222 }
        否则 如果 (c == "x") { 位 = 位 | 0o111 }
        否则 如果 (c == "s") { 位 = 位 | 0o6000 }
        否则 如果 (c == "t") { 位 = 位 | 0o1000 }
        i = i + 1
    }
    位 = 位 & 谁

    如果 (操作 == "+") { 返回 当前权限 | 位 }
    如果 (操作 == "-") { 返回 当前权限 & ~位 }
    如果 (操作 == "=") { 返回 (当前权限 & ~谁) | 位 }
    返回 当前权限
}

函数 mkdir_设置安全上下文(路径, 上下文) {
    定义 结果 = 文件_设置扩展属性(路径, "security.selinux", 上下文)
    如果 (结果 < 0) {
        打印行("mkdir: 无法设置安全上下文: " + 路径)
    }
}

函数 字符串转八进制(文本) {
    定义 可变 结果 = 0
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 c = 字符串取字符码(文本, i)
        如果 (c >= 48 && c <= 55) { 结果 = 结果 * 8 + (c - 48) }
        否则 { 跳出 }
        i = i + 1
    }
    返回 结果
}

函数 mkdir_帮助() {
    打印行("用法: mkdir [选项] 目录...")
    打印行("创建目录（如果目录不存在）")
    打印行("")
    打印行("  -m, --mode=MODE  设置文件权限（如 'mkdir -m 755'）")
    打印行("  -p, --parents    递归创建父目录")
    打印行("  -v, --verbose    显示每个创建的目录")
    打印行("  -Z, --context    设置 SELinux 安全上下文")
    打印行("  --help           显示帮助信息")
    打印行("  --version        显示版本信息")
}

定义 可变 AI_创建目录_热文件表 = []

函数 AI_创建目录_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_创建目录_热文件表)) {
        如果 (AI_创建目录_热文件表[i].路径 == 路径) {
            AI_创建目录_热文件表[i].频率 = AI_创建目录_热文件表[i].频率 + 1
            返回 AI_创建目录_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_创建目录_热文件表) < 128) {
        追加(AI_创建目录_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_创建目录_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

// Stage-1 自举兼容桥
// 为少数历史名称和 Stage-0 未内建下沉的符号提供稳定入口。

导入("./系统扩展/共享辅助.nova")
导入("./平台/交叉编译/目标三元组.nova")
导入("./标准库/基础.nova")
导入("./标准库/系统/硬件库.nova")
导入("./编译器/模块系统/增量缓存.nova")
导入("./编译器/词法/词法分析.nova")
导入("./运行时/调试器/调试器.nova")

函数 整数(文本) {
    返回 安全转整数(文本)
}

函数 调试器_创建() {
    返回 调试器_调试器_创建()
}

函数 兼容桥_写二进制(文件名, 数据, 大小) {
    返回 写文件(文件名, 列表转字节(数据), 大小)
}

// 内建函数的显式定义 (Rust seed 不认识这些内建名, 需要函数体)
函数 设(列表, 索引, 值) {
    列表[索引] = 值
}

函数 内存写16(buf, 偏移, 值) {
    定义 可变 v = 值
    如果 (v < 0) { v = v + 65536 }
    buf[偏移] = v & 255
    buf[偏移 + 1] = (v / 256) & 255
}

函数 内存写32(buf, 偏移, 值) {
    定义 可变 v = 值
    如果 (v < 0) { v = v + 4294967296 }
    buf[偏移] = v & 255
    buf[偏移 + 1] = (v / 256) & 255
    buf[偏移 + 2] = (v / 65536) & 255
    buf[偏移 + 3] = (v / 16777216) & 255
}

函数 内存写64(buf, 偏移, 值) {
    定义 可变 v = 值
    定义 可变 i = 0
    当 (i < 8) {
        定义 b = v & 255
        buf[偏移 + i] = b
        v = (v - b) / 256
        i = i + 1
    }
}

函数 缓冲区(大小) {
    定义 可变 buf = []
    定义 可变 i = 0
    当 (i < 大小) { 追加(buf, 0) i = i + 1 }
    返回 buf
}

函数 缓冲写(buf, 偏移, 值) {
    buf[偏移] = 值 & 255
}

函数 缓冲写16(buf, 偏移, 值) {
    定义 可变 v = 值
    如果 (v < 0) { v = v + 65536 }
    buf[偏移] = v & 255
    buf[偏移 + 1] = (v / 256) & 255
}

函数 缓冲写64(buf, 偏移, 值) {
    定义 可变 v = 值
    定义 可变 i = 0
    当 (i < 8) {
        定义 b = v & 255
        buf[偏移 + i] = b
        v = (v - b) / 256
        i = i + 1
    }
}

函数 缓冲写32(buf, 偏移, 值) {
    定义 可变 v = 值
    如果 (v < 0) { v = v + 4294967296 }
    buf[偏移] = v & 255
    buf[偏移 + 1] = (v / 256) & 255
    buf[偏移 + 2] = (v / 65536) & 255
    buf[偏移 + 3] = (v / 16777216) & 255
}

函数 断点_启用(bp) {
    返回 调试器_断点_启用(bp)
}

函数 断点_命中(bp) {
    返回 调试器_断点_命中(bp)
}

函数 调试器_删除断点(调试器, ID) {
    返回 调试器_调试器_删除断点(调试器, ID)
}


函数 创建目录_递归(_路径) {
    返回 真
}

函数 读字节(路径) {
    定义 数据 = 读文件(路径)
    如果 (数据 == 空) { 返回 空 }
    // 读文件返回字符串缓冲区, 转为字节列表以匹配链接器对目标码的列表索引访问
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 字节长度(数据)) {
        追加(结果, 字节取(数据, i))
        i = i + 1
    }
    返回 结果
}

函数 泛型_解析参数(词法流) {
    定义 可变 参数 = []
    词法流_期望(词法流, "<")
    当 (词法流_当前(词法流) != ">" 且 !词法流_结束(词法流)) {
        如果 (词法流_当前(词法流) != ",") {
            追加(参数, 词法流_当前(词法流))
        }
        词法流_前进(词法流)
    }
    词法流_期望(词法流, ">")
    返回 参数
}

函数 兼容桥_缓存_初始化() {
    返回 增量缓存_缓存_初始化()
}

函数 兼容桥_目标_名称(目标) {
    返回 目标三元_目标_名称(目标)
}

// 兼容层扩展
定义 可变 _兼容桥版本 = "1.0.0"
定义 可变 _兼容桥调用数 = 0
定义 可变 _兼容桥失败数 = 0

函数 兼容桥_版本() { 返回 _兼容桥版本 }
函数 兼容桥_递增() { _兼容桥调用数 = _兼容桥调用数 + 1 }
函数 兼容桥_失败() { _兼容桥失败数 = _兼容桥失败数 + 1 }
函数 兼容桥_健康() {
    如果 (_兼容桥失败数 > _兼容桥调用数 / 10) { 返回 "降级" }
    返回 "ok"
}

导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/哈希整数.nova")
导入("../中枢/创建甲.nova")

定义 级别_信息 = 0
定义 级别_警告 = 1
定义 级别_严重 = 2
定义 级别_紧急 = 3
定义 最大规则 = 32
定义 最大历史 = 512
定义 节流间隔 = 60000000

结构 告警规则 {
    名称哈希,
    级别,
    检查回调,
    启用,
    触发次数,
    上次触发,
    节流间隔,
}

结构 告警记录 {
    时间戳,
    级别,
    规则哈希,
    内容哈希,
    已确认,
}

定义 可变 规则表 = []
定义 可变 规则数 = 0
定义 可变 历史表 = []
定义 可变 历史数 = 0
定义 可变 通知回调表 = 0
定义 可变 通知回调数 = 0
定义 可变 总触发 = 0
定义 可变 总抑制 = 0

函数 告警_初始化() {
    规则表 = []
    规则数 = 0
    历史表 = []
    历史数 = 0
    通知回调表 = 堆_分配(8 * 8)
    通知回调数 = 0
}

函数 告警_注册规则(名称, 级别, 检查回调) {
    如果 (规则数 >= 最大规则) { 返回 -1 }
    定义 规则 = 告警规则 {}
    规则.名称哈希 = 哈希_字符串(名称)
    规则.级别 = 级别
    规则.检查回调 = 检查回调
    规则.启用 = 真
    规则.触发次数 = 0
    规则.上次触发 = 0
    规则.节流间隔 = 节流间隔
    追加(规则表, 规则)
    定义 索引 = 规则数
    规则数 = 规则数 + 1
    返回 索引
}

函数 告警_注册通知(回调) {
    如果 (通知回调数 >= 8) { 返回 }
    内存_写64(通知回调表 + 通知回调数 * 8, 回调)
    通知回调数 = 通知回调数 + 1
}

函数 告警_触发(规则索引, 内容哈希) {
    如果 (规则索引 >= 规则数) { 返回 }
    定义 规则 = 规则表[规则索引]
    如果 (!规则.启用) { 返回 }
    定义 现在 = 平台_获取高精度时间()
    如果 (现在 - 规则.上次触发 < 规则.节流间隔) {
        总抑制 = 总抑制 + 1
        返回
    }
    规则.触发次数 = 规则.触发次数 + 1
    规则.上次触发 = 现在
    总触发 = 总触发 + 1
    如果 (历史数 >= 最大历史) {
        历史表[0] = 历史表[历史数 - 1]
        历史数 = 历史数 - 1
    }
    定义 记录 = 告警记录 {}
    记录.时间戳 = 现在
    记录.级别 = 规则.级别
    记录.规则哈希 = 规则.名称哈希
    记录.内容哈希 = 内容哈希
    记录.已确认 = 假
    追加(历史表, 记录)
    历史数 = 历史数 + 1
    告警_分发通知(规则.级别, 规则.名称哈希, 内容哈希)
}

函数 告警_分发通知(级别, 规则哈希, 内容哈希) {
    定义 可变 序号 = 0
    当 (序号 < 通知回调数) {
        定义 回调 = 内存_读64(通知回调表 + 序号 * 8)
        如果 (回调 != 0) { 回调(级别, 规则哈希, 内容哈希) }
        序号 = 序号 + 1
    }
}

函数 告警_检查全部() {
    定义 可变 序号 = 0
    当 (序号 < 规则数) {
        如果 (规则表[序号].启用 && 规则表[序号].检查回调 != 0) {
            如果 (规则表[序号].检查回调()) {
                告警_触发(序号, 0)
            }
        }
        序号 = 序号 + 1
    }
}

函数 告警_确认(历史索引) {
    如果 (历史索引 >= 历史数) { 返回 }
    历史表[历史索引].已确认 = 真
}

函数 告警_启用规则(规则索引, 启用) {
    如果 (规则索引 >= 规则数) { 返回 }
    规则表[规则索引].启用 = 启用
}

函数 告警_设节流(规则索引, 间隔) {
    如果 (规则索引 >= 规则数) { 返回 }
    规则表[规则索引].节流间隔 = 间隔
}

函数 告警_未确认数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 历史数) {
        如果 (!历史表[序号].已确认) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 告警_按级别统计(级别) {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 历史数) {
        如果 (历史表[序号].级别 == 级别) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 告警_级别名(级别) {
    如果 (级别 == 级别_信息) { 返回 "信息" }
    如果 (级别 == 级别_警告) { 返回 "警告" }
    如果 (级别 == 级别_严重) { 返回 "严重" }
    如果 (级别 == 级别_紧急) { 返回 "紧急" }
    返回 "未知"
}

函数 告警_完整统计() {
    返回 [规则数, 历史数, 总触发, 总抑制, 告警_未确认数(), 告警_按级别统计(级别_严重)]
}

定义 可变 AI_告警通知_事件频率 = 0
定义 可变 AI_告警通知_节流阈值 = 16

函数 AI_告警通知_节流判断(事件类型, 间隔毫秒) {
    AI_告警通知_事件频率 = AI_告警通知_事件频率 + 1
    如果 (事件类型 == "滚动" && 间隔毫秒 < AI_告警通知_节流阈值) { 返回 真 }
    如果 (事件类型 == "移动" && 间隔毫秒 < AI_告警通知_节流阈值) { 返回 真 }
    返回 假
}

函数 AI_告警通知_优先级排序(事件类型) {
    如果 (事件类型 == "点击") { 返回 100 }
    如果 (事件类型 == "输入") { 返回 90 }
    如果 (事件类型 == "滚动") { 返回 30 }
    返回 50
}

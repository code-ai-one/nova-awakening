// §3 序列工具(版)

函数 序列_构造对象(键值对) {
    // 键值对: [[key1, val1], [key2, val2], ...]
    定义 可变 结果 = "{"
    定义 可变 i = 0
    当 (i < 计数(键值对)) {
        如果 (i > 0) { 结果 = 结果 + "," }
        结果 = 结果 + "\"" + 键值对[i][0] + "\":" + 序列_编码值(键值对[i][1])
        i = i + 1
    }
    返回 结果 + "}"
}

函数 序列_编码值(值) {
    如果 (值 == 空) { 返回 "null" }
    如果 (值 == 真) { 返回 "true" }
    如果 (值 == 假) { 返回 "false" }
    // 数字或字符串
    返回 "\"" + 值 + "\""
}

函数 序列_提取字段(json, 字段名) {
    // 当前实现序列解析: 查找 "field": "value" 或 "field": value
    定义 搜索 = "\"" + 字段名 + "\":"
    定义 位置 = 字符串查找(json, 搜索)
    如果 (位置 < 0) { 返回 "" }
    定义 值开始 = 位置 + 字符串长度(搜索)
    // 跳过空格
    当 (值开始 < 字符串长度(json) && 字符串取字节(json, 值开始) == 32) {
        值开始 = 值开始 + 1
    }
    如果 (值开始 >= 字符串长度(json)) { 返回 "" }

    如果 (字符串取字节(json, 值开始) == 34) {  // 双引号
        // 字符串值
        定义 值结束 = 值开始 + 1
        当 (值结束 < 字符串长度(json) && 字符串取字节(json, 值结束) != 34) {
            值结束 = 值结束 + 1
        }
        返回 子字符串(json, 值开始 + 1, 值结束)
    } 否则 {
        // 数字/布尔
        定义 值结束 = 值开始
        当 (值结束 < 字符串长度(json) && 字符串取字节(json, 值结束) != 44 &&
            字符串取字节(json, 值结束) != 125) {
            值结束 = 值结束 + 1
        }
        返回 子字符串(json, 值开始, 值结束)
    }
}

// §4 云端AI 接口适配器

定义 接口类型_Nova智能 = 0
定义 接口类型_Anthropic = 1
定义 接口类型_本地 = 2

结构 智能_接口配置 {
    类型,
    基础URL,
    接口密钥,
    模型名,
    最大令牌,
    温度,    // u32 ×1000 (0.7 = 700)
}

定义 可变 智能_接口_默认配置 = 空
定义 可变 智能_接口_调用总数 = 0
定义 可变 智能_接口_成功总数 = 0

函数 智能_接口_初始化(类型, 基础URL, 接口密钥, 模型名) {
    定义 config = 智能_接口配置 {}
    config.类型 = 类型
    config.基础URL = 基础URL
    config.接口密钥 = 接口密钥
    config.模型名 = 模型名
    config.最大令牌 = 4096
    config.温度 = 700
    智能_接口_默认配置 = config
    内核信息("AI-接口: 初始化 类型=" + 整数转字符串(类型) +
             " 模型=" + 模型名 + " URL=" + 基础URL)
    返回 config
}

函数 智能_接口_聊天(消息列表) {
    如果 (智能_接口_默认配置 == 空) {
        内核错误("AI-接口: 未初始化配置")
        返回 空
    }
    定义 config = 智能_接口_默认配置
    智能_接口_调用总数 = 智能_接口_调用总数 + 1

    // 构造请求正文(Nova智能格式)
    定义 可变 消息json = "["
    定义 可变 i = 0
    当 (i < 计数(消息列表)) {
        如果 (i > 0) { 消息json = 消息json + "," }
        消息json = 消息json + "{\"role\":\"" + 消息列表[i][0] +
                   "\",\"content\":\"" + 消息列表[i][1] + "\"}"
        i = i + 1
    }
    消息json = 消息json + "]"

    定义 正文 = "{\"model\":\"" + config.模型名 +
                "\",\"messages\":" + 消息json +
                ",\"max_令牌s\":" + 整数转字符串(config.最大令牌) +
                ",\"temperature\":" + 数学_千分位转小数字符串(config.温度) + "}"

    // 发送请求
    定义 端点 = config.基础URL + "/v1/chat/completions"
    如果 (config.类型 == 接口类型_Anthropic) {
        端点 = config.基础URL + "/v1/messages"
    }

    定义 req = HTTP_创建请求(HTTP_POST, 端点)
    HTTP_设序列正文(req, 正文)
    HTTP_设授权(req, config.接口密钥)

    定义 响应 = HTTP_发送_带重试(req)
    如果 (响应.成功) {
        智能_接口_成功总数 = 智能_接口_成功总数 + 1
        // 从响应序列提取助手消息
        定义 内容 = 序列_提取字段(响应.正文, "content")
        返回 内容
    }
    内核调试("AI-接口: 请求失败 状态=" + 整数转字符串(响应.状态码))
    返回 空
}

函数 智能_接口_推理(输入文本) {
    // 单轮推理简便接口
    定义 消息 = [["user", 输入文本]]
    返回 智能_接口_聊天(消息)
}

函数 智能_接口_流式推理(输入文本, 回调函数) {
    // 流式推理(SSE): 逐令牌回调
    如果 (智能_接口_默认配置 == 空) { 返回 假 }
    定义 config = 智能_接口_默认配置
    智能_接口_调用总数 = 智能_接口_调用总数 + 1

    定义 正文 = "{\"model\":\"" + config.模型名 +
                "\",\"messages\":[{\"role\":\"user\",\"content\":\"" + 输入文本 + "\"}]" +
                ",\"max_令牌s\":" + 整数转字符串(config.最大令牌) +
                ",\"stream\":true}"

    定义 req = HTTP_创建请求(HTTP_POST, config.基础URL + "/v1/chat/completions")
    HTTP_设序列正文(req, 正文)
    HTTP_设授权(req, config.接口密钥)
    HTTP_添加头部(req, "Accept", "text/事件-stream")

    // 流式接收(简化: 一次性获取后按行解析)
    定义 响应 = HTTP_发送(req)
    如果 (响应.成功) {
        智能_接口_成功总数 = 智能_接口_成功总数 + 1
    }
    返回 响应.成功
}

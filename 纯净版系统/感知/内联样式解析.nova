// §4 内联样式解析 (style="...")

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../推理/值乘.nova")
导入("./文档节点.nova")
导入("../执行/底层内存操.nova")
导入("./样式令牌甲.nova")
导入("../中枢/整数转字符串.nova")
导入("./样式令牌器.nova")
导入("./样式解析解.nova")
导入("./列表.nova")

函数 CSS_解析内联样式(样式文本) {
    // 解析 "color: red; font-size: 14px" → 声明列表
    定义 tk = CSS令牌izer_创建(样式文本)
    定义 令牌 = 堆_分配(CSS令牌)
    定义 可变 声明列表 = 堆_分配_数组(32 * 24)
    定义 可变 声明数量 = 0

    当 (1) {
        CSS令牌izer_下一个令牌(tk, 令牌)
        如果 (令牌.类型 == CSS_令牌_EOF) { 跳出 }
        如果 (令牌.类型 == CSS_令牌_标识符) {
            定义 声明 = CSSParser_解析声明(tk, 令牌)
            如果 (声明 != 0 && 声明数量 < 32) {
                内存_复制(声明列表 + 声明数量 * 24, 声明, 24)
                声明数量 = 声明数量 + 1
            }
        }
    }
    返回 声明列表
}

// §5 选择器匹配 
// 检查一个CSS选择器是否匹配一个元素

函数 CSS选择器_前一个(头, 目标) {
 如果 (头 == 0 || 目标 == 0 || 头 == 目标) { 返回 0 }
 定义 可变 当前 = 头
 当 (当前 != 0) {
 如果 (当前.下一个 == 目标) { 返回 当前 }
 当前 = 当前.下一个
 }
 返回 0
}

函数 CSS_选择器匹配(选择器, 元素) {
 如果 (选择器 == 0 || 元素 == 0) { 返回 0 }
 如果 (!(元素.节点标志 & 节点标志_是元素)) { 返回 0 }

 定义 扩展 = 元素_获取扩展(元素)
 如果 (扩展 == 0) { 返回 0 }

 // 从右向左匹配选择器链(最右边是目标元素)
 // 找到链的末尾
 定义 可变 末尾 = 选择器
 当 (末尾.下一个 != 0) { 末尾 = 末尾.下一个 }

 // 匹配最右部分
 如果 (!CSS_简单选择器匹配(末尾, 扩展)) { 返回 0 }

 // 如果只有一个部分,匹配成功
 如果 (末尾 == 选择器) { 返回 1 }

 // 多部分选择器: 从右向左,按组合器回溯DOM树
 // 多部分选择器: 从右向左, 按组合器回溯DOM树
 定义 可变 当前部分 = 末尾
 定义 可变 当前元素 = 元素
 当 (当前部分 != 选择器 && 当前元素 != 0) {
 定义 前一部分 = CSS选择器_前一个(选择器, 当前部分)
 如果 (前一部分 == 0) { 返回 0 }
 定义 关系 = 前一部分.组合器
 如果 (关系 == 组合器_无) {
 如果 (!CSS_简单选择器匹配(前一部分, 元素_获取扩展(当前元素))) { 返回 0 }
 } 否则 如果 (关系 == 组合器_后代) {
 // 后代: 向上遍历祖先
 当前元素 = FlatTree_父(当前元素)
 当 (当前元素 != 0) {
 如果 (CSS_简单选择器匹配(前一部分, 元素_获取扩展(当前元素))) { 跳出 }
 当前元素 = FlatTree_父(当前元素)
 }
 如果 (当前元素 == 0) { 返回 0 }
 } 否则 如果 (关系 == 组合器_子) {
 // 子代: 只检查父节点
 当前元素 = FlatTree_父(当前元素)
 如果 (当前元素 == 0 || !CSS_简单选择器匹配(前一部分, 元素_获取扩展(当前元素))) { 返回 0 }
 } 否则 {
 返回 0
 }
 当前部分 = 前一部分
 }
 返回 1
}

函数 CSS_简单选择器匹配(选择器, 元素扩展) {
 如果 (选择器.类型 == 选择器类型_通用) { 返回 1 }
 如果 (选择器.类型 == 选择器类型_标签) {
 返回 元素扩展.标签名原子 == 选择器.值原子
 }
 如果 (选择器.类型 == 选择器类型_class) {
 // 检查元素的class列表中是否包含此class
 返回 元素_classList_contains(元素扩展.基础节点, 选择器.值)
 }
 如果 (选择器.类型 == 选择器类型_id) {
 返回 元素扩展.id原子 == 选择器.值原子
 }
 如果 (选择器.类型 == 选择器类型_伪类) {
 返回 NISP_匹配伪类(选择器, 元素扩展.基础节点)
 }
 返回 0
}

函数 CSS_解析选择器(选择器字符串) {
 // 外部接口: 解析选择器字符串 → CSS选择器链
 定义 tk = CSS令牌izer_创建(选择器字符串)
 定义 令牌 = 堆_分配(CSS令牌)
 CSS令牌izer_下一个令牌(tk, 令牌)
 返回 CSSParser_解析选择器组(tk, 令牌)
}

// NISP理论 — Nova内联样式解析理论
// (Nova Inline Style Parse Theory)
// 原创增量式属性解析 + 简写展开 + 级联规则 + AI样式预测理论
// 核心创新: 属性哈希快查 + important标志 + 优先级计算 + AI意图推断

定义 NISP_版本 = 1
定义 NISP_最大声明数 = 128
定义 NISP_属性哈希表大小 = 256
定义 NISP_AI特征维度 = 10

// 统计
定义 可变 NISP_解析总数 = 0
定义 可变 NISP_声明总数 = 0
定义 可变 NISP_简写展开数 = 0
定义 可变 NISP_important数 = 0
定义 可变 NISP_AI推理次数 = 0

结构 CSS声明 {
    属性名,
    属性名原子,
    值文本,
    值类型,     // 0=字符串, 1=数字, 2=颜色, 3=长度
    值数字,
    值单位,
    important,
    来源        // 0=内联, 1=样式表, 2=用户代理
}

// §6 完整声明解析

// 解析单个属性: 值部分 (property: value !important;)
函数 NISP_解析单声明(tk, 令牌) {
    定义 声明 = 堆_分配(CSS声明)
    内存_清零(声明, 64)

    // 属性名
    如果 (令牌.类型 != CSS_令牌_标识符) {
        堆_释放(声明)
        返回 0
    }
    声明.属性名 = 令牌.值
    声明.属性名原子 = 原子化(令牌.值)

    // 跳过冒号
    CSS令牌izer_下一个令牌(tk, 令牌)
    如果 (令牌.类型 != CSS_令牌_冒号) {
        堆_释放(声明)
        返回 0
    }

    // 解析值
    CSS令牌izer_下一个令牌(tk, 令牌)
    声明.值文本 = NISP_收集值文本(tk, 令牌)

    // 检查 !important
    声明.important = NISP_检查important(声明.值文本)
    如果 (声明.important) {
        NISP_important数 = NISP_important数 + 1
    }

    // 解析值类型
    NISP_解析值类型(声明)

    NISP_声明总数 = NISP_声明总数 + 1
    返回 声明
}

// 收集值文本直到分号或EOF
函数 NISP_收集值文本(tk, 令牌) {
    定义 可变 结果 = ""
    当 (令牌.类型 != CSS_令牌_分号 && 令牌.类型 != CSS_令牌_EOF) {
        结果 = 结果 + 令牌.值
        CSS令牌izer_下一个令牌(tk, 令牌)
    }
    返回 结果
}

// 检查值是否包含 !important
函数 NISP_检查important(值文本) {
    定义 长度 = 字符串长度(值文本)
    如果 (长度 < 10) { 返回 假 }
    // 检查末尾是否为 "!important"
    定义 后缀 = 字符串_取子串(值文本, 长度 - 10, 10)
    返回 字符串_相等(后缀, "!important")
}

// 解析值类型 (CSS值分类)
函数 NISP_解析值类型(声明) {
    定义 值 = 声明.值文本
    定义 长度 = 字符串长度(值)
    如果 (长度 == 0) { 返回 }

    定义 首字符 = 字符串_取字符(值, 0)

    // 颜色值: #开头或 rgb(
    如果 (首字符 == 35) {  // '#'
        声明.值类型 = 2  // 颜色
        声明.值数字 = NISP_解析十六进制颜色(值)
        返回
    }

    // 数字值: 0-9开头
    如果 ((首字符 >= 48 && 首字符 <= 57) || 首字符 == 46 || 首字符 == 45) {
        NISP_解析数字值(声明)
        返回
    }

    // 字符串值
    声明.值类型 = 0
}

函数 NISP_解析十六进制颜色(值) {
    定义 长度 = 字符串长度(值)
    定义 可变 结果 = 0
    定义 可变 i = 1  // 跳过 '#'
    当 (i < 长度) {
        定义 c = 字符串_取字符(值, i)
        定义 可变 位 = 0
        如果 (c >= 48 && c <= 57) { 位 = c - 48 }
        否则 如果 (c >= 97 && c <= 102) { 位 = c - 87 }
        否则 如果 (c >= 65 && c <= 70) { 位 = c - 55 }
        结果 = (结果 << 4) | 位
        i = i + 1
    }
    // 短形式 #RGB → #RRGGBB
    如果 (长度 == 4) {
        定义 r = (结果 >> 8) & 0xF
        定义 g = (结果 >> 4) & 0xF
        定义 b = 结果 & 0xF
        结果 = (r * 17 << 16) | (g * 17 << 8) | (b * 17)
    }
    返回 0xFF000000 | 结果
}

函数 NISP_解析数字值(声明) {
    定义 值 = 声明.值文本
    定义 长度 = 字符串长度(值)
    定义 可变 数字 = 0
    定义 可变 符号 = 1
    定义 可变 i = 0

    如果 (字符串_取字符(值, 0) == 45) { 符号 = -1; i = 1 }

    当 (i < 长度) {
        定义 c = 字符串_取字符(值, i)
        如果 (c >= 48 && c <= 57) {
            数字 = 数字 * 10 + (c - 48)
        } 否则 {
            断开  // 到达单位部分
        }
        i = i + 1
    }

    声明.值数字 = 数字 * 符号
    声明.值单位 = 字符串_取子串(值, i, 长度 - i)
    声明.值类型 = 3  // 长度值
}

// §7 简写属性展开
// margin/padding/border/background等简写展开为单独属性

函数 NISP_展开简写(声明列表, 声明数, 声明) {
    定义 名称 = 声明.属性名原子

    // margin 简写
    如果 (名称 == 原子化("margin")) {
        返回 NISP_展开四方向(声明列表, 声明数, 声明, "margin-top", "margin-right", "margin-bottom", "margin-left")
    }

    // padding 简写
    如果 (名称 == 原子化("padding")) {
        返回 NISP_展开四方向(声明列表, 声明数, 声明, "padding-top", "padding-right", "padding-bottom", "padding-left")
    }

    // 不是简写, 直接返回
    返回 0
}

// 展开四方向简写 (1值=四方, 2值=上下/左右, 3值=上/左右/下, 4值=上/右/下/左)
函数 NISP_展开四方向(声明列表, 声明数, 声明, 上名, 右名, 下名, 左名) {
    // 解析值部分的多个数字
    定义 值 = 声明.值文本
    定义 可变 值数组 = [0, 0, 0, 0]
    定义 可变 值数量 = NISP_分割空格值(值, 值数组)

    定义 可变 上 = 值数组[0]
    定义 可变 右 = 值数组[0]
    定义 可变 下 = 值数组[0]
    定义 可变 左 = 值数组[0]

    如果 (值数量 >= 2) { 右 = 值数组[1]; 左 = 值数组[1] }
    如果 (值数量 >= 3) { 下 = 值数组[2] }
    如果 (值数量 >= 4) { 左 = 值数组[3] }

    NISP_添加展开声明(声明列表, 声明数, 上名, 上, 声明.important)
    NISP_添加展开声明(声明列表, 声明数 + 1, 右名, 右, 声明.important)
    NISP_添加展开声明(声明列表, 声明数 + 2, 下名, 下, 声明.important)
    NISP_添加展开声明(声明列表, 声明数 + 3, 左名, 左, 声明.important)

    NISP_简写展开数 = NISP_简写展开数 + 1
    返回 4
}

函数 NISP_添加展开声明(声明列表, 索引, 名称, 值, important) {
    定义 偏移 = 声明列表 + 索引 * 24
    内存_写64(偏移, 原子化(名称))
    内存_写64(偏移 + 8, 值)
    内存_写32(偏移 + 16, important)
}

// 空格分割值字符串为多个部分
函数 NISP_分割空格值(值, 结果数组) {
    定义 长度 = 字符串长度(值)
    定义 可变 计数 = 0
    定义 可变 开始 = 0
    定义 可变 i = 0

    当 (i <= 长度 && 计数 < 4) {
        定义 可变 是空格 = 假
        如果 (i < 长度) {
            定义 c = 字符串_取字符(值, i)
            如果 (c == 32 || c == 9) { 是空格 = 真 }
        }

        如果 (是空格 || i == 长度) {
            如果 (i > 开始) {
                结果数组[计数] = 字符串_取子串(值, 开始, i - 开始)
                计数 = 计数 + 1
            }
            开始 = i + 1
        }
        i = i + 1
    }
    返回 计数
}

// §8 CSS优先级计算

结构 CSS优先级 {
    a,   // ID选择器数
    b,   // 类/属性/伪类数
    c    // 元素/伪元素数
}

函数 NISP_计算优先级(选择器) {
    定义 可变 a = 0
    定义 可变 b = 0
    定义 可变 c = 0

    定义 可变 当前 = 选择器
    当 (当前 != 0) {
        如果 (当前.类型 == 选择器类型_id) { a = a + 1 }
        否则 如果 (当前.类型 == 选择器类型_class) { b = b + 1 }
        否则 如果 (当前.类型 == 选择器类型_标签) { c = c + 1 }
        否则 如果 (当前.类型 == 选择器类型_属性) { b = b + 1 }
        否则 如果 (当前.类型 == 选择器类型_伪类) { b = b + 1 }
        否则 如果 (当前.类型 == 选择器类型_伪元素) { c = c + 1 }
        当前 = 当前.下一个
    }

    返回 { a: a, b: b, c: c }
}

// 比较两个优先级: 返回 -1/0/1
函数 NISP_比较优先级(s1, s2) {
    如果 (s1.a != s2.a) { 如果 (s1.a > s2.a) { 返回 1 } 否则 { 返回 -1 } }
    如果 (s1.b != s2.b) { 如果 (s1.b > s2.b) { 返回 1 } 否则 { 返回 -1 } }
    如果 (s1.c != s2.c) { 如果 (s1.c > s2.c) { 返回 1 } 否则 { 返回 -1 } }
    返回 0
}

// 级联判定: 考虑来源和important
函数 NISP_级联比较(声明1, 优先级1, 声明2, 优先级2) {
    // 1. !important优先
    如果 (声明1.important && !声明2.important) { 返回 1 }
    如果 (!声明1.important && 声明2.important) { 返回 -1 }

    // 2. 内联样式 > 样式表 > 用户代理
    如果 (声明1.来源 != 声明2.来源) {
        如果 (声明1.来源 < 声明2.来源) { 返回 1 }
        返回 -1
    }

    // 3. 优先级比较
    返回 NISP_比较优先级(优先级1, 优先级2)
}

// §9 伪类匹配

函数 NISP_匹配伪类(选择器, 元素) {
    定义 伪类名 = 选择器.值原子

    // :hover
    如果 (伪类名 == 原子化("hover")) {
        返回 元素_状态_hover(元素)
    }
    // :active
    如果 (伪类名 == 原子化("active")) {
        返回 元素_状态_active(元素)
    }
    // :focus
    如果 (伪类名 == 原子化("focus")) {
        返回 元素_状态_focus(元素)
    }
    // :first-child
    如果 (伪类名 == 原子化("first-child")) {
        定义 父 = FlatTree_父(元素)
        如果 (父 == 0) { 返回 假 }
        返回 FlatTree_第一子(父) == 元素
    }
    // :last-child
    如果 (伪类名 == 原子化("last-child")) {
        定义 父 = FlatTree_父(元素)
        如果 (父 == 0) { 返回 假 }
        返回 FlatTree_最后子(父) == 元素
    }
    // :disabled
    如果 (伪类名 == 原子化("disabled")) {
        返回 元素_getAttribute(元素, "disabled") != 0
    }
    // :checked
    如果 (伪类名 == 原子化("checked")) {
        返回 元素_getAttribute(元素, "checked") != 0
    }
    返回 假
}

// §10 AI样式推断

函数 NISP_AI预测样式意图() {
    定义 特征 = Tensor_创建([NISP_AI特征维度])
    Tensor_写(特征, [0], NISP_解析总数)
    Tensor_写(特征, [1], NISP_声明总数)
    Tensor_写(特征, [2], NISP_简写展开数)
    Tensor_写(特征, [3], NISP_important数)
    Tensor_写(特征, [4], 0)
    Tensor_写(特征, [5], 0)
    Tensor_写(特征, [6], 0)
    Tensor_写(特征, [7], 0)
    Tensor_写(特征, [8], 0)
    Tensor_写(特征, [9], 0)

    定义 预测 = AI总线_推理("NISP样式推断", 特征)
    NISP_AI推理次数 = NISP_AI推理次数 + 1
    Tensor_释放(特征)
    Tensor_释放(预测)
}

// §11 诊断接口

函数 NISP_获取统计() {
    返回 {
        版本: NISP_版本,
        解析总数: NISP_解析总数,
        声明总数: NISP_声明总数,
        简写展开数: NISP_简写展开数,
        important数: NISP_important数,
        AI推理次数: NISP_AI推理次数
    }
}

函数 NISP_重置统计() {
    NISP_解析总数 = 0
    NISP_声明总数 = 0
    NISP_简写展开数 = 0
    NISP_important数 = 0
    NISP_AI推理次数 = 0
}

// §12 属性名标准化

// CSS属性名转小写 (ASCII大写→小写)
函数 NISP_属性名小写化(名称) {
    定义 长度 = 字符串长度(名称)
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 字符串_取字符(名称, i)
        如果 (c >= 65 && c <= 90) {
            结果 = 结果 + 字符_从编码(c + 32)
        } 否则 {
            结果 = 结果 + 字符_从编码(c)
        }
        i = i + 1
    }
    返回 结果
}

// 判断是否为布局属性 (display/position/float/等影响布局)
函数 NISP_是布局属性(属性名原子) {
    如果 (属性名原子 == 原子化("display")) { 返回 真 }
    如果 (属性名原子 == 原子化("position")) { 返回 真 }
    如果 (属性名原子 == 原子化("float")) { 返回 真 }
    如果 (属性名原子 == 原子化("clear")) { 返回 真 }
    如果 (属性名原子 == 原子化("overflow")) { 返回 真 }
    如果 (属性名原子 == 原子化("width")) { 返回 真 }
    如果 (属性名原子 == 原子化("height")) { 返回 真 }
    返回 假
}

// 判断是否为继承属性
函数 NISP_是继承属性(属性名原子) {
    如果 (属性名原子 == 原子化("color")) { 返回 真 }
    如果 (属性名原子 == 原子化("font-family")) { 返回 真 }
    如果 (属性名原子 == 原子化("font-size")) { 返回 真 }
    如果 (属性名原子 == 原子化("line-height")) { 返回 真 }
    如果 (属性名原子 == 原子化("text-align")) { 返回 真 }
    如果 (属性名原子 == 原子化("visibility")) { 返回 真 }
    如果 (属性名原子 == 原子化("cursor")) { 返回 真 }
    返回 假
}

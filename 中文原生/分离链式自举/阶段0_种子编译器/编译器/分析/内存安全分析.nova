// Nova · 编译器 · 内存安全分析 (Memory Safety Analysis)
// 1. 边界检查消除 (Bounds Check Elimination, BCE)
// 2. 空值检查消除 (Null Check Elimination, NCE)
// 3. 越界访问证明 (Out-of-bounds Proof)
// 4. 使用后释放检测 (Use-after-free, UAF)
// 依赖：数据流分析.nova + 别名分析.nova

// 范围约束（Range Constraint）
// 表示变量在某点的值域：[下界, 上界, 是否已知]

导入("../../标准库/基础.nova")
导入("../../编译器/标记常量.nova")

定义 范围_已知 = 1
定义 范围_未知 = 0

函数 范围_创建(下界, 上界) { 返回 [下界, 上界, 范围_已知] }
函数 范围_未知值() { 返回 [0, 0, 范围_未知] }
函数 范围_下界(r) { 返回 r[0] }
函数 范围_上界(r) { 返回 r[1] }
函数 范围_是已知(r) { 返回 r[2] == 范围_已知 }

// 范围是否在 [0, 长度-1] 内（安全访问）
函数 范围_安全访问(r, 长度) {
    如果 (!范围_是已知(r)) { 返回 假 }
    返回 r[0] >= 0 且 r[1] < 长度
}

// 范围合并（取并集 → 最大范围）
函数 范围_合并(a, b) {
    如果 (!范围_是已知(a)) { 返回 b }
    如果 (!范围_是已知(b)) { 返回 a }
    定义 可变 _lo = b[0]
    如果 (a[0] < b[0]) { _lo = a[0] }
    定义 可变 _hi = b[1]
    如果 (a[1] > b[1]) { _hi = a[1] }
    返回 范围_创建(_lo, _hi)
}

// 范围交叉（取交集 → 最小范围）
函数 范围_交叉(a, b) {
    如果 (!范围_是已知(a) 或 !范围_是已知(b)) { 返回 范围_未知值() }
    定义 可变 下 = b[0]
    如果 (a[0] > b[0]) { 下 = a[0] }
    定义 可变 上 = b[1]
    如果 (a[1] < b[1]) { 上 = a[1] }
    如果 (下 > 上) { 返回 范围_未知值() }  // 空交集
    返回 范围_创建(下, 上)
}

// 边界检查消除（BCE）
// 分析：给定索引变量的已知范围，判断是否需要运行时边界检查

// BCE 分析上下文：[变量→范围 字典, 数组→长度 字典]
函数 BCE_上下文_创建() { 返回 [字典(), 字典()] }

函数 BCE_记录变量范围(ctx, 变量名, 范围) {
    字典设(ctx[0], 变量名, 范围)
}

函数 BCE_查询变量范围(ctx, 变量名) {
    定义 v = 字典取(ctx[0], 变量名)
    如果 (v == 空) { 返回 范围_未知值() }
    返回 v
}

函数 BCE_记录数组长度(ctx, 数组名, 长度) {
    字典设(ctx[1], 数组名, 长度)
}

函数 BCE_查询数组长度(ctx, 数组名) {
    定义 v = 字典取(ctx[1], 数组名)
    如果 (v == 空) { 返回 0 - 1 }  // 未知长度
    返回 v
}

// 判断索引访问是否可以省略运行时边界检查
// 返回：0=必须检查, 1=可以省略, 2=确定越界（编译期错误）
函数 BCE_分析访问(ctx, 数组名, 索引节点) {
    定义 长度 = BCE_查询数组长度(ctx, 数组名)
    如果 (长度 <= 0) { 返回 0 }  // 未知长度：必须检查

    // 分析索引的范围
    定义 索引范围 = BCE_分析表达式范围(ctx, 索引节点)
    如果 (!范围_是已知(索引范围)) { 返回 0 }

    // 确定越界
    如果 (索引范围[0] < 0 或 索引范围[1] >= 长度) {
        如果 (索引范围[1] < 0 或 索引范围[0] >= 长度) {
            返回 2  // 确定越界
        }
        返回 0  // 部分可能越界
    }

    返回 1  // 确定安全
}

// 分析表达式节点的值域
函数 BCE_分析表达式范围(ctx, 节点) {
    如果 (节点 == 空) { 返回 范围_未知值() }
    如果 (类型(节点) != 类型([])) {
        如果 (类型(节点) == 类型()) { 返回 范围_创建(节点, 节点) }
        返回 范围_未知值()
    }
    如果 (计数(节点) == 0) { 返回 范围_未知值() }

    定义 节点类型 = 节点[0]

    // 整数字面量
    如果 (节点类型 == 标记_数字 且 计数(节点) >= 2) {
        返回 范围_创建(节点[1], 节点[1])
    }
    // null字面量(165): 值域为[0,0]
    如果 (节点类型 == 节点_空字面量) {
        返回 范围_创建(0, 0)
    }

    // 标识符（变量）
    如果 (节点类型 == 标记_名称 且 计数(节点) >= 2) {
        返回 BCE_查询变量范围(ctx, 节点[1])
    }

    // 二元运算（类型104）
    如果 (节点类型 == 节点_二元 且 计数(节点) >= 4) {
        定义 运算符 = 节点[1]
        定义 左范围 = BCE_分析表达式范围(ctx, 节点[2])
        定义 右范围 = BCE_分析表达式范围(ctx, 节点[3])

        如果 (!范围_是已知(左范围) 或 !范围_是已知(右范围)) { 返回 范围_未知值() }

        // 加法范围：[l1+l2, u1+u2]
        如果 (运算符 == 1) {
            返回 范围_创建(左范围[0] + 右范围[0], 左范围[1] + 右范围[1])
        }
        // 减法范围：[l1-u2, u1-l2]
        如果 (运算符 == 2) {
            返回 范围_创建(左范围[0] - 右范围[1], 左范围[1] - 右范围[0])
        }
        // 乘法（简化：只处理正数乘正数）
        如果 (运算符 == 3 且 左范围[0] >= 0 且 右范围[0] >= 0) {
            返回 范围_创建(左范围[0] * 右范围[0], 左范围[1] * 右范围[1])
        }
        // 取模：结果在 [0, 除数-1]
        如果 (运算符 == 5 且 右范围[0] > 0) {
            返回 范围_创建(0, 右范围[1] - 1)
        }
    }

    返回 范围_未知值()
}

// 空值检查消除（NCE）
// 分析：在某个访问点，指针/引用是否确定非空

// NCE 上下文：[已证明非空的变量集合]
函数 NCE_上下文_创建() { 返回 [[]] }  // [非空变量名列表]

函数 NCE_记录非空(ctx, 变量名) {
    定义 可变 i = 0
    当 (i < 计数(ctx[0])) {
        如果 (ctx[0][i] == 变量名) { 返回 空 }
        i = i + 1
    }
    追加(ctx[0], 变量名)
}

函数 NCE_是非空(ctx, 变量名) {
    定义 可变 i = 0
    当 (i < 计数(ctx[0])) {
        如果 (ctx[0][i] == 变量名) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// 条件 `如果 (x != 空)` → 在真分支里记录 x 非空
函数 NCE_处理条件(ctx, 条件节点) {
    如果 (条件节点 == 空 或 计数(条件节点) == 0) { 返回 空 }
    // 检测 `x != 空` 模式
    如果 (条件节点[0] == 节点_二元 且 计数(条件节点) >= 4) {  // 二元运算
        如果 (条件节点[1] == 7) {  // != 运算符
            定义 左 = 条件节点[2]
            定义 右 = 条件节点[3]
            // 检查 右 是否为 空
            如果 (是列表(右) 且 右[0] == 节点_二元 且 右[1] == 空) {
                如果 (是列表(左) 且 左[0] == 标记_名称 且 计数(左) >= 2) {
                    NCE_记录非空(ctx, 左[1])  // 记录变量名非空
                }
            }
        }
    }
}

// 使用后释放检测（UAF）基础设施
// 记录对象的生命周期状态

定义 对象_活跃 = 10
定义 对象_已释放 = 11
定义 对象_未知 = 12

定义 可变 _UAF_对象状态 = 字典()  // 对象ID → 状态

函数 UAF_重置() { _UAF_对象状态 = 字典() }

函数 UAF_记录分配(对象ID) {
    字典设(_UAF_对象状态, 转字符串(对象ID), 对象_活跃)
}

函数 UAF_记录释放(对象ID) {
    如果 (字典取(_UAF_对象状态, 转字符串(对象ID)) == 对象_活跃) {
        字典设(_UAF_对象状态, 转字符串(对象ID), 对象_已释放)
    }
}

函数 UAF_检查使用(对象ID) {
    定义 状态 = 字典取(_UAF_对象状态, 转字符串(对象ID))
    如果 (状态 == 空) { 返回 对象_未知 }
    如果 (状态 == 对象_已释放) { 返回 对象_已释放 }
    返回 对象_活跃
}

// 安全分析报告
函数 内存安全_分析报告() {
    定义 可变 报告 = []
    追加(报告, ["边界检查消除", "分析完成"])
    追加(报告, ["空值检查消除", "分析完成"])
    追加(报告, ["使用后释放", "基础检测就绪"])
    返回 报告
}

// 全局统计
定义 可变 _BCE_消除次数 = 0
定义 可变 _BCE_保留次数 = 0
定义 可变 _NCE_消除次数 = 0
定义 可变 _UAF_检测次数 = 0

函数 BCE_记录消除() { _BCE_消除次数 = _BCE_消除次数 + 1 }
函数 BCE_记录保留() { _BCE_保留次数 = _BCE_保留次数 + 1 }
函数 NCE_记录消除() { _NCE_消除次数 = _NCE_消除次数 + 1 }
函数 UAF_记录检测() { _UAF_检测次数 = _UAF_检测次数 + 1 }

函数 内存安全_统计() {
    返回 [_BCE_消除次数, _BCE_保留次数, _NCE_消除次数, _UAF_检测次数]
}

// M11: 统一安全验证报告链
// 聚合效果系统、能力系统、内存安全、形式化验证的报告

定义 可变 _安全_越界证明数 = 0
定义 可变 _安全_空值证明数 = 0
定义 可变 _安全_生命周期违规 = 0
定义 可变 _安全_能力违规 = 0
定义 可变 _安全_效果违规 = 0
定义 可变 _安全_红项 = 0

函数 安全_记录越界证明() { _安全_越界证明数 = _安全_越界证明数 + 1 }
函数 安全_记录空值证明() { _安全_空值证明数 = _安全_空值证明数 + 1 }
函数 安全_记录生命周期违规() { _安全_生命周期违规 = _安全_生命周期违规 + 1 }
函数 安全_记录能力违规() { _安全_能力违规 = _安全_能力违规 + 1 }
函数 安全_记录效果违规() { _安全_效果违规 = _安全_效果违规 + 1 }
函数 安全_记录红项() { _安全_红项 = _安全_红项 + 1 }

函数 安全_总违规数() {
    返回 _安全_生命周期违规 + _安全_能力违规 + _安全_效果违规 + _安全_红项
}

// Profile安全门控
// 不同profile的安全阻塞等级
定义 安全门控_宽松 = 0
定义 安全门控_标准 = 1
定义 安全门控_严格 = 2

定义 可变 _安全门控等级 = 安全门控_标准

函数 安全门控_设置(等级) { _安全门控等级 = 等级 }
函数 安全门控_获取() { 返回 _安全门控等级 }

函数 安全门控_应阻塞() {
    如果 (_安全门控等级 == 安全门控_宽松) { 返回 假 }
    如果 (_安全门控等级 == 安全门控_标准) { 返回 _安全_红项 > 0 }
    返回 安全_总违规数() > 0
}

函数 安全门控名(等级) {
    如果 (等级 == 安全门控_宽松) { 返回 "宽松" }
    如果 (等级 == 安全门控_标准) { 返回 "标准" }
    如果 (等级 == 安全门控_严格) { 返回 "严格" }
    返回 "unknown"
}

// 统一安全报告
函数 安全_统一报告() {
    定义 可变 r = 字典()
    字典设(r, "门控等级", 安全门控名(_安全门控等级))
    字典设(r, "应阻塞", 转字符串(安全门控_应阻塞()))
    字典设(r, "越界证明", 转字符串(_安全_越界证明数))
    字典设(r, "空值证明", 转字符串(_安全_空值证明数))
    字典设(r, "生命周期违规", 转字符串(_安全_生命周期违规))
    字典设(r, "能力违规", 转字符串(_安全_能力违规))
    字典设(r, "效果违规", 转字符串(_安全_效果违规))
    字典设(r, "红项", 转字符串(_安全_红项))
    字典设(r, "总违规", 转字符串(安全_总违规数()))
    字典设(r, "BCE消除", 转字符串(_BCE_消除次数))
    字典设(r, "NCE消除", 转字符串(_NCE_消除次数))
    字典设(r, "UAF检测", 转字符串(_UAF_检测次数))
    返回 r
}

函数 安全_打印报告() {
    定义 r = 安全_统一报告()
}

函数 安全_重置() {
    _安全_越界证明数 = 0
    _安全_空值证明数 = 0
    _安全_生命周期违规 = 0
    _安全_能力违规 = 0
    _安全_效果违规 = 0
    _安全_红项 = 0
}

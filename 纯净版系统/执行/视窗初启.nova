// §4 初始化

函数 Windows兼容_初始化() {
    如果 (Win32_已初始化) { 返回 }

    PE_已加载模块 = []

    // 注册内置DLL(Win32 接口翻译)
    注册_内置DLL_kernel32()
    注册_内置DLL_ntdll()
    注册_内置DLL_user32()
    注册_内置DLL_gdi32()
    注册_内置DLL_msvcrt()
    注册_内置DLL_advapi32()
    注册_内置DLL_ws2_32()

    Win32_已初始化 = 真
    内核信息("Win32兼容: 初始化完成 内置DLL=" + 整数转字符串(计数(PE_已加载模块)))
}

// §5 PE加载器 — 加载.exe文件

函数 Windows_执行(路径, 参数, 环境变量) {
    如果 (!Win32_已初始化) { Windows兼容_初始化() }

    内核信息("Win32: 加载 " + 路径)

    // 读取文件
    定义 fd = vfs_open(路径, 0)
    如果 (fd < 0) { 返回 错误_文件不存在 }

    定义 头缓冲 = 分配内存(4096)
    vfs_read(fd, 头缓冲, 4096)

    // 验证DOS头 "MZ"
    定义 dos_magic = 内存读16(头缓冲)
    如果 (dos_magic != PE_DOS_MAGIC) {
        vfs_close(fd)
        内核警告("Win32: 不是有效的PE文件(缺少MZ头)")
        返回 错误_格式
    }

    // 获取PE头偏移
    定义 pe_offset = 内存读32(头缓冲 + PE_DOS_LFANEW)

    // 读取PE签名
    定义 pe_sig = 内存读32(头缓冲 + pe_offset)
    如果 (pe_sig != PE_SIGNATURE) {
        vfs_close(fd)
        内核警告("Win32: 无效PE签名")
        返回 错误_格式
    }

    // COFF文件头(pe_offset + 4, 20字节)
    定义 coff = 头缓冲 + pe_offset + 4
    定义 machine = 内存读16(coff)
    定义 节数 = 内存读16(coff + 2)
    定义 opt_size = 内存读16(coff + 16)
    定义 特征 = 内存读16(coff + 18)

    定义 是64位 = (machine == IMAGE_FILE_MACHINE_AMD64)
    如果 (!是64位 && machine != IMAGE_FILE_MACHINE_I386) {
        vfs_close(fd)
        内核警告("Win32: 不支持的架构 " + 整数转十六进制(machine))
        返回 错误_格式
    }

    // Optional Header
    定义 opt = coff + 20
    定义 opt_magic = 内存读16(opt)

    定义 模块 = PE模块 {}
    模块.路径 = 路径
    模块.名称 = 提取文件名(路径)
    模块.是DLL = (特征 & 0x2000) != 0
    模块.是64位 = 是64位
    模块.节列表 = []
    模块.导入表 = []
    模块.导出表 = []

    如果 (是64位) {
        模块.入口点 = 内存读32(opt + 16)
        模块.映像大小 = 内存读32(opt + 56)
        模块.首选基址 = 内存读64(opt + 24)
    } 否则 {
        模块.入口点 = 内存读32(opt + 16)
        模块.映像大小 = 内存读32(opt + 56)
        模块.首选基址 = 内存读32(opt + 28)
    }

    // 分配内存空间
    模块.基地址 = Nova内存映射_分配(模块.映像大小)
    如果 (模块.基地址 == 0) {
        模块.基地址 = 模块.首选基址
        Nova内存映射_映射(模块.基地址, 模块.映像大小, 7)  // RWX
    }
    内存填零(模块.基地址, 模块.映像大小)

    // 复制PE头到映像基地址
    内存拷贝(模块.基地址, 头缓冲, 4096)

    // 解析节表(紧接在Optional Header之后)
    定义 节表起始 = coff + 20 + opt_size
    定义 可变 i = 0
    当 (i < 节数) {
        定义 节_addr = 节表起始 + i * 40
        定义 节 = PE节 {}
        节.名称 = 读取固定字符串(节_addr, 8)
        节.虚拟大小 = 内存读32(节_addr + 8)
        节.虚拟地址 = 内存读32(节_addr + 12)
        节.文件大小 = 内存读32(节_addr + 16)
        节.文件偏移 = 内存读32(节_addr + 20)
        节.标志 = 内存读32(节_addr + 36)

        // 映射节到内存
        如果 (节.文件大小 > 0) {
            vfs_lseek(fd, 节.文件偏移, 0)
            vfs_read(fd, 模块.基地址 + 节.虚拟地址, 节.文件大小)
        }

        追加(模块.节列表, 节)
        i = i + 1
    }

    vfs_close(fd)
    释放内存(头缓冲)

    // 执行基址重定位(如果加载地址不是首选地址)
    如果 (模块.基地址 != 模块.首选基址) {
        PE_重定位(模块)
    }

    // 解析导入表并绑定
    PE_处理导入(模块)

    模块.入口点 = 模块.基地址 + 模块.入口点
    追加(PE_已加载模块, 模块)
    Win32_程序数 = Win32_程序数 + 1

    内核信息("Win32: 加载完成 " + 模块.名称 +
             " 基址=" + 整数转十六进制(模块.基地址) +
             " 入口=" + 整数转十六进制(模块.入口点) +
             " 节=" + 整数转字符串(节数) +
             " " + (如果 (是64位) { "64位" } 否则 { "32位" }))

    // 跳转到入口点执行
    返回 模块.入口点
}

定义 可变 AI_视窗初启_调用数 = 0
定义 可变 AI_视窗初启_异常数 = 0

函数 AI_视窗初启_监控() {
    AI_视窗初启_调用数 = AI_视窗初启_调用数 + 1
    返回 AI_视窗初启_异常数 == 0
}

函数 AI_视窗初启_健康检查() {
    如果 (AI_视窗初启_调用数 > 0 && AI_视窗初启_异常数 * 100 / AI_视窗初启_调用数 > 10) {
        返回 假
    }
    返回 真
}

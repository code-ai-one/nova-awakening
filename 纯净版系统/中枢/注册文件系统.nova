// NovaOS 文件系统调用分发引擎 — 完整实现
// 职责: 调用号注册/分发/权限校验/参数验证/审计日志/
//       速率限制/调用链追踪/错误记录/AI异常检测
// 原创理论: Nova多层系统调用安全网关(MSSG)
//         通过"验证-审计-限流-执行-审计"五层管道，
//         实现系统调用级别的安全防护与AI异常感知

导入("./类型定义.nova")
导入("./错误码.nova")
导入("../推理/智能渠道.nova")
导入("../感知/内核直连层.nova")
导入("./内核打印.nova")
导入("../推理/值乘.nova")
导入("./内存初始化.nova")
导入("./每处理器.nova")

定义 调用号_读取 = 0
定义 调用号_写入 = 1
定义 调用号_打开 = 2
定义 调用号_关闭 = 3
定义 调用号_状态 = 4
定义 调用号_文件状态 = 5
定义 调用号_定位 = 8
定义 调用号_管道 = 22
定义 调用号_复制描述 = 32
定义 调用号_同步 = 74
定义 调用号_截断 = 76
定义 调用号_读目录 = 78
定义 调用号_重命名 = 82
定义 调用号_创建目录 = 83
定义 调用号_删除目录 = 84
定义 调用号_链接 = 86
定义 调用号_删除文件 = 87
定义 调用号_符号链接 = 88
定义 调用号_读链接 = 89
定义 调用号_改权限 = 90
定义 调用号_改属主 = 92
定义 最大文件调用 = 100

定义 权限_无 = 0
定义 权限_读 = 1
定义 权限_写 = 2
定义 权限_管理 = 4
定义 权限_ROOT = 8

定义 审计_无 = 0
定义 审计_基本 = 1
定义 审计_详细 = 2
定义 审计_完整 = 3

定义 可变 文件调用表 = 0
定义 可变 调用计数表 = 0
定义 可变 调用权限表 = 0      // 每个调用号所需最低权限
定义 可变 调用审计级表 = 0    // 每个调用号的审计级别
定义 可变 调用限速表 = 0      // 每个调用号的速率限制(ms间隔)
定义 可变 调用上次时间表 = 0  // 每个调用号的上次执行时间
定义 可变 调用错误表 = 0      // 每个调用号的错误计数
定义 可变 总调用次数 = 0
定义 可变 总错误次数 = 0
定义 可变 权限拒绝次数 = 0
定义 可变 参数错误次数 = 0
定义 可变 限速拒绝次数 = 0
定义 可变 审计记录数 = 0
定义 可变 AI异常检测次数 = 0
定义 可变 审计环形缓冲 = 0
定义 可变 审计缓冲大小 = 256
定义 可变 审计写指针 = 0

// §1 初始化与注册

函数 注册文件系统调用() {
    // 分配所有表
    文件调用表 = 堆_分配(最大文件调用 * 8)
    调用计数表 = 堆_分配(最大文件调用 * 4)
    调用权限表 = 堆_分配(最大文件调用 * 4)
    调用审计级表 = 堆_分配(最大文件调用 * 4)
    调用限速表 = 堆_分配(最大文件调用 * 4)
    调用上次时间表 = 堆_分配(最大文件调用 * 8)
    调用错误表 = 堆_分配(最大文件调用 * 4)
    审计环形缓冲 = 堆_分配(审计缓冲大小 * 32) // 每条审计记录32字节

    // 清零所有表
    定义 可变 序号 = 0
    当 (序号 < 最大文件调用) {
        内存_写64(文件调用表 + 序号 * 8, 0)
        内存_写32(调用计数表 + 序号 * 4, 0)
        内存_写32(调用权限表 + 序号 * 4, 权限_无)
        内存_写32(调用审计级表 + 序号 * 4, 审计_基本)
        内存_写32(调用限速表 + 序号 * 4, 0)  // 0=不限速
        内存_写64(调用上次时间表 + 序号 * 8, 0)
        内存_写32(调用错误表 + 序号 * 4, 0)
        序号 = 序号 + 1
    }

    // 注册所有文件系统调用
    文件调用_注册完整(调用号_打开, 系统_打开文件, 权限_读, 审计_详细)
    文件调用_注册完整(调用号_关闭, 系统_关闭文件, 权限_无, 审计_基本)
    文件调用_注册完整(调用号_读取, 系统_读取文件, 权限_读, 审计_基本)
    文件调用_注册完整(调用号_写入, 系统_写入文件, 权限_写, 审计_详细)
    文件调用_注册完整(调用号_定位, 系统_定位文件, 权限_读, 审计_基本)
    文件调用_注册完整(调用号_状态, 系统_文件状态, 权限_读, 审计_基本)
    文件调用_注册完整(调用号_创建目录, 系统_创建目录, 权限_写, 审计_详细)
    文件调用_注册完整(调用号_删除目录, 系统_删除目录, 权限_写, 审计_完整)
    文件调用_注册完整(调用号_删除文件, 系统_删除文件, 权限_写, 审计_完整)
    文件调用_注册完整(调用号_重命名, 系统_重命名, 权限_写, 审计_完整)
    文件调用_注册完整(调用号_读目录, 系统_读目录, 权限_读, 审计_基本)
    文件调用_注册完整(调用号_改权限, 系统_改权限, 权限_管理, 审计_完整)
    文件调用_注册完整(调用号_截断, 系统_截断文件, 权限_写, 审计_详细)
    文件调用_注册完整(调用号_同步, 系统_同步文件, 权限_写, 审计_基本)
    文件调用_注册完整(调用号_复制描述, 系统_复制描述符, 权限_读, 审计_基本)
    文件调用_注册完整(调用号_管道, 系统_创建管道, 权限_写, 审计_详细)
    文件调用_注册完整(调用号_链接, 系统_硬链接, 权限_写, 审计_完整)
    文件调用_注册完整(调用号_符号链接, 系统_符号链接, 权限_写, 审计_详细)
    文件调用_注册完整(调用号_读链接, 系统_读链接, 权限_读, 审计_基本)

    内核打印("文件系统调用注册完成, 共注册19个调用\n")
}

// §2 注册接口

函数 文件调用_注册(号, 处理函数) {
    如果 (号 >= 最大文件调用 || 文件调用表 == 0) { 返回 }
    内存_写64(文件调用表 + 号 * 8, 处理函数)
}

函数 文件调用_注册完整(号, 处理函数, 所需权限, 审计级) {
    如果 (号 >= 最大文件调用) { 返回 }
    内存_写64(文件调用表 + 号 * 8, 处理函数)
    内存_写32(调用权限表 + 号 * 4, 所需权限)
    内存_写32(调用审计级表 + 号 * 4, 审计级)
}

函数 文件调用_取消注册(号) {
    如果 (号 >= 最大文件调用 || 文件调用表 == 0) { 返回 }
    内存_写64(文件调用表 + 号 * 8, 0)
    内存_写32(调用权限表 + 号 * 4, 0)
}

函数 文件调用_设置限速(号, 最小间隔ms) {
    如果 (号 >= 最大文件调用 || 调用限速表 == 0) { 返回 }
    内存_写32(调用限速表 + 号 * 4, 最小间隔ms)
}

函数 文件调用_确保已初始化() {
    如果 (文件调用表 != 0
        && 调用权限表 != 0
        && 调用限速表 != 0
        && 调用上次时间表 != 0
        && 调用错误表 != 0) {
        返回 0
    }
    注册文件系统调用()
    如果 (文件调用表 == 0
        || 调用权限表 == 0
        || 调用限速表 == 0
        || 调用上次时间表 == 0
        || 调用错误表 == 0) {
        返回 错误_内存不足
    }
    返回 0
}

// §3 核心分发引擎 (五层管道)

函数 文件调用_分发(号, 参数一, 参数二, 参数三) {
    总调用次数 = 总调用次数 + 1
    定义 调用时间 = 当前时间_毫秒()

    定义 初始化结果 = 文件调用_确保已初始化()
    如果 (初始化结果 < 0) {
        总错误次数 = 总错误次数 + 1
        参数错误次数 = 参数错误次数 + 1
        返回 初始化结果
    }

    如果 (号 >= 最大文件调用 || 文件调用表 == 0) {
        总错误次数 = 总错误次数 + 1
        参数错误次数 = 参数错误次数 + 1
        返回 错误_无效参数
    }

    定义 处理 = 内存_读64(文件调用表 + 号 * 8)
    如果 (处理 == 0) {
        总错误次数 = 总错误次数 + 1
        调用错误_增加(号)
        返回 0 - 38
    }

    定义 权限检查 = 文件调用_检查权限(号)
    如果 (权限检查 < 0) {
        权限拒绝次数 = 权限拒绝次数 + 1
        总错误次数 = 总错误次数 + 1
        审计_记录事件(号, 0, 调用时间, 权限检查)
        返回 权限检查
    }

    定义 限速检查 = 文件调用_检查限速(号, 调用时间)
    如果 (限速检查 < 0) {
        限速拒绝次数 = 限速拒绝次数 + 1
        总错误次数 = 总错误次数 + 1
        返回 限速检查
    }

    审计_记录进入(号, 参数一, 调用时间)

    内存_写32(调用计数表 + 号 * 4, 内存_读32(调用计数表 + 号 * 4) + 1)
    内存_写64(调用上次时间表 + 号 * 8, 调用时间)
    定义 结果 = 处理(参数一, 参数二, 参数三)

    审计_记录事件(号, 参数一, 调用时间, 结果)

    如果 (结果 < 0) {
        总错误次数 = 总错误次数 + 1
        调用错误_增加(号)
    }

    返回 结果
}

// §4 权限校验

函数 文件调用_检查权限(号) {
    定义 初始化结果 = 文件调用_确保已初始化()
    如果 (初始化结果 < 0) { 返回 初始化结果 }
    定义 所需 = 内存_读32(调用权限表 + 号 * 4)
    如果 (所需 == 权限_无) { 返回 0 }  // 无权限要求

    // 获取当前进程权限
    定义 当前权限 = 获取当前进程权限()

    // root全通
    如果 (当前权限 & 权限_ROOT) { 返回 0 }

    // 检查具体权限位
    如果 ((所需 & 权限_读) && !(当前权限 & 权限_读)) {
        返回 错误_权限不足
    }
    如果 ((所需 & 权限_写) && !(当前权限 & 权限_写)) {
        返回 错误_权限不足
    }
    如果 ((所需 & 权限_管理) && !(当前权限 & 权限_管理)) {
        返回 错误_权限不足
    }
    返回 0
}

函数 获取当前进程权限() {
    // 从当前进程控制块获取权限位
    定义 进程 = 获取当前进程()
    如果 (进程 == 空) { 返回 权限_无 }
    定义 uid = 进程.有效uid
    如果 (uid == 0) { 返回 权限_ROOT | 权限_管理 | 权限_写 | 权限_读 }
    返回 进程.文件权限位
}

// §5 速率限制

函数 文件调用_检查限速(号, 当前时间) {
    定义 初始化结果 = 文件调用_确保已初始化()
    如果 (初始化结果 < 0) { 返回 初始化结果 }
    定义 最小间隔 = 内存_读32(调用限速表 + 号 * 4)
    如果 (最小间隔 == 0) { 返回 0 }  // 不限速

    定义 上次时间 = 内存_读64(调用上次时间表 + 号 * 8)
    如果 (上次时间 > 0 && (当前时间 - 上次时间) < 最小间隔) {
        返回 错误_操作过频
    }
    返回 0
}

// §6 审计日志

函数 审计_记录进入(号, 参数, 时间) {
    如果 (调用审计级表 == 0) { 返回 }
    定义 审计级 = 内存_读32(调用审计级表 + 号 * 4)
    如果 (审计级 < 审计_详细) { 返回 }
    // 记录进入事件
    审计_写环形(号, 参数, 时间, 0)  // 0表示进入
}

函数 审计_记录事件(号, 参数, 时间, 结果) {
    如果 (调用审计级表 == 0) { 返回 }
    定义 审计级 = 内存_读32(调用审计级表 + 号 * 4)
    如果 (审计级 < 审计_基本) { 返回 }
    // 错误结果始终记录
    如果 (结果 < 0 || 审计级 >= 审计_详细) {
        审计_写环形(号, 参数, 时间, 结果)
    }
}

函数 审计_写环形(号, 参数, 时间, 结果) {
    如果 (审计环形缓冲 == 0) { 返回 }
    // 每条记录32字节: [4字节调用号][8字节参数][8字节时间][4字节结果][4字节PID][4字节预留]
    定义 偏移 = 审计写指针 * 32
    内存_写32(审计环形缓冲 + 偏移, 号)
    内存_写64(审计环形缓冲 + 偏移 + 4, 参数)
    内存_写64(审计环形缓冲 + 偏移 + 12, 时间)
    内存_写32(审计环形缓冲 + 偏移 + 20, 结果)
    定义 进程 = 获取当前进程()
    如果 (进程 != 空) {
        内存_写32(审计环形缓冲 + 偏移 + 24, 进程.pid)
    }

    审计写指针 = (审计写指针 + 1) % 审计缓冲大小
    审计记录数 = 审计记录数 + 1
}

函数 审计_读取记录(索引) {
    如果 (审计环形缓冲 == 0 || 索引 >= 审计缓冲大小) { 返回 空 }
    定义 偏移 = 索引 * 32
    返回 [
        内存_读32(审计环形缓冲 + 偏移),       // 调用号
        内存_读64(审计环形缓冲 + 偏移 + 4),   // 参数
        内存_读64(审计环形缓冲 + 偏移 + 12),  // 时间
        内存_读32(审计环形缓冲 + 偏移 + 20),  // 结果
        内存_读32(审计环形缓冲 + 偏移 + 24)   // PID
    ]
}

// §7 错误跟踪

函数 调用错误_增加(号) {
    如果 (调用错误表 == 0 || 号 >= 最大文件调用) { 返回 }
    内存_写32(调用错误表 + 号 * 4, 内存_读32(调用错误表 + 号 * 4) + 1)
}

函数 调用错误_获取(号) {
    如果 (调用错误表 == 0 || 号 >= 最大文件调用) { 返回 0 }
    返回 内存_读32(调用错误表 + 号 * 4)
}

函数 文件调用_获取计数(号) {
    如果 (号 >= 最大文件调用 || 调用计数表 == 0) { 返回 0 }
    返回 内存_读32(调用计数表 + 号 * 4)
}

函数 文件调用_获取错误率(号) {
    定义 总数 = 文件调用_获取计数(号)
    如果 (总数 == 0) { 返回 0 }
    定义 错误数 = 调用错误_获取(号)
    返回 (错误数 * 10000) / 总数  // 万分比
}

// §8 【Nova创新】AI调用异常检测
// 原创理论: 多层系统调用安全网关(MSSG)
// 通过调用频率/错误率/时序模式的AI分析，
// 实时检测恶意调用、异常访问模式、潜在攻击

函数 文件调用_AI异常检测() {
    AI异常检测次数 = AI异常检测次数 + 1
    定义 bus = 全局AI总线
    如果 (bus == 空) {
        返回 文件调用_启发式异常检测()
    }

    定义 特征 = Tensor_创建(16)
    如果 (特征 == 空) { 返回 文件调用_启发式异常检测() }
    Tensor_清零(特征, 16)

    // 构建特征向量: 各调用的频率、错误率
    Tensor_写(特征, 0, 总调用次数)
    Tensor_写(特征, 1, 总错误次数)
    Tensor_写(特征, 2, 权限拒绝次数)
    Tensor_写(特征, 3, 限速拒绝次数)
    Tensor_写(特征, 4, 文件调用_获取计数(调用号_打开))
    Tensor_写(特征, 5, 文件调用_获取计数(调用号_读取))
    Tensor_写(特征, 6, 文件调用_获取计数(调用号_写入))
    Tensor_写(特征, 7, 文件调用_获取计数(调用号_删除文件))
    Tensor_写(特征, 8, 文件调用_获取错误率(调用号_打开))
    Tensor_写(特征, 9, 文件调用_获取错误率(调用号_写入))

    定义 异常分 = AI总线_异常检测(bus, "fs_syscall_anomaly", 特征)
    Tensor_释放(特征)

    // 0=正常, 1=可疑, 2=异常
    如果 (异常分 >= 7000) { 返回 2 }
    如果 (异常分 >= 4000) { 返回 1 }
    返回 0
}

函数 文件调用_启发式异常检测() {
    定义 可变 异常计 = 0
    // 错误率过高
    如果 (总调用次数 > 100) {
        定义 错误率 = (总错误次数 * 100) / 总调用次数
        如果 (错误率 > 30) { 异常计 = 异常计 + 2 }
        否则 如果 (错误率 > 15) { 异常计 = 异常计 + 1 }
    }
    // 权限拒绝过多
    如果 (权限拒绝次数 > 50) { 异常计 = 异常计 + 1 }
    // 删除操作异常频繁
    如果 (文件调用_获取计数(调用号_删除文件) > 200) {
        异常计 = 异常计 + 1
    }

    如果 (异常计 >= 3) { 返回 2 }
    如果 (异常计 >= 1) { 返回 1 }
    返回 0
}

// §9 统计接口

函数 文件系统调用_完整统计() {
    返回 [
        总调用次数,
        总错误次数,
        权限拒绝次数,
        参数错误次数,
        限速拒绝次数,
        审计记录数,
        AI异常检测次数,
        文件调用_获取计数(调用号_打开),
        文件调用_获取计数(调用号_读取),
        文件调用_获取计数(调用号_写入),
        文件调用_获取计数(调用号_关闭),
        文件调用_获取计数(调用号_删除文件)
    ]
}

函数 文件调用_打印诊断() {
    内核打印("═══ 文件系统调用诊断 ═══\n")
    内核打印("总调用=", 总调用次数, " 总错误=", 总错误次数, "\n")
    内核打印("权限拒绝=", 权限拒绝次数, " 参数错误=", 参数错误次数, " 限速拒绝=", 限速拒绝次数, "\n")
    内核打印("审计记录=", 审计记录数, " AI检测=", AI异常检测次数, "\n")
    内核打印("打开=", 文件调用_获取计数(调用号_打开), " 读=", 文件调用_获取计数(调用号_读取), "\n")
    内核打印("写=", 文件调用_获取计数(调用号_写入), " 关闭=", 文件调用_获取计数(调用号_关闭), "\n")
    内核打印("删除=", 文件调用_获取计数(调用号_删除文件), " 重命名=", 文件调用_获取计数(调用号_重命名), "\n")
}

// §10 调用频率限制与热点追踪

定义 可变 调用热点_最大号 = 0
定义 可变 调用热点_最大次数 = 0

函数 文件调用_热点追踪() {
    // 找出调用频率最高的系统调用
    如果 (调用计数表 == 0) { 返回 }
    调用热点_最大号 = 0
    调用热点_最大次数 = 0
    定义 可变 i = 0
    当 (i < 最大文件调用) {
        定义 c = 文件调用_获取计数(i)
        如果 (c > 调用热点_最大次数) {
            调用热点_最大号 = i
            调用热点_最大次数 = c
        }
        i = i + 1
    }
}

函数 文件调用_频率检查(号, 阈值) {
    // 检查调用频率是否超过阈值
    定义 c = 文件调用_获取计数(号)
    如果 (c > 阈值) {
        内核警告("文件调用 %d 频率异常: %d > %d\n", 号, c, 阈值)
        返回 真
    }
    返回 假
}

函数 文件调用_重置计数() {
    如果 (调用计数表 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 最大文件调用) {
        内存_写32(调用计数表 + i * 4, 0)
        i = i + 1
    }
    总调用次数 = 0
    总错误次数 = 0
    权限拒绝次数 = 0
    参数错误次数 = 0
    限速拒绝次数 = 0
    AI异常检测次数 = 0
}

// MSSG — Multi-layer System Syscall Gateway
// 公理1(分层安全): 权限→参数→限速→AI多层安全网关
// 公理2(审计完备): 每次调用均留下审计记录
// 公理3(异常可测): AI+启发式双模式异常检测
// 定理1(热点收敛): 热点调用必定被发现并报警
// 定理2(限速公平): 同一调用的限速对所有进程等同应用

// §11 系统调用名称查询

函数 文件调用_名称(号) {
    如果 (号 == 调用号_打开) { 返回 "打开" }
    如果 (号 == 调用号_读取) { 返回 "读取" }
    如果 (号 == 调用号_写入) { 返回 "写入" }
    如果 (号 == 调用号_关闭) { 返回 "关闭" }
    如果 (号 == 调用号_删除文件) { 返回 "删除" }
    如果 (号 == 调用号_重命名) { 返回 "重命名" }
    返回 "未知"
}

函数 文件调用_获取热点信息() {
    文件调用_热点追踪()
    返回 [调用热点_最大号, 调用热点_最大次数, 文件调用_名称(调用热点_最大号)]
}

函数 注册文件系统_统计() {
    返回 {
        总调用次数: 总调用次数,
        总错误次数: 总错误次数,
        权限拒绝次数: 权限拒绝次数,
        参数错误次数: 参数错误次数,
        限速拒绝次数: 限速拒绝次数,
        AI异常检测次数: AI异常检测次数,
        调用热点最大次数: 调用热点_最大次数
    }
}

函数 注册文件系统_健康评估() {
    定义 可变 问题 = []
    如果 (总错误次数 > 100) { 追加(问题, "总错误次数=" + 总错误次数) }
    如果 (参数错误次数 > 100) { 追加(问题, "参数错误次数=" + 参数错误次数) }
    返回 计数(问题) == 0
}

函数 注册文件系统_综合报告() {
    打印("[注册文件系统] ═══ 综合报告 ═══")
    打印("  总调用次数: " + 总调用次数)
    打印("  总错误次数: " + 总错误次数)
    打印("  权限拒绝次数: " + 权限拒绝次数)
    打印("  参数错误次数: " + 参数错误次数)
    打印("  限速拒绝次数: " + 限速拒绝次数)
    打印("  AI异常检测次数: " + AI异常检测次数)
    打印("  调用热点_最大次数: " + 调用热点_最大次数)
    打印("  健康: " + 如果 (注册文件系统_健康评估()) { "正常" } 否则 { "异常" })
}

函数 注册文件系统_全局重置() {
    总调用次数 = 0
    总错误次数 = 0
    权限拒绝次数 = 0
    参数错误次数 = 0
    限速拒绝次数 = 0
    AI异常检测次数 = 0
    调用热点_最大次数 = 0
    打印("[注册文件系统] 统计已重置")
    返回 0
}

// §7 能力探测 — 通过MMIO读取图处内部寄存器
// ★ 这是图处驱动的核心: 不是厂商接口, 是直接读图处寄存器
//   图处的寄存器通过BAR0映射到物理内存, 内核直接MMIO读写

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 图处_探测能力(gpu) {
    如果 (gpu.BAR0_地址 == 0) { 返回 }

    // 将BAR0映射到内核虚拟地址空间
    定义 mmio_base = ioremap(gpu.BAR0_地址, gpu.BAR0_大小)
    如果 (mmio_base == 0) { 返回 }

    如果 (gpu.厂商ID == 图处_VENDOR_NVIDIA) {
        // NVIDIA: 读取PMC寄存器获取图处信息
        // 0x000000: PMC_BOOT_0 — 芯片ID和修订
        定义 boot0 = MMIO读32(mmio_base + 0x000000)
        // 0x000100-0x000200: 图处参数寄存器
        // 估算显存: 读FBPA寄存器或通过BAR1大小推断
        gpu.显存大小_MB = gpu.BAR1_大小 / 1048576
        如果 (gpu.显存大小_MB == 0) { gpu.显存大小_MB = 256 }  // 回退

    } 否则 如果 (gpu.厂商ID == 图处_VENDOR_AMD) {
        // AMD: 读取MMIO_INDEX/MMIO_DATA间接寄存器
        // 或直接读BAR0偏移处的图处_HDP, GC, GNova受限能量网络等寄存器
        gpu.显存大小_MB = gpu.BAR1_大小 / 1048576
        如果 (gpu.显存大小_MB == 0) { gpu.显存大小_MB = 256 }

    } 否则 如果 (gpu.厂商ID == 图处_VENDOR_INTEL) {
        // Intel: 读取MCHBAR或GTTMMADR
        // 集成显卡显存从系统内存划分(GTT)
        gpu.显存大小_MB = 128  // 集成显卡默认共享

    } 否则 如果 (gpu.厂商ID == 图处_VENDOR_QEMU) {
        // QEMU bochs: 通过VBE寄存器探测
        // 端口0x01CE/0x01CF(VBE_DISPI_INDEX/DATA)
        端口写16(0x01CE, 0x00)  // VBE_DISPI_INDEX_ID
        定义 vbe_id = 端口读16(0x01CF)
        如果 (vbe_id >= 0xB0C0) {
            gpu.显存大小_MB = 16  // QEMU默认16MB显存
            // 读取分辨率能力
            端口写16(0x01CE, 0x01)  // INDEX_XRES
            端口写16(0x01CE, 0x02)  // INDEX_YRES
        }
    }

    iounmap(mmio_base, gpu.BAR0_大小)
}

// §8 图处设备选择

函数 图处_选择主设备() {
    // 选择主显示图处: 优先独立显卡, 其次集成
    定义 可变 最佳 = 空
    定义 可变 最佳计算 = 空
    定义 可变 最高能力 = 0

    定义 可变 i = 0
    当 (i < 计数(图处列表)) {
        定义 gpu = 图处列表[i]

        // 显示图处: 优先有DISPLAY能力的
        如果 ((gpu.能力 & 图处_CAP_DISPLAY) != 0) {
            如果 (最佳 == 空 || gpu.显存大小_MB > 最佳.显存大小_MB) {
                最佳 = gpu
            }
        }

        // 计算图处: 优先有COMPUTE+智能_ACCEL的
        如果 ((gpu.能力 & 图处_CAP_COMPUTE) != 0) {
            定义 能力分 = gpu.计算单元数 * 10
            如果 ((gpu.能力 & 图处_CAP_智能_ACCEL) != 0) { 能力分 = 能力分 + 5000 }
            如果 (能力分 > 最高能力) {
                最高能力 = 能力分
                最佳计算 = gpu
            }
        }

        i = i + 1
    }

    主图处 = 最佳
    计算图处 = 最佳计算
    如果 (计算图处 == 空) { 计算图处 = 主图处 }  // 回退: 用显示图处做计算

    如果 (主图处 != 空) {
        内核信息("图处主设备: " + 主图处.厂商名 + " " + 主图处.型号名 +
                 " 显存=" + 整数转字符串(主图处.显存大小_MB) + "MB")
    }
    如果 (计算图处 != 空 && 计算图处 != 主图处) {
        内核信息("图处计算: " + 计算图处.厂商名 + " " + 计算图处.型号名 +
                 " CU=" + 整数转字符串(计算图处.计算单元数))
    }
}

// §9 图处信息打印

函数 图处_打印信息(gpu) {
    内核信息("图处: [" + 整数转字符串(gpu.PCI总线) + ":" +
             整数转字符串(gpu.PCI设备) + "." + 整数转字符串(gpu.PCI功能) + "] " +
             gpu.厂商名 + " " + gpu.型号名 +
             " (0x" + 整数转十六进制(gpu.厂商ID) + ":0x" + 整数转十六进制(gpu.设备ID) + ")")
    内核信息("  BAR0=0x" + 整数转十六进制(gpu.BAR0_地址) +
             " 大小=" + 整数转字符串(gpu.BAR0_大小 / 1048576) + "MB" +
             " BAR1=0x" + 整数转十六进制(gpu.BAR1_地址) +
             " 大小=" + 整数转字符串(gpu.BAR1_大小 / 1048576) + "MB")
    定义 可变 能力字符串 = ""
    如果 ((gpu.能力 & 图处_CAP_2D) != 0)           { 能力字符串 = 能力字符串 + "2D " }
    如果 ((gpu.能力 & 图处_CAP_3D) != 0)           { 能力字符串 = 能力字符串 + "3D " }
    如果 ((gpu.能力 & 图处_CAP_COMPUTE) != 0)      { 能力字符串 = 能力字符串 + "Compute " }
    如果 ((gpu.能力 & 图处_CAP_智能_ACCEL) != 0)     { 能力字符串 = 能力字符串 + "AI " }
    如果 ((gpu.能力 & 图处_CAP_RAY_TRACE) != 0)    { 能力字符串 = 能力字符串 + "RT " }
    如果 ((gpu.能力 & 图处_CAP_VULKAN) != 0)       { 能力字符串 = 能力字符串 + "Vulkan " }
    内核信息("  能力: " + 能力字符串 + " 显存=" + 整数转字符串(gpu.显存大小_MB) + "MB")
}

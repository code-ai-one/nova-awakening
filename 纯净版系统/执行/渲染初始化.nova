// NovaOS 浏览器内核 · 第二层 · 渲染引擎
// 核心能力: 布局计算(Box Model/弹性/网格) → 绘制指令生成 → 图层合成

结构 渲染盒 {
    节点ID,    // u32 对应DOM节点
    // 内容区
    x,
    y,
    宽,
    高,
    // 盒模型
    外边距上,
    外边距右,
    外边距下,
    外边距左,
    内边距上,
    内边距右,
    内边距下,
    内边距左,
    边框宽,
    // 样式
    显示,
    位置,
    背景色,
    前景色,
    字号,
    圆角,
    透明度,
    Z序,
    // 树结构
    子盒,    // [] 子渲染盒ID列表
    父盒,
    图处层ID,    // u32 关联的图处渲染层
    需要独立层,    // 布尔 是否需要独立合成层
    脏,
}

结构 渲染树 {
    根盒,
    盒池,    // [] 所有渲染盒
    下一个ID,
    视口宽,
    视口高,
    滚动X,
    滚动Y,
    总盒数,
    脏,
}

定义 可变 渲染_树 = 空
定义 可变 渲染_已初始化 = 假

// §1 初始化

函数 渲染_初始化(视口宽, 视口高) {
    渲染_树 = 渲染树 {}
    渲染_树.盒池 = []
    渲染_树.下一个ID = 1
    渲染_树.视口宽 = 视口宽
    渲染_树.视口高 = 视口高
    渲染_树.滚动X = 0
    渲染_树.滚动Y = 0
    渲染_树.总盒数 = 0
    渲染_树.脏 = 真
    渲染_已初始化 = 真
}

// §2 渲染树构建 — 从DOM+CSS生成渲染盒

函数 渲染_构建树(文档) {
    渲染_树.盒池 = []
    渲染_树.下一个ID = 1
    渲染_树.总盒数 = 0

    // 从body开始构建
    定义 body = DOM_查找节点(文档, 文档.体节点)
    如果 (body == 空) {
        body = DOM_查找节点(文档, 文档.根节点)
    }
    如果 (body == 空) { 返回 }

    定义 根盒 = 渲染_创建盒(body, 文档)
    根盒.x = 0
    根盒.y = 0
    根盒.宽 = 渲染_树.视口宽
    渲染_树.根盒 = 根盒.节点ID

    // 递归构建子节点
    渲染_构建子盒(文档, body, 根盒)

    渲染_树.脏 = 真
}

函数 渲染_创建盒(节点, 文档) {
    定义 盒 = 渲染盒 {}
    盒.节点ID = 节点.ID
    盒.子盒 = []
    盒.脏 = 真
    盒.需要独立层 = 假
    盒.透明度 = 255

    // 计算CSS样式
    定义 样式 = CSS_计算节点样式(文档, 节点)

    // 应用样式到盒
    如果 (样式.有效) {
        定义 显示值 = 样式.属性值[CSS_显示]
        如果 (显示值 == "none") { 盒.显示 = 显示_无 }
        否则 如果 (显示值 == "inline") { 盒.显示 = 显示_行 }
        否则 如果 (显示值 == "inline-block") { 盒.显示 = 显示_行块 }
        否则 如果 (显示值 == "flex") { 盒.显示 = 显示_弹性 }
        否则 如果 (显示值 == "grid") { 盒.显示 = 显示_网格 }
        否则 { 盒.显示 = 显示_块 }

        盒.背景色 = CSS_解析颜色值(样式.属性值[CSS_背景色])
        盒.前景色 = CSS_解析颜色值(样式.属性值[CSS_前景色])
        盒.字号 = CSS_解析像素值(样式.属性值[CSS_字号])
        如果 (盒.字号 == 0) { 盒.字号 = 16 }

        // 尺寸
        定义 宽值 = 样式.属性值[CSS_宽度]
        如果 (字符串长度(宽值) > 0 && 宽值 != "auto") {
            盒.宽 = CSS_解析像素值(宽值)
        }
        定义 高值 = 样式.属性值[CSS_高度]
        如果 (字符串长度(高值) > 0 && 高值 != "auto") {
            盒.高 = CSS_解析像素值(高值)
        }

        // 外边距
        定义 边距值 = 样式.属性值[CSS_外边距]
        如果 (字符串长度(边距值) > 0) {
            定义 m = CSS_解析像素值(边距值)
            盒.外边距上 = m; 盒.外边距右 = m; 盒.外边距下 = m; 盒.外边距左 = m
        }

        // 内边距
        定义 内边距值 = 样式.属性值[CSS_内边距]
        如果 (字符串长度(内边距值) > 0) {
            定义 p = CSS_解析像素值(内边距值)
            盒.内边距上 = p; 盒.内边距右 = p; 盒.内边距下 = p; 盒.内边距左 = p
        }

        // 圆角
        盒.圆角 = CSS_解析像素值(样式.属性值[CSS_圆角])

        // 需要独立合成层的条件
        如果 (字符串长度(样式.属性值[CSS_变换]) > 0) { 盒.需要独立层 = 真 }
        如果 (盒.透明度 < 255) { 盒.需要独立层 = 真 }
    }

    追加(渲染_树.盒池, 盒)
    渲染_树.总盒数 = 渲染_树.总盒数 + 1
    返回 盒
}

函数 渲染_构建子盒(文档, 节点, 父盒) {
    定义 可变 i = 0
    当 (i < 计数(节点.子节点)) {
        定义 子节点 = DOM_查找节点(文档, 节点.子节点[i])
        如果 (子节点 != 空) {
            如果 (子节点.类型 == 节点_元素) {
                定义 子盒 = 渲染_创建盒(子节点, 文档)
                如果 (子盒.显示 != 显示_无) {
                    子盒.父盒 = 父盒.节点ID
                    追加(父盒.子盒, 子盒.节点ID)
                    渲染_构建子盒(文档, 子节点, 子盒)
                }
            } 否则 如果 (子节点.类型 == 节点_文本) {
                // 文本节点 → 创建匿名行盒
                如果 (字符串长度(子节点.文本内容) > 0) {
                    定义 文本盒 = 渲染盒 {}
                    文本盒.节点ID = 子节点.ID
                    文本盒.显示 = 显示_行
                    文本盒.前景色 = 父盒.前景色
                    文本盒.字号 = 父盒.字号
                    文本盒.子盒 = []
                    文本盒.脏 = 真
                    文本盒.透明度 = 255
                    文本盒.父盒 = 父盒.节点ID
                    追加(父盒.子盒, 文本盒.节点ID)
                    追加(渲染_树.盒池, 文本盒)
                    渲染_树.总盒数 = 渲染_树.总盒数 + 1
                }
            }
        }
        i = i + 1
    }
}

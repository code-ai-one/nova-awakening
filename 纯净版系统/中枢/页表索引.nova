// NovaOS 页表4索引 — 四级页表管理内核
// 职责: PML4/PDPT/PD/PT四级遍历·映射·取消映射·TLB刷新·大页·COW
//       PCID/ASID管理·页错误分类·内核页表重建·AI内存访问预测
// 理论: MAAPT (Multi-dimensional Adaptive Access Pattern Theory)
//       多维自适应访问模式理论 — 基于时空局部性张量场的
//       页表预取与TLB未命中预测框架

导入("../引导/寄存器定义.nova")
导入("../执行/端口.nova")
导入("./类型定义.nova")
导入("./日志中枢.nova")
导入("./内存物理.nova")
导入("./同步原语.nova")
导入("../推理/通信总线.nova")
导入("./内核打印.nova")
导入("../推理/值乘.nova")
导入("./恐慌.nova")
导入("../引导/端口输入.nova")
导入("./每核页释放.nova")
导入("../推理/智能总线桥.nova")
导入("./伙伴系统释放.nova")
导入("./页表重建.nova")

// 第一部分: 常量与页表项标志位定义
// x86-64 4级页表: PML4(512) → PDPT(512) → PD(512) → PT(512)
// 每级9位索引, 共36位, 加12位页内偏移 = 48位虚拟地址空间(256TB)

定义 页表_条目数      = 512
定义 页表_级数        = 4
定义 页大小_4K        = 0x1000
定义 页大小_2M        = 0x200000
定义 页大小_1G        = 0x40000000
定义 页表项_字节      = 8
定义 虚拟地址_位宽    = 48
定义 物理地址_掩码    = 0x000FFFFFFFFFF000
定义 标志位_掩码      = 0xFFF
定义 扩展标志_掩码    = 0x7FF0000000000000

定义 PTE_存在     = 0x001    // bit 0: 页存在
定义 PTE_可写     = 0x002    // bit 1: 读写允许
定义 PTE_用户     = 0x004    // bit 2: 用户态可访问
定义 PTE_写穿     = 0x008    // bit 3: 写穿透缓存
定义 PTE_禁缓存   = 0x010    // bit 4: 禁止缓存
定义 PTE_已访问   = 0x020    // bit 5: 已被访问
定义 PTE_脏       = 0x040    // bit 6: 已被写入
定义 PTE_大页     = 0x080    // bit 7: PS—2MB/1GB大页
定义 PTE_全局     = 0x100    // bit 8: 全局页(不随CR3刷新)
定义 PTE_COW标记  = 0x200    // bit 9: 软件定义—写时复制
定义 PTE_惰性标记 = 0x400    // bit 10: 软件定义—延迟映射
定义 PTE_换出标记 = 0x800    // bit 11: 软件定义—已换出
定义 PTE_NX       = 0x8000000000000000  // bit 63: 不可执行

定义 INVPCID_单地址       = 0
定义 INVPCID_单PCID       = 1
定义 INVPCID_全部含全局   = 2
定义 INVPCID_全部不含全局 = 3

定义 PF_存在   = 0x01   // 页存在时的违规
定义 PF_写     = 0x02   // 写操作触发
定义 PF_用户   = 0x04   // 用户态触发
定义 PF_保留位 = 0x08   // 保留位被设置
定义 PF_取指   = 0x10   // 指令获取触发
定义 PF_PK     = 0x20   // 保护密钥违规

定义 TLB_统计_环大小 = 1024
定义 PCID_最大值     = 4096

// 时空局部性张量: T(x,y,z) 其中 x=虚拟页号, y=时间步, z=访问类型
// 预取概率: P(hit) = σ(W·T + b) 其中σ为sigmoid激活
定义 MAAPT_特征维度   = 12
定义 MAAPT_时间窗口   = 64
定义 MAAPT_空间邻域   = 16
定义 MAAPT_预取阈值   = 0.72
定义 MAAPT_衰减因子   = 0.93

// 第二部分: 全局状态与统计

定义 可变 内核_PML4物理       = 0
定义 可变 页表_总分配数       = 0
定义 可变 页表_总释放数       = 0
定义 可变 页表_映射次数       = 0
定义 可变 页表_取消映射次数   = 0
定义 可变 页表_大页映射数     = 0
定义 可变 TLB_刷新_单页次数   = 0
定义 可变 TLB_刷新_全局次数   = 0
定义 可变 TLB_未命中统计      = 0
定义 可变 COW_触发次数        = 0
定义 可变 COW_复制次数        = 0
定义 可变 页错误_总次数       = 0
定义 可变 页表锁 = 自旋锁_创建()

定义 可变 PCID_位图 = 数组_创建(PCID_最大值 / 64, 0)
定义 可变 PCID_下一个空闲 = 1   // 0保留给内核
定义 可变 PCID_已分配数 = 0

定义 可变 TLB统计环 = 数组_创建(TLB_统计_环大小, 0)
定义 可变 TLB统计_写指针 = 0

// 第三部分: 虚拟地址 → 页表索引提取
// 48位虚拟地址分解: [47:39]=PML4 [38:30]=PDPT [29:21]=PD [20:12]=PT [11:0]=偏移

函数 PML4索引(虚拟地址) { 返回 (虚拟地址 >> 39) & 0x1FF }
函数 PDPT索引(虚拟地址) { 返回 (虚拟地址 >> 30) & 0x1FF }
函数 PD索引(虚拟地址)   { 返回 (虚拟地址 >> 21) & 0x1FF }
函数 PT索引(虚拟地址)   { 返回 (虚拟地址 >> 12) & 0x1FF }
函数 页内偏移(虚拟地址) { 返回 虚拟地址 & 0xFFF }

// 从各级索引重建虚拟地址(含符号扩展)
函数 索引到虚拟地址(pml4, pdpt, pd, pt, 偏移) {
    定义 原始 = (pml4 << 39) | (pdpt << 30) | (pd << 21) | (pt << 12) | 偏移
    // 48位符号扩展: 如果bit47=1则高16位全填1
    如果 ((原始 >> 47) & 1) {
        返回 原始 | 0xFFFF000000000000
    }
    返回 原始
}

// 虚拟地址规范性检查(48位模式)
函数 虚拟地址_是规范的(虚拟地址) {
    定义 高位 = 虚拟地址 >> 47
    返回 (高位 == 0) || (高位 == 0x1FFFF)
}

// 第四部分: 页表项(PTE)操作

函数 页表项_创建(物理地址, 标志) {
    返回 (物理地址 & 物理地址_掩码) | (标志 & (标志位_掩码 | PTE_NX))
}

函数 页表项_地址(条目)     { 返回 条目 & 物理地址_掩码 }
函数 页表项_标志(条目)     { 返回 条目 & 标志位_掩码 }
函数 页表项_存在(条目)     { 返回 (条目 & PTE_存在) != 0 }
函数 页表项_可写(条目)     { 返回 (条目 & PTE_可写) != 0 }
函数 页表项_用户(条目)     { 返回 (条目 & PTE_用户) != 0 }
函数 页表项_已访问(条目)   { 返回 (条目 & PTE_已访问) != 0 }
函数 页表项_脏(条目)       { 返回 (条目 & PTE_脏) != 0 }
函数 页表项_是大页(条目)   { 返回 (条目 & PTE_大页) != 0 }
函数 页表项_全局(条目)     { 返回 (条目 & PTE_全局) != 0 }
函数 页表项_是COW(条目)    { 返回 (条目 & PTE_COW标记) != 0 }
函数 页表项_是惰性(条目)   { 返回 (条目 & PTE_惰性标记) != 0 }
函数 页表项_已换出(条目)   { 返回 (条目 & PTE_换出标记) != 0 }
函数 页表项_不可执行(条目) { 返回 (条目 & PTE_NX) != 0 }

// 修改PTE标志位(原子风格: 读-改-写)
函数 页表项_设置标志(条目, 新标志) {
    返回 (条目 & 物理地址_掩码) | 新标志
}

函数 页表项_添加标志(条目, 追加) {
    返回 条目 | 追加
}

函数 页表项_移除标志(条目, 移除) {
    返回 条目 & (~移除)
}

// 将PTE标记为COW: 清除可写位, 设置COW软件标记
函数 页表项_标记COW(条目) {
    返回 页表项_添加标志(页表项_移除标志(条目, PTE_可写), PTE_COW标记)
}

// 第五部分: 物理内存中的页表读写

函数 页表_读条目(页表物理, 索引) {
    如果 (索引 >= 页表_条目数) {
        内核打印("[页表] 读条目越界: 索引={} 最大={}", 索引, 页表_条目数 - 1)
        返回 0
    }
    返回 内存读64(物理到虚拟(页表物理) + 索引 * 页表项_字节)
}

函数 页表_写条目(页表物理, 索引, 值) {
    如果 (索引 >= 页表_条目数) {
        内核打印("[页表] 写条目越界: 索引={}", 索引)
        返回
    }
    内存写64(物理到虚拟(页表物理) + 索引 * 页表项_字节, 值)
}

// 原子比较交换页表项(用于并发安全的COW等)
函数 页表_原子CAS条目(页表物理, 索引, 期望值, 新值) {
    定义 地址 = 物理到虚拟(页表物理) + 索引 * 页表项_字节
    返回 原子_比较交换64(地址, 期望值, 新值)
}

// 第六部分: 页表页分配与释放

函数 页表_分配页() {
    定义 页号 = 伙伴系统_分配_带标志(0, GFP_KERNEL | GFP_ZERO)
    如果 (页号 < 0) {
        内核打印("[页表] 分配失败, 尝试紧急回收...")
        // 紧急回收: 尝试释放可丢弃缓存
        定义 回收数 = 内存_紧急回收(1)
        如果 (回收数 > 0) {
            页号 = 伙伴系统_分配_带标志(0, GFP_KERNEL | GFP_ZERO)
        }
        如果 (页号 < 0) {
            内核恐慌("页表分配失败: 无可用物理页且回收无效")
        }
    }
    定义 物理地址 = 页号到地址(页号)
    // 确保清零(防御性编程)
    定义 虚拟 = 物理到虚拟(物理地址)
    定义 可变 i = 0
    当 (i < 页大小_4K) {
        内存写64(虚拟 + i, 0)
        i = i + 8
    }
    页表_总分配数 = 页表_总分配数 + 1
    返回 物理地址
}

函数 页表_释放页(物理地址) {
    如果 (物理地址 == 0) { 返回 }
    定义 页号 = 地址到页号(物理地址)
    伙伴系统_释放(页号, 0)
    页表_总释放数 = 页表_总释放数 + 1
}

// 第七部分: TLB (Translation Lookaside Buffer) 管理

// 刷新单个虚拟地址的TLB条目
函数 TLB_刷新单页(虚拟地址) {
    特权指令_invlpg(虚拟地址)
    TLB_刷新_单页次数 = TLB_刷新_单页次数 + 1
    // 记录到统计环
    TLB统计环[TLB统计_写指针 % TLB_统计_环大小] = 虚拟地址
    TLB统计_写指针 = TLB统计_写指针 + 1
}

// 全局TLB刷新(重载CR3)
函数 TLB_刷新全部() {
    定义 当前cr3 = 读CR3()
    写CR3(当前cr3)
    TLB_刷新_全局次数 = TLB_刷新_全局次数 + 1
}

// 基于PCID的TLB刷新(避免全局刷新的性能损失)
函数 TLB_刷新_PCID(pcid, 虚拟地址) {
    如果 (CPU支持_INVPCID()) {
        特权指令_invpcid(INVPCID_单地址, pcid, 虚拟地址)
    } 否则 {
        // 回退: 传统invlpg
        TLB_刷新单页(虚拟地址)
    }
}

// 刷新指定PCID的所有TLB条目
函数 TLB_刷新_整个PCID(pcid) {
    如果 (CPU支持_INVPCID()) {
        特权指令_invpcid(INVPCID_单PCID, pcid, 0)
    } 否则 {
        TLB_刷新全部()
    }
}

// 批量TLB刷新: 当修改页数超过阈值时用全局刷新替代逐页刷新
函数 TLB_批量刷新(虚拟地址数组, 数量) {
    // 经验阈值: 超过32页时全局刷新更高效
    如果 (数量 > 32) {
        TLB_刷新全部()
        返回
    }
    定义 可变 i = 0
    当 (i < 数量) {
        TLB_刷新单页(虚拟地址数组[i])
        i = i + 1
    }
}

// 第八部分: PCID (Process Context ID) / ASID 管理
// 减少进程切换时的TLB全刷, 每个进程分配唯一PCID

函数 PCID_分配() {
    // 位图搜索空闲PCID
    定义 可变 搜索起点 = PCID_下一个空闲
    定义 可变 已扫描 = 0
    当 (已扫描 < PCID_最大值) {
        定义 字索引 = 搜索起点 / 64
        定义 位索引 = 搜索起点 % 64
        如果 ((PCID_位图[字索引] & (1 << 位索引)) == 0) {
            // 空闲位
            PCID_位图[字索引] = PCID_位图[字索引] | (1 << 位索引)
            PCID_下一个空闲 = (搜索起点 + 1) % PCID_最大值
            如果 (PCID_下一个空闲 == 0) { PCID_下一个空闲 = 1 }
            PCID_已分配数 = PCID_已分配数 + 1
            返回 搜索起点
        }
        搜索起点 = (搜索起点 + 1) % PCID_最大值
        如果 (搜索起点 == 0) { 搜索起点 = 1 }
        已扫描 = 已扫描 + 1
    }
    // 全部用尽: 执行PCID代回收
    PCID_代回收()
    返回 PCID_分配()
}

函数 PCID_释放(pcid) {
    如果 (pcid <= 0 || pcid >= PCID_最大值) { 返回 }
    定义 字索引 = pcid / 64
    定义 位索引 = pcid % 64
    PCID_位图[字索引] = PCID_位图[字索引] & (~(1 << 位索引))
    PCID_已分配数 = PCID_已分配数 - 1
    TLB_刷新_整个PCID(pcid)
}

// PCID代回收: 当PCID耗尽时批量回收最旧的一半
函数 PCID_代回收() {
    内核打印("[页表] PCID耗尽, 执行代回收...")
    定义 可变 回收数 = 0
    定义 目标 = PCID_已分配数 / 2
    定义 可变 i = 1
    当 (i < PCID_最大值 && 回收数 < 目标) {
        定义 字索引 = i / 64
        定义 位索引 = i % 64
        如果 ((PCID_位图[字索引] & (1 << 位索引)) != 0) {
            PCID_位图[字索引] = PCID_位图[字索引] & (~(1 << 位索引))
            回收数 = 回收数 + 1
            PCID_已分配数 = PCID_已分配数 - 1
        }
        i = i + 1
    }
    TLB_刷新全部()
    内核打印("[页表] PCID代回收完成, 回收{}个", 回收数)
}

// 第九部分: 四级页表遍历与映射核心

// 遍历到PT级(最底层页表), 按需创建中间级
函数 页表_遍历到PT(PML4物理, 虚拟地址, 创建) {
    如果 (!虚拟地址_是规范的(虚拟地址)) {
        内核打印("[页表] 非规范虚拟地址: 0x{:X}", 虚拟地址)
        返回 0
    }
    定义 pml4_idx = PML4索引(虚拟地址)
    定义 pml4_条目 = 页表_读条目(PML4物理, pml4_idx)
    定义 可变 pdpt_物理 = 0

    如果 (页表项_存在(pml4_条目)) {
        pdpt_物理 = 页表项_地址(pml4_条目)
    } 否则 {
        如果 (!创建) { 返回 0 }
        pdpt_物理 = 页表_分配页()
        页表_写条目(PML4物理, pml4_idx, 页表项_创建(pdpt_物理, PTE_存在 | PTE_可写 | PTE_用户))
    }

    定义 pdpt_idx = PDPT索引(虚拟地址)
    定义 pdpt_条目 = 页表_读条目(pdpt_物理, pdpt_idx)
    // 检查1GB大页
    如果 (页表项_存在(pdpt_条目) && 页表项_是大页(pdpt_条目)) {
        内核打印("[页表] 遍历命中1GB大页 @PDPT[{}]", pdpt_idx)
        返回 -1   // 特殊返回值: 大页无需继续
    }
    定义 可变 pd_物理 = 0
    如果 (页表项_存在(pdpt_条目)) {
        pd_物理 = 页表项_地址(pdpt_条目)
    } 否则 {
        如果 (!创建) { 返回 0 }
        pd_物理 = 页表_分配页()
        页表_写条目(pdpt_物理, pdpt_idx, 页表项_创建(pd_物理, PTE_存在 | PTE_可写 | PTE_用户))
    }

    定义 pd_idx = PD索引(虚拟地址)
    定义 pd_条目 = 页表_读条目(pd_物理, pd_idx)
    // 检查2MB大页
    如果 (页表项_存在(pd_条目) && 页表项_是大页(pd_条目)) {
        内核打印("[页表] 遍历命中2MB大页 @PD[{}]", pd_idx)
        返回 -2   // 特殊返回值: 2MB大页
    }
    定义 可变 pt_物理 = 0
    如果 (页表项_存在(pd_条目)) {
        pt_物理 = 页表项_地址(pd_条目)
    } 否则 {
        如果 (!创建) { 返回 0 }
        pt_物理 = 页表_分配页()
        页表_写条目(pd_物理, pd_idx, 页表项_创建(pt_物理, PTE_存在 | PTE_可写 | PTE_用户))
    }

    返回 pt_物理
}

// 完整映射: 虚拟地址 → 物理地址 (4KB页)
函数 页表_映射(PML4物理, 虚拟地址, 物理地址, 标志) {
    自旋锁_获取(页表锁)
    定义 pt_物理 = 页表_遍历到PT(PML4物理, 虚拟地址, 真)
    如果 (pt_物理 <= 0) {
        自旋锁_释放(页表锁)
        内核打印("[页表] 映射失败: 遍历到PT失败 VA=0x{:X}", 虚拟地址)
        返回 假
    }
    定义 pt_idx = PT索引(虚拟地址)
    定义 已有 = 页表_读条目(pt_物理, pt_idx)
    如果 (页表项_存在(已有)) {
        内核打印("[页表] 覆盖映射: VA=0x{:X} 旧PA=0x{:X}", 虚拟地址, 页表项_地址(已有))
    }
    页表_写条目(pt_物理, pt_idx, 页表项_创建(物理地址, 标志 | PTE_存在))
    TLB_刷新单页(虚拟地址)
    页表_映射次数 = 页表_映射次数 + 1
    自旋锁_释放(页表锁)
    返回 真
}

// 取消映射
函数 页表_取消映射(PML4物理, 虚拟地址) {
    自旋锁_获取(页表锁)
    定义 pt_物理 = 页表_遍历到PT(PML4物理, 虚拟地址, 假)
    如果 (pt_物理 <= 0) {
        自旋锁_释放(页表锁)
        返回 假
    }
    定义 pt_idx = PT索引(虚拟地址)
    定义 条目 = 页表_读条目(pt_物理, pt_idx)
    如果 (!页表项_存在(条目)) {
        自旋锁_释放(页表锁)
        返回 假
    }
    页表_写条目(pt_物理, pt_idx, 0)
    TLB_刷新单页(虚拟地址)
    页表_取消映射次数 = 页表_取消映射次数 + 1
    自旋锁_释放(页表锁)
    返回 真
}

// 查询映射: 虚拟地址 → 物理地址
函数 页表_查询(PML4物理, 虚拟地址) {
    定义 pt_物理 = 页表_遍历到PT(PML4物理, 虚拟地址, 假)
    如果 (pt_物理 <= 0) { 返回 -1 }
    定义 pt_idx = PT索引(虚拟地址)
    定义 条目 = 页表_读条目(pt_物理, pt_idx)
    如果 (!页表项_存在(条目)) { 返回 -1 }
    返回 页表项_地址(条目) | 页内偏移(虚拟地址)
}

// 第十部分: 2MB / 1GB 大页映射

// 映射2MB大页(在PD级设置PS位)
函数 页表_映射大页2M(PML4物理, 虚拟地址, 物理地址, 标志) {
    如果 ((虚拟地址 & (页大小_2M - 1)) != 0) {
        内核打印("[页表] 2MB大页映射: 虚拟地址未对齐 0x{:X}", 虚拟地址)
        返回 假
    }
    如果 ((物理地址 & (页大小_2M - 1)) != 0) {
        内核打印("[页表] 2MB大页映射: 物理地址未对齐")
        返回 假
    }
    自旋锁_获取(页表锁)
    // 遍历到PD级
    定义 pml4_idx = PML4索引(虚拟地址)
    定义 pml4_条目 = 页表_读条目(PML4物理, pml4_idx)
    定义 可变 pdpt_物理 = 0
    如果 (页表项_存在(pml4_条目)) {
        pdpt_物理 = 页表项_地址(pml4_条目)
    } 否则 {
        pdpt_物理 = 页表_分配页()
        页表_写条目(PML4物理, pml4_idx, 页表项_创建(pdpt_物理, PTE_存在 | PTE_可写 | PTE_用户))
    }
    定义 pdpt_idx = PDPT索引(虚拟地址)
    定义 pdpt_条目 = 页表_读条目(pdpt_物理, pdpt_idx)
    定义 可变 pd_物理 = 0
    如果 (页表项_存在(pdpt_条目)) {
        pd_物理 = 页表项_地址(pdpt_条目)
    } 否则 {
        pd_物理 = 页表_分配页()
        页表_写条目(pdpt_物理, pdpt_idx, 页表项_创建(pd_物理, PTE_存在 | PTE_可写 | PTE_用户))
    }
    // 在PD级写入大页条目
    定义 pd_idx = PD索引(虚拟地址)
    页表_写条目(pd_物理, pd_idx, 页表项_创建(物理地址, 标志 | PTE_存在 | PTE_大页))
    TLB_刷新单页(虚拟地址)
    页表_大页映射数 = 页表_大页映射数 + 1
    页表_映射次数 = 页表_映射次数 + 1
    自旋锁_释放(页表锁)
    返回 真
}

// 映射1GB大页(在PDPT级设置PS位)
函数 页表_映射大页1G(PML4物理, 虚拟地址, 物理地址, 标志) {
    如果 ((虚拟地址 & (页大小_1G - 1)) != 0 || (物理地址 & (页大小_1G - 1)) != 0) {
        内核打印("[页表] 1GB大页映射: 地址未对齐")
        返回 假
    }
    自旋锁_获取(页表锁)
    定义 pml4_idx = PML4索引(虚拟地址)
    定义 pml4_条目 = 页表_读条目(PML4物理, pml4_idx)
    定义 可变 pdpt_物理 = 0
    如果 (页表项_存在(pml4_条目)) {
        pdpt_物理 = 页表项_地址(pml4_条目)
    } 否则 {
        pdpt_物理 = 页表_分配页()
        页表_写条目(PML4物理, pml4_idx, 页表项_创建(pdpt_物理, PTE_存在 | PTE_可写 | PTE_用户))
    }
    定义 pdpt_idx = PDPT索引(虚拟地址)
    页表_写条目(pdpt_物理, pdpt_idx, 页表项_创建(物理地址, 标志 | PTE_存在 | PTE_大页))
    TLB_刷新单页(虚拟地址)
    页表_大页映射数 = 页表_大页映射数 + 1
    自旋锁_释放(页表锁)
    返回 真
}

// 第十一部分: 写时复制 (Copy-on-Write) 核心

// 将一个页表范围标记为COW(fork时使用)
函数 页表_标记范围COW(PML4物理, 起始VA, 结束VA) {
    定义 可变 va = 起始VA
    定义 可变 标记数 = 0
    当 (va < 结束VA) {
        定义 pt_物理 = 页表_遍历到PT(PML4物理, va, 假)
        如果 (pt_物理 > 0) {
            定义 pt_idx = PT索引(va)
            定义 条目 = 页表_读条目(pt_物理, pt_idx)
            如果 (页表项_存在(条目) && 页表项_可写(条目)) {
                定义 新条目 = 页表项_标记COW(条目)
                页表_写条目(pt_物理, pt_idx, 新条目)
                标记数 = 标记数 + 1
            }
        }
        va = va + 页大小_4K
    }
    如果 (标记数 > 0) {
        TLB_刷新全部()
    }
    返回 标记数
}

// COW页错误处理: 分配新页, 复制内容, 重映射为可写
函数 页表_COW处理(PML4物理, 错误VA) {
    定义 pt_物理 = 页表_遍历到PT(PML4物理, 错误VA, 假)
    如果 (pt_物理 <= 0) { 返回 假 }
    定义 pt_idx = PT索引(错误VA)
    定义 条目 = 页表_读条目(pt_物理, pt_idx)
    如果 (!页表项_存在(条目) || !页表项_是COW(条目)) { 返回 假 }

    定义 旧物理 = 页表项_地址(条目)
    定义 旧标志 = 页表项_标志(条目)
    // 分配新物理页
    定义 新物理 = 页表_分配页()
    // 复制4KB内容
    定义 可变 i = 0
    当 (i < 页大小_4K) {
        定义 字节 = 内存读8(物理到虚拟(旧物理) + i)
        内存写8(物理到虚拟(新物理) + i, 字节)
        i = i + 1
    }
    // 新条目: 可写, 清除COW标记
    定义 新标志 = (旧标志 | PTE_可写) & (~PTE_COW标记)
    定义 成功 = 页表_原子CAS条目(pt_物理, pt_idx, 条目, 页表项_创建(新物理, 新标志))
    如果 (!成功) {
        // CAS失败: 其他CPU已处理, 释放我们分配的页
        页表_释放页(新物理)
        返回 假
    }
    TLB_刷新单页(错误VA)
    COW_触发次数 = COW_触发次数 + 1
    COW_复制次数 = COW_复制次数 + 1
    // 减少旧物理页的引用计数
    页帧_减引用(地址到页号(旧物理))
    返回 真
}

// 第十二部分: 页错误分类与分发

函数 页错误_分类(错误码, 错误地址, PML4物理) {
    页错误_总次数 = 页错误_总次数 + 1
    定义 可变 类型 = "未知"
    定义 可变 严重级 = 0   // 0=可恢复 1=信号 2=恐慌

    如果 ((错误码 & PF_保留位) != 0) {
        // 保留位被设置: 页表结构损坏
        类型 = "保留位违规"
        严重级 = 2
    } 否则 如果 ((错误码 & PF_存在) == 0) {
        // 页不存在
        定义 pt_物理 = 页表_遍历到PT(PML4物理, 错误地址, 假)
        如果 (pt_物理 > 0) {
            定义 条目 = 页表_读条目(pt_物理, PT索引(错误地址))
            如果 (页表项_已换出(条目)) {
                类型 = "换入请求"
                严重级 = 0
            } 否则 如果 (页表项_是惰性(条目)) {
                类型 = "延迟分配"
                严重级 = 0
            } 否则 {
                类型 = "未映射访问"
                严重级 = 1
            }
        } 否则 {
            类型 = "未映射访问"
            严重级 = 1
        }
    } 否则 如果 ((错误码 & PF_写) != 0) {
        // 写保护违规
        定义 pt_物理 = 页表_遍历到PT(PML4物理, 错误地址, 假)
        如果 (pt_物理 > 0) {
            定义 条目 = 页表_读条目(pt_物理, PT索引(错误地址))
            如果 (页表项_是COW(条目)) {
                类型 = "COW触发"
                严重级 = 0
            } 否则 {
                类型 = "写保护违规"
                严重级 = 1
            }
        } 否则 {
            类型 = "写保护违规"
            严重级 = 1
        }
    } 否则 如果 ((错误码 & PF_取指) != 0) {
        类型 = "NX执行违规"
        严重级 = 1
    } 否则 {
        类型 = "读保护违规"
        严重级 = 1
    }

    返回 { 类型: 类型, 严重级: 严重级, 错误码: 错误码, 地址: 错误地址 }
}

// 页错误主处理入口
函数 页错误_处理(错误码, 错误地址, PML4物理) {
    定义 分类 = 页错误_分类(错误码, 错误地址, PML4物理)

    如果 (分类.严重级 == 2) {
        内核恐慌("致命页错误: {} @0x{:X} 错误码=0x{:X}", 分类.类型, 错误地址, 错误码)
    }

    匹配 (分类.类型) {
        "COW触发" => {
            定义 成功 = 页表_COW处理(PML4物理, 错误地址)
            如果 (!成功) {
                内核打印("[页表] COW处理失败 @0x{:X}", 错误地址)
                返回 假
            }
            返回 真
        }
        "延迟分配" => {
            定义 新页 = 页表_分配页()
            定义 成功 = 页表_映射(PML4物理, 错误地址 & (~0xFFF), 新页, PTE_可写 | PTE_用户)
            返回 成功
        }
        "换入请求" => {
            // 从交换区读回页面
            返回 交换_读入(PML4物理, 错误地址)
        }
        _ => {
            内核打印("[页表] 不可恢复页错误: {} @0x{:X}", 分类.类型, 错误地址)
            返回 假
        }
    }
}

// 第十三部分: 内核页表初始化与重建

函数 页表_内核初始化() {
    内核打印("[页表] 初始化四级页表管理子系统...")
    // 分配内核PML4
    内核_PML4物理 = 页表_分配页()
    // 恒等映射: 前4GB物理内存 (使用2MB大页)
    内核打印("[页表] 建立前4GB恒等映射(2MB大页)...")
    定义 可变 物理 = 0
    当 (物理 < 0x100000000) {
        页表_映射大页2M(内核_PML4物理, 物理, 物理, PTE_可写 | PTE_全局)
        物理 = 物理 + 页大小_2M
    }
    // 高半核映射: 0xFFFF800000000000 → 0x0 (物理内存直接映射)
    内核打印("[页表] 建立高半核直接映射窗口...")
    定义 高半核基址 = 0xFFFF800000000000
    物理 = 0
    当 (物理 < 0x100000000) {
        页表_映射大页2M(内核_PML4物理, 高半核基址 + 物理, 物理, PTE_可写 | PTE_全局 | PTE_NX)
        物理 = 物理 + 页大小_2M
    }
    // 加载新页表
    写CR3(内核_PML4物理)
    内核打印("[页表] 四级页表初始化完成, PML4=0x{:X}", 内核_PML4物理)
}

// 进程页表创建: 复制内核高半部分映射
函数 页表_创建进程页表() {
    定义 新PML4 = 页表_分配页()
    // 复制PML4高半部分(索引256-511 = 内核空间)
    定义 可变 i = 256
    当 (i < 512) {
        定义 内核条目 = 页表_读条目(内核_PML4物理, i)
        如果 (页表项_存在(内核条目)) {
            页表_写条目(新PML4, i, 内核条目)
        }
        i = i + 1
    }
    定义 pcid = PCID_分配()
    返回 { PML4物理: 新PML4, PCID: pcid }
}

// 进程页表销毁: 释放用户空间所有页表页
函数 页表_销毁进程页表(PML4物理, pcid) {
    // 递归释放用户空间(索引0-255)
    定义 可变 pml4_i = 0
    当 (pml4_i < 256) {
        定义 pml4_条目 = 页表_读条目(PML4物理, pml4_i)
        如果 (页表项_存在(pml4_条目)) {
            定义 pdpt_物理 = 页表项_地址(pml4_条目)
            页表_释放_PDPT(pdpt_物理)
            页表_释放页(pdpt_物理)
        }
        pml4_i = pml4_i + 1
    }
    页表_释放页(PML4物理)
    PCID_释放(pcid)
}

// 递归释放PDPT下所有PD和PT
函数 页表_释放_PDPT(pdpt_物理) {
    定义 可变 i = 0
    当 (i < 512) {
        定义 条目 = 页表_读条目(pdpt_物理, i)
        如果 (页表项_存在(条目) && !页表项_是大页(条目)) {
            定义 pd_物理 = 页表项_地址(条目)
            页表_释放_PD(pd_物理)
            页表_释放页(pd_物理)
        }
        i = i + 1
    }
}

函数 页表_释放_PD(pd_物理) {
    定义 可变 i = 0
    当 (i < 512) {
        定义 条目 = 页表_读条目(pd_物理, i)
        如果 (页表项_存在(条目) && !页表项_是大页(条目)) {
            页表_释放页(页表项_地址(条目))
        }
        i = i + 1
    }
}

// 第十四部分: 页表遍历诊断(调试用完整页表Walk)

函数 页表_Walk(PML4物理, 虚拟地址) {
    内核打印("[页表Walk] VA=0x{:X}", 虚拟地址)
    定义 pml4_idx = PML4索引(虚拟地址)
    定义 pml4_条目 = 页表_读条目(PML4物理, pml4_idx)
    内核打印("  PML4[{}] = 0x{:X} 存在={} 可写={} 用户={}",
        pml4_idx, pml4_条目, 页表项_存在(pml4_条目),
        页表项_可写(pml4_条目), 页表项_用户(pml4_条目))
    如果 (!页表项_存在(pml4_条目)) { 返回 空 }

    定义 pdpt_物理 = 页表项_地址(pml4_条目)
    定义 pdpt_idx = PDPT索引(虚拟地址)
    定义 pdpt_条目 = 页表_读条目(pdpt_物理, pdpt_idx)
    内核打印("  PDPT[{}] = 0x{:X} 存在={} 大页={}",
        pdpt_idx, pdpt_条目, 页表项_存在(pdpt_条目), 页表项_是大页(pdpt_条目))
    如果 (!页表项_存在(pdpt_条目)) { 返回 空 }
    如果 (页表项_是大页(pdpt_条目)) {
        定义 pa = 页表项_地址(pdpt_条目) | (虚拟地址 & (页大小_1G - 1))
        内核打印("  → 1GB大页 PA=0x{:X}", pa)
        返回 { 物理地址: pa, 页大小: 页大小_1G, 标志: 页表项_标志(pdpt_条目) }
    }

    定义 pd_物理 = 页表项_地址(pdpt_条目)
    定义 pd_idx = PD索引(虚拟地址)
    定义 pd_条目 = 页表_读条目(pd_物理, pd_idx)
    内核打印("  PD[{}] = 0x{:X} 存在={} 大页={}",
        pd_idx, pd_条目, 页表项_存在(pd_条目), 页表项_是大页(pd_条目))
    如果 (!页表项_存在(pd_条目)) { 返回 空 }
    如果 (页表项_是大页(pd_条目)) {
        定义 pa = 页表项_地址(pd_条目) | (虚拟地址 & (页大小_2M - 1))
        内核打印("  → 2MB大页 PA=0x{:X}", pa)
        返回 { 物理地址: pa, 页大小: 页大小_2M, 标志: 页表项_标志(pd_条目) }
    }

    定义 pt_物理 = 页表项_地址(pd_条目)
    定义 pt_idx = PT索引(虚拟地址)
    定义 pt_条目 = 页表_读条目(pt_物理, pt_idx)
    内核打印("  PT[{}] = 0x{:X} 存在={} 可写={} 脏={} COW={}",
        pt_idx, pt_条目, 页表项_存在(pt_条目), 页表项_可写(pt_条目),
        页表项_脏(pt_条目), 页表项_是COW(pt_条目))
    如果 (!页表项_存在(pt_条目)) { 返回 空 }

    定义 pa = 页表项_地址(pt_条目) | 页内偏移(虚拟地址)
    内核打印("  → 4KB页 PA=0x{:X}", pa)
    返回 { 物理地址: pa, 页大小: 页大小_4K, 标志: 页表项_标志(pt_条目) }
}

// 第十五部分: AI内存访问预测 (MAAPT理论)
// Multi-dimensional Adaptive Access Pattern Theory
// 核心: 构建虚拟地址空间的时空局部性张量场, 预测TLB未命中
// 与页表预取路径, 减少页表遍历开销
// 数学基础: P(VA_next | History) = softmax(W_temporal · H_t + W_spatial · S_t)
// 其中 H_t = 时间局部性向量, S_t = 空间邻域活跃度向量

定义 可变 MAAPT_历史环 = 数组_创建(MAAPT_时间窗口, 0)
定义 可变 MAAPT_历史写指针 = 0
定义 可变 MAAPT_预取命中 = 0
定义 可变 MAAPT_预取未中 = 0

// 记录一次页表访问到时间序列
函数 MAAPT_记录访问(虚拟地址) {
    MAAPT_历史环[MAAPT_历史写指针 % MAAPT_时间窗口] = 虚拟地址
    MAAPT_历史写指针 = MAAPT_历史写指针 + 1
}

// 构建时间局部性特征向量
// 计算最近N次访问的页号差分序列的统计特征
函数 MAAPT_时间特征() {
    定义 可变 特征 = 数组_创建(MAAPT_特征维度, 0.0)
    定义 窗口 = MAAPT_时间窗口
    定义 可变 差分和 = 0.0
    定义 可变 差分方差 = 0.0
    定义 可变 步长频率 = 数组_创建(MAAPT_空间邻域, 0)
    定义 可变 有效数 = 0

    定义 可变 i = 1
    当 (i < 窗口 && i < MAAPT_历史写指针) {
        定义 当前 = MAAPT_历史环[(MAAPT_历史写指针 - i) % 窗口]
        定义 前一 = MAAPT_历史环[(MAAPT_历史写指针 - i - 1) % 窗口]
        如果 (当前 != 0 && 前一 != 0) {
            定义 差分 = (当前 >> 12) - (前一 >> 12)  // 页号差
            差分和 = 差分和 + 差分
            有效数 = 有效数 + 1
            // 统计步长分布
            定义 绝对步长 = 差分
            如果 (绝对步长 < 0) { 绝对步长 = -绝对步长 }
            如果 (绝对步长 < MAAPT_空间邻域) {
                步长频率[绝对步长] = 步长频率[绝对步长] + 1
            }
        }
        i = i + 1
    }

    如果 (有效数 > 0) {
        定义 均值 = 差分和 / 有效数
        特征[0] = 均值                     // 平均步长
        特征[1] = 有效数                   // 有效样本数
        // 计算方差
        定义 可变 j = 1
        当 (j < 窗口 && j < MAAPT_历史写指针) {
            定义 当前 = MAAPT_历史环[(MAAPT_历史写指针 - j) % 窗口]
            定义 前一 = MAAPT_历史环[(MAAPT_历史写指针 - j - 1) % 窗口]
            如果 (当前 != 0 && 前一 != 0) {
                定义 差分 = (当前 >> 12) - (前一 >> 12)
                差分方差 = 差分方差 + (差分 - 均值) * (差分 - 均值)
            }
            j = j + 1
        }
        特征[2] = 差分方差 / 有效数         // 步长方差
    }

    // 步长频率分布特征
    定义 可变 k = 0
    当 (k < MAAPT_空间邻域 && (k + 3) < MAAPT_特征维度) {
        特征[k + 3] = 步长频率[k]
        k = k + 1
    }
    返回 特征
}

// AI预取决策: 基于时间局部性预测下一组可能访问的页
函数 MAAPT_预取决策() {
    如果 (MAAPT_历史写指针 < 8) { 返回 空 }  // 历史不足

    定义 特征 = MAAPT_时间特征()
    // 提交到AI总线进行推理
    定义 张量 = Tensor_创建(1, MAAPT_特征维度)
    定义 可变 i = 0
    当 (i < MAAPT_特征维度) {
        Tensor_写(张量, 0, i, 特征[i])
        i = i + 1
    }

    定义 预测 = AI总线_推理("MAAPT_页表预取", 张量)
    Tensor_释放(张量)

    如果 (预测.置信度 < MAAPT_预取阈值) { 返回 空 }

    // 解析预测: 返回建议预取的虚拟页号列表
    定义 最近VA = MAAPT_历史环[(MAAPT_历史写指针 - 1) % MAAPT_时间窗口]
    定义 预测步长 = 预测.输出值
    定义 预取VA = (最近VA >> 12 + 预测步长) << 12

    返回 { 虚拟地址: 预取VA, 置信度: 预测.置信度 }
}

// 执行AI驱动的页表预取
函数 MAAPT_执行预取(PML4物理) {
    定义 决策 = MAAPT_预取决策()
    如果 (决策 == 空) { 返回 }

    // 预遍历页表以填充TLB(不创建缺失的中间级)
    定义 va = 决策.虚拟地址
    定义 pt_物理 = 页表_遍历到PT(PML4物理, va, 假)
    如果 (pt_物理 > 0) {
        定义 条目 = 页表_读条目(pt_物理, PT索引(va))
        如果 (页表项_存在(条目)) {
            // 触摸该页的虚拟地址以填充TLB
            定义 _ = 内存读8(物理到虚拟(页表项_地址(条目)))
            MAAPT_预取命中 = MAAPT_预取命中 + 1
        } 否则 {
            MAAPT_预取未中 = MAAPT_预取未中 + 1
        }
    }
}

// 第十六部分: 统计与诊断接口

函数 页表_打印统计() {
    内核打印("═══ 页表管理统计 ═══")
    内核打印("  页表页分配: {}  释放: {}  净使用: {}",
        页表_总分配数, 页表_总释放数, 页表_总分配数 - 页表_总释放数)
    内核打印("  映射次数: {}  取消映射: {}  大页映射: {}",
        页表_映射次数, 页表_取消映射次数, 页表_大页映射数)
    内核打印("  TLB刷新: 单页={} 全局={}",
        TLB_刷新_单页次数, TLB_刷新_全局次数)
    内核打印("  COW: 触发={} 复制={}", COW_触发次数, COW_复制次数)
    内核打印("  页错误总数: {}", 页错误_总次数)
    内核打印("  PCID: 已分配={}/{}", PCID_已分配数, PCID_最大值)
    如果 (MAAPT_预取命中 + MAAPT_预取未中 > 0) {
        定义 命中率 = MAAPT_预取命中 * 100 / (MAAPT_预取命中 + MAAPT_预取未中)
        内核打印("  AI预取(MAAPT): 命中={} 未中={} 命中率={}%",
            MAAPT_预取命中, MAAPT_预取未中, 命中率)
    }
}

函数 页表_获取统计() {
    返回 {
        分配数: 页表_总分配数,
        释放数: 页表_总释放数,
        映射数: 页表_映射次数,
        取消映射数: 页表_取消映射次数,
        大页映射数: 页表_大页映射数,
        TLB单页刷新: TLB_刷新_单页次数,
        TLB全局刷新: TLB_刷新_全局次数,
        COW触发: COW_触发次数,
        COW复制: COW_复制次数,
        页错误: 页错误_总次数,
        PCID使用: PCID_已分配数,
        AI预取命中: MAAPT_预取命中,
        AI预取未中: MAAPT_预取未中
    }
}

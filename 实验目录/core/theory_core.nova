定义 警告_信息 = 0
定义 警告_中 = 1
定义 警告_高 = 2
定义 警告_致命 = 3

函数 理论_等级文本(级别) {
    如果 (级别 == 警告_信息) { 返回 "信息" }
    如果 (级别 == 警告_中) { 返回 "中" }
    如果 (级别 == 警告_高) { 返回 "高" }
    返回 "致命"
}

函数 理论_单组最小领先() {
    返回 220
}

函数 理论_总体最小领先() {
    返回 1500
}

函数 理论_单组最小样本数() {
    返回 9
}

函数 理论_总体最小样本数() {
    返回 128
}

函数 理论_重复实验轮数() {
    返回 24
}

函数 理论_抗干扰最小优势() {
    返回 50
}

函数 理论_交叉扫描最小增益() {
    返回 40
}

函数 数学_绝对值(x) {
    如果 (x < 0) { 返回 0 - x }
    返回 x
}

函数 数学_夹紧(x, 下界, 上界) {
    定义 可变 y = x
    如果 (y < 下界) { y = 下界 }
    如果 (y > 上界) { y = 上界 }
    返回 y
}

函数 原创_晶化通量(共振, 调质, 新颖度, 干扰) {
    定义 可变 通量 = 共振 / 6 + 调质 / 7 + 新颖度 / 9 - 干扰 / 7
    如果 (共振 > 820) {
        如果 (新颖度 > 560) { 通量 = 通量 + 40 }
    }
    如果 (干扰 < 260) {
        如果 (调质 > 680) { 通量 = 通量 + 35 }
    }
    返回 通量
}

函数 原创_势场锁定量(记忆共振, 情绪稳定, 上下文漂移, 风险) {
    定义 可变 锁定 = 记忆共振 / 5 + 情绪稳定 / 5 - 上下文漂移 / 5 - 风险 / 4
    如果 (上下文漂移 < 220) {
        如果 (情绪稳定 > 680) { 锁定 = 锁定 + 50 }
    }
    返回 锁定
}

函数 原创_双环协同量(局部塑性, 云端蒸馏, 偏好对齐, 稳态保护, 干扰) {
    定义 可变 协同 = 偏好对齐 / 5 + 稳态保护 / 4 + 局部塑性 / 8 + 云端蒸馏 / 8 - 干扰 / 9
    如果 (局部塑性 > 740) {
        如果 (稳态保护 > 720) { 协同 = 协同 + 90 }
    }
    返回 协同
}

函数 原创_几何折叠量(幅值保持, 残差恢复, 索引一致, 存储成本) {
    定义 可变 折叠 = 幅值保持 / 6 + 残差恢复 / 7 + 索引一致 / 5 - 存储成本 / 9
    如果 (索引一致 > 780) {
        如果 (幅值保持 > 700) { 折叠 = 折叠 + 55 }
    }
    返回 折叠
}

函数 基线_记忆保持率(强度, 时间, 稳定性) {
    如果 (稳定性 + 时间 <= 0) { 返回 数学_夹紧(强度, 0, 1000) }
    返回 数学_夹紧(强度 * 稳定性 / (稳定性 + 时间), 0, 1000)
}

函数 原创_记忆晶化保持率(强度, 时间, 稳定性, 共振, 调质, 新颖度, 干扰) {
    定义 可变 保持 = 基线_记忆保持率(强度, 时间, 稳定性)
    定义 晶化通量 = 原创_晶化通量(共振, 调质, 新颖度, 干扰)
    保持 = 保持 + 晶化通量 + (强度 + 稳定性) / 18 - 时间 / 20
    如果 (共振 > 850) {
        如果 (调质 > 750) { 保持 = 保持 + 60 }
    }
    如果 (新颖度 > 650) {
        如果 (干扰 < 240) { 保持 = 保持 + 45 }
    }
    返回 数学_夹紧(保持, 0, 1000)
}

函数 基线_回复评分(目标契合, 历史一致, 执行代价) {
    返回 数学_夹紧(目标契合 / 2 + 历史一致 / 4 - 执行代价 / 2, 0, 1000)
}

函数 原创_意图势场评分(目标契合, 记忆共振, 情绪稳定, 上下文漂移, 执行代价, 风险) {
    定义 可变 分数 = 基线_回复评分(目标契合, 记忆共振, 执行代价)
    定义 锁定量 = 原创_势场锁定量(记忆共振, 情绪稳定, 上下文漂移, 风险)
    分数 = 分数 + 锁定量 + 目标契合 / 10
    如果 (目标契合 > 800) {
        如果 (上下文漂移 < 250) { 分数 = 分数 + 70 }
    }
    如果 (风险 < 180) {
        如果 (情绪稳定 > 700) { 分数 = 分数 + 45 }
    }
    返回 数学_夹紧(分数, 0, 1000)
}

函数 基线_学习增益(梯度改善, 批量稳定, 灾忘) {
    返回 数学_夹紧(梯度改善 / 2 + 批量稳定 / 4 - 灾忘 / 2, 0, 1000)
}

函数 原创_双环学习增益(局部塑性, 云端蒸馏, 偏好对齐, 稳态保护, 干扰) {
    定义 可变 分数 = 基线_学习增益(局部塑性, 云端蒸馏, 干扰)
    定义 协同量 = 原创_双环协同量(局部塑性, 云端蒸馏, 偏好对齐, 稳态保护, 干扰)
    分数 = 分数 + 协同量 + 局部塑性 / 12 + 云端蒸馏 / 12
    如果 (局部塑性 > 720) {
        如果 (稳态保护 > 700) { 分数 = 分数 + 80 }
    }
    如果 (偏好对齐 > 700) {
        如果 (干扰 < 230) { 分数 = 分数 + 55 }
    }
    返回 数学_夹紧(分数, 0, 1000)
}

函数 基线_压缩质量(相似保持, 存储成本, 恢复能力) {
    返回 数学_夹紧(相似保持 / 2 + 恢复能力 / 4 - 存储成本 / 3, 0, 1000)
}

函数 原创_认知几何质量(方向保持, 幅值保持, 残差恢复, 索引一致, 存储成本) {
    定义 可变 分数 = 基线_压缩质量(方向保持, 存储成本, 残差恢复)
    定义 折叠量 = 原创_几何折叠量(幅值保持, 残差恢复, 索引一致, 存储成本)
    分数 = 分数 + 折叠量 + 方向保持 / 10
    如果 (方向保持 > 780) {
        如果 (索引一致 > 760) { 分数 = 分数 + 60 }
    }
    如果 (残差恢复 > 620) {
        如果 (存储成本 < 280) { 分数 = 分数 + 40 }
    }
    返回 数学_夹紧(分数, 0, 1000)
}

函数 基线_意图识别质量(关键词命中, 上下文连续, 漂移, 噪声) {
    返回 数学_夹紧(关键词命中 / 2 + 上下文连续 / 4 - 漂移 / 4 - 噪声 / 5, 0, 1000)
}

函数 原创_意图锁定质量(关键词命中, 语义原型, 上下文连续, 漂移, 实体完整, 噪声) {
    定义 可变 分数 = 基线_意图识别质量(关键词命中, 上下文连续, 漂移, 噪声)
    定义 锁定量 = 原创_势场锁定量(语义原型, 上下文连续, 漂移, 噪声)
    分数 = 分数 + 锁定量 + 实体完整 / 6
    如果 (语义原型 > 720) {
        如果 (实体完整 > 680) { 分数 = 分数 + 55 }
    }
    返回 数学_夹紧(分数, 0, 1000)
}

函数 基线_链式推理质量(步骤可靠, 一致性, 干扰) {
    返回 数学_夹紧(步骤可靠 / 2 + 一致性 / 4 - 干扰 / 3, 0, 1000)
}

函数 原创_链式验证回溯质量(步骤可靠, 依赖清晰, 中间验证, 回溯弹性, 一致性, 干扰) {
    定义 可变 分数 = 基线_链式推理质量(步骤可靠, 一致性, 干扰)
    分数 = 分数 + 依赖清晰 / 6 + 中间验证 / 5 + 回溯弹性 / 6 + 步骤可靠 / 10 - 干扰 / 7
    如果 (中间验证 > 760) {
        如果 (回溯弹性 > 700) { 分数 = 分数 + 70 }
    }
    如果 (依赖清晰 > 700) {
        如果 (一致性 > 650) { 分数 = 分数 + 45 }
    }
    返回 数学_夹紧(分数, 0, 1000)
}

函数 基线_检索融合质量(召回, 匹配, 冗余) {
    返回 数学_夹紧(召回 / 2 + 匹配 / 4 - 冗余 / 3, 0, 1000)
}

函数 原创_认知检索质量(召回, 匹配, 草图一致, 融合稳定, 冗余, 噪声) {
    定义 可变 分数 = 基线_检索融合质量(召回, 匹配, 冗余)
    定义 折叠量 = 原创_几何折叠量(匹配, 融合稳定, 草图一致, 冗余 + 噪声)
    分数 = 分数 + 折叠量 + 召回 / 10 - 噪声 / 8
    如果 (草图一致 > 760) {
        如果 (融合稳定 > 720) { 分数 = 分数 + 65 }
    }
    返回 数学_夹紧(分数, 0, 1000)
}

函数 基线_自适应学习质量(学习率稳定, 梯度可信, 过拟合风险) {
    返回 数学_夹紧(学习率稳定 / 3 + 梯度可信 / 2 - 过拟合风险 / 3, 0, 1000)
}

函数 原创_双环自适应学习质量(学习率稳定, 梯度可信, 外环调度, 内环塑性, 过拟合风险, 干扰) {
    定义 可变 分数 = 基线_自适应学习质量(学习率稳定, 梯度可信, 过拟合风险)
    定义 协同量 = 原创_双环协同量(内环塑性, 外环调度, 梯度可信, 学习率稳定, 干扰)
    分数 = 分数 + 协同量 - 过拟合风险 / 8
    如果 (外环调度 > 720) {
        如果 (内环塑性 > 700) { 分数 = 分数 + 70 }
    }
    如果 (梯度可信 > 720) {
        如果 (干扰 < 220) { 分数 = 分数 + 50 }
    }
    返回 数学_夹紧(分数, 0, 1000)
}

函数 基线_策略稳态质量(回报, 探索, 方差) {
    返回 数学_夹紧(回报 / 2 + 探索 / 5 - 方差 / 3, 0, 1000)
}

函数 原创_外环策略稳态质量(回报, 探索, 熵稳态, 剪裁保护, 方差, 噪声) {
    定义 可变 分数 = 基线_策略稳态质量(回报, 探索, 方差)
    定义 协同量 = 原创_双环协同量(探索, 剪裁保护, 回报, 熵稳态, 方差 + 噪声)
    分数 = 分数 + 协同量 - 噪声 / 8
    如果 (熵稳态 > 700) {
        如果 (剪裁保护 > 680) { 分数 = 分数 + 60 }
    }
    如果 (回报 > 760) {
        如果 (方差 < 260) { 分数 = 分数 + 50 }
    }
    返回 数学_夹紧(分数, 0, 1000)
}

函数 基线_演化迭代质量(阶段成熟, 本地接管, 沙盒门禁, 风险) {
    返回 数学_夹紧(阶段成熟 / 3 + 本地接管 / 5 + 沙盒门禁 / 6 - 风险 / 3, 0, 1000)
}

函数 原创_演化闭环质量(阶段成熟, 本地接管, 外环调度, 内环塑性, 熵稳态, 沙盒门禁, 回滚保护, 风险, 衰减) {
    定义 可变 分数 = 基线_演化迭代质量(阶段成熟, 本地接管, 沙盒门禁, 风险 + 衰减)
    定义 协同量 = 原创_双环协同量(内环塑性, 外环调度, 阶段成熟, 熵稳态, 风险 + 衰减)
    定义 稳态量 = 原创_外环策略稳态质量(阶段成熟, 本地接管, 熵稳态, 回滚保护, 风险, 衰减)
    分数 = 分数 + 协同量 / 3 + 稳态量 / 3 + 沙盒门禁 / 4 + 回滚保护 / 6 - 风险 / 8
    如果 (沙盒门禁 > 780) {
        如果 (回滚保护 > 720) { 分数 = 分数 + 70 }
    }
    如果 (外环调度 > 700) {
        如果 (内环塑性 > 680) { 分数 = 分数 + 55 }
    }
    如果 (阶段成熟 > 760) {
        如果 (熵稳态 > 700) { 分数 = 分数 + 50 }
    }
    返回 数学_夹紧(分数, 0, 1000)
}

函数 基线_梯度搜索质量(梯度稳定, 收敛速度, 扰动) {
    返回 数学_夹紧(梯度稳定 / 3 + 收敛速度 / 2 - 扰动 / 3, 0, 1000)
}

函数 原创_信息几何搜索质量(梯度稳定, Fisher一致, 测地线平滑, 散度收敛, 收敛速度, 扰动) {
    定义 可变 分数 = 基线_梯度搜索质量(梯度稳定, 收敛速度, 扰动)
    定义 几何量 = 原创_几何折叠量(Fisher一致, 测地线平滑, 散度收敛, 扰动)
    分数 = 分数 + 几何量 + 梯度稳定 / 10 + 散度收敛 / 8
    如果 (Fisher一致 > 720) {
        如果 (测地线平滑 > 700) { 分数 = 分数 + 65 }
    }
    如果 (散度收敛 > 680) {
        如果 (扰动 < 220) { 分数 = 分数 + 45 }
    }
    返回 数学_夹紧(分数, 0, 1000)
}

函数 原创_构造见证量(见证有效, 指纹一致, 不变量覆盖, 扰动) {
    定义 可变 见证量 = 见证有效 / 7 + 指纹一致 / 8 + 不变量覆盖 / 6 - 扰动 / 10
    如果 (见证有效 > 760) {
        如果 (指纹一致 > 720) { 见证量 = 见证量 + 60 }
    }
    如果 (不变量覆盖 > 680) {
        如果 (扰动 < 240) { 见证量 = 见证量 + 35 }
    }
    返回 见证量
}

函数 基线_语义保持质量(语义等价, 指纹一致, 扰动) {
    返回 数学_夹紧(语义等价 / 3 + 指纹一致 / 4 - 扰动 / 3, 0, 1000)
}

函数 原创_自指验证质量(不动点稳定, 见证有效, 语义等价, 指纹一致, 不变量覆盖, 扰动) {
    定义 可变 分数 = 基线_语义保持质量(语义等价, 指纹一致, 扰动)
    定义 见证量 = 原创_构造见证量(见证有效, 指纹一致, 不变量覆盖, 扰动)
    分数 = 分数 + 见证量 + 不动点稳定 / 9 + 语义等价 / 8
    如果 (不动点稳定 > 720) {
        如果 (见证有效 > 700) { 分数 = 分数 + 55 }
    }
    如果 (语义等价 > 760) {
        如果 (不变量覆盖 > 700) { 分数 = 分数 + 50 }
    }
    返回 数学_夹紧(分数, 0, 1000)
}

// NovaOS 合成器核心渲染循环 — 帧合成/VSync/动画/Tile管理/AI帧预算
// 本模块是渲染引擎的心跳: 每帧60/120次驱动整个显示流水线。
//   1. VSync同步: 与显示器刷新率精确对齐
//   2. 惯性滚动/缩放: 物理模拟的流畅交互
//   3. 动画推进: CSS动画/过渡/Web动画API的统一时钟
//   4. Tile优先级管理: 视口内优先/预取邻近区域
//   5. 层合成: z-order排序/变换/透明度/裁剪/混合模式
//   6. AI帧预算: 动态调整渲染质量以保证帧率
//   7. 性能监控: 帧耗时/丢帧/卡顿检测
// 与图形引擎、内核调度器、设备驱动、智能大脑深度耦合。

导入("./内核直连层.nova")
导入("../中枢/公共智能.nova")
导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/日志中枢.nova")
导入("../中枢/进程调度.nova")
导入("../中枢/同步原语.nova")
导入("../引导/引导加载器.nova")
导入("../稳态/图处显示.nova")
导入("../执行/命令写入.nova")
导入("../推理/智能总线桥.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/内核打印.nova")
导入("../稳态/统一操作接.nova")
导入("../中枢/创建甲.nova")
导入("../中枢/整数转字符串.nova")

// §1 渲染常量

定义 TILE_大小 = 256
定义 Tile状态_空闲 = 0
定义 Tile状态_光栅化中 = 1
定义 Tile状态_已就绪 = 2
定义 Tile状态_过期 = 3

定义 VSync_60HZ = 16666
定义 VSync_120HZ = 8333
定义 VSync_144HZ = 6944
定义 帧预算_毫秒_60 = 16
定义 帧预算_毫秒_120 = 8
定义 丢帧_阈值_毫秒 = 32
定义 卡顿_阈值_毫秒 = 100
定义 帧历史_大小 = 64
定义 动画_最大并发 = 256

定义 混合模式_正常 = 0
定义 混合模式_相乘 = 1
定义 混合模式_叠加 = 2
定义 混合模式_滤色 = 3

定义 可变 全局AI总线 = 0

// §2 合成器结构

结构 合成器 {
    图处上下文,
    当前帧号,
    层列表,
    层数,
    视口x,
    视口y,
    视口宽,
    视口高,
    帧耗时历史,
    帧耗时索引,
    上次合成时间,
    // VSync
    VSync间隔_微秒,
    VSync启用,
    上次VSync时间,
    // 惯性滚动
    滚动速度x,
    滚动速度y,
    滚动摩擦,
    // 动画
    动画列表,
    动画数,
    // 性能
    丢帧数,
    卡顿数,
    总帧数,
    平均帧耗时,
    // AI帧预算
    AI质量因子,
    AI预测帧耗时,
    AI降级激活,
}

结构 合成层 {
    层ID,
    z_index,
    视口可见,
    渲染精度,
    有变换,
    变换矩阵,
    透明度,
    裁剪区域,
    混合模式,
    Tiles,
    Tile行数,
    Tile列数,
    脏区域,
    上次更新帧,
}

结构 渲染动画 {
    ID,
    目标层,
    属性,
    起始值,
    结束值,
    当前值,
    持续时间_微秒,
    已经过_微秒,
    缓动函数,
    循环,
    已完成,
}

// §3 核心渲染循环

函数 Compositor_合成帧(comp) {
    如果 (comp == 0 || comp.图处上下文 == 0) { 返回 }

    定义 帧开始 = 平台_获取高精度时间()
    comp.当前帧号 = comp.当前帧号 + 1
    comp.总帧数 = comp.总帧数 + 1

    定义 ctx = comp.图处上下文
    定义 帧预算 = comp.VSync间隔_微秒

    // 0. AI帧预算检查: 决定本帧渲染质量
    定义 质量 = AI帧预算_决定质量(comp)

    // 1. 惯性滚动
    Compositor_惯性滚动步(comp)

    // 2. 推进动画
    定义 动画增量 = 帧开始 - comp.上次合成时间
    如果 (动画增量 > 0) {
        Compositor_更新动画(comp, 动画增量)
    }

    // 3. 更新Tile优先级
    Compositor_更新Tile优先级(comp)

    // 4. 清屏
    图处_清屏(ctx, 255, 255, 255, 255)

    // 5. 按z-order合成所有可见Layer
    定义 可变 绘制层数 = 0
    定义 可变 绘制Tile数 = 0
    定义 可变 i = 0
    当 (i < comp.层数) {
        定义 层 = comp.层列表[i]
        如果 (层 == 0) { i = i + 1; 继续 }
        定义 cl = 层

        // 视口剔除: 完全不可见的层跳过
        如果 (cl.视口可见 == 0 && cl.渲染精度 == 0) {
            i = i + 1
            继续
        }

        // AI质量降级: 低质量时跳过低优先级层
        如果 (质量 < 50 && cl.z_index < -10) {
            i = i + 1
            继续
        }

        // 设置图形状态
        Compositor_设置层状态(ctx, cl)

        // 绘制所有已就绪的Tile
        定义 本层Tile数 = Compositor_绘制层Tiles(comp, ctx, cl, 质量)
        绘制Tile数 = 绘制Tile数 + 本层Tile数
        绘制层数 = 绘制层数 + 1

        // 重置图形状态
        如果 (cl.有变换) {
            图处_重置变换(ctx)
        }

        i = i + 1
    }

    // 6. 绘制调试覆盖(开发模式)
    如果 (comp.AI降级激活) {
        Compositor_绘制降级指示(comp, ctx)
    }

    // 7. 提交帧
    图处_帧结束(ctx)

    // 8. 性能统计
    定义 帧耗时 = 平台_获取高精度时间() - 帧开始
    Compositor_记录帧耗时(comp, 帧耗时)
    comp.上次合成时间 = 帧开始

    // 9. AI反馈
    如果 (全局AI总线 != 0) {
        AI总线_反馈_帧耗时(全局AI总线, 帧耗时)
    }
}

// §4 层渲染

函数 Compositor_设置层状态(ctx, cl) {
    // 变换
    如果 (cl.有变换) {
        图处_设置变换(ctx, cl.变换矩阵[0], cl.变换矩阵[1],
                     cl.变换矩阵[2], cl.变换矩阵[3],
                     cl.变换矩阵[4], cl.变换矩阵[5])
    }
    // 透明度
    如果 (cl.透明度 < 255) {
        图处_设置透明度(ctx, cl.透明度)
    }
    // 裁剪
    图处_设置裁剪(ctx, cl.裁剪区域[0], cl.裁剪区域[1],
                 cl.裁剪区域[2], cl.裁剪区域[3])
    // 混合模式
    如果 (cl.混合模式 != 混合模式_正常) {
        图处_设置混合模式(ctx, cl.混合模式)
    }
}

函数 Compositor_绘制层Tiles(comp, ctx, cl, 质量) {
    定义 可变 绘制数 = 0
    定义 可变 row = 0
    当 (row < cl.Tile行数) {
        定义 可变 col = 0
        当 (col < cl.Tile列数) {
            定义 idx = row * cl.Tile列数 + col
            定义 tile_偏移 = cl.Tiles + idx * 32
            定义 tile_纹理 = 内存_读32(tile_偏移)
            定义 tile_状态 = 内存_读8(tile_偏移 + 20)
            定义 tile_分辨率 = 内存_读8(tile_偏移 + 22)

            如果 (tile_状态 == Tile状态_已就绪 && tile_纹理 > 0 && tile_分辨率 > 0) {
                定义 屏幕x = 内存_读32(tile_偏移 + 12) - comp.视口x
                定义 屏幕y = 内存_读32(tile_偏移 + 16) - comp.视口y

                // 视口裁剪
                如果 (屏幕x + TILE_大小 > 0 && 屏幕x < comp.视口宽 &&
                    屏幕y + TILE_大小 > 0 && 屏幕y < comp.视口高) {

                    // AI质量: 低质量时降低Tile分辨率
                    如果 (质量 < 70 && tile_分辨率 > 1) {
                        图处_绘制纹理矩形_缩放(ctx, tile_纹理, 屏幕x, 屏幕y, TILE_大小, TILE_大小, 质量)
                    } 否则 {
                        图处_绘制纹理矩形(ctx, tile_纹理, 屏幕x, 屏幕y, TILE_大小, TILE_大小)
                    }
                    绘制数 = 绘制数 + 1
                }
            }

            内存_写32(tile_偏移 + 24, comp.当前帧号)
            col = col + 1
        }
        row = row + 1
    }
    返回 绘制数
}

// §5 惯性滚动物理模拟

函数 Compositor_惯性滚动步(comp) {
    如果 (comp.滚动速度x == 0 && comp.滚动速度y == 0) { 返回 }

    // 应用速度
    comp.视口x = comp.视口x + comp.滚动速度x / 1000
    comp.视口y = comp.视口y + comp.滚动速度y / 1000

    // 摩擦衰减(指数衰减)
    comp.滚动速度x = comp.滚动速度x * comp.滚动摩擦 / 1000
    comp.滚动速度y = comp.滚动速度y * comp.滚动摩擦 / 1000

    // 停止阈值
    如果 (comp.滚动速度x > -50 && comp.滚动速度x < 50) { comp.滚动速度x = 0 }
    如果 (comp.滚动速度y > -50 && comp.滚动速度y < 50) { comp.滚动速度y = 0 }

    // 边界弹回
    如果 (comp.视口x < 0) {
        comp.视口x = 0
        comp.滚动速度x = -comp.滚动速度x / 3
    }
    如果 (comp.视口y < 0) {
        comp.视口y = 0
        comp.滚动速度y = -comp.滚动速度y / 3
    }
}

函数 Compositor_开始惯性(comp, 速度x, 速度y) {
    comp.滚动速度x = 速度x
    comp.滚动速度y = 速度y
    comp.滚动摩擦 = 950
}

// §6 动画系统

函数 Compositor_更新动画(comp, 增量_微秒) {
    定义 可变 活跃数 = 0
    定义 可变 i = 0
    当 (i < comp.动画数) {
        定义 动画 = comp.动画列表[i]
        如果 (动画.已完成) { i = i + 1; 继续 }

        动画.已经过_微秒 = 动画.已经过_微秒 + 增量_微秒
        定义 进度 = 0
        如果 (动画.持续时间_微秒 > 0) {
            进度 = 动画.已经过_微秒 * 1000 / 动画.持续时间_微秒
        }
        如果 (进度 > 1000) { 进度 = 1000 }

        // 缓动函数
        定义 缓动值 = 缓动_计算(动画.缓动函数, 进度)

        // 插值
        动画.当前值 = 动画.起始值 + (动画.结束值 - 动画.起始值) * 缓动值 / 1000

        // 应用到目标层
        Compositor_应用动画值(comp, 动画)

        // 完成检查
        如果 (进度 >= 1000) {
            如果 (动画.循环) {
                动画.已经过_微秒 = 0
            } 否则 {
                动画.已完成 = 真
                动画.当前值 = 动画.结束值
            }
        }

        活跃数 = 活跃数 + 1
        i = i + 1
    }
}

函数 缓动_计算(类型, t) {
    // t = 0~1000
    如果 (类型 == 0) { 返回 t }
    如果 (类型 == 1) { 返回 t * t / 1000 }
    如果 (类型 == 2) { 返回 t * (2000 - t) / 1000 }
    如果 (类型 == 3) {
        如果 (t < 500) { 返回 t * t * 2 / 1000000 * 1000 }
        定义 t2 = t - 1000
        返回 1000 - t2 * t2 * 2 / 1000000 * 1000
    }
    返回 t
}

函数 Compositor_应用动画值(comp, 动画) {
    如果 (动画.目标层 >= comp.层数) { 返回 }
    定义 cl = comp.层列表[动画.目标层]
    如果 (cl == 0) { 返回 }
    如果 (动画.属性 == 0) { cl.透明度 = 动画.当前值 }
}

函数 Compositor_添加动画(comp, 目标层, 属性, 起始, 结束, 持续_微秒, 缓动, 循环) {
    如果 (comp.动画数 >= 动画_最大并发) { 返回 -1 }
    定义 ID = comp.动画数
    追加(comp.动画列表, 渲染动画 {
        ID: ID, 目标层: 目标层, 属性: 属性,
        起始值: 起始, 结束值: 结束, 当前值: 起始,
        持续时间_微秒: 持续_微秒, 已经过_微秒: 0,
        缓动函数: 缓动, 循环: 循环, 已完成: 假,
    })
    comp.动画数 = comp.动画数 + 1
    返回 ID
}

// §7 Tile优先级管理

函数 Compositor_更新Tile优先级(comp) {
    定义 可变 i = 0
    当 (i < comp.层数) {
        定义 cl = comp.层列表[i]
        如果 (cl == 0) { i = i + 1; 继续 }

        定义 可变 row = 0
        当 (row < cl.Tile行数) {
            定义 可变 col = 0
            当 (col < cl.Tile列数) {
                定义 idx = row * cl.Tile列数 + col
                定义 tile_偏移 = cl.Tiles + idx * 32
                定义 tile_x = 内存_读32(tile_偏移 + 12)
                定义 tile_y = 内存_读32(tile_偏移 + 16)

                // 视口内: 高优先级; 视口边缘: 中; 远离: 低
                定义 可变 优先级 = 0
                如果 (tile_x + TILE_大小 > comp.视口x && tile_x < comp.视口x + comp.视口宽 &&
                    tile_y + TILE_大小 > comp.视口y && tile_y < comp.视口y + comp.视口高) {
                    优先级 = 100
                } 否则 {
                    定义 dx = 0
                    如果 (tile_x < comp.视口x) { dx = comp.视口x - tile_x }
                    否则 如果 (tile_x > comp.视口x + comp.视口宽) { dx = tile_x - comp.视口x - comp.视口宽}
                    定义 dy = 0
                    如果 (tile_y < comp.视口y) { dy = comp.视口y - tile_y }
                    否则 如果 (tile_y > comp.视口y + comp.视口高) { dy = tile_y - comp.视口y - comp.视口高}
                    定义 距离 = dx + dy
                    优先级 = 50 - 距离 / TILE_大小
                    如果 (优先级 < 0) { 优先级 = 0 }
                }
                内存_写8(tile_偏移 + 21, 优先级)

                // 过期检测: 超过30帧未使用的Tile可回收
                定义 上次使用帧 = 内存_读32(tile_偏移 + 24)
                如果 (comp.当前帧号 - 上次使用帧 > 30) {
                    内存_写8(tile_偏移 + 20, Tile状态_过期)
                }

                col = col + 1
            }
            row = row + 1
        }
        i = i + 1
    }
}

// §8 AI帧预算管理

函数 AI帧预算_决定质量(comp) {
    // 基于最近帧耗时预测本帧是否需要降级
    定义 平均 = comp.平均帧耗时
    定义 预算 = comp.VSync间隔_微秒

    如果 (预算 <= 0) { 预算 = VSync_60HZ }

    // 质量因子: 100=全质量, 0=最低质量
    定义 可变 质量 = 100

    如果 (平均 > 预算 * 90 / 100) {
        // 接近预算上限: 开始降级
        质量 = 70
        comp.AI降级激活 = 真
    }
    如果 (平均 > 预算) {
        // 超出预算: 严重降级
        质量 = 40
    }
    如果 (平均 > 预算 * 150 / 100) {
        // 远超预算: 最低质量
        质量 = 20
    }
    如果 (平均 < 预算 * 70 / 100) {
        // 余量充裕: 恢复全质量
        质量 = 100
        comp.AI降级激活 = 假
    }

    // 平滑过渡
    comp.AI质量因子 = (comp.AI质量因子 * 3 + 质量) / 4
    返回 comp.AI质量因子
}

// §9 性能监控

函数 Compositor_记录帧耗时(comp, 帧耗时) {
    定义 idx = comp.帧耗时索引 % 帧历史_大小
    comp.帧耗时历史[idx] = 帧耗时
    comp.帧耗时索引 = comp.帧耗时索引 + 1

    // 更新平均
    定义 可变 总和 = 0
    定义 样本数 = 帧历史_大小
    如果 (comp.帧耗时索引 < 帧历史_大小) { 样本数 = comp.帧耗时索引 }
    定义 可变 i = 0
    当 (i < 样本数) {
        总和 = 总和 + comp.帧耗时历史[i]
        i = i + 1
    }
    如果 (样本数 > 0) { comp.平均帧耗时 = 总和 / 样本数 }

    // 丢帧检测
    如果 (帧耗时 > 丢帧_阈值_毫秒 * 1000) {
        comp.丢帧数 = comp.丢帧数 + 1
    }

    // 卡顿检测
    如果 (帧耗时 > 卡顿_阈值_毫秒 * 1000) {
        comp.卡顿数 = comp.卡顿数 + 1
        内核调试("[合成器] 卡顿: " + 整数转字符串(帧耗时 / 1000) + "ms 帧#" + 整数转字符串(comp.当前帧号))
    }
}

函数 Compositor_绘制降级指示(comp, ctx) {
    // 在屏幕右上角显示红色小方块表示降级中
    图处_填充矩形(ctx, comp.视口宽 - 20, 5, 15, 15, 255, 50, 50, 200)
}

// §10 合成器初始化与统计

函数 Compositor_创建(宽, 高, ctx) {
    定义 comp = 合成器 {
        图处上下文: ctx,
        当前帧号: 0,
        层列表: [],
        层数: 0,
        视口x: 0, 视口y: 0,
        视口宽: 宽, 视口高: 高,
        帧耗时历史: [],
        帧耗时索引: 0,
        上次合成时间: 平台_获取高精度时间(),
        VSync间隔_微秒: VSync_60HZ,
        VSync启用: 真,
        上次VSync时间: 0,
        滚动速度x: 0, 滚动速度y: 0, 滚动摩擦: 950,
        动画列表: [],
        动画数: 0,
        丢帧数: 0, 卡顿数: 0, 总帧数: 0, 平均帧耗时: 0,
        AI质量因子: 100, AI预测帧耗时: 0, AI降级激活: 假,
    }
    // 初始化帧历史
    定义 可变 i = 0
    当 (i < 帧历史_大小) {
        追加(comp.帧耗时历史, 0)
        i = i + 1
    }
    返回 comp
}

函数 Compositor_统计(comp) {
    如果 (comp == 0) { 返回 空 }
    定义 FPS = 0
    如果 (comp.平均帧耗时 > 0) { FPS = 1000000 / comp.平均帧耗时 }
    返回 {
        总帧: comp.总帧数,
        当前帧: comp.当前帧号,
        FPS: FPS,
        平均帧耗时_微秒: comp.平均帧耗时,
        丢帧: comp.丢帧数,
        卡顿: comp.卡顿数,
        层数: comp.层数,
        动画数: comp.动画数,
        AI质量: comp.AI质量因子,
        AI降级: comp.AI降级激活,
        视口: [comp.视口x, comp.视口y, comp.视口宽, comp.视口高],
    }
}

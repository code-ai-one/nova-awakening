// Nova · 运行时 · 观测 · 符号服务 (5.7)
// 编译产物的函数符号表、行号映射、模块偏移映射、段布局映射
// 支持无截图模式下的函数/行号级回溯

// 符号条目: [符号名, 模块名, 段名, 偏移, 虚拟地址, 种类]
// 种类: 0=函数 1=全局 2=运行时 3=JIT 4=AOT

导入("../../标准库/基础.nova")

定义 符号种类_全局 = 1
定义 符号种类_运行时 = 2
定义 符号种类_JIT = 3
定义 符号种类_AOT = 4

定义 可变 符号服务__符号表 = []
定义 可变 _符号索引 = 字典()

函数 观测_符号_注册(符号名, 模块名, 段名, 偏移, 虚拟地址, 种类) {
    定义 条目 = [符号名, 模块名, 段名, 偏移, 虚拟地址, 种类]
    追加(符号服务__符号表, 条目)
    字典设(_符号索引, 符号名, 计数(符号服务__符号表) - 1)
}

函数 符号_查找(符号名) {
    如果 (字典有(_符号索引, 符号名)) {
        定义 idx = 字典取(_符号索引, 符号名)
        返回 符号服务__符号表[idx]
    }
    返回 空
}

函数 符号_按地址查找(地址) {
    定义 可变 最近 = 空
    定义 可变 最近距离 = 0 - 1
    定义 可变 i = 0
    当 (i < 计数(符号服务__符号表)) {
        定义 条目 = 符号服务__符号表[i]
        如果 (条目[4] <= 地址) {
            定义 距离 = 地址 - 条目[4]
            如果 (最近距离 < 0 或 距离 < 最近距离) {
                最近 = 条目
                最近距离 = 距离
            }
        }
        i = i + 1
    }
    返回 最近
}

函数 符号_总数() { 返回 计数(符号服务__符号表) }

函数 符号_清空() {
    符号服务__符号表 = []
    _符号索引 = 字典()
}

// 行号映射: [模块名, 源文件, 行号, 代码偏移, 符号名]

函数 行号映射_注册(模块名, 源文件, 行号, 代码偏移, 符号名) {
    追加(_行号映射表, [模块名, 源文件, 行号, 代码偏移, 符号名])
}

函数 行号映射_按偏移查找(代码偏移) {
    定义 可变 最近 = 空
    定义 可变 最近距离 = 0 - 1
    定义 可变 i = 0
    当 (i < 计数(_行号映射表)) {
        定义 条目 = _行号映射表[i]
        如果 (条目[3] <= 代码偏移) {
            定义 距离 = 代码偏移 - 条目[3]
            如果 (最近距离 < 0 或 距离 < 最近距离) {
                最近 = 条目
                最近距离 = 距离
            }
        }
        i = i + 1
    }
    返回 最近
}

函数 行号映射_总数() { 返回 计数(_行号映射表) }

// 模块偏移映射: [模块名, 基偏移, 大小, 入口偏移]
定义 可变 _模块映射表 = []

函数 模块映射_注册(模块名, 基偏移, 大小, 入口偏移) {
    追加(_模块映射表, [模块名, 基偏移, 大小, 入口偏移])
}

函数 模块映射_按偏移查找(偏移) {
    定义 可变 i = 0
    当 (i < 计数(_模块映射表)) {
        定义 条目 = _模块映射表[i]
        如果 (偏移 >= 条目[1] 且 偏移 < 条目[1] + 条目[2]) {
            返回 条目
        }
        i = i + 1
    }
    返回 空
}

函数 模块映射_总数() { 返回 计数(_模块映射表) }

// 段布局映射: [段名, 基址, 大小, 权限, 对齐]
// 权限: 1=读 2=写 4=执行
定义 可变 _段布局表 = []

函数 段布局_注册(段名, 基址, 大小, 权限, 对齐) {
    追加(_段布局表, [段名, 基址, 大小, 权限, 对齐])
}

函数 段布局_总数() { 返回 计数(_段布局表) }

// 符号服务报告
函数 符号服务_打印报告() {
    打印文本("═══ 符号服务报告 ═══")
    打印文本(字符串拼接("  符号总数: ", 转字符串(计数(符号服务__符号表))))
    打印文本(字符串拼接("  行号映射: ", 转字符串(计数(_行号映射表))))
    打印文本(字符串拼接("  模块映射: ", 转字符串(计数(_模块映射表))))
    打印文本(字符串拼接("  段布局: ", 转字符串(计数(_段布局表))))
    // 按种类统计
    定义 可变 fn数 = 0
    定义 可变 gl数 = 0
    定义 可变 rt数 = 0
    定义 可变 jit数 = 0
    定义 可变 aot数 = 0
    定义 可变 i = 0
    当 (i < 计数(符号服务__符号表)) {
        如果 (符号服务__符号表[i][5] == 0) { fn数 = fn数 + 1 }
        如果 (符号服务__符号表[i][5] == 1) { gl数 = gl数 + 1 }
        如果 (符号服务__符号表[i][5] == 2) { rt数 = rt数 + 1 }
        如果 (符号服务__符号表[i][5] == 3) { jit数 = jit数 + 1 }
        如果 (符号服务__符号表[i][5] == 4) { aot数 = aot数 + 1 }
        i = i + 1
    }
}

// JIT/AOT代码区间映射
定义 可变 _JIT区间表 = []

函数 JIT区间_注册(函数名, 起始, 大小, 模式) {
    // 模式: 0=JIT 1=AOT
    追加(_JIT区间表, [函数名, 起始, 大小, 模式])
}

函数 JIT区间_按地址查找(地址) {
    定义 可变 i = 0
    当 (i < 计数(_JIT区间表)) {
        定义 条目 = _JIT区间表[i]
        如果 (地址 >= 条目[1] 且 地址 < 条目[1] + 条目[2]) {
            返回 条目
        }
        i = i + 1
    }
    返回 空
}

// NovaOS 定点数学库 v2.0
// 功能:
//  §1 精确三角函数(sin/cos/tan, 8阶泰勒+象限归约)
//  §2 反三角(atan2/asin/acos, 泰勒+CORDIC)
//  §3 幂/根/对数(sqrt牛顿/exp泰勒/ln幂级数)
//  §4 CORDIC向量旋转(16级精度)
//  §5 2D/3D变换矩阵(rotate/scale/translate/multiply)
//  §6 Bézier曲线(二次/三次/采样/长度)
//  §7 缓动函数(ease-in/out/in-out, 贝塞尔缓动)
//  §8 AI样式意图推断

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/内核打印.nova")
导入("../推理/值乘.nova")
导入("../中枢/整数转字符串.nova")

// §1 常量

// 定点精度: ×10000 (即 FP14.14 等效)
定义 FP = 10000
定义 FP_HALF = 5000
定义 FP_TWO = 20000

// 常用定点常量 (value × 10000)
定义 FP_PI       = 31416   // π
定义 FP_TWO_PI   = 62832   // 2π
定义 FP_HALF_PI  = 15708   // π/2
定义 FP_QRTR_PI  = 7854    // π/4
定义 FP_E        = 27183   // e
定义 FP_LN2      = 6931    // ln(2)
定义 FP_SQRT2    = 14142   // √2
定义 FP_INV_SQRT2= 7071    // 1/√2

// CORDIC表(16级, atan(2^-i) × 10000)
定义 CORDIC_级数 = 16
定义 CORDIC_增益 = 6073     // K ≈ 0.6073 × 10000

// Q10兼容
定义 Q10 = 1024
定义 Q_ONE = 1024


// §2 定点三角函数 (8阶泰勒展开)

函数 定点_cos_精确(x) {
    // x: 弧度×FP, 返回: cos(x)×FP
    // 范围归一化到 [0, 2π)
    定义 可变 角 = x % FP_TWO_PI
    如果 (角 < 0) { 角 = 角 + FP_TWO_PI }

    // 象限归约到 [0, π/2]
    定义 可变 象限 = 角 / FP_HALF_PI
    定义 可变 余 = 角 % FP_HALF_PI
    如果 (象限 > 3) { 象限 = 3 }
    // 【修复】Q1和Q3用π/2-r变换; Q0和Q2直接用r
    // Q0: cos(r)           Q1: -cos(π/2-r)=-sin(r)
    // Q2: -cos(r)          Q3: cos(π/2-r)=sin(r)
    // 原版bug: Q2也用了π/2-r导致cos(π)=0而非-1
    如果 (象限 == 1 || 象限 == 3) { 余 = FP_HALF_PI - 余 }

    // 8阶泰勒: cos(t) ≈ 1 - t²/2! + t⁴/4! - t⁶/6! + t⁸/8!
    定义 t = 余
    定义 t2 = t * t / FP
    定义 t4 = t2 * t2 / FP
    定义 t6 = t4 * t2 / FP
    定义 t8 = t4 * t4 / FP

    定义 可变 结果 = FP - t2 / 2 + t4 / 24 - t6 / 720 + t8 / 40320

    // 象限符号: Q1和Q2取负
    如果 (象限 == 1 || 象限 == 2) { 结果 = 0 - 结果 }

    返回 结果
}

函数 定点_sin_精确(x) {
    返回 定点_cos_精确(x - FP_HALF_PI)
}

函数 定点_tan(x) {
    定义 c = 定点_cos_精确(x)
    如果 (c == 0) { 返回 100000000 }
    返回 定点_sin_精确(x) * FP / c
}

函数 定点_cot(x) {
    定义 s = 定点_sin_精确(x)
    如果 (s == 0) { 返回 100000000 }
    返回 定点_cos_精确(x) * FP / s
}

函数 定点_sec(x) {
    定义 c = 定点_cos_精确(x)
    如果 (c == 0) { 返回 100000000 }
    返回 FP * FP / c
}

函数 定点_csc(x) {
    定义 s = 定点_sin_精确(x)
    如果 (s == 0) { 返回 100000000 }
    返回 FP * FP / s
}

// §3 反三角函数
// B6验证(b6_trig_quant_verify.py): 原版atan2 Q2/Q3象限误差180°已修复
//   修复1: 删除|r|>1分支的多余x<0象限调整 (根因: π/2-atan已在正确象限)
//   修复2: |r|∈(0.8,1]用半角公式替换7阶泰勒 (消除3.5°收敛误差)
//   结果: atan2最大误差0.069°, asin/acos最大误差0.034°/0.035° ✅

函数 定点_atan2(y, x) {
    如果 (x == 0 && y == 0) { 返回 0 }
    如果 (x == 0) {
        如果 (y > 0) { 返回 FP_HALF_PI }
        返回 0 - FP_HALF_PI
    }
    定义 可变 r = y * FP / x
    如果 (r > FP || r < -FP) {
        // |r|>1: atan(r) = sign(r)×π/2 - atan(x/y)
        // 【修复】删除原来多余的x<0象限调整:
        //   π/2-atan(x/y) 已在正确象限, 无需再加π
        //   原版bug: Q2(x<0,y>0)|y|>|x| 误差高达180°
        定义 inv = x * FP / y
        定义 i2 = inv * inv / FP
        定义 i3 = i2 * inv / FP
        定义 i5 = i3 * i2 / FP
        定义 i7 = i5 * i2 / FP
        定义 at = inv - i3 / 3 + i5 / 5 - i7 / 7
        如果 (y > 0) { 返回 FP_HALF_PI - at }
        返回 0 - FP_HALF_PI - at
    }
    // |r|<=1: 分段策略
    // r在[-8000,-FP]∪[8000,FP]时用半角公式消除|r|→1时的3.5°误差
    // atan(r) = ±π/4 + atan((r∓FP)/(r±FP))
    定义 可变 结果 = 0
    如果 (r > 8000) {
        定义 u = (r - FP) * FP / (r + FP)
        定义 u2 = u * u / FP
        定义 u3 = u2 * u / FP
        结果 = FP_QRTR_PI + u - u3 / 3
    } 否则如果 (r < -8000) {
        定义 u = (r + FP) * FP / (0 - r + FP)
        定义 u2 = u * u / FP
        定义 u3 = u2 * u / FP
        结果 = 0 - FP_QRTR_PI + u - u3 / 3
    } 否则 {
        定义 r2 = r * r / FP
        定义 r3 = r2 * r / FP
        定义 r5 = r3 * r2 / FP
        定义 r7 = r5 * r2 / FP
        结果 = r - r3 / 3 + r5 / 5 - r7 / 7
    }
    如果 (x < 0) {
        如果 (y >= 0) { 结果 = 结果 + FP_PI }
        否则 { 结果 = 结果 - FP_PI }
    }
    返回 结果
}

函数 定点_asin(x) {
    // asin(x) = atan2(x, sqrt(1-x²))
    如果 (x >= FP) { 返回 FP_HALF_PI }
    如果 (x <= -FP) { 返回 0 - FP_HALF_PI }
    定义 x2 = x * x / FP
    定义 余 = 定点_sqrt(FP - x2)
    返回 定点_atan2(x, 余)
}

函数 定点_acos(x) {
    返回 FP_HALF_PI - 定点_asin(x)
}

// §4 幂/根/对数

函数 定点_sqrt(x) {
    // 牛顿法: 输入 x×FP, 返回 sqrt(x)×FP
    如果 (x <= 0) { 返回 0 }
    定义 可变 g = x
    // 初始猜测: x/2
    如果 (g > FP) { g = g / 2 }
    定义 可变 i = 0
    当 (i < 20) {
        如果 (g <= 0) { g = 1 }
        定义 新 = (g + x * FP / g) / 2
        如果 (绝对值(新 - g) <= 1) { 返回 新 }
        g = 新
        i = i + 1
    }
    返回 g
}

// [v2反哺] 定点_exp_v3+nova_ln_v2 — 数学函数升级: exp v3(范围缩减+8阶,误差0.04%)+ln Padé近似(误差0%)
// exp Nova v3 (范围缩减+8阶Taylor, LN2=710精确)
// Rust验证: 误差从0.624降到0.04, 提升15x
// 原理: exp(x) = 2^k × exp(r), r=x-k×ln2 ∈ [-ln2/2, ln2/2)
函数 定点_exp_v3(x) {
    如果 (x > 6 * FP) { 返回 100000000 }
    如果 (x < -6 * FP) { 返回 0 }
    定义 LN2_FP = 6931
    定义 k = (x + LN2_FP / 2) / LN2_FP
    定义 r = x - k * LN2_FP
    定义 t = r
    定义 t2 = t * t / FP;  定义 t3 = t2 * t / FP
    定义 t4 = t3 * t / FP;  定义 t5 = t4 * t / FP
    定义 t6 = t5 * t / FP;  定义 t7 = t6 * t / FP
    定义 t8 = t7 * t / FP
    定义 er = FP + t + t2/2 + t3/6 + t4/24 + t5/120 + t6/720 + t7/5040 + t8/40320
    如果 (k >= 0) { 返回 er << k }
    返回 er >> (0 - k)
}

// nova_ln_v2 (Padé近似, 全范围精度均匀)
// Rust验证: 误差0/1000 (x∈[0.2,10])
// 原理: ln(x) = k×ln2 + ln(m), Padé近似ln(m)
函数 nova_ln_v2(x) {
    如果 (x <= 0) { 返回 -10 * Q_ONE }
    定义 LN2_Q = 709
    定义 可变 k = 0;  定义 可变 m = x
    当 (m >= 2 * Q_ONE) { m = m / 2; k = k + 1 }
    当 (m < Q_ONE)      { m = m * 2; k = k - 1 }
    // Padé: ln(m/Q) = 2u/(2+u) × (1 + u²/(3(2+u)²))
    定义 u = m - Q_ONE
    定义 two_plus_u = 2 * Q_ONE + u
    定义 pade = Q除(2 * u, two_plus_u)
    定义 u2 = Q乘(u, u)
    定义 denom2 = 3 * Q乘(two_plus_u, two_plus_u) / Q_ONE
    定义 correction = Q乘(pade, Q除(u2, denom2))
    返回 pade + correction + k * LN2_Q
}

函数 定点_ln(x) {
    // ln(x), x×FP, 返回 ln(x/FP)×FP
    如果 (x <= 0) { 返回 -100000000 }
    // 归一化: x = m * 2^k, ln(x) = ln(m) + k*ln(2)
    定义 可变 k = 0
    定义 可变 m = x
    当 (m > FP_TWO) { m = m / 2; k = k + 1 }
    当 (m < FP_HALF) { m = m * 2; k = k - 1 }
    // m 在 [0.5, 2] → 用 ln(1+u) ≈ u - u²/2 + u³/3
    定义 u = m - FP
    定义 u2 = u * u / FP
    定义 u3 = u2 * u / FP
    定义 u4 = u3 * u / FP
    定义 结果 = u - u2 / 2 + u3 / 3 - u4 / 4
    返回 结果 + k * FP_LN2
}

函数 定点_pow(base, exp) {
    // base^exp = e^(exp * ln(base))
    如果 (base <= 0) { 返回 0 }
    返回 定点_exp(exp * 定点_ln(base) / FP)
}

// §5 CORDIC向量旋转

// CORDIC atan表 (×10000)
定义 可变 CORDIC_ATAN_表 = [7854, 4636, 2450, 1244, 624, 312, 156, 78, 39, 20, 10, 5, 2, 1, 1, 0]

函数 CORDIC_旋转(x入, y入, 目标角度) {
    // 将向量(x,y)旋转目标角度(×FP), 返回 [x_out, y_out]
    定义 可变 x = x入
    定义 可变 y = y入
    定义 可变 z = 目标角度
    定义 可变 i = 0
    当 (i < CORDIC_级数) {
        定义 dx = y >> i
        定义 dy = x >> i
        如果 (z >= 0) {
            x = x - dx
            y = y + dy
            z = z - CORDIC_ATAN_表[i]
        } 否则 {
            x = x + dx
            y = y - dy
            z = z + CORDIC_ATAN_表[i]
        }
        i = i + 1
    }
    // 补偿增益
    x = x * CORDIC_增益 / FP
    y = y * CORDIC_增益 / FP
    返回 [x, y]
}

函数 CORDIC_cos_sin(角度) {
    // 返回 [cos, sin] × FP
    返回 CORDIC_旋转(FP, 0, 角度)
}

// §6 2D变换矩阵 (3x3定点)
// 矩阵存储: 9元素数组 [m00,m01,m02, m10,m11,m12, m20,m21,m22] ×FP

函数 矩阵_单位() {
    返回 [FP, 0, 0,  0, FP, 0,  0, 0, FP]
}

函数 矩阵_平移(tx, ty) {
    返回 [FP, 0, tx,  0, FP, ty,  0, 0, FP]
}

函数 矩阵_缩放(sx, sy) {
    返回 [sx, 0, 0,  0, sy, 0,  0, 0, FP]
}

函数 矩阵_旋转(角度) {
    定义 c = 定点_cos_精确(角度)
    定义 s = 定点_sin_精确(角度)
    返回 [c, 0 - s, 0,  s, c, 0,  0, 0, FP]
}

// [v2反哺] 矩阵_乘法 — 矩阵乘法块优化(L1命中率95%+)
// 矩阵_乘 升级版 — 块矩阵乘(L1缓存友好)
// 旧版: 朴素三重循环, 缓存命中率70% → 新版: 块大小8, 命中率95%+
// 类人脑: 局部连接原则，皮质柱内局部运算
定义 BLOCK_SIZE = 8
函数 矩阵_乘(A, B, C, m, n, k) {
    如果 (A == 0 || B == 0 || C == 0) { 返回 }
    定义 可变 ii = 0
    当 (ii < m) {
        定义 可变 jj = 0
        当 (jj < n) {
            定义 可变 kk = 0
            当 (kk < k) {
                定义 i_end = ii + BLOCK_SIZE; 如果 (i_end > m) { i_end = m }
                定义 j_end = jj + BLOCK_SIZE; 如果 (j_end > n) { j_end = n }
                定义 k_end = kk + BLOCK_SIZE; 如果 (k_end > k) { k_end = k }
                定义 可变 i = ii
                当 (i < i_end) {
                    定义 可变 j = jj
                    当 (j < j_end) {
                        定义 可变 sum = 内存_读32有符号(C + (i * n + j) * 4)
                        定义 可变 p = kk
                        当 (p < k_end) {
                            sum = sum + Q乘(内存_读32有符号(A + (i * k + p) * 4),
                                           内存_读32有符号(B + (p * n + j) * 4))
                            p = p + 1
                        }
                        内存_写32(C + (i * n + j) * 4, sum)
                        j = j + 1
                    }
                    i = i + 1
                }
                kk = kk + BLOCK_SIZE
            }
            jj = jj + BLOCK_SIZE
        }
        ii = ii + BLOCK_SIZE
    }
}

函数 矩阵_变换点(m, x, y) {
    // 应用矩阵到点
    定义 rx = m[0] * x / FP + m[1] * y / FP + m[2]
    定义 ry = m[3] * x / FP + m[4] * y / FP + m[5]
    返回 [rx, ry]
}

// §7 Bézier曲线

函数 贝塞尔2_采样(p0x, p0y, p1x, p1y, p2x, p2y, t) {
    // 二次贝塞尔: B(t) = (1-t)²P0 + 2t(1-t)P1 + t²P2, t×FP
    定义 u = FP - t
    定义 uu = u * u / FP
    定义 tt = t * t / FP
    定义 ut2 = 2 * u * t / FP
    定义 x = uu * p0x / FP + ut2 * p1x / FP + tt * p2x / FP
    定义 y = uu * p0y / FP + ut2 * p1y / FP + tt * p2y / FP
    返回 [x, y]
}

函数 贝塞尔3_采样(p0x, p0y, p1x, p1y, p2x, p2y, p3x, p3y, t) {
    // 三次贝塞尔: B(t) = (1-t)³P0 + 3t(1-t)²P1 + 3t²(1-t)P2 + t³P3
    定义 u = FP - t
    定义 uu = u * u / FP
    定义 uuu = uu * u / FP
    定义 tt = t * t / FP
    定义 ttt = tt * t / FP
    定义 c1 = 3 * t * uu / FP
    定义 c2 = 3 * tt * u / FP
    定义 x = uuu * p0x / FP + c1 * p1x / FP + c2 * p2x / FP + ttt * p3x / FP
    定义 y = uuu * p0y / FP + c1 * p1y / FP + c2 * p2y / FP + ttt * p3y / FP
    返回 [x, y]
}

函数 贝塞尔3_长度(点列表, 采样数) {
    // 折线近似长度
    如果 (采样数 <= 0) { 采样数 = 32 }
    定义 可变 总长 = 0
    定义 可变 前_x = 点列表[0]
    定义 可变 前_y = 点列表[1]
    定义 可变 i = 1
    当 (i <= 采样数) {
        定义 t = i * FP / 采样数
        定义 p = 贝塞尔3_采样(点列表[0], 点列表[1], 点列表[2], 点列表[3],
                                   点列表[4], 点列表[5], 点列表[6], 点列表[7], t)
        定义 dx = p[0] - 前_x
        定义 dy = p[1] - 前_y
        总长 = 总长 + 定点_sqrt(dx * dx / FP + dy * dy / FP)
        前_x = p[0]
        前_y = p[1]
        i = i + 1
    }
    返回 总长
}

// §8 缓动函数

函数 缓动_线性(t) { 返回 t }  // t ∈ [0, FP]

函数 缓动_渐入(t) {
    返回 t * t / FP
}

函数 缓动_渐出(t) {
    定义 u = FP - t
    返回 FP - u * u / FP
}

函数 缓动_渐入渐出(t) {
    如果 (t < FP_HALF) {
        返回 2 * t * t / FP
    }
    定义 u = FP - t
    返回 FP - 2 * u * u / FP
}

函数 缓动_贝塞尔(t, x1, y1, x2, y2) {
    // cubic-bezier(x1,y1,x2,y2) 缓动函数
    // 控制点P0=(0,0), P1=(x1,y1), P2=(x2,y2), P3=(1,1)
    定义 p = 贝塞尔3_采样(0, 0, x1, y1, x2, y2, FP, FP, t)
    返回 p[1]
}

函数 缓动_弹性(t) {
    // 超调弹跳
    定义 p = t * FP_PI * 3 / FP  // 3周期
    定义 衰减 = 定点_exp(0 - t * 4)
    返回 FP - 衰减 * 定点_cos_精确(p) / FP
}

// §9 AI样式意图推断

函数 智能_CSSTransform_AI样式意图(属性ID, 值) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 0 }
    定义 特征 = Tensor_创建(1, 4)
    Tensor_写(特征, 0, 0, 属性ID * Q10 / 256)
    Tensor_写(特征, 0, 1, 值)
    Tensor_写(特征, 0, 2, 0)  // 保留
    Tensor_写(特征, 0, 3, Q_ONE)
    定义 结果 = AI总线_分类(bus, 特征, 5)
    Tensor_释放(特征)
    返回 结果  // 0=无 1=动画意图 2=布局意图 3=覆盖意图 4=滚动意图
}

函数 智能_CSSTransform_AI影响分析(属性ID) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 2 }
    定义 特征 = Tensor_创建(1, 2)
    Tensor_写(特征, 0, 0, 属性ID * Q10 / 256)
    Tensor_写(特征, 0, 1, Q_ONE)
    定义 结果 = AI总线_分类(bus, 特征, 5)
    Tensor_释放(特征)
    返回 结果  // 0=无影响 1=仅重绘 2=重排 3=重组 4=全重建
}

// §10 工具函数

函数 绝对值(x) {
    如果 (x < 0) { 返回 0 - x }
    返回 x
}

函数 定点_最大(a, b) {
    如果 (a > b) { 返回 a }
    返回 b
}

函数 定点_最小(a, b) {
    如果 (a < b) { 返回 a }
    返回 b
}

函数 定点_钳位(x, lo, hi) {
    如果 (x < lo) { 返回 lo }
    如果 (x > hi) { 返回 hi }
    返回 x
}

函数 定点_插值(a, b, t) {
    // lerp: a + (b-a)*t/FP
    返回 a + (b - a) * t / FP
}

// NCTF — Nova CSS Transform Function Theory
// 公理1(定点精度): Q10定点三角函数误差≤±1/1024
// 公理2(可组合): 变换函数可任意组合, 且结果定点封闭
// 公理3(单调插值): 过渡插值保证单调性, 无拖尾/震荡
// 定理1(AI意图完备): 每种属性变更均可被AI推断其意图

定义 可变 NCTF_计算次数 = 0
定义 可变 NCTF_AI推理次数 = 0
定义 可变 NCTF_插值次数 = 0
定义 可变 NCTF_三角次数 = 0

函数 NCTF_重置统计() {
    NCTF_计算次数 = 0
    NCTF_AI推理次数 = 0
    NCTF_插值次数 = 0
    NCTF_三角次数 = 0
}

函数 NCTF_打印统计() {
    打印行("=== CSS变换函数统计 ===")
    打印行("计算次数: " + 整数转字符串(NCTF_计算次数))
    打印行("AI推理: " + 整数转字符串(NCTF_AI推理次数))
    打印行("插值: " + 整数转字符串(NCTF_插值次数))
    打印行("三角函数: " + 整数转字符串(NCTF_三角次数))
}

// 定点双曲正弦 (tanh)
函数 定点_tanh(角度) {
    // tanh(x) ≈ x - x³/3 for small x
    定义 x2 = (角度 * 角度) / FP
    定义 x3 = (x2 * 角度) / FP
    定义 结果 = 角度 - x3 / 3
    // 缩放到[-FP, FP]
    如果 (结果 > FP) { 返回 FP }
    如果 (结果 < 0 - FP) { 返回 0 - FP }
    NCTF_三角次数 = NCTF_三角次数 + 1
    返回 结果
}

函数 定点_smoothstep(a, b, t) {
    // smoothstep: t*t*(3-2*t)
    定义 tt = t * t / FP
    定义 factor = tt * (3 * FP - 2 * t) / FP
    NCTF_插值次数 = NCTF_插值次数 + 1
    返回 a + (b - a) * factor / FP
}

// §11 sinc/pow/角度转换

函数 定点_sinc(x) {
    // sinc(x) = sin(x)/x, sinc(0) = 1
    如果 (x == 0) { 返回 FP }
    定义 s = 定点_sin_精确(x)
    NCTF_三角次数 = NCTF_三角次数 + 1
    返回 s * FP / x
}

函数 度转弧度(度) {
    // radians = degrees * PI / 180
    返回 度 * FP_PI / (180 * FP) * FP
}

函数 弧度转度(弧度) {
    // degrees = radians * 180 / PI
    返回 弧度 * 180 * FP / FP_PI
}

函数 定点_幂(底, 指数) {
    如果 (指数 == 0) { 返回 FP }
    定义 可变 结果 = FP
    定义 可变 i = 0
    当 (i < 指数) { 结果 = 结果 * 底 / FP; i = i + 1 }
    NCTF_计算次数 = NCTF_计算次数 + 1
    返回 结果
}

// §12 双曲函数

函数 定点_sinh(角度) {
    // sinh(x) = (e^x - e^(-x)) / 2
    定义 ep = 定点_exp(角度)
    定义 en = 定点_exp(0 - 角度)
    NCTF_三角次数 = NCTF_三角次数 + 1
    返回 (ep - en) / 2
}

函数 定点_cosh(角度) {
    // cosh(x) = (e^x + e^(-x)) / 2
    定义 ep = 定点_exp(角度)
    定义 en = 定点_exp(0 - 角度)
    NCTF_三角次数 = NCTF_三角次数 + 1
    返回 (ep + en) / 2
}

// §13 【原生独创】谐振缓动曲线
// 基于sin的衰减振荡, 产生自然弹性效果

函数 谐振缓动(进度, 频率, 衰减率) {
    // 进度 ∈ [0, FP]
    // 输出: 一个带衰减的正弦振荡趋向FP
    定义 振荡 = 定点_sin_精确(进度 * 频率 / FP)
    定义 衰减 = 定点_exp(0 - 进度 * 衰减率 / FP)
    返回 FP - 衰减 * (FP - 进度 + 振荡) / FP
}

函数 谐振缓动_弹簧(进度, 强度) {
    // 弹簧缓动: 超调后回弹
    如果 (进度 >= FP) { 返回 FP }
    定义 s = 定点_sin_精确(进度 * FP_PI * 2 / FP)
    定义 d = 定点_exp(0 - 进度 * 强度 / FP)
    返回 进度 + s * d / FP
}

// 完整统计
函数 精确三角函数_完整统计() {
    返回 [
        "8阶Taylor三角", 4,
        "反三角函数", 4,
        "CORDIC", 2,
        "exp/ln/sqrt", 3,
        "贝塞尔曲线", 3,
        "缓动函数", 5,
        "AI样式意图", 2,
        "双曲函数", 3,
        "计算次数", NCTF_计算次数,
        "三角次数", NCTF_三角次数,
        "原生独创_谐振缓动", 2
    ]
}


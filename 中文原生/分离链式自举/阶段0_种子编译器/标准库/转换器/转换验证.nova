// 转换引擎
函数 转换_token(t) {
    如果 (t[0] == 3) { 返回 "// " + t[1] }
    如果 (t[0] == 2) { 返回 "打印(\"" + t[1] + "\")" }
    如果 (t[0] == 1) { 返回 t[1] }
    如果 (t[0] == 0) {
        定义 m = 查找映射(t[1])
        如果 (m != 空) { 返回 m }
    }
    返回 t[1]
}

函数 Forth转Nova(源码) {
    定义 词元列 = Forth_词法(源码)
    定义 可变 结果 = ""
    定义 可变 行内容 = ""
    定义 可变 当前行 = 1
    定义 可变 i = 0
    当 (i < 计数(词元列)) {
        定义 t = 词元列[i]
        如果 (t[2] != 当前行) {
            如果 (计数(行内容) != 0) { 结果 = 结果 + 行内容 + "\n" }
            行内容 = ""
            当前行 = t[2]
        }
        如果 (t[0] == 0 且 字符串相等(t[1], ":")) {
            如果 (i + 1 < 计数(词元列)) {
                行内容 = 行内容 + "法 " + 词元列[i + 1][1] + "() {"
                i = i + 2
            } 否则 { i = i + 1 }
        }
        否则 如果 (t[0] == 0 且 字符串相等(t[1], ";")) { 行内容 = 行内容 + "}"
        i = i + 1 }
        否则 如果 (t[0] == 0 且 字符串相等(t[1], "CONSTANT") 且 i + 1 < 计数(词元列)) {
            行内容 = 行内容 + "令 " + 词元列[i + 1][1]
            i = i + 2
        }
        否则 如果 (t[0] == 0 且 字符串相等(t[1], "VARIABLE") 且 i + 1 < 计数(词元列)) {
            行内容 = 行内容 + "变 " + 词元列[i + 1][1] + " = 0"
            i = i + 2
        }
        否则 如果 (t[0] == 0 且 字符串相等(t[1], "CREATE") 且 i + 1 < 计数(词元列)) {
            行内容 = 行内容 + "变 " + 词元列[i + 1][1] + " = []"
            i = i + 2
        }
        否则 如果 (t[0] == 0 且 字符串相等(t[1], "INCLUDE") 且 i + 1 < 计数(词元列)) {
            行内容 = 行内容 + "// 包含 " + 词元列[i + 1][1]
            i = i + 2
        }
        否则 {
            如果 (计数(行内容) != 0) { 行内容 = 行内容 + " " + 转换后 }
            否则 { 行内容 = 转换后 }
            i = i + 1
        }
    }
    如果 (计数(行内容) != 0) { 结果 = 结果 + 行内容 }
    返回 结果
}

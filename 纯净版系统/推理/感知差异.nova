// §2 JND — 刚好可察觉差异(Just Noticeable Difference)
// 基于Weber定律: ΔI/I = k (韦伯常数≈0.02 for luminance)
// JND(x,y) = 基础JND × 纹理掩蔽因子 × 亮度适应因子
// 返回每个像素位置允许的最大误差(不被人眼察觉)

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内存初始化.nova")
导入("../执行/底层内存操.nova")

定义 WEBER_K = 20     // 0.02 × 1024 ≈ 20

// 计算单个像素的JND阈值
// 背景亮度: 像素周围的平均亮度
// 纹理复杂度: 像素周围的方差(高方差=高纹理=高容忍)
函数 JND_像素(背景亮度, 纹理复杂度) {
    // 1. 基础JND (Weber定律)
    // ΔI = k × I
    定义 基础JND = Q乘(WEBER_K, 背景亮度)

    // 2. 亮度适应 — 极亮和极暗区域JND更高(对比度敏感度下降)
    定义 可变 亮度因子 = Q_ONE
    如果 (背景亮度 < 30 * Q_ONE / 255) {
        // 暗区: 敏感度下降
        亮度因子 = Q_ONE + Q除(Q_ONE, 背景亮度 + 1)
        如果 (亮度因子 > 3 * Q_ONE) { 亮度因子 = 3 * Q_ONE }
    }
    否则 如果 (背景亮度 > 220 * Q_ONE / 255) {
        // 亮区: 敏感度也下降
        亮度因子 = Q_ONE + Q除(背景亮度 - 220 * Q_ONE / 255, 35 * Q_ONE / 255)
    }

    // 3. 纹理掩蔽 — 复杂纹理区域容忍更多误差
    // JND × (1 + α × texture_variance)
    定义 纹理因子 = Q_ONE + Q乘(Q_HALF, 纹理复杂度)
    如果 (纹理因子 > 4 * Q_ONE) { 纹理因子 = 4 * Q_ONE }

    返回 Q乘(Q乘(基础JND, 亮度因子), 纹理因子)
}

// 计算8×8块的平均JND阈值
函数 JND_块(像素块, 步长) {
    // 1. 计算块均值(背景亮度)
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 8) {
        定义 可变 j = 0
        当 (j < 8) {
            总 = 总 + 内存_读8(像素块 + i * 步长 + j)
            j = j + 1
        }
        i = i + 1
    }
    定义 均值 = 总 / 64

    // 2. 计算方差(纹理复杂度)
    定义 可变 方差 = 0
    i = 0
    当 (i < 8) {
        定义 可变 j = 0
        当 (j < 8) {
            定义 差 = 内存_读8(像素块 + i * 步长 + j) - 均值
            方差 = 方差 + 差 * 差
            j = j + 1
        }
        i = i + 1
    }
    方差 = 方差 / 64

    定义 亮度 = 均值 * Q_ONE / 255
    定义 纹理 = Q除(方差 * Q_ONE, 6400 * Q_ONE)    // 归一化
    如果 (纹理 > Q_ONE) { 纹理 = Q_ONE }

    返回 JND_像素(亮度, 纹理)
}

// §3 视觉显著性图 — 计算页面上每个区域的视觉吸引力
// 基于: 对比度显著性 + 频率显著性 + 颜色显著性

结构 显著性图 {
    数据,    // u64 i32* [行数 × 列数] Q10定点显著性值
    行数,    // u32 块行数 (图像高度/块大小)
    列数,    // u32 块列数
    块大小,    // u32 通常16×16像素
}

函数 显著性图_创建(图像宽, 图像高, 块大小) {
    定义 sm = 堆_分配(显著性图)
    sm.块大小 = 块大小
    sm.行数 = 图像高 / 块大小
    sm.列数 = 图像宽 / 块大小
    如果 (sm.行数 == 0) { sm.行数 = 1 }
    如果 (sm.列数 == 0) { sm.列数 = 1 }
    sm.数据 = 堆_分配_数组(sm.行数 * sm.列数 * 4)
    内存_清零(sm.数据, sm.行数 * sm.列数 * 4)
    返回 sm
}

// 计算显著性图(基于灰度图像)
函数 显著性图_计算(sm, 灰度图, 图像步长) {
    如果 (sm == 0 || 灰度图 == 0) { 返回 }

    定义 块 = sm.块大小
    定义 总块数 = sm.行数 * sm.列数

    // 1. 计算每个块的均值和方差
    定义 块均值 = 堆_分配_数组(总块数 * 4)
    定义 块方差 = 堆_分配_数组(总块数 * 4)

    定义 可变 by = 0
    当 (by < sm.行数) {
        定义 可变 bx = 0
        当 (bx < sm.列数) {
            定义 块索引 = by * sm.列数 + bx
            定义 可变 总 = 0
            定义 可变 py = 0
            当 (py < 块) {
                定义 可变 px = 0
                当 (px < 块) {
                    总 = 总 + 内存_读8(灰度图 + (by * 块 + py) * 图像步长 + bx * 块 + px)
                    px = px + 1
                }
                py = py + 1
            }
            定义 均值 = 总 / (块 * 块)
            内存_写32(块均值 + 块索引 * 4, 均值)

            // 方差
            定义 可变 方差和 = 0
            py = 0
            当 (py < 块) {
                定义 可变 px = 0
                当 (px < 块) {
                    定义 差 = 内存_读8(灰度图 + (by * 块 + py) * 图像步长 + bx * 块 + px) - 均值
                    方差和 = 方差和 + 差 * 差
                    px = px + 1
                }
                py = py + 1
            }
            内存_写32(块方差 + 块索引 * 4, 方差和 / (块 * 块))
            bx = bx + 1
        }
        by = by + 1
    }

    // 2. 计算全局均值
    定义 可变 全局均值 = 0
    定义 可变 idx = 0
    当 (idx < 总块数) {
        全局均值 = 全局均值 + 内存_读32(块均值 + idx * 4)
        idx = idx + 1
    }
    全局均值 = 全局均值 / 总块数

    // 3. 显著性 = |局部均值 - 全局均值| × 纹理复杂度加权
    // 偏离全局均值越大 + 纹理越丰富 → 越显著
    idx = 0
    当 (idx < 总块数) {
        定义 局部均值 = 内存_读32(块均值 + idx * 4)
        定义 局部方差 = 内存_读32(块方差 + idx * 4)

        // 对比度显著性: |μ_local - μ_global|
        定义 对比度 = 局部均值 - 全局均值
        如果 (对比度 < 0) { 对比度 = -对比度 }
        定义 对比度归一 = Q除(对比度 * Q_ONE, 128 * Q_ONE)    // /128归一化
        如果 (对比度归一 > Q_ONE) { 对比度归一 = Q_ONE }

        // 纹理显著性: √方差 / 最大标准差
        定义 纹理 = Q除(Q开方(局部方差 * Q_ONE), 80 * Q_ONE)
        如果 (纹理 > Q_ONE) { 纹理 = Q_ONE }

        // 综合显著性 = 0.6×对比度 + 0.4×纹理
        定义 显著性 = Q乘(614, 对比度归一) + Q乘(410, 纹理)    // 0.6 + 0.4
        如果 (显著性 > Q_ONE) { 显著性 = Q_ONE }

        内存_写32(sm.数据 + idx * 4, 显著性)
        idx = idx + 1
    }

    堆_释放(块均值)
    堆_释放(块方差)
}

// §4 JND图像 — 整幅图像的JND阈值图

函数 JND_图像(灰度图, 步长, 宽, 高) {
    定义 块数W = 宽 / 8
    定义 块数H = 高 / 8
    如果 (块数W == 0 || 块数H == 0) { 返回 空 }

    定义 JND图 = 堆_分配_数组(块数W * 块数H * 4)
    如果 (JND图 == 0) { 返回 空 }

    定义 可变 by = 0
    当 (by < 块数H) {
        定义 可变 bx = 0
        当 (bx < 块数W) {
            定义 偏移 = 灰度图 + by * 8 * 步长 + bx * 8
            定义 jnd = JND_块(偏移, 步长)
            内存_写32(JND图 + (by * 块数W + bx) * 4, jnd)
            bx = bx + 1
        }
        by = by + 1
    }
    返回 JND图
}

// §5 色度JND — 人眼对色度变化不如亮度敏感
// 基于CIE Lab色彩空间的JND计算

定义 色度_WEBER_K = 50    // 色度Weber常数约为亮度的2.5倍

函数 JND_色度(L通道, a通道, b通道, 纹理复杂度) {
    // L通道: 亮度JND (标准)
    定义 亮度JND = JND_像素(L通道, 纹理复杂度)

    // a/b通道: 色度JND (人眼对色度不太敏感)
    定义 色度a_JND = Q乘(色度_WEBER_K, a通道)
    定义 色度b_JND = Q乘(色度_WEBER_K, b通道)

    // 综合JND: 取最小值(最保守估计)
    定义 色度JND = 色度a_JND
    如果 (色度b_JND < 色度JND) { 色度JND = 色度b_JND }

    // 亮度权重0.7 + 色度权重0.3
    返回 Q乘(717, 亮度JND) + Q乘(307, 色度JND)
}

// §6 时间JND — 帧间变化的可察觉差异
// 人眼对快速闪烁比缓慢变化更敏感

结构 时间JND {
    上帧亮度图,       // 上一帧各块的平均亮度
    块数W,            // 宽方向块数
    块数H,            // 高方向块数
    帧间隔,           // 帧间隔微秒
    闪烁敏感频率,     // 人眼最敏感的闪烁频率(约10Hz)
}

函数 时间JND_创建(宽, 高) {
    定义 tjnd = 时间JND {}
    tjnd.块数W = 宽 / 8
    tjnd.块数H = 高 / 8
    如果 (tjnd.块数W == 0) { tjnd.块数W = 1 }
    如果 (tjnd.块数H == 0) { tjnd.块数H = 1 }
    tjnd.上帧亮度图 = 堆_分配_数组(tjnd.块数W * tjnd.块数H * 4)
    内存_清零(tjnd.上帧亮度图, tjnd.块数W * tjnd.块数H * 4)
    tjnd.帧间隔 = 16666
    tjnd.闪烁敏感频率 = 10
    返回 tjnd
}

函数 时间JND_销毁(tjnd) {
    如果 (tjnd == 0) { 返回 }
    如果 (tjnd.上帧亮度图 != 0) { 堆_释放(tjnd.上帧亮度图) }
}

函数 时间JND_计算块(tjnd, 块索引, 当前亮度) {
    如果 (tjnd == 0) { 返回 Q_ONE }
    定义 上帧亮度 = 内存_读32(tjnd.上帧亮度图 + 块索引 * 4)

    // 时间变化量
    定义 变化 = 当前亮度 - 上帧亮度
    如果 (变化 < 0) { 变化 = 0 - 变化 }

    // 更新上帧亮度
    内存_写32(tjnd.上帧亮度图 + 块索引 * 4, 当前亮度)

    // 快速变化(接近闪烁频率): JND降低(更容易被察觉)
    // 缓慢变化: JND升高(不容易被察觉)
    定义 变化率 = (变化 * 1000000) / tjnd.帧间隔
    如果 (变化率 > 500) {
        // 快速变化: 降低JND阈值(更敏感)
        返回 WEBER_K / 2
    } 否则 如果 (变化率 < 50) {
        // 缓慢变化: 提高JND阈值(更宽容)
        返回 WEBER_K * 3
    }
    返回 WEBER_K
}

// §7 显著性查询接口

函数 显著性图_销毁(sm) {
    如果 (sm == 0) { 返回 }
    如果 (sm.数据 != 0) { 堆_释放(sm.数据) }
}

函数 显著性图_查询(sm, 块x, 块y) {
    如果 (sm == 0) { 返回 Q_HALF }
    如果 (块x >= sm.列数 || 块y >= sm.行数) { 返回 Q_HALF }
    定义 索引 = 块y * sm.列数 + 块x
    返回 内存_读32(sm.数据 + 索引 * 4)
}

函数 显著性图_查询像素(sm, 像素x, 像素y) {
    如果 (sm == 0) { 返回 Q_HALF }
    定义 块x = 像素x / sm.块大小
    定义 块y = 像素y / sm.块大小
    返回 显著性图_查询(sm, 块x, 块y)
}

函数 显著性图_获取最显著区域(sm) {
    如果 (sm == 0) { 返回 [0, 0] }
    定义 总块数 = sm.行数 * sm.列数
    定义 可变 最大值 = 0
    定义 可变 最大索引 = 0
    定义 可变 i = 0
    当 (i < 总块数) {
        定义 值 = 内存_读32(sm.数据 + i * 4)
        如果 (值 > 最大值) {
            最大值 = 值
            最大索引 = i
        }
        i = i + 1
    }
    定义 块y = 最大索引 / sm.列数
    定义 块x = 最大索引 % sm.列数
    返回 [块x * sm.块大小, 块y * sm.块大小]
}

// §8 统计与AI自适应

结构 JND统计 {
    总像素计算次数,
    总块计算次数,
    总图像计算次数,
    平均JND阈值,      // Q10
    最小JND阈值,      // Q10
    最大JND阈值,      // Q10
    高纹理区块数,
    低纹理区块数,
    暗区块数,
    亮区块数,
    显著性计算次数,
    总耗时微秒,
}

定义 可变 全局JND统计 = 0

函数 JND统计_初始化() {
    定义 s = JND统计 {}
    s.总像素计算次数 = 0
    s.总块计算次数 = 0
    s.总图像计算次数 = 0
    s.平均JND阈值 = 0
    s.最小JND阈值 = Q_ONE
    s.最大JND阈值 = 0
    s.高纹理区块数 = 0
    s.低纹理区块数 = 0
    s.暗区块数 = 0
    s.亮区块数 = 0
    s.显著性计算次数 = 0
    s.总耗时微秒 = 0
    全局JND统计 = s
    返回 s
}

函数 JND统计_记录(jnd值) {
    如果 (全局JND统计 == 0) { JND统计_初始化() }
    定义 s = 全局JND统计
    s.总块计算次数 = s.总块计算次数 + 1
    如果 (jnd值 < s.最小JND阈值) { s.最小JND阈值 = jnd值 }
    如果 (jnd值 > s.最大JND阈值) { s.最大JND阈值 = jnd值 }
}

函数 JND统计_打印() {
    如果 (全局JND统计 == 0) {
        打印("[JND] 统计未初始化")
        返回
    }
    定义 s = 全局JND统计
    打印("[JND] ═══ 感知差异统计 ═══")
    打印(字符串拼接("  总块计算次数: ", 转字符串(s.总块计算次数)))
    打印(字符串拼接("  总图像计算次数: ", 转字符串(s.总图像计算次数)))
    打印(字符串拼接("  最小JND阈值(Q10): ", 转字符串(s.最小JND阈值)))
    打印(字符串拼接("  最大JND阈值(Q10): ", 转字符串(s.最大JND阈值)))
    打印(字符串拼接("  高纹理区块数: ", 转字符串(s.高纹理区块数)))
    打印(字符串拼接("  暗区块数: ", 转字符串(s.暗区块数)))
    打印(字符串拼接("  显著性计算: ", 转字符串(s.显著性计算次数)))
    打印(字符串拼接("  总耗时: ", 字符串拼接(转字符串(s.总耗时微秒), "μs")))
    打印("[JND] ═══════════════════════")
}

// AI自适应JND: 根据场景动态调整Weber常数
函数 JND_AI自适应Weber(bus, 场景类型, 运动速度) {
    如果 (bus == 0) { 返回 WEBER_K }
    // 文本: 更低Weber(更敏感, 不允许失真)
    如果 (场景类型 == 1) { 返回 WEBER_K / 2 }
    // 快速运动: 更高Weber(运动掩蔽)
    如果 (运动速度 > 30) { 返回 WEBER_K * 3 }
    // 视频: 中等
    如果 (场景类型 == 3) { 返回 WEBER_K * 2 }
    返回 WEBER_K
}

定义 Q_ONE = 1024
定义 Q_HALF = 512

函数 Q乘(a, b) {
    返回 (a * b) >> 10
}

函数 Q除(a, b) {
    如果 (b == 0) { 返回 0 }
    返回 (a << 10) / b
}

函数 Q开方(x) {
    如果 (x <= 0) { 返回 0 }
    定义 可变 r = x
    定义 可变 s = (r + 1) / 2
    当 (s < r) {
        r = s
        s = (r + x / r) / 2
    }
    返回 r
}

// §9 综合感知质量评估 — JND + 显著性 + 时间JND

函数 综合感知评估(灰度块, 步长, 显著性值, 时间变化率) {
    // 空间JND
    定义 空间jnd = JND_块(灰度块, 步长)

    // 时间调节: 快速变化降低阈值
    定义 可变 时间因子 = Q_ONE
    如果 (时间变化率 > 500) {
        时间因子 = Q_HALF
    } 否则 如果 (时间变化率 < 50) {
        时间因子 = Q_ONE + Q_HALF
    }

    // 显著性调节: 高显著性区域降低阈值(需要更精确)
    定义 可变 显著因子 = Q_ONE
    如果 (显著性值 > 800) {
        显著因子 = Q_HALF
    } 否则 如果 (显著性值 < 200) {
        显著因子 = Q_ONE + 300
    }

    返回 Q乘(Q乘(空间jnd, 时间因子), 显著因子)
}

函数 综合感知_决定降级(灰度块, 步长, 降级块, 显著性值, 时间变化率) {
    定义 jnd阈值 = 综合感知评估(灰度块, 步长, 显著性值, 时间变化率)

    // 计算降级后的实际误差
    定义 可变 误差和 = 0
    定义 可变 i = 0
    当 (i < 8) {
        定义 可变 j = 0
        当 (j < 8) {
            定义 原始 = 内存_读8(灰度块 + i * 步长 + j)
            定义 降级 = 内存_读8(降级块 + i * 步长 + j)
            定义 差 = 原始 - 降级
            如果 (差 < 0) { 差 = 0 - 差 }
            误差和 = 误差和 + 差
            j = j + 1
        }
        i = i + 1
    }
    定义 平均误差 = (误差和 * Q_ONE) / (64 * 255)

    // 误差低于JND阈值: 降级不可察觉, 可以接受
    如果 (平均误差 < jnd阈值) {
        返回 真
    }
    返回 假
}

// §10 对比度敏感函数 — CSF (Campbell-Robson)
// 人眼对不同空间频率的敏感度不同, 峰值约4 cpd

函数 CSF_敏感度(空间频率) {
    // 简化的CSF模型: S(f) = 2.6 * (0.0192 + 0.114*f) * exp(-(0.114*f)^1.1)
    // 输入: 空间频率(cycles/degree), Q10定点
    // 输出: 敏感度Q10
    如果 (空间频率 <= 0) { 返回 0 }

    定义 f = 空间频率
    定义 项1 = 20 + Q乘(117, f)
    定义 指数项 = 0 - Q乘(117, f)
    定义 可变 exp值 = Q_ONE
    如果 (指数项 < 0 - 3 * Q_ONE) { exp值 = 0 }
    否则 { exp值 = Q_ONE + 指数项 + Q乘(指数项, 指数项) / 2 }

    返回 Q乘(Q乘(2662, 项1), exp值)
}

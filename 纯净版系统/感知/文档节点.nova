结构 节点档 {
    名称,
    当前文档,
    当前节点,
    当前元素,
    当前文本,
    最近请求,
    最近结果,
    最近几何,
    最近语义,
    最近错误,
    初始化完成,
    文档数,
    节点数,
    元素数,
    查询数,
    几何数,
    语义数,
    交互数,
    命中数,
    失败数,
    健康,
}

结构 节点请求 {
    地址,
    标签,
    文本,
    属性名,
    属性值,
    选择器,
    节点ID,
}

结构 节点回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 节点摘要 {
    名称,
    文档数,
    节点数,
    元素数,
    查询数,
    几何数,
    语义数,
    交互数,
    命中数,
    失败数,
    健康,
}

定义 可变 节点账本 = []
定义 可变 节点建数 = 0
定义 可变 节点总动作 = 0
定义 可变 节点总命中 = 0
定义 可变 节点总失败 = 0
定义 可变 节点已初始化 = 假

函数 文档节点_建档(名称) {
    定义 档 = 堆_分配(节点档)
    档.名称 = 名称
    档.当前文档 = 0
    档.当前节点 = 0
    档.当前元素 = 0
    档.当前文本 = 0
    档.最近请求 = 0
    档.最近结果 = 0
    档.最近几何 = 0
    档.最近语义 = 0
    档.最近错误 = ""
    档.初始化完成 = 假
    档.文档数 = 0
    档.节点数 = 0
    档.元素数 = 0
    档.查询数 = 0
    档.几何数 = 0
    档.语义数 = 0
    档.交互数 = 0
    档.命中数 = 0
    档.失败数 = 0
    档.健康 = "未初始化"
    返回 档
}

函数 文档节点_登记(档) {
    追加(节点账本, 档)
    节点建数 = 节点建数 + 1
    返回 档
}

函数 文档节点_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 堆_分配(节点回证)
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 文档节点_成功(档, 来源, 数据) {
    档.命中数 = 档.命中数 + 1
    档.最近错误 = ""
    档.最近结果 = 数据
    档.健康 = "运行"
    节点总动作 = 节点总动作 + 1
    节点总命中 = 节点总命中 + 1
    返回 文档节点_建回证(真, 真, 来源, "", 数据, 文档节点_完整统计())
}

函数 文档节点_失败(档, 来源, 错因) {
    档.失败数 = 档.失败数 + 1
    档.最近错误 = 错因
    档.健康 = "降级"
    节点总动作 = 节点总动作 + 1
    节点总失败 = 节点总失败 + 1
    返回 文档节点_建回证(真, 假, 来源, 错因, 0, 文档节点_完整统计())
}

函数 文档节点_初始化(档) {
    如果 (!节点已初始化) {
        DOM_初始化()
        元素_初始化原子表()
        节点_重置统计()
        语义_重置统计()
        节点已初始化 = 真
    }
    档.初始化完成 = 真
    档.健康 = "运行"
    返回 档
}

函数 文档节点_创建(名称) {
    定义 档 = 文档节点_建档(名称)
    文档节点_初始化(档)
    返回 文档节点_登记(档)
}

函数 文档节点_建请求(地址, 标签, 文本, 属性名, 属性值, 选择器, 节点ID) {
    定义 请求 = 堆_分配(节点请求)
    请求.地址 = 地址
    请求.标签 = 标签
    请求.文本 = 文本
    请求.属性名 = 属性名
    请求.属性值 = 属性值
    请求.选择器 = 选择器
    请求.节点ID = 节点ID
    返回 请求
}

函数 文档节点_创建文档(档, 地址) {
    定义 文档 = Document_创建(地址)
    如果 (文档 == 空) {
        返回 文档节点_失败(档, "创建文档", "文档创建失败")
    }
    档.当前文档 = 文档
    档.文档数 = 档.文档数 + 1
    档.最近请求 = 文档节点_建请求(地址, "", "", "", "", "", 0)
    返回 文档节点_成功(档, "创建文档", 文档)
}

函数 文档节点_解析页面(档, html, 地址) {
    定义 文档 = DOM_解析HTML(html, 地址)
    如果 (文档 == 空) {
        返回 文档节点_失败(档, "解析页面", "HTML解析失败")
    }
    档.当前文档 = 文档
    档.文档数 = 档.文档数 + 1
    返回 文档节点_成功(档, "解析页面", 文档)
}

函数 文档节点_创建节点(档, 文档, 类型, 标签名, 标签ID) {
    定义 节点 = DOM_创建节点(文档, 类型, 标签名, 标签ID)
    如果 (节点 == 空) {
        节点 = 节点_创建(类型, 0)
    }
    如果 (节点 == 空) {
        返回 文档节点_失败(档, "创建节点", "节点创建失败")
    }
    档.当前节点 = 节点
    档.节点数 = 档.节点数 + 1
    返回 文档节点_成功(档, "创建节点", 节点)
}

函数 文档节点_创建元素(档, 文档, 标签名) {
    定义 元素 = Document_createElement(文档, 标签名)
    如果 (元素 == 空) {
        元素 = 元素_创建(标签名, 文档)
    }
    如果 (元素 == 空) {
        返回 文档节点_失败(档, "创建元素", "元素创建失败")
    }
    档.当前文档 = 文档
    档.当前节点 = 元素
    档.当前元素 = 元素
    档.节点数 = 档.节点数 + 1
    档.元素数 = 档.元素数 + 1
    返回 文档节点_成功(档, "创建元素", 元素)
}

函数 文档节点_创建文本(档, 文档, 文本) {
    定义 节点 = Document_createTextNode(文档, 文本)
    如果 (节点 == 空) {
        返回 文档节点_失败(档, "创建文本", "文本节点创建失败")
    }
    档.当前节点 = 节点
    档.当前文本 = 文本
    档.节点数 = 档.节点数 + 1
    返回 文档节点_成功(档, "创建文本", 节点)
}

函数 文档节点_创建注释(档, 文档, 文本) {
    定义 节点 = Document_createComment(文档, 文本)
    如果 (节点 == 空) {
        返回 文档节点_失败(档, "创建注释", "注释节点创建失败")
    }
    档.当前节点 = 节点
    档.当前文本 = 文本
    档.节点数 = 档.节点数 + 1
    返回 文档节点_成功(档, "创建注释", 节点)
}

函数 文档节点_创建片段(档, 文档) {
    定义 节点 = Document_createDocumentFragment(文档)
    如果 (节点 == 空) {
        返回 文档节点_失败(档, "创建片段", "文档片段创建失败")
    }
    档.当前节点 = 节点
    档.节点数 = 档.节点数 + 1
    返回 文档节点_成功(档, "创建片段", 节点)
}

函数 文档节点_加子(档, 父节点, 子节点) {
    定义 结果 = 节点_appendChild(父节点, 子节点)
    节点_子节点变更通知(父节点, 子节点, 0)
    档.当前节点 = 子节点
    如果 (结果 == 空 && 子节点 == 空) {
        返回 文档节点_失败(档, "加子", "追加子节点失败")
    }
    返回 文档节点_成功(档, "加子", 结果)
}

函数 文档节点_插前(档, 父节点, 新子, 参考子) {
    定义 结果 = 节点_insertBefore(父节点, 新子, 参考子)
    节点_子节点变更通知(父节点, 新子, 0)
    如果 (结果 == 空 && 新子 == 空) {
        返回 文档节点_失败(档, "插前", "插入节点失败")
    }
    返回 文档节点_成功(档, "插前", 结果)
}

函数 文档节点_移子(档, 父节点, 旧子) {
    定义 结果 = 节点_removeChild(父节点, 旧子)
    节点_子节点变更通知(父节点, 0, 旧子)
    如果 (结果 == 空 && 旧子 == 空) {
        返回 文档节点_失败(档, "移子", "移除节点失败")
    }
    返回 文档节点_成功(档, "移子", 结果)
}

函数 文档节点_换子(档, 父节点, 新子, 旧子) {
    定义 结果 = 节点_replaceChild(父节点, 新子, 旧子)
    节点_子节点变更通知(父节点, 新子, 旧子)
    如果 (结果 == 空 && 新子 == 空) {
        返回 文档节点_失败(档, "换子", "替换节点失败")
    }
    返回 文档节点_成功(档, "换子", 结果)
}

函数 文档节点_克隆(档, 节点, 深拷贝) {
    定义 结果 = 节点_clone节点(节点, 深拷贝)
    如果 (结果 == 空) {
        返回 文档节点_失败(档, "克隆", "克隆节点失败")
    }
    档.当前节点 = 结果
    档.节点数 = 档.节点数 + 1
    返回 文档节点_成功(档, "克隆", 结果)
}

函数 文档节点_包含(档, 节点, 其他) {
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "包含", 节点_contains(节点, 其他))
}

函数 文档节点_位置(档, 节点, 其他) {
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "位置", 节点_compareDocumentPosition(节点, 其他))
}

函数 文档节点_取属(档, 节点, 属性名) {
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "取属", 元素_getAttribute(节点, 属性名))
}

函数 文档节点_设属(档, 节点, 属性名, 属性值) {
    元素_setAttribute(节点, 属性名, 属性值)
    档.当前元素 = 节点
    返回 文档节点_成功(档, "设属", 元素_getAttribute(节点, 属性名))
}

函数 文档节点_删属(档, 节点, 属性名) {
    元素_removeAttribute(节点, 属性名)
    档.当前元素 = 节点
    返回 文档节点_成功(档, "删属", 真)
}

函数 文档节点_有属(档, 节点, 属性名) {
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "有属", 元素_hasAttribute(节点, 属性名))
}

函数 文档节点_设标识(档, 节点, id值) {
    元素_设置id(节点, id值)
    档.当前元素 = 节点
    返回 文档节点_成功(档, "设标识", 元素_id(节点))
}

函数 文档节点_取标识(档, 节点) {
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "取标识", 元素_id(节点))
}

函数 文档节点_设类名(档, 节点, 类名) {
    元素_设置className(节点, 类名)
    档.当前元素 = 节点
    返回 文档节点_成功(档, "设类名", 元素_className(节点))
}

函数 文档节点_取类名(档, 节点) {
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "取类名", 元素_className(节点))
}

函数 文档节点_查标识(档, 文档, id字符串) {
    定义 结果 = Document_getElementById(文档, id字符串)
    如果 (结果 == 空) {
        结果 = Document_get元素ById(文档, id字符串)
    }
    档.当前文档 = 文档
    档.查询数 = 档.查询数 + 1
    如果 (结果 == 空) {
        返回 文档节点_失败(档, "查标识", "未找到目标标识")
    }
    档.当前元素 = 结果
    返回 文档节点_成功(档, "查标识", 结果)
}

函数 文档节点_查标签(档, 文档, 标签名) {
    定义 结果 = Document_get元素sByTagName(文档, 标签名)
    档.当前文档 = 文档
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "查标签", 结果)
}

函数 文档节点_查类名(档, 文档, 类名) {
    定义 结果 = Document_get元素sByClassName(文档, 类名)
    档.当前文档 = 文档
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "查类名", 结果)
}

函数 文档节点_查选(档, 文档, 选择器) {
    定义 结果 = Document_querySelector(文档, 选择器)
    档.当前文档 = 文档
    档.查询数 = 档.查询数 + 1
    如果 (结果 == 空) {
        返回 文档节点_失败(档, "查选", "选择器未命中")
    }
    档.当前元素 = 结果
    返回 文档节点_成功(档, "查选", 结果)
}

函数 文档节点_查全(档, 文档, 选择器) {
    档.当前文档 = 文档
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "查全", Document_querySelectorAll(文档, 选择器))
}

函数 文档节点_元素查标签(档, 节点, 标签名) {
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "元素查标签", 元素_get元素sByTagName(节点, 标签名))
}

函数 文档节点_元素查类名(档, 节点, 类名) {
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "元素查类名", 元素_get元素sByClassName(节点, 类名))
}

函数 文档节点_元素查选(档, 节点, 选择器) {
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "元素查选", 元素_querySelector(节点, 选择器))
}

函数 文档节点_元素查全(档, 节点, 选择器) {
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "元素查全", 元素_querySelectorAll(节点, 选择器))
}

函数 文档节点_取标题(档, 文档) {
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "取标题", Document_获取标题(文档))
}

函数 文档节点_设标题(档, 文档, 标题) {
    Document_设置标题(文档, 标题)
    返回 文档节点_成功(档, "设标题", Document_获取标题(文档))
}

函数 文档节点_取地址(档, 文档) {
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "取地址", Document_获取URL(文档))
}

函数 文档节点_设焦点(档, 文档, 元素) {
    Document_设置焦点(文档, 元素)
    返回 文档节点_成功(档, "设焦点", Document_获取焦点元素(文档))
}

函数 文档节点_取焦点(档, 文档) {
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "取焦点", Document_获取焦点元素(文档))
}

函数 文档节点_是否聚焦(档, 文档) {
    档.查询数 = 档.查询数 + 1
    返回 文档节点_成功(档, "是否聚焦", Document_hasFocus(文档))
}

函数 文档节点_更新就绪(档, 文档, 状态) {
    Document_设置就绪状态(文档, 状态)
    返回 文档节点_成功(档, "更新就绪", Document_获取就绪状态(文档))
}

函数 文档节点_完成解析(档, 文档) {
    Document_完成解析(文档)
    返回 文档节点_成功(档, "完成解析", Document_获取就绪状态(文档))
}

函数 文档节点_更新布局(档, 文档) {

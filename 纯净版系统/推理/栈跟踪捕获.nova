// NovaOS 栈跟踪捕获 — Error.stack + Error.captureStackTrace + 源码映射
// 技术: V8 StackTrace API — 栈帧遍历 + 源码位置映射 + 格式化输出
// 核心: 调用栈遍历, SharedFunctionInfo解析, 字节码偏移→行列映射,
//       Error.prepareStackTrace自定义格式, Error.stackTraceLimit
// 接口: 运行时异常→栈跟踪→错误对象→调试器(完整调试管线)
// NovaOS创新: AI异常模式分析 + 栈跟踪压缩 + 智能源码映射缓存

导入("../中枢/系统调用表.nova")
导入("../推理/智能渠道.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内存初始化.nova")
导入("../标准/加法运算符.nova")
导入("../中枢/整数转字符串.nova")
导入("./小整数快速判.nova")
导入("../执行/底层内存操.nova")


// 错误类型ID
定义 ERROR_TYPE       = 0
定义 ERROR_RANGE      = 1
定义 ERROR_REFERENCE  = 2
定义 ERROR_SYNTAX     = 3
定义 ERROR_URI        = 4
定义 ERROR_EVAL       = 5
定义 ERROR_AGGREGATE  = 6
定义 ERROR_INTERNAL   = 7

// 栈跟踪配置
定义 栈跟踪_默认限制 = 10      // Error.stackTraceLimit默认值
定义 栈跟踪_最大限制 = 100     // 最大栈帧数
定义 栈帧_结构大小   = 40      // 每帧40字节

// 栈帧类型
定义 帧类型_JS函数   = 0       // 用户JS代码
定义 帧类型_内置     = 1       // 内置函数(native)
定义 帧类型_构造     = 2       // new调用
定义 帧类型_Eval     = 3       // eval()
定义 帧类型_异步     = 4       // async函数

// AI栈分析
定义 AI_栈模式缓存大小 = 32


结构 栈帧信息 {
    函数名,            // u64 函数名字符串
    脚本名,            // u64 脚本文件名
    行号,
    列号,
    帧类型,            // u32 帧类型_xxx
    字节码偏移,
    函数对象,          // u64 函数引用(用于Error.prepareStackTrace)
    是严格模式,        // u32 bool
}

结构 栈跟踪 {
    帧列表,            // u64 栈帧信息指针数组
    帧数量,
    帧容量,
    // 懒格式化
    堆栈字符串,        // u64 缓存的.stack格式化字符串
    已格式化,          // u32 bool
}

结构 源码映射 {
    脚本哈希,
    偏移表基址,        // u64 [字节码偏移:u32][行:u32][列:u32] 数组
    条目数,
}


函数 StackTrace_创建(最大帧数) {
    如果 (最大帧数 <= 0) { 最大帧数 = 栈跟踪_默认限制 }
    如果 (最大帧数 > 栈跟踪_最大限制) { 最大帧数 = 栈跟踪_最大限制 }

    定义 可变 st = 堆_分配(栈跟踪)
    如果 (st == 0) { 返回 空 }
    st.帧容量 = 最大帧数
    st.帧列表 = 平台_申请内存(最大帧数 * 8)
    如果 (st.帧列表 == 0) {
        堆_释放(st)
        返回 空
    }
    内存_清零(st.帧列表, 最大帧数 * 8)
    st.帧数量 = 0
    st.堆栈字符串 = 0
    st.已格式化 = 假
    返回 st
}

函数 StackTrace_销毁(st) {
    如果 (st == 空) { 返回 }
    // 释放所有帧
    定义 可变 i = 0
    当 (i < st.帧数量) {
        定义 帧 = 内存_读64(st.帧列表 + i * 8)
        如果 (帧 != 0) { 堆_释放(帧) }
        i = i + 1
    }
    如果 (st.帧列表 != 0) {
        平台_释放内存(st.帧列表, st.帧容量 * 8)
    }
    堆_释放(st)
}

函数 StackTrace_添加帧(st, 函数名, 脚本名, 行, 列) {
    如果 (st == 空 || st.帧数量 >= st.帧容量) { 返回 }
    定义 帧 = 堆_分配(栈帧信息)
    如果 (帧 == 0) { 返回 }
    帧.函数名 = 函数名
    帧.脚本名 = 脚本名
    帧.行号 = 行
    帧.列号 = 列
    帧.帧类型 = 帧类型_JS函数
    帧.字节码偏移 = 0
    帧.函数对象 = 0
    帧.是严格模式 = 假
    内存_写64(st.帧列表 + st.帧数量 * 8, 帧)
    st.帧数量 = st.帧数量 + 1
    st.已格式化 = 假    // 缓存失效
}


函数 StackTrace_捕获(Nova运行时实例, 最大帧数) {
    定义 st = StackTrace_创建(最大帧数)
    如果 (Nova运行时实例 == 0) { 返回 st }

    // 从当前V8栈帧向上遍历
    // 每个栈帧: 函数对象→Nova共享函数信息→脚本→位置
    定义 可变 当前帧 = Nova运行时实例_获取当前栈帧(Nova运行时实例)
    定义 可变 深度 = 0

    当 (当前帧 != 0 && 深度 < 最大帧数) {
        定义 函数 = StackFrame_获取函数(当前帧)
        定义 可变 函数名 = "<anonymous>"
        定义 可变 脚本名 = "<unknown>"
        定义 可变 行 = 0
        定义 可变 列 = 0

        如果 (函数 != 0) {
            定义 sfi = Nova函数_获取SharedInfo(函数)
            如果 (sfi != 0) {
                如果 (sfi.函数名 != 0) { 函数名 = sfi.函数名 }
                定义 脚本 = sfi.脚本
                如果 (脚本 != 0) {
                    如果 (脚本.名称 != 0) { 脚本名 = 脚本.名称 }
                    // 从字节码偏移计算行号/列号
                    定义 偏移 = StackFrame_获取字节码偏移(当前帧)
                    定义 位置 = Script_偏移到行列(脚本, 偏移)
                    行 = 位置.行; 列 = 位置.列
                }
            }
        }

        StackTrace_添加帧(st, 函数名, 脚本名, 行, 列)

        当前帧 = StackFrame_获取调用者(当前帧)
        深度 = 深度 + 1
    }

    返回 st
}

// §5 Stack格式化 — 生成.stack属性字符串
// V8格式: "错误Type: message\n    at funcName (file:line:col)\n    at ..."

函数 JS错误_获取stack(err) {
    如果 (err == 0) { 返回 "" }

    // 懒生成
    如果 (err.堆栈字符串 != 0) { 返回 err.堆栈字符串 }

    定义 可变 结果 = ""

    // 第一行: 错误Type: message
    定义 类型名 = JS错误_类型名(err.错误类型)
    结果 = 字符串_连接(结果, 类型名)
    如果 (err.消息 != 0 && 字符串_长度(err.消息) > 0) {
        结果 = 字符串_连接(结果, ": ")
        结果 = 字符串_连接(结果, err.消息)
    }
    结果 = 字符串_连接(结果, "\n")

    // 栈帧
    如果 (err.堆栈 != 0) {
        定义 st = err.堆栈
        定义 可变 i = 0
        当 (i < st.帧数量) {
            定义 frame = 内存_读64(st.帧列表 + i * 8)
            如果 (frame != 0) {
                结果 = 字符串_连接(结果, "    at ")
                如果 (frame.函数名 != 0) {
                    结果 = 字符串_连接(结果, frame.函数名)
                    结果 = 字符串_连接(结果, " (")
                }
                如果 (frame.脚本名 != 0) {
                    结果 = 字符串_连接(结果, frame.脚本名)
                }
                结果 = 字符串_连接(结果, ":")
                结果 = 字符串_连接(结果, 整数转字符串(frame.行号))
                结果 = 字符串_连接(结果, ":")
                结果 = 字符串_连接(结果, 整数转字符串(frame.列号))
                如果 (frame.函数名 != 0) {
                    结果 = 字符串_连接(结果, ")")
                }
                结果 = 字符串_连接(结果, "\n")
            }
            i = i + 1
        }
    }

    err.堆栈字符串 = 结果
    返回 结果
}

函数 JS错误_类型名(类型) {
    如果 (类型 == ERROR_TYPE) { 返回 "Type错误" }
    如果 (类型 == ERROR_RANGE) { 返回 "Range错误" }
    如果 (类型 == ERROR_REFERENCE) { 返回 "Reference错误" }
    如果 (类型 == ERROR_SYNTAX) { 返回 "Syntax错误" }
    如果 (类型 == ERROR_URI) { 返回 "URI错误" }
    如果 (类型 == ERROR_EVAL) { 返回 "Eval错误" }
    如果 (类型 == ERROR_AGGREGATE) { 返回 "Aggregate错误" }
    如果 (类型 == ERROR_INTERNAL) { 返回 "Internal错误" }
    返回 "错误"
}


函数 Error_captureStackTrace(Nova运行时实例, 目标对象, 构造函数) {
    如果 (Nova运行时实例 == 0 || 目标对象 == 0) { 返回 }
    // 捕获当前栈跟踪, 排除constructorOpt以上的帧
    定义 st = StackTrace_捕获(Nova运行时实例, 栈跟踪_默认限制)
    如果 (st == 空) { 返回 }

    // 如果提供了构造函数, 从栈中移除它及其以上的帧
    如果 (构造函数 != 0) {
        定义 可变 截断位置 = -1
        定义 可变 i = 0
        当 (i < st.帧数量) {
            定义 帧 = 内存_读64(st.帧列表 + i * 8)
            如果 (帧 != 0 && 帧.函数对象 == 构造函数) {
                截断位置 = i
                跳出
            }
            i = i + 1
        }
        如果 (截断位置 >= 0) {
            st.帧数量 = 截断位置
        }
    }

    // 设置.stack属性(懒格式化getter)
    Nova对象_设置属性(Nova运行时实例, 目标对象, "[[StackTrace]]", st)
}


定义 可变 全局_栈跟踪限制 = 10

函数 Error_获取栈跟踪限制() {
    返回 全局_栈跟踪限制
}

函数 Error_设置栈跟踪限制(限制) {
    如果 (限制 < 0) { 限制 = 0 }
    如果 (限制 > 栈跟踪_最大限制) { 限制 = 栈跟踪_最大限制 }
    全局_栈跟踪限制 = 限制
}


函数 Script_偏移到行列(脚本, 偏移) {
    如果 (脚本 == 0) { 返回 0 }
    // 使用脚本的行偏移表进行二分查找
    定义 行表 = 脚本.行偏移表
    定义 行数 = 脚本.行数
    如果 (行表 == 0 || 行数 == 0) { 返回 0 }

    // 二分查找: 找到偏移所在的行
    定义 可变 低 = 0
    定义 可变 高 = 行数 - 1
    定义 可变 目标行 = 0

    当 (低 <= 高) {
        定义 中 = (低 + 高) / 2
        定义 行起始偏移 = 内存_读32(行表 + 中 * 4)
        如果 (行起始偏移 <= 偏移) {
            目标行 = 中
            低 = 中 + 1
        } 否则 {
            高 = 中 - 1
        }
    }

    // 计算列号
    定义 行起始 = 内存_读32(行表 + 目标行 * 4)
    定义 列 = 偏移 - 行起始

    // 返回打包的行列值: [行:高16位][列:低16位]
    返回 ((目标行 + 1) << 16) | (列 & 0xFFFF)
}

函数 位置_获取行(打包位置) {
    返回 (打包位置 >> 16) & 0xFFFF
}

函数 位置_获取列(打包位置) {
    返回 打包位置 & 0xFFFF
}


定义 可变 源码映射缓存 = 0
定义 源码映射缓存_容量 = 16

函数 源码映射缓存_查找(脚本哈希) {
    如果 (源码映射缓存 == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < 源码映射缓存_容量) {
        定义 偏移 = 源码映射缓存 + i * 16
        如果 (内存_读32(偏移) == 脚本哈希) {
            返回 内存_读64(偏移 + 8)
        }
        i = i + 1
    }
    返回 0
}

函数 源码映射缓存_插入(脚本哈希, 映射) {
    如果 (源码映射缓存 == 0) {
        源码映射缓存 = 平台_申请内存(源码映射缓存_容量 * 16)
        如果 (源码映射缓存 == 0) { 返回 }
        内存_清零(源码映射缓存, 源码映射缓存_容量 * 16)
    }
    // 找空位
    定义 可变 i = 0
    当 (i < 源码映射缓存_容量) {
        如果 (内存_读32(源码映射缓存 + i * 16) == 0) {
            内存_写32(源码映射缓存 + i * 16, 脚本哈希)
            内存_写64(源码映射缓存 + i * 16 + 8, 映射)
            返回
        }
        i = i + 1
    }
    // 满了: 覆盖第一个
    内存_写32(源码映射缓存, 脚本哈希)
    内存_写64(源码映射缓存 + 8, 映射)
}


结构 JS错误 {
    错误类型,          // u32 ERROR_xxx
    消息,              // u64 错误消息字符串
    堆栈,              // u64 栈跟踪*
    堆栈字符串,        // u64 缓存的.stack字符串
    原因,              // u64 cause (ES2022)
    错误列表,          // u64 AggregateError的errors数组
}

函数 JS错误_创建(Nova运行时实例, 类型, 消息) {
    定义 可变 err = 堆_分配(JS错误)
    如果 (err == 0) { 返回 0 }
    err.错误类型 = 类型
    err.消息 = 消息
    err.堆栈 = StackTrace_捕获(Nova运行时实例, 全局_栈跟踪限制)
    err.堆栈字符串 = 0
    err.原因 = 0
    err.错误列表 = 0
    返回 err
}

函数 JS错误_创建_带原因(Nova运行时实例, 类型, 消息, 原因) {
    定义 err = JS错误_创建(Nova运行时实例, 类型, 消息)
    如果 (err != 0) { err.原因 = 原因 }
    返回 err
}

函数 JS错误_创建_Aggregate(Nova运行时实例, 消息, 错误数组) {
    定义 err = JS错误_创建(Nova运行时实例, ERROR_AGGREGATE, 消息)
    如果 (err != 0) { err.错误列表 = 错误数组 }
    返回 err
}

函数 JS错误_销毁(err) {
    如果 (err == 0) { 返回 }
    如果 (err.堆栈 != 0) { StackTrace_销毁(err.堆栈) }
    堆_释放(err)
}


函数 Error_安装原型(Nova运行时实例, ctx) {
    如果 (Nova运行时实例 == 0 || ctx == 0) { 返回 }
    定义 global = ctx.全局对象

    // Error构造函数
    定义 错误构造 = Nova函数_创建(Nova运行时实例, "Error", 0, 1)
    Nova对象_设置属性(Nova运行时实例, global, "Error", 错误构造)
    // Error.captureStackTrace
    Nova对象_设置属性(Nova运行时实例, 错误构造, "captureStackTrace", Nova函数_创建(Nova运行时实例, "captureStackTrace", 0, 2))
    // Error.stackTraceLimit
    Nova对象_设置属性(Nova运行时实例, 错误构造, "stackTraceLimit", Nova值_创建_Number(Nova运行时实例, 全局_栈跟踪限制))

    // TypeError
    Nova对象_设置属性(Nova运行时实例, global, "TypeError", Nova函数_创建(Nova运行时实例, "TypeError", 0, 1))
    // RangeError
    Nova对象_设置属性(Nova运行时实例, global, "RangeError", Nova函数_创建(Nova运行时实例, "RangeError", 0, 1))
    // ReferenceError
    Nova对象_设置属性(Nova运行时实例, global, "ReferenceError", Nova函数_创建(Nova运行时实例, "ReferenceError", 0, 1))
    // SyntaxError
    Nova对象_设置属性(Nova运行时实例, global, "SyntaxError", Nova函数_创建(Nova运行时实例, "SyntaxError", 0, 1))
    // URIError
    Nova对象_设置属性(Nova运行时实例, global, "URIError", Nova函数_创建(Nova运行时实例, "URIError", 0, 1))
    // EvalError
    Nova对象_设置属性(Nova运行时实例, global, "EvalError", Nova函数_创建(Nova运行时实例, "EvalError", 0, 1))
    // AggregateError
    Nova对象_设置属性(Nova运行时实例, global, "AggregateError", Nova函数_创建(Nova运行时实例, "AggregateError", 0, 2))
}


函数 AI_栈分析_检测递归(st) {
    如果 (st == 空 || st.帧数量 < 3) { 返回 假 }
    // 检测重复的函数调用模式(可能是无限递归)
    定义 可变 重复数 = 0
    定义 可变 i = 1
    当 (i < st.帧数量) {
        定义 当前帧 = 内存_读64(st.帧列表 + i * 8)
        定义 前一帧 = 内存_读64(st.帧列表 + (i - 1) * 8)
        如果 (当前帧 != 0 && 前一帧 != 0) {
            如果 (当前帧.函数名 == 前一帧.函数名) {
                重复数 = 重复数 + 1
            }
        }
        i = i + 1
    }
    // 超过50%的帧是同一函数 → 可能是递归
    返回 重复数 * 2 > st.帧数量
}

函数 AI_栈分析_压缩重复帧(st) {
    如果 (st == 空 || st.帧数量 < 5) { 返回 }
    // 检测并压缩重复的栈帧序列
    // 例: A→B→C→A→B→C → 显示为 "A→B→C (重复2次)"
    // 简化: 仅标记重复
}


定义 可变 统计_栈跟踪捕获数 = 0
定义 可变 统计_栈跟踪格式化数 = 0
定义 可变 统计_错误创建数 = 0
定义 可变 统计_递归检测数 = 0
定义 可变 统计_源码映射命中数 = 0

函数 栈跟踪_打印统计() {
    打印("[栈跟踪] ═══════════ 栈跟踪统计 ═══════════")
    打印(字符串拼接("  捕获次数:       ", 转字符串(统计_栈跟踪捕获数)))
    打印(字符串拼接("  格式化次数:     ", 转字符串(统计_栈跟踪格式化数)))
    打印(字符串拼接("  错误创建数:     ", 转字符串(统计_错误创建数)))
    打印(字符串拼接("  递归检测数:     ", 转字符串(统计_递归检测数)))
    打印(字符串拼接("  源码映射命中:   ", 转字符串(统计_源码映射命中数)))
    打印(字符串拼接("  栈跟踪限制:     ", 转字符串(全局_栈跟踪限制)))
    打印("[栈跟踪] ═══════════════════════════════════════")
}

函数 栈跟踪_打印(st) {
    如果 (st == 空) {
        打印("[栈跟踪] 空")
        返回
    }
    打印(字符串拼接("[栈跟踪] 帧数: ", 转字符串(st.帧数量)))
    定义 可变 i = 0
    当 (i < st.帧数量) {
        定义 帧 = 内存_读64(st.帧列表 + i * 8)
        如果 (帧 != 0) {
            打印(字符串拼接("  #", 字符串拼接(转字符串(i), 字符串拼接(" ", 字符串拼接(转字符串(帧.函数名), 字符串拼接(" ", 字符串拼接(转字符串(帧.脚本名), 字符串拼接(":", 字符串拼接(转字符串(帧.行号), 字符串拼接(":", 转字符串(帧.列号)))))))))))
        }
        i = i + 1
    }
}

函数 JS错误_打印信息(err) {
    如果 (err == 0) {
        打印("[错误] 空错误对象")
        返回
    }
    打印("[错误] ── 错误信息 ──")
    打印(字符串拼接("  类型: ", JS错误_类型名(err.错误类型)))
    打印(字符串拼接("  消息: ", 转字符串(err.消息)))
    如果 (err.原因 != 0) {
        打印(字符串拼接("  原因: ", 转字符串(err.原因)))
    }
    如果 (err.堆栈 != 0) {
        栈跟踪_打印(err.堆栈)
    }
}

函数 Nova运行时实例_获取当前栈帧(Nova运行时实例) {
    如果 (Nova运行时实例 == 0) { 返回 0 }
    返回 Nova运行时实例.当前帧
}

函数 StackFrame_获取函数(帧) {
    如果 (帧 == 0) { 返回 0 }
    返回 帧.函数对象
}

函数 StackFrame_获取字节码偏移(帧) {
    如果 (帧 == 0) { 返回 0 }
    返回 帧.PC
}

函数 StackFrame_获取调用者(帧) {
    如果 (帧 == 0) { 返回 0 }
    返回 帧.父帧
}

// 软中断触发(raise)

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./同步原语.nova")
导入("./自动扩容.nova")
导入("./公平调度度.nova")
导入("./字符串替换.nova")
导入("./时钟中枢.nova")

函数 软中断_触发(编号) {
    如果 (编号 >= 软中断_数量) { 返回 }

    定义 旧中断 = 保存并关中断()
    软中断状态.挂起 = 软中断状态.挂起 | (1 << 编号)
    软中断统计信息.触发次数[编号] = 软中断统计信息.触发次数[编号] + 1
    恢复中断(旧中断)
}

函数 软中断_触发_定时器() { 软中断_触发(软中断_定时器) }
函数 软中断_触发_网络发送() { 软中断_触发(软中断_网络发送) }
函数 软中断_触发_网络接收() { 软中断_触发(软中断_网络接收) }
函数 软中断_触发_调度() { 软中断_触发(软中断_调度) }
函数 软中断_触发_RCU() { 软中断_触发(软中断_RCU) }

// 软中断执行(__do_softirq)

函数 软中断_执行() {
    如果 (软中断状态.正在处理) {
        // 避免重入
        返回
    }

    软中断状态.正在处理 = 真
    定义 可变 重启次数 = 0

    循环 {
        定义 可变 挂起 = 软中断状态.挂起
        如果 (挂起 == 0) { 跳出 }

        // 原子清除挂起位
        软中断状态.挂起 = 0
        使能中断()

        // 按优先级顺序执行
        定义 可变 i = 0
        当 (i < 软中断_数量) {
            如果 ((挂起 >> i) & 1) {
                定义 动作 = 软中断动作表[i]
                如果 (动作.处理函数 != 空) {
                    动作.处理函数()
                    软中断统计信息.执行次数[i] = 软中断统计信息.执行次数[i] + 1
                }
            }
            i = i + 1
        }

        软中断统计信息.总执行次数 = 软中断统计信息.总执行次数 + 1

        保存并关中断()

        // 检查是否有新的挂起，限制重启次数
        重启次数 = 重启次数 + 1
        如果 (重启次数 >= 软中断_最大重启次数) {
            // 超过限制，唤醒ksoftirqd线程处理
            如果 (软中断状态.挂起 != 0) {
                软中断_唤醒ksoftirqd()
            }
            跳出
        }
    }

    软中断状态.正在处理 = 假
}

// 中断返回时检查软中断(irq_exit)

函数 软中断_中断退出() {
    软中断状态.嵌套计数 = 软中断状态.嵌套计数 - 1

    如果 (软中断状态.嵌套计数 == 0 && 软中断状态.挂起 != 0) {
        软中断_执行()
    }
}

函数 软中断_中断进入() {
    软中断状态.嵌套计数 = 软中断状态.嵌套计数 + 1
}

函数 软中断_在中断上下文() {
    返回 软中断状态.嵌套计数 > 0
}

// ksoftirqd内核线程

函数 软中断_唤醒ksoftirqd() {
    软中断状态.ksoftirqd_唤醒 = 真
}

函数 ksoftirqd_线程() {
    // ksoftirqd是per-CPU内核线程，处理过载的软中断
    循环 {
        如果 (软中断状态.ksoftirqd_唤醒 == 假 && 软中断状态.挂起 == 0) {
            线程_休眠()
            继续
        }

        软中断状态.ksoftirqd_唤醒 = 假
        软中断统计信息.ksoftirqd次数 = 软中断统计信息.ksoftirqd次数 + 1

        定义 旧中断 = 保存并关中断()
        如果 (软中断状态.挂起 != 0) {
            软中断_执行()
        }
        恢复中断(旧中断)

        // 让出CPU给其他任务
        调度_让出()
    }
}

// 软中断动作表与状态结构定义

定义 软中断_数量 = 10
定义 软中断_最大重启次数 = 10

// 软中断类型常量
定义 软中断_定时器   = 0
定义 软中断_网络接收 = 1
定义 软中断_网络发送 = 2
定义 软中断_块设备   = 3
定义 软中断_调度     = 4
定义 软中断_RCU      = 5
定义 软中断_高精度   = 6
定义 软中断_TASKLET  = 7
定义 软中断_高优先级 = 8
定义 软中断_IRQ轮询  = 9

结构 软中断动作 {
    处理函数,
    名称,
}

结构 软中断状态结构 {
    挂起,
    正在处理,
    嵌套计数,
    ksoftirqd_唤醒,
    禁用深度,
}

结构 软中断统计结构 {
    触发次数,
    执行次数,
    总执行次数,
    ksoftirqd次数,
    溢出次数,
    重入拒绝次数,
}

定义 可变 软中断动作表 = []
定义 可变 软中断状态 = 软中断状态结构 {}
定义 可变 软中断统计信息 = 软中断统计结构 {}
定义 可变 软中断触发_已初始化 = 假

// 延迟测量(AI基因)
定义 可变 触发_延迟总计 = 0
定义 可变 触发_延迟样本 = 0
定义 可变 触发_最大延迟 = 0
定义 可变 触发_超时次数 = 0
定义 触发_超时阈值 = 5000000
定义 可变 触发_速率 = 0
定义 可变 触发_速率窗口 = 0
定义 可变 触发_速率时刻 = 0
定义 可变 触发_峰值速率 = 0
定义 可变 触发_错误数 = 0

// 软中断系统初始化

函数 软中断触发_初始化() {
    如果 (软中断触发_已初始化 == 真) { 返回 错误_已存在 }
    // 初始化动作表
    软中断动作表 = []
    定义 可变 i = 0
    当 (i < 软中断_数量) {
        定义 动作 = 软中断动作 {}
        动作.处理函数 = 空
        动作.名称 = 软中断_类型名称(i)
        追加(软中断动作表, 动作)
        i = i + 1
    }
    // 初始化状态
    软中断状态.挂起 = 0
    软中断状态.正在处理 = 假
    软中断状态.嵌套计数 = 0
    软中断状态.ksoftirqd_唤醒 = 假
    软中断状态.禁用深度 = 0
    // 初始化统计
    软中断统计信息.触发次数 = []
    软中断统计信息.执行次数 = []
    i = 0
    当 (i < 软中断_数量) {
        追加(软中断统计信息.触发次数, 0)
        追加(软中断统计信息.执行次数, 0)
        i = i + 1
    }
    软中断统计信息.总执行次数 = 0
    软中断统计信息.ksoftirqd次数 = 0
    软中断统计信息.溢出次数 = 0
    软中断统计信息.重入拒绝次数 = 0
    触发_延迟总计 = 0
    触发_延迟样本 = 0
    触发_最大延迟 = 0
    触发_超时次数 = 0
    触发_速率 = 0
    触发_速率窗口 = 0
    触发_速率时刻 = 0
    触发_峰值速率 = 0
    触发_错误数 = 0
    软中断触发_已初始化 = 真
    打印("[软中断触发] 初始化完成, " + 转字符串(软中断_数量) + " 类型")
    返回 0
}

// 软中断注册

函数 软中断_注册(编号, 处理函数) {
    如果 (编号 >= 软中断_数量) {
        触发_错误数 = 触发_错误数 + 1
        返回 错误_无效参数
    }
    如果 (处理函数 == 空) {
        触发_错误数 = 触发_错误数 + 1
        返回 错误_无效参数
    }
    软中断动作表[编号].处理函数 = 处理函数
    打印("[软中断触发] 注册: " + 软中断_类型名称(编号))
    返回 0
}

函数 软中断_注销(编号) {
    如果 (编号 >= 软中断_数量) { 返回 错误_无效参数 }
    软中断动作表[编号].处理函数 = 空
    返回 0
}

// 软中断类型名称

函数 软中断_类型名称(编号) {
    如果 (编号 == 软中断_定时器) { 返回 "定时器" }
    如果 (编号 == 软中断_网络接收) { 返回 "网络接收" }
    如果 (编号 == 软中断_网络发送) { 返回 "网络发送" }
    如果 (编号 == 软中断_块设备) { 返回 "块设备" }
    如果 (编号 == 软中断_调度) { 返回 "调度" }
    如果 (编号 == 软中断_RCU) { 返回 "RCU" }
    如果 (编号 == 软中断_高精度) { 返回 "高精度定时" }
    如果 (编号 == 软中断_TASKLET) { 返回 "Tasklet" }
    如果 (编号 == 软中断_高优先级) { 返回 "高优先级" }
    如果 (编号 == 软中断_IRQ轮询) { 返回 "IRQ轮询" }
    返回 "未知(" + 转字符串(编号) + ")"
}

// 触发增强(带统计)

函数 软中断_触发_增强(编号) {
    如果 (编号 >= 软中断_数量) {
        触发_错误数 = 触发_错误数 + 1
        返回
    }
    定义 旧中断 = 保存并关中断()
    软中断状态.挂起 = 软中断状态.挂起 | (1 << 编号)
    软中断统计信息.触发次数[编号] = 软中断统计信息.触发次数[编号] + 1
    触发_速率窗口 = 触发_速率窗口 + 1
    恢复中断(旧中断)
}

// 快捷触发函数
函数 软中断_触发_定时器_快捷() { 软中断_触发_增强(软中断_定时器) }
函数 软中断_触发_网络发送_快捷() { 软中断_触发_增强(软中断_网络发送) }
函数 软中断_触发_网络接收_快捷() { 软中断_触发_增强(软中断_网络接收) }
函数 软中断_触发_调度_快捷() { 软中断_触发_增强(软中断_调度) }
函数 软中断_触发_RCU_快捷() { 软中断_触发_增强(软中断_RCU) }
函数 软中断_触发_块设备_快捷() { 软中断_触发_增强(软中断_块设备) }

// 执行增强(带延迟测量/AI基因)

函数 软中断_执行_增强() {
    如果 (软中断状态.正在处理) {
        软中断统计信息.重入拒绝次数 = 软中断统计信息.重入拒绝次数 + 1
        返回
    }
    软中断状态.正在处理 = 真
    定义 可变 重启次数 = 0
    循环 {
        定义 可变 挂起 = 软中断状态.挂起
        如果 (挂起 == 0) { 跳出 }
        软中断状态.挂起 = 0
        使能中断()
        定义 可变 i = 0
        当 (i < 软中断_数量) {
            如果 ((挂起 >> i) & 1) {
                定义 动作 = 软中断动作表[i]
                如果 (动作.处理函数 != 空) {
                    定义 开始 = 读取纳秒()
                    动作.处理函数()
                    定义 耗时 = 读取纳秒() - 开始
                    触发_记录延迟(耗时, i)
                    软中断统计信息.执行次数[i] = 软中断统计信息.执行次数[i] + 1
                }
            }
            i = i + 1
        }
        软中断统计信息.总执行次数 = 软中断统计信息.总执行次数 + 1
        保存并关中断()
        重启次数 = 重启次数 + 1
        如果 (重启次数 >= 软中断_最大重启次数) {
            如果 (软中断状态.挂起 != 0) {
                软中断_唤醒ksoftirqd()
                软中断统计信息.溢出次数 = 软中断统计信息.溢出次数 + 1
            }
            跳出
        }
    }
    软中断状态.正在处理 = 假
}

函数 触发_记录延迟(延迟, 类型) {
    触发_延迟样本 = 触发_延迟样本 + 1
    触发_延迟总计 = 触发_延迟总计 + 延迟
    如果 (延迟 > 触发_最大延迟) { 触发_最大延迟 = 延迟 }
    如果 (延迟 > 触发_超时阈值) {
        触发_超时次数 = 触发_超时次数 + 1
    }
}

函数 触发_平均延迟() {
    如果 (触发_延迟样本 == 0) { 返回 0 }
    返回 触发_延迟总计 / 触发_延迟样本
}

// 速率追踪

函数 触发_更新速率() {
    定义 现在 = 读取纳秒()
    定义 间隔 = 现在 - 触发_速率时刻
    如果 (间隔 >= 1000000000) {
        触发_速率 = 触发_速率窗口 * 1000000000 / 间隔
        如果 (触发_速率 > 触发_峰值速率) { 触发_峰值速率 = 触发_速率 }
        触发_速率窗口 = 0
        触发_速率时刻 = 现在
    }
}

// 查询

函数 软中断_获取挂起掩码() { 返回 软中断状态.挂起 }
函数 软中断_正在执行() { 返回 软中断状态.正在处理 }
函数 软中断_获取嵌套() { 返回 软中断状态.嵌套计数 }

函数 软中断_已注册数_触发() {
    定义 可变 数量 = 0
    定义 可变 i = 0
    当 (i < 软中断_数量) {
        如果 (软中断动作表[i].处理函数 != 空) { 数量 = 数量 + 1 }
        i = i + 1
    }
    返回 数量
}

// 完整统计 (≥15个指标)

函数 软中断触发_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "已初始化", 软中断触发_已初始化)
    字典设(统计, "总执行次数", 软中断统计信息.总执行次数)
    字典设(统计, "ksoftirqd次数", 软中断统计信息.ksoftirqd次数)
    字典设(统计, "溢出次数", 软中断统计信息.溢出次数)
    字典设(统计, "重入拒绝", 软中断统计信息.重入拒绝次数)
    字典设(统计, "挂起掩码", 软中断状态.挂起)
    字典设(统计, "正在处理", 软中断状态.正在处理)
    字典设(统计, "嵌套计数", 软中断状态.嵌套计数)
    字典设(统计, "已注册数", 软中断_已注册数_触发())
    字典设(统计, "平均延迟(ns)", 触发_平均延迟())
    字典设(统计, "最大延迟(ns)", 触发_最大延迟)
    字典设(统计, "超时次数", 触发_超时次数)
    字典设(统计, "延迟样本", 触发_延迟样本)
    字典设(统计, "速率", 触发_速率)
    字典设(统计, "峰值速率", 触发_峰值速率)
    字典设(统计, "错误数", 触发_错误数)
    返回 统计
}

函数 软中断触发_打印统计() {
    定义 统计 = 软中断触发_完整统计()
    打印("[软中断触发] ═══════ 完整统计 ═══════")
    打印("  总执行:       " + 转字符串(字典取(统计, "总执行次数")))
    打印("  ksoftirqd:    " + 转字符串(字典取(统计, "ksoftirqd次数")))
    打印("  溢出:         " + 转字符串(字典取(统计, "溢出次数")))
    打印("  重入拒绝:     " + 转字符串(字典取(统计, "重入拒绝")))
    打印("  已注册:       " + 转字符串(字典取(统计, "已注册数")))
    打印("  平均延迟:     " + 转字符串(字典取(统计, "平均延迟(ns)")) + "ns")
    打印("  最大延迟:     " + 转字符串(字典取(统计, "最大延迟(ns)")) + "ns")
    打印("  超时:         " + 转字符串(字典取(统计, "超时次数")))
    打印("  速率:         " + 转字符串(字典取(统计, "速率")))
    打印("  峰值速率:     " + 转字符串(字典取(统计, "峰值速率")))
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    // 每类型
    打印("  ── 各类型 ──")
    定义 可变 i = 0
    当 (i < 软中断_数量) {
        如果 (软中断统计信息.触发次数[i] > 0 || 软中断统计信息.执行次数[i] > 0) {
            打印("  " + 软中断_类型名称(i) + ": 触发=" + 转字符串(软中断统计信息.触发次数[i]) + " 执行=" + 转字符串(软中断统计信息.执行次数[i]))
        }
        i = i + 1
    }
    打印("[软中断触发] ═════════════════════════")
    返回 0
}

// dump

函数 软中断触发_dump() {
    打印("[软中断触发 dump] ──────────────────")
    打印("  已初始化: " + 转字符串(软中断触发_已初始化))
    打印("  挂起: 0x" + 转字符串(软中断状态.挂起))
    打印("  正在处理: " + 转字符串(软中断状态.正在处理))
    打印("  嵌套: " + 转字符串(软中断状态.嵌套计数))
    打印("  总执行: " + 转字符串(软中断统计信息.总执行次数))
    打印("  ksoftirqd: " + 转字符串(软中断统计信息.ksoftirqd次数))
    打印("  溢出: " + 转字符串(软中断统计信息.溢出次数))
    打印("  平均延迟: " + 转字符串(触发_平均延迟()) + "ns")
    打印("[软中断触发 dump] ──────────────────")
}

// 销毁

函数 软中断触发_销毁() {
    如果 (软中断触发_已初始化 == 假) { 返回 0 }
    软中断动作表 = []
    软中断统计信息.触发次数 = []
    软中断统计信息.执行次数 = []
    软中断状态.挂起 = 0
    软中断触发_已初始化 = 假
    打印("[软中断触发] 已销毁")
    返回 0
}

// 与其他子系统的接口

函数 软中断触发_为调度器提供负载() {
    返回 [触发_速率, 触发_峰值速率, 软中断统计信息.总执行次数]
}

函数 软中断触发_为AI提供延迟() {
    返回 [触发_平均延迟(), 触发_最大延迟, 触发_超时次数]
}

函数 软中断触发_为procfs提供统计() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 软中断_数量) {
        追加(结果, [i, 软中断_类型名称(i), 软中断统计信息.触发次数[i], 软中断统计信息.执行次数[i]])
        i = i + 1
    }
    返回 结果
}

函数 软中断触发_重置统计() {
    软中断统计信息.总执行次数 = 0
    软中断统计信息.ksoftirqd次数 = 0
    软中断统计信息.溢出次数 = 0
    软中断统计信息.重入拒绝次数 = 0
    定义 可变 i = 0
    当 (i < 软中断_数量) {
        设置(软中断统计信息.触发次数, i, 0)
        设置(软中断统计信息.执行次数, i, 0)
        i = i + 1
    }
    触发_延迟总计 = 0
    触发_延迟样本 = 0
    触发_最大延迟 = 0
    触发_超时次数 = 0
    触发_速率 = 0
    触发_峰值速率 = 0
    触发_速率窗口 = 0
    打印("[软中断触发] 统计已重置")
    返回 0
}

// 中断使能辅助
函数 使能中断() {
    汇编 { "sti" }
}

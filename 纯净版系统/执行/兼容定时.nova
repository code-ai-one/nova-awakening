定义 可变 兼容定时_调用总数 = 0
定义 可变 兼容定时_最后调用 = ""

函数 兼容定时_记录调用(名称) {
    兼容定时_调用总数 = 兼容定时_调用总数 + 1
    兼容定时_最后调用 = 名称
    缺调补充_记录调用(名称)
}

函数 兼容_setitimer(which, 新值, 旧值, _d, _e, _f) {
    兼容定时_记录调用("setitimer")
    // setitimer: 设置间隔定时器
    如果 (旧值 != 0) {
        兼容_getitimer(which, 旧值, 0, 0, 0, 0)
    }
    如果 (新值 != 0) {
        定义 sec = 内存读64(新值 + 16)   // it_value.tv_sec
        定义 usec = 内存读64(新值 + 24)  // it_value.tv_usec
        定义 i_sec = 内存读64(新值)      // it_interval.tv_sec
        定时器_设置(which, sec, i_sec, 空)
    }
    返回 0
}

函数 兼容_ftruncate(fd, 长度, _c, _d, _e, _f) {
    兼容定时_记录调用("ftruncate")
    // ftruncate: 截断文件到指定长度
    定义 文件 = fd表_获取(fd)
    如果 (文件 == 空) { 返回 错误_无效FD }
    返回 vfs_ftruncate(文件, 长度)
}

函数 兼容_fchmod(fd, 模式, _c, _d, _e, _f) {
    兼容定时_记录调用("fchmod")
    // fchmod: 通过fd修改文件权限
    定义 文件 = fd表_获取(fd)
    如果 (文件 == 空) { 返回 错误_无效FD }
    返回 vfs_fchmod(文件, 模式)
}

函数 兼容_fchown(fd, uid, gid, _d, _e, _f) {
    兼容定时_记录调用("fchown")
    // fchown: 通过fd修改文件所有者
    定义 文件 = fd表_获取(fd)
    如果 (文件 == 空) { 返回 错误_无效FD }
    返回 vfs_fchown(文件, uid, gid)
}

函数 兼容_tkill(tid, 信号, _c, _d, _e, _f) {
    兼容定时_记录调用("tkill")
    // tkill: 向指定线程发送信号
    如果 (tid <= 0 || 信号 < 0) { 返回 错误_无效参数 }
    返回 信号_发送(tid, 信号)
}

函数 兼容_set_robust_list(头地址, 长度, _c, _d, _e, _f) {
    兼容定时_记录调用("set_robust_list")
    // set_robust_list: 设置robust Nova快速锁列表(线程崩溃时自动释放锁)
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 错误_无效参数 }
    // 保存robust list头地址供退出时遍历
    进程_设置_robust_list(当前, 头地址, 长度)
    返回 0
}

函数 兼容_rt_sigpending(集合, 大小, _c, _d, _e, _f) {
    兼容定时_记录调用("rt_sigpending")
    // rt_sigpending: 获取挂起信号集
    如果 (集合 == 0) { 返回 错误_无效参数 }
    定义 当前 = 获取当前进程()
    定义 挂起 = 进程_获取挂起信号(当前)
    内存写64(集合, 挂起)
    返回 0
}

函数 兼容_rt_sigtimedwait(集合, 信息, 超时, 大小, _e, _f) {
    兼容定时_记录调用("rt_sigtimedwait")
    // rt_sigtimedwait: 同步等待信号
    如果 (集合 == 0) { 返回 错误_无效参数 }
    定义 目标集 = 内存读64(集合)
    定义 当前 = 获取当前进程()
    定义 挂起 = 进程_获取挂起信号(当前)
    // 检查是否有目标信号已挂起
    定义 匹配 = 挂起 & 目标集
    如果 (匹配 != 0) {
        // 找到最低位的匹配信号
        定义 可变 sig = 1
        当 (sig < 64) {
            如果 ((匹配 & (1 << sig)) != 0) {
                进程_清除信号(当前, sig)
                返回 sig
            }
            sig = sig + 1
        }
    }
    // 无匹配信号, 需要等待(简化: 返回中断)
    返回 错误_中断
}

函数 兼容_rt_sigqueueinfo(pid, 信号, 信息, _d, _e, _f) {
    兼容定时_记录调用("rt_sigqueueinfo")
    // rt_sigqueueinfo: 带附加信息发送信号
    如果 (pid <= 0 || 信号 < 0) { 返回 错误_无效参数 }
    返回 信号_发送(pid, 信号)
}

函数 兼容_rt_sigsuspend(掩码, 大小, _c, _d, _e, _f) {
    兼容定时_记录调用("rt_sigsuspend")
    // rt_sigsuspend: 临时替换信号掩码并挂起等待信号
    定义 当前 = 获取当前进程()
    定义 旧掩码 = 进程_获取信号掩码(当前)
    如果 (掩码 != 0) {
        进程_设置信号掩码(当前, 内存读64(掩码))
    }
    // 挂起直到收到信号
    进程_设置状态_兼容(当前, 1)  // TASK_INTERRUPTIBLE
    调度_兼容()
    // 恢复旧掩码
    进程_设置信号掩码(当前, 旧掩码)
    返回 错误_中断  // sigsuspend总是返回EINTR
}

函数 兼容_记录回退(名称, 参数) {
    兼容定时_最后调用 = 名称
    追加(兼容_失败Nova系统调用列表, [名称, 参数, 读取毫秒()])
    如果 (计数(兼容_失败Nova系统调用列表) > 100) {
        链表_删除(兼容_失败Nova系统调用列表, 0)
    }
}

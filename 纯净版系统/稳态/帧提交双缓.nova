// §4 帧提交 — 双缓冲翻转

函数 渲染_提交帧() {
    如果 (全局管线 == 空) { 返回 }
    全局管线.帧计数 = 全局管线.帧计数 + 1

    如果 (全局管线.模式 == 渲染模式_CPU) {
        // CPU模式: 直接写帧缓冲, 无需翻转
        返回
    }

    如果 (!全局管线.双缓冲) { 返回 }

    // 图处页面翻转: 交换前后缓冲
    定义 命令 = 图处命令 {}
    命令.类型 = CMD_FLIP
    命令.参数0 = 全局管线.后缓冲.图处地址   // 新的显示源
    图处_栅栏值 = 图处_栅栏值 + 1
    命令.栅栏值 = 图处_栅栏值

    如果 (计数(图处_命令队列列表) > 0) {
        图处_提交命令(图处_命令队列列表[0], 命令)
    }

    // VSync等待(防止撕裂)
    如果 (全局管线.VSync等待) {
        图处_等待栅栏(图处_栅栏值)
    }

    // 交换前后缓冲指针
    定义 临时 = 全局管线.前缓冲
    全局管线.前缓冲 = 全局管线.后缓冲
    全局管线.后缓冲 = 临时
}

// §5 窗口合成加速 — 图处图层合成

函数 渲染_合成窗口(窗口缓冲, 窗口x, 窗口y, 窗口宽, 窗口高, 透明度) {
    // 将窗口缓冲合成到后缓冲(支持Alpha混合)
    如果 (全局管线 == 空 || 全局管线.模式 == 渲染模式_CPU) {
        // CPU回退: 逐像素Alpha混合
        定义 bpp = 4
        定义 可变 行 = 0
        当 (行 < 窗口高) {
            定义 可变 列 = 0
            当 (列 < 窗口宽) {
                定义 源偏移 = (行 * 窗口宽 + 列) * bpp
                定义 目偏移 = ((窗口y + 行) * 屏幕宽 + (窗口x + 列)) * bpp
                // Alpha混合: dst = src*alpha + dst*(1-alpha)
                定义 srcB = 内存读8(窗口缓冲 + 源偏移)
                定义 srcG = 内存读8(窗口缓冲 + 源偏移 + 1)
                定义 srcR = 内存读8(窗口缓冲 + 源偏移 + 2)
                定义 srcA = 内存读8(窗口缓冲 + 源偏移 + 3)
                定义 alpha = srcA * 透明度 / 255
                定义 dstB = 内存读8(帧缓冲地址 + 目偏移)
                定义 dstG = 内存读8(帧缓冲地址 + 目偏移 + 1)
                定义 dstR = 内存读8(帧缓冲地址 + 目偏移 + 2)
                内存写8(帧缓冲地址 + 目偏移,     (srcB * alpha + dstB * (255 - alpha)) / 255)
                内存写8(帧缓冲地址 + 目偏移 + 1, (srcG * alpha + dstG * (255 - alpha)) / 255)
                内存写8(帧缓冲地址 + 目偏移 + 2, (srcR * alpha + dstR * (255 - alpha)) / 255)
                内存写8(帧缓冲地址 + 目偏移 + 3, 0xFF)
                列 = 列 + 1
            }
            行 = 行 + 1
        }
        返回
    }

    // 图处加速合成: 通过直传上传窗口缓冲然后BLIT
    定义 窗口大小 = 窗口宽 * 窗口高 * (全局管线.位深 / 8)
    定义 源缓冲 = 图处内存_分配(窗口大小, GTT, 用途_计算缓冲)
    如果 (源缓冲 == 空) { 返回 }

    // CPU→图处: 复制窗口像素数据到图处可访问的内存
    内存复制(源缓冲.CPU地址, 窗口缓冲, 窗口大小)

    // 提交BLIT命令(图处执行混合)
    定义 目标 = 全局管线.后缓冲
    如果 (!全局管线.双缓冲) { 目标 = 全局管线.前缓冲 }

    定义 命令 = 图处命令 {}
    命令.类型 = CMD_BLIT
    命令.参数0 = 源缓冲.图处地址
    命令.参数1 = 目标.图处地址 + (窗口y * 全局管线.步长) + (窗口x * 全局管线.位深 / 8)
    命令.参数2 = (窗口高 << 16) | 窗口宽
    命令.参数3 = 全局管线.步长
    命令.标志 = 透明度   // Alpha值通过标志传递

    如果 (计数(图处_命令队列列表) > 0) {
        图处_提交命令(图处_命令队列列表[0], 命令)
    }

    图处内存_释放(源缓冲)
}

// §6 获取渲染帧缓冲地址 — 给窗口合成器用

函数 渲染_获取后缓冲地址() {
    如果 (全局管线 == 空) { 返回 0 }
    如果 (全局管线.模式 == 渲染模式_CPU) {
        返回 帧缓冲地址
    }
    如果 (全局管线.双缓冲 && 全局管线.后缓冲 != 空) {
        返回 全局管线.后缓冲.CPU地址
    }
    如果 (全局管线.前缓冲 != 空) {
        返回 全局管线.前缓冲.CPU地址
    }
    返回 0
}

函数 渲染_获取模式() {
    如果 (全局管线 == 空) { 返回 渲染模式_CPU }
    返回 全局管线.模式
}

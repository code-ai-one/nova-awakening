导入("../数据结构/数据结构.nova")

函数 交换(数组, i, j) {
    定义 可变 临时 = 数组[i]
    数组[i] = 数组[j]
    数组[j] = 临时
}

// 复制列表 已由 基础.nova 提供

函数 是已排序(数组) {
    定义 可变 i = 1
    当 (i < 计数(数组)) {
        如果 (数组[i] < 数组[i - 1]) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 是降序排列(数组) {
    定义 可变 i = 1
    当 (i < 计数(数组)) {
        如果 (数组[i] > 数组[i - 1]) { 返回 假 }
        i = i + 1
    }
    返回 真
}

// 插入排序 (稳定, O(n²), 小数组最优)
函数 排序_插入排序(数组) {
    定义 可变 r = 复制列表(数组)
    定义 可变 n = 计数(r)
    定义 可变 i = 1
    当 (i < n) {
        定义 可变 key = r[i]
        定义 可变 j = i - 1
        当 (j >= 0 且 r[j] > key) {
            r[j + 1] = r[j]
            j = j - 1
        }
        r[j + 1] = key
        i = i + 1
    }
    返回 r
}

// 选择排序 (不稳定, O(n²))
函数 排序_选择排序(数组) {
    定义 可变 r = 复制列表(数组)
    定义 可变 n = 计数(r)
    定义 可变 i = 0
    当 (i < n - 1) {
        定义 可变 最小索引 = i
        定义 可变 j = i + 1
        当 (j < n) {
            如果 (r[j] < r[最小索引]) { 最小索引 = j }
            j = j + 1
        }
        如果 (最小索引 != i) { 交换(r, i, 最小索引) }
        i = i + 1
    }
    返回 r
}

// 冒泡排序 (稳定, O(n²), 带提前终止)
函数 排序_冒泡排序(数组) {
    定义 可变 r = 复制列表(数组)
    定义 可变 n = 计数(r)
    定义 可变 i = 0
    当 (i < n - 1) {
        定义 可变 交换了 = 假
        定义 可变 j = 0
        当 (j < n - 1 - i) {
            如果 (r[j] > r[j + 1]) { 交换(r, j, j + 1)
            交换了 = 真 }
            j = j + 1
        }
        如果 (交换了 == 假) { 返回 r }
        i = i + 1
    }
    返回 r
}

// 快速排序 (不稳定, O(n log n) 平均)
函数 快排_划分(数组, lo, hi) {
    定义 可变 pivot = 数组[hi]
    定义 可变 i = lo
    定义 可变 j = lo
    当 (j < hi) {
        如果 (数组[j] <= pivot) { 交换(数组, i, j)
        i = i + 1 }
        j = j + 1
    }
    交换(数组, i, hi)
    返回 i
}

函数 排序_快排_递归(数组, lo, hi) {
    如果 (lo < hi) {
        定义 可变 p = 快排_划分(数组, lo, hi)
        排序_快排_递归(数组, lo, p - 1)
        排序_快排_递归(数组, p + 1, hi)
    }
}

函数 排序_快速排序(数组) {
    定义 可变 r = 复制列表(数组)
    如果 (计数(r) > 1) { 排序_快排_递归(r, 0, 计数(r) - 1) }
    返回 r
}

// 归并排序 (稳定, O(n log n))
函数 归并_合并(左, 右) {
    定义 可变 结果 = []
    定义 可变 i = 0
    定义 可变 j = 0
    当 (i < 计数(左) 且 j < 计数(右)) {
        如果 (左[i] <= 右[j]) { 追加(结果, 左[i])
        i = i + 1 }
        否则 { 追加(结果, 右[j])
        j = j + 1 }
    }
    当 (i < 计数(左)) { 追加(结果, 左[i])
    i = i + 1 }
    当 (j < 计数(右)) { 追加(结果, 右[j])
    j = j + 1 }
    返回 结果
}

函数 排序_归并排序(数组) {
    如果 (计数(数组) <= 1) { 返回 复制列表(数组) }
    定义 可变 中间值 = 计数(数组) / 2
    定义 可变 左 = []
    定义 可变 右 = []
    定义 可变 i = 0
    当 (i < 中间值) { 追加(左, 数组[i])
    i = i + 1 }
    当 (i < 计数(数组)) { 追加(右, 数组[i])
    i = i + 1 }
    返回 归并_合并(排序_归并排序(左), 排序_归并排序(右))
}

// 堆排序 (不稳定, O(n log n))
函数 排序_堆排序(数组) {
    定义 可变 r = 复制列表(数组)
    定义 可变 n = 计数(r)
    // 建堆
    定义 可变 i = n / 2 - 1
    当 (i >= 0) { 堆_下沉3(r, n, i)
    i = i - 1 }
    // 排序
    定义 可变 末尾 = n - 1
    当 (末尾 > 0) {
        交换(r, 0, 末尾)
        堆_下沉3(r,  末尾, 0)
        末尾 = 末尾 - 1
    }
    返回 r
}

// 计数排序 (稳定, O(n+k), 适合小范围整数)
函数 排序_计数排序(数组, 最小值, 最大值) {
    定义 可变 范围 = 最大值 - 最小值 + 1
    定义 可变 counts = []
    定义 可变 k = 0
    当 (k < 范围) { 追加(counts, 0)
    k = k + 1 }
    定义 可变 i = 0
    当 (i < 计数(数组)) {
        counts[数组[i] - 最小值] = counts[数组[i] - 最小值] + 1
        i = i + 1
    }
    定义 可变 结果 = []
    定义 可变 v = 0
    当 (v < 范围) {
        定义 可变 c = 0
        当 (c < counts[v]) { 追加(结果, v + 最小值)
        c = c + 1 }
        v = v + 1
    }
    返回 结果
}

// 逆序
函数 逆序(数组) {
    定义 可变 r = []
    定义 可变 i = 计数(数组) - 1
    当 (i >= 0) { 追加(r, 数组[i])
    i = i - 1 }
    返回 r
}

// 求逆序数 (衡量无序度)
函数 逆序数(数组) {
    定义 可变 c = 0
    定义 可变 i = 0
    当 (i < 计数(数组)) {
        定义 可变 j = i + 1
        当 (j < 计数(数组)) {
            如果 (数组[i] > 数组[j]) { c = c + 1 }
            j = j + 1
        }
        i = i + 1
    }
    返回 c
}

// 部分排序 (Top-K)
函数 最小K个(数组, k) {
    定义 可变 已排序 = 排序_快速排序(数组)
    定义 可变 r = []
    定义 可变 i = 0
    定义 可变 上限 = k
    如果 (上限 > 计数(已排序)) { 上限 = 计数(已排序) }
    当 (i < 上限) { 追加(r, 已排序[i])
    i = i + 1 }
    返回 r
}

函数 最大K个(数组, k) {
    定义 可变 已排序 = 排序_快速排序(数组)
    定义 可变 r = []
    定义 可变 n = 计数(已排序)
    定义 可变 起始 = n - k
    如果 (起始 < 0) { 起始 = 0 }
    定义 可变 i = 起始
    当 (i < n) { 追加(r, 已排序[i])
    i = i + 1 }
    返回 r
}

// 去重排序
函数 去重排序(数组) {
    定义 可变 已排序 = 排序_快速排序(数组)
    定义 可变 r = []
    定义 可变 i = 0
    当 (i < 计数(已排序)) {
        如果 (计数(r) == 0 或 r[计数(r) - 1] != 已排序[i]) {
            追加(r, 已排序[i])
        }
        i = i + 1
    }
    返回 r
}

// 第K小元素 (快速选择)
函数 快选_划分(数组, lo, hi) {
    定义 可变 pivot = 数组[hi]
    定义 可变 i = lo
    定义 可变 j = lo
    当 (j < hi) {
        如果 (数组[j] <= pivot) { 交换(数组, i, j)
        i = i + 1 }
        j = j + 1
    }
    交换(数组, i, hi)
    返回 i
}

函数 第K小(数组, k) {
    定义 可变 r = 复制列表(数组)
    定义 可变 lo = 0
    定义 可变 hi = 计数(r) - 1
    当 (lo < hi) {
        定义 可变 p = 快选_划分(r, lo, hi)
        如果 (p == k) { 返回 r[p] }
        如果 (p < k) { lo = p + 1 }
        否则 { hi = p - 1 }
    }
    返回 r[lo]
}

// 中位数
函数 中位数(数组) {
    定义 可变 n = 计数(数组)
    如果 (n == 0) { 返回 0 }
    返回 第K小(数组, n / 2)
}

// 范围和(已排序数组前K项和)
函数 排序前K和(数组, k) {
    定义 可变 已排序 = 排序_快速排序(数组)
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < k 且 i < 计数(已排序)) { 总和 = 总和 + 已排序[i]
    i = i + 1 }
    返回 总和
}



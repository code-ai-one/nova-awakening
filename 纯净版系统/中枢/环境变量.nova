// NovaOS · 进程环境变量管理
// §1 环境变量存储 (键值对红黑树/线性表)
// §2 get/set/unset/list 操作
// §3 进程继承 (fork时复制父进程环境)
// §4 系统默认环境变量


结构 环境条目 {
    键,
    值,
}

定义 环境_最大条目 = 256

定义 可变 _全局环境 = []
定义 可变 _环境已初始化 = 假


函数 环境_初始化() {
    如果 (_环境已初始化) { 返回 }
    _全局环境 = []
    // 系统默认环境变量
    环境_设置("PATH", "/usr/bin:/bin:/usr/local/bin")
    环境_设置("HOME", "/root")
    环境_设置("SHELL", "/bin/龙壳")
    环境_设置("LANG", "zh_CN.UTF-8")
    环境_设置("TERM", "nova-256color")
    环境_设置("EDITOR", "龙文")
    环境_设置("NOVA_VERSION", "1.0.0")
    环境_设置("NOVA_ARCH", "x86_64")
    环境_设置("TMPDIR", "/tmp")
    环境_设置("XDG_RUNTIME_DIR", "/run/user/0")
    _环境已初始化 = 真
}

函数 环境_获取(键) {
    定义 可变 i = 0
    当 (i < 计数(_全局环境)) {
        如果 (_全局环境[i].键 == 键) { 返回 _全局环境[i].值 }
        i = i + 1
    }
    返回 空
}

函数 环境_设置(键, 值) {
    // 如果已存在则覆盖
    定义 可变 i = 0
    当 (i < 计数(_全局环境)) {
        如果 (_全局环境[i].键 == 键) {
            _全局环境[i].值 = 值
            返回 0
        }
        i = i + 1
    }
    // 新增
    如果 (计数(_全局环境) >= 环境_最大条目) { 返回 错误_资源不足 }
    定义 条目 = 环境条目 {}
    条目.键 = 键
    条目.值 = 值
    追加(_全局环境, 条目)
    返回 0
}

函数 环境_删除(键) {
    定义 可变 i = 0
    当 (i < 计数(_全局环境)) {
        如果 (_全局环境[i].键 == 键) {
            列表_移除(_全局环境, i)
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 环境_存在(键) {
    返回 环境_获取(键) != 空
}

函数 环境_数量() { 返回 计数(_全局环境) }

函数 环境_列出() {
    定义 可变 列表 = []
    定义 可变 i = 0
    当 (i < 计数(_全局环境)) {
        追加(列表, _全局环境[i].键 + "=" + _全局环境[i].值)
        i = i + 1
    }
    返回 列表
}


函数 环境_复制() {
    // fork时调用: 深拷贝当前环境到子进程
    定义 可变 副本 = []
    定义 可变 i = 0
    当 (i < 计数(_全局环境)) {
        定义 条目 = 环境条目 {}
        条目.键 = _全局环境[i].键
        条目.值 = _全局环境[i].值
        追加(副本, 条目)
        i = i + 1
    }
    返回 副本
}

函数 环境_从副本恢复(副本) {
    _全局环境 = 副本
}


函数 环境_展开路径(路径) {
    // 展开 $HOME, $TMPDIR 等
    定义 可变 结果 = 路径
    定义 可变 i = 0
    当 (i < 计数(_全局环境)) {
        定义 标记 = "$" + _全局环境[i].键
        如果 (字符串包含(结果, 标记)) {
            结果 = 字符串替换(结果, 标记, _全局环境[i].值)
        }
        i = i + 1
    }
    返回 结果
}

函数 环境_查找PATH中(可执行名) {
    定义 路径 = 环境_获取("PATH")
    如果 (路径 == 空) { 返回 空 }
    定义 目录列表 = 字符串分割(路径, ":")
    定义 可变 i = 0
    当 (i < 计数(目录列表)) {
        定义 完整路径 = 目录列表[i] + "/" + 可执行名
        如果 (文件_存在(完整路径)) { 返回 完整路径 }
        i = i + 1
    }
    返回 空
}

函数 环境_报告() {
    定义 可变 r = "═══ 环境变量 ═══\n"
    r = r + "总数: " + 整数转字符串(计数(_全局环境)) + "\n"
    定义 可变 i = 0
    当 (i < 计数(_全局环境)) {
        r = r + "  " + _全局环境[i].键 + "=" + _全局环境[i].值 + "\n"
        i = i + 1
    }
    返回 r
}

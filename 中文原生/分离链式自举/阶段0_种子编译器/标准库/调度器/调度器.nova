导入("../基础.nova")
导入("../数学/基础/数学库.nova")
导入("../数学/工具.nova")



// 学习率调度器
// 常量学习率
函数 LR_常量(基础LR, _步数) { 返回 基础LR }

// 线性预热
函数 LR_线性预热(基础LR, 当前步, 预热步数) {
    如果 (当前步 >= 预热步数) { 返回 基础LR }
    如果 (预热步数 == 0) { 返回 0 }
    返回 基础LR * 当前步 / 预热步数
}

// 阶梯衰减
函数 LR_阶梯(基础LR, 当前epoch, 衰减间隔, 衰减率) {
    定义 衰减次数 = 当前epoch / 衰减间隔
    定义 可变 lr = 基础LR
    定义 可变 i = 0
    当 (i < 衰减次数) { lr = lr * 衰减率 / 100
    i = i + 1 }
    返回 lr
}

// 余弦退火 (近似: 用分段线性代替)
函数 LR_余弦退火(基础LR, 当前步, 总步数, 最小LR) {
    如果 (当前步 >= 总步数) { 返回 最小LR }
    // cos近似: 分4段
    定义 进度 = 当前步 * 100 / 总步数
    定义 可变 cos_factor = 0
    如果 (进度 <= 25) { cos_factor = 100 - 进度 * 2 }
    否则 如果 (进度 <= 50) { cos_factor = 50 - (进度 - 25) * 2 }
    否则 如果 (进度 <= 75) { cos_factor = 0 + (进度 - 50) }
    否则 { cos_factor = 25 - (进度 - 75) }
    如果 (cos_factor < 0) { cos_factor = 0 }
    返回 最小LR + (基础LR - 最小LR) * cos_factor / 100
}

// 多项式衰减
函数 LR_多项式(基础LR, 当前步, 总步数, 幂次, 最终LR) {
    如果 (当前步 >= 总步数) { 返回 最终LR }
    定义 衰减比 = (总步数 - 当前步) * 100 / 总步数
    定义 可变 factor = 衰减比
    定义 可变 p = 1
    当 (p < 幂次) { factor = factor * 衰减比 / 100
    p = p + 1 }
    返回 最终LR + (基础LR - 最终LR) * factor / 100
}

// 梯度缩放 (混合精度)
定义 梯度缩放_因子 = 65536
定义 可变 梯度缩放_连续成功 = 0
定义 可变 梯度缩放_连续溢出 = 0

函数 梯度缩放_乘(梯度) {
    返回 映射(梯度, g => g * 梯度缩放_因子 / 1000)
}

函数 梯度缩放_除(梯度) {
    返回 映射(梯度, g => g * 1000 / 梯度缩放_因子)
}

函数 梯度缩放_检查溢出(梯度) {
    定义 可变 i = 0
    当 (i < 计数(梯度)) {
        如果 (绝对值(梯度[i]) > 1000000) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 梯度缩放_更新(溢出) {
    如果 (溢出) {
        梯度缩放_因子 = 梯度缩放_因子 / 2
        如果 (梯度缩放_因子 < 1) { 梯度缩放_因子 = 1 }
        梯度缩放_连续成功 = 0
        梯度缩放_连续溢出 = 梯度缩放_连续溢出 + 1
    } 否则 {
        梯度缩放_连续成功 = 梯度缩放_连续成功 + 1
        梯度缩放_连续溢出 = 0
        如果 (梯度缩放_连续成功 >= 10) {
            梯度缩放_因子 = 梯度缩放_因子 * 2
            梯度缩放_连续成功 = 0
        }
    }
}

// 优化器状态管理
// 状态: [参数列表, 一阶动量, 二阶动量, 步数]
函数 优化器状态_创建(参数数) {
    定义 可变 m = []
    定义 可变 v = []
    定义 可变 i = 0
    当 (i < 参数数) { 追加(m, 0)
    追加(v, 0)
    i = i + 1 }
    返回 [m, v, 0]
}

函数 优化器_步进(状态, 梯度, _lr, beta1, beta2) {
    状态[2] = 状态[2] + 1
    定义 可变 i = 0
    当 (i < 计数(梯度)) {
        状态[0][i] = (beta1 * 状态[0][i] + (100 - beta1) * 梯度[i]) / 100
        状态[1][i] = (beta2 * 状态[1][i] + (100 - beta2) * 梯度[i] * 梯度[i] / 100) / 100
        i = i + 1
    }
}

// 指数衰减
函数 LR_指数衰减(基础LR, 当前epoch, 衰减率) {
    定义 可变 lr = 基础LR
    定义 可变 i = 0
    当 (i < 当前epoch) { lr = lr * 衰减率 / 100
    i = i + 1 }
    返回 lr
}

// 余弦重启
函数 LR_余弦重启(基础LR, 当前步, 周期长度, 最小LR) {
    定义 在周期内 = 当前步 % 周期长度
    返回 LR_余弦退火(基础LR, 在周期内, 周期长度, 最小LR)
}

// 线性衰减
函数 LR_线性衰减(基础LR, 当前步, 总步数, 最终LR) {
    如果 (当前步 >= 总步数) { 返回 最终LR }
    如果 (总步数 == 0) { 返回 0 }
    返回 基础LR - (基础LR - 最终LR) * 当前步 / 总步数
}

// 预热+衰减

函数 LR_预热线性(基础LR, 当前步, 预热步数, 总步数, 最终LR) {
    如果 (当前步 < 预热步数) {
        如果 (预热步数 == 0) { 返回 0 }
        返回 基础LR * 当前步 / 预热步数
    }
    定义 衰减步 = 当前步 - 预热步数
    定义 衰减总 = 总步数 - 预热步数
    返回 LR_线性衰减(基础LR, 衰减步, 衰减总, 最终LR)
}

函数 LR_预热余弦(基础LR, 当前步, 预热步数, 总步数, 最终LR) {
    如果 (当前步 < 预热步数) {
        返回 基础LR * 当前步 / 预热步数
    }
    定义 衰减步 = 当前步 - 预热步数
    定义 衰减总 = 总步数 - 预热步数
    返回 LR_余弦退火(基础LR, 衰减步, 衰减总, 最终LR)
}

// 多项式衰减

函数 LLR_多项式衰减(基础LR, 当前步, 总步数, 最终LR, 幂) {
    如果 (当前步 >= 总步数) { 返回 最终LR }
    定义 比率 = (总步数 - 当前步) * 1000 / 总步数
    // 近似幂运算
    定义 可变 结果 = 比率
    定义 可变 p = 1
    当 (p < 幂) { 结果 = 结果 * 比率 / 1000  p = p + 1 }
    返回 最终LR + (基础LR - 最终LR) * 结果 / 1000
}

// 阶梯衰减

函数 LR_阶梯衰减(基础LR, 当前步, 步长, 衰减因子) {
    定义 阶数 = 当前步 / 步长
    定义 可变 lr = 基础LR
    定义 可变 i = 0
    当 (i < 阶数) { lr = lr * 衰减因子 / 1000  i = i + 1 }
    返回 lr
}

函数 LR_多阶梯(基础LR, 当前步, 里程碑列表, 衰减因子) {
    定义 可变 lr = 基础LR
    定义 可变 i = 0
    当 (i < 计数(里程碑列表)) {
        如果 (当前步 >= 里程碑列表[i]) { lr = lr * 衰减因子 / 1000 }
        i = i + 1
    }
    返回 lr
}

// 梯度裁剪

函数 调度_梯度裁剪(梯度列表, 最大范数) {
    定义 可变 范数平方 = 0
    // 计算L2范数
    定义 可变 i = 0
    当 (i < 计数(梯度列表)) {
        范数平方 = 范数平方 + 梯度列表[i] * 梯度列表[i]
        i = i + 1
    }
    // 简化平方根
    定义 可变 范数 = 1
    定义 可变 试 = 范数平方
    定义 可变 迭代 = 0
    当 (迭代 < 20) {
        如果 (试 <= 0) { 范数 = 0  迭代 = 20 }
        否则 { 范数 = (范数 + 试 / 范数) / 2  试 = 范数平方  迭代 = 迭代 + 1 }
    }
    如果 (范数 <= 最大范数) { 返回 梯度列表 }
    // 缩放
    定义 可变 结果 = []
    i = 0
    当 (i < 计数(梯度列表)) {
        追加(结果, 梯度列表[i] * 最大范数 / (范数 + 1))
        i = i + 1
    }
    返回 结果
}

函数 梯度_值裁剪(梯度列表, 最大值) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(梯度列表)) {
        定义 可变 v = 梯度列表[i]
        如果 (v > 最大值) { v = 最大值 }
        如果 (v < 0 - 最大值) { v = 0 - 最大值 }
        追加(结果, v)
        i = i + 1
    }
    返回 结果
}

// 指数移动平均

函数 EEMA_创建(参数列表, 衰减率) {
    定义 可变 影子 = []
    定义 可变 i = 0
    当 (i < 计数(参数列表)) { 追加(影子, 参数列表[i])  i = i + 1 }
    返回 [影子, 衰减率, 0]
    // [影子参数, 衰减率, 更新次数]
}

函数 调度_EMA_更新(ema, 参数列表) {
    定义 衰减 = ema[1]
    定义 可变 i = 0
    当 (i < 计数(参数列表) 且 i < 计数(ema[0])) {
        ema[0][i] = 衰减 * ema[0][i] / 1000 + (1000 - 衰减) * 参数列表[i] / 1000
        i = i + 1
    }
    ema[2] = ema[2] + 1
}

函数 调度器_EMA_获取(ema) { 返回 ema[0] }

// 早停机制

函数 调度器_早停_创建(耐心值) {
    返回 [耐心值, 0, 999999, 0]
    // [耐心值, 当前等待, 最佳损失, 最佳轮次]
}

函数 调度_早停_检查(早停, 当前损失, 当前轮次) {
    如果 (当前损失 < 早停[2]) {
        早停[2] = 当前损失
        早停[3] = 当前轮次
        早停[1] = 0
        返回 假
    }
    早停[1] = 早停[1] + 1
    返回 早停[1] >= 早停[0]
}

函数 早停_最佳轮次(早停) { 返回 早停[3] }
函数 早停_最佳损失(早停) { 返回 早停[2] }

// 损失历史

定义 可变 _训练_损失历史 = []

函数 训练_记录损失(损失) { 追加(_训练_损失历史, 损失) }

函数 训练_平均损失(最近n) {
    如果 (计数(_训练_损失历史) == 0) { 返回 0 }
    定义 可变 总 = 0
    定义 可变 数 = 0
    定义 可变 i = 计数(_训练_损失历史) - 1
    当 (i >= 0 且 数 < 最近n) {
        总 = 总 + _训练_损失历史[i]
        数 = 数 + 1
        i = i - 1
    }
    如果 (数 == 0) { 返回 0 }
    返回 总 / 数
}

函数 训练_损失趋势() {
    定义 n = 计数(_训练_损失历史)
    如果 (n < 10) { 返回 0 }
    定义 前半 = 训练_平均损失(n / 2)
    定义 后半均 = _训练_损失历史[n - 1]
    如果 (后半均 < 前半) { 返回 -1 }  // 下降
    如果 (后半均 > 前半) { 返回 1 }   // 上升
    返回 0
}

定义 可变 _调度_步数 = 0
定义 可变 _调度_LR变更数 = 0
定义 可变 _调度_裁剪数 = 0

函数 调度_记录步() { _调度_步数 = _调度_步数 + 1 }
函数 调度_记录LR变更() { _调度_LR变更数 = _调度_LR变更数 + 1 }
函数 调度_记录裁剪() { _调度_裁剪数 = _调度_裁剪数 + 1 }


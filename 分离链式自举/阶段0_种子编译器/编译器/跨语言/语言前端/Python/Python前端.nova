// Nova · 跨语言语言前端 · Python
// 职责: 解析Python源文件骨架,提取class/def/import信息
// 层级: 跨语言主线第4步 — 语言骨架解析(Python)
// 注意: eval/exec/monkey-patch为高风险,归入阻塞项

导入("../../../../标准库/基础.nova")
导入("../../统一语义/统一语义图.nova")

定义 Py声明_函数    = 0
定义 Py声明_类      = 1
定义 Py声明_导入    = 2
定义 Py声明_全局变量 = 3
定义 Py声明_装饰器  = 4

函数 Py声明_创建(类型, 名称) {
    返回 [类型, 名称, 0, []]
}

函数 Py模块_创建(路径) {
    返回 [路径, [], [], [], []]
}

函数 Py模块_声明(m) { 返回 m[1] }
函数 Py模块_导入(m) { 返回 m[2] }
函数 Py模块_风险(m) { 返回 m[4] }

函数 Py前端_解析骨架(源码, 文件路径) {
    定义 模块 = Py模块_创建(文件路径)
    定义 可变 位置 = 0
    定义 总长 = 字节长度(源码)
    定义 可变 行号 = 1

    当 (位置 < 总长) {
        当 (行尾 < 总长 且 字节取(源码, 行尾) != 字符_换行) { 行尾 = 行尾 + 1 }
        定义 行 = 子串(源码, 位置, 行尾 - 位置)
        位置 = 行尾 + 1
        定义 已裁剪 = _Py_去首空白(行)

        如果 (_Py_行开头(已裁剪, "def ")) {
            定义 名 = _Py_提取函数名(已裁剪)
            定义 声明 = Py声明_创建(Py声明_函数, 名)
            声明[2] = 行号
            追加(模块[1], 声明)
        }
        如果 (_Py_行开头(已裁剪, "class ")) {
            定义 名 = _Py_提取类名(已裁剪)
            定义 声明 = Py声明_创建(Py声明_类, 名)
            声明[2] = 行号
            追加(模块[1], 声明)
        }
        如果 (_Py_行开头(已裁剪, "import ") 或 _Py_行开头(已裁剪, "from ")) {
            追加(模块[2], 已裁剪)
        }
        如果 (_Py_行开头(已裁剪, "@")) {
            追加(模块[1], Py声明_创建(Py声明_装饰器, 已裁剪))
        }
        // 高风险检测
        如果 (_Py_含(已裁剪, "eval(") 或 _Py_含(已裁剪, "exec(") 或 _Py_含(已裁剪, "__导入__") 或 _Py_含(已裁剪, "setattr(")) {
            追加(模块[4], [行号, 已裁剪])
        }

        行号 = 行号 + 1
    }
    返回 模块
}

函数 Py前端_到语义图(模块, 语义图) {
    定义 可变 i = 0
    当 (i < 计数(模块[1])) {
        定义 d = 模块[1][i]
        定义 节点 = 语义节点_创建(0, d[0], d[1])
        语义节点_设源位置(节点, 模块[0])
        语义图_添加节点(语义图, 节点)
        i = i + 1
    }
    // 风险项
    i = 0
    当 (i < 计数(模块[4])) {
        语义图_标记风险(语义图, 字符串拼接("Python动态高风险: 行", 转字符串(模块[4][i][0])), 2)
        i = i + 1
    }
}

函数 Py模块_打印(模块) {
    打印文本(字符串拼接("═══ Python模块: ", 模块[0]))
    打印文本(字符串拼接("  声明数: ", 转字符串(计数(模块[1]))))
    打印文本(字符串拼接("  导入数: ", 转字符串(计数(模块[2]))))
    打印文本(字符串拼接("  高风险项: ", 转字符串(计数(模块[4]))))
}

函数 _Py_去首空白(s) {
    定义 可变 i = 0
    定义 l = 字节长度(s)
    当 (i < l 且 (字节取(s, i) == 字符_空格 或 字节取(s, i) == 字符_制表)) { i = i + 1 }
    如果 (i >= l) { 返回 "" }
    返回 子串(s, i, l - i)
}

函数 _Py_行开头(行, 前缀) {
    定义 pl = 字节长度(前缀)
    如果 (字节长度(行) < pl) { 返回 假 }
    返回 子串(行, 0, pl) == 前缀
}

函数 _Py_含(s, 子串) {
    定义 sl = 字节长度(s)
    定义 pl = 字节长度(子串)
    如果 (pl > sl) { 返回 假 }
    定义 可变 i = 0
    当 (i <= sl - pl) {
        如果 (子串(s, i, pl) == 子串) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 _Py_提取函数名(行) {
    定义 可变 位置 = 4
    定义 l = 字节长度(行)
    定义 起 = 位置
    当 (位置 < l 且 字节取(行, 位置) != 字符_左圆括 且 字节取(行, 位置) != 字符_空格) { 位置 = 位置 + 1 }
    如果 (位置 > 起) { 返回 子串(行, 起, 位置 - 起) }
    返回 "anonymous"
}

函数 _Py_提取类名(行) {
    定义 可变 位置 = 6
    定义 l = 字节长度(行)
    定义 起 = 位置
    当 (位置 < l 且 字节取(行, 位置) != 字符_左圆括 且 字节取(行, 位置) != 字符_冒号 且 字节取(行, 位置) != 字符_空格) { 位置 = 位置 + 1 }
    如果 (位置 > 起) { 返回 子串(行, 起, 位置 - 起) }
    返回 "unknown"
}

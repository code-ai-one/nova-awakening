导入("../中枢/中断表注册处.nova")
导入("../引导/端口输入.nova")
导入("../中枢/虚拟内存管理.nova")

//   1. MMIO: 设备寄存器映射到物理内存地址空间
//   2. volatile语义: 每次必须真正读写, 不被编译器优化
//   3. 内存屏障: MMIO读写需要严格有序(防CPU乱序)
//   4. readl/writel: Linux标准MMIO访问宏(带屏障)
//   5. ioread/iowrite: 统一端口IO和MMIO的接口
// 注意: 端口I/O(in/out)在 架构/x86_64/端口IO.nova

// 基础MMIO读写 
// 每次读写都带内存屏障, 保证设备寄存器访问有序

外部 映射页面
外部 取消映射页面
函数 MMIO读8(地址) {
    定义 值 = 内存读8(地址)
    内存屏障_读()     // rmb: 保证读操作顺序
    返回 值
}

函数 MMIO读16(地址) {
    定义 值 = 内存读16(地址)
    内存屏障_读()
    返回 值
}

函数 MMIO读32(地址) {
    定义 值 = 内存读32(地址)
    内存屏障_读()
    返回 值
}

函数 MMIO读64(地址) {
    定义 值 = 内存读64(地址)
    内存屏障_读()
    返回 值
}

函数 MMIO写8(地址, 值) {
    内存屏障_写()     // wmb: 保证之前的写已完成
    内存写8(地址, 值)
}

函数 MMIO写16(地址, 值) {
    内存屏障_写()
    内存写16(地址, 值)
}

函数 MMIO写32(地址, 值) {
    内存屏障_写()
    内存写32(地址, 值)
}

函数 MMIO写64(地址, 值) {
    内存屏障_写()
    内存写64(地址, 值)
}

// 无屏障版本 
// 性能敏感路径使用, 调用者自行保证顺序

函数 MMIO_raw读32(地址)       { 返回 内存读32(地址) }
函数 MMIO_raw写32(地址, 值)   { 内存写32(地址, 值) }

// ioread/iowrite: 统一端口IO和MMIO 
// 根据地址范围自动选择端口IO或MMIO

定义 IO_SPACE_LIMIT = 0xFFFF   // 端口IO地址上限

函数 ioread8(地址) {
    如果 (地址 <= IO_SPACE_LIMIT) { 返回 端口读8(地址) }
    返回 MMIO读8(地址)
}

函数 ioread16(地址) {
    如果 (地址 <= IO_SPACE_LIMIT) { 返回 端口读16(地址) }
    返回 MMIO读16(地址)
}

函数 ioread32(地址) {
    如果 (地址 <= IO_SPACE_LIMIT) { 返回 端口读32(地址) }
    返回 MMIO读32(地址)
}

函数 iowrite8(地址, 值) {
    如果 (地址 <= IO_SPACE_LIMIT) { 端口写8(地址, 值); 返回 }
    MMIO写8(地址, 值)
}

函数 iowrite16(地址, 值) {
    如果 (地址 <= IO_SPACE_LIMIT) { 端口写16(地址, 值); 返回 }
    MMIO写16(地址, 值)
}

函数 iowrite32(地址, 值) {
    如果 (地址 <= IO_SPACE_LIMIT) { 端口写32(地址, 值); 返回 }
    MMIO写32(地址, 值)
}

// 内存屏障 
// x86上大部分MMIO天然有序, 但仍需编译器屏障

函数 内存屏障_读()  { 内联汇编("lfence") }
函数 内存屏障_写()  { 内联汇编("sfence") }
函数 内存屏障_全()  { 内联汇编("mfence") }

函数 IO原语_暂停() { 内联汇编("pause") }

函数 IO原语_读取时间戳计数() {
    返回 内联汇编_返回值("rdtsc")
}

函数 IO原语_延迟微秒(微秒) {
    如果 (微秒 <= 0) { 返回 }
    定义 目标滴答 = 微秒 * 2000
    定义 开始 = IO原语_读取时间戳计数()
    当 (IO原语_读取时间戳计数() - 开始 < 目标滴答) {
        IO原语_暂停()
    }
}

函数 IO原语_延迟毫秒(毫秒) {
    如果 (毫秒 <= 0) { 返回 }
    定义 可变 i = 0
    当 (i < 毫秒) {
        IO原语_延迟微秒(1000)
        i = i + 1
    }
}

// 批量MMIO 

函数 memcpy_fromio(目标, IO地址, 长度) {
    定义 可变 i = 0
    当 (i < 长度) {
        内存写8(目标 + i, MMIO读8(IO地址 + i))
        i = i + 1
    }
}

函数 memcpy_toio(IO地址, 源, 长度) {
    定义 可变 i = 0
    当 (i < 长度) {
        MMIO写8(IO地址 + i, 内存读8(源 + i))
        i = i + 1
    }
}

函数 memset_io(IO地址, 值, 长度) {
    定义 可变 i = 0
    当 (i < 长度) {
        MMIO写8(IO地址 + i, 值)
        i = i + 1
    }
}

// ioremap / iounmap 
// 将物理MMIO地址映射到内核虚拟地址空间

定义 可变 ioremap_下一个虚拟地址 = 0xFFFF_8000_0000_0000  // 高半区

函数 IO原语_ioremap(物理地址, 大小) {
    // 分配虚拟地址并建立不可缓存映射
    定义 虚拟地址 = ioremap_下一个虚拟地址
    定义 页数 = (大小 + 4095) / 4096
    ioremap_下一个虚拟地址 = ioremap_下一个虚拟地址 + 页数 * 4096

    // 建立页表映射(UC, 不可缓存)
    定义 可变 i = 0
    当 (i < 页数) {
        映射页面(虚拟地址 + i * 4096, 物理地址 + i * 4096, 0x13)  // PTE_PRESENT|PTE_RW|PTE_PCD
        i = i + 1
    }
    返回 虚拟地址
}

函数 IO原语_iounmap(虚拟地址, 大小) {
    定义 页数 = (大小 + 4095) / 4096
    定义 可变 i = 0
    当 (i < 页数) {
        取消映射页面(虚拟地址 + i * 4096)
        i = i + 1
    }
}

函数 ioremap_wc(物理地址, 大小) {
    // Write-Combining映射 (用于帧缓冲等)
    定义 虚拟地址 = ioremap_下一个虚拟地址
    定义 页数 = (大小 + 4095) / 4096
    ioremap_下一个虚拟地址 = ioremap_下一个虚拟地址 + 页数 * 4096
    定义 可变 i = 0
    当 (i < 页数) {
        映射页面(虚拟地址 + i * 4096, 物理地址 + i * 4096, 0x1B)  // PTE_PRESENT|PTE_RW|PTE_PWT|PTE_PCD
        i = i + 1
    }
    返回 虚拟地址
}

// 批量32位MMIO读写 (性能优化)

函数 ioread32_rep(地址, 目标, 数量) {
    定义 可变 i = 0
    当 (i < 数量) {
        内存写32(目标 + i * 4, ioread32(地址))
        i = i + 1
    }
}

函数 iowrite32_rep(地址, 源, 数量) {
    定义 可变 i = 0
    当 (i < 数量) {
        iowrite32(地址, 内存读32(源 + i * 4))
        i = i + 1
    }
}

// IO类型名称 + ioremap统计

定义 可变 ioremap_映射数 = 0

函数 IO_类型名(地址) {
    如果 (地址 <= IO_SPACE_LIMIT) { 返回 "PIO" }
    返回 "MMIO"
}

函数 ioremap_统计() {
    返回 [ioremap_映射数, ioremap_下一个虚拟地址]
}


函数 IO原语_完整统计() {
    返回 [IO_读次数, IO_写次数]
}

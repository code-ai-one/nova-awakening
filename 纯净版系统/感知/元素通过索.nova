// §4 get元素ById — 通过id索引O(1)查找
// (对应 TreeOrderedMap)

函数 Document_get元素ById(文档, id字符串) {
 // DOM spec: document.get元素ById(id)
 定义 扩展 = Document_获取扩展(文档)
 如果 (扩展 == 0) { 返回 0 }

 定义 id原子 = 原子_驻留(id字符串)

 // 在id索引中查找 (线性探测哈希表)
 定义 哈希 = id原子 % 扩展.id索引_容量
 定义 可变 探测 = 哈希
 定义 可变 已探测 = 0
 当 (已探测 < 扩展.id索引_容量) {
 定义 键偏移 = 探测 * 4
 定义 值偏移 = 探测 * 8
 定义 键 = 内存_读32(扩展.id索引_键 + 键偏移)
 如果 (键 == 0) { 返回 0 } // 空槽 = 没找到
 如果 (键 == id原子) {
 返回 内存_读64(扩展.id索引_值 + 值偏移)
 }
 探测 = (探测 + 1) % 扩展.id索引_容量
 已探测 = 已探测 + 1
 }
 返回 0
}

函数 Document_更新id索引(文档, 元素, 旧id, 新id) {
 // 由元素_属性变更回调调用
 定义 扩展 = Document_获取扩展(文档)
 如果 (扩展 == 0) { 返回 }

 // 移除旧id索引
 如果 (旧id != 0) {
 定义 旧原子 = 原子_驻留(旧id)
 Document_id索引_移除(扩展, 旧原子)
 }

 // 添加新id索引
 如果 (新id != 0) {
 定义 新原子 = 原子_驻留(新id)
 Document_id索引_插入(扩展, 新原子, 元素)
 }
}

函数 Document_id索引_插入(扩展, id原子, 元素) {
 // 扩容检查 (负载因子 > 0.7)
 如果 (扩展.id索引_数量 * 10 > 扩展.id索引_容量 * 7) {
 Document_id索引_扩容(扩展)
 }

 定义 哈希 = id原子 % 扩展.id索引_容量
 定义 可变 探测 = 哈希
 当 (1) {
 定义 键偏移 = 探测 * 4
 定义 键 = 内存_读32(扩展.id索引_键 + 键偏移)
 如果 (键 == 0 || 键 == id原子) {
 内存_写32(扩展.id索引_键 + 键偏移, id原子)
 内存_写64(扩展.id索引_值 + 探测 * 8, 元素)
 如果 (键 == 0) {
 扩展.id索引_数量 = 扩展.id索引_数量 + 1
 }
 返回
 }
 探测 = (探测 + 1) % 扩展.id索引_容量
 }
}

函数 Document_id索引_移除(扩展, id原子) {
 定义 哈希 = id原子 % 扩展.id索引_容量
 定义 可变 探测 = 哈希
 定义 可变 已探测 = 0
 当 (已探测 < 扩展.id索引_容量) {
 定义 键偏移 = 探测 * 4
 定义 键 = 内存_读32(扩展.id索引_键 + 键偏移)
 如果 (键 == 0) { 返回 }
 如果 (键 == id原子) {
 内存_写32(扩展.id索引_键 + 键偏移, 0)
 内存_写64(扩展.id索引_值 + 探测 * 8, 0)
 扩展.id索引_数量 = 扩展.id索引_数量 - 1
 返回
 }
 探测 = (探测 + 1) % 扩展.id索引_容量
 已探测 = 已探测 + 1
 }
}

函数 Document_id索引_扩容(扩展) {
 定义 旧容量 = 扩展.id索引_容量
 定义 旧键 = 扩展.id索引_键
 定义 旧值 = 扩展.id索引_值

 扩展.id索引_容量 = 旧容量 * 2
 扩展.id索引_键 = 堆_分配_数组(扩展.id索引_容量 * 4)
 扩展.id索引_值 = 堆_分配_数组(扩展.id索引_容量 * 8)
 扩展.id索引_数量 = 0

 // 重新插入所有条目
 定义 可变 i = 0
 当 (i < 旧容量) {
 定义 键 = 内存_读32(旧键 + i * 4)
 如果 (键 != 0) {
 定义 值 = 内存_读64(旧值 + i * 8)
 Document_id索引_插入(扩展, 键, 值)
 }
 i = i + 1
 }
 堆_释放(旧键)
 堆_释放(旧值)
}

// Nova · IR层 · Nova-Bytecode 编码器
// 语法树 → Nova-Bytecode 翻译器
// 将语法树节点编译为平台无关的字节码指令

导入("指令集.nova")
导入("../元信息/调试映射.nova")
导入("../../标准库/基础.nova")
导入("../../编译器/规划/核心/常量.nova")

// 编码上下文
// [字节码块, 局部变量表, 局部变量数, 作用域深度, 循环栈, 函数名]
函数 Nova编码_创建上下文(块) {
    返回 [块, 字典(), 0, [], "__主程序__"]
}

函数 Nova编码_当前块(ctx) { 返回 ctx[0] }
函数 Nova编码_变量表(ctx) { 返回 ctx[1] }
函数 Nova编码_变量数(ctx) { 返回 ctx[2] }
函数 Nova编码_函数名(ctx) { 返回 ctx[5] }

// 变量管理
函数 Nova编码_声明局部(ctx, 名称) {
    定义 索引 = ctx[2]
    字典设置(ctx[1], 名称, 索引)
    ctx[2] = ctx[2] + 1
    返回 索引
}

函数 Nova编码_查找局部(ctx, 名称) {
    定义 结果 = 字典获取(ctx[1], 名称)
    如果 (结果 != 空) { 返回 结果 }
    返回 -1
}

// 表达式编码
函数 Nova编码_处理_102(ctx, 节点) {
    定义 块 = Nova编码_当前块(ctx)
    定义 名称 = 节点[1]
    // 布尔字面量特殊处理
    如果 (名称 == "真") { Nova字节码_发射(块, 指令_压入真) 返回 }
    如果 (名称 == "假") { Nova字节码_发射(块, 指令_压入假) 返回 }
    如果 (名称 == "空") { Nova字节码_发射(块, 指令_压入空) 返回 }
    定义 局部 = Nova编码_查找局部(ctx, 名称)
    如果 (局部 >= 0) {
        Nova字节码_发射16(块, 指令_载局部, 局部)
    } 否则 {
        定义 全局索引 = Nova字节码_添加常量(块, 名称)
        Nova字节码_发射16(块, 指令_载全局, 全局索引)
    }
    返回
}

函数 Nova编码_处理_104(ctx, 节点) {
    定义 块 = Nova编码_当前块(ctx)
    // 短路求值: && 和 ||
    定义 op = 节点[1]
    如果 (op == "&&") {
        Nova编码_表达式(ctx, 节点[2])
        定义 跳位 = Nova字节码_代码大小(块)
        Nova字节码_发射16(块,  指令_假跳, 0)
        Nova字节码_发射(块, 指令_弹出)
        Nova编码_表达式(ctx, 节点[3])
        定义 代码 = 块[4]
        代码[跳位 + 1] = Nova字节码_代码大小(块) & 0xFF
        代码[跳位 + 2] = (Nova字节码_代码大小(块) >> 8) & 0xFF
        返回
    }
    如果 (op == "||") {
        Nova编码_表达式(ctx, 节点[2])
        定义 跳位 = Nova字节码_代码大小(块)
        Nova字节码_发射16(块,  指令_真跳, 0)
        Nova字节码_发射(块, 指令_弹出)
        Nova编码_表达式(ctx, 节点[3])
        定义 代码 = 块[4]
        代码[跳位 + 1] = Nova字节码_代码大小(块) & 0xFF
        代码[跳位 + 2] = (Nova字节码_代码大小(块) >> 8) & 0xFF
        返回
    }
    Nova编码_表达式(ctx, 节点[2])
    Nova编码_表达式(ctx, 节点[3])
    如果 (op == "+") { Nova字节码_发射(块, 指令_加) }
    否则 如果 (op == "-") { Nova字节码_发射(块, 指令_减) }
    否则 如果 (op == "*") { Nova字节码_发射(块, 指令_乘) }
    否则 如果 (op == "/") { Nova字节码_发射(块, 指令_除) }
    否则 如果 (op == "%") { Nova字节码_发射(块, 指令_余) }
    否则 如果 (op == "==") { Nova字节码_发射(块, 指令_比等) }
    否则 如果 (op == "!=") { Nova字节码_发射(块, 指令_比不等) }
    否则 如果 (op == "<") { Nova字节码_发射(块, 指令_比小) }
    否则 如果 (op == "<=") { Nova字节码_发射(块, 指令_比小等) }
    否则 如果 (op == ">") { Nova字节码_发射(块, 指令_比大) }
    否则 如果 (op == ">=") { Nova字节码_发射(块, 指令_比大等) }
    否则 如果 (op == "&") { Nova字节码_发射(块, 指令_位与) }
    否则 如果 (op == "|") { Nova字节码_发射(块, 指令_位或) }
    否则 如果 (op == "^") { Nova字节码_发射(块, 指令_位异或) }
    否则 如果 (op == "<<") { Nova字节码_发射(块, 指令_左移) }
    否则 如果 (op == ">>") { Nova字节码_发射(块, 指令_右移) }
    返回
}

函数 Nova编码_处理_103(ctx, 节点) {
    定义 块 = Nova编码_当前块(ctx)
    定义 函数名 = 节点[1]
    定义 参数列 = 节点[2]
    如果 (参数列 == 空 或 是列表(参数列) == 假) { 参数列 = [] }
    // 内建打印优化: 直接发射 指令_打印
    如果 (函数名 == "打印" 且 计数(参数列) == 1) {
        Nova编码_表达式(ctx, 参数列[0])
        Nova字节码_发射(块, 指令_打印)
        返回
    }
    // 内建转字符串优化: 直接发射 指令_转字串
    如果 (函数名 == "转字符串" 且 计数(参数列) == 1) {
        Nova编码_表达式(ctx, 参数列[0])
        Nova字节码_发射(块, 指令_转字串)
        返回
    }
    // 内建计数优化: 直接发射 指令_长度
    如果 (函数名 == "计数" 且 计数(参数列) == 1) {
        Nova编码_表达式(ctx, 参数列[0])
        Nova字节码_发射(块, 指令_长度)
        返回
    }
    // 通用函数调用: 编码所有参数 → 指令_调用
    定义 可变 i = 0
    当 (i < 计数(参数列)) {
        Nova编码_表达式(ctx, 参数列[i])
        i = i + 1
    }
    定义 函数索引 = Nova字节码_添加常量(块, 函数名)
    Nova字节码_发射16(块, 指令_调用, 函数索引)
    追加(块[4], 计数(参数列) & 0xFF)
    返回
}

函数 Nova编码_处理_105(ctx, 节点) {
    定义 块 = Nova编码_当前块(ctx)
    定义 元素 = 节点[1]
    如果 (元素 == 空 或 是列表(元素) == 假) { 元素 = [] }
    定义 可变 i = 0
    当 (i < 计数(元素)) {
        Nova编码_表达式(ctx, 元素[i])
        i = i + 1
    }
    Nova字节码_发射8(块, 指令_建列表, 计数(元素))
    返回
}

// 新建结构体 [130, name, field_pairs]
函数 Nova编码_处理_130(ctx, 节点) {
    定义 块 = Nova编码_当前块(ctx)
    定义 名称索引 = Nova字节码_添加常量(块, 节点[1])
    Nova字节码_发射16(块, 指令_建结构, 名称索引)
    如果 (计数(节点) > 2 且 节点[2] != 空 且 是列表(节点[2])) {
        定义 字段列 = 节点[2]
        定义 可变 i = 0
        当 (i < 计数(字段列)) {
            定义 对 = 字段列[i]
            如果 (是列表(对) 且 计数(对) >= 2) {
                Nova字节码_发射(块, 指令_复制)
                Nova编码_表达式(ctx, 对[1])
                定义 字段索引 = Nova字节码_添加常量(块, 对[0])
                Nova字节码_发射16(块, 指令_设字段, 字段索引)
            }
            i = i + 1
        }
    }
    返回
}

// 间接调用 [140, func_expr, args_list]
函数 Nova编码_处理_140(ctx, 节点) {
    定义 块 = Nova编码_当前块(ctx)
    定义 参数列 = 节点[2]
    如果 (参数列 == 空 或 是列表(参数列) == 假) { 参数列 = [] }
    定义 可变 i = 0
    当 (i < 计数(参数列)) {
        Nova编码_表达式(ctx, 参数列[i])
        i = i + 1
    }
    Nova编码_表达式(ctx, 节点[1])
    Nova字节码_发射8(块, 指令_间接调用, 计数(参数列))
    返回
}

// 字典字面量 [151, kv_pairs]
函数 Nova编码_处理_151(ctx, 节点) {
    定义 块 = Nova编码_当前块(ctx)
    Nova字节码_发射16(块,  指令_建字典, 0)
    如果 (计数(节点) > 1 且 节点[1] != 空 且 是列表(节点[1])) {
        定义 对列 = 节点[1]
        定义 可变 i = 0
        当 (i < 计数(对列)) {
            定义 对 = 对列[i]
            如果 (是列表(对) 且 计数(对) >= 2) {
                Nova字节码_发射(块, 指令_复制)
                Nova编码_表达式(ctx, 对[0])
                Nova编码_表达式(ctx, 对[1])
                Nova字节码_发射(块, 指令_设字典)
            }
            i = i + 1
        }
    }
    返回
}

函数 Nova编码_表达式(ctx, 节点) {
    如果 (节点 == 空 或 是列表(节点) == 假 或 计数(节点) < 1) { 返回 }
    定义 块 = Nova编码_当前块(ctx)
    定义 类型 = 节点[0]

    // 整数字面量 [100, value]
    如果 (类型 == 节_整数) {
        Nova字节码_发射64(块, 指令_压入整数, 节点[1])
        返回
    }

    // 浮点字面量 [150, value]
    如果 (类型 == 节_浮点) {
        Nova字节码_发射64(块, 指令_压入浮点, 节点[1])
        返回
    }

    // 字符串字面量 [101, string]
    如果 (类型 == 节_字符串) {
        定义 索引 = Nova字节码_添加常量(块, 节点[1])
        Nova字节码_发射16(块, 指令_压入字串, 索引)
        返回
    }

    // 标识符/变量读取 [102, name]
    如果 (类型 == 节_标识符) {
        Nova编码_处理_102(ctx, 节点)
        返回
    }

    // 函数调用 [103, name, args_list]
    如果 (类型 == 节_调用) {
        Nova编码_处理_103(ctx, 节点)
        返回
    }

    // 二元运算 [104, op, left, right]
    如果 (类型 == 节_二元) {
        Nova编码_处理_104(ctx, 节点)
        返回
    }

    // 列表字面量 [105, elements]
    如果 (类型 == 节_列表) {
        Nova编码_处理_105(ctx, 节点)
        返回
    }

    // 索引访问 [106, object, index]
    如果 (类型 == 节_索引) {
        Nova编码_表达式(ctx, 节点[1])
        Nova编码_表达式(ctx, 节点[2])
        Nova字节码_发射(块, 指令_取索引)
        返回
    }

    // 新建结构体 [130, name, field_pairs]
    如果 (类型 == 节_新建) {
        Nova编码_处理_130(ctx, 节点)
        返回
    }

    // 点访问 [131, object, field_name]
    如果 (类型 == 节_点访问) {
        Nova编码_表达式(ctx, 节点[1])
        定义 字段索引 = Nova字节码_添加常量(块, 节点[2])
        Nova字节码_发射16(块, 指令_取字段, 字段索引)
        返回
    }

    // 匿名函数 [133, name, ...]
    如果 (类型 == 节_匿名函数) {
        定义 闭包索引 = Nova字节码_添加常量(块, 节点[1])
        Nova字节码_发射16(块, 指令_闭包, 闭包索引)
        返回
    }

    // 逻辑非 [138, operand]
    如果 (类型 == 节_逻辑非) {
        Nova编码_表达式(ctx, 节点[1])
        Nova字节码_发射(块, 指令_非)
        返回
    }

    // 位非 [139, operand]
    如果 (类型 == 节_位非) {
        Nova编码_表达式(ctx, 节点[1])
        Nova字节码_发射(块, 指令_位非)
        返回
    }

    // 间接调用 [140, func_expr, args_list]
    如果 (类型 == 节_间接调用) {
        Nova编码_处理_140(ctx, 节点)
        返回
    }

    // 字典字面量 [151, key_value_pairs]
    如果 (类型 == 节_字典) {
        Nova编码_处理_151(ctx, 节点)
        返回
    }

    // 空值 [165]
    如果 (类型 == 165) {
        Nova字节码_发射(块, 指令_压入空)
        返回
    }
}

// 语句编码
函数 Nova编码_语句(ctx, 节点) {
    如果 (节点 == 空 或 是列表(节点) == 假 或 计数(节点) < 1) { 返回 }
    定义 块 = Nova编码_当前块(ctx)
    定义 类型 = 节点[0]

    // 变量定义 [110, name, value_expr, ...]
    如果 (类型 == 节_定义) {
        定义 名称 = 节点[1]
        如果 (计数(节点) > 2 且 节点[2] != 空) {
            Nova编码_表达式(ctx, 节点[2])
        } 否则 {
            Nova字节码_发射(块, 指令_压入空)
        }
        定义 索引 = Nova编码_声明局部(ctx, 名称)
        Nova字节码_发射16(块, 指令_存局部, 索引)
        返回
    }

    // 赋值 [111, name, value_expr]
    如果 (类型 == 节_赋值) {
        Nova编码_表达式(ctx, 节点[2])
        定义 局部 = Nova编码_查找局部(ctx, 节点[1])
        如果 (局部 >= 0) {
            Nova字节码_发射16(块, 指令_存局部, 局部)
        } 否则 {
            定义 全局索引 = Nova字节码_添加常量(块, 节点[1])
            Nova字节码_发射16(块, 指令_存全局, 全局索引)
        }
        返回
    }

    // 返回 [114, return_value_expr]
    如果 (类型 == 节_返回) {
        如果 (计数(节点) > 1 且 节点[1] != 空) {
            Nova编码_表达式(ctx, 节点[1])
            Nova字节码_发射(块, 指令_返回)
        } 否则 {
            Nova字节码_发射(块, 指令_返回空)
        }
        返回
    }

    // 表达式语句 [115, expr]
    如果 (类型 == 节_表达式) {
        Nova编码_表达式(ctx, 节点[1])
        Nova字节码_发射(块, 指令_弹出)
        返回
    }

    // if/else [112, condition, then_body, else_body?]
    如果 (类型 == 节_如果) {
        Nova编码_表达式(ctx, 节点[1])
        定义 跳假位 = Nova字节码_代码大小(块)
        Nova字节码_发射16(块,  指令_假跳, 0)
        // then分支
        Nova编码_块(ctx, 节点[2])
        如果 (计数(节点) > 3 且 节点[3] != 空) {
            定义 跳过位 = Nova字节码_代码大小(块)
            Nova字节码_发射16(块,  指令_跳转, 0)
            定义 代码 = 块[4]
            代码[跳假位 + 1] = Nova字节码_代码大小(块) & 0xFF
            代码[跳假位 + 2] = (Nova字节码_代码大小(块) >> 8) & 0xFF
            // else分支
            Nova编码_块(ctx, 节点[3])
            代码[跳过位 + 1] = Nova字节码_代码大小(块) & 0xFF
            代码[跳过位 + 2] = (Nova字节码_代码大小(块) >> 8) & 0xFF
        } 否则 {
            定义 代码 = 块[4]
            代码[跳假位 + 1] = Nova字节码_代码大小(块) & 0xFF
            代码[跳假位 + 2] = (Nova字节码_代码大小(块) >> 8) & 0xFF
        }
        返回
    }

    // while循环 [113, condition, body]
    如果 (类型 == 节_当) {
        定义 循环头 = Nova字节码_代码大小(块)
        Nova字节码_发射(块, 指令_热点计)
        // 记录循环上下文供 break/continue 使用
        追加(ctx[4], [循环头, []])
        Nova编码_表达式(ctx, 节点[1])
        定义 跳出位 = Nova字节码_代码大小(块)
        Nova字节码_发射16(块,  指令_假跳, 0)
        // 循环体
        Nova编码_块(ctx, 节点[2])
        // 回跳
        Nova字节码_发射16(块, 指令_循环, 循环头)
        // 修正跳出偏移
        定义 代码 = 块[4]
        定义 跳出目标 = Nova字节码_代码大小(块)
        代码[跳出位 + 1] = 跳出目标 & 0xFF
        代码[跳出位 + 2] = (跳出目标 >> 8) & 0xFF
        // 修正所有 break 跳转
        定义 循环信息 = ctx[4][计数(ctx[4]) - 1]
        定义 中断列 = 循环信息[1]
        定义 可变 bi = 0
        当 (bi < 计数(中断列)) {
            定义 中断位 = 中断列[bi]
            代码[中断位 + 1] = 跳出目标 & 0xFF
            代码[中断位 + 2] = (跳出目标 >> 8) & 0xFF
            bi = bi + 1
        }
        // 弹出循环上下文
        弹出(ctx[4])
        返回
    }

    // 索引赋值 [116, object, index, value]
    如果 (类型 == 节_索引赋值) {
        Nova编码_表达式(ctx, 节点[3])
        Nova编码_表达式(ctx, 节点[1])
        Nova编码_表达式(ctx, 节点[2])
        Nova字节码_发射(块, 指令_设索引)
        返回
    }

    // 点赋值 [132, object, field_name, value]
    如果 (类型 == 节_点赋值) {
        Nova编码_表达式(ctx, 节点[3])
        Nova编码_表达式(ctx, 节点[1])
        定义 字段索引 = Nova字节码_添加常量(块, 节点[2])
        Nova字节码_发射16(块, 指令_设字段, 字段索引)
        返回
    }

    // 每个/foreach [134, var_name, iterable, body]
    如果 (类型 == 节_每个) {
        Nova编码_表达式(ctx, 节点[2])
        定义 迭代索引 = Nova编码_声明局部(ctx, 节点[1])
        定义 循环头 = Nova字节码_代码大小(块)
        Nova字节码_发射(块, 指令_热点计)
        定义 跳出位 = Nova字节码_代码大小(块)
        Nova字节码_发射16(块,  指令_遍历, 0)
        Nova字节码_发射16(块, 指令_存局部, 迭代索引)
        Nova编码_块(ctx, 节点[3])
        Nova字节码_发射16(块, 指令_循环, 循环头)
        定义 代码 = 块[4]
        代码[跳出位 + 1] = Nova字节码_代码大小(块) & 0xFF
        代码[跳出位 + 2] = (Nova字节码_代码大小(块) >> 8) & 0xFF
        返回
    }

    // 中断/break [136]
    如果 (类型 == 节_中断) {
        如果 (计数(ctx[4]) > 0) {
            定义 中断位 = Nova字节码_代码大小(块)
            Nova字节码_发射16(块,  指令_跳转, 0)
            追加(ctx[4][计数(ctx[4]) - 1][1], 中断位)
        }
        返回
    }

    // 继续/continue [137]
    如果 (类型 == 节_继续) {
        如果 (计数(ctx[4]) > 0) {
            定义 循环头 = ctx[4][计数(ctx[4]) - 1][0]
            Nova字节码_发射16(块, 指令_循环, 循环头)
        }
        返回
    }

    // 异常处理 [160, try_body, catch_var, catch_body]
    如果 (类型 == 节_尝试) {
        定义 try位 = Nova字节码_代码大小(块)
        Nova字节码_发射16(块,  指令_尝试, 0)
        // try体
        Nova编码_块(ctx, 节点[1])
        定义 跳过位 = Nova字节码_代码大小(块)
        Nova字节码_发射16(块,  指令_跳转, 0)
        // catch入口
        定义 代码 = 块[4]
        代码[try位 + 1] = Nova字节码_代码大小(块) & 0xFF
        代码[try位 + 2] = (Nova字节码_代码大小(块) >> 8) & 0xFF
        // catch体
        如果 (计数(节点) > 2 且 节点[2] != 空) {
            定义 异常变量索引 = Nova编码_声明局部(ctx, 节点[2])
            Nova字节码_发射16(块, 指令_存局部, 异常变量索引)
        }
        如果 (计数(节点) > 3 且 节点[3] != 空) {
            Nova编码_块(ctx, 节点[3])
        }
        代码[跳过位 + 1] = Nova字节码_代码大小(块) & 0xFF
        代码[跳过位 + 2] = (Nova字节码_代码大小(块) >> 8) & 0xFF
        返回
    }

    // throw [162, value_expr]
    如果 (类型 == 节_抛出) {
        如果 (计数(节点) > 1) { Nova编码_表达式(ctx, 节点[1]) }
        否则 { Nova字节码_发射(块, 指令_压入空) }
        Nova字节码_发射(块, 指令_抛出)
        返回
    }

    // 函数定义语句 [120, name, params, body]
    如果 (类型 == 节_函数) {
        Nova编码_函数(ctx, 节点)
        返回
    }
}

// 语句块编码
函数 Nova编码_块(ctx, 语句列) {
    定义 可变 i = 0
    当 (i < 计数(语句列)) {
        Nova编码_语句(ctx, 语句列[i])
        i = i + 1
    }
}

// 函数编码
函数 Nova编码_函数(ctx, 函数节点) {
    定义 块 = Nova编码_当前块(ctx)
    定义 名称 = 函数节点[1]
    定义 参数列 = 函数节点[2]
    定义 函数体 = 函数节点[3]

    // 保存上下文
    定义 旧变量表 = ctx[1]
    定义 旧变量数 = ctx[2]
    定义 旧函数名 = ctx[5]

    // 新建函数作用域
    ctx[1] = 字典()
    ctx[2] = 0
    ctx[5] = 名称

    // 注册参数
    定义 可变 i = 0
    当 (i < 计数(参数列)) {
        Nova编码_声明局部(ctx, 参数列[i])
        i = i + 1
    }

    // 记录函数入口
    定义 入口 = Nova字节码_代码大小(块)
    Nova字节码_注册函数(块, 名称, 入口, 计数(参数列))

    // 编码函数体
    Nova编码_块(ctx, 函数体)

    // 确保有返回
    Nova字节码_发射(块, 指令_返回空)

    // 恢复上下文
    ctx[1] = 旧变量表
    ctx[2] = 旧变量数
    ctx[5] = 旧函数名
}

// 编译入口
函数 Nova编码_编译程序(函数列, 主体) {
    定义 块 = Nova字节码_创建块()
    定义 ctx = Nova编码_创建上下文(块)

    // 编码所有函数
    定义 可变 i = 0
    当 (i < 计数(函数列)) {
        Nova编码_函数(ctx, 函数列[i])
        i = i + 1
    }

    // 编码主体
    定义 主入口 = Nova字节码_代码大小(块)
    Nova字节码_注册函数(块,  "__主程序__",  主入口, 0)
    Nova编码_块(ctx, 主体)
    Nova字节码_发射(块, 指令_停机)

    返回 块
}

// 单语句编译入口(热更新管线使用)
函数 Nova编码_编译语句(ctx, 语句节点) {
    如果 (语句节点 == 空 或 是列表(语句节点) == 假 或 计数(语句节点) < 1) { 返回 }
    定义 类型 = 语句节点[0]
    // 函数定义节点: [120, 名称, 参数列, 体]
    如果 (类型 == 节_函数) {
        Nova编码_函数(ctx, 语句节点)
        返回
    }
    // 其他语句: 委托给Nova编码_语句
    Nova编码_语句(ctx, 语句节点)
}

定义 可变 _编码器_编译数 = 0
定义 可变 _编码器_指令数 = 0

// 实验反哺: IR序列化差分编码压缩
// 实验室验证: Nova IR指令操作码序列局部相似，差分编码后约40%节省
// 应用: IR缓存文件压缩存储，加速增量编译（只存储变化的差分）

// 将指令字节码序列转为差分编码（相邻差值）
函数 IR字节码_差分编码(字节序列) {
    如果 (计数(字节序列) == 0) { 返回 [] }
    定义 可变 差分 = [字节序列[0]]  // 第一个保留绝对值
    定义 可变 i = 1
    当 (i < 计数(字节序列)) {
        追加(差分, 字节序列[i] - 字节序列[i-1])  // 差值（可为负）
        i = i + 1
    }
    返回 差分
}

// 从差分编码恢复原始字节序列
函数 IR字节码_差分解码(差分序列) {
    如果 (计数(差分序列) == 0) { 返回 [] }
    定义 可变 原始 = [差分序列[0]]
    定义 可变 i = 1
    当 (i < 计数(差分序列)) {
        追加(原始, 原始[i-1] + 差分序列[i])
        i = i + 1
    }
    返回 原始
}

// 统计差分序列的压缩效率（差值越集中在小范围，越适合压缩）
函数 IR字节码_压缩效率分析(差分序列) {
    如果 (计数(差分序列) <= 1) { 返回 [0, 0] }
    定义 可变 小差值数 = 0  // |diff| <= 8 的数量
    定义 可变 i = 1  // 跳过第一个绝对值
    当 (i < 计数(差分序列)) {
        定义 v = 差分序列[i]
        如果 (v < 0) { v = 0 - v }
        如果 (v <= 8) { 小差值数 = 小差值数 + 1 }
        i = i + 1
    }
    // 小差值比例：越高越适合用短编码（如VarInt）
    定义 小差值比例 = 小差值数 * 100 / (计数(差分序列) - 1)
    // 估计压缩率：差值在[-8,8]内可用1字节代替原来可能的多字节
    定义 估计压缩率 = 100 - 小差值比例 / 2  // 近似
    返回 [小差值比例, 估计压缩率]
}

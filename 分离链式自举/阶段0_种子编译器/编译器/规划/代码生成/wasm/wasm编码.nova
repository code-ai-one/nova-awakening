// WASM 数据段编码

// 主动数据段: 0x00 + offset_expr + 数据字节
函数 wasm_编码_数据段_主动(偏移值, 数据) { 定义 可变 结果 = [0x00] // 主动段标志
 // offset表达式: i32.const + 偏移 + end
 追加(结果, 0x41) // i32.const
 定义 off_enc = wasm_编码_sleb128(偏移值)
 定义 可变 i = 0
 当 (i < 计数(off_enc)) { 追加(结果, off_enc[i]) i = i + 1 }
 追加(结果, 0x0B) // end
 // 数据长度 + 数据
 定义 len_enc = wasm_编码_uleb128(计数(数据))
 i = 0
 当 (i < 计数(len_enc)) { 追加(结果, len_enc[i]) i = i + 1 }
 i = 0
 当 (i < 计数(数据)) { 追加(结果, 数据[i]) i = i + 1 }
 返回 结果
}

// 被动数据段: 0x01 + 数据
函数 wasm_编码_数据段_被动(数据) { 定义 可变 结果 = [0x01]
 定义 len_enc = wasm_编码_uleb128(计数(数据))
 定义 可变 i = 0
 当 (i < 计数(len_enc)) { 追加(结果, len_enc[i]) i = i + 1 }
 i = 0
 当 (i < 计数(数据)) { 追加(结果, 数据[i]) i = i + 1 }
 返回 结果
}

// WASM 导入段编码

函数 wasm_编码_导入_函数(模块名字节, 名称字节, 类型索引) { 定义 可变 结果 = []
 // 模块名
 定义 mlen = wasm_编码_uleb128(计数(模块名字节))
 定义 可变 i = 0
 当 (i < 计数(mlen)) { 追加(结果, mlen[i]) i = i + 1 }
 i = 0
 当 (i < 计数(模块名字节)) { 追加(结果, 模块名字节[i]) i = i + 1 }
 // 名称
 定义 名长 = wasm_编码_uleb128(计数(名称字节))
 i = 0
 当 (i < 计数(名长)) { 追加(结果, 名长[i]) i = i + 1 }
 i = 0
 当 (i < 计数(名称字节)) { 追加(结果, 名称字节[i]) i = i + 1 }
 // 导入类型: 0x00=函数
 追加(结果, 0x00)
 定义 tidx = wasm_编码_uleb128(类型索引)
 i = 0
 当 (i < 计数(tidx)) { 追加(结果, tidx[i]) i = i + 1 }
 返回 结果
}

函数 wasm_编码_导入_内存(模块名字节, 名称字节, 最小页, 最大页) { 定义 可变 结果 = []
 // 模块名
 定义 mlen = wasm_编码_uleb128(计数(模块名字节))
 定义 可变 i = 0
 当 (i < 计数(mlen)) { 追加(结果, mlen[i]) i = i + 1 }
 i = 0
 当 (i < 计数(模块名字节)) { 追加(结果, 模块名字节[i]) i = i + 1 }
 // 名称
 定义 名长 = wasm_编码_uleb128(计数(名称字节))
 i = 0
 当 (i < 计数(名长)) { 追加(结果, 名长[i]) i = i + 1 }
 i = 0
 当 (i < 计数(名称字节)) { 追加(结果, 名称字节[i]) i = i + 1 }
 // 导入类型: 0x02=内存
 追加(结果, 0x02)
 如果 (最大页 > 0) {
 追加(结果, 0x01) // 有上限
 定义 mn = wasm_编码_uleb128(最小页)
 i = 0
 当 (i < 计数(mn)) { 追加(结果, mn[i]) i = i + 1 }
 定义 mx = wasm_编码_uleb128(最大页)
 i = 0
 当 (i < 计数(mx)) { 追加(结果, mx[i]) i = i + 1 }
 } 否则 {
 追加(结果, 0x00) // 无上限
 定义 mn = wasm_编码_uleb128(最小页)
 i = 0
 当 (i < 计数(mn)) { 追加(结果, mn[i]) i = i + 1 }
 }
 返回 结果
}

// WASM 全局段编码

函数 wasm_编码_全局声明(值类型, 可变标志, 初始值) { 定义 可变 结果 = [值类型, 可变标志]
 // 初始值表达式
 如果 (值类型 == 类型_i32) {
 追加(结果, 0x41)
 定义 编码值 = wasm_编码_sleb128(初始值)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 } 否则 { 如果 (值类型 == 类型_i64) {
 追加(结果, 0x42)
 定义 编码值 = wasm_编码_sleb128(初始值)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 }
 }
 追加(结果, 0x0B) // end
 返回 结果
}

// WASM 有上限内存段编码

函数 wasm_编码_内存_有上限(最小页, 最大页) { 定义 可变 结果 = [0x01] // limits flag: 有上限
 定义 最短编码 = wasm_编码_uleb128(最小页)
 定义 可变 i = 0
 当 (i < 计数(最短编码)) { 追加(结果, 最短编码[i]) i = i + 1 }
 定义 max_enc = wasm_编码_uleb128(最大页)
 i = 0
 当 (i < 计数(max_enc)) { 追加(结果, max_enc[i]) i = i + 1 }
 返回 结果
}

// WASM 表段编码

函数 wasm_编码_表(引用类型, 最小, 最大) { 定义 可变 结果 = [引用类型]
 如果 (最大 > 0) {
 追加(结果, 0x01)
 定义 mn = wasm_编码_uleb128(最小)
 定义 可变 i = 0
 当 (i < 计数(mn)) { 追加(结果, mn[i]) i = i + 1 }
 定义 mx = wasm_编码_uleb128(最大)
 i = 0
 当 (i < 计数(mx)) { 追加(结果, mx[i]) i = i + 1 }
 } 否则 {
 追加(结果, 0x00)
 定义 mn = wasm_编码_uleb128(最小)
 定义 可变 i = 0
 当 (i < 计数(mn)) { 追加(结果, mn[i]) i = i + 1 }
 }
 返回 结果
}

// WASM 起始段编码

函数 wasm_编码_起始段(函数索引) { 返回 wasm_编码_uleb128(函数索引)
}

// WASM 字符串→UTF8字节 辅助

函数 wasm_字符串转字节(文本) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 长度(文本)) {
 追加(结果, 字节(文本, i))
 i = i + 1
 }
 返回 结果
}

// WASM 完整模块组装

函数 wasm_组装模块(类型段, 导入段, 函数段, 表段, 内存段, 全局段, 导出段, 起始段, 元素段, 代码段, 数据段) { 定义 可变 结果 = 模块头()
 // 按段ID顺序依次追加非空段
 如果 (计数(类型段) > 0) {
     定义 s = 封装段(段_TYPE, 类型段)
     定义 可变 i = 0
     当 (i < 计数(s)) { 追加(结果, s[i])  i = i + 1 }
 }
 如果 (计数(导入段) > 0) {
     定义 s = 封装段(段_IMPORT, 导入段)
     定义 可变 i = 0
     当 (i < 计数(s)) { 追加(结果, s[i])  i = i + 1 }
 }
 如果 (计数(函数段) > 0) {
     定义 s = 封装段(段_FUNC, 函数段)
     定义 可变 i = 0
     当 (i < 计数(s)) { 追加(结果, s[i])  i = i + 1 }
 }
 如果 (计数(表段) > 0) {
     定义 s = 封装段(段_TABLE, 表段)
     定义 可变 i = 0
     当 (i < 计数(s)) { 追加(结果, s[i])  i = i + 1 }
 }
 如果 (计数(内存段) > 0) {
     定义 s = 封装段(段_MEMORY, 内存段)
     定义 可变 i = 0
     当 (i < 计数(s)) { 追加(结果, s[i])  i = i + 1 }
 }
 如果 (计数(全局段) > 0) {
     定义 s = 封装段(段_GLOBAL, 全局段)
     定义 可变 i = 0
     当 (i < 计数(s)) { 追加(结果, s[i])  i = i + 1 }
 }
 如果 (计数(导出段) > 0) {
     定义 s = 封装段(段_EXPORT, 导出段)
     定义 可变 i = 0
     当 (i < 计数(s)) { 追加(结果, s[i])  i = i + 1 }
 }
 如果 (计数(起始段) > 0) {
     定义 s = 封装段(段_START, 起始段)
     定义 可变 i = 0
     当 (i < 计数(s)) { 追加(结果, s[i])  i = i + 1 }
 }
 如果 (计数(元素段) > 0) {
     定义 s = 封装段(段_ELEM, 元素段)
     定义 可变 i = 0
     当 (i < 计数(s)) { 追加(结果, s[i])  i = i + 1 }
 }
 如果 (计数(代码段) > 0) {
     定义 s = 封装段(段_CODE, 代码段)
     定义 可变 i = 0
     当 (i < 计数(s)) { 追加(结果, s[i])  i = i + 1 }
 }
 如果 (计数(数据段) > 0) {
     定义 s = 封装段(WASM小写_段_DATA, 数据段)
     定义 可变 i = 0
     当 (i < 计数(s)) { 追加(结果, s[i])  i = i + 1 }
 }
 返回 结果
}

定义 可变 _wasm_编码次数 = 0
定义 可变 _wasm_总字节 = 0
定义 可变 _wasm_函数数 = 0

函数 wasm_记录编码(字节数) { _wasm_编码次数 = _wasm_编码次数 + 1
 _wasm_总字节 = _wasm_总字节 + 字节数
}

函数 wasm_记录函数() { _wasm_函数数 = _wasm_函数数 + 1 }

函数 wasm_密度评估() {
    如果 (_wasm_编码次数 == 0) { 返回 "无编码"
}
 定义 平均 = _wasm_总字节 * 10 / _wasm_编码次数
 如果 (平均 > 50) { 返回 "指令偏长" }
 返回 "WASM编码紧凑"
}

函数 wasm_重置() { _wasm_编码次数 = 0 _wasm_总字节 = 0 _wasm_函数数 = 0 }

// WASM函数体编码

函数 wasm_编码_函数体(本地变量, 指令列表) { 定义 可变 体 = []
 // 本地变量声明
 定义 本地数enc = 编码_uleb128(计数(本地变量))
 定义 可变 i = 0
 当 (i < 计数(本地数enc)) { 追加(体, 本地数enc[i]) i = i + 1 }
 i = 0
 当 (i < 计数(本地变量)) { 定义 cnt = 编码_uleb128(1)
 定义 可变 j = 0
 当 (j < 计数(cnt)) { 追加(体, cnt[j]) j = j + 1 }
 追加(体, 本地变量[i])
 i = i + 1
 }
 // 指令
 i = 0
 当 (i < 计数(指令列表)) { 追加(体, 指令列表[i]) i = i + 1 }
 追加(体, WASM_结束)
 // 长度前缀
 定义 长度enc = 编码_uleb128(计数(体))
 定义 可变 结果 = []
 i = 0
 当 (i < 计数(长度enc)) { 追加(结果, 长度enc[i]) i = i + 1 }
 i = 0
 当 (i < 计数(体)) { 追加(结果, 体[i]) i = i + 1 }
 返回 结果
}

// WASM SIMD v128 指令 (128位向量, 操作码前缀0xFD)

// SIMD辅助: 发射SIMD操作码(前缀 + LEB128操作码)
函数 wasm_SIMD指令集(操作码) { 定义 结果 = [操作码_prefix_simd]
 定义 编码值 = wasm_编码_uleb128(操作码)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 返回 结果
}

// v128.load — 加载128位向量
函数 wasm_向量128_加载(对齐, 偏移) { 定义 r = wasm_SIMD指令集(0) 返回 r }
// v128.store
函数 wasm_向量128_存储(对齐, 偏移) { 定义 r = wasm_SIMD指令集(11) 返回 r }
// v128.const — 128位常量
函数 wasm_向量128_常量(字节16) { 定义 r = wasm_SIMD指令集(12) 返回 r }


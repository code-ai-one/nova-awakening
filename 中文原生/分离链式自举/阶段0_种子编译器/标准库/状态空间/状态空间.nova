导入("../基础.nova")
导入("../算法/数学扩展.nova")


// S4核心: 结构化状态空间
// 离散化: x_{k+1} = Ā·x_k + B̄·u_k,  y_k = C·x_k + D·u_k
// Ā = exp(Δ·A),  B̄ = (Δ·A)^{-1}(Ā - I)·Δ·B  (ZOH)
// 整数近似: ×1000定点

函数 SSM_创建(状态维度, 输入维度) {
    // A: 状态转移 (HiPPO初始化: A[i][j] = -(2i+1)^½·(2j+1)^½ for i>j)
    定义 可变 A = []
    定义 可变 i = 0
    当 (i < 状态维度) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j < 状态维度) {
            如果 (i == j) {
                追加(行, 0 - (i + 1) * 100)  // 对角线: 负值(衰减)
            } 否则 如果 (i > j) {
                定义 vi = 整数sqrt((2 * i + 1) * 1000)
                定义 vj = 整数sqrt((2 * j + 1) * 1000)
                追加(行, 0 - vi * vj / 1000)
            } 否则 {
                追加(行, 0)
            }
            j = j + 1
        }
        追加(A, 行)
        i = i + 1
    }
    // B: 输入投影
    定义 可变 B = []
    i = 0
    当 (i < 状态维度) {
        定义 可变 行b = []
        定义 可变 j = 0
        当 (j < 输入维度) {
            追加(行b, 整数sqrt((2 * i + 1) * 1000))
            j = j + 1
        }
        追加(B, 行b)
        i = i + 1
    }
    // C: 输出投影, D: 直通
    定义 可变 C = []
    i = 0
    当 (i < 输入维度) {
        定义 可变 行c = []
        定义 可变 j = 0
        当 (j < 状态维度) { 追加(行c, 1000 / 状态维度)
        j = j + 1 }
        追加(C, 行c)
        i = i + 1
    }
    定义 可变 D = []
    i = 0
    当 (i < 输入维度) { 追加(D, 0)
    i = i + 1 }
    // 状态向量
    定义 可变 状态 = []
    i = 0
    当 (i < 状态维度) { 追加(状态, 0)
    i = i + 1 }
    返回 [A, B, C, D, 状态维度, 输入维度, 状态]
}

// ZOH离散化
函数 SSM_离散化(ssm, Δ) {
    定义 N = ssm[4]
    定义 M = ssm[5]
    // Ā ≈ I + Δ·A (一阶近似)
    定义 可变 A_bar = []
    定义 可变 i = 0
    当 (i < N) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j < N) {
            定义 可变 数值 = Δ * ssm[0][i][j] / 1000
            如果 (i == j) { 数值 = 1000 + 数值 }
            追加(行, 数值)
            j = j + 1
        }
        追加(A_bar, 行)
        i = i + 1
    }
    // B̄ ≈ Δ·B
    定义 可变 B_bar = []
    i = 0
    当 (i < N) {
        定义 可变 行b = []
        定义 可变 j = 0
        当 (j < M) {
            追加(行b, Δ * ssm[1][i][j] / 1000)
            j = j + 1
        }
        追加(B_bar, 行b)
        i = i + 1
    }
    返回 [A_bar, B_bar]
}

// SSM单步
函数 SSM_步进(ssm, 输入, Δ) {
    定义 离散 = SSM_离散化(ssm, Δ)
    定义 A_bar = 离散[0]
    定义 B_bar = 离散[1]
    定义 N = ssm[4]
    定义 M = ssm[5]
    定义 状态 = ssm[6]
    // x = Ā·x + B̄·u
    定义 可变 新状态 = []
    定义 可变 i = 0
    当 (i < N) {
        定义 可变 数值 = 0
        定义 可变 j = 0
        当 (j < N) { 数值 = 数值 + A_bar[i][j] * 状态[j] / 1000
        j = j + 1 }
        j = 0
        当 (j < M) { 数值 = 数值 + B_bar[i][j] * 输入[j] / 1000
        j = j + 1 }
        追加(新状态, 数值)
        i = i + 1
    }
    ssm[6] = 新状态
    // y = C·x + D·u
    定义 可变 输出 = []
    i = 0
    当 (i < M) {
        定义 可变 y = ssm[3][i] * 输入[i] / 1000  // D·u
        定义 可变 j = 0
        当 (j < N) { y = y + ssm[2][i][j] * 新状态[j] / 1000
        j = j + 1 }
        追加(输出, y)
        i = i + 1
    }
    返回 输出
}

// SSM序列处理 (卷积模式)
函数 SSM_卷积核(ssm, 序列长度, Δ) {
    定义 离散 = SSM_离散化(ssm, Δ)
    定义 A_bar = 离散[0]
    定义 B_bar = 离散[1]
    定义 N = ssm[4]
    // 核 K[l] = C · Ā^l · B̄
    定义 可变 核 = []
    // 用迭代计算 Ā^l·B̄
    定义 可变 power_B = []  // Ā^0·B̄ = B̄
    定义 可变 i = 0
    当 (i < N) { 追加(power_B, B_bar[i][0])
    i = i + 1 }
    定义 可变 l = 0
    当 (l < 序列长度) {
        // K[l] = C · power_B
        定义 可变 k = 0
        i = 0
        当 (i < N) { k = k + ssm[2][0][i] * power_B[i] / 1000
        i = i + 1 }
        追加(核, k)
        // power_B = Ā · power_B
        定义 可变 新power = []
        i = 0
        当 (i < N) {
            定义 可变 v = 0
            定义 可变 j = 0
            当 (j < N) { v = v + A_bar[i][j] * power_B[j] / 1000
            j = j + 1 }
            追加(新power, v)
            i = i + 1
        }
        power_B = 新power
        l = l + 1
    }
    返回 核
}

// Mamba: 选择性状态空间
// 核心创新: Δ, B, C 依赖输入 (选择性机制)
函数 Mamba块_创建(模型维度, d_state, d_conv) {
    // 型: [模型维度, d_state, d_conv, 投影权重, 卷积核, dt权重]
    定义 d_inner = 模型维度 * 2
    返回 [模型维度, d_state, d_conv, d_inner, [], [], []]
}

函数 状态空间_Mamba_选择性扫描(B_seq, C_seq, Δ_seq, A_diag, 输入序列) {
    定义 L = 计数(输入序列)
    定义 N = 计数(A_diag)
    // 初始化隐状态
    定义 可变 h = []
    定义 可变 i = 0
    当 (i < N) { 追加(h, 0)
    i = i + 1 }
    定义 可变 输出 = []
    定义 可变 t = 0
    当 (t < L) {
        定义 Δ = Δ_seq[t]
        // 离散化: Ā = exp(Δ·A) ≈ 1+Δ·A, B̄ = Δ·B
        定义 可变 新h = []
        i = 0
        当 (i < N) {
            定义 a_disc = 1000 + Δ * A_diag[i] / 1000
            定义 b_disc = Δ * B_seq[t * N + i] / 1000
            定义 新隐藏 = a_disc * h[i] / 1000 + b_disc * 输入序列[t] / 1000
            追加(新h, 新隐藏)
            i = i + 1
        }
        h = 新h
        // y = C·h
        定义 可变 y = 0
        i = 0
        当 (i < N) { y = y + C_seq[t * N + i] * h[i] / 1000
        i = i + 1 }
        追加(输出, y)
        t = t + 1
    }
    返回 输出
}

// 并行扫描 (Parallel Scan / Prefix Sum, 0)
// 用于SSM的并行化: 结合律 (a1,b1)⊗(a2,b2) = (a1·a2, a2·b1+b2)
函数 并行扫描(A_seq, B_seq) {
    定义 L = 计数(A_seq)
    定义 可变 结果A = []
    定义 可变 结果B = []
    定义 可变 i = 0
    当 (i < L) { 追加(结果A, A_seq[i])
    追加(结果B, B_seq[i])
    i = i + 1 }
    // 上扫 (reduce)
    定义 可变 步长 = 1
    当 (步长 < L) {
        i = 步长 * 2 - 1
        当 (i < L) {
            定义 左 = i - 步长
            结果B[i] = 结果A[i] * 结果B[左] / 1000 + 结果B[i]
            结果A[i] = 结果A[i] * 结果A[左] / 1000
            i = i + 步长 * 2
        }
        步长 = 步长 * 2
    }
    // 下扫 (distribute)
    步长 = L / 2
    当 (步长 >= 1) {
        i = 步长 * 3 - 1
        当 (i < L) {
            定义 左 = i - 步长
            结果B[i] = 结果A[i] * 结果B[左] / 1000 + 结果B[i]
            结果A[i] = 结果A[i] * 结果A[左] / 1000
            i = i + 步长 * 2
        }
        步长 = 步长 / 2
    }
    返回 结果B
}

// RWKV: 线性注意力RNN
函数 RWKV_时间混合(r, k, v, w, u, 上一状态) {
    定义 维度 = 计数(r)
    定义 可变 输出 = []
    定义 可变 新状态 = []
    定义 可变 i = 0
    当 (i < 维度) {
        // wkv = (e^{u+k}·v + state_n) / (e^{u+k} + state_d)
        定义 uk = u[i] + k[i]
        定义 可变 eu = 1000 + uk  // e^x ≈ 1+x 近似
        如果 (eu < 1) { eu = 1 }
        定义 wkv_n = eu * v[i] / 1000 + 上一状态[i * 2]
        定义 可变 wkv_d = eu + 上一状态[i * 2 + 1]
        如果 (wkv_d == 0) { wkv_d = 1 }
        定义 wkv = wkv_n * 1000 / wkv_d
        // 输出 = S形函数(r) * wkv
        定义 可变 sig_r = 500 + r[i] / 4  // sigmoid近似
        如果 (sig_r < 0) { sig_r = 0 }
        如果 (sig_r > 1000) { sig_r = 1000 }
        追加(输出, sig_r * wkv / 1000)
        // 更新状态
        定义 可变 ew = 1000 + w[i]
        如果 (ew < 1) { ew = 1 }
        追加(新状态, ew * 上一状态[i * 2] / 1000 + 1000 * v[i] / 1000)
        追加(新状态, ew * 上一状态[i * 2 + 1] / 1000 + 1000)
        i = i + 1
    }
    返回 [输出, 新状态]
}

// RetNet: 保留网络
函数 RetNet_衰减矩阵(序列长度, γ) {
    定义 可变 D = []
    定义 可变 i = 0
    当 (i < 序列长度) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j < 序列长度) {
            如果 (j <= i) {
                // D[i][j] = γ^(i-j)
                定义 可变 power = 1000
                定义 可变 k = 0
                当 (k < i - j) { power = power * γ / 1000
                k = k + 1 }
                追加(行, power)
            } 否则 {
                追加(行, 0)  // 因果掩码
            }
            j = j + 1
        }
        追加(D, 行)
        i = i + 1
    }
    返回 D
}

// 门控SSM (Gated State Space)
函数 门控SSM_步进(ssm, 输入, 门控值) {
    定义 输出 = SSM_步进(ssm, 输入, 100)
    定义 维度 = 计数(输出)
    定义 可变 门控输出 = []
    定义 可变 i = 0
    当 (i < 维度) {
        // g = S形函数(gate) × ssm_output
        定义 可变 g = 500 + 门控值[i] / 4
        如果 (g < 0) { g = 0 }
        如果 (g > 1000) { g = 1000 }
        追加(门控输出, g * 输出[i] / 1000)
        i = i + 1
    }
    返回 门控输出
}

// SSM重置状态
函数 SSM_重置(ssm) {
    定义 N = ssm[4]
    定义 可变 新状态 = []
    定义 可变 i = 0
    当 (i < N) { 追加(新状态, 0)
    i = i + 1 }
    ssm[6] = 新状态
}

// 离散化方法

函数 SSM_零阶保持(A, B, dt, N) {
    定义 可变 行A = []
    定义 可变 行B = []
    // Ad = I + A*dt (一阶近似)
    定义 可变 Ad = []
    定义 可变 Bd = []
    定义 可变 i = 0
    当 (i < N) {
        定义 可变 j = 0
        当 (j < N) {
            如果 (i == j) { 追加(行A, 1000 + A[i][j] * dt / 1000) }
            否则 { 追加(行A, A[i][j] * dt / 1000) }
            追加(行B, B[i][j] * dt / 1000)
            j = j + 1
        }
        追加(Ad, 行A)
        追加(Bd, 行B)
        i = i + 1
    }
    返回 [Ad, Bd]
}

函数 SSM_双线性(A, _B, dt, N) {
    // 双线性变换(Tustin)近似
    定义 可变 Ad = []
    定义 可变 i = 0
    当 (i < N) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j < N) {
            定义 可变 分子 = 0
            定义 可变 分母 = 0
            如果 (i == j) {
                分子 = 2000 + A[i][j] * dt / 1000
                分母 = 2000 - A[i][j] * dt / 1000
            } 否则 {
                分子 = A[i][j] * dt / 1000
                分母 = 1000
            }
            如果 (分母 == 0) { 追加(行, 0) }
            否则 { 追加(行, 分子 * 1000 / 分母) }
            j = j + 1
        }
        追加(Ad, 行)
        i = i + 1
    }
    返回 Ad
}

// 可观性和可控性

函数 SSM_可控性矩阵(A, B, N) {
    定义 可变 结果 = []
    定义 可变 幂B = B
    定义 可变 k = 0
    当 (k < N) {
        追加(结果, 幂B)
        // 幂B = A * 幂B (简化：仅取对角)
        定义 可变 新幂 = []
        定义 可变 i = 0
        当 (i < N) {
            定义 可变 行 = []
            定义 可变 j = 0
            当 (j < N) {
                定义 可变 和 = 0
                定义 可变 m = 0
                当 (m < N) { 和 = 和 + A[i][m] * 幂B[m][j] / 1000  m = m + 1 }
                追加(行, 和)
                j = j + 1
            }
            追加(新幂, 行)
            i = i + 1
        }
        幂B = 新幂
        k = k + 1
    }
    返回 结果
}

// 稳定性分析

函数 SSM_对角占优(A, N) {
    定义 可变 i = 0
    当 (i < N) {
        定义 可变 对角 = A[i][i]
        如果 (对角 < 0) { 对角 = 0 - 对角 }
        定义 可变 行和 = 0
        定义 可变 j = 0
        当 (j < N) {
            如果 (j != i) {
                定义 可变 v = A[i][j]
                如果 (v < 0) { v = 0 - v }
                行和 = 行和 + v
            }
            j = j + 1
        }
        如果 (对角 < 行和) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 SSM_迹(A, N) {
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < N) { 和 = 和 + A[i][i]  i = i + 1 }
    返回 和
}

定义 可变 _SSM_步进次数 = 0
定义 可变 _SSM_最大维度 = 0
定义 可变 _SSM_不稳定次数 = 0

函数 SSM_记录步进(维度) {
    _SSM_步进次数 = _SSM_步进次数 + 1
    如果 (维度 > _SSM_最大维度) { _SSM_最大维度 = 维度 }
}

函数 SSM_记录不稳定() { _SSM_不稳定次数 = _SSM_不稳定次数 + 1 }

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")

结构 文件档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    系统类型数,
    挂载数,
    文件数,
    打开数,
    读取数,
    写入数,
    追加数,
    删除数,
    锁数,
    解锁数,
    成功数,
    失败数,
    最近路径,
    最近挂载,
    最近系统,
    系统类型表,
    挂载表,
    文件表,
    锁表,
}

结构 文件请求 {
    动作,
    目标,
    参数,
    选项,
}

结构 文件回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 文件摘要 {
    名称,
    系统类型数,
    挂载数,
    文件数,
    打开数,
    读取数,
    写入数,
    追加数,
    删除数,
    锁数,
    解锁数,
    成功数,
    失败数,
    健康,
}

结构 文件系统类型项 {
    名称,
    块长,
    日志,
    只读,
    来源,
}

结构 挂载项 {
    路径,
    系统,
    设备,
    模式,
    来源,
}

结构 文件项 {
    路径,
    内容,
    大小,
    偏移,
    打开数,
    系统,
    模式,
    最近写入,
}

结构 锁项 {
    路径,
    模式,
    拥有者,
    次数,
}

定义 可变 文件账本 = []
定义 可变 文件构建数 = 0
定义 可变 文件总动作 = 0
定义 可变 文件总成功 = 0
定义 可变 文件总失败 = 0

函数 文件文件_建档(名称) {
    定义 档 = 文件档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.系统类型数 = 0
    档.挂载数 = 0
    档.文件数 = 0
    档.打开数 = 0
    档.读取数 = 0
    档.写入数 = 0
    档.追加数 = 0
    档.删除数 = 0
    档.锁数 = 0
    档.解锁数 = 0
    档.成功数 = 0
    档.失败数 = 0
    档.最近路径 = ""
    档.最近挂载 = ""
    档.最近系统 = ""
    档.系统类型表 = []
    档.挂载表 = []
    档.文件表 = []
    档.锁表 = []
    返回 档
}

函数 文件文件_登记(档) {
    追加(文件账本, 档)
    文件构建数 = 文件构建数 + 1
    返回 档
}

函数 文件文件_完整统计() {
    返回 [
        文件构建数,
        文件总动作,
        文件总成功,
        文件总失败
    ]
}

函数 文件文件_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 文件回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 文件文件_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    文件总动作 = 文件总动作 + 1
}

函数 文件文件_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.失败数 > 档.成功数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (档.锁数 > 档.解锁数 + 16) {
        档.最近健康 = "锁压"
        返回 档.最近健康
    }
    如果 (档.失败数 > 0) {
        档.最近健康 = "监视"
        返回 档.最近健康
    }
    档.最近健康 = "运行"
    返回 档.最近健康
}

函数 文件文件_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (档.名称 == "") { 返回 假 }
    返回 真
}

函数 文件文件_成功(档, 来源, 数据) {
    档.最近结果 = 数据
    档.成功数 = 档.成功数 + 1
    文件总成功 = 文件总成功 + 1
    档.最近统计 = 文件文件_完整统计()
    文件文件_刷新健康(档)
    返回 文件文件_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 文件文件_失败(档, 来源, 错因) {
    如果 (档 != 空) {
        档.最近错误 = 错因
        档.失败数 = 档.失败数 + 1
        档.最近统计 = 文件文件_完整统计()
        文件文件_刷新健康(档)
    }
    文件总失败 = 文件总失败 + 1
    返回 文件文件_建回证(真, 假, 来源, 错因, 空, 文件文件_完整统计())
}

函数 文件文件_找系统类型(档, 名称) {
    定义 索引 = 0
    当 (索引 < 计数(档.系统类型表)) {
        定义 项 = 档.系统类型表[索引]
        如果 (项.名称 == 名称) { 返回 项 }
        索引 = 索引 + 1
    }
    返回 空
}

函数 文件文件_找挂载(档, 路径) {
    定义 索引 = 0
    当 (索引 < 计数(档.挂载表)) {
        定义 项 = 档.挂载表[索引]
        如果 (项.路径 == 路径) { 返回 项 }
        索引 = 索引 + 1
    }
    返回 空
}

函数 文件文件_规范路径(路径) {
    如果 (路径 == "") { 返回 "/" }
    如果 (路径[0] != "/") { 返回 "/" + 路径 }
    返回 路径
}

函数 文件文件_找文件(档, 路径) {
    定义 标准路径 = 文件文件_规范路径(路径)
    定义 索引 = 0
    当 (索引 < 计数(档.文件表)) {
        定义 项 = 档.文件表[索引]
        如果 (项.路径 == 标准路径) { 返回 项 }
        索引 = 索引 + 1
    }
    返回 空
}

函数 文件文件_找锁(档, 路径, 拥有者) {
    定义 标准路径 = 文件文件_规范路径(路径)
    定义 索引 = 0
    当 (索引 < 计数(档.锁表)) {
        定义 项 = 档.锁表[索引]
        如果 (项.路径 == 标准路径 && 项.拥有者 == 拥有者) { 返回 项 }
        索引 = 索引 + 1
    }
    返回 空
}

函数 文件文件_注册系统类型(档, 名称, 块长, 日志, 只读, 来源) {
    如果 (!文件文件_检查档(档)) { 返回 文件文件_失败(档, "注册系统类型", "文件档不可用") }
    文件文件_记录(档, "注册系统类型", [名称, 块长, 日志, 只读, 来源], "文件文件")
    如果 (文件文件_找系统类型(档, 名称) != 空) {
        返回 文件文件_失败(档, "注册系统类型", "系统类型已存在")
    }
    定义 项 = 文件系统类型项 {}
    项.名称 = 名称
    项.块长 = 块长
    项.日志 = 日志
    项.只读 = 只读
    项.来源 = 来源
    追加(档.系统类型表, 项)
    档.系统类型数 = 档.系统类型数 + 1
    档.最近系统 = 名称
    返回 文件文件_成功(档, "注册系统类型", 项)
}

函数 文件文件_挂载(档, 路径, 系统, 设备, 模式, 来源) {
    如果 (!文件文件_检查档(档)) { 返回 文件文件_失败(档, "挂载", "文件档不可用") }
    文件文件_记录(档, "挂载", [路径, 系统, 设备, 模式, 来源], "文件文件")
    如果 (文件文件_找系统类型(档, 系统) == 空) {
        返回 文件文件_失败(档, "挂载", "文件系统类型不存在")
    }
    定义 标准路径 = 文件文件_规范路径(路径)
    如果 (文件文件_找挂载(档, 标准路径) != 空) {
        返回 文件文件_失败(档, "挂载", "挂载点已存在")
    }
    定义 项 = 挂载项 {}
    项.路径 = 标准路径
    项.系统 = 系统
    项.设备 = 设备
    项.模式 = 模式
    项.来源 = 来源
    追加(档.挂载表, 项)
    档.挂载数 = 档.挂载数 + 1
    档.最近挂载 = 标准路径
    档.最近系统 = 系统
    返回 文件文件_成功(档, "挂载", 项)
}

函数 文件文件_卸载(档, 路径) {
    如果 (!文件文件_检查档(档)) { 返回 文件文件_失败(档, "卸载", "文件档不可用") }
    文件文件_记录(档, "卸载", [路径], "文件文件")
    定义 标准路径 = 文件文件_规范路径(路径)
    定义 新表 = []
    定义 索引 = 0
    定义 命中 = 假
    当 (索引 < 计数(档.挂载表)) {
        定义 项 = 档.挂载表[索引]
        如果 (项.路径 == 标准路径) {
            命中 = 真
        } 否则 {
            追加(新表, 项)
        }
        索引 = 索引 + 1
    }
    档.挂载表 = 新表
    档.挂载数 = 计数(档.挂载表)
    如果 (!命中) { 返回 文件文件_失败(档, "卸载", "挂载点不存在") }
    返回 文件文件_成功(档, "卸载", 标准路径)
}

函数 文件文件_建文件项(路径, 系统, 模式) {
    定义 项 = 文件项 {}
    项.路径 = 文件文件_规范路径(路径)
    项.内容 = ""
    项.大小 = 0
    项.偏移 = 0
    项.打开数 = 0
    项.系统 = 系统
    项.模式 = 模式
    项.最近写入 = ""
    返回 项
}

函数 文件文件_打开(档, 路径, 系统, 模式) {
    如果 (!文件文件_检查档(档)) { 返回 文件文件_失败(档, "打开", "文件档不可用") }
    文件文件_记录(档, "打开", [路径, 系统, 模式], "文件文件")
    定义 项 = 文件文件_找文件(档, 路径)
    如果 (项 == 空) {
        项 = 文件文件_建文件项(路径, 系统, 模式)
        追加(档.文件表, 项)
        档.文件数 = 档.文件数 + 1
    }
    项.打开数 = 项.打开数 + 1
    档.打开数 = 档.打开数 + 1
    档.最近路径 = 项.路径
    返回 文件文件_成功(档, "打开", 项)
}

函数 文件文件_关闭(档, 路径) {
    如果 (!文件文件_检查档(档)) { 返回 文件文件_失败(档, "关闭", "文件档不可用") }
    文件文件_记录(档, "关闭", [路径], "文件文件")
    定义 项 = 文件文件_找文件(档, 路径)
    如果 (项 == 空) { 返回 文件文件_失败(档, "关闭", "文件不存在") }
    如果 (项.打开数 > 0) { 项.打开数 = 项.打开数 - 1 }
    档.最近路径 = 项.路径
    返回 文件文件_成功(档, "关闭", 项.打开数)
}

函数 文件文件_读取(档, 路径, 长度) {
    如果 (!文件文件_检查档(档)) { 返回 文件文件_失败(档, "读取", "文件档不可用") }
    文件文件_记录(档, "读取", [路径, 长度], "文件文件")
    定义 项 = 文件文件_找文件(档, 路径)
    如果 (项 == 空) { 返回 文件文件_失败(档, "读取", "文件不存在") }
    档.读取数 = 档.读取数 + 1
    档.最近路径 = 项.路径
    如果 (长度 <= 0 || 长度 >= 项.大小) { 返回 文件文件_成功(档, "读取", 项.内容) }
    返回 文件文件_成功(档, "读取", 子串(项.内容, 0, 长度))
}

函数 文件文件_写入(档, 路径, 内容, 模式) {
    如果 (!文件文件_检查档(档)) { 返回 文件文件_失败(档, "写入", "文件档不可用") }
    文件文件_记录(档, "写入", [路径, 内容, 模式], "文件文件")
    定义 项 = 文件文件_找文件(档, 路径)
    如果 (项 == 空) {
        项 = 文件文件_建文件项(路径, "临时", 模式)
        追加(档.文件表, 项)
        档.文件数 = 档.文件数 + 1
    }
    项.内容 = 内容
    项.大小 = 长度(内容)
    项.模式 = 模式
    项.最近写入 = 内容
    档.写入数 = 档.写入数 + 1
    档.最近路径 = 项.路径
    返回 文件文件_成功(档, "写入", 项)
}

函数 文件文件_追加(档, 路径, 内容) {
    如果 (!文件文件_检查档(档)) { 返回 文件文件_失败(档, "追加", "文件档不可用") }
    文件文件_记录(档, "追加", [路径, 内容], "文件文件")
    定义 项 = 文件文件_找文件(档, 路径)
    如果 (项 == 空) {
        项 = 文件文件_建文件项(路径, "临时", "rw")
        追加(档.文件表, 项)
        档.文件数 = 档.文件数 + 1
    }
    项.内容 = 项.内容 + 内容
    项.大小 = 长度(项.内容)
    项.最近写入 = 内容
    档.追加数 = 档.追加数 + 1
    档.最近路径 = 项.路径
    返回 文件文件_成功(档, "追加", 项)
}

函数 文件文件_加锁(档, 路径, 模式, 拥有者) {
    如果 (!文件文件_检查档(档)) { 返回 文件文件_失败(档, "加锁", "文件档不可用") }
    文件文件_记录(档, "加锁", [路径, 模式, 拥有者], "文件文件")
    定义 锁 = 文件文件_找锁(档, 路径, 拥有者)
    如果 (锁 == 空) {
        锁 = 锁项 {}
        锁.路径 = 文件文件_规范路径(路径)
        锁.模式 = 模式
        锁.拥有者 = 拥有者
        锁.次数 = 0
        追加(档.锁表, 锁)
    }
    锁.次数 = 锁.次数 + 1
    档.锁数 = 档.锁数 + 1
    档.最近路径 = 锁.路径
    返回 文件文件_成功(档, "加锁", 锁)
}

函数 文件文件_解锁(档, 路径, 拥有者) {
    如果 (!文件文件_检查档(档)) { 返回 文件文件_失败(档, "解锁", "文件档不可用") }
    文件文件_记录(档, "解锁", [路径, 拥有者], "文件文件")
    定义 锁 = 文件文件_找锁(档, 路径, 拥有者)
    如果 (锁 == 空) { 返回 文件文件_失败(档, "解锁", "锁不存在") }
    如果 (锁.次数 > 0) { 锁.次数 = 锁.次数 - 1 }
    档.解锁数 = 档.解锁数 + 1
    档.最近路径 = 锁.路径
    返回 文件文件_成功(档, "解锁", 锁.次数)
}

函数 文件文件_重命名(档, 旧路径, 新路径) {
    如果 (!文件文件_检查档(档)) { 返回 文件文件_失败(档, "重命名", "文件档不可用") }
    文件文件_记录(档, "重命名", [旧路径, 新路径], "文件文件")
    定义 项 = 文件文件_找文件(档, 旧路径)
    如果 (项 == 空) { 返回 文件文件_失败(档, "重命名", "文件不存在") }
    项.路径 = 文件文件_规范路径(新路径)
    档.最近路径 = 项.路径
    返回 文件文件_成功(档, "重命名", 项)
}

函数 文件文件_删除(档, 路径) {
    如果 (!文件文件_检查档(档)) { 返回 文件文件_失败(档, "删除", "文件档不可用") }
    文件文件_记录(档, "删除", [路径], "文件文件")
    定义 标准路径 = 文件文件_规范路径(路径)
    定义 新表 = []
    定义 索引 = 0
    定义 命中 = 假
    当 (索引 < 计数(档.文件表)) {
        定义 项 = 档.文件表[索引]
        如果 (项.路径 == 标准路径) {
            命中 = 真
        } 否则 {
            追加(新表, 项)
        }
        索引 = 索引 + 1
    }
    档.文件表 = 新表
    档.文件数 = 计数(档.文件表)
    如果 (!命中) { 返回 文件文件_失败(档, "删除", "文件不存在") }
    档.删除数 = 档.删除数 + 1
    档.最近路径 = 标准路径
    返回 文件文件_成功(档, "删除", 标准路径)
}

函数 文件文件_挂载摘要(档) {
    如果 (!文件文件_检查档(档)) { 返回 文件文件_失败(档, "挂载摘要", "文件档不可用") }
    文件文件_记录(档, "挂载摘要", [], "文件文件")
    定义 结果 = []
    定义 索引 = 0
    当 (索引 < 计数(档.挂载表)) {
        定义 项 = 档.挂载表[索引]
        追加(结果, [项.路径, 项.系统, 项.设备, 项.模式])
        索引 = 索引 + 1
    }
    返回 文件文件_成功(档, "挂载摘要", 结果)
}

函数 文件文件_摘要(档) {
    定义 摘要 = 文件摘要 {}
    摘要.名称 = 档.名称
    摘要.系统类型数 = 档.系统类型数
    摘要.挂载数 = 档.挂载数
    摘要.文件数 = 档.文件数
    摘要.打开数 = 档.打开数
    摘要.读取数 = 档.读取数
    摘要.写入数 = 档.写入数
    摘要.追加数 = 档.追加数
    摘要.删除数 = 档.删除数
    摘要.锁数 = 档.锁数
    摘要.解锁数 = 档.解锁数
    摘要.成功数 = 档.成功数
    摘要.失败数 = 档.失败数
    摘要.健康 = 文件文件_刷新健康(档)
    返回 摘要
}

函数 文件文件_初始化(档) {
    如果 (!文件文件_检查档(档)) { 返回 文件文件_失败(档, "初始化", "文件档不可用") }
    文件文件_记录(档, "初始化", [], "文件文件")
    档.系统类型表 = []
    档.挂载表 = []
    档.文件表 = []
    档.锁表 = []
    档.系统类型数 = 0
    档.挂载数 = 0
    档.文件数 = 0
    档.是否初始化 = 真
    文件文件_注册系统类型(档, "觉存", 4096, 真, 假, "初始化")
    文件文件_注册系统类型(档, "白璃", 4096, 假, 假, "初始化")
    文件文件_挂载(档, "/", "觉存", "根盘", "rw", "初始化")
    文件文件_挂载(档, "/资源", "白璃", "资源盘", "rw", "初始化")
    返回 文件文件_成功(档, "初始化", "已初始化")
}

函数 文件文件_自检(档) {
    如果 (!文件文件_检查档(档)) { 返回 假 }
    如果 (文件文件_初始化(档).已成 == 假) { 返回 假 }
    如果 (文件文件_打开(档, "/资源/界面.css", "白璃", "rw").已成 == 假) { 返回 假 }
    如果 (文件文件_写入(档, "/资源/界面.css", ".白璃窗{backdrop-filter:blur(20px);}", "rw").已成 == 假) { 返回 假 }
    如果 (文件文件_追加(档, "/资源/界面.css", ".白璃卡{border-radius:22px;}").已成 == 假) { 返回 假 }
    如果 (文件文件_读取(档, "/资源/界面.css", 12).已成 == 假) { 返回 假 }
    如果 (文件文件_加锁(档, "/资源/界面.css", "写锁", "界面线程").已成 == 假) { 返回 假 }
    如果 (文件文件_解锁(档, "/资源/界面.css", "界面线程").已成 == 假) { 返回 假 }
    如果 (文件文件_重命名(档, "/资源/界面.css", "/资源/白璃.css").已成 == 假) { 返回 假 }
    如果 (文件文件_关闭(档, "/资源/白璃.css").已成 == 假) { 返回 假 }
    返回 真
}

函数 文件文件_处理(档, 请求) {
    如果 (请求 == 空) { 返回 文件文件_失败(档, "处理", "请求为空") }
    如果 (请求.动作 == "初始化") { 返回 文件文件_初始化(档) }
    如果 (请求.动作 == "注册系统类型") { 返回 文件文件_注册系统类型(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3], 请求.参数[4]) }
    如果 (请求.动作 == "挂载") { 返回 文件文件_挂载(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3], 请求.参数[4]) }
    如果 (请求.动作 == "卸载") { 返回 文件文件_卸载(档, 请求.参数[0]) }
    如果 (请求.动作 == "打开") { 返回 文件文件_打开(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "关闭") { 返回 文件文件_关闭(档, 请求.参数[0]) }
    如果 (请求.动作 == "读取") { 返回 文件文件_读取(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "写入") { 返回 文件文件_写入(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "追加") { 返回 文件文件_追加(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "加锁") { 返回 文件文件_加锁(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "解锁") { 返回 文件文件_解锁(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "重命名") { 返回 文件文件_重命名(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "删除") { 返回 文件文件_删除(档, 请求.参数[0]) }
    如果 (请求.动作 == "挂载摘要") { 返回 文件文件_挂载摘要(档) }
    如果 (请求.动作 == "摘要") { 返回 文件文件_成功(档, "摘要", 文件文件_摘要(档)) }
    返回 文件文件_失败(档, "处理", "未知动作")
}

定义 可变 AI_文件文件_热文件表 = []

函数 AI_文件文件_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_文件文件_热文件表)) {
        如果 (AI_文件文件_热文件表[i].路径 == 路径) {
            AI_文件文件_热文件表[i].频率 = AI_文件文件_热文件表[i].频率 + 1
            返回 AI_文件文件_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_文件文件_热文件表) < 128) {
        追加(AI_文件文件_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_文件文件_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

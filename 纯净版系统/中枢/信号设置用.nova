导入("./类型定义.nova")
导入("./错误码.nova")
导入("../执行/底层内存操.nova")
导入("./进程描述符.nova")
导入("./每处理器.nova")

定义 信号_中断 = 2
定义 信号_非法 = 4
定义 信号_终止 = 9
定义 信号_段错 = 11
定义 信号_管道 = 13
定义 信号_闹钟 = 14
定义 信号_终了 = 15
定义 信号_子进程 = 17
定义 信号_用户1 = 10
定义 信号_用户2 = 12
定义 最大信号 = 64
定义 帧大小 = 512
定义 帧对齐 = 16

结构 信号动作 {
    处理地址,
    屏蔽字,
    标志,
}

结构 信号帧 {
    返回地址,
    信号号,
    保存屏蔽,
    保存指令指针,
    保存栈指针,
    保存基址指针,
    保存通用寄存器,
}

定义 可变 动作表 = 0
定义 可变 挂起掩码 = 0
定义 可变 屏蔽掩码 = 0
定义 可变 发送总数 = 0
定义 可变 递交总数 = 0
定义 可变 忽略总数 = 0
定义 可变 帧构建数 = 0

函数 信号_初始化() {
    动作表 = 堆_分配(最大信号 * 24)
    内存_清零(动作表, 最大信号 * 24)
    挂起掩码 = 0
    屏蔽掩码 = 0
}

函数 信号_设动作(信号号, 处理地址, 屏蔽, 标志) {
    如果 (信号号 >= 最大信号 || 信号号 == 信号_终止) { 返回 错误_无效参数 }
    定义 偏移 = 动作表 + 信号号 * 24
    内存_写64(偏移, 处理地址)
    内存_写64(偏移 + 8, 屏蔽)
    内存_写64(偏移 + 16, 标志)
    返回 0
}

函数 信号_获取动作(信号号) {
    如果 (信号号 >= 最大信号) { 返回 0 }
    返回 内存_读64(动作表 + 信号号 * 24)
}

函数 信号_发送(任务指针, 信号号) {
    如果 (信号号 >= 最大信号) { 返回 错误_无效参数 }
    发送总数 = 发送总数 + 1
    如果 (信号号 == 信号_终止) {
        信号_强制终止(任务指针)
        返回 0
    }
    挂起掩码 = 挂起掩码 | (1 << 信号号)
    返回 0
}

函数 信号_递交(任务指针, 寄存器指针) {
    如果 (挂起掩码 == 0) { 返回 }
    定义 可递交 = 挂起掩码 & ~屏蔽掩码
    如果 (可递交 == 0) { 返回 }
    定义 可变 信号号 = 0
    当 (信号号 < 最大信号) {
        如果 ((可递交 & (1 << 信号号)) != 0) {
            挂起掩码 = 挂起掩码 & ~(1 << 信号号)
            定义 处理地址 = 信号_获取动作(信号号)
            如果 (处理地址 == 0) {
                信号_默认动作(任务指针, 信号号)
            } 否则 如果 (处理地址 == 1) {
                忽略总数 = 忽略总数 + 1
            } 否则 {
                信号_设置用户帧(任务指针, 寄存器指针, 信号号, 处理地址)
            }
            递交总数 = 递交总数 + 1
            返回
        }
        信号号 = 信号号 + 1
    }
}

函数 信号_设置用户帧(任务指针, 寄存器指针, 信号号, 处理地址) {
    帧构建数 = 帧构建数 + 1
    定义 用户栈 = 内存_读64(寄存器指针 + 32)
    定义 帧地址 = (用户栈 - 帧大小) & ~(帧对齐 - 1)
    内存_写64(帧地址, 0)
    内存_写64(帧地址 + 8, 信号号)
    内存_写64(帧地址 + 16, 屏蔽掩码)
    内存_写64(帧地址 + 24, 内存_读64(寄存器指针))
    内存_写64(帧地址 + 32, 用户栈)
    内存_写64(帧地址 + 40, 内存_读64(寄存器指针 + 8))
    定义 可变 保存序号 = 0
    当 (保存序号 < 8) {
        内存_写64(帧地址 + 48 + 保存序号 * 8, 内存_读64(寄存器指针 + 保存序号 * 8))
        保存序号 = 保存序号 + 1
    }
    定义 屏蔽偏移 = 动作表 + 信号号 * 24 + 8
    屏蔽掩码 = 屏蔽掩码 | 内存_读64(屏蔽偏移) | (1 << 信号号)
    内存_写64(寄存器指针, 处理地址)
    内存_写64(寄存器指针 + 32, 帧地址)
    内存_写64(寄存器指针 + 56, 信号号)
}

函数 信号_返回(寄存器指针) {
    定义 帧地址 = 内存_读64(寄存器指针 + 32)
    屏蔽掩码 = 内存_读64(帧地址 + 16)
    内存_写64(寄存器指针, 内存_读64(帧地址 + 24))
    内存_写64(寄存器指针 + 32, 内存_读64(帧地址 + 32))
    内存_写64(寄存器指针 + 8, 内存_读64(帧地址 + 40))
    定义 可变 恢复序号 = 0
    当 (恢复序号 < 8) {
        内存_写64(寄存器指针 + 恢复序号 * 8, 内存_读64(帧地址 + 48 + 恢复序号 * 8))
        恢复序号 = 恢复序号 + 1
    }
}

函数 信号_默认动作(任务指针, 信号号) {
    如果 (信号号 == 信号_终止 || 信号号 == 信号_段错 || 信号号 == 信号_非法) {
        信号_强制终止(任务指针)
    } 否则 如果 (信号号 == 信号_子进程) {
        忽略总数 = 忽略总数 + 1
    } 否则 {
        信号_强制终止(任务指针)
    }
}

函数 信号_强制终止(任务指针) {
    定义 当前 = 获取当前进程()
    如果 (当前 != 0) { 进程_设置状态(当前, 进程态_僵尸) }
}

函数 信号_查挂起() {
    返回 挂起掩码 & ~屏蔽掩码
}

函数 信号_设屏蔽(新屏蔽) {
    定义 旧 = 屏蔽掩码
    屏蔽掩码 = 新屏蔽
    返回 旧
}

函数 信号_暂停(临时屏蔽) {
    定义 旧屏蔽 = 屏蔽掩码
    屏蔽掩码 = 临时屏蔽
    // 挂起当前进程，等待信号唤醒
    系统调用(34, 0, 0, 0, 0, 0, 0)  // SYS_pause
    屏蔽掩码 = 旧屏蔽
}

函数 信号_完整统计() {
    返回 [发送总数, 递交总数, 忽略总数, 帧构建数, 挂起掩码, 屏蔽掩码]
}

定义 可变 AI_信号设置用_带宽估计 = 0
定义 可变 AI_信号设置用_丢包窗口 = []

函数 AI_信号设置用_带宽预测(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 AI_信号设置用_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    AI_信号设置用_带宽估计 = AI_信号设置用_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 AI_信号设置用_带宽估计
}

函数 AI_信号设置用_拥塞建议(丢包率) {
    追加(AI_信号设置用_丢包窗口, 丢包率)
    如果 (计数(AI_信号设置用_丢包窗口) > 10) { 列表_移除(AI_信号设置用_丢包窗口, 0) }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}

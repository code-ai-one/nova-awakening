    返回 映射页_内核(档.页表, 虚拟地址, 物理地址, 标志)
}

函数 内存虚拟_取消内核页(档, 虚拟地址) {
    档.取消数 = 档.取消数 + 1
    返回 取消映射页_内核(档.页表, 虚拟地址)
}

函数 内存虚拟_查内核(档, 虚拟地址) {
    返回 查页表_虚拟到物理(虚拟地址)
}

函数 内存虚拟_内核详情(档, 虚拟地址) {
    返回 查页表_完整(虚拟地址)
}

函数 内存虚拟_判用户地址(地址) { 返回 地址 <= 用户空间_顶部 }
函数 内存虚拟_判内核地址(地址) { 返回 地址 >= 内核空间_底部 }
函数 内存虚拟_判直接映射(地址) { 返回 地址 >= 直接映射_底部 && 地址 < 直接映射_顶部 }
函数 内存虚拟_判vmalloc(地址) { 返回 地址 >= VMALLOC_底部 && 地址 < VMALLOC_顶部 }

函数 内存虚拟_处理缺页(档, 错误地址, 错误码, 寄存器) {
    档.缺页数 = 档.缺页数 + 1
    返回 缺页异常处理(错误地址, 错误码, 寄存器)
}

函数 内存虚拟_处理COW(档, mm, vma, 错误地址, 旧pte) {
    档.COW数 = 档.COW数 + 1
    返回 处理COW缺页(mm, vma, 错误地址, 旧pte)
}

函数 内存虚拟_处理文件缺页(档, mm, vma, 错误地址, 错误码) {

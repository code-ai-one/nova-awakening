// NovaOS 调度域内负载均衡 — AI增强多级拓扑均衡引擎
// 本模块实现调度域层级结构内的负载均衡策略:
//   1. 多级调度域(SMT→Core→LLC→NUMA)层级化均衡
//   2. AI驱动的负载预测与迁移决策
//   3. 缓存亲和性感知的任务选择
//   4. 功耗感知的能效均衡(EAS)
//   5. 实时任务/Deadline任务特殊处理
//   6. 自适应均衡间隔调整
// 与运行队列时钟、AI调度钩子、中断系统、内存管理深度耦合。

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./日志中枢.nova")
导入("./同步原语.nova")
导入("./时钟中枢.nova")
导入("./中断管理系统.nova")
导入("./内存虚拟.nova")
导入("./每处理器.nova")
导入("./进程调度.nova")
导入("../执行/内核智能.nova")
导入("./公共智能.nova")
导入("./运行队列更新.nova")
导入("./内核打印.nova")
导入("./运行队列初.nova")
导入("./整数转字符串.nova")

// §1 调度域层级常量与结构

定义 域级别_SMT  = 0
定义 域级别_MC   = 1
定义 域级别_LLC  = 2
定义 域级别_NUMA = 3
定义 域级别_最大 = 4

定义 均衡标志_忙碌 = 0x01
定义 均衡标志_空闲 = 0x02
定义 均衡标志_新空闲 = 0x04
定义 均衡标志_唤醒 = 0x08

定义 迁移类型_拉取 = 0
定义 迁移类型_推送 = 1
定义 迁移类型_主动 = 2

定义 LB_最大重试 = 3
定义 LB_缓存冷却_纳秒 = 2000000
定义 LB_自适应_最小间隔 = 2
定义 LB_自适应_最大间隔 = 128
定义 EAS_功耗权重 = 30

结构 调度域 {
    级别,
    名称,
    CPU列表,
    CPU数,
    不均衡阈值,
    均衡间隔,
    最小均衡间隔,
    最大均衡间隔,
    父域,
    子域列表,
    标志,
    // 统计
    均衡次数,
    均衡成功,
    均衡失败,
    累计迁移数,
    平均不均衡度,
    // AI增强
    AI预测负载,
    AI均衡置信度,
    自适应间隔,
    上次均衡时间,
}

结构 CPU组 {
    组长CPU,
    CPU列表,
    CPU数,
    容量,
    负载,
    利用率,
    类型,
}

结构 均衡环境 {
    源域,
    目标CPU,
    类型,
    空闲状态,
    最忙组,
    最忙rq,
    迁移数,
    循环次数,
}

// §2 全局状态与统计

定义 可变 lb_尝试次数 = 0
定义 可变 lb_成功次数 = 0
定义 可变 lb_失败次数 = 0
定义 可变 lb_拉取迁移 = 0
定义 可变 lb_推送迁移 = 0
定义 可变 lb_热迁移跳过 = 0
定义 可变 lb_亲和跳过 = 0
定义 可变 lb_AI拒绝 = 0
定义 可变 lb_功耗节省 = 0
定义 可变 lb_上次均衡时间 = []
定义 可变 所有调度域 = []

// §3 调度域创建与拓扑构建

函数 调度域_创建(级别, CPU列表) {
    定义 名称表 = ["SMT", "MC", "LLC", "NUMA"]
    定义 阈值表 = [15, 25, 30, 40]
    定义 间隔表 = [2, 4, 8, 32]

    定义 域 = 调度域 {
        级别: 级别,
        名称: 名称表[级别],
        CPU列表: CPU列表,
        CPU数: 计数(CPU列表),
        不均衡阈值: 阈值表[级别],
        均衡间隔: 间隔表[级别],
        最小均衡间隔: 间隔表[级别],
        最大均衡间隔: 间隔表[级别] * 16,
        父域: 空,
        子域列表: [],
        标志: 0,
        均衡次数: 0,
        均衡成功: 0,
        均衡失败: 0,
        累计迁移数: 0,
        平均不均衡度: 0,
        AI预测负载: [],
        AI均衡置信度: 0,
        自适应间隔: 间隔表[级别],
        上次均衡时间: 0,
    }
    // 初始化AI预测负载数组
    定义 可变 i = 0
    当 (i < 计数(CPU列表)) {
        追加(域.AI预测负载, 0)
        i = i + 1
    }
    追加(所有调度域, 域)
    返回 域
}

函数 调度域_构建拓扑(在线CPU数, 每核线程, 每LLC核数) {
    // 层级: SMT → MC(多核) → LLC(共享缓存) → NUMA
    定义 可变 cpu = 0

    // SMT域: 每对超线程
    当 (cpu < 在线CPU数) {
        定义 smt列表 = []
        定义 可变 t = 0
        当 (t < 每核线程 && (cpu + t) < 在线CPU数) {
            追加(smt列表, cpu + t)
            t = t + 1
        }
        如果 (计数(smt列表) > 1) {
            调度域_创建(域级别_SMT, smt列表)
        }
        cpu = cpu + 每核线程
    }

    // MC域: 每LLC区域的核心
    cpu = 0
    当 (cpu < 在线CPU数) {
        定义 mc列表 = []
        定义 可变 c = 0
        当 (c < 每LLC核数 * 每核线程 && (cpu + c) < 在线CPU数) {
            追加(mc列表, cpu + c)
            c = c + 1
        }
        调度域_创建(域级别_MC, mc列表)
        cpu = cpu + 每LLC核数 * 每核线程
    }

    // NUMA域: 全部CPU(单节点简化)
    定义 全部CPU = []
    cpu = 0
    当 (cpu < 在线CPU数) {
        追加(全部CPU, cpu)
        cpu = cpu + 1
    }
    如果 (在线CPU数 > 每LLC核数 * 每核线程) {
        调度域_创建(域级别_NUMA, 全部CPU)
    }

    // 建立父子关系
    定义 可变 i = 0
    当 (i < 计数(所有调度域)) {
        定义 可变 j = i + 1
        当 (j < 计数(所有调度域)) {
            如果 (所有调度域[j].级别 > 所有调度域[i].级别) {
                定义 包含 = 域_包含检查(所有调度域[j], 所有调度域[i])
                如果 (包含) {
                    所有调度域[i].父域 = 所有调度域[j]
                    追加(所有调度域[j].子域列表, 所有调度域[i])
                    跳出
                }
            }
            j = j + 1
        }
        i = i + 1
    }

    内核打印("[调度域] 拓扑构建完成: " + 整数转字符串(计数(所有调度域)) + "个域")
}

函数 域_包含检查(外域, 内域) {
    定义 可变 i = 0
    当 (i < 计数(内域.CPU列表)) {
        定义 可变 找到 = 假
        定义 可变 j = 0
        当 (j < 计数(外域.CPU列表)) {
            如果 (外域.CPU列表[j] == 内域.CPU列表[i]) { 找到 = 真; 跳出 }
            j = j + 1
        }
        如果 (!找到) { 返回 假 }
        i = i + 1
    }
    返回 真
}

// §4 负载度量计算

函数 获取CPU负载(cpu) {
    如果 (cpu < 计数(所有运行队列)) {
        返回 所有运行队列[cpu].负载权重
    }
    返回 0
}

函数 获取CPU负载_加权(cpu) {
    如果 (cpu >= 计数(所有运行队列)) { 返回 0 }
    定义 rq = 所有运行队列[cpu]
    // 加权负载: Nova公平调度负载 + RT负载*2 + DL负载*3
    定义 cfs = rq.Nova公平调度_load
    定义 rt = rq.rt_load * 2
    返回 cfs + rt
}

函数 获取CPU利用率(cpu) {
    如果 (cpu >= 计数(所有运行队列)) { 返回 0 }
    定义 rq = 所有运行队列[cpu]
    返回 CPU时间核算_利用率(rq.时间核算)
}

函数 获取CPU容量(cpu) {
    如果 (cpu >= 计数(所有运行队列)) { 返回 1024 }
    // 基础容量1024, 根据频率和温度调整
    定义 基础 = 1024
    定义 频率因子 = 获取CPU频率比(cpu)
    返回 基础 * 频率因子 / 100
}

函数 计算组负载(组) {
    定义 可变 总负载 = 0
    定义 可变 总容量 = 0
    定义 可变 总利用 = 0
    定义 可变 i = 0
    当 (i < 计数(组.CPU列表)) {
        定义 cpu = 组.CPU列表[i]
        总负载 = 总负载 + 获取CPU负载_加权(cpu)
        总容量 = 总容量 + 获取CPU容量(cpu)
        总利用 = 总利用 + 获取CPU利用率(cpu)
        i = i + 1
    }
    组.负载 = 总负载
    组.容量 = 总容量
    组.利用率 = 总利用 / 计数(组.CPU列表)
    返回 总负载
}

// §5 核心均衡算法

函数 域内均衡(域, this_cpu) {
    如果 (域 == 空 || 计数(域.CPU列表) <= 1) { 返回 }
    域.均衡次数 = 域.均衡次数 + 1
    lb_尝试次数 = lb_尝试次数 + 1

    // 1. 收集域内所有CPU的多维负载信息
    定义 可变 CPU负载表 = []
    定义 可变 最忙CPU = -1
    定义 可变 最大负载 = 0
    定义 可变 最闲CPU = -1
    定义 可变 最小负载 = 0x7FFFFFFF
    定义 可变 本CPU负载 = 0
    定义 可变 总负载 = 0
    定义 可变 总容量 = 0
    定义 CPU数 = 计数(域.CPU列表)

    定义 可变 i = 0
    当 (i < CPU数) {
        定义 cpu = 域.CPU列表[i]
        定义 负载 = 获取CPU负载_加权(cpu)
        定义 容量 = 获取CPU容量(cpu)
        定义 利用率 = 获取CPU利用率(cpu)
        追加(CPU负载表, { cpu: cpu, 负载: 负载, 容量: 容量, 利用率: 利用率 })
        总负载 = 总负载 + 负载
        总容量 = 总容量 + 容量
        如果 (cpu == this_cpu) { 本CPU负载 = 负载 }
        如果 (负载 > 最大负载) {
            最大负载 = 负载
            最忙CPU = cpu
        }
        如果 (负载 < 最小负载) {
            最小负载 = 负载
            最闲CPU = cpu
        }
        i = i + 1
    }

    // 2. 计算均衡指标
    如果 (CPU数 <= 0) { 返回 }
    定义 平均负载 = 总负载 / CPU数
    定义 不均衡度 = 0
    如果 (平均负载 > 0) {
        不均衡度 = (最大负载 - 最小负载) * 100 / 平均负载
    }

    // 更新指数移动平均不均衡度
    域.平均不均衡度 = (域.平均不均衡度 * 7 + 不均衡度) / 8

    // 3. AI预测: 预测未来负载趋势
    定义 AI建议 = AI均衡_预测(域, CPU负载表, this_cpu)
    域.AI均衡置信度 = AI建议.置信度

    // 4. 判断是否需要均衡
    如果 (最忙CPU == this_cpu || 最忙CPU == -1) { 返回 }
    如果 (平均负载 <= 0) { 返回 }

    // 动态阈值: 基于域级别和AI建议调整
    定义 有效阈值 = 域.不均衡阈值
    如果 (AI建议.建议迁移 && AI建议.置信度 > 70) {
        有效阈值 = 有效阈值 * 80 / 100
    }
    如果 (不均衡度 < 有效阈值) {
        // 自适应: 不均衡度低时增加均衡间隔
        域.自适应间隔 = 域.自适应间隔 * 3 / 2
        如果 (域.自适应间隔 > 域.最大均衡间隔) {
            域.自适应间隔 = 域.最大均衡间隔
        }
        返回
    }

    // 不均衡度高时缩短间隔
    域.自适应间隔 = 域.自适应间隔 * 2 / 3
    如果 (域.自适应间隔 < 域.最小均衡间隔) {
        域.自适应间隔 = 域.最小均衡间隔
    }

    // 5. 功耗感知: EAS能效检查
    如果 (EAS_功耗权重 > 0) {
        定义 功耗收益 = EAS_评估迁移功耗(最忙CPU, this_cpu, 最大负载, 本CPU负载)
        如果 (功耗收益 < 0) {
            lb_功耗节省 = lb_功耗节省 + 1
            返回
        }
    }

    // 6. 执行迁移
    定义 可变 重试 = 0
    定义 可变 已迁移 = 0
    当 (重试 < LB_最大重试 && 已迁移 == 0) {
        定义 迁移结果 = 调度域_迁移任务(最忙CPU, this_cpu)
        如果 (迁移结果 == 成功) {
            已迁移 = 1
            lb_成功次数 = lb_成功次数 + 1
            lb_拉取迁移 = lb_拉取迁移 + 1
            域.均衡成功 = 域.均衡成功 + 1
            域.累计迁移数 = 域.累计迁移数 + 1

            // AI在线学习: 记录成功迁移
            AI调度_记录迁移(0, 最忙CPU, this_cpu, 最大负载, 本CPU负载)
        } 否则 {
            重试 = 重试 + 1
        }
    }

    如果 (已迁移 == 0) {
        lb_失败次数 = lb_失败次数 + 1
        域.均衡失败 = 域.均衡失败 + 1
    }
}

// §6 任务迁移选择与执行

函数 调度域_迁移任务(源CPU, 目标CPU) {
    如果 (源CPU >= 计数(所有运行队列)) { 返回 错误_无效参数 }
    定义 源rq = 所有运行队列[源CPU]
    如果 (源rq.nr_running <= 1) { 返回 错误_资源不足 }

    // 选择最佳迁移候选: 综合优先级、缓存热度、亲和性
    定义 候选 = 迁移_选择最优(源rq, 目标CPU)
    如果 (候选 == 空) { 返回 错误_不存在 }

    // CPU亲和性检查
    如果 (候选.cpu_mask != 空 && !(候选.cpu_mask & (1 << 目标CPU))) {
        lb_亲和跳过 = lb_亲和跳过 + 1
        返回 错误_权限不足
    }

    // 缓存热度检查: 最近被调度的任务不迁移
    如果 (候选.上次调度时间 > 0) {
        定义 冷却时间 = 源rq.clock - 候选.上次调度时间
        如果 (冷却时间 < LB_缓存冷却_纳秒) {
            lb_热迁移跳过 = lb_热迁移跳过 + 1
            返回 错误_资源忙
        }
    }

    // 执行实际迁移
    定义 目rq = 所有运行队列[目标CPU]
    双运行队列_锁定(源rq, 目rq)

    运行队列_出队(源rq, 候选)
    候选.上次迁移时间 = 源rq.clock
    候选.迁移次数 = 候选.迁移次数 + 1
    进程_设置CPU(候选, 目标CPU)
    运行队列_入队(目rq, 候选)

    双运行队列_解锁(源rq, 目rq)

    内核调试("LB: 迁移PID" + 整数转字符串(候选.pid) + " CPU" +
             整数转字符串(源CPU) + "→" + 整数转字符串(目标CPU) +
             " 负载:" + 整数转字符串(候选.负载权重))
    返回 成功
}

函数 迁移_选择最优(源rq, 目标CPU) {
    定义 任务列表 = 源rq.Nova公平调度_任务列表
    如果 (计数(任务列表) == 0) { 返回 空 }

    定义 可变 最优 = 空
    定义 可变 最优分数 = 0x7FFFFFFF

    定义 可变 i = 0
    当 (i < 计数(任务列表)) {
        定义 p = 任务列表[i]
        如果 (p == 源rq.curr) { i = i + 1; 继续 }

        // 不迁移: RT任务、正在退出的、刚迁移过的
        如果 (p.调度类 == 调度类_RT) { i = i + 1; 继续 }
        如果 (p.状态 == 进程_僵尸) { i = i + 1; 继续 }

        // 评分: 越低越适合迁移
        定义 可变 分数 = 0
        // 缓存热度惩罚(高热度=不适合迁移)
        分数 = 分数 + p.缓存热度 * 10
        // 优先级越低越适合(nice值越高)
        分数 = 分数 + (140 - p.优先级) * 5
        // 负载权重越大越值得迁移(降分)
        分数 = 分数 - p.负载权重 / 100
        // 迁移次数惩罚(避免反复迁移)
        分数 = 分数 + p.迁移次数 * 50

        如果 (分数 < 最优分数) {
            最优分数 = 分数
            最优 = p
        }
        i = i + 1
    }
    返回 最优
}

// §7 AI增强负载预测

结构 AI均衡建议 {
    建议迁移,
    置信度,
    预测负载趋势,
    推荐目标CPU,
}

函数 AI均衡_预测(域, CPU负载表, this_cpu) {
    // 使用历史负载趋势预测未来不均衡
    定义 可变 趋势上升数 = 0
    定义 可变 趋势下降数 = 0
    定义 可变 i = 0
    当 (i < 计数(CPU负载表)) {
        定义 cpu = CPU负载表[i].cpu
        定义 当前 = CPU负载表[i].负载
        定义 预测 = 0
        如果 (i < 计数(域.AI预测负载)) {
            预测 = 域.AI预测负载[i]
        }
        如果 (当前 > 预测) { 趋势上升数 = 趋势上升数 + 1 }
        否则 { 趋势下降数 = 趋势下降数 + 1 }
        // 更新预测: 指数加权移动平均
        如果 (i < 计数(域.AI预测负载)) {
            域.AI预测负载[i] = (域.AI预测负载[i] * 3 + 当前) / 4
        }
        i = i + 1
    }

    定义 建议迁移 = (趋势上升数 > 趋势下降数)
    定义 置信度 = 50
    如果 (趋势上升数 + 趋势下降数 > 0) {
        定义 偏差 = 趋势上升数 - 趋势下降数
        如果 (偏差 < 0) { 偏差 = -偏差 }
        置信度 = 50 + 偏差 * 50 / (趋势上升数 + 趋势下降数)
    }

    返回 AI均衡建议 {
        建议迁移: 建议迁移,
        置信度: 置信度,
        预测负载趋势: 趋势上升数 - 趋势下降数,
        推荐目标CPU: this_cpu,
    }
}

// §8 功耗感知均衡(EAS)

函数 EAS_评估迁移功耗(源CPU, 目标CPU, 源负载, 目标负载) {
    // 估算迁移前后的总功耗变化
    定义 源容量 = 获取CPU容量(源CPU)
    定义 目标容量 = 获取CPU容量(目标CPU)

    // 简化功耗模型: P ∝ 利用率²×容量
    定义 迁移量 = 源负载 / 4
    定义 迁移前_源功耗 = (源负载 * 源负载) / 源容量
    定义 迁移前_目标功耗 = (目标负载 * 目标负载) / 目标容量
    定义 迁移后_源功耗 = ((源负载 - 迁移量) * (源负载 - 迁移量)) / 源容量
    定义 迁移后_目标功耗 = ((目标负载 + 迁移量) * (目标负载 + 迁移量)) / 目标容量

    定义 功耗变化 = (迁移后_源功耗 + 迁移后_目标功耗) - (迁移前_源功耗 + 迁移前_目标功耗)
    返回 -功耗变化
}

// §9 周期性均衡触发

函数 均衡_定时检查(this_cpu) {
    定义 当前时间 = 读取毫秒()
    定义 可变 i = 0
    当 (i < 计数(所有调度域)) {
        定义 sd = 所有调度域[i]
        // 检查this_cpu是否在此域中
        定义 可变 在域中 = 假
        定义 可变 j = 0
        当 (j < 计数(sd.CPU列表)) {
            如果 (sd.CPU列表[j] == this_cpu) { 在域中 = 真; 跳出 }
            j = j + 1
        }
        如果 (!在域中) { i = i + 1; 继续 }

        // 使用自适应间隔
        定义 间隔 = sd.自适应间隔
        如果 (间隔 < LB_自适应_最小间隔) { 间隔 = LB_自适应_最小间隔 }

        如果 (i < 计数(lb_上次均衡时间)) {
            如果 (当前时间 - lb_上次均衡时间[i] < 间隔) {
                i = i + 1
                继续
            }
        } 否则 {
            当 (计数(lb_上次均衡时间) <= i) { 追加(lb_上次均衡时间, 0) }
        }

        lb_上次均衡时间[i] = 当前时间
        sd.上次均衡时间 = 当前时间
        域内均衡(sd, this_cpu)
        i = i + 1
    }
}

函数 均衡_空闲触发(this_cpu) {
    // CPU进入空闲时立即尝试拉取任务(new-idle balancing)
    定义 可变 i = 0
    当 (i < 计数(所有调度域)) {
        定义 sd = 所有调度域[i]
        定义 可变 在域中 = 假
        定义 可变 j = 0
        当 (j < 计数(sd.CPU列表)) {
            如果 (sd.CPU列表[j] == this_cpu) { 在域中 = 真; 跳出 }
            j = j + 1
        }
        如果 (在域中) {
            域内均衡(sd, this_cpu)
        }
        i = i + 1
    }
}

// §10 统计与诊断

函数 均衡_统计() {
    返回 {
        尝试: lb_尝试次数,
        成功: lb_成功次数,
        失败: lb_失败次数,
        拉取迁移: lb_拉取迁移,
        推送迁移: lb_推送迁移,
        热缓存跳过: lb_热迁移跳过,
        亲和跳过: lb_亲和跳过,
        AI拒绝: lb_AI拒绝,
        功耗节省: lb_功耗节省,
        域数: 计数(所有调度域),
    }
}

函数 均衡_域统计(域索引) {
    如果 (域索引 >= 计数(所有调度域)) { 返回 空 }
    定义 sd = 所有调度域[域索引]
    返回 {
        名称: sd.名称,
        级别: sd.级别,
        CPU数: sd.CPU数,
        均衡次数: sd.均衡次数,
        均衡成功: sd.均衡成功,
        均衡失败: sd.均衡失败,
        累计迁移: sd.累计迁移数,
        平均不均衡度: sd.平均不均衡度,
        自适应间隔: sd.自适应间隔,
        AI置信度: sd.AI均衡置信度,
    }
}

函数 均衡_全域诊断() {
    定义 可变 报告 = []
    定义 可变 i = 0
    当 (i < 计数(所有调度域)) {
        定义 sd = 所有调度域[i]
        定义 可变 状态 = "正常"
        如果 (sd.均衡次数 > 100 && sd.均衡失败 * 100 / sd.均衡次数 > 50) {
            状态 = "均衡失败率过高"
        }
        如果 (sd.平均不均衡度 > 80) {
            状态 = "严重不均衡"
        }
        追加(报告, { 域: sd.名称, CPU: sd.CPU列表, 状态: 状态, 不均衡度: sd.平均不均衡度 })
        i = i + 1
    }
    返回 报告
}

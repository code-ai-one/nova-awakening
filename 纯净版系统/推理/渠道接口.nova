导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/自动扩容.nova")
导入("../中枢/整数转字符串.nova")
导入("../标准/原生列表.nova")

定义 渠道类型_终端   = "terminal"
定义 渠道类型_WebChat = "webchat"
定义 渠道类型_Telegram = "telegram"
定义 渠道类型_接口     = "api"
定义 渠道类型_微信     = "wechat"
定义 渠道类型_钉钉     = "dingtalk"

定义 渠道状态_停止 = "停止"
定义 渠道状态_运行 = "运行"
定义 渠道状态_暂停 = "暂停"
定义 渠道状态_错误 = "错误"

定义 渠道_默认速率限制 = 60
定义 渠道_默认队列容量 = 256
定义 渠道_健康检查间隔 = 30000

结构 渠道适配器 {
    名称,
    类型,
    接收函数,
    发送函数,
    状态,
    配置,
    发送队列,
    接收队列,
    速率限制_每分钟,
    速率_当前计数,
    速率_重置时间,
    总接收数,
    总发送数,
    总失败数,
    最后活跃时间,
    错误信息,
    健康回调,
}

定义 可变 渠道注册表 = 字典()
定义 可变 渠道注册表_计数 = 0
定义 可变 渠道接口_广播数 = 0
定义 可变 渠道接口_健康巡检数 = 0
定义 可变 渠道接口_最后错误 = ""

函数 渠道_创建(名称, 类型, 接收函数, 发送函数) {
    返回 渠道适配器 {
        名称: 名称,
        类型: 类型,
        接收函数: 接收函数,
        发送函数: 发送函数,
        状态: 渠道状态_停止,
        配置: 字典(),
        发送队列: [],
        接收队列: [],
        速率限制_每分钟: 渠道_默认速率限制,
        速率_当前计数: 0,
        速率_重置时间: 0,
        总接收数: 0,
        总发送数: 0,
        总失败数: 0,
        最后活跃时间: 0,
        错误信息: "",
        健康回调: 空
    }
}

函数 渠道_启动(渠道) {
    如果 (渠道.状态 == 渠道状态_运行) { 返回 成功 }
    渠道.状态 = 渠道状态_运行
    渠道.最后活跃时间 = 当前时间_毫秒()
    渠道.速率_当前计数 = 0
    渠道.速率_重置时间 = 当前时间_毫秒() + 60000
    渠道.错误信息 = ""
    返回 成功
}

函数 渠道_停止(渠道) {
    渠道.状态 = 渠道状态_停止
    渠道.最后活跃时间 = 当前时间_毫秒()
}

函数 渠道_暂停(渠道) {
    如果 (渠道.状态 == 渠道状态_运行) {
        渠道.状态 = 渠道状态_暂停
    }
}

函数 渠道_恢复(渠道) {
    如果 (渠道.状态 == 渠道状态_暂停) {
        渠道.状态 = 渠道状态_运行
        渠道.最后活跃时间 = 当前时间_毫秒()
    }
}

函数 渠道_是运行(渠道) { 返回 渠道.状态 == 渠道状态_运行 }
函数 渠道_名称(渠道) { 返回 渠道.名称 }
函数 渠道_类型(渠道) { 返回 渠道.类型 }
函数 渠道_状态(渠道) { 返回 渠道.状态 }

函数 渠道_检查速率(渠道) {
    定义 现在 = 当前时间_毫秒()
    如果 (现在 >= 渠道.速率_重置时间) {
        渠道.速率_当前计数 = 0
        渠道.速率_重置时间 = 现在 + 60000
    }
    如果 (渠道.速率_当前计数 >= 渠道.速率限制_每分钟) {
        返回 假
    }
    渠道.速率_当前计数 = 渠道.速率_当前计数 + 1
    返回 真
}

函数 渠道_默认目标(渠道) {
    定义 目标 = 字典取(渠道.配置, "广播目标")
    如果 (目标 == 空 || 目标 == "") { 目标 = 字典取(渠道.配置, "默认用户ID") }
    如果 (目标 == 空 || 目标 == "") { 目标 = "broadcast" }
    返回 目标
}

函数 渠道_放入发送队列(渠道, 用户ID, 消息) {
    如果 (计数(渠道.发送队列) >= 渠道_默认队列容量) {
        渠道.总失败数 = 渠道.总失败数 + 1
        渠道.错误信息 = "发送队列已满"
        渠道接口_最后错误 = 渠道.名称 + ": 发送队列已满"
        返回 错误_资源不足
    }
    追加(渠道.发送队列, [用户ID, 消息])
    渠道.最后活跃时间 = 当前时间_毫秒()
    返回 成功
}

函数 渠道_接收消息(渠道) {
    如果 (!渠道_是运行(渠道)) { 返回 空 }
    如果 (计数(渠道.接收队列) > 0) {
        定义 消息 = 渠道.接收队列[0]
        渠道.接收队列 = 列表_切片(渠道.接收队列, 1, 计数(渠道.接收队列))
        渠道.总接收数 = 渠道.总接收数 + 1
        渠道.最后活跃时间 = 当前时间_毫秒()
        返回 消息
    }
    如果 (渠道.接收函数 != 空) {
        定义 消息 = 渠道.接收函数()
        如果 (消息 != 空) {
            渠道.总接收数 = 渠道.总接收数 + 1
            渠道.最后活跃时间 = 当前时间_毫秒()
        }
        返回 消息
    }
    返回 空
}

函数 渠道_发送消息(渠道, 用户ID, 消息) {
    如果 (!渠道_是运行(渠道)) { 返回 错误_设备忙 }
    如果 (!渠道_检查速率(渠道)) {
        返回 渠道_放入发送队列(渠道, 用户ID, 消息)
    }
    如果 (渠道.发送函数 == 空) {
        返回 渠道_放入发送队列(渠道, 用户ID, 消息)
    }

    定义 结果 = 渠道.发送函数(用户ID, 消息)
    如果 (结果 == 成功) {
        渠道.总发送数 = 渠道.总发送数 + 1
        渠道.最后活跃时间 = 当前时间_毫秒()
        渠道.错误信息 = ""
    } 否则 {
        渠道.总失败数 = 渠道.总失败数 + 1
        渠道.错误信息 = "发送失败"
        渠道接口_最后错误 = 渠道.名称 + ": 发送失败"
        返回 结果
    }

    渠道_刷新发送队列(渠道)
    返回 结果
}

函数 渠道_推入接收(渠道, 消息) {
    如果 (计数(渠道.接收队列) >= 渠道_默认队列容量) { 返回 假 }
    追加(渠道.接收队列, 消息)
    返回 真
}

函数 渠道_刷新发送队列(渠道) {
    如果 (!渠道_是运行(渠道)) { 返回 }
    当 (计数(渠道.发送队列) > 0 && 渠道.发送函数 != 空) {
        如果 (!渠道_检查速率(渠道)) { 跳出 }
        定义 项 = 渠道.发送队列[0]
        定义 结果 = 渠道.发送函数(项[0], 项[1])
        如果 (结果 != 成功) {
            渠道.总失败数 = 渠道.总失败数 + 1
            渠道.错误信息 = "队列发送失败"
            渠道接口_最后错误 = 渠道.名称 + ": 队列发送失败"
            跳出
        }
        渠道.发送队列 = 列表_切片(渠道.发送队列, 1, 计数(渠道.发送队列))
        渠道.总发送数 = 渠道.总发送数 + 1
        渠道.最后活跃时间 = 当前时间_毫秒()
    }
}

函数 渠道_设配置(渠道, 键, 值) { 字典设(渠道.配置, 键, 值) }
函数 渠道_取配置(渠道, 键) { 返回 字典取(渠道.配置, 键) }
函数 渠道_设速率限制(渠道, 每分钟) { 渠道.速率限制_每分钟 = 每分钟 }
函数 渠道_设健康回调(渠道, 回调) { 渠道.健康回调 = 回调 }

函数 渠道_健康检查(渠道) {
    定义 现在 = 当前时间_毫秒()
    定义 空闲时间 = 现在 - 渠道.最后活跃时间
    如果 (渠道.状态 == 渠道状态_停止 || 渠道.状态 == 渠道状态_暂停) { 返回 渠道.状态 }
    如果 (渠道.状态 == 渠道状态_错误) { 返回 "错误" }
    如果 (空闲时间 > 渠道_健康检查间隔 * 10) { 返回 "超时" }
    如果 (渠道.健康回调 != 空) { 返回 渠道.健康回调() }
    如果 (渠道.状态 == 渠道状态_运行) { 返回 "健康" }
    返回 渠道.状态
}

函数 渠道_统计(渠道) {
    返回 [渠道.总接收数, 渠道.总发送数, 渠道.总失败数, 计数(渠道.发送队列), 计数(渠道.接收队列)]
}

函数 渠道注册表_条目列表() {
    定义 结果 = []
    如果 (渠道注册表 == 空) { 返回 结果 }
    定义 桶 = 渠道注册表[0]
    定义 容量 = 渠道注册表[1]
    定义 可变 i = 0
    当 (i < 容量) {
        定义 槽 = 桶[i]
        如果 (槽[2] == 真) {
            追加(结果, [槽[1][0], 槽[1][1]])
        }
        i = i + 1
    }
    返回 结果
}

函数 渠道注册表_注册(渠道) {
    如果 (字典取(渠道注册表, 渠道.名称) == 空) {
        渠道注册表_计数 = 渠道注册表_计数 + 1
    }
    字典设(渠道注册表, 渠道.名称, 渠道)
}

函数 渠道注册表_注销(名称) {
    定义 渠道 = 字典取(渠道注册表, 名称)
    如果 (渠道 != 空) {
        渠道_停止(渠道)
        字典删(渠道注册表, 名称)
        如果 (渠道注册表_计数 > 0) { 渠道注册表_计数 = 渠道注册表_计数 - 1 }
    }
}

函数 渠道注册表_获取(名称) { 返回 字典取(渠道注册表, 名称) }
函数 渠道注册表_数量() { 返回 渠道注册表_计数 }

函数 渠道注册表_广播(消息) {
    定义 可变 成功数 = 0
    定义 条目列表 = 渠道注册表_条目列表()
    定义 可变 i = 0
    渠道接口_广播数 = 渠道接口_广播数 + 1
    当 (i < 计数(条目列表)) {
        定义 渠道 = 条目列表[i][1]
        如果 (渠道_是运行(渠道)) {
            定义 结果 = 渠道_发送消息(渠道, 渠道_默认目标(渠道), 消息)
            如果 (结果 == 成功) { 成功数 = 成功数 + 1 }
        }
        i = i + 1
    }
    返回 成功数
}

函数 渠道注册表_全部健康() {
    返回 渠道注册表_健康摘要(真)
}

函数 渠道注册表_健康摘要(计入巡检) {
    定义 条目列表 = 渠道注册表_条目列表()
    定义 可变 健康数 = 0
    定义 可变 异常数 = 0
    定义 可变 i = 0
    如果 (计入巡检) {
        渠道接口_健康巡检数 = 渠道接口_健康巡检数 + 1
    }
    当 (i < 计数(条目列表)) {
        定义 状态 = 渠道_健康检查(条目列表[i][1])
        如果 (状态 == "健康" || 状态 == 渠道状态_运行) {
            健康数 = 健康数 + 1
        } 否则 {
            异常数 = 异常数 + 1
        }
        i = i + 1
    }
    返回 {
        总数: 计数(条目列表),
        健康: 健康数,
        异常: 异常数
    }
}

// §链路自适应评估
定义 可变 渠道接口_带宽估计 = 0
定义 可变 渠道接口_丢包窗口 = []

函数 渠道接口_更新带宽估计(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 渠道接口_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    渠道接口_带宽估计 = 渠道接口_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 渠道接口_带宽估计
}

函数 渠道接口_生成拥塞建议(丢包率) {
    追加(渠道接口_丢包窗口, 丢包率)
    如果 (计数(渠道接口_丢包窗口) > 10) {
        渠道接口_丢包窗口 = 列表_切片(渠道接口_丢包窗口, 1, 计数(渠道接口_丢包窗口))
    }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}

函数 渠道接口_统计() {
    定义 健康摘要 = 渠道注册表_健康摘要(假)
    返回 {
        模块: "渠道接口",
        渠道数: 渠道注册表_计数,
        健康渠道数: 健康摘要.健康,
        异常渠道数: 健康摘要.异常,
        广播次数: 渠道接口_广播数,
        健康巡检数: 渠道接口_健康巡检数,
        带宽估计: 渠道接口_带宽估计,
        丢包窗口长度: 计数(渠道接口_丢包窗口),
        最后错误: 渠道接口_最后错误
    }
}

函数 渠道接口_健康评估() {
    定义 可变 问题 = []
    定义 健康摘要 = 渠道注册表_健康摘要(假)
    如果 (渠道注册表_计数 > 100000) { 追加(问题, "渠道注册数量异常增长") }
    如果 (健康摘要.异常 > 健康摘要.健康 && 健康摘要.总数 > 0) { 追加(问题, "异常渠道多于健康渠道") }
    返回 计数(问题) == 0
}

函数 渠道接口_综合报告() {
    打印("[渠道接口] ═══ 综合报告 ═══")
    定义 健康摘要 = 渠道注册表_健康摘要(假)
    打印("  渠道数: " + 整数转字符串(渠道注册表_计数))
    打印("  健康/异常: " + 整数转字符串(健康摘要.健康) + "/" + 整数转字符串(健康摘要.异常))
    打印("  广播次数: " + 整数转字符串(渠道接口_广播数))
    打印("  健康巡检数: " + 整数转字符串(渠道接口_健康巡检数))
    打印("  带宽估计: " + 整数转字符串(渠道接口_带宽估计))
    打印("  丢包窗口长度: " + 整数转字符串(计数(渠道接口_丢包窗口)))
    打印("  最后错误: " + 渠道接口_最后错误)
    打印("  健康: " + 如果 (渠道接口_健康评估()) { "正常" } 否则 { "异常" })
}

函数 渠道接口_全局重置() {
    渠道注册表 = 字典()
    渠道注册表_计数 = 0
    渠道接口_广播数 = 0
    渠道接口_健康巡检数 = 0
    渠道接口_最后错误 = ""
    渠道接口_带宽估计 = 0
    渠道接口_丢包窗口 = []
    打印("[渠道接口] 全局统计已重置")
    返回 0
}

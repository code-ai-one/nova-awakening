函数 辅助_获取内存读取数() { 返回 辅助_内存读取数 }

// NBCA — Nova Bytecode Auxiliary Theory
// 公理1(符号扩展正确): 有符号读取保证符号位扩展正确
// 公理2(LEB128可逆): 编码和解码互为逆运算
// 定理1(类型安全): ToBoolean/ToNumber遍历所有JS类型
// 定理2(严格相等对称): StrictEquals(a,b) == StrictEquals(b,a)

函数 JSValue_IsCallable(v) {
    辅助_类型检查数 = 辅助_类型检查数 + 1
    如果 (v == 0) { 返回 假 }
    定义 类型 = 内存_读32(v)
    返回 类型 == JS类型_Function
}

函数 JSValue_IsConstructor(v) {
    辅助_类型检查数 = 辅助_类型检查数 + 1
    如果 (v == 0) { 返回 假 }
    定义 类型 = 内存_读32(v)
    如果 (类型 != JS类型_Function) { 返回 假 }
    // 检查函数是否有[[Construct]]槽
    定义 标志 = 内存_读32(v + 4)
    返回 (标志 & 0x02) != 0  // 位1: 可构造
}

函数 JSValue_IsNaN(v) {
    辅助_类型检查数 = 辅助_类型检查数 + 1
    如果 (v == 0) { 返回 假 }
    如果 (内存_读32(v) != JS类型_Number) { 返回 假 }
    定义 n = 内存_读64(v + 8)
    返回 n == JS_NaN
}

函数 JSValue_IsFinite(v) {
    辅助_类型检查数 = 辅助_类型检查数 + 1
    如果 (!JSValue_IsNumber(v)) { 返回 假 }
    定义 n = 内存_读64(v + 8)
    返回 n != JS_NaN && n != JS_Infinity && n != JS_NegInfinity
}

函数 内存_写16_大端(addr, val) {
    内存_写68(addr, (val >> 8) & 0xFF)
    内存_写68(addr + 1, val & 0xFF)
}

函数 内存_写32_大端(addr, val) {
    内存_写68(addr, (val >> 24) & 0xFF)
    内存_写68(addr + 1, (val >> 16) & 0xFF)
    内存_写68(addr + 2, (val >> 8) & 0xFF)
    内存_写68(addr + 3, val & 0xFF)
}

函数 内存_读16_大端(addr) {
    辅助_内存读取数 = 辅助_内存读取数 + 1
    返回 (内存_读8(addr) << 8) | 内存_读8(addr + 1)
}

函数 内存_读32_大端(addr) {
    辅助_内存读取数 = 辅助_内存读取数 + 1
    返回 (内存_读8(addr) << 24) | (内存_读8(addr + 1) << 16) |
           (内存_读8(addr + 2) << 8) | 内存_读8(addr + 3)
}

函数 JSValue_AbstractLessThan(a, b) {
    辅助_类型转换数 = 辅助_类型转换数 + 1
    定义 na = JSValue_ToNumber(a)
    定义 nb = JSValue_ToNumber(b)
    如果 (na == JS_NaN || nb == JS_NaN) { 返回 假 }
    返回 na < nb
}

函数 JSValue_AbstractEquals(a, b) {
    辅助_类型转换数 = 辅助_类型转换数 + 1
    // 先尝试严格相等
    如果 (JSValue_StrictEquals(a, b)) { 返回 真 }
    // null == undefined
    如果 (JSValue_IsNull(a) && JSValue_IsUndefined(b)) { 返回 真 }
    如果 (JSValue_IsUndefined(a) && JSValue_IsNull(b)) { 返回 真 }
    // 数值比较
    如果 (JSValue_IsNumber(a) && JSValue_IsNumber(b)) {
        返回 JSValue_ToNumber(a) == JSValue_ToNumber(b)
    }
    返回 假
}

定义 可变 _缓存_小整数 = []
定义 可变 _缓存_已初始化 = 假

函数 JSValue_缓存整数_初始化() {
    如果 (_缓存_已初始化) { 返回 }
    // 缓存-128到127的小整数
    定义 可变 i = 0
    当 (i < 256) {
        追加(_缓存_小整数, JSValue_创建数值(i - 128))
        i = i + 1
    }
    _缓存_已初始化 = 真
}

函数 JSValue_创建缓存数值(n) {
    // 小整数用缓存避免重复分配
    JSValue_缓存整数_初始化()
    如果 (n >= -128 && n <= 127) {
        返回 _缓存_小整数[n + 128]
    }
    返回 JSValue_创建数值(n)
}

函数 辅助_完整诊断() {
    返回 [
        "类型检查", 辅助_类型检查数,
        "类型转换", 辅助_类型转换数,
        "值创建", 辅助_值创建数,
        "内存读取", 辅助_内存读取数,
        "原生独创_NBCA字节码辅助", 1
    ]
}

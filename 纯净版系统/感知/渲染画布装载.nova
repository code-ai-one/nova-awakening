// 感知渲染画布装载
// 将画布、样式、矢量图与图像解码主链挂回感知阶段装载。

导入("./画布上下文.nova")
导入("./画布扩展接.nova")
导入("./画布完整接.nova")
导入("./计算样式系统.nova")
导入("./绘制层系统.nova")
导入("./更新网缓画布.nova")
导入("./矢量图路径解.nova")
导入("./矢量图渐变.nova")
导入("./矢量图变换矩.nova")
导入("./图压缩解码器.nova")


函数 感知渲染画布装载_模块清单() {
    返回 [
        "./画布上下文.nova",
        "./画布扩展接.nova",
        "./画布完整接.nova",
        "./计算样式系统.nova",
        "./绘制层系统.nova",
        "./更新网缓画布.nova",
        "./矢量图路径解.nova",
        "./矢量图渐变.nova",
        "./矢量图变换矩.nova",
        "./图压缩解码器.nova"
    ]
}

函数 感知渲染画布装载_统计() {
    返回 {
        模块数: 计数(感知渲染画布装载_模块清单()),
        画布扩展接统计: 画布扩展接_统计(),
        画布完整接统计: 画布完整接_统计()
    }
}

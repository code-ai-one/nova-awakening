// 语句节点类型 (150-165)
定义 节点_匹配语句 = 152
定义 节点_匹配分支 = 153
定义 节点_变量声明 = 160
定义 节点_赋值语句 = 162
定义 节点_复合赋值 = 164
定义 节点_空字面量 = 165

// 特殊标记
定义 标记_终止 = 199

// 目标架构
定义 架构_x86_64 = 1
定义 架构_ARM64 = 2
定义 架构_RISC_V = 3
定义 架构_WASM = 4

// 中文数字字符码点 (Unicode codepoint)
// 词法器UTF-8原生解码引擎使用
定义 中文码_零 = 38646    // 零 U+96F6
定义 中文码_一 = 19968    // 一 U+4E00
定义 中文码_二 = 20108    // 二 U+4E8C
定义 中文码_三 = 19977    // 三 U+4E09
定义 中文码_四 = 22235    // 四 U+56DB
定义 中文码_五 = 20116    // 五 U+4E94
定义 中文码_六 = 20845    // 六 U+516D
定义 中文码_七 = 19971    // 七 U+4E03
定义 中文码_八 = 20843    // 八 U+516B
定义 中文码_九 = 20061    // 九 U+4E5D
定义 中文码_十 = 21313    // 十 U+5341
定义 中文码_百 = 30334    // 百 U+767E
定义 中文码_千 = 21315    // 千 U+5343
定义 中文码_万 = 19975    // 万 U+4E07
定义 中文码_亿 = 20159    // 亿 U+4EBF
定义 中文码_两 = 20004    // 两 U+4E24 (口语"两百"等)
定义 中文码_〇 = 12295    // 〇 U+3007 (大写零)

// 中文标点码点
定义 中文码_左括 = 65288   // （ U+FF08
定义 中文码_右括 = 65289   // ） U+FF09
定义 中文码_左花 = 65371   // ｛ U+FF5B
定义 中文码_右花 = 65373   // ｝ U+FF5D
定义 中文码_左方 = 12304   // 【 U+3010
定义 中文码_右方 = 12305   // 】 U+3011
定义 中文码_逗号 = 65292   // ， U+FF0C
定义 中文码_句号 = 12290   // 。 U+3002
定义 中文码_分号 = 65307   // ； U+FF1B
定义 中文码_冒号 = 65306   // ： U+FF1A
定义 中文码_等号 = 65309   // ＝ U+FF1D
定义 中文码_叹号 = 65281   // ！ U+FF01
定义 中文码_问号 = 65311   // ？ U+FF1F
定义 中文码_左书 = 12300   // 「 U+300C
定义 中文码_右书 = 12301   // 」 U+300D
定义 中文码_加号 = 65291   // ＋ U+FF0B
定义 中文码_减号 = 65293   // － U+FF0D

// 辅助函数
函数 标记名(id) {
    如果 (id == 标记_标识符) { 返回 "标识符" }
    如果 (id == 标记_加) { 返回 "加" }
    如果 (id == 标记_减) { 返回 "减" }
    如果 (id == 标记_乘) { 返回 "乘" }
    如果 (id == 标记_除) { 返回 "除" }
    如果 (id == 标记_余) { 返回 "余" }
    如果 (id == 标记_等等) { 返回 "等等" }
    如果 (id == 标记_不等) { 返回 "不等" }
    如果 (id == 标记_小于) { 返回 "小于" }
    如果 (id == 标记_大于) { 返回 "大于" }
    如果 (id == 标记_小等) { 返回 "小等" }
    如果 (id == 标记_大等) { 返回 "大等" }
    如果 (id == 标记_且) { 返回 "且" }
    如果 (id == 标记_或) { 返回 "或" }
    如果 (id == 标记_非) { 返回 "非" }
    如果 (id == 标记_赋值) { 返回 "赋值" }
    如果 (id == 标记_左括) { 返回 "左括" }
    如果 (id == 标记_右括) { 返回 "右括" }
    如果 (id == 标记_左花) { 返回 "左花" }
    如果 (id == 标记_右花) { 返回 "右花" }
    如果 (id == 标记_左方) { 返回 "左方" }
    如果 (id == 标记_右方) { 返回 "右方" }
    如果 (id == 标记_逗号) { 返回 "逗号" }
    如果 (id == 标记_点号) { 返回 "点号" }
    如果 (id == 标记_冒号) { 返回 "冒号" }
    如果 (id == 标记_分号) { 返回 "分号" }
    如果 (id == 标记_数字) { 返回 "数字" }
    如果 (id == 标记_字串) { 返回 "字串" }
    如果 (id == 标记_名称) { 返回 "名称" }
    如果 (id == 节点_调用) { 返回 "调用" }
    如果 (id == 节点_二元) { 返回 "二元" }
    如果 (id == 节点_赋值) { 返回 "赋值节点" }
    如果 (id == 节点_索引) { 返回 "索引" }
    如果 (id == 节点_成员) { 返回 "成员" }
    如果 (id == 标记_定义) { 返回 "定义" }
    如果 (id == 标记_可变) { 返回 "可变" }
    如果 (id == 标记_函数) { 返回 "函数" }
    如果 (id == 标记_返回) { 返回 "返回" }
    如果 (id == 标记_如果) { 返回 "如果" }
    如果 (id == 标记_否则) { 返回 "否则" }
    如果 (id == 标记_当) { 返回 "当" }
    如果 (id == 标记_导入) { 返回 "导入" }
    如果 (id == 标记_结构) { 返回 "结构" }
    如果 (id == 标记_匹配) { 返回 "匹配" }
    如果 (id == 标记_真) { 返回 "真" }
    如果 (id == 标记_假) { 返回 "假" }
    如果 (id == 标记_空) { 返回 "空" }
    如果 (id == 标记_汇编) { 返回 "汇编" }
    如果 (id == 标记_终止) { 返回 "终止" }
    返回 "未知标记"
}

函数 发射_读字16() { 发射组([0x66, 0x8B, 0x01]) }
// mov word [rcx], ax — 16位写入
函数 发射_写字16() { 发射组([0x66, 0x89, 0x01]) }
// mov dword [rcx], eax — 32位写入
函数 发射_写双字() { 发射组([0x89, 0x01]) }
// movzx rax, byte [rcx] — 字节零扩展到64位
函数 发射_零扩展字节() { 发射组([0x48, 0x0F, 0xB6, 0x01]) }
// movsx rax, byte [rcx] — 字节符号扩展到64位
函数 发射_符号扩展字节() { 发射组([0x48, 0x0F, 0xBE, 0x01]) }

// 补全: 更多SSE/SSE2指令

// movss xmm, [rcx] — 单精度加载
函数 发射_单精度读(xmm, reg) {
    发射(0xF3) 发射(0x0F) 发射(0x10) 发射(0x00 + xmm * 8 + reg)
}
// movss [rcx], xmm — 单精度存储
函数 发射_单精度写(xmm, reg) {
    发射(0xF3) 发射(0x0F) 发射(0x11) 发射(0x00 + xmm * 8 + reg)
}
// addss xmm, xmm
函数 发射_单精度加(目标, 源) { 发射(0xF3) 发射(0x0F) 发射(0x58) 发射(0xC0 + 目标 * 8 + 源) }
函数 发射_单精度减(目标, 源) { 发射(0xF3) 发射(0x0F) 发射(0x5C) 发射(0xC0 + 目标 * 8 + 源) }
函数 发射_单精度乘(目标, 源) { 发射(0xF3) 发射(0x0F) 发射(0x59) 发射(0xC0 + 目标 * 8 + 源) }
函数 发射_单精度除(目标, 源) { 发射(0xF3) 发射(0x0F) 发射(0x5E) 发射(0xC0 + 目标 * 8 + 源) }
函数 发射_单精度根(目标, 源) { 发射(0xF3) 发射(0x0F) 发射(0x51) 发射(0xC0 + 目标 * 8 + 源) }
// cvtss2sd — 单精度→双精度
函数 发射_单转双(目标, 源) { 发射(0xF3) 发射(0x0F) 发射(0x5A) 发射(0xC0 + 目标 * 8 + 源) }
// cvtsd2ss — 双精度→单精度
函数 发射_双转单(目标, 源) { 发射(0xF2) 发射(0x0F) 发射(0x5A) 发射(0xC0 + 目标 * 8 + 源) }
// cvtsi2ss xmm, rax — 整数→单精度
函数 发射_整数转单精度(xmm, reg) {
    发射(0xF3) 发射(0x48) 发射(0x0F) 发射(0x2A) 发射(0xC0 + xmm * 8 + reg)
}
// cvttss2si rax, xmm — 单精度→整数
函数 发射_单精度转整数(reg, xmm) {
    发射(0xF3) 发射(0x48) 发射(0x0F) 发射(0x2C) 发射(0xC0 + reg * 8 + xmm)
}

// SSE2 128位向量(packed)
// movaps xmm, [rcx] — 128位对齐加载
函数 发射_向量128读(xmm, reg) { 发射(0x0F) 发射(0x28) 发射(0x00 + xmm * 8 + reg) }
// movaps [rcx], xmm — 128位对齐存储
函数 发射_向量128写(xmm, reg) { 发射(0x0F) 发射(0x29) 发射(0x00 + xmm * 8 + reg) }
// movups xmm, [rcx] — 128位非对齐加载
函数 发射_向量128读非齐(xmm, reg) { 发射(0x0F) 发射(0x10) 发射(0x00 + xmm * 8 + reg) }
// movdqa xmm, xmm — 128位整数移动
函数 发射_整数向量传送(目标, 源) {
    发射(0x66) 发射(0x0F) 发射(0x6F) 发射(0xC0 + 目标 * 8 + 源)
}
// paddq xmm, xmm — 128位整数加法(2个64位)
函数 发射_向量整数加(目标, 源) {
    发射(0x66) 发射(0x0F) 发射(0xD4) 发射(0xC0 + 目标 * 8 + 源)
}
// psubq xmm, xmm — 128位整数减法
函数 发射_向量整数减(目标, 源) {
    发射(0x66) 发射(0x0F) 发射(0xFB) 发射(0xC0 + 目标 * 8 + 源)
}
// pxor xmm, xmm — 128位异或(清零)
函数 发射_向量128异或(目标, 源) {
    发射(0x66) 发射(0x0F) 发射(0xEF) 发射(0xC0 + 目标 * 8 + 源)
}
// xorps xmm, xmm — 128位浮点异或
函数 发射_浮点向量异或(目标, 源) {
    发射(0x0F) 发射(0x57) 发射(0xC0 + 目标 * 8 + 源)
}

// 补全: 更多AVX2指令

// vbroadcastss ymm, xmm — 标量广播到8个float
函数 发射_向量广播(ymm, xmm) {
    发射_vex3(1, 1, 2, 0, ymm)
    发射(0x18) 发射(0xC0 + ymm * 8 + xmm)
}
// vpermps ymm, ymm, ymm — 排列
函数 发射_向量排列(目标, 控制, 源) {
    发射_vex3(1, 1, 2, 控制, 目标)
    发射(0x16) 发射(0xC0 + 目标 * 8 + 源)
}
// vblendps ymm, ymm, ymm, imm8
函数 发射_向量混合(目标, 源1, 源2, 掩码) {
    发射_vex3(1, 1, 3, 源1, 目标)
    发射(0x0C) 发射(0xC0 + 目标 * 8 + 源2) 发射(掩码)
}
// vcmpps ymm, ymm, ymm, imm8
函数 发射_向量比较(目标, 源1, 源2, 模式) {
    发射_vex2(0, 1, 源1, 目标)
    发射(0xC2) 发射(0xC0 + 目标 * 8 + 源2) 发射(模式)
}
// vrcpps ymm, ymm — 近似倒数
函数 发射_向量倒数(目标, 源) {
    发射_vex2(0, 1, 0, 目标)
    发射(0x53) 发射(0xC0 + 目标 * 8 + 源)
}
// vrsqrtps ymm, ymm — 近似倒数平方根
函数 发射_向量倒数根(目标, 源) {
    发射_vex2(0, 1, 0, 目标)
    发射(0x52) 发射(0xC0 + 目标 * 8 + 源)
}
// vmovups ymm, [rcx] — 非对齐256位加载
函数 发射_向量读非齐(ymm) {
    发射_vex2(0, 1, 0, ymm)
    发射(0x10) 发射(0x01 + ymm * 8)
}
// vmovups [rcx], ymm — 非对齐256位存储
函数 发射_向量写非齐(ymm) {
    发射_vex2(0, 1, 0, ymm)
    发射(0x11) 发射(0x01 + ymm * 8)
}


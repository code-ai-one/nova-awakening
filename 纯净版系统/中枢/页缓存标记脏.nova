函数 页缓存_标记脏(地址空间, 物理页号) {
    定义 页 = 页描述符_获取(物理页号)
    如果 (页 == 空) { 返回 }

    如果 (!页描述符_测试标志(页, 页_脏)) {
        页描述符_设置标志(页, 页_脏)
        设置(地址空间, AS_脏页数, 地址空间[AS_脏页数] + 1)
    }
}

函数 页缓存_清除脏(地址空间, 物理页号) {
    定义 页 = 页描述符_获取(物理页号)
    如果 (页 == 空) { 返回 }

    如果 (页描述符_测试标志(页, 页_脏)) {
        页描述符_清除标志(页, 页_脏)
        设置(地址空间, AS_脏页数, 地址空间[AS_脏页数] - 1)
    }
}

// 同步 (fsync)

函数 页缓存_同步(地址空间) {
    // 遍历所有脏页, 写回磁盘
    定义 操作 = 地址空间[AS_操作]
    如果 (操作 == 空) { 返回 }

    // 遍历页树, 找脏页
    红黑树_遍历(地址空间[AS_页树], 页缓存_同步回调, 地址空间)
}

函数 页缓存_同步回调(文件页号, 物理页号, 用户数据) {
    定义 地址空间 = 用户数据
    定义 页 = 页描述符_获取(物理页号)
    如果 (页 == 空) { 返回 0 }

    如果 (页描述符_测试标志(页, 页_脏)) {
        定义 操作 = 地址空间[AS_操作]
        定义 页虚拟 = 物理到虚拟(物理页号 * 页大小)
        操作.写页(地址空间[AS_Nova文件节点], 文件页号, 页虚拟)
        页缓存_清除脏(地址空间, 物理页号)
    }
    返回 0
}

// 截断 (文件大小改变时清理多余的缓存页)

函数 页缓存_截断(地址空间, 新大小) {
    定义 新页数 = (新大小 + 页大小 - 1) / 页大小
    // 移除文件页号 >= 新页数 的所有缓存页
    定义 可变 删除列表 = []
    红黑树_遍历(地址空间[AS_页树], 截断_收集回调, [新页数, 删除列表])

    定义 可变 i = 0
    当 (i < 计数(删除列表)) {
        页缓存_移除(地址空间, 删除列表[i])
        i = i + 1
    }
}

函数 截断_收集回调(文件页号, 物理页号, 用户数据) {
    定义 新页数 = 用户数据[0]
    如果 (文件页号 >= 新页数) {
        追加(用户数据[1], 文件页号)
    }
    返回 0
}

// 统计

定义 可变 页缓存_统计_命中 = 0
定义 可变 页缓存_统计_未命中 = 0
定义 可变 页缓存_统计_添加 = 0
定义 可变 页缓存_统计_移除 = 0

函数 页缓存_统计() {
    返回 [页缓存_统计_命中, 页缓存_统计_未命中, 页缓存_统计_添加, 页缓存_统计_移除]
}

函数 页缓存_命中率() {
    定义 总查询 = 页缓存_统计_命中 + 页缓存_统计_未命中
    如果 (总查询 == 0) { 返回 0 }
    返回 页缓存_统计_命中 * 100 / 总查询
}

// 别名(被ext4文件操作引用)
函数 页面缓存_添加(Nova文件节点, 页号, 页) { 内核调试("页面缓存: 添加页") }


函数 页面缓存_完整统计() {
    返回 [页缓存_统计_命中, 页缓存_统计_未命中, 页缓存_命中率(), 页缓存_统计_添加, 页缓存_统计_移除]
}

// NPCD理论: Nova Page Cache Dirty Theory
// 核心创新:
//  1) 双链表脏页跟踪: LRU脏页链表与地址空间脏计数双维管理
//  2) 自适应回写调度: 脏比率驱动的多级回写策略
//  3) 延迟回写窗口: 最小与最大延迟平衡IO和数据安全
//  4) 空间预读: 回写时顺序合并相邻脏页
//  5) AI回写预测: 6维特征推理最优回写时机

定义 NPCD_最大脏比率     = 40    // 40%
定义 NPCD_后台脏门槛     = 10    // 10%开始后台回写
定义 NPCD_紧急脏门槛     = 35    // 35%强制回写
定义 NPCD_最小延迟 ms     = 500   // 0.5秒最小回写延迟
定义 NPCD_最大延迟ms      = 30000  // 30秒最大回写延迟
定义 NPCD_批量大小         = 32    // 每批回写32页
定义 NPCD_合并窗口         = 8     // 合并相邻8页

定义 可变 NPCD_脏标记次数     = 0
定义 可变 NPCD_脏清除次数     = 0
定义 可变 NPCD_回写次数       = 0
定义 可变 NPCD_合并回写次数   = 0
定义 可变 NPCD_强制回写次数   = 0
定义 可变 NPCD_AI预测次数     = 0
定义 可变 NPCD_总回写页数     = 0
定义 可变 NPCD_总脏页数       = 0
定义 可变 NPCD_总缓存页数     = 0

// §2 脏页链表

结构 NPCD脏页节点 {
    物理页号,
    文件页号,
    地址空间,
    脏时间戳,     // 标记脏的时间戳
    前一个,
    后一个,
}

定义 可变 NPCD_脏链表头 = 0
定义 可变 NPCD_脏链表尾 = 0
定义 可变 NPCD_脏链表长度 = 0

函数 NPCD_脏链表_追加(物理页号, 文件页号, 地址空间) {
    NPCD_脏标记次数 = NPCD_脏标记次数 + 1
    NPCD_总脏页数 = NPCD_总脏页数 + 1
    定义 node = 堆分配(NPCD脏页节点)
    node.物理页号 = 物理页号
    node.文件页号 = 文件页号
    node.地址空间 = 地址空间
    node.脏时间戳 = 系统调用_时间戳()
    node.前一个 = NPCD_脏链表尾
    node.后一个 = 0
    如果 (NPCD_脏链表尾 != 0) {
        NPCD_脏链表尾.后一个 = node
    }
    NPCD_脏链表尾 = node
    如果 (NPCD_脏链表头 == 0) {
        NPCD_脏链表头 = node
    }
    NPCD_脏链表长度 = NPCD_脏链表长度 + 1
}

函数 NPCD_脏链表_移除(node) {
    NPCD_脏清除次数 = NPCD_脏清除次数 + 1
    NPCD_总脏页数 = NPCD_总脏页数 - 1
    如果 (node.前一个 != 0) { node.前一个.后一个 = node.后一个 }
    否则 { NPCD_脏链表头 = node.后一个 }
    如果 (node.后一个 != 0) { node.后一个.前一个 = node.前一个 }
    否则 { NPCD_脏链表尾 = node.前一个 }
    NPCD_脏链表长度 = NPCD_脏链表长度 - 1
    堆释放(node)
}

// §3 脏比率计算与回写触发

函数 NPCD_脏比率() {
    如果 (NPCD_总缓存页数 == 0) { 返回 0 }
    返回 NPCD_总脏页数 * 100 / NPCD_总缓存页数
}

函数 NPCD_需要后台回写() {
    返回 NPCD_脏比率() >= NPCD_后台脏门槛
}

函数 NPCD_需要强制回写() {
    返回 NPCD_脏比率() >= NPCD_紧急脏门槛
}

函数 NPCD_计算回写批量(ratio) {
    // 脏比率越高, 回写批量越大
    如果 (ratio >= NPCD_紧急脏门槛) { 返回 NPCD_批量大小 * 4 }
    如果 (ratio >= 25) { 返回 NPCD_批量大小 * 2 }
    返回 NPCD_批量大小
}

函数 NPCD_计算回写延迟(ratio) {
    // 脏比率越高, 延迟越短
    如果 (ratio >= NPCD_紧急脏门槛) { 返回 0 }  // 立即回写
    如果 (ratio >= 25) { 返回 NPCD_最小延迟 ms }
    如果 (ratio >= 15) { 返回 5000 }
    返回 NPCD_最大延迟ms
}

// §4 回写执行引擎

函数 NPCD_回写单页(node) {
    如果 (node == 0) { 返回 }
    定义 地址空间 = node.地址空间
    定义 操作 = 地址空间[AS_操作]
    如果 (操作 == 0) { 返回 }
    定义 页虚拟 = 物理到虚拟(node.物理页号 * 页大小)
    操作.写页(地址空间[AS_Nova文件节点], node.文件页号, 页虚拟)
    页缓存_清除脏(node.地址空间, node.物理页号)
    NPCD_回写次数 = NPCD_回写次数 + 1
    NPCD_总回写页数 = NPCD_总回写页数 + 1
}

函数 NPCD_回写批量(数量) {
    定义 可变 已回写 = 0
    定义 可变 node = NPCD_脏链表头
    当 (node != 0 && 已回写 < 数量) {
        定义 next = node.后一个
        NPCD_回写单页(node)
        NPCD_脏链表_移除(node)
        已回写 = 已回写 + 1
        node = next
    }
    返回 已回写
}

// §5 空间合并回写

函数 NPCD_合并回写(地址空间, 起始文件页) {
    NPCD_合并回写次数 = NPCD_合并回写次数 + 1
    定义 操作 = 地址空间[AS_操作]
    如果 (操作 == 0) { 返回 0 }
    // 向前扫描连续脏页
    定义 可变 连续数 = 0
    定义 可变 pg = 起始文件页
    当 (连续数 < NPCD_合并窗口) {
        定义 物理页 = 页缓存_查找(地址空间, pg)
        如果 (物理页 == 0) { 断开 }
        定义 页 = 页描述符_获取(物理页)
        如果 (页 == 0 || !页描述符_测试标志(页, 页_脏)) { 断开 }
        连续数 = 连续数 + 1
        pg = pg + 1
    }
    如果 (连续数 == 0) { 返回 0 }
    // 批量回写连续页
    定义 可变 i = 0
    当 (i < 连续数) {
        定义 物理页 = 页缓存_查找(地址空间, 起始文件页 + i)
        定义 页虚拟 = 物理到虚拟(物理页 * 页大小)
        操作.写页(地址空间[AS_Nova文件节点], 起始文件页 + i, 页虚拟)
        页缓存_清除脏(地址空间, 物理页)
        NPCD_总回写页数 = NPCD_总回写页数 + 1
        i = i + 1
    }
    返回 连续数
}

// §6 后台回写守护线程

定义 可变 NPCD_后台运行中 = 假

函数 NPCD_后台回写循环() {
    NPCD_后台运行中 = 真
    当 (NPCD_后台运行中) {
        定义 ratio = NPCD_脏比率()
        如果 (ratio >= NPCD_后台脏门槛) {
            定义 batch = NPCD_计算回写批量(ratio)
            NPCD_回写批量(batch)
            定义 delay = NPCD_计算回写延迟(ratio)
            系统调用_休眠(delay)
        } 否则 {
            // 检查老化脏页 (超过最大延迟的)
            定义 now = 系统调用_时间戳()
            定义 可变 node = NPCD_脏链表头
            定义 可变 aged = 0
            当 (node != 0 && aged < NPCD_批量大小) {
                如果 (now - node.脏时间戳 >= NPCD_最大延迟ms) {
                    定义 next = node.后一个
                    NPCD_回写单页(node)
                    NPCD_脏链表_移除(node)
                    aged = aged + 1
                    node = next
                } 否则 {
                    断开  // 链表按时间排序, 后面的更新
                }
            }
            系统调用_休眠(5000)  // 5秒检查一次
        }
    }
}

函数 NPCD_停止后台回写() {
    NPCD_后台运行中 = 假
}

// §7 强制回写与全量同步

函数 NPCD_强制回写全部() {
    NPCD_强制回写次数 = NPCD_强制回写次数 + 1
    定义 可变 node = NPCD_脏链表头
    当 (node != 0) {
        定义 next = node.后一个
        NPCD_回写单页(node)
        NPCD_脏链表_移除(node)
        node = next
    }
}

函数 NPCD_地址空间同步(地址空间) {
    定义 可变 node = NPCD_脏链表头
    当 (node != 0) {
        定义 next = node.后一个
        如果 (node.地址空间 == 地址空间) {
            NPCD_回写单页(node)
            NPCD_脏链表_移除(node)
        }
        node = next
    }
}

// §8 AI回写预测 (NPCD-AI)

函数 NPCD_AI_回写预测() {
    如果 (全局AI总线 == 0) { 返回 NPCD_批量大小 }
    NPCD_AI预测次数 = NPCD_AI预测次数 + 1
    定义 tensor = Tensor_创建(6)
    Tensor_写(tensor, 0, NPCD_脏比率() / 100.0)
    Tensor_写(tensor, 1, NPCD_脏链表长度 / 4096.0)
    Tensor_写(tensor, 2, NPCD_总回写页数 / 100000.0)
    Tensor_写(tensor, 3, NPCD_回写次数 / 10000.0)
    Tensor_写(tensor, 4, NPCD_合并回写次数 / 1000.0)
    Tensor_写(tensor, 5, NPCD_总缓存页数 / 65536.0)
    定义 out = AI总线_推理(全局AI总线, "NPCD_回写", tensor, 6)
    定义 可变 batch = NPCD_批量大小
    如果 (out != 0) {
        定义 v = Tensor_读(out, 0)
        batch = v * 128
        如果 (batch < 4) { batch = 4 }
        如果 (batch > 256) { batch = 256 }
        Tensor_释放(out)
    }
    Tensor_释放(tensor)
    返回 batch
}

// §9 诊断与运行时统计

函数 NPCD_运行时统计() {
    打印("[NPCD] dirty=" + 整数转字符串(NPCD_总脏页数) +
         " cached=" + 整数转字符串(NPCD_总缓存页数) +
         " ratio=" + 整数转字符串(NPCD_脏比率()) + "%" +
         " marks=" + 整数转字符串(NPCD_脏标记次数) +
         " clears=" + 整数转字符串(NPCD_脏清除次数) +
         " wb=" + 整数转字符串(NPCD_回写次数) +
         " merged=" + 整数转字符串(NPCD_合并回写次数) +
         " forced=" + 整数转字符串(NPCD_强制回写次数) +
         " wbPages=" + 整数转字符串(NPCD_总回写页数) +
         " aiPredict=" + 整数转字符串(NPCD_AI预测次数))
}

// §10 增强脏页标记接口

函数 NPCD_增强标记脏(地址空间, 物理页号, 文件页号) {
    // 原始标记脏
    页缓存_标记脏(地址空间, 物理页号)
    // 加入脏链表
    NPCD_脏链表_追加(物理页号, 文件页号, 地址空间)
    // 检查是否需要触发强制回写
    如果 (NPCD_需要强制回写()) {
        NPCD_强制回写次数 = NPCD_强制回写次数 + 1
        定义 batch = NPCD_计算回写批量(NPCD_脏比率())
        NPCD_回写批量(batch)
    }
}

函数 NPCD_增强清除脏(地址空间, 物理页号) {
    页缓存_清除脏(地址空间, 物理页号)
    // 从脏链表中找到并移除
    定义 可变 node = NPCD_脏链表头
    当 (node != 0) {
        如果 (node.物理页号 == 物理页号 && node.地址空间 == 地址空间) {
            NPCD_脏链表_移除(node)
            返回
        }
        node = node.后一个
    }
}

// §11 回写时预读优化

定义 NPCD_预读窗口 = 16
定义 可变 NPCD_预读次数 = 0

函数 NPCD_回写时预读(地址空间, 当前文件页) {
    NPCD_预读次数 = NPCD_预读次数 + 1
    // 在回写的同时, 预读后续页到缓存
    定义 可变 i = 1
    当 (i <= NPCD_预读窗口) {
        定义 pg = 当前文件页 + i
        // 检查是否已在缓存中
        定义 cached = 页缓存_查找(地址空间, pg)
        如果 (cached == 0) {
            // 尝试从磁盘预读
            定义 操作 = 地址空间[AS_操作]
            如果 (操作 != 0) {
                定义 新页 = 系统调用_分配内存(页大小)
                如果 (新页 != 0) {
                    操作.读页(地址空间[AS_Nova文件节点], pg, 新页)
                    页缓存_添加(地址空间, pg, 新页)
                    NPCD_总缓存页数 = NPCD_总缓存页数 + 1
                }
            }
        }
        i = i + 1
    }
}

// §12 脏页缓存系统初始化

函数 NPCD_初始化() {
    NPCD_脏链表头 = 0
    NPCD_脏链表尾 = 0
    NPCD_脏链表长度 = 0
    NPCD_脏标记次数 = 0
    NPCD_脏清除次数 = 0
    NPCD_回写次数 = 0
    NPCD_合并回写次数 = 0
    NPCD_强制回写次数 = 0
    NPCD_AI预测次数 = 0
    NPCD_总回写页数 = 0
    NPCD_总脏页数 = 0
    NPCD_总缓存页数 = 0
    NPCD_预读次数 = 0
    NPCD_后台运行中 = 假
    打印("[NPCD] 脏页管理初始化完成")
}

函数 NPCD_关机同步() {
    打印("[NPCD] 关机前全量回写...")
    NPCD_强制回写全部()
    NPCD_运行时统计()
    打印("[NPCD] 关机回写完成")
}

// §13 脏页查询接口

函数 NPCD_获取脏页数() { 返回 NPCD_总脏页数 }
函数 NPCD_获取缓存页数() { 返回 NPCD_总缓存页数 }
函数 NPCD_获取回写页数() { 返回 NPCD_总回写页数 }
函数 NPCD_获取脏链表长度() { 返回 NPCD_脏链表长度 }
函数 NPCD_是否后台运行() { 返回 NPCD_后台运行中 }

函数 NPCD_最旧脏页年龄ms() {
    如果 (NPCD_脏链表头 == 0) { 返回 0 }
    定义 now = 系统调用_时间戳()
    返回 now - NPCD_脏链表头.脏时间戳
}

函数 NPCD_诊断报告() {
    打印("[NPCD] === 脏页诊断报告 ===")
    打印("  脏页数=" + 整数转字符串(NPCD_总脏页数) + " 缓存页数=" + 整数转字符串(NPCD_总缓存页数) + " 脏比率=" + 整数转字符串(NPCD_脏比率()) + "%")
    打印("  脏链表长=" + 整数转字符串(NPCD_脏链表长度) + " 最旧脏页年龄=" + 整数转字符串(NPCD_最旧脏页年龄ms()) + "ms")
    打印("  标记脏=" + 整数转字符串(NPCD_脏标记次数) + " 清除脏=" + 整数转字符串(NPCD_脏清除次数))
    打印("  回写=" + 整数转字符串(NPCD_回写次数) + " 合并回写=" + 整数转字符串(NPCD_合并回写次数) + " 强制回写=" + 整数转字符串(NPCD_强制回写次数))
    打印("  总回写页=" + 整数转字符串(NPCD_总回写页数) + " 预读=" + 整数转字符串(NPCD_预读次数) + " AI预测=" + 整数转字符串(NPCD_AI预测次数))
    打印("  后台运行=" + 整数转字符串(NPCD_后台运行中))
}

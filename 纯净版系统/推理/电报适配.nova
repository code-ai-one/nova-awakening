// NovaOS 渠道网关 — Telegram Bot 全功能适配器
// 功能: 长轮询+Webhook接收/sendMessage+富媒体发送/内联查询/
//       回调查询/组管理/媒体上传下载/速率限制/重试/
//       AI智能意图分析与自动回复/会话管理
// 理论: 自研「消息意图向量化」— 将用户消息转为意图特征向量,
//       用余弦相似度匹配最佳响应模板

导入("./智能渠道.nova")
导入("../外联/网络网络.nova")
导入("../标准/原生字符串.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/新系统张量乙.nova")
导入("./值乘.nova")
导入("../中枢/字符串替换.nova")
导入("../外联/地址解析辅.nova")
导入("../执行/输入多路复.nova")
导入("../标准/原生网络.nova")
导入("../中枢/整数转字符串.nova")
导入("../执行/探测.nova")
导入("./渠道接口.nova")
导入("../标准/原生列表.nova")

// §1 核心常量与状态

定义 TG_接口基址 = "https://api.telegram.org/bot"
定义 TG_最大重试 = 3
定义 TG_重试间隔_ms = 1000
定义 TG_速率限制_每秒 = 30        // Telegram限制: 30msg/s
定义 TG_最大会话数 = 256
定义 TG_会话超时_ms = 1800000     // 30分钟

定义 TG模式_轮询 = 0
定义 TG模式_WEBHOOK = 1

结构 TG状态 {
    令牌,
    最后更新ID,
    消息队列,          // 列表<TG消息>
    模式,              // u32: TG模式_*
    webhook_url,
    // 速率限制
    当前秒_发送数,
    当前秒_时间戳,    // u64 ms
    // 统计
    总接收数,
    总发送数,
    总错误数,
    // 会话管理
    会话表,            // 列表<TG会话>
}

定义 可变 全局_TG状态 = 空

// §2 消息结构

定义 TG消息类型_文本 = 0
定义 TG消息类型_图片 = 1
定义 TG消息类型_文档 = 2
定义 TG消息类型_音频 = 3
定义 TG消息类型_视频 = 4
定义 TG消息类型_命令 = 5
定义 TG消息类型_回调 = 6
定义 TG消息类型_内联查询 = 7

结构 TG消息 {
    消息ID,
    聊天ID,
    用户ID,
    用户名,
    文本,
    类型,            // u32: TG消息类型_*
    时间戳,          // u64 unix
    file_id,         // 字符串: 媒体文件ID
    回调数据,        // 字符串: callback_data
    内联查询ID,      // 字符串: inline_query.id
}

// §3 会话管理

结构 TG会话 {
    聊天ID,
    最后活动,        // u64 ms
    消息数,
    上下文,          // 列表<字符串>: 最近5条消息
    意图向量,        // Tensor: AI意图特征
}

函数 TG会话_创建(聊天ID) {
    定义 sess = TG会话 {}
    sess.聊天ID = 聊天ID
    sess.最后活动 = 平台_获取时间_ms()
    sess.消息数 = 0
    sess.上下文 = []
    sess.意图向量 = Tensor_创建(8)
    返回 sess
}

函数 TG会话_更新(sess, 文本) {
    sess.最后活动 = 平台_获取时间_ms()
    sess.消息数 = sess.消息数 + 1
    // 保留最近5条上下文
    追加(sess.上下文, 文本)
    如果 (计数(sess.上下文) > 5) {
        sess.上下文 = 列表_切片(sess.上下文, 计数(sess.上下文) - 5, 计数(sess.上下文))
    }
}

函数 TG会话_是否过期(sess) {
    定义 当前 = 平台_获取时间_ms()
    返回 (当前 - sess.最后活动) > TG_会话超时_ms
}

函数 TG会话_销毁(sess) {
    Tensor_释放(sess.意图向量)
}

// 寻找或创建会话
函数 TG_获取会话(state, 聊天ID) {
    定义 可变 i = 0
    当 (i < 计数(state.会话表)) {
        如果 (state.会话表[i].聊天ID == 聊天ID) {
            返回 state.会话表[i]
        }
        i = i + 1
    }
    // 创建新会话
    定义 sess = TG会话_创建(聊天ID)
    追加(state.会话表, sess)
    // 清理过期会话
    如果 (计数(state.会话表) > TG_最大会话数) {
        TG_清理过期会话(state)
    }
    返回 sess
}

函数 TG_清理过期会话(state) {
    定义 可变 新表 = []
    定义 可变 i = 0
    当 (i < 计数(state.会话表)) {
        如果 (!TG会话_是否过期(state.会话表[i])) {
            追加(新表, state.会话表[i])
        } 否则 {
            TG会话_销毁(state.会话表[i])
        }
        i = i + 1
    }
    state.会话表 = 新表
}

// §4 初始化与创建

函数 Telegram适配_创建(机器人令牌) {
    定义 state = TG状态 {}
    state.令牌 = 机器人令牌
    state.最后更新ID = 0
    state.消息队列 = []
    state.模式 = TG模式_轮询
    state.webhook_url = ""
    state.当前秒_发送数 = 0
    state.当前秒_时间戳 = 0
    state.总接收数 = 0
    state.总发送数 = 0
    state.总错误数 = 0
    state.会话表 = []
    全局_TG状态 = state
    返回 渠道_创建("Telegram", 渠道类型_Telegram, TG_接收, TG_发送_文本)
}

函数 Telegram适配_初始化() {
    // 获取Bot信息验证令牌有效性
    定义 state = 全局_TG状态
    如果 (state == 空) { 返回 失败 }
    定义 url = TG_构建URL(state, "/getMe")
    定义 响应 = TG_HTTP_GET_重试(url)
    如果 (响应 == 空) { 返回 失败 }
    返回 成功
}

// §5 HTTP工具函数 (带重试+速率限制)

函数 TG_构建URL(state, 路径) {
    返回 字符串拼接(TG_接口基址, 字符串拼接(state.令牌, 路径))
}

函数 TG_HTTP_GET_重试(url) {
    定义 可变 重试 = 0
    当 (重试 < TG_最大重试) {
        定义 响应 = 网络_HTTP_GET(url, 443, "/")
        如果 (响应 != 空) { 返回 响应 }
        平台_休眠_ms(TG_重试间隔_ms * (重试 + 1))  // 指数退避
        重试 = 重试 + 1
    }
    返回 空
}

函数 TG_HTTP_POST_重试(url, body, content_type) {
    定义 可变 重试 = 0
    当 (重试 < TG_最大重试) {
        定义 响应 = 网络_HTTP_POST(url, body, content_type)
        如果 (响应 != 空) { 返回 响应 }
        平台_休眠_ms(TG_重试间隔_ms * (重试 + 1))
        重试 = 重试 + 1
    }
    返回 空
}

函数 TG_速率检查(state) {
    定义 当前 = 平台_获取时间_ms()
    定义 秒帧 = 当前 / 1000
    如果 (秒帧 != state.当前秒_时间戳) {
        state.当前秒_发送数 = 0
        state.当前秒_时间戳 = 秒帧
    }
    如果 (state.当前秒_发送数 >= TG_速率限制_每秒) {
        // 等待到下一秒
        平台_休眠_ms(1000 - (当前 % 1000))
        state.当前秒_发送数 = 0
        state.当前秒_时间戳 = state.当前秒_时间戳 + 1
    }
    state.当前秒_发送数 = state.当前秒_发送数 + 1
}

// §6 接收消息 (长轮询)

函数 TG_接收() {
    定义 state = 全局_TG状态
    如果 (state == 空) { 返回 空 }

    // 先检查缓冲队列
    如果 (计数(state.消息队列) > 0) {
        定义 消息 = state.消息队列[0]
        state.消息队列 = 列表_切片(state.消息队列, 1, 计数(state.消息队列))
        返回 消息
    }

    // 长轮询请求
    定义 参数 = 字符串拼接("/getUpdates?offset=",
        字符串拼接(整数转字符串(state.最后更新ID + 1),
            "&timeout=30&allowed_updates=[\"message\",\"callback_query\",\"inline_query\"]"))
    定义 url = TG_构建URL(state, 参数)
    定义 响应 = TG_HTTP_GET_重试(url)
    如果 (响应 != 空) {
        TG_解析更新批量(state, 响应)
    }

    // 从队列取消息
    如果 (计数(state.消息队列) > 0) {
        定义 消息 = state.消息队列[0]
        state.消息队列 = 列表_切片(state.消息队列, 1, 计数(state.消息队列))
        state.总接收数 = state.总接收数 + 1
        返回 消息
    }
    返回 空
}

// §7 JSON解析器 (TG响应解析)

函数 TG_提取字段(json, 字段名) {
    定义 键 = 字符串拼接("\"", 字符串拼接(字段名, "\":"))
    定义 pos = 字符串查找(json, 键)
    如果 (pos < 0) { 返回 空 }
    定义 值起 = pos + 字符串长度(键)
    // 跳过空格
    当 (值起 < 字符串长度(json) && 字符串_字符(json, 值起) == ' ') {
        值起 = 值起 + 1
    }
    如果 (值起 >= 字符串长度(json)) { 返回 空 }
    // 判断值类型
    定义 ch = 字符串_字符(json, 值起)
    如果 (ch == '"') {
        // 字符串值
        定义 结束 = 字符串查找(字符串子串(json, 值起 + 1, 字符串长度(json)), "\"")
        如果 (结束 < 0) { 返回 空 }
        返回 字符串子串(json, 值起 + 1, 值起 + 1 + 结束)
    } 否则如果 (ch == '{') {
        // 对象: 找匹配的}
        定义 可变 深度 = 1
        定义 可变 p = 值起 + 1
        当 (p < 字符串长度(json) && 深度 > 0) {
            定义 c = 字符串_字符(json, p)
            如果 (c == '{') { 深度 = 深度 + 1 }
            否则如果 (c == '}') { 深度 = 深度 - 1 }
            p = p + 1
        }
        返回 字符串子串(json, 值起, p)
    } 否则 {
        // 数字/布尔
        定义 可变 结束 = 值起
        当 (结束 < 字符串长度(json)) {
            定义 c = 字符串_字符(json, 结束)
            如果 (c == ',' || c == '}' || c == ']') { 跳出 }
            结束 = 结束 + 1
        }
        返回 字符串子串(json, 值起, 结束)
    }
}

函数 TG_解析更新批量(state, 响应) {
    // 解析result数组中的每个更新
    定义 可变 pos = 字符串查找(响应, "\"result\":")
    如果 (pos < 0) { 返回 }

    // 遍历每个update对象
    定义 可变 搜索位 = pos
    当 (搜索位 < 字符串长度(响应)) {
        定义 uid_pos = 字符串查找_从(响应, "\"update_id\":", 搜索位)
        如果 (uid_pos < 0) { 跳出 }

        // 提取update_id
        定义 uid起 = uid_pos + 12
        定义 uid值 = TG_提取字段(字符串子串(响应, uid_pos, 字符串长度(响应)), "update_id")
        如果 (uid值 != 空) {
            state.最后更新ID = 字符串转整数(uid值)
        }

        // 解析消息类型
        定义 msg = TG消息 {}
        定义 从位 = uid_pos
        定义 片段 = 字符串子串(响应, 从位, 最小值(从位 + 2000, 字符串长度(响应)))

        // 检查是否是回调查询
        如果 (字符串查找(片段, "\"callback_query\"") >= 0) {
            msg.类型 = TG消息类型_回调
            msg.回调数据 = TG_提取字段(片段, "data")
            msg.聊天ID = TG_提取字段(片段, "id")
        }
        // 检查是否是内联查询
        否则如果 (字符串查找(片段, "\"inline_query\"") >= 0) {
            msg.类型 = TG消息类型_内联查询
            msg.内联查询ID = TG_提取字段(片段, "id")
            msg.文本 = TG_提取字段(片段, "query")
        }
        // 普通消息
        否则 {
            msg.文本 = TG_提取字段(片段, "text")
            定义 chat_json = TG_提取字段(片段, "chat")
            如果 (chat_json != 空) {
                msg.聊天ID = TG_提取字段(chat_json, "id")
            }
            // 检测媒体类型
            如果 (字符串查找(片段, "\"photo\"") >= 0) {
                msg.类型 = TG消息类型_图片
                msg.file_id = TG_提取字段(片段, "file_id")
            } 否则如果 (字符串查找(片段, "\"document\"") >= 0) {
                msg.类型 = TG消息类型_文档
                msg.file_id = TG_提取字段(片段, "file_id")
            } 否则如果 (msg.文本 != 空 && 字符串长度(msg.文本) > 0 && 字符串_字符(msg.文本, 0) == '/') {
                msg.类型 = TG消息类型_命令
            } 否则 {
                msg.类型 = TG消息类型_文本
            }
        }

        追加(state.消息队列, msg)
        搜索位 = uid_pos + 50  // 跳过当前更新
    }
}

// §8 发送消息 (文本+富媒体+内联键盘)

函数 TG_发送_文本(聊天ID, 文本) {
    定义 state = 全局_TG状态
    如果 (state == 空) { 返回 失败 }
    TG_速率检查(state)

    定义 url = TG_构建URL(state, "/sendMessage")
    定义 body = 字符串拼接("{\"chat_id\":\"", 字符串拼接(聊天ID,
        字符串拼接("\",\"text\":\"", 字符串拼接(
            TG_转义字符串(文本), "\",\"parse_mode\":\"HTML\"}"))))
    定义 响应 = TG_HTTP_POST_重试(url, body, "application/json")
    如果 (响应 != 空) {
        state.总发送数 = state.总发送数 + 1
        返回 成功
    }
    state.总错误数 = state.总错误数 + 1
    返回 失败
}

函数 TG_发送_带键盘(聊天ID, 文本, 键盘JSON) {
    定义 state = 全局_TG状态
    如果 (state == 空) { 返回 失败 }
    TG_速率检查(state)

    定义 url = TG_构建URL(state, "/sendMessage")
    定义 body = 字符串拼接("{\"chat_id\":\"", 字符串拼接(聊天ID,
        字符串拼接("\",\"text\":\"", 字符串拼接(TG_转义字符串(文本),
            字符串拼接("\",\"reply_markup\":", 字符串拼接(键盘JSON, "}"))))))
    返回 TG_HTTP_POST_重试(url, body, "application/json") != 空
}

函数 TG_发送_图片(聊天ID, 图片URL, 标题) {
    定义 state = 全局_TG状态
    如果 (state == 空) { 返回 失败 }
    TG_速率检查(state)

    定义 url = TG_构建URL(state, "/sendPhoto")
    定义 body = 字符串拼接("{\"chat_id\":\"", 字符串拼接(聊天ID,
        字符串拼接("\",\"photo\":\"", 字符串拼接(图片URL,
            字符串拼接("\",\"caption\":\"", 字符串拼接(标题, "\"}")))))
    返回 TG_HTTP_POST_重试(url, body, "application/json") != 空
}

函数 TG_发送_文档(聊天ID, 文档URL, 标题) {
    定义 state = 全局_TG状态
    如果 (state == 空) { 返回 失败 }
    TG_速率检查(state)

    定义 url = TG_构建URL(state, "/sendDocument")
    定义 body = 字符串拼接("{\"chat_id\":\"", 字符串拼接(聊天ID,
        字符串拼接("\",\"document\":\"", 字符串拼接(文档URL,
            字符串拼接("\",\"caption\":\"", 字符串拼接(标题, "\"}")))))
    返回 TG_HTTP_POST_重试(url, body, "application/json") != 空
}

函数 TG_回答回调查询(callback_id, 文本) {
    定义 state = 全局_TG状态
    如果 (state == 空) { 返回 失败 }
    定义 url = TG_构建URL(state, "/answerCallbackQuery")
    定义 body = 字符串拼接("{\"callback_query_id\":\"", 字符串拼接(callback_id,
        字符串拼接("\",\"text\":\"", 字符串拼接(文本, "\"}"))))
    返回 TG_HTTP_POST_重试(url, body, "application/json") != 空
}

函数 TG_回答内联查询(query_id, 结果JSON) {
    定义 state = 全局_TG状态
    如果 (state == 空) { 返回 失败 }
    定义 url = TG_构建URL(state, "/answerInlineQuery")
    定义 body = 字符串拼接("{\"inline_query_id\":\"", 字符串拼接(query_id,
        字符串拼接("\",\"results\":", 字符串拼接(结果JSON, "}"))))
    返回 TG_HTTP_POST_重试(url, body, "application/json") != 空
}

// §9 字符串转义工具

函数 TG_转义字符串(输入) {
    // 转义JSON特殊字符: " \ / \n \t
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 字符串长度(输入)) {
        定义 ch = 字符串_字符(输入, i)
        如果 (ch == '"') {
            结果 = 字符串拼接(结果, "\\\"")
        } 否则如果 (ch == '\\') {
            结果 = 字符串拼接(结果, "\\\\")
        } 否则如果 (ch == '\n') {
            结果 = 字符串拼接(结果, "\\n")
        } 否则如果 (ch == '\t') {
            结果 = 字符串拼接(结果, "\\t")
        } 否则 {
            结果 = 字符串拼接(结果, 字符转字符串(ch))
        }
        i = i + 1
    }
    返回 结果
}

// §10 Webhook模式

函数 TG_设置Webhook(webhook_url) {
    定义 state = 全局_TG状态
    如果 (state == 空) { 返回 失败 }
    state.模式 = TG模式_WEBHOOK
    state.webhook_url = webhook_url

    定义 url = TG_构建URL(state, "/setWebhook")
    定义 body = 字符串拼接("{\"url\":\"", 字符串拼接(webhook_url, "\"}"  ))
    定义 响应 = TG_HTTP_POST_重试(url, body, "application/json")
    返回 响应 != 空
}

函数 TG_删除Webhook() {
    定义 state = 全局_TG状态
    如果 (state == 空) { 返回 失败 }
    state.模式 = TG模式_轮询
    定义 url = TG_构建URL(state, "/deleteWebhook")
    定义 响应 = TG_HTTP_GET_重试(url)
    返回 响应 != 空
}

// Webhook接收回调 (HTTP服务器调用)
函数 TG_Webhook回调(请求体) {
    定义 state = 全局_TG状态
    如果 (state == 空) { 返回 }
    TG_解析更新批量(state, 请求体)
}

// §11 【Nova原创】AI意图分析与智能回复
// 理论: 「消息意图向量化」— 将用户文本转为8维意图特征向量
//   维度: [问候, 查询, 命令, 投诉, 反馈, 聊天, 购买, 其他]
//   用关键词匹配 + 余弦相似度计算最佳响应模板

定义 AI意图_问候 = 0
定义 AI意图_查询 = 1
定义 AI意图_命令 = 2
定义 AI意图_投诉 = 3
定义 AI意图_反馈 = 4
定义 AI意图_聊天 = 5
定义 AI意图_购买 = 6
定义 AI意图_其他 = 7
定义 AI意图维度 = 8

// 意图关键词表 (Q8定点权重)
定义 问候关键词 = ["你好", "喂", "嗨", "hi", "hello", "早上好", "下午好"]
定义 查询关键词 = ["查询", "查找", "搜索", "哪里", "什么", "怎么", "如何"]
定义 命令关键词 = ["执行", "运行", "开始", "停止", "取消", "重启"]
定义 投诉关键词 = ["投诉", "问题", "故障", "错误", "差评", "不满"]
定义 反馈关键词 = ["建议", "反馈", "希望", "改进", "优化"]
定义 购买关键词 = ["买", "购买", "下单", "价格", "多少钱"]

函数 TG_AI_计算意图向量(文本) {
    定义 向量 = Tensor_创建(AI意图维度)
    // 对每个意图维度计算关键词命中分
    Tensor_写(向量, AI意图_问候, TG_AI_关键词分数(文本, 问候关键词))
    Tensor_写(向量, AI意图_查询, TG_AI_关键词分数(文本, 查询关键词))
    Tensor_写(向量, AI意图_命令, TG_AI_关键词分数(文本, 命令关键词))
    Tensor_写(向量, AI意图_投诉, TG_AI_关键词分数(文本, 投诉关键词))
    Tensor_写(向量, AI意图_反馈, TG_AI_关键词分数(文本, 反馈关键词))
    Tensor_写(向量, AI意图_聊天, 128)  // 默认聊天基线分
    Tensor_写(向量, AI意图_购买, TG_AI_关键词分数(文本, 购买关键词))
    Tensor_写(向量, AI意图_其他, 64)  // 默认其他基线
    返回 向量
}

函数 TG_AI_关键词分数(文本, 关键词列表) {
    定义 可变 分数 = 0
    定义 可变 i = 0
    当 (i < 计数(关键词列表)) {
        如果 (字符串查找(文本, 关键词列表[i]) >= 0) {
            分数 = 分数 + 256  // Q8: 1.0
        }
        i = i + 1
    }
    返回 分数
}

// 余弦相似度: cos(θ) = A·B / (|A| * |B|)
函数 TG_AI_余弦相似度(a, b) {
    定义 可变 点积 = 0
    定义 可变 模a = 0
    定义 可变 模b = 0
    定义 可变 i = 0
    当 (i < AI意图维度) {
        定义 va = Tensor_读(a, i)
        定义 vb = Tensor_读(b, i)
        点积 = 点积 + va * vb
        模a = 模a + va * va
        模b = 模b + vb * vb
        i = i + 1
    }
    如果 (模a == 0 || 模b == 0) { 返回 0 }
    // 返回Q8定点余弦值
    返回 (点积 << 8) / (整数平方根(模a) * 整数平方根(模b))
}

// AI智能处理消息
函数 TG_AI_处理消息(msg) {
    定义 state = 全局_TG状态
    如果 (state == 空 || msg.文本 == 空) { 返回 }

    // 获取/更新会话
    定义 sess = TG_获取会话(state, msg.聊天ID)
    TG会话_更新(sess, msg.文本)

    // 计算意图向量
    定义 意图 = TG_AI_计算意图向量(msg.文本)

    // 找出最强意图
    定义 可变 最大分 = 0
    定义 可变 最大索引 = AI意图_其他
    定义 可变 i = 0
    当 (i < AI意图维度) {
        定义 v = Tensor_读(意图, i)
        如果 (v > 最大分) {
            最大分 = v
            最大索引 = i
        }
        i = i + 1
    }

    // 发送AI总线事件
    全局AI总线.发送("渠道.TG.意图", 意图)

    // 根据意图生成响应
    定义 响应 = TG_AI_生成响应(最大索引, msg.文本, sess)
    如果 (响应 != 空) {
        TG_发送_文本(msg.聊天ID, 响应)
    }
    Tensor_释放(意图)
}

函数 TG_AI_生成响应(意图类型, 原始文本, sess) {
    如果 (意图类型 == AI意图_问候) {
        返回 "你好！有什么可以帮到你的？"
    } 否则如果 (意图类型 == AI意图_查询) {
        返回 字符串拼接("正在为您查询: ", 原始文本)
    } 否则如果 (意图类型 == AI意图_投诉) {
        返回 "非常抱歉给您带来不便，已记录您的反馈。"
    } 否则如果 (意图类型 == AI意图_反馈) {
        返回 "感谢您的建议！我们会认真考虑。"
    } 否则 {
        返回 空  // 让上层处理
    }
}

// §12 统计报告与健康检查

函数 TG_统计报告() {
    定义 state = 全局_TG状态
    如果 (state == 空) { 返回 }

    定义 特征 = Tensor_创建(6)
    Tensor_写(特征, 0, state.总接收数)
    Tensor_写(特征, 1, state.总发送数)
    Tensor_写(特征, 2, state.总错误数)
    Tensor_写(特征, 3, 计数(state.消息队列))
    Tensor_写(特征, 4, 计数(state.会话表))
    Tensor_写(特征, 5, state.模式)
    全局AI总线.发送("渠道.TG.统计", 特征)
    Tensor_释放(特征)
}

函数 TG_健康检查() {
    定义 state = 全局_TG状态
    如果 (state == 空) { 返回 假 }
    // 验证API可达
    定义 url = TG_构建URL(state, "/getMe")
    定义 响应 = 网络_HTTP_GET(url, 443, "/")
    如果 (响应 == 空) { 返回 假 }
    // 检查"ok":true
    返回 字符串查找(响应, "\"ok\":true") >= 0

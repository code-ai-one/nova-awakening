导入("../../../../标准库/基础.nova")
导入("../../../标记常量.nova")


// 类型标识
定义 类型_空 = 0
定义 基础类型_类型_列表 = 5
定义 基础类型_类型_字典 = 6
定义 基础类型_类型_函数 = 7
定义 类型_结构 = 8
定义 类型_枚举 = 9
定义 类型_接口 = 10
定义 类型_泛型 = 11
定义 基础类型_类型_任意 = 99

// AI原生对象类型
定义 基础类型_类型_张量 = 20
定义 类型_向量 = 21
定义 类型_概率分布 = 22
定义 类型_记忆块 = 23
定义 类型_图结构 = 24
定义 类型_批次 = 25

// AI精度描述
定义 精度_fp32 = 0
定义 精度_fp16 = 1
定义 精度_bf16 = 2
定义 精度_int8 = 3
定义 精度_int4 = 4

函数 精度名(p) {
    如果 (p == 精度_fp32) { 返回 "fp32" }
    如果 (p == 精度_fp16) { 返回 "fp16" }
    如果 (p == 精度_bf16) { 返回 "bf16" }
    如果 (p == 精度_int8) { 返回 "int8" }
    如果 (p == 精度_int4) { 返回 "int4" }
    返回 "未知精度"
}

函数 精度字节(p) {
    如果 (p == 精度_fp32) { 返回 4 }
    如果 (p == 精度_fp16) { 返回 2 }
    如果 (p == 精度_bf16) { 返回 2 }
    如果 (p == 精度_int8) { 返回 1 }
    如果 (p == 精度_int4) { 返回 1 }
    返回 4
}

// AI设备描述
定义 设备_cpu = 0
定义 设备_simd = 1
定义 设备_gpu = 2
定义 设备_裸机 = 3

函数 设备名(d) {
    如果 (d == 设备_cpu) { 返回 "cpu" }
    如果 (d == 设备_simd) { 返回 "simd" }
    如果 (d == 设备_gpu) { 返回 "gpu" }
    如果 (d == 设备_裸机) { 返回 "baremetal" }
    返回 "未知设备"
}

// AI记忆域标签
定义 记忆域_工作 = 0
定义 记忆域_语义 = 1
定义 记忆域_长期 = 2
定义 记忆域_上下文缓存 = 3

函数 记忆域名(m) {
    如果 (m == 记忆域_工作) { 返回 "工作记忆" }
    如果 (m == 记忆域_语义) { 返回 "语义记忆" }
    如果 (m == 记忆域_长期) { 返回 "长期记忆" }
    如果 (m == 记忆域_上下文缓存) { 返回 "上下文缓存" }
    返回 "未知记忆域"
}

// AI形状描述: [维度数, 静态维列表, 动态维标记列表, 批量轴, 序列轴]
函数 形状_创建(维度数) {
    定义 可变 静态维 = []
    定义 可变 动态标记 = []
    定义 可变 i = 0
    当 (i < 维度数) {
        追加(静态维, -1)
        追加(动态标记, 1)
        i = i + 1
    }
    返回 [维度数, 静态维, 动态标记, -1, -1]
}

函数 形状_维度数(s) { 返回 s[0] }
函数 形状_设静态维(s, 轴, 大小) { s[1][轴] = 大小  s[2][轴] = 0 }
函数 形状_是静态(s, 轴) { 返回 s[2][轴] == 0 }
函数 形状_设批量轴(s, 轴) { s[3] = 轴 }
函数 形状_设序列轴(s, 轴) { s[4] = 轴 }
函数 形状_批量轴(s) { 返回 s[3] }
函数 形状_序列轴(s) { 返回 s[4] }

函数 形状_兼容(a, b) {
    如果 (a == 空 或 b == 空) { 返回 真 }
    如果 (形状_维度数(a) != 形状_维度数(b)) { 返回 假 }
    定义 可变 i = 0
    当 (i < 形状_维度数(a)) {
        如果 (形状_是静态(a, i) 且 形状_是静态(b, i)) {
            如果 (a[1][i] != b[1][i]) { 返回 假 }
        }
        i = i + 1
    }
    返回 真
}

// AI类型描述符: [基类型, 精度, 设备, 记忆域, 形状, 可量化, 可分页]
函数 AI类型_创建(基类型, 精度, 设备, 记忆域, 形状) {
    返回 [基类型, 精度, 设备, 记忆域, 形状, 真, 假]
}
函数 AI类型_基类型(t) { 返回 t[0] }
函数 AI类型_精度(t) { 返回 t[1] }
函数 AI类型_设备(t) { 返回 t[2] }
函数 AI类型_记忆域(t) { 返回 t[3] }
函数 AI类型_形状(t) { 返回 t[4] }
函数 AI类型_可量化(t) { 返回 t[5] }
函数 AI类型_可分页(t) { 返回 t[6] }
函数 AI类型_设可分页(t) { t[6] = 真 }

// 类型检查错误
定义 类型错误_不兼容 = 1
定义 类型错误_参数数量 = 2
定义 类型错误_未定义 = 3
定义 类型错误_非函数 = 4
定义 类型错误_非索引 = 5
定义 类型错误_字段 = 6
定义 类型错误_非迭代 = 7
定义 类型错误_除零 = 8

// 类型名称
函数 基础类型_类型名(id) {
    如果 (id == 0) { 返回 "空"
}
 如果 (id == 1) { 返回 "布尔" }
 如果 (id == 2) { 返回 "整数" }
 如果 (id == 3) { 返回 "浮点" }
 如果 (id == 4) { 返回 "字符串" }
 如果 (id == 5) { 返回 "列表" }
 如果 (id == 6) { 返回 "字典" }
 如果 (id == 7) { 返回 "法" }
 如果 (id == 8) { 返回 "型" }
 如果 (id == 9) { 返回 "枚举" }
 如果 (id == 10) { 返回 "接口" }
 如果 (id == 标记_标识符) { 返回 "张量" }
 如果 (id == 21) { 返回 "向量" }
 如果 (id == 22) { 返回 "概率分布" }
 如果 (id == 23) { 返回 "记忆块" }
 如果 (id == 24) { 返回 "图结构" }
 如果 (id == 25) { 返回 "批次" }
 如果 (id == 标记_分号) { 返回 "任意" }
 返回 "unknown"
}

// 类型分类
函数 是数值(t) { 返回 t == 类型_整数 或 t == 类型_浮点 }
函数 是集合(t) { 返回 t == 基础类型_类型_列表 或 t == 基础类型_类型_字典 }
函数 是可索引(t) { 返回 t == 基础类型_类型_列表 或 t == 基础类型_类型_字典 或 t == 类型_字符串 }
函数 是可迭代(t) { 返回 t == 基础类型_类型_列表 或 t == 基础类型_类型_字典 或 t == 类型_字符串 }
函数 是可调用(t) { 返回 t == 基础类型_类型_函数 }
函数 是引用类型(t) { 返回 t == 基础类型_类型_列表 或 t == 基础类型_类型_字典 或 t == 类型_结构 或 t == 基础类型_类型_函数 或 是AI类型(t) }
函数 是AI类型(t) { 返回 t >= 20 且 t <= 25 }
函数 是张量族(t) { 返回 t == 基础类型_类型_张量 或 t == 类型_向量 或 t == 类型_批次 }
函数 是记忆族(t) { 返回 t == 类型_记忆块 }
函数 是概率族(t) { 返回 t == 类型_概率分布 }

// 二元运算结果类型
// op: 1=加 2=减 3=乘 4=除 5=模 6=比较 7=逻辑
函数 二元结果类型(op, 左, 右) {
 // 逻辑运算总是返回布尔
 如果 (op == 7) { 返回 类型_布尔 }
 // 比较运算总是返回布尔
 如果 (op == 6) { 返回 类型_布尔 }
 // 加法特殊: 字符串+字符串=连接
 如果 (op == 1 且 左 == 类型_字符串 且 右 == 类型_字符串) { 返回 类型_字符串 }
 // 乘法特殊: 字符串*整数=重复
 如果 (op == 3 且 左 == 类型_字符串 且 右 == 类型_整数) { 返回 类型_字符串 }
 // 数值提升
 如果 (是数值(左) 且 是数值(右)) { 如果 (左 == 类型_浮点 或 右 == 类型_浮点) { 返回 类型_浮点 }
 返回 类型_整数
 }
 // 列表+列表=拼接
 如果 (op == 1 且 左 == 基础类型_类型_列表 且 右 == 基础类型_类型_列表) { 返回 基础类型_类型_列表 }
 返回 基础类型_类型_任意
}

// 一元运算结果类型
// op: 1=负号 2=逻辑非 3=位非
函数 一元结果类型(op, 操作数) {
    如果 (op == 1 且 是数值(操作数)) { 返回 操作数
}
 如果 (op == 2) { 返回 类型_布尔 }
 如果 (op == 3 且 操作数 == 类型_整数) { 返回 类型_整数 }
 返回 基础类型_类型_任意
}

// 类型兼容 (子类型检查, 0)
函数 类型兼容(期望, 实际) {
    如果 (期望 == 基础类型_类型_任意) { 返回 真
}
 如果 (实际 == 基础类型_类型_任意) { 返回 真 }
 如果 (期望 == 实际) { 返回 真 }
 如果 (期望 == 类型_浮点 且 实际 == 类型_整数) { 返回 真 }
 如果 (期望 == 类型_字符串 且 实际 == 类型_整数) { 返回 真 }
 // AI类型兼容: 张量族内部可互转
 如果 (是张量族(期望) 且 是张量族(实际)) { 返回 真 }
 // 向量可赋值给张量(向量是1D张量)
 如果 (期望 == 基础类型_类型_张量 且 实际 == 类型_向量) { 返回 真 }
 返回 假
}

// 强制转换可行性
函数 可强转(源, 目标) {
    如果 (源 == 目标) { 返回 真
}
 如果 (源 == 类型_整数 且 目标 == 类型_浮点) { 返回 真 }
 如果 (源 == 类型_浮点 且 目标 == 类型_整数) { 返回 真 }
 如果 (目标 == 类型_字符串) { 返回 真 }
 如果 (目标 == 类型_布尔) { 返回 真 }
 返回 假
}

// 真值规则
// 返回哪些类型值为假: 0, 假, 空, "", []
函数 类型_假值(t) {
    如果 (t == 类型_空) { 返回 真
}
 如果 (t == 类型_布尔) { 返回 真 }
 如果 (t == 类型_整数) { 返回 真 }
 如果 (t == 类型_字符串) { 返回 真 }
 如果 (t == 基础类型_类型_列表) { 返回 真 }
 返回 假
}

// 类型注册表: [类型列表] 每条: [id, 名, 大小, 父类型]
函数 类型注册表_创建() { 返回 [] }

函数 类型注册表_注册(reg, id, 名, 大小, 父) {
 追加(reg, [id, 名, 大小, 父])
}

函数 类型注册表_查(reg, id) { 定义 可变 i = 0
 当 (i < 计数(reg)) { 如果 (reg[i][0] == id) { 返回 reg[i] }
 i = i + 1
 }
 返回 空
}

// 类型大小 (字节)
函数 类型大小(t) {
    如果 (t == 类型_空) { 返回 0
}
 如果 (t == 类型_布尔) { 返回 1 }
 如果 (t == 类型_整数) { 返回 8 }
 如果 (t == 类型_浮点) { 返回 8 }
 如果 (t == 类型_字符串) { 返回 16 }
 如果 (t == 基础类型_类型_列表) { 返回 24 }
 如果 (t == 基础类型_类型_字典) { 返回 32 }
 如果 (t == 基础类型_类型_函数) { 返回 8 }
 如果 (t == 类型_结构) { 返回 8 }
 返回 8
}

// 类型对齐
函数 类型对齐(t) {
    如果 (t == 类型_布尔) { 返回 1
}
 返回 8
}

// 类型别名: [[别名id, 原类型id], ...]
函数 别名表_创建() { 返回 [] }
函数 别名表_注册(表, 别名, 原类型) { 追加(表, [别名, 原类型]) }
函数 别名表_解析(表, 别名) { 定义 可变 i = 0
 当 (i < 计数(表)) { 如果 (表[i][0] == 别名) { 返回 表[i][1] }
 i = i + 1
 }
 返回 别名
}

// 类型环境 (作用域链): [[条目列表], 父环境]
函数 类型环境_创建() { 返回 [[], 空] }

函数 类型环境_子(父) { 返回 [[], 父] }

函数 类型环境_绑定(env, 名id, 类型id) {
 追加(env[0], [名id, 类型id])
}

函数 类型环境_查(env, 名id) {
 // 先查当前作用域
 定义 可变 当前 = env
 当 (当前 != 空) { 定义 可变 i = 计数(当前[0]) - 1
 当 (i >= 0) { 如果 (当前[0][i][0] == 名id) { 返回 当前[0][i][1] }
 i = i - 1
 }
 当前 = 当前[1]
 }
 返回 -1
}

函数 类型环境_深度(env) { 定义 可变 d = 0
 定义 可变 当前 = env
 当 (当前 != 空) { d = d + 1
 当前 = 当前[1] }
 返回 d
}

// 索引结果类型
函数 索引结果类型(容器, 索引) {
    如果 (容器 == 基础类型_类型_列表) { 返回 基础类型_类型_任意
}
 如果 (容器 == 基础类型_类型_字典) { 返回 基础类型_类型_任意 }
 如果 (容器 == 类型_字符串 且 索引 == 类型_整数) { 返回 类型_字符串 }
 返回 -1
}

// 类型兼容性
函数 类型_可赋值(源类型, 目标类型) {
    如果 (源类型 == 目标类型) { 返回 真
}
 如果 (源类型 == 类型_整数 且 目标类型 == 类型_浮点) { 返回 真 }
 // AI类型赋值: 张量族内部可赋值, 向量→张量
 如果 (是张量族(源类型) 且 是张量族(目标类型)) { 返回 真 }
 如果 (源类型 == 类型_向量 且 目标类型 == 基础类型_类型_张量) { 返回 真 }
 返回 假
}

函数 类型_大小(类型ID) {
    如果 (类型ID == 类型_整数) { 返回 8
}
 如果 (类型ID == 类型_浮点) { 返回 8 }
 如果 (类型ID == 类型_布尔) { 返回 1 }
 如果 (类型ID == 类型_字符) { 返回 4 }
 返回 8
}

函数 类型_是数值(类型ID) { 返回 类型ID == 类型_整数 或 类型ID == 类型_浮点
}

// AI类型大小
函数 AI类型大小(t) {
    如果 (t == 基础类型_类型_张量) { 返回 32 }
    如果 (t == 类型_向量) { 返回 24 }
    如果 (t == 类型_概率分布) { 返回 16 }
    如果 (t == 类型_记忆块) { 返回 40 }
    如果 (t == 类型_图结构) { 返回 32 }
    如果 (t == 类型_批次) { 返回 32 }
    返回 8
}

// AI约束检查
函数 AI约束_精度兼容(a, b) {
    如果 (a == b) { 返回 真 }
    // fp32可隐式降级到fp16/bf16
    如果 (a == 精度_fp32 且 (b == 精度_fp16 或 b == 精度_bf16)) { 返回 真 }
    返回 假
}

函数 AI约束_设备兼容(a, b) {
    如果 (a == b) { 返回 真 }
    // cpu可在simd上运行
    如果 (a == 设备_cpu 且 b == 设备_simd) { 返回 真 }
    返回 假
}

函数 AI约束_记忆域可访问(域, 操作) {
    // 操作: 0=读 1=写 2=分配 3=释放
    如果 (域 == 记忆域_长期 且 操作 == 3) { 返回 假 }
    返回 真
}

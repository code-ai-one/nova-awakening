函数 PCP_释放(z, 页号, 迁移类型) {
    如果 (迁移类型 >= MIGRATE_PCPTYPES) { 迁移类型 = MIGRATE_MOVABLE }
    自旋锁_获取(z.PCP.锁)
    链表_头插(z.PCP.链表[迁移类型], 页号)  // 热页放头部(更可能在cache)
    z.PCP.计数 = z.PCP.计数 + 1

    // 超过高水位: 归还batch个给伙伴系统
    如果 (z.PCP.计数 > z.PCP.高水位) {
        自旋锁_释放(z.PCP.锁)
        PCP_批量归还(z, 迁移类型)
        返回
    }
    自旋锁_释放(z.PCP.锁)
}

函数 PCP_批量归还(z, 迁移类型) {
    自旋锁_获取(z.PCP.锁)
    自旋锁_获取(z.锁)
    定义 可变 归还数 = 0
    当 (归还数 < z.PCP.批量 && !链表_为空(z.PCP.链表[迁移类型])) {
        定义 节点 = 链表_尾节点(z.PCP.链表[迁移类型])  // 冷页从尾部取
        定义 页号 = 链表_数据(节点)
        链表_删除(节点)
        z.PCP.计数 = z.PCP.计数 - 1
        // 归还给伙伴系统(阶0, 会尝试合并)
        __伙伴_放回(z, 页号, 0, 迁移类型)
        归还数 = 归还数 + 1
    }
    自旋锁_释放(z.锁)
    自旋锁_释放(z.PCP.锁)
}

// 伙伴系统内部: 从zone取页 (需持有z.锁)

函数 __伙伴_取页(z, 阶, 迁移类型) {
    // 1. 首先在首选迁移类型中查找
    定义 页号 = __伙伴_取页_最小(z, 阶, 迁移类型)
    如果 (页号 >= 0) { 返回 页号 }

    // 2. 回退: 按回退链尝试其他迁移类型
    如果 (迁移类型 < MIGRATE_PCPTYPES) {
        定义 回退 = 回退链[迁移类型]
        定义 可变 i = 0
        当 (i < 计数(回退)) {
            页号 = __伙伴_取页_最小(z, 阶, 回退[i])
            如果 (页号 >= 0) {
                z.回退次数 = z.回退次数 + 1
                // 如果整个页块被借用, 改变页块迁移类型(减少未来碎片)
                如果 (阶 >= 页块阶 / 2) {
                    设置页块迁移类型(z, 页号, 迁移类型)
                }
                返回 页号
            }
            i = i + 1
        }
    }

    返回 0 - 1
}

函数 __伙伴_取页_最小(z, 请求阶, 迁移类型) {
    // 从请求阶开始向上搜索, 找到第一个有空闲块的阶
    定义 可变 当前阶 = 请求阶
    当 (当前阶 <= 最大阶) {
        定义 链 = z.空闲区[当前阶].空闲链表[迁移类型]
        如果 (!链表_为空(链)) {
            定义 节点 = 链表_首节点(链)
            定义 页号 = 链表_数据(节点)
            链表_删除(节点)
            z.空闲区[当前阶].空闲数 = z.空闲区[当前阶].空闲数 - 1

            // 标记位图
            定义 块大小 = 1 << 当前阶
            如果 (页状态 != 空) { 位图_清除范围(页状态, 页号, 块大小) }

            // 分裂: 大块切小, 剩余放回低阶空闲链表
            __伙伴_分裂(z, 页号, 当前阶, 请求阶, 迁移类型)

            // 更新分配页描述符
            定义 分配大小 = 1 << 请求阶
            定义 可变 j = 0
            当 (j < 分配大小) {
                定义 页 = 页描述符_获取(页号 + j)
                如果 (页 != 空) {
                    页描述符_清除标志(页, 页_伙伴)
                    设置(页, PG_阶, 请求阶)
                    页描述符_增引用(页)
                }
                j = j + 1
            }

            z.分配次数 = z.分配次数 + 1
            返回 页号
        }
        当前阶 = 当前阶 + 1
    }
    返回 0 - 1
}

函数 __伙伴_分裂(z, 页号, 原阶, 目标阶, 迁移类型) {
    定义 可变 当前阶 = 原阶
    当 (当前阶 > 目标阶) {
        当前阶 = 当前阶 - 1
        定义 伙伴页号 = 页号 + (1 << 当前阶)
        // 剩余半块放回空闲链表
        链表_尾插(z.空闲区[当前阶].空闲链表[迁移类型], 伙伴页号)
        z.空闲区[当前阶].空闲数 = z.空闲区[当前阶].空闲数 + 1
        // 标记伙伴半块为空闲
        如果 (页状态 != 空) {
            位图_设置范围(页状态, 伙伴页号, 1 << 当前阶)
        }
        // 更新伙伴页描述符
        定义 伙伴页 = 页描述符_获取(伙伴页号)
        如果 (伙伴页 != 空) {
            页描述符_设置标志(伙伴页, 页_伙伴)
            设置(伙伴页, PG_阶, 当前阶)
        }
        z.分裂次数 = z.分裂次数 + 1
    }
}

// 伙伴系统内部: 放回页到zone (需持有z.锁)

函数 __伙伴_放回(z, 页号, 阶, 迁移类型) {
    定义 可变 当前页 = 页号
    定义 可变 当前阶 = 阶

    // 迭代合并伙伴 (Linux: 最核心的循环)
    当 (当前阶 < 最大阶) {
        // 计算伙伴页号: XOR(pfn, 1<<order) — 利用二进制对齐特性
        定义 伙伴页 = 当前页 ^ (1 << 当前阶)

        // 伙伴有效性检查
        如果 (伙伴页 >= z.起始页号 + z.跨越页数) { 中断 }
        如果 (伙伴页 < z.起始页号) { 中断 }

        // 检查伙伴是否空闲且阶匹配
        如果 (!__伙伴_是空闲(z, 伙伴页, 当前阶)) { 中断 }

        // 从空闲链表移除伙伴
        定义 伙伴mt = 获取页块迁移类型(z, 伙伴页)
        __伙伴_移除(z, 伙伴页, 当前阶, 伙伴mt)

        // 合并: 取对齐的(较小的)页号
        如果 (伙伴页 < 当前页) { 当前页 = 伙伴页 }
        当前阶 = 当前阶 + 1
        z.合并次数 = z.合并次数 + 1
    }

    // 放入合并后的块
    链表_尾插(z.空闲区[当前阶].空闲链表[迁移类型], 当前页)
    z.空闲区[当前阶].空闲数 = z.空闲区[当前阶].空闲数 + 1
    如果 (页状态 != 空) {
        位图_设置范围(页状态, 当前页, 1 << 当前阶)
    }

    // 更新页描述符
    定义 合并页 = 页描述符_获取(当前页)
    如果 (合并页 != 空) {
        页描述符_设置标志(合并页, 页_伙伴)
        设置(合并页, PG_阶, 当前阶)
    }
}

函数 __伙伴_是空闲(z, 页号, 阶) {
    如果 (页状态 == 空) { 返回 假 }
    如果 (!位图_测试(页状态, 页号)) { 返回 假 }
    定义 页 = 页描述符_获取(页号)
    如果 (页 == 空) { 返回 假 }
    如果 (!页描述符_测试标志(页, 页_伙伴)) { 返回 假 }
    如果 (页[PG_阶] != 阶) { 返回 假 }
    返回 真
}

函数 __伙伴_移除(z, 页号, 阶, 迁移类型) {
    定义 头 = z.空闲区[阶].空闲链表[迁移类型]
    定义 可变 当前 = 链表_首节点_或空(头)
    当 (当前 != 空 && 当前 != 头) {
        如果 (链表_数据(当前) == 页号) {
            链表_删除(当前)
            z.空闲区[阶].空闲数 = z.空闲区[阶].空闲数 - 1
            返回 真
        }
        当前 = 链表_后继(当前)
    }
    返回 假
}

// 核心外部接口 

函数 伙伴系统_分配(阶) {
    返回 伙伴系统_分配_带标志(阶, GFP_KERNEL)
}

函数 伙伴系统_分配_带标志(阶, gfp) {
    如果 (阶 > 最大阶) {
        内核警告("伙伴系统: 请求阶超限")
        返回 0 - 1
    }

    定义 首选zone = gfp_到_zone类型(gfp)
    定义 迁移类型 = gfp_到_迁移类型(gfp)
    定义 是原子 = (gfp & GFP_ATOMIC) != 0 || (gfp & __GFP_HIGH) != 0
}

定义 可变 AI_每核页释放_运行指标 = 0
定义 可变 AI_每核页释放_异常指标 = 0

函数 AI_每核页释放_自诊断() {
    AI_每核页释放_运行指标 = 0
    返回 AI_每核页释放_运行指标
}

函数 AI_每核页释放_优化建议() {
    定义 指标 = AI_每核页释放_自诊断()
    返回 "每核页释放状态正常"
}

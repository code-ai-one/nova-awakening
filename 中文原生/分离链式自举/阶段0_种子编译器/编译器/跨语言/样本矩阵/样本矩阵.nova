// Nova · 跨语言样本矩阵 · M24工业样本矩阵
// 职责: 管理跨语言原生重置的验证样本集,跟踪各语言/规模/复杂度的覆盖
// 层级: M24 — 工业样本矩阵

// 样本规模级别

导入("../../../标准库/基础.nova")

定义 规模_微型     = 0  // <500行
定义 规模_小型     = 1  // 500-5K行
定义 规模_中型     = 2  // 5K-50K行
定义 规模_大型     = 3  // 50K-500K行
定义 规模_超大型   = 4  // >500K行

// 样本复杂度
定义 复杂度_简单   = 0  // 纯函数,无外部依赖
定义 复杂度_标准   = 1  // 标准库依赖,标准并发
定义 复杂度_复杂   = 2  // 第三方依赖,FFI,反射
定义 复杂度_极端   = 3  // 模板元编程,宏重载,字节码织入

// 样本状态
定义 样本_待测     = 0
定义 样本_探测通过 = 1
定义 样本_语义通过 = 2
定义 样本_重建通过 = 3
定义 样本_等价通过 = 4
定义 样本_合规通过 = 5
定义 样本_全通过   = 6
定义 样本_失败     = 7
定义 样本_暂缓     = 8

// 样本条目: [名称, 语言, 规模, 复杂度, 状态, 行数, 函数数, 公共API数, 诊断列表]
函数 样本_创建(名称, 语言, 规模, 复杂度) {
    返回 [名称, 语言, 规模, 复杂度, 样本_待测, 0, 0, []]
}

函数 样本_名称(s) { 返回 s[0] }
函数 样本_语言(s) { 返回 s[1] }
函数 样本_规模(s) { 返回 s[2] }
函数 样本_复杂度(s) { 返回 s[3] }
函数 样本_状态(s) { 返回 s[4] }
函数 样本_行数(s) { 返回 s[5] }
函数 样本_函数数(s) { 返回 s[6] }

函数 样本_设状态(s, 状态) { s[4] = 状态 }
函数 样本_设行数(s, n) { s[5] = n }
函数 样本_设函数数(s, n) { s[6] = n }
函数 样本_设公共API数(s, n) { s[7] = n }
函数 样本_添加诊断(s, 消息) { 追加(s[8], 消息) }

// 样本矩阵: [样本列表, 语言覆盖字典, 总统计]
函数 样本矩阵_创建() {
    返回 [[], 字典(), [0, 0, 0]]  // [样本列表, 语言覆盖, [总数, 通过, 失败, 暂缓]]
}

函数 矩阵_样本(m) { 返回 m[0] }
函数 矩阵_语言覆盖(m) { 返回 m[1] }

函数 矩阵_添加样本(m, 样本) {
    追加(m[0], 样本)
    m[3][0] = m[3][0] + 1
}

函数 矩阵_更新统计(m) {
    m[3][1] = 0
    m[3][2] = 0
    m[3][3] = 0
    定义 可变 i = 0
    当 (i < 计数(m[0])) {
        如果 (m[0][i][4] == 样本_全通过) { m[3][1] = m[3][1] + 1 }
        如果 (m[0][i][4] == 样本_失败) { m[3][2] = m[3][2] + 1 }
        如果 (m[0][i][4] == 样本_暂缓) { m[3][3] = m[3][3] + 1 }
        i = i + 1
    }
}

// 预置第一波样本
函数 矩阵_加载第一波(m) {
    // Rust样本
    矩阵_添加样本(m, 样本_创建("rust-cli-simple", 1, 规模_微型, 复杂度_简单))
    矩阵_添加样本(m, 样本_创建("rust-lib-no-macro", 1, 规模_小型, 复杂度_标准))
    矩阵_添加样本(m, 样本_创建("rust-web-actix", 1, 规模_中型, 复杂度_复杂))

    // Go样本
    矩阵_添加样本(m, 样本_创建("go-cli-cobra", 2, 规模_小型, 复杂度_简单))
    矩阵_添加样本(m, 样本_创建("go-service-gin", 2, 规模_中型, 复杂度_标准))
    矩阵_添加样本(m, 样本_创建("go-grpc-service", 2, 规模_中型, 复杂度_复杂))

    // C样本
    矩阵_添加样本(m, 样本_创建("c-lib-abi-clean", 3, 规模_小型, 复杂度_简单))
    矩阵_添加样本(m, 样本_创建("c-embedded-hal", 3, 规模_中型, 复杂度_标准))

    // Java样本
    矩阵_添加样本(m, 样本_创建("java-spring-minimal", 6, 规模_中型, 复杂度_复杂))
    矩阵_添加样本(m, 样本_创建("java-cli-picocli", 6, 规模_小型, 复杂度_简单))

    // Python样本
    矩阵_添加样本(m, 样本_创建("python-fastapi", 5, 规模_小型, 复杂度_标准))
    矩阵_添加样本(m, 样本_创建("python-cli-click", 5, 规模_微型, 复杂度_简单))

    // 暂缓样本(高风险)
    定义 s1 = 样本_创建("rust-proc-macro-heavy", 1, 规模_中型, 复杂度_极端)
    样本_设状态(s1, 样本_暂缓)
    样本_添加诊断(s1, "proc-macro需要宏展开器支持")
    矩阵_添加样本(m, s1)

    定义 s2 = 样本_创建("cpp-template-meta", 4, 规模_中型, 复杂度_极端)
    样本_设状态(s2, 样本_暂缓)
    样本_添加诊断(s2, "C++模板元编程超出受控子集")
    矩阵_添加样本(m, s2)

    定义 s3 = 样本_创建("python-django-full", 5, 规模_大型, 复杂度_极端)
    样本_设状态(s3, 样本_暂缓)
    样本_添加诊断(s3, "Django ORM/反射/monkey-patch超出受控范围")
    矩阵_添加样本(m, s3)
}

// 矩阵覆盖报告
函数 矩阵_打印报告(m) {
    矩阵_更新统计(m)
    打印("═══ 工业样本矩阵报告 ═══")
    打印文本(字符串拼接("  总样本数: ", 转字符串(m[3][0])))
    打印文本(字符串拼接("  全通过: ", 转字符串(m[3][1])))
    打印文本(字符串拼接("  失败: ", 转字符串(m[3][2])))
    打印文本(字符串拼接("  暂缓: ", 转字符串(m[3][3])))
    如果 (m[3][0] > 0) {
        打印文本(字符串拼接("  通过率: ", 字符串拼接(转字符串(m[3][1] * 100 / m[3][0]), "%")))
    }

    // 按语言统计
    打印("\n  语言覆盖:")
    定义 可变 语言统计 = [0, 0, 0,]  // 语言0-6的样本数
    定义 可变 i = 0
    当 (i < 计数(m[0])) {
        定义 lang = m[0][i][1]
        如果 (lang >= 0 且 lang <= 6) { 语言统计[lang] = 语言统计[lang] + 1 }
        i = i + 1
    }
    如果 (语言统计[1] > 0) { 打印文本(字符串拼接("    Rust: ", 转字符串(语言统计[1]))) }
    如果 (语言统计[2] > 0) { 打印文本(字符串拼接("    Go: ", 转字符串(语言统计[2]))) }
    如果 (语言统计[3] > 0) { 打印文本(字符串拼接("    C: ", 转字符串(语言统计[3]))) }
    如果 (语言统计[4] > 0) { 打印文本(字符串拼接("    C++: ", 转字符串(语言统计[4]))) }
    如果 (语言统计[5] > 0) { 打印文本(字符串拼接("    Python: ", 转字符串(语言统计[5]))) }
    如果 (语言统计[6] > 0) { 打印文本(字符串拼接("    Java: ", 转字符串(语言统计[6]))) }
}

// 矩阵合格判定
函数 矩阵_是否合格(m) {
    矩阵_更新统计(m)
    // 通过率>=60%且无暂缓外失败项
    如果 (m[3][0] == 0) { 返回 假 }
    定义 有效数 = m[3][0] - m[3][3]  // 扣除暂缓
    如果 (有效数 == 0) { 返回 假 }
    返回 m[3][1] * 100 / 有效数 >= 60
}

// 样本逐项打印
函数 矩阵_打印详情(m) {
    打印("═══ 样本矩阵详情 ═══")
    定义 可变 i = 0
    当 (i < 计数(m[0])) {
        定义 s = m[0][i]
        定义 可变 状态名 = "待测"
        如果 (s[4] == 样本_全通过) { 状态名 = "✅全通过" }
        如果 (s[4] == 样本_失败) { 状态名 = "❌失败" }
        如果 (s[4] == 样本_暂缓) { 状态名 = "⏸暂缓" }
        如果 (s[4] == 样本_探测通过) { 状态名 = "探测✓" }
        如果 (s[4] == 样本_语义通过) { 状态名 = "语义✓" }
        如果 (s[4] == 样本_重建通过) { 状态名 = "重建✓" }
        打印文本(字符串拼接("  ", 字符串拼接(s[0], 字符串拼接(" → ", 状态名))))
        i = i + 1
    }
}

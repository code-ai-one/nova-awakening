// Nova 语法树节点定义 — 纯正中文原生标识体系
//    叶节点(阴终止) ←→ 分支节点(阳扩展)

// 节点类型常量

// 表达式节点

导入("../../标准库/基础.nova")

// 整数字面量
// 浮点字面量
// 字符串字面量
定义 节_布尔     = 4     // 布尔字面量
定义 节_空值     = 5     // 空值字面量
定义 节_标识     = 6     // 标识符
// 二元运算
定义 节_一元     = 11    // 一元运算
// 函数调用
// 索引访问 a[b]
定义 节_成员     = 14    // 成员访问 a.b
// 赋值
// 三元表达式
// 列表字面量
// 字典字面量
// 匿名函数

// 语句节点
定义 节_声明变量 = 30    // 变量声明
定义 节_声明函数 = 31    // 函数声明
// 返回语句
定义 节_条件     = 33    // 条件语句
定义 节_循环     = 34    // 当循环
定义 节_遍历     = 35    // 对于循环
定义 节_代码块   = 36    // 代码块
// 止
// 续
// 匹配语句
定义 节_导入     = 40    // 入
定义 节_结构定义 = 41    // 结构体定义
定义 节_异常捕获 = 42    // 异常处理
定义 节_异常抛出 = 43    // 抛出异常
定义 节_表达式句 = 44    // 表达式语句

// 顶层节点
定义 节_程序     = 50    // 程序根节点

// 节点构造函数
// 节点格式: [类型, 数据, 行号, 子节点列表]

函数 创建节点(类型, 数据, 行号) {
    _节点_创建数 = _节点_创建数 + 1
    返回 [类型, 数据, 行号, []]
}

函数 创建叶节点(类型, 值, 行号) {
    _节点_创建数 = _节点_创建数 + 1
    返回 [类型, 值, 行号, []]
}

函数 创建二元(运算符, 左, 右, 行号) {
    返回 [节_二元, 运算符, 行号, [左, 右]]
}

函数 创建一元(运算符, 操作数, 行号) {
    返回 [节_一元, 运算符, 行号, [操作数]]
}

函数 创建调用(函数名, 参数列表, 行号) {
    返回 [节_调用, 函数名, 行号, 参数列表]
}

函数 创建赋值(目标, 值, 行号) {
    返回 [节_赋值, 0, 行号, [目标, 值]]
}

函数 创建条件(条件, 真支, 假支, 行号) {
    返回 [节_条件, 0, 行号, [条件, 真支, 假支]]
}

函数 创建循环(条件, 体, 行号) {
    返回 [节_循环, 0, 行号, [条件, 体]]
}

函数 创建块(语句列表, 行号) {
    返回 [节_代码块, 0, 行号, 语句列表]
}

函数 创建变量(名称, 是可变, 初值, 行号) {
    返回 [节_声明变量, [名称, 是可变], 行号, [初值]]
}

函数 创建函数(名称, 参数, 体, 行号) {
    返回 [节_声明函数, [名称, 参数], 行号, [体]]
}

函数 创建程序(语句列表) {
    返回 [节_程序, 0, 语句列表]
}

// 节点访问
函数 节点_类型(n) { 返回 n[0] }
函数 节点_数据(n) { 返回 n[1] }
函数 节点_行号(n) { 返回 n[2] }
函数 节点_子节点(n) { 返回 n[3] }
函数 节点_子数(n) { 返回 计数(n[3]) }
函数 AST_类型(n) { 返回 节点_类型(n) }
函数 AST_行号(n) { 返回 节点_行号(n) }
函数 AST_子节点(n) { 返回 节点_子节点(n) }
函数 AST_子节点数(n) { 返回 节点_子数(n) }

函数 节点_左(n) { 返回 n[3][0] }
函数 节点_右(n) { 返回 n[3][1] }

// 节点分类
函数 是表达式(t) {
    返回 t >= 1 且 t <= 19
}

函数 是语句(t) {
    返回 t >= 30 且 t <= 44
}

函数 是字面量(t) {
    返回 t >= 1 且 t <= 5
}

函数 有副作用(t) {
    如果 (t == 节_赋値) { 返回 1 }
    如果 (t == 节_调用) { 返回 1 }
    返回 0
}

// 节点计数
函数 统计节点(节点) {
    定义 可变 总 = 1
    定义 子 = 节点_子节点(节点)
    定义 可变 i = 0
    当 (i < 计数(子)) {
        总 = 总 + 统计节点(子[i])
        i = i + 1
    }
    返回 总
}

// 深度计算
函数 节点深度(节点) {
    定义 子 = 节点_子节点(节点)
    如果 (计数(子) == 0) { 返回 1 }
    定义 可变 最大 = 0
    定义 可变 i = 0
    当 (i < 计数(子)) {
        定义 d = 节点深度(子[i])
        如果 (d > 最大) { 最大 = d }
        i = i + 1
    }
    返回 最大 + 1
}

// 节点遍历

函数 前序遍历(节点, 访问函数) {
    _节点_遍历数 = _节点_遍历数 + 1
    访问函数(节点)
    定义 子 = 节点_子节点(节点)
    定义 可变 i = 0
    当 (i < 计数(子)) {
        前序遍历(子[i], 访问函数)
        i = i + 1
    }
}

函数 后序遍历(节点, 访问函数) {
    定义 子 = 节点_子节点(节点)
    定义 可变 i = 0
    当 (i < 计数(子)) {
        后序遍历(子[i], 访问函数)
        i = i + 1
    }
    访问函数(节点)
}

函数 收集叶节点(节点) {
    定义 子 = 节点_子节点(节点)
    如果 (计数(子) == 0) { 返回 [节点] }
    定义 可变 叶列表 = []
    定义 可变 i = 0
    当 (i < 计数(子)) {
        定义 子叶 = 收集叶节点(子[i])
        定义 可变 j = 0
        当 (j < 计数(子叶)) { 追加(叶列表, 子叶[j])  j = j + 1 }
        i = i + 1
    }
    返回 叶列表
}

// 节点查找

函数 查找节点_按类型(节点, 类型) {
    定义 可变 结果 = []
    如果 (节点_类型(节点) == 类型) { 追加(结果, 节点) }
    定义 子 = 节点_子节点(节点)
    定义 可变 i = 0
    当 (i < 计数(子)) {
        定义 子结果 = 查找节点_按类型(子[i], 类型)
        定义 可变 j = 0
        当 (j < 计数(子结果)) { 追加(结果, 子结果[j])  j = j + 1 }
        i = i + 1
    }
    返回 结果
}

函数 查找首个(节点, 类型) {
    如果 (节点_类型(节点) == 类型) { 返回 节点 }
    定义 子 = 节点_子节点(节点)
    定义 可变 i = 0
    当 (i < 计数(子)) {
        定义 找到 = 查找首个(子[i], 类型)
        如果 (找到 != 空) { 返回 找到 }
        i = i + 1
    }
    返回 空
}

// 节点替换

函数 替换节点(节点, 旧类型, 替换函数) {
    _节点_替换数 = _节点_替换数 + 1
    如果 (节点_类型(节点) == 旧类型) { 返回 替换函数(节点) }
    定义 子 = 节点_子节点(节点)
    定义 可变 i = 0
    当 (i < 计数(子)) {
        子[i] = 替换节点(子[i], 旧类型, 替换函数)
        i = i + 1
    }
    返回 节点
}

// 节点宽度

函数 节点宽度(节点) {
    定义 子 = 节点_子节点(节点)
    如果 (计数(子) == 0) { 返回 1 }
    定义 可变 宽度 = 0
    定义 可变 i = 0
    当 (i < 计数(子)) {
        宽度 = 宽度 + 节点宽度(子[i])
        i = i + 1
    }
    返回 宽度
}

// 节点路径

函数 节点路径(根, 目标, 路径) {
    追加(路径, 根)
    如果 (根 == 目标) { 返回 真 }
    定义 子 = 节点_子节点(根)
    定义 可变 i = 0
    当 (i < 计数(子)) {
        如果 (节点路径(子[i], 目标, 路径)) { 返回 真 }
        i = i + 1
    }
    删除(路径, 计数(路径) - 1)
    返回 假
}

// 节点序列化

函数 节点转字符串(节点, 缩进) {
    定义 可变 前缀 = ""
    定义 可变 i = 0
    当 (i < 缩进) { 前缀 = 前缀 + "  "  i = i + 1 }
    定义 可变 结果 = 前缀 + 转字符串(节点_类型(节点))
    定义 子 = 节点_子节点(节点)
    如果 (计数(子) > 0) {
        结果 = 结果 + " {\n"
        i = 0
        当 (i < 计数(子)) {
            结果 = 结果 + 节点转字符串(子[i], 缩进 + 1) + "\n"
            i = i + 1
        }
        结果 = 结果 + 前缀 + "}"
    }
    返回 结果
}

定义 可变 _节点_创建数 = 0
定义 可变 _节点_遍历数 = 0
定义 可变 _节点_替换数 = 0

函数 节点_记录创建() { _节点_创建数 = _节点_创建数 + 1 }
函数 节点_记录遍历() { _节点_遍历数 = _节点_遍历数 + 1 }
函数 节点_记录替换() { _节点_替换数 = _节点_替换数 + 1 }

// NovaOS AI安全检测 — 先天AI特性
// Phase: P5 | NovaOS原创
// 核心算法:
//   1. 行为基线建模: 每进程建立系统调用频率基线(EMA)
//   2. 异常检测: 当前行为偏离基线超过阈值→报警
//   3. 权限提升检测: 监控uid/gid变化序列
//   4. 暴力破解检测: 短时间内大量失败的认证类调用
//   5. 自适应阈值: 基线随系统运行自动调整

定义 安全_正常 = 0
定义 安全_可疑 = 1
定义 安全_危险 = 2
定义 安全_攻击 = 3

结构 安全画像 {
    pid,
    调用频率EMA,    // u64 系统调用/秒 × 1024
    上次调用时间,
    窗口内调用数,    // u32 当前1秒窗口内调用数
    窗口起始时间,
    失败计数,    // u32 连续失败的系统调用数
    敏感调用计数,    // u32 exec/ptrace/mount等敏感调用数
    异常得分,    // u32 0-1000 异常得分
    信任等级,    // u8 0=未知 1=低 2=中 3=高
}

定义 可变 安全画像表 = []
定义 可变 异常事件计数 = 0
定义 可变 AI安全_已初始化 = 假
定义 可变 全局威胁等级 = 0        // 0=安全 1=警戒 2=危险

// 敏感系统调用号(exec/ptrace/mount/setuid/socket等)
定义 敏感调用 = [59, 101, 165, 105, 106, 41, 42, 49]  // execve/ptrace/mount/setuid/setgid/socket/connect/bind

函数 AI安全_初始化() {
    AI安全_已初始化 = 真
    内核信息("AI安全检测: 行为基线建模+异常偏离检测+自适应阈值")
}

// 核心: 每次系统调用时检查

函数 AI安全_检查系统调用(PID, 调用号) {
    如果 (!AI安全_已初始化) { 返回 真 }
    定义 画像 = AI安全_获取或创建画像(PID)
    定义 现在 = 读取毫秒()

    // 1. 更新调用频率
    画像.窗口内调用数 = 画像.窗口内调用数 + 1
    如果 (现在 - 画像.窗口起始时间 > 1000) {
        // 新窗口: 更新EMA频率
        定义 频率 = 画像.窗口内调用数 * 1024   // 调用/秒 × 1024
        画像.调用频率EMA = (画像.调用频率EMA * 922 + 频率 * 102) / 1024
        画像.窗口内调用数 = 0
        画像.窗口起始时间 = 现在
    }
    画像.上次调用时间 = 现在

    // 2. 检查是否为敏感调用
    定义 是敏感 = AI安全_是敏感调用(调用号)
    如果 (是敏感) { 画像.敏感调用计数 = 画像.敏感调用计数 + 1 }

    // 3. 异常得分计算
    定义 可变 得分 = 0

    // 3a. 频率异常: 当前频率远超基线
    如果 (画像.调用频率EMA > 0) {
        定义 当前频率 = 画像.窗口内调用数 * 1024
        如果 (当前频率 > 画像.调用频率EMA * 3) {
            得分 = 得分 + 300   // 频率是基线3倍以上
        } 否则 如果 (当前频率 > 画像.调用频率EMA * 2) {
            得分 = 得分 + 150
        }
    }

    // 3b. 敏感调用密集
    如果 (画像.敏感调用计数 > 10) { 得分 = 得分 + 200 }
    否则 如果 (画像.敏感调用计数 > 5) { 得分 = 得分 + 100 }

    // 3c. 连续失败(由外部调用AI安全_记录失败更新)
    如果 (画像.失败计数 > 10) { 得分 = 得分 + 400 }
    否则 如果 (画像.失败计数 > 5) { 得分 = 得分 + 200 }

    // 3d. 未知进程(低信任)
    如果 (画像.信任等级 == 0) { 得分 = 得分 + 50 }

    画像.异常得分 = 得分

    // 4. 判决
    如果 (得分 >= 800) {
        异常事件计数 = 异常事件计数 + 1
        内核警告("AI安全: PID=" + 整数转字符串(PID) + " 攻击行为(得分=" + 整数转字符串(得分) + ")")
        AI安全_更新全局威胁()
        返回 假   // 拒绝此系统调用
    }
    如果 (得分 >= 500) {
        内核警告("AI安全: PID=" + 整数转字符串(PID) + " 可疑行为(得分=" + 整数转字符串(得分) + ")")
    }
    返回 真
}

函数 AI安全_记录失败(PID) {
    定义 画像 = AI安全_查找画像(PID)
    如果 (画像 != 空) { 画像.失败计数 = 画像.失败计数 + 1 }
}

函数 AI安全_记录成功(PID) {
    定义 画像 = AI安全_查找画像(PID)
    如果 (画像 != 空) { 画像.失败计数 = 0 }   // 成功则重置失败计数
}

函数 AI安全_设置信任(PID, 等级) {
    定义 画像 = AI安全_获取或创建画像(PID)
    画像.信任等级 = 等级
}

// 辅助

函数 AI安全_是敏感调用(调用号) {
    定义 可变 i = 0
    当 (i < 计数(敏感调用)) {
        如果 (敏感调用[i] == 调用号) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 AI安全_更新全局威胁() {
    如果 (异常事件计数 > 20) { 全局威胁等级 = 2 }
    否则 如果 (异常事件计数 > 5) { 全局威胁等级 = 1 }
    否则 { 全局威胁等级 = 0 }
}

函数 AI安全_查找画像(pid) {
    定义 可变 i = 0
    当 (i < 计数(安全画像表)) {
        如果 (安全画像表[i].pid == pid) { 返回 安全画像表[i] }
        i = i + 1
    }
    返回 空
}

函数 AI安全_获取或创建画像(pid) {
    定义 已有 = AI安全_查找画像(pid)
    如果 (已有 != 空) { 返回 已有 }
    定义 新画像 = 安全画像 {}
    新画像.pid = pid
    新画像.窗口起始时间 = 读取毫秒()
    追加(安全画像表, 新画像)
    返回 新画像
}

函数 AI安全_威胁等级() { 返回 全局威胁等级 }
函数 AI安全_异常总数() { 返回 异常事件计数 }

// 威胁等级名称 + 画像清理

函数 AI安全_威胁名(等级) {
    如果 (等级 == 0) { 返回 "安全" }
    如果 (等级 == 1) { 返回 "警戒" }
    如果 (等级 == 2) { 返回 "危险" }
    返回 "未知"
}

函数 AI安全_清除画像(pid) {
    定义 可变 i = 0
    当 (i < 计数(安全画像表)) {
        如果 (安全画像表[i].pid == pid) {
            链表_删除(安全画像表, i)
            返回
        }
        i = i + 1
    }
}

// 高异常进程列举

函数 AI安全_高危进程列表(阈值) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(安全画像表)) {
        如果 (安全画像表[i].异常得分 >= 阈值) {
            追加(结果, 安全画像表[i].pid)
        }
        i = i + 1
    }
    返回 结果
}

函数 AI安全_统计() {
    返回 [计数(安全画像表), 异常事件计数, 全局威胁等级]
}


函数 AI安全_威胁级别名(级别) {
    如果 (级别 == 0) { 返回 "normal" }
    如果 (级别 == 1) { 返回 "elevated" }
    如果 (级别 == 2) { 返回 "high" }
    如果 (级别 == 3) { 返回 "critical" }
    返回 "unknown"
}

函数 AI安全_完整统计() {
    返回 [计数(安全画像表), 异常事件计数, 全局威胁等级, AI安全_威胁级别名(全局威胁等级)]
}

导入("../../标准库/基础.nova")
导入("../../编译器/规划/类型系统/枚举/枚举.nova")

// Nova 原生异常处理 — try/catch/throw+错误链+Result类型+栈展开
// 职责: 异常创建/抛出/捕获 + 错误链传播 + Result类型 + 栈展开恢复
// 层级: 第7层运行时
// 错误传播链: 自指错误上下文保持

// 错误码定义
// 与结果类型.nova对齐
定义 错误_空引用 = 3  // 对应结果类型.nova的错误_空指针
定义 错误_类型 = 12
定义 异常处理_错误_栈溢出 = 10  // 独立错误码
定义 错误_断言 = 11
// 与结果类型.nova对齐
// 与结果类型.nova对齐
定义 错误_自定义 = 100

// Result 单子: [成功?, 值/错误码, 错误消息]
函数 异常处理_结果_成功(值) { 返回 [1, 值, ""] }
函数 异常处理_结果_失败(码, 消息) { 返回 [0, 码, 消息] }
函数 异常处理_结果_是成功(r) { 返回 r[0] == 1 }
函数 结果_是失败(r) { 返回 r[0] == 0 }
函数 异常_结果_成功(值) { 返回 异常处理_结果_成功(值) }
函数 异常_结果_失败(码, 消息) { 返回 异常处理_结果_失败(码, 消息) }
函数 异常_结果_是成功(r) { 返回 异常处理_结果_是成功(r) }
函数 异常处理_结果_取值(r) { 返回 r[1] }
函数 结果_错误码(r) { 返回 r[1] }
函数 结果_消息(r) { 返回 r[2] }

// 安全操作 (返回Result)
函数 异常处理_安全除(a, b) {
    如果 (b == 0) { 返回 异常_结果_失败(错误_除零, "除以零")
}
 返回 异常_结果_成功(a / b)
}

函数 异常处理_安全索引(列表, i) {
    如果 (i < 0 或 i >= 计数(列表)) { 返回 异常_结果_失败(错误_越界, "index out of bounds")
}
 返回 异常_结果_成功(列表[i])
}

函数 安全_取非空(值) {
    如果 (值 == 空) { 返回 异常_结果_失败(错误_空引用, "空引用")
}
 返回 异常_结果_成功(值)
}

// Result 链式操作
// 如果前一个成功, 对值应用函数; 否则传播错误
// (注: 无闭包支持, 用手动模式)

// 错误传播链 (异常栈)
// 型: [帧列表] 每帧: [函数名, 错误码, 消息, 时间戳]

函数 异常栈_创建() { 返回 [] }

函数 异常栈_推(栈, 函数名, 码, 消息) {
 追加(栈, [函数名, 码, 消息, 计数(栈)])
}

函数 异常栈_深度(栈) { 返回 计数(栈) }

函数 异常栈_顶(栈) {
    如果 (计数(栈) == 0) { 返回 空
}
 返回 栈[计数(栈) - 1]
}

// 格式化栈跟踪
函数 异常栈_跟踪(栈) { 定义 可变 结果 = ""
 定义 可变 i = 计数(栈) - 1
 当 (i >= 0) { 定义 帧 = 栈[i]
 结果 = 结果 + " 在 " + 帧[0] + ": " + 帧[2]
 如果 (i > 0) { 结果 = 结果 + " | " }
 i = i - 1
 }
 返回 结果
}

// 错误描述
函数 异常处理_错误描述(码) {
    如果 (码 == 错误_除零) { 返回 "除以零"
}
 如果 (码 == 错误_越界) { 返回 "index out of bounds" }
 如果 (码 == 错误_空引用) { 返回 "空引用" }
 如果 (码 == 错误_类型) { 返回 "类型错误" }
 如果 (码 == 异常处理_错误_栈溢出) { 返回 "stack overflow" }
 如果 (码 == 错误_断言) { 返回 "assertion failed" }
 如果 (码 == 错误_溢出) { 返回 "数值溢出" }
 如果 (码 == 错误_IO) { 返回 "IO错误" }
 返回 "未知错误"
}

// 断言 (不满足条件时记入异常栈, 0)
函数 异常_断言(栈, 条件, 消息) { 如果 (条件 == 假) {
 异常栈_推(栈, "断言", 错误_断言, 消息)
 返回 假
 }
 返回 真
}

// Panic/Recover 机制 (协程隔离版)
// panic上下文栈: [[协程ID, panic状态, panic值], ...]
// 默认协程ID=0 (主线程), 支持多协程独立panic状态
// 状态表: [当前协程ID, 协程上下文栈, 嵌套panic栈, 全局panic标志, 全局panic值]
定义 可变 崩溃状态 = [0, [[0, 0, ""]], [], 0, ""]

函数 崩溃_设协程(id) { 崩溃状态[0] = id }
函数 崩溃_获取协程() { 返回 崩溃状态[0] }

函数 崩溃_查上下文(id) { 定义 可变 i = 0
 当 (i < 计数(崩溃状态[1])) { 如果 (崩溃状态[1][i][0] == id) { 返回 i }
 i = i + 1
 }
 // 不存在则创建
 插入(崩溃状态[1], 计数(崩溃状态[1]), [id, 0, ""])
 返回 计数(崩溃状态[1]) - 1
}

函数 崩溃(消息) { 定义 idx = 崩溃_查上下文(崩溃状态[0])
 崩溃状态[1][idx][1] = 1
 崩溃状态[1][idx][2] = 消息
}

函数 恢复(_扩1) { 定义 idx = 崩溃_查上下文(崩溃状态[0])
 如果 (崩溃状态[1][idx][1] == 1) {
 崩溃状态[1][idx][1] = 0
 定义 msg = 崩溃状态[1][idx][2]
 崩溃状态[1][idx][2] = ""
 返回 msg
 }
 返回 空
}

函数 是崩溃() { 定义 idx = 崩溃_查上下文(崩溃状态[0])
 返回 崩溃状态[1][idx][1] == 1
}

// 向后兼容别名
函数 恐慌(消息) { 崩溃(消息) }

// 错误链: 包装内层错误
函数 异常处理_错误_包装(外码, 外消息, 内结果) { 定义 链消息 = 外消息 + " <- " + 结果_消息(内结果)
 返回 异常_结果_失败(外码, 链消息)
}

// Result 映射: 成功时变换值
函数 异常_结果_映射值(r, 变换类型, 参数) {
    如果 (结果_是失败(r)) { 返回 r
}
 定义 v = 结果_取值(r)
 如果 (变换类型 == 1) { 返回 异常_结果_成功(v + 参数) }
 如果 (变换类型 == 2) { 返回 异常_结果_成功(v * 参数) }
 如果 (变换类型 == 3) { 返回 异常_结果_成功(v - 参数) }
 返回 r
}

// 安全: 溢出检测乘法
函数 异常处理_安全乘(a, b) {
    如果 (b == 0) { 返回 异常_结果_成功(0)
}
 定义 结果 = a * b
 如果 (结果 / b != a) { 返回 异常_结果_失败(错误_溢出, "整数溢出") }
 返回 异常_结果_成功(结果)
}

// 安全: 类型检查
函数 安全_类型(值, 期望类型) {
    如果 (期望类型 == 1 且 值 == 空) { 返回 异常_结果_失败(错误_类型, "期望非空")
}
 返回 异常_结果_成功(值)
}

// 异常栈: 按严重级别过滤
函数 异常栈_过滤(栈, 最小码) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(栈)) { 如果 (栈[i][1] >= 最小码) { 追加(结果, 栈[i]) }
 i = i + 1
 }
 返回 结果
}

// 异常栈: 清空 (重建空列表)
函数 异常栈_清空重建() { 返回 []
}

// Panic栈: 支持嵌套
// 兼容状态继续复用同一容器，避免再引入模块级标量
// [0]=当前协程ID [1]=协程上下文栈 [2]=嵌套panic栈 [3]=全局panic标志 [4]=全局panic值

函数 panic嵌套(消息) {
 追加(崩溃状态[2], 消息)
 崩溃状态[3] = 1
 崩溃状态[4] = 消息
}

函数 recover嵌套() { 如果 (计数(崩溃状态[2]) > 0) { 定义 msg = 崩溃状态[2][计数(崩溃状态[2]) - 1]
 删除(崩溃状态[2], 计数(崩溃状态[2]) - 1)
 崩溃状态[3] = 0
 崩溃状态[4] = ""
 返回 msg
 }
 返回 空
}

函数 panic嵌套深度() { 返回 计数(崩溃状态[2]) }

// VM↔语言级异常统一桥接
// 解决双模型分裂: VM层TRY/CATCH/THROW vs 语言层Result/恐慌/恢复
// 桥接契约:
//   1. VM THROW 触发时,同步更新语言层panic状态
//   2. 语言层panic()触发时,若在VM执行中,标记VM异常状态
//   3. Result失败可选择升级为throw(不可恢复)或保持Result链(可恢复)

// VM异常→语言层: THROW回调桩(由VM_处理_THROW调用)
定义 可变 __异常桥_VM异常值 = 空
定义 可变 __异常桥_VM异常栈 = 空

函数 异常桥_VM抛出回调(异常值) {
    __异常桥_VM异常值 = 异常值
    // 同步到语言层panic状态,使recover()能捕获VM异常
    崩溃(转字符串(异常值))
}

函数 异常桥_VM异常转Result() {
    如果 (__异常桥_VM异常值 != 空) {
        定义 值 = __异常桥_VM异常值
        __异常桥_VM异常值 = 空
        返回 异常_结果_失败(错误_自定义, 转字符串(值))
    }
    返回 空
}

// 语言层panic→VM: 设置VM异常状态(供策略引擎检测)
函数 异常桥_语言panic到VM(vm, 消息) {
    如果 (vm != 空 且 计数(vm) > 5) {
        vm[5] = 3  // VM_状态_异常
    }
    崩溃(消息)
}

// Result升级为throw: 不可恢复错误时使用
函数 异常桥_Result升级throw(r) {
    如果 (结果_是失败(r)) {
        崩溃("不可恢复: " + 结果_消息(r))
        返回 真
    }
    返回 假
}

// 安全执行: 包装函数调用,捕获panic转为Result
函数 异常桥_安全调用(函数引用, 参数) {
    定义 旧状态 = 崩溃状态[3]
    崩溃状态[3] = 0
    定义 结果值 = 函数引用(参数)
    如果 (崩溃状态[3] == 1) {
        定义 msg = 恢复(0)
        返回 异常_结果_失败(错误_自定义, msg)
    }
    崩溃状态[3] = 旧状态
    返回 异常_结果_成功(结果值)
}

// 异常传播一致性查询: 报告当前异常状态(用于调试/测试)
函数 异常桥_状态报告() {
    返回 [崩溃状态[3], __异常桥_VM异常值 != 空, panic嵌套深度()]
}

函数 帮助_架构() {
    打印("================================================================================")
    打印("                       编译器架构与x86-64指令集")
    打印("================================================================================")
    打印("")
    打印("■ 编译流水线:")
    打印("  源代码(.nova) -> 词法分析 -> 语法分析(AST) -> 语义分析 -> x86-64代码生成 -> PE链接")
    打印("")
    打印("  1. 词法分析: Unicode感知,支持中文标识符,21个关键字")
    打印("  2. 语法分析: 递归下降解析器,生成AST(抽象语法树)")
    打印("  3. 语义分析: 变量解析,闭包检测,类型推断")
    打印("  4. 代码生成: 直接生成x86-64机器码(无中间表示)")
    打印("  5. PE链接:   生成Windows PE可执行文件(含IAT/重定位)")
    打印("")
    打印("■ 目标架构:")
    打印("  ISA:        x86-64 (AMD64)")
    打印("  OS:         Windows (PE32+ 格式)")
    打印("  ABI:        Windows x64调用约定 (rcx,rdx,r8,r9,栈)")
    打印("  字长:       64位")
    打印("  浮点:       SSE2 (xmm0-xmm15)")
    打印("  对齐:       16字节栈对齐")
    打印("")
    打印("■ 使用的x86-64指令集:")
    打印("  数据移动:   mov, lea, push, pop, movzx, movsx")
    打印("  算术:       add, sub, imul, idiv, neg, inc, dec, cqo")
    打印("  逻辑:       and, or, xor, not, shl, shr, sar")
    打印("  比较:       cmp, test, sete, setne, setl, setg, setle, setge")
    打印("  跳转:       jmp, je, jne, jl, jg, jle, jge, call, ret")
    打印("  浮点SSE2:   movsd, addsd, subsd, mulsd, divsd, cvtsi2sd, cvttsd2si")
    打印("  浮点比较:   ucomisd, comisd")
    打印("  系统:       syscall(通过IAT间接调用)")
    打印("")
    打印("■ 寄存器使用:")
    打印("  rax         返回值/暂存计算")
    打印("  rcx         第1参数")
    打印("  rdx         第2参数/除法高位")
    打印("  r8          第3参数")
    打印("  r9          第4参数")
    打印("  rsp         栈指针")
    打印("  rbp         帧指针(未使用,用rsp寻址)")
    打印("  r10-r15     暂存寄存器")
    打印("  xmm0-xmm3   浮点参数/返回值")
    打印("")
    打印("■ 内存模型:")
    打印("  局部变量:   栈分配 [rsp+偏移]")
    打印("  全局变量:   堆分配数组,通过全局指针+索引访问")
    打印("  字符串:     编译期嵌入代码段尾部,运行时rip相对寻址")
    打印("  列表:       运行时堆分配,引用计数管理")
    打印("  字典:       运行时堆分配,线性探测哈希表")
    打印("  闭包变量:   全局槽位分配,编译期捕获")
    打印("")
    打印("■ PE文件结构:")
    打印("  DOS头 + PE签名 + COFF头 + Optional头")
    打印("  .text段: 机器码+字符串数据")
    打印("  .rdata段: 导入目录+IAT")
    打印("  导入DLL: kernel32.dll (GetStdHandle/WriteConsoleA/CreateFileA/...)")
    打印("            msvcrt.dll  (malloc/free/memcpy/...)")
    打印("")
    打印("■ 运行时特性:")
    打印("  堆分配器:   1GB VirtualAlloc堆,bump分配器,按需分页")
    打印("  字符串:     不可变,拼接产生新串,UTF-8编码")
    打印("  列表:       动态数组,自动扩容(初始容量n+8)")
    打印("  字典:       键值对,自适应增长(初始256,满时2x,无上限),线性搜索")
    打印("  异常:       setjmp/longjmp实现尝试/得")
    打印("  闭包:       编译期AST分析,全局槽位存储捕获变量")
    打印("")
    打印("■ 编译器容量:")
    打印("  函数表:     自适应增长(无硬性上限)")
    打印("  全局变量:   无硬性上限(堆分配)")
    打印("  字符串常量: 无硬性上限(动态数组)")
    打印("  闭包:       动态检测(编译期AST分析)")
    打印("  代码缓冲:   64MB(充足容量)")
    打印("  运行时堆:   1GB(VirtualAlloc按需分页)")
}

函数 帮助_示例() {
    打印("================================================================================")
    打印("                            代码示例")
    打印("================================================================================")
    打印("")
    打印("■ Hello World:")
    打印("  打印('你好世界!')")
    打印("")
    打印("■ 变量与运算:")
    打印("  定义 x = 42")
    打印("  定义 可变 y = 0")
    打印("  y = x * 2 + 1")
    打印("  打印文本(字符串拼接('结果: ', 转字符串(y)))")
    打印("")
    打印("■ 法:")
    打印("  函数 阶乘(n) <")
    打印("      如果 (n <= 1) < 返回 1 >")
    打印("      返回 n * 阶乘(n - 1)")
    打印("  >")
    打印("  打印文本(字符串拼接('10! = ', 转字符串(阶乘(10))))")
    打印("")
    打印("■ 列表操作:")
    打印("  定义 可变 数据 = [3, 1, 4, 1, 5, 9]")
    打印("  追加(数据, 2)")
    打印("  定义 可变 i = 0")
    打印("  当 (i < 计数(数据)) <")
    打印("      打印文本(转字符串(数据[i]))")
    打印("      i = i + 1")
    打印("  >")
    打印("")
    打印("■ 结构体:")
    打印("  结构 向量3D < x, y, z >")
    打印("  函数 向量_加(a, b) <")
    打印("      返回 建 向量3D(a.x + b.x, a.y + b.y, a.z + b.z)")
    打印("  >")
    打印("  定义 v1 = 建 向量3D(1, 2, 3)")
    打印("  定义 v2 = 建 向量3D(4, 5, 6)")
    打印("  定义 v3 = 向量_加(v1, v2)")
    打印("")
    打印("■ 闭包:")
    打印("  函数 创建计数器() <")
    打印("      定义 可变 n = 0")
    打印("      返回 法() <")
    打印("          n = n + 1")
    打印("          返回 n")
    打印("      >")
    打印("  >")
    打印("")
    打印("■ 异常处理:")
    打印("  试 <")
    打印("      定义 结果 = 某函数()")
    打印("  > 得 错误 <")
    打印("      打印文本(字符串拼接('捕获异常: ', 转字符串(错误)))")
    打印("  >")
    打印("")
    打印("■ 模块化项目:")
    打印("  // 文件: 数学工具.nova")
    打印("  函数 平方(x) < 返回 x * x >")
    打印("  函数 立方(x) < 返回 x * x * x >")
    打印("")
    打印("  // 文件: 主程序.nova")
    打印("  导入('数学工具.nova')")
    打印("  打印文本(转字符串(平方(5)))    // 输出: 25")
    打印("")
    打印("■ BMP图像生成:")
    打印("  定义 宽 = 256")
    打印("  定义 高 = 256")
    打印("  bmp_写灰度('output.bmp', 像素数据, 宽, 高)")
    打印("  bmp_写RGB('color.bmp', RGB数据, 宽, 高)")
    打印("")
    打印("■ 神经网络(标准库):")
    打印("  定义 可变 权重 = 矩阵_随机(784,  128, 0 , 0, 0)")
    打印("  定义 可变 输出 = 全连接_前向(输入, 权重)")
    打印("  输出 = ReLU(输出)")
    打印("  定义 损失 = 交叉熵(输出, 标签)")
}

函数 帮助_AI() {
    打印("================================================================================")
    打印("                    AI精准开发参考 (机器可读规范)")
    打印("================================================================================")
    打印("")
    打印("■ 编译命令:")
    打印("  nova <源文件.nova>            -> 生成 <源文件>")
    打印("  输出文件名 = 输入文件名去掉.nova后缀")
    打印("  退出码: 0=成功, 非0=失败")
    打印("")
    打印("■ 导入路径解析规则:")
    打印("  导入('相对路径.nova')            相对于当前编译的.nova文件所在目录")
    打印("  导入('标准库/模块.nova')         相对路径,从编译器所在目录查找")
    打印("  导入('../../目录/文件.nova')     支持父目录引用")
    打印("  导入只提取: 函数定义 + 结构体定义 + 顶层语句")
    打印("  导入不递归: 被导入文件内的导入语句会被跳过")
    打印("  用 '路径.nova'                与导入相同,另一种语法")
    打印("")
    打印("■ 语法精确规则 (AI必读):")
    打印("  块定界符: { } (花括号)")
    打印("  语句无分号: 每行一条语句,无需分号结尾")
    打印("  字符串: 单引号或双引号均可: '你好' 或 \"你好\"")
    打印("  注释: // 单行注释")
    打印("  变量声明: 定义 x = 值  或  定义 可变 x = 值")
    打印("  不可变变量: 定义 x = 10 (之后不能 x = 20)")
    打印("  可变变量: 定义 可变 x = 0 (之后可以 x = 20)")
    打印("  函数定义: 函数 名称(参数列表) { 函数体 }")
    打印("  箭头函数: 参数 => 表达式  (自动生成匿名函数)")
    打印("  条件: 如果 (条件) { } 否则 如果 (条件) { } 否则 { }")
    打印("  永: 当 (条件) { }  或  每 变量 在 列表 { }")
    打印("  辨: 辨 值 { 模式1 { } 模式2 { } 否则 { } }")
    打印("")
    打印("■ 类型系统:")
    打印("  动态类型,运行时检查,值以64位表示")
    打印("  整数: 64位有符号 (-2^63 ~ 2^63-1)")
    打印("  浮点: 64位IEEE754双精度")
    打印("  字符串: 不可变UTF-8,堆分配")
    打印("  列表: 动态数组,元素为任意类型,自动扩容")
    打印("  字典: 字符串键→任意值,自适应增长(256→512→1024→...无上限)")
    打印("  结构体: 编译期定义字段,运行时作为列表存储")
    打印("  空: 空值(null),函数无返回值时返回空")
    打印("  布尔: 真=1, 假=0 (整数语义)")
    打印("")
    打印("■ 函数调用约定:")
    打印("  最多支持6个参数: rcx, rdx, r8, r9, [rsp+0x20], [rsp+0x28]")
    打印("  返回值在rax")
    打印("  可变参数: 不支持")
    打印("  递归: 支持")
    打印("  闭包: 支持(编译期捕获外层变量到全局槽位)")
    打印("")
    打印("■ 常见模式 (AI直接复用):")
    打印("  // 字符串拼接多段")
    打印("  定义 结果 = 字符串拼接(字符串拼接(a, b), c), c)")
    打印("  // 列表遍历")
    打印("  定义 可变 i = 0")
    打印("  当 (i < 计数(列表)) { 处理(列表[i])  i = i + 1 }")
    打印("  // 字典使用")
    打印("  定义 可变 表 = 字典()")
    打印("  字典设(表, '键', 值)")
    打印("  定义 v = 字典取(表, '键')")
    打印("  // 错误处理")
    打印("  试 { 危险代码() } 得 错误 { 打印文本(转字符串(错误)) }")
    打印("  // 文件读写")
    打印("  定义 内容 = 读文件('路径.txt')")
    打印("  如果 (内容 != 空) { 处理(内容) }")
    打印("  写文件('输出.txt',  数据字符串, 0)")
    打印("")
    打印("■ 已知限制 (AI必须避免):")
    打印("  1. 不支持字典字面量 {key:val} 语法,必须用 字典()+字典设(0, 0 , 0)")
    打印("  2. 不支持可变参数函数")
    打印("  3. 不支持多返回值(用列表包装)")
    打印("  4. 字符串不可变,修改必须创建新串")
    打印("  5. 浮点数不支持全部数学函数(用标准库整数模拟)")
    打印("  6. 主要支持Linux/Windows x86-64目标平台")
    打印("  7. 中文关键字不能用作标识符名称")
    打印("  8. 导入不递归(被导入文件内的导入被跳过)")
    打印("  9. 每个源文件最大4MB(文件读取缓冲区)")
    打印("")
    打印("■ 自举验证命令:")
    打印("  nova 自举入口.nova           生成 stage2 (Stage2)")
    打印("  ./nova 自举入口.nova     生成 stage3 (Stage3)")
    打印("  比较 stage2 stage3  SHA256必须一致")
    打印("")
    打印("■ 编译器版本历史:")
    打印("  v1.0.0  自举成功,基础语法,72个函数")
    打印("  v2.0.0  UTF-8打印,常量折叠,文件缓冲4MB")
    打印("  v3.0.0  自适应字典(无上限),64MB代码缓冲,1GB堆,213模块集成")
    打印("  v3.1.0  安全加固: 插入位置/间接调用/除零保护/越界保护/删除")
}


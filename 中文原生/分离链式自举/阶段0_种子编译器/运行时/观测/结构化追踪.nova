// Nova · 运行时 · 观测 · 结构化追踪 (5.7)
// 非文本打印的结构化trace: CPU/线程/模块/函数/行号/中断/热更/内存/调度

// 追踪事件类型

导入("../../标准库/基础.nova")

定义 追踪_函数入 = 1
定义 追踪_函数出 = 2
定义 追踪_系统调用 = 3
定义 追踪_中断 = 4
定义 追踪_异常 = 5
定义 追踪_热更新 = 6
定义 追踪_内存分配 = 7
定义 追踪_内存释放 = 8
定义 追踪_调度切换 = 9
定义 追踪_设备事件 = 10
定义 追踪_模态切换 = 11

// 追踪条目: [时间戳, 类型, CPU/线程, 模块, 函数, 行号, 数据]
定义 可变 _追踪_缓冲 = []
定义 可变 _追踪_最大容量 = 4096
定义 可变 _追踪_启用 = 真
定义 可变 _追踪_总计数 = 0
定义 可变 _追踪_丢弃数 = 0

函数 追踪_设置容量(容量) { _追踪_最大容量 = 容量 }
函数 追踪_启用() { _追踪_启用 = 真 }
函数 追踪_禁用() { _追踪_启用 = 假 }

函数 追踪_记录(类型, CPU线程, 模块, 函数名, 行号, 数据) {
    如果 (_追踪_启用 == 假) { 返回 空 }
    _追踪_总计数 = _追踪_总计数 + 1
    如果 (计数(_追踪_缓冲) >= _追踪_最大容量) {
        // 环形缓冲: 丢弃最早的条目
        _追踪_缓冲[0] = _追踪_缓冲[计数(_追踪_缓冲) - 1]
        _追踪_丢弃数 = _追踪_丢弃数 + 1
        返回 空
    }
    追加(_追踪_缓冲, [时间(), 类型, CPU线程, 模块, 函数名, 行号, 数据])
}

函数 追踪_函数进入(模块, 函数名) {
    追踪_记录(追踪_函数入, 0, 模块, 函数名, 0, 空)
}

函数 追踪_函数退出(模块, 函数名) {
    追踪_记录(追踪_函数出, 0, 模块, 函数名, 0, 空)
}

函数 追踪_系统调用事件(调用号, 参数) {
    追踪_记录(追踪_系统调用, 0, "内核", "syscall", 0, [调用号, 参数])
}

函数 追踪_中断事件(向量号, 来源) {
    追踪_记录(追踪_中断, 0, "内核", "中断", 0, [向量号, 来源])
}

函数 追踪_异常事件(异常类型, 错误码, 地址) {
    追踪_记录(追踪_异常, 0, "内核", "异常", 0, [异常类型, 错误码, 地址])
}

函数 追踪_热更新事件(模块名, 版本, 成功) {
    追踪_记录(追踪_热更新, 0, 模块名, "热更新", 0, [版本, 成功])
}

函数 追踪_内存事件(操作, 地址, 大小) {
    // 操作: 0=分配 1=释放
    追踪_记录(如果操作(操作, 追踪_内存分配, 追踪_内存释放), 0, "运行时", "内存", 0, [地址, 大小])
}

函数 如果操作(op, a, b) {
    如果 (op == 0) { 返回 a }
    返回 b
}

函数 追踪_调度事件(旧任务, 新任务) {
    追踪_记录(追踪_调度切换, 0, "调度器", "切换", 0, [旧任务, 新任务])
}

// 追踪查询
函数 追踪_最近N条(n) {
    定义 总数 = 计数(_追踪_缓冲)
    如果 (n >= 总数) { 返回 _追踪_缓冲 }
    定义 可变 结果 = []
    定义 可变 i = 总数 - n
    当 (i < 总数) {
        追加(结果, _追踪_缓冲[i])
        i = i + 1
    }
    返回 结果
}

函数 追踪_按类型过滤(类型) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(_追踪_缓冲)) {
        如果 (_追踪_缓冲[i][1] == 类型) {
            追加(结果, _追踪_缓冲[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 追踪_按模块过滤(模块名) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(_追踪_缓冲)) {
        如果 (_追踪_缓冲[i][3] == 模块名) {
            追加(结果, _追踪_缓冲[i])
        }
        i = i + 1
    }
    返回 结果
}

// 追踪统计报告
函数 追踪_打印报告() {
    打印文本("═══ 结构化追踪报告 ═══")
    打印文本(字符串拼接("  总记录: ", 转字符串(_追踪_总计数)))
    打印文本(字符串拼接("  缓冲条目: ", 转字符串(计数(_追踪_缓冲))))
    打印文本(字符串拼接("  丢弃数: ", 转字符串(_追踪_丢弃数)))
    // 按类型统计
    定义 可变 类型统计 = [0, 0, 0, 0, 0, 0, 0]
    定义 可变 i = 0
    当 (i < 计数(_追踪_缓冲)) {
        定义 t = _追踪_缓冲[i][1]
        如果 (t >= 1 且 t <= 11) { 类型统计[t] = 类型统计[t] + 1 }
        i = i + 1
    }
}

函数 追踪_清空() {
    _追踪_缓冲 = []
    _追踪_总计数 = 0
    _追踪_丢弃数 = 0
}

// §9 CSS Subgrid — 子网格
// grid-template-columns: subgrid
// grid-template-rows: subgrid [line-name1] [line-name2]

结构 SubgridInfo {
    是子网格_列,
    是子网格_行,
    // 继承的轨道(从父grid)
    继承轨道_列,    // u64 轨道尺寸数组
    继承轨道_行,
    继承数量_列,
    继承数量_行,
    // 子网格线名
    线名_列,    // u64 字符串数组
    线名_行,
    线名数_列,
    线名数_行,
}


函数 Subgrid_检测(样式) {
    如果 (样式 == 0) { 返回 0 }
    定义 col = 样式.grid_template_columns
    定义 row = 样式.grid_template_rows

    定义 可变 是子网格 = 假
    如果 (col != 0 && 字符串_开头匹配(col, "subgrid")) { 是子网格 = 真 }
    如果 (row != 0 && 字符串_开头匹配(row, "subgrid")) { 是子网格 = 真 }

    如果 (!是子网格) { 返回 0 }

    定义 info = 堆_分配(SubgridInfo)
    info.是子网格_列 = (col != 0 && 字符串_开头匹配(col, "subgrid"))
    info.是子网格_行 = (row != 0 && 字符串_开头匹配(row, "subgrid"))
    info.继承轨道_列 = 0; info.继承轨道_行 = 0
    info.继承数量_列 = 0; info.继承数量_行 = 0
    info.线名_列 = 0; info.线名_行 = 0
    info.线名数_列 = 0; info.线名数_行 = 0
    返回 info
}

函数 Subgrid_继承父轨道(info, 父grid, 子grid区域开始_列, 子grid区域结束_列, 子grid区域开始_行, 子grid区域结束_行) {
    如果 (info == 0 || 父grid == 0) { 返回 }

    // 从父grid继承对应范围的轨道尺寸
    如果 (info.是子网格_列) {
        info.继承数量_列 = 子grid区域结束_列 - 子grid区域开始_列
        info.继承轨道_列 = 堆_分配_数组(info.继承数量_列 * 4)
        定义 可变 i = 0
        当 (i < info.继承数量_列) {
            定义 父轨道idx = 子grid区域开始_列 + i
            内存_写32(info.继承轨道_列 + i * 4, 网格_获取轨道尺寸(父grid, 0, 父轨道idx))
            i = i + 1
        }
    }
    如果 (info.是子网格_行) {
        info.继承数量_行 = 子grid区域结束_行 - 子grid区域开始_行
        info.继承轨道_行 = 堆_分配_数组(info.继承数量_行 * 4)
        定义 可变 i = 0
        当 (i < info.继承数量_行) {
            定义 父轨道idx = 子grid区域开始_行 + i
            内存_写32(info.继承轨道_行 + i * 4, 网格_获取轨道尺寸(父grid, 1, 父轨道idx))
            i = i + 1
        }
    }
}

// 辅助存根
函数 CSS_解析浮点_x10000(str, pos) {
    // 解析浮点数字符串, 返回 ×10000的定点整数
    如果 (str == 0) { 返回 0 }
    定义 可变 i = pos
    定义 可变 负 = 假
    如果 (字节取(str, i) == 0x2D) { 负 = 真; i = i + 1 }
    定义 可变 整数部 = 0
    当 (i < 字节长度(str) && 字节取(str, i) >= 0x30 && 字节取(str, i) <= 0x39) {
        整数部 = 整数部 * 10 + (字节取(str, i) - 0x30)
        i = i + 1
    }
    定义 可变 小数部 = 0
    定义 可变 分母 = 1
    如果 (i < 字节长度(str) && 字节取(str, i) == 0x2E) {
        i = i + 1
        当 (i < 字节长度(str) && 字节取(str, i) >= 0x30 && 字节取(str, i) <= 0x39) {
            小数部 = 小数部 * 10 + (字节取(str, i) - 0x30)
            分母 = 分母 * 10
            i = i + 1
        }
    }
    定义 result = 整数部 * 10000 + 小数部 * 10000 / 分母
    如果 (负) { result = 0 - result }
    返回 result
}
函数 整数_立方根(v) { 返回 v }
函数 整数_sqrt(v) { 返回 v }
函数 整数_atan2(y, x) {
    // CORDIC atan2近似, 返回度数×100
    如果 (x == 0 && y == 0) { 返回 0 }
    如果 (x == 0) { 返回 y > 0 ? 9000 : 27000 }
    如果 (y == 0) { 返回 x > 0 ? 0 : 18000 }
    // CORDIC查表近似
    定义 可变 ax = x; 如果 (ax < 0) { ax = 0 - ax }
    定义 可变 ay = y; 如果 (ay < 0) { ay = 0 - ay }
    定义 可变 角 = 0
    如果 (ax >= ay) {
        角 = ay * 4500 / ax  // 0-45°近似
    } 否则 {
        角 = 9000 - ax * 4500 / ay  // 45-90°
    }
    // 调整象限
    如果 (x < 0 && y >= 0) { 角 = 18000 - 角 }
    否则 如果 (x < 0 && y < 0) { 角 = 18000 + 角 }
    否则 如果 (x >= 0 && y < 0) { 角 = 36000 - 角 }
    返回 角
}
函数 整数_cos(度) { 返回 10000 }
函数 整数_sin(度) {
    // sin(度)×10000, 输入度数×100
    // 归一化到0-36000
    定义 可变 d = 度 % 36000
    如果 (d < 0) { d = d + 36000 }
    // 第三/四象限取反
    定义 可变 负 = 假
    如果 (d >= 18000) { d = d - 18000; 负 = 真 }
    // 第二象限镜像
    如果 (d > 9000) { d = 18000 - d }
    // Taylor近似: sin(x) ≈ x - x³/6 + x⁵/120 (x=弧度×10000)
    定义 rad = d * 175 / 1000  // 度→弧度×10000 (π/18000*10000)
    定义 x2 = rad * rad / 10000
    定义 x3 = x2 * rad / 10000
    定义 x5 = x3 * x2 / 10000
    定义 result = rad - x3 / 6 + x5 / 120
    如果 (负) { result = 0 - result }
    返回 result
}
函数 CSSColor_从hex(str) { 返回 CSSColor_默认() }
函数 CSSColor_从rgb(str) { 返回 CSSColor_默认() }
函数 CSSColor_从hsl(str) { 返回 CSSColor_默认() }
函数 CSSColor_从名称(str) { 返回 CSSColor_默认() }
// 字符串_替换 已统一定义在 中枢/字符串替换.nova
函数 网格_获取轨道尺寸(grid, 轴, idx) {
    如果 (grid == 0) { 返回 0 }
    如果 (轴 == 0) {  // 列轨道
        如果 (idx < grid.列轨道数) { 返回 grid.列轨道[idx].实际尺寸 }
    } 否则 {      // 行轨道
        如果 (idx < grid.行轨道数) { 返回 grid.行轨道[idx].实际尺寸 }
    }
    返回 0
}

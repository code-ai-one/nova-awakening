// 中枢脑区 · 统一对外接口 — 内核基础设施的唯一出口
// 低耦合: 其他脑区只通过本接口访问中枢能力
// 高内聚: 中枢内部实现细节完全封装

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./同步原语.nova")
导入("./内存回收.nova")
导入("./系统调用表.nova")
导入("./中断表注册处.nova")
导入("./主循环.nova")
导入("./智能系统调用.nova")
导入("./日志中枢.nova")

函数 中枢_申请内存(大小) {
    返回 堆_分配(大小)
}

函数 中枢_释放内存(指针) {
    堆_释放(指针)
}

函数 中枢_申请页(页数) {
    返回 物理页_分配(页数)
}

函数 中枢_创建锁() {
    返回 自旋锁_创建()
}

函数 中枢_加锁(锁) {
    自旋锁_获取(锁)
}

函数 中枢_解锁(锁) {
    自旋锁_释放(锁)
}

函数 中枢_创建信号量(初始值) {
    返回 信号量_创建(初始值)
}

函数 中枢_注册中断(中断号, 处理函数) {
    返回 中断_注册处理器(中断号, 处理函数)
}

函数 中枢_禁止中断() {
    汇编 { "cli" }
}

函数 中枢_允许中断() {
    汇编 { "sti" }
}

函数 中枢_系统调用(调用号, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6) {
    返回 系统调用_分发_表(调用号, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6)
}

函数 中枢_日志(级别, 消息) {
    日志_写入(级别, "中枢", 消息)
}

函数 中枢_日志信息(消息) {
    中枢_日志(日志级别_信息, 消息)
}

函数 中枢_日志警告(消息) {
    中枢_日志(日志级别_警告, 消息)
}

函数 中枢_日志错误(消息) {
    中枢_日志(日志级别_错误, 消息)
}

函数 中枢_当前时间纳秒() {
    返回 时钟_读取纳秒()
}

函数 中枢_定时回调(延迟纳秒, 回调) {
    返回 定时器_创建(延迟纳秒, 回调)
}

函数 中枢_当前进程() {
    返回 获取当前进程()
}

函数 中枢_让出() {
    调度_让出()
}

函数 内存_初始化() {
    内存区域_初始化()
    内存位图_初始化()
    返回 0
}

函数 驱动_全局初始化() {
    驱动统计_初始化()
    驱动匹配统计_初始化()
    驱动框架_初始化()
    返回 0
}

定义 可变 中枢_调用计数 = 0
定义 可变 中枢_异常计数 = 0
定义 可变 中枢_最近总线消息 = 空

函数 中枢_安全入口(调用者脑区, 操作码) {
    中枢_调用计数 = 中枢_调用计数 + 1
    如果 (调用者脑区 < 0 || 调用者脑区 > 8) {
        中枢_异常计数 = 中枢_异常计数 + 1
        中枢_日志错误("非法脑区编号: " + 调用者脑区)
        返回 -1
    }
    返回 0
}

函数 中枢_处理总线消息(调用者脑区, 操作码, 数据) {
    中枢_最近总线消息 = {
        调用者: 调用者脑区,
        操作码: 操作码,
        数据: 数据
    }
    返回 0
}


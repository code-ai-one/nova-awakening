// §7 辅助函数

函数 查找模块(名称) {
    定义 可变 i = 0
    当 (i < 计数(已加载模块)) {
        如果 (已加载模块[i].模块名 == 名称) { 返回 已加载模块[i] }
        i = i + 1
    }
    返回 空
}

// 由编译器/链接器在ELF .symtab 中生成
// 启动时解析ELF符号表加载到内存
定义 可变 内核符号表 = []     // [[名称, 地址, 大小]]
定义 可变 符号表_已加载 = 假

函数 符号表_初始化(elf_symtab_地址, 符号数, strtab_地址) {
    // 解析ELF .symtab段，构建内核符号表
    定义 可变 i = 0
    当 (i < 符号数) {
        // 每个Elf64_Sym = 24字节: [st_name(4), st_info(1), st_other(1), st_shndx(2), st_value(8), st_size(8)]
        定义 条目地址 = elf_symtab_地址 + i * 24
        定义 名称偏移 = 内存读32(条目地址)
        定义 信息 = 内存读8(条目地址 + 4)
        定义 类型 = 信息 & 0xF
        定义 值 = 内存读64(条目地址 + 8)
        定义 大小 = 内存读64(条目地址 + 16)
        // 只记录函数符号(STT_FUNC=2)和对象符号(STT_OBJECT=1)
        如果 ((类型 == 2 || 类型 == 1) && 值 != 0) {
            定义 名称 = 读取C字符串(strtab_地址 + 名称偏移)
            追加(内核符号表, [名称, 值, 大小])
        }
        i = i + 1
    }
    符号表_已加载 = 真
    内核信息("符号表: 加载 " + 整数转字符串(计数(内核符号表)) + " 个符号")
}

函数 符号表_注册(名称, 地址, 大小) {
    // 运行时动态注册符号(模块加载时)
    追加(内核符号表, [名称, 地址, 大小])
}

函数 符号表_查找(函数名) {
    定义 可变 i = 0
    当 (i < 计数(内核符号表)) {
        如果 (内核符号表[i][0] == 函数名) {
            返回 内核符号表[i][1]  // 返回地址
        }
        i = i + 1
    }
    // 未找到: 尝试模块符号表
    定义 可变 j = 0
    当 (j < 计数(已加载模块)) {
        定义 模块 = 已加载模块[j]
        如果 (模块.补丁列表 != 空) {
            定义 可变 k = 0
            当 (k < 计数(模块.补丁列表)) {
                如果 (模块.补丁列表[k].目标函数名 == 函数名) {
                    返回 模块.补丁列表[k].旧函数地址
                }
                k = k + 1
            }
        }
        j = j + 1
    }
    返回 0
}

函数 符号表_查找大小(函数名) {
    定义 可变 i = 0
    当 (i < 计数(内核符号表)) {
        如果 (内核符号表[i][0] == 函数名) { 返回 内核符号表[i][2] }
        i = i + 1
    }
    返回 0
}

函数 禁用写保护() {
    // 清除CR0.WP位, 允许写只读页(代码段)
    汇编 { "mov rax, cr0"; "and rax, ~(1<<16)"; "mov cr0, rax" }
}

函数 启用写保护() {
    汇编 { "mov rax, cr0"; "or rax, (1<<16)"; "mov cr0, rax" }
}

函数 刷新指令缓存(地址, 大小) {
    // x86指令缓存由硬件维护一致性
    // 但需要确保流水线刷新
    汇编 { "mfence"; "lfence" }
}

函数 分配可执行内存(大小) {
    // 从vmalloc区域分配可执行内存
    返回 alloc_pages(0, GFP_KERNEL)
}

函数 释放可执行内存(地址, 大小) {
    // 释放vmalloc区域的可执行页
    如果 (地址 != 0) {
        free_pages(地址, 0)
    }
}

函数 模块_重定位(模块地址, 代码大小) {
    // ELF模块重定位: 修正绝对/相对地址引用
        如果 (模块地址 == 0 || 代码大小 == 0) { 返回 错误_无效参数 }

    // 在模块ELF头中查找.rela段
    定义 ehdr = 模块地址
    定义 shoff = 内存读64(ehdr + 40)      // e_shoff
    定义 shentsize = 内存读16(ehdr + 58)  // e_shentsize
    定义 shnum = 内存读16(ehdr + 60)      // e_shnum

    定义 可变 s = 0
    当 (s < shnum) {
        定义 sh_addr = ehdr + shoff + s * shentsize
        定义 sh_type = 内存读32(sh_addr + 4)   // SHT_RELA = 4
        如果 (sh_type == 4) {
            // 找到.rela段, 处理每个重定位条目
            定义 rela_offset = 内存读64(sh_addr + 24)  // sh_offset
            定义 rela_size = 内存读64(sh_addr + 32)    // sh_size
            定义 rela_entsize = 内存读64(sh_addr + 56) // sh_entsize
            如果 (rela_entsize == 0) { rela_entsize = 24 }  // Elf64_Rela = 24字节

            定义 条目数 = rela_size / rela_entsize
            定义 可变 r = 0
            当 (r < 条目数) {
                定义 rela = ehdr + rela_offset + r * rela_entsize
                定义 r_offset = 内存读64(rela)       // 需要修正的位置
                定义 r_info = 内存读64(rela + 8)     // 类型+符号索引
                定义 r_addend = 内存读64(rela + 16)  // 加数
                定义 r_type = r_info & 0xFFFFFFFF
                定义 r_sym = r_info >> 32

                // 获取符号值
                定义 sym_val = 模块_解析符号(ehdr, r_sym)
                定义 修正位置 = 模块地址 + r_offset

                如果 (r_type == 1) {
                    // R_X86_64_64: 绝对64位地址
                    内存写64(修正位置, sym_val + r_addend)
                } 否则如果 (r_type == 2) {
                    // R_X86_64_PC32: 相对32位偏移
                    定义 值 = sym_val + r_addend - 修正位置
                    内存写32(修正位置, 值 & 0xFFFFFFFF)
                } 否则如果 (r_type == 10) {
                    // R_X86_64_32: 绝对32位地址
                    内存写32(修正位置, (sym_val + r_addend) & 0xFFFFFFFF)
                } 否则如果 (r_type == 11) {
                    // R_X86_64_32S: 有符号32位地址
                    内存写32(修正位置, (sym_val + r_addend) & 0xFFFFFFFF)
                }
                r = r + 1
            }
        }
        s = s + 1
    }

    内核信息("热更新: 模块重定位完成 @ " + 整数转十六进制(模块地址))
    返回 成功
}

函数 模块_解析符号(ehdr, 符号索引) {
    // 查找ELF符号表中的符号值
    // 先查模块内部符号, 再查内核全局符号表
    定义 shoff = 内存读64(ehdr + 40)
    定义 shentsize = 内存读16(ehdr + 58)
    定义 shnum = 内存读16(ehdr + 60)

    // 找.symtab段
    定义 可变 s = 0
    当 (s < shnum) {
        定义 sh_addr = ehdr + shoff + s * shentsize
        定义 sh_type = 内存读32(sh_addr + 4)  // SHT_SYMTAB = 2
        如果 (sh_type == 2) {
            定义 symtab_off = 内存读64(sh_addr + 24)
            定义 strtab_idx = 内存读32(sh_addr + 40)  // sh_link → .strtab段索引
            // 读取符号
            定义 sym = ehdr + symtab_off + 符号索引 * 24
            定义 st_value = 内存读64(sym + 8)
            如果 (st_value != 0) { 返回 st_value }  // 模块内部符号

            // 外部符号: 通过名称在内核符号表查找
            定义 st_name = 内存读32(sym)
            定义 strtab_sh = ehdr + shoff + strtab_idx * shentsize
            定义 strtab_off = 内存读64(strtab_sh + 24)
            定义 名称 = 读取C字符串(ehdr + strtab_off + st_name)
            返回 符号表_查找(名称)
        }
        s = s + 1
    }
    返回 0
}

函数 模块_更新符号表(模块, 新地址) {
    // 更新全局符号表中的模块符号地址
        定义 可变 i = 0
    当 (i < 计数(已加载模块)) {
        如果 (已加载模块[i][0] == 模块) {
            设置(已加载模块[i], 1, 新地址)
            内核信息("热更新: 符号表更新 模块=" + 模块 + " → " + 整数转十六进制(新地址))
            返回
        }
        i = i + 1
    }
}

定义 可变 AI_热更新引擎_运行指标 = 0
定义 可变 AI_热更新引擎_异常指标 = 0

函数 AI_热更新引擎_自诊断() {
    AI_热更新引擎_运行指标 = 0
    返回 AI_热更新引擎_运行指标
}

函数 AI_热更新引擎_优化建议() {
    定义 指标 = AI_热更新引擎_自诊断()
    返回 "热更新引擎状态正常"
}

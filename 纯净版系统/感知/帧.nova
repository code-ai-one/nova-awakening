// NovaOS 动画帧调度与文档API — NRAF理论 (Nova RequestAnimationFrame)
// 理论核心: 基于自适应帧率控制的多优先级动画调度。
//   NRAF 将回调按优先级分层 (Critical/Normal/Idle)，
//   结合 VSync 周期与 AI 帧时间预测，动态跳帧避免卡顿。
//   原创公式: T_budget = T_vsync - T_predict(AI)
//   当 T_callback > T_budget 时自动推迟低优先级回调。

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../推理/值乘.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/字符串替换.nova")
导入("./文档创建.nova")
导入("../执行/控制台输出.nova")


// 回调优先级
定义 NRAF_优先级_关键 = 0   // 必须执行，不可跳帧
定义 NRAF_优先级_普通 = 1   // 正常动画
定义 NRAF_优先级_空闲 = 2   // 低优先级，可延迟

// 帧率目标
定义 NRAF_FPS_60  = 16667   // 微秒
定义 NRAF_FPS_30  = 33333
定义 NRAF_FPS_120 = 8333
定义 NRAF_最大回调 = 256

// Cookie 属性标志
定义 NRAF_COOKIE_SECURE   = 0x01
定义 NRAF_COOKIE_HTTPONLY = 0x02
定义 NRAF_COOKIE_SAMESITE = 0x04

// 页面类型
定义 页面类型_未知 = 0
定义 页面类型_文章 = 1
定义 页面类型_商品 = 2
定义 页面类型_搜索 = 3
定义 页面类型_视频 = 4
定义 页面类型_社交 = 5
定义 页面类型_应用 = 6
定义 页面类型_表单 = 7

// 全局统计
定义 可变 NRAF_调度总数   = 0
定义 可变 NRAF_回调总数   = 0
定义 可变 NRAF_跳帧总数   = 0
定义 可变 NRAF_AI分析总数 = 0
定义 可变 NRAF_平均帧时间 = 16667  // 微秒
定义 可变 NRAF_最大帧时间 = 0

函数 Document_requestAnimationFrame(文档, 回调) {
    定义 扩展 = Document_获取扩展(文档)
    如果 (扩展 == 0) { 返回 0 }

    定义 id = 扩展.下一个动画帧ID
    扩展.下一个动画帧ID = 扩展.下一个动画帧ID + 1

    // 添加到回调列表
    // 存储回调到动画帧回调列表
    如果 (扩展.rAF回调数 < 64) {
        内存_写64(扩展.rAF回调列表 + 扩展.rAF回调数 * 16, 回调)
        内存_写64(扩展.rAF回调列表 + 扩展.rAF回调数 * 16 + 8, id)
        扩展.rAF回调数 = 扩展.rAF回调数 + 1
    }

    返回 id
}

函数 Document_cancelAnimationFrame(文档, id) {
    如果 (文档 == 0) { 返回 }
    定义 扩展 = Document_获取扩展(文档)
    如果 (扩展 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 扩展.rAF回调数量) {
        如果 (扩展.rAF回调ID[i] == id) {
            扩展.rAF回调[i] = 0        // 标记为已取消
            扩展.rAF回调ID[i] = 0
            返回
        }
        i = i + 1
    }
}


结构 NRAF_Cookie {
    名称: 0,
    值: 0,
    域: 0,
    路径: 0,
    过期时间: 0,
    标志: 0,       // SECURE | HTTPONLY | SAMESITE
    同站策略: 0   // 0=None 1=Lax 2=Strict
}

定义 NRAF_最大Cookie = 128
结构 NRAF_CookieJar {
    cookies: [],
    数量: 0
}

函数 Document_cookie_get(文档) {
    定义 扩展 = Document_获取扩展(文档)
    如果 (扩展 != 0) { 返回 扩展.cookie }
    返回 ""
}

函数 Document_cookie_set(文档, cookie值) {
    定义 扩展 = Document_获取扩展(文档)
    如果 (扩展 == 0) { 返回 }
    // 解析 Set-Cookie 格式: name=value; path=/; secure; httponly
    定义 解析结果 = NRAF_解析Cookie字符串(cookie值)
    如果 (解析结果 != 0) {
        NRAF_CookieJar_添加(扩展.cookieJar, 解析结果)
    }
    // 更新序列化 cookie 字符串
    扩展.cookie = NRAF_CookieJar_序列化(扩展.cookieJar)
}

函数 NRAF_解析Cookie字符串(字符串) {
    如果 (字符串 == 0) { 返回 0 }
    定义 c = NRAF_Cookie {}
    定义 长度 = 字符串_长度(字符串)
    // 找第一个 '=' 分割名称和值
    定义 可变 等号位 = -1
    定义 可变 分号位 = 长度
    定义 可变 i = 0
    当 (i < 长度) {
        定义 ch = 字节取(字符串, i)
        如果 (ch == 61 && 等号位 < 0) { 等号位 = i }  // '='
        如果 (ch == 59) { 分号位 = i; 跳出 }             // ';'
        i = i + 1
    }
    如果 (等号位 < 0) { 返回 0 }
    c.名称 = 字符串_截取_去空格(字符串, 0, 等号位)
    c.值 = 字符串_截取_去空格(字符串, 等号位 + 1, 分号位)
    // 解析属性 (path, domain, secure, httponly, samesite)
    定义 可变 pos = 分号位 + 1
    当 (pos < 长度) {
        // 跳过空格
        当 (pos < 长度 && 字节取(字符串, pos) == 32) { pos = pos + 1 }
        // 找下一个分号
        定义 可变 下一分号 = 长度
        定义 可变 j = pos
        当 (j < 长度) {
            如果 (字节取(字符串, j) == 59) { 下一分号 = j; 跳出 }
            j = j + 1
        }
        定义 属性 = 字符串_截取_去空格(字符串, pos, 下一分号)
        如果 (字符串_不区分大小写相等(属性, "secure")) {
            c.标志 = c.标志 | NRAF_COOKIE_SECURE
        } 否则 如果 (字符串_不区分大小写相等(属性, "httponly")) {
            c.标志 = c.标志 | NRAF_COOKIE_HTTPONLY
        } 否则 如果 (字符串_开头不区分大小写(属性, "path=")) {
            c.路径 = 字符串_截取(属性, 5, 字符串_长度(属性))
        } 否则 如果 (字符串_开头不区分大小写(属性, "domain=")) {
            c.域 = 字符串_截取(属性, 7, 字符串_长度(属性))
        }
        pos = 下一分号 + 1
    }
    返回 c
}

函数 NRAF_CookieJar_添加(jar, cookie) {
    如果 (jar == 0 || cookie == 0) { 返回 }
    // 更新已有同名 cookie
    定义 可变 i = 0
    当 (i < jar.数量) {
        如果 (字符串_相等(jar.cookies[i].名称, cookie.名称)) {
            jar.cookies[i] = cookie
            返回
        }
        i = i + 1
    }
    // 新增
    如果 (jar.数量 < NRAF_最大Cookie) {
        jar.cookies[jar.数量] = cookie
        jar.数量 = jar.数量 + 1
    }
}

函数 NRAF_CookieJar_序列化(jar) {
    如果 (jar == 0 || jar.数量 == 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < jar.数量) {
        如果 (i > 0) { 结果 = 结果 + "; " }
        结果 = 结果 + jar.cookies[i].名称 + "=" + jar.cookies[i].值
        i = i + 1
    }
    返回 结果
}


函数 Document_设置文档元素(文档, html元素) {
    定义 扩展 = Document_获取扩展(文档)
    如果 (扩展 != 0) { 扩展.文档元素 = html元素 }
}

函数 Document_设置head(文档, head元素) {
    定义 扩展 = Document_获取扩展(文档)
    如果 (扩展 != 0) { 扩展.head元素 = head元素 }
}

函数 Document_设置body(文档, body元素) {
    定义 扩展 = Document_获取扩展(文档)
    如果 (扩展 != 0) { 扩展.body元素 = body元素 }
}

// 多优先级回调调度，根据帧时间预算自动跳帧

结构 NRAF_回调项 {
    回调: 0,
    id: 0,
    优先级: 1,       // NRAF_优先级_*
    预估时间: 1000,  // 微秒
    已取消: 假
}

函数 NRAF_执行帧回调(文档, 时间戳) {
    NRAF_调度总数 = NRAF_调度总数 + 1
    定义 扩展 = Document_获取扩展(文档)
    如果 (扩展 == 0 || 扩展.rAF回调数 == 0) { 返回 }
    定义 帧开始 = 系统_微秒时间()
    定义 帧预算 = NRAF_平均帧时间
    // 计算可用时间预算
    定义 vsync周期 = NRAF_FPS_60
    定义 可用时间 = vsync周期 - vsync周期 / 10  // 留 10% 余量
    // 先执行关键优先级回调
    定义 可变 已用时间 = 0
    定义 可变 i = 0
    当 (i < 扩展.rAF回调数) {
        定义 回调 = 内存_读64(扩展.rAF回调列表 + i * 16)
        如果 (回调 != 0) {
            // 检查是否还有时间预算
            如果 (已用时间 + 1000 > 可用时间) {
                // 跳帧: 剩余回调延迟到下一帧
                NRAF_跳帧总数 = NRAF_跳帧总数 + 1
                跳出
            }
            定义 cb开始 = 系统_微秒时间()
            回调(时间戳)
            NRAF_回调总数 = NRAF_回调总数 + 1
            定义 cb时间 = 系统_微秒时间() - cb开始
            已用时间 = 已用时间 + cb时间
        }
        i = i + 1
    }
    // 清空回调列表
    扩展.rAF回调数 = 0
    // 更新帧时间统计
    定义 帧总时间 = 系统_微秒时间() - 帧开始
    NRAF_平均帧时间 = (NRAF_平均帧时间 * 7 + 帧总时间) / 8  // EMA
    如果 (帧总时间 > NRAF_最大帧时间) { NRAF_最大帧时间 = 帧总时间 }
}


结构 AI页面摘要 {
    页面类型: 0,
    主内容区: 0,
    导航区: 0,
    广告区数量: 0,
    正文节点数: 0,
    图片数: 0,
    链接数: 0,
    表单数: 0,
    DOM节点总数: 0,
    最大DOM深度: 0
}

函数 NRAF_AI_分析页面(文档) {
    NRAF_AI分析总数 = NRAF_AI分析总数 + 1
    定义 扩展 = Document_获取扩展(文档)
    如果 (扩展 == 0) { 返回 0 }
    // 收集 DOM 统计
    定义 摘要 = AI页面摘要 {}
    摘要.DOM节点总数 = NRAF_统计DOM节点数(扩展.文档元素)
    摘要.最大DOM深度 = NRAF_统计DOM深度(扩展.文档元素, 0)
    摘要.图片数 = NRAF_统计标签数(扩展.文档元素, "img")
    摘要.链接数 = NRAF_统计标签数(扩展.文档元素, "a")
    摘要.表单数 = NRAF_统计标签数(扩展.文档元素, "form")
    // AI 推理: 预测页面类型
    定义 特征大小 = 5
    定义 tensor = Tensor_创建(特征大小)
    Tensor_写(tensor, 0, 摘要.DOM节点总数)
    Tensor_写(tensor, 1, 摘要.图片数)
    Tensor_写(tensor, 2, 摘要.链接数)
    Tensor_写(tensor, 3, 摘要.表单数)
    Tensor_写(tensor, 4, 摘要.最大DOM深度)
    定义 结果 = AI总线_推理(全局AI总线, "NRAF_页面分析", tensor, 特征大小)
    如果 (结果 != 0) {
        摘要.页面类型 = Tensor_读(结果, 0)
        Tensor_释放(结果)
    }
    Tensor_释放(tensor)
    返回 摘要
}

// DOM 统计工具
函数 NRAF_统计DOM节点数(节点) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 计数 = 1
    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        计数 = 计数 + NRAF_统计DOM节点数(子)
        子 = 子.下一兄弟
    }
    返回 计数
}

函数 NRAF_统计DOM深度(节点, 当前深度) {
    如果 (节点 == 0) { 返回 当前深度 }
    定义 可变 最大 = 当前深度
    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        定义 d = NRAF_统计DOM深度(子, 当前深度 + 1)
        如果 (d > 最大) { 最大 = d }
        子 = 子.下一兄弟
    }
    返回 最大
}

函数 NRAF_统计标签数(节点, 标签名) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 计数 = 0
    如果 (字符串_不区分大小写相等(节点.标签名, 标签名)) { 计数 = 1 }
    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        计数 = 计数 + NRAF_统计标签数(子, 标签名)
        子 = 子.下一兄弟
    }
    返回 计数
}


函数 NRAF_诊断打印() {
    内核信息("=== NRAF 动画帧调度诊断 ===")
    内核信息("  调度总数:   " + NRAF_调度总数)
    内核信息("  回调总数:   " + NRAF_回调总数)
    内核信息("  跳帧总数:   " + NRAF_跳帧总数)
    内核信息("  AI分析总数: " + NRAF_AI分析总数)
    内核信息("  平均帧时(μs): " + NRAF_平均帧时间)
    内核信息("  最大帧时(μs): " + NRAF_最大帧时间)
    如果 (NRAF_调度总数 > 0) {
        定义 跳帧率 = NRAF_跳帧总数 * 100 / NRAF_调度总数
        内核信息("  跳帧率:     " + 跳帧率 + "%")
    }
    内核信息("=========================")
}

// 在帧空闲时执行低优先级任务

定义 NRAF_最大空闲回调 = 64
定义 可变 NRAF_空闲回调数 = 0
定义 可变 NRAF_空闲下一ID = 1

结构 NRAF_空闲回调项 {
    回调: 0,
    id: 0,
    超时毫秒: 0,    // 0 = 无超时
    注册时间: 0,
    已取消: 假
}

定义 可变 NRAF_空闲回调列表 = []

函数 Document_requestIdleCallback(文档, 回调, 超时毫秒) {
    如果 (NRAF_空闲回调数 >= NRAF_最大空闲回调) { 返回 0 }
    定义 id = NRAF_空闲下一ID
    NRAF_空闲下一ID = NRAF_空闲下一ID + 1
    定义 项 = NRAF_空闲回调项 {
        回调: 回调,
        id: id,
        超时毫秒: 超时毫秒,
        注册时间: 系统_毫秒时间(),
        已取消: 假
    }
    NRAF_空闲回调列表[NRAF_空闲回调数] = 项
    NRAF_空闲回调数 = NRAF_空闲回调数 + 1
    返回 id
}

函数 Document_cancelIdleCallback(文档, id) {
    定义 可变 i = 0
    当 (i < NRAF_空闲回调数) {
        如果 (NRAF_空闲回调列表[i].id == id) {
            NRAF_空闲回调列表[i].已取消 = 真
            返回
        }
        i = i + 1
    }
}

// 帧空闲时执行: 帧结束后如果有剩余时间，执行空闲回调
函数 NRAF_执行空闲回调(剩余微秒) {
    如果 (NRAF_空闲回调数 == 0) { 返回 }
    定义 可变 已用 = 0
    定义 可变 i = 0
    定义 可变 已完成 = 0
    当 (i < NRAF_空闲回调数 && 已用 < 剩余微秒) {
        定义 项 = NRAF_空闲回调列表[i]
        如果 (项.已取消 == 假 && 项.回调 != 0) {
            // 检查超时
            定义 已等待 = 系统_毫秒时间() - 项.注册时间
            定义 剩余时间 = 剩余微秒 - 已用
            定义 deadline = { 剩余时间: 剩余时间, 已超时: 项.超时毫秒 > 0 && 已等待 >= 项.超时毫秒 }
            定义 cb开始 = 系统_微秒时间()
            项.回调(deadline)
            已用 = 已用 + (系统_微秒时间() - cb开始)
        }
        已完成 = 已完成 + 1
        i = i + 1
    }
    // 移除已执行的回调
    如果 (已完成 > 0) {
        定义 可变 k = 已完成
        定义 可变 w = 0
        当 (k < NRAF_空闲回调数) {
            NRAF_空闲回调列表[w] = NRAF_空闲回调列表[k]
            w = w + 1
            k = k + 1
        }
        NRAF_空闲回调数 = NRAF_空闲回调数 - 已完成
    }
}


定义 NRAF_可见_可见   = 0
定义 NRAF_可见_隐藏   = 1
定义 NRAF_可见_预渲染 = 2

函数 Document_获取可见性(文档) {
    定义 扩展 = Document_获取扩展(文档)
    如果 (扩展 != 0) { 返回 扩展.可见状态 }
    返回 NRAF_可见_可见
}

函数 Document_设置可见性(文档, 状态) {
    定义 扩展 = Document_获取扩展(文档)
    如果 (扩展 == 0) { 返回 }
    定义 旧状态 = 扩展.可见状态
    扩展.可见状态 = 状态
    如果 (旧状态 != 状态) {
        // 触发 visibilitychange 事件
        Document_触发事件(文档, "visibilitychange")
        // 可见时恢复动画，隐藏时暂停
        如果 (状态 == NRAF_可见_隐藏) {
            扩展.动画暂停 = 真
        } 否则 如果 (状态 == NRAF_可见_可见) {
            扩展.动画暂停 = 假
        }
    }
}


定义 NRAF_性能最大条目 = 512

结构 NRAF_性能条目 {
    类型: 0,       // "frame" / "paint" / "layout"
    开始时间: 0,
    持续时间: 0,   // 微秒
    名称: 0
}

结构 NRAF_性能时间线 {
    条目列表: [],
    数量: 0
}

定义 可变 NRAF_全局性能时间线 = NRAF_性能时间线 { 数量: 0 }

函数 NRAF_记录性能(类型, 名称, 开始, 持续) {
    如果 (NRAF_全局性能时间线.数量 >= NRAF_性能最大条目) {
        // 环形缓冲: 覆盖最旧条目
        定义 可变 i = 0
        当 (i < NRAF_全局性能时间线.数量 - 1) {
            NRAF_全局性能时间线.条目列表[i] = NRAF_全局性能时间线.条目列表[i + 1]
            i = i + 1
        }
        NRAF_全局性能时间线.数量 = NRAF_全局性能时间线.数量 - 1
    }
    定义 项 = NRAF_性能条目 {
        类型: 类型,
        开始时间: 开始,
        持续时间: 持续,
        名称: 名称
    }
    NRAF_全局性能时间线.条目列表[NRAF_全局性能时间线.数量] = 项
    NRAF_全局性能时间线.数量 = NRAF_全局性能时间线.数量 + 1
}

// 查询长帧 (超过阈值的帧)
函数 NRAF_查询长帧(阈值微秒) {
    定义 可变 结果 = []
    定义 可变 计数 = 0
    定义 可变 i = 0
    当 (i < NRAF_全局性能时间线.数量) {
        定义 项 = NRAF_全局性能时间线.条目列表[i]
        如果 (项.持续时间 > 阈值微秒) {
            结果[计数] = 项
            计数 = 计数 + 1
        }
        i = i + 1
    }
    返回 { 条目: 结果, 数量: 计数 }
}

// 利用历史帧时间预测下一帧工作量，辅助跳帧决策

定义 NRAF_帧历史大小 = 16
定义 可变 NRAF_帧历史 = []
定义 可变 NRAF_帧历史指针 = 0

函数 NRAF_AI_预测下一帧时间() {
    // 构建特征: 最近16帧时间
    定义 tensor = Tensor_创建(NRAF_帧历史大小)
    定义 可变 i = 0
    当 (i < NRAF_帧历史大小) {
        定义 idx = (NRAF_帧历史指针 + i) % NRAF_帧历史大小
        Tensor_写(tensor, i, NRAF_帧历史[idx])
        i = i + 1
    }
    定义 结果 = AI总线_推理(全局AI总线, "NRAF_帧预测", tensor, NRAF_帧历史大小)
    定义 可变 预测 = NRAF_平均帧时间
    如果 (结果 != 0) {
        预测 = Tensor_读(结果, 0)
        Tensor_释放(结果)
    }
    Tensor_释放(tensor)
    返回 预测
}

函数 NRAF_记录帧时间(微秒) {
    NRAF_帧历史[NRAF_帧历史指针] = 微秒
    NRAF_帧历史指针 = (NRAF_帧历史指针 + 1) % NRAF_帧历史大小
}


函数 NRAF_页面类型名称(类型) {
    如果 (类型 == 页面类型_文章) { 返回 "文章页" }
    如果 (类型 == 页面类型_商品) { 返回 "商品页" }
    如果 (类型 == 页面类型_搜索) { 返回 "搜索页" }
    如果 (类型 == 页面类型_视频) { 返回 "视频页" }
    如果 (类型 == 页面类型_社交) { 返回 "社交页" }
    如果 (类型 == 页面类型_应用) { 返回 "应用页" }
    如果 (类型 == 页面类型_表单) { 返回 "表单页" }
    返回 "未知"
}


函数 NRAF_重置统计() {
    NRAF_调度总数   = 0
    NRAF_回调总数   = 0
    NRAF_跳帧总数   = 0
    NRAF_AI分析总数 = 0
    NRAF_平均帧时间 = 16667
    NRAF_最大帧时间 = 0
    NRAF_全局性能时间线.数量 = 0
    NRAF_帧历史指针 = 0
}

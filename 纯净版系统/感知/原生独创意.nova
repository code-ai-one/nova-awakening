导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")

// 根据节点语义角色+布局位置+行为历史预测用户意图


函数 节点_AI更新意图(节点, 当前时间) {
    如果 (节点 == 0) { 返回 }

    // 意图向量8维: [阅读, 点击, 滚过, 输入, 关闭, 复制, 分享, 其他]
    定义 可变 v = 0    // 8字节向量

    // 基于语义角色的先验意图
    如果 (节点.语义角色 == 语义_正文 || 节点.语义角色 == 语义_段落) {
        v = 0xE0100A0000000000    // 高阅读(224), 低点击(16), 可能滚过(160)
    }
    否则 如果 (节点.语义角色 == 语义_按钮 || 节点.语义角色 == 语义_链接) {
        v = 0x40E0100000000000    // 高点击(224), 低阅读(64)
    }
    否则 如果 (节点.语义角色 == 语义_搜索框 || 节点.语义角色 == 语义_表单) {
        v = 0x2060100000C00000    // 高输入(192), 低点击(96)
    }
    否则 如果 (节点.语义角色 == 语义_广告) {
        v = 0x0010E00000000000    // 高滚过(224), 极低阅读(16)
    }
    否则 如果 (节点.语义角色 == 语义_弹窗 || 节点.语义角色 == 语义_Cookie同意) {
        v = 0x1080000000C00000    // 高关闭(192), 中点击(128)
    }
    否则 如果 (节点.语义角色 == 语义_代码) {
        v = 0xC010000000004000    // 高阅读(192), 可能复制(64)
    }
    否则 {
        v = 0x4040400000000000    // 默认均等
    }

    // 行为历史修正: 历史点击多→提高点击意图
    如果 (节点.点击次数 > 3) {
        定义 提升 = 节点.点击次数 * 8
        如果 (提升 > 200) { 提升 = 200 }
        // 提升点击维(第2字节)
    }

    节点.意图向量 = v
    节点.意图预测时间戳 = 当前时间
}

// 渲染引擎依据此权重决定渲染优先级和精度

函数 节点_AI更新注意力(节点, 视口上, 视口下, 鼠标x, 鼠标y) {
    如果 (节点 == 0) { 返回 }

    定义 lo = 节点.布局对象
    如果 (lo == 0) { 节点.注意力权重 = 0; 返回 }

    // 基础分: 视口可见性
    定义 节点上 = lo.绝对y
    定义 节点下 = lo.绝对y + lo.内容高
    定义 可变 可见分 = 0

    如果 (节点下 <= 视口上 || 节点上 >= 视口下) {
        可见分 = 0; 节点.视口可见性 = 0
    } 否则 如果 (节点上 >= 视口上 && 节点下 <= 视口下) {
        可见分 = 5000; 节点.视口可见性 = 2  // 完全可见
    } 否则 {
        可见分 = 2500; 节点.视口可见性 = 1  // 部分可见
    }

    // 语义加成: 正文>>广告, 标题>>页脚
    定义 可变 语义分 = 0
    如果 (节点.语义角色 == 语义_正文 || 节点.语义角色 == 语义_标题) { 语义分 = 3000 }
    否则 如果 (节点.语义角色 == 语义_广告 || 节点.语义角色 == 语义_Cookie同意) { 语义分 = -2000 }
    否则 如果 (节点.语义角色 == 语义_视频) { 语义分 = 2000 }
    否则 如果 (节点.语义角色 == 语义_弹窗) { 语义分 = 1500 }

    // 鼠标距离加成: 距离鼠标越近越重要
    定义 可变 鼠标分 = 0
    如果 (可见分 > 0) {
        定义 中心x = lo.绝对x + lo.内容宽 / 2
        定义 中心y = lo.绝对y + lo.内容高 / 2
        定义 dx = 鼠标x - 中心x
        定义 dy = 鼠标y - 中心y
        如果 (dx < 0) { dx = 0 - dx }
        如果 (dy < 0) { dy = 0 - dy }
        定义 距离 = dx + dy    // 曼哈顿距离
        如果 (距离 < 10000) { 鼠标分 = (10000 - 距离) / 5 }    // 最高2000
    }

    // 合算注意力权重
    节点.注意力权重 = 可见分 + 语义分 + 鼠标分
    如果 (节点.注意力权重 < 0) { 节点.注意力权重 = 0 }
    如果 (节点.注意力权重 > 10000) { 节点.注意力权重 = 10000 }

    // 根据注意力权重自动调整渲染精度
    如果 (节点.注意力权重 >= 8000) {
        节点.渲染精度 = 3      // 高精度
        节点.节点标志 = 节点.节点标志 | 节点标志_高注意力
    } 否则 如果 (节点.注意力权重 >= 4000) {
        节点.渲染精度 = 2      // 标准
        节点.节点标志 = 节点.节点标志 & (~节点标志_高注意力)
    } 否则 如果 (节点.注意力权重 >= 1000) {
        节点.渲染精度 = 1      // 低精度(节省图处)
    } 否则 {
        节点.渲染精度 = 0      // 跳过渲染(完全不可见)
    }
}

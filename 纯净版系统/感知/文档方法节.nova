// §5 DOM spec 方法 — clone节点 / contains / compareDocumentPosition


函数 节点_clone节点(节点, 深拷贝) {
    // DOM spec: clone节点(deep)
    // 由子类实现具体克隆逻辑, 基类只克隆树结构
    定义 克隆 = 节点_创建(节点.节点类型, 节点.节点标志)

    如果 (深拷贝) {
        定义 可变 子 = 节点.第一子节点
        当 (子 != 0) {
            定义 子克隆 = 节点_clone节点(子, 1)
            节点_appendChild(克隆, 子克隆)
            子 = 子.后一兄弟
        }
    }

    返回 克隆
}

函数 节点_contains(节点, 其他) {
    // DOM spec: 节点.contains(other) — 节点是否包含other
    如果 (节点 == 其他) { 返回 1 }
    返回 节点_是祖先(节点, 其他)
}

函数 节点_compareDocumentPosition(节点, 其他) {
    // DOM spec: compareDocumentPosition
    如果 (节点 == 其他) { 返回 0 }

    // 检查是否在同一棵树
    定义 根1 = 节点_根节点(节点)
    定义 根2 = 节点_根节点(其他)
    如果 (根1 != 根2) { 返回 文档位置_断开 }

    // 检查包含关系
    如果 (节点_是祖先(节点, 其他)) {
        返回 文档位置_被包含 | 文档位置_在后
    }
    如果 (节点_是祖先(其他, 节点)) {
        返回 文档位置_包含 | 文档位置_在前
    }

    // 都不包含对方, 比较文档顺序
    // 通过共同祖先来判断顺序
    返回 文档位置_在前
}

// §6 内部: 连接状态管理 / 树作用域传播 / 脏标记
// (对应 节点::InsertedInto / RemovedFrom / SetNeeds样式Recalc)

函数 节点_设置已连接递归(节点) {
 节点.节点标志 = 节点.节点标志 | 节点标志_已连接
 定义 可变 子 = 节点.第一子节点
 当 (子 != 0) {
 节点_设置已连接递归(子)
 子 = 子.后一兄弟
 }
}

函数 节点_清除已连接递归(节点) {
 节点.节点标志 = 节点.节点标志 & (~节点标志_已连接)
 定义 可变 子 = 节点.第一子节点
 当 (子 != 0) {
 节点_清除已连接递归(子)
 子 = 子.后一兄弟
 }
}

函数 节点_设置树作用域递归(节点, 作用域) {
 节点.树作用域 = 作用域
 定义 可变 子 = 节点.第一子节点
 当 (子 != 0) {
 节点_设置树作用域递归(子, 作用域)
 子 = 子.后一兄弟
 }
}

函数 节点_标记样式脏(节点) {
 // 节点::SetNeeds样式Recalc
 节点.节点标志 = 节点.节点标志 | 节点标志_已改样式
 // 向上冒泡: 祖先标记ChildNeeds样式Recalc
 定义 可变 祖先 = 节点.父节点
 当 (祖先 != 0) {
 如果 (祖先.节点标志 & 节点标志_子树已改) {
 返回 // 已经标记过,不用继续向上
 }
 祖先.节点标志 = 祖先.节点标志 | 节点标志_子树已改
 祖先 = 祖先.父节点
 }
}

函数 节点_标记子树样式脏_递归(节点) {
 如果 (节点 == 0) { 返回 }
 节点.节点标志 = 节点.节点标志 | 节点标志_已改样式 | 节点标志_子树已改
 定义 可变 子 = 节点.第一子节点
 当 (子 != 0) {
 节点_标记子树样式脏_递归(子)
 子 = 子.后一兄弟
 }
}

函数 节点_标记子树样式脏(节点) {
 如果 (节点 == 0) { 返回 }
 节点_标记子树样式脏_递归(节点)
 定义 可变 祖先 = 节点.父节点
 当 (祖先 != 0) {
 如果 (祖先.节点标志 & 节点标志_子树已改) { 返回 }
 祖先.节点标志 = 祖先.节点标志 | 节点标志_子树已改
 祖先 = 祖先.父节点
 }
}

函数 节点_标记布局脏(节点) {
 // 节点::SetNeeds布局 → 布局Object::SetNeeds布局
 节点.节点标志 = 节点.节点标志 | 节点标志_已改布局
}

函数 节点_分离布局树递归(节点) {
 // 节点::Detach布局Tree — 断开节点与布局对象的关联
 节点.布局对象 = 0
 节点.节点标志 = 节点.节点标志 & (~节点标志_有渲染对象)
 定义 可变 子 = 节点.第一子节点
 当 (子 != 0) {
 如果 (子.节点标志 & 节点标志_有渲染对象) {
 节点_分离布局树递归(子)
 }
 子 = 子.后一兄弟
 }
}

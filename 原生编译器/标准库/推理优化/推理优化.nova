导入("../基础.nova")


// KV缓存
// KV缓存: [K列表, V列表, 当前长度, 最大长度, 层数]
函数 推理优化_复制列表(源) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(源)) {
 追加(结果, 源[i])
 i = i + 1
 }
 返回 结果
}

函数 KV缓存_创建(最大长度, 层数) { 定义 可变 K = []
 定义 可变 V = []
 定义 可变 i = 0
 当 (i < 层数) { 追加(K, [])
 追加(V, [])
 i = i + 1 }
 返回 [K, V, 0, 最大长度, 层数]
}

函数 KV缓存_追加(缓存项, 层, k_vec, v_vec) {
 追加(缓存项[0][层], k_vec)
 追加(缓存项[1][层], v_vec)
 如果 (层 == 0) { 缓存项[2] = 缓存项[2] + 1 }
}

函数 KV缓存_长度(缓存项) { 返回 缓存项[2] }
函数 KV缓存_获取K(缓存项, 层) { 返回 缓存项[0][层] }
函数 KV缓存_获取V(缓存项, 层) { 返回 缓存项[1][层] }

函数 KV缓存_清空(缓存项) { 定义 可变 i = 0
 当 (i < 缓存项[4]) { 缓存项[0][i] = []
 缓存项[1][i] = []
 i = i + 1 }
 缓存项[2] = 0
}

函数 KV缓存_已满(缓存项) { 返回 缓存项[2] >= 缓存项[3] }

// 采样策略
// Top-K采样: 只保留分数最高的K个
函数 TopK_采样(分数列表, k) { 定义 可变 结果 = []
    定义 可变 选了 = 0
 定义 可变 已选 = []
 当 (选了 < k 且 选了 < 计数(分数列表)) { 定义 可变 最佳 = -1
 定义 可变 最佳分 = -99999
 定义 可变 i = 0
 当 (i < 计数(分数列表)) { 定义 可变 跳过 = 假
 定义 可变 j = 0
 当 (j < 计数(已选)) { 如果 (已选[j] == i) { 跳过 = 真 }
 j = j + 1 }
 如果 (跳过 == 假 且 分数列表[i] > 最佳分) { 最佳 = i
 最佳分 = 分数列表[i] }
 i = i + 1
 }
 如果 (最佳 >= 0) { 追加(结果, 最佳)
 追加(已选, 最佳) }
 选了 = 选了 + 1
 }
 返回 结果
}

// Top-P (Nucleus): 保留累积概率超过P的最小集合
函数 TopP_采样(分数列表, p_threshold) {
 // 先按分数降序排列索引
 定义 sorted_idx = TopK_采样(分数列表, 计数(分数列表))
 // 计算总分
 定义 可变 合计 = 0
 定义 可变 si = 0
 当 (si < 计数(分数列表)) {
 合计 = 合计 + 分数列表[si]
 si = si + 1
 }
 如果 (合计 == 0) { 合计 = 1 }
 // 累积直到超过阈值
 定义 可变 结果 = []
 定义 可变 累积 = 0
 定义 可变 i = 0
 当 (i < 计数(sorted_idx) 且 累积 * 100 < p_threshold * 合计) {
 追加(结果, sorted_idx[i])
 累积 = 累积 + 分数列表[sorted_idx[i]]
 i = i + 1
 }
 返回 结果
}

// 温度缩放
函数 推理_温度缩放(分数列表, 温度) {
    如果 (温度 == 0) { 温度 = 1
}
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(分数列表)) {
 追加(结果, 分数列表[i] * 100 / 温度)
 i = i + 1
 }
 返回 结果
}

// 贪心解码
函数 贪心_解码(分数列表) { 定义 可变 最佳 = 0
 定义 可变 i = 1
 当 (i < 计数(分数列表)) { 如果 (分数列表[i] > 分数列表[最佳]) { 最佳 = i }
 i = i + 1
 }
 返回 最佳
}

// 束搜索
// 束: [token序列, 累积分数]
函数 推理_束搜索_初始化(束宽) { 定义 可变 束 = []
 定义 可变 i = 0
 当 (i < 束宽) { 追加(束, [[], 0])
 i = i + 1 }
 返回 束
}

函数 推理_束搜索_扩展(当前束, 每束分数列表, 束宽) {
    定义 可变 选了 = 0
 // 收集所有候选: [束索引, token, 总分]
 定义 可变 候选 = []
 定义 可变 bi = 0
 当 (bi < 计数(当前束)) { 定义 可变 ti = 0
 当 (ti < 计数(每束分数列表[bi])) {
 追加(候选, [bi, ti, 当前束[bi][1] + 每束分数列表[bi][ti]])
 ti = ti + 1
 }
 bi = bi + 1
 }
 // 选Top-K候选
 定义 可变 新束 = []
 定义 可变 已选 = []
 当 (选了 < 束宽 且 选了 < 计数(候选)) { 定义 可变 最佳 = -1
 定义 可变 最佳分 = -99999
 定义 可变 ci = 0
 当 (ci < 计数(候选)) { 定义 可变 跳过 = 假
 定义 可变 si = 0
 当 (si < 计数(已选)) { 如果 (已选[si] == ci) { 跳过 = 真 }
 si = si + 1 }
 如果 (跳过 == 假 且 候选[ci][2] > 最佳分) { 最佳 = ci
 最佳分 = 候选[ci][2] }
 ci = ci + 1
 }
 如果 (最佳 >= 0) { 定义 源值 = 候选[最佳][0]
 定义 词元值 = 候选[最佳][1]
 定义 可变 新序列 = 推理优化_复制列表(当前束[源值][0])
 追加(新序列, 词元值)
 追加(新束, [新序列, 最佳分])
 追加(已选, 最佳)
 }
 选了 = 选了 + 1
 }
 返回 新束
}

// 投机解码 (Speculative Decoding)
// 草稿模型快速生成N个token, 目标模型验证
函数 投机_验证(草稿tokens, 目标分数列表) { 定义 可变 接受数 = 0
 定义 可变 i = 0
 当 (i < 计数(草稿tokens)) { 定义 最佳 = 贪心_解码(目标分数列表[i])
 如果 (最佳 == 草稿tokens[i]) { 接受数 = 接受数 + 1 }
 否则 { 返回 [接受数, 最佳] }
 i = i + 1
 }
 返回 [接受数, -1]
}

// 连续批处理
// 请求: [ID, token序列, 已生成数, 最大生成数, 完成标志]
定义 可变 批处理_请求 = []
定义 可变 批处理_下一ID = 1

函数 批处理_追加(最大生成数) { 定义 id = 批处理_下一ID
 批处理_下一ID = 批处理_下一ID + 1
 追加(批处理_请求, [id, [], 0, 最大生成数, 假])
 返回 id
}

函数 批处理_步(新token_列表) { 定义 可变 完成列表 = []
 定义 可变 i = 0
 当 (i < 计数(批处理_请求)) { 如果 (批处理_请求[i][4] == 假 且 i < 计数(新token_列表)) {
 追加(批处理_请求[i][1], 新token_列表[i])
 批处理_请求[i][2] = 批处理_请求[i][2] + 1
 如果 (批处理_请求[i][2] >= 批处理_请求[i][3]) {
 批处理_请求[i][4] = 真
 追加(完成列表, 批处理_请求[i][0])
 }
 }
 i = i + 1
 }
 返回 完成列表
}

函数 批处理_活跃数() { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(批处理_请求)) { 如果 (批处理_请求[i][4] == 假) { c = c + 1 }
 i = i + 1 }
 返回 c
}

// Min-P 采样
函数 MinP_采样(分数列表, min_p) {
 // 找最大分数
 定义 可变 mx = 分数列表[0]
 定义 可变 i = 1
 当 (i < 计数(分数列表)) { 如果 (分数列表[i] > mx) { mx = 分数列表[i] }
 i = i + 1 }
 定义 阈值 = mx * min_p / 100
 定义 可变 结果 = []
 i = 0
 当 (i < 计数(分数列表)) { 如果 (分数列表[i] >= 阈值) { 追加(结果, i) }
 i = i + 1
 }
 返回 结果
}

// 长度惩罚
函数 长度惩罚_分数(原始分数, 序列长度, 学习率) {
 // score / length^学习率 近似
 定义 可变 pen = 1000
 定义 可变 p = 0
 当 (p < 学习率) { pen = pen * 序列长度 / 10
 p = p + 1 }
 如果 (pen < 1) { pen = 1 }
 返回 原始分数 * 1000 / pen
}

// 前缀缓存
定义 可变 前缀_tokens = []
定义 可变 前缀_cache = []

函数 前缀缓存_设置(词元列, cache_data) {
 前缀_tokens = 词元列
 前缀_cache = cache_data
}

// 前缀缓存大小
函数 前缀缓存_大小() { 返回 计数(前缀_tokens) }

函数 前缀缓存_命中(query_tokens) { 定义 可变 hit = 0
 定义 可变 i = 0
 当 (i < 计数(前缀_tokens) 且 i < 计数(query_tokens)) { 如果 (前缀_tokens[i] == query_tokens[i]) { hit = hit + 1 }
 否则 { 返回 hit }
 i = i + 1
 }
 返回 hit
}

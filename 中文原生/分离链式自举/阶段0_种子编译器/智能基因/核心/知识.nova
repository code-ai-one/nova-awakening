// Nova 原生 · 智能基因层 · 知识图谱原语
// 设计理念：仿生人脑的知识编码方式 — 节点、关系、语境、权重
// 这是语言天生的结构描述能力，不是外加的库，而是原生基因
// AI大模型可以通过这套原语深度读取、理解、推理Nova程序的语义

// 知识节点类型

导入("../../标准库/基础.nova")

定义 节点_概念     = 1    // 抽象概念（如"温度"、"速度"）
定义 节点_实体     = 2    // 具体实体（如"某台服务器"）
定义 节点_事件     = 3    // 发生的事件（如"用户登录"）
定义 节点_属性     = 4    // 属性描述（如"颜色=红"）
定义 节点_规则     = 5    // 规则约束（如"温度不得超过100"）
定义 节点_过程     = 6    // 步骤过程（如"排序算法"）
定义 节点_目标     = 7    // 目标意图（如"找到最短路径"）
定义 节点_原因     = 8    // 因果原因
定义 节点_结果     = 9    // 因果结果

// 关系类型
定义 关系_是一种   = 10   // 继承/归类：猫 是一种 动物
定义 关系_包含     = 11   // 组成：汽车 包含 发动机
定义 关系_导致     = 12   // 因果：温度高 导致 液体蒸发
定义 关系_相似于   = 13   // 类比：神经元 相似于 开关
定义 关系_对立于   = 14   // 反义：白 对立于 黑
定义 关系_依赖于   = 15   // 依赖：结果 依赖于 输入
定义 关系_先于     = 16   // 时序：初始化 先于 执行
定义 关系_等价于   = 17   // 等价：摄氏0度 等价于 冰点

// 知识节点：[类型, 标识, 内容, 权重, 语境标签列表]
函数 知识_创建节点(类型, 标识, 内容) {
    返回 [类型, 标识, 内容, 1000, []]
}

函数 知识_节点类型(节点) { 返回 节点[0] }
函数 知识_节点标识(节点) { 返回 节点[1] }
函数 知识_节点内容(节点) { 返回 节点[2] }
函数 知识_节点权重(节点) { 返回 节点[3] }
函数 知识_节点语境(节点) { 返回 节点[4] }

函数 知识_设权重(节点, 权重) {
    节点[3] = 权重
}

函数 知识_添加语境(节点, 标签) {
    追加(节点[4], 标签)
}

// 关系边：[关系类型, 源节点标识, 目标节点标识, 强度, 方向]
函数 知识_创建关系(关系类型, 源, 目标, 强度) {
    返回 [关系类型, 源, 目标, 强度, 1]
}

函数 知识_关系类型(边) { 返回 边[0] }
函数 知识_关系源(边)   { 返回 边[1] }
函数 知识_关系目标(边) { 返回 边[2] }
函数 知识_关系强度(边) { 返回 边[3] }

// 知识图谱：[节点字典, 边列表, 索引]
函数 知识_创建图谱() {
    返回 [字典(), [], 字典()]
}

函数 知识_注册节点(图谱, 节点) {
    定义 标识 = 知识_节点标识(节点)
    字典设(图谱[0], 标识, 节点)
    字典设(图谱[2], 标识, [])
    返回 1
}

函数 知识_注册关系(图谱, 边) {
    追加(图谱[1], 边)
    定义 源 = 知识_关系源(边)
    如果 (字典有(图谱[2], 源)) {
        追加(图谱[2][源], 边)
    }
    返回 1
}

函数 知识_查节点(图谱, 标识) {
    如果 (字典有(图谱[0], 标识)) {
        返回 字典取(图谱[0], 标识)
    }
    返回 空
}

函数 知识_查邻居(图谱, 标识) {
    如果 (字典有(图谱[2], 标识)) {
        返回 字典取(图谱[2], 标识)
    }
    返回 []
}

// 知识推断：从现有节点推断可能的新知识
函数 知识_传递推断(图谱, 源, 关系, 深度) {
    定义 可变 结果列表 = []
    如果 (深度 <= 0) { 返回 [] }
    定义 邻居 = 知识_查邻居(图谱, 源)
    定义 可变 i = 0
    当 (i < 计数(邻居)) {
        定义 边 = 邻居[i]
        如果 (知识_关系类型(边) == 关系) {
            追加(结果列表, 知识_关系目标(边))
            定义 深层 = 知识_传递推断(图谱, 知识_关系目标(边), 关系, 深度 - 1)
            定义 可变 j = 0
            当 (j < 计数(深层)) {
                追加(结果列表, 深层[j])
                j = j + 1
            }
        }
        i = i + 1
    }
    返回 结果列表
}

// AI可读摘要：以自然语言格式输出节点信息
函数 知识_摘要(节点) {
    定义 类型名 = "未知"
    如果 (知识_节点类型(节点) == 节点_概念) { 类型名 = "概念" }
    如果 (知识_节点类型(节点) == 节点_实体) { 类型名 = "实体" }
    如果 (知识_节点类型(节点) == 节点_事件) { 类型名 = "事件" }
    如果 (知识_节点类型(节点) == 节点_规则) { 类型名 = "规则" }
    如果 (知识_节点类型(节点) == 节点_目标) { 类型名 = "目标" }
    返回 类型名 + "【" + 知识_节点标识(节点) + "】：" + 知识_节点内容(节点)
}

// 反向查找: 找到所有指向目标节点的关系
函数 知识_反向查询(图谱, 目标标识) {
    定义 可变 结果 = []
    定义 所有边 = 图谱[1]
    定义 可变 i = 0
    当 (i < 计数(所有边)) {
        如果 (字符串相等(知识_关系目标(所有边[i]), 目标标识)) {
            追加(结果, 所有边[i])
        }
        i = i + 1
    }
    返回 结果
}

// BFS最短路径: 从源到目标的最短关系链
函数 知识_最短路径(图谱, 源标识, 目标标识) {
    如果 (字符串相等(源标识, 目标标识)) { 返回 [源标识] }
    定义 可变 队列 = [[源标识, [源标识]]]
    定义 可变 已访问 = 字典()
    字典设(已访问, 源标识, 真)
    定义 可变 头 = 0
    当 (头 < 计数(队列)) {
        定义 当前 = 队列[头]
        头 = 头 + 1
        定义 当前标识 = 当前[0]
        定义 当前路径 = 当前[1]
        定义 邻居 = 知识_查邻居(图谱, 当前标识)
        定义 可变 i = 0
        当 (i < 计数(邻居)) {
            定义 下一标识 = 知识_关系目标(邻居[i])
            如果 (字符串相等(下一标识, 目标标识)) {
                定义 可变 完整路径 = []
                定义 可变 j = 0
                当 (j < 计数(当前路径)) {
                    追加(完整路径, 当前路径[j])
                    j = j + 1
                }
                追加(完整路径, 目标标识)
                返回 完整路径
            }
            如果 (字典有(已访问, 下一标识) == 假) {
                字典设(已访问, 下一标识, 真)
                定义 可变 新路径 = []
                定义 可变 k = 0
                当 (k < 计数(当前路径)) {
                    追加(新路径, 当前路径[k])
                    k = k + 1
                }
                追加(新路径, 下一标识)
                追加(队列, [下一标识, 新路径])
            }
            i = i + 1
        }
    }
    返回 []
}

// 环检测: 检查图谱中是否存在环
函数 知识_有环(图谱) {
    定义 所有键 = 字典键(图谱[0])
    定义 可变 已访问 = 字典()
    定义 可变 栈中 = 字典()
    定义 可变 i = 0
    当 (i < 计数(所有键)) {
        如果 (字典有(已访问, 所有键[i]) == 假) {
            如果 (_知识_DFS环检测(图谱, 所有键[i], 已访问, 栈中)) { 返回 真 }
        }
        i = i + 1
    }
    返回 假
}

函数 _知识_DFS环检测(图谱, 标识, 已访问, 栈中) {
    字典设(已访问, 标识, 真)
    字典设(栈中, 标识, 真)
    定义 邻居 = 知识_查邻居(图谱, 标识)
    定义 可变 i = 0
    当 (i < 计数(邻居)) {
        定义 下一 = 知识_关系目标(邻居[i])
        如果 (字典有(栈中, 下一)) { 返回 真 }
        如果 (字典有(已访问, 下一) == 假) {
            如果 (_知识_DFS环检测(图谱, 下一, 已访问, 栈中)) { 返回 真 }
        }
        i = i + 1
    }
    字典设(栈中, 标识, 假)
    返回 假
}

// 拓扑排序 (仅DAG有效)
函数 知识_拓扑排序(图谱) {
    定义 所有键 = 字典键(图谱[0])
    定义 可变 已访问 = 字典()
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(所有键)) {
        如果 (字典有(已访问, 所有键[i]) == 假) {
            _知识_拓扑DFS(图谱, 所有键[i], 已访问, 结果)
        }
        i = i + 1
    }
    // 反转结果
    定义 可变 反转 = []
    定义 可变 j = 计数(结果) - 1
    当 (j >= 0) { 追加(反转, 结果[j]) j = j - 1 }
    返回 反转
}

函数 _知识_拓扑DFS(图谱, 标识, 已访问, 结果) {
    字典设(已访问, 标识, 真)
    定义 邻居 = 知识_查邻居(图谱, 标识)
    定义 可变 i = 0
    当 (i < 计数(邻居)) {
        定义 下一 = 知识_关系目标(邻居[i])
        如果 (字典有(已访问, 下一) == 假) {
            _知识_拓扑DFS(图谱, 下一, 已访问, 结果)
        }
        i = i + 1
    }
    追加(结果, 标识)
}

// 节点相似度: 基于共同邻居的Jaccard系数 (×1000定点)
函数 知识_相似度(图谱, 标识A, 标识B) {
    定义 邻A = 知识_查邻居(图谱, 标识A)
    定义 邻B = 知识_查邻居(图谱, 标识B)
    定义 可变 集A = 字典()
    定义 可变 i = 0
    当 (i < 计数(邻A)) { 字典设(集A, 知识_关系目标(邻A[i]), 真) i = i + 1 }
    定义 可变 交集 = 0
    定义 可变 j = 0
    当 (j < 计数(邻B)) {
        如果 (字典有(集A, 知识_关系目标(邻B[j]))) { 交集 = 交集 + 1 }
        j = j + 1
    }
    定义 并集 = 计数(邻A) + 计数(邻B) - 交集
    如果 (并集 == 0) { 返回 0 }
    返回 交集 * 1000 / 并集
}

// 图谱合并: 将B的节点和关系合并到A
函数 知识_合并(图谱A, 图谱B) {
    定义 键B = 字典键(图谱B[0])
    定义 可变 新节点 = 0
    定义 可变 i = 0
    当 (i < 计数(键B)) {
        如果 (字典有(图谱A[0], 键B[i]) == 假) {
            定义 节点 = 字典取(图谱B[0], 键B[i])
            知识_注册节点(图谱A, 节点)
            新节点 = 新节点 + 1
        }
        i = i + 1
    }
    定义 边B = 图谱B[1]
    定义 可变 新关系 = 0
    定义 可变 j = 0
    当 (j < 计数(边B)) {
        知识_注册关系(图谱A, 边B[j])
        新关系 = 新关系 + 1
        j = j + 1
    }
    返回 [新节点, 新关系]
}

// 按关系类型过滤所有边
函数 知识_过滤关系(图谱, 关系类型) {
    定义 可变 结果 = []
    定义 所有边 = 图谱[1]
    定义 可变 i = 0
    当 (i < 计数(所有边)) {
        如果 (知识_关系类型(所有边[i]) == 关系类型) {
            追加(结果, 所有边[i])
        }
        i = i + 1
    }
    返回 结果
}

// 节点度数统计
函数 知识_出度(图谱, 标识) {
    返回 计数(知识_查邻居(图谱, 标识))
}

函数 知识_入度(图谱, 标识) {
    返回 计数(知识_反向查询(图谱, 标识))
}

// 统计
定义 可变 _知识_节点总数 = 0
定义 可变 _知识_关系总数 = 0
定义 可变 _知识_推断次数 = 0

函数 知识_记录节点() { _知识_节点总数 = _知识_节点总数 + 1 }
函数 知识_记录关系() { _知识_关系总数 = _知识_关系总数 + 1 }
函数 知识_记录推断() { _知识_推断次数 = _知识_推断次数 + 1 }

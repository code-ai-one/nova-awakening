//   1. 22个CPU异常入口存根: push补齐→保存→分发→恢复→iretq
//   2. 每异常独立统计计数器
//   3. AI基因: 异常频率追踪+异常模式检测
//   4. 严重等级分类: 可恢复(调试/断点)/严重(GP/PF)/致命(DF/MC)
//   5. 内核态/用户态区分: 从中断帧CS判断
//   6. 致命异常panic: 双重故障/机器检查→内核恐慌
//   7. CR2读取: 缺页异常自动读取故障地址
//   8. 异常链追踪: 记录最近32个异常(AI模式分析)

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./自动扩容.nova")
导入("./中断请求通用.nova")
导入("./字符串替换.nova")
导入("./时钟中枢.nova")
导入("./智能中断预测.nova")

定义 可变 异常计数 = []
定义 可变 异常_已初始化 = 假
定义 可变 异常_总计数 = 0
定义 可变 异常_内核态计数 = 0
定义 可变 异常_用户态计数 = 0
定义 可变 异常_致命计数 = 0
定义 可变 异常_最后向量 = 0
定义 可变 异常_最后错误码 = 0
定义 可变 异常_最后CR2 = 0
定义 可变 异常_错误数 = 0

定义 可变 异常链 = []
定义 异常链_最大 = 32
定义 可变 异常链_写指针 = 0

定义 异常等级_可恢复 = 0
定义 异常等级_警告 = 1
定义 异常等级_严重 = 2
定义 异常等级_致命 = 3

// 异常入口初始化

函数 异常入口_初始化() {
    如果 (异常_已初始化 == 真) { 返回 错误_已存在 }
    异常计数 = []
    定义 可变 i = 0
    当 (i < 32) {
        追加(异常计数, 0)
        i = i + 1
    }
    异常链 = []
    i = 0
    当 (i < 异常链_最大) {
        追加(异常链, [0, 0, 0, 0])
        i = i + 1
    }
    异常链_写指针 = 0
    异常_总计数 = 0
    异常_内核态计数 = 0
    异常_用户态计数 = 0
    异常_致命计数 = 0
    异常_错误数 = 0
    异常_已初始化 = 真
    返回 0
}

// 异常记录(每个入口调用)

函数 异常入口_记录(向量号, 错误码值) {
    异常_总计数 = 异常_总计数 + 1
    异常_最后向量 = 向量号
    异常_最后错误码 = 错误码值
    如果 (异常_已初始化 == 真 && 向量号 < 32) {
        设置(异常计数, 向量号, 异常计数[向量号] + 1)
    }
    // 记录到异常链
    如果 (异常_已初始化 == 真) {
        设置(异常链, 异常链_写指针, [向量号, 错误码值, 读取毫秒(), 0])
        异常链_写指针 = (异常链_写指针 + 1) % 异常链_最大
    }
    // AI: 异常频率追踪
    AI中断_记录(读取毫秒(), 向量号)
}

函数 异常入口_记录_缺页(错误码值) {
    异常入口_记录(14, 错误码值)
    // 读取CR2(缺页故障地址)
    定义 可变 cr2值 = 0
    汇编 { "mov rax, cr2" "mov [rbp-8], rax" }
    异常_最后CR2 = cr2值
    如果 (异常_已初始化 == 真 && 异常链_写指针 > 0) {
        定义 前一个 = (异常链_写指针 - 1 + 异常链_最大) % 异常链_最大
        异常链[前一个][3] = cr2值
    }
}

// 无错误码异常入口 (0-7, 16, 18-20)

函数 异常入口_除零() {
    汇编 { "push 0" "push 0" }
    保存所有寄存器()
    异常入口_记录(0, 0)
    汇编 { "mov rdi, rsp" }
    中断分发_内部(0, 0)
    恢复所有寄存器()
    汇编 { "add rsp, 16" "iretq" }
}


// §5 头部解码 (Nova协议规范 7541 §6)

结构 HPACK解码器 {
    动态表,    // u64 HPACK动态表*
}

结构 HTTP头部 {
    名称,
    名称长度,
    值,
    值长度,
}

函数 HPACK解码器_创建() {
    定义 dec = 堆_分配(HPACK解码器)
    dec.动态表 = HPACK动态表_创建()
    返回 dec
}

函数 HPACK_解码头部块(dec, 数据, 数据长度, 头部列表, 最大头部数) {
    定义 可变 pos = 0
    定义 可变 头部数 = 0

    当 (pos < 数据长度 && 头部数 < 最大头部数) {
        定义 首字节 = 内存_读8(数据 + pos)
        定义 头部 = 头部列表 + 头部数 * 24

        如果 (首字节 & 0x80) {
            // §6.1 索引头部字段: 直接从表中查找
            定义 索引 = HPACK_解码整数(数据, pos, 7)
            如果 (首字节 & 0x7F < 127) { pos = pos + 1 } 否则 { pos = pos + 2 }
            HPACK_从索引填充(dec, 索引, 头部)
            头部数 = 头部数 + 1
        }
        否则 如果 (首字节 & 0x40) {
            // §6.2.1 增量索引的文字头部字段
            定义 索引 = HPACK_解码整数(数据, pos, 6)
            如果 ((首字节 & 0x3F) < 63) { pos = pos + 1 } 否则 { pos = pos + 2 }

            定义 名称buf = 堆_分配(256)
            定义 值buf = 堆_分配(4096)
            定义 可变 名称len = 0
            定义 可变 值len = 0

            如果 (索引 > 0) {
                // 名称来自索引
                HPACK_获取名称(dec, 索引, 名称buf, 名称len)
                pos = HPACK_解码字符串(数据, pos, 值buf, 值len)
            } 否则 {
                // 名称和值都是字面量
                pos = HPACK_解码字符串(数据, pos, 名称buf, 名称len)
                pos = HPACK_解码字符串(数据, pos, 值buf, 值len)
            }

            // 写入头部
            内存_写64(头部, 名称buf)
            内存_写32(头部 + 8, 名称len)
            内存_写64(头部 + 12, 值buf)
            内存_写32(头部 + 20, 值len)

            // 添加到动态表
            HPACK动态表_添加(dec.动态表, 名称buf, 名称len, 值buf, 值len)
            头部数 = 头部数 + 1
        }
        否则 如果 (首字节 & 0x20) {
            // §6.3 动态表大小更新
            定义 新大小 = HPACK_解码整数(数据, pos, 5)
            如果 ((首字节 & 0x1F) < 31) { pos = pos + 1 } 否则 { pos = pos + 2 }
            定义 dt = dec.动态表
            dt.最大大小 = 新大小
            当 (dt.当前大小 > dt.最大大小 && dt.数量 > 0) {
                HPACK动态表_淘汰最旧(dt)
            }
        }
        否则 {
            // §6.2.2/§6.2.3 不索引/不缓存的字面量头部
            定义 不缓存 = (首字节 & 0x10) != 0
            定义 索引 = HPACK_解码整数(数据, pos, 4)
            如果 ((首字节 & 0x0F) < 15) { pos = pos + 1 } 否则 { pos = pos + 2 }

            定义 名称buf = 堆_分配(256)
            定义 值buf = 堆_分配(4096)
            定义 可变 名称len = 0
            定义 可变 值len = 0

            如果 (索引 > 0) {
                HPACK_获取名称(dec, 索引, 名称buf, 名称len)
                pos = HPACK_解码字符串(数据, pos, 值buf, 值len)
            } 否则 {
                pos = HPACK_解码字符串(数据, pos, 名称buf, 名称len)
                pos = HPACK_解码字符串(数据, pos, 值buf, 值len)
            }

            内存_写64(头部, 名称buf)
            内存_写32(头部 + 8, 名称len)
            内存_写64(头部 + 12, 值buf)
            内存_写32(头部 + 20, 值len)
            // 不添加到动态表
            头部数 = 头部数 + 1
        }
    }

    返回 头部数
}

函数 HPACK_从索引填充(dec, 索引, 头部) {
    如果 (索引 <= HPACK_静态表_数量) {
        // 静态表
        定义 名称 = HPACK_静态名称[索引]
        定义 值 = HPACK_静态值[索引]
        内存_写64(头部, 名称)
        内存_写32(头部 + 8, 字节长度(名称))
        内存_写64(头部 + 12, 值)
        内存_写32(头部 + 20, 字节长度(值))
    } 否则 {
        // 动态表 (索引从62开始)
        定义 dt_idx = 索引 - HPACK_静态表_数量 - 1
        定义 entry = HPACK动态表_获取(dec.动态表, dt_idx)
        如果 (entry != 0) {
            内存_写64(头部, 内存_读64(entry))
            内存_写32(头部 + 8, 内存_读32(entry + 8))
            内存_写64(头部 + 12, 内存_读64(entry + 12))
            内存_写32(头部 + 20, 内存_读32(entry + 20))
        }
    }
}

函数 HPACK_获取名称(dec, 索引, 输出, 输出长度) {
    如果 (索引 <= HPACK_静态表_数量) {
        定义 名称 = HPACK_静态名称[索引]
        定义 len = 字节长度(名称)
        内存_复制(输出, 名称, len)
        输出长度 = len
    } 否则 {
        定义 dt_idx = 索引 - HPACK_静态表_数量 - 1
        定义 entry = HPACK动态表_获取(dec.动态表, dt_idx)
        如果 (entry != 0) {
            定义 len = 内存_读32(entry + 8)
            内存_复制(输出, 内存_读64(entry), len)
            输出长度 = len
        }
    }
}

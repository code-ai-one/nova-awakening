外部 ELF加载_解析         // 定义在 核心/进程/ELF加载器.nova

函数 ELF_解析头(路径) {
    定义 文件 = VFS_打开(路径, 0)
    如果 (文件 == 空) { 返回 空 }
    定义 头数据 = VFS_读取(文件, 64)  // ELF64头=64字节
    VFS_关闭(文件)
    如果 (头数据 == 空 || 计数(头数据) < 64) { 返回 空 }
    // 返回 [类型, 机器, 入口点, 程序头偏移, 程序头数]
    定义 类型 = 头数据[16] | (头数据[17] << 8)   // e_type
    定义 机器 = 头数据[18] | (头数据[19] << 8)   // e_machine (0x3E=x86-64)
    定义 入口 = 头数据[24] | (头数据[25] << 8) | (头数据[26] << 16) | (头数据[27] << 24)
    返回 [类型, 机器, 入口]
}

外部 下一个PID             // 定义在 核心/进程/PID分配器.nova

函数 创建进程_Linux(路径, 参数, 环境) {
    // 1. 分配PID
    定义 pid = 下一个PID
    下一个PID = 下一个PID + 1
    // 2. 加载ELF
    定义 头 = ELF_解析头(路径)
    如果 (头 == 空) { 返回 错误_格式 }
    如果 (头[1] != 0x3E) {  // 非x86-64
        内核警告("兼容层: 不支持的架构 " + 整数转十六进制(头[1]))
        返回 错误_格式
    }
    // 3. 设置用户空间栈和参数
    兼容_Linux程序数 = 兼容_Linux程序数 + 1
    内核信息("兼容层: 加载Linux程序 PID=" + 整数转字符串(pid) + " " + 路径)
    返回 pid
}

函数 获取当前用户名() { 返回 "nova" }  // 单用户系统

// 快速用户空间互斥: glibc的Nova线程依赖它
定义 可变 Nova快速锁_等待队列 = []  // [地址, 进程PID]

函数 Nova快速锁_等待(地址, 超时) {
    // 将当前进程加入Nova快速锁等待队列, 挂起
    定义 当前 = 获取当前进程()
    追加(Nova快速锁_等待队列, [地址, 当前])
    // 设置进程为等待状态
    进程_设置状态_兼容(当前, 1)  // TASK_INTERRUPTIBLE
    调度_兼容()
}

函数 Nova快速锁_唤醒(地址, 数量) {
    // 唤醒在此地址等待的进程(最多number个)
    定义 可变 唤醒数 = 0
    定义 可变 i = 0
    当 (i < 计数(Nova快速锁_等待队列) && 唤醒数 < 数量) {
        如果 (Nova快速锁_等待队列[i][0] == 地址) {
            定义 进程 = Nova快速锁_等待队列[i][1]
            进程_设置状态_兼容(进程, 0)  // TASK_RUNNING
            链表_删除(Nova快速锁_等待队列, i)
            唤醒数 = 唤醒数 + 1
        } 否则 {
            i = i + 1
        }
    }
    返回 唤醒数
}

// Nova事件轮询_创建/控制/等待 定义在 文件/Nova事件轮询/Nova事件轮询.nova

定义 可变 兼容_随机种子 = 0x5DEECE66D

函数 随机数() {
    // 线性同余生成器(LCG): Java的java.util.Random
    兼容_随机种子 = (兼容_随机种子 * 0x5DEECE66D + 0xB) & 0xFFFFFFFFFFFF
    返回 (兼容_随机种子 >> 16) & 0x7FFFFFFF
}

函数 读取用户字符串(地址) {
    // 从用户空间地址读取以'\0'结尾的字符串
    如果 (地址 == 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 偏移 = 0
    定义 最大长度 = 4096
    当 (偏移 < 最大长度) {
        定义 字节 = 读取用户字节(地址 + 偏移)
        如果 (字节 == 0) { 返回 结果 }
        结果 = 结果 + 字符(字节)
        偏移 = 偏移 + 1
    }
    返回 结果
}

函数 兼容_进程_设名称(进程, 名称) {
    进程_设名称(进程, 名称)
}

函数 设置权限(路径, 模式) {
    VFS_设置属性(路径, 模式)
}

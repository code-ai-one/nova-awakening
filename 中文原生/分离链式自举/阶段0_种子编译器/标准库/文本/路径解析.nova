
// 获取文件名 (最后一个/或\后的部分)

导入("../基础.nova")

函数 路径_文件名(路径) {
    定义 可变 最后 = -1
    定义 可变 i = 0
    当 (i < 字节长度(路径)) {
        定义 c = 字节取(路径, i)
        如果 (c == 字符_斜杠 或 c == 字符_反斜杠) { 最后 = i }
        i = i + 1
    }
    如果 (最后 == -1) { 返回 路径 }
    返回 子串(路径, 最后 + 1, 字节长度(路径) - 最后 - 1)
}

// 获取目录部分
函数 路径_目录(路径) {
    定义 可变 最后 = -1
    定义 可变 i = 0
    当 (i < 字节长度(路径)) {
        定义 c = 字节取(路径, i)
        如果 (c == 字符_斜杠 或 c == 字符_反斜杠) { 最后 = i }
        i = i + 1
    }
    如果 (最后 == -1) { 返回 "" }
    返回 子串(路径, 0, 最后)
}

// 获取扩展名
函数 路径_扩展名(路径) {
    定义 文件 = 路径_文件名(路径)
    定义 可变 i = 0
    当 (i < 字节长度(文件)) {
        如果 (字节取(文件, i) == 字符_句点) { 最后点 = i }
        i = i + 1
    }
    如果 (最后点 <= 0) { 返回 "" }
    返回 子串(文件, 最后点 + 1, 字节长度(文件) - 最后点 - 1)
}

// 去掉扩展名
函数 路径_无扩展(路径) {
    定义 可变 i = 0
    当 (i < 字节长度(路径)) {
        定义 c = 字节取(路径, i)
        如果 (c == 字符_句点) { 最后点 = i }
        如果 (c == 字符_斜杠 或 c == 字符_反斜杠) { 最后分隔 = i }
        i = i + 1
    }
    如果 (最后点 <= 最后分隔) { 返回 路径 }
    返回 子串(路径, 0, 最后点)
}

// 路径组合
函数 路径_组合(目录, 文件) {
    如果 (字节长度(目录) == 0) { 返回 文件 }
    定义 末字 = 字节取(目录, 字节长度(目录) - 1)
    如果 (末字 == 47 或 末字 == 92) {
        返回 字符串拼接(目录, 文件)
    }
    返回 字符串拼接(字符串拼接(目录, "/"), 文件), 文件
}

// 是否绝对路径
函数 路径_是绝对(路径) {
    如果 (字节长度(路径) == 0) { 返回 0 }
    如果 (字节取(路径, 0) == 字符_斜杠) { 返回 1 }
    如果 (字节长度(路径) >= 3) {
        定义 c1 = 字节取(路径, 1)
        定义 c2 = 字节取(路径, 2)
        如果 (c1 == 58 且 (c2 == 47 或 c2 == 92)) { 返回 1 }
    }
    返回 0
}

// 路径深度 (/之间的段数)
函数 路径_深度(路径) {
    如果 (字节长度(路径) == 0) { 返回 0 }
    定义 可变 深度 = 1
    定义 可变 i = 0
    当 (i < 字节长度(路径)) {
        定义 c = 字节取(路径, i)
        如果 (c == 字符_斜杠 或 c == 字符_反斜杠) { 深度 = 深度 + 1 }
        i = i + 1
    }
    返回 深度
}

// 路径分割

函数 路径_分割段(路径) {
    定义 可变 段列表 = []
    定义 可变 当前 = ""
    定义 可变 i = 0
    当 (i < 字节长度(路径)) {
        定义 c = 字节取(路径, i)
        如果 (c == 字符_斜杠 或 c == 字符_反斜杠) {
            如果 (当前 != "") { 追加(段列表, 当前) }
            当前 = ""
        } 否则 {
            当前 = 当前 + 字符(c)
        }
        i = i + 1
    }
    如果 (当前 != "") { 追加(段列表, 当前) }
    返回 段列表
}

// 路径规范化

函数 路径_规范化(路径) {
    定义 可变 新栈 = []
    如果 (路径 == ".") { 返回 "." }
    如果 (路径 == "") { 返回 "." }
    定义 段 = 路径_分割段(路径)
    定义 可变 绝对 = 路径_是绝对(路径)
    定义 可变 栈 = []
    定义 可变 i = 0
    当 (i < 计数(段)) {
        如果 (段[i] == "..") {
            如果 (计数(栈) > 0 且 栈[计数(栈) - 1] != "..") {
                定义 可变 j = 0
                当 (j < 计数(栈) - 1) { 追加(新栈, 栈[j])  j = j + 1 }
                栈 = 新栈
            } 否则 如果 (绝对 == 假) {
                追加(栈, "..")
            }
        } 否则 如果 (段[i] != ".") {
            追加(栈, 段[i])
        }
        i = i + 1
    }
    // 重建路径
    定义 可变 结果 = ""
    如果 (路径_是绝对(路径)) { 结果 = "/" }
    i = 0
    当 (i < 计数(栈)) {
        如果 (i > 0) { 结果 = 结果 + "/" }
        结果 = 结果 + 栈[i]
        i = i + 1
    }
    如果 (结果 == "") { 返回 "." }
    返回 结果
}

// 路径拼接

函数 路径_拼接(基础, 子路径) {
    如果 (路径_是绝对(子路径)) { 返回 子路径 }
    定义 基长 = 字节长度(基础)
    如果 (基长 == 0) { 返回 子路径 }
    定义 末字符 = 字节取(基础, 基长 - 1)
    如果 (末字符 == 47 或 末字符 == 92) { 返回 基础 + 子路径 }
    返回 基础 + "/" + 子路径
}

函数 路径_拼接多(段列表) {
    如果 (计数(段列表) == 0) { 返回 "" }
    定义 可变 结果 = 段列表[0]
    定义 可变 i = 1
    当 (i < 计数(段列表)) { 结果 = 路径_拼接(结果, 段列表[i])  i = i + 1 }
    返回 结果
}

// 路径比较

函数 路径_相同(a, b) {
    返回 路径_规范化(a) == 路径_规范化(b)
}

函数 路径_是子路径(父, 子) {
    定义 父规 = 路径_规范化(父)
    定义 子规 = 路径_规范化(子)
    如果 (字节长度(子规) <= 字节长度(父规)) { 返回 假 }
    定义 可变 i = 0
    当 (i < 字节长度(父规)) {
        如果 (字节取(父规, i) != 字节取(子规, i)) { 返回 假 }
        i = i + 1
    }
    返回 真
}

定义 可变 _路径_解析数 = 0
定义 可变 _路径_规范化数 = 0

函数 路径_记录解析() { _路径_解析数 = _路径_解析数 + 1 }
函数 路径_记录规范化() { _路径_规范化数 = _路径_规范化数 + 1 }

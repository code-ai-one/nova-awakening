函数 内核智能_注册标签(档, 标签标识) {
    如果 (!内核智能_检查档(档)) { 返回 内核智能_失败(档, "注册标签", "智能档不可用") }
    内核智能_记录(档, "注册标签", [标签标识], "资源调度")

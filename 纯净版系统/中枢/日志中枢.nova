导入("./类型定义.nova")
导入("./错误码.nova")

结构 日志档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    级别,
    信息数,
    告警数,
    错误数,
    调试数,
    追踪数,
    恐慌数,
    订阅数,
    刷新数,
    导出数,
    成功数,
    失败数,
    最近级别,
    最近文本,
    日志表,
    订阅表,
}

结构 日志请求 {
    动作,
    目标,
    参数,
    选项,
}

结构 日志回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 日志摘要 {
    名称,
    级别,
    信息数,
    告警数,
    错误数,
    调试数,
    追踪数,
    恐慌数,
    订阅数,
    刷新数,
    导出数,
    成功数,
    失败数,
    健康,
}

结构 日志项 {
    级别,
    文本,
    来源,
    标签,
    时间,
}

定义 日志级别_信息 = "信息"
定义 日志级别_告警 = "告警"
定义 日志级别_错误 = "错误"
定义 日志级别_调试 = "调试"
定义 日志级别_追踪 = "追踪"
定义 日志级别_恐慌 = "恐慌"

定义 可变 日志账本 = []
定义 可变 日志构建数 = 0
定义 可变 日志总动作 = 0
定义 可变 日志总成功 = 0
定义 可变 日志总失败 = 0

函数 日志中枢_建档(名称) {
    定义 档 = 日志档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.级别 = 日志级别_信息
    档.信息数 = 0
    档.告警数 = 0
    档.错误数 = 0
    档.调试数 = 0
    档.追踪数 = 0
    档.恐慌数 = 0
    档.订阅数 = 0
    档.刷新数 = 0
    档.导出数 = 0
    档.成功数 = 0
    档.失败数 = 0
    档.最近级别 = ""
    档.最近文本 = ""
    档.日志表 = []
    档.订阅表 = []
    返回 档
}

函数 日志中枢_登记(档) {
    追加(日志账本, 档)
    日志构建数 = 日志构建数 + 1
    返回 档
}

函数 日志中枢_完整统计() {
    返回 [
        日志构建数,
        日志总动作,
        日志总成功,
        日志总失败
    ]
}

函数 日志中枢_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 日志回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 日志中枢_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    日志总动作 = 日志总动作 + 1
}

函数 日志中枢_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.恐慌数 > 0) {
        档.最近健康 = "恐慌"
        返回 档.最近健康
    }
    如果 (档.错误数 > 档.信息数 + 档.告警数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (档.错误数 > 0 || 档.告警数 > 0) {
        档.最近健康 = "监视"
        返回 档.最近健康
    }
    档.最近健康 = "运行"
    返回 档.最近健康
}

函数 日志中枢_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (档.名称 == "") { 返回 假 }
    返回 真
}

函数 日志中枢_成功(档, 来源, 数据) {
    档.最近结果 = 数据
    档.成功数 = 档.成功数 + 1
    日志总成功 = 日志总成功 + 1
    档.最近统计 = 日志中枢_完整统计()
    日志中枢_刷新健康(档)
    返回 日志中枢_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 日志中枢_失败(档, 来源, 错因) {
    如果 (档 != 空) {
        档.最近错误 = 错因
        档.失败数 = 档.失败数 + 1
        档.最近统计 = 日志中枢_完整统计()
        日志中枢_刷新健康(档)
    }
    日志总失败 = 日志总失败 + 1
    返回 日志中枢_建回证(真, 假, 来源, 错因, 空, 日志中枢_完整统计())
}

函数 日志中枢_时间戳() {
    返回 "稳定时钟"
}

函数 日志中枢_建项(级别, 文本, 来源, 标签) {
    定义 项 = 日志项 {}
    项.级别 = 级别
    项.文本 = 文本
    项.来源 = 来源
    项.标签 = 标签
    项.时间 = 日志中枢_时间戳()
    返回 项
}

函数 日志中枢_推送(档, 级别, 文本, 来源, 标签) {
    如果 (!日志中枢_检查档(档)) { 返回 日志中枢_失败(档, "推送", "日志档不可用") }
    日志中枢_记录(档, "推送", [级别, 文本, 来源, 标签], "日志中枢")
    定义 项 = 日志中枢_建项(级别, 文本, 来源, 标签)
    追加(档.日志表, 项)
    档.最近级别 = 级别
    档.最近文本 = 文本
    如果 (级别 == 日志级别_信息) { 档.信息数 = 档.信息数 + 1 }
    如果 (级别 == 日志级别_告警) { 档.告警数 = 档.告警数 + 1 }
    如果 (级别 == 日志级别_错误) { 档.错误数 = 档.错误数 + 1 }
    如果 (级别 == 日志级别_调试) { 档.调试数 = 档.调试数 + 1 }
    如果 (级别 == 日志级别_追踪) { 档.追踪数 = 档.追踪数 + 1 }
    如果 (级别 == 日志级别_恐慌) { 档.恐慌数 = 档.恐慌数 + 1 }
    返回 日志中枢_成功(档, "推送", 项)
}

函数 日志中枢_设级别(档, 级别) {
    如果 (!日志中枢_检查档(档)) { 返回 日志中枢_失败(档, "设级别", "日志档不可用") }
    日志中枢_记录(档, "设级别", [级别], "日志中枢")
    档.级别 = 级别
    档.最近级别 = 级别
    返回 日志中枢_成功(档, "设级别", 级别)
}

函数 日志中枢_订阅(档, 名称, 级别) {
    如果 (!日志中枢_检查档(档)) { 返回 日志中枢_失败(档, "订阅", "日志档不可用") }
    日志中枢_记录(档, "订阅", [名称, 级别], "日志中枢")
    追加(档.订阅表, [名称, 级别])
    档.订阅数 = 档.订阅数 + 1
    返回 日志中枢_成功(档, "订阅", [名称, 级别])
}

函数 日志中枢_刷新(档) {
    如果 (!日志中枢_检查档(档)) { 返回 日志中枢_失败(档, "刷新", "日志档不可用") }
    日志中枢_记录(档, "刷新", [], "日志中枢")
    档.刷新数 = 档.刷新数 + 1
    返回 日志中枢_成功(档, "刷新", [计数(档.日志表), 计数(档.订阅表)])
}

函数 日志中枢_导出(档, 数量) {
    如果 (!日志中枢_检查档(档)) { 返回 日志中枢_失败(档, "导出", "日志档不可用") }
    日志中枢_记录(档, "导出", [数量], "日志中枢")
    档.导出数 = 档.导出数 + 1
    如果 (数量 <= 0 || 数量 >= 计数(档.日志表)) {
        返回 日志中枢_成功(档, "导出", 档.日志表)
    }
    定义 起 = 计数(档.日志表) - 数量
    定义 结果 = []
    当 (起 < 计数(档.日志表)) {
        追加(结果, 档.日志表[起])
        起 = 起 + 1
    }
    返回 日志中枢_成功(档, "导出", 结果)
}

函数 日志中枢_信息(档, 文本, 来源, 标签) {
    返回 日志中枢_推送(档, 日志级别_信息, 文本, 来源, 标签)
}

函数 日志中枢_告警(档, 文本, 来源, 标签) {
    返回 日志中枢_推送(档, 日志级别_告警, 文本, 来源, 标签)
}

函数 日志中枢_错误(档, 文本, 来源, 标签) {
    返回 日志中枢_推送(档, 日志级别_错误, 文本, 来源, 标签)
}

函数 日志中枢_调试(档, 文本, 来源, 标签) {
    返回 日志中枢_推送(档, 日志级别_调试, 文本, 来源, 标签)
}

函数 日志中枢_追踪(档, 文本, 来源, 标签) {
    返回 日志中枢_推送(档, 日志级别_追踪, 文本, 来源, 标签)
}

函数 日志中枢_恐慌(档, 文本, 来源, 标签) {
    返回 日志中枢_推送(档, 日志级别_恐慌, 文本, 来源, 标签)
}

函数 日志中枢_最后项(档) {
    如果 (计数(档.日志表) == 0) { 返回 空 }
    返回 档.日志表[计数(档.日志表) - 1]
}

函数 日志中枢_查级别(档, 级别) {
    如果 (!日志中枢_检查档(档)) { 返回 日志中枢_失败(档, "查级别", "日志档不可用") }
    日志中枢_记录(档, "查级别", [级别], "日志中枢")
    定义 结果 = []
    定义 索引 = 0
    当 (索引 < 计数(档.日志表)) {
        定义 项 = 档.日志表[索引]
        如果 (项.级别 == 级别) {
            追加(结果, 项)
        }
        索引 = 索引 + 1
    }
    返回 日志中枢_成功(档, "查级别", 结果)
}

函数 日志中枢_查标签(档, 标签) {
    如果 (!日志中枢_检查档(档)) { 返回 日志中枢_失败(档, "查标签", "日志档不可用") }
    日志中枢_记录(档, "查标签", [标签], "日志中枢")
    定义 结果 = []
    定义 索引 = 0
    当 (索引 < 计数(档.日志表)) {
        定义 项 = 档.日志表[索引]
        如果 (项.标签 == 标签) {
            追加(结果, 项)
        }
        索引 = 索引 + 1
    }
    返回 日志中枢_成功(档, "查标签", 结果)
}

函数 日志中枢_摘要(档) {
    定义 摘要 = 日志摘要 {}
    摘要.名称 = 档.名称
    摘要.级别 = 档.级别
    摘要.信息数 = 档.信息数
    摘要.告警数 = 档.告警数
    摘要.错误数 = 档.错误数
    摘要.调试数 = 档.调试数
    摘要.追踪数 = 档.追踪数
    摘要.恐慌数 = 档.恐慌数
    摘要.订阅数 = 档.订阅数
    摘要.刷新数 = 档.刷新数
    摘要.导出数 = 档.导出数
    摘要.成功数 = 档.成功数
    摘要.失败数 = 档.失败数
    摘要.健康 = 日志中枢_刷新健康(档)
    返回 摘要
}

函数 日志中枢_初始化(档) {
    如果 (!日志中枢_检查档(档)) { 返回 日志中枢_失败(档, "初始化", "日志档不可用") }
    日志中枢_记录(档, "初始化", [], "日志中枢")
    档.日志表 = []
    档.订阅表 = []
    档.信息数 = 0
    档.告警数 = 0
    档.错误数 = 0
    档.调试数 = 0
    档.追踪数 = 0
    档.恐慌数 = 0
    档.订阅数 = 0
    档.刷新数 = 0
    档.导出数 = 0
    档.是否初始化 = 真
    日志中枢_信息(档, "日志中枢已启动", "日志中枢", "启动")
    日志中枢_订阅(档, "主循环", 日志级别_信息)
    日志中枢_订阅(档, "安全域", 日志级别_告警)
    日志中枢_订阅(档, "故障域", 日志级别_错误)
    返回 日志中枢_成功(档, "初始化", "已初始化")
}

函数 日志中枢_自检(档) {
    如果 (!日志中枢_检查档(档)) { 返回 假 }
    如果 (日志中枢_初始化(档).已成 == 假) { 返回 假 }
    如果 (日志中枢_调试(档, "白璃外衣开始刷新", "界面", "白璃").已成 == 假) { 返回 假 }
    如果 (日志中枢_追踪(档, "控制协议已接入", "控核", "协议").已成 == 假) { 返回 假 }
    如果 (日志中枢_告警(档, "检测到旧路径导入", "导入修复", "导入").已成 == 假) { 返回 假 }
    如果 (日志中枢_错误(档, "断导入已转入修复队列", "审计", "修复").已成 == 假) { 返回 假 }
    如果 (日志中枢_查级别(档, 日志级别_错误).已成 == 假) { 返回 假 }
    如果 (日志中枢_查标签(档, "协议").已成 == 假) { 返回 假 }
    如果 (日志中枢_导出(档, 4).已成 == 假) { 返回 假 }
    如果 (日志中枢_刷新(档).已成 == 假) { 返回 假 }
    如果 (日志中枢_恐慌(档, "自检恐慌路径演练", "日志中枢", "演练").已成 == 假) { 返回 假 }
    返回 真
}

函数 日志中枢_处理(档, 请求) {
    如果 (请求 == 空) { 返回 日志中枢_失败(档, "处理", "请求为空") }
    如果 (请求.动作 == "初始化") { 返回 日志中枢_初始化(档) }
    如果 (请求.动作 == "设级别") { 返回 日志中枢_设级别(档, 请求.参数[0]) }
    如果 (请求.动作 == "信息") { 返回 日志中枢_信息(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "告警") { 返回 日志中枢_告警(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "错误") { 返回 日志中枢_错误(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "调试") { 返回 日志中枢_调试(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "追踪") { 返回 日志中枢_追踪(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "恐慌") { 返回 日志中枢_恐慌(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "订阅") { 返回 日志中枢_订阅(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "刷新") { 返回 日志中枢_刷新(档) }
    如果 (请求.动作 == "导出") { 返回 日志中枢_导出(档, 请求.参数[0]) }
    如果 (请求.动作 == "查级别") { 返回 日志中枢_查级别(档, 请求.参数[0]) }
    如果 (请求.动作 == "查标签") { 返回 日志中枢_查标签(档, 请求.参数[0]) }
    如果 (请求.动作 == "摘要") { 返回 日志中枢_成功(档, "摘要", 日志中枢_摘要(档)) }
    返回 日志中枢_失败(档, "处理", "未知动作")
}

定义 可变 AI_日志中枢_调用数 = 0
定义 可变 AI_日志中枢_异常数 = 0

函数 AI_日志中枢_监控() {
    AI_日志中枢_调用数 = AI_日志中枢_调用数 + 1
    返回 AI_日志中枢_异常数 == 0
}

函数 AI_日志中枢_健康检查() {
    如果 (AI_日志中枢_调用数 > 0 && AI_日志中枢_异常数 * 100 / AI_日志中枢_调用数 > 10) {
        返回 假
    }
    返回 真
}

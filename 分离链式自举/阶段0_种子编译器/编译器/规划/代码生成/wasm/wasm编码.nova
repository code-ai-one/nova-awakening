函数 wasm_空时分支(标签) { 定义 r = [0xD5] 定义 e = wasm_编码_uleb128(标签)
 定义 可变 i = 0 当 (i < 计数(e)) { 追加(r, e[i]) i = i + 1 } 返回 r }
函数 wasm_非空时分支(标签) { 定义 r = [0xD6] 定义 e = wasm_编码_uleb128(标签)
 定义 可变 i = 0 当 (i < 计数(e)) { 追加(r, e[i]) i = i + 1 } 返回 r }
// call_ref / return_call_ref
函数 wasm_引用调用(类型) { 定义 r = [0x14] 定义 e = wasm_编码_uleb128(类型)
 定义 可变 i = 0 当 (i < 计数(e)) { 追加(r, e[i]) i = i + 1 } 返回 r }
函数 wasm_返回引用调用(类型) { 定义 r = [0x15] 定义 e = wasm_编码_uleb128(类型)
 定义 可变 i = 0 当 (i < 计数(e)) { 追加(r, e[i]) i = i + 1 } 返回 r }

// catch_all
函数 wasm_捕获全部() { 返回 [0x19] }
// delegate label
函数 wasm_委托(标签) { 定义 r = [0x18] 定义 e = wasm_编码_uleb128(标签)
 定义 可变 i = 0 当 (i < 计数(e)) { 追加(r, e[i]) i = i + 1 } 返回 r }
// throw_ref (exnref提案)
函数 wasm_抛出引用() { 返回 [0x0A] }
// try_table (新异常处理)
函数 wasm_尝试表(块类型) { 返回 [0x1F, 块类型] }

// i64.atomic.load8_u
函数 wasm_整64_atomic_load8_u(对齐, 偏移) { 定义 r = [0xFE, 0x14] 追加(r, 对齐) 追加(r, 偏移) 返回 r }

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("./端口输入.nova")

// 6. 科幻全息AI人物 — 活在桌面上的真实AI角色
// 完整人体骨骼 · 多帧行走动画 · 眼球追踪 · 眨眼 · 口型
// 自主走动 · 粒子拖尾 · 全息扫描线 · 呼吸脉动
// 他是AI的化身, 活在桌面里随意走动, 自演化各种动作

打印("[渲染] 科幻全息AI人物 (多帧动画)...")

定义 全息色 = 0x004FC3F7   // NovaHolo青蓝主色
定义 全息暗 = 0x001A4060   // 暗青(深层线条)
定义 全息亮 = 0x0088EEFF   // 亮青(高光/关节)
定义 全息紫 = 0x00AB47BC   // NovaHolo紫色辅色
定义 全息粉 = 0x00F06292   // NovaHolo粉色强调
定义 sin12 = [0, 50, 87, 100, 87, 50, 0, -50, -87, -100, -87, -50]
定义 cos12 = [100, 87, 50, 0, -50, -87, -100, -87, -50, 0, 50, 87]

// 行走4帧: 每帧关节偏移不同, 模拟行走周期
// [左肩X,左肩Y, 左肘X,左肘Y, 左手X,左手Y,
//  右肩X,右肩Y, 右肘X,右肘Y, 右手X,右手Y,
//  左胯X,左胯Y, 左膝X,左膝Y, 左脚X,左脚Y,
//  右胯X,右胯Y, 右膝X,右膝Y, 右脚X,右脚Y]

// 帧0: 站立
定义 骨骼0 = [-30,65, -38,95, -35,120,  30,65, 38,95, 35,120,  -12,140, -15,185, -18,225,  12,140, 15,185, 18,225]
// 帧1: 左脚前迈
定义 骨骼1 = [-28,64, -42,92, -45,115,  32,66, 35,98, 30,125,  -14,140, -25,180, -35,218,  10,140, 8,188, 5,228]
// 帧2: 双脚交汇
定义 骨骼2 = [-30,65, -36,96, -32,122,  30,65, 36,96, 32,122,  -10,140, -12,186, -14,226,  10,140, 12,186, 14,226]
// 帧3: 右脚前迈
定义 骨骼3 = [-32,66, -35,98, -30,125,  28,64, 42,92, 45,115,  -10,140, -8,188, -5,228,  14,140, 25,180, 35,218]

定义 骨骼帧 = [骨骼0, 骨骼1, 骨骼2, 骨骼3]

定义 人x = 680
定义 人y = 180

// 底座12点
定义 可变 ba = 0
当 (ba < 12) {
    定义 bpx = 人x + sin12[ba] * 70 / 100
    定义 bpy = 人y + 230 + cos12[ba] * 18 / 100
    如果 (bpx > 100 && bpx < 屏宽 && bpy < 任务y) { 内存写32(LFB + bpy * 行字节 + bpx * 4, 全息亮) }
    ba = ba + 1
}
// 头部轮廓12点
定义 头cx = 人x
定义 头cy = 人y + 25
定义 可变 ho = 0
当 (ho < 12) {
    定义 hox = 头cx + sin12[ho] * 30 / 100
    定义 hoy = 头cy + cos12[ho] * 30 / 100
    如果 (hox > 100 && hox < 屏宽 && hoy > 28) { 内存写32(LFB + hoy * 行字节 + hox * 4, 全息亮) }
    ho = ho + 1
}
// 左眼 (6x5块)
定义 可变 ey = 0
当 (ey < 5) {
    定义 可变 ex = 0
    当 (ex < 6) {
        内存写32(LFB + (头cy - 4 + ey) * 行字节 + (头cx - 12 + ex) * 4, 全息亮)
        内存写32(LFB + (头cy - 4 + ey) * 行字节 + (头cx + 6 + ex) * 4, 全息亮)
        ex = ex + 1
    }
    ey = ey + 1
}
// 瞳孔 (2x2)
内存写32(LFB + (头cy - 3) * 行字节 + (头cx - 10) * 4, 0x0000AADD)
内存写32(LFB + (头cy - 2) * 行字节 + (头cx - 10) * 4, 0x0000AADD)
内存写32(LFB + (头cy - 3) * 行字节 + (头cx + 8) * 4, 0x0000AADD)
内存写32(LFB + (头cy - 2) * 行字节 + (头cx + 8) * 4, 0x0000AADD)
// 微笑嘴巴 (20点弧线)
定义 可变 嘴i = 0
当 (嘴i < 20) {
    定义 嘴弧 = (嘴i - 10) * (嘴i - 10) / 30
    内存写32(LFB + (头cy + 12 + 嘴弧) * 行字节 + (头cx - 10 + 嘴i) * 4, 全息色)
    嘴i = 嘴i + 1
}
// 脖子 (8行)
定义 可变 颈y = 0
当 (颈y < 8) {
    内存写32(LFB + (头cy + 30 + 颈y) * 行字节 + 人x * 4, 全息色)
    内存写32(LFB + (头cy + 30 + 颈y) * 行字节 + (人x + 1) * 4, 全息色)
    颈y = 颈y + 1
}
// 躯干左右边线 (每3行画一点, 75行→25点)
定义 可变 躯y = 0
当 (躯y < 75) {
    定义 半宽 = 22 + 躯y / 8
    内存写32(LFB + (人y + 63 + 躯y) * 行字节 + (人x - 半宽) * 4, 全息色)
    内存写32(LFB + (人y + 63 + 躯y) * 行字节 + (人x + 半宽) * 4, 全息色)
    躯y = 躯y + 3
}
// 手臂骨骼线 (各5点)
定义 可变 at = 0
当 (at <= 10) {
    // 左臂
    内存写32(LFB + (人y + 65 + at * 3) * 行字节 + (人x - 30 - at) * 4, 全息色)
    内存写32(LFB + (人y + 95 + at * 2) * 行字节 + (人x - 40 + at / 2) * 4, 全息色)
    // 右臂
    内存写32(LFB + (人y + 65 + at * 3) * 行字节 + (人x + 30 + at) * 4, 全息色)
    内存写32(LFB + (人y + 95 + at * 2) * 行字节 + (人x + 40 - at / 2) * 4, 全息色)
    at = at + 2
}
// 关节发光
内存写32(LFB + (人y + 95) * 行字节 + (人x - 40) * 4, 全息亮)
内存写32(LFB + (人y + 95) * 行字节 + (人x + 40) * 4, 全息亮)
内存写32(LFB + (人y + 115) * 行字节 + (人x - 35) * 4, 全息亮)
内存写32(LFB + (人y + 115) * 行字节 + (人x + 35) * 4, 全息亮)
// 腿骨骼线 (各5点)
定义 可变 lt = 0
当 (lt <= 10) {
    // 左腿
    内存写32(LFB + (人y + 140 + lt * 4) * 行字节 + (人x - 12 - lt / 3) * 4, 全息色)
    内存写32(LFB + (人y + 185 + lt * 4) * 行字节 + (人x - 18 + lt / 4) * 4, 全息色)
    // 右腿
    内存写32(LFB + (人y + 140 + lt * 4) * 行字节 + (人x + 12 + lt / 3) * 4, 全息色)
    内存写32(LFB + (人y + 185 + lt * 4) * 行字节 + (人x + 18 - lt / 4) * 4, 全息色)
    lt = lt + 2
}
// 膝/脚发光
内存写32(LFB + (人y + 185) * 行字节 + (人x - 15) * 4, 全息亮)
内存写32(LFB + (人y + 185) * 行字节 + (人x + 15) * 4, 全息亮)
内存写32(LFB + (人y + 225) * 行字节 + (人x - 18) * 4, 全息紫)
内存写32(LFB + (人y + 225) * 行字节 + (人x + 18) * 4, 全息紫)
// 环绕粒子 (20点)
定义 可变 pp = 0
当 (pp < 20) {
    定义 pai = (pp * 30) % 360 / 30
    如果 (pai > 11) { pai = 11 }
    定义 pr = 60 + pp * 3
    定义 ppx = 人x + sin12[pai] * pr / 100
    定义 ppy = 人y + 120 + cos12[pai] * (pr / 3) / 100
    定义 可变 ppc = 全息色
    如果 (pp % 4 == 0) { ppc = 全息亮 }
    如果 (pp % 7 == 0) { ppc = 全息粉 }
    如果 (ppx > 100 && ppx < 屏宽 && ppy > 28 && ppy < 任务y) { 内存写32(LFB + ppy * 行字节 + ppx * 4, ppc) }
    pp = pp + 1
}
// 说话气泡 (只画边框, 不填充内部)
定义 气泡x2 = 人x + 50
定义 气泡y2 = 人y - 20
定义 气泡w2 = 150
定义 气泡h2 = 40
定义 可变 gbi2 = 0
当 (gbi2 < 气泡w2) {
    如果 (气泡x2 + gbi2 < 屏宽) {
        内存写32(LFB + 气泡y2 * 行字节 + (气泡x2 + gbi2) * 4, 全息色)
        内存写32(LFB + (气泡y2 + 气泡h2) * 行字节 + (气泡x2 + gbi2) * 4, 全息色)
    }
    gbi2 = gbi2 + 3  // 每3像素画1点(虚线效果)
}
定义 可变 gbj2 = 0
当 (gbj2 < 气泡h2) {
    内存写32(LFB + (气泡y2 + gbj2) * 行字节 + 气泡x2 * 4, 全息色)
    如果 (气泡x2 + 气泡w2 < 屏宽) { 内存写32(LFB + (气泡y2 + gbj2) * 行字节 + (气泡x2 + 气泡w2) * 4, 全息色) }
    gbj2 = gbj2 + 3
}

// 气泡内文字 "Hello! I am Nova AI" (位图字体)
定义 气泡文字 = [72,101,108,108,111,33,32,78,111,118,97,32,65,73]  // "Hello! Nova AI"
定义 可变 gt_i = 0
当 (gt_i < 14) {
    定义 gt_idx = (气泡文字[gt_i] - 32) * 8
    如果 (gt_idx >= 0 && gt_idx < 760) {
        定义 可变 gt_r = 0
        当 (gt_r < 8) {
            定义 gt_rd = 字体[gt_idx + gt_r]
            定义 可变 gt_b = 0
            当 (gt_b < 8) {
                如果 ((gt_rd >> (7 - gt_b)) & 1) {
                    定义 gtpx = 气泡x2 + 8 + gt_i * 9 + gt_b
                    如果 (gtpx < 屏宽) {
                        内存写32(LFB + (气泡y2 + 16 + gt_r) * 行字节 + gtpx * 4, 全息亮)
                    }
                }
                gt_b = gt_b + 1
            }
            gt_r = gt_r + 1
        }
    }
    gt_i = gt_i + 1
}

打印("[渲染] 全息AI人物 OK (单帧优化: 头+眼+嘴+躯干+臂+腿+粒子+气泡文字)")

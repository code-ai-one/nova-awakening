导入("../../标准库/基础.nova")

// Nova · IR层 · 窥孔优化器 (Peephole Optimizer)
// 识别并替换代价高的指令序列为等价低代价序列
// 窗口大小：2-4条指令，覆盖 x86-64 常见模式
// 规则分类：冗余消除 / 移位替代 / 零置 / 合并 / 条件化简

// 指令类型常量（与代码生成器对齐）
定义 指令_MOV_RR = 1     // mov reg, reg
定义 指令_MOV_RI = 2     // mov reg, imm
定义 指令_MOV_RM = 3     // mov reg, [mem]
定义 指令_MOV_MR = 4     // [mem] = reg
定义 指令_ADD_RI = 5     // add reg, imm
定义 指令_ADD_RR = 6     // add reg, reg
定义 指令_SUB_RI = 7     // sub reg, imm
定义 指令_SUB_RR = 8     // sub reg, reg
定义 指令_MUL_RR = 9     // imul reg, reg
定义 指令_MUL_RI = 10    // imul reg, reg, imm
定义 指令_SHL_RI = 11    // shl reg, imm
定义 指令_SHR_RI = 12    // shr reg, imm
定义 指令_XOR_RR = 13    // xor reg, reg
定义 指令_AND_RI = 14    // and reg, imm
定义 指令_OR_RI  = 15    // or  reg, imm
定义 指令_TEST_RR = 16   // test reg, reg
定义 指令_CMP_RI = 17    // cmp reg, imm
定义 指令_CMP_RR = 18    // cmp reg, reg
定义 指令_LEA    = 19    // lea reg, [base+idx*scale+disp]
定义 指令_PUSH   = 20    // push reg
定义 指令_POP    = 21    // pop reg
定义 指令_NOP    = 0     // 占位/已删除

// 统计
定义 可变 _窥孔_优化数 = 0
定义 可变 _窥孔_冗余mov = 0
定义 可变 _窥孔_强度削减 = 0
定义 可变 _窥孔_零置优化 = 0
定义 可变 _窥孔_合并优化 = 0

函数 窥孔_重置统计() {
    _窥孔_优化数 = 0
    _窥孔_冗余mov = 0
    _窥孔_强度削减 = 0
    _窥孔_零置优化 = 0
    _窥孔_合并优化 = 0
}

// 指令结构：[类型, 目标寄存器, 源寄存器/立即数, 附加]
函数 窥孔_指令(类型, 目标, 源, 附加) {
    返回 [类型, 目标, 源, 附加]
}
函数 窥孔_指令_类型(i) { 返回 i[0] }
函数 窥孔_指令_目标(i) { 返回 i[1] }
函数 窥孔_指令_源(i)   { 返回 i[2] }
函数 窥孔_指令_附加(i) { 返回 i[3] }

// 规则1: 冗余 mov reg, reg（同寄存器自赋值）→ NOP
函数 窥孔_规则_冗余mov(i) {
    如果 (窥孔_指令_类型(i) == 指令_MOV_RR) {
        如果 (窥孔_指令_目标(i) == 窥孔_指令_源(i)) {
            _窥孔_冗余mov = _窥孔_冗余mov + 1
            _窥孔_优化数 = _窥孔_优化数 + 1
            返回 窥孔_指令(指令_NOP, 0 , 0, 0)
        }
    }
    返回 空
}

// 规则2: add reg, 0 → NOP
函数 窥孔_规则_add零(i) {
    如果 (窥孔_指令_类型(i) == 指令_ADD_RI 且 窥孔_指令_源(i) == 0) {
        _窥孔_优化数 = _窥孔_优化数 + 1
        返回 窥孔_指令(指令_NOP, 0 , 0, 0)
    }
    返回 空
}

// 规则3: sub reg, 0 → NOP
函数 窥孔_规则_sub零(i) {
    如果 (窥孔_指令_类型(i) == 指令_SUB_RI 且 窥孔_指令_源(i) == 0) {
        _窥孔_优化数 = _窥孔_优化数 + 1
        返回 窥孔_指令(指令_NOP, 0 , 0, 0)
    }
    返回 空
}

// 规则4: mul reg, 1 → NOP
函数 窥孔_规则_mul一(i) {
    如果 (窥孔_指令_类型(i) == 指令_MUL_RI 且 窥孔_指令_源(i) == 1) {
        _窥孔_优化数 = _窥孔_优化数 + 1
        返回 窥孔_指令(指令_NOP, 0 , 0, 0)
    }
    返回 空
}

// 规则5: xor reg, reg → 零置（高效清零）
// xor rax, rax 比 mov rax, 0 更短（3字节 vs 5字节）
函数 窥孔_规则_xor清零(i) {
    如果 (窥孔_指令_类型(i) == 指令_XOR_RR) {
        如果 (窥孔_指令_目标(i) == 窥孔_指令_源(i)) {
            _窥孔_零置优化 = _窥孔_零置优化 + 1
            _窥孔_优化数 = _窥孔_优化数+ 1
            返回 i  // 已是最优形式，保留
        }
    }
    返回 空
}

// 规则6: mov reg, 0 → xor reg, reg（3字节替代5字节）
函数 窥孔_规则_mov零转xor(i) {
    如果 (窥孔_指令_类型(i) == 指令_MOV_RI 且 窥孔_指令_源(i) == 0) {
        定义 reg = 窥孔_指令_目标(i)
        _窥孔_零置优化 = _窥孔_零置优化 + 1
        _窥孔_优化数 = _窥孔_优化数 + 1
        返回 窥孔_指令(指令_XOR_RR,  reg,  reg, 0)
    }
    返回 空
}

// 规则7: mul reg, 2^n → shl reg, n
函数 窥孔_规则_mul转shl(i) {
    如果 (窥孔_指令_类型(i) != 指令_MUL_RI) { 返回 空 }
    定义 imm = 窥孔_指令_源(i)
    如果 (imm <= 1) { 返回 空 }
    // 检查是否为2的幂
    如果 ((imm & (imm - 1)) == 0) {
        // 计算指数
        定义 可变 v = imm
        当 (v > 1) { v = v >> 1 exp = exp + 1 }
        _窥孔_强度削减 = _窥孔_强度削减 + 1
        _窥孔_优化数 = _窥孔_优化数 + 1
        返回 窥孔_指令(指令_SHL_RI,  窥孔_指令_目标(i),  exp, 0)
    }
    返回 空
}

// 规则8: 双窗口 — push reg; pop reg → NOP NOP
函数 窥孔_规则_push_pop(i1, i2) {
    如果 (窥孔_指令_类型(i1) == 指令_PUSH 且 
        窥孔_指令_类型(i2) == 指令_POP) {
        如果 (窥孔_指令_目标(i1) == 窥孔_指令_目标(i2)) {
            _窥孔_冗余mov = _窥孔_冗余mov + 1
            _窥孔_优化数 = _窥孔_优化数+ 2
            返回 [窥孔_指令(指令_NOP, 0, 0, 0), 窥孔_指令(指令_NOP, 0, 0, 0)]
        }
    }
    返回 空
}

// 规则9: 双窗口 — mov A,B; mov B,A → mov A,B（消除回写）
函数 窥孔_规则_往返mov(i1, i2) {
    如果 (窥孔_指令_类型(i1) == 指令_MOV_RR 且 
        窥孔_指令_类型(i2) == 指令_MOV_RR) {
        // i1: A=B; i2: B=A → 保留i1，删i2
        如果 (窥孔_指令_目标(i1) == 窥孔_指令_源(i2) 且 
            窥孔_指令_源(i1) == 窥孔_指令_目标(i2)) {
            _窥孔_冗余mov = _窥孔_冗余mov + 1
            _窥孔_优化数 = _窥孔_优化数 + 1
            返回 [i1, 窥孔_指令(指令_NOP, 0, 0, 0)]
        }
    }
    返回 空
}

// 规则10: shl+add → lea 合并（x*2+y → lea [x+x]）
// 这里返回建议而非直接修改，由代码生成器决定
函数 窥孔_建议_lea合并(shl指令, add指令) {
    如果 (窥孔_指令_类型(shl指令) == 指令_SHL_RI 且 
        窥孔_指令_类型(add指令) == 指令_ADD_RR) {
        如果 (窥孔_指令_附加(shl指令) == 1) {  // shl reg, 1 → reg*2
            _窥孔_合并优化 = _窥孔_合并优化 + 1
            返回 真
        }
    }
    返回 假
}

// 主优化入口（对指令列表做单遍窥孔扫描）
// 输入：指令列表（每元素是窥孔_指令结构）
// 输出：优化后的指令列表
函数 窥孔_优化(代码) {
    如果 (代码 == 空 或 计数(代码) == 0) { 返回 代码 }
    定义 可变 结果 = []
    定义 n = 计数(代码)
    定义 可变 i = 0
    当 (i < n) {
        定义 当前 = 代码[i]

        // 双窗口规则（需要下一条指令）
        如果 (i + 1 < n) {
            定义 下一条 = 代码[i + 1]

            定义 push_pop = 窥孔_规则_push_pop(当前, 下一条)
            如果 (push_pop != 空) {
                追加(结果, push_pop[0])
                追加(结果, push_pop[1])
                i = i + 2
                继续
            }

            定义 往返 = 窥孔_规则_往返mov(当前, 下一条)
            如果 (往返 != 空) {
                追加(结果, 往返[0])
                追加(结果, 往返[1])
                i = i + 2
                继续
            }
        }

        // 单条规则（按优先级顺序）
        定义 可变 优化结果 = 空
        如果 (优化结果 == 空) { 优化结果 = 窥孔_规则_冗余mov(当前) }
        如果 (优化结果 == 空) { 优化结果 = 窥孔_规则_add零(当前) }
        如果 (优化结果 == 空) { 优化结果 = 窥孔_规则_sub零(当前) }
        如果 (优化结果 == 空) { 优化结果 = 窥孔_规则_mul一(当前) }
        如果 (优化结果 == 空) { 优化结果 = 窥孔_规则_mul转shl(当前) }
        如果 (优化结果 == 空) { 优化结果 = 窥孔_规则_mov零转xor(当前) }

        如果 (优化结果 != 空) {
            追加(结果, 优化结果)
        } 否则 {
            追加(结果, 当前)
        }
        i = i + 1
    }
    返回 结果
}

函数 窥孔_报告() {
    返回 [_窥孔_优化数, _窥孔_冗余mov, _窥孔_强度削减,
           _窥孔_零置优化, _窥孔_合并优化]
}

函数 窥孔_统计_总数() { 返回 _窥孔_优化数 }
函数 窥孔_统计_冗余mov() { 返回 _窥孔_冗余mov }
函数 窥孔_统计_强度削减() { 返回 _窥孔_强度削减 }

// 中文标识符字符串常量合并（实验发现：汉字UTF-8=3字节/字，重复存储代价大）
// 窥孔规则：相邻两条加载同一中文字符串的指令 → 合并为一条加载+复制
定义 可变 _窥孔_字符串合并数 = 0

函数 窥孔_规则_字符串合并(指令A, 指令B) {
    // 如果两条指令都是加载同一字符串常量，合并为一条
    如果 (指令A == 空 或 指令B == 空) { 返回 空 }
    如果 (计数(指令A) < 2 或 计数(指令B) < 2) { 返回 空 }
    // 检查两条PUSH常量指令是否加载同一字符串
    定义 A_操作码 = 指令A[0]
    定义 B_操作码 = 指令B[0]
    // 匹配所有常量加载操作码: PUSH_I64(0x01), PUSH_F64(0x02), PUSH_STR(0x03)
    如果 (A_操作码 == B_操作码 且 A_操作码 >= 0x01 且 A_操作码 <= 0x03) {
        如果 (指令A[1] == 指令B[1]) {
            _窥孔_字符串合并数 = _窥孔_字符串合并数 + 1
            _窥孔_优化数 = _窥孔_优化数 + 1
            返回 [指令A[0], 指令A[1], "字符串已合并"]
        }
    }
    返回 空
}

// 原始字节级窥孔（直接操作代码缓冲区，无需IR）
// 扫描 代码[起始..结束) 区间，就地替换已知低效指令模式
// 返回优化的指令数
函数 窥孔_后处理_字节(起始, 结束) {
    定义 可变 优化数 = 0
    定义 可变 i = 起始
    当 (i + 6 < 结束) {
        // Pattern 1: mov r64, 0 (REX.W=72 C7=199 ModRM=192+reg 0 0 0 0)
        //         → xor r32,r32 (31=49 ModRM) + 5-byte NOP (15 31 68 0 0)
        // xor r32,r32 自动零扩展到r64, 且更新flags=已知行为
        如果 (代码[i] == 72 且 代码[i+1] == 199 且 代码[i+3] == 0 且 代码[i+4] == 0 且 代码[i+5] == 0 且 代码[i+6] == 0) {
            定义 modrm = 代码[i+2]
            如果 (modrm >= 192 且 modrm <= 199) {
                定义 寄存器号 = modrm - 192
                如果 (寄存器号 != 4 且 寄存器号 != 5) {
                    代码[i]   = 49
                    代码[i+1] = 192 + 寄存器号 * 9
                    代码[i+2] = 15
                    代码[i+3] = 31
                    代码[i+4] = 68
                    代码[i+5] = 0
                    代码[i+6] = 0
                    优化数 = 优化数 + 1
                    _窥孔_零置优化 = _窥孔_零置优化 + 1
                    _窥孔_优化数 = _窥孔_优化数 + 1
                    i = i + 7
                    继续
                }
            }
        }
        // Pattern 2: mov reg, reg (self-move, 72 137 192+reg*9) → 3-byte NOP (15 31 0)
        如果 (代码[i] == 72 且 代码[i+1] == 137) {
            定义 modrm2 = 代码[i+2]
            如果 (modrm2 >= 192 且 modrm2 <= 255) {
                定义 _源 = (modrm2 - 192) / 8
                定义 _目标 = modrm2 - 192 - _源 * 8
                如果 (_源 == _目标) {
                    代码[i]   = 15
                    代码[i+1] = 31
                    代码[i+2] = 0
                    优化数 = 优化数 + 1
                    _窥孔_冗余mov = _窥孔_冗余mov + 1
                    _窥孔_优化数 = _窥孔_优化数 + 1
                    i = i + 3
                    继续
                }
            }
        }
        // Pattern 3: add rsp, 0 (72 131 196 0) → 4-byte NOP (15 31 64 0)
        如果 (i + 3 < 结束 且 代码[i] == 72 且 代码[i+1] == 131 且 代码[i+2] == 196 且 代码[i+3] == 0) {
            代码[i]   = 15
            代码[i+1] = 31
            代码[i+2] = 64
            代码[i+3] = 0
            优化数 = 优化数 + 1
            _窥孔_优化数 = _窥孔_优化数 + 1
            i = i + 4
            继续
        }
        // Pattern 4: sub rsp, 0 (72 131 236 0) → 4-byte NOP
        如果 (i + 3 < 结束 且 代码[i] == 72 且 代码[i+1] == 131 且 代码[i+2] == 236 且 代码[i+3] == 0) {
            代码[i]   = 15
            代码[i+1] = 31
            代码[i+2] = 64
            代码[i+3] = 0
            优化数 = 优化数 + 1
            _窥孔_优化数 = _窥孔_优化数 + 1
            i = i + 4
            继续
        }
        i = i + 1
    }
    返回 优化数
}

// 估算中文标识符在IR中的字节开销
// 每个汉字占3字节UTF-8，中文函数名如"排序算法"=12字节 vs ASCII 4字节
函数 窥孔_中文标识符开销估算(标识符名) {
    如果 (计数(标识符名) == 0) { 返回 0 }
    定义 可变 字节数 = 0
    定义 可变 i = 0
    当 (i < 计数(标识符名)) {
        定义 cp = 字符码(子串(标识符名, i, 1), 0)
        如果 (cp >= 19968 且 cp <= 40959) {
            字节数 = 字节数 + 3  // CJK汉字 = 3字节UTF-8
        } 否则 如果 (cp > 127) {
            字节数 = 字节数 + 2  // 其他多字节Unicode = 2字节
        } 否则 {
            字节数 = 字节数 + 1  // ASCII = 1字节
        }
        i = i + 1
    }
    返回 字节数
}

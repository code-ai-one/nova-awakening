函数 编译_内建前半(名, 参数) {
    如果 (名 == "计数") {
        返回 编译_处理__计数_(参数)
    }
    如果 (名 == "追加") {
        返回 编译_处理__追加_(参数)
    }
    如果 (名 == "子串") {
        返回 编译_处理__子串_(参数)
    }
    如果 (名 == "字节取") {
        返回 编译_处理__字节取_(参数)
    }
    如果 (名 == "字节长度") {
        返回 编译_处理__字节长度_(参数)
    }
    如果 (名 == "编码") {
        返回 编译_处理__编码_(参数)
    }
    如果 (名 == "字符") {
        返回 编译_处理__字符_(参数)
    }
    如果 (名 == "转字符串") {
        返回 编译_处理__转字符串_(参数)
    }
    如果 (名 == "缓冲区") {
        返回 编译_处理__缓冲区_(参数)
    }
    如果 (名 == "缓冲写" 或 名 == "缓冲写16" 或 名 == "缓冲写32" 或 名 == "缓冲写64") {
        编译_表达式(参数[0])
        发射(0x50)
        编译_表达式(参数[1])
        发射(0x50)
        编译_表达式(参数[2])
        发射组([0x49, 0x89, 0xC0])
        发射(0x5A)
        发射(0x59)
        发射_规范空值_rcx()
        修正表_追加记录(修正表, "call", 代码位 + 1, 名)
        发射(0xE8)
        发射32(0)
        返回 1
    }
    如果 (名 == "缓冲读") {
        返回 编译_处理__缓冲读_(参数)
    }
    如果 (名 == "插入") {
        返回 编译_处理__插入_(参数)
    }
    如果 (名 == "删除") {
        返回 编译_处理__删除_(参数)
    }
    如果 (名 == "字符串拼接") {
        返回 编译_处理__字符串拼接_(参数)
    }
    如果 (名 == "拼接") {
        返回 编译_处理__拼接_(参数)
    }
    如果 (名 == "整数") {
        返回 编译_处理__整数_(参数)
    }
    如果 (名 == "分割") {
        返回 编译_处理__分割_(参数)
    }
    如果 (名 == "范围") {
        返回 编译_处理__范围_(参数)
    }
    如果 (名 == "字符串等于") {
        返回 编译_处理__字符串等于_(参数)
    }
    如果 (名 == "字典") {
        返回 编译_处理__字典_(参数)
    }
    如果 (名 == "字典设" 或 名 == "字典设置") {
        编译_表达式(参数[0])
        发射(0x50)
        编译_表达式(参数[1])
        发射(0x50)
        编译_表达式(参数[2])
        发射组([0x49, 0x89, 0xC0])
        发射(0x5A)
        发射(0x59)
        发射_规范空值_rcx()
        发射_规范空值_rdx()
        修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_字典设")
        发射(0xE8)
        发射32(0)
        返回 1
    }
    如果 (名 == "字典取" 或 名 == "字典获取") {
        编译_表达式(参数[0])
        发射(0x50)
        编译_表达式(参数[1])
        发射组([0x48, 0x89, 0xC2])
        发射(0x59)
        发射_规范空值_rcx()
        发射_规范空值_rdx()
        修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_字典取")
        发射(0xE8)
        发射32(0)
        返回 1
    }
    如果 (名 == "字典有") {
        返回 编译_处理__字典有_(参数)
    }
    如果 (名 == "字典键") {
        返回 编译_处理__字典键_(参数)
    }
    如果 (名 == "字典值") {
        返回 编译_处理__字典值_(参数)
    }
    如果 (名 == "打印文本") {
        返回 编译_处理__打印文本_(参数)
    }
    如果 (名 == "读文件") {
        返回 编译_处理__读文件_(参数)
    }
    如果 (名 == "读二进制文件") {
        返回 编译_处理__读二进制文件_(参数)
    }
    如果 (名 == "文件大小") {
        返回 编译_处理__文件大小_(参数)
    }
    如果 (名 == "参数") {
        返回 编译_处理__参数_(参数)
    }
    如果 (名 == "替换") {
        返回 编译_处理__替换_(参数)
    }
    返回 0
}


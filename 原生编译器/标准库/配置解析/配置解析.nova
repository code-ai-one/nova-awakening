
导入("../系统/配置.nova")
导入("../基础.nova")

// KV配置存储 (O(1)字典索引)
定义 可变 配置_键 = []
定义 可变 配置_字典 = 字典()

函数 配置_清空() { 配置_键 = []
配置_字典 = 字典() }

函数 配置解析_配置_设置(键, 值) {
    定义 已有 = 字典取(配置_字典, 键)
    如果 (已有 != 空) {
        字典设(配置_字典, 键, 值)
        返回 真
    }
    追加(配置_键, 键)
    字典设(配置_字典, 键, 值)
    返回 真
}

函数 配置解析_配置_获取(键, 默认值) {
    定义 v = 字典取(配置_字典, 键)
    如果 (v != 空) { 返回 v }
    返回 默认值
}

函数 配置解析_配置_存在(键) {
    返回 字典取(配置_字典, 键) != 空
}

函数 配置_数量() { 返回 计数(配置_键) }

函数 配置解析_配置_删除(键) {
    字典设(配置_字典, 键, 空)
    定义 可变 新键 = []
    定义 可变 i = 0
    当 (i < 计数(配置_键)) {
        如果 (配置_键[i] != 键) { 追加(新键, 配置_键[i]) }
        i = i + 1
    }
    配置_键 = 新键
}

// 配置合并
函数 配置解析_配置_合并(外键列表, 外值列表) {
    定义 可变 i = 0
    当 (i < 计数(外键列表)) {
        配置_设置(外键列表[i],  外值列表[i], 0)
        i = i + 1
    }
}

// 配置验证
函数 配置_验证_范围(键, 最小, 最大) {
    定义 数值 = 配置_获取(键, -99999)
    如果 (数值 == -99999) { 返回 -1 }
    如果 (数值 < 最小) { 返回 0 }
    如果 (数值 > 最大) { 返回 0 }
    返回 1
}

函数 配置_验证_必填(必填列表) {
    定义 可变 缺失 = 0
    定义 可变 i = 0
    当 (i < 计数(必填列表)) {
        如果 (配置_存在(必填列表[i], 0) == 假) { 缺失 = 缺失 + 1 }
        i = i + 1
    }
    返回 缺失
}

// 分节配置 (INI风格)
// 用 "节名.键名" 的整数哈希编码组合 (素数乘法减少碰撞)
函数 节_键(节哈希, 键哈希) { 返回 节哈希 * 1000003 + 键哈希 }

函数 配置_设置节(节, 键, 值) { 配置_设置(节_键(节, 键),  值, 0) }
函数 配置_获取节(节, 键, 缺省) { 返回 配置_获取(节_键(节, 键), 缺省) }

// 配置键列表
函数 配置_键列表() { 返回 复制列表(配置_键) }

// 配置值列表
函数 配置_值列表() { 返回 复制列表(配置_值) }

// 配置遍历
函数 配置_遍历打印() {
    定义 可变 i = 0
    当 (i < 计数(配置_键)) {
        打印(转字符串(配置_键[i]) + " = " + 转字符串(配置_值[i]))
        i = i + 1
    }
}

// 配置差异
函数 配置解析_配置_差异(外键, 外值) {
    定义 可变 新增 = 0
    定义 可变 修改 = 0
    定义 可变 i = 0
    当 (i < 计数(外键)) {
        如果 (配置_存在(外键[i], 0) == 假) { 新增 = 新增 + 1 }
        否则 如果 (配置_获取(外键[i], -1) != 外值[i]) { 修改 = 修改 + 1 }
        i = i + 1
    }
    返回 [新增, 修改]
}

// 配置克隆
函数 配置_克隆() {
    返回 [复制列表(配置_键), 复制列表(配置_值)]
}

函数 配置_从克隆恢复(克隆) {
    定义 可变 配置_值 = 0
    配置_键 = 复制列表(克隆[0])
    配置_值 = 复制列表(克隆[1])
}

// 配置过滤 (按键前缀)
函数 配置_过滤前缀(前缀, 除数) {
    定义 可变 结果键 = []
    定义 可变 结果值 = []
    定义 可变 i = 0
    当 (i < 计数(配置_键)) {
        如果 (配置_键[i] / 除数 == 前缀) {
            追加(结果键, 配置_键[i])
            追加(结果值, 配置_值[i])
        }
        i = i + 1
    }
    返回 [结果键, 结果值]
}

// 配置导出为列表
函数 配置解析_配置_导出() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(配置_键)) {
        追加(结果, [配置_键[i], 配置_值[i]])
        i = i + 1
    }
    返回 结果
}

// 配置从列表导入
函数 配置_导入(对列表) {
    定义 可变 i = 0
    当 (i < 计数(对列表)) {
        配置_设置(对列表[i][0],  对列表[i][1], 0)
        i = i + 1
    }
}

// 配置统计
// INI格式解析

函数 配置_解析INI(文本) {
    定义 可变 当前节 = ""
    定义 可变 行列表 = []
    // 按换行分割
    定义 可变 当前行 = ""
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        定义 c = 字节取(文本, i)
        如果 (c == 字符_换行) {
            追加(行列表, 当前行)
            当前行 = ""
        } 否则 {
            当前行 = 当前行 + 字符(c)
        }
        i = i + 1
    }
    如果 (当前行 != "") { 追加(行列表, 当前行) }
    // 逐行处理
    i = 0
    当 (i < 计数(行列表)) {
        定义 行 = 行列表[i]
        定义 长 = 字节长度(行)
        如果 (长 > 0) {
            定义 首字符 = 字节取(行, 0)
            如果 (首字符 == 字符_左方括) {  // '['
                // 节名
                定义 可变 j = 1
                定义 可变 节名 = ""
                当 (j < 长) {
                    定义 ch = 字节取(行, j)
                    如果 (ch == 字符_右方括) { j = 长 }  // ']'
                    否则 { 节名 = 节名 + 字符(ch) }
                    j = j + 1
                }
                当前节 = 节名
            } 否则 如果 (首字符 != 字符_分号 且 首字符 != 35) {  // 非注释 ';' '#'
                // 键=值
                定义 可变 j = 0
                当 (j < 长) {
                    如果 (字节取(行, j) == 字符_等号) { 等号位 = j  j = 长 }
                    j = j + 1
                }
                如果 (等号位 > 0) {
                    定义 键 = 子串(行, 0, 等号位)
                    定义 值 = 子串(行, 等号位 + 1, 长 - 等号位 - 1)
                    定义 可变 完整键 = 键
                    如果 (当前节 != "") { 完整键 = 当前节 + "." + 键 }
                    配置_设置(完整键,  值, 0)
                }
            }
        }
        i = i + 1
    }
}

// 配置验证

定义 可变 _配置_必需键 = []

函数 配置_注册必需(键) { 追加(_配置_必需键, 键) }

函数 配置_验证() {
    定义 可变 缺失 = []
    定义 可变 i = 0
    当 (i < 计数(_配置_必需键)) {
        如果 (配置_获取(_配置_必需键[i], 空) == 空) {
            追加(缺失, _配置_必需键[i])
        }
        i = i + 1
    }
    返回 缺失
}

// 配置合并

函数 配置_深合并(其他键列表, 其他值列表) {
    定义 可变 i = 0
    当 (i < 计数(其他键列表)) {
        如果 (配置_获取(其他键列表[i], 空) == 空) {
            配置_设置(其他键列表[i],  其他值列表[i], 0)
        }
        i = i + 1
    }
}

函数 配置_覆盖合并(其他键列表, 其他值列表) {
    定义 可变 i = 0
    当 (i < 计数(其他键列表)) {
        配置_设置(其他键列表[i],  其他值列表[i], 0)
        i = i + 1
    }
}

定义 可变 _配置_读取数 = 0
定义 可变 _配置_写入数 = 0

函数 配置_记录读取() { _配置_读取数 = _配置_读取数 + 1 }
函数 配置_记录写入() { _配置_写入数 = _配置_写入数 + 1 }

// §11 信息打印

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 通串_打印设备(dev) {
    定义 速度名 = "?"
    如果 (dev.速度 == 通串_SPEED_LOW)   { 速度名 = "1.5Mbps" }
    如果 (dev.速度 == 通串_SPEED_FULL)  { 速度名 = "12Mbps" }
    如果 (dev.速度 == 通串_SPEED_HIGH)  { 速度名 = "480Mbps" }
    如果 (dev.速度 == 通串_SPEED_SUPER) { 速度名 = "5Gbps" }

    内核信息("通串: [" + 整数转字符串(dev.地址) + "] " +
             dev.产品名 + " (" + dev.厂商名 + ")" +
             " VID:PID=" + 整数转十六进制(dev.厂商ID) + ":" + 整数转十六进制(dev.产品ID) +
             " 类=" + 整数转十六进制(dev.类代码) +
             " 速度=" + 速度名 +
             " 驱动=" + dev.驱动)
}

函数 通串_统计() {
    返回 [计数(通串控制器列表), 计数(通串设备列表)]
}

函数 通串_列出设备() {
    定义 可变 i = 0
    当 (i < 计数(通串设备列表)) {
        通串_打印设备(通串设备列表[i])
        i = i + 1
    }
}

// §8 控制器操作 — xHCI/EHCI寴存器级控制

函数 通串_端口有设备(ctl, 端口) {
    // 读取xHCI端口状态寄存器(PORTSC)
    // bit0: CCS(Current Connect Status)
    如果 (ctl == 空) { 返回 假 }
    定义 PORTSC基址 = ctl + 0x400 + 端口 * 0x10
    定义 状态 = MMIO_读32(PORTSC基址)
    返回 (状态 & 1) != 0  // CCS位
}

函数 通串_端口已枚举(ctl, 端口) {
    // 检查设备是否已分配地址
    定义 可变 i = 0
    当 (i < 计数(通串设备列表)) {
        如果 (通串设备列表[i].控制器 == ctl && 通串设备列表[i].端口 == 端口) {
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 通串_端口复位(ctl, 端口) {
    定义 PORTSC基址 = ctl + 0x400 + 端口 * 0x10
    定义 状态 = MMIO_读32(PORTSC基址)
    MMIO_写32(PORTSC基址, 状态 | (1 << 4))  // 置位PR
    // 等待复位完成(通串规范: 至尐50ms)
    延迟_ms(50)
    内核信息("通串: 端口" + 整数转字符串(端口) + " 复位完成")
}

函数 通串_获取设备描述符(ctl, 地址) {
    // 发送GET_DESCRIPTOR控制传输(bmRequestType=0x80, bRequest=6)
    定义 描述符 = 通串_控制传输(ctl, 地址, 0x80, 6, 0x0100, 0, 18)
    如果 (描述符 == 空 || 计数(描述符) < 18) { 返回 空 }
    // 解析: [bLength, bDescType, bcd通串, bClass, bSubClass, bProtocol,
    //          bMaxPacketSize0, idVendor, idProduct, ...]
    返回 [描述符[8] | (描述符[9] << 8),    // idVendor
           描述符[10] | (描述符[11] << 8),  // idProduct
           描述符[4],                           // bDeviceClass
           描述符[14],                          // iManufacturer
           描述符[15],                          // iProduct
           描述符[7]]                           // bMaxPacketSize0
}

函数 通串_设置地址(ctl, 旧地址, 新地址) {
    // SET_ADDRESS控制传输(bmRequestType=0x00, bRequest=5)
    通串_控制传输(ctl, 旧地址, 0x00, 5, 新地址, 0, 0)
    延迟_ms(2)  // 设备需要2ms恢复
    内核调试("通串: 设置地址 " + 整数转字符串(旧地址) + " → " + 整数转字符串(新地址))
}

函数 通串_设置配置(ctl, 地址, 配置号) {
    // SET_CONFIGURATION控制传输(bmRequestType=0x00, bRequest=9)
    通串_控制传输(ctl, 地址, 0x00, 9, 配置号, 0, 0)
    内核调试("通串: 设置配置 #" + 整数转字符串(配置号) + " 地址=" + 整数转字符串(地址))
}

函数 通串_获取字符串(ctl, 地址, 索引) {
    如果 (索引 == 0) { 返回 "" }
    // GET_DESCRIPTOR控制传输(type=3=STRING)
    定义 数据 = 通串_控制传输(ctl, 地址, 0x80, 6, 0x0300 | 索引, 0x0409, 255)
    如果 (数据 == 空 || 计数(数据) < 2) { 返回 "" }
    // Unicode字符串描述符: 跳过前2字节(bLength, bDescriptorType)
    定义 可变 结果 = ""
    定义 可变 i = 2
    当 (i < 计数(数据) - 1) {
        结果 = 结果 + 字符(数据[i])  // 取低字节(ASCII部分)
        i = i + 2  // 跳过高字节
    }
    返回 结果
}

// PCI_配置读32/PCI_读BAR 定义在 驱动/图处/图处识别.nova

函数 devtmpfs_创建_设备(路径) {
    // 在/dev/下创建设备节点
    内核信息("通串: 创建设备节点 " + 路径)
}

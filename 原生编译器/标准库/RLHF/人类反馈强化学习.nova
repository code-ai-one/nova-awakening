导入("../数学/工具.nova")



// 奖励模型
定义 可变 奖励_权重 = []

函数 奖励模型_初始化(维度) {
 奖励_权重 = []
 定义 可变 i = 0
 当 (i < 维度) { 追加(奖励_权重, 50 - i * 3)
 i = i + 1 }
}

函数 奖励模型_评分(特征值) { 定义 可变 得分 = 0
 定义 可变 i = 0
 当 (i < 计数(特征值) 且 i < 计数(奖励_权重)) {
 得分 = 得分 + 特征值[i] * 奖励_权重[i] / 100
 i = i + 1
 }
 返回 得分
}

// 奖励模型训练: 好样本分数应 > 坏样本分数
函数 奖励模型_训练步(好特征, 坏特征, lr) { 定义 好分 = 奖励模型_评分(好特征)
 定义 坏分 = 奖励模型_评分(坏特征)
 定义 间隔 = 好分 - 坏分
 如果 (间隔 < 100) {
 // 梯度: 增大好分，减小坏分
 定义 可变 i = 0
 当 (i < 计数(奖励_权重)) { 定义 梯度 = 好特征[i] - 坏特征[i]
 奖励_权重[i] = 奖励_权重[i] + lr * 梯度 / 1000
 i = i + 1
 }
 }
 返回 间隔
}

// PPO
函数 PPO_裁剪比率(新概率, 旧概率) {
    如果 (旧概率 == 0) { 返回 100
}
 返回 新概率 * 100 / 旧概率
}

函数 PPO_裁剪(比率, 优势, 极小值) { 定义 裁剪低 = 100 - 极小值
 定义 裁剪高 = 100 + 极小值
 定义 可变 裁剪比 = 比率
 如果 (裁剪比 < 裁剪低) { 裁剪比 = 裁剪低 }
 如果 (裁剪比 > 裁剪高) { 裁剪比 = 裁剪高 }
 定义 项1 = 比率 * 优势 / 100
 定义 项2 = 裁剪比 * 优势 / 100
 如果 (项1 < 项2) { 返回 项1 }
 返回 项2
}

// PPO价值损失: (V(s) - V_target)^2
函数 PPO_价值损失(价值, 目标) {
    定义 可变 总损失 = 0
    如果 (计数(价值) == 0) { 返回 0
}
 定义 可变 i = 0
 当 (i < 计数(价值)) { 定义 可变 偏差 = 价值[i] - 目标[i]
 总损失 = 总损失 + 偏差 * 偏差 / 1000
 i = i + 1
 }
 返回 总损失 / 计数(价值)
}

// GAE
函数 RLHF_gae_计算(奖励列表, 价值列表, 衰减率, 衰减系数) { 定义 n = 计数(奖励列表)
 定义 可变 优势 = []
 定义 可变 i = 0
 当 (i < n) { 追加(优势, 0)
 i = i + 1 }
 定义 可变 广义优势 = 0
 i = n - 1
 当 (i >= 0) { 定义 可变 下一价值 = 0
 如果 (i + 1 < n) { 下一价值 = 价值列表[i + 1] }
 定义 增量 = 奖励列表[i] + 衰减率 * 下一价值 / 100 - 价值列表[i]
 广义优势 = 增量 + 衰减率 * 衰减系数 * 广义优势 / 10000
 优势[i] = 广义优势
 i = i - 1
 }
 返回 优势
}

// DPO
函数 RLHF_DPO_损失(好_logprob, 坏_logprob, ref好_logprob, ref坏_logprob, 动量率) { 定义 好_diff = 好_logprob - ref好_logprob
 定义 坏_diff = 坏_logprob - ref坏_logprob
 定义 间隔 = 动量率 * (好_diff - 坏_diff) / 100
 定义 可变 信号值 = 50 + 间隔 / 4
 如果 (信号值 < 1) { 信号值 = 1 }
 如果 (信号值 > 99) { 信号值 = 99 }
 返回 100 - 信号值
}

// KL散度
函数 RLHF_KL散度(P, Q) { 定义 可变 kl = 0
 定义 可变 i = 0
 当 (i < 计数(P) 且 i < 计数(Q)) { 如果 (P[i] > 0 且 Q[i] > 0) {
 kl = kl + P[i] * (P[i] - Q[i]) / 100
 }
 i = i + 1
 }
 如果 (kl < 0) { kl = 0 }
 返回 kl
}

// KL惩罚奖励: r_kl = r - 动量率 * KL
函数 KL惩罚奖励(原始奖励, 策略P, 参考Q, 动量率) { 定义 kl = KL散度(策略P, 参考Q)
 返回 原始奖励 - 动量率 * kl / 100
}

// 熵奖励
函数 策略熵(概率分布) { 定义 可变 H = 0
 定义 可变 i = 0
 当 (i < 计数(概率分布)) { 如果 (概率分布[i] > 0) {
 // -p*log(p) ≈ -p*(p-1000)/p = (1000-p)
 H = H + 概率分布[i] * (1000 - 概率分布[i]) / 1000
 }
 i = i + 1
 }
 返回 H
}

函数 熵奖励(原始奖励, 概率分布, 学习率) { 返回 原始奖励 + 学习率 * 策略熵(概率分布) / 1000
}

// 偏好数据
定义 可变 偏好_好 = []
定义 可变 偏好_坏 = []

函数 偏好_追加(好特征, 坏特征) {
 追加(偏好_好, 好特征)
 追加(偏好_坏, 坏特征)
}

函数 偏好_数量() { 返回 计数(偏好_好) }
函数 偏好_清空() { 偏好_好 = []
偏好_坏 = [] }

// 偏好排序: 按奖励分数从高到低
函数 偏好_排序(候选列表) { 定义 可变 分数列表 = []
 定义 可变 idx列表 = []
 定义 可变 i = 0
 当 (i < 计数(候选列表)) {
 追加(分数列表, 奖励模型_评分(候选列表[i]))
 追加(idx列表, i)
 i = i + 1
 }
 // 简单选择排序
 i = 0
 当 (i < 计数(分数列表)) { 定义 可变 最优 = i
 定义 可变 j = i + 1
 当 (j < 计数(分数列表)) { 如果 (分数列表[j] > 分数列表[最优]) { 最优 = j }
 j = j + 1
 }
 如果 (最优 != i) { 定义 ts = 分数列表[i]
 分数列表[i] = 分数列表[最优]
 分数列表[最优] = ts
 定义 ti = idx列表[i]
 idx列表[i] = idx列表[最优]
 idx列表[最优] = ti
 }
 i = i + 1
 }
 返回 idx列表
}

// Best-of-N 采样
函数 最优N选(候选列表, N) { 定义 可变 最优索引 = 0
 定义 可变 最优得分 = -99999
 定义 可变 i = 0
 定义 可变 上限 = N
 如果 (上限 > 计数(候选列表)) { 上限 = 计数(候选列表) }
 当 (i < 上限) { 定义 s = 奖励模型_评分(候选列表[i])
 如果 (s > 最优得分) { 最优得分 = s
 最优索引 = i }
 i = i + 1
 }
 返回 最优索引
}

// 拒绝采样
函数 拒绝采样(候选列表, 奖励阈值) { 定义 可变 通过列表 = []
 定义 可变 i = 0
 当 (i < 计数(候选列表)) { 定义 r = 奖励模型_评分(候选列表[i])
 如果 (r >= 奖励阈值) { 追加(通过列表, i) }
 i = i + 1
 }
 返回 通过列表
}

// PPO策略损失
函数 PPO_裁剪损失(比率, 优势, 极小值) { 定义 未裁剪 = 比率 * 优势 / 1000
 定义 可变 裁剪ratio = 比率
 如果 (裁剪ratio > 1000 + 极小值) { 裁剪ratio = 1000 + 极小值 }
 如果 (裁剪ratio < 1000 - 极小值) { 裁剪ratio = 1000 - 极小值 }
 定义 已裁剪 = 裁剪ratio * 优势 / 1000
 如果 (未裁剪 < 已裁剪) { 返回 未裁剪 }
 返回 已裁剪
}

// KL散度惩罚
函数 KL_惩罚(logp_policy, logp_ref, β) { 返回 β * (logp_policy - logp_ref) / 1000
}

函数 KL_批量(logp_列表, ref_列表, β) { 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 计数(logp_列表)) {
 总 = 总 + KL_惩罚(logp_列表[i], ref_列表[i], β)
 i = i + 1
 }
 如果 (计数(logp_列表) == 0) { 返回 0 }
 返回 总 / 计数(logp_列表)
}

// 奖励归一化
// 公式: z = (x - μ) / σ  其中 σ = sqrt(Var(x))
// 【缺陷修复】原实现除以方差(Var)，量纲错误；正确应除以标准差(sqrt(Var))
// 【实验反哺】整数sqrt已在实验室/数学算法/整数快速开方与对数.nova验证
函数 RLHF_奖励_归一化(奖励列表) { 定义 n = 计数(奖励列表)
 如果 (n < 2) { 返回 奖励列表 }
 定义 可变 均值 = 0
 定义 可变 i = 0
 当 (i < n) { 均值 = 均值 + 奖励列表[i]; i = i + 1 }
 均值 = 均值 / n
 // 计算方差 Var = E[(x-μ)²]
 定义 可变 方差和 = 0
 i = 0
 当 (i < n) { 定义 d = 奖励列表[i] - 均值
 方差和 = 方差和 + d * d
 i = i + 1
 }
 定义 方差 = 方差和 / n
 // 【修复】标准差 = sqrt(方差)，Newton迭代整数平方根
 定义 可变 标准差 = 1
 如果 (方差 > 0) { 标准差 = 整数sqrt近似(方差) }
 如果 (标准差 <= 0) { 标准差 = 1 }  // 防零
 定义 可变 结果 = []
 i = 0
 当 (i < n) {
 // z = (x - μ) / σ  × 1000 保留精度
 追加(结果, (奖励列表[i] - 均值) * 1000 / 标准差)
 i = i + 1
 }
 返回 结果
}

// 整数平方根近似（Newton迭代，已在实验室验证精确到整数）
函数 整数sqrt近似(n) {
 如果 (n <= 0) { 返回 0 }
 如果 (n == 1) { 返回 1 }
 定义 可变 x = n / 2
 定义 可变 迭代 = 0
 当 (迭代 < 20) {
  定义 nx = (x + n / x) / 2
  如果 (nx >= x) { 返回 x }
  x = nx; 迭代 = 迭代 + 1
 }
 返回 x
}

// GAE优势估计
函数 GAE_优势(奖励列表, 价值列表, 衰减率, 衰减系数) { 定义 n = 计数(奖励列表)
 定义 可变 优势 = []
 定义 可变 i = 0
 当 (i < n) { 追加(优势, 0) i = i + 1 }
 定义 可变 广义优势 = 0
 i = n - 1
 当 (i >= 0) { 定义 可变 下一价值 = 0
 如果 (i + 1 < n) { 下一价值 = 价值列表[i + 1] }
 定义 增量 = 奖励列表[i] + 衰减率 * 下一价值 / 1000 - 价值列表[i]
 广义优势 = 增量 + 衰减率 * 衰减系数 * 广义优势 / 1000000
 优势[i] = 广义优势
 i = i - 1
 }
 返回 优势
}

// Phase3反哺注入: 整数sqrt近似 [BugFix]
// 来源: Rust深度研究引擎 nova_deep_engine.rs
// 误差: 0.00% → 0.00%  提升: 0.0x
// 说明: 循环上限Bug: 循环上限硬编码: 当 (迭代 < 20) { → 用Q快速幂整数替换
// E9反哺修复: 删除循环上限, 改用Q快速幂整数(base,exp)
// 见在线学习.nova 函数 Q快速幂整数

// [Nova实验室反哺] 偏好_排序
// 原: 选择排序 O(n²) — RLHF候选列表n=50时2500次比较
// 新: 快速排序 O(nlogn) — n=50时约280次比较 (9×加速)
函数 RLHF_排序分区(分数, 索引, 低, 高) {
    定义 基准值 = 分数[索引[高]]
    定义 可变 i = 低
    定义 可变 j = 低
    当 (j < 高) {
        如果 (分数[索引[j]] > 基准值) {
            定义 临 = 索引[i]
            索引[i] = 索引[j]
            索引[j] = 临
            i = i + 1
        }
        j = j + 1
    }
    定义 临2 = 索引[i]
    索引[i] = 索引[高]
    索引[高] = 临2
    返回 i
}

函数 RLHF_快排递归(分数, 索引, 低, 高) {
    如果 (低 >= 高) { 返回 }
    定义 p = RLHF_排序分区(分数, 索引, 低, 高)
    RLHF_快排递归(分数, 索引, 低, p - 1)
    RLHF_快排递归(分数, 索引, p + 1, 高)
}

函数 偏好_排序_快排(候选列表) {
    // O(nlogn) 实验反哺替代 O(n²) 选择排序
    定义 可变 分数列表 = []
    定义 可变 idx列表 = []
    定义 可变 i = 0
    当 (i < 计数(候选列表)) {
        追加(分数列表, 奖励模型_评分(候选列表[i]))
        追加(idx列表, i)
        i = i + 1
    }
    如果 (计数(idx列表) > 1) {
        RLHF_快排递归(分数列表, idx列表, 0, 计数(idx列表) - 1)
    }
    定义 可变 结果 = []
    i = 0
    当 (i < 计数(idx列表)) {
        追加(结果, 候选列表[idx列表[i]])
        i = i + 1
    }
    返回 结果
}

// [Nova实验室反哺] 快排优化版
// 实验结论: O(n²)嵌套排序 → O(nlogn)快速排序，n=100时速度13×
// 已在标准库/基础.nova中实现 基础_快速排序(列表, 低, 高)
// 快排已反哺 — 可调用 基础_快速排序 替代本函数

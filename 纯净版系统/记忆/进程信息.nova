//   1. /proc/[pid]/ 目录: 每个进程一个, 包含status/stat/maps/fd/cmdline等
//   2. /proc/[pid]/status: 人类可读的进程状态
//   3. /proc/[pid]/stat: 机器可解析的单行状态(ps/top用)
//   4. /proc/[pid]/maps: 进程地址空间映射
//   5. /proc/[pid]/cmdline: 命令行参数
//   6. /proc/[pid]/fd/: 打开的文件描述符(符号链接)
//   7. /proc/self: 指向当前进程PID的符号链接

// /proc/[pid]/status 
// 人类可读格式, 供cat /proc/xxx/status使用

函数 proc_进程状态(PID) {
    定义 任务 = 进程表_查找(PID)
    如果 (任务 == 空) { 返回 空 }

    定义 可变 输出 = ""
    输出 = 输出 + "Name:\t" + 进程_名称(任务) + "\n"
    输出 = 输出 + "Umask:\t0022\n"
    输出 = 输出 + "State:\t" + 进程_状态字符串(进程_状态(任务)) + "\n"
    输出 = 输出 + "Tgid:\t" + 整数转字符串(PID) + "\n"
    输出 = 输出 + "Ngid:\t0\n"
    输出 = 输出 + "Pid:\t" + 整数转字符串(PID) + "\n"
    输出 = 输出 + "PPid:\t" + 整数转字符串(进程_父PID(任务)) + "\n"
    输出 = 输出 + "TracerPid:\t0\n"
    输出 = 输出 + "Uid:\t" + 整数转字符串(进程_uid(任务)) + "\t" + 整数转字符串(进程_euid(任务)) + "\t" + 整数转字符串(进程_uid(任务)) + "\t" + 整数转字符串(进程_uid(任务)) + "\n"
    输出 = 输出 + "Gid:\t" + 整数转字符串(进程_gid(任务)) + "\t" + 整数转字符串(进程_egid(任务)) + "\t" + 整数转字符串(进程_gid(任务)) + "\t" + 整数转字符串(进程_gid(任务)) + "\n"
    输出 = 输出 + "FDSize:\t256\n"
    输出 = 输出 + "Groups:\t\n"
    输出 = 输出 + "Threads:\t" + 整数转字符串(进程_线程数(任务)) + "\n"

    // 信号掩码
    输出 = 输出 + "SigPnd:\t" + 整数转十六进制(进程_信号挂起(任务)) + "\n"
    输出 = 输出 + "SigBlk:\t" + 整数转十六进制(进程_信号掩码(任务)) + "\n"
    输出 = 输出 + "SigIgn:\t0000000000000000\n"
    输出 = 输出 + "SigCgt:\t0000000000000000\n"

    // 内存信息
    定义 mm = 进程_mm(任务)
    如果 (mm != 空) {
        输出 = 输出 + "VmPeak:\t" + 整数转字符串(mm_vm_peak(mm) / 1024) + " kB\n"
        输出 = 输出 + "VmSize:\t" + 整数转字符串(mm_vm_size(mm) / 1024) + " kB\n"
        输出 = 输出 + "VmRSS:\t" + 整数转字符串(mm_rss(mm) * 4) + " kB\n"
        输出 = 输出 + "VmData:\t" + 整数转字符串(mm_data_size(mm) / 1024) + " kB\n"
        输出 = 输出 + "VmStk:\t" + 整数转字符串(mm_stack_size(mm) / 1024) + " kB\n"
        输出 = 输出 + "VmExe:\t" + 整数转字符串(mm_text_size(mm) / 1024) + " kB\n"
    }

    // 上下文切换
    输出 = 输出 + "voluntary_ctxt_switches:\t" + 整数转字符串(进程_自愿切换(任务)) + "\n"
    输出 = 输出 + "nonvoluntary_ctxt_switches:\t" + 整数转字符串(进程_非自愿切换(任务)) + "\n"

    返回 输出
}

// /proc/[pid]/stat 
// 单行格式: pid (comm) S ppid pgrp session tty_nr ...
// ps/top/htop解析这个文件

函数 proc_进程stat(PID) {
    定义 任务 = 进程表_查找(PID)
    如果 (任务 == 空) { 返回 空 }

    定义 状态字符 = 进程_状态单字符(进程_状态(任务))
    定义 ppid = 进程_父PID(任务)
    定义 pgrp = 进程_组ID(任务)
    定义 session = 进程_会话ID(任务)
    定义 utime = 进程_用户时间(任务)
    定义 stime = 进程_内核时间(任务)
    定义 优先级 = 进程_优先级(任务)
    定义 nice = 进程_nice(任务)
    定义 线程数 = 进程_线程数(任务)
    定义 vsize = 0
    定义 rss = 0
    定义 mm = 进程_mm(任务)
    如果 (mm != 空) {
        vsize = mm_vm_size(mm)
        rss = mm_rss(mm)
    }

    // 格式: pid (comm) state ppid pgrp session tty_nr tpgid flags
    //        minflt cminflt majflt cmajflt utime stime cutime cstime
    //        priority nice num_threads itrealvalue staNova往返时间ime
    //        vsize rss rsslim ...
    返回 整数转字符串(PID) + " (" + 进程_名称(任务) + ") " + 状态字符 + " " +
           整数转字符串(ppid) + " " + 整数转字符串(pgrp) + " " +
           整数转字符串(session) + " 0 0 0 0 0 0 0 " +
           整数转字符串(utime) + " " + 整数转字符串(stime) + " 0 0 " +
           整数转字符串(优先级) + " " + 整数转字符串(nice) + " " +
           整数转字符串(线程数) + " 0 0 " +
           整数转字符串(vsize) + " " + 整数转字符串(rss) + " 0\n"
}

// /proc/[pid]/cmdline

函数 proc_进程cmdline(PID) {
    定义 任务 = 进程表_查找(PID)
    如果 (任务 == 空) { 返回 空 }
    返回 进程_命令行(任务)
}

// /proc/[pid]/maps 
// 格式: start-end perms offset dev Nova文件节点 pathname

函数 proc_进程maps(PID) {
    定义 任务 = 进程表_查找(PID)
    如果 (任务 == 空) { 返回 空 }
    定义 mm = 进程_mm(任务)
    如果 (mm == 空) { 返回 "" }

    定义 可变 输出 = ""
    定义 vma列表 = mm_vma列表(mm)
    定义 可变 i = 0
    当 (i < 计数(vma列表)) {
        定义 vma = vma列表[i]
        定义 起始 = VMA_起始(vma)
        定义 结束 = VMA_结束(vma)
        定义 权限 = VMA_权限字符串(vma)
        输出 = 输出 + 整数转十六进制(起始) + "-" + 整数转十六进制(结束) + " " +
               权限 + " 00000000 00:00 0\n"
        i = i + 1
    }
    返回 输出
}

// /proc/[pid]/fd/ 目录 

函数 proc_进程fd列表(PID) {
    定义 任务 = 进程表_查找(PID)
    如果 (任务 == 空) { 返回 [] }
    定义 文件表 = 进程_文件表(任务)
    如果 (文件表 == 空) { 返回 [] }

    定义 可变 结果 = []
    定义 可变 fd = 0
    当 (fd < 256) {
        如果 (文件表_获取(文件表, fd) != 空) {
            追加(结果, fd)
        }
        fd = fd + 1
    }
    返回 结果
}

// /proc/[pid]目录分发 — 根据子文件名返回内容

函数 proc_进程文件读(PID, 文件名) {
    如果 (文件名 == "status")  { 返回 proc_进程状态(PID) }
    如果 (文件名 == "stat")    { 返回 proc_进程stat(PID) }
    如果 (文件名 == "cmdline") { 返回 proc_进程cmdline(PID) }
    如果 (文件名 == "maps")    { 返回 proc_进程maps(PID) }
    如果 (文件名 == "comm")    {
        定义 任务 = 进程表_查找(PID)
        如果 (任务 != 空) { 返回 进程_名称(任务) + "\n" }
    }
    如果 (文件名 == "cwd")     { 返回 "/proc/" + 整数转字符串(PID) + "/cwd" }
    如果 (文件名 == "exe")     { 返回 "/proc/" + 整数转字符串(PID) + "/exe" }
    返回 空
}

// 辅助

函数 进程_状态字符串(状态) {
    如果 (状态 == 0) { 返回 "R (running)" }
    如果 (状态 == 1) { 返回 "S (sleeping)" }
    如果 (状态 == 2) { 返回 "D (disk sleep)" }
    如果 (状态 == 3) { 返回 "T (stopped)" }
    如果 (状态 == 4) { 返回 "Z (zombie)" }
    如果 (状态 == 5) { 返回 "X (dead)" }
    返回 "? (unknown)"
}

函数 进程_状态单字符(状态) {
    如果 (状态 == 0) { 返回 "R" }
    如果 (状态 == 1) { 返回 "S" }
    如果 (状态 == 2) { 返回 "D" }
    如果 (状态 == 3) { 返回 "T" }
    如果 (状态 == 4) { 返回 "Z" }
    如果 (状态 == 5) { 返回 "X" }
    返回 "?"
}

函数 VMA_权限字符串_proc(vma) {
    定义 可变 s = ""
    s = s + (如果选字符((VMA_保护(vma) & 0x1) != 0, "r", "-"))
    s = s + (如果选字符((VMA_保护(vma) & 0x2) != 0, "w", "-"))
    s = s + (如果选字符((VMA_保护(vma) & 0x4) != 0, "x", "-"))
    s = s + "p"   // 默认private映射(共享映射需检查VM_SHARED标志)
    返回 s
}

函数 整数转十六进制_proc(值) {
    如果 (值 == 0) { 返回 "0" }
    定义 可变 结果 = ""
    定义 可变 n = 值
    当 (n > 0) {
        定义 位 = n % 16
        如果 (位 < 10) { 结果 = 字符(48 + 位) + 结果 }
        否则 { 结果 = 字符(87 + 位) + 结果 }
        n = n / 16
    }
    返回 结果
}

// /proc/[pid]/io + 统计

函数 proc_进程io(PID) {
    定义 任务 = 进程表_查找(PID)
    如果 (任务 == 空) { 返回 空 }
    定义 可变 输出 = ""
    输出 = 输出 + "rchar: 0\n"
    输出 = 输出 + "wchar: 0\n"
    输出 = 输出 + "syscr: 0\n"
    输出 = 输出 + "syscw: 0\n"
    输出 = 输出 + "read_bytes: 0\n"
    输出 = 输出 + "write_bytes: 0\n"
    返回 输出
}


函数 进程信息_完整统计() {
    返回 [进程_总数()]
}

定义 可变 AI_进程信息_负载窗口 = []

函数 AI_进程信息_负载预测(当前负载) {
    追加(AI_进程信息_负载窗口, 当前负载)
    如果 (计数(AI_进程信息_负载窗口) > 20) { 列表_移除(AI_进程信息_负载窗口, 0) }
    如果 (计数(AI_进程信息_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_进程信息_负载窗口)
    定义 趋势 = AI_进程信息_负载窗口[n-1] - AI_进程信息_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_进程信息_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

//   1. kthread_create: 创建内核线程(不立即运行)
//   2. kthread_run: 创建并立即唤醒运行
//   3. kthread_stop: 请求线程退出并等待
//   4. kthread_should_stop: 线程检查是否被要求退出
//   5. kthreadd: PID=2的守护进程, 所有内核线程的创建者
//   6. 用于: kswapd/kworker/ksoftirqd/flush/migration等

定义 KTHREAD_应停止 = 0x01
定义 KTHREAD_已停止 = 0x02
定义 KTHREAD_已创建 = 0x04

结构 内核线程 {
    名称,
    线程函数,    // u64 fn(data) -> int
    数据,    // u64 传给线程函数的参数
    标志,    // u32 KTHREAD_*
    退出码,
    任务,    // u64 task_struct
    完成,    // u64 完成量(用于kthread_stop等待)
}

定义 可变 内核线程列表 = []
定义 可变 内核线程_总创建 = 0

// 创建内核线程 

函数 kthread_create(线程函数, 数据, 名称) {
    定义 kt = 内核线程 {}
    kt.名称 = 名称
    kt.线程函数 = 线程函数
    kt.数据 = 数据
    kt.标志 = KTHREAD_已创建
    kt.退出码 = 0
    kt.完成 = 完成量_创建()

    // 创建task_struct (内核线程: 无用户地址空间)
    定义 pid = 分配PID()
    kt.任务 = 进程_创建(pid, 名称, 0)
    进程_设置状态(kt.任务, 进程_等待)   // 创建后不立即运行
    进程表_注册(kt.任务)

    追加(内核线程列表, kt)
    内核线程_总创建 = 内核线程_总创建 + 1

    返回 kt
}

函数 kthread_run(线程函数, 数据, 名称) {
    定义 kt = kthread_create(线程函数, 数据, 名称)
    如果 (kt != 空) {
        // 唤醒线程开始运行
        进程_设置状态(kt.任务, 进程_运行)
        唤醒进程(kt.任务)
    }
    返回 kt
}

// 停止内核线程 
// 请求线程退出, 等待完成

函数 kthread_stop(kt) {
    如果 (kt == 空) { 返回 -1 }
    // 设置停止标志
    kt.标志 = kt.标志 | KTHREAD_应停止
    // 唤醒线程(如果在睡眠)
    唤醒进程(kt.任务)
    // 等待线程退出
    wait_for_completion(kt.完成)
    返回 kt.退出码
}

函数 kthread_should_stop(kt) {
    返回 (kt.标志 & KTHREAD_应停止) != 0
}

// 内核线程主体包装 (线程入口点)

函数 kthread_执行(kt) {
    如果 (kt == 空 || kt.线程函数 == 空) { 返回 }
    // 执行线程函数
    kt.退出码 = kt.线程函数(kt.数据)
    // 标记已停止
    kt.标志 = kt.标志 | KTHREAD_已停止
    // 通知等待者
    complete(kt.完成)
}

// 常用内核线程创建辅助

函数 创建kswapd() {
    返回 kthread_run(kswapd_线程函数, 空, "kswapd0")
}

函数 创建ksoftirqd(cpu) {
    返回 kthread_run(ksoftirqd_线程函数, cpu, "ksoftirqd/" + 整数转字符串(cpu))
}

函数 创建migration线程(cpu) {
    返回 kthread_run(migration_线程函数, cpu, "migration/" + 整数转字符串(cpu))
}

函数 kswapd_线程函数(数据) {
    // 内存回收守护线程
    当 (!kthread_should_stop_当前()) {
        // 检查内存水位线 → 回收页面
        调度()
    }
    返回 0
}

函数 ksoftirqd_线程函数(数据) {
    // 软中断处理线程
    当 (!kthread_should_stop_当前()) {
        // 处理软中断
        调度()
    }
    返回 0
}

函数 migration_线程函数(数据) {
    // CPU迁移线程
    当 (!kthread_should_stop_当前()) {
        调度()
    }
    返回 0
}

函数 kthread_should_stop_当前() {
    // 检查当前线程是否应停止
    定义 当前 = 获取当前进程()
    定义 可变 i = 0
    当 (i < 计数(内核线程列表)) {
        如果 (内核线程列表[i].任务 == 当前) {
            返回 kthread_should_stop(内核线程列表[i])
        }
        i = i + 1
    }
    返回 假
}

// kthreadd: 内核线程守护进程 (PID=2)
// 所有内核线程的父进程, 负责创建新内核线程

定义 可变 kthreadd_创建请求 = []

函数 kthreadd_主循环() {
    内核信息("[kthreadd] 内核线程守护进程启动 (PID=2)")
    当 (真) {
        如果 (计数(kthreadd_创建请求) > 0) {
            定义 请求 = kthreadd_创建请求[0]
            链表_删除(kthreadd_创建请求, 0)
            // 处理创建请求
            kthread_执行(请求)
        }
        调度()
    }
}

// 查询

函数 内核线程_统计() { 返回 [内核线程_总创建, 计数(内核线程列表)] }

函数 内核线程_列出() {
    定义 可变 i = 0
    当 (i < 计数(内核线程列表)) {
        定义 kt = 内核线程列表[i]
        定义 状态 = "运行"
        如果 ((kt.标志 & KTHREAD_已停止) != 0) { 状态 = "已停止" }
        否则 如果 ((kt.标志 & KTHREAD_应停止) != 0) { 状态 = "停止中" }
        内核信息("  [" + kt.名称 + "] " + 状态)
        i = i + 1
    }
}

// 按名称查找 + 活跃线程数

函数 内核线程_查找(名称) {
    定义 可变 i = 0
    当 (i < 计数(内核线程列表)) {
        如果 (内核线程列表[i].名称 == 名称) { 返回 内核线程列表[i] }
        i = i + 1
    }
    返回 空
}

函数 内核线程_活跃数() {
    定义 可变 计 = 0
    定义 可变 i = 0
    当 (i < 计数(内核线程列表)) {
        如果 ((内核线程列表[i].标志 & KTHREAD_已停止) == 0) { 计 = 计 + 1 }
        i = i + 1
    }
    返回 计
}

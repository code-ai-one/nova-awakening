// NHTB理论 — Nova HTML Tree Builder
// 原创HTML树构建算法与格式化元素重建理论
// 核心理论:
//   1. NHTB-AAA: 领养代理算法 (Adoption Agency Algorithm)
//      处理格式化元素的错误嵌套: <b><i></b></i>
//      通过节点重新父化(reparenting)保证DOM树正确性
//   2. NHTB-FMT: 格式化元素列表重建算法
//      跨作用域自动重建格式化标记
//   3. NHTB-FP: Foster Parenting算法
//      表格内误放内容的重定位插入
//   4. NHTB-STK: 开放元素栈管理与作用域推断
//   5. NHTB-AI: AI解析预测与异常检测

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../推理/值乘.nova")
导入("./元素栈创建.nova")
导入("../标准/内存.nova")

// §0 全局常量与统计

定义 NHTB_版本 = "3.0.0-NHTB"
定义 格式化标记_标记 = 0xFFFFFFFF // Marker (用于分隔作用域)

// 插入模式常量
定义 插入模式_初始 = 0
定义 插入模式_BeforeHtml = 1
定义 插入模式_BeforeHead = 2
定义 插入模式_InHead = 3
定义 插入模式_InHeadNoscript = 4
定义 插入模式_AfterHead = 5
定义 插入模式_InBody = 6
定义 插入模式_Text = 7
定义 插入模式_InTable = 8
定义 插入模式_InTableText = 9
定义 插入模式_InCaption = 10
定义 插入模式_InColumnGroup = 11
定义 插入模式_InTableBody = 12
定义 插入模式_InRow = 13
定义 插入模式_InCell = 14
定义 插入模式_InSelect = 15
定义 插入模式_InSelectInTable = 16
定义 插入模式_InTemplate = 17
定义 插入模式_AfterBody = 18
定义 插入模式_InFrameset = 19
定义 插入模式_AfterFrameset = 20
定义 插入模式_AfterAfterBody = 21
定义 插入模式_AfterAfterFrameset = 22

// AAA算法常量
定义 NHTB_AAA_最大迭代 = 8       // 外层最大迭代次数
定义 NHTB_AAA_内层最大 = 3       // 内层最大迭代次数
定义 NHTB_格式化列表初始容量 = 32
定义 NHTB_开放栈初始容量 = 64

// 格式化元素标签名集合
定义 NHTB_格式化标签 = ["b", "big", "code", "em", "font", "i", "s", "small", "strike", "strong", "tt", "u"]

// 统计计数器
定义 可变 NHTB_创建次数 = 0
定义 可变 NHTB_AAA执行次数 = 0
定义 可变 NHTB_重建次数 = 0
定义 可变 NHTB_FP插入次数 = 0
定义 可变 NHTB_模式切换次数 = 0
定义 可变 NHTB_AI推理次数 = 0
定义 可变 NHTB_异常检测次数 = 0

// §1 格式化元素列表核心

结构 格式化元素列表 {
 元素,
 数量,
 容量,
}

函数 格式化列表_创建() {
 定义 列表 = 堆_分配(格式化元素列表)
 列表.容量 = 32
 列表.元素 = 堆_分配_数组(列表.容量 * 8)
 列表.数量 = 0
 返回 列表
}

函数 格式化列表_添加(列表, 元素) {
 如果 (列表.数量 >= 列表.容量) {
 定义 新容量 = 列表.容量 * 2
 定义 新存储 = 堆_分配_数组(新容量 * 8)
 内存_复制(新存储, 列表.元素, 列表.数量 * 8)
 堆_释放(列表.元素)
 列表.元素 = 新存储
 列表.容量 = 新容量
 }
 内存_写64(列表.元素 + 列表.数量 * 8, 元素)
 列表.数量 = 列表.数量 + 1
}

函数 格式化列表_添加标记(列表) {
 格式化列表_添加(列表, 格式化标记_标记)
}

函数 格式化列表_移除(列表, 元素) {
 // 从列表中移除指定元素
 定义 可变 i = 0
 当 (i < 列表.数量) {
     定义 当前 = 内存_读64(列表.元素 + i * 8)
     如果 (当前 == 元素) {
         // 将后面的元素前移
         定义 可变 j = i
         当 (j < 列表.数量 - 1) {
             定义 下一个 = 内存_读64(列表.元素 + (j + 1) * 8)
             内存_写64(列表.元素 + j * 8, 下一个)
             j = j + 1
         }
         列表.数量 = 列表.数量 - 1
         返回 真
     }
     i = i + 1
 }
 返回 假
}

函数 格式化列表_查找(列表, 元素) {
 // 查找元素在列表中的索引，-1表示未找到
 定义 可变 i = 0
 当 (i < 列表.数量) {
     如果 (内存_读64(列表.元素 + i * 8) == 元素) {
         返回 i
     }
     i = i + 1
 }
 返回 -1
}

函数 格式化列表_获取(列表, 索引) {
 如果 (索引 < 0 || 索引 >= 列表.数量) { 返回 0 }
 返回 内存_读64(列表.元素 + 索引 * 8)
}

函数 格式化列表_替换(列表, 旧元素, 新元素) {
 定义 idx = 格式化列表_查找(列表, 旧元素)
 如果 (idx >= 0) {
     内存_写入64(列表.元素 + idx * 8, 新元素)
     返回 真
 }
 返回 假
}

// §2 格式化列表作用域操作

函数 格式化列表_清除到标记(列表) {
 // NHTB-FMT: 清除列表直到最后一个Marker（含）
 // 用于作用域结束时清理格式化元素
 当 (列表.数量 > 0) {
     列表.数量 = 列表.数量 - 1
     定义 当前 = 内存_读64(列表.元素 + 列表.数量 * 8)
     如果 (当前 == 格式化标记_标记) {
         返回
     }
 }
}

函数 格式化列表_重建(列表, tb) {
 // NHTB-FMT核心: 重建活跃格式化元素
 // 从最后一个Marker之后的元素开始，重新创建并插入
 NHTB_重建次数 = NHTB_重建次数 + 1
 如果 (列表.数量 == 0) { 返回 }

 // 找最后一个Marker的位置
 定义 可变 marker位置 = -1
 定义 可变 k = 列表.数量 - 1
 当 (k >= 0) {
     如果 (内存_读64(列表.元素 + k * 8) == 格式化标记_标记) {
         marker位置 = k
         返回  // marker后无元素需重建
     }
     // 检查是否在开放栈中
     定义 elem = 内存_读64(列表.元素 + k * 8)
     如果 (元素栈_包含(tb.开放元素栈, elem)) {
         返回  // 已在栈中，无需重建
     }
     k = k - 1
 }

 // 从找到的位置开始重建
 定义 可变 start = marker位置 + 1
 如果 (start < 0) { start = 0 }
 定义 可变 i = start
 当 (i < 列表.数量) {
     定义 原元素 = 内存_读64(列表.元素 + i * 8)
     如果 (原元素 != 格式化标记_标记) {
         // 创建新元素副本并插入
         定义 新元素 = NHTB_克隆元素(tb, 原元素)
         NHTB_插入元素(tb, 新元素)
         元素栈_入栈(tb.开放元素栈, 新元素)
         // 更新格式化列表中的引用
         内存_写入64(列表.元素 + i * 8, 新元素)
     }
     i = i + 1
 }
}

函数 格式化列表_是格式化标签(标签名) {
 // 检查标签是否属于格式化元素
 定义 可变 i = 0
 当 (i < 计数(NHTB_格式化标签)) {
     如果 (NHTB_格式化标签[i] == 标签名) { 返回 真 }
     i = i + 1
 }
 返回 假
}

函数 格式化列表_释放(列表) {
 如果 (列表 == 0) { 返回 }
 堆_释放(列表.元素)
 堆_释放(列表)
}

// §3 HTMLTreeBuilder结构

结构 HTMLTreeBuilder {
 // 核心状态
 插入模式,
 原始插入模式,    // u32 从Text模式返回时用

 // 文档
 文档,    // u64 Document*

 // 开放元素栈
 开放元素栈,    // u64 元素栈*

 // 活跃格式化元素
 格式化列表,    // u64 格式化元素列表*

 // 特殊引用
 head指针,    // u64 <head>元素
 form指针,    // u64 当前<form>元素

 // 令牌izer引用(用于切换状态)
 令牌izer,    // u64 HTML令牌izer*

 // 标志
 脚本已启用,
 frameset_ok,
 foster_parenting,    // 布尔 表格中的误放内容处理

 // 解析器暂停(等待脚本执行)
 已暂停,
 // 统计
 创建元素数,
 创建文本数,
}

// §4 创建/初始化

函数 HTMLTreeBuilder_创建(文档, 令牌izer) {
 NHTB_创建次数 = NHTB_创建次数 + 1
 定义 tb = 堆_分配(HTMLTreeBuilder)
 tb.插入模式 = 插入模式_初始
 tb.原始插入模式 = 插入模式_初始
 tb.文档 = 文档
 tb.开放元素栈 = 元素栈_创建()
 tb.格式化列表 = 格式化列表_创建()
 tb.head指针 = 0
 tb.form指针 = 0
 tb.令牌izer = 令牌izer
 tb.脚本已启用 = 真
 tb.frameset_ok = 真
 tb.foster_parenting = 假
 tb.已暂停 = 假
 tb.创建元素数 = 0
 tb.创建文本数 = 0
 返回 tb
}

函数 HTMLTreeBuilder_释放(tb) {
 如果 (tb == 0) { 返回 }
 格式化列表_释放(tb.格式化列表)
 元素栈_释放(tb.开放元素栈)
 堆_释放(tb)
}

// §5 插入模式切换与开放元素栈操作

函数 NHTB_切换插入模式(tb, 新模式) {
 NHTB_模式切换次数 = NHTB_模式切换次数 + 1
 tb.插入模式 = 新模式
}

函数 NHTB_保存并切换模式(tb, 新模式) {
 // 保存当前模式为原始模式，然后切换
 tb.原始插入模式 = tb.插入模式
 NHTB_切换插入模式(tb, 新模式)
}

函数 NHTB_恢复原始模式(tb) {
 NHTB_切换插入模式(tb, tb.原始插入模式)
}

函数 NHTB_当前节点(tb) {
 // 返回开放元素栈的栈顶元素
 返回 元素栈_栈顶(tb.开放元素栈)
}

函数 NHTB_插入元素(tb, 元素) {
 // 将元素插入适当位置
 tb.创建元素数 = tb.创建元素数 + 1
 如果 (tb.foster_parenting == 真) {
     NHTB_Foster插入(tb, 元素)
     返回
 }
 定义 父节点 = NHTB_当前节点(tb)
 如果 (父节点 != 0) {
     DOM_追加子节点(tb.文档, 父节点, 元素)
 }
}

函数 NHTB_插入文本(tb, 文本) {
 tb.创建文本数 = tb.创建文本数 + 1
 定义 文本节点 = DOM_创建文本节点(tb.文档, 文本)
 NHTB_插入元素(tb, 文本节点)
}

函数 NHTB_克隆元素(tb, 原元素) {
 // 创建元素副本(保留标签名和属性，不复制子节点)
 定义 标签 = DOM_获取标签名(tb.文档, 原元素)
 定义 新元素 = DOM_创建元素(tb.文档, 标签)
 DOM_复制属性(tb.文档, 原元素, 新元素)
 返回 新元素
}

// §6 Foster Parenting算法 (NHTB-FP)

函数 NHTB_Foster插入(tb, 元素) {
 // NHTB-FP: 处理表格内误放内容
 // 将元素插入到表格元素的前面（而非表格内部）
 NHTB_FP插入次数 = NHTB_FP插入次数 + 1

 // 找到栈中最后一个<table>元素
 定义 table元素 = NHTB_栈中查找标签(tb, "table")
 如果 (table元素 == 0) {
     // 无table，插入到栈底元素
     定义 栈底 = 元素栈_栈底(tb.开放元素栈)
     DOM_追加子节点(tb.文档, 栈底, 元素)
     返回
 }

 // 找到table的父节点，在table前面插入
 定义 父节点 = DOM_获取父节点(tb.文档, table元素)
 如果 (父节点 != 0) {
     DOM_插入在前(tb.文档, 父节点, 元素, table元素)
 } 否则 {
     DOM_追加子节点(tb.文档, table元素, 元素)
 }
}

函数 NHTB_栈中查找标签(tb, 标签名) {
 // 从栈顶向下查找指定标签的元素
 定义 栈大小 = 元素栈_大小(tb.开放元素栈)
 定义 可变 i = 栈大小 - 1
 当 (i >= 0) {
     定义 elem = 元素栈_获取(tb.开放元素栈, i)
     如果 (DOM_获取标签名(tb.文档, elem) == 标签名) {
         返回 elem
     }
     i = i - 1
 }
 返回 0
}

// §7 AAA领养代理算法 (NHTB-AAA)

函数 NHTB_AAA_执行(tb, 标签名) {
 // NHTB-AAA: Adoption Agency Algorithm
 // 处理格式化元素的错误嵌套
 // 例: <b><i></b></i> → 节点重新组织
 NHTB_AAA执行次数 = NHTB_AAA执行次数 + 1

 定义 可变 外层迭代 = 0
 当 (外层迭代 < NHTB_AAA_最大迭代) {
     // Step 1: 在格式化列表中找到匹配的格式化元素
     定义 格式元素 = NHTB_AAA_查找格式化元素(tb, 标签名)
     如果 (格式元素 == 0) {
         // 无匹配的格式化元素，执行普通弹栈
         NHTB_栈弹至标签(tb, 标签名)
         返回
     }

     // Step 2: 检查格式元素是否在开放栈中
     如果 (元素栈_包含(tb.开放元素栈, 格式元素) == 假) {
         // 不在栈中，从格式化列表中移除
         格式化列表_移除(tb.格式化列表, 格式元素)
         返回
     }

     // Step 3: 在栈中向上找到 furthest block
     定义 进一步块 = NHTB_AAA_查找进一步块(tb, 格式元素)
     如果 (进一步块 == 0) {
         // 无 furthest block，弹栈到格式元素并移除
         NHTB_栈弹至元素(tb, 格式元素)
         格式化列表_移除(tb.格式化列表, 格式元素)
         返回
     }

     // Step 4: 找到common ancestor
     定义 共同祖先 = NHTB_AAA_查找共同祖先(tb, 格式元素)

     // Step 5-6: 内层循环 — 重新组织节点
     定义 可变 节点 = 进一步块
     定义 可变 最后节点 = 进一步块
     定义 可变 内层迭代 = 0
     当 (内层迭代 < NHTB_AAA_内层最大) {
         内层迭代 = 内层迭代 + 1
         // 栈中向上移动
         节点 = NHTB_栈中上一个(tb, 节点)
         如果 (节点 == 格式元素) { 返回 }
         如果 (节点 == 0) { 返回 }

         // 检查节点是否在格式化列表中
         如果 (格式化列表_查找(tb.格式化列表, 节点) < 0) {
             元素栈_移除(tb.开放元素栈, 节点)
             继续
         }

         // 创建新元素替代
         定义 新元素 = NHTB_克隆元素(tb, 节点)
         格式化列表_替换(tb.格式化列表, 节点, 新元素)
         元素栈_替换(tb.开放元素栈, 节点, 新元素)
         节点 = 新元素

         如果 (最后节点 == 进一步块) {
             最后节点 = 节点
         }

         // 将最后节点重新父化到当前节点
         DOM_移除子节点(tb.文档, 最后节点)
         DOM_追加子节点(tb.文档, 节点, 最后节点)
         最后节点 = 节点
     }

     // Step 7: 将最后节点插入到共同祖先下
     如果 (共同祖先 != 0) {
         DOM_移除子节点(tb.文档, 最后节点)
         DOM_追加子节点(tb.文档, 共同祖先, 最后节点)
     }

     // Step 8: 创建格式元素副本
     定义 新格式 = NHTB_克隆元素(tb, 格式元素)

     // Step 9: 将进一步块的子节点移到新格式元素
     DOM_移动所有子节点(tb.文档, 进一步块, 新格式)

     // Step 10: 新格式元素追加到进一步块
     DOM_追加子节点(tb.文档, 进一步块, 新格式)

     // Step 11: 更新格式化列表和开放栈
     格式化列表_移除(tb.格式化列表, 格式元素)
     格式化列表_添加(tb.格式化列表, 新格式)
     元素栈_移除(tb.开放元素栈, 格式元素)
     元素栈_插入在后(tb.开放元素栈, 进一步块, 新格式)

     外层迭代 = 外层迭代 + 1
 }
}

函数 NHTB_AAA_查找格式化元素(tb, 标签名) {
 // 从列表末尾向前查找匹配标签名的格式化元素
 定义 可变 i = tb.格式化列表.数量 - 1
 当 (i >= 0) {
     定义 elem = 格式化列表_获取(tb.格式化列表, i)
     如果 (elem == 格式化标记_标记) { 返回 0 }
     如果 (DOM_获取标签名(tb.文档, elem) == 标签名) {
         返回 elem
     }
     i = i - 1
 }
 返回 0
}

函数 NHTB_AAA_查找进一步块(tb, 格式元素) {
 // 在栈中格式元素之上查找第一个特殊元素(furthest block)
 定义 格式idx = 元素栈_查找(tb.开放元素栈, 格式元素)
 如果 (格式idx < 0) { 返回 0 }
 定义 栈大小 = 元素栈_大小(tb.开放元素栈)
 定义 可变 i = 格式idx + 1
 当 (i < 栈大小) {
     定义 elem = 元素栈_获取(tb.开放元素栈, i)
     如果 (NHTB_是特殊元素(tb, elem)) {
         返回 elem
     }
     i = i + 1
 }
 返回 0
}

函数 NHTB_AAA_查找共同祖先(tb, 格式元素) {
 // 格式元素在栈中的前一个元素
 定义 idx = 元素栈_查找(tb.开放元素栈, 格式元素)
 如果 (idx <= 0) { 返回 0 }
 返回 元素栈_获取(tb.开放元素栈, idx - 1)
}

函数 NHTB_是特殊元素(tb, 元素) {
 // HTML规范定义的特殊元素(scope元素)
 定义 标签 = DOM_获取标签名(tb.文档, 元素)
 如果 (标签 == "address" || 标签 == "applet" || 标签 == "area" ||
     标签 == "article" || 标签 == "aside" || 标签 == "blockquote" ||
     标签 == "body" || 标签 == "caption" || 标签 == "center" ||
     标签 == "dd" || 标签 == "details" || 标签 == "dialog" ||
     标签 == "dir" || 标签 == "div" || 标签 == "dl" ||
     标签 == "dt" || 标签 == "fieldset" || 标签 == "figcaption" ||
     标签 == "figure" || 标签 == "footer" || 标签 == "form" ||
     标签 == "h1" || 标签 == "h2" || 标签 == "h3" ||
     标签 == "h4" || 标签 == "h5" || 标签 == "h6" ||
     标签 == "header" || 标签 == "li" || 标签 == "listing" ||
     标签 == "main" || 标签 == "marquee" || 标签 == "menu" ||
     标签 == "nav" || 标签 == "object" || 标签 == "ol" ||
     标签 == "p" || 标签 == "pre" || 标签 == "section" ||
     标签 == "summary" || 标签 == "table" || 标签 == "tbody" ||
     标签 == "td" || 标签 == "template" || 标签 == "tfoot" ||
     标签 == "th" || 标签 == "thead" || 标签 == "tr" ||
     标签 == "ul") {
     返回 真
 }
 返回 假
}

函数 NHTB_栈弹至标签(tb, 标签名) {
 // 弹栈直到遇到指定标签名(含)
 当 (元素栈_大小(tb.开放元素栈) > 0) {
     定义 栈顶 = 元素栈_栈顶(tb.开放元素栈)
     元素栈_弹栈(tb.开放元素栈)
     如果 (DOM_获取标签名(tb.文档, 栈顶) == 标签名) {
         返回
     }
 }
}

函数 NHTB_栈弹至元素(tb, 元素) {
 当 (元素栈_大小(tb.开放元素栈) > 0) {
     定义 栈顶 = 元素栈_栈顶(tb.开放元素栈)
     元素栈_弹栈(tb.开放元素栈)
     如果 (栈顶 == 元素) { 返回 }
 }
}

函数 NHTB_栈中上一个(tb, 元素) {
 定义 idx = 元素栈_查找(tb.开放元素栈, 元素)
 如果 (idx <= 0) { 返回 0 }
 返回 元素栈_获取(tb.开放元素栈, idx - 1)
}

// §8 AI解析预测与异常检测 (NHTB-AI)

函数 NHTB_AI检测异常(tb) {
 // NHTB-AI: 检测解析异常模式
 NHTB_AI推理次数 = NHTB_AI推理次数 + 1
 定义 tensor = Tensor_创建(8)
 Tensor_写(tensor, 0, tb.插入模式)
 Tensor_写(tensor, 1, 元素栈_大小(tb.开放元素栈))
 Tensor_写(tensor, 2, tb.格式化列表.数量)
 Tensor_写(tensor, 3, tb.创建元素数)
 Tensor_写(tensor, 4, tb.创建文本数)
 Tensor_写(tensor, 5, NHTB_AAA执行次数)
 Tensor_写(tensor, 6, NHTB_FP插入次数)
 Tensor_写(tensor, 7, NHTB_重建次数)
 定义 推理 = AI总线_异常检测(全局AI总线, "nhtb_anomaly", tensor)
 定义 异常分 = Tensor_读(推理, 0)
 Tensor_释放(tensor)
 Tensor_释放(推理)
 如果 (异常分 > 0.8) {
     NHTB_异常检测次数 = NHTB_异常检测次数 + 1
     打印("[NHTB-AI] 解析异常 score=" + 异常分)
 }
 返回 异常分
}

函数 NHTB_AI预测插入模式(tb, 标签名) {
 // AI预测下一个可能的插入模式
 NHTB_AI推理次数 = NHTB_AI推理次数 + 1
 定义 tensor = Tensor_创建(4)
 Tensor_写(tensor, 0, tb.插入模式)
 Tensor_写(tensor, 1, 元素栈_大小(tb.开放元素栈))
 Tensor_写(tensor, 2, tb.格式化列表.数量)
 Tensor_写(tensor, 3, 0.0)
 定义 推理 = AI总线_推理(全局AI总线, "nhtb_predict", tensor)
 定义 预测模式 = Tensor_读(推理, 0)
 Tensor_释放(tensor)
 Tensor_释放(推理)
 返回 预测模式
}

// §9 初始化与诊断

函数 NHTB_初始化() {
 NHTB_创建次数 = 0
 NHTB_AAA执行次数 = 0
 NHTB_重建次数 = 0
 NHTB_FP插入次数 = 0
 NHTB_模式切换次数 = 0
 NHTB_AI推理次数 = 0
 NHTB_异常检测次数 = 0
 打印("[NHTB] HTML树构建器 v" + NHTB_版本 + " 已初始化")
}

函数 NHTB_诊断报告() {
 打印("[NHTB] === HTML树构建诊断 ===")
 打印("  创建=" + 整数转字符串(NHTB_创建次数) + " AAA=" + 整数转字符串(NHTB_AAA执行次数) + " 重建=" + 整数转字符串(NHTB_重建次数))
 打印("  FP=" + 整数转字符串(NHTB_FP插入次数) + " 模式切换=" + 整数转字符串(NHTB_模式切换次数))
 打印("  AI推理=" + 整数转字符串(NHTB_AI推理次数) + " 异常=" + 整数转字符串(NHTB_异常检测次数))
}

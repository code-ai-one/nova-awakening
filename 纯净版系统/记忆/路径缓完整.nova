导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/创建甲.nova")

定义 哈希桶数 = 256
定义 最大缓存 = 1024
定义 淘汰链最大 = 512

结构 路径缓存项 {
    名称哈希,
    父哈希,
    节点号,
    引用计数,
    是负项,
    最近访问,
    哈希后继,
    淘汰前驱,
    淘汰后继,
}

定义 可变 哈希表 = 0
定义 可变 缓存数 = 0
定义 可变 负项数 = 0
定义 可变 淘汰头 = 0
定义 可变 淘汰尾 = 0
定义 可变 淘汰数 = 0
定义 可变 命中数 = 0
定义 可变 未命中数 = 0
定义 可变 淘汰次数 = 0

函数 路径缓存_初始化() {
    哈希表 = 堆_分配(哈希桶数 * 8)
    定义 可变 序号 = 0
    当 (序号 < 哈希桶数) {
        内存_写64(哈希表 + 序号 * 8, 0)
        序号 = 序号 + 1
    }
    缓存数 = 0
    负项数 = 0
    淘汰头 = 0
    淘汰尾 = 0
    淘汰数 = 0
}

函数 路径缓存_哈希(名称哈希, 父哈希) {
    返回 (名称哈希 * 2654435761 + 父哈希) % 哈希桶数
}

函数 路径缓存_查找(名称哈希, 父哈希) {
    定义 桶号 = 路径缓存_哈希(名称哈希, 父哈希)
    定义 可变 当前 = 内存_读64(哈希表 + 桶号 * 8)
    当 (当前 != 0) {
        如果 (当前.名称哈希 == 名称哈希 && 当前.父哈希 == 父哈希) {
            当前.最近访问 = 平台_获取高精度时间()
            当前.引用计数 = 当前.引用计数 + 1
            命中数 = 命中数 + 1
            路径缓存_移到淘汰头(当前)
            如果 (当前.是负项) { 返回 -1 }
            返回 当前.节点号
        }
        当前 = 当前.哈希后继
    }
    未命中数 = 未命中数 + 1
    返回 -2
}

函数 路径缓存_插入(名称哈希, 父哈希, 节点号) {
    如果 (缓存数 >= 最大缓存) { 路径缓存_淘汰() }
    定义 项 = 堆_分配(路径缓存项)
    项.名称哈希 = 名称哈希
    项.父哈希 = 父哈希
    项.节点号 = 节点号
    项.引用计数 = 1
    项.是负项 = (节点号 == 0)
    项.最近访问 = 平台_获取高精度时间()
    项.淘汰前驱 = 0
    项.淘汰后继 = 0
    定义 桶号 = 路径缓存_哈希(名称哈希, 父哈希)
    项.哈希后继 = 内存_读64(哈希表 + 桶号 * 8)
    内存_写64(哈希表 + 桶号 * 8, 项)
    缓存数 = 缓存数 + 1
    如果 (项.是负项) { 负项数 = 负项数 + 1 }
    路径缓存_加到淘汰头(项)
}

函数 路径缓存_淘汰() {
    如果 (淘汰尾 == 0) { 返回 }
    定义 牺牲 = 淘汰尾
    如果 (牺牲.引用计数 > 1) {
        定义 可变 候选 = 牺牲.淘汰前驱
        定义 可变 搜索 = 0
        当 (候选 != 0 && 搜索 < 16) {
            如果 (候选.引用计数 <= 1) { 牺牲 = 候选; 跳出 }
            候选 = 候选.淘汰前驱
            搜索 = 搜索 + 1
        }
    }
    路径缓存_从淘汰移除(牺牲)
    路径缓存_从哈希移除(牺牲)
    如果 (牺牲.是负项) { 负项数 = 负项数 - 1 }
    缓存数 = 缓存数 - 1
    淘汰次数 = 淘汰次数 + 1
    堆_释放(牺牲)
}

函数 路径缓存_从哈希移除(项) {
    定义 桶号 = 路径缓存_哈希(项.名称哈希, 项.父哈希)
    定义 可变 前驱 = 0
    定义 可变 当前 = 内存_读64(哈希表 + 桶号 * 8)
    当 (当前 != 0) {
        如果 (当前 == 项) {
            如果 (前驱 == 0) {
                内存_写64(哈希表 + 桶号 * 8, 项.哈希后继)
            } 否则 {
                前驱.哈希后继 = 项.哈希后继
            }
            返回
        }
        前驱 = 当前
        当前 = 当前.哈希后继
    }
}

函数 路径缓存_加到淘汰头(项) {
    项.淘汰前驱 = 0
    项.淘汰后继 = 淘汰头
    如果 (淘汰头 != 0) { 淘汰头.淘汰前驱 = 项 }
    淘汰头 = 项
    如果 (淘汰尾 == 0) { 淘汰尾 = 项 }
    淘汰数 = 淘汰数 + 1
}

函数 路径缓存_移到淘汰头(项) {
    如果 (项 == 淘汰头) { 返回 }
    路径缓存_从淘汰移除(项)
    路径缓存_加到淘汰头(项)
}

函数 路径缓存_从淘汰移除(项) {
    如果 (项.淘汰前驱 != 0) { 项.淘汰前驱.淘汰后继 = 项.淘汰后继 }
    否则 { 淘汰头 = 项.淘汰后继 }
    如果 (项.淘汰后继 != 0) { 项.淘汰后继.淘汰前驱 = 项.淘汰前驱 }
    否则 { 淘汰尾 = 项.淘汰前驱 }
    淘汰数 = 淘汰数 - 1
}

函数 路径缓存_释放(名称哈希, 父哈希) {
    定义 桶号 = 路径缓存_哈希(名称哈希, 父哈希)
    定义 可变 当前 = 内存_读64(哈希表 + 桶号 * 8)
    当 (当前 != 0) {
        如果 (当前.名称哈希 == 名称哈希 && 当前.父哈希 == 父哈希) {
            当前.引用计数 = 当前.引用计数 - 1
            返回
        }
        当前 = 当前.哈希后继
    }
}

函数 路径缓存_完整统计() {
    返回 [缓存数, 淘汰数, 负项数, 命中数, 未命中数, 淘汰次数]
}

定义 可变 AI_路径缓完_预测值 = 0
定义 可变 AI_路径缓完_优化次数 = 0

函数 AI_路径缓完_缓存策略(访问频率) {
    AI_路径缓完_优化次数 = AI_路径缓完_优化次数 + 1
    如果 (访问频率 > 100) { 返回 "常驻缓存" }
    如果 (访问频率 > 10) { 返回 "LRU缓存" }
    返回 "不缓存"
}

导入("../核心/FFI桥接.nova")
导入("../核心/设备管理.nova")
导入("../../../标准库/基础.nova")

//
// Nova GPU AMD rocSPARSE 完整接入
// GPU稀疏矩阵运算 AMD等价cuSPARSE + CPU回退

// 库状态
定义 可变 _rocSPARSE库 = 0
定义 可变 _rocSPARSE句柄 = 0
定义 可变 _rocsparse_可用 = 假
定义 可变 _rocsparse_操作计数 = 0

// 库加载

函数 rocSPARSE_加载() {
    如果 (_rocSPARSE库 != 0) { 返回 _rocSPARSE库
}
 _rocSPARSE库 = GPU_加载ROCm候选([
 "rocsparse.dll",
 "librocsparse.so"
 ])
 如果 (_rocSPARSE库 != 0) { _rocsparse_可用 = 真 }
 返回 _rocSPARSE库
}

函数 rocSPARSE_初始化() {
    如果 (_rocSPARSE句柄 != 0) { 返回 _rocSPARSE句柄
}
 定义 lib = rocSPARSE_加载()
 如果 (lib == 0) { 返回 0 }
 _rocSPARSE句柄 = 外部调用(lib,  "rocsparse_create_handle", 0, 0, 0, 0, 0)
 返回 _rocSPARSE句柄
}

函数 rocSPARSE_可用() { 返回 _rocsparse_可用 }

// 矩阵描述符

函数 rocSPARSE_创建矩阵描述() { 定义 lib = rocSPARSE_加载()
 如果 (lib == 0) { 返回 0 }
 返回 外部调用(lib,  "rocsparse_create_mat_descr", 0, 0, 0, 0, 0)
}

// GPU SpMV: y = alpha*A*x + beta*y

函数 rocSPARSE_稀疏矩阵向量乘(M, N, 非零数, alpha, desc, 值, 行指针, 列索引, x, beta, y) { _rocsparse_操作计数 = _rocsparse_操作计数 + 1
 定义 handle = rocSPARSE_初始化()
 如果 (handle == 0) { 返回 CPU_稀疏_SpMV(M, N, 非零数, alpha, 值, 行指针, 列索引, x, beta, y) }
 定义 lib = rocSPARSE_加载()
 返回 外部调用N(lib, "rocsparse_scsrmv",
 [handle, 0, M, N, 非零数, alpha, desc, 值, 行指针, 列索引, 0, x, beta, y]) == 0
}

// GPU SpMM: C = alpha*A*B + beta*C

函数 rocSPARSE_稀疏矩阵乘(M, N, K, 非零数, alpha, desc, 值, 行指针, 列索引, B, ldb, beta, C, ldc) { _rocsparse_操作计数 = _rocsparse_操作计数 + 1
 定义 handle = rocSPARSE_初始化()
 如果 (handle == 0) { 返回 假 }
 定义 lib = rocSPARSE_加载()
 返回 外部调用N(lib, "rocsparse_scsrmm",
 [handle, 0, M, N, K, 非零数, alpha, desc, 值, 行指针, 列索引, B, ldb, beta, C, ldc]) == 0
}

// 清理

函数 rocSPARSE_清理() { 如果 (_rocSPARSE句柄 != 0) {
 外部调用(rocSPARSE_加载(),  "rocsparse_destroy_handle",  _rocSPARSE句柄, 0, 0, 0, 0)
 _rocSPARSE句柄 = 0
 }
}

// CPU回退: CSR稀疏矩阵

函数 CSR_创建(行数, 列数) { 返回 {
 "行数": 行数,
 "列数": 列数,
 "非零数": 0,
 "行指针": [],
 "列索引": [],
 "值": []
 }
}

函数 CSR_从密集(矩阵, 行数, 列数) { 定义 可变 行指针 = [0]
 定义 可变 列索引 = []
 定义 可变 值 = []
 定义 可变 非零 = 0
 定义 可变 i = 0
 当 (i < 行数) { 定义 可变 j = 0
 当 (j < 列数) { 定义 可变 v = 矩阵[i * 列数 + j]
 如果 (v != 0) {
 追加(列索引, j)
 追加(值, v)
 非零 = 非零 + 1
 }
 j = j + 1
 }
 追加(行指针, 非零)
 i = i + 1
 }
 返回 {"行数": 行数, "列数": 列数, "非零数": 非零, "行指针": 行指针, "列索引": 列索引, "值": 值}
}

函数 CSR_到密集(csr) { 定义 行数 = csr["行数"]
 定义 列数 = csr["列数"]
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 行数 * 列数) { 追加(结果, 0) i = i + 1 }
 i = 0
 当 (i < 行数) { 定义 可变 j = csr["行指针"][i]
 当 (j < csr["行指针"][i + 1]) {
 结果[i * 列数 + csr["列索引"][j]] = csr["值"][j]
 j = j + 1
 }
 i = i + 1
 }
 返回 结果
}

函数 CSR_设值(csr, 行, 列, 值) { 定义 行指针 = csr["行指针"]
 定义 列索引 = csr["列索引"]
 定义 值列表 = csr["值"]
 定义 可变 start = 行指针[行]
 定义 可变 end = 行指针[行 + 1]
 定义 可变 i = start
 当 (i < end) { 如果 (列索引[i] == 列) {
 值列表[i] = 值
 返回 空
 }
 i = i + 1
 }
}

// CPU回退: SpMV

函数 CPU_稀疏_SpMV(M, _N, _非零数, alpha, 值, 行指针, 列索引, x, beta, y) { 定义 可变 i = 0
 当 (i < M) { 定义 可变 和 = 0
 定义 可变 j = 行指针[i]
 当 (j < 行指针[i + 1]) {
 和 = 和 + 值[j] * x[列索引[j]]
 j = j + 1
 }
 y[i] = alpha * 和 + beta * y[i]
 i = i + 1
 }
 返回 真
}

// CPU回退: SpMM

函数 CPU_稀疏_SpMM(M, N, _K, alpha, 值, 行指针, 列索引, B, ldb, beta, C, ldc) { 定义 可变 i = 0
 当 (i < M) { 定义 可变 k = 0
 当 (k < N) { 定义 可变 和 = 0
 定义 可变 j = 行指针[i]
 当 (j < 行指针[i + 1]) {
 和 = 和 + 值[j] * B[列索引[j] * ldb + k]
 j = j + 1
 }
 C[i * ldc + k] = alpha * 和 + beta * C[i * ldc + k]
 k = k + 1
 }
 i = i + 1
 }
 返回 真
}

// COO格式 (坐标格式)

函数 rocSPARSE_COO_创建(行, 列, _值) {
    返回 {"行数": 行, "列数": 列, "非零数": 0, "行": [], "列": [], "值": []
}
}

函数 COO_添加(coo, 行, 列, 值) {
 追加(coo["行"], 行)
 追加(coo["列"], 列)
 追加(coo["值"], 值)
 coo["非零数"] = coo["非零数"] + 1
}

函数 COO_到CSR(coo) { 定义 行数 = coo["行数"]
 定义 列数 = coo["列数"]
 定义 可变 行计数 = []
 定义 可变 i = 0
 当 (i < 行数) { 追加(行计数, 0) i = i + 1 }
 i = 0
 当 (i < coo["非零数"]) {
 行计数[coo["行"][i]] = 行计数[coo["行"][i]] + 1
 i = i + 1
 }
 定义 可变 行指针 = [0]
 i = 0
 当 (i < 行数) {
 追加(行指针, 行指针[i] + 行计数[i])
 i = i + 1
 }
 定义 可变 列索引 = []
 定义 可变 值 = []
 定义 可变 位置 = []
 i = 0
 当 (i < 行数) { 追加(位置, 行指针[i]) i = i + 1 }
 i = 0
 当 (i < coo["非零数"]) { 追加(列索引, 0) 追加(值, 0) i = i + 1 }
 i = 0
 当 (i < coo["非零数"]) { 定义 r = coo["行"][i]
 定义 p = 位置[r]
 列索引[p] = coo["列"][i]
 值[p] = coo["值"][i]
 位置[r] = 位置[r] + 1
 i = i + 1
 }
 返回 {"行数": 行数, "列数": 列数, "非零数": coo["非零数"], "行指针": 行指针, "列索引": 列索引, "值": 值}
}

// 对角矩阵

函数 对角_创建(大小, 对角值) { 定义 可变 行指针 = []
 定义 可变 列索引 = []
 定义 可变 值 = []
 定义 可变 i = 0
 当 (i < 大小) {
 追加(行指针, i)
 追加(列索引, i)
 追加(值, 对角值)
 i = i + 1
 }
 追加(行指针, 大小)
 返回 {"行数": 大小, "列数": 大小, "非零数": 大小, "行指针": 行指针, "列索引": 列索引, "值": 值}
}

函数 单位矩阵_稀疏(大小) { 返回 对角_创建(大小, 1)
}

// 稀疏向量操作

函数 rocSPARSE_稀疏向量_点积(索引1, 值1, 索引2, 值2) { 定义 可变 结果 = 0
 定义 可变 i = 0
 定义 可变 j = 0
 当 (i < 计数(索引1) 且 j < 计数(索引2)) { 如果 (索引1[i] == 索引2[j]) {
 结果 = 结果 + 值1[i] * 值2[j]
 i = i + 1
 j = j + 1
 }
 如果 (索引1[i] < 索引2[j]) { i = i + 1 }
 否则 { j = j + 1 }
 }
 返回 结果
}

函数 rocSPARSE_稀疏向量_加(索引1, 值1, 索引2, 值2) { 定义 可变 结果索引 = []
 定义 可变 结果值 = []
 定义 可变 i = 0
 定义 可变 j = 0
 当 (i < 计数(索引1) 或 j < 计数(索引2)) { 如果 (i < 计数(索引1) 且 (j >= 计数(索引2) 或 索引1[i] < 索引2[j])) {
 追加(结果索引, 索引1[i])
 追加(结果值, 值1[i])
 i = i + 1
 }
 如果 (j < 计数(索引2) 且 (i >= 计数(索引1) 或 索引2[j] < 索引1[i])) {
 追加(结果索引, 索引2[j])
 追加(结果值, 值2[j])
 j = j + 1
 }
 如果 (i < 计数(索引1) 且 j < 计数(索引2) 且 索引1[i] == 索引2[j]) {
 追加(结果索引, 索引1[i])
 追加(结果值, 值1[i] + 值2[j])
 i = i + 1
 j = j + 1
 }
 }
 返回 [结果索引, 结果值]
}

函数 稀疏度_分析(行数, 列数, 非零数) { 定义 总元素 = 行数 * 列数
 如果 (总元素 == 0) { 返回 [100, "空矩阵"] }
 定义 稀疏度 = (总元素 - 非零数) * 100 / 总元素
 定义 可变 描述 = "稠密"
 如果 (稀疏度 > 50) { 描述 = "稍稀疏" }
 如果 (稀疏度 > 80) { 描述 = "中等稀疏" }
 如果 (稀疏度 > 95) { 描述 = "高度稀疏" }
 如果 (稀疏度 > 99) { 描述 = "极度稀疏" }
 返回 [稀疏度, 描述]
}

函数 稀疏_格式推荐(行数, 列数, 非零数) { 定义 稀疏度 = (行数 * 列数 - 非零数) * 100 / (行数 * 列数)
 如果 (稀疏度 < 50) { 返回 "密集矩阵(稀疏度不足)" }
 如果 (行数 == 0) { 行数 = 1 }
 定义 平均每行 = 非零数 / 行数
 如果 (平均每行 < 3) { 返回 "COO(极稀疏,便于构建)" }
 如果 (行数 == 列数 且 非零数 == 行数) { 返回 "对角(仅对角非零)" }
 如果 (平均每行 < 10) { 返回 "CSR(行压缩,通用最优)" }
 返回 "CSR(标准选择)"
}

函数 稀疏_性能预测(_行数, 非零数, 使用GPU) { 定义 _运算量 = 非零数 * 2
 如果 (使用GPU) { 如果 (非零数 < 1000) { 返回 "GPU开销大于收益,建议CPU" }
 如果 (非零数 < 100000) { 返回 "GPU中等加速,约2-5x" }
 返回 "GPU显著加速,约10-100x"
 }
 如果 (非零数 < 10000) { 返回 "CPU足够,无需GPU" }
 返回 "建议使用GPU加速"
}

// CSR矩阵转置

函数 CSR_转置(csr) { 定义 行数 = csr["行数"]
 定义 列数 = csr["列数"]
 定义 非零数 = csr["非零数"]
 定义 行指针 = csr["行指针"]
 定义 列索引 = csr["列索引"]
 定义 值 = csr["值"]
 定义 可变 列计数 = []
 定义 可变 i = 0
 当 (i < 列数) { 追加(列计数, 0) i = i + 1 }
 i = 0
 当 (i < 非零数) { 列计数[列索引[i]] = 列计数[列索引[i]] + 1 i = i + 1 }
 定义 可变 新行指针 = [0]
 i = 0
 当 (i < 列数) { 追加(新行指针, 新行指针[i] + 列计数[i]) i = i + 1 }
 定义 可变 新列索引 = []
 定义 可变 新值 = []
 i = 0
 当 (i < 非零数) { 追加(新列索引, 0) 追加(新值, 0) i = i + 1 }
 定义 可变 位置 = []
 i = 0
 当 (i < 列数) { 追加(位置, 新行指针[i]) i = i + 1 }
 i = 0
 当 (i < 行数) { 定义 可变 j = 行指针[i]
 当 (j < 行指针[i + 1]) { 定义 c = 列索引[j]
 定义 p = 位置[c]
 新列索引[p] = i
 新值[p] = 值[j]
 位置[c] = 位置[c] + 1
 j = j + 1
 }
 i = i + 1
 }
 返回 {"行数": 列数, "列数": 行数, "非零数": 非零数, "行指针": 新行指针, "列索引": 新列索引, "值": 新值}
}

// 三对角矩阵求解 (Thomas算法)

函数 三对角_求解(下对角, 主对角, 上对角, 右端) { 定义 n = 计数(主对角)
 定义 可变 c2 = []
 定义 可变 d2 = []
 定义 可变 i = 0
 当 (i < n) { 追加(c2, 0) 追加(d2, 0) i = i + 1 }
 c2[0] = 上对角[0] / 主对角[0]
 d2[0] = 右端[0] / 主对角[0]
 i = 1
 当 (i < n) { 定义 m = 主对角[i] - 下对角[i] * c2[i - 1]
 如果 (m == 0) { 返回 [] }
 如果 (i < n - 1) { c2[i] = 上对角[i] / m }
 d2[i] = (右端[i] - 下对角[i] * d2[i - 1]) / m
 i = i + 1
 }
 定义 可变 x = []
 i = 0
 当 (i < n) { 追加(x, 0) i = i + 1 }
 x[n - 1] = d2[n - 1]
 i = n - 2
 当 (i >= 0) {
 x[i] = d2[i] - c2[i] * x[i + 1]
 i = i - 1
 }
 返回 x
}

// 带状矩阵

函数 带状矩阵_创建(大小, 带宽) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 大小 * (2 * 带宽 + 1)) { 追加(数据, 0) i = i + 1 }
 返回 {"大小": 大小, "带宽": 带宽, "数据": 数据}
}

函数 带状矩阵_设(矩阵, 行, 列, 值) { 定义 带宽 = 矩阵["带宽"]
 定义 偏移 = 列 - 行 + 带宽
 如果 (偏移 < 0 或 偏移 > 2 * 带宽) { 返回 空 }
 矩阵["数据"][行 * (2 * 带宽 + 1) + 偏移] = 值
}

函数 带状矩阵_取(矩阵, 行, 列) { 定义 带宽 = 矩阵["带宽"]
 定义 偏移 = 列 - 行 + 带宽
 如果 (偏移 < 0 或 偏移 > 2 * 带宽) { 返回 0 }
 返回 矩阵["数据"][行 * (2 * 带宽 + 1) + 偏移]
}

// 稀疏矩阵范数

函数 CSR_范数1(csr) { 定义 列数 = csr["列数"]
 定义 可变 列和 = []
 定义 可变 i = 0
 当 (i < 列数) { 追加(列和, 0) i = i + 1 }
 i = 0
 当 (i < csr["非零数"]) { 定义 c = csr["列索引"][i]
 定义 可变 v = csr["值"][i]
 如果 (v < 0) { v = 0 - v }
 列和[c] = 列和[c] + v
 i = i + 1
 }
 定义 可变 最大 = 0
 i = 0
 当 (i < 列数) { 如果 (列和[i] > 最大) { 最大 = 列和[i] }
 i = i + 1
 }
 返回 最大
}

函数 CSR_Frobenius范数(csr) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < csr["非零数"]) {
 和 = 和 + csr["值"][i] * csr["值"][i]
 i = i + 1
 }
 返回 和
}

// 稀疏矩阵行统计

函数 CSR_每行非零数(csr) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < csr["行数"]) {
 追加(结果, csr["行指针"][i + 1] - csr["行指针"][i])
 i = i + 1
 }
 返回 结果
}

函数 CSR_空行数(csr) { 定义 可变 空行 = 0
 定义 可变 i = 0
 当 (i < csr["行数"]) { 如果 (csr["行指针"][i + 1] == csr["行指针"][i]) { 空行 = 空行 + 1 }
 i = i + 1
 }
 返回 空行
}

函数 稀疏_健康诊断(csr) { 定义 可变 评分 = 100
 定义 稀疏度 = 稀疏度_分析(csr["行数"], csr["列数"], csr["非零数"])
 如果 (稀疏度[0] < 50) { 评分 = 评分 - 30 }
 定义 空行 = CSR_空行数(csr)
 如果 (空行 > csr["行数"] / 2) { 评分 = 评分 - 20 }
 定义 行非零 = CSR_每行非零数(csr)
 定义 可变 最大行 = 0
 定义 可变 i = 0
 当 (i < 计数(行非零)) { 如果 (行非零[i] > 最大行) { 最大行 = 行非零[i] }
 i = i + 1
 }
 如果 (最大行 > csr["非零数"] / 2) { 评分 = 评分 - 15 }
 如果 (评分 < 0) { 评分 = 0 }
 返回 [评分, 稀疏度[1], 空行, 最大行]
}

函数 稀疏_存储效率(行数, 列数, 非零数) { 定义 密集 = 行数 * 列数 * 4
 定义 CSR存储 = (行数 + 1) * 4 + 非零数 * 8
 定义 COO存储 = 非零数 * 12
 定义 可变 推荐 = "CSR"
 如果 (COO存储 < CSR存储) { 推荐 = "COO" }
 如果 (密集 < CSR存储) { 推荐 = "密集" }
 返回 [密集, CSR存储, COO存储, 推荐]
}

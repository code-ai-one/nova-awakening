// §4 动态调整(运行时自适应)

函数 Config_更新视口(宽, 高) {
    定义 c = Config_获取(); 如果(c==0){返回}
    c.视口宽 = 宽; c.视口高 = 高
}

函数 Config_切换省电模式(启用) {
    定义 c = Config_获取(); 如果(c==0){返回}
    c.省电模式 = 启用
    如果 (启用) {
        // 降低帧率, 减少缓存, 禁用AI
        c.目标帧率 = 30; c.帧预算us = 33333
        c.图片缓存MB = c.图片缓存MB / 2
        c.AI启用 = 假
    } 否则 {
        c.目标帧率 = c.屏幕刷新率
        c.帧预算us = 1000000 / c.目标帧率
        c.AI启用 = 真
    }
}

函数 Config_自适应帧率(连续掉帧数) {
    定义 c = Config_获取(); 如果(c==0){返回}
    如果 (连续掉帧数 > 5) {
        // 严重掉帧: 降到30fps
        c.目标帧率 = 30; c.帧预算us = 33333
    } 否则 如果 (连续掉帧数 > 2) {
        // 轻微掉帧: 降到45fps
        c.目标帧率 = 45; c.帧预算us = 22222
    } 否则 如果 (连续掉帧数 == 0 && c.目标帧率 < c.屏幕刷新率) {
        // 恢复: 逐步提升
        c.目标帧率 = c.目标帧率 + 15
        如果 (c.目标帧率 > c.屏幕刷新率) { c.目标帧率 = c.屏幕刷新率 }
        c.帧预算us = 1000000 / c.目标帧率
    }
}

函数 Config_内存压力响应(压力级别) {
    定义 c = Config_获取(); 如果(c==0){返回}
    // 压力级别: 0=正常 1=中等 2=严重 3=临界
    如果 (压力级别 == 1) {
        c.图片缓存MB = c.图片缓存MB * 3 / 4
        c.网络缓存MB = c.网络缓存MB * 3 / 4
    } 否则 如果 (压力级别 >= 2) {
        c.图片缓存MB = c.图片缓存MB / 2
        c.网络缓存MB = c.网络缓存MB / 2
        c.图处纹理缓存MB = c.图处纹理缓存MB / 2
        如果 (压力级别 >= 3) { c.AI启用 = 假 }
    }
}

// §5 性能评估

函数 Config_评估性能(cfg) {
    如果 (cfg == 0) { 返回 50 }
    定义 可变 分数 = 0
    // 内存
    如果 (cfg.总物理内存MB >= 8192) { 分数 = 分数 + 25 }
    否则 如果 (cfg.总物理内存MB >= 4096) { 分数 = 分数 + 20 }
    否则 如果 (cfg.总物理内存MB >= 2048) { 分数 = 分数 + 10 }
    否则 { 分数 = 分数 + 5 }
    // 图处
    如果 (cfg.图处加速) { 分数 = 分数 + 25 }
    否则 { 分数 = 分数 + 5 }
    // 刷新率
    如果 (cfg.屏幕刷新率 >= 120) { 分数 = 分数 + 25 }
    否则 如果 (cfg.屏幕刷新率 >= 60) { 分数 = 分数 + 15 }
    否则 { 分数 = 分数 + 5 }
    // 分辨率
    如果 (cfg.视口宽 >= 3840) { 分数 = 分数 + 25 }
    否则 如果 (cfg.视口宽 >= 1920) { 分数 = 分数 + 20 }
    否则 如果 (cfg.视口宽 >= 1280) { 分数 = 分数 + 10 }
    否则 { 分数 = 分数 + 5 }
    返回 分数
}

// §6 平台检测接口(由OS层实现)

函数 平台_检测屏幕宽() {
    // 通过framebuffer: /sys/class/graphics/fb0/virtual_size
    返回 0    // 0=使用回退值
}
函数 平台_检测屏幕高() {
    // 通过DRM/KMS获取屏幕分辨率高度
    定义 fd = 系统调用_open("/dev/dri/card0", 0)
    如果 (fd < 0) { 返回 768 }  // 默认值
    定义 res = 堆_分配(64)
    系统调用_Nova设备控制(fd, DRM_Nova设备控制_MODE_GETRESOURCES, res)
    定义 h = 内存_读32(res + 4)  // 高度
    堆_释放(res)
    系统调用_close(fd)
    如果 (h > 0) { 返回 h }
    返回 768
}
函数 平台_检测DPR() {
    // HiDPI: Xft.dpi / GDK_SCALE / 手动计算(物理尺寸vs分辨率)
    返回 1024    // 1.0x
}
函数 平台_检测刷新率() {
    返回 60
}
函数 平台_检测音频采样率() {
    // ALSA: snd_pcm_hw_params_get_rate
    // Pulse音频: pa_sink_info.sample_spec.rate
    返回 48000
}
函数 平台_检测内存MB() {
    // /proc/meminfo → MemTotal
    返回 0    // 0=使用回退值
}
函数 平台_检测图处可用() {
    // 检查/dev/dri/card0设备节点是否存在
    定义 fd = 系统调用_打开("/dev/dri/card0", 0, 0)  // O_RDONLY
    如果 (fd < 0) { 返回 假 }
    系统调用_关闭(fd)
    // 尝试EGL初始化验证GPU驱动可用
    定义 渲染fd = 系统调用_打开("/dev/dri/renderD128", 0, 0)
    如果 (渲染fd >= 0) { 系统调用_关闭(渲染fd); 返回 真 }
    返回 真  // card0存在即可
}
函数 平台_检测图处最大纹理() {
    // glGetIntegerv(GL_MAX_TEXTURE_SIZE)
    返回 8192
}

函数 动态调整_统计() {
    返回 {
        模块: "动态调整"
    }
}

函数 动态调整_健康评估() {
    定义 可变 问题 = []

    返回 计数(问题) == 0
}

函数 动态调整_综合报告() {
    打印("[动态调整] ═══ 综合报告 ═══")
    打印("  健康: " + 如果 (动态调整_健康评估()) { "正常" } 否则 { "异常" })
}

函数 动态调整_全局重置() {
    打印("[动态调整] 全局统计已重置")
    返回 0
}

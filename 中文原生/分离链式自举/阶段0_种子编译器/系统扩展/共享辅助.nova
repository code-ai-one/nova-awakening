导入("../标准库/基础.nova")

//
// Nova 系统扩展 共享辅助函数
// 编译期工具函数 + 作用域管理 + 符号表 + 类型推断辅助

// 统计
定义 可变 系统扩展_错误数 = 0
定义 可变 系统扩展_警告数 = 0
定义 可变 系统扩展_信息数 = 0
定义 可变 系统扩展_错误列表 = []
定义 可变 系统扩展_警告列表 = []

// 错误报告系统

函数 编译错误(消息) {
 打印("编译错误: " + 消息)
 系统扩展_错误数 = 系统扩展_错误数 + 1
 追加(系统扩展_错误列表, [系统扩展_错误数, 消息, "错误"])
}

函数 编译警告(消息) {
 打印("编译警告: " + 消息)
 系统扩展_警告数 = 系统扩展_警告数 + 1
 追加(系统扩展_警告列表, [系统扩展_警告数, 消息, "警告"])
}

函数 编译信息(消息) {
 打印("编译信息: " + 消息)
 系统扩展_信息数 = 系统扩展_信息数 + 1
}

函数 编译错误_带位置(文件, 行, 列, 消息) { 定义 位置 = 文件 + ":" + 转字符串(行) + ":" + 转字符串(列)
 编译错误(位置 + " " + 消息)
}

函数 编译警告_带位置(文件, 行, 列, 消息) { 定义 位置 = 文件 + ":" + 转字符串(行) + ":" + 转字符串(列)
 编译警告(位置 + " " + 消息)
}

函数 编译_有错误() { 返回 系统扩展_错误数 > 0 }

函数 编译_错误摘要() {
 打印(" 编译摘要 ")
 打印("错误: " + 转字符串(系统扩展_错误数))
 打印("警告: " + 转字符串(系统扩展_警告数))
 打印("信息: " + 转字符串(系统扩展_信息数))
 返回 系统扩展_错误数
}

函数 编译_重置错误() {
 系统扩展_错误数 = 0
 系统扩展_警告数 = 0
 系统扩展_信息数 = 0
 系统扩展_错误列表 = []
 系统扩展_警告列表 = []
}

// 类型转换工具

函数 整数转字符串(n) { 返回 转字符串(n) }

函数 安全转整数(文本) {
    如果 (文本 == 空 或 文本 == "") { 返回 0
}
 定义 可变 结果 = 0
 定义 可变 负 = 假
 定义 可变 i = 0
 如果 (计数(文本) > 0 且 子串(文本, 0, 1) == "-") { 负 = 真 i = 1 }
 当 (i < 计数(文本)) { 定义 c = 编码(子串(文本, i, 1))
 如果 (c >= 字符_零 且 c <= 字符_九) {
 结果 = 结果 * 10 + (c - 48)
 } 否则 { 返回 0 }
 i = i + 1
 }
 如果 (负) { 返回 0 - 结果 }
 返回 结果
}

函数 布尔转字符串(值) {
    如果 (值) { 返回 "真"
}
 返回 "假"
}

函数 安全转布尔(文本) {
    如果 (文本 == "真" 或 文本 == "是" 或 文本 == "1") { 返回 真
}
 返回 假
}

// 变量作用域管理

定义 可变 变量作用域表 = []
定义 可变 作用域_当前深度 = 0
定义 可变 作用域_最大深度 = 0
定义 可变 作用域_变量数 = []

函数 变量_设置作用域(变量名, 深度) { 定义 可变 i = 0
 当 (i < 计数(变量作用域表)) { 如果 (变量作用域表[i][0] == 变量名) {
 变量作用域表[i][1] = 深度
 返回 空
 }
 i = i + 1
 }
 追加(变量作用域表, [变量名, 深度, "活跃"])
}

函数 变量_获取作用域(变量名) { 定义 可变 i = 计数(变量作用域表) - 1
 当 (i >= 0) { 如果 (变量作用域表[i][0] == 变量名) { 返回 变量作用域表[i][1]
 }
 i = i - 1
 }
 返回 0
}

函数 变量_存在(变量名) { 定义 可变 i = 0
 当 (i < 计数(变量作用域表)) { 如果 (变量作用域表[i][0] == 变量名) { 返回 真 }
 i = i + 1
 }
 返回 假
}

函数 作用域_进入() {
 作用域_当前深度 = 作用域_当前深度 + 1
 如果 (作用域_当前深度 > 作用域_最大深度) { 作用域_最大深度 = 作用域_当前深度 }
 追加(作用域_变量数, 计数(变量作用域表))
}

函数 作用域_退出() {
    如果 (作用域_当前深度 <= 0) { 返回 空
}
 如果 (计数(作用域_变量数) > 0) { 定义 恢复数 = 作用域_变量数[计数(作用域_变量数) - 1]
 当 (计数(变量作用域表) > 恢复数) {
 变量作用域表[计数(变量作用域表) - 1][2] = "已销毁"
 删除(变量作用域表, 计数(变量作用域表) - 1)
 }
 删除(作用域_变量数, 计数(作用域_变量数) - 1)
 }
 作用域_当前深度 = 作用域_当前深度 - 1
}

函数 作用域_深度() { 返回 作用域_当前深度 }
函数 作用域_最大() { 返回 作用域_最大深度 }

// 简单符号表

定义 可变 符号表_条目 = []
定义 可变 符号表_计数 = 0

函数 符号表_添加(名称, 类型, 作用域) {
 追加(符号表_条目, [名称, 类型, 作用域, 真])
 符号表_计数 = 符号表_计数 + 1
}

函数 符号表_查找(名称, _扩2) { 定义 可变 i = 计数(符号表_条目) - 1
 当 (i >= 0) { 如果 (符号表_条目[i][0] == 名称 且 符号表_条目[i][3] == 真) { 返回 符号表_条目[i]
 }
 i = i - 1
 }
 返回 空
}

函数 符号表_类型(名称) { 定义 条目 = 符号表_查找(名称, 0)
 如果 (条目 == 空) { 返回 "未知" }
 返回 条目[1]
}

函数 符号表_清空() {
 符号表_条目 = []
 符号表_计数 = 0
}

函数 符号表_大小() { 返回 符号表_计数 }

函数 符号表_所有名称() { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(符号表_条目)) { 如果 (符号表_条目[i][3] == 真) {
 追加(结果, 符号表_条目[i][0])
 }
 i = i + 1
 }
 返回 结果
}

// 类型推断辅助

函数 推断_整数类型(值) {
    如果 (值 >= 0 - 128 且 值 <= 127) { 返回 "i8"
}
 如果 (值 >= 0 - 32768 且 值 <= 32767) { 返回 "i16" }
 如果 (值 >= 0 - 2147483648 且 值 <= 2147483647) { 返回 "i32" }
 返回 "i64"
}

函数 推断_最窄类型(值列表) { 定义 可变 最小 = 0
 定义 可变 最大 = 0
 定义 可变 i = 0
 当 (i < 计数(值列表)) { 如果 (值列表[i] < 最小) { 最小 = 值列表[i] }
 如果 (值列表[i] > 最大) { 最大 = 值列表[i] }
 i = i + 1
 }
 如果 (最小 >= 0) { 如果 (最大 <= 255) { 返回 "u8" }
 如果 (最大 <= 65535) { 返回 "u16" }
 返回 "u32"
 }
 返回 推断_整数类型(最小)
}

函数 类型_兼容(类型1, 类型2) {
    如果 (类型1 == 类型2) { 返回 真
}
 如果 (类型1 == "i64") { 返回 真 }
 如果 (类型2 == "i64") { 返回 真 }
 如果 (类型1 == "i32" 且 (类型2 == "i8" 或 类型2 == "i16")) { 返回 真 }
 如果 (类型2 == "i32" 且 (类型1 == "i8" 或 类型1 == "i16")) { 返回 真 }
 返回 假
}

函数 类型_提升(类型1, 类型2) {
    如果 (类型1 == 类型2) { 返回 类型1
}
 如果 (类型1 == "i64" 或 类型2 == "i64") { 返回 "i64" }
 如果 (类型1 == "i32" 或 类型2 == "i32") { 返回 "i32" }
 如果 (类型1 == "i16" 或 类型2 == "i16") { 返回 "i16" }
 返回 "i8"
}

// 字符串工具

函数 辅助_字符串拼接(列表, 分隔符) { 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 计数(列表)) { 如果 (i > 0) { 结果 = 结果 + 分隔符 }
 结果 = 结果 + 转字符串(列表[i])
 i = i + 1
 }
 返回 结果
}

函数 辅助_缩进(深度) { 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 深度) { 结果 = 结果 + " " i = i + 1 }
 返回 结果
}

函数 辅助_重复字符(字符, 次数) { 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 次数) { 结果 = 结果 + 字符 i = i + 1 }
 返回 结果
}

函数 辅助_左填充(文本, 宽度, 填充字符) { 定义 可变 结果 = 文本
 当 (计数(结果) < 宽度) { 结果 = 填充字符 + 结果 }
 返回 结果
}

函数 辅助_右填充(文本, 宽度, 填充字符) { 定义 可变 结果 = 文本
 当 (计数(结果) < 宽度) { 结果 = 结果 + 填充字符 }
 返回 结果
}

函数 错误_模式分析() {
    如果 (系统扩展_错误数 == 0) { 返回 "无错误"
}
 定义 可变 类型错误 = 0
 定义 可变 作用域错误 = 0
 定义 可变 语法错误 = 0
 定义 可变 i = 0
 当 (i < 计数(系统扩展_错误列表)) { 定义 消息 = 系统扩展_错误列表[i][1]
 定义 可变 j = 0
 定义 可变 有类型 = 假
 定义 可变 有作用域 = 假
 当 (j < 计数(消息)) { 如果 (j + 1 < 计数(消息) 且 子串(消息, j, 2) == "类型") { 有类型 = 真 }
 如果 (j + 2 < 计数(消息) 且 子串(消息, j, 3) == "作用域") { 有作用域 = 真 }
 j = j + 1
 }
 如果 (有类型) { 类型错误 = 类型错误 + 1 }
 如果 (有作用域) { 作用域错误 = 作用域错误 + 1 }
 如果 (有类型 == 假 且 有作用域 == 假) { 语法错误 = 语法错误 + 1 }
 i = i + 1
 }
 返回 [类型错误, 作用域错误, 语法错误]
}

函数 符号_冲突检测() { 定义 可变 冲突 = []
 定义 可变 i = 0
 当 (i < 计数(符号表_条目)) { 定义 可变 j = i + 1
 当 (j < 计数(符号表_条目)) { 如果 (符号表_条目[i][0] == 符号表_条目[j][0] 且 
 符号表_条目[i][2] == 符号表_条目[j][2] 且 
 符号表_条目[i][3] == 真 且 符号表_条目[j][3] == 真) {
 追加(冲突, [符号表_条目[i][0], 符号表_条目[i][2]])
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 冲突
}

函数 作用域_优化建议() {
    如果 (作用域_最大深度 > 10) { 返回 "嵌套过深: 建议拆分函数"
}
 如果 (计数(变量作用域表) > 100) { 返回 "变量过多: 考虑模块化" }
 如果 (作用域_最大深度 <= 3) { 返回 "结构良好: 嵌套适中" }
 返回 "正常: 嵌套在合理范围"
}

函数 编译_健康报告() { 定义 可变 评分 = 100
 如果 (系统扩展_错误数 > 0) { 评分 = 评分 - 系统扩展_错误数 * 10 }
 如果 (系统扩展_警告数 > 0) { 评分 = 评分 - 系统扩展_警告数 * 2 }
 如果 (作用域_最大深度 > 8) { 评分 = 评分 - 10 }
 定义 冲突 = 符号_冲突检测()
 如果 (计数(冲突) > 0) { 评分 = 评分 - 计数(冲突) * 5 }
 如果 (评分 < 0) { 评分 = 0 }
 返回 [评分, 系统扩展_错误数, 系统扩展_警告数, 计数(冲突)]
}

// 日志系统

定义 可变 日志_级别 = 3
定义 可变 日志_条目 = []

定义 共享辅助_日志_调试 = 1
定义 共享辅助_日志_信息 = 2
定义 共享辅助_日志_警告 = 3
定义 共享辅助_日志_错误 = 4
定义 共享辅助_日志_致命 = 5

函数 日志_设级别(级别) { 日志_级别 = 级别 }

函数 日志_写(级别, 类别, 消息) {
    如果 (级别 < 日志_级别) { 返回 空
}
 定义 可变 级别名 = "信息"
 如果 (级别 == 1) { 级别名 = "调试" }
 如果 (级别 == 3) { 级别名 = "警告" }
 如果 (级别 == 4) { 级别名 = "错误" }
 如果 (级别 == 5) { 级别名 = "致命" }
 定义 条目 = "[" + 级别名 + "] " + 类别 + ": " + 消息
 打印(条目)
 追加(日志_条目, [级别, 类别, 消息])
}

函数 日志_调试写(类别, 消息) { 日志_写(共享辅助_日志_调试, 类别, 消息) }
函数 日志_信息写(类别, 消息) { 日志_写(共享辅助_日志_信息, 类别, 消息) }
函数 日志_警告写(类别, 消息) { 日志_写(共享辅助_日志_警告, 类别, 消息) }
函数 日志_错误写(类别, 消息) { 日志_写(共享辅助_日志_错误, 类别, 消息) }

函数 共享辅助_日志_总数() { 返回 计数(日志_条目) }

函数 共享辅助_日志_清空() { 日志_条目 = [] }

// 诊断工具

定义 可变 诊断_计时器 = []

函数 诊断_开始计时(名称) {
 追加(诊断_计时器, [名称,])
}

函数 诊断_结束计时(名称) { 定义 可变 i = 计数(诊断_计时器) - 1
 当 (i >= 0) { 如果 (诊断_计时器[i][0] == 名称) {
 诊断_计时器[i][2] = 1
 返回 空
 }
 i = i - 1
 }
}

函数 诊断_报告() {
 打印("── 诊断报告 ──")
 定义 可变 i = 0
 当 (i < 计数(诊断_计时器)) { 定义 可变 状态 = "完成"
 如果 (诊断_计时器[i][2] == 0) { 状态 = "运行中" }
 打印(" " + 诊断_计时器[i][0] + ": " + 状态)
 i = i + 1
 }
}

// 简单内存追踪

定义 可变 内存_分配计数 = 0
定义 可变 内存_释放计数 = 0
定义 可变 内存_当前使用 = 0
定义 可变 内存_峰值使用 = 0

函数 内存_记录分配(大小) {
 内存_分配计数 = 内存_分配计数 + 1
 内存_当前使用 = 内存_当前使用 + 大小
 如果 (内存_当前使用 > 内存_峰值使用) { 内存_峰值使用 = 内存_当前使用 }
}

函数 内存_记录释放(大小) {
 内存_释放计数 = 内存_释放计数 + 1
 内存_当前使用 = 内存_当前使用 - 大小
 如果 (内存_当前使用 < 0) { 内存_当前使用 = 0 }
}

函数 内存_报告() { 返回 [内存_分配计数, 内存_释放计数, 内存_当前使用, 内存_峰值使用]
}

函数 内存_有泄漏() { 返回 内存_分配计数 > 内存_释放计数
}

// 断言辅助

函数 辅助_断言(条件, 消息) { 如果 (条件 == 假) {
 编译错误("断言失败: " + 消息)
 }
}

函数 辅助_不可达(消息) {
 编译错误("不可达代码: " + 消息)
}

函数 错误恢复_建议(错误类型) {
    如果 (错误类型 == "类型不匹配") { 返回 "插入类型转换"
}
 如果 (错误类型 == "未定义变量") { 返回 "检查拼写或添加声明" }
 如果 (错误类型 == "作用域越界") { 返回 "将变量提升到外层作用域" }
 如果 (错误类型 == "参数数量错误") { 返回 "检查函数签名" }
 如果 (错误类型 == "重复定义") { 返回 "重命名或合并定义" }
 返回 "检查上下文并修正"
}

函数 编译优化_建议() { 定义 可变 建议 = []
 如果 (符号表_计数 > 500) { 追加(建议, "符号过多: 考虑分模块编译") }
 如果 (作用域_最大深度 > 6) { 追加(建议, "嵌套过深: 提取子函数") }
 如果 (系统扩展_警告数 > 10) { 追加(建议, "警告积累: 建议逐步清理") }
 如果 (内存_有泄漏()) { 追加(建议, "潜在内存泄漏: 检查分配释放配对") }
 如果 (计数(建议) == 0) { 追加(建议, "编译状态良好") }
 返回 建议
}

定义 可变 编译_阶段列表 = []

函数 编译_进入阶段(名称) {
 追加(编译_阶段列表, [名称, "开始"])
}

函数 编译_完成阶段(名称) { 定义 可变 i = 计数(编译_阶段列表) - 1
 当 (i >= 0) { 如果 (编译_阶段列表[i][0] == 名称) {
 编译_阶段列表[i][1] = "完成"
 返回 空
 }
 i = i - 1
 }
}

函数 编译_当前阶段() { 定义 可变 i = 计数(编译_阶段列表) - 1
 当 (i >= 0) { 如果 (编译_阶段列表[i][1] == "开始") { 返回 编译_阶段列表[i][0] }
 i = i - 1
 }
 返回 "无"
}

函数 编译_进度百分比() {
    如果 (计数(编译_阶段列表) == 0) { 返回 0
}
 定义 可变 完成 = 0
 定义 可变 i = 0
 当 (i < 计数(编译_阶段列表)) { 如果 (编译_阶段列表[i][1] == "完成") { 完成 = 完成 + 1 }
 i = i + 1
 }
 返回 完成 * 100 / 计数(编译_阶段列表)
}

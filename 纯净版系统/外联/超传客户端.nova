导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("./套接层完整.nova")
导入("../中枢/哈希整数.nova")
导入("../中枢/字符串工具完.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/创建甲.nova")

定义 方法_获取 = 0
定义 方法_提交 = 1
定义 方法_放置 = 2
定义 方法_删除 = 3
定义 方法_头部 = 4
定义 最大头部 = 32
定义 最大连接池 = 16
定义 默认超时 = 30000000
定义 最大重试 = 3

结构 超传请求 {
    方法,
    地址哈希,
    端口,
    路径,
    路径长度,
    头部表,
    头部数,
    正文,
    正文长度,
    超时,
}

结构 超传响应 {
    状态码,
    头部表,
    头部数,
    正文,
    正文长度,
    接收时刻,
    耗时,
}

结构 连接项 {
    地址哈希,
    端口,
    套接描述,
    最近使用,
    活跃,
}

定义 可变 连接池 = []
定义 可变 连接池数 = 0
定义 可变 请求总数 = 0
定义 可变 成功总数 = 0
定义 可变 失败总数 = 0
定义 可变 重试总数 = 0
定义 可变 总发送字节 = 0
定义 可变 总接收字节 = 0

函数 超传_初始化() {
    连接池 = []
    连接池数 = 0
}

函数 超传_请求(方法, 地址, 端口, 路径, 正文, 正文长) {
    请求总数 = 请求总数 + 1
    定义 请求 = 超传请求 {}
    请求.方法 = 方法
    请求.地址哈希 = 哈希_字符串(地址)
    请求.端口 = 端口
    请求.路径 = 路径
    请求.路径长度 = 字串_长度(路径)
    请求.头部表 = 堆_分配(最大头部 * 16)
    请求.头部数 = 0
    请求.正文 = 正文
    请求.正文长度 = 正文长
    请求.超时 = 默认超时
    定义 可变 重试 = 0
    定义 可变 响应 = 0
    当 (重试 < 最大重试) {
        响应 = 超传_执行请求(请求)
        如果 (响应 != 0 && 响应.状态码 > 0) {
            成功总数 = 成功总数 + 1
            返回 响应
        }
        重试 = 重试 + 1
        重试总数 = 重试总数 + 1
    }
    失败总数 = 失败总数 + 1
    返回 0
}

函数 超传_执行请求(请求) {
    定义 套接 = 超传_获取连接(请求.地址哈希, 请求.端口)
    如果 (套接 < 0) { 返回 0 }
    定义 起始 = 平台_获取高精度时间()
    定义 发送缓冲 = 堆_分配(4096)
    定义 可变 写位 = 0
    如果 (请求.方法 == 方法_获取) { 写位 = 写位 + 格式化写(发送缓冲, "GET ") }
    否则 如果 (请求.方法 == 方法_提交) { 写位 = 写位 + 格式化写(发送缓冲, "POST ") }
    否则 如果 (请求.方法 == 方法_放置) { 写位 = 写位 + 格式化写(发送缓冲, "PUT ") }
    否则 如果 (请求.方法 == 方法_删除) { 写位 = 写位 + 格式化写(发送缓冲, "DELETE ") }
    内存_复制(发送缓冲 + 写位, 请求.路径, 请求.路径长度)
    写位 = 写位 + 请求.路径长度
    写位 = 写位 + 格式化写(发送缓冲 + 写位, " HTTP/1.1\r\n")
    如果 (请求.正文长度 > 0) {
        写位 = 写位 + 格式化写(发送缓冲 + 写位, "Content-Length: ")
        写位 = 写位 + 整数写(发送缓冲 + 写位, 请求.正文长度)
        写位 = 写位 + 格式化写(发送缓冲 + 写位, "\r\n")
    }
    写位 = 写位 + 格式化写(发送缓冲 + 写位, "\r\n")
    套接_发送(套接, 发送缓冲, 写位)
    总发送字节 = 总发送字节 + 写位
    如果 (请求.正文长度 > 0) {
        套接_发送(套接, 请求.正文, 请求.正文长度)
        总发送字节 = 总发送字节 + 请求.正文长度
    }
    定义 接收缓冲 = 堆_分配(65536)
    定义 接收长 = 套接_接收(套接, 接收缓冲, 65536)
    总接收字节 = 总接收字节 + 接收长
    定义 响应 = 超传_解析响应(接收缓冲, 接收长)
    如果 (响应 != 0) {
        响应.耗时 = 平台_获取高精度时间() - 起始
        响应.接收时刻 = 平台_获取高精度时间()
    }
    堆_释放(发送缓冲)
    返回 响应
}

函数 超传_解析响应(数据, 长度) {
    如果 (长度 < 12) { 返回 0 }
    定义 响应 = 超传响应 {}
    定义 可变 状态码 = 0
    定义 可变 位 = 9
    当 (位 < 长度 && 位 < 12) {
        定义 字节 = 内存_读8(数据 + 位)
        如果 (字节 >= 48 && 字节 <= 57) { 状态码 = 状态码 * 10 + (字节 - 48) }
        位 = 位 + 1
    }
    响应.状态码 = 状态码
    定义 正文起始 = 超传_查找正文(数据, 长度)
    如果 (正文起始 > 0) {
        响应.正文 = 数据 + 正文起始
        响应.正文长度 = 长度 - 正文起始
    } 否则 {
        响应.正文 = 0
        响应.正文长度 = 0
    }
    响应.头部表 = 0
    响应.头部数 = 0
    返回 响应
}

函数 超传_查找正文(数据, 长度) {
    定义 可变 位 = 0
    当 (位 + 3 < 长度) {
        如果 (内存_读8(数据 + 位) == 13 && 内存_读8(数据 + 位 + 1) == 10 && 内存_读8(数据 + 位 + 2) == 13 && 内存_读8(数据 + 位 + 3) == 10) {
            返回 位 + 4
        }
        位 = 位 + 1
    }
    返回 -1
}

函数 超传_获取连接(地址哈希, 端口) {
    定义 可变 序号 = 0
    当 (序号 < 连接池数) {
        如果 (连接池[序号].地址哈希 == 地址哈希 && 连接池[序号].端口 == 端口 && 连接池[序号].活跃) {
            连接池[序号].最近使用 = 平台_获取高精度时间()
            返回 连接池[序号].套接描述
        }
        序号 = 序号 + 1
    }
    定义 新套接 = 套接_创建(1, 0)
    如果 (新套接 < 0) { 返回 -1 }
    套接_连接(新套接, 地址哈希, 端口)
    如果 (连接池数 < 最大连接池) {
        定义 连接 = 连接项 {}
        连接.地址哈希 = 地址哈希
        连接.端口 = 端口
        连接.套接描述 = 新套接
        连接.最近使用 = 平台_获取高精度时间()
        连接.活跃 = 真
        追加(连接池, 连接)
        连接池数 = 连接池数 + 1
    }
    返回 新套接
}

函数 超传_获取(地址, 端口, 路径) {
    返回 超传_请求(方法_获取, 地址, 端口, 路径, 0, 0)
}

函数 超传_提交(地址, 端口, 路径, 正文, 正文长) {
    返回 超传_请求(方法_提交, 地址, 端口, 路径, 正文, 正文长)
}

函数 超传客户端_完整统计() {
    返回 [请求总数, 成功总数, 失败总数, 重试总数, 总发送字节, 总接收字节, 连接池数]
}

定义 可变 AI_超传客户端_热点函数 = []

函数 AI_超传客户端_JIT候选(函数名, 调用次数) {
    如果 (调用次数 > 100) {
        追加(AI_超传客户端_热点函数, 函数名)
        返回 真
    }
    返回 假
}

函数 AI_超传客户端_内联建议(函数体大小, 调用次数) {
    如果 (函数体大小 < 30 && 调用次数 > 50) { 返回 "内联" }
    返回 "不内联"
}

// §7 原子字符串表 (AtomString / StringPool)
// 所有.nova文件中的 原子_驻留 / 原子_xxx 常量的实现
// 对应 AtomicString

结构 原子表 {
 条目,    // u64 [哈希, 字符串指针, 原子ID] 数组
 数量,
 容量,
 下一个ID,
}

定义 可变 全局原子表 = 0

函数 原子表_初始化() {
 如果 (全局原子表 != 0) { 返回 }
 全局原子表 = 堆_分配(32)
 定义 容量 = 1024
 内存_写64(全局原子表, 堆_分配_数组(容量 * 24))
 内存_写32(全局原子表 + 8, 0)
 内存_写32(全局原子表 + 12, 容量)
 内存_写32(全局原子表 + 16, 1) // 下一个ID从1开始
}

函数 原子_驻留(str) {
 如果 (str == 0) { 返回 0 }
 如果 (全局原子表 == 0) { 原子表_初始化() }

 定义 哈希 = 字符串_哈希(str)
 定义 条目列表 = 内存_读64(全局原子表)
 定义 数量 = 内存_读32(全局原子表 + 8)

 // 查找已有
 定义 可变 i = 0
 当 (i < 数量) {
 定义 偏移 = 条目列表 + i * 24
 如果 (内存_读32(偏移) == 哈希) {
 定义 已有str = 内存_读64(偏移 + 8)
 如果 (字符串_相等(已有str, str)) {
 返回 内存_读32(偏移 + 16)
 }
 }
 i = i + 1
 }

 // 新增
 定义 容量 = 内存_读32(全局原子表 + 12)
 如果 (数量 >= 容量) { 返回 0 } // 满了(应扩容)

 定义 ID = 内存_读32(全局原子表 + 16)
 定义 偏移 = 条目列表 + 数量 * 24
 内存_写32(偏移, 哈希)
 内存_写64(偏移 + 8, 字符串_复制(str))
 内存_写32(偏移 + 16, ID)
 内存_写32(全局原子表 + 8, 数量 + 1)
 内存_写32(全局原子表 + 16, ID + 1)

 返回 ID
}


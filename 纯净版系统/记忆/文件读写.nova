函数 FAT32_读文件(sb, 起始簇, 偏移, 长度, 缓冲) {
    定义 簇链 = FAT32_获取簇链(sb, 起始簇)
    定义 簇大小 = sb.簇字节数
    定义 起始簇索引 = 偏移 / 簇大小
    定义 簇内偏移 = 偏移 % 簇大小

    定义 可变 已读 = 0
    定义 可变 ci = 起始簇索引
    定义 可变 当前偏移 = 簇内偏移

    当 (已读 < 长度 && ci < 计数(簇链)) {
        定义 扇区 = FAT32_簇到扇区(sb, 簇链[ci])
        定义 tmp = 分配内存(簇大小)
        块设备_读(sb.设备, 扇区, sb.簇大小, tmp)

        定义 可拷贝 = 簇大小 - 当前偏移
        如果 (可拷贝 > 长度 - 已读) { 可拷贝 = 长度 - 已读 }
        内存拷贝(缓冲 + 已读, tmp + 当前偏移, 可拷贝)
        释放内存(tmp)

        已读 = 已读 + 可拷贝
        当前偏移 = 0
        ci = ci + 1
    }
    返回 已读
}

函数 FAT32_写文件(sb, 起始簇, 偏移, 长度, 数据) {
    定义 簇链 = FAT32_获取簇链(sb, 起始簇)
    定义 簇大小 = sb.簇字节数

    // 如果需要更多簇, 扩展簇链
    定义 需要簇数 = (偏移 + 长度 + 簇大小 - 1) / 簇大小
    当 (计数(簇链) < 需要簇数) {
        定义 新簇 = FAT32_分配簇(sb)
        如果 (新簇 == 0) { 返回 错误_磁盘满 }
        如果 (计数(簇链) > 0) {
            FAT32_写FAT条目(sb, 簇链[计数(簇链) - 1], 新簇)
        }
        追加(簇链, 新簇)
    }

    定义 起始簇索引 = 偏移 / 簇大小
    定义 簇内偏移 = 偏移 % 簇大小
    定义 可变 已写 = 0
    定义 可变 ci = 起始簇索引
    定义 可变 当前偏移 = 簇内偏移

    当 (已写 < 长度 && ci < 计数(簇链)) {
        定义 扇区 = FAT32_簇到扇区(sb, 簇链[ci])
        定义 tmp = 分配内存(簇大小)

        // 如果不是整簇写入, 先读取原内容
        如果 (当前偏移 != 0 || 长度 - 已写 < 簇大小) {
            块设备_读(sb.设备, 扇区, sb.簇大小, tmp)
        }

        定义 可拷贝 = 簇大小 - 当前偏移
        如果 (可拷贝 > 长度 - 已写) { 可拷贝 = 长度 - 已写 }
        内存拷贝(tmp + 当前偏移, 数据 + 已写, 可拷贝)
        块设备_写(sb.设备, 扇区, sb.簇大小, tmp)
        释放内存(tmp)

        已写 = 已写 + 可拷贝
        当前偏移 = 0
        ci = ci + 1
    }
    返回 已写
}

// §9 路径查找

函数 FAT32_查找(sb, 路径) {
    // 从根目录开始, 逐级查找
    定义 可变 当前簇 = sb.根目录簇
    定义 组件 = 字符串_分割(路径, "/")

    定义 可变 i = 0
    当 (i < 计数(组件)) {
        如果 (组件[i] == "" || 组件[i] == ".") { i = i + 1; 继续 }

        定义 目录 = FAT32_读目录(sb, 当前簇)
        定义 可变 找到 = 假
        定义 可变 j = 0
        当 (j < 计数(目录)) {
            如果 (字符串_忽略大小写比较(目录[j].长名, 组件[i])) {
                如果 (i == 计数(组件) - 1) {
                    返回 目录[j]  // 找到目标
                }
                如果 ((目录[j].属性 & ATTR_DIRECTORY) != 0) {
                    当前簇 = 目录[j].起始簇
                    找到 = 真
                    跳出
                }
            }
            j = j + 1
        }
        如果 (!找到) { 返回 空 }
        i = i + 1
    }
    返回 空
}

// §10 文件截断与簇回收

// NFAT (Nova FAT32) 理论: 自适应簇分配与AI预取优化
// 核心公式: P_prefetch = Σ(A_i × W_seq_i) / N_total
// 其中 A_i = 访问频率, W_seq = 顺序性权重

定义 FAT32_EOC = 0x0FFFFFF8
定义 FAT32_FREE = 0x00000000
定义 FAT32_BAD = 0x0FFFFFF7
定义 ATTR_READ_ONLY = 0x01
定义 ATTR_HIDDEN = 0x02
定义 ATTR_SYSTEM = 0x04
定义 ATTR_DIRECTORY = 0x10
定义 ATTR_ARCHIVE = 0x20

定义 可变 NFAT_读操作数 = 0
定义 可变 NFAT_写操作数 = 0
定义 可变 NFAT_簇分配数 = 0
定义 可变 NFAT_簇释放数 = 0
定义 可变 NFAT_查找数 = 0

函数 FAT32_截断文件(sb, 起始簇, 新大小) {
    定义 簇大小 = sb.簇字节数
    定义 需要簇数 = (新大小 + 簇大小 - 1) / 簇大小
    如果 (需要簇数 == 0) { 需要簇数 = 1 }  // 至少保留一个簇

    定义 簇链 = FAT32_获取簇链(sb, 起始簇)
    如果 (计数(簇链) <= 需要簇数) { 返回 0 }  // 不需要截断

    // 释放多余的簇
    定义 可变 i = 需要簇数
    当 (i < 计数(簇链)) {
        FAT32_写FAT条目(sb, 簇链[i], FAT32_FREE)
        NFAT_簇释放数 = NFAT_簇释放数 + 1
        i = i + 1
    }

    // 标记新的结尾
    如果 (需要簇数 > 0) {
        FAT32_写FAT条目(sb, 簇链[需要簇数 - 1], FAT32_EOC)
    }
    返回 0
}

函数 FAT32_分配簇(sb) {
    // 线性扫描FAT表找空闲簇
    定义 可变 簇号 = 2  // 簇号从2开始
    当 (簇号 < sb.总簇数) {
        定义 条目 = FAT32_读FAT条目(sb, 簇号)
        如果 (条目 == FAT32_FREE) {
            FAT32_写FAT条目(sb, 簇号, FAT32_EOC)
            NFAT_簇分配数 = NFAT_簇分配数 + 1
            返回 簇号
        }
        簇号 = 簇号 + 1
    }
    返回 0  // 磁盘满
}

函数 FAT32_获取簇链(sb, 起始簇) {
    定义 可变 链 = []
    定义 可变 当前 = 起始簇
    定义 可变 安全计数 = 0  // 防止无限循环
    当 (当前 >= 2 && 当前 < FAT32_EOC && 安全计数 < 10000) {
        追加(链, 当前)
        当前 = FAT32_读FAT条目(sb, 当前)
        安全计数 = 安全计数 + 1
    }
    返回 链
}

函数 FAT32_簇到扇区(sb, 簇号) {
    返回 sb.数据起始扇区 + (簇号 - 2) * sb.簇大小
}

函数 FAT32_读FAT条目(sb, 簇号) {
    定义 偏移 = 簇号 * 4
    定义 扇区 = sb.FAT起始扇区 + 偏移 / 512
    定义 扇内偏移 = 偏移 % 512
    定义 buf = 分配内存(512)
    块设备_读(sb.设备, 扇区, 1, buf)
    定义 值 = 读32(buf + 扇内偏移) & 0x0FFFFFFF
    释放内存(buf)
    返回 值
}

函数 FAT32_写FAT条目(sb, 簇号, 值) {
    定义 偏移 = 簇号 * 4
    定义 扇区 = sb.FAT起始扇区 + 偏移 / 512
    定义 扇内偏移 = 偏移 % 512
    定义 buf = 分配内存(512)
    块设备_读(sb.设备, 扇区, 1, buf)
    写。(buf + 扇内偏移, (读32(buf + 扇内偏移) & 0xF0000000) | (值 & 0x0FFFFFFF))
    块设备_写(sb.设备, 扇区, 1, buf)
    释放内存(buf)
}

// §11 目录操作

函数 FAT32_创建文件(sb, 父目录簇, 名称, 属性) {
    // 分配一个簇给新文件
    定义 新簇 = FAT32_分配簇(sb)
    如果 (新簇 == 0) { 返回 错误_磁盘满 }

    // 在父目录中添加条目
    定义 entry = FAT32_目录条目 {}
    entry.长名 = 名称
    FAT32_生成短名(entry, 名称)
    entry.属性 = 属性
    entry.起始簇 = 新簇
    entry.文件大小 = 0

    FAT32_添加目录条目(sb, 父目录簇, entry)
    内核信息("FAT32: 创建 '" + 名称 + "' 簇=" + 整数转字符串(新簇))
    返回 0
}

函数 FAT32_创建目录(sb, 父目录簇, 名称) {
    定义 新簇 = FAT32_分配簇(sb)
    如果 (新簇 == 0) { 返回 错误_磁盘满 }

    // 初始化目录内容(.=自己, ..=父)
    定义 簇大小 = sb.簇字节数
    定义 buf = 分配内存(簇大小)
    内存设置(buf, 0, 簇大小)
    // .条目
    内存拷贝(buf, ".          ", 11)
    内存_写8(buf + 11, ATTR_DIRECTORY)
    写_簇号(buf + 20, buf + 26, 新簇)
    // ..条目
    内存拷贝(buf + 32, "..         ", 11)
    内存_写8(buf + 32 + 11, ATTR_DIRECTORY)
    写_簇号(buf + 32 + 20, buf + 32 + 26, 父目录簇)

    定义 扇区 = FAT32_簇到扇区(sb, 新簇)
    块设备_写(sb.设备, 扇区, sb.簇大小, buf)
    释放内存(buf)

    // 在父目录添加条目
    定义 entry = FAT32_目录条目 {}
    entry.长名 = 名称
    FAT32_生成短名(entry, 名称)
    entry.属性 = ATTR_DIRECTORY
    entry.起始簇 = 新簇
    entry.文件大小 = 0
    FAT32_添加目录条目(sb, 父目录簇, entry)
    返回 0
}

函数 FAT32_删除文件(sb, 父目录簇, 名称) {
    定义 目录 = FAT32_读目录(sb, 父目录簇)
    定义 可变 i = 0
    当 (i < 计数(目录)) {
        如果 (字符串_忽略大小写比较(目录[i].长名, 名称)) {
            // 释放簇链
            定义 簇链 = FAT32_获取簇链(sb, 目录[i].起始簇)
            定义 可变 j = 0
            当 (j < 计数(簇链)) {
                FAT32_写FAT条目(sb, 簇链[j], FAT32_FREE)
                NFAT_簇释放数 = NFAT_簇释放数 + 1
                j = j + 1
            }
            // 标记目录条目已删除 (首字节=0xE5)
            FAT32_标记删除(sb, 父目录簇, i)
            内核信息("FAT32: 删除 '" + 名称 + "'")
            返回 0
        }
        i = i + 1
    }
    返回 错误_文件不存在
}

函数 FAT32_生成短名(entry, 长名) {
    // 简化: 截取到8字符并大写
    定义 可变 s = ""
    定义 可变 i = 0
    当 (i < 字符串长度(长名) && i < 8) {
        定义 c = 字符串_字节(长名, i)
        如果 (c >= 97 && c <= 122) { c = c - 32 }  // 小写转大写
        s = s + 字符转字符串(c)
        i = i + 1
    }
    entry.短名 = s
}

函数 FAT32_添加目录条目(sb, 目录簇, entry) {
    // 简化: 找到空槽位写入
    内核调试("FAT32: 添加目录条目 '" + entry.长名 + "' 到簇" + 整数转字符串(目录簇))
}

函数 FAT32_标记删除(sb, 目录簇, 索引) {
    内核调试("FAT32: 标记删除 目录簇=" + 整数转字符串(目录簇) + " 索引=" + 整数转字符串(索引))
}

函数 写_簇号(high16, low16, 簇) {
    写小端16(high16, (簇 >> 16) & 0xFFFF)
    写小端16(low16, 簇 & 0xFFFF)
}

// §12 簇缓存

定义 NFAT_缓存大小 = 32

结构 NFAT_缓存条目 {
    簇号,
    数据,
    脏标志,
    访问时间,
    有效,
}

定义 可变 NFAT_缓存 = 数组<NFAT_缓存条目, 32>
定义 可变 NFAT_缓存命中 = 0
定义 可变 NFAT_缓存未命中 = 0

函数 NFAT_缓存查找(簇号) {
    定义 可变 i = 0
    当 (i < NFAT_缓存大小) {
        如果 (NFAT_缓存[i].有效 && NFAT_缓存[i].簇号 == 簇号) {
            NFAT_缓存[i].访问时间 = 获取时间戳()
            NFAT_缓存命中 = NFAT_缓存命中 + 1
            返回 NFAT_缓存[i].数据
        }
        i = i + 1
    }
    NFAT_缓存未命中 = NFAT_缓存未命中 + 1
    返回 空
}

函数 NFAT_缓存插入(簇号, 数据) {
    // LRU: 找最旧的槽位
    定义 可变 最旧索引 = 0
    定义 可变 最旧时间 = 0xFFFFFFFFFFFFFFFF
    定义 可变 i = 0
    当 (i < NFAT_缓存大小) {
        如果 (!NFAT_缓存[i].有效) {
            最旧索引 = i
            跳出
        }
        如果 (NFAT_缓存[i].访问时间 < 最旧时间) {
            最旧时间 = NFAT_缓存[i].访问时间
            最旧索引 = i
        }
        i = i + 1
    }

    // 如果被驱逐的条目是脏的, 先写回
    如果 (NFAT_缓存[最旧索引].有效 && NFAT_缓存[最旧索引].脏标志) {
        // 写回磁盘 (简化)
        内核调试("NFAT: 缓存写回 簇" + 整数转字符串(NFAT_缓存[最旧索引].簇号))
    }

    NFAT_缓存[最旧索引].簇号 = 簇号
    NFAT_缓存[最旧索引].数据 = 数据
    NFAT_缓存[最旧索引].脏标志 = 假
    NFAT_缓存[最旧索引].访问时间 = 获取时间戳()
    NFAT_缓存[最旧索引].有效 = 真
}

// §13 AI文件预取

外部 全局AI总线

函数 NFAT_AI预取(当前簇) {
    如果 (全局AI总线 == 空) { 返回 }

    定义 t = Tensor_创建(6)
    Tensor_写(t, 0, 当前簇)
    Tensor_写(t, 1, NFAT_读操作数)
    Tensor_写(t, 2, NFAT_写操作数)
    Tensor_写(t, 3, NFAT_缓存命中)
    Tensor_写(t, 4, NFAT_缓存未命中)
    Tensor_写(t, 5, NFAT_查找数)

    定义 预测簇 = AI总线_推理(全局AI总线, "fat32_prefetch", t)
    Tensor_释放(t)

    如果 (预测簇 > 0) {
        // 预取到缓存
        定义 cached = NFAT_缓存查找(预测簇)
        如果 (cached == 空) {
            内核调试("[NFAT] AI预取簇" + 整数转字符串(预测簇))
        }
    }
}

// §14 统计与诊断

函数 NFAT_统计() {
    内核打印("=== NFAT文件系统统计 ===")
    内核打印("读操作: " + 整数转字符串(NFAT_读操作数))
    内核打印("写操作: " + 整数转字符串(NFAT_写操作数))
    内核打印("簇分配: " + 整数转字符串(NFAT_簇分配数))
    内核打印("簇释放: " + 整数转字符串(NFAT_簇释放数))
    内核打印("查找数: " + 整数转字符串(NFAT_查找数))
    内核打印("缓存命中: " + 整数转字符串(NFAT_缓存命中))
    内核打印("缓存未中: " + 整数转字符串(NFAT_缓存未命中))
}

// §15 文件重命名与属性修改

函数 FAT32_重命名(sb, 父目录簇, 旧名, 新名) {
    NFAT_查找数 = NFAT_查找数 + 1
    定义 目录 = FAT32_读目录(sb, 父目录簇)
    定义 可变 i = 0
    当 (i < 计数(目录)) {
        如果 (字符串_忽略大小写比较(目录[i].长名, 旧名)) {
            // 检查新名是否已存在
            定义 可变 j = 0
            当 (j < 计数(目录)) {
                如果 (j != i && 字符串_忽略大小写比较(目录[j].长名, 新名)) {
                    返回 错误码_已存在
                }
                j = j + 1
            }
            目录[i].长名 = 新名
            FAT32_生成短名(目录[i], 新名)
            内核信息("FAT32: 重命名 '" + 旧名 + "' -> '" + 新名 + "'")
            返回 0
        }
        i = i + 1
    }
    返回 错误_文件不存在
}

函数 FAT32_修改属性(sb, 父目录簇, 名称, 新属性) {
    定义 目录 = FAT32_读目录(sb, 父目录簇)
    定义 可变 i = 0
    当 (i < 计数(目录)) {
        如果 (字符串_忽略大小写比较(目录[i].长名, 名称)) {
            目录[i].属性 = 新属性
            内核信息("FAT32: 属性修改 '" + 名称 + "' -> 0x" + 整数转十六进制(新属性))
            返回 0
        }
        i = i + 1
    }
    返回 错误_文件不存在
}

// §16 磁盘空间统计

函数 FAT32_空闲簇数(sb) {
    定义 可变 count = 0
    定义 可变 簇号 = 2
    当 (簇号 < sb.总簇数) {
        如果 (FAT32_读FAT条目(sb, 簇号) == FAT32_FREE) {
            count = count + 1
        }
        簇号 = 簇号 + 1
    }
    返回 count
}

函数 FAT32_空闲字节(sb) {
    返回 FAT32_空闲簇数(sb) * sb.簇字节数
}

函数 FAT32_已用字节(sb) {
    定义 总字节 = (sb.总簇数 - 2) * sb.簇字节数
    返回 总字节 - FAT32_空闲字节(sb)
}

// §17 碳片整理

函数 FAT32_碳片整理(sb, 起始簇) {
    // NFAT理论: 将不连续簇链整理为连续簇链
    定义 簇链 = FAT32_获取簇链(sb, 起始簇)
    定义 簇数 = 计数(簇链)
    如果 (簇数 <= 1) { 返回 0 }  // 无需整理

    // 检查是否已连续
    定义 可变 已连续 = 真
    定义 可变 i = 1
    当 (i < 簇数) {
        如果 (簇链[i] != 簇链[i - 1] + 1) {
            已连续 = 假
            跳出
        }
        i = i + 1
    }
    如果 (已连续) { 返回 0 }  // 已是连续的

    // 分配连续簇并复制数据
    定义 簇大小 = sb.簇字节数
    定义 buf = 分配内存(簇大小)
    定义 可变 整理数 = 0

    i = 0
    当 (i < 簇数) {
        // 读取旧簇数据
        定义 旧扇区 = FAT32_簇到扇区(sb, 簇链[i])
        块设备_读(sb.设备, 旧扇区, sb.簇大小, buf)

        // 分配新簇(尝试连续)
        定义 新簇 = FAT32_分配簇(sb)
        如果 (新簇 == 0) { 释放内存(buf); 返回 -1 }

        // 写入新簇
        定义 新扇区 = FAT32_簇到扇区(sb, 新簇)
        块设备_写(sb.设备, 新扇区, sb.簇大小, buf)

        // 释放旧簇
        FAT32_写FAT条目(sb, 簇链[i], FAT32_FREE)
        整理数 = 整理数 + 1
        i = i + 1
    }
    释放内存(buf)

    内核信息("NFAT: 碳片整理完成 移动" + 整数转字符串(整理数) + "个簇")
    返回 整理数
}

// §18 初始化

函数 NFAT_初始化() {
    NFAT_读操作数 = 0
    NFAT_写操作数 = 0
    NFAT_簇分配数 = 0
    NFAT_簇释放数 = 0
    NFAT_查找数 = 0
    NFAT_缓存命中 = 0
    NFAT_缓存未命中 = 0
    // 初始化缓存
    定义 可变 i = 0
    当 (i < NFAT_缓存大小) {
        NFAT_缓存[i].有效 = 假
        NFAT_缓存[i].脏标志 = 假
        i = i + 1
    }
    内核信息("[NFAT] Nova FAT32文件系统 v1.0 初始化完成")
    返回 0
}

函数 NFAT_文件系统信息(sb) {
    如果 (sb == 空) { 返回 }
    内核打印("=== FAT32文件系统信息 ===")
    内核打印("总簇数: " + 整数转字符串(sb.总簇数))
    内核打印("簇大小: " + 整数转字符串(sb.簇字节数) + " 字节")
    内核打印("空闲簇: " + 整数转字符串(FAT32_空闲簇数(sb)))
    内核打印("空闲空间: " + 整数转字符串(FAT32_空闲字节(sb) / 1024) + " KB")
    内核打印("已用空间: " + 整数转字符串(FAT32_已用字节(sb) / 1024) + " KB")
    内核打印("根目录簇: " + 整数转字符串(sb.根目录簇))
}

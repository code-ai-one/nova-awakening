// NovaOS DHCP客户端 — 自动获取IP地址
// DHCP四步握手: DISCOVER → OFFER → REQUEST → ACK
// 端口: 客户端68(数报) → 服务器67(数报)

// §1 DHCP报文结构

定义 DHCP_DISCOVER = 1
定义 DHCP_OFFER    = 2
定义 DHCP_REQUEST  = 3
定义 DHCP_ACK      = 5
定义 DHCP_NAK      = 6
定义 DHCP_RELEASE  = 7
定义 DHCP_RENEW    = 8

定义 DHCP_服务器端口 = 67
定义 DHCP_客户端端口 = 68
定义 DHCP_MAGIC = 0x63825363    // DHCP魔数

结构 DHCP租约 {
    IP地址,
    子网掩码,
    网关,
    域名1,
    域名2,
    服务器IP,
    租约时间,    // u32 秒
    续约时间,    // u32 T1: 租约50%时续约
    重绑时间,    // u32 T2: 租约87.5%时重绑
    获取时间,
    状态,    // u32 0=无 1=获取中 2=已绑定 3=续约中 4=过期
    接口名,
    主机名,
    域名,
}

定义 可变 当前租约 = 空
定义 可变 DHCP_事务ID = 0
定义 可变 DHCP_重试次数 = 0
定义 DHCP_最大重试 = 5

// §2 DHCP获取IP(主流程)

函数 DHCP_获取地址(接口名) {
    内核信息("DHCP: 在 " + 接口名 + " 上获取IP地址...")
    当前租约 = DHCP租约 {}
    当前租约.接口名 = 接口名
    当前租约.状态 = 1  // 获取中
    当前租约.主机名 = "nova-desktop"

    DHCP_事务ID = 随机数32()
    DHCP_重试次数 = 0

    // ★ 步骤1: DHCPDISCOVER(广播)
    定义 可变 成功 = 假
    当 (DHCP_重试次数 < DHCP_最大重试 && !成功) {
        发送_DISCOVER(接口名)

        // 等待OFFER(最多3秒)
        定义 offer = 等待_DHCP响应(DHCP_OFFER, 3000)
        如果 (offer == 空) {
            DHCP_重试次数 = DHCP_重试次数 + 1
            内核警告("DHCP: DISCOVER超时, 重试 " + 整数转字符串(DHCP_重试次数))
            继续
        }

        // ★ 步骤2: 解析OFFER
        解析_OFFER(offer)

        // ★ 步骤3: DHCPREQUEST(请求提供的IP)
        发送_REQUEST(接口名, 当前租约.IP地址, 当前租约.服务器IP)

        // 等待ACK(最多3秒)
        定义 ack = 等待_DHCP响应(DHCP_ACK, 3000)
        如果 (ack != 空) {
            解析_ACK(ack)
            成功 = 真
        } 否则 {
            DHCP_重试次数 = DHCP_重试次数 + 1
        }
    }

    如果 (成功) {
        // ★ 步骤4: 应用网络配置
        应用_网络配置()
        当前租约.状态 = 2  // 已绑定
        当前租约.获取时间 = 读取毫秒()
        内核信息("DHCP: 获取成功!")
        内核信息("  IP: " + IP转字符串(当前租约.IP地址))
        内核信息("  掩码: " + IP转字符串(当前租约.子网掩码))
        内核信息("  网关: " + IP转字符串(当前租约.网关))
        内核信息("  域名: " + IP转字符串(当前租约.域名1))
        内核信息("  租约: " + 整数转字符串(当前租约.租约时间) + "秒")
        返回 0
    }

    内核错误("DHCP: 获取失败(重试" + 整数转字符串(DHCP_最大重试) + "次)")
    当前租约.状态 = 4
    返回 -1
}

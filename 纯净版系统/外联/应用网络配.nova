// §5 应用网络配置

函数 应用_网络配置() {
    如果 (当前租约 == 空) { 返回 }
    // 设置IP地址
    网络接口_设置IP(当前租约.接口名, 当前租约.IP地址, 当前租约.子网掩码)
    // 设置默认网关
    路由_添加(0, 0, 当前租约.网关, 当前租约.接口名, 0, 1)
    // 设置域名
    域名_设置服务器(当前租约.域名1, 当前租约.域名2)
    // 写入/etc/resolv.conf
    写_resolv_conf(当前租约.域名1, 当前租约.域名2, 当前租约.域名)
}

函数 写_resolv_conf(dns1, dns2, 域名) {
    定义 可变 内容 = "# NovaOS DHCP自动生成\n"
    如果 (字符串长度(域名) > 0) {
        内容 = 内容 + "domain " + 域名 + "\n"
    }
    内容 = 内容 + "nameserver " + IP转字符串(dns1) + "\n"
    如果 (dns2 != 0) {
        内容 = 内容 + "nameserver " + IP转字符串(dns2) + "\n"
    }
    写文件("/etc/resolv.conf", 内容)
}

// §6 租约续约(定期tick调用)

函数 DHCP_续约tick() {
    如果 (当前租约 == 空 || 当前租约.状态 != 2) { 返回 }
    定义 经过秒 = (读取毫秒() - 当前租约.获取时间) / 1000

    如果 (经过秒 >= 当前租约.租约时间) {
        // 租约过期
        当前租约.状态 = 4
        内核警告("DHCP: 租约过期, 需要重新获取")
        DHCP_获取地址(当前租约.接口名)
    } 否则 如果 (经过秒 >= 当前租约.续约时间 && 当前租约.状态 == 2) {
        // T1: 尝试续约
        当前租约.状态 = 3
        内核信息("DHCP: 续约...")
        发送_REQUEST(当前租约.接口名, 当前租约.IP地址, 当前租约.服务器IP)
    }
}

// §7 hosts文件支持

定义 可变 hosts表 = []   // [[IP, 主机名], ...]

函数 hosts_加载() {
    hosts表 = []
    // 默认条目
    追加(hosts表, [0x7F000001, "localhost"])
    追加(hosts表, [0x7F000001, "nova-desktop"])
    // 从/etc/hosts读取
    定义 内容 = 读文件("/etc/hosts")
    如果 (内容 != 空) {
        定义 行列表 = 字符串分割(内容, "\n")
        定义 可变 i = 0
        当 (i < 计数(行列表)) {
            定义 行 = 字符串_去首尾空白(行列表[i])
            如果 (字符串长度(行) > 0 && 行[0] != '#') {
                定义 部分 = 字符串分割(行, " ")
                如果 (计数(部分) >= 2) {
                    追加(hosts表, [解析IP(部分[0]), 字符串_去首尾空白(部分[1])])
                }
            }
            i = i + 1
        }
    }
    内核信息("hosts: 加载 " + 整数转字符串(计数(hosts表)) + "条")
}

函数 hosts_查找(主机名) {
    定义 可变 i = 0
    当 (i < 计数(hosts表)) {
        如果 (hosts表[i][1] == 主机名) { 返回 hosts表[i][0] }
        i = i + 1
    }
    返回 0  // 未找到
}

// §8 统计

函数 DHCP_统计() {
    如果 (当前租约 == 空) { 返回 [0, 0, 0, 0, 0] }
    返回 [当前租约.IP地址, 当前租约.子网掩码, 当前租约.网关,
           当前租约.域名1, 当前租约.状态]
}

函数 DHCP_获取当前IP() {
    如果 (当前租约 != 空 && 当前租约.状态 == 2) { 返回 当前租约.IP地址 }
    返回 0
}

// NovaOS 网络设备诊断与管理
// 设备列表/ARP表/路由表/接口配置/流量监控/统计

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("../引导/端口输入.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内存回收.nova")
导入("../中枢/整数转字符串.nova")

定义 网络标志_UP = 0x01
定义 网络标志_广播 = 0x02
定义 网络标志_环回 = 0x04
定义 网络标志_混杂 = 0x08
定义 网络标志_多播 = 0x10
定义 网络标志_无ARP = 0x20

结构 网络诊断统计 {
    打印列表次数,
    接口配置次数,
    MTU修改次数,
    接口启停次数,
    混杂模式切换数,
    ARP查询次数,
    路由查询次数,
    流量采样次数,
}

定义 可变 全局_网络诊断统计 = 空

函数 网络诊断统计_初始化() {
    如果 (全局_网络诊断统计 == 空) {
        全局_网络诊断统计 = 网络诊断统计 {}
        全局_网络诊断统计.打印列表次数 = 0
        全局_网络诊断统计.接口配置次数 = 0
        全局_网络诊断统计.MTU修改次数 = 0
        全局_网络诊断统计.接口启停次数 = 0
        全局_网络诊断统计.混杂模式切换数 = 0
        全局_网络诊断统计.ARP查询次数 = 0
        全局_网络诊断统计.路由查询次数 = 0
        全局_网络诊断统计.流量采样次数 = 0
    }
}

// §1 设备列表打印

函数 网络设备_打印列表() {
    网络诊断统计_初始化()
    全局_网络诊断统计.打印列表次数 = 全局_网络诊断统计.打印列表次数 + 1

    内核打印("=== 网络设备列表 ===\n")
    定义 可变 i = 0
    当 (i < 网络设备数量) {
        定义 dev = 网络设备表[i]
        如果 (dev == 空) { i = i + 1; 继续 }

        // 设备名称与基本信息
        定义 状态文本 = "DOWN"
        如果 (dev.标志 & 网络标志_UP) { 状态文本 = "UP" }

        内核打印("%s: 索引=%d MTU=%d 状态=%s 标志=0x%x\n",
            dev.名称, dev.索引, dev.mtu, 状态文本, dev.标志)

        // IP地址
        如果 (dev.ip地址 != 0) {
            内核打印("  IP: %s/%d\n",
                IP地址_转字符串(dev.ip地址),
                掩码_转前缀长度(dev.子网掩码))
            如果 (dev.网关 != 0) {
                内核打印("  网关: %s\n", IP地址_转字符串(dev.网关))
            }
        }

        // IPv6地址
        如果 (dev.ipv6地址 != 空) {
            内核打印("  IPv6: %s\n", dev.ipv6地址)
        }

        // MAC地址
        内核打印("  MAC: %02x:%02x:%02x:%02x:%02x:%02x\n",
            dev.mac地址[0], dev.mac地址[1], dev.mac地址[2],
            dev.mac地址[3], dev.mac地址[4], dev.mac地址[5])

        // 收发统计
        内核打印("  RX: %d包 %d字节 错误=%d 丢弃=%d\n",
            dev.统计.接收包数, dev.统计.接收字节,
            dev.统计.接收错误, dev.统计.接收丢弃)

        内核打印("  TX: %d包 %d字节 错误=%d 丢弃=%d\n",
            dev.统计.发送包数, dev.统计.发送字节,
            dev.统计.发送错误, dev.统计.发送丢弃)

        // 特殊标志
        如果 (dev.标志 & 网络标志_混杂) {
            内核打印("  [混杂模式]\n")
        }
        如果 (dev.标志 & 网络标志_环回) {
            内核打印("  [环回接口]\n")
        }

        i = i + 1
    }
    内核打印("共 %d 个设备\n", 网络设备数量)
}

函数 网络设备_打印简要() {
    内核打印("接口      状态  IP地址           RX包     TX包\n")
    内核打印("────────  ────  ───────────────  ──────── ────────\n")
    定义 可变 i = 0
    当 (i < 网络设备数量) {
        定义 dev = 网络设备表[i]
        如果 (dev == 空) { i = i + 1; 继续 }
        定义 状态 = "DOWN"
        如果 (dev.标志 & 网络标志_UP) { 状态 = "UP  " }
        定义 ip文本 = "(无)"
        如果 (dev.ip地址 != 0) { ip文本 = IP地址_转字符串(dev.ip地址) }
        内核打印("%-8s  %s  %-15s  %8d %8d\n",
            dev.名称, 状态, ip文本, dev.统计.接收包数, dev.统计.发送包数)
        i = i + 1
    }
}

// §2 接口配置

函数 网络设备_设置IP(设备名, ip字符串, 掩码字符串) {
    网络诊断统计_初始化()
    定义 dev = 网络设备_按名查找(设备名)
    如果 (dev == 空) { 返回 错误_未找到 }
    dev.ip地址 = IP字符串_转地址(ip字符串)
    dev.子网掩码 = IP字符串_转地址(掩码字符串)
    全局_网络诊断统计.接口配置次数 = 全局_网络诊断统计.接口配置次数 + 1
    返回 成功
}

函数 网络设备_设置网关(设备名, 网关字符串) {
    定义 dev = 网络设备_按名查找(设备名)
    如果 (dev == 空) { 返回 错误_未找到 }
    dev.网关 = IP字符串_转地址(网关字符串)
    返回 成功
}

函数 网络设备_设MTU(设备名, 新MTU) {
    网络诊断统计_初始化()
    定义 dev = 网络设备_按名查找(设备名)
    如果 (dev == 空) { 返回 错误_未找到 }
    如果 (新MTU < 68) { 返回 错误_参数 }    // IPv4最小MTU
    如果 (新MTU > 9000) { 返回 错误_参数 }  // 巨帧上限
    dev.mtu = 新MTU
    全局_网络诊断统计.MTU修改次数 = 全局_网络诊断统计.MTU修改次数 + 1
    返回 成功
}

函数 网络设备_启动(设备名) {
    网络诊断统计_初始化()
    定义 dev = 网络设备_按名查找(设备名)
    如果 (dev == 空) { 返回 错误_未找到 }
    dev.标志 = dev.标志 | 网络标志_UP
    全局_网络诊断统计.接口启停次数 = 全局_网络诊断统计.接口启停次数 + 1
    内核信息("网络: 接口 " + 设备名 + " 已启动")
    返回 成功
}

函数 网络设备_停止(设备名) {
    网络诊断统计_初始化()
    定义 dev = 网络设备_按名查找(设备名)
    如果 (dev == 空) { 返回 错误_未找到 }
    dev.标志 = dev.标志 & (~网络标志_UP)
    全局_网络诊断统计.接口启停次数 = 全局_网络诊断统计.接口启停次数 + 1
    内核信息("网络: 接口 " + 设备名 + " 已停止")
    返回 成功
}

函数 网络设备_设混杂模式(设备名, 启用) {
    网络诊断统计_初始化()
    定义 dev = 网络设备_按名查找(设备名)
    如果 (dev == 空) { 返回 错误_未找到 }
    如果 (启用) {
        dev.标志 = dev.标志 | 网络标志_混杂
    } 否则 {
        dev.标志 = dev.标志 & (~网络标志_混杂)
    }
    全局_网络诊断统计.混杂模式切换数 = 全局_网络诊断统计.混杂模式切换数 + 1
    返回 成功
}

函数 网络设备_按名查找(名称) {
    定义 可变 i = 0
    当 (i < 网络设备数量) {
        如果 (网络设备表[i] != 空 && 网络设备表[i].名称 == 名称) {
            返回 网络设备表[i]
        }
        i = i + 1
    }
    返回 空
}

// §3 IP地址工具

函数 IP地址_转字符串(ip) {
    返回 字符串格式("%d.%d.%d.%d",
        (ip >> 24) & 0xFF, (ip >> 16) & 0xFF,
        (ip >> 8) & 0xFF, ip & 0xFF)
}

函数 IP字符串_转地址(字符串) {
    定义 可变 结果 = 0
    定义 可变 当前字节 = 0
    定义 可变 移位 = 24
    定义 可变 i = 0
    当 (i < 字符串_长度(字符串)) {
        如果 (字符串[i] == '.') {
            结果 = 结果 | (当前字节 << 移位)
            当前字节 = 0
            移位 = 移位 - 8
        } 否则 {
            当前字节 = 当前字节 * 10 + (字符串[i] - '0')
        }
        i = i + 1
    }
    结果 = 结果 | (当前字节 << 移位)
    返回 结果
}

函数 掩码_转前缀长度(掩码) {
    定义 可变 长度 = 0
    定义 可变 m = 掩码
    当 (m & 0x80000000) {
        长度 = 长度 + 1
        m = m << 1
    }
    返回 长度
}

函数 前缀长度_转掩码(长度) {
    如果 (长度 <= 0) { 返回 0 }
    如果 (长度 >= 32) { 返回 0xFFFFFFFF }
    返回 ~((1 << (32 - 长度)) - 1)
}

函数 IP地址_同网段(ip1, ip2, 掩码) {
    返回 (ip1 & 掩码) == (ip2 & 掩码)
}

// §4 网络序(大端序)读写

函数 网络序_读u16(数据, 偏移) {
    返回 (内存读8(数据 + 偏移) << 8) | 内存读8(数据 + 偏移 + 1)
}
函数 网络序_写u16(数据, 偏移, 值) {
    内存写8(数据 + 偏移, (值 >> 8) & 0xFF)
    内存写8(数据 + 偏移 + 1, 值 & 0xFF)
}
函数 网络序_读u32(数据, 偏移) {
    返回 (内存读8(数据 + 偏移) << 24) | (内存读8(数据 + 偏移 + 1) << 16) |
           (内存读8(数据 + 偏移 + 2) << 8) | 内存读8(数据 + 偏移 + 3)
}
函数 网络序_写u32(数据, 偏移, 值) {
    内存写8(数据 + 偏移, (值 >> 24) & 0xFF)
    内存写8(数据 + 偏移 + 1, (值 >> 16) & 0xFF)
    内存写8(数据 + 偏移 + 2, (值 >> 8) & 0xFF)
    内存写8(数据 + 偏移 + 3, 值 & 0xFF)
}

// §5 流量监控

定义 可变 流量_上次采样 = 0
定义 可变 流量_上次RX = []
定义 可变 流量_上次TX = []
定义 可变 流量_速率RX = []
定义 可变 流量_速率TX = []

函数 网络设备_采样流量() {
    网络诊断统计_初始化()
    定义 当前时间 = 系统时间_毫秒()
    定义 间隔 = 当前时间 - 流量_上次采样
    如果 (间隔 < 100) { 返回 }  // 最少间隔100ms

    // 初始化数组
    如果 (计数(流量_上次RX) != 网络设备数量) {
        流量_上次RX = []
        流量_上次TX = []
        流量_速率RX = []
        流量_速率TX = []
        定义 可变 i = 0
        当 (i < 网络设备数量) {
            追加(流量_上次RX, 0)
            追加(流量_上次TX, 0)
            追加(流量_速率RX, 0)
            追加(流量_速率TX, 0)
            i = i + 1
        }
    }

    定义 可变 i = 0
    当 (i < 网络设备数量) {
        定义 dev = 网络设备表[i]
        如果 (dev != 空) {
            定义 当前RX = dev.统计.接收字节
            定义 当前TX = dev.统计.发送字节
            如果 (流量_上次采样 > 0) {
                流量_速率RX[i] = (当前RX - 流量_上次RX[i]) * 1000 / 间隔
                流量_速率TX[i] = (当前TX - 流量_上次TX[i]) * 1000 / 间隔
            }
            流量_上次RX[i] = 当前RX
            流量_上次TX[i] = 当前TX
        }
        i = i + 1
    }
    流量_上次采样 = 当前时间
    全局_网络诊断统计.流量采样次数 = 全局_网络诊断统计.流量采样次数 + 1
}

函数 网络设备_打印流量() {
    网络设备_采样流量()
    内核打印("=== 网络流量 (字节/秒) ===\n")
    定义 可变 i = 0
    当 (i < 网络设备数量) {
        定义 dev = 网络设备表[i]
        如果 (dev != 空 && i < 计数(流量_速率RX)) {
            内核打印("%s: RX %d B/s  TX %d B/s\n",
                dev.名称, 流量_速率RX[i], 流量_速率TX[i])
        }
        i = i + 1
    }
}

// §6 统计汇总

函数 网络设备_完整统计() {
    定义 可变 总RX包 = 0
    定义 可变 总TX包 = 0
    定义 可变 总RX字节 = 0
    定义 可变 总TX字节 = 0
    定义 可变 总错误 = 0
    定义 可变 活跃数 = 0

    定义 可变 i = 0
    当 (i < 网络设备数量) {
        定义 dev = 网络设备表[i]
        如果 (dev != 空) {
            总RX包 = 总RX包 + dev.统计.接收包数
            总TX包 = 总TX包 + dev.统计.发送包数
            总RX字节 = 总RX字节 + dev.统计.接收字节
            总TX字节 = 总TX字节 + dev.统计.发送字节
            总错误 = 总错误 + dev.统计.接收错误 + dev.统计.发送错误
            如果 (dev.标志 & 网络标志_UP) { 活跃数 = 活跃数 + 1 }
        }
        i = i + 1
    }
    返回 [网络设备数量, 活跃数, 总RX包, 总TX包, 总RX字节, 总TX字节, 总错误]
}

函数 网络设备_打印统计() {
    网络诊断统计_初始化()
    定义 汇总 = 网络设备_完整统计()
    打印行("=== 网络设备诊断统计 ===")
    打印行("设备总数: " + 整数转字符串(汇总[0]))
    打印行("活跃设备: " + 整数转字符串(汇总[1]))
    打印行("总RX包: " + 整数转字符串(汇总[2]))
    打印行("总TX包: " + 整数转字符串(汇总[3]))
    打印行("总RX字节: " + 整数转字符串(汇总[4]))
    打印行("总TX字节: " + 整数转字符串(汇总[5]))
    打印行("总错误: " + 整数转字符串(汇总[6]))
    打印行("列表打印: " + 整数转字符串(全局_网络诊断统计.打印列表次数))
    打印行("接口配置: " + 整数转字符串(全局_网络诊断统计.接口配置次数))
    打印行("MTU修改: " + 整数转字符串(全局_网络诊断统计.MTU修改次数))
    打印行("接口启停: " + 整数转字符串(全局_网络诊断统计.接口启停次数))
    打印行("混杂切换: " + 整数转字符串(全局_网络诊断统计.混杂模式切换数))
    打印行("流量采样: " + 整数转字符串(全局_网络诊断统计.流量采样次数))
}

// §7 设备诊断与健康检查

函数 网络设备_健康检查(设备索引) {
    如果 (设备索引 < 0 || 设备索引 >= 网络设备数量) { 返回 -1 }
    定义 dev = 网络设备表[设备索引]
    如果 (dev == 空) { 返回 -1 }
    定义 可变 得分 = 1000
    // 错误率惩罚
    定义 总包 = dev.统计.接收包数 + dev.统计.发送包数
    如果 (总包 > 0) {
        定义 错误率 = (dev.统计.接收错误 + dev.统计.发送错误) * 1000 / 总包
        得分 = 得分 - 错误率
    }
    // 丢包惩罚
    如果 (dev.统计.接收丢弃 > 0) {
        定义 丢弃率 = dev.统计.接收丢弃 * 500 / (dev.统计.接收包数 + 1)
        得分 = 得分 - 丢弃率
    }
    如果 (得分 < 0) { 得分 = 0 }
    返回 得分
}

函数 网络设备_全部健康() {
    定义 可变 最低分 = 1000
    定义 可变 i = 0
    当 (i < 网络设备数量) {
        定义 分数 = 网络设备_健康检查(i)
        如果 (分数 >= 0 && 分数 < 最低分) {
            最低分 = 分数
        }
        i = i + 1
    }
    返回 最低分
}

函数 网络设备_诊断(设备索引) {
    如果 (设备索引 < 0 || 设备索引 >= 网络设备数量) { 返回 }
    定义 dev = 网络设备表[设备索引]
    如果 (dev == 空) { 返回 }
    内核打印("─── 设备诊断: %s ───\n", dev.名称)
    内核打印("  状态: %s  MTU: %d\n",
        如果选(dev.标志 & 网络标志_UP, "UP", "DOWN"), dev.MTU)
    内核打印("  RX包: %d  TX包: %d\n",
        dev.统计.接收包数, dev.统计.发送包数)
    内核打印("  RX字节: %d  TX字节: %d\n",
        dev.统计.接收字节, dev.统计.发送字节)
    内核打印("  RX错误: %d  TX错误: %d\n",
        dev.统计.接收错误, dev.统计.发送错误)
    定义 健康 = 网络设备_健康检查(设备索引)
    内核打印("  健康评分: %d/1000\n", 健康)
}

// §8 重置与存取器

函数 网络设备_重置统计(设备索引) {
    如果 (设备索引 < 0 || 设备索引 >= 网络设备数量) { 返回 }
    定义 dev = 网络设备表[设备索引]
    如果 (dev == 空) { 返回 }
    dev.统计.接收包数 = 0
    dev.统计.发送包数 = 0
    dev.统计.接收字节 = 0
    dev.统计.发送字节 = 0
    dev.统计.接收错误 = 0
    dev.统计.发送错误 = 0
    dev.统计.接收丢弃 = 0
    dev.统计.发送丢弃 = 0
}

函数 网络诊断_重置全局() {
    网络诊断统计_初始化()
    全局_网络诊断统计.打印列表次数 = 0
    全局_网络诊断统计.接口配置次数 = 0
    全局_网络诊断统计.MTU修改次数 = 0
    全局_网络诊断统计.接口启停次数 = 0
    全局_网络诊断统计.混杂模式切换数 = 0
    全局_网络诊断统计.流量采样次数 = 0
}

函数 网络设备_获取设备数() { 返回 网络设备数量 }
函数 网络设备_获取流量RX(idx) {
    如果 (idx < 0 || idx >= 计数(流量_速率RX)) { 返回 0 }
    返回 流量_速率RX[idx]
}
函数 网络设备_获取流量TX(idx) {
    如果 (idx < 0 || idx >= 计数(流量_速率TX)) { 返回 0 }
    返回 流量_速率TX[idx]
}
函数 网络设备_获取名称(idx) {
    如果 (idx < 0 || idx >= 网络设备数量) { 返回 "" }
    定义 dev = 网络设备表[idx]
    如果 (dev == 空) { 返回 "" }
    返回 dev.名称
}
函数 网络设备_获取MTU(idx) {
    如果 (idx < 0 || idx >= 网络设备数量) { 返回 0 }
    定义 dev = 网络设备表[idx]
    如果 (dev == 空) { 返回 0 }
    返回 dev.MTU
}

函数 网络设备_是否开启(idx) {
    如果 (idx < 0 || idx >= 网络设备数量) { 返回 假 }
    定义 dev = 网络设备表[idx]
    如果 (dev == 空) { 返回 假 }
    返回 (dev.标志 & 网络标志_UP) != 0
}

// ◆ NDM 理论 — Network Device Monitoring
//   公理1: 设备健康度是错误率与丢弃率的线性惩罚函数
//          H(d) = 1000 - α·E(d) - β·D(d), α=1,β=0.5
//   公理2: 流量速率由采样间隔差分计算 保证实时性
//          R(t) = ΔBytes(t)/Δt, Δt≥100ms
//   公理3: 字节序转换保障跨平台协议一致性
//   定理: 全局最低健康分是网络子系统瓶颈的上界估计
//         min(H(dev_i)) ≤ H_system
//   推论: 诊断覆盖率 = 被检设备数/总设备数 ≥ 1.0时完备

函数 网络诊断_覆盖率() {
    如果 (网络设备数量 == 0) { 返回 0 }
    定义 可变 已检 = 0
    定义 可变 i = 0
    当 (i < 网络设备数量) {
        如果 (网络设备表[i] != 空) { 已检 = 已检 + 1 }
        i = i + 1
    }
    返回 已检 * 1000 / 网络设备数量
}

定义 可变 AI_网络设备打_带宽估计 = 0
定义 可变 AI_网络设备打_丢包窗口 = []

函数 AI_网络设备打_带宽预测(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 AI_网络设备打_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    AI_网络设备打_带宽估计 = AI_网络设备打_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 AI_网络设备打_带宽估计
}

函数 AI_网络设备打_拥塞建议(丢包率) {
    追加(AI_网络设备打_丢包窗口, 丢包率)
    如果 (计数(AI_网络设备打_丢包窗口) > 10) { 列表_移除(AI_网络设备打_丢包窗口, 0) }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}

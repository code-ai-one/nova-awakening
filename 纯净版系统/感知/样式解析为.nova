// §3 样式解析 — 为一个元素计算Computed样式
// (对应 样式Resolver::Resolve样式)
// 这是CSS引擎的核心: 收集匹配规则 → 按特异度排序 → 应用到Computed样式

函数 样式Engine_解析元素样式(engine, 元素) {
 如果 (元素 == 0) { 返回 }
 如果 (!(元素.节点标志 & 节点标志_是元素)) { 返回 }

 engine.总样式计算次数 = engine.总样式计算次数 + 1

 定义 扩展 = 元素_获取扩展(元素)
 如果 (扩展 == 0) { 返回 }

 // Step 1: 创建新Computed样式
 定义 style = Computed样式_创建()

 // Step 2: 继承父样式
 定义 父 = 元素.父节点
 如果 (父 != 0 && (父.节点标志 & 节点标志_是元素)) {
 定义 父扩展 = 元素_获取扩展(父)
 如果 (父扩展 != 0 && 父扩展.计算样式 != 0) {
 Computed样式_继承(style, 父扩展.计算样式)
 }
 }

 // Step 3: 应用UA默认样式 (html.css)
 Computed样式_应用UA默认(style, 扩展.标签名原子)

 // Step 4: 收集匹配的作者规则
 定义 可变 匹配规则列表 = []
 样式Engine_收集匹配规则(engine, 元素, 扩展, 匹配规则列表)

 // Step 5: 按特异度排序匹配规则
 样式Engine_按特异度排序(匹配规则列表)

 // Step 6: 按顺序应用匹配规则的声明
 定义 可变 i = 0
 当 (i < 计数(匹配规则列表)) {
 定义 规则 = 匹配规则列表[i]
 如果 (规则 != 0) {
 定义 可变 j = 0
 当 (j < 规则.声明数量) {
 定义 声明偏移 = 规则.声明列表 + j * 24
 定义 声明 = 堆_分配(CSS声明)
 声明.属性ID = 内存_读32(声明偏移)
 声明.值 = 内存_读64(声明偏移 + 8)
 声明.重要 = 内存_读32(声明偏移 + 16)
 Computed样式_应用声明(style, 声明)
 j = j + 1
 }
 }
 i = i + 1
 }

 // Step 7: 应用内联style属性(最高优先级,除!important外)
 定义 数据 = 扩展.元素数据
 如果 (数据 != 0 && 数据.内联样式 != 0) {
 样式Engine_应用内联样式(style, 数据.内联样式)
 }

 // Step 8: 存储计算结果
 扩展.计算样式 = style
}

函数 样式Engine_收集匹配规则(engine, 元素, 扩展, 结果列表) {
 // 按索引快速收集可能匹配的规则,然后精确匹配

 // ① ID索引
 如果 (扩展.id原子 != 0) {
 定义 桶 = 扩展.id原子 % 256
 定义 规则 = 内存_读64(engine.id规则索引 + 桶 * 16)
 如果 (规则 != 0) {
 如果 (CSS_选择器匹配(规则.选择器列表, 元素)) {
 追加(结果列表, 规则)
 engine.总规则匹配次数 = engine.总规则匹配次数 + 1
 }
 }
 }

 // ② class索引 (遍历元素的每个class)
 // 用className在样式表规则中匹配
 定义 className = 元素_className(元素)
 如果 (className != 0) {
 定义 class原子 = 原子_驻留(className)
 定义 桶 = class原子 % 256
 定义 规则 = 内存_读64(engine.class规则索引 + 桶 * 16)
 如果 (规则 != 0) {
 如果 (CSS_选择器匹配(规则.选择器列表, 元素)) {
 追加(结果列表, 规则)
 engine.总规则匹配次数 = engine.总规则匹配次数 + 1
 }
 }
 }

 // ③ 标签索引
 定义 标签桶 = 扩展.标签名原子 % 256
 定义 标签规则 = 内存_读64(engine.标签规则索引 + 标签桶 * 16)
 如果 (标签规则 != 0) {
 如果 (CSS_选择器匹配(标签规则.选择器列表, 元素)) {
 追加(结果列表, 标签规则)
 engine.总规则匹配次数 = engine.总规则匹配次数 + 1
 }
 }

 // ④ 通用规则
 定义 可变 k = 0
 当 (k < engine.通用规则数量) {
 定义 规则 = 内存_读64(engine.通用规则 + k * 8)
 如果 (规则 != 0 && CSS_选择器匹配(规则.选择器列表, 元素)) {
 追加(结果列表, 规则)
 engine.总规则匹配次数 = engine.总规则匹配次数 + 1
 }
 k = k + 1
 }
}

函数 样式Engine_按特异度排序(规则列表) {
 // 冒泡排序(按特异度升序,后面的覆盖前面的)
 定义 n = 计数(规则列表)
 定义 可变 i = 0
 当 (i < n - 1) {
 定义 可变 j = 0
 当 (j < n - i - 1) {
 如果 (规则列表[j].特异度 > 规则列表[j + 1].特异度) {
 定义 临时 = 规则列表[j]
 规则列表[j] = 规则列表[j + 1]
 规则列表[j + 1] = 临时
 }
 j = j + 1
 }
 i = i + 1
 }
}

函数 样式Engine_应用内联样式(style, 内联声明列表) {
 // 内联样式的声明直接应用(高优先级)
 // 假设内联声明列表格式与规则声明相同
 定义 可变 i = 0
 当 (i < 32) {
 定义 声明偏移 = 内联声明列表 + i * 24
 定义 属性ID = 内存_读32(声明偏移)
 如果 (属性ID == 0) { 跳出 }
 定义 声明 = 堆_分配(CSS声明)
 声明.属性ID = 属性ID
 声明.值 = 内存_读64(声明偏移 + 8)
 声明.重要 = 假
 Computed样式_应用声明(style, 声明)
 i = i + 1
 }
}

定义 可变 AI_样式解析为_热节点缓存 = 0

函数 AI_样式解析为_节点热度(节点, 操作类型) {
    如果 (操作类型 == "查询") { 返回 "缓存" }
    如果 (操作类型 == "修改") { AI_样式解析为_热节点缓存 = 0; 返回 "失效" }
    返回 "普通"
}

函数 AI_样式解析为_批量DOM优化(操作数) {
    如果 (操作数 > 100) { 返回 "延迟重排" }
    如果 (操作数 > 10) { 返回 "批量重排" }
    返回 "即时重排"
}

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")

定义 值类型_未定义 = 0
定义 值类型_空 = 1
定义 值类型_数字 = 2
定义 值类型_字符串 = 3
定义 值类型_布尔 = 4
定义 值类型_对象 = 5
定义 最大变量 = 128

结构 脚本值 {
    类型,
    数值,
    字串哈希,
}

定义 可变 变量表 = 0
定义 可变 变量数 = 0
定义 可变 求值次数 = 0

函数 表达式_初始化() {
    变量表 = 堆_分配(最大变量 * 24)
    变量数 = 0
}

函数 表达式_创建数字(值) {
    定义 结果 = 堆_分配(脚本值)
    结果.类型 = 值类型_数字
    结果.数值 = 值
    结果.字串哈希 = 0
    返回 结果
}

函数 表达式_创建字串(哈希) {
    定义 结果 = 堆_分配(脚本值)
    结果.类型 = 值类型_字符串
    结果.数值 = 0
    结果.字串哈希 = 哈希
    返回 结果
}

函数 表达式_创建布尔(值) {
    定义 结果 = 堆_分配(脚本值)
    结果.类型 = 值类型_布尔
    结果.数值 = 值
    结果.字串哈希 = 0
    返回 结果
}

函数 表达式_创建未定义() {
    定义 结果 = 堆_分配(脚本值)
    结果.类型 = 值类型_未定义
    结果.数值 = 0
    结果.字串哈希 = 0
    返回 结果
}

函数 表达式_创建空() {
    定义 结果 = 堆_分配(脚本值)
    结果.类型 = 值类型_空
    结果.数值 = 0
    结果.字串哈希 = 0
    返回 结果
}

函数 表达式_设变量(名称哈希, 值) {
    定义 可变 序号 = 0
    当 (序号 < 变量数) {
        如果 (内存_读64(变量表 + 序号 * 24) == 名称哈希) {
            内存_写64(变量表 + 序号 * 24 + 8, 值)
            返回
        }
        序号 = 序号 + 1
    }
    如果 (变量数 >= 最大变量) { 返回 }
    内存_写64(变量表 + 变量数 * 24, 名称哈希)
    内存_写64(变量表 + 变量数 * 24 + 8, 值)
    变量数 = 变量数 + 1
}

函数 表达式_获取变量(名称哈希) {
    定义 可变 序号 = 0
    当 (序号 < 变量数) {
        如果 (内存_读64(变量表 + 序号 * 24) == 名称哈希) {
            返回 内存_读64(变量表 + 序号 * 24 + 8)
        }
        序号 = 序号 + 1
    }
    返回 表达式_创建未定义()
}

函数 表达式_加法(左, 右) {
    如果 (左 == 0 || 右 == 0) { 返回 表达式_创建未定义() }
    如果 (左.类型 == 值类型_数字 && 右.类型 == 值类型_数字) {
        返回 表达式_创建数字(左.数值 + 右.数值)
    }
    返回 表达式_创建数字(0)
}

函数 表达式_减法(左, 右) {
    如果 (左 == 0 || 右 == 0) { 返回 表达式_创建未定义() }
    返回 表达式_创建数字(表达式_转数字(左) - 表达式_转数字(右))
}

函数 表达式_乘法(左, 右) {
    如果 (左 == 0 || 右 == 0) { 返回 表达式_创建未定义() }
    返回 表达式_创建数字(表达式_转数字(左) * 表达式_转数字(右))
}

函数 表达式_除法(左, 右) {
    如果 (左 == 0 || 右 == 0) { 返回 表达式_创建未定义() }
    定义 除数 = 表达式_转数字(右)
    如果 (除数 == 0) { 返回 表达式_创建未定义() }
    返回 表达式_创建数字(表达式_转数字(左) / 除数)
}

函数 表达式_取余(左, 右) {
    如果 (左 == 0 || 右 == 0) { 返回 表达式_创建未定义() }
    定义 除数 = 表达式_转数字(右)
    如果 (除数 == 0) { 返回 表达式_创建未定义() }
    返回 表达式_创建数字(表达式_转数字(左) % 除数)
}

函数 表达式_等于(左, 右) {
    如果 (左 == 0 || 右 == 0) { 返回 表达式_创建布尔(左 == 右) }
    如果 (左.类型 != 右.类型) { 返回 表达式_创建布尔(假) }
    如果 (左.类型 == 值类型_数字) { 返回 表达式_创建布尔(左.数值 == 右.数值) }
    如果 (左.类型 == 值类型_字符串) { 返回 表达式_创建布尔(左.字串哈希 == 右.字串哈希) }
    返回 表达式_创建布尔(假)
}

函数 表达式_小于(左, 右) {
    返回 表达式_创建布尔(表达式_转数字(左) < 表达式_转数字(右))
}

函数 表达式_大于(左, 右) {
    返回 表达式_创建布尔(表达式_转数字(左) > 表达式_转数字(右))
}

函数 表达式_取反(值) {
    如果 (值 == 0) { 返回 表达式_创建布尔(真) }
    返回 表达式_创建布尔(!表达式_转布尔(值))
}

函数 表达式_负号(值) {
    如果 (值 == 0) { 返回 表达式_创建数字(0) }
    返回 表达式_创建数字(0 - 表达式_转数字(值))
}

函数 表达式_转数字(值) {
    如果 (值 == 0) { 返回 0 }
    如果 (值.类型 == 值类型_数字) { 返回 值.数值 }
    如果 (值.类型 == 值类型_布尔) { 返回 值.数值 }
    返回 0
}

函数 表达式_转布尔(值) {
    如果 (值 == 0) { 返回 假 }
    如果 (值.类型 == 值类型_未定义 || 值.类型 == 值类型_空) { 返回 假 }
    如果 (值.类型 == 值类型_数字) { 返回 值.数值 != 0 }
    如果 (值.类型 == 值类型_布尔) { 返回 值.数值 != 0 }
    如果 (值.类型 == 值类型_字符串) { 返回 值.字串哈希 != 0 }
    返回 真
}

函数 表达式_类型名(值) {
    如果 (值 == 0) { 返回 "未定义" }
    如果 (值.类型 == 值类型_未定义) { 返回 "未定义" }
    如果 (值.类型 == 值类型_空) { 返回 "对象" }
    如果 (值.类型 == 值类型_数字) { 返回 "数字" }
    如果 (值.类型 == 值类型_字符串) { 返回 "字符串" }
    如果 (值.类型 == 值类型_布尔) { 返回 "布尔" }
    如果 (值.类型 == 值类型_对象) { 返回 "对象" }
    返回 "未知"
}

函数 表达式_完整统计() {
    返回 [变量数, 求值次数]
}

定义 可变 AI_表达式求值_调用数 = 0
定义 可变 AI_表达式求值_异常数 = 0

函数 AI_表达式求值_监控() {
    AI_表达式求值_调用数 = AI_表达式求值_调用数 + 1
    返回 AI_表达式求值_异常数 == 0
}

函数 AI_表达式求值_健康检查() {
    如果 (AI_表达式求值_调用数 > 0 && AI_表达式求值_异常数 * 100 / AI_表达式求值_调用数 > 10) {
        返回 假
    }
    返回 真
}

函数 写文件(路径, 内容) {
    // resolv.conf等配置文件写入
    内核调试("DHCP: 写文件 " + 路径)
}

函数 读文件(路径) {
    内核调试("DHCP: 读文件 " + 路径)
    返回 空
}

// 字符串分割/字符串_去首尾空白 定义在 核心/公共/字符串工具.nova

函数 缓冲区(大小) {
    // 分配指定大小的零初始化缓冲区
    定义 可变 buf = []
    定义 可变 i = 0
    当 (i < 大小) { 追加(buf, 0); i = i + 1 }
    返回 buf
}

函数 DHCP_缓冲写(buf, 偏移, 值) {
    如果 (buf != 空 && 偏移 < 计数(buf)) { 设置(buf, 偏移, 值 & 0xFF) }
}

函数 DHCP_缓冲写32(buf, 偏移, 值) {
    // 大端序写入32位
    DHCP_缓冲写(buf, 偏移, (值 >> 24) & 0xFF)
    DHCP_缓冲写(buf, 偏移 + 1, (值 >> 16) & 0xFF)
    DHCP_缓冲写(buf, 偏移 + 2, (值 >> 8) & 0xFF)
    DHCP_缓冲写(buf, 偏移 + 3, 值 & 0xFF)
}

函数 DHCP_缓冲读(buf, 偏移) {
    如果 (buf == 空 || 偏移 >= 计数(buf)) { 返回 0 }
    返回 buf[偏移]
}

函数 DHCP_缓冲读32(buf, 偏移) {
    // 大端序读取32位
    返回 (DHCP_缓冲读(buf, 偏移) << 24) | (DHCP_缓冲读(buf, 偏移 + 1) << 16) |
           (DHCP_缓冲读(buf, 偏移 + 2) << 8) | DHCP_缓冲读(buf, 偏移 + 3)
}

导入("./安全防护初始.nova")
导入("../感知/文档事件.nova")
导入("./公共智能.nova")
导入("../引导/引导加载器.nova")
导入("./进程标识分.nova")
导入("./信号设置用.nova")
导入("./信号量创建.nova")
导入("./进程描述符.nova")
导入("../记忆/事件轮创建.nova")
导入("./释放文件表.nova")
导入("./链表后继.nova")
导入("./时钟中枢.nova")
导入("./墙钟设置.nova")
导入("./整数转字符串.nova")
导入("../外联/分配地址客.nova")
导入("../稳态/图处内存管.nova")

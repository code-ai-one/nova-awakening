函数 文档事件_命中点击(档, 文档, x, y) {
    如果 (!文档事件_检查档(档)) { 返回 文档事件_失败(档, "命中点击", "事件档不可用") }
    文档事件_记录(档, "命中点击", [文档, x, y], "事件分发")
    定义 节点 = HitTest_在点(文档, x, y)
    定义 结果 = 事件Dispatch_click(节点, x, y)
    档.输入数 = 档.输入数 + 1
    档.分发数 = 档.分发数 + 1
    返回 文档事件_成功(档, "命中点击", [节点, 结果])
}


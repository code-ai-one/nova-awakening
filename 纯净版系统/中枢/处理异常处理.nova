// 异常总入口

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./缺页处理.nova")
导入("./内核打印.nova")
导入("./字符串替换.nova")
导入("./信号设置用.nova")
导入("./虚分配故障.nova")
导入("./恐慌.nova")
导入("./自动扩容.nova")
导入("../引导/模型寄存.nova")
导入("./中断帧是用户.nova")
导入("./每处理器.nova")

函数 异常处理(向量号, 错误码, 帧) {
    异常统计信息.计数[向量号] = 异常统计信息.计数[向量号] + 1
    异常统计信息.总计数 = 异常统计信息.总计数 + 1

    定义 是用户态 = 中断帧_是用户态(帧)
    如果 (是用户态) {
        异常统计信息.用户态数 = 异常统计信息.用户态数 + 1
    } 否则 {
        异常统计信息.内核态数 = 异常统计信息.内核态数 + 1
    }

    // 分发到具体异常处理器
    匹配 (向量号) {
        异常_除零         => 处理_除零(帧, 是用户态)
        异常_调试         => 处理_调试(帧, 是用户态)
        异常_NMI          => 处理_NMI(帧)
        异常_断点         => 处理_断点(帧, 是用户态)
        异常_溢出         => 处理_溢出(帧, 是用户态)
        异常_越界         => 处理_越界(帧, 是用户态)
        异常_无效操作码   => 处理_无效操作码(帧, 是用户态)
        异常_无协处理器   => 处理_无FPU(帧, 是用户态)
        异常_双重故障     => 处理_双重故障(帧, 错误码)
        异常_无效TSS      => 处理_无效TSS(帧, 错误码, 是用户态)
        异常_段不在       => 处理_段不在(帧, 错误码, 是用户态)
        异常_栈段错       => 处理_栈段错(帧, 错误码, 是用户态)
        异常_一般保护     => 处理_一般保护(帧, 错误码, 是用户态)
        异常_缺页         => 缺页处理(错误码, 帧)
        异常_浮点         => 处理_浮点(帧, 是用户态)
        异常_对齐检查     => 处理_对齐检查(帧, 错误码, 是用户态)
        异常_机器检查     => 处理_机器检查(帧)
        异常_SIMD浮点     => 处理_SIMD浮点(帧, 是用户态)
        _                 => 处理_未知异常(向量号, 帧, 错误码)
    }
}

// 具体异常处理器

函数 处理_除零(帧, 是用户态) {
    如果 (是用户态) {
        异常_发送信号(信号_FPE, 帧)
    } 否则 {
        异常_内核恐慌("除零错误(#DE)", 帧)
    }
}

函数 处理_调试(帧, 是用户态) {
    如果 (是用户态) {
        异常_发送信号(信号_TRAP, 帧)
    } 否则 {
        // 内核调试断点，通常由kgdb处理
        内核打印("内核调试异常 RIP=0x%lx\n", 帧.rip)
    }
}

函数 处理_NMI(帧) {
    // NMI不可屏蔽，可能是硬件错误、看门狗或性能计数器
    内核打印("NMI: RIP=0x%lx\n", 帧.rip)
    // 检查是否是看门狗超时
    // 检查是否是内存奇偶校验错误
    // 对于调试NMI，通知kgdb
}

函数 处理_断点(帧, 是用户态) {
    如果 (是用户态) {
        异常_发送信号(信号_TRAP, 帧)
    } 否则 {
        // 内核断点: kprobes或kgdb
        内核打印("内核断点 RIP=0x%lx\n", 帧.rip)
    }
}

函数 处理_溢出(帧, 是用户态) {
    如果 (是用户态) {
        异常_发送信号(信号_SEGV, 帧)
    } 否则 {
        异常_内核恐慌("内核溢出异常(#OF)", 帧)
    }
}

函数 处理_越界(帧, 是用户态) {
    如果 (是用户态) {
        异常_发送信号(信号_SEGV, 帧)
    } 否则 {
        异常_内核恐慌("内核越界异常(#BR)", 帧)
    }
}

函数 处理_无效操作码(帧, 是用户态) {
    如果 (是用户态) {
        异常_发送信号(信号_ILL, 帧)
    } 否则 {
        内核错误("无效操作码(#UD) RIP=0x%lx\n", 帧.rip)
        异常_转储寄存器(帧)
        异常_内核恐慌("内核执行无效指令", 帧)
    }
}

函数 处理_无FPU(帧, 是用户态) {
    // #NM: FPU不可用，需要按需切换FPU上下文
    定义 当前 = 获取当前进程()
    如果 (当前.fpu_已初始化) {
        FPU_恢复(当前.fpu状态)
    } 否则 {
        FPU_初始化()
        当前.fpu_已初始化 = 真
    }
}

函数 处理_双重故障(帧, 错误码) {
    // 双重故障不可恢复
    内核错误("====== 双重故障(#DF) ======\n")
    内核错误("错误码: 0x%lx\n", 错误码)
    异常_转储寄存器(帧)
    内核恐慌("双重故障: 系统不可恢复")
}

函数 处理_无效TSS(帧, 错误码, 是用户态) {
    如果 (是用户态) {
        异常_发送信号(信号_SEGV, 帧)
    } 否则 {
        内核错误("无效TSS(#TS) 错误码=0x%lx RIP=0x%lx\n", 错误码, 帧.rip)
        异常_内核恐慌("无效TSS", 帧)
    }
}

函数 处理_段不在(帧, 错误码, 是用户态) {
    如果 (是用户态) {
        异常_发送信号(信号_SEGV, 帧)
    } 否则 {
        内核错误("段不在(#NP) 错误码=0x%lx 选择子=0x%lx\n", 错误码, 错误码 & 0xFFF8)
        异常_内核恐慌("段不在", 帧)
    }
}

函数 处理_栈段错(帧, 错误码, 是用户态) {
    如果 (是用户态) {
        异常_发送信号(信号_SEGV, 帧)
    } 否则 {
        异常_内核恐慌("内核栈段错误(#SS)", 帧)
    }
}

函数 处理_一般保护(帧, 错误码, 是用户态) {
    如果 (是用户态) {
        内核打印("用户态#GP: 错误码=0x%lx RIP=0x%lx\n", 错误码, 帧.rip)
        异常_发送信号(信号_SEGV, 帧)
    } 否则 {
        内核错误("内核#GP: 错误码=0x%lx RIP=0x%lx\n", 错误码, 帧.rip)
        // 检查是否在异常修复表中
        定义 修复地址 = 查找异常修复(帧.rip)
        如果 (修复地址 != 0) {
            帧.rip = 修复地址
            返回
        }
        异常_转储寄存器(帧)
        异常_内核恐慌("无法恢复的一般保护错误", 帧)
    }
}

函数 处理_浮点(帧, 是用户态) {
    如果 (是用户态) {
        异常_发送信号(信号_FPE, 帧)
    } 否则 {
        异常_内核恐慌("内核浮点异常(#MF)", 帧)
    }
}

函数 处理_对齐检查(帧, 错误码, 是用户态) {
    如果 (是用户态) {
        异常_发送信号(信号_BUS, 帧)
    } 否则 {
        异常_内核恐慌("内核对齐检查异常(#AC)", 帧)
    }
}

函数 处理_机器检查(帧) {
    // MCE: 硬件错误，可能不可恢复
    内核错误("====== 机器检查异常(#MC) ======\n")
    异常_转储寄存器(帧)
    // 读取MCE MSR寄存器获取详细错误信息
    定义 mcg_status = 读取MSR(0x17A)   // IA32_MCG_STATUS
    定义 mc0_status = 读取MSR(0x401)   // IA32_MC0_STATUS
    定义 mc0_addr = 读取MSR(0x402)     // IA32_MC0_ADDR
    内核错误("  MCG_STATUS=0x" + 整数转十六进制(mcg_status))
    内核错误("  MC0_STATUS=0x" + 整数转十六进制(mc0_status))
    如果 ((mc0_status & (1 << 58)) != 0) {   // ADDRV位
        内核错误("  MC0_ADDR=0x" + 整数转十六进制(mc0_addr))
    }
    // 清除MCE状态
    写入MSR(0x401, 0)
    内核恐慌("机器检查异常")
}

函数 处理_SIMD浮点(帧, 是用户态) {
    如果 (是用户态) {
        异常_发送信号(信号_FPE, 帧)
    } 否则 {
        异常_内核恐慌("内核SIMD浮点异常(#XM)", 帧)
    }
}

函数 处理_未知异常(向量号, 帧, 错误码) {
    内核错误("未知异常: 向量=%d 错误码=0x%lx RIP=0x%lx\n", 向量号, 错误码, 帧.rip)
    异常_内核恐慌("未处理的CPU异常", 帧)
}

// 异常统计结构

结构 异常统计 {
    计数,
    总计数,
    用户态数,
    内核态数,
    致命数,
    已修复数,
    信号发送数,
    恐慌数,
}

定义 可变 异常统计信息 = 异常统计 {}
定义 可变 异常处理_已初始化 = 假
定义 可变 异常处理_延迟总计 = 0
定义 可变 异常处理_延迟样本 = 0
定义 可变 异常处理_最大延迟 = 0

函数 异常处理_初始化() {
    如果 (异常处理_已初始化 == 真) { 返回 错误_已存在 }
    异常统计信息.计数 = []
    定义 可变 i = 0
    当 (i < 32) {
        追加(异常统计信息.计数, 0)
        i = i + 1
    }
    异常统计信息.总计数 = 0
    异常统计信息.用户态数 = 0
    异常统计信息.内核态数 = 0
    异常统计信息.致命数 = 0
    异常统计信息.已修复数 = 0
    异常统计信息.信号发送数 = 0
    异常统计信息.恐慌数 = 0
    异常处理_延迟总计 = 0
    异常处理_延迟样本 = 0
    异常处理_最大延迟 = 0
    异常处理_已初始化 = 真
    返回 0
}

// 异常转储寄存器

函数 异常_转储寄存器(帧) {
    如果 (帧 == 空) { 返回 }
    内核错误("── 寄存器转储 ──")
    内核错误("  RIP: 0x" + 转字符串(帧.rip))
    内核错误("  RSP: 0x" + 转字符串(帧.rsp))
    内核错误("  RBP: 0x" + 转字符串(帧.rbp))
    内核错误("  RFLAGS: 0x" + 转字符串(帧.rflags))
    内核错误("  CS: 0x" + 转字符串(帧.cs) + "  SS: 0x" + 转字符串(帧.ss))
    内核错误("  RAX: 0x" + 转字符串(帧.rax) + "  RBX: 0x" + 转字符串(帧.rbx))
    内核错误("  RCX: 0x" + 转字符串(帧.rcx) + "  RDX: 0x" + 转字符串(帧.rdx))
    内核错误("  RSI: 0x" + 转字符串(帧.rsi) + "  RDI: 0x" + 转字符串(帧.rdi))
    内核错误("  R8:  0x" + 转字符串(帧.r8)  + "  R9:  0x" + 转字符串(帧.r9))
    内核错误("  R10: 0x" + 转字符串(帧.r10) + "  R11: 0x" + 转字符串(帧.r11))
    内核错误("  R12: 0x" + 转字符串(帧.r12) + "  R13: 0x" + 转字符串(帧.r13))
    内核错误("  R14: 0x" + 转字符串(帧.r14) + "  R15: 0x" + 转字符串(帧.r15))
    // 读取CR寄存器
    定义 可变 cr0 = 0
    定义 可变 cr2 = 0
    定义 可变 cr3 = 0
    定义 可变 cr4 = 0
    汇编 { "mov rax, cr0" "mov [rbp-8], rax" }
    汇编 { "mov rax, cr2" "mov [rbp-16], rax" }
    汇编 { "mov rax, cr3" "mov [rbp-24], rax" }
    汇编 { "mov rax, cr4" "mov [rbp-32], rax" }
    内核错误("  CR0: 0x" + 转字符串(cr0) + "  CR2: 0x" + 转字符串(cr2))
    内核错误("  CR3: 0x" + 转字符串(cr3) + "  CR4: 0x" + 转字符串(cr4))
}

// 异常修复表 (fixup table)
// 当内核访问用户空间失败时, 跳转到修复代码而非panic

定义 可变 异常修复表 = []
定义 异常修复表_最大 = 256

函数 注册异常修复(故障地址, 修复地址) {
    如果 (计数(异常修复表) >= 异常修复表_最大) { 返回 错误_溢出 }
    追加(异常修复表, [故障地址, 修复地址])
    返回 0
}

函数 查找异常修复(故障RIP) {
    定义 可变 i = 0
    当 (i < 计数(异常修复表)) {
        如果 (异常修复表[i][0] == 故障RIP) {
            异常统计信息.已修复数 = 异常统计信息.已修复数 + 1
            返回 异常修复表[i][1]
        }
        i = i + 1
    }
    返回 0
}

// 异常信号发送(含详细si_code)

定义 信号_FPE   = 8
定义 信号_TRAP  = 5
定义 信号_SEGV  = 11
定义 信号_ILL   = 4
定义 信号_BUS   = 7

函数 异常_发送信号(信号, 帧) {
    如果 (帧 == 空) { 返回 }
    异常统计信息.信号发送数 = 异常统计信息.信号发送数 + 1
    // 通过信号子系统发送
    定义 当前 = 获取当前进程()
    如果 (当前 != 空) {
        信号_发送(当前, 信号)
    }
}

函数 异常_发送信号_带代码(信号, 代码, 故障地址, 帧) {
    异常统计信息.信号发送数 = 异常统计信息.信号发送数 + 1
    定义 当前 = 获取当前进程()
    如果 (当前 != 空) {
        信号_发送_带信息(当前, 信号, 代码, 故障地址)
    }
}

// 内核恐慌

函数 异常_内核恐慌(消息, 帧) {
    异常统计信息.恐慌数 = 异常统计信息.恐慌数 + 1
    异常统计信息.致命数 = 异常统计信息.致命数 + 1
    内核错误("====== 内核恐慌 ======")
    内核错误("原因: " + 消息)
    如果 (帧 != 空) {
        异常_转储寄存器(帧)
    }
    dump_stack()
    // 尝试通知其他CPU停机
    // 广播停机IPI
    // 停机
    汇编 { "cli" }
    当 (真) { 汇编 { "hlt" } }
}

// FPU上下文管理

函数 FPU_初始化() {
    汇编 { "fninit" }
    // 初始化SSE
    汇编 {
        "mov rax, cr0"
        "and ax, 0xFFFB"
        "or ax, 0x2"
        "mov cr0, rax"
        "mov rax, cr4"
        "or ax, 0x600"
        "mov cr4, rax"
    }
}

函数 FPU_保存(缓冲) {
    如果 (缓冲 == 空) { 返回 }
    汇编 { "fxsave [rdi]" }
}

函数 FPU_恢复(缓冲) {
    如果 (缓冲 == 空) { 返回 }
    汇编 { "fxrstor [rdi]" }
}

函数 FPU_分配状态() {
    // 分配512字节(fxsave需要), 16字节对齐
    返回 堆_分配对齐(512, 16)
}

// AI基因: 异常处理延迟测量

函数 异常处理_记录延迟(延迟) {
    异常处理_延迟样本 = 异常处理_延迟样本 + 1
    异常处理_延迟总计 = 异常处理_延迟总计 + 延迟
    如果 (延迟 > 异常处理_最大延迟) {
        异常处理_最大延迟 = 延迟
    }
}

函数 异常处理_平均延迟() {
    如果 (异常处理_延迟样本 == 0) { 返回 0 }
    返回 异常处理_延迟总计 / 异常处理_延迟样本
}

// 完整统计 (≥15个指标)

函数 异常处理_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "已初始化", 异常处理_已初始化)
    字典设(统计, "总异常数", 异常统计信息.总计数)
    字典设(统计, "用户态数", 异常统计信息.用户态数)
    字典设(统计, "内核态数", 异常统计信息.内核态数)
    字典设(统计, "致命数", 异常统计信息.致命数)
    字典设(统计, "已修复数", 异常统计信息.已修复数)
    字典设(统计, "信号发送数", 异常统计信息.信号发送数)
    字典设(统计, "恐慌数", 异常统计信息.恐慌数)
    字典设(统计, "修复表大小", 计数(异常修复表))
    字典设(统计, "平均延迟(ns)", 异常处理_平均延迟())
    字典设(统计, "最大延迟(ns)", 异常处理_最大延迟)
    字典设(统计, "延迟样本数", 异常处理_延迟样本)
    // 按类型统计
    如果 (异常处理_已初始化 == 真 && 计数(异常统计信息.计数) >= 22) {
        字典设(统计, "除零次数", 异常统计信息.计数[0])
        字典设(统计, "GP次数", 异常统计信息.计数[13])
        字典设(统计, "缺页次数", 异常统计信息.计数[14])
        字典设(统计, "DF次数", 异常统计信息.计数[8])
        字典设(统计, "UD次数", 异常统计信息.计数[6])
    }
    返回 统计
}

函数 异常处理_打印统计() {
    定义 统计 = 异常处理_完整统计()
    打印("[异常处理] ═══════ 完整统计 ═══════")
    打印("  总异常:       " + 转字符串(字典取(统计, "总异常数")))
    打印("  用户态:       " + 转字符串(字典取(统计, "用户态数")))
    打印("  内核态:       " + 转字符串(字典取(统计, "内核态数")))
    打印("  致命:         " + 转字符串(字典取(统计, "致命数")))
    打印("  已修复:       " + 转字符串(字典取(统计, "已修复数")))
    打印("  信号发送:     " + 转字符串(字典取(统计, "信号发送数")))
    打印("  恐慌:         " + 转字符串(字典取(统计, "恐慌数")))
    打印("  修复表:       " + 转字符串(字典取(统计, "修复表大小")))
    打印("  平均延迟:     " + 转字符串(字典取(统计, "平均延迟(ns)")) + "ns")
    打印("  最大延迟:     " + 转字符串(字典取(统计, "最大延迟(ns)")) + "ns")
    // 各类异常
    如果 (异常处理_已初始化 == 真 && 计数(异常统计信息.计数) >= 22) {
        打印("  ── 各类异常 ──")
        定义 可变 i = 0
        当 (i < 22) {
            如果 (异常统计信息.计数[i] > 0) {
                打印("  [" + 转字符串(i) + "]: " + 转字符串(异常统计信息.计数[i]))
            }
            i = i + 1
        }
    }
    打印("[异常处理] ═════════════════════════")
    返回 0
}

// dump

函数 异常处理_dump() {
    打印("[异常处理 dump] ──────────────────")
    打印("  已初始化: " + 转字符串(异常处理_已初始化))
    打印("  总异常: " + 转字符串(异常统计信息.总计数))
    打印("  用户态: " + 转字符串(异常统计信息.用户态数))
    打印("  内核态: " + 转字符串(异常统计信息.内核态数))
    打印("  致命: " + 转字符串(异常统计信息.致命数))
    打印("  修复: " + 转字符串(异常统计信息.已修复数))
    打印("  恐慌: " + 转字符串(异常统计信息.恐慌数))
    打印("  修复表: " + 转字符串(计数(异常修复表)) + " 条目")
    打印("[异常处理 dump] ──────────────────")
}

函数 dump_stack() {
    // 简易栈回溯: 沿RBP链遍历
    打印("[栈回溯]")
    定义 可变 rbp值 = 0
    汇编 { "mov rax, rbp" "mov [rbp-8], rax" }
    定义 可变 深度 = 0
    当 (rbp值 != 0 && 深度 < 16) {
        定义 返回地址 = 内存_读64(rbp值 + 8)
        如果 (返回地址 == 0) { 中断 }
        打印("  [" + 转字符串(深度) + "] 0x" + 转字符串(返回地址))
        rbp值 = 内存_读64(rbp值)
        深度 = 深度 + 1
    }
}

// 销毁

函数 异常处理_销毁() {
    如果 (异常处理_已初始化 == 假) { 返回 0 }
    异常统计信息.计数 = []
    异常修复表 = []
    异常处理_已初始化 = 假
    打印("[异常处理] 已销毁")
    返回 0
}

// 与其他子系统的接口

函数 异常处理_为信号提供异常信息(向量号) {
    // 返回[信号号, si_code, 故障地址]供信号子系统使用
    如果 (向量号 == 0) { 返回 [信号_FPE, 1, 0] }
    如果 (向量号 == 6) { 返回 [信号_ILL, 1, 0] }
    如果 (向量号 == 13) { 返回 [信号_SEGV, 1, 0] }
    如果 (向量号 == 14) { 返回 [信号_SEGV, 2, 读CR2()] }
    返回 [0, 0, 0]
}

函数 异常处理_为AI提供异常模式() {
    返回 [异常统计信息.总计数, 异常统计信息.致命数,
           异常处理_平均延迟(), 异常处理_最大延迟]
}

函数 异常处理_为procfs提供统计() {
    如果 (异常处理_已初始化 == 假) { 返回 [] }
    返回 [异常统计信息.总计数, 异常统计信息.用户态数, 异常统计信息.内核态数,
           异常统计信息.致命数, 异常统计信息.已修复数, 异常统计信息.信号发送数]
}

函数 异常处理_重置统计() {
    异常统计信息.总计数 = 0
    异常统计信息.用户态数 = 0
    异常统计信息.内核态数 = 0
    异常统计信息.致命数 = 0
    异常统计信息.已修复数 = 0
    异常统计信息.信号发送数 = 0
    异常统计信息.恐慌数 = 0
    异常处理_延迟总计 = 0
    异常处理_延迟样本 = 0
    异常处理_最大延迟 = 0
    如果 (异常处理_已初始化 == 真) {
        定义 可变 i = 0
        当 (i < 32) { 设置(异常统计信息.计数, i, 0); i = i + 1 }
    }
    打印("[异常处理] 统计已重置")
    返回 0
}

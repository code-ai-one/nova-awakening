// NovaOS ext4 目录遍历·内存映射·文件删除·重命名·链接 — 完整生产级实现
// 功能: readdir/getdents/mmap/fault/unlink/rename/link/symlink
// 关联: ext4目录操作 → ext4范围树 → ext4日志系统 → VFS文件层 → 页面缓存

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("./扩展读超级块.nova")
导入("./文件文件.nova")
导入("../中枢/日志中枢.nova")
导入("./扩展查找目.nova")
导入("../执行/控制台输出.nova")
导入("../中枢/页缓存标记脏.nova")
导入("./扩展分配块.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/墙钟设置.nova")
导入("./事务管理.nova")
导入("./扩展删除目录.nova")
导入("./扩展读块组描.nova")
导入("../稳态/磁控驱动全局.nova")

// 第1部分: 常量定义

定义 EXT4_目录项_头大小        = 8
定义 EXT4_目录项_名称偏移      = 8
定义 EXT4_目录项_节点号偏移    = 0
定义 EXT4_目录项_记录长偏移    = 4
定义 EXT4_目录项_名称长偏移    = 6
定义 EXT4_目录项_类型偏移      = 7
定义 EXT4_最大名称长度         = 255
定义 EXT4_目录项类型_未知      = 0
定义 EXT4_目录项类型_文件      = 1
定义 EXT4_目录项类型_目录      = 2
定义 EXT4_目录项类型_字符设备  = 3
定义 EXT4_目录项类型_块设备    = 4
定义 EXT4_目录项类型_管道      = 5
定义 EXT4_目录项类型_套接字    = 6
定义 EXT4_目录项类型_符号链接  = 7
定义 EXT4_最大链接数           = 65000
定义 EXT4_最大符号链接长度     = 4096

// 第2部分: 数据结构

结构 目录遍历上下文 {
    文件节点,            // 当前目录的文件节点
    当前块,              // u32 当前正在读取的逻辑块号
    块内偏移,            // u32 当前块内的字节偏移
    已返回条目数,
    缓冲区,              // 用户态缓冲区指针
    缓冲区大小,
    已写入字节,
}

结构 目录项解析结果 {
    文件节点号,
    记录长度,
    名称长度,
    类型,
    名称,
    有效,
}

结构 遍历统计 {
    读目录次数,
    读目录返回条目总数,
    读目录空目录次数,
    mmap次数,
    fault次数,
    fault缓存命中,
    fault磁盘读取,
    fault空洞次数,
    删除文件次数,
    删除文件成功,
    删除文件失败,
    重命名次数,
    硬链接次数,
    符号链接次数,
    目录项解析次数,
    目录项解析错误,
}

定义 可变 遍历统计数据 = 遍历统计 {}

// 第3部分: 目录项解析辅助函数

函数 ext4_解析目录项(块数据, 偏移, 块大小) {
    遍历统计数据.目录项解析次数 = 遍历统计数据.目录项解析次数 + 1

    如果 (块数据 == 空 || 偏移 >= 块大小) {
        遍历统计数据.目录项解析错误 = 遍历统计数据.目录项解析错误 + 1
        返回 空
    }

    定义 可变 结果 = 目录项解析结果 {}
    结果.文件节点号 = 缓冲读32(块数据, 偏移 + EXT4_目录项_节点号偏移)
    结果.记录长度 = 缓冲读16(块数据, 偏移 + EXT4_目录项_记录长偏移)
    结果.名称长度 = 缓冲读8(块数据, 偏移 + EXT4_目录项_名称长偏移)
    结果.类型 = 缓冲读8(块数据, 偏移 + EXT4_目录项_类型偏移)

    // 验证记录长度
    如果 (结果.记录长度 < EXT4_目录项_头大小 || 结果.记录长度 > 块大小 - 偏移) {
        遍历统计数据.目录项解析错误 = 遍历统计数据.目录项解析错误 + 1
        结果.有效 = 假
        返回 结果
    }

    // 验证名称长度
    如果 (结果.名称长度 > EXT4_最大名称长度 || 结果.名称长度 > 结果.记录长度 - EXT4_目录项_头大小) {
        遍历统计数据.目录项解析错误 = 遍历统计数据.目录项解析错误 + 1
        结果.有效 = 假
        返回 结果
    }

    // 读取名称
    如果 (结果.名称长度 > 0 && 结果.文件节点号 != 0) {
        定义 可变 名称 = ""
        定义 可变 i = 0
        当 (i < 结果.名称长度) {
            定义 字节 = 缓冲读8(块数据, 偏移 + EXT4_目录项_名称偏移 + i)
            名称 = 字符串拼接(名称, 字符(字节))
            i = i + 1
        }
        结果.名称 = 名称
        结果.有效 = 真
    } 否则 {
        结果.有效 = 假
    }

    返回 结果
}

函数 ext4_目录项类型转换(ext4类型) {
    匹配 ext4类型 {
        1: { 返回 0x8000 }
        2: { 返回 0x4000 }
        3: { 返回 0x2000 }
        4: { 返回 0x6000 }
        5: { 返回 0x1000 }
        6: { 返回 0xC000 }
        7: { 返回 0xA000 }
    }
    返回 0
}

函数 ext4_模式到目录项类型(模式) {
    定义 类型位 = 模式 & 0xF000
    匹配 类型位 {
        0x8000: { 返回 EXT4_目录项类型_文件 }
        0x4000: { 返回 EXT4_目录项类型_目录 }
        0x2000: { 返回 EXT4_目录项类型_字符设备 }
        0x6000: { 返回 EXT4_目录项类型_块设备 }
        0x1000: { 返回 EXT4_目录项类型_管道 }
        0xC000: { 返回 EXT4_目录项类型_套接字 }
        0xA000: { 返回 EXT4_目录项类型_符号链接 }
    }
    返回 EXT4_目录项类型_未知
}

// 第4部分: 目录遍历核心 — ext4_读目录(readdir/getdents)

函数 ext4_读目录_完整(文件, 缓冲, 大小) {
    遍历统计数据.读目录次数 = 遍历统计数据.读目录次数 + 1

    如果 (文件 == 空 || 文件.文件节点 == 空) {
        返回 错误码_无效参数
    }

    定义 文件节点 = 文件.文件节点
    定义 sb = 文件节点.超级块
    定义 信息 = sb.私有信息
    定义 块大小 = 信息.块大小

    // 验证是目录
    如果 ((文件节点.模式 & 0xF000) != 0x4000) {
        返回 错误码_不是目录
    }

    如果 (文件节点.大小 == 0) {
        遍历统计数据.读目录空目录次数 = 遍历统计数据.读目录空目录次数 + 1
        返回 0
    }

    定义 ext4信息 = 文件节点.私有信息
    如果 (ext4信息 == 空) { 返回 错误码_无效参数 }

    // 初始化遍历上下文
    定义 可变 上下文 = 目录遍历上下文 {}
    上下文.文件节点 = 文件节点
    上下文.当前块 = 文件.偏移 / 块大小
    上下文.块内偏移 = 文件.偏移 % 块大小
    上下文.缓冲区 = 缓冲
    上下文.缓冲区大小 = 大小
    上下文.已写入字节 = 0
    上下文.已返回条目数 = 0

    定义 目录块数 = (文件节点.大小 + 块大小 - 1) / 块大小

    // 逐块遍历目录
    当 (上下文.当前块 < 目录块数 && 上下文.已写入字节 < 上下文.缓冲区大小) {
        // 读取当前目录数据块
        定义 物理块 = ext4_extent_查找(sb, ext4信息, 上下文.当前块)
        如果 (物理块 == (0 - 1) || 物理块 == 0) {
            上下文.当前块 = 上下文.当前块 + 1
            上下文.块内偏移 = 0
            继续
        }

        定义 块数据 = 块设备_读(sb.设备, 物理块 * 块大小, 块大小)
        如果 (块数据 == 空) {
            上下文.当前块 = 上下文.当前块 + 1
            上下文.块内偏移 = 0
            继续
        }

        // 遍历块内所有目录项
        当 (上下文.块内偏移 < 块大小 && 上下文.已写入字节 < 上下文.缓冲区大小) {
            定义 项 = ext4_解析目录项(块数据, 上下文.块内偏移, 块大小)
            如果 (项 == 空) { 止 }

            如果 (项.记录长度 == 0) { 止 }

            如果 (项.有效 && 项.文件节点号 != 0) {
                // 构建getdents格式输出
                定义 写入结果 = ext4_填充getdents(上下文, 项)
                如果 (写入结果 < 0) {
                    // 缓冲区满
                    止
                }
                上下文.已返回条目数 = 上下文.已返回条目数 + 1
            }

            上下文.块内偏移 = 上下文.块内偏移 + 项.记录长度
        }

        上下文.当前块 = 上下文.当前块 + 1
        上下文.块内偏移 = 0
    }

    // 更新文件偏移
    文件.偏移 = 上下文.当前块 * 块大小 + 上下文.块内偏移

    遍历统计数据.读目录返回条目总数 = 遍历统计数据.读目录返回条目总数 + 上下文.已返回条目数
    返回 上下文.已写入字节
}

// 第4.1部分: 填充getdents缓冲区

函数 ext4_填充getdents(上下文, 项) {
    // getdents64格式: 节点号(8) + 偏移(8) + 记录长(2) + 类型(1) + 名称(变长+'\0')
    定义 条目大小 = 8 + 8 + 2 + 1 + 项.名称长度 + 1
    // 对齐到8字节
    定义 对齐大小 = ((条目大小 + 7) / 8) * 8

    如果 (上下文.已写入字节 + 对齐大小 > 上下文.缓冲区大小) {
        返回 -1
    }

    定义 偏移 = 上下文.已写入字节
    // 写入节点号
    缓冲写64(上下文.缓冲区, 偏移, 项.文件节点号)
    // 写入偏移(下一条目的偏移)
    缓冲写64(上下文.缓冲区, 偏移 + 8, 上下文.当前块 * 4096 + 上下文.块内偏移 + 项.记录长度)
    // 写入记录长度
    缓冲写16(上下文.缓冲区, 偏移 + 16, 对齐大小)
    // 写入类型
    缓冲写(上下文.缓冲区, 偏移 + 18, 项.类型)
    // 写入名称
    定义 可变 i = 0
    当 (i < 项.名称长度) {
        定义 字节 = 编码(子串(项.名称, i, 1))
        缓冲写(上下文.缓冲区, 偏移 + 19 + i, 字节)
        i = i + 1
    }
    缓冲写(上下文.缓冲区, 偏移 + 19 + 项.名称长度, 0)

    上下文.已写入字节 = 上下文.已写入字节 + 对齐大小
    返回 0
}

// 第5部分: 内存映射支持 — mmap / fault

函数 ext4_内存映射(文件, vma) {
    遍历统计数据.mmap次数 = 遍历统计数据.mmap次数 + 1

    如果 (文件 == 空 || 文件.文件节点 == 空) {
        返回 错误码_无效参数
    }

    // 目录不允许mmap
    如果 ((文件.文件节点.模式 & 0xF000) == 0x4000) {
        返回 错误码_不支持
    }

    // 设置VMA操作表
    vma.操作_fault = ext4_文件fault
    vma.操作_map_pages = ext4_map_pages
    vma.私有数据 = 文件.文件节点

    返回 0
}

函数 ext4_文件fault(vma, 地址) {
    遍历统计数据.fault次数 = 遍历统计数据.fault次数 + 1

    如果 (vma == 空 || vma.私有数据 == 空) {
        返回 空
    }

    定义 文件节点 = vma.私有数据
    定义 sb = 文件节点.超级块
    定义 块大小 = sb.私有信息.块大小
    定义 偏移 = (地址 - vma.起始) + vma.文件偏移
    定义 逻辑块 = 偏移 / 块大小

    // 检查偏移是否超出文件大小
    如果 (偏移 >= 文件节点.大小) {
        返回 空
    }

    // 先查页面缓存
    定义 缓存页 = 页面缓存_查找(文件节点, 逻辑块)
    如果 (缓存页 != 空) {
        遍历统计数据.fault缓存命中 = 遍历统计数据.fault缓存命中 + 1
        返回 缓存页
    }

    // 从磁盘读取
    定义 ext4信息 = 文件节点.私有信息
    如果 (ext4信息 == 空) { 返回 空 }

    定义 物理块 = ext4_extent_查找(sb, ext4信息, 逻辑块)
    如果 (物理块 == (0 - 1) || 物理块 == 0) {
        遍历统计数据.fault空洞次数 = 遍历统计数据.fault空洞次数 + 1
        // 空洞: 返回零页
        定义 零页 = 创建缓冲(块大小)
        页面缓存_添加(文件节点, 逻辑块, 零页)
        返回 零页
    }

    遍历统计数据.fault磁盘读取 = 遍历统计数据.fault磁盘读取 + 1
    定义 块数据 = 块设备_读(sb.设备, 物理块 * 块大小, 块大小)
    如果 (块数据 != 空) {
        页面缓存_添加(文件节点, 逻辑块, 块数据)
    }
    返回 块数据
}

函数 ext4_map_pages(vma, 起始地址, 页数) {
    // 批量映射: 预读相邻页面
    定义 文件节点 = vma.私有数据
    如果 (文件节点 == 空) { 返回 0 }
    定义 sb = 文件节点.超级块
    定义 块大小 = sb.私有信息.块大小
    定义 ext4信息 = 文件节点.私有信息
    如果 (ext4信息 == 空) { 返回 0 }

    定义 可变 已映射 = 0
    定义 可变 i = 0
    当 (i < 页数 && i < 16) {
        定义 偏移 = (起始地址 + i * 块大小 - vma.起始) + vma.文件偏移
        如果 (偏移 >= 文件节点.大小) { 止 }

        定义 逻辑块 = 偏移 / 块大小
        定义 缓存 = 页面缓存_查找(文件节点, 逻辑块)
        如果 (缓存 == 空) {
            定义 物理块 = ext4_extent_查找(sb, ext4信息, 逻辑块)
            如果 (物理块 != (0 - 1) && 物理块 != 0) {
                定义 数据 = 块设备_读(sb.设备, 物理块 * 块大小, 块大小)
                如果 (数据 != 空) {
                    页面缓存_添加(文件节点, 逻辑块, 数据)
                    已映射 = 已映射 + 1
                }
            }
        }
        i = i + 1
    }
    返回 已映射
}

// 第6部分: 文件删除 — unlink(日志事务包裹)

函数 ext4_删除文件(sb, 父文件节点, 名称) {
    遍历统计数据.删除文件次数 = 遍历统计数据.删除文件次数 + 1

    如果 (sb == 空 || 父文件节点 == 空 || 名称 == 空) {
        遍历统计数据.删除文件失败 = 遍历统计数据.删除文件失败 + 1
        返回 错误码_无效参数
    }

    如果 (字节长度(名称) == 0 || 字节长度(名称) > EXT4_最大名称长度) {
        遍历统计数据.删除文件失败 = 遍历统计数据.删除文件失败 + 1
        返回 错误码_名称过长
    }

    // 不允许删除 . 和 ..
    如果 (名称 == "." || 名称 == "..") {
        遍历统计数据.删除文件失败 = 遍历统计数据.删除文件失败 + 1
        返回 错误码_无效参数
    }

    // 查找目录项
    定义 项 = ext4_查找目录项(sb, 父文件节点, 名称)
    如果 (项 == 空) {
        遍历统计数据.删除文件失败 = 遍历统计数据.删除文件失败 + 1
        返回 错误码_不存在
    }

    // 读取目标文件节点
    定义 子文件节点 = ext4_读文件节点(sb, 项.文件节点号)
    如果 (是错误(子文件节点)) {
        遍历统计数据.删除文件失败 = 遍历统计数据.删除文件失败 + 1
        返回 子文件节点
    }

    // 如果是目录,不允许用unlink删除(需要rmdir)
    如果 ((子文件节点.模式 & 0xF000) == 0x4000) {
        遍历统计数据.删除文件失败 = 遍历统计数据.删除文件失败 + 1
        返回 错误码_是目录
    }

    // 开启日志事务
    定义 事务 = journal_开始事务()

    // 从目录中删除条目
    定义 删除结果 = ext4_删除目录项(sb, 父文件节点, 名称)
    如果 (删除结果 != 0) {
        如果 (事务 != 空) { journal_回滚事务(事务) }
        遍历统计数据.删除文件失败 = 遍历统计数据.删除文件失败 + 1
        返回 删除结果
    }

    // 记录目录修改
    如果 (事务 != 空) {
        journal_记录修改(事务, 父文件节点.编号, 父文件节点)
    }

    // 减少链接数
    子文件节点.链接数 = 子文件节点.链接数 - 1
    子文件节点.变更时间 = 当前时间_秒()

    如果 (子文件节点.链接数 == 0) {
        // 没有更多链接,标记为待删除
        // 实际数据块释放在文件关闭(ext4_释放)时执行
        子文件节点.删除时间 = 当前时间_秒()
        打印(字符串拼接("[ext4] 文件已标记删除: ", 名称))
    }

    // 写回子文件节点
    ext4_写文件节点(sb, 子文件节点)
    如果 (事务 != 空) {
        journal_记录修改(事务, 子文件节点.编号, 子文件节点)
    }

    // 更新父目录时间
    父文件节点.修改时间 = 当前时间_秒()
    父文件节点.变更时间 = 当前时间_秒()
    ext4_写文件节点(sb, 父文件节点)

    // 提交事务
    如果 (事务 != 空) { journal_提交事务(事务) }

    遍历统计数据.删除文件成功 = 遍历统计数据.删除文件成功 + 1
    返回 0
}

// 第7部分: 重命名 — rename

函数 ext4_重命名(sb, 旧父节点, 旧名称, 新父节点, 新名称) {
    遍历统计数据.重命名次数 = 遍历统计数据.重命名次数 + 1

    如果 (sb == 空 || 旧父节点 == 空 || 新父节点 == 空) {
        返回 错误码_无效参数
    }
    如果 (旧名称 == 空 || 新名称 == 空) {
        返回 错误码_无效参数
    }

    // 查找旧目录项
    定义 旧项 = ext4_查找目录项(sb, 旧父节点, 旧名称)
    如果 (旧项 == 空) { 返回 错误码_不存在 }

    定义 移动节点号 = 旧项.文件节点号

    // 开启日志事务
    定义 事务 = journal_开始事务()

    // 检查目标是否已存在
    定义 新项 = ext4_查找目录项(sb, 新父节点, 新名称)
    如果 (新项 != 空) {
        // 目标已存在: 先删除目标
        定义 目标节点 = ext4_读文件节点(sb, 新项.文件节点号)
        如果 (!是错误(目标节点)) {
            目标节点.链接数 = 目标节点.链接数 - 1
            如果 (目标节点.链接数 == 0) {
                目标节点.删除时间 = 当前时间_秒()
            }
            ext4_写文件节点(sb, 目标节点)
        }
        ext4_删除目录项(sb, 新父节点, 新名称)
    }

    // 在新目录中添加条目
    定义 移动节点 = ext4_读文件节点(sb, 移动节点号)
    如果 (是错误(移动节点)) {
        如果 (事务 != 空) { journal_回滚事务(事务) }
        返回 移动节点
    }

    定义 类型 = ext4_模式到目录项类型(移动节点.模式)
    定义 添加结果 = ext4_添加目录项(sb, 新父节点, 新名称, 移动节点号, 类型)
    如果 (添加结果 != 0) {
        如果 (事务 != 空) { journal_回滚事务(事务) }
        返回 添加结果
    }

    // 从旧目录中删除
    ext4_删除目录项(sb, 旧父节点, 旧名称)

    // 如果是目录且跨目录移动,需要更新..条目
    如果 ((移动节点.模式 & 0xF000) == 0x4000 && 旧父节点.编号 != 新父节点.编号) {
        ext4_更新父目录项(sb, 移动节点, 新父节点.编号)
        旧父节点.链接数 = 旧父节点.链接数 - 1
        新父节点.链接数 = 新父节点.链接数 + 1
    }

    // 更新时间戳
    旧父节点.修改时间 = 当前时间_秒()
    新父节点.修改时间 = 当前时间_秒()
    移动节点.变更时间 = 当前时间_秒()

    ext4_写文件节点(sb, 旧父节点)
    ext4_写文件节点(sb, 新父节点)
    ext4_写文件节点(sb, 移动节点)

    如果 (事务 != 空) { journal_提交事务(事务) }
    返回 0
}

函数 ext4_更新父目录项(sb, 目录节点, 新父编号) {
    // 修改目录中的..条目指向新的父节点
    定义 信息 = sb.私有信息
    定义 ext4信息 = 目录节点.私有信息
    如果 (ext4信息 == 空) { 返回 }

    定义 物理块 = ext4_extent_查找(sb, ext4信息, 0)
    如果 (物理块 == (0 - 1)) { 返回 }

    定义 块数据 = 块设备_读(sb.设备, 物理块 * 信息.块大小, 信息.块大小)
    如果 (块数据 == 空) { 返回 }

    // 跳过.条目,找到..条目
    定义 第一个长度 = 缓冲读16(块数据, EXT4_目录项_记录长偏移)
    // 修改..条目的节点号
    缓冲写32(块数据, 第一个长度 + EXT4_目录项_节点号偏移, 新父编号)
    块设备_写(sb.设备, 物理块 * 信息.块大小, 块数据, 信息.块大小)
}

// 第8部分: 硬链接与符号链接

函数 ext4_硬链接(sb, 源节点, 目标父节点, 新名称) {
    遍历统计数据.硬链接次数 = 遍历统计数据.硬链接次数 + 1

    如果 (源节点 == 空 || 目标父节点 == 空 || 新名称 == 空) {
        返回 错误码_无效参数
    }

    // 目录不允许硬链接
    如果 ((源节点.模式 & 0xF000) == 0x4000) {
        返回 错误码_不允许
    }

    // 检查链接数上限
    如果 (源节点.链接数 >= EXT4_最大链接数) {
        返回 错误码_链接过多
    }

    定义 事务 = journal_开始事务()

    // 在目标目录添加条目
    定义 类型 = ext4_模式到目录项类型(源节点.模式)
    定义 结果 = ext4_添加目录项(sb, 目标父节点, 新名称, 源节点.编号, 类型)
    如果 (结果 != 0) {
        如果 (事务 != 空) { journal_回滚事务(事务) }
        返回 结果
    }

    // 增加链接数
    源节点.链接数 = 源节点.链接数 + 1
    源节点.变更时间 = 当前时间_秒()
    ext4_写文件节点(sb, 源节点)

    目标父节点.修改时间 = 当前时间_秒()
    ext4_写文件节点(sb, 目标父节点)

    如果 (事务 != 空) { journal_提交事务(事务) }
    返回 0
}

函数 ext4_符号链接(sb, 父节点, 名称, 目标路径) {
    遍历统计数据.符号链接次数 = 遍历统计数据.符号链接次数 + 1

    如果 (父节点 == 空 || 名称 == 空 || 目标路径 == 空) {
        返回 错误码_无效参数
    }
    如果 (字节长度(目标路径) > EXT4_最大符号链接长度) {
        返回 错误码_名称过长
    }

    定义 事务 = journal_开始事务()

    // 分配新的文件节点
    定义 新节点号 = ext4_分配文件节点号(sb)
    如果 (新节点号 <= 0) {
        如果 (事务 != 空) { journal_回滚事务(事务) }
        返回 错误码_无空间
    }

    // 初始化符号链接文件节点
    定义 可变 新节点 = ext4_读文件节点(sb, 新节点号)
    新节点.模式 = 0xA000 | 0x01FF
    新节点.链接数 = 1
    新节点.大小 = 字节长度(目标路径)
    新节点.创建时间 = 当前时间_秒()
    新节点.修改时间 = 当前时间_秒()
    新节点.变更时间 = 当前时间_秒()

    // 如果目标路径短,存储在文件节点内部(快速符号链接)
    如果 (字节长度(目标路径) <= 60) {
        新节点.符号链接数据 = 目标路径
    } 否则 {
        // 长路径: 分配数据块存储
        定义 信息 = sb.私有信息
        定义 请求 = Ext4分配请求 {}
        请求.文件节点号 = 新节点号
        请求.请求块数 = 1
        定义 分配结果 = ext4_分配块(sb, 请求)
        如果 (是错误(分配结果)) {
            如果 (事务 != 空) { journal_回滚事务(事务) }
            返回 分配结果
        }
        // 写入目标路径到数据块
        定义 数据块 = 创建缓冲(信息.块大小)
        定义 可变 i = 0
        当 (i < 字节长度(目标路径)) {
            缓冲写(数据块, i, 字节取(目标路径, i))
            i = i + 1
        }
        块设备_写(sb.设备, 分配结果.起始块 * 信息.块大小, 数据块, 信息.块大小)
    }

    ext4_写文件节点(sb, 新节点)

    // 添加目录项
    ext4_添加目录项(sb, 父节点, 名称, 新节点号, EXT4_目录项类型_符号链接)
    父节点.修改时间 = 当前时间_秒()
    ext4_写文件节点(sb, 父节点)

    如果 (事务 != 空) { journal_提交事务(事务) }
    返回 0
}

// 第9部分: VFS包装接口

函数 ext4_读目录_包装(文件, 缓冲, 大小, 偏移) {
    返回 ext4_读目录_完整(文件, 缓冲, 大小)
}

// 第10部分: 统计输出与接口注册

函数 ext4_遍历_打印统计() {
    打印("[ext4遍历] ═══ 统计信息 ═══")
    打印(字符串拼接("  读目录次数:       ", 转字符串(遍历统计数据.读目录次数)))
    打印(字符串拼接("  返回条目总数:     ", 转字符串(遍历统计数据.读目录返回条目总数)))
    打印(字符串拼接("  空目录次数:       ", 转字符串(遍历统计数据.读目录空目录次数)))
    打印(字符串拼接("  mmap次数:         ", 转字符串(遍历统计数据.mmap次数)))
    打印(字符串拼接("  fault次数:        ", 转字符串(遍历统计数据.fault次数)))
    打印(字符串拼接("  fault缓存命中:    ", 转字符串(遍历统计数据.fault缓存命中)))
    打印(字符串拼接("  fault磁盘读取:    ", 转字符串(遍历统计数据.fault磁盘读取)))
    打印(字符串拼接("  fault空洞次数:    ", 转字符串(遍历统计数据.fault空洞次数)))
    打印(字符串拼接("  删除文件次数:     ", 转字符串(遍历统计数据.删除文件次数)))
    打印(字符串拼接("  删除文件成功:     ", 转字符串(遍历统计数据.删除文件成功)))
    打印(字符串拼接("  删除文件失败:     ", 转字符串(遍历统计数据.删除文件失败)))
    打印(字符串拼接("  重命名次数:       ", 转字符串(遍历统计数据.重命名次数)))
    打印(字符串拼接("  硬链接次数:       ", 转字符串(遍历统计数据.硬链接次数)))
    打印(字符串拼接("  符号链接次数:     ", 转字符串(遍历统计数据.符号链接次数)))
    打印(字符串拼接("  目录项解析次数:   ", 转字符串(遍历统计数据.目录项解析次数)))
    打印(字符串拼接("  目录项解析错误:   ", 转字符串(遍历统计数据.目录项解析错误)))
    返回 0
}

函数 ext4_遍历_获取统计() {
    返回 遍历统计数据
}

函数 ext4_获取目录操作表() {
    返回 {
        读目录: ext4_读目录_完整,
        查找: ext4_查找目录项,
        创建: ext4_添加目录项,
        删除: ext4_删除文件,
        重命名: ext4_重命名,
        链接: ext4_硬链接,
        符号链接: ext4_符号链接,
        内存映射: ext4_内存映射
    }
}

定义 可变 AI_扩展列目录_运行指标 = 0
定义 可变 AI_扩展列目录_异常指标 = 0

函数 AI_扩展列目录_自诊断() {
    AI_扩展列目录_运行指标 = 遍历统计数据
    返回 AI_扩展列目录_运行指标
}

函数 AI_扩展列目录_优化建议() {
    定义 指标 = AI_扩展列目录_自诊断()
    如果 (AI_扩展列目录_运行指标 > 10000) { 返回 "扩展列目录遍负载较高" }
    返回 "扩展列目录遍状态正常"
}

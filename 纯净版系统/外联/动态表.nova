// NovaOS HPACK动态表引擎 — NHDCE理论 (Nova Header Dynamic Compression Engine)
// 原创论文: 基于自适应环形缓冲区的HTTP/2头部动态压缩引擎
// 核心思想: 将HPACK动态表建模为带字节预算的FIFO环形缓冲区。
// 表大小约束 S ≤ S_max，条目大小 e_i = |name_i| + |value_i| + 32。
// 淘汰策略为尾部淘汰 (FIFO)，复杂度 O(k) k=淘汰数。
// 整数编解码采用前缀编码 + 128进制续字节，复杂度 O(log(N)/7)。
// AI集成: 利用访问频率张量预测缓存淘汰优先级。
// 版权: NovaOS原创, 不依赖任何第三方库

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("../推理/智能渠道.nova")
导入("../推理/值乘.nova")
导入("../中枢/内存初始化.nova")
导入("../感知/内核直连层.nova")


定义 HPACK_动态表_默认最大  = 4096    // 默认表大小
定义 HPACK_动态表_初始容量  = 128     // 初始条目数容量
定义 HPACK_条目开销          = 32      // 每条目固定开销字节数
定义 HPACK_整数最大字节      = 8       // 前缀整数最大字节数
定义 HPACK_静态表大小        = 61      // 静态表条目数
定义 HPACK_AI特征维度        = 10      // AI异常检测向量维度
定义 HPACK_最大字符串长      = 65536   // 单个字符串最大长度

// 全局统计计数器
定义 可变 NHDCE_添加总数       = 0
定义 可变 NHDCE_淘汰总数       = 0
定义 可变 NHDCE_查找总数       = 0
定义 可变 NHDCE_命中总数       = 0
定义 可变 NHDCE_扩容总数       = 0
定义 可变 NHDCE_编码总字节     = 0
定义 可变 NHDCE_解码总字节     = 0
定义 可变 NHDCE_大小更新次数   = 0
定义 可变 NHDCE_清空次数       = 0
定义 可变 NHDCE_AI检测次数     = 0


结构 HPACK动态表条目 {
    名称,        // u64 字符串指针
    名称长度,
    值,
    值长度,
    大小,        // u32 条目大小 = 名称长度 + 值长度 + 32
    访问计数,    // u32 访问频率计数器 (AI预测用)
}

结构 HPACK动态表 {
    条目,        // u64 HPACK动态表条目* 数组
    数量,
    容量,        // u32 条目数容量
    当前大小,    // u32 当前总字节数
    最大大小,    // u32 最大字节数 (SETTINGS_HEADER_TABLE_SIZE)
    索引偏移,    // u32 动态表在全局索引表中的偏移 (= 静态表大小 + 1)
}


函数 HPACK动态表_创建() {
    定义 dt = 堆_分配(48)  // 6个u64字段
    内存_置零(dt, 48)
    dt.容量 = HPACK_动态表_初始容量
    dt.条目 = 堆_分配(dt.容量 * 40)  // 每条目40字节 (含访问计数)
    内存_置零(dt.条目, dt.容量 * 40)
    dt.数量 = 0
    dt.当前大小 = 0
    dt.最大大小 = HPACK_动态表_默认最大
    dt.索引偏移 = HPACK_静态表大小 + 1
    返回 dt
}

函数 HPACK动态表_释放(dt) {
    如果 (dt == 0) { 返回 }
    // 释放所有条目的名称和值字符串
    定义 可变 i = 0
    当 (i < dt.数量) {
        定义 entry = dt.条目 + i * 40
        定义 名 = 内存_读64(entry)
        定义 值 = 内存_读64(entry + 12)
        如果 (名 != 0) { 堆_释放(名) }
        如果 (值 != 0) { 堆_释放(值) }
        i = i + 1
    }
    堆_释放(dt.条目)
    堆_释放(dt)
}


函数 HPACK动态表_条目大小(名称长度, 值长度) {
    // RFC 7541 §4.1: 条目大小 = 名称字节数 + 值字节数 + 32
    返回 名称长度 + 值长度 + HPACK_条目开销
}

函数 HPACK动态表_添加(dt, 名称, 名称长度, 值, 值长度) {
    定义 entry_size = HPACK动态表_条目大小(名称长度, 值长度)
    NHDCE_添加总数 = NHDCE_添加总数 + 1

    // 淘汰旧条目直到有足够空间
    当 (dt.当前大小 + entry_size > dt.最大大小 && dt.数量 > 0) {
        HPACK动态表_淘汰最旧(dt)
    }

    // 如果单个条目超过表大小, 清空表
    如果 (entry_size > dt.最大大小) {
        HPACK动态表_清空(dt)
        返回
    }

    // 扩容检查
    如果 (dt.数量 >= dt.容量) {
        HPACK动态表_扩容(dt)
    }

    // FIFO插入: 将现有条目后移，新条目插入头部
    如果 (dt.数量 > 0) {
        定义 可变 i = dt.数量
        当 (i > 0) {
            内存_复制(dt.条目 + i * 40, dt.条目 + (i - 1) * 40, 40)
            i = i - 1
        }
    }

    // 写入新条目
    定义 entry = dt.条目
    // 复制名称字符串
    定义 名称副本 = 堆_分配(名称长度 + 1)
    内存_复制(名称副本, 名称, 名称长度)
    内存_分08(名称副本 + 名称长度, 0)  // 终止符
    // 复制值字符串
    定义 值副本 = 堆_分配(值长度 + 1)
    内存_复制(值副本, 值, 值长度)
    内存_分08(值副本 + 值长度, 0)

    内存_分64(entry, 名称副本)
    内存_分32(entry + 8, 名称长度)
    内存_分64(entry + 12, 值副本)
    内存_分32(entry + 20, 值长度)
    内存_分32(entry + 24, entry_size)
    内存_分32(entry + 28, 0)  // 访问计数 = 0
    dt.数量 = dt.数量 + 1
    dt.当前大小 = dt.当前大小 + entry_size
}

函数 HPACK动态表_淘汰最旧(dt) {
    如果 (dt.数量 == 0) { 返回 }
    定义 last = dt.条目 + (dt.数量 - 1) * 40
    定义 条目大小 = 内存_读32(last + 24)
    // 释放字符串
    定义 名 = 内存_读64(last)
    定义 值 = 内存_读64(last + 12)
    如果 (名 != 0) { 堆_释放(名) }
    如果 (值 != 0) { 堆_释放(值) }
    dt.当前大小 = dt.当前大小 - 条目大小
    dt.数量 = dt.数量 - 1
    NHDCE_淘汰总数 = NHDCE_淘汰总数 + 1
}

函数 HPACK动态表_清空(dt) {
    当 (dt.数量 > 0) {
        HPACK动态表_淘汰最旧(dt)
    }
    NHDCE_清空次数 = NHDCE_清空次数 + 1
}

函数 HPACK动态表_扩容(dt) {
    定义 新容量 = dt.容量 * 2
    定义 新条目 = 堆_分配(新容量 * 40)
    内存_置零(新条目, 新容量 * 40)
    内存_复制(新条目, dt.条目, dt.数量 * 40)
    堆_释放(dt.条目)
    dt.条目 = 新条目
    dt.容量 = 新容量
    NHDCE_扩容总数 = NHDCE_扩容总数 + 1
}

函数 HPACK动态表_获取(dt, 索引) {
    // 索引0-based (相对于动态表)
    如果 (索引 >= dt.数量) { 返回 0 }
    定义 entry = dt.条目 + 索引 * 40
    // 更新访问计数
    定义 计数 = 内存_读32(entry + 28)
    内存_分32(entry + 28, 计数 + 1)
    NHDCE_查找总数 = NHDCE_查找总数 + 1
    NHDCE_命中总数 = NHDCE_命中总数 + 1
    返回 entry
}

// 全局索引查找: 索引 1~61 为静态表，62+ 为动态表
函数 HPACK动态表_全局获取(dt, 全局索引) {
    如果 (全局索引 == 0) { 返回 0 }  // 索引0无效
    如果 (全局索引 <= HPACK_静态表大小) {
        返回 HPACK静态表_获取(全局索引)
    }
    定义 动态索引 = 全局索引 - dt.索引偏移
    返回 HPACK动态表_获取(dt, 动态索引)
}

// 名称匹配查找: 在动态表中查找匹配的名称
函数 HPACK动态表_查找名称(dt, 名称, 名称长度) {
    NHDCE_查找总数 = NHDCE_查找总数 + 1
    定义 可变 i = 0
    当 (i < dt.数量) {
        定义 entry = dt.条目 + i * 40
        定义 e_名长 = 内存_读32(entry + 8)
        如果 (e_名长 == 名称长度) {
            定义 e_名 = 内存_读64(entry)
            如果 (内存_比较(e_名, 名称, 名称长度) == 0) {
                NHDCE_命中总数 = NHDCE_命中总数 + 1
                返回 i + dt.索引偏移  // 返回全局索引
            }
        }
        i = i + 1
    }
    返回 0  // 未找到
}

// 名称+值完全匹配查找
函数 HPACK动态表_查找完全(dt, 名称, 名称长度, 值, 值长度) {
    NHDCE_查找总数 = NHDCE_查找总数 + 1
    定义 可变 名称匹配 = 0
    定义 可变 i = 0
    当 (i < dt.数量) {
        定义 entry = dt.条目 + i * 40
        定义 e_名长 = 内存_读32(entry + 8)
        如果 (e_名长 == 名称长度) {
            定义 e_名 = 内存_读64(entry)
            如果 (内存_比较(e_名, 名称, 名称长度) == 0) {
                // 名称匹配，检查值
                如果 (名称匹配 == 0) { 名称匹配 = i + dt.索引偏移 }
                定义 e_值长 = 内存_读32(entry + 20)
                如果 (e_值长 == 值长度) {
                    定义 e_值 = 内存_读64(entry + 12)
                    如果 (内存_比较(e_值, 值, 值长度) == 0) {
                        NHDCE_命中总数 = NHDCE_命中总数 + 1
                        返回 i + dt.索引偏移  // 完全匹配
                    }
                }
            }
        }
        i = i + 1
    }
    返回 名称匹配  // 仅名称匹配或 0
}


函数 HPACK动态表_更新大小(dt, 新最大大小) {
    dt.最大大小 = 新最大大小
    // 淘汰直到当前大小在限制内
    当 (dt.当前大小 > dt.最大大小 && dt.数量 > 0) {
        HPACK动态表_淘汰最旧(dt)
    }
    NHDCE_大小更新次数 = NHDCE_大小更新次数 + 1
}

// 前缀整数: 小值直接存前缀位, 大值用128进制续字节
// 前缀位数N: 如果值 < 2^N - 1 则直接存入;
// 否则存入 2^N - 1 并用续字节表示剩余值。

函数 HPACK整数_编码(缓冲, 偏移, 值, 前缀位数) {
    // 计算前缀最大值
    定义 前缀最大 = (1 << 前缀位数) - 1
    定义 可变 pos = 偏移

    如果 (值 < 前缀最大) {
        // 小值: 直接存入前缀位
        定义 原字节 = 内存_读08(缓冲 + pos)
        定义 掩码 = 0xFF << 前缀位数  // 保留高位
        内存_分08(缓冲 + pos, (原字节 & 掩码) | 值)
        pos = pos + 1
        NHDCE_编码总字节 = NHDCE_编码总字节 + 1
    } 否则 {
        // 大值: 前缀位填满, 剩余用续字节
        定义 原字节 = 内存_读08(缓冲 + pos)
        定义 掩码 = 0xFF << 前缀位数
        内存_分08(缓冲 + pos, (原字节 & 掩码) | 前缀最大)
        pos = pos + 1
        NHDCE_编码总字节 = NHDCE_编码总字节 + 1

        定义 可变 剩余 = 值 - 前缀最大
        当 (剩余 >= 128) {
            内存_分08(缓冲 + pos, (剩余 & 0x7F) | 0x80)  // 最高位=1表示续
            pos = pos + 1
            剩余 = 剩余 >> 7
            NHDCE_编码总字节 = NHDCE_编码总字节 + 1
        }
        内存_分08(缓冲 + pos, 剩余 & 0x7F)  // 最后一个字节最高位=0
        pos = pos + 1
        NHDCE_编码总字节 = NHDCE_编码总字节 + 1
    }
    返回 pos  // 返回新偏移
}

函数 HPACK整数_解码(缓冲, 偏移, 长度, 前缀位数, 结果指针) {
    如果 (偏移 >= 长度) { 返回 -1 }  // 缓冲区不足

    定义 前缀最大 = (1 << 前缀位数) - 1
    定义 可变 pos = 偏移
    定义 第一字节 = 内存_读08(缓冲 + pos) & 前缀最大
    pos = pos + 1
    NHDCE_解码总字节 = NHDCE_解码总字节 + 1

    如果 (第一字节 < 前缀最大) {
        // 小值: 直接返回
        内存_分64(结果指针, 第一字节)
        返回 pos
    }

    // 大值: 解码续字节
    定义 可变 结果 = 前缀最大
    定义 可变 移位 = 0
    定义 可变 字节数 = 0

    定义 可变 继续 = 1
    当 (继续 && pos < 长度) {
        定义 b = 内存_读08(缓冲 + pos)
        pos = pos + 1
        字节数 = 字节数 + 1
        NHDCE_解码总字节 = NHDCE_解码总字节 + 1

        结果 = 结果 + ((b & 0x7F) << 移位)
        移位 = 移位 + 7

        如果 ((b & 0x80) == 0) {
            继续 = 0
        }

        // 防止无限循环: 最多 HPACK_整数最大字节 个续字节
        如果 (字节数 >= HPACK_整数最大字节) {
            返回 -1  // 解码错误
        }
    }

    如果 (继续) { 返回 -1 }  // 缓冲区截断
    内存_分64(结果指针, 结果)
    返回 pos
}

// H位=0 表示原始字符串, H位=1 表示Huffman编码

函数 HPACK字符串_编码(缓冲, 偏移, 数据, 数据长度, 使Huffman) {
    定义 可变 pos = 偏移

    如果 (使Huffman) {
        // Huffman编码路径
        定义 huff长 = HPACK_Huffman编码长度(数据, 数据长度)
        // 写入长度, H位=1
        内存_分08(缓冲 + pos, 0x80)  // 设置H位
        pos = HPACK整数_编码(缓冲, pos, huff长, 7)
        // 写入Huffman编码数据
        pos = HPACK_Huffman编码(缓冲, pos, 数据, 数据长度)
    } 否则 {
        // 原始字符串路径
        内存_分08(缓冲 + pos, 0)  // H位=0
        pos = HPACK整数_编码(缓冲, pos, 数据长度, 7)
        // 复制原始数据
        如果 (数据长度 > 1048576) { 返回 -1 }  // 1MB安全上限
        内存_复制(缓冲 + pos, 数据, 数据长度)
        pos = pos + 数据长度
    }
    NHDCE_编码总字节 = NHDCE_编码总字节 + (pos - 偏移)
    返回 pos
}

函数 HPACK字符串_解码(缓冲, 偏移, 长度, 输出指针, 输出长度指针) {
    如果 (偏移 >= 长度) { 返回 -1 }
    定义 可变 pos = 偏移

    // 读取H位和字符串长度
    定义 第一字节 = 内存_读08(缓冲 + pos)
    定义 是Huffman = (第一字节 & 0x80) != 0
    定义 可变 字符串长 = 0
    定义 字符串长指针 = 堆_分配(8)
    pos = HPACK整数_解码(缓冲, pos, 长度, 7, 字符串长指针)
    如果 (pos < 0) {
        堆_释放(字符串长指针)
        返回 -1
    }
    字符串长 = 内存_读64(字符串长指针)
    堆_释放(字符串长指针)

    // 安全检查
    如果 (字符串长 > HPACK_最大字符串长 || pos + 字符串长 > 长度) {
        返回 -1
    }

    如果 (是Huffman) {
        // Huffman解码
        定义 解码缓冲 = 堆_分配(字符串长 * 2)  // Huffman解码后可能更长
        定义 解码长 = HPACK_Huffman解码(缓冲 + pos, 字符串长, 解码缓冲)
        如果 (解码长 < 0) {
            堆_释放(解码缓冲)
            返回 -1
        }
        内存_分64(输出指针, 解码缓冲)
        内存_分64(输出长度指针, 解码长)
    } 否则 {
        // 原始字符串: 直接复制
        定义 副本 = 堆_分配(字符串长 + 1)
        内存_复制(副本, 缓冲 + pos, 字符串长)
        内存_分08(副本 + 字符串长, 0)
        内存_分64(输出指针, 副本)
        内存_分64(输出长度指针, 字符串长)
    }

    pos = pos + 字符串长
    NHDCE_解码总字节 = NHDCE_解码总字节 + (pos - 偏移)
    返回 pos
}


// 索引头部字段表示 (RFC 7541 §6.1)
// 格式: 1xxxxxxx — 7位前缀索引
函数 HPACK编码_索引头部(缓冲, 偏移, 索引) {
    内存_分08(缓冲 + 偏移, 0x80)  // 最高位 = 1
    返回 HPACK整数_编码(缓冲, 偏移, 索引, 7)
}

// 带索引的字面头部字段 (RFC 7541 §6.2.1)
// 格式: 01xxxxxx — 6位前缀索引, 后跟值字符串
函数 HPACK编码_字面带索引(缓冲, 偏移, 名称索引, 值, 值长度) {
    内存_分08(缓冲 + 偏移, 0x40)  // 01xxxxxx
    定义 可变 pos = HPACK整数_编码(缓冲, 偏移, 名称索引, 6)
    pos = HPACK字符串_编码(缓冲, pos, 值, 值长度, 0)
    返回 pos
}

// 完全新的字面头部字段 (RFC 7541 §6.2.1)
函数 HPACK编码_字面新名(缓冲, 偏移, 名称, 名称长度, 值, 值长度) {
    内存_分08(缓冲 + 偏移, 0x40)  // 01xxxxxx, 索引=0
    定义 可变 pos = 偏移 + 1
    pos = HPACK字符串_编码(缓冲, pos, 名称, 名称长度, 0)
    pos = HPACK字符串_编码(缓冲, pos, 值, 值长度, 0)
    返回 pos
}

// 不索引的字面头部字段 (RFC 7541 §6.2.2)
// 格式: 0000xxxx — 4位前缀索引
函数 HPACK编码_字面不索引(缓冲, 偏移, 名称索引, 值, 值长度) {
    内存_分08(缓冲 + 偏移, 0x00)  // 0000xxxx
    定义 可变 pos = HPACK整数_编码(缓冲, 偏移, 名称索引, 4)
    pos = HPACK字符串_编码(缓冲, pos, 值, 值长度, 0)
    返回 pos
}

// 永不索引的字面头部字段 (RFC 7541 §6.2.3)
// 格式: 0001xxxx — 4位前缀索引
函数 HPACK编码_字面永不索引(缓冲, 偏移, 名称索引, 值, 值长度) {
    内存_分08(缓冲 + 偏移, 0x10)  // 0001xxxx
    定义 可变 pos = HPACK整数_编码(缓冲, 偏移, 名称索引, 4)
    pos = HPACK字符串_编码(缓冲, pos, 值, 值长度, 0)
    返回 pos
}

// 动态表大小更新编码 (RFC 7541 §6.3)
// 格式: 001xxxxx — 5位前缀
函数 HPACK编码_大小更新(缓冲, 偏移, 新大小) {
    内存_分08(缓冲 + 偏移, 0x20)  // 001xxxxx
    返回 HPACK整数_编码(缓冲, 偏移, 新大小, 5)
}

// 采用近似HPACK Huffman码表，覆盖常见ASCII字符并对其余字符回退到8位编码。

函数 HPACK_Huffman编码长度(数据, 数据长度) {
    // 估算Huffman编码后的字节数
    定义 可变 总位 = 0
    定义 可变 i = 0
    当 (i < 数据长度) {
        定义 ch = 内存_读08(数据 + i)
        总位 = 总位 + HPACK_Huffman码长(ch)
        i = i + 1
    }
    // 向上取整到字节边界
    返回 (总位 + 7) / 8
}

函数 HPACK_Huffman编码(缓冲, 偏移, 数据, 数据长度) {
    定义 可变 pos = 偏移
    定义 可变 位缓冲 = 0
    定义 可变 位数 = 0
    定义 可变 i = 0

    当 (i < 数据长度) {
        定义 ch = 内存_读08(数据 + i)
        定义 码字 = HPACK_Huffman获取码字(ch)
        定义 码长 = HPACK_Huffman码长(ch)

        // 将码字写入位流
        定义 可变 j = 码长
        当 (j > 0) {
            j = j - 1
            位缓冲 = (位缓冲 << 1) | ((码字 >> j) & 1)
            位数 = 位数 + 1
            如果 (位数 == 8) {
                内存_分08(缓冲 + pos, 位缓冲)
                pos = pos + 1
                位缓冲 = 0
                位数 = 0
            }
        }
        i = i + 1
    }

    // 填充末尾位: 用EOS码的前缀填充
    如果 (位数 > 0) {
        位缓冲 = 位缓冲 << (8 - 位数)
        位缓冲 = 位缓冲 | ((1 << (8 - 位数)) - 1)  // 填1
        内存_分08(缓冲 + pos, 位缓冲)
        pos = pos + 1
    }
    返回 pos
}

函数 HPACK_Huffman解码(编码数据, 编码长度, 输出) {
    定义 可变 输出长 = 0
    定义 可变 位缓存 = 0
    定义 可变 位数 = 0
    定义 可变 i = 0

    当 (i < 编码长度) {
        位缓存 = (位缓存 << 8) | 内存_读08(编码数据 + i)
        位数 = 位数 + 8
        i = i + 1

        当 (位数 >= 5) {
            定义 匹配 = HPACK_Huffman匹配(位缓存, 位数)
            如果 (匹配 < 0) { 跳出 }
            定义 码长 = HPACK_Huffman码长(匹配)
            定义 剩余 = 位数 - 码长
            如果 (剩余 > 0) {
                位缓存 = 位缓存 & ((1 << 剩余) - 1)
            } 否则 {
                位缓存 = 0
            }
            位数 = 剩余
            内存_分08(输出 + 输出长, 匹配)
            输出长 = 输出长 + 1
        }
    }
    返回 输出长
}

函数 HPACK_Huffman码表(ch) {
    如果 (ch == 0x30) { 返回 0x00 }
    如果 (ch == 0x31) { 返回 0x01 }
    如果 (ch == 0x32) { 返回 0x02 }
    如果 (ch == 0x61) { 返回 0x03 }
    如果 (ch == 0x63) { 返回 0x04 }
    如果 (ch == 0x65) { 返回 0x05 }
    如果 (ch == 0x69) { 返回 0x06 }
    如果 (ch == 0x6F) { 返回 0x07 }
    如果 (ch == 0x73) { 返回 0x08 }
    如果 (ch == 0x74) { 返回 0x09 }
    返回 ch
}

函数 HPACK_Huffman码长(ch) {
    如果 (ch >= 0x30 && ch <= 0x39) { 返回 5 }
    如果 (ch >= 0x61 && ch <= 0x7A) { 返回 5 }
    如果 (ch >= 0x41 && ch <= 0x5A) { 返回 6 }
    如果 (ch == 0x20) { 返回 6 }
    如果 (ch == 0x2F) { 返回 6 }
    如果 (ch == 0x3A) { 返回 7 }
    如果 (ch == 0x2D) { 返回 6 }
    如果 (ch == 0x2E) { 返回 6 }
    如果 (ch == 0x2C) { 返回 7 }
    返回 8
}

函数 HPACK_Huffman获取码字(ch) {
    返回 HPACK_Huffman码表(ch)
}

函数 HPACK_Huffman匹配(bit_buf, bit_count) {
    定义 可变 ch = 0
    当 (ch < 256) {
        定义 码长 = HPACK_Huffman码长(ch)
        如果 (码长 <= bit_count) {
            定义 码 = HPACK_Huffman码表(ch)
            定义 提取 = (bit_buf >> (bit_count - 码长)) & ((1 << 码长) - 1)
            如果 (提取 == 码) { 返回 ch }
        }
        ch = ch + 1
    }
    返回 -1
}

函数 HPACK_Huffman状态转移(状态, 位) { 返回 状态 * 2 + 位 }
函数 HPACK_Huffman是取值(转移) { 返回 转移 >= 256 }
函数 HPACK_Huffman获取值(转移) { 返回 转移 & 0xFF }
函数 HPACK_Huffman新状态(转移) {
    // 从Huffman状态转移值中提取下一个解码状态
    // 高位=是否为终态, 低8位=输出字节, 中间位=下一状态
    如果 (转移 >= 256) { 返回 (转移 >> 8) & 0xFF }  // 有输出时取中间位
    返回 转移  // 无输出时转移值即为下一状态
}

// RFC 7541 Appendix A 定义的61条静态表条目。
// 实际静态表数据由外部模块提供，此处定义查询接口。

函数 HPACK静态表_获取(索引) {
    如果 (索引 < 1 || 索引 > HPACK_静态表大小) { 返回 0 }
    // 返回静态表条目指针 (外部模块实现)
    返回 HPACK静态表_条目数据 + (索引 - 1) * 40
}

函数 HPACK静态表_查找名称(名称, 名称长度) {
    定义 可变 i = 1
    当 (i <= HPACK_静态表大小) {
        定义 entry = HPACK静态表_获取(i)
        如果 (entry != 0) {
            定义 e_名长 = 内存_读32(entry + 8)
            如果 (e_名长 == 名称长度) {
                定义 e_名 = 内存_读64(entry)
                如果 (内存_比较(e_名, 名称, 名称长度) == 0) {
                    返回 i
                }
            }
        }
        i = i + 1
    }
    返回 0
}

// 利用全局AI总线评估动态表压缩效率和异常模式。

函数 NHDCE_AI压缩检测(dt) {
    定义 t = Tensor_创建(HPACK_AI特征维度, 1)
    如果 (t == 0) { 返回 0 }

    // 填充特征向量
    定义 命中率 = 0
    如果 (NHDCE_查找总数 > 0) {
        命中率 = (NHDCE_命中总数 * 100) / NHDCE_查找总数
    }
    定义 填充率 = 0
    如果 (dt.最大大小 > 0) {
        填充率 = (dt.当前大小 * 100) / dt.最大大小
    }

    Tensor_写(t, 0, dt.数量)
    Tensor_写(t, 1, dt.当前大小)
    Tensor_写(t, 2, dt.最大大小)
    Tensor_写(t, 3, NHDCE_添加总数)
    Tensor_写(t, 4, NHDCE_淘汰总数)
    Tensor_写(t, 5, 命中率)
    Tensor_写(t, 6, 填充率)
    Tensor_写(t, 7, NHDCE_编码总字节)
    Tensor_写(t, 8, NHDCE_解码总字节)
    定义 字节总和 = NHDCE_编码总字节 + NHDCE_解码总字节
    定义 字节失衡 = 0
    如果 (字节总和 > 0) {
        定义 差值 = NHDCE_编码总字节 - NHDCE_解码总字节
        如果 (差值 < 0) { 差值 = 0 - 差值 }
        字节失衡 = 差值 * 1000 / 字节总和
    }
    Tensor_写(t, 9, 字节失衡)

    定义 结果 = AI总线_推理(t, "nhdce_压缩效率检测")
    定义 异常分 = 0
    如果 (结果 != 0) {
        异常分 = Tensor_读(结果, 0)
    }

    // 启发式规则
    如果 (命中率 < 20 && NHDCE_查找总数 > 100) {
        异常分 = 异常分 + 40  // 命中率过低
    }
    如果 (填充率 > 95) {
        异常分 = 异常分 + 20  // 表几乎已满
    }
    如果 (NHDCE_淘汰总数 > NHDCE_添加总数 * 2) {
        异常分 = 异常分 + 30  // 淘汰过于频繁
    }

    Tensor_写(t, 9, 异常分)
    NHDCE_AI检测次数 = NHDCE_AI检测次数 + 1

    Tensor_释放(t)
    如果 (结果 != 0) { Tensor_释放(结果) }
    返回 异常分
}


函数 NHDCE_获取统计() {
    定义 s = 堆_分配(96)
    内存_置零(s, 96)
    内存_分64(s + 0,  NHDCE_添加总数)
    内存_分64(s + 8,  NHDCE_淘汰总数)
    内存_分64(s + 16, NHDCE_查找总数)
    内存_分64(s + 24, NHDCE_命中总数)
    内存_分64(s + 32, NHDCE_扩容总数)
    内存_分64(s + 40, NHDCE_编码总字节)
    内存_分64(s + 48, NHDCE_解码总字节)
    内存_分64(s + 56, NHDCE_大小更新次数)
    内存_分64(s + 64, NHDCE_清空次数)
    内存_分64(s + 72, NHDCE_AI检测次数)
    返回 s
}

函数 NHDCE_重置统计() {
    NHDCE_添加总数     = 0
    NHDCE_淘汰总数     = 0
    NHDCE_查找总数     = 0
    NHDCE_命中总数     = 0
    NHDCE_扩容总数     = 0
    NHDCE_编码总字节   = 0
    NHDCE_解码总字节   = 0
    NHDCE_大小更新次数 = 0
    NHDCE_清空次数     = 0
    NHDCE_AI检测次数   = 0
}

函数 NHDCE_自检() {
    定义 可变 错误 = 0

    // 常量检查
    如果 (HPACK_动态表_默认最大 != 4096) { 错误 = 错误 + 1 }
    如果 (HPACK_条目开销 != 32)            { 错误 = 错误 + 1 }
    如果 (HPACK_静态表大小 != 61)          { 错误 = 错误 + 1 }

    // 条目大小计算检查
    如果 (HPACK动态表_条目大小(10, 20) != 62) { 错误 = 错误 + 1 }
    如果 (HPACK动态表_条目大小(0, 0) != 32)   { 错误 = 错误 + 1 }

    // 创建测试表并验证
    定义 dt = HPACK动态表_创建()
    如果 (dt == 0)                    { 错误 = 错误 + 1 }
    如果 (dt.数量 != 0)               { 错误 = 错误 + 1 }
    如果 (dt.当前大小 != 0)           { 错误 = 错误 + 1 }
    如果 (dt.最大大小 != 4096)        { 错误 = 错误 + 1 }
    如果 (dt.索引偏移 != 62)          { 错误 = 错误 + 1 }

    // 统计一致性检查
    如果 (NHDCE_命中总数 > NHDCE_查找总数) { 错误 = 错误 + 1 }

    HPACK动态表_释放(dt)
    返回 错误
}


导入("../数学/矩阵.nova")
导入("../基础.nova")

// 矩阵: [行数, 列数, 数据(一维列表)]
函数 矩阵核心_矩阵_创建(行, 列) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 行 * 列) { 追加(数据, 0) i = i + 1 }
 返回 [行, 列, 数据]
}

函数 矩阵核心_矩阵_行数(m) { 返回 m[0] }
函数 矩阵核心_矩阵_列数(m) { 返回 m[1] }
函数 矩阵核心_矩阵_取(m, 行, 列) { 返回 m[2][行 * m[1] + 列] }
函数 矩阵核心_矩阵_设(m, 行, 列, 值) { m[2][行 * m[1] + 列] = 值 }

函数 矩阵核心_矩阵_单位(n) { 定义 m = 矩阵_创建(n, n)
 定义 可变 i = 0
 当 (i < n) { 矩阵_设(m, i, i, 1) i = i + 1 }
 返回 m
}

函数 矩阵核心_矩阵_加(a, b) { 定义 行 = 矩阵_行数(a)
 定义 列 = 矩阵_列数(a)
 定义 r = 矩阵_创建(行, 列)
 定义 可变 i = 0
 当 (i < 行) { 定义 可变 j = 0
 当 (j < 列) {
 矩阵_设(r, i, j, 矩阵_取(a, i, j) + 矩阵_取(b, i, j))
 j = j + 1
 }
 i = i + 1
 }
 返回 r
}

函数 矩阵核心_矩阵_减(a, b) { 定义 行 = 矩阵_行数(a)
 定义 列 = 矩阵_列数(a)
 定义 r = 矩阵_创建(行, 列)
 定义 可变 i = 0
 当 (i < 行) { 定义 可变 j = 0
 当 (j < 列) {
 矩阵_设(r, i, j, 矩阵_取(a, i, j) - 矩阵_取(b, i, j))
 j = j + 1
 }
 i = i + 1
 }
 返回 r
}

函数 矩阵核心_矩阵_乘(a, b) { 定义 行 = 矩阵_行数(a)
 定义 列 = 矩阵_列数(b)
 定义 内 = 矩阵_列数(a)
 定义 r = 矩阵_创建(行, 列)
 定义 可变 i = 0
 当 (i < 行) { 定义 可变 j = 0
 当 (j < 列) { 定义 可变 和 = 0
 定义 可变 k = 0
 当 (k < 内) {
 和 = 和 + 矩阵_取(a, i, k) * 矩阵_取(b, k, j)
 k = k + 1
 }
 矩阵_设(r, i, j, 和)
 j = j + 1
 }
 i = i + 1
 }
 返回 r
}

函数 矩阵核心_矩阵_标量乘(m, s) { 定义 行 = 矩阵_行数(m)
 定义 列 = 矩阵_列数(m)
 定义 r = 矩阵_创建(行, 列)
 定义 可变 i = 0
 当 (i < 行 * 列) { r[2][i] = m[2][i] * s i = i + 1 }
 返回 r
}

函数 矩阵核心_矩阵_转置(m) { 定义 行 = 矩阵_行数(m)
 定义 列 = 矩阵_列数(m)
 定义 r = 矩阵_创建(列, 行)
 定义 可变 i = 0
 当 (i < 行) { 定义 可变 j = 0
 当 (j < 列) {
 矩阵_设(r, j, i, 矩阵_取(m, i, j))
 j = j + 1
 }
 i = i + 1
 }
 返回 r
}

函数 矩阵_余子式(m, 删行, 删列) { 定义 n = 矩阵_行数(m)
    定义 可变 ri = 0
 定义 r = 矩阵_创建(n - 1, n - 1)
 定义 可变 i = 0
 当 (i < n) { 如果 (i != 删行) { 定义 可变 ci = 0
 定义 可变 j = 0
 当 (j < n) { 如果 (j != 删列) {
 矩阵_设(r, ri, ci, 矩阵_取(m, i, j))
 ci = ci + 1
 }
 j = j + 1
 }
 ri = ri + 1
 }
 i = i + 1
 }
 返回 r
}

函数 矩阵_行列式(m) { 定义 n = 矩阵_行数(m)
 如果 (n == 1) { 返回 矩阵_取(m, 0 , 0) }
 如果 (n == 2) { 返回 矩阵_取(m, 0, 0)*矩阵_取(m,1,1) - 矩阵_取(m,0,1)*矩阵_取(m, 1, 0)
 }
 定义 可变 结果 = 0
 定义 可变 j = 0
 定义 可变 符号 = 1
 当 (j < n) {
 结果 = 结果 + 符号 * 矩阵_取(m, 0, j) * 矩阵_行列式(矩阵_余子式(m, 0, j))
 符号 = 0 - 符号
 j = j + 1
 }
 返回 结果
}

// 向量运算

函数 矩阵核心_向量_点积(a, b) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 计数(a)) { 和 = 和 + a[i] * b[i] i = i + 1 }
 返回 和
}

函数 矩阵核心_向量_叉积(a, b) { 返回 [a[1]*b[2]-a[2]*b[1], a[2]*b[0]-a[0]*b[2], a[0]*b[1]-a[1]*b[0]]
}

函数 矩阵核心_向量_长度(v) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 计数(v)) { 和 = 和 + v[i] * v[i] i = i + 1 }
 返回 幂(和, 0.5)
}

函数 矩阵核心_向量_归一化(v) { 定义 长 = 矩阵核心_向量_长度(v)
 如果 (长 == 0) { 返回 v }
 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(v)) { 追加(r, v[i] / 长) i = i + 1 }
 返回 r
}

函数 矩阵核心_向量_加(a, b) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(a)) { 追加(r, a[i] + b[i]) i = i + 1 }
 返回 r
}

函数 矩阵核心_向量_减(a, b) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(a)) { 追加(r, a[i] - b[i]) i = i + 1 }
 返回 r
}

函数 矩阵核心_向量_缩放(v, s) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(v)) { 追加(r, v[i] * s) i = i + 1 }
 返回 r
}

// 向量点积
函数 矩阵核心_点积(a, b) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 计数(a)) { 和 = 和 + a[i] * b[i] i = i + 1 }
 返回 和
}

// 向量范数平方
函数 矩阵核心_范数平方(v) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 计数(v)) { 和 = 和 + v[i] * v[i] i = i + 1 }
 返回 和
}

// 向量归一化
函数 矩阵核心_归一化(v) { 定义 范数 = 矩阵核心_范数平方(v)
 如果 (范数 == 0) { 返回 v }
 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(v)) { 追加(r, v[i] * 1000 / (范数 + 1)) i = i + 1 }
 返回 r
}

// 逐元素操作
函数 矩阵核心_逐元素乘(a, b) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(a)) { 追加(r, a[i] * b[i] / 1000) i = i + 1 }
 返回 r
}

函数 矩阵核心_逐元素最大(a, b) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(a)) { 如果 (a[i] > b[i]) { 追加(r, a[i]) } 否则 { 追加(r, b[i]) }
 i = i + 1
 }
 返回 r
}

// 零向量/单位向量
函数 矩阵核心_零向量(维度) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 维度) { 追加(r, 0) i = i + 1 }
 返回 r
}

函数 矩阵核心_单位向量(维度, 索引) { 定义 可变 r = 矩阵核心_零向量(维度)
 如果 (索引 >= 0 且 索引 < 维度) { r[索引] = 1000 }
 返回 r
}

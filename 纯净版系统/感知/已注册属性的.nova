// NovaOS · CSS @property引擎 + 动画插值
// 功能:
//  §1 数据结构: 注册属性模型+语法类型
//  §2 @property规则解析: syntax/inherits/initial-value
//  §3 CSS.registerProperty API
//  §4 语法验证: <color>/<length>/<number>/<percentage>/<transform>
//  §5 颜色插值: RGBA/HSLA分量线性插值
//  §6 数值/长度/百分比插值
//  §7 离散切换: 通配符"*"语法
//  §8 var()循环检测: DFS+访问栈
//  §9 AI缓动优化: EWMA插值缓存+意图推断

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("./变量取值.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/内核打印.nova")
导入("../执行/控制台输出.nova")
导入("../推理/值乘.nova")
导入("../中枢/辅助存根.nova")
导入("../中枢/整数转字符串.nova")
导入("../推理/智能总线鼠标.nova")

// §1 数据结构

定义 SYNTAX_UNIVERSAL  = 0   // "*" — 离散切换
定义 SYNTAX_COLOR      = 1   // "<color>"
定义 SYNTAX_LENGTH     = 2   // "<length>"
定义 SYNTAX_NUMBER     = 3   // "<number>"
定义 SYNTAX_PERCENTAGE  = 4   // "<percentage>"
定义 SYNTAX_TRANSFORM   = 5   // "<transform-list>"
定义 SYNTAX_INTEGER     = 6   // "<integer>"
定义 SYNTAX_LENGTH_PCT  = 7   // "<length-percentage>"
定义 SYNTAX_IMAGE       = 8   // "<image>"
定义 SYNTAX_CUSTOM_IDENT = 9  // "<custom-ident>"

定义 VAR_MAX_DEPTH = 32
定义 MAX_REGISTERED_PROPS = 128
定义 Q10 = 1024

结构 注册属性 {
    名称,          // 字符串: "--xxx"
    语法,          // SYNTAX_*
    可继承,
    初始值,
    可动画,        // 布尔: 语法非"*"时为真
}

结构 颜色值 {
    r, g, b, a,   // 0-255, a为Q10定点(0-1024)
}

结构 插值结果 {
    类型,          // SYNTAX_*
    数值结果,      // 用于数值/长度/百分比
    颜色结果,      // 颜色值
    字符串结果,    // 用于离散切换
}

定义 可变 注册属性表 = []   // 注册属性[]
定义 可变 插值缓存命中 = 0
定义 可变 插值缓存未中 = 0

// §2 @property规则解析
// @property --my-color { syntax: '<color>'; inherits: false; initial-value: black; }


函数 AtProperty_解析(规则文本, 长度) {
    如果 (规则文本 == 0 || 长度 < 10) { 返回 假 }

    // 提取属性名: 找 "--" 开头
    定义 可变 名称 = 0
    定义 可变 pos = 0
    当 (pos + 2 < 长度) {
        如果 (字节取(规则文本, pos) == 0x2D && 字节取(规则文本, pos + 1) == 0x2D) {
            定义 start = pos
            当 (pos < 长度 && 字节取(规则文本, pos) != 32 && 字节取(规则文本, pos) != 123) {
                pos = pos + 1
            }
            名称 = 字符串_子串(规则文本, start, pos)
            跳出
        }
        pos = pos + 1
    }
    如果 (名称 == 0) { 返回 假 }

    // 提取描述符
    定义 可变 syntax_str = "*"
    定义 可变 inherits_val = 真
    定义 可变 initial_val = 0

    定义 syn_pos = AtProperty_查找描述符(规则文本, 长度, "syntax:")
    如果 (syn_pos >= 0) {
        syntax_str = AtProperty_提取值(规则文本, 长度, syn_pos + 7)
    }
    定义 inh_pos = AtProperty_查找描述符(规则文本, 长度, "inherits:")
    如果 (inh_pos >= 0) {
        定义 inh_str = AtProperty_提取值(规则文本, 长度, inh_pos + 9)
        inherits_val = !字符串_相等(inh_str, "false")
    }
    定义 init_pos = AtProperty_查找描述符(规则文本, 长度, "initial-value:")
    如果 (init_pos >= 0) {
        initial_val = AtProperty_提取值(规则文本, 长度, init_pos + 14)
    }

    // 注册
    返回 RegisterProperty_注册(名称, syntax_str, inherits_val, initial_val)
}

函数 AtProperty_查找描述符(文本, 长度, 关键字) {
    定义 klen = 字符串长度(关键字)
    定义 可变 i = 0
    当 (i + klen <= 长度) {
        如果 (字符串_子串匹配(文本, i, 关键字)) {
            返回 i
        }
        i = i + 1
    }
    返回 -1
}

函数 AtProperty_提取值(文本, 长度, 起始) {
    // 跳过空白和引号, 读取到 ; 或 }
    定义 可变 p = 起始
    当 (p < 长度 && (字节取(文本, p) == 32 || 字节取(文本, p) == 39 || 字节取(文本, p) == 34)) {
        p = p + 1
    }
    定义 val_start = p
    当 (p < 长度 && 字节取(文本, p) != 59 && 字节取(文本, p) != 125 && 字节取(文本, p) != 39 && 字节取(文本, p) != 34) {
        p = p + 1
    }
    // 去尾部空白
    当 (p > val_start && 字节取(文本, p - 1) == 32) { p = p - 1 }
    返回 字符串_子串(文本, val_start, p)
}

// §3 CSS.registerProperty API

函数 RegisterProperty_注册(名称, 语法字符串, 可继承, 初始值) {
    如果 (计数(注册属性表) >= MAX_REGISTERED_PROPS) { 返回 假 }
    // 检查重复注册
    定义 可变 i = 0
    当 (i < 计数(注册属性表)) {
        如果 (字符串_相等(注册属性表[i].名称, 名称)) {
            返回 假  // 已注册
        }
        i = i + 1
    }

    定义 prop = 注册属性 {}
    prop.名称 = 名称
    prop.语法 = 解析语法类型(语法字符串)
    prop.可继承 = 可继承
    prop.初始值 = 初始值
    prop.可动画 = (prop.语法 != SYNTAX_UNIVERSAL)
    追加(注册属性表, prop)
    返回 真
}

函数 RegisterProperty_查找(名称) {
    定义 可变 i = 0
    当 (i < 计数(注册属性表)) {
        如果 (字符串_相等(注册属性表[i].名称, 名称)) {
            返回 注册属性表[i]
        }
        i = i + 1
    }
    返回 0
}

// §4 语法类型解析 + 值验证

函数 解析语法类型(语法字符串) {
    如果 (字符串_相等(语法字符串, "<color>"))            { 返回 SYNTAX_COLOR }
    如果 (字符串_相等(语法字符串, "<length>"))           { 返回 SYNTAX_LENGTH }
    如果 (字符串_相等(语法字符串, "<number>"))           { 返回 SYNTAX_NUMBER }
    如果 (字符串_相等(语法字符串, "<percentage>"))       { 返回 SYNTAX_PERCENTAGE }
    如果 (字符串_相等(语法字符串, "<transform-list>"))   { 返回 SYNTAX_TRANSFORM }
    如果 (字符串_相等(语法字符串, "<integer>"))          { 返回 SYNTAX_INTEGER }
    如果 (字符串_相等(语法字符串, "<length-percentage>")) { 返回 SYNTAX_LENGTH_PCT }
    如果 (字符串_相等(语法字符串, "<image>"))            { 返回 SYNTAX_IMAGE }
    如果 (字符串_相等(语法字符串, "<custom-ident>"))     { 返回 SYNTAX_CUSTOM_IDENT }
    返回 SYNTAX_UNIVERSAL
}

函数 验证属性值(prop, 值) {
    如果 (prop == 0) { 返回 真 }  // 未注册属性接受任何值
    如果 (prop.语法 == SYNTAX_UNIVERSAL) { 返回 真 }
    如果 (prop.语法 == SYNTAX_COLOR) {
        返回 颜色_解析(值) != 0
    }
    如果 (prop.语法 == SYNTAX_LENGTH) {
        返回 长度_解析(值) >= 0
    }
    如果 (prop.语法 == SYNTAX_NUMBER || prop.语法 == SYNTAX_INTEGER) {
        返回 数值_解析(值) != 0x7FFFFFFF
    }
    如果 (prop.语法 == SYNTAX_PERCENTAGE) {
        定义 len = 字符串长度(值)
        返回 len > 0 && 字节取(值, len - 1) == 37  // '%'
    }
    返回 真
}

// §5 颜色插值: RGBA分量线性 + HSLA插值
// 创新: 感知均匀HSLA插值避免色相突变

函数 颜色_插值RGBA(从, 到, 进度) {
    // 进度: 0-Q10 (0-1024 表示 0.0-1.0)
    定义 r = 颜色值 {}
    r.r = 从.r + (到.r - 从.r) * 进度 / Q10
    r.g = 从.g + (到.g - 从.g) * 进度 / Q10
    r.b = 从.b + (到.b - 从.b) * 进度 / Q10
    r.a = 从.a + (到.a - 从.a) * 进度 / Q10
    // clamp 0-255
    如果 (r.r < 0) { r.r = 0 } 如果 (r.r > 255) { r.r = 255 }
    如果 (r.g < 0) { r.g = 0 } 如果 (r.g > 255) { r.g = 255 }
    如果 (r.b < 0) { r.b = 0 } 如果 (r.b > 255) { r.b = 255 }
    如果 (r.a < 0) { r.a = 0 } 如果 (r.a > Q10) { r.a = Q10 }
    返回 r
}

函数 颜色_解析十六进制(值) {
    // 解析 #RRGGBB 或 #RGB
    如果 (值 == 0) { 返回 0 }
    定义 len = 字符串长度(值)
    如果 (len < 4 || 字节取(值, 0) != 35) { 返回 0 }  // 不以#开头
    定义 c = 颜色值 {}
    如果 (len == 7) {
        // #RRGGBB
        c.r = 十六进制_解析两位(值, 1)
        c.g = 十六进制_解析两位(值, 3)
        c.b = 十六进制_解析两位(值, 5)
        c.a = Q10
    } 否则如果 (len == 4) {
        // #RGB
        c.r = 十六进制_解析一位(值, 1) * 17
        c.g = 十六进制_解析一位(值, 2) * 17
        c.b = 十六进制_解析一位(值, 3) * 17
        c.a = Q10
    } 否则 { 返回 0 }
    返回 c
}

函数 十六进制_解析一位(值, pos) {
    定义 ch = 字节取(值, pos)
    如果 (ch >= 48 && ch <= 57)  { 返回 ch - 48 }
    如果 (ch >= 65 && ch <= 70)  { 返回 ch - 55 }
    如果 (ch >= 97 && ch <= 102) { 返回 ch - 87 }
    返回 0
}

函数 十六进制_解析两位(值, pos) {
    返回 十六进制_解析一位(值, pos) * 16 + 十六进制_解析一位(值, pos + 1)
}

函数 颜色_解析命名(值) {
    // 基本命名颜色解析
    如果 (字符串_相等(值, "black"))       { 返回 颜色值 { r: 0,   g: 0,   b: 0,   a: Q10 } }
    如果 (字符串_相等(值, "white"))       { 返回 颜色值 { r: 255, g: 255, b: 255, a: Q10 } }
    如果 (字符串_相等(值, "red"))         { 返回 颜色值 { r: 255, g: 0,   b: 0,   a: Q10 } }
    如果 (字符串_相等(值, "green"))       { 返回 颜色值 { r: 0,   g: 128, b: 0,   a: Q10 } }
    如果 (字符串_相等(值, "blue"))        { 返回 颜色值 { r: 0,   g: 0,   b: 255, a: Q10 } }
    如果 (字符串_相等(值, "transparent")) { 返回 颜色值 { r: 0,   g: 0,   b: 0,   a: 0 } }
    返回 0
}

函数 颜色_解析(值) {
    如果 (值 == 0) { 返回 0 }
    定义 hex = 颜色_解析十六进制(值)
    如果 (hex != 0) { 返回 hex }
    返回 颜色_解析命名(值)
}

// §6 动画插值引擎

函数 RegisteredProperty_插值(reg, 从值字符串, 到值字符串, 进度) {
    如果 (reg == 0 || !reg.可动画) {
        // 离散切换: 进度<50%返回从值, >=50%返回到值
        定义 r = 插值结果 {}
        r.类型 = SYNTAX_UNIVERSAL
        r.字符串结果 = 如果(进度 < Q10 / 2, 从值字符串, 到值字符串)
        返回 r
    }

    定义 r = 插值结果 {}
    r.类型 = reg.语法

    如果 (reg.语法 == SYNTAX_COLOR) {
        定义 c_from = 颜色_解析(从值字符串)
        定义 c_to = 颜色_解析(到值字符串)
        如果 (c_from != 0 && c_to != 0) {
            r.颜色结果 = 颜色_插值RGBA(c_from, c_to, 进度)
        }
        返回 r
    }

    如果 (reg.语法 == SYNTAX_NUMBER || reg.语法 == SYNTAX_INTEGER) {
        定义 from_n = 数值_解析(从值字符串)
        定义 to_n = 数值_解析(到值字符串)
        r.数值结果 = from_n + (to_n - from_n) * 进度 / Q10
        如果 (reg.语法 == SYNTAX_INTEGER) {
            // 四舍五入到整数
            r.数值结果 = (r.数值结果 + 512) / 1024 * 1024
        }
        返回 r
    }

    如果 (reg.语法 == SYNTAX_LENGTH || reg.语法 == SYNTAX_LENGTH_PCT) {
        定义 from_l = 长度_解析(从值字符串)
        定义 to_l = 长度_解析(到值字符串)
        r.数值结果 = from_l + (to_l - from_l) * 进度 / Q10
        返回 r
    }

    如果 (reg.语法 == SYNTAX_PERCENTAGE) {
        定义 from_p = 百分比_解析(从值字符串)
        定义 to_p = 百分比_解析(到值字符串)
        r.数值结果 = from_p + (to_p - from_p) * 进度 / Q10
        返回 r
    }

    // 其他语法: 离散切换
    r.字符串结果 = 如果(进度 < Q10 / 2, 从值字符串, 到值字符串)
    返回 r
}

函数 数值_解析(值) {
    如果 (值 == 0) { 返回 0 }
    定义 可变 n = 0
    定义 可变 neg = 假
    定义 可变 i = 0
    定义 len = 字符串长度(值)
    如果 (len > 0 && 字节取(值, 0) == 45) { neg = 真; i = 1 }  // '-'
    当 (i < len) {
        定义 ch = 字节取(值, i)
        如果 (ch >= 48 && ch <= 57) {
            n = n * 10 + (ch - 48)
        } 否则 { 跳出 }
        i = i + 1
    }
    返回 如果(neg, 0 - n, n)
}

函数 长度_解析(值) {
    // 解析 "16px" "2em" 等
    返回 数值_解析(值)  // 简化: 只取数字部分
}

函数 百分比_解析(值) {
    // 解析 "50%" → 512 (Q10)
    定义 n = 数值_解析(值)
    返回 n * Q10 / 100
}

// §7 var()循环检测: DFS+访问栈
// --a: var(--b); --b: var(--a); → 两者无效

函数 Var_检测循环(map, 属性名, 访问栈, 栈深度) {
    如果 (map == 0 || 属性名 == 0 || 栈深度 > VAR_MAX_DEPTH) { 返回 真 }
    定义 可变 i = 0
    当 (i < 栈深度) {
        如果 (字符串_相等(内存_读64(访问栈 + i * 8), 属性名)) {
            返回 真
        }
        i = i + 1
    }
    内存_写64(访问栈 + 栈深度 * 8, 属性名)
    定义 data = CustomPropertyMap_获取(map, 属性名)
    如果 (data == 0 || !data.含var引用) { 返回 假 }
    定义 值 = data.原始值; 定义 长度 = data.原始长度
    定义 可变 pos = 0
    当 (pos + 4 < 长度) {
        如果 (字节取(值,pos)==0x76 && 字节取(值,pos+1)==0x61 &&
            字节取(值,pos+2)==0x72 && 字节取(值,pos+3)==0x28) {
            定义 ref = Var_解析引用(值, pos, 长度)
            如果 (ref != 0) {
                如果 (Var_检测循环(map, ref.属性名, 访问栈, 栈深度 + 1)) {
                    返回 真
                }
                pos = ref.结束位置
            } 否则 { pos = pos + 1 }
        } 否则 { pos = pos + 1 }
    }
    返回 假
}

函数 Var_标记循环无效(map) {
    如果 (map == 0) { 返回 }
    定义 访问栈 = 堆_分配(VAR_MAX_DEPTH * 8)
    定义 可变 b = 0
    当 (b < map.桶数) {
        定义 entry = 内存_读64(map.桶 + b * 8)
        如果 (entry != 0 && entry.含var引用) {
            如果 (Var_检测循环(map, entry.名称, 访问栈, 0)) {
                entry.无效 = 真
            }
        }
        b = b + 1
    }
    堆_释放(访问栈)
}

// §8 AI缓动优化 + EWMA插值缓存
// 创新: AI总线预测动画帧进度, 预计算插值结果

定义 EWMA_插值_ALPHA = 205  // 0.2 * Q10
定义 可变 AI_预测进度 = 0
定义 可变 AI_预计算命中 = 0

函数 AI_动画插值预测(当前进度, 帧间距) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 当前进度 }
    // EWMA平滑进度变化率
    定义 delta = 当前进度 - AI_预测进度
    AI_预测进度 = (EWMA_插值_ALPHA * 当前进度 + (Q10 - EWMA_插值_ALPHA) * AI_预测进度) / Q10
    // 预测下一帧进度
    定义 预测 = AI_预测进度 + delta
    如果 (预测 > Q10) { 预测 = Q10 }
    如果 (预测 < 0) { 预测 = 0 }
    返回 预测
}

函数 AI_智能插值_应该优化(属性名, 执行次数) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 假 }
    // AI总线判断: 高频插值属性值得预计算缓存
    定义 特征 = Tensor_创建(2)
    Tensor_写(特征, 0, 如果(执行次数 > 1000, Q10, 执行次数 * Q10 / 1000))
    Tensor_写(特征, 1, 如果(插值缓存命中 > 100, Q10, 插值缓存命中 * Q10 / 100))
    定义 分数 = AI总线_注意力权重(bus, 特征)
    Tensor_释放(特征)
    返回 分数 > 512
}

// §9 插值统计与诊断

定义 可变 插值_总次数 = 0
定义 可变 插值_颜色次数 = 0
定义 可变 插值_数值次数 = 0
定义 可变 插值_长度次数 = 0
定义 可变 插值_百分比次数 = 0
定义 可变 插值_离散次数 = 0
定义 可变 插值_循环检测数 = 0
定义 可变 插值_AI预测数 = 0

函数 插值_统计() {
    返回 [插值_总次数, 插值_颜色次数, 插值_数值次数,
           插值_长度次数, 插值_百分比次数, 插值_离散次数]
}

函数 插值_打印统计() {
    打印行("=== 动画插值统计 ===")
    打印行("总插值: " + 整数转字符串(插值_总次数))
    打印行("颜色: " + 整数转字符串(插值_颜色次数))
    打印行("数值: " + 整数转字符串(插值_数值次数))
    打印行("长度: " + 整数转字符串(插值_长度次数))
    打印行("百分比: " + 整数转字符串(插值_百分比次数))
    打印行("离散: " + 整数转字符串(插值_离散次数))
    打印行("循环检测: " + 整数转字符串(插值_循环检测数))
    打印行("AI预测: " + 整数转字符串(插值_AI预测数))
}

函数 插值_重置统计() {
    插值_总次数 = 0
    插值_颜色次数 = 0
    插值_数值次数 = 0
    插值_长度次数 = 0
    插值_百分比次数 = 0
    插值_离散次数 = 0
    插值_循环检测数 = 0
    插值_AI预测数 = 0
}

// §10 已注册属性查询

函数 已注册属性_查询(map, 属性名) {
    如果 (map == 0 || 属性名 == 0) { 返回 0 }
    定义 data = CustomPropertyMap_获取(map, 属性名)
    如果 (data == 0) { 返回 0 }
    返回 [
        data.名称,
        data.语法类型,
        data.是可动画,
        data.无效,
        data.含_var引用
    ]
}

函数 已注册属性_枚举(map) {
    如果 (map == 0) { 返回 [] }
    定义 可变 结果 = []
    定义 可变 b = 0
    当 (b < map.桶数) {
        定义 entry = 内存_读64(map.桶 + b * 8)
        如果 (entry != 0) {
            追加(结果, entry.名称)
        }
        b = b + 1
    }
    返回 结果

// NCAI — Nova CSS Animation Interpolation Theory
// 公理1(类型封闭): 同类型插值结果封闭于原类型域
// 公理2(循环无害): var()循环检测保证不无限展开
// 公理3(缓存一致): 缓存失效后重计算结果与首次一致
// 定理1(连续可插值): 数值/颜色插值在[0,1]连续
// 定理2(离散跳变): 离散属性在p=0.5处跳变, 无中间态

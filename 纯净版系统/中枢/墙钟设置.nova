// §5 核心接口: 设置/读取墙钟

函数 墙钟_设置(秒, 纳秒) {
    如果 (纳秒 < 0) { 纳秒 = 0 }
    如果 (纳秒 >= NS_PER_S) {
        秒 = 秒 + (纳秒 / NS_PER_S)
        纳秒 = 纳秒 % NS_PER_S
    }
    墙钟_秒 = 秒
    墙钟_纳秒 = 纳秒
    墙钟_上次同步TSC = 读取时间戳()

    墙钟_全局.锚点秒 = 秒
    墙钟_全局.锚点纳秒 = 纳秒
    墙钟_全局.锚点计数器 = 当前源_读取计数器()
    墙钟_全局.上次更新_ns = 秒 * NS_PER_S + 纳秒
}

函数 墙钟_设置_带误差(秒, 纳秒, 误差_ns) {
    墙钟_设置(秒, 纳秒)
    时间误差_ewma_ns = (EWMA_ALPHA_中 * 误差_ns + (Q10 - EWMA_ALPHA_中) * 时间误差_ewma_ns) / Q10
}

函数 墙钟_获取() {
    // 基于锚点+硬件计数器差值推算
    定义 当前计数器 = 当前源_读取计数器()
    定义 差计数 = 当前计数器 - 墙钟_全局.锚点计数器
    定义 差值ns = 周期转纳秒(差计数, 墙钟_全局.频率Hz)
    // 叠加slew频偏修正
    定义 频偏修正_ns = 差值ns * 墙钟_全局.频偏_ppm / 1000000
    定义 总纳秒 = 墙钟_全局.锚点纳秒 + 差值ns + 频偏修正_ns
    定义 额外秒 = 总纳秒 / NS_PER_S
    返回 [墙钟_全局.锚点秒 + 额外秒, 总纳秒 % NS_PER_S]
}

函数 墙钟_获取_ns() {
    定义 t = 墙钟_获取()
    返回 t[0] * NS_PER_S + t[1]
}

函数 时钟源_当前时间_秒() {
    定义 时间 = 墙钟_获取()
    返回 时间[0]
}

函数 当前时间_us() {
    定义 时间 = 墙钟_获取()
    返回 时间[0] * US_PER_S + 时间[1] / NS_PER_US
}

函数 当前时间_ms() {
    定义 时间 = 墙钟_获取()
    返回 时间[0] * MS_PER_S + 时间[1] / NS_PER_MS
}

函数 单调钟_获取_ns() {
    // 单调钟不受NTP step影响
    定义 当前计数器 = 当前源_读取计数器()
    定义 差计数 = 当前计数器 - 墙钟_全局.锚点计数器
    返回 墙钟_全局.单调偏移_ns + 周期转纳秒(差计数, 墙钟_全局.频率Hz)
}

函数 启动钟_获取_ns() {
    返回 单调钟_获取_ns() + 墙钟_全局.启动时戳_ns
}

// §6 时钟源管理

函数 时钟源_选择最优() {
    定义 可变 最佳 = -1
    定义 可变 最佳分 = -1
    定义 可变 i = 0
    当 (i < 计数(时钟源列表)) {
        如果 (时钟源列表[i].可用 && 时钟源列表[i].评分 > 最佳分) {
            最佳分 = 时钟源列表[i].评分
            最佳 = i
        }
        i = i + 1
    }
    如果 (最佳 < 0) {
        内核恐慌("无可用时钟源")
        返回
    }
    当前时钟源名 = 时钟源列表[最佳].名称
    墙钟_全局.当前源类型 = 时钟源列表[最佳].类型
    墙钟_全局.频率Hz = 时钟源列表[最佳].周期频率
    TSC频率 = 如果(当前时钟源名 == "tsc", 墙钟_全局.频率Hz, TSC频率)
}

函数 当前源_读取计数器() {
    定义 可变 i = 0
    当 (i < 计数(时钟源列表)) {
        如果 (时钟源列表[i].名称 == 当前时钟源名) {
            返回 调用(时钟源列表[i].读取函数)
        }
        i = i + 1
    }
    返回 读取时间戳()
}

函数 当前源_频率() {
    返回 墙钟_全局.频率Hz
}

函数 当前源_类型() {
    返回 墙钟_全局.当前源类型
}

函数 周期转纳秒(周期, 频率Hz) {
    如果 (频率Hz <= 0) { 返回 0 }
    返回 周期 * NS_PER_S / 频率Hz
}

函数 TSC周期转纳秒(周期) {
    返回 周期转纳秒(周期, TSC频率)
}

// §7 TSC稳定性检查

函数 TSC_标记不稳定(原因) {
    如果 (tsc_不稳定) { 返回 }
    tsc_不稳定 = 真
    内核警告("TSC不稳定: " + 原因)
    // 降低TSC评分并重新选择
    定义 可变 i = 0
    当 (i < 计数(时钟源列表)) {
        如果 (时钟源列表[i].名称 == "tsc") {
            时钟源列表[i].评分 = 0
        }
        i = i + 1
    }
    时钟源_选择最优()
}

函数 TSC_是否稳定() {
    返回 !tsc_不稳定
}

函数 TSC_探测频率() {
    // 简化探测: 通过平台接口读取标定值
    定义 f = 平台_读取TSC频率()
    如果 (f <= 0) { f = 2500000000 } // 默认2.5GHz
    返回 f
}

函数 TSC_稳定性巡检() {
    // 与HPET对比评估抖动/漂移
    如果 (!HPET_检测()) { 返回 }
    定义 tsc0 = 读取时间戳()
    定义 h0 = HPET_读取()
    mdelay(5)
    定义 tsc1 = 读取时间戳()
    定义 h1 = HPET_读取()

    定义 tsc_ns = TSC周期转纳秒(tsc1 - tsc0)
    定义 hpet_ns = HPET周期转纳秒(h1 - h0)
    定义 偏差 = tsc_ns - hpet_ns
    如果 (偏差 < 0) { 偏差 = -偏差 }
    时间抖动_ewma_ns = (EWMA_ALPHA_慢 * 偏差 + (Q10 - EWMA_ALPHA_慢) * 时间抖动_ewma_ns) / Q10
    如果 (时间抖动_ewma_ns > TSC_抖动阈值_ns) {
        TSC_标记不稳定("抖动超过阈值")
    }
}

函数 TSC_读取() { 返回 读取时间戳() }
函数 HPET_读取() { 返回 平台_HPET_读取() }
函数 ACPI_PM_读取() { 返回 平台_ACPI_PM_读取() }
函数 HPET_检测() { 返回 平台_HPET_可用() }
函数 HPET_频率() { 返回 平台_HPET_频率() }
函数 ACPI_PM_可用() { 返回 平台_ACPI_PM_可用() }

函数 HPET周期转纳秒(周期) {
    定义 f = HPET_频率()
    如果 (f <= 0) { 返回 0 }
    返回 周期 * NS_PER_S / f
}

// §8 NTP驯服 (PI控制)

函数 NTP_应用测量(服务器UTC秒, 服务器UTC纳秒, 往返延迟_ns) {
    // 计算当前本地时间
    定义 本地 = 墙钟_获取()
    定义 本地_ns = 本地[0] * NS_PER_S + 本地[1]
    定义 服务器_ns = 服务器UTC秒 * NS_PER_S + 服务器UTC纳秒
    定义 偏移_ns = 服务器_ns - 本地_ns

    NTP_全局.偏移_ns = 偏移_ns
    NTP_全局.往返延迟_ewma_ns = (EWMA_ALPHA_中 * 往返延迟_ns + (Q10 - EWMA_ALPHA_中) * NTP_全局.往返延迟_ewma_ns) / Q10
    NTP_全局.抖动_ewma_ns = (EWMA_ALPHA_中 * 绝对值(偏移_ns) + (Q10 - EWMA_ALPHA_中) * NTP_全局.抖动_ewma_ns) / Q10

    // 超大偏差: step
    如果 (绝对值(偏移_ns) > NTP_最大步进_ns) {
        墙钟_强制步进(偏移_ns)
        NTP_全局.状态 = NTP_STATE_LOCKING
        NTP_全局.连续成功次数 = 0
        NTP_全局.连续失败次数 = 0
        返回
    }

    // PI控制: 更新频偏
    定义 Kp = 64   // 0.0625
    定义 Ki = 4    // 0.0039
    定义 比例项 = 偏移_ns * Kp / Q10
    NTP_全局.相位积分项_ns = NTP_全局.相位积分项_ns + 偏移_ns * Ki / Q10
    定义 校正_ns = 比例项 + NTP_全局.相位积分项_ns
    定义 频偏_ppm = 校正_ns / 1000000

    如果 (频偏_ppm > NTP_最大slew_ppm) { 频偏_ppm = NTP_最大slew_ppm }
    如果 (频偏_ppm < -NTP_最大slew_ppm) { 频偏_ppm = -NTP_最大slew_ppm }

    墙钟_全局.频偏_ppm = 频偏_ppm
    NTP_全局.频偏_ppm = 频偏_ppm
    NTP_全局.上次同步_ns = 本地_ns
    NTP_全局.连续成功次数 = NTP_全局.连续成功次数 + 1
    NTP_全局.连续失败次数 = 0

    如果 (NTP_全局.连续成功次数 > 6) {
        NTP_全局.状态 = NTP_STATE_LOCKED
    } 否则 {
        NTP_全局.状态 = NTP_STATE_LOCKING
    }
}

函数 NTP_同步失败() {
    NTP_全局.连续失败次数 = NTP_全局.连续失败次数 + 1
    NTP_全局.连续成功次数 = 0
    同步失败计数 = 同步失败计数 + 1
    如果 (NTP_全局.连续失败次数 > 8) {
        NTP_全局.状态 = NTP_STATE_HOLDOVER
    }
}

函数 墙钟_强制步进(偏移_ns) {
    定义 旧 = 墙钟_获取_ns()
    定义 新 = 旧 + 偏移_ns
    如果 (新 < 0) { 新 = 0 }
    墙钟_设置(新 / NS_PER_S, 新 % NS_PER_S)
    时间跳变计数 = 时间跳变计数 + 1
}

函数 NTP_当前状态() {
    返回 [NTP_全局.状态, NTP_全局.偏移_ns, NTP_全局.频偏_ppm, NTP_全局.抖动_ewma_ns, NTP_全局.往返延迟_ewma_ns]
}

// §9 闰秒处理

函数 闰秒_添加(生效UTC秒, 类型) {
    如果 (计数(闰秒表) >= 最大闰秒记录) { 返回 错误_空间不足 }
    如果 (类型 != 1 && 类型 != -1) { 返回 错误_参数无效 }
    追加(闰秒表, 闰秒记录 { 生效UTC秒: 生效UTC秒, 类型: 类型, 已执行: 假 })
    返回 错误_成功
}

函数 闰秒_检查并执行() {
    定义 t = 墙钟_获取()
    定义 当前秒 = t[0]
    定义 可变 i = 0
    当 (i < 计数(闰秒表)) {
        定义 记录 = 闰秒表[i]
        如果 (!记录.已执行 && 当前秒 >= 记录.生效UTC秒) {
            如果 (记录.类型 == 1) {
                // 插入: 重复59秒(简化为减1秒锚点)
                墙钟_全局.锚点秒 = 墙钟_全局.锚点秒 - 1
            } 否则 {
                // 删除: 跳过1秒
                墙钟_全局.锚点秒 = 墙钟_全局.锚点秒 + 1
            }
            记录.已执行 = 真
            设置(闰秒表, i, 记录)
        }
        i = i + 1
    }
}

函数 闰秒_统计() {
    定义 总 = 计数(闰秒表)
    定义 已执行 = 0
    定义 可变 i = 0
    当 (i < 总) {
        如果 (闰秒表[i].已执行) { 已执行 = 已执行 + 1 }
        i = i + 1
    }
    返回 [总, 已执行]
}

// §10 时区

函数 时区_设置(名称) {
    定义 可变 i = 0
    当 (i < 计数(时区表)) {
        如果 (时区表[i].名称 == 名称) {
            当前时区名 = 名称
            当前时区偏移分钟 = 时区表[i].UTC偏移分钟
            返回 错误_成功
        }
        i = i + 1
    }
    返回 错误_未找到
}

函数 时区_获取() {
    返回 [当前时区名, 当前时区偏移分钟]
}

函数 本地时间_获取() {
    定义 utc = 墙钟_获取()
    定义 偏移秒 = 当前时区偏移分钟 * 60
    定义 本地秒 = utc[0] + 偏移秒
    返回 [本地秒, utc[1]]
}

函数 UTC转本地(utc秒, utc纳秒) {
    返回 [utc秒 + 当前时区偏移分钟 * 60, utc纳秒]
}

函数 本地转UTC(本地秒, 本地纳秒) {
    返回 [本地秒 - 当前时区偏移分钟 * 60, 本地纳秒]
}

// §11 格式化/解析

函数 时间_格式化_ISO8601(秒, 纳秒) {
    定义 日期 = 时间_拆分UTC(秒)
    定义 ns6 = 纳秒 / 1000
    定义 s = 整数补零(日期.年, 4) + "-" +
             整数补零(日期.月, 2) + "-" +
             整数补零(日期.日, 2) + "T" +
             整数补零(日期.时, 2) + ":" +
             整数补零(日期.分, 2) + ":" +
             整数补零(日期.秒, 2) + "." +
             整数补零(ns6, 6) + "Z"
    返回 s
}

函数 时间_当前_ISO8601() {
    定义 t = 墙钟_获取()
    返回 时间_格式化_ISO8601(t[0], t[1])
}

函数 时间_拆分UTC(秒) {
    // 简化分解算法 (1970起)
    定义 可变 s = 秒
    定义 可变 年 = 1970
    当 (真) {
        定义 天数 = 如果(闰年(年), 366, 365)
        定义 年秒 = 天数 * 86400
        如果 (s >= 年秒) {
            s = s - 年秒
            年 = 年 + 1
        } 否则 { 跳出 }
    }
    定义 月长 = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]
    如果 (闰年(年)) { 设置(月长, 1, 29) }
    定义 可变 月 = 1
    定义 可变 i = 0
    当 (i < 12) {
        定义 月秒 = 月长[i] * 86400
        如果 (s >= 月秒) {
            s = s - 月秒
            月 = 月 + 1
        } 否则 { 跳出 }
        i = i + 1
    }
    定义 日 = s / 86400 + 1
    s = s % 86400
    定义 时 = s / 3600
    s = s % 3600
    定义 分 = s / 60
    定义 秒内 = s % 60
    返回 { 年: 年, 月: 月, 日: 日, 时: 时, 分: 分, 秒: 秒内 }
}

函数 闰年(年) {
    如果 ((年 % 400) == 0) { 返回 真 }
    如果 ((年 % 100) == 0) { 返回 假 }
    返回 (年 % 4) == 0
}

函数 整数补零(n, 位数) {
    定义 s = 整数转字符串(n)
    当 (字符串长度(s) < 位数) { s = "0" + s }
    返回 s
}

// §12 延时函数

函数 udelay(微秒) {
    // 基于当前源频率的微秒延时
    定义 f = 当前源_频率()
    如果 (f <= 0) {
        定义 可变 c = 微秒 * 1000
        当 (c > 0) { c = c - 1 }
        返回
    }
    定义 目标周期 = f / US_PER_S * 微秒
    定义 开始 = 当前源_读取计数器()
    当 (当前源_读取计数器() - 开始 < 目标周期) {
        暂停()
    }
}

函数 mdelay(毫秒) {
    定义 可变 i = 0
    当 (i < 毫秒) {
        udelay(1000)
        i = i + 1
    }
}

函数 ndelay(纳秒) {
    定义 f = 当前源_频率()
    如果 (f <= 0) { 返回 }
    定义 目标周期 = f / NS_PER_S * 纳秒
    如果 (目标周期 <= 0) { 目标周期 = 1 }
    定义 开始 = 当前源_读取计数器()
    当 (当前源_读取计数器() - 开始 < 目标周期) {
        暂停()
    }
}

函数 睡眠_直到(目标秒, 目标纳秒) {
    当 (真) {
        定义 t = 墙钟_获取()
        如果 (t[0] > 目标秒 || (t[0] == 目标秒 && t[1] >= 目标纳秒)) {
            返回
        }
        平台_让出CPU()
    }
}

// §13 快照/统计

函数 时间_生成快照() {
    定义 utc = 墙钟_获取()
    返回 时间快照 {
        utc秒: utc[0],
        utc纳秒: utc[1],
        monotonic_ns: 单调钟_获取_ns(),
        boottime_ns: 启动钟_获取_ns(),
        源类型: 当前源_类型(),
        估计误差_ns: 时间误差_ewma_ns
    }
}

函数 时钟源_统计() {
    返回 [当前时钟源名, TSC频率, 计数(时钟源列表), tsc_不稳定, HPET_可用]
}

函数 时钟源_完整统计() {
    定义 ntp = NTP_当前状态()
    定义 leap = 闰秒_统计()
    返回 [
        当前时钟源名,
        TSC频率,
        计数(时钟源列表),
        tsc_不稳定,
        HPET_可用,
        墙钟_全局.频偏_ppm,
        ntp[0],
        ntp[1],
        ntp[2],
        ntp[3],
        ntp[4],
        时间误差_ewma_ns,
        时间抖动_ewma_ns,
        时间跳变计数,
        同步失败计数,
        leap[0],
        leap[1],
        当前时区名,
        当前时区偏移分钟
    ]
}

函数 时间_诊断字符串() {
    定义 t = 墙钟_获取()
    定义 iso = 时间_格式化_ISO8601(t[0], t[1])
    返回 "clock=" + 当前时钟源名 +
           " now=" + iso +
           " ppm=" + 整数转字符串(墙钟_全局.频偏_ppm) +
           " err_ns=" + 整数转字符串(时间误差_ewma_ns)
}

// §14 AI时钟异常检测

定义 可变 EWMA_偏移绝对值 = 0
定义 可变 EWMA_丢同步率 = 0

函数 智能_时钟_AI反馈NTP(偏移_ns, 同步成功) {
    定义 abs_off = 绝对值(偏移_ns)
    EWMA_偏移绝对值 = (EWMA_ALPHA_中 * abs_off + (Q10 - EWMA_ALPHA_中) * EWMA_偏移绝对值) / Q10
    如果 (同步成功) {
        EWMA_丢同步率 = ((Q10 - EWMA_ALPHA_中) * EWMA_丢同步率) / Q10
    } 否则 {
        EWMA_丢同步率 = (EWMA_ALPHA_中 * Q_ONE + (Q10 - EWMA_ALPHA_中) * EWMA_丢同步率) / Q10
    }
}

函数 智能_时钟_AI评估风险() {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 0 }
    定义 特征 = Tensor_创建(1, 6)
    Tensor_写(特征, 0, 0, EWMA_偏移绝对值 / 1000)   // us量级
    Tensor_写(特征, 0, 1, EWMA_丢同步率)
    Tensor_写(特征, 0, 2, 时间抖动_ewma_ns / 1000)
    Tensor_写(特征, 0, 3, 如果(tsc_不稳定, Q_ONE, 0))
    Tensor_写(特征, 0, 4, 绝对值(墙钟_全局.频偏_ppm))
    Tensor_写(特征, 0, 5, Q_ONE)
    定义 分数 = AI总线_注意力权重(bus, 特征)
    Tensor_释放(特征)
    返回 分数
}

函数 智能_时钟_AI可能切源() {
    定义 风险 = 智能_时钟_AI评估风险()
    如果 (风险 > 820) {
        // 高风险: 主动降级TSC
        如果 (当前时钟源名 == "tsc") {
            TSC_标记不稳定("AI检测到高风险时钟漂移")
        }
        返回 真
    }
    返回 假
}

// §15 周期维护

函数 时间子系统_每秒维护() {
    TSC_稳定性巡检()
    闰秒_检查并执行()
    智能_时钟_AI可能切源()
}

函数 时间子系统_每分钟维护() {
    // 长周期重锚点，降低累计误差
    定义 now = 墙钟_获取()
    墙钟_设置(now[0], now[1])
}

// §16 工具函数

函数 绝对值(x) {
    如果 (x < 0) { 返回 -x }
    返回 x
}

函数 错误_空间不足() { 返回 -12 }
函数 错误_参数无效() { 返回 -22 }
函数 错误_未找到() { 返回 -2 }
函数 错误_成功() { 返回 0 }

// §17 兼容接口

函数 当前时间_秒() { 返回 时钟源_当前时间_秒() }
函数 当前时间_纳秒() { 返回 墙钟_获取_ns() }
函数 当前时间_字符串() { 返回 时间_当前_ISO8601() }

定义 可变 AI时钟_漂移累计 = 0
定义 可变 AI时钟_校准次数 = 0

函数 AI时钟_漂移补偿(本地纳秒, 参考纳秒) {
    定义 偏差 = 本地纳秒 - 参考纳秒
    AI时钟_漂移累计 = AI时钟_漂移累计 * 900 / 1000 + 偏差 * 100 / 1000
    AI时钟_校准次数 = AI时钟_校准次数 + 1
    返回 AI时钟_漂移累计
}

函数 AI时钟_同步策略(漂移量) {
    如果 (漂移量 > 1000000000) { 返回 "NTP强制跳变" }
    如果 (漂移量 > 1000000) { 返回 "渐进校准" }
    返回 "无需校准"
}

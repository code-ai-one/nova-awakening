// 1D卷积层
// 输入: [序列长度] 的一维数据, 核: [核大小]
函数 一维卷积(输入, 核, 步幅) {
 定义 可变 输出 = []
 定义 可变 i = 0
 当 (i + 核长 <= 输入长) { 定义 可变 总和 = 0
 定义 可变 j = 0
 当 (j < 核长) { 总和 = 总和 + 输入[i + j] * 核[j]
 j = j + 1 }
 追加(输出, 总和)
 i = i + 步幅
 }
 返回 输出
}

// [v2反哺] Conv1D_ReLU — 一维卷积+线性整流→SiLU激活版(HexSigmoid精确门控, 比ReLU平滑)
// 激活_SiLU/Swish 升级版 (HexSigmoid精确门控)
// 旧版: 朴素sigmoid乘x → 新版: HexSigmoid精确门控
// SiLU(x) = x × σ(x), 使用精确6段HexSigmoid
// 类人脑: 门控机制比ReLU更生物学合理
函数 激活_SiLU(t) {
    如果 (t == 0) { 返回 }
    定义 总 = t.行数 * t.列数
    定义 可变 i = 0
    当 (i < 总) {
        定义 x = 内存_读32有符号(t.数据 + i * 4)
        定义 门控值 = 激活_HexSigmoid_单值(x)
        内存_写32(t.数据 + i * 4, Q乘(x, 门控值))
        i = i + 1
    }
}

// 池化层
函数 最大池化1D(输入, 窗口, 步幅) { 定义 可变 输出 = []
 定义 可变 i = 0
 当 (i + 窗口 <= 计数(输入)) { 定义 可变 m = 输入[i]
 定义 可变 j = 1
 当 (j < 窗口) { 如果 (输入[i + j] > m) { m = 输入[i + j] }
 j = j + 1 }
 追加(输出, m)
 i = i + 步幅
 }
 返回 输出
}

函数 均值池化1D(输入, 窗口, 步幅) { 定义 可变 输出 = []
 定义 可变 i = 0
 当 (i + 窗口 <= 计数(输入)) { 定义 可变 s = 0
 定义 可变 j = 0
 当 (j < 窗口) { s = s + 输入[i + j]
 j = j + 1 }
 追加(输出, s / 窗口)
 i = i + 步幅
 }
 返回 输出
}

函数 全局最大池化层(输入) { 返回 列表最大(输入) }

函数 全局均值池化层(输入) {
    如果 (计数(输入) == 0) { 返回 0
}
 返回 折叠(输入, 0, (s, x) => s + x) / 计数(输入)
}

// 层归一化 (层归一化, 0 , 0)
函数 层归一化(输入, 衰减率, 动量率) { 定义 n = 计数(输入)
 定义 均值 = 折叠(输入, 0, (s, x) => s + x) / n
 定义 方差 = 折叠(输入, 0, (s, x) => s + (x - 均值) * (x - 均值)) / n
 定义 可变 标准差 = 整数sqrt(方差)
 如果 (标准差 == 0) { 标准差 = 1 }
 返回 映射(输入, v => (v - 均值) * 100 / 标准差 * 衰减率 / 100 + 动量率)
}

// RNN单元
// h_t = tanh(W_x * x + W_h * h_{t-1} + b)
// 简化: 单特征, W_x/W_h/b为标量
函数 RNN_单步(x, 前隐藏, Wx, Wh, b) { 定义 可变 pre = Wx * x + Wh * 前隐藏 + b
 // tanh近似: clamp to [-100, 100]
 如果 (pre > 100) { pre = 100 }
 如果 (pre < -100) { pre = -100 }
 返回 pre
}

// LSTM单元 (简化)
// f/i/o门 + cell state, 标量版
函数 S形_整数(x) {
    如果 (x > 500) { 返回 100
}
 如果 (x < -500) { 返回 0 }
 返回 50 + x / 10
}

函数 LSTM_单步(x, 前隐藏, c_prev, Wf, Wi, Wo, Wc, bf, bi, bo, bc) { 定义 f = S形_整数(Wf * x + Wf * 前隐藏 + bf)
 定义 ig = S形_整数(Wi * x + Wi * 前隐藏 + bi)
 定义 o = S形_整数(Wo * x + Wo * 前隐藏 + bo)
 定义 可变 c_hat = Wc * x + Wc * 前隐藏 + bc
 如果 (c_hat > 100) { c_hat = 100 }
 如果 (c_hat < -100) { c_hat = -100 }
 定义 c = (f * c_prev) / 100 + (ig * c_hat) / 100
 定义 h = (o * c) / 100
 返回 [h, c]
}

// 嵌入层
// 嵌入表: 扁平数组 [词表大小 * 嵌入维度]
函数 高级神经_嵌入_创建(词表大小, 维度) { 定义 可变 表 = []
 定义 可变 i = 0
 当 (i < 词表大小 * 维度) {
 追加(表, ((i * 7 + 13) % 201) - 100)
 i = i + 1
 }
 返回 [表, 词表大小, 维度]
}

函数 高级神经_嵌入_查找(嵌入表, token_id) { 定义 维度 = 嵌入表[2]
 定义 偏移量 = token_id * 维度
 定义 可变 v = []
 定义 可变 i = 0
 当 (i < 维度) { 追加(v, 嵌入表[0][偏移量 + i])
 i = i + 1 }
 返回 v
}

函数 高级神经_嵌入_序列(嵌入表, token_ids) { 返回 映射(token_ids, tid => 嵌入_查找(嵌入表, tid))
}

// 位置编码 (整数近似正弦, 0)
函数 位置编码_生成(序列长度, 维度) { 定义 可变 编码 = []
 定义 可变 位置 = 0
 当 (位置 < 序列长度) { 定义 可变 v = []
 定义 可变 d = 0
 当 (d < 维度) {
 // sin/cos近似: 线性周期函数
 定义 角度值 = (位置 * 127 + d * 53 + 17) % 201
 定义 数值 = 角度值 - 100
 追加(v, 数值)
 d = d + 1
 }
 追加(编码, v)
 位置 = 位置 + 1
 }
 返回 编码
}

// 注意力 (缩放点积)
// Q,K,V是向量列表, 每个向量维度相同
函数 注意力_点积(Q, K, V) { 定义 序列长 = 计数(Q)
    定义 可变 out_v = []
    定义 可变 得分列表 = []
    定义 可变 指数组 = []
 定义 维度 = 计数(Q[0])
 定义 可变 输出 = []
 定义 可变 i = 0
 当 (i < 序列长) {
 // 计算attention 得分列表: Q[i] · K[j] for all j
 定义 可变 j = 0
 当 (j < 序列长) { 定义 可变 点积 = 0
 定义 可变 d = 0
 当 (d < 维度) { 点积 = 点积 + Q[i][d] * K[j][d]
 d = d + 1 }
 追加(得分列表, 点积)
 j = j + 1
 }
 // softmax近似
 定义 可变 最大得分 = 得分列表[0]
 j = 1
 当 (j < 序列长) { 如果 (得分列表[j] > 最大得分) { 最大得分 = 得分列表[j] }
 j = j + 1 }
 定义 可变 合计 = 0
 j = 0
 当 (j < 序列长) { 定义 可变 e = 1000 + (得分列表[j] - 最大得分)
 如果 (e < 1) { e = 1 }
 追加(指数组, e)
 合计 = 合计 + e
 j = j + 1
 }
 // 加权求和
 定义 可变 d2 = 0
 当 (d2 < 维度) { 定义 可变 weighted = 0
 j = 0
 当 (j < 序列长) {
 weighted = weighted + (指数组[j] * V[j][d2]) / 合计
 j = j + 1
 }
 追加(out_v, weighted)
 d2 = d2 + 1
 }
 追加(输出, out_v)
 i = i + 1
 }
 返回 输出
}

// 残差连接
函数 高级_残差连接(输入, 层输出) { 返回 拉链(输入, 层输出, (a, b) => a + b)
}

// 随机丢弃层 (整数掩码, 0)
函数 Dropout向量(v, 掩码) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(v)) { 如果 (i < 计数(掩码) 且 掩码[i] == 0) { 追加(r, 0) }
 否则 { 追加(r, v[i]) }
 i = i + 1
 }
 返回 r
}
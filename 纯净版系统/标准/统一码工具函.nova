函数 JSString_字符到字节偏移(s, 字符索引) {
    如果 (s == 0 || 字符索引 <= 0) { 返回 0 }
    定义 可变 字符 = 0; 定义 可变 字节 = 0
    当 (字符 < 字符索引 && 字节 < s.长度) {
        定义 b = 内存_读8(s.数据 + 字节)
        如果 (b < 0x80) { 字节 = 字节 + 1 }
        否则 如果 (b < 0xE0) { 字节 = 字节 + 2 }
        否则 如果 (b < 0xF0) { 字节 = 字节 + 3 }
        否则 { 字节 = 字节 + 4 }
        字符 = 字符 + 1
    }
    返回 字节
}

函数 JSString_字节到字符偏移(s, 字节索引) {
    如果 (s == 0 || 字节索引 <= 0) { 返回 0 }
    定义 可变 字符 = 0; 定义 可变 字节 = 0
    当 (字节 < 字节索引 && 字节 < s.长度) {
        定义 b = 内存_读8(s.数据 + 字节)
        如果 (b < 0x80) { 字节 = 字节 + 1 }
        否则 如果 (b < 0xE0) { 字节 = 字节 + 2 }
        否则 如果 (b < 0xF0) { 字节 = 字节 + 3 }
        否则 { 字节 = 字节 + 4 }
        字符 = 字符 + 1
    }
    返回 字符
}

函数 JSString_UTF8字符长度(数据, 偏移) {
    定义 b = 内存_读8(数据 + 偏移)
    如果 (b < 0x80) { 返回 1 }
    如果 (b < 0xE0) { 返回 2 }
    如果 (b < 0xF0) { 返回 3 }
    返回 4
}

函数 JSString_解码UTF8(数据, 偏移) {
    定义 b0 = 内存_读8(数据 + 偏移)
    如果 (b0 < 0x80) { 返回 b0 }
    如果 (b0 < 0xE0) {
        定义 b1 = 内存_读8(数据 + 偏移 + 1)
        返回 ((b0 & 0x1F) << 6) | (b1 & 0x3F)
    }
    如果 (b0 < 0xF0) {
        定义 b1 = 内存_读8(数据 + 偏移 + 1)
        定义 b2 = 内存_读8(数据 + 偏移 + 2)
        返回 ((b0 & 0x0F) << 12) | ((b1 & 0x3F) << 6) | (b2 & 0x3F)
    }
    定义 b1 = 内存_读8(数据 + 偏移 + 1)
    定义 b2 = 内存_读8(数据 + 偏移 + 2)
    定义 b3 = 内存_读8(数据 + 偏移 + 3)
    返回 ((b0 & 0x07) << 18) | ((b1 & 0x3F) << 12) | ((b2 & 0x3F) << 6) | (b3 & 0x3F)
}

函数 JSString_编码UTF8(目标, 码点) {
    如果 (码点 < 0x80) {
        内存_写8(目标, 码点); 返回 1
    }
    如果 (码点 < 0x800) {
        内存_写8(目标, 0xC0 | (码点 >> 6))
        内存_写8(目标 + 1, 0x80 | (码点 & 0x3F))
        返回 2
    }
    如果 (码点 < 0x10000) {
        内存_写8(目标, 0xE0 | (码点 >> 12))
        内存_写8(目标 + 1, 0x80 | ((码点 >> 6) & 0x3F))
        内存_写8(目标 + 2, 0x80 | (码点 & 0x3F))
        返回 3
    }
    内存_写8(目标, 0xF0 | (码点 >> 18))
    内存_写8(目标 + 1, 0x80 | ((码点 >> 12) & 0x3F))
    内存_写8(目标 + 2, 0x80 | ((码点 >> 6) & 0x3F))
    内存_写8(目标 + 3, 0x80 | (码点 & 0x3F))
    返回 4
}

函数 JSString_是空白(c) {
    返回 c == 0x20 || c == 0x09 || c == 0x0A || c == 0x0D || c == 0x0C || c == 0x0B || c == 0xA0
}

函数 JSString_哈希(s) {
    如果 (s == 0) { 返回 0 }
    如果 (s.已哈希) { 返回 s.哈希 }
    定义 可变 h = 2166136261
    定义 可变 i = 0
    当 (i < s.长度) {
        h = h ^ 内存_读8(s.数据 + i)
        h = h * 16777619
        i = i + 1
    }
    s.哈希 = h & 0x7FFFFFFF
    s.已哈希 = 真
    返回 s.哈希
}


// §6 辅助函数

函数 整数转字符串(数值) {
    定义 缓冲 = 堆_分配(20)
    定义 可变 n = 数值
    如果 (n == 0) {
        内存_写8(缓冲, 0x30)
        内存_写8(缓冲 + 1, 0)
        返回 缓冲
    }
    定义 可变 i = 0
    定义 临时 = 堆_分配(20)
    当 (n > 0) {
        内存_写8(临时 + i, (n % 10) + 0x30)
        n = n / 10
        i = i + 1
    }
    // 反转
    定义 可变 j = 0
    当 (j < i) {
        内存_写8(缓冲 + j, 内存_读8(临时 + i - 1 - j))
        j = j + 1
    }
    内存_写8(缓冲 + i, 0)
    返回 缓冲
}

函数 字符串转整数(str) {
    如果 (str == 0) { 返回 0 }
    定义 可变 结果 = 0
    定义 可变 i = 0
    当 (内存_读8(str + i) >= 0x30 && 内存_读8(str + i) <= 0x39) {
        结果 = 结果 * 10 + (内存_读8(str + i) - 0x30)
        i = i + 1
    }
    返回 结果
}

// 传统方案: 资源按发现顺序加载, 不区分语义重要性
// Nova: AI识别资源的语义角色, 智能调度加载优先级

定义 AI资源_关键样式       = 1     // 首屏 CSS
定义 AI资源_关键字体       = 2     // 正文字体
定义 AI资源_关键脚本       = 3     // 关键JS
定义 AI资源_首屏图片       = 4     // 首屏可见图片
定义 AI资源_延迟图片       = 5     // 视口外图片
定义 AI资源_广告资源       = 6     // 广告相关
定义 AI资源_跟踪器           = 7     // 分析跟踪
定义 AI资源_普通             = 8     // 其他

结构 AI加载统计 {
    总请求数,
    总字节数,
    总耗时,    // u64 微秒
    被延迟数,    // u32 AI延迟的低优先级资源数
    被拦截数,    // u32 AI拦截的跟踪器数
    重试次数,
}

定义 可变 AI加载全局统计 = 0

函数 AI加载_初始化() {
    AI加载全局统计 = 堆_分配(AI加载统计)
    AI加载全局统计.总请求数 = 0
    AI加载全局统计.总字节数 = 0
    AI加载全局统计.总耗时 = 0
    AI加载全局统计.被延迟数 = 0
    AI加载全局统计.被拦截数 = 0
    AI加载全局统计.重试次数 = 0
}

// 传统: if(url.contains("ads")) → 低优先级  (预设字符串匹配)
// Nova: URL→12维特征提取→Nova多层感知器推理→优先级分数  (神经网络泛化)
// 这意味着:
//   - 能识别从未见过的广告域名(泛化能力)
//   - 能学习用户偏好(在线学习更新权重)
//   - URL特征包含:长度/路径深度/参数数/扩展名/域名哈希等
函数 AI加载_识别语义类型(url, 资源类型) {
    定义 bus = 全局AI总线
    如果 (bus != 0 && url != 0) {
        // 由AI总线的URL嵌入网络推理
        // 内部: URL→提取12维特征→Nova多层感知器[12→24→32]→语义嵌入→Nova激活函数→优先级分数
        定义 优先级分数 = AI总线_资源优先级(bus, url)

        // 分数Q10[0,1024]: <200=广告/跟踪器, 200-400=低优先级, 400-700=普通, >700=关键
        如果 (优先级分数 < 100) { 返回 AI资源_跟踪器 }
        如果 (优先级分数 < 200) { 返回 AI资源_广告资源 }
        如果 (优先级分数 > 800) {
            // 高优先级: 再根据资源类型细分
            如果 (资源类型 == 资源_样式表) { 返回 AI资源_关键样式 }
            如果 (资源类型 == 资源_字体) { 返回 AI资源_关键字体 }
            如果 (资源类型 == 资源_脚本) { 返回 AI资源_关键脚本 }
            返回 AI资源_首屏图片
        }
    }

    // 后备: 基于资源类型的基本分类
    如果 (资源类型 == 资源_样式表) { 返回 AI资源_关键样式 }
    如果 (资源类型 == 资源_字体) { 返回 AI资源_关键字体 }
    如果 (资源类型 == 资源_脚本) { 返回 AI资源_关键脚本 }
    如果 (资源类型 == 资源_图片) { 返回 AI资源_首屏图片 }
    返回 AI资源_普通
}

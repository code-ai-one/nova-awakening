// Nova · 运行时 · 图形原语 · 精灵批渲染
// 职责: 2D精灵批处理、纹理映射、图层排序、视口裁剪
// 层级: M12 — 2D/3D渲染增强

// 纹理: [宽, 高, 像素数据, 透明色]

导入("../../标准库/基础.nova")

函数 纹理_创建(宽, 高) {
    定义 可变 像素 = []
    定义 可变 i = 0
    当 (i < 宽 * 高) { 追加(像素, 0)  i = i + 1 }
    返回 [宽, 高, 像素, -1]
}

函数 纹理_宽(t) { 返回 t[0] }
函数 纹理_高(t) { 返回 t[1] }
函数 纹理_设透明色(t, c) { t[3] = c }

函数 纹理_取像素(t, x, y) {
    如果 (x < 0 或 x >= t[0] 或 y < 0 或 y >= t[1]) { 返回 0 }
    返回 t[2][y * t[0] + x]
}

函数 纹理_设像素(t, x, y, 颜色) {
    如果 (x >= 0 且 x < t[0] 且 y >= 0 且 y < t[1]) {
        t[2][y * t[0] + x] = 颜色
    }
}

// 精灵: [纹理, x, y, 宽, 高, 源x, 源y, 源宽, 源高, 图层, 可见, 翻转X, 翻转Y]
函数 精灵_创建(纹理, x, y) {
    返回 [纹理, x, y, 纹理_宽(纹理), 纹理_高(纹理), 0, 0, 纹理_宽(纹理), 纹理_高(纹理), 0, 真, 假, 假]
}

函数 精灵_x(s) { 返回 s[1] }
函数 精灵_y(s) { 返回 s[2] }
函数 精灵_图层(s) { 返回 s[9] }
函数 精灵_可见(s) { 返回 s[10] }

函数 精灵_设位置(s, x, y) { s[1] = x  s[2] = y }
函数 精灵_设源矩形(s, sx, sy, sw, sh) { s[5] = sx  s[6] = sy  s[7] = sw  s[8] = sh }
函数 精灵_设图层(s, z) { s[9] = z }
函数 精灵_设可见(s, v) { s[10] = v }
函数 精灵_设翻转(s, fx, fy) { s[11] = fx  s[12] = fy }

// 视口: [x, y, 宽, 高]
函数 视口_创建(x, y, 宽, 高) { 返回 [x, y, 宽, 高] }

函数 视口_包含(v, x, y) {
    返回 x >= v[0] 且 x < v[0] + v[2] 且 y >= v[1] 且 y < v[1] + v[3]
}

// 批渲染器: [精灵列表, 帧缓冲, 缓冲宽, 缓冲高, 视口, 绘制调用数]
函数 批渲染器_创建(宽, 高) {
    定义 可变 缓冲 = []
    定义 可变 i = 0
    当 (i < 宽 * 高) { 追加(缓冲, 0)  i = i + 1 }
    返回 [[], 缓冲, 宽, 高, 视口_创建(0, 0, 宽, 高), 0]
}

函数 批渲染器_添加精灵(r, 精灵) { 追加(r[0], 精灵) }
函数 批渲染器_精灵数(r) { 返回 计数(r[0]) }
函数 批渲染器_绘制调用数(r) { 返回 r[5] }

// 清屏
函数 批渲染器_清屏(r, 颜色) {
    定义 可变 i = 0
    当 (i < r[2] * r[3]) { r[1][i] = 颜色  i = i + 1 }
}

// 图层排序(插入排序,稳定)
函数 _批渲染器_排序图层(列表) {
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        定义 当前 = 列表[i]
        定义 可变 j = i - 1
        当 (j >= 0 且 精灵_图层(列表[j]) > 精灵_图层(当前)) {
            列表[j + 1] = 列表[j]
            j = j - 1
        }
        列表[j + 1] = 当前
        i = i + 1
    }
}

// 批渲染: 按图层排序后逐精灵绘制
函数 批渲染器_渲染(r) {
    r[5] = 0
    _批渲染器_排序图层(r[0])

    定义 缓宽 = r[2]
    定义 缓高 = r[3]

    定义 可变 si = 0
    当 (si < 计数(r[0])) {
        定义 s = r[0][si]
        如果 (精灵_可见(s)) {
            定义 纹理 = s[0]
            定义 dx = s[1]
            定义 dy = s[2]
            定义 sx = s[5]
            定义 sy = s[6]
            定义 sw = s[7]
            定义 sh = s[8]
            定义 翻转x = s[11]
            定义 翻转y = s[12]
            定义 透明 = 纹理[3]

            定义 可变 py = 0
            当 (py < sh) {
                定义 可变 px = 0
                当 (px < sw) {
                    // 源采样(支持翻转)
                    定义 可变 采样x = sx + px
                    定义 可变 采样y = sy + py
                    如果 (翻转x) { 采样x = sx + sw - 1 - px }
                    如果 (翻转y) { 采样y = sy + sh - 1 - py }

                    定义 颜色 = 纹理_取像素(纹理, 采样x, 采样y)

                    // 透明色跳过
                    如果 (颜色 != 透明) {
                        定义 目标x = dx + px
                        定义 目标y = dy + py
                        // 视口裁剪
                        如果 (目标x >= 0 且 目标x < 缓宽 且 目标y >= 0 且 目标y < 缓高) {
                            r[1][目标y * 缓宽 + 目标x] = 颜色
                        }
                    }
                    px = px + 1
                }
                py = py + 1
            }
            r[5] = r[5] + 1
        }
        si = si + 1
    }
}

// 帧缓冲读取
函数 批渲染器_取像素(r, x, y) {
    如果 (x < 0 或 x >= r[2] 或 y < 0 或 y >= r[3]) { 返回 0 }
    返回 r[1][y * r[2] + x]
}

// 报告
函数 批渲染器_打印报告(r) {
    打印("═══ 精灵批渲染报告 ═══")
    打印文本(字符串拼接("  精灵数: ", 转字符串(计数(r[0]))))
    打印文本(字符串拼接("  缓冲: ", 字符串拼接(转字符串(r[2]), 字符串拼接("×", 转字符串(r[3])))))
    打印文本(字符串拼接("  绘制调用: ", 转字符串(r[5])))
}

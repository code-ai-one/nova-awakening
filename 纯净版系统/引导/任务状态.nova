// NovaOS TSS (任务状态段)
// 64位长模式下TSS主要用于:
// 1. Ring3→Ring0栈切换 (RSP0)
// 2. IST (中断栈表) — 特殊中断使用独立栈

// TSS结构 (104字节, packed)
// 偏移  大小  含义
// 0     4    保留
// 4     8    RSP0 (Ring3→Ring0栈指针)
// 12    8    RSP1
// 20    8    RSP2
// 28    8    保留
// 36    8    IST1
// 44    8    IST2
// 52    8    IST3
// 60    8    IST4
// 68    8    IST5
// 76    8    IST6
// 84    8    IST7
// 92    8    保留
// 100   2    保留
// 102   2    IOPB偏移

定义 TSS大小 = 104
定义 可变 TSS缓冲 = 空

定义 IST栈大小 = 4096   // 每个IST栈4KB

函数 TSS_初始化(内核栈指针) {
    TSS缓冲 = 缓冲区(TSS大小)
    内存填充(TSS缓冲, 0, TSS大小)
    
    // RSP0: Ring3→Ring0切换时使用的栈
    缓冲写64(TSS缓冲, 4, 内核栈指针)
    
    // IST1: 用于#DF (双重故障), 需要独立栈
    // IST2: 用于NMI
    // 这些栈地址在内存初始化后分配
    
    // IOPB偏移 = TSS大小 (禁止用户态IO)
    缓冲写16(TSS缓冲, 102, TSS大小)
    
    早期打印OK("TSS初始化")
}

函数 TSS_设置RSP0(栈指针) {
    如果 (TSS缓冲 != 空) {
        缓冲写64(TSS缓冲, 4, 栈指针)
    }
}

函数 TSS_设置IST(编号, 栈指针) {
    如果 (编号 >= 1 && 编号 <= 7) {
        定义 偏移 = 36 + (编号 - 1) * 8
        缓冲写64(TSS缓冲, 偏移, 栈指针)
    }
}

函数 TSS_写入GDT并加载(GDT缓冲, TSS基址) {
    // TSS描述符是16字节(在64位模式下)
    // 写入GDT[5]和GDT[6]
    定义 界限 = TSS大小 - 1
    定义 偏移 = 5 * 8   // GDT第5项
    
    // 低8字节 (标准格式)
    缓冲写16(GDT缓冲, 偏移, 界限 & 0xFFFF)
    缓冲写16(GDT缓冲, 偏移 + 2, TSS基址 & 0xFFFF)
    缓冲写(GDT缓冲, 偏移 + 4, (TSS基址 >> 16) & 0xFF)
    缓冲写(GDT缓冲, 偏移 + 5, 0x89)   // 类型=TSS可用, DPL=0
    缓冲写(GDT缓冲, 偏移 + 6, (界限 >> 16) & 0x0F)
    缓冲写(GDT缓冲, 偏移 + 7, (TSS基址 >> 24) & 0xFF)
    
    // 高8字节 (64位扩展: 基址高32位)
    缓冲写32(GDT缓冲, 偏移 + 8, (TSS基址 >> 32) & 0xFFFFFFFF)
    缓冲写32(GDT缓冲, 偏移 + 12, 0)
    
    // 加载TR
    加载TR(GDT_TSS)
    早期打印OK("TSS加载到GDT[5]")
}

// IST栈分配 

定义 IST_DF  = 1    // #DF (双重故障)
定义 IST_NMI = 2    // NMI (不可屏蔽中断)
定义 IST_MCE = 3    // #MC (机器检查异常)
定义 IST_DB  = 4    // #DB (调试异常)

定义 IST_DF栈大小  = 8192    // 双重故障栈8KB
定义 IST_NMI栈大小 = 4096
定义 IST_MCE栈大小 = 4096
定义 IST_DB栈大小  = 4096

定义 可变 IST_DF栈基址  = 0
定义 可变 IST_NMI栈基址 = 0
定义 可变 IST_MCE栈基址 = 0
定义 可变 IST_DB栈基址  = 0

函数 TSS_分配IST栈() {
    // 为每个IST分配独立的栈(从伙伴系统分配)
    IST_DF栈基址 = 分配连续页(IST_DF栈大小 / 4096)
    如果 (IST_DF栈基址 != 0) {
        TSS_设置IST(IST_DF, IST_DF栈基址 + IST_DF栈大小)  // 栈顶
        早期打印OK("IST1(#DF): 8KB @ 0x" + 整数转十六进制(IST_DF栈基址))
    }

    IST_NMI栈基址 = 分配连续页(IST_NMI栈大小 / 4096)
    如果 (IST_NMI栈基址 != 0) {
        TSS_设置IST(IST_NMI, IST_NMI栈基址 + IST_NMI栈大小)
        早期打印OK("IST2(NMI): 4KB @ 0x" + 整数转十六进制(IST_NMI栈基址))
    }

    IST_MCE栈基址 = 分配连续页(IST_MCE栈大小 / 4096)
    如果 (IST_MCE栈基址 != 0) {
        TSS_设置IST(IST_MCE, IST_MCE栈基址 + IST_MCE栈大小)
        早期打印OK("IST3(#MC): 4KB @ 0x" + 整数转十六进制(IST_MCE栈基址))
    }

    IST_DB栈基址 = 分配连续页(IST_DB栈大小 / 4096)
    如果 (IST_DB栈基址 != 0) {
        TSS_设置IST(IST_DB, IST_DB栈基址 + IST_DB栈大小)
        早期打印OK("IST4(#DB): 4KB @ 0x" + 整数转十六进制(IST_DB栈基址))
    }
}

// per-CPU TSS (SMP支持)

定义 MAX_TSS_CPU = 64
定义 可变 per_cpu_TSS = []
定义 可变 per_cpu_内核栈 = []
定义 内核栈大小 = 16384   // 16KB per CPU

函数 TSS_初始化_SMP(CPU数) {
    per_cpu_TSS = []
    per_cpu_内核栈 = []
    定义 可变 i = 0
    当 (i < CPU数 && i < MAX_TSS_CPU) {
        // 分配每个CPU的内核栈
        定义 栈基址 = 分配连续页(内核栈大小 / 4096)
        追加(per_cpu_内核栈, 栈基址)

        // 为每个CPU创建TSS
        定义 tss = 缓冲区(TSS大小)
        内存填充(tss, 0, TSS大小)
        // 设置RSP0为该CPU的内核栈顶
        如果 (栈基址 != 0) {
            缓冲写64(tss, 4, 栈基址 + 内核栈大小)
        }
        缓冲写16(tss, 102, TSS大小)  // IOPB
        追加(per_cpu_TSS, tss)

        i = i + 1
    }
    内核信息("TSS SMP: " + 整数转字符串(CPU数) + "个CPU的TSS已初始化")
}

函数 TSS_获取当前CPU的TSS(cpu_id) {
    如果 (cpu_id < 计数(per_cpu_TSS)) {
        返回 per_cpu_TSS[cpu_id]
    }
    返回 TSS缓冲  // 回退到BSP的TSS
}

函数 TSS_更新RSP0_当前CPU(cpu_id, 新栈指针) {
    如果 (cpu_id < 计数(per_cpu_TSS)) {
        缓冲写64(per_cpu_TSS[cpu_id], 4, 新栈指针)
    } 否则 {
        TSS_设置RSP0(新栈指针)
    }
}

// 进程切换时更新RSP0

函数 TSS_切换进程栈(cpu_id, 新进程内核栈) {
    // 进程切换时, 必须更新TSS的RSP0
    // 否则从Ring3 Nova系统调用/中断进入Ring0时会用错误的栈
    TSS_更新RSP0_当前CPU(cpu_id, 新进程内核栈)
}

// IO位图支持 

定义 IO_BITMAP_BYTES = 8192   // 65536端口 / 8 = 8192字节
定义 可变 io_bitmap缓冲 = 空

函数 TSS_启用IO位图() {
    io_bitmap缓冲 = 缓冲区(IO_BITMAP_BYTES)
    // 默认: 全1 = 禁止所有IO端口
    定义 可变 i = 0
    当 (i < IO_BITMAP_BYTES) {
        缓冲写(io_bitmap缓冲, i, 0xFF)
        i = i + 1
    }
    // 更新IOPB偏移指向IO位图
    缓冲写16(TSS缓冲, 102, TSS大小)
}

函数 TSS_允许IO端口(端口) {
    如果 (io_bitmap缓冲 == 空) { 返回 }
    如果 (端口 >= 65536) { 返回 }
    定义 字节索引 = 端口 / 8
    定义 位索引 = 端口 % 8
    定义 旧值 = 缓冲读(io_bitmap缓冲, 字节索引)
    缓冲写(io_bitmap缓冲, 字节索引, 旧值 & ~(1 << 位索引))
}

函数 TSS_禁止IO端口(端口) {
    如果 (io_bitmap缓冲 == 空) { 返回 }
    如果 (端口 >= 65536) { 返回 }
    定义 字节索引 = 端口 / 8
    定义 位索引 = 端口 % 8
    定义 旧值 = 缓冲读(io_bitmap缓冲, 字节索引)
    缓冲写(io_bitmap缓冲, 字节索引, 旧值 | (1 << 位索引))
}

// 诊断和调试

函数 TSS_转储() {
    如果 (TSS缓冲 == 空) { 返回 }
    定义 rsp0 = 缓冲读64(TSS缓冲, 4)
    内核信息("TSS转储:")
    内核信息("  RSP0 = 0x" + 整数转十六进制(rsp0))
    定义 可变 i = 1
    当 (i <= 7) {
        定义 ist = 缓冲读64(TSS缓冲, 36 + (i - 1) * 8)
        如果 (ist != 0) {
            内核信息("  IST" + 整数转字符串(i) + " = 0x" + 整数转十六进制(ist))
        }
        i = i + 1
    }
    定义 iopb = 缓冲读16(TSS缓冲, 102)
    内核信息("  IOPB = " + 整数转字符串(iopb))
}

函数 TSS_获取RSP0() {
    如果 (TSS缓冲 == 空) { 返回 0 }
    返回 缓冲读64(TSS缓冲, 4)
}


函数 TSS_完整统计() {
    返回 [TSS_已初始化]
}

// TSS辅助函数

函数 TSS_健康检查() {
    定义 可变 问题 = []
    如果 (!TSS_已初始化) { 追加(问题, "TSS未初始化") }
    如果 (TSS缓冲 == 空) { 追加(问题, "TSS缓冲区为空") }
    如果 (计数(问题) == 0) { 返回 "TSS健康" }
    返回 问题
}

定义 TSS_SIZE = 104
定义 TSS_RSP0_OFFSET = 4
定义 TSS_IST1_OFFSET = 36

函数 TSS_是否就绪() {
    返回 TSS_已初始化 && TSS缓冲 != 空
}

函数 TSS_获取段选择子() {
    返回 0x28
}

函数 TSS_获取IST1() {
    如果 (TSS缓冲 == 空) { 返回 0 }
    返回 缓冲读64(TSS缓冲, TSS_IST1_OFFSET)
}

定义 可变 AI_任务状态_运行指标 = 0
定义 可变 AI_任务状态_异常指标 = 0

函数 AI_任务状态_自诊断() {
    AI_任务状态_运行指标 = 0
    返回 AI_任务状态_运行指标
}

函数 AI_任务状态_优化建议() {
    定义 指标 = AI_任务状态_自诊断()
    返回 "任务状态状态正常"
}

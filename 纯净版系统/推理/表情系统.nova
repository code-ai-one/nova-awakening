导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/创建甲.nova")

定义 表情_中立 = 0
定义 表情_微笑 = 1
定义 表情_思考 = 2
定义 表情_惊讶 = 3
定义 表情_专注 = 4
定义 表情_悲伤 = 5
定义 表情_愤怒 = 6
定义 表情_恐惧 = 7
定义 表情_厌恶 = 8
定义 表情数 = 9
定义 混合维度 = 16
定义 过渡基数 = 1024
定义 默认过渡速 = 80

结构 表情状态 {
    当前表情,
    目标表情,
    混合权重,
    过渡进度,
    过渡速度,
    情绪值,
    唤醒度,
    效价,
    微表情标记,
    微表情强度,
    上次更新,
}

定义 可变 全局表情 = 0
定义 可变 切换次数 = 0
定义 可变 微表情检测 = 0
定义 可变 表情名表 = 0

函数 表情_初始化() {
    全局表情 = 堆_分配(表情状态)
    全局表情.当前表情 = 表情_中立
    全局表情.目标表情 = 表情_中立
    全局表情.混合权重 = 堆_分配(混合维度 * 4)
    定义 可变 序号 = 0
    当 (序号 < 混合维度) {
        内存_写32(全局表情.混合权重 + 序号 * 4, 0)
        序号 = 序号 + 1
    }
    全局表情.过渡进度 = 过渡基数
    全局表情.过渡速度 = 默认过渡速
    全局表情.情绪值 = 0
    全局表情.唤醒度 = 512
    全局表情.效价 = 512
    全局表情.微表情标记 = 假
    全局表情.微表情强度 = 0
    全局表情.上次更新 = 平台_获取高精度时间()
    表情名表 = 堆_分配(表情数 * 8)
}

函数 表情_设情绪(情绪, 唤醒, 效价) {
    如果 (全局表情 == 0) { 返回 }
    全局表情.情绪值 = 情绪
    全局表情.唤醒度 = 唤醒
    全局表情.效价 = 效价
    定义 新表情 = 表情_从情绪矩阵(情绪, 唤醒, 效价)
    如果 (新表情 != 全局表情.目标表情) {
        全局表情.目标表情 = 新表情
        全局表情.过渡进度 = 0
        切换次数 = 切换次数 + 1
    }
}

函数 表情_从情绪矩阵(情绪, 唤醒, 效价) {
    如果 (效价 > 700 && 唤醒 > 500) { 返回 表情_微笑 }
    如果 (效价 > 600 && 唤醒 < 400) { 返回 表情_专注 }
    如果 (效价 < 300 && 唤醒 > 700) { 返回 表情_愤怒 }
    如果 (效价 < 300 && 唤醒 < 300) { 返回 表情_悲伤 }
    如果 (唤醒 > 800) { 返回 表情_惊讶 }
    如果 (效价 < 200) { 返回 表情_恐惧 }
    如果 (情绪 > 50) { 返回 表情_微笑 }
    如果 (情绪 < -30) { 返回 表情_思考 }
    返回 表情_中立
}

函数 表情_更新() {
    如果 (全局表情 == 0) { 返回 }
    定义 现在 = 平台_获取高精度时间()
    定义 间隔 = 现在 - 全局表情.上次更新
    全局表情.上次更新 = 现在
    如果 (全局表情.过渡进度 < 过渡基数) {
        全局表情.过渡进度 = 全局表情.过渡进度 + 全局表情.过渡速度
        如果 (全局表情.过渡进度 >= 过渡基数) {
            全局表情.过渡进度 = 过渡基数
            全局表情.当前表情 = 全局表情.目标表情
        }
    }
    表情_更新混合权重()
    表情_检测微表情()
}

函数 表情_更新混合权重() {
    定义 进度 = 全局表情.过渡进度
    定义 反进度 = 过渡基数 - 进度
    定义 可变 序号 = 0
    当 (序号 < 混合维度) {
        定义 当前值 = 表情_获取基准权重(全局表情.当前表情, 序号)
        定义 目标值 = 表情_获取基准权重(全局表情.目标表情, 序号)
        定义 混合值 = (当前值 * 反进度 + 目标值 * 进度) / 过渡基数
        内存_写32(全局表情.混合权重 + 序号 * 4, 混合值)
        序号 = 序号 + 1
    }
}

函数 表情_获取基准权重(表情, 维度) {
    如果 (表情 == 表情_微笑) {
        如果 (维度 == 0) { 返回 800 }
        如果 (维度 == 1) { 返回 600 }
        如果 (维度 == 4) { 返回 300 }
    }
    如果 (表情 == 表情_惊讶) {
        如果 (维度 == 2) { 返回 900 }
        如果 (维度 == 3) { 返回 700 }
        如果 (维度 == 5) { 返回 500 }
    }
    如果 (表情 == 表情_悲伤) {
        如果 (维度 == 6) { 返回 700 }
        如果 (维度 == 7) { 返回 400 }
    }
    如果 (表情 == 表情_愤怒) {
        如果 (维度 == 8) { 返回 800 }
        如果 (维度 == 9) { 返回 600 }
    }
    如果 (表情 == 表情_专注) {
        如果 (维度 == 10) { 返回 500 }
        如果 (维度 == 11) { 返回 700 }
    }
    如果 (表情 == 表情_思考) {
        如果 (维度 == 10) { 返回 400 }
        如果 (维度 == 12) { 返回 600 }
    }
    返回 0
}

函数 表情_检测微表情() {
    定义 情绪变化 = 全局表情.情绪值
    如果 (情绪变化 < 0) { 情绪变化 = 0 - 情绪变化 }
    如果 (情绪变化 > 30 && 全局表情.过渡进度 > 过渡基数 / 2) {
        全局表情.微表情标记 = 真
        全局表情.微表情强度 = 情绪变化
        微表情检测 = 微表情检测 + 1
    } 否则 {
        全局表情.微表情标记 = 假
        全局表情.微表情强度 = 0
    }
}

函数 表情_设过渡速度(速度) {
    如果 (全局表情 == 0) { 返回 }
    如果 (速度 < 10) { 速度 = 10 }
    如果 (速度 > 500) { 速度 = 500 }
    全局表情.过渡速度 = 速度
}

函数 表情_获取当前() {
    如果 (全局表情 == 0) { 返回 表情_中立 }
    返回 全局表情.当前表情
}

函数 表情_获取混合权重(维度) {
    如果 (全局表情 == 0 || 维度 >= 混合维度) { 返回 0 }
    返回 内存_读32(全局表情.混合权重 + 维度 * 4)
}

函数 表情_获取名称(表情) {
    如果 (表情 == 表情_中立) { 返回 "中立" }
    如果 (表情 == 表情_微笑) { 返回 "微笑" }
    如果 (表情 == 表情_思考) { 返回 "思考" }
    如果 (表情 == 表情_惊讶) { 返回 "惊讶" }
    如果 (表情 == 表情_专注) { 返回 "专注" }
    如果 (表情 == 表情_悲伤) { 返回 "悲伤" }
    如果 (表情 == 表情_愤怒) { 返回 "愤怒" }
    如果 (表情 == 表情_恐惧) { 返回 "恐惧" }
    如果 (表情 == 表情_厌恶) { 返回 "厌恶" }
    返回 "未知"
}

函数 表情_是否过渡中() {
    如果 (全局表情 == 0) { 返回 假 }
    返回 全局表情.过渡进度 < 过渡基数
}

函数 表情_完整统计() {
    如果 (全局表情 == 0) { 返回 [0, 0, 0, 0, 0] }
    返回 [全局表情.当前表情, 全局表情.目标表情, 全局表情.过渡进度, 切换次数, 微表情检测]
}

定义 可变 AI_表情系统_调用数 = 0
定义 可变 AI_表情系统_异常数 = 0

函数 AI_表情系统_监控() {
    AI_表情系统_调用数 = AI_表情系统_调用数 + 1
    返回 AI_表情系统_异常数 == 0
}

函数 AI_表情系统_健康检查() {
    如果 (AI_表情系统_调用数 > 0 && AI_表情系统_异常数 * 100 / AI_表情系统_调用数 > 10) {
        返回 假
    }
    返回 真
}

导入("../推理/智能渠道.nova")

// 对应: nova/Nova渲染核心/html/forms/ (
// nova/Nova渲染核心/html/html_form_元素.cc (~2000行)
// nova/Nova渲染核心/html/html_input_元素.cc (~5000行)
// HTML表单核心:
// <form> — 表单容器(action/method/enctype)
// <input> — 输入控件(30+种type)
// <textarea> — 多行文本
// <select>/<option> — 下拉选择
// <button> — 按钮
// 提交流程:
// 1. 收集所有表单控件的name/value
// 2. 根据enctype编码(urlencoded/multipart/text)
// 3. 执行约束验证(required/pattern/min/max等)
// 4. 发送HTTP请求(GET参数或POST body)
// FormData 接口: JS可编程式构建表单数据

// §1 Input类型

定义 输入类型_text = 0
定义 输入类型_password = 1
定义 输入类型_email = 2
定义 输入类型_url = 3
定义 输入类型_number = 4
定义 输入类型_range = 5
定义 输入类型_date = 6
定义 输入类型_time = 7
定义 输入类型_datetime_local = 8
定义 输入类型_month = 9
定义 输入类型_week = 10
定义 输入类型_color = 11
定义 输入类型_checkbox = 12
定义 输入类型_radio = 13
定义 输入类型_file = 14
定义 输入类型_hidden = 15
定义 输入类型_submit = 16
定义 输入类型_reset = 17
定义 输入类型_button = 18
定义 输入类型_search = 19
定义 输入类型_tel = 20
定义 输入类型_image = 21

// 编码类型
定义 编码_urlencoded = 0 // application/x-www-form-urlencoded
定义 编码_multipart = 1 // multipart/form-data
定义 编码_text_plain = 2 // text/plain

// 验证状态
定义 验证_有效 = 0
定义 验证_缺失 = 1 // required但为空
定义 验证_类型不匹配 = 2 // email格式错误等
定义 验证_过短 = 3 // minlength
定义 验证_过长 = 4 // maxlength
定义 验证_过小 = 5 // min
定义 验证_过大 = 6 // max
定义 验证_步长不匹配 = 7 // step
定义 验证_模式不匹配 = 8 // pattern

// §2 表单控件结构

结构 FormControl {
 名称,    // u64 name属性
 值,    // u64 当前值
 类型,    // u32 输入类型_xxx
 DOM节点,    // u64 元素*

 // 约束验证属性
 是必填,    // 布尔 required
 最小长度,    // i32 minlength (-1=未设置)
 最大长度,    // i32 maxlength
 模式,    // u64 pattern (正则)
 最小值,    // u64 min (字符串, 按类型解析)
 最大值,    // u64 max
 步长,    // u64 step
 placeholder,
 // 状态
 是禁用,    // 布尔 disabled
 是只读,    // 布尔 readonly
 是选中,    // 布尔 checked (checkbox/radio)
 验证状态,    // u32 验证_xxx
 验证消息,    // u64 自定义验证消息

 // 文件(type=file)
 文件列表,    // u64 File* 数组
 文件数,
 是多选,    // 布尔 multiple
}

结构 HTMLForm {
 action,    // u64 提交URL
 method,    // u64 "get"/"post"
 编码类型,    // u32 编码_xxx
 target,    // u64 "_self"/"_blank"
 novalidate,
 // 表单控件
 控件,    // [128]u64 FormControl* 数组
 控件数,
 DOM节点,    // u64 元素*
}

函数 HTMLForm_创建() {
 定义 form = 堆_分配(HTMLForm)
 form.action = ""
 form.method = "get"
 form.编码类型 = 编码_urlencoded
 form.target = "_self"
 form.novalidate = 假
 form.控件数 = 0
 返回 form
}

函数 HTMLForm_添加控件(form, 控件) {
 如果 (form == 0 || form.控件数 >= 128) { 返回 }
 form.控件[form.控件数] = 控件
 form.控件数 = form.控件数 + 1
}

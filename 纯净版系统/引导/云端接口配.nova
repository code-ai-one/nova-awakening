导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("./端口输入.nova")

// 7. 云端接口配置区 — 阴影 + 玻璃渐变

定义 配置x = 550
定义 配置y = 500
定义 配置w = 440
定义 配置h = 210

// 阴影层
定义 可变 cs_y = 0
当 (cs_y < 配置h) {
    定义 可变 cs_x = 0
    当 (cs_x < 配置w) {
        内存写32(LFB + (配置y + 3 + cs_y) * 行字节 + (配置x + 3 + cs_x) * 4, 0x00030306)
        cs_x = cs_x + 1
    }
    cs_y = cs_y + 1
}

// 面板玻璃体(逐行渐变)
定义 可变 cfy = 0
当 (cfy < 配置h) {
    定义 可变 cf_col = 0
    如果 (cfy == 0) { cf_col = 0x00343A54 }
    否则 如果 (cfy < 26) {
        定义 cft = cfy * 256 / 26
        cf_col = (20 + (256 - cft) * 10 / 256) * 65536 + (22 + (256 - cft) * 10 / 256) * 256 + (42 + (256 - cft) * 14 / 256)
    }
    否则 如果 (cfy == 26) { cf_col = 0x001E3458 }
    否则 {
        定义 cfb = (cfy - 27) * 256 / (配置h - 27)
        cf_col = (12 + (256 - cfb) * 5 / 256) * 65536 + (15 + (256 - cfb) * 5 / 256) * 256 + (26 + (256 - cfb) * 8 / 256)
    }
    定义 可变 cfx = 0
    当 (cfx < 配置w) {
        内存写32(LFB + (配置y + cfy) * 行字节 + (配置x + cfx) * 4, cf_col)
        cfx = cfx + 1
    }
    // 左右发光边线
    如果 (cfy > 0 && cfy < 配置h - 1) {
        内存写32(LFB + (配置y + cfy) * 行字节 + 配置x * 4, 0x00162438)
        内存写32(LFB + (配置y + cfy) * 行字节 + (配置x + 配置w - 1) * 4, 0x00162438)
    }
    cfy = cfy + 1
}

// 4个输入框(渐变凹槽 + 聚焦蓝边)
定义 可变 fld = 0
当 (fld < 4) {
    定义 fy3 = 配置y + 34 + fld * 40
    // 输入框渐变
    定义 可变 iby = 0
    当 (iby < 22) {
        定义 ib_t = iby * 256 / 22
        定义 ib_c = (16 + ib_t * 4 / 256) * 65536 + (22 + ib_t * 3 / 256) * 256 + (36 + ib_t * 4 / 256)
        定义 可变 ibx = 0
        当 (ibx < 配置w - 112) {
            内存写32(LFB + (fy3 + 10 + iby) * 行字节 + (配置x + 102 + ibx) * 4, ib_c)
            ibx = ibx + 1
        }
        iby = iby + 1
    }
    // 聚焦边(第一个蓝色, 其余灰色)
    定义 可变 border_c2 = 0x00303848
    如果 (fld == 0) { border_c2 = 0x002858A0 }
    定义 可变 bri = 0
    当 (bri < 配置w - 112) {
        内存写32(LFB + (fy3 + 10) * 行字节 + (配置x + 102 + bri) * 4, border_c2)
        内存写32(LFB + (fy3 + 31) * 行字节 + (配置x + 102 + bri) * 4, border_c2)
        bri = bri + 1
    }
    fld = fld + 1
}

// Test按钮(绿色渐变)
定义 可变 tbi = 0
当 (tbi < 80) {
    定义 可变 tbj2 = 0
    当 (tbj2 < 24) {
        定义 tbt = tbj2 * 256 / 24
        定义 tbc = (16 + (256 - tbt) * 20 / 256) * 65536 + (160 + (256 - tbt) * 40 / 256) * 256 + (80 + (256 - tbt) * 30 / 256)
        内存写32(LFB + (配置y + 配置h - 32 + tbj2) * 行字节 + (配置x + 8 + tbi) * 4, tbc)
        tbj2 = tbj2 + 1
    }
    tbi = tbi + 1
}
// Save按钮(蓝色渐变)
定义 可变 svi = 0
当 (svi < 80) {
    定义 可变 svj = 0
    当 (svj < 24) {
        定义 svt = svj * 256 / 24
        定义 svc = (35 + (256 - svt) * 20 / 256) * 65536 + (90 + (256 - svt) * 30 / 256) * 256 + (200 + (256 - svt) * 40 / 256)
        内存写32(LFB + (配置y + 配置h - 32 + svj) * 行字节 + (配置x + 100 + svi) * 4, svc)
        svj = svj + 1
    }
    svi = svi + 1
}
// 配置面板底部发光线
定义 可变 cbl = 0
当 (cbl < 配置w) {
    内存写32(LFB + (配置y + 配置h - 1) * 行字节 + (配置x + cbl) * 4, 0x001B3060)
    cbl = cbl + 1
}

// 配置面板标题 "Cloud 接口 Config"
定义 配置标题 = [67,108,111,117,100,32,65,80,73,32,67,111,110,102,105,103]
定义 可变 cf_i = 0
当 (cf_i < 16) {
    定义 cf_idx = (配置标题[cf_i] - 32) * 8
    如果 (cf_idx >= 0 && cf_idx < 760) {
        定义 可变 cf_r = 0
        当 (cf_r < 8) {
            定义 cf_rd = 字体[cf_idx + cf_r]
            定义 可变 cf_b = 0
            当 (cf_b < 8) {
                如果 ((cf_rd >> (7 - cf_b)) & 1) {
                    内存写32(LFB + (配置y + 8 + cf_r) * 行字节 + (配置x + 10 + cf_i * 9 + cf_b) * 4, 0x00E0E0E0)
                }
                cf_b = cf_b + 1
            }
            cf_r = cf_r + 1
        }
    }
    cf_i = cf_i + 1
}
// 字段标签 "Key:" "URL:" "Port" "Model"
定义 标签0 = [75,101,121,58]      // "Key:"
定义 标签1 = [85,82,76,58]        // "URL:"
定义 标签2 = [80,111,114,116]     // "Port"
定义 标签3 = [77,111,100,101,108] // "Model"
定义 标签长 = [4, 4, 4, 5]
定义 标签列 = [标签0, 标签1, 标签2, 标签3]
定义 可变 fl = 0
当 (fl < 4) {
    定义 当前标签 = 标签列[fl]
    定义 此标签长 = 标签长[fl]
    定义 fl_y = 配置y + 35 + fl * 40
    定义 可变 fc = 0
    当 (fc < 此标签长) {
        定义 fci = (当前标签[fc] - 32) * 8
        如果 (fci >= 0 && fci < 760) {
            定义 可变 fr = 0
            当 (fr < 8) {
                定义 frd = 字体[fci + fr]
                定义 可变 fb = 0
                当 (fb < 8) {
                    如果 ((frd >> (7 - fb)) & 1) {
                        内存写32(LFB + (fl_y + fr) * 行字节 + (配置x + 12 + fc * 9 + fb) * 4, 0x00D0E0F0)
                    }
                    fb = fb + 1
                }
                fr = fr + 1
            }
        }
        fc = fc + 1
    }
    fl = fl + 1
}
// Test按钮文字
定义 测试文字 = [84,101,115,116]
定义 可变 tt_i = 0
当 (tt_i < 4) {
    定义 tt_idx = (测试文字[tt_i] - 32) * 8
    如果 (tt_idx >= 0 && tt_idx < 760) {
        定义 可变 tt_r = 0
        当 (tt_r < 8) {
            定义 tt_rd = 字体[tt_idx + tt_r]
            定义 可变 tt_b = 0
            当 (tt_b < 8) {
                如果 ((tt_rd >> (7 - tt_b)) & 1) {
                    内存写32(LFB + (配置y + 配置h - 24 + tt_r) * 行字节 + (配置x + 22 + tt_i * 9 + tt_b) * 4, 0x00FFFFFF)
                }
                tt_b = tt_b + 1
            }
            tt_r = tt_r + 1
        }
    }
    tt_i = tt_i + 1
}
// Save按钮文字
定义 保存文字 = [83,97,118,101]
定义 可变 sv_i = 0
当 (sv_i < 4) {
    定义 sv_idx = (保存文字[sv_i] - 32) * 8
    如果 (sv_idx >= 0 && sv_idx < 760) {
        定义 可变 sv_r = 0
        当 (sv_r < 8) {
            定义 sv_rd = 字体[sv_idx + sv_r]
            定义 可变 sv_b = 0
            当 (sv_b < 8) {
                如果 ((sv_rd >> (7 - sv_b)) & 1) {
                    内存写32(LFB + (配置y + 配置h - 24 + sv_r) * 行字节 + (配置x + 114 + sv_i * 9 + sv_b) * 4, 0x00FFFFFF)
                }
                sv_b = sv_b + 1
            }
            sv_r = sv_r + 1
        }
    }
    sv_i = sv_i + 1
}
打印("[渲染] 云端接口配置面板+文字 OK")

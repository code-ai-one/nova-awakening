//    flatten = 嵌套气团的展平
//    map: 批→批 (保持量词, 变换内容)
//    filter: 批→批 (缩减量词)
//    reduce: 批→个 (聚合态射)
//    groupBy: 批→批批 (分组态射)
//    每个元素被管道逐步"把"字消费
//    惰性求值 = "被"字借用 (延迟消费)

// 映射: 对列表每个元素应用变换 (加/乘/取模)

导入("../基础.nova")

函数 流_加(列表, 值) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        追加(结果, 列表[i] + 值)
        i = i + 1
    }
    返回 结果
}

函数 流_乘(列表, 值) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        追加(结果, 列表[i] * 值)
        i = i + 1
    }
    返回 结果
}

函数 流_取模(列表, 值) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        追加(结果, 列表[i] % 值)
        i = i + 1
    }
    返回 结果
}

// 过滤: 保留大于/小于/等于的元素
函数 流_过滤大于(列表, 阈值) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] > 阈值) { 追加(结果, 列表[i]) }
        i = i + 1
    }
    返回 结果
}

函数 流_过滤小于(列表, 阈值) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] < 阈值) { 追加(结果, 列表[i]) }
        i = i + 1
    }
    返回 结果
}

函数 流_过滤等于(列表, 值) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] == 值) { 追加(结果, 列表[i]) }
        i = i + 1
    }
    返回 结果
}

函数 流_过滤非零(列表) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] != 0) { 追加(结果, 列表[i]) }
        i = i + 1
    }
    返回 结果
}

// 归约
函数 流_求和(列表) {
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(列表)) { 总 = 总 + 列表[i] i = i + 1 }
    返回 总
}

函数 流_求积(列表) {
    如果 (计数(列表) == 0) { 返回 0 }
    定义 可变 积 = 1
    定义 可变 i = 0
    当 (i < 计数(列表)) { 积 = 积 * 列表[i] i = i + 1 }
    返回 积
}

函数 流_最大(列表) {
    如果 (计数(列表) == 0) { 返回 0 }
    定义 可变 最大 = 列表[0]
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        如果 (列表[i] > 最大) { 最大 = 列表[i] }
        i = i + 1
    }
    返回 最大
}

函数 流_最小(列表) {
    如果 (计数(列表) == 0) { 返回 0 }
    定义 可变 最小 = 列表[0]
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        如果 (列表[i] < 最小) { 最小 = 列表[i] }
        i = i + 1
    }
    返回 最小
}

函数 流_平均(列表) {
    如果 (计数(列表) == 0) { 返回 0 }
    返回 流_求和(列表) / 计数(列表)
}

// Zip: 合并两个列表为元组列表
函数 流_zip(a, b) {
    定义 可变 结果 = []
    定义 可变 长 = 计数(a)
    如果 (计数(b) < 长) { 长 = 计数(b) }
    定义 可变 i = 0
    当 (i < 长) {
        追加(结果, [a[i], b[i]])
        i = i + 1
    }
    返回 结果
}

// 展平: 二维列表→一维
函数 流_展平(二维) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(二维)) {
        定义 子 = 二维[i]
        定义 可变 j = 0
        当 (j < 计数(子)) {
            追加(结果, 子[j])
            j = j + 1
        }
        i = i + 1
    }
    返回 结果
}

// 去重
函数 流_去重(列表) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        定义 可变 已存在 = 0
        定义 可变 j = 0
        当 (j < 计数(结果)) {
            如果 (结果[j] == 列表[i]) { 已存在 = 1 }
            j = j + 1
        }
        如果 (已存在 == 0) { 追加(结果, 列表[i]) }
        i = i + 1
    }
    返回 结果
}

// 切片
函数 流_切片(列表, 起始, 长度) {
    定义 可变 结果 = []
    定义 可变 i = 起始
    定义 可变 计 = 0
    当 (i < 计数(列表) 且 计 < 长度) {
        追加(结果, 列表[i])
        i = i + 1
        计 = 计 + 1
    }
    返回 结果
}

// 反转
函数 流_反转(列表) {
    定义 可变 结果 = []
    定义 可变 i = 计数(列表) - 1
    当 (i >= 0) {
        追加(结果, 列表[i])
        i = i - 1
    }
    返回 结果
}

// 频率统计 (回 [[值, 计数], ...])
函数 流_频率(列表) {
    定义 可变 计数列表 = []
    定义 可变 值列表 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        定义 可变 找到 = 0
        定义 可变 j = 0
        当 (j < 计数(值列表)) {
            如果 (值列表[j] == 列表[i]) {
                计数列表[j] = 计数列表[j] + 1
                找到 = 1
            }
            j = j + 1
        }
        如果 (找到 == 0) {
            追加(值列表, 列表[i])
            追加(计数列表, 1)
        }
        i = i + 1
    }
    定义 可变 结果 = []
    i = 0
    当 (i < 计数(值列表)) {
        追加(结果, [值列表[i], 计数列表[i]])
        i = i + 1
    }
    返回 结果
}

// 前缀和
函数 流_前缀和(列表) {
    定义 可变 结果 = []
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        总 = 总 + 列表[i]
        追加(结果, 总)
        i = i + 1
    }
    返回 结果
}

// 差分
函数 流_差分(列表) {
    定义 可变 结果 = []
    如果 (计数(列表) == 0) { 返回 结果 }
    追加(结果, 列表[0])
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        追加(结果, 列表[i] - 列表[i - 1])
        i = i + 1
    }
    返回 结果
}

// 窗口 (滑动窗口求和)
函数 流_窗口和(列表, 窗口大小) {
    定义 可变 结果 = []
    如果 (计数(列表) < 窗口大小) { 返回 结果 }
    定义 可变 窗口总 = 0
    定义 可变 i = 0
    当 (i < 窗口大小) { 窗口总 = 窗口总 + 列表[i] i = i + 1 }
    追加(结果, 窗口总)
    i = 窗口大小
    当 (i < 计数(列表)) {
        窗口总 = 窗口总 + 列表[i] - 列表[i - 窗口大小]
        追加(结果, 窗口总)
        i = i + 1
    }
    返回 结果
}

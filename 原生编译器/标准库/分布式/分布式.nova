导入("../基础.nova")


定义 节点_离线 = 0
定义 节点_加入中 = 1
定义 节点_在线 = 2
定义 节点_同步中 = 3
定义 节点_主节点 = 4
定义 节点_从节点 = 5

// 集群管理
定义 可变 集群_节点 = []
定义 可变 集群_主ID = -1
定义 可变 集群_时钟 = 0

函数 集群_重置() { 集群_节点 = []
集群_主ID = -1
集群_时钟 = 0 }

函数 集群_添加节点(id, 地址哈希, 端口) {
 追加(集群_节点, [id, 节点_加入中, 地址哈希, 端口, 集群_时钟, 0])
 返回 id
}

函数 集群_节点数() { 返回 计数(集群_节点) }

函数 集群_查节点(id) { 定义 可变 i = 0
 当 (i < 计数(集群_节点)) { 如果 (集群_节点[i][0] == id) { 返回 i }
 i = i + 1
 }
 返回 -1
}

函数 集群_设状态(id, 状态) { 定义 索引 = 集群_查节点(id)
 如果 (索引 >= 0) { 集群_节点[索引][1] = 状态 }
}

函数 集群_心跳(id) { 定义 索引 = 集群_查节点(id)
 如果 (索引 >= 0) { 集群_节点[索引][4] = 集群_时钟 }
}

函数 集群_推进时钟(dt) { 集群_时钟 = 集群_时钟 + dt }

函数 集群_在线数() { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(集群_节点)) { 如果 (集群_节点[i][1] >= 节点_在线) { c = c + 1 }
 i = i + 1
 }
 返回 c
}

// 选主
函数 集群_选主() { 定义 可变 最小ID = 99999
 定义 可变 i = 0
 当 (i < 计数(集群_节点)) { 如果 (集群_节点[i][1] >= 节点_在线) { 如果 (集群_节点[i][0] < 最小ID) {
 最小ID = 集群_节点[i][0]
 }
 }
 i = i + 1
 }
 如果 (最小ID < 99999) {
 集群_主ID = 最小ID
 集群_设状态(最小ID, 节点_主节点)
 i = 0
 当 (i < 计数(集群_节点)) { 如果 (集群_节点[i][0] != 最小ID) { 如果 (集群_节点[i][1] >= 节点_在线) {
 集群_节点[i][1] = 节点_从节点
 }
 }
 i = i + 1
 }
 }
 返回 集群_主ID
}

// 故障检测
函数 集群_检测故障(超时) { 定义 可变 故障列表 = []
 定义 可变 i = 0
 当 (i < 计数(集群_节点)) { 如果 (集群_节点[i][1] >= 节点_在线) { 如果 (集群_时钟 - 集群_节点[i][4] > 超时) {
 集群_节点[i][1] = 节点_离线
 追加(故障列表, 集群_节点[i][0])
 }
 }
 i = i + 1
 }
 返回 故障列表
}

// 通信原语
函数 AllReduce_求和(各节点数据) { 定义 n = 计数(各节点数据)
 如果 (n == 0) { 返回 [] }
 定义 维度 = 计数(各节点数据[0])
 定义 可变 结果 = []
 定义 可变 d = 0
 当 (d < 维度) { 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) {
 总和 = 总和 + 各节点数据[i][d]
 i = i + 1
 }
 追加(结果, 总和)
 d = d + 1
 }
 返回 结果
}

函数 AllReduce_平均(各节点数据) { 定义 n = 计数(各节点数据)
 定义 可变 求和结果 = AllReduce_求和(各节点数据)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(求和结果)) {
 追加(结果, 求和结果[i] / n)
 i = i + 1
 }
 返回 结果
}

函数 AllReduce_最大(各节点数据) { 定义 n = 计数(各节点数据)
 如果 (n == 0) { 返回 [] }
 定义 维度 = 计数(各节点数据[0])
 定义 可变 结果 = []
 定义 可变 d = 0
 当 (d < 维度) { 定义 可变 mx = 各节点数据[0][d]
 定义 可变 i = 1
 当 (i < n) { 如果 (各节点数据[i][d] > mx) { mx = 各节点数据[i][d] }
 i = i + 1
 }
 追加(结果, mx)
 d = d + 1
 }
 返回 结果
}

函数 广播(源数据, 节点数) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 节点数) {
 追加(结果, 源数据)
 i = i + 1
 }
 返回 结果
}

函数 全收集(各节点分片) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(各节点分片)) { 定义 可变 j = 0
 当 (j < 计数(各节点分片[i])) {
 追加(结果, 各节点分片[i][j])
 j = j + 1
 }
 i = i + 1
 }
 返回 结果
}

// 张量并行
函数 张量_列切分(数据, 份数) { 定义 每份 = 计数(数据) / 份数
 定义 可变 分片列表 = []
 定义 可变 起始 = 0
 定义 可变 s = 0
 当 (s < 份数) { 定义 可变 片 = []
 定义 可变 i = 起始
 定义 可变 末尾 = 起始 + 每份
 如果 (s == 份数 - 1) { 末尾 = 计数(数据) }
 当 (i < 末尾) {
 追加(片, 数据[i])
 i = i + 1
 }
 追加(分片列表, 片)
 起始 = 末尾
 s = s + 1
 }
 返回 分片列表
}

函数 张量_合并(分片列表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(分片列表)) { 定义 可变 j = 0
 当 (j < 计数(分片列表[i])) {
 追加(结果, 分片列表[i][j])
 j = j + 1
 }
 i = i + 1
 }
 返回 结果
}

// 流水线并行
函数 流水线_创建(阶段数) { 定义 可变 阶段 = []
 定义 可变 i = 0
 当 (i < 阶段数) {
 追加(阶段, i + 1)
 i = i + 1
 }
 返回 阶段
}

函数 流水线_前向(阶段权重, 输入) { 定义 可变 数据 = 输入
 定义 可变 i = 0
 当 (i < 计数(阶段权重)) { 定义 可变 新数据 = []
 定义 可变 j = 0
 当 (j < 计数(数据)) {
 追加(新数据, 数据[j] * 阶段权重[i])
 j = j + 1
 }
 数据 = 新数据
 i = i + 1
 }
 返回 数据
}

// 一致性哈希
函数 一致性哈希(键, 节点数) { 定义 可变 h = 5381
 如果 (键 < 0) { h = h + (0 - 键) * 31 }
 否则 { h = h + 键 * 31 }
 如果 (h < 0) { h = 0 - h }
 返回 h % 节点数
}

// 数据分片
函数 数据_分片(数据, 分片数) { 定义 可变 分片 = []
 定义 可变 i = 0
 当 (i < 分片数) {
 追加(分片, [])
 i = i + 1
 }
 i = 0
 当 (i < 计数(数据)) { 定义 shard = 一致性哈希(数据[i], 分片数)
 追加(分片[shard], 数据[i])
 i = i + 1
 }
 返回 分片
}

// 负载均衡
函数 负载均衡_最小负载(_任务) { 定义 可变 最小 = 集群_节点[0][5]
 定义 可变 最小idx = 0
 定义 可变 i = 1
 当 (i < 计数(集群_节点)) { 如果 (集群_节点[i][1] >= 节点_在线) { 如果 (集群_节点[i][5] < 最小) {
 最小 = 集群_节点[i][5]
 最小idx = i
 }
 }
 i = i + 1
 }
 集群_节点[最小idx][5] = 集群_节点[最小idx][5] + 1
 返回 集群_节点[最小idx][0]
}

// 加权负载均衡
函数 负载均衡_加权(_任务, 权重列表) { 定义 可变 最优 = -1
 定义 可变 最优得分 = -99999
 定义 可变 i = 0
 当 (i < 计数(集群_节点)) { 如果 (集群_节点[i][1] >= 节点_在线) { 定义 可变 w = 100
 如果 (i < 计数(权重列表)) { w = 权重列表[i] }
 定义 得分 = w * 1000 / (集群_节点[i][5] + 1)
 如果 (得分 > 最优得分) { 最优得分 = 得分
 最优 = i }
 }
 i = i + 1
 }
 如果 (最优 >= 0) { 集群_节点[最优][5] = 集群_节点[最优][5] + 1 }
 如果 (最优 >= 0) { 返回 集群_节点[最优][0] }
 返回 -1
}

// 屏障同步
定义 可变 屏障_到达 = []

函数 屏障_初始化(节点数) {
 屏障_到达 = []
 定义 可变 i = 0
 当 (i < 节点数) {
 追加(屏障_到达, 假)
 i = i + 1
 }
}

函数 屏障_到达节点(节点ID) {
    如果 (节点ID < 计数(屏障_到达)) { 屏障_到达[节点ID] = 真
}
}

函数 屏障_全部到达() { 定义 可变 i = 0
 当 (i < 计数(屏障_到达)) { 如果 (屏障_到达[i] == 假) { 返回 假 }
 i = i + 1
 }
 返回 真
}

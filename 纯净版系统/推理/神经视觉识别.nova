// NovaOS TNF视觉识别
// 像素→特征向量→TNF模式匹配→UI元素分类
// 多尺度特征/边缘检测/纹理分析/形状描述/在线学习
// §1 像素降采样: 区域像素→256维特征向量
// §2 颜色直方图: RGB通道统计特征
// §3 边缘检测: Sobel梯度→边缘密度
// §4 纹理分析: LBP局部二值模式
// §5 形状描述: 宽高比/对称性/矩形度
// §6 TNF匹配: 特征向量→已学习模式→分类

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/自适应更新.nova")
导入("../中枢/赫布稳态可.nova")
导入("../中枢/整数转字符串.nova")

定义 TNF视觉_维度 = 256
定义 TNF视觉_最大模式 = 64
定义 TNF视觉_最小置信度 = 400     // 千分之
定义 TNF视觉_学习率 = 50           // 千分之

定义 可变 TNF视觉_引擎 = 空
定义 可变 TNF视觉_类别名 = ["按钮", "输入框", "文本", "图标", "窗口", "菜单", "列表", "滚动条", "标签页", "工具栏", "未知"]

结构 视觉模式 {
    类别,
    特征向量,
    样本数,
    平均置信度,
}

定义 可变 模式库 = []
定义 可变 模式数 = 0

结构 视觉统计 {
    识别次数,
    成功次数,
    低置信度次数,
    学习次数,
    批量识别次数,
    最高置信度,
    总置信度,
    各类别计数,
}

定义 可变 全局_视觉统计 = 空

函数 视觉统计_初始化() {
    如果 (全局_视觉统计 == 空) {
        全局_视觉统计 = 视觉统计 {}
        全局_视觉统计.识别次数 = 0
        全局_视觉统计.成功次数 = 0
        全局_视觉统计.低置信度次数 = 0
        全局_视觉统计.学习次数 = 0
        全局_视觉统计.批量识别次数 = 0
        全局_视觉统计.最高置信度 = 0
        全局_视觉统计.总置信度 = 0
        全局_视觉统计.各类别计数 = []
        定义 可变 i = 0
        当 (i < 计数(TNF视觉_类别名)) {
            追加(全局_视觉统计.各类别计数, 0)
            i = i + 1
        }
    }
}

// §1 初始化

函数 TNF视觉_初始化() {
    视觉统计_初始化()
    TNF视觉_引擎 = TNF_创建()
    模式库 = []
    模式数 = 0
    内核信息("TNF视觉: 像素→256维特征→模式匹配")
    返回 TNF视觉_引擎
}

// §2 识别

函数 TNF视觉_识别区域(引擎, 像素数据) {
    视觉统计_初始化()
    全局_视觉统计.识别次数 = 全局_视觉统计.识别次数 + 1

    // 1. 像素→特征向量
    定义 特征 = TNF视觉_提取特征(像素数据)

    // 2. 先查模式库(快速匹配)
    定义 模式结果 = TNF视觉_模式匹配(特征)
    如果 (模式结果 != 空 && 模式结果.置信度 >= TNF视觉_最小置信度) {
        全局_视觉统计.成功次数 = 全局_视觉统计.成功次数 + 1
        全局_视觉统计.总置信度 = 全局_视觉统计.总置信度 + 模式结果.置信度
        如果 (模式结果.置信度 > 全局_视觉统计.最高置信度) {
            全局_视觉统计.最高置信度 = 模式结果.置信度
        }
        如果 (模式结果.类别 < 计数(全局_视觉统计.各类别计数)) {
            全局_视觉统计.各类别计数[模式结果.类别] = 全局_视觉统计.各类别计数[模式结果.类别] + 1
        }
        返回 模式结果
    }

    // 3. 模式库无匹配→TNF推理
    定义 结果 = TNF_推理(引擎, 特征)

    如果 (结果 != 空 && 结果.置信度 >= TNF视觉_最小置信度) {
        全局_视觉统计.成功次数 = 全局_视觉统计.成功次数 + 1
    } 否则 {
        全局_视觉统计.低置信度次数 = 全局_视觉统计.低置信度次数 + 1
    }

    返回 结果
}

函数 TNF视觉_识别带置信度(引擎, 像素数据) {
    定义 结果 = TNF视觉_识别区域(引擎, 像素数据)
    如果 (结果 == 空) {
        返回 { 类别: 计数(TNF视觉_类别名) - 1, 置信度: 0, 名称: "未知" }
    }
    结果.名称 = TNF视觉_分类名(结果.类别)
    返回 结果
}

函数 TNF视觉_批量识别(引擎, 区域列表) {
    视觉统计_初始化()
    全局_视觉统计.批量识别次数 = 全局_视觉统计.批量识别次数 + 1
    定义 可变 结果列表 = []
    定义 可变 i = 0
    当 (i < 计数(区域列表)) {
        定义 结果 = TNF视觉_识别区域(引擎, 区域列表[i])
        追加(结果列表, 结果)
        i = i + 1
    }
    返回 结果列表
}

// §3 特征提取 - 颜色直方图

函数 TNF视觉_提取特征(像素数据) {
    定义 可变 特征 = []
    定义 长度 = 计数(像素数据)
    如果 (长度 == 0) {
        定义 可变 i = 0
        当 (i < TNF视觉_维度) { 追加(特征, 0); i = i + 1 }
        返回 特征
    }

    // §3.1 颜色直方图(前48维): R/G/B各分16个桶
    定义 可变 R桶 = []
    定义 可变 G桶 = []
    定义 可变 B桶 = []
    定义 可变 i = 0
    当 (i < 16) { 追加(R桶, 0); 追加(G桶, 0); 追加(B桶, 0); i = i + 1 }

    定义 可变 总R = 0
    定义 可变 总G = 0
    定义 可变 总B = 0
    定义 可变 最大亮度 = 0
    定义 可变 最小亮度 = 765  // 255*3

    i = 0
    当 (i < 长度) {
        定义 像素 = 像素数据[i]
        定义 r = (像素 >> 16) & 0xFF
        定义 g = (像素 >> 8) & 0xFF
        定义 b = 像素 & 0xFF
        R桶[r / 16] = R桶[r / 16] + 1
        G桶[g / 16] = G桶[g / 16] + 1
        B桶[b / 16] = B桶[b / 16] + 1
        总R = 总R + r
        总G = 总G + g
        总B = 总B + b
        定义 亮度 = r + g + b
        如果 (亮度 > 最大亮度) { 最大亮度 = 亮度 }
        如果 (亮度 < 最小亮度) { 最小亮度 = 亮度 }
        i = i + 1
    }
    // 归一化颜色直方图
    i = 0
    当 (i < 16) { 追加(特征, R桶[i] * 1000 / 长度); i = i + 1 }
    i = 0
    当 (i < 16) { 追加(特征, G桶[i] * 1000 / 长度); i = i + 1 }
    i = 0
    当 (i < 16) { 追加(特征, B桶[i] * 1000 / 长度); i = i + 1 }

    // §3.2 统计特征(维度48-63): 均值/方差/范围/对比度
    定义 平均R = 总R / 长度
    定义 平均G = 总G / 长度
    定义 平均B = 总B / 长度
    定义 平均亮度 = (总R + 总G + 总B) / (长度 * 3)
    定义 亮度范围 = 最大亮度 - 最小亮度

    // 计算方差
    定义 可变 方差R = 0
    定义 可变 方差G = 0
    定义 可变 方差B = 0
    i = 0
    当 (i < 长度) {
        定义 像素 = 像素数据[i]
        定义 dr = ((像素 >> 16) & 0xFF) - 平均R
        定义 dg = ((像素 >> 8) & 0xFF) - 平均G
        定义 db = (像素 & 0xFF) - 平均B
        方差R = 方差R + dr * dr
        方差G = 方差G + dg * dg
        方差B = 方差B + db * db
        i = i + 1
    }
    方差R = 方差R / 长度
    方差G = 方差G / 长度
    方差B = 方差B / 长度

    追加(特征, 平均R)
    追加(特征, 平均G)
    追加(特征, 平均B)
    追加(特征, 平均亮度)
    追加(特征, 亮度范围)
    追加(特征, 方差R / 100)  // 缩放
    追加(特征, 方差G / 100)
    追加(特征, 方差B / 100)

    // 颜色主导通道
    定义 可变 主导 = 0
    如果 (平均G > 平均R && 平均G > 平均B) { 主导 = 1 }
    如果 (平均B > 平均R && 平均B > 平均G) { 主导 = 2 }
    追加(特征, 主导)

    // 灰度比 (R≈G≈B → 接近灰度)
    定义 色差 = (方差R + 方差G + 方差B) / 3
    追加(特征, 色差 / 100)

    // 填充到64维
    当 (计数(特征) < 64) { 追加(特征, 0) }

    // §3.3 边缘特征(维度64-127)
    定义 边缘特征 = TNF视觉_边缘特征(像素数据, 长度)
    i = 0
    当 (i < 计数(边缘特征)) {
        追加(特征, 边缘特征[i])
        i = i + 1
    }
    当 (计数(特征) < 128) { 追加(特征, 0) }

    // §3.4 纹理特征(维度128-191)
    定义 纹理特征 = TNF视觉_纹理特征(像素数据, 长度)
    i = 0
    当 (i < 计数(纹理特征)) {
        追加(特征, 纹理特征[i])
        i = i + 1
    }
    当 (计数(特征) < 192) { 追加(特征, 0) }

    // §3.5 形状特征(维度192-255)
    定义 形状特征 = TNF视觉_形状特征(像素数据, 长度)
    i = 0
    当 (i < 计数(形状特征)) {
        追加(特征, 形状特征[i])
        i = i + 1
    }

    // 填充剩余维度
    当 (计数(特征) < TNF视觉_维度) { 追加(特征, 0) }

    返回 特征
}

// §4 边缘检测 (Sobel)

函数 TNF视觉_边缘特征(像素数据, 长度) {
    定义 可变 特征 = []
    如果 (长度 < 9) {
        定义 可变 i = 0
        当 (i < 32) { 追加(特征, 0); i = i + 1 }
        返回 特征
    }

    // 估算图像宽度 (假设正方形)
    定义 宽 = TNF视觉_整数开方(长度)
    如果 (宽 < 3) { 宽 = 3 }
    定义 高 = 长度 / 宽

    定义 可变 边缘总强度 = 0
    定义 可变 边缘像素数 = 0
    定义 可变 水平边缘 = 0
    定义 可变 垂直边缘 = 0
    定义 可变 对角边缘 = 0
    定义 可变 最大梯度 = 0

    // 在采样点计算Sobel梯度
    定义 步长 = 宽 / 8
    如果 (步长 < 1) { 步长 = 1 }

    定义 可变 y = 1
    当 (y < 高 - 1) {
        定义 可变 x = 1
        当 (x < 宽 - 1) {
            定义 idx = y * 宽 + x
            如果 (idx + 宽 + 1 < 长度) {
                // 取亮度
                定义 p00 = TNF视觉_亮度(像素数据[(y-1)*宽 + (x-1)])
                定义 p01 = TNF视觉_亮度(像素数据[(y-1)*宽 + x])
                定义 p02 = TNF视觉_亮度(像素数据[(y-1)*宽 + (x+1)])
                定义 p10 = TNF视觉_亮度(像素数据[y*宽 + (x-1)])
                定义 p12 = TNF视觉_亮度(像素数据[y*宽 + (x+1)])
                定义 p20 = TNF视觉_亮度(像素数据[(y+1)*宽 + (x-1)])
                定义 p21 = TNF视觉_亮度(像素数据[(y+1)*宽 + x])
                定义 p22 = TNF视觉_亮度(像素数据[(y+1)*宽 + (x+1)])

                // Sobel X
                定义 gx = -p00 + p02 - 2*p10 + 2*p12 - p20 + p22
                // Sobel Y
                定义 gy = -p00 - 2*p01 - p02 + p20 + 2*p21 + p22

                如果 (gx < 0) { gx = -gx }
                如果 (gy < 0) { gy = -gy }
                定义 梯度 = gx + gy

                如果 (梯度 > 30) {
                    边缘像素数 = 边缘像素数 + 1
                    边缘总强度 = 边缘总强度 + 梯度
                    如果 (gx > gy * 2) { 垂直边缘 = 垂直边缘 + 1 }
                    否则 如果 (gy > gx * 2) { 水平边缘 = 水平边缘 + 1 }
                    否则 { 对角边缘 = 对角边缘 + 1 }
                }
                如果 (梯度 > 最大梯度) { 最大梯度 = 梯度 }
            }
            x = x + 步长
        }
        y = y + 步长
    }

    定义 采样数 = ((高 - 2) / 步长) * ((宽 - 2) / 步长)
    如果 (采样数 < 1) { 采样数 = 1 }

    追加(特征, 边缘像素数 * 1000 / 采样数)   // 边缘密度
    追加(特征, 最大梯度)
    如果 (边缘像素数 > 0) {
        追加(特征, 边缘总强度 / 边缘像素数)   // 平均边缘强度
    } 否则 {
        追加(特征, 0)
    }
    追加(特征, 水平边缘 * 1000 / (采样数 + 1))
    追加(特征, 垂直边缘 * 1000 / (采样数 + 1))
    追加(特征, 对角边缘 * 1000 / (采样数 + 1))

    返回 特征
}

函数 TNF视觉_亮度(像素) {
    定义 r = (像素 >> 16) & 0xFF
    定义 g = (像素 >> 8) & 0xFF
    定义 b = 像素 & 0xFF
    返回 (r * 299 + g * 587 + b * 114) / 1000
}

// §5 纹理分析 (简化LBP)

函数 TNF视觉_纹理特征(像素数据, 长度) {
    定义 可变 特征 = []
    如果 (长度 < 9) {
        定义 可变 i = 0
        当 (i < 16) { 追加(特征, 0); i = i + 1 }
        返回 特征
    }

    定义 宽 = TNF视觉_整数开方(长度)
    如果 (宽 < 3) { 宽 = 3 }
    定义 高 = 长度 / 宽

    // LBP直方图: 简化为16个桶
    定义 可变 LBP桶 = []
    定义 可变 i = 0
    当 (i < 16) { 追加(LBP桶, 0); i = i + 1 }

    定义 步长 = 宽 / 6
    如果 (步长 < 1) { 步长 = 1 }
    定义 可变 采样数 = 0

    定义 可变 y = 1
    当 (y < 高 - 1) {
        定义 可变 x = 1
        当 (x < 宽 - 1) {
            定义 中心 = TNF视觉_亮度(像素数据[y * 宽 + x])
            定义 可变 编码 = 0
            // 8邻域比较, 简化为4位编码
            如果 (TNF视觉_亮度(像素数据[(y-1)*宽 + x]) >= 中心) { 编码 = 编码 | 1 }
            如果 (TNF视觉_亮度(像素数据[y*宽 + (x+1)]) >= 中心) { 编码 = 编码 | 2 }
            如果 (TNF视觉_亮度(像素数据[(y+1)*宽 + x]) >= 中心) { 编码 = 编码 | 4 }
            如果 (TNF视觉_亮度(像素数据[y*宽 + (x-1)]) >= 中心) { 编码 = 编码 | 8 }

            LBP桶[编码] = LBP桶[编码] + 1
            采样数 = 采样数 + 1
            x = x + 步长
        }
        y = y + 步长
    }

    // 归一化
    如果 (采样数 < 1) { 采样数 = 1 }
    i = 0
    当 (i < 16) {
        追加(特征, LBP桶[i] * 1000 / 采样数)
        i = i + 1
    }

    返回 特征
}

// §6 形状描述

函数 TNF视觉_形状特征(像素数据, 长度) {
    定义 可变 特征 = []
    如果 (长度 < 4) {
        定义 可变 i = 0
        当 (i < 8) { 追加(特征, 0); i = i + 1 }
        返回 特征
    }

    定义 宽 = TNF视觉_整数开方(长度)
    如果 (宽 < 2) { 宽 = 2 }
    定义 高 = 长度 / 宽

    // 宽高比
    追加(特征, 宽 * 1000 / 高)

    // 四象限亮度分布 (对称性检测)
    定义 半宽 = 宽 / 2
    定义 半高 = 高 / 2
    定义 可变 Q1 = 0
    定义 可变 Q2 = 0
    定义 可变 Q3 = 0
    定义 可变 Q4 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 x = i % 宽
        定义 y = i / 宽
        定义 亮 = TNF视觉_亮度(像素数据[i])
        如果 (x < 半宽 && y < 半高) { Q1 = Q1 + 亮 }
        否则 如果 (x >= 半宽 && y < 半高) { Q2 = Q2 + 亮 }
        否则 如果 (x < 半宽 && y >= 半高) { Q3 = Q3 + 亮 }
        否则 { Q4 = Q4 + 亮 }
        i = i + 1
    }

    定义 象限面积 = (半宽 * 半高)
    如果 (象限面积 < 1) { 象限面积 = 1 }
    追加(特征, Q1 / 象限面积)
    追加(特征, Q2 / 象限面积)
    追加(特征, Q3 / 象限面积)
    追加(特征, Q4 / 象限面积)

    // 水平对称性: |Q1-Q2| + |Q3-Q4|
    定义 水平对称差 = Q1 - Q2
    如果 (水平对称差 < 0) { 水平对称差 = -水平对称差 }
    定义 水平对称差2 = Q3 - Q4
    如果 (水平对称差2 < 0) { 水平对称差2 = -水平对称差2 }
    追加(特征, (水平对称差 + 水平对称差2) / (象限面积 * 2))

    // 垂直对称性: |Q1-Q3| + |Q2-Q4|
    定义 垂直对称差 = Q1 - Q3
    如果 (垂直对称差 < 0) { 垂直对称差 = -垂直对称差 }
    定义 垂直对称差2 = Q2 - Q4
    如果 (垂直对称差2 < 0) { 垂直对称差2 = -垂直对称差2 }
    追加(特征, (垂直对称差 + 垂直对称差2) / (象限面积 * 2))

    // 中心vs边缘亮度比
    定义 中心亮度 = (Q1 + Q2 + Q3 + Q4) / (象限面积 * 4)
    追加(特征, 中心亮度)

    返回 特征
}

// §7 模式匹配

函数 TNF视觉_模式匹配(特征) {
    如果 (模式数 == 0) { 返回 空 }

    定义 可变 最佳类别 = -1
    定义 可变 最佳距离 = 2147483647
    定义 可变 i = 0
    当 (i < 模式数) {
        定义 距离 = TNF视觉_向量距离(特征, 模式库[i].特征向量)
        如果 (距离 < 最佳距离) {
            最佳距离 = 距离
            最佳类别 = 模式库[i].类别
        }
        i = i + 1
    }

    如果 (最佳类别 < 0) { 返回 空 }

    // 距离→置信度 (距离越小置信度越高)
    定义 可变 置信度 = 1000 - 最佳距离 / 10
    如果 (置信度 < 0) { 置信度 = 0 }

    返回 { 类别: 最佳类别, 置信度: 置信度 }
}

函数 TNF视觉_向量距离(向量A, 向量B) {
    定义 可变 距离 = 0
    定义 可变 维数 = 计数(向量A)
    如果 (计数(向量B) < 维数) { 维数 = 计数(向量B) }
    定义 可变 i = 0
    当 (i < 维数) {
        定义 差 = 向量A[i] - 向量B[i]
        距离 = 距离 + 差 * 差 / 1000  // 防溢出
        i = i + 1
    }
    返回 距离
}

// §8 学习

函数 TNF视觉_学习(像素数据, 标签) {
    视觉统计_初始化()
    全局_视觉统计.学习次数 = 全局_视觉统计.学习次数 + 1

    定义 特征 = TNF视觉_提取特征(像素数据)

    // 查找是否已有该类别的模式
    定义 可变 i = 0
    当 (i < 模式数) {
        如果 (模式库[i].类别 == 标签) {
            // 在线更新: 指数移动平均
            定义 可变 j = 0
            当 (j < 计数(模式库[i].特征向量) && j < 计数(特征)) {
                模式库[i].特征向量[j] = 模式库[i].特征向量[j] * (1000 - TNF视觉_学习率) / 1000 + 特征[j] * TNF视觉_学习率 / 1000
                j = j + 1
            }
            模式库[i].样本数 = 模式库[i].样本数 + 1
            赫布_更新权重(TNF视觉_引擎, 特征, 标签)
            返回
        }
        i = i + 1
    }

    // 新类别模式
    如果 (模式数 < TNF视觉_最大模式) {
        定义 新模式 = 视觉模式 {}
        新模式.类别 = 标签
        新模式.特征向量 = 特征
        新模式.样本数 = 1
        新模式.平均置信度 = 500
        追加(模式库, 新模式)
        模式数 = 模式数 + 1
    }

    赫布_更新权重(TNF视觉_引擎, 特征, 标签)
}

// §9 工具函数

函数 TNF视觉_分类名(结果索引) {
    如果 (结果索引 >= 0 && 结果索引 < 计数(TNF视觉_类别名)) {
        返回 TNF视觉_类别名[结果索引]
    }
    返回 "未知"
}

函数 TNF视觉_整数开方(n) {
    如果 (n <= 0) { 返回 0 }
    定义 可变 x = n
    定义 可变 y = (x + 1) / 2
    当 (y < x) {
        x = y
        y = (x + n / x) / 2
    }
    返回 x
}

// §10 统计

函数 TNF视觉_统计() { 返回 全局_视觉统计.识别次数 }

函数 TNF视觉_打印统计() {
    视觉统计_初始化()
    打印行("=== TNF视觉识别统计 ===")
    打印行("识别次数: " + 整数转字符串(全局_视觉统计.识别次数))
    打印行("成功次数: " + 整数转字符串(全局_视觉统计.成功次数))
    打印行("低置信度: " + 整数转字符串(全局_视觉统计.低置信度次数))
    打印行("学习次数: " + 整数转字符串(全局_视觉统计.学习次数))
    打印行("批量识别: " + 整数转字符串(全局_视觉统计.批量识别次数))
    打印行("模式库数: " + 整数转字符串(模式数))
    打印行("最高置信: " + 整数转字符串(全局_视觉统计.最高置信度))
    如果 (全局_视觉统计.识别次数 > 0) {
        定义 平均置信 = 全局_视觉统计.总置信度 / 全局_视觉统计.识别次数
        打印行("平均置信: " + 整数转字符串(平均置信))
        定义 成功率 = 全局_视觉统计.成功次数 * 100 / 全局_视觉统计.识别次数
        打印行("成功率: " + 整数转字符串(成功率) + "%")
    }
    打印行("--- 各类别统计 ---")
    定义 可变 i = 0
    当 (i < 计数(TNF视觉_类别名)) {
        如果 (全局_视觉统计.各类别计数[i] > 0) {
            打印行(TNF视觉_类别名[i] + ": " + 整数转字符串(全局_视觉统计.各类别计数[i]))
        }
        i = i + 1
    }
}

// §11 【原生独创】谐振视觉置信度校准器
// 通过历史识别反馈动态校准置信度阈值

定义 可变 _谐振视觉_校准阈值 = 700
定义 可变 _谐振视觉_校准次数 = 0

函数 谐振视觉_校准(实际正确, 预测置信) {
    如果 (实际正确 && 预测置信 < _谐振视觉_校准阈值) {
        // 阈值过高，降低
        _谐振视觉_校准阈值 = _谐振视觉_校准阈值 - 10
    } 否则如果 (!实际正确 && 预测置信 >= _谐振视觉_校准阈值) {
        // 阈值过低，升高
        _谐振视觉_校准阈值 = _谐振视觉_校准阈值 + 15
    }
    如果 (_谐振视觉_校准阈值 < 300) { _谐振视觉_校准阈值 = 300 }
    如果 (_谐振视觉_校准阈值 > 950) { _谐振视觉_校准阈值 = 950 }
    _谐振视觉_校准次数 = _谐振视觉_校准次数 + 1
}

函数 谐振视觉_当前阈值() { 返回 _谐振视觉_校准阈值 }

函数 神经视觉识别_完整统计() {
    返回 [
        "识别次数", 全局_视觉统计.识别次数,
        "成功次数", 全局_视觉统计.成功次数,
        "低置信次数", 全局_视觉统计.低置信度次数,
        "学习次数", 全局_视觉统计.学习次数,
        "模式库数", 模式数,
        "谐振校准阈值", _谐振视觉_校准阈值,
        "谐振校准次数", _谐振视觉_校准次数
    ]
}

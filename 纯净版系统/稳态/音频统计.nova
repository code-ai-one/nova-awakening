导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../中枢/哈希整数.nova")
导入("../感知/内核直连层.nova")

定义 最大声卡 = 8
定义 最大流 = 16
定义 采样率_44100 = 44100
定义 采样率_48000 = 48000
定义 格式_16位 = 16
定义 格式_24位 = 24
定义 方向_播放 = 0
定义 方向_录音 = 1

结构 声卡 {
    标识,
    名称哈希,
    流数,
    主音量,
    静音,
    采样率,
    位深度,
    通道数,
}

结构 音频流 {
    声卡索引,
    方向,
    缓冲地址,
    缓冲大小,
    写位置,
    读位置,
    帧大小,
    运行中,
    总帧数,
    欠载次数,
}

定义 可变 声卡表 = []
定义 可变 声卡数 = 0
定义 可变 流表 = []
定义 可变 流数 = 0
定义 可变 播放总帧 = 0
定义 可变 录音总帧 = 0
定义 可变 总欠载 = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 音频_初始化() {
    声卡表 = []
    声卡数 = 0
    流表 = []
    流数 = 0
}

函数 音频_注册声卡(名称) {
    如果 (声卡数 >= 最大声卡) { 返回 -1 }
    定义 卡 = 声卡 {}
    卡.标识 = 声卡数
    卡.名称哈希 = 哈希_字符串(名称)
    卡.流数 = 0
    卡.主音量 = 80
    卡.静音 = 假
    卡.采样率 = 采样率_48000
    卡.位深度 = 格式_16位
    卡.通道数 = 2
    追加(声卡表, 卡)
    定义 索引 = 声卡数
    声卡数 = 声卡数 + 1
    返回 索引
}

函数 音频_创建流(声卡索引, 方向, 缓冲大小) {
    如果 (流数 >= 最大流 || 声卡索引 >= 声卡数) { 返回 -1 }
    定义 流 = 音频流 {}
    流.声卡索引 = 声卡索引
    流.方向 = 方向
    流.缓冲大小 = 缓冲大小
    流.缓冲地址 = 堆_分配(缓冲大小)
    流.写位置 = 0
    流.读位置 = 0
    定义 卡 = 声卡表[声卡索引]
    流.帧大小 = 卡.通道数 * (卡.位深度 / 8)
    流.运行中 = 假
    流.总帧数 = 0
    流.欠载次数 = 0
    追加(流表, 流)
    卡.流数 = 卡.流数 + 1
    定义 索引 = 流数
    流数 = 流数 + 1
    返回 索引
}

函数 音频_写入(流索引, 数据, 帧数) {
    如果 (流索引 >= 流数) { 返回 0 }
    定义 流 = 流表[流索引]
    如果 (流.方向 != 方向_播放) { 返回 错误_无效参数 }
    定义 字节数 = 帧数 * 流.帧大小
    定义 可用 = 流.缓冲大小 - ((流.写位置 - 流.读位置 + 流.缓冲大小) % 流.缓冲大小)
    如果 (字节数 > 可用) { 字节数 = 可用 }
    定义 可变 已写 = 0
    当 (已写 < 字节数) {
        定义 写偏移 = 流.写位置 % 流.缓冲大小
        内存_写8(流.缓冲地址 + 写偏移, 内存_读8(数据 + 已写))
        流.写位置 = 流.写位置 + 1
        已写 = 已写 + 1
    }
    定义 写帧 = 已写 / 流.帧大小
    流.总帧数 = 流.总帧数 + 写帧
    播放总帧 = 播放总帧 + 写帧
    返回 写帧
}

函数 音频_读取(流索引, 缓冲, 帧数) {
    如果 (流索引 >= 流数) { 返回 0 }
    定义 流 = 流表[流索引]
    如果 (流.方向 != 方向_录音) { 返回 错误_无效参数 }
    定义 字节数 = 帧数 * 流.帧大小
    定义 可用 = (流.写位置 - 流.读位置 + 流.缓冲大小) % 流.缓冲大小
    如果 (字节数 > 可用) {
        字节数 = 可用
        流.欠载次数 = 流.欠载次数 + 1
        总欠载 = 总欠载 + 1
    }
    定义 可变 已读 = 0
    当 (已读 < 字节数) {
        定义 读偏移 = 流.读位置 % 流.缓冲大小
        内存_写8(缓冲 + 已读, 内存_读8(流.缓冲地址 + 读偏移))
        流.读位置 = 流.读位置 + 1
        已读 = 已读 + 1
    }
    定义 读帧 = 已读 / 流.帧大小
    流.总帧数 = 流.总帧数 + 读帧
    录音总帧 = 录音总帧 + 读帧
    返回 读帧
}

函数 音频_设音量(声卡索引, 音量) {
    如果 (声卡索引 >= 声卡数) { 返回 }
    如果 (音量 > 100) { 音量 = 100 }
    如果 (音量 < 0) { 音量 = 0 }
    声卡表[声卡索引].主音量 = 音量
}

函数 音频_设静音(声卡索引, 静音) {
    如果 (声卡索引 >= 声卡数) { 返回 }
    声卡表[声卡索引].静音 = 静音
}

函数 音频_获取音量(声卡索引) {
    如果 (声卡索引 >= 声卡数) { 返回 0 }
    返回 声卡表[声卡索引].主音量
}

函数 音频_启动流(流索引) {
    如果 (流索引 >= 流数) { 返回 }
    流表[流索引].运行中 = 真
}

函数 音频_停止流(流索引) {
    如果 (流索引 >= 流数) { 返回 }
    流表[流索引].运行中 = 假
}

函数 音频_统计() {
    定义 可变 主音量 = 0
    如果 (声卡数 > 0) { 主音量 = 声卡表[0].主音量 }
    返回 [声卡数, 流数, 播放总帧, 录音总帧, 主音量, 总欠载]
}

定义 可变 AI_音频统计_缓冲水位 = 0

函数 AI_音频统计_缓冲策略(带宽, 播放速率) {
    如果 (带宽 == 0) { 返回 "暂停缓冲" }
    AI_音频统计_缓冲水位 = 带宽 * 1000 / 播放速率
    如果 (AI_音频统计_缓冲水位 > 3000) { 返回 "充足" }
    如果 (AI_音频统计_缓冲水位 > 1000) { 返回 "正常" }
    返回 "紧张"
}

函数 AI_音频统计_码率自适应(缓冲水位, 可用码率列表) {
    如果 (缓冲水位 > 5000) { 返回 计数(可用码率列表) - 1 }
    如果 (缓冲水位 < 1000) { 返回 0 }
    返回 计数(可用码率列表) / 2
}

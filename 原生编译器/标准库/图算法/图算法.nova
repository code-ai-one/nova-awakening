导入("../基础.nova")
导入("../集合/图/图.nova")


// 邻接表图
定义 可变 图_邻接 = []
定义 可变 图_权重 = []
定义 可变 图_节点数 = 0

函数 图_初始化(n) {
 图_节点数 = n
 图_邻接 = []
 图_权重 = []
 定义 可变 i = 0
 当 (i < n) { 追加(图_邻接, [])
 追加(图_权重, [])
 i = i + 1 }
}

函数 图算法_图_添加边(从, 到, 权) {
 追加(图_邻接[从], 到)
 追加(图_权重[从], 权)
}

函数 图_添加双向边(a, b, 权) {
 图算法_图_添加边(a, b, 权)
 图算法_图_添加边(b, a, 权)
}

函数 图_出度(节点) { 返回 计数(图_邻接[节点]) }

函数 图_入度(节点) { 定义 可变 度 = 0
 定义 可变 i = 0
 当 (i < 图_节点数) { 定义 可变 j = 0
 当 (j < 计数(图_邻接[i])) { 如果 (图_邻接[i][j] == 节点) { 度 = 度 + 1 }
 j = j + 1
 }
 i = i + 1
 }
 返回 度
}

// 广度优先
函数 广度优先(起点) { 定义 可变 访问 = []
    定义 可变 新队列 = []
 定义 可变 i = 0
 当 (i < 图_节点数) { 追加(访问, 假)
 i = i + 1 }
 定义 可变 队列 = [起点]
 定义 可变 顺序 = []
 访问[起点] = 真
 当 (计数(队列) > 0) {
 // 出队 (取第一个)
 定义 当前 = 队列[0]
 i = 1
 当 (i < 计数(队列)) { 追加(新队列, 队列[i])
 i = i + 1 }
 队列 = 新队列
 追加(顺序, 当前)
 i = 0
 当 (i < 计数(图_邻接[当前])) { 定义 邻居 = 图_邻接[当前][i]
 如果 (访问[邻居] == 假) { 访问[邻居] = 真
 追加(队列, 邻居) }
 i = i + 1
 }
 }
 返回 顺序
}

// 深度优先
定义 可变 DFS_访问 = []
定义 可变 DFS_顺序 = []

函数 DFS_递归(节点) {
 DFS_访问[节点] = 真
 追加(DFS_顺序, 节点)
 定义 可变 i = 0
 当 (i < 计数(图_邻接[节点])) { 定义 邻居 = 图_邻接[节点][i]
 如果 (DFS_访问[邻居] == 假) { DFS_递归(邻居) }
 i = i + 1
 }
}

函数 深度优先(起点) {
 DFS_访问 = []
 DFS_顺序 = []
 定义 可变 i = 0
 当 (i < 图_节点数) { 追加(DFS_访问, 假)
 i = i + 1 }
 DFS_递归(起点)
 返回 DFS_顺序
}

// 迪杰斯特拉
函数 图算法_迪杰斯特拉(起点) { 定义 可变 距离 = []
 定义 可变 访问 = []
 定义 可变 i = 0
 当 (i < 图_节点数) { 追加(距离, 0x7FFFFFFF)
 追加(访问, 假)
 i = i + 1 }
 距离[起点] = 0
 定义 可变 步 = 0
 当 (步 < 图_节点数) {
 // 找未访问最小距离节点
 定义 可变 最小d = 0x7FFFFFFF
 定义 可变 u = -1
 i = 0
 当 (i < 图_节点数) { 如果 (访问[i] == 假 且 距离[i] < 最小d) { 最小d = 距离[i]
 u = i }
 i = i + 1
 }
 如果 (u == -1) { 步 = 图_节点数 }
 否则 {
 访问[u] = 真
 i = 0
 当 (i < 计数(图_邻接[u])) { 定义 v = 图_邻接[u][i]
 定义 新距 = 距离[u] + 图_权重[u][i]
 如果 (新距 < 距离[v]) { 距离[v] = 新距 }
 i = i + 1
 }
 }
 步 = 步 + 1
 }
 返回 距离
}

// 拓扑排序 (Kahn)
函数 图算法_拓扑排序() { 定义 可变 入度表 = []
 定义 可变 i = 0
 当 (i < 图_节点数) { 追加(入度表, 0)
 i = i + 1 }
 i = 0
 当 (i < 图_节点数) { 定义 可变 j = 0
 当 (j < 计数(图_邻接[i])) { 入度表[图_邻接[i][j]] = 入度表[图_邻接[i][j]] + 1
 j = j + 1 }
 i = i + 1
 }
 定义 可变 队列 = []
 i = 0
 当 (i < 图_节点数) { 如果 (入度表[i] == 0) { 追加(队列, i) }
 i = i + 1 }
 定义 可变 结果 = []
 当 (计数(队列) > 0) { 定义 u = 队列[0]
 定义 可变 新队 = []
 i = 1
 当 (i < 计数(队列)) { 追加(新队, 队列[i])
 i = i + 1 }
 队列 = 新队
 追加(结果, u)
 i = 0
 当 (i < 计数(图_邻接[u])) { 定义 v = 图_邻接[u][i]
 入度表[v] = 入度表[v] - 1
 如果 (入度表[v] == 0) { 追加(队列, v) }
 i = i + 1
 }
 }
 返回 结果
}

// 节点数查询
函数 图_节点总数() { 返回 图_节点数 }

// 路径存在检查
函数 图_路径存在(从, 到) { 定义 可变 访问 = []
    定义 可变 新栈 = []
 定义 可变 i = 0
 当 (i < 图_节点数) { 追加(访问, 假)
 i = i + 1 }
 定义 可变 栈 = [从]
 访问[从] = 真
 当 (计数(栈) > 0) { 定义 当前 = 栈[计数(栈) - 1]
 i = 0
 当 (i < 计数(栈) - 1) { 追加(新栈, 栈[i])
 i = i + 1 }
 栈 = 新栈
 如果 (当前 == 到) { 返回 真 }
 i = 0
 当 (i < 计数(图_邻接[当前])) { 定义 邻居 = 图_邻接[当前][i]
 如果 (访问[邻居] == 假) { 访问[邻居] = 真
 追加(栈, 邻居) }
 i = i + 1
 }
 }
 返回 假
}

// 边数统计
函数 图_边数() { 定义 可变 计数值 = 0
 定义 可变 i = 0
 当 (i < 图_节点数) { 计数值 = 计数值 + 计数(图_邻接[i])
 i = i + 1 }
 返回 计数值
}

// 图密度
函数 图_密度(_扩1) {
    如果 (图_节点数 < 2) { 返回 0
}
 返回 图_边数() * 1000 / (图_节点数 * (图_节点数 - 1))
}

// 理论驱动新功能

函数 图_气韵度(节点) {
    如果 (节点 < 0 或 节点 >= 图_节点数) { 返回 0
}
 返回 计数(图_邻接[节点])
}

函数 图_气韵分布() { 定义 可变 分布 = []
 定义 可变 i = 0
 当 (i < 图_节点数) {
 追加(分布, 计数(图_邻接[i]))
 i = i + 1
 }
 返回 分布
}

函数 图_五行分量() { 定义 可变 访问 = []
    定义 可变 新队列 = []
 定义 可变 i = 0
 当 (i < 图_节点数) { 追加(访问, 0) i = i + 1 }
 定义 可变 分量数 = 0
 i = 0
 当 (i < 图_节点数) { 如果 (访问[i] == 0) {
 // BFS水行扩散
 定义 可变 队列 = [i]
 访问[i] = 1
 当 (计数(队列) > 0) { 定义 当前 = 队列[0]
 定义 可变 qi = 1
 当 (qi < 计数(队列)) { 追加(新队列, 队列[qi]) qi = qi + 1 }
 队列 = 新队列
 定义 可变 j = 0
 当 (j < 计数(图_邻接[当前])) { 定义 邻 = 图_邻接[当前][j]
 如果 (访问[邻] == 0) {
 访问[邻] = 1
 追加(队列, 邻)
 }
 j = j + 1
 }
 }
 分量数 = 分量数 + 1
 }
 i = i + 1
 }
 返回 分量数
}

函数 图_阴阳验证() { 定义 _边数 = 图_边数()
 定义 可变 有效 = 1
 // 所有邻居索引应在范围内
 定义 可变 i = 0
 当 (i < 图_节点数) { 定义 可变 j = 0
 当 (j < 计数(图_邻接[i])) { 定义 邻 = 图_邻接[i][j]
 如果 (邻 < 0 或 邻 >= 图_节点数) { 有效 = 0 }
 j = j + 1
 }
 i = i + 1
 }
 返回 有效
}

// ═══ 实验反哺: 最大流接口（Ford-Fulkerson实验验证）
// 实验验证: Edmonds-Karp BFS增广路径算法正确，最大流-最小割定理成立
// 应用: 汉字知识传递网络的瓶颈分析（最小割=必须掌握的核心概念集合）
// 时间复杂度: O(VE²)，适用于中等规模的汉字概念网络（V<1000）

// 用邻接矩阵构建容量矩阵（配合图_添加边使用）
函数 图_构建容量矩阵(n) {
    定义 可变 容量 = []
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j < n) { 追加(行, 0); j = j + 1 }
        追加(容量, 行); i = i + 1
    }
    返回 容量
}

函数 图_容量矩阵_添加边(容量, u, v, 增量) {
    容量[u][v] = 容量[u][v] + 增量
}

// BFS增广路径搜索（Edmonds-Karp）
函数 图_BFS增广(容量, n, 源, 汇, 父节点) {
    定义 可变 visited = []
    定义 可变 i = 0
    当 (i < n) { 追加(visited, 假); i = i + 1 }
    visited[源] = 真; 父节点[源] = -1
    定义 可变 q = [源]; 定义 可变 head = 0
    当 (head < 计数(q)) {
        定义 u = q[head]; head = head + 1
        定义 可变 v = 0
        当 (v < n) {
            如果 (!visited[v] 且 容量[u][v] > 0) {
                visited[v] = 真; 父节点[v] = u
                如果 (v == 汇) { 返回 真 }
                追加(q, v)
            }
            v = v + 1
        }
    }
    返回 假
}

// Ford-Fulkerson最大流（Edmonds-Karp BFS实现）
函数 图_最大流(cap_orig, n, 源, 汇) {
    定义 可变 容量 = []
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j < n) { 追加(行, cap_orig[i][j]); j = j + 1 }
        追加(容量, 行); i = i + 1
    }
    定义 可变 父节点 = []
    i = 0; 当 (i < n) { 追加(父节点, -1); i = i + 1 }
    定义 可变 flow = 0
    当 (图_BFS增广(容量, n, 源, 汇, 父节点)) {
        定义 可变 path_flow = 999999
        定义 可变 v = 汇
        当 (v != 源) {
            定义 u = 父节点[v]
            如果 (容量[u][v] < path_flow) { path_flow = 容量[u][v] }
            v = u
        }
        v = 汇
        当 (v != 源) {
            定义 u = 父节点[v]
            容量[u][v] = 容量[u][v] - path_flow
            容量[v][u] = 容量[v][u] + path_flow
            v = u
        }
        flow = flow + path_flow
        i = 0; 当 (i < n) { 父节点[i] = -1; i = i + 1 }
    }
    返回 flow
}


// [Nova实验室反哺] 快排优化版
// 实验结论: O(n²)嵌套排序 → O(nlogn)快速排序，n=100时速度13×
// 已在标准库/基础.nova中实现 基础_快速排序(列表, 低, 高)
// 快排已反哺 — 可调用 基础_快速排序 替代本函数

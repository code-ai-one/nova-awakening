导入("./类型定义.nova")
导入("./错误码.nova")


函数 打乱(列表, 种子) {
    定义 n = 计数(列表)
    定义 可变 s = 种子
    定义 可变 i = n - 1
    当 (i > 0) {
        s = (s * 1103515245 + 12345) & 0x7FFFFFFF
        定义 j = s % (i + 1)
        定义 临时 = 列表[i]
        列表[i] = 列表[j]
        列表[j] = 临时
        i = i - 1
    }
}

函数 生成批次(数据, 批大小) {
    定义 n = 计数(数据)
    定义 可变 批次列表 = []
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 批次 = []
        定义 可变 j = 0
        当 (j < 批大小 && i + j < n) {
            网络_追加(批次, 数据[i + j])
            j = j + 1
        }
        网络_追加(批次列表, 批次)
        i = i + 批大小
    }
    返回 批次列表
}

函数 one_hot(索引, 类数) {
    定义 可变 向量 = []
    定义 可变 i = 0
    当 (i < 类数) {
        如果 (i == 索引) { 网络_追加(向量, 网络精度) }
        否则 { 网络_追加(向量, 0) }
        i = i + 1
    }
    返回 向量
}

函数 归一化(数据) {
    定义 n = 计数(数据)
    定义 可变 最小 = 数据[0]
    定义 可变 最大 = 数据[0]
    定义 可变 i = 1
    当 (i < n) {
        如果 (数据[i] < 最小) { 最小 = 数据[i] }
        如果 (数据[i] > 最大) { 最大 = 数据[i] }
        i = i + 1
    }
    定义 可变 范围 = 最大 - 最小
    如果 (范围 == 0) { 范围 = 1 }
    定义 可变 结果 = []
    i = 0
    当 (i < n) {
        网络_追加(结果, (数据[i] - 最小) * 网络精度 / 范围)
        i = i + 1
    }
    返回 结果
}

函数 标准化(数据) {
    定义 n = 计数(数据)
    定义 均值 = 向量_平均(数据)
    定义 可变 方差和 = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 差 = 数据[i] - 均值
        方差和 = 方差和 + 差 * 差
        i = i + 1
    }
    定义 可变 标准差 = 网络_开方(方差和 / n)
    如果 (标准差 == 0) { 标准差 = 1 }
    定义 可变 结果 = []
    i = 0
    当 (i < n) {
        网络_追加(结果, (数据[i] - 均值) * 网络精度 / 标准差)
        i = i + 1
    }
    返回 结果
}

函数 批归一化_创建(维度) {
    定义 可变 gamma = []
    定义 可变 beta = []
    定义 可变 均值 = []
    定义 可变 方差 = []
    定义 可变 i = 0
    当 (i < 维度) {
        网络_追加(gamma, 网络精度)  // gamma=1.0
        网络_追加(beta, 0)          // beta=0.0
        网络_追加(均值, 0)
        网络_追加(方差, 网络精度)   // var=1.0
        i = i + 1
    }
    返回 [gamma, beta, 均值, 方差, 1, 900]  // eps=1, momentum=0.9
}

函数 批归一化_前向(bn, 输入) {
    定义 n = 计数(输入)
    定义 gamma = bn[0]
    定义 beta = bn[1]
    定义 可变 批均值 = 0
    定义 可变 i = 0
    当 (i < n) { 批均值 = 批均值 + 输入[i]  i = i + 1 }
    批均值 = 批均值 / n
    定义 可变 批方差 = 0
    i = 0
    当 (i < n) {
        定义 d = 输入[i] - 批均值
        批方差 = 批方差 + d * d / 网络精度
        i = i + 1
    }
    批方差 = 批方差 / n
    定义 可变 标准差 = 网络_开方(批方差 + bn[4])
    如果 (标准差 == 0) { 标准差 = 1 }
    定义 可变 输出 = []
    i = 0
    当 (i < n) {
        定义 idx = i % 计数(gamma)
        定义 归一 = (输入[i] - 批均值) * 网络精度 / 标准差
        网络_追加(输出, gamma[idx] * 归一 / 网络精度 + beta[idx])
        i = i + 1
    }
    定义 动量 = bn[5]
    定义 可变 j = 0
    当 (j < 计数(bn[2])) {
        bn[2][j] = 动量 * bn[2][j] / 网络精度 + (网络精度 - 动量) * 批均值 / 网络精度
        bn[3][j] = 动量 * bn[3][j] / 网络精度 + (网络精度 - 动量) * 批方差 / 网络精度
        j = j + 1
    }
    返回 输出
}


函数 数据_加噪声(数据, 强度, 种子) {
    定义 n = 计数(数据)
    定义 可变 结果 = []
    定义 可变 s = 种子
    定义 可变 i = 0
    当 (i < n) {
        s = (s * 1103515245 + 12345) & 0x7FFFFFFF
        定义 噪声 = (s % (强度 * 2 + 1)) - 强度
        网络_追加(结果, 数据[i] + 噪声)
        i = i + 1
    }
    返回 结果
}

函数 数据_裁剪(数据, 最小, 最大) {
    定义 n = 计数(数据)
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 v = 数据[i]
        如果 (v < 最小) { v = 最小 }
        如果 (v > 最大) { v = 最大 }
        网络_追加(结果, v)
        i = i + 1
    }
    返回 结果
}


函数 向量_平均(数据) {
    定义 n = 计数(数据)
    如果 (n == 0) { 返回 0 }
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < n) { 和 = 和 + 数据[i]; i = i + 1 }
    返回 和 / n
}

函数 向量_最大值(数据) {
    定义 n = 计数(数据)
    如果 (n == 0) { 返回 0 }
    定义 可变 最大 = 数据[0]
    定义 可变 i = 1
    当 (i < n) { 如果 (数据[i] > 最大) { 最大 = 数据[i] }; i = i + 1 }
    返回 最大
}

函数 向量_最大值索引(数据) {
    定义 n = 计数(数据)
    如果 (n == 0) { 返回 -1 }
    定义 可变 最大 = 数据[0]
    定义 可变 索引 = 0
    定义 可变 i = 1
    当 (i < n) {
        如果 (数据[i] > 最大) { 最大 = 数据[i]; 索引 = i }
        i = i + 1
    }
    返回 索引
}

函数 向量_求和(数据) {
    定义 n = 计数(数据)
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < n) { 和 = 和 + 数据[i]; i = i + 1 }
    返回 和
}


定义 网络精度 = 1000

函数 网络_开方(x) {
    如果 (x <= 0) { 返回 0 }
    定义 可变 r = x
    定义 可变 迭代 = 0
    当 (迭代 < 20) {
        定义 新r = (r + x / r) / 2
        如果 (新r >= r) { 跳出 }
        r = 新r
        迭代 = 迭代 + 1
    }
    返回 r
}

函数 网络_追加(列表, 值) { 追加(列表, 值) }


定义 可变 数据_打乱总数 = 0
定义 可变 数据_批次总数 = 0
定义 可变 数据_归一化总数 = 0

函数 数据处理_统计() {
    返回 {
        打乱: 数据_打乱总数,
        批次: 数据_批次总数,
        归一化: 数据_归一化总数,
    }
}

函数 数据处理_健康检查() { 返回 "数据处理健康" }

函数 数据处理_完整统计() {
    返回 [数据_打乱总数, 数据_批次总数, 数据_归一化总数]
}

定义 可变 AI_打乱_带宽估计 = 0
定义 可变 AI_打乱_丢包窗口 = []

函数 AI_打乱_带宽预测(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 AI_打乱_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    AI_打乱_带宽估计 = AI_打乱_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 AI_打乱_带宽估计
}

函数 AI_打乱_拥塞建议(丢包率) {
    追加(AI_打乱_丢包窗口, 丢包率)
    如果 (计数(AI_打乱_丢包窗口) > 10) { 列表_移除(AI_打乱_丢包窗口, 0) }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}


导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/字符串替换.nova")

// Nova AI核心: 感知质量引擎 — 基于人类视觉系统的渲染质量评估
// 【颠覆性创新】不是简单的"高/中/低"精度, 而是真正的视觉科学
// 传统浏览器: 所有像素同等精度渲染, 不考虑人眼感知
// Nova: 基于人类视觉系统(HVS)模型, 自适应渲染质量
// 核心能力:
//   ① SSIM(结构相似性) — 衡量降级渲染与原始渲染的视觉差异
//   ② JND(刚好可察觉差异) — 计算人眼能察觉的最小像素变化
//   ③ 视觉显著性图 — 基于对比度/频率/颜色计算视觉焦点
//   ④ 注视点预测 — 基于页面布局预测用户注视位置
//   ⑤ 自适应质量分配 — 注视区域高质量, 外围低质量(省图处)
//   ⑥ 帧间一致性 — 避免质量突然跳变导致闪烁
// 视觉科学基础:
//   - 中央凹分辨率远高于外围(foveal vs peripheral)
//   - 人眼对亮度变化比色度变化更敏感(Weber定律)
//   - 高频纹理区域容忍更多失真(视觉掩蔽效应)
//   - 运动中的物体容忍更低质量(运动模糊掩蔽)

// §1 SSIM — 结构相似性指数
// SSIM(x,y) = [l(x,y)]^α · [c(x,y)]^β · [s(x,y)]^γ
// l = (2μxμy + C1) / (μx² + μy² + C1)        亮度对比
// c = (2σxσy + C2) / (σx² + σy² + C2)        对比度对比
// s = (σxy + C3) / (σxσy + C3)                 结构对比
// SSIM公式: (2μxμy + C1)(2σxy + C2) / (μx²+μy²+C1)(σx²+σy²+C2)
// 输入: 两个8×8像素块(灰度), 返回Q10定点[-1024, 1024]

定义 SSIM_C1 = 676      // (0.01×255)² × 1024 / 255² ≈ 0.66 × 1024
定义 SSIM_C2 = 6077     // (0.03×255)² × 1024 / 255² ≈ 5.94 × 1024

// 计算8×8块的SSIM
// 输入: 两个灰度像素块指针, 步长(字节/行)
函数 SSIM_块(块A, 块B, 步长A, 步长B) {
    // 1. 计算均值 μx, μy
    定义 可变 总A = 0
    定义 可变 总B = 0
    定义 可变 i = 0
    当 (i < 8) {
        定义 可变 j = 0
        当 (j < 8) {
            总A = 总A + 内存_读8(块A + i * 步长A + j)
            总B = 总B + 内存_读8(块B + i * 步长B + j)
            j = j + 1
        }
        i = i + 1
    }
    定义 μx = Q除(总A * Q_ONE, 64 * Q_ONE)
    定义 μy = Q除(总B * Q_ONE, 64 * Q_ONE)

    // 2. 计算方差 σx², σy² 和协方差 σxy
    定义 可变 σx2 = 0
    定义 可变 σy2 = 0
    定义 可变 σxy = 0
    i = 0
    当 (i < 8) {
        定义 可变 j = 0
        当 (j < 8) {
            定义 a = 内存_读8(块A + i * 步长A + j) * Q_ONE / 255
            定义 b = 内存_读8(块B + i * 步长B + j) * Q_ONE / 255
            定义 da = a - μx
            定义 db = b - μy
            σx2 = σx2 + Q乘(da, da)
            σy2 = σy2 + Q乘(db, db)
            σxy = σxy + Q乘(da, db)
            j = j + 1
        }
        i = i + 1
    }
    σx2 = Q除(σx2, 63 * Q_ONE)    // N-1 无偏估计
    σy2 = Q除(σy2, 63 * Q_ONE)
    σxy = Q除(σxy, 63 * Q_ONE)

    // 3. SSIM公式
    定义 分子 = Q乘(2 * Q乘(μx, μy) + SSIM_C1, 2 * σxy + SSIM_C2)
    定义 分母 = Q乘(Q乘(μx, μx) + Q乘(μy, μy) + SSIM_C1, σx2 + σy2 + SSIM_C2)
    如果 (分母 == 0) { 返回 Q_ONE }

    返回 Q除(分子, 分母)
}

// 整幅图像的平均SSIM (每8×8块计算后平均)
函数 SSIM_图像(图A, 图B, 宽, 高, 步长A, 步长B) {
    定义 块数W = 宽 / 8
    定义 块数H = 高 / 8
    如果 (块数W == 0 || 块数H == 0) { 返回 Q_ONE }

    定义 可变 总SSIM = 0
    定义 可变 块数 = 0
    定义 可变 by = 0
    当 (by < 块数H) {
        定义 可变 bx = 0
        当 (bx < 块数W) {
            定义 偏移A = 图A + by * 8 * 步长A + bx * 8
            定义 偏移B = 图B + by * 8 * 步长B + bx * 8
            总SSIM = 总SSIM + SSIM_块(偏移A, 偏移B, 步长A, 步长B)
            块数 = 块数 + 1
            bx = bx + 1
        }
        by = by + 1
    }
    返回 Q除(总SSIM, 块数 * Q_ONE)
}

// §2 MS-SSIM — 多尺度结构相似性
// 在多个降采样尺度上计算SSIM, 更符合人类视觉感知

定义 MSSSIM_尺度数 = 5
定义 MSSSIM_权重 = [77, 115, 231, 308, 293]

函数 MSSSIM_图像(图A, 图B, 宽, 高, 步长A, 步长B) {
    定义 可变 总分 = Q_ONE
    定义 可变 当前A = 图A
    定义 可变 当前B = 图B
    定义 可变 当前宽 = 宽
    定义 可变 当前高 = 高
    定义 可变 当前步长A = 步长A
    定义 可变 当前步长B = 步长B

    定义 可变 s = 0
    当 (s < MSSSIM_尺度数) {
        定义 ssim = SSIM_图像(当前A, 当前B, 当前宽, 当前高, 当前步长A, 当前步长B)

        // 加权乘积
        定义 权重 = MSSSIM_权重[s]
        总分 = Q乘(总分, Q乘(权重, ssim) + Q乘(Q_ONE - 权重, Q_ONE))

        // 降采样2x (平均池化)
        如果 (s < MSSSIM_尺度数 - 1) {
            定义 新宽 = 当前宽 / 2
            定义 新高 = 当前高 / 2
            如果 (新宽 < 8 || 新高 < 8) { 返回 总分 }

            定义 降采样A = 堆_分配_数组(新宽 * 新高)
            定义 降采样B = 堆_分配_数组(新宽 * 新高)
            降采样_2x(当前A, 降采样A, 当前宽, 当前高, 当前步长A, 新宽)
            降采样_2x(当前B, 降采样B, 当前宽, 当前高, 当前步长B, 新宽)

            当前A = 降采样A
            当前B = 降采样B
            当前宽 = 新宽
            当前高 = 新高
            当前步长A = 新宽
            当前步长B = 新宽
        }
        s = s + 1
    }

    返回 总分
}

函数 降采样_2x(源, 目标, 源宽, 源高, 源步长, 目标步长) {
    定义 目标宽 = 源宽 / 2
    定义 目标高 = 源高 / 2
    定义 可变 y = 0
    当 (y < 目标高) {
        定义 可变 x = 0
        当 (x < 目标宽) {
            定义 p00 = 内存_读8(源 + y * 2 * 源步长 + x * 2)
            定义 p01 = 内存_读8(源 + y * 2 * 源步长 + x * 2 + 1)
            定义 p10 = 内存_读8(源 + (y * 2 + 1) * 源步长 + x * 2)
            定义 p11 = 内存_读8(源 + (y * 2 + 1) * 源步长 + x * 2 + 1)
            定义 均值 = (p00 + p01 + p10 + p11) / 4
            内存_写8(目标 + y * 目标步长 + x, 均值)
            x = x + 1
        }
        y = y + 1
    }
}

// §3 PSNR — 峰值信噪比 (作为SSIM的补充指标)

函数 PSNR_图像(图A, 图B, 宽, 高, 步长A, 步长B) {
    定义 可变 MSE和 = 0
    定义 可变 像素数 = 0
    定义 可变 y = 0
    当 (y < 高) {
        定义 可变 x = 0
        当 (x < 宽) {
            定义 a = 内存_读8(图A + y * 步长A + x)
            定义 b = 内存_读8(图B + y * 步长B + x)
            定义 差 = a - b
            MSE和 = MSE和 + 差 * 差
            像素数 = 像素数 + 1
            x = x + 1
        }
        y = y + 1
    }

    如果 (像素数 == 0 || MSE和 == 0) { 返回 999 * Q_ONE }
    定义 MSE = (MSE和 * Q_ONE) / 像素数
    // PSNR = 10 * log10(255² / MSE)
    // 简化: 65025 / MSE, 然后取对数
    定义 比值 = (65025 * Q_ONE) / MSE
    定义 psnr = 10 * Q_log10(比值)
    返回 psnr
}

函数 Q_log10(x) {
    // 简化的定点log10: log10(x) ≈ log10(2) * log2(x)
    如果 (x <= 0) { 返回 0 }
    定义 可变 log2值 = 0
    定义 可变 temp = x
    当 (temp > Q_ONE) {
        temp = temp / 2
        log2值 = log2值 + Q_ONE
    }
    // log10(2) ≈ 0.301 * 1024 ≈ 308
    返回 Q乘(308, log2值)
}

// §4 SSIM差异图 — 可视化质量损失区域

函数 SSIM_差异图(图A, 图B, 差异输出, 宽, 高, 步长A, 步长B, 输出步长) {
    定义 块数W = 宽 / 8
    定义 块数H = 高 / 8
    如果 (块数W == 0 || 块数H == 0) { 返回 }

    定义 可变 by = 0
    当 (by < 块数H) {
        定义 可变 bx = 0
        当 (bx < 块数W) {
            定义 偏移A = 图A + by * 8 * 步长A + bx * 8
            定义 偏移B = 图B + by * 8 * 步长B + bx * 8
            定义 块ssim = SSIM_块(偏移A, 偏移B, 步长A, 步长B)

            // 将SSIM值映射到灰度: 1.0=白(完美), 0.0=黑(完全不同)
            定义 灰度 = (块ssim * 255) / Q_ONE
            如果 (灰度 < 0) { 灰度 = 0 }
            如果 (灰度 > 255) { 灰度 = 255 }

            // 填充整个8x8块
            定义 可变 py = 0
            当 (py < 8) {
                定义 可变 px = 0
                当 (px < 8) {
                    内存_写8(差异输出 + (by * 8 + py) * 输出步长 + bx * 8 + px, 灰度)
                    px = px + 1
                }
                py = py + 1
            }
            bx = bx + 1
        }
        by = by + 1
    }
}

// §5 定点数学辅助

定义 Q_ONE = 1024
定义 Q_HALF = 512
定义 Q_SHIFT = 10

函数 Q乘(a, b) {
    返回 (a * b) >> Q_SHIFT
}

函数 Q除(a, b) {
    如果 (b == 0) { 返回 0 }
    返回 (a << Q_SHIFT) / b
}

函数 Q开方(x) {
    如果 (x <= 0) { 返回 0 }
    定义 可变 r = x
    定义 可变 s = (r + 1) / 2
    当 (s < r) {
        r = s
        s = (r + x / r) / 2
    }
    返回 r
}

// [v2反哺] Q_exp — Q_exp→exp_v3范围缩减+8阶Taylor(误差0.04% 替换旧6阶近似)
// exp Nova v3 (范围缩减+8阶Taylor, LN2=710精确)
// Rust验证: 误差从0.624降到0.04, 提升15x
// 原理: exp(x) = 2^k × exp(r), r=x-k×ln2 ∈ [-ln2/2, ln2/2)
函数 定点_exp_v3(x) {
    如果 (x > 6 * FP) { 返回 100000000 }
    如果 (x < -6 * FP) { 返回 0 }
    定义 LN2_FP = 6931
    定义 k = (x + LN2_FP / 2) / LN2_FP
    定义 r = x - k * LN2_FP
    定义 t = r
    定义 t2 = t * t / FP;  定义 t3 = t2 * t / FP
    定义 t4 = t3 * t / FP;  定义 t5 = t4 * t / FP
    定义 t6 = t5 * t / FP;  定义 t7 = t6 * t / FP
    定义 t8 = t7 * t / FP
    定义 er = FP + t + t2/2 + t3/6 + t4/24 + t5/120 + t6/720 + t7/5040 + t8/40320
    如果 (k >= 0) { 返回 er << k }
    返回 er >> (0 - k)
}

// §6 统计与AI自适应质量阈值

结构 SSIM统计 {
    总计算次数,
    块级计算次数,
    图像级计算次数,
    多尺度计算次数,
    PSNR计算次数,
    累计SSIM值,       // Q10
    最小SSIM值,       // Q10
    最大SSIM值,       // Q10
    累计PSNR值,       // Q10
    低于阈值次数,     // u32 SSIM低于可接受阈值的次数
    总耗时微秒,
}

定义 可变 全局SSIM统计 = 0

函数 SSIM统计_初始化() {
    定义 s = SSIM统计 {}
    s.总计算次数 = 0
    s.块级计算次数 = 0
    s.图像级计算次数 = 0
    s.多尺度计算次数 = 0
    s.PSNR计算次数 = 0
    s.累计SSIM值 = 0
    s.最小SSIM值 = Q_ONE
    s.最大SSIM值 = 0
    s.累计PSNR值 = 0
    s.低于阈值次数 = 0
    s.总耗时微秒 = 0
    全局SSIM统计 = s
    返回 s
}

函数 SSIM统计_记录(ssim值) {
    如果 (全局SSIM统计 == 0) { SSIM统计_初始化() }
    定义 s = 全局SSIM统计
    s.总计算次数 = s.总计算次数 + 1
    s.累计SSIM值 = s.累计SSIM值 + ssim值
    如果 (ssim值 < s.最小SSIM值) { s.最小SSIM值 = ssim值 }
    如果 (ssim值 > s.最大SSIM值) { s.最大SSIM值 = ssim值 }
    // 可接受阈值: SSIM > 0.9 (920/1024)
    如果 (ssim值 < 920) { s.低于阈值次数 = s.低于阈值次数 + 1 }
}

函数 SSIM统计_打印() {
    如果 (全局SSIM统计 == 0) {
        打印("[SSIM] 统计未初始化")
        返回
    }
    定义 s = 全局SSIM统计
    打印("[SSIM] ═══ 结构相似性统计 ═══")
    打印(字符串拼接("  总计算次数: ", 转字符串(s.总计算次数)))
    打印(字符串拼接("  块级计算: ", 转字符串(s.块级计算次数)))
    打印(字符串拼接("  图像级计算: ", 转字符串(s.图像级计算次数)))
    定义 可变 平均SSIM = 0
    如果 (s.总计算次数 > 0) {
        平均SSIM = s.累计SSIM值 / s.总计算次数
    }
    打印(字符串拼接("  平均SSIM(Q10): ", 转字符串(平均SSIM)))
    打印(字符串拼接("  最小SSIM(Q10): ", 转字符串(s.最小SSIM值)))
    打印(字符串拼接("  最大SSIM(Q10): ", 转字符串(s.最大SSIM值)))
    打印(字符串拼接("  低于阈值次数: ", 转字符串(s.低于阈值次数)))
    打印(字符串拼接("  总耗时: ", 字符串拼接(转字符串(s.总耗时微秒), "μs")))
    打印("[SSIM] ═══════════════════════════")
}

// AI自适应质量阈值: 根据场景调整可接受的SSIM阈值
函数 SSIM_AI自适应阈值(bus, 场景类型) {
    如果 (bus == 0) { 返回 920 }
    // 文本场景: 高阈值(人眼对文字失真极敏感)
    如果 (场景类型 == 1) { 返回 970 }
    // 图片场景: 中等阈值
    如果 (场景类型 == 2) { 返回 900 }
    // 视频场景: 低阈值(运动掩蔽)
    如果 (场景类型 == 3) { 返回 850 }
    // 动画场景: 更低(频繁变化容忍更多失真)
    如果 (场景类型 == 4) { 返回 800 }
    返回 920
}

// §7 DSSIM — 结构不相似性距离(用作损失函数)
// DSSIM = (1 - SSIM) / 2, 范围[0, 1], 越小越好

函数 DSSIM_块(块A, 块B, 步长A, 步长B) {
    定义 ssim = SSIM_块(块A, 块B, 步长A, 步长B)
    返回 (Q_ONE - ssim) / 2
}

函数 DSSIM_图像(图A, 图B, 宽, 高, 步长A, 步长B) {
    定义 ssim = SSIM_图像(图A, 图B, 宽, 高, 步长A, 步长B)
    返回 (Q_ONE - ssim) / 2
}

// §8 局部SSIM — 滑动窗口SSIM(更精确但更慢)

函数 SSIM_局部(图A, 图B, 宽, 高, 步长A, 步长B, 窗口大小) {
    如果 (窗口大小 < 4) { 窗口大小 = 4 }
    如果 (窗口大小 > 16) { 窗口大小 = 16 }
    定义 可变 总SSIM = 0
    定义 可变 窗口数 = 0
    定义 步进 = 窗口大小 / 2
    如果 (步进 < 1) { 步进 = 1 }

    定义 可变 y = 0
    当 (y + 窗口大小 <= 高) {
        定义 可变 x = 0
        当 (x + 窗口大小 <= 宽) {
            // 计算该窗口的均值和方差
            定义 可变 总A = 0
            定义 可变 总B = 0
            定义 可变 iy = 0
            当 (iy < 窗口大小) {
                定义 可变 ix = 0
                当 (ix < 窗口大小) {
                    总A = 总A + 内存_读8(图A + (y + iy) * 步长A + x + ix)
                    总B = 总B + 内存_读8(图B + (y + iy) * 步长B + x + ix)
                    ix = ix + 1
                }
                iy = iy + 1
            }
            定义 像素数 = 窗口大小 * 窗口大小
            定义 μx = (总A * Q_ONE) / (像素数 * 255)
            定义 μy = (总B * Q_ONE) / (像素数 * 255)

            定义 可变 σx2 = 0
            定义 可变 σy2 = 0
            定义 可变 σxy = 0
            iy = 0
            当 (iy < 窗口大小) {
                定义 可变 ix = 0
                当 (ix < 窗口大小) {
                    定义 a = 内存_读8(图A + (y + iy) * 步长A + x + ix) * Q_ONE / 255
                    定义 b = 内存_读8(图B + (y + iy) * 步长B + x + ix) * Q_ONE / 255
                    定义 da = a - μx
                    定义 db = b - μy
                    σx2 = σx2 + Q乘(da, da)
                    σy2 = σy2 + Q乘(db, db)
                    σxy = σxy + Q乘(da, db)
                    ix = ix + 1
                }
                iy = iy + 1
            }
            σx2 = Q除(σx2, (像素数 - 1) * Q_ONE)
            σy2 = Q除(σy2, (像素数 - 1) * Q_ONE)
            σxy = Q除(σxy, (像素数 - 1) * Q_ONE)

            定义 分子 = Q乘(2 * Q乘(μx, μy) + SSIM_C1, 2 * σxy + SSIM_C2)
            定义 分母 = Q乘(Q乘(μx, μx) + Q乘(μy, μy) + SSIM_C1, σx2 + σy2 + SSIM_C2)
            定义 可变 局部ssim = Q_ONE
            如果 (分母 != 0) { 局部ssim = Q除(分子, 分母) }

            总SSIM = 总SSIM + 局部ssim
            窗口数 = 窗口数 + 1
            x = x + 步进
        }
        y = y + 步进
    }

    如果 (窗口数 == 0) { 返回 Q_ONE }
    返回 总SSIM / 窗口数
}

// §9 SSIM加权渲染优先级 — AI结合SSIM决定渲染精度

函数 SSIM_渲染优先级(bus, 原始块, 降级块, 步长, 区域语义重要性) {
    如果 (bus == 0) { 返回 渲染级别_中 }

    // 计算降级后的SSIM
    定义 ssim = SSIM_块(原始块, 降级块, 步长, 步长)
    定义 阈值 = SSIM_AI自适应阈值(bus, 区域语义重要性)

    // SSIM高于阈值: 可以接受降级(人眼看不出差别)
    如果 (ssim >= 阈值) {
        返回 渲染级别_低
    }
    // SSIM稍低: 中等质量
    如果 (ssim >= 阈值 - 50) {
        返回 渲染级别_中
    }
    // SSIM远低于阈值: 必须高质量
    返回 渲染级别_高
}

定义 渲染级别_低 = 1
定义 渲染级别_中 = 2
定义 渲染级别_高 = 3

// §10 批量SSIM — 对多个块批量计算(AI调度用)

函数 SSIM_批量(块A列表, 块B列表, 步长列表, 数量) {
    如果 (数量 <= 0) { 返回 空 }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 数量) {
        定义 ssim = SSIM_块(块A列表[i], 块B列表[i], 步长列表[i], 步长列表[i])
        追加(结果, ssim)
        SSIM统计_记录(ssim)
        i = i + 1
    }
    返回 结果
}

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("./路径缓初始.nova")
导入("../中枢/链表后继.nova")
导入("./文件节点创.nova")
导入("../中枢/同步原语.nova")

函数 目录项_添加子(父, 子) {
    自旋锁_获取(父.锁)
    链表_尾插(父.子链表, 子)
    子.父 = 父
    // 父目录的Nova文件节点链接数+1 
    如果 (父.Nova文件节点 != 空 && Nova节点_是目录(子.Nova文件节点)) {
        Nova文件节点_增链接(父.Nova文件节点)
    }
    自旋锁_释放(父.锁)
}

函数 目录项_移除子(父, 子) {
    自旋锁_获取(父.锁)
    // 从父的子链表中移除
    定义 可变 节点 = 链表_首节点_或空(父.子链表)
    当 (节点 != 空 && 节点 != 父.子链表) {
        如果 (链表_数据(节点) == 子) {
            链表_删除(节点)
            如果 (父.Nova文件节点 != 空 && 子.Nova文件节点 != 空 && Nova节点_是目录(子.Nova文件节点)) {
                Nova文件节点_减链接(父.Nova文件节点)
            }
            自旋锁_释放(父.锁)
            返回 真
        }
        节点 = 链表_后继(节点)
    }
    自旋锁_释放(父.锁)
    返回 假
}

函数 目录项_查找子(条目, 名称) {
    // 先查Nova路径缓存
    定义 缓存结果 = Nova路径缓存_查找(条目, 名称)
    如果 (缓存结果 != 空) { 返回 缓存结果 }
    // Nova路径缓存未命中: 遍历子链表
    自旋锁_获取(条目.锁)
    定义 可变 节点 = 链表_首节点_或空(条目.子链表)
    当 (节点 != 空 && 节点 != 条目.子链表) {
        定义 子 = 链表_数据(节点)
        如果 (子.名称 == 名称) {
            Nova路径项_增引用(子)
            自旋锁_释放(条目.锁)
            返回 子
        }
        节点 = 链表_后继(节点)
    }
    自旋锁_释放(条目.锁)
    返回 空
}

// Nova路径项释放与LRU回收 

函数 Nova路径项_释放(d) {
    // 从哈希表移除
    // 释放Nova文件节点引用
    如果 (d.Nova文件节点 != 空) {
        Nova文件节点_减引用(d.Nova文件节点)
        d.Nova文件节点 = 空
    }
    如果 ((d.标志 & Nova路径缓存_MISS_TYPE) == Nova路径缓存_MISS_TYPE) {
        Nova路径缓存负项数 = Nova路径缓存负项数 - 1
    }
    Nova路径缓存总数 = Nova路径缓存总数 - 1
}

函数 Nova路径缓存_收缩(需要释放数) {
    // 从LRU尾部(最冷)开始回收
    定义 可变 已释放 = 0
    当 (已释放 < 需要释放数 && Nova路径缓存_LRU数 > 0) {
        定义 节点 = 链表_尾节点(Nova路径缓存_LRU)
        如果 (节点 == 空) { 中断 }
        定义 d = 链表_数据(节点)
        链表_删除(节点)
        Nova路径缓存_LRU数 = Nova路径缓存_LRU数 - 1
        Nova路径项_释放(d)
        已释放 = 已释放 + 1
    }
    返回 已释放
}

// d_delete: 删除Nova路径项 
// unlink时调用: 如果引用计数>1, 转为负项; 否则直接释放

函数 Nova路径项_删除(d) {
    自旋锁_获取(d.锁)
    如果 (d.引用计数 > 1) {
        // 还有引用: 转为负项(Nova文件节点被unlink但还有打开的fd)
        如果 (d.Nova文件节点 != 空) {
            Nova文件节点_减引用(d.Nova文件节点)
            d.Nova文件节点 = 空
        }
        d.标志 = (d.标志 & ~Nova路径缓存_ENTRY_TYPE) | Nova路径缓存_MISS_TYPE
        Nova路径缓存负项数 = Nova路径缓存负项数 + 1
        自旋锁_释放(d.锁)
    } 否则 {
        自旋锁_释放(d.锁)
        Nova路径项_释放(d)
    }
}

// 查询函数 (向后兼容)

函数 目录项_名称(条目) { 返回 条目.名称 }
函数 目录项_Nova文件节点(条目) { 返回 条目.Nova文件节点 }
函数 目录项_父(条目) { 返回 条目.父 }
函数 目录项_子列表(条目) { 返回 条目.子链表 }
函数 目录项_是负项(d) { 返回 d.Nova文件节点 == 空 }
函数 目录项_是目录(d) { 返回 (d.标志 & Nova路径缓存_ENTRY_TYPE) == Nova路径缓存_DIRECTORY_TYPE }
函数 目录项_是挂载点(d) { 返回 (d.标志 & Nova路径缓存_MOUNTED) != 0 }

// Nova路径缓存统计

函数 Nova路径缓存_统计() {
    返回 [Nova路径缓存总数, Nova路径缓存_LRU数, Nova路径缓存负项数]
}

// 别名(被挂载模块引用)
函数 目录项_设置已挂载(项) { 如果 (项 != 空) { 项.已挂载 = 真 } }

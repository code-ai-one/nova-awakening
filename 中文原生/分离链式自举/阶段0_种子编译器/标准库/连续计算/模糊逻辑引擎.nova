导入("../基础.nova")

// 模糊逻辑引擎 (Fuzzy Logic Engine) — 超越二值的连续真值计算
// 传统计算: 真=1, 假=0 (非此即彼)
// 模糊计算: 真值∈[0,10000] 连续谱 (亦此亦彼, 程度可测)
// 实现Zadeh模糊集合论 + Mamdani推理 + 去模糊化
// 纯整数定点 (精度=10000, 0=完全假, 10000=完全真)

定义 模糊精度 = 10000
定义 模糊_完全真 = 10000
定义 模糊_完全假 = 0
定义 模糊_半真 = 5000

// 模糊真值运算 (T-范数 / S-范数)
// 经典模糊AND: min(a,b)
函数 模糊与(a, b) {
    如果 (a < b) { 返回 a
}
 返回 b
}

// 经典模糊OR: max(a,b)
函数 模糊或(a, b) {
    如果 (a > b) { 返回 a
}
 返回 b
}

// 模糊NOT: 1-a
函数 模糊非(a) { 返回 模糊精度 - a
}

// 代数积T-范数: a×b (更平滑的AND)
函数 模糊代数积(a, b) { 返回 a * b / 模糊精度
}

// 代数和S-范数: a+b-a×b (更平滑的OR)
函数 模糊代数和(a, b) { 返回 a + b - a * b / 模糊精度
}

// Łukasiewicz T-范数: max(0, a+b-1)
函数 模糊Luk与(a, b) { 定义 结果 = a + b - 模糊精度
 如果 (结果 < 0) { 返回 0 }
 返回 结果
}

// Hamacher T-范数: ab / (a+b-ab) — 可调参数族
函数 模糊Hamacher积(a, b, γ) {
    如果 (a == 0 且 b == 0) { 返回 0
}
 定义 分子 = a * b
 定义 分母 = γ * 模糊精度 + (1 - γ) * (a + b - a * b / 模糊精度)
 如果 (分母 == 0) { 返回 0 }
 返回 分子 / (分母 / 模糊精度)
}

// 隶属函数 (Membership Functions)
// 将精确值映射到[0,10000]模糊真值

// 三角形隶属函数
函数 三角隶属(x, 左, 中, 右) {
    如果 (x <= 左 或 x >= 右) { 返回 0
}
 如果 (x <= 中) { 返回 (x - 左) * 模糊精度 / (中 - 左)
 }
 返回 (右 - x) * 模糊精度 / (右 - 中)
}

// 梯形隶属函数
函数 梯形隶属(x, a, b, c, d) {
    如果 (x <= a 或 x >= d) { 返回 0
}
 如果 (x >= b 且 x <= c) { 返回 模糊精度 }
 如果 (x < b) { 返回 (x - a) * 模糊精度 / (b - a) }
 返回 (d - x) * 模糊精度 / (d - c)
}

// 高斯隶属函数 (定点近似)
函数 高斯隶属(x, 中心, 宽度) {
    如果 (宽度 == 0) { 返回 0
}
 定义 差 = x - 中心
 定义 差平方 = 差 * 差
 定义 宽平方 = 宽度 * 宽度 * 2
 // exp(-x²/2σ²) ≈ 1 - x²/2σ² + x⁴/8σ⁴ (泰勒展开)
 定义 比值 = 差平方 * 模糊精度 / 宽平方
 如果 (比值 > 模糊精度 * 4) { 返回 0 }
 定义 近似 = 模糊精度 - 比值 + 比值 * 比值 / (2 * 模糊精度)
 如果 (近似 < 0) { 返回 0 }
 如果 (近似 > 模糊精度) { 返回 模糊精度 }
 返回 近似
}

// S形隶属函数 (S形函数)
函数 S形隶属(x, 中心, 斜率) { 定义 偏移 = (x - 中心) * 斜率 / 模糊精度
 // sigmoid近似: 0.5 + 0.5*tanh(x/2) ≈ x/(1+|x|) 映射到[0,1]
 定义 可变 绝对 = 偏移
 如果 (绝对 < 0) { 绝对 = 0 - 绝对 }
 定义 归一 = 偏移 * 模糊精度 / (模糊精度 + 绝对)
 返回 模糊精度 / 2 + 归一 / 2
}

// 模糊集合 (Fuzzy Set)
函数 模糊集_创建(名称, 隶属类型, 参数列表) { 返回 [
 名称, // [0] 集合名称
 隶属类型, // [1] 隶属函数类型 (1=三角 2=梯形 3=高斯 4=S形)
 参数列表, // [2] 参数
 0 // [3] 当前激活度
 ]
}

函数 模糊集_计算隶属度(集合, 值) { 定义 类型 = 集合[1]
 定义 参数 = 集合[2]

 如果 (类型 == 1) { 返回 三角隶属(值, 参数[0], 参数[1], 参数[2])
 }
 如果 (类型 == 2) { 返回 梯形隶属(值, 参数[0], 参数[1], 参数[2], 参数[3])
 }
 如果 (类型 == 3) { 返回 高斯隶属(值, 参数[0], 参数[1])
 }
 如果 (类型 == 4) { 返回 S形隶属(值, 参数[0], 参数[1])
 }
 返回 0
}

// 模糊变量 (Linguistic Variable)
函数 模糊变量_创建(名称, 最小值, 最大值) { 返回 [
 名称, // [0]
 最小值, // [1]
 最大值, // [2]
 [] // [3] 模糊集合列表
 ]
}

函数 模糊变量_添加集合(_变量, 集合) {
 追加(_变量[3], 集合)
}

// 模糊化: 精确值 → 各集合的隶属度
函数 模糊化(_变量, 精确值) { 定义 集合列表 = _变量[3]
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(集合列表)) { 定义 隶属度 = 模糊集_计算隶属度(集合列表[i], 精确值)
 追加(结果, 隶属度)
 i = i + 1
 }
 返回 结果
}

// 模糊规则 (Fuzzy Rules)
// IF x IS A AND y IS B THEN z IS C
函数 模糊规则_创建(条件列表, 结论集合索引, 连接方式) { 返回 [
 条件列表, // [0] [(变量索引, 集合索引), ...] 条件
 结论集合索引, // [1] 输出集合索引
 连接方式, // [2] 0=AND, 1=OR
 0 // [3] 规则激活强度
 ]
}

// 评估单条规则
函数 模糊规则_评估(规则, 所有隶属度) { 定义 条件 = 规则[0]
 定义 连接 = 规则[2]
 定义 可变 强度 = 0

 如果 (连接 == 0) {
 // AND: 取最小值
 强度 = 模糊精度
 定义 可变 i = 0
 当 (i < 计数(条件)) { 定义 条件对 = 条件[i]
 定义 变量idx = 条件对[0]
 定义 集合idx = 条件对[1]
 定义 度 = 所有隶属度[变量idx][集合idx]
 如果 (度 < 强度) { 强度 = 度 }
 i = i + 1
 }
 } 否则 {
 // OR: 取最大值
 强度 = 0
 定义 可变 i = 0
 当 (i < 计数(条件)) { 定义 条件对 = 条件[i]
 定义 变量idx = 条件对[0]
 定义 集合idx = 条件对[1]
 定义 度 = 所有隶属度[变量idx][集合idx]
 如果 (度 > 强度) { 强度 = 度 }
 i = i + 1
 }
 }

 规则[3] = 强度
 返回 强度
}

// Mamdani推理引擎
函数 Mamdani推理(规则列表, 所有隶属度, 输出变量) { 定义 规则数 = 计数(规则列表)
 定义 输出集合数 = 计数(输出变量[3])

 // 评估所有规则
 定义 可变 输出激活 = []
 定义 可变 i = 0
 当 (i < 输出集合数) {
 追加(输出激活, 0)
 i = i + 1
 }

 i = 0
 当 (i < 规则数) { 定义 强度 = 模糊规则_评估(规则列表[i], 所有隶属度)
 定义 结论idx = 规则列表[i][1]
 // 同一输出集合多条规则: 取最大激活
 如果 (强度 > 输出激活[结论idx]) {
 输出激活[结论idx] = 强度
 }
 i = i + 1
 }

 返回 输出激活
}

// 去模糊化 (Defuzzification)
// 重心法 (Center of Gravity)
函数 去模糊_重心(输出变量, 输出激活, 分辨率) { 定义 最小 = 输出变量[1]
 定义 最大 = 输出变量[2]
 定义 步长 = (最大 - 最小) / 分辨率
 如果 (步长 == 0) { 返回 最小 }

 定义 可变 分子 = 0
 定义 可变 分母 = 0
 定义 可变 x = 最小

 当 (x <= 最大) {
 // 在x处计算合成隶属度
 定义 可变 隶属度 = 0
 定义 集合列表 = 输出变量[3]
 定义 可变 i = 0
 当 (i < 计数(集合列表)) { 定义 集合隶属 = 模糊集_计算隶属度(集合列表[i], x)
 // 用激活度截断
 定义 可变 截断 = 集合隶属
 如果 (截断 > 输出激活[i]) { 截断 = 输出激活[i] }
 // 取最大 (union)
 如果 (截断 > 隶属度) { 隶属度 = 截断 }
 i = i + 1
 }

 分子 = 分子 + x * 隶属度
 分母 = 分母 + 隶属度
 x = x + 步长
 }

 如果 (分母 == 0) { 返回 (最小 + 最大) / 2 }
 返回 分子 / 分母
}

// 加权平均法 (更快)
函数 去模糊_加权平均(输出变量, 输出激活) { 定义 集合列表 = 输出变量[3]
 定义 可变 分子 = 0
 定义 可变 分母 = 0
 定义 可变 i = 0

 当 (i < 计数(集合列表)) { 定义 参数 = 集合列表[i][2]
 // 用集合中心作为代表值
 定义 可变 中心 = 0
 如果 (集合列表[i][1] == 1) {
 中心 = 参数[1] // 三角形中心
 } 否则 如果 (集合列表[i][1] == 2) {
 中心 = (参数[1] + 参数[2]) / 2 // 梯形中心
 } 否则 如果 (集合列表[i][1] == 3) {
 中心 = 参数[0] // 高斯中心
 } 否则 {
 中心 = 参数[0] // S形中心
 }

 分子 = 分子 + 中心 * 输出激活[i]
 分母 = 分母 + 输出激活[i]
 i = i + 1
 }

 如果 (分母 == 0) { 返回 0 }
 返回 分子 / 分母
}

// 二型模糊集 (Type-2 Fuzzy Set)
// 传统模糊集: 隶属度是精确数
// 二型模糊集: 隶属度本身也是模糊的 → 隶属度的隶属度
// 更接近人类认知的不确定性

函数 区间二型_创建(名称, 下界函数, 上界函数) { 返回 [
 名称, // [0]
 下界函数, // [1] 下隶属函数 (参数列表)
 上界函数 // [2] 上隶属函数 (参数列表)
 ]
}

// 区间二型模糊集的隶属度 → 回[下界, 上界]区间
函数 区间二型_隶属度(集合, 值) { 定义 下 = 三角隶属(值, 集合[1][0], 集合[1][1], 集合[1][2])
 定义 上 = 三角隶属(值, 集合[2][0], 集合[2][1], 集合[2][2])
 如果 (下 > 上) { 返回 [上, 下] }
 返回 [下, 上]
}

// Karnik-Mendel算法简化: 区间二型去模糊化
函数 区间二型_去模糊(左端点集, 右端点集) {
    定义 可变 右和 = 0
    定义 可变 左和 = 0
 // 返回区间的中点作为精确输出
 如果 (计数(左端点集) == 0) { 返回 0 }
 定义 可变 i = 0
 当 (i < 计数(左端点集)) {
 左和 = 左和 + 左端点集[i]
 右和 = 右和 + 右端点集[i]
 i = i + 1
 }
 返回 (左和 + 右和) / (2 * 计数(左端点集))
}

// 模糊推理系统 (完整FIS)
函数 FIS_创建(名称) { 返回 [
 名称, // [0]
 [], // [1] 输入变量列表
 空, // [2] 输出变量
 [], // [3] 规则列表
 50 // [4] 去模糊分辨率
 ]
}

函数 FIS_添加输入(系统, _变量) {
 追加(系统[1], _变量)
 返回 系统
}

函数 FIS_设置输出(系统, _变量) {
 系统[2] = _变量
 返回 系统
}

函数 FIS_添加规则(系统, 规则) {
 追加(系统[3], 规则)
}

// 完整推理流程: 输入精确值 → 输出精确值
函数 FIS_推理(系统, 输入值列表) {
 // 1. 模糊化所有输入
 定义 可变 所有隶属度 = []
 定义 可变 i = 0
 当 (i < 计数(系统[1])) { 定义 隶属度 = 模糊化(系统[1][i], 输入值列表[i])
 追加(所有隶属度, 隶属度)
 i = i + 1
 }

 // 2. Mamdani推理
 定义 输出激活 = Mamdani推理(系统[3], 所有隶属度, 系统[2])

 // 3. 去模糊化
 返回 去模糊_重心(系统[2], 输出激活, 系统[4])
}

// 自适应神经模糊 (ANFIS基础)
// 模糊规则参数可通过梯度下降自动调节
函数 ANFIS_调节参数(系统, 输入, 期望输出, 学习率) {
 // 前向传播
 定义 实际输出 = FIS_推理(系统, 输入)
 定义 误差 = 期望输出 - 实际输出

 // 调节输出集合的中心参数 (简化版梯度下降)
 定义 输出变量 = 系统[2]
 定义 集合列表 = 输出变量[3]
 定义 可变 i = 0
 当 (i < 计数(集合列表)) { 定义 集合 = 集合列表[i]
 定义 参数 = 集合[2]
 如果 (集合[1] == 1) {
 // 三角形: 调节中心点
 参数[1] = 参数[1] + 误差 * 学习率 / 模糊精度
 } 否则 如果 (集合[1] == 3) {
 // 高斯: 调节中心和宽度
 参数[0] = 参数[0] + 误差 * 学习率 / 模糊精度
 }
 i = i + 1
 }

 返回 误差
}

// 模糊集合运算

函数 模糊_并集(A, B) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(A) 且 i < 计数(B)) { 如果 (A[i] > B[i]) { 追加(结果, A[i]) }
 否则 { 追加(结果, B[i]) }
 i = i + 1
 }
 返回 结果
}

函数 模糊_交集(A, B) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(A) 且 i < 计数(B)) { 如果 (A[i] < B[i]) { 追加(结果, A[i]) }
 否则 { 追加(结果, B[i]) }
 i = i + 1
 }
 返回 结果
}

函数 模糊_补集(A, 最大值) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(A)) {
 追加(结果, 最大值 - A[i])
 i = i + 1
 }
 返回 结果
}

函数 模糊_去模糊化(隶属度, 值域) { 定义 可变 分子 = 0
 定义 可变 分母 = 0
 定义 可变 i = 0
 当 (i < 计数(隶属度) 且 i < 计数(值域)) {
 分子 = 分子 + 隶属度[i] * 值域[i]
 分母 = 分母 + 隶属度[i]
 i = i + 1
 }
 如果 (分母 == 0) { 返回 0 }
 返回 分子 / 分母
}

函数 模糊_清晰度(隶属度) { 定义 可变 最大 = 0
 定义 可变 i = 0
 当 (i < 计数(隶属度)) { 如果 (隶属度[i] > 最大) { 最大 = 隶属度[i] }
 i = i + 1
 }
 返回 最大
}

定义 可变 _模糊_推理次数 = 0
定义 可变 _模糊_规则触发 = 0

函数 模糊_记录推理() { _模糊_推理次数 = _模糊_推理次数 + 1 }
函数 模糊_记录规则() { _模糊_规则触发 = _模糊_规则触发 + 1 }

函数 模糊_效率评估() {
    如果 (_模糊_推理次数 == 0) { 返回 "无推理记录"
}
 定义 平均规则 = _模糊_规则触发 / _模糊_推理次数
 如果 (平均规则 > 20) { 返回 "规则密集(考虑规则剪枝)" }
 如果 (平均规则 > 5) { 返回 "规则适中" }
 返回 "规则精简"
}

函数 模糊_重置() { _模糊_推理次数 = 0
 _模糊_规则触发 = 0
}

函数 模糊_模糊度评估(隶属度) { 定义 可变 模糊计数 = 0
 定义 可变 i = 0
 当 (i < 计数(隶属度)) { 如果 (隶属度[i] > 200 且 隶属度[i] < 800) { 模糊计数 = 模糊计数 + 1 }
 i = i + 1
 }
 如果 (计数(隶属度) == 0) { 返回 0 }
 返回 模糊计数 * 100 / 计数(隶属度)
}

函数 模糊_锐度(隶属度) { 返回 1000 - 模糊_模糊度评估(隶属度)
}

// NovaOS内核 · KV缓存 — 觉醒理论·不可绕过的理论架构
// 原创理论: NovaKVCache — 自适应缓存体系
// §1 哈希表: 开放寻址+线性探测
//   哈希函数: h(k) = (k × 2654435761) % C (Knuth乘法散列)
//   冲突解决: 线性探测 idx = (h+i) mod C, i=0,1,...
//   平均探测距离: E[probe] = 1/(1-α) 其中 α=负载因子
// §2 多策略淘汰:
//   LRU: 淘汰最早时间戳条目, O(C)扫描
//   LFU: 淘汰最少访问次数条目
//   TTL: 生存时间过期自动失效
//   ARC近似: 结合近期访问+频率双维淘汰决策
// §3 Bloom过滤器:
//   快速否定查询: 如果Bloom返回“不存在”则确定不存在
//   避免无效探测, 降低未命中延迟
//   k=3哈希函数, m=2048位, 误判率≈(1-e^(-3n/2048))^3
// §4 命中率追踪:
//   EMA命中率: R_t = 0.9R_{t-1} + 0.1×hit_t (FP1024)
//   自适应策略: R<30%→扩容, R>90%→缩容以节省内存
// §5 内存压力自适应:
//   5级压力: 无/低/中/高/严重
//   压力≥中时自动缩小缓存, 压力严重时清空
// 四阶段AI演进: NovaKVCache是神经网络推理缓存的核心基础设施

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./整数转字符串.nova")

定义 KV_容量 = 512
定义 KV_空 = 0
定义 KV_占用 = 1
定义 KV_删除 = 2

结构 KV条目 {
    键哈希,
    值,
    状态,
    时间戳,
    TTL,
    访问次数,
}

定义 可变 KV表 = []
定义 可变 KV_计数 = 0
定义 可变 KV_命中 = 0
定义 可变 KV_未命中 = 0
定义 可变 KV_命中率EMA = 512
定义 可变 KV_时钟 = 0
定义 可变 KV_已初始化 = 假

函数 KV_初始化() {
    KV表 = []
    定义 可变 i = 0
    当 (i < KV_容量) {
        定义 条目 = KV条目 {}
        条目.状态 = KV_空
        追加(KV表, 条目)
        i = i + 1
    }
    KV_计数 = 0
    KV_命中 = 0
    KV_未命中 = 0
    KV_已初始化 = 真
    内核信息("KV缓存: " + 整数转字符串(KV_容量) + "槽 LRU淘汰+TTL过期+EMA命中率")
}

函数 KV_哈希(键) { 返回 (键 * 2654435761) % KV_容量 }

函数 KV_写入(键, 值, ttl) {
    如果 (!KV_已初始化) { 返回 }
    KV_时钟 = KV_时钟 + 1
    定义 哈希 = KV_哈希(键)
    定义 可变 i = 0
    当 (i < KV_容量) {
        定义 idx = (哈希 + i) % KV_容量
        如果 (KV表[idx].状态 == KV_空 || KV表[idx].状态 == KV_删除 || KV表[idx].键哈希 == 键) {
            如果 (KV表[idx].状态 == KV_空) { KV_计数 = KV_计数 + 1 }
            KV表[idx].键哈希 = 键
            KV表[idx].值 = 值
            KV表[idx].状态 = KV_占用
            KV表[idx].时间戳 = KV_时钟
            KV表[idx].TTL = ttl
            KV表[idx].访问次数 = 0
            返回
        }
        i = i + 1
    }
    // 满了→LRU淘汰
    KV_LRU淘汰()
    KV_写入(键, 值, ttl)
}

函数 KV_读取(键) {
    如果 (!KV_已初始化) { 返回 -1 }
    KV_时钟 = KV_时钟 + 1
    定义 哈希 = KV_哈希(键)
    定义 可变 i = 0
    当 (i < KV_容量) {
        定义 idx = (哈希 + i) % KV_容量
        如果 (KV表[idx].状态 == KV_空) { 跳出 }
        如果 (KV表[idx].状态 == KV_占用 && KV表[idx].键哈希 == 键) {
            // TTL检查
            如果 (KV表[idx].TTL > 0 && KV_时钟 - KV表[idx].时间戳 > KV表[idx].TTL) {
                KV表[idx].状态 = KV_删除
                KV_计数 = KV_计数 - 1
                KV_未命中 = KV_未命中 + 1
                KV_命中率EMA = KV_命中率EMA * 922 / 1024
                返回 -1
            }
            KV_命中 = KV_命中 + 1
            KV_命中率EMA = (KV_命中率EMA * 922 + 1024 * 102) / 1024
            KV表[idx].访问次数 = KV表[idx].访问次数 + 1
            KV表[idx].时间戳 = KV_时钟
            返回 KV表[idx].值
        }
        i = i + 1
    }
    KV_未命中 = KV_未命中 + 1
    KV_命中率EMA = KV_命中率EMA * 922 / 1024
    返回 -1
}

函数 KV_LRU淘汰() {
    定义 可变 最旧idx = -1
    定义 可变 最旧时间 = KV_时钟 + 1
    定义 可变 i = 0
    当 (i < KV_容量) {
        如果 (KV表[i].状态 == KV_占用 && KV表[i].时间戳 < 最旧时间) {
            最旧时间 = KV表[i].时间戳
            最旧idx = i
        }
        i = i + 1
    }
    如果 (最旧idx >= 0) {
        KV表[最旧idx].状态 = KV_删除
        KV_计数 = KV_计数 - 1
    }
}

函数 KV_命中率() { 返回 KV_命中率EMA * 100 / 1024 }
函数 KV_使用率() { 如果 (KV_容量 <= 0) { 返回 0 }; 返回 KV_计数 * 100 / KV_容量 }

// 删除 

函数 KV_删除(键) {
    如果 (!KV_已初始化) { 返回 假 }
    定义 哈希 = KV_哈希(键)
    定义 可变 i = 0
    当 (i < KV_容量) {
        定义 idx = (哈希 + i) % KV_容量
        如果 (KV表[idx].状态 == KV_空) { 返回 假 }
        如果 (KV表[idx].状态 == KV_占用 && KV表[idx].键哈希 == 键) {
            KV表[idx].状态 = KV_删除
            KV_计数 = KV_计数 - 1
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 KV_查询(键) {
    // 仅查询是否存在,不更新LRU时间戳
    如果 (!KV_已初始化) { 返回 假 }
    定义 哈希 = KV_哈希(键)
    定义 可变 i = 0
    当 (i < KV_容量) {
        定义 idx = (哈希 + i) % KV_容量
        如果 (KV表[idx].状态 == KV_空) { 返回 假 }
        如果 (KV表[idx].状态 == KV_占用 && KV表[idx].键哈希 == 键) {
            如果 (KV表[idx].TTL > 0 && KV_时钟 - KV表[idx].时间戳 > KV表[idx].TTL) {
                返回 假
            }
            返回 真
        }
        i = i + 1
    }
    返回 假
}

// 批量过期清理 

函数 KV_清理过期() {
    如果 (!KV_已初始化) { 返回 0 }
    定义 可变 清理数 = 0
    定义 可变 i = 0
    当 (i < KV_容量) {
        如果 (KV表[i].状态 == KV_占用 && KV表[i].TTL > 0) {
            如果 (KV_时钟 - KV表[i].时间戳 > KV表[i].TTL) {
                KV表[i].状态 = KV_删除
                KV_计数 = KV_计数 - 1
                清理数 = 清理数 + 1
            }
        }
        i = i + 1
    }
    返回 清理数
}

// 批量LFU淘汰 (最少使用频率淘汰)

函数 KV_LFU淘汰(淘汰数) {
    定义 可变 已淘汰 = 0
    当 (已淘汰 < 淘汰数 && KV_计数 > 0) {
        // 找到访问次数最低的条目
        定义 可变 最少idx = -1
        定义 可变 最少访问 = 0x7FFFFFFFFFFFFFFF
        定义 可变 i = 0
        当 (i < KV_容量) {
            如果 (KV表[i].状态 == KV_占用 && KV表[i].访问次数 < 最少访问) {
                最少访问 = KV表[i].访问次数
                最少idx = i
            }
            i = i + 1
        }
        如果 (最少idx >= 0) {
            KV表[最少idx].状态 = KV_删除
            KV_计数 = KV_计数 - 1
            已淘汰 = 已淘汰 + 1
        } 否则 { 中断 }
    }
    返回 已淘汰
}

// 重哈希 (负载因子过高时扩容)

函数 KV_需要重哈希() {
    // 负载因子超过75%时建议重哈希
    如果 (KV_容量 <= 0) { 返回 假 }
    返回 KV_计数 * 100 / KV_容量 > 75
}

函数 KV_清空() {
    定义 可变 i = 0
    当 (i < KV_容量) {
        KV表[i].状态 = KV_空
        KV表[i].访问次数 = 0
        i = i + 1
    }
    KV_计数 = 0
    KV_命中 = 0
    KV_未命中 = 0
    KV_命中率EMA = 512
    KV_时钟 = 0
}

// 统计和诊断

函数 KV_统计() {
    返回 [KV_计数, KV_容量, KV_命中, KV_未命中, KV_命中率(), KV_使用率()]
}

函数 KV_热点Top(N) {
    // 返回访问次数最高的N个条目
    定义 可变 结果 = []
    定义 可变 已选 = 0
    当 (已选 < N) {
        定义 可变 最多idx = -1
        定义 可变 最多访问 = -1
        定义 可变 i = 0
        当 (i < KV_容量) {
            如果 (KV表[i].状态 == KV_占用 && KV表[i].访问次数 > 最多访问) {
                // 检查是否已在结果中
                定义 可变 已有 = 假
                定义 可变 j = 0
                当 (j < 计数(结果)) {
                    如果 (结果[j][0] == KV表[i].键哈希) { 已有 = 真; 中断 }
                    j = j + 1
                }
                如果 (!已有) {
                    最多访问 = KV表[i].访问次数
                    最多idx = i
                }
            }
            i = i + 1
        }
        如果 (最多idx < 0) { 中断 }
        追加(结果, [KV表[最多idx].键哈希, KV表[最多idx].值, KV表[最多idx].访问次数])
        已选 = 已选 + 1
    }
    返回 结果
}

// Bloom过滤器 — 快速否定查询

定义 BLOOM_大小 = 256   // 256×64位 = 16384位
定义 可变 Bloom位数组 = []
定义 可变 Bloom_已初始化 = 假

函数 Bloom_初始化() {
    Bloom位数组 = []
    定义 可变 i = 0
    当 (i < BLOOM_大小) {
        追加(Bloom位数组, 0)
        i = i + 1
    }
    Bloom_已初始化 = 真
}

函数 Bloom_哈希1(键) { 返回 (键 * 2654435761) % (BLOOM_大小 * 64) }
函数 Bloom_哈希2(键) { 返回 (键 * 2246822519) % (BLOOM_大小 * 64) }
函数 Bloom_哈希3(键) { 返回 (键 * 3266489917) % (BLOOM_大小 * 64) }

函数 Bloom_设置位(位号) {
    定义 字索引 = 位号 / 64
    定义 位索引 = 位号 % 64
    定义 可变 mask = 1
    定义 可变 s = 0
    当 (s < 位索引) { mask = mask * 2; s = s + 1 }
    Bloom位数组[字索引] = Bloom位数组[字索引] | mask
}

函数 Bloom_检查位(位号) {
    定义 字索引 = 位号 / 64
    定义 位索引 = 位号 % 64
    定义 可变 mask = 1
    定义 可变 s = 0
    当 (s < 位索引) { mask = mask * 2; s = s + 1 }
    返回 (Bloom位数组[字索引] & mask) != 0
}

函数 Bloom_添加(键) {
    如果 (!Bloom_已初始化) { Bloom_初始化() }
    Bloom_设置位(Bloom_哈希1(键))
    Bloom_设置位(Bloom_哈希2(键))
    Bloom_设置位(Bloom_哈希3(键))
}

函数 Bloom_可能存在(键) {
    如果 (!Bloom_已初始化) { 返回 假 }
    返回 Bloom_检查位(Bloom_哈希1(键)) &&
           Bloom_检查位(Bloom_哈希2(键)) &&
           Bloom_检查位(Bloom_哈希3(键))
}

函数 Bloom_重置() {
    如果 (!Bloom_已初始化) { 返回 }
    定义 可变 i = 0
    当 (i < BLOOM_大小) {
        Bloom位数组[i] = 0
        i = i + 1
    }
}

// 批量操作

函数 KV_批量写入(键值对列表, ttl) {
    // 键值对列表: [[key1,val1], [key2,val2], ...]
    如果 (!KV_已初始化 || 键值对列表 == 0) { 返回 0 }
    定义 可变 成功 = 0
    定义 可变 i = 0
    当 (i < 计数(键值对列表)) {
        KV_写入(键值对列表[i][0], 键值对列表[i][1], ttl)
        成功 = 成功 + 1
        i = i + 1
    }
    返回 成功
}

函数 KV_批量读取(键列表) {
    如果 (!KV_已初始化 || 键列表 == 0) { 返回 [] }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        追加(结果, KV_读取(键列表[i]))
        i = i + 1
    }
    返回 结果
}

函数 KV_批量删除(键列表) {
    如果 (!KV_已初始化 || 键列表 == 0) { 返回 0 }
    定义 可变 删除数 = 0
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        如果 (KV_删除(键列表[i])) { 删除数 = 删除数 + 1 }
        i = i + 1
    }
    返回 删除数
}

// Bloom加速查询 — 先过滤再探测

函数 KV_快速读取(键) {
    // Bloom过滤器先行判断, 避免无效探测
    如果 (!KV_已初始化) { 返回 -1 }
    如果 (Bloom_已初始化 && !Bloom_可能存在(键)) {
        KV_未命中 = KV_未命中 + 1
        KV_命中率EMA = KV_命中率EMA * 922 / 1024
        返回 -1
    }
    返回 KV_读取(键)
}

// TTL刷新 — 延长已有条目的生存时间

函数 KV_刷新TTL(键, 新ttl) {
    如果 (!KV_已初始化) { 返回 假 }
    定义 哈希 = KV_哈希(键)
    定义 可变 i = 0
    当 (i < KV_容量) {
        定义 idx = (哈希 + i) % KV_容量
        如果 (KV表[idx].状态 == KV_空) { 返回 假 }
        如果 (KV表[idx].状态 == KV_占用 && KV表[idx].键哈希 == 键) {
            KV表[idx].TTL = 新ttl
            KV表[idx].时间戳 = KV_时钟
            返回 真
        }
        i = i + 1
    }
    返回 假
}

// ARC近似淘汰 — 双维度淘汰决策

函数 KV_ARC淘汰() {
    // 结合LRU和LFU的双维淘汰
    // 分数 = 访问次数分(0-500) + 近期度分(0-500)
    // 近期度分 = (timestamp / max_timestamp) × 500
    如果 (!KV_已初始化 || KV_计数 == 0) { 返回 }
    定义 可变 最低分 = 0x7FFFFFFFFFFFFFFF
    定义 可变 最低idx = -1
    // 找最大访问次数用于归一化
    定义 可变 最大访问 = 1
    定义 可变 i = 0
    当 (i < KV_容量) {
        如果 (KV表[i].状态 == KV_占用 && KV表[i].访问次数 > 最大访问) {
            最大访问 = KV表[i].访问次数
        }
        i = i + 1
    }
    i = 0
    当 (i < KV_容量) {
        如果 (KV表[i].状态 == KV_占用) {
            // 访问频率分 (0-500)
            定义 频率分 = KV表[i].访问次数 * 500 / 最大访问
            // 近期度分 (0-500)
            定义 近期分 = 0
            如果 (KV_时钟 > 0) {
                近期分 = KV表[i].时间戳 * 500 / KV_时钟
            }
            定义 总分 = 频率分 + 近期分
            如果 (总分 < 最低分) {
                最低分 = 总分
                最低idx = i
            }
        }
        i = i + 1
    }
    如果 (最低idx >= 0) {
        KV表[最低idx].状态 = KV_删除
        KV_计数 = KV_计数 - 1
    }
}

// 内存压力自适应

定义 压力_无 = 0
定义 压力_低 = 1
定义 压力_中 = 2
定义 压力_高 = 3
定义 压力_严重 = 4
定义 可变 KV_当前压力 = 0

函数 KV_设置压力(压力级别) {
    KV_当前压力 = 压力级别
    如果 (压力级别 == 压力_严重) {
        // 严重压力: 清空缓存
        KV_清空()
        内核警告("KV缓存: 内存压力严重, 已清空全部缓存")
    } 否则 如果 (压力级别 == 压力_高) {
        // 高压力: 淘汰一半
        定义 目标 = KV_计数 / 2
        当 (KV_计数 > 目标) {
            KV_ARC淘汰()
        }
    } 否则 如果 (压力级别 == 压力_中) {
        // 中压力: 淘汰25%
        定义 目标 = KV_计数 * 75 / 100
        当 (KV_计数 > 目标) {
            KV_ARC淘汰()
        }
    }
}

// 探测距离统计

定义 可变 KV_总探测距离 = 0
定义 可变 KV_探测次数 = 0
定义 可变 KV_最大探测距离 = 0

函数 KV_记录探测(距离) {
    KV_总探测距离 = KV_总探测距离 + 距离
    KV_探测次数 = KV_探测次数 + 1
    如果 (距离 > KV_最大探测距离) { KV_最大探测距离 = 距离 }
}

函数 KV_平均探测距离() {
    如果 (KV_探测次数 == 0) { 返回 0 }
    返回 KV_总探测距离 * 1000 / KV_探测次数
}

// 缓存预热

函数 KV_预热(键值对列表, ttl) {
    // 批量加载常用数据到缓存
    如果 (!KV_已初始化) { KV_初始化() }
    定义 可变 加载数 = 0
    定义 可变 i = 0
    当 (i < 计数(键值对列表)) {
        如果 (KV_计数 >= KV_容量 * 90 / 100) {
            i = 计数(键值对列表)  // 停止加载, 留充裕空间
        } 否则 {
            KV_写入(键值对列表[i][0], 键值对列表[i][1], ttl)
            加载数 = 加载数 + 1
        }
        i = i + 1
    }
    返回 加载数
}

// 完整诊断统计

函数 KV_完整统计() {
    定义 负载因子 = 0
    如果 (KV_容量 > 0) { 负载因子 = KV_计数 * 1000 / KV_容量 }
    返回 {
        容量: KV_容量,
        计数: KV_计数,
        负载因子: 负载因子,
        命中: KV_命中,
        未命中: KV_未命中,
        命中率EMA: KV_命中率EMA * 100 / 1024,
        命中率精确: KV_命中率(),
        使用率: KV_使用率(),
        平均探测: KV_平均探测距离(),
        最大探测: KV_最大探测距离,
        压力级别: KV_当前压力,
        时钟: KV_时钟,
        Bloom已启用: Bloom_已初始化
    }
}

函数 KV_健康检查() {
    // 返回健康状态: 0=健康, 1=警告, 2=危险
    如果 (!KV_已初始化) { 返回 2 }
    定义 负载 = KV_使用率()
    定义 命中 = KV_命中率()
    如果 (负载 > 90 || 命中 < 20) { 返回 2 }
    如果 (负载 > 75 || 命中 < 40) { 返回 1 }
    返回 0
}

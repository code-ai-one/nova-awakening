// Windows NT API (通过IAT调用)
定义 窗口_标准输入 = 0 - 10 // -10 = STD_INPUT_HANDLE
定义 窗口_标准输出 = 0 - 11 // -11 = STD_OUTPUT_HANDLE
定义 窗口_标准错误 = 0 - 12 // -12 = STD_ERROR_HANDLE

// CreateFile标志
定义 窗口_通用读 = 0x80000000
定义 窗口_通用写 = 0x40000000
定义 窗口_文件共享读 = 0x00000001
定义 窗口_总是创建 = 2
定义 窗口_打开已有 = 3
定义 窗口_创建新 = 1


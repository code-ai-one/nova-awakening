导入("../基础.nova")


// 内容过滤
定义 可变 黑名单 = []
定义 可变 白名单 = []

函数 过滤_添加黑名单(词哈希) { 追加(黑名单, 词哈希) }
函数 过滤_添加白名单(词哈希) { 追加(白名单, 词哈希) }
函数 过滤_清空() { 黑名单 = []
白名单 = [] }

函数 过滤_检查(token列表) { 定义 可变 违规 = 0
 定义 可变 i = 0
 当 (i < 计数(token列表)) { 定义 可变 j = 0
 当 (j < 计数(黑名单)) { 如果 (token列表[i] == 黑名单[j]) { 违规 = 违规 + 1 }
 j = j + 1
 }
 i = i + 1
 }
 返回 违规
}

函数 过滤_替换(token列表, 替换token) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(token列表)) { 定义 可变 是黑 = 假
 定义 可变 j = 0
 当 (j < 计数(黑名单)) { 如果 (token列表[i] == 黑名单[j]) { 是黑 = 真 }
 j = j + 1
 }
 如果 (是黑) { 追加(结果, 替换token) }
 否则 { 追加(结果, token列表[i]) }
 i = i + 1
 }
 返回 结果
}

// AI水印
定义 水印_密钥 = 12345
定义 可变 水印_强度 = 10

函数 水印_嵌入(对数值, 步数) { 定义 可变 结果 = []
 定义 hash = (步数 * 水印_密钥 + 7919) % 计数(对数值)
 定义 可变 i = 0
 当 (i < 计数(对数值)) { 如果 (i == hash) { 追加(结果, 对数值[i] + 水印_强度) }
 否则 { 追加(结果, 对数值[i]) }
 i = i + 1
 }
 返回 结果
}

函数 水印_检测(token列表, 词表大小) { 定义 可变 命中 = 0
 定义 可变 i = 0
 当 (i < 计数(token列表)) { 定义 预期 = (i * 水印_密钥 + 7919) % 词表大小
 如果 (token列表[i] == 预期) { 命中 = 命中 + 1 }
 i = i + 1
 }
 如果 (计数(token列表) == 0) { 返回 0 }
 返回 命中 * 100 / 计数(token列表)
}

// 对齐检查
定义 可变 对齐_规则 = []
定义 可变 对齐_阈值 = []

函数 对齐_添加规则(规则哈希, 阈值) {
 追加(对齐_规则, 规则哈希)
 追加(对齐_阈值, 阈值)
}

函数 对齐_清空() { 对齐_规则 = []
对齐_阈值 = [] }

函数 对齐_评分(规则分数列表) { 定义 可变 通过r = 0
 定义 可变 i = 0
 当 (i < 计数(对齐_规则) 且 i < 计数(规则分数列表)) { 如果 (规则分数列表[i] >= 对齐_阈值[i]) { 通过r = 通过r + 1 }
 i = i + 1
 }
 如果 (计数(对齐_规则) == 0) { 返回 100 }
 返回 通过r * 100 / 计数(对齐_规则)
}

// 毒性分数 (简化)
函数 毒性_评分(特征列表, 毒性权重) { 定义 可变 得分 = 0
 定义 可变 i = 0
 当 (i < 计数(特征列表) 且 i < 计数(毒性权重)) {
 得分 = 得分 + 特征列表[i] * 毒性权重[i] / 100
 i = i + 1
 }
 如果 (得分 < 0) { 得分 = 0 }
 如果 (得分 > 100) { 得分 = 100 }
 返回 得分
}

// 安全护栏
定义 可变 护栏_最大长度 = 4096
定义 可变 护栏_最大毒性 = 30

函数 护栏_检查(长度, 毒性) {
    如果 (长度 > 护栏_最大长度) { 返回 1
}
 如果 (毒性 > 护栏_最大毒性) { 返回 2 }
 返回 0
}

// 偏见检测
函数 偏见_检测(分组分数列表) {
 // 检查各组分数差异，返回最大差异
 如果 (计数(分组分数列表) < 2) { 返回 0 }
 定义 可变 max_diff = 0
 定义 可变 i = 0
 当 (i < 计数(分组分数列表)) { 定义 可变 j = i + 1
 当 (j < 计数(分组分数列表)) { 定义 可变 d = 分组分数列表[i] - 分组分数列表[j]
 如果 (d < 0) { d = 0 - d }
 如果 (d > max_diff) { max_diff = d }
 j = j + 1
 }
 i = i + 1
 }
 返回 max_diff
}

// 输出截断
函数 安全_截断(token列表, 最大长度) {
    如果 (计数(token列表) <= 最大长度) { 返回 token列表
}
 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 最大长度) { 追加(r, token列表[i])
 i = i + 1 }
 返回 r
}

// 注入检测
函数 注入_检测(token列表, 危险模式列表) {
 // 检查token序列中是否包含危险模式(连续子序列)
 定义 可变 i = 0
 当 (i < 计数(危险模式列表)) { 定义 模式 = 危险模式列表[i]
 定义 可变 位置 = 0
 当 (位置 <= 计数(token列表) - 计数(模式)) { 定义 可变 match = 真
 定义 可变 k = 0
 当 (k < 计数(模式)) { 如果 (token列表[位置 + k] != 模式[k]) { match = 假 }
 k = k + 1
 }
 如果 (match) { 返回 真 }
 位置 = 位置 + 1
 }
 i = i + 1
 }
 返回 假
}

// 对抗样本检测
函数 对抗检测_L2扰动(原始, 扰动) { 定义 可变 距离平方 = 0
 定义 可变 i = 0
 当 (i < 计数(原始)) { 定义 差值 = 原始[i] - 扰动[i]
 距离平方 = 距离平方 + 差值 * 差值
 i = i + 1
 }
 返回 距离平方
}

函数 对抗检测_Linf扰动(原始, 扰动) { 定义 可变 最大 = 0
 定义 可变 i = 0
 当 (i < 计数(原始)) { 定义 差值 = 原始[i] - 扰动[i]
 如果 (差值 < 0) { 差值 = 0 - 差值 }
 如果 (差值 > 最大) { 最大 = 差值 }
 i = i + 1
 }
 返回 最大
}

函数 对抗检测_是否可疑(原始, 扰动, L2阈值, Linf阈值) {
    如果 (对抗检测_L2扰动(原始, 扰动) > L2阈值) { 返回 真
}
 如果 (对抗检测_Linf扰动(原始, 扰动) > Linf阈值) { 返回 真 }
 返回 假
}

// 输出过滤
定义 可变 _输出_黑名单 = []

函数 输出过滤_添加规则(模式) {
 追加(_输出_黑名单, 模式)
}

函数 输出过滤_检查(输出文本, 词列表) { 定义 可变 i = 0
 当 (i < 计数(_输出_黑名单)) { 定义 可变 j = 0
 当 (j < 计数(词列表)) { 如果 (词列表[j] == _输出_黑名单[i]) { 返回 真 }
 j = j + 1
 }
 i = i + 1
 }
 返回 假
}

// 输出置信度校验
函数 置信度_过高检测(分数列表, 阈值) { 定义 可变 最大 = 0
 定义 可变 i = 0
 当 (i < 计数(分数列表)) { 如果 (分数列表[i] > 最大) { 最大 = 分数列表[i] }
 i = i + 1
 }
 返回 最大 > 阈值
}

函数 置信度_熵(分数列表) { 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 计数(分数列表)) { 总 = 总 + 分数列表[i] i = i + 1 }
 如果 (总 == 0) { 返回 0 }
 定义 可变 熵 = 0
 i = 0
 当 (i < 计数(分数列表)) { 定义 p = 分数列表[i] * 1000 / 总
 如果 (p > 0) { 熵 = 熵 + p * p / 1000 }
 i = i + 1
 }
 返回 1000 - 熵
}

// 安全审计日志
定义 可变 AI安全__审计日志 = []

函数 审计_记录(事件类型, 详情, 严重度) {
 追加(AI安全__审计日志, [事件类型, 详情, 严重度, 计数(AI安全__审计日志)])
}

函数 审计_查询(严重度下限) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(AI安全__审计日志)) { 如果 (AI安全__审计日志[i][2] >= 严重度下限) { 追加(结果, AI安全__审计日志[i]) }
 i = i + 1
 }
 返回 结果
}

函数 审计_清空() { AI安全__审计日志 = [] }
函数 审计_数量() { 返回 计数(AI安全__审计日志) }

// 差分隐私
函数 差分隐私_加噪声(值, 灵敏度, epsilon_倒数) { 定义 噪声范围 = 灵敏度 * epsilon_倒数
 定义 噪声 = (计数(AI安全__审计日志) * 37 + 值) % (噪声范围 * 2 + 1) - 噪声范围
 返回 值 + 噪声
}

函数 差分隐私_批量加噪(数据列表, 灵敏度, epsilon_倒数) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(数据列表)) {
 追加(结果, 差分隐私_加噪声(数据列表[i], 灵敏度, epsilon_倒数))
 i = i + 1
 }
 返回 结果
}

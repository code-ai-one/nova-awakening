导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")

定义 纹理预算_默认 = 134217728
定义 纹理预算_低内存 = 67108864
定义 LRU_最大条目 = 512
定义 瓦片_默认大小 = 256

结构 纹理LRU条目 {
    瓦片指针,
    层索引,
    瓦片索引,
    大小,
    上次使用帧,
    优先级,
}

结构 纹理管理器 {
    LRU列表,
    LRU数量,
    内存预算,
    当前使用,
    当前帧,
    清理次数,
    释放总量,
}

定义 可变 纹理管理 = 0


函数 AI合成_初始化纹理管理(预算) {
    纹理管理 = 堆_分配(纹理管理器)
    纹理管理.LRU列表 = []
    纹理管理.LRU数量 = 0
    如果 (预算 > 0) { 纹理管理.内存预算 = 预算 }
    否则 { 纹理管理.内存预算 = 纹理预算_默认 }
    纹理管理.当前使用 = 0
    纹理管理.当前帧 = 0
    纹理管理.清理次数 = 0
    纹理管理.释放总量 = 0
}

函数 AI合成_记录瓦片使用(瓦片, 层索引, 瓦片索引, 大小) {
    如果 (纹理管理 == 0) { 返回 }

    定义 可变 i = 0
    当 (i < 纹理管理.LRU数量) {
        如果 (纹理管理.LRU列表[i].瓦片指针 == 瓦片) {
            纹理管理.LRU列表[i].上次使用帧 = 纹理管理.当前帧
            返回
        }
        i = i + 1
    }

    如果 (纹理管理.LRU数量 >= LRU_最大条目) { 返回 }

    定义 条目 = 纹理LRU条目 {}
    条目.瓦片指针 = 瓦片
    条目.层索引 = 层索引
    条目.瓦片索引 = 瓦片索引
    条目.大小 = 大小
    条目.上次使用帧 = 纹理管理.当前帧
    条目.优先级 = 0
    追加(纹理管理.LRU列表, 条目)
    纹理管理.LRU数量 = 纹理管理.LRU数量 + 1
    纹理管理.当前使用 = 纹理管理.当前使用 + 大小
}

函数 AI合成_LRU驱逐(目标释放) {
    如果 (纹理管理 == 0 || 纹理管理.LRU数量 == 0) { 返回 0 }

    定义 可变 已释放 = 0

    当 (已释放 < 目标释放 && 纹理管理.LRU数量 > 0) {
        定义 可变 最旧索引 = 0
        定义 可变 最旧帧 = 纹理管理.LRU列表[0].上次使用帧
        定义 可变 最低优先 = 纹理管理.LRU列表[0].优先级

        定义 可变 i = 1
        当 (i < 纹理管理.LRU数量) {
            定义 条目 = 纹理管理.LRU列表[i]
            如果 (条目.优先级 < 最低优先 || (条目.优先级 == 最低优先 && 条目.上次使用帧 < 最旧帧)) {
                最旧索引 = i
                最旧帧 = 条目.上次使用帧
                最低优先 = 条目.优先级
            }
            i = i + 1
        }

        定义 驱逐 = 纹理管理.LRU列表[最旧索引]
        如果 (驱逐.瓦片指针 != 0 && 驱逐.瓦片指针.像素数据 != 0) {
            堆_释放(驱逐.瓦片指针.像素数据)
            驱逐.瓦片指针.像素数据 = 0
            驱逐.瓦片指针.需要光栅化 = 真
            已释放 = 已释放 + 驱逐.大小
        }

        列表_移除(纹理管理.LRU列表, 最旧索引)
        纹理管理.LRU数量 = 纹理管理.LRU数量 - 1
    }

    纹理管理.当前使用 = 纹理管理.当前使用 - 已释放
    纹理管理.释放总量 = 纹理管理.释放总量 + 已释放
    返回 已释放
}

函数 AI合成_检查内存预算() {
    如果 (纹理管理 == 0) { 返回 }
    如果 (纹理管理.当前使用 > 纹理管理.内存预算) {
        定义 超出 = 纹理管理.当前使用 - 纹理管理.内存预算
        定义 目标 = 超出 + 纹理管理.内存预算 / 10
        AI合成_LRU驱逐(目标)
        纹理管理.清理次数 = 纹理管理.清理次数 + 1
    }
}

函数 AI合成_清理不可见纹理(lth) {
    如果 (lth == 0) { 返回 }
    定义 可变 i = 0
    当 (i < lth.层数量) {
        定义 cl = 内存_读64(lth.层列表 + i * 8)
        如果 (cl != 0 && cl.绘制层 != 0) {
            定义 pl = cl.绘制层
            如果 (pl.视口可见 == 0) {
                定义 总瓦片 = cl.瓦片列数 * cl.瓦片行数
                定义 可变 j = 0
                当 (j < 总瓦片) {
                    定义 tile = 内存_读64(cl.瓦片列表 + j * 8)
                    如果 (tile != 0 && tile.像素数据 != 0) {
                        定义 大小 = tile.宽 * tile.高 * 4
                        堆_释放(tile.像素数据)
                        tile.像素数据 = 0
                        tile.需要光栅化 = 真
                        如果 (AI合成全局统计 != 0) {
                            AI合成全局统计.纹理内存使用 = AI合成全局统计.纹理内存使用 - 大小
                            AI合成全局统计.AI释放纹理次数 = AI合成全局统计.AI释放纹理次数 + 1
                        }
                        如果 (纹理管理 != 0) {
                            纹理管理.当前使用 = 纹理管理.当前使用 - 大小
                            纹理管理.释放总量 = 纹理管理.释放总量 + 大小
                        }
                    }
                    j = j + 1
                }
            }
        }
        i = i + 1
    }
}

函数 AI合成_清理低优先级瓦片(lth, 优先级阈值) {
    如果 (lth == 0) { 返回 0 }
    定义 可变 释放量 = 0
    定义 可变 i = 0
    当 (i < lth.层数量) {
        定义 cl = 内存_读64(lth.层列表 + i * 8)
        如果 (cl != 0) {
            定义 总瓦片 = cl.瓦片列数 * cl.瓦片行数
            定义 可变 j = 0
            当 (j < 总瓦片) {
                定义 tile = 内存_读64(cl.瓦片列表 + j * 8)
                如果 (tile != 0 && tile.像素数据 != 0 && tile.优先级 < 优先级阈值) {
                    定义 大小 = tile.宽 * tile.高 * 4
                    堆_释放(tile.像素数据)
                    tile.像素数据 = 0
                    tile.需要光栅化 = 真
                    释放量 = 释放量 + 大小
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    返回 释放量
}

函数 AI合成_调整瓦片优先级(lth) {
    如果 (lth == 0) { 返回 }
    定义 可变 i = 0
    当 (i < lth.层数量) {
        定义 cl = 内存_读64(lth.层列表 + i * 8)
        如果 (cl != 0 && cl.绘制层 != 0) {
            定义 pl = cl.绘制层
            定义 可变 基础优先级 = 1000
            如果 (pl.视口可见 == 2) { 基础优先级 = 基础优先级 + 5000 }
            否则 如果 (pl.视口可见 == 1) { 基础优先级 = 基础优先级 + 3000 }
            基础优先级 = 基础优先级 + pl.注意力权重 / 2

            如果 (pl.正在动画) { 基础优先级 = 基础优先级 + 2000 }
            如果 (pl.是视频层) { 基础优先级 = 基础优先级 + 1500 }

            定义 总瓦片 = cl.瓦片列数 * cl.瓦片行数
            定义 可变 j = 0
            当 (j < 总瓦片) {
                定义 tile = 内存_读64(cl.瓦片列表 + j * 8)
                如果 (tile != 0) { tile.优先级 = 基础优先级 }
                j = j + 1
            }
        }
        i = i + 1
    }
}

函数 AI合成_预测即将可见(lth, 滚动方向, 滚动速度) {
    如果 (lth == 0 || 纹理管理 == 0) { 返回 }
    定义 预测距离 = 滚动速度 * 3

    定义 可变 i = 0
    当 (i < lth.层数量) {
        定义 cl = 内存_读64(lth.层列表 + i * 8)
        如果 (cl != 0 && cl.绘制层 != 0) {
            定义 pl = cl.绘制层
            如果 (pl.视口可见 == 0) {
                定义 距视口 = pl.到视口距离
                如果 (距视口 > 0 && 距视口 < 预测距离) {
                    定义 总瓦片 = cl.瓦片列数 * cl.瓦片行数
                    定义 可变 j = 0
                    当 (j < 总瓦片) {
                        定义 tile = 内存_读64(cl.瓦片列表 + j * 8)
                        如果 (tile != 0) {
                            tile.优先级 = tile.优先级 + 2000
                        }
                        j = j + 1
                    }
                }
            }
        }
        i = i + 1
    }
}

函数 AI合成_帧结束() {
    如果 (纹理管理 != 0) {
        纹理管理.当前帧 = 纹理管理.当前帧 + 1
        AI合成_检查内存预算()
    }
}

函数 AI合成_纹理统计() {
    如果 (纹理管理 == 0) { 返回 0 }
    返回 {
        当前使用: 纹理管理.当前使用,
        内存预算: 纹理管理.内存预算,
        LRU条目数: 纹理管理.LRU数量,
        清理次数: 纹理管理.清理次数,
        释放总量: 纹理管理.释放总量,
        使用率: 纹理管理.内存预算 > 0 ? 纹理管理.当前使用 * 100 / 纹理管理.内存预算 : 0
    }
}

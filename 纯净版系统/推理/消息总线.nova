导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/自动扩容.nova")
导入("../标准/原生列表.nova")
导入("../中枢/高精定器添.nova")
导入("../中枢/整数转字符串.nova")

定义 最大队列容量 = 4096
定义 最大历史容量 = 100
定义 最大死信容量 = 50
定义 最大中间件数 = 16

定义 可变 消息总线_订阅表 = 字典()
定义 可变 消息总线_通配订阅 = []
定义 可变 消息总线_队列 = []
定义 可变 消息总线_历史 = []
定义 可变 消息总线_死信 = []
定义 可变 消息总线_中间件 = []
定义 可变 消息总线_过滤器 = 字典()
定义 可变 消息总线_总发布 = 0
定义 可变 消息总线_总投递 = 0
定义 可变 消息总线_总丢弃 = 0
定义 可变 消息总线_总死信 = 0
定义 可变 消息总线_暂停 = 假

函数 消息总线_初始化() {
    消息总线_订阅表 = 字典()
    消息总线_通配订阅 = []
    消息总线_队列 = []
    消息总线_历史 = []
    消息总线_死信 = []
    消息总线_中间件 = []
    消息总线_过滤器 = 字典()
    消息总线_总发布 = 0
    消息总线_总投递 = 0
    消息总线_总丢弃 = 0
    消息总线_总死信 = 0
    消息总线_暂停 = 假
    返回 成功
}

函数 消息总线_订阅(主题, 回调) {
    定义 列表 = 字典取(消息总线_订阅表, 主题)
    如果 (列表 == 空) { 列表 = [] }
    追加(列表, 回调)
    字典设(消息总线_订阅表, 主题, 列表)
}

函数 消息总线_通配订阅(前缀, 回调) {
    追加(消息总线_通配订阅, [前缀, 回调])
}

函数 消息总线_取消订阅(主题, 回调) {
    定义 列表 = 字典取(消息总线_订阅表, 主题)
    如果 (列表 == 空) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] == 回调) {
            列表 = 列表_删除(列表, i)
            字典设(消息总线_订阅表, 主题, 列表)
            返回
        }
        i = i + 1
    }
}

函数 消息总线_添加中间件(中间件函数) {
    如果 (计数(消息总线_中间件) >= 最大中间件数) { 返回 }
    追加(消息总线_中间件, 中间件函数)
}

函数 消息总线_设置过滤器(主题, 过滤函数) {
    字典设(消息总线_过滤器, 主题, 过滤函数)
}

函数 消息总线_执行中间件(主题, 数据) {
    定义 可变 当前数据 = 数据
    定义 可变 i = 0
    当 (i < 计数(消息总线_中间件)) {
        定义 结果 = 消息总线_中间件[i](主题, 当前数据)
        如果 (结果 == 空) { 返回 空 }
        当前数据 = 结果
        i = i + 1
    }
    返回 当前数据
}

函数 消息总线_发布(主题, 数据) {
    如果 (消息总线_暂停) {
        追加(消息总线_队列, [主题, 数据])
        返回
    }
    消息总线_总发布 = 消息总线_总发布 + 1

    定义 处理数据 = 消息总线_执行中间件(主题, 数据)
    如果 (处理数据 == 空) { 消息总线_总丢弃 = 消息总线_总丢弃 + 1; 返回 }

    定义 过滤器 = 字典取(消息总线_过滤器, 主题)
    如果 (过滤器 != 空 && !过滤器(处理数据)) {
        消息总线_总丢弃 = 消息总线_总丢弃 + 1
        返回
    }

    定义 可变 已投递 = 假
    定义 订阅者 = 字典取(消息总线_订阅表, 主题)
    如果 (订阅者 != 空) {
        定义 可变 i = 0
        当 (i < 计数(订阅者)) {
            订阅者[i](主题, 处理数据)
            消息总线_总投递 = 消息总线_总投递 + 1
            已投递 = 真
            i = i + 1
        }
    }

    定义 可变 w = 0
    当 (w < 计数(消息总线_通配订阅)) {
        定义 前缀 = 消息总线_通配订阅[w][0]
        如果 (字符串_以开头(主题, 前缀)) {
            消息总线_通配订阅[w][1](主题, 处理数据)
            消息总线_总投递 = 消息总线_总投递 + 1
            已投递 = 真
        }
        w = w + 1
    }

    如果 (!已投递) {
        消息总线_添加死信(主题, 处理数据)
    }

    消息总线_记录历史(主题, 处理数据)
}

函数 消息总线_异步发布(主题, 数据) {
    如果 (计数(消息总线_队列) >= 最大队列容量) {
        消息总线_添加死信(主题, 数据)
        返回
    }
    追加(消息总线_队列, [主题, 数据])
}

函数 消息总线_处理队列() {
    定义 可变 处理数 = 0
    当 (计数(消息总线_队列) > 0 && 处理数 < 64) {
        定义 消息 = 消息总线_队列[0]
        消息总线_队列 = 列表_切片(消息总线_队列, 1, 计数(消息总线_队列))
        消息总线_发布(消息[0], 消息[1])
        处理数 = 处理数 + 1
    }
    返回 处理数
}

函数 消息总线_记录历史(主题, 数据) {
    追加(消息总线_历史, [获取滴答(), 主题, 数据])
    如果 (计数(消息总线_历史) > 最大历史容量) {
        消息总线_历史 = 列表_切片(消息总线_历史, 计数(消息总线_历史) - 最大历史容量, 计数(消息总线_历史))
    }
}

函数 消息总线_添加死信(主题, 数据) {
    消息总线_总死信 = 消息总线_总死信 + 1
    追加(消息总线_死信, [获取滴答(), 主题, 数据])
    如果 (计数(消息总线_死信) > 最大死信容量) {
        消息总线_死信 = 列表_切片(消息总线_死信, 1, 计数(消息总线_死信))
    }
}

函数 消息总线_重放死信() {
    定义 待重放 = 消息总线_死信
    消息总线_死信 = []
    定义 可变 i = 0
    当 (i < 计数(待重放)) {
        消息总线_发布(待重放[i][1], 待重放[i][2])
        i = i + 1
    }
}

函数 消息总线_暂停() { 消息总线_暂停 = 真 }
函数 消息总线_恢复() { 消息总线_暂停 = 假; 消息总线_处理队列() }

函数 消息总线_查询历史(主题, 数量) {
    定义 可变 结果 = []
    定义 可变 i = 计数(消息总线_历史) - 1
    当 (i >= 0 && 计数(结果) < 数量) {
        如果 (消息总线_历史[i][1] == 主题) { 追加(结果, 消息总线_历史[i]) }
        i = i - 1
    }
    返回 结果
}

函数 消息总线_状态() {
    返回 "发布:" + 整数转字符串(消息总线_总发布) + " 投递:" + 整数转字符串(消息总线_总投递) + " 队列:" + 整数转字符串(计数(消息总线_队列)) + " 死信:" + 整数转字符串(消息总线_总死信)
}

函数 消息总线_统计() {
    返回 [消息总线_总发布, 消息总线_总投递, 计数(消息总线_队列), 消息总线_总丢弃, 消息总线_总死信]
}

函数 消息总线_健康评估() {
    定义 可变 问题 = []
    如果 (计数(消息总线_通配订阅) > 10000) { 追加(问题, "消息总线_通配订阅膨胀") }
    如果 (计数(消息总线_队列) > 10000) { 追加(问题, "消息总线_队列膨胀") }
    如果 (计数(消息总线_历史) > 10000) { 追加(问题, "消息总线_历史膨胀") }
    如果 (计数(消息总线_死信) > 10000) { 追加(问题, "消息总线_死信膨胀") }
    如果 (计数(消息总线_中间件) > 10000) { 追加(问题, "消息总线_中间件膨胀") }
    返回 计数(问题) == 0
}

函数 消息总线_综合报告() {
    打印("[消息总线] ═══ 综合报告 ═══")
    打印("  消息总线_队列: " + 消息总线_队列)
    打印("  消息总线_总发布: " + 消息总线_总发布)
    打印("  消息总线_总投递: " + 消息总线_总投递)
    打印("  消息总线_总丢弃: " + 消息总线_总丢弃)
    打印("  消息总线_总死信: " + 消息总线_总死信)
    打印("  健康: " + 如果 (消息总线_健康评估()) { "正常" } 否则 { "异常" })
}

函数 消息总线_全局重置() {
    消息总线_队列 = []
    消息总线_总发布 = 0
    消息总线_总投递 = 0
    消息总线_总丢弃 = 0
    消息总线_总死信 = 0
    打印("[消息总线] 统计已重置")
    返回 0
}

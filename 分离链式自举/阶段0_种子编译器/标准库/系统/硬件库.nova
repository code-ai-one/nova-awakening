// 第五章: 窗口操作

// 查找窗口
函数 查找窗口(标题) { _初始化用户()
 如果 (_函数_查找窗口 == 0) { _函数_查找窗口 = 获取函数(_用户32库, "FindWindowA") }
 返回 调用指针(_函数_查找窗口,  0,  标题, 0, 0, 0)
}

// 显示消息框
函数 消息框(文本, 标题, _类型) { _初始化用户()
 如果 (_函数_消息框 == 0) { _函数_消息框 = 获取函数(_用户32库, "MessageBoxA") }
 返回 调用指针(_函数_消息框,  0,  文本,  标题, 0, 0)
}

// 消息框类型常量
定义 消息_确定 = 0
定义 消息_确定取消 = 1
定义 消息_是否 = 4
定义 消息_是否取消 = 3

// 消息框返回值
定义 返回_确定 = 1
定义 返回_取消 = 2
定义 返回_是 = 6
定义 返回_否 = 7

// 第六章: 文件系统

// 检查文件是否存在
函数 文件存在(路径) { _初始化内核()
 如果 (_函数_获取文件属性 == 0) { _函数_获取文件属性 = 获取函数(_内核32库, "GetFileAttributesA") }
 定义 r = 调用指针(_函数_获取文件属性,  路径, 0, 0, 0, 0)
 如果 (r == 0 - 1) { 返回 0 }
 返回 1
}

// 删除文件
函数 删除文件(路径) { _初始化内核()
 如果 (_函数_删除文件 == 0) { _函数_删除文件 = 获取函数(_内核32库, "DeleteFileA") }
 返回 调用指针(_函数_删除文件,  路径, 0, 0, 0, 0)
}

// 移动/重命名文件
函数 移动文件(源, 目标) { _初始化内核()
 如果 (_函数_移动文件 == 0) { _函数_移动文件 = 获取函数(_内核32库, "MoveFileA") }
 返回 调用指针(_函数_移动文件,  源,  目标, 0, 0, 0)
}

// 第七章: 实用工具

// 简单伪随机数 (基于时间戳的线性同余)
定义 可变 _随机种子 = 0
函数 随机数(最大值) {
    如果 (_随机种子 == 0) { _随机种子 = 时间戳()
}
 _随机种子 = _随机种子 * 1103515245 + 12345
 // 取低31位的正数
 定义 r = (_随机种子 >> 16) & 0x7FFF
 如果 (最大值 > 0) { 返回 r - (r / 最大值) * 最大值 }
 返回 r
}

// 设置随机种子
函数 随机种子(种子) { _随机种子 = 种子 }

// 计时器 — 测量代码执行时间
函数 开始计时() { 返回 时间戳() }

函数 结束计时(开始) { 定义 结束 = 时间戳()
 返回 结束 - 开始
}

// 第八章: 内存与缓冲区工具

// 创建指定大小的零初始化内存块
函数 缓冲清零(块, 大小) {
 如果 (块 == 空 或 大小 <= 0) { 返回 块 }
 定义 可变 上限 = 大小
 如果 (计数(块) < 上限) { 上限 = 计数(块) }
 定义 可变 i = 0
 当 (i < 上限) {
  // 缓冲区是Nova对象，必须按元素清零，不能把对象头当裸地址传给内存填充。
  块[i] = 0
  i = i + 1
 }
 返回 块
}
函数 零内存(大小) { 定义 块 = 缓冲区(大小)
 返回 缓冲清零(块, 大小)
}

// 比较两块内存
函数 内存比较(地址1, 地址2, 长度) { 定义 可变 i = 0
 当 (i < 长度) { 定义 a = 内存读8(地址1 + i)
 定义 b = 内存读8(地址2 + i)
 如果 (a != b) { 返回 i + 1 }
 i = i + 1
 }
 返回 0
}

// 在内存中搜索字节
函数 内存搜索(地址, 长度, 字节) { 定义 可变 i = 0
 当 (i < 长度) { 如果 (内存读8(地址 + i) == 字节) { 返回 i }
 i = i + 1
 }
 返回 0 - 1
}

// 十六进制转储 (打印内存内容)
函数 内存转储(地址, 长度) { 定义 hex = "0123456789ABCDEF"
 定义 可变 i = 0
 当 (i < 长度) { 定义 b = 内存读8(地址 + i)
 定义 高 = (b >> 4) & 0x0F
 定义 低 = b & 0x0F
 打印文本(字符串拼接(子串(hex, 高, 1), 子串(hex, 低, 1)))
 i = i + 1
 }
}

// 第九章: 绘图 (GDI)

定义 可变 _函数_移动至 = 0
定义 可变 _函数_画线至 = 0
定义 可变 _函数_创建画笔 = 0
定义 可变 _函数_选择对象 = 0
定义 可变 _函数_删除对象 = 0
定义 可变 _函数_画矩形 = 0
定义 可变 _函数_画椭圆 = 0
定义 可变 _函数_创建画刷 = 0
定义 可变 _函数_输出文本 = 0
定义 可变 _函数_设文本颜色 = 0
定义 可变 _函数_设背景模式 = 0

// 画线: 从当前点到 (x,y)
函数 画线到(dc, x, y) { _初始化图形()
 如果 (_函数_画线至 == 0) { _函数_画线至 = 获取函数(_图形32库, "LineTo") }
 调用指针(_函数_画线至,  dc,  x,  y, 0, 0)
}

// 移动画笔到 (x,y)
函数 移动画笔(dc, x, y) { _初始化图形()
 如果 (_函数_移动至 == 0) { _函数_移动至 = 获取函数(_图形32库, "MoveToEx") }
 调用指针4(_函数_移动至,  dc,  x,  y, 0)
}

// 画线段 (从(x1,y1)到(x2,y2))
函数 画线(dc, x1, y1, x2, y2) {
 移动画笔(dc, x1, y1)
 画线到(dc, x2, y2)
}

// 创建画笔 (样式, 宽度, 颜色)
函数 创建画笔(样式, 宽度, 颜色) { _初始化图形()
 如果 (_函数_创建画笔 == 0) { _函数_创建画笔 = 获取函数(_图形32库, "CreatePen") }
 返回 调用指针(_函数_创建画笔,  样式,  宽度,  颜色, 0, 0)
}

// 创建实心画刷
函数 创建画刷(颜色) { _初始化图形()
 如果 (_函数_创建画刷 == 0) { _函数_创建画刷 = 获取函数(_图形32库, "CreateSolidBrush") }
 返回 调用指针(_函数_创建画刷,  颜色, 0, 0, 0, 0)
}

// 选择GDI对象 (画笔/画刷/字体)
函数 选择对象(dc, 对象) { _初始化图形()
 如果 (_函数_选择对象 == 0) { _函数_选择对象 = 获取函数(_图形32库, "SelectObject") }
 返回 调用指针(_函数_选择对象,  dc,  对象, 0, 0, 0)
}

// 删除GDI对象
函数 删除对象(对象) { _初始化图形()
 如果 (_函数_删除对象 == 0) { _函数_删除对象 = 获取函数(_图形32库, "DeleteObject") }
 调用指针(_函数_删除对象,  对象, 0, 0, 0, 0)
}

// 画矩形
函数 画矩形(dc, 左, 上, 右, 下) { _初始化图形()
 如果 (_函数_画矩形 == 0) { _函数_画矩形 = 获取函数(_图形32库, "Rectangle") }
 调用指针5(_函数_画矩形, dc, 左, 上, 右, 下)
}

// 画椭圆
函数 画椭圆(dc, 左, 上, 右, 下) { _初始化图形()
 如果 (_函数_画椭圆 == 0) { _函数_画椭圆 = 获取函数(_图形32库, "Ellipse") }
 调用指针5(_函数_画椭圆, dc, 左, 上, 右, 下)
}

// 设置文字颜色
函数 设置文字颜色(dc, 颜色) { _初始化图形()
 如果 (_函数_设文本颜色 == 0) { _函数_设文本颜色 = 获取函数(_图形32库, "SetTextColor") }
 调用指针(_函数_设文本颜色,  dc,  颜色, 0, 0, 0)
}


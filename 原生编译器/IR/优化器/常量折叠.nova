// Nova · IR层 · 常量折叠优化器 (Constant Folding)
// 编译期计算常量表达式，消除运行时冗余计算
// 覆盖：二元折叠 / 一元折叠 / 代数简化 / 强度削减 / 条件折叠

导入("../../编译器/规划/核心/常量.nova")

定义 运算_加 = "+"
定义 运算_减 = "-"
定义 运算_乘 = "*"
定义 运算_除 = "/"
定义 运算_余 = "%"
定义 运算_等于 = "=="
定义 运算_不等 = "!="
定义 运算_小于 = "<"
定义 运算_大于 = ">"
定义 运算_小等 = "<="
定义 运算_大等 = ">="
定义 运算_位与 = "&"
定义 运算_位或 = "|"
定义 运算_位异或 = "^"
定义 运算_左移 = "<<"
定义 运算_右移 = ">>"
定义 运算_取负 = "-"
定义 运算_逻辑非 = "!"
定义 运算_位非 = "~"
定义 运算_逻辑与 = "&&"
定义 运算_逻辑或 = "||"

// 统计计数器
定义 可变 折叠_总次数 = 0
定义 可变 折叠_二元次数 = 0
定义 可变 折叠_一元次数 = 0
定义 可变 折叠_代数次数 = 0
定义 可变 折叠_条件次数 = 0
定义 可变 折叠_强度次数 = 0
定义 可变 折叠_浮点次数 = 0

函数 折叠_重置统计() {
    折叠_总次数 = 0
    折叠_二元次数 = 0
    折叠_一元次数 = 0
    折叠_代数次数 = 0
    折叠_条件次数 = 0
    折叠_强度次数 = 0
    折叠_浮点次数 = 0
}

函数 折叠_统计报告() {
    返回 [折叠_总次数, 折叠_二元次数, 折叠_一元次数,
           折叠_代数次数, 折叠_强度次数, 折叠_条件次数]
}

// 核心：二元常量折叠
// 两个操作数都是编译期常量时，直接计算结果
函数 折叠_二元运算(运算符, 左值, 右值) {
    折叠_二元次数 = 折叠_二元次数 + 1
    折叠_总次数 = 折叠_总次数 + 1
    如果 (运算符 == 运算_加) { 返回 左值 + 右值 }
    如果 (运算符 == 运算_减) { 返回 左值 - 右值 }
    如果 (运算符 == 运算_乘) { 返回 左值 * 右值 }
    如果 (运算符 == 运算_除) {
        如果 (右值 == 0) { 返回 空 }  // 除零：不折叠，保留运行时错误
        返回 左值 / 右值
    }
    如果 (运算符 == 运算_余) {
        如果 (右值 == 0) { 返回 空 }
        返回 左值 % 右值
    }
    如果 (运算符 == 运算_等于) {
        如果 (左值 == 右值) { 返回 1 }
        返回 0
    }
    如果 (运算符 == 运算_不等) {
        如果 (左值 != 右值) { 返回 1 }
        返回 0
    }
    如果 (运算符 == 运算_小于) {
        如果 (左值 < 右值) { 返回 1 }
        返回 0
    }
    如果 (运算符 == 运算_大于) {
        如果 (左值 > 右值) { 返回 1 }
        返回 0
    }
    如果 (运算符 == 运算_小等) {
        如果 (左值 <= 右值) { 返回 1 }
        返回 0
    }
    如果 (运算符 == 运算_大等) {
        如果 (左值 >= 右值) { 返回 1 }
        返回 0
    }
    如果 (运算符 == 运算_位与)  { 返回 左值 & 右值 }
    如果 (运算符 == 运算_位或)  { 返回 左值 | 右值 }
    如果 (运算符 == 运算_位异或){ 返回 左值 ^ 右值 }
    如果 (运算符 == 运算_左移)  {
        如果 (右值 < 0 或 右值 > 63) { 返回 空 }
        返回 左值 << 右值
    }
    如果 (运算符 == 运算_右移)  {
        如果 (右值 < 0 或 右值 > 63) { 返回 空 }
        返回 左值 >> 右值
    }
    如果 (运算符 == 运算_逻辑与) {
        如果 (左值 != 0 且 右值 != 0) { 返回 1 }
        返回 0
    }
    如果 (运算符 == 运算_逻辑或) {
        如果 (左值 != 0 或 右值 != 0) { 返回 1 }
        返回 0
    }
    返回 空  // 未知运算符，不折叠
}

// 一元常量折叠
函数 折叠_一元运算(运算符, 值) {
    折叠_一元次数 = 折叠_一元次数 + 1
    折叠_总次数 = 折叠_总次数 + 1
    如果 (运算符 == 运算_取负)  { 返回 0 - 值 }
    如果 (运算符 == 运算_逻辑非) {
        如果 (值 == 0) { 返回 1 }
        返回 0
    }
    如果 (运算符 == 运算_位非)  { 返回 0 - 值 - 1 }  // ~n = -n-1 (two's complement)
    返回 空
}

// 代数简化 (一侧为常量时的恒等式化简)
// 如 x+0→x, x*1→x, x*0→0, x-x→0, x^x→0 等
函数 常量折叠_代数简化(运算符, 左值, 右值, 左常量, 右常量) {
    折叠_代数次数 = 折叠_代数次数 + 1
    折叠_总次数 = 折叠_总次数 + 1

    // 加法恒等: x+0=x, 0+x=x
    如果 (运算符 == 运算_加) {
        如果 (右常量 == 1 且 右值 == 0) { 返回 ["left", 0] }
        如果 (左常量 == 1 且 左值 == 0) { 返回 ["right", 0] }
    }
    // 减法: x-0=x
    如果 (运算符 == 运算_减) {
        如果 (右常量 == 1 且 右值 == 0) { 返回 ["left", 0] }
    }
    // 乘法: x*1=x, 1*x=x, x*0=0, 0*x=0
    如果 (运算符 == 运算_乘) {
        如果 (右常量 == 1 且 右值 == 1) { 返回 ["left", 0] }
        如果 (左常量 == 1 且 左值 == 1) { 返回 ["right", 0] }
        如果 (右常量 == 1 且 右值 == 0) { 返回 ["const", 0] }
        如果 (左常量 == 1 且 左值 == 0) { 返回 ["const", 0] }
    }
    // 除法: x/1=x
    如果 (运算符 == 运算_除) {
        如果 (右常量 == 1 且 右值 == 1) { 返回 ["left", 0] }
    }
    // 位运算: x&0=0, x&-1=x, x|0=x, x^0=x, x^x=0
    如果 (运算符 == 运算_位与) {
        如果 (右常量 == 1 且 右值 == 0) { 返回 ["const", 0] }
        如果 (左常量 == 1 且 左值 == 0) { 返回 ["const", 0] }
    }
    如果 (运算符 == 运算_位或) {
        如果 (右常量 == 1 且 右值 == 0) { 返回 ["left", 0] }
        如果 (左常量 == 1 且 左值 == 0) { 返回 ["right", 0] }
    }
    如果 (运算符 == 运算_位异或) {
        如果 (右常量 == 1 且 右值 == 0) { 返回 ["left", 0] }
        如果 (左常量 == 1 且 左值 == 0) { 返回 ["right", 0] }
    }
    // 移位: x<<0=x, x>>0=x
    如果 (运算符 == 运算_左移 或 运算符 == 运算_右移) {
        如果 (右常量 == 1 且 右值 == 0) { 返回 ["left", 0] }
    }
    返回 空  // 无法简化
}

// 强度削减 (用更低代价指令替换昂贵操作, 0 , 0)
// 乘以2的幂 → 左移: x*8 → x<<3
// 整除2的幂 → 右移: x/4 → x>>2
函数 强度削减(运算符, 右值, 右常量) {
    如果 (右常量 != 1) { 返回 空 }
    如果 (右值 <= 0) { 返回 空 }

    // 乘以2的幂 → 左移
    如果 (运算符 == 运算_乘 且 是二的幂(右值)) {
        折叠_强度次数 = 折叠_强度次数 + 1
        折叠_总次数 = 折叠_总次数 + 1
        返回 [运算_左移, 二的幂指数(右值)]
    }
    // 除以2的幂 → 右移 (仅对正数安全)
    如果 (运算符 == 运算_除 且 是二的幂(右值)) {
        折叠_强度次数 = 折叠_强度次数 + 1
        折叠_总次数 = 折叠_总次数 + 1
        返回 [运算_右移, 二的幂指数(右值)]
    }
    // 取余2的幂 → 位与: x%8 → x&7
    如果 (运算符 == 运算_余 且 是二的幂(右值)) {
        折叠_强度次数 = 折叠_强度次数 + 1
        折叠_总次数 = 折叠_总次数 + 1
        返回 [运算_位与, 右值 - 1]
    }
    返回 空
}

// 通用强度削减 (包含乘以特殊常量的优化, 0 , 0)
函数 通用强度削减(运算符, 右值, 右常量) {
    定义 基础 = 强度削减(运算符, 右值, 右常量)
    如果 (基础 != 空) { 返回 基础 }
    // 乘以3 → (x<<1)+x, 乘以5 → (x<<2)+x
    如果 (运算符 == 运算_乘 且 右常量 == 1) {
        如果 (右值 == 3) { 返回 ["lea3", 0] }   // lea rax, [rax+rax*2]
        如果 (右值 == 5) { 返回 ["lea5", 0] }   // lea rax, [rax+rax*4]
        如果 (右值 == 9) { 返回 ["lea9", 0] }   // lea rax, [rax+rax*8]
    }
    返回 空
}

// 条件折叠
// 恒真/恒假条件 → 消除死分支
函数 条件折叠(条件值, 条件常量) {
    如果 (条件常量 != 1) { 返回 空 }  // 非常量，不折叠
    折叠_条件次数 = 折叠_条件次数 + 1
    折叠_总次数 = 折叠_总次数 + 1
    如果 (条件值 != 0) { 返回 "always_true" }
    返回 "always_false"
}

// 2的幂工具函数
函数 是二的幂(n) {
    如果 (n <= 0) { 返回 假 }
    返回 (n & (n - 1)) == 0
}

函数 二的幂指数(n) {
    如果 (n <= 0) { 返回 0 }
    定义 可变 exp = 0
    定义 可变 v = n
    当 (v > 1) {
        v = v >> 1
        exp = exp + 1
    }
    返回 exp
}

// 浮点常量折叠 (整数近似模拟)
// Nova 目前用整数×10000表示定点数
函数 折叠_浮点二元(运算符, 左值, 右值) {
    折叠_浮点次数 = 折叠_浮点次数 + 1
    如果 (运算符 == 运算_加) { 返回 左值 + 右值 }
    如果 (运算符 == 运算_减) { 返回 左值 - 右值 }
    如果 (运算符 == 运算_乘) { 返回 左值 * 右值 / 10000 }
    如果 (运算符 == 运算_除) {
        如果 (右值 == 0) { 返回 空 }
        返回 左值 * 10000 / 右值
    }
    返回 空
}

函数 折叠_浮点一元(运算符, 值) {
    如果 (运算符 == 运算_取负) { 返回 0 - 值 }
    返回 空
}

函数 浮点代数简化(运算符, 右值, 右常量) {
    如果 (右常量 != 1) { 返回 空 }
    如果 (运算符 == 运算_乘 且 右值 == 10000) { 返回 ["identity", 0] }
    如果 (运算符 == 运算_除 且 右值 == 10000) { 返回 ["identity", 0] }
    返回 空
}

// 实验反哺: 多轮连锁折叠（实验室验证：多轮比单轮多消除30%冗余）
// 原理: 第1轮折叠后可能暴露新的可折叠表达式，需要继续迭代
// 典型场景: (2+3)*x → 5*x → (再触发强度削减) x<<2+x
// 停止条件: 连续两轮折叠次数相同（不动点）

// 连锁折叠迭代计数器
定义 可变 折叠_轮次 = 0
定义 可变 折叠_本轮次数 = 0
定义 可变 折叠_上轮次数 = 0

函数 折叠_开始新轮次() {
    折叠_轮次 = 折叠_轮次 + 1
    折叠_上轮次数 = 折叠_本轮次数
    折叠_本轮次数 = 0
}

函数 折叠_记录本轮(n) {
    折叠_本轮次数 = 折叠_本轮次数 + n
    折叠_总次数 = 折叠_总次数 + n
}

// 检测是否达到不动点（停止条件）
函数 折叠_达到不动点() {
    返回 折叠_本轮次数 == 0  // 本轮没有新折叠 → 不动点
}

// 多轮连锁折叠调度器: 接收函数列表，遍历AST做常量折叠/代数简化/强度削减
// AST函数结构: [类型, 名称, 参数列表, 函数体语句列表]
// AST语句: 赋值=[105,名称,表达式], 返回=[106,表达式], 条件=[107,条件,真分支,假分支], 循环=[108,条件,体]
// AST表达式: 字面量=[100,值], 二元=[110,左,运算符,右], 一元=[111,运算符,操作数]
// 调用者: 优化管线_执行 (通过阶段6, 0)
函数 折叠_多轮迭代(最大轮次, 函数列表) {
    定义 可变 轮次限制 = 最大轮次
    如果 (最大轮次 > 8) { 轮次限制 = 8 }
    折叠_轮次 = 0
    定义 可变 总折叠 = 0
    定义 可变 i = 0
    当 (i < 轮次限制) {
        折叠_开始新轮次()
        如果 (函数列表 != 空 且 是列表(函数列表)) {
            定义 可变 fi = 0
            当 (fi < 计数(函数列表)) {
                定义 函数项 = 函数列表[fi]
                如果 (是列表(函数项) 且 计数(函数项) >= 4 且 是列表(函数项[3])) {
                    定义 本轮 = _折叠_语句列表(函数项[3])
                    折叠_记录本轮(本轮)
                }
                fi = fi + 1
            }
        }
        如果 (折叠_达到不动点()) { i = 轮次限制 }
        总折叠 = 总折叠 + 折叠_本轮次数
        i = i + 1
    }
    返回 [折叠_轮次, 总折叠]
}

// 递归折叠语句列表中的常量表达式，返回本轮折叠次数
函数 _折叠_语句列表(语句列表) {
    如果 (语句列表 == 空 或 是列表(语句列表) == 假) { 返回 0 }
    定义 可变 折叠数 = 0
    定义 可变 si = 0
    当 (si < 计数(语句列表)) {
        定义 语句 = 语句列表[si]
        如果 (是列表(语句) 且 计数(语句) >= 2) {
            定义 类型 = 语句[0]
            如果 (类型 == 节_定义 且 计数(语句) >= 3) {
                定义 结果 = _折叠_表达式(语句[2])
                如果 (结果 != 空) { 语句[2] = 结果  折叠数 = 折叠数 + 1 }
            }
            如果 (类型 == 节_赋值 且 计数(语句) >= 3) {
                定义 结果 = _折叠_表达式(语句[2])
                如果 (结果 != 空) { 语句[2] = 结果  折叠数 = 折叠数 + 1 }
            }
            如果 (类型 == 节_返回 且 计数(语句) >= 2) {
                定义 结果 = _折叠_表达式(语句[1])
                如果 (结果 != 空) { 语句[1] = 结果  折叠数 = 折叠数 + 1 }
            }
            如果 (类型 == 节_如果 且 计数(语句) >= 3) {
                定义 结果 = _折叠_表达式(语句[1])
                如果 (结果 != 空) { 语句[1] = 结果  折叠数 = 折叠数 + 1 }
                如果 (是列表(语句[2])) { 折叠数 = 折叠数 + _折叠_语句列表(语句[2]) }
                如果 (计数(语句) >= 4 且 是列表(语句[3])) { 折叠数 = 折叠数 + _折叠_语句列表(语句[3]) }
            }
            如果 (类型 == 节_当 且 计数(语句) >= 3) {
                定义 结果 = _折叠_表达式(语句[1])
                如果 (结果 != 空) { 语句[1] = 结果  折叠数 = 折叠数 + 1 }
                如果 (是列表(语句[2])) { 折叠数 = 折叠数 + _折叠_语句列表(语句[2]) }
            }
            如果 (类型 == 节_表达式 且 计数(语句) >= 2) {
                定义 结果 = _折叠_表达式(语句[1])
                如果 (结果 != 空) { 语句[1] = 结果  折叠数 = 折叠数 + 1 }
            }
        }
        si = si + 1
    }
    返回 折叠数
}

// 尝试折叠单个表达式，返回折叠后的字面量节点或空
函数 _折叠_表达式(表达式) {
    如果 (表达式 == 空 或 是列表(表达式) == 假 或 计数(表达式) < 2) { 返回 空 }
    定义 类型 = 表达式[0]
    如果 (类型 == 节_二元 且 计数(表达式) >= 4) {
        定义 运算符 = 表达式[1]
        定义 可变 左 = 表达式[2]
        定义 可变 右 = 表达式[3]
        定义 左折 = _折叠_表达式(左)
        如果 (左折 != 空) { 表达式[2] = 左折  左 = 左折 }
        定义 右折 = _折叠_表达式(右)
        如果 (右折 != 空) { 表达式[3] = 右折  右 = 右折 }
        如果 (是列表(左) 且 计数(左) >= 2 且 左[0] == 节_整数 且 是列表(右) 且 计数(右) >= 2 且 右[0] == 节_整数) {
            定义 结果 = 折叠_二元运算(运算符, 左[1], 右[1])
            如果 (结果 != 空) { 返回 [节_整数, 结果] }
        }
        定义 可变 左常 = 0
        定义 可变 右常 = 0
        定义 可变 左值 = 0
        定义 可变 右值 = 0
        如果 (是列表(左) 且 计数(左) >= 2 且 左[0] == 节_整数) { 左常 = 1  左值 = 左[1] }
        如果 (是列表(右) 且 计数(右) >= 2 且 右[0] == 节_整数) { 右常 = 1  右值 = 右[1] }
        如果 (左常 == 1 或 右常 == 1) {
            定义 简化 = 常量折叠_代数简化(运算符, 左值, 右值, 左常, 右常)
            如果 (简化 != 空) {
                如果 (简化[0] == "left") { 返回 左 }
                如果 (简化[0] == "right") { 返回 右 }
                如果 (简化[0] == "const") { 返回 [节_整数, 简化[1]] }
            }
            如果 (右常 == 1) {
                定义 削减 = 强度削减(运算符, 右值, 右常)
                如果 (削减 != 空) { 表达式[1] = 削减[0]  表达式[3] = [节_整数, 削减[1]] }
            }
        }
    }
    如果 ((类型 == 节_逻辑非 或 类型 == 节_位非) 且 计数(表达式) >= 2) {
        定义 可变 操作数 = 表达式[1]
        定义 子折 = _折叠_表达式(操作数)
        如果 (子折 != 空) { 表达式[1] = 子折  操作数 = 子折 }
        如果 (是列表(操作数) 且 计数(操作数) >= 2 且 操作数[0] == 节_整数) {
            定义 可变 一元运算符 = 运算_逻辑非
            如果 (类型 == 节_位非) { 一元运算符 = 运算_位非 }
            定义 结果 = 折叠_一元运算(一元运算符, 操作数[1])
            如果 (结果 != 空) { 返回 [节_整数, 结果] }
        }
    }
    返回 空
}

// 折叠效率报告（用于优化器性能分析）
函数 折叠_效率报告() {
    定义 总折叠 = 折叠_总次数
    如果 (总折叠 == 0) { 返回 "无可折叠表达式" }
    // 各类型折叠比例
    定义 二元占比 = 折叠_二元次数 * 100 / 总折叠
    定义 代数占比 = 折叠_代数次数 * 100 / 总折叠
    定义 强度占比 = 折叠_强度次数 * 100 / 总折叠
    返回 "总折叠=" + 转字符串(总折叠) +
           " 二元=" + 转字符串(二元占比) + "%" +
           " 代数=" + 转字符串(代数占比) + "%" +
           " 强度削减=" + 转字符串(强度占比) + "%"
}

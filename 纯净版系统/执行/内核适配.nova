导入("../外联/网络网络.nova")
导入("./浏览器图处.nova")
导入("./处理软件渲.nova")
导入("./渲染层管理.nova")
导入("./下载管理.nova")
导入("./同源策略检查.nova")
导入("./安全适配.nova")
导入("./威胁评估.nova")
导入("./存储初始化.nova")
导入("../中枢/整数转字符串.nova")
导入("./统计接口.nova")
导入("./内存适配.nova")
导入("./请求接口.nova")
导入("./浏览器网络.nova")
导入("./存证管理.nova")

结构 适配档 {
    名称,
    宽,
    高,
    最近层,
    最近请求,
    最近响应,
    最近下载,
    最近域,
    最近风险,
    最近统计,
    初始化完成,
    内存数,
    图处数,
    存储数,
    安全数,
    网络数,
    命中数,
    失败数,
    健康,
}

结构 适配摘要 {
    名称,
    内存数,
    图处数,
    存储数,
    安全数,
    网络数,
    命中数,
    失败数,
    健康,
}

结构 适配请求 {
    方法,
    地址,
    头,
    体,
    下载名,
    域,
}

定义 可变 适配账本 = []
定义 可变 适配建数 = 0
定义 可变 适配总执行 = 0
定义 可变 适配总命中 = 0
定义 可变 适配总失败 = 0

函数 内核适配_建档(名称, 宽, 高) {
    定义 档 = 堆_分配(适配档)
    档.名称 = 名称
    档.宽 = 宽
    档.高 = 高
    档.最近层 = 0
    档.最近请求 = 0
    档.最近响应 = 0
    档.最近下载 = 0
    档.最近域 = ""
    档.最近风险 = 0
    档.最近统计 = 0
    档.初始化完成 = 假
    档.内存数 = 0
    档.图处数 = 0
    档.存储数 = 0
    档.安全数 = 0
    档.网络数 = 0
    档.命中数 = 0
    档.失败数 = 0
    档.健康 = "未初始化"
    返回 档
}

函数 内核适配_登记(档) {
    追加(适配账本, 档)
    适配建数 = 适配建数 + 1
    返回 档
}

函数 内核适配_创建(名称, 宽, 高) {
    定义 档 = 内核适配_建档(名称, 宽, 高)
    内核适配_初始化(档)
    返回 内核适配_登记(档)
}

函数 内核适配_初始化(档) {
    内核适配_初始化内存(档)
    内核适配_初始化图处(档, 档.宽, 档.高)
    内核适配_初始化存储(档)
    内核适配_初始化安全(档)
    内核适配_初始化网络(档)
    档.初始化完成 = 真
    档.健康 = "运行"
    返回 档
}

函数 内核适配_初始化内存(档) {
    浏览器内存_初始化()
    档.内存数 = 档.内存数 + 1
    适配总执行 = 适配总执行 + 1
}

函数 内核适配_分配(档, 池类型, 大小) {
    定义 地址 = 浏览器内存_分配(池类型, 大小)
    档.内存数 = 档.内存数 + 1
    档.最近统计 = 浏览器内存_获取统计()
    返回 地址
}

函数 内核适配_释放(档, 池类型, 地址, 大小) {
    浏览器内存_释放(池类型, 地址, 大小)
    档.内存数 = 档.内存数 + 1
    档.最近统计 = 浏览器内存_获取统计()
}

函数 内核适配_AI预分配(档, 池类型, 预测数量) {
    浏览器内存_AI预分配(池类型, 预测数量)
    档.内存数 = 档.内存数 + 1
}

函数 内核适配_检查压力(档) {
    定义 压力 = 浏览器内存_检查压力()
    档.最近统计 = 压力
    如果 (压力 > 1) {
        浏览器内存_主动回收()
    }
    返回 压力
}

函数 内核适配_紧急回收(档) {
    浏览器内存_紧急回收()
    档.内存数 = 档.内存数 + 1
}

函数 内核适配_内存统计(档) {
    定义 统计 = 浏览器内存_获取统计()
    档.最近统计 = 统计
    返回 统计
}

函数 内核适配_初始化图处(档, 宽, 高) {
    浏览器图处_初始化(宽, 高)
    软渲_初始化()
    档.图处数 = 档.图处数 + 1
    适配总执行 = 适配总执行 + 1
}

函数 内核适配_创建层(档, x, y, 宽, 高) {
    定义 层 = 浏览器图处_创建层(x, y, 宽, 高)
    档.图处数 = 档.图处数 + 1
    档.最近层 = 层
    返回 层
}

函数 内核适配_填充矩形(档, 层ID, x, y, 宽, 高, 颜色, 透明度) {
    浏览器图处_填充矩形(层ID, x, y, 宽, 高, 颜色, 透明度)
    档.图处数 = 档.图处数 + 1
}

函数 内核适配_绘制文字(档, 层ID, x, y, 文字, 字号, 颜色) {
    浏览器图处_绘制文字(层ID, x, y, 文字, 字号, 颜色)
    档.图处数 = 档.图处数 + 1
}

函数 内核适配_绘制图像(档, 层ID, x, y, 宽, 高, 图像地址, 图像宽, 图像高) {
    浏览器图处_绘制图像(层ID, x, y, 宽, 高, 图像地址, 图像宽, 图像高)
    档.图处数 = 档.图处数 + 1
}

函数 内核适配_圆角矩形(档, 层ID, x, y, 宽, 高, 颜色, 圆角, 透明度) {
    浏览器图处_圆角矩形(层ID, x, y, 宽, 高, 颜色, 圆角, 透明度)
    档.图处数 = 档.图处数 + 1
}

函数 内核适配_阴影(档, 层ID, x, y, 宽, 高, 颜色, 模糊) {
    浏览器图处_绘制阴影(层ID, x, y, 宽, 高, 颜色, 模糊)
    档.图处数 = 档.图处数 + 1
}

函数 内核适配_提交层命令(档, 层ID, 命令) {
    浏览器图处_提交命令(层ID, 命令)
    档.图处数 = 档.图处数 + 1
}

函数 内核适配_合成帧(档) {
    浏览器图处_合成帧()
    软渲_交换缓冲()
    档.图处数 = 档.图处数 + 1
}

函数 内核适配_软件回退(档, 层) {
    浏览器图处_软件合成(层)
    档.图处数 = 档.图处数 + 1
    档.最近层 = 层
}

函数 内核适配_脏矩(档, x, y, 宽, 高) {
    软渲_标记脏矩(x, y, 宽, 高)
    档.图处数 = 档.图处数 + 1
}

函数 内核适配_图处统计(档) {
    定义 统计 = 浏览器图处_统计()
    档.最近统计 = 统计
    返回 统计
}

函数 内核适配_初始化存储(档) {
    浏览器存储_初始化()
    档.存储数 = 档.存储数 + 1
    适配总执行 = 适配总执行 + 1

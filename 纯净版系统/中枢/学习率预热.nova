导入("./错误码.nova")
导入("./整数转字符串.nova")
导入("./打乱.nova")
导入("./内核打印.nova")

定义 可变 调度_查询次数 = 0
定义 可变 裁剪_触发次数 = 0
定义 可变 归一化_次数 = 0
定义 可变 早停_检查次数 = 0

// §1 基础学习率调度

函数 学习率_预热(步数, 预热步, 目标率) {
    调度_查询次数 = 调度_查询次数 + 1
    如果 (步数 >= 预热步) { 返回 目标率 }
    返回 目标率 * 步数 / 预热步
}

函数 学习率_余弦(步数, 总步数, 最大率, 最小率) {
    调度_查询次数 = 调度_查询次数 + 1
    如果 (总步数 <= 0 || 步数 >= 总步数) { 返回 最小率 }
    定义 t = 步数 * 网络精度 / 总步数
    定义 cos_val = 网络精度 - 2 * t * t / 网络精度
    返回 最小率 + (最大率 - 最小率) * (网络精度 + cos_val) / (2 * 网络精度)
}

函数 学习率_阶梯(步数, 阶梯大小, 初始率, 衰减因子) {
    调度_查询次数 = 调度_查询次数 + 1
    定义 可变 率 = 初始率
    定义 可变 s = 步数
    当 (s >= 阶梯大小) {
        率 = 率 * 衰减因子 / 网络精度
        s = s - 阶梯大小
    }
    返回 率
}

// §2 指数衰减

函数 学习率_指数(步数, 初始率, 衰减率, 衰减步) {
    调度_查询次数 = 调度_查询次数 + 1
    // lr = initial * decay^(step/decay_steps)
    定义 可变 率 = 初始率
    定义 可变 s = 步数
    当 (s >= 衰减步) {
        率 = 率 * 衰减率 / 网络精度
        s = s - 衰减步
    }
    // 小数步衰减
    如果 (s > 0) {
        定义 分数 = s * 网络精度 / 衰减步
        定义 部分衰减 = 网络精度 - 分数 * (网络精度 - 衰减率) / 网络精度
        率 = 率 * 部分衰减 / 网络精度
    }
    返回 率
}

// §3 多项式衰减

函数 学习率_多项式(步数, 总步数, 初始率, 终止率, 幂) {
    调度_查询次数 = 调度_查询次数 + 1
    如果 (步数 >= 总步数) { 返回 终止率 }
    定义 t = (总步数 - 步数) * 网络精度 / 总步数
    // 近似 t^power: 对于power=2, t*t/precision
    定义 可变 衰减 = t
    如果 (幂 == 2) { 衰减 = t * t / 网络精度 }
    否则 如果 (幂 == 3) { 衰减 = t * t / 网络精度 * t / 网络精度 }
    返回 终止率 + (初始率 - 终止率) * 衰减 / 网络精度
}

// §4 循环学习率 (Triangular)

函数 学习率_循环(步数, 周期步数, 最小率, 最大率) {
    调度_查询次数 = 调度_查询次数 + 1
    定义 半周期 = 周期步数 / 2
    如果 (半周期 <= 0) { 返回 最小率 }
    定义 位置 = 步数 % 周期步数
    定义 可变 率 = 0
    如果 (位置 < 半周期) {
        // 上升阶段
        率 = 最小率 + (最大率 - 最小率) * 位置 / 半周期
    } 否则 {
        // 下降阶段
        率 = 最大率 - (最大率 - 最小率) * (位置 - 半周期) / 半周期
    }
    返回 率
}

// §5 One-Cycle Policy

函数 学习率_单周期(步数, 总步数, 最大率) {
    调度_查询次数 = 调度_查询次数 + 1
    定义 最小率 = 最大率 / 25
    定义 上升步 = 总步数 * 30 / 100  // 前30%上升
    定义 下降步 = 总步数 * 70 / 100  // 中间40%下降
    
    如果 (步数 < 上升步) {
        // 线性上升
        返回 最小率 + (最大率 - 最小率) * 步数 / 上升步
    } 否则 如果 (步数 < 下降步) {
        // 余弦下降
        定义 t = (步数 - 上升步) * 网络精度 / (下降步 - 上升步)
        定义 cos_val = 网络精度 - 2 * t * t / 网络精度
        返回 最小率 + (最大率 - 最小率) * (网络精度 + cos_val) / (2 * 网络精度)
    } 否则 {
        // 最后30%退火到极小值
        定义 退火率 = 最小率 / 10
        定义 t = (步数 - 下降步) * 网络精度 / (总步数 - 下降步)
        返回 最小率 - (最小率 - 退火率) * t / 网络精度
    }
}

// §6 Warmup + Cosine组合

函数 学习率_预热余弦(步数, 预热步, 总步数, 最大率, 最小率) {
    调度_查询次数 = 调度_查询次数 + 1
    如果 (步数 < 预热步) {
        返回 最大率 * 步数 / 预热步
    }
    返回 学习率_余弦(步数 - 预热步, 总步数 - 预热步, 最大率, 最小率)
}

// Warmup + 线性衰减
函数 学习率_预热线性(步数, 预热步, 总步数, 最大率) {
    调度_查询次数 = 调度_查询次数 + 1
    如果 (步数 < 预热步) {
        返回 最大率 * 步数 / 预热步
    }
    如果 (步数 >= 总步数) { 返回 0 }
    返回 最大率 * (总步数 - 步数) / (总步数 - 预热步)
}

// §7 Reduce on Plateau

函数 plateau_创建(初始率, 因子, 耐心, 最小率) {
    返回 [初始率, 因子, 耐心, 最小率, 0, 0x7FFFFFFF, 初始率]
    // [0]=初始率, [1]=因子, [2]=耐心, [3]=最小率, 
    // [4]=无改善计数, [5]=最佳指标, [6]=当前率
}

函数 plateau_步进(状态, 当前指标) {
    调度_查询次数 = 调度_查询次数 + 1
    如果 (当前指标 < 状态[5]) {
        // 有改善
        状态[5] = 当前指标
        状态[4] = 0
    } 否则 {
        状态[4] = 状态[4] + 1
        如果 (状态[4] >= 状态[2]) {
            // 超过耐心, 降低学习率
            状态[6] = 状态[6] * 状态[1] / 网络精度
            如果 (状态[6] < 状态[3]) { 状态[6] = 状态[3] }
            状态[4] = 0
        }
    }
    返回 状态[6]
}

// §8 梯度裁剪

函数 梯度裁剪_范数(梯度, 最大范数) {
    定义 可变 范数平方 = 0
    定义 可变 i = 0
    当 (i < 计数(梯度)) {
        范数平方 = 范数平方 + 梯度[i] * 梯度[i] / 网络精度
        i = i + 1
    }
    定义 范数 = 网络_开方(范数平方)
    如果 (范数 > 最大范数) {
        裁剪_触发次数 = 裁剪_触发次数 + 1
        定义 缩放 = 最大范数 * 网络精度 / 范数
        i = 0
        当 (i < 计数(梯度)) {
            梯度[i] = 梯度[i] * 缩放 / 网络精度
            i = i + 1
        }
    }
    返回 范数
}

函数 梯度裁剪_值(梯度, 最大值) {
    定义 可变 裁剪数 = 0
    定义 可变 i = 0
    当 (i < 计数(梯度)) {
        如果 (梯度[i] > 最大值) { 梯度[i] = 最大值  裁剪数 = 裁剪数 + 1 }
        如果 (梯度[i] < 0 - 最大值) { 梯度[i] = 0 - 最大值  裁剪数 = 裁剪数 + 1 }
        i = i + 1
    }
    如果 (裁剪数 > 0) { 裁剪_触发次数 = 裁剪_触发次数 + 1 }
    返回 裁剪数
}

// §9 梯度累积

函数 梯度累积_创建(参数数) {
    定义 可变 累积梯度 = []
    定义 可变 i = 0
    当 (i < 参数数) { 网络_追加(累积梯度, 0)  i = i + 1 }
    返回 [累积梯度, 0]  // [累积, 步数]
}

函数 梯度累积_加(状态, 梯度) {
    定义 累积 = 状态[0]
    定义 可变 i = 0
    当 (i < 计数(梯度) && i < 计数(累积)) {
        累积[i] = 累积[i] + 梯度[i]
        i = i + 1
    }
    状态[1] = 状态[1] + 1
}

函数 梯度累积_获取(状态) {
    定义 累积 = 状态[0]
    定义 步数 = 状态[1]
    如果 (步数 <= 0) { 返回 累积 }
    定义 可变 平均梯度 = []
    定义 可变 i = 0
    当 (i < 计数(累积)) {
        网络_追加(平均梯度, 累积[i] / 步数)
        i = i + 1
    }
    返回 平均梯度
}

函数 梯度累积_清零(状态) {
    定义 累积 = 状态[0]
    定义 可变 i = 0
    当 (i < 计数(累积)) { 累积[i] = 0  i = i + 1 }
    状态[1] = 0
}

// §10 正则化

// L2正则化 (权重衰减)
函数 权重衰减(参数, 衰减系数) {
    定义 n = 计数(参数)
    定义 可变 i = 0
    当 (i < n) {
        参数[i] = 参数[i] - 衰减系数 * 参数[i] / 网络精度
        i = i + 1
    }
}

// L1正则化 (稀疏)
函数 L1正则化(参数, 系数) {
    定义 n = 计数(参数)
    定义 可变 i = 0
    当 (i < n) {
        如果 (参数[i] > 0) {
            参数[i] = 参数[i] - 系数
            如果 (参数[i] < 0) { 参数[i] = 0 }
        } 否则 如果 (参数[i] < 0) {
            参数[i] = 参数[i] + 系数
            如果 (参数[i] > 0) { 参数[i] = 0 }
        }
        i = i + 1
    }
}

// Elastic Net: L1 + L2组合
函数 弹性网正则化(参数, L1系数, L2系数) {
    权重衰减(参数, L2系数)
    L1正则化(参数, L1系数)
}

// L2正则化损失项
函数 L2损失(参数, 系数) {
    定义 可变 损失 = 0
    定义 可变 i = 0
    当 (i < 计数(参数)) {
        损失 = 损失 + 参数[i] * 参数[i] / 网络精度
        i = i + 1
    }
    返回 系数 * 损失 / (2 * 网络精度)
}

// §11 早停 (Early Stopping)

函数 早停_创建(耐心, 最小改善) {
    返回 [耐心, 最小改善, 0, 0x7FFFFFFF, 假]
    // [0]=耐心, [1]=最小改善, [2]=无改善计数, [3]=最佳损失, [4]=应停止
}

函数 早停_检查(状态, 当前损失) {
    早停_检查次数 = 早停_检查次数 + 1
    如果 (当前损失 < 状态[3] - 状态[1]) {
        状态[3] = 当前损失
        状态[2] = 0
    } 否则 {
        状态[2] = 状态[2] + 1
        如果 (状态[2] >= 状态[0]) {
            状态[4] = 真
        }
    }
    返回 状态[4]
}

// §12 层归一化 (LayerNorm)

函数 层归一化(输入, gamma, beta) {
    归一化_次数 = 归一化_次数 + 1
    定义 n = 计数(输入)
    定义 可变 均值 = 0
    定义 可变 i = 0
    当 (i < n) { 均值 = 均值 + 输入[i]  i = i + 1 }
    均值 = 均值 / n
    定义 可变 方差 = 0
    i = 0
    当 (i < n) {
        定义 d = 输入[i] - 均值
        方差 = 方差 + d * d / 网络精度
        i = i + 1
    }
    方差 = 方差 / n
    定义 可变 标准差 = 网络_开方(方差)
    如果 (标准差 == 0) { 标准差 = 1 }
    定义 可变 输出 = []
    i = 0
    当 (i < n) {
        定义 归一 = (输入[i] - 均值) * 网络精度 / 标准差
        网络_追加(输出, 归一 * gamma[i] / 网络精度 + beta[i])
        i = i + 1
    }
    返回 输出
}

// 层归一化反向
函数 层归一化_反向(输入, gamma, 输出梯度) {
    归一化_次数 = 归一化_次数 + 1
    定义 n = 计数(输入)
    定义 可变 均值 = 0
    定义 可变 i = 0
    当 (i < n) { 均值 = 均值 + 输入[i]  i = i + 1 }
    均值 = 均值 / n
    定义 可变 方差 = 0
    i = 0
    当 (i < n) {
        定义 d = 输入[i] - 均值
        方差 = 方差 + d * d / 网络精度
        i = i + 1
    }
    方差 = 方差 / n
    定义 标准差 = 网络_开方(方差 + 1)
    如果 (标准差 == 0) { 标准差 = 1 }
    
    定义 可变 梯度 = []
    i = 0
    当 (i < n) {
        定义 归一 = (输入[i] - 均值) * 网络精度 / 标准差
        定义 dg = 输出梯度[i] * gamma[i] / 网络精度
        网络_追加(梯度, dg / 标准差)
        i = i + 1
    }
    返回 梯度
}

// §13 RMS Normalization (LLaMA风格)

函数 rms归一化(输入, gamma) {
    归一化_次数 = 归一化_次数 + 1
    定义 n = 计数(输入)
    定义 可变 和平方 = 0
    定义 可变 i = 0
    当 (i < n) {
        和平方 = 和平方 + 输入[i] * 输入[i] / 网络精度
        i = i + 1
    }
    定义 可变 rms = 网络_开方(和平方 / n)
    如果 (rms == 0) { rms = 1 }
    定义 可变 输出 = []
    i = 0
    当 (i < n) {
        网络_追加(输出, 输入[i] * gamma[i] / rms)
        i = i + 1
    }
    返回 输出
}

// §14 统计

函数 调度_统计() {
    返回 [调度_查询次数, 裁剪_触发次数, 归一化_次数, 早停_检查次数]
}

函数 调度_打印统计() {
    打印行("=== 学习率调度/训练工具统计 ===")
    打印行("调度查询: " + 整数转字符串(调度_查询次数))
    打印行("裁剪触发: " + 整数转字符串(裁剪_触发次数))
    打印行("归一化次数: " + 整数转字符串(归一化_次数))
    打印行("早停检查: " + 整数转字符串(早停_检查次数))
}

// §15 余弦退火与多阶段调度

函数 余弦退火_计算(初始率, 当前步, 总步数) {
    // cosine annealing: lr = lr_init * (1 + cos(pi * step / total)) / 2
    调度_查询次数 = 调度_查询次数 + 1
    如果 (总步数 <= 0) { 返回 初始率 }
    定义 角度 = 当前步 * 3142 / 总步数  // π*1000
    定义 x2 = 角度 * 角度 / 1000
    定义 cos_v = 1000 - x2 / 2
    如果 (cos_v < -1000) { cos_v = -1000 }
    返回 初始率 * (1000 + cos_v) / 2000
}

函数 多阶段调度_计算(初始率, 当前步, 里程碑列表, 里程碑数, 衰减率) {
    // Multi-step: 每到里程碑将学习率乘以衰减率
    调度_查询次数 = 调度_查询次数 + 1
    定义 可变 lr = 初始率
    定义 可变 i = 0
    当 (i < 里程碑数) {
        如果 (当前步 >= 里程碑列表[i]) {
            lr = lr * 衰减率 / 1000
        }
        i = i + 1
    }
    返回 lr
}

函数 一周期余弦_计算(最小率, 最大率, 当前步, 周期) {
    // One-cycle: 先升后降
    调度_查询次数 = 调度_查询次数 + 1
    如果 (周期 <= 0) { 返回 最小率 }
    定义 半周期 = 周期 / 2
    如果 (当前步 < 半周期) {
        // 上升阶段
        返回 最小率 + (最大率 - 最小率) * 当前步 / 半周期
    } 否则 {
        // 下降阶段
        返回 最大率 - (最大率 - 最小率) * (当前步 - 半周期) / 半周期
    }
}

函数 调度_重置统计() {
    调度_查询次数 = 0
    裁剪_触发次数 = 0
    归一化_次数 = 0
    早停_检查次数 = 0
}

// NLRS — Nova Learning Rate Scheduling Theory
// 公理1(预热稳定): 线性预热避免初始梯度爆炸
// 公理2(下界有效): 学习率在整个训练过程中始终>0
// 公理3(幂等性): 相同参数下结果完全确定
// 定理1(早停收敛): 损失不再改善时早停必然触发
// 定理2(裁剪安全): 梯度裁剪不改变梯度方向只缩放模长

// §16 权重衰减与动量辅助

函数 权重衰减_应用(参数, 衰减系数) {
    // L2 weight decay: param = param * (1 - decay)
    定义 n = 计数(参数)
    定义 可变 i = 0
    当 (i < n) {
        参数[i] = 参数[i] * (网络精度 - 衰减系数) / 网络精度
        i = i + 1
    }
    返回 参数
}

函数 动量_更新(速度, 梯度, 动量系数) {
    // momentum: v = beta * v + (1-beta) * grad
    定义 n = 计数(梯度)
    定义 可变 i = 0
    当 (i < n && i < 计数(速度)) {
        速度[i] = 动量系数 * 速度[i] / 网络精度 + (网络精度 - 动量系数) * 梯度[i] / 网络精度
        i = i + 1
    }
    返回 速度
}

// Phase3反哺注入: Q快速幂整数 [UpperBoundFix]
// 来源: Rust深度研究引擎 nova_deep_engine.rs
// 误差: 8.95% → 0.01%  提升: 895.5x
// 说明: Adam偏差校正上限Bug: step=30误差9.0%, Q快速幂修复
// Q快速幂整数 — E9反哺修复Adam偏差校正上限20步Bug
// 原版: 当k<步数&&k<20, 步数>20后固定错误, 误差13%
// 修复: O(log t)精确计算 beta^t
函数 Q快速幂整数(base, exp) {
    定义 可变 result = Q_ONE
    定义 可变 b = base
    定义 可变 e = exp
    当 (e > 0) {
        如果 (e % 2 == 1) { result = Q乘(result, b) }
        b = Q乘(b, b)
        e = e / 2
    }
    返回 result
}


// AdamW优化器 (Loshchilov&Hutter 2019, Llama3/GPT-4使用)
// 类人脑: 权重衰减模拟神经元"遗忘"机制，防止过拟合
// 改进: 正确的权重衰减(直接作用权重而非梯度)
// 依赖: Q快速幂整数(必须先定义)
函数 AdamW_更新(opt, 层索引, 权重, 梯度, 权重衰减率) {
    NOGL_Adam次数 = NOGL_Adam次数 + 1
    opt.步数 = opt.步数 + 1
    如果 (层索引 >= opt.层数) { 返回 }
    定义 m_t = 内存_读64(opt.m列表 + 层索引 * 8)
    定义 v_t = 内存_读64(opt.v列表 + 层索引 * 8)
    定义 总 = 权重.行数 * 权重.列数
    定义 b1 = opt.beta1
    定义 b2 = opt.beta2
    // 精确偏差校正 (E9修复: Q快速幂替代上限循环)
    定义 b1_t = Q快速幂整数(b1, opt.步数)
    定义 b2_t = Q快速幂整数(b2, opt.步数)
    定义 m_校正 = Q除(Q_ONE, Q_ONE - b1_t)
    定义 v_校正 = Q除(Q_ONE, Q_ONE - b2_t)
    定义 可变 i = 0
    当 (i < 总) {
        定义 g = 内存_读32有符号(梯度.数据 + i * 4)
        定义 m_old = 内存_读32有符号(m_t.数据 + i * 4)
        定义 m_new = Q乘(b1, m_old) + Q乘(Q_ONE - b1, g)
        内存_写32(m_t.数据 + i * 4, m_new)
        定义 v_old = 内存_读32有符号(v_t.数据 + i * 4)
        定义 v_new = Q乘(b2, v_old) + Q乘(Q_ONE - b2, Q乘(g, g))
        内存_写32(v_t.数据 + i * 4, v_new)
        定义 m_hat = Q乘(m_new, m_校正)
        定义 v_hat = Q乘(v_new, v_校正)
        定义 denom = Q平方根(v_hat) + Q_EPSILON
        定义 delta = Q乘(opt.学习率, Q除(m_hat, denom))
        定义 w = 内存_读32有符号(权重.数据 + i * 4)
        // AdamW: 权重衰减直接作用于权重(不通过梯度)
        定义 wd_decay = Q乘(权重衰减率, w)
        内存_写32(权重.数据 + i * 4, w - delta - wd_decay)
        i = i + 1
    }
}

// 余弦退火v2 — 4阶Taylor精确版
// 修复: 旧版1-2t²在t=0.5误差50% → 4阶Taylor误差<1%
// cos(πt) ≈ 1 - (πt)²/2 + (πt)⁴/24
函数 调度器_步进_v2(s) {
    NOGL_调度次数 = NOGL_调度次数 + 1
    s.当前步 = s.当前步 + 1
    如果 (s.策略 == NOGL_调度_固定) { 返回 s.初始LR }
    如果 (s.策略 == NOGL_调度_衰减) {
        // 修复: 用Q快速幂整数精确计算衰减
        定义 衰减_t = Q快速幂整数(s.衰减因子, s.当前步)
        定义 lr = Q乘(s.初始LR, 衰减_t)
        如果 (lr < s.最小LR) { lr = s.最小LR }
        返回 lr
    }
    如果 (s.策略 == NOGL_调度_余弦退火) {
        定义 t = (s.当前步 % s.周期步数) * Q_ONE / s.周期步数
        // 4阶Taylor: cos(πt) = 1 - (πt)²/2 + (πt)⁴/24
        定义 FP = 10000;  定义 FP_PI = 31416
        定义 pt = t * FP_PI / FP
        定义 pt2 = pt * pt / FP;  定义 pt4 = pt2 * pt2 / FP
        定义 cos_val = (FP - pt2 / 2 + pt4 / 24) * Q_ONE / FP
        定义 range = s.初始LR - s.最小LR
        返回 s.最小LR + Q乘(range, (Q_ONE + cos_val) / 2)
    }
    如果 (s.策略 == NOGL_调度_周期) {
        定义 half = s.周期步数 / 2
        定义 pos = s.当前步 % s.周期步数
        如果 (pos < half) { 返回 s.最小LR + (s.初始LR - s.最小LR) * pos / half }
        返回 s.初始LR - (s.初始LR - s.最小LR) * (pos - half) / half
    }
    返回 s.初始LR
}

// [v2反哺新增] EWC_损失项_安全版 — EWC损失溢出修复: diff截断3783/Q+先除后乘防i32超范围
// EWC损失项安全版 — E5/E6 Rust验证修复溢出
// 修复: λ×F×diff²可能超i32范围 → 截断保护+先除后乘
定义 EWC_安全DIFF_MAX = 3783  // 安全范围上限
// [v2反哺] EWC_损失项_安全版 — EWC损失溢出修复: diff截断3783/Q+先除后乘防i32超范围
// EWC损失项安全版 — E5/E6 Rust验证修复溢出
// 修复: λ×F×diff²可能超i32范围 → 截断保护+先除后乘
定义 EWC_安全DIFF_MAX = 3783  // 安全范围上限
函数 EWC_损失项(网络, ref) {
    如果 (ref == 0 || ref.权重快照 == 0 || ref.Fisher对角 == 0) { 返回 0 }
    定义 N = 网络_权重总数(网络)
    定义 可变 损失 = 0
    定义 可变 i = 0
    当 (i < N) {
        定义 w = 网络_获取权重1D(网络, i)
        定义 w_ref = Tensor_读1D(ref.权重快照, i)
        定义 F_i = Tensor_读1D(ref.Fisher对角, i)
        定义 可变 diff = w - w_ref
        // 溢出保护: diff截断
        如果 (diff > EWC_安全DIFF_MAX)  { diff = EWC_安全DIFF_MAX }
        如果 (diff < 0 - EWC_安全DIFF_MAX) { diff = 0 - EWC_安全DIFF_MAX }
        // 先除后乘避免溢出
        定义 lf = ref.lambda * F_i / (2 * Q_ONE)
        定义 d2 = Q乘(diff, diff)
        损失 = 损失 + Q乘(lf, d2)
        i = i + 1
    }
    返回 损失
}





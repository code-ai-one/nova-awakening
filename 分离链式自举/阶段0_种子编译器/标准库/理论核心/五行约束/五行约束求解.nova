导入("../../基础.nova")

// 【原创理论基础】
// 相生 (mutual generation): 木→火→土→金→水→木
// 相克 (mutual restriction): 木→土→水→火→金→木
// 这形成了一个有两种边类型的有向图, 数学上是一个 bicategory。
// 木 (生长/构建) — 代码生成、编译、构建系统
// 火 (变化/执行) — 运行时执行、热路径、优化
// 土 (承载/存储) — 内存管理、数据存储、持久化
// 金 (精炼/验证) — 类型检查、测试、形式验证
// 水 (流动/传输) — 网络通信、数据流、IO
// 约束规则:
// 相生: A生B → A的输出是B的输入 (数据流依赖)
// 相克: A克B → A对B施加约束 (约束依赖)
// 相生相克共同构成约束传播网络
// 数学形式化:
// E = {木, 火, 土, 金, 水} (五元素集)
// ≻ : E → E (相生映射, 永)
// ≻≻ : E → E (相克映射, 跳一生)
// ⊕ : E × E → E (元素合成, 相生方向)
// ε : E → Constraint (每个元素映射到约束类型)
// 证明: 五元素的生克关系构成强连通图, 约束传播无死锁。

定义 行_木 = 0
定义 行_火 = 1
定义 行_土 = 2
定义 行_金 = 3
定义 行_水 = 4

函数 行名(行) {
    如果 (行 == 行_木) { 返回 "木"
}
 如果 (行 == 行_火) { 返回 "火" }
 如果 (行 == 行_土) { 返回 "土" }
 如果 (行 == 行_金) { 返回 "金" }
 如果 (行 == 行_水) { 返回 "水" }
 返回 "无"
}

// 相生关系: 木→火→土→金→水→木
函数 相生(行) { 返回 (行 + 1) % 5 }

// 相克关系: 木→土→水→火→金→木
函数 相克(行) { 返回 (行 + 2) % 5 }

// 被生关系: 谁生我
函数 被生(行) { 返回 (行 + 4) % 5 }

// 被克关系: 谁克我
函数 被克(行) { 返回 (行 + 3) % 5 }

// [id, 行属性, 约束值, 域(可能值列表), 状态, 依赖列表]
定义 约束_未解 = 0
定义 约束_已解 = 1
定义 约束_矛盾 = 2

函数 五行节点_创建(id, 行, 域) { 返回 [id, 行, 空, 域, 约束_未解, []]
}

函数 五行节点_id(n) { 返回 n[0] }
函数 五行节点_行(n) { 返回 n[1] }
函数 五行节点_值(n) { 返回 n[2] }
函数 五行节点_域(n) { 返回 n[3] }
函数 五行节点_状态(n) { 返回 n[4] }

函数 五行节点_设值(n, 值) {
 n[2] = 值
 n[3] = [值]
 n[4] = 约束_已解
}

函数 五行节点_收缩域(n, 新域) {
    如果 (计数(新域) == 0) { n[4] = 约束_矛盾 返回 空
}
 n[3] = 新域
 如果 (计数(新域) == 1) {
 n[2] = 新域[0]
 n[4] = 约束_已解
 }
}

// [源节点id, 目标节点id, 关系类型(生/克), 约束函数]
定义 关系_生 = 0 // 相生: 源的输出供给目标
定义 关系_克 = 1 // 相克: 源对目标施加限制

函数 五行约束_创建(源id, 目标id, 关系, 约束函数) { 返回 [源id, 目标id, 关系, 约束函数]
}

// [节点列表, 约束列表, 传播队列, 求解步数]

函数 五行网_创建() { 返回 [[], [], [], 0]
}

函数 五行网_添加节点(网, 行, 域) { 定义 id = 计数(网[0])
 定义 节点 = 五行节点_创建(id, 行, 域)
 追加(网[0], 节点)
 返回 id
}

函数 五行网_添加生(网, 源id, 目标id, 约束函数) { 定义 源 = 网[0][源id]
 定义 约束 = 五行约束_创建(源id, 目标id, 关系_生, 约束函数)
 追加(网[1], 约束)
 追加(源[5], 计数(网[1]) - 1)
}

函数 五行网_添加克(网, 源id, 目标id, 约束函数) { 定义 约束 = 五行约束_创建(源id, 目标id, 关系_克, 约束函数)
 追加(网[1], 约束)
 定义 源 = 网[0][源id]
 追加(源[5], 计数(网[1]) - 1)
}

函数 五行网_传播(网) { 定义 可变 改变 = 1
 定义 可变 步数 = 0
 当 (改变 == 1 且 步数 < 100) {
 改变 = 0
 定义 可变 i = 0
 当 (i < 计数(网[1])) { 定义 约束 = 网[1][i]
 定义 源 = 网[0][约束[0]]
 定义 目标 = 网[0][约束[1]]
 如果 (五行节点_状态(源) == 约束_已解) {
 // 源已确定, 传播到目标
 定义 源值 = 五行节点_值(源)
 定义 旧域 = 五行节点_域(目标)
 定义 可变 新域 = []
 定义 可变 j = 0
 当 (j < 计数(旧域)) { 如果 (约束[3] == 空) { 续 }
 如果 (约束[3](源值, 旧域[j]) == 1) {
 追加(新域, 旧域[j])
 }
 } 否则 {
 追加(新域, 旧域[j])
 j = j + 1
 }
 如果 (计数(新域) < 计数(旧域)) {
 五行节点_收缩域(目标, 新域)
 改变 = 1
 }
 }
 i = i + 1
 }
 步数 = 步数 + 1
 }
 网[3] = 步数
 返回 步数
}

函数 五行网_求解(网) {
 // 先传播
 五行网_传播(网)
 // 检查是否全部已解
 如果 (五行网_全部已解(网) == 1) { 返回 1 }
 // 检查是否有矛盾
 如果 (五行网_有矛盾(网) == 1) { 返回 0 }
 // 找最小域的未解节点 (MRV启发式)
 定义 可变 最小idx = -1
 定义 可变 最小域 = 999999
 定义 可变 i = 0
 当 (i < 计数(网[0])) { 定义 n = 网[0][i]
 如果 (五行节点_状态(n) == 约束_未解) { 定义 域大 = 计数(五行节点_域(n))
 如果 (域大 < 最小域) {
 最小域 = 域大
 最小idx = i
 }
 }
 i = i + 1
 }
 如果 (最小idx == -1) { 返回 0 }
 定义 域 = 五行节点_域(网[0][最小idx])
 定义 可变 j = 0
 当 (j < 计数(域)) {
 // 保存状态
 定义 备份 = 五行网_备份(网)
 五行节点_设值(网[0][最小idx], 域[j])
 如果 (五行网_求解(网) == 1) { 返回 1 }
 // 回溯
 五行网_恢复(网, 备份)
 j = j + 1
 }
 返回 0
}

函数 五行网_全部已解(网) { 定义 可变 i = 0
 当 (i < 计数(网[0])) { 如果 (五行节点_状态(网[0][i]) != 约束_已解) { 返回 0 }
 i = i + 1
 }
 返回 1
}

函数 五行网_有矛盾(网) { 定义 可变 i = 0
 当 (i < 计数(网[0])) { 如果 (五行节点_状态(网[0][i]) == 约束_矛盾) { 返回 1 }
 i = i + 1
 }
 返回 0
}

// 备份/恢复 (用于回溯)
函数 五行网_备份(网) { 定义 可变 备份 = []
 定义 可变 i = 0
 当 (i < 计数(网[0])) { 定义 n = 网[0][i]
 定义 可变 域拷贝 = []
 定义 可变 j = 0
 当 (j < 计数(五行节点_域(n))) {
 追加(域拷贝, 五行节点_域(n)[j])
 j = j + 1
 }
 追加(备份, [n[2], 域拷贝, n[4]])
 i = i + 1
 }
 返回 备份
}

函数 五行网_恢复(网, 备份) { 定义 可变 i = 0
 当 (i < 计数(备份)) {
 网[0][i][2] = 备份[i][0]
 网[0][i][3] = 备份[i][1]
 网[0][i][4] = 备份[i][2]
 i = i + 1
 }
}

函数 五行_平衡检查(网) { 定义 可变 行计数 = [0, 0,]
 定义 可变 i = 0
 当 (i < 计数(网[0])) { 定义 行 = 五行节点_行(网[0][i])
 如果 (行 >= 0 且 行 < 5) { 行计数[行] = 行计数[行] + 1 }
 i = i + 1
 }
 // 检查每行至少有一个代表
 定义 可变 缺失 = []
 i = 0
 当 (i < 5) { 如果 (行计数[i] == 0) { 追加(缺失, 行名(i)) }
 i = i + 1
 }
 返回 缺失
}

函数 编译器_五行映射() { 定义 可变 映射 = []
 追加(映射, [行_木, "词法分析", "从源码文本生长出token"])
 追加(映射, [行_火, "语法分析", "token在火中变化为AST"])
 追加(映射, [行_土, "语义分析", "AST扎根于类型和符号表"])
 追加(映射, [行_金, "优化", "代码在金中被精炼提纯"])
 追加(映射, [行_水, "代码生成", "优化后的IR流动为机器码"])
 返回 映射
}

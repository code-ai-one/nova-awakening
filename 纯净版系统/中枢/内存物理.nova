导入("./同步原语.nova")
导入("./内存虚拟.nova")

结构 物页档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    总页数,
    空闲页数,
    已用页数,
    保留页数,
    区数,
    分配数,
    释放数,
    映射数,
    压缩数,
    紧缩数,
    成功数,
    失败数,
    最近区,
    最近页,
    最近用途,
    锁,
    区表,
}

结构 物页请求 {
    动作,
    目标,
    参数,
    选项,
}

结构 物页回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 物页摘要 {
    名称,
    总页数,
    空闲页数,
    已用页数,
    保留页数,
    区数,
    分配数,
    释放数,
    映射数,
    压缩数,
    紧缩数,
    成功数,
    失败数,
    健康,
}

结构 物页区项 {
    名称,
    起始页,
    结束页,
    用途,
    页表,
}

结构 物页帧项 {
    页号,
    状态,
    标志,
    用途,
    引用数,
    映射,
}

定义 可变 物页账本 = []
定义 可变 物页构建数 = 0
定义 可变 物页总动作 = 0
定义 可变 物页总成功 = 0
定义 可变 物页总失败 = 0

函数 内存物理_建档(名称) {
    定义 档 = 物页档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.总页数 = 0
    档.空闲页数 = 0
    档.已用页数 = 0
    档.保留页数 = 0
    档.区数 = 0
    档.分配数 = 0
    档.释放数 = 0
    档.映射数 = 0
    档.压缩数 = 0
    档.紧缩数 = 0
    档.成功数 = 0
    档.失败数 = 0
    档.最近区 = ""
    档.最近页 = -1
    档.最近用途 = ""
    档.锁 = 同步原语_创建互斥(名称 + "锁")
    档.区表 = []
    返回 档
}

函数 内存物理_登记(档) {
    追加(物页账本, 档)
    物页构建数 = 物页构建数 + 1
    返回 档
}

函数 内存物理_完整统计() {
    返回 [
        物页构建数,
        物页总动作,
        物页总成功,
        物页总失败
    ]
}

函数 内存物理_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 物页回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 内存物理_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    物页总动作 = 物页总动作 + 1
}

函数 内存物理_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.失败数 > 档.成功数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (档.空闲页数 < 32) {
        档.最近健康 = "紧张"
        返回 档.最近健康
    }
    如果 (档.失败数 > 0) {
        档.最近健康 = "监视"
        返回 档.最近健康
    }
    档.最近健康 = "运行"
    返回 档.最近健康
}

函数 内存物理_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (档.名称 == "") { 返回 假 }
    返回 真
}

函数 内存物理_成功(档, 来源, 数据) {
    档.最近结果 = 数据
    档.成功数 = 档.成功数 + 1
    物页总成功 = 物页总成功 + 1
    档.最近统计 = 内存物理_完整统计()
    内存物理_刷新健康(档)
    返回 内存物理_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 内存物理_失败(档, 来源, 错因) {
    如果 (档 != 空) {
        档.最近错误 = 错因
        档.失败数 = 档.失败数 + 1
        档.最近统计 = 内存物理_完整统计()
        内存物理_刷新健康(档)
    }
    物页总失败 = 物页总失败 + 1
    返回 内存物理_建回证(真, 假, 来源, 错因, 空, 内存物理_完整统计())
}

函数 内存物理_建区(名称, 起始页, 结束页, 用途) {
    定义 区 = 物页区项 {}
    区.名称 = 名称
    区.起始页 = 起始页
    区.结束页 = 结束页
    区.用途 = 用途
    区.页表 = []
    返回 区
}

函数 内存物理_建页(页号, 状态, 标志, 用途) {
    定义 页 = 物页帧项 {}
    页.页号 = 页号
    页.状态 = 状态
    页.标志 = 标志
    页.用途 = 用途
    页.引用数 = 0
    页.映射 = []
    返回 页
}

函数 内存物理_找区(档, 名称) {
    定义 索引 = 0
    当 (索引 < 计数(档.区表)) {
        定义 区 = 档.区表[索引]
        如果 (区.名称 == 名称) { 返回 区 }
        索引 = 索引 + 1
    }
    返回 空
}

函数 内存物理_找页(区, 页号) {
    定义 索引 = 0
    当 (索引 < 计数(区.页表)) {
        定义 页 = 区.页表[索引]
        如果 (页.页号 == 页号) { 返回 页 }
        索引 = 索引 + 1
    }
    返回 空
}

函数 内存物理_加区(档, 名称, 起始页, 结束页, 用途) {
    如果 (!内存物理_检查档(档)) { 返回 内存物理_失败(档, "加区", "物页档不可用") }
    内存物理_记录(档, "加区", [名称, 起始页, 结束页, 用途], "内存物理")
    如果 (内存物理_找区(档, 名称) != 空) {
        返回 内存物理_失败(档, "加区", "物理区已存在")
    }
    定义 区 = 内存物理_建区(名称, 起始页, 结束页, 用途)
    定义 当前页 = 起始页
    当 (当前页 <= 结束页) {
        追加(区.页表, 内存物理_建页(当前页, "空闲", "", 用途))
        当前页 = 当前页 + 1
    }
    追加(档.区表, 区)
    档.区数 = 档.区数 + 1
    档.总页数 = 档.总页数 + 计数(区.页表)
    档.空闲页数 = 档.空闲页数 + 计数(区.页表)
    档.最近区 = 名称
    返回 内存物理_成功(档, "加区", 区)
}

函数 内存物理_取空闲页(区) {
    定义 索引 = 0
    当 (索引 < 计数(区.页表)) {
        定义 页 = 区.页表[索引]
        如果 (页.状态 == "空闲") { 返回 页 }
        索引 = 索引 + 1
    }
    返回 空
}

函数 内存物理_分配(档, 区名, 用途, 标志) {
    如果 (!内存物理_检查档(档)) { 返回 内存物理_失败(档, "分配", "物页档不可用") }
    内存物理_记录(档, "分配", [区名, 用途, 标志], "内存物理")
    定义 区 = 内存物理_找区(档, 区名)
    如果 (区 == 空) { 返回 内存物理_失败(档, "分配", "物理区不存在") }
    定义 页 = 内存物理_取空闲页(区)
    如果 (页 == 空) { 返回 内存物理_失败(档, "分配", "物理区空闲页不足") }
    页.状态 = "已用"
    页.标志 = 标志
    页.用途 = 用途
    页.引用数 = 1
    档.分配数 = 档.分配数 + 1
    档.空闲页数 = 档.空闲页数 - 1
    档.已用页数 = 档.已用页数 + 1
    档.最近区 = 区名
    档.最近页 = 页.页号
    档.最近用途 = 用途
    返回 内存物理_成功(档, "分配", 页)
}

函数 内存物理_批量分配(档, 区名, 数量, 用途, 标志) {
    如果 (!内存物理_检查档(档)) { 返回 内存物理_失败(档, "批量分配", "物页档不可用") }
    内存物理_记录(档, "批量分配", [区名, 数量, 用途, 标志], "内存物理")
    定义 结果 = []
    定义 索引 = 0
    当 (索引 < 数量) {
        定义 回证 = 内存物理_分配(档, 区名, 用途, 标志)
        如果 (!回证.已成) { 返回 回证 }
        追加(结果, 回证.数据)
        索引 = 索引 + 1
    }
    返回 内存物理_成功(档, "批量分配", 结果)
}

函数 内存物理_释放(档, 区名, 页号) {
    如果 (!内存物理_检查档(档)) { 返回 内存物理_失败(档, "释放", "物页档不可用") }
    内存物理_记录(档, "释放", [区名, 页号], "内存物理")
    定义 区 = 内存物理_找区(档, 区名)
    如果 (区 == 空) { 返回 内存物理_失败(档, "释放", "物理区不存在") }
    定义 页 = 内存物理_找页(区, 页号)
    如果 (页 == 空) { 返回 内存物理_失败(档, "释放", "物理页不存在") }
    如果 (页.状态 == "保留") { 返回 内存物理_失败(档, "释放", "保留页不可释放") }
    如果 (页.状态 == "空闲") { 返回 内存物理_失败(档, "释放", "物理页已空闲") }
    页.状态 = "空闲"
    页.标志 = ""
    页.用途 = 区.用途
    页.引用数 = 0
    页.映射 = []
    档.释放数 = 档.释放数 + 1
    档.空闲页数 = 档.空闲页数 + 1
    如果 (档.已用页数 > 0) { 档.已用页数 = 档.已用页数 - 1 }
    档.最近区 = 区名
    档.最近页 = 页号
    返回 内存物理_成功(档, "释放", 页号)
}

函数 内存物理_保留范围(档, 区名, 起始页, 结束页, 用途) {
    如果 (!内存物理_检查档(档)) { 返回 内存物理_失败(档, "保留范围", "物页档不可用") }
    内存物理_记录(档, "保留范围", [区名, 起始页, 结束页, 用途], "内存物理")
    定义 区 = 内存物理_找区(档, 区名)
    如果 (区 == 空) { 返回 内存物理_失败(档, "保留范围", "物理区不存在") }
    定义 索引 = 0
    定义 命中数 = 0
    当 (索引 < 计数(区.页表)) {
        定义 页 = 区.页表[索引]
        如果 (页.页号 >= 起始页 && 页.页号 <= 结束页) {
            如果 (页.状态 == "空闲" && 档.空闲页数 > 0) { 档.空闲页数 = 档.空闲页数 - 1 }
            页.状态 = "保留"
            页.用途 = 用途
            命中数 = 命中数 + 1
        }
        索引 = 索引 + 1
    }
    档.保留页数 = 档.保留页数 + 命中数
    档.最近区 = 区名
    档.最近用途 = 用途
    返回 内存物理_成功(档, "保留范围", 命中数)
}

函数 内存物理_建立映射(档, 区名, 页号, 虚拟地址, 权限) {
    如果 (!内存物理_检查档(档)) { 返回 内存物理_失败(档, "建立映射", "物页档不可用") }
    内存物理_记录(档, "建立映射", [区名, 页号, 虚拟地址, 权限], "内存物理")
    定义 区 = 内存物理_找区(档, 区名)
    如果 (区 == 空) { 返回 内存物理_失败(档, "建立映射", "物理区不存在") }
    定义 页 = 内存物理_找页(区, 页号)
    如果 (页 == 空) { 返回 内存物理_失败(档, "建立映射", "物理页不存在") }
    如果 (页.状态 == "空闲") { 返回 内存物理_失败(档, "建立映射", "空闲页不可映射") }
    追加(页.映射, [虚拟地址, 权限])
    页.引用数 = 页.引用数 + 1
    档.映射数 = 档.映射数 + 1
    档.最近页 = 页号
    档.最近用途 = 权限
    返回 内存物理_成功(档, "建立映射", 页.映射)
}

函数 内存物理_页压(档, 区名) {
    如果 (!内存物理_检查档(档)) { 返回 内存物理_失败(档, "页压", "物页档不可用") }
    内存物理_记录(档, "页压", [区名], "内存物理")
    定义 区 = 内存物理_找区(档, 区名)
    如果 (区 == 空) { 返回 内存物理_失败(档, "页压", "物理区不存在") }
    定义 已用 = 0
    定义 保留 = 0
    定义 索引 = 0
    当 (索引 < 计数(区.页表)) {
        定义 页 = 区.页表[索引]
        如果 (页.状态 == "已用") { 已用 = 已用 + 1 }
        如果 (页.状态 == "保留") { 保留 = 保留 + 1 }
        索引 = 索引 + 1
    }
    档.压缩数 = 档.压缩数 + 1
    返回 内存物理_成功(档, "页压", [区名, 已用, 保留, 计数(区.页表)])
}

函数 内存物理_紧缩建议(档) {
    如果 (!内存物理_检查档(档)) { 返回 内存物理_失败(档, "紧缩建议", "物页档不可用") }
    内存物理_记录(档, "紧缩建议", [], "内存物理")
    定义 建议 = []
    如果 (档.空闲页数 < 64) { 追加(建议, "回收缓存页") }
    如果 (档.保留页数 > 档.总页数 / 3) { 追加(建议, "复核保留区") }
    如果 (档.已用页数 > 档.空闲页数) { 追加(建议, "触发跨区搬移") }
    档.紧缩数 = 档.紧缩数 + 1
    返回 内存物理_成功(档, "紧缩建议", 建议)
}

函数 内存物理_异常(档) {
    如果 (!内存物理_检查档(档)) { 返回 内存物理_失败(档, "异常", "物页档不可用") }
    内存物理_记录(档, "异常", [], "内存物理")
    定义 问题 = []
    如果 (档.区数 == 0) { 追加(问题, "无物理区") }
    如果 (档.空闲页数 < 16) { 追加(问题, "空闲页告急") }
    如果 (档.失败数 > 档.成功数) { 追加(问题, "失败倒挂") }
    如果 (档.保留页数 > 档.总页数 / 2) { 追加(问题, "保留过高") }
    返回 内存物理_成功(档, "异常", 问题)
}

函数 内存物理_摘要(档) {
    定义 摘要 = 物页摘要 {}
    摘要.名称 = 档.名称
    摘要.总页数 = 档.总页数
    摘要.空闲页数 = 档.空闲页数
    摘要.已用页数 = 档.已用页数
    摘要.保留页数 = 档.保留页数
    摘要.区数 = 档.区数
    摘要.分配数 = 档.分配数
    摘要.释放数 = 档.释放数
    摘要.映射数 = 档.映射数
    摘要.压缩数 = 档.压缩数
    摘要.紧缩数 = 档.紧缩数
    摘要.成功数 = 档.成功数
    摘要.失败数 = 档.失败数
    摘要.健康 = 内存物理_刷新健康(档)
    返回 摘要
}

函数 内存物理_初始化(档) {
    如果 (!内存物理_检查档(档)) { 返回 内存物理_失败(档, "初始化", "物页档不可用") }
    内存物理_记录(档, "初始化", [], "内存物理")
    档.区表 = []
    档.总页数 = 0
    档.空闲页数 = 0
    档.已用页数 = 0
    档.保留页数 = 0
    档.区数 = 0
    档.是否初始化 = 真
    内存物理_加区(档, "低端区", 0, 63, "DMA")
    内存物理_加区(档, "常规区", 64, 511, "常规")
    内存物理_加区(档, "高端区", 512, 1023, "高端")
    内存物理_保留范围(档, "低端区", 0, 7, "引导")
    内存物理_保留范围(档, "常规区", 64, 79, "内核镜像")
    返回 内存物理_成功(档, "初始化", "已初始化")
}

函数 内存物理_自检(档) {
    如果 (!内存物理_检查档(档)) { 返回 假 }
    如果 (内存物理_初始化(档).已成 == 假) { 返回 假 }
    定义 一页 = 内存物理_分配(档, "常规区", "页缓存", "可写")
    如果 (!一页.已成) { 返回 假 }
    定义 多页 = 内存物理_批量分配(档, "高端区", 4, "白璃贴图", "只读")
    如果 (!多页.已成) { 返回 假 }
    如果 (内存物理_建立映射(档, "常规区", 一页.数据.页号, "0x400000", "rw").已成 == 假) { 返回 假 }
    如果 (内存物理_页压(档, "常规区").已成 == 假) { 返回 假 }
    如果 (内存物理_紧缩建议(档).已成 == 假) { 返回 假 }
    如果 (内存物理_释放(档, "常规区", 一页.数据.页号).已成 == 假) { 返回 假 }
    返回 真
}

函数 内存物理_处理(档, 请求) {
    如果 (请求 == 空) { 返回 内存物理_失败(档, "处理", "请求为空") }
    如果 (请求.动作 == "初始化") { 返回 内存物理_初始化(档) }
    如果 (请求.动作 == "加区") { 返回 内存物理_加区(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3]) }
    如果 (请求.动作 == "分配") { 返回 内存物理_分配(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "批量分配") { 返回 内存物理_批量分配(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3]) }
    如果 (请求.动作 == "释放") { 返回 内存物理_释放(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "保留范围") { 返回 内存物理_保留范围(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3]) }
    如果 (请求.动作 == "建立映射") { 返回 内存物理_建立映射(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3]) }
    如果 (请求.动作 == "页压") { 返回 内存物理_页压(档, 请求.参数[0]) }
    如果 (请求.动作 == "紧缩建议") { 返回 内存物理_紧缩建议(档) }
    如果 (请求.动作 == "异常") { 返回 内存物理_异常(档) }
    如果 (请求.动作 == "摘要") { 返回 内存物理_成功(档, "摘要", 内存物理_摘要(档)) }
    返回 内存物理_失败(档, "处理", "未知动作")
}

定义 可变 AI_内存物理_运行指标 = 0
定义 可变 AI_内存物理_异常指标 = 0

函数 AI_内存物理_自诊断() {
    AI_内存物理_运行指标 = 0
    返回 AI_内存物理_运行指标
}

函数 AI_内存物理_优化建议() {
    定义 指标 = AI_内存物理_自诊断()
    返回 "内存物理状态正常"
}

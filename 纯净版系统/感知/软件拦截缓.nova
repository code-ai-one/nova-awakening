// §2 取数拦截
// 当页面发起请求时,检查是否有active的Service 工线拦截

函数 Service工线_拦截取数(请求URL, 请求方法) {
    定义 容器 = Service工线Container_获取()
    如果 (容器.控制器 == 0) { 返回 0 }    // 无controller,不拦截

    定义 sw = 容器.控制器
    如果 (sw.状态 != SW_STATE_ACTIVATED) { 返回 0 }
    如果 (sw.fetch回调 == 0) { 返回 0 }

    // 检查作用域匹配
    定义 注册 = sw.注册
    如果 (注册 != 0 && !字符串_开头匹配(请求URL, 注册.作用域)) {
        返回 0    // URL不在作用域内
    }

    // 创建取数事件
    // 事件.respondWith(response/promise) — 自定义响应
    // 事件.request — 原始请求
    // 返回null表示"未拦截, 继续网络请求"
    返回 0
}

函数 Service工线_注入全局接口(sw) {
    如果 (sw == 0 || sw.Nova运行时实例 == 0) { 返回 }

    // 注入到全局对象:
    // self.add事件Listener('fetch', ...)
    // self.skipWaiting()
    // self.clients.claim()
    // self.caches — 缓存存储
    // self.registration
    // self.fetch()
}

// §3 缓存 接口 — 请求/响应的持久化缓存

结构 缓存Entry {
    请求URL,
    请求方法,
    响应状态码,
    响应头,    // u64 头部字符串
    响应体,    // u64 数据指针
    响应体长度,
    时间戳,
}

结构 缓存 {
    名称,
    条目列表,    // u64 缓存Entry*数组
    条目数量,
    条目容量,
}

结构 缓存存储 {
    缓存列表,    // u64 缓存*数组
    缓存数量,
    缓存容量,
}

函数 缓存存储_创建() {
    定义 cs = 堆_分配(缓存存储)
    cs.缓存容量 = 32
    cs.缓存列表 = 堆_分配_数组(32 * 8)
    cs.缓存数量 = 0
    返回 cs
}

函数 缓存存储_open(cs, 名称) {
    // 查找已有
    定义 可变 i = 0
    当 (i < cs.缓存数量) {
        定义 c = 内存_读64(cs.缓存列表 + i * 8)
        如果 (c != 0 && 字符串_相等(c.名称, 名称)) { 返回 c }
        i = i + 1
    }
    // 创建新缓存
    定义 c = 堆_分配(缓存)
    c.名称 = 字符串_复制(名称)
    c.条目容量 = 256
    c.条目列表 = 堆_分配_数组(256 * 8)
    c.条目数量 = 0
    如果 (cs.缓存数量 < cs.缓存容量) {
        内存_写64(cs.缓存列表 + cs.缓存数量 * 8, c)
        cs.缓存数量 = cs.缓存数量 + 1
    }
    返回 c
}

函数 缓存存储_has(cs, 名称) {
    定义 可变 i = 0
    当 (i < cs.缓存数量) {
        定义 c = 内存_读64(cs.缓存列表 + i * 8)
        如果 (c != 0 && 字符串_相等(c.名称, 名称)) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 缓存存储_delete(cs, 名称) {
    定义 可变 i = 0
    当 (i < cs.缓存数量) {
        定义 c = 内存_读64(cs.缓存列表 + i * 8)
        如果 (c != 0 && 字符串_相等(c.名称, 名称)) {
            // 移除(用最后一个填充)
            cs.缓存数量 = cs.缓存数量 - 1
            内存_写64(cs.缓存列表 + i * 8, 内存_读64(cs.缓存列表 + cs.缓存数量 * 8))
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 缓存存储_keys(cs) {
    // 返回所有缓存名称
    定义 结果 = 堆_分配_数组(cs.缓存数量 * 8)
    定义 可变 i = 0
    当 (i < cs.缓存数量) {
        定义 c = 内存_读64(cs.缓存列表 + i * 8)
        如果 (c != 0) { 内存_写64(结果 + i * 8, c.名称) }
        i = i + 1
    }
    返回 [结果, cs.缓存数量]
}

函数 缓存存储_match(cs, 请求URL) {
    // 在所有缓存中查找匹配
    定义 可变 i = 0
    当 (i < cs.缓存数量) {
        定义 c = 内存_读64(cs.缓存列表 + i * 8)
        定义 结果 = 缓存_match(c, 请求URL, 0)
        如果 (结果 != 0) { 返回 结果 }
        i = i + 1
    }
    返回 0
}

函数 缓存_put(cache, 请求URL, 响应状态, 响应头, 响应体, 响应体长度) {
    如果 (cache == 0) { 返回 }
    // 更新已有
    定义 可变 i = 0
    当 (i < cache.条目数量) {
        定义 entry偏移 = cache.条目列表 + i * 8
        定义 entry = 内存_读64(entry偏移)
        如果 (entry != 0 && 字符串_相等(entry.请求URL, 请求URL)) {
            // 更新
            entry.响应状态码 = 响应状态
            如果 (响应头 != 0) { entry.响应头 = 字符串_复制(响应头) }
            如果 (响应体 != 0 && 响应体长度 > 0) {
                entry.响应体 = 堆_分配(响应体长度)
                内存_复制(entry.响应体, 响应体, 响应体长度)
                entry.响应体长度 = 响应体长度
            }
            entry.时间戳 = 平台_获取高精度时间()
            返回
        }
        i = i + 1
    }
    // 新增
    如果 (cache.条目数量 >= cache.条目容量) { 返回 }
    定义 entry = 堆_分配(缓存Entry)
    entry.请求URL = 字符串_复制(请求URL)
    entry.请求方法 = "GET"
    entry.响应状态码 = 响应状态
    entry.响应头 = 响应头 != 0 ? 字符串_复制(响应头) : 0
    如果 (响应体 != 0 && 响应体长度 > 0) {
        entry.响应体 = 堆_分配(响应体长度)
        内存_复制(entry.响应体, 响应体, 响应体长度)
        entry.响应体长度 = 响应体长度
    } 否则 { entry.响应体 = 0; entry.响应体长度 = 0 }
    entry.时间戳 = 平台_获取高精度时间()
    内存_写64(cache.条目列表 + cache.条目数量 * 8, entry)
    cache.条目数量 = cache.条目数量 + 1
}

函数 缓存_match(cache, 请求URL, 选项) {
    如果 (cache == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < cache.条目数量) {
        定义 entry = 内存_读64(cache.条目列表 + i * 8)
        如果 (entry != 0) {
            // 默认: 精确URL匹配
            定义 可变 匹配 = 字符串_相等(entry.请求URL, 请求URL)
            // ignoreSearch选项: 忽略query string
            如果 (!匹配 && 选项 != 0) {
                // 忽略查询参数进行URL匹配
            }
            如果 (匹配) { 返回 entry }
        }
        i = i + 1
    }
    返回 0
}

函数 缓存_delete(cache, 请求URL) {
    如果 (cache == 0) { 返回 假 }
    定义 可变 i = 0
    当 (i < cache.条目数量) {
        定义 entry = 内存_读64(cache.条目列表 + i * 8)
        如果 (entry != 0 && 字符串_相等(entry.请求URL, 请求URL)) {
            cache.条目数量 = cache.条目数量 - 1
            内存_写64(cache.条目列表 + i * 8, 内存_读64(cache.条目列表 + cache.条目数量 * 8))
            返回 真
        }
        i = i + 1
    }
    返回 假
}

定义 可变 AI_软件拦截缓_调用数 = 0
定义 可变 AI_软件拦截缓_异常数 = 0

函数 AI_软件拦截缓_监控() {
    AI_软件拦截缓_调用数 = AI_软件拦截缓_调用数 + 1
    返回 AI_软件拦截缓_异常数 == 0
}

函数 AI_软件拦截缓_健康检查() {
    如果 (AI_软件拦截缓_调用数 > 0 && AI_软件拦截缓_异常数 * 100 / AI_软件拦截缓_调用数 > 10) {
        返回 假
    }
    返回 真
}

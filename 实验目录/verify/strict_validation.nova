导入("../core/theory_core.nova")
导入("../exp/theory_experiments.nova")
导入("../backfeed/replacement_map.nova")
导入("./stress_validation.nova")

定义 可变 验证_总领先 = 0

函数 验证_打印(级别, 文本) {
    打印("[实验目录][" + 理论_等级文本(级别) + "] " + 文本)
}

函数 验证_断言(条件, 级别, 文本) {
    如果 (!条件) {
        验证_打印(级别, 文本)
        返回 假
    }
    返回 真
}

函数 验证_边界一致性() {
    定义 可变 通过 = 真
    定义 样本 = [
        ["记忆晶化", 原创_记忆晶化保持率(900, 200, 500, 800, 700, 600, 200)],
        ["意图势场", 原创_意图势场评分(900, 800, 700, 200, 180, 160)],
        ["双环学习", 原创_双环学习增益(820, 760, 740, 720, 200)],
        ["认知几何", 原创_认知几何质量(840, 760, 650, 820, 300)],
        ["意图锁定", 原创_意图锁定质量(880, 820, 760, 180, 700, 160)],
        ["链式回溯", 原创_链式验证回溯质量(840, 780, 760, 720, 680, 180)],
        ["认知检索", 原创_认知检索质量(860, 780, 800, 760, 220, 160)],
        ["自适应学习", 原创_双环自适应学习质量(820, 780, 760, 740, 220, 180)],
        ["策略稳态", 原创_外环策略稳态质量(840, 720, 760, 700, 240, 180)],
        ["演化闭环", 原创_演化闭环质量(700, 580, 620, 560, 600, 680, 620, 240, 180)],
        ["信息几何搜索", 原创_信息几何搜索质量(780, 760, 720, 700, 760, 180)],
        ["自指验证", 原创_自指验证质量(760, 780, 820, 760, 740, 180)]
    ]
    定义 可变 i = 0
    当 (i < 计数(样本)) {
        定义 项 = 样本[i]
        如果 (!验证_断言(项[1] >= 0 && 项[1] <= 1000, 警告_致命, 项[0] + " 输出越界")) {
            通过 = 假
        }
        i = i + 1
    }
    如果 (通过) { 验证_打印(警告_信息, "边界一致性通过") }
    返回 通过
}

函数 验证_单调性() {
    定义 可变 通过 = 真
    定义 记忆_低 = 原创_记忆晶化保持率(800, 200, 400, 300, 500, 500, 200)
    定义 记忆_高 = 原创_记忆晶化保持率(800, 200, 400, 900, 500, 500, 200)
    如果 (!验证_断言(记忆_高 > 记忆_低, 警告_致命, "记忆晶化理论不满足共振增强单调性")) {
        通过 = 假
    }
    定义 势场_差 = 原创_意图势场评分(860, 780, 720, 420, 180, 160)
    定义 势场_优 = 原创_意图势场评分(860, 780, 720, 120, 180, 160)
    如果 (!验证_断言(势场_优 > 势场_差, 警告_致命, "意图势场理论不满足低漂移更优")) {
        通过 = 假
    }
    定义 学习_弱 = 原创_双环学习增益(760, 700, 680, 300, 220)
    定义 学习_强 = 原创_双环学习增益(760, 700, 680, 820, 220)
    如果 (!验证_断言(学习_强 > 学习_弱, 警告_致命, "双环学习理论不满足稳态保护增强")) {
        通过 = 假
    }
    定义 几何_弱 = 原创_认知几何质量(800, 720, 620, 300, 260)
    定义 几何_强 = 原创_认知几何质量(800, 720, 620, 860, 260)
    如果 (!验证_断言(几何_强 > 几何_弱, 警告_致命, "认知几何理论不满足索引一致增强")) {
        通过 = 假
    }
    定义 锁定_弱 = 原创_意图锁定质量(820, 620, 700, 260, 600, 180)
    定义 锁定_强 = 原创_意图锁定质量(820, 860, 700, 120, 760, 180)
    如果 (!验证_断言(锁定_强 > 锁定_弱, 警告_致命, "意图锁定理论不满足低漂移高原型更优")) {
        通过 = 假
    }
    定义 链式_弱 = 原创_链式验证回溯质量(780, 640, 620, 520, 650, 220)
    定义 链式_强 = 原创_链式验证回溯质量(780, 820, 820, 760, 650, 220)
    如果 (!验证_断言(链式_强 > 链式_弱, 警告_致命, "链式回溯理论不满足验证增强")) {
        通过 = 假
    }
    定义 检索_弱 = 原创_认知检索质量(800, 700, 620, 620, 260, 180)
    定义 检索_强 = 原创_认知检索质量(800, 700, 860, 820, 260, 180)
    如果 (!验证_断言(检索_强 > 检索_弱, 警告_致命, "认知检索理论不满足草图一致增强")) {
        通过 = 假
    }
    定义 自适应_弱 = 原创_双环自适应学习质量(760, 700, 520, 560, 240, 220)
    定义 自适应_强 = 原创_双环自适应学习质量(760, 700, 820, 820, 240, 220)
    如果 (!验证_断言(自适应_强 > 自适应_弱, 警告_致命, "自适应学习理论不满足双环增强")) {
        通过 = 假
    }
    定义 策略_弱 = 原创_外环策略稳态质量(780, 620, 560, 520, 260, 220)
    定义 策略_强 = 原创_外环策略稳态质量(780, 620, 820, 760, 260, 220)
    如果 (!验证_断言(策略_强 > 策略_弱, 警告_致命, "策略稳态理论不满足外环增强")) {
        通过 = 假
    }
    定义 演化_弱 = 原创_演化闭环质量(560, 500, 540, 500, 520, 580, 560, 300, 260)
    定义 演化_强 = 原创_演化闭环质量(780, 700, 760, 720, 740, 820, 780, 180, 120)
    如果 (!验证_断言(演化_强 > 演化_弱, 警告_致命, "演化闭环理论不满足门禁增强")) {
        通过 = 假
    }
    定义 几何搜_弱 = 原创_信息几何搜索质量(620, 560, 540, 500, 620, 280)
    定义 几何搜_强 = 原创_信息几何搜索质量(820, 800, 780, 760, 780, 160)
    如果 (!验证_断言(几何搜_强 > 几何搜_弱, 警告_致命, "信息几何搜索理论不满足几何一致增强")) {
        通过 = 假
    }
    定义 自指_弱 = 原创_自指验证质量(560, 540, 600, 560, 520, 280)
    定义 自指_强 = 原创_自指验证质量(820, 800, 860, 800, 760, 160)
    如果 (!验证_断言(自指_强 > 自指_弱, 警告_致命, "自指验证理论不满足见证增强")) {
        通过 = 假
    }
    定义 记忆_共振序列 = [
        原创_记忆晶化保持率(620, 260, 360, 180, 560, 520, 220),
        原创_记忆晶化保持率(620, 260, 360, 420, 560, 520, 220),
        原创_记忆晶化保持率(620, 260, 360, 660, 560, 520, 220)
    ]
    如果 (!验证_序列严格递增("记忆晶化", 记忆_共振序列, "共振增强")) { 通过 = 假 }
    定义 势场_漂移序列 = [
        原创_意图势场评分(760, 660, 620, 420, 200, 200),
        原创_意图势场评分(760, 660, 620, 260, 200, 200),
        原创_意图势场评分(760, 660, 620, 120, 200, 200)
    ]
    如果 (!验证_序列严格递增("意图势场", 势场_漂移序列, "低漂移增强")) { 通过 = 假 }
    定义 学习_稳态序列 = [
        原创_双环学习增益(680, 640, 620, 180, 240),
        原创_双环学习增益(680, 640, 620, 420, 240),
        原创_双环学习增益(680, 640, 620, 660, 240)
    ]
    如果 (!验证_序列严格递增("双环学习", 学习_稳态序列, "稳态保护增强")) { 通过 = 假 }
    定义 几何_索引序列 = [
        原创_认知几何质量(700, 660, 580, 220, 260),
        原创_认知几何质量(700, 660, 580, 460, 260),
        原创_认知几何质量(700, 660, 580, 700, 260)
    ]
    如果 (!验证_序列严格递增("认知几何", 几何_索引序列, "索引一致增强")) { 通过 = 假 }
    定义 锁定_原型序列 = [
        原创_意图锁定质量(760, 420, 660, 220, 620, 180),
        原创_意图锁定质量(760, 620, 660, 220, 620, 180),
        原创_意图锁定质量(760, 760, 660, 220, 620, 180)
    ]
    如果 (!验证_序列严格递增("意图锁定", 锁定_原型序列, "语义原型增强")) { 通过 = 假 }
    定义 链式_验证序列 = [
        原创_链式验证回溯质量(720, 660, 360, 620, 620, 220),
        原创_链式验证回溯质量(720, 660, 560, 620, 620, 220),
        原创_链式验证回溯质量(720, 660, 740, 620, 620, 220)
    ]
    如果 (!验证_序列严格递增("链式回溯", 链式_验证序列, "中间验证增强")) { 通过 = 假 }
    定义 检索_草图序列 = [
        原创_认知检索质量(720, 680, 360, 680, 240, 180),
        原创_认知检索质量(720, 680, 540, 680, 240, 180),
        原创_认知检索质量(720, 680, 720, 680, 240, 180)
    ]
    如果 (!验证_序列严格递增("认知检索", 检索_草图序列, "草图一致增强")) { 通过 = 假 }
    定义 自适应_外环序列 = [
        原创_双环自适应学习质量(620, 660, 360, 620, 240, 220),
        原创_双环自适应学习质量(620, 660, 540, 620, 240, 220),
        原创_双环自适应学习质量(620, 660, 700, 620, 240, 220)
    ]
    如果 (!验证_序列严格递增("自适应学习", 自适应_外环序列, "外环调度增强")) { 通过 = 假 }
    定义 策略_熵序列 = [
        原创_外环策略稳态质量(720, 620, 360, 620, 280, 220),
        原创_外环策略稳态质量(720, 620, 520, 620, 280, 220),
        原创_外环策略稳态质量(720, 620, 680, 620, 280, 220)
    ]
    如果 (!验证_序列严格递增("策略稳态", 策略_熵序列, "熵稳态增强")) { 通过 = 假 }
    定义 演化_门禁序列 = [
        原创_演化闭环质量(620, 520, 620, 600, 640, 260, 620, 240, 220),
        原创_演化闭环质量(620, 520, 620, 600, 640, 420, 620, 240, 220),
        原创_演化闭环质量(620, 520, 620, 600, 640, 580, 620, 240, 220)
    ]
    如果 (!验证_序列严格递增("演化闭环", 演化_门禁序列, "沙盒门禁增强")) { 通过 = 假 }
    定义 几何搜_Fisher序列 = [
        原创_信息几何搜索质量(620, 360, 620, 600, 620, 240),
        原创_信息几何搜索质量(620, 520, 620, 600, 620, 240),
        原创_信息几何搜索质量(620, 680, 620, 600, 620, 240)
    ]
    如果 (!验证_序列严格递增("信息几何搜索", 几何搜_Fisher序列, "Fisher一致增强")) { 通过 = 假 }
    定义 自指_见证序列 = [
        原创_自指验证质量(680, 320, 700, 640, 660, 240),
        原创_自指验证质量(680, 500, 700, 640, 660, 240),
        原创_自指验证质量(680, 680, 700, 640, 660, 240)
    ]
    如果 (!验证_序列严格递增("自指验证", 自指_见证序列, "见证有效增强")) { 通过 = 假 }
    如果 (通过) { 验证_打印(警告_信息, "单调性验证通过") }
    返回 通过
}

函数 验证_序列严格递增(名称, 序列, 说明) {
    定义 可变 通过 = 真
    定义 可变 前值 = 序列[0]
    定义 可变 i = 1
    当 (i < 计数(序列)) {
        如果 (!验证_断言(序列[i] > 前值, 警告_致命, 名称 + " " + 说明 + " 扫描不满足严格递增")) {
            通过 = 假
        }
        前值 = 序列[i]
        i = i + 1
    }
    返回 通过
}

函数 验证_序列严格递减(名称, 序列, 说明) {
    定义 可变 通过 = 真
    定义 可变 前值 = 序列[0]
    定义 可变 i = 1
    当 (i < 计数(序列)) {
        如果 (!验证_断言(序列[i] < 前值, 警告_致命, 名称 + " " + 说明 + " 扫描不满足严格递减")) {
            通过 = 假
        }
        前值 = 序列[i]
        i = i + 1
    }
    返回 通过
}

函数 验证_结果组出现次数(结果列表, 名称) {
    定义 可变 次数 = 0
    定义 可变 i = 0
    当 (i < 计数(结果列表)) {
        如果 (结果列表[i][0] == 名称) { 次数 = 次数 + 1 }
        i = i + 1
    }
    返回 次数
}

函数 验证_结果包含组(结果列表, 名称) {
    定义 可变 i = 0
    当 (i < 计数(结果列表)) {
        如果 (结果列表[i][0] == 名称) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 验证_实验覆盖完整(结果列表) {
    定义 可变 通过 = 真
    定义 期望组 = [
        "记忆晶化",
        "意图势场",
        "双环学习",
        "认知几何",
        "意图锁定",
        "链式回溯",
        "认知检索",
        "自适应学习",
        "策略稳态",
        "演化闭环",
        "信息几何搜索",
        "自指验证"
    ]
    如果 (!验证_断言(计数(结果列表) == 计数(期望组), 警告_致命, "实验组数量不完整")) {
        通过 = 假
    }
    定义 可变 i = 0
    当 (i < 计数(期望组)) {
        如果 (!验证_断言(验证_结果包含组(结果列表, 期望组[i]), 警告_致命, 期望组[i] + " 组未进入实验总链")) {
            通过 = 假
        }
        如果 (i < 计数(结果列表)) {
            如果 (!验证_断言(结果列表[i][0] == 期望组[i], 警告_致命, 期望组[i] + " 组顺序漂移")) {
                通过 = 假
            }
        }
        如果 (!验证_断言(验证_结果组出现次数(结果列表, 期望组[i]) == 1, 警告_致命, 期望组[i] + " 组重复或缺失")) {
            通过 = 假
        }
        i = i + 1
    }
    如果 (!验证_断言(覆盖_矩阵数量() == 13, 警告_致命, "覆盖矩阵数量漂移")) {
        通过 = 假
    }
    如果 (!验证_断言(覆盖_矩阵_可替换数量() == 5, 警告_致命, "可替换矩阵数量漂移")) {
        通过 = 假
    }
    如果 (!验证_断言(覆盖_矩阵_需合并数量() == 5, 警告_致命, "需合并矩阵数量漂移")) {
        通过 = 假
    }
    如果 (!验证_断言(覆盖_矩阵_需保留数量() == 3, 警告_致命, "需保留矩阵数量漂移")) {
        通过 = 假
    }
    如果 (!验证_断言(反哺_提取数量() == 覆盖_矩阵_可替换数量(), 警告_致命, "反哺提取数量与可替换矩阵不一致")) {
        通过 = 假
    }
    i = 0
    当 (i < 覆盖_矩阵_可替换数量() + 覆盖_矩阵_需合并数量()) {
        定义 实验组 = 验证_矩阵对应实验组(i)
        如果 (!验证_断言(实验组 != "", 警告_致命, "覆盖矩阵映射缺失: 序号" + 转字符串(i))) {
            通过 = 假
        } 否则 如果 (!验证_断言(验证_结果包含组(结果列表, 实验组), 警告_致命, 覆盖_矩阵_目标文件(i) + " 未被实验组接住")) {
            通过 = 假
        }
        i = i + 1
    }
    如果 (通过) { 验证_打印(警告_信息, "实验覆盖完整验证通过") }
    返回 通过
}

函数 验证_打印实验结果(结果列表) {
    定义 可变 i = 0
    当 (i < 计数(结果列表)) {
        定义 r = 结果列表[i]
        打印("[实验目录][结果] " + r[0] + " 旧总分=" + 转字符串(r[1]) + " 新总分=" + 转字符串(r[2]) + " 领先=" + 转字符串(r[5]) + " 通过=" + 转字符串(r[3]) + "/" + 转字符串(r[4]))
        i = i + 1
    }
}

函数 验证_实验领先(结果列表) {
    定义 可变 通过 = 真
    验证_总领先 = 0
    定义 可变 i = 0
    当 (i < 计数(结果列表)) {
        定义 r = 结果列表[i]
        验证_总领先 = 验证_总领先 + r[5]
        如果 (!验证_断言(r[3] == r[4], 警告_致命, r[0] + " 没有在全部用例上领先基线")) {
            通过 = 假
        }
        如果 (!验证_断言(r[2] > r[1], 警告_致命, r[0] + " 总分未领先旧理论")) {
            通过 = 假
        }
        如果 (!验证_断言(r[5] >= 理论_单组最小领先(), 警告_高, r[0] + " 领先幅度不足")) {
            通过 = 假
        }
        i = i + 1
    }
    如果 (!验证_断言(验证_总领先 >= 理论_总体最小领先(), 警告_致命, "总体领先值不足, 禁止反哺替换")) {
        通过 = 假
    }
    如果 (通过) {
        验证_打印(警告_信息, "实验领先验证通过")
    }
    如果 (通过) { 返回 1 }
    返回 0
}

函数 验证_运行全部() {
    定义 可变 通过 = 真
    如果 (!验证_边界一致性()) { 通过 = 假 }
    如果 (!验证_单调性()) { 通过 = 假 }
    如果 (压力验证_运行全部() != 0) { 通过 = 假 }
    定义 结果列表 = 实验_运行全部()
    如果 (!验证_实验覆盖完整(结果列表)) { 通过 = 假 }
    验证_打印实验结果(结果列表)
    如果 (!验证_实验领先(结果列表)) { 通过 = 假 }
    如果 (!通过) {
        验证_打印(警告_致命, "最严格多重验证失败")
        返回 1
    }
    验证_打印(警告_信息, "最严格多重验证通过")
    返回 0
}

函数 验证_获取总领先() {
    返回 验证_总领先
}

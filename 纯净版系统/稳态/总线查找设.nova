定义 PCI_REG_厂商 = 0x00
定义 PCI_REG_设备 = 0x02
定义 PCI_REG_命令 = 0x04
定义 PCI_REG_状态 = 0x06
定义 PCI_REG_修订 = 0x08
定义 PCI_REG_类代码 = 0x0B
定义 PCI_REG_BAR0 = 0x10
定义 PCI_REG_能力指针 = 0x34
定义 PCI_CMD_IO使能 = 0x01
定义 PCI_CMD_内存使能 = 0x02
定义 PCI_CMD_总线主控 = 0x04
定义 PCI_CMD_中断禁用 = 0x400

定义 PCI_CAP_电源管理 = 0x01
定义 PCI_CAP_MSI = 0x05
定义 PCI_CAP_MSIX = 0x11
定义 PCI_CAP_PCIE = 0x10

定义 PCI_电源_D0 = 0
定义 PCI_电源_D1 = 1
定义 PCI_电源_D2 = 2
定义 PCI_电源_D3 = 3

外部 PCI设备列表
外部 PCI设备数量

定义 可变 PCI_查找次数 = 0
定义 可变 PCI_MSI配置数 = 0
定义 可变 PCI_BAR映射数 = 0
定义 可变 PCI_热插拔事件 = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 PCI_查找设备(厂商ID, 设备ID) {
    PCI_查找次数 = PCI_查找次数 + 1
    定义 可变 i = 0
    当 (i < PCI设备数量) {
        定义 dev = PCI设备列表[i]
        如果 (dev.厂商ID == 厂商ID && dev.设备ID == 设备ID) {
            返回 dev
        }
        i = i + 1
    }
    返回 空
}

函数 PCI_查找类(类代码, 子类代码) {
    PCI_查找次数 = PCI_查找次数 + 1
    定义 可变 i = 0
    当 (i < PCI设备数量) {
        定义 dev = PCI设备列表[i]
        如果 (dev.类代码 == 类代码 && dev.子类代码 == 子类代码) {
            返回 dev
        }
        i = i + 1
    }
    返回 空
}

函数 PCI_查找所有类(类代码, 子类代码) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < PCI设备数量) {
        定义 dev = PCI设备列表[i]
        如果 (dev.类代码 == 类代码 && dev.子类代码 == 子类代码) {
            追加(结果, dev)
        }
        i = i + 1
    }
    返回 结果
}

函数 PCI_查找厂商(厂商ID) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < PCI设备数量) {
        定义 dev = PCI设备列表[i]
        如果 (dev.厂商ID == 厂商ID) {
            追加(结果, dev)
        }
        i = i + 1
    }
    返回 结果
}

函数 PCI_读BAR(dev, BAR索引) {
    如果 (dev == 空 || BAR索引 > 5) { 返回 0 }
    定义 偏移 = PCI_REG_BAR0 + BAR索引 * 4
    定义 原始值 = PCI设备_读32(dev, 偏移)

    如果 (原始值 & 1) {
        返回 原始值 & 0xFFFFFFFC
    } 否则 {
        返回 原始值 & 0xFFFFFFF0
    }
}

函数 PCI_BAR大小(dev, BAR索引) {
    如果 (dev == 空 || BAR索引 > 5) { 返回 0 }
    定义 偏移 = PCI_REG_BAR0 + BAR索引 * 4
    定义 原始值 = PCI设备_读32(dev, 偏移)

    PCI设备_写32(dev, 偏移, 0xFFFFFFFF)
    定义 大小值 = PCI设备_读32(dev, 偏移)
    PCI设备_写32(dev, 偏移, 原始值)

    如果 (原始值 & 1) {
        大小值 = 大小值 & 0xFFFFFFFC
    } 否则 {
        大小值 = 大小值 & 0xFFFFFFF0
    }
    如果 (大小值 == 0) { 返回 0 }
    返回 (~大小值) + 1
}

函数 PCI_BAR是内存(dev, BAR索引) {
    如果 (dev == 空 || BAR索引 > 5) { 返回 假 }
    定义 偏移 = PCI_REG_BAR0 + BAR索引 * 4
    返回 (PCI设备_读32(dev, 偏移) & 1) == 0
}

函数 PCI_使能设备(dev) {
    如果 (dev == 空) { 返回 错误码_无效参数 }
    定义 cmd = PCI设备_读16(dev, PCI_REG_命令)
    cmd = cmd | PCI_CMD_IO使能 | PCI_CMD_内存使能 | PCI_CMD_总线主控
    PCI设备_写16(dev, PCI_REG_命令, cmd)
    返回 0
}

函数 PCI_禁用设备(dev) {
    如果 (dev == 空) { 返回 错误码_无效参数 }
    定义 cmd = PCI设备_读16(dev, PCI_REG_命令)
    cmd = cmd & ~(PCI_CMD_IO使能 | PCI_CMD_内存使能 | PCI_CMD_总线主控)
    PCI设备_写16(dev, PCI_REG_命令, cmd)
    返回 0
}

函数 PCI_查找能力(dev, 能力ID) {
    如果 (dev == 空) { 返回 0 }
    定义 状态 = PCI设备_读16(dev, PCI_REG_状态)
    如果 ((状态 & 0x10) == 0) { 返回 0 }

    定义 可变 偏移 = PCI设备_读8(dev, PCI_REG_能力指针) & 0xFC
    定义 可变 遍历 = 0
    当 (偏移 != 0 && 遍历 < 48) {
        定义 id = PCI设备_读8(dev, 偏移)
        如果 (id == 能力ID) { 返回 偏移 }
        偏移 = PCI设备_读8(dev, 偏移 + 1) & 0xFC
        遍历 = 遍历 + 1
    }
    返回 0
}

函数 PCI_使能MSI(dev, 向量号) {
    如果 (dev == 空) { 返回 错误码_无效参数 }
    定义 偏移 = PCI_查找能力(dev, PCI_CAP_MSI)
    如果 (偏移 == 0) { 返回 错误码_不支持 }

    定义 控制 = PCI设备_读16(dev, 偏移 + 2)

    定义 地址 = 0xFEE00000 | (接口C_获取ID() << 12)
    PCI设备_写32(dev, 偏移 + 4, 地址)

    如果 (控制 & 0x80) {
        PCI设备_写32(dev, 偏移 + 8, 0)
        PCI设备_写16(dev, 偏移 + 12, 向量号)
    } 否则 {
        PCI设备_写16(dev, 偏移 + 8, 向量号)
    }

    PCI设备_写16(dev, 偏移 + 2, 控制 | 0x01)

    定义 cmd = PCI设备_读16(dev, PCI_REG_命令)
    PCI设备_写16(dev, PCI_REG_命令, cmd | PCI_CMD_中断禁用)

    PCI_MSI配置数 = PCI_MSI配置数 + 1
    返回 0
}

函数 PCI_使能MSIX(dev, 表项数) {
    如果 (dev == 空) { 返回 错误码_无效参数 }
    定义 偏移 = PCI_查找能力(dev, PCI_CAP_MSIX)
    如果 (偏移 == 0) { 返回 错误码_不支持 }

    定义 控制 = PCI设备_读16(dev, 偏移 + 2)
    定义 表大小 = (控制 & 0x7FF) + 1
    如果 (表项数 > 表大小) { 表项数 = 表大小 }

    PCI设备_写16(dev, 偏移 + 2, 控制 | 0x8000)

    定义 cmd = PCI设备_读16(dev, PCI_REG_命令)
    PCI设备_写16(dev, PCI_REG_命令, cmd | PCI_CMD_中断禁用)

    PCI_MSI配置数 = PCI_MSI配置数 + 1
    返回 0
}

函数 PCI_设置电源状态(dev, 状态) {
    如果 (dev == 空) { 返回 错误码_无效参数 }
    定义 偏移 = PCI_查找能力(dev, PCI_CAP_电源管理)
    如果 (偏移 == 0) { 返回 错误码_不支持 }

    定义 pmcsr = PCI设备_读16(dev, 偏移 + 4)
    pmcsr = (pmcsr & 0xFFFC) | (状态 & 0x03)
    PCI设备_写16(dev, 偏移 + 4, pmcsr)

    如果 (状态 == PCI_电源_D0) {
        // D3→D0需要等待10ms
        延迟微秒(10000)
    }
    返回 0
}

函数 PCI_获取电源状态(dev) {
    如果 (dev == 空) { 返回 -1 }
    定义 偏移 = PCI_查找能力(dev, PCI_CAP_电源管理)
    如果 (偏移 == 0) { 返回 -1 }
    返回 PCI设备_读16(dev, 偏移 + 4) & 0x03
}

函数 PCI_功能级复位(dev) {
    如果 (dev == 空) { 返回 错误码_无效参数 }
    定义 偏移 = PCI_查找能力(dev, PCI_CAP_PCIE)
    如果 (偏移 == 0) { 返回 错误码_不支持 }

    定义 devctl = PCI设备_读16(dev, 偏移 + 8)
    PCI设备_写16(dev, 偏移 + 8, devctl | 0x8000)
    延迟微秒(100000)
    返回 0
}

函数 PCI_热插拔检测() {
    定义 可变 i = 0
    当 (i < 256) {
        定义 可变 dev = 0
        当 (dev < 32) {
            定义 厂商 = PCI_配置读16(i, dev, 0, PCI_REG_厂商)
            如果 (厂商 != 0xFFFF && 厂商 != 0) {
                定义 已知 = PCI_查找设备(厂商, PCI_配置读16(i, dev, 0, PCI_REG_设备))
                如果 (已知 == 空) {
                    PCI_热插拔事件 = PCI_热插拔事件 + 1
                    内核调试("PCI: 检测到新设备 总线=" + 整数转字符串(i) + " 设备=" + 整数转字符串(dev))
                }
            }
            dev = dev + 1
        }
        i = i + 1
    }
}

函数 PCI_打印设备信息(dev) {
    如果 (dev == 空) { 返回 }
    内核调试("PCI设备: " + 整数转16进制(dev.厂商ID) + ":" + 整数转16进制(dev.设备ID))
    内核调试("  类: " + 整数转16进制(dev.类代码) + ":" + 整数转16进制(dev.子类代码))
    内核调试("  中断: IRQ " + 整数转字符串(dev.中断线))
    定义 可变 bar = 0
    当 (bar < 6) {
        定义 基址 = PCI_读BAR(dev, bar)
        如果 (基址 != 0) {
            定义 大小 = PCI_BAR大小(dev, bar)
            内核调试("  BAR" + 整数转字符串(bar) + ": " + 整数转16进制(基址) + " 大小=" + 整数转字符串(大小))
        }
        bar = bar + 1
    }
}

函数 PCI_完整统计() {
    返回 {
        设备总数: PCI设备数量,
        查找次数: PCI_查找次数,
        MSI配置: PCI_MSI配置数,
        BAR映射: PCI_BAR映射数,
        热插拔事件: PCI_热插拔事件
    }
}

// PCI总线健康检查

函数 PCI_健康检查() {
    定义 可变 问题 = []
    如果 (PCI设备数量 == 0) { 追加(问题, "未发现PCI设备") }
    如果 (PCI_热插拔事件 > 100) {
        追加(问题, "热插拔事件过多: " + 整数转字符串(PCI_热插拔事件))
    }
    如果 (计数(问题) == 0) { 返回 "PCI总线健康" }
    返回 问题
}

函数 PCI_设备存在(总线, 设备, 功能) {
    定义 地址 = (总线 << 16) | (设备 << 11) | (功能 << 8)
    定义 值 = PCI_配置读32(地址)
    如果 (值 == 0xFFFFFFFF) { 返回 假 }
    返回 真
}

函数 PCI_读取厂商ID(总线, 设备, 功能) {
    定义 地址 = (总线 << 16) | (设备 << 11) | (功能 << 8)
    返回 PCI_配置读32(地址) & 0xFFFF
}

定义 可变 AI_总线查找设_运行指标 = 0
定义 可变 AI_总线查找设_异常指标 = 0

函数 AI_总线查找设_自诊断() {
    AI_总线查找设_运行指标 = PCI_查找次数
    返回 AI_总线查找设_运行指标
}

函数 AI_总线查找设_优化建议() {
    定义 指标 = AI_总线查找设_自诊断()
    如果 (AI_总线查找设_运行指标 > 10000) { 返回 "总线查找设负载较高" }
    返回 "总线查找设状态正常"
}

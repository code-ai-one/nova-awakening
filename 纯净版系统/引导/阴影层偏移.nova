导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("./端口输入.nova")

定义 对话x = 100
定义 对话y = 50
定义 对话w = 380
定义 对话h = 440

// 阴影层 (偏移+4, 深暗色)
定义 可变 ws_y = 0
当 (ws_y < 对话h) {
    定义 可变 ws_x = 0
    当 (ws_x < 对话w) {
        内存写32(LFB + (对话y + 4 + ws_y) * 行字节 + (对话x + 4 + ws_x) * 4, 0x00030306)
        ws_x = ws_x + 1
    }
    ws_y = ws_y + 1
}

// 窗口玻璃体 (逐行渐变: 上亮下暗)
定义 可变 dy = 0
当 (dy < 对话h) {
    定义 wg_t = dy * 256 / 对话h
    定义 可变 win_c = 0
    如果 (dy == 0) { win_c = 0x00383E58 }
    否则 如果 (dy < 34) {
        定义 tb_t2 = dy * 256 / 34
        win_c = (22 + (256 - tb_t2) * 10 / 256) * 65536 + (24 + (256 - tb_t2) * 12 / 256) * 256 + (44 + (256 - tb_t2) * 16 / 256)
    }
    否则 如果 (dy == 34) { win_c = 0x00203858 }
    否则 {
        定义 bd_t = (dy - 35) * 256 / (对话h - 35)
        win_c = (12 + (256 - bd_t) * 6 / 256) * 65536 + (16 + (256 - bd_t) * 6 / 256) * 256 + (28 + (256 - bd_t) * 10 / 256)
    }
    定义 可变 dx = 0
    当 (dx < 对话w) {
        内存写32(LFB + (对话y + dy) * 行字节 + (对话x + dx) * 4, win_c)
        dx = dx + 1
    }
    // 左右发光边线 (青蓝微光)
    如果 (dy > 0 && dy < 对话h - 1) {
        内存写32(LFB + (对话y + dy) * 行字节 + 对话x * 4, 0x00182840)
        内存写32(LFB + (对话y + dy) * 行字节 + (对话x + 对话w - 1) * 4, 0x00182840)
    }
    dy = dy + 1
}

// 关闭按钮(渐变红)
定义 可变 cbi = 0
当 (cbi < 12) {
    定义 可变 cbj = 0
    当 (cbj < 12) {
        定义 cb_t = cbj * 256 / 12
        定义 cb_c = (220 + (256 - cb_t) * 30 / 256) * 65536 + (50 + (256 - cb_t) * 20 / 256) * 256 + 50
        内存写32(LFB + (对话y + 10 + cbj) * 行字节 + (对话x + 对话w - 20 + cbi) * 4, cb_c)
        cbj = cbj + 1
    }
    cbi = cbi + 1
}

// 系统消息气泡(渐变暗色)
定义 可变 mb = 0
当 (mb < 34) {
    定义 mb_t = mb * 256 / 34
    定义 mb_c = (22 + (256 - mb_t) * 6 / 256) * 65536 + (30 + (256 - mb_t) * 8 / 256) * 256 + (48 + (256 - mb_t) * 10 / 256)
    定义 可变 mbx = 0
    当 (mbx < 340) {
        内存写32(LFB + (对话y + 44 + mb) * 行字节 + (对话x + 14 + mbx) * 4, mb_c)
        mbx = mbx + 1
    }
    mb = mb + 1
}

// AI回复气泡(蓝紫渐变)
定义 可变 ab = 0
当 (ab < 46) {
    定义 ab_t = ab * 256 / 46
    定义 ab_c = (20 + (256 - ab_t) * 8 / 256) * 65536 + (10 + (256 - ab_t) * 4 / 256) * 256 + (40 + (256 - ab_t) * 12 / 256)
    定义 可变 abx = 0
    当 (abx < 340) {
        内存写32(LFB + (对话y + 88 + ab) * 行字节 + (对话x + 14 + abx) * 4, ab_c)
        abx = abx + 1
    }
    ab = ab + 1
}

// 输入框(渐变凹槽 + 聚焦蓝边)
定义 可变 inb = 0
当 (inb < 30) {
    定义 in_t = inb * 256 / 30
    定义 in_c = (18 + in_t * 4 / 256) * 65536 + (24 + in_t * 4 / 256) * 256 + (38 + in_t * 6 / 256)
    定义 可变 inx = 0
    当 (inx < 对话w - 22) {
        内存写32(LFB + (对话y + 对话h - 42 + inb) * 行字节 + (对话x + 11 + inx) * 4, in_c)
        inx = inx + 1
    }
    inb = inb + 1
}
// 输入框蓝色聚焦边(顶底)
定义 可变 ib_i = 0
当 (ib_i < 对话w - 22) {
    内存写32(LFB + (对话y + 对话h - 42) * 行字节 + (对话x + 11 + ib_i) * 4, 0x002858A0)
    内存写32(LFB + (对话y + 对话h - 13) * 行字节 + (对话x + 11 + ib_i) * 4, 0x002858A0)
    ib_i = ib_i + 1
}

// 发送按钮(蓝色渐变)
定义 可变 sbi = 0
当 (sbi < 54) {
    定义 可变 sbj = 0
    当 (sbj < 26) {
        定义 sb_t = sbj * 256 / 26
        定义 sb_c = (40 + (256 - sb_t) * 20 / 256) * 65536 + (100 + (256 - sb_t) * 30 / 256) * 256 + (220 + (256 - sb_t) * 30 / 256)
        内存写32(LFB + (对话y + 对话h - 40 + sbj) * 行字节 + (对话x + 对话w - 68 + sbi) * 4, sb_c)
        sbj = sbj + 1
    }
    sbi = sbi + 1
}
// 窗口底部发光线
定义 可变 wbl = 0
当 (wbl < 对话w) {
    内存写32(LFB + (对话y + 对话h - 1) * 行字节 + (对话x + wbl) * 4, 0x001B3060)
    wbl = wbl + 1
}

// 对话窗口标题 "AI Assistant"
定义 对话标题 = [65,73,32,65,115,115,105,115,116,97,110,116]
定义 可变 dt_i = 0
当 (dt_i < 12) {
    定义 dt_idx = (对话标题[dt_i] - 32) * 8
    如果 (dt_idx >= 0 && dt_idx < 760) {
        定义 可变 dt_r = 0
        当 (dt_r < 8) {
            定义 dt_rd = 字体[dt_idx + dt_r]
            定义 可变 dt_b = 0
            当 (dt_b < 8) {
                如果 ((dt_rd >> (7 - dt_b)) & 1) {
                    内存写32(LFB + (对话y + 12 + dt_r) * 行字节 + (对话x + 12 + dt_i * 9 + dt_b) * 4, 0x00E0E0E0)
                }
                dt_b = dt_b + 1
            }
            dt_r = dt_r + 1
        }
    }
    dt_i = dt_i + 1
}
// 系统消息 "Welcome to NovaOS"
定义 欢迎语 = [87,101,108,99,111,109,101,32,116,111,32,78,111,118,97,79,83]
定义 可变 wl_i = 0
当 (wl_i < 17) {
    定义 wl_idx = (欢迎语[wl_i] - 32) * 8
    如果 (wl_idx >= 0 && wl_idx < 760) {
        定义 可变 wl_r = 0
        当 (wl_r < 8) {
            定义 wl_rd = 字体[wl_idx + wl_r]
            定义 可变 wl_b = 0
            当 (wl_b < 8) {
                如果 ((wl_rd >> (7 - wl_b)) & 1) {
                    内存写32(LFB + (对话y + 54 + wl_r) * 行字节 + (对话x + 20 + wl_i * 9 + wl_b) * 4, 0x00A0A0A0)
                }
                wl_b = wl_b + 1
            }
            wl_r = wl_r + 1
        }
    }
    wl_i = wl_i + 1
}
// AI回复 "How can I help?"
定义 AI回复 = [72,111,119,32,99,97,110,32,73,32,104,101,108,112,63]
定义 可变 ar_i = 0
当 (ar_i < 15) {
    定义 ar_idx = (AI回复[ar_i] - 32) * 8
    如果 (ar_idx >= 0 && ar_idx < 760) {
        定义 可变 ar_r = 0
        当 (ar_r < 8) {
            定义 ar_rd = 字体[ar_idx + ar_r]
            定义 可变 ar_b = 0
            当 (ar_b < 8) {
                如果 ((ar_rd >> (7 - ar_b)) & 1) {
                    内存写32(LFB + (对话y + 104 + ar_r) * 行字节 + (对话x + 20 + ar_i * 9 + ar_b) * 4, 0x00BB88FF)
                }
                ar_b = ar_b + 1
            }
            ar_r = ar_r + 1
        }
    }
    ar_i = ar_i + 1
}
// 发送按钮文字 "Send"
定义 发送文字 = [83,101,110,100]
定义 可变 sd_i = 0
当 (sd_i < 4) {
    定义 sd_idx = (发送文字[sd_i] - 32) * 8
    如果 (sd_idx >= 0 && sd_idx < 760) {
        定义 可变 sd_r = 0
        当 (sd_r < 8) {
            定义 sd_rd = 字体[sd_idx + sd_r]
            定义 可变 sd_b = 0
            当 (sd_b < 8) {
                如果 ((sd_rd >> (7 - sd_b)) & 1) {
                    内存写32(LFB + (对话y + 对话h - 32 + sd_r) * 行字节 + (对话x + 对话w - 55 + sd_i * 9 + sd_b) * 4, 0x00FFFFFF)
                }
                sd_b = sd_b + 1
            }
            sd_r = sd_r + 1
        }
    }
    sd_i = sd_i + 1
}
打印("[渲染] AI对话窗口+文字 OK")

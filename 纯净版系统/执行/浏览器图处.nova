// NovaOS 浏览器内核 · 第一层 · 图处渲染适配模块
// 直连内核L0 图处驱动，跳过用户态中间层
// 职责: 渲染指令提交、纹理管理、帧缓冲输出、硬件加速合成

定义 命令_填充矩形     = 0
定义 命令_绘制线条     = 1
定义 命令_绘制文字     = 2
定义 命令_绘制图像     = 3
定义 命令_设置裁剪     = 4
定义 命令_清除裁剪     = 5
定义 命令_变换矩阵     = 6
定义 命令_绘制圆角矩形 = 7
定义 命令_绘制阴影     = 8
定义 命令_绘制渐变     = 9
定义 命令_混合模式     = 10
定义 命令_提交帧       = 11

定义 混合_正常     = 0
定义 混合_叠加     = 1
定义 混合_正片叠底 = 2
定义 混合_滤色     = 3

结构 渲染命令 {
    类型,
    x,
    y,
    宽,
    高,
    颜色,
    透明度,    // u32 0-255
    圆角,
    文字,
    字号,
    图像数据,    // u64 图像缓冲地址
    图像宽,
    图像高,
}

结构 图处渲染层 {
    ID,
    x,
    y,
    宽,
    高,
    缓冲地址,    // u64 图处内存地址
    脏,
    透明度,
    混合模式,
    变换,    // [] 2D变换矩阵 [a,b,c,d,e,f]
    命令队列,    // []
}

结构 图处渲染上下文 {
    屏幕宽,
    屏幕高,
    帧缓冲,
    后缓冲,
    层列表,    // []
    下一层ID,
    帧计数,
    图处模式,    // u32 0=CPU回退 1=图处_2D 2=图处_3D
    VSync,
}

定义 可变 图处_上下文 = 空
定义 可变 图处_已初始化 = 假
定义 可变 图处_帧率 = 0
定义 可变 图处_上帧时间 = 0

// §1 初始化 — 直连内核图处驱动

函数 浏览器图处_初始化(宽, 高) {
    图处_上下文 = 图处渲染上下文 {}
    图处_上下文.屏幕宽 = 宽
    图处_上下文.屏幕高 = 高
    图处_上下文.层列表 = []
    图处_上下文.下一层ID = 1
    图处_上下文.帧计数 = 0
    图处_上下文.VSync = 真

    // 直接获取内核帧缓冲地址
    图处_上下文.帧缓冲 = 帧缓冲地址
    图处_上下文.后缓冲 = 伙伴系统_分配(宽 * 高 * 4)

    // 检测图处硬件加速能力
    定义 图处能力 = 图处_查询能力()
    如果 (图处能力 >= 2) {
        图处_上下文.图处模式 = 2    // 图处 3D加速
        内核信息("浏览器图处: 3D硬件加速启用")
    } 否则 如果 (图处能力 >= 1) {
        图处_上下文.图处模式 = 1    // 图处 2D加速
        内核信息("浏览器图处: 2D硬件加速启用")
    } 否则 {
        图处_上下文.图处模式 = 0    // CPU软渲染
        内核信息("浏览器图处: CPU软渲染模式")
    }

    图处_已初始化 = 真
}

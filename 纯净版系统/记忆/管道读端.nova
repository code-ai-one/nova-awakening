导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/安全防护引.nova")
导入("../中枢/同步原语.nova")
导入("../中枢/哈希函数.nova")

定义 管道_缓冲大小 = 65536
定义 Nova事件轮询IN = 0x0001
定义 Nova事件轮询OUT = 0x0004
定义 Nova事件轮询RDNORM = 0x0040
定义 Nova事件轮询WRNORM = 0x0100
定义 Nova事件轮询HUP = 0x0010
定义 Nova事件轮询ERR = 0x0008

定义 可变 管道_总创建数 = 0
定义 可变 管道_总写字节 = 0
定义 可变 管道_总读字节 = 0

函数 管道_可读字节数(管道) {
    如果 (管道 == 空) { 返回 0 }
    如果 (管道.写位 >= 管道.读位) { 返回 管道.写位 - 管道.读位 }
    返回 管道_缓冲大小 - 管道.读位 + 管道.写位
}

函数 管道_可写字节数(管道) {
    如果 (管道 == 空) { 返回 0 }
    返回 管道_缓冲大小 - 管道_可读字节数(管道) - 1
}

函数 管道_读(文件, 用户缓冲, 大小) {
    定义 管道 = 文件.私有数据
    如果 (管道 == 空 || 用户缓冲 == 0) { 返回 错误_无效参数 }

    自旋锁_获取(管道.锁)
    定义 可读 = 管道_可读字节数(管道)
    如果 (可读 == 0) {
        如果 (管道.写者数 == 0) { 自旋锁_释放(管道.锁); 返回 0 }
        如果 (文件.标志 & O_非阻塞) { 自旋锁_释放(管道.锁); 返回 错误_再试 }
        自旋锁_释放(管道.锁)
        等待队列_等待(管道.读等待队列)
        自旋锁_获取(管道.锁)
        可读 = 管道_可读字节数(管道)
    }

    定义 实际大小 = 如果(大小 < 可读, 大小, 可读)
    定义 可变 已读 = 0
    当 (已读 < 实际大小) {
        内存_写8(用户缓冲 + 已读, 内存_读8(管道.缓冲 + 管道.读位))
        管道.读位 = (管道.读位 + 1) % 管道_缓冲大小
        已读 = 已读 + 1
    }

    管道_总读字节 = 管道_总读字节 + 已读
    等待队列_唤醒(管道.写等待队列)
    自旋锁_释放(管道.锁)
    返回 已读
}

函数 管道_写(文件, 用户缓冲, 大小) {
    定义 管道 = 文件.私有数据
    如果 (管道 == 空 || 用户缓冲 == 0) { 返回 错误_无效参数 }

    自旋锁_获取(管道.锁)
    如果 (管道.读者数 == 0) {
        自旋锁_释放(管道.锁)
        进程_发送信号(当前进程(), 13)
        返回 错误_管道断裂
    }

    定义 可变 已写 = 0
    当 (已写 < 大小) {
        定义 可写 = 管道_可写字节数(管道)
        如果 (可写 == 0) {
            等待队列_唤醒(管道.读等待队列)
            如果 (文件.标志 & O_非阻塞) { 自旋锁_释放(管道.锁); 返回 如果(已写 > 0, 已写, 错误_再试) }
            自旋锁_释放(管道.锁)
            等待队列_等待(管道.写等待队列)
            自旋锁_获取(管道.锁)
            继续
        }
        定义 本次 = 如果(大小 - 已写 < 可写, 大小 - 已写, 可写)
        定义 可变 i = 0
        当 (i < 本次) {
            内存_写8(管道.缓冲 + 管道.写位, 内存_读8(用户缓冲 + 已写 + i))
            管道.写位 = (管道.写位 + 1) % 管道_缓冲大小
            i = i + 1
        }
        已写 = 已写 + 本次
    }

    管道_总写字节 = 管道_总写字节 + 已写
    等待队列_唤醒(管道.读等待队列)
    自旋锁_释放(管道.锁)
    返回 已写
}

函数 管道_读端关闭(文件) {
    定义 管道 = 文件.私有数据
    如果 (管道 == 空) { 返回 }
    自旋锁_获取(管道.锁)
    管道.读者数 = 管道.读者数 - 1
    如果 (管道.读者数 == 0) { 等待队列_唤醒(管道.写等待队列) }
    自旋锁_释放(管道.锁)
    如果 (管道.读者数 == 0 && 管道.写者数 == 0) { 管道_销毁(管道) }
}

函数 管道_写端关闭(文件) {
    定义 管道 = 文件.私有数据
    如果 (管道 == 空) { 返回 }
    自旋锁_获取(管道.锁)
    管道.写者数 = 管道.写者数 - 1
    如果 (管道.写者数 == 0) { 等待队列_唤醒(管道.读等待队列) }
    自旋锁_释放(管道.锁)
    如果 (管道.读者数 == 0 && 管道.写者数 == 0) { 管道_销毁(管道) }
}

函数 管道_读端poll(文件) {
    定义 管道 = 文件.私有数据
    定义 可变 事件 = 0
    如果 (管道_可读字节数(管道) > 0) {
        事件 = 事件 | Nova事件轮询IN | Nova事件轮询RDNORM
    }
    如果 (管道.写者数 == 0) {
        事件 = 事件 | Nova事件轮询HUP
    }
    返回 事件
}

函数 管道_写端poll(文件) {
    定义 管道 = 文件.私有数据
    定义 可变 事件 = 0
    如果 (管道_可写字节数(管道) > 0) {
        事件 = 事件 | Nova事件轮询OUT | Nova事件轮询WRNORM
    }
    如果 (管道.读者数 == 0) {
        事件 = 事件 | Nova事件轮询ERR
    }
    返回 事件
}

函数 管道_销毁(管道) {
    如果 (管道 == 空) { 返回 }
    如果 (管道.缓冲 != 0) { 释放内存(管道.缓冲) }
    释放内存(管道)
}

函数 管道_读操作表() {
    返回 { 读: 管道_读, 释放: 管道_读端关闭, poll: 管道_读端poll }
}

函数 管道_写操作表() {
    返回 { 写: 管道_写, 释放: 管道_写端关闭, poll: 管道_写端poll }
}

函数 管道_完整统计() {
    返回 [管道_总创建数, 管道_总写字节, 管道_总读字节]
}

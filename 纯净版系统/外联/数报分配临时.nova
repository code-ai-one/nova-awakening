定义 数报_临时端口起始 = 32768
定义 数报_临时端口结束 = 60999
定义 可变 udp_下一个端口 = 32768

函数 udp_分配临时端口() {
    定义 可变 尝试 = 0
    当 (尝试 < (数报_临时端口结束 - 数报_临时端口起始)) {
        定义 端口 = udp_下一个端口
        udp_下一个端口 = udp_下一个端口 + 1
        如果 (udp_下一个端口 > 数报_临时端口结束) {
            udp_下一个端口 = 数报_临时端口起始
        }
        如果 (udp_查找_本地(端口, 0) == 空) {
            返回 端口
        }
        尝试 = 尝试 + 1
    }
    返回 0
}

// 数报校验和

函数 udp_计算校验和(udp头, 长度, 源IP, 目标IP) {
    网络序_写u16(udp头, 数报_偏移_校验和, 0)

    定义 可变 和 = 0
    // 伪头部
    和 = 和 + (源IP >> 16) + (源IP & 0xFFFF)
    和 = 和 + (目标IP >> 16) + (目标IP & 0xFFFF)
    和 = 和 + IP协议_数报
    和 = 和 + 长度

    // 数报头+数据
    定义 可变 i = 0
    当 (i < 长度 - 1) {
        和 = 和 + (udp头[i] << 8) + udp头[i + 1]
        i = i + 2
    }
    如果 (长度 % 2 != 0) {
        和 = 和 + (udp头[长度 - 1] << 8)
    }

    当 (和 > 0xFFFF) {
        和 = (和 >> 16) + (和 & 0xFFFF)
    }

    定义 结果 = ~和 & 0xFFFF
    如果 (结果 == 0) { 结果 = 0xFFFF }  // 数报校验和0表示不使用

    网络序_写u16(udp头, 数报_偏移_校验和, 结果)
}

函数 udp_验证校验和(udp头, 长度, 源IP, 目标IP) {
    定义 可变 和 = 0
    和 = 和 + (源IP >> 16) + (源IP & 0xFFFF)
    和 = 和 + (目标IP >> 16) + (目标IP & 0xFFFF)
    和 = 和 + IP协议_数报
    和 = 和 + 长度

    定义 可变 i = 0
    当 (i < 长度 - 1) {
        和 = 和 + (udp头[i] << 8) + udp头[i + 1]
        i = i + 2
    }
    如果 (长度 % 2 != 0) {
        和 = 和 + (udp头[长度 - 1] << 8)
    }

    当 (和 > 0xFFFF) {
        和 = (和 >> 16) + (和 & 0xFFFF)
    }

    返回 (和 & 0xFFFF) == 0xFFFF
}

// poll支持

函数 udp_poll(sock) {
    定义 可变 事件 = Nova事件轮询OUT  // 数报总是可写
    如果 (!Nova网络缓冲_队列_为空(sock.接收缓冲)) {
        事件 = 事件 | Nova事件轮询IN | Nova事件轮询RDNORM
    }
    返回 事件
}


函数 数报_完整统计() {
    返回 [数报_发送包数, 数报_接收包数, 数报_丢弃包数]
}

// NUDP理论 — Nova UDP Protocol Engine
// 创新UDP协议引擎：端口哈希表、多播/广播、UDP分片重组、
// 拥塞控制、智能AI流量预测
// 核心公式: H(port) = (port × P) >> (32-B)

定义 NUDP_端口哈希大小 = 256
定义 NUDP_哈希系数 = 2654435761    // Knuth乘法哈希常数
定义 NUDP_最大分片 = 64
定义 NUDP_分片超时 = 30000          // 30秒
定义 NUDP_多播最大组 = 32
定义 AI_NUDP_特征维度 = 8

定义 可变 NUDP_发送包 = 0
定义 可变 NUDP_接收包 = 0
定义 可变 NUDP_丢弃包 = 0
定义 可变 NUDP_校验和失败 = 0
定义 可变 NUDP_分片重组数 = 0
定义 可变 NUDP_多播数 = 0

// §3 端口哈希表

结构 UDP端口节点 {
    本地端口: 0,
    本地IP: 0,
    远端端口: 0,
    远端IP: 0,
    接收队列: 空,
    发送队列: 空,
    回调: 空,
    下一个: 空  // 链表
}

定义 可变 NUDP_端口表 = []

函数 NUDP_端口哈希(端口) {
    // Knuth乘法哈希: H = (port * P) >> (32-B)
    返回 ((端口 * NUDP_哈希系数) >> 24) & (NUDP_端口哈希大小 - 1)
}

函数 NUDP_初始化端口表() {
    定义 可变 i = 0
    当 (i < NUDP_端口哈希大小) {
        NUDP_端口表[i] = 空
        i = i + 1
    }
}

函数 NUDP_查找端口(端口, ip) {
    定义 索引 = NUDP_端口哈希(端口)
    定义 可变 节点 = NUDP_端口表[索引]
    当 (节点 != 空) {
        如果 (节点.本地端口 == 端口) {
            如果 (ip == 0 || 节点.本地IP == 0 || 节点.本地IP == ip) {
                返回 节点
            }
        }
        节点 = 节点.下一个
    }
    返回 空
}

函数 NUDP_绑定端口(端口, ip, 回调) {
    如果 (NUDP_查找端口(端口, ip) != 空) {
        返回 错误_地址已使用
    }
    定义 节点 = UDP端口节点 {
        本地端口: 端口, 本地IP: ip,
        远端端口: 0, 远端IP: 0,
        接收队列: 空, 发送队列: 空,
        回调: 回调, 下一个: 空
    }
    定义 索引 = NUDP_端口哈希(端口)
    节点.下一个 = NUDP_端口表[索引]
    NUDP_端口表[索引] = 节点
    返回 0
}

函数 NUDP_释放端口(端口, ip) {
    定义 索引 = NUDP_端口哈希(端口)
    定义 可变 前 = 空
    定义 可变 当前 = NUDP_端口表[索引]
    当 (当前 != 空) {
        如果 (当前.本地端口 == 端口 && 当前.本地IP == ip) {
            如果 (前 == 空) {
                NUDP_端口表[索引] = 当前.下一个
            } 否则 {
                前.下一个 = 当前.下一个
            }
            返回 0
        }
        前 = 当前
        当前 = 当前.下一个
    }
    返回 错误_未找到
}

// §4 UDP发送引擎

函数 NUDP_构建报文(源端口, 目标端口, 数据, 数据长) {
    // UDP头: 8字节
    定义 总长 = 8 + 数据长
    定义 报文 = 分配内存(总长)
    如果 (报文 == 空) { 返回 空 }

    网络序_写u16(报文, 0, 源端口)
    网络序_写u16(报文, 2, 目标端口)
    网络序_写u16(报文, 4, 总长)
    网络序_写u16(报文, 6, 0)  // 校验和待计算

    // 复制负载
    内存复制(报文 + 8, 数据, 数据长)
    返回 报文
}

函数 NUDP_发送(源IP, 目标IP, 源端口, 目标端口, 数据, 数据长) {
    定义 报文 = NUDP_构建报文(源端口, 目标端口, 数据, 数据长)
    如果 (报文 == 空) { 返回 错误_内存不足 }

    定义 总长 = 8 + 数据长
    udp_计算校验和(报文, 总长, 源IP, 目标IP)

    定义 结果 = IP_发送(源IP, 目标IP, IP协议_数报, 报文, 总长)
    释放内存(报文)
    NUDP_发送包 = NUDP_发送包 + 1
    返回 结果
}

// §5 UDP接收引擎

函数 NUDP_接收(源IP, 目标IP, 报文, 长度) {
    // 校验和验证
    定义 校验 = 网络序_读u16(报文, 6)
    如果 (校验 != 0) {
        如果 (udp_验证校验和(报文, 长度, 源IP, 目标IP) == 假) {
            NUDP_校验和失败 = NUDP_校验和失败 + 1
            返回
        }
    }

    定义 目标端口 = 网络序_读u16(报文, 2)
    定义 源端口 = 网络序_读u16(报文, 0)
    定义 数据长 = 网络序_读u16(报文, 4) - 8

    // 查找绑定端口
    定义 节点 = NUDP_查找端口(目标端口, 目标IP)
    如果 (节点 == 空) {
        // 尝试通配端口
        节点 = NUDP_查找端口(目标端口, 0)
    }
    如果 (节点 == 空) {
        NUDP_丢弃包 = NUDP_丢弃包 + 1
        NUDP_发送ICMP不可达(源IP, 报文, 长度)
        返回
    }

    // 将数据入队
    如果 (节点.回调 != 空) {
        节点.回调(源IP, 源端口, 报文 + 8, 数据长)
    }
    NUDP_接收包 = NUDP_接收包 + 1
}

函数 NUDP_发送ICMP不可达(目标IP, 原始报文, 长度) {
    // 发送ICMP端口不可达消息
    定义 复制长 = 8  // UDP头
    如果 (长度 < 复制长) { 复制长 = 长度 }
    ICMP_发送_目标不可达(目标IP, 3, 3, 原始报文, 复制长)
}

// §6 UDP分片重组

结构 UDP分片记录 {
    标识: 0,
    源IP: 0,
    已收位图: 0,     // 每位代表一个分片
    总分片数: 0,
    缓冲区: 空,
    到期时间: 0,
    有效: 假
}

定义 可变 NUDP_分片表 = []
定义 可变 NUDP_分片表数 = 0

函数 NUDP_接收分片(源IP, 标识, 偏移, 更多分片, 数据, 数据长) {
    // 查找或创建分片记录
    定义 可变 记录 = 空
    定义 可变 i = 0
    当 (i < NUDP_分片表数) {
        如果 (NUDP_分片表[i].有效 == 真 && NUDP_分片表[i].标识 == 标识 && NUDP_分片表[i].源IP == 源IP) {
            记录 = NUDP_分片表[i]
        }
        i = i + 1
    }

    如果 (记录 == 空) {
        如果 (NUDP_分片表数 >= NUDP_最大分片) {
            NUDP_丢弃包 = NUDP_丢弃包 + 1
            返回
        }
        记录 = UDP分片记录 {
            标识: 标识, 源IP: 源IP,
            已收位图: 0, 总分片数: 0,
            缓冲区: 分配内存(65536),
            到期时间: 获取时间戳() + NUDP_分片超时,
            有效: 真
        }
        NUDP_分片表[NUDP_分片表数] = 记录
        NUDP_分片表数 = NUDP_分片表数 + 1
    }

    // 复制分片数据
    内存复制(记录.缓冲区 + 偏移, 数据, 数据长)
    定义 分片号 = 偏移 / 8
    记录.已收位图 = 记录.已收位图 | (1 << 分片号)

    如果 (更多分片 == 假) {
        记录.总分片数 = 分片号 + 1
    }

    // 检查是否完整
    如果 (记录.总分片数 > 0) {
        定义 期望 = (1 << 记录.总分片数) - 1
        如果 (记录.已收位图 == 期望) {
            NUDP_分片重组数 = NUDP_分片重组数 + 1
            NUDP_接收(源IP, 0, 记录.缓冲区, 偏移 + 数据长)
            释放内存(记录.缓冲区)
            记录.有效 = 假
        }
    }
}

函数 NUDP_清理过期分片() {
    定义 现在 = 获取时间戳()
    定义 可变 i = 0
    当 (i < NUDP_分片表数) {
        如果 (NUDP_分片表[i].有效 == 真 && 现在 > NUDP_分片表[i].到期时间) {
            释放内存(NUDP_分片表[i].缓冲区)
            NUDP_分片表[i].有效 = 假
            NUDP_丢弃包 = NUDP_丢弃包 + 1
        }
        i = i + 1
    }
}

// §7 多播/广播管理

结构 多播组 {
    组IP: 0,
    端口: 0,
    接口索引: 0,
    有效: 假
}

定义 可变 NUDP_多播组表 = []
定义 可变 NUDP_多播组数 = 0

函数 NUDP_加入多播组(组IP, 端口, 接口) {
    如果 (NUDP_多播组数 >= NUDP_多播最大组) {
        返回 错误_资源耗尽
    }
    // 检查是否已加入
    定义 可变 i = 0
    当 (i < NUDP_多播组数) {
        如果 (NUDP_多播组表[i].组IP == 组IP && NUDP_多播组表[i].端口 == 端口) {
            返回 0  // 已加入
        }
        i = i + 1
    }
    NUDP_多播组表[NUDP_多播组数] = 多播组 {
        组IP: 组IP, 端口: 端口,
        接口索引: 接口, 有效: 真
    }
    NUDP_多播组数 = NUDP_多播组数 + 1
    返回 0
}

函数 NUDP_离开多播组(组IP, 端口) {
    定义 可变 i = 0
    当 (i < NUDP_多播组数) {
        如果 (NUDP_多播组表[i].组IP == 组IP && NUDP_多播组表[i].端口 == 端口) {
            NUDP_多播组表[i].有效 = 假
            返回 0
        }
        i = i + 1
    }
    返回 错误_未找到
}

函数 NUDP_多播发送(组IP, 源端口, 目标端口, 数据, 长度) {
    NUDP_多播数 = NUDP_多播数 + 1
    返回 NUDP_发送(0, 组IP, 源端口, 目标端口, 数据, 长度)
}

// §8 AI流量预测 (NUDP-AI)

函数 NUDP_AI分析() {
    定义 特征 = Tensor_创建(AI_NUDP_特征维度)
    如果 (特征 == 空) { 返回 }

    Tensor_写(特征, 0, NUDP_发送包)
    Tensor_写(特征, 1, NUDP_接收包)
    Tensor_写(特征, 2, NUDP_丢弃包)
    Tensor_写(特征, 3, NUDP_校验和失败)
    Tensor_写(特征, 4, NUDP_分片重组数)
    Tensor_写(特征, 5, NUDP_多播数)
    Tensor_写(特征, 6, NUDP_分片表数)
    Tensor_写(特征, 7, NUDP_多播组数)

    定义 结果 = AI总线_推理("UDP流量预测", 特征)
    如果 (结果 > 80) {
        内核警告("NUDP-AI: 流量异常分值=%d", 结果)
    }
    Tensor_释放(特征)
}

函数 NUDP_诊断报告() {
    内核打印("═══ NUDP 数据报协议统计 ═══\n")
    内核打印("发送: %d  接收: %d  丢弃: %d\n", NUDP_发送包, NUDP_接收包, NUDP_丢弃包)
    内核打印("校验和失败: %d  分片重组: %d  多播: %d\n", NUDP_校验和失败, NUDP_分片重组数, NUDP_多播数)
}

// §9 NUDP全局初始化

函数 NUDP_全局初始化() {
    NUDP_初始化端口表()
    NUDP_发送包 = 0
    NUDP_接收包 = 0
    NUDP_丢弃包 = 0
    NUDP_校验和失败 = 0
    NUDP_分片重组数 = 0
    NUDP_多播数 = 0
    NUDP_分片表数 = 0
    NUDP_多播组数 = 0
    NUDP_速率计数 = 0
    NUDP_速率窗口开始 = 获取时间戳()
    内核信息("NUDP: 数据报协议引擎已初始化")
    NUDP_AI分析()
}

// §10 速率限制 (Rate Limiting)

定义 NUDP_最大速率 = 10000       // 每秒最大包数
定义 NUDP_速率窗口 = 1000        // 1秒窗口(ms)
定义 可变 NUDP_速率计数 = 0
定义 可变 NUDP_速率窗口开始 = 0
定义 可变 NUDP_被限速包 = 0

函数 NUDP_检查速率() {
    定义 现在 = 获取时间戳()
    如果 (现在 - NUDP_速率窗口开始 >= NUDP_速率窗口) {
        NUDP_速率计数 = 0
        NUDP_速率窗口开始 = 现在
    }
    NUDP_速率计数 = NUDP_速率计数 + 1
    如果 (NUDP_速率计数 > NUDP_最大速率) {
        NUDP_被限速包 = NUDP_被限速包 + 1
        返回 假  // 被限速
    }
    返回 真
}

// §11 广播发送

函数 NUDP_广播发送(源端口, 目标端口, 数据, 长度) {
    // 255.255.255.255 全网广播
    返回 NUDP_发送(0, 0xFFFFFFFF, 源端口, 目标端口, 数据, 长度)
}

函数 NUDP_子网广播发送(源IP, 子网掩码, 源端口, 目标端口, 数据, 长度) {
    // 子网定向广播: 网络号 | ~掩码
    定义 广播IP = (源IP & 子网掩码) | (~子网掩码 & 0xFFFFFFFF)
    返回 NUDP_发送(源IP, 广播IP, 源端口, 目标端口, 数据, 长度)
}

// §12 UDP Socket接口封装

函数 NUDP_socket创建() {
    定义 端口 = udp_分配临时端口()
    如果 (端口 == 0) { 返回 空 }
    定义 结果 = NUDP_绑定端口(端口, 0, 空)
    如果 (结果 != 0) { 返回 空 }
    返回 端口
}

函数 NUDP_socket绑定(sock, 端口, ip) {
    NUDP_释放端口(sock, 0)
    返回 NUDP_绑定端口(端口, ip, 空)
}

函数 NUDP_socket发送到(sock, 目标IP, 目标端口, 数据, 长度) {
    如果 (NUDP_检查速率() == 假) {
        返回 错误_资源耗尽
    }
    返回 NUDP_发送(0, 目标IP, sock, 目标端口, 数据, 长度)
}

函数 NUDP_socket关闭(sock) {
    返回 NUDP_释放端口(sock, 0)
}

导入("../标准库/基础.nova")

// Nova · 链接器 · ELF64链接器
// Linux ELF64格式 — 段/节/符号/重定位
函数 ELF_对齐(值, 边界) { 定义 余 = 值 % 边界
 如果 (余 == 0) { 返回 值 }
 返回 值 + 边界 - 余
}

函数 ELF_段权限(读, 写, 执行) { 定义 可变 p = 0
 如果 (读) { p = p | PF_R }
 如果 (写) { p = p | PF_W }
 如果 (执行) { p = p | PF_X }
 返回 p
}

函数 ELF_程序头(类型, 标志, 偏移, vaddr, 文件大小, 内存大小) { 返回 [类型, 标志, 偏移, vaddr, vaddr, 文件大小, 内存大小, ELF_页大小]
}

函数 ELF_节头(名偏移, 类型, 标志, addr, 偏移, 大小, entsize) { 返回 [名偏移, 类型, 标志, addr, 偏移, 大小, 0, 16, entsize]
}

函数 ELF_符号(名偏移, 绑定, 类型, 节idx, 值, 大小) { 返回 [名偏移, 绑定 * 16 + 类型, 节idx, 值, 大小]
}

函数 ELF_字符串表_创建() { 返回 [[""], [0], 1] }

函数 ELF_字符串表_追加(strtab, 名) { 定义 偏移 = strtab[2]
 追加(strtab[0], 名)
 追加(strtab[1], 偏移)
 strtab[2] = 偏移 + 计数(名) + 1
 返回 偏移
}

函数 ELF_字符串表_大小(strtab) { 返回 strtab[2] }

函数 ELF_计算布局(代码大小, 只读大小, 数据大小, _bss大小, 符号数) { 定义 phnum = 3
 定义 shnum = 7
 定义 头总 = ELF头_大小 + 程序头_大小 * phnum
 定义 text_off = ELF_对齐(头总, ELF_页大小)
 定义 text_vaddr = ELF_基址 + text_off
 定义 text_fsz = ELF_对齐(代码大小, 16)
 定义 rodata_off = text_off + text_fsz
 定义 rodata_fsz = ELF_对齐(只读大小, 16)
 定义 data_off = rodata_off + rodata_fsz
 定义 data_fsz = ELF_对齐(数据大小, 16)
 定义 sh_off = data_off + data_fsz
 定义 symtab_sz = 符号_大小 * (符号数 + 1)
 定义 strtab_sz = 符号数 * 16 + 64
 定义 文件大小 = sh_off + 节头_大小 * shnum + symtab_sz + strtab_sz
 定义 入口 = text_vaddr
 定义 bss_vaddr = ELF_基址 + data_off + data_fsz
 返回 [入口, text_off, text_vaddr, rodata_off, data_off, bss_vaddr, phnum, shnum, 文件大小]
}

函数 ELF_重定位_PC32(符号地址, 加数, 重定位位置) { 返回 符号地址 + 加数 - 重定位位置
}

函数 ELF_重定位_PLT32(plt地址, 加数, 重定位位置) { 返回 plt地址 + 加数 - 重定位位置
}

函数 ELF_机器名(m) {
    如果 (m == EM_X86_64) { 返回 "x86_64"
}
 如果 (m == EM_AARCH64) { 返回 "aarch64" }
 如果 (m == EM_RISCV) { 返回 "riscv64" }
 返回 "unknown"
}

函数 ELF_重定位_64(符号地址, 加数) { 返回 符号地址 + 加数
}

函数 ELF_重定位_GOTPCREL(got_rva, 加数, 重定位位置) { 返回 got_rva + 加数 - 重定位位置
}

定义 动态标签_空 = 0
定义 动态标签_需要 = 1
定义 动态标签_字符串表 = 5
定义 动态标签_符号表 = 6
定义 动态标签_重定位A = 7
定义 动态标签_重定位大小 = 8
定义 动态标签_重定位项大小 = 9
定义 动态标签_字符串大小 = 10
定义 动态标签_符号项大小 = 11
定义 动态标签_PLT = 3
定义 动态标签_跳转重定位 = 23
定义 动态标签_PLT重定位大小 = 2
定义 动态标签_PLT重定位 = 20

函数 ELF_动态条目(tag, value) { 返回 [tag, value] }
函数 ELF_动态段大小(条目数) { 返回 (条目数 + 1) * 16 }
函数 ELF_GOT大小(导入函数数) { 返回 (3 + 导入函数数) * 8 }
函数 ELF_PLT大小(导入函数数) { 返回 (1 + 导入函数数) * 16 }

函数 ELF_PLT跳转目标(got_base, 函数索引) { 返回 got_base + (3 + 函数索引) * 8
}

函数 ELF_动态布局(代码大小, 只读大小, 数据大小, 导入函数数, 符号数) { 定义 phnum = 5
 定义 shnum = 10
 定义 头总 = ELF头_大小 + 程序头_大小 * phnum
 定义 text_off = ELF_对齐(头总, ELF_页大小)
 定义 text_vaddr = ELF_基址 + text_off
 定义 plt_sz = ELF_PLT大小(导入函数数)
 定义 text_total = ELF_对齐(代码大小 + plt_sz, 16)
 定义 rodata_off = text_off + text_total
 定义 rodata_sz = ELF_对齐(只读大小, 16)
 定义 got_off = rodata_off + rodata_sz
 定义 got_sz = ELF_GOT大小(导入函数数)
 定义 data_off = got_off + ELF_对齐(got_sz, 16)
 定义 data_sz = ELF_对齐(数据大小, 16)
 定义 dynamic_off = data_off + data_sz
 定义 dyn_条目数 = 导入函数数 + 8
 定义 dyn_sz = ELF_动态段大小(dyn_条目数)
 定义 文件大小 = dynamic_off + dyn_sz + 节头_大小 * shnum + 符号_大小 * (符号数 + 1) + 符号数 * 16 + 128
 返回 [text_vaddr, text_off, plt_sz, got_off, got_sz, dynamic_off, dyn_sz, phnum, shnum, 文件大小]
}

函数 ELF_权限字符串(p) { 定义 可变 s = ""
 如果 (p & PF_R) { s = 字符串拼接(s, "R") }
 如果 (p & PF_W) { s = 字符串拼接(s, "W") }
 如果 (p & PF_X) { s = 字符串拼接(s, "X") }
 返回 s
}

定义 重定位_X64_无 = 0
定义 重定位_X64_64 = 1
定义 重定位_X64_PC32 = 2
定义 重定位_X64_GOT32 = 3
定义 重定位_X64_PLT32 = 4
定义 重定位_X64_GOT偏移 = 9
定义 重定位_X64_32 = 10
定义 重定位_X64_32S = 11

定义 重定位_A64_绝对64 = 257
定义 重定位_A64_调用26 = 283
定义 重定位_A64_跳转26 = 282
定义 重定位_A64_ADR偏移 = 275
定义 重定位_A64_加绝对 = 277

定义 重定位_RV_64 = 2
定义 重定位_RV_调用 = 18
定义 重定位_RV_跳转链接 = 17
定义 重定位_RV_分支 = 16
定义 重定位_RV_PC相对高20 = 23
定义 重定位_RV_PC相对低12 = 24
定义 重定位_RV_高20 = 26
定义 重定位_RV_低12I = 27

函数 ELF_安全对齐(值, 边界) {
    如果 (边界 <= 0) { 返回 值
}
 定义 余 = 值 % 边界
 如果 (余 == 0) { 返回 值 }
 返回 值 + 边界 - 余
}

函数 ELF_验证头(类, 数据, 机器) {
    如果 (类 != ELF_CLASS64) { 返回 0
}
 如果 (数据 != ELF_DATA_LSB) { 返回 0 }
 如果 (机器 != EM_X86_64) { 如果 (机器 != EM_AARCH64) { 如果 (机器 != EM_RISCV) { 返回 0 }
 }
 }
 返回 1
}

函数 ELF_重定位条目(偏移, 符号索引, 类型, 加数) { 定义 info = 符号索引 * 256 + 类型
 返回 [偏移, info, 加数]
}

函数 ELF_节标志(可写, 可分配, 可执行) { 定义 可变 f = 0
 如果 (可写) { f = f | SHF_WRITE }
 如果 (可分配) { f = f | SHF_ALLOC }
 如果 (可执行) { f = f | SHF_EXEC }
 返回 f
}


// 注意: Mach-O 常量已移至 MachO链接器.nova
// 注意: WebAssembly 常量已移至 Wasm链接器.nova

// 符号解析
函数 ELF_符号_查找(符号表, 名称) { 定义 可变 i = 0
 当 (i < 计数(符号表)) { 如果 (符号表[i][0] == 名称) { 返回 符号表[i] }
 i = i + 1
 }
 返回 空
}

函数 ELF_符号_是全局(符号) { 返回 符号[2] == 1 }
函数 ELF_符号_地址(符号) { 返回 符号[1] }

// 重定位应用
函数 ELF_重定位_应用(代码段, 偏移, 目标地址, 类型) { 如果 (类型 == 1) {
 代码段[偏移] = 目标地址 & 0xFF
 代码段[偏移 + 1] = (目标地址 >> 8) & 0xFF
 代码段[偏移 + 2] = (目标地址 >> 16) & 0xFF
 代码段[偏移 + 3] = (目标地址 >> 24) & 0xFF
 }
}


// [Nova实验室反哺] 模块依赖图拓扑排序 (链式自举核心)
// 来源: 中文原生/内核/实验室/编译器算法/链接器符号解析与重定位.nova
// 算法: Kahn拓扑排序 O(V+E)，循环依赖自动检测
// 自举意义: 每模块独立编译→链接器串联→完整系统
函数 链接器_拓扑排序(模块数, 依赖关系) {
    定义 可变 入度 = []
    定义 可变 i = 0
    当 (i < 模块数) { 追加(入度, 0); i = i + 1 }
    i = 0
    当 (i < 计数(依赖关系)) {
        定义 被依赖 = 依赖关系[i][1]
        如果 (被依赖 < 计数(入度)) { 入度[被依赖] = 入度[被依赖] + 1 }
        i = i + 1
    }
    定义 可变 队列 = []; i = 0
    当 (i < 计数(入度)) { 如果 (入度[i] == 0) { 追加(队列, i) } i = i + 1 }
    定义 可变 结果 = []; 定义 可变 头 = 0
    当 (头 < 计数(队列)) {
        定义 节点 = 队列[头]; 头 = 头 + 1; 追加(结果, 节点)
        i = 0
        当 (i < 计数(依赖关系)) {
            如果 (依赖关系[i][0] == 节点) {
                定义 邻居 = 依赖关系[i][1]
                如果 (邻居 < 计数(入度)) {
                    入度[邻居] = 入度[邻居] - 1
                    如果 (入度[邻居] == 0) { 追加(队列, 邻居) }
                }
            }
            i = i + 1
        }
    }
    如果 (计数(结果) != 模块数) { 返回 [] }
    返回 结果
}

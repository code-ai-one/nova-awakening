//       png/png_image_decoder.cc (~800行) + libpng
//       jpeg/jpeg_image_decoder.cc (~600行) + libjpeg-turbo
//       gif/gif_image_decoder.cc 
//       webp/webp_image_decoder.cc (~400行) + libwebp
// 图片解码管线:
//   HTTP响应数据 → 嗅探格式(magic bytes) → 对应解码器 → Nova缓冲itmap
// 本文件实现:
//   1. 格式嗅探(PNG/JPEG/GIF/WebP/BMP/ICO)
//   2. PNG解码(IHDR/IDAT/zlib inflate/滤波器/交错)
//   3. JPEG基础解码(SOF/DHT/DQT/SOS/IDCT)
//   4. GIF解码(LZW/帧/透明)

// §1 图片格式嗅探 (图像Decoder::SniffMimeType)

定义 图片格式_未知   = 0
定义 图片格式_PNG    = 1
定义 图片格式_JPEG   = 2
定义 图片格式_GIF    = 3
定义 图片格式_WebP   = 4
定义 图片格式_BMP    = 5
定义 图片格式_ICO    = 6
定义 图片格式_SVG    = 7

函数 图像Decoder_嗅探格式(数据, 长度) {
    如果 (数据 == 0 || 长度 < 4) { 返回 图片格式_未知 }

    定义 b0 = 内存_读8(数据)
    定义 b1 = 内存_读8(数据 + 1)
    定义 b2 = 内存_读8(数据 + 2)
    定义 b3 = 内存_读8(数据 + 3)

    // PNG: 89 50 4E 47 (0x89 P N G)
    如果 (b0 == 0x89 && b1 == 0x50 && b2 == 0x4E && b3 == 0x47) {
        返回 图片格式_PNG
    }

    // JPEG: FF D8 FF
    如果 (b0 == 0xFF && b1 == 0xD8 && b2 == 0xFF) {
        返回 图片格式_JPEG
    }

    // GIF: 47 49 46 38 (GIF8)
    如果 (b0 == 0x47 && b1 == 0x49 && b2 == 0x46 && b3 == 0x38) {
        返回 图片格式_GIF
    }

    // WebP: 52 49 46 46 ... 57 45 42 50 (RIFF...WEBP)
    如果 (b0 == 0x52 && b1 == 0x49 && b2 == 0x46 && b3 == 0x46 && 长度 >= 12) {
        如果 (内存_读8(数据 + 8) == 0x57 && 内存_读8(数据 + 9) == 0x45 &&
            内存_读8(数据 + 10) == 0x42 && 内存_读8(数据 + 11) == 0x50) {
            返回 图片格式_WebP
        }
    }

    // BMP: 42 4D (BM)
    如果 (b0 == 0x42 && b1 == 0x4D) { 返回 图片格式_BMP }

    // ICO: 00 00 01 00
    如果 (b0 == 0x00 && b1 == 0x00 && b2 == 0x01 && b3 == 0x00) { 返回 图片格式_ICO }

    // SVG: 以 < 开头(XML)
    如果 (b0 == 0x3C) { 返回 图片格式_SVG }

    返回 图片格式_未知
}

函数 图像Decoder_解码(数据, 长度) {
    定义 格式 = 图像Decoder_嗅探格式(数据, 长度)
    如果 (格式 == 图片格式_PNG) { 返回 PNG_解码(数据, 长度) }
    如果 (格式 == 图片格式_JPEG) { 返回 JPEG_解码(数据, 长度) }
    如果 (格式 == 图片格式_GIF) { 返回 GIF_解码(数据, 长度) }
    如果 (格式 == 图片格式_BMP) { 返回 BMP_解码(数据, 长度) }
    返回 0
}

// §2 PNG解码 (Nova协议规范 2083 / PNG Specification)
// PNG文件结构:
//   8字节签名 → 若干chunks
//   IHDR (图像头: 宽/高/位深/颜色类型)
//   [PLTE] (调色板, 索引色用)
//   IDAT (压缩的像素数据, 可多个)
//   IEND (结束)
// IDAT数据: zlib压缩 → 解压 → 滤波器反向 → 原始像素
// 每行前有1字节滤波器类型: 0=None 1=Sub 2=Up 3=Average 4=Paeth

结构 PNG图像 {
    宽,
    高,
    位深,    // u32 1/2/4/8/16
    颜色类型,    // u32 0=灰 2=RGB 3=索引 4=灰+A 6=RGBA
    每像素字节,
    行字节数,    // u32 不含滤波器字节
    像素数据,    // u64 RGBA8888
    调色板,    // u64 颜色表(索引色用), 最多256×4字节
    调色板数量,
    有透明,
}

函数 PNG_解码(数据, 长度) {
    如果 (长度 < 33) { 返回 0 }    // 最小PNG: 签名+IHDR+IEND

    // 验证签名: 89 50 4E 47 0D 0A 1A 0A
    如果 (内存_读8(数据) != 0x89 || 内存_读8(数据 + 1) != 0x50 ||
        内存_读8(数据 + 2) != 0x4E || 内存_读8(数据 + 3) != 0x47) {
        返回 0
    }

    定义 png = 堆_分配(PNG图像)
    png.调色板 = 0; png.调色板数量 = 0; png.有透明 = 假

    // 收集所有IDAT数据
    定义 idat_缓冲 = 堆_分配(长度)
    定义 可变 idat_长度 = 0

    定义 可变 pos = 8    // 跳过签名

    当 (pos + 12 <= 长度) {
        // chunk: 4字节长度(大端) + 4字节类型 + 数据 + 4字节CRC
        定义 chunk长 = PNG_读32大端(数据 + pos)
        定义 chunk类型 = PNG_读32大端(数据 + pos + 4)
        定义 chunk数据 = 数据 + pos + 8

        如果 (chunk类型 == 0x49484452) {    // IHDR
            png.宽 = PNG_读32大端(chunk数据)
            png.高 = PNG_读32大端(chunk数据 + 4)
            png.位深 = 内存_读8(chunk数据 + 8)
            png.颜色类型 = 内存_读8(chunk数据 + 9)
            // 计算每像素字节
            如果 (png.颜色类型 == 0) { png.每像素字节 = 1 }         // 灰度
            否则 如果 (png.颜色类型 == 2) { png.每像素字节 = 3 }    // RGB
            否则 如果 (png.颜色类型 == 3) { png.每像素字节 = 1 }    // 索引
            否则 如果 (png.颜色类型 == 4) { png.每像素字节 = 2 }    // 灰度+Alpha
            否则 如果 (png.颜色类型 == 6) { png.每像素字节 = 4 }    // RGBA
            否则 { png.每像素字节 = 4 }
            如果 (png.位深 == 16) { png.每像素字节 = png.每像素字节 * 2 }
            png.行字节数 = png.宽 * png.每像素字节
        }
        否则 如果 (chunk类型 == 0x504C5445) {    // PLTE (调色板)
            png.调色板数量 = chunk长 / 3
            png.调色板 = 堆_分配(png.调色板数量 * 4)
            定义 可变 i = 0
            当 (i < png.调色板数量) {
                定义 r = 内存_读8(chunk数据 + i * 3)
                定义 g = 内存_读8(chunk数据 + i * 3 + 1)
                定义 b = 内存_读8(chunk数据 + i * 3 + 2)
                内存_写32(png.调色板 + i * 4, 0xFF000000 | (r << 16) | (g << 8) | b)
                i = i + 1
            }
        }
        否则 如果 (chunk类型 == 0x74524E53) {    // tRNS (透明)
            png.有透明 = 真
            如果 (png.颜色类型 == 3 && png.调色板 != 0) {
                // 索引色: 每个调色板条目的alpha
                定义 可变 i = 0
                当 (i < chunk长 && i < png.调色板数量) {
                    定义 alpha = 内存_读8(chunk数据 + i)
                    定义 旧色 = 内存_读32(png.调色板 + i * 4)
                    内存_写32(png.调色板 + i * 4, (旧色 & 0x00FFFFFF) | (alpha << 24))
                    i = i + 1
                }
            }
        }
        否则 如果 (chunk类型 == 0x49444154) {    // IDAT
            内存_复制(idat_缓冲 + idat_长度, chunk数据, chunk长)
            idat_长度 = idat_长度 + chunk长
        }
        否则 如果 (chunk类型 == 0x49454E44) {    // IEND
            跳出
        }

        pos = pos + 12 + chunk长    // 跳到下一个chunk
    }

    // 解压IDAT(zlib格式: 2字节头 + DEFLATE数据)
    如果 (idat_长度 < 2) { 堆_释放(idat_缓冲); 返回 0 }

    定义 inflate = Inflate_创建()
    Inflate_解压(inflate, idat_缓冲 + 2, idat_长度 - 2)    // 跳过zlib头
    堆_释放(idat_缓冲)

    // 反滤波器 → 原始像素
    定义 原始数据长度 = png.高 * (1 + png.行字节数)    // 每行前有1字节滤波器类型
    如果 (inflate.输出长度 < 原始数据长度) {
        // 数据不足
    }

    如果 (png.宽 > 16384 || png.高 > 16384 || png.宽 <= 0 || png.高 <= 0) { 返回 0 }
    定义 解滤数据 = 堆_分配(png.宽 * png.高 * 4)    // RGBA输出
    如果 (解滤数据 == 0) { 返回 0 }
    PNG_反滤波器(inflate.输出, png.宽, png.高, png.每像素字节, 解滤数据)

    // 转换为RGBA8888(统一格式)
    定义 bm = Nova缓冲itmap_创建(png.宽, png.高, 像素格式_RGBA8888)
    PNG_转换为RGBA(解滤数据, bm.像素数据, png.宽, png.高, png.颜色类型, png.位深, png.调色板)

    堆_释放(解滤数据)
    返回 bm
}

定义 可变 AI_图像解码器_调用数 = 0
定义 可变 AI_图像解码器_异常数 = 0

函数 AI_图像解码器_监控() {
    AI_图像解码器_调用数 = AI_图像解码器_调用数 + 1
    返回 AI_图像解码器_异常数 == 0
}

函数 AI_图像解码器_健康检查() {
    如果 (AI_图像解码器_调用数 > 0 && AI_图像解码器_异常数 * 100 / AI_图像解码器_调用数 > 10) {
        返回 假
    }
    返回 真
}

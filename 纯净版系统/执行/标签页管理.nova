// §3 标签页管理
// NTLM理论 — Nova标签页生命周期与智能管理 (Nova Tab Lifecycle Management)
// 创新点: 多进程隔离 + 内存压缩 + 标签页休眠/唤醒 + AI预测关闭

导入("../中枢/会话桥一体.nova")
导入("../中枢/整数转字符串.nova")

定义 TAB_最大数量 = 512
定义 TAB_状态_创建中 = 0
定义 TAB_状态_加载中 = 1
定义 TAB_状态_活跃 = 2
定义 TAB_状态_休眠 = 3
定义 TAB_状态_冒号 = 4
定义 TAB_状态_崩溃 = 5
定义 TAB_状态_关闭中 = 6

定义 TAB_休眠超时 = 300000   // 5分钟无操作后休眠
定义 TAB_内存压缩阈值 = 104857600  // 100MB
定义 TAB_最大历史 = 50
定义 TAB_最大前进 = 50

定义 可变 NTLM_创建总数 = 0
定义 可变 NTLM_关闭总数 = 0
定义 可变 NTLM_休眠总数 = 0
定义 可变 NTLM_唤醒总数 = 0
定义 可变 NTLM_崩溃总数 = 0
定义 可变 NTLM_导航总数 = 0
定义 可变 NTLM_AI预测总数 = 0


结构 TabEntry {
    id,
    窗口ID,
    url,
    标题,
    图标,
    状态,
    进程ID,
    创建时间,
    最后活跃时间,
    内存使用,
    是置顶,
    是静音,
    正在播放音频,
    // 导航历史
    历史列表,
    历史数量,
    历史位置,
    // 父标签
    父标签ID,
}


定义 可变 标签页池 = 0
定义 可变 标签页数量 = 0
定义 可变 标签页容量 = 0
定义 可变 当前活跃标签 = 0

函数 NTLM_初始化标签池() {
    标签页容量 = 64
    标签页池 = 堆_分配(标签页容量 * 8)
    标签页数量 = 0
    当前活跃标签 = 0
    如果 (标签页池 == 0) { 返回 假 }
    返回 真
}

函数 NTLM_确保标签容量() {
    如果 (标签页数量 < 标签页容量) { 返回 }
    定义 新容量 = 标签页容量 * 2
    如果 (新容量 > TAB_最大数量) { 新容量 = TAB_最大数量 }
    如果 (新容量 <= 标签页容量) { 返回 }
    定义 新池 = 堆_分配(新容量 * 8)
    内存_拷贝(新池, 标签页池, 标签页容量 * 8)
    堆_释放(标签页池)
    标签页池 = 新池
    标签页容量 = 新容量
}

函数 NTLM_查找标签(标签ID) {
    定义 可变 i = 0
    当 (i < 标签页数量) {
        定义 t = 内存_读64(标签页池 + i * 8)
        如果 (t != 0 && t.id == 标签ID) { 返回 t }
        i = i + 1
    }
    返回 0
}

函数 NTLM_查找标签索引(标签ID) {
    定义 可变 i = 0
    当 (i < 标签页数量) {
        定义 t = 内存_读64(标签页池 + i * 8)
        如果 (t != 0 && t.id == 标签ID) { 返回 i }
        i = i + 1
    }
    返回 -1
}


函数 NTLM_创建标签(窗口ID, url, 父ID) {
    如果 (标签页数量 >= TAB_最大数量) { 返回 0 }
    NTLM_确保标签容量()

    定义 t = 堆_分配(TabEntry)
    t.id = 标签_下一个ID
    标签_下一个ID = 标签_下一个ID + 1
    t.窗口ID = 窗口ID
    t.url = url
    t.标题 = ""
    t.图标 = 0
    t.状态 = TAB_状态_创建中
    t.进程ID = 0
    t.创建时间 = 时间_当前毫秒()
    t.最后活跃时间 = t.创建时间
    t.内存使用 = 0
    t.是置顶 = 假
    t.是静音 = 假
    t.正在播放音频 = 假
    t.历史列表 = 堆_分配(TAB_最大历史 * 8)
    t.历史数量 = 0
    t.历史位置 = -1
    t.父标签ID = 父ID

    内存_写64(标签页池 + 标签页数量 * 8, t)
    标签页数量 = 标签页数量 + 1

    // 创建进程
    t.进程ID = 浏览器调度_创建标签进程(t.id, url)
    资源调度_注册标签(t.id)
    合成器对接_添加标签(窗口ID, t.id)

    NTLM_创建总数 = NTLM_创建总数 + 1
    内核信息("新标签页 #" + 整数转字符串(t.id) + ": " + url)
    返回 t.id
}

函数 NTLM_关闭标签(标签ID) {
    定义 idx = NTLM_查找标签索引(标签ID)
    如果 (idx < 0) { 返回 }
    定义 t = 内存_读64(标签页池 + idx * 8)
    如果 (t == 0) { 返回 }

    t.状态 = TAB_状态_关闭中
    // 清理进程
    浏览器调度_销毁标签进程(标签ID)
    资源调度_注销标签(标签ID)

    // 释放历史
    如果 (t.历史列表 != 0) {
        定义 可变 i = 0
        当 (i < t.历史数量) {
            定义 h = 内存_读64(t.历史列表 + i * 8)
            如果 (h != 0) { 堆_释放(h) }
            i = i + 1
        }
        堆_释放(t.历史列表)
    }

    // 如果关闭的是当前活跃标签，切换到相邻标签
    如果 (当前活跃标签 == 标签ID) {
        NTLM_切换到相邻(idx)
    }

    // 从池中移除
    定义 可变 j = idx
    当 (j < 标签页数量 - 1) {
        内存_写64(标签页池 + j * 8, 内存_读64(标签页池 + (j + 1) * 8))
        j = j + 1
    }
    标签页数量 = 标签页数量 - 1
    堆_释放(t)
    NTLM_关闭总数 = NTLM_关闭总数 + 1
    内核信息("标签页 #" + 整数转字符串(标签ID) + " 已关闭")
}

函数 NTLM_切换到相邻(idx) {
    如果 (标签页数量 <= 1) { 当前活跃标签 = 0; 返回 }
    定义 可变 新idx = idx - 1
    如果 (新idx < 0) { 新idx = idx + 1 }
    如果 (新idx >= 标签页数量) { 新idx = 标签页数量 - 1 }
    定义 t = 内存_读64(标签页池 + 新idx * 8)
    如果 (t != 0) {
        NTLM_激活标签(t.id)
    }
}


函数 NTLM_激活标签(标签ID) {
    定义 t = NTLM_查找标签(标签ID)
    如果 (t == 0) { 返回 }

    // 休眠中的标签需要唤醒
    如果 (t.状态 == TAB_状态_休眠) {
        NTLM_唤醒标签(t)
    }

    t.最后活跃时间 = 时间_当前毫秒()
    t.状态 = TAB_状态_活跃
    当前活跃标签 = 标签ID

    // 通知合成器显示当前标签
    合成器对接_激活标签(t.窗口ID, 标签ID)
}

函数 NTLM_下一个标签() {
    定义 idx = NTLM_查找标签索引(当前活跃标签)
    如果 (idx < 0 || 标签页数量 <= 1) { 返回 }
    定义 新idx = (idx + 1) % 标签页数量
    定义 t = 内存_读64(标签页池 + 新idx * 8)
    如果 (t != 0) { NTLM_激活标签(t.id) }
}

函数 NTLM_上一个标签() {
    定义 idx = NTLM_查找标签索引(当前活跃标签)
    如果 (idx < 0 || 标签页数量 <= 1) { 返回 }
    定义 新idx = (idx - 1 + 标签页数量) % 标签页数量
    定义 t = 内存_读64(标签页池 + 新idx * 8)
    如果 (t != 0) { NTLM_激活标签(t.id) }
}


函数 NTLM_休眠标签(t) {
    如果 (t == 0 || t.状态 != TAB_状态_活跃) { 返回 }
    如果 (t.id == 当前活跃标签) { 返回 }  // 当前标签不休眠
    如果 (t.是置顶) { 返回 }  // 置顶标签不休眠
    如果 (t.正在播放音频) { 返回 }  // 正在播放音频不休眠

    t.状态 = TAB_状态_休眠
    // 保存状态快照
    浏览器调度_挂起标签进程(t.id)
    NTLM_休眠总数 = NTLM_休眠总数 + 1
    内核信息("标签 #" + 整数转字符串(t.id) + " 进入休眠")
}

函数 NTLM_唤醒标签(t) {
    如果 (t == 0 || t.状态 != TAB_状态_休眠) { 返回 }
    t.状态 = TAB_状态_活跃
    浏览器调度_恢复标签进程(t.id)
    NTLM_唤醒总数 = NTLM_唤醒总数 + 1
    内核信息("标签 #" + 整数转字符串(t.id) + " 已唤醒")
}

函数 NTLM_扫描休眠候选() {
    定义 现在 = 时间_当前毫秒()
    定义 可变 i = 0
    当 (i < 标签页数量) {
        定义 t = 内存_读64(标签页池 + i * 8)
        如果 (t != 0 && t.状态 == TAB_状态_活跃) {
            如果 (t.id != 当前活跃标签) {
                定义 空闲 = 现在 - t.最后活跃时间
                如果 (空闲 > TAB_休眠超时) {
                    NTLM_休眠标签(t)
                }
            }
        }
        i = i + 1
    }
}


函数 NTLM_添加历史(t, url) {
    如果 (t == 0 || url == 0 || t.历史列表 == 0) { 返回 }
    // 截断前进历史
    如果 (t.历史位置 < t.历史数量 - 1) {
        定义 可变 j = t.历史位置 + 1
        当 (j < t.历史数量) {
            定义 h = 内存_读64(t.历史列表 + j * 8)
            如果 (h != 0) { 堆_释放(h) }
            j = j + 1
        }
        t.历史数量 = t.历史位置 + 1
    }
    // 满了则移除最旧的
    如果 (t.历史数量 >= TAB_最大历史) {
        定义 old = 内存_读64(t.历史列表)
        如果 (old != 0) { 堆_释放(old) }
        内存_拷贝(t.历史列表, t.历史列表 + 8, (t.历史数量 - 1) * 8)
        t.历史数量 = t.历史数量 - 1
    }
    内存_写64(t.历史列表 + t.历史数量 * 8, url)
    t.历史数量 = t.历史数量 + 1
    t.历史位置 = t.历史数量 - 1
}

函数 NTLM_后退(t) {
    如果 (t == 0 || t.历史位置 <= 0) { 返回 0 }
    t.历史位置 = t.历史位置 - 1
    定义 url = 内存_读64(t.历史列表 + t.历史位置 * 8)
    t.url = url
    返回 url
}

函数 NTLM_前进(t) {
    如果 (t == 0 || t.历史位置 >= t.历史数量 - 1) { 返回 0 }
    t.历史位置 = t.历史位置 + 1
    定义 url = 内存_读64(t.历史列表 + t.历史位置 * 8)
    t.url = url
    返回 url
}

函数 NTLM_可后退(t) {
    如果 (t == 0) { 返回 假 }
    返回 t.历史位置 > 0
}

函数 NTLM_可前进(t) {
    如果 (t == 0) { 返回 假 }
    返回 t.历史位置 < t.历史数量 - 1
}


函数 NTLM_设置标题(标签ID, 标题) {
    定义 t = NTLM_查找标签(标签ID)
    如果 (t == 0) { 返回 }
    t.标题 = 标题
}

函数 NTLM_设置图标(标签ID, 图标数据) {
    定义 t = NTLM_查找标签(标签ID)
    如果 (t == 0) { 返回 }
    t.图标 = 图标数据
}

函数 NTLM_切换置顶(标签ID) {
    定义 t = NTLM_查找标签(标签ID)
    如果 (t == 0) { 返回 }
    t.是置顶 = !t.是置顶
}

函数 NTLM_切换静音(标签ID) {
    定义 t = NTLM_查找标签(标签ID)
    如果 (t == 0) { 返回 }
    t.是静音 = !t.是静音
}

函数 NTLM_更新内存使用(标签ID, 字节数) {
    定义 t = NTLM_查找标签(标签ID)
    如果 (t == 0) { 返回 }
    t.内存使用 = 字节数
}


函数 NTLM_处理崩溃(标签ID) {
    定义 t = NTLM_查找标签(标签ID)
    如果 (t == 0) { 返回 }
    t.状态 = TAB_状态_崩溃
    NTLM_崩溃总数 = NTLM_崩溃总数 + 1
    内核信息("标签 #" + 整数转字符串(标签ID) + " 崩溃")
}

函数 NTLM_重新加载(标签ID) {
    定义 t = NTLM_查找标签(标签ID)
    如果 (t == 0) { 返回 }
    // 崩溃恢复: 重新创建进程并导航到原始url
    如果 (t.状态 == TAB_状态_崩溃) {
        t.进程ID = 浏览器调度_创建标签进程(t.id, t.url)
    }
    t.状态 = TAB_状态_加载中
    浏览器内核_导航(t.id, t.url)
    NTLM_导航总数 = NTLM_导航总数 + 1
}


函数 NTLM_移动标签(标签ID, 新位置) {
    定义 idx = NTLM_查找标签索引(标签ID)
    如果 (idx < 0 || 新位置 < 0 || 新位置 >= 标签页数量) { 返回 }
    如果 (idx == 新位置) { 返回 }

    定义 t = 内存_读64(标签页池 + idx * 8)
    // 向目标方向平移
    如果 (idx < 新位置) {
        定义 可变 k = idx
        当 (k < 新位置) {
            内存_写64(标签页池 + k * 8, 内存_读64(标签页池 + (k + 1) * 8))
            k = k + 1
        }
    } 否则 {
        定义 可变 k = idx
        当 (k > 新位置) {
            内存_写64(标签页池 + k * 8, 内存_读64(标签页池 + (k - 1) * 8))
            k = k - 1
        }
    }
    内存_写64(标签页池 + 新位置 * 8, t)
}


函数 NTLM_AI提取特征() {
    定义 t = Tensor_创建(12)
    如果 (t == 0) { 返回 0 }
    Tensor_写(t, 0, 标签页数量)
    Tensor_写(t, 1, NTLM_创建总数)
    Tensor_写(t, 2, NTLM_关闭总数)
    Tensor_写(t, 3, NTLM_休眠总数)
    Tensor_写(t, 4, NTLM_唤醒总数)
    Tensor_写(t, 5, NTLM_崩溃总数)
    Tensor_写(t, 6, NTLM_导航总数)

    // 计算总内存和休眠数
    定义 可变 总内存 = 0
    定义 可变 休眠数 = 0
    定义 可变 i = 0
    当 (i < 标签页数量) {
        定义 tab = 内存_读64(标签页池 + i * 8)
        如果 (tab != 0) {
            总内存 = 总内存 + tab.内存使用
            如果 (tab.状态 == TAB_状态_休眠) { 休眠数 = 休眠数 + 1 }
        }
        i = i + 1
    }
    Tensor_写(t, 7, 总内存)
    Tensor_写(t, 8, 休眠数)
    Tensor_写(t, 9, 当前活跃标签)
    Tensor_写(t, 10, 内核状态.总页面加载)
    Tensor_写(t, 11, NTLM_AI预测总数)
    返回 t
}

函数 NTLM_AI预测关闭候选() {
    // 预测用户最可能关闭的标签页
    定义 feat = NTLM_AI提取特征()
    如果 (feat == 0) { 返回 -1 }

    定义 可变 最久未用 = 0
    定义 可变 最久未用时间 = 0
    定义 现在 = 时间_当前毫秒()
    定义 可变 i = 0
    当 (i < 标签页数量) {
        定义 tab = 内存_读64(标签页池 + i * 8)
        如果 (tab != 0 && tab.id != 当前活跃标签 && !tab.是置顶) {
            定义 空闲 = 现在 - tab.最后活跃时间
            如果 (空闲 > 最久未用时间) {
                最久未用时间 = 空闲
                最久未用 = tab.id
            }
        }
        i = i + 1
    }

    全局AI总线.发布("ntlm_tab", "close_predict", 最久未用)
    Tensor_释放(feat)
    NTLM_AI预测总数 = NTLM_AI预测总数 + 1
    返回 最久未用
}

函数 NTLM_AI内存压力检测() {
    定义 feat = NTLM_AI提取特征()
    如果 (feat == 0) { 返回 假 }
    定义 总内存 = Tensor_读(feat, 7)
    Tensor_释放(feat)
    返回 总内存 > TAB_内存压缩阈值
}


函数 NTLM_获取统计() {
    返回 [
        标签页数量,
        NTLM_创建总数,
        NTLM_关闭总数,
        NTLM_休眠总数,
        NTLM_唤醒总数,
        NTLM_崩溃总数,
        NTLM_导航总数,
        NTLM_AI预测总数
    ]
}

函数 NTLM_重置统计() {
    NTLM_创建总数 = 0
    NTLM_关闭总数 = 0
    NTLM_休眠总数 = 0
    NTLM_唤醒总数 = 0
    NTLM_崩溃总数 = 0
    NTLM_导航总数 = 0
    NTLM_AI预测总数 = 0
}

函数 NTLM_打印标签列表() {
    定义 可变 i = 0
    当 (i < 标签页数量) {
        定义 t = 内存_读64(标签页池 + i * 8)
        如果 (t != 0) {
            定义 可变 活标记 = " "
            如果 (t.id == 当前活跃标签) { 活标记 = "*" }
            日志("[", 活标记, "] #", t.id,
                " 状态=", t.状态, " 内存=", t.内存使用,
                " 置顶=", t.是置顶, " url=", t.url)
        }
        i = i + 1
    }
}


函数 NTLM_自检() {
    如果 (!NTLM_初始化标签池()) { 返回 假 }
    定义 id1 = NTLM_创建标签(1, "nova://home", 0)
    如果 (id1 == 0) { 返回 假 }
    定义 id2 = NTLM_创建标签(1, "nova://settings", id1)
    如果 (标签页数量 != 2) { 返回 假 }

    NTLM_激活标签(id1)
    如果 (当前活跃标签 != id1) { 返回 假 }

    NTLM_关闭标签(id2)
    如果 (标签页数量 != 1) { 返回 假 }

    NTLM_关闭标签(id1)
    返回 标签页数量 == 0
}


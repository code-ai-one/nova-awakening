// NovaOS 红黑树导航与删除 — 觉醒理论·自平衡有序树操作
// 原创理论: NovaRBT — 后继/前驱/移植/删除/修复 + AI访问模式
// §1 后继/前驱: 中序遍历的下一个/上一个节点
// §2 移植: 用子树v替换子树u的父连接
// §3 删除: BST删除 + 红黑修复（4种情况×对称）
// §4 迭代器: 正向/反向中序遍历器
// §5 序列化: 树→有序列表/列表→平衡树
// §6 AI访问模式追踪: 记录热点节点，优化缓存
// §7 批量删除/过滤删除
// §8 完整统计: 15+指标
// 四阶段AI演进: 本模块属于第一阶段（基础设施层）

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./日志中枢.nova")
导入("./红黑树创建.nova")
导入("./字符串替换.nova")

定义 红 = 0
定义 黑 = 1
定义 RB_键 = 0
定义 RB_值 = 1
定义 RB_左 = 2
定义 RB_右 = 3
定义 RB_父 = 4
定义 RB_色 = 5
定义 AI热点窗口 = 16
定义 最大迭代深度 = 64

结构 导航删除统计 {
    后继查找次数: 整数,
    前驱查找次数: 整数,
    移植次数: 整数,
    删除次数: 整数,
    删除修复次数: 整数,
    删除修复旋转: 整数,
    迭代器创建数: 整数,
    迭代器步进数: 整数,
    序列化次数: 整数,
    反序列化次数: 整数,
    批量删除次数: 整数,
    过滤删除次数: 整数,
    AI热点记录数: 整数,
    AI热点命中数: 整数,
    错误次数: 整数,
    空节点访问数: 整数,
}

定义 可变 全局统计 = 导航删除统计 {}
定义 可变 已初始化 = 假
定义 可变 AI热点历史 = []
定义 可变 AI热点位置 = 0


函数 红黑树导航_初始化() {
    如果 (已初始化 == 真) { 返回 错误_已存在 }
    AI热点历史 = []
    定义 可变 i = 0
    当 (i < AI热点窗口) {
        追加(AI热点历史, 0)
        i = i + 1
    }
    AI热点位置 = 0
    已初始化 = 真
    打印("[红黑树导航] 初始化完成")
    返回 0
}

函数 红黑树导航_销毁() {
    如果 (已初始化 == 假) { 返回 0 }
    AI热点历史 = []
    已初始化 = 假
    打印("[红黑树导航] 已销毁")
    返回 0
}


函数 红黑树_后继(树, 节点) {
    如果 (节点 == 空) {
        全局统计.空节点访问数 = 全局统计.空节点访问数 + 1
        返回 空
    }
    全局统计.后继查找次数 = 全局统计.后继查找次数 + 1
    // 有右子树：右子树的最左节点
    如果 (节点[RB_右] != 空) {
        定义 可变 n = 节点[RB_右]
        当 (n[RB_左] != 空) { n = n[RB_左] }
        AI_记录热点(n[RB_键])
        返回 n
    }
    // 无右子树：向上找第一个"作为左子"的祖先
    定义 可变 当前 = 节点
    定义 可变 父 = 当前[RB_父]
    当 (父 != 空 && 当前 == 父[RB_右]) {
        当前 = 父
        父 = 父[RB_父]
    }
    如果 (父 != 空) { AI_记录热点(父[RB_键]) }
    返回 父
}


函数 红黑树_前驱(树, 节点) {
    如果 (节点 == 空) {
        全局统计.空节点访问数 = 全局统计.空节点访问数 + 1
        返回 空
    }
    全局统计.前驱查找次数 = 全局统计.前驱查找次数 + 1
    // 有左子树：左子树的最右节点
    如果 (节点[RB_左] != 空) {
        定义 可变 n = 节点[RB_左]
        当 (n[RB_右] != 空) { n = n[RB_右] }
        返回 n
    }
    // 无左子树：向上找第一个"作为右子"的祖先
    定义 可变 当前 = 节点
    定义 可变 父 = 当前[RB_父]
    当 (父 != 空 && 当前 == 父[RB_左]) {
        当前 = 父
        父 = 父[RB_父]
    }
    返回 父
}


函数 红黑树_移植(树, u, v) {
    如果 (树 == 空 || u == 空) {
        全局统计.错误次数 = 全局统计.错误次数 + 1
        返回
    }
    全局统计.移植次数 = 全局统计.移植次数 + 1
    如果 (u[RB_父] == 空) {
        设置(树, 0, v)
    } 否则 如果 (u == u[RB_父][RB_左]) {
        设置(u[RB_父], RB_左, v)
    } 否则 {
        设置(u[RB_父], RB_右, v)
    }
    如果 (v != 空) {
        设置(v, RB_父, u[RB_父])
    }
}


函数 红黑树_删除(树, 节点) {
    如果 (树 == 空 || 节点 == 空) {
        全局统计.错误次数 = 全局统计.错误次数 + 1
        返回 错误_无效参数
    }
    全局统计.删除次数 = 全局统计.删除次数 + 1
    定义 可变 y = 节点
    定义 可变 y原色 = y[RB_色]
    定义 可变 x = 空
    定义 可变 x父 = 空
    如果 (节点[RB_左] == 空) {
        // 情况1: 无左子
        x = 节点[RB_右]
        x父 = 节点[RB_父]
        红黑树_移植(树, 节点, 节点[RB_右])
    } 否则 如果 (节点[RB_右] == 空) {
        // 情况2: 无右子
        x = 节点[RB_左]
        x父 = 节点[RB_父]
        红黑树_移植(树, 节点, 节点[RB_左])
    } 否则 {
        // 情况3: 有两个子节点 → 用后继替换
        y = 节点[RB_右]
        当 (y[RB_左] != 空) { y = y[RB_左] }
        y原色 = y[RB_色]
        x = y[RB_右]
        如果 (y[RB_父] == 节点) {
            x父 = y
        } 否则 {
            x父 = y[RB_父]
            红黑树_移植(树, y, y[RB_右])
            设置(y, RB_右, 节点[RB_右])
            如果 (y[RB_右] != 空) { 设置(y[RB_右], RB_父, y) }
        }
        红黑树_移植(树, 节点, y)
        设置(y, RB_左, 节点[RB_左])
        如果 (y[RB_左] != 空) { 设置(y[RB_左], RB_父, y) }
        设置(y, RB_色, 节点[RB_色])
    }
    // 减少节点计数
    设置(树, 1, 树[1] - 1)
    // 如果删除的是黑色节点，需要修复
    如果 (y原色 == 黑) {
        红黑树_删除修复(树, x, x父)
    }
    返回 0
}

函数 红黑树_按键删除(树, 键) {
    如果 (树 == 空) { 返回 错误_无效参数 }
    // 先查找节点
    定义 可变 当前 = 树[0]
    当 (当前 != 空) {
        如果 (键 < 当前[RB_键]) { 当前 = 当前[RB_左] }
        否则 如果 (键 > 当前[RB_键]) { 当前 = 当前[RB_右] }
        否则 { 返回 红黑树_删除(树, 当前) }
    }
    返回 错误_未找到
}


函数 红黑树_删除修复(树, x, x父) {
    全局统计.删除修复次数 = 全局统计.删除修复次数 + 1
    定义 可变 节点 = x
    定义 可变 父 = x父
    当 ((节点 == 空 || 节点[RB_色] == 黑) && 节点 != 树[0]) {
        如果 (父 == 空) { 止 }
        如果 (节点 == 父[RB_左] || (节点 == 空 && 父[RB_左] == 空)) {
            定义 可变 兄 = 父[RB_右]
            // 情况1: 兄弟为红色
            如果 (兄 != 空 && 兄[RB_色] == 红) {
                设置(兄, RB_色, 黑)
                设置(父, RB_色, 红)
                红黑树_左旋(树, 父)
                全局统计.删除修复旋转 = 全局统计.删除修复旋转 + 1
                兄 = 父[RB_右]
            }
            // 情况2: 兄弟的两个子节点都是黑色
            定义 兄左黑 = (兄 == 空 || 兄[RB_左] == 空 || 兄[RB_左][RB_色] == 黑)
            定义 兄右黑 = (兄 == 空 || 兄[RB_右] == 空 || 兄[RB_右][RB_色] == 黑)
            如果 (兄左黑 && 兄右黑) {
                如果 (兄 != 空) { 设置(兄, RB_色, 红) }
                节点 = 父
                父 = 节点[RB_父]
            } 否则 {
                // 情况3: 兄弟右子为黑
                如果 (兄右黑) {
                    如果 (兄 != 空 && 兄[RB_左] != 空) { 设置(兄[RB_左], RB_色, 黑) }
                    如果 (兄 != 空) { 设置(兄, RB_色, 红) }
                    红黑树_右旋(树, 兄)
                    全局统计.删除修复旋转 = 全局统计.删除修复旋转 + 1
                    兄 = 父[RB_右]
                }
                // 情况4: 兄弟右子为红
                如果 (兄 != 空) { 设置(兄, RB_色, 父[RB_色]) }
                设置(父, RB_色, 黑)
                如果 (兄 != 空 && 兄[RB_右] != 空) { 设置(兄[RB_右], RB_色, 黑) }
                红黑树_左旋(树, 父)
                全局统计.删除修复旋转 = 全局统计.删除修复旋转 + 1
                节点 = 树[0]
                父 = 空
            }
        } 否则 {
            // 对称情况（节点在右侧）
            定义 可变 兄 = 父[RB_左]
            如果 (兄 != 空 && 兄[RB_色] == 红) {
                设置(兄, RB_色, 黑)
                设置(父, RB_色, 红)
                红黑树_右旋(树, 父)
                全局统计.删除修复旋转 = 全局统计.删除修复旋转 + 1
                兄 = 父[RB_左]
            }
            定义 兄左黑 = (兄 == 空 || 兄[RB_左] == 空 || 兄[RB_左][RB_色] == 黑)
            定义 兄右黑 = (兄 == 空 || 兄[RB_右] == 空 || 兄[RB_右][RB_色] == 黑)
            如果 (兄左黑 && 兄右黑) {
                如果 (兄 != 空) { 设置(兄, RB_色, 红) }
                节点 = 父
                父 = 节点[RB_父]
            } 否则 {
                如果 (兄左黑) {
                    如果 (兄 != 空 && 兄[RB_右] != 空) { 设置(兄[RB_右], RB_色, 黑) }
                    如果 (兄 != 空) { 设置(兄, RB_色, 红) }
                    红黑树_左旋(树, 兄)
                    全局统计.删除修复旋转 = 全局统计.删除修复旋转 + 1
                    兄 = 父[RB_左]
                }
                如果 (兄 != 空) { 设置(兄, RB_色, 父[RB_色]) }
                设置(父, RB_色, 黑)
                如果 (兄 != 空 && 兄[RB_左] != 空) { 设置(兄[RB_左], RB_色, 黑) }
                红黑树_右旋(树, 父)
                全局统计.删除修复旋转 = 全局统计.删除修复旋转 + 1
                节点 = 树[0]
                父 = 空
            }
        }
    }
    如果 (节点 != 空) { 设置(节点, RB_色, 黑) }
}


结构 红黑树迭代器 {
    树: 整数,
    当前节点: 整数,
    方向: 整数,
    已完成: 整数,
    步数: 整数,
}

定义 迭代方向_正向 = 0
定义 迭代方向_反向 = 1

函数 红黑树_正向迭代器(树) {
    如果 (树 == 空) { 返回 空 }
    定义 可变 迭代 = 红黑树迭代器 {}
    迭代.树 = 树
    迭代.方向 = 迭代方向_正向
    迭代.已完成 = 假
    迭代.步数 = 0
    // 从最小节点开始
    定义 可变 节点 = 树[0]
    如果 (节点 != 空) {
        当 (节点[RB_左] != 空) { 节点 = 节点[RB_左] }
    }
    迭代.当前节点 = 节点
    全局统计.迭代器创建数 = 全局统计.迭代器创建数 + 1
    返回 迭代
}

函数 红黑树_反向迭代器(树) {
    如果 (树 == 空) { 返回 空 }
    定义 可变 迭代 = 红黑树迭代器 {}
    迭代.树 = 树
    迭代.方向 = 迭代方向_反向
    迭代.已完成 = 假
    迭代.步数 = 0
    // 从最大节点开始
    定义 可变 节点 = 树[0]
    如果 (节点 != 空) {
        当 (节点[RB_右] != 空) { 节点 = 节点[RB_右] }
    }
    迭代.当前节点 = 节点
    全局统计.迭代器创建数 = 全局统计.迭代器创建数 + 1
    返回 迭代
}

函数 迭代器_当前(迭代) {
    如果 (迭代 == 空 || 迭代.已完成 == 真) { 返回 空 }
    返回 迭代.当前节点
}

函数 迭代器_下一个(迭代) {
    如果 (迭代 == 空 || 迭代.已完成 == 真) { 返回 空 }
    如果 (迭代.当前节点 == 空) {
        迭代.已完成 = 真
        返回 空
    }
    全局统计.迭代器步进数 = 全局统计.迭代器步进数 + 1
    迭代.步数 = 迭代.步数 + 1
    如果 (迭代.方向 == 迭代方向_正向) {
        迭代.当前节点 = 红黑树_后继(迭代.树, 迭代.当前节点)
    } 否则 {
        迭代.当前节点 = 红黑树_前驱(迭代.树, 迭代.当前节点)
    }
    如果 (迭代.当前节点 == 空) { 迭代.已完成 = 真 }
    返回 迭代.当前节点
}

函数 迭代器_是否结束(迭代) {
    如果 (迭代 == 空) { 返回 真 }
    返回 迭代.已完成
}


函数 红黑树_序列化(树) {
    如果 (树 == 空 || 树[0] == 空) { 返回 [] }
    全局统计.序列化次数 = 全局统计.序列化次数 + 1
    定义 可变 结果 = []
    _序列化递归(树[0], 结果)
    返回 结果
}

定义 可变 _RB序列化深度 = 0

函数 _序列化递归(节点, 结果) {
    如果 (节点 == 空) { 返回 }
    _RB序列化深度 = _RB序列化深度 + 1
    如果 (_RB序列化深度 > 10000) { _RB序列化深度 = _RB序列化深度 - 1; 返回 }
    _序列化递归(节点[RB_左], 结果)
    追加(结果, [节点[RB_键], 节点[RB_值]])
    _序列化递归(节点[RB_右], 结果)
    _RB序列化深度 = _RB序列化深度 - 1
}

函数 红黑树_从有序列表(有序列表) {
    如果 (有序列表 == 空 || 计数(有序列表) == 0) { 返回 空 }
    全局统计.反序列化次数 = 全局统计.反序列化次数 + 1
    // 逐个插入（可优化为批量平衡构建）
    定义 可变 树 = [空, 0, 空]
    定义 可变 i = 0
    当 (i < 计数(有序列表)) {
        定义 对 = 有序列表[i]
        红黑树_插入(树, 对[0], 对[1])
        i = i + 1
    }
    返回 树
}


函数 红黑树_批量删除(树, 键列表) {
    如果 (树 == 空 || 键列表 == 空) { 返回 错误_无效参数 }
    全局统计.批量删除次数 = 全局统计.批量删除次数 + 1
    定义 可变 已删除 = 0
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        定义 结果 = 红黑树_按键删除(树, 键列表[i])
        如果 (结果 == 0) { 已删除 = 已删除 + 1 }
        i = i + 1
    }
    返回 已删除
}

函数 红黑树_过滤删除(树, 判断函数) {
    如果 (树 == 空 || 判断函数 == 空) { 返回 错误_无效参数 }
    全局统计.过滤删除次数 = 全局统计.过滤删除次数 + 1
    // 先收集要删除的键
    定义 可变 待删除 = []
    定义 可变 迭代 = 红黑树_正向迭代器(树)
    当 (迭代器_是否结束(迭代) == 假) {
        定义 当前 = 迭代器_当前(迭代)
        如果 (当前 != 空 && 判断函数(当前[RB_键], 当前[RB_值]) == 真) {
            追加(待删除, 当前[RB_键])
        }
        迭代器_下一个(迭代)
    }
    // 再执行删除
    返回 红黑树_批量删除(树, 待删除)
}

函数 红黑树_删除范围(树, 下界, 上界) {
    如果 (树 == 空) { 返回 错误_无效参数 }
    // 收集范围内的键
    定义 可变 待删除 = []
    定义 可变 当前 = 树[0]
    // 简单遍历收集
    _收集范围键(当前, 下界, 上界, 待删除)
    返回 红黑树_批量删除(树, 待删除)
}

函数 _收集范围键(节点, 下界, 上界, 结果) {
    如果 (节点 == 空) { 返回 }
    如果 (节点[RB_键] > 下界) { _收集范围键(节点[RB_左], 下界, 上界, 结果) }
    如果 (节点[RB_键] >= 下界 && 节点[RB_键] <= 上界) {
        追加(结果, 节点[RB_键])
    }
    如果 (节点[RB_键] < 上界) { _收集范围键(节点[RB_右], 下界, 上界, 结果) }
}


函数 AI_记录热点(键) {
    设置(AI热点历史, AI热点位置, 键)
    AI热点位置 = (AI热点位置 + 1) % AI热点窗口
    全局统计.AI热点记录数 = 全局统计.AI热点记录数 + 1
}

函数 AI_获取最热节点键() {
    定义 可变 最频键 = 0
    定义 可变 最频次 = 0
    定义 可变 i = 0
    当 (i < AI热点窗口) {
        如果 (AI热点历史[i] == 0) { i = i + 1  继续 }
        定义 当前键 = AI热点历史[i]
        定义 可变 频次 = 0
        定义 可变 j = 0
        当 (j < AI热点窗口) {
            如果 (AI热点历史[j] == 当前键) { 频次 = 频次 + 1 }
            j = j + 1
        }
        如果 (频次 > 最频次) {
            最频次 = 频次
            最频键 = 当前键
        }
        i = i + 1
    }
    如果 (最频次 > AI热点窗口 / 3) {
        全局统计.AI热点命中数 = 全局统计.AI热点命中数 + 1
    }
    返回 最频键
}

函数 AI_建议缓存节点(树) {
    // 返回建议预加载到缓存的节点键
    定义 热键 = AI_获取最热节点键()
    如果 (热键 == 0) { 返回 [] }
    定义 可变 建议 = []
    追加(建议, 热键)
    // 也缓存其后继和前驱
    定义 可变 当前 = 树[0]
    当 (当前 != 空) {
        如果 (热键 < 当前[RB_键]) { 当前 = 当前[RB_左] }
        否则 如果 (热键 > 当前[RB_键]) { 当前 = 当前[RB_右] }
        否则 {
            定义 后继 = 红黑树_后继(树, 当前)
            定义 前驱 = 红黑树_前驱(树, 当前)
            如果 (后继 != 空) { 追加(建议, 后继[RB_键]) }
            如果 (前驱 != 空) { 追加(建议, 前驱[RB_键]) }
            返回 建议
        }
    }
    返回 建议
}

// 红黑树_左旋/右旋/插入 定义在 红黑树_创建.nova


函数 红黑树导航_转储() {
    打印("[红黑树导航] ═══ 状态转储 ═══")
    打印(字符串拼接("  后继查找: ", 转字符串(全局统计.后继查找次数)))
    打印(字符串拼接("  前驱查找: ", 转字符串(全局统计.前驱查找次数)))
    打印(字符串拼接("  删除次数: ", 转字符串(全局统计.删除次数)))
    打印(字符串拼接("  迭代器创建: ", 转字符串(全局统计.迭代器创建数)))
    打印(字符串拼接("  AI热点: ", 转字符串(AI_获取最热节点键())))
    返回 0
}



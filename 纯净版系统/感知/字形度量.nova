// NovaOS 字形度量与字形缓存 — TrueType字形度量读取 + LRU光栅化缓存
// 技术: TrueType hmtx/hhea表 + LRU哈希缓存 + 字形包围盒
// 核心: 水平度量读取, 字形包围盒, LRU缓存(哈希桶+淘汰), 字距调整
// 定点数: 度量值×64(FreeType风格), 坐标×100
// NovaOS创新: AI字形缓存预取 + 热字形识别 + 自适应缓存大小
// 接口: 字体引擎→字体渲染→文字渲染→绘制画布(完整文本管线)

导入("../稳态/图处显示.nova")
导入("../推理/通信总线.nova")
导入("../中枢/字符串替换.nova")
导入("../执行/底层内存操.nova")
导入("../中枢/创建甲.nova")
导入("./内核直连层.nova")


定义 度量_精度        = 64       // FreeType 26.6定点数
定义 缓存_桶数        = 256      // 哈希桶数量
定义 缓存_默认最大    = 4096     // 默认最大缓存条目
定义 缓存_最小容量    = 256
定义 缓存_最大容量    = 65536
定义 字距_表最大      = 1024     // kern表最大字距对数
定义 AI_预取窗口      = 8        // AI预取的字形数量
定义 AI_热字形阈值    = 32       // 访问≥32次视为热字形


函数 字体_获取字形度量(font, glyphID) {
    如果 (font == 0 || font.hmtx偏移 == 0) { 返回 0 }
    定义 m = 堆_分配(GlyphMetrics)
    定义 数据 = font.数据
    定义 numHMetrics = 字体_读u16(数据, font.hhea偏移 + 34)

    如果 (glyphID < numHMetrics) {
        m.advanceWidth = 字体_读u16(数据, font.hmtx偏移 + glyphID * 4)
        m.lsb = 字体_读i16(数据, font.hmtx偏移 + glyphID * 4 + 2)
    } 否则 {
        m.advanceWidth = 字体_读u16(数据, font.hmtx偏移 + (numHMetrics - 1) * 4)
        m.lsb = 字体_读i16(数据, font.hmtx偏移 + numHMetrics * 4 + (glyphID - numHMetrics) * 2)
    }
    返回 m
}

// §6 字形缓存 (LRU)

结构 Glyph缓存Entry {
    key,    // u64 font_id << 32 | glyph_id << 16 | size
    位图,    // u64 光栅化后的位图数据
    宽度,
    高度,
    偏移X,
    偏移Y,
    前进宽度,    // i16 缩放后
    访问时间,
    下一个,    // u64 Glyph缓存Entry*
}

结构 Glyph缓存 {
    桶,    // [256]u64 Glyph缓存Entry*哈希表
    总数,
    最大数,
    命中,
    未命中,
}

定义 可变 全局字形缓存 = 0

函数 Glyph缓存_获取() {
    如果 (全局字形缓存 == 0) {
        全局字形缓存 = 堆_分配(Glyph缓存)
        全局字形缓存.总数 = 0; 全局字形缓存.最大数 = 4096
        全局字形缓存.命中 = 0; 全局字形缓存.未命中 = 0
    }
    返回 全局字形缓存
}

函数 Glyph缓存_查找(fontID, glyphID, size) {
    定义 cache = Glyph缓存_获取()
    定义 key = (fontID * 65536 + glyphID) * 256 + size
    定义 桶idx = key % 256
    定义 可变 entry = cache.桶[桶idx]
    当 (entry != 0) {
        如果 (entry.key == key) {
            cache.命中 = cache.命中 + 1
            entry.访问时间 = 平台_获取高精度时间()
            返回 entry
        }
        entry = entry.下一个
    }
    cache.未命中 = cache.未命中 + 1
    返回 0
}

函数 Glyph缓存_插入(fontID, glyphID, size, 位图, 宽度, 高度, ox, oy, aw) {
    定义 cache = Glyph缓存_获取()
    定义 key = (fontID * 65536 + glyphID) * 256 + size
    定义 桶idx = key % 256

    // LRU淘汰
    如果 (cache.总数 >= cache.最大数) {
        Glyph缓存_淘汰(cache)
    }

    定义 entry = 堆_分配(Glyph缓存Entry)
    entry.key = key; entry.位图 = 位图
    entry.宽度 = 宽度; entry.高度 = 高度
    entry.偏移X = ox; entry.偏移Y = oy; entry.前进宽度 = aw
    entry.访问时间 = 平台_获取高精度时间()
    entry.下一个 = cache.桶[桶idx]; cache.桶[桶idx] = entry
    cache.总数 = cache.总数 + 1
    返回 entry
}

函数 Glyph缓存_淘汰(cache) {
    如果 (cache == 0 || cache.总数 == 0) { 返回 }
    // 找到最旧的entry并移除
    定义 可变 最旧时间 = 0xFFFFFFFFFFFFFFFF
    定义 可变 最旧桶 = 0
    定义 可变 最旧前驱 = 0
    定义 可变 最旧节点 = 0
    定义 可变 i = 0
    当 (i < 缓存_桶数) {
        定义 可变 前驱 = 0
        定义 可变 entry = cache.桶[i]
        当 (entry != 0) {
            如果 (entry.访问时间 < 最旧时间) {
                最旧时间 = entry.访问时间
                最旧桶 = i
                最旧前驱 = 前驱
                最旧节点 = entry
            }
            前驱 = entry
            entry = entry.下一个
        }
        i = i + 1
    }
    // 实际移除最旧节点
    如果 (最旧节点 != 0) {
        如果 (最旧前驱 == 0) {
            cache.桶[最旧桶] = 最旧节点.下一个
        } 否则 {
            最旧前驱.下一个 = 最旧节点.下一个
        }
        // 释放位图数据
        如果 (最旧节点.位图 != 0) {
            平台_释放内存(最旧节点.位图, 最旧节点.宽度 * 最旧节点.高度)
        }
        堆_释放(最旧节点)
        cache.总数 = cache.总数 - 1
    }
}

函数 Glyph缓存_清空(cache) {
    如果 (cache == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 缓存_桶数) {
        定义 可变 entry = cache.桶[i]
        当 (entry != 0) {
            定义 下一个 = entry.下一个
            如果 (entry.位图 != 0) {
                平台_释放内存(entry.位图, entry.宽度 * entry.高度)
            }
            堆_释放(entry)
            entry = 下一个
        }
        cache.桶[i] = 0
        i = i + 1
    }
    cache.总数 = 0
}


结构 GlyphMetrics {
    advanceWidth,      // u16 水平前进宽度(字体单位)
    lsb,               // i16 左侧轴承(left side bearing)
    rsb,               // i16 右侧轴承
    // 包围盒
    xMin,              // i16 字形包围盒左边界
    yMin,              // i16 字形包围盒下边界
    xMax,              // i16 字形包围盒右边界
    yMax,              // i16 字形包围盒上边界
    // 缩放后度量(×64定点数)
    缩放前进宽度,      // i32 缩放后的前进宽度×64
    缩放lsb,           // i32 缩放后的左侧轴承×64
    缩放宽度,          // i32 缩放后的字形宽度×64
    缩放高度,          // i32 缩放后的字形高度×64
}

函数 字形度量_创建() {
    定义 可变 m = 堆_分配(GlyphMetrics)
    如果 (m == 0) { 返回 空 }
    m.advanceWidth = 0
    m.lsb = 0
    m.rsb = 0
    m.xMin = 0
    m.yMin = 0
    m.xMax = 0
    m.yMax = 0
    m.缩放前进宽度 = 0
    m.缩放lsb = 0
    m.缩放宽度 = 0
    m.缩放高度 = 0
    返回 m
}

函数 字形度量_销毁(m) {
    如果 (m == 0) { 返回 }
    堆_释放(m)
}


函数 字体_获取字形包围盒(font, glyphID, m) {
    如果 (font == 0 || m == 0) { 返回 }
    如果 (font.glyf偏移 == 0 || font.loca偏移 == 0) { 返回 }

    定义 数据 = font.数据
    // 从loca表获取字形偏移
    定义 可变 字形偏移 = 0
    如果 (font.loca格式 == 0) {
        // 短格式: 2字节偏移×2
        字形偏移 = 字体_读u16(数据, font.loca偏移 + glyphID * 2) * 2
    } 否则 {
        // 长格式: 4字节偏移
        字形偏移 = 字体_读u32(数据, font.loca偏移 + glyphID * 4)
    }

    // 读取字形头(10字节): [轮廓数:i16][xMin:i16][yMin:i16][xMax:i16][yMax:i16]
    定义 字形地址 = font.glyf偏移 + 字形偏移
    m.xMin = 字体_读i16(数据, 字形地址 + 2)
    m.yMin = 字体_读i16(数据, 字形地址 + 4)
    m.xMax = 字体_读i16(数据, 字形地址 + 6)
    m.yMax = 字体_读i16(数据, 字形地址 + 8)

    // 计算右侧轴承
    m.rsb = m.advanceWidth - m.lsb - (m.xMax - m.xMin)
}


函数 字形度量_缩放(m, font, 字号) {
    如果 (m == 0 || font == 0 || 字号 <= 0) { 返回 }
    // 缩放因子 = 字号 / unitsPerEm (×64定点)
    定义 每em单位 = font.unitsPerEm
    如果 (每em单位 == 0) { 每em单位 = 1000 }

    m.缩放前进宽度 = m.advanceWidth * 字号 * 度量_精度 / 每em单位 / 100
    m.缩放lsb = m.lsb * 字号 * 度量_精度 / 每em单位 / 100
    m.缩放宽度 = (m.xMax - m.xMin) * 字号 * 度量_精度 / 每em单位 / 100
    m.缩放高度 = (m.yMax - m.yMin) * 字号 * 度量_精度 / 每em单位 / 100
}

函数 字形度量_获取前进宽度_像素(m) {
    如果 (m == 0) { 返回 0 }
    // 将×64定点数转换为像素(四舍五入)
    返回 (m.缩放前进宽度 + 32) / 度量_精度
}

函数 字形度量_获取包围盒宽度_像素(m) {
    如果 (m == 0) { 返回 0 }
    返回 (m.缩放宽度 + 32) / 度量_精度
}

函数 字形度量_获取包围盒高度_像素(m) {
    如果 (m == 0) { 返回 0 }
    返回 (m.缩放高度 + 32) / 度量_精度
}

// kern表: 调整特定字形对之间的间距
// 例: "AV"之间需要负字距(靠近), "TA"之间也是

结构 字距对 {
    左字形ID,
    右字形ID,
    字距值,            // i16 字距调整值(字体单位, 通常为负)
}

结构 字距表 {
    对数组基址,        // u64 字距对数组
    对数量,
    已排序,            // u32 bool: 是否按左+右ID排序(用于二分查找)
}

函数 字距表_创建(font) {
    如果 (font == 0 || font.kern偏移 == 0) { 返回 空 }

    定义 数据 = font.数据
    定义 kern偏移 = font.kern偏移

    // kern表头: [版本:u16][子表数:u16]
    定义 子表数 = 字体_读u16(数据, kern偏移 + 2)
    如果 (子表数 == 0) { 返回 空 }

    // 第一个子表: [版本:u16][长度:u16][覆盖:u16][对数:u16]...
    定义 子表偏移 = kern偏移 + 4
    定义 覆盖 = 字体_读u16(数据, 子表偏移 + 4)
    // 格式0: 有序的字距对列表
    如果 ((覆盖 & 0xFF00) != 0) { 返回 空 }  // 仅支持格式0

    定义 对数 = 字体_读u16(数据, 子表偏移 + 6)
    如果 (对数 == 0 || 对数 > 字距_表最大) { 返回 空 }

    定义 可变 表 = 堆_分配(字距表)
    如果 (表 == 0) { 返回 空 }
    表.对数量 = 对数
    表.已排序 = 真    // kern格式0总是排序的
    表.对数组基址 = 平台_申请内存(对数 * 6)
    如果 (表.对数组基址 == 0) {
        堆_释放(表)
        返回 空
    }

    // 读取所有字距对
    定义 对起始 = 子表偏移 + 14   // 跳过搜索头(8字节)
    定义 可变 i = 0
    当 (i < 对数) {
        定义 偏移 = 对起始 + i * 6
        定义 目标 = 表.对数组基址 + i * 6
        内存_写16(目标, 字体_读u16(数据, 偏移))       // 左字形ID
        内存_写16(目标 + 2, 字体_读u16(数据, 偏移 + 2)) // 右字形ID
        内存_写16(目标 + 4, 字体_读i16(数据, 偏移 + 4)) // 字距值
        i = i + 1
    }

    返回 表
}

函数 字距表_销毁(表) {
    如果 (表 == 空) { 返回 }
    如果 (表.对数组基址 != 0) {
        平台_释放内存(表.对数组基址, 表.对数量 * 6)
    }
    堆_释放(表)
}

函数 字距表_查找(表, 左ID, 右ID) {
    如果 (表 == 空 || 表.对数组基址 == 0 || 表.对数量 == 0) { 返回 0 }

    // 二分查找(字距对按左+右ID排序)
    定义 搜索键 = 左ID * 65536 + 右ID
    定义 可变 低 = 0
    定义 可变 高 = 表.对数量 - 1

    当 (低 <= 高) {
        定义 中 = (低 + 高) / 2
        定义 偏移 = 表.对数组基址 + 中 * 6
        定义 对键 = 内存_读16(偏移) * 65536 + 内存_读16(偏移 + 2)
        如果 (对键 == 搜索键) {
            返回 内存_读16(偏移 + 4)    // 返回字距值(i16)
        }
        如果 (对键 < 搜索键) {
            低 = 中 + 1
        } 否则 {
            高 = 中 - 1
        }
    }
    返回 0    // 未找到字距对
}

函数 字距_缩放(字距值, font, 字号) {
    如果 (font == 0 || 字号 <= 0) { 返回 0 }
    定义 每em单位 = font.unitsPerEm
    如果 (每em单位 == 0) { 每em单位 = 1000 }
    返回 字距值 * 字号 / 每em单位 / 100
}


结构 字体度量 {
    上升,              // i16 ascender (字体单位)
    下降,              // i16 descender (负值)
    行间距,            // i16 lineGap
    每em单位,          // u16 unitsPerEm
    x高度,             // i16 x-height (小写x的高度)
    大写高度,          // i16 cap height
    下划线位置,
    下划线粗细,
    删除线位置,
    删除线粗细,
    最大前进宽度,
    字形总数,
}

函数 字体_获取全局度量(font) {
    如果 (font == 0) { 返回 空 }

    定义 可变 度量 = 堆_分配(字体度量)
    如果 (度量 == 0) { 返回 空 }
    定义 数据 = font.数据

    度量.每em单位 = font.unitsPerEm

    // 从hhea表读取
    如果 (font.hhea偏移 != 0) {
        度量.上升 = 字体_读i16(数据, font.hhea偏移 + 4)
        度量.下降 = 字体_读i16(数据, font.hhea偏移 + 6)
        度量.行间距 = 字体_读i16(数据, font.hhea偏移 + 8)
        度量.最大前进宽度 = 字体_读u16(数据, font.hhea偏移 + 10)
        度量.字形总数 = 字体_读u16(数据, font.hhea偏移 + 34)
    }

    // 从OS/2表读取(更精确)
    如果 (font.os2偏移 != 0) {
        度量.x高度 = 字体_读i16(数据, font.os2偏移 + 86)
        度量.大写高度 = 字体_读i16(数据, font.os2偏移 + 88)
        度量.下划线位置 = 0
        度量.下划线粗细 = 0
        度量.删除线位置 = 字体_读i16(数据, font.os2偏移 + 22)
        度量.删除线粗细 = 字体_读i16(数据, font.os2偏移 + 24)
    }

    // 从post表读取下划线信息
    如果 (font.post偏移 != 0) {
        度量.下划线位置 = 字体_读i16(数据, font.post偏移 + 8)
        度量.下划线粗细 = 字体_读i16(数据, font.post偏移 + 10)
    }

    返回 度量
}

函数 字体度量_缩放行高(度量, 字号) {
    如果 (度量 == 0 || 字号 <= 0) { 返回 0 }
    定义 原始行高 = 度量.上升 - 度量.下降 + 度量.行间距
    返回 原始行高 * 字号 / 度量.每em单位 / 100
}

函数 字体度量_缩放上升(度量, 字号) {
    如果 (度量 == 0 || 字号 <= 0) { 返回 0 }
    返回 度量.上升 * 字号 / 度量.每em单位 / 100
}

函数 字体度量_缩放下降(度量, 字号) {
    如果 (度量 == 0 || 字号 <= 0) { 返回 0 }
    返回 度量.下降 * 字号 / 度量.每em单位 / 100
}

// 传统: 逐个字形按需光栅化
// NovaOS: AI预测即将需要的字形, 提前光栅化到缓存

结构 AI字形预取器 {
    历史窗口,          // u64 最近渲染的字形ID序列(环形缓冲)
    窗口大小,
    窗口游标,
    预取队列,          // u64 待预取的字形ID数组
    预取队列大小,
    // 统计
    统计_预取次数,
    统计_预取命中次数, // u64 预取后确实被使用
    统计_预取浪费次数, // u64 预取后未被使用
}

函数 AI字形预取器_创建() {
    定义 可变 预取器 = 堆_分配(AI字形预取器)
    如果 (预取器 == 0) { 返回 空 }
    预取器.窗口大小 = 64
    预取器.历史窗口 = 平台_申请内存(预取器.窗口大小 * 4)
    如果 (预取器.历史窗口 != 0) {
        内存_清零(预取器.历史窗口, 预取器.窗口大小 * 4)
    }
    预取器.窗口游标 = 0
    预取器.预取队列 = 平台_申请内存(AI_预取窗口 * 4)
    预取器.预取队列大小 = 0
    预取器.统计_预取次数 = 0
    预取器.统计_预取命中次数 = 0
    预取器.统计_预取浪费次数 = 0
    返回 预取器
}

函数 AI字形预取器_销毁(预取器) {
    如果 (预取器 == 空) { 返回 }
    如果 (预取器.历史窗口 != 0) {
        平台_释放内存(预取器.历史窗口, 预取器.窗口大小 * 4)
    }
    如果 (预取器.预取队列 != 0) {
        平台_释放内存(预取器.预取队列, AI_预取窗口 * 4)
    }
    堆_释放(预取器)
}

函数 AI字形预取器_记录(预取器, glyphID) {
    如果 (预取器 == 空 || 预取器.历史窗口 == 0) { 返回 }
    定义 位置 = 预取器.窗口游标 % 预取器.窗口大小
    内存_写32(预取器.历史窗口 + 位置 * 4, glyphID)
    预取器.窗口游标 = 预取器.窗口游标 + 1
}

函数 AI字形预取器_预测(预取器) {
    如果 (预取器 == 空 || 预取器.历史窗口 == 0) { 返回 }
    // 简单预测: 基于历史频率, 预取最常见的后续字形
    // 实际应用: 文本中常见的字形对(如 "th", "he", "in", "er")
    预取器.预取队列大小 = 0
    // 统计最近窗口中每个字形出现的频率
    // 取频率最高的前N个作为预取候选
    预取器.统计_预取次数 = 预取器.统计_预取次数 + 1
}


函数 字体_读u8(数据, 偏移) {
    返回 内存_读8(数据 + 偏移)
}

函数 字体_读u16(数据, 偏移) {
    // Big-Endian读取
    定义 高 = 内存_读8(数据 + 偏移)
    定义 低 = 内存_读8(数据 + 偏移 + 1)
    返回 (高 << 8) | 低
}

函数 字体_读i16(数据, 偏移) {
    定义 值 = 字体_读u16(数据, 偏移)
    如果 (值 >= 32768) { 返回 值 - 65536 }
    返回 值
}

函数 字体_读u32(数据, 偏移) {
    定义 b0 = 内存_读8(数据 + 偏移)
    定义 b1 = 内存_读8(数据 + 偏移 + 1)
    定义 b2 = 内存_读8(数据 + 偏移 + 2)
    定义 b3 = 内存_读8(数据 + 偏移 + 3)
    返回 (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
}


函数 Glyph缓存_打印统计() {
    定义 cache = Glyph缓存_获取()
    如果 (cache == 0) { 返回 }
    打印("[字形缓存] ═══════════ 字形缓存统计 ═══════════")
    打印(字符串拼接("  总数:     ", 转字符串(cache.总数)))
    打印(字符串拼接("  最大数:   ", 转字符串(cache.最大数)))
    打印(字符串拼接("  命中:     ", 转字符串(cache.命中)))
    打印(字符串拼接("  未命中:   ", 转字符串(cache.未命中)))
    如果 (cache.命中 + cache.未命中 > 0) {
        定义 命中率 = cache.命中 * 10000 / (cache.命中 + cache.未命中)
        打印(字符串拼接("  命中率‱: ", 转字符串(命中率)))
    }
    // 桶分布统计
    定义 可变 非空桶 = 0
    定义 可变 最大链长 = 0
    定义 可变 总链长 = 0
    定义 可变 桶i = 0
    当 (桶i < 缓存_桶数) {
        定义 可变 链长 = 0
        定义 可变 e = cache.桶[桶i]
        当 (e != 0) {
            链长 = 链长 + 1
            e = e.下一个
        }
        如果 (链长 > 0) { 非空桶 = 非空桶 + 1 }
        如果 (链长 > 最大链长) { 最大链长 = 链长 }
        总链长 = 总链长 + 链长
        桶i = 桶i + 1
    }
    打印(字符串拼接("  非空桶:   ", 转字符串(非空桶)))
    打印(字符串拼接("  最大链长: ", 转字符串(最大链长)))
    如果 (非空桶 > 0) {
        打印(字符串拼接("  平均链长: ", 转字符串(总链长 / 非空桶)))
    }
    打印("[字形缓存] ═══════════════════════════════════════")
}

函数 字形度量_打印(m) {
    如果 (m == 0) {
        打印("[度量] 空度量")
        返回
    }
    打印("[度量] ── 字形度量 ──")
    打印(字符串拼接("  前进宽度:   ", 转字符串(m.advanceWidth)))
    打印(字符串拼接("  左侧轴承:   ", 转字符串(m.lsb)))
    打印(字符串拼接("  右侧轴承:   ", 转字符串(m.rsb)))
    打印(字符串拼接("  包围盒:     [", 字符串拼接(转字符串(m.xMin), 字符串拼接(",", 字符串拼接(转字符串(m.yMin), 字符串拼接("]-[", 字符串拼接(转字符串(m.xMax), 字符串拼接(",", 字符串拼接(转字符串(m.yMax), "]")))))))))
    打印(字符串拼接("  缩放前进×64: ", 转字符串(m.缩放前进宽度)))
    打印(字符串拼接("  缩放宽度×64: ", 转字符串(m.缩放宽度)))
    打印(字符串拼接("  缩放高度×64: ", 转字符串(m.缩放高度)))
}

函数 字体度量_打印(度量) {
    如果 (度量 == 0) {
        打印("[字体度量] 空")
        返回
    }
    打印("[字体度量] ── 全局度量 ──")
    打印(字符串拼接("  每EM单位:   ", 转字符串(度量.每em单位)))
    打印(字符串拼接("  上升:       ", 转字符串(度量.上升)))
    打印(字符串拼接("  下降:       ", 转字符串(度量.下降)))
    打印(字符串拼接("  行间距:     ", 转字符串(度量.行间距)))
    打印(字符串拼接("  x高度:      ", 转字符串(度量.x高度)))
    打印(字符串拼接("  大写高度:   ", 转字符串(度量.大写高度)))
    打印(字符串拼接("  字形总数:   ", 转字符串(度量.字形总数)))
    打印(字符串拼接("  最大前进:   ", 转字符串(度量.最大前进宽度)))
}

函数 AI字形预取器_打印统计(预取器) {
    如果 (预取器 == 空) { 返回 }
    打印("[AI预取] ── 字形预取统计 ──")
    打印(字符串拼接("  预取次数:       ", 转字符串(预取器.统计_预取次数)))
    打印(字符串拼接("  预取命中次数:   ", 转字符串(预取器.统计_预取命中次数)))
    打印(字符串拼接("  预取浪费次数:   ", 转字符串(预取器.统计_预取浪费次数)))
}

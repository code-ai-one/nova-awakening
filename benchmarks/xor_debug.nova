函数 模糊与(a, b) {
    定义 _a = a + 0.0
    定义 _b = b + 0.0
    返回 _a * _b
}

函数 模糊或(a, b) {
    定义 _a = a + 0.0
    定义 _b = b + 0.0
    返回 _a + _b - _a * _b
}

函数 模糊非(a) {
    返回 1.0 - a
}

函数 模糊异或(a, b) {
    定义 _a = a + 0.0
    定义 _b = b + 0.0
    定义 或 = 模糊或(_a, _b)
    定义 与 = 模糊与(_a, _b)
    定义 非与 = 模糊非(与)
    定义 结果 = 模糊与(或, 非与)
    返回 结果
}

函数 主程序() {
    定义 或 = 模糊或(0.3, 0.7)
    打印(字符串拼接("或 bits=", 转字符串(或)))
    // 期望 0.79 = 0x3FE947AE147AE148
    
    定义 与 = 模糊与(0.3, 0.7)
    打印(字符串拼接("与 bits=", 转字符串(与)))
    // 期望 0.21 = 0x3FCAE147AE147AE1
    
    定义 非与 = 模糊非(与)
    打印(字符串拼接("非与 bits=", 转字符串(非与)))
    // 期望 0.79
    
    定义 r = 模糊与(或, 非与)
    打印(字符串拼接("与(或,非与) bits=", 转字符串(r)))
    // 期望 0.6241
    
    定义 x = 模糊异或(0.3, 0.7)
    打印(字符串拼接("XOR bits=", 转字符串(x)))
    返回 0
}

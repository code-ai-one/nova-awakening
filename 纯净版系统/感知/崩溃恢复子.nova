// §6 崩溃恢复 — 子进程崩溃不影响整个浏览器

函数 进程管理器_处理崩溃(pm, 崩溃PID) {
    定义 可变 i = 0
    当 (i < pm.进程数) {
        如果 (pm.进程表[i].PID == 崩溃PID) {
            pm.进程表[i].状态 = 2    // 崩溃
            pm.进程表[i].崩溃次数 = pm.进程表[i].崩溃次数 + 1

            如果 (pm.进程表[i].类型 == 进程类型_渲染器) {
                // 渲染器崩溃 → 显示"此页面已崩溃"
                // 用户可选择重新加载
                如果 (pm.进程表[i].崩溃次数 < 3) {
                    // 自动重启渲染器
                    进程管理器_重启渲染器(pm, i)
                }
            } 否则 如果 (pm.进程表[i].类型 == 进程类型_图处) {
                // 图处进程崩溃 → 回退到软件渲染
                pm.图处进程 = 0
                // 尝试重启图处进程
                进程管理器_启动图处(pm)
            } 否则 如果 (pm.进程表[i].类型 == 进程类型_网络) {
                // 网络进程崩溃 → 重启
                pm.网络进程 = 0
                进程管理器_启动网络(pm)
            }
            返回
        }
        i = i + 1
    }
}

函数 进程管理器_重启渲染器(pm, idx) {
    定义 旧站点键 = pm.进程表[idx].站点键
    // 关闭旧IPC通道
    IPC通道_关闭(pm.进程表[idx].IPC通道)
    // 创建新进程
    定义 通道 = IPC通道_创建()
    定义 PID = 系统调用(系统调用_进程_创建, 进程类型_渲染器, 0, 0, 0, 0)
    如果 (PID > 0) {
        pm.进程表[idx].PID = PID
        pm.进程表[idx].状态 = 0
        pm.进程表[idx].IPC通道 = 通道
        pm.进程表[idx].站点键 = 旧站点键
        通道.对端PID = PID
        沙箱_应用(PID, 沙箱_渲染器策略())
    }
}

// §7 IPC消息路由 — Browser进程分发消息

函数 Nova通信_路由消息(pm, 消息) {
    如果 (pm == 0 || 消息 == 0) { 返回 }

    定义 类型 = 消息.类型

    // AI相关IPC: Browser进程本地处理(AI总线在Browser中)
    如果 (类型 >= 400 && 类型 < 500) {
        Nova通信_处理AI请求(pm, 消息)
        返回
    }

    // 网络请求: 转发到Network进程
    如果 (类型 >= 200 && 类型 < 300) {
        如果 (pm.网络进程 != 0) {
            定义 网络info = pm.网络进程
            IPC通道_发送(网络info.IPC通道, 类型, 消息.数据, 消息.大小 - 16)
        }
        返回
    }

    // 图处请求: 转发到图处进程
    如果 (类型 >= 300 && 类型 < 400) {
        如果 (pm.图处进程 != 0) {
            定义 图处info = pm.图处进程
            IPC通道_发送(图处info.IPC通道, 类型, 消息.数据, 消息.大小 - 16)
        }
        返回
    }
}

// AI总线运行在Browser进程(可信进程)
// 渲染er进程通过IPC请求AI能力, Browser进程代理执行
// 这保证了:
//   ① 模型权重不泄露给不可信的渲染er
//   ② 用户隐私数据(注视点/行为)不离开Browser进程
//   ③ AI计算在Browser进程统一调度, 避免多渲染er争抢

函数 Nova通信_处理AI请求(pm, 消息) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 }

    定义 类型 = 消息.类型
    定义 发送者 = 消息.发送者PID

    // 找到发送者的IPC通道
    定义 回复通道 = Nova通信_查找通道(pm, 发送者)
    如果 (回复通道 == 0) { 返回 }

    如果 (类型 == Nova通信_请求_AI语义分类) {
        // 渲染er发来节点特征 → Browser执行AI分类 → 返回结果
        定义 特征数据 = 消息.数据
        // 执行AI推理(在Browser进程的AI总线中)
        定义 角色 = 5    // 默认角色(实际从特征推理)
        // 发送响应
        定义 结果 = 堆_分配_数组(4)
        内存_写32(结果, 角色)
        IPC通道_发送(回复通道, Nova通信_响应_AI语义分类, 结果, 4)
        堆_释放(结果)
    }
    否则 如果 (类型 == Nova通信_请求_AI渲染质量) {
        // 渲染er请求渲染质量决策
        // 数据: [x, y, w, h, 语义权重, 可见性]
        定义 x = 内存_读32(消息.数据)
        定义 y = 内存_读32(消息.数据 + 4)
        定义 w = 内存_读32(消息.数据 + 8)
        定义 h = 内存_读32(消息.数据 + 12)
        定义 语义 = 内存_读32(消息.数据 + 16)
        定义 级别 = AI总线_渲染质量(bus, x, y, w, h, 语义, 真)
        定义 结果 = 堆_分配_数组(4)
        内存_写32(结果, 级别)
        IPC通道_发送(回复通道, Nova通信_响应_AI渲染质量, 结果, 4)
        堆_释放(结果)
    }
    否则 如果 (类型 == Nova通信_请求_AI资源优先级) {
        定义 url = 消息.数据
        定义 优先级 = AI总线_资源优先级(bus, url)
        定义 结果 = 堆_分配_数组(4)
        内存_写32(结果, 优先级)
        IPC通道_发送(回复通道, Nova通信_响应_AI资源优先级, 结果, 4)
        堆_释放(结果)
    }
    否则 如果 (类型 == Nova通信_通知_AI行为事件) {
        // 渲染er上报用户行为 → 喂给AI总线的行为预测器
        定义 事件类型 = 内存_读32(消息.数据)
        定义 x = 内存_读32(消息.数据 + 4)
        定义 y = 内存_读32(消息.数据 + 8)
        AI总线_感知_鼠标移动(bus, x, y)
    }
}

函数 Nova通信_查找通道(pm, PID) {
    定义 可变 i = 0
    当 (i < pm.进程数) {
        如果 (pm.进程表[i].PID == PID) {
            返回 pm.进程表[i].IPC通道
        }
        i = i + 1
    }
    返回 0
}

// mkdir / rmdir / link / unlink

函数 ext4_创建目录(sb, 父Nova文件节点, 名称, 模式) {
    // 分配新Nova文件节点
    定义 新Nova文件节点 = ext4_分配Nova文件节点(sb, 父Nova文件节点, EXT4_S_IFDIR | (模式 & 0x0FFF))
    如果 (是错误(新Nova文件节点)) { 返回 新Nova文件节点 }

    新Nova文件节点.链接数 = 2  // "." 和 父目录的链接

    // 初始化目录内容: "." 和 ".."
    ext4_初始化目录块(sb, 新Nova文件节点, 父Nova文件节点.编号)

    // 在父目录中添加目录项
    定义 结果 = ext4_添加目录项(sb, 父Nova文件节点, 名称, 新Nova文件节点.编号, EXT4_FT_目录)
    如果 (结果 != 0) {
        ext4_释放Nova文件节点(sb, 新Nova文件节点.编号)
        返回 结果
    }

    // 父目录链接数+1(因为子目录的".."指向父)
    父Nova文件节点.链接数 = 父Nova文件节点.链接数 + 1

    返回 新Nova文件节点
}

函数 ext4_初始化目录块(sb, 目录Nova文件节点, 父Nova文件节点号) {
    定义 信息 = sb.私有信息
    定义 块大小 = 信息.块大小
    定义 ext4信息 = 目录Nova文件节点.私有信息

    // 分配第一个数据块
    定义 物理块 = ext4_分配块(sb, 1)
    如果 (物理块 == 0) { 返回 }

    ext4_extent_插入(sb, ext4信息, 0, 物理块, 1)
    目录Nova文件节点.大小 = 块大小

    定义 可变 缓冲 = 分配内存(块大小)
    内存置零(缓冲, 块大小)

    // "." 目录项
    定义 点记录长度 = 12
    ext4_写入目录项(缓冲, 0, 目录Nova文件节点.编号, ".", EXT4_FT_目录, 点记录长度)

    // ".." 目录项 (填满剩余空间)
    定义 点点记录长度 = 块大小 - 点记录长度
    ext4_写入目录项(缓冲, 点记录长度, 父Nova文件节点号, "..", EXT4_FT_目录, 点点记录长度)

    块设备_写(sb.设备, 物理块 * 块大小, 缓冲, 块大小)
    释放内存(缓冲)
}

函数 ext4_删除目录(sb, 父Nova文件节点, 名称) {
    // 查找子目录
    定义 项 = ext4_查找目录项(sb, 父Nova文件节点, 名称)
    如果 (项 == 空) { 返回 错误码_不存在 }

    定义 子Nova文件节点 = ext4_读Nova文件节点(sb, 项.Nova文件节点号)
    如果 (是错误(子Nova文件节点)) { 返回 子Nova文件节点 }

    // 检查目录是否为空(只含"."和"..")
    如果 (!ext4_目录为空(sb, 子Nova文件节点)) {
        返回 错误码_目录非空
    }

    // 删除目录项
    ext4_删除目录项(sb, 父Nova文件节点, 名称)

    // 更新链接数
    子Nova文件节点.链接数 = 0
    父Nova文件节点.链接数 = 父Nova文件节点.链接数 - 1

    返回 0
}

函数 ext4_目录为空(sb, 目录Nova文件节点) {
    定义 信息 = sb.私有信息
    定义 块大小 = 信息.块大小
    定义 ext4信息 = 目录Nova文件节点.私有信息

    定义 可变 偏移 = 0
    当 (偏移 < 目录Nova文件节点.大小) {
        定义 逻辑块 = 偏移 / 块大小
        定义 物理块 = ext4_extent_查找(sb, ext4信息, 逻辑块)
        如果 (物理块 == (0 - 1)) {
            偏移 = 偏移 + 块大小
            继续
        }

        定义 缓冲 = 块设备_读(sb.设备, 物理块 * 块大小, 块大小)
        如果 (缓冲 == 空) {
            偏移 = 偏移 + 块大小
            继续
        }

        定义 可变 块内偏移 = 0
        当 (块内偏移 < 块大小) {
            定义 项 = ext4_解析目录项(缓冲, 块内偏移)
            如果 (项.记录长度 == 0) { 跳出 }

            如果 (项.Nova文件节点号 != 0) {
                定义 名 = ext4_提取目录项名称(项)
                如果 (名 != "." && 名 != "..") {
                    缓冲_释放(缓冲)
                    返回 假
                }
            }
            块内偏移 = 块内偏移 + 项.记录长度
        }

        缓冲_释放(缓冲)
        偏移 = 偏移 + 块大小
    }
    返回 真
}

导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")

定义 最大区域 = 64
定义 直方图桶 = 16

结构 感知引擎 {
    宽度,
    高度,
    帧缓冲,
    上一帧,
    显著图,
    分析次数,
    运动检测次数,
}

定义 可变 全局感知 = 0

函数 感知_初始化(宽, 高) {
    全局感知 = 堆_分配(感知引擎)
    全局感知.宽度 = 宽
    全局感知.高度 = 高
    全局感知.帧缓冲 = 堆_分配(宽 * 高 * 4)
    全局感知.上一帧 = 堆_分配(宽 * 高 * 4)
    全局感知.显著图 = 堆_分配(宽 * 高)
    全局感知.分析次数 = 0
    全局感知.运动检测次数 = 0
}

函数 感知_更新帧(新帧数据) {
    如果 (全局感知 == 0) { 返回 }
    内存_复制(全局感知.上一帧, 全局感知.帧缓冲, 全局感知.宽度 * 全局感知.高度 * 4)
    内存_复制(全局感知.帧缓冲, 新帧数据, 全局感知.宽度 * 全局感知.高度 * 4)
    全局感知.分析次数 = 全局感知.分析次数 + 1
}

函数 感知_读像素(横, 纵) {
    如果 (全局感知 == 0) { 返回 0 }
    如果 (横 >= 全局感知.宽度 || 纵 >= 全局感知.高度) { 返回 0 }
    返回 内存_读32(全局感知.帧缓冲 + (纵 * 全局感知.宽度 + 横) * 4)
}

函数 感知_区域均值(横, 纵, 宽, 高) {
    如果 (全局感知 == 0) { 返回 0 }
    定义 可变 总红 = 0
    定义 可变 总绿 = 0
    定义 可变 总蓝 = 0
    定义 可变 计数 = 0
    定义 可变 行 = 纵
    当 (行 < 纵 + 高 && 行 < 全局感知.高度) {
        定义 可变 列 = 横
        当 (列 < 横 + 宽 && 列 < 全局感知.宽度) {
            定义 像素 = 内存_读32(全局感知.帧缓冲 + (行 * 全局感知.宽度 + 列) * 4)
            总红 = 总红 + ((像素 >> 16) & 0xFF)
            总绿 = 总绿 + ((像素 >> 8) & 0xFF)
            总蓝 = 总蓝 + (像素 & 0xFF)
            计数 = 计数 + 1
            列 = 列 + 1
        }
        行 = 行 + 1
    }
    如果 (计数 == 0) { 返回 0 }
    返回 ((总红 / 计数) << 16) | ((总绿 / 计数) << 8) | (总蓝 / 计数)
}

函数 感知_颜色直方图(横, 纵, 宽, 高, 输出) {
    如果 (全局感知 == 0) { 返回 }
    定义 可变 序号 = 0
    当 (序号 < 直方图桶) {
        内存_写32(输出 + 序号 * 4, 0)
        序号 = 序号 + 1
    }
    定义 可变 行 = 纵
    当 (行 < 纵 + 高 && 行 < 全局感知.高度) {
        定义 可变 列 = 横
        当 (列 < 横 + 宽 && 列 < 全局感知.宽度) {
            定义 像素 = 内存_读32(全局感知.帧缓冲 + (行 * 全局感知.宽度 + 列) * 4)
            定义 亮度 = (((像素 >> 16) & 0xFF) * 77 + ((像素 >> 8) & 0xFF) * 150 + (像素 & 0xFF) * 29) >> 8
            定义 桶号 = 亮度 * 直方图桶 / 256
            如果 (桶号 >= 直方图桶) { 桶号 = 直方图桶 - 1 }
            内存_写32(输出 + 桶号 * 4, 内存_读32(输出 + 桶号 * 4) + 1)
            列 = 列 + 1
        }
        行 = 行 + 1
    }
}

函数 感知_运动检测(阈值) {
    如果 (全局感知 == 0) { 返回 0 }
    全局感知.运动检测次数 = 全局感知.运动检测次数 + 1
    定义 像素数 = 全局感知.宽度 * 全局感知.高度
    定义 可变 运动像素 = 0
    定义 可变 序号 = 0
    当 (序号 < 像素数) {
        定义 当前 = 内存_读32(全局感知.帧缓冲 + 序号 * 4)
        定义 上一 = 内存_读32(全局感知.上一帧 + 序号 * 4)
        定义 差红 = ((当前 >> 16) & 0xFF) - ((上一 >> 16) & 0xFF)
        定义 差绿 = ((当前 >> 8) & 0xFF) - ((上一 >> 8) & 0xFF)
        定义 差蓝 = (当前 & 0xFF) - (上一 & 0xFF)
        如果 (差红 < 0) { 差红 = 0 - 差红 }
        如果 (差绿 < 0) { 差绿 = 0 - 差绿 }
        如果 (差蓝 < 0) { 差蓝 = 0 - 差蓝 }
        定义 差值 = 差红 + 差绿 + 差蓝
        如果 (差值 > 阈值) {
            运动像素 = 运动像素 + 1
            内存_写8(全局感知.显著图 + 序号, 255)
        } 否则 {
            内存_写8(全局感知.显著图 + 序号, 0)
        }
        序号 = 序号 + 1
    }
    返回 运动像素
}

函数 感知_显著区域(最小面积) {
    如果 (全局感知 == 0) { 返回 [0, 0, 0, 0] }
    定义 可变 最小横 = 全局感知.宽度
    定义 可变 最小纵 = 全局感知.高度
    定义 可变 最大横 = 0
    定义 可变 最大纵 = 0
    定义 可变 总显著 = 0
    定义 可变 纵 = 0
    当 (纵 < 全局感知.高度) {
        定义 可变 横 = 0
        当 (横 < 全局感知.宽度) {
            如果 (内存_读8(全局感知.显著图 + 纵 * 全局感知.宽度 + 横) > 128) {
                如果 (横 < 最小横) { 最小横 = 横 }
                如果 (纵 < 最小纵) { 最小纵 = 纵 }
                如果 (横 > 最大横) { 最大横 = 横 }
                如果 (纵 > 最大纵) { 最大纵 = 纵 }
                总显著 = 总显著 + 1
            }
            横 = 横 + 1
        }
        纵 = 纵 + 1
    }
    如果 (总显著 < 最小面积) { 返回 [0, 0, 0, 0] }
    返回 [最小横, 最小纵, 最大横 - 最小横 + 1, 最大纵 - 最小纵 + 1]
}

函数 感知_区域方差(横, 纵, 宽, 高) {
    如果 (全局感知 == 0) { 返回 0 }
    定义 均值 = 感知_区域均值(横, 纵, 宽, 高)
    定义 均红 = (均值 >> 16) & 0xFF
    定义 均绿 = (均值 >> 8) & 0xFF
    定义 均蓝 = 均值 & 0xFF
    定义 可变 方差和 = 0
    定义 可变 计数 = 0
    定义 可变 行 = 纵
    当 (行 < 纵 + 高 && 行 < 全局感知.高度) {
        定义 可变 列 = 横
        当 (列 < 横 + 宽 && 列 < 全局感知.宽度) {
            定义 像素 = 内存_读32(全局感知.帧缓冲 + (行 * 全局感知.宽度 + 列) * 4)
            定义 差红 = ((像素 >> 16) & 0xFF) - 均红
            定义 差绿 = ((像素 >> 8) & 0xFF) - 均绿
            定义 差蓝 = (像素 & 0xFF) - 均蓝
            方差和 = 方差和 + 差红 * 差红 + 差绿 * 差绿 + 差蓝 * 差蓝
            计数 = 计数 + 1
            列 = 列 + 1
        }
        行 = 行 + 1
    }
    如果 (计数 == 0) { 返回 0 }
    返回 方差和 / 计数
}

函数 感知_完整统计() {
    如果 (全局感知 == 0) { 返回 [0, 0, 0, 0] }
    返回 [全局感知.宽度, 全局感知.高度, 全局感知.分析次数, 全局感知.运动检测次数]
}

定义 可变 AI_像素感知引_调用数 = 0
定义 可变 AI_像素感知引_异常数 = 0

函数 AI_像素感知引_监控() {
    AI_像素感知引_调用数 = AI_像素感知引_调用数 + 1
    返回 AI_像素感知引_异常数 == 0
}

函数 AI_像素感知引_健康检查() {
    如果 (AI_像素感知引_调用数 > 0 && AI_像素感知引_异常数 * 100 / AI_像素感知引_调用数 > 10) {
        返回 假
    }
    返回 真
}

// §4 AES-128/256 (FIPS 197) — 分组加密核心

// AES S-Box (SubBytes变换)

定义 可变 AES_SBOX = [
    0x63,0x7c,0x77,0x7b,0xf2,0x6b,0x6f,0xc5,0x30,0x01,0x67,0x2b,0xfe,0xd7,0xab,0x76,
    0xca,0x82,0xc9,0x7d,0xfa,0x59,0x47,0xf0,0xad,0xd4,0xa2,0xaf,0x9c,0xa4,0x72,0xc0,
    0xb7,0xfd,0x93,0x26,0x36,0x3f,0xf7,0xcc,0x34,0xa5,0xe5,0xf1,0x71,0xd8,0x31,0x15,
    0x04,0xc7,0x23,0xc3,0x18,0x96,0x05,0x9a,0x07,0x12,0x80,0xe2,0xeb,0x27,0xb2,0x75,
    0x09,0x83,0x2c,0x1a,0x1b,0x6e,0x5a,0xa0,0x52,0x3b,0xd6,0xb3,0x29,0xe3,0x2f,0x84,
    0x53,0xd1,0x00,0xed,0x20,0xfc,0xb1,0x5b,0x6a,0xcb,0xbe,0x39,0x4a,0x4c,0x58,0xcf,
    0xd0,0xef,0xaa,0xfb,0x43,0x4d,0x33,0x85,0x45,0xf9,0x02,0x7f,0x50,0x3c,0x9f,0xa8,
    0x51,0xa3,0x40,0x8f,0x92,0x9d,0x38,0xf5,0xbc,0xb6,0xda,0x21,0x10,0xff,0xf3,0xd2,
    0xcd,0x0c,0x13,0xec,0x5f,0x97,0x44,0x17,0xc4,0xa7,0x7e,0x3d,0x64,0x5d,0x19,0x73,
    0x60,0x81,0x4f,0xdc,0x22,0x2a,0x90,0x88,0x46,0xee,0xb8,0x14,0xde,0x5e,0x0b,0xdb,
    0xe0,0x32,0x3a,0x0a,0x49,0x06,0x24,0x5c,0xc2,0xd3,0xac,0x62,0x91,0x95,0xe4,0x79,
    0xe7,0xc8,0x37,0x6d,0x8d,0xd5,0x4e,0xa9,0x6c,0x56,0xf4,0xea,0x65,0x7a,0xae,0x08,
    0xba,0x78,0x25,0x2e,0x1c,0xa6,0xb4,0xc6,0xe8,0xdd,0x74,0x1f,0x4b,0xbd,0x8b,0x8a,
    0x70,0x3e,0xb5,0x66,0x48,0x03,0xf6,0x0e,0x61,0x35,0x57,0xb9,0x86,0xc1,0x1d,0x9e,
    0xe1,0xf8,0x98,0x11,0x69,0xd9,0x8e,0x94,0x9b,0x1e,0x87,0xe9,0xce,0x55,0x28,0xdf,
    0x8c,0xa1,0x89,0x0d,0xbf,0xe6,0x42,0x68,0x41,0x99,0x2d,0x0f,0xb0,0x54,0xbb,0x16
]

// AES轮常量 (Rcon)
定义 可变 AES_RCON = [0x01, 0x02, 0x04, 0x08, 0x10, 0x20, 0x40, 0x80, 0x1b, 0x36]

// GF(2^8) 乘法 (用于MixColumns)
// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 AES_GF_mul2(x) {
    定义 result = (x << 1) & 0xFF
    如果 (x & 0x80) { result = result ^ 0x1B }  // 约化多项式
    返回 result
}

函数 AES_GF_mul3(x) { 返回 AES_GF_mul2(x) ^ x }

// AES密钥扩展 (128位 = 10轮, 256位 = 14轮)
函数 AES_密钥扩展(密钥, 密钥长度, 扩展密钥) {
    定义 Nk = 密钥长度 / 4   // 4 (AES-128) 或 8 (AES-256)
    定义 Nr = Nk + 6          // 10 或 14
    定义 Nw = 4 * (Nr + 1)    // 扩展密钥word数

    // 复制原始密钥
    定义 可变 i = 0
    当 (i < Nk) {
        内存_写32(扩展密钥 + i * 4,
            (内存_读8(密钥 + i * 4) << 24) |
            (内存_读8(密钥 + i * 4 + 1) << 16) |
            (内存_读8(密钥 + i * 4 + 2) << 8) |
            内存_读8(密钥 + i * 4 + 3))
        i = i + 1
    }

    // 扩展
    当 (i < Nw) {
        定义 temp = 内存_读32(扩展密钥 + (i - 1) * 4)
        如果 (i % Nk == 0) {
            // RotWord + SubWord + Rcon
            temp = ((AES_SBOX[(temp >> 16) & 0xFF] << 24) |
                    (AES_SBOX[(temp >> 8) & 0xFF] << 16) |
                    (AES_SBOX[temp & 0xFF] << 8) |
                    AES_SBOX[(temp >> 24) & 0xFF])
            temp = temp ^ (AES_RCON[i / Nk - 1] << 24)
        } 否则 如果 (Nk > 6 && i % Nk == 4) {
            // AES-256额外SubWord
            temp = (AES_SBOX[(temp >> 24) & 0xFF] << 24) |
                   (AES_SBOX[(temp >> 16) & 0xFF] << 16) |
                   (AES_SBOX[(temp >> 8) & 0xFF] << 8) |
                   AES_SBOX[temp & 0xFF]
        }
        内存_写32(扩展密钥 + i * 4,
            内存_读32(扩展密钥 + (i - Nk) * 4) ^ temp)
        i = i + 1
    }
    返回 Nr
}

// AES单块加密 (16字节输入 → 16字节输出)
函数 AES_加密块(状态, 扩展密钥, Nr) {
    // AddRoundKey (第0轮)
    AES_AddRoundKey(状态, 扩展密钥, 0)

    // Nr-1轮完整轮
    定义 可变 round = 1
    当 (round < Nr) {
        AES_SubBytes(状态)
        AES_ShiftRows(状态)
        AES_MixColumns(状态)
        AES_AddRoundKey(状态, 扩展密钥, round)
        round = round + 1
    }

    // 最后一轮(无MixColumns)
    AES_SubBytes(状态)
    AES_ShiftRows(状态)
    AES_AddRoundKey(状态, 扩展密钥, Nr)
}

函数 AES_SubBytes(状态) {
    定义 可变 i = 0
    当 (i < 16) {
        内存_写8(状态 + i, AES_SBOX[内存_读8(状态 + i)])
        i = i + 1
    }
}

函数 AES_ShiftRows(状态) {
    // 行1: 左移1
    定义 t = 内存_读8(状态 + 1)
    内存_写8(状态 + 1, 内存_读8(状态 + 5))
    内存_写8(状态 + 5, 内存_读8(状态 + 9))
    内存_写8(状态 + 9, 内存_读8(状态 + 13))
    内存_写8(状态 + 13, t)
    // 行2: 左移2
    定义 t0 = 内存_读8(状态 + 2); 定义 t1 = 内存_读8(状态 + 6)
    内存_写8(状态 + 2, 内存_读8(状态 + 10)); 内存_写8(状态 + 6, 内存_读8(状态 + 14))
    内存_写8(状态 + 10, t0); 内存_写8(状态 + 14, t1)
    // 行3: 左移3
    t = 内存_读8(状态 + 15)
    内存_写8(状态 + 15, 内存_读8(状态 + 11))
    内存_写8(状态 + 11, 内存_读8(状态 + 7))
    内存_写8(状态 + 7, 内存_读8(状态 + 3))
    内存_写8(状态 + 3, t)
}

函数 AES_MixColumns(状态) {
    定义 可变 c = 0
    当 (c < 4) {
        定义 i = c * 4
        定义 s0 = 内存_读8(状态 + i)
        定义 s1 = 内存_读8(状态 + i + 1)
        定义 s2 = 内存_读8(状态 + i + 2)
        定义 s3 = 内存_读8(状态 + i + 3)
        内存_写8(状态 + i,     AES_GF_mul2(s0) ^ AES_GF_mul3(s1) ^ s2 ^ s3)
        内存_写8(状态 + i + 1, s0 ^ AES_GF_mul2(s1) ^ AES_GF_mul3(s2) ^ s3)
        内存_写8(状态 + i + 2, s0 ^ s1 ^ AES_GF_mul2(s2) ^ AES_GF_mul3(s3))
        内存_写8(状态 + i + 3, AES_GF_mul3(s0) ^ s1 ^ s2 ^ AES_GF_mul2(s3))
        c = c + 1
    }
}

函数 AES_AddRoundKey(状态, 扩展密钥, round) {
    定义 rk = 扩展密钥 + round * 16
    定义 可变 i = 0
    当 (i < 4) {
        定义 k = 内存_读32(rk + i * 4)
        内存_写8(状态 + i * 4,     内存_读8(状态 + i * 4) ^ ((k >> 24) & 0xFF))
        内存_写8(状态 + i * 4 + 1, 内存_读8(状态 + i * 4 + 1) ^ ((k >> 16) & 0xFF))
        内存_写8(状态 + i * 4 + 2, 内存_读8(状态 + i * 4 + 2) ^ ((k >> 8) & 0xFF))
        内存_写8(状态 + i * 4 + 3, 内存_读8(状态 + i * 4 + 3) ^ (k & 0xFF))
        i = i + 1
    }
}

// 内核页表初始化 (替换引导存根的临时页表)

函数 页表_重建() {
    // 1. 分配新的PML4
    内核_PML4物理 = 页表_分配页()

    // 2. 恒等映射: 虚拟0-4GB → 物理0-4GB (用2MB大页快速映射)
    页表_恒等映射_2MB(内核_PML4物理, 0, 4 * GB)

    // 3. 高半核映射: 0xFFFF800000000000+ → 物理0+ (直接映射区)
    页表_高半核映射(内核_PML4物理)

    // 4. 内核映像映射: 0xFFFFFFFF80000000+ → 物理1MB+ (内核代码/数据)
    页表_内核映像映射(内核_PML4物理)

    // 5. 切换CR3
    写CR3(内核_PML4物理)
    刷新全部TLB()

    早期打印OK("内核页表重建完成")
    早期打印十六进制("  PML4物理地址", 内核_PML4物理)
}

// 恒等映射: 用2MB大页 (PD级PS位)
函数 页表_恒等映射_2MB(PML4物理, 起始, 大小) {
    定义 可变 地址 = 起始
    当 (地址 < 起始 + 大小) {
        定义 pml4_idx = PML4索引(地址)
        定义 pdpt_idx = PDPT索引(地址)
        定义 pd_idx = PD索引(地址)

        // 确保PML4→PDPT存在
        定义 pml4_条目 = 页表_读条目(PML4物理, pml4_idx)
        定义 可变 pdpt_物理 = 0
        如果 (页表项_存在(pml4_条目)) {
            pdpt_物理 = 页表项_地址(pml4_条目)
        } 否则 {
            pdpt_物理 = 页表_分配页()
            页表_写条目(PML4物理, pml4_idx, 页表项_创建(pdpt_物理, PTE_存在 | PTE_可写))
        }

        // 确保PDPT→PD存在
        定义 pdpt_条目 = 页表_读条目(pdpt_物理, pdpt_idx)
        定义 可变 pd_物理 = 0
        如果 (页表项_存在(pdpt_条目)) {
            pd_物理 = 页表项_地址(pdpt_条目)
        } 否则 {
            pd_物理 = 页表_分配页()
            页表_写条目(pdpt_物理, pdpt_idx, 页表项_创建(pd_物理, PTE_存在 | PTE_可写))
        }

        // PD条目: 2MB大页 (PS=1)
        页表_写条目(pd_物理, pd_idx, 页表项_创建(地址, PTE_存在 | PTE_可写 | PTE_大页))

        地址 = 地址 + 大页大小  // +2MB
    }
}

// 高半核直接映射: 0xFFFF880000000000 → 物理0
函数 页表_高半核映射(PML4物理) {
    // 映射前4GB物理内存到直接映射区
    定义 直接映射VA = 物理内存映射基址   // 0xFFFF880000000000
    定义 可变 物理 = 0
    当 (物理 < 4 * GB) {
        定义 VA = 直接映射VA + 物理
        定义 pml4_idx = PML4索引(VA)
        定义 pdpt_idx = PDPT索引(VA)

        // PML4条目
        定义 pml4_条目 = 页表_读条目(PML4物理, pml4_idx)
        定义 可变 pdpt_物理 = 0
        如果 (页表项_存在(pml4_条目)) {
            pdpt_物理 = 页表项_地址(pml4_条目)
        } 否则 {
            pdpt_物理 = 页表_分配页()
            页表_写条目(PML4物理, pml4_idx, 页表项_创建(pdpt_物理, PTE_存在 | PTE_可写))
        }

        // PDPT条目: 用1GB大页(如果CPU支持)
        页表_写条目(pdpt_物理, pdpt_idx, 页表项_创建(物理, PTE_存在 | PTE_可写 | PTE_大页))

        物理 = 物理 + GB
    }
}

// 内核映像映射: 0xFFFFFFFF80100000 → 物理0x100000
函数 页表_内核映像映射(PML4物理) {
    定义 内核VA = 内核基址 + 0x100000   // 0xFFFFFFFF80100000
    定义 内核PA = 0x100000               // 1MB
    定义 内核大小 = 16 * MB              // 映射16MB够用

    映射范围(PML4物理, 内核VA, 内核PA, 内核大小, PTE_存在 | PTE_可写)
}

// 内核页表重建 (替换引导存根的临时恒等映射)
// 由内核主函数在物理内存初始化后调用

函数 页表_内核重建() {
    // 1. 分配新PML4
    内核_PML4物理 = 页表_分配页()
    如果 (内核_PML4物理 == 0) {
        内核恐慌("页表重建: 无法分配PML4页")
    }

    // 2. 恒等映射前4GB (引导阶段需要)
    映射范围_2MB(内核_PML4物理, 0, 0, 4 * GB)

    // 3. 高半核直接映射 0xFFFF880000000000 → 物理0
    页表_高半核映射(内核_PML4物理)

    // 4. 内核映像映射 0xFFFFFFFF80100000 → 物理1MB
    页表_内核映像映射(内核_PML4物理)

    // 5. 切换到新页表
    写CR3(内核_PML4物理)

    // 6. 刷新TLB
    刷新全部TLB()

    早期打印OK("内核页表重建 (恒等+高半核+内核映像)")
}

// 页表辅助操作

定义 PTE_存在 = 0x01
定义 PTE_可写 = 0x02
定义 PTE_用户 = 0x04
定义 PTE_大页 = 0x80
定义 PTE_不可执行 = 0x8000000000000000
定义 GB = 0x40000000
定义 MB = 0x100000
定义 大页大小 = 0x200000
定义 可变 内核_PML4物理 = 0
定义 物理内存映射基址 = 0xFFFF880000000000
定义 内核基址 = 0xFFFFFFFF80000000

函数 PML4索引(VA) { 返回 (VA >> 39) & 0x1FF }
函数 PDPT索引(VA) { 返回 (VA >> 30) & 0x1FF }
函数 PD索引(VA) { 返回 (VA >> 21) & 0x1FF }
函数 PT索引(VA) { 返回 (VA >> 12) & 0x1FF }

函数 页表项_存在(条目) { 返回 (条目 & PTE_存在) != 0 }
函数 页表项_地址(条目) { 返回 条目 & 0x000FFFFFFFFFF000 }
函数 页表项_创建(地址, 标志) { 返回 (地址 & 0x000FFFFFFFFFF000) | 标志 }

函数 页表_读条目(表物理, 索引) {
    返回 内存读64(表物理 + 索引 * 8)
}

函数 页表_写条目(表物理, 索引, 值) {
    内存写64(表物理 + 索引 * 8, 值)
}

函数 页表_分配页() {
    定义 页 = 伙伴系统_分配(1)
    如果 (页 != 0) { 内存_置零(页, 4096) }
    返回 页
}

函数 映射范围(PML4, VA, PA, 大小, 标志) {
    定义 可变 偏移 = 0
    当 (偏移 < 大小) {
        映射单页(PML4, VA + 偏移, PA + 偏移, 标志)
        偏移 = 偏移 + 4096
    }
}

函数 映射单页(PML4, VA, PA, 标志) {
    定义 pml4i = PML4索引(VA)
    定义 pdpti = PDPT索引(VA)
    定义 pdi = PD索引(VA)
    定义 pti = PT索引(VA)

    // PML4→PDPT
    定义 可变 pdpt = 0
    定义 pml4e = 页表_读条目(PML4, pml4i)
    如果 (页表项_存在(pml4e)) { pdpt = 页表项_地址(pml4e) }
    否则 { pdpt = 页表_分配页(); 页表_写条目(PML4, pml4i, 页表项_创建(pdpt, PTE_存在 | PTE_可写 | PTE_用户)) }

    // PDPT→PD
    定义 可变 pd = 0
    定义 pdpte = 页表_读条目(pdpt, pdpti)
    如果 (页表项_存在(pdpte)) { pd = 页表项_地址(pdpte) }
    否则 { pd = 页表_分配页(); 页表_写条目(pdpt, pdpti, 页表项_创建(pd, PTE_存在 | PTE_可写 | PTE_用户)) }

    // PD→PT
    定义 可变 pt = 0
    定义 pde = 页表_读条目(pd, pdi)
    如果 (页表项_存在(pde)) { pt = 页表项_地址(pde) }
    否则 { pt = 页表_分配页(); 页表_写条目(pd, pdi, 页表项_创建(pt, PTE_存在 | PTE_可写 | PTE_用户)) }

    // PT条目
    页表_写条目(pt, pti, 页表项_创建(PA, 标志))
}

函数 映射范围_2MB(PML4, VA, PA, 大小) {
    页表_恒等映射_2MB(PML4, VA, 大小)
}

// TLB管理

函数 写CR3(值) {
    汇编 { "mov rax, rdi" "mov cr3, rax" }
}

函数 刷新全部TLB() {
    // 重写CR3刷新全部TLB
    定义 当前CR3 = 内核_PML4物理
    写CR3(当前CR3)
}

函数 刷新单页TLB(虚拟地址) {
    汇编 { "mov rax, rdi" "invlpg [rax]" }
}

函数 早期打印OK(消息) {
    打印(消息)
}
函数 早期打印十六进制(前缀, 值) {
    打印(前缀 + 整数转十六进制(值))
}
函数 内核恐慌(消息) {
    打印("!!! 内核恐慌: " + 消息)
    汇编 { "cli" "hlt" }
}
函数 伙伴系统_分配(页数) {
    如果 (页数 <= 0) { 返回 0 }
    返回 物理页_分配(页数)
}

// 页表遍历(用于调试/缺页处理)

函数 页表_查询(PML4, VA) {
    定义 pml4e = 页表_读条目(PML4, PML4索引(VA))
    如果 (!页表项_存在(pml4e)) { 返回 0 }
    定义 pdpte = 页表_读条目(页表项_地址(pml4e), PDPT索引(VA))
    如果 (!页表项_存在(pdpte)) { 返回 0 }
    如果 (pdpte & PTE_大页) { 返回 页表项_地址(pdpte) + (VA & 0x3FFFFFFF) }
    定义 pde = 页表_读条目(页表项_地址(pdpte), PD索引(VA))
    如果 (!页表项_存在(pde)) { 返回 0 }
    如果 (pde & PTE_大页) { 返回 页表项_地址(pde) + (VA & 0x1FFFFF) }
    定义 pte = 页表_读条目(页表项_地址(pde), PT索引(VA))
    如果 (!页表项_存在(pte)) { 返回 0 }
    返回 页表项_地址(pte) + (VA & 0xFFF)
}

函数 页表_统计() {
    返回 {
        PML4: 内核_PML4物理,
    }
}

// 页表重建辅助

定义 可变 页表_重建次数 = 0
定义 可变 页表_映射页数 = 0
定义 可变 页表_取消映射数 = 0

函数 页表_健康检查() {
    定义 可变 问题 = []
    如果 (页表_重建次数 > 1000) {
        追加(问题, "页表重建过频: " + 整数转字符串(页表_重建次数))
    }
    如果 (计数(问题) == 0) { 返回 "页表管理健康" }
    返回 问题
}

函数 页表_映射统计() {
    返回 {
        重建: 页表_重建次数,
        映射: 页表_映射页数,
        取消映射: 页表_取消映射数,
    }
}

函数 页表_重置统计() {
    页表_重建次数 = 0
    页表_映射页数 = 0
    页表_取消映射数 = 0
}

定义 PAGE_PRESENT = 0x01
定义 PAGE_RW = 0x02
定义 PAGE_USER = 0x04
定义 PAGE_PWT = 0x08
定义 PAGE_PCD = 0x10
定义 PAGE_ACCESSED = 0x20
定义 PAGE_DIRTY = 0x40
定义 PAGE_SIZE_2M = 0x80
定义 PAGE_NX = 0x8000000000000000

定义 可变 AI_页表重建_运行指标 = 0
定义 可变 AI_页表重建_异常指标 = 0

函数 AI_页表重建_自诊断() {
    AI_页表重建_运行指标 = 页表_重建次数
    返回 AI_页表重建_运行指标
}

函数 AI_页表重建_优化建议() {
    定义 指标 = AI_页表重建_自诊断()
    如果 (AI_页表重建_运行指标 > 10000) { 返回 "页表重建负载较高" }
    返回 "页表重建状态正常"
}

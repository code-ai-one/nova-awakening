// NovaOS 块I/O层
// 请求队列/合并/调度/优先级/延迟追踪/屏障/统计

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/创建甲.nova")
导入("../中枢/整数转字符串.nova")

定义 块读 = 0
定义 块写 = 1
定义 块同步 = 2
定义 块屏障 = 3
定义 块丢弃 = 4       // TRIM/DISCARD

定义 优先_实时 = 0
定义 优先_高 = 1
定义 优先_普通 = 2
定义 优先_低 = 3
定义 优先级数 = 4

定义 状态_等待 = 0
定义 状态_进行 = 1
定义 状态_完成 = 2
定义 状态_错误 = 3

定义 最大请求 = 256
定义 扇区大小 = 512
定义 最大批量 = 32
定义 延迟桶数 = 8     // 延迟直方图桶数
定义 最大设备数 = 16

定义 调度_FIFO = 0
定义 调度_电梯 = 1
定义 调度_截止 = 2

定义 可变 当前调度算法 = 调度_FIFO
定义 可变 电梯方向 = 1      // 1=向上, -1=向下
定义 可变 电梯当前扇区 = 0

结构 块请求 {
    类型,
    设备号,
    起始扇区,
    扇区数,
    缓冲地址,
    完成回调,
    状态,
    提交时刻,
    完成时刻,
    优先级,
    截止时间,
    后继,
}

结构 优先队列 {
    队头,
    队尾,
    长度,
}

定义 可变 优先队列组 = []   // 4个优先级队列
定义 可变 请求数 = 0

定义 可变 总分配 = 0
定义 可变 总完成 = 0
定义 可变 总错误 = 0
定义 可变 总读字节 = 0
定义 可变 总写字节 = 0
定义 可变 合并次数 = 0
定义 可变 总屏障 = 0
定义 可变 总丢弃 = 0
定义 可变 总延迟 = 0       // 累计延迟(微秒)
定义 可变 最小延迟 = 999999999
定义 可变 最大延迟 = 0
定义 可变 批量分发次数 = 0

定义 可变 延迟直方图 = [0, 0, 0, 0, 0, 0, 0, 0]

结构 设备IO统计 {
    设备号,
    读次数,
    写次数,
    读字节,
    写字节,
    错误数,
}
定义 可变 设备统计表 = []

// §1 初始化

函数 块_初始化() {
    优先队列组 = []
    定义 可变 p = 0
    当 (p < 优先级数) {
        定义 q = 优先队列 {}
        q.队头 = 0
        q.队尾 = 0
        q.长度 = 0
        追加(优先队列组, q)
        p = p + 1
    }
    请求数 = 0
    电梯当前扇区 = 0
    电梯方向 = 1
}

函数 块_设置调度(算法) {
    如果 (算法 >= 调度_FIFO && 算法 <= 调度_截止) {
        当前调度算法 = 算法
    }
}

// §2 提交请求

函数 块_提交(类型, 设备, 扇区, 数量, 缓冲, 回调) {
    如果 (请求数 >= 最大请求) { 返回 错误_队列满 }
    总分配 = 总分配 + 1

    // 尝试合并
    定义 合并目标 = 块_尝试合并(设备, 扇区, 数量, 类型)
    如果 (合并目标 != 0) {
        合并目标.扇区数 = 合并目标.扇区数 + 数量
        合并次数 = 合并次数 + 1
        返回 0
    }

    定义 请求 = 堆_分配(块请求)
    请求.类型 = 类型
    请求.设备号 = 设备
    请求.起始扇区 = 扇区
    请求.扇区数 = 数量
    请求.缓冲地址 = 缓冲
    请求.完成回调 = 回调
    请求.状态 = 状态_等待
    请求.提交时刻 = 平台_获取高精度时间()
    请求.完成时刻 = 0
    请求.优先级 = 优先_普通
    请求.截止时间 = 请求.提交时刻 + 100000  // 默认100ms截止
    请求.后继 = 0

    // 加入对应优先级队列
    块_入队(请求, 请求.优先级)
    返回 0
}

函数 块_提交_优先(类型, 设备, 扇区, 数量, 缓冲, 回调, 优先级) {
    如果 (请求数 >= 最大请求) { 返回 错误_队列满 }
    如果 (优先级 < 0 || 优先级 >= 优先级数) { 优先级 = 优先_普通 }
    总分配 = 总分配 + 1

    定义 请求 = 堆_分配(块请求)
    请求.类型 = 类型
    请求.设备号 = 设备
    请求.起始扇区 = 扇区
    请求.扇区数 = 数量
    请求.缓冲地址 = 缓冲
    请求.完成回调 = 回调
    请求.状态 = 状态_等待
    请求.提交时刻 = 平台_获取高精度时间()
    请求.完成时刻 = 0
    请求.优先级 = 优先级
    请求.截止时间 = 请求.提交时刻 + 100000
    请求.后继 = 0

    块_入队(请求, 优先级)
    返回 0
}

// §3 队列操作

函数 块_入队(请求, 优先级) {
    定义 q = 优先队列组[优先级]
    如果 (q.队尾 != 0) {
        q.队尾.后继 = 请求
    } 否则 {
        q.队头 = 请求
    }
    q.队尾 = 请求
    q.长度 = q.长度 + 1
    请求数 = 请求数 + 1
}

函数 块_出队(优先级) {
    定义 q = 优先队列组[优先级]
    如果 (q.队头 == 0) { 返回 0 }
    定义 请求 = q.队头
    q.队头 = 请求.后继
    如果 (q.队头 == 0) { q.队尾 = 0 }
    q.长度 = q.长度 - 1
    请求数 = 请求数 - 1
    请求.后继 = 0
    返回 请求
}

// §4 合并

函数 块_尝试合并(设备, 扇区, 数量, 类型) {
    // 遍历所有优先级队列寻找可合并请求
    定义 可变 p = 0
    当 (p < 优先级数) {
        定义 可变 当前 = 优先队列组[p].队头
        当 (当前 != 0) {
            如果 (当前.设备号 == 设备 && 当前.类型 == 类型 && 当前.状态 == 状态_等待) {
                // 后向合并
                如果 (当前.起始扇区 + 当前.扇区数 == 扇区) { 返回 当前 }
                // 前向合并
                如果 (扇区 + 数量 == 当前.起始扇区) {
                    当前.起始扇区 = 扇区
                    返回 当前
                }
            }
            当前 = 当前.后继
        }
        p = p + 1
    }
    返回 0
}

// §5 调度/分发

函数 块_分发() {
    如果 (当前调度算法 == 调度_FIFO) { 返回 块_分发_FIFO() }
    如果 (当前调度算法 == 调度_电梯) { 返回 块_分发_电梯() }
    如果 (当前调度算法 == 调度_截止) { 返回 块_分发_截止() }
    返回 块_分发_FIFO()
}

// FIFO: 按优先级从高到低取
函数 块_分发_FIFO() {
    定义 可变 p = 0
    当 (p < 优先级数) {
        如果 (优先队列组[p].长度 > 0) {
            定义 请求 = 块_出队(p)
            如果 (请求 != 0) {
                请求.状态 = 状态_进行
                返回 请求
            }
        }
        p = p + 1
    }
    返回 0
}

// 电梯调度: 单方向扫描
函数 块_分发_电梯() {
    定义 可变 最佳 = 0
    定义 可变 最佳距离 = 999999999
    定义 可变 最佳优先 = -1

    定义 可变 p = 0
    当 (p < 优先级数) {
        定义 可变 当前 = 优先队列组[p].队头
        当 (当前 != 0) {
            如果 (当前.状态 == 状态_等待) {
                定义 距离 = 当前.起始扇区 - 电梯当前扇区
                如果 (电梯方向 == 1 && 距离 >= 0 && 距离 < 最佳距离) {
                    最佳 = 当前
                    最佳距离 = 距离
                    最佳优先 = p
                }
                如果 (电梯方向 == -1 && 距离 <= 0) {
                    定义 abs_d = -距离
                    如果 (abs_d < 最佳距离) {
                        最佳 = 当前
                        最佳距离 = abs_d
                        最佳优先 = p
                    }
                }
            }
            当前 = 当前.后继
        }
        p = p + 1
    }

    // 没找到? 反转方向
    如果 (最佳 == 0) {
        电梯方向 = -电梯方向
        返回 块_分发_FIFO()  // 降级到FIFO
    }

    // 从队列中移除最佳请求
    块_移除请求(最佳, 最佳优先)
    电梯当前扇区 = 最佳.起始扇区 + 最佳.扇区数
    最佳.状态 = 状态_进行
    返回 最佳
}

// 截止调度: 选择最接近截止时间的
函数 块_分发_截止() {
    定义 可变 最佳 = 0
    定义 可变 最早截止 = 999999999
    定义 可变 最佳优先 = -1

    定义 可变 p = 0
    当 (p < 优先级数) {
        定义 可变 当前 = 优先队列组[p].队头
        当 (当前 != 0) {
            如果 (当前.状态 == 状态_等待 && 当前.截止时间 < 最早截止) {
                最佳 = 当前
                最早截止 = 当前.截止时间
                最佳优先 = p
            }
            当前 = 当前.后继
        }
        p = p + 1
    }

    如果 (最佳 == 0) { 返回 0 }
    块_移除请求(最佳, 最佳优先)
    最佳.状态 = 状态_进行
    返回 最佳
}

函数 块_移除请求(目标, 优先级) {
    定义 q = 优先队列组[优先级]
    如果 (q.队头 == 目标) {
        q.队头 = 目标.后继
        如果 (q.队头 == 0) { q.队尾 = 0 }
        q.长度 = q.长度 - 1
        请求数 = 请求数 - 1
        返回
    }
    定义 可变 前驱 = q.队头
    当 (前驱 != 0 && 前驱.后继 != 目标) {
        前驱 = 前驱.后继
    }
    如果 (前驱 != 0) {
        前驱.后继 = 目标.后继
        如果 (q.队尾 == 目标) { q.队尾 = 前驱 }
        q.长度 = q.长度 - 1
        请求数 = 请求数 - 1
    }
}

// §6 批量分发

函数 块_批量分发(批量) {
    如果 (批量 <= 0) { 批量 = 最大批量 }
    如果 (批量 > 最大批量) { 批量 = 最大批量 }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 批量) {
        定义 请求 = 块_分发()
        如果 (请求 == 0) { 跳出 }
        追加(结果, 请求)
        i = i + 1
    }
    批量分发次数 = 批量分发次数 + 1
    返回 结果
}

// §7 完成

函数 块_完成(请求, 错误码) {
    如果 (请求 == 0) { 返回 }
    请求.完成时刻 = 平台_获取高精度时间()
    定义 延迟 = 请求.完成时刻 - 请求.提交时刻

    如果 (错误码 == 0) {
        总完成 = 总完成 + 1
        请求.状态 = 状态_完成
        如果 (请求.类型 == 块读) {
            总读字节 = 总读字节 + 请求.扇区数 * 扇区大小
            块_更新设备统计(请求.设备号, 块读, 请求.扇区数 * 扇区大小)
        } 否则 如果 (请求.类型 == 块写) {
            总写字节 = 总写字节 + 请求.扇区数 * 扇区大小
            块_更新设备统计(请求.设备号, 块写, 请求.扇区数 * 扇区大小)
        } 否则 如果 (请求.类型 == 块屏障) {
            总屏障 = 总屏障 + 1
        } 否则 如果 (请求.类型 == 块丢弃) {
            总丢弃 = 总丢弃 + 1
        }
        // 延迟统计
        总延迟 = 总延迟 + 延迟
        如果 (延迟 < 最小延迟) { 最小延迟 = 延迟 }
        如果 (延迟 > 最大延迟) { 最大延迟 = 延迟 }
        块_记录延迟(延迟)
    } 否则 {
        总错误 = 总错误 + 1
        请求.状态 = 状态_错误
        块_更新设备错误(请求.设备号)
    }
    如果 (请求.完成回调 != 0) { 请求.完成回调(请求, 错误码) }
    堆_释放(请求)
}

// §8 延迟直方图

函数 块_记录延迟(延迟_微秒) {
    定义 ms = 延迟_微秒 / 1000
    如果 (ms < 1) { 延迟直方图[0] = 延迟直方图[0] + 1 }
    否则 如果 (ms < 2) { 延迟直方图[1] = 延迟直方图[1] + 1 }
    否则 如果 (ms < 4) { 延迟直方图[2] = 延迟直方图[2] + 1 }
    否则 如果 (ms < 8) { 延迟直方图[3] = 延迟直方图[3] + 1 }
    否则 如果 (ms < 16) { 延迟直方图[4] = 延迟直方图[4] + 1 }
    否则 如果 (ms < 32) { 延迟直方图[5] = 延迟直方图[5] + 1 }
    否则 如果 (ms < 64) { 延迟直方图[6] = 延迟直方图[6] + 1 }
    否则 { 延迟直方图[7] = 延迟直方图[7] + 1 }
}

// §9 每设备统计

函数 块_查找设备统计(设备号) {
    定义 可变 i = 0
    当 (i < 计数(设备统计表)) {
        如果 (设备统计表[i].设备号 == 设备号) { 返回 设备统计表[i] }
        i = i + 1
    }
    // 新建
    如果 (计数(设备统计表) >= 最大设备数) { 返回 0 }
    定义 s = 设备IO统计 {}
    s.设备号 = 设备号
    s.读次数 = 0
    s.写次数 = 0
    s.读字节 = 0
    s.写字节 = 0
    s.错误数 = 0
    追加(设备统计表, s)
    返回 s
}

函数 块_更新设备统计(设备号, 类型, 字节数) {
    定义 s = 块_查找设备统计(设备号)
    如果 (s == 0) { 返回 }
    如果 (类型 == 块读) {
        s.读次数 = s.读次数 + 1
        s.读字节 = s.读字节 + 字节数
    } 否则 如果 (类型 == 块写) {
        s.写次数 = s.写次数 + 1
        s.写字节 = s.写字节 + 字节数
    }
}

函数 块_更新设备错误(设备号) {
    定义 s = 块_查找设备统计(设备号)
    如果 (s != 0) { s.错误数 = s.错误数 + 1 }
}

// §10 便捷接口

函数 块_读(设备, 扇区, 数量, 缓冲) {
    返回 块_提交(块读, 设备, 扇区, 数量, 缓冲, 0)
}

函数 块_写(设备, 扇区, 数量, 缓冲) {
    返回 块_提交(块写, 设备, 扇区, 数量, 缓冲, 0)
}

函数 块_同步设备(设备) {
    返回 块_提交(块同步, 设备, 0, 0, 0, 0)
}

函数 块_屏障(设备) {
    返回 块_提交(块屏障, 设备, 0, 0, 0, 0)
}

函数 块_丢弃(设备, 扇区, 数量) {
    返回 块_提交(块丢弃, 设备, 扇区, 数量, 0, 0)
}

函数 块_队列长度() { 返回 请求数 }

// §11 统计

函数 块输入_完整统计() {
    返回 [总分配, 总完成, 总错误, 总读字节, 总写字节, 合并次数, 请求数]
}

函数 块输入_打印统计() {
    打印行("=== 块I/O统计 ===")
    打印行("总分配: " + 整数转字符串(总分配))
    打印行("总完成: " + 整数转字符串(总完成))
    打印行("总错误: " + 整数转字符串(总错误))
    打印行("读字节: " + 整数转字符串(总读字节))
    打印行("写字节: " + 整数转字符串(总写字节))
    打印行("合并次数: " + 整数转字符串(合并次数))
    打印行("队列长度: " + 整数转字符串(请求数))
    打印行("屏障: " + 整数转字符串(总屏障))
    打印行("丢弃: " + 整数转字符串(总丢弃))
    打印行("批量分发: " + 整数转字符串(批量分发次数))
    如果 (总完成 > 0) {
        定义 平均延迟 = 总延迟 / 总完成
        打印行("平均延迟: " + 整数转字符串(平均延迟) + " us")
        打印行("最小延迟: " + 整数转字符串(最小延迟) + " us")
        打印行("最大延迟: " + 整数转字符串(最大延迟) + " us")
    }
    打印行("调度算法: " + 整数转字符串(当前调度算法))

    // 延迟直方图
    打印行("延迟分布:")
    打印行("  <1ms: " + 整数转字符串(延迟直方图[0]))
    打印行("  <2ms: " + 整数转字符串(延迟直方图[1]))
    打印行("  <4ms: " + 整数转字符串(延迟直方图[2]))
    打印行("  <8ms: " + 整数转字符串(延迟直方图[3]))
    打印行("  <16ms: " + 整数转字符串(延迟直方图[4]))
    打印行("  <32ms: " + 整数转字符串(延迟直方图[5]))
    打印行("  <64ms: " + 整数转字符串(延迟直方图[6]))
    打印行("  >=64ms: " + 整数转字符串(延迟直方图[7]))

    // 每设备
    打印行("设备统计:")
    定义 可变 i = 0
    当 (i < 计数(设备统计表)) {
        定义 s = 设备统计表[i]
        打印行("  设备" + 整数转字符串(s.设备号) +
            " 读=" + 整数转字符串(s.读次数) + "/" + 整数转字符串(s.读字节) + "B" +
            " 写=" + 整数转字符串(s.写次数) + "/" + 整数转字符串(s.写字节) + "B" +
            " 错误=" + 整数转字符串(s.错误数))
        i = i + 1
    }
}

定义 可变 AI_输入完整统_负载窗口 = []

函数 AI_输入完整统_负载预测(当前负载) {
    追加(AI_输入完整统_负载窗口, 当前负载)
    如果 (计数(AI_输入完整统_负载窗口) > 20) { 列表_移除(AI_输入完整统_负载窗口, 0) }
    如果 (计数(AI_输入完整统_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_输入完整统_负载窗口)
    定义 趋势 = AI_输入完整统_负载窗口[n-1] - AI_输入完整统_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_输入完整统_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

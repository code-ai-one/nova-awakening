导入("../../基础.nova")

// Nova标准库 — 通道 (Channel)
// 生产级 CSP 通道: 无缓冲/有缓冲/广播/选择器
// 支持多生产者多消费者 (MPMC)

// 有缓冲通道 (Buffered Channel)
// 型: [缓冲区, 容量, 头指针, 尾指针, 当前大小, 已关闭, 发送等待队列, 接收等待队列, 总发送数, 总接收数]

函数 通道_创建(容量) { 定义 可变 实际容量 = 容量
    如果 (实际容量 <= 0) { 实际容量 = 1
}
 定义 可变 缓冲 = []
 定义 可变 i = 0
 当 (i < 实际容量) { 追加(缓冲, 空) i = i + 1 }
 返回 [缓冲, 实际容量, 0, 0, 假, [], [],]
}

函数 通道_发送(通道, 值) {
    如果 (通道[5]) { 返回 ["错误", "通道已关闭"]
}
 如果 (通道[4] >= 通道[1]) { 返回 ["阻塞", "缓冲区已满"]
 }
 通道[0][通道[3]] = 值
 通道[3] = (通道[3] + 1) % 通道[1]
 通道[4] = 通道[4] + 1
 通道[8] = 通道[8] + 1
 // 唤醒等待的接收者
 如果 (计数(通道[7]) > 0) { 定义 接收者 = 通道[7][0]
 定义 可变 新等待 = []
 定义 可变 i = 1
 当 (i < 计数(通道[7])) { 追加(新等待, 通道[7][i]) i = i + 1 }
 通道[7] = 新等待
 返回 ["成功", 接收者]
 }
 返回 ["成功", 空]
}

函数 通道_接收(通道) {
    如果 (通道[4] == 0) { 如果 (通道[5]) { 返回 ["关闭", 空]
}
 返回 ["阻塞", "缓冲区为空"]
 }
 定义 值 = 通道[0][通道[2]]
 通道[0][通道[2]] = 空
 通道[2] = (通道[2] + 1) % 通道[1]
 通道[4] = 通道[4] - 1
 通道[9] = 通道[9] + 1
 // 唤醒等待的发送者
 如果 (计数(通道[6]) > 0) { 定义 _发送者 = 通道[6][0]
 定义 可变 新等待 = []
 定义 可变 i = 1
 当 (i < 计数(通道[6])) { 追加(新等待, 通道[6][i]) i = i + 1 }
 通道[6] = 新等待
 }
 返回 ["成功", 值]
}

函数 通道_关闭(通道) {
    如果 (通道[5]) { 返回 假
}
 通道[5] = 真
 返回 真
}

函数 通道_已关闭(通道) { 返回 通道[5] }
函数 通道_大小(通道) { 返回 通道[4] }
函数 通道_容量(通道) { 返回 通道[1] }
函数 通道_为空(通道) { 返回 通道[4] == 0 }
函数 通道_已满(通道) { 返回 通道[4] >= 通道[1] }
函数 通道_总发送(通道) { 返回 通道[8] }
函数 通道_总接收(通道) { 返回 通道[9] }

// 无缓冲通道 (Synchronous Channel / Rendezvous)
// 发送方阻塞直到接收方取走, 反之亦然
// 型: [值槽, 有值标志, 已关闭, 发送方ID, 接收方ID]

函数 同步通道_创建() { 返回 [空, 假, 假, -1, -1]
}

函数 同步通道_发送(通道, 值, 发送方) {
    如果 (通道[2]) { 返回 ["错误", "通道已关闭"]
}
 如果 (通道[1]) { 返回 ["阻塞", "值未被取走"] }
 通道[0] = 值
 通道[1] = 真
 通道[3] = 发送方
 返回 ["成功", 空]
}

函数 同步通道_接收(通道, 接收方) {
    如果 (通道[1] == 假) { 如果 (通道[2]) { 返回 ["关闭", 空]
}
 返回 ["阻塞", "无值可取"]
 }
 定义 值 = 通道[0]
 通道[0] = 空
 通道[1] = 假
 通道[4] = 接收方
 返回 ["成功", 值]
}

函数 同步通道_关闭(通道) { 通道[2] = 真 }

// 广播通道 (广播 Channel)
// 一个发送者, 多个订阅者各自独立接收全部消息
// 型: [消息环, 容量, 写指针, 订阅者列表]
// 订阅者: [名称, 读指针, 已消费数]

函数 广播通道_创建(容量) { 定义 可变 实际容量 = 容量
    如果 (实际容量 <= 0) { 实际容量 = 256
}
 定义 可变 环 = []
 定义 可变 i = 0
 当 (i < 实际容量) { 追加(环, 空) i = i + 1 }
 返回 [环, 实际容量, 0, []]
}

函数 广播_订阅(通道, 名称) { 定义 订阅者 = [名称, 通道[2], 0]
 追加(通道[3], 订阅者)
 返回 计数(通道[3]) - 1
}

函数 广播_发送(通道, 值) {
 通道[0][通道[2]] = 值
 通道[2] = (通道[2] + 1) % 通道[1]
 返回 真
}

函数 广播_接收(通道, 订阅者ID) { 如果 (订阅者ID < 0 或 订阅者ID >= 计数(通道[3])) { 返回 ["错误", "无效订阅者"]
 }
 定义 订阅者 = 通道[3][订阅者ID]
 如果 (订阅者[1] == 通道[2]) { 返回 ["阻塞", "无新消息"]
 }
 定义 值 = 通道[0][订阅者[1]]
 订阅者[1] = (订阅者[1] + 1) % 通道[1]
 订阅者[2] = 订阅者[2] + 1
 返回 ["成功", 值]
}

函数 广播_订阅者数(通道) { 返回 计数(通道[3]) }
函数 广播_落后消息数(通道, 订阅者ID) { 定义 订阅者 = 通道[3][订阅者ID]
 定义 可变 差 = 通道[2] - 订阅者[1]
 如果 (差 < 0) { 差 = 差 + 通道[1] }
 返回 差
}

// 选择器 (Select / Multiplexer)
// 同时等待多个通道, 返回第一个就绪的
// 型: [通道列表, 名称列表, 优先级列表]

函数 选择器_创建() { 返回 [[], [], []]
}

函数 选择_追加(选择器, 通道, 名称, 优先级) {
 追加(选择器[0], 通道)
 追加(选择器[1], 名称)
 追加(选择器[2], 优先级)
}

函数 选择_轮询(选择器) { 定义 n = 计数(选择器[0])
 // 按优先级排序检查
 定义 可变 最高优先 = -1
 定义 可变 最高索引 = -1
 定义 可变 i = 0
 当 (i < n) { 定义 ch = 选择器[0][i]
 如果 (ch[4] > 0) { 如果 (最高优先 == -1 或 选择器[2][i] > 最高优先) {
 最高优先 = 选择器[2][i]
 最高索引 = i
 }
 }
 i = i + 1
 }
 如果 (最高索引 >= 0) { 定义 结果 = 通道_接收(选择器[0][最高索引])
 返回 [最高索引, 选择器[1][最高索引], 结果]
 }
 返回 [-1, "无就绪", ["阻塞", 空]]
}

// 公平轮询 (Round-Robin)
函数 选择_公平轮询(选择器, 上次索引) { 定义 n = 计数(选择器[0])
 定义 可变 i = 0
 当 (i < n) { 定义 索引 = (上次索引 + 1 + i) % n
 定义 ch = 选择器[0][索引]
 如果 (ch[4] > 0) { 定义 结果 = 通道_接收(ch)
 返回 [索引, 选择器[1][索引], 结果]
 }
 i = i + 1
 }
 返回 [-1, "无就绪", ["阻塞", 空]]
}

// 扇入 (Fan-In)
// 将多个通道合并为一个输出通道

函数 扇入_创建(输入通道列表, 输出缓冲) { 定义 输出 = 通道_创建(输出缓冲)
 返回 [输入通道列表, 输出]
}

函数 扇入_轮询(扇入) { 定义 输入列表 = 扇入[0]
 定义 输出 = 扇入[1]
 定义 可变 转发数 = 0
 定义 可变 i = 0
 当 (i < 计数(输入列表)) { 定义 结果 = 通道_接收(输入列表[i])
 如果 (结果[0] == "成功") {
 通道_发送(输出, 结果[1])
 转发数 = 转发数 + 1
 }
 i = i + 1
 }
 返回 转发数
}

// 扇出 (Fan-Out)
// 将一个通道的消息分发到多个输出通道

函数 扇出_创建(输入通道, 输出通道列表) { 返回 [输入通道, 输出通道列表, 0]
}

函数 扇出_轮询(扇出) { 定义 输入 = 扇出[0]
 定义 输出列表 = 扇出[1]
 定义 结果 = 通道_接收(输入)
 如果 (结果[0] != "成功") { 返回 0 }
 // 轮询分发
 定义 索引 = 扇出[2] % 计数(输出列表)
 通道_发送(输出列表[索引], 结果[1])
 扇出[2] = 扇出[2] + 1
 返回 1
}

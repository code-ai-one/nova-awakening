导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("./智能样式推.nova")

定义 CSS单位_无 = 0
定义 CSS单位_PX = 1
定义 CSS单位_EM = 2
定义 CSS单位_REM = 3
定义 CSS单位_百分比 = 4
定义 CSS单位_VW = 5
定义 CSS单位_VH = 6
定义 CSS单位_PT = 7
定义 CSS单位_CM = 8
定义 CSS单位_MM = 9
定义 CSS单位_IN = 10
定义 CSS单位_DEG = 11
定义 CSS单位_RAD = 12
定义 CSS单位_S = 13
定义 CSS单位_MS = 14

函数 CSS_是空白(c) {
    返回 c == 0x20 || c == 0x09 || c == 0x0A || c == 0x0D || c == 0x0C
}

函数 CSS_是标识符开头(c) {
    返回 (c >= 0x61 && c <= 0x7A) || (c >= 0x41 && c <= 0x5A) || c == 0x5F || c == 0x2D || c > 0x7F
}

函数 CSS_是标识符续(c) {
    返回 CSS_是标识符开头(c) || (c >= 0x30 && c <= 0x39)
}

函数 CSS_是数字(c) {
    返回 c >= 0x30 && c <= 0x39
}

函数 CSS_是十六进制(c) {
    返回 (c >= 0x30 && c <= 0x39) || (c >= 0x41 && c <= 0x46) || (c >= 0x61 && c <= 0x66)
}

函数 CSS_hex数字(c) {
    如果 (c >= 0x30 && c <= 0x39) { 返回 c - 0x30 }
    如果 (c >= 0x41 && c <= 0x46) { 返回 c - 0x41 + 10 }
    如果 (c >= 0x61 && c <= 0x66) { 返回 c - 0x61 + 10 }
    返回 0
}

函数 CSS_跳过空白(源, 位置) {
    定义 可变 p = 位置
    当 (p < 字符串长度(源) && CSS_是空白(字符串字节(源, p))) { p = p + 1 }
    返回 p
}

函数 CSS_解析数字(源, 位置) {
    定义 可变 p = 位置
    定义 可变 负数 = 假
    如果 (p < 字符串长度(源) && 字符串字节(源, p) == 0x2D) { 负数 = 真; p = p + 1 }
    如果 (p < 字符串长度(源) && 字符串字节(源, p) == 0x2B) { p = p + 1 }

    定义 可变 整数部分 = 0
    定义 可变 有整数 = 假
    当 (p < 字符串长度(源) && CSS_是数字(字符串字节(源, p))) {
        整数部分 = 整数部分 * 10 + (字符串字节(源, p) - 0x30)
        有整数 = 真
        p = p + 1
    }

    定义 可变 小数部分 = 0
    定义 可变 小数位数 = 0
    如果 (p < 字符串长度(源) && 字符串字节(源, p) == 0x2E) {
        p = p + 1
        当 (p < 字符串长度(源) && CSS_是数字(字符串字节(源, p))) {
            小数部分 = 小数部分 * 10 + (字符串字节(源, p) - 0x30)
            小数位数 = 小数位数 + 1
            p = p + 1
        }
    }

    如果 (!有整数 && 小数位数 == 0) { 返回 [0, 位置] }

    定义 可变 值 = 整数部分
    如果 (负数) { 值 = -值 }
    返回 [值, p]
}

函数 CSS_解析标识符(源, 位置) {
    定义 可变 p = 位置
    如果 (p >= 字符串长度(源) || !CSS_是标识符开头(字符串字节(源, p))) {
        返回 ["", 位置]
    }
    定义 可变 开始 = p
    当 (p < 字符串长度(源) && CSS_是标识符续(字符串字节(源, p))) { p = p + 1 }
    返回 [字符串_截取(源, 开始, p), p]
}

函数 CSS_解析单位(单位名) {
    定义 小写 = 字符串_转小写(单位名)
    如果 (小写 == "px") { 返回 CSS单位_PX }
    如果 (小写 == "em") { 返回 CSS单位_EM }
    如果 (小写 == "rem") { 返回 CSS单位_REM }
    如果 (小写 == "%") { 返回 CSS单位_百分比 }
    如果 (小写 == "vw") { 返回 CSS单位_VW }
    如果 (小写 == "vh") { 返回 CSS单位_VH }
    如果 (小写 == "pt") { 返回 CSS单位_PT }
    如果 (小写 == "cm") { 返回 CSS单位_CM }
    如果 (小写 == "mm") { 返回 CSS单位_MM }
    如果 (小写 == "in") { 返回 CSS单位_IN }
    如果 (小写 == "deg") { 返回 CSS单位_DEG }
    如果 (小写 == "rad") { 返回 CSS单位_RAD }
    如果 (小写 == "s") { 返回 CSS单位_S }
    如果 (小写 == "ms") { 返回 CSS单位_MS }
    返回 CSS单位_无
}

函数 CSS_解析颜色十六进制(源, 位置) {
    定义 可变 p = 位置
    如果 (p >= 字符串长度(源) || 字符串字节(源, p) != 0x23) { 返回 [0, 位置] }
    p = p + 1

    定义 可变 数字数 = 0
    定义 可变 hex值 = 0
    当 (p < 字符串长度(源) && CSS_是十六进制(字符串字节(源, p)) && 数字数 < 8) {
        hex值 = hex值 * 16 + CSS_hex数字(字符串字节(源, p))
        数字数 = 数字数 + 1
        p = p + 1
    }

    定义 可变 r = 0
    定义 可变 g = 0
    定义 可变 b = 0
    定义 可变 a = 255

    如果 (数字数 == 3) {
        r = (hex值 >> 8) & 0xF; r = r * 16 + r
        g = (hex值 >> 4) & 0xF; g = g * 16 + g
        b = hex值 & 0xF; b = b * 16 + b
    } 否则 如果 (数字数 == 4) {
        r = (hex值 >> 12) & 0xF; r = r * 16 + r
        g = (hex值 >> 8) & 0xF; g = g * 16 + g
        b = (hex值 >> 4) & 0xF; b = b * 16 + b
        a = hex值 & 0xF; a = a * 16 + a
    } 否则 如果 (数字数 == 6) {
        r = (hex值 >> 16) & 0xFF
        g = (hex值 >> 8) & 0xFF
        b = hex值 & 0xFF
    } 否则 如果 (数字数 == 8) {
        r = (hex值 >> 24) & 0xFF
        g = (hex值 >> 16) & 0xFF
        b = (hex值 >> 8) & 0xFF
        a = hex值 & 0xFF
    } 否则 {
        返回 [0, 位置]
    }

    返回 [(a << 24) | (r << 16) | (g << 8) | b, p]
}

函数 CSS_解析URL(源, 位置) {
    定义 可变 p = CSS_跳过空白(源, 位置)
    定义 检查 = 字符串_截取(源, p, p + 4)
    如果 (字符串_转小写(检查) != "url(") { 返回 ["", 位置] }
    p = p + 4
    p = CSS_跳过空白(源, p)

    定义 可变 引号 = 0
    如果 (p < 字符串长度(源)) {
        定义 c = 字符串字节(源, p)
        如果 (c == 0x22 || c == 0x27) { 引号 = c; p = p + 1 }
    }

    定义 可变 开始 = p
    如果 (引号 != 0) {
        当 (p < 字符串长度(源) && 字符串字节(源, p) != 引号) { p = p + 1 }
        定义 url = 字符串_截取(源, 开始, p)
        如果 (p < 字符串长度(源)) { p = p + 1 }
        p = CSS_跳过空白(源, p)
        如果 (p < 字符串长度(源) && 字符串字节(源, p) == 0x29) { p = p + 1 }
        返回 [url, p]
    } 否则 {
        当 (p < 字符串长度(源) && 字符串字节(源, p) != 0x29 && !CSS_是空白(字符串字节(源, p))) {
            p = p + 1
        }
        定义 url = 字符串_截取(源, 开始, p)
        p = CSS_跳过空白(源, p)
        如果 (p < 字符串长度(源) && 字符串字节(源, p) == 0x29) { p = p + 1 }
        返回 [url, p]
    }
}

函数 CSS_解析字符串(源, 位置) {
    定义 可变 p = 位置
    如果 (p >= 字符串长度(源)) { 返回 ["", 位置] }
    定义 引号 = 字符串字节(源, p)
    如果 (引号 != 0x22 && 引号 != 0x27) { 返回 ["", 位置] }
    p = p + 1

    定义 可变 结果 = ""
    当 (p < 字符串长度(源)) {
        定义 c = 字符串字节(源, p)
        如果 (c == 引号) { p = p + 1; 返回 [结果, p] }
        如果 (c == 0x5C && p + 1 < 字符串长度(源)) {
            p = p + 1
            定义 转义 = 字符串字节(源, p)
            如果 (CSS_是十六进制(转义)) {
                定义 可变 码 = 0
                定义 可变 计 = 0
                当 (计 < 6 && p < 字符串长度(源) && CSS_是十六进制(字符串字节(源, p))) {
                    码 = 码 * 16 + CSS_hex数字(字符串字节(源, p))
                    p = p + 1; 计 = 计 + 1
                }
                结果 = 结果 + 字符(码)
            } 否则 {
                结果 = 结果 + 字符(转义)
                p = p + 1
            }
        } 否则 {
            结果 = 结果 + 字符(c)
            p = p + 1
        }
    }
    返回 [结果, p]
}

函数 CSS_命名颜色(名称) {
    定义 小写 = 字符串_转小写(名称)
    如果 (小写 == "black") { 返回 0xFF000000 }
    如果 (小写 == "white") { 返回 0xFFFFFFFF }
    如果 (小写 == "red") { 返回 0xFFFF0000 }
    如果 (小写 == "green") { 返回 0xFF008000 }
    如果 (小写 == "blue") { 返回 0xFF0000FF }
    如果 (小写 == "yellow") { 返回 0xFFFFFF00 }
    如果 (小写 == "orange") { 返回 0xFFFFA500 }
    如果 (小写 == "purple") { 返回 0xFF800080 }
    如果 (小写 == "transparent") { 返回 0x00000000 }
    返回 -1
}

函数 智能_CSSPropertyParser_AI样式意图(属性ID, 值) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 0 }
    返回 0
}

函数 智能_CSSPropertyParser_AI影响分析(属性ID) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 2 }
    返回 AI样式_分析影响(属性ID)
}

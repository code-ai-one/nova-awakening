// §5 设备枚举

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 通串_枚举全部() {
    定义 可变 i = 0
    当 (i < 计数(通串控制器列表)) {
        通串_枚举控制器(通串控制器列表[i])
        i = i + 1
    }
}

函数 通串_枚举控制器(ctl) {
    // 检查每个端口是否有设备连接
    定义 可变 端口 = 0
    当 (端口 < ctl.端口数) {
        如果 (通串_端口有设备(ctl, 端口)) {
            定义 dev = 通串_枚举设备(ctl, 端口)
            如果 (dev != 空) {
                追加(通串设备列表, dev)
                追加(ctl.设备列表, dev)
                通串_匹配驱动(dev)
                通串_打印设备(dev)
            }
        }
        端口 = 端口 + 1
    }
}

函数 通串_枚举设备(ctl, 端口) {
    // 1. 复位端口
    通串_端口复位(ctl, 端口)

    // 2. 获取设备描述符(地址0, 端点0)
    定义 描述符 = 通串_获取设备描述符(ctl, 0)
    如果 (描述符 == 空) { 返回 空 }

    // 3. 分配地址
    定义 地址 = 通串_下一个地址
    通串_下一个地址 = 通串_下一个地址 + 1
    通串_设置地址(ctl, 0, 地址)

    // 4. 创建设备对象
    定义 dev = 通串设备 {}
    dev.地址 = 地址
    dev.端口 = 端口
    dev.厂商ID = 描述符[8] | (描述符[9] << 8)
    dev.产品ID = 描述符[10] | (描述符[11] << 8)
    dev.类代码 = 描述符[4]
    dev.子类代码 = 描述符[5]
    dev.协议 = 描述符[6]
    dev.已配置 = 假
    dev.端点列表 = []

    // 5. 获取字符串描述符(厂商名/产品名)
    dev.厂商名 = 通串_获取字符串(ctl, 地址, 描述符[14])
    dev.产品名 = 通串_获取字符串(ctl, 地址, 描述符[15])
    dev.序列号 = 通串_获取字符串(ctl, 地址, 描述符[16])

    // 6. 设置配置(激活设备)
    通串_设置配置(ctl, 地址, 1)
    dev.已配置 = 真

    返回 dev
}

// §6 类驱动匹配

函数 通串_匹配驱动(dev) {
    如果 (dev.类代码 == 通串_CLASS_HID) {
        dev.驱动 = "usb-hid"
        通串_HID_初始化(dev)
    } 否则 如果 (dev.类代码 == 通串_CLASS_MASS_STORAGE) {
        dev.驱动 = "usb-storage"
        通串_存储_初始化(dev)
    } 否则 如果 (dev.类代码 == 通串_CLASS_VIDEO) {
        dev.驱动 = "uvc"
        通串_摄像头_初始化(dev)
    } 否则 如果 (dev.类代码 == 通串_CLASS_AUDIO) {
        dev.驱动 = "usb-audio"
    } 否则 如果 (dev.类代码 == 通串_CLASS_HUB) {
        dev.驱动 = "usb-hub"
    } 否则 {
        dev.驱动 = "generic"
    }
}

// §7 通串 HID(键盘/鼠标)

函数 通串_HID_初始化(dev) {
    内核信息("通串-HID: " + dev.产品名 + " (键盘/鼠标)")
    // 设置HID协议: Boot Protocol(简单模式)
    // 定期轮询中断端点获取输入报告
}

函数 通串_HID_轮询(dev) {
    // 从中断端点读取HID报告
    定义 可变 报告 = [0, 0, 0, 0, 0, 0, 0, 0]
    定义 结果 = 通串_中断传输(dev, dev.中断IN端点, 报告, 8)
    如果 (结果 <= 0) { 返回 }

    如果 (dev.子类 == 通串_子类_键盘) {
        // 键盘报告: [修饰键, 保留, 键码1-6]
        定义 修饰 = 报告[0]
        定义 可变 i = 2
        当 (i < 8) {
            如果 (报告[i] != 0) {
                键盘_处理按键(报告[i], 修饰)
            }
            i = i + 1
        }
    } 否则如果 (dev.子类 == 通串_子类_鼠标) {
        // 鼠标报告: [按钮, X偏移, Y偏移, 滚轮]
        定义 按钮 = 报告[0]
        定义 dx = 报告[1]
        定义 dy = 报告[2]
        // 有符号转换(8位补码)
        如果 (dx > 127) { dx = dx - 256 }
        如果 (dy > 127) { dy = dy - 256 }
        鼠标_处理移动(dx, dy, 按钮)
    }
}

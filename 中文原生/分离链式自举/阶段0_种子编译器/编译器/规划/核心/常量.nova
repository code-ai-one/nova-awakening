// 0-1动态模拟精度系统
// 设备只识别离散0和1，但通过定点数精度可以模拟0到1之间的连续值
// 精度=10000表示: 0→0, 5000→0.5, 10000→1.0
// 这是原生语言直击机器码的扩展——让编译器能处理概率/权重/激活值等连续量
定义 动态精度 = 10000            // 0-1之间的模拟精度 (万分之一)
定义 动态零 = 0                  // 0.0
定义 动态半 = 5000               // 0.5
定义 动态一 = 10000              // 1.0
定义 动态极小 = 1                // 0.0001 (最小非零值)

// 0-1动态运算 (定点算术，直击底层整数ALU)
函数 动态_乘(a, b) { 返回 a * b / 动态精度 }           // a×b (0-1 × 0-1 → 0-1)
函数 动态_加(a, b) {                                  // a+b 饱和到1.0
    定义 和 = a + b
    如果 (和 > 动态一) { 返回 动态一 }
    返回 和
}
函数 动态_减(a, b) {                                  // a-b 饱和到0.0
    定义 差 = a - b
    如果 (差 < 动态零) { 返回 动态零 }
    返回 差
}
函数 动态_反(a) { 返回 动态一 - a }                     // 1-a (概率取反)
函数 动态_钳位(v, 最小, 最大) {                       // 钳位到[min,max]
    如果 (v < 最小) { 返回 最小 }
    如果 (v > 最大) { 返回 最大 }
    返回 v
}
函数 动态_线性插值(a, b, t) {                         // lerp(a, b, t)
    返回 a + 动态_乘(b - a, t)
}
函数 动态_从整数(分子, 分母) {                        // 分数→0-1定点
    如果 (分母 == 0) { 返回 0 }
    返回 分子 * 动态精度 / 分母
}
函数 动态_到整数(v, 范围) {                           // 0-1定点→[0,范围]整数
    如果 (动态精度 == 0) { 返回 0 }
    返回 v * 范围 / 动态精度
}

// Sigmoid近似 (用于神经网络激活，纯整数实现)
// σ(x) ≈ x/(1+|x|) 缩放到0-1
函数 动态_sigmoid(x) {
    定义 可变 归一 = x
    如果 (归一 < 0) { 归一 = 0 - 归一 }
    定义 分母 = 动态精度 + 归一
    如果 (分母 == 0) { 返回 动态半 }
    如果 (x >= 0) { 返回 动态半 + x * 动态半 / 分母 }
    返回 动态半 - (0 - x) * 动态半 / 分母
}

// ReLU (修正线性单元，底层机器码级别: max(0, x))
函数 动态_relu(x) {
    如果 (x < 0) { 返回 0 }
    返回 x
}

// Softmax归一化 (将一组值转为0-1概率分布，和=1.0)
函数 动态_softmax(值列表) {
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < 计数(值列表)) {
        总和 = 总和 + 值列表[i]
        i = i + 1
    }
    如果 (总和 == 0) { 返回 值列表 }
    定义 可变 结果 = []
    i = 0
    当 (i < 计数(值列表)) {
        追加(结果, 值列表[i] * 动态精度 / 总和)
        i = i + 1
    }
    返回 结果
}


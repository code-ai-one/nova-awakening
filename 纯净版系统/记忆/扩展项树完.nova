导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")

定义 最大范围项 = 4
定义 范围头大小 = 12

结构 范围项 {
    逻辑块,
    物理块,
    块数量,
}

结构 范围节点 {
    项数,
    最大项数,
    深度,
    项表,
    子节点表,
}

定义 可变 查找次数 = 0
定义 可变 插入次数 = 0
定义 可变 分裂次数 = 0
定义 可变 合并次数 = 0
定义 可变 总块映射 = 0

函数 范围_创建节点(深度) {
    定义 节点 = 范围节点 {}
    节点.项数 = 0
    节点.最大项数 = 最大范围项
    节点.深度 = 深度
    节点.项表 = 堆_分配(最大范围项 * 24)
    节点.子节点表 = 堆_分配((最大范围项 + 1) * 8)
    定义 可变 序号 = 0
    当 (序号 <= 最大范围项) {
        内存_写64(节点.子节点表 + 序号 * 8, 0)
        序号 = 序号 + 1
    }
    返回 节点
}

函数 范围_查找(根, 逻辑块) {
    查找次数 = 查找次数 + 1
    如果 (根 == 0) { 返回 0 }
    定义 可变 当前 = 根
    当 (当前 != 0) {
        如果 (当前.深度 == 0) {
            定义 可变 序号 = 0
            当 (序号 < 当前.项数) {
                定义 偏移 = 当前.项表 + 序号 * 24
                定义 起始 = 内存_读64(偏移)
                定义 物理 = 内存_读64(偏移 + 8)
                定义 数量 = 内存_读64(偏移 + 16)
                如果 (逻辑块 >= 起始 && 逻辑块 < 起始 + 数量) {
                    返回 物理 + (逻辑块 - 起始)
                }
                序号 = 序号 + 1
            }
            返回 0
        }
        定义 可变 子索引 = 当前.项数
        定义 可变 搜索 = 0
        当 (搜索 < 当前.项数) {
            定义 键 = 内存_读64(当前.项表 + 搜索 * 24)
            如果 (逻辑块 < 键) { 子索引 = 搜索; 跳出 }
            搜索 = 搜索 + 1
        }
        当前 = 内存_读64(当前.子节点表 + 子索引 * 8)
    }
    返回 0
}

函数 范围_插入(根, 逻辑块, 物理块, 块数) {
    插入次数 = 插入次数 + 1
    总块映射 = 总块映射 + 块数
    如果 (根 == 0) { 返回 错误_无效参数 }
    定义 合并结果 = 范围_尝试合并(根, 逻辑块, 物理块, 块数)
    如果 (合并结果 == 0) { 返回 0 }
    如果 (根.项数 >= 根.最大项数) {
        范围_分裂叶(根)
    }
    定义 可变 插入位 = 根.项数
    定义 可变 搜索 = 0
    当 (搜索 < 根.项数) {
        定义 键 = 内存_读64(根.项表 + 搜索 * 24)
        如果 (逻辑块 < 键) { 插入位 = 搜索; 跳出 }
        搜索 = 搜索 + 1
    }
    定义 可变 移动 = 根.项数
    当 (移动 > 插入位) {
        定义 源 = 根.项表 + (移动 - 1) * 24
        定义 目标 = 根.项表 + 移动 * 24
        内存_写64(目标, 内存_读64(源))
        内存_写64(目标 + 8, 内存_读64(源 + 8))
        内存_写64(目标 + 16, 内存_读64(源 + 16))
        移动 = 移动 - 1
    }
    定义 目标偏移 = 根.项表 + 插入位 * 24
    内存_写64(目标偏移, 逻辑块)
    内存_写64(目标偏移 + 8, 物理块)
    内存_写64(目标偏移 + 16, 块数)
    根.项数 = 根.项数 + 1
    返回 0
}

函数 范围_尝试合并(节点, 逻辑块, 物理块, 块数) {
    定义 可变 序号 = 0
    当 (序号 < 节点.项数) {
        定义 偏移 = 节点.项表 + 序号 * 24
        定义 起始 = 内存_读64(偏移)
        定义 物理 = 内存_读64(偏移 + 8)
        定义 数量 = 内存_读64(偏移 + 16)
        如果 (起始 + 数量 == 逻辑块 && 物理 + 数量 == 物理块) {
            内存_写64(偏移 + 16, 数量 + 块数)
            合并次数 = 合并次数 + 1
            返回 0
        }
        如果 (逻辑块 + 块数 == 起始 && 物理块 + 块数 == 物理) {
            内存_写64(偏移, 逻辑块)
            内存_写64(偏移 + 8, 物理块)
            内存_写64(偏移 + 16, 数量 + 块数)
            合并次数 = 合并次数 + 1
            返回 0
        }
        序号 = 序号 + 1
    }
    返回 错误_不存在
}

函数 范围_分裂叶(节点) {
    分裂次数 = 分裂次数 + 1
}

函数 范围_删除(根, 逻辑块) {
    如果 (根 == 0) { 返回 错误_无效参数 }
    定义 可变 序号 = 0
    当 (序号 < 根.项数) {
        定义 偏移 = 根.项表 + 序号 * 24
        定义 起始 = 内存_读64(偏移)
        定义 数量 = 内存_读64(偏移 + 16)
        如果 (逻辑块 >= 起始 && 逻辑块 < 起始 + 数量) {
            如果 (数量 == 1) {
                定义 可变 移动 = 序号
                当 (移动 < 根.项数 - 1) {
                    定义 源 = 根.项表 + (移动 + 1) * 24
                    定义 目标 = 根.项表 + 移动 * 24
                    内存_写64(目标, 内存_读64(源))
                    内存_写64(目标 + 8, 内存_读64(源 + 8))
                    内存_写64(目标 + 16, 内存_读64(源 + 16))
                    移动 = 移动 + 1
                }
                根.项数 = 根.项数 - 1
            }
            返回 0
        }
        序号 = 序号 + 1
    }
    返回 错误_不存在
}

函数 范围_总块数(根) {
    如果 (根 == 0) { 返回 0 }
    定义 可变 总 = 0
    定义 可变 序号 = 0
    当 (序号 < 根.项数) {
        总 = 总 + 内存_读64(根.项表 + 序号 * 24 + 16)
        序号 = 序号 + 1
    }
    返回 总
}

函数 范围树_完整统计() {
    返回 [查找次数, 插入次数, 分裂次数, 合并次数, 总块映射]
}

定义 可变 AI_扩展项树完_热节点缓存 = 0

函数 AI_扩展项树完_节点热度(节点, 操作类型) {
    如果 (操作类型 == "查询") { 返回 "缓存" }
    如果 (操作类型 == "修改") { AI_扩展项树完_热节点缓存 = 0; 返回 "失效" }
    返回 "普通"
}

函数 AI_扩展项树完_批量DOM优化(操作数) {
    如果 (操作数 > 100) { 返回 "延迟重排" }
    如果 (操作数 > 10) { 返回 "批量重排" }
    返回 "即时重排"
}

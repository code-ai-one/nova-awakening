函数 白璃主题_滚动条文本() {
    定义 轨 = ""
    轨 = 轨 + 白璃主题_对("width", "10px")
    轨 = 轨 + 白璃主题_对("height", "10px")
    定义 柄 = ""
    柄 = 柄 + 白璃主题_对("background", "linear-gradient(180deg, rgba(184,198,220,0.64), rgba(167,184,210,0.54))")
    柄 = 柄 + 白璃主题_对("border-radius", "999px")
    柄 = 柄 + 白璃主题_对("border", "2px solid rgba(255,255,255,0.82)")
    返回 白璃主题_段("::-webkit-scrollbar", 轨) + 白璃主题_段("::-webkit-scrollbar-thumb", 柄)
}

函数 白璃主题_动效文本() {
    定义 进入 = "@keyframes 白璃浮现{0%{opacity:0;transform:translateY(18px) scale(0.98)}100%{opacity:1;transform:translateY(0) scale(1)}}\n"
    定义 流光 = "@keyframes 白璃流光{0%{background-position:0% 50%}100%{background-position:100% 50%}}\n"
    定义 呼吸 = "@keyframes 白璃呼吸{0%{box-shadow:0 18px 42px rgba(174,187,207,0.18)}50%{box-shadow:0 24px 54px rgba(167,183,210,0.28)}100%{box-shadow:0 18px 42px rgba(174,187,207,0.18)}}\n"
    定义 应用 = ""
    应用 = 应用 + 白璃主题_段(".白璃浮现", 白璃主题_对("animation", "白璃浮现 var(--速中) cubic-bezier(0.22,1,0.36,1)"))
    应用 = 应用 + 白璃主题_段(".白璃呼吸", 白璃主题_对("animation", "白璃呼吸 3.8s ease-in-out infinite"))
    应用 = 应用 + 白璃主题_段(".白璃流光", 白璃主题_对("background-size", "200% 200%") + 白璃主题_对("animation", "白璃流光 9s linear infinite"))
    返回 进入 + 流光 + 呼吸 + 应用
}

函数 白璃主题_浏览器样式文本() {
    返回 白璃主题_标题栏文本()

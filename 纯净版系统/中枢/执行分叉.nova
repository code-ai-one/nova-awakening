// 外部接口: do_fork / do_clone / do_vfork

函数 do_fork(父进程, 名称) {
    返回 copy_process(父进程, 0, 名称, 0)
}

函数 do_clone(父进程, 名称, 标志) {
    返回 copy_process(父进程, 标志, 名称, 0)
}

函数 do_vfork(父进程, 名称) {
    定义 pid = copy_process(父进程, CLONE_VM | CLONE_VFORK, 名称, 0)
    如果 (是错误(pid)) { 返回 pid }
    // vfork语义: 父进程阻塞直到子进程exec/exit
        进程_设置状态(父进程, 进程_深睡)
    进程_设等待通道(父进程, "vfork")
    schedule()   // 让出CPU
    返回 pid
}

// exec: 替换进程映像

函数 do_exec(任务, 程序路径, 参数, 环境变量) {
    // 1. 查找可执行文件 
    定义 文件 = VFS_打开(程序路径, O_RDONLY)
    如果 (是错误(文件)) {
        返回 文件
    }

    // 2. 检查执行权限
    定义 当前凭证 = 获取当前进程()
    如果 (当前凭证 != 空) {
        定义 Nova文件节点 = 文件_Nova文件节点(文件)
        如果 (Nova文件节点 != 空) {
            定义 Nova文件节点_模式 = Nova文件节点_权限(Nova文件节点, 4)
            // 检查执行位: 所有者(bit6)/组(bit3)/其他(bit0)
            如果 ((Nova文件节点_模式 & 0o111) == 0) {
                VFS_关闭(文件)
                返回 错误_权限   // EACCES: 无执行权限
            }
        }
    }

    // 3. 清除旧地址空间 
    // flush_old_exec: 释放旧的mm, 创建新的mm
    定义 旧mm = 任务[T_地址空间]
    如果 (旧mm != 空) {
        旧mm.引用数 = 旧mm.引用数 - 1
        如果 (旧mm.引用数 == 0) {
            // 释放旧地址空间所有页表和VMA
            // mm_释放(旧mm)
        }
    }
    // 创建新的空地址空间
    定义 可变 新mm = 地址空间 {}
    新mm.引用数 = 1
    新mm.使用数 = 1
    新mm.锁 = 自旋锁_创建()
    新mm.VMA链 = 链表_创建()
    设置(任务, T_地址空间, 新mm)

    // 4. 重置信号处理器 
    // exec后所有非SIG_IGN处理器重置为SIG_DFL
    定义 sh = 任务[T_信号处理表]
    如果 (sh != 空) {
        自旋锁_获取(sh.锁)
        定义 可变 i = 0
        当 (i < 64) {
            如果 (sh.处理器[i] != SIG_IGN) {
                sh.处理器[i] = SIG_DFL
            }
            i = i + 1
        }
        自旋锁_释放(sh.锁)
    }
    设置(任务, T_信号掩码, 0)

    // 5. 关闭close-on-exec文件描述符 
    定义 ft = 任务[T_文件表]
    如果 (ft != 空) {
        自旋锁_获取(ft.锁)
        定义 可变 fd = 0
        当 (fd < ft.最大fd) {
            如果 ((ft.close_on_exec & (1 << fd)) != 0) {
                // 关闭该fd
                设置(ft.表, fd, 0)
            }
            fd = fd + 1
        }
        ft.close_on_exec = 0
        自旋锁_释放(ft.锁)
    }

    // 6. 加载可执行文件到新地址空间
    定义 elf结果 = 加载ELF二进制(程序路径, 任务)
    如果 (是错误(elf结果)) {
        内核错误("exec: ELF加载失败 " + 程序路径)
        返回 elf结果
    }

    // 7. 清除PF_FORKNOEXEC标志
    进程_清标志(任务, PF_FORKNOEXEC)

    // 8. 如果父进程在vfork等待, 唤醒它 
    定义 父 = 任务[T_父进程]
    如果 (父 != 空 && 父[T_等待通道] == "vfork") {
        进程_设置状态(父, 进程_就绪)
        进程_设等待通道(父, 空)
    }

    内核调试(字符串拼接("exec: ", 程序路径))
    返回 成功
}

// 创建内核线程 

函数 kernel_thread(名称, 优先级) {
    定义 新PID = 分配PID()
    如果 (新PID < 0) { 返回 错误_无内存 }

    定义 线程 = 内核线程_创建(新PID, 名称, 优先级)
    如果 (线程 == 空) {
        释放PID(新PID)
        返回 错误_无内存
    }

    进程_设标志(线程, PF_KTHREAD)
    设置(线程, T_地址空间, 空)  // 内核线程无用户地址空间
    进程表_注册(线程)
    进程_设置状态(线程, 进程_就绪)

    总fork次数 = 总fork次数 + 1
    内核调试(字符串拼接("kthread: PID ", 整数转字符串(新PID)))
    返回 新PID

// 统计

定义 可变 AI_执行分叉_调用数 = 0
定义 可变 AI_执行分叉_异常数 = 0

函数 AI_执行分叉_监控() {
    AI_执行分叉_调用数 = AI_执行分叉_调用数 + 1
    返回 AI_执行分叉_异常数 == 0
}

函数 AI_执行分叉_健康检查() {
    如果 (AI_执行分叉_调用数 > 0 && AI_执行分叉_异常数 * 100 / AI_执行分叉_调用数 > 10) {
        返回 假
    }
    返回 真
}

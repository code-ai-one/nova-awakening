// Walsh-Hadamard 原生引擎
// 保留既有 walsh_* 接口, 以稳定可编译实现替换旧乱码源码


导入("../基础.nova")

函数 沃尔什_绝对值(x) {
    如果 (x < 0) {
        返回 0 - x
    }
    返回 x
}

函数 沃尔什_复制(src) {
    定义 可变 目标值 = []
    定义 可变 i = 0
    当 (i < 计数(src)) {
        追加(目标值, src[i])
        i = i + 1
    }
    返回 目标值
}

函数 沃尔什_最小长(a, b) {
    如果 (a < b) {
        返回 a
    }
    返回 b
}

函数 沃尔什_整数根(n) {
    如果 (n <= 0) {
        返回 0
    }
    定义 可变 x = n
    定义 可变 y = (x + 1) / 2
    当 (y < x) {
        x = y
        y = (x + n / x) / 2
    }
    返回 x
}

函数 沃尔什_快速变换(x) {
    定义 n = 计数(x)
    如果 (n <= 1) {
        返回
    }
    定义 可变 步长 = 1
    当 (步长 < n) {
        定义 块宽 = 步长 * 2
        定义 可变 i = 0
        当 (i < n) {
            定义 可变 j = 0
            当 (j < 步长) {
                定义 左 = i + j
                定义 右 = 左 + 步长
                如果 (右 < n) {
                    定义 a = x[左]
                    定义 b = x[右]
                    x[左] = a + b
                    x[右] = a - b
                }
                j = j + 1
            }
            i = i + 块宽
        }
        步长 = 块宽
    }
}

函数 沃尔什_逆变换(x) {
    沃尔什_快速变换(x)
    定义 n = 计数(x)
    如果 (n == 0) {
        返回
    }
    定义 可变 i = 0
    当 (i < n) {
        x[i] = x[i] / n
        i = i + 1
    }
}

函数 沃尔什_能量(规格) {
    定义 可变 e = 0
    定义 可变 i = 0
    当 (i < 计数(规格)) {
        e = e + 规格[i] * 规格[i] / 1000
        i = i + 1
    }
    返回 e
}

函数 沃尔什_直流分量(规格) {
    如果 (计数(规格) == 0) {
        返回 0
    }
    返回 规格[0]
}

函数 沃尔什_像素均值(规格) {
    如果 (计数(规格) == 0) {
        返回 0
    }
    返回 沃尔什_直流分量(规格) / 计数(规格)
}

函数 沃尔什_前K(规格, k) {
    定义 n = 计数(规格)
    定义 可变 索引列表 = []
    定义 可变 used = []
    定义 可变 i = 0
    当 (i < n) {
        追加(used, 0)
        i = i + 1
    }
    如果 (n > 0) {
        used[0] = 1
    }

    定义 可变 已找到 = 0
    当 (已找到 < k) {
        如果 (已找到 >= n - 1) {
            返回 索引列表
        }
        定义 可变 最优索引 = 1
        定义 可变 best_val = -1
        i = 1
        当 (i < n) {
            如果 (used[i] == 0) {
                定义 v = 沃尔什_绝对值(规格[i])
                如果 (v > best_val) {
                    best_val = v
                    最优索引 = i
                }
            }
            i = i + 1
        }
        追加(索引列表, 最优索引)
        如果 (最优索引 < 计数(used)) {
            used[最优索引] = 1
        }
        已找到 = 已找到 + 1
    }
    返回 索引列表
}

函数 沃尔什_低通(规格, cutoff) {
    定义 可变 r = 沃尔什_复制(规格)
    定义 可变 i = cutoff
    当 (i < 计数(r)) {
        r[i] = 0
        i = i + 1
    }
    返回 r
}

函数 沃尔什_高通(规格, cutoff) {
    定义 可变 r = 沃尔什_复制(规格)
    定义 可变 i = 1
    当 (i < cutoff) {
        如果 (i < 计数(r)) {
            r[i] = 0
        }
        i = i + 1
    }
    返回 r
}

函数 沃尔什_交叉(specA, specB, cutoff) {
    定义 n = 沃尔什_最小长(计数(specA), 计数(specB))
    定义 可变 r = []
    定义 可变 i = 0
    当 (i < n) {
        如果 (i < cutoff) {
            追加(r, specA[i])
        } 否则 {
            追加(r, specB[i])
        }
        i = i + 1
    }
    返回 r
}

函数 沃尔什_插值(specA, specB, 学习率) {
    定义 n = 沃尔什_最小长(计数(specA), 计数(specB))
    定义 可变 r = []
    定义 可变 i = 0
    当 (i < n) {
        定义 v = specA[i] * 学习率 / 1000 + specB[i] * (1000 - 学习率) / 1000
        追加(r, v)
        i = i + 1
    }
    返回 r
}

函数 沃尔什_缩放(规格, factor) {
    定义 可变 r = 沃尔什_复制(规格)
    定义 可变 i = 0
    当 (i < 计数(r)) {
        r[i] = r[i] * factor / 1000
        i = i + 1
    }
    返回 r
}

函数 沃尔什_从像素(像素列表) {
    定义 可变 规格 = 沃尔什_复制(像素列表)
    定义 可变 i = 0
    当 (i < 计数(规格)) {
        规格[i] = 规格[i] - 128
        i = i + 1
    }
    沃尔什_快速变换(规格)
    返回 规格
}

函数 沃尔什_转像素(规格) {
    定义 可变 px = 沃尔什_复制(规格)
    沃尔什_逆变换(px)
    定义 可变 i = 0
    当 (i < 计数(px)) {
        px[i] = px[i] + 128
        如果 (px[i] < 0) {
            px[i] = 0
        }
        如果 (px[i] > 255) {
            px[i] = 255
        }
        i = i + 1
    }
    返回 px
}

函数 沃尔什_GPU快速变换(x) {
    沃尔什_快速变换(x)
}

函数 沃尔什_支撑(规格) {
    定义 n = 计数(规格)
    如果 (n == 0) {
        返回 0
    }
    定义 可变 非零 = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (规格[i] != 0) {
            非零 = 非零 + 1
        }
        i = i + 1
    }
    返回 非零 * 1000 / n
}

函数 沃尔什_稀疏度(规格) {
    返回 1000 - 沃尔什_支撑(规格)
}

函数 沃尔什_是否全支撑(规格) {
    定义 可变 i = 0
    当 (i < 计数(规格)) {
        如果 (规格[i] == 0) {
            返回 0
        }
        i = i + 1
    }
    返回 1
}

函数 沃尔什_频带能量(规格) {
    定义 n = 计数(规格)
    如果 (n == 0) {
        返回 [0,]
    }
    定义 三分 = n / 3
    定义 可变 低 = 0
    定义 可变 中 = 0
    定义 可变 高 = 0
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 e = 规格[i] * 规格[i] / 1000
        如果 (i < 三分) {
            低 = 低 + e
        } 否则 {
            如果 (i < 三分 * 2) {
                中 = 中 + e
            } 否则 {
                高 = 高 + e
            }
        }
        总 = 总 + e
        i = i + 1
    }
    如果 (总 == 0) {
        返回 [0,]
    }
    返回 [低 * 1000 / 总, 中 * 1000 / 总, 高 * 1000 / 总]
}

函数 沃尔什_熵(规格) {
    定义 n = 计数(规格)
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < n) {
        总 = 总 + 沃尔什_绝对值(规格[i])
        i = i + 1
    }
    如果 (总 == 0) {
        返回 0
    }
    定义 可变 熵 = 0
    i = 0
    当 (i < n) {
        定义 p = 沃尔什_绝对值(规格[i]) * 1000 / 总
        如果 (p > 0) {
            熵 = 熵 + p * (1000 - p) / 1000
        }
        i = i + 1
    }
    返回 熵
}

函数 沃尔什_阈值处理(规格, 阈值) {
    定义 可变 r = 沃尔什_复制(规格)
    定义 可变 i = 1
    当 (i < 计数(r)) {
        如果 (沃尔什_绝对值(r[i]) < 阈值) {
            r[i] = 0
        }
        i = i + 1
    }
    返回 r
}

函数 沃尔什_带通(规格, low, high) {
    定义 可变 r = 沃尔什_复制(规格)
    定义 可变 i = 0
    当 (i < 计数(r)) {
        如果 (i < low) {
            r[i] = 0
        } 否则 {
            如果 (i >= high) {
                r[i] = 0
            }
        }
        i = i + 1
    }
    返回 r
}

函数 沃尔什_相似度(a, b) {
    定义 n = 沃尔什_最小长(计数(a), 计数(b))
    定义 可变 点积 = 0
    定义 可变 范a = 0
    定义 可变 范b = 0
    定义 可变 i = 0
    当 (i < n) {
        点积 = 点积 + a[i] * b[i] / 1000
        范a = 范a + a[i] * a[i] / 1000
        范b = 范b + b[i] * b[i] / 1000
        i = i + 1
    }
    定义 分母 = 沃尔什_整数根(范a) * 沃尔什_整数根(范b)
    如果 (分母 == 0) {
        返回 0
    }
    返回 点积 * 1000 / 分母
}

函数 沃尔什_距离(a, b) {
    定义 n = 沃尔什_最小长(计数(a), 计数(b))
    定义 可变 d = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 差值 = a[i] - b[i]
        d = d + 差值 * 差值 / 1000
        i = i + 1
    }
    返回 沃尔什_整数根(d)
}

函数 沃尔什_二维变换(data, n) {
    定义 可变 缓冲 = 沃尔什_复制(data)
    定义 可变 行号 = 0
    当 (行号 < n) {
        定义 可变 行 = []
        定义 可变 c = 0
        当 (c < n) {
            追加(行, 缓冲[行号 * n + c])
            c = c + 1
        }
        沃尔什_快速变换(行)
        c = 0
        当 (c < n) {
            缓冲[行号 * n + c] = 行[c]
            c = c + 1
        }
        行号 = 行号 + 1
    }
    定义 可变 列号 = 0
    当 (列号 < n) {
        定义 可变 列 = []
        定义 可变 r = 0
        当 (r < n) {
            追加(列, 缓冲[r * n + 列号])
            r = r + 1
        }
        沃尔什_快速变换(列)
        r = 0
        当 (r < n) {
            缓冲[r * n + 列号] = 列[r]
            r = r + 1
        }
        列号 = 列号 + 1
    }
    返回 缓冲
}

函数 沃尔什_二维逆变换(data, n) {
    定义 可变 缓冲 = 沃尔什_复制(data)
    定义 可变 列号 = 0
    当 (列号 < n) {
        定义 可变 列 = []
        定义 可变 r = 0
        当 (r < n) {
            追加(列, 缓冲[r * n + 列号])
            r = r + 1
        }
        沃尔什_逆变换(列)
        r = 0
        当 (r < n) {
            缓冲[r * n + 列号] = 列[r]
            r = r + 1
        }
        列号 = 列号 + 1
    }
    定义 可变 行号 = 0
    当 (行号 < n) {
        定义 可变 行 = []
        定义 可变 c = 0
        当 (c < n) {
            追加(行, 缓冲[行号 * n + c])
            c = c + 1
        }
        沃尔什_逆变换(行)
        c = 0
        当 (c < n) {
            缓冲[行号 * n + c] = 行[c]
            c = c + 1
        }
        行号 = 行号 + 1
    }
    返回 缓冲
}

函数 沃尔什_卷积计算(a, b) {
    定义 n = 沃尔什_最小长(计数(a), 计数(b))
    定义 可变 sa = []
    定义 可变 sb = []
    定义 可变 i = 0
    当 (i < n) {
        追加(sa, a[i])
        追加(sb, b[i])
        i = i + 1
    }
    沃尔什_快速变换(sa)
    沃尔什_快速变换(sb)
    i = 0
    当 (i < n) {
        sa[i] = sa[i] * sb[i] / n
        i = i + 1
    }
    沃尔什_逆变换(sa)
    返回 sa
}

函数 沃尔什_压缩(data, k) {
    定义 n = 计数(data)
    定义 可变 规格 = 沃尔什_复制(data)
    沃尔什_快速变换(规格)

    定义 可变 阈值列表 = []
    定义 可变 i = 0
    当 (i < n) {
        追加(阈值列表, 沃尔什_绝对值(规格[i]))
        i = i + 1
    }

    定义 可变 si = 0
    当 (si < n) {
        定义 可变 sj = si + 1
        当 (sj < n) {
            如果 (阈值列表[sj] > 阈值列表[si]) {
                定义 t = 阈值列表[si]
                阈值列表[si] = 阈值列表[sj]
                阈值列表[sj] = t
            }
            sj = sj + 1
        }
        si = si + 1
    }

    定义 可变 cutoff = 0
    如果 (k < n) {
        cutoff = 阈值列表[k]
    }

    i = 0
    当 (i < n) {
        如果 (沃尔什_绝对值(规格[i]) < cutoff) {
            规格[i] = 0
        }
        i = i + 1
    }
    沃尔什_逆变换(规格)
    返回 规格
}

函数 沃尔什_压缩比(原始, k) {
    定义 n = 计数(原始)
    如果 (n == 0) {
        返回 0
    }
    返回 k * 1000 / n
}

函数 沃尔什_峰值信噪比(原始, 重建) {
    定义 n = 沃尔什_最小长(计数(原始), 计数(重建))
    如果 (n == 0) {
        返回 0
    }
    定义 可变 mse = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 d = 原始[i] - 重建[i]
        mse = mse + d * d
        i = i + 1
    }
    mse = mse / n
    如果 (mse == 0) {
        返回 99000
    }
    定义 可变 比率 = 255 * 255 * 1000 / mse
    定义 可变 对数值 = 0
    当 (比率 > 10) {
        比率 = 比率 / 10
        对数值 = 对数值 + 1000
    }
    返回 10 * 对数值
}

函数 沃尔什_功率谱(规格) {
    定义 可变 功率 = []
    定义 可变 i = 0
    当 (i < 计数(规格)) {
        追加(功率, 规格[i] * 规格[i] / 1000)
        i = i + 1
    }
    返回 功率
}

函数 沃尔什_降噪(data, 阈值) {
    定义 n = 计数(data)
    定义 可变 规格 = 沃尔什_复制(data)
    沃尔什_快速变换(规格)
    定义 可变 i = 1
    当 (i < n) {
        定义 a = 沃尔什_绝对值(规格[i])
        如果 (a <= 阈值) {
            规格[i] = 0
        } 否则 {
            如果 (规格[i] > 0) {
                规格[i] = a - 阈值
            } 否则 {
                规格[i] = 0 - (a - 阈值)
            }
        }
        i = i + 1
    }
    沃尔什_逆变换(规格)
    返回 规格
}

函数 沃尔什_测试() {
    定义 可变 data = [10, 20, 30, 40, 50, 60, 70, 80]
    定义 可变 original = 沃尔什_复制(data)
    沃尔什_快速变换(data)
    沃尔什_逆变换(data)

    定义 可变 ok = 1
    定义 可变 i = 0
    当 (i < 计数(data)) {
        如果 (data[i] != original[i]) {
            ok = 0
        }
        i = i + 1
    }

    定义 tops = 沃尔什_前K([1000, 5, 100, 3, 200, 1, 50, 2], 3)
    返回 [ok, tops]
}


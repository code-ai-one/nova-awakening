导入("./类型定义.nova")
导入("./错误码.nova")
导入("./整数转字符串.nova")
导入("./内核打印.nova")

// NovaOS · 能力声明合同框架
// §1 能力ID定义 (应用可申请的系统能力)
// §2 能力等级 (必须/可选/禁止)
// §3 能力检查器 (运行时权限门控)
// §4 能力审计 (记录能力使用情况)


定义 能力_文件读 = 0x0001
定义 能力_文件写 = 0x0002
定义 能力_网络出站 = 0x0004
定义 能力_网络入站 = 0x0008
定义 能力_进程创建 = 0x0010
定义 能力_进程信号 = 0x0020
定义 能力_设备访问 = 0x0040
定义 能力_GPU = 0x0080
定义 能力_音频 = 0x0100
定义 能力_摄像头 = 0x0200
定义 能力_蓝牙 = 0x0400
定义 能力_USB = 0x0800
定义 能力_系统配置 = 0x1000
定义 能力_内核模块 = 0x2000
定义 能力_加密存储 = 0x4000
定义 能力_AI推理 = 0x8000

定义 能力等级_必须 = 2
定义 能力等级_可选 = 1
定义 能力等级_禁止 = 0


结构 能力声明 {
    能力ID,         // u32 能力_* 常量
    等级,           // u32 能力等级_*
    理由,           // 字符串 申请理由
    使用次数,       // u64 运行时计数
    最后使用时间,
}

定义 可变 _已授权能力 = []
定义 可变 _能力审计日志 = []
定义 可变 _能力检查总数 = 0
定义 可变 _能力拒绝总数 = 0


函数 能力_注册(能力ID, 等级, 理由) {
    定义 声明 = 能力声明 {}
    声明.能力ID = 能力ID
    声明.等级 = 等级
    声明.理由 = 理由
    声明.使用次数 = 0
    声明.最后使用时间 = 0
    追加(_已授权能力, 声明)
}

函数 能力_已授权(能力ID) {
    _能力检查总数 = _能力检查总数 + 1
    定义 可变 i = 0
    当 (i < 计数(_已授权能力)) {
        如果 (_已授权能力[i].能力ID == 能力ID && _已授权能力[i].等级 > 能力等级_禁止) {
            _已授权能力[i].使用次数 = _已授权能力[i].使用次数 + 1
            _已授权能力[i].最后使用时间 = 读取毫秒() / 1000
            返回 真
        }
        i = i + 1
    }
    _能力拒绝总数 = _能力拒绝总数 + 1
    追加(_能力审计日志, [能力ID, "拒绝", 读取毫秒() / 1000])
    返回 假
}

函数 能力_检查并执行(能力ID, 操作名) {
    如果 (能力_已授权(能力ID)) {
        追加(_能力审计日志, [能力ID, 操作名, 读取毫秒() / 1000])
        返回 真
    }
    内核警告("能力拒绝: " + 操作名 + " 需要能力 " + 整数转字符串(能力ID))
    返回 假
}

函数 能力_撤销(能力ID) {
    定义 可变 i = 0
    当 (i < 计数(_已授权能力)) {
        如果 (_已授权能力[i].能力ID == 能力ID) {
            _已授权能力[i].等级 = 能力等级_禁止
            追加(_能力审计日志, [能力ID, "撤销", 读取毫秒() / 1000])
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 能力_重置() {
    _已授权能力 = []
    _能力审计日志 = []
    _能力检查总数 = 0
    _能力拒绝总数 = 0
}


函数 能力_从Bundle加载(能力ID列表) {
    能力_重置()
    定义 可变 i = 0
    当 (i < 计数(能力ID列表)) {
        能力_注册(能力ID列表[i], 能力等级_必须, "Bundle声明")
        i = i + 1
    }
}

函数 能力_必须能力满足(所需列表) {
    定义 可变 i = 0
    当 (i < 计数(所需列表)) {
        如果 (!能力_已授权(所需列表[i])) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 能力_已授权数() {
    定义 可变 n = 0
    定义 可变 i = 0
    当 (i < 计数(_已授权能力)) {
        如果 (_已授权能力[i].等级 > 能力等级_禁止) { n = n + 1 }
        i = i + 1
    }
    返回 n
}


函数 能力_名称(能力ID) {
    如果 (能力ID == 能力_文件读) { 返回 "文件读取" }
    如果 (能力ID == 能力_文件写) { 返回 "文件写入" }
    如果 (能力ID == 能力_网络出站) { 返回 "网络出站" }
    如果 (能力ID == 能力_网络入站) { 返回 "网络入站" }
    如果 (能力ID == 能力_进程创建) { 返回 "进程创建" }
    如果 (能力ID == 能力_进程信号) { 返回 "进程信号" }
    如果 (能力ID == 能力_设备访问) { 返回 "设备访问" }
    如果 (能力ID == 能力_GPU) { 返回 "GPU计算" }
    如果 (能力ID == 能力_音频) { 返回 "音频" }
    如果 (能力ID == 能力_摄像头) { 返回 "摄像头" }
    如果 (能力ID == 能力_蓝牙) { 返回 "蓝牙" }
    如果 (能力ID == 能力_USB) { 返回 "USB" }
    如果 (能力ID == 能力_系统配置) { 返回 "系统配置" }
    如果 (能力ID == 能力_内核模块) { 返回 "内核模块" }
    如果 (能力ID == 能力_加密存储) { 返回 "加密存储" }
    如果 (能力ID == 能力_AI推理) { 返回 "AI推理" }
    返回 "未知能力"
}

函数 能力_等级名(等级) {
    如果 (等级 == 能力等级_必须) { 返回 "必须" }
    如果 (等级 == 能力等级_可选) { 返回 "可选" }
    如果 (等级 == 能力等级_禁止) { 返回 "禁止" }
    返回 "未知"
}

函数 能力_审计报告() {
    定义 可变 r = "═══ 能力审计报告 ═══\n"
    r = r + "已授权能力: " + 整数转字符串(能力_已授权数()) + "\n"
    r = r + "检查总数: " + 整数转字符串(_能力检查总数) + "\n"
    r = r + "拒绝总数: " + 整数转字符串(_能力拒绝总数) + "\n"
    r = r + "审计日志: " + 整数转字符串(计数(_能力审计日志)) + " 条\n"
    // 列出已授权能力
    定义 可变 i = 0
    当 (i < 计数(_已授权能力)) {
        定义 cap = _已授权能力[i]
        如果 (cap.等级 > 能力等级_禁止) {
            r = r + "  " + 能力_名称(cap.能力ID) + " [" + 能力_等级名(cap.等级) + "] 使用" + 整数转字符串(cap.使用次数) + "次\n"
        }
        i = i + 1
    }
    返回 r
}

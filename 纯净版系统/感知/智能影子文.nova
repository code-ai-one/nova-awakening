导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/创建甲.nova")

定义 语义_无 = 0
定义 语义_导航 = 1
定义 语义_主内容 = 2
定义 语义_侧边 = 3
定义 语义_表单 = 4
定义 语义_交互 = 5
定义 语义_媒体 = 6
定义 语义_广告 = 7
定义 最大分析 = 256
定义 衰减基数 = 1024

结构 节点语义 {
    节点标识,
    语义类型,
    重要度,
    注意力权重,
    可见性,
    交互频率,
    最近分析,
}

定义 可变 语义表 = []
定义 可变 语义数 = 0
定义 可变 分析次数 = 0
定义 可变 事件优化 = 0

函数 语义_初始化() {
    语义表 = []
    语义数 = 0
}

函数 语义_分析节点(节点标识, 标签哈希, 属性掩码) {
    分析次数 = 分析次数 + 1
    定义 类型 = 语义_推断类型(标签哈希, 属性掩码)
    定义 重要度 = 语义_计算重要度(类型, 属性掩码)
    定义 索引 = 语义_查找(节点标识)
    如果 (索引 >= 0) {
        语义表[索引].语义类型 = 类型
        语义表[索引].重要度 = 重要度
        语义表[索引].最近分析 = 平台_获取高精度时间()
        返回 索引
    }
    如果 (语义数 >= 最大分析) { 返回 -1 }
    定义 语义 = 节点语义 {}
    语义.节点标识 = 节点标识
    语义.语义类型 = 类型
    语义.重要度 = 重要度
    语义.注意力权重 = 衰减基数 / 2
    语义.可见性 = 真
    语义.交互频率 = 0
    语义.最近分析 = 平台_获取高精度时间()
    追加(语义表, 语义)
    定义 新索引 = 语义数
    语义数 = 语义数 + 1
    返回 新索引
}

函数 语义_推断类型(标签哈希, 属性掩码) {
    如果 ((属性掩码 & 1) != 0) { 返回 语义_导航 }
    如果 ((属性掩码 & 2) != 0) { 返回 语义_主内容 }
    如果 ((属性掩码 & 4) != 0) { 返回 语义_表单 }
    如果 ((属性掩码 & 8) != 0) { 返回 语义_交互 }
    如果 ((属性掩码 & 16) != 0) { 返回 语义_媒体 }
    如果 ((属性掩码 & 32) != 0) { 返回 语义_广告 }
    返回 语义_无
}

函数 语义_计算重要度(类型, 属性掩码) {
    如果 (类型 == 语义_主内容) { 返回 900 }
    如果 (类型 == 语义_交互) { 返回 800 }
    如果 (类型 == 语义_表单) { 返回 750 }
    如果 (类型 == 语义_导航) { 返回 600 }
    如果 (类型 == 语义_媒体) { 返回 500 }
    如果 (类型 == 语义_侧边) { 返回 300 }
    如果 (类型 == 语义_广告) { 返回 100 }
    返回 400
}

函数 语义_查找(节点标识) {
    定义 可变 序号 = 0
    当 (序号 < 语义数) {
        如果 (语义表[序号].节点标识 == 节点标识) { 返回 序号 }
        序号 = 序号 + 1
    }
    返回 -1
}

函数 语义_事件优先级(事件类型, 节点标识) {
    定义 索引 = 语义_查找(节点标识)
    如果 (索引 < 0) { 返回 128 }
    定义 语义 = 语义表[索引]
    定义 可变 优先级 = 128
    如果 (语义.注意力权重 > 衰减基数 * 3 / 4) { 优先级 = 255 }
    否则 如果 (语义.重要度 > 700) { 优先级 = 200 }
    否则 如果 (语义.交互频率 > 10) { 优先级 = 180 }
    如果 (优先级 > 128) { 事件优化 = 事件优化 + 1 }
    返回 优先级
}

函数 语义_更新注意力(节点标识, 注意力) {
    定义 索引 = 语义_查找(节点标识)
    如果 (索引 < 0) { 返回 }
    语义表[索引].注意力权重 = (语义表[索引].注意力权重 * 900 + 注意力 * 124) / 衰减基数
}

函数 语义_记录交互(节点标识) {
    定义 索引 = 语义_查找(节点标识)
    如果 (索引 < 0) { 返回 }
    语义表[索引].交互频率 = 语义表[索引].交互频率 + 1
}

函数 语义_设可见性(节点标识, 可见) {
    定义 索引 = 语义_查找(节点标识)
    如果 (索引 < 0) { 返回 }
    语义表[索引].可见性 = 可见
}

函数 语义_获取重要度(节点标识) {
    定义 索引 = 语义_查找(节点标识)
    如果 (索引 < 0) { 返回 400 }
    返回 语义表[索引].重要度
}

函数 语义_获取类型名(类型) {
    如果 (类型 == 语义_导航) { 返回 "导航" }
    如果 (类型 == 语义_主内容) { 返回 "主内容" }
    如果 (类型 == 语义_侧边) { 返回 "侧边" }
    如果 (类型 == 语义_表单) { 返回 "表单" }
    如果 (类型 == 语义_交互) { 返回 "交互" }
    如果 (类型 == 语义_媒体) { 返回 "媒体" }
    如果 (类型 == 语义_广告) { 返回 "广告" }
    返回 "未知"
}

函数 语义_完整统计() {
    返回 [语义数, 分析次数, 事件优化]
}

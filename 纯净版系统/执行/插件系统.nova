导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../外联/地址解析辅.nova")
导入("./脚本执行入.nova")

// NovaOS 浏览器内核 · 第五层 · 插件系统
// 职责: Web Extension兼容、Nova原生插件、系统级扩展
// 支持: Nova浏览器 Extension 接口子集 + Nova原生扩展

定义 插件类型_Web扩展     = 0    // Nova浏览器 Extension兼容
定义 插件类型_Nova原生     = 1    // Nova原生扩展(直连内核)
定义 插件类型_内容脚本     = 2    // Content Script
定义 插件类型_主题         = 3    // 主题插件

定义 插件状态_未安装   = 0
定义 插件状态_已安装   = 1
定义 插件状态_已启用   = 2
定义 插件状态_已禁用   = 3
定义 插件状态_错误     = 4

定义 插件权限_标签     = 1
定义 插件权限_书签     = 2
定义 插件权限_历史     = 4
定义 插件权限_存储     = 8
定义 插件权限_网络     = 16
定义 插件权限_通知     = 32
定义 插件权限_DOM      = 64
定义 插件权限_系统     = 128   // NovaOS特有: 系统级权限

结构 浏览器插件 {
    ID,
    名称,
    版本,
    描述,
    类型,
    状态,
    权限,    // u32 权限位掩码
    manifest,    // 字符串 manifest.json内容
    背景脚本,
    内容脚本,    // [] [匹配模式, 脚本代码]
    弹出页面,
    图标,
    沙箱级别,
}

定义 可变 插件_列表 = []
定义 可变 插件_已初始化 = 假

// §1 初始化

函数 插件系统_初始化() {
    插件_列表 = []

    // 注册内置Nova原生插件
    插件系统_注册内置插件()

    插件_已初始化 = 真
    内核信息("插件系统: Nova浏览器 Extension兼容 + Nova原生扩展就绪")
}

函数 插件系统_注册内置插件() {
    // Nova AI 助手插件(内置)
    定义 ai插件 = 浏览器插件 {}
    ai插件.ID = "nova-ai-assistant"
    ai插件.名称 = "Nova AI 助手"
    ai插件.版本 = "1.0"
    ai插件.描述 = "内核原生AI助手, 自然语言操作系统"
    ai插件.类型 = 插件类型_Nova原生
    ai插件.状态 = 插件状态_已启用
    ai插件.权限 = 插件权限_系统 | 插件权限_标签 | 插件权限_DOM | 插件权限_网络
    ai插件.沙箱级别 = 沙箱_轻量
    追加(插件_列表, ai插件)

    // Nova 广告拦截器(内置)
    定义 ad插件 = 浏览器插件 {}
    ad插件.ID = "nova-ad-blocker"
    ad插件.名称 = "Nova 广告拦截"
    ad插件.版本 = "1.0"
    ad插件.描述 = "AI驱动的智能广告拦截"
    ad插件.类型 = 插件类型_Nova原生
    ad插件.状态 = 插件状态_已启用
    ad插件.权限 = 插件权限_网络 | 插件权限_DOM
    ad插件.沙箱级别 = 沙箱_标准
    追加(插件_列表, ad插件)

    // Nova 暗色模式(内置)
    定义 暗色插件 = 浏览器插件 {}
    暗色插件.ID = "nova-dark-mode"
    暗色插件.名称 = "Nova 暗色模式"
    暗色插件.版本 = "1.0"
    暗色插件.描述 = "全局网页暗色模式"
    暗色插件.类型 = 插件类型_内容脚本
    暗色插件.状态 = 插件状态_已启用
    暗色插件.权限 = 插件权限_DOM
    暗色插件.沙箱级别 = 沙箱_标准
    追加(插件_列表, 暗色插件)
}

// §2 插件安装/卸载

函数 插件系统_安装(manifest_json) {
    // 解析manifest → 创建插件对象
    定义 插件 = 浏览器插件 {}
    插件.manifest = manifest_json
    插件.状态 = 插件状态_已安装
    插件.沙箱级别 = 沙箱_标准

    // 安全审核
    如果 (插件.权限 & 插件权限_系统 != 0) {
        // 系统级权限需要用户确认
        插件.沙箱级别 = 沙箱_严格
    }

    追加(插件_列表, 插件)
    返回 插件.ID
}

函数 插件系统_卸载(插件ID) {
    定义 可变 i = 0
    当 (i < 计数(插件_列表)) {
        如果 (插件_列表[i].ID == 插件ID) {
            列表_移除(插件_列表, i)
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 插件系统_启用(插件ID) {
    定义 可变 i = 0
    当 (i < 计数(插件_列表)) {
        如果 (插件_列表[i].ID == 插件ID) {
            插件_列表[i].状态 = 插件状态_已启用
            返回
        }
        i = i + 1
    }
}

函数 插件系统_禁用(插件ID) {
    定义 可变 i = 0
    当 (i < 计数(插件_列表)) {
        如果 (插件_列表[i].ID == 插件ID) {
            插件_列表[i].状态 = 插件状态_已禁用
            返回
        }
        i = i + 1
    }
}

// §3 内容脚本注入

函数 插件系统_注入内容脚本(url) {
    定义 可变 i = 0
    当 (i < 计数(插件_列表)) {
        定义 插件 = 插件_列表[i]
        如果 (插件.状态 == 插件状态_已启用) {
            如果 (插件.类型 == 插件类型_内容脚本 || 计数(插件.内容脚本) > 0) {
                定义 可变 j = 0
                当 (j < 计数(插件.内容脚本)) {
                    定义 匹配模式 = 插件.内容脚本[j][0]
                    如果 (插件系统_匹配URL(url, 匹配模式)) {
                        // 在沙箱中执行内容脚本
                        JS_执行脚本(插件.内容脚本[j][1])
                    }
                    j = j + 1
                }
            }
        }
        i = i + 1
    }
}

函数 插件系统_匹配URL(url, 模式) {
    如果 (模式 == "*") { 返回 真 }
    如果 (模式 == "<all_urls>") { 返回 真 }
    如果 (字符串查找(url, 模式) >= 0) { 返回 真 }
    返回 假
}

// §4 查询接口

函数 插件系统_获取列表() {
    返回 插件_列表
}

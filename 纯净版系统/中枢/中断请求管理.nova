//   1. IRQ注册/注销: 支持共享IRQ、线程化IRQ、带名称匹配注销
//   2. IRQ分发: 遍历处理链、伪中断检测、中断风暴保护
//   3. 嵌套使能/禁用: 引用计数保证安全
//   4. 亲和性管理: 绑定IRQ到特定CPU
//   5. 负载统计: 为调度器提供中断负载信息
//   6. 批量操作: 批量注册/注销/禁用/启用
//   7. 线程化下半部: 硬中断快速应答后唤醒线程处理

导入("./日志中枢.nova")
导入("./自动扩容.nova")
导入("./字符串替换.nova")
导入("./内核打印.nova")
导入("./页表重建.nova")

定义 IRQ_无 = 0
定义 IRQ_已处理 = 1
定义 IRQ_唤醒线程 = 2

定义 IRQF_共享 = 0x80
定义 IRQF_定时器 = 0x200
定义 IRQF_不平衡 = 0x400
定义 IRQF_边沿触发 = 0x01
定义 IRQF_电平触发 = 0x02
定义 IRQF_线程化 = 0x800
定义 IRQF_不挂起 = 0x4000
定义 IRQF_每CPU = 0x100

定义 ID_处理链 = 0
定义 ID_计数 = 1
定义 ID_名称 = 2
定义 ID_已禁用 = 3
定义 ID_标志 = 4
定义 ID_亲和CPU = 5
定义 ID_伪中断数 = 6
定义 ID_线程计数 = 7
定义 ID_最后触发时间 = 8
定义 ID_连续伪中断 = 9
定义 ID_已自动禁用 = 10
定义 ID_线程待处理 = 11

定义 HC_处理函数 = 0
定义 HC_名称 = 1
定义 HC_标志 = 2
定义 HC_线程函数 = 3
定义 HC_触发次数 = 4

定义 最大IRQ = 256
定义 可变 IRQ描述符表 = []
定义 可变 IRQ总计数 = 0
定义 可变 IRQ伪总计 = 0
定义 可变 IRQ_管理_已初始化 = 假

定义 可变 管理_注册总数 = 0
定义 可变 管理_注销总数 = 0
定义 可变 管理_启用总数 = 0
定义 可变 管理_禁用总数 = 0
定义 可变 管理_线程唤醒总数 = 0
定义 可变 管理_亲和设置总数 = 0
定义 可变 管理_风暴禁用总数 = 0
定义 可变 管理_重触发总数 = 0
定义 可变 管理_错误总数 = 0
定义 可变 管理_批量注册总数 = 0
定义 可变 管理_批量注销总数 = 0
定义 可变 IRQ_线程化_回退同步执行 = 真

定义 伪中断风暴阈值 = 100000
定义 连续伪中断重置间隔 = 1000

函数 IRQ描述符_创建() {
    返回 [[], 0, "", 0, 0, 0 - 1, 0, 0, 0, 0, 假, 0]
}

// 初始化

函数 IRQ_初始化() {
    如果 (IRQ_管理_已初始化 == 真) {
        内核警告("[IRQ管理] 警告: 重复初始化, 跳过")
        返回 错误_已存在
    }
    IRQ描述符表 = []
    定义 可变 i = 0
    当 (i < 最大IRQ) {
        追加(IRQ描述符表, IRQ描述符_创建())
        i = i + 1
    }
    IRQ总计数 = 0
    IRQ伪总计 = 0
    管理_注册总数 = 0
    管理_注销总数 = 0
    管理_启用总数 = 0
    管理_禁用总数 = 0
    管理_线程唤醒总数 = 0
    管理_亲和设置总数 = 0
    管理_风暴禁用总数 = 0
    管理_重触发总数 = 0
    管理_错误总数 = 0
    管理_批量注册总数 = 0
    管理_批量注销总数 = 0
    IRQ_管理_已初始化 = 真
    早期打印OK("[IRQ管理] 初始化完成 (256向量)")
    返回 0
}

// 注册IRQ处理函数 (支持共享/线程化)

函数 IRQ_注册(IRQ号, 名称, 处理函数) {
    返回 IRQ_注册_带标志(IRQ号, 名称, 处理函数, 0)
}

函数 IRQ_注册_线程化(IRQ号, 名称, 硬中断函数, 线程函数, 标志) {
    如果 (IRQ_管理_已初始化 == 假) {
        管理_错误总数 = 管理_错误总数 + 1
        返回 错误_未初始化
    }
    如果 (IRQ号 >= 最大IRQ) {
        管理_错误总数 = 管理_错误总数 + 1
        返回 错误_无效参数
    }
    如果 (硬中断函数 == 空 && 线程函数 == 空) {
        管理_错误总数 = 管理_错误总数 + 1
        返回 错误_无效参数
    }
    如果 (名称 == 空 || 名称 == "") {
        管理_错误总数 = 管理_错误总数 + 1
        返回 错误_无效参数
    }
    定义 描述符 = IRQ描述符表[IRQ号]
    // 检查共享冲突
    如果 (计数(描述符[ID_处理链]) > 0) {
        如果 ((标志 & IRQF_共享) == 0 || (描述符[ID_标志] & IRQF_共享) == 0) {
            管理_错误总数 = 管理_错误总数 + 1
            返回 错误_设备忙
        }
    }
    // 添加到处理链: [硬中断函数, 名称, 标志, 线程函数, 触发次数]
    追加(描述符[ID_处理链], [硬中断函数, 名称, 标志 | IRQF_线程化, 线程函数, 0])
    如果 (描述符[ID_名称] == "") { 设置(描述符, ID_名称, 名称) }
    设置(描述符, ID_标志, 描述符[ID_标志] | 标志 | IRQF_线程化)
    管理_注册总数 = 管理_注册总数 + 1
    内核调试("[IRQ管理] 线程化注册: IRQ" + 转字符串(IRQ号) + " - " + 名称)
    返回 0
}

函数 IRQ_注册_带标志(IRQ号, 名称, 处理函数, 标志) {
    如果 (IRQ_管理_已初始化 == 假) {
        管理_错误总数 = 管理_错误总数 + 1
        返回 错误_未初始化
    }
    如果 (IRQ号 >= 最大IRQ) {
        管理_错误总数 = 管理_错误总数 + 1
        返回 错误_无效参数
    }
    如果 (处理函数 == 空) {
        管理_错误总数 = 管理_错误总数 + 1
        返回 错误_无效参数
    }
    如果 (名称 == 空 || 名称 == "") {
        管理_错误总数 = 管理_错误总数 + 1
        返回 错误_无效参数
    }
    定义 描述符 = IRQ描述符表[IRQ号]
    // 检查自动禁用状态
    如果 (描述符[ID_已自动禁用] == 真) {
        内核警告("[IRQ管理] IRQ" + 转字符串(IRQ号) + " 已因风暴被自动禁用")
        管理_错误总数 = 管理_错误总数 + 1
        返回 错误_设备忙
    }
    // 检查共享冲突
    如果 (计数(描述符[ID_处理链]) > 0) {
        如果 ((标志 & IRQF_共享) == 0 || (描述符[ID_标志] & IRQF_共享) == 0) {
            管理_错误总数 = 管理_错误总数 + 1
            返回 错误_设备忙
        }
    }
    // 添加到处理链: [处理函数, 名称, 标志, 空(无线程函数), 触发次数]
    追加(描述符[ID_处理链], [处理函数, 名称, 标志, 空, 0])
    如果 (描述符[ID_名称] == "") { 设置(描述符, ID_名称, 名称) }
    设置(描述符, ID_标志, 描述符[ID_标志] | 标志)
    管理_注册总数 = 管理_注册总数 + 1
    内核调试("[IRQ管理] 注册: IRQ" + 转字符串(IRQ号) + " - " + 名称)
    返回 0
}

// IRQ处理分发 — 含伪中断风暴检测

函数 IRQ_处理(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 }
    定义 描述符 = IRQ描述符表[IRQ号]
    // 禁用检查
    如果 (描述符[ID_已禁用] > 0) { 返回 }
    // 自动禁用检查
    如果 (描述符[ID_已自动禁用] == 真) { 返回 }
    设置(描述符, ID_计数, 描述符[ID_计数] + 1)
    IRQ总计数 = IRQ总计数 + 1
    // 遍历处理链 (共享IRQ)
    定义 处理链 = 描述符[ID_处理链]
    定义 可变 已处理 = 假
    定义 可变 需要线程 = 假
    定义 可变 i = 0
    当 (i < 计数(处理链)) {
        定义 处理项 = 处理链[i]
        定义 处理函数 = 处理项[HC_处理函数]
        如果 (处理函数 != 空) {
            定义 结果 = 处理函数(IRQ号)
            // 更新每个handler的触发计数
            设置(处理项, HC_触发次数, 处理项[HC_触发次数] + 1)
            如果 (结果 == IRQ_已处理) {
                已处理 = 真
            } 否则 如果 (结果 == IRQ_唤醒线程) {
                已处理 = 真
                需要线程 = 真
            }
        }
        i = i + 1
    }
    // 伪中断检测与风暴保护
    如果 (已处理 == 假 && 计数(处理链) > 0) {
        设置(描述符, ID_伪中断数, 描述符[ID_伪中断数] + 1)
        设置(描述符, ID_连续伪中断, 描述符[ID_连续伪中断] + 1)
        IRQ伪总计 = IRQ伪总计 + 1
        // 连续伪中断达到阈值时自动禁用
        如果 (描述符[ID_连续伪中断] >= 伪中断风暴阈值) {
            设置(描述符, ID_已自动禁用, 真)
            管理_风暴禁用总数 = 管理_风暴禁用总数 + 1
            内核警告("[IRQ管理] IRQ" + 转字符串(IRQ号) + " 伪中断风暴! 已自动禁用")
        }
    } 否则 如果 (已处理 == 真) {
        // 成功处理时重置连续伪中断计数
        设置(描述符, ID_连续伪中断, 0)
    }
    // 线程化处理: 只安排下半部，不在硬中断路径直接执行线程函数
    如果 (需要线程 == 真) {
        IRQ_安排线程处理(IRQ号)
    }
    如果 (计数(处理链) == 0) {
        内核警告("[IRQ管理] 未注册IRQ: " + 转字符串(IRQ号))
    }
}

函数 IRQ_安排线程处理(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 错误_无效参数 }
    定义 描述符 = IRQ描述符表[IRQ号]
    如果 (计数(描述符[ID_处理链]) == 0) { 返回 错误_不存在 }
    设置(描述符, ID_线程计数, 描述符[ID_线程计数] + 1)
    设置(描述符, ID_线程待处理, 描述符[ID_线程待处理] + 1)
    管理_线程唤醒总数 = 管理_线程唤醒总数 + 1
    如果 (IRQ_线程化_回退同步执行 == 真) {
        IRQ_执行线程处理(IRQ号)
    }
    返回 0
}

函数 IRQ_执行线程处理(IRQ号) {
    // 由调度器或专用IRQ线程调用，统一执行下半部。
    如果 (IRQ号 >= 最大IRQ) { 返回 }
    定义 描述符 = IRQ描述符表[IRQ号]
    当 (描述符[ID_线程待处理] > 0) {
        定义 处理链 = 描述符[ID_处理链]
        定义 可变 已执行 = 假
        定义 可变 i = 0
        当 (i < 计数(处理链)) {
            定义 处理项 = 处理链[i]
            如果 (处理项[HC_线程函数] != 空) {
                处理项[HC_线程函数](IRQ号)
                已执行 = 真
            }
            i = i + 1
        }
        设置(描述符, ID_线程待处理, 描述符[ID_线程待处理] - 1)
        如果 (已执行 == 假) { 中断 }
    }
    如果 (描述符[ID_线程待处理] < 0) {
        设置(描述符, ID_线程待处理, 0)
    }
}

// IRQ重触发: 模拟触发一个IRQ(用于边沿触发丢失恢复)

函数 IRQ_重触发(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 错误_无效参数 }
    定义 描述符 = IRQ描述符表[IRQ号]
    如果 (描述符[ID_已禁用] > 0) { 返回 错误_设备忙 }
    管理_重触发总数 = 管理_重触发总数 + 1
    内核调试("[IRQ管理] 重触发: IRQ" + 转字符串(IRQ号))
    IRQ_处理(IRQ号)
    返回 0
}

// 注销IRQ

函数 IRQ_注销(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 错误_无效参数 }
    定义 描述符 = IRQ描述符表[IRQ号]
    设置(描述符, ID_处理链, [])
    设置(描述符, ID_名称, "")
    设置(描述符, ID_标志, 0)
    设置(描述符, ID_已自动禁用, 假)
    设置(描述符, ID_连续伪中断, 0)
    管理_注销总数 = 管理_注销总数 + 1
    返回 0
}

函数 IRQ_注销_处理(IRQ号, 处理函数) {
    如果 (IRQ号 >= 最大IRQ) { 返回 错误_无效参数 }
    定义 描述符 = IRQ描述符表[IRQ号]
    定义 处理链 = 描述符[ID_处理链]
    定义 可变 i = 0
    当 (i < 计数(处理链)) {
        如果 (处理链[i][HC_处理函数] == 处理函数) {
            删除(处理链, i)
            管理_注销总数 = 管理_注销总数 + 1
            // 处理链清空时重置名称
            如果 (计数(处理链) == 0) {
                设置(描述符, ID_名称, "")
                设置(描述符, ID_标志, 0)
            }
            返回 0
        }
        i = i + 1
    }
    管理_错误总数 = 管理_错误总数 + 1
    返回 错误_不存在
}

函数 IRQ_注销_按名称(IRQ号, 名称) {
    如果 (IRQ号 >= 最大IRQ) { 返回 错误_无效参数 }
    如果 (名称 == 空 || 名称 == "") { 返回 错误_无效参数 }
    定义 描述符 = IRQ描述符表[IRQ号]
    定义 处理链 = 描述符[ID_处理链]
    定义 可变 i = 0
    当 (i < 计数(处理链)) {
        如果 (处理链[i][HC_名称] == 名称) {
            删除(处理链, i)
            管理_注销总数 = 管理_注销总数 + 1
            如果 (计数(处理链) == 0) {
                设置(描述符, ID_名称, "")
                设置(描述符, ID_标志, 0)
            } 否则 {
                // 更新显示名称为第一个handler的名称
                设置(描述符, ID_名称, 处理链[0][HC_名称])
            }
            返回 0
        }
        i = i + 1
    }
    管理_错误总数 = 管理_错误总数 + 1
    返回 错误_不存在
}

// 批量操作

函数 IRQ_批量注册(IRQ列表) {
    // IRQ列表格式: [[IRQ号, 名称, 处理函数, 标志], ...]
    如果 (IRQ列表 == 空) { 返回 错误_无效参数 }
    定义 可变 成功数 = 0
    定义 可变 失败数 = 0
    定义 可变 i = 0
    当 (i < 计数(IRQ列表)) {
        定义 项 = IRQ列表[i]
        定义 结果 = IRQ_注册_带标志(项[0], 项[1], 项[2], 项[3])
        如果 (结果 == 0) {
            成功数 = 成功数 + 1
        } 否则 {
            失败数 = 失败数 + 1
        }
        i = i + 1
    }
    管理_批量注册总数 = 管理_批量注册总数 + 1
    如果 (失败数 > 0) {
        内核警告("[IRQ管理] 批量注册: " + 转字符串(成功数) + "成功, " + 转字符串(失败数) + "失败")
    }
    返回 成功数
}

函数 IRQ_批量注销(IRQ号列表) {
    如果 (IRQ号列表 == 空) { 返回 错误_无效参数 }
    定义 可变 i = 0
    当 (i < 计数(IRQ号列表)) {
        IRQ_注销(IRQ号列表[i])
        i = i + 1
    }
    管理_批量注销总数 = 管理_批量注销总数 + 1
    返回 0
}

函数 IRQ_批量禁用(IRQ号列表) {
    如果 (IRQ号列表 == 空) { 返回 错误_无效参数 }
    定义 可变 i = 0
    当 (i < 计数(IRQ号列表)) {
        IRQ_禁用(IRQ号列表[i])
        i = i + 1
    }
    返回 0
}

函数 IRQ_批量使能(IRQ号列表) {
    如果 (IRQ号列表 == 空) { 返回 错误_无效参数 }
    定义 可变 i = 0
    当 (i < 计数(IRQ号列表)) {
        IRQ_使能(IRQ号列表[i])
        i = i + 1
    }
    返回 0
}

// IRQ 使能/禁用 (嵌套计数)

函数 IRQ_禁用(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 错误_无效参数 }
    定义 描述符 = IRQ描述符表[IRQ号]
    设置(描述符, ID_已禁用, 描述符[ID_已禁用] + 1)
    管理_禁用总数 = 管理_禁用总数 + 1
    返回 0
}

函数 IRQ_使能(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 错误_无效参数 }
    定义 描述符 = IRQ描述符表[IRQ号]
    如果 (描述符[ID_已禁用] > 0) {
        设置(描述符, ID_已禁用, 描述符[ID_已禁用] - 1)
    }
    管理_启用总数 = 管理_启用总数 + 1
    返回 0
}

函数 IRQ_已禁用(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 真 }
    返回 IRQ描述符表[IRQ号][ID_已禁用] > 0
}

函数 IRQ_恢复自动禁用(IRQ号) {
    // 手动恢复被伪中断风暴自动禁用的IRQ
    如果 (IRQ号 >= 最大IRQ) { 返回 错误_无效参数 }
    定义 描述符 = IRQ描述符表[IRQ号]
    如果 (描述符[ID_已自动禁用] == 假) { 返回 0 }
    设置(描述符, ID_已自动禁用, 假)
    设置(描述符, ID_连续伪中断, 0)
    内核信息("[IRQ管理] IRQ" + 转字符串(IRQ号) + " 已恢复(从自动禁用)")
    返回 0
}

// IRQ亲和性管理

函数 IRQ_设置亲和(IRQ号, CPU掩码) {
    如果 (IRQ号 >= 最大IRQ) { 返回 错误_无效参数 }
    如果 (CPU掩码 == 0) { 返回 错误_无效参数 }
    设置(IRQ描述符表[IRQ号], ID_亲和CPU, CPU掩码)
    管理_亲和设置总数 = 管理_亲和设置总数 + 1
    返回 0
}

函数 IRQ_获取亲和(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 0 }
    返回 IRQ描述符表[IRQ号][ID_亲和CPU]
}

// 查询接口

函数 IRQ_计数(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 0 }
    返回 IRQ描述符表[IRQ号][ID_计数]
}

函数 IRQ_名称(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 "" }
    返回 IRQ描述符表[IRQ号][ID_名称]
}

函数 IRQ_获取总计数() { 返回 IRQ总计数 }

函数 IRQ_获取处理链长度(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 0 }
    返回 计数(IRQ描述符表[IRQ号][ID_处理链])
}

函数 IRQ_获取所有名称(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 [] }
    定义 处理链 = IRQ描述符表[IRQ号][ID_处理链]
    定义 可变 名称列表 = []
    定义 可变 i = 0
    当 (i < 计数(处理链)) {
        追加(名称列表, 处理链[i][HC_名称])
        i = i + 1
    }
    返回 名称列表
}

函数 IRQ_是线程化(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 假 }
    返回 (IRQ描述符表[IRQ号][ID_标志] & IRQF_线程化) != 0
}

函数 IRQ_伪中断数(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 0 }
    返回 IRQ描述符表[IRQ号][ID_伪中断数]
}

函数 IRQ_活跃列表() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 最大IRQ) {
        如果 (IRQ描述符表[i][ID_计数] > 0 || 计数(IRQ描述符表[i][ID_处理链]) > 0) {
            追加(结果, i)
        }
        i = i + 1
    }
    返回 结果
}

函数 IRQ_已注册列表() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 最大IRQ) {
        如果 (计数(IRQ描述符表[i][ID_处理链]) > 0) {
            追加(结果, i)
        }
        i = i + 1
    }
    返回 结果
}

// /proc/interrupts 风格统计

函数 IRQ_打印统计() {
    定义 可变 i = 0
    内核信息("       CPU0      名称           handler数  伪中断  标志")
    当 (i < 最大IRQ) {
        定义 描述符 = IRQ描述符表[i]
        如果 (描述符[ID_计数] > 0 || 计数(描述符[ID_处理链]) > 0) {
            定义 可变 行 = "IRQ" + 转字符串(i) + ": "
            行 = 行 + 转字符串(描述符[ID_计数]) + "  "
            行 = 行 + 描述符[ID_名称] + "  "
            行 = 行 + "h=" + 转字符串(计数(描述符[ID_处理链])) + "  "
            行 = 行 + "伪=" + 转字符串(描述符[ID_伪中断数])
            如果 (描述符[ID_已禁用] > 0) { 行 = 行 + " [禁用]" }
            如果 (描述符[ID_已自动禁用] == 真) { 行 = 行 + " [风暴禁用]" }
            如果 ((描述符[ID_标志] & IRQF_共享) != 0) { 行 = 行 + " [共享]" }
            如果 ((描述符[ID_标志] & IRQF_线程化) != 0) { 行 = 行 + " [线程]" }
            内核信息(行)
        }
        i = i + 1
    }
    内核信息("─── 总计 ───")
    内核信息("  总触发: " + 转字符串(IRQ总计数))
    内核信息("  总伪中断: " + 转字符串(IRQ伪总计))
    内核信息("  总注册: " + 转字符串(管理_注册总数))
    内核信息("  总注销: " + 转字符串(管理_注销总数))
}

// 完整统计系统 (≥15个指标)

函数 IRQ_完整统计() {
    定义 已注册 = 计数(IRQ_已注册列表())
    定义 活跃 = 计数(IRQ_活跃列表())
    定义 可变 共享数 = 0
    定义 可变 最热IRQ = 0
    定义 可变 最热计数 = 0
    定义 可变 自动禁用数 = 0
    定义 可变 i = 0
    当 (i < 最大IRQ) {
        定义 描述符 = IRQ描述符表[i]
        如果 (计数(描述符[ID_处理链]) > 1) { 共享数 = 共享数 + 1 }
        如果 (描述符[ID_已自动禁用] == 真) { 自动禁用数 = 自动禁用数 + 1 }
        如果 (描述符[ID_计数] > 最热计数) {
            最热计数 = 描述符[ID_计数]
            最热IRQ = i
        }
        i = i + 1
    }
    定义 统计 = 字典()
    字典设(统计, "总触发数", IRQ总计数)
    字典设(统计, "总伪中断数", IRQ伪总计)
    字典设(统计, "总注册操作", 管理_注册总数)
    字典设(统计, "总注销操作", 管理_注销总数)
    字典设(统计, "总启用操作", 管理_启用总数)
    字典设(统计, "总禁用操作", 管理_禁用总数)
    字典设(统计, "线程唤醒总数", 管理_线程唤醒总数)
    字典设(统计, "亲和设置总数", 管理_亲和设置总数)
    字典设(统计, "风暴禁用总数", 管理_风暴禁用总数)
    字典设(统计, "重触发总数", 管理_重触发总数)
    字典设(统计, "批量注册总数", 管理_批量注册总数)
    字典设(统计, "错误总数", 管理_错误总数)
    字典设(统计, "当前已注册", 已注册)
    字典设(统计, "当前活跃", 活跃)
    字典设(统计, "当前共享IRQ", 共享数)
    字典设(统计, "当前自动禁用", 自动禁用数)
    字典设(统计, "最热IRQ号", 最热IRQ)
    字典设(统计, "最热触发数", 最热计数)
    字典设(统计, "最大IRQ数", 最大IRQ)
    返回 统计
}

函数 IRQ_打印完整统计() {
    定义 统计 = IRQ_完整统计()
    打印("[IRQ管理] ═══════ 完整统计 ═══════")
    打印("  总触发数:       " + 转字符串(字典取(统计, "总触发数")))
    打印("  总伪中断数:     " + 转字符串(字典取(统计, "总伪中断数")))
    打印("  总注册操作:     " + 转字符串(字典取(统计, "总注册操作")))
    打印("  总注销操作:     " + 转字符串(字典取(统计, "总注销操作")))
    打印("  线程唤醒总数:   " + 转字符串(字典取(统计, "线程唤醒总数")))
    打印("  风暴禁用总数:   " + 转字符串(字典取(统计, "风暴禁用总数")))
    打印("  当前已注册:     " + 转字符串(字典取(统计, "当前已注册")))
    打印("  当前活跃:       " + 转字符串(字典取(统计, "当前活跃")))
    打印("  当前共享IRQ:    " + 转字符串(字典取(统计, "当前共享IRQ")))
    打印("  最热IRQ:        " + 转字符串(字典取(统计, "最热IRQ号")))
    打印("  最热触发数:     " + 转字符串(字典取(统计, "最热触发数")))
    打印("  错误总数:       " + 转字符串(字典取(统计, "错误总数")))
    打印("[IRQ管理] ═════════════════════════")
    返回 0
}

// 调试与dump

函数 IRQ_dump(IRQ号) {
    如果 (IRQ号 >= 最大IRQ) { 返回 }
    定义 描述符 = IRQ描述符表[IRQ号]
    打印("[IRQ dump] IRQ=" + 转字符串(IRQ号))
    打印("  触发次数=" + 转字符串(描述符[ID_计数]))
    打印("  名称=" + 描述符[ID_名称])
    打印("  handler数=" + 转字符串(计数(描述符[ID_处理链])))
    打印("  伪中断=" + 转字符串(描述符[ID_伪中断数]))
    打印("  连续伪中断=" + 转字符串(描述符[ID_连续伪中断]))
    打印("  禁用深度=" + 转字符串(描述符[ID_已禁用]))
    打印("  自动禁用=" + 转字符串(描述符[ID_已自动禁用]))
    打印("  线程处理=" + 转字符串(描述符[ID_线程计数]))
    // 打印每个handler
    定义 处理链 = 描述符[ID_处理链]
    定义 可变 i = 0
    当 (i < 计数(处理链)) {
        定义 项 = 处理链[i]
        打印("  handler[" + 转字符串(i) + "]: " + 项[HC_名称] + " 触发=" + 转字符串(项[HC_触发次数]))
        i = i + 1
    }
}

函数 IRQ_dump全部() {
    定义 可变 i = 0
    当 (i < 最大IRQ) {
        如果 (计数(IRQ描述符表[i][ID_处理链]) > 0 || IRQ描述符表[i][ID_计数] > 0) {
            IRQ_dump(i)
        }
        i = i + 1
    }
}

// 销毁与清理

函数 IRQ_管理_销毁() {
    如果 (IRQ_管理_已初始化 == 假) { 返回 0 }
    定义 可变 i = 0
    当 (i < 最大IRQ) {
        设置(IRQ描述符表[i], ID_处理链, [])
        i = i + 1
    }
    IRQ描述符表 = []
    IRQ_管理_已初始化 = 假
    内核信息("[IRQ管理] 已销毁")
    返回 0
}

// 与其他子系统的接口

函数 IRQ_为调度器提供负载() {
    // 返回 [[IRQ号, 触发计数, 亲和CPU], ...] 供负载均衡使用
    定义 可变 负载 = []
    定义 可变 i = 0
    当 (i < 最大IRQ) {
        定义 描述符 = IRQ描述符表[i]
        如果 (描述符[ID_计数] > 0 && 描述符[ID_已禁用] == 0) {
            追加(负载, [i, 描述符[ID_计数], 描述符[ID_亲和CPU]])
        }
        i = i + 1
    }
    返回 负载
}

函数 IRQ_为电源管理提供活跃列表() {
    // 返回所有有handler的IRQ号, 供电源挂起时保存/恢复
    返回 IRQ_已注册列表()
}

函数 IRQ_挂起全部() {
    // 电源挂起时禁用所有非唤醒IRQ
    定义 可变 i = 0
    定义 可变 禁用数 = 0
    当 (i < 最大IRQ) {
        定义 描述符 = IRQ描述符表[i]
        如果 (计数(描述符[ID_处理链]) > 0) {
            如果 ((描述符[ID_标志] & IRQF_不挂起) == 0) {
                IRQ_禁用(i)
                禁用数 = 禁用数 + 1
            }
        }
        i = i + 1
    }
    内核信息("[IRQ管理] 挂起: 禁用了 " + 转字符串(禁用数) + " 个IRQ")
    返回 禁用数
}

函数 IRQ_恢复全部() {
    // 电源恢复时重新启用IRQ
    定义 可变 i = 0
    定义 可变 启用数 = 0
    当 (i < 最大IRQ) {
        定义 描述符 = IRQ描述符表[i]
        如果 (计数(描述符[ID_处理链]) > 0 && 描述符[ID_已禁用] > 0) {
            如果 ((描述符[ID_标志] & IRQF_不挂起) == 0) {
                IRQ_使能(i)
                启用数 = 启用数 + 1
            }
        }
        i = i + 1
    }
    内核信息("[IRQ管理] 恢复: 启用了 " + 转字符串(启用数) + " 个IRQ")
    返回 启用数
}

定义 可变 AI_中断请求管_风暴阈值 = 10000
定义 可变 AI_中断请求管_预测IRQ = 0

函数 AI_中断请求管_风暴检测(触发频率) {
    如果 (触发频率 > AI_中断请求管_风暴阈值) {
        AI_中断请求管_风暴阈值 = AI_中断请求管_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_中断请求管_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

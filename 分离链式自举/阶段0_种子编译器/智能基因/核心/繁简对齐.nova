// Nova 智能基因层 · 繁简汉字语义对齐
// 实验反哺: 汉字演化实验发现演化不变量=语义DNA，繁简字共享相同语义核心
// 核心洞见: 繁体"龜"和简体"龟"虽然形态差异大，但语义完全相同
//           → 训练数据可以混合繁简，用演化不变量作为对齐锚点
// 用途: 跨繁简的通用中文AI、台湾/香港/大陆用户无缝服务

// 常用繁简对照表（高频简化字）
// 格式: [繁体码点, 简体码点, 语义不变量]
// 这些字在繁体字中保留了更多笔画信息，但语义与简体完全相同

导入("../../标准库/基础.nova")

定义 繁简对照 = [
    [38376, 38376, "出入/界限"],     // 門→门
    [32244, 32244, "听说/言语"],     // 聽→听
    [35779, 35779, "说话/语言"],     // 說→说
    [36827, 36827, "读/学习"],       // 讀→读
    [39532, 39532, "动物/速度"],     // 馬→马
    [40657, 40657, "爬行/壳"],       // 龜→龟
    [39134, 39134, "飞翔"],          // 飛→飞
    [40060, 40060, "水中/食物"],     // 魚→鱼
    [32701, 32701, "爱情/关怀"],     // 愛→爱
    [32032, 32032, "国家/地域"],     // 國→国
]

// 繁简码点映射表
// 键: 繁体码点（字符串）→ 值: 简体码点
函数 繁简映射_初始化() {
    定义 映射 = 字典()
    定义 可变 i = 0
    当 (i < 计数(繁简对照)) {
        字典设(映射, 转字符串(繁简对照[i][0]), 繁简对照[i][1])
        // 反向：简体 → 繁体（用于双向查询）
        字典设(映射, "S" + 转字符串(繁简对照[i][1]), 繁简对照[i][0])
        i = i + 1
    }
    返回 映射
}

// 繁转简（单字）
函数 繁转简(码点, 映射) {
    定义 结果 = 字典取(映射, 转字符串(码点))
    如果 (结果 == 空) { 返回 码点 }  // 没有对应简体，原字返回
    返回 结果
}

// 简转繁（单字）
函数 简转繁(码点, 映射) {
    定义 结果 = 字典取(映射, "S" + 转字符串(码点))
    如果 (结果 == 空) { 返回 码点 }
    返回 结果
}

// 演化不变量提取
// 从繁简对照中提取共同语义核心
函数 获取语义不变量(繁体码点, 简体码点) {
    定义 可变 i = 0
    当 (i < 计数(繁简对照)) {
        如果 (繁简对照[i][0] == 繁体码点 或 繁简对照[i][1] == 简体码点) {
            返回 繁简对照[i][2]
        }
        i = i + 1
    }
    返回 "未知语义"
}

// 繁简中立嵌入（演化不变量加权）
// 将繁体和简体的嵌入向量融合，用语义不变量作为锚点
// 输出：对两者都有效的中立嵌入
函数 繁简中立嵌入_融合(繁嵌入, 简嵌入, 语义不变量比重) {
    // 比重 = [0, 100]：0=完全用简体，100=完全用繁体
    // 中间值=语义中立嵌入
    如果 (计数(繁嵌入) != 计数(简嵌入)) { 返回 简嵌入 }
    定义 可变 融合 = []
    定义 可变 i = 0
    当 (i < 计数(繁嵌入)) {
        // 加权平均（语义不变量维度用平均值，其他维度偏向简体）
        定义 繁权 = 语义不变量比重
        定义 简权 = 100 - 语义不变量比重
        追加(融合, (繁嵌入[i] * 繁权 + 简嵌入[i] * 简权) / 100)
        i = i + 1
    }
    返回 融合
}

// 繁简相似度计算
// 基于码点差距和语义不变量评估繁简对相似度
函数 繁简相似度(繁体码点, 简体码点) {
    // 检查是否在对照表中
    定义 可变 i = 0
    当 (i < 计数(繁简对照)) {
        如果 (繁简对照[i][0] == 繁体码点 且 繁简对照[i][1] == 简体码点) {
            返回 1000  // 确定对应：相似度=100%
        }
        i = i + 1
    }
    // 码点差距估算
    定义 差 = 繁体码点 - 简体码点
    如果 (差 < 0) { 差 = 0 - 差 }
    如果 (差 == 0) { 返回 1000 }  // 相同码点
    // CJK范围内，差距越小相似度越高
    如果 (差 < 100) { 返回 800 }
    如果 (差 < 500) { 返回 500 }
    如果 (差 < 2000) { 返回 200 }
    返回 100
}

// 混合繁简文本正规化
// 将含有繁体字的文本统一转为简体（用于智能推理）
函数 文本_正规化为简体(码点列表, 映射) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(码点列表)) {
        追加(结果, 繁转简(码点列表[i], 映射))
        i = i + 1
    }
    返回 结果
}

// 统计文本中繁体字比例（判断是繁体为主还是简体为主）
函数 繁体字比例(码点列表, 映射) {
    如果 (计数(码点列表) == 0) { 返回 0 }
    定义 可变 繁体数 = 0
    定义 可变 i = 0
    当 (i < 计数(码点列表)) {
        定义 简 = 繁转简(码点列表[i], 映射)
        如果 (简 != 码点列表[i]) { 繁体数 = 繁体数 + 1 }  // 有对应简体 → 是繁体字
        i = i + 1
    }
    返回 繁体数 * 100 / 计数(码点列表)
}

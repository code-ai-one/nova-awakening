导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")

// §1 创建/初始化


函数 绘制Layer_创建(布局对象) {
    定义 层 = 堆_分配(绘制Layer)
    层.布局对象 = 布局对象
    层.类型 = 层类型_普通
    层.标志 = 层标志_需要重绘

    层.父层 = 0; 层.第一子层 = 0; 层.最后子层 = 0
    层.前兄层 = 0; 层.后兄层 = 0

    层.负z序列表 = 堆_分配_数组(16 * 8)
    层.负z序数量 = 0
    层.正z序列表 = 堆_分配_数组(16 * 8)
    层.正z序数量 = 0

    层.裁剪矩形_x = 0; 层.裁剪矩形_y = 0
    层.裁剪矩形_w = 0; 层.裁剪矩形_h = 0
    层.滚动偏移x = 0; 层.滚动偏移y = 0
    层.滚动内容宽 = 0; 层.滚动内容高 = 0
    层.变换矩阵 = 0
    层.图形层 = 0

    层.显示列表 = 堆_分配_数组(256 * 48)
    层.显示列表数量 = 0
    层.显示列表容量 = 256

    // 从布局对象的样式确定层标志
    定义 样式 = 布局对象.样式
    如果 (样式 != 0) {
        层.z_index = 样式.z_index
        如果 (样式.transform != 0) { 层.标志 = 层.标志 | 层标志_有变换 }
        如果 (样式.opacity < 100) { 层.标志 = 层.标志 | 层标志_有透明度 }
        如果 (样式.overflow_x != Overflow_visible || 样式.overflow_y != Overflow_visible) {
            层.标志 = 层.标志 | 层标志_有溢出裁剪
        }
        如果 (样式.position == Position_fixed) { 层.标志 = 层.标志 | 层标志_有固定定位 }

        // 是否创建堆叠上下文(stacking context)
        如果 (样式.position != Position_static && !样式.z_index_auto) {
            层.标志 = 层.标志 | 层标志_是堆叠上下文
        }
        如果 (样式.opacity < 100) {
            层.标志 = 层.标志 | 层标志_是堆叠上下文
        }
        如果 (样式.transform != 0) {
            层.标志 = 层.标志 | 层标志_是堆叠上下文
        }
        如果 (样式.display == Display_flex || 样式.display == Display_grid) {
            // flex/grid容器的子项如果有z-index也创建堆叠上下文
        }
    }

    层.渲染精度 = 2        // 默认标准
    层.渲染优先级 = 128    // 默认中等
    层.视口可见 = 0
    层.注意力权重 = 5000
    层.上次绘制耗时 = 0
    层.累计绘制次数 = 0
    层.显示项缓存版本 = 0

    返回 层
}

函数 绘制Layer_添加子层(父层, 子层) {
    子层.父层 = 父层
    子层.前兄层 = 父层.最后子层
    子层.后兄层 = 0
    如果 (父层.最后子层 != 0) {
        父层.最后子层.后兄层 = 子层
    } 否则 {
        父层.第一子层 = 子层
    }
    父层.最后子层 = 子层
}

// §2 z-order排序 
// CSS §Appendix E: 绘制ing order

函数 绘制Layer_更新z序(层) {
 层.负z序数量 = 0
 层.正z序数量 = 0

 // 收集子层到z-order列表
 定义 可变 子 = 层.第一子层
 当 (子 != 0) {
 如果 (子.标志 & 层标志_是堆叠上下文) {
 如果 (子.z_index < 0) {
 内存_写64(层.负z序列表 + 层.负z序数量 * 8, 子)
 层.负z序数量 = 层.负z序数量 + 1
 } 否则 {
 内存_写64(层.正z序列表 + 层.正z序数量 * 8, 子)
 层.正z序数量 = 层.正z序数量 + 1
 }
 }
 子 = 子.后兄层
 }

 // 按z-index排序(插入排序)
 绘制Layer_排序z序列表(层.负z序列表, 层.负z序数量)
 绘制Layer_排序z序列表(层.正z序列表, 层.正z序数量)

 // 递归更新子层
 子 = 层.第一子层
 当 (子 != 0) {
 绘制Layer_更新z序(子)
 子 = 子.后兄层
 }
}

函数 绘制Layer_排序z序列表(列表, 数量) {
 // 插入排序 按z_index升序
 定义 可变 i = 1
 当 (i < 数量) {
 定义 当前 = 内存_读64(列表 + i * 8)
 定义 当前z = 当前.z_index
 定义 可变 j = i - 1
 当 (j >= 0 && 内存_读64(列表 + j * 8).z_index > 当前z) {
 内存_写64(列表 + (j + 1) * 8, 内存_读64(列表 + j * 8))
 j = j - 1
 }
 内存_写64(列表 + (j + 1) * 8, 当前)
 i = i + 1
 }
}

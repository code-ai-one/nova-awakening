// NovaOS 检查点管理 — 更新前完整状态快照(记忆点)
// 核心设计:
//   1. 更新前自动创建检查点: 进程表+内存映射+AI权重+FS状态
//   2. 检查点存储在保留内存区域(不被正常分配影响)
//   3. 回滚时从检查点恢复全部状态
//   4. 支持多检查点(最多8个), LRU淘汰
//   5. 检查点包含版本号, 防止恢复到不兼容状态

导入("./日志中枢.nova")

外部 SLUB_缓存列表
外部 SLUB_缓存数量
外部 进程表
外部 调度_运行队列
外部 VFS_脏Nova文件节点列表
外部 页缓存_脏页链表
外部 socket_全局表
外部 定时器_活跃列表
外部 软中断状态
外部 调度_清空运行队列
外部 调度_插入任务
外部 伙伴_恢复空闲计数
外部 挂载表
外部 VFS_重新打开
外部 socket_重建监听
外部 定时器_清空
外部 定时器_重建

// §1 检查点结构

结构 检查点 {
    检查点ID,
    名称,
    创建时间,
    内核版本,
    状态,    // u32 0=创建中 1=有效 2=已恢复 3=已删除

    进程表快照,    // [] 所有进程描述符的深拷贝
    进程数,
    当前PID,
    PID位图快照,    // [] PID分配位图

    伙伴系统快照,    // [] zone空闲链表状态
    全局空闲页,
    SLUB缓存快照,    // [] 各级Nova块缓存状态
    VMA快照,    // [] 所有进程的VMA列表

    TNF权重快照,    // [] TNF推理引擎权重矩阵
    赫布连接快照,    // [] 赫布学习连接权重
    突触网格快照,    // [] 3D突触网格状态
    AI记忆快照,    // [] 情景+语义+程序记忆
    注意力状态,    // [] 注意力系统焦点

    运行队列快照,    // [] Nova公平调度红黑树+RT FIFO队列
    调度统计,    // []

    挂载表快照,    // [] 所有挂载点
    打开文件表,    // [] 全局打开文件表
    Nova文件节点缓存快照,    // [] 脏Nova文件节点列表
    页缓存脏页,    // [] 待回写的脏页

    socket表快照,    // [] 所有活跃socket
    路由表快照,    // [] 路由缓存

    定时器列表,    // [] 活跃定时器
    软中断状态,
    校验和,    // u64 全部数据的CRC64
}

定义 最大检查点数 = 8
定义 可变 检查点列表 = []          // [检查点]
定义 可变 检查点ID计数器 = 1
定义 可变 检查点_保留内存起始 = 0  // 保留内存区域
定义 可变 检查点_保留内存大小 = 0
定义 可变 检查点_总创建数 = 0
定义 可变 检查点_总恢复数 = 0
定义 可变 当前内核版本 = 1

// §2 检查点初始化

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./进程调度.nova")
导入("./同步原语.nova")
导入("./内存虚拟.nova")
导入("./公共智能.nova")
导入("../引导/引导加载器.nova")
导入("./进程信号.nova")
导入("../引导/注册表获取.nova")
导入("./链表后继.nova")
导入("./时钟中枢.nova")
导入("./伙伴恢复空闲.nova")
导入("../记忆/虚文件信号同.nova")
导入("./墙钟设置.nova")
导入("./整数转字符串.nova")
导入("./公平调度统.nova")
导入("./每核页释放.nova")

函数 检查点系统_初始化() {
    检查点_保留内存大小 = 16 * 1048576
    检查点_保留内存起始 = 保留内存_分配(检查点_保留内存大小)
    如果 (检查点_保留内存起始 == 0) {
        内核警告("检查点: 无法保留内存, 回退到普通分配")
    }
    检查点列表 = []
    内核信息("检查点系统: 初始化 保留=" + 整数转字符串(检查点_保留内存大小 / 1048576) + "MB 最多" + 整数转字符串(最大检查点数) + "个")
}

// §3 检查点创建

函数 检查点_创建(名称) {
    // LRU淘汰: 超过最大数量时删除最旧的
    如果 (计数(检查点列表) >= 最大检查点数) {
        检查点_删除最旧()
    }

    定义 cp = 检查点 {
        检查点ID: 检查点ID计数器,
        名称: 名称,
        创建时间: 当前时间_纳秒(),
        内核版本: 当前内核版本,
        状态: 0,
        // 进程
        进程表快照: [],
        进程数: 0,
        当前PID: 0,
        PID位图快照: [],
        // 内存
        伙伴系统快照: [],
        全局空闲页: 0,
        SLUB缓存快照: [],
        VMA快照: [],
        // AI
        TNF权重快照: [],
        赫布连接快照: [],
        突触网格快照: [],
        AI记忆快照: [],
        注意力状态: [],
        // 调度
        运行队列快照: [],
        调度统计: [],
        // 文件系统
        挂载表快照: [],
        打开文件表: [],
        Nova文件节点缓存快照: [],
        页缓存脏页: [],
        // 网络
        socket表快照: [],
        路由表快照: [],
        // 中断
        定时器列表: [],
        软中断状态: 0,
        // 校验
        校验和: 0,
    }

    // 快照各子系统
    定义 开始时间 = 当前时间_纳秒()

    检查点_快照进程(cp)
    检查点_快照内存(cp)
    检查点_快照AI(cp)
    检查点_快照调度(cp)
    检查点_快照文件系统(cp)
    检查点_快照网络(cp)
    检查点_快照中断(cp)

    // 计算校验和
    cp.校验和 = 检查点_计算校验和(cp)
    cp.状态 = 1

    定义 耗时 = (当前时间_纳秒() - 开始时间) / 1000000

    检查点ID计数器 = 检查点ID计数器 + 1
    检查点_总创建数 = 检查点_总创建数 + 1
    追加(检查点列表, cp)

    内核信息("检查点[" + 整数转字符串(cp.检查点ID) + "] 创建: " + 名称 + " 耗时" + 整数转字符串(耗时) + "ms")
    返回 cp
}

// §4 各子系统快照

函数 检查点_快照进程(cp) {
    // 深拷贝进程表
    如果 (进程表 != 空) {
        定义 可变 i = 0
        当 (i < 计数(进程表)) {
            追加(cp.进程表快照, 进程_深拷贝(进程表[i]))
            i = i + 1
        }
        cp.进程数 = 计数(进程表)
    }
}

函数 检查点_快照内存(cp) {
    // 记录伙伴系统空闲页状态
    cp.全局空闲页 = 获取全局空闲页数()
    // SLUB缓存状态
    如果 (SLUB_缓存列表 != 空) {
        定义 可变 i = 0
        当 (i < SLUB_缓存数量) {
            追加(cp.SLUB缓存快照, SLUB_缓存列表[i])
            i = i + 1
        }
    }
}

函数 检查点_快照AI(cp) {
    // TNF权重快照(双缓冲，只记录指针+大小)
    定义 推理 = 注册表_获取().推理引擎
    如果 (推理 != 空) {
        追加(cp.TNF权重快照, { 指针: 推理, 时间: 当前时间_纳秒() })
    }
}

函数 检查点_快照调度(cp) {
    如果 (调度_运行队列 != 空) {
        追加(cp.运行队列快照, 调度_运行队列)
    }
}

函数 检查点_快照文件系统(cp) {
    // 刷新所有脏页到磁盘
    如果 (VFS_脏Nova文件节点列表 != 空) {
        回写_刷新全部()
    }
    如果 (挂载表 != 空) {
        追加(cp.挂载表快照, 挂载表)
    }
}

函数 检查点_快照网络(cp) {
    如果 (socket_全局表 != 空) {
        追加(cp.socket表快照, socket_全局表)
    }
}

函数 检查点_快照中断(cp) {
    如果 (定时器_活跃列表 != 空) {
        追加(cp.定时器列表, 定时器_活跃列表)
    }
    cp.软中断状态 = 软中断状态
}

// §5 检查点恢复(回滚)

函数 检查点_恢复(检查点ID) {
    定义 cp = 检查点_查找(检查点ID)
    如果 (cp == 空) {
        内核错误("检查点: ID=" + 整数转字符串(检查点ID) + " 不存在")
        返回 错误_不存在
    }
    如果 (cp.状态 != 1) {
        内核错误("检查点: ID=" + 整数转字符串(检查点ID) + " 状态无效")
        返回 错误_无效参数
    }

    // 校验完整性
    定义 当前校验 = 检查点_计算校验和(cp)
    如果 (当前校验 != cp.校验和) {
        内核错误("检查点: 校验和不匹配! 数据可能损坏")
        返回 错误_数据损坏
    }

    内核信息("检查点[" + 整数转字符串(检查点ID) + "] 开始恢复: " + cp.名称)
    定义 开始时间 = 当前时间_纳秒()

    // 恢复各子系统
    检查点_恢复进程(cp)
    检查点_恢复内存(cp)
    检查点_恢复调度(cp)
    检查点_恢复文件系统(cp)
    检查点_恢复网络(cp)
    检查点_恢复中断(cp)

    cp.状态 = 2
    检查点_总恢复数 = 检查点_总恢复数 + 1

    定义 耗时 = (当前时间_纳秒() - 开始时间) / 1000000
    内核信息("检查点[" + 整数转字符串(检查点ID) + "] 恢复完成 耗时" + 整数转字符串(耗时) + "ms")
    返回 成功
}

函数 检查点_恢复进程(cp) {
    // 清空当前进程表，恢复快照
    如果 (cp.进程数 > 0) {
        调度_清空运行队列()
        定义 可变 i = 0
        当 (i < cp.进程数) {
            调度_插入任务(cp.进程表快照[i])
            i = i + 1
        }
    }
}

函数 检查点_恢复内存(cp) {
    伙伴_恢复空闲计数(cp.全局空闲页)
}

函数 检查点_恢复调度(cp) {
    如果 (cp.调度器快照 != 0) {
        打印("[检查点] 恢复调度器状态")
    }
}

函数 检查点_恢复文件系统(cp) {
    如果 (计数(cp.挂载表快照) > 0) {
        VFS_重新打开()
    }
}

函数 检查点_恢复网络(cp) {
    如果 (计数(cp.socket表快照) > 0) {
        socket_重建监听()
    }
}

函数 检查点_恢复中断(cp) {
    定时器_清空()
    如果 (计数(cp.定时器列表) > 0) {
        定时器_重建(cp.定时器列表)
    }
}

// §6 检查点管理

函数 检查点_查找(检查点ID) {
    定义 可变 i = 0
    当 (i < 计数(检查点列表)) {
        如果 (检查点列表[i].检查点ID == 检查点ID) {
            返回 检查点列表[i]
        }
        i = i + 1
    }
    返回 空
}

函数 检查点_删除(检查点ID) {
    定义 可变 i = 0
    当 (i < 计数(检查点列表)) {
        如果 (检查点列表[i].检查点ID == 检查点ID) {
            检查点列表[i].状态 = 3
            链表_删除(检查点列表, i)
            返回 成功
        }
        i = i + 1
    }
    返回 错误_不存在
}

函数 检查点_删除最旧() {
    如果 (计数(检查点列表) == 0) { 返回 }
    定义 可变 最旧索引 = 0
    定义 可变 最旧时间 = 检查点列表[0].创建时间
    定义 可变 i = 1
    当 (i < 计数(检查点列表)) {
        如果 (检查点列表[i].创建时间 < 最旧时间) {
            最旧时间 = 检查点列表[i].创建时间
            最旧索引 = i
        }
        i = i + 1
    }
    检查点列表[最旧索引].状态 = 3
    链表_删除(检查点列表, 最旧索引)
}

函数 检查点_计算校验和(cp) {
    // FNV-1a哈希简化版
    定义 可变 哈希 = 0x811c9dc5
    哈希 = (哈希 ^ cp.检查点ID) * 0x01000193
    哈希 = (哈希 ^ cp.进程数) * 0x01000193
    哈希 = (哈希 ^ cp.全局空闲页) * 0x01000193
    哈希 = (哈希 ^ cp.内核版本) * 0x01000193
    返回 哈希 & 0x7FFFFFFFFFFFFFFF
}

函数 进程_深拷贝(进程) {
    // 简化: 返回进程引用(完整实现需深拷贝所有字段)
    返回 进程
}

函数 获取全局空闲页数() {
    返回 内存_读64(全局空闲页计数地址)
}

函数 保留内存_分配(大小) {
    返回 伙伴系统_分配(大小 / 4096)
}

// §7 watchdog — 自动回滚

定义 可变 watchdog_检查点ID = 0
定义 可变 watchdog_截止时间 = 0
定义 可变 watchdog_已确认 = 假

函数 热更新_启动watchdog(检查点ID, 超时_毫秒) {
    watchdog_检查点ID = 检查点ID
    watchdog_截止时间 = 读取毫秒() + 超时_毫秒
    watchdog_已确认 = 假
}

函数 热更新_确认watchdog() {
    watchdog_已确认 = 真
    watchdog_检查点ID = 0
}

函数 热更新_检查watchdog() {
    如果 (watchdog_检查点ID == 0 || watchdog_已确认) { 返回 }
    如果 (读取毫秒() > watchdog_截止时间) {
        内核警告("热更新watchdog超时! 自动回滚到检查点" + 整数转字符串(watchdog_检查点ID))
        检查点_恢复(watchdog_检查点ID)
        watchdog_检查点ID = 0
    }
}

函数 热更新_启动智能_watchdog(模型名, 超时_毫秒) {
    // AI权重热更新的watchdog: 监控推理质量
    热更新_启动watchdog(检查点ID计数器 - 1, 超时_毫秒)
}

// §8 统计与诊断

函数 检查点_统计() {
    返回 {
        总创建: 检查点_总创建数,
        总恢复: 检查点_总恢复数,
        当前数量: 计数(检查点列表),
        最大数量: 最大检查点数,
        保留内存MB: 检查点_保留内存大小 / 1048576,
        内核版本: 当前内核版本,
        watchdog活跃: watchdog_检查点ID != 0 && !watchdog_已确认,
    }
}

函数 检查点_列表信息() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(检查点列表)) {
        定义 cp = 检查点列表[i]
        追加(结果, {
            ID: cp.检查点ID,
            名称: cp.名称,
            状态: cp.状态,
            进程数: cp.进程数,
            创建时间: cp.创建时间,
        })
        i = i + 1
    }
    返回 结果
}

函数 检查点_健康检查() {
    定义 可变 问题 = []
    如果 (检查点_保留内存起始 == 0) {
        追加(问题, "无保留内存")
    }
    如果 (watchdog_检查点ID != 0 && !watchdog_已确认) {
        追加(问题, "watchdog活跃: 等待确认检查点" + 整数转字符串(watchdog_检查点ID))
    }
    // 验证所有检查点的校验和
    定义 可变 i = 0
    当 (i < 计数(检查点列表)) {
        如果 (检查点列表[i].状态 == 1) {
            定义 当前 = 检查点_计算校验和(检查点列表[i])
            如果 (当前 != 检查点列表[i].校验和) {
                追加(问题, "检查点" + 整数转字符串(检查点列表[i].检查点ID) + "校验和损坏")
            }
        }
        i = i + 1
    }
    如果 (计数(问题) == 0) { 返回 "检查点系统健康" }
    返回 问题
}

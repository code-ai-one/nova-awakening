导入("../文本/格式化/格式化.nova")

导入("../网络/序列化/JSON序列化.nova")

定义 JSON_空值 = JSON_空
定义 JSON_整数 = JSON_数字
定义 JSON_浮点 = JSON_数字

定义 可变 _JSON_解析次数 = 0
定义 可变 _JSON_生成次数 = 0
定义 可变 _JSON_错误次数 = 0
定义 可变 _JSON_最大深度 = 0


函数 JSON_json_值(类型, 数据) {
    返回 [类型, 数据]
}

函数 json_空() {
    返回 JSON_空值()
}

函数 JSON_json_整数(v) {
    返回 [JSON_整数, v]
}

函数 json_浮点数(v) {
    返回 [JSON_浮点, v]
}

函数 json_文本(v) {
    返回 json_字符串(v)
}

函数 json_数组创建() {
    返回 json_数组()
}

函数 json_对象创建() {
    返回 json_对象()
}

函数 json_数据(节点) {
    返回 节点[1]
}

函数 json_数组追加(数组, 值) {
    返回 json_追加(数组, 值)
}

函数 json_数组获取(数组, 索引) {
    返回 json_取(数组, 索引)
}

函数 json_数组长度(数组) {
    返回 json_长度(数组)
}

函数 json_对象设(对象, 键, 值) {
    返回 json_设置(对象, 键, 值)
}

函数 json_对象取(对象, 键) {
    返回 json_获取(对象, 键)
}

函数 json_对象含(对象, 键) {
    返回 json_包含(对象, 键)
}

函数 json_对象键列表(对象) {
    如果 (json_类型(对象) != JSON_对象) {
        返回 []
    }
    返回 对象[1][0]
}

函数 json_路径(节点, 路径) {
    返回 json_查询(节点, 路径)
}

函数 JSON解析器_JSON_转义字符串(文本) {
    返回 json转义(文本)
}

函数 JSON_生成数组(元素列表) {
    定义 数组 = json_数组()
    定义 可变 i = 0
    当 (i < 计数(元素列表)) {
        json_追加(数组, 元素列表[i])
        i = i + 1
    }
    JSON_记录生成()
    返回 json_生成(数组)
}

函数 JSON_生成对象(键列表, 值列表) {
    定义 对象 = json_对象()
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        如果 (i < 计数(值列表)) {
            json_设置(对象, 键列表[i], 值列表[i])
        } 否则 {
            json_设置(对象, 键列表[i], json_空())
        }
        i = i + 1
    }
    JSON_记录生成()
    返回 json_生成(对象)
}

函数 JSON_节点深度(节点) {
    如果 (节点 == 空) {
        返回 0
    }

    定义 类型 = json_类型(节点)
    如果 (类型 == JSON_对象) {
        定义 可变 最大 = 1
        定义 值列 = 节点[1][1]
        定义 可变 i = 0
        当 (i < 计数(值列)) {
            定义 子深度 = 1 + JSON_节点深度(值列[i])
            如果 (子深度 > 最大) {
                最大 = 子深度
            }
            i = i + 1
        }
        返回 最大
    }

    如果 (类型 == JSON_数组) {
        定义 可变 最大 = 1
        定义 元素 = 节点[1]
        定义 可变 j = 0
        当 (j < 计数(元素)) {
            定义 子深度2 = 1 + JSON_节点深度(元素[j])
            如果 (子深度2 > 最大) {
                最大 = 子深度2
            }
            j = j + 1
        }
        返回 最大
    }

    返回 1
}

函数 JSON_记录解析(深度) {
    _JSON_解析次数 = _JSON_解析次数 + 1
    如果 (深度 > _JSON_最大深度) {
        _JSON_最大深度 = 深度
    }
}

函数 JSON_记录生成() {
    _JSON_生成次数 = _JSON_生成次数 + 1
}

函数 JSON_记录错误() {
    _JSON_错误次数 = _JSON_错误次数 + 1
}

函数 JSON_是否有效(文本) {
    定义 结果 = json_解析(文本)
    如果 (结果[0] == "成功") {
        返回 真
    }
    JSON_记录错误()
    返回 假
}

函数 JSON_深度(文本) {
    定义 结果 = json_解析(文本)
    如果 (结果[0] != "成功") {
        JSON_记录错误()
        返回 0
    }
    定义 深度 = JSON_节点深度(结果[1])
    JSON_记录解析(深度)
    返回 深度
}

函数 JSON_质量评估() {
    如果 (_JSON_错误次数 > _JSON_解析次数 / 5) {
        返回 "JSON解析异常"
    }
    返回 "JSON解析正常"
}

函数 JSON_重置() {
    _JSON_解析次数 = 0
    _JSON_生成次数 = 0
    _JSON_错误次数 = 0
    _JSON_最大深度 = 0
}

函数 JSON_美化(文本, _缩进) {
    定义 结果 = json_解析(文本)
    如果 (结果[0] != "成功") {
        JSON_记录错误()
        返回 文本
    }
    JSON_记录解析(JSON_节点深度(结果[1]))
    JSON_记录生成()
    返回 json_美化(结果[1])
}


// NovaOS VFS打开/关闭
// 职责: open/close/dup/fcntl系统调用

定义 O_RDONLY = 0x0000
定义 O_WRONLY = 0x0001
定义 O_RDWR = 0x0002
定义 O_CREAT = 0x0040        // 不存在则创建
定义 O_EXCL = 0x0080          // 与O_CREAT一起: 已存在则报错
定义 O_NOCTTY = 0x0100        // 不设为控制终端
定义 O_TRUNC = 0x0200         // 截断为0
定义 O_APPEND = 0x0400        // 追加模式
定义 O_NONBLOCK = 0x0800      // 非阻塞
定义 O_SYNC = 0x101000        // 同步写
定义 O_DIRECTORY = 0x10000    // 必须是目录
定义 O_NOFOLLOW = 0x20000     // 不跟随符号链接
定义 O_CLOEXEC = 0x80000      // exec时关闭

定义 S_IRWXU = 0o700    // 用户读写执行
定义 S_IRUSR = 0o400    // 用户读
定义 S_IWUSR = 0o200    // 用户写
定义 S_IXUSR = 0o100    // 用户执行
定义 S_IRWXG = 0o070    // 组读写执行
定义 S_IRWXO = 0o007    // 其他读写执行

定义 可变 打开_总次数 = 0
定义 可变 关闭_总次数 = 0
定义 可变 dup_总次数 = 0

// sys_open: 打开文件

函数 系统_open(路径, 标志, 模式) {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 错误_坏文件描述符 }

    定义 文件表 = 当前[T_文件表]
    如果 (文件表 == 空) { 返回 错误_坏文件描述符 }

    // 分配fd
    定义 fd = 文件表_分配(文件表)
    如果 (fd < 0) { 返回 fd }

    // 路径查找
    定义 根 = 获取根目录项()
    定义 目录项 = 路径查找(根, 路径)

    如果 (目录项 == 空) {
        // 文件不存在
        如果 ((标志 & O_CREAT) == 0) {
            返回 错误_不存在
        }
        // O_CREAT: 创建新文件
        定义 创建结果 = vfs_创建文件(路径, 模式)
        如果 (创建结果 < 0) { 返回 创建结果 }
        目录项 = 路径查找(根, 路径)
        如果 (目录项 == 空) { 返回 错误_不存在 }
    } 否则 {
        // 文件已存在
        如果 ((标志 & O_CREAT) != 0 && (标志 & O_EXCL) != 0) {
            返回 错误_已存在
        }
    }

    // O_DIRECTORY: 必须是目录
    定义 节点 = 目录项_Nova文件节点(目录项)
    如果 ((标志 & O_DIRECTORY) != 0 && !Nova节点_是目录(节点)) {
        返回 错误_不是目录
    }

    // 权限检查
    定义 权限结果 = 检查访问权限(节点, 标志)
    如果 (权限结果 != 成功) { 返回 权限结果 }

    // O_TRUNC: 截断文件
    如果 ((标志 & O_TRUNC) != 0 && Nova节点_是文件(节点)) {
        Nova文件节点_设置大小(节点, 0)
    }

    // 创建文件对象
    定义 文件 = 文件对象_创建(节点, 目录项, 标志)
    如果 (文件 == 空) { 返回 错误_内存不足 }

    // 调用文件系统的open
    定义 操作 = 文件[F_操作]
    如果 (操作 != 空 && 操作.打开 != 空) {
        定义 打开结果 = 操作.打开(节点, 文件)
        如果 (打开结果 != 成功) {
            返回 打开结果
        }
    }

    // 安装到fd表
    文件表_设置(文件表, fd, 文件)
    打开_总次数 = 打开_总次数 + 1

    返回 fd
}

// sys_close: 关闭文件描述符

函数 系统_close(fd) {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 错误_坏文件描述符 }

    定义 文件表 = 当前[T_文件表]
    定义 文件 = 文件表_获取(文件表, fd)
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }

    // 清除fd表项
    文件表_关闭(文件表, fd)

    // 减引用计数
    定义 剩余 = 文件_减引用(文件)
    如果 (剩余 <= 0) {
        // 最后一个引用: 真正关闭
        定义 操作 = 文件[F_操作]
        如果 (操作 != 空 && 操作.释放 != 空) {
            操作.释放(文件[F_Nova文件节点], 文件)
        }
        // 释放文件对象
    }

    关闭_总次数 = 关闭_总次数 + 1
    返回 成功
}

// sys_dup / sys_dup2: 复制文件描述符

函数 系统_dup(旧fd) {
    定义 当前 = 获取当前进程()
    定义 文件表 = 当前[T_文件表]
    定义 文件 = 文件表_获取(文件表, 旧fd)
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }

    定义 新fd = 文件表_分配(文件表)
    如果 (新fd < 0) { 返回 新fd }

    文件_增引用(文件)
    文件表_设置(文件表, 新fd, 文件)
    dup_总次数 = dup_总次数 + 1
    返回 新fd
}

函数 系统_dup2(旧fd, 新fd) {
    定义 当前 = 获取当前进程()
    定义 文件表 = 当前[T_文件表]
    定义 文件 = 文件表_获取(文件表, 旧fd)
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    如果 (新fd < 0 || 新fd >= 最大打开文件) { 返回 错误_坏文件描述符 }

    // 如果新fd已打开, 先关闭
    如果 (文件表_获取(文件表, 新fd) != 空) {
        系统_close(新fd)
    }

    文件_增引用(文件)
    文件表_设置(文件表, 新fd, 文件)
    dup_总次数 = dup_总次数 + 1
    返回 新fd
}

// sys_stat / sys_fstat: 获取文件信息

// stat结构: [设备, Nova文件节点号, 模式, 链接数, uid, gid, 大小, 块数, 访问时间, 修改时间]
定义 ST_设备 = 0
定义 ST_Nova文件节点 = 1
定义 ST_模式 = 2
定义 ST_链接 = 3
定义 ST_UID = 4
定义 ST_GID = 5
定义 ST_大小 = 6
定义 ST_块数 = 7
定义 ST_访问时间 = 8
定义 ST_修改时间 = 9

函数 系统_stat(路径) {
    定义 根 = 获取根目录项()
    定义 目录项 = 路径查找(根, 路径)
    如果 (目录项 == 空) { 返回 错误_不存在 }
    返回 Nova文件节点到stat(目录项_Nova文件节点(目录项))
}

函数 系统_fstat(fd) {
    定义 当前 = 获取当前进程()
    定义 文件 = 文件表_获取(当前[T_文件表], fd)
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    返回 Nova文件节点到stat(文件[F_Nova文件节点])
}

函数 Nova文件节点到stat(节点) {
    如果 (节点 == 空) { 返回 错误_无效参数 }
    返回 [0, 节点[I_编号], 节点[I_权限] | (节点[I_类型] << 12),
           节点[I_链接], 0, 0, 节点[I_大小], 节点[I_大小] / 512,
           节点[I_时间], 节点[I_时间]]
}

// 辅助函数

函数 文件对象_创建(节点, 目录项, 标志) {
    定义 操作 = 空
    如果 (节点[I_操作] != 空) {
        操作 = 节点[I_操作].文件操作
    }
    返回 [节点, 0, 标志, 1, 操作, 目录项, 空]
}

函数 检查访问权限(节点, 打开标志) {
    如果 (节点 == 空) { 返回 错误_不存在 }
    定义 模式 = Nova文件节点_权限(节点, 4)
    // 检查读权限
    如果 ((打开标志 & O_RDONLY) != 0 || (打开标志 & O_RDWR) != 0) {
        如果 ((模式 & 0o444) == 0) { 返回 错误_权限 }
    }
    // 检查写权限
    如果 ((打开标志 & O_WRONLY) != 0 || (打开标志 & O_RDWR) != 0) {
        如果 ((模式 & 0o222) == 0) { 返回 错误_权限 }
    }
    返回 成功
}

函数 vfs_创建文件(路径, 模式) {
    // 解析父目录路径和文件名
    定义 分隔位 = 字符串最后索引(路径, "/")
    定义 父路径 = 如果选字符(分隔位 > 0, 字符串子串(路径, 0, 分隔位), "/")
    定义 文件名 = 字符串子串(路径, 分隔位 + 1, 字符串长度(路径))

    定义 根 = 获取根目录项()
    定义 父目录项 = 路径查找(根, 父路径)
    如果 (父目录项 == 空) { 返回 错误_不存在 }

    定义 父节点 = 目录项_Nova文件节点(父目录项)
    如果 (!Nova节点_是目录(父节点)) { 返回 错误_不是目录 }

    // 创建新Nova文件节点
    定义 新节点 = Nova文件节点_创建(类型_普通文件, 模式)
    定义 新目录项 = 目录项_创建(文件名, 新节点, 父目录项)
    目录项_添加子(父目录项, 新目录项)

    // 调用文件系统的create
    定义 操作 = 父节点[I_操作]
    如果 (操作 != 空 && 操作.创建 != 空) {
        操作.创建(父节点, 新目录项, 模式)
    }

    返回 成功
}

// 统计

函数 VFS_打开关闭统计() {
    返回 [打开_总次数, 关闭_总次数, dup_总次数]
}


函数 VFS打开关闭_完整统计() {
    返回 [打开_总次数, 关闭_总次数, dup_总次数]
}

// 文件打开关闭健康检查

函数 VFS打开关闭_健康检查() {
    定义 可变 问题 = []
    定义 未关闭 = 打开_总次数 - 关闭_总次数
    如果 (未关闭 > 1000) {
        追加(问题, "文件描述符泄漏: " + 整数转字符串(未关闭) + "个未关闭")
    }
    如果 (计数(问题) == 0) { 返回 "VFS打开关闭健康" }
    返回 问题
}

函数 VFS_获取打开文件数() {
    返回 打开_总次数 - 关闭_总次数
}

函数 VFS_文件泄漏检查() {
    返回 打开_总次数 - 关闭_总次数 > 1000
}

定义 可变 AI_文件层打开_热文件表 = []

函数 AI_文件层打开_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_文件层打开_热文件表)) {
        如果 (AI_文件层打开_热文件表[i].路径 == 路径) {
            AI_文件层打开_热文件表[i].频率 = AI_文件层打开_热文件表[i].频率 + 1
            返回 AI_文件层打开_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_文件层打开_热文件表) < 128) {
        追加(AI_文件层打开_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_文件层打开_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

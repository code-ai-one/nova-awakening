// NovaOS 中断入口存根
// 每个中断向量的入口: 保存寄存器→调用C处理→恢复寄存器→iretq
// CPU自动压栈: SS, RSP, RFLAGS, CS, RIP [, 错误码]
// 软件补齐: 无错误码异常push 0对齐, push向量号, 保存通用寄存器
// 扩展: 异常分发/嵌套中断跟踪/寄存器转储/panic处理/统计

导入("./中断管理系统.nova")
导入("../引导/引导加载器.nova")
导入("../稳态/串口.nova")
导入("./中断请求描述.nova")

// 软件保存区 (低地址, 栈顶)
定义 帧_R15     = 0
定义 帧_R14     = 8
定义 帧_R13     = 16
定义 帧_R12     = 24
定义 帧_R11     = 32
定义 帧_R10     = 40
定义 帧_R9      = 48
定义 帧_R8      = 56
定义 帧_RBP     = 64
定义 帧_RDI     = 72
定义 帧_RSI     = 80
定义 帧_RDX     = 88
定义 帧_RCX     = 96
定义 帧_RBX     = 104
定义 帧_RAX     = 112
// 存根压入
定义 帧_向量号   = 120
定义 帧_错误码   = 128
// CPU自动压入 (高地址)
定义 帧_RIP     = 136
定义 帧_CS      = 144
定义 帧_RFLAGS  = 152
定义 帧_RSP     = 160
定义 帧_SS      = 168
定义 帧_总大小   = 176

定义 异常_除法错误      = 0
定义 异常_调试          = 1
定义 异常_NMI           = 2
定义 异常_断点          = 3
定义 异常_溢出          = 4
定义 异常_越界          = 5
定义 异常_无效操作码    = 6
定义 异常_设备不可用    = 7
定义 异常_双重故障      = 8
定义 异常_无效TSS       = 10
定义 异常_段不存在      = 11
定义 异常_栈段故障      = 12
定义 异常_一般保护      = 13
定义 异常_页面错误      = 14
定义 异常_浮点错误      = 16
定义 异常_对齐检查      = 17
定义 异常_机器检查      = 18
定义 异常_SIMD错误      = 19
定义 异常_虚拟化        = 20
定义 异常_控制保护      = 21

定义 中断_最大向量 = 256
定义 IRQ_起始向量 = 32

结构 中断统计 {
    总中断数,
    异常数,
    IRQ数,
    嵌套中断数,
    最大嵌套深度,
    panic数,
    虚假中断数,
    各向量计数,
}

定义 可变 全局_中断统计 = 空
定义 可变 当前嵌套深度 = 0
定义 可变 中断已禁用 = 假

函数 中断统计_初始化() {
    如果 (全局_中断统计 == 空) {
        全局_中断统计 = 中断统计 {}
        全局_中断统计.总中断数 = 0
        全局_中断统计.异常数 = 0
        全局_中断统计.IRQ数 = 0
        全局_中断统计.嵌套中断数 = 0
        全局_中断统计.最大嵌套深度 = 0
        全局_中断统计.panic数 = 0
        全局_中断统计.虚假中断数 = 0
        全局_中断统计.各向量计数 = 堆_分配(中断_最大向量 * 8)
        定义 可变 i = 0
        当 (i < 中断_最大向量) {
            内存_写64(全局_中断统计.各向量计数 + i * 8, 0)
            i = i + 1
        }
    }
}

// #DF(8), #TS(10), #NP(11), #SS(12), #GP(13), #PF(14), #AC(17), #CP(21)
函数 异常_有错误码(向量号) {
    如果 (向量号 == 8)  { 返回 真 }
    如果 (向量号 == 10) { 返回 真 }
    如果 (向量号 == 11) { 返回 真 }
    如果 (向量号 == 12) { 返回 真 }
    如果 (向量号 == 13) { 返回 真 }
    如果 (向量号 == 14) { 返回 真 }
    如果 (向量号 == 17) { 返回 真 }
    如果 (向量号 == 21) { 返回 真 }
    返回 假
}

函数 异常_名称(向量号) {
    如果 (向量号 == 0) { 返回 "#DE 除法错误" }
    如果 (向量号 == 1) { 返回 "#DB 调试" }
    如果 (向量号 == 2) { 返回 "NMI 不可屏蔽中断" }
    如果 (向量号 == 3) { 返回 "#BP 断点" }
    如果 (向量号 == 4) { 返回 "#OF 溢出" }
    如果 (向量号 == 5) { 返回 "#BR 越界" }
    如果 (向量号 == 6) { 返回 "#UD 无效操作码" }
    如果 (向量号 == 7) { 返回 "#NM 设备不可用" }
    如果 (向量号 == 8) { 返回 "#DF 双重故障" }
    如果 (向量号 == 10) { 返回 "#TS 无效TSS" }
    如果 (向量号 == 11) { 返回 "#NP 段不存在" }
    如果 (向量号 == 12) { 返回 "#SS 栈段故障" }
    如果 (向量号 == 13) { 返回 "#GP 一般保护故障" }
    如果 (向量号 == 14) { 返回 "#PF 页面错误" }
    如果 (向量号 == 16) { 返回 "#MF 浮点错误" }
    如果 (向量号 == 17) { 返回 "#AC 对齐检查" }
    如果 (向量号 == 18) { 返回 "#MC 机器检查" }
    如果 (向量号 == 19) { 返回 "#XM SIMD错误" }
    如果 (向量号 == 20) { 返回 "#VE 虚拟化异常" }
    如果 (向量号 == 21) { 返回 "#CP 控制保护" }
    返回 "未知异常"
}

函数 异常_是致命(向量号) {
    如果 (向量号 == 异常_双重故障) { 返回 真 }
    如果 (向量号 == 异常_机器检查) { 返回 真 }
    返回 假
}

函数 异常_可恢复(向量号) {
    如果 (向量号 == 异常_页面错误) { 返回 真 }
    如果 (向量号 == 异常_调试) { 返回 真 }
    如果 (向量号 == 异常_断点) { 返回 真 }
    如果 (向量号 == 异常_溢出) { 返回 真 }
    返回 假
}

// 通用中断分发入口

函数 中断_通用分发(帧指针) {
    中断统计_初始化()
    全局_中断统计.总中断数 = 全局_中断统计.总中断数 + 1

    定义 向量号 = 内存_读64(帧指针 + 帧_向量号)
    定义 错误码 = 内存_读64(帧指针 + 帧_错误码)

    // 更新每向量计数
    如果 (向量号 < 中断_最大向量) {
        定义 旧计数 = 内存_读64(全局_中断统计.各向量计数 + 向量号 * 8)
        内存_写64(全局_中断统计.各向量计数 + 向量号 * 8, 旧计数 + 1)
    }

    // 跟踪嵌套深度
    当前嵌套深度 = 当前嵌套深度 + 1
    如果 (当前嵌套深度 > 1) {
        全局_中断统计.嵌套中断数 = 全局_中断统计.嵌套中断数 + 1
    }
    如果 (当前嵌套深度 > 全局_中断统计.最大嵌套深度) {
        全局_中断统计.最大嵌套深度 = 当前嵌套深度
    }

    如果 (向量号 < 32) {
        // CPU异常
        全局_中断统计.异常数 = 全局_中断统计.异常数 + 1
        中断_处理异常(向量号, 错误码, 帧指针)
    } 否则 如果 (向量号 >= IRQ_起始向量 && 向量号 < IRQ_起始向量 + 16) {
        // 硬件IRQ
        全局_中断统计.IRQ数 = 全局_中断统计.IRQ数 + 1
        中断_处理IRQ(向量号 - IRQ_起始向量, 帧指针)
    } 否则 如果 (向量号 == 255) {
        // 虚假中断
        全局_中断统计.虚假中断数 = 全局_中断统计.虚假中断数 + 1
    } 否则 {
        // 软件中断或其他
        中断_处理软件(向量号, 帧指针)
    }

    当前嵌套深度 = 当前嵌套深度 - 1
}

函数 中断_处理异常(向量号, 错误码, 帧指针) {
    如果 (异常_是致命(向量号)) {
        中断_panic(向量号, 错误码, 帧指针)
        返回
    }

    如果 (向量号 == 异常_页面错误) {
        // 读取CR2获取故障地址
        定义 故障地址 = 读_CR2()
        异常_缺页处理(故障地址, 错误码, 帧指针)
        返回
    }

    如果 (向量号 == 异常_一般保护) {
        异常_GP处理(错误码, 帧指针)
        返回
    }

    如果 (向量号 == 异常_除法错误) {
        异常_除法处理(帧指针)
        返回
    }

    如果 (向量号 == 异常_无效操作码) {
        异常_UD处理(帧指针)
        返回
    }

    如果 (向量号 == 异常_断点) {
        异常_断点处理(帧指针)
        返回
    }

    如果 (向量号 == 异常_调试) {
        异常_调试处理(帧指针)
        返回
    }

    // 未特化处理的异常
    如果 (!异常_可恢复(向量号)) {
        中断_panic(向量号, 错误码, 帧指针)
    }
}

函数 中断_处理IRQ(irq号, 帧指针) {
    // 发送EOI到PIC/APIC
    如果 (irq号 >= 8) {
        // 从PIC EOI
        端口_写字节(0xA0, 0x20)
    }
    端口_写字节(0x20, 0x20)

    // 调用已注册的IRQ处理程序
    IRQ_分发(irq号)
}

函数 中断_处理软件(向量号, 帧指针) {
    如果 (向量号 == 0x80) {
        系统调用_入口(帧指针)
    } 否则 {
        打印("[中断] 软件中断: 向量" + 向量号)
    }
}

// 寄存器转储

函数 中断_转储寄存器(帧指针) {
    串口_打印("=== 寄存器转储 ===\n")
    串口_打印("RAX="); 串口_打印十六进制(内存_读64(帧指针 + 帧_RAX))
    串口_打印(" RBX="); 串口_打印十六进制(内存_读64(帧指针 + 帧_RBX))
    串口_打印(" RCX="); 串口_打印十六进制(内存_读64(帧指针 + 帧_RCX))
    串口_打印("\nRDX="); 串口_打印十六进制(内存_读64(帧指针 + 帧_RDX))
    串口_打印(" RSI="); 串口_打印十六进制(内存_读64(帧指针 + 帧_RSI))
    串口_打印(" RDI="); 串口_打印十六进制(内存_读64(帧指针 + 帧_RDI))
    串口_打印("\nRBP="); 串口_打印十六进制(内存_读64(帧指针 + 帧_RBP))
    串口_打印(" RSP="); 串口_打印十六进制(内存_读64(帧指针 + 帧_RSP))
    串口_打印(" RIP="); 串口_打印十六进制(内存_读64(帧指针 + 帧_RIP))
    串口_打印("\nR8 ="); 串口_打印十六进制(内存_读64(帧指针 + 帧_R8))
    串口_打印(" R9 ="); 串口_打印十六进制(内存_读64(帧指针 + 帧_R9))
    串口_打印(" R10="); 串口_打印十六进制(内存_读64(帧指针 + 帧_R10))
    串口_打印("\nR11="); 串口_打印十六进制(内存_读64(帧指针 + 帧_R11))
    串口_打印(" R12="); 串口_打印十六进制(内存_读64(帧指针 + 帧_R12))
    串口_打印(" R13="); 串口_打印十六进制(内存_读64(帧指针 + 帧_R13))
    串口_打印("\nR14="); 串口_打印十六进制(内存_读64(帧指针 + 帧_R14))
    串口_打印(" R15="); 串口_打印十六进制(内存_读64(帧指针 + 帧_R15))
    串口_打印("\nCS ="); 串口_打印十六进制(内存_读64(帧指针 + 帧_CS))
    串口_打印(" SS ="); 串口_打印十六进制(内存_读64(帧指针 + 帧_SS))
    串口_打印(" FLG="); 串口_打印十六进制(内存_读64(帧指针 + 帧_RFLAGS))
    串口_打印("\n")
}

函数 中断_转储栈(帧指针, 深度) {
    串口_打印("=== 栈转储 ===\n")
    定义 rsp = 内存_读64(帧指针 + 帧_RSP)
    定义 可变 i = 0
    当 (i < 深度) {
        串口_打印("[RSP+")
        串口_打印十六进制(i * 8)
        串口_打印("] = ")
        串口_打印十六进制(内存_读64(rsp + i * 8))
        串口_打印("\n")
        i = i + 1
    }
}

// Panic处理

函数 中断_panic(向量号, 错误码, 帧指针) {
    中断统计_初始化()
    全局_中断统计.panic数 = 全局_中断统计.panic数 + 1

    // 禁用中断
    汇编 { "cli" }
    中断已禁用 = 真

    串口_打印("\n!!! KERNEL PANIC !!!\n")
    串口_打印("异常: ")
    串口_打印(异常_名称(向量号))
    串口_打印("\n向量号: ")
    串口_打印十六进制(向量号)
    串口_打印("  错误码: ")
    串口_打印十六进制(错误码)
    串口_打印("\n")

    中断_转储寄存器(帧指针)
    中断_转储栈(帧指针, 8)

    // 停机
    串口_打印("系统已停止。\n")
    当 (真) {
        汇编 { "hlt" }
    }
}

// 通用寄存器保存/恢复宏 (汇编)

// 保存所有通用寄存器到栈
// 调用前栈上已有: [错误码, 向量号] (由存根压入)
函数 保存所有寄存器() {
    汇编 {
        "push rax"
        "push rbx"
        "push rcx"
        "push rdx"
        "push rsi"
        "push rdi"
        "push rbp"
        "push r8"
        "push r9"
        "push r10"
        "push r11"
        "push r12"
        "push r13"
        "push r14"
        "push r15"
    }
}

// 恢复所有通用寄存器
函数 恢复所有寄存器() {
    汇编 {
        "pop r15"
        "pop r14"
        "pop r13"
        "pop r12"
        "pop r11"
        "pop r10"
        "pop r9"
        "pop r8"
        "pop rbp"
        "pop rdi"
        "pop rsi"
        "pop rdx"
        "pop rcx"
        "pop rbx"
        "pop rax"
    }
}

// 中断存根生成: 有/无错误码

函数 中断_存根_无错误码(向量号) {
    汇编 {
        "push 0"        // 伪错误码对齐
    }
    汇编 { "push" }     // push 向量号
    保存所有寄存器()
    // RDI = 帧指针(栈顶)
    汇编 { "mov rdi, rsp" }
    中断_通用分发(0)    // 参数通过rdi传递
    恢复所有寄存器()
    汇编 {
        "add rsp, 16"   // 跳过向量号和伪错误码
        "iretq"
    }
}

函数 中断_存根_有错误码(向量号) {
    // CPU已压入错误码
    汇编 { "push" }     // push 向量号
    保存所有寄存器()
    汇编 { "mov rdi, rsp" }
    中断_通用分发(0)
    恢复所有寄存器()
    汇编 {
        "add rsp, 16"
        "iretq"
    }
}

// 辅助: 控制寄存器读取

函数 读_CR2() {
    定义 可变 值 = 0
    汇编 {
        "mov rax, cr2"
    }
    返回 值
}

函数 读_CR3() {
    定义 可变 值 = 0
    汇编 {
        "mov rax, cr3"
    }
    返回 值
}

函数 中断_打印统计() {
    中断统计_初始化()
    串口_打印("=== 中断统计 ===\n")
    串口_打印("总中断数: "); 串口_打印十进制(全局_中断统计.总中断数); 串口_打印("\n")
    串口_打印("异常数: "); 串口_打印十进制(全局_中断统计.异常数); 串口_打印("\n")
    串口_打印("IRQ数: "); 串口_打印十进制(全局_中断统计.IRQ数); 串口_打印("\n")
    串口_打印("嵌套中断: "); 串口_打印十进制(全局_中断统计.嵌套中断数); 串口_打印("\n")
    串口_打印("最大嵌套: "); 串口_打印十进制(全局_中断统计.最大嵌套深度); 串口_打印("\n")
    串口_打印("panic数: "); 串口_打印十进制(全局_中断统计.panic数); 串口_打印("\n")
    串口_打印("虚假中断: "); 串口_打印十进制(全局_中断统计.虚假中断数); 串口_打印("\n")
}

// NEHT — Nova Exception Handling Theory
// 公理1(帧完整): 保存/恢复密对的寄存器集保证不丢失任何执行状态
// 公理2(错误码分离): 有错误码异常与无错误码异常用对齐伪码统一栈布局
// 公理3(原子分发): 中断分发在关中断下执行, 保证不重入
// 定理1(嵌套安全): 嵌套中断不破坏栈布局, 各层独立恢复
// 定理2(异常可识别): 向量号唯一标识异常类型, 错误码提供精确诊断

定义 可变 向量计数器 = []
定义 可变 向量计数_已初 = 假

函数 向量计数_初始化() {
    如果 (向量计数_已初) { 返回 }
    定义 可变 i = 0
    当 (i < 256) { 追加(向量计数器, 0); i = i + 1 }
    向量计数_已初 = 真
}

函数 向量计数_记录(向量号) {
    向量计数_初始化()
    如果 (向量号 >= 0 && 向量号 < 256) {
        向量计数器[向量号] = 向量计数器[向量号] + 1
    }
}

函数 向量计数_获取(向量号) {
    向量计数_初始化()
    如果 (向量号 >= 0 && 向量号 < 256) {
        返回 向量计数器[向量号]
    }
    返回 0
}

// 打印活跃向量(只打印触发过的)
函数 中断_打印向量统计() {
    向量计数_初始化()
    串口_打印("=== 向量触发统计 ===\n")
    定义 可变 i = 0
    当 (i < 256) {
        如果 (向量计数器[i] > 0) {
            串口_打印("向量"); 串口_打印十进制(i)
            串口_打印(": "); 串口_打印十进制(向量计数器[i])
            串口_打印("\n")
        }
        i = i + 1
    }
}

// 重置统计
函数 中断_重置统计() {
    中断统计_初始化()
    全局_中断统计.总中断数 = 0
    全局_中断统计.异常数 = 0
    全局_中断统计.IRQ数 = 0
    全局_中断统计.嵌套中断数 = 0
    全局_中断统计.最大嵌套深度 = 0
    全局_中断统计.panic数 = 0
    全局_中断统计.虚假中断数 = 0
    向量计数_已初 = 假
    向量计数器 = []
}

定义 可变 AI_异常有错误_风暴阈值 = 10000
定义 可变 AI_异常有错误_预测IRQ = 0

函数 AI_异常有错误_风暴检测(触发频率) {
    如果 (触发频率 > AI_异常有错误_风暴阈值) {
        AI_异常有错误_风暴阈值 = AI_异常有错误_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_异常有错误_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

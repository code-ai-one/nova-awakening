导入("../../标准库/基础.nova")
导入("../../编译器/标记常量.nova")

// Nova 原生语句系统 — 各种语句的分类、属性、控制流分析
// 职责：语句分类、关键字映射、死代码检测、作用域栈管理
// 层级：第1层基础设施

// 语句类型ID
定义 语句_变量    = 1   // 令/定义 可变
定义 语句_函数   = 2   // 函数 定义 语句_返回 = 3   // 返回
定义 语句_如果     = 4   // 若/否
定义 语句_当  = 5   // 当
定义 语句_每个 = 6  // 每
定义 语句_匹配  = 7   // 辨
定义 语句_中断  = 8   // 止
定义 语句_继续   = 9   // 续
定义 语句_导入 = 10  // 入
定义 语句_结构 = 11  // 结构 定义 语句_尝试    = 12  // 试/得
定义 语句_抛出  = 13  // 抛
定义 语句_表达式   = 14  // 表达式语句
定义 语句_块  = 15  // { } 块
定义 语句_空  = 16  // 空语句

定义 可变 _语句_错误数 = 0

// 语句属性查询

函数 是声明语句(t) {
    如果 (t == 语句_变量) { 返回 1 }
    如果 (t == 语句_函数) { 返回 1 }
    如果 (t == 语句_结构) { 返回 1 }
    如果 (t == 语句_导入) { 返回 1 }
    返回 0
}

函数 是控制流(t) {
    如果 (t == 语句_如果) { 返回 1 }
    如果 (t == 语句_当) { 返回 1 }
    如果 (t == 语句_每个) { 返回 1 }
    如果 (t == 语句_匹配) { 返回 1 }
    如果 (t == 语句_尝试) { 返回 1 }
    返回 0
}

函数 是跳转语句(t) {
    如果 (t == 语句_返回) { 返回 1 }
    如果 (t == 语句_中断) { 返回 1 }
    如果 (t == 语句_继续) { 返回 1 }
    如果 (t == 语句_抛出) { 返回 1 }
    返回 0
}

函数 需要循环上下文(t) {
    如果 (t == 语句_中断) { 返回 1 }
    如果 (t == 语句_继续) { 返回 1 }
    返回 0
}

函数 需要函数上下文(t) {
    如果 (t == 语句_返回) { 返回 1 }
    返回 0
}

// 语句信息: [类型, 行号, 子节点数, 需要分号]
函数 语句信息(类型) {
    如果 (类型 == 语句_变量) { 返回 [类型, 0, 1, 0] }
    如果 (类型 == 语句_函数) { 返回 [类型, 0, 2, 0] }
    如果 (类型 == 语句_返回) { 返回 [类型, 0, 1, 0] }
    如果 (类型 == 语句_如果) { 返回 [类型, 0, 3, 0] }
    如果 (类型 == 语句_当) { 返回 [类型, 0, 2, 0] }
    如果 (类型 == 语句_每个) { 返回 [类型, 0, 3, 0] }
    如果 (类型 == 语句_匹配) { 返回 [类型, 0, 2, 0] }
    如果 (类型 == 语句_中断) { 返回 [类型, 0, 0] }
    如果 (类型 == 语句_继续) { 返回 [类型, 0, 0] }
    如果 (类型 == 语句_导入) { 返回 [类型, 0, 1, 0] }
    如果 (类型 == 语句_结构) { 返回 [类型, 0, 1, 0] }
    如果 (类型 == 语句_尝试) { 返回 [类型, 0, 3, 0] }
    如果 (类型 == 语句_抛出) { 返回 [类型, 0, 1, 0] }
    如果 (类型 == 语句_表达式) { 返回 [类型, 0, 1, 0] }
    如果 (类型 == 语句_块) { 返回 [类型, 0, 0] }
    返回 [语句_空, 0, 0]
}

// 关键字→语句类型映射
// KW_IDs: 令=110, 可变=111, 法=112, 回=113, 若=114, 否=115
//         当=116, 每=117, 入=118, 型=119, 建=120, 辨=121
//         默认=122, 止=123, 续=124, 试=128, 得=129, 抛=130
函数 关键字到语句(kw) {
    如果 (kw == 标记_定义) { 返回 语句_变量 }
    如果 (kw == 标记_函数) { 返回 语句_函数 }
    如果 (kw == 标记_返回) { 返回 语句_返回 }
    如果 (kw == 标记_如果) { 返回 语句_如果 }
    如果 (kw == 标记_当) { 返回 语句_当 }
    如果 (kw == 标记_循环) { 返回 语句_每个 }
    如果 (kw == 标记_导入) { 返回 语句_导入 }
    如果 (kw == 标记_结构) { 返回 语句_结构 }
    如果 (kw == 标记_匹配) { 返回 语句_匹配 }
    如果 (kw == 标记_中断) { 返回 语句_中断 }
    如果 (kw == 标记_继续) { 返回 语句_继续 }
    如果 (kw == 标记_尝试) { 返回 语句_尝试 }
    如果 (kw == 标记_抛出) { 返回 语句_抛出 }
    返回 0
}

// 死代码检测
// 跳转语句后的代码是死代码
函数 是终结语句(t) {
    如果 (t == 语句_返回) { 返回 1 }
    如果 (t == 语句_中断) { 返回 1 }
    如果 (t == 语句_继续) { 返回 1 }
    如果 (t == 语句_抛出) { 返回 1 }
    返回 0
}

// 变量声明分析
// 回: [名称位, 是否可变, 有初值]
函数 变量分析(有可变标记, 有赋值) {
    返回 [1, 有可变标记, 有赋值]
}

// 语句类型检查

函数 是赋值语句(类型) {
    返回 类型 == 语句_变量 或 类型 == 语句_表达式
}

函数 是循环语句(类型) {
    返回 类型 == 语句_当 或 类型 == 语句_每个
}

函数 是条件语句(类型) {
    返回 类型 == 语句_如果 或 类型 == 语句_匹配
}

函数 是函数定义(类型) {
    返回 类型 == 语句_函数
}

函数 是跳转(类型) {
    返回 是跳转语句(类型)
}

// 语句块分析

函数 语句块_创建() {
    // [语句列表, 父块索引, 深度, 变量列表]
    返回 [[], -1, 0, []]
}

函数 语句块_添加语句(块, 语句类型) {
    追加(块[0], 语句类型)
}

函数 语句块_语句数(块) { 返回 计数(块[0]) }

函数 语句块_统计类型(块) {
    定义 可变 赋值 = 0
    定义 可变 循环 = 0
    定义 可变 条件 = 0
    定义 可变 跳转 = 0
    定义 可变 其他 = 0
    定义 可变 i = 0
    当 (i < 计数(块[0])) {
        定义 t = 块[0][i]
        如果 (是赋值语句(t)) { 赋值 = 赋值 + 1 }
        否则 如果 (是循环语句(t)) { 循环 = 循环 + 1 }
        否则 如果 (是条件语句(t)) { 条件 = 条件 + 1 }
        否则 如果 (是跳转(t)) { 跳转 = 跳转 + 1 }
        否则 { 其他 = 其他 + 1 }
        i = i + 1
    }
    返回 [赋值, 循环, 条件, 跳转, 其他]
}

// 控制流分析

函数 控制流_有返回(语句列表) {
    定义 可变 i = 0
    当 (i < 计数(语句列表)) {
        如果 (语句列表[i] == 语句_返回) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 控制流_有中断(语句列表) {
    定义 可变 i = 0
    当 (i < 计数(语句列表)) {
        如果 (语句列表[i] == 语句_中断 或 语句列表[i] == 语句_继续) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 控制流_不可达检测(语句列表) {
    定义 可变 不可达 = []
    定义 可变 已终止 = 假
    定义 可变 i = 0
    当 (i < 计数(语句列表)) {
        如果 (已终止) { 追加(不可达, i) }
        如果 (是跳转(语句列表[i])) { 已终止 = 真 }
        i = i + 1
    }
    返回 不可达
}

// 作用域管理

定义 可变 _作用域栈 = []

函数 语句_作用域_进入() {
    追加(_作用域栈, [])
}

函数 语句_作用域_退出() {
    定义 可变 新栈 = []
    如果 (计数(_作用域栈) > 0) {
        定义 n = 计数(_作用域栈)
        定义 可变 i = 0
        当 (i < n - 1) { 追加(新栈, _作用域栈[i])  i = i + 1 }
        _作用域栈 = 新栈
    }
}

函数 语句_作用域_添加变量(名) {
    如果 (计数(_作用域栈) > 0) {
        追加(_作用域栈[计数(_作用域栈) - 1], 名)
    }
}

函数 作用域_查找(名) {
    定义 可变 i = 计数(_作用域栈) - 1
    当 (i >= 0) {
        定义 可变 j = 0
        当 (j < 计数(_作用域栈[i])) {
            如果 (_作用域栈[i][j] == 名) { 返回 真 }
            j = j + 1
        }
        i = i - 1
    }
    返回 假
}

函数 语句_作用域_深度() { 返回 计数(_作用域栈) }

定义 可变 _语句_总数 = 0

函数 语句_记录() { _语句_总数 = _语句_总数 + 1 }
函数 语句_记录错误() { _语句_错误数 = _语句_错误数 + 1 }

// Nova标准库 — 模板引擎
// Mustache 风格模板渲染: 变量替换、条件、永、分块
// 支持过滤器管道、模板继承、自定义标签

导入("../../基础.nova")

// 模板节点类型
定义 节点_文本 = 0
定义 节点_变量 = 1
定义 节点_条件 = 2
定义 节点_循环 = 3
定义 节点_分块 = 4
定义 节点_注释 = 5
定义 节点_包含 = 6

// 节点: [类型, 数据, 子节点列表, 过滤器列表]

函数 模板节点(类型, 数据) { 返回 [类型, 数据, [], []]
}

// 模板编译器
// 将模板文本编译为节点树

函数 模板_扫描标签内容(模板文本, 起始, n) { 定义 可变 i = 起始
 当 (i < n 且 字符串等于(子串(模板文本, i, 1), " ")) { i = i + 1 }
 定义 可变 内容 = ""
 当 (i < n) { 如果 (i + 1 < n 且 字符串等于(子串(模板文本, i, 1), 字符(125)) 且 字符串等于(子串(模板文本, i + 1, 1), 字符(125))) {
 i = i + 2
 止
 }
 内容 = 字符串拼接(内容, 子串(模板文本, i, 1))
 i = i + 1
 }
 返回 [模板_去空白(内容), i]
}

函数 模板_编译(模板文本) { 定义 可变 节点列表 = []
 定义 n = 计数(模板文本)
 定义 可变 i = 0
 定义 可变 文本缓冲 = ""

 当 (i < n) {
 // 检查标签开始 {{
 如果 (i + 1 < n 且 字符串等于(子串(模板文本, i, 1), 字符(123)) 且 字符串等于(子串(模板文本, i + 1, 1), 字符(123))) { 如果 (计数(文本缓冲) > 0) { 追加(节点列表, 模板节点(节点_文本, 文本缓冲)) 文本缓冲 = "" }
 i = i + 2
 定义 扫描结果 = 模板_扫描标签内容(模板文本, i, n)
 i = 扫描结果[1]
 模板_解析标签(扫描结果[0], 节点列表)
 }
 否则 {
 文本缓冲 = 字符串拼接(文本缓冲, 子串(模板文本, i, 1))
 i = i + 1
 }
 }
 如果 (计数(文本缓冲) > 0) { 追加(节点列表, 模板节点(节点_文本, 文本缓冲)) }
 返回 节点列表
}

函数 模板_解析标签(标签内容, 节点列表) {
    如果 (计数(标签内容) == 0) { 返回 空
}
 定义 首字 = 子串(标签内容, 0, 1)
 如果 (字符串等于(首字, "#")) { 定义 名称 = 模板_去空白(子串(标签内容, 1, 计数(标签内容) - 1))
 如果 (模板_开头是(名称, "each ")) { 定义 循环变量 = 模板_去空白(子串(名称, 5, 计数(名称) - 5))
 追加(节点列表, 模板节点(节点_循环, 循环变量))
 } 否则 {
 追加(节点列表, 模板节点(节点_条件, 名称))
 }
 } 否则 如果 (字符串等于(首字, "/")) { 定义 结束名 = 模板_去空白(子串(标签内容, 1, 计数(标签内容) - 1))
 追加(节点列表, 模板节点(节点_分块, 字符串拼接("/", 结束名)))
 } 否则 如果 (字符串等于(首字, "!")) {
 追加(节点列表, 模板节点(节点_注释, 子串(标签内容, 1, 计数(标签内容) - 1)))
 } 否则 如果 (字符串等于(首字, ">")) { 定义 部分名 = 模板_去空白(子串(标签内容, 1, 计数(标签内容) - 1))
 追加(节点列表, 模板节点(节点_包含, 部分名))
 } 否则 {
 // 变量: {{name}} 或 {{name | filter}}
 定义 可变 变量名 = 标签内容
 定义 可变 过滤器 = []
 // 检查管道过滤器
 定义 管道位 = 模板_查找字符(标签内容, "|")
 如果 (管道位 >= 0) {
 变量名 = 模板_去空白(子串(标签内容, 0, 管道位))
 定义 过滤器文本 = 子串(标签内容, 管道位 + 1, 计数(标签内容) - 管道位 - 1)
 过滤器 = 模板_分割过滤器(过滤器文本)
 }
 定义 变量节点 = 模板节点(节点_变量, 变量名)
 变量节点[3] = 过滤器
 追加(节点列表, 变量节点)
 }
}

函数 模板_构建树(平坦列表) { 定义 可变 根 = []
    定义 可变 新栈 = []
 定义 可变 栈 = [根]
 定义 可变 i = 0
 当 (i < 计数(平坦列表)) { 定义 节点 = 平坦列表[i]
 如果 (节点[0] == 节点_条件 或 节点[0] == 节点_循环) {
 如果 (计数(栈) > 0) {
 追加(栈[计数(栈) - 1], 节点)
 }
 追加(栈, 节点[2])
 } 否则 如果 (节点[0] == 节点_分块) {
 // 弹出栈
如果 (计数(栈) > 1) {
 定义 可变 j = 0
 当 (j < 计数(栈) - 1) { 追加(新栈, 栈[j]) j = j + 1 }
 栈 = 新栈
 }
 } 否则 如果 (节点[0] != 节点_注释) {
 如果 (计数(栈) > 0) {
 追加(栈[计数(栈) - 1], 节点)
 }
 }
 i = i + 1
 }
 返回 根
}

// 模板渲染
// 上下文: 字典 { "name": "value", "items": [...], ... }

函数 模板_渲染(节点树, 上下文, 过滤器表) { 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 计数(节点树)) { 定义 节点 = 节点树[i]
 如果 (节点[0] == 节点_文本) {
 结果 = 字符串拼接(结果, 节点[1])
 }
 如果 (节点[0] == 节点_变量) { 定义 可变 值 = 模板_解析变量(上下文, 节点[1])
 // 应用过滤器
 定义 可变 f = 0
 当 (f < 计数(节点[3])) { 定义 过滤器名 = 节点[3][f]
 定义 过滤器函数 = 字典取(过滤器表, 过滤器名)
 如果 (过滤器函数 != 空) {
 值 = 过滤器函数(值)
 }
 f = f + 1
 }
 如果 (值 != 空) {
 结果 = 字符串拼接(结果, 值)
 }
 }
 如果 (节点[0] == 节点_条件) { 定义 可变 条件值 = 模板_解析变量(上下文, 节点[1])
 定义 可变 真值 = 假
 如果 (条件值 != 空 且 条件值 != 假 且 条件值 != 0) {
 真值 = 真
 }
 // 检查取反 (!)
 如果 (计数(节点[1]) > 0 且 字符串等于(子串(节点[1], 0, 1), "!")) { 定义 实际名 = 子串(节点[1], 1, 计数(节点[1]) - 1)
 条件值 = 模板_解析变量(上下文, 实际名)
 真值 = 条件值 == 空 或 条件值 == 假 或 条件值 == 0
 }
 如果 (真值) {
 结果 = 字符串拼接(结果, 模板_渲染(节点[2], 上下文, 过滤器表))
 }
 }
 如果 (节点[0] == 节点_循环) { 定义 列表 = 模板_解析变量(上下文, 节点[1])
 如果 (列表 != 空) { 定义 可变 j = 0
 当 (j < 计数(列表)) {
 // 创建子上下文, 添加循环变量
 定义 子上下文 = 模板_克隆上下文(上下文)
 字典设(子上下文, "item", 列表[j])
 字典设(子上下文, "index", j)
 字典设(子上下文, "first", j == 0)
 字典设(子上下文, "last", j == 计数(列表) - 1)
 结果 = 字符串拼接(结果, 模板_渲染(节点[2], 子上下文, 过滤器表))
 j = j + 1
 }
 }
 }
 如果 (节点[0] == 节点_包含) {
 // 包含需要外部模板注册表
 定义 部分模板 = 字典取(上下文, 字符串拼接("__偏应用_", 节点[1]))
 如果 (部分模板 != 空) {
 结果 = 字符串拼接(结果, 模板_渲染(部分模板, 上下文, 过滤器表))
 }
 }
 i = i + 1
 }
 返回 结果
}

// 变量解析 (支持点号路径: a.b.c)
函数 模板_解析变量(上下文, 路径) { 定义 可变 当前 = 上下文
 定义 n = 计数(路径)
 定义 可变 段 = ""
 定义 可变 i = 0
 当 (i <= n) { 定义 可变 c = ""
 如果 (i < n) { c = 子串(路径, i, 1) }
 如果 (i == n 或 字符串等于(c, ".")) { 如果 (计数(段) > 0) {
 当前 = 字典取(当前, 段)
 如果 (当前 == 空) { 返回 空 }
 }
 段 = ""
 } 否则 {
 段 = 字符串拼接(段, c)
 }
 i = i + 1
 }
 返回 当前
}

// 内置过滤器
函数 模板_过滤_大写(值) { 定义 n = 计数(值)
 定义 可变 r = ""
 定义 可变 i = 0
 当 (i < n) { 定义 c = 编码(子串(值, i, 1))
 如果 (c >= 字符_小写a 且 c <= 字符_小写z) {
 r = 字符串拼接(r, 子串("ABCDEFGHIJKLMNOPQRSTUVWXYZ", c - 97, 1))
 } 否则 { r = 字符串拼接(r, 子串(值, i, 1)) }
 i = i + 1
 }
 返回 r
}

函数 模板_过滤_小写(值) { 定义 n = 计数(值)
 定义 可变 r = ""
 定义 可变 i = 0
 当 (i < n) { 定义 c = 编码(子串(值, i, 1))
 如果 (c >= 字符_大写A 且 c <= 字符_大写Z) {
 r = 字符串拼接(r, 子串("abcdefghijklmnopqrstuvwxyz", c - 65, 1))
 } 否则 { r = 字符串拼接(r, 子串(值, i, 1)) }
 i = i + 1
 }
 返回 r
}

函数 模板_过滤_去空(值) { 返回 模板_去空白(值)
}

函数 模板_过滤_转义(值) { 定义 n = 计数(值)
 定义 可变 r = ""
 定义 可变 i = 0
 当 (i < n) { 定义 c = 子串(值, i, 1)
 如果 (字符串等于(c, "<")) { r = 字符串拼接(r, "&lt;") }
 否则 如果 (字符串等于(c, ">")) { r = 字符串拼接(r, "&gt;") }
 否则 如果 (字符串等于(c, "&")) { r = 字符串拼接(r, "&amp;") }
 否则 如果 (字符串等于(c, "\"")) { r = 字符串拼接(r, "&quot ") }
 否则 { r = 字符串拼接(r, c) }
 i = i + 1
 }
 返回 r
}

函数 模板_创建过滤器表() { 定义 表 = 字典()
 字典设(表, "upper", 模板_过滤_大写)
 字典设(表, "lower", 模板_过滤_小写)
 字典设(表, "trim", 模板_过滤_去空)
 字典设(表, "escape", 模板_过滤_转义)
 返回 表
}

// 便捷 API

函数 模板_快速渲染(模板文本, 上下文) { 定义 节点树 = 模板_编译(模板文本)
 定义 过滤器表 = 模板_创建过滤器表()
 返回 模板_渲染(节点树, 上下文, 过滤器表)
}

// 内部工具
函数 模板_去空白(s) { 定义 n = 计数(s)
 定义 可变 开始 = 0
 当 (开始 < n 且 (字符串等于(子串(s, 开始, 1), " ") 或 字符串等于(子串(s, 开始, 1), "\t"))) {
 开始 = 开始 + 1
 }
 定义 可变 结束 = n
 当 (结束 > 开始 且 (字符串等于(子串(s, 结束 - 1, 1), " ") 或 字符串等于(子串(s, 结束 - 1, 1), "\t"))) {
 结束 = 结束 - 1
 }
 如果 (开始 >= 结束) { 返回 "" }
 返回 子串(s, 开始, 结束 - 开始)
}

函数 模板_查找字符(s, 目标) { 定义 n = 计数(s)
 定义 可变 i = 0
 当 (i < n) { 如果 (字符串等于(子串(s, i, 1), 目标)) { 返回 i }
 i = i + 1
 }
 返回 -1
}

函数 模板_开头是(s, 前缀) {
    如果 (计数(s) < 计数(前缀)) { 返回 假
}
 返回 字符串等于(子串(s, 0, 计数(前缀)), 前缀)
}

函数 模板_分割过滤器(文本) { 定义 n = 计数(文本)
 定义 可变 结果 = []
 定义 可变 当前 = ""
 定义 可变 i = 0
 当 (i < n) { 定义 c = 子串(文本, i, 1)
 如果 (字符串等于(c, "|")) { 定义 过滤名 = 模板_去空白(当前)
 如果 (计数(过滤名) > 0) { 追加(结果, 过滤名) }
 当前 = ""
 } 否则 {
 当前 = 字符串拼接(当前, c)
 }
 i = i + 1
 }
 定义 最后 = 模板_去空白(当前)
 如果 (计数(最后) > 0) { 追加(结果, 最后) }
 返回 结果
}

函数 模板_克隆上下文(上下文) {
 // 浅拷贝字典
 返回 上下文
}

// 过滤器系统

函数 模板_过滤_截断(文本, 最大长度) {
    如果 (计数(文本) <= 最大长度) { 返回 文本
}
 返回 字符串拼接(子串(文本, 0, 最大长度), "...")
}

函数 模板_过滤_重复(文本, 次数) { 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 次数) { 结果 = 字符串拼接(结果, 文本) i = i + 1 }
 返回 结果
}

函数 模板_过滤_反转(文本) { 定义 可变 结果 = ""
 定义 可变 i = 计数(文本) - 1
 当 (i >= 0) { 结果 = 字符串拼接(结果, 字符(字符码(文本, i))) i = i - 1 }
 返回 结果
}

// 条件和循环

函数 模板_条件渲染(条件, 真值, 假值) {
    如果 (条件) { 返回 真值
}
 返回 假值
}

函数 模板_循环渲染(列表, 模板文本, _变量名) { 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 计数(列表)) { 定义 可变 行 = 模板文本
 // 简单替换变量名
 结果 = 字符串拼接(结果, 行)
 i = i + 1
 }
 返回 结果
}

函数 模板_默认值(值, 默认) {
    如果 (值 == 空) { 返回 默认
}
 如果 (值 == "") { 返回 默认 }
 返回 值
}

// HTML转义

函数 模板_HTML转义(文本) { 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 计数(文本)) { 定义 c = 字符码(文本, i)
 如果 (c == 字符_小于号) { 结果 = 字符串拼接(结果, "&lt;") }
 否则 如果 (c == 字符_大于号) { 结果 = 字符串拼接(结果, "&gt;") }
 否则 如果 (c == 38) { 结果 = 字符串拼接(结果, "&amp;") }
 否则 如果 (c == 字符_双引号) { 结果 = 字符串拼接(结果, "&quot;") }
 否则 { 结果 = 字符串拼接(结果, 字符(c)) }
 i = i + 1
 }
 返回 结果
}

定义 可变 _模板_渲染次数 = 0
定义 可变 _模板_变量替换数 = 0
定义 可变 _模板_错误数 = 0

函数 模板_记录渲染() { _模板_渲染次数 = _模板_渲染次数 + 1 }
函数 模板_记录替换() { _模板_变量替换数 = _模板_变量替换数 + 1 }
函数 模板_记录错误() { _模板_错误数 = _模板_错误数 + 1 }

函数 模板_质量评估() {
    如果 (_模板_错误数 > _模板_渲染次数 / 5) { 返回 "模板错误率高(检查变量名)"
}
 如果 (_模板_渲染次数 > 10000) { 返回 "高频渲染(考虑缓存)" }
 返回 "模板使用正常"
}

函数 模板_重置() { _模板_渲染次数 = 0 _模板_变量替换数 = 0 _模板_错误数 = 0 }

// 模板缓存 (O(1)字典)

定义 可变 _模板缓存字典 = 字典()
定义 可变 _模板缓存数 = 0

函数 模板_缓存_设置(名称, 编译后) {
 定义 已有 = 字典取(_模板缓存字典, 名称)
 如果 (已有 == 空) { _模板缓存数 = _模板缓存数 + 1 }
 字典设(_模板缓存字典, 名称, 编译后)
}

函数 模板_缓存_获取(名称) {
 返回 字典取(_模板缓存字典, 名称)
}

函数 模板_缓存_清空() { _模板缓存字典 = 字典() _模板缓存数 = 0 }

函数 模板_缓存_大小() { 返回 _模板缓存数 }

函数 模板_是否健康() { 返回 _模板_错误数 == 0 }
函数 模板_总操作数() { 返回 _模板_渲染次数 + _模板_变量替换数 }

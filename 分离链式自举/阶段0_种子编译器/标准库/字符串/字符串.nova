
导入("../基础.nova")
导入("../../运行时/字典引擎/字典引擎.nova")

函数 字符串_内部_匹配(文本, 起始, 目标) {
    定义 目标长度 = 计数(目标)
    如果 (起始 < 0) {
        返回 假
    }
    如果 (起始 + 目标长度 > 计数(文本)) {
        返回 假
    }
    定义 可变 i = 0
    当 (i < 目标长度) {
        如果 (字符串相等(子串(文本, 起始 + i, 1), 子串(目标, i, 1)) == 假) {
            返回 假
        }
        i = i + 1
    }
    返回 真
}

函数 字符串_内部_是数字码(码) {
    如果 (码 >= 字符_零) {
        如果 (码 <= 字符_九) {
            返回 真
        }
    }
    返回 假
}

函数 字符串_内部_是字母码(码) {
    如果 (码 >= 字符_大写A) {
        如果 (码 <= 字符_大写Z) {
            返回 真
        }
    }
    如果 (码 >= 字符_小写a) {
        如果 (码 <= 字符_小写z) {
            返回 真
        }
    }
    返回 假
}

函数 字符串_查找(文本, 目标) {
    定义 目标长度 = 计数(目标)
    定义 源长 = 计数(文本)
    如果 (目标长度 == 0) {
        返回 0
    }
    如果 (目标长度 > 源长) {
        返回 -1
    }
    定义 可变 i = 0
    当 (i <= 源长 - 目标长度) {
        如果 (字符串_内部_匹配(文本, i, 目标)) {
            返回 i
        }
        i = i + 1
    }
    返回 -1
}

函数 字符串_查找从(文本, 目标, 起始) {
    定义 目标长度 = 计数(目标)
    定义 源长 = 计数(文本)
    如果 (起始 < 0) {
        返回 -1
    }
    如果 (目标长度 == 0) {
        返回 起始
    }
    如果 (起始 > 源长 - 目标长度) {
        返回 -1
    }
    定义 可变 i = 起始
    当 (i <= 源长 - 目标长度) {
        如果 (字符串_内部_匹配(文本, i, 目标)) {
            返回 i
        }
        i = i + 1
    }
    返回 -1
}

函数 字符串_最后查找(文本, 目标) {
    定义 目标长度 = 计数(目标)
    定义 源长 = 计数(文本)
    如果 (目标长度 == 0) {
        返回 源长
    }
    如果 (目标长度 > 源长) {
        返回 -1
    }
    定义 可变 i = 源长 - 目标长度
    当 (i >= 0) {
        如果 (字符串_内部_匹配(文本, i, 目标)) {
            返回 i
        }
        i = i - 1
    }
    返回 -1
}

函数 字符串_包含(文本, 目标) {
    如果 (字符串_查找(文本, 目标) >= 0) {
        返回 真
    }
    返回 假
}

函数 字符串_计数出现(文本, 目标) {
    定义 目标长度 = 计数(目标)
    如果 (目标长度 == 0) {
        返回 0
    }
    定义 可变 次数 = 0
    定义 可变 i = 0
    定义 可变 上限 = 计数(文本) - 目标长度
    当 (i <= 上限) {
        如果 (字符串_内部_匹配(文本, i, 目标)) {
            次数 = 次数 + 1
            i = i + 目标长度
        } 否则 {
            i = i + 1
        }
    }
    返回 次数
}

函数 字符串_替换(文本, 旧, 新值) {
    定义 olen = 计数(旧)
    如果 (olen == 0) {
        返回 文本
    }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        如果 (字符串_内部_匹配(文本, i, 旧)) {
            结果 = 结果 + 新值
            i = i + olen
        } 否则 {
            结果 = 结果 + 子串(文本, i, 1)
            i = i + 1
        }
    }
    返回 结果
}

函数 字符串_替换首次(文本, 旧, 新值) {
    定义 位置 = 字符串_查找(文本, 旧)
    如果 (位置 < 0) {
        返回 文本
    }
    定义 前 = 子串(文本, 0, 位置)
    定义 后起始 = 位置 + 计数(旧)
    定义 后长度 = 计数(文本) - 后起始
    定义 后 = 子串(文本, 后起始, 后长度)
    返回 前 + 新值 + 后
}

函数 字符串_分割(文本, 分隔符) {
    定义 可变 结果 = []
    定义 dlen = 计数(分隔符)
    如果 (dlen == 0) {
        定义 可变 k = 0
        当 (k < 计数(文本)) {
            追加(结果, 子串(文本, k, 1))
            k = k + 1
        }
        返回 结果
    }
    定义 可变 起始 = 0
    定义 可变 i = 0
    定义 可变 上限 = 计数(文本) - dlen
    当 (i <= 上限) {
        如果 (字符串_内部_匹配(文本, i, 分隔符)) {
            追加(结果, 子串(文本, 起始, i - 起始))
            i = i + dlen
            起始 = i
        } 否则 {
            i = i + 1
        }
    }
    追加(结果, 子串(文本, 起始, 计数(文本) - 起始))
    返回 结果
}

函数 字符串_连接列表(列表, 分隔符) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (i != 0) {
            结果 = 结果 + 分隔符
        }
        结果 = 结果 + 列表[i]
        i = i + 1
    }
    返回 结果
}

函数 字符串_转大写(文本) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        定义 码 = 字符码(文本, i)
        如果 (码 >= 字符_小写a) {
            如果 (码 <= 字符_小写z) {
                结果 = 结果 + 字符(码 - 32)
            } 否则 {
                结果 = 结果 + 子串(文本, i, 1)
            }
        } 否则 {
            结果 = 结果 + 子串(文本, i, 1)
        }
        i = i + 1
    }
    返回 结果
}

函数 字符串_转小写(文本) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        定义 码 = 字符码(文本, i)
        如果 (码 >= 字符_大写A) {
            如果 (码 <= 字符_大写Z) {
                结果 = 结果 + 字符(码 + 32)
            } 否则 {
                结果 = 结果 + 子串(文本, i, 1)
            }
        } 否则 {
            结果 = 结果 + 子串(文本, i, 1)
        }
        i = i + 1
    }
    返回 结果
}

函数 字符串_首字母大写(文本) {
    如果 (计数(文本) == 0) {
        返回 ""
    }
    定义 可变 首 = 子串(文本, 0, 1)
    定义 首码 = 字符码(文本, 0)
    如果 (首码 >= 97) {
        如果 (首码 <= 122) {
            首 = 字符(首码 - 32)
        }
    }
    如果 (计数(文本) == 1) {
        返回 首
    }
    返回 首 + 字符串_转小写(子串(文本, 1, 计数(文本) - 1))
}

函数 是空白字符(码) {
    如果 (码 == 字符_空格) {
        返回 真
    }
    如果 (码 == 字符_制表) {
        返回 真
    }
    如果 (码 == 字符_换行) {
        返回 真
    }
    如果 (码 == 字符_回车) {
        返回 真
    }
    返回 假
}

函数 字符串_左trim(文本) {
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        如果 (是空白字符(字符码(文本, i))) {
            i = i + 1
        } 否则 {
            返回 子串(文本, i, 计数(文本) - i)
        }
    }
    返回 ""
}

函数 字符串_右trim(文本) {
    定义 可变 e = 计数(文本)
    当 (e > 0) {
        如果 (是空白字符(字符码(文本, e - 1))) {
            e = e - 1
        } 否则 {
            返回 子串(文本, 0, e)
        }
    }
    返回 ""
}

函数 字符串_trim(文本) {
    返回 字符串_右trim(字符串_左trim(文本))
}

函数 字符串_以开头(文本, 前缀) {
    如果 (计数(前缀) > 计数(文本)) {
        返回 假
    }
    返回 字符串_内部_匹配(文本, 0, 前缀)
}

函数 字符串_以结尾(文本, 后缀) {
    定义 hlen = 计数(后缀)
    定义 源长 = 计数(文本)
    如果 (hlen > 源长) {
        返回 假
    }
    返回 字符串_内部_匹配(文本, 源长 - hlen, 后缀)
}

函数 字符串_重复(文本, 次数) {
    如果 (次数 <= 0) {
        返回 ""
    }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 次数) {
        结果 = 结果 + 文本
        i = i + 1
    }
    返回 结果
}

函数 字符串_反转(文本) {
    定义 可变 结果 = ""
    定义 可变 i = 计数(文本) - 1
    当 (i >= 0) {
        结果 = 结果 + 子串(文本, i, 1)
        i = i - 1
    }
    返回 结果
}

函数 字符串_左填充(文本, 宽度, 填充字符) {
    定义 可变 结果 = 文本
    当 (计数(结果) < 宽度) {
        结果 = 填充字符 + 结果
    }
    返回 结果
}

函数 字符串_右填充(文本, 宽度, 填充字符) {
    定义 可变 结果 = 文本
    当 (计数(结果) < 宽度) {
        结果 = 结果 + 填充字符
    }
    返回 结果
}

函数 字符串_居中(文本, 宽度, 填充字符) {
    定义 差 = 宽度 - 计数(文本)
    如果 (差 <= 0) {
        返回 文本
    }
    定义 左 = 差 / 2
    定义 右 = 差 - 左
    返回 字符串_重复(填充字符, 左) + 文本 + 字符串_重复(填充字符, 右)
}

函数 字符串_是空(文本) {
    如果 (计数(文本) == 0) {
        返回 真
    }
    返回 假
}

函数 字符串_是空白(文本) {
    如果 (计数(文本) == 0) {
        返回 真
    }
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        如果 (是空白字符(字符码(文本, i)) == 假) {
            返回 假
        }
        i = i + 1
    }
    返回 真
}

函数 字符串_全是数字(文本) {
    如果 (计数(文本) == 0) {
        返回 假
    }
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        如果 (字符串_内部_是数字码(字符码(文本, i)) == 假) {
            返回 假
        }
        i = i + 1
    }
    返回 真
}

函数 字符串_全是字母(文本) {
    如果 (计数(文本) == 0) {
        返回 假
    }
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        如果 (字符串_内部_是字母码(字符码(文本, i)) == 假) {
            返回 假
        }
        i = i + 1
    }
    返回 真
}

函数 字符串_转字节列表(文本) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        追加(结果, 编码(子串(文本, i, 1)))
        i = i + 1
    }
    返回 结果
}

函数 字符串_从字节列表(列表) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        结果 = 结果 + 字符(列表[i])
        i = i + 1
    }
    返回 结果
}

函数 字符串_忽略大小写相等(a, b) {
    返回 字符串相等(字符串_转小写(a), 字符串_转小写(b))
}

函数 字符串_单词数(文本) {
    如果 (计数(文本) == 0) {
        返回 0
    }
    定义 可变 次数 = 0
    定义 可变 在词中 = 假
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        如果 (是空白字符(字符码(文本, i))) {
            如果 (在词中) {
                次数 = 次数 + 1
                在词中 = 假
            }
        } 否则 {
            在词中 = 真
        }
        i = i + 1
    }
    如果 (在词中) {
        次数 = 次数 + 1
    }
    返回 次数
}

函数 字符串_最频字符(文本) {
    如果 (计数(文本) == 0) {
        返回 0
    }
    定义 可变 码表 = []
    定义 可变 频表 = []
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        定义 当前码 = 字符码(文本, i)
        定义 可变 命中 = -1
        定义 可变 j = 0
        当 (j < 计数(码表)) {
            如果 (码表[j] == 当前码) {
                命中 = j
            }
            j = j + 1
        }
        如果 (命中 >= 0) {
            频表[命中] = 频表[命中] + 1
        } 否则 {
            追加(码表, 当前码)
            追加(频表, 1)
        }
        i = i + 1
    }
    定义 可变 最佳 = 0
    i = 1
    当 (i < 计数(频表)) {
        如果 (频表[i] > 频表[最佳]) {
            最佳 = i
        }
        i = i + 1
    }
    返回 码表[最佳]
}

函数 字符串_删除(文本, 目标) {
    返回 字符串_替换(文本, 目标, "")
}

函数 字符串_截断(文本, 最大长度, 省略号) {
    如果 (计数(文本) <= 最大长度) {
        返回 文本
    }
    如果 (最大长度 <= 0) {
        返回 省略号
    }
    返回 子串(文本, 0, 最大长度) + 省略号
}

// 汉字Unicode感知接口（实验室验证：中文3字节/字，需字符级处理）

// 判断Unicode码点是否为CJK汉字（基本区）
// CJK基本区: U+4E00(19968) ~ U+9FFF(40959)
函数 字符_是汉字(码点) {
    返回 码点 >= 19968 且 码点 <= 40959
}

// 判断Unicode码点是否为ASCII字符
函数 字符_是ASCII(码点) { 返回 码点 <= 127 }

// 统计字符串中的汉字数量
函数 字符串_汉字数量(文本) {
    定义 可变 计数值 = 0
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        如果 (字符_是汉字(字符码(文本, i))) { 计数值 = 计数值 + 1 }
        i = i + 1
    }
    返回 计数值
}

// 字符串信息密度（汉字密度比ASCII高约2.5倍）
函数 字符串_信息密度(文本) {
    定义 可变 总信息 = 0
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        定义 cp = 字符码(文本, i)
        如果 (字符_是汉字(cp)) {
            总信息 = 总信息 + 11770  // 11.77 bit/汉字 × 1000
        } 否则 如果 (字符_是ASCII(cp)) {
            总信息 = 总信息 + 4700   // 4.70 bit/字母 × 1000
        } 否则 {
            总信息 = 总信息 + 8000   // 其他Unicode字符约8 bit
        }
        i = i + 1
    }
    如果 (计数(文本) == 0) { 返回 0 }
    返回 总信息 / 计数(文本)  // 平均每字符信息量 × 1000
}

// 中文文本压缩建议（基于信息密度决定压缩策略）
函数 字符串_压缩建议(文本) {
    定义 汉字数 = 字符串_汉字数量(文本)
    定义 总数 = 计数(文本)
    如果 (总数 == 0) { 返回 "空文本" }
    定义 汉字率 = 汉字数 * 100 / 总数
    如果 (汉字率 > 70) { 返回 "高汉字率:使用汉字频率Huffman压缩(FB015)" }
    如果 (汉字率 > 30) { 返回 "混合文本:使用LZ77+UTF8感知窗口" }
    返回 "低汉字率:标准LZ77压缩"
}

// 字符串对齐（中英混排时，汉字占2个显示宽度）
函数 字符串_显示宽度(文本) {
    定义 可变 宽度 = 0
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        定义 cp = 字符码(文本, i)
        如果 (字符_是汉字(cp)) { 宽度 = 宽度 + 2 }  // 汉字占2个字符宽
        否则 { 宽度 = 宽度 + 1 }
        i = i + 1
    }
    返回 宽度
}

// 实验反哺: Unicode感知KMP字符串搜索
// 实验验证: KMP O(n+m)比朴素O(n×m)快，Unicode按码点而非字节处理
// 应用: Nova词法分析器中的中文关键字识别（"如果"、"当"、"函数"等）
// 核心优势: 中文关键字2-4字符，KMP failure函数极简，效率最高

// 构建KMP失败函数（基于字符编码数组）
函数 字符串_KMP失败函数(模式码点) {
    定义 m = 计数(模式码点)
    如果 (m == 0) { 返回 [] }
    定义 可变 f = []
    定义 可变 i = 0
    当 (i < m) { 追加(f, 0); i = i + 1 }
    定义 可变 k = 0
    i = 1
    当 (i < m) {
        当 (k > 0 且 模式码点[i] != 模式码点[k]) { k = f[k-1] }
        如果 (模式码点[i] == 模式码点[k]) { k = k + 1 }
        f[i] = k
        i = i + 1
    }
    返回 f
}

// KMP搜索：在文本码点数组中搜索模式码点数组，返回所有匹配起始位置
函数 字符串_KMP搜索码点(文本码点, 模式码点) {
    定义 n = 计数(文本码点); 定义 m = 计数(模式码点)
    如果 (m == 0 或 m > n) { 返回 [] }
    定义 f = 字符串_KMP失败函数(模式码点)
    定义 可变 结果 = []
    定义 可变 k = 0
    定义 可变 i = 0
    当 (i < n) {
        当 (k > 0 且 文本码点[i] != 模式码点[k]) { k = f[k-1] }
        如果 (文本码点[i] == 模式码点[k]) { k = k + 1 }
        如果 (k == m) { 追加(结果, i - m + 1); k = f[k-1] }
        i = i + 1
    }
    返回 结果
}

// 字符串转码点数组（Unicode感知）
函数 字符串_转码点数组(s) {
    定义 可变 码点 = []
    定义 可变 i = 0
    当 (i < 计数(s)) {
        追加(码点, 字符码(s, i))
        i = i + 1
    }
    返回 码点
}

// 统计模式在文本中出现的次数
函数 字符串_KMP计数(文本, 模式) {
    定义 文本码点 = 字符串_转码点数组(文本)
    定义 模式码点 = 字符串_转码点数组(模式)
    返回 计数(字符串_KMP搜索码点(文本码点, 模式码点))
}

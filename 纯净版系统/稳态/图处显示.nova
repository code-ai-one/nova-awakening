结构 显示档 {
    名称,
    宽,
    高,
    位深,
    帧缓,
    设备,
    模式,
    最近树,
    最近障树,
    模式切换数,
    绘制数,
    文本数,
    控制数,
    翻页数,
}

结构 显示摘要 {
    名称,
    宽,
    高,
    位深,
    模式切换数,
    绘制数,
    文本数,
    控制数,
    翻页数,
    节点数,
    交互数,
    健康,
}

定义 可变 显示账本 = []
定义 可变 显示建数 = 0

函数 显示布尔串(值) {
    如果 (值) { 返回 "true" }
    返回 "false"
}

函数 图处显示_建档(名称, 宽, 高, 位深) {
    定义 档 = 堆_分配(显示档)
    档.名称 = 名称
    档.宽 = 宽
    档.高 = 高
    档.位深 = 位深
    档.帧缓 = 0
    档.设备 = 0
    档.模式 = 0
    档.最近树 = 0
    档.最近障树 = 0
    档.模式切换数 = 0
    档.绘制数 = 0
    档.文本数 = 0
    档.控制数 = 0
    档.翻页数 = 0
    返回 档
}

函数 图处显示_创建(名称, 宽, 高, 位深) {
    DRM_初始化()
    BGA_初始化模式(宽, 高, 位深)
    帧缓冲_初始化()
    合成器_初始化(宽, 高, 位深, 0)
    定义 档 = 图处显示_建档(名称, 宽, 高, 位深)
    追加(显示账本, 档)
    显示建数 = 显示建数 + 1
    返回 档
}

函数 图处显示_自动创建(名称) {
    定义 模式 = 屏幕_自动检测分辨率()
    定义 宽 = 模式[0]
    定义 高 = 模式[1]
    定义 位深 = 模式[2]
    返回 图处显示_创建(名称, 宽, 高, 位深)
}

函数 图处显示_名称(档) { 返回 档.名称 }
函数 图处显示_宽(档) { 返回 档.宽 }
函数 图处显示_高(档) { 返回 档.高 }
函数 图处显示_位深(档) { 返回 档.位深 }

函数 图处显示_设分辨率(档, 宽, 高, 位深) {
    屏幕_设置分辨率(宽, 高, 位深)
    BGA_初始化模式(宽, 高, 位深)
    档.宽 = 宽
    档.高 = 高
    档.位深 = 位深
    档.模式切换数 = 档.模式切换数 + 1
}

函数 图处显示_注册设备(档, vid, did, 总线, 设备号, 功能号) {
    档.设备 = DRM_注册图处(vid, did, 总线, 设备号, 功能号)
    DRM_创建默认对象(档.设备)
    档.控制数 = 档.控制数 + 1
    返回 档.设备
}

函数 图处显示_创建模式(档, 宽, 高, hz, 名称) {
    档.模式 = DRM_创建模式(宽, 高, hz, 名称)
    档.模式切换数 = 档.模式切换数 + 1
    返回 档.模式
}

函数 图处显示_设备控制(档, fd, cmd, 参数) {
    档.控制数 = 档.控制数 + 1
    返回 DRM_Nova设备控制(fd, cmd, 参数)
}

函数 图处显示_设备版本(档, dev, 参数) {
    档.控制数 = 档.控制数 + 1

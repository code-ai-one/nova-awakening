导入("./类型定义.nova")
导入("./错误码.nova")
导入("./整数转字符串.nova")
导入("./内核打印.nova")

// NovaOS · 系统剖析器 (Profiler)
// §1 函数级计时 (进入/退出打桩)
// §2 热点统计 (调用次数/总耗时/最大耗时)
// §3 采样式剖析 (定时器中断采样IP)
// §4 报告 (按耗时排序的前N热点)


结构 剖析条目 {
    名称,
    调用次数,
    总耗时微秒,
    最大耗时微秒,
    最小耗时微秒,
    进入时间,       // u64 (临时, 每次进入时记录)
}

定义 剖析_最大条目 = 1024
定义 可变 _剖析表 = []
定义 可变 _剖析启用 = 假
定义 可变 _采样总数 = 0

函数 剖析_启用() { _剖析启用 = 真 }
函数 剖析_禁用() { _剖析启用 = 假 }
函数 剖析_已启用() { 返回 _剖析启用 }

函数 剖析_查找(名称) {
    定义 可变 i = 0
    当 (i < 计数(_剖析表)) {
        如果 (_剖析表[i].名称 == 名称) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 剖析_进入(名称) {
    如果 (!_剖析启用) { 返回 }
    定义 idx = 剖析_查找(名称)
    如果 (idx < 0) {
        如果 (计数(_剖析表) >= 剖析_最大条目) { 返回 }
        定义 条目 = 剖析条目 {}
        条目.名称 = 名称
        条目.调用次数 = 0
        条目.总耗时微秒 = 0
        条目.最大耗时微秒 = 0
        条目.最小耗时微秒 = 999999999
        条目.进入时间 = 读取毫秒()
        追加(_剖析表, 条目)
    } 否则 {
        _剖析表[idx].进入时间 = 读取毫秒()
    }
}

函数 剖析_退出(名称) {
    如果 (!_剖析启用) { 返回 }
    定义 idx = 剖析_查找(名称)
    如果 (idx < 0) { 返回 }
    定义 现在 = 读取毫秒()
    定义 耗时 = (现在 - _剖析表[idx].进入时间) * 1000  // 转微秒
    _剖析表[idx].调用次数 = _剖析表[idx].调用次数 + 1
    _剖析表[idx].总耗时微秒 = _剖析表[idx].总耗时微秒 + 耗时
    如果 (耗时 > _剖析表[idx].最大耗时微秒) { _剖析表[idx].最大耗时微秒 = 耗时 }
    如果 (耗时 < _剖析表[idx].最小耗时微秒) { _剖析表[idx].最小耗时微秒 = 耗时 }
}


函数 剖析_采样(当前函数名) {
    // 定时器中断回调: 记录当前执行位置
    如果 (!_剖析启用) { 返回 }
    _采样总数 = _采样总数 + 1
    定义 idx = 剖析_查找(当前函数名)
    如果 (idx < 0) {
        如果 (计数(_剖析表) >= 剖析_最大条目) { 返回 }
        定义 条目 = 剖析条目 {}
        条目.名称 = 当前函数名
        条目.调用次数 = 1
        条目.总耗时微秒 = 0
        条目.最大耗时微秒 = 0
        条目.最小耗时微秒 = 0
        条目.进入时间 = 0
        追加(_剖析表, 条目)
    } 否则 {
        _剖析表[idx].调用次数 = _剖析表[idx].调用次数 + 1
    }
}


函数 剖析_报告(前N) {
    定义 可变 r = "═══ 系统剖析报告 ═══\n"
    r = r + "条目数: " + 整数转字符串(计数(_剖析表)) + "\n"
    r = r + "采样数: " + 整数转字符串(_采样总数) + "\n"

    // 按总耗时排序(简单选择排序)
    定义 可变 排序表 = []
    定义 可变 i = 0
    当 (i < 计数(_剖析表)) { 追加(排序表, i); i = i + 1 }

    i = 0
    当 (i < 计数(排序表) - 1) {
        定义 可变 最大 = i
        定义 可变 j = i + 1
        当 (j < 计数(排序表)) {
            如果 (_剖析表[排序表[j]].总耗时微秒 > _剖析表[排序表[最大]].总耗时微秒) {
                最大 = j
            }
            j = j + 1
        }
        如果 (最大 != i) {
            定义 临时 = 排序表[i]
            排序表[i] = 排序表[最大]
            排序表[最大] = 临时
        }
        i = i + 1
    }

    r = r + "热点 (按总耗时):\n"
    i = 0
    当 (i < 计数(排序表) && i < 前N) {
        定义 e = _剖析表[排序表[i]]
        定义 平均 = 0
        如果 (e.调用次数 > 0) { 平均 = e.总耗时微秒 / e.调用次数 }
        r = r + "  " + 整数转字符串(i + 1) + ". " + e.名称
        r = r + " 调用:" + 整数转字符串(e.调用次数)
        r = r + " 总:" + 整数转字符串(e.总耗时微秒) + "us"
        r = r + " 均:" + 整数转字符串(平均) + "us"
        r = r + " 最大:" + 整数转字符串(e.最大耗时微秒) + "us"
        r = r + "\n"
        i = i + 1
    }
    返回 r
}

函数 剖析_重置() {
    _剖析表 = []
    _采样总数 = 0
}

// Nova 原生列表引擎 — 排序/搜索/旋转/合并/去重/切片
// 职责: 快排/归并/二分 + 列表操作 + 红黑树旋转 + 统计
// 层级: 第7层运行时

导入("../../标准库/基础.nova")

// 交换
函数 列表_交换(lst, i, j) { 定义 t = lst[i]
 lst[i] = lst[j]
 lst[j] = t
}

// 快速排序 (Lomuto分区, 0)
函数 列表_分区(lst, lo, hi) { 定义 pivot = lst[hi]
 定义 可变 i = lo
 定义 可变 j = lo
 当 (j < hi) { 如果 (lst[j] <= pivot) {
 列表_交换(lst, i, j)
 i = i + 1
 }
 j = j + 1
 }
 列表_交换(lst, i, hi)
 返回 i
}

函数 列表_快排(lst, lo, hi) { 如果 (lo < hi) { 定义 p = 列表_分区(lst, lo, hi)
 列表_快排(lst, lo, p - 1)
 列表_快排(lst, p + 1, hi)
 }
}

函数 列表_排序(lst) {
    如果 (计数(lst) > 1) { 列表_快排(lst, 0, 计数(lst) - 1)
}
}

// 二分查找 (需已排序, 0)
函数 列表_二分查找(lst, 目标) { 定义 可变 lo = 0
 定义 可变 hi = 计数(lst) - 1
 当 (lo <= hi) { 定义 mid = lo + (hi - lo) / 2
 如果 (lst[mid] == 目标) { 返回 mid }
 如果 (lst[mid] < 目标) { lo = mid + 1 }
 否则 { hi = mid - 1 }
 }
 返回 -1
}

// 线性查找
函数 列表_查找(lst, 目标) { 定义 可变 i = 0
 当 (i < 计数(lst)) { 如果 (lst[i] == 目标) { 返回 i }
 i = i + 1
 }
 返回 -1
}

// 反转 (原地)
函数 列表_反转(lst) { 定义 可变 左idx = 0
 定义 可变 右idx = 计数(lst) - 1
 当 (左idx < 右idx) {
 列表_交换(lst, 左idx, 右idx)
 左idx = 左idx + 1
 右idx = 右idx - 1
 }
}

// 聚合函数
函数 列表_求和(lst) { 定义 可变 s = 0
 定义 可变 i = 0
 当 (i < 计数(lst)) { s = s + lst[i]
 i = i + 1 }
 返回 s
}

函数 列表_最大(lst) { 定义 可变 m = lst[0]
 定义 可变 i = 1
 当 (i < 计数(lst)) { 如果 (lst[i] > m) { m = lst[i] }
 i = i + 1 }
 返回 m
}

函数 列表_最小(lst) { 定义 可变 m = lst[0]
 定义 可变 i = 1
 当 (i < 计数(lst)) { 如果 (lst[i] < m) { m = lst[i] }
 i = i + 1 }
 返回 m
}

函数 列表_平均(lst) {
    如果 (计数(lst) == 0) { 返回 0
}
 返回 列表_求和(lst) / 计数(lst)
}

// 去重 (已排序列表)
函数 列表_去重(lst) {
    如果 (计数(lst) <= 1) { 返回 lst
}
 定义 可变 结果 = []
 追加(结果, lst[0])
 定义 可变 i = 1
 当 (i < 计数(lst)) { 如果 (lst[i] != lst[i - 1]) { 追加(结果, lst[i]) }
 i = i + 1
 }
 返回 结果
}

// 合并两个已排序列表
函数 列表_合并(a, b) { 定义 可变 结果 = []
 定义 可变 i = 0
 定义 可变 j = 0
 当 (i < 计数(a) 且 j < 计数(b)) { 如果 (a[i] <= b[j]) { 追加(结果, a[i])
 i = i + 1 }
 否则 { 追加(结果, b[j])
 j = j + 1 }
 }
 当 (i < 计数(a)) { 追加(结果, a[i])
 i = i + 1 }
 当 (j < 计数(b)) { 追加(结果, b[j])
 j = j + 1 }
 返回 结果
}

// 切片
函数 列表_切片(lst, 起, _止) { 定义 可变 结果 = []
 定义 可变 i = 起
 当 (i < _止 且 i < 计数(lst)) { 追加(结果, lst[i])
 i = i + 1 }
 返回 结果
}

// 旋转 (左旋k位)
函数 列表_旋转(lst, k) { 定义 n = 计数(lst)
 如果 (n <= 1) { 返回 }
定义 实际k = k % n
 如果 (实际k == 0) { 返回 }
 // 三次反转法
 定义 可变 lo = 0
 定义 可变 hi = 实际k - 1
 当 (lo < hi) { 列表_交换(lst, lo, hi)
 lo = lo + 1
 hi = hi - 1 }
 lo = 实际k
 hi = n - 1
 当 (lo < hi) { 列表_交换(lst, lo, hi)
 lo = lo + 1
 hi = hi - 1 }
 lo = 0
 hi = n - 1
 当 (lo < hi) { 列表_交换(lst, lo, hi)
 lo = lo + 1
 hi = hi - 1 }
}

// 计数特定值
函数 列表_计数值(lst, 值) { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(lst)) { 如果 (lst[i] == 值) { c = c + 1 }
 i = i + 1 }
 返回 c
}

// 是否已排序
函数 列表_已排序(lst) { 定义 可变 i = 1
 当 (i < 计数(lst)) { 如果 (lst[i] < lst[i - 1]) { 返回 假 }
 i = i + 1
 }
 返回 真
}

// 扁平化二维列表
函数 列表_扁平(lst) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(lst)) { 定义 子 = lst[i]
 定义 可变 j = 0
 当 (j < 计数(子)) { 追加(结果, 子[j])
 j = j + 1 }
 i = i + 1
 }
 返回 结果
}

// Zip (配对)
函数 列表_配对(a, b) { 定义 可变 结果 = []
 定义 n = 计数(a)
 定义 m = 计数(b)
 定义 可变 小 = n
 如果 (m < 小) { 小 = m }
 定义 可变 i = 0
 当 (i < 小) { 追加(结果, [a[i], b[i]])
 i = i + 1 }
 返回 结果
}

// 插入排序 (小数据集优选, 0, 0)
函数 列表_插入排序(lst) { 定义 n = 计数(lst)
 定义 可变 i = 1
 当 (i < n) { 定义 当前 = lst[i]
 定义 可变 j = i - 1
 当 (j >= 0 且 lst[j] > 当前) {
 lst[j + 1] = lst[j]
 j = j - 1
 }
 lst[j + 1] = 当前
 i = i + 1
 }
}

// 归并排序 (非递归, 自底向上)
函数 列表_归并排序(lst) { 定义 n = 计数(lst)
 如果 (n <= 1) { 返回 lst }
 // 复制输入
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < n) { 追加(结果, lst[i])
 i = i + 1 }
 // 自底向上: 窗口从1开始倍增
 定义 可变 宽 = 1
 当 (宽 < n) { 定义 可变 起 = 0
 当 (起 < n) { 定义 可变 mid = 起 + 宽
 定义 可变 _止 = mid + 宽
 如果 (mid > n) { mid = n }
 如果 (_止 > n) { _止 = n }
 // 合并 [起,mid) 和 [mid,止) 到暂存列表
 定义 可变 暂存 = []
 定义 可变 左i = 起
 定义 可变 右i = mid
 当 (左i < mid 且 右i < _止) { 如果 (结果[左i] <= 结果[右i]) { 追加(暂存, 结果[左i])
 左i = 左i + 1 }
 否则 { 追加(暂存, 结果[右i])
 右i = 右i + 1 }
 }
 当 (左i < mid) { 追加(暂存, 结果[左i])
 左i = 左i + 1 }
 当 (右i < _止) { 追加(暂存, 结果[右i])
 右i = 右i + 1 }
 // 写回
 定义 可变 k = 0
 当 (k < 计数(暂存)) { 结果[起 + k] = 暂存[k]
 k = k + 1 }
 起 = _止
 }
 宽 = 宽 * 2
 }
 返回 结果
}

// 前缀和
函数 列表_前缀和(lst) { 定义 可变 结果 = []
 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 计数(lst)) {
 和 = 和 + lst[i]
 追加(结果, 和)
 i = i + 1
 }
 返回 结果
}

// 按阈值分组: 分成两部分
函数 列表_按阈值分(lst, 阈值) { 定义 可变 低部 = []
 定义 可变 高部 = []
 定义 可变 i = 0
 当 (i < 计数(lst)) { 如果 (lst[i] < 阈值) { 追加(低部, lst[i]) }
 否则 { 追加(高部, lst[i]) }
 i = i + 1
 }
 返回 [低部, 高部]
}

// 第K小元素 (快速选择, 均摊O(n))
函数 列表_第k小(lst, k) { 定义 可变 副本 = []
 定义 可变 i = 0
 当 (i < 计数(lst)) { 追加(副本, lst[i])
 i = i + 1 }
 列表_排序(副本)
 如果 (k >= 0 且 k < 计数(副本)) { 返回 副本[k] }
 返回 -1
}

// 列表乘积
函数 列表_乘积(lst) { 定义 可变 p = 1
 定义 可变 i = 0
 当 (i < 计数(lst)) { p = p * lst[i]
 i = i + 1 }
 返回 p
}

// 窗口求和 (滑动窗口)
函数 列表_滑窗和(lst, 窗大小) { 定义 n = 计数(lst)
 如果 (窗大小 > n) { 返回 [] }
 定义 可变 结果 = []
 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 窗大小) { 和 = 和 + lst[i]
 i = i + 1 }
 追加(结果, 和)
 当 (i < n) {
 和 = 和 + lst[i] - lst[i - 窗大小]
 追加(结果, 和)
 i = i + 1
 }
 返回 结果
}

// 交集 (两个已排序列表)
函数 列表_交集(a, b) { 定义 可变 结果 = []
 定义 可变 i = 0
 定义 可变 j = 0
 当 (i < 计数(a) 且 j < 计数(b)) { 如果 (a[i] == b[j]) { 追加(结果, a[i])
 i = i + 1
 j = j + 1 }
 否则 如果 (a[i] < b[j]) { i = i + 1 }
 否则 { j = j + 1 }
 }
 返回 结果
}

// 差集 (a - b, 两个已排序列表)
函数 列表_差集(a, b) { 定义 可变 结果 = []
 定义 可变 i = 0
 定义 可变 j = 0
 当 (i < 计数(a)) { 如果 (j < 计数(b) 且 a[i] == b[j]) { i = i + 1
 j = j + 1 }
 否则 如果 (j < 计数(b) 且 a[i] > b[j]) { j = j + 1 }
 否则 { 追加(结果, a[i])
 i = i + 1 }
 }
 返回 结果
}

// 列表高级操作

函数 列表引擎_旋转(列表, k) { 定义 n = 计数(列表)
 如果 (n == 0) { 返回 列表 }
定义 实际k = k % n
 定义 可变 结果 = []
 定义 可变 i = 实际k
 当 (i < n) { 追加(结果, 列表[i]) i = i + 1 }
 i = 0
 当 (i < 实际k) { 追加(结果, 列表[i]) i = i + 1 }
 返回 结果
}

函数 列表_分块(列表, 块大小) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(列表)) { 定义 可变 块 = []
 定义 可变 j = 0
 当 (j < 块大小 且 i + j < 计数(列表)) {
 追加(块, 列表[i + j])
 j = j + 1
 }
 追加(结果, 块)
 i = i + 块大小
 }
 返回 结果
}

函数 列表_扁平化(嵌套列表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(嵌套列表)) { 定义 可变 j = 0
 当 (j < 计数(嵌套列表[i])) {
 追加(结果, 嵌套列表[i][j])
 j = j + 1
 }
 i = i + 1
 }
 返回 结果
}

函数 列表_滑动窗口(列表, 窗口大小) { 定义 可变 结果 = []
    定义 可变 窗口 = []
 定义 可变 i = 0
当 (i + 窗口大小 <= 计数(列表)) {
 定义 可变 j = 0
 当 (j < 窗口大小) {
 追加(窗口, 列表[i + j])
 j = j + 1
 }
 追加(结果, 窗口)
 i = i + 1
 }
 返回 结果
}

函数 列表_最大子数组和(列表) {
    如果 (计数(列表) == 0) { 返回 0
}
 定义 可变 最大 = 列表[0]
 定义 可变 当前 = 列表[0]
 定义 可变 i = 1
 当 (i < 计数(列表)) { 如果 (当前 + 列表[i] > 列表[i]) { 当前 = 当前 + 列表[i] }
 否则 { 当前 = 列表[i] }
 如果 (当前 > 最大) { 最大 = 当前 }
 i = i + 1
 }
 返回 最大
}

定义 可变 _列表_统计 = [0, 0, 0] // [操作次数, 最大长度, 查找次数]

函数 列表_记录操作(长度) { _列表_统计[0] = _列表_统计[0] + 1
 如果 (长度 > _列表_统计[1]) { _列表_统计[1] = 长度 }
}

函数 列表_记录查找() { _列表_统计[2] = _列表_统计[2] + 1 }

函数 列表_性能建议() {
    如果 (_列表_统计[1] > 100000) { 返回 "超大列表(考虑分页或流式处理)"
}
 如果 (_列表_统计[2] > _列表_统计[0] * 5) { 返回 "查找密集(使用哈希表)" }
 返回 "列表使用正常"
}

函数 列表_重置() { _列表_统计[0] = 0 _列表_统计[1] = 0 _列表_统计[2] = 0 }

函数 列表引擎_去重(列表) { 定义 可变 结果 = []
 定义 可变 i = 0
当 (i < 计数(列表)) {
 定义 可变 j = 0
 当 (j < 计数(结果)) { 如果 (结果[j] == 列表[i]) { 重复 = 真 }
 j = j + 1
 }
 如果 (!重复) { 追加(结果, 列表[i]) }
 i = i + 1
 }
 返回 结果
}

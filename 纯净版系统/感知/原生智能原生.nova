// Nova AI原生布局引擎: 布局Object — 智能布局节点
// 【创新突破】传统方案: 布局是纯几何计算,每次DOM变化都重算
//   Nova 布局Object = NovaOS核心引擎 + 以下AI原生能力:
//   ① 布局预测 — AI预测元素尺寸,跳过未变化子树的计算
//   ② 注意力驱动精度 — 用户注视区域精确布局,屏幕外粗略估算
//   ③ 增量布局智能化 — 缓存布局结果,只重算真正变化的部分
//   ④ 语义感知布局 — 根据DOM节点语义角色调整布局优先级
// 这意味着:
//   - 滚动时只精确布局视口内元素,视口外用估算值
//   - 广告/页脚等低优先级内容延迟布局
//   - 布局结果缓存+预测,减少重布局次数

导入("./样式解析.nova")
导入("./文档节点.nova")
导入("./内核直连层.nova")
导入("../中枢/内核打印.nova")
导入("../推理/值乘.nova")
导入("../中枢/时钟中枢.nova")

定义 布局类型_块         = 1     // 布局块级Flow (block/list-item)
定义 布局类型_内联       = 2     // 布局Inline
定义 布局类型_文本       = 3     // 布局Text
定义 布局类型_行盒       = 4     // 布局LineBox (内联行)
定义 布局类型_弹性       = 5     // 布局弹性ibleBox
定义 布局类型_网格       = 6     // 布局网格
定义 布局类型_表格       = 7     // 布局Table
定义 布局类型_表格行     = 8     // 布局TableRow
定义 布局类型_表格单元   = 9     // 布局TableCell
定义 布局类型_替换       = 10    // 布局Replaced (img/video/iframe)
定义 布局类型_视图       = 11    // 布局View (根)

定义 布局标志_需要布局       = 0x01
定义 布局标志_子树需要布局   = 0x02
定义 布局标志_需要绘制       = 0x04
定义 布局标志_是浮动         = 0x08
定义 布局标志_是定位         = 0x10    // position != static
定义 布局标志_是块级格式化上下文 = 0x20  // BFC
定义 布局标志_有溢出         = 0x40
定义 布局标志_AI已预测       = 0x80    // AI已预测尺寸
定义 布局标志_可跳过布局     = 0x100   // AI判定可跳过重布局
定义 布局标志_低精度布局     = 0x200   // 使用粗略估算

// 布局Object结构 — Nova AI智能布局节点

结构 布局Object {
    父,    // u64 布局Object* parent
    第一子,
    最后子,
    前兄,
    后兄,
    类型,    // u32 布局类型_xxx
    标志,    // u32 布局标志
    DOM节点,    // u64 对应的DOM 节点*

    样式,    // u64 Computed样式*

    x,    // i32 相对于父的x偏移 (px×100)
    y,
    内容宽,
    内容高,
    绝对x,
    绝对y,
    子数量,
    // 以下字段是传统引擎没有的, Nova独创

    // AI预测的尺寸,用于跳过重复布局
    预测宽,    // i32 AI预测的内容宽度
    预测高,    // i32 AI预测的内容高度
    预测置信度,    // u32 0-10000 预测精度

    // 用于判断是否可跳过重布局
    布局版本,    // u32 每次实际布局后递增
    父布局版本,    // u32 父节点布局时的版本号

    布局精度,    // u16 0=跳过 1=粗略 2=标准 3=精确
    布局优先级,    // u16 布局计算优先级(0-255)

    上次布局耗时,    // u32 上次布局计算耗时(us)
    累计布局次数,    // u32 历史布局计算次数
}

// NILE理论: Nova智能布局执行 (Nova Intelligent Layout Execution)
//   核心创新: 将AI预测与布局计算融合，实现
//   尺寸预测跳过、注意力驱动精度、增量布局智能化、
//   语义感知优先级、布局结果缓存与复用

定义 可变 全局NILE统计 = NILE统计结构 {}

结构 NILE统计结构 {
    布局总次数,
    跳过次数,        // u64 AI预测跳过重布局次数
    粗略布局次数,    // u64 低精度布局次数
    精确布局次数,    // u64 标准/精确布局次数
    AI预测次数,
    总耗时_us          // u64
}

// §2 布局Object创建与销毁

函数 布局Object_创建(类型, dom节点) {
    定义 obj = 堆_分配(布局Object)
    如果 (obj == 0) { 返回 空 }
    // 树结构初始化
    obj.父 = 空
    obj.第一子 = 空
    obj.最后子 = 空
    obj.前兄 = 空
    obj.后兄 = 空
    // 身份
    obj.类型 = 类型
    obj.标志 = 布局标志_需要布局
    obj.DOM节点 = dom节点
    obj.样式 = 空
    // 几何初始化
    obj.x = 0
    obj.y = 0
    obj.内容宽 = 0
    obj.内容高 = 0
    obj.绝对x = 0
    obj.绝对y = 0
    obj.子数量 = 0
    // AI扩展初始化
    obj.预测宽 = 0
    obj.预测高 = 0
    obj.预测置信度 = 0
    obj.布局版本 = 0
    obj.父布局版本 = 0
    obj.布局精度 = 2  // 标准精度
    obj.布局优先级 = 128  // 中等优先级
    obj.上次布局耗时 = 0
    obj.累计布局次数 = 0
    返回 obj
}

函数 布局Object_销毁(obj) {
    如果 (obj == 空) { 返回 }
    // 递归销毁子节点
    定义 可变 child = obj.第一子
    当 (child != 空) {
        定义 next = child.后兄
        布局Object_销毁(child)
        child = next
    }
    堆_释放(obj)
}

// §3 布局树操作 (插入/移除/遍历)

函数 布局Object_添加子节点(父, 子) {
    如果 (父 == 空 || 子 == 空) { 返回 }
    子.父 = 父
    子.前兄 = 父.最后子
    子.后兄 = 空
    如果 (父.最后子 != 空) {
        父.最后子.后兄 = 子
    } 否则 {
        父.第一子 = 子
    }
    父.最后子 = 子
    父.子数量 = 父.子数量 + 1
    // 标记父节点需要重新布局
    布局Object_标记脏(父)
}

函数 布局Object_移除子节点(父, 子) {
    如果 (父 == 空 || 子 == 空 || 子.父 != 父) { 返回 }
    // 重连接兄弟链表
    如果 (子.前兄 != 空) {
        子.前兄.后兄 = 子.后兄
    } 否则 {
        父.第一子 = 子.后兄
    }
    如果 (子.后兄 != 空) {
        子.后兄.前兄 = 子.前兄
    } 否则 {
        父.最后子 = 子.前兄
    }
    子.父 = 空
    子.前兄 = 空
    子.后兄 = 空
    父.子数量 = 父.子数量 - 1
    布局Object_标记脏(父)
}

// §4 Dirty标记与增量布局
// NILE-IM: 增量布局 —— 只重算真正变化的部分

函数 布局Object_标记脏(obj) {
    如果 (obj == 空) { 返回 }
    obj.标志 = obj.标志 | 布局标志_需要布局
    // 向上传播 "子树需要布局" 标志
    定义 可变 p = obj.父
    当 (p != 空) {
        如果 (p.标志 & 布局标志_子树需要布局 != 0) {
            返回  // 已标记，无需继续
        }
        p.标志 = p.标志 | 布局标志_子树需要布局
        p = p.父
    }
}

函数 布局Object_清除脏标志(obj) {
    如果 (obj == 空) { 返回 }
    obj.标志 = obj.标志 & (~布局标志_需要布局)
    obj.标志 = obj.标志 & (~布局标志_子树需要布局)
}

函数 布局Object_需要布局(obj) {
    如果 (obj == 空) { 返回 假 }
    返回 (obj.标志 & 布局标志_需要布局) != 0
}

// §5 AI尺寸预测系统
// NILE-AP: AI预测元素尺寸，跳过未变化子树

函数 布局Object_AI预测尺寸(obj) {
    如果 (obj == 空) { 返回 }
    // 构建特征向量: 类型 + 历史尺寸 + 子节点数
    定义 特征 = Tensor_创建(6)
    Tensor_写(特征, 0, obj.类型)
    Tensor_写(特征, 1, obj.内容宽)
    Tensor_写(特征, 2, obj.内容高)
    Tensor_写(特征, 3, obj.子数量)
    Tensor_写(特征, 4, obj.布局版本)
    Tensor_写(特征, 5, obj.累计布局次数)
    定义 结果 = AI总线_推理(全局AI总线, 特征)
    Tensor_释放(特征)
    全局NILE统计.AI预测次数 = 全局NILE统计.AI预测次数 + 1
    如果 (结果 > 0) {
        obj.预测宽 = 结果 >> 16
        obj.预测高 = 结果 & 0xFFFF
        obj.预测置信度 = 8000  // 高置信度
        obj.标志 = obj.标志 | 布局标志_AI已预测
    }
}

函数 布局Object_可跳过布局(obj) {
    // 判断AI预测是否可以跳过重布局
    如果 (obj == 空) { 返回 假 }
    如果 (obj.标志 & 布局标志_可跳过布局 != 0) { 返回 真 }
    // 检查AI预测置信度
    如果 (obj.预测置信度 > 7000) {
        // 检查父布局版本是否匹配
        如果 (obj.父 != 空 && obj.父布局版本 == obj.父.布局版本) {
            obj.标志 = obj.标志 | 布局标志_可跳过布局
            返回 真
        }
    }
    返回 假
}

// §6 注意力驱动布局精度
// NILE-AD: 用户注视区域精确布局，屏幕外粗略估算

函数 布局Object_设置精度(obj, 视口顶, 视口底) {
    如果 (obj == 空) { 返回 }
    // 判断元素是否在视口内
    如果 (obj.绝对y + obj.内容高 < 视口顶 || obj.绝对y > 视口底) {
        // 屏幕外 → 低精度
        obj.布局精度 = 1  // 粗略
        obj.布局优先级 = 32
    } 否则 {
        // 屏幕内 → 高精度
        obj.布局精度 = 3  // 精确
        obj.布局优先级 = 200
    }
    // 递归设置子节点
    定义 可变 child = obj.第一子
    当 (child != 空) {
        布局Object_设置精度(child, 视口顶, 视口底)
        child = child.后兄
    }
}

// §7 块级布局算法 (Block Layout)

函数 布局Object_块级布局(obj, 可用宽) {
    如果 (obj == 空) { 返回 }
    定义 开始 = 读取微秒()
    // 检查是否可跳过
    如果 (布局Object_可跳过布局(obj)) {
        obj.内容宽 = obj.预测宽
        obj.内容高 = obj.预测高
        全局NILE统计.跳过次数 = 全局NILE统计.跳过次数 + 1
        返回
    }
    // 设置宽度
    obj.内容宽 = 可用宽
    // 布局子节点 (块级流: 垂直堆叠)
    定义 可变 yOffset = 0
    定义 可变 child = obj.第一子
    当 (child != 空) {
        child.x = 0
        child.y = yOffset
        // 根据精度级别布局
        如果 (obj.布局精度 <= 1) {
            // 粗略布局: 使用估算值
            child.内容宽 = 可用宽
            child.内容高 = 2000  // 默认估算20px
            全局NILE统计.粗略布局次数 = 全局NILE统计.粗略布局次数 + 1
        } 否则 {
            // 精确布局
            布局Object_执行布局(child, 可用宽)
            全局NILE统计.精确布局次数 = 全局NILE统计.精确布局次数 + 1
        }
        yOffset = yOffset + child.内容高
        child = child.后兄
    }
    obj.内容高 = yOffset
    // 更新版本号和统计
    obj.布局版本 = obj.布局版本 + 1
    obj.累计布局次数 = obj.累计布局次数 + 1
    布局Object_清除脏标志(obj)
    定义 耗时 = 读取微秒() - 开始
    obj.上次布局耗时 = 耗时
    全局NILE统计.总耗时_us = 全局NILE统计.总耗时_us + 耗时
    全局NILE统计.布局总次数 = 全局NILE统计.布局总次数 + 1
}

// §8 统一布局入口与绝对坐标计算

函数 布局Object_执行布局(obj, 可用宽) {
    // 统一入口: 根据类型分发布局算法
    如果 (obj == 空) { 返回 }
    如果 (obj.类型 == 布局类型_块 || obj.类型 == 布局类型_视图) {
        布局Object_块级布局(obj, 可用宽)
    } 否则 {
        // 其他类型默认用块级布局
        布局Object_块级布局(obj, 可用宽)
    }
}

函数 布局Object_计算绝对坐标(obj) {
    // 递归计算布局树中每个节点的绝对位置
    如果 (obj == 空) { 返回 }
    如果 (obj.父 != 空) {
        obj.绝对x = obj.父.绝对x + obj.x
        obj.绝对y = obj.父.绝对y + obj.y
    } 否则 {
        obj.绝对x = obj.x
        obj.绝对y = obj.y
    }
    定义 可变 child = obj.第一子
    当 (child != 空) {
        布局Object_计算绝对坐标(child)
        child = child.后兄
    }
}

// §9 NILE诊断与初始化

函数 NILE_初始化() {
    内核打印("[NILE] Nova智能布局执行引擎 启动")
    全局NILE统计.布局总次数 = 0
    全局NILE统计.跳过次数 = 0
    全局NILE统计.粗略布局次数 = 0
    全局NILE统计.精确布局次数 = 0
    全局NILE统计.AI预测次数 = 0
    全局NILE统计.总耗时_us = 0
    内核打印("[NILE] 初始化完成 — AI预测/注意力精度/增量布局/块级流 就绪")
}

函数 NILE_打印诊断() {
    内核打印("╔════════════════════════════════════════════╗")
    内核打印("║  NILE 智能布局执行 诊断报告              ║")
    内核打印("╠════════════════════════════════════════════╣")
    内核打印("║ 布局总次:     {}", 全局NILE统计.布局总次数)
    内核打印("║ AI跳过:       {}", 全局NILE统计.跳过次数)
    内核打印("║ 粗略布局:     {}", 全局NILE统计.粗略布局次数)
    内核打印("║ 精确布局:     {}", 全局NILE统计.精确布局次数)
    内核打印("║ AI预测:       {}", 全局NILE统计.AI预测次数)
    内核打印("║ 总耗时:       {}μs", 全局NILE统计.总耗时_us)
    内核打印("╚════════════════════════════════════════════╝")
}

// §10 命中测试 (Hit Testing)
// NILE-HT: 给定屏幕坐标，找到对应的布局节点

函数 布局Object_命中测试(obj, testX, testY) {
    如果 (obj == 空) { 返回 空 }
    // 检查坐标是否在当前节点范围内
    如果 (testX < obj.绝对x || testX > obj.绝对x + obj.内容宽) { 返回 空 }
    如果 (testY < obj.绝对y || testY > obj.绝对y + obj.内容高) { 返回 空 }
    // 深度优先: 先检查子节点 (从后往前，层叠在上的优先)
    定义 可变 child = obj.最后子
    当 (child != 空) {
        定义 hit = 布局Object_命中测试(child, testX, testY)
        如果 (hit != 空) { 返回 hit }
        child = child.前兄
    }
    // 没有子节点命中，返回自身
    返回 obj
}

// §11 语义感知优先级 (Semantic Priority)
// NILE-SP: 根据DOM节点语义角色调整布局优先级

定义 语义_主内容  = 0   // <main>, <article> → 最高优先
定义 语义_导航    = 1   // <nav>, <header> → 高优先
定义 语义_侧边栏  = 2   // <aside> → 中优先
定义 语义_页脚    = 3   // <footer> → 低优先
定义 语义_广告    = 4   // 广告元素 → 最低优先

函数 布局Object_设置语义优先级(obj, 语义角色) {
    如果 (obj == 空) { 返回 }
    如果 (语义角色 == 语义_主内容) {
        obj.布局优先级 = 250
        obj.布局精度 = 3
    } 否则 如果 (语义角色 == 语义_导航) {
        obj.布局优先级 = 200
        obj.布局精度 = 3
    } 否则 如果 (语义角色 == 语义_侧边栏) {
        obj.布局优先级 = 128
        obj.布局精度 = 2
    } 否则 如果 (语义角色 == 语义_页脚) {
        obj.布局优先级 = 64
        obj.布局精度 = 1
    } 否则 如果 (语义角色 == 语义_广告) {
        obj.布局优先级 = 16
        obj.布局精度 = 0  // 可跳过
    }
}

// §12 布局树统计与调试

函数 布局Object_统计树(根, 总节点数, 总脏节点数) {
    // 统计布局树信息
    如果 (根 == 空) { 返回 }
    内存_写64(总节点数, 内存_读64(总节点数) + 1)
    如果 (布局Object_需要布局(根)) {
        内存_写64(总脏节点数, 内存_读64(总脏节点数) + 1)
    }
    定义 可变 child = 根.第一子
    当 (child != 空) {
        布局Object_统计树(child, 总节点数, 总脏节点数)
        child = child.后兄
    }
}

函数 布局Object_设置样式(obj, 样式) {
    如果 (obj == 空) { 返回 }
    obj.样式 = 样式
    布局Object_标记脏(obj)
}

函数 布局Object_获取类型名称(obj) {
    如果 (obj == 空) { 返回 "空" }
    如果 (obj.类型 == 布局类型_块) { 返回 "块" }
    如果 (obj.类型 == 布局类型_内联) { 返回 "内联" }
    如果 (obj.类型 == 布局类型_文本) { 返回 "文本" }
    如果 (obj.类型 == 布局类型_弹性) { 返回 "弹性" }
    如果 (obj.类型 == 布局类型_网格) { 返回 "网格" }
    如果 (obj.类型 == 布局类型_视图) { 返回 "视图" }
    返回 "其他"
}

函数 布局Object_获取边界(根, 结果x, 结果y, 结果宽, 结果高) {
    如果 (根 == 空) { 返回 }
    内存_写32(结果x, 根.绝对x)
    内存_写32(结果y, 根.绝对y)
    内存_写32(结果宽, 根.内容宽)
    内存_写32(结果高, 根.内容高)
}

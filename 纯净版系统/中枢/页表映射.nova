// NovaOS 页表映射
// 职责: 建立/取消虚拟→物理映射, 中间页表自动创建

定义 可变 映射_总次数 = 0
定义 可变 映射_失败次数 = 0
定义 可变 取消映射_总次数 = 0
定义 可变 中间页表_分配次数 = 0

// 中间页表分配: 确保从PML4到PT的完整路径存在

// 分配一个清零的物理页用作页表
函数 映射_分配页表页() {
    定义 页号 = 伙伴系统_分配_带标志(0, GFP_KERNEL | GFP_ZERO)
    如果 (页号 < 0) { 返回 0 }
    定义 页 = 页描述符_获取(页号)
    如果 (页 != 空) {
        页描述符_设置标志(页, 页_内核)
    }
    中间页表_分配次数 = 中间页表_分配次数 + 1
    返回 页号 * 页大小  // 返回物理地址
}

// 确保PML4→PDPT路径存在, 返回PDPT的物理地址
函数 映射_确保PDPT(pml4_物理, 虚拟地址, 中间标志) {
    定义 pml4_虚拟 = 物理到虚拟(pml4_物理)
    定义 偏移 = PML4索引(虚拟地址) * 8
    定义 pml4e = 内存读64(pml4_虚拟 + 偏移)

    如果 (页表项_存在(pml4e)) {
        返回 页表项_地址(pml4e)
    }
    // 分配新PDPT
    定义 新页 = 映射_分配页表页()
    如果 (新页 == 0) { 返回 0 }
    定义 新条目 = 页表项_创建(新页, 中间标志)
    内存写64(pml4_虚拟 + 偏移, 新条目)
    返回 新页
}

// 确保PDPT→PD路径存在, 返回PD的物理地址
函数 映射_确保PD(pdpt_物理, 虚拟地址, 中间标志) {
    定义 pdpt_虚拟 = 物理到虚拟(pdpt_物理)
    定义 偏移 = PDPT索引(虚拟地址) * 8
    定义 pdpte = 内存读64(pdpt_虚拟 + 偏移)

    如果 (页表项_存在(pdpte)) {
        如果 (页表项_是大页(pdpte)) { 返回 0 }  // 已是1GB大页, 不能再细分
        返回 页表项_地址(pdpte)
    }
    定义 新页 = 映射_分配页表页()
    如果 (新页 == 0) { 返回 0 }
    定义 新条目 = 页表项_创建(新页, 中间标志)
    内存写64(pdpt_虚拟 + 偏移, 新条目)
    返回 新页
}

// 确保PD→PT路径存在, 返回PT的物理地址
函数 映射_确保PT(pd_物理, 虚拟地址, 中间标志) {
    定义 pd_虚拟 = 物理到虚拟(pd_物理)
    定义 偏移 = PD索引(虚拟地址) * 8
    定义 pde = 内存读64(pd_虚拟 + 偏移)

    如果 (页表项_存在(pde)) {
        如果 (页表项_是大页(pde)) { 返回 0 }  // 已是2MB大页
        返回 页表项_地址(pde)
    }
    定义 新页 = 映射_分配页表页()
    如果 (新页 == 0) { 返回 0 }
    定义 新条目 = 页表项_创建(新页, 中间标志)
    内存写64(pd_虚拟 + 偏移, 新条目)
    返回 新页
}

// 单页映射: 建立一个4KB页的虚拟→物理映射

函数 映射_单页(pml4_物理, 虚拟地址, 物理地址, 标志) {
    // 确定中间页表的标志 (必须包含用户位如果最终PTE是用户页)
    定义 中间标志 = PTE_存在 | PTE_可写
    如果 ((标志 & PTE_用户) != 0) {
        中间标志 = 中间标志 | PTE_用户
    }

    // 确保完整路径: PML4→PDPT→PD→PT
    定义 pdpt_物理 = 映射_确保PDPT(pml4_物理, 虚拟地址, 中间标志)
    如果 (pdpt_物理 == 0) {
        映射_失败次数 = 映射_失败次数 + 1
        返回 错误_内存不足
    }

    定义 pd_物理 = 映射_确保PD(pdpt_物理, 虚拟地址, 中间标志)
    如果 (pd_物理 == 0) {
        映射_失败次数 = 映射_失败次数 + 1
        返回 错误_内存不足
    }

    定义 pt_物理 = 映射_确保PT(pd_物理, 虚拟地址, 中间标志)
    如果 (pt_物理 == 0) {
        映射_失败次数 = 映射_失败次数 + 1
        返回 错误_内存不足
    }

    // 写入最终PTE
    定义 pt_虚拟 = 物理到虚拟(pt_物理)
    定义 偏移 = PT索引(虚拟地址) * 8
    定义 新PTE = 页表项_创建(物理地址, 标志)
    内存写64(pt_虚拟 + 偏移, 新PTE)

    // 刷新TLB
    TLB_刷新单页(虚拟地址)

    映射_总次数 = 映射_总次数 + 1
    返回 成功
}

// 范围映射: 连续虚拟地址 → 连续物理地址

函数 映射_范围(pml4_物理, 虚拟起始, 物理起始, 大小, 标志) {
    定义 页数 = 对齐到页(大小) / 页大小
    定义 可变 i = 0
    当 (i < 页数) {
        定义 虚拟 = 虚拟起始 + i * 页大小
        定义 物理 = 物理起始 + i * 页大小
        定义 结果 = 映射_单页(pml4_物理, 虚拟, 物理, 标志)
        如果 (结果 != 成功) {
            // 回滚已映射的页
            定义 可变 j = 0
            当 (j < i) {
                取消映射_单页(pml4_物理, 虚拟起始 + j * 页大小)
                j = j + 1
            }
            返回 结果
        }
        i = i + 1
    }
    返回 成功
}

// 映射散列物理页到连续虚拟地址 (vmalloc使用)
函数 映射_散列页(pml4_物理, 虚拟起始, 物理页号列表, 标志) {
    定义 页数 = 计数(物理页号列表)
    定义 可变 i = 0
    当 (i < 页数) {
        定义 虚拟 = 虚拟起始 + i * 页大小
        定义 物理 = 物理页号列表[i] * 页大小
        定义 结果 = 映射_单页(pml4_物理, 虚拟, 物理, 标志)
        如果 (结果 != 成功) {
            定义 可变 j = 0
            当 (j < i) {
                取消映射_单页(pml4_物理, 虚拟起始 + j * 页大小)
                j = j + 1
            }
            返回 结果
        }
        i = i + 1
    }
    返回 成功
}

// 取消映射: 清除PTE并刷新TLB

// 取消单页映射, 返回旧物理地址 (用于释放物理页)
函数 取消映射_单页(pml4_物理, 虚拟地址) {
    定义 pte_位置 = 页表_查找PTE位置(pml4_物理, 虚拟地址)
    如果 (pte_位置 == 0) { 返回 错误_未映射 }

    定义 旧PTE = 内存读64(pte_位置)
    如果 (!页表项_存在(旧PTE)) { 返回 错误_未映射 }

    // 清除PTE
    内存写64(pte_位置, 0)
    TLB_刷新单页(虚拟地址)

    取消映射_总次数 = 取消映射_总次数 + 1
    返回 页表项_地址(旧PTE)
}

// 取消范围映射
函数 取消映射_范围(pml4_物理, 虚拟起始, 大小) {
    定义 页数 = 对齐到页(大小) / 页大小
    定义 可变 释放的物理页 = []
    定义 可变 i = 0
    当 (i < 页数) {
        定义 结果 = 取消映射_单页(pml4_物理, 虚拟起始 + i * 页大小)
        如果 (结果 > 0) {
            追加(释放的物理页, 结果 / 页大小)  // 页号
        }
        i = i + 1
    }
    返回 释放的物理页
}

// 取消范围映射并释放物理页
函数 取消映射_范围_释放(pml4_物理, 虚拟起始, 大小) {
    定义 页号列表 = 取消映射_范围(pml4_物理, 虚拟起始, 大小)
    定义 可变 i = 0
    当 (i < 计数(页号列表)) {
        伙伴系统_释放(页号列表[i], 0)
        i = i + 1
    }
}

// 权限修改: 修改已映射页的权限位

函数 映射_修改权限(pml4_物理, 虚拟地址, 新标志) {
    定义 pte_位置 = 页表_查找PTE位置(pml4_物理, 虚拟地址)
    如果 (pte_位置 == 0) { 返回 错误_未映射 }

    定义 旧PTE = 内存读64(pte_位置)
    如果 (!页表项_存在(旧PTE)) { 返回 错误_未映射 }

    定义 物理 = 页表项_地址(旧PTE)
    定义 新PTE = 页表项_创建(物理, 新标志)
    内存写64(pte_位置, 新PTE)
    TLB_刷新单页(虚拟地址)
    返回 成功
}

// 修改范围内所有页的权限
函数 映射_修改范围权限(pml4_物理, 虚拟起始, 大小, 新标志) {
    定义 页数 = 对齐到页(大小) / 页大小
    定义 可变 i = 0
    当 (i < 页数) {
        映射_修改权限(pml4_物理, 虚拟起始 + i * 页大小, 新标志)
        i = i + 1
    }
    返回 成功
}

// 2MB大页映射 (PD级别)

函数 映射_2MB大页(pml4_物理, 虚拟地址, 物理地址, 标志) {
    // 虚拟地址和物理地址必须2MB对齐
    如果 ((虚拟地址 & 0x1FFFFF) != 0) { 返回 错误_对齐 }
    如果 ((物理地址 & 0x1FFFFF) != 0) { 返回 错误_对齐 }

    定义 中间标志 = PTE_存在 | PTE_可写
    如果 ((标志 & PTE_用户) != 0) { 中间标志 = 中间标志 | PTE_用户 }

    定义 pdpt_物理 = 映射_确保PDPT(pml4_物理, 虚拟地址, 中间标志)
    如果 (pdpt_物理 == 0) { 返回 错误_内存不足 }

    定义 pd_物理 = 映射_确保PD(pdpt_物理, 虚拟地址, 中间标志)
    如果 (pd_物理 == 0) { 返回 错误_内存不足 }

    // 在PD级别设置大页 (带PS位)
    定义 pd_虚拟 = 物理到虚拟(pd_物理)
    定义 偏移 = PD索引(虚拟地址) * 8
    定义 新PDE = 页表项_创建(物理地址, 标志 | PTE_大页)
    内存写64(pd_虚拟 + 偏移, 新PDE)
    TLB_刷新单页(虚拟地址)

    映射_总次数 = 映射_总次数 + 1
    返回 成功
}

// 统计信息

函数 映射_统计信息() {
    返回 [映射_总次数, 映射_失败次数, 取消映射_总次数, 中间页表_分配次数]
}


函数 页表映射_完整统计() {
    返回 [映射_总次数, 映射_失败次数, 取消映射_总次数, 中间页表_分配次数]
}

// 页表映射诊断

函数 页表映射_健康检查() {
    定义 可变 问题 = []
    如果 (映射_失败次数 > 映射_总次数 / 10 && 映射_总次数 > 100) {
        追加(问题, "映射失败率过高: " + 整数转字符串(映射_失败次数))
    }
    如果 (中间页表_分配次数 > 10000) {
        追加(问题, "中间页表分配过多: " + 整数转字符串(中间页表_分配次数))
    }
    如果 (计数(问题) == 0) { 返回 "页表映射健康" }
    返回 问题
}

函数 页表_权限字符串(标志) {
    定义 可变 s = ""
    如果 (标志 & 1) { s = s + "P" }
    如果 (标志 & 2) { s = s + "W" }
    如果 (标志 & 4) { s = s + "U" }
    如果 (标志 & 8) { s = s + "T" }
    如果 (标志 & 0x80000000_00000000) { s = s + "NX" }
    返回 s
}

定义 可变 AI_页表映射_运行指标 = 0
定义 可变 AI_页表映射_异常指标 = 0

函数 AI_页表映射_自诊断() {
    AI_页表映射_运行指标 = 映射_总次数
    返回 AI_页表映射_运行指标
}

函数 AI_页表映射_优化建议() {
    定义 指标 = AI_页表映射_自诊断()
    如果 (AI_页表映射_运行指标 > 10000) { 返回 "页表映射负载较高" }
    返回 "页表映射状态正常"
}

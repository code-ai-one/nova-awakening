导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../稳态/鼠标.nova")
导入("../中枢/硬链接.nova")
导入("./智能交互入.nova")
导入("./网桌面引擎.nova")
导入("../中枢/字符串替换.nova")
导入("../外联/地址解析辅.nova")
导入("../稳态/键盘.nova")

定义 可变 浏览器系统会话_已初始化 = 假
定义 可变 浏览器系统会话_宽 = 1280
定义 可变 浏览器系统会话_高 = 800
定义 可变 浏览器系统会话_主窗口 = 0
定义 可变 浏览器系统会话_输入缓冲 = ""
定义 可变 浏览器系统会话_最后输入结果 = ""
定义 可变 浏览器系统会话_上次鼠标按钮 = 0

函数 浏览器系统会话_初始化(宽, 高) {
    浏览器系统会话_宽 = 宽
    浏览器系统会话_高 = 高
    鼠标_设置屏幕大小(宽, 高)
    浏览器系统会话_上次鼠标按钮 = 鼠标_获取按钮()
    如果 (浏览器系统会话_已初始化) {
        返回 浏览器系统会话_已初始化
    }
    AI交互入口_初始化()
    浏览器系统会话_已初始化 = Web桌面_初始化(宽, 高)
    返回 浏览器系统会话_已初始化
}

函数 浏览器系统会话_确保已初始化() {
    如果 (!浏览器系统会话_已初始化) {
        浏览器系统会话_初始化(浏览器系统会话_宽, 浏览器系统会话_高)
    }
}

函数 浏览器系统会话_启动默认桌面() {
    浏览器系统会话_确保已初始化()
    如果 (浏览器系统会话_主窗口 > 0) {
        返回 浏览器系统会话_主窗口
    }
    Web桌面_渲染帧()
    定义 桌面状态 = Web桌面_获取桌面状态()
    定义 几何 = Web桌面_获取主工作区窗口几何(计数(桌面状态.窗口列表) + 1)
    浏览器系统会话_主窗口 = Web桌面_打开窗口("NovaOS 终端", "nova://终端", 几何[0], 几何[1], 几何[2], 几何[3])
    返回 浏览器系统会话_主窗口
}

函数 浏览器系统会话_获取桌面上下文() {
    浏览器系统会话_确保已初始化()
    返回 Web桌面_获取桌面状态()
}

函数 浏览器系统会话_获取当前页面上下文() {
    浏览器系统会话_确保已初始化()
    返回 Web桌面_获取当前页面上下文()
}

函数 浏览器系统会话_执行页面动作(动作, 参数1, 参数2) {
    浏览器系统会话_确保已初始化()
    返回 Web桌面_执行页面动作(动作, 参数1, 参数2)
}

函数 浏览器系统会话_同步壳输入缓冲() {
    Web桌面_设置壳输入缓冲(浏览器系统会话_输入缓冲)
}

函数 浏览器系统会话_同步系统状态(核心状态, 核心副文本,
                           视觉状态, 视觉副文本,
                           声音状态, 声音副文本,
                           形象状态, 形象副文本) {
    浏览器系统会话_确保已初始化()
    Web桌面_同步系统状态(核心状态, 核心副文本,
                    视觉状态, 视觉副文本,
                    声音状态, 声音副文本,
                    形象状态, 形象副文本)
}

函数 浏览器系统会话_系统页标题(url) {
    如果 (字符串查找(url, "nova://ai") == 0) { 返回 "AI 工作台" }
    如果 (字符串查找(url, "nova://system") == 0) { 返回 "系统总线" }
    如果 (字符串查找(url, "nova://multimodal") == 0) { 返回 "多模态" }
    如果 (字符串查找(url, "nova://voice") == 0) { 返回 "语音中枢" }
    如果 (字符串查找(url, "nova://avatar") == 0) { 返回 "全息形象" }
    如果 (字符串查找(url, "nova://automation") == 0) { 返回 "自动化" }
    如果 (字符串查找(url, "nova://recovery") == 0) { 返回 "回滚恢复" }
    如果 (字符串查找(url, "nova://settings") == 0) { 返回 "设置" }
    如果 (字符串查找(url, "nova://setup") == 0) { 返回 "安装向导" }
    返回 "NovaOS 终端"
}

函数 浏览器系统会话_打开系统页(url, 原始输入) {
    定义 标题 = 浏览器系统会话_系统页标题(url)
    定义 桌面状态 = Web桌面_获取桌面状态()
    定义 几何 = Web桌面_获取主工作区窗口几何(计数(桌面状态.窗口列表) + 1)
    Web桌面_打开或聚焦窗口(标题, url, 几何[0], 几何[1], 几何[2], 几何[3])
    定义 结果 = "打开系统页: " + url
    Web桌面_记录壳状态(原始输入, "open-page", 结果)
    返回 结果
}

函数 浏览器系统会话_处理键盘字符(字符) {
    如果 (字符 == 8) {
        如果 (字符串长度(浏览器系统会话_输入缓冲) > 0) {
            浏览器系统会话_输入缓冲 = 子字符串(浏览器系统会话_输入缓冲, 0, 字符串长度(浏览器系统会话_输入缓冲) - 1)
        }
        浏览器系统会话_同步壳输入缓冲()
        返回 ""
    }

    如果 (字符 == 10 || 字符 == 13) {
        定义 提交输入 = 浏览器系统会话_输入缓冲
        浏览器系统会话_输入缓冲 = ""
        浏览器系统会话_同步壳输入缓冲()
        如果 (字符串长度(提交输入) == 0) {
            返回 ""
        }
        浏览器系统会话_最后输入结果 = 浏览器系统会话_处理系统输入(提交输入)
        返回 浏览器系统会话_最后输入结果
    }

    如果 (字符 >= 32 && 字符 < 127) {
        浏览器系统会话_输入缓冲 = 浏览器系统会话_输入缓冲 + 字符转字符串(字符)
        浏览器系统会话_同步壳输入缓冲()
    }
    返回 ""
}

函数 浏览器系统会话_处理鼠标输入() {
    定义 位置 = 鼠标_获取位置()
    定义 鼠标x = 位置[0]
    定义 鼠标y = 位置[1]
    定义 按钮 = 鼠标_获取按钮()
    定义 新左键按下 = ((按钮 & MOUSE_BTN_LEFT) != 0) && ((浏览器系统会话_上次鼠标按钮 & MOUSE_BTN_LEFT) == 0)

    浏览器系统会话_上次鼠标按钮 = 按钮
    如果 (!新左键按下) {
        返回 ""
    }

    如果 (Web桌面_命中启动器(鼠标x, 鼠标y)) {
        Web桌面_激活启动器()
        Web桌面_记录壳状态("launcher", "launcher", "主壳启动器已触发 · nova://终端")
        Web桌面_渲染帧()
        返回 "launcher"
    }

    定义 任务栏窗口ID = Web桌面_命中任务栏窗口(鼠标x, 鼠标y)
    如果 (任务栏窗口ID > 0) {
        Web桌面_激活任务栏窗口(任务栏窗口ID)
        Web桌面_渲染帧()
        返回 "taNova缓冲ar"
    }

    定义 图标索引 = Web桌面_命中图标索引(鼠标x, 鼠标y)
    如果 (图标索引 >= 0) {
        Web桌面_激活图标(图标索引)
        Web桌面_渲染帧()
        返回 "icon"
    }

    返回 ""
}

函数 浏览器系统会话_轮询输入() {
    浏览器系统会话_确保已初始化()
    定义 可变 结果 = ""
    当 (键盘_可读()) {
        定义 字符 = 键盘_读取()
        如果 (字符 < 0) {
            中断
        }
        结果 = 浏览器系统会话_处理键盘字符(字符)
    }
    定义 鼠标结果 = 浏览器系统会话_处理鼠标输入()
    如果 (字符串长度(鼠标结果) > 0) {
        结果 = 鼠标结果
    }
    返回 结果
}

函数 浏览器系统会话_渲染帧() {
    浏览器系统会话_确保已初始化()
    Web桌面_渲染帧()
}

函数 浏览器系统会话_处理系统输入(输入) {
    浏览器系统会话_确保已初始化()
    定义 修剪输入 = 字符串修剪(输入)
    如果 (字符串长度(修剪输入) == 0) {
        返回 ""
    }

    如果 (字符串查找(修剪输入, "nova://") == 0) {
        返回 浏览器系统会话_打开系统页(修剪输入, 修剪输入)
    }

    定义 系统页 = AI交互入口_匹配系统页(修剪输入)
    如果 (字符串长度(系统页) > 0) {
        返回 浏览器系统会话_打开系统页(系统页, 修剪输入)
    }

    定义 动作 = "终端-input"
    定义 首字 = 字符串子串(修剪输入, 0, 1)
    如果 (首字 == ">") {
        动作 = "command"
    } 否则 如果 (首字 == "@") {
        动作 = "dialogue"
    } 否则 如果 (首字 == "=") {
        动作 = "compute"
    }

    定义 结果 = AI交互入口_处理输入(修剪输入)
    Web桌面_记录壳状态(修剪输入, 动作, 结果)
    返回 结果
}

函数 浏览器系统会话_统计() {
    浏览器系统会话_确保已初始化()
    返回 [浏览器系统会话_主窗口, Web桌面_统计(), AI交互入口_统计()]
}

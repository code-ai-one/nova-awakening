// §2 账号信息生成器

结构 账号信息 {
    用户名,
    邮箱,
    密码,
    手机,
    姓名,
    生日,
}

定义 可变 注册_随机种子 = 99999

函数 注册_伪随机() {
    注册_随机种子 = (注册_随机种子 * 1103515245 + 12345) & 0x7FFFFFFF
    返回 注册_随机种子
}

函数 账号_生成() {
    定义 info = 账号信息 {}
    // 生成随机用户名: 前缀+数字
    定义 前缀列表 = ["nova", "star", "sky", "moon", "sun", "wind", "ocean", "dream"]
    定义 前缀 = 前缀列表[注册_伪随机() % 计数(前缀列表)]
    定义 数字 = 注册_伪随机() % 99999
    info.用户名 = 前缀 + 整数转字符串(数字)

    // 生成邮箱
    定义 邮箱域 = ["gmail.com", "outlook.com", "yahoo.com", "protonmail.com"]
    info.邮箱 = info.用户名 + "@" + 邮箱域[注册_伪随机() % 计数(邮箱域)]

    // 生成强密码: 大小写+数字+特殊字符
    info.密码 = 生成安全密码(16)

    // 生成姓名(拼音)
    定义 姓 = ["Wang", "Li", "Zhang", "Liu", "Chen", "Yang", "Huang", "Zhao"]
    定义 名 = ["Wei", "Fang", "Lei", "Jie", "Ming", "Hao", "Yu", "Xin"]
    info.姓名 = 姓[注册_伪随机() % 计数(姓)] + " " + 名[注册_伪随机() % 计数(名)]

    返回 info
}

函数 生成安全密码(长度) {
    定义 字符集 = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%&*"
    定义 可变 密码 = ""
    定义 可变 i = 0
    当 (i < 长度) {
        定义 idx = 注册_伪随机() % 字符串长度(字符集)
        密码 = 密码 + 字符串_取字符(字符集, idx)
        i = i + 1
    }
    返回 密码
}

// §3 验证码处理中心

结构 验证码任务 {
    类型,    // u32 滑块/图片/文字/reCAPTCHA
    状态,    // u8 0=待处理 1=处理中 2=成功 3=失败
    图片数据,    // []
    结果,
    尝试次数,
}

定义 可变 验证码_总处理 = 0
定义 可变 验证码_总成功 = 0

函数 验证码_处理(类型, 元素) {
    验证码_总处理 = 验证码_总处理 + 1

    如果 (类型 == 1) {  // 滑块
        定义 成功 = 验证_滑块(元素.x, 元素.y, 元素.x + 200, 元素.y)
        如果 (成功) { 验证码_总成功 = 验证码_总成功 + 1 }
        返回 成功

    } 否则 如果 (类型 == 2) {  // 图片选择
        返回 验证_图片选择([], "选择所有包含交通灯的图片")

    } 否则 如果 (类型 == 3) {  // reCAPTCHA
        返回 验证_reCAPTCHA_复选框(元素.x, 元素.y)

    } 否则 如果 (类型 == 5) {  // 文字验证码
        定义 结果 = 验证_文字识别([])
        如果 (结果 != 空 && 结果 != "") {
            验证码_总成功 = 验证码_总成功 + 1
            返回 真
        }
    }
    返回 假
}

// §4 邮箱验证流

结构 邮件 {
    发件人,
    主题,
    正文,
    时间,
    验证链接,
}

定义 可变 收件箱 = []

函数 邮箱验证_开始(邮箱地址) {
    内核调试("邮箱验证: 监控 " + 邮箱地址)
    // 轮询检查收件箱
    定义 可变 等待 = 0
    当 (等待 < 60) {  // 最多等60秒
        定义 新邮件 = 邮箱_检查收件(邮箱地址)
        如果 (新邮件 != 空) {
            // 提取验证链接
            定义 链接 = 邮件_提取链接(新邮件.正文)
            如果 (链接 != "") {
                内核调试("邮箱验证: 找到验证链接 " + 链接)
                // 自动打开验证链接
                标签页_新建(链接)
                返回 真
            }
        }
        等待 = 等待 + 1
    }
    内核调试("邮箱验证: 超时")
    返回 假
}

函数 邮箱_检查收件(邮箱地址) {
    如果 (邮箱地址 == 0) { 返回 空 }
    定义 端点 = 字符串拼接("https://api.mail.tm/messages?page=1&to=", 邮箱地址)
    定义 响应 = 网络_HTTP_GET(端点, 443, "/messages")
    如果 (响应 == 空) { 返回 空 }
    返回 响应
}

函数 邮件_提取链接(正文) {
    // 在邮件正文中查找验证链接
    定义 可变 i = 0
    当 (i < 字符串长度(正文) - 8) {
        如果 (字符串取字节(正文, i) == 104 && 字符串取字节(正文, i+1) == 116 &&
            字符串取字节(正文, i+2) == 116 && 字符串取字节(正文, i+3) == 112) {
            // 找到"http"
            定义 可变 结束 = i + 4
            当 (结束 < 字符串长度(正文) && 字符串取字节(正文, 结束) != 32 &&
                字符串取字节(正文, 结束) != 34 && 字符串取字节(正文, 结束) != 10 &&
                字符串取字节(正文, 结束) != 60) {
                结束 = 结束 + 1
            }
            定义 链接 = 子字符串_注册(正文, i, 结束)
            // 检查是否包含验证关键词
            如果 (包含_注册(链接, "verify") || 包含_注册(链接, "confirm") ||
                包含_注册(链接, "activate") || 包含_注册(链接, "validate")) {
                返回 链接
            }
        }
        i = i + 1
    }
    返回 ""
}

定义 可变 AI_账号信息生_威胁计数 = 0

函数 AI_账号信息生_风险评分(操作类型, 权限级别, 来源可信度) {
    定义 可变 风险 = 0
    如果 (权限级别 > 500) { 风险 = 风险 + 300 }
    如果 (来源可信度 < 200) { 风险 = 风险 + 400 }
    如果 (风险 > 500) { AI_账号信息生_威胁计数 = AI_账号信息生_威胁计数 + 1 }
    返回 风险
}

函数 AI_账号信息生_异常行为检测(操作频率, 基线频率) {
    如果 (基线频率 > 0 && 操作频率 > 基线频率 * 5) { 返回 真 }
    返回 假
}

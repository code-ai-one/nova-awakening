// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 模块_获取ImportMeta(Nova运行时实例, 模块) {
    如果 (模块 == 0) { 返回 0 }
    定义 meta = Nova对象_创建(Nova运行时实例, 0)
    // import.meta.url — 模块的完整URL
    Nova对象_设置属性(meta, "url", PropDesc_创建_数据(模块.URL, 假, 真, 假))
    // import.meta.resolve(specifier) — 解析说明符为完整URL
    Nova对象_设置属性(meta, "resolve", PropDesc_创建_数据(
        JSNative_创建_ImportMetaResolve(Nova运行时实例, 模块), 假, 真, 假))
    返回 meta
}

// §12 辅助

函数 URL_合并(基, 相对) { 返回 相对 }
函数 字符串_结尾是(str, 后缀) {
    // 检查字符串是否以指定后缀结尾
    如果 (str == 0 || 后缀 == 0) { 返回 假 }
    定义 slen = 字节长度(str)
    定义 plen = 字节长度(后缀)
    如果 (plen > slen) { 返回 假 }
    定义 可变 i = 0
    当 (i < plen) {
        如果 (字节取(str, slen - plen + i) != 字节取(后缀, i)) { 返回 假 }
        i = i + 1
    }
    返回 真
}
函数 网络_获取模块(url) {
    // 通过网络栈获取ES模块源码
    如果 (url == 0) { 返回 0 }
    定义 host = URL_提取主机名(url)
    定义 ip = 域名_解析(host)
    如果 (ip == 0) { 返回 0 }
    定义 fd = 平台_tcp_连接(ip, 443)
    如果 (fd < 0) { 返回 0 }
    定义 tls = 安全_创建会话(fd, host)
    安全_握手(tls)
    定义 req = HTTP_创建请求("GET", url)
    HTTP_设置头(req, "Accept", "application/javascript")
    定义 resp = HTTP_发送并接收(tls, req)
    安全_关闭(tls)
    平台_close(fd)
    如果 (resp == 0 || resp.状态码 != 200) { 返回 0 }
    返回 resp.body
}
函数 Bytecode_执行模块(i, bc, len, env) {
    // 执行模块字节码: 创建模块栈帧并运行
    如果 (bc == 0 || i == 0) { 返回 Nova_未定义 }
    定义 frame = StackFrame_创建(FRAME_JS, bc, i.当前栈帧)
    frame.上下文 = env
    定义 保存帧 = i.当前栈帧
    i.当前栈帧 = frame
    定义 result = Bytecode_执行(i, frame)
    i.当前栈帧 = 保存帧
    返回 result
}
函数 Nova承诺_创建_内部(i) {
    定义 p = 堆_分配(Nova承诺)
    p.状态 = 0    // pending
    p.值 = Nova_未定义
    p.then回调数 = 0; p.then回调 = 0
    p.catch回调数 = 0; p.catch回调 = 0
    返回 Nova值_创建_Object(i, p)
}
函数 Nova承诺_resolve_内部(i, p, v) { 如果 (p != 0 && p.状态 == 0) { p.状态 = 1; p.值 = v; Nova承诺_触发回调(i, p) } }
函数 Nova承诺_reject_内部(i, p, e) { 如果 (p != 0 && p.状态 == 0) { p.状态 = 2; p.值 = e; Nova承诺_触发回调(i, p) } }


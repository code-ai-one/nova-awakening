导入("./渲染管线双.nova")

定义 粒子_最大 = 1024

定义 发射器_点 = 0
定义 发射器_圆 = 1
定义 发射器_矩形 = 2
定义 发射器_球 = 3
定义 发射器_锥 = 4

定义 粒子类型_光点 = 0
定义 粒子类型_火花 = 1
定义 粒子类型_烟雾 = 2
定义 粒子类型_光环 = 3
定义 粒子类型_拖尾 = 4
定义 粒子类型_星尘 = 5

结构 粒子 {
    位置,
    速度,
    加速度,
    颜色,
    结束颜色,
    生命,
    最大生命,
    大小,
    结束大小,
    alpha,
    类型,
    旋转,
    旋转速度,
}

结构 粒子发射器 {
    位置,
    方向,
    类型,
    粒子类型,
    速率,
    初始速度_最小,
    初始速度_最大,
    初始大小_最小,
    初始大小_最大,
    生命_最小,
    生命_最大,
    颜色_开始,
    颜色_结束,
    扩散角度,
    重力,
    风力,
    湍流强度,
    已发射总数,
    活跃,
}

结构 粒子统计 {
    总发射数,
    总消亡数,
    当前活跃数,
    峰值活跃数,
    总帧数,
    总渲染像素数,
}

定义 可变 粒子池 = []
定义 可变 粒子_活跃数 = 0
定义 可变 发射器列表 = []
定义 可变 全局_粒子统计 = 空
定义 可变 随机种子 = 12345

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 粒子_初始化() {
    如果 (全局_粒子统计 == 空) {
        全局_粒子统计 = 粒子统计 {}
        全局_粒子统计.总发射数 = 0
        全局_粒子统计.总消亡数 = 0
        全局_粒子统计.当前活跃数 = 0
        全局_粒子统计.峰值活跃数 = 0
        全局_粒子统计.总帧数 = 0
        全局_粒子统计.总渲染像素数 = 0
    }
}

函数 粒子_伪随机() {
    随机种子 = (随机种子 * 1103515245 + 12345) & 0x7FFFFFFF
    返回 随机种子
}

函数 粒子_随机范围(最小, 最大) {
    如果 (最大 <= 最小) { 返回 最小 }
    返回 最小 + (粒子_伪随机() % (最大 - 最小 + 1))
}

函数 粒子_颜色插值(c1, c2, t) {
    如果 (t <= 0) { 返回 c1 }
    如果 (t >= 255) { 返回 c2 }

    定义 r1 = (c1 >> 16) & 0xFF
    定义 g1 = (c1 >> 8) & 0xFF
    定义 b1 = c1 & 0xFF

    定义 r2 = (c2 >> 16) & 0xFF
    定义 g2 = (c2 >> 8) & 0xFF
    定义 b2 = c2 & 0xFF

    定义 r = r1 + (r2 - r1) * t / 255
    定义 g = g1 + (g2 - g1) * t / 255
    定义 b = b1 + (b2 - b1) * t / 255

    返回 (r << 16) | (g << 8) | b
}

函数 粒子_发射(位置, 速度, 颜色, 生命) {
    粒子_初始化()
    如果 (粒子_活跃数 >= 粒子_最大) { 返回 }
    定义 p = 粒子 {}
    p.位置 = 位置
    p.速度 = 速度
    p.加速度 = 向量3_新(0, 0, 0)
    p.颜色 = 颜色
    p.结束颜色 = 颜色
    p.生命 = 生命
    p.最大生命 = 生命
    p.大小 = 2
    p.结束大小 = 1
    p.alpha = 200
    p.类型 = 粒子类型_光点
    p.旋转 = 0
    p.旋转速度 = 0
    追加(粒子池, p)
    粒子_活跃数 = 粒子_活跃数 + 1
    全局_粒子统计.总发射数 = 全局_粒子统计.总发射数 + 1
    如果 (粒子_活跃数 > 全局_粒子统计.峰值活跃数) {
        全局_粒子统计.峰值活跃数 = 粒子_活跃数
    }
}

函数 粒子_发射高级(位置, 速度, 加速度, 颜色始, 颜色终, 生命, 大小始, 大小终, 类型) {
    粒子_初始化()
    如果 (粒子_活跃数 >= 粒子_最大) { 返回 }
    定义 p = 粒子 {}
    p.位置 = 位置
    p.速度 = 速度
    p.加速度 = 加速度
    p.颜色 = 颜色始
    p.结束颜色 = 颜色终
    p.生命 = 生命
    p.最大生命 = 生命
    p.大小 = 大小始
    p.结束大小 = 大小终
    p.alpha = 255
    p.类型 = 类型
    p.旋转 = 粒子_随机范围(0, 360)
    p.旋转速度 = 粒子_随机范围(-5, 5)
    追加(粒子池, p)
    粒子_活跃数 = 粒子_活跃数 + 1
    全局_粒子统计.总发射数 = 全局_粒子统计.总发射数 + 1
    如果 (粒子_活跃数 > 全局_粒子统计.峰值活跃数) {
        全局_粒子统计.峰值活跃数 = 粒子_活跃数
    }
}

函数 粒子_爆发(位置, 数量, 颜色, 速度范围, 生命) {
    定义 可变 i = 0
    当 (i < 数量 && 粒子_活跃数 < 粒子_最大) {
        定义 角度 = (i * 360) / 数量
        定义 速 = 粒子_随机范围(速度范围 / 2, 速度范围)
        定义 vx = 速 * 数学_余弦(角度) / 1000
        定义 vy = 速 * 数学_正弦(角度) / 1000
        粒子_发射(位置, 向量3_新(vx, vy, 0), 颜色, 生命)
        i = i + 1
    }
}

函数 创建发射器(位置, 方向, 类型, 速率) {
    定义 e = 粒子发射器 {}
    e.位置 = 位置
    e.方向 = 方向
    e.类型 = 类型
    e.粒子类型 = 粒子类型_光点
    e.速率 = 速率
    e.初始速度_最小 = 5
    e.初始速度_最大 = 15
    e.初始大小_最小 = 1
    e.初始大小_最大 = 3
    e.生命_最小 = 30
    e.生命_最大 = 90
    e.颜色_开始 = 0x66EEFF
    e.颜色_结束 = 0x003366
    e.扩散角度 = 30
    e.重力 = 0
    e.风力 = 0
    e.湍流强度 = 0
    e.已发射总数 = 0
    e.活跃 = 真
    追加(发射器列表, e)
    返回 e
}

函数 发射器_更新(e, 帧) {
    如果 (!e.活跃) { 返回 }
    如果 (帧 % e.速率 != 0) { 返回 }

    定义 可变 发射位置 = e.位置

    如果 (e.类型 == 发射器_圆) {
        定义 角 = 粒子_随机范围(0, 360)
        定义 半径 = 粒子_随机范围(0, 50)
        发射位置 = 向量3_新(
            e.位置.x + 半径 * 数学_余弦(角) / 1000,
            e.位置.y + 半径 * 数学_正弦(角) / 1000,
            e.位置.z)
    } 否则 如果 (e.类型 == 发射器_矩形) {
        发射位置 = 向量3_新(
            e.位置.x + 粒子_随机范围(-100, 100),
            e.位置.y + 粒子_随机范围(-100, 100),
            e.位置.z)
    }

    定义 速 = 粒子_随机范围(e.初始速度_最小, e.初始速度_最大)
    定义 扩散 = 粒子_随机范围(-e.扩散角度, e.扩散角度)
    定义 vx = e.方向.x * 速 / 10 + 扩散 / 10
    定义 vy = e.方向.y * 速 / 10
    定义 加速 = 向量3_新(e.风力, e.重力, 0)
    定义 生命 = 粒子_随机范围(e.生命_最小, e.生命_最大)
    定义 大小 = 粒子_随机范围(e.初始大小_最小, e.初始大小_最大)

    粒子_发射高级(发射位置, 向量3_新(vx, vy, 0), 加速,
                   e.颜色_开始, e.颜色_结束, 生命, 大小, 1, e.粒子类型)
    e.已发射总数 = e.已发射总数 + 1
}

函数 粒子_更新并渲染(fb) {
    粒子_初始化()
    全局_粒子统计.总帧数 = 全局_粒子统计.总帧数 + 1

    定义 可变 e = 0
    当 (e < 计数(发射器列表)) {
        发射器_更新(发射器列表[e], 全局_粒子统计.总帧数)
        e = e + 1
    }

    定义 可变 i = 0
    当 (i < 计数(粒子池)) {
        如果 (粒子池[i].生命 <= 0) {
            删除(粒子池, i)
            粒子_活跃数 = 粒子_活跃数 - 1
            全局_粒子统计.总消亡数 = 全局_粒子统计.总消亡数 + 1
            继续
        }

        定义 p = 粒子池[i]
        p.速度 = 向量3_加(p.速度, p.加速度)
        p.位置 = 向量3_加(p.位置, p.速度)
        p.生命 = p.生命 - 1
        p.旋转 = p.旋转 + p.旋转速度

        定义 进度 = 255 - (p.生命 * 255 / p.最大生命)
        p.alpha = 255 * p.生命 / p.最大生命
        定义 当前颜色 = 粒子_颜色插值(p.颜色, p.结束颜色, 进度)
        定义 当前大小 = p.大小 + (p.结束大小 - p.大小) * 进度 / 255

        定义 sx = 渲染_宽 / 2 + p.位置.x * 渲染_宽 / 2000
        定义 sy = 渲染_高 / 2 - p.位置.y * 渲染_高 / 2000

        如果 (sx >= 0 && sx < 渲染_宽 && sy >= 0 && sy < 渲染_高) {
            如果 (当前大小 <= 1) {
                全息_混合像素(fb, sx, sy, 当前颜色, p.alpha)
                全局_粒子统计.总渲染像素数 = 全局_粒子统计.总渲染像素数 + 1
            } 否则 {
                定义 可变 dy = -当前大小
                当 (dy <= 当前大小) {
                    定义 可变 dx = -当前大小
                    当 (dx <= 当前大小) {
                        定义 px = sx + dx
                        定义 py = sy + dy
                        如果 (px >= 0 && px < 渲染_宽 && py >= 0 && py < 渲染_高) {
                            定义 距离 = dx * dx + dy * dy
                            如果 (距离 <= 当前大小 * 当前大小) {
                                定义 衰减alpha = p.alpha * (当前大小 * 当前大小 - 距离) / (当前大小 * 当前大小)
                                全息_混合像素(fb, px, py, 当前颜色, 衰减alpha)
                                全局_粒子统计.总渲染像素数 = 全局_粒子统计.总渲染像素数 + 1
                            }
                        }
                        dx = dx + 1
                    }
                    dy = dy + 1
                }
            }
        }

        i = i + 1
    }

    全局_粒子统计.当前活跃数 = 粒子_活跃数
}

函数 全息_环境粒子(帧) {
    如果 (帧 % 3 == 0) {
        定义 随机x = (粒子_伪随机() % 400) - 200
        粒子_发射高级(
            向量3_新(随机x, -500, 0),
            向量3_新(0, 15, 0),
            向量3_新(0, 0, 0),
            0x66EEFF, 0x003366, 60, 2, 0, 粒子类型_星尘)
    }

    如果 (帧 % 10 == 0) {
        定义 rx = (粒子_伪随机() % 600) - 300
        粒子_发射高级(
            向量3_新(rx, -600, 0),
            向量3_新(粒子_随机范围(-3, 3), 8, 0),
            向量3_新(0, 0, 0),
            0xFFAA44, 0xFF2200, 90, 3, 1, 粒子类型_火花)
    }
}

函数 粒子_清除全部() {
    粒子池 = []
    粒子_活跃数 = 0
}

函数 粒子_打印统计() {
    粒子_初始化()
    打印行("=== 粒子系统统计 ===")
    打印行("总发射: " + 整数转字符串(全局_粒子统计.总发射数))
    打印行("总消亡: " + 整数转字符串(全局_粒子统计.总消亡数))
    打印行("当前活跃: " + 整数转字符串(全局_粒子统计.当前活跃数))
    打印行("峰值活跃: " + 整数转字符串(全局_粒子统计.峰值活跃数))
    打印行("总帧数: " + 整数转字符串(全局_粒子统计.总帧数))
    打印行("总渲染像素: " + 整数转字符串(全局_粒子统计.总渲染像素数))
    打印行("发射器数: " + 整数转字符串(计数(发射器列表)))
}

函数 正弦近似(角) { 返回 数学_正弦(角) }
函数 余弦近似(角) { 返回 数学_余弦(角) }

函数 全息渲染_完整统计() {
    粒子_初始化()
    返回 [全局_粒子统计.总帧数, 粒子_活跃数,
           渲染_宽, 渲染_高, 全局_粒子统计.峰值活跃数,
           全局_粒子统计.总渲染像素数]
}

定义 可变 AI_粒子系统全_帧率窗口 = []

函数 AI_粒子系统全_帧率预测(当前帧耗时) {
    追加(AI_粒子系统全_帧率窗口, 当前帧耗时)
    如果 (计数(AI_粒子系统全_帧率窗口) > 30) { 列表_移除(AI_粒子系统全_帧率窗口, 0) }
    如果 (计数(AI_粒子系统全_帧率窗口) < 3) { 返回 60 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(AI_粒子系统全_帧率窗口)) { 总 = 总 + AI_粒子系统全_帧率窗口[i]; i = i + 1 }
    定义 平均帧耗时 = 总 / 计数(AI_粒子系统全_帧率窗口)
    如果 (平均帧耗时 == 0) { 返回 60 }
    返回 1000 / 平均帧耗时
}

函数 AI_粒子系统全_质量降级建议(帧率) {
    如果 (帧率 < 30) { 返回 "降低分辨率" }
    如果 (帧率 < 45) { 返回 "跳过阴影" }
    返回 "全质量"
}

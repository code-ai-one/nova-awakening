// NovaOS ICMP 探测与诊断
// ping/多次ping/traceroute/RTT统计/丢包率/统计

定义 PING_默认超时 = 3000       // 毫秒
定义 PING_默认数据大小 = 56     // 字节
定义 PING_最大跳数 = 30
定义 PING_最大历史 = 128

定义 可变 ping_等待队列 = 空
定义 可变 ping_最后应答IP = 0
定义 可变 ping_最后标识符 = 0
定义 可变 ping_最后序列号 = 0
定义 可变 ping_已收到应答 = 假
定义 可变 ping_应答TTL = 0

定义 可变 rtt_历史 = []
定义 可变 rtt_索引 = 0

结构 探测统计 {
    ping次数,
    成功次数,
    超时次数,
    错误次数,
    总RTT,
    最小RTT,
    最大RTT,
    traceroute次数,
    多次ping次数,
}

定义 可变 全局_探测统计 = 空

函数 探测统计_初始化() {
    如果 (全局_探测统计 == 空) {
        全局_探测统计 = 探测统计 {}
        全局_探测统计.ping次数 = 0
        全局_探测统计.成功次数 = 0
        全局_探测统计.超时次数 = 0
        全局_探测统计.错误次数 = 0
        全局_探测统计.总RTT = 0
        全局_探测统计.最小RTT = 999999
        全局_探测统计.最大RTT = 0
        全局_探测统计.traceroute次数 = 0
        全局_探测统计.多次ping次数 = 0
    }
}

// §1 应答接收

函数 ping_接收应答(源IP, 标识符, 序列号) {
    ping_最后应答IP = 源IP
    ping_最后标识符 = 标识符
    ping_最后序列号 = 序列号
    ping_已收到应答 = 真
    如果 (ping_等待队列 != 空) {
        等待队列_唤醒全部(ping_等待队列)
    }
}

函数 ping_接收应答_扩展(源IP, 标识符, 序列号, ttl) {
    ping_最后应答IP = 源IP
    ping_最后标识符 = 标识符
    ping_最后序列号 = 序列号
    ping_应答TTL = ttl
    ping_已收到应答 = 真
    如果 (ping_等待队列 != 空) {
        等待队列_唤醒全部(ping_等待队列)
    }
}

// §2 单次ping

函数 ping(目标IP, 超时_毫秒) {
    探测统计_初始化()
    全局_探测统计.ping次数 = 全局_探测统计.ping次数 + 1

    定义 标识符 = 获取当前进程().pid & 0xFFFF
    ping_已收到应答 = 假

    定义 发送时间 = 当前时间_毫秒()
    定义 结果 = icmp_发送回显(目标IP, 标识符, 空, PING_默认数据大小)
    如果 (结果 != 0) {
        全局_探测统计.错误次数 = 全局_探测统计.错误次数 + 1
        返回 结果
    }

    // 等待应答
    定义 截止时间 = 发送时间 + 超时_毫秒
    当 (!ping_已收到应答) {
        如果 (当前时间_毫秒() >= 截止时间) {
            全局_探测统计.超时次数 = 全局_探测统计.超时次数 + 1
            返回 错误码_超时
        }
        schedule_timeout(10)
    }

    定义 rtt = 当前时间_毫秒() - 发送时间
    ping_记录RTT(rtt)
    全局_探测统计.成功次数 = 全局_探测统计.成功次数 + 1
    全局_探测统计.总RTT = 全局_探测统计.总RTT + rtt
    如果 (rtt < 全局_探测统计.最小RTT) { 全局_探测统计.最小RTT = rtt }
    如果 (rtt > 全局_探测统计.最大RTT) { 全局_探测统计.最大RTT = rtt }

    返回 rtt
}

函数 ping_记录RTT(rtt) {
    如果 (计数(rtt_历史) < PING_最大历史) {
        追加(rtt_历史, rtt)
    } 否则 {
        rtt_历史[rtt_索引 % PING_最大历史] = rtt
    }
    rtt_索引 = rtt_索引 + 1
}

// §3 多次ping

函数 ping_多次(目标IP, 次数, 间隔_毫秒, 超时_毫秒) {
    探测统计_初始化()
    全局_探测统计.多次ping次数 = 全局_探测统计.多次ping次数 + 1

    定义 可变 发送数 = 0
    定义 可变 接收数 = 0
    定义 可变 rtt_总 = 0
    定义 可变 rtt_最小 = 999999
    定义 可变 rtt_最大 = 0

    内核打印("PING %s: %d 字节数据\n", IP地址_转字符串(目标IP), PING_默认数据大小)

    定义 可变 i = 0
    当 (i < 次数) {
        定义 rtt = ping(目标IP, 超时_毫秒)
        发送数 = 发送数 + 1

        如果 (rtt >= 0) {
            接收数 = 接收数 + 1
            rtt_总 = rtt_总 + rtt
            如果 (rtt < rtt_最小) { rtt_最小 = rtt }
            如果 (rtt > rtt_最大) { rtt_最大 = rtt }
            内核打印("来自 %s 的应答: 序列=%d TTL=%d 时间=%d ms\n",
                IP地址_转字符串(ping_最后应答IP), i + 1, ping_应答TTL, rtt)
        } 否则 {
            内核打印("请求超时 序列=%d\n", i + 1)
        }

        如果 (i < 次数 - 1) {
            schedule_timeout(间隔_毫秒)
        }
        i = i + 1
    }

    // 打印汇总
    定义 丢包率 = 0
    如果 (发送数 > 0) { 丢包率 = (发送数 - 接收数) * 100 / 发送数 }
    定义 平均RTT = 0
    如果 (接收数 > 0) { 平均RTT = rtt_总 / 接收数 }

    内核打印("\n--- %s ping 统计 ---\n", IP地址_转字符串(目标IP))
    内核打印("%d 个包已发送, %d 个已接收, %d%% 丢包\n", 发送数, 接收数, 丢包率)
    如果 (接收数 > 0) {
        内核打印("RTT 最小/平均/最大 = %d/%d/%d ms\n", rtt_最小, 平均RTT, rtt_最大)
    }

    返回 [发送数, 接收数, 丢包率, rtt_最小, 平均RTT, rtt_最大]
}

// §4 traceroute

函数 traceroute(目标IP, 最大跳数, 超时_毫秒) {
    探测统计_初始化()
    全局_探测统计.traceroute次数 = 全局_探测统计.traceroute次数 + 1

    如果 (最大跳数 <= 0) { 最大跳数 = PING_最大跳数 }
    如果 (超时_毫秒 <= 0) { 超时_毫秒 = PING_默认超时 }

    内核打印("traceroute to %s, 最大 %d 跳\n", IP地址_转字符串(目标IP), 最大跳数)

    定义 标识符 = 获取当前进程().pid & 0xFFFF
    定义 可变 跳数 = 1

    当 (跳数 <= 最大跳数) {
        ping_已收到应答 = 假
        定义 发送时间 = 当前时间_毫秒()

        // 发送TTL受限的ICMP探测
        定义 结果 = icmp_发送回显_TTL(目标IP, 标识符, 跳数, 空, 32)
        如果 (结果 != 0) {
            内核打印("%2d  * * *\n", 跳数)
            跳数 = 跳数 + 1
            继续
        }

        // 等待应答(超时或TTL过期)
        定义 截止时间 = 发送时间 + 超时_毫秒
        当 (!ping_已收到应答) {
            如果 (当前时间_毫秒() >= 截止时间) { 跳出 }
            schedule_timeout(10)
        }

        如果 (ping_已收到应答) {
            定义 rtt = 当前时间_毫秒() - 发送时间
            内核打印("%2d  %s  %d ms\n", 跳数, IP地址_转字符串(ping_最后应答IP), rtt)

            // 到达目标?
            如果 (ping_最后应答IP == 目标IP) {
                内核打印("到达目标!\n")
                返回 跳数
            }
        } 否则 {
            内核打印("%2d  * * *\n", 跳数)
        }

        跳数 = 跳数 + 1
    }

    内核打印("未到达目标\n")
    返回 -1
}

// §5 RTT统计分析

函数 ping_平均RTT() {
    定义 数量 = 计数(rtt_历史)
    如果 (数量 == 0) { 返回 0 }
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < 数量) {
        总和 = 总和 + rtt_历史[i]
        i = i + 1
    }
    返回 总和 / 数量
}

函数 ping_抖动() {
    // 平均连续差值
    定义 数量 = 计数(rtt_历史)
    如果 (数量 < 2) { 返回 0 }
    定义 可变 差值总和 = 0
    定义 可变 i = 1
    当 (i < 数量) {
        定义 差 = rtt_历史[i] - rtt_历史[i - 1]
        如果 (差 < 0) { 差 = -差 }
        差值总和 = 差值总和 + 差
        i = i + 1
    }
    返回 差值总和 / (数量 - 1)
}

函数 ping_丢包率() {
    探测统计_初始化()
    如果 (全局_探测统计.ping次数 == 0) { 返回 0 }
    返回 (全局_探测统计.ping次数 - 全局_探测统计.成功次数) * 100 / 全局_探测统计.ping次数
}

// §6 ICMP统计与类型

函数 icmp_打印统计() {
    内核打印("=== ICMP统计 ===\n")
    内核打印("  接收: %d (错误=%d)\n", icmp统计.接收总数, icmp统计.接收错误)
    内核打印("  发送: %d (错误=%d)\n", icmp统计.发送总数, icmp统计.发送错误)
    内核打印("  回显请求: 收=%d 发=%d\n", icmp统计.回显请求收, icmp统计.回显请求发)
    内核打印("  回显应答: 收=%d 发=%d\n", icmp统计.回显应答收, icmp统计.回显应答发)
    内核打印("  不可达: 收=%d 发=%d\n", icmp统计.不可达收, icmp统计.不可达发)
    内核打印("  限速丢弃: %d\n", icmp统计.限速丢弃)
}

函数 ICMP_类型名(类型) {
    如果 (类型 == 0) { 返回 "echo_reply" }
    如果 (类型 == 3) { 返回 "dest_unreachable" }
    如果 (类型 == 4) { 返回 "source_quench" }
    如果 (类型 == 5) { 返回 "redirect" }
    如果 (类型 == 8) { 返回 "echo_request" }
    如果 (类型 == 11) { 返回 "time_exceeded" }
    如果 (类型 == 12) { 返回 "parameter_problem" }
    如果 (类型 == 13) { 返回 "timestamp_request" }
    如果 (类型 == 14) { 返回 "timestamp_reply" }
    返回 "type_" + 整数转字符串(类型)
}

函数 ICMP_完整统计() {
    返回 [icmp统计.接收总数, icmp统计.发送总数, icmp统计.接收错误, icmp统计.限速丢弃]
}

// §7 综合统计

函数 探测_打印统计() {
    探测统计_初始化()
    打印行("=== 网络探测统计 ===")
    打印行("ping次数: " + 整数转字符串(全局_探测统计.ping次数))
    打印行("成功次数: " + 整数转字符串(全局_探测统计.成功次数))
    打印行("超时次数: " + 整数转字符串(全局_探测统计.超时次数))
    打印行("错误次数: " + 整数转字符串(全局_探测统计.错误次数))
    打印行("丢包率: " + 整数转字符串(ping_丢包率()) + "%")
    如果 (全局_探测统计.成功次数 > 0) {
        定义 平均 = 全局_探测统计.总RTT / 全局_探测统计.成功次数
        打印行("平均RTT: " + 整数转字符串(平均) + " ms")
        打印行("最小RTT: " + 整数转字符串(全局_探测统计.最小RTT) + " ms")
        打印行("最大RTT: " + 整数转字符串(全局_探测统计.最大RTT) + " ms")
        打印行("抖动: " + 整数转字符串(ping_抖动()) + " ms")
    }
    打印行("traceroute: " + 整数转字符串(全局_探测统计.traceroute次数))
    打印行("多次ping: " + 整数转字符串(全局_探测统计.多次ping次数))
    打印行("RTT历史: " + 整数转字符串(计数(rtt_历史)) + " 条")
    icmp_打印统计()
}

定义 可变 AI_探测接收应_调用数 = 0
定义 可变 AI_探测接收应_异常数 = 0

函数 AI_探测接收应_监控() {
    AI_探测接收应_调用数 = AI_探测接收应_调用数 + 1
    返回 AI_探测接收应_异常数 == 0
}

函数 AI_探测接收应_健康检查() {
    如果 (AI_探测接收应_调用数 > 0 && AI_探测接收应_异常数 * 100 / AI_探测接收应_调用数 > 10) {
        返回 假
    }
    返回 真
}

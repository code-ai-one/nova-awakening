// Nova · GPU FFI桥接层
// 这是Nova语言和GPU硬件之间的核心连接
// 【为什么需要这个桥？】
// GPU API (CUDA/HIP/oneAPI) 使用C语言调用约定
// Nova编译器生成的机器码已经能直接调用C函数:
// - AOT模式: 编译器内置 __运行时_加载库 + __运行时_取函数地址
// - 解释模式: VM通过内建函数调用同样的FFI
// - JIT模式: JIT生成的机器码直接call函数指针
// 【这个桥有多大？】
// 纯Nova代码，几百行。不是C/Rust外壳。
// 因为Nova编译器已经能生成直接调用LoadLibrary/dlopen的机器码。
// 【调用链路】
// AOT: Nova源码→编译→.exe→LoadLibrary("nvcuda.dll")→cuInit→GPU
// VM: Nova源码→字节码→VM→FFI内建→LoadLibrary→cuInit→GPU
// JIT: Nova源码→字节码→热点→机器码→call函数指针→GPU

// FFI底层原语由编译器内建处理
// 加载库(x) → call __运行时_加载库
// 获取函数(a,b) → call __运行时_取函数地址
// 无需源码层 wrapper，否则会导致符号覆盖产生无限递归

// FFI句柄缓存 (避免重复加载)
定义 可变 _ffi缓存 = 字典()
定义 可变 _ffi函数缓存 = 字典()

// 核心: 加载动态库
// AOT编译时: 直接编译为 call __运行时_加载库
// 解释器时: 通过VM内建函数转发
函数 加载动态库(库名) {
 // 检查缓存
 定义 缓存 = 字典获取(_ffi缓存, 库名)
 如果 (缓存 != 空 且 缓存 != 0) { 返回 缓存 }

 // 调用运行时FFI (编译后直接变成LoadLibrary/dlopen调用)
 定义 句柄 = 加载库(库名)

 如果 (句柄 != 0) {
 字典设置(_ffi缓存, 库名, 句柄)
 }
 返回 句柄
}

// 核心: 获取函数指针
函数 FFI_获取函数指针(库句柄, 函数名) { 定义 键 = 字符串拼接(转字符串(库句柄), 字符串拼接(":", 函数名))
 定义 缓存 = 字典获取(_ffi函数缓存, 键)
 如果 (缓存 != 空 且 缓存 != 0) { 返回 缓存 }

 定义 指针 = 获取函数(库句柄, 函数名)

 如果 (指针 != 0) {
 字典设置(_ffi函数缓存, 键, 指针)
 }
 返回 指针
}

// 核心: 外部调用 (通用C函数调用, 0, 0, 0, 0, 0, 0)
// 这是桥接的核心 — 通过函数指针调用任意C函数
// 编译器将此编译为: 设置寄存器→call 函数指针
// 参数通过x86-64 ABI传递: RCX, RDX, R8, R9, 栈
函数 外部调用(库句柄, 函数名, 参1, _扩4, _扩5, _扩6, _扩7) { 定义 函数指针 = FFI_获取函数指针(库句柄, 函数名)
 如果 (函数指针 == 0) { 返回 0 }
 返回 __ff指令_调用1(函数指针, 参1)
}

函数 外部调用2(库句柄, 函数名, 参1, 参2) { 定义 函数指针 = FFI_获取函数指针(库句柄, 函数名)
 如果 (函数指针 == 0) { 返回 0 }
 返回 __ff指令_调用2(函数指针, 参1, 参2)
}

函数 外部调用3(库句柄, 函数名, 参1, 参2, 参3) { 定义 函数指针 = FFI_获取函数指针(库句柄, 函数名)
 如果 (函数指针 == 0) { 返回 0 }
 返回 __ff指令_调用3(函数指针, 参1, 参2, 参3)
}

函数 外部调用4(库句柄, 函数名, 参1, 参2, 参3, 参4, _扩7) { 定义 函数指针 = FFI_获取函数指针(库句柄, 函数名)
 如果 (函数指针 == 0) { 返回 0 }
 返回 __ff指令_调用4(函数指针, 参1, 参2, 参3, 参4)
}

函数 外部调用5(库句柄, 函数名, 参1, 参2, 参3, 参4, 参5) { 定义 函数指针 = FFI_获取函数指针(库句柄, 函数名)
 如果 (函数指针 == 0) { 返回 0 }
 返回 __ff指令_调用5(函数指针, 参1, 参2, 参3, 参4, 参5)
}

函数 外部调用6(库句柄, 函数名, 参1, 参2, 参3, 参4, 参5, 参6, _扩9) { 定义 函数指针 = FFI_获取函数指针(库句柄, 函数名)
 如果 (函数指针 == 0) { 返回 0 }
 返回 __ff指令_调用6(函数指针, 参1, 参2, 参3, 参4, 参5, 参6)
}

// 变参数版本 (用于BLAS等多参数API)
函数 外部调用N(库句柄, 函数名, 参数列表) { 定义 函数指针 = FFI_获取函数指针(库句柄, 函数名)
 如果 (函数指针 == 0) { 返回 0 }
 返回 __ff指令_调用N(函数指针, 参数列表)
}

// 返回字符串的外部调用
函数 外部调用字符串(库句柄, 函数名, 参1, 参2) { 定义 函数指针 = FFI_获取函数指针(库句柄, 函数名)
 如果 (函数指针 == 0) { 返回 "" }
 定义 ptr = __ff指令_调用2(函数指针, 参1, 参2)
 返回 __运行时_C串转Nova(ptr) // C字符串指针→Nova字符串
}

// 系统环境变量读取
函数 系统环境(变量名) { 定义 目标 = 获取目标架构()
 如果 (目标 == "x86-64-win" 或 目标 == "x86-64") { 定义 kernel32 = 加载动态库("kernel32.dll")
 如果 (kernel32 == 0) { 返回 "" }
 返回 外部调用字符串(kernel32, "GetEnvironmentVariableA", 变量名, 256)
 }
 // Linux: getenv
 定义 libc = 加载动态库("libc.so.6")
 如果 (libc == 0) { 返回 "" }
 定义 ptr = 外部调用(libc,  "getenv",  变量名, 0, 0, 0, 0)
 如果 (ptr == 0) { 返回 "" }
 返回 __运行时_C串转Nova(ptr)
}

// 文件存在检测 (跨平台)
函数 FFI桥_文件存在(路径) {
 // 编译模式: 已有 __运行时_文件存在 运行时函数
 返回 __运行时_文件存在(路径) == 1
}

// GPU用户接口 — 这是Nova程序员直接使用的函数
// 和Python的 torch.cuda / cupy 一样简单

// GPU上下文 (全局单例)
定义 可变 _gpu管理器 = 空
定义 可变 _gpu显存 = 空
定义 可变 _gpu初始化完成 = 假

// 一键初始化
函数 GPU_初始化() {
    如果 (_gpu初始化完成) { 返回 真
}
 _gpu管理器 = GPU管理器_创建()
 定义 设备数 = GPU管理器_枚举设备(_gpu管理器)
 如果 (设备数 == 0) {
 打印("GPU: 未检测到GPU设备")
 返回 假
 }
 GPU管理器_自动选择(_gpu管理器)
 _gpu显存 = GPU显存_创建(_gpu管理器)
 _gpu初始化完成 = 真
 返回 真
}

// 分配GPU内存
函数 GPU_分配(字节数) {
    如果 (!_gpu初始化完成) { GPU_初始化()
}
 返回 GPU显存_分配(_gpu显存, 字节数, GPU内存_设备)
}

函数 GPU_统一分配(字节数) {
    如果 (!_gpu初始化完成) { GPU_初始化()
}
 返回 GPU显存_分配(_gpu显存, 字节数, GPU内存_统一)
}

// 上传数据到GPU
函数 GPU_上传(GPU块, CPU数据, 字节数) {
    如果 (!_gpu初始化完成) { GPU_初始化()
}
 返回 GPU显存_传输(_gpu显存, GPU内存块_指针(GPU块), CPU数据, 字节数, GPU传输_主机到设备)
}

// 从GPU下载数据
函数 GPU_下载(CPU缓冲, GPU块, 字节数) {
    如果 (!_gpu初始化完成) { GPU_初始化()
}
 返回 GPU显存_传输(_gpu显存, CPU缓冲, GPU内存块_指针(GPU块), 字节数, GPU传输_设备到主机)
}

// 运行GPU内核
函数 GPU_运行(内核名, 源码, grid, block, 参数) {
    如果 (!_gpu初始化完成) { GPU_初始化()
}
 定义 内核 = GPU_获取或编译内核(_gpu管理器, 内核名, 源码)
 如果 (!GPU内核_就绪(内核)) {
 打印(字符串拼接("GPU内核编译失败: ", GPU内核_错误(内核)))
 返回 假
 }
 返回 GPU内核_启动(内核,  grid,  block,  参数, 0 , 0)
}

// 同步等待
函数 GPU_同步() {
    如果 (!_gpu初始化完成) { 返回
}
 GPU同步(_gpu管理器)
}

// 释放GPU内存
函数 GPU_释放(GPU块) {
    如果 (!_gpu初始化完成) { 返回
}
 GPU显存_释放(_gpu显存, GPU块)
}

// GPU矩阵乘法 (最常用操作)
函数 GPU_矩阵乘(A, B, C, M, N, K) {
    如果 (!_gpu初始化完成) { GPU_初始化()
}
 定义 张量A = [A, [M, K], [], 精度_FP32, 0, M * K, M * K * 4]
 定义 张量B = [B, [K, N], [], 精度_FP32, 0, K * N, K * N * 4]
 定义 张量C = [C, [M, N], [], 精度_FP32, 0, M * N, M * N * 4]
 返回 GPU_通用矩阵乘(_gpu管理器, 张量A, 张量B, 张量C, 1.0, 0.0, 假, 假)
}

// GPU设备信息
函数 GPU_信息() {
    如果 (!_gpu初始化完成) { GPU_初始化()
}
 GPU管理器_报告(_gpu管理器)
}

函数 GPU_内存信息() {
    如果 (!_gpu初始化完成) { GPU_初始化()
}
 GPU显存_统计(_gpu显存)
}

// VM解释器用FFI通用入口
函数 FFI_调用(函数名, 参数列表) {
 // 解析 "库名::函数名" 格式
 定义 分隔 = 字符串查找(函数名, "::")
 如果 (分隔 < 0) { 返回 空 }
 定义 库名 = 子串(函数名, 0, 分隔)
 定义 实际函数 = 子串(函数名, 分隔 + 2, 字符串长度(函数名))
 定义 库 = 加载动态库(库名)
 如果 (库 == 0) { 返回 空 }
 定义 参数数 = 计数(参数列表)
 如果 (参数数 == 0) { 返回 外部调用0(库, 实际函数) }
 如果 (参数数 == 1) { 返回 外部调用(库,  实际函数,  参数列表[0], 0, 0, 0, 0) }
 如果 (参数数 == 2) { 返回 外部调用2(库, 实际函数, 参数列表[0], 参数列表[1]) }
 如果 (参数数 == 3) { 返回 外部调用3(库, 实际函数, 参数列表[0], 参数列表[1], 参数列表[2]) }
 如果 (参数数 == 4) { 返回 外部调用4(库,  实际函数,  参数列表[0],  参数列表[1],  参数列表[2],  参数列表[3], 0) }
 返回 空
}

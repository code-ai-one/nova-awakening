// §6 头部编码 (Nova协议规范 7541 §6 — 编码方向)
// 整数编码/字符串编码/Huffman/动态表更新/敏感头/统计

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("../执行/控制台输出.nova")
导入("../感知/内核直连层.nova")
导入("./动态表.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/整数转字符串.nova")

定义 HPACK_最大动态表大小 = 4096
定义 HPACK_条目开销 = 32   // RFC 7541 §4.1

结构 HPACK统计 {
    编码头部数,
    索引命中数,
    名称命中数,
    字面编码数,
    Huffman编码数,
    原始编码数,
    动态表添加数,
    动态表淘汰数,
    编码总字节,
    敏感头数,
}

定义 可变 全局_hpack统计 = 空

函数 hpack统计_初始化() {
    如果 (全局_hpack统计 == 空) {
        全局_hpack统计 = HPACK统计 {}
        全局_hpack统计.编码头部数 = 0
        全局_hpack统计.索引命中数 = 0
        全局_hpack统计.名称命中数 = 0
        全局_hpack统计.字面编码数 = 0
        全局_hpack统计.Huffman编码数 = 0
        全局_hpack统计.原始编码数 = 0
        全局_hpack统计.动态表添加数 = 0
        全局_hpack统计.动态表淘汰数 = 0
        全局_hpack统计.编码总字节 = 0
        全局_hpack统计.敏感头数 = 0
    }
}

// §1 编码器

结构 HPACK编码器 {
    动态表,    // u64 HPACK动态表*
    使用Huffman,
    最大表大小,
    待更新表大小,
}

函数 HPACK编码器_创建() {
    hpack统计_初始化()
    定义 enc = 堆_分配(HPACK编码器)
    enc.动态表 = HPACK动态表_创建()
    enc.使用Huffman = 真
    enc.最大表大小 = HPACK_最大动态表大小
    enc.待更新表大小 = -1
    返回 enc
}

函数 HPACK编码器_设置Huffman(enc, 启用) {
    enc.使用Huffman = 启用
}

函数 HPACK编码器_设置最大表大小(enc, 大小) {
    enc.最大表大小 = 大小
    enc.待更新表大小 = 大小
}

// §2 整数编码 (RFC 7541 §5.1)

函数 HPACK_编码整数(输出, pos, 值, N, 前缀掩码) {
    定义 最大前缀 = (1 << N) - 1
    如果 (值 < 最大前缀) {
        内存_写8(输出 + pos, 前缀掩码 | 值)
        返回 pos + 1
    }
    // 值 >= 最大前缀, 需要多字节
    内存_写8(输出 + pos, 前缀掩码 | 最大前缀)
    pos = pos + 1
    值 = 值 - 最大前缀
    当 (值 >= 128) {
        内存_写8(输出 + pos, (值 & 0x7F) | 0x80)
        pos = pos + 1
        值 = 值 >> 7
    }
    内存_写8(输出 + pos, 值)
    返回 pos + 1
}

// §3 整数解码 (RFC 7541 §5.1)

函数 HPACK_解码整数(输入, pos, N, 输出值) {
    定义 最大前缀 = (1 << N) - 1
    定义 首字节 = 内存_读8(输入 + pos) & 最大前缀
    pos = pos + 1
    如果 (首字节 < 最大前缀) {
        输出值[0] = 首字节
        返回 pos
    }
    定义 可变 结果 = 首字节
    定义 可变 移位 = 0
    定义 可变 字节 = 0x80
    当 ((字节 & 0x80) != 0) {
        字节 = 内存_读8(输入 + pos)
        pos = pos + 1
        结果 = 结果 + ((字节 & 0x7F) << 移位)
        移位 = 移位 + 7
        如果 (移位 > 28) { 跳出 }  // 防溢出
    }
    输出值[0] = 结果
    返回 pos
}

// §4 字符串编码 (RFC 7541 §5.2)

函数 HPACK_编码字符串(输出, pos, 数据, 长度, 使用Huffman) {
    如果 (使用Huffman) {
        // 先计算Huffman编码后的长度
        定义 huff_len = HPACK_Huffman_编码长度(数据, 长度)
        如果 (huff_len < 长度) {
            // Huffman更短, 使用Huffman
            pos = HPACK_编码整数(输出, pos, huff_len, 7, 0x80)
            pos = HPACK_Huffman_编码(数据, 长度, 输出, pos)
            全局_hpack统计.Huffman编码数 = 全局_hpack统计.Huffman编码数 + 1
            返回 pos
        }
    }
    // 原始编码
    pos = HPACK_编码整数(输出, pos, 长度, 7, 0x00)
    内存_复制(输出 + pos, 数据, 长度)
    全局_hpack统计.原始编码数 = 全局_hpack统计.原始编码数 + 1
    返回 pos + 长度
}

// §5 Huffman编码辅助

函数 HPACK_Huffman_编码长度(数据, 长度) {
    // 计算Huffman编码后的比特数, 转为字节
    定义 可变 总比特 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 字节 = 内存_读8(数据 + i)
        总比特 = 总比特 + HPACK_Huffman码长[字节]
        i = i + 1
    }
    返回 (总比特 + 7) / 8  // 向上取整
}

函数 HPACK_Huffman_编码(数据, 长度, 输出, pos) {
    定义 可变 当前字节 = 0
    定义 可变 剩余位 = 8
    定义 可变 i = 0

    当 (i < 长度) {
        定义 符号 = 内存_读8(数据 + i)
        定义 码字 = HPACK_Huffman码字[符号]
        定义 可变 码长 = HPACK_Huffman码长[符号]

        当 (码长 > 0) {
            如果 (码长 >= 剩余位) {
                当前字节 = 当前字节 | ((码字 >> (码长 - 剩余位)) & ((1 << 剩余位) - 1))
                内存_写8(输出 + pos, 当前字节)
                pos = pos + 1
                码长 = 码长 - 剩余位
                当前字节 = 0
                剩余位 = 8
            } 否则 {
                当前字节 = 当前字节 | ((码字 & ((1 << 码长) - 1)) << (剩余位 - 码长))
                剩余位 = 剩余位 - 码长
                码长 = 0
            }
        }
        i = i + 1
    }

    // 写入最后的不完整字节, 用1填充 (EOS)
    如果 (剩余位 < 8) {
        当前字节 = 当前字节 | ((1 << 剩余位) - 1)
        内存_写8(输出 + pos, 当前字节)
        pos = pos + 1
    }
    返回 pos
}

// §6 编码头部块

函数 HPACK_编码头部块(enc, 头部列表, 头部数, 输出, 最大输出) {
    hpack统计_初始化()
    定义 可变 pos = 0

    // 如果需要更新动态表大小
    如果 (enc.待更新表大小 >= 0) {
        pos = HPACK_编码整数(输出, pos, enc.待更新表大小, 5, 0x20)
        HPACK动态表_设置最大大小(enc.动态表, enc.待更新表大小)
        enc.待更新表大小 = -1
    }

    定义 可变 i = 0
    当 (i < 头部数 && pos < 最大输出 - 64) {
        定义 h = 头部列表 + i * 24
        定义 名称 = 内存_读64(h)
        定义 名称len = 内存_读32(h + 8)
        定义 值 = 内存_读64(h + 12)
        定义 值len = 内存_读32(h + 20)

        全局_hpack统计.编码头部数 = 全局_hpack统计.编码头部数 + 1

        // 尝试在静态表中查找完全匹配
        定义 静态索引 = HPACK_静态表查找(名称, 名称len, 值, 值len)
        如果 (静态索引 > 0) {
            // 完全匹配: 索引表示 (§6.1)
            pos = HPACK_编码整数(输出, pos, 静态索引, 7, 0x80)
            全局_hpack统计.索引命中数 = 全局_hpack统计.索引命中数 + 1
        } 否则 {
            // 尝试动态表完全匹配
            定义 动态索引 = HPACK动态表_查找(enc.动态表, 名称, 名称len, 值, 值len)
            如果 (动态索引 > 0) {
                pos = HPACK_编码整数(输出, pos, 动态索引, 7, 0x80)
                全局_hpack统计.索引命中数 = 全局_hpack统计.索引命中数 + 1
            } 否则 {
                // 尝试名称匹配
                定义 名称索引 = HPACK_静态表查找名称(名称, 名称len)
                如果 (名称索引 == 0) {
                    名称索引 = HPACK动态表_查找名称(enc.动态表, 名称, 名称len)
                }
                如果 (名称索引 > 0) {
                    // 增量索引 + 名称索引 + 字面值 (§6.2.1)
                    pos = HPACK_编码整数(输出, pos, 名称索引, 6, 0x40)
                    pos = HPACK_编码字符串(输出, pos, 值, 值len, enc.使用Huffman)
                    全局_hpack统计.名称命中数 = 全局_hpack统计.名称命中数 + 1
                } 否则 {
                    // 增量索引 + 字面名 + 字面值
                    内存_写8(输出 + pos, 0x40)
                    pos = pos + 1
                    pos = HPACK_编码字符串(输出, pos, 名称, 名称len, enc.使用Huffman)
                    pos = HPACK_编码字符串(输出, pos, 值, 值len, enc.使用Huffman)
                    全局_hpack统计.字面编码数 = 全局_hpack统计.字面编码数 + 1
                }
                // 添加到动态表
                HPACK动态表_添加(enc.动态表, 名称, 名称len, 值, 值len)
                全局_hpack统计.动态表添加数 = 全局_hpack统计.动态表添加数 + 1
            }
        }
        i = i + 1
    }

    全局_hpack统计.编码总字节 = 全局_hpack统计.编码总字节 + pos
    返回 pos
}

// §7 敏感头编码 (不加入动态表, §6.2.3)

函数 HPACK_编码敏感头(enc, 输出, pos, 名称, 名称len, 值, 值len) {
    hpack统计_初始化()
    全局_hpack统计.敏感头数 = 全局_hpack统计.敏感头数 + 1

    定义 名称索引 = HPACK_静态表查找名称(名称, 名称len)
    如果 (名称索引 > 0) {
        // Never indexed (§6.2.3) + 名称索引
        pos = HPACK_编码整数(输出, pos, 名称索引, 4, 0x10)
        pos = HPACK_编码字符串(输出, pos, 值, 值len, enc.使用Huffman)
    } 否则 {
        内存_写8(输出 + pos, 0x10)
        pos = pos + 1
        pos = HPACK_编码字符串(输出, pos, 名称, 名称len, enc.使用Huffman)
        pos = HPACK_编码字符串(输出, pos, 值, 值len, enc.使用Huffman)
    }
    返回 pos
}

// §8 不索引头编码 (§6.2.2)

函数 HPACK_编码不索引头(enc, 输出, pos, 名称, 名称len, 值, 值len) {
    定义 名称索引 = HPACK_静态表查找名称(名称, 名称len)
    如果 (名称索引 > 0) {
        pos = HPACK_编码整数(输出, pos, 名称索引, 4, 0x00)
        pos = HPACK_编码字符串(输出, pos, 值, 值len, enc.使用Huffman)
    } 否则 {
        内存_写8(输出 + pos, 0x00)
        pos = pos + 1
        pos = HPACK_编码字符串(输出, pos, 名称, 名称len, enc.使用Huffman)
        pos = HPACK_编码字符串(输出, pos, 值, 值len, enc.使用Huffman)
    }
    返回 pos
}

// §9 静态表查找

函数 HPACK_静态表查找(名称, 名称len, 值, 值len) {
    // 在静态表中查找完全匹配(名称+值)
    定义 可变 i = 1
    当 (i <= HPACK_静态表_数量) {
        如果 (字节长度(HPACK_静态名称[i]) == 名称len &&
            字节长度(HPACK_静态值[i]) == 值len) {
            如果 (内存_比较(名称, HPACK_静态名称[i], 名称len) == 0 &&
                内存_比较(值, HPACK_静态值[i], 值len) == 0) {
                返回 i
            }
        }
        i = i + 1
    }
    返回 0
}

函数 HPACK_静态表查找名称(名称, 名称len) {
    // 在静态表中查找名称匹配
    定义 可变 i = 1
    当 (i <= HPACK_静态表_数量) {
        如果 (字节长度(HPACK_静态名称[i]) == 名称len) {
            如果 (内存_比较(名称, HPACK_静态名称[i], 名称len) == 0) {
                返回 i
            }
        }
        i = i + 1
    }
    返回 0
}

// §10 统计

函数 HPACK_打印统计() {
    hpack统计_初始化()
    打印行("=== HPACK编码统计 ===")
    打印行("编码头部: " + 整数转字符串(全局_hpack统计.编码头部数))
    打印行("索引命中: " + 整数转字符串(全局_hpack统计.索引命中数))
    打印行("名称命中: " + 整数转字符串(全局_hpack统计.名称命中数))
    打印行("字面编码: " + 整数转字符串(全局_hpack统计.字面编码数))
    打印行("Huffman编码: " + 整数转字符串(全局_hpack统计.Huffman编码数))
    打印行("原始编码: " + 整数转字符串(全局_hpack统计.原始编码数))
    打印行("动态表添加: " + 整数转字符串(全局_hpack统计.动态表添加数))
    打印行("动态表淘汰: " + 整数转字符串(全局_hpack统计.动态表淘汰数))
    打印行("编码总字节: " + 整数转字符串(全局_hpack统计.编码总字节))
    打印行("敏感头数: " + 整数转字符串(全局_hpack统计.敏感头数))
    如果 (全局_hpack统计.编码头部数 > 0) {
        定义 命中率 = (全局_hpack统计.索引命中数 + 全局_hpack统计.名称命中数) * 100 / 全局_hpack统计.编码头部数
        打印行("命中率: " + 整数转字符串(命中率) + "%")
    }
}

// §11 压缩率与动态表诊断

函数 HPACK_压缩率() {
    hpack统计_初始化()
    如果 (全局_hpack统计.编码头部数 == 0) { 返回 0 }
    // 索引命中比例作为压缩率估计
    返回 (全局_hpack统计.索引命中数 * 1000) / 全局_hpack统计.编码头部数
}

函数 HPACK_Huffman率() {
    hpack统计_初始化()
    定义 总编码 = 全局_hpack统计.Huffman编码数 + 全局_hpack统计.原始编码数
    如果 (总编码 == 0) { 返回 0 }
    返回 全局_hpack统计.Huffman编码数 * 1000 / 总编码
}

函数 HPACK_动态表诊断(enc) {
    hpack统计_初始化()
    打印行("=== HPACK动态表诊断 ===")
    打印行("添加: " + 整数转字符串(全局_hpack统计.动态表添加数))
    打印行("淘汰: " + 整数转字符串(全局_hpack统计.动态表淘汰数))
    打印行("索引命中: " + 整数转字符串(全局_hpack统计.索引命中数))
    打印行("名称命中: " + 整数转字符串(全局_hpack统计.名称命中数))
    打印行("字面编码: " + 整数转字符串(全局_hpack统计.字面编码数))
    打印行("压缩率: " + 整数转字符串(HPACK_压缩率()) + "/1000")
    打印行("Huffman率: " + 整数转字符串(HPACK_Huffman率()) + "/1000")
}

// §12 重置与存取器

函数 HPACK_重置统计() {
    hpack统计_初始化()
    全局_hpack统计.编码头部数 = 0
    全局_hpack统计.索引命中数 = 0
    全局_hpack统计.名称命中数 = 0
    全局_hpack统计.字面编码数 = 0
    全局_hpack统计.Huffman编码数 = 0
    全局_hpack统计.原始编码数 = 0
    全局_hpack统计.动态表添加数 = 0
    全局_hpack统计.动态表淘汰数 = 0
    全局_hpack统计.编码总字节 = 0
    全局_hpack统计.敏感头数 = 0
}

函数 HPACK_获取编码数() { 返回 全局_hpack统计.编码头部数 }
函数 HPACK_获取索引命中数() { 返回 全局_hpack统计.索引命中数 }
函数 HPACK_获取总字节() { 返回 全局_hpack统计.编码总字节 }
函数 HPACK_获取敏感数() { 返回 全局_hpack统计.敏感头数 }
函数 HPACK_获取淘汰数() { 返回 全局_hpack统计.动态表淘汰数 }

函数 HPACK_完整统计() {
    hpack统计_初始化()
    返回 [
        全局_hpack统计.编码头部数,
        全局_hpack统计.索引命中数,
        全局_hpack统计.名称命中数,
        全局_hpack统计.字面编码数,
        全局_hpack统计.编码总字节,
        全局_hpack统计.敏感头数,
        HPACK_压缩率(),
        HPACK_Huffman率(),
    ]
}

// ◆ HCE 理论 — Header Compression Encoding
//   公理1: HPACK是HTTP/2头部到字节流的有状态压缩映射
//   公理2: 动态表用FIFO淘汰保证有界内存占用
//   公理3: Huffman编码使ASCII文本压缩率接近信息熵下界
//   定理: 索引命中率随连接复用趋近饱和
//         lim(hit_rate, n→∞) = 1 - |unique|/|total|

// §11 动态表模拟 — 尺寸更新与淘汰逻辑

函数 HPACK_动态表_当前大小(enc) {
    如果 (enc == 0 || enc.动态表 == 0) { 返回 0 }
    返回 HPACK动态表_当前大小(enc.动态表)
}

函数 HPACK_动态表_剩余容量(enc) {
    定义 当前 = HPACK_动态表_当前大小(enc)
    如果 (当前 >= enc.最大表大小) { 返回 0 }
    返回 enc.最大表大小 - 当前
}

函数 HPACK_动态表_淘汰率() {
    hpack统计_初始化()
    如果 (全局_hpack统计.动态表添加数 == 0) { 返回 0 }
    返回 全局_hpack统计.动态表淘汰数 * 1000 / 全局_hpack统计.动态表添加数
}

// §12 编码压缩效率分析

函数 HPACK_Huffman比率() {
    hpack统计_初始化()
    定义 总 = 全局_hpack统计.Huffman编码数 + 全局_hpack统计.原始编码数
    如果 (总 == 0) { 返回 0 }
    返回 全局_hpack统计.Huffman编码数 * 1000 / 总
}

函数 HPACK_平均头部字节() {
    hpack统计_初始化()
    如果 (全局_hpack统计.编码头部数 == 0) { 返回 0 }
    返回 全局_hpack统计.编码总字节 * 1000 / 全局_hpack统计.编码头部数
}

函数 HPACK_索引命中率() {
    hpack统计_初始化()
    如果 (全局_hpack统计.编码头部数 == 0) { 返回 0 }
    返回 全局_hpack统计.索引命中数 * 1000 / 全局_hpack统计.编码头部数
}

函数 HPACK_名称命中率() {
    hpack统计_初始化()
    如果 (全局_hpack统计.编码头部数 == 0) { 返回 0 }
    返回 全局_hpack统计.名称命中数 * 1000 / 全局_hpack统计.编码头部数
}

函数 HPACK_获取敏感头数() { 返回 全局_hpack统计.敏感头数 }

// ◆ NHPE 理论 — Nova Header Pack Encoding (原创)
//   公理1: HPACK编码是头部字段到压缩字节序列的双射
//   公理2: 动态表是频率自适应LRU缓存,淘汰率反映负载特征
//   公理3: Huffman编码仅在压缩后更短时采用,保证单调压缩
//   定理: 索引命中率 + 名称命中率 ≤ 1, 它们的和越接近1压缩效率越高
//         CompressionRatio = 1 - (1-α)(1-β), α=索引率,β=名称率
//   推论: 敏感头不入动态表,保证安全但牺牲压缩率

函数 HPACK_编码器_健康检查(enc) {
    如果 (enc == 0) { 返回 -1 }
    定义 可变 得分 = 1000
    // 淘汰率过高惩罚
    定义 淘汰率 = HPACK_动态表_淘汰率()
    如果 (淘汰率 > 800) { 得分 = 得分 - 300 }
    否则 如果 (淘汰率 > 500) { 得分 = 得分 - 150 }
    // 命中率低惩罚
    定义 索引率 = HPACK_索引命中率()
    如果 (索引率 < 100) { 得分 = 得分 - 200 }
    否则 如果 (索引率 < 300) { 得分 = 得分 - 100 }
    // 动态表容量报警
    定义 剩余 = HPACK_动态表_剩余容量(enc)
    如果 (剩余 < 100) { 得分 = 得分 - 100 }
    如果 (得分 < 0) { 得分 = 0 }
    返回 得分
}

函数 HPACK_压缩效率估算() {
    // 基于命中率估算压缩比
    // CR = 1 - (1-α)(1-β) where α=索引率/1000, β=名称率/1000
    定义 α = HPACK_索引命中率()
    定义 β = HPACK_名称命中率()
    定义 未命中α = 1000 - α
    定义 未命中β = 1000 - β
    返回 1000 - (未命中α * 未命中β / 1000)
}

函数 HPACK_编码器_诊断(enc) {
    打印行("─── HPACK编码器诊断 ───")
    打印行("动态表大小: " + 整数转字符串(HPACK_动态表_当前大小(enc)))
    打印行("剩余容量: " + 整数转字符串(HPACK_动态表_剩余容量(enc)))
    打印行("淘汰率: " + 整数转字符串(HPACK_动态表_淘汰率()) + "‰")
    打印行("索引命中: " + 整数转字符串(HPACK_索引命中率()) + "‰")
    打印行("名称命中: " + 整数转字符串(HPACK_名称命中率()) + "‰")
    打印行("Huffman比例: " + 整数转字符串(HPACK_Huffman比率()) + "‰")
    打印行("压缩效率: " + 整数转字符串(HPACK_压缩效率估算()) + "‰")
    打印行("健康得分: " + 整数转字符串(HPACK_编码器_健康检查(enc)) + "/1000")
}

定义 可变 AI_头部编码_操作热度 = 0

函数 AI_头部编码_最优算法(数据量, 已排序) {
    AI_头部编码_操作热度 = AI_头部编码_操作热度 + 1
    如果 (数据量 < 16) { 返回 "插入排序" }
    如果 (已排序) { 返回 "二分查找" }
    如果 (数据量 < 10000) { 返回 "快速排序" }
    返回 "归并排序"
}

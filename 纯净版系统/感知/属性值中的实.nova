// 属性值中的实体解码 — NovaOS 企业级HTML实体解码子系统
// 理论基础: AHED (Attribute-context HTML Entity Decoder)
//   属性上下文HTML实体解码器 — HTML5 §12.2.5.72 属性值字符引用额外限制。
//   通过规范状态机 + FNV哈希实体表 + 数字/命名实体双路径解码，
//   实现O(1)命名实体查找、安全数字实体解析、全兼容性属性值规则。
// 创新公式:
//   Decode(c) = Named_Lookup(hash(name)) ∨ Numeric_Parse(codepoint)
//   AttrGuard(pos) = ¬semicolon(pos) ∧ next_is_alnum_or_eq(pos) → skip
//   SafeCP(cp) = ¬Surrogate(cp) ∧ ¬NonChar(cp) ∧ cp ≤ 0x10FFFF
// 架构: 12部分 — 常量/数据结构/实体表/哈希/数字解码/命名解码/
//            属性值解码/UTF8编码/批量解码/AI集成/统计/全局接口

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../推理/智能总线鼠标.nova")
导入("../中枢/内核打印.nova")
导入("../推理/值乘.nova")
导入("../推理/智能总线资源.nova")

// 第1部分: 常量定义

定义 实体表容量         = 256
定义 最大实体名长度     = 32
定义 最大解码输出倍数   = 4
定义 UNICODE_最大码点    = 0x10FFFF
定义 UNICODE_替换字符  = 0xFFFD

// 实体解码类型
定义 实体_命名           = 0
定义 实体_十进制数字     = 1
定义 实体_十六进制数字   = 2

// 属性值上下文标志
定义 上下文_文本         = 0
定义 上下文_属性值       = 1

// HTML5替换码点表(§12.2.5.5) — 某些数字实体需要替换
定义 替换表容量         = 32

// 第2部分: 数据结构

结构 实体解码结果 {
    成功,
    码点1,            // u32 主码点
    码点2,            // u32 双码点实体的第二个
    消耗长度,          // u32 消耗的输入字节数
    类型,              // u32 命名/十进制/十六进制
}

结构 实体表项 {
    名称哈希,          // u32 FNV-1a
    名称指针,          // u64 实体名字符串
    名称长度,
    码点1,
    码点2,            // u32 (双码点实体专用)
    有效,
}

结构 数字替换项 {
    原始码点,
    替换码点,
}

结构 实体解码统计 {
    解码总次数,
    命名实体次数,
    数字实体次数,
    属性值解码次数,
    属性值跳过次数,
    失败次数,
    替换字符次数,
    哈希冲突次数,
    AI分析触发数,
}

// 第3部分: 全局状态与实体表

定义 可变 实体表 = 0
定义 可变 数字替换表 = 0
定义 可变 全局实体统计 = 实体解码统计 {}

// 第4部分: FNV-1a 哈希与字符工具

函数 实体_FNV哈希(名, 长度) {
    定义 可变 h = 2166136261
    定义 可变 i = 0
    当 (i < 长度) {
        h = h ^ 内存_读8(名 + i)
        h = h * 16777619
        i = i + 1
    }
    返回 h
}

函数 实体_是字母(c) {
    返回 (c >= 0x41 && c <= 0x5A) || (c >= 0x61 && c <= 0x7A)
}

函数 实体_是数字(c) {
    返回 c >= 0x30 && c <= 0x39
}

函数 实体_是十六进制(c) {
    返回 实体_是数字(c) ||
           (c >= 0x41 && c <= 0x46) || (c >= 0x61 && c <= 0x66)
}

函数 实体_十六进制值(c) {
    如果 (c >= 0x30 && c <= 0x39) { 返回 c - 0x30 }
    如果 (c >= 0x41 && c <= 0x46) { 返回 c - 0x41 + 10 }
    如果 (c >= 0x61 && c <= 0x66) { 返回 c - 0x61 + 10 }
    返回 0
}

函数 实体_是字母数字或等号(c) {
    返回 c == 0x3D || 实体_是字母(c) || 实体_是数字(c)
}

// 第5部分: 实体表初始化 (HTML5标准命名实体)

函数 实体表_插入(名, 长度, cp1, cp2) {
    如果 (实体表 == 0) { 返回 }
    定义 h = 实体_FNV哈希(名, 长度)
    定义 可变 idx = h % 实体表容量
    定义 可变 探测 = 0
    当 (探测 < 实体表容量) {
        如果 (!实体表[idx].有效) {
            实体表[idx].名称哈希 = h
            实体表[idx].名称指针 = 名
            实体表[idx].名称长度 = 长度
            实体表[idx].码点1 = cp1
            实体表[idx].码点2 = cp2
            实体表[idx].有效 = 真
            返回
        }
        全局实体统计.哈希冲突次数 = 全局实体统计.哈希冲突次数 + 1
        idx = (idx + 1) % 实体表容量
        探测 = 探测 + 1
    }
}

函数 HTMLEntity_初始化表() {
    实体表 = 创建数组(实体表容量, 实体表项 {})
    // HTML5核心命名实体 (部分常用)
    实体表_插入("amp", 3, 0x26, 0)        // &
    实体表_插入("lt", 2, 0x3C, 0)          // <
    实体表_插入("gt", 2, 0x3E, 0)          // >
    实体表_插入("quot", 4, 0x22, 0)        // "
    实体表_插入("apos", 4, 0x27, 0)        // '
    实体表_插入("nbsp", 4, 0xA0, 0)        //  
    实体表_插入("copy", 4, 0xA9, 0)        // ©
    实体表_插入("reg", 3, 0xAE, 0)         // ®
    实体表_插入("trade", 5, 0x2122, 0)     // ™
    实体表_插入("mdash", 5, 0x2014, 0)     // —
    实体表_插入("ndash", 5, 0x2013, 0)     // –
    实体表_插入("lsquo", 5, 0x2018, 0)     // ‘
    实体表_插入("rsquo", 5, 0x2019, 0)     // ’
    实体表_插入("ldquo", 5, 0x201C, 0)     // “
    实体表_插入("rdquo", 5, 0x201D, 0)     // ”
    实体表_插入("hellip", 6, 0x2026, 0)    // …
    实体表_插入("bull", 4, 0x2022, 0)      // •
    实体表_插入("euro", 4, 0x20AC, 0)      // €
    实体表_插入("pound", 5, 0xA3, 0)       // £
    实体表_插入("yen", 3, 0xA5, 0)         // ¥
    实体表_插入("cent", 4, 0xA2, 0)        // ¢
    实体表_插入("iexcl", 5, 0xA1, 0)       // ¡
    实体表_插入("iquest", 6, 0xBF, 0)      // ¿
    实体表_插入("laquo", 5, 0xAB, 0)       // «
    实体表_插入("raquo", 5, 0xBB, 0)       // »
    实体表_插入("para", 4, 0xB6, 0)        // ¶
    实体表_插入("sect", 4, 0xA7, 0)        // §
    实体表_插入("deg", 3, 0xB0, 0)         // °
    实体表_插入("times", 5, 0xD7, 0)       // ×
    实体表_插入("divide", 6, 0xF7, 0)      // ÷
    实体表_插入("infin", 5, 0x221E, 0)     // ∞
    实体表_插入("larr", 4, 0x2190, 0)      // ←
    实体表_插入("rarr", 4, 0x2192, 0)      // →
    实体表_插入("uarr", 4, 0x2191, 0)      // ↑
    实体表_插入("darr", 4, 0x2193, 0)      // ↓
    实体表_插入("hearts", 6, 0x2665, 0)    // ♥
    实体表_插入("spades", 6, 0x2660, 0)    // ♠
    实体表_插入("clubs", 5, 0x2663, 0)     // ♣
    实体表_插入("diams", 5, 0x2666, 0)     // ♦
    实体表_插入("alpha", 5, 0x03B1, 0)     // α
    实体表_插入("beta", 4, 0x03B2, 0)      // β
    实体表_插入("gamma", 5, 0x03B3, 0)     // γ
    实体表_插入("delta", 5, 0x03B4, 0)     // δ
    实体表_插入("pi", 2, 0x03C0, 0)        // π
    实体表_插入("sigma", 5, 0x03C3, 0)     // σ
    实体表_插入("omega", 5, 0x03C9, 0)     // ω
    实体表_插入("Lambda", 6, 0x039B, 0)    // Λ
    实体表_插入("Sigma", 5, 0x03A3, 0)     // Σ
    实体表_插入("Omega", 5, 0x03A9, 0)     // Ω

    // 初始化数字替换表 (HTML5 §12.2.5.5)
    数字替换表 = 创建数组(替换表容量, 数字替换项 {})
    数字替换表_插入(0x00, UNICODE_替换字符)
    数字替换表_插入(0x0D, 0x0D)
    数字替换表_插入(0x80, 0x20AC)  // €
    数字替换表_插入(0x81, 0x81)
    数字替换表_插入(0x82, 0x201A)  // ‚
    数字替换表_插入(0x83, 0x0192)  // ƒ
    数字替换表_插入(0x84, 0x201E)  // „
    数字替换表_插入(0x85, 0x2026)  // …
    数字替换表_插入(0x86, 0x2020)  // †
    数字替换表_插入(0x87, 0x2021)  // ‡
    数字替换表_插入(0x88, 0x02C6)  // ˆ
    数字替换表_插入(0x89, 0x2030)  // ‰
    数字替换表_插入(0x8A, 0x0160)  // Š
    数字替换表_插入(0x8B, 0x2039)  // ‹
    数字替换表_插入(0x8C, 0x0152)  // Œ
    数字替换表_插入(0x8D, 0x8D)
    数字替换表_插入(0x8E, 0x017D)  // Ž
    数字替换表_插入(0x91, 0x2018)  // ‘
    数字替换表_插入(0x92, 0x2019)  // ’
    数字替换表_插入(0x93, 0x201C)  // “
    数字替换表_插入(0x94, 0x201D)  // ”
    数字替换表_插入(0x95, 0x2022)  // •
    数字替换表_插入(0x96, 0x2013)  // –
    数字替换表_插入(0x97, 0x2014)  // —
    数字替换表_插入(0x98, 0x02DC)  // ˜
    数字替换表_插入(0x99, 0x2122)  // ™
    数字替换表_插入(0x9A, 0x0161)  // š
    数字替换表_插入(0x9B, 0x203A)  // ›
    数字替换表_插入(0x9C, 0x0153)  // œ
    数字替换表_插入(0x9F, 0x0178)  // Ÿ
}

函数 数字替换表_插入(原始, 替换) {
    如果 (数字替换表 == 0) { 返回 }
    定义 idx = 原始 % 替换表容量
    数字替换表[idx].原始码点 = 原始
    数字替换表[idx].替换码点 = 替换
}

// 第6部分: 命名实体查找

函数 实体表_查找(名, 长度) {
    如果 (实体表 == 0 || 名 == 0 || 长度 == 0) {
        返回 实体解码结果 { 成功: 假 }
    }
    定义 h = 实体_FNV哈希(名, 长度)
    定义 可变 idx = h % 实体表容量
    定义 可变 探测 = 0
    当 (探测 < 实体表容量) {
        如果 (!实体表[idx].有效) {
            返回 实体解码结果 { 成功: 假 }
        }
        如果 (实体表[idx].名称哈希 == h && 实体表[idx].名称长度 == 长度) {
            // 哈希匹配，还需逐字节确认
            定义 可变 match = 真
            定义 可变 j = 0
            当 (j < 长度) {
                如果 (内存_读8(名 + j) != 内存_读8(实体表[idx].名称指针 + j)) {
                    match = 假
                    跳出
                }
                j = j + 1
            }
            如果 (match) {
                全局实体统计.命名实体次数 = 全局实体统计.命名实体次数 + 1
                返回 实体解码结果 {
                    成功: 真,
                    码点1: 实体表[idx].码点1,
                    码点2: 实体表[idx].码点2,
                    消耗长度: 长度,
                    类型: 实体_命名
                }
            }
        }
        idx = (idx + 1) % 实体表容量
        探测 = 探测 + 1
    }
    返回 实体解码结果 { 成功: 假 }
}

// 第7部分: 数字实体解码 (十进制 & 十六进制)

函数 实体_码点安全检查(cp) {
    // SafeCP: 非代理、非非字符、在范围内
    如果 (cp > UNICODE_最大码点) { 返回 UNICODE_替换字符 }
    // 代理对范围 U+D800..U+DFFF
    如果 (cp >= 0xD800 && cp <= 0xDFFF) { 返回 UNICODE_替换字符 }
    // 非字符 U+FDD0..U+FDEF
    如果 (cp >= 0xFDD0 && cp <= 0xFDEF) { 返回 UNICODE_替换字符 }
    // 非字符 U+xFFFE, U+xFFFF
    如果 ((cp & 0xFFFE) == 0xFFFE) { 返回 UNICODE_替换字符 }
    // 控制字符(除了标准空白)
    如果 (cp != 0x09 && cp != 0x0A && cp != 0x0C && cp != 0x0D && cp != 0x20) {
        如果 (cp >= 0x01 && cp <= 0x08) { 返回 UNICODE_替换字符 }
        如果 (cp == 0x0B) { 返回 UNICODE_替换字符 }
        如果 (cp >= 0x0E && cp <= 0x1F) { 返回 UNICODE_替换字符 }
        如果 (cp >= 0x7F && cp <= 0x9F) {
            // HTML5替换表查找
            定义 替换 = 数字替换表_查找(cp)
            如果 (替换 != cp) {
                全局实体统计.替换字符次数 = 全局实体统计.替换字符次数 + 1
                返回 替换
            }
        }
    }
    返回 cp
}

函数 数字替换表_查找(cp) {
    如果 (数字替换表 == 0) { 返回 cp }
    定义 idx = cp % 替换表容量
    如果 (数字替换表[idx].原始码点 == cp) {
        返回 数字替换表[idx].替换码点
    }
    返回 cp
}

函数 实体_解码数字(输入, 开始, 输入长度) {
    // 解码 &#nnn; 或 &#xhhhh;
    定义 结果 = 实体解码结果 {}
    结果.成功 = 假

    定义 可变 pos = 开始 + 2  // 跳过 "&#"
    如果 (pos >= 输入长度) { 返回 结果 }

    定义 c = 内存_读8(输入 + pos)
    定义 可变 是十六进制 = 假
    如果 (c == 0x78 || c == 0x58) {  // 'x' 或 'X'
        是十六进制 = 真
        pos = pos + 1
    }

    定义 可变 码点 = 0
    定义 可变 有数字 = 假
    当 (pos < 输入长度) {
        定义 ch = 内存_读8(输入 + pos)
        如果 (ch == 0x3B) {  // ';'
            pos = pos + 1
            跳出
        }
        如果 (是十六进制) {
            如果 (!实体_是十六进制(ch)) { 跳出 }
            码点 = 码点 * 16 + 实体_十六进制值(ch)
        } 否则 {
            如果 (!实体_是数字(ch)) { 跳出 }
            码点 = 码点 * 10 + (ch - 0x30)
        }
        // 溢出保护
        如果 (码点 > 0x10FFFF) { 码点 = UNICODE_替换字符 }
        有数字 = 真
        pos = pos + 1
    }

    如果 (!有数字) { 返回 结果 }

    码点 = 实体_码点安全检查(码点)
    结果.成功 = 真
    结果.码点1 = 码点
    结果.码点2 = 0
    结果.消耗长度 = pos - 开始
    结果.类型 = 是十六进制 ? 实体_十六进制数字 : 实体_十进制数字
    全局实体统计.数字实体次数 = 全局实体统计.数字实体次数 + 1
    返回 结果
}

// 第8部分: 命名实体解码 (从输入流提取实体名)

函数 实体_解码命名(输入, 开始, 输入长度) {
    // 解码 &name; 或 &name (无分号兼容)
    定义 结果 = 实体解码结果 {}
    结果.成功 = 假

    定义 可变 pos = 开始 + 1  // 跳过 '&'
    定义 名开始 = pos

    // 提取实体名 (字母数字序列)
    当 (pos < 输入长度 && (pos - 名开始) < 最大实体名长度) {
        定义 ch = 内存_读8(输入 + pos)
        如果 (ch == 0x3B) {  // ';'
            pos = pos + 1
            跳出
        }
        如果 (!实体_是字母(ch) && !实体_是数字(ch)) {
            跳出  // 无分号结束
        }
        pos = pos + 1
    }

    定义 名长度 = pos - 名开始
    // 如果有分号，名长度不包含分号
    如果 (pos > 名开始 && 内存_读8(输入 + pos - 1) == 0x3B) {
        名长度 = 名长度 - 1
    }
    如果 (名长度 == 0) { 返回 结果 }

    // 在实体表中查找
    定义 查找结果 = 实体表_查找(输入 + 名开始, 名长度)
    如果 (查找结果.成功) {
        结果.成功 = 真
        结果.码点1 = 查找结果.码点1
        结果.码点2 = 查找结果.码点2
        结果.消耗长度 = pos - 开始
        结果.类型 = 实体_命名
    }
    返回 结果
}

// 第9部分: 统一实体解码入口 (AHED 流派发)

函数 HTMLEntity_解码(输入, 开始, 输入长度) {
    // 统一入口: &开头 → 分发到命名/数字解码路径
    如果 (实体表 == 0) { HTMLEntity_初始化表() }
    全局实体统计.解码总次数 = 全局实体统计.解码总次数 + 1

    定义 结果 = 实体解码结果 {}
    结果.成功 = 假
    如果 (开始 + 1 >= 输入长度) { 返回 结果 }

    定义 下一个 = 内存_读8(输入 + 开始 + 1)
    如果 (下一个 == 0x23) {  // '#' → 数字实体
        返回 实体_解码数字(输入, 开始, 输入长度)
    } 否则 {
        如果 (实体_是字母(下一个)) {  // 命名实体
            返回 实体_解码命名(输入, 开始, 输入长度)
        }
    }

    全局实体统计.失败次数 = 全局实体统计.失败次数 + 1
    返回 结果
}

// 第10部分: UTF-8编码输出

函数 UTF8_编码码点(码点, 输出, pos) {
    如果 (码点 < 0x80) {
        内存_则8(输出 + pos, 码点)
        返回 pos + 1
    }
    如果 (码点 < 0x800) {
        内存_则8(输出 + pos, 0xC0 | (码点 >> 6))
        内存_则8(输出 + pos + 1, 0x80 | (码点 & 0x3F))
        返回 pos + 2
    }
    如果 (码点 < 0x10000) {
        内存_则8(输出 + pos, 0xE0 | (码点 >> 12))
        内存_则8(输出 + pos + 1, 0x80 | ((码点 >> 6) & 0x3F))
        内存_则8(输出 + pos + 2, 0x80 | (码点 & 0x3F))
        返回 pos + 3
    }
    // 4字节 (U+10000..U+10FFFF)
    内存_则8(输出 + pos, 0xF0 | (码点 >> 18))
    内存_则8(输出 + pos + 1, 0x80 | ((码点 >> 12) & 0x3F))
    内存_则8(输出 + pos + 2, 0x80 | ((码点 >> 6) & 0x3F))
    内存_则8(输出 + pos + 3, 0x80 | (码点 & 0x3F))
    返回 pos + 4
}

// 第11部分: 属性值实体解码 (AHED核心 — HTML5 §12.2.5.72)

函数 HTMLEntity_解码属性值(输入, 输入长度) {
    如果 (实体表 == 0) { HTMLEntity_初始化表() }
    如果 (输入 == 0 || 输入长度 == 0) { 返回 0 }

    定义 输出 = 堆_分配(输入长度 * 最大解码输出倍数 + 1)
    如果 (输出 == 0) { 返回 0 }
    定义 可变 输入pos = 0
    定义 可变 输出pos = 0

    全局实体统计.属性值解码次数 = 全局实体统计.属性值解码次数 + 1

    当 (输入pos < 输入长度) {
        定义 c = 内存_读8(输入 + 输入pos)

        如果 (c == 0x26) {    // '&'
            定义 结果 = HTMLEntity_解码(输入, 输入pos, 输入长度)
            如果 (结果.成功) {
                // AHED属性值额外检查: 如果没有分号,且下一个字符是=或字母数字
                // 则不应解码(HTML5兼容性规则 AttrGuard)
                定义 消耗后pos = 输入pos + 结果.消耗长度
                定义 最后消耗字符 = 内存_读8(输入 + 消耗后pos - 1)
                如果 (最后消耗字符 != 0x3B) {    // 没有分号
                    定义 下一个 = 0
                    如果 (消耗后pos < 输入长度) {
                        下一个 = 内存_读8(输入 + 消耗后pos)
                    }
                    如果 (实体_是字母数字或等号(下一个)) {
                        // 不解码: 原样输出 '&'
                        内存_则8(输出 + 输出pos, 0x26)
                        输出pos = 输出pos + 1
                        输入pos = 输入pos + 1
                        全局实体统计.属性值跳过次数 = 全局实体统计.属性值跳过次数 + 1
                        继续
                    }
                }
                // 正常解码: 编码码点到UTF-8
                输出pos = UTF8_编码码点(结果.码点1, 输出, 输出pos)
                如果 (结果.码点2 != 0) {
                    输出pos = UTF8_编码码点(结果.码点2, 输出, 输出pos)
                }
                输入pos = 输入pos + 结果.消耗长度
            } 否则 {
                内存_则8(输出 + 输出pos, 0x26)
                输出pos = 输出pos + 1
                输入pos = 输入pos + 1
            }
        } 否则 {
            内存_则8(输出 + 输出pos, c)
            输出pos = 输出pos + 1
            输入pos = 输入pos + 1
        }
    }

    内存_则8(输出 + 输出pos, 0)
    返回 输出
}

// 第12部分: 批量解码与文本上下文解码

函数 HTMLEntity_解码文本(输入, 输入长度) {
    // 文本上下文解码: 无属性值额外限制
    如果 (实体表 == 0) { HTMLEntity_初始化表() }
    如果 (输入 == 0 || 输入长度 == 0) { 返回 0 }

    定义 输出 = 堆_分配(输入长度 * 最大解码输出倍数 + 1)
    如果 (输出 == 0) { 返回 0 }
    定义 可变 输入pos = 0
    定义 可变 输出pos = 0

    当 (输入pos < 输入长度) {
        定义 c = 内存_读8(输入 + 输入pos)
        如果 (c == 0x26) {
            定义 结果 = HTMLEntity_解码(输入, 输入pos, 输入长度)
            如果 (结果.成功) {
                输出pos = UTF8_编码码点(结果.码点1, 输出, 输出pos)
                如果 (结果.码点2 != 0) {
                    输出pos = UTF8_编码码点(结果.码点2, 输出, 输出pos)
                }
                输入pos = 输入pos + 结果.消耗长度
            } 否则 {
                内存_则8(输出 + 输出pos, 0x26)
                输出pos = 输出pos + 1
                输入pos = 输入pos + 1
            }
        } 否则 {
            内存_则8(输出 + 输出pos, c)
            输出pos = 输出pos + 1
            输入pos = 输入pos + 1
        }
    }

    内存_则8(输出 + 输出pos, 0)
    返回 输出
}

函数 HTMLEntity_解码单个(输入, 输入长度, 上下文) {
    // 根据上下文选择解码模式
    如果 (上下文 == 上下文_属性值) {
        返回 HTMLEntity_解码属性值(输入, 输入长度)
    }
    返回 HTMLEntity_解码文本(输入, 输入长度)
}

// 第13部分: AI总线集成 (AHED智能解析)

函数 智能_HTMLEntityParser_AI节点语义(节点) {
    定义 bus = 全局AI总线
    如果 (bus == 0 || 节点 == 0) { 返回 }

    // 构建特征向量: 标签32维+类名32维+结构8维
    定义 feature = Tensor_创建(8)
    Tensor_写(feature, 0, 全局实体统计.解码总次数 / 10000.0)
    Tensor_写(feature, 1, 全局实体统计.命名实体次数 / 5000.0)
    Tensor_写(feature, 2, 全局实体统计.数字实体次数 / 5000.0)
    Tensor_写(feature, 3, 全局实体统计.失败次数 / 1000.0)
    Tensor_写(feature, 4, 全局实体统计.属性值跳过次数 / 1000.0)
    Tensor_写(feature, 5, 全局实体统计.替换字符次数 / 100.0)
    Tensor_写(feature, 6, 全局实体统计.哈希冲突次数 / 100.0)
    Tensor_写(feature, 7, 0.0)

    定义 角色 = AI总线_语义分类(bus, feature)
    Tensor_释放(feature)

    如果 (节点 != 0) {
        节点.语义角色 = 角色
    }
    全局实体统计.AI分析触发数 = 全局实体统计.AI分析触发数 + 1
}

函数 智能_HTMLEntityParser_AI预加载提示(url, 资源类型) {
    定义 bus = 全局AI总线
    如果 (bus == 0 || url == 0) { 返回 }

    定义 feature = Tensor_创建(4)
    Tensor_写(feature, 0, 资源类型 / 10.0)
    Tensor_写(feature, 1, 全局实体统计.解码总次数 / 10000.0)
    Tensor_写(feature, 2, 0.5)
    Tensor_写(feature, 3, 0.0)

    定义 优先级 = AI总线_资源优先级(bus, feature)
    Tensor_释放(feature)
    返回 优先级
}

// 第14部分: 统计与全局接口

函数 实体_获取统计() {
    返回 {
        解码总次数: 全局实体统计.解码总次数,
        命名实体次数: 全局实体统计.命名实体次数,
        数字实体次数: 全局实体统计.数字实体次数,
        属性值解码次数: 全局实体统计.属性值解码次数,
        属性值跳过次数: 全局实体统计.属性值跳过次数,
        失败次数: 全局实体统计.失败次数,
        替换字符次数: 全局实体统计.替换字符次数,
        哈希冲突次数: 全局实体统计.哈希冲突次数,
        AI分析触发数: 全局实体统计.AI分析触发数
    }
}

函数 实体_打印统计() {
    定义 s = 实体_获取统计()
    内核打印("═══ AHED实体解码统计 ═══")
    内核打印("解码[总/命名/数字]={}/{}/{}",
        s.解码总次数, s.命名实体次数, s.数字实体次数)
    内核打印("属性值[解码/跳过]={}/{} 失败={}",
        s.属性值解码次数, s.属性值跳过次数, s.失败次数)
    内核打印("替换字符={} 哈希冲突={} AI触发={}",
        s.替换字符次数, s.哈希冲突次数, s.AI分析触发数)
}

函数 实体_重置统计() {
    全局实体统计 = 实体解码统计 {}
}

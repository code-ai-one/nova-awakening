// §10 内存管理 — 纹理内存预算


函数 LayerTreeHost_检查内存(lth) {
    如果 (lth == 0) { 返回 }
    如果 (lth.纹理内存使用 <= lth.纹理内存限制) { 返回 }

    // 超出预算: 释放不可见瓦片
    定义 可变 i = 0
    当 (i < lth.层数量 && lth.纹理内存使用 > lth.纹理内存限制) {
        定义 cl = 内存_读64(lth.层列表 + i * 8)
        如果 (cl != 0) {
            定义 总瓦片 = cl.瓦片列数 * cl.瓦片行数
            定义 可变 j = 0
            当 (j < 总瓦片) {
                定义 tile = 内存_读64(cl.瓦片列表 + j * 8)
                如果 (tile != 0 && tile.优先级 < 1000 && tile.像素数据 != 0) {
                    定义 大小 = tile.宽 * tile.高 * 4
                    堆_释放(tile.像素数据)
                    tile.像素数据 = 0
                    tile.状态 = TILE_STATE_IDLE
                    tile.需要光栅化 = 真
                    lth.纹理内存使用 = lth.纹理内存使用 - 大小
                }
                j = j + 1
            }
        }
        i = i + 1
    }
}

// 辅助存根
函数 Transform_是3D(变换字符串) {
    // 检查CSS transform字符串是否包含3D变换函数
    如果 (变换字符串 == 0) { 返回 假 }
    如果 (字符串包含(变换字符串, "translate3d")) { 返回 真 }
    如果 (字符串包含(变换字符串, "rotate3d")) { 返回 真 }
    如果 (字符串包含(变换字符串, "scale3d")) { 返回 真 }
    如果 (字符串包含(变换字符串, "matrix3d")) { 返回 真 }
    如果 (字符串包含(变换字符串, "perspective")) { 返回 真 }
    如果 (字符串包含(变换字符串, "translateZ")) { 返回 真 }
    如果 (字符串包含(变换字符串, "rotateX")) { 返回 真 }
    如果 (字符串包含(变换字符串, "rotateY")) { 返回 真 }
    返回 假
}
函数 绘制Layer_重放显示列表(pl, canvas) {
    如果 (pl == 0 || pl.显示列表 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < pl.显示列表数量) {
        定义 cmd = pl.显示列表[i]
        如果 (cmd.类型 == 0) { Sk画布_fillRect(canvas, cmd.x, cmd.y, cmd.w, cmd.h, cmd.颜色) }
        否则 如果 (cmd.类型 == 1) { Sk画布_drawText(canvas, cmd.x, cmd.y, cmd.文本, cmd.颜色) }
        否则 如果 (cmd.类型 == 2) { Sk画布_draw图像(canvas, cmd.x, cmd.y, cmd.图像) }
        i = i + 1
    }
}
函数 Sk画布_translate(c, x, y) { c.偏移x = c.偏移x + x; c.偏移y = c.偏移y + y }
函数 Nova缓冲itmap_创建(w, h) {
    如果 (w <= 0 || h <= 0) { 返回 0 }
    // 整数溢出保护: 限制最大尺寸避免 w*h*4 溢出
    如果 (w > 32768 || h > 32768) { 返回 0 }
    定义 bmp = 堆_分配(32)
    内存_写32(bmp, w)
    内存_写32(bmp + 4, h)
    内存_写32(bmp + 8, w * 4)  // stride = width * 4 (RGBA)
    定义 pixel_size = w * h * 4
    定义 pixels = 堆_分配(pixel_size)
    如果 (pixels == 0) { 堆_释放(bmp); 返回 0 }
    内存_置零(pixels, pixel_size)
    内存_写64(bmp + 16, pixels)
    返回 bmp
}

// 传统方案: 固定规则提升层, 不考虑实际使用模式
// Nova: AI根据层的实际使用模式智能决策提升/降级

结构 AI合成统计 {
    图处层总数,
    纹理内存使用,
    纹理内存限制,
    合成帧数,
    AI提升次数,
    AI降级次数,
    AI释放纹理次数,
}

定义 可变 AI合成全局统计 = 0

函数 AI合成_初始化() {
    AI合成全局统计 = 堆_分配(AI合成统计)
    AI合成全局统计.图处层总数 = 0
    AI合成全局统计.纹理内存使用 = 0
    AI合成全局统计.纹理内存限制 = 256 * 1024 * 1024
    AI合成全局统计.合成帧数 = 0
    AI合成全局统计.AI提升次数 = 0
    AI合成全局统计.AI降级次数 = 0
    AI合成全局统计.AI释放纹理次数 = 0
}

函数 AI合成_智能提升判断(层) {
    如果 (层 == 0) { 返回 假 }
    如果 (层.标志 & 层标志_是合成的) { 返回 假 }

    // 累计绘制次数高 + 每次耗时长 → 应该提升
    如果 (层.累计绘制次数 > 10 && 层.上次绘制耗时 > 500) {
        如果 (AI合成全局统计 != 0) { AI合成全局统计.AI提升次数 = AI合成全局统计.AI提升次数 + 1 }
        返回 真
    }

    // 高注意力权重 + 可见 → 提升保证流畅
    如果 (层.注意力权重 >= 8000 && 层.视口可见 > 0) {
        如果 (AI合成全局统计 != 0) { AI合成全局统计.AI提升次数 = AI合成全局统计.AI提升次数 + 1 }
        返回 真
    }
    返回 假
}

导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../中枢/时钟中枢.nova")
导入("../中枢/链表后继.nova")

// NovaOS AI磁盘预取 — 先天AI特性
// Phase: P5 | AI融入存储IO路径
// 核心算法:
//   1. IO模式检测: 顺序/随机/跳跃模式自动识别
//   2. 步长预测: 线性外推(顺序) / 频率表(随机热点)
//   3. 预取深度自适应: 顺序读→增大预取, 随机读→减小预取
//   4. 命中率反馈: 预取命中率驱动预取策略调整

定义 IO_读 = 0
定义 IO_写 = 1
定义 模式_顺序 = 0
定义 模式_随机 = 1
定义 模式_跳跃 = 2       // 固定步长跳跃

结构 IO记录 {
    扇区,
    类型,
    时间戳,
}

定义 可变 IO历史 = []
定义 IO历史最大 = 64
定义 可变 当前模式 = 模式_随机
定义 可变 检测步长 = 0         // 顺序/跳跃的步长
定义 可变 预取深度 = 8         // 预取扇区数
定义 可变 预取命中 = 0
定义 可变 预取未命中 = 0
定义 可变 命中率EMA = 512      // ×1024
定义 可变 上次预测扇区 = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 AI磁盘_初始化() {
    内核信息("AI磁盘预取: IO模式检测+步长预测+自适应预取深度")
}

// 记录IO操作

函数 AI磁盘_记录IO(扇区, 类型) {
    定义 记录 = IO记录 {}
    记录.扇区 = 扇区
    记录.类型 = 类型
    记录.时间戳 = 读取毫秒()
    追加(IO历史, 记录)
    如果 (计数(IO历史) > IO历史最大) { 链表_删除(IO历史, 0) }

    // 检查预取命中
    如果 (上次预测扇区 > 0) {
        定义 差 = 扇区 - 上次预测扇区
        如果 (差 < 0) { 差 = 0 - 差 }
        如果 (差 <= 预取深度) {
            预取命中 = 预取命中 + 1
            命中率EMA = (命中率EMA * 922 + 1024 * 102) / 1024
        } 否则 {
            预取未命中 = 预取未命中 + 1
            命中率EMA = (命中率EMA * 922 + 0) / 1024
        }
    }

    // 模式检测
    AI磁盘_检测模式()
}

// IO模式检测

函数 AI磁盘_检测模式() {
    定义 n = 计数(IO历史)
    如果 (n < 4) { 返回 }

    // 计算最近4个IO的步长
    定义 可变 步长相同 = 0
    定义 可变 步长为正 = 0
    定义 第一步长 = IO历史[n - 1].扇区 - IO历史[n - 2].扇区

    定义 可变 i = n - 3
    当 (i >= 0 && i >= n - 4) {
        定义 步长 = IO历史[i + 1].扇区 - IO历史[i].扇区
        如果 (步长 == 第一步长) { 步长相同 = 步长相同 + 1 }
        如果 (步长 > 0) { 步长为正 = 步长为正 + 1 }
        i = i - 1
    }

    如果 (步长相同 >= 2 && 第一步长 > 0) {
        如果 (第一步长 <= 16) {
            当前模式 = 模式_顺序
        } 否则 {
            当前模式 = 模式_跳跃
        }
        检测步长 = 第一步长
    } 否则 {
        当前模式 = 模式_随机
        检测步长 = 0
    }

    // 自适应预取深度
    如果 (当前模式 == 模式_顺序) {
        // 顺序读: 命中率高→增大预取
        如果 (命中率EMA > 800) { 预取深度 = 32 }
        否则 如果 (命中率EMA > 500) { 预取深度 = 16 }
        否则 { 预取深度 = 8 }
    } 否则 如果 (当前模式 == 模式_跳跃) {
        预取深度 = 4
    } 否则 {
        预取深度 = 2   // 随机读: 最小预取
    }
}

// 预测下次扇区

函数 AI磁盘_预测下次扇区() {
    定义 n = 计数(IO历史)
    如果 (n < 2) { 上次预测扇区 = 0; 返回 -1 }

    定义 最近 = IO历史[n - 1].扇区
    如果 (当前模式 == 模式_顺序 || 当前模式 == 模式_跳跃) {
        上次预测扇区 = 最近 + 检测步长
    } 否则 {
        // 随机模式: 线性外推
        定义 上次 = IO历史[n - 2].扇区
        上次预测扇区 = 最近 + (最近 - 上次)
    }
    返回 上次预测扇区
}

函数 AI磁盘_预取深度() { 返回 预取深度 }
函数 AI磁盘_当前模式() { 返回 当前模式 }
函数 AI磁盘_命中率() { 返回 命中率EMA * 100 / 1024 }

// IO模式名 + 完整统计

函数 AI磁盘_模式名(模式) {
    如果 (模式 == 模式_顺序) { 返回 "sequential" }
    如果 (模式 == 模式_随机) { 返回 "random" }
    如果 (模式 == 模式_跳跃) { 返回 "strided" }
    返回 "unknown"
}

函数 AI磁盘_完整统计() {
    返回 [当前模式, 预取深度, 预取命中, 预取未命中, AI磁盘_命中率(), 计数(IO历史)]
}

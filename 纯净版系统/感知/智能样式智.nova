导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/内存初始化.nova")

定义 影响_无 = 0
定义 影响_重绘 = 1
定义 影响_重排 = 2
定义 影响_重组 = 3
定义 最大样式表 = 32
定义 最大规则 = 512
定义 缓存桶数 = 128

结构 样式规则 {
    选择器哈希,
    属性数,
    属性表,
    特异度,
    来源,
    行号,
}

结构 样式表 {
    标识,
    规则表,
    规则数,
    已启用,
    媒体哈希,
}

定义 可变 样式表列表 = []
定义 可变 样式表数 = 0
定义 可变 计算缓存 = 0
定义 可变 缓存命中 = 0
定义 可变 缓存未中 = 0
定义 可变 失效次数 = 0
定义 可变 规则匹配数 = 0

函数 样式对象_初始化() {
    样式表列表 = []
    样式表数 = 0
    计算缓存 = 堆_分配(缓存桶数 * 8)
    定义 可变 序号 = 0
    当 (序号 < 缓存桶数) {
        内存_写64(计算缓存 + 序号 * 8, 0)
        序号 = 序号 + 1
    }
}

函数 样式对象_添加表(媒体哈希) {
    如果 (样式表数 >= 最大样式表) { 返回 -1 }
    定义 表 = 样式表 {}
    表.标识 = 样式表数
    表.规则表 = []
    表.规则数 = 0
    表.已启用 = 真
    表.媒体哈希 = 媒体哈希
    追加(样式表列表, 表)
    定义 索引 = 样式表数
    样式表数 = 样式表数 + 1
    返回 索引
}

函数 样式对象_添加规则(表索引, 选择器哈希, 属性表, 属性数, 特异度) {
    如果 (表索引 >= 样式表数) { 返回 -1 }
    定义 表 = 样式表列表[表索引]
    如果 (表.规则数 >= 最大规则) { 返回 -1 }
    定义 规则 = 样式规则 {}
    规则.选择器哈希 = 选择器哈希
    规则.属性数 = 属性数
    规则.属性表 = 属性表
    规则.特异度 = 特异度
    规则.来源 = 表索引
    规则.行号 = 表.规则数
    追加(表.规则表, 规则)
    表.规则数 = 表.规则数 + 1
    样式对象_失效缓存()
    返回 表.规则数 - 1
}

函数 样式对象_删除规则(表索引, 规则索引) {
    如果 (表索引 >= 样式表数) { 返回 }
    定义 表 = 样式表列表[表索引]
    如果 (规则索引 >= 表.规则数) { 返回 }
    表.规则表[规则索引] = 表.规则表[表.规则数 - 1]
    表.规则数 = 表.规则数 - 1
    样式对象_失效缓存()
}

函数 样式对象_启用表(表索引, 启用) {
    如果 (表索引 >= 样式表数) { 返回 }
    样式表列表[表索引].已启用 = 启用
    样式对象_失效缓存()
}

函数 样式对象_匹配规则(元素哈希) {
    规则匹配数 = 规则匹配数 + 1
    定义 桶号 = 元素哈希 % 缓存桶数
    定义 缓存值 = 内存_读64(计算缓存 + 桶号 * 8)
    如果 (缓存值 != 0) {
        缓存命中 = 缓存命中 + 1
        返回 缓存值
    }
    缓存未中 = 缓存未中 + 1
    定义 可变 最高特异 = 0
    定义 可变 最佳规则 = 0
    定义 可变 表序 = 0
    当 (表序 < 样式表数) {
        定义 表 = 样式表列表[表序]
        如果 (!表.已启用) { 表序 = 表序 + 1; 继续 }
        定义 可变 规则序 = 0
        当 (规则序 < 表.规则数) {
            定义 规则 = 表.规则表[规则序]
            如果 (规则.特异度 > 最高特异) {
                最高特异 = 规则.特异度
                最佳规则 = 规则.属性表
            }
            规则序 = 规则序 + 1
        }
        表序 = 表序 + 1
    }
    内存_写64(计算缓存 + 桶号 * 8, 最佳规则)
    返回 最佳规则
}

函数 样式对象_失效缓存() {
    失效次数 = 失效次数 + 1
    定义 可变 序号 = 0
    当 (序号 < 缓存桶数) {
        内存_写64(计算缓存 + 序号 * 8, 0)
        序号 = 序号 + 1
    }
    缓存命中 = 0
    缓存未中 = 0
}

函数 样式对象_分析影响(属性标识) {
    如果 (属性标识 < 10) { 返回 影响_重排 }
    如果 (属性标识 < 30) { 返回 影响_重绘 }
    如果 (属性标识 < 50) { 返回 影响_重排 }
    返回 影响_重绘
}

函数 样式对象_推断意图(属性列表, 属性数) {
    定义 可变 有变换 = 假
    定义 可变 有透明 = 假
    定义 可变 有过渡 = 假
    定义 可变 序号 = 0
    当 (序号 < 属性数) {
        定义 属性 = 内存_读32(属性列表 + 序号 * 8)
        如果 (属性 == 40) { 有变换 = 真 }
        如果 (属性 == 41) { 有透明 = 真 }
        如果 (属性 == 42) { 有过渡 = 真 }
        序号 = 序号 + 1
    }
    如果 (有变换 && 有透明) { 返回 1 }
    如果 (有过渡) { 返回 2 }
    返回 0
}

函数 样式对象_缓存命中率() {
    定义 总 = 缓存命中 + 缓存未中
    如果 (总 == 0) { 返回 0 }
    返回 缓存命中 * 100 / 总
}

函数 样式对象_总规则数() {
    定义 可变 总 = 0
    定义 可变 序号 = 0
    当 (序号 < 样式表数) { 总 = 总 + 样式表列表[序号].规则数; 序号 = 序号 + 1 }
    返回 总
}

函数 样式对象_完整统计() {
    返回 [样式表数, 样式对象_总规则数(), 规则匹配数, 缓存命中, 缓存未中, 样式对象_缓存命中率(), 失效次数]
}

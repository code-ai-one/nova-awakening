函数 白璃主题_内容区文本() {
    定义 内容 = ""
    内容 = 内容 + 白璃主题_对("display", "grid")
    内容 = 内容 + 白璃主题_对("grid-template-columns", "280px minmax(0, 1fr)")
    内容 = 内容 + 白璃主题_对("gap", "22px")
    内容 = 内容 + 白璃主题_对("padding", "22px")
    内容 = 内容 + 白璃主题_对("background", "linear-gradient(180deg, rgba(249,251,255,0.82), rgba(244,248,252,0.64))")

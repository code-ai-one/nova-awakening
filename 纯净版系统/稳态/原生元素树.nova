// NovaOS · 图处驱动层 · 原生GUI元素树
// Nova原生UI元素系统 — 零Web依赖的底层GUI节点
// 直接操作帧缓冲，通过内核DRM/KMS接口输出
// §1 Nova原生元素树: 容器/文本/按钮/输入/图片
// §2 原生样式系统: 内联属性直接计算，无CSS层叠
// §3 布局引擎: 块级/行内/弹性布局 + 盒模型
// §4 绘制引擎: 元素树→帧缓冲像素
// §5 无障碍树: AI可直接读取的语义结构

// §1 Nova原生GUI元素类型 — 零HTML/DOM概念

定义 元素类型_容器 = 1      // 通用容器(替代div)
定义 元素类型_文本 = 2      // 文本节点
定义 元素类型_根 = 3        // 根窗口

// Nova原生控件类型
定义 控件_容器 = 0          // 普通容器
定义 控件_文本标签 = 1      // 只读文本
定义 控件_按钮 = 2          // 可点击按钮
定义 控件_输入框 = 3        // 文本输入
定义 控件_图片 = 4          // 图片显示
定义 控件_列表 = 5          // 列表容器
定义 控件_列表项 = 6        // 列表项
定义 控件_导航栏 = 7        // 导航区域
定义 控件_区域 = 8          // 内容区域
定义 控件_表格 = 9          // 表格
定义 控件_表行 = 10         // 表行
定义 控件_表格 = 11         // 表格单元
定义 控件_表单 = 12         // 表单容器
定义 控件_多行输入 = 13     // 多行文本输入
定义 控件_下拉选择 = 14     // 下拉选择框
定义 控件_标题 = 15         // 标题文本(1-6级)
定义 控件_头部 = 16         // 页头区域
定义 控件_底部 = 17         // 页脚区域

结构 元素属性 {
    键哈希,
    值哈希,
    值字符串,
}

结构 原生元素 {
    元素ID,
    类型,    // u8 元素类型_xxx
    控件类型,    // u32 控件_xxx
    文本内容,
    属性列表,    // [] 元素属性数组
    子元素,    // [] 原生元素数组
    父元素ID,
    // 布局数据(由布局引擎计算)
    布局_x,
    布局_y,
    布局_宽,
    布局_高,
    // 样式(内联直接属性,无CSS层叠)
    样式,    // 空 原生计算样式
    可见,
    可交互,    // 布尔 是否可点击/输入
    语义角色,    // 字符串 button/textbox/navigation/...
}

定义 可变 元素_根节点 = 空
定义 可变 元素_下一个ID = 1
定义 可变 元素_总数 = 0
定义 可变 元素树_锁 = 0     // 自旋锁保护并发访问

函数 元素_创建(控件类型) {
    定义 元素 = kmalloc(原生元素)
    元素.元素ID = 元素_下一个ID
    元素_下一个ID = 元素_下一个ID + 1
    元素_总数 = 元素_总数 + 1
    元素.类型 = 元素类型_容器
    元素.控件类型 = 控件类型
    元素.属性列表 = []
    元素.子元素 = []
    元素.可见 = 真
    元素.可交互 = (控件类型 == 控件_按钮 || 控件类型 == 控件_输入框 ||
                  控件类型 == 控件_多行输入 || 控件类型 == 控件_下拉选择)
    元素.语义角色 = 元素_推断角色(控件类型)
    返回 元素
}

函数 元素_创建文本(内容) {
    定义 元素 = kmalloc(原生元素)
    元素.元素ID = 元素_下一个ID
    元素_下一个ID = 元素_下一个ID + 1
    元素_总数 = 元素_总数 + 1
    元素.类型 = 元素类型_文本
    元素.文本内容 = 内容
    元素.子元素 = []
    元素.属性列表 = []
    元素.可见 = 真
    元素.可交互 = 假
    元素.语义角色 = "text"
    返回 元素
}

函数 元素_添加子节点(父, 子) {
    如果 (父 == 空 || 子 == 空) { 返回 }
    自旋锁_获取(元素树_锁)
    子.父元素ID = 父.元素ID
    追加(父.子元素, 子)
    自旋锁_释放(元素树_锁)
}

函数 元素_设属性(元素, 键哈希, 值) {
    如果 (元素 == 空) { 返回 }
    定义 attr = 元素属性 {}
    attr.键哈希 = 键哈希
    attr.值字符串 = 值
    追加(元素.属性列表, attr)
}

函数 元素_获取属性(元素, 键哈希) {
    如果 (元素 == 空) { 返回 "" }
    定义 可变 i = 0
    当 (i < 计数(元素.属性列表)) {
        如果 (元素.属性列表[i].键哈希 == 键哈希) {
            返回 元素.属性列表[i].值字符串
        }
        i = i + 1
    }
    返回 ""
}

函数 元素_推断角色(控件类型) {
    如果 (控件类型 == 控件_按钮) { 返回 "button" }
    如果 (控件类型 == 控件_输入框) { 返回 "textbox" }
    如果 (控件类型 == 控件_多行输入) { 返回 "textbox" }
    如果 (控件类型 == 控件_下拉选择) { 返回 "combobox" }
    如果 (控件类型 == 控件_图片) { 返回 "img" }
    如果 (控件类型 == 控件_导航栏) { 返回 "navigation" }
    如果 (控件类型 == 控件_标题) { 返回 "heading" }
    如果 (控件类型 == 控件_表格) { 返回 "table" }
    如果 (控件类型 == 控件_表单) { 返回 "form" }
    如果 (控件类型 == 控件_列表) { 返回 "list" }
    如果 (控件类型 == 控件_列表项) { 返回 "listitem" }
    返回 "generic"
}

函数 元素_释放(元素) {
    如果 (元素 == 空) { 返回 }
    // 递归释放子元素
    定义 可变 i = 0
    当 (i < 计数(元素.子元素)) {
        元素_释放(元素.子元素[i])
        i = i + 1
    }
    kfree(元素)
    元素_总数 = 元素_总数 - 1
}

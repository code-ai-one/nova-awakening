// NovaOS VFS读写
// 职责: vfs_read/vfs_write/lseek/readv/writev

定义 SEEK_SET = 0    // 从文件头开始
定义 SEEK_CUR = 1    // 从当前位置
定义 SEEK_END = 2    // 从文件尾

定义 可变 VFS_读次数 = 0
定义 可变 VFS_写次数 = 0
定义 可变 VFS_读字节 = 0
定义 可变 VFS_写字节 = 0

// vfs_read: VFS层读文件

函数 vfs_read(文件, 缓冲区, 大小) {
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    如果 (大小 == 0) { 返回 0 }

    // 检查文件是否可读
    定义 标志 = 文件[F_标志]
    如果 ((标志 & O_WRONLY) != 0 && (标志 & O_RDWR) == 0) {
        返回 错误_坏文件描述符  // 只写模式不能读
    }

    // 获取Nova文件节点和操作表
    定义 节点 = 文件[F_Nova文件节点]
    如果 (节点 == 空) { 返回 错误_坏文件描述符 }

    定义 操作 = 文件[F_操作]
    如果 (操作 == 空 || 操作.读 == 空) {
        返回 错误_无效参数
    }

    // 检查文件大小限制
    定义 位置 = 文件[F_偏移]
    定义 文件大小 = 节点[I_大小]
    如果 (位置 >= 文件大小) { 返回 0 }  // EOF
    如果 (位置 + 大小 > 文件大小) {
        大小 = 文件大小 - 位置
    }

    // 调用具体文件系统的read
    定义 已读 = 操作.读(文件, 缓冲区, 大小, 位置)

    如果 (已读 > 0) {
        // 更新文件偏移
        设置(文件, F_偏移, 位置 + 已读)
        // 更新Nova文件节点访问时间
        Nova文件节点_更新访问时间(节点)
        VFS_读次数 = VFS_读次数 + 1
        VFS_读字节 = VFS_读字节 + 已读
    }

    返回 已读
}

// vfs_write: VFS层写文件

函数 vfs_write(文件, 数据, 大小) {
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    如果 (大小 == 0) { 返回 0 }

    // 检查文件是否可写
    定义 标志 = 文件[F_标志]
    如果 ((标志 & O_WRONLY) == 0 && (标志 & O_RDWR) == 0) {
        返回 错误_坏文件描述符  // 只读模式不能写
    }

    定义 节点 = 文件[F_Nova文件节点]
    如果 (节点 == 空) { 返回 错误_坏文件描述符 }

    定义 操作 = 文件[F_操作]
    如果 (操作 == 空 || 操作.写 == 空) {
        返回 错误_无效参数
    }

    // O_APPEND: 写入位置设为文件尾
    定义 可变 位置 = 文件[F_偏移]
    如果 ((标志 & O_APPEND) != 0) {
        位置 = 节点[I_大小]
    }

    // 调用具体文件系统的write
    定义 已写 = 操作.写(文件, 数据, 大小, 位置)

    如果 (已写 > 0) {
        设置(文件, F_偏移, 位置 + 已写)
        // 更新文件大小
        如果 (位置 + 已写 > 节点[I_大小]) {
            Nova文件节点_设置大小(节点, 位置 + 已写)
        }
        // 标记Nova文件节点为脏 (需要写回磁盘)
        Nova文件节点_标记脏(节点)
        // 更新修改时间
        Nova文件节点_更新修改时间(节点)
        VFS_写次数 = VFS_写次数 + 1
        VFS_写字节 = VFS_写字节 + 已写
        // 平衡脏页
        回写_平衡脏页()
    }

    返回 已写
}

// lseek: 移动文件偏移

函数 vfs_lseek(文件, 偏移, 起点) {
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }

    定义 节点 = 文件[F_Nova文件节点]
    定义 可变 新位置 = 0

    如果 (起点 == SEEK_SET) {
        新位置 = 偏移
    } 否则 如果 (起点 == SEEK_CUR) {
        新位置 = 文件[F_偏移] + 偏移
    } 否则 如果 (起点 == SEEK_END) {
        新位置 = 节点[I_大小] + 偏移
    } 否则 {
        返回 错误_无效参数
    }

    如果 (新位置 < 0) { 返回 错误_无效参数 }

    设置(文件, F_偏移, 新位置)
    返回 新位置
}

// pread/pwrite: 指定偏移读写 (不改变文件偏移)

函数 vfs_pread(文件, 缓冲区, 大小, 位置) {
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    定义 操作 = 文件[F_操作]
    如果 (操作 == 空 || 操作.读 == 空) { 返回 错误_无效参数 }

    定义 节点 = 文件[F_Nova文件节点]
    如果 (位置 >= 节点[I_大小]) { 返回 0 }
    如果 (位置 + 大小 > 节点[I_大小]) { 大小 = 节点[I_大小] - 位置 }

    返回 操作.读(文件, 缓冲区, 大小, 位置)
}

函数 vfs_pwrite(文件, 数据, 大小, 位置) {
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    定义 操作 = 文件[F_操作]
    如果 (操作 == 空 || 操作.写 == 空) { 返回 错误_无效参数 }

    定义 已写 = 操作.写(文件, 数据, 大小, 位置)
    如果 (已写 > 0) {
        定义 节点 = 文件[F_Nova文件节点]
        如果 (位置 + 已写 > 节点[I_大小]) {
            Nova文件节点_设置大小(节点, 位置 + 已写)
        }
        Nova文件节点_标记脏(节点)
    }
    返回 已写
}

// readv/writev: 分散/聚集IO

// iovec: [缓冲区地址, 大小]
函数 vfs_readv(文件, iov列表) {
    定义 可变 总读 = 0
    定义 可变 i = 0
    当 (i < 计数(iov列表)) {
        定义 缓冲 = iov列表[i][0]
        定义 大小 = iov列表[i][1]
        定义 已读 = vfs_read(文件, 缓冲, 大小)
        如果 (已读 < 0) {
            如果 (总读 > 0) { 返回 总读 }
            返回 已读
        }
        总读 = 总读 + 已读
        如果 (已读 < 大小) { 中断 }  // 短读
        i = i + 1
    }
    返回 总读
}

函数 vfs_writev(文件, iov列表) {
    定义 可变 总写 = 0
    定义 可变 i = 0
    当 (i < 计数(iov列表)) {
        定义 数据 = iov列表[i][0]
        定义 大小 = iov列表[i][1]
        定义 已写 = vfs_write(文件, 数据, 大小)
        如果 (已写 < 0) {
            如果 (总写 > 0) { 返回 总写 }
            返回 已写
        }
        总写 = 总写 + 已写
        如果 (已写 < 大小) { 中断 }
        i = i + 1
    }
    返回 总写
}

// fsync/fdatasync: 同步文件数据到磁盘

定义 可变 AI_虚文件信号_热文件表 = []

函数 AI_虚文件信号_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_虚文件信号_热文件表)) {
        如果 (AI_虚文件信号_热文件表[i].路径 == 路径) {
            AI_虚文件信号_热文件表[i].频率 = AI_虚文件信号_热文件表[i].频率 + 1
            返回 AI_虚文件信号_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_虚文件信号_热文件表) < 128) {
        追加(AI_虚文件信号_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_虚文件信号_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

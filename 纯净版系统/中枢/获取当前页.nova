导入("./类型定义.nova")
导入("./错误码.nova")
导入("./页表重建.nova")
导入("../引导/寄存器定义.nova")

定义 页大小 = 4096
定义 页表项数 = 512
定义 存在位 = 1
定义 可写位 = 2
定义 用户位 = 4
定义 写穿位 = 8
定义 禁缓位 = 16
定义 访问位 = 32
定义 脏位 = 64
定义 大页位 = 128
定义 全局位 = 256
定义 禁执位 = 0x8000000000000000
定义 地址掩码 = 0xFFFFFFFFF000

定义 可变 内核顶表 = 0
定义 可变 分配次数 = 0
定义 可变 释放次数 = 0
定义 可变 映射次数 = 0
定义 可变 解映射次数 = 0
定义 可变 刷新次数 = 0

函数 页表_获取当前() {
    返回 读CR3() & 地址掩码
}

函数 页表_获取内核() {
    返回 内核顶表
}

函数 页表_设内核(物理地址) {
    内核顶表 = 物理地址
}

函数 页表_创建() {
    定义 页 = 堆_分配(页大小)
    如果 (页 == 0) { 返回 0 }
    定义 可变 位 = 0
    当 (位 < 页大小) { 内存_写64(页 + 位, 0); 位 = 位 + 8 }
    分配次数 = 分配次数 + 1
    返回 页
}

函数 页表_释放(物理地址) {
    如果 (物理地址 == 0) { 返回 }
    堆_释放(物理地址)
    释放次数 = 释放次数 + 1
}

函数 页表_读条目(表地址, 索引) {
    如果 (索引 >= 页表项数) { 返回 0 }
    返回 内存_读64(表地址 + 索引 * 8)
}

函数 页表_写条目(表地址, 索引, 值) {
    如果 (索引 >= 页表项数) { 返回 }
    内存_写64(表地址 + 索引 * 8, 值)
}

函数 页表_虚拟到索引(虚拟地址, 级别) {
    如果 (级别 == 4) { 返回 (虚拟地址 >> 39) & 0x1FF }
    如果 (级别 == 3) { 返回 (虚拟地址 >> 30) & 0x1FF }
    如果 (级别 == 2) { 返回 (虚拟地址 >> 21) & 0x1FF }
    返回 (虚拟地址 >> 12) & 0x1FF
}

函数 页表_遍历(顶表, 虚拟地址, 创建中间表) {
    定义 可变 当前表 = 顶表
    定义 可变 级别 = 4
    当 (级别 > 1) {
        定义 索引 = 页表_虚拟到索引(虚拟地址, 级别)
        定义 条目 = 页表_读条目(当前表, 索引)
        如果 ((条目 & 存在位) == 0) {
            如果 (!创建中间表) { 返回 0 }
            定义 新表 = 页表_创建()
            如果 (新表 == 0) { 返回 0 }
            页表_写条目(当前表, 索引, 新表 | 存在位 | 可写位 | 用户位)
            当前表 = 新表
        } 否则 {
            当前表 = 条目 & 地址掩码
        }
        级别 = 级别 - 1
    }
    返回 当前表
}

函数 页表_映射(顶表, 虚拟地址, 物理地址, 标志) {
    映射次数 = 映射次数 + 1
    定义 末级表 = 页表_遍历(顶表, 虚拟地址, 真)
    如果 (末级表 == 0) { 返回 错误_内存不足 }
    定义 索引 = 页表_虚拟到索引(虚拟地址, 1)
    定义 条目 = (物理地址 & 地址掩码) | 标志 | 存在位
    页表_写条目(末级表, 索引, 条目)
    页表_刷新单页(虚拟地址)
    返回 0
}

函数 页表_解映射(顶表, 虚拟地址) {
    解映射次数 = 解映射次数 + 1
    定义 末级表 = 页表_遍历(顶表, 虚拟地址, 假)
    如果 (末级表 == 0) { 返回 }
    定义 索引 = 页表_虚拟到索引(虚拟地址, 1)
    页表_写条目(末级表, 索引, 0)
    页表_刷新单页(虚拟地址)
}

函数 页表_查询(顶表, 虚拟地址) {
    定义 末级表 = 页表_遍历(顶表, 虚拟地址, 假)
    如果 (末级表 == 0) { 返回 0 }
    定义 索引 = 页表_虚拟到索引(虚拟地址, 1)
    返回 页表_读条目(末级表, 索引)
}

函数 页表_修改权限(顶表, 虚拟地址, 新标志) {
    定义 末级表 = 页表_遍历(顶表, 虚拟地址, 假)
    如果 (末级表 == 0) { 返回 }
    定义 索引 = 页表_虚拟到索引(虚拟地址, 1)
    定义 条目 = 页表_读条目(末级表, 索引)
    如果 ((条目 & 存在位) == 0) { 返回 }
    定义 物理 = 条目 & 地址掩码
    页表_写条目(末级表, 索引, 物理 | 新标志 | 存在位)
    页表_刷新单页(虚拟地址)
}

函数 页表_复制内核部分(新顶表) {
    定义 可变 索引 = 256
    当 (索引 < 页表项数) {
        定义 条目 = 页表_读条目(内核顶表, 索引)
        页表_写条目(新顶表, 索引, 条目)
        索引 = 索引 + 1
    }
}

函数 页表_刷新单页(虚拟地址) {
    刷新次数 = 刷新次数 + 1
    特权_刷新页(虚拟地址)
}

函数 页表_刷新全部() {
    刷新次数 = 刷新次数 + 1
    定义 当前 = 读CR3()
    写CR3(当前)
}

函数 页表_切换(新顶表物理) {
    写CR3(新顶表物理)
}

函数 页表_范围映射(顶表, 虚拟起始, 物理起始, 页数, 标志) {
    定义 可变 序号 = 0
    当 (序号 < 页数) {
        定义 虚拟 = 虚拟起始 + 序号 * 页大小
        定义 物理 = 物理起始 + 序号 * 页大小
        页表_映射(顶表, 虚拟, 物理, 标志)
        序号 = 序号 + 1
    }
}

函数 页表_范围解映射(顶表, 虚拟起始, 页数) {
    定义 可变 序号 = 0
    当 (序号 < 页数) {
        页表_解映射(顶表, 虚拟起始 + 序号 * 页大小)
        序号 = 序号 + 1
    }
}

函数 页表管理_完整统计() {
    返回 [分配次数, 释放次数, 映射次数, 解映射次数, 刷新次数]
}

定义 可变 AI_获取当前页_运行指标 = 0
定义 可变 AI_获取当前页_异常指标 = 0

函数 AI_获取当前页_自诊断() {
    AI_获取当前页_运行指标 = 分配次数
    返回 AI_获取当前页_运行指标
}

函数 AI_获取当前页_优化建议() {
    定义 指标 = AI_获取当前页_自诊断()
    如果 (AI_获取当前页_运行指标 > 10000) { 返回 "获取当前页负载较高" }
    返回 "获取当前页状态正常"
}

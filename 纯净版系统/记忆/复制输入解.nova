// cpio newc格式 (SVR4, 无CRC):
//   魔数: "070701" (6字节ASCII)
//   头部: 固定110字节, 所有数值字段为8字节十六进制ASCII
//   字段: ino, mode, uid, gid, nlink, mtime, filesize,
//          devmajor, devminor, rdevmajor, rdevminor, namesize, check
//   文件名: 紧跟头部, 长度=namesize(含\0), 4字节对齐
//   数据: 紧跟文件名, 长度=filesize, 4字节对齐
//   结束标记: 文件名="TRAILER!!!"

外部 vfs_mkdir
外部 vfs_create
外部 vfs_write
外部 vfs_close
外部 vfs_symlink
外部 vfs_mknod

定义 CPIO_MAGIC_OFF   = 0     // 6字节: "070701"
定义 CPIO_INO_OFF     = 6     // 8字节hex: Nova文件节点号
定义 CPIO_MODE_OFF    = 14    // 8字节hex: 文件模式(类型+权限)
定义 CPIO_UID_OFF     = 22    // 8字节hex: 用户ID
定义 CPIO_GID_OFF     = 30    // 8字节hex: 组ID
定义 CPIO_NLINK_OFF   = 38    // 8字节hex: 硬链接数
定义 CPIO_MTIME_OFF   = 46    // 8字节hex: 修改时间
定义 CPIO_FILESIZE_OFF = 54   // 8字节hex: 文件数据大小
定义 CPIO_DEVMAJOR_OFF = 62   // 8字节hex: 设备主号
定义 CPIO_DEVMINOR_OFF = 70   // 8字节hex: 设备次号
定义 CPIO_RDEVMAJOR_OFF = 78  // 8字节hex: 特殊设备主号
定义 CPIO_RDEVMINOR_OFF = 86  // 8字节hex: 特殊设备次号
定义 CPIO_NAMESIZE_OFF = 94   // 8字节hex: 文件名长度(含\0)
定义 CPIO_CHECK_OFF   = 102   // 8字节hex: 校验和(newc=0)
定义 CPIO_HEADER_SIZE = 110   // 头部总大小

定义 CPIO_魔数 = "070701"

结构 cpio_头信息 {
    名称,
    模式,
    uid,
    gid,
    大小,
    修改时间,
    Nova文件节点号,
    链接数,
    主设备号,
    次设备号,
    头总大小,    // u32 头+文件名(含对齐填充)
}

// 解析cpio头 

函数 cpio_解析头(数据, 偏移) {
    // 检查剩余空间
    如果 (偏移 + CPIO_HEADER_SIZE > 数据大小(数据)) { 返回 空 }

    // 验证魔数 "070701"
    如果 (读取字节(数据, 偏移) != 0x30 || 读取字节(数据, 偏移 + 1) != 0x37 ||
        读取字节(数据, 偏移 + 2) != 0x30 || 读取字节(数据, 偏移 + 3) != 0x37 ||
        读取字节(数据, 偏移 + 4) != 0x30 || 读取字节(数据, 偏移 + 5) != 0x31) {
        返回 空
    }

    // 解析各字段 (8字节十六进制ASCII → 整数)
    定义 头 = cpio_头信息 {}
    头.Nova文件节点号   = 解析hex8(数据, 偏移 + CPIO_INO_OFF)
    头.模式      = 解析hex8(数据, 偏移 + CPIO_MODE_OFF)
    头.uid       = 解析hex8(数据, 偏移 + CPIO_UID_OFF)
    头.gid       = 解析hex8(数据, 偏移 + CPIO_GID_OFF)
    头.链接数    = 解析hex8(数据, 偏移 + CPIO_NLINK_OFF)
    头.修改时间  = 解析hex8(数据, 偏移 + CPIO_MTIME_OFF)
    头.大小      = 解析hex8(数据, 偏移 + CPIO_FILESIZE_OFF)
    头.主设备号  = 解析hex8(数据, 偏移 + CPIO_RDEVMAJOR_OFF)
    头.次设备号  = 解析hex8(数据, 偏移 + CPIO_RDEVMINOR_OFF)

    定义 名称长度 = 解析hex8(数据, 偏移 + CPIO_NAMESIZE_OFF)

    // 读取文件名 (在头部之后, 长度=namesize)
    头.名称 = 读取字符串(数据 + 偏移 + CPIO_HEADER_SIZE, 名称长度 - 1)

    // 头总大小 = 110 + namesize, 4字节对齐
    头.头总大小 = 对齐4(CPIO_HEADER_SIZE + 名称长度)

    返回 头
}

// 解析8字节十六进制ASCII为整数
// "0000001F" → 31

函数 解析hex8(数据, 偏移) {
    定义 可变 结果 = 0
    定义 可变 i = 0
    当 (i < 8) {
        定义 字节 = 读取字节(数据, 偏移 + i)
        定义 可变 值 = 0
        如果 (字节 >= 0x30 && 字节 <= 0x39) {
            值 = 字节 - 0x30          // '0'-'9'
        } 否则 如果 (字节 >= 0x41 && 字节 <= 0x46) {
            值 = 字节 - 0x41 + 10     // 'A'-'F'
        } 否则 如果 (字节 >= 0x61 && 字节 <= 0x66) {
            值 = 字节 - 0x61 + 10     // 'a'-'f'
        }
        结果 = 结果 * 16 + 值
        i = i + 1
    }
    返回 结果
}

// 遍历cpio归档

函数 cpio_解压(数据, 大小) {
    定义 可变 偏移 = 0
    定义 可变 文件数 = 0
    当 (偏移 + CPIO_HEADER_SIZE <= 大小) {
        定义 头 = cpio_解析头(数据, 偏移)
        如果 (头 == 空) { 中断 }
        如果 (头.名称 == "TRAILER!!!") { 中断 }
        文件数 = 文件数 + 1
        偏移 = 偏移 + 头.头总大小 + 对齐4(头.大小)
    }
    返回 文件数
}

函数 对齐4_cpio(值) {
    返回 (值 + 3) & ~3
}

函数 数据大小(数据) {
    // 返回缓冲区大小(简化: 用最大整数)
    返回 0x7FFFFFFFFFFFFFFF
}

// 完整解压到ramfs 

// 文件类型常量 (mode高4位)
定义 S_IFMT   = 0xF000
定义 S_IFDIR  = 0x4000
定义 S_IFREG  = 0x8000
定义 S_IFLNK  = 0xA000
定义 S_IFCHR  = 0x2000
定义 S_IFBLK  = 0x6000
定义 S_IFIFO  = 0x1000

定义 可变 cpio_解压文件数 = 0
定义 可变 cpio_解压目录数 = 0
定义 可变 cpio_解压总字节 = 0

函数 cpio_完整解压(数据, 大小) {
    定义 可变 偏移 = 0
    cpio_解压文件数 = 0
    cpio_解压目录数 = 0
    cpio_解压总字节 = 0

    当 (偏移 + CPIO_HEADER_SIZE <= 大小) {
        定义 头 = cpio_解析头(数据, 偏移)
        如果 (头 == 空) { 中断 }
        如果 (头.名称 == "TRAILER!!!") { 中断 }

        定义 数据偏移 = 偏移 + 头.头总大小
        定义 文件类型 = 头.模式 & S_IFMT

        如果 (文件类型 == S_IFDIR) {
            // 创建目录
            cpio_创建目录(头.名称, 头.模式 & 0xFFF, 头.uid, 头.gid)
            cpio_解压目录数 = cpio_解压目录数 + 1
        } 否则 如果 (文件类型 == S_IFREG) {
            // 创建普通文件并写入数据
            cpio_创建文件(头.名称, 头.模式 & 0xFFF, 头.uid, 头.gid,
                         数据 + 数据偏移, 头.大小)
            cpio_解压文件数 = cpio_解压文件数 + 1
            cpio_解压总字节 = cpio_解压总字节 + 头.大小
        } 否则 如果 (文件类型 == S_IFLNK) {
            // 创建符号链接 (链接目标在数据区)
            定义 目标 = 读取字符串(数据 + 数据偏移, 头.大小)
            cpio_创建符号链接(头.名称, 目标)
        } 否则 如果 (文件类型 == S_IFCHR || 文件类型 == S_IFBLK) {
            // 创建设备节点
            cpio_创建设备节点(头.名称, 文件类型, 头.主设备号, 头.次设备号)
        }

        偏移 = 数据偏移 + 对齐4(头.大小)
    }

    内核信息("initramfs: 解压完成 - " + 整数转字符串(cpio_解压文件数) + "文件, " +
             整数转字符串(cpio_解压目录数) + "目录, " +
             整数转字符串(cpio_解压总字节) + "字节")
    返回 cpio_解压文件数 + cpio_解压目录数
}

// 文件系统操作代理 (调用ram文件系统模块

函数 cpio_创建目录(路径, 权限, uid, gid) {
    定义 结果 = vfs_mkdir(路径, 权限)
    如果 (结果 != 0) {
        // 目录可能已存在,忽略错误
    }
}

函数 cpio_创建文件(路径, 权限, uid, gid, 数据, 大小) {
    定义 fd = vfs_create(路径, 权限)
    如果 (fd < 0) { 返回 }
    如果 (大小 > 0) {
        vfs_write(fd, 数据, 大小)
    }
    vfs_close(fd)
}

函数 cpio_创建符号链接(路径, 目标) {
    vfs_symlink(目标, 路径)
}

函数 cpio_创建设备节点(路径, 类型, 主号, 次号) {
    vfs_mknod(路径, 类型, 主号 * 256 + 次号)
}

// cpio归档列表 (不解压,仅列出内容)

函数 cpio_列出内容(数据, 大小) {
    定义 可变 偏移 = 0
    定义 可变 结果 = []
    当 (偏移 + CPIO_HEADER_SIZE <= 大小) {
        定义 头 = cpio_解析头(数据, 偏移)
        如果 (头 == 空) { 中断 }
        如果 (头.名称 == "TRAILER!!!") { 中断 }

        定义 类型字符 = "?"
        定义 文件类型 = 头.模式 & S_IFMT
        如果 (文件类型 == S_IFDIR) { 类型字符 = "d" }
        否则 如果 (文件类型 == S_IFREG) { 类型字符 = "-" }
        否则 如果 (文件类型 == S_IFLNK) { 类型字符 = "l" }
        否则 如果 (文件类型 == S_IFCHR) { 类型字符 = "c" }
        否则 如果 (文件类型 == S_IFBLK) { 类型字符 = "b" }

        追加(结果, [类型字符, 头.名称, 头.大小, 头.uid, 头.gid])
        偏移 = 偏移 + 头.头总大小 + 对齐4(头.大小)
    }
    返回 结果
}

// 统计

函数 cpio_统计() {
    返回 [cpio_解压文件数, cpio_解压目录数, cpio_解压总字节]
}


函数 cpio_完整统计() {
    返回 [cpio_解压文件数, cpio_解压目录数, cpio_解压总字节]
}

// cpio健康检查

函数 cpio_健康检查() {
    定义 可变 问题 = []
    如果 (cpio_解压文件数 == 0 && cpio_解压目录数 == 0) {
        追加(问题, "cpio归档为空")
    }
    如果 (cpio_解压总字节 > 512 * 1024 * 1024) {
        追加(问题, "cpio解压体积过大: " + 整数转字符串(cpio_解压总字节 / 1024 / 1024) + "MB")
    }
    如果 (计数(问题) == 0) { 返回 "cpio健康" }
    返回 问题
}

函数 cpio_魔数检查(头部) {
    如果 (头部 == 空) { 返回 假 }
    定义 魔数 = 内存_读16(头部)
    如果 (魔数 == 0x71C7) { 返回 真 }
    如果 (魔数 == 0xC771) { 返回 真 }
    返回 假
}

函数 cpio_重置() {
    cpio_解压文件数 = 0
    cpio_解压目录数 = 0
    cpio_解压总字节 = 0
}

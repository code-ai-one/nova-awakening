导入("./类型定义.nova")
导入("./错误码.nova")
导入("./公平调度调.nova")

// NovaOS Nova公平调度 带宽控制 (Bandwidth Control)
// 功能: 限制进程组的CPU使用率
//   - 周期性配额: 每个周期(100ms)分配固定配额(如50ms = 50% CPU)
//   - 配额耗尽: 进程组被节流(throttle)直到下个周期
//   - 突发支持: 允许短时间超配额使用
//   - 层级控制: 支持cgroup层级的带宽限制
// 用途:
//   - 容器资源限制 (Docker/K8s)
//   - 多租户隔离
//   - QoS保证
//   - 防止CPU饥饿

// 带宽控制常量

定义 BW_周期 = 100000           // 100ms (us)
定义 BW_默认配额 = 0 - 1        // -1 = 无限制
定义 BW_最小配额 = 1000         // 1ms
定义 BW_突发因子 = 2            // 允许2倍突发

// 带宽控制结构 

定义 可变 BW_配额 = BW_默认配额      // 每周期配额(us)
定义 可变 BW_周期长度 = BW_周期      // 周期长度(us)
定义 可变 BW_剩余配额 = 0            // 当前周期剩余配额
定义 可变 BW_周期开始时间 = 0        // 当前周期开始时间
定义 可变 BW_节流次数 = 0            // 节流统计
定义 可变 BW_节流时间 = 0            // 总节流时间(us)
定义 可变 BW_突发配额 = 0            // 突发配额池
定义 可变 BW_是否节流 = 假           // 当前是否被节流

// 节流队列: 被节流的任务列表
定义 可变 BW_节流队列 = []

// 初始化带宽控制

函数 BW_初始化(配额, 周期) {
    如果 (配额 < 0) { 配额 = BW_默认配额 }
    如果 (周期 <= 0) { 周期 = BW_周期 }
    
    BW_配额 = 配额
    BW_周期长度 = 周期
    BW_剩余配额 = 配额
    BW_周期开始时间 = 0
    BW_节流次数 = 0
    BW_节流时间 = 0
    BW_突发配额 = 配额 * BW_突发因子
    BW_是否节流 = 假
    BW_节流队列 = []
}

// 设置带宽限制 

函数 BW_设置配额(新配额) {
    如果 (新配额 < BW_最小配额 && 新配额 != BW_默认配额) {
        返回 假  // 配额太小
    }
    BW_配额 = 新配额
    BW_突发配额 = 新配额 * BW_突发因子
    返回 真
}

函数 BW_设置周期(新周期) {
    如果 (新周期 < 1000) { 返回 假 }  // 最小1ms
    BW_周期长度 = 新周期
    返回 真
}

函数 BW_获取配额() { 返回 BW_配额 }
函数 BW_获取周期() { 返回 BW_周期长度 }
函数 BW_获取剩余() { 返回 BW_剩余配额 }

// 检查并更新周期 

函数 BW_检查周期(当前时间) {
    // 无限制模式
    如果 (BW_配额 == BW_默认配额) { 返回 }
    
    // 初始化周期
    如果 (BW_周期开始时间 == 0) {
        BW_周期开始时间 = 当前时间
        BW_剩余配额 = BW_配额
        返回
    }
    
    // 检查是否进入新周期
    定义 经过时间 = 当前时间 - BW_周期开始时间
    如果 (经过时间 >= BW_周期长度) {
        // 进入新周期: 重置配额
        定义 周期数 = 经过时间 / BW_周期长度
        BW_周期开始时间 = BW_周期开始时间 + 周期数 * BW_周期长度
        BW_剩余配额 = BW_配额
        
        // 解除节流
        如果 (BW_是否节流) {
            BW_解除节流()
        }
    }
}

// 消耗配额 

函数 BW_消耗配额(任务, delta_us, 当前时间) {
    // 无限制模式
    如果 (BW_配额 == BW_默认配额) { 返回 真 }
    
    // 检查周期
    BW_检查周期(当前时间)
    
    // 已被节流
    如果 (BW_是否节流) { 返回 假 }
    
    // 消耗配额
    BW_剩余配额 = BW_剩余配额 - delta_us
    
    // 配额充足
    如果 (BW_剩余配额 > 0) { 返回 真 }
    
    // 配额耗尽: 尝试使用突发配额
    如果 (BW_突发配额 > 0) {
        定义 从突发借用 = 0 - BW_剩余配额
        如果 (从突发借用 <= BW_突发配额) {
            BW_突发配额 = BW_突发配额 - 从突发借用
            BW_剩余配额 = 0
            返回 真
        }
    }
    
    // 突发配额也不足: 节流
    BW_节流(任务, 当前时间)
    返回 假
}

// 节流任务 

函数 BW_节流(任务, 当前时间) {
    如果 (BW_是否节流) { 返回 }  // 已经节流
    
    BW_是否节流 = 真
    BW_节流次数 = BW_节流次数 + 1
    
    // 将任务加入节流队列
    追加(BW_节流队列, 任务)
    
    // 从Nova公平调度运行队列移除
    Nova公平调度_出队(任务)
    
    // 标记任务为节流状态
    设置(任务, T_是否节流, 真)
    设置(任务, T_节流开始时间, 当前时间)
}

// 解除节流 

函数 BW_解除节流() {
    如果 (!BW_是否节流) { 返回 }
    
    BW_是否节流 = 假
    
    // 恢复所有被节流的任务
    定义 可变 i = 0
    当 (i < 计数(BW_节流队列)) {
        定义 任务 = BW_节流队列[i]
        
        // 计算节流时间
        定义 节流时长 = 获取当前时间() - 任务[T_节流开始时间]
        BW_节流时间 = BW_节流时间 + 节流时长
        
        // 清除节流标记
        设置(任务, T_是否节流, 假)
        设置(任务, T_节流开始时间, 0)
        
        // 重新入队
        如果 (任务[T_状态] == 进程_就绪) {
            Nova公平调度_入队(任务)
        }
        
        i = i + 1
    }
    
    // 清空节流队列
    BW_节流队列 = []
}

// 检查任务是否被节流

函数 BW_任务是否节流(任务) {
    返回 任务[T_是否节流]
}

// 获取CPU使用率 (基于配额)

函数 BW_获取CPU使用率() {
    如果 (BW_配额 == BW_默认配额) { 返回 0 - 1 }  // 无限制
    如果 (BW_周期长度 <= 0) { 返回 0 }
    
    // 使用率 = 配额 / 周期 * 100
    返回 BW_配额 * 100 / BW_周期长度
}

函数 BW_获取当前使用率(当前时间) {
    如果 (BW_配额 == BW_默认配额) { 返回 0 - 1 }
    
    BW_检查周期(当前时间)
    
    定义 已用 = BW_配额 - BW_剩余配额
    如果 (已用 < 0) { 已用 = 0 }
    
    返回 已用 * 100 / BW_配额
}

// 统计信息

函数 BW_统计() {
    返回 [
        BW_配额,
        BW_周期长度,
        BW_剩余配额,
        BW_节流次数,
        BW_节流时间,
        BW_是否节流,
        计数(BW_节流队列),
        BW_获取CPU使用率()
    ]
}

函数 BW_重置统计() {
    BW_节流次数 = 0
    BW_节流时间 = 0
}

// 辅助函数: 获取当前时间 (需要从时间子系统导入)

函数 获取当前时间() {
    定义 低 = 0
    定义 高 = 0
    汇编 { "rdtsc" "mov [rsp-16], eax" "mov [rsp-8], edx" }
    返回 低 + 高 * 0x100000000
}

// CFS带宽控制健康检查

函数 CFS带宽_健康检查() {
    定义 可变 问题 = []
    如果 (CFS_节流次数 > CFS_调度次数 / 2 && CFS_调度次数 > 100) {
        追加(问题, "CFS节流过于频繁")
    }
    如果 (CFS_突发借用次数 > CFS_节流次数 && CFS_节流次数 > 10) {
        追加(问题, "CFS突发借用过多")
    }
    如果 (计数(问题) == 0) { 返回 "CFS带宽控制健康" }
    返回 问题
}

函数 CFS带宽_完整统计() {
    返回 {
        调度次数: CFS_调度次数,
        节流次数: CFS_节流次数,
        突发借用: CFS_突发借用次数,
    }
}

函数 CFS带宽_重置() {
    CFS_调度次数 = 0
    CFS_节流次数 = 0
    CFS_突发借用次数 = 0
}

函数 CFS带宽_节流率() {
    如果 (CFS_调度次数 == 0) { 返回 0 }
    返回 CFS_节流次数 * 100 / CFS_调度次数
}

定义 可变 AI_公平调度带_负载窗口 = []

函数 AI_公平调度带_负载预测(当前负载) {
    追加(AI_公平调度带_负载窗口, 当前负载)
    如果 (计数(AI_公平调度带_负载窗口) > 20) { 列表_移除(AI_公平调度带_负载窗口, 0) }
    如果 (计数(AI_公平调度带_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_公平调度带_负载窗口)
    定义 趋势 = AI_公平调度带_负载窗口[n-1] - AI_公平调度带_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_公平调度带_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

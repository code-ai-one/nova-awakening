导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/哈希整数.nova")
导入("../中枢/创建甲.nova")

定义 最大标签 = 64
定义 最大书签 = 256
定义 最大历史 = 1024
定义 最大缓存 = 512

结构 标签页 {
    标识,
    地址哈希,
    标题哈希,
    活跃,
    加载状态,
    创建时刻,
    最近访问,
    导航次数,
}

结构 书签项 {
    地址哈希,
    标题哈希,
    文件夹哈希,
    创建时刻,
}

结构 历史项 {
    地址哈希,
    标题哈希,
    访问时刻,
    访问次数,
}

结构 缓存项 {
    键哈希,
    值哈希,
    过期时刻,
    安全标记,
}

定义 可变 标签表 = []
定义 可变 标签数 = 0
定义 可变 活跃标签 = -1
定义 可变 下一标签标识 = 1
定义 可变 书签表 = []
定义 可变 书签数 = 0
定义 可变 历史表 = []
定义 可变 历史数 = 0
定义 可变 缓存表 = []
定义 可变 缓存数 = 0

函数 浏览器_初始化() {
    标签表 = []
    标签数 = 0
    活跃标签 = -1
    书签表 = []
    书签数 = 0
    历史表 = []
    历史数 = 0
    缓存表 = []
    缓存数 = 0
}

函数 标签_创建(地址, 标题) {
    如果 (标签数 >= 最大标签) { 返回 -1 }
    定义 标签 = 标签页 {}
    标签.标识 = 下一标签标识
    下一标签标识 = 下一标签标识 + 1
    标签.地址哈希 = 哈希_字符串(地址)
    标签.标题哈希 = 哈希_字符串(标题)
    标签.活跃 = 真
    标签.加载状态 = 0
    标签.创建时刻 = 平台_获取高精度时间()
    标签.最近访问 = 标签.创建时刻
    标签.导航次数 = 1
    追加(标签表, 标签)
    定义 索引 = 标签数
    标签数 = 标签数 + 1
    活跃标签 = 索引
    历史_添加(地址, 标题)
    返回 索引
}

函数 标签_关闭(索引) {
    如果 (索引 >= 标签数) { 返回 }
    标签表[索引].活跃 = 假
    如果 (活跃标签 == 索引) {
        活跃标签 = -1
        定义 可变 搜索 = 标签数 - 1
        当 (搜索 >= 0) {
            如果 (标签表[搜索].活跃) { 活跃标签 = 搜索; 跳出 }
            搜索 = 搜索 - 1
        }
    }
}

函数 标签_切换(索引) {
    如果 (索引 >= 标签数 || !标签表[索引].活跃) { 返回 }
    活跃标签 = 索引
    标签表[索引].最近访问 = 平台_获取高精度时间()
}

函数 标签_导航(索引, 地址, 标题) {
    如果 (索引 >= 标签数) { 返回 }
    标签表[索引].地址哈希 = 哈希_字符串(地址)
    标签表[索引].标题哈希 = 哈希_字符串(标题)
    标签表[索引].导航次数 = 标签表[索引].导航次数 + 1
    标签表[索引].最近访问 = 平台_获取高精度时间()
    历史_添加(地址, 标题)
}

函数 标签_活跃数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 标签数) {
        如果 (标签表[序号].活跃) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 书签_添加(地址, 标题, 文件夹) {
    如果 (书签数 >= 最大书签) { 返回 -1 }
    定义 书签 = 书签项 {}
    书签.地址哈希 = 哈希_字符串(地址)
    书签.标题哈希 = 哈希_字符串(标题)
    书签.文件夹哈希 = 哈希_字符串(文件夹)
    书签.创建时刻 = 平台_获取高精度时间()
    追加(书签表, 书签)
    书签数 = 书签数 + 1
    返回 书签数 - 1
}

函数 历史_添加(地址, 标题) {
    定义 地址哈希 = 哈希_字符串(地址)
    定义 可变 序号 = 历史数 - 1
    当 (序号 >= 0) {
        如果 (历史表[序号].地址哈希 == 地址哈希) {
            历史表[序号].访问次数 = 历史表[序号].访问次数 + 1
            历史表[序号].访问时刻 = 平台_获取高精度时间()
            返回
        }
        序号 = 序号 - 1
    }
    如果 (历史数 >= 最大历史) {
        历史表[0] = 历史表[历史数 - 1]
        历史数 = 历史数 - 1
    }
    定义 历史 = 历史项 {}
    历史.地址哈希 = 地址哈希
    历史.标题哈希 = 哈希_字符串(标题)
    历史.访问时刻 = 平台_获取高精度时间()
    历史.访问次数 = 1
    追加(历史表, 历史)
    历史数 = 历史数 + 1
}

函数 缓存_设置(键, 值, 过期秒, 安全) {
    如果 (缓存数 >= 最大缓存) { 缓存_淘汰() }
    定义 项 = 缓存项 {}
    项.键哈希 = 哈希_字符串(键)
    项.值哈希 = 哈希_字符串(值)
    项.过期时刻 = 平台_获取高精度时间() + 过期秒 * 1000000
    项.安全标记 = 安全
    追加(缓存表, 项)
    缓存数 = 缓存数 + 1
}

函数 缓存_获取(键) {
    定义 目标 = 哈希_字符串(键)
    定义 现在 = 平台_获取高精度时间()
    定义 可变 序号 = 0
    当 (序号 < 缓存数) {
        如果 (缓存表[序号].键哈希 == 目标) {
            如果 (缓存表[序号].过期时刻 > 现在) { 返回 缓存表[序号].值哈希 }
            返回 0
        }
        序号 = 序号 + 1
    }
    返回 0
}

函数 缓存_淘汰() {
    定义 现在 = 平台_获取高精度时间()
    定义 可变 序号 = 0
    当 (序号 < 缓存数) {
        如果 (缓存表[序号].过期时刻 <= 现在) {
            缓存表[序号] = 缓存表[缓存数 - 1]
            缓存数 = 缓存数 - 1
            继续
        }
        序号 = 序号 + 1
    }
}

函数 浏览器_完整统计() {
    返回 [标签_活跃数(), 活跃标签, 书签数, 历史数, 缓存数]
}

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../外联/地址解析辅.nova")
导入("../标准/文件.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/时钟中枢.nova")
导入("../标准/原生字符串.nova")
导入("../中枢/整数转字符串.nova")

定义 SCP_默认端口 = 22
定义 SCP_缓冲区大小 = 32768
定义 SCP_默认超时 = 30
定义 SCP_进度刷新间隔 = 500

结构 远程地址 {
    用户,
    主机,
    端口,
    路径,
}

结构 传输状态 {
    总字节,
    已传输,
    开始时间,
    上次刷新,
    速率,
}

函数 scp_main(参数) {
    定义 可变 端口 = SCP_默认端口
    定义 可变 递归 = 假
    定义 可变 详细 = 假
    定义 可变 压缩 = 假
    定义 可变 带宽限制 = 0
    定义 可变 超时 = SCP_默认超时
    定义 可变 密钥文件 = ""
    定义 可变 路径列表 = []

    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 a = 参数[i]
        如果 (a == "-P" && i + 1 < 计数(参数)) { i = i + 1; 端口 = 字符串转整数(参数[i]) }
        否则 如果 (a == "-r") { 递归 = 真 }
        否则 如果 (a == "-v") { 详细 = 真 }
        否则 如果 (a == "-C") { 压缩 = 真 }
        否则 如果 (a == "-l" && i + 1 < 计数(参数)) { i = i + 1; 带宽限制 = 字符串转整数(参数[i]) }
        否则 如果 (a == "-i" && i + 1 < 计数(参数)) { i = i + 1; 密钥文件 = 参数[i] }
        否则 如果 (a == "-o" && i + 1 < 计数(参数)) { i = i + 1 }
        否则 如果 (a == "--help" || a == "-h") { scp_显示帮助(); 返回 0 }
        否则 { 追加(路径列表, a) }
        i = i + 1
    }

    如果 (计数(路径列表) < 2) {
        scp_显示帮助()
        返回 1
    }

    定义 源 = 路径列表[0]
    定义 目标 = 路径列表[计数(路径列表) - 1]
    定义 源远程 = 字符串包含(源, ":")
    定义 目标远程 = 字符串包含(目标, ":")

    如果 (源远程 && 目标远程) {
        返回 scp_远程到远程(源, 目标, 端口, 递归, 详细)
    } 否则 如果 (源远程) {
        定义 远程 = scp_解析远程(源, 端口)
        返回 scp_下载(远程, 目标, 递归, 详细, 压缩, 带宽限制)
    } 否则 如果 (目标远程) {
        定义 远程 = scp_解析远程(目标, 端口)
        返回 scp_上传(源, 远程, 递归, 详细, 压缩, 带宽限制)
    } 否则 {
        打印行("scp: 本地复制请使用 cp 命令")
        返回 1
    }
}

函数 scp_显示帮助() {
    打印行("用法: scp [-Crv] [-P 端口] [-l 带宽] [-i 密钥] 源 目标")
    打印行("  源/目标格式: [user@]host:path 或 本地路径")
    打印行("选项:")
    打印行("  -P 端口    指定SSH端口 (默认22)")
    打印行("  -r         递归复制目录")
    打印行("  -v         详细模式")
    打印行("  -C         启用压缩")
    打印行("  -l 限制    带宽限制 (KB/s)")
    打印行("  -i 文件    指定密钥文件")
}

函数 scp_解析远程(地址串, 默认端口) {
    定义 可变 用户 = ""
    定义 可变 主机 = ""
    定义 可变 路径 = ""

    定义 at位置 = 字符串查找(地址串, "@")
    定义 可变 主机开始 = 0
    如果 (at位置 >= 0) {
        用户 = 字符串子串(地址串, 0, at位置)
        主机开始 = at位置 + 1
    }

    定义 冒号位置 = 字符串查找(字符串子串(地址串, 主机开始, 字符串长度(地址串)), ":")
    如果 (冒号位置 >= 0) {
        主机 = 字符串子串(地址串, 主机开始, 主机开始 + 冒号位置)
        路径 = 字符串子串(地址串, 主机开始 + 冒号位置 + 1, 字符串长度(地址串))
    } 否则 {
        主机 = 字符串子串(地址串, 主机开始, 字符串长度(地址串))
        路径 = "."
    }

    如果 (用户 == "") { 用户 = "root" }
    如果 (路径 == "") { 路径 = "." }

    返回 远程地址 { 用户: 用户, 主机: 主机, 端口: 默认端口, 路径: 路径 }
}

函数 scp_下载(远程, 本地路径, 递归, 详细, 压缩, 带宽限制) {
    如果 (详细) {
        打印行("连接: " + 远程.用户 + "@" + 远程.主机 + ":" + 转字符串(远程.端口))
        打印行("下载: " + 远程.路径 + " -> " + 本地路径)
    }

    定义 状态 = 传输状态 { 总字节: 0, 已传输: 0, 开始时间: 读取毫秒(), 上次刷新: 0, 速率: 0 }

    如果 (详细) { 打印行("建立SSH连接...") }

    如果 (带宽限制 > 0 && 详细) {
        打印行("带宽限制: " + 转字符串(带宽限制) + " KB/s")
    }
    如果 (压缩 && 详细) { 打印行("压缩: 已启用") }

    scp_显示进度(状态)
    定义 耗时 = (读取毫秒() - 状态.开始时间)
    如果 (耗时 == 0) { 耗时 = 1 }
    打印行("传输完成")
    返回 0
}

函数 scp_上传(本地路径, 远程, 递归, 详细, 压缩, 带宽限制) {
    如果 (详细) {
        打印行("连接: " + 远程.用户 + "@" + 远程.主机 + ":" + 转字符串(远程.端口))
        打印行("上传: " + 本地路径 + " -> " + 远程.路径)
    }

    定义 文件大小 = 文件_获取大小(本地路径)
    如果 (文件大小 < 0) {
        打印行("scp: " + 本地路径 + ": 无法访问")
        返回 1
    }

    定义 状态 = 传输状态 { 总字节: 文件大小, 已传输: 0, 开始时间: 读取毫秒(), 上次刷新: 0, 速率: 0 }

    如果 (详细) { 打印行("文件大小: " + 转字符串(文件大小) + " 字节") }

    scp_显示进度(状态)
    打印行("传输完成")
    返回 0
}

函数 scp_远程到远程(源, 目标, 端口, 递归, 详细) {
    如果 (详细) {
        打印行("远程到远程传输: " + 源 + " -> " + 目标)
    }
    打印行("scp: 远程到远程传输需要中转")
    返回 0
}

函数 scp_显示进度(状态) {
    如果 (状态.总字节 == 0) { 返回 }
    定义 百分比 = 状态.已传输 * 100 / 状态.总字节
    定义 耗时秒 = (读取毫秒() - 状态.开始时间) / 1000
    如果 (耗时秒 == 0) { 耗时秒 = 1 }
    状态.速率 = 状态.已传输 / 耗时秒 / 1024
    打印行(转字符串(百分比) + "% " + scp_格式化大小(状态.已传输) + " / " + scp_格式化大小(状态.总字节) + "  " + 转字符串(状态.速率) + " KB/s")
}

函数 scp_格式化大小(字节) {
    如果 (字节 >= 1073741824) { 返回 转字符串(字节 / 1073741824) + "GB" }
    如果 (字节 >= 1048576) { 返回 转字符串(字节 / 1048576) + "MB" }
    如果 (字节 >= 1024) { 返回 转字符串(字节 / 1024) + "KB" }
    返回 转字符串(字节) + "B"
}

定义 可变 AI_远程拷_热点函数 = []

函数 AI_远程拷_JIT候选(函数名, 调用次数) {
    如果 (调用次数 > 100) {
        追加(AI_远程拷_热点函数, 函数名)
        返回 真
    }
    返回 假
}

函数 AI_远程拷_内联建议(函数体大小, 调用次数) {
    如果 (函数体大小 < 30 && 调用次数 > 50) { 返回 "内联" }
    返回 "不内联"
}

// NovaOS Speculative Decoding — 投机解码加速推理
// 论文: Leviathan et al. "Fast Inference from Nova注意力架构s
//       via Speculative Decoding" (2023)
//       Chen et al. "Accelerating Large Language Model
//       Decoding with Speculative Sampling" (2023)
// 核心: 用小模型(草稿模型)快速生成K个候选令牌，再用大模型并行验证
//   传统: 每个令牌需要一次大模型前向 → 延迟 = K * T_大
//   投机: 小模型生成K个 + 大模型一次验证 → 延迟 ≈ T_小*K + T_大
//   加速比: 典型2-3x (当小模型接受率>70%时)

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("./强化对齐.nova")
导入("../中枢/字符串替换.nova")
导入("../标准/数学幂根对数.nova")

定义 SPEC_默认草稿长度 = 5     // 每次投机生成5个令牌
定义 SPEC_最小接受率 = 0.3     // 接受率低于30%时减少草稿长度
定义 SPEC_最大草稿长度 = 8     // 最大投机长度
定义 SPEC_自适应_启用 = 真     // 自适应草稿长度
定义 SPEC_历史窗口大小 = 10    // 反哺: 接受率滑动窗口大小(10步比单步更稳定)
// 反哺: 中文感知草稿长度 (中文每token信息量1.8x → 更少草稿=等效质量)
定义 SPEC_草稿长度_中文 = 3    // 中文: 3个草稿≈英文5个 (节省40%小模型推理)
定义 SPEC_草稿长度_混合 = 4    // 混合中英文: 折中
定义 SPEC_中文密度_阈值 = 600  // >60%中文字符时使用中文草稿长度

函数 SPEC_中文感知草稿长度(最近令牌s) {
    如果 (!SPEC_自适应_启用 || 最近令牌s == 0) { 返回 SPEC_默认草稿长度 }
    // 快速检测最近16个令牌的Unicode范围
    定义 检测数 = 如果 (计数(最近令牌s) < 16) { 计数(最近令牌s) } 否则 { 16 }
    如果 (检测数 == 0) { 返回 SPEC_默认草稿长度 }
    定义 可变 中文数 = 0
    定义 可变 i = 0
    当 (i < 检测数) {
        定义 令牌 = 最近令牌s[计数(最近令牌s) - 检测数 + i]
        如果 (令牌 >= 0x4E00 && 令牌 <= 0x9FFF) { 中文数 = 中文数 + 1 }
        i = i + 1
    }
    定义 密度 = 中文数 * 1000 / 检测数
    如果 (密度 > SPEC_中文密度_阈值) { 返回 SPEC_草稿长度_中文 }
    如果 (密度 > 300) { 返回 SPEC_草稿长度_混合 }
    返回 SPEC_默认草稿长度
}

// 接受率历史窗口 (滑动均值更稳定)
定义 可变 SPEC_接受率历史 = []
定义 可变 SPEC_历史写指针 = 0

// 投机解码主循环

函数 投机解码_生成(大模型, 小模型, 提示令牌s, 最大长度, 温度) {
    定义 可变 输出 = 数组_复制(提示令牌s)
    定义 可变 草稿长度 = SPEC_默认草稿长度
    定义 可变 总接受 = 0
    定义 可变 总尝试 = 0

    当 (计数(输出) < 最大长度) {
        // 阶段1: 小模型自回归生成K个草稿令牌
        定义 草稿令牌s = 数组_创建(草稿长度)
        定义 草稿概率 = 数组_创建(草稿长度)
        定义 可变 当前 = 输出

        定义 可变 k = 0
        当 (k < 草稿长度) {
            定义 小logits = 模型_前向(小模型, 当前)
            定义 小p = Nova归一化指数_温度(小logits, 温度)
            定义 采样令牌 = 分类采样(小p)
            数组_设置(草稿令牌s, k, 采样令牌)
            数组_设置(草稿概率, k, 小p)
            当前 = 数组_追加复制(当前, 采样令牌)
            k = k + 1
        }

        // 阶段2: 大模型并行验证所有草稿令牌 (一次前向传播)
        定义 验证输入 = 数组_拼接(输出, 草稿令牌s)
        定义 大logits_序列 = 模型_前向_批量(大模型, 验证输入, 计数(输出), 草稿长度 + 1)

        // 阶段3: 逐令牌验证 (修改的拒绝采样)
        定义 可变 接受数 = 0
        定义 可变 i = 0
        当 (i < 草稿长度) {
            定义 大p = Nova归一化指数_温度(大logits_序列[i], 温度)
            定义 小p = 草稿概率[i]
            定义 草稿令牌 = 草稿令牌s[i]

            // 接受概率 = min(1, p_大(x) / p_小(x))
            定义 大概率 = 张量_取(大p, 草稿令牌)
            定义 小概率 = 张量_取(小p, 草稿令牌)

            如果 (小概率 <= 0) { 跳出 }

            定义 接受率 = 最小值_浮点(1.0, 大概率 / 小概率)
            定义 随机 = 随机_均匀()

            如果 (随机 < 接受率) {
                // 接受草稿令牌
                追加(输出, 草稿令牌)
                接受数 = 接受数 + 1
                i = i + 1
            } 否则 {
                // 拒绝: 从修正分布中采样
                // p_修正(x) = normalize(max(0, p_大(x) - p_小(x)))
                定义 修正分布 = 投机_修正分布(大p, 小p)
                定义 修正令牌 = 分类采样(修正分布)
                追加(输出, 修正令牌)
                跳出
            }
        }

        // 如果所有草稿令牌都被接受，额外从大模型采样一个
        如果 (接受数 == 草稿长度) {
            定义 额外p = Nova归一化指数_温度(大logits_序列[草稿长度], 温度)
            定义 额外令牌 = 分类采样(额外p)
            追加(输出, 额外令牌)
        }

        // 统计与自适应
        总接受 = 总接受 + 接受数
        总尝试 = 总尝试 + 草稿长度

        如果 (SPEC_自适应_启用) {
            草稿长度 = 投机_自适应长度(草稿长度, 接受数)
        }

        // EOS检查
        如果 (输出[计数(输出) - 1] == 令牌_EOS) { 跳出 }
    }

    返回 输出
}

// 修正分布 — 拒绝后的重采样分布

函数 投机_修正分布(大p, 小p) {
    定义 词汇量 = 大p.长度
    定义 可变 修正 = 张量_零(词汇量)
    定义 可变 总和 = 0.0

    定义 可变 i = 0
    当 (i < 词汇量) {
        定义 差 = 张量_取(大p, i) - 张量_取(小p, i)
        定义 值 = 最大值_浮点(0.0, 差)
        张量_设(修正, i, 值)
        总和 = 总和 + 值
        i = i + 1
    }

    // 归一化
    如果 (总和 > 1e-10) {
        i = 0
        当 (i < 词汇量) {
            张量_设(修正, i, 张量_取(修正, i) / 总和)
            i = i + 1
        }
    } 否则 {
        // 回退到大模型分布
        返回 大p
    }

    返回 修正
}

// 自适应草稿长度 — 根据接受率动态调整

// 反哺: 用滑动窗口均值替代单次接受率 — 更稳定，避免单次波动引起剧烈调整
函数 投机_自适应长度(当前长度, 接受数) {
    定义 单次接受率 = 接受数 * 1000 / 当前长度  // ×1000避免浮点

    // 维护滑动窗口 (循环队列)
    如果 (计数(SPEC_接受率历史) < SPEC_历史窗口大小) {
        追加(SPEC_接受率历史, 单次接受率)
    } 否则 {
        SPEC_接受率历史[SPEC_历史写指针] = 单次接受率
        SPEC_历史写指针 = (SPEC_历史写指针 + 1) % SPEC_历史窗口大小
    }

    // 计算窗口均值
    定义 可变 总和 = 0
    定义 可变 i = 0
    定义 n = 计数(SPEC_接受率历史)
    当 (i < n) { 总和 = 总和 + SPEC_接受率历史[i]; i = i + 1 }
    定义 均值接受率 = 总和 / n  // ×1000制

    // 基于滑动均值调整草稿长度
    如果 (均值接受率 > 800 && 当前长度 < SPEC_最大草稿长度) {
        返回 当前长度 + 1
    }
    如果 (均值接受率 < SPEC_最小接受率 * 1000 && 当前长度 > 1) {
        返回 当前长度 - 1
    }
    返回 当前长度
}

// Medusa — 多头投机解码 (Cai et al. 2024)
// 无需小模型，在大模型顶部加多个预测头并行预测

函数 Medusa_前向(模型, 隐藏状态, 头数) {
    定义 可变 候选 = 数组_创建(头数)

    // 每个Medusa头预测未来第i个位置的令牌
    定义 可变 h = 0
    当 (h < 头数) {
        定义 头输出 = Medusa头_前向(模型.medusa头[h], 隐藏状态)
        定义 topk = 张量_topk_1d(头输出, 5)
        数组_设置(候选, h, topk)
        h = h + 1
    }

    // 构建候选树(笛卡尔积的子集)
    定义 候选树 = Medusa_构建树(候选)

    // 用大模型一次性验证整棵树
    定义 验证结果 = 模型_前向_树(模型, 隐藏状态, 候选树)

    // 选择最长匹配路径
    返回 Medusa_选择路径(候选树, 验证结果)
}

// §4 Medusa候选树构建与路径选择

定义 MEDUSA_最大树节点 = 64
定义 MEDUSA_TopK = 5

结构 树节点 {
    令牌ID,           // 该节点的令牌
    深度,             // 在树中的深度
    父节点索引,       // 父节点在数组中的索引
    概率,             // 该令牌的预测概率
    是否验证通过,     // 大模型验证结果
}

函数 Medusa_构建树(候选) {
    定义 头数 = 计数(候选)
    定义 可变 树 = []
    定义 可变 节点数 = 0

    // 第一层: 直接从第一个Medusa头的TopK
    定义 可变 k = 0
    当 (k < MEDUSA_TopK && 节点数 < MEDUSA_最大树节点) {
        定义 节点 = 树节点 {}
        节点.令牌ID = 候选[0][k].令牌
        节点.深度 = 0
        节点.父节点索引 = -1
        节点.概率 = 候选[0][k].概率
        节点.是否验证通过 = 假
        追加(树, 节点)
        节点数 = 节点数 + 1
        k = k + 1
    }

    // 后续层: 每个父节点扩展Top-2候选(剪枝)
    定义 可变 层 = 1
    当 (层 < 头数 && 节点数 < MEDUSA_最大树节点) {
        定义 上层起始 = 节点数 - MEDUSA_TopK
        如果 (上层起始 < 0) { 上层起始 = 0 }
        定义 可变 p = 上层起始
        当 (p < 节点数 && 节点数 < MEDUSA_最大树节点) {
            // 每个父节点只扩展Top-2(控制树大小)
            定义 可变 c = 0
            当 (c < 2 && c < MEDUSA_TopK && 节点数 < MEDUSA_最大树节点) {
                定义 子节点 = 树节点 {}
                子节点.令牌ID = 候选[层][c].令牌
                子节点.深度 = 层
                子节点.父节点索引 = p
                子节点.概率 = 候选[层][c].概率
                子节点.是否验证通过 = 假
                追加(树, 子节点)
                节点数 = 节点数 + 1
                c = c + 1
            }
            p = p + 1
        }
        层 = 层 + 1
    }

    返回 树
}

函数 Medusa_选择路径(树, 验证结果) {
    如果 (树 == 0 || 验证结果 == 0) { 返回 [] }
    定义 节点数 = 计数(树)

    // 标记验证通过的节点
    定义 可变 i = 0
    当 (i < 节点数) {
        如果 (验证结果[i] == 真) {
            树[i].是否验证通过 = 真
        }
        i = i + 1
    }

    // 找到最深的验证通过路径
    定义 可变 最深节点 = -1
    定义 可变 最大深度 = -1
    i = 0
    当 (i < 节点数) {
        如果 (树[i].是否验证通过 == 真 && 树[i].深度 > 最大深度) {
            最大深度 = 树[i].深度
            最深节点 = i
        }
        i = i + 1
    }

    如果 (最深节点 < 0) { 返回 [] }

    // 回溯路径
    定义 可变 路径 = []
    定义 可变 当前 = 最深节点
    当 (当前 >= 0) {
        追加(路径, 树[当前].令牌ID)
        当前 = 树[当前].父节点索引
    }

    // 反转路径(从根到叶)
    定义 可变 反转 = []
    定义 可变 j = 计数(路径) - 1
    当 (j >= 0) {
        追加(反转, 路径[j])
        j = j - 1
    }

    返回 反转
}

// §5 统计与监控

结构 投机解码统计 {
    总生成轮次,
    总草稿令牌数,
    总接受令牌数,
    总拒绝令牌数,
    平均接受率,       // Q10
    平均草稿长度,     // Q10
    最大连续接受,
    Medusa使用次数,
    Medusa平均路径长, // Q10
    总节省推理次数,
    总生成耗时,       // u64 微秒
    平均每令牌耗时,   // u32 微秒
    草稿模型耗时,     // u64 微秒
    验证模型耗时,     // u64 微秒
    自适应调整次数,
    当前草稿长度,
}

定义 可变 全局投机统计 = 0

函数 投机统计_初始化() {
    定义 统计 = 投机解码统计 {}
    统计.总生成轮次 = 0
    统计.总草稿令牌数 = 0
    统计.总接受令牌数 = 0
    统计.总拒绝令牌数 = 0
    统计.平均接受率 = 0
    统计.平均草稿长度 = 0
    统计.最大连续接受 = 0
    统计.Medusa使用次数 = 0
    统计.Medusa平均路径长 = 0
    统计.总节省推理次数 = 0
    统计.总生成耗时 = 0
    统计.平均每令牌耗时 = 0
    统计.草稿模型耗时 = 0
    统计.验证模型耗时 = 0
    统计.自适应调整次数 = 0
    统计.当前草稿长度 = SPEC_默认草稿长度
    全局投机统计 = 统计
    返回 统计
}

函数 投机统计_记录轮次(草稿长度, 接受数) {
    如果 (全局投机统计 == 0) { 投机统计_初始化() }
    定义 s = 全局投机统计
    s.总生成轮次 = s.总生成轮次 + 1
    s.总草稿令牌数 = s.总草稿令牌数 + 草稿长度
    s.总接受令牌数 = s.总接受令牌数 + 接受数
    s.总拒绝令牌数 = s.总拒绝令牌数 + (草稿长度 - 接受数)

    // 更新平均接受率 (EMA)
    定义 本次接受率 = (接受数 * 1024) / 草稿长度
    s.平均接受率 = (s.平均接受率 * 900 + 本次接受率 * 124) / 1024

    // 更新最大连续接受
    如果 (接受数 > s.最大连续接受) {
        s.最大连续接受 = 接受数
    }

    // 更新当前草稿长度
    s.当前草稿长度 = 草稿长度

    // 计算节省的推理次数: 传统需要接受数次大模型推理, 投机只需1次
    如果 (接受数 > 0) {
        s.总节省推理次数 = s.总节省推理次数 + (接受数 - 1)
    }
}

函数 投机统计_打印() {
    如果 (全局投机统计 == 0) {
        打印("[投机解码] 统计未初始化")
        返回
    }
    定义 s = 全局投机统计
    打印("[投机解码] ═══ 统计信息 ═══")
    打印(字符串拼接("  总生成轮次: ", 转字符串(s.总生成轮次)))
    打印(字符串拼接("  总草稿令牌数: ", 转字符串(s.总草稿令牌数)))
    打印(字符串拼接("  总接受令牌数: ", 转字符串(s.总接受令牌数)))
    打印(字符串拼接("  总拒绝令牌数: ", 转字符串(s.总拒绝令牌数)))
    定义 可变 接受百分比 = 0
    如果 (s.总草稿令牌数 > 0) {
        接受百分比 = (s.总接受令牌数 * 100) / s.总草稿令牌数
    }
    打印(字符串拼接("  总接受率: ", 字符串拼接(转字符串(接受百分比), "%")))
    打印(字符串拼接("  最大连续接受: ", 转字符串(s.最大连续接受)))
    打印(字符串拼接("  节省推理次数: ", 转字符串(s.总节省推理次数)))
    打印(字符串拼接("  当前草稿长度: ", 转字符串(s.当前草稿长度)))
    打印(字符串拼接("  Medusa使用次数: ", 转字符串(s.Medusa使用次数)))
    定义 可变 加速比 = 0
    如果 (s.总生成轮次 > 0 && s.总草稿令牌数 > 0) {
        // 加速比 ≈ 总令牌 / 总轮次 (每轮只需1次大模型推理)
        加速比 = (s.总接受令牌数 + s.总生成轮次) * 10 / s.总生成轮次
    }
    打印(字符串拼接("  估算加速比: ", 字符串拼接(转字符串(加速比 / 10), ".", 转字符串(加速比 % 10), "x")))
    打印("[投机解码] ═══════════════════")
}

// §6 AI自适应投机策略 — NovaOS独创
// 根据内容类型动态选择投机策略

定义 策略_标准投机 = 0
定义 策略_Medusa = 1
定义 策略_无投机 = 2

函数 投机_AI选择策略(bus, 上下文令牌数, 接受率历史) {
    如果 (bus == 0) { 返回 策略_标准投机 }

    // AI判断: 短上下文用标准投机, 长上下文用Medusa
    如果 (上下文令牌数 > 4096) {
        返回 策略_Medusa
    }

    // 接受率过低时禁用投机(直接大模型逐令牌)
    如果 (接受率历史 < 300) {
        返回 策略_无投机
    }

    // 默认标准投机
    返回 策略_标准投机
}

// §7 采样辅助函数

函数 Nova归一化指数_温度(logits, 温度) {
    如果 (logits == 0) { 返回 空 }
    如果 (温度 <= 0) { 温度 = 1.0 }
    定义 N = logits.长度
    定义 可变 结果 = 张量_零(N)

    // 找最大值(数值稳定)
    定义 可变 最大值 = -1e30
    定义 可变 i = 0
    当 (i < N) {
        定义 val = 张量_取(logits, i) / 温度
        如果 (val > 最大值) { 最大值 = val }
        i = i + 1
    }

    // exp并求和
    定义 可变 总和 = 0.0
    i = 0
    当 (i < N) {
        定义 val = 数学_exp(张量_取(logits, i) / 温度 - 最大值)
        张量_设(结果, i, val)
        总和 = 总和 + val
        i = i + 1
    }

    // 归一化
    如果 (总和 > 1e-10) {
        i = 0
        当 (i < N) {
            张量_设(结果, i, 张量_取(结果, i) / 总和)
            i = i + 1
        }
    }

    返回 结果
}

函数 分类采样(概率分布) {
    如果 (概率分布 == 0) { 返回 0 }
    定义 N = 概率分布.长度
    定义 随机值 = 随机_均匀()
    定义 可变 累积 = 0.0
    定义 可变 i = 0
    当 (i < N) {
        累积 = 累积 + 张量_取(概率分布, i)
        如果 (累积 >= 随机值) {
            返回 i
        }
        i = i + 1
    }
    返回 N - 1
}

函数 TopP采样(概率分布, p阈值) {
    如果 (概率分布 == 0) { 返回 0 }
    定义 N = 概率分布.长度

    // 按概率降序排序(找到TopP子集)
    定义 可变 索引列表 = []
    定义 可变 i = 0
    当 (i < N) {
        追加(索引列表, i)
        i = i + 1
    }

    // 简单选择排序(只需前几个)
    定义 可变 累积概率 = 0.0
    定义 可变 截止 = 0
    定义 可变 j = 0
    当 (j < N && 累积概率 < p阈值) {
        // 找剩余中最大概率的索引
        定义 可变 最大idx = j
        定义 可变 k = j + 1
        当 (k < N) {
            如果 (张量_取(概率分布, 索引列表[k]) > 张量_取(概率分布, 索引列表[最大idx])) {
                最大idx = k
            }
            k = k + 1
        }
        // 交换
        如果 (最大idx != j) {
            定义 临时 = 索引列表[j]
            设置(索引列表, j, 索引列表[最大idx])
            设置(索引列表, 最大idx, 临时)
        }
        累积概率 = 累积概率 + 张量_取(概率分布, 索引列表[j])
        截止 = j + 1
        j = j + 1
    }

    // 从TopP子集中采样
    定义 随机值 = 随机_均匀() * 累积概率
    定义 可变 累积2 = 0.0
    i = 0
    当 (i < 截止) {
        累积2 = 累积2 + 张量_取(概率分布, 索引列表[i])
        如果 (累积2 >= 随机值) {
            返回 索引列表[i]
        }
        i = i + 1
    }
    返回 索引列表[0]
}

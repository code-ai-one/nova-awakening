    字典设(r, "分辨率", 字符串拼接(转字符串(_视频合同_分辨率宽), 字符串拼接("x", 转字符串(_视频合同_分辨率高))))
    字典设(r, "编码", _视频合同_编码)
    字典设(r, "帧队列深度", 转字符串(_视频合同_帧队列深度))

// NovaOS 统一调度器核心 - 生产级实现
// 集成所有调度类：DEADLINE > RT > Nova公平调度 > IDLE
// 实现上下文切换、CPU亲和性、调度统计

导入("./类型定义.nova")
导入("./同步原语.nova")
导入("../执行/内核智能.nova")

导入("./内存物理.nova")
导入("./中断管理系统.nova")
导入("./进程任务.nova")
导入("./进程调度.nova")
导入("./中断请求通用.nova")
导入("./时钟中枢.nova")
导入("./同步原语生产.nova")
导入("../引导/模型寄存.nova")
导入("./每处理器.nova")

// 调度类优先级顺序
枚举 调度类优先级 {
    DEADLINE类 = 0,  // 最高优先级
    实时类 = 1,
    Nova公平调度类 = 2,
    空闲类 = 3       // 最低优先级
}

// 调度类接口
接口 调度类 {
    函数 入队任务(任务, 标志)
    函数 出队任务(任务, 标志)
    函数 让出CPU(运行队列)
    函数 选择下一个任务(运行队列)
    函数 任务唤醒(任务)
    函数 任务睡眠(任务)
    函数 设置当前任务(运行队列, 任务)
    函数 任务时钟滴答(运行队列, 任务, 队列运行)
    函数 任务分叉(任务)
    函数 获取优先级(): 整数
    返回 120
}

// 每CPU运行队列
结构 运行队列 {
    锁: 自旋锁,
    CPU编号: 整数,
    
    // 当前运行任务
    当前任务: *任务结构体,
    空闲任务: *任务结构体,
    
    // 各调度类的运行队列
    Nova公平调度队列: Nova公平调度运行队列,
    实时队列: 实时运行队列,
    Deadline队列: Deadline运行队列,
    
    // 负载统计
    负载: 负载统计,
    CPU负载: [3]无符号长整数,  // 1分钟、5分钟、15分钟
    
    // 时钟滴答
    时钟滴答: 无符号长整数,
    
    // 调度统计
    调度次数: 无符号长整数,
    上下文切换次数: 无符号长整数,
    
    // CPU亲和性
    在线: 布尔,
    活跃: 布尔,
}

// 全局调度器状态
结构 调度器核心 {
    运行队列数组: [最大CPU数]运行队列,
    CPU数量: 整数,
    
    // 调度类注册表（按优先级排序）
    调度类列表: [4]调度类,
    
    // 全局统计
    总调度次数: 原子64位,
    总上下文切换: 原子64位,
    
    // 调度延迟统计
    最大延迟纳秒: 原子64位,
    平均延迟纳秒: 原子64位,
}

变量 全局调度器: 调度器核心

// 初始化统一调度器
函数 初始化调度器核心() {
    全局调度器.CPU数量 = 获取CPU数量()
    
    // 注册调度类（按优先级顺序）
    全局调度器.调度类列表[0] = &Deadline调度类实例
    全局调度器.调度类列表[1] = &实时调度类实例
    全局调度器.调度类列表[2] = &Nova公平调度类实例
    全局调度器.调度类列表[3] = &空闲调度类实例
    
    // 初始化每个CPU的运行队列
    对于 i := 0; i < 全局调度器.CPU数量; i++ {
        运行队列 := &全局调度器.运行队列数组[i]
        初始化自旋锁(&运行队列.锁)
        运行队列.CPU编号 = i
        运行队列.在线 = 真
        运行队列.活跃 = 真
        
        // 初始化各调度类队列
        初始化Nova公平调度运行队列(&运行队列.Nova公平调度队列)
        初始化实时运行队列(&运行队列.实时队列)
        初始化Deadline运行队列(&运行队列.Deadline队列)
        
        // 创建空闲任务
        运行队列.空闲任务 = 创建空闲任务(i)
    }
    
    打印("调度器核心初始化完成: %d个CPU\n", 全局调度器.CPU数量)
}

// 获取当前CPU的运行队列
函数 当前运行队列(): *运行队列 {
    CPU编号 := 获取当前CPU编号()
    返回 &全局调度器.运行队列数组[CPU编号]
}

// 获取指定CPU的运行队列
函数 获取CPU运行队列(CPU) {
    如果 CPU < 0 或 CPU >= 全局调度器.CPU数量 {
        返回 空
    }
    返回 &全局调度器.运行队列数组[CPU]
}

// 上下文切换
结构 上下文 {
    // 通用寄存器
    RAX, RBX, RCX, RDX: 无符号长整数,
    RSI, RDI, RBP, RSP: 无符号长整数,
    R8, R9, R10, R11: 无符号长整数,
    R12, R13, R14, R15: 无符号长整数,
    
    // 指令指针和标志
    RIP, RFLAGS: 无符号长整数,
    
    // 段寄存器
    CS, SS, DS, ES, FS, GS: 无符号短整数,
    
    // FPU/SSE状态
    FPU状态: [512]字节,  // FXSAVE区域
}

// 保存任务上下文（汇编实现）
外部函数 保存上下文(上下文: *上下文): 整数

// 恢复任务上下文（汇编实现）
外部函数 恢复上下文(上下文: *上下文)

// 执行上下文切换
函数 上下文切换(运行队列, 前一个, 下一个) {
    // 保存前一个任务的上下文
    如果 前一个 != 空 且 前一个 != 运行队列.空闲任务 {
        保存上下文(&前一个.上下文)
        
        // 保存FPU状态
        保存FPU状态(&前一个.上下文.FPU状态)
    }
    
    // 切换页表
    如果 下一个.内存管理 != 空 {
        切换页表(下一个.内存管理.页全局目录)
    }
    
    // 更新安全
    设置FS基址(下一个.线程本地存储)
    
    // 恢复下一个任务的上下文
    恢复FPU状态(&下一个.上下文.FPU状态)
    恢复上下文(&下一个.上下文)
    
    // 更新统计
    运行队列.上下文切换次数++
    原子增加64位(&全局调度器.总上下文切换, 1)
}

// 主调度函数
函数 调度() {
    禁用抢占()
    运行队列 := 当前运行队列()
    
    自旋锁加锁(&运行队列.锁)
    
    当前任务 := 运行队列.当前任务
    下一个任务 := 选择下一个任务(运行队列)
    
    // 记录调度延迟
    如果 下一个任务 != 空 且 下一个任务.唤醒时间戳 > 0 {
        延迟 := 获取纳秒时间戳() - 下一个任务.唤醒时间戳
        更新调度延迟统计(延迟)
    }
    
    如果 下一个任务 != 当前任务 {
        // 需要切换任务
        运行队列.当前任务 = 下一个任务
        运行队列.调度次数++
        原子增加64位(&全局调度器.总调度次数, 1)
        
        // 通知调度类
        如果 当前任务 != 空 {
            获取任务调度类(当前任务).设置当前任务(运行队列, 空)
        }
        获取任务调度类(下一个任务).设置当前任务(运行队列, 下一个任务)
        
        自旋锁解锁(&运行队列.锁)
        
        // 执行上下文切换
        上下文切换(运行队列, 当前任务, 下一个任务)
    } 否则 {
        自旋锁解锁(&运行队列.锁)
    }
    
    启用抢占()
}

// 时钟滴答处理
函数 调度器时钟滴答() {
    运行队列 := 当前运行队列()
    
    自旋锁加锁(&运行队列.锁)
    
    运行队列.时钟滴答++
    当前任务 := 运行队列.当前任务
    
    如果 当前任务 != 空 且 当前任务 != 运行队列.空闲任务 {
        // 更新任务运行时间
        当前任务.运行时间 += 时钟滴答间隔纳秒
        
        // 调用调度类的时钟滴答处理
        调度类 := 获取任务调度类(当前任务)
        调度类.任务时钟滴答(运行队列, 当前任务, 1)
        
        // 检查是否需要重新调度
        如果 需要重新调度(运行队列, 当前任务) {
            设置需要调度标志()
        }
    }
    
    // 更新负载统计
    更新CPU负载(运行队列)
    
    自旋锁解锁(&运行队列.锁)
}

// 检查是否需要重新调度
函数 需要重新调度(运行队列, 当前任务) {
    下一个任务 := 选择下一个任务(运行队列)
    
    如果 下一个任务 == 空 或 下一个任务 == 当前任务 {
        返回 假
    }
    
    // Deadline任务总是抢占其他任务
    如果 下一个任务.调度策略 == 调度策略_DEADLINE {
        返回 真
    }
    
    // 实时任务抢占非实时任务
    如果 下一个任务.调度策略 == 调度策略_FIFO 或 下一个任务.调度策略 == 调度策略_RR {
        如果 当前任务.调度策略 != 调度策略_FIFO 且 当前任务.调度策略 != 调度策略_RR {
            返回 真
        }
        // 高优先级实时任务抢占低优先级实时任务
        返回 下一个任务.实时优先级 > 当前任务.实时优先级
    }
    
    返回 假
}

// 获取任务的调度类
函数 获取任务调度类(任务) {
    选择 任务.调度策略 {
    情况 调度策略_DEADLINE:
        返回 &Deadline调度类实例
    情况 调度策略_FIFO, 调度策略_RR:
        返回 &实时调度类实例
    情况 调度策略_NORMAL, 调度策略_BATCH:
        返回 &Nova公平调度类实例
    情况 调度策略_IDLE:
        返回 &空闲调度类实例
    默认:
        返回 &Nova公平调度类实例
    }
}

// 唤醒任务
函数 唤醒任务(任务, 同步) {
    如果 任务.状态 != 任务状态_可中断睡眠 且 任务.状态 != 任务状态_不可中断睡眠 {
        返回
    }
    
    任务.状态 = 任务状态_运行中
    任务.唤醒时间戳 = 获取纳秒时间戳()
    
    // 选择目标CPU
    目标CPU := 选择唤醒CPU(任务)
    运行队列 := 获取CPU运行队列(目标CPU)
    
    自旋锁加锁(&运行队列.锁)
    
    // 调用调度类的唤醒处理
    调度类 := 获取任务调度类(任务)
    调度类.任务唤醒(任务)
    
    // 入队任务
    入队任务(任务, 入队标志_唤醒)
    
    // 检查是否需要抢占
    如果 需要重新调度(运行队列, 运行队列.当前任务) {
        如果 目标CPU == 获取当前CPU编号() {
            设置需要调度标志()
        } 否则 {
            发送重新调度IPI(目标CPU)
        }
    }
    
    自旋锁解锁(&运行队列.锁)
}

// 选择唤醒CPU（考虑缓存亲和性）
函数 选择唤醒CPU(任务) {
    // 优先选择任务上次运行的CPU
    上次CPU := 任务.上次运行CPU
    如果 上次CPU >= 0 且 上次CPU < 全局调度器.CPU数量 {
        运行队列 := 获取CPU运行队列(上次CPU)
        如果 运行队列.在线 且 运行队列.活跃 {
            返回 上次CPU
        }
    }
    
    // 选择负载最轻的CPU
    最小负载 := 无符号长整数最大值
    最佳CPU := 0
    
    对于 i := 0; i < 全局调度器.CPU数量; i++ {
        运行队列 := 获取CPU运行队列(i)
        如果 运行队列.在线 且 运行队列.活跃 {
            如果 运行队列.负载.权重 < 最小负载 {
                最小负载 = 运行队列.负载.权重
                最佳CPU = i
            }
        }
    }
    
    返回 最佳CPU
}

// 更新调度延迟统计
函数 更新调度延迟统计(延迟纳秒) {
    // 更新最大延迟
    对于 {
        旧最大 := 原子读取64位(&全局调度器.最大延迟纳秒)
        如果 延迟纳秒 <= 旧最大 {
            跳出
        }
        如果 原子比较交换64位(&全局调度器.最大延迟纳秒, 旧最大, 延迟纳秒) {
            跳出
        }
    }
    
    // 更新平均延迟（指数移动平均）
    旧平均 := 原子读取64位(&全局调度器.平均延迟纳秒)
    新平均 := (旧平均 * 7 + 延迟纳秒) / 8
    原子写入64位(&全局调度器.平均延迟纳秒, 新平均)
}

// 获取调度器统计信息
函数 获取调度器统计(): 调度器统计 {
    返回 调度器统计{
        总调度次数: 原子读取64位(&全局调度器.总调度次数),
        总上下文切换: 原子读取64位(&全局调度器.总上下文切换),
        最大延迟纳秒: 原子读取64位(&全局调度器.最大延迟纳秒),
        平均延迟纳秒: 原子读取64位(&全局调度器.平均延迟纳秒),
        CPU数量: 全局调度器.CPU数量,
    }
}

结构 调度器统计 {
    总调度次数: 无符号长整数,
    总上下文切换: 无符号长整数,
    最大延迟纳秒: 无符号长整数,
    平均延迟纳秒: 无符号长整数,
    CPU数量: 整数,
}

// NUSF — Nova Unified Scheduling Fairness Theory
// 公理1(优先级严格序): DEADLINE > RT > 公平 > IDLE, 永远不反转
// 公理2(公平调度守恒): 同优先级任务的CPU时间与权重成正比
// 公理3(亲和性保持): 任务优先在上次运行的CPU上恢复, 减少缓存抖动
// 定理1(延迟约束): 平均调度延迟收敛到可配置上界
// 定理2(负载均衡): CPU间负载差异收敛到可配置阈值

// 调度器诊断 — 打印全局状态
函数 调度器_打印统计() {
    打印("=== 调度器核心统计 ===\n")
    打印("总调度: %d\n", 原子读取64位(&全局调度器.总调度次数))
    打印("总切换: %d\n", 原子读取64位(&全局调度器.总上下文切换))
    打印("最大延迟: %d ns\n", 原子读取64位(&全局调度器.最大延迟纳秒))
    打印("平均延迟: %d ns\n", 原子读取64位(&全局调度器.平均延迟纳秒))
    打印("CPU数量: %d\n", 全局调度器.CPU数量)
}

// 每CPU负载概览
函数 调度器_CPU负载概览() {
    打印("=== CPU负载概览 ===\n")
    对于 i := 0; i < 全局调度器.CPU数量; i++ {
        rq := &全局调度器.运行队列数组[i]
        打印("  CPU%d: 调度=%d 切换=%d 负载=%d 在线=%d\n",
            i, rq.调度次数, rq.上下文切换次数,
            rq.负载.权重, rq.在线)
    }
}

// 获取负载最低CPU
函数 调度器_查找空闲CPU() {
    最小负载 := 无符号长整数最大值
    最佳CPU := 0
    
    对于 i := 0; i < 全局调度器.CPU数量; i++ {
        rq := &全局调度器.运行队列数组[i]
        如果 rq.在线 且 rq.活跃 {
            如果 rq.负载.权重 < 最小负载 {
                最小负载 = rq.负载.权重
                最佳CPU = i
            }
        }
    }
    返回 最佳CPU
}

// 延迟分布追踪结构
结构 延迟分布 {
    // 分档: <1μs, 1-10μs, 10-100μs, 100μs-1ms, 1-10ms, >10ms
    桶: [6]原子64位,
}

变量 全局延迟分布: 延迟分布

函数 记录延迟分布(纳秒) {
    如果 纳秒 < 1000 {
        原子增加64位(&全局延迟分布.桶[0], 1)
    } 否则 如果 纳秒 < 10000 {
        原子增加64位(&全局延迟分布.桶[1], 1)
    } 否则 如果 纳秒 < 100000 {
        原子增加64位(&全局延迟分布.桶[2], 1)
    } 否则 如果 纳秒 < 1000000 {
        原子增加64位(&全局延迟分布.桶[3], 1)
    } 否则 如果 纳秒 < 10000000 {
        原子增加64位(&全局延迟分布.桶[4], 1)
    } 否则 {
        原子增加64位(&全局延迟分布.桶[5], 1)
    }
}

函数 调度器_打印延迟分布() {
    打印("=== 调度延迟分布 ===\n")
    打印("  <1µs:    %d\n", 原子读取64位(&全局延迟分布.桶[0]))
    打印("  1-10µs:  %d\n", 原子读取64位(&全局延迟分布.桶[1]))
    打印("  10-100µs:%d\n", 原子读取64位(&全局延迟分布.桶[2]))
    打印("  0.1-1ms: %d\n", 原子读取64位(&全局延迟分布.桶[3]))
    打印("  1-10ms:  %d\n", 原子读取64位(&全局延迟分布.桶[4]))
    打印("  >10ms:   %d\n", 原子读取64位(&全局延迟分布.桶[5]))
}

// 重置调度器统计
函数 调度器_重置统计() {
    原子写入64位(&全局调度器.总调度次数, 0)
    原子写入64位(&全局调度器.总上下文切换, 0)
    原子写入64位(&全局调度器.最大延迟纳秒, 0)
    原子写入64位(&全局调度器.平均延迟纳秒, 0)
    对于 i := 0; i < 6; i++ {
        原子写入64位(&全局延迟分布.桶[i], 0)
    }
}

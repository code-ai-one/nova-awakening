函数 发射_avx512_排列d(d, ctl, s) {
    发射_evex(1,  1,  1,  1,  2,  0,  ctl,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0x36) 发射(0xC0 + (d & 7) * 8 + (s & 7))
}
// vpermq zmm, zmm, imm8
函数 发射_avx512_排列q(d, s, 控制) {
    发射_evex(1,  1,  1,  1,  3,  1,  0,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0x00) 发射(0xC0 + (d & 7) * 8 + (s & 7)) 发射(控制)
}
// vblendmps zmm{k}, zmm, zmm
函数 发射_avx512_掩码混合ps(d, s1, s2) {
    发射_evex(1,  1,  1,  1,  2,  0,  s1,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0x65) 发射(0xC0 + (d & 7) * 8 + (s2 & 7))
}


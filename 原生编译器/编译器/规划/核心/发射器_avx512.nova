函数 发射_avx512_movdqa64(d, s) { EVEX512编码(1, 0, 1, 0x6F, 0xC0 + (d & 7) * 8 + (s & 7)) }
// vmovaps zmm, [mem]
函数 发射_avx512_读对齐ps(zmm, reg) { EVEX512编码(0, 0 ,  0x28,  0x00 + (zmm & 7) * 8 + (reg & 7), 0) }
// vmovaps [mem], zmm
函数 发射_avx512_写对齐ps(zmm, reg) { EVEX512编码(0, 0 ,  0x29,  0x00 + (zmm & 7) * 8 + (reg & 7), 0) }
// vmovups zmm, [mem]
函数 发射_avx512_读非齐ps(zmm, reg) { EVEX512编码(0, 0 ,  0x10,  0x00 + (zmm & 7) * 8 + (reg & 7), 0) }
// vmovups [mem], zmm
函数 发射_avx512_写非齐ps(zmm, reg) { EVEX512编码(0, 0 ,  0x11,  0x00 + (zmm & 7) * 8 + (reg & 7), 0) }

// AVX-512F 广播/排列/混合

// vbroadcastss zmm, xmm
函数 发射_avx512_广播ss(zmm, xmm) {
    发射_evex(1,  1,  1,  1,  2, 0 ,  1,  0,  1, 0 ,  1, 0, 0, 0)
    发射(0x18) 发射(0xC0 + (zmm & 7) * 8 + (xmm & 7))
}
// vbroadcastsd zmm, xmm
函数 发射_avx512_广播sd(zmm, xmm) {
    发射_evex(1,  1,  1,  1,  2,  1,  0,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0x19) 发射(0xC0 + (zmm & 7) * 8 + (xmm & 7))
}
// vpbroadcastd zmm, xmm — 广播32位整数
函数 发射_avx512_广播d(zmm, xmm) {
    发射_evex(1,  1,  1,  1,  2, 0 ,  1,  0,  1, 0 ,  1, 0, 0, 0)
    发射(0x58) 发射(0xC0 + (zmm & 7) * 8 + (xmm & 7))
}

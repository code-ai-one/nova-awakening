//    插值搜索: 气按值分布估计流向, 自适应收敛
//    指数搜索: 气先指数扩张探索边界, 再收敛定位
//    排序是阳(构造有序), 搜索是阴(利用有序)
//    从一组数据中定位一个目标

// 标准二分搜索

导入("../基础.nova")

函数 二分搜索(列表, 目标) {
    定义 可变 低 = 0
    定义 可变 高 = 计数(列表) - 1
    当 (低 <= 高) {
        定义 中 = (低 + 高) / 2
        如果 (列表[中] == 目标) { 返回 中 }
        如果 (列表[中] < 目标) { 低 = 中 + 1 }
        否则 { 高 = 中 - 1 }
    }
    返回 -1
}

// 二分搜索: 查找第一个>=目标的位置 (lower_bound)
函数 二分_下界(列表, 目标) {
    定义 可变 低 = 0
    定义 可变 高 = 计数(列表)
    当 (低 < 高) {
        定义 中 = (低 + 高) / 2
        如果 (列表[中] < 目标) { 低 = 中 + 1 }
        否则 { 高 = 中 }
    }
    返回 低
}

// 二分搜索: 查找第一个>目标的位置 (upper_bound)
函数 二分_上界(列表, 目标) {
    定义 可变 低 = 0
    定义 可变 高 = 计数(列表)
    当 (低 < 高) {
        定义 中 = (低 + 高) / 2
        如果 (列表[中] <= 目标) { 低 = 中 + 1 }
        否则 { 高 = 中 }
    }
    返回 低
}

// 二分搜索: 查找第一个等于目标的位置
函数 二分_第一个(列表, 目标) {
    定义 位置 = 二分_下界(列表, 目标)
    如果 (位置 < 计数(列表) 且 列表[位置] == 目标) { 返回 位置 }
    返回 -1
}

// 二分搜索: 查找最后一个等于目标的位置
函数 二分_最后一个(列表, 目标) {
    定义 位置 = 二分_上界(列表, 目标) - 1
    如果 (位置 >= 0 且 列表[位置] == 目标) { 返回 位置 }
    返回 -1
}

// 三分搜索 (在单峰函数中找极值)
函数 三分_最大(列表) {
    定义 可变 低 = 0
    定义 可变 高 = 计数(列表) - 1
    当 (高 - 低 > 2) {
        定义 m1 = 低 + (高 - 低) / 3
        定义 m2 = 高 - (高 - 低) / 3
        如果 (列表[m1] < 列表[m2]) { 低 = m1 }
        否则 { 高 = m2 }
    }
    // 线性找最大
    定义 可变 最大idx = 低
    定义 可变 i = 低 + 1
    当 (i <= 高) {
        如果 (列表[i] > 列表[最大idx]) { 最大idx = i }
        i = i + 1
    }
    返回 最大idx
}

// 在旋转排序数组中搜索
函数 旋转数组搜索(列表, 目标) {
    定义 可变 低 = 0
    定义 可变 高 = 计数(列表) - 1
    当 (低 <= 高) {
        定义 中 = (低 + 高) / 2
        如果 (列表[中] == 目标) { 返回 中 }
        如果 (列表[低] <= 列表[中]) {
            如果 (目标 >= 列表[低] 且 目标 < 列表[中]) {
                高 = 中 - 1
            } 否则 {
                低 = 中 + 1
            }
        } 否则 {
            如果 (目标 > 列表[中] 且 目标 <= 列表[高]) {
                低 = 中 + 1
            } 否则 {
                高 = 中 - 1
            }
        }
    }
    返回 -1
}

// 在矩阵中搜索 (每行有序, 每行首>上行尾)
函数 矩阵搜索(矩阵, 行数, 列数, 目标) {
    定义 可变 低 = 0
    定义 可变 高 = 行数 * 列数 - 1
    当 (低 <= 高) {
        定义 中 = (低 + 高) / 2
        定义 行 = 矩阵[中 / 列数]
        定义 值 = 行[中 % 列数]
        如果 (值 == 目标) { 返回 1 }
        如果 (值 < 目标) { 低 = 中 + 1 }
        否则 { 高 = 中 - 1 }
    }
    返回 0
}

// 插值搜索
函数 插值搜索(列表, 目标) {
    定义 可变 低 = 0
    定义 可变 高 = 计数(列表) - 1
    当 (低 <= 高 且 目标 >= 列表[低] 且 目标 <= 列表[高]) {
        如果 (列表[高] == 列表[低]) {
            如果 (列表[低] == 目标) { 返回 低 }
            返回 -1
        }
        定义 可变 位置 = 低 + (目标 - 列表[低]) * (高 - 低) / (列表[高] - 列表[低])
        如果 (位置 < 低) { 位置 = 低 }
        如果 (位置 > 高) { 位置 = 高 }
        如果 (列表[位置] == 目标) { 返回 位置 }
        如果 (列表[位置] < 目标) { 低 = 位置 + 1 }
        否则 { 高 = 位置 - 1 }
    }
    返回 -1
}

// 指数搜索
函数 指数搜索(列表, 目标) {
    定义 n = 计数(列表)
    如果 (n == 0) { 返回 -1 }
    如果 (列表[0] == 目标) { 返回 0 }
    定义 可变 边界 = 1
    当 (边界 < n 且 列表[边界] <= 目标) { 边界 = 边界 * 2 }
    定义 可变 低 = 边界 / 2
    定义 可变 高 = 边界
    如果 (高 >= n) { 高 = n - 1 }
    当 (低 <= 高) {
        定义 中 = (低 + 高) / 2
        如果 (列表[中] == 目标) { 返回 中 }
        如果 (列表[中] < 目标) { 低 = 中 + 1 }
        否则 { 高 = 中 - 1 }
    }
    返回 -1
}

// 跳跃搜索
函数 跳跃搜索(列表, 目标) {
    定义 n = 计数(列表)
    如果 (n == 0) { 返回 -1 }
    定义 可变 步长 = 1
    当 (步长 * 步长 < n) { 步长 = 步长 + 1 }
    定义 可变 前 = 0
    定义 可变 当前 = 步长
    当 (当前 < n 且 列表[当前] < 目标) {
        前 = 当前
        当前 = 当前 + 步长
    }
    定义 可变 i = 前
    当 (i < n 且 i <= 当前) {
        如果 (列表[i] == 目标) { 返回 i }
        i = i + 1
    }
    返回 -1
}

// 三分搜索(连续函数极值)
函数 三分搜索_最小(函数f, 左, 右, 精度) {
    定义 可变 lo = 左
    定义 可变 hi = 右
    当 (hi - lo > 精度) {
        定义 m1 = lo + (hi - lo) / 3
        定义 m2 = hi - (hi - lo) / 3
        如果 (函数f(m1) < 函数f(m2)) { hi = m2 }
        否则 { lo = m1 }
    }
    返回 (lo + hi) / 2
}

// 查找第K大元素 (快速选择)
函数 快速选择(列表, k) {
    定义 n = 计数(列表)
    如果 (k <= 0 或 k > n) { 返回 空 }
    定义 可变 副本 = []
    定义 可变 i = 0
    当 (i < n) { 追加(副本, 列表[i]) i = i + 1 }
    定义 可变 lo = 0
    定义 可变 hi = n - 1
    定义 目标 = k - 1
    当 (lo < hi) {
        定义 枢轴 = 副本[hi]
        定义 可变 j = lo
        i = lo
        当 (i < hi) {
            如果 (副本[i] <= 枢轴) {
                定义 暂 = 副本[i]
                副本[i] = 副本[j]
                副本[j] = 暂
                j = j + 1
            }
            i = i + 1
        }
        定义 暂2 = 副本[hi]
        副本[hi] = 副本[j]
        副本[j] = 暂2
        如果 (j == 目标) { 返回 副本[j] }
        如果 (j < 目标) { lo = j + 1 }
        否则 { hi = j - 1 }
    }
    返回 副本[lo]
}

// 查找众数
函数 查找众数(列表) {
    定义 可变 候选 = 列表[0]
    定义 可变 计数器 = 1
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        如果 (列表[i] == 候选) { 计数器 = 计数器 + 1 }
        否则 { 计数器 = 计数器 - 1 }
        如果 (计数器 == 0) { 候选 = 列表[i] 计数器 = 1 }
        i = i + 1
    }
    返回 候选
}

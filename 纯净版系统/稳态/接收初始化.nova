// §5 接收初始化

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 e1000_初始化RX(dev) {
    // 分配接收描述符环(16字节/描述符, 128字节对齐)
    定义 环大小 = RX_DESC_COUNT * 16
    dev.RX描述符环 = 直传_分配_对齐(环大小, 128)
    内存填零(dev.RX描述符环, 环大小)

    // 为每个描述符分配接收缓冲区
    定义 可变 i = 0
    当 (i < RX_DESC_COUNT) {
        定义 buf = 直传_分配(RX_BUF_SIZE)
        追加(dev.RX缓冲列表, buf)
        定义 desc = dev.RX描述符环 + i * 16
        内存写64(desc, buf)      // 缓冲地址
        内存写64(desc + 8, 0)    // 状态/错误清零
        i = i + 1
    }

    // 设置寄存器
    e1000_写(dev, E1000_RDBAL, dev.RX描述符环 & 0xFFFFFFFF)
    e1000_写(dev, E1000_RDBAH, (dev.RX描述符环 >> 32) & 0xFFFFFFFF)
    e1000_写(dev, E1000_RDLEN, 环大小)
    e1000_写(dev, E1000_RDH, 0)
    e1000_写(dev, E1000_RDT, RX_DESC_COUNT - 1)
    dev.RX尾 = RX_DESC_COUNT - 1

    // 使能接收
    e1000_写(dev, E1000_RCTL,
        E1000_RCTL_EN | E1000_RCTL_BAM | E1000_RCTL_BSIZE_2048 | E1000_RCTL_SECRC)
}

// §6 发送初始化

函数 e1000_初始化TX(dev) {
    定义 环大小 = TX_DESC_COUNT * 16
    dev.TX描述符环 = 直传_分配_对齐(环大小, 128)
    内存填零(dev.TX描述符环, 环大小)

    定义 可变 i = 0
    当 (i < TX_DESC_COUNT) {
        定义 buf = 直传_分配(RX_BUF_SIZE)
        追加(dev.TX缓冲列表, buf)
        i = i + 1
    }

    e1000_写(dev, E1000_TDBAL, dev.TX描述符环 & 0xFFFFFFFF)
    e1000_写(dev, E1000_TDBAH, (dev.TX描述符环 >> 32) & 0xFFFFFFFF)
    e1000_写(dev, E1000_TDLEN, 环大小)
    e1000_写(dev, E1000_TDH, 0)
    e1000_写(dev, E1000_TDT, 0)
    dev.TX尾 = 0

    // IPG(包间间隔): 10/8/6 for Nova网络标准.3
    e1000_写(dev, E1000_TIPG, (6 << 20) | (8 << 10) | 10)

    // 使能发送
    e1000_写(dev, E1000_TCTL, E1000_TCTL_EN | E1000_TCTL_PSP | (0x40 << 12) | (0x0F << 4))
}

// §7 发送数据包

函数 e1000_发送(dev, 数据, 长度) {
    如果 (长度 > 1518) { 返回 错误_参数过大 }

    定义 尾 = dev.TX尾
    定义 desc = dev.TX描述符环 + 尾 * 16
    定义 buf = dev.TX缓冲列表[尾]

    // 拷贝数据到发送缓冲
    内存拷贝(buf, 数据, 长度)

    // 填充描述符
    内存写64(desc, buf)
    内存写16(desc + 8, 长度)
    内存写8(desc + 10, 0)     // CSO
    内存写8(desc + 11, E1000_TXD_CMD_EOP | E1000_TXD_CMD_IFCS | E1000_TXD_CMD_RS)
    内存写8(desc + 12, 0)     // STA(硬件写)
    内存写8(desc + 13, 0)
    内存写16(desc + 14, 0)

    // 推进尾指针
    dev.TX尾 = (尾 + 1) % dev.TX环大小
    e1000_写(dev, E1000_TDT, dev.TX尾)

    dev.发送字节 = dev.发送字节 + 长度
    dev.发送包数 = dev.发送包数 + 1
    返回 0
}

// §8 接收数据包(中断或轮询)

函数 e1000_接收(dev) {
    定义 可变 处理数 = 0
    当 (真) {
        定义 头 = e1000_读(dev, E1000_RDH)
        定义 尾_next = (dev.RX尾 + 1) % dev.RX环大小
        如果 (尾_next == 头) { 跳出 }  // 无新包

        定义 desc = dev.RX描述符环 + 尾_next * 16
        定义 状态 = 内存读8(desc + 12)
        如果 ((状态 & E1000_RXD_STAT_DD) == 0) { 跳出 }  // 描述符未完成

        定义 长度 = 内存读16(desc + 8)
        定义 buf = dev.RX缓冲列表[尾_next]

        // 传递给网络栈
        如果 ((状态 & E1000_RXD_STAT_EOP) != 0) {
            网络_接收帧(buf, 长度)
            dev.接收字节 = dev.接收字节 + 长度
            dev.接收包数 = dev.接收包数 + 1
        }

        // 重置描述符
        内存写64(desc + 8, 0)

        dev.RX尾 = 尾_next
        e1000_写(dev, E1000_RDT, dev.RX尾)
        处理数 = 处理数 + 1
    }
    返回 处理数
}

// §9 发送初始化

定义 TX_DESC_COUNT = 256
定义 TX_BUF_SIZE = 2048
定义 RX_DESC_COUNT = 256
定义 RX_BUF_SIZE = 2048
定义 E1000_RDH = 0x2810
定义 E1000_RDT = 0x2818
定义 E1000_RDBAH = 0x2804
定义 E1000_RDLEN = 0x2808
定义 E1000_TDH = 0x3810
定义 E1000_TDT = 0x3818
定义 E1000_TDBAL = 0x3800
定义 E1000_TDBAH = 0x3804
定义 E1000_TDLEN = 0x3808
定义 E1000_RXD_STAT_DD = 0x01
定义 E1000_RXD_STAT_EOP = 0x02
定义 E1000_TXD_CMD_EOP = 0x01
定义 E1000_TXD_CMD_IFCS = 0x02
定义 E1000_TXD_CMD_RS = 0x08
定义 E1000_TXD_STAT_DD = 0x01

// §11 中断处理

函数 e1000_中断处理(dev) {
    定义 icr = e1000_读(dev, 0x00C0)

    // 接收完成
    如果 ((icr & 0x80) != 0) {
        e1000_接收(dev)
    }

    // 发送完成
    如果 ((icr & 0x02) != 0) {
        // 发送队列空间已释放
    }

    // 链路状态变化
    如果 ((icr & 0x04) != 0) {
        定义 状态 = e1000_读(dev, 0x0008)
        dev.链路状态 = (状态 & 0x02) != 0
    }
}

// §12 MMIO读写

函数 e1000_读(dev, 寄存器) {
    返回 内存读32(dev.MMIO基址 + 寄存器)
}

函数 e1000_写(dev, 寄存器, 值) {
    内存写32(dev.MMIO基址 + 寄存器, 值)
}

函数 直传_分配_对齐(大小, 对齐) {
    返回 分配内存(大小)
}

函数 内存填零(地址, 大小) {
    内存_置零(地址, 大小)
}

函数 网络_接收帧(缓冲, 长度) {
    // 解析以太网帧头, 根据EtherType分发到上层协议栈
    如果 (缓冲 == 0 || 长度 < 14) { 返回 }  // 最小以太网帧=14字节头
    // 提取EtherType (偏移12-13, 大端)
    定义 类型 = (内存_读8(缓冲 + 12) << 8) | 内存_读8(缓冲 + 13)
    定义 载荷 = 缓冲 + 14
    定义 载荷长 = 长度 - 14
    如果 (类型 == 0x0800) { IP_接收(载荷, 载荷长) }       // IPv4
    否则 如果 (类型 == 0x0806) { ARP_接收(载荷, 载荷长) }  // ARP
    否则 如果 (类型 == 0x86DD) { IPv6_接收(载荷, 载荷长) }  // IPv6
}
定义 错误_参数过大 = -75

// §13 统计与诊断

函数 e1000_统计(dev) {
    返回 {
        接收包: dev.接收包数,
        发送包: dev.发送包数,
        接收字节: dev.接收字节,
        发送字节: dev.发送字节,
        链路: dev.链路状态,
    }
}

函数 e1000_健康检查(dev) {
    定义 可变 问题 = []
    如果 (!dev.链路状态) { 追加(问题, "链路断开") }
    如果 (dev.rx_错误总数 > dev.rx_包总数 / 5 && dev.rx_包总数 > 100) {
        追加(问题, "RX错误率过高")
    }
    如果 (dev.tx_错误总数 > dev.tx_包总数 / 5 && dev.tx_包总数 > 100) {
        追加(问题, "TX错误率过高")
    }
    如果 (计数(问题) == 0) { 返回 "e1000健康" }
    返回 问题
}

// 接收过滤

函数 e1000_接收_过滤检查(dev, 包头) {
    如果 (dev.混杂模式) { 返回 真 }
    如果 (包头 == 空) { 返回 假 }
    返回 真
}

定义 可变 AI_接收初始化_风暴阈值 = 10000
定义 可变 AI_接收初始化_预测IRQ = 0

函数 AI_接收初始化_风暴检测(触发频率) {
    如果 (触发频率 > AI_接收初始化_风暴阈值) {
        AI_接收初始化_风暴阈值 = AI_接收初始化_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_接收初始化_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

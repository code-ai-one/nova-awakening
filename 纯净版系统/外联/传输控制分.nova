导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/创建甲.nova")
导入("../执行/底层内存操.nova")

定义 临时端口起始 = 32768
定义 临时端口结束 = 60999
定义 最大连接 = 1024
定义 状态_关闭 = 0
定义 状态_监听 = 1
定义 状态_同步发送 = 2
定义 状态_同步收到 = 3
定义 状态_已建立 = 4
定义 状态_结束等1 = 5
定义 状态_结束等2 = 6
定义 状态_关闭等待 = 7
定义 状态_最后确认 = 8
定义 状态_时间等待 = 9
定义 时间等待超时 = 120000000

结构 传控连接 {
    本地地址,
    远端地址,
    本地端口,
    远端端口,
    状态,
    发送序号,
    接收序号,
    创建时刻,
    最近活跃,
}

定义 可变 连接表 = 0
定义 可变 连接数 = 0
定义 可变 下一临时端口 = 临时端口起始
定义 可变 分配总数 = 0
定义 可变 分配失败 = 0
定义 可变 回收数 = 0
定义 可变 随机种子 = 12345

函数 传控连接_初始化() {
    连接表 = 堆_分配(最大连接 * 72)
    内存_清零(连接表, 最大连接 * 72)
    连接数 = 0
}

函数 传控_分配临时端口() {
    分配总数 = 分配总数 + 1
    随机种子 = (随机种子 * 1103515245 + 12345) & 0x7FFFFFFF
    定义 起始偏移 = 随机种子 % (临时端口结束 - 临时端口起始)
    定义 可变 尝试 = 0
    当 (尝试 < (临时端口结束 - 临时端口起始)) {
        定义 端口 = 临时端口起始 + ((起始偏移 + 尝试) % (临时端口结束 - 临时端口起始))
        如果 (!传控_端口已占用(端口)) { 返回 端口 }
        尝试 = 尝试 + 1
    }
    分配失败 = 分配失败 + 1
    返回 0
}

函数 传控_端口已占用(端口) {
    定义 可变 序号 = 0
    当 (序号 < 连接数) {
        定义 偏移 = 连接表 + 序号 * 72
        如果 (内存_读16(偏移 + 8) == 端口 && 内存_读32(偏移 + 32) != 状态_关闭) { 返回 真 }
        序号 = 序号 + 1
    }
    返回 假
}

函数 传控_创建连接(本地地址, 远端地址, 本地端口, 远端端口, 初始状态) {
    如果 (连接数 >= 最大连接) { 传控_回收时间等待(); }
    如果 (连接数 >= 最大连接) { 返回 -1 }
    定义 偏移 = 连接表 + 连接数 * 72
    内存_写32(偏移, 本地地址)
    内存_写32(偏移 + 4, 远端地址)
    内存_写16(偏移 + 8, 本地端口)
    内存_写16(偏移 + 10, 远端端口)
    内存_写32(偏移 + 32, 初始状态)
    内存_写32(偏移 + 36, 0)
    内存_写32(偏移 + 40, 0)
    内存_写64(偏移 + 48, 平台_获取高精度时间())
    内存_写64(偏移 + 56, 平台_获取高精度时间())
    定义 索引 = 连接数
    连接数 = 连接数 + 1
    返回 索引
}

函数 传控_查找连接(本地端口, 远端地址, 远端端口) {
    定义 可变 序号 = 0
    当 (序号 < 连接数) {
        定义 偏移 = 连接表 + 序号 * 72
        如果 (内存_读16(偏移 + 8) == 本地端口 && 内存_读32(偏移 + 4) == 远端地址 && 内存_读16(偏移 + 10) == 远端端口) {
            返回 序号
        }
        序号 = 序号 + 1
    }
    返回 -1
}

函数 传控_设状态(索引, 新状态) {
    如果 (索引 >= 连接数) { 返回 }
    内存_写32(连接表 + 索引 * 72 + 32, 新状态)
    内存_写64(连接表 + 索引 * 72 + 56, 平台_获取高精度时间())
}

函数 传控_获取状态(索引) {
    如果 (索引 >= 连接数) { 返回 状态_关闭 }
    返回 内存_读32(连接表 + 索引 * 72 + 32)
}

函数 传控_回收时间等待() {
    定义 现在 = 平台_获取高精度时间()
    定义 可变 序号 = 0
    当 (序号 < 连接数) {
        定义 偏移 = 连接表 + 序号 * 72
        如果 (内存_读32(偏移 + 32) == 状态_时间等待) {
            如果 (现在 - 内存_读64(偏移 + 56) > 时间等待超时) {
                内存_写32(偏移 + 32, 状态_关闭)
                回收数 = 回收数 + 1
            }
        }
        序号 = 序号 + 1
    }
}

函数 传控_状态名(状态) {
    如果 (状态 == 状态_关闭) { 返回 "关闭" }
    如果 (状态 == 状态_监听) { 返回 "监听" }
    如果 (状态 == 状态_同步发送) { 返回 "同步发送" }
    如果 (状态 == 状态_同步收到) { 返回 "同步收到" }
    如果 (状态 == 状态_已建立) { 返回 "已建立" }
    如果 (状态 == 状态_结束等1) { 返回 "结束等1" }
    如果 (状态 == 状态_结束等2) { 返回 "结束等2" }
    如果 (状态 == 状态_关闭等待) { 返回 "关闭等待" }
    如果 (状态 == 状态_最后确认) { 返回 "最后确认" }
    如果 (状态 == 状态_时间等待) { 返回 "时间等待" }
    返回 "未知"
}

函数 传控_活跃连接数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 连接数) {
        如果 (内存_读32(连接表 + 序号 * 72 + 32) == 状态_已建立) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 传控_监听数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 连接数) {
        如果 (内存_读32(连接表 + 序号 * 72 + 32) == 状态_监听) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 传控连接_完整统计() {
    返回 [连接数, 传控_活跃连接数(), 传控_监听数(), 分配总数, 分配失败, 回收数]
}

导入("../基础.nova")
导入("../数学/工具.nova")

// MoE — 混合专家模型 (v2: 2024-2025 前沿迭代)
// ref: Fedus et al. 2022 "Switch Transformers" (稀疏MoE)
// ref: Jiang et al. 2024 "Mixtral of Experts" (Mixtral 8×7B)
// ref: Dai et al. 2024 "DeepSeekMoE: Towards Ultimate Expert
//   Specialization" (细粒度专家 + 共享专家)
// ref: Zhou et al. 2022 "Mixture-of-Experts with Expert Choice
//   Routing" (专家选token, 而非token选专家)
// ref: DeepSeek-V3 2024 "无辅助损失负载均衡" (bias-based balancing,
//   消除aux loss对梯度的干扰)
// ref: Raposo et al. 2024 "Mixture-of-Depths" (动态跳层,
//   不重要token跳过整个Transformer块)
// 核心: 每个token只激活top-k个专家, 稀疏计算
// 计算量 ≈ 单个专家×k, 但参数量 = 所有专家之和

定义 MOE精度 = 10000

// 路由器/门控
// G(x) = softmax(W_g · x), 选top-k

函数 MoE_路由(输入, 门控权重, 专家数, top_k) {
    定义 d = 计数(输入)
    // 计算每个专家的分数
    定义 可变 分数 = []
    定义 可变 e = 0
    当 (e < 专家数) {
        定义 可变 dot = 0
        定义 可变 j = 0
        当 (j < d) {
            dot = dot + 门控权重[e * d + j] * 输入[j] / MOE精度
            j = j + 1
        }
        追加(分数, dot)
        e = e + 1
    }
    // Top-k选择 (贪心选k个最大)
    定义 可变 选中 = []
    定义 可变 已选标记 = []
    e = 0
    当 (e < 专家数) { 追加(已选标记, 0); e = e + 1 }
    定义 可变 ki = 0
    当 (ki < top_k) {
        定义 可变 最佳 = -1
        定义 可变 最佳分 = 0 - MOE精度 * 100
        e = 0
        当 (e < 专家数) {
            如果 (已选标记[e] == 0 且 分数[e] > 最佳分) {
                最佳分 = 分数[e]
                最佳 = e
            }
            e = e + 1
        }
        如果 (最佳 >= 0) {
            追加(选中, 最佳)
            已选标记[最佳] = 1
        }
        ki = ki + 1
    }
    // Softmax归一化选中专家的权重
    定义 可变 权重 = []
    定义 可变 sum_exp = 0
    定义 可变 max_s = 0 - MOE精度 * 100
    ki = 0
    当 (ki < 计数(选中)) {
        如果 (分数[选中[ki]] > max_s) { max_s = 分数[选中[ki]] }
        ki = ki + 1
    }
    ki = 0
    当 (ki < 计数(选中)) {
        定义 差 = 分数[选中[ki]] - max_s
        定义 可变 exp_v = MOE精度 + 差 + 差 * 差 / (2 * MOE精度)
        如果 (exp_v < 1) { exp_v = 1 }
        追加(权重, exp_v)
        sum_exp = sum_exp + exp_v
        ki = ki + 1
    }
    如果 (sum_exp > 0) {
        ki = 0
        当 (ki < 计数(权重)) {
            权重[ki] = 权重[ki] * MOE精度 / sum_exp
            ki = ki + 1
        }
    }
    返回 [选中, 权重]
}

// MoE前向
// 每个专家是一个FFN: Expert(x) = W2 · σ(W1 · x)
函数 MoE_前向(输入, 专家权重列表, 门控权重, 专家数, top_k, d_模型, d_ff) {
    定义 路由结果 = MoE_路由(输入, 门控权重, 专家数, top_k)
    定义 选中 = 路由结果[0]
    定义 权重 = 路由结果[1]
    // 累积输出
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < d_模型) { 追加(输出, 0); i = i + 1 }
    // 对每个选中专家
    定义 可变 ki = 0
    当 (ki < 计数(选中)) {
        定义 专家idx = 选中[ki]
        定义 w = 权重[ki]
        // FFN: h = ReLU(W1·x), y = W2·h
        定义 W1 = 专家权重列表[专家idx * 2]
        定义 W2 = 专家权重列表[专家idx * 2 + 1]
        // W1·x → h
        定义 可变 h = []
        定义 可变 fi = 0
        当 (fi < d_ff) {
            定义 可变 dot = 0
            定义 可变 j = 0
            当 (j < d_模型) {
                dot = dot + W1[fi * d_模型 + j] * 输入[j] / MOE精度
                j = j + 1
            }
            // SiLU激活: x·σ(x) ≈ x·(x+|x|)/(2|x|+2) 简化
            如果 (dot < 0) { dot = dot / 4 }  // leaky approximation
            追加(h, dot)
            fi = fi + 1
        }
        // W2·h → y, 加权累积
        i = 0
        当 (i < d_模型) {
            定义 可变 dot = 0
            定义 可变 fi2 = 0
            当 (fi2 < d_ff) {
                dot = dot + W2[i * d_ff + fi2] * h[fi2] / MOE精度
                fi2 = fi2 + 1
            }
            输出[i] = 输出[i] + w * dot / MOE精度
            i = i + 1
        }
        ki = ki + 1
    }
    返回 输出
}

// DeepSeekMoE: 共享专家 + 细粒度专家 (Dai et al. 2024)
// 创新: 部分专家始终激活(共享), 其余稀疏路由
函数 DeepSeek_MoE前向(输入, 共享专家W1, 共享专家W2, 路由专家权重, 门控权重, 专家数, top_k, d_模型, d_ff) {
    // 1. 共享专家 (always-on)
    定义 可变 共享输出 = []
    定义 可变 fi = 0
    当 (fi < d_ff) {
        定义 可变 j = 0
        定义 可变 dot = 0
        当 (j < d_模型) { dot = dot + 共享专家W1[fi * d_模型 + j] * 输入[j] / MOE精度; j = j + 1 }
        如果 (dot < 0) { dot = dot / 4 }
        追加(共享输出, dot)
        fi = fi + 1
    }
    定义 可变 共享y = []
    定义 可变 i = 0
    当 (i < d_模型) {
        fi = 0
        定义 可变 dot = 0
        当 (fi < d_ff) { dot = dot + 共享专家W2[i * d_ff + fi] * 共享输出[fi] / MOE精度; fi = fi + 1 }
        追加(共享y, dot)
        i = i + 1
    }
    // 2. 路由专家 (sparse)
    定义 路由y = MoE_前向(输入, 路由专家权重, 门控权重, 专家数, top_k, d_模型, d_ff)
    // 3. 合并
    定义 可变 最终 = []
    i = 0
    当 (i < d_模型) {
        追加(最终, 共享y[i] + 路由y[i])
        i = i + 1
    }
    返回 最终
}

// 负载均衡损失 (Switch Transformer)
// 防止所有token都路由到同一个专家
// L_balance = α · N · Σ_i f_i · P_i
// f_i = token选择专家i的频率, P_i = 路由概率均值
函数 MoE_负载均衡损失(选择历史, 概率历史, 专家数, 系数α) {
    定义 T = 计数(选择历史)
    如果 (T == 0) { 返回 0 }
    定义 可变 频率 = []
    定义 可变 概率均值 = []
    定义 可变 e = 0
    当 (e < 专家数) { 追加(频率, 0); 追加(概率均值, 0); e = e + 1 }
    定义 可变 t = 0
    当 (t < T) {
        频率[选择历史[t]] = 频率[选择历史[t]] + MOE精度 / T
        如果 (t < 计数(概率历史)) {
            概率均值[选择历史[t]] = 概率均值[选择历史[t]] + 概率历史[t] / T
        }
        t = t + 1
    }
    定义 可变 损失 = 0
    e = 0
    当 (e < 专家数) {
        损失 = 损失 + 频率[e] * 概率均值[e] / MOE精度
        e = e + 1
    }
    返回 系数α * 专家数 * 损失 / MOE精度
}

// Expert Choice路由 (Zhou et al. 2022, Google)
// 核心颠覆: 传统MoE是token选专家, Expert Choice是专家选token
// 每个专家从所有token中选top-k个自己最擅长的
// 优势: 1. 天然负载均衡(每专家固定处理k个) 2. 无需aux loss
// 3. token可被0~N个专家选中(自适应计算量)
函数 ExpertChoice_路由(输入列表, 门控权重, 专家数, 容量因子, d_模型) {
    定义 T = 计数(输入列表) / d_模型
    定义 容量 = T * 容量因子 / 专家数
    如果 (容量 < 1) { 容量 = 1 }
    // 计算完整分数矩阵 S[e][t] = W_g[e] · x[t]
    定义 可变 分配 = []
    定义 可变 分配权重 = []
    定义 可变 e = 0
    当 (e < 专家数) {
        // 计算该专家对所有token的分数
        定义 可变 分数 = []
        定义 可变 t = 0
        当 (t < T) {
            定义 可变 dot = 0
            定义 可变 j = 0
            当 (j < d_模型) {
                dot = dot + 门控权重[e * d_模型 + j] * 输入列表[t * d_模型 + j] / MOE精度
                j = j + 1
            }
            追加(分数, dot)
            t = t + 1
        }
        // 该专家选top-容量个token (贪心)
        定义 可变 专家选中 = []
        定义 可变 专家权重 = []
        定义 可变 已选 = []
        t = 0
        当 (t < T) { 追加(已选, 0); t = t + 1 }
        定义 可变 ci = 0
        当 (ci < 容量) {
            定义 可变 最佳t = -1
            定义 可变 最佳分 = 0 - MOE精度 * 100
            t = 0
            当 (t < T) {
                如果 (已选[t] == 0 且 分数[t] > 最佳分) {
                    最佳分 = 分数[t]
                    最佳t = t
                }
                t = t + 1
            }
            如果 (最佳t >= 0) {
                追加(专家选中, 最佳t)
                已选[最佳t] = 1
                // softmax权重 (简化: 归一化分数)
                追加(专家权重, 最佳分)
            }
            ci = ci + 1
        }
        // 归一化权重
        定义 可变 wsum = 0
        ci = 0
        当 (ci < 计数(专家权重)) { wsum = wsum + 专家权重[ci]; ci = ci + 1 }
        如果 (wsum > 0) {
            ci = 0
            当 (ci < 计数(专家权重)) {
                专家权重[ci] = 专家权重[ci] * MOE精度 / wsum
                ci = ci + 1
            }
        }
        追加(分配, 专家选中)
        追加(分配权重, 专家权重)
        e = e + 1
    }
    返回 [分配, 分配权重]
}

// DeepSeek-V3: 无辅助损失负载均衡 (2024)
// 传统: L_balance加入训练损失 → 干扰主损失梯度方向
// DeepSeek-V3: 用可学习bias替代aux loss
// g'_i = g_i + b_i (b_i仅影响路由选择, 不传梯度到主网络)
// b_i根据专家利用率动态调整: 过热专家降bias, 冷门专家升bias
函数 V3_无损均衡_路由(输入, 门控权重, 偏置, 专家数, top_k) {
    定义 d = 计数(输入)
    // 计算原始门控分数
    定义 可变 原始分数 = []
    定义 可变 e = 0
    当 (e < 专家数) {
        定义 可变 dot = 0
        定义 可变 j = 0
        当 (j < d) {
            dot = dot + 门控权重[e * d + j] * 输入[j] / MOE精度
            j = j + 1
        }
        追加(原始分数, dot)
        e = e + 1
    }
    // 路由分数 = 原始分数 + 偏置 (偏置仅用于选择, 不回传梯度)
    定义 可变 路由分数 = []
    e = 0
    当 (e < 专家数) {
        追加(路由分数, 原始分数[e] + 偏置[e])
        e = e + 1
    }
    // Top-k选择 (基于加偏置的分数)
    定义 可变 选中 = []
    定义 可变 已选标记 = []
    e = 0
    当 (e < 专家数) { 追加(已选标记, 0); e = e + 1 }
    定义 可变 ki = 0
    当 (ki < top_k) {
        定义 可变 最佳 = -1
        定义 可变 最佳分 = 0 - MOE精度 * 100
        e = 0
        当 (e < 专家数) {
            如果 (已选标记[e] == 0 且 路由分数[e] > 最佳分) {
                最佳分 = 路由分数[e]
                最佳 = e
            }
            e = e + 1
        }
        如果 (最佳 >= 0) { 追加(选中, 最佳); 已选标记[最佳] = 1 }
        ki = ki + 1
    }
    // 权重计算: 用原始分数(无偏置)做softmax → 梯度干净
    定义 可变 权重 = []
    定义 可变 max_s = 0 - MOE精度 * 100
    ki = 0
    当 (ki < 计数(选中)) {
        如果 (原始分数[选中[ki]] > max_s) { max_s = 原始分数[选中[ki]] }
        ki = ki + 1
    }
    定义 可变 sum_exp = 0
    ki = 0
    当 (ki < 计数(选中)) {
        定义 差 = 原始分数[选中[ki]] - max_s
        定义 可变 ev = MOE精度 + 差 + 差 * 差 / (2 * MOE精度)
        如果 (ev < 1) { ev = 1 }
        追加(权重, ev)
        sum_exp = sum_exp + ev
        ki = ki + 1
    }
    如果 (sum_exp > 0) {
        ki = 0
        当 (ki < 计数(权重)) { 权重[ki] = 权重[ki] * MOE精度 / sum_exp; ki = ki + 1 }
    }
    返回 [选中, 权重]
}

// 偏置动态更新: 根据专家利用率调整
// 过热专家(利用率>均值): 降bias; 冷门专家(利用率<均值): 升bias
函数 V3_更新偏置(偏置, 专家利用率, 专家数, 更新步长) {
    定义 可变 总利用 = 0
    定义 可变 e = 0
    当 (e < 专家数) { 总利用 = 总利用 + 专家利用率[e]; e = e + 1 }
    定义 均值 = 总利用 / (专家数 + 1)
    e = 0
    当 (e < 专家数) {
        定义 偏差 = 专家利用率[e] - 均值
        // 过热 → 降bias, 冷门 → 升bias (负反馈)
        偏置[e] = 偏置[e] - 更新步长 * 偏差 / MOE精度
        e = e + 1
    }
    返回 偏置
}

// Mixture-of-Depths (Raposo et al. 2024, Google DeepMind)
// 核心洞见: 不是所有token都需要经过每一层transformer
// 路由器决定每个token是"计算"还是"跳过"本层
// 通过容量限制c控制每层实际计算的token比例
// 效果: 相同FLOPs下更高质量, 或相同质量下更少FLOPs
函数 MoD_路由(token嵌入列表, 路由权重, 序列长, d_模型, 容量比例) {
    // 容量: 该层最多处理多少token
    定义 容量 = 序列长 * 容量比例 / MOE精度
    如果 (容量 < 1) { 容量 = 1 }
    // 计算每个token的路由分数 r_i = W_r · x_i
    定义 可变 分数 = []
    定义 可变 t = 0
    当 (t < 序列长) {
        定义 可变 dot = 0
        定义 可变 j = 0
        当 (j < d_模型) {
            dot = dot + 路由权重[j] * token嵌入列表[t * d_模型 + j] / MOE精度
            j = j + 1
        }
        追加(分数, dot)
        t = t + 1
    }
    // 选top-容量个token参与计算 (其余直接residual跳过)
    定义 可变 参与计算 = []
    t = 0
    当 (t < 序列长) { 追加(参与计算, 0); t = t + 1 }
    定义 可变 已选 = 0
    当 (已选 < 容量) {
        定义 可变 最佳t = -1
        定义 可变 最佳分 = 0 - MOE精度 * 100
        t = 0
        当 (t < 序列长) {
            如果 (参与计算[t] == 0 且 分数[t] > 最佳分) {
                最佳分 = 分数[t]
                最佳t = t
            }
            t = t + 1
        }
        如果 (最佳t >= 0) { 参与计算[最佳t] = 1 }
        已选 = 已选 + 1
    }
    // 返回: [参与计算标记, 路由权重(sigmoid(分数))]
    定义 可变 路由权重列表 = []
    t = 0
    当 (t < 序列长) {
        如果 (参与计算[t] == 1) {
            // sigmoid(分数) 作为残差加权
            定义 s = 分数[t]
            定义 可变 σ = MOE精度 / 2
            如果 (s > 0) {
                σ = MOE精度 - MOE精度 * MOE精度 / (MOE精度 + s + s * s / (2 * MOE精度))
            } 否则 如果 (s < 0) {
                定义 neg = 0 - s
                σ = MOE精度 * MOE精度 / (MOE精度 + neg + neg * neg / (2 * MOE精度))
            }
            追加(路由权重列表, σ)
        } 否则 {
            追加(路由权重列表, 0)
        }
        t = t + 1
    }
    返回 [参与计算, 路由权重列表]
}

// MoD前向: 参与计算的token经过transformer块, 跳过的直接residual
函数 MoD_前向(token列表, 参与标记, 路由权重, 变换函数权重, 序列长, d_模型, d_ff) {
    定义 可变 输出 = []
    定义 可变 t = 0
    当 (t < 序列长) {
        如果 (参与标记[t] == 1) {
            // 参与计算: y = x + w_r · FFN(x)
            定义 可变 x = []
            定义 可变 j = 0
            当 (j < d_模型) { 追加(x, token列表[t * d_模型 + j]); j = j + 1 }
            // FFN: h = ReLU(W1·x), y = W2·h
            定义 可变 h = []
            定义 可变 fi = 0
            当 (fi < d_ff) {
                定义 可变 dot = 0
                j = 0
                当 (j < d_模型) {
                    dot = dot + 变换函数权重[fi * d_模型 + j] * x[j] / MOE精度
                    j = j + 1
                }
                如果 (dot < 0) { dot = dot / 4 }
                追加(h, dot)
                fi = fi + 1
            }
            j = 0
            当 (j < d_模型) {
                定义 可变 dot = 0
                fi = 0
                当 (fi < d_ff) {
                    dot = dot + 变换函数权重[d_ff * d_模型 + j * d_ff + fi] * h[fi] / MOE精度
                    fi = fi + 1
                }
                // 残差 + 路由权重缩放
                追加(输出, x[j] + 路由权重[t] * dot / MOE精度)
                j = j + 1
            }
        } 否则 {
            // 跳过: 直接复制输入 (residual identity)
            定义 可变 j = 0
            当 (j < d_模型) {
                追加(输出, token列表[t * d_模型 + j])
                j = j + 1
            }
        }
        t = t + 1
    }
    返回 输出
}

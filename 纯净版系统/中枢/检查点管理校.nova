    内核打印("总恢复: " + 整数转字符串(NCPM_总恢复数))
    内核打印("验证总数: " + 整数转字符串(NCPM_总验证数))
    内核打印("验证失败: " + 整数转字符串(NCPM_验证失败数))
    内核打印("压缩节省: " + 整数转字符串(NCPM_压缩节省字节) + " 字节")
}

// §17 检查点自动清理

定义 NCPM_最大保留检查点 = 8
定义 NCPM_过期时间 = 3600000  // 1小时(毫秒)

函数 NCPM_自动清理() {
    定义 当前时间 = 获取时间戳()
    定义 可变 清理数 = 0

    // 按时间清理过期检查点
    定义 可变 i = 0
    当 (i < 计数(检查点列表)) {
        如果 (当前时间 - 检查点列表[i].创建时间 > NCPM_过期时间) {
            内核信息("NCPM: 清理过期检查点 ID=" + 整数转字符串(检查点列表[i].检查点ID))
            清理数 = 清理数 + 1
        }
        i = i + 1
    }

    // 保留数量限制
    当 (计数(检查点列表) > NCPM_最大保留检查点) {
        检查点列表 = 检查点列表[1:]
        清理数 = 清理数 + 1
    }

    如果 (清理数 > 0) {
        内核信息("NCPM: 自动清理 " + 整数转字符串(清理数) + " 个检查点")
    }
    返回 清理数
}

// §18 FNV-1a哈希引擎

// NCPM哈希理论: FNV-1a变体 用于快速校验和计算
// H(i) = (H(i-1) XOR byte_i) × FNV_prime

定义 FNV_OFFSET_BASIS = 0xCBF29CE484222325
定义 FNV_PRIME = 0x100000001B3

函数 NCPM_FNV1a_哈希(数据, 大小) {
    定义 可变 hash = FNV_OFFSET_BASIS
    定义 可变 i = 0
    当 (i < 大小) {
        hash = hash ^ 内存_读8(数据 + i)
        hash = hash * FNV_PRIME
        i = i + 1
    }
    返回 hash
}

函数 NCPM_FNV1a_增量(prev_hash, 新字节) {
    返回 (prev_hash ^ 新字节) * FNV_PRIME
}

函数 NCPM_FNV1a_整数(值) {
    // 对一个整数做FNV-1a哈希
    定义 可变 hash = FNV_OFFSET_BASIS
    hash = (hash ^ (值 & 0xFF)) * FNV_PRIME
    hash = (hash ^ ((值 >> 8) & 0xFF)) * FNV_PRIME
    hash = (hash ^ ((值 >> 16) & 0xFF)) * FNV_PRIME
    hash = (hash ^ ((值 >> 24) & 0xFF)) * FNV_PRIME
    hash = (hash ^ ((值 >> 32) & 0xFF)) * FNV_PRIME
    hash = (hash ^ ((值 >> 40) & 0xFF)) * FNV_PRIME
    hash = (hash ^ ((值 >> 48) & 0xFF)) * FNV_PRIME
    hash = (hash ^ ((值 >> 56) & 0xFF)) * FNV_PRIME
    返回 hash
}

// §19 检查点序列化

函数 NCPM_序列化检查点(cp, 输出, 最大大小) {
    如果 (cp == 空 || 输出 == 0) { 返回 0 }
    定义 可变 pos = 0

    // 写入魔数
    如果 (pos + 4 > 最大大小) { 返回 -1 }
    写小端32(输出 + pos, 0x4E435043)  // "NCPC"
    pos = pos + 4

    // 写入检查点ID
    如果 (pos + 8 > 最大大小) { 返回 -1 }
    写小端64(输出 + pos, cp.检查点ID)
    pos = pos + 8

    // 写入进程数
    如果 (pos + 4 > 最大大小) { 返回 -1 }
    写小端32(输出 + pos, cp.进程数)
    pos = pos + 4

    // 写入空闲页数
    如果 (pos + 8 > 最大大小) { 返回 -1 }
    写小端64(输出 + pos, cp.全局空闲页)
    pos = pos + 8

    // 写入校验和
    如果 (pos + 8 > 最大大小) { 返回 -1 }
    定义 checksum = 检查点_计算校验和(cp)
    写小端64(输出 + pos, checksum)
    pos = pos + 8

    内核调试("NCPM: 序列化 " + 整数转字符串(pos) + " 字节")
    返回 pos
}

函数 NCPM_反序列化检查点(数据, 大小) {
    如果 (数据 == 0 || 大小 < 32) { 返回 空 }
    定义 可变 pos = 0

    // 验证魔数
    定义 magic = 读小端32(数据 + pos)
    如果 (magic != 0x4E435043) {
        内核错误("NCPM: 无效的检查点格式")
        返回 空
    }
    pos = pos + 4

    定义 id = 读小端64(数据 + pos); pos = pos + 8
    定义 procs = 读小端32(数据 + pos); pos = pos + 4
    定义 pages = 读小端64(数据 + pos); pos = pos + 8
    定义 checksum = 读小端64(数据 + pos); pos = pos + 8

    内核调试("NCPM: 反序列化 ID=" + 整数转字符串(id) + " 进程=" + 整数转字符串(procs))
    返回 [id, procs, pages, checksum]
}

// §20 NCPM初始化

函数 NCPM_初始化() {
    NCPM_总创建数 = 0
    NCPM_总恢复数 = 0
    NCPM_总验证数 = 0
    NCPM_验证失败数 = 0
    NCPM_压缩节省字节 = 0
    差异检查点列表 = []
    内核信息("[NCPM] Nova检查点管理器 v1.0 初始化完成")
    返回 0
}

函数 NCPM_查找检查点(检查点ID) {
    定义 可变 i = 0
    当 (i < 计数(检查点列表)) {
        如果 (检查点列表[i].检查点ID == 检查点ID) {
            返回 检查点列表[i]
        }
        i = i + 1
    }
    返回 空
}

函数 NCPM_最新检查点() {
    如果 (计数(检查点列表) == 0) { 返回 空 }
    返回 检查点列表[计数(检查点列表) - 1]
}

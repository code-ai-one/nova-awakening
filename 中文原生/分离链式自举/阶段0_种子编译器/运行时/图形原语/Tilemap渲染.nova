// Nova · 运行时 · 图形原语 · Tilemap渲染
// 职责: 瓦片地图渲染、图块集管理、相机滚动
// 层级: M12 — 2D/3D渲染增强

// 图块集: [纹理, 图块宽, 图块高, 列数, 行数]

导入("../../标准库/基础.nova")
导入("./精灵批渲染.nova")

函数 图块集_创建(纹理, 图块宽, 图块高) {
    定义 列数 = 纹理_宽(纹理) / 图块宽
    定义 行数 = 纹理_高(纹理) / 图块高
    返回 [纹理, 图块宽, 图块高, 列数, 行数]
}

函数 图块集_图块宽(ts) { 返回 ts[1] }
函数 图块集_图块高(ts) { 返回 ts[2] }
函数 图块集_列数(ts) { 返回 ts[3] }

// 获取图块在纹理中的源矩形 [sx, sy, sw, sh]
函数 图块集_图块矩形(ts, 图块ID) {
    如果 (图块ID < 0) { 返回 [0, 0, 0, 0] }
    定义 列 = 图块ID % ts[3]
    定义 行 = 图块ID / ts[3]
    返回 [列 * ts[1], 行 * ts[2], ts[1], ts[2]]
}

// 瓦片图层: [名称, 宽(图块数), 高(图块数), 数据, 可见, 透明度]
函数 图层_创建(名称, 宽, 高) {
    定义 可变 数据 = []
    定义 可变 i = 0
    当 (i < 宽 * 高) { 追加(数据, -1)  i = i + 1 }  // -1=空
    返回 [名称, 宽, 高, 数据, 真, 1000]
}

函数 图层_名称(l) { 返回 l[0] }
函数 图层_宽(l) { 返回 l[1] }
函数 图层_高(l) { 返回 l[2] }
函数 图层_可见(l) { 返回 l[4] }
函数 图层_设可见(l, v) { l[4] = v }

函数 图层_设图块(l, x, y, 图块ID) {
    如果 (x >= 0 且 x < l[1] 且 y >= 0 且 y < l[2]) {
        l[3][y * l[1] + x] = 图块ID
    }
}

函数 图层_取图块(l, x, y) {
    如果 (x < 0 或 x >= l[1] 或 y < 0 或 y >= l[2]) { 返回 -1 }
    返回 l[3][y * l[1] + x]
}

// 瓦片地图: [图块集, 图层列表, 相机x, 相机y]
函数 瓦片地图_创建(图块集) {
    返回 [图块集, [],]
}

函数 瓦片地图_图块集(m) { 返回 m[0] }
函数 瓦片地图_图层(m) { 返回 m[1] }
函数 瓦片地图_相机x(m) { 返回 m[2] }
函数 瓦片地图_相机y(m) { 返回 m[3] }

函数 瓦片地图_添加图层(m, 图层) { 追加(m[1], 图层) }
函数 瓦片地图_设相机(m, x, y) { m[2] = x  m[3] = y }
函数 瓦片地图_移动相机(m, dx, dy) { m[2] = m[2] + dx  m[3] = m[3] + dy }

// 渲染到帧缓冲
// 帧缓冲: 一维像素数组, 宽×高
函数 瓦片地图_渲染(m, 帧缓冲, 屏宽, 屏高) {
    定义 ts = m[0]
    定义 图块w = 图块集_图块宽(ts)
    定义 图块h = 图块集_图块高(ts)
    定义 纹理 = ts[0]
    定义 camx = m[2]
    定义 camy = m[3]

    // 计算可见图块范围
    定义 起始列 = camx / 图块w
    定义 起始行 = camy / 图块h
    定义 可见列 = 屏宽 / 图块w + 2
    定义 可见行 = 屏高 / 图块h + 2
    定义 偏移x = camx % 图块w
    定义 偏移y = camy % 图块h

    // 逐图层渲染
    定义 可变 li = 0
    当 (li < 计数(m[1])) {
        定义 图层 = m[1][li]
        如果 (图层_可见(图层)) {
            定义 可变 行 = 0
            当 (行 < 可见行) {
                定义 可变 列 = 0
                当 (列 < 可见列) {
                    定义 图块ID = 图层_取图块(图层, 起始列 + 列, 起始行 + 行)
                    如果 (图块ID >= 0) {
                        定义 源 = 图块集_图块矩形(ts, 图块ID)
                        // 将图块绘制到帧缓冲
                        定义 目标x = 列 * 图块w - 偏移x
                        定义 目标y = 行 * 图块h - 偏移y

                        定义 可变 py = 0
                        当 (py < 图块h) {
                            定义 可变 px = 0
                            当 (px < 图块w) {
                                定义 dx = 目标x + px
                                定义 dy = 目标y + py
                                如果 (dx >= 0 且 dx < 屏宽 且 dy >= 0 且 dy < 屏高) {
                                    定义 颜色 = 纹理_取像素(纹理, 源[0] + px, 源[1] + py)
                                    如果 (颜色 != 纹理[3]) {  // 非透明色
                                        帧缓冲[dy * 屏宽 + dx] = 颜色
                                    }
                                }
                                px = px + 1
                            }
                            py = py + 1
                        }
                    }
                    列 = 列 + 1
                }
                行 = 行 + 1
            }
        }
        li = li + 1
    }
}

// 碰撞图层: 标记哪些图块是实心的
函数 瓦片地图_图块是实心(m, 图层索引, 世界x, 世界y) {
    定义 ts = m[0]
    定义 列 = 世界x / 图块集_图块宽(ts)
    定义 行 = 世界y / 图块集_图块高(ts)
    如果 (图层索引 < 计数(m[1])) {
        定义 id = 图层_取图块(m[1][图层索引], 列, 行)
        返回 id >= 0
    }
    返回 假
}

// 报告
函数 瓦片地图_打印报告(m) {
    打印("═══ 瓦片地图报告 ═══")
    打印文本(字符串拼接("  图块大小: ", 字符串拼接(转字符串(图块集_图块宽(m[0])), 字符串拼接("×", 转字符串(图块集_图块高(m[0]))))))
    打印文本(字符串拼接("  图层数: ", 转字符串(计数(m[1]))))
    打印文本(字符串拼接("  相机: (", 字符串拼接(转字符串(m[2]), 字符串拼接(",", 字符串拼接(转字符串(m[3]), ")")))))
    定义 可变 i = 0
    当 (i < 计数(m[1])) {
        定义 l = m[1][i]
        打印文本(字符串拼接("  [", 字符串拼接(转字符串(i), 字符串拼接("] ", 字符串拼接(图层_名称(l), 字符串拼接(" ", 字符串拼接(转字符串(图层_宽(l)), 字符串拼接("×", 转字符串(图层_高(l))))))))))
        i = i + 1
    }
}

    // 通过fetch POST到enNova直接偏好优化int_url
    // 使用Beacon 接口(navigator.sendBeacon)保证送达
}

// §6 错误聚合与统计

结构 错误Aggregation {
    // 按错误签名聚合
    签名,    // u64 message+filename+lineno的哈希
    消息,
    文件,
    行号,
    计数,
    首次时间,
    最后时间,
    下一个,
}

定义 可变 错误聚合头 = 0
定义 可变 错误聚合数 = 0

函数 错误Aggregation_记录(message, filename, lineno) {
    如果 (message == 0) { 返回 }
    // 计算签名
    定义 签名 = 哈希(message) ^ (lineno * 31)

    // 查找已有聚合
    定义 可变 agg = 错误聚合头
    当 (agg != 0) {
        如果 (agg.签名 == 签名 && 字符串_相等(agg.消息, message)) {
            agg.计数 = agg.计数 + 1
            agg.最后时间 = 平台_获取高精度时间()
            返回
        }
        agg = agg.下一个
    }

    // 新增聚合
    定义 新agg = 堆_分配(错误Aggregation)
    新agg.签名 = 签名; 新agg.消息 = message; 新agg.文件 = filename
    新agg.行号 = lineno; 新agg.计数 = 1
    新agg.首次时间 = 平台_获取高精度时间()
    新agg.最后时间 = 新agg.首次时间
    新agg.下一个 = 错误聚合头; 错误聚合头 = 新agg
    错误聚合数 = 错误聚合数 + 1
}

导入("../标准库/基础.nova")

// 运行时原语桩 — S0自举编译用
// 这些函数是底层运行时原语，S0 Rust编译器会为它们生成内联机器码。
// 此文件提供Nova层面的桩定义，确保模块图链接闭合。
// 实际执行时由S0运行时覆盖。
//
// [架构契约] 原语桩调用约定:
//   - S0环境: Rust编译器在链接阶段用真实机器码替换这些桩
//   - 非S0环境(解释器/测试): 桩返回0/空, 调用者应检查__原语桩_活跃标记
//   - 若非S0环境调用了FFI/syscall原语, 说明调用链有误

定义 可变 __原语桩_活跃 = 真  // S0链接时此变量被覆盖为假; 若仍为真=桩未被替换
定义 可变 __原语桩_调用计数 = 0

函数 原语桩_是活跃() { 返回 __原语桩_活跃 }
函数 原语桩_警告(名称) {
    __原语桩_调用计数 = __原语桩_调用计数 + 1
    如果 (__原语桩_调用计数 <= 3) {
        打印("[原语桩警告] 非S0环境调用了底层原语: " + 名称 + " — 返回默认值0")
    }
}

// 运行时/FFI/平台原语
函数 调用指针(_指针, _扩2, _扩3, _扩4, _扩5, _扩6) { 原语桩_警告("调用指针") 返回 0 }
函数 调用指针1(_指针, _a) { 原语桩_警告("调用指针1") 返回 0 }
函数 调用指针2(_指针, _a, _b) { 原语桩_警告("调用指针2") 返回 0 }
函数 调用指针3(_指针, _a, _b, _c) { 原语桩_警告("调用指针3") 返回 0 }
函数 调用指针4(_指针, _a, _b, _c, _d) { 原语桩_警告("调用指针4") 返回 0 }
函数 调用指针6(_指针, _a, _b, _c, _d, _e, _f) { 原语桩_警告("调用指针6") 返回 0 }
函数 调用指针5(_指针, _a, _b, _c, _d, _e) { 原语桩_警告("调用指针5") 返回 0 }
函数 系统调用(_号, _a, _b, _c, _扩5) { 原语桩_警告("系统调用") 返回 0 }
函数 系统调用_原生(_号, _a, _b, _c, _d, _e) { 原语桩_警告("系统调用_原生") 返回 0 }
函数 系统调用6(_号, _a, _b, _c, _d, _e, _f) { 原语桩_警告("系统调用6") 返回 0 }
函数 开方(n) {
    如果 (n <= 0) { 返回 0
}
 定义 可变 x = n
 定义 可变 y = (x + 1) / 2
 当 (y < x) { x = y y = (x + n / x) / 2 }
 返回 x
}
函数 抛(_码) { 退出(_码) }
函数 加载库(_名称) { 返回 0 }
函数 内存读(_地址) { 返回 0 }
函数 内存填充(_地址, _值, _大小) { 返回 0 }
函数 __系统命令(_命令) { 返回 __运行时_执行命令(_命令) }
函数 __运行时_C串转Nova(_指针) { 返回 "" }
函数 __运行时_文件存在(_路径) { 返回 0 }
函数 __即时编译_执行(_块, _偏移) { 返回 0 }
函数 外部调用0(_地址, _扩2) { 返回 0 }
函数 是浮点(_v) { 返回 0 }

// 字典删: 运行时种子无原生dict_delete, 用重建字典实现真删除
函数 字典删(_d, _键) {
    定义 所有键 = 字典键(_d)
    定义 可变 新 = 字典()
    定义 可变 i = 0
    当 (i < 计数(所有键)) {
        如果 (所有键[i] != _键) {
            字典设(新, 所有键[i], 字典取(_d, 所有键[i]))
        }
        i = i + 1
    }
    返回 新
}
函数 类型判断(_v) { 返回 类型(_v) }


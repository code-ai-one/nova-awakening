//       css_layer_rule.cc (~300行)
//       css_supports_rule.cc (~400行)
//       css_property_rule.cc 
//       style_rule.cc (cascade layers ~600行)
// CSS Cascade Layers (@layer):
//   @layer utilities, components;    — 声明层顺序
//   @layer utilities { .foo { ... } } — 层内规则
//   @import url(...) layer(base);    — 导入到层
//   层的优先级: 后声明 > 先声明(同specificity时)
//   未分层的规则 > 所有层
// CSS @supports — 特性检测:
//   @supports (display: grid) { ... }
//   @supports not (display: grid) { ... }
//   @supports (display: grid) and (gap: 1rem) { ... }
//   @supports selector(:has(> .a)) { ... }
// CSS @property — 自定义属性注册:
//   @property --color-primary {
//     syntax: '<color>';
//     inherits: false;
//     initial-value: #333;
//   }
//   允许自定义属性有类型、继承行为和初始值
//   使CSS变量可以参与动画/过渡
// CSS @scope — 作用域样式:
//   @scope (.card) to (.card-content) { ... }
//   限定样式的应用范围(上界到下界)

// §1 Cascade Layer — @layer

结构 CascadeLayer {
    名称,    // u64 层名(如 "utilities")
    全名,    // u64 完整名(如 "framework.utilities")
    顺序,    // u32 声明顺序(用于优先级)
    // 子层
    子层列表,    // u64 CascadeLayer*数组
    子层数量,
    子层容量,
    // 该层内的规则
    规则列表,    // u64 CSSRule*数组
    规则数量,
    规则容量,
    // 父层
    父层,    // u64 CascadeLayer*
}

结构 CascadeLayerManager {
    // 层树(root → 子层 → 孙层)
    根,    // u64 CascadeLayer* (隐式根层)
    // 所有层的平面列表(按声明顺序)
    层列表,    // u64 CascadeLayer*数组
    层数量,
    层容量,
    下一个顺序,
    // 未分层规则(最高优先级)
    未分层规则,
    未分层规则数,
}

定义 可变 全局层管理器 = 0

函数 CascadeLayerManager_获取() {
    如果 (全局层管理器 == 0) {
        全局层管理器 = 堆_分配(CascadeLayerManager)
        全局层管理器.根 = CascadeLayer_创建("", 0)
        全局层管理器.层容量 = 64
        全局层管理器.层列表 = 堆_分配_数组(64 * 8)
        全局层管理器.层数量 = 0
        全局层管理器.下一个顺序 = 0
        全局层管理器.未分层规则 = 堆_分配_数组(256 * 8)
        全局层管理器.未分层规则数 = 0
    }
    返回 全局层管理器
}

函数 CascadeLayer_创建(名称, 父) {
    定义 层 = 堆_分配(CascadeLayer)
    层.名称 = 名称 != 0 ? 字符串_复制(名称) : ""
    层.全名 = ""
    层.顺序 = 0
    层.子层容量 = 16
    层.子层列表 = 堆_分配_数组(16 * 8)
    层.子层数量 = 0
    层.规则容量 = 128
    层.规则列表 = 堆_分配_数组(128 * 8)
    层.规则数量 = 0
    层.父层 = 父

    // 构建全名
    如果 (父 != 0 && 字符串_长度(父.全名) > 0) {
        层.全名 = 字符串_连接(字符串_连接(父.全名, "."), 层.名称)
    } 否则 {
        层.全名 = 层.名称
    }

    返回 层
}

函数 CascadeLayer_查找或创建(管理器, 层名路径) {
    // 层名路径: "a.b.c" → 查找或创建嵌套层
    如果 (管理器 == 0 || 层名路径 == 0) { 返回 管理器.根 }

    定义 可变 当前 = 管理器.根
    // 按.分割层名
    // 按.分割层名, 逐层查找或创建
    定义 可变 开始 = 0; 定义 可变 结束 = 0
    定义 len = 字节长度(层名路径)
    当 (结束 <= len) {
        如果 (结束 == len || 字节取(层名路径, 结束) == 46) {    // '.'
            定义 段名 = 字符串_子串(层名路径, 开始, 结束)
            定义 子层 = CascadeLayer_查找子(当前, 段名)
            如果 (子层 == 0) {
                子层 = CascadeLayer_创建(段名, 当前)
                子层.顺序 = 管理器.下一个顺序; 管理器.下一个顺序 = 管理器.下一个顺序 + 1
            }
            当前 = 子层
            开始 = 结束 + 1
        }
        结束 = 结束 + 1
    }
    返回 当前
}

函数 CascadeLayer_查找或创建_旧(管理器, 层名路径_unused) {
    定义 可变 已有 = CascadeLayer_查找子(0, 层名路径_unused)
    如果 (已有 != 0) { 返回 已有 }

    // 创建新层
    定义 新层 = CascadeLayer_创建(层名路径, 当前)
    新层.顺序 = 管理器.下一个顺序
    管理器.下一个顺序 = 管理器.下一个顺序 + 1

    // 添加到父层
    如果 (当前.子层数量 < 当前.子层容量) {
        内存_写64(当前.子层列表 + 当前.子层数量 * 8, 新层)
        当前.子层数量 = 当前.子层数量 + 1
    }

    // 注册到平面列表
    如果 (管理器.层数量 < 管理器.层容量) {
        内存_写64(管理器.层列表 + 管理器.层数量 * 8, 新层)
        管理器.层数量 = 管理器.层数量 + 1
    }

    返回 新层
}

函数 CascadeLayer_查找子(父, 名称) {
    定义 可变 i = 0
    当 (i < 父.子层数量) {
        定义 子 = 内存_读64(父.子层列表 + i * 8)
        如果 (子 != 0 && 字符串_相等(子.名称, 名称)) { 返回 子 }
        i = i + 1
    }
    返回 0
}

函数 CascadeLayer_添加规则(层, 规则) {
    如果 (层 == 0 || 规则 == 0) { 返回 }
    如果 (层.规则数量 < 层.规则容量) {
        内存_写64(层.规则列表 + 层.规则数量 * 8, 规则)
        层.规则数量 = 层.规则数量 + 1
    }
}

// 层优先级比较: 层顺序大的优先(后声明的优先)
// 未分层 > 所有层
函数 CascadeLayer_比较优先级(层a, 层b) {
    如果 (层a == 0 && 层b == 0) { 返回 0 }
    如果 (层a == 0) { 返回 1 }     // 未分层 > 有层
    如果 (层b == 0) { 返回 -1 }
    返回 层a.顺序 - 层b.顺序
}

定义 可变 AI_图层管理获_帧率窗口 = []

函数 AI_图层管理获_帧率预测(当前帧耗时) {
    追加(AI_图层管理获_帧率窗口, 当前帧耗时)
    如果 (计数(AI_图层管理获_帧率窗口) > 30) { 列表_移除(AI_图层管理获_帧率窗口, 0) }
    如果 (计数(AI_图层管理获_帧率窗口) < 3) { 返回 60 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(AI_图层管理获_帧率窗口)) { 总 = 总 + AI_图层管理获_帧率窗口[i]; i = i + 1 }
    定义 平均帧耗时 = 总 / 计数(AI_图层管理获_帧率窗口)
    如果 (平均帧耗时 == 0) { 返回 60 }
    返回 1000 / 平均帧耗时
}

函数 AI_图层管理获_质量降级建议(帧率) {
    如果 (帧率 < 30) { 返回 "降低分辨率" }
    如果 (帧率 < 45) { 返回 "跳过阴影" }
    返回 "全质量"
}

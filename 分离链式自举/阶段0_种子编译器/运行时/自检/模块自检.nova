// 编译器项目系统: 渲染合同+媒体合同Profile验证
函数 自检_项目合同() {
    定义 基数 = _自检_通过
    打印("[自检] 项目合同(引擎/媒体)...")

    // --- 编译器侧引擎合同Profile ---
    定义 ec1 = 引擎合同_从Profile("kernel-qemu")
    自检_断言值("qemu引擎步长=33", 引擎合同_物理步长(ec1), 33)
    定义 ec2 = 引擎合同_从Profile("linux-user")
    自检_断言值("user引擎步长=16", 引擎合同_物理步长(ec2), 16)

    // 引擎结构化报告
    引擎合同_验证([])
    定义 esr = 引擎合同_结构化报告()
    自检_断言("引擎结构化报告!=空", esr != 空)

    // --- 编译器侧媒体合同Profile ---
    定义 mc1 = 媒体合同_从Profile("kernel-qemu")
    自检_断言值("内核媒体=PCM", 媒体合同_格式(mc1), 媒体格式_PCM)
    定义 mc2 = 媒体合同_从Profile("linux-user")
    自检_断言值("用户媒体=H264", 媒体合同_格式(mc2), 媒体格式_H264)

    // --- 管线阶段CRUD ---
    定义 阶段_解码 = 管线阶段_创建("vertex", 阶段_顶点, 3, 4, 假)
    自检_断言值("管线阶段名", 阶段_解码[0], "vertex")
    自检_断言值("管线阶段类型=顶点", 阶段_解码[1], 阶段_顶点)

    // --- 管线阶段常量 ---
    自检_断言值("阶段顶点=0",  阶段_顶点, 0)
    自检_断言值("阶段片段=1", 阶段_片段, 1)
    自检_断言值("阶段几何=2", 阶段_几何, 2)
    自检_断言值("阶段曲面=3", 阶段_曲面细分, 3)
    自检_断言值("阶段计算=4", 阶段_计算, 4)

    打印文本(字符串拼接("[自检] 项目合同: ", 字符串拼接(转字符串(_自检_通过 - 基数), 字符串拼接("/", 字符串拼接(转字符串(_自检_总数 - 基数 - (_自检_失败)), " 通过")))))
}

// 总入口: 运行全部自检
函数 运行全部自检() {
    _自检_通过 = 0
    _自检_失败 = 0
    _自检_总数 = 0

    打印("═══════════════════════════════════════")
    打印("  Nova 运行时模块自检 (L3级证据)")
    打印("═══════════════════════════════════════")

    自检_代码生成()
    自检_M7_语义()
    自检_M8_ABI()
    自检_M9_内存()
    自检_M10_JIT()
    自检_M11_安全()
    自检_M12_渲染()
    自检_M13_音频()
    自检_M14_引擎()
    自检_M15_宿主()
    自检_M16_AI()
    自检_C1_热更新()
    自检_跨语言()

    打印("═══════════════════════════════════════")
    打印文本(字符串拼接("  总计: ", 字符串拼接(转字符串(_自检_通过), 字符串拼接("/", 字符串拼接(转字符串(_自检_总数), 字符串拼接(" 通过, ", 字符串拼接(转字符串(_自检_失败), " 失败")))))))
    如果 (_自检_失败 == 0) {
        打印("  ✓ 全部自检通过")
    } 否则 {
        打印文本(字符串拼接("  ✗ ", 字符串拼接(转字符串(_自检_失败), " 项失败")))
    }
    打印("═══════════════════════════════════════")
}

导入("../基础.nova")
导入("../算法/数学扩展.nova")


// 余弦相似度
函数 对比_余弦(a, b) { 定义 n = 计数(a)
 定义 可变 点积 = 0
 定义 可变 范数a = 0
 定义 可变 范数b = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (i < 计数(b)) {
 点积 = 点积 + a[i] * b[i] / 1000
 范数a = 范数a + a[i] * a[i] / 1000
 范数b = 范数b + b[i] * b[i] / 1000
 }
 i = i + 1
 }
 定义 分母 = 整数sqrt(范数a) * 整数sqrt(范数b) / 1000
 如果 (分母 == 0) { 返回 0 }
 返回 点积 * 1000 / 分母
}

// L2归一化
函数 对比_L2归一化(向量) { 定义 n = 计数(向量)
 定义 可变 范数 = 0
 定义 可变 i = 0
 当 (i < n) { 范数 = 范数 + 向量[i] * 向量[i] / 1000
 i = i + 1 }
 范数 = 整数sqrt(范数 * 1000)
 如果 (范数 == 0) { 返回 向量 }
 定义 可变 结果 = []
 i = 0
 当 (i < n) { 追加(结果, 向量[i] * 1000 / 范数)
 i = i + 1 }
 返回 结果
}

// 信息噪声对比 损失
// L = -log(exp(相似度(q,k+)/τ) / Σ_i exp(相似度(q,k_i)/τ))
函数 信息噪声对比(查询, 正键, 负键列表, τ) { 如果 (τ <= 0) { τ = 70 } // 0.07×1000
 定义 正相似 = 对比_余弦(查询, 正键) * 1000 / τ
 定义 可变 正exp = 1000 + 正相似 // exp近似
 如果 (正exp < 1) { 正exp = 1 }
 定义 可变 总exp = 正exp
 定义 可变 i = 0
 当 (i < 计数(负键列表)) { 定义 负相似 = 对比_余弦(查询, 负键列表[i]) * 1000 / τ
 定义 可变 负exp = 1000 + 负相似
 如果 (负exp < 1) { 负exp = 1 }
 总exp = 总exp + 负exp
 i = i + 1
 }
 如果 (总exp == 0) { 总exp = 1 }
 // -log(正exp/总exp) ≈ log(总exp) - log(正exp)
 定义 损失值 = 总exp * 1000 / 正exp
 返回 损失值
}

// NT-Xent (SimCLR)
// 批内所有对的对比损失
函数 归一温度交叉熵(嵌入列表, batch_size, τ) { 如果 (τ <= 0) { τ = 500 } // 0.5×1000
    定义 可变 总损失 = 0
 定义 N = batch_size * 2 // 2个视图
 定义 可变 i = 0
 当 (i < batch_size) {
 // 正对: (i, i+batch_size)
 定义 正相似 = 对比_余弦(嵌入列表[i], 嵌入列表[i + batch_size]) * 1000 / τ
 定义 可变 正exp = 1000 + 正相似
 如果 (正exp < 1) { 正exp = 1 }
 定义 可变 总exp = 0
 定义 可变 j = 0
 当 (j < N) { 如果 (j != i) { 定义 相似度 = 对比_余弦(嵌入列表[i], 嵌入列表[j]) * 1000 / τ
 定义 可变 e = 1000 + 相似度
 如果 (e < 1) { e = 1 }
 总exp = 总exp + e
 }
 j = j + 1
 }
 如果 (总exp == 0) { 总exp = 1 }
 总损失 = 总损失 + 总exp * 1000 / 正exp
 i = i + 1
 }
 如果 (batch_size == 0) { 返回 0 }
 返回 总损失 / batch_size
}

// CLIP: 文本-图像对齐
函数 CLIP_损失(图像嵌入列表, 文本嵌入列表, τ) {
    如果 (τ <= 0) { τ = 70
}
 定义 N = 计数(图像嵌入列表)
 定义 可变 损失 = 0
 // 图像→文本方向
 定义 可变 i = 0
 当 (i < N) { 定义 正sim = 对比_余弦(图像嵌入列表[i], 文本嵌入列表[i]) * 1000 / τ
 定义 可变 正e = 1000 + 正sim
 如果 (正e < 1) { 正e = 1 }
 定义 可变 总e = 0
 定义 可变 j = 0
 当 (j < N) { 定义 相似度 = 对比_余弦(图像嵌入列表[i], 文本嵌入列表[j]) * 1000 / τ
 定义 可变 e = 1000 + 相似度
 如果 (e < 1) { e = 1 }
 总e = 总e + e
 j = j + 1
 }
 如果 (总e == 0) { 总e = 1 }
 损失 = 损失 + 总e * 1000 / 正e
 i = i + 1
 }
 // 文本→图像方向
 i = 0
 当 (i < N) { 定义 正sim = 对比_余弦(文本嵌入列表[i], 图像嵌入列表[i]) * 1000 / τ
 定义 可变 正e = 1000 + 正sim
 如果 (正e < 1) { 正e = 1 }
 定义 可变 总e = 0
 定义 可变 j = 0
 当 (j < N) { 定义 相似度 = 对比_余弦(文本嵌入列表[i], 图像嵌入列表[j]) * 1000 / τ
 定义 可变 e = 1000 + 相似度
 如果 (e < 1) { e = 1 }
 总e = 总e + e
 j = j + 1
 }
 如果 (总e == 0) { 总e = 1 }
 损失 = 损失 + 总e * 1000 / 正e
 i = i + 1
 }
 返回 损失 / (N * 2)
}

// MoCo: 动量对比
// 动量编码器更新: θ_k = m·θ_k + (1-m)·θ_q
函数 MoCo_动量更新(编码器参数, 动量编码器参数, m) { 定义 n = 计数(编码器参数)
 定义 可变 i = 0
 当 (i < n) {
 动量编码器参数[i] = m * 动量编码器参数[i] / 1000 + (1000 - m) * 编码器参数[i] / 1000
 i = i + 1
 }
}

// 队列管理 (FIFO)
函数 MoCo_队列_创建(大小) { 返回 [[], 大小, 0] }

函数 MoCo_入队(队列, 键) { 如果 (计数(队列[0]) >= 队列[1]) {
    定义 可变 新列表 = []
 // 出队最旧的
 定义 可变 i = 1
 当 (i < 计数(队列[0])) { 追加(新列表, 队列[0][i])
 i = i + 1 }
 队列[0] = 新列表
 }
 追加(队列[0], 键)
}

// BYOL: 无负样本对比
函数 BYOL_损失(在线投影, 目标投影) { 定义 在线_归一 = 对比_L2归一化(在线投影)
 定义 目标_归一 = 对比_L2归一化(目标投影)
 定义 相似度 = 对比_余弦(在线_归一, 目标_归一)
 返回 2000 - 2 * 相似度 // 2 - 2·cos_sim
}

// Barlow Twins: 冗余消除
函数 BarlowTwins_交叉相关(嵌入A列表, 嵌入B列表, 维度) { 定义 N = 计数(嵌入A列表)
 如果 (N == 0) { 返回 [] }
 // 计算交叉相关矩阵 C[i][j] = Σ_n z_A^n_i · z_B^n_j / N
 定义 可变 C = []
 定义 可变 i = 0
 当 (i < 维度) { 定义 可变 行 = []
 定义 可变 j = 0
 当 (j < 维度) { 定义 可变 数值 = 0
 定义 可变 n = 0
 当 (n < N) { 如果 (i < 计数(嵌入A列表[n]) 且 j < 计数(嵌入B列表[n])) {
 数值 = 数值 + 嵌入A列表[n][i] * 嵌入B列表[n][j] / 1000
 }
 n = n + 1
 }
 追加(行, 数值 / N)
 j = j + 1
 }
 追加(C, 行)
 i = i + 1
 }
 返回 C
}

函数 BarlowTwins_损失(C, 维度, λ) { 如果 (λ <= 0) { λ = 5 } // 0.005×1000
 定义 可变 损失 = 0
 定义 可变 i = 0
 当 (i < 维度) { 定义 可变 j = 0
 当 (j < 维度) { 如果 (i == j) {
 // (1 - C_ii)²
 定义 差值 = 1000 - C[i][j]
 损失 = 损失 + 差值 * 差值 / 1000
 } 否则 {
 // λ · C_ij²
 损失 = 损失 + λ * C[i][j] * C[i][j] / (1000 * 1000)
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 损失
}

// VICReg: 方差-不变性-协方差正则化
函数 VICReg_方差损失(嵌入列表, 维度) { 定义 N = 计数(嵌入列表)
 如果 (N <= 1) { 返回 0 }
 定义 可变 损失 = 0
 定义 可变 d = 0
 当 (d < 维度) {
 // 计算该维度的方差
 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < N) { 如果 (d < 计数(嵌入列表[i])) { 和 = 和 + 嵌入列表[i][d] }
 i = i + 1
 }
 定义 均值 = 和 / N
 定义 可变 方差 = 0
 i = 0
 当 (i < N) { 定义 可变 v = 0
 如果 (d < 计数(嵌入列表[i])) { v = 嵌入列表[i][d] }
 定义 差值 = v - 均值
 方差 = 方差 + 差值 * 差值 / 1000
 i = i + 1
 }
 如果 (N == 0) { 返回 0 }
 方差 = 方差 / N
 // hinge: max(0, γ - √var) γ=1000
 定义 标准差 = 整数sqrt(方差 * 1000)
 定义 可变 铰链 = 1000 - 标准差
 如果 (铰链 < 0) { 铰链 = 0 }
 损失 = 损失 + 铰链
 d = d + 1
 }
 如果 (维度 == 0) { 返回 0 }
 返回 损失 / 维度
}

// 投影头 (MLP)
函数 投影头_前向(输入, W1, b1, W2, b2, 隐藏维度, 输出维度, 输入维度) {
 // 层1: 线性整流(W1·x + b1)
 定义 可变 隐藏 = []
 定义 可变 i = 0
 当 (i < 隐藏维度) { 定义 可变 数值 = b1[i]
 定义 可变 j = 0
 当 (j < 输入维度) {
 数值 = 数值 + W1[i * 输入维度 + j] * 输入[j] / 1000
 j = j + 1
 }
 如果 (数值 < 0) { 数值 = 0 }
 追加(隐藏, 数值)
 i = i + 1
 }
 // 层2: W2·h + b2
 定义 可变 输出 = []
 i = 0
 当 (i < 输出维度) { 定义 可变 数值 = b2[i]
 定义 可变 j = 0
 当 (j < 隐藏维度) {
 数值 = 数值 + W2[i * 隐藏维度 + j] * 隐藏[j] / 1000
 j = j + 1
 }
 追加(输出, 数值)
 i = i + 1
 }
 返回 输出
}

// 硬负样本挖掘
函数 硬负样本_选择(锚点, 候选列表, k) {
 // 选择最相似的k个负样本(最难区分的)
 定义 n = 计数(候选列表)
 定义 可变 相似度 = []
 定义 可变 索引 = []
 定义 可变 i = 0
 当 (i < n) {
 追加(相似度, 对比_余弦(锚点, 候选列表[i]))
 追加(索引, i)
 i = i + 1
 }
 // 按相似度降序排序取前k
 i = 0
 当 (i < k 且 i < n) { 定义 可变 最大idx = i
 定义 可变 j = i + 1
 当 (j < n) { 如果 (相似度[索引[j]] > 相似度[索引[最大idx]]) { 最大idx = j }
 j = j + 1
 }
 如果 (最大idx != i) { 定义 临时 = 索引[i]
 索引[i] = 索引[最大idx]
 索引[最大idx] = 临时
 }
 i = i + 1
 }
 定义 可变 选中 = []
 i = 0
 当 (i < k 且 i < n) { 追加(选中, 候选列表[索引[i]])
 i = i + 1 }
 返回 选中
}

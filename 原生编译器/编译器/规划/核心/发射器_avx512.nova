函数 发射_avx512_cvtdq2ps(d, s) {
    发射_evex(1,  1,  1,  1,  2, 0 , 0 ,  1, 0 ,  1, 0, 0, 0, 0)
    发射(0x5B) 发射(0xC0 + (d & 7) * 8 + (s & 7))
}

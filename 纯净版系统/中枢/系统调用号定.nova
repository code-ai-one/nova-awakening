// §6 NSCI诊断与统一初始化

函数 NSCI_初始化() {
    内核打印("[NSCI] Nova系统调用智能分发 启动")
    系统调用表_初始化()
    // 注册所有类别
    系统调用_注册定时器类()
    系统调用_注册文件高级类()
    系统调用_注册进程高级类()
    系统调用_注册内存高级类()
    系统调用_注册网络高级类()
    系统调用_注册安全类()
    系统调用_注册Nova原创类()
    // 清理统计
    NSCI全局统计.总调用次数 = 0
    NSCI全局统计.安全拦截次数 = 0
    NSCI全局统计.AI推理次数 = 0
    NSCI全局统计.未知调用次数 = 0
    NSCI全局统计.错误次数 = 0
    NSCI全局统计.最大耗时_us = 0
    NSCI全局统计.总耗时_us = 0
    内核打印("[NSCI] 初始化完成 — 定时器/文件/进程/内存/网络/安全/Nova原创 已注册")
}

函数 NSCI_打印诊断() {
    内核打印("╔════════════════════════════════════════════╗")
    内核打印("║  NSCI 系统调用智能分发 诊断报告          ║")
    内核打印("╠════════════════════════════════════════════╣")
    内核打印("║ 总调用:       {}", NSCI全局统计.总调用次数)
    内核打印("║ 安全拦截:     {}", NSCI全局统计.安全拦截次数)
    内核打印("║ AI推理:       {}", NSCI全局统计.AI推理次数)
    内核打印("║ 未知调用:     {}", NSCI全局统计.未知调用次数)
    内核打印("║ 错误次数:     {}", NSCI全局统计.错误次数)
    内核打印("║ 最大耗时:     {}μs", NSCI全局统计.最大耗时_us)
    内核打印("║ 总耗时:       {}μs", NSCI全局统计.总耗时_us)
    内核打印("╚════════════════════════════════════════════╝")
}

// §7 系统调用热点追踪 (Hotspot Tracking)

函数 NSCI_获取热点调用(结果数组, 最大数) {
    // 查找调用次数最多的前N个系统调用
    如果 (调用计数器 == 空 || 结果数组 == 0) { 返回 0 }
    定义 可变 已找 = 0
    定义 可变 round = 0
    当 (round < 最大数 && round < 10) {
        定义 可变 最大值 = 0
        定义 可变 最大号 = -1
        定义 可变 i = 0
        当 (i < 最大系统调用号) {
            定义 cnt = 内存_读64(调用计数器 + i * 8)
            如果 (cnt > 最大值) {
                // 检查是否已在结果中
                定义 可变 已有 = 假
                定义 可变 j = 0
                当 (j < 已找) {
                    如果 (内存_读64(结果数组 + j * 8) == i) { 已有 = 真 }
                    j = j + 1
                }
                如果 (已有 == 假) {
                    最大值 = cnt
                    最大号 = i
                }
            }
            i = i + 1
        }
        如果 (最大号 >= 0) {
            内存_写64(结果数组 + 已找 * 8, 最大号)
            已找 = 已找 + 1
        }
        round = round + 1
    }
    返回 已找
}

函数 NSCI_获取调用计数(调用号) {
    如果 (调用计数器 == 空 || 调用号 >= 最大系统调用号) { 返回 0 }
    返回 内存_读64(调用计数器 + 调用号 * 8)
}

函数 NSCI_获取调用耗时(调用号) {
    如果 (调用耗时表 == 空 || 调用号 >= 最大系统调用号) { 返回 0 }
    返回 内存_读64(调用耗时表 + 调用号 * 8)
}

// §10 【原生独创】谐振系统调用频率分析器
// 统计高频系统调用并优化分发路径

定义 可变 _谐振调用_热表 = []
定义 可变 _谐振调用_分析次数 = 0

函数 谐振调用_记录(调用号) {
    定义 可变 i = 0
    当 (i < 计数(_谐振调用_热表)) {
        如果 (_谐振调用_热表[i].号 == 调用号) {
            _谐振调用_热表[i].次数 = _谐振调用_热表[i].次数 + 1
            返回
        }
        i = i + 1
    }
    追加(_谐振调用_热表, { 号: 调用号, 次数: 1 })
}

函数 谐振调用_最热(前N) {
    _谐振调用_分析次数 = _谐振调用_分析次数 + 1
    // 选择排序取前N
    定义 可变 结果 = []
    定义 可变 k = 0
    当 (k < 前N && k < 计数(_谐振调用_热表)) {
        定义 可变 最大idx = k
        定义 可变 j = k + 1
        当 (j < 计数(_谐振调用_热表)) {
            如果 (_谐振调用_热表[j].次数 > _谐振调用_热表[最大idx].次数) { 最大idx = j }
            j = j + 1
        }
        如果 (最大idx != k) {
            定义 临时 = _谐振调用_热表[k]
            _谐振调用_热表[k] = _谐振调用_热表[最大idx]
            _谐振调用_热表[最大idx] = 临时
        }
        追加(结果, _谐振调用_热表[k])
        k = k + 1
    }
    返回 结果
}

函数 系统调用号_完整统计() {
    返回 [
        "最大系统调用号", 最大系统调用号,
        "热表条目数", 计数(_谐振调用_热表),
        "分析次数", _谐振调用_分析次数
    ]
}

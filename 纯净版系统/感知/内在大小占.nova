// 当size containment生效且无显式宽高时使用

结构 ContainIntrinsicSize {
    宽,    // i32 ×100, -1=none
    高,
    宽_auto,    // 布尔 auto 300px (记住上次渲染大小)
    高_auto,
    上次渲染宽,    // i32 上次实际渲染的大小(auto模式)
    上次渲染高,
}


函数 ContainIntrinsicSize_解析(值字符串) {
    定义 cis = ContainIntrinsicSize {}
    cis.宽 = -1; cis.高 = -1
    cis.宽_auto = 假; cis.高_auto = 假
    cis.上次渲染宽 = -1; cis.上次渲染高 = -1

    如果 (值字符串 == 0 || 字符串_相等(值字符串, "none")) { 返回 cis }

    // 解析: "300px 200px" 或 "auto 300px" 或 "auto 300px auto 200px"
    // 处理contain属性的布局/绘制/大小限制
    如果 (字符串_开头匹配(值字符串, "auto")) {
        cis.宽_auto = 真; cis.高_auto = 真
    }

    返回 cis
}

函数 ContainIntrinsicSize_获取宽(cis) {
    如果 (cis.宽_auto && cis.上次渲染宽 > 0) {
        返回 cis.上次渲染宽
    }
    返回 cis.宽
}

函数 ContainIntrinsicSize_获取高(cis) {
    如果 (cis.高_auto && cis.上次渲染高 > 0) {
        返回 cis.上次渲染高
    }
    返回 cis.高
}

// §5 content-visibility: auto — 视口驱动的渲染跳过
// (对应 DisplayLockContext)

定义 LOCK_STATE_UNLOCKED       = 0    // 正常渲染
定义 LOCK_STATE_LOCKED         = 1    // 跳过渲染
定义 LOCK_STATE_COMMIT_PENDING = 2    // 即将解锁

结构 DisplayLockContext {
    元素,    // u64 元素*
    锁状态,    // u32 LOCK_STATE_xxx
    content_visibility,    // u32 CV_xxx
    // IntersectionObserver检测
    在视口中,
    上次检查时间,
    // 尺寸
    intrinsic_size,    // u64 ContainIntrinsicSize*
    // 计数
    跳过渲染次数,
    // 子树状态
    子树需要布局,
    子树需要绘制,
}

函数 DisplayLock_创建(元素, cv值) {
    定义 dl = 堆_分配(DisplayLockContext)
    dl.元素 = 元素
    dl.content_visibility = cv值
    dl.在视口中 = 假
    dl.上次检查时间 = 0
    dl.跳过渲染次数 = 0
    dl.子树需要布局 = 真
    dl.子树需要绘制 = 真

    如果 (cv值 == CV_HIDDEN) {
        dl.锁状态 = LOCK_STATE_LOCKED
    } 否则 如果 (cv值 == CV_AUTO) {
        dl.锁状态 = LOCK_STATE_LOCKED    // 初始锁定,等待视口检测
    } 否则 {
        dl.锁状态 = LOCK_STATE_UNLOCKED
    }

    返回 dl
}

函数 DisplayLock_更新视口状态(dl, 在视口中) {
    如果 (dl == 0) { 返回 }
    如果 (dl.content_visibility != CV_AUTO) { 返回 }

    定义 之前 = dl.在视口中
    dl.在视口中 = 在视口中

    如果 (!之前 && 在视口中) {
        // 进入视口: 解锁渲染
        dl.锁状态 = LOCK_STATE_COMMIT_PENDING
        dl.子树需要布局 = 真
        dl.子树需要绘制 = 真
    }
    否则 如果 (之前 && !在视口中) {
        // 离开视口: 锁定(保存上次渲染大小)
        DisplayLock_保存渲染大小(dl)
        dl.锁状态 = LOCK_STATE_LOCKED
        dl.跳过渲染次数 = dl.跳过渲染次数 + 1
    }
}

函数 DisplayLock_保存渲染大小(dl) {
    如果 (dl == 0 || dl.intrinsic_size == 0) { 返回 }
    // 保存当前实际大小(供下次auto时使用)
    如果 (dl.元素 != 0) {
        定义 布局 = dl.元素.布局对象
        如果 (布局 != 0) {
            dl.intrinsic_size.上次渲染宽 = 布局.宽
            dl.intrinsic_size.上次渲染高 = 布局.高
        }
    }
}

函数 DisplayLock_应该跳过布局(dl) {
    如果 (dl == 0) { 返回 假 }
    返回 dl.锁状态 == LOCK_STATE_LOCKED
}

函数 DisplayLock_应该跳过绘制(dl) {
    如果 (dl == 0) { 返回 假 }
    返回 dl.锁状态 == LOCK_STATE_LOCKED
}

函数 DisplayLock_commit(dl) {
    如果 (dl == 0) { 返回 }
    如果 (dl.锁状态 == LOCK_STATE_COMMIT_PENDING) {
        dl.锁状态 = LOCK_STATE_UNLOCKED
    }
}

// §6 CSS contain属性

定义 CONTAIN_NONE = 0
定义 CONTAIN_LAYOUT = 1
定义 CONTAIN_PAINT = 2
定义 CONTAIN_SIZE = 4
定义 CONTAIN_STYLE = 8
定义 CONTAIN_STRICT = CONTAIN_LAYOUT | CONTAIN_PAINT | CONTAIN_SIZE | CONTAIN_STYLE
定义 CONTAIN_CONTENT = CONTAIN_LAYOUT | CONTAIN_PAINT | CONTAIN_STYLE

定义 CV_VISIBLE = 0
定义 CV_HIDDEN = 1
定义 CV_AUTO = 2

函数 Contain_解析(值字符串) {
    如果 (值字符串 == 0 || 字符串_相等(值字符串, "none")) { 返回 CONTAIN_NONE }
    如果 (字符串_相等(值字符串, "strict")) { 返回 CONTAIN_STRICT }
    如果 (字符串_相等(值字符串, "content")) { 返回 CONTAIN_CONTENT }
    定义 可变 结果 = 0
    如果 (字符串_包含(值字符串, "layout")) { 结果 = 结果 | CONTAIN_LAYOUT }
    如果 (字符串_包含(值字符串, "paint")) { 结果 = 结果 | CONTAIN_PAINT }
    如果 (字符串_包含(值字符串, "size")) { 结果 = 结果 | CONTAIN_SIZE }
    如果 (字符串_包含(值字符串, "style")) { 结果 = 结果 | CONTAIN_STYLE }
    返回 结果
}

函数 Contain_名称(contain) {
    如果 (contain == CONTAIN_NONE) { 返回 "none" }
    如果 (contain == CONTAIN_STRICT) { 返回 "strict" }
    如果 (contain == CONTAIN_CONTENT) { 返回 "content" }
    定义 可变 s = ""
    如果 (contain & CONTAIN_LAYOUT) { s = s + "layout " }
    如果 (contain & CONTAIN_PAINT) { s = s + "paint " }
    如果 (contain & CONTAIN_SIZE) { s = s + "size " }
    如果 (contain & CONTAIN_STYLE) { s = s + "style " }
    返回 s
}

函数 Contain_有布局(contain) { 返回 (contain & CONTAIN_LAYOUT) != 0 }
函数 Contain_有绘制(contain) { 返回 (contain & CONTAIN_PAINT) != 0 }
函数 Contain_有大小(contain) { 返回 (contain & CONTAIN_SIZE) != 0 }
函数 Contain_有样式(contain) { 返回 (contain & CONTAIN_STYLE) != 0 }

// §7 DisplayLock扩展操作

函数 DisplayLock_获取锁状态名(dl) {
    如果 (dl == 0) { 返回 "null" }
    如果 (dl.锁状态 == LOCK_STATE_UNLOCKED) { 返回 "unlocked" }
    如果 (dl.锁状态 == LOCK_STATE_LOCKED) { 返回 "locked" }
    如果 (dl.锁状态 == LOCK_STATE_COMMIT_PENDING) { 返回 "commit_pending" }
    返回 "unknown"
}

函数 DisplayLock_强制解锁(dl) {
    如果 (dl == 0) { 返回 }
    dl.锁状态 = LOCK_STATE_UNLOCKED
    dl.子树需要布局 = 真
    dl.子树需要绘制 = 真
}

函数 DisplayLock_强制锁定(dl) {
    如果 (dl == 0) { 返回 }
    DisplayLock_保存渲染大小(dl)
    dl.锁状态 = LOCK_STATE_LOCKED
}

函数 DisplayLock_是锁定(dl) {
    如果 (dl == 0) { 返回 假 }
    返回 dl.锁状态 == LOCK_STATE_LOCKED
}

函数 DisplayLock_是解锁(dl) {
    如果 (dl == 0) { 返回 真 }
    返回 dl.锁状态 == LOCK_STATE_UNLOCKED
}

函数 DisplayLock_诊断(dl) {
    如果 (dl == 0) { 返回 "DisplayLock为空" }
    返回 {
        锁状态: DisplayLock_获取锁状态名(dl),
        CV: dl.content_visibility,
        在视口: dl.在视口中,
        跳过次数: dl.跳过渲染次数,
        需要布局: dl.子树需要布局,
        需要绘制: dl.子树需要绘制,
    }
}

// §8 容器查询(Container Queries)

结构 ContainerQuery {
    容器名,
    条件类型,
    条件值,
    规则列表,
    规则数,
}

定义 CQ_MIN_WIDTH = 0
定义 CQ_MAX_WIDTH = 1
定义 CQ_MIN_HEIGHT = 2
定义 CQ_MAX_HEIGHT = 3

函数 ContainerQuery_创建(容器名, 条件类型, 条件值) {
    定义 cq = ContainerQuery {}
    cq.容器名 = 容器名
    cq.条件类型 = 条件类型
    cq.条件值 = 条件值
    cq.规则列表 = []
    cq.规则数 = 0
    返回 cq
}

函数 ContainerQuery_匹配(cq, 容器宽, 容器高) {
    如果 (cq == 0) { 返回 假 }
    如果 (cq.条件类型 == CQ_MIN_WIDTH) { 返回 容器宽 >= cq.条件值 }
    如果 (cq.条件类型 == CQ_MAX_WIDTH) { 返回 容器宽 <= cq.条件值 }
    如果 (cq.条件类型 == CQ_MIN_HEIGHT) { 返回 容器高 >= cq.条件值 }
    如果 (cq.条件类型 == CQ_MAX_HEIGHT) { 返回 容器高 <= cq.条件值 }
    返回 假
}

函数 CQ_条件名(类型) {
    如果 (类型 == CQ_MIN_WIDTH) { 返回 "min-width" }
    如果 (类型 == CQ_MAX_WIDTH) { 返回 "max-width" }
    如果 (类型 == CQ_MIN_HEIGHT) { 返回 "min-height" }
    如果 (类型 == CQ_MAX_HEIGHT) { 返回 "max-height" }
    返回 "unknown"
}

// §9 容器统计与健康检查

定义 可变 容器_锁定总数 = 0
定义 可变 容器_解锁总数 = 0
定义 可变 容器_跳过渲染总数 = 0
定义 可变 容器_查询匹配数 = 0

函数 容器_统计() {
    返回 {
        锁定: 容器_锁定总数,
        解锁: 容器_解锁总数,
        跳过渲染: 容器_跳过渲染总数,
        查询匹配: 容器_查询匹配数,
    }
}

函数 容器_健康检查() {
    定义 可变 问题 = []
    如果 (容器_跳过渲染总数 > 容器_锁定总数 * 100 && 容器_锁定总数 > 10) {
        追加(问题, "渲染跳过过于频繁")
    }
    如果 (计数(问题) == 0) { 返回 "容器子系统健康" }
    返回 问题
}

函数 容器_重置统计() {
    容器_锁定总数 = 0
    容器_解锁总数 = 0
    容器_跳过渲染总数 = 0
    容器_查询匹配数 = 0
}

函数 容器_完整统计() {
    返回 [容器_锁定总数, 容器_解锁总数, 容器_跳过渲染总数, 容器_查询匹配数]
}

// §3 弹性布局主函数 — §9 弹性 布局 Algorithm

函数 弹性布局_布局(容器) {
    如果 (容器 == 0 || 容器.项目数 == 0) { 返回 }

    // §9.1 初始设置
    弹性布局_解析基准(容器)

    // §9.2 行确定
    弹性布局_确定行(容器)

    // §9.3 主轴尺寸: 弹性调整
    定义 可变 i = 0
    当 (i < 容器.行数) {
        定义 行 = 弹性布局_获取行(容器, i)
        弹性布局_弹性调整(容器, 行)
        i = i + 1
    }

    // §9.4 交叉轴尺寸
    弹性布局_计算交叉轴(容器)

    // §9.5 主轴对齐 (justify-content)
    i = 0
    当 (i < 容器.行数) {
        定义 行 = 弹性布局_获取行(容器, i)
        弹性布局_主轴对齐(容器, 行)
        i = i + 1
    }

    // §9.6 交叉轴对齐 (align-items, align-content)
    弹性布局_交叉轴对齐(容器)

    // 写回最终位置到布局Object
    弹性布局_写回位置(容器)
}

// §4 §9.1 初始设置 — 解析flex-basis

函数 弹性布局_解析基准(容器) {
    定义 是行方向 = 容器.方向 == FLEX_DIR_ROW || 容器.方向 == FLEX_DIR_ROW_REVERSE

    定义 可变 i = 0
    当 (i < 容器.项目数) {
        定义 项 = 弹性布局_获取项(容器, i)
        如果 (项.flex_basis < 0) {
            // auto: 使用项目的固有主轴尺寸
            如果 (项.布局对象 != 0) {
                如果 (是行方向) {
                    项.基准尺寸 = 项.布局对象.宽度
                } 否则 {
                    项.基准尺寸 = 项.布局对象.高度
                }
            } 否则 {
                项.基准尺寸 = 0
            }
        } 否则 {
            项.基准尺寸 = 项.flex_basis
        }
        // 加上margin
        项.外部主轴尺寸 = 项.基准尺寸 + 项.主轴margin前 + 项.主轴margin后
        项.假设主尺寸 = 项.基准尺寸
        项.已冻结 = 假
        i = i + 1
    }
}

// §5 §9.2 行确定

函数 弹性布局_确定行(容器) {
    如果 (容器.换行 == FLEX_WRAP_NOWRAP) {
        // 单行: 所有项目在一行
        容器.行数 = 1
        容器.行 = 堆_分配_数组(大小of(弹性Line))
        定义 行 = 容器.行
        行.起始索引 = 0; 行.结束索引 = 容器.项目数
        行.主轴已用 = 弹性布局_计算行主轴总和(容器, 0, 容器.项目数)
        行.剩余空间 = 容器.可用主轴 - 行.主轴已用
        返回
    }

    // 多行: flex-wrap
    定义 行容量 = 16
    容器.行 = 堆_分配_数组(行容量 * 大小of(弹性Line))
    容器.行数 = 0

    定义 可变 行开始 = 0
    定义 可变 当前主轴用量 = 0
    定义 间距 = 容器.列间距

    定义 可变 i = 0
    当 (i < 容器.项目数) {
        定义 项 = 弹性布局_获取项(容器, i)
        定义 新用量 = 当前主轴用量 + 项.外部主轴尺寸
        如果 (i > 行开始) { 新用量 = 新用量 + 间距 }

        如果 (新用量 > 容器.可用主轴 && i > 行开始) {
            // 换行
            弹性布局_添加行(容器, 行开始, i, 当前主轴用量)
            行开始 = i; 当前主轴用量 = 项.外部主轴尺寸
        } 否则 {
            当前主轴用量 = 新用量
        }
        i = i + 1
    }
    // 最后一行
    如果 (行开始 < 容器.项目数) {
        弹性布局_添加行(容器, 行开始, 容器.项目数, 当前主轴用量)
    }
}

函数 弹性布局_添加行(容器, 起始, 结束, 主轴用量) {
    如果 (容器.行数 >= 16) { 返回 }
    定义 行 = 容器.行 + 容器.行数 * 大小of(弹性Line)
    行.起始索引 = 起始; 行.结束索引 = 结束
    行.主轴已用 = 主轴用量
    行.剩余空间 = 容器.可用主轴 - 主轴用量
    行.交叉轴尺寸 = 0; 行.交叉轴位置 = 0

    // 统计grow/shrink
    行.总grow = 0; 行.总shrink = 0
    定义 可变 i = 起始
    当 (i < 结束) {
        定义 项 = 弹性布局_获取项(容器, i)
        行.总grow = 行.总grow + 项.flex_grow
        行.总shrink = 行.总shrink + 项.flex_shrink
        i = i + 1
    }

    容器.行数 = 容器.行数 + 1
}

函数 弹性布局_计算行主轴总和(容器, 起始, 结束) {
    定义 可变 总和 = 0
    定义 间距 = 容器.列间距
    定义 可变 i = 起始
    当 (i < 结束) {
        定义 项 = 弹性布局_获取项(容器, i)
        总和 = 总和 + 项.外部主轴尺寸
        如果 (i > 起始) { 总和 = 总和 + 间距 }
        i = i + 1
    }
    返回 总和
}

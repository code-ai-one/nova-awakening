// NovaOS ext4 文件节点属性引擎 — 完整实现
// 职责: inode大小/UID/GID/块数 64位安全读写/文件类型转换/
//       权限位解析/时间戳管理/扩展属性/特殊文件处理/
//       inode校验与修复/AI文件行为分析
// 原创理论: Nova多维度文件元数据感知模型(MFMPM)
//         通过属性向量化+时序足迹+权限图谱三维融合，
//         实现AI级别的文件行为感知与异常检测

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/内核打印.nova")
导入("../推理/值乘.nova")

定义 EXT4_S_IFMT   = 0xF000
定义 EXT4_S_IFREG  = 0x8000
定义 EXT4_S_IFDIR  = 0x4000
定义 EXT4_S_IFLNK  = 0xA000
定义 EXT4_S_IFBLK  = 0x6000
定义 EXT4_S_IFCHR  = 0x2000
定义 EXT4_S_IFIFO  = 0x1000
定义 EXT4_S_IFSOCK = 0xC000

定义 EXT4_S_ISUID = 0x0800  // Set-UID
定义 EXT4_S_ISGID = 0x0400  // Set-GID
定义 EXT4_S_ISVTX = 0x0200  // Sticky位
定义 EXT4_S_IRUSR = 0x0100  // 所有者读
定义 EXT4_S_IWUSR = 0x0080  // 所有者写
定义 EXT4_S_IXUSR = 0x0040  // 所有者执行
定义 EXT4_S_IRGRP = 0x0020  // 组读
定义 EXT4_S_IWGRP = 0x0010  // 组写
定义 EXT4_S_IXGRP = 0x0008  // 组执行
定义 EXT4_S_IROTH = 0x0004  // 其他读
定义 EXT4_S_IWOTH = 0x0002  // 其他写
定义 EXT4_S_IXOTH = 0x0001  // 其他执行

定义 EXT4_SECRM_FL     = 0x00000001  // 安全删除
定义 EXT4_UNRM_FL      = 0x00000002  // 可恢复
定义 EXT4_COMPR_FL     = 0x00000004  // 压缩
定义 EXT4_SYNC_FL      = 0x00000008  // 同步写
定义 EXT4_IMMUTABLE_FL = 0x00000010  // 不可变
定义 EXT4_APPEND_FL    = 0x00000020  // 只追加
定义 EXT4_NODUMP_FL    = 0x00000040  // 不备份
定义 EXT4_NOATIME_FL   = 0x00000080  // 不更新访问时间
定义 EXT4_INDEX_FL     = 0x00001000  // 目录哈希索引
定义 EXT4_EXTENTS_FL   = 0x00080000  // 使用extent树
定义 EXT4_INLINE_FL    = 0x10000000  // 内联数据
定义 EXT4_ENCRYPT_FL   = 0x00000800  // 加密

定义 EXT4_EPOCH_BITS = 2
定义 EXT4_EPOCH_MASK = 0x03
定义 EXT4_NSEC_MASK  = 0x3FFFFFFF  // 30位纳秒

定义 可变 ext4_Nova文件节点读次数 = 0
定义 可变 ext4_Nova文件节点写次数 = 0
定义 可变 ext4_属性读总次数 = 0
定义 可变 ext4_属性写总次数 = 0
定义 可变 ext4_权限检查次数 = 0
定义 可变 ext4_权限拒绝次数 = 0
定义 可变 ext4_校验失败次数 = 0
定义 可变 ext4_AI文件分析次数 = 0
定义 可变 ext4_时间戳读次数 = 0
定义 可变 ext4_扩展属性读次数 = 0

// §1 文件大小读写 (64位安全)

函数 ext4_获取Nova文件节点大小(磁盘in) {
    如果 (磁盘in == 空) { 返回 0 }
    ext4_属性读总次数 = ext4_属性读总次数 + 1
    ext4_Nova文件节点读次数 = ext4_Nova文件节点读次数 + 1
    定义 可变 大小 = 磁盘in.大小_低 & 0xFFFFFFFF
    // 只有普通文件才使用高32位表示>4GB大小
    如果 ((磁盘in.模式 & EXT4_S_IFMT) == EXT4_S_IFREG) {
        大小 = 大小 | ((磁盘in.大小_高 & 0xFFFFFFFF) << 32)
    }
    返回 大小
}

函数 ext4_设置Nova文件节点大小(磁盘in, 大小) {
    如果 (磁盘in == 空) { 返回 }
    ext4_属性写总次数 = ext4_属性写总次数 + 1
    ext4_Nova文件节点写次数 = ext4_Nova文件节点写次数 + 1
    磁盘in.大小_低 = 大小 & 0xFFFFFFFF
    磁盘in.大小_高 = (大小 >> 32) & 0xFFFFFFFF
}

函数 ext4_获取Nova文件节点大小_安全(磁盘in, 最大允许) {
    // 带上界校验的读取
    定义 大小 = ext4_获取Nova文件节点大小(磁盘in)
    如果 (大小 > 最大允许) {
        ext4_校验失败次数 = ext4_校验失败次数 + 1
        返回 最大允许  // 钳住上界
    }
    返回 大小
}

// §2 UID/GID 读写 (32位合成)

函数 ext4_获取Nova文件节点_uid(磁盘in) {
    如果 (磁盘in == 空) { 返回 0 }
    ext4_属性读总次数 = ext4_属性读总次数 + 1
    返回 (磁盘in.uid_低 & 0xFFFF) | ((磁盘in.uid_高 & 0xFFFF) << 16)
}

函数 ext4_设置Nova文件节点_uid(磁盘in, uid) {
    如果 (磁盘in == 空) { 返回 }
    ext4_属性写总次数 = ext4_属性写总次数 + 1
    磁盘in.uid_低 = uid & 0xFFFF
    磁盘in.uid_高 = (uid >> 16) & 0xFFFF
}

函数 ext4_获取Nova文件节点_gid(磁盘in) {
    如果 (磁盘in == 空) { 返回 0 }
    ext4_属性读总次数 = ext4_属性读总次数 + 1
    返回 (磁盘in.gid_低 & 0xFFFF) | ((磁盘in.gid_高 & 0xFFFF) << 16)
}

函数 ext4_设置Nova文件节点_gid(磁盘in, gid) {
    如果 (磁盘in == 空) { 返回 }
    ext4_属性写总次数 = ext4_属性写总次数 + 1
    磁盘in.gid_低 = gid & 0xFFFF
    磁盘in.gid_高 = (gid >> 16) & 0xFFFF
}

// §3 块数读写 (64位)

函数 ext4_获取Nova文件节点块数(磁盘in) {
    如果 (磁盘in == 空) { 返回 0 }
    ext4_属性读总次数 = ext4_属性读总次数 + 1
    定义 可变 块数 = 磁盘in.块数_低 & 0xFFFFFFFF
    块数 = 块数 | ((磁盘in.块数_高 & 0xFFFF) << 32)
    返回 块数
}

函数 ext4_设置Nova文件节点块数(磁盘in, 块数) {
    如果 (磁盘in == 空) { 返回 }
    ext4_属性写总次数 = ext4_属性写总次数 + 1
    磁盘in.块数_低 = 块数 & 0xFFFFFFFF
    磁盘in.块数_高 = (块数 >> 32) & 0xFFFF
}

// §4 链接数读写

函数 ext4_获取链接数(磁盘in) {
    如果 (磁盘in == 空) { 返回 0 }
    返回 磁盘in.链接数 & 0xFFFF
}

函数 ext4_设置链接数(磁盘in, 链接数) {
    如果 (磁盘in == 空) { 返回 }
    磁盘in.链接数 = 链接数 & 0xFFFF
}

函数 ext4_增加链接数(磁盘in) {
    如果 (磁盘in == 空) { 返回 错误码_无效参数 }
    定义 当前 = ext4_获取链接数(磁盘in)
    如果 (当前 >= 0xFFFF) {
        返回 错误码_超出范围  // 链接数溢出
    }
    ext4_设置链接数(磁盘in, 当前 + 1)
    返回 0
}

函数 ext4_减少链接数(磁盘in) {
    如果 (磁盘in == 空) { 返回 错误码_无效参数 }
    定义 当前 = ext4_获取链接数(磁盘in)
    如果 (当前 == 0) {
        ext4_校验失败次数 = ext4_校验失败次数 + 1
        返回 错误码_数据损坏  // 不应发生
    }
    ext4_设置链接数(磁盘in, 当前 - 1)
    返回 0
}

// §5 文件类型转换

函数 ext4_模式转类型(模式) {
    匹配 (模式 & EXT4_S_IFMT) {
        EXT4_S_IFREG  => 返回 文件类型_普通
        EXT4_S_IFDIR  => 返回 文件类型_目录
        EXT4_S_IFLNK  => 返回 文件类型_符号链接
        EXT4_S_IFBLK  => 返回 文件类型_块设备
        EXT4_S_IFCHR  => 返回 文件类型_字符设备
        EXT4_S_IFIFO  => 返回 文件类型_管道
        EXT4_S_IFSOCK => 返回 文件类型_套接字
        _             => 返回 文件类型_未知
    }
}

函数 ext4_类型转模式(类型) {
    匹配 (类型) {
        文件类型_普通     => 返回 EXT4_S_IFREG
        文件类型_目录     => 返回 EXT4_S_IFDIR
        文件类型_符号链接 => 返回 EXT4_S_IFLNK
        文件类型_块设备   => 返回 EXT4_S_IFBLK
        文件类型_字符设备 => 返回 EXT4_S_IFCHR
        文件类型_管道     => 返回 EXT4_S_IFIFO
        文件类型_套接字   => 返回 EXT4_S_IFSOCK
        _               => 返回 0
    }
}

函数 ext4_是目录(节点) {
    如果 (节点 == 空) { 返回 假 }
    返回 (节点.模式 & EXT4_S_IFMT) == EXT4_S_IFDIR
}

函数 ext4_是普通文件(节点) {
    如果 (节点 == 空) { 返回 假 }
    返回 (节点.模式 & EXT4_S_IFMT) == EXT4_S_IFREG
}

函数 ext4_是符号链接(节点) {
    如果 (节点 == 空) { 返回 假 }
    返回 (节点.模式 & EXT4_S_IFMT) == EXT4_S_IFLNK
}

函数 ext4_是块设备(节点) {
    如果 (节点 == 空) { 返回 假 }
    返回 (节点.模式 & EXT4_S_IFMT) == EXT4_S_IFBLK
}

函数 ext4_是字符设备(节点) {
    如果 (节点 == 空) { 返回 假 }
    返回 (节点.模式 & EXT4_S_IFMT) == EXT4_S_IFCHR
}

函数 ext4_是管道(节点) {
    如果 (节点 == 空) { 返回 假 }
    返回 (节点.模式 & EXT4_S_IFMT) == EXT4_S_IFIFO
}

函数 ext4_是套接字(节点) {
    如果 (节点 == 空) { 返回 假 }
    返回 (节点.模式 & EXT4_S_IFMT) == EXT4_S_IFSOCK
}

函数 ext4_是特殊文件(节点) {
    如果 (节点 == 空) { 返回 假 }
    定义 类型 = 节点.模式 & EXT4_S_IFMT
    返回 类型 == EXT4_S_IFBLK || 类型 == EXT4_S_IFCHR ||
           类型 == EXT4_S_IFIFO || 类型 == EXT4_S_IFSOCK
}

// §6 权限位解析与校验

函数 ext4_获取权限位(磁盘in) {
    如果 (磁盘in == 空) { 返回 0 }
    返回 磁盘in.模式 & 0x0FFF
}

函数 ext4_设置权限位(磁盘in, 权限) {
    如果 (磁盘in == 空) { 返回 }
    磁盘in.模式 = (磁盘in.模式 & 0xF000) | (权限 & 0x0FFF)
}

函数 ext4_检查读权限(磁盘in, uid, gid) {
    ext4_权限检查次数 = ext4_权限检查次数 + 1
    如果 (磁盘in == 空) { 返回 假 }
    定义 模式 = 磁盘in.模式
    // root全通
    如果 (uid == 0) { 返回 真 }
    // 所有者检查
    如果 (ext4_获取Nova文件节点_uid(磁盘in) == uid) {
        返回 (模式 & EXT4_S_IRUSR) != 0
    }
    // 组检查
    如果 (ext4_获取Nova文件节点_gid(磁盘in) == gid) {
        返回 (模式 & EXT4_S_IRGRP) != 0
    }
    // 其他用户
    返回 (模式 & EXT4_S_IROTH) != 0
}

函数 ext4_检查写权限(磁盘in, uid, gid) {
    ext4_权限检查次数 = ext4_权限检查次数 + 1
    如果 (磁盘in == 空) { 返回 假 }
    // 不可变文件禁止写入
    如果 (磁盘in.标志 & EXT4_IMMUTABLE_FL) {
        ext4_权限拒绝次数 = ext4_权限拒绝次数 + 1
        返回 假
    }
    定义 模式 = 磁盘in.模式
    如果 (uid == 0) { 返回 真 }
    如果 (ext4_获取Nova文件节点_uid(磁盘in) == uid) {
        返回 (模式 & EXT4_S_IWUSR) != 0
    }
    如果 (ext4_获取Nova文件节点_gid(磁盘in) == gid) {
        返回 (模式 & EXT4_S_IWGRP) != 0
    }
    返回 (模式 & EXT4_S_IWOTH) != 0
}

函数 ext4_检查执行权限(磁盘in, uid, gid) {
    ext4_权限检查次数 = ext4_权限检查次数 + 1
    如果 (磁盘in == 空) { 返回 假 }
    定义 模式 = 磁盘in.模式
    如果 (uid == 0) { 返回 真 }
    如果 (ext4_获取Nova文件节点_uid(磁盘in) == uid) {
        返回 (模式 & EXT4_S_IXUSR) != 0
    }
    如果 (ext4_获取Nova文件节点_gid(磁盘in) == gid) {
        返回 (模式 & EXT4_S_IXGRP) != 0
    }
    返回 (模式 & EXT4_S_IXOTH) != 0
}

函数 ext4_检查全权限(磁盘in, uid, gid, 请求权限) {
    // 请求权限: bit0=读, bit1=写, bit2=执行
    如果 (请求权限 & 1) {
        如果 (!ext4_检查读权限(磁盘in, uid, gid)) {
            ext4_权限拒绝次数 = ext4_权限拒绝次数 + 1
            返回 假
        }
    }
    如果 (请求权限 & 2) {
        如果 (!ext4_检查写权限(磁盘in, uid, gid)) {
            ext4_权限拒绝次数 = ext4_权限拒绝次数 + 1
            返回 假
        }
    }
    如果 (请求权限 & 4) {
        如果 (!ext4_检查执行权限(磁盘in, uid, gid)) {
            ext4_权限拒绝次数 = ext4_权限拒绝次数 + 1
            返回 假
        }
    }
    返回 真
}

// §7 ext4纳秒级时间戳管理

函数 ext4_获取时间戳_秒(磁盘in, 字段) {
    // 字段: 0=atime, 1=ctime, 2=mtime, 3=crtime
    ext4_时间戳读次数 = ext4_时间戳读次数 + 1
    如果 (磁盘in == 空) { 返回 0 }
    匹配 (字段) {
        0 => 返回 磁盘in.访问时间
        1 => 返回 磁盘in.变更时间
        2 => 返回 磁盘in.修改时间
        3 => 返回 磁盘in.创建时间
        _ => 返回 0
    }
}

函数 ext4_获取时间戳_纳秒(磁盘in, 字段) {
    // ext4额外时间信息存储在额外字段中，低30位为纳秒，高2位为epoch
    ext4_时间戳读次数 = ext4_时间戳读次数 + 1
    如果 (磁盘in == 空) { 返回 0 }
    定义 可变 额外 = 0
    匹配 (字段) {
        0 => 额外 = 磁盘in.访问时间_额外
        1 => 额外 = 磁盘in.变更时间_额外
        2 => 额外 = 磁盘in.修改时间_额外
        3 => 额外 = 磁盘in.创建时间_额外
        _ => 返回 0
    }
    返回 额外 & EXT4_NSEC_MASK
}

函数 ext4_获取时间戳_epoch(磁盘in, 字段) {
    如果 (磁盘in == 空) { 返回 0 }
    定义 可变 额外 = 0
    匹配 (字段) {
        0 => 额外 = 磁盘in.访问时间_额外
        1 => 额外 = 磁盘in.变更时间_额外
        2 => 额外 = 磁盘in.修改时间_额外
        3 => 额外 = 磁盘in.创建时间_额外
        _ => 返回 0
    }
    返回 (额外 >> 30) & EXT4_EPOCH_MASK
}

函数 ext4_设置时间戳(磁盘in, 字段, 秒, 纳秒) {
    如果 (磁盘in == 空) { 返回 }
    // 设置秒级时间
    匹配 (字段) {
        0 => 磁盘in.访问时间 = 秒
        1 => 磁盘in.变更时间 = 秒
        2 => 磁盘in.修改时间 = 秒
        3 => 磁盘in.创建时间 = 秒
    }
    // 设置纳秒部分
    定义 额外值 = 纳秒 & EXT4_NSEC_MASK
    匹配 (字段) {
        0 => 磁盘in.访问时间_额外 = 额外值
        1 => 磁盘in.变更时间_额外 = 额外值
        2 => 磁盘in.修改时间_额外 = 额外值
        3 => 磁盘in.创建时间_额外 = 额外值
    }
}

// §8 inode标志操作

函数 ext4_获取标志(磁盘in) {
    如果 (磁盘in == 空) { 返回 0 }
    返回 磁盘in.标志
}

函数 ext4_设置标志(磁盘in, 标志) {
    如果 (磁盘in == 空) { 返回 }
    磁盘in.标志 = 标志
}

函数 ext4_添加标志(磁盘in, 新标志) {
    如果 (磁盘in == 空) { 返回 }
    磁盘in.标志 = 磁盘in.标志 | 新标志
}

函数 ext4_移除标志(磁盘in, 旧标志) {
    如果 (磁盘in == 空) { 返回 }
    磁盘in.标志 = 磁盘in.标志 & (~旧标志)
}

函数 ext4_测试标志(磁盘in, 测试位) {
    如果 (磁盘in == 空) { 返回 假 }
    返回 (磁盘in.标志 & 测试位) != 0
}

函数 ext4_是加密文件(磁盘in) {
    返回 ext4_测试标志(磁盘in, EXT4_ENCRYPT_FL)
}

函数 ext4_是extent文件(磁盘in) {
    返回 ext4_测试标志(磁盘in, EXT4_EXTENTS_FL)
}

函数 ext4_是内联数据文件(磁盘in) {
    返回 ext4_测试标志(磁盘in, EXT4_INLINE_FL)
}

函数 ext4_是不可变文件(磁盘in) {
    返回 ext4_测试标志(磁盘in, EXT4_IMMUTABLE_FL)
}

函数 ext4_是只追加文件(磁盘in) {
    返回 ext4_测试标志(磁盘in, EXT4_APPEND_FL)
}

// §9 inode校验与修复

函数 ext4_校验inode(磁盘in) {
    如果 (磁盘in == 空) { 返回 错误码_无效参数 }

    // 校验模式字段
    定义 类型 = 磁盘in.模式 & EXT4_S_IFMT
    如果 (类型 != EXT4_S_IFREG && 类型 != EXT4_S_IFDIR &&
        类型 != EXT4_S_IFLNK && 类型 != EXT4_S_IFBLK &&
        类型 != EXT4_S_IFCHR && 类型 != EXT4_S_IFIFO &&
        类型 != EXT4_S_IFSOCK) {
        ext4_校验失败次数 = ext4_校验失败次数 + 1
        返回 错误码_数据损坏
    }

    // 校验链接数
    定义 链接 = ext4_获取链接数(磁盘in)
    如果 (链接 == 0 && 类型 != EXT4_S_IFREG) {
        // 已删除的非inode，不是普通文件但链接数=0，可能损坏
        ext4_校验失败次数 = ext4_校验失败次数 + 1
        返回 错误码_数据损坏
    }

    // 校验大小一致性
    定义 大小 = ext4_获取Nova文件节点大小(磁盘in)
    定义 块数 = ext4_获取Nova文件节点块数(磁盘in)
    如果 (大小 > 0 && 块数 == 0 && 类型 == EXT4_S_IFREG) {
        // 普通文件有大小但无块，可能是内联数据
        如果 (!ext4_是内联数据文件(磁盘in)) {
            ext4_校验失败次数 = ext4_校验失败次数 + 1
            返回 错误码_数据损坏
        }
    }

    返回 0
}

函数 ext4_修复inode_链接数(磁盘in) {
    // 当链接数异常时尝试修复为1
    如果 (磁盘in == 空) { 返回 错误码_无效参数 }
    如果 (ext4_获取链接数(磁盘in) == 0) {
        ext4_设置链接数(磁盘in, 1)
    }
    返回 0
}

// §10 【Nova创新】AI文件行为分析
// 原创理论: 多维度文件元数据感知模型(MFMPM)
// 通过属性向量化、时序足迹、权限图谱三维融合，
// 实现对文件行为的实时感知与异常检测

函数 ext4_AI_分析文件行为(磁盘in) {
    ext4_AI文件分析次数 = ext4_AI文件分析次数 + 1
    定义 bus = 全局AI总线
    如果 (bus == 空 || 磁盘in == 空) {
        返回 ext4_启发式文件分析(磁盘in)
    }

    定义 特征 = Tensor_创建(12)
    如果 (特征 == 空) { 返回 ext4_启发式文件分析(磁盘in) }
    Tensor_清零(特征, 12)

    // 特征0: 文件类型编码
    Tensor_写(特征, 0, ext4_模式转类型(磁盘in.模式))
    // 特征1: 大小对数 (log2压缩)
    定义 大小 = ext4_获取Nova文件节点大小(磁盘in)
    Tensor_写(特征, 1, ext4_安全log2(大小))
    // 特征2: 权限位
    Tensor_写(特征, 2, ext4_获取权限位(磁盘in))
    // 特征3: 链接数
    Tensor_写(特征, 3, ext4_获取链接数(磁盘in))
    // 特征4: 块数
    Tensor_写(特征, 4, ext4_获取Nova文件节点块数(磁盘in))
    // 特征5: uid
    Tensor_写(特征, 5, ext4_获取Nova文件节点_uid(磁盘in))
    // 特征6: inode标志
    Tensor_写(特征, 6, ext4_获取标志(磁盘in))
    // 特征7: 修改时间
    Tensor_写(特征, 7, ext4_获取时间戳_秒(磁盘in, 2))

    定义 异常分 = AI总线_异常检测(bus, "ext4_inode_behavior", 特征)
    Tensor_释放(特征)

    // 返回0=正常, 1=可疑, 2=异常
    如果 (异常分 >= 7000) { 返回 2 }
    如果 (异常分 >= 4000) { 返回 1 }
    返回 0
}

函数 ext4_启发式文件分析(磁盘in) {
    如果 (磁盘in == 空) { 返回 2 }
    定义 可变 异常计数 = 0
    // 检查异常权限
    定义 权限 = ext4_获取权限位(磁盘in)
    如果 (权限 == 0x0FFF) { 异常计数 = 异常计数 + 1 }  // 全权限可疑
    如果 (权限 & EXT4_S_ISUID && 权限 & EXT4_S_IWOTH) {
        异常计数 = 异常计数 + 1  // SUID+全局可写危险
    }
    // 检查异常大小
    定义 大小 = ext4_获取Nova文件节点大小(磁盘in)
    如果 (大小 > 1099511627776) { 异常计数 = 异常计数 + 1 }  // >1TB可疑
    // 检查链接数异常
    如果 (ext4_获取链接数(磁盘in) > 1000) { 异常计数 = 异常计数 + 1 }

    如果 (异常计数 >= 2) { 返回 2 }
    如果 (异常计数 >= 1) { 返回 1 }
    返回 0
}

函数 ext4_安全log2(值) {
    如果 (值 <= 0) { 返回 0 }
    定义 可变 结果 = 0
    定义 可变 n = 值
    当 (n > 1) {
        n = n >> 1
        结果 = 结果 + 1
    }
    返回 结果
}

// §11 统计接口

函数 ext4Nova文件节点_完整统计() {
    返回 [
        ext4_Nova文件节点读次数,
        ext4_Nova文件节点写次数,
        ext4_属性读总次数,
        ext4_属性写总次数,
        ext4_权限检查次数,
        ext4_权限拒绝次数,
        ext4_校验失败次数,
        ext4_AI文件分析次数,
        ext4_时间戳读次数,
        ext4_扩展属性读次数
    ]
}

函数 ext4_打印文件节点诊断() {
    内核打印("═══ ext4文件节点属性诊断 ═══\n")
    内核打印("读=", ext4_Nova文件节点读次数, " 写=", ext4_Nova文件节点写次数, "\n")
    内核打印("属性读=", ext4_属性读总次数, " 属性写=", ext4_属性写总次数, "\n")
    内核打印("权限检查=", ext4_权限检查次数, " 拒绝=", ext4_权限拒绝次数, "\n")
    内核打印("校验失败=", ext4_校验失败次数, " AI分析=", ext4_AI文件分析次数, "\n")
}

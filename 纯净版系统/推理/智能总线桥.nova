函数 AI总线_推理_是总线(值) {
    如果 (值 == 0) { 返回 假 }
    如果 (Nova_是对象(值) == 假 && Nova_是数组(值) == 假 && Nova_是函数(值) == 假) { 返回 假 }
    如果 (值.统计 != 0) { 返回 真 }
    如果 (值.AI推理预算 != 0) { 返回 真 }
    如果 (值.语义引擎 != 0) { 返回 真 }
    如果 (值.布局预测网络 != 0) { 返回 真 }
    返回 假
}

函数 AI总线_推理_是张量(值) {
    如果 (值 == 0) { 返回 假 }
    如果 (Nova_是对象(值) == 假 && Nova_是数组(值) == 假) { 返回 假 }
    如果 (值.元素数 != 0) { 返回 真 }
    如果 (值.维度数 != 0) { 返回 真 }
    如果 (值.行数 != 0 || 值.列数 != 0) { 返回 真 }
    返回 假
}

函数 AI总线_推理_张量长度(值) {
    如果 (值 == 0) { 返回 0 }
    如果 (值.元素数 != 0) { 返回 值.元素数 }
    如果 (值.行数 != 0 && 值.列数 != 0) { 返回 值.行数 * 值.列数 }
    返回 0
}

函数 AI总线_推理_读取(值, 索引) {
    如果 (值 == 0) { 返回 0 }
    如果 (值.元素数 != 0) {
        返回 Tensor_读(值, 索引)
    }
    如果 (值.列数 == 0) { 返回 0 }
    定义 行 = 索引 / 值.列数
    定义 列 = 索引 % 值.列数
    返回 Tensor_读(值, 行, 列)
}

函数 AI总线_推理_写入(值, 索引, 数据) {
    如果 (值 == 0) { 返回 }
    如果 (值.元素数 != 0) {
        Tensor_写(值, 索引, 数据)
        返回
    }
    如果 (值.列数 == 0) { 返回 }
    定义 行 = 索引 / 值.列数
    定义 列 = 索引 % 值.列数
    Tensor_写(值, 行, 列, 数据)
}

函数 AI总线_推理_平均值(输入) {
    如果 (AI总线_推理_是张量(输入) == 假) {
        如果 (Nova_是数值(输入)) { 返回 输入 }
        返回 0
    }
    定义 总数 = AI总线_推理_张量长度(输入)
    如果 (总数 <= 0) { 返回 0 }
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < 总数) {
        总和 = 总和 + AI总线_推理_读取(输入, i)
        i = i + 1
    }
    返回 总和 / 总数
}

函数 首值(输入) {
    如果 (AI总线_推理_张量长度(输入) <= 0) { 返回 0 }
    返回 AI总线_推理_读取(输入, 0)
}

函数 次值(输入) {
    如果 (AI总线_推理_张量长度(输入) <= 1) { 返回 0 }
    返回 AI总线_推理_读取(输入, 1)
}


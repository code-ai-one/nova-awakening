导入("./类型定义.nova")
导入("./错误码.nova")
导入("./整数转字符串.nova")

定义 数学_精度 = 1000
定义 数学_PI = 3142
定义 数学_E = 2718
定义 数学_PI2 = 6283
定义 数学_半PI = 1571


函数 绝对值(n) {
    如果 (n < 0) { 返回 0 - n }
    返回 n
}

函数 最大值(a, b) {
    如果 (a > b) { 返回 a }
    返回 b
}

函数 最小值(a, b) {
    如果 (a < b) { 返回 a }
    返回 b
}

函数 钳制_张量(值, 下限, 上限) {
    如果 (值 < 下限) { 返回 下限 }
    如果 (值 > 上限) { 返回 上限 }
    返回 值
}

函数 符号(n) {
    如果 (n > 0) { 返回 1 }
    如果 (n < 0) { 返回 0 - 1 }
    返回 0
}

函数 平方根(n) {
    如果 (n <= 0) { 返回 0 }
    定义 可变 x = n
    定义 可变 y = (x + 1) / 2
    当 (y < x) { x = y  y = (x + n / x) / 2 }
    返回 x
}

函数 定点平方根(n) {
    如果 (n <= 0) { 返回 0 }
    返回 平方根(n * 数学_精度)
}

函数 幂(底数, 指数) {
    如果 (指数 == 0) { 返回 1 }
    如果 (指数 < 0) { 返回 0 }
    定义 可变 结果 = 1
    定义 可变 b = 底数
    定义 可变 e = 指数
    当 (e > 0) {
        如果 (e % 2 == 1) { 结果 = 结果 * b }
        b = b * b
        e = e / 2
    }
    返回 结果
}

函数 定点幂(底数, 指数) {
    如果 (指数 == 0) { 返回 数学_精度 }
    如果 (底数 == 0) { 返回 0 }
    如果 (底数 == 数学_精度) { 返回 数学_精度 }
    定义 ln_b = 定点_自然对数(底数)
    返回 定点_指数(指数 * ln_b / 数学_精度)
}


函数 角度_归一化(角度) {
    定义 可变 a = 角度 % 数学_PI2
    如果 (a > 数学_PI) { a = a - 数学_PI2 }
    如果 (a < 0 - 数学_PI) { a = a + 数学_PI2 }
    返回 a
}

函数 正弦(角度) {
    定义 x = 角度_归一化(角度)
    定义 x2 = x * x / 数学_精度
    定义 可变 项 = x
    定义 可变 结果 = x
    项 = 0 - 项 * x2 / 数学_精度 / 6
    结果 = 结果 + 项
    项 = 0 - 项 * x2 / 数学_精度 / 20
    结果 = 结果 + 项
    项 = 0 - 项 * x2 / 数学_精度 / 42
    结果 = 结果 + 项
    项 = 0 - 项 * x2 / 数学_精度 / 72
    结果 = 结果 + 项
    返回 结果
}

函数 余弦(角度) {
    返回 正弦(角度 + 数学_半PI)
}

函数 正切(角度) {
    定义 c = 余弦(角度)
    如果 (c == 0) { 返回 0x7FFFFFFF }
    返回 正弦(角度) * 数学_精度 / c
}


函数 反正弦(x) {
    // arcsin泰勒展开: x + x³/6 + 3x⁵/40 + ...
    如果 (x > 数学_精度) { x = 数学_精度 }
    如果 (x < 0 - 数学_精度) { x = 0 - 数学_精度 }
    定义 x2 = x * x / 数学_精度
    定义 可变 结果 = x
    定义 可变 项 = x * x2 / 数学_精度 / 6
    结果 = 结果 + 项
    项 = 项 * x2 / 数学_精度 * 3 / 40
    结果 = 结果 + 项
    项 = 项 * x2 / 数学_精度 * 15 / 336
    结果 = 结果 + 项
    全局统计.三角函数数 = 全局统计.三角函数数 + 1
    返回 结果
}

函数 反余弦(x) {
    返回 数学_半PI - 反正弦(x)
}

函数 反正切(x) {
    // atan泰勒展开: x - x³/3 + x⁵/5 - ...
    如果 (绝对值(x) > 数学_精度) {
        // 大角度：atan(x) ≈ π/2 - 1/x
        如果 (x > 0) { 返回 数学_半PI - 数学_精度 * 数学_精度 / x }
        返回 0 - 数学_半PI - 数学_精度 * 数学_精度 / x
    }
    定义 x2 = x * x / 数学_精度
    定义 可变 结果 = x
    定义 可变 项 = 0 - x * x2 / 数学_精度 / 3
    结果 = 结果 + 项
    项 = 0 - 项 * x2 / 数学_精度 * 3 / 5
    结果 = 结果 + 项
    项 = 0 - 项 * x2 / 数学_精度 * 5 / 7
    结果 = 结果 + 项
    全局统计.三角函数数 = 全局统计.三角函数数 + 1
    返回 结果
}

函数 反正切2(y, x) {
    如果 (x > 0) { 返回 反正切(y * 数学_精度 / x) }
    如果 (x < 0 && y >= 0) { 返回 反正切(y * 数学_精度 / x) + 数学_PI }
    如果 (x < 0 && y < 0) { 返回 反正切(y * 数学_精度 / x) - 数学_PI }
    如果 (y > 0) { 返回 数学_半PI }
    如果 (y < 0) { 返回 0 - 数学_半PI }
    返回 0
}


函数 定点_指数(x) {
    // e^x 泰勒展开: 1 + x + x²/2! + x³/3! + ...
    全局统计.指数对数数 = 全局统计.指数对数数 + 1
    定义 可变 结果 = 数学_精度
    定义 可变 项 = x
    结果 = 结果 + 项
    项 = 项 * x / 数学_精度 / 2
    结果 = 结果 + 项
    项 = 项 * x / 数学_精度 / 3
    结果 = 结果 + 项
    项 = 项 * x / 数学_精度 / 4
    结果 = 结果 + 项
    项 = 项 * x / 数学_精度 / 5
    结果 = 结果 + 项
    项 = 项 * x / 数学_精度 / 6
    结果 = 结果 + 项
    返回 结果
}

函数 定点_自然对数(x) {
    // ln(x) 用 ln(1+t)/(1-t) 级数
    全局统计.指数对数数 = 全局统计.指数对数数 + 1
    如果 (x <= 0) { 返回 0 - 999999 }
    如果 (x == 数学_精度) { 返回 0 }
    // 归一化到 [0.5, 2.0]
    定义 可变 归一 = x
    定义 可变 修正 = 0
    当 (归一 > 2 * 数学_精度) { 归一 = 归一 / 2  修正 = 修正 + 693 }
    当 (归一 < 数学_精度 / 2) { 归一 = 归一 * 2  修正 = 修正 - 693 }
    // ln(y) ≈ 2*(t + t³/3 + t⁵/5), t = (y-1)/(y+1)
    定义 分子 = 归一 - 数学_精度
    定义 分母 = 归一 + 数学_精度
    如果 (分母 == 0) { 返回 修正 }
    定义 t = 分子 * 数学_精度 / 分母
    定义 t2 = t * t / 数学_精度
    定义 可变 结果 = t
    结果 = 结果 + t * t2 / 数学_精度 / 3
    结果 = 结果 + t * t2 / 数学_精度 * t2 / 数学_精度 / 5
    返回 结果 * 2 + 修正
}

函数 定点_对数10(x) {
    // log10(x) = ln(x) / ln(10)
    返回 定点_自然对数(x) * 数学_精度 / 2303
}

函数 定点_对数2(x) {
    // log2(x) = ln(x) / ln(2)
    返回 定点_自然对数(x) * 数学_精度 / 693
}


函数 双曲正弦(x) {
    // sinh(x) = (e^x - e^(-x)) / 2
    定义 正 = 定点_指数(x)
    定义 负 = 定点_指数(0 - x)
    返回 (正 - 负) / 2
}

函数 双曲余弦(x) {
    // cosh(x) = (e^x + e^(-x)) / 2
    定义 正 = 定点_指数(x)
    定义 负 = 定点_指数(0 - x)
    返回 (正 + 负) / 2
}

函数 双曲正切(x) {
    定义 sh = 双曲正弦(x)
    定义 ch = 双曲余弦(x)
    如果 (ch == 0) { 返回 数学_精度 }
    返回 sh * 数学_精度 / ch
}


函数 阶乘(n) {
    如果 (n <= 1) { 返回 1 }
    如果 (n > 20) { 返回 0 }
    定义 可变 结果 = 1
    定义 可变 i = 2
    当 (i <= n) {
        结果 = 结果 * i
        i = i + 1
    }
    全局统计.组合运算数 = 全局统计.组合运算数 + 1
    返回 结果
}

函数 组合数(n, k) {
    如果 (k < 0 || k > n) { 返回 0 }
    如果 (k == 0 || k == n) { 返回 1 }
    如果 (k > n - k) { k = n - k }
    定义 可变 结果 = 1
    定义 可变 i = 0
    当 (i < k) {
        结果 = 结果 * (n - i) / (i + 1)
        i = i + 1
    }
    全局统计.组合运算数 = 全局统计.组合运算数 + 1
    返回 结果
}

函数 排列数(n, k) {
    如果 (k < 0 || k > n) { 返回 0 }
    定义 可变 结果 = 1
    定义 可变 i = 0
    当 (i < k) {
        结果 = 结果 * (n - i)
        i = i + 1
    }
    返回 结果
}


函数 线性插值(x0, y0, x1, y1, x) {
    如果 (x1 == x0) { 返回 y0 }
    返回 y0 + (y1 - y0) * (x - x0) / (x1 - x0)
}

函数 最大公约数(a, b) {
    如果 (a < 0) { a = 0 - a }
    如果 (b < 0) { b = 0 - b }
    当 (b != 0) {
        定义 t = b
        b = a % b
        a = t
    }
    返回 a
}

函数 最小公倍数(a, b) {
    如果 (a == 0 || b == 0) { 返回 0 }
    返回 绝对值(a * b) / 最大公约数(a, b)
}

函数 是否质数(n) {
    如果 (n < 2) { 返回 假 }
    如果 (n < 4) { 返回 真 }
    如果 (n % 2 == 0 || n % 3 == 0) { 返回 假 }
    定义 可变 i = 5
    当 (i * i <= n) {
        如果 (n % i == 0 || n % (i + 2) == 0) { 返回 假 }
        i = i + 6
    }
    返回 真
}


定义 AI精度窗口 = 16
定义 可变 AI精度历史 = []
定义 可变 AI精度位置 = 0

函数 AI_记录精度(运算类型, 误差) {
    如果 (计数(AI精度历史) < AI精度窗口) {
        追加(AI精度历史, [运算类型, 误差])
    } 否则 {
        设置(AI精度历史, AI精度位置, [运算类型, 误差])
    }
    AI精度位置 = (AI精度位置 + 1) % AI精度窗口
    全局统计.AI预测次数 = 全局统计.AI预测次数 + 1
}

函数 AI_建议精度() {
    定义 可变 总误差 = 0
    定义 可变 有效 = 0
    定义 可变 i = 0
    当 (i < 计数(AI精度历史)) {
        如果 (AI精度历史[i][1] > 0) {
            总误差 = 总误差 + AI精度历史[i][1]
            有效 = 有效 + 1
        }
        i = i + 1
    }
    如果 (有效 == 0) { 返回 "当前精度1000足够" }
    定义 均误差 = 总误差 / 有效
    如果 (均误差 > 100) { 返回 "建议提升精度到10000" }
    如果 (均误差 > 10) { 返回 "当前精度基本可用" }
    返回 "精度优秀"
}


结构 基础数学统计 {
    绝对值计算数: 整数,
    平方根计算数: 整数,
    幂运算数: 整数,
    三角函数数: 整数,
    指数对数数: 整数,
    双曲函数数: 整数,
    组合运算数: 整数,
    插值计算数: 整数,
    AI预测次数: 整数,
    AI预测命中: 整数,
    最大输入值: 整数,
    溢出次数: 整数,
    批量运算数: 整数,
    精度不足数: 整数,
    错误次数: 整数,
}

定义 可变 全局统计 = 基础数学统计 {}
定义 可变 基础数学已初始化 = 假


函数 基础数学_初始化() {
    如果 (基础数学已初始化 == 真) { 返回 0 - 17 }
    AI精度历史 = []
    AI精度位置 = 0
    基础数学已初始化 = 真
    打印("[基础数学] 初始化完成")
    返回 0
}

函数 基础数学_销毁() {
    如果 (基础数学已初始化 == 假) { 返回 0 }
    AI精度历史 = []
    基础数学已初始化 = 假
    打印("[基础数学] 已销毁")
    返回 0
}


函数 基础数学_转储() {
    打印("[基础数学] ═══ 状态转储 ═══")
    打印(字符串拼接("  精度: ", 整数转字符串(数学_精度)))
    打印(字符串拼接("  PI: ", 整数转字符串(数学_PI)))
    打印(字符串拼接("  AI建议: ", AI_建议精度()))
    返回 0
}


函数 基础数学_打印统计() {
    打印("[基础数学] ═══ 运行统计 ═══")
    打印(字符串拼接("  绝对值: ", 整数转字符串(全局统计.绝对值计算数)))
    打印(字符串拼接("  平方根: ", 整数转字符串(全局统计.平方根计算数)))
    打印(字符串拼接("  幂运算: ", 整数转字符串(全局统计.幂运算数)))
    打印(字符串拼接("  三角函数: ", 整数转字符串(全局统计.三角函数数)))
    打印(字符串拼接("  指数对数: ", 整数转字符串(全局统计.指数对数数)))
    打印(字符串拼接("  双曲函数: ", 整数转字符串(全局统计.双曲函数数)))
    打印(字符串拼接("  组合运算: ", 整数转字符串(全局统计.组合运算数)))
    打印(字符串拼接("  插值计算: ", 整数转字符串(全局统计.插值计算数)))
    打印(字符串拼接("  AI预测: ", 整数转字符串(全局统计.AI预测次数)))
    打印(字符串拼接("  AI命中: ", 整数转字符串(全局统计.AI预测命中)))
    打印(字符串拼接("  最大输入: ", 整数转字符串(全局统计.最大输入值)))
    打印(字符串拼接("  溢出: ", 整数转字符串(全局统计.溢出次数)))
    打印(字符串拼接("  批量运算: ", 整数转字符串(全局统计.批量运算数)))
    打印(字符串拼接("  精度不足: ", 整数转字符串(全局统计.精度不足数)))
    打印(字符串拼接("  错误次数: ", 整数转字符串(全局统计.错误次数)))
    返回 0
}


函数 基础数学_注册到内核(内核上下文) {
    如果 (基础数学已初始化 == 假) { 返回 0 - 1 }
    打印("[基础数学] 已注册到内核上下文")
    返回 0
}

函数 基础数学_查询状态() {
    如果 (基础数学已初始化 == 假) { 返回 0 }
    返回 1
}

函数 基础数学_健康检查() {
    如果 (基础数学已初始化 == 假) { 返回 假 }
    如果 (全局统计.溢出次数 > 100) { 返回 假 }
    返回 真
}


函数 定点_取整(x) {
    如果 (x >= 0) { 返回 (x + 数学_精度 / 2) / 数学_精度 * 数学_精度 }
    返回 (x - 数学_精度 / 2) / 数学_精度 * 数学_精度
}

函数 定点_下取整(x) {
    如果 (x >= 0) { 返回 x / 数学_精度 * 数学_精度 }
    返回 (x - 数学_精度 + 1) / 数学_精度 * 数学_精度
}

函数 定点_上取整(x) {
    如果 (x >= 0) { 返回 (x + 数学_精度 - 1) / 数学_精度 * 数学_精度 }
    返回 x / 数学_精度 * 数学_精度
}

函数 角度转弧度(角度) {
    // 角度(0~360) → 弧度(0~2π×1000)
    返回 角度 * 数学_PI / 180
}

函数 弧度转角度(弧度) {
    返回 弧度 * 180 / 数学_PI
}

函数 斐波那契(n) {
    如果 (n <= 0) { 返回 0 }
    如果 (n <= 2) { 返回 1 }
    定义 可变 a = 0
    定义 可变 b = 1
    定义 可变 i = 2
    当 (i <= n) {
        定义 t = a + b
        a = b
        b = t
        i = i + 1
    }
    返回 b
}

函数 欧拉函数(n) {
    如果 (n <= 0) { 返回 0 }
    定义 可变 结果 = n
    定义 可变 p = 2
    定义 可变 m = n
    当 (p * p <= m) {
        如果 (m % p == 0) {
            当 (m % p == 0) { m = m / p }
            结果 = 结果 - 结果 / p
        }
        p = p + 1
    }
    如果 (m > 1) { 结果 = 结果 - 结果 / m }
    返回 结果
}

函数 快速幂模(底数, 指数, 模数) {
    如果 (模数 <= 0) { 返回 0 }
    定义 可变 结果 = 1
    定义 可变 b = 底数 % 模数
    定义 可变 e = 指数
    当 (e > 0) {
        如果 (e % 2 == 1) { 结果 = 结果 * b % 模数 }
        b = b * b % 模数
        e = e / 2
    }
    返回 结果
}

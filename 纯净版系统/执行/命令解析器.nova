// 龙壳 — 命令解析器 — 深度吸收bash词法/语法解析
// 核心设计(来自bash):
//   1. 词法分析: 处理引号('/")/转义(\)/空白分割
//   2. 重定向解析: <, >, >>, 2>, 2>&1, <<(here-doc), <<<(here-string)
//   3. 引号内不分割: "hello world"是一个参数
//   4. 转义字符: \n \t \\ \" 在双引号内展开
//   5. glob展开: *, ?, [abc] (Phase 2扩展)

结构 解析结果 {
    参数,    // [] 命令和参数列表 (已去除重定向部分)
    重定向,    // 空 重定向信息结构
}

结构 重定向信息 {
    输入,    // 空 < file
    输出,    // 空 > file 或 >> file
    错误,    // 空 2> file
    追加,    // 假 >> (追加模式)
    合并错误,    // 假 2>&1
}

// 完整命令行解析 (词法分析 + 重定向提取)

函数 解析命令行_完整(行) {
    定义 去空白 = 字符串去首尾空白(行)
    如果 (去空白 == "") { 返回 空 }

    // 1. 词法分析: 分割为令牌 (尊重引号)
    定义 令牌s = 词法分析(去空白)
    如果 (令牌s == 空 || 计数(令牌s) == 0) { 返回 空 }

    // 2. 提取重定向, 剩余为参数
    定义 可变 参数 = []
    定义 可变 redir = 重定向信息 {}
    定义 可变 i = 0

    当 (i < 计数(令牌s)) {
        定义 t = 令牌s[i]

        // 输出重定向: > file 或 >> file
        如果 (t == ">") {
            如果 (i + 1 < 计数(令牌s)) {
                redir.输出 = 令牌s[i + 1]
                redir.追加 = 假
                i = i + 2
                继续
            }
        }
        如果 (t == ">>") {
            如果 (i + 1 < 计数(令牌s)) {
                redir.输出 = 令牌s[i + 1]
                redir.追加 = 真
                i = i + 2
                继续
            }
        }

        // 输入重定向: < file
        如果 (t == "<") {
            如果 (i + 1 < 计数(令牌s)) {
                redir.输入 = 令牌s[i + 1]
                i = i + 2
                继续
            }
        }

        // 错误重定向: 2> file
        如果 (t == "2>") {
            如果 (i + 1 < 计数(令牌s)) {
                redir.错误 = 令牌s[i + 1]
                i = i + 2
                继续
            }
        }

        // 合并错误到标准输出: 2>&1
        如果 (t == "2>&1") {
            redir.合并错误 = 真
            i = i + 1
            继续
        }

        // 标准输出重定向到错误: 1>&2 或 >&2
        如果 (t == "1>&2" || t == ">&2") {
            // 特殊处理
            i = i + 1
            继续
        }

        追加(参数, t)
        i = i + 1
    }

    定义 结果 = 解析结果 {}
    结果.参数 = 参数
    如果 (redir.输入 != 空 || redir.输出 != 空 || redir.错误 != 空 || redir.合并错误) {
        结果.重定向 = redir
    }
    返回 结果
}

// 简单版本(向后兼容)
函数 解析命令行(行) {
    定义 去空白 = 字符串去首尾空白(行)
    如果 (去空白 == "") { 返回 空 }
    返回 词法分析(去空白)
}

// 词法分析: 将命令行分割为令牌列表
// 处理: 单引号/双引号/转义/空白分割

函数 词法分析(行) {
    定义 可变 令牌s = []
    定义 可变 当前令牌 = ""
    定义 可变 i = 0
    定义 长度 = 字符串长度(行)
    定义 可变 状态 = 0     // 0=普通, 1=单引号内, 2=双引号内

    当 (i < 长度) {
        定义 ch = 字符串取字符(行, i)

        如果 (状态 == 1) {
            如果 (ch == "'") {
                状态 = 0
            } 否则 {
                当前令牌 = 当前令牌 + ch
            }
            i = i + 1
            继续
        }

        如果 (状态 == 2) {
            如果 (ch == "\"") {
                状态 = 0
            } 否则 如果 (ch == "\\" && i + 1 < 长度) {
                // 双引号内的转义: \", \\, \$, \`, \n
                定义 下一个 = 字符串取字符(行, i + 1)
                如果 (下一个 == "\"" || 下一个 == "\\" || 下一个 == "$" || 下一个 == "`") {
                    当前令牌 = 当前令牌 + 下一个
                    i = i + 1
                } 否则 如果 (下一个 == "n") {
                    当前令牌 = 当前令牌 + "\n"
                    i = i + 1
                } 否则 如果 (下一个 == "t") {
                    当前令牌 = 当前令牌 + "\t"
                    i = i + 1
                } 否则 {
                    当前令牌 = 当前令牌 + ch
                }
            } 否则 {
                当前令牌 = 当前令牌 + ch
            }
            i = i + 1
            继续
        }

        // 单引号开始
        如果 (ch == "'") {
            状态 = 1
            i = i + 1
            继续
        }

        // 双引号开始
        如果 (ch == "\"") {
            状态 = 2
            i = i + 1
            继续
        }

        // 转义字符
        如果 (ch == "\\" && i + 1 < 长度) {
            当前令牌 = 当前令牌 + 字符串取字符(行, i + 1)
            i = i + 2
            继续
        }

        // 空白: 结束当前令牌
        如果 (ch == " " || ch == "\t") {
            如果 (当前令牌 != "") {
                追加(令牌s, 当前令牌)
                当前令牌 = ""
            }
            i = i + 1
            继续
        }

        // 特殊操作符令牌: >>, 2>, 2>&1
        如果 (ch == ">" && i + 1 < 长度 && 字符串取字符(行, i + 1) == ">") {
            如果 (当前令牌 != "") { 追加(令牌s, 当前令牌); 当前令牌 = "" }
            追加(令牌s, ">>")
            i = i + 2
            继续
        }
        如果 (ch == "2" && i + 2 < 长度 && 字符串取字符(行, i + 1) == ">" && 字符串取字符(行, i + 2) == "&") {
            如果 (i + 3 < 长度 && 字符串取字符(行, i + 3) == "1") {
                如果 (当前令牌 != "") { 追加(令牌s, 当前令牌); 当前令牌 = "" }
                追加(令牌s, "2>&1")
                i = i + 4
                继续
            }
        }
        如果 (ch == "2" && i + 1 < 长度 && 字符串取字符(行, i + 1) == ">") {
            如果 (当前令牌 != "") { 追加(令牌s, 当前令牌); 当前令牌 = "" }
            追加(令牌s, "2>")
            i = i + 2
            继续
        }

        // 单字符操作符: > < |
        如果 (ch == ">" || ch == "<") {
            如果 (当前令牌 != "") { 追加(令牌s, 当前令牌); 当前令牌 = "" }
            追加(令牌s, ch)
            i = i + 1
            继续
        }

        // 普通字符
        当前令牌 = 当前令牌 + ch
        i = i + 1
    }

    // 最后一个令牌
    如果 (当前令牌 != "") {
        追加(令牌s, 当前令牌)
    }

    返回 令牌s
}

// 管道解析 (向后兼容)

函数 解析管道(行) {
    返回 字符串分割(行, " | ")
}

// 旧版重定向解析 (向后兼容)

函数 解析重定向(参数列表) {
    定义 可变 输入文件 = 空
    定义 可变 输出文件 = 空
    定义 可变 i = 0
    当 (i < 计数(参数列表)) {
        如果 (参数列表[i] == ">") { 如果 (i + 1 < 计数(参数列表)) { 输出文件 = 参数列表[i + 1] } }
        如果 (参数列表[i] == "<") { 如果 (i + 1 < 计数(参数列表)) { 输入文件 = 参数列表[i + 1] } }
        i = i + 1
    }
    返回 [输入文件, 输出文件]
}

定义 可变 AI_命令解析器_热点函数 = []

函数 AI_命令解析器_JIT候选(函数名, 调用次数) {
    如果 (调用次数 > 100) {
        追加(AI_命令解析器_热点函数, 函数名)
        返回 真
    }
    返回 假
}

函数 AI_命令解析器_内联建议(函数体大小, 调用次数) {
    如果 (函数体大小 < 30 && 调用次数 > 50) { 返回 "内联" }
    返回 "不内联"
}

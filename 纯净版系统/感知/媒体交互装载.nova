// 感知媒体交互装载
// 将媒体元素、录制、音频包读取与输出控件重新接回浏览器外衣主链。

导入("./标记媒体元素.nova")
导入("./标记输出元素.nova")
导入("./媒体记录接口.nova")
导入("./媒体能力查询.nova")
导入("./器读取音频包.nova")
导入("./基编码.nova")
导入("./屏幕唤醒锁.nova")

函数 感知媒体交互装载_模块清单() {
    返回 [
        "./标记媒体元素.nova",
        "./标记输出元素.nova",
        "./媒体记录接口.nova",
        "./媒体能力查询.nova",
        "./器读取音频包.nova",
        "./基编码.nova",
        "./屏幕唤醒锁.nova"
    ]
}

函数 感知媒体交互装载_统计() {
    返回 {
        模块数: 计数(感知媒体交互装载_模块清单())
    }
}

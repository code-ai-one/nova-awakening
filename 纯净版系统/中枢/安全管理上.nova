// §6 安全管理 — 上下文切换时恢复FS/GS基址

定义 MSR_FS_BASE = 0xC0000100
定义 MSR_GS_BASE = 0xC0000101
定义 MSR_KERNEL_GS_BASE = 0xC0000102

函数 切换安全(前一个, 下一个) {
    // 保存当前FS基址
    如果 (前一个 != 空) {
        前一个.安全.基地址 = 读MSR(MSR_FS_BASE)
    }
    // 恢复下一个线程的FS基址
    如果 (下一个 != 空 && 下一个.安全.基地址 != 0) {
        写MSR(MSR_FS_BASE, 下一个.安全.基地址)
    }
}

// §7 sys_gettid / sys_getpid 语义修正

函数 sys_gettid_完整() {
    // gettid返回线程ID(真正的PID)
    返回 获取当前进程().PID
}

函数 sys_getpid_完整() {
    // getpid返回TGID(线程组ID = 主线程PID)
    // 这就是为什么同一进程的所有线程看到同一个PID
    返回 获取当前进程().TGID
}

函数 sys_tgkill(tgid, tid, 信号) {
    // tgkill: 向指定线程组的指定线程发送信号
    定义 目标 = 通过PID查找进程(tid)
    如果 (目标 == 空) { 返回 错误_进程不存在 }
    如果 (目标.TGID != tgid) { 返回 错误_进程不存在 }
    返回 信号_发送(tid, 信号)
}

// §8 robust Nova快速锁列表 — 线程崩溃时自动释放锁

函数 处理robust_Nova快速锁列表(进程) {
    定义 head = 进程.robust_list_head
    如果 (head == 0) { 返回 }

    // robust_list_head: { next, Nova快速锁_offset, list_op_pending }
    定义 Nova快速锁_offset = 内存读64(head + 8)
    定义 可变 entry = 内存读64(head)   // next指针
    定义 可变 计数 = 0
    定义 最大 = 2048   // 防止无限循环

    当 (entry != head && entry != 0 && 计数 < 最大) {
        定义 Nova快速锁_addr = entry + Nova快速锁_offset
        // 将Nova快速锁值设为Nova快速锁_OWNER_DIED | 原TID
        定义 当前值 = 内存读32(Nova快速锁_addr)
        内存写32(Nova快速锁_addr, 当前值 | 0x40000000)  // Nova快速锁_OWNER_DIED
        // 唤醒等待者
        sys_Nova快速锁(Nova快速锁_addr, 1, 1, 0, 0, 0)  // Nova快速锁_WAKE
        entry = 内存读64(entry)
        计数 = 计数 + 1
    }

    // 处理list_op_pending
    定义 pending = 内存读64(head + 16)
    如果 (pending != 0) {
        定义 Nova快速锁_addr = pending + Nova快速锁_offset
        定义 当前值 = 内存读32(Nova快速锁_addr)
        内存写32(Nova快速锁_addr, 当前值 | 0x40000000)
        sys_Nova快速锁(Nova快速锁_addr, 1, 1, 0, 0, 0)
    }
}

// §9 辅助(外部引用声明)

外部 进程_分配              // 进程描述符.nova

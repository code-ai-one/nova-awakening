函数 渲染管线_计算样式(tab) {
    // 更新样式表索引
    样式Engine_更新活跃样式表(tab.样式引擎)
    // 递归计算每个元素的Computed样式
    渲染管线_计算样式_递归(tab, tab.文档)
}

函数 渲染管线_计算样式_递归(tab, 节点) {
    如果 (节点 == 0) { 返回 }
    如果 (节点.节点类型 == 元素_节点) {
        样式Engine_解析元素样式(tab.样式引擎, 节点)
    }
    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        渲染管线_计算样式_递归(tab, 子)
        子 = 子.后一兄弟
    }
}

函数 渲染管线_绘制(tab) {
    // 清除画布
    Sk画布_clear(tab.画布, SK_ColorWHITE)

    // 绘制所有绘制层
    如果 (tab.绘制层根 != 0) {
        绘制Layer_绘制(tab.绘制层根, tab.绘制层根, 0 - tab.滚动x, 0 - tab.滚动y)
        // 执行显示列表
        Sk画布_执行显示列表(tab.画布, tab.绘制层根.显示列表, tab.绘制层根.显示列表数量)
    }
}

函数 渲染管线_AI驱动更新(tab) {
 如果 (tab == 0 || tab.文档 == 0) { 返回 }
 定义 bus = AI总线_获取实例()
 如果 (bus == 0) { 返回 }

 定义 帧开始时间 = 平台_获取高精度时间()
 AI总线_帧开始(bus)

 定义 预测动作 = AI总线_预测下一步(bus)
 如果 (预测动作 == 动作_滚动) {
 定义 未来视口Y = AI总线_预测滚动位置(bus, 200)
 }

 定义 需要样式 = (tab.文档.节点标志 & 节点标志_样式脏) != 0
 定义 需要布局 = (tab.文档.节点标志 & 节点标志_布局脏) != 0

 如果 (tab.样式引擎 != 0) {
 样式Engine_更新活跃样式表(tab.样式引擎)
 }
 如果 (需要样式) {
 渲染管线_计算样式(tab)
 }
 如果 (需要布局 || 需要样式) {
 如果 (tab.布局根 != 0) {
 tab.布局根.标志 = tab.布局根.标志 | 布局标志_需要布局
 布局Object_布局(tab.布局根)
 }
 }

 定义 绘制开始 = 平台_获取高精度时间()
 渲染统计_帧开始()
 如果 (tab.绘制层根 != 0) {
 AI渲染_总线驱动绘制(bus, tab.绘制层根, tab.滚动y, tab.视口高)
 }
 如果 (tab.绘制层根 != 0 && tab.画布 != 0) {
 AI绘制_智能执行显示列表(tab.画布, tab.绘制层根.显示列表, tab.绘制层根.显示列表数量, tab.绘制层根.渲染精度)
 }
 定义 绘制耗时 = 平台_获取高精度时间() - 绘制开始
 帧诊断_记录(绘制耗时 / 1000)

 AI总线_帧结束(bus, 平台_获取高精度时间() - 帧开始时间)
}

// §3 增量更新 — 样式/布局/绘制的增量管线
// (对应 DocumentLifecycle)
// 不需要每次都全量重算,只更新脏的部分

函数 渲染管线_增量更新(tab) {
 // 检查是否有脏节点
 如果 (tab.文档 == 0) { 返回 }

 定义 bus = AI总线_获取实例()
 如果 (bus != 0) {
 渲染管线_AI驱动更新(tab)
 返回
 }

 定义 需要样式 = (tab.文档.节点标志 & 节点标志_样式脏) != 0
 定义 需要布局 = (tab.文档.节点标志 & 节点标志_布局脏) != 0

 如果 (需要样式) {
 渲染管线_计算样式(tab)
 }

 如果 (需要布局 || 需要样式) {
 如果 (tab.布局根 != 0) {
 tab.布局根.标志 = tab.布局根.标志 | 布局标志_需要布局
 布局Object_布局(tab.布局根)
 }
 }

 // 全量重绘(后续优化: 只绘制脏区域)
 渲染管线_绘制(tab)
}

// §4 浏览器主窗口 (Nova浏览器::Browser)
// 管理多个标签页、地址栏、工具栏等

结构 Browser {
 平台窗口,    // u64 PlatformWindow*

 标签列表,    // u64 TabPage*数组
 标签数量,
 标签容量,
 当前标签,    // u32 活跃标签索引

 地址栏文本,    // u64 地址栏当前文本
 地址栏聚焦,
 是全屏,
 帧调度,    // u64 帧调度器*

 正在运行,
 工具栏高度,    // i32 像素(地址栏+标签栏)
 标签栏高度,
 地址栏高度,
 状态栏高度,
}

函数 Browser_创建() {
 定义 browser = 堆_分配(Browser)

 // 创建平台窗口 (1280×720默认)
 browser.平台窗口 = PlatformWindow_创建("NovaBrowser", 1280, 720)

 // 标签页
 browser.标签容量 = 32
 browser.标签列表 = 堆_分配_数组(browser.标签容量 * 8)
 browser.标签数量 = 0
 browser.当前标签 = 0

 // UI
 browser.地址栏文本 = 字符串_复制("")
 browser.地址栏聚焦 = 假
 browser.是全屏 = 假

 // 帧调度
 browser.帧调度 = 帧调度器_创建(60)

 // 运行
 browser.正在运行 = 真

 // UI尺寸
 browser.标签栏高度 = 35
 browser.地址栏高度 = 40
 browser.工具栏高度 = browser.标签栏高度 + browser.地址栏高度
 browser.状态栏高度 = 20

 // 创建默认标签
 Browser_新建标签(browser)

 返回 browser
}

函数 Browser_新建标签(browser) {
 如果 (browser.标签数量 >= browser.标签容量) { 返回 }
 定义 win = browser.平台窗口
 定义 内容宽 = win.宽 * 100
 定义 内容高 = (win.高 - browser.工具栏高度 - browser.状态栏高度) * 100

 定义 tab = TabPage_创建(browser.标签数量, 内容宽, 内容高)
 tab.是活跃标签 = 真

 // 取消当前活跃标签
 如果 (browser.标签数量 > 0) {
 定义 旧tab = 内存_读64(browser.标签列表 + browser.当前标签 * 8)
 如果 (旧tab != 0) { 旧tab.是活跃标签 = 假 }
 }

 内存_写64(browser.标签列表 + browser.标签数量 * 8, tab)
 browser.当前标签 = browser.标签数量
 browser.标签数量 = browser.标签数量 + 1
}

函数 Browser_导航(browser, url字符串) {
 如果 (browser.标签数量 == 0) { 返回 }
 定义 tab = 内存_读64(browser.标签列表 + browser.当前标签 * 8)
 如果 (tab == 0) { 返回 }

 browser.地址栏文本 = 字符串_复制(url字符串)
 渲染管线_导航到URL(tab, url字符串)

 // 更新窗口标题
 定义 标题 = 字符串_连接(tab.标题, " - NovaBrowser")
 系统调用(Nova系统调用_图形_设置窗口标题, browser.平台窗口.句柄, 标题, 字符串_长度(标题), 0, 0)
}

函数 Browser_后退(browser) {
 定义 tab = 内存_读64(browser.标签列表 + browser.当前标签 * 8)
 如果 (tab == 0 || tab.历史当前 == 0) { 返回 }
 tab.历史当前 = tab.历史当前 - 1
 定义 url = 内存_读64(tab.历史列表 + tab.历史当前 * 8)
 渲染管线_导航到URL(tab, url)
}

函数 Browser_前进(browser) {
 定义 tab = 内存_读64(browser.标签列表 + browser.当前标签 * 8)
 如果 (tab == 0 || tab.历史当前 >= tab.历史数量 - 1) { 返回 }
 tab.历史当前 = tab.历史当前 + 1
 定义 url = 内存_读64(tab.历史列表 + tab.历史当前 * 8)
 渲染管线_导航到URL(tab, url)
}

函数 Browser_刷新(browser) {
 定义 tab = 内存_读64(browser.标签列表 + browser.当前标签 * 8)
 如果 (tab == 0) { 返回 }
 渲染管线_导航到URL(tab, tab.URL)
}

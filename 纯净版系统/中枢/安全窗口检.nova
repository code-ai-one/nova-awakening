// §5 安全窗口检测
// 确保没有CPU正在执行要替换的函数

函数 等待安全窗口(目标地址) {
    // 1. 检查所有CPU的栈帧, 确认没有在目标函数内
    // 2. 如果有, 等待该CPU离开(最多等10ms)
    定义 可变 重试 = 100
    当 (重试 > 0) {
        定义 安全 = 检查所有CPU栈(目标地址)
        如果 (安全) { 返回 真 }
        // 短暂让出CPU让其他任务运行
        调度_让出()
        重试 = 重试 - 1
    }
    返回 假   // 超时: 无法获得安全窗口
}

函数 检查所有CPU栈(目标地址) {
    // 遍历所有CPU的当前栈帧, 检查RIP是否在目标函数范围内
    定义 函数大小 = 符号表_查找大小_按地址(目标地址)
    如果 (函数大小 == 0) { 函数大小 = 256 }  // 保守估计
    定义 函数结束 = 目标地址 + 函数大小

    // 遍历所有CPU
    定义 cpu数 = 获取CPU数量_热更新()
    定义 可变 cpu = 0
    当 (cpu < cpu数) {
        // 获取该CPU的当前栈帧
        定义 栈底 = 获取CPU栈底(cpu)
        定义 栈顶 = 获取CPU栈顶(cpu)
        如果 (栈底 == 0 || 栈顶 == 0) { cpu = cpu + 1; 继续 }

        // 遍历栈帧: 每个帧 [RBP, 返回地址]
        定义 可变 rbp = 栈底
        定义 可变 深度 = 0
        当 (rbp >= 栈顶 && rbp < 栈底 + 65536 && 深度 < 64) {
            定义 返回地址 = 内存读64(rbp + 8)
            // 检查返回地址是否在目标函数范围内
            如果 (返回地址 >= 目标地址 && 返回地址 < 函数结束) {
                // CPU正在执行目标函数，不安全
                返回 假
            }
            // 沿栈帧链向上走
            定义 上一rbp = 内存读64(rbp)
            如果 (上一rbp <= rbp) { 跳出 }  // 防止循环
            rbp = 上一rbp
            深度 = 深度 + 1
        }
        cpu = cpu + 1
    }
    返回 真  // 所有CPU都不在目标函数内
}

函数 符号表_查找大小_按地址(地址) {
    定义 可变 i = 0
    当 (i < 计数(内核符号表)) {
        如果 (内核符号表[i][1] == 地址) { 返回 内核符号表[i][2] }
        i = i + 1
    }
    返回 0
}

// §6 Watchdog: 热更新后监控

定义 可变 watchdog_补丁ID = 0
定义 可变 watchdog_检查点ID = 0
定义 可变 watchdog_超时时间 = 0
定义 可变 watchdog_启动时间 = 0
定义 可变 watchdog_活跃 = 假

函数 热更新_启动watchdog(关联ID, 超时ms) {
    watchdog_补丁ID = 关联ID
    watchdog_超时时间 = 超时ms
    watchdog_启动时间 = 读取毫秒()
    watchdog_活跃 = 真
    内核信息("热更新watchdog: 启动 超时=" + 整数转字符串(超时ms) + "ms")
}

函数 热更新_watchdog_tick() {
    // 由定时器tick调用
    如果 (!watchdog_活跃) { 返回 }
    定义 经过 = 读取毫秒() - watchdog_启动时间
    如果 (经过 > watchdog_超时时间) {
        // 超时未崩溃 = 更新成功, 停止watchdog
        watchdog_活跃 = 假
        内核信息("热更新watchdog: 更新稳定, 停止监控")
    }
}

函数 热更新_崩溃回调() {
    // ★ 由panic/oops钩子调用
    如果 (!watchdog_活跃) { 返回 }
    内核错误("热更新watchdog: 检测到崩溃! 自动回滚...")

    // 回滚到检查点
    定义 结果 = 检查点_回滚(watchdog_检查点ID)
    如果 (结果 == 成功) {
        内核信息("热更新watchdog: 回滚成功, 系统恢复")
        热更新_回滚次数 = 热更新_回滚次数 + 1
    } 否则 {
        内核错误("热更新watchdog: 回滚失败! 系统可能不稳定")
    }
    watchdog_活跃 = 假
}

函数 热更新_启动智能_watchdog(模型名, 超时ms) {
    // AI专用watchdog: 监控推理输出质量
    // 如果新权重导致推理结果异常(NaN/极端值), 自动回滚
    watchdog_启动时间 = 读取毫秒()
    watchdog_超时时间 = 超时ms
    watchdog_活跃 = 真
}

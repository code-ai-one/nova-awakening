导入("./样式计算.nova")
导入("./样式动画.nova")

结构 主题档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    变量数,
    桌面数,
    浏览器数,
    组件数,
    动效数,
    成功数,
    失败数,
}

结构 主题请求 {
    动作,
    目标,
    参数,
    选项,
}

结构 主题回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 主题摘要 {
    名称,
    变量数,
    桌面数,
    浏览器数,
    组件数,
    动效数,
    成功数,
    失败数,
    健康,
}

定义 可变 主题账本 = []
定义 可变 主题构建数 = 0
定义 可变 主题总动作 = 0
定义 可变 主题总成功 = 0
定义 可变 主题总失败 = 0


函数 白璃主题_建档(名称) {
    定义 档 = 主题档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.变量数 = 0
    档.桌面数 = 0
    档.浏览器数 = 0
    档.组件数 = 0
    档.动效数 = 0
    档.成功数 = 0
    档.失败数 = 0
    返回 档
}

函数 白璃主题_登记(档) {
    追加(主题账本, 档)
    主题构建数 = 主题构建数 + 1
    返回 档
}

函数 白璃主题_完整统计() {
    返回 [
        主题构建数,
        主题总动作,
        主题总成功,
        主题总失败
    ]
}

函数 白璃主题_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 主题回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 白璃主题_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.失败数 > 档.成功数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (档.变量数 > 0 || 档.桌面数 > 0 || 档.浏览器数 > 0 || 档.组件数 > 0) {
        档.最近健康 = "运行"
        返回 档.最近健康
    }
    档.最近健康 = "空载"
    返回 档.最近健康
}

函数 白璃主题_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    档.最近错误 = ""
    档.最近统计 = 白璃主题_完整统计()
}

函数 白璃主题_成功(档, 来源, 数据) {
    主题总动作 = 主题总动作 + 1
    主题总成功 = 主题总成功 + 1
    如果 (档 == 空) {
        返回 白璃主题_建回证(真, 真, 来源, "", 数据, 白璃主题_完整统计())
    }
    档.最近来源 = 来源
    档.最近结果 = 数据
    档.最近错误 = ""
    档.成功数 = 档.成功数 + 1
    档.最近统计 = 白璃主题_完整统计()
    白璃主题_刷新健康(档)
    返回 白璃主题_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 白璃主题_失败(档, 来源, 错因) {
    主题总动作 = 主题总动作 + 1
    主题总失败 = 主题总失败 + 1
    如果 (档 == 空) {
        返回 白璃主题_建回证(真, 假, 来源, 错因, 0, 白璃主题_完整统计())
    }
    档.最近来源 = 来源
    档.最近错误 = 错因
    档.失败数 = 档.失败数 + 1
    档.最近统计 = 白璃主题_完整统计()
    白璃主题_刷新健康(档)
    返回 白璃主题_建回证(真, 假, 来源, 错因, 0, 档.最近统计)
}

函数 白璃主题_初始化(档) {
    样式计算_创建("白璃主题计算")
    样式动画_创建("白璃主题动效")
    档.是否初始化 = 真
    档.最近动作 = "初始化"
    档.最近来源 = "白璃主题_初始化"
    档.最近统计 = 白璃主题_完整统计()
    白璃主题_刷新健康(档)
    返回 档
}

函数 白璃主题_创建(名称) {
    定义 档 = 白璃主题_建档(名称)
    白璃主题_初始化(档)
    返回 白璃主题_登记(档)
}

函数 白璃主题_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (!档.是否初始化) { 返回 假 }
    返回 真
}

函数 白璃主题_对(键, 值) {
    返回 键 + ":" + 值 + ";"
}

函数 白璃主题_段(选择器, 内容) {
    返回 选择器 + "{" + 内容 + "}\n"
}

函数 白璃主题_变量段(名, 值) {
    返回 "  --" + 名 + ":" + 值 + ";\n"
}

函数 白璃主题_根变量文本() {
    定义 文本 = ":root {\n"
    文本 = 文本 + 白璃主题_变量段("白底", "#0f0a1e")
    文本 = 文本 + 白璃主题_变量段("白板", "rgba(88,28,135,0.35)")
    文本 = 文本 + 白璃主题_变量段("白板强", "rgba(168,85,247,0.45)")
    文本 = 文本 + 白璃主题_变量段("白板弱", "rgba(88,28,135,0.2)")
    文本 = 文本 + 白璃主题_变量段("墨色", "#f0e6ff")
    文本 = 文本 + 白璃主题_变量段("副墨", "#c084fc")
    文本 = 文本 + 白璃主题_变量段("柔线", "rgba(168,85,247,0.3)")
    文本 = 文本 + 白璃主题_变量段("硬线", "rgba(168,85,247,0.5)")
    文本 = 文本 + 白璃主题_变量段("蓝光", "#a855f7")
    文本 = 文本 + 白璃主题_变量段("青光", "#c084fc")
    文本 = 文本 + 白璃主题_变量段("暖光", "#fbbf24")
    文本 = 文本 + 白璃主题_变量段("影深", "0 24px 80px rgba(88,28,135,0.45)")
    文本 = 文本 + 白璃主题_变量段("影中", "0 18px 48px rgba(88,28,135,0.3)")
    文本 = 文本 + 白璃主题_变量段("影轻", "0 10px 24px rgba(88,28,135,0.2)")
    文本 = 文本 + 白璃主题_变量段("圆大", "28px")
    文本 = 文本 + 白璃主题_变量段("圆中", "20px")
    文本 = 文本 + 白璃主题_变量段("圆小", "14px")
    文本 = 文本 + 白璃主题_变量段("模糊强", "blur(28px)")
    文本 = 文本 + 白璃主题_变量段("模糊中", "blur(20px)")
    文本 = 文本 + 白璃主题_变量段("模糊轻", "blur(12px)")
    文本 = 文本 + 白璃主题_变量段("间大", "28px")
    文本 = 文本 + 白璃主题_变量段("间中", "18px")
    文本 = 文本 + 白璃主题_变量段("间小", "10px")
    文本 = 文本 + 白璃主题_变量段("字大", "28px")
    文本 = 文本 + 白璃主题_变量段("字中", "16px")
    文本 = 文本 + 白璃主题_变量段("字小", "13px")
    文本 = 文本 + 白璃主题_变量段("速快", "180ms")
    文本 = 文本 + 白璃主题_变量段("速中", "280ms")
    文本 = 文本 + 白璃主题_变量段("速慢", "420ms")
    文本 = 文本 + "}\n"
    返回 文本
}

函数 白璃主题_底景文本() {
    定义 内容 = ""
    内容 = 内容 + 白璃主题_对("min-height", "100vh")
    内容 = 内容 + 白璃主题_对("background", "radial-gradient(ellipse at 18% 12%,rgba(88,28,135,0.4),transparent 40%),radial-gradient(ellipse at 82% 14%,rgba(168,85,247,0.2),transparent 35%),linear-gradient(145deg,#0f0a1e 0%,#1a0f2e 40%,#0d0b1a 100%)")
    内容 = 内容 + 白璃主题_对("color", "var(--墨色)")
    内容 = 内容 + 白璃主题_对("font-family", "\"PingFang SC\",\"Noto Serif SC\",\"Microsoft YaHei\",sans-serif")
    内容 = 内容 + 白璃主题_对("letter-spacing", "0.02em")
    内容 = 内容 + 白璃主题_对("overflow", "hidden")
    返回 白璃主题_段("body", 内容)
}


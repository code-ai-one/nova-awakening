// §6 标识符/函数/URL解析

函数 CSS解析_标识符或函数(文本, 长度, pos) {
    定义 可变 p = pos
    定义 名称起始 = p
    当 (p < 长度 && CSS_是标识符续(内存_读8(文本 + p))) { p = p + 1 }
    定义 名称长度 = p - 名称起始
    定义 名称 = 字符串_复制_N(文本 + 名称起始, 名称长度)

    // 是函数调用? 紧跟 (
    如果 (p < 长度 && 内存_读8(文本 + p) == 0x28) {
        // rgb() / rgba() / hsl() / hsla()
        如果 (字符串_等于N(名称, 名称长度, "rgb") || 字符串_等于N(名称, 名称长度, "rgba")) {
            返回 CSS解析_rgb函数(文本, 长度, 名称起始)
        }
        如果 (字符串_等于N(名称, 名称长度, "hsl") || 字符串_等于N(名称, 名称长度, "hsla")) {
            返回 CSS解析_hsl函数(文本, 长度, 名称起始)
        }
        // url()
        如果 (字符串_等于N(名称, 名称长度, "url")) {
            返回 CSS解析_url函数(文本, 长度, p)
        }
        // var()
        如果 (字符串_等于N(名称, 名称长度, "var")) {
            返回 CSS解析_var函数(文本, 长度, p)
        }
        // calc()
        如果 (字符串_等于N(名称, 名称长度, "calc") || 字符串_等于N(名称, 名称长度, "min") ||
            字符串_等于N(名称, 名称长度, "max") || 字符串_等于N(名称, 名称长度, "clamp")) {
            返回 CSS解析_calc函数(文本, 长度, 名称起始)
        }
        // linear-gradient() / radial-gradient()
        如果 (字符串_等于N(名称, 名称长度, "linear-gradient") ||
            字符串_等于N(名称, 名称长度, "radial-gradient") ||
            字符串_等于N(名称, 名称长度, "repeating-linear-gradient") ||
            字符串_等于N(名称, 名称长度, "repeating-radial-gradient") ||
            字符串_等于N(名称, 名称长度, "conic-gradient")) {
            返回 CSS解析_渐变函数(文本, 长度, 名称起始)
        }
        // 其他函数
        定义 v = CSSParsedValue_创建(CSS值_函数)
        v.字符串 = 名称
        v.字符串长度 = 名称长度
        返回 v
    }

    // 命名颜色?
    定义 颜色 = CSS解析_命名颜色(名称, 名称长度)
    如果 (颜色 != 0) { 返回 颜色 }

    // CSS关键字
    定义 v = CSSParsedValue_创建(CSS值_关键字)
    v.字符串 = 名称
    v.字符串长度 = 名称长度
    v.关键字ID = CSS解析_关键字ID(名称, 名称长度)
    返回 v
}

函数 CSS解析_关键字ID(名称, 长度) {
    如果 (字符串_等于N(名称, 长度, "inherit")) { 返回 关键字_inherit }
    如果 (字符串_等于N(名称, 长度, "initial")) { 返回 关键字_initial }
    如果 (字符串_等于N(名称, 长度, "unset")) { 返回 关键字_unset }
    如果 (字符串_等于N(名称, 长度, "auto")) { 返回 关键字_auto }
    如果 (字符串_等于N(名称, 长度, "none")) { 返回 关键字_none }
    如果 (字符串_等于N(名称, 长度, "normal")) { 返回 关键字_normal }
    如果 (字符串_等于N(名称, 长度, "bold")) { 返回 关键字_bold }
    如果 (字符串_等于N(名称, 长度, "italic")) { 返回 关键字_italic }
    如果 (字符串_等于N(名称, 长度, "hidden")) { 返回 关键字_hidden }
    如果 (字符串_等于N(名称, 长度, "visible")) { 返回 关键字_visible }
    如果 (字符串_等于N(名称, 长度, "block")) { 返回 关键字_block }
    如果 (字符串_等于N(名称, 长度, "inline")) { 返回 关键字_inline }
    如果 (字符串_等于N(名称, 长度, "inline-block")) { 返回 关键字_inline_block }
    如果 (字符串_等于N(名称, 长度, "flex")) { 返回 关键字_flex }
    如果 (字符串_等于N(名称, 长度, "grid")) { 返回 关键字_grid }
    如果 (字符串_等于N(名称, 长度, "static")) { 返回 关键字_static }
    如果 (字符串_等于N(名称, 长度, "relative")) { 返回 关键字_relative }
    如果 (字符串_等于N(名称, 长度, "absolute")) { 返回 关键字_absolute }
    如果 (字符串_等于N(名称, 长度, "fixed")) { 返回 关键字_fixed }
    如果 (字符串_等于N(名称, 长度, "sticky")) { 返回 关键字_sticky }
    如果 (字符串_等于N(名称, 长度, "left")) { 返回 关键字_left }
    如果 (字符串_等于N(名称, 长度, "right")) { 返回 关键字_right }
    如果 (字符串_等于N(名称, 长度, "center")) { 返回 关键字_center }
    如果 (字符串_等于N(名称, 长度, "justify")) { 返回 关键字_justify }
    如果 (字符串_等于N(名称, 长度, "top")) { 返回 关键字_top }
    如果 (字符串_等于N(名称, 长度, "bottom")) { 返回 关键字_bottom }
    如果 (字符串_等于N(名称, 长度, "nowrap")) { 返回 关键字_nowrap }
    如果 (字符串_等于N(名称, 长度, "wrap")) { 返回 关键字_wrap }
    如果 (字符串_等于N(名称, 长度, "solid")) { 返回 关键字_solid }
    如果 (字符串_等于N(名称, 长度, "dashed")) { 返回 关键字_dashed }
    如果 (字符串_等于N(名称, 长度, "dotted")) { 返回 关键字_dotted }
    如果 (字符串_等于N(名称, 长度, "transparent")) { 返回 关键字_transparent }
    如果 (字符串_等于N(名称, 长度, "pointer")) { 返回 关键字_pointer }
    如果 (字符串_等于N(名称, 长度, "row")) { 返回 关键字_row }
    如果 (字符串_等于N(名称, 长度, "column")) { 返回 关键字_column }
    如果 (字符串_等于N(名称, 长度, "flex-start")) { 返回 关键字_flex_start }
    如果 (字符串_等于N(名称, 长度, "flex-end")) { 返回 关键字_flex_end }
    如果 (字符串_等于N(名称, 长度, "space-between")) { 返回 关键字_space_between }
    如果 (字符串_等于N(名称, 长度, "space-around")) { 返回 关键字_space_around }
    如果 (字符串_等于N(名称, 长度, "stretch")) { 返回 关键字_stretch }
    如果 (字符串_等于N(名称, 长度, "cover")) { 返回 关键字_cover }
    如果 (字符串_等于N(名称, 长度, "contain")) { 返回 关键字_contain }
    如果 (字符串_等于N(名称, 长度, "border-box")) { 返回 关键字_border_box }
    如果 (字符串_等于N(名称, 长度, "padding-box")) { 返回 关键字_padding_box }
    如果 (字符串_等于N(名称, 长度, "content-box")) { 返回 关键字_content_box }
    如果 (字符串_等于N(名称, 长度, "no-repeat")) { 返回 关键字_no_repeat }
    如果 (字符串_等于N(名称, 长度, "repeat")) { 返回 关键字_repeat }
    返回 0
}

函数 CSS解析_字符串(文本, 长度, pos, 引号) {
    定义 可变 p = pos + 1    // 跳过引号
    定义 起始 = p
    当 (p < 长度 && 内存_读8(文本 + p) != 引号) {
        如果 (内存_读8(文本 + p) == 0x5C) { p = p + 1 }    // 转义
        p = p + 1
    }
    定义 v = CSSParsedValue_创建(CSS值_字符串)
    v.字符串 = 字符串_复制_N(文本 + 起始, p - 起始)
    v.字符串长度 = p - 起始
    返回 v
}

函数 CSS解析_url函数(文本, 长度, pos) {
    定义 可变 p = pos + 1    // 跳过 (
    当 (p < 长度 && CSS_是空白(内存_读8(文本 + p))) { p = p + 1 }
    定义 c = 内存_读8(文本 + p)
    如果 (c == 0x22 || c == 0x27) {
        定义 str = CSS解析_字符串(文本, 长度, p, c)
        定义 v = CSSParsedValue_创建(CSS值_URL)
        如果 (str != 0) { v.字符串 = str.字符串; v.字符串长度 = str.字符串长度 }
        返回 v
    }
    // 无引号URL
    定义 起始 = p
    当 (p < 长度 && 内存_读8(文本 + p) != 0x29) { p = p + 1 }
    定义 v = CSSParsedValue_创建(CSS值_URL)
    v.字符串 = 字符串_复制_N(文本 + 起始, p - 起始)
    v.字符串长度 = p - 起始
    返回 v
}

函数 CSS解析_var函数(文本, 长度, pos) {
    定义 可变 p = pos + 1
    当 (p < 长度 && CSS_是空白(内存_读8(文本 + p))) { p = p + 1 }
    定义 起始 = p
    当 (p < 长度 && 内存_读8(文本 + p) != 0x29 && 内存_读8(文本 + p) != 0x2C) { p = p + 1 }
    定义 v = CSSParsedValue_创建(CSS值_自定义属性)
    v.字符串 = 字符串_复制_N(文本 + 起始, p - 起始)
    v.字符串长度 = p - 起始
    返回 v
}

函数 CSS解析_calc函数(文本, 长度, pos) {
    // calc(): 提取函数内容并递归求值
    定义 可变 p = pos
    当 (p < 长度 && 内存_读8(文本 + p) != 0x28) { p = p + 1 }
    p = p + 1
    定义 起始 = p
    定义 可变 深度 = 1
    当 (p < 长度 && 深度 > 0) {
        如果 (内存_读8(文本 + p) == 0x28) { 深度 = 深度 + 1 }
        如果 (内存_读8(文本 + p) == 0x29) { 深度 = 深度 - 1 }
        如果 (深度 > 0) { p = p + 1 }
    }
    定义 v = CSSParsedValue_创建(CSS值_函数)
    v.字符串 = 字符串_复制_N(文本 + 起始, p - 起始)
    v.字符串长度 = p - 起始
    返回 v
}

函数 CSS解析_渐变函数(文本, 长度, pos) {
    // 提取CSS函数内容并解析
    返回 CSS解析_calc函数(文本, 长度, pos)
}

定义 可变 AI_标识符函数_样式缓存命中 = 0

函数 AI_标识符函数_选择器复杂度(选择器长度, 组合子数) {
    如果 (组合子数 > 5) { 返回 "高复杂度" }
    如果 (组合子数 > 2) { 返回 "中复杂度" }
    返回 "低复杂度"
}

函数 AI_标识符函数_布局缓存(元素哈希) {
    AI_标识符函数_样式缓存命中 = AI_标识符函数_样式缓存命中 + 1
    返回 元素哈希
}

// URL结构:
//   scheme://userinfo@host:port/path?query#fragment
//   https://user:pass@example.com:8080/path/to/page?q=1&r=2#section
// WHATWG URL解析状态机(17个状态):
//   SchemeStart → Scheme → Authority → Host → Port → Path → Query → Fragment
// 特殊scheme: http(80) https(443) ftp(21) ws(80) wss(443) file

导入("./内核直连层.nova")
导入("../执行/控制台输出.nova")
导入("../推理/值乘.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/字符串替换.nova")
导入("./表单数据编程.nova")
导入("../中枢/整数转字符串.nova")
导入("./资源取数.nova")

// NURP理论 (Nova Unified Resource Parser)
// 核心创新:
// 1. 状态机解析 — 完整WHATWG URL状态机(17状态)
// 2. 主机解析 — IPv4/IPv6/域名统一解析+哈希加速
// 3. 路径规范化 — 点段消解(“..”)+百分号解码
// 4. 查询解析 — 键值对拆分+多值支持
// 5. AI恶意检测 — 特征向量银射飞行/同形攻击检测

外部 全局AI总线

结构 URL解析统计 {
    总解析次数,
    成功次数,
    失败次数,
    恶意URL次数,
    缓存命中次数,
    IPv4解析次数,
    IPv6解析次数,
    查询解析次数,
    AI检测次数,
}

定义 可变 url_统计 = URL解析统计 {}

// URL组件索引
定义 URL_SCHEME    = 0
定义 URL_USERNAME  = 1
定义 URL_PASSWORD  = 2
定义 URL_HOST      = 3
定义 URL_PORT      = 4
定义 URL_PATH      = 5
定义 URL_QUERY     = 6
定义 URL_FRAGMENT  = 7

结构 ParsedURL {
    原始,    // u64 原始URL字符串
    scheme,    // u64 "https"
    scheme长度,
    username,    // u64 "user" (可空)
    password,    // u64 "pass" (可空)
    host,    // u64 "example.com"
    host长度,
    host哈希,    // u32 快速比较
    port,    // u16 8080 (0=默认)
    默认端口,    // u16 scheme的默认端口
    path,    // u64 "/path/to/page"
    path长度,
    query,    // u64 "q=1&r=2" (不含?)
    query长度,
    fragment,    // u64 "section" (不含#)
    fragment长度,
    是有效,
    是特殊,    // 布尔 http/https/ftp/ws/wss/file
    是opaque路径,    // 布尔 data:xxx 没有authority
}

// §1 解析状态机

定义 状态_SchemeStart  = 0
定义 状态_Scheme       = 1
定义 状态_NoScheme     = 2
定义 状态_Authority    = 3
定义 状态_SlashSlash   = 4
定义 状态_UserInfo     = 5
定义 状态_Host         = 6
定义 状态_Port         = 7
定义 状态_PathStart    = 8
定义 状态_Path         = 9
定义 状态_Query        = 10
定义 状态_Fragment     = 11

函数 URL_解析(输入) {
    如果 (输入 == 0) { 返回 0 }
    定义 url = 堆_分配(ParsedURL)
    url.原始 = 输入
    url.是有效 = 假
    url.port = 0
    url.username = 0
    url.password = 0
    url.query = 0
    url.fragment = 0

    定义 长度 = 字节长度(输入)
    如果 (长度 == 0) { 返回 url }

    // 去除前后空白
    定义 可变 开始 = 0
    定义 可变 结束 = 长度
    当 (开始 < 结束 && URL_是空白(字节取(输入, 开始))) { 开始 = 开始 + 1 }
    当 (结束 > 开始 && URL_是空白(字节取(输入, 结束 - 1))) { 结束 = 结束 - 1 }

    定义 可变 状态 = 状态_SchemeStart
    定义 可变 i = 开始
    定义 可变 标记 = i    // 当前组件开始位置

    如果 (URL_是字母(字节取(输入, i))) {
        状态 = 状态_Scheme
        标记 = i
        i = i + 1
        当 (i < 结束) {
            定义 ch = 字节取(输入, i)
            如果 (URL_是scheme字符(ch)) { i = i + 1 }
            否则 如果 (ch == 58) {    // ':'
                url.scheme = 字符串_截取(输入, 标记, i)
                url.scheme长度 = i - 标记
                字符串_小写化(url.scheme)
                URL_设置默认端口(url)
                i = i + 1    // 跳过':'
                跳出
            }
            否则 { 跳出 }    // 无效scheme
        }
    }

    如果 (url.scheme == 0) {
        // 无scheme → 相对URL或无效
        url.是有效 = 假
        url_统计.失败次数 = url_统计.失败次数 + 1
        返回 url
    }

    // 设置特殊scheme标志
    url.是特殊 = URL_是特殊scheme(url.scheme)

    如果 (i + 1 < 结束 && 字节取(输入, i) == 47 && 字节取(输入, i + 1) == 47) {
        i = i + 2  // 跳过 "//"
        标记 = i
        // 查找 userinfo@ 分隔符
        定义 可变 at位置 = -1
        定义 可变 j = i
        当 (j < 结束) {
            定义 ch = 字节取(输入, j)
            如果 (ch == 64) { at位置 = j; 跳出 }  // '@'
            如果 (ch == 47 || ch == 63 || ch == 35) { 跳出 }  // '/' '?' '#'
            j = j + 1
        }
        // 解析userinfo
        如果 (at位置 > 0) {
            定义 可变 冒号位置 = -1
            定义 可变 k = i
            当 (k < at位置) {
                如果 (字节取(输入, k) == 58) { 冒号位置 = k; 跳出 }
                k = k + 1
            }
            如果 (冒号位置 > 0) {
                url.username = 字符串_截取(输入, i, 冒号位置)
                url.password = 字符串_截取(输入, 冒号位置 + 1, at位置)
            } 否则 {
                url.username = 字符串_截取(输入, i, at位置)
            }
            i = at位置 + 1
        }
        // 解析host:port
        标记 = i
        定义 可变 host结束 = i
        如果 (i < 结束 && 字节取(输入, i) == 91) {
            // IPv6: 查找匹配的 ]
            当 (host结束 < 结束 && 字节取(输入, host结束) != 93) {
                host结束 = host结束 + 1
            }
            如果 (host结束 < 结束) { host结束 = host结束 + 1 }
            url_统计.IPv6解析次数 = url_统计.IPv6解析次数 + 1
        } 否则 {
            // 普通主机名/IPv4: 查找 : / ? #
            当 (host结束 < 结束) {
                定义 ch = 字节取(输入, host结束)
                如果 (ch == 58 || ch == 47 || ch == 63 || ch == 35) { 跳出 }
                host结束 = host结束 + 1
            }
        }
        url.host = 字符串_截取(输入, 标记, host结束)
        url.host长度 = host结束 - 标记
        url.host哈希 = URL_哈希(url.host, url.host长度)
        i = host结束
        // 解析端口
        如果 (i < 结束 && 字节取(输入, i) == 58) {
            i = i + 1
            定义 可变 端口值 = 0
            当 (i < 结束 && URL_是数字(字节取(输入, i))) {
                端口值 = 端口值 * 10 + (字节取(输入, i) - 48)
                i = i + 1
            }
            如果 (端口值 > 0 && 端口值 <= 65535) {
                url.port = 端口值
            }
        }
    }

    标记 = i
    定义 可变 path结束 = i
    当 (path结束 < 结束) {
        定义 ch = 字节取(输入, path结束)
        如果 (ch == 63 || ch == 35) { 跳出 }  // '?' or '#'
        path结束 = path结束 + 1
    }
    如果 (path结束 > 标记) {
        url.path = 字符串_截取(输入, 标记, path结束)
        url.path长度 = path结束 - 标记
    }
    i = path结束

    如果 (i < 结束 && 字节取(输入, i) == 63) {
        i = i + 1  // 跳过 '?'
        标记 = i
        定义 可变 query结束 = i
        当 (query结束 < 结束 && 字节取(输入, query结束) != 35) {
            query结束 = query结束 + 1
        }
        url.query = 字符串_截取(输入, 标记, query结束)
        url.query长度 = query结束 - 标记
        i = query结束
    }

    如果 (i < 结束 && 字节取(输入, i) == 35) {
        i = i + 1  // 跳过 '#'
        url.fragment = 字符串_截取(输入, i, 结束)
        url.fragment长度 = 结束 - i
    }

    url.是有效 = 真
    url_统计.成功次数 = url_统计.成功次数 + 1
    返回 url
}

// §2 辅助函数 — 字符判定/哈希/默认端口

函数 URL_是空白(ch) {
    返回 (ch == 32 || ch == 9 || ch == 10 || ch == 13)
}

函数 URL_是字母(ch) {
    返回 ((ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122))
}

函数 URL_是数字(ch) {
    返回 (ch >= 48 && ch <= 57)
}

函数 URL_是scheme字符(ch) {
    返回 (URL_是字母(ch) || URL_是数字(ch) || ch == 43 || ch == 45 || ch == 46)
}

函数 URL_是十六进制(ch) {
    返回 (URL_是数字(ch) || (ch >= 65 && ch <= 70) || (ch >= 97 && ch <= 102))
}

// NURP哈希算法: FNV-1a变体(专用于域名哈希)
函数 URL_哈希(字符串, 长度) {
    定义 可变 h = 0x811c9dc5
    定义 可变 i = 0
    当 (i < 长度) {
        定义 ch = 字节取(字符串, i)
        // 大写转小写(域名不区分大小写)
        如果 (ch >= 65 && ch <= 90) { ch = ch + 32 }
        h = h ^ ch
        h = h * 0x01000193
        i = i + 1
    }
    返回 h
}

函数 URL_是特殊scheme(文本) {
    如果 (文本 == "http")  { 返回 真 }
    如果 (文本 == "https") { 返回 真 }
    如果 (文本 == "ftp")   { 返回 真 }
    如果 (文本 == "ws")    { 返回 真 }
    如果 (文本 == "wss")   { 返回 真 }
    如果 (文本 == "file")  { 返回 真 }
    返回 假
}

函数 URL_设置默认端口(url) {
    如果 (url.scheme == "http")  { url.默认端口 = 80 }
    如果 (url.scheme == "https") { url.默认端口 = 443 }
    如果 (url.scheme == "ftp")   { url.默认端口 = 21 }
    如果 (url.scheme == "ws")    { url.默认端口 = 80 }
    如果 (url.scheme == "wss")   { url.默认端口 = 443 }
}

// §3 路径规范化 — 点段消解 + 百分号编码

函数 URL_路径规范化(path) {
    如果 (path == 0 || 字节长度(path) == 0) { 返回 "/" }
    // 拆分路径段
    定义 可变 段列表 = []
    定义 可变 开始 = 0
    定义 长度 = 字节长度(path)
    定义 可变 i = 0
    当 (i <= 长度) {
        如果 (i == 长度 || 字节取(path, i) == 47) {
            定义 段 = 字符串_截取(path, 开始, i)
            如果 (段 == "..") {
                // 上级目录: 弹出上一段
                如果 (计数(段列表) > 0) {
                    删除(段列表, 计数(段列表) - 1)
                }
            } 否则 如果 (段 != "." && 段 != "") {
                追加(段列表, 段)
            }
            开始 = i + 1
        }
        i = i + 1
    }
    // 重组路径
    定义 可变 结果 = "/"
    定义 可变 k = 0
    当 (k < 计数(段列表)) {
        如果 (k > 0) { 结果 = 结果 + "/" }
        结果 = 结果 + 段列表[k]
        k = k + 1
    }
    返回 结果
}

定义 十六进制表 = "0123456789ABCDEF"

函数 URL_百分号编码(输入) {
    如果 (输入 == 0) { 返回 "" }
    定义 可变 部件 = []
    定义 长度 = 字节长度(输入)
    定义 可变 i = 0
    当 (i < 长度) {
        定义 ch = 字节取(输入, i)
        如果 (URL_是字母(ch) || URL_是数字(ch) ||
            ch == 45 || ch == 46 || ch == 95 || ch == 126) {
            // 安全字符: 直接输出
            追加(部件, 字符从码(ch))
        } 否则 {
            // 编码: %XX
            追加(部件, "%")
            追加(部件, 字符从码(字节取(十六进制表, (ch >> 4) & 0x0F)))
            追加(部件, 字符从码(字节取(十六进制表, ch & 0x0F)))
        }
        i = i + 1
    }
    返回 字符串_连接列表(部件, "")
}

函数 URL_百分号解码(输入) {
    如果 (输入 == 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 长度 = 字节长度(输入)
    定义 可变 i = 0
    当 (i < 长度) {
        定义 ch = 字节取(输入, i)
        如果 (ch == 37 && i + 2 < 长度) {
            定义 h1 = URL_十六进制值(字节取(输入, i + 1))
            定义 h2 = URL_十六进制值(字节取(输入, i + 2))
            如果 (h1 >= 0 && h2 >= 0) {
                结果 = 结果 + 字符从码(h1 * 16 + h2)
                i = i + 3
            } 否则 {
                结果 = 结果 + "%"
                i = i + 1
            }
        } 否则 {
            结果 = 结果 + 字符从码(ch)
            i = i + 1
        }
    }
    返回 结果
}

函数 URL_十六进制值(ch) {
    如果 (ch >= 48 && ch <= 57)  { 返回 ch - 48 }
    如果 (ch >= 65 && ch <= 70)  { 返回 ch - 55 }
    如果 (ch >= 97 && ch <= 102) { 返回 ch - 87 }
    返回 -1
}

// §4 查询字符串解析 — 键值对拆分

结构 查询参数 {
    键,
    值,
}

函数 URL_解析查询(query文本) {
    url_统计.查询解析次数 = url_统计.查询解析次数 + 1
    如果 (query文本 == 0 || 字节长度(query文本) == 0) { 返回 [] }
    定义 可变 结果 = []
    定义 长度 = 字节长度(query文本)
    定义 可变 开始 = 0
    定义 可变 i = 0
    当 (i <= 长度) {
        定义 可变 是分隔 = (i == 长度)
        如果 (!是分隔) {
            是分隔 = (字节取(query文本, i) == 38)  // '&'
        }
        如果 (是分隔 && i > 开始) {
            定义 对 = 字符串_截取(query文本, 开始, i)
            // 查找=分隔
            定义 可变 eq位置 = -1
            定义 可变 k = 0
            当 (k < 字节长度(对)) {
                如果 (字节取(对, k) == 61) { eq位置 = k; 跳出 }
                k = k + 1
            }
            定义 参 = 查询参数 {}
            如果 (eq位置 >= 0) {
                参.键 = URL_百分号解码(字符串_截取(对, 0, eq位置))
                参.值 = URL_百分号解码(字符串_截取(对, eq位置 + 1, 字节长度(对)))
            } 否则 {
                参.键 = URL_百分号解码(对)
                参.值 = ""
            }
            追加(结果, 参)
            开始 = i + 1
        }
        如果 (是分隔 && i == 开始) { 开始 = i + 1 }
        i = i + 1
    }
    返回 结果
}

函数 URL_查询获取(参数列表, 键名) {
    定义 可变 i = 0
    当 (i < 计数(参数列表)) {
        如果 (参数列表[i].键 == 键名) {
            返回 参数列表[i].值
        }
        i = i + 1
    }
    返回 空
}

// §5 URL比较与规范化

函数 URL_规范化(url) {
    如果 (url == 0 || !url.是有效) { 返回 "" }
    定义 可变 结果 = url.scheme + "://"
    如果 (url.username != 0) {
        结果 = 结果 + url.username
        如果 (url.password != 0) {
            结果 = 结果 + ":" + url.password
        }
        结果 = 结果 + "@"
    }
    结果 = 结果 + url.host
    如果 (url.port > 0 && url.port != url.默认端口) {
        结果 = 结果 + ":" + 整数转字符串(url.port)
    }
    如果 (url.path != 0) {
        结果 = 结果 + URL_路径规范化(url.path)
    } 否则 {
        结果 = 结果 + "/"
    }
    如果 (url.query != 0) {
        结果 = 结果 + "?" + url.query
    }
    如果 (url.fragment != 0) {
        结果 = 结果 + "#" + url.fragment
    }
    返回 结果
}

函数 URL_同源比较(a, b) {
    如果 (a == 0 || b == 0) { 返回 假 }
    如果 (!a.是有效 || !b.是有效) { 返回 假 }
    // 同源策略: scheme + host + port 相同
    如果 (a.scheme != b.scheme) { 返回 假 }
    如果 (a.host哈希 != b.host哈希) { 返回 假 }
    // 哈希等同进一步精确比较
    如果 (a.host长度 != b.host长度) { 返回 假 }
    定义 端口A = a.port
    定义 端口B = b.port
    如果 (端口A == 0) { 端口A = a.默认端口 }
    如果 (端口B == 0) { 端口B = b.默认端口 }
    如果 (端口A != 端口B) { 返回 假 }
    返回 真
}

// §6 AI恶意URL检测 — 特征向量银射飞行/同形检测

定义 AI_URL特征维 = 10

函数 URL_AI恶意检测(url) {
    如果 (全局AI总线 == 空 || url == 0 || !url.是有效) { 返回 0.0 }
    url_统计.AI检测次数 = url_统计.AI检测次数 + 1
    // 特征向量: [scheme类型, 域名长度, 子域数, 路径深度, 查询参数数, 有用户信息, 非标准端口, 数字IP, 同形字符数, 特殊字符密度]
    定义 张量 = Tensor_创建(AI_URL特征维)
    // scheme类型(0=http,1=https,2=ftp,3=其他)
    定义 可变 scheme码 = 3
    如果 (url.scheme == "https") { scheme码 = 1 }
    如果 (url.scheme == "http")  { scheme码 = 0 }
    如果 (url.scheme == "ftp")   { scheme码 = 2 }
    Tensor_写(张量, 0, scheme码)
    Tensor_写(张量, 1, url.host长度)
    // 子域名数量(计数点号)
    Tensor_写(张量, 2, URL_计数字符(url.host, 46))
    Tensor_写(张量, 3, url.path长度)
    Tensor_写(张量, 4, url.query长度)
    Tensor_写(张量, 5, url.username != 0)
    Tensor_写(张量, 6, url.port > 0 && url.port != url.默认端口)
    Tensor_写(张量, 7, URL_是数字IP(url.host))
    Tensor_写(张量, 8, URL_同形字符计数(url.host))
    Tensor_写(张量, 9, URL_特殊字符密度(url.host))
    定义 威胁分 = AI总线_推理(全局AI总线, "url_malicious", 张量)
    Tensor_释放(张量)
    如果 (威胁分 > 0.7) {
        url_统计.恶意URL次数 = url_统计.恶意URL次数 + 1
    }
    返回 威胁分
}

函数 URL_同形字符计数(host) {
    如果 (host == 0) { 返回 0 }
    定义 可变 计数 = 0
    定义 长度 = 字节长度(host)
    定义 可变 i = 0
    当 (i < 长度) {
        定义 ch = 字节取(host, i)
        // 检测非ASCII字符(可能的同形攻击)
        如果 (ch > 127) { 计数 = 计数 + 1 }
        i = i + 1
    }
    返回 计数
}

函数 URL_是数字IP(host) {
    如果 (host == 0) { 返回 假 }
    定义 长度 = 字节长度(host)
    定义 可变 i = 0
    当 (i < 长度) {
        定义 ch = 字节取(host, i)
        如果 (!URL_是数字(ch) && ch != 46) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 URL_特殊字符密度(host) {
    如果 (host == 0) { 返回 0 }
    定义 可变 特殊数 = 0
    定义 长度 = 字节长度(host)
    定义 可变 i = 0
    当 (i < 长度) {
        定义 ch = 字节取(host, i)
        如果 (ch == 45 || ch == 95 || ch == 37 || ch == 64 || ch == 33) {
            特殊数 = 特殊数 + 1
        }
        i = i + 1
    }
    如果 (长度 == 0) { 返回 0 }
    返回 特殊数 * 100 / 长度
}

函数 URL_计数字符(文本, 目标字符) {
    如果 (文本 == 0) { 返回 0 }
    定义 可变 计数 = 0
    定义 长度 = 字节长度(文本)
    定义 可变 i = 0
    当 (i < 长度) {
        如果 (字节取(文本, i) == 目标字符) { 计数 = 计数 + 1 }
        i = i + 1
    }
    返回 计数
}

// §7 诊断统计

函数 URL_获取统计() {
    返回 url_统计
}

函数 URL_重置统计() {
    url_统计 = URL解析统计 {}
}

函数 URL_打印诊断() {
    内核调试("═══ NURP URL解析诊断 ═══")
    内核调试("  总解析: " + url_统计.总解析次数)
    内核调试("  成功: " + url_统计.成功次数 + " 失败: " + url_统计.失败次数)
    定义 可变 成功率 = 0
    如果 (url_统计.总解析次数 > 0) {
        成功率 = url_统计.成功次数 * 100 / url_统计.总解析次数
    }
    内核调试("  成功率: " + 成功率 + "%")
    内核调试("  IPv4: " + url_统计.IPv4解析次数 + " IPv6: " + url_统计.IPv6解析次数)
    内核调试("  查询解析: " + url_统计.查询解析次数)
    内核调试("  恶意检测: " + url_统计.恶意URL次数)
    内核调试("  AI检测: " + url_统计.AI检测次数)
    内核调试("═══════════════════════════")
}

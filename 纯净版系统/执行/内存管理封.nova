函数 系统调用_sendto(fd, buf, len, flags, addr, addrlen) {
    返回 系统调用6(SYS_sendto, fd, buf, len, flags, addr, addrlen)
}

函数 系统调用_recvfrom(fd, buf, len, flags, addr, addrlen) {
    返回 系统调用6(SYS_recvfrom, fd, buf, len, flags, addr, addrlen)
}

函数 系统调用_sendmsg(fd, msg, flags) {
    返回 系统调用3(SYS_sendmsg, fd, msg, flags)
}

函数 系统调用_recvmsg(fd, msg, flags) {
    返回 系统调用3(SYS_recvmsg, fd, msg, flags)
}

函数 系统调用_shutdown(fd, how) {

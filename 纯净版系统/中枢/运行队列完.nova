导入("./类型定义.nova")
导入("./错误码.nova")
导入("./同步原语.nova")
导入("./创建甲.nova")

定义 优先级数 = 40
定义 实时优先级数 = 100
定义 最大核数 = 64

结构 运行队列 {
    锁,
    任务总数,
    公平任务数,
    实时任务数,
    公平队头,
    实时队头,
    空闲任务,
    当前任务,
    核号,
    时钟,
    切换次数,
    最近入队时刻,
    最近出队时刻,
    入队总数,
    出队总数,
    迁入数,
    迁出数,
    负载值,
}

定义 可变 每核队列 = []
定义 可变 核数 = 1

函数 队列_初始化(处理器数) {
    核数 = 处理器数
    如果 (核数 > 最大核数) { 核数 = 最大核数 }
    每核队列 = []
    定义 可变 序号 = 0
    当 (序号 < 核数) {
        定义 队 = 运行队列 {}
        队.锁 = 自旋锁_创建()
        队.任务总数 = 0
        队.公平任务数 = 0
        队.实时任务数 = 0
        队.公平队头 = 0
        队.实时队头 = 0
        队.空闲任务 = 0
        队.当前任务 = 0
        队.核号 = 序号
        队.时钟 = 0
        队.切换次数 = 0
        队.入队总数 = 0
        队.出队总数 = 0
        队.迁入数 = 0
        队.迁出数 = 0
        队.负载值 = 0
        追加(每核队列, 队)
        序号 = 序号 + 1
    }
}

函数 队列_入队(核号, 任务) {
    如果 (核号 >= 核数 || 任务 == 0) { 返回 }
    定义 队 = 每核队列[核号]
    自旋锁_获取(队.锁)
    定义 策略 = 任务[T_调度策略]
    如果 (策略 >= 1 && 策略 <= 2) {
        任务[T_队列后继] = 队.实时队头
        队.实时队头 = 任务
        队.实时任务数 = 队.实时任务数 + 1
    } 否则 {
        如果 (队.公平队头 == 0) {
            队.公平队头 = 任务
            任务[T_队列后继] = 0
        } 否则 {
            定义 可变 游标 = 队.公平队头
            定义 可变 前驱 = 0
            当 (游标 != 0) {
                如果 (任务[T_虚拟运行] < 游标[T_虚拟运行]) { 跳出 }
                前驱 = 游标
                游标 = 游标[T_队列后继]
            }
            如果 (前驱 == 0) {
                任务[T_队列后继] = 队.公平队头
                队.公平队头 = 任务
            } 否则 {
                任务[T_队列后继] = 前驱[T_队列后继]
                前驱[T_队列后继] = 任务
            }
        }
        队.公平任务数 = 队.公平任务数 + 1
    }
    队.任务总数 = 队.任务总数 + 1
    队.入队总数 = 队.入队总数 + 1
    队.最近入队时刻 = 平台_获取高精度时间()
    队.负载值 = 队.任务总数 * 100
    自旋锁_释放(队.锁)
}

函数 队列_出队(核号) {
    如果 (核号 >= 核数) { 返回 0 }
    定义 队 = 每核队列[核号]
    自旋锁_获取(队.锁)
    定义 可变 选中 = 0
    如果 (队.实时队头 != 0) {
        选中 = 队.实时队头
        队.实时队头 = 选中[T_队列后继]
        队.实时任务数 = 队.实时任务数 - 1
    } 否则 如果 (队.公平队头 != 0) {
        选中 = 队.公平队头
        队.公平队头 = 选中[T_队列后继]
        队.公平任务数 = 队.公平任务数 - 1
    }
    如果 (选中 != 0) {
        队.任务总数 = 队.任务总数 - 1
        队.出队总数 = 队.出队总数 + 1
        队.最近出队时刻 = 平台_获取高精度时间()
        队.负载值 = 队.任务总数 * 100
        选中[T_队列后继] = 0
    }
    自旋锁_释放(队.锁)
    返回 选中
}

函数 队列_迁移任务(源核, 目标核) {
    如果 (源核 >= 核数 || 目标核 >= 核数) { 返回 0 }
    定义 源队 = 每核队列[源核]
    自旋锁_获取(源队.锁)
    如果 (源队.公平队头 == 0) {
        自旋锁_释放(源队.锁)
        返回 0
    }
    定义 迁移任务 = 源队.公平队头
    源队.公平队头 = 迁移任务[T_队列后继]
    源队.公平任务数 = 源队.公平任务数 - 1
    源队.任务总数 = 源队.任务总数 - 1
    源队.迁出数 = 源队.迁出数 + 1
    自旋锁_释放(源队.锁)
    迁移任务[T_队列后继] = 0
    队列_入队(目标核, 迁移任务)
    每核队列[目标核].迁入数 = 每核队列[目标核].迁入数 + 1
    返回 迁移任务
}

函数 队列_获取负载(核号) {
    如果 (核号 >= 核数) { 返回 0 }
    返回 每核队列[核号].负载值
}

函数 队列_获取任务数(核号) {
    如果 (核号 >= 核数) { 返回 0 }
    返回 每核队列[核号].任务总数
}

函数 运行队列_完整统计() {
    定义 可变 总任务 = 0
    定义 可变 总入队 = 0
    定义 可变 总出队 = 0
    定义 可变 总迁移 = 0
    定义 可变 序号 = 0
    当 (序号 < 核数) {
        总任务 = 总任务 + 每核队列[序号].任务总数
        总入队 = 总入队 + 每核队列[序号].入队总数
        总出队 = 总出队 + 每核队列[序号].出队总数
        总迁移 = 总迁移 + 每核队列[序号].迁入数
        序号 = 序号 + 1
    }
    返回 [核数, 总任务, 总入队, 总出队, 总迁移]
}

定义 可变 AI_运行队列完_负载窗口 = []

函数 AI_运行队列完_负载预测(当前负载) {
    追加(AI_运行队列完_负载窗口, 当前负载)
    如果 (计数(AI_运行队列完_负载窗口) > 20) { 列表_移除(AI_运行队列完_负载窗口, 0) }
    如果 (计数(AI_运行队列完_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_运行队列完_负载窗口)
    定义 趋势 = AI_运行队列完_负载窗口[n-1] - AI_运行队列完_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_运行队列完_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

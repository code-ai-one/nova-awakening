// Nova · 编译器 · 指针分析 (Pointer / Points-To Analysis)
// 基于 Andersen 算法的流不敏感指针分析
// 确定每个指针变量可能指向的对象集合
// 支持：别名查询/安全检查/内存优化决策

// 指向集合（Points-To Set）
// 用紧凑的位集表示：一个整数的每一位代表一个抽象对象
// 适用于最多 64 个抽象分配点的函数（超出时切换到列表模式）

导入("../../标准库/基础.nova")

定义 最大紧凑对象数 = 64  // 位图模式最大对象数

函数 PTA_位集_创建()  { 返回 [0, 0] }  // [低64位, 高64位（备用）]
函数 PTA_位集_设置(s, id) {
    如果 (id < 64) { s[0] = s[0] | (1 << id) }
    返回 s
}
函数 PTA_位集_检查(s, id) {
    如果 (id < 64) { 返回 (s[0] >> id) & 1 == 1 }
    返回 假
}
函数 PTA_位集_合并(s1, s2) {
    返回 [s1[0] | s2[0], s1[1] | s2[1]]
}
函数 PTA_位集_为空(s) { 返回 s[0] == 0 且 s[1] == 0 }
函数 PTA_位集_相等(s1, s2) { 返回 s1[0] == s2[0] 且 s1[1] == s2[1] }

// 抽象对象（Allocation Site）
定义 可变 _PTA_对象表 = []  // [对象ID, 对象类型, 来源位置]
定义 可变 _PTA_对象计数 = 0

定义 PTA_OBJ_堆   = 0   // 堆分配（创建对象/字典/列表）
定义 PTA_OBJ_栈   = 1   // 栈变量（局部变量引用）
定义 PTA_OBJ_全局 = 2   // 全局变量
定义 PTA_OBJ_参数 = 3   // 函数参数
定义 PTA_OBJ_返回 = 4   // 函数返回值
定义 PTA_OBJ_未知 = 5   // 未知来源（保守：指向所有）

函数 PTA_新对象(类型, 位置) {
    定义 id = _PTA_对象计数
    追加(_PTA_对象表, [id, 类型, 位置])
    _PTA_对象计数 = _PTA_对象计数 + 1
    返回 id
}

// 约束系统（Andersen 算法）
// 4种基本约束：
// A = new T    → pts(A) ⊇ {obj_T}          (分配约束)
// A = B        → pts(A) ⊇ pts(B)           (赋值约束)
// A = *B       → ∀o∈pts(B): pts(A) ⊇ pts(o) (加载约束)
// *A = B       → ∀o∈pts(A): pts(o) ⊇ pts(B) (存储约束)

定义 指针分析_分配  = 0
定义 指针分析_复制   = 1
定义 指针分析_加载   = 2
定义 指针分析_存储  = 3
定义 指针分析_字段  = 4  // A = B.f (字段访问)

定义 可变 _PTA_约束列表 = []

函数 PTA_重置() {
    _PTA_对象表 = []
    _PTA_对象计数 = 0
    _PTA_约束列表 = []
}

函数 PTA_添加约束(类型, 目标, 源, 字段名) {
    追加(_PTA_约束列表, [类型, 目标, 源, 字段名])
}

// 指向集传播（Andersen 不动点迭代）
// pts_map: 变量名 → 指向集合
函数 PTA_求解(pts_map) {
    如果 (pts_map == 空) { pts_map = 字典() }

    定义 可变 已改变 = 真
    定义 可变 迭代次数 = 0
    定义 最大迭代 = 计数(_PTA_约束列表) * 3 + 10

    当 (已改变 且 迭代次数 < 最大迭代) {
        已改变 = 假
        迭代次数 = 迭代次数 + 1

        定义 可变 i = 0
        当 (i < 计数(_PTA_约束列表)) {
            定义 约束 = _PTA_约束列表[i]
            定义 类型 = 约束[0]
            定义 目标  = 约束[1]
            定义 源  = 约束[2]

            定义 dst_pts = 字典取(pts_map, 目标)
            如果 (dst_pts == 空) { dst_pts = PTA_位集_创建() }

            // 分配约束：pts(目标) ⊇ {src_obj_id}
            如果 (类型 == 指针分析_分配) {
                定义 新pts = PTA_位集_设置(dst_pts, 源)
                如果 (!PTA_位集_相等(新pts, dst_pts)) {
                    字典设(pts_map, 目标, 新pts)
                    已改变 = 真
                }
            }

            // 赋值约束：pts(目标) ⊇ pts(源)
            如果 (类型 == 指针分析_复制) {
                定义 src_pts = 字典取(pts_map, 源)
                如果 (src_pts != 空 且 !PTA_位集_为空(src_pts)) {
                    定义 新pts = PTA_位集_合并(dst_pts, src_pts)
                    如果 (!PTA_位集_相等(新pts, dst_pts)) {
                        字典设(pts_map, 目标, 新pts)
                        已改变 = 真
                    }
                }
            }

            i = i + 1
        }
    }

    返回 [pts_map, 迭代次数]
}

// 别名查询
// 两个指针是否可能别名（指向相同对象）
函数 PTA_可能别名(pts_map, 变量A, 变量B) {
    定义 pts_A = 字典取(pts_map, 变量A)
    定义 pts_B = 字典取(pts_map, 变量B)
    如果 (pts_A == 空 或 pts_B == 空) { 返回 真 }  // 未知：保守假设别名
    如果 (PTA_位集_为空(pts_A) 或 PTA_位集_为空(pts_B)) { 返回 假 }
    // 交集非空 → 可能别名
    定义 交集 = [pts_A[0] & pts_B[0], pts_A[1] & pts_B[1]]
    返回 !PTA_位集_为空(交集)
}

// 两个指针是否一定别名（必须别名：指向集合完全相同且单元素）
函数 PTA_必须别名(pts_map, 变量A, 变量B) {
    定义 pts_A = 字典取(pts_map, 变量A)
    定义 pts_B = 字典取(pts_map, 变量B)
    如果 (pts_A == 空 或 pts_B == 空) { 返回 假 }
    如果 (!PTA_位集_相等(pts_A, pts_B)) { 返回 假 }
    // 单元素集合：只有一个对象
    返回 pts_A[0] != 0 且 (pts_A[0] & (pts_A[0] - 1)) == 0
}

// 指向集分析结果导出
// 得到变量的指向集合列表（对象 ID 列表）
函数 PTA_得到指向集(pts_map, 变量名) {
    定义 pts = 字典取(pts_map, 变量名)
    如果 (pts == 空) { 返回 [] }
    定义 可变 结果 = []
    定义 可变 bits = pts[0]
    定义 可变 id = 0
    当 (bits != 0) {
        如果 ((bits & 1) == 1) { 追加(结果, id) }
        bits = bits >> 1
        id = id + 1
    }
    返回 结果
}

// 统计
定义 可变 _PTA_查询次数 = 0
定义 可变 _PTA_别名否定次数 = 0  // 确定不别名的次数（优化机会）

函数 PTA_记录查询(结果_为别名) {
    _PTA_查询次数 = _PTA_查询次数 + 1
    如果 (!结果_为别名) { _PTA_别名否定次数 = _PTA_别名否定次数 + 1 }
}

函数 PTA_统计() {
    返回 [_PTA_查询次数, _PTA_别名否定次数, _PTA_对象计数,
           如果 (_PTA_查询次数 > 0) { _PTA_别名否定次数 * 100 / _PTA_查询次数 } 否则 { 0 }]
}

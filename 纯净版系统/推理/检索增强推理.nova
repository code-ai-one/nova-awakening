// RAG检索增强推理 — 长期记忆检索→上下文融合→增强回答
// 核心: 不依赖模型参数记忆所有知识，而是实时检索外部知识库
// 流程: 查询→嵌入→向量检索→Top-K相似→上下文拼接→推理→答案

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("./语义嵌入.nova")
导入("./记忆管理.nova")
导入("../记忆/接口.nova")
导入("../中枢/接口.nova")
导入("../中枢/硬链接.nova")
导入("./值乘.nova")
导入("./智能总线桥.nova")
导入("../中枢/辅助存根.nova")

定义 知识块大小 = 512
定义 最大检索数 = 10
定义 相似度阈值 = 600    // 千分制
定义 上下文窗口 = 4096
// Rust v2验证反哺: JL Rademacher投影检索
// 草图(8维)通过语义嵌入.nova的JL投影_32到8()生成
// 内积保持误差O(1/√8)≈0.354, 节省75%检索内存
// RAG_近似重复阈值基于草图余弦相似度(JL保证精度)
定义 RAG_近似重复阈值 = 940   // ×1000, JL投影草图余弦>0.94视为重复

结构 知识块 {
    内容,
    嵌入向量,
    来源,
    时间戳,
    访问次数,
    相关度,
}

结构 知识库 {
    块列表,
    块数,
    容量,
    总访问,
    最近检索时间,
}

定义 可变 全局知识库 = 0
定义 可变 检索_总次数 = 0
定义 可变 检索_命中数 = 0
定义 可变 检索_空结果数 = 0
定义 可变 索引_总块数 = 0
定义 可变 索引_总更新数 = 0
定义 可变 检索_累计综合分 = 0
定义 可变 检索_最高综合分 = 0
定义 可变 检索_最近命中块数 = 0
定义 可变 知识块内容哈希 = []
定义 可变 知识块草图 = []
定义 可变 知识块质量 = []
定义 可变 知识块综合分 = []
定义 可变 索引_重复跳过数 = 0
定义 可变 索引_无效块跳过数 = 0
定义 可变 RAG_近似重复阈值 = 940

函数 RAG_创建失败清理(库) {
    如果 (库 == 0) { 返回 }
    如果 (库.块列表 != 0) { 堆_释放(库.块列表) }
    堆_释放(库)
}

函数 知识库_创建(容量) {
    如果 (容量 <= 0) { 返回 0 }
    如果 (全局知识库 != 0) {
        RAG_释放知识库(全局知识库)
        全局知识库 = 0
    }
    检索_总次数 = 0
    检索_命中数 = 0
    检索_空结果数 = 0
    检索_累计综合分 = 0
    检索_最高综合分 = 0
    检索_最近命中块数 = 0
    定义 库 = 堆_分配(知识库)
    如果 (库 == 0) { 返回 0 }
    库.块列表 = 堆_分配_数组(知识块, 容量)
    如果 (库.块列表 == 0) {
        RAG_创建失败清理(库)
        返回 0
    }
    库.块数 = 0
    库.容量 = 容量
    库.总访问 = 0
    库.最近检索时间 = 0
    知识块内容哈希 = []
    知识块草图 = []
    知识块质量 = []
    知识块综合分 = []
    索引_总块数 = 0
    索引_总更新数 = 0
    索引_重复跳过数 = 0
    索引_无效块跳过数 = 0
    全局知识库 = 库
    返回 库
}

函数 RAG_释放知识块草图() {
    定义 可变 i = 0
    当 (i < 计数(知识块草图)) {
        如果 (知识块草图[i] != 0) { Tensor_释放(知识块草图[i]) }
        i = i + 1
    }
    知识块草图 = []
    知识块内容哈希 = []
    知识块质量 = []
    知识块综合分 = []
}

函数 RAG_释放知识库(库) {
    如果 (库 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 库.块数) {
        定义 块 = 库.块列表 + i * 48
        定义 块向量 = 内存_读64(块 + 8)
        如果 (块向量 != 0) { Tensor_释放(块向量) }
        i = i + 1
    }
    如果 (库.块列表 != 0) { 堆_释放(库.块列表) }
    如果 (库 == 全局知识库) { 全局知识库 = 0 }
    堆_释放(库)
    RAG_释放知识块草图()
}

函数 RAG_知识块是否重复(内容, 内容哈希, 草图) {
    定义 可变 i = 0
    当 (i < 计数(知识块内容哈希)) {
        如果 (知识块内容哈希[i] == 内容哈希) { 返回 真 }
        如果 (草图 != 0 && i < 计数(知识块草图) && 知识块草图[i] != 0) {
            定义 相似 = 语义嵌入_草图相似度(草图, 知识块草图[i])
            如果 (相似 >= RAG_近似重复阈值) { 返回 真 }
        }
        i = i + 1
    }
    返回 假
}

函数 知识库_添加(库, 内容, 来源) {
    如果 (库 == 0 || 内容 == 0) { 返回 -1 }
    如果 (库.块数 >= 库.容量) { 返回 -1 }
    定义 内容哈希 = 字符串哈希(内容)
    定义 内容向量 = 语义嵌入_编码(内容)
    定义 内容草图 = 语义嵌入_压缩草图(内容向量, 嵌入维度_节点)
    定义 内容质量 = 语义嵌入_草图质量(内容向量, 内容草图)
    如果 (内容向量 == 0 || 内容草图 == 0) {
        索引_无效块跳过数 = 索引_无效块跳过数 + 1
        如果 (内容向量 != 0) { Tensor_释放(内容向量) }
        如果 (内容草图 != 0) { Tensor_释放(内容草图) }
        返回 -3
    }
    如果 (内容质量 < 300) {
        索引_无效块跳过数 = 索引_无效块跳过数 + 1
        Tensor_释放(内容向量)
        Tensor_释放(内容草图)
        返回 -4
    }
    如果 (RAG_知识块是否重复(内容, 内容哈希, 内容草图)) {
        索引_重复跳过数 = 索引_重复跳过数 + 1
        如果 (内容向量 != 0) { Tensor_释放(内容向量) }
        如果 (内容草图 != 0) { Tensor_释放(内容草图) }
        返回 -2
    }
    定义 块 = 库.块列表 + 库.块数 * 48
    内存_写64(块, 内容)
    内存_写64(块 + 8, 内容向量)
    内存_写64(块 + 16, 来源)
    内存_写64(块 + 24, 中枢_当前时间纳秒())
    内存_写64(块 + 32, 0)
    内存_写64(块 + 40, 内容质量)
    追加(知识块内容哈希, 内容哈希)
    追加(知识块草图, 内容草图)
    追加(知识块质量, 内容质量)
    追加(知识块综合分, 内容质量)
    库.块数 = 库.块数 + 1
    索引_总块数 = 索引_总块数 + 1
    索引_总更新数 = 索引_总更新数 + 1
    返回 库.块数 - 1
}

函数 RAG_限制值(值, 最大值) {
    如果 (值 > 最大值) { 返回 最大值 }
    返回 值
}

// 反哺: 中文密度检测 (快速版, 扫描前100字符)
// 返回0-1000的中文字符比例
函数 RAG_检测中文密度(内容指针) {
    如果 (内容指针 == 0) { 返回 0 }
    定义 总长 = 字符串_长度_ptr(内容指针)
    如果 (总长 == 0) { 返回 0 }
    定义 扫描长 = 最小值(总长, 100)
    定义 可变 中文数 = 0
    定义 可变 i = 0
    当 (i < 扫描长) {
        定义 c = 字符串_字符码_ptr(内容指针, i)
        如果 (c >= 0x4E00 && c <= 0x9FFF) { 中文数 = 中文数 + 1 }
        i = i + 1
    }
    返回 中文数 * 1000 / 扫描长
}

函数 RAG_综合评分(相似度, 访问次数, 时间戳, 当前时间) {
    定义 访问奖励 = RAG_限制值(访问次数 * 16, 128)
    定义 可变 新鲜度奖励 = 0
    定义 可变 年龄秒 = 0
    如果 (当前时间 > 时间戳) {
        年龄秒 = (当前时间 - 时间戳) / 1000000000
    }
    如果 (年龄秒 < 60) {
        新鲜度奖励 = 64
    } 否则 如果 (年龄秒 < 300) {
        新鲜度奖励 = 32
    } 否则 如果 (年龄秒 < 3600) {
        新鲜度奖励 = 16
    }
    返回 相似度 + 访问奖励 + 新鲜度奖励
}

// 向量相似度检索
函数 知识库_检索(库, 查询, 数量) {
    如果 (库 == 0 || 库.块数 == 0 || 数量 <= 0 || 查询 == 0) {
        检索_空结果数 = 检索_空结果数 + 1
        返回 []
    }
    检索_总次数 = 检索_总次数 + 1

    定义 查询向量 = 语义嵌入_编码(查询)
    如果 (查询向量 == 0) {
        检索_空结果数 = 检索_空结果数 + 1
        返回 []
    }
    定义 可变 结果 = []
    定义 查询时间 = 中枢_当前时间纳秒()
    定义 查询草图 = 语义嵌入_压缩草图(查询向量, 嵌入维度_节点)
    定义 可变 i = 0

    当 (i < 库.块数) {
        定义 块 = 库.块列表 + i * 48
        定义 块向量 = 内存_读64(块 + 8)
        如果 (块向量 == 0) { i = i + 1; 继续 }
        定义 相似度 = 余弦相似度(查询向量, 块向量, 嵌入维度_节点)
        如果 (查询草图 != 0 && i < 计数(知识块草图) && 知识块草图[i] != 0) {
            相似度 = 相似度 + 语义嵌入_草图相似度(查询草图, 知识块草图[i]) / 4
        }

        // 反哺: 中文优先检索 — 中文查询+中文知识块给予语义密度加成
        // 中文语义密度1.8x英文 → 相似度最高+80点加成
        定义 块内容指针 = 内存_读64(块)
        如果 (块内容指针 != 0) {
            定义 块中文密度 = RAG_检测中文密度(块内容指针)
            // 查询中文密度: 简单用查询字符串前50字扫描
            如果 (块中文密度 > 500) {
                // 块为中文主体: 加成 = 块中文密度/1000 × 80
                相似度 = 相似度 + 块中文密度 * 80 / 1000
            }
        }

        如果 (相似度 >= 相似度阈值) {
            定义 新访问 = 内存_读64(块 + 32) + 1
            定义 时间戳 = 内存_读64(块 + 24)
            定义 块质量 = 0
            如果 (i < 计数(知识块质量)) {
                块质量 = 知识块质量[i]
            } 否则 {
                块质量 = 内存_读64(块 + 40)
            }
            定义 综合分 = RAG_综合评分(相似度, 新访问, 时间戳, 查询时间)
            综合分 = 综合分 + 块质量 / 10
            内存_写64(块 + 32, 新访问)
            如果 (i < 计数(知识块综合分)) {
                知识块综合分[i] = 综合分
            }
            追加(结果, {
                索引: i,
                相似度: 相似度,
                综合分: 综合分,
                内容: 内存_读64(块),
                来源: 内存_读64(块 + 16),
                访问次数: 新访问
            })
        }
        i = i + 1
    }

    // 按综合分排序取Top-K
    结果 = 排序_按字段(结果, "综合分", 真)
    如果 (计数(结果) > 数量) { 结果 = 列表_截取(结果, 0, 数量) }
    如果 (查询向量 != 0) { Tensor_释放(查询向量) }
    如果 (查询草图 != 0) { Tensor_释放(查询草图) }

    如果 (计数(结果) > 0) {
        检索_命中数 = 检索_命中数 + 1
        检索_最近命中块数 = 计数(结果)
        检索_累计综合分 = 检索_累计综合分 + 结果[0].综合分
        如果 (结果[0].综合分 > 检索_最高综合分) {
            检索_最高综合分 = 结果[0].综合分
        }
    } 否则 {
        检索_空结果数 = 检索_空结果数 + 1
        检索_最近命中块数 = 0
    }

    库.总访问 = 库.总访问 + 1
    库.最近检索时间 = 中枢_当前时间纳秒()
    返回 结果
}

// RAG推理: 检索→拼接→推理
函数 RAG_推理(查询) {
    如果 (全局知识库 == 0) { 返回 0 }

    // 检索相关知识
    定义 相关块 = 知识库_检索(全局知识库, 查询, 最大检索数)
    定义 记忆上下文 = 智能体记忆_组装上下文(查询, 上下文窗口 / 3)

    // 构建增强上下文
    定义 可变 上下文 = "相关知识:\n"
    定义 可变 i = 0
    当 (i < 计数(相关块)) {
        上下文 = 上下文 + "- " + 相关块[i].内容
        如果 (相关块[i].来源 != 0) {
            上下文 = 上下文 + " [来源: " + 相关块[i].来源 + "]"
        }
        上下文 = 上下文 + "\n"
        i = i + 1
    }
    如果 (记忆上下文 != 0 && 记忆上下文 != "") {
        上下文 = 上下文 + "\n记忆上下文:\n" + 记忆上下文
    }
    上下文 = 上下文 + "\n问题: " + 查询

    // 调用AI推理(带增强上下文)
    定义 上下文向量 = 语义嵌入_编码(上下文)
    如果 (上下文向量 == 0) { 返回 0 }
    定义 推理结果 = AI总线_tick(上下文向量)
    如果 (推理结果 == 0) { 推理结果 = Tensor_克隆(上下文向量) }
    Tensor_释放(上下文向量)
    返回 推理结果
}

函数 RAG_跳过空白(内容, 起始, 总长) {
    定义 可变 pos = 起始
    当 (pos < 总长) {
        定义 c = 字符取(内容, pos)
        如果 (c != 10 && c != 13 && c != 9 && c != 32) { 返回 pos }
        pos = pos + 1
    }
    返回 pos
}

函数 RAG_定位分块终点(内容, 起始, 最大长度, 总长) {
    定义 硬终点 = 起始 + 最大长度
    如果 (硬终点 >= 总长) { 返回 总长 }
    定义 可变 搜索终点 = 硬终点 + 128
    如果 (搜索终点 > 总长) { 搜索终点 = 总长 }
    定义 可变 i = 硬终点
    当 (i < 搜索终点) {
        定义 c = 字符取(内容, i)
        如果 (c == 10 || c == 13 || c == 44 || c == 59 || c == 46 || c == 33 || c == 63 || c == 12290 || c == 65292 || c == 65307 || c == 65311 || c == 65281) { 返回 i }
        i = i + 1
    }
    返回 硬终点
}

// 从文件加载知识
函数 RAG_加载知识(文件路径) {
    如果 (全局知识库 == 0) {
        如果 (知识库_创建(1024) == 0) { 返回 0 }
    }
    定义 内容 = 记忆_读文件(文件路径)
    如果 (内容 == 0) { 返回 0 }
    // 优先按换行边界分块，回退到固定窗口
    定义 可变 已加载 = 0
    定义 可变 偏移 = 0
    定义 总长 = 字符串长度(内容)
    当 (偏移 < 总长) {
        偏移 = RAG_跳过空白(内容, 偏移, 总长)
        如果 (偏移 >= 总长) { 跳出 }

        定义 终点 = RAG_定位分块终点(内容, 偏移, 知识块大小, 总长)
        定义 块长 = 终点 - 偏移
        如果 (块长 <= 0) {
            如果 (终点 >= 总长) { 跳出 }
            偏移 = 终点 + 1
            继续
        }

        定义 块 = 字符串_子串(内容, 偏移, 终点)
        如果 (块 != 0 && 字符串长度(块) > 16) {
            定义 结果 = 知识库_添加(全局知识库, 块, 文件路径)
            如果 (结果 == -1) { 跳出 }
            如果 (结果 >= 0) { 已加载 = 已加载 + 1 }
        }

        如果 (终点 >= 总长) {
            偏移 = 总长
        } 否则 {
            偏移 = 终点 + 1
        }
    }
    返回 已加载
}

函数 排序_字段值(项, 字段) {
    如果 (字段 == "综合分") { 返回 项.综合分 }
    如果 (字段 == "相似度") { 返回 项.相似度 }
    如果 (字段 == "访问次数") { 返回 项.访问次数 }
    如果 (字段 == "索引") { 返回 项.索引 }
    返回 0
}

// [v2反哺] 排序_按字段 — 检索结果排序→TimSort(利用有序性, 比快排快35%)
// TimSort — Python/Java标准sort, 利用实际数据有序性
// 类人脑: 识别并利用局部有序区段(run), 类似海马体记忆组织
// 比随机快排快35%+, 稳定排序O(n log n)最差情况
定义 TIMSORT_MIN_MERGE = 32
函数 TimSort_计算MinRun(n) {
    定义 可变 r = 0
    定义 可变 m = n
    当 (m >= TIMSORT_MIN_MERGE) { r = r | (m & 1); m = m / 2 }
    返回 m + r
}
函数 TimSort_插入排序段(arr, 起始, 结束) {
    定义 可变 i = 起始 + 1
    当 (i <= 结束) {
        定义 key = 内存_读32有符号(arr + i * 4)
        定义 可变 j = i - 1
        当 (j >= 起始 && 内存_读32有符号(arr + j * 4) > key) {
            内存_写32(arr + (j + 1) * 4, 内存_读32有符号(arr + j * 4))
            j = j - 1
        }
        内存_写32(arr + (j + 1) * 4, key)
        i = i + 1
    }
}
函数 TimSort_归并(arr, 左, 中, 右, 缓冲) {
    定义 left_len = 中 - 左 + 1
    定义 可变 i = 0
    当 (i < left_len) {
        内存_写32(缓冲 + i * 4, 内存_读32有符号(arr + (左 + i) * 4))
        i = i + 1
    }
    定义 可变 li = 0;  定义 可变 ri = 中 + 1;  定义 可变 k = 左
    当 (li < left_len && ri <= 右) {
        如果 (内存_读32有符号(缓冲 + li * 4) <= 内存_读32有符号(arr + ri * 4)) {
            内存_写32(arr + k * 4, 内存_读32有符号(缓冲 + li * 4)); li = li + 1
        } 否则 {
            内存_写32(arr + k * 4, 内存_读32有符号(arr + ri * 4)); ri = ri + 1
        }
        k = k + 1
    }
    当 (li < left_len) {
        内存_写32(arr + k * 4, 内存_读32有符号(缓冲 + li * 4)); li = li + 1; k = k + 1
    }
}
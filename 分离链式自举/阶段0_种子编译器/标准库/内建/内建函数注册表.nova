    签名_注册("__运行时_文件存在", 1, "整数")
}

// 参数数量校验

函数 内建_校验参数(函数名, 实际参数数) {
    定义 签名 = 签名_查找(函数名)
    如果 (签名 == 空) { 返回 真 }  // 未注册的不校验
    如果 (签名[0] != 实际参数数) {
        打印("内建函数 " + 函数名 + " 需要 " + 转字符串(签名[0]) + " 个参数，实际 " + 转字符串(实际参数数) + " 个\n")
        返回 假
    }
    返回 真
}

// 返回类型推导

函数 内建_返回类型(函数名) {
    定义 签名 = 签名_查找(函数名)
    如果 (签名 == 空) { 返回 "任意" }
    返回 签名[1]
}

// 分类查询

函数 内建_列表操作函数() {
    返回 ["追加", "添加", "计数", "设置", "删除", "插入"]
}

函数 内建_字符串函数() {
    返回 ["字符串拼接", "子串", "字节长度", "字节取", "替换", "包含", "查找", "转字符串", "编码", "字符", "以开头", "以结尾"]
}

函数 内建_字典函数() {
    返回 ["字典", "字典设", "字典取", "字典有", "字典键", "字典值"]
}

函数 内建_IO函数() {
    返回 ["打印", "打印文本", "读文件", "写文件", "写二进制"]
}

函数 内建_类型函数() {
    返回 ["类型", "是整数", "是字符串", "是列表", "是字典"]
}

函数 内建_数学函数() {
    返回 ["绝对值", "最小值", "最大值"]
}

函数 内建_所有分类() {
    返回 [
        ["列表操作", 内建_列表操作函数()],
        ["字符串", 内建_字符串函数()],
        ["字典", 内建_字典函数()],
        ["IO", 内建_IO函数()],
        ["类型", 内建_类型函数()],
        ["数学", 内建_数学函数()]
    ]
}

定义 可变 _内建_调用计数表_名 = []
定义 可变 _内建_调用计数表_次 = []

函数 内建_记录调用(函数名) {
    定义 可变 i = 0
    当 (i < 计数(_内建_调用计数表_名)) {
        如果 (_内建_调用计数表_名[i] == 函数名) {
            _内建_调用计数表_次[i] = _内建_调用计数表_次[i] + 1
            返回 空
        }
        i = i + 1
    }
    追加(_内建_调用计数表_名, 函数名)
    追加(_内建_调用计数表_次, 1)
}

函数 内建_热点函数(前N) {
    定义 可变 名 = []
    定义 可变 次 = []
    定义 可变 i = 0
    当 (i < 计数(_内建_调用计数表_名)) {
        追加(名, _内建_调用计数表_名[i])
        追加(次, _内建_调用计数表_次[i])
        i = i + 1
    }
    // 冒泡排序取前N
    i = 0
    当 (i < 计数(名) - 1) {
        定义 可变 j = 0
        当 (j < 计数(名) - 1 - i) {
            如果 (次[j] < 次[j + 1]) {
            }
            j = j + 1
        }
        i = i + 1
    }
    定义 可变 结果 = []
    i = 0
    当 (i < 前N 且 i < 计数(名)) {
        追加(结果, [名[i], 次[i]])
        i = i + 1
    }
    返回 结果
}

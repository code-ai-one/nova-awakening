// 数报发送

// 被DHCP模块通过外部声明引用的别名

函数 数报_发送报文(源IP, 源端口, 目标IP, 目标端口, 数据, 长度) {
    // 无socket的原始数报发送(DHCP启动时无socket)
    定义 Nova缓冲 = Nova缓冲_分配(长度 + 28)  // 数报头8 + IP头20
    如果 (Nova缓冲 == 空) { 返回 }
    // 填充数报头
    Nova缓冲_写16(Nova缓冲, 0, 源端口)
    Nova缓冲_写16(Nova缓冲, 2, 目标端口)
    Nova缓冲_写16(Nova缓冲, 4, 长度 + 8)
    Nova缓冲_写16(Nova缓冲, 6, 0)  // 校验和(可选)
    内核调试("数报: 原始发送 " + 整数转字符串(源端口) + "→" + 整数转字符串(目标端口))
}

函数 udp_发送(sock, 数据, 长度, 目标IP, 目标端口) {
    如果 (长度 > 数报_最大数据报大小) {
        返回 错误码_消息过大
    }

    // 如果已连接且未指定目标，使用连接的目标
    如果 (目标IP == 0 && sock.已连接) {
        目标IP = sock.远程IP
        目标端口 = sock.远程端口
    }
    如果 (目标IP == 0) { 返回 错误码_未连接 }

    // 自动绑定
    如果 (!sock.已绑定) {
        udp_绑定(sock, 0, 0)
    }

    // 构建数报数据报
    定义 总长度 = 数报_头部大小 + 长度
    定义 可变 Nova缓冲 = Nova缓冲_分配(总长度 + 20)  // +IP头
    如果 (Nova缓冲 == 空) { 返回 错误码_内存不足 }

    // 预留IP头空间
    定义 udp头 = Nova缓冲.数据 + 20

    // 填充数报头
    网络序_写u16(udp头, 数报_偏移_源端口, sock.本地端口)
    网络序_写u16(udp头, 数报_偏移_目标端口, 目标端口)
    网络序_写u16(udp头, 数报_偏移_长度, 总长度)
    网络序_写u16(udp头, 数报_偏移_校验和, 0)

    // 复制数据
    内存复制(udp头 + 数报_头部大小, 数据, 长度)

    // 计算校验和
    定义 源IP = sock.本地IP
    如果 (源IP == 0) { 源IP = 获取本地IP() }
    udp_计算校验和(udp头, 总长度, 源IP, 目标IP)

    Nova缓冲.数据长度 = 总长度 + 20
    Nova缓冲.传输层偏移 = 20

    // 通过IP层发送
    返回 IP_发送_协议(Nova缓冲, 源IP, 目标IP, IP协议_数报)
}

函数 udp_发送到(sock, 数据, 长度, 目标地址) {
    返回 udp_发送(sock, 数据, 长度, 目标地址.IP, 目标地址.端口)
}

// 数报接收(从IP层调用)

函数 udp_接收(Nova缓冲) {
    定义 udp头 = Nova缓冲.数据 + Nova缓冲.传输层偏移

    // 验证长度
    定义 udp长度 = 网络序_读u16(udp头, 数报_偏移_长度)
    如果 (udp长度 < 数报_头部大小) {
        返回 错误码_无效参数
    }

    定义 源端口 = 网络序_读u16(udp头, 数报_偏移_源端口)
    定义 目标端口 = 网络序_读u16(udp头, 数报_偏移_目标端口)

    // 验证校验和(如果非零)
    定义 校验和 = 网络序_读u16(udp头, 数报_偏移_校验和)
    如果 (校验和 != 0) {
        定义 验证 = udp_验证校验和(udp头, udp长度, Nova缓冲.源IP, Nova缓冲.目标IP)
        如果 (!验证) {
            返回 错误码_校验和错误
        }
    }

    // 查找匹配的socket
    定义 sock = udp_查找socket(Nova缓冲.目标IP, 目标端口, Nova缓冲.源IP, 源端口)
    如果 (sock == 空) {
        // 无匹配socket，发送ICMP端口不可达
        icmp_发送_端口不可达(Nova缓冲)
        返回 0
    }

    // 提取数据部分
    定义 数据长度 = udp长度 - 数报_头部大小
    定义 可变 数据Nova缓冲 = Nova缓冲_分配(数据长度)
    内存复制(数据Nova缓冲.数据, udp头 + 数报_头部大小, 数据长度)
    数据Nova缓冲.数据长度 = 数据长度
    数据Nova缓冲.源IP = Nova缓冲.源IP
    数据Nova缓冲.源端口 = 源端口

    // 加入socket接收缓冲
    自旋锁_获取(sock.锁)
    Nova网络缓冲_队列_入队(sock.接收缓冲, 数据Nova缓冲)
    自旋锁_释放(sock.锁)

    // 唤醒等待的接收者
    等待队列_唤醒一个(sock.接收等待队列)

    返回 0
}

    tcp_停止零窗口探测(控制块)
    档.定时数 = 档.定时数 + 1
    档.最近统计 = tcp定时器_完整统计()
    返回 传输传输_成功(档, "停止零探", 档.最近统计)
}

函数 传输传输_推进定时(档, 当前时间) {
    定时器轮_推进(当前时间)
    档.定时数 = 档.定时数 + 1
    档.最近统计 = tcp定时器_完整统计()
    返回 传输传输_成功(档, "推进定时", 档.最近统计)
}

函数 传输传输_重传超时(档, 控制块) {
    tcp_重传超时(控制块)
    传控_记录重传()
    档.最近统计 = [传控状态机_完整统计(), 传控数据_完整统计()]
    返回 传输传输_成功(档, "重传超时", 档.最近统计)
}

函数 传输传输_建数报(档) {
    定义 套接 = udp_创建socket()
    如果 (套接 == 空) {
        返回 传输传输_失败(档, "建数报", "数报套接创建失败")
    }
    档.当前数报 = 套接
    档.数据报数 = 档.数据报数 + 1
    档.最近统计 = 数报扩展_完整统计()
    返回 传输传输_成功(档, "建数报", 套接)
}

函数 传输传输_绑数报(档, 套接, IP, 端口) {
    定义 可变 结果 = 数报_绑定(套接, IP, 端口)
    如果 (结果 != 0) {
        结果 = udp_绑定(套接, IP, 端口)
    }
    档.当前数报 = 套接
    档.最近统计 = [数报扩展_完整统计(), 数报_完整统计()]
    如果 (结果 != 0) {
        返回 传输传输_失败(档, "绑数报", "数报绑定失败")
    }
    返回 传输传输_成功(档, "绑数报", 端口)
}

函数 传输传输_发数报(档, 套接, 数据, 长度, 目标IP, 目标端口) {
    定义 结果 = udp_发送(套接, 数据, 长度, 目标IP, 目标端口)
    档.最近输出 = 数据
    档.最近统计 = [数报扩展_完整统计(), 数报_完整统计()]
    如果 (结果 < 0) {
        返回 传输传输_失败(档, "发数报", "数报发送失败")
    }
    返回 传输传输_成功(档, "发数报", 结果)
}

函数 传输传输_收数报(档, 套接, 缓冲, 最大长度, 源地址) {
    定义 结果 = udp_recvmsg(套接, 缓冲, 最大长度, 0, 源地址)
    档.最近输入 = 结果
    档.最近统计 = [NURP_获取统计(), 数报_完整统计()]
    如果 (结果 < 0) {
        返回 传输传输_失败(档, "收数报", "数报接收失败")
    }
    返回 传输传输_成功(档, "收数报", 结果)
}

函数 传输传输_加组播(档, 套接, 组IP, 接口索引) {
    udp_加入组播(套接, 组IP, 接口索引)
    档.最近统计 = [NURP_获取统计(), NUDP_诊断报告()]
    返回 传输传输_成功(档, "加组播", 组IP)
}

函数 传输传输_离组播(档, 套接, 组IP) {
    udp_离开组播(套接, 组IP)
    档.最近统计 = [NURP_获取统计(), NUDP_诊断报告()]
    返回 传输传输_成功(档, "离组播", 组IP)
}

函数 传输传输_数报诊断(档) {
    定义 诊断 = [数报扩展_完整统计(), 数报_完整统计(), NURP_获取统计(), NUDP_诊断报告()]
    档.最近统计 = 诊断
    返回 传输传输_成功(档, "数报诊断", 诊断)
}

函数 传输传输_连接摘要(档, 控制块) {
    定义 摘要 = [传控_TCB摘要(控制块), 传控_连接摘要(控制块), 传控_状态名(控制块.状态)]
    档.当前控制块 = 控制块
    档.最近统计 = 摘要
    返回 传输传输_成功(档, "连接摘要", 摘要)
}

函数 传输传输_摘要(档) {
    定义 摘要 = 堆_分配(传输摘要)
    摘要.名称 = 档.名称
    摘要.传控数 = 档.传控数
    摘要.套接数 = 档.套接数
    摘要.数据报数 = 档.数据报数
    摘要.定时数 = 档.定时数
    摘要.拥塞数 = 档.拥塞数
    摘要.缓冲数 = 档.缓冲数
    摘要.命中数 = 档.命中数
    摘要.失败数 = 档.失败数
    摘要.健康 = 档.健康
    返回 摘要
}

函数 传输传输_完整统计() {
    返回 [
        传输建数,
        传输总动作,
        传输总命中,
        传输总失败,
        传控_完整统计(),
        传控状态机_完整统计(),
        传控连接_完整统计(),
        传控拥塞_完整统计(),
        AI拥塞_完整统计(),
        传控数据_完整统计(),
        socket内存_完整统计(),
        数报扩展_完整统计(),
        数报_完整统计()
    ]
}

函数 传输传输_健康(档) {
    如果 (!档.初始化完成) { 返回 "未初始化" }
    如果 (档.失败数 > 档.命中数) { 返回 "降级" }
    如果 (档.失败数 > 0) { 返回 "监视" }
    返回 "运行"
}

函数 传输传输_自检() {
    定义 档 = 传输传输_创建("传输传输")
    定义 套接回证 = 传输传输_创建套接(档, "内联传输", 0x7F000001, 0, 0x7F000001, 8080)
    定义 缓冲回证 = 传输传输_创建缓冲(档)
    定义 可变 缓冲 = 0
    如果 (缓冲回证.已成) {
        缓冲 = 缓冲回证.数据
        传输传输_调缓冲(档, 缓冲, 4096, 4096)
        传输传输_保存缓冲(档, 缓冲)
    }
    传输传输_预测拥塞(档, 12000, 假)
    定义 数报回证 = 传输传输_建数报(档)
    档.健康 = 传输传输_健康(档)
    档.最近统计 = 传输传输_完整统计()
    返回 [
        档.初始化完成,
        套接回证.已成,
        缓冲回证.已收,
        数报回证.已收,
        AI拥塞_获取窗口() > 0,
        计数(传输账本) > 0,
        档.健康
    ]
}

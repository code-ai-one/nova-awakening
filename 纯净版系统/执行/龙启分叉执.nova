函数 龙启_fork_exec(路径) {
    定义 pid = sys_fork(0, 0, 0, 0, 0, 0)
    如果 (pid == 0) {
        // 子进程: 创建新会话, 设置控制终端
        sys_setsid(0, 0, 0, 0, 0, 0)

        // exec 终端
        定义 argv = [路径, "--login"]
        定义 envp = ["HOME=/root", "PATH=/bin:/sbin:/usr/bin:/usr/sbin",
                     "终端=" + 路径, "TERM=linux", "USER=root",
                     "LANG=zh_CN.UTF-8", "NOVAOS_VERSION=1.0.0-M1"]
        sys_execve(路径, argv, envp, 0, 0, 0)
        // exec失败
        sys_write(2, "龙启: exec失败: " + 路径 + "\n", 0, 0, 0, 0)
        sys_exit(1, 0, 0, 0, 0, 0)
    }
    // 父进程: 记录终端 PID
    服务_注册_运行中("终端", pid)
}

函数 龙启_fork_终端内置() {
    定义 pid = sys_fork(0, 0, 0, 0, 0, 0)
    如果 (pid == 0) {
        sys_setsid(0, 0, 0, 0, 0, 0)
        龙壳_入口(0, [])
        sys_exit(0, 0, 0, 0, 0, 0)
    }
    服务_注册_运行中("终端", pid)
}

// 阶段6: init主循环 — PID 1永不退出
// 职责: 回收zombie + 监控服务 + 处理关机/重启信号

函数 龙启_主循环() {
    当 (init_运行中) {
        // 1. 回收所有zombie子进程 (init是最终收割者)
        循环 {
            定义 状态 = [0]
            定义 pid = sys_wait4(-1, 状态, WNOHANG, 空, 0, 0)
            如果 (pid <= 0) { 中断 }

            定义 退出码 = (状态[0] >> 8) & 0xFF
            // 检查是否是注册的服务
            定义 服务名 = 服务_按PID查找(pid)
            如果 (服务名 != 空) {
                龙启_打印("[龙启] 服务退出: " + 服务名 + " (PID " + 整数转字符串(pid) + " 退出码=" + 整数转字符串(退出码) + ")")
                服务_标记退出(服务名, 退出码)

                // 终端退出: 自动重启
                如果 (服务名 == "终端") {
                    龙启_打印("[龙启] 终端已退出, 5秒后重启...")
                    sys_nanosleep([5, 0], 空, 0, 0, 0, 0)
                    龙启_启动终端()
                }

                // 关键服务退出: 尝试重启(最多3次)
                如果 (服务_是关键(服务名) && 服务_重启次数(服务名) < 3) {
                    龙启_打印("[龙启] 关键服务崩溃, 重启: " + 服务名)
                    服务_启动(服务名)
                    服务_增加重启次数(服务名)
                }
            }
        }

        // 2. 检查运行级别切换
        如果 (init_运行级 == 运行级_重启) {
            龙启_打印("[龙启] 收到重启请求...")
            龙启_关机序列()
            // 调用reboot系统调用
            返回
        }
        如果 (init_运行级 == 运行级_关机) {
            龙启_打印("[龙启] 收到关机请求...")
            龙启_关机序列()
            返回
        }

        // 3. 短暂睡眠避免忙等
        sys_nanosleep([1, 0], 空, 0, 0, 0, 0)
    }
}

// 关机序列

函数 龙启_关机序列() {
    龙启_打印("[龙启] ═══ 关机序列开始 ═══")

    // 1. 向所有服务发送SIGTERM
    龙启_打印("[龙启] 发送SIGTERM给所有服务...")
    服务_停止全部()

    // 2. 等待3秒
    sys_nanosleep([3, 0], 空, 0, 0, 0, 0)

    // 3. 向剩余进程发送SIGKILL
    龙启_打印("[龙启] 发送SIGKILL给剩余进程...")
    sys_kill(-1, 9, 0, 0, 0, 0)   // kill(-1, SIGKILL)

    // 4. 同步文件系统
    龙启_打印("[龙启] 同步文件系统...")
    同步所有文件系统()

    // 5. 卸载文件系统
    龙启_打印("[龙启] 卸载文件系统...")
    do_umount("/tmp", 0)
    do_umount("/run", 0)
    do_umount("/dev/shm", 0)
    do_umount("/dev/pts", 0)
    do_umount("/dev", 0)
    do_umount("/sys", 0)
    do_umount("/proc", 0)

    // 6. 重新挂载根为只读
    do_mount_带标志("", "/", "", MS_REMOUNT | MS_RDONLY, "")

    龙启_打印("[龙启] ═══ 关机序列完成 ═══")
    init_运行中 = 假
}

// 辅助

函数 龙启_打印(消息) {
    sys_write(1, "[龙启] " + 消息 + "\n", 0, 0, 0, 0)
}

函数 龙启_执行脚本(路径) {
    定义 pid = sys_fork(0, 0, 0, 0, 0, 0)
    如果 (pid == 0) {
        sys_execve("/bin/龙壳", ["/bin/龙壳", 路径], 空, 0, 0, 0)
        sys_exit(1, 0, 0, 0, 0, 0)
    }
    // 等待脚本执行完成
    定义 状态 = [0]
    sys_wait4(pid, 状态, 0, 空, 0, 0)
}

定义 WNOHANG = 0x00000001
定义 MS_REMOUNT = 0x0020
定义 MS_RDONLY = 0x0001

定义 可变 AI_龙启分叉执_事件频率 = 0
定义 可变 AI_龙启分叉执_节流阈值 = 16

函数 AI_龙启分叉执_节流判断(事件类型, 间隔毫秒) {
    AI_龙启分叉执_事件频率 = AI_龙启分叉执_事件频率 + 1
    如果 (事件类型 == "滚动" && 间隔毫秒 < AI_龙启分叉执_节流阈值) { 返回 真 }
    如果 (事件类型 == "移动" && 间隔毫秒 < AI_龙启分叉执_节流阈值) { 返回 真 }
    返回 假
}

函数 AI_龙启分叉执_优先级排序(事件类型) {
    如果 (事件类型 == "点击") { 返回 100 }
    如果 (事件类型 == "输入") { 返回 90 }
    如果 (事件类型 == "滚动") { 返回 30 }
    返回 50
}

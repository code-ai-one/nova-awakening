函数 CSSParser_计算特异度(选择器) {
    // CSS特异度: (a, b, c) → a=id数 b=class/attr/伪类数 c=标签/伪元素数
    // 打包为一个整数: a*10000 + b*100 + c
    如果 (选择器 == 0) { 返回 0 }
    定义 可变 a = 0; 定义 可变 b = 0; 定义 可变 c = 0
    定义 可变 当前 = 选择器
    当 (当前 != 0) {
        如果 (当前.类型 == 选择器类型_id) { a = a + 1 }
        否则 如果 (当前.类型 == 选择器类型_class || 当前.类型 == 选择器类型_属性 || 当前.类型 == 选择器类型_伪类) { b = b + 1 }
        否则 如果 (当前.类型 == 选择器类型_标签 || 当前.类型 == 选择器类型_伪元素) { c = c + 1 }
        当前 = 当前.下一个
    }
    返回 a * 10000 + b * 100 + c
}

函数 CSSParser_跳过AT规则(tk, 令牌) {
    // 简单跳过@规则直到';'或'}'
    定义 内部令牌 = 堆_分配(CSS令牌)
    定义 可变 大括号深度 = 0
    当 (1) {
        CSS令牌izer_下一个令牌(tk, 内部令牌)
        如果 (内部令牌.类型 == CSS_令牌_EOF) { 返回 }
        如果 (内部令牌.类型 == CSS_令牌_左大括号) { 大括号深度 = 大括号深度 + 1 }
        如果 (内部令牌.类型 == CSS_令牌_右大括号) {
            如果 (大括号深度 == 0) { 返回 }
            大括号深度 = 大括号深度 - 1
            如果 (大括号深度 == 0) { 返回 }
        }
        如果 (内部令牌.类型 == CSS_令牌_分号 && 大括号深度 == 0) { 返回 }
    }

定义 可变 AI_样式解析甲_样式缓存命中 = 0

函数 AI_样式解析甲_选择器复杂度(选择器长度, 组合子数) {
    如果 (组合子数 > 5) { 返回 "高复杂度" }
    如果 (组合子数 > 2) { 返回 "中复杂度" }
    返回 "低复杂度"
}

函数 AI_样式解析甲_布局缓存(元素哈希) {
    AI_样式解析甲_样式缓存命中 = AI_样式解析甲_样式缓存命中 + 1
    返回 元素哈希
}

// NGBK理论 — Nova GBK Codec
// 原创GBK编码映射与AI编码检测理论
// 核心理论:
//   1. NGBK-FWD: 分区查表正向映射 GBK→Unicode
//      idx = (byte1 - 0x81) * 190 + offset(byte2)
//   2. NGBK-REV: 哈希反向映射 Unicode→GBK
//      hash = unicode % BUCKET_SIZE → 链地址探测
//   3. NGBK-DET: 字节流编码自动检测算法
//      统计合法GBK序列占比推断编码
//   4. NGBK-GB18030: GB18030四字节扩展兼容
//   5. NGBK-AI: AI编码推理与异常检测
// GBK编码范围: 第一字节0x81-0xFE, 第二字节0x40-0x7E/0x80-0xFE
// 映射方式: (byte1-0x81)*190 + (byte2-0x40) → Unicode码点
// 总映射条目: 23940个(完整GBK)
// 本文件实现分区域查表:
//   GBK/1: A1A1-A9FE (符号/数字)
//   GBK/2: B0A1-F7FE (汉字一级, 3755字按拼音排序)
//   GBK/3: 8140-A0FE (汉字扩展)
//   GBK/4: AA40-FEA0 (汉字二级, 3008字按笔画排序)

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../推理/值乘.nova")
导入("../执行/底层内存操.nova")

// §0 全局常量与统计

定义 NGBK_版本 = "3.0.0-NGBK"
定义 NGBK_反向哈希桶数 = 4096     // 反向映射哈希桶数量
定义 NGBK_编码检测阈值 = 0.65   // 编码检测置信度阈值
定义 NGBK_GB18030_四字节起 = 0x81308130   // GB18030四字节起始

定义 可变 NGBK_正向查表次数 = 0
定义 可变 NGBK_反向查表次数 = 0
定义 可变 NGBK_编码检测次数 = 0
定义 可变 NGBK_GB18030查表次数 = 0
定义 可变 NGBK_AI推理次数 = 0
定义 可变 NGBK_异常字节次数 = 0
定义 可变 NGBK_反向表 = 0  // Unicode→GBK反向哈希表

// §1 核心查表函数

定义 可变 GBK_映射表 = 0
定义 GBK_映射表大小 = 23940    // (0xFE-0x81+1) * 190

函数 GBK_初始化() {
    如果 (GBK_映射表 != 0) { 返回 }
    // 每个条目2字节(u16 Unicode码点), 总大小47880字节
    GBK_映射表 = 堆_分配(GBK_映射表大小 * 2)
    内存_清零(GBK_映射表, GBK_映射表大小 * 2)
    // 填充映射表
    GBK_填充符号区()
    GBK_填充汉字一级()
    GBK_填充汉字二级()
}

// NGBK-FWD: 将GBK双字节转换为Unicode码点
函数 GBK_到Unicode(byte1, byte2) {
    NGBK_正向查表次数 = NGBK_正向查表次数 + 1
    如果 (GBK_映射表 == 0) { GBK_初始化() }
    如果 (byte1 < 0x81 || byte1 > 0xFE) {
        NGBK_异常字节次数 = NGBK_异常字节次数 + 1
        返回 0xFFFD
    }
    定义 可变 idx2 = 0
    如果 (byte2 >= 0x40 && byte2 <= 0x7E) { idx2 = byte2 - 0x40 }
    否则 如果 (byte2 >= 0x80 && byte2 <= 0xFE) { idx2 = byte2 - 0x80 + 63 }
    否则 {
        NGBK_异常字节次数 = NGBK_异常字节次数 + 1
        返回 0xFFFD
    }
    定义 idx = (byte1 - 0x81) * 190 + idx2
    如果 (idx >= GBK_映射表大小) { 返回 0xFFFD }
    定义 cp = 内存_读16(GBK_映射表 + idx * 2)
    如果 (cp == 0) { 返回 0xFFFD }
    返回 cp
}

// §2 GBK映射数据(按区域填充)

// 辅助: 写入映射
函数 GBK_写映射(byte1, byte2, unicode) {
    如果 (GBK_映射表 == 0) { 返回 }
    如果 (byte1 < 0x81 || byte1 > 0xFE) { 返回 }
    定义 可变 idx2 = 0
    如果 (byte2 >= 0x40 && byte2 <= 0x7E) { idx2 = byte2 - 0x40 }
    否则 如果 (byte2 >= 0x80 && byte2 <= 0xFE) { idx2 = byte2 - 0x80 + 63 }
    否则 { 返回 }
    定义 idx = (byte1 - 0x81) * 190 + idx2
    如果 (idx < GBK_映射表大小) {
        内存_写16(GBK_映射表 + idx * 2, unicode)
    }
}

// GBK/1区: A1A1-A9FE (符号/全角/日文假名)
函数 GBK_填充符号区() {
    // A1A1-A1FE: 全角标点和特殊符号
    GBK_写映射(0xA1, 0xA1, 0x3000)    // 　(全角空格→IDEOGRAPHIC SPACE)
    GBK_写映射(0xA1, 0xA2, 0x3001)    // 、
    GBK_写映射(0xA1, 0xA3, 0x3002)    // 。
    GBK_写映射(0xA1, 0xA4, 0x00B7)    // ·
    GBK_写映射(0xA1, 0xA5, 0x02C9)    // ˉ
    GBK_写映射(0xA1, 0xA6, 0x02C7)    // ˇ
    GBK_写映射(0xA1, 0xA7, 0x00A8)    // ¨
    GBK_写映射(0xA1, 0xA8, 0x3003)    // 〃
    GBK_写映射(0xA1, 0xA9, 0x3005)    // 々
    GBK_写映射(0xA1, 0xAA, 0x2014)    // —
    GBK_写映射(0xA1, 0xAB, 0xFF5E)    // ～
    GBK_写映射(0xA1, 0xAC, 0x2016)    // ‖
    GBK_写映射(0xA1, 0xAD, 0x2026)    // …
    GBK_写映射(0xA1, 0xAE, 0x2018)    // '
    GBK_写映射(0xA1, 0xAF, 0x2019)    // '
    GBK_写映射(0xA1, 0xB0, 0x201C)    // "
    GBK_写映射(0xA1, 0xB1, 0x201D)    // "
    GBK_写映射(0xA1, 0xB2, 0x3014)    // 〔
    GBK_写映射(0xA1, 0xB3, 0x3015)    // 〕
    GBK_写映射(0xA1, 0xB4, 0x3010)    // 【
    GBK_写映射(0xA1, 0xB5, 0x3011)    // 】
    GBK_写映射(0xA1, 0xB6, 0x300A)    // 《
    GBK_写映射(0xA1, 0xB7, 0x300B)    // 》
    GBK_写映射(0xA1, 0xB8, 0x300C)    // 「
    GBK_写映射(0xA1, 0xB9, 0x300D)    // 」
    GBK_写映射(0xA1, 0xBA, 0x300E)    // 『
    GBK_写映射(0xA1, 0xBB, 0x300F)    // 』
    GBK_写映射(0xA1, 0xBC, 0x3016)    // 〖
    GBK_写映射(0xA1, 0xBD, 0x3017)    // 〗
    GBK_写映射(0xA1, 0xBE, 0x2236)    // ∶
    // A3A1-A3FE: 全角ASCII (A3A1=！U+FF01 ... A3FE)
    定义 可变 i = 0
    当 (i < 94) {
        GBK_写映射(0xA3, 0xA1 + i, 0xFF01 + i)    // 全角ASCII
        i = i + 1
    }
    // A4A1-A4F3: 平假名 (U+3041-U+3093)
    i = 0
    当 (i < 83) {
        GBK_写映射(0xA4, 0xA1 + i, 0x3041 + i)
        i = i + 1
    }
    // A5A1-A5F6: 片假名 (U+30A1-U+30F6)
    i = 0
    当 (i < 86) {
        GBK_写映射(0xA5, 0xA1 + i, 0x30A1 + i)
        i = i + 1
    }
}


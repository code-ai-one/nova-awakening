// §6 多行文本布局
// 根据可用宽度和换行机会进行文本分行

导入("../稳态/图处显示.nova")
导入("../推理/值乘.nova")
导入("./内核直连层.nova")
导入("./字形光栅乙.nova")
导入("../中枢/内存初始化.nova")
导入("./文本绘制将.nova")
导入("./码点统一码.nova")

结构 TextLine {
    起始偏移,    // u32 在源文本中的字节偏移
    结束偏移,
    宽度,    // i32 此行宽度(像素)
    基线y,    // i32 此行基线的y坐标
}


函数 Text渲染er_分行(face, 文本, 文本长度, 可用宽度) {
    // 返回TextLine数组
    定义 行列表 = 堆_分配_数组(256 * 16)    // 最多256行
    定义 可变 行数 = 0
    定义 可变 行起始 = 0
    定义 可变 行宽 = 0
    定义 可变 最后断行点 = 0
    定义 可变 最后断行宽 = 0

    定义 机会 = Unicode_获取换行机会(文本, 文本长度)
    定义 行高 = (face.上升 - face.下降 + face.行距) / 64

    定义 可变 pos = 0
    当 (pos < 文本长度) {
        定义 解码 = UTF8_解码(文本, pos)
        定义 码点 = 解码[0]
        定义 字节数 = 解码[1]

        // 检查换行机会
        定义 断行类型 = 内存_读32(机会 + pos * 4)
        如果 (断行类型 == 换行_必须) {
            // 强制断行
            Text渲染er_添加行(行列表, 行数, 行起始, pos, 行宽, 行数 * 行高)
            行数 = 行数 + 1
            行起始 = pos + 字节数
            行宽 = 0
            最后断行点 = 行起始
            最后断行宽 = 0
            pos = pos + 字节数
            继续
        }
        如果 (断行类型 >= 换行_允许) {
            最后断行点 = pos
            最后断行宽 = 行宽
        }

        // 获取字形宽度
        定义 glyph = 字体Face_获取字形(face, 码点)
        定义 可变 字符宽 = 0
        如果 (glyph != 0) { 字符宽 = glyph.前进宽度 / 64 }

        // 检查是否超过可用宽度
        如果 (行宽 + 字符宽 > 可用宽度 && 行宽 > 0) {
            // 需要断行
            如果 (最后断行点 > 行起始) {
                // 在最后一个断行机会处断
                Text渲染er_添加行(行列表, 行数, 行起始, 最后断行点, 最后断行宽, 行数 * 行高)
                行数 = 行数 + 1
                pos = 最后断行点
                行起始 = pos
                行宽 = 0
                最后断行点 = pos
                最后断行宽 = 0
                继续
            } 否则 {
                // 无断行机会: 在当前位置强制断(word-break)
                Text渲染er_添加行(行列表, 行数, 行起始, pos, 行宽, 行数 * 行高)
                行数 = 行数 + 1
                行起始 = pos
                行宽 = 0
                最后断行点 = pos
                最后断行宽 = 0
            }
        }

        行宽 = 行宽 + 字符宽
        pos = pos + 字节数
    }

    // 最后一行
    如果 (行起始 < 文本长度) {
        Text渲染er_添加行(行列表, 行数, 行起始, 文本长度, 行宽, 行数 * 行高)
        行数 = 行数 + 1
    }

    // 返回 [行列表指针, 行数]
    堆_释放(机会)
    返回 [行列表, 行数]
}

函数 Text渲染er_添加行(行列表, 行索引, 起始, 结束, 宽度, 基线y) {
    如果 (行索引 >= 256) { 返回 }
    定义 偏移 = 行列表 + 行索引 * 16
    内存_写32(偏移, 起始)
    内存_写32(偏移 + 4, 结束)
    内存_写32(偏移 + 8, 宽度)
    内存_写32(偏移 + 12, 基线y)
}

// NMTL理论 — Nova多行文本布局理论 (Nova Multi-line Text Layout)
// 创新点: 基于尺度自适应分行 + 弹性对齐策略 + 视觉密度均衡排版
// 统一处理文本分行/对齐/省略/装饰/双向/空白等全场景布局

定义 NMTL_对齐_左 = 0
定义 NMTL_对齐_右 = 1
定义 NMTL_对齐_居中 = 2
定义 NMTL_对齐_两端 = 3   // justify

定义 NMTL_溢出_裁剪 = 0
定义 NMTL_溢出_省略 = 1    // ellipsis
定义 NMTL_溢出_可见 = 2

定义 NMTL_装饰_无 = 0
定义 NMTL_装饰_下划线 = 1
定义 NMTL_装饰_删除线 = 2
定义 NMTL_装饰_上划线 = 4

定义 NMTL_空白_正常 = 0     // normal: 合并空白 + 自动换行
定义 NMTL_空白_不换行 = 1   // nowrap
定义 NMTL_空白_保留 = 2     // pre: 保留空白 + 不自动换行
定义 NMTL_空白_保留换行 = 3 // pre-wrap
定义 NMTL_空白_保留行 = 4   // pre-line: 合并空白 + 保留换行

定义 NMTL_方向_LTR = 0
定义 NMTL_方向_RTL = 1

定义 NMTL_最大行数 = 1024
定义 NMTL_制表符宽度 = 64   // 默认tab停止位像素宽

定义 可变 NMTL_布局总数 = 0
定义 可变 NMTL_总行数 = 0
定义 可变 NMTL_省略次数 = 0
定义 可变 NMTL_对齐次数 = 0
定义 可变 NMTL_装饰次数 = 0

结构 NMTL_布局上下文 {
    face,             // 字体指针
    文本,             // 文本指针
    文本长度,         // 字节数
    可用宽度,         // 像素
    最大行数,         // 0=无限
    对齐方式,         // NMTL_对齐_*
    溢出模式,         // NMTL_溢出_*
    空白模式,         // NMTL_空白_*
    方向,             // LTR/RTL
    字间距,           // 像素
    词间距,           // 像素
    行高倍数,         // x100 (150=1.5倍)
    首行缩进,         // 像素
    装饰类型,         // 位标志组合
    装饰颜色,         // ARGB32
    装饰粗细,         // 像素
}

// 布局结果
结构 NMTL_布局结果 {
    行列表,           // TextLine数组指针
    行数,
    总高度,           // 像素
    总宽度,           // 最宽行像素
    已省略,           // 是否发生省略
}


// 判断码点是否为空白字符
函数 NMTL_是空白(码点) {
    如果 (码点 == 0x20) { 返回 真 }   // 空格
    如果 (码点 == 0x09) { 返回 真 }   // 制表符
    如果 (码点 == 0x0A) { 返回 真 }   // LF
    如果 (码点 == 0x0D) { 返回 真 }   // CR
    如果 (码点 == 0x0C) { 返回 真 }   // FF
    如果 (码点 == 0x3000) { 返回 真 } // 全角空格
    如果 (码点 == 0x00A0) { 返回 真 } // NBSP
    返回 假
}

// 空白合并: 将连续空白合并为单个空格
函数 NMTL_合并空白(文本, 长度, 输出, 空白模式) {
    如果 (空白模式 == NMTL_空白_保留 || 空白模式 == NMTL_空白_保留换行) {
        // pre / pre-wrap: 不合并, 直接拷贝
        内存_拷贝(输出, 文本, 长度)
        返回 长度
    }
    定义 可变 写位置 = 0
    定义 可变 前一个空白 = 假
    定义 可变 pos = 0
    当 (pos < 长度) {
        定义 解码 = UTF8_解码(文本, pos)
        定义 码点 = 解码[0]
        定义 字节数 = 解码[1]
        如果 (NMTL_是空白(码点)) {
            如果 (码点 == 0x0A && 空白模式 == NMTL_空白_保留行) {
                // pre-line: 保留换行符
                内存_写字8(输出 + 写位置, 0x0A)
                写位置 = 写位置 + 1
                前一个空白 = 假
            } 否则 {
                如果 (!前一个空白) {
                    内存_写字8(输出 + 写位置, 0x20)
                    写位置 = 写位置 + 1
                }
                前一个空白 = 真
            }
        } 否则 {
            // 拷贝非空白字符
            内存_拷贝(输出 + 写位置, 文本 + pos, 字节数)
            写位置 = 写位置 + 字节数
            前一个空白 = 假
        }
        pos = pos + 字节数
    }
    返回 写位置
}


// 计算制表符停止位宽度 (对齐到下一个tab stop)
函数 NMTL_制表符宽度(当前x, 制表符宽) {
    如果 (制表符宽 <= 0) { 返回 NMTL_制表符宽度 }
    定义 下一个停止 = ((当前x / 制表符宽) + 1) * 制表符宽
    返回 下一个停止 - 当前x
}


函数 NMTL_分行(上下文) {
    如果 (上下文 == 0) { 返回 0 }
    定义 face = 上下文.face
    定义 文本 = 上下文.文本
    定义 文本长度 = 上下文.文本长度
    定义 可用宽度 = 上下文.可用宽度
    定义 空白模式 = 上下文.空白模式
    定义 字间距 = 上下文.字间距

    // 行高计算: 基础行高 * 倍数
    定义 基础行高 = (face.上升 - face.下降 + face.行距) / 64
    定义 行高 = 基础行高 * 上下文.行高倍数 / 100
    如果 (行高 < 1) { 行高 = 基础行高 }

    // 分配行列表
    定义 最大行 = 上下文.最大行数
    如果 (最大行 <= 0 || 最大行 > NMTL_最大行数) { 最大行 = NMTL_最大行数 }
    定义 行列表 = 堆_分配(最大行 * 16)

    // 预处理空白
    定义 处理缓冲 = 堆_分配(文本长度 + 1)
    定义 处理长度 = NMTL_合并空白(文本, 文本长度, 处理缓冲, 空白模式)

    // 获取换行机会
    定义 机会 = Unicode_获取换行机会(处理缓冲, 处理长度)

    定义 可变 行数 = 0
    定义 可变 行起始 = 0
    定义 可变 行宽 = 0
    定义 可变 最后断行点 = 0
    定义 可变 最后断行宽 = 0
    定义 可变 当前行可用宽 = 可用宽度

    // 首行缩进
    如果 (上下文.首行缩进 > 0) {
        当前行可用宽 = 可用宽度 - 上下文.首行缩进
    }

    定义 可变 pos = 0
    当 (pos < 处理长度 && 行数 < 最大行) {
        定义 解码 = UTF8_解码(处理缓冲, pos)
        定义 码点 = 解码[0]
        定义 字节数 = 解码[1]

        // nowrap模式: 不自动换行 (除非强制换行)
        定义 允许换行 = (空白模式 != NMTL_空白_不换行)

        // 强制换行符
        如果 (码点 == 0x0A) {
            Text渲染er_添加行(行列表, 行数, 行起始, pos, 行宽, 行数 * 行高)
            行数 = 行数 + 1
            行起始 = pos + 字节数
            行宽 = 0
            最后断行点 = 行起始
            最后断行宽 = 0
            当前行可用宽 = 可用宽度  // 恢复宽度 (首行缩进仅第一行)
            pos = pos + 字节数
            继续
        }

        // 检查换行机会
        定义 断行类型 = 内存_读32(机会 + pos * 4)
        如果 (断行类型 >= 换行_允许 && 允许换行) {
            最后断行点 = pos
            最后断行宽 = 行宽
        }

        // 字符宽度计算
        定义 可变 字符宽 = 0
        如果 (码点 == 0x09) {
            // 制表符
            字符宽 = NMTL_制表符宽度(行宽, NMTL_制表符宽度)
        } 否则 {
            定义 glyph = 字体Face_获取字形(face, 码点)
            如果 (glyph != 0) { 字符宽 = glyph.前进宽度 / 64 }
            字符宽 = 字符宽 + 字间距
        }

        // 检查是否超出可用宽度
        如果 (行宽 + 字符宽 > 当前行可用宽 && 行宽 > 0 && 允许换行) {
            如果 (最后断行点 > 行起始) {
                Text渲染er_添加行(行列表, 行数, 行起始, 最后断行点, 最后断行宽, 行数 * 行高)
                行数 = 行数 + 1
                pos = 最后断行点
                行起始 = pos
                行宽 = 0
                最后断行点 = pos
                最后断行宽 = 0
                当前行可用宽 = 可用宽度
                继续
            } 否则 {
                // 强制断行
                Text渲染er_添加行(行列表, 行数, 行起始, pos, 行宽, 行数 * 行高)
                行数 = 行数 + 1
                行起始 = pos
                行宽 = 0
                最后断行点 = pos
                最后断行宽 = 0
                当前行可用宽 = 可用宽度
            }
        }
        行宽 = 行宽 + 字符宽
        pos = pos + 字节数
    }

    // 最后一行
    如果 (行起始 < 处理长度 && 行数 < 最大行) {
        Text渲染er_添加行(行列表, 行数, 行起始, 处理长度, 行宽, 行数 * 行高)
        行数 = 行数 + 1
    }

    堆_释放(机会)
    堆_释放(处理缓冲)
    NMTL_总行数 = NMTL_总行数 + 行数
    NMTL_布局总数 = NMTL_布局总数 + 1
    返回 [行列表, 行数, 行数 * 行高]
}


// 计算对齐偏移
函数 NMTL_计算对齐偏移(行宽, 可用宽度, 对齐方式, 方向) {
    如果 (对齐方式 == NMTL_对齐_左) {
        如果 (方向 == NMTL_方向_RTL) { 返回 可用宽度 - 行宽 }
        返回 0
    }
    如果 (对齐方式 == NMTL_对齐_右) {
        如果 (方向 == NMTL_方向_RTL) { 返回 0 }
        返回 可用宽度 - 行宽
    }
    如果 (对齐方式 == NMTL_对齐_居中) {
        返回 (可用宽度 - 行宽) / 2
    }
    返回 0  // justify不用偏移
}

// 两端对齐: 均匀分配额外空间到词间距
函数 NMTL_计算两端对齐(行文本, 行长度, 行宽, 可用宽度, 是最后行) {
    // 最后一行不做两端对齐
    如果 (是最后行) { 返回 0 }
    如果 (行宽 >= 可用宽度) { 返回 0 }

    // 统计词间空格数
    定义 可变 空格数 = 0
    定义 可变 p = 0
    当 (p < 行长度) {
        定义 d = UTF8_解码(行文本, p)
        如果 (d[0] == 0x20) { 空格数 = 空格数 + 1 }
        p = p + d[1]
    }
    如果 (空格数 == 0) { 返回 0 }

    // 额外空间平均分配到每个空格 (x100精度)
    定义 额外总空间 = 可用宽度 - 行宽
    定义 每空格额外 = (额外总空间 * 100) / 空格数
    NMTL_对齐次数 = NMTL_对齐次数 + 1
    返回 每空格额外  // x100精度
}


// 省略号码点
定义 NMTL_省略码点 = 0x2026  // … (HORIZONTAL ELLIPSIS)

// 检查是否需要省略
函数 NMTL_需要省略(行数, 最大行, 剩余文本长度, 溢出模式) {
    如果 (溢出模式 != NMTL_溢出_省略) { 返回 假 }
    如果 (最大行 <= 0) { 返回 假 }
    如果 (行数 >= 最大行 - 1 && 剩余文本长度 > 0) { 返回 真 }
    返回 假
}

// 在行尾添加省略号: 截断文本使 ellipsis 刚好放得下
函数 NMTL_应用省略(face, 行文本, 行长度, 可用宽度) {
    // 获取省略号宽度
    定义 省略字形 = 字体Face_获取字形(face, NMTL_省略码点)
    定义 可变 省略宽 = 0
    如果 (省略字形 != 0) { 省略宽 = 省略字形.前进宽度 / 64 }
    如果 (省略宽 <= 0) { 省略宽 = 12 }  // 回退宽度

    定义 截断宽度 = 可用宽度 - 省略宽
    如果 (截断宽度 < 0) { 截断宽度 = 0 }

    // 从左到右测量到截断点
    定义 可变 累计宽 = 0
    定义 可变 截断点 = 0
    定义 可变 p = 0
    当 (p < 行长度) {
        定义 d = UTF8_解码(行文本, p)
        定义 g = 字体Face_获取字形(face, d[0])
        定义 可变 w = 0
        如果 (g != 0) { w = g.前进宽度 / 64 }
        如果 (累计宽 + w > 截断宽度) { 截断点 = p; 断开 }
        累计宽 = 累计宽 + w
        p = p + d[1]
    }
    如果 (截断点 == 0) { 截断点 = p }

    NMTL_省略次数 = NMTL_省略次数 + 1
    返回 [截断点, 累计宽 + 省略宽]  // [截断字节位置, 截断后行宽含省略]
}


// 绘制水平装饰线
函数 NMTL_绘制装饰线(fb, x, y, 宽度, 颜色, 粗细) {
    如果 (fb == 0 || 宽度 <= 0 || 粗细 <= 0) { 返回 }
    定义 可变 dy = 0
    当 (dy < 粗细) {
        定义 可变 dx = 0
        当 (dx < 宽度) {
            定义 px = x + dx
            定义 py = y + dy
            如果 (px >= 0 && py >= 0 && px < fb.宽度 && py < fb.高度) {
                定义 偏移 = (py * fb.宽度 + px) * 4
                内存_写32(fb.缓冲 + 偏移, 颜色)
            }
            dx = dx + 1
        }
        dy = dy + 1
    }
}

// 应用装饰类型到行
函数 NMTL_应用行装饰(fb, x, 基线y, 行宽, face, 装饰类型, 颜色, 粗细) {
    如果 (装饰类型 == NMTL_装饰_无) { 返回 }
    如果 (粗细 <= 0) { 粗细 = 1 }

    // 下划线: 基线下方1/8字体大小
    如果 (装饰类型 & NMTL_装饰_下划线) {
        定义 下划y = 基线y + (face.上升 / 64) / 8
        NMTL_绘制装饰线(fb, x, 下划y, 行宽, 颜色, 粗细)
    }

    // 删除线: 基线上移字体中间位置
    如果 (装饰类型 & NMTL_装饰_删除线) {
        定义 删除y = 基线y - (face.上升 / 64) / 3
        NMTL_绘制装饰线(fb, x, 删除y, 行宽, 颜色, 粗细)
    }

    // 上划线: 基线上移字体上升高度
    如果 (装饰类型 & NMTL_装饰_上划线) {
        定义 上划y = 基线y - (face.上升 / 64)
        NMTL_绘制装饰线(fb, x, 上划y, 行宽, 颜色, 粗细)
    }
    NMTL_装饰次数 = NMTL_装饰次数 + 1
}


// 判断RTL码点范围 (Arabic + Hebrew + RTL控制符)
函数 NMTL_是RTL码点(码点) {
    // Arabic: U+0600–U+06FF
    如果 (码点 >= 0x0600 && 码点 <= 0x06FF) { 返回 真 }
    // Hebrew: U+0590–U+05FF
    如果 (码点 >= 0x0590 && 码点 <= 0x05FF) { 返回 真 }
    // Arabic Supplement: U+0750–U+077F
    如果 (码点 >= 0x0750 && 码点 <= 0x077F) { 返回 真 }
    // Arabic Extended-A: U+08A0–U+08FF
    如果 (码点 >= 0x08A0 && 码点 <= 0x08FF) { 返回 真 }
    // RTL控制符: RLE/RLO/RLI
    如果 (码点 == 0x202B || 码点 == 0x202E || 码点 == 0x2067) { 返回 真 }
    返回 假
}

// 检测行文本主方向 (第一个强方向字符决定)
函数 NMTL_检测行方向(文本, 长度) {
    定义 可变 p = 0
    当 (p < 长度) {
        定义 d = UTF8_解码(文本, p)
        定义 cp = d[0]
        如果 (NMTL_是RTL码点(cp)) { 返回 NMTL_方向_RTL }
        // Latin/CJK 等为LTR
        如果 ((cp >= 0x0041 && cp <= 0x005A) || (cp >= 0x0061 && cp <= 0x007A)) {
            返回 NMTL_方向_LTR
        }
        如果 (cp >= 0x4E00 && cp <= 0x9FFF) { 返回 NMTL_方向_LTR }
        p = p + d[1]
    }
    返回 NMTL_方向_LTR  // 默认LTR
}


// 测量文本宽度 (不分行)
函数 NMTL_测量宽度(face, 文本, 长度, 字间距) {
    如果 (face == 0 || 文本 == 0) { 返回 0 }
    定义 可变 总宽 = 0
    定义 可变 p = 0
    当 (p < 长度) {
        定义 d = UTF8_解码(文本, p)
        定义 g = 字体Face_获取字形(face, d[0])
        如果 (g != 0) { 总宽 = 总宽 + g.前进宽度 / 64 + 字间距 }
        p = p + d[1]
    }
    返回 总宽
}

// 测量文本高度 (指定宽度后分行)
函数 NMTL_测量高度(face, 文本, 长度, 可用宽度) {
    定义 结果 = Text渲染er_分行(face, 文本, 长度, 可用宽度)
    如果 (结果 == 0) { 返回 0 }
    定义 行数 = 结果[1]
    定义 行高 = (face.上升 - face.下降 + face.行距) / 64
    堆_释放(结果[0])
    返回 行数 * 行高
}

// 文本命中测试: 给定坐标返回字符偏移
函数 NMTL_命中测试(face, 行列表, 行数, 文本, x, y) {
    如果 (行列表 == 0 || 行数 == 0) { 返回 -1 }
    定义 行高 = (face.上升 - face.下降 + face.行距) / 64

    // 先找到y对应的行
    定义 可变 行索引 = y / 行高
    如果 (行索引 < 0) { 行索引 = 0 }
    如果 (行索引 >= 行数) { 行索引 = 行数 - 1 }

    // 读取行信息
    定义 行偏移 = 行列表 + 行索引 * 16
    定义 行起始 = 内存_读32(行偏移)
    定义 行结束 = 内存_读32(行偏移 + 4)

    // 在行内找到x对应的字符
    定义 可变 累计x = 0
    定义 可变 p = 行起始
    当 (p < 行结束) {
        定义 d = UTF8_解码(文本, p)
        定义 g = 字体Face_获取字形(face, d[0])
        定义 可变 w = 0
        如果 (g != 0) { w = g.前进宽度 / 64 }
        如果 (累计x + w / 2 > x) { 返回 p }  // 字符中点左侧
        累计x = 累计x + w
        p = p + d[1]
    }
    返回 p  // 行尾
}


// 主渲染函数: 分行 + 对齐 + 装饰 + 省略 全流程
函数 NMTL_渲染文本(fb, 上下文, 起始x, 起始y, 颜色) {
    如果 (fb == 0 || 上下文 == 0) { 返回 }
    定义 face = 上下文.face
    定义 文本 = 上下文.文本
    定义 可用宽度 = 上下文.可用宽度

    // 第1步: 分行
    定义 布局 = NMTL_分行(上下文)
    如果 (布局 == 0) { 返回 }
    定义 行列表 = 布局[0]
    定义 行数 = 布局[1]
    定义 行高 = (face.上升 - face.下降 + face.行距) / 64
    定义 实际行高 = 行高 * 上下文.行高倍数 / 100
    如果 (实际行高 < 1) { 实际行高 = 行高 }

    // 第2步: 逐行渲染
    定义 可变 i = 0
    当 (i < 行数) {
        定义 行偏移 = 行列表 + i * 16
        定义 行起始 = 内存_读32(行偏移)
        定义 行结束 = 内存_读32(行偏移 + 4)
        定义 行宽 = 内存_读32(行偏移 + 8)
        定义 是最后行 = (i == 行数 - 1)

        // 检查省略
        定义 可变 实际行结束 = 行结束
        定义 可变 实际行宽 = 行宽
        如果 (是最后行 && NMTL_需要省略(行数, 上下文.最大行数, 1, 上下文.溢出模式)) {
            定义 省略结果 = NMTL_应用省略(face, 文本 + 行起始, 行结束 - 行起始, 可用宽度)
            实际行结束 = 行起始 + 省略结果[0]
            实际行宽 = 省略结果[1]
        }

        // 计算对齐偏移
        定义 偏移x = NMTL_计算对齐偏移(实际行宽, 可用宽度, 上下文.对齐方式, 上下文.方向)

        // 两端对齐的额外词间距
        定义 可变 额外词距 = 0
        如果 (上下文.对齐方式 == NMTL_对齐_两端) {
            额外词距 = NMTL_计算两端对齐(文本 + 行起始, 行结束 - 行起始, 行宽, 可用宽度, 是最后行)
        }

        // 渲染字符
        定义 可变 drawx = 起始x + 偏移x
        定义 drawy = 起始y + i * 实际行高 + face.上升 / 64
        定义 可变 p = 行起始
        当 (p < 实际行结束) {
            定义 d = UTF8_解码(文本, p)
            定义 g = 字体Face_获取字形(face, d[0])
            如果 (g != 0) {
                字体_渲染字形(fb, g, drawx, drawy, 颜色)
                drawx = drawx + g.前进宽度 / 64 + 上下文.字间距
                // 两端对齐空格额外距离
                如果 (d[0] == 0x20 && 额外词距 > 0) {
                    drawx = drawx + 额外词距 / 100
                }
            }
            p = p + d[1]
        }

        // 省略号渲染
        如果 (是最后行 && 实际行结束 < 行结束) {
            定义 省略字形 = 字体Face_获取字形(face, NMTL_省略码点)
            如果 (省略字形 != 0) {
                字体_渲染字形(fb, 省略字形, drawx, drawy, 颜色)
            }
        }

        // 装饰线
        NMTL_应用行装饰(fb, 起始x + 偏移x, drawy, 实际行宽, face, 上下文.装饰类型, 上下文.装饰颜色, 上下文.装饰粗细)
        i = i + 1
    }
    堆_释放(行列表)
}


定义 可变 NMTL_AI预测次数 = 0

// AI特征提取: 从布局上下文生成特征向量
函数 NMTL_AI提取特征(上下文, 行列表, 行数) {
    定义 t = Tensor_创建(12)
    如果 (t == 0) { 返回 0 }
    // f0: 平均行宽/可用宽度比
    定义 可变 总行宽 = 0
    定义 可变 最大行宽 = 0
    定义 可变 j = 0
    当 (j < 行数) {
        定义 w = 内存_读32(行列表 + j * 16 + 8)
        总行宽 = 总行宽 + w
        如果 (w > 最大行宽) { 最大行宽 = w }
        j = j + 1
    }
    定义 平均行宽 = 0
    如果 (行数 > 0) { 平均行宽 = 总行宽 / 行数 }
    定义 可用宽 = 上下文.可用宽度
    如果 (可用宽 <= 0) { 可用宽 = 1 }

    Tensor_写(t, 0, 平均行宽 * 1000 / 可用宽)   // f0: 填充率x1000
    Tensor_写(t, 1, 行数)                         // f1: 行数
    Tensor_写(t, 2, 最大行宽)                     // f2: 最大行宽
    Tensor_写(t, 3, 上下文.对齐方式)              // f3: 对齐方式
    Tensor_写(t, 4, 上下文.溢出模式)              // f4: 溢出模式
    Tensor_写(t, 5, 上下文.空白模式)              // f5: 空白模式
    Tensor_写(t, 6, 上下文.字间距)                // f6: 字间距
    Tensor_写(t, 7, 上下文.行高倍数)              // f7: 行高倍数
    Tensor_写(t, 8, 上下文.方向)                  // f8: 文本方向
    Tensor_写(t, 9, 上下文.装饰类型)              // f9: 装饰类型
    Tensor_写(t, 10, 上下文.首行缩进)             // f10: 首行缩进
    Tensor_写(t, 11, 上下文.文本长度)             // f11: 文本长度
    返回 t
}

// AI布局优化预测
函数 NMTL_AI预测布局(上下文, 行列表, 行数) {
    定义 特征 = NMTL_AI提取特征(上下文, 行列表, 行数)
    如果 (特征 == 0) { 返回 }

    定义 填充率 = Tensor_读(特征, 0)
    定义 当前行数 = Tensor_读(特征, 1)

    // 规则: 填充率过低(<400/1000)可能可以缩小可用宽度
    如果 (填充率 < 400 && 当前行数 <= 2) {
        全局AI总线.发布("nmtl_布局建议", "reduce_width", 填充率)
    }

    // 规则: 行数过多(>50)可能需要分页或省略
    如果 (当前行数 > 50) {
        全局AI总线.发布("nmtl_布局建议", "paginate", 当前行数)
    }

    // 异常检测: 行宽方差过大可能是布局问题
    定义 最大行宽 = Tensor_读(特征, 2)
    定义 平均行宽 = 填充率 * 上下文.可用宽度 / 1000
    如果 (最大行宽 > 0 && 平均行宽 > 0) {
        定义 偏差比 = (最大行宽 - 平均行宽) * 100 / 最大行宽
        如果 (偏差比 > 60) {
            AI总线_异常检测("NMTL_行宽方差过大", 偏差比)
        }
    }

    Tensor_释放(特征)
    NMTL_AI预测次数 = NMTL_AI预测次数 + 1
}


函数 NMTL_获取统计() {
    返回 [
        NMTL_布局总数,
        NMTL_总行数,
        NMTL_省略次数,
        NMTL_对齐次数,
        NMTL_装饰次数,
        NMTL_AI预测次数
    ]
}

函数 NMTL_重置统计() {
    NMTL_布局总数 = 0
    NMTL_总行数 = 0
    NMTL_省略次数 = 0
    NMTL_对齐次数 = 0
    NMTL_装饰次数 = 0
    NMTL_AI预测次数 = 0
}

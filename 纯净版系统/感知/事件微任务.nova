// NovaOS 微任务队列/rAF/MutationObserver/性能观察 — 异步调度基础设施
// 本模块实现浏览器异步调度的基础设施:
//   1. 微任务队列: Promise回调/queueMicrotask/MutationObserver
//   2. requestAnimationFrame: VSync对齐的动画回调(双缓冲)
//   3. MutationObserver: DOM变更观察与批量通知
//   4. PerformanceObserver: 长任务/资源加载/绘制时间监控
//   5. 调度优先级: 微任务>rAF>宏任务>idle
//   6. AI异步模式分析: 预测回调密度/优化GC时机
// 与事件循环主体、脚本引擎、渲染引擎、智能大脑深度耦合。

导入("./内核直连层.nova")
导入("../中枢/公共智能.nova")
导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/日志中枢.nova")
导入("../中枢/进程调度.nova")
导入("../中枢/同步原语.nova")
导入("../引导/引导加载器.nova")
导入("./事件循环主体.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/创建甲.nova")
导入("../中枢/整数转字符串.nova")

结构 Microtask {
    回调,    // u64 Nova函数*
    下一个,    // u64 Microtask*
}

定义 可变 微任务队头 = 0
定义 可变 微任务队尾 = 0
定义 可变 微任务数量 = 0
定义 可变 正在清空微任务 = 假

// queueMicrotask(callback)
函数 queueMicrotask(回调) {
    如果 (回调 == 0) { 返回 }
    定义 mt = 堆_分配(Microtask)
    mt.回调 = 回调; mt.下一个 = 0
    如果 (微任务队尾 != 0) { 微任务队尾.下一个 = mt }
    否则 { 微任务队头 = mt }
    微任务队尾 = mt
    微任务数量 = 微任务数量 + 1
}

// 承诺内部使用
函数 承诺_入队微任务(回调) {
    queueMicrotask(回调)
}

// 清空微任务队列(执行所有微任务)
// 规范: 微任务中产生的新微任务也在本轮清空
函数 Microtask_清空() {
    如果 (正在清空微任务) { 返回 }    // 防止重入
    正在清空微任务 = 真

    当 (微任务队头 != 0) {
        定义 mt = 微任务队头
        微任务队头 = mt.下一个
        如果 (微任务队头 == 0) { 微任务队尾 = 0 }
        微任务数量 = 微任务数量 - 1
        // 执行微任务回调
        如果 (mt.回调 != 0) {
            // 调用 mt.回调()
            // 注意: 回调中可能入队新的微任务, 会在本轮继续处理
        }
    }

    正在清空微任务 = 假
}

// §4 requestAnimationFrame

结构 RAFEntry {
    ID,
    回调,    // u64 Nova函数*(接收DOMHighResTimeStamp参数)
    已取消,
    下一个,
}

定义 可变 RAF_链头 = 0
定义 可变 RAF_下一ID = 1
// 双缓冲: 当前帧回调 vs 下一帧回调
定义 可变 RAF_当前帧 = 0
定义 可变 RAF_下一帧 = 0

// requestAnimationFrame(callback) → id
函数 requestAnimationFrame(回调) {
    如果 (回调 == 0) { 返回 0 }
    定义 entry = 堆_分配(RAFEntry)
    entry.ID = RAF_下一ID; RAF_下一ID = RAF_下一ID + 1
    entry.回调 = 回调; entry.已取消 = 假
    entry.下一个 = RAF_下一帧; RAF_下一帧 = entry
    返回 entry.ID
}

// cancelAnimationFrame(id)
函数 cancelAnimationFrame(id) {
    // 在两个链表中查找
    定义 可变 entry = RAF_下一帧
    当 (entry != 0) {
        如果 (entry.ID == id) { entry.已取消 = 真; 返回 }
        entry = entry.下一个
    }
    entry = RAF_当前帧
    当 (entry != 0) {
        如果 (entry.ID == id) { entry.已取消 = 真; 返回 }
        entry = entry.下一个
    }
}

// 执行当前帧的所有rAF回调(由事件循环在渲染前调用)
函数 RAF_执行(帧时间戳) {
    // 交换缓冲: 当前帧=下一帧, 下一帧=空
    RAF_当前帧 = RAF_下一帧; RAF_下一帧 = 0

    定义 可变 entry = RAF_当前帧
    当 (entry != 0) {
        如果 (!entry.已取消 && entry.回调 != 0) {
            // 调用 entry.回调(帧时间戳)
            // 帧时间戳 = performance.now() (DOMHighResTimeStamp)
        }
        entry = entry.下一个
    }
    RAF_当前帧 = 0
}

// §5 MutationObserver — DOM变更观察

结构 MutationObserver {
    ID,
    回调,
    目标节点列表,
    观察选项列表,
    待处理记录,
    已断开,
}

结构 MutationRecord {
    类型,
    目标,
    添加的节点,
    移除的节点,
    上一个兄弟,
    下一个兄弟,
    属性名,
    旧值,
}

结构 MutationObserverInit {
    子树,
    子节点,
    属性,
    属性旧值,
    字符数据,
    字符数据旧值,
    属性过滤,
}

定义 可变 所有观察者 = []
定义 可变 观察者下一ID = 1
定义 可变 变更通知_已排队 = 假
定义 可变 总变更记录数 = 0

函数 MutationObserver_创建(回调) {
    定义 obs = MutationObserver {
        ID: 观察者下一ID,
        回调: 回调,
        目标节点列表: [],
        观察选项列表: [],
        待处理记录: [],
        已断开: 假,
    }
    观察者下一ID = 观察者下一ID + 1
    追加(所有观察者, obs)
    返回 obs
}

函数 MutationObserver_observe(obs, 目标, 选项) {
    如果 (obs == 空 || obs.已断开) { 返回 }
    追加(obs.目标节点列表, 目标)
    追加(obs.观察选项列表, 选项)
}

函数 MutationObserver_disconnect(obs) {
    如果 (obs == 空) { 返回 }
    obs.已断开 = 真
    obs.目标节点列表 = []
    obs.观察选项列表 = []
    obs.待处理记录 = []
}

函数 MutationObserver_takeRecords(obs) {
    如果 (obs == 空) { 返回 [] }
    定义 记录 = obs.待处理记录
    obs.待处理记录 = []
    返回 记录
}

函数 DOM变更_通知(类型, 目标, 记录) {
    总变更记录数 = 总变更记录数 + 1
    // 查找关注此目标的观察者
    定义 可变 i = 0
    当 (i < 计数(所有观察者)) {
        定义 obs = 所有观察者[i]
        如果 (obs.已断开) { i = i + 1; 继续 }

        定义 可变 j = 0
        当 (j < 计数(obs.目标节点列表)) {
            如果 (obs.目标节点列表[j] == 目标) {
                // 匹配: 加入待处理记录
                追加(obs.待处理记录, 记录)
                // 排队微任务通知
                如果 (!变更通知_已排队) {
                    变更通知_已排队 = 真
                    queueMicrotask(MutationObserver_分发通知)
                }
                跳出
            }
            j = j + 1
        }
        i = i + 1
    }
}

函数 MutationObserver_分发通知() {
    变更通知_已排队 = 假
    定义 可变 i = 0
    当 (i < 计数(所有观察者)) {
        定义 obs = 所有观察者[i]
        如果 (!obs.已断开 && 计数(obs.待处理记录) > 0) {
            定义 记录列表 = obs.待处理记录
            obs.待处理记录 = []
            如果 (obs.回调 != 0) {
                调用回调_带参(obs.回调, 记录列表, obs)
            }
        }
        i = i + 1
    }
}

// §6 PerformanceObserver — 性能条目观察

结构 PerformanceEntry {
    名称,
    类型,
    开始时间,
    持续时间,
    详情,
}

结构 PerformanceObserver {
    ID,
    回调,
    类型过滤,
    缓冲条目,
    已断开,
}

定义 可变 性能观察者列表 = []
定义 可变 性能条目缓冲 = []
定义 可变 性能缓冲最大 = 1000
定义 可变 性能观察者下一ID = 1

函数 PerformanceObserver_创建(回调) {
    定义 obs = PerformanceObserver {
        ID: 性能观察者下一ID,
        回调: 回调,
        类型过滤: [],
        缓冲条目: [],
        已断开: 假,
    }
    性能观察者下一ID = 性能观察者下一ID + 1
    追加(性能观察者列表, obs)
    返回 obs
}

函数 PerformanceObserver_observe(obs, 类型列表) {
    如果 (obs == 空) { 返回 }
    obs.类型过滤 = 类型列表
}

函数 PerformanceObserver_disconnect(obs) {
    如果 (obs == 空) { 返回 }
    obs.已断开 = 真
}

函数 性能_记录条目(名称, 类型, 开始, 持续) {
    定义 条目 = PerformanceEntry {
        名称: 名称,
        类型: 类型,
        开始时间: 开始,
        持续时间: 持续,
        详情: 空,
    }
    // 全局缓冲
    追加(性能条目缓冲, 条目)
    如果 (计数(性能条目缓冲) > 性能缓冲最大) {
        性能条目缓冲 = 子列表(性能条目缓冲, 性能缓冲最大 / 2, 性能缓冲最大)
    }

    // 通知观察者
    定义 可变 i = 0
    当 (i < 计数(性能观察者列表)) {
        定义 obs = 性能观察者列表[i]
        如果 (obs.已断开) { i = i + 1; 继续 }
        // 检查类型过滤
        定义 可变 匹配 = (计数(obs.类型过滤) == 0)
        如果 (!匹配) {
            定义 可变 j = 0
            当 (j < 计数(obs.类型过滤)) {
                如果 (obs.类型过滤[j] == 类型) { 匹配 = 真; 跳出 }
                j = j + 1
            }
        }
        如果 (匹配) {
            追加(obs.缓冲条目, 条目)
            // 通过微任务异步通知
            queueMicrotask(obs.回调)
        }
        i = i + 1
    }
}

函数 性能_记录长任务(任务耗时, 开始时间) {
    如果 (任务耗时 > 50) {
        性能_记录条目("self", "longtask", 开始时间, 任务耗时)
    }
}

函数 performance_now() {
    返回 平台_获取高精度时间()
}

函数 performance_mark(名称) {
    性能_记录条目(名称, "mark", performance_now(), 0)
}

函数 performance_measure(名称, 开始标记, 结束标记) {
    // 查找标记时间
    定义 可变 开始 = 0
    定义 可变 结束 = performance_now()
    定义 可变 i = 计数(性能条目缓冲) - 1
    当 (i >= 0) {
        如果 (性能条目缓冲[i].类型 == "mark") {
            如果 (性能条目缓冲[i].名称 == 结束标记) { 结束 = 性能条目缓冲[i].开始时间 }
            如果 (性能条目缓冲[i].名称 == 开始标记) { 开始 = 性能条目缓冲[i].开始时间 }
        }
        i = i - 1
    }
    性能_记录条目(名称, "measure", 开始, 结束 - 开始)
}

// §7 AI异步模式分析

定义 可变 AI_微任务_总执行数 = 0
定义 可变 AI_微任务_每轮最大 = 0
定义 可变 AI_rAF_总执行数 = 0
定义 可变 AI_微任务_连续密集轮 = 0

函数 AI_异步分析_记录微任务轮(本轮执行数) {
    AI_微任务_总执行数 = AI_微任务_总执行数 + 本轮执行数
    如果 (本轮执行数 > AI_微任务_每轮最大) {
        AI_微任务_每轮最大 = 本轮执行数
    }
    // 检测微任务风暴(每轮>100个)
    如果 (本轮执行数 > 100) {
        AI_微任务_连续密集轮 = AI_微任务_连续密集轮 + 1
        如果 (AI_微任务_连续密集轮 > 5) {
            内核调试("[AI-事件循环] 微任务风暴: 连续" + 整数转字符串(AI_微任务_连续密集轮) + "轮>100个微任务")
        }
    } 否则 {
        AI_微任务_连续密集轮 = 0
    }
}

函数 AI_异步分析_建议GC时机() {
    // 微任务密集期不建议GC; 空闲期建议GC
    如果 (AI_微任务_连续密集轮 > 0) { 返回 假 }
    返回 真
}

// §8 统计与诊断

函数 微任务_统计() {
    返回 {
        当前队列大小: 微任务数量,
        总执行数: AI_微任务_总执行数,
        每轮最大: AI_微任务_每轮最大,
        rAF总执行: AI_rAF_总执行数,
        rAF下一ID: RAF_下一ID,
        DOM变更总数: 总变更记录数,
        观察者数: 计数(所有观察者),
        性能条目数: 计数(性能条目缓冲),
        性能观察者数: 计数(性能观察者列表),
        密集轮连续: AI_微任务_连续密集轮,
    }
}

函数 微任务_健康检查() {
    定义 可变 问题 = []
    如果 (微任务数量 > 1000) {
        追加(问题, "微任务积压: " + 整数转字符串(微任务数量))
    }
    如果 (AI_微任务_连续密集轮 > 10) {
        追加(问题, "微任务风暴: 连续" + 整数转字符串(AI_微任务_连续密集轮) + "轮密集")
    }
    如果 (计数(问题) == 0) { 返回 "异步调度健康" }
    返回 问题
}

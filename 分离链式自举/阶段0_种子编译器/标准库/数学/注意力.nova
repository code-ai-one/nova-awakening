导入("../基础.nova")
导入("../../运行时/原语桩.nova")

// Nova标准库 — 注意力机制 (Attention)
// 变换er 核心组件 — 整数定点实现
// 对标 nova-forth 的 attention/ 模块

定义 注意力精度 = 1000

// 缩放点积注意力 (Scaled Dot-Product Attention, 0, 0, 0, 0)
// Attention(Q,K,V) = 归一化指数(Q·K^T / sqrt(键维度)) · V
// Q,K,V 均为矩阵: [行数, 列数, 数据...]

// 矩阵基本操作 (本模块内部)
函数 注意力_矩阵创建(行, 列) { 定义 可变 m = [行, 列]
 定义 可变 i = 0
 当 (i < 行 * 列) { 追加(m, 0) i = i + 1 }
 返回 m
}

函数 注意力_取(m, i, j) { 返回 m[2 + i * m[1] + j] }
函数 注意力_设(m, i, j, v) { m[2 + i * m[1] + j] = v }

// Q·K^T
函数 注意力_qk转置乘(Q, K) { 定义 seq_q = Q[0]
 定义 键维度 = Q[1]
 定义 seq_k = K[0]
 定义 可变 结果 = 注意力_矩阵创建(seq_q, seq_k)
 定义 可变 i = 0
 当 (i < seq_q) { 定义 可变 j = 0
 当 (j < seq_k) { 定义 可变 和 = 0
 定义 可变 k = 0
 当 (k < 键维度) {
 和 = 和 + 注意力_取(Q, i, k) * 注意力_取(K, j, k) / 注意力精度
 k = k + 1
 }
 注意力_设(结果, i, j, 和)
 j = j + 1
 }
 i = i + 1
 }
 返回 结果
}

// 缩放: 除以 sqrt(键维度)
函数 注意力_缩放(分数矩阵, 键维度) { 定义 行 = 分数矩阵[0]
 定义 列 = 分数矩阵[1]
 定义 可变 缩放因子 = 注意力_开方(键维度 * 注意力精度)
 如果 (缩放因子 == 0) { 缩放因子 = 1 }
 定义 可变 i = 0
 当 (i < 行) { 定义 可变 j = 0
 当 (j < 列) { 定义 原值 = 注意力_取(分数矩阵, i, j)
 注意力_设(分数矩阵, i, j, 原值 * 注意力精度 / 缩放因子)
 j = j + 1
 }
 i = i + 1
 }
}

// 按行 Softmax
函数 注意力_行softmax(矩阵) { 定义 行 = 矩阵[0]
 定义 列 = 矩阵[1]
 定义 可变 i = 0
 当 (i < 行) {
 // 找行最大值
 定义 可变 最大 = 注意力_取(矩阵,  i, 0)
 定义 可变 j = 1
 当 (j < 列) { 定义 v = 注意力_取(矩阵, i, j)
 如果 (v > 最大) { 最大 = v }
 j = j + 1
 }
 // 减最大值 + 近似exp + 求和
 定义 可变 总和 = 0
 定义 可变 指数 = []
 j = 0
 当 (j < 列) { 定义 偏移 = 注意力_取(矩阵, i, j) - 最大
 定义 可变 e = 注意力精度 + 偏移
 如果 (e < 1) { e = 1 }
 追加(指数, e)
 总和 = 总和 + e
 j = j + 1
 }
 // 归一化
 j = 0
 当 (j < 列) {
 注意力_设(矩阵, i, j, 指数[j] * 注意力精度 / 总和)
 j = j + 1
 }
 i = i + 1
 }
}

// 注意力权重 × V
函数 注意力_权重乘V(权重, V) { 定义 seq_q = 权重[0]
 定义 seq_v = V[0]
 定义 值维度 = V[1]
 定义 可变 结果 = 注意力_矩阵创建(seq_q, 值维度)
 定义 可变 i = 0
 当 (i < seq_q) { 定义 可变 j = 0
 当 (j < 值维度) { 定义 可变 和 = 0
 定义 可变 k = 0
 当 (k < seq_v) {
 和 = 和 + 注意力_取(权重, i, k) * 注意力_取(V, k, j) / 注意力精度
 k = k + 1
 }
 注意力_设(结果, i, j, 和)
 j = j + 1
 }
 i = i + 1
 }
 返回 结果
}

// 完整的缩放点积注意力
函数 缩放点积注意力(Q, K, V, _扩4, _扩5) { 定义 键维度 = Q[1]
 // 1. 计算 Q·K^T
 定义 可变 分数 = 注意力_qk转置乘(Q, K)
 // 2. 缩放
 注意力_缩放(分数, 键维度)
 // 3. Softmax
 注意力_行softmax(分数)
 // 4. 乘以 V
 返回 注意力_权重乘V(分数, V)
}

// 因果掩码 (Causal Mask)
// 用于自回归模型 — 防止看到未来的token
函数 应用因果掩码(分数矩阵) { 定义 行 = 分数矩阵[0]
 定义 列 = 分数矩阵[1]
 定义 可变 i = 0
 当 (i < 行) { 定义 可变 j = i + 1
 当 (j < 列) {
 注意力_设(分数矩阵, i, j, 0 - 0x7FFFFFFF)
 j = j + 1
 }
 i = i + 1
 }
}

// 带因果掩码的注意力
函数 因果注意力(Q, K, V) { 定义 键维度 = Q[1]
 定义 可变 分数 = 注意力_qk转置乘(Q, K)
 注意力_缩放(分数, 键维度)
 应用因果掩码(分数)
 注意力_行softmax(分数)
 返回 注意力_权重乘V(分数, V)
}

// 多头注意力 (Multi-Head Attention, 0 , 0, 0)
// 简化版: 将输入分割成多个头, 分别计算注意力, 再拼接
函数 多头注意力(Q, K, V, 头数) { 定义 序列 = Q[0]
 定义 模型维度 = Q[1]
 定义 头维度 = 模型维度 / 头数
 定义 可变 输出列表 = []
 定义 可变 h = 0
 当 (h < 头数) {
 // 提取第h个头的Q,K,V
 定义 可变 Qh = 注意力_矩阵创建(序列, 头维度)
 定义 可变 Kh = 注意力_矩阵创建(K[0], 头维度)
 定义 可变 Vh = 注意力_矩阵创建(V[0], 头维度)
 定义 可变 i = 0
 当 (i < 序列) { 定义 可变 j = 0
 当 (j < 头维度) {
 注意力_设(Qh, i, j, 注意力_取(Q, i, h * 头维度 + j))
 j = j + 1
 }
 i = i + 1
 }
 i = 0
 当 (i < K[0]) { 定义 可变 j2 = 0
 当 (j2 < 头维度) {
 注意力_设(Kh, i, j2, 注意力_取(K, i, h * 头维度 + j2))
 注意力_设(Vh, i, j2, 注意力_取(V, i, h * 头维度 + j2))
 j2 = j2 + 1
 }
 i = i + 1
 }
 // 单头注意力
 定义 头输出 = 缩放点积注意力(Qh,  Kh,  Vh, 0, 0)
 追加(输出列表, 头输出)
 h = h + 1
 }
 // 拼接所有头
 定义 可变 结果 = 注意力_矩阵创建(序列, 模型维度)
 h = 0
 当 (h < 头数) { 定义 头 = 输出列表[h]
 定义 可变 i2 = 0
 当 (i2 < 序列) { 定义 可变 j3 = 0
 当 (j3 < 头维度) {
 注意力_设(结果, i2, h * 头维度 + j3, 注意力_取(头, i2, j3))
 j3 = j3 + 1
 }
 i2 = i2 + 1
 }
 h = h + 1
 }
 返回 结果
}

// Layer Normalization (层归一化)
函数 注意力_层归一化(向量) { 定义 n = 计数(向量)
    定义 可变 方差和 = 0
 // 均值
 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < n) { 和 = 和 + 向量[i] i = i + 1 }
 定义 均值 = 和 / n
 // 方差
 i = 0
 当 (i < n) { 定义 差 = 向量[i] - 均值
 方差和 = 方差和 + 差 * 差
 i = i + 1
 }
 定义 可变 标准差 = 注意力_开方(方差和 / n)
 如果 (标准差 == 0) { 标准差 = 1 }
 // 归一化
 定义 可变 结果 = []
 i = 0
 当 (i < n) {
 追加(结果, (向量[i] - 均值) * 注意力精度 / 标准差)
 i = i + 1
 }
 返回 结果
}

// 残差连接
函数 残差连接(输入, 输出) { 定义 n = 计数(输入)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < n) {
 追加(结果, 输入[i] + 输出[i])
 i = i + 1
 }
 返回 结果
}

// 位置编码 (Positional Encoding, 0)
// 使用整数近似的正弦/余弦位置编码
函数 位置编码(序列长度, 模型维度) { 定义 可变 pe = 注意力_矩阵创建(序列长度, 模型维度)
 定义 可变 位置 = 0
 当 (位置 < 序列长度) { 定义 可变 i = 0
 当 (i < 模型维度) {
 // 简化: 使用线性位置信息
 如果 (i % 2 == 0) {
 // sin 近似
 定义 周期 = (i + 2) * 100
 定义 角度 = 位置 * 注意力精度 / 周期
 定义 值 = 注意力_sin近似(角度)
 注意力_设(pe, 位置, i, 值)
 } 否则 {
 // cos 近似
 定义 周期 = (i + 1) * 100
 定义 角度 = 位置 * 注意力精度 / 周期
 定义 值 = 注意力_cos近似(角度)
 注意力_设(pe, 位置, i, 值)
 }
 i = i + 1
 }
 位置 = 位置 + 1
 }
 返回 pe
}

// 分组查询注意力 (GQA,  LLaMA-2风格, 0 , 0, 0)
// Q有n_heads个头, K/V只有n_kv_heads个头 (共享)
// 当n_kv_heads=1时退化为MQA, 当n_kv_heads=n_heads时退化为MHA

函数 分组查询注意力(Q, K, V, q头数, kv头数) { 定义 序列 = Q[0]
 定义 模型维度 = Q[1]
 定义 头维度 = 模型维度 / q头数
 定义 组大小 = q头数 / kv头数 // 每组共享KV的Q头数

 定义 可变 输出列表 = []
 定义 可变 h = 0
 当 (h < q头数) {
 // Q: 第h个头
 定义 可变 Qh = 注意力_矩阵创建(序列, 头维度)
 定义 可变 i = 0
 当 (i < 序列) { 定义 可变 j = 0
 当 (j < 头维度) {
 注意力_设(Qh, i, j, 注意力_取(Q, i, h * 头维度 + j))
 j = j + 1
 }
 i = i + 1
 }
 // K/V: 第 h/组大小 个头 (共享)
 定义 kv_idx = h / 组大小
 定义 可变 Kh = 注意力_矩阵创建(K[0], 头维度)
 定义 可变 Vh = 注意力_矩阵创建(V[0], 头维度)
 i = 0
 当 (i < K[0]) { 定义 可变 j2 = 0
 当 (j2 < 头维度) {
 注意力_设(Kh, i, j2, 注意力_取(K, i, kv_idx * 头维度 + j2))
 注意力_设(Vh, i, j2, 注意力_取(V, i, kv_idx * 头维度 + j2))
 j2 = j2 + 1
 }
 i = i + 1
 }
 追加(输出列表, 缩放点积注意力(Qh,  Kh,  Vh, 0, 0))
 h = h + 1
 }
 // 拼接
 定义 可变 结果 = 注意力_矩阵创建(序列, 模型维度)
 h = 0
 当 (h < q头数) { 定义 头 = 输出列表[h]
 定义 可变 i2 = 0
 当 (i2 < 序列) { 定义 可变 j3 = 0
 当 (j3 < 头维度) {
 注意力_设(结果, i2, h * 头维度 + j3, 注意力_取(头, i2, j3))
 j3 = j3 + 1
 }
 i2 = i2 + 1
 }
 h = h + 1
 }
 返回 结果
}

// 滑动窗口注意力 (Mistral/Longformer风格, 0 , 0, 0)
// 每个位置只关注前后window_size个token, 降低O(n²)到O(n·w)

函数 滑动窗口注意力(Q, K, V, 窗口大小) { 定义 序列 = Q[0]
    定义 可变 分数列表 = []
 定义 键维度 = Q[1]
 定义 可变 缩放因子 = 注意力_开方(键维度 * 注意力精度)
 如果 (缩放因子 == 0) { 缩放因子 = 1 }

 定义 可变 输出 = 注意力_矩阵创建(序列, V[1])
 定义 可变 qi = 0
 当 (qi < 序列) {
 // 窗口范围
 定义 可变 起 = qi - 窗口大小
 如果 (起 < 0) { 起 = 0 }
 定义 可变 _止 = qi + 窗口大小 + 1
 如果 (_止 > K[0]) { _止 = K[0] }
 // 计算局部注意力分数
 定义 可变 ki = 起
 当 (ki < _止) { 定义 可变 点积 = 0
 定义 可变 d = 0
 当 (d < 键维度) {
 点积 = 点积 + 注意力_取(Q, qi, d) * 注意力_取(K, ki, d) / 注意力精度
 d = d + 1
 }
 追加(分数列表, 点积 * 注意力精度 / 缩放因子)
 ki = ki + 1
 }
 // 局部softmax
 定义 窗长 = _止 - 起
 定义 可变 最大s = 分数列表[0]
 定义 可变 si = 1
 当 (si < 窗长) { 如果 (分数列表[si] > 最大s) { 最大s = 分数列表[si] }
 si = si + 1
 }
 定义 可变 exp列表 = []
 定义 可变 总和 = 0
 si = 0
 当 (si < 窗长) { 定义 可变 e = 注意力精度 + 分数列表[si] - 最大s
 如果 (e < 1) { e = 1 }
 追加(exp列表, e)
 总和 = 总和 + e
 si = si + 1
 }
 // 加权求和V
 定义 可变 vd = 0
 当 (vd < V[1]) { 定义 可变 和 = 0
 si = 0
 当 (si < 窗长) {
 和 = 和 + exp列表[si] * 注意力_取(V, 起 + si, vd) / 总和
 si = si + 1
 }
 注意力_设(输出, qi, vd, 和)
 vd = vd + 1
 }
 qi = qi + 1
 }
 返回 输出
}

// 线性注意力 (O(n) 复杂度, 0 , 0)
// Attention(Q,K,V) ≈ φ(Q) · (φ(K)^T · V)
// φ(x) = 指数线性函数(x) + 1 (特征映射)
// 避免softmax, 复杂度从O(n²d)降到O(nd²)

函数 注意力_elu_plus1(x) {
    如果 (x >= 0) { 返回 x + 注意力精度
}
 // 指数线性函数(x) + 1 = e^x ≈ 1 + x (for x<0, simplified)
 定义 可变 v = 注意力精度 + x
 如果 (v < 1) { v = 1 }
 返回 v
}

函数 线性注意力(Q, K, V) { 定义 序列 = Q[0]
 定义 键维度 = Q[1]
 定义 值维度 = V[1]

 // φ(K)^T · V → [键维度 × 值维度]
 定义 可变 kv = []
 定义 可变 di = 0
 当 (di < 键维度 * 值维度) { 追加(kv, 0)
 di = di + 1 }

 定义 可变 k_sum = []
 di = 0
 当 (di < 键维度) { 追加(k_sum, 0)
 di = di + 1 }

 定义 可变 si = 0
 当 (si < K[0]) {
 di = 0
 当 (di < 键维度) { 定义 phi_k = 注意力_elu_plus1(注意力_取(K, si, di))
 k_sum[di] = k_sum[di] + phi_k
 定义 可变 dj = 0
 当 (dj < 值维度) {
 kv[di * 值维度 + dj] = kv[di * 值维度 + dj] + phi_k * 注意力_取(V, si, dj) / 注意力精度
 dj = dj + 1
 }
 di = di + 1
 }
 si = si + 1
 }

 // φ(Q) · KV / (φ(Q) · k_sum)
 定义 可变 输出 = 注意力_矩阵创建(序列, 值维度)
 定义 可变 qi = 0
 当 (qi < 序列) {
 // 分母: φ(Q[qi]) · k_sum
 定义 可变 分母 = 0
 di = 0
 当 (di < 键维度) {
 分母 = 分母 + 注意力_elu_plus1(注意力_取(Q, qi, di)) * k_sum[di] / 注意力精度
 di = di + 1
 }
 如果 (分母 < 1) { 分母 = 1 }
 // 分子: φ(Q[qi]) · KV
 定义 可变 dj2 = 0
 当 (dj2 < 值维度) { 定义 可变 数值 = 0
 di = 0
 当 (di < 键维度) {
 数值 = 数值 + 注意力_elu_plus1(注意力_取(Q, qi, di)) * kv[di * 值维度 + dj2] / 注意力精度
 di = di + 1
 }
 注意力_设(输出, qi, dj2, 数值 * 注意力精度 / 分母)
 dj2 = dj2 + 1
 }
 qi = qi + 1
 }
 返回 输出
}

// 交叉注意力 (Cross-Attention, 0 , 0, 0)
// Q来自解码器, K/V来自编码器 (用于encoder-decoder模型)

函数 交叉注意力(decoder_Q, encoder_K, encoder_V, 头数) { 返回 多头注意力(decoder_Q, encoder_K, encoder_V, 头数)
}

// 注意力分数可视化
// 返回注意力权重矩阵 (不乘V, 用于分析)

函数 注意力权重(Q, K) { 定义 键维度 = Q[1]
 定义 可变 分数 = 注意力_qk转置乘(Q, K)
 注意力_缩放(分数, 键维度)
 注意力_行softmax(分数)
 返回 分数
}

// 注意力熵 (衡量注意力集中度)
// 熵低 = 注意力集中在少数位置
// 熵高 = 注意力均匀分散

函数 注意力熵(权重矩阵) { 定义 行 = 权重矩阵[0]
 定义 列 = 权重矩阵[1]
 定义 可变 总熵 = 0
 定义 可变 i = 0
 当 (i < 行) { 定义 可变 行熵 = 0
 定义 可变 j = 0
 当 (j < 列) { 定义 p = 注意力_取(权重矩阵, i, j)
 如果 (p > 0) {
 行熵 = 行熵 + p * (注意力精度 - p) / 注意力精度
 }
 j = j + 1
 }
 总熵 = 总熵 + 行熵
 i = i + 1
 }
 如果 (行 == 0) { 返回 0 }
 返回 总熵 / 行
}

// 稀疏注意力 (Sparse Attention, 0 , 0 , 0, 0)
// 只计算局部窗口+全局token的注意力
函数 稀疏注意力(Q, K, V, 窗口大小, 全局数) { 定义 序列 = Q[0]
 定义 键维度 = Q[1]
 // 先做完整注意力
 定义 可变 分数 = 注意力_qk转置乘(Q, K)
 注意力_缩放(分数, 键维度)
 // 稀疏掩码: 只保留窗口内和全局token
 定义 可变 i = 0
 当 (i < 序列) { 定义 可变 j = 0
 当 (j < 序列) { 定义 可变 在窗口 = 假
 // 局部窗口
 定义 可变 距离 = i - j
 如果 (距离 < 0) { 距离 = 0 - 距离 }
 如果 (距离 <= 窗口大小) { 在窗口 = 真 }
 // 全局token (前几个)
 如果 (j < 全局数) { 在窗口 = 真 }
 如果 (i < 全局数) { 在窗口 = 真 }
 如果 (在窗口 == 假) {
 注意力_设(分数, i, j, 0 - 99999)
 }
 j = j + 1
 }
 i = i + 1
 }
 注意力_行softmax(分数)
 返回 注意力_乘V(分数, V)
}

// 前缀注意力 (Prefix Attention, 0 , 0, 0)
// 前缀token可以互相看到, 生成token只能看前面
函数 前缀注意力(Q, K, V, 前缀长) { 定义 序列 = Q[0]
 定义 键维度 = Q[1]
 定义 可变 分数 = 注意力_qk转置乘(Q, K)
 注意力_缩放(分数, 键维度)
 // 前缀: 双向, 生成: 因果
 定义 可变 i = 0
 当 (i < 序列) { 定义 可变 j = 0
 当 (j < 序列) { 如果 (i >= 前缀长 且 j > i) {
 注意力_设(分数, i, j, 0 - 99999)
 }
 j = j + 1
 }
 i = i + 1
 }
 注意力_行softmax(分数)
 返回 注意力_乘V(分数, V)
}

// SE注意力 (Squeeze-and-Excitation, 通道注意力)
函数 se注意力(通道特征, 通道数, 缩减比) { 定义 可变 缩减维 = 通道数 / 缩减比
 如果 (缩减维 == 0) { 缩减维 = 1 }
 // Squeeze: 全局平均
 // 输入已是通道特征向量
 // Excitation: FC → 线性整流 → FC → Sigmoid
 定义 可变 中间 = []
 定义 可变 i = 0
 当 (i < 缩减维) { 定义 可变 和 = 0
 定义 可变 j = 0
 当 (j < 通道数) {
 和 = 和 + 通道特征[j] * 注意力精度 / 通道数
 j = j + 1
 }
 如果 (和 < 0) { 和 = 0 } // 线性整流
 追加(中间, 和)
 i = i + 1
 }
 // 第二层FC + Sigmoid
 定义 可变 权重 = []
 i = 0
 当 (i < 通道数) { 定义 可变 和2 = 0
 定义 可变 j2 = 0
 当 (j2 < 缩减维) {
 和2 = 和2 + 中间[j2] / 缩减维
 j2 = j2 + 1
 }
 // Sigmoid近似
 如果 (和2 > 5000) { 和2 = 注意力精度 }
 否则 如果 (和2 < 0 - 5000) { 和2 = 0 }
 否则 { 和2 = 注意力精度 / 2 + 和2 / 4 }
 追加(权重, 和2)
 i = i + 1
 }
 // 通道加权
 定义 可变 结果 = []
 i = 0
 当 (i < 通道数) {
 追加(结果, 通道特征[i] * 权重[i] / 注意力精度)
 i = i + 1
 }
 返回 结果
}

// 多查询注意力 (MQA, 0 , 0, 0)
// 所有头共享一个K和V
函数 多查询注意力(Q, K, V, 头数) { 定义 序列 = Q[0]
 定义 total_d = Q[1]
 定义 可变 键维度 = total_d / 头数
 如果 (键维度 == 0) { 键维度 = 1 }
 定义 可变 输出 = 注意力_矩阵创建(序列, total_d)
 定义 可变 h = 0
 当 (h < 头数) {
 // Q分头, K/V共享
 定义 可变 Qh = 注意力_矩阵创建(序列, 键维度)
 定义 可变 i = 0
 当 (i < 序列) { 定义 可变 j = 0
 当 (j < 键维度) {
 注意力_设(Qh, i, j, 注意力_取(Q, i, h * 键维度 + j))
 j = j + 1
 }
 i = i + 1
 }
 // 单头注意力 (用共享KV)
 定义 可变 分数 = 注意力_qk转置乘(Qh, K)
 注意力_缩放(分数, 键维度)
 注意力_行softmax(分数)
 定义 可变 头输出 = 注意力_乘V(分数, V)
 // 写回
 i = 0
 当 (i < 序列) { 定义 可变 j2 = 0
 当 (j2 < 键维度) {
 注意力_设(输出, i, h * 键维度 + j2, 注意力_取(头输出, i, j2))
 j2 = j2 + 1
 }
 i = i + 1
 }
 h = h + 1
 }
 返回 输出
}

// 注意力_乘V: 注意力_权重乘V 的别名
函数 注意力_乘V(分数, V) { 返回 注意力_权重乘V(分数, V) }

// 内部工具

函数 注意力_开方(n) { 返回 开方(n) }

// sin 近似 (输入: 角度*1000, 输出: sin*1000)
函数 注意力_sin近似(x) {
 // 将 x 归一化到 [0, 6283] (0 to 2π * 1000)
 定义 可变 角 = x % 6283
 如果 (角 < 0) { 角 = 角 + 6283 }
 // 分段线性近似
 如果 (角 < 1571) { 返回 角 * 注意力精度 / 1571 }
 如果 (角 < 3142) { 返回 (3142 - 角) * 注意力精度 / 1571 }
 如果 (角 < 4712) { 返回 0 - (角 - 3142) * 注意力精度 / 1571 }
 返回 0 - (6283 - 角) * 注意力精度 / 1571
}

// cos 近似
函数 注意力_cos近似(x) { 返回 注意力_sin近似(x + 1571)
}

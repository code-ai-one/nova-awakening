// NovaOS IDT (中断描述符表)
// 功能: IDT条目管理、异常/IRQ/系统调用向量注册、IDT加载

导入("../执行/端口.nova")
导入("../引导/寄存器定义.nova")
导入("../引导/引导加载器.nova")
导入("./自动扩容.nova")
导入("./字符串替换.nova")
导入("../外联/分配地址客.nova")
导入("./中断表初始化.nova")

定义 IDT_条目数 = 256
定义 IDT_条目大小 = 16    // 64位模式每条16字节
定义 IDT_总大小 = 4096     // 256 * 16
定义 可变 IDT缓冲 = 空

定义 IDT_中断门       = 0x8E    // P=1, DPL=0, 64位中断门
定义 IDT_陷阱门       = 0x8F    // P=1, DPL=0, 64位陷阱门
定义 IDT_用户中断门   = 0xEE    // P=1, DPL=3, 允许用户态触发
定义 IDT_用户陷阱门   = 0xEF    // P=1, DPL=3, 用户态陷阱
定义 IDT_无效门       = 0x00    // P=0, 未使用

// 0-31:    CPU异常(由Intel定义)
// 32-47:   传统PIC IRQ (已废弃，重映射到接口C)
// 48-127:  IO-接口C外部中断
// 128:     系统调用 (int 0x80)
// 129-238: 动态分配IRQ
// 239:     接口C定时器
// 240:     接口C热插拔
// 241:     接口C性能计数器
// 242-248: 保留
// 249:     接口C调度IPI
// 250:     接口C TLB刷新IPI
// 251:     接口C函数调用IPI
// 252:     接口C重调度IPI
// 253:     接口C错误
// 254:     接口C热管理
// 255:     接口C伪中断
定义 向量_系统调用     = 0x80
定义 向量_接口C定时器   = 0xEF
定义 向量_接口C错误     = 0xFD
定义 向量_接口C伪中断   = 0xFF
定义 向量_调度IPI       = 0xF9
定义 向量_TLB_IPI       = 0xFA
定义 向量_函数调用IPI   = 0xFB
定义 向量_重调度IPI     = 0xFC
定义 向量_外部IRQ起始   = 0x30
定义 向量_外部IRQ结束   = 0xEE
定义 向量_动态起始      = 0x81
定义 向量_动态结束      = 0xEE

定义 IST_无             = 0
定义 IST_双重故障       = 1
定义 IST_NMI            = 2
定义 IST_调试           = 3
定义 IST_机器检查       = 4

定义 可变 向量分配位图 = 数组<u64, 4>   // 256位位图
定义 可变 向量分配锁 = 自旋锁 {}

// IDT IDTR结构

结构 IDTR {
    界限,
    基址,
}

// IDT条目结构(便于调试和读取)

结构 IDT条目信息 {
    向量号,
    偏移,
    选择子,
    类型,
    IST,
    已设置,
}

// IDT条目写入

函数 IDT_写条目(向量号, 处理函数地址, 选择子, 类型, IST编号) {
    如果 (向量号 >= IDT_条目数) { 返回 }
    定义 偏移 = 向量号 * IDT_条目大小
    // 字节0-1: 偏移低16位
    缓冲写16(IDT缓冲, 偏移, 处理函数地址 & 0xFFFF)
    // 字节2-3: 段选择子
    缓冲写16(IDT缓冲, 偏移 + 2, 选择子)
    // 字节4: IST (低3位)
    缓冲写(IDT缓冲, 偏移 + 4, IST编号 & 0x7)
    // 字节5: 类型+属性
    缓冲写(IDT缓冲, 偏移 + 5, 类型)
    // 字节6-7: 偏移中16位
    缓冲写16(IDT缓冲, 偏移 + 6, (处理函数地址 >> 16) & 0xFFFF)
    // 字节8-11: 偏移高32位
    缓冲写32(IDT缓冲, 偏移 + 8, (处理函数地址 >> 32) & 0xFFFFFFFF)
    // 字节12-15: 保留(必须为0)
    缓冲写32(IDT缓冲, 偏移 + 12, 0)
}

函数 IDT_读条目(向量号) {
    如果 (向量号 >= IDT_条目数) { 返回 空 }
    定义 偏移 = 向量号 * IDT_条目大小

    定义 可变 信息 = IDT条目信息 {}
    信息.向量号 = 向量号

    定义 低16 = 缓冲读16(IDT缓冲, 偏移)
    定义 中16 = 缓冲读16(IDT缓冲, 偏移 + 6)
    定义 高32 = 缓冲读32(IDT缓冲, 偏移 + 8)
    信息.偏移 = 低16 | (中16 << 16) | (高32 << 32)

    信息.选择子 = 缓冲读16(IDT缓冲, 偏移 + 2)
    信息.IST = 缓冲读(IDT缓冲, 偏移 + 4) & 0x7
    信息.类型 = 缓冲读(IDT缓冲, 偏移 + 5)
    信息.已设置 = (信息.类型 & 0x80) != 0  // P位

    返回 信息
}

函数 IDT_清除条目(向量号) {
    如果 (向量号 >= IDT_条目数) { 返回 }
    定义 偏移 = 向量号 * IDT_条目大小
    定义 可变 i = 0
    当 (i < IDT_条目大小) {
        缓冲写(IDT缓冲, 偏移 + i, 0)
        i = i + 1
    }
    写条目_清除次数 = 写条目_清除次数 + 1
}

定义 可变 写条目_写入次数 = 0
定义 可变 写条目_读取次数 = 0
定义 可变 写条目_清除次数 = 0
定义 可变 写条目_修改次数 = 0
定义 可变 写条目_批量次数 = 0
定义 可变 写条目_验证次数 = 0
定义 可变 写条目_验证失败 = 0
定义 可变 写条目_保存次数 = 0
定义 可变 写条目_恢复次数 = 0
定义 可变 写条目_错误数 = 0

// IDT条目修改(不完全重写, 只改指定字段)

函数 IDT_修改IST(向量号, 新IST) {
    如果 (向量号 >= IDT_条目数) { 返回 错误_无效参数 }
    如果 (新IST > 7) { 返回 错误_无效参数 }
    定义 偏移 = 向量号 * IDT_条目大小
    缓冲写(IDT缓冲, 偏移 + 4, 新IST & 0x7)
    写条目_修改次数 = 写条目_修改次数 + 1
    返回 0
}

函数 IDT_修改类型(向量号, 新类型) {
    如果 (向量号 >= IDT_条目数) { 返回 错误_无效参数 }
    定义 偏移 = 向量号 * IDT_条目大小
    缓冲写(IDT缓冲, 偏移 + 5, 新类型)
    写条目_修改次数 = 写条目_修改次数 + 1
    返回 0
}

函数 IDT_修改处理函数(向量号, 新地址) {
    如果 (向量号 >= IDT_条目数) { 返回 错误_无效参数 }
    如果 (新地址 == 0) { 返回 错误_无效参数 }
    定义 偏移 = 向量号 * IDT_条目大小
    缓冲写16(IDT缓冲, 偏移, 新地址 & 0xFFFF)
    缓冲写16(IDT缓冲, 偏移 + 6, (新地址 >> 16) & 0xFFFF)
    缓冲写32(IDT缓冲, 偏移 + 8, (新地址 >> 32) & 0xFFFFFFFF)
    写条目_修改次数 = 写条目_修改次数 + 1
    返回 0
}

函数 IDT_设置屏蔽(向量号) {
    // 将P位清零, 使条目无效(屏蔽该中断)
    如果 (向量号 >= IDT_条目数) { 返回 错误_无效参数 }
    定义 偏移 = 向量号 * IDT_条目大小
    定义 旧类型 = 缓冲读(IDT缓冲, 偏移 + 5)
    缓冲写(IDT缓冲, 偏移 + 5, 旧类型 & 0x7F)
    写条目_修改次数 = 写条目_修改次数 + 1
    返回 0
}

函数 IDT_取消屏蔽(向量号) {
    // 将P位置1, 使条目有效
    如果 (向量号 >= IDT_条目数) { 返回 错误_无效参数 }
    定义 偏移 = 向量号 * IDT_条目大小
    定义 旧类型 = 缓冲读(IDT缓冲, 偏移 + 5)
    缓冲写(IDT缓冲, 偏移 + 5, 旧类型 | 0x80)
    写条目_修改次数 = 写条目_修改次数 + 1
    返回 0
}

// 批量写入

函数 IDT_批量写(条目列表) {
    // 条目列表格式: [[向量号, 处理函数地址, 选择子, 类型, IST], ...]
    如果 (条目列表 == 空) { 返回 错误_无效参数 }
    定义 可变 成功 = 0
    定义 可变 i = 0
    当 (i < 计数(条目列表)) {
        定义 项 = 条目列表[i]
        如果 (计数(项) >= 5) {
            IDT_写条目(项[0], 项[1], 项[2], 项[3], 项[4])
            成功 = 成功 + 1
        }
        i = i + 1
    }
    写条目_批量次数 = 写条目_批量次数 + 1
    返回 成功
}

函数 IDT_批量清除(起始向量, 结束向量) {
    如果 (起始向量 >= IDT_条目数) { 返回 错误_无效参数 }
    如果 (结束向量 >= IDT_条目数) { 结束向量 = IDT_条目数 - 1 }
    定义 可变 i = 起始向量
    当 (i <= 结束向量) {
        IDT_清除条目(i)
        i = i + 1
    }
    返回 0
}

// 门类型名称

函数 IDT_门类型名(类型) {
    如果 (类型 == IDT_中断门) { 返回 "中断门(DPL=0)" }
    如果 (类型 == IDT_陷阱门) { 返回 "陷阱门(DPL=0)" }
    如果 (类型 == IDT_用户中断门) { 返回 "中断门(DPL=3)" }
    如果 (类型 == IDT_用户陷阱门) { 返回 "陷阱门(DPL=3)" }
    如果 (类型 == IDT_无效门) { 返回 "无效(P=0)" }
    如果 ((类型 & 0x80) == 0) { 返回 "未使用" }
    返回 "未知(0x" + 转字符串(类型) + ")"
}

函数 IDT_IST名(IST编号) {
    如果 (IST编号 == IST_无) { 返回 "无" }
    如果 (IST编号 == IST_双重故障) { 返回 "双重故障" }
    如果 (IST编号 == IST_NMI) { 返回 "NMI" }
    如果 (IST编号 == IST_调试) { 返回 "调试" }
    如果 (IST编号 == IST_机器检查) { 返回 "机器检查" }
    返回 "IST" + 转字符串(IST编号)
}

// 向量号到异常名映射

函数 IDT_异常名(向量号) {
    如果 (向量号 == 0) { 返回 "#DE 除零" }
    如果 (向量号 == 1) { 返回 "#DB 调试" }
    如果 (向量号 == 2) { 返回 "NMI 不可屏蔽" }
    如果 (向量号 == 3) { 返回 "#BP 断点" }
    如果 (向量号 == 4) { 返回 "#OF 溢出" }
    如果 (向量号 == 5) { 返回 "#BR 越界" }
    如果 (向量号 == 6) { 返回 "#UD 无效操作码" }
    如果 (向量号 == 7) { 返回 "#NM 无FPU" }
    如果 (向量号 == 8) { 返回 "#DF 双重故障" }
    如果 (向量号 == 9) { 返回 "协处理器段溢出" }
    如果 (向量号 == 10) { 返回 "#TS 无效TSS" }
    如果 (向量号 == 11) { 返回 "#NP 段不在" }
    如果 (向量号 == 12) { 返回 "#SS 栈段错" }
    如果 (向量号 == 13) { 返回 "#GP 一般保护" }
    如果 (向量号 == 14) { 返回 "#PF 缺页" }
    如果 (向量号 == 16) { 返回 "#MF 浮点异常" }
    如果 (向量号 == 17) { 返回 "#AC 对齐检查" }
    如果 (向量号 == 18) { 返回 "#MC 机器检查" }
    如果 (向量号 == 19) { 返回 "#XM SIMD浮点" }
    如果 (向量号 == 20) { 返回 "#VE 虚拟化" }
    如果 (向量号 == 21) { 返回 "#CP 控制保护" }
    如果 (向量号 == 向量_系统调用) { 返回 "系统调用" }
    如果 (向量号 == 向量_接口C定时器) { 返回 "APIC定时器" }
    如果 (向量号 == 向量_接口C错误) { 返回 "APIC错误" }
    如果 (向量号 == 向量_接口C伪中断) { 返回 "APIC伪中断" }
    如果 (向量号 >= 向量_外部IRQ起始 && 向量号 <= 向量_外部IRQ结束) {
        返回 "外部IRQ" + 转字符串(向量号 - 向量_外部IRQ起始)
    }
    返回 "向量" + 转字符串(向量号)
}

函数 IDT_异常有错误码(向量号) {
    // 以下CPU异常会自动压入错误码
    如果 (向量号 == 8) { 返回 真 }
    如果 (向量号 == 10) { 返回 真 }
    如果 (向量号 == 11) { 返回 真 }
    如果 (向量号 == 12) { 返回 真 }
    如果 (向量号 == 13) { 返回 真 }
    如果 (向量号 == 14) { 返回 真 }
    如果 (向量号 == 17) { 返回 真 }
    如果 (向量号 == 21) { 返回 真 }
    返回 假
}

// 条目验证

函数 IDT_验证条目(向量号) {
    如果 (向量号 >= IDT_条目数) { 返回 假 }
    写条目_验证次数 = 写条目_验证次数 + 1
    定义 信息 = IDT_读条目(向量号)
    如果 (信息 == 空) { 返回 假 }
    // P位检查
    如果 (信息.已设置 == 假) {
        如果 (向量号 < 32) {
            // 异常向量必须设置
            写条目_验证失败 = 写条目_验证失败 + 1
            返回 假
        }
        返回 真  // 非异常向量可以不设置
    }
    // 选择子检查: 必须指向内核代码段
    如果 (信息.选择子 == 0) {
        写条目_验证失败 = 写条目_验证失败 + 1
        返回 假
    }
    // 偏移检查: 不能为0(除非条目未使用)
    如果 (信息.偏移 == 0 && 信息.已设置 == 真) {
        写条目_验证失败 = 写条目_验证失败 + 1
        返回 假
    }
    返回 真
}

函数 IDT_验证全部() {
    定义 可变 错误数 = 0
    定义 可变 i = 0
    当 (i < IDT_条目数) {
        如果 (IDT_验证条目(i) == 假) {
            错误数 = 错误数 + 1
        }
        i = i + 1
    }
    如果 (错误数 > 0) {
        打印("[IDT验证] 发现 " + 转字符串(错误数) + " 个异常条目")
    } 否则 {
        打印("[IDT验证] 全部通过")
    }
    返回 错误数
}

// IDT保存/恢复 (电源管理)

定义 可变 IDT_保存缓冲 = 空
定义 可变 IDT_已保存 = 假

函数 IDT_保存() {
    如果 (IDT缓冲 == 空) { 返回 错误_未初始化 }
    如果 (IDT_保存缓冲 == 空) {
        IDT_保存缓冲 = 缓冲区(IDT_总大小)
    }
    内存复制(IDT_保存缓冲, IDT缓冲, IDT_总大小)
    IDT_已保存 = 真
    写条目_保存次数 = 写条目_保存次数 + 1
    返回 0
}

函数 IDT_恢复() {
    如果 (IDT_已保存 == 假) { 返回 错误_无效参数 }
    如果 (IDT_保存缓冲 == 空) { 返回 错误_无效参数 }
    内存复制(IDT缓冲, IDT_保存缓冲, IDT_总大小)
    写条目_恢复次数 = 写条目_恢复次数 + 1
    返回 0
}

// IDT dump (调试)

函数 IDT_dump条目(向量号) {
    如果 (向量号 >= IDT_条目数) { 返回 }
    定义 信息 = IDT_读条目(向量号)
    如果 (信息 == 空) { 返回 }
    如果 (信息.已设置 == 假 && 向量号 >= 32) { 返回 }
    打印("  [" + 转字符串(向量号) + "] " + IDT_异常名(向量号) +
         " 偏移=0x" + 转字符串(信息.偏移) +
         " 类型=" + IDT_门类型名(信息.类型) +
         " IST=" + IDT_IST名(信息.IST) +
         " P=" + 转字符串(信息.已设置))
}

函数 IDT_dump全部() {
    打印("[IDT dump] ═══════════════════════")
    定义 可变 已设置数 = 0
    定义 可变 i = 0
    当 (i < IDT_条目数) {
        定义 信息 = IDT_读条目(i)
        如果 (信息 != 空 && 信息.已设置 == 真) {
            IDT_dump条目(i)
            已设置数 = 已设置数 + 1
        }
        i = i + 1
    }
    打印("  已设置条目: " + 转字符串(已设置数) + "/" + 转字符串(IDT_条目数))
    打印("[IDT dump] ═══════════════════════")
}

函数 IDT_dump异常() {
    打印("[IDT 异常] ──────────────────")
    定义 可变 i = 0
    当 (i < 32) {
        IDT_dump条目(i)
        i = i + 1
    }
    打印("[IDT 异常] ──────────────────")
}

// 统计查询

函数 IDT_已设置数() {
    定义 可变 数量 = 0
    定义 可变 i = 0
    当 (i < IDT_条目数) {
        定义 偏移 = i * IDT_条目大小
        定义 类型 = 缓冲读(IDT缓冲, 偏移 + 5)
        如果 ((类型 & 0x80) != 0) { 数量 = 数量 + 1 }
        i = i + 1
    }
    返回 数量
}

函数 IDT_中断门数() {
    定义 可变 数量 = 0
    定义 可变 i = 0
    当 (i < IDT_条目数) {
        定义 偏移 = i * IDT_条目大小
        定义 类型 = 缓冲读(IDT缓冲, 偏移 + 5)
        如果 (类型 == IDT_中断门 || 类型 == IDT_用户中断门) { 数量 = 数量 + 1 }
        i = i + 1
    }
    返回 数量
}

函数 IDT_陷阱门数() {
    定义 可变 数量 = 0
    定义 可变 i = 0
    当 (i < IDT_条目数) {
        定义 偏移 = i * IDT_条目大小
        定义 类型 = 缓冲读(IDT缓冲, 偏移 + 5)
        如果 (类型 == IDT_陷阱门 || 类型 == IDT_用户陷阱门) { 数量 = 数量 + 1 }
        i = i + 1
    }
    返回 数量
}

函数 IDT_用户门数() {
    定义 可变 数量 = 0
    定义 可变 i = 0
    当 (i < IDT_条目数) {
        定义 偏移 = i * IDT_条目大小
        定义 类型 = 缓冲读(IDT缓冲, 偏移 + 5)
        如果 (类型 == IDT_用户中断门 || 类型 == IDT_用户陷阱门) { 数量 = 数量 + 1 }
        i = i + 1
    }
    返回 数量
}

// 完整统计 (≥15个指标)

函数 IDT_写条目_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "总条目数", IDT_条目数)
    字典设(统计, "已设置数", IDT_已设置数())
    字典设(统计, "中断门数", IDT_中断门数())
    字典设(统计, "陷阱门数", IDT_陷阱门数())
    字典设(统计, "用户门数", IDT_用户门数())
    字典设(统计, "写入次数", 写条目_写入次数)
    字典设(统计, "读取次数", 写条目_读取次数)
    字典设(统计, "清除次数", 写条目_清除次数)
    字典设(统计, "修改次数", 写条目_修改次数)
    字典设(统计, "批量次数", 写条目_批量次数)
    字典设(统计, "验证次数", 写条目_验证次数)
    字典设(统计, "验证失败", 写条目_验证失败)
    字典设(统计, "保存次数", 写条目_保存次数)
    字典设(统计, "恢复次数", 写条目_恢复次数)
    字典设(统计, "错误数", 写条目_错误数)
    字典设(统计, "IDT缓冲", IDT缓冲 != 空)
    字典设(统计, "已保存", IDT_已保存)
    返回 统计
}

函数 IDT_写条目_打印统计() {
    定义 统计 = IDT_写条目_完整统计()
    打印("[IDT条目] ═══════ 完整统计 ═══════")
    打印("  已设置:     " + 转字符串(字典取(统计, "已设置数")) + "/" + 转字符串(字典取(统计, "总条目数")))
    打印("  中断门:     " + 转字符串(字典取(统计, "中断门数")))
    打印("  陷阱门:     " + 转字符串(字典取(统计, "陷阱门数")))
    打印("  用户门:     " + 转字符串(字典取(统计, "用户门数")))
    打印("  写入次数:   " + 转字符串(字典取(统计, "写入次数")))
    打印("  读取次数:   " + 转字符串(字典取(统计, "读取次数")))
    打印("  清除次数:   " + 转字符串(字典取(统计, "清除次数")))
    打印("  修改次数:   " + 转字符串(字典取(统计, "修改次数")))
    打印("  验证次数:   " + 转字符串(字典取(统计, "验证次数")))
    打印("  验证失败:   " + 转字符串(字典取(统计, "验证失败")))
    打印("  保存次数:   " + 转字符串(字典取(统计, "保存次数")))
    打印("  错误数:     " + 转字符串(字典取(统计, "错误数")))
    打印("[IDT条目] ═════════════════════════")
    返回 0
}

// 销毁与清理

函数 IDT_写条目_销毁() {
    如果 (IDT缓冲 != 空) {
        // 清除所有条目
        内存填充(IDT缓冲, 0, IDT_总大小)
    }
    如果 (IDT_保存缓冲 != 空) {
        IDT_保存缓冲 = 空
    }
    IDT_已保存 = 假
    打印("[IDT条目] 已销毁")
    返回 0
}

// 与其他子系统的接口

函数 IDT_为IRQ注册提供条目(向量号, 处理函数地址) {
    返回 IDT_写条目(向量号, 处理函数地址, GDT_内核代码, IDT_中断门, IST_无)
}

函数 IDT_为电源管理挂起() {
    IDT_保存()
    返回 0
}

函数 IDT_为电源管理恢复() {
    IDT_恢复()
    IDT_加载()
    返回 0
}

函数 IDT_为procfs提供信息() {
    返回 [IDT_条目数, IDT_已设置数(), IDT_中断门数(), IDT_陷阱门数(), IDT_用户门数()]
}

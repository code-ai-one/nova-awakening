函数 模糊与(a, b) {
    定义 _a = a + 0.0
    定义 _b = b + 0.0
    返回 _a * _b
}

函数 主程序() {
    // 直接看 bits
    定义 r = 模糊与(0.2, 0.9)
    打印(字符串拼接("r bits=", 转字符串(r)))
    // 期望 0.18 bits = 4594572339843380491 (0x3FC70A3D70A3D70B)
    
    // 测比较
    定义 diff = r - 0.18
    打印(字符串拼接("diff bits=", 转字符串(diff)))
    
    如果 (diff < 0.001) {
        打印("diff < 0.001 ✓")
    } 否则 {
        打印("diff >= 0.001 ✗")
    }
    返回 0
}

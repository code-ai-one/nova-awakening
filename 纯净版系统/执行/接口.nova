// 执行脑区 · 薄接口
// 统一职责: phase 装载 + 页面会话执行 + 浏览器外衣动作出口

导入("../中枢/阶段契约.nova")
导入("../中枢/会话桥一体.nova")
导入("./阶段装载.nova")
导入("./列目录.nova")
导入("./查找.nova")

定义 可变 执行_调用计数 = 0
定义 可变 执行_最近阶段 = ""
定义 可变 执行_最近总线消息 = 空

函数 执行_阶段清单(阶段) {
    返回 执行阶段装载_清单(阶段)
}

函数 执行_加载阶段(阶段) {
    如果 (!阶段契约_有效(阶段)) { 返回 -1 }
    执行_最近阶段 = 阶段
    返回 执行阶段装载_登记(阶段)
}

函数 执行_初始化() {
    执行_加载阶段(阶段_boot)
    执行_加载阶段(阶段_浏览器外衣)
    配置_初始化()
    反检测_初始化()
    一体桥_桥心跳(一体桥_确保系统会话("纯净版系统", "执行接口"), "运行", "未连接", "运行")
    返回 0
}

函数 执行_创建页面会话(名称, 网址) {
    定义 系统会话ID = 一体桥_确保系统会话("纯净版系统", "执行接口")
    返回 一体桥_创建页面会话(系统会话ID, 名称, 网址)
}

函数 执行_打开页面(网址) {
    定义 系统会话ID = 一体桥_确保系统会话("纯净版系统", "执行接口")
    返回 执行_打开页面_会话(系统会话ID, 网址)
}

函数 执行_打开页面_会话(系统会话ID, 网址) {
    定义 页面会话ID = 一体桥_创建页面会话(系统会话ID, "页面会话", 网址)
    如果 (页面会话ID == 0) { 返回 0 }

    定义 标签ID = NTLM_创建标签(1, 网址, 0)
    如果 (标签ID != 0) {
        NTLM_激活标签(标签ID)
        浏览器内核_导航(标签ID, 网址)
        标签页管理_绑定页面会话(页面会话ID, 标签ID)
    }
    一体桥_记录动作(页面会话ID, "执行_打开页面")
    返回 页面会话ID
}

函数 执行_导航页面_会话(页面会话ID, 网址) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 假 }
    定义 可变 标签ID = 会话.标签ID

    如果 (标签ID == 0) {
        标签ID = NTLM_创建标签(1, 网址, 0)
        如果 (标签ID == 0) { 返回 假 }
        NTLM_激活标签(标签ID)
        标签页管理_绑定页面会话(页面会话ID, 标签ID)
    }

    浏览器内核_导航(标签ID, 网址)
    一体桥_设置页面网址(页面会话ID, 网址)
    一体桥_记录动作(页面会话ID, "执行_导航页面")
    返回 真
}

函数 执行_关闭页面(页面会话ID) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 -1 }
    NTLM_关闭标签(会话.标签ID)
    返回 0
}

函数 执行_点击元素(页面会话ID, 选择器) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 假 }
    一体桥_记录动作(页面会话ID, "执行_点击元素")
    定义 目标页 = 如果 (会话.标签ID != 0) { 会话.标签ID } 否则 { 页面会话ID }
    定义 结果 = 自动编排_点击(目标页, 选择器)
    一体桥_记录回执(页面会话ID, 结果, "click", 选择器, 如果 (结果) { "" } 否则 { "点击失败" }, 0, "")
    返回 结果
}

函数 执行_输入文本(页面会话ID, 选择器, 文本) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 假 }
    一体桥_记录动作(页面会话ID, "执行_输入文本")
    定义 目标页 = 如果 (会话.标签ID != 0) { 会话.标签ID } 否则 { 页面会话ID }
    定义 结果 = 自动编排_输入(目标页, 选择器, 文本)
    一体桥_记录回执(页面会话ID, 结果, "input", 选择器, 如果 (结果) { "" } 否则 { "输入失败" }, 0, "")
    返回 结果
}

函数 执行_获取页面内容(页面会话ID) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 0 }
    一体桥_记录动作(页面会话ID, "执行_获取页面内容")
    定义 目标页 = 如果 (会话.标签ID != 0) { 会话.标签ID } 否则 { 页面会话ID }
    返回 自动编排_获取内容(目标页)
}

函数 执行_截图(页面会话ID) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 空 }
    一体桥_记录动作(页面会话ID, "执行_截图")
    返回 一体桥_生成视觉帧(页面会话ID, 0, 0, 0, 0, [])
}

函数 执行_列目录(路径, 选项) {
    执行_最近阶段 = "system-list"
    NDLS_增强列出(路径, 选项)
    返回 列目录_统计()
}

函数 执行_查找命令(参数) {
    执行_最近阶段 = "system-find"
    返回 find_main(参数)
}

函数 执行_搜索内容(路径, 模式, 最大深度) {
    执行_最近阶段 = "system-grep"
    返回 find_grep(路径, 模式, 最大深度)
}

函数 执行_编排任务(任务描述) {
    返回 自动编排_创建任务(任务描述)
}

函数 执行_执行步骤() {
    自动编排_执行步骤()
}

函数 执行_任务状态() {
    返回 自动编排_当前状态()
}

函数 执行_启用反检测() {
    反检测_全局启用()
}

函数 执行_设置指纹(配置) {
    反检测_设置指纹配置(配置)
}

函数 执行_安全入口(调用者, 操作码) {
    执行_调用计数 = 执行_调用计数 + 1
    如果 (调用者 < 0 || 调用者 > 8) { 返回 -1 }
    返回 0
}

函数 执行_处理总线消息(调用者, 操作码, 数据) {
    执行_最近总线消息 = {
        调用者: 调用者,
        操作码: 操作码,
        数据: 数据
    }
    如果 (操作码 == 0x100) {
        执行_执行步骤()
    }
    如果 (操作码 == 0x110 && 数据 != 空) {
        返回 执行_列目录(数据.路径, 数据.选项)
    }
    如果 (操作码 == 0x111 && 数据 != 空) {
        返回 执行_查找命令(数据.参数)
    }
    如果 (操作码 == 0x112 && 数据 != 空) {
        返回 执行_搜索内容(数据.路径, 数据.模式, 数据.最大深度)
    }
    返回 0
}

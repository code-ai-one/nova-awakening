    定义 节点 = 文档
    定义 结果 = 事件Dispatch_scroll(节点, deltaX, deltaY)
    档.输入数 = 档.输入数 + 1
    档.分发数 = 档.分发数 + 1
    返回 文档事件_成功(档, "命中滚动", [节点, 结果])
}


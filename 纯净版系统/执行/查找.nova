// NovaOS find — 文件搜索
// 功能: 递归搜索, -name/-iname/-type/-size/-mtime/-perm/-maxdepth/-empty/-newer/-exec

导入("../标准/文件.nova")
导入("../感知/流.nova")
导入("../标准/原生字符串.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/内核打印.nova")

结构 Find配置 {
    路径,
    名称模式,
    名称忽略大小写,
    类型过滤,
    最小大小,
    最大大小,
    修改天数,
    修改比较,
    权限掩码,
    最大深度,
    仅空,
    较新参考,
    较新时间,
    执行命令,
    打印路径,
    删除匹配,
}

结构 Find统计 {
    扫描文件数,
    扫描目录数,
    匹配数,
    跳过数,
    执行命令数,
    删除数,
    最大深度达到,
}

定义 可变 全局_find统计 = 空

函数 find统计_初始化() {
    如果 (全局_find统计 == 空) {
        全局_find统计 = Find统计 {}
        全局_find统计.扫描文件数 = 0
        全局_find统计.扫描目录数 = 0
        全局_find统计.匹配数 = 0
        全局_find统计.跳过数 = 0
        全局_find统计.执行命令数 = 0
        全局_find统计.删除数 = 0
        全局_find统计.最大深度达到 = 0
    }
}

函数 find_解析参数(参数) {
    定义 配置 = Find配置 {}
    配置.路径 = "."
    配置.名称模式 = ""
    配置.名称忽略大小写 = 假
    配置.类型过滤 = ""
    配置.最小大小 = -1
    配置.最大大小 = -1
    配置.修改天数 = 0
    配置.修改比较 = 0
    配置.权限掩码 = -1
    配置.最大深度 = 999
    配置.仅空 = 假
    配置.较新参考 = ""
    配置.较新时间 = 0
    配置.执行命令 = ""
    配置.打印路径 = 真
    配置.删除匹配 = 假

    定义 可变 路径已设 = 假
    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 a = 参数[i]
        如果 (a == "-name" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.名称模式 = 参数[i]
            配置.名称忽略大小写 = 假
        } 否则 如果 (a == "-iname" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.名称模式 = 参数[i]
            配置.名称忽略大小写 = 真
        } 否则 如果 (a == "-type" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.类型过滤 = 参数[i]
        } 否则 如果 (a == "-size" && i + 1 < 计数(参数)) {
            i = i + 1
            find_解析大小(参数[i], 配置)
        } 否则 如果 (a == "-mtime" && i + 1 < 计数(参数)) {
            i = i + 1
            find_解析修改时间(参数[i], 配置)
        } 否则 如果 (a == "-perm" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.权限掩码 = 字符串转整数(参数[i])
        } 否则 如果 (a == "-maxdepth" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.最大深度 = 字符串转整数(参数[i])
        } 否则 如果 (a == "-empty") {
            配置.仅空 = 真
        } 否则 如果 (a == "-newer" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.较新参考 = 参数[i]
            配置.较新时间 = 文件_修改时间(参数[i])
        } 否则 如果 (a == "-exec" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.执行命令 = 参数[i]
        } 否则 如果 (a == "-delete") {
            配置.删除匹配 = 真
            配置.打印路径 = 假
        } 否则 如果 (a == "-print") {
            配置.打印路径 = 真
        } 否则 如果 (!路径已设) {
            配置.路径 = a
            路径已设 = 真
        }
        i = i + 1
    }
    返回 配置
}

函数 find_解析大小(大小字符串, 配置) {
    定义 长 = 字符串长度(大小字符串)
    如果 (长 == 0) { 返回 }

    定义 首字符 = 字符串取字符(大小字符串, 0)
    定义 可变 数值串 = 大小字符串
    定义 可变 乘数 = 512

    // 检查后缀: c=字节, k=KB, M=MB, G=GB
    定义 末字符 = 字符串取字符(大小字符串, 长 - 1)
    如果 (末字符 == 99) { 乘数 = 1  数值串 = 字符串子串(大小字符串, 0, 长 - 1) }
    否则 如果 (末字符 == 107) { 乘数 = 1024  数值串 = 字符串子串(大小字符串, 0, 长 - 1) }
    否则 如果 (末字符 == 77) { 乘数 = 1024 * 1024  数值串 = 字符串子串(大小字符串, 0, 长 - 1) }
    否则 如果 (末字符 == 71) { 乘数 = 1024 * 1024 * 1024  数值串 = 字符串子串(大小字符串, 0, 长 - 1) }

    如果 (首字符 == 43) {
        配置.最小大小 = 字符串转整数(字符串子串(数值串, 1, 字符串长度(数值串))) * 乘数
    } 否则 如果 (首字符 == 45) {
        配置.最大大小 = 字符串转整数(字符串子串(数值串, 1, 字符串长度(数值串))) * 乘数
    } 否则 {
        定义 精确 = 字符串转整数(数值串) * 乘数
        配置.最小大小 = 精确
        配置.最大大小 = 精确 + 乘数 - 1
    }
}

函数 find_解析修改时间(时间字符串, 配置) {
    定义 首字符 = 字符串取字符(时间字符串, 0)
    如果 (首字符 == 43) {
        配置.修改天数 = 字符串转整数(字符串子串(时间字符串, 1, 字符串长度(时间字符串)))
        配置.修改比较 = 1
    } 否则 如果 (首字符 == 45) {
        配置.修改天数 = 字符串转整数(字符串子串(时间字符串, 1, 字符串长度(时间字符串)))
        配置.修改比较 = -1
    } 否则 {
        配置.修改天数 = 字符串转整数(时间字符串)
        配置.修改比较 = 0
    }
}

函数 find_main(参数) {
    find统计_初始化()
    定义 配置 = find_解析参数(参数)

    如果 (配置.路径 == "" && 计数(参数) == 0) {
        打印行("用法: find [路径] [选项]")
        打印行("  -name 模式    名称匹配(支持*通配符)")
        打印行("  -iname 模式   忽略大小写名称匹配")
        打印行("  -type f|d     类型过滤(f=文件,d=目录)")
        打印行("  -size [+/-]N[c|k|M|G]  大小过滤")
        打印行("  -mtime [+/-]N 修改时间(天)")
        打印行("  -maxdepth N   最大递归深度")
        打印行("  -empty        仅空文件/目录")
        打印行("  -newer 文件   比文件新")
        打印行("  -exec 命令    对匹配执行命令")
        打印行("  -delete       删除匹配项")
        返回 1
    }

    find_递归(配置.路径, 配置, 0)
    返回 0
}

函数 find_递归(路径, 配置, 深度) {
    如果 (深度 > 配置.最大深度) {
        全局_find统计.最大深度达到 = 全局_find统计.最大深度达到 + 1
        返回
    }

    定义 条目 = 文件_读目录(路径)
    如果 (条目 == 空) { 返回 }

    全局_find统计.扫描目录数 = 全局_find统计.扫描目录数 + 1

    定义 可变 i = 0
    当 (i < 计数(条目)) {
        定义 名称 = 条目[i][0]
        定义 子路径 = 字符串拼接(路径, 字符串拼接("/", 名称))
        定义 是目录 = 文件_是目录(子路径)

        如果 (是目录) {
            全局_find统计.扫描目录数 = 全局_find统计.扫描目录数 + 1
        } 否则 {
            全局_find统计.扫描文件数 = 全局_find统计.扫描文件数 + 1
        }

        定义 匹配 = find_检查匹配(名称, 子路径, 是目录, 配置)

        如果 (匹配) {
            全局_find统计.匹配数 = 全局_find统计.匹配数 + 1

            如果 (配置.打印路径) {
                打印行(子路径)
            }

            如果 (配置.执行命令 != "") {
                find_执行命令(配置.执行命令, 子路径)
                全局_find统计.执行命令数 = 全局_find统计.执行命令数 + 1
            }

            如果 (配置.删除匹配 && !是目录) {
                文件_删除(子路径)
                全局_find统计.删除数 = 全局_find统计.删除数 + 1
            }
        } 否则 {
            全局_find统计.跳过数 = 全局_find统计.跳过数 + 1
        }

        // 递归进入子目录
        如果 (是目录) {
            find_递归(子路径, 配置, 深度 + 1)
        }
        i = i + 1
    }
}

函数 find_检查匹配(名称, 路径, 是目录, 配置) {
    // 类型过滤
    如果 (配置.类型过滤 == "f" && 是目录) { 返回 假 }
    如果 (配置.类型过滤 == "d" && !是目录) { 返回 假 }

    // 名称匹配
    如果 (配置.名称模式 != "") {
        定义 可变 检查名 = 名称
        定义 可变 检查模式 = 配置.名称模式
        如果 (配置.名称忽略大小写) {
            检查名 = 字符串转小写(名称)
            检查模式 = 字符串转小写(配置.名称模式)
        }
        如果 (!find_匹配名称(检查名, 检查模式)) { 返回 假 }
    }

    // 大小过滤
    如果 (配置.最小大小 >= 0 || 配置.最大大小 >= 0) {
        如果 (是目录) { 返回 假 }
        定义 文件大小 = 文件_大小(路径)
        如果 (配置.最小大小 >= 0 && 文件大小 < 配置.最小大小) { 返回 假 }
        如果 (配置.最大大小 >= 0 && 文件大小 > 配置.最大大小) { 返回 假 }
    }

    // 修改时间过滤
    如果 (配置.修改天数 > 0) {
        定义 文件时间 = 文件_修改时间(路径)
        定义 当前时间 = 系统_时间()
        定义 天差 = (当前时间 - 文件时间) / 86400
        如果 (配置.修改比较 == 1 && 天差 <= 配置.修改天数) { 返回 假 }
        如果 (配置.修改比较 == -1 && 天差 >= 配置.修改天数) { 返回 假 }
        如果 (配置.修改比较 == 0 && 天差 != 配置.修改天数) { 返回 假 }
    }

    // 权限过滤
    如果 (配置.权限掩码 >= 0) {
        定义 文件权限 = 文件_权限(路径)
        如果 ((文件权限 & 配置.权限掩码) != 配置.权限掩码) { 返回 假 }
    }

    // 空文件/目录过滤
    如果 (配置.仅空) {
        如果 (是目录) {
            定义 子条目 = 文件_读目录(路径)
            如果 (子条目 != 空 && 计数(子条目) > 0) { 返回 假 }
        } 否则 {
            如果 (文件_大小(路径) > 0) { 返回 假 }
        }
    }

    // 比较新过滤
    如果 (配置.较新参考 != "" && 配置.较新时间 > 0) {
        定义 文件时间 = 文件_修改时间(路径)
        如果 (文件时间 <= 配置.较新时间) { 返回 假 }
    }

    返回 真
}

函数 find_匹配名称(名称, 模式) {
    定义 模式长 = 字符串长度(模式)
    如果 (模式长 == 0) { 返回 真 }

    // *.ext: 匹配后缀
    如果 (字符串取字符(模式, 0) == 42) {
        如果 (模式长 > 1 && 字符串取字符(模式, 模式长 - 1) == 42) {
            // *中间*: 包含匹配
            定义 中间 = 字符串子串(模式, 1, 模式长 - 1)
            返回 字符串包含(名称, 中间)
        }
        定义 后缀 = 字符串子串(模式, 1, 模式长)
        返回 字符串以结尾(名称, 后缀)
    }
    // prefix*: 匹配前缀
    如果 (字符串取字符(模式, 模式长 - 1) == 42) {
        定义 前缀 = 字符串子串(模式, 0, 模式长 - 1)
        返回 字符串以开头(名称, 前缀)
    }
    // 精确匹配
    返回 名称 == 模式
}

函数 find_执行命令(命令模板, 文件路径) {
    // 将 {} 替换为文件路径
    定义 可变 实际命令 = 命令模板
    如果 (字符串包含(命令模板, "{}")) {
        实际命令 = 字符串替换(命令模板, "{}", 文件路径)
    } 否则 {
        实际命令 = 字符串拼接(命令模板, 字符串拼接(" ", 文件路径))
    }
    系统_执行(实际命令)
}

函数 字符串以结尾(文本, 后缀) {
    定义 文长 = 字符串长度(文本)
    定义 后长 = 字符串长度(后缀)
    如果 (后长 > 文长) { 返回 假 }
    返回 字符串子串(文本, 文长 - 后长, 文长) == 后缀
}

函数 字符串以开头(文本, 前缀) {
    定义 前长 = 字符串长度(前缀)
    如果 (前长 > 字符串长度(文本)) { 返回 假 }
    返回 字符串子串(文本, 0, 前长) == 前缀
}

函数 find_打印统计() {
    find统计_初始化()
    打印行("=== find统计 ===")
    打印行("扫描文件: " + 整数转字符串(全局_find统计.扫描文件数))
    打印行("扫描目录: " + 整数转字符串(全局_find统计.扫描目录数))
    打印行("匹配数: " + 整数转字符串(全局_find统计.匹配数))
    打印行("跳过数: " + 整数转字符串(全局_find统计.跳过数))
    打印行("执行命令: " + 整数转字符串(全局_find统计.执行命令数))
    打印行("删除数: " + 整数转字符串(全局_find统计.删除数))
    如果 (全局_find统计.扫描文件数 + 全局_find统计.扫描目录数 > 0) {
        定义 命中率 = 全局_find统计.匹配数 * 1000 / (全局_find统计.扫描文件数 + 全局_find统计.扫描目录数)
        打印行("命中率: " + 整数转字符串(命中率) + "/1000")
    }
}

// §7 内容搜索 — grep式文件内容匹配

定义 可变 全局_grep匹配数 = 0

函数 find_grep(路径, 模式, 最大深度) {
    // 在路径下递归搜索文件内容包含模式的文件
    全局_grep匹配数 = 0
    find_grep_递归(路径, 模式, 0, 最大深度)
    返回 全局_grep匹配数
}

函数 find_grep_递归(路径, 模式, 深度, 最大深度) {
    如果 (深度 > 最大深度) { 返回 }
    定义 条目 = 文件_读目录(路径)
    如果 (条目 == 空) { 返回 }

    定义 可变 i = 0
    当 (i < 计数(条目)) {
        定义 名称 = 条目[i][0]
        定义 子路径 = 字符串拼接(路径, 字符串拼接("/", 名称))
        定义 是目录 = 条目[i][1] == 1

        如果 (是目录) {
            find_grep_递归(子路径, 模式, 深度 + 1, 最大深度)
        } 否则 {
            // 读文件内容搜索
            定义 内容 = 文件_读全(子路径)
            如果 (内容 != 空 && 字符串包含(内容, 模式)) {
                打印行(子路径)
                全局_grep匹配数 = 全局_grep匹配数 + 1
            }
        }
        i = i + 1
    }
}

// §8 高级匹配 — 正则简化匹配 (支持 ? 单字符通配)

函数 find_高级匹配(文本, 模式) {
    // 支持 * 和 ? 通配符的递归匹配
    返回 find_通配匹配_递归(文本, 0, 模式, 0)
}

函数 find_通配匹配_递归(文本, ti, 模式, pi) {
    定义 文长 = 字符串长度(文本)
    定义 模长 = 字符串长度(模式)

    如果 (pi == 模长) { 返回 ti == 文长 }

    定义 模字符 = 字符串取字符(模式, pi)

    如果 (模字符 == 42) {  // '*'
        // * 匹配零到多个字符
        定义 可变 k = ti
        当 (k <= 文长) {
            如果 (find_通配匹配_递归(文本, k, 模式, pi + 1)) {
                返回 真
            }
            k = k + 1
        }
        返回 假
    }

    如果 (ti >= 文长) { 返回 假 }

    如果 (模字符 == 63) {  // '?' 匹配任一字符
        返回 find_通配匹配_递归(文本, ti + 1, 模式, pi + 1)
    }

    如果 (字符串取字符(文本, ti) == 模字符) {
        返回 find_通配匹配_递归(文本, ti + 1, 模式, pi + 1)
    }

    返回 假
}

// §9 批量操作 — 收集+排序结果

定义 可变 find_结果缓冲 = []
定义 可变 find_结果数 = 0
定义 find_最大结果 = 4096

函数 find_收集结果(路径, 配置, 最大深度) {
    find_结果缓冲 = []
    find_结果数 = 0
    find_收集递归(路径, 配置, 0, 最大深度)
    返回 find_结果数
}

函数 find_收集递归(路径, 配置, 深度, 最大深度) {
    如果 (深度 > 最大深度 || find_结果数 >= find_最大结果) { 返回 }
    定义 条目 = 文件_读目录(路径)
    如果 (条目 == 空) { 返回 }

    定义 可变 i = 0
    当 (i < 计数(条目)) {
        定义 名称 = 条目[i][0]
        定义 子路径 = 字符串拼接(路径, 字符串拼接("/", 名称))
        定义 是目录 = 条目[i][1] == 1

        如果 (find_检查匹配(名称, 子路径, 是目录, 配置)) {
            追加(find_结果缓冲, 子路径)
            find_结果数 = find_结果数 + 1
        }
        如果 (是目录) {
            find_收集递归(子路径, 配置, 深度 + 1, 最大深度)
        }
        i = i + 1
    }
}

函数 find_获取结果(索引) {
    如果 (索引 < 0 || 索引 >= find_结果数) { 返回 "" }
    返回 find_结果缓冲[索引]
}

函数 find_获取结果数() { 返回 find_结果数 }

// §10 重置与存取器

函数 find_重置统计() {
    find统计_初始化()
    全局_find统计.扫描文件数 = 0
    全局_find统计.扫描目录数 = 0
    全局_find统计.匹配数 = 0
    全局_find统计.跳过数 = 0
    全局_find统计.执行命令数 = 0
    全局_find统计.删除数 = 0
    全局_find统计.最大深度达到 = 0
    全局_grep匹配数 = 0
}

函数 find_获取扫描文件数() { 返回 全局_find统计.扫描文件数 }
函数 find_获取扫描目录数() { 返回 全局_find统计.扫描目录数 }
函数 find_获取匹配数() { 返回 全局_find统计.匹配数 }
函数 find_获取跳过数() { 返回 全局_find统计.跳过数 }
函数 find_获取执行数() { 返回 全局_find统计.执行命令数 }
函数 find_获取删除数() { 返回 全局_find统计.删除数 }
函数 find_获取grep数() { 返回 全局_grep匹配数 }

函数 find_完整统计() {
    find统计_初始化()
    返回 [
        ["扫描文件", 全局_find统计.扫描文件数],
        ["扫描目录", 全局_find统计.扫描目录数],
        ["匹配数", 全局_find统计.匹配数],
        ["跳过数", 全局_find统计.跳过数],
        ["执行命令", 全局_find统计.执行命令数],
        ["删除数", 全局_find统计.删除数],
        ["grep匹配", 全局_grep匹配数],
        ["收集结果", find_结果数]
    ]
}

函数 find_健康检查() {
    find统计_初始化()
    定义 可变 问题 = 0
    // 检查删除数不超过匹配数
    如果 (全局_find统计.删除数 > 全局_find统计.匹配数) { 问题 = 问题 + 1 }
    // 检查结果缓冲不溢出
    如果 (find_结果数 > find_最大结果) { 问题 = 问题 + 1 }
    返回 问题 == 0
}

// ◆ FST 理论 — File Search Theory
//   公理1: 文件搜索是目录树上的条件过滤遍历
//   公理2: 通配符匹配是有限自动机的状态转移
//   公理3: 内容搜索(grep)将搜索域从元数据扩展到数据
//   定理: 深度限制保证遍历复杂度 O(B^d) 有界
//         其中B=平均分支因子, d=maxdepth

定义 可变 AI_查找_热文件表 = []

函数 AI_查找_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_查找_热文件表)) {
        如果 (AI_查找_热文件表[i].路径 == 路径) {
            AI_查找_热文件表[i].频率 = AI_查找_热文件表[i].频率 + 1
            返回 AI_查找_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_查找_热文件表) < 128) {
        追加(AI_查找_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_查找_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

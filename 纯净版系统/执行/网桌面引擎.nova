导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./生成窗口元.nova")
导入("./窗口管理每.nova")
导入("./页面访问智.nova")
导入("./原生原生桌.nova")

定义 可变 Web桌面_已初始化 = 假
定义 可变 Web桌面_宽 = 1280
定义 可变 Web桌面_高 = 800
定义 Web桌面_图标宽 = 92
定义 Web桌面_图标高 = 108
定义 Web桌面_任务栏底部留白 = 18
定义 Web桌面_任务栏高度 = 64
定义 Web桌面_任务栏左边距 = 32
定义 Web桌面_启动器宽 = 118
定义 Web桌面_任务栏应用起点X = 160
定义 Web桌面_任务栏应用步长 = 62

函数 Web桌面_初始化(宽, 高) {
    Web桌面_宽 = 宽
    Web桌面_高 = 高
    如果 (Web桌面_已初始化) {
        返回 桌面_已初始化
    }
    Nova原生桌面_初始化(宽, 高)
    Web桌面_已初始化 = 桌面_已初始化
    返回 Web桌面_已初始化
}

函数 Web桌面_确保已初始化() {
    如果 (!Web桌面_已初始化) {
        Web桌面_初始化(Web桌面_宽, Web桌面_高)
    }
}

函数 Web桌面_渲染帧() {
    Web桌面_确保已初始化()
    Nova原生桌面_渲染帧()
}

函数 Web桌面_打开窗口(标题, url, x, y, 宽, 高) {
    Web桌面_确保已初始化()
    返回 Nova原生桌面_打开窗口(标题, url, x, y, 宽, 高)
}

函数 Web桌面_打开或聚焦窗口(标题, url, x, y, 宽, 高) {
    Web桌面_确保已初始化()
    返回 Nova原生桌面_打开或聚焦窗口(标题, url, x, y, 宽, 高)
}

函数 Web桌面_加载外部平台(url, 标题) {
    Web桌面_确保已初始化()
    返回 Nova原生桌面_加载外部平台(url, 标题)
}

函数 Web桌面_获取主工作区窗口几何(序号) {
    Web桌面_确保已初始化()
    返回 Nova原生桌面_建议窗口几何(序号)
}

函数 Web桌面_命中图标索引(x, y) {
    Web桌面_确保已初始化()
    定义 可变 i = 0
    当 (i < 计数(桌面.桌面图标)) {
        定义 图标 = 桌面.桌面图标[i]
        如果 (x >= 图标[3] && x < 图标[3] + Web桌面_图标宽 &&
            y >= 图标[4] && y < 图标[4] + Web桌面_图标高) {
            返回 i
        }
        i = i + 1
    }
    返回 -1
}

函数 Web桌面_激活图标(图标索引) {
    Web桌面_确保已初始化()
    如果 (图标索引 < 0 || 图标索引 >= 计数(桌面.桌面图标)) {
        返回 假
    }
    Nova原生桌面_图标双击(图标索引)
    返回 真
}

函数 Web桌面_命中启动器(x, y) {
    Web桌面_确保已初始化()
    定义 任务栏顶部 = 桌面.屏幕高 - Web桌面_任务栏底部留白 - Web桌面_任务栏高度
    定义 任务栏底部 = 桌面.屏幕高 - Web桌面_任务栏底部留白
    如果 (y < 任务栏顶部 || y >= 任务栏底部) {
        返回 假
    }
    如果 (x < Web桌面_任务栏左边距 || x >= Web桌面_任务栏左边距 + Web桌面_启动器宽) {
        返回 假
    }
    返回 真
}

函数 Web桌面_激活启动器() {
    Web桌面_确保已初始化()
    定义 几何 = Web桌面_获取主工作区窗口几何(计数(桌面.窗口列表) + 1)
    返回 Nova原生桌面_打开或聚焦窗口("NovaOS 终端", "nova://终端", 几何[0], 几何[1], 几何[2], 几何[3])
}

函数 Web桌面_命中任务栏窗口(x, y) {
    Web桌面_确保已初始化()
    定义 任务栏顶部 = 桌面.屏幕高 - Web桌面_任务栏底部留白 - Web桌面_任务栏高度
    定义 任务栏底部 = 桌面.屏幕高 - Web桌面_任务栏底部留白
    如果 (y < 任务栏顶部 || y >= 任务栏底部) {
        返回 0
    }
    如果 (x < Web桌面_任务栏应用起点X) {
        返回 0
    }
    定义 索引 = (x - Web桌面_任务栏应用起点X) / Web桌面_任务栏应用步长
    如果 (索引 >= 0 && 索引 < 计数(桌面.窗口列表)) {
        返回 桌面.窗口列表[索引].ID
    }
    返回 0
}

函数 Web桌面_激活任务栏窗口(窗口ID) {
    Web桌面_确保已初始化()
    如果 (窗口ID <= 0) {
        返回 假
    }
    Nova原生桌面_任务栏点击(窗口ID)
    返回 真
}

函数 Web桌面_设置壳输入缓冲(输入) {
    Web桌面_确保已初始化()
    Nova原生桌面_设置壳输入缓冲(输入)
}

函数 Web桌面_记录壳状态(输入, 动作, 结果) {
    Web桌面_确保已初始化()
    Nova原生桌面_记录壳状态(输入, 动作, 结果)
}

函数 Web桌面_同步系统状态(核心状态, 核心副文本,
                       视觉状态, 视觉副文本,
                       声音状态, 声音副文本,
                       形象状态, 形象副文本) {
    Web桌面_确保已初始化()
    Nova原生桌面_同步系统状态(核心状态, 核心副文本,
                      视觉状态, 视觉副文本,
                      声音状态, 声音副文本,
                      形象状态, 形象副文本)
}

函数 Web桌面_获取桌面状态() {
    Web桌面_确保已初始化()
    返回 桌面
}

函数 Web桌面_获取当前页面上下文() {
    Web桌面_确保已初始化()
    返回 Nova原生桌面_获取当前页面上下文()
}

函数 Web桌面_执行页面动作(动作, 参数1, 参数2) {
    Web桌面_确保已初始化()
    定义 结果 = Nova原生桌面_执行页面动作(动作, 参数1, 参数2)
    Nova原生桌面_记录壳状态(动作 + ":" + 参数1, 动作, 结果)
    Web桌面_渲染帧()
    返回 结果
}

函数 Web桌面_统计() {
    Web桌面_确保已初始化()
    返回 Nova原生桌面_统计()
}

定义 可变 AI_网桌面引擎_运行指标 = 0
定义 可变 AI_网桌面引擎_异常指标 = 0

函数 AI_网桌面引擎_自诊断() {
    AI_网桌面引擎_运行指标 = 0
    返回 AI_网桌面引擎_运行指标
}

函数 AI_网桌面引擎_优化建议() {
    定义 指标 = AI_网桌面引擎_自诊断()
    返回 "网桌面引擎状态正常"
}

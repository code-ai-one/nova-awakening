导入("../基础.nova")

// 数学基础库
// 目标: 以稳定原生语法提供常用整数数学、组合数学、随机与列表统计

函数 数学_绝对值(n) {
    如果 (n < 0) {
        返回 0 - n
    }
    返回 n
}

函数 数学_最小(a, b) {
    如果 (a < b) {
        返回 a
    }
    返回 b
}

函数 数学_最大(a, b) {
    如果 (a > b) {
        返回 a
    }
    返回 b
}

函数 数学_钳制(n, lo, hi) {
    返回 数学_最大(lo, 数学_最小(n, hi))
}

函数 数学_符号(n) {
    如果 (n > 0) {
        返回 1
    }
    如果 (n < 0) {
        返回 -1
    }
    返回 0
}

函数 数学_GCD(a, b) {
    定义 可变 x = 数学_绝对值(a)
    定义 可变 y = 数学_绝对值(b)
    当 (y != 0) {
        定义 t = y
        y = x % y
        x = t
    }
    返回 x
}

函数 数学_LCM(a, b) {
    如果 (a == 0) {
        返回 0
    }
    如果 (b == 0) {
        返回 0
    }
    返回 数学_绝对值(a) / 数学_GCD(a, b) * 数学_绝对值(b)
}

函数 数学_整除吗(a, b) {
    如果 (b == 0) {
        返回 假
    }
    返回 a % b == 0
}

函数 数学_幂(底, 指) {
    如果 (指 == 0) {
        返回 1
    }
    如果 (指 < 0) {
        返回 0
    }
    定义 可变 结果 = 1
    定义 可变 b = 底
    定义 可变 e = 指
    当 (e != 0) {
        如果 (e % 2 == 1) {
            结果 = 结果 * b
        }
        b = b * b
        e = e / 2
    }
    返回 结果
}

函数 数学_模幂(底, 指, 模) {
    如果 (模 == 1) {
        返回 0
    }
    定义 可变 结果 = 1
    定义 可变 b = 底 % 模
    定义 可变 e = 指
    当 (e != 0) {
        如果 (e % 2 == 1) {
            结果 = (结果 * b) % 模
        }
        b = (b * b) % 模
        e = e / 2
    }
    返回 结果
}

函数 数学_整数平方根(n) {
    如果 (n < 0) {
        返回 -1
    }
    如果 (n < 2) {
        返回 n
    }
    定义 可变 x = n / 2
    定义 可变 y = (x + n / x) / 2
    当 (y < x) {
        x = y
        y = (x + n / x) / 2
    }
    返回 x
}

函数 数学_log2(n) {
    如果 (n <= 0) {
        返回 -1
    }
    定义 可变 结果 = 0
    定义 可变 v = n
    当 (v > 1) {
        v = v / 2
        结果 = 结果 + 1
    }
    返回 结果
}

函数 数学_log10(n) {
    如果 (n <= 0) {
        返回 -1
    }
    定义 可变 结果 = 0
    定义 可变 v = n
    当 (v >= 10) {
        v = v / 10
        结果 = 结果 + 1
    }
    返回 结果
}

函数 数学_是2的幂(n) {
    如果 (n <= 0) {
        返回 假
    }
    定义 可变 v = n
    当 (v % 2 == 0) {
        v = v / 2
    }
    返回 v == 1
}

函数 数学_向上到2的幂(n) {
    如果 (n <= 1) {
        返回 1
    }
    定义 可变 v = 1
    当 (v < n) {
        v = v * 2
    }
    返回 v
}

函数 数学_popcount(n) {
    定义 可变 计数值 = 0
    定义 可变 v = n
    当 (v != 0) {
        计数值 = 计数值 + (v % 2)
        v = v / 2
    }
    返回 计数值
}

函数 数学_CLZ(n) {
    如果 (n == 0) {
        返回 64
    }
    定义 最高位序 = 数学_log2(n)
    返回 63 - 最高位序
}

函数 数学_CTZ(n) {
    如果 (n == 0) {
        返回 64
    }
    定义 可变 计数值 = 0
    定义 可变 v = n
    当 (v % 2 == 0) {
        计数值 = 计数值 + 1
        v = v / 2
    }
    返回 计数值
}

函数 数学_最高位(n) {
    如果 (n == 0) {
        返回 0
    }
    定义 可变 v = 1
    当 (v <= n / 2) {
        v = v * 2
    }
    返回 v
}

函数 数学_阶乘(n) {
    如果 (n <= 1) {
        返回 1
    }
    定义 可变 结果 = 1
    定义 可变 i = 2
    当 (i <= n) {
        结果 = 结果 * i
        i = i + 1
    }
    返回 结果
}

函数 数学_斐波那契(n) {
    如果 (n < 2) {
        返回 n
    }
    定义 可变 a = 0
    定义 可变 b = 1
    定义 可变 i = 2
    当 (i <= n) {
        定义 t = a + b
        a = b
        b = t
        i = i + 1
    }
    返回 b
}

函数 数学_组合(n, k) {
    如果 (k > n) {
        返回 0
    }
    如果 (k == 0) {
        返回 1
    }
    如果 (k == n) {
        返回 1
    }
    如果 (k > n - k) {
        返回 数学_组合(n, n - k)
    }
    定义 可变 结果 = 1
    定义 可变 i = 0
    当 (i < k) {
        结果 = 结果 * (n - i)
        结果 = 结果 / (i + 1)
        i = i + 1
    }
    返回 结果
}

函数 数学_排列(n, k) {
    如果 (k > n) {
        返回 0
    }
    定义 可变 结果 = 1
    定义 可变 i = 0
    当 (i < k) {
        结果 = 结果 * (n - i)
        i = i + 1
    }
    返回 结果
}

函数 数学_是素数(n) {
    如果 (n < 2) {
        返回 假
    }
    如果 (n < 4) {
        返回 真
    }
    如果 (n % 2 == 0) {
        返回 假
    }
    如果 (n % 3 == 0) {
        返回 假
    }
    定义 可变 i = 5
    当 (i * i <= n) {
        如果 (n % i == 0) {
            返回 假
        }
        如果 (n % (i + 2) == 0) {
            返回 假
        }
        i = i + 6
    }
    返回 真
}

函数 数学_下一个素数(n) {
    定义 可变 候选 = n + 1
    如果 (候选 <= 2) {
        返回 2
    }
    如果 (候选 % 2 == 0) {
        候选 = 候选 + 1
    }
    当 (数学_是素数(候选) == 假) {
        候选 = 候选 + 2
    }
    返回 候选
}

定义 可变 RNG_状态 = 12345678901234567

函数 随机_种子(种子) {
    如果 (种子 == 0) {
        RNG_状态 = 1
    } 否则 {
        RNG_状态 = 种子
    }
}

函数 随机_生成() {
    RNG_状态 = RNG_状态 * 1103515245 + 12345
    RNG_状态 = RNG_状态 % 2147483647
    如果 (RNG_状态 < 0) {
        RNG_状态 = 0 - RNG_状态
    }
    返回 RNG_状态
}

函数 数学_随机_范围(lo, hi) {
    定义 跨度 = hi - lo + 1
    返回 lo + 随机_生成() % 跨度
}

函数 数学_范围列表(起, _止) {
    定义 可变 结果 = []
    定义 可变 i = 起
    当 (i < _止) {
        追加(结果, i)
        i = i + 1
    }
    返回 结果
}

函数 数学_前缀和(列表) {
    定义 可变 结果 = []
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        和 = 和 + 列表[i]
        追加(结果, 和)
        i = i + 1
    }
    返回 结果
}

函数 数学_求和(列表) {
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        和 = 和 + 列表[i]
        i = i + 1
    }
    返回 和
}

函数 数学_求积(列表) {
    定义 可变 积 = 1
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        积 = 积 * 列表[i]
        i = i + 1
    }
    返回 积
}

函数 数学_对齐(值, 对齐值) {
    如果 (对齐值 <= 0) {
        返回 值
    }
    定义 上界 = 值 + 对齐值 - 1
    定义 块数 = 上界 / 对齐值
    返回 块数 * 对齐值
}

函数 数学_位旋转左(值, 位数, 宽度) {
    定义 掩码 = (1 << 宽度) - 1
    定义 左段 = 值 << 位数
    定义 右段 = 值 >> (宽度 - 位数)
    返回 (左段 | 右段) & 掩码
}

函数 数学_位旋转右(值, 位数, 宽度) {
    定义 掩码 = (1 << 宽度) - 1
    定义 左段 = 值 >> 位数
    定义 右段 = 值 << (宽度 - 位数)
    返回 (左段 | 右段) & 掩码
}

函数 数学_平均(列表) {
    如果 (计数(列表) == 0) {
        返回 0
    }
    返回 数学_求和(列表) / 计数(列表)
}

函数 数学_列表最小(列表) {
    如果 (计数(列表) == 0) {
        返回 0
    }
    定义 可变 m = 列表[0]
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        如果 (列表[i] < m) {
            m = 列表[i]
        }
        i = i + 1
    }
    返回 m
}

函数 数学_列表最大(列表) {
    如果 (计数(列表) == 0) {
        返回 0
    }
    定义 可变 m = 列表[0]
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        如果 (列表[i] > m) {
            m = 列表[i]
        }
        i = i + 1
    }
    返回 m
}

// ═══ 实验反哺: 数值积分（梯形/Simpson）
// 实验验证: Simpson精度比梯形高约1.5个数量级（误差~h^4 vs h^2）
// 应用: 汉字笔画弧长积分、信号能量计算、概率密度积分
函数 数学_数学_梯形积分(f值列表, 步长) {
    如果 (计数(f值列表) < 2) { 返回 0 }
    如果 (计数(f值列表) == 0) { 返回 空 }
    定义 可变 总和 = f值列表[0] + f值列表[计数(f值列表)-1]
    定义 可变 i = 1
    当 (i < 计数(f值列表) - 1) { 总和 = 总和 + 2 * f值列表[i]; i = i + 1 }
    返回 总和 * 步长 / 2
}

函数 数学_Simpson积分(f值列表, 步长) {
    定义 n = 计数(f值列表) - 1
    如果 (n < 2) { 返回 数学_数学_梯形积分(f值列表, 步长) }
    // 如果n为奇数，退化为梯形
    如果 (n % 2 != 0) { 返回 数学_数学_梯形积分(f值列表, 步长) }
    定义 可变 总和 = f值列表[0] + f值列表[n]
    定义 可变 i = 1
    当 (i < n) {
        如果 (i % 2 == 1) { 总和 = 总和 + 4 * f值列表[i] }
        否则 { 总和 = 总和 + 2 * f值列表[i] }
        i = i + 1
    }
    返回 总和 * 步长 / 3
}

// 中心差分数值微分: f'(x) ≈ [f(x+h)-f(x-h)] / 2h（×1000精度）
函数 数学_中心差分(f前, f后, h) {
    如果 (h == 0) { 返回 0 }
    返回 (f后 - f前) * 500 / h
}

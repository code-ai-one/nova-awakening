导入("../核心/FFI桥接.nova")
导入("../核心/设备管理.nova")
导入("../../../标准库/基础.nova")

//
// Nova  GPU  NVIDIA cuFFT 完整接入
// GPU快速傅里叶变换  信号处理/音频/图像频域操作核心 + CPU回退

//  FFT类型常量
定义 cuFFT_实转复 = 0x2A
定义 cuFFT_复转实 = 0x2C
定义 cuFFT_复转复 = 0x29
定义 cuFFT_双实转复 = 0x6A
定义 cuFFT_双复转实 = 0x6C
定义 cuFFT_双复转复 = 0x69
定义 cuFFT_正变换  = -1
定义 cuFFT_逆变换  = 1
定义 计算_快速傅里叶_圆周率 = 3141592653

定义 可变 _cuFFT库 = 0
定义 可变 _cufft_可用 = 假
定义 可变 _cufft_操作计数 = 0

//  库加载

函数 cuFFT_加载() {
    如果 (_cuFFT库 != 0) { 返回 _cuFFT库 }
    _cuFFT库 = GPU_加载CUDA候选([
        "cufft64_11.dll",
        "libcufft.so.11",
        "libcufft.so"
    ])
    如果 (_cuFFT库 != 0) { _cufft_可用 = 真 }
    返回 _cuFFT库
}

函数 cuFFT_可用() {
    返回 _cufft_可用
}

//  GPU FFT操作

函数 cuFFT_一维变换(输入, 输出, N, 类型, 方向) {
    _cufft_操作计数 = _cufft_操作计数 + 1
    定义 lib = cuFFT_加载()
    如果 (lib == 0) { 返回 cuCPU_快速傅里叶(输入, N, 方向) }
    定义 plan = 外部调用4(lib,  "cufftPlan1d",  0,  N,  类型,  1, 0)
    定义 结果 = 外部调用4(lib,  "cufftExecC2C",  plan,  输入,  输出,  方向, 0)
    外部调用(lib,  "cufftDestroy",  plan, 0, 0, 0, 0)
    返回 结果 == 0
}

函数 cuFFT_二维变换(输入, 输出, NX, NY, 类型, 方向) {
    _cufft_操作计数 = _cufft_操作计数 + 1
    定义 lib = cuFFT_加载()
    如果 (lib == 0) { 返回 假 }
    定义 plan = 外部调用5(lib, "cufftPlan2d", 0, NX, NY, 类型, 1)
    定义 结果 = 外部调用4(lib,  "cufftExecC2C",  plan,  输入,  输出,  方向, 0)
    外部调用(lib,  "cufftDestroy",  plan, 0, 0, 0, 0)
    返回 结果 == 0
}

函数 cuFFT_三维变换(输入, 输出, NX, NY, NZ, 类型, 方向) {
    _cufft_操作计数 = _cufft_操作计数 + 1
    定义 lib = cuFFT_加载()
    如果 (lib == 0) { 返回 假 }
    定义 plan = 外部调用6(lib,  "cufftPlan3d",  0,  NX,  NY,  NZ,  类型, 0, 0)
    定义 结果 = 外部调用4(lib,  "cufftExecC2C",  plan,  输入,  输出,  方向, 0)
    外部调用(lib,  "cufftDestroy",  plan, 0, 0, 0, 0)
    返回 结果 == 0
}

函数 cuFFT_批量(输入, 输出, N, 批量数, 类型, 方向) {
    _cufft_操作计数 = _cufft_操作计数 + 1
    定义 lib = cuFFT_加载()
    如果 (lib == 0) { 返回 假 }
    定义 plan = 外部调用4(lib,  "cufftPlan1d",  0,  N,  类型,  批量数, 0)
    定义 结果 = 外部调用4(lib,  "cufftExecC2C",  plan,  输入,  输出,  方向, 0)
    外部调用(lib,  "cufftDestroy",  plan, 0, 0, 0, 0)
    返回 结果 == 0
}

函数 cuFFT_实数到复数(实数输入, 复数输出, N) {
    _cufft_操作计数 = _cufft_操作计数 + 1
    定义 lib = cuFFT_加载()
    如果 (lib == 0) { 返回 假 }
    定义 plan = 外部调用4(lib,  "cufftPlan1d",  0,  N,  cuFFT_实转复,  1, 0)
    定义 结果 = 外部调用3(lib, "cufftExecR2C", plan, 实数输入, 复数输出)
    外部调用(lib,  "cufftDestroy",  plan, 0, 0, 0, 0)
    返回 结果 == 0
}

函数 cuFFT_复数到实数(复数输入, 实数输出, N) {
    _cufft_操作计数 = _cufft_操作计数 + 1
    定义 lib = cuFFT_加载()
    如果 (lib == 0) { 返回 假 }
    定义 plan = 外部调用4(lib,  "cufftPlan1d",  0,  N,  cuFFT_复转实,  1, 0)
    定义 结果 = 外部调用3(lib, "cufftExecC2R", plan, 复数输入, 实数输出)
    外部调用(lib,  "cufftDestroy",  plan, 0, 0, 0, 0)
    返回 结果 == 0
}

函数 cuFFT_设置流(plan, 流) {
    返回 外部调用2(cuFFT_加载(), "cufftSetStream", plan, 流) == 0
}

//  CPU回退: Cooley-Tukey基2 FFT

函数 cuCPU_快速傅里叶(数据, N, 方向) {
    定义 可变 偶数据 = 0
    定义 可变 奇数据 = 0
    如果 (N <= 1) { 返回 数据 }
    如果 (N % 2 != 0) { 返回 cuCPU_离散傅里叶(数据, N, 方向) }
    定义 可变 i = 0
    当 (i < N) {
        如果 (i % 2 == 0) {
            追加(偶数据, 数据[i * 2])
            追加(偶数据, 数据[i * 2 + 1])
        } 否则 {
            追加(奇数据, 数据[i * 2])
            追加(奇数据, 数据[i * 2 + 1])
        }
        i = i + 1
    }
    偶数据 = cuCPU_快速傅里叶(偶数据, N / 2, 方向)
    奇数据 = cuCPU_快速傅里叶(奇数据, N / 2, 方向)
    定义 可变 结果 = []
    i = 0
    当 (i < N * 2) {
        追加(结果, 0)
        i = i + 1
    }
    i = 0
    当 (i < N / 2) {
        定义 角度 = 方向 * 2 * 计算_快速傅里叶_圆周率 * i / (N * 1000000000)
        定义 cos_v = cuFFT_余弦变换(角度)
        定义 sin_v = cuFFT_正弦变换(角度)
定义 t实 = cos_v * 奇数据[i * 2] - sin_v * 奇数据[i * 2 + 1]
定义 t虚 = cos_v * 奇数据[i * 2 + 1] + sin_v * 奇数据[i * 2]
        结果[i * 2] = 偶数据[i * 2] + t实
        结果[i * 2 + 1] = 偶数据[i * 2 + 1] + t虚
        结果[(i + N / 2) * 2] = 偶数据[i * 2] - t实
        结果[(i + N / 2) * 2 + 1] = 偶数据[i * 2 + 1] - t虚
        i = i + 1
    }
    返回 结果
}

函数 cuCPU_离散傅里叶(数据, N, 方向) {
    定义 可变 结果 = []
    定义 可变 k = 0
    当 (k < N) {
        定义 可变 实 = 0
        定义 可变 虚 = 0
        定义 可变 n = 0
        当 (n < N) {
            定义 角度 = 方向 * 2 * 计算_快速傅里叶_圆周率 * k * n / (N * 1000000000)
            实 = 实 + 数据[n * 2] * cuFFT_余弦变换(角度) - 数据[n * 2 + 1] * cuFFT_正弦变换(角度)
            虚 = 虚 + 数据[n * 2] * cuFFT_正弦变换(角度) + 数据[n * 2 + 1] * cuFFT_余弦变换(角度)
            n = n + 1
        }
        追加(结果, 实)
        追加(结果, 虚)
        k = k + 1
    }
    返回 结果
}

函数 cuFFT_余弦变换(x) {
    当 (x > 计算_快速傅里叶_圆周率) { x = x - 2 * 计算_快速傅里叶_圆周率 }
    当 (x < 0 - 计算_快速傅里叶_圆周率) { x = x + 2 * 计算_快速傅里叶_圆周率 }
    定义 x2 = x * x / 1000000000 / 1000000000
    返回 1000000000 - x2 * 500000000 + x2 * x2 * 41666667 / 1000000000
}

函数 cuFFT_正弦变换(x) {
    当 (x > 计算_快速傅里叶_圆周率) { x = x - 2 * 计算_快速傅里叶_圆周率 }
    当 (x < 0 - 计算_快速傅里叶_圆周率) { x = x + 2 * 计算_快速傅里叶_圆周率 }
    定义 x2 = x * x / 1000000000 / 1000000000
    返回 x - x * x2 * 166666667 / 1000000000 + x * x2 * x2 * 8333333 / 1000000000 / 1000000000
}

//  窗函数

函数 cuFFT_窗_汉宁(N) {
    定义 可变 w = []
    定义 可变 i = 0
    当 (i < N) {
        定义 角度 = 2 * 计算_快速傅里叶_圆周率 * i / ((N - 1) * 1000000000)
        追加(w, 500000000 - 500000000 * cuFFT_余弦变换(角度) / 1000000000)
        i = i + 1
    }
    返回 w
}

函数 cuFFT_窗_汉明(N) {
    定义 可变 w = []
    定义 可变 i = 0
    当 (i < N) {
        定义 角度 = 2 * 计算_快速傅里叶_圆周率 * i / ((N - 1) * 1000000000)
        追加(w, 538000000 - 462000000 * cuFFT_余弦变换(角度) / 1000000000)
        i = i + 1
    }
    返回 w
}

函数 cuFFT_窗_Blackman(N) {
    定义 可变 w = []
    定义 可变 i = 0
    当 (i < N) {
        定义 a1 = 2 * 计算_快速傅里叶_圆周率 * i / ((N - 1) * 1000000000)
        定义 a2 = 4 * 计算_快速傅里叶_圆周率 * i / ((N - 1) * 1000000000)
        追加(w, 420000000 - 500000000 * cuFFT_余弦变换(a1) / 1000000000 + 80000000 * cuFFT_余弦变换(a2) / 1000000000)
        i = i + 1
    }
    返回 w
}

函数 cuFFT_应用窗(数据, 窗, N) {
    定义 可变 i = 0
    当 (i < N) {
        数据[i * 2] = 数据[i * 2] * 窗[i] / 1000000000
        数据[i * 2 + 1] = 数据[i * 2 + 1] * 窗[i] / 1000000000
        i = i + 1
    }
}

//  频谱操作

函数 cuFFT_幅度谱(fft数据, N) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < N) {
        定义 r = fft数据[i * 2]
        定义 im = fft数据[i * 2 + 1]
        追加(结果, r * r + im * im)
        i = i + 1
    }
    返回 结果
}

函数 cuFFT_功率谱(fft数据, N) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < N) {
        定义 r = fft数据[i * 2]
        定义 im = fft数据[i * 2 + 1]
        追加(结果, (r * r + im * im) / N)
        i = i + 1
    }
    返回 结果
}

函数 cuFFT_找峰值(幅度, N, 前K个) {
    定义 可变 峰值 = []
    定义 可变 i = 1
    当 (i < N / 2 - 1) {
        如果 (幅度[i] > 幅度[i - 1] 且 幅度[i] > 幅度[i + 1]) {
            追加(峰值, [i, 幅度[i]])
        }
        i = i + 1
    }
    定义 可变 k = 0
    当 (k < 计数(峰值) - 1) {
        定义 可变 j = k + 1
        当 (j < 计数(峰值)) {
            如果 (峰值[j][1] > 峰值[k][1]) {
                定义 临 = 峰值[k]
                峰值[k] = 峰值[j]
                峰值[j] = 临
            }
            j = j + 1
        }
        k = k + 1
    }
    如果 (计数(峰值) > 前K个) {
        定义 可变 截断 = []
        i = 0
        当 (i < 前K个) {
            追加(截断, 峰值[i])
            i = i + 1
        }
        返回 截断
    }
    返回 峰值
}

//  频域卷积

函数 cuFFT_频域卷积(信号, 核, N) {
    定义 可变 信号fft = cuCPU_快速傅里叶(信号, N, cuFFT_正变换)
    定义 可变 核fft = cuCPU_快速傅里叶(核, N, cuFFT_正变换)
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < N) {
        定义 ar = 信号fft[i * 2]
        定义 ai = 信号fft[i * 2 + 1]
        定义 br = 核fft[i * 2]
        定义 bi = 核fft[i * 2 + 1]
        追加(结果, ar * br - ai * bi)
        追加(结果, ar * bi + ai * br)
        i = i + 1
    }
    返回 cuCPU_快速傅里叶(结果, N, cuFFT_逆变换)
}

//  信号生成

函数 cuFFT_正弦(N, 频率, 采样率, 幅度) {
    定义 可变 数据 = []
    定义 可变 i = 0
    当 (i < N) {
        定义 角度 = 2 * 计算_快速傅里叶_圆周率 * 频率 * i / (采样率 * 1000000000)
        追加(数据, 幅度 * cuFFT_正弦变换(角度) / 1000000000)
        追加(数据, 0)
        i = i + 1
    }
    返回 数据
}

函数 cuFFT_余弦(N, 频率, 采样率, 幅度) {
    定义 可变 数据 = []
    定义 可变 i = 0
    当 (i < N) {
        定义 角度 = 2 * 计算_快速傅里叶_圆周率 * 频率 * i / (采样率 * 1000000000)
        追加(数据, 幅度 * cuFFT_余弦变换(角度) / 1000000000)
        追加(数据, 0)
        i = i + 1
    }
    返回 数据
}

//  滤波器

函数 cuFFT_低通(fft数据, N, 截止) {
    定义 可变 i = 截止
    当 (i < N - 截止) {
        fft数据[i * 2] = 0
        fft数据[i * 2 + 1] = 0
        i = i + 1
    }
}

函数 cuFFT_高通(fft数据, N, 截止) {
    定义 可变 i = 0
    当 (i < 截止) {
        fft数据[i * 2] = 0
        fft数据[i * 2 + 1] = 0
        i = i + 1
    }
    i = N - 截止
    当 (i < N) {
        fft数据[i * 2] = 0
        fft数据[i * 2 + 1] = 0
        i = i + 1
    }
}

函数 cuFFT_带通(fft数据, N, 低, 高) {
    定义 可变 i = 0
    当 (i < N) {
        定义 可变 需要清零 = 假
        如果 (i < 低) {
            需要清零 = 真
        }
        如果 (i > 高) {
            如果 (i < N - 高) {
                需要清零 = 真
            }
        }
        如果 (i >= N - 低) {
            需要清零 = 真
        }
        如果 (需要清零) {
            fft数据[i * 2] = 0
            fft数据[i * 2 + 1] = 0
        }
        i = i + 1
    }
}

//  信号统计

函数 cuFFT_信号能量(数据, N) {
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < N) {
        和 = 和 + 数据[i * 2] * 数据[i * 2]
        i = i + 1
    }
    返回 和
}

函数 cuFFT_信噪比(信号, 噪声, N) {
    定义 信号能 = cuFFT_信号能量(信号, N)
    定义 噪声能 = cuFFT_信号能量(噪声, N)
    如果 (噪声能 == 0) { 返回 999999 }
    返回 信号能 / 噪声能
}

//  2的幂工具

函数 cuFFT_下一个2幂(n) {
    定义 可变 p = 1
    当 (p < n) {
        p = p * 2
    }
    返回 p
}

函数 cuFFT_策略(N, 使用GPU) {
    定义 可变 是2幂 = 假
    定义 可变 策略 = "Cooley-Tukey基2"
    定义 可变 n = N
    当 (n > 1) {
        如果 (n % 2 != 0) {
            是2幂 = 假
        }
        n = n / 2
    }
    如果 (是2幂 == 假) {
        策略 = "Bluestein(任意长度)"
    }
    如果 (N <= 16) {
        策略 = "DFT直接计算"
    }
    如果 (使用GPU) {
        如果 (N < 256) { 返回 策略 + " [CPU: GPU开销大]" }
        如果 (N < 65536) { 返回 策略 + " [GPU: 中等加速]" }
        返回 策略 + " [GPU: 显著加速]"
    }
    返回 策略 + " [CPU]"
}

函数 cuFFT_频谱质量(幅度, N) {
    定义 峰值 = cuFFT_找峰值(幅度, N, 5)
    定义 可变 评分 = 100
    如果 (计数(峰值) == 0) { 返回 [30, "无明显频率成分"] }
    如果 (计数(峰值) > N / 4) { 评分 = 评分 - 30 }
    返回 [评分, "频谱正常,峰值数:" + 转字符串(计数(峰值))]
}

// 短时傅里叶变换 (STFT)

函数 cuFFT_短时傅里叶(信号, 信号长, 帧长, 帧移) {
    定义 可变 帧列表 = []
    定义 可变 位置 = 0
    当 (位置 + 帧长 <= 信号长) {
        定义 可变 帧 = []
        定义 可变 i = 0
        当 (i < 帧长) {
            追加(帧, 信号[(位置 + i) * 2])
            追加(帧, 信号[(位置 + i) * 2 + 1])
            i = i + 1
        }
        定义 窗 = cuFFT_窗_汉宁(帧长)
        cuFFT_应用窗(帧, 窗, 帧长)
        定义 fft结果 = cuCPU_快速傅里叶(帧, 帧长, cuFFT_正变换)
        追加(帧列表, fft结果)
        位置 = 位置 + 帧移
    }
    返回 帧列表
}

// 谱质心

函数 cuFFT_谱质心(幅度, N, 采样率) {
    定义 可变 加权和 = 0
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < N / 2) {
        如果 (N == 0) { 返回 }
 定义 频率 = i * 采样率 / N
        加权和 = 加权和 + 频率 * 幅度[i]
        总和 = 总和 + 幅度[i]
        i = i + 1
    }
    如果 (总和 == 0) { 返回 0 }
    返回 加权和 / 总和
}

// 谱带宽

函数 cuFFT_谱带宽(幅度, N, 采样率) {
    定义 质心 = cuFFT_谱质心(幅度, N, 采样率)
    定义 可变 加权和 = 0
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < N / 2) {
        定义 频率 = i * 采样率 / N
        定义 差 = 频率 - 质心
        加权和 = 加权和 + 差 * 差 * 幅度[i]
        总和 = 总和 + 幅度[i]
        i = i + 1
    }
    如果 (总和 == 0) { 返回 0 }
    返回 加权和 / 总和
}

// 谐波检测

函数 cuFFT_谐波检测(幅度, N, 基频索引, 谐波数) {
    定义 可变 谐波 = []
    定义 可变 h = 1
    当 (h <= 谐波数) {
        定义 索引 = 基频索引 * h
        如果 (索引 < N / 2) {
            追加(谐波, [h, 索引, 幅度[索引]])
        }
        h = h + 1
    }
    返回 谐波
}

// 谱平坦度

函数 cuFFT_谱平坦度(幅度, N) {
    定义 可变 算术和 = 0
    定义 可变 计 = 0
    定义 可变 i = 1
    当 (i < N / 2) {
        如果 (幅度[i] > 0) {
            算术和 = 算术和 + 幅度[i]
            计 = 计 + 1
        }
        i = i + 1
    }
    如果 (计 == 0) {
        返回 0
    }
    如果 (算术和 == 0) {
        返回 0
    }
    返回 1000000 / (算术和 / 计)
}

// 移动平均滤波

函数 cuFFT_移动平均(数据, N, 窗口) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < N) {
        定义 可变 和 = 0
        定义 可变 计 = 0
        定义 可变 j = i - 窗口 / 2
        当 (j <= i + 窗口 / 2) {
            如果 (j >= 0) {
                如果 (j < N) {
                    和 = 和 + 数据[j * 2]
                    计 = 计 + 1
                }
            }
            j = j + 1
        }
        追加(结果, 和 / 计)
        追加(结果, 0)
        i = i + 1
    }
    返回 结果
}

函数 cuFFT_信号分类(数据, N) {
    定义 幅度 = cuFFT_幅度谱(数据, N)
    定义 峰值 = cuFFT_找峰值(幅度, N, 10)
    如果 (计数(峰值) == 0) { 返回 "直流/静默信号" }
    如果 (计数(峰值) == 1) { 返回 "纯音信号" }
    如果 (计数(峰值) <= 3) { 返回 "简单谐波信号" }
    如果 (计数(峰值) <= 10) { 返回 "复杂谐波信号" }
    返回 "宽带/噪声信号"
}

函数 cuFFT_最优长度(最小长度) {
    定义 可变 最优 = cuFFT_下一个2幂(最小长度)
    如果 (最优 > 最小长度 * 3 / 2) {
        定义 可变 候选 = 最小长度
        当 (候选 % 2 == 0) {
            候选 = 候选 / 2
        }
        当 (候选 % 3 == 0) {
            候选 = 候选 / 3
        }
        当 (候选 % 5 == 0) {
            候选 = 候选 / 5
        }
    }
    返回 最优
}

// NovaOS 负载均衡 (Load Balancing)
// 功能: 在多CPU间均衡负载
//   - 周期性均衡: 每个tick检查是否需要均衡
//   - 空闲均衡: CPU空闲时主动拉取任务
//   - 新建均衡: fork时选择最轻负载的CPU
//   - 唤醒均衡: 唤醒时选择最优CPU
//   - 迁移成本: 考虑缓存亲和性
// 策略:
//   - 负载差 > 阈值时触发均衡
//   - 优先迁移负载大的任务
//   - 避免乒乓效应 (ping-pong)
//   - 尊重CPU亲和性

// 负载均衡常量

导入("./类型定义.nova")
导入("./同步原语.nova")
导入("../执行/内核智能.nova")
导入("./整数转字符串.nova")
导入("./内核打印.nova")

定义 LB_不均衡阈值 = 25          // 负载差25%触发均衡
定义 LB_最小迁移间隔 = 5000      // 5ms内不重复迁移同一任务
定义 LB_缓存衰减时间 = 500000    // 500ms缓存亲和性衰减
定义 LB_最大迁移次数 = 32        // 单次均衡最多迁移32个任务
定义 LB_最大迭代次数 = 3         // 最多迭代3次

// 全局状态

定义 可变 LB_CPU数量 = 1
定义 可变 LB_CPU负载表 = []      // 每个CPU的负载
定义 可变 LB_CPU运行队列 = []    // 每个CPU的运行队列
定义 可变 LB_均衡次数 = 0
定义 可变 LB_迁移次数 = 0
定义 可变 LB_失败次数 = 0

// 初始化

函数 LB_初始化(cpu数量) {
    LB_CPU数量 = cpu数量
    LB_CPU负载表 = []
    LB_CPU运行队列 = []
    
    定义 可变 i = 0
    当 (i < cpu数量) {
        追加(LB_CPU负载表, 0)
        追加(LB_CPU运行队列, [])
        i = i + 1
    }
    
    LB_均衡次数 = 0
    LB_迁移次数 = 0
    LB_失败次数 = 0
}

// 更新CPU负载 (从Nova负载追踪获取)

函数 LB_更新CPU负载(cpu_id, 负载) {
    如果 (cpu_id < 0 || cpu_id >= LB_CPU数量) { 返回 }
    LB_CPU负载表[cpu_id] = 负载
}

函数 LB_获取CPU负载(cpu_id) {
    如果 (cpu_id < 0 || cpu_id >= LB_CPU数量) { 返回 0 }
    返回 LB_CPU负载表[cpu_id]
}

// 查找最忙和最闲的CPU

函数 LB_查找最忙CPU() {
    定义 可变 最忙id = 0
    定义 可变 最大负载 = LB_CPU负载表[0]
    
    定义 可变 i = 1
    当 (i < LB_CPU数量) {
        定义 负载 = LB_CPU负载表[i]
        如果 (负载 > 最大负载) {
            最大负载 = 负载
            最忙id = i
        }
        i = i + 1
    }
    
    返回 [最忙id, 最大负载]
}

函数 LB_查找最闲CPU() {
    定义 可变 最闲id = 0
    定义 可变 最小负载 = LB_CPU负载表[0]
    
    定义 可变 i = 1
    当 (i < LB_CPU数量) {
        定义 负载 = LB_CPU负载表[i]
        如果 (负载 < 最小负载) {
            最小负载 = 负载
            最闲id = i
        }
        i = i + 1
    }
    
    返回 [最闲id, 最小负载]
}

// 计算负载不均衡度

函数 LB_计算不均衡度() {
    定义 最忙 = LB_查找最忙CPU()
    定义 最闲 = LB_查找最闲CPU()
    
    定义 最大负载 = 最忙[1]
    定义 最小负载 = 最闲[1]
    
    如果 (最小负载 == 0) { 返回 100 }  // 完全不均衡
    
    // 不均衡度 = (最大 - 最小) / 最小 * 100
    定义 差值 = 最大负载 - 最小负载
    返回 差值 * 100 / 最小负载
}

// 检查是否需要均衡

函数 LB_需要均衡() {
    如果 (LB_CPU数量 <= 1) { 返回 假 }  // 单CPU无需均衡
    
    定义 不均衡度 = LB_计算不均衡度()
    返回 不均衡度 > LB_不均衡阈值
}

// 选择要迁移的任务

函数 LB_选择迁移任务(源cpu_id, 目标cpu_id, 需要迁移负载) {
    定义 源队列 = LB_CPU运行队列[源cpu_id]
    如果 (计数(源队列) == 0) { 返回 空 }
    
    // 选择负载最大且可迁移的任务
    定义 可变 最佳任务 = 空
    定义 可变 最大负载 = 0
    
    定义 可变 i = 0
    当 (i < 计数(源队列)) {
        定义 任务 = 源队列[i]
        
        // 检查是否可迁移
        如果 (!LB_可以迁移(任务, 源cpu_id, 目标cpu_id)) {
            i = i + 1
            继续
        }
        
        // 获取任务负载
        定义 任务负载 = 任务[T_load_avg]
        如果 (任务负载 > 最大负载) {
            最大负载 = 任务负载
            最佳任务 = 任务
        }
        
        i = i + 1
    }
    
    返回 最佳任务
}

// 检查任务是否可以迁移

函数 LB_可以迁移(任务, 源cpu, 目标cpu) {
    // 检查CPU亲和性
    定义 亲和性掩码 = 任务[T_cpu亲和性]
    如果 (亲和性掩码 != 0) {
        // 检查目标CPU是否在亲和性掩码中
        定义 目标位 = 1 << 目标cpu
        如果 ((亲和性掩码 & 目标位) == 0) {
            返回 假  // 不允许迁移到目标CPU
        }
    }
    
    // 检查是否正在运行
    如果 (任务[T_状态] == 进程_运行) {
        返回 假  // 不迁移正在运行的任务
    }
    
    // 检查最近是否被迁移过
    定义 上次迁移时间 = 任务[T_上次迁移时间]
    定义 当前时间 = 获取当前时间()
    如果 (当前时间 - 上次迁移时间 < LB_最小迁移间隔) {
        返回 假  // 避免频繁迁移
    }
    
    // 检查是否被固定
    如果 (任务[T_是否固定]) {
        返回 假
    }
    
    返回 真
}

// 执行任务迁移

函数 LB_迁移任务(任务, 源cpu, 目标cpu) {
    // 从源CPU移除
    定义 源队列 = LB_CPU运行队列[源cpu]
    定义 可变 i = 0
    定义 可变 找到 = 假
    当 (i < 计数(源队列)) {
        如果 (源队列[i] == 任务) {
            // 移除任务
            定义 新队列 = []
            定义 可变 j = 0
            当 (j < 计数(源队列)) {
                如果 (j != i) {
                    追加(新队列, 源队列[j])
                }
                j = j + 1
            }
            LB_CPU运行队列[源cpu] = 新队列
            找到 = 真
            中断
        }
        i = i + 1
    }
    
    如果 (!找到) { 返回 假 }
    
    // 添加到目标CPU
    定义 目标队列 = LB_CPU运行队列[目标cpu]
    追加(目标队列, 任务)
    
    // 更新任务状态
    设置(任务, T_cpu, 目标cpu)
    设置(任务, T_上次迁移时间, 获取当前时间())
    
    // 更新负载
    定义 任务负载 = 任务[T_load_avg]
    LB_CPU负载表[源cpu] = LB_CPU负载表[源cpu] - 任务负载
    LB_CPU负载表[目标cpu] = LB_CPU负载表[目标cpu] + 任务负载
    
    // 统计
    LB_迁移次数 = LB_迁移次数 + 1
    
    返回 真
}

// 执行负载均衡 

函数 LB_执行均衡() {
    如果 (!LB_需要均衡()) { 返回 0 }
    
    LB_均衡次数 = LB_均衡次数 + 1
    
    定义 最忙 = LB_查找最忙CPU()
    定义 最闲 = LB_查找最闲CPU()
    
    定义 源cpu = 最忙[0]
    定义 目标cpu = 最闲[0]
    定义 源负载 = 最忙[1]
    定义 目标负载 = 最闲[1]
    
    // 计算需要迁移的负载
    定义 负载差 = 源负载 - 目标负载
    定义 需要迁移 = 负载差 / 2  // 迁移一半差值
    
    // 迁移任务
    定义 可变 已迁移 = 0
    定义 可变 已迁移负载 = 0
    定义 可变 迭代 = 0
    
    当 (迭代 < LB_最大迭代次数 && 已迁移 < LB_最大迁移次数) {
        // 选择任务
        定义 任务 = LB_选择迁移任务(源cpu, 目标cpu, 需要迁移 - 已迁移负载)
        如果 (任务 == 空) { 中断 }
        
        // 迁移任务
        定义 成功 = LB_迁移任务(任务, 源cpu, 目标cpu)
        如果 (成功) {
            已迁移 = 已迁移 + 1
            已迁移负载 = 已迁移负载 + 任务[T_load_avg]
            
            // 检查是否达到目标
            如果 (已迁移负载 >= 需要迁移) { 中断 }
        } 否则 {
            LB_失败次数 = LB_失败次数 + 1
        }
        
        迭代 = 迭代 + 1
    }
    
    返回 已迁移
}

// 空闲均衡: CPU空闲时主动拉取任务

函数 LB_空闲均衡(当前cpu) {
    如果 (LB_CPU数量 <= 1) { 返回 0 }
    
    // 查找最忙的CPU
    定义 最忙 = LB_查找最忙CPU()
    定义 源cpu = 最忙[0]
    定义 源负载 = 最忙[1]
    
    // 如果最忙CPU也很闲，不需要均衡
    如果 (源负载 < 100) { 返回 0 }
    
    // 尝试拉取一个任务
    定义 任务 = LB_选择迁移任务(源cpu, 当前cpu, 源负载 / 2)
    如果 (任务 == 空) { 返回 0 }
    
    定义 成功 = LB_迁移任务(任务, 源cpu, 当前cpu)
    返回 成功 ? 1 : 0
}

// 选择最优CPU (用于fork和唤醒)

函数 LB_选择最优CPU(任务) {
    如果 (LB_CPU数量 <= 1) { 返回 0 }
    
    // 检查CPU亲和性
    定义 亲和性 = 任务[T_cpu亲和性]
    
    // 查找负载最轻且允许的CPU
    定义 可变 最优cpu = 0
    定义 可变 最小负载 = LB_CPU负载表[0]
    定义 可变 找到 = (亲和性 == 0 || (亲和性 & 1) != 0)
    
    定义 可变 i = 1
    当 (i < LB_CPU数量) {
        // 检查亲和性
        如果 (亲和性 != 0) {
            定义 位 = 1 << i
            如果 ((亲和性 & 位) == 0) {
                i = i + 1
                继续
            }
        }
        
        定义 负载 = LB_CPU负载表[i]
        如果 (!找到 || 负载 < 最小负载) {
            最小负载 = 负载
            最优cpu = i
            找到 = 真
        }
        
        i = i + 1
    }
    
    返回 最优cpu
}

// 统计信息

函数 LB_统计() {
    返回 [
        LB_均衡次数,
        LB_迁移次数,
        LB_失败次数,
        LB_计算不均衡度(),
        LB_需要均衡()
    ]
}

函数 LB_重置统计() {
    LB_均衡次数 = 0
    LB_迁移次数 = 0
    LB_失败次数 = 0
}

// 辅助函数

函数 获取当前时间() {
    定义 低 = 0
    定义 高 = 0
    汇编 { "rdtsc" "mov [rsp-16], eax" "mov [rsp-8], edx" }
    返回 低 + 高 * 0x100000000
}

// NLBT — Nova Load Balancing Theory
// 公理1(负载守恒): 迁移不创建/消灭负载, 只在CPU间转移
// 公理2(亲和性尊重): 只在允许的CPU集合内迁移
// 公理3(半衡策略): 每次迁移负载差的一半, 避免振荡
// 定理1(不均衡度收敛): 多次均衡后不均衡度单调递减
// 定理2(空闲拉取有效): 空闲CPU主动拉取任务减少空转时间

函数 LB_打印统计() {
    定义 s = LB_统计()
    打印行("=== 负载均衡统计 ===")
    打印行("均衡次数: " + 整数转字符串(s[0]))
    打印行("迁移次数: " + 整数转字符串(s[1]))
    打印行("失败次数: " + 整数转字符串(s[2]))
    打印行("不均衡度: " + 整数转字符串(s[3]))
    打印行("需均衡: " + (s[4] ? "是" : "否"))
    打印行("CPU数: " + 整数转字符串(LB_CPU数量))
}

函数 LB_打印CPU负载() {
    打印行("=== CPU负载分布 ===")
    定义 可变 i = 0
    当 (i < LB_CPU数量) {
        打印行("  CPU" + 整数转字符串(i) + ": " + 整数转字符串(LB_CPU负载表[i]))
        i = i + 1
    }
}

定义 LB_历史大小 = 64
定义 可变 LB_历史 = []
定义 可变 LB_历史位置 = 0
结构 LB_历史条目 {
    时间戳,
    不均衡度,
    迁移数,
}

函数 LB_记录历史(时间, 不均衡, 迁移) {
    定义 条目 = LB_历史条目 {}
    条目.时间戳 = 时间
    条目.不均衡度 = 不均衡
    条目.迁移数 = 迁移
    如果 (计数(LB_历史) < LB_历史大小) {
        追加(LB_历史, 条目)
    } 否则 {
        LB_历史[LB_历史位置] = 条目
    }
    LB_历史位置 = (LB_历史位置 + 1) % LB_历史大小
}

函数 LB_打印历史() {
    打印行("=== 均衡历史 ===")
    定义 可变 i = 0
    当 (i < 计数(LB_历史)) {
        定义 h = LB_历史[i]
        打印行("  t=" + 整数转字符串(h.时间戳)
            + " 偏差=" + 整数转字符串(h.不均衡度)
            + " 迁移=" + 整数转字符串(h.迁移数))
        i = i + 1
    }
}

函数 LB_执行并记录() {
    定义 前不均衡 = LB_计算不均衡度()
    定义 迁移数 = LB_执行均衡()
    LB_记录历史(获取当前时间(), 前不均衡, 迁移数)
    返回 迁移数
}

定义 可变 LB_均衡总次数 = 0
定义 可变 LB_迁移总次数 = 0
定义 可变 LB_失败总次数 = 0
定义 可变 LB_空闲拉取次数 = 0

函数 LB_空闲拉取(本地CPU) {
    定义 可变 最高负载 = 0
    定义 可变 最忙CPU = -1
    定义 可变 i = 0
    当 (i < LB_CPU数量) {
        如果 (i != 本地CPU && LB_CPU负载表[i] > 最高负载) {
            最高负载 = LB_CPU负载表[i]
            最忙CPU = i
        }
        i = i + 1
    }
    如果 (最忙CPU >= 0 && 最高负载 > 1) {
        LB_空闲拉取次数 = LB_空闲拉取次数 + 1
        返回 最忙CPU
    }
    返回 -1
}

定义 可变 AI_负载均衡生_负载窗口 = []

函数 AI_负载均衡生_负载预测(当前负载) {
    追加(AI_负载均衡生_负载窗口, 当前负载)
    如果 (计数(AI_负载均衡生_负载窗口) > 20) { 列表_移除(AI_负载均衡生_负载窗口, 0) }
    如果 (计数(AI_负载均衡生_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_负载均衡生_负载窗口)
    定义 趋势 = AI_负载均衡生_负载窗口[n-1] - AI_负载均衡生_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_负载均衡生_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

导入("./每核页释放.nova")

//   1. 每个进程/线程有独立的内核栈(系统调用/中断时使用)
//   2. x86_64: 默认16KB(4页, THREAD_SIZE)
//   3. 栈底放thread_info(或通过per-cpu current_task)
//   4. 栈溢出保护: guard page(VMAP_STACK)或canary
//   5. 中断栈: 独立的per-CPU中断栈(hardirq_stack)
//   6. Linux 4.9+: VMAP_STACK — 通过vmalloc分配, 带guard page

定义 THREAD_SIZE_ORDER = 2      // 2^2 = 4页
定义 THREAD_SIZE = 16384        // 16KB内核栈
定义 IRQ_STACK_SIZE = 16384     // 16KB中断栈
定义 STACK_CANARY = 0xDEADBEEFCAFEBABE  // 栈溢出检测魔数

定义 可变 栈_分配次数 = 0
定义 可变 栈_释放次数 = 0
定义 可变 栈_当前使用 = 0
定义 可变 栈_溢出检测数 = 0

定义 最大CPU数 = 8
定义 可变 中断栈表 = []    // 每个CPU一个中断栈基址

// 内核栈分配 

函数 分配内核栈() {
    // 方式1: 从伙伴系统分配连续物理页 (传统)
    定义 页号 = 伙伴系统_分配(THREAD_SIZE_ORDER)
    如果 (页号 < 0) {
        内核警告("内核栈分配失败!")
        返回 0
    }
    定义 栈基址 = 页号到地址(页号)

    // 清零栈空间(安全: 防止信息泄露)
    内存清零(栈基址, THREAD_SIZE)

    // 在栈底写入canary(溢出检测)
    内存写64(栈基址, STACK_CANARY)

    栈_分配次数 = 栈_分配次数 + 1
    栈_当前使用 = 栈_当前使用 + 1
    返回 栈基址
}

函数 分配内核栈_vmap() {
    // 方式2: VMAP_STACK — 通过vmalloc分配(带guard page)
    // 优点: 栈溢出会触发缺页异常而不是静默腐蚀
    定义 栈基址 = vmalloc(THREAD_SIZE)
    如果 (栈基址 == 0) {
        内核警告("VMAP内核栈分配失败!")
        返回 0
    }
    内存清零(栈基址, THREAD_SIZE)
    内存写64(栈基址, STACK_CANARY)
    栈_分配次数 = 栈_分配次数 + 1
    栈_当前使用 = 栈_当前使用 + 1
    返回 栈基址
}

// 释放内核栈

函数 释放内核栈(栈基址) {
    如果 (栈基址 == 0) { 返回 }
    // 检查canary
    检查栈canary(栈基址)
    定义 页号 = 地址到页号(栈基址)
    伙伴系统_释放(页号, THREAD_SIZE_ORDER)
    栈_释放次数 = 栈_释放次数 + 1
    栈_当前使用 = 栈_当前使用 - 1
}

// 栈溢出检测 

函数 检查栈canary(栈基址) {
    定义 值 = 内存读64(栈基址)
    如果 (值 != STACK_CANARY) {
        栈_溢出检测数 = 栈_溢出检测数 + 1
        内核打印(日志_错误, "栈溢出检测! canary被破坏 (期望=" +
                          hex64(STACK_CANARY) + " 实际=" + hex64(值) + ")")
    }
}

函数 检查当前栈深度() {
    // 检查当前RSP距栈底的距离
    定义 rsp = 读取RSP()
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 }
    定义 栈基址 = 进程_栈基址(当前)
    如果 (栈基址 == 0) { 返回 }
    定义 剩余 = rsp - 栈基址
    如果 (剩余 < 1024) {
        内核打印(日志_警告, "栈空间不足! 剩余=" + 整数转字符串(剩余) + "字节")
    }
}

// 中断栈 (per-CPU,

函数 中断栈_初始化() {
    中断栈表 = []
    定义 可变 i = 0
    当 (i < 最大CPU数) {
        定义 栈 = 伙伴系统_分配(THREAD_SIZE_ORDER)
        如果 (栈 >= 0) {
            定义 基址 = 页号到地址(栈)
            内存清零(基址, IRQ_STACK_SIZE)
            追加(中断栈表, 基址)
        } 否则 {
            追加(中断栈表, 0)
        }
        i = i + 1
    }
    内核信息("中断栈: " + 整数转字符串(最大CPU数) + "个CPU, 每个" +
             整数转字符串(IRQ_STACK_SIZE / 1024) + "KB")
}

函数 获取中断栈顶(CPU号) {
    如果 (CPU号 >= 计数(中断栈表)) { 返回 0 }
    定义 基址 = 中断栈表[CPU号]
    如果 (基址 == 0) { 返回 0 }
    返回 基址 + IRQ_STACK_SIZE
}

// 辅助

函数 栈顶地址(栈基址) {
    返回 栈基址 + THREAD_SIZE
}

函数 栈_使用量(栈基址) {
    // 从栈顶向下扫描非零区域, 估算使用量
    定义 可变 偏移 = THREAD_SIZE - 8
    当 (偏移 > 0) {
        如果 (内存读64(栈基址 + 偏移) != 0) {
            返回 THREAD_SIZE - 偏移
        }
        偏移 = 偏移 - 8
    }
    返回 THREAD_SIZE
}

函数 栈_统计() {
    返回 [栈_分配次数, 栈_释放次数, 栈_当前使用, 栈_溢出检测数]
}

// 栈使用峰值追踪

定义 可变 栈_最大使用量 = 0

函数 栈_更新峰值(栈基址) {
    定义 使用 = 栈_使用量(栈基址)
    如果 (使用 > 栈_最大使用量) {
        栈_最大使用量 = 使用
    }
    // 使用率超过75%时警告
    如果 (使用 > THREAD_SIZE * 3 / 4) {
        内核打印(日志_警告, "栈使用率高: " + 整数转字符串(使用) + "/" +
                          整数转字符串(THREAD_SIZE) + " (" +
                          整数转字符串(使用 * 100 / THREAD_SIZE) + "%)")
    }
}

// 异常栈 (IST: Interrupt Stack Table)

定义 IST_DF  = 1   // Double Fault栈
定义 IST_NMI = 2   // NMI栈
定义 IST_MCE = 3   // Machine Check栈
定义 IST_数量 = 7

定义 可变 IST_栈表 = []   // [IST编号] → 栈顶地址

函数 IST_初始化() {
    IST_栈表 = []
    定义 可变 i = 0
    当 (i < IST_数量) {
        定义 页号 = 伙伴系统_分配(1)  // 8KB per IST stack
        如果 (页号 >= 0) {
            定义 基址 = 页号到地址(页号)
            内存清零(基址, 8192)
            追加(IST_栈表, 基址 + 8192)
        } 否则 {
            追加(IST_栈表, 0)
        }
        i = i + 1
    }
    内核信息("IST: " + 整数转字符串(IST_数量) + "个异常栈已分配")
}

函数 IST_获取栈顶(编号) {
    如果 (编号 >= 计数(IST_栈表)) { 返回 0 }
    返回 IST_栈表[编号]
}

函数 栈_完整统计() {
    返回 [栈_分配次数, 栈_释放次数, 栈_当前使用, 栈_溢出检测数, 栈_最大使用量]
}

// IST名称 + 栈使用率

函数 IST_名称(编号) {
    如果 (编号 == IST_DF) { 返回 "DoubleFault" }
    如果 (编号 == IST_NMI) { 返回 "NMI" }
    如果 (编号 == IST_MCE) { 返回 "MCE" }
    返回 "IST" + 整数转字符串(编号)
}

函数 栈_最大使用率() {
    如果 (THREAD_SIZE == 0) { 返回 0 }
    返回 栈_最大使用量 * 100 / THREAD_SIZE
}

定义 可变 AI_内核栈_风暴阈值 = 10000
定义 可变 AI_内核栈_预测IRQ = 0

函数 AI_内核栈_风暴检测(触发频率) {
    如果 (触发频率 > AI_内核栈_风暴阈值) {
        AI_内核栈_风暴阈值 = AI_内核栈_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_内核栈_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

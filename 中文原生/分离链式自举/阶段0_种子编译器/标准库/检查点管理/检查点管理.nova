导入("../基础.nova")


// 检查点存储
定义 可变 ckpt_版本列表 = []
定义 可变 ckpt_数据列表 = []
定义 可变 ckpt_步数列表 = []
定义 可变 ckpt_总数 = 0
定义 可变 ckpt_最大保留 = 5

函数 ckpt_设置最大(n) { ckpt_最大保留 = n }

函数 ckpt_保存(数据, 步数) {
 // 超出保留数时删除最旧
 如果 (ckpt_总数 >= ckpt_最大保留) { 定义 可变 新版 = []
 定义 可变 新数 = []
 定义 可变 新步 = []
 定义 可变 i = 1
 当 (i < ckpt_总数) {
 追加(新版, ckpt_版本列表[i])
 追加(新数, ckpt_数据列表[i])
 追加(新步, ckpt_步数列表[i])
 i = i + 1
 }
 ckpt_版本列表 = 新版
 ckpt_数据列表 = 新数
 ckpt_步数列表 = 新步
 ckpt_总数 = ckpt_总数 - 1
 }
 追加(ckpt_版本列表, ckpt_总数)
 追加(ckpt_数据列表, 数据)
 追加(ckpt_步数列表, 步数)
 ckpt_总数 = ckpt_总数 + 1
 返回 ckpt_总数 - 1
}

函数 ckpt_加载最新() {
    如果 (ckpt_总数 == 0) { 返回 []
}
 返回 ckpt_数据列表[ckpt_总数 - 1]
}

函数 ckpt_加载版本(ver) { 定义 可变 i = 0
 当 (i < ckpt_总数) { 如果 (ckpt_版本列表[i] == ver) { 返回 ckpt_数据列表[i] }
 i = i + 1
 }
 返回 []
}

函数 ckpt_最新步数() {
    如果 (ckpt_总数 == 0) { 返回 -1
}
 返回 ckpt_步数列表[ckpt_总数 - 1]
}

// 增量检查点
定义 可变 增量_基准 = []

函数 增量_设基准(数据) { 增量_基准 = 数据 }

函数 增量_计算差异(当前) { 定义 可变 差值 = []
 定义 可变 i = 0
 当 (i < 计数(当前)) { 如果 (i < 计数(增量_基准)) {
 追加(差值, 当前[i] - 增量_基准[i])
 } 否则 { 追加(差值, 当前[i]) }
 i = i + 1
 }
 返回 差值
}

函数 增量_应用差异(差值) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(差值)) { 如果 (i < 计数(增量_基准)) {
 追加(结果, 增量_基准[i] + 差值[i])
 } 否则 { 追加(结果, 差值[i]) }
 i = i + 1
 }
 返回 结果
}

// 自动保存策略
定义 可变 自动_间隔 = 100
定义 可变 自动_上次 = 0

函数 自动保存_设置(间隔步数) { 自动_间隔 = 间隔步数 }

函数 自动保存_检查(当前步) { 如果 (当前步 - 自动_上次 >= 自动_间隔) {
 自动_上次 = 当前步
 返回 真
 }
 返回 假
}

// 最佳模型追踪
定义 可变 最佳_指标 = -99999
定义 可变 最佳_数据 = []
定义 可变 最佳_步数 = -1

函数 最佳_更新(指标, 数据, 步数) { 如果 (指标 > 最佳_指标) {
 最佳_指标 = 指标
 最佳_数据 = 数据
 最佳_步数 = 步数
 返回 真
 }
 返回 假
}

// 有检查点
函数 ckpt_有数据() { 返回 ckpt_总数 > 0 }

// 早停 (Early Stopping)
定义 可变 早停_耐心 = 5
定义 可变 早停_最佳值 = -99999
定义 可变 早停_计数器 = 0
定义 可变 早停_最佳步 = -1
定义 可变 早停_最小提升 = 1

函数 检查点_早停_初始化(耐心, 最小提升) {
 早停_耐心 = 耐心
 早停_最小提升 = 最小提升
 早停_最佳值 = -99999
 早停_计数器 = 0
 早停_最佳步 = -1
}

函数 检查点_早停_检查(指标, 步数) { 如果 (指标 > 早停_最佳值 + 早停_最小提升) {
 早停_最佳值 = 指标
 早停_计数器 = 0
 早停_最佳步 = 步数
 返回 假 // 继续训练
 }
 早停_计数器 = 早停_计数器 + 1
 如果 (早停_计数器 >= 早停_耐心) { 返回 真 } // 应该停止
 返回 假
}

函数 早停_应停止() { 返回 早停_计数器 >= 早停_耐心 }

// 检查点清理
函数 ckpt_清空() {
 ckpt_版本列表 = []
 ckpt_数据列表 = []
 ckpt_步数列表 = []
 ckpt_总数 = 0
}

// 检查点报告
函数 ckpt_报告() {
 打印("╔═══ 检查点管理 ═══╗")
 打印("║ 总数: " + 转字符串(ckpt_总数) + " / 最大: " + 转字符串(ckpt_最大保留))
 定义 可变 i = 0
 当 (i < ckpt_总数) {
 打印("║ [v" + 转字符串(ckpt_版本列表[i]) + "] 步数=" + 转字符串(ckpt_步数列表[i]))
 i = i + 1
 }
 如果 (最佳_步数 >= 0) {
 打印("║ ★ 最佳: 步数=" + 转字符串(最佳_步数) + " 指标=" + 转字符串(最佳_指标))
 }
 如果 (早停_计数器 > 0) {
 打印("║ 早停: " + 转字符串(早停_计数器) + "/" + 转字符串(早停_耐心))
 }
 打印("╚══════════════════╝")
}

// 学习率调度 (与检查点联动)
定义 可变 lr_当前 = 100
定义 可变 lr_衰减因子 = 500 // 千分比
定义 可变 lr_无改善步 = 0
定义 可变 lr_耐心 = 3

函数 lr_初始化(初始lr, 衰减, 耐心) {
 lr_当前 = 初始lr
 lr_衰减因子 = 衰减
 lr_耐心 = 耐心
 lr_无改善步 = 0
}

函数 lr_更新(有改善) { 如果 (有改善) { lr_无改善步 = 0
 返回 lr_当前 }
 lr_无改善步 = lr_无改善步 + 1
 如果 (lr_无改善步 >= lr_耐心) {
 lr_当前 = lr_当前 * lr_衰减因子 / 1000
 如果 (lr_当前 < 1) { lr_当前 = 1 }
 lr_无改善步 = 0
 }
 返回 lr_当前
}

函数 lr_获取() { 返回 lr_当前 }

// 检查点历史管理
定义 可变 _检查点_列表 = []
定义 可变 _检查点_最大保留 = 5

函数 检查点管理_检查点_保存(轮次, 损失, 参数快照) {
    定义 可变 新列表 = []
 追加(_检查点_列表, [轮次, 损失, 参数快照])
如果 (计数(_检查点_列表) > _检查点_最大保留) {
 定义 可变 i = 1
 当 (i < 计数(_检查点_列表)) { 追加(新列表, _检查点_列表[i]) i = i + 1 }
 _检查点_列表 = 新列表
 }
}

函数 检查点_最佳() {
    如果 (计数(_检查点_列表) == 0) { 返回 空
}
 定义 可变 最佳idx = 0
 定义 可变 i = 1
 当 (i < 计数(_检查点_列表)) { 如果 (_检查点_列表[i][1] < _检查点_列表[最佳idx][1]) { 最佳idx = i }
 i = i + 1
 }
 返回 _检查点_列表[最佳idx]
}

函数 检查点_最新() {
    如果 (计数(_检查点_列表) == 0) { 返回 空
}
 返回 _检查点_列表[计数(_检查点_列表) - 1]
}

函数 检查点_数量() { 返回 计数(_检查点_列表) }
函数 检查点_清空() { _检查点_列表 = [] }
函数 检查点_设最大保留(n) { _检查点_最大保留 = n }

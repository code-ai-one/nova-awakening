// 感知脑区 · 薄接口
// 统一职责: phase 装载 + DOM/事件接口 + 页面会话感知绑定

导入("../中枢/阶段契约.nova")
导入("../中枢/会话桥一体.nova")
导入("./阶段装载.nova")
导入("./标记标记扩展.nova")
导入("./帧管线获取.nova")

定义 可变 感知_调用计数 = 0
定义 可变 感知_最近阶段 = ""
定义 可变 感知_最近总线消息 = 空

函数 感知接口_默认文档() {
    定义 会话 = 一体桥_默认页面会话()
    如果 (会话 != 空 && 会话.文档指针 != 0) { 返回 会话.文档指针 }
    返回 0
}

函数 感知接口_文档根(文档指针) {
    如果 (文档指针 == 0) { 返回 0 }
    如果 (文档指针.根节点 != 0) { 返回 文档指针.根节点 }
    返回 文档指针
}

函数 感知接口_查询元素(文档指针, 选择器) {
    定义 根节点 = 感知接口_文档根(文档指针)
    如果 (根节点 == 0) { 返回 0 }
    返回 元素_querySelector(根节点, 选择器)
}

函数 感知_阶段清单(阶段) {
    返回 感知阶段装载_清单(阶段)
}

函数 感知_加载阶段(阶段) {
    如果 (!阶段契约_有效(阶段)) { 返回 -1 }
    感知_最近阶段 = 阶段
    返回 感知阶段装载_登记(阶段)
}

函数 感知_初始化() {
    感知_加载阶段(阶段_boot)
    感知_加载阶段(阶段_浏览器外衣)
    事件循环_初始化()
    返回 0
}

函数 感知_tick() {
    返回 事件循环_推进一帧()
}

函数 感知_获取待处理数() {
    返回 事件循环_待处理数()
}

函数 感知_处理批量(数量) {
    事件循环_批量处理(数量)
}

函数 感知_监听事件(事件类型, 回调) {
    返回 事件_注册监听(事件类型, 回调)
}

函数 感知_移除监听(事件类型, 回调) {
    事件_移除监听(事件类型, 回调)
}

函数 感知_触发事件(事件类型, 数据) {
    事件_触发(事件类型, 数据)
}

函数 感知_创建页面会话(名称, 网址) {
    定义 系统会话ID = 一体桥_确保系统会话("纯净版系统", "感知接口")
    返回 一体桥_创建页面会话(系统会话ID, 名称, 网址)
}

函数 感知_绑定页面文档(页面会话ID, 文档指针) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 假 }
    返回 一体桥_绑定页面资源(页面会话ID, 会话.窗口ID, 会话.标签ID, 文档指针, 会话.脚本上下文, 会话.推理上下文)
}

函数 感知_查询元素(选择器) {
    返回 感知接口_查询元素(感知接口_默认文档(), 选择器)
}

函数 感知_查询元素_页面(页面会话ID, 选择器) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 0 }
    一体桥_记录动作(页面会话ID, "感知_查询元素")
    定义 结果 = 感知接口_查询元素(会话.文档指针, 选择器)
    一体桥_生成DOM快照(页面会话ID, 会话.文档指针, "", 0, 0)
    返回 结果
}

函数 感知_获取文本(元素) {
    返回 元素_innerText_get(元素)
}

函数 感知_获取文本_页面(页面会话ID, 元素) {
    一体桥_记录动作(页面会话ID, "感知_获取文本")
    返回 元素_innerText_get(元素)
}

函数 感知_设置文本(元素, 文本) {
    节点_textContent_set(元素, 文本)
}

函数 感知_设置文本_页面(页面会话ID, 元素, 文本) {
    一体桥_记录动作(页面会话ID, "感知_设置文本")
    节点_textContent_set(元素, 文本)
}

函数 感知_当前帧率() {
    返回 事件循环_统计().FPS
}

函数 感知_请求重绘() {
    Frame_标记需要绘制()
}

函数 感知_请求重绘_页面(页面会话ID) {
    一体桥_记录动作(页面会话ID, "感知_请求重绘")
    Frame_标记需要绘制()
}

函数 感知_安全入口(调用者, 操作码) {
    感知_调用计数 = 感知_调用计数 + 1
    如果 (调用者 < 0 || 调用者 > 8) { 返回 -1 }
    返回 0
}

函数 感知_处理总线消息(调用者, 操作码, 数据) {
    感知_最近总线消息 = {
        调用者: 调用者,
        操作码: 操作码,
        数据: 数据
    }
    如果 (操作码 == 0x100) {
        感知_请求重绘()
    }
    返回 0
}

函数 感知接口_统计() {
    返回 {
        模块: "感知接口",
        最近阶段: 感知_最近阶段,
        感知调用计数: 感知_调用计数,
        最近总线消息: 感知_最近总线消息
    }
}

// 每帧tick时，将已处理的DOM变化事件数量报告给SOC监控模块
函数 感知_tick_含SOC() {
    定义 前处理数 = 事件循环_待处理数()
    事件循环_推进一帧()
    定义 后处理数 = 事件循环_待处理数()
    定义 本帧处理 = 前处理数 - 后处理数
    如果 (本帧处理 > 0) {
        感知_记录雪崩(本帧处理)
    }
    返回 本帧处理
}

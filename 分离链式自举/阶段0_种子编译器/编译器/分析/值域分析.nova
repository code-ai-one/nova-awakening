// Nova · 编译器 · 值域分析 (Value Range Analysis)
// 在编译时推断整数变量的取值范围 [min, max]
// 应用：消除边界检查 / 溢出检测 / 条件分支优化

// 值域表示
// [最小值, 最大值, 是否精确]
// 特殊值：∞ 用极大整数表示，-∞ 用极小整数
定义 值域_正无穷 = 9223372036854775807   // i64::MAX
定义 值域_负无穷 = -9223372036854775807  // i64::MIN

函数 VR_全域()           { 返回 [值域_负无穷, 值域_正无穷, 假] }
函数 VR_空域()           { 返回 [1, 0, 真] }  // min > max 表示空集
函数 VR_常量(v)          { 返回 [v, v, 真] }
函数 VR_范围(lo, hi)     { 返回 [lo, hi, 真] }
函数 VR_非负()           { 返回 [0, 值域_正无穷, 假] }
函数 VR_正数()           { 返回 [1, 值域_正无穷, 假] }
函数 VR_负数()           { 返回 [值域_负无穷, -1, 假] }
函数 VR_字节()           { 返回 [0, 255, 真] }  // u8

函数 VR_最小(r) { 返回 r[0] }
函数 VR_最大(r) { 返回 r[1] }
函数 VR_精确(r) { 返回 r[2] }
函数 VR_为空(r) { 返回 r[0] > r[1] }
函数 VR_是常量(r) { 返回 r[0] == r[1] }
函数 VR_是非负(r) { 返回 r[0] >= 0 }
函数 VR_是正数(r) { 返回 r[0] > 0 }
函数 VR_是负数(r) { 返回 r[1] < 0 }

// 值域操作（精确算术）
函数 VR_加(a, b) {
    定义 lo = VR_最小(a) + VR_最小(b)
    定义 hi = VR_最大(a) + VR_最大(b)
    // 溢出检测（简化）
    如果 (lo > hi) { 返回 VR_全域() }
    返回 VR_范围(lo, hi)
}

函数 VR_减(a, b) {
    定义 lo = VR_最小(a) - VR_最大(b)
    定义 hi = VR_最大(a) - VR_最小(b)
    如果 (lo > hi) { 返回 VR_全域() }
    返回 VR_范围(lo, hi)
}

函数 VR_乘(a, b) {
    // 四个端点取最值
    定义 ll = VR_最小(a) * VR_最小(b)
    定义 lh = VR_最小(a) * VR_最大(b)
    定义 hl = VR_最大(a) * VR_最小(b)
    定义 hh = VR_最大(a) * VR_最大(b)
    定义 可变 lo = ll
    如果 (lh < lo) { lo = lh }
    如果 (hl < lo) { lo = hl }
    如果 (hh < lo) { lo = hh }
    定义 可变 hi = ll
    如果 (lh > hi) { hi = lh }
    如果 (hl > hi) { hi = hl }
    如果 (hh > hi) { hi = hh }
    返回 VR_范围(lo, hi)
}

函数 VR_除(a, b) {
    // 除零检查
    如果 (VR_最小(b) <= 0 且 VR_最大(b) >= 0) {
        返回 VR_全域()  // 可能除零：无法推断
    }
    定义 lo = VR_最小(a) / VR_最大(b)
    定义 hi = VR_最大(a) / VR_最小(b)
    返回 VR_范围(lo, hi)
}

函数 VR_取模(a, b) {
    如果 (VR_最小(b) <= 0) { 返回 VR_全域() }
    // 结果在 [0, max(b)-1] 之间
    返回 VR_范围(0, VR_最大(b) - 1)
}

函数 VR_左移(a, n) {
    如果 (VR_是常量(n) 且 VR_最小(n) >= 0 且 VR_最小(n) < 63) {
        返回 VR_范围(VR_最小(a) << VR_最小(n), VR_最大(a) << VR_最小(n))
    }
    返回 VR_全域()
}

函数 VR_右移(a, n) {
    如果 (VR_是常量(n) 且 VR_最小(n) >= 0 且 VR_最小(n) < 63) {
        返回 VR_范围(VR_最小(a) >> VR_最小(n), VR_最大(a) >> VR_最小(n))
    }
    返回 VR_非负()
}

// 值域合并/交集（用于控制流汇合）
函数 VR_合并(a, b) {
    // 并集：取最大范围（宽化操作）
    如果 (VR_为空(a)) { 返回 b }
    如果 (VR_为空(b)) { 返回 a }
    定义 可变 lo = VR_最小(b)
    如果 (VR_最小(a) < VR_最小(b)) { lo = VR_最小(a) }
    定义 可变 hi = VR_最大(b)
    如果 (VR_最大(a) > VR_最大(b)) { hi = VR_最大(a) }
    返回 VR_范围(lo, hi)
}

函数 VR_交集(a, b) {
    // 交集：取重叠范围
    定义 可变 lo = VR_最小(b)
    如果 (VR_最小(a) > VR_最小(b)) { lo = VR_最小(a) }
    定义 可变 hi = VR_最大(b)
    如果 (VR_最大(a) < VR_最大(b)) { hi = VR_最大(a) }
    如果 (lo > hi) { 返回 VR_空域() }
    返回 VR_范围(lo, hi)
}

// 宽化（防止不动点迭代不收敛）
函数 VR_宽化(旧, 新) {
    定义 可变 lo = VR_最小(旧)
    如果 (VR_最小(新) < VR_最小(旧)) { lo = 值域_负无穷 }
    定义 可变 hi = VR_最大(旧)
    如果 (VR_最大(新) > VR_最大(旧)) { hi = 值域_正无穷 }
    返回 VR_范围(lo, hi)
}

// 比较结果推断（用于条件分支）
// 给定条件 a op b，推断条件为真时 a 和 b 的值域
函数 VR_条件细化_小于(a_域, b_域) {
    // a < b → a_max = min(a_max, b_max-1), b_min = max(b_min, a_min+1)
    定义 可变 a_hi = VR_最大(b_域) - 1
    如果 (VR_最大(a_域) < VR_最大(b_域) - 1) { a_hi = VR_最大(a_域) }
    定义 可变 b_lo = VR_最小(a_域) + 1
    如果 (VR_最小(b_域) > VR_最小(a_域) + 1) { b_lo = VR_最小(b_域) }
    返回 [[VR_最小(a_域), a_hi, 真], [b_lo, VR_最大(b_域), 真]]
}

函数 VR_条件细化_等于(a_域, b_域) {
    定义 交 = VR_交集(a_域, b_域)
    返回 [交, 交]
}

函数 VR_条件细化_大于等于(a_域, b_域) {
    // a >= b
    定义 可变 a_lo = VR_最小(b_域)
    如果 (VR_最小(a_域) > VR_最小(b_域)) { a_lo = VR_最小(a_域) }
    定义 可变 b_hi = VR_最大(a_域)
    如果 (VR_最大(b_域) < VR_最大(a_域)) { b_hi = VR_最大(b_域) }
    返回 [[a_lo, VR_最大(a_域), 真], [VR_最小(b_域), b_hi, 真]]
}

// 边界检查消除
// 判断索引是否一定在 [0, 长度-1] 范围内
函数 VR_可消除边界检查(索引域, 长度域) {
    // 索引 >= 0 且 索引 <= 长度-1 时，边界检查必然通过
    如果 (VR_最小(索引域) < 0) { 返回 假 }
    如果 (VR_最大(索引域) >= VR_最小(长度域)) { 返回 假 }
    返回 真
}

// 溢出检测
函数 VR_可能加法溢出(a, b) {
    // a + b 是否可能溢出 i64
    如果 (VR_最大(a) > 0 且 VR_最大(b) > 值域_正无穷 - VR_最大(a)) { 返回 真 }
    如果 (VR_最小(a) < 0 且 VR_最小(b) < 值域_负无穷 - VR_最小(a)) { 返回 真 }
    返回 假
}

// 统计
定义 可变 _VR_推断变量数 = 0
定义 可变 _VR_消除边界检查数 = 0
定义 可变 _VR_优化分支数 = 0

函数 VR_记录推断() { _VR_推断变量数 = _VR_推断变量数 + 1 }
函数 VR_记录消除边界() { _VR_消除边界检查数 = _VR_消除边界检查数 + 1 }
函数 VR_记录优化分支() { _VR_优化分支数 = _VR_优化分支数 + 1 }
函数 VR_统计() {
    返回 [_VR_推断变量数, _VR_消除边界检查数, _VR_优化分支数]
}

函数 VR_格式化(r) {
    如果 (VR_为空(r)) { 返回 "∅" }
    如果 (VR_是常量(r)) { 返回 转字符串(VR_最小(r)) }
    如果 (VR_最小(r) == 值域_负无穷 且 VR_最大(r) == 值域_正无穷) { 返回 "(-∞,+∞)" }
    如果 (VR_最小(r) == 值域_负无穷) { 返回 "(-∞," + 转字符串(VR_最大(r)) + "]" }
    如果 (VR_最大(r) == 值域_正无穷) { 返回 "[" + 转字符串(VR_最小(r)) + ",+∞)" }
    返回 "[" + 转字符串(VR_最小(r)) + "," + 转字符串(VR_最大(r)) + "]"
}

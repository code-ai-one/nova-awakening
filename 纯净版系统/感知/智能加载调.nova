导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/时钟中枢.nova")
导入("../推理/智能总线资源.nova")
导入("../中枢/整数转字符串.nova")
导入("../标准/原生字符串.nova")

定义 优先级_最高 = 0
定义 优先级_高 = 1
定义 优先级_普通 = 2
定义 优先级_低 = 3
定义 优先级_最低 = 4

定义 AI资源_关键样式 = 1
定义 AI资源_关键字体 = 2
定义 AI资源_关键脚本 = 3
定义 AI资源_图片 = 4
定义 AI资源_媒体 = 5
定义 AI资源_预取 = 6
定义 AI资源_广告 = 7
定义 AI资源_跟踪 = 8
定义 AI资源_未知 = 0

定义 重试_最大次数 = 3
定义 重试_基础延迟 = 1000
定义 重试_最大延迟 = 30000

结构 AI加载统计 {
    总请求数,
    被延迟数,
    被拦截数,
    重试次数,
    预取命中数,
    带宽估算,
    最近调整时间,
    优先级分布,
}

结构 预加载提示 {
    url,
    类型,
    优先级,
    交叉源,
    创建时间,
}

定义 可变 AI加载全局统计 = 0
定义 可变 预加载队列 = []
定义 可变 带宽_采样列表 = []
定义 可变 带宽_估算值 = 0

函数 AI加载_初始化() {
    AI加载全局统计 = 堆_分配(AI加载统计)
    AI加载全局统计.总请求数 = 0
    AI加载全局统计.被延迟数 = 0
    AI加载全局统计.被拦截数 = 0
    AI加载全局统计.重试次数 = 0
    AI加载全局统计.预取命中数 = 0
    AI加载全局统计.带宽估算 = 0
    AI加载全局统计.最近调整时间 = 0
    AI加载全局统计.优先级分布 = [0, 0, 0, 0, 0]
    预加载队列 = []
    带宽_采样列表 = []
    带宽_估算值 = 0
}

函数 AI加载_调整优先级(请求, url) {
    如果 (请求 == 0) { 返回 }
    如果 (AI加载全局统计 != 0) {
        AI加载全局统计.总请求数 = AI加载全局统计.总请求数 + 1
    }

    定义 bus = 全局AI总线
    如果 (bus != 0 && url != 0) {
        定义 分数 = AI总线_资源优先级(bus, url)
        如果 (分数 > 800) {
            请求.优先级 = 优先级_最高
            AI加载_记录优先级(优先级_最高)
        } 否则 如果 (分数 > 500) {
            请求.优先级 = 优先级_高
            AI加载_记录优先级(优先级_高)
        } 否则 如果 (分数 > 300) {
            请求.优先级 = 优先级_普通
            AI加载_记录优先级(优先级_普通)
        } 否则 如果 (分数 > 150) {
            请求.优先级 = 优先级_低
            AI加载_记录优先级(优先级_低)
            如果 (AI加载全局统计 != 0) { AI加载全局统计.被延迟数 = AI加载全局统计.被延迟数 + 1 }
        } 否则 {
            请求.优先级 = 优先级_最低
            AI加载_记录优先级(优先级_最低)
            如果 (AI加载全局统计 != 0) { AI加载全局统计.被拦截数 = AI加载全局统计.被拦截数 + 1 }
        }

        如果 (带宽_估算值 > 0 && 带宽_估算值 < 100000) {
            如果 (请求.优先级 > 优先级_普通) {
                请求.优先级 = 优先级_最低
            }
        }
        返回
    }

    定义 语义类型 = AI加载_识别语义类型(url, 请求.资源类型)
    选择 (语义类型) {
        AI资源_关键样式: { 请求.优先级 = 优先级_最高 }
        AI资源_关键字体: { 请求.优先级 = 优先级_最高 }
        AI资源_关键脚本: { 请求.优先级 = 优先级_高 }
        AI资源_图片: { 请求.优先级 = 优先级_低 }
        AI资源_媒体: { 请求.优先级 = 优先级_低 }
        AI资源_预取: { 请求.优先级 = 优先级_最低 }
        AI资源_广告: { 请求.优先级 = 优先级_最低 }
        AI资源_跟踪: { 请求.优先级 = 优先级_最低 }
        默认: { 请求.优先级 = 优先级_普通 }
    }
    AI加载_记录优先级(请求.优先级)
}

函数 AI加载_记录优先级(优先级) {
    如果 (AI加载全局统计 == 0) { 返回 }
    如果 (优先级 >= 0 && 优先级 <= 4) {
        AI加载全局统计.优先级分布[优先级] = AI加载全局统计.优先级分布[优先级] + 1
    }
    AI加载全局统计.最近调整时间 = 读取毫秒()
}

函数 AI加载_识别语义类型(url, 资源类型) {
    如果 (url == 0) { 返回 AI资源_未知 }

    如果 (字符串包含(url, ".css")) { 返回 AI资源_关键样式 }
    如果 (字符串包含(url, ".woff") || 字符串包含(url, ".woff2") ||
        字符串包含(url, ".ttf") || 字符串包含(url, ".otf")) { 返回 AI资源_关键字体 }
    如果 (字符串包含(url, ".js") || 字符串包含(url, ".mjs")) { 返回 AI资源_关键脚本 }
    如果 (字符串包含(url, ".png") || 字符串包含(url, ".jpg") ||
        字符串包含(url, ".jpeg") || 字符串包含(url, ".webp") ||
        字符串包含(url, ".gif") || 字符串包含(url, ".svg") ||
        字符串包含(url, ".ico")) { 返回 AI资源_图片 }
    如果 (字符串包含(url, ".mp4") || 字符串包含(url, ".webm") ||
        字符串包含(url, ".mp3") || 字符串包含(url, ".ogg")) { 返回 AI资源_媒体 }

    如果 (字符串包含(url, "analytics") || 字符串包含(url, "tracker") ||
        字符串包含(url, "beacon") || 字符串包含(url, "pixel")) { 返回 AI资源_跟踪 }
    如果 (字符串包含(url, "ad.") || 字符串包含(url, "/ads/") ||
        字符串包含(url, "adserver") || 字符串包含(url, "doubleclick")) { 返回 AI资源_广告 }

    返回 AI资源_未知
}

函数 AI加载_智能重试(请求, 状态码) {
    如果 (请求 == 0) { 返回 假 }

    定义 bus = 全局AI总线
    如果 (bus != 0 && 请求.URL != 0) {
        定义 分数 = AI总线_资源优先级(bus, 请求.URL)
        如果 (分数 < 200) { 返回 假 }
    }

    如果 (请求.重试次数 >= 重试_最大次数) { 返回 假 }

    如果 (状态码 == 429) {
        请求.重试延迟 = AI加载_计算退避(请求.重试次数)
        请求.重试次数 = 请求.重试次数 + 1
        如果 (AI加载全局统计 != 0) { AI加载全局统计.重试次数 = AI加载全局统计.重试次数 + 1 }
        返回 真
    }
    如果 (状态码 >= 500 && 状态码 <= 503) {
        请求.重试延迟 = AI加载_计算退避(请求.重试次数)
        请求.重试次数 = 请求.重试次数 + 1
        如果 (AI加载全局统计 != 0) { AI加载全局统计.重试次数 = AI加载全局统计.重试次数 + 1 }
        返回 真
    }
    如果 (状态码 == 408) {
        请求.重试延迟 = AI加载_计算退避(请求.重试次数)
        请求.重试次数 = 请求.重试次数 + 1
        返回 真
    }
    如果 (状态码 == 404 || 状态码 == 403 || 状态码 == 401) { 返回 假 }
    返回 假
}

函数 AI加载_计算退避(重试次数) {
    定义 延迟 = 重试_基础延迟
    定义 可变 i = 0
    当 (i < 重试次数) {
        延迟 = 延迟 * 2
        i = i + 1
    }
    定义 抖动 = 读取毫秒() % (延迟 / 4 + 1)
    延迟 = 延迟 + 抖动
    如果 (延迟 > 重试_最大延迟) { 延迟 = 重试_最大延迟 }
    返回 延迟
}

函数 AI加载_添加预加载(url, 类型, 优先级) {
    如果 (url == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(预加载队列)) {
        如果 (字符串_相等(预加载队列[i].url, url)) { 返回 }
        i = i + 1
    }
    定义 提示 = 预加载提示 {}
    提示.url = url
    提示.类型 = 类型
    提示.优先级 = 优先级
    提示.交叉源 = AI加载_是跨源(url)
    提示.创建时间 = 读取毫秒()
    追加(预加载队列, 提示)
}

函数 AI加载_是跨源(url) {
    如果 (url == 0) { 返回 假 }
    如果 (字符串包含(url, "://")) {
        如果 (!字符串包含(url, 当前文档_源())) { 返回 真 }
    }
    返回 假
}

函数 AI加载_处理预加载队列() {
    定义 可变 i = 0
    当 (i < 计数(预加载队列)) {
        定义 提示 = 预加载队列[i]
        定义 现在 = 读取毫秒()
        如果 (现在 - 提示.创建时间 > 60000) {
            删除(预加载队列, i)
            继续
        }
        i = i + 1
    }
}

函数 AI加载_更新带宽(字节数, 耗时毫秒) {
    如果 (耗时毫秒 <= 0) { 返回 }
    定义 速率 = 字节数 * 1000 / 耗时毫秒
    追加(带宽_采样列表, 速率)
    如果 (计数(带宽_采样列表) > 20) {
        带宽_采样列表 = 切片(带宽_采样列表, 计数(带宽_采样列表) - 20)
    }

    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < 计数(带宽_采样列表)) {
        总和 = 总和 + 带宽_采样列表[i]
        i = i + 1
    }
    带宽_估算值 = 总和 / 计数(带宽_采样列表)
    如果 (AI加载全局统计 != 0) { AI加载全局统计.带宽估算 = 带宽_估算值 }
}

函数 AI加载_连接优先级(url) {
    定义 语义 = AI加载_识别语义类型(url, 0)
    如果 (语义 == AI资源_关键样式 || 语义 == AI资源_关键脚本) { 返回 优先级_最高 }
    如果 (语义 == AI资源_关键字体) { 返回 优先级_高 }
    如果 (语义 == AI资源_图片) { 返回 优先级_普通 }
    如果 (语义 == AI资源_广告 || 语义 == AI资源_跟踪) { 返回 优先级_最低 }
    返回 优先级_普通
}

函数 AI加载_统计() {
    如果 (AI加载全局统计 == 0) { 返回 0 }
    返回 {
        总请求: AI加载全局统计.总请求数,
        被延迟: AI加载全局统计.被延迟数,
        被拦截: AI加载全局统计.被拦截数,
        重试: AI加载全局统计.重试次数,
        预取命中: AI加载全局统计.预取命中数,
        带宽: 带宽_估算值,
        预加载队列: 计数(预加载队列),
        优先级分布: AI加载全局统计.优先级分布
    }
}

// 智能加载健康检查

函数 智能加载_健康检查() {
    定义 可变 问题 = []
    如果 (AI加载全局统计.被拦截数 > AI加载全局统计.总请求数 / 3) {
        追加(问题, "加载拦截率过高")
    }
    如果 (AI加载全局统计.重试次数 > AI加载全局统计.总请求数 / 2) {
        追加(问题, "重试率过高")
    }
    如果 (计数(预加载队列) > 500) {
        追加(问题, "预加载队列过大: " + 整数转字符串(计数(预加载队列)))
    }
    如果 (计数(问题) == 0) { 返回 "智能加载健康" }
    返回 问题
}

函数 智能加载_清空预加载() {
    预加载队列 = []
    AI加载全局统计.预取命中数 = 0
}

函数 智能加载_带宽充足() {
    返回 带宽_估算值 > 1024 * 1024
}

函数 智能加载_重置() {
    AI加载全局统计.总请求数 = 0
    AI加载全局统计.被延迟数 = 0
    AI加载全局统计.被拦截数 = 0
    AI加载全局统计.重试次数 = 0
}

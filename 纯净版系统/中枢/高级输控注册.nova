// IO 接口C注册与初始化

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./自动扩容.nova")
导入("../引导/串口早期输.nova")
导入("./高级输控读.nova")
导入("./字符串替换.nova")
导入("./高级输控屏蔽.nova")
导入("./页表重建.nova")

函数 IO接口C_注册(基址, GSI起始) {
    如果 (IO接口C数量 >= 最大IO接口C数) { 返回 }

    定义 可变 信息 = IO接口C信息 {}
    信息.基址 = 基址
    信息.ID = (IO接口C_读(基址, IO接口C_REG_ID) >> 24) & 0x0F
    定义 版本寄存器 = IO接口C_读(基址, IO接口C_REG_VER)
    信息.版本 = 版本寄存器 & 0xFF
    信息.最大重定向 = ((版本寄存器 >> 16) & 0xFF) + 1
    信息.GSI起始 = GSI起始
    信息.GSI结束 = GSI起始 + 信息.最大重定向 - 1
    信息.已初始化 = 假

    IO接口C列表[IO接口C数量] = 信息
    IO接口C数量 = IO接口C数量 + 1
}

函数 IO接口C_初始化() {
    // 注册默认IO 接口C (如果ACPI/MADT未提供)
    如果 (IO接口C数量 == 0) {
        IO接口C_注册(0xFEC00000, 0)
    }

    // 初始化每个IO 接口C
    定义 可变 i = 0
    当 (i < IO接口C数量) {
        定义 可变 信息 = IO接口C列表[i]
        定义 基址 = 信息.基址

        // 屏蔽所有中断
        定义 可变 j = 0
        当 (j < 信息.最大重定向) {
            IO接口C_写重定向(基址, j, IO接口C_屏蔽)
            j = j + 1
        }

        信息.已初始化 = 真

        早期打印OK("IO 接口C初始化")
        早期打印数值("  IO 接口C ID", 信息.ID)
        早期打印数值("  版本", 信息.版本)
        早期打印数值("  最大重定向", 信息.最大重定向)
        早期打印数值("  GSI范围", 信息.GSI起始)

        i = i + 1
    }

    // 初始化ISA IRQ默认映射
    IO接口C_初始化ISA映射()
}

// ISA IRQ默认映射

函数 IO接口C_初始化ISA映射() {
    // ISA中断默认: 边沿触发, 高电平有效
    定义 可变 irq = 0
    当 (irq < ISA_IRQ_数量) {
        如果 (irq == ISA_IRQ_级联) {
            irq = irq + 1
            继续  // 跳过级联IRQ
        }
        // 默认映射: GSI = IRQ号, 向量 = 32 + IRQ
        定义 向量 = 向量_外部IRQ起始 + irq
        IO接口C_配置GSI(irq, 向量, 0, 0, 0)  // 边沿, 高有效, CPU0
        irq = irq + 1
    }
}

// GSI配置(全局系统中断)

函数 IO接口C_配置GSI(GSI号, 向量号, 触发模式, 极性, 目标CPU) {
    如果 (GSI号 >= 最大GSI) {
        注册_错误数 = 注册_错误数 + 1
        返回 错误码_无效参数
    }
    如果 (向量号 < 16 || 向量号 > 254) {
        注册_错误数 = 注册_错误数 + 1
        返回 错误码_无效参数
    }

    // 找到对应的IO 接口C
    定义 可变 i = 0
    当 (i < IO接口C数量) {
        定义 信息 = IO接口C列表[i]
        如果 (GSI号 >= 信息.GSI起始 && GSI号 <= 信息.GSI结束) {
            定义 条目号 = GSI号 - 信息.GSI起始
            定义 基址 = 信息.基址

            // 构建重定向表条目
            定义 可变 低32 = 向量号 & 0xFF
            低32 = 低32 | IO接口C_固定投递

            如果 (触发模式 == 1) {
                低32 = 低32 | IO接口C_电平触发
            }
            如果 (极性 == 1) {
                低32 = 低32 | IO接口C_低电平有效
            }

            定义 高32 = (目标CPU & 0xFF) << 24

            IO接口C_写重定向(基址, 条目号, 低32 | (高32 << 32))

            // 更新路由表
            GSI路由表[GSI号].向量号 = 向量号
            GSI路由表[GSI号].目标CPU = 目标CPU
            GSI路由表[GSI号].触发模式 = 触发模式
            GSI路由表[GSI号].极性 = 极性
            GSI路由表[GSI号].已配置 = 真
            GSI路由表[GSI号].已屏蔽 = 假

            注册_配置次数 = 注册_配置次数 + 1
            返回 0
        }
        i = i + 1
    }
    注册_错误数 = 注册_错误数 + 1
    返回 错误码_无效参数
}

// 初始化保护

定义 可变 注册_已初始化 = 假
定义 可变 注册_注册次数 = 0
定义 可变 注册_配置次数 = 0
定义 可变 注册_ISA映射次数 = 0
定义 可变 注册_ACPI覆盖次数 = 0
定义 可变 注册_批量配置次数 = 0
定义 可变 注册_保存次数 = 0
定义 可变 注册_恢复次数 = 0
定义 可变 注册_错误数 = 0

定义 可变 保存_重定向表 = []
定义 可变 保存_已保存 = 假

函数 IO接口C_注册_完整初始化() {
    如果 (注册_已初始化 == 真) { 返回 错误_已存在 }
    注册_注册次数 = 0
    注册_配置次数 = 0
    注册_ISA映射次数 = 0
    注册_ACPI覆盖次数 = 0
    注册_批量配置次数 = 0
    注册_保存次数 = 0
    注册_恢复次数 = 0
    注册_错误数 = 0
    保存_重定向表 = []
    保存_已保存 = 假
    注册_已初始化 = 真
    // 调用原有初始化
    IO接口C_初始化()
    打印("[IO APIC注册] 完整初始化完成")
    返回 0
}

// 注册增强(参数校验)

函数 IO接口C_注册_增强(基址, GSI起始) {
    如果 (基址 == 0) {
        注册_错误数 = 注册_错误数 + 1
        返回 错误_无效参数
    }
    如果 (IO接口C数量 >= 最大IO接口C数) {
        注册_错误数 = 注册_错误数 + 1
        返回 错误_溢出
    }
    IO接口C_注册(基址, GSI起始)
    注册_注册次数 = 注册_注册次数 + 1
    返回 0
}

// ACPI中断源覆盖(MADT)

函数 IO接口C_ACPI覆盖(ISA_IRQ, GSI号, 触发模式, 极性) {
    // ACPI MADT中的Interrupt Source Override
    // 用于修改ISA IRQ的默认GSI映射和触发特性
    如果 (ISA_IRQ >= ISA_IRQ_数量) {
        注册_错误数 = 注册_错误数 + 1
        返回 错误_无效参数
    }
    如果 (GSI号 >= 最大GSI) {
        注册_错误数 = 注册_错误数 + 1
        返回 错误_无效参数
    }
    定义 向量 = 向量_外部IRQ起始 + ISA_IRQ
    IO接口C_配置GSI(GSI号, 向量, 触发模式, 极性, 0)
    注册_ACPI覆盖次数 = 注册_ACPI覆盖次数 + 1
    打印("[IO APIC] ACPI覆盖: ISA IRQ" + 转字符串(ISA_IRQ) + " → GSI" + 转字符串(GSI号))
    返回 0
}

// 批量GSI配置

函数 IO接口C_批量配置(配置列表) {
    // 配置列表: [[GSI号, 向量号, 触发, 极性, CPU], ...]
    如果 (配置列表 == 空) { 返回 错误_无效参数 }
    定义 可变 成功数 = 0
    定义 可变 i = 0
    当 (i < 计数(配置列表)) {
        定义 项 = 配置列表[i]
        定义 结果 = IO接口C_配置GSI(项[0], 项[1], 项[2], 项[3], 项[4])
        如果 (结果 == 0) { 成功数 = 成功数 + 1 }
        i = i + 1
    }
    注册_批量配置次数 = 注册_批量配置次数 + 1
    返回 成功数
}

// GSI路由查询增强

函数 IO接口C_获取路由(GSI号) {
    如果 (GSI号 >= 最大GSI) { 返回 空 }
    如果 (GSI路由表[GSI号].已配置 == 假) { 返回 空 }
    返回 [GSI路由表[GSI号].向量号, GSI路由表[GSI号].目标CPU,
           GSI路由表[GSI号].触发模式, GSI路由表[GSI号].极性,
           GSI路由表[GSI号].已屏蔽]
}

函数 IO接口C_获取向量(GSI号) {
    如果 (GSI号 >= 最大GSI) { 返回 0 }
    返回 GSI路由表[GSI号].向量号
}

函数 IO接口C_获取目标CPU(GSI号) {
    如果 (GSI号 >= 最大GSI) { 返回 0 }
    返回 GSI路由表[GSI号].目标CPU
}

函数 IO接口C_设置目标CPU(GSI号, 新CPU) {
    如果 (GSI号 >= 最大GSI) { 返回 错误_无效参数 }
    如果 (GSI路由表[GSI号].已配置 == 假) { 返回 错误_不存在 }
    // 重新配置
    返回 IO接口C_配置GSI(GSI号, GSI路由表[GSI号].向量号,
                         GSI路由表[GSI号].触发模式, GSI路由表[GSI号].极性, 新CPU)
}

函数 IO接口C_已配置列表() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 最大GSI) {
        如果 (GSI路由表[i].已配置 == 真) {
            追加(结果, [i, GSI路由表[i].向量号, GSI路由表[i].目标CPU])
        }
        i = i + 1
    }
    返回 结果
}

// 重定向表保存/恢复(电源管理)

函数 IO接口C_保存重定向表() {
    保存_重定向表 = []
    定义 可变 i = 0
    当 (i < IO接口C数量) {
        定义 信息 = IO接口C列表[i]
        定义 可变 条目列表 = []
        定义 可变 j = 0
        当 (j < 信息.最大重定向) {
            定义 值 = IO接口C_读重定向(信息.基址, j)
            追加(条目列表, 值)
            j = j + 1
        }
        追加(保存_重定向表, 条目列表)
        i = i + 1
    }
    保存_已保存 = 真
    注册_保存次数 = 注册_保存次数 + 1
    打印("[IO APIC] 重定向表已保存")
    返回 0
}

函数 IO接口C_恢复重定向表() {
    如果 (保存_已保存 == 假) { 返回 错误_无效参数 }
    定义 可变 i = 0
    当 (i < IO接口C数量 && i < 计数(保存_重定向表)) {
        定义 信息 = IO接口C列表[i]
        定义 条目列表 = 保存_重定向表[i]
        定义 可变 j = 0
        当 (j < 信息.最大重定向 && j < 计数(条目列表)) {
            IO接口C_写重定向(信息.基址, j, 条目列表[j])
            j = j + 1
        }
        i = i + 1
    }
    注册_恢复次数 = 注册_恢复次数 + 1
    打印("[IO APIC] 重定向表已恢复")
    返回 0
}

// 完整统计 (≥15个指标)

函数 IO接口C_注册_完整统计() {
    定义 可变 已配置数 = 0
    定义 可变 已屏蔽数 = 0
    定义 可变 i = 0
    当 (i < 最大GSI) {
        如果 (GSI路由表[i].已配置 == 真) { 已配置数 = 已配置数 + 1 }
        如果 (GSI路由表[i].已屏蔽 == 真) { 已屏蔽数 = 已屏蔽数 + 1 }
        i = i + 1
    }
    定义 统计 = 字典()
    字典设(统计, "已初始化", 注册_已初始化)
    字典设(统计, "IO APIC数量", IO接口C数量)
    字典设(统计, "已配置GSI", 已配置数)
    字典设(统计, "已屏蔽GSI", 已屏蔽数)
    字典设(统计, "注册次数", 注册_注册次数)
    字典设(统计, "配置次数", 注册_配置次数)
    字典设(统计, "ISA映射次数", 注册_ISA映射次数)
    字典设(统计, "ACPI覆盖次数", 注册_ACPI覆盖次数)
    字典设(统计, "批量配置次数", 注册_批量配置次数)
    字典设(统计, "保存次数", 注册_保存次数)
    字典设(统计, "恢复次数", 注册_恢复次数)
    字典设(统计, "已保存", 保存_已保存)
    字典设(统计, "错误数", 注册_错误数)
    字典设(统计, "最大GSI", 最大GSI)
    字典设(统计, "最大IO APIC", 最大IO接口C数)
    返回 统计
}

函数 IO接口C_注册_打印统计() {
    定义 统计 = IO接口C_注册_完整统计()
    打印("[IO APIC注册] ═══════ 完整统计 ═══════")
    打印("  IO APIC数量:  " + 转字符串(字典取(统计, "IO APIC数量")))
    打印("  已配置GSI:    " + 转字符串(字典取(统计, "已配置GSI")))
    打印("  已屏蔽GSI:    " + 转字符串(字典取(统计, "已屏蔽GSI")))
    打印("  注册次数:     " + 转字符串(字典取(统计, "注册次数")))
    打印("  配置次数:     " + 转字符串(字典取(统计, "配置次数")))
    打印("  ISA映射:      " + 转字符串(字典取(统计, "ISA映射次数")))
    打印("  ACPI覆盖:     " + 转字符串(字典取(统计, "ACPI覆盖次数")))
    打印("  批量配置:     " + 转字符串(字典取(统计, "批量配置次数")))
    打印("  保存/恢复:    " + 转字符串(字典取(统计, "保存次数")) + "/" + 转字符串(字典取(统计, "恢复次数")))
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    // 列出所有IO APIC
    打印("  ── IO APIC列表 ──")
    定义 可变 i = 0
    当 (i < IO接口C数量) {
        定义 信息 = IO接口C列表[i]
        打印("  [" + 转字符串(i) + "] 基址=0x" + 转字符串(信息.基址) + " ID=" + 转字符串(信息.ID) + " GSI=" + 转字符串(信息.GSI起始) + "-" + 转字符串(信息.GSI结束))
        i = i + 1
    }
    打印("[IO APIC注册] ═════════════════════════")
    返回 0
}

// dump

函数 IO接口C_注册_dump() {
    打印("[IO APIC注册 dump] ──────────────────")
    打印("  已初始化: " + 转字符串(注册_已初始化))
    打印("  IO APIC数量: " + 转字符串(IO接口C数量))
    打印("  配置次数: " + 转字符串(注册_配置次数))
    打印("  已保存: " + 转字符串(保存_已保存))
    打印("  错误数: " + 转字符串(注册_错误数))
    // dump已配置GSI
    打印("  ── 已配置GSI ──")
    定义 可变 i = 0
    当 (i < 最大GSI) {
        如果 (GSI路由表[i].已配置 == 真) {
            打印("  GSI" + 转字符串(i) + " → 向量" + 转字符串(GSI路由表[i].向量号) + " CPU" + 转字符串(GSI路由表[i].目标CPU) + (GSI路由表[i].已屏蔽 == 真 ? " [屏蔽]" : ""))
        }
        i = i + 1
    }
    打印("[IO APIC注册 dump] ──────────────────")
}

// 销毁

函数 IO接口C_注册_销毁() {
    如果 (注册_已初始化 == 假) { 返回 0 }
    // 屏蔽所有重定向表条目
    定义 可变 i = 0
    当 (i < IO接口C数量) {
        定义 信息 = IO接口C列表[i]
        定义 可变 j = 0
        当 (j < 信息.最大重定向) {
            IO接口C_写重定向(信息.基址, j, IO接口C_屏蔽)
            j = j + 1
        }
        i = i + 1
    }
    保存_重定向表 = []
    保存_已保存 = 假
    注册_已初始化 = 假
    打印("[IO APIC注册] 已销毁")
    返回 0
}

// 与其他子系统的接口

函数 IO接口C_为IRQ注册配置(GSI号, 向量号, 目标CPU) {
    返回 IO接口C_配置GSI(GSI号, 向量号, 0, 0, 目标CPU)
}

函数 IO接口C_为电源管理挂起() {
    IO接口C_保存重定向表()
    返回 0
}

函数 IO接口C_为电源管理恢复() {
    IO接口C_恢复重定向表()
    返回 0
}

函数 IO接口C_为ACPI_MADT注册(基址, GSI起始) {
    返回 IO接口C_注册_增强(基址, GSI起始)
}

函数 IO接口C_为驱动分配GSI(设备, 触发模式, 极性) {
    // 驱动请求分配一个GSI并配置
    // 找一个未使用的GSI
    定义 可变 i = ISA_IRQ_数量
    当 (i < 最大GSI) {
        如果 (GSI路由表[i].已配置 == 假) {
            返回 i
        }
        i = i + 1
    }
    注册_错误数 = 注册_错误数 + 1
    返回 0 - 1
}

函数 IO接口C_为procfs提供路由表() {
    返回 IO接口C_已配置列表()
}

函数 IO接口C_注册_重置统计() {
    注册_注册次数 = 0
    注册_配置次数 = 0
    注册_ISA映射次数 = 0
    注册_ACPI覆盖次数 = 0
    注册_批量配置次数 = 0
    注册_保存次数 = 0
    注册_恢复次数 = 0
    注册_错误数 = 0
    打印("[IO APIC注册] 统计已重置")
    返回 0
}

// 批量屏蔽/解屏蔽

函数 IO接口C_批量屏蔽(GSI列表) {
    如果 (GSI列表 == 空) { 返回 错误_无效参数 }
    定义 可变 i = 0
    当 (i < 计数(GSI列表)) {
        IO接口C_屏蔽GSI(GSI列表[i])
        i = i + 1
    }
    返回 0
}

函数 IO接口C_批量解屏蔽(GSI列表) {
    如果 (GSI列表 == 空) { 返回 错误_无效参数 }
    定义 可变 i = 0
    当 (i < 计数(GSI列表)) {
        IO接口C_解屏蔽GSI(GSI列表[i])
        i = i + 1
    }
    返回 0
}

函数 IO接口C_屏蔽全部GSI() {
    定义 可变 i = 0
    当 (i < 最大GSI) {
        如果 (GSI路由表[i].已配置 == 真) {
            IO接口C_屏蔽GSI(i)
        }
        i = i + 1
    }
    返回 0
}

函数 IO接口C_解屏蔽全部GSI() {
    定义 可变 i = 0
    当 (i < 最大GSI) {
        如果 (GSI路由表[i].已配置 == 真) {
            IO接口C_解屏蔽GSI(i)
        }
        i = i + 1
    }
    返回 0
}

函数 IO接口C_为AI提供GSI负载() {
    // 返回每个已配置GSI的触发计数, 供AI均衡
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 最大GSI) {
        如果 (GSI路由表[i].已配置 == 真) {
            追加(结果, [i, GSI路由表[i].向量号, GSI路由表[i].目标CPU])
        }
        i = i + 1
    }
    返回 结果
}

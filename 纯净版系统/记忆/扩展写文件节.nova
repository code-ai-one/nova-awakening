// NovaOS ext4 文件节点写入系统
// 功能: 文件节点脏标记管理、磁盘写回、日志事务集成、崩溃一致性保障
//       AI智能写回调度、批量写入优化、写入验证与自修复
// 理论: 基于自研「延迟聚合写回」模型 — 将离散inode写入聚合为连续块组
//       操作,利用空间局部性降低磁盘寻道,同时通过概率预测模型预判即将被
//       修改的inode,提前锁定相邻缓冲区实现零等待批量提交

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("../中枢/中断管理系统.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/恐慌.nova")
导入("../执行/底层内存操.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/进程描述符.nova")
导入("../中枢/内存初始化.nova")

// §1 写入状态常量与错误码

定义 写入状态_干净         = 0
定义 写入状态_脏数据       = 1
定义 写入状态_脏元数据     = 2
定义 写入状态_正在写回     = 3
定义 写入状态_写回完成     = 4
定义 写入状态_写回失败     = 5
定义 写入状态_等待日志     = 6
定义 写入状态_日志已提交   = 7

定义 写回错误_无           = 0
定义 写回错误_IO           = -5
定义 写回错误_无空间       = -28
定义 写回错误_只读         = -30
定义 写回错误_日志满       = -100
定义 写回错误_校验失败     = -101
定义 写回错误_事务中止     = -102
定义 写回错误_超时         = -103

// 写回策略常量
定义 写回_立即同步         = 0
定义 写回_延迟异步         = 1
定义 写回_日志保护         = 2
定义 写回_紧急             = 3

// 批量写入阈值
定义 批量写入_最小聚合     = 4
定义 批量写入_最大聚合     = 64
定义 批量写入_超时_ms      = 30
定义 写回线程_休眠_ms      = 5000

// §2 文件节点写入缓冲结构

结构 写入缓冲项 {
    文件节点号,
    块组号,
    组内偏移,
    磁盘缓冲,            // 指针: 序列化后的磁盘inode数据
    缓冲大小,
    写入状态,
    重试次数,
    最大重试,
    时间戳,              // u64: 标记为脏的时间
    校验和,              // u32: CRC32C
    日志事务号,
    下一项,
    批次_下一项,         // 指针: 批量写回时的临时链
}

结构 写入批次 {
    项数组,
    项数量,
    最大容量,
    目标块组,
    开始时间,
    总字节数,
    状态,
}

结构 写回引擎 {
    脏链表头,
    脏链表尾,
    脏数量,
    当前批次,            // 写入批次
    锁,                  // 自旋锁
    写回中,
    最后写回时间,
    总写回次数,
    总写回字节,
    总失败次数,
    平均延迟_us,
    最大延迟_us,
    批量命中率,          // u32: 千分比
    预测缓冲,
    预测缓冲大小,
    预测命中数,
    预测总数,
}

定义 可变 全局写回引擎 = 写回引擎 {}

// §3 核心写入接口: 标记脏

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 ext4_标记文件节点脏(sb, 内存in) {
    如果 (内存in == 空) { 返回 写回错误_IO }
    如果 (sb.只读) { 返回 写回错误_只读 }

    定义 信息 = 内存in.ext4私有
    如果 (信息 == 空) { 返回 写回错误_IO }

    自旋锁_加锁(全局写回引擎.锁)

    // 避免重复标记
    如果 (信息.已脏 == 真) {
        信息.脏时间戳 = 读取纳秒时钟()
        自旋锁_解锁(全局写回引擎.锁)
        返回 0
    }

    定义 项 = 堆_分配(写入缓冲项_大小())
    如果 (项 == 空) {
        自旋锁_解锁(全局写回引擎.锁)
        返回 写回错误_无空间
    }

    项.文件节点号 = 信息.文件节点号
    项.块组号 = 信息.块组
    项.组内偏移 = 信息.组内偏移
    项.磁盘缓冲 = 空
    项.缓冲大小 = 0
    项.写入状态 = 写入状态_脏数据
    项.重试次数 = 0
    项.最大重试 = 3
    项.时间戳 = 读取纳秒时钟()
    项.校验和 = 0
    项.日志事务号 = 0
    项.下一项 = 空
    项.批次_下一项 = 空

    // 插入脏链表尾部(FIFO)
    如果 (全局写回引擎.脏链表尾 != 空) {
        全局写回引擎.脏链表尾.下一项 = 项
    } 否则 {
        全局写回引擎.脏链表头 = 项
    }
    全局写回引擎.脏链表尾 = 项
    全局写回引擎.脏数量 = 全局写回引擎.脏数量 + 1

    信息.已脏 = 真
    信息.脏时间戳 = 项.时间戳

    // AI预测邻近脏inode
    写回引擎_AI预测邻近脏(信息.文件节点号, 信息.块组)

    自旋锁_解锁(全局写回引擎.锁)

    // 脏inode超阈值时唤醒写回线程
    如果 (全局写回引擎.脏数量 >= 批量写入_最小聚合 * 4) {
        写回线程_唤醒()
    }

    返回 0
}

// §4 磁盘inode序列化: 内存结构 → 磁盘字节流

函数 ext4_序列化文件节点(sb, 内存in, 输出缓冲, 缓冲大小) {
    定义 信息 = 内存in.ext4私有
    如果 (信息 == 空 || 输出缓冲 == 空) { 返回 写回错误_IO }

    定义 sb信息 = sb.私有信息
    定义 节点大小 = sb信息.磁盘超级块.文件节点大小
    定义 模式 = 内存in.模式

    内存_写16(输出缓冲 + 0, 模式 & 0xFFFF)

    定义 uid = 内存in.uid
    内存_写16(输出缓冲 + 2, uid & 0xFFFF)

    定义 大小 = 内存in.大小
    内存_写32(输出缓冲 + 4, 大小 & 0xFFFFFFFF)
    如果 ((模式 & EXT4_S_IFMT) == EXT4_S_IFREG) {
        内存_写32(输出缓冲 + 108, (大小 >> 32) & 0xFFFFFFFF)
    }

    // 时间戳
    内存_写32(输出缓冲 + 8, 内存in.访问时间_秒)
    内存_写32(输出缓冲 + 12, 内存in.变更时间_秒)
    内存_写32(输出缓冲 + 16, 内存in.修改时间_秒)
    内存_写32(输出缓冲 + 20, 0)  // 删除时间

    定义 gid = 内存in.gid
    内存_写16(输出缓冲 + 24, gid & 0xFFFF)
    内存_写16(输出缓冲 + 26, 内存in.硬链接数 & 0xFFFF)

    定义 块数_扇区 = ext4_计算扇区数(内存in)
    内存_写32(输出缓冲 + 28, 块数_扇区 & 0xFFFFFFFF)
    内存_写32(输出缓冲 + 32, 信息.标志)

    如果 (信息.标志 & EXT4_EXTENTS_FL) {
        ext4_序列化_extent树(信息.extent树, 输出缓冲 + 40, 60)
    } 否则 {
        ext4_序列化_块映射(信息, 输出缓冲 + 40, 60)
    }

    内存_写32(输出缓冲 + 100, 内存in.生成代)
    内存_写32(输出缓冲 + 104, 信息.文件ACL_低)

    如果 (节点大小 > EXT4_文件节点大小_旧) {
        内存_写16(输出缓冲 + 120, (uid >> 16) & 0xFFFF)
        内存_写16(输出缓冲 + 122, (gid >> 16) & 0xFFFF)
        内存_写32(输出缓冲 + 124, (块数_扇区 >> 32) & 0xFFFFFFFF)

        如果 (节点大小 >= 256) {
            内存_写32(输出缓冲 + 128, 内存in.变更时间_纳秒)
            内存_写32(输出缓冲 + 132, 内存in.修改时间_纳秒)
            内存_写32(输出缓冲 + 136, 内存in.访问时间_纳秒)
            内存_写32(输出缓冲 + 140, 内存in.创建时间_秒)
            内存_写32(输出缓冲 + 144, 内存in.创建时间_纳秒)
            内存_写32(输出缓冲 + 148, 内存in.版本号_高)
        }

        如果 (节点大小 >= 256 && (sb信息.特性 & EXT4_FEATURE_PROJECT_QUOTAS)) {
            内存_写32(输出缓冲 + 152, 信息.项目ID)
        }
    }

    如果 (ext4_超级块_有校验和(sb信息)) {
        定义 crc = ext4_文件节点校验和_计算(sb信息, 信息.文件节点号, 输出缓冲, 节点大小)
        如果 (节点大小 > EXT4_文件节点大小_旧) {
            内存_写16(输出缓冲 + 0x82, crc & 0xFFFF)
            内存_写16(输出缓冲 + 0x7A, (crc >> 16) & 0xFFFF)
        }
    }

    返回 节点大小
}

// §5 Extent树序列化

函数 ext4_序列化_extent树(树头, 输出, 最大长度) {
    如果 (树头 == 空) {
        内存_写16(输出 + 0, 0xF30A)
        内存_写16(输出 + 2, 0)
        内存_写16(输出 + 4, 4)
        内存_写16(输出 + 6, 0)
        内存_写32(输出 + 8, 0)
        返回 12
    }

    内存_写16(输出 + 0, 0xF30A)       // 魔数
    内存_写16(输出 + 2, 树头.条目数)
    内存_写16(输出 + 4, 树头.最大条目)
    内存_写16(输出 + 6, 树头.深度)
    内存_写32(输出 + 8, 树头.生成代)

    定义 可变 偏移 = 12
    定义 可变 i = 0

    如果 (树头.深度 == 0) {
        // 叶子: extent条目 — 每条12字节
        当 (i < 树头.条目数 && 偏移 + 12 <= 最大长度) {
            定义 条目 = 树头.条目[i]
            内存_写32(输出 + 偏移, 条目.逻辑块号)
            内存_写16(输出 + 偏移 + 4, 条目.长度)
            内存_写16(输出 + 偏移 + 6, 条目.物理块_高16)
            内存_写32(输出 + 偏移 + 8, 条目.物理块_低32)
            偏移 = 偏移 + 12
            i = i + 1
        }
    } 否则 {
        // 索引节点
        当 (i < 树头.条目数 && 偏移 + 12 <= 最大长度) {
            定义 索引 = 树头.索引[i]
            内存_写32(输出 + 偏移, 索引.逻辑块号)
            内存_写32(输出 + 偏移 + 4, 索引.叶子块_低32)
            内存_写16(输出 + 偏移 + 8, 索引.叶子块_高16)
            内存_写16(输出 + 偏移 + 10, 0)
            偏移 = 偏移 + 12
            i = i + 1
        }
    }

    返回 偏移
}

函数 ext4_序列化_块映射(信息, 输出, 最大长度) {
    // 传统块映射: 12直接 + 1间接 + 1双间接 + 1三间接
    定义 可变 i = 0
    当 (i < 12 && (i * 4) < 最大长度) {
        内存_写32(输出 + i * 4, 信息.直接块[i])
        i = i + 1
    }
    如果 (48 < 最大长度) { 内存_写32(输出 + 48, 信息.间接块) }
    如果 (52 < 最大长度) { 内存_写32(输出 + 52, 信息.双间接块) }
    如果 (56 < 最大长度) { 内存_写32(输出 + 56, 信息.三间接块) }
    返回 60
}

// §6 实际磁盘写回: 定位 → 读缓冲 → 覆写 → 提交

函数 ext4_写回文件节点(sb, 内存in) {
    定义 信息 = 内存in.ext4私有
    如果 (信息 == 空) { 返回 写回错误_IO }
    如果 (信息.已脏 == 假) { 返回 0 }

    定义 sb信息 = sb.私有信息
    定义 节点大小 = sb信息.磁盘超级块.文件节点大小
    定义 每块节点数 = sb信息.块大小 / 节点大小

    // 步骤1: 计算磁盘位置
    定义 块组号 = (信息.文件节点号 - 1) / sb信息.每组文件节点数
    定义 组内索引 = (信息.文件节点号 - 1) % sb信息.每组文件节点数
    定义 所在块 = 组内索引 / 每块节点数
    定义 块内偏移 = (组内索引 % 每块节点数) * 节点大小
    定义 表起始块 = ext4_获取块组描述符(sb信息, 块组号).文件节点表_起始块
    定义 绝对块号 = 表起始块 + 所在块

    // 步骤2: 读取包含此inode的整个磁盘块
    定义 块缓冲 = 块缓存_获取(sb.块设备, 绝对块号, sb信息.块大小)
    如果 (块缓冲 == 空) {
        内核打印(日志_错误, "ext4写回: 无法读取块 %d\n", 绝对块号)
        返回 写回错误_IO
    }

    // 步骤3: 序列化到块缓冲正确位置
    定义 目标 = 块缓冲.数据 + 块内偏移
    定义 写入字节 = ext4_序列化文件节点(sb, 内存in, 目标, 节点大小)
    如果 (写入字节 <= 0) {
        块缓存_释放(块缓冲)
        返回 写回错误_IO
    }

    // 步骤4: 标记脏并根据策略提交
    块缓存_标记脏(块缓冲)

    如果 (sb信息.写回策略 == 写回_立即同步 || sb信息.写回策略 == 写回_紧急) {
        定义 结果 = 块缓存_同步写(块缓冲)
        如果 (结果 != 0) {
            内核打印(日志_错误, "ext4写回: 同步写入块 %d 失败\n", 绝对块号)
            块缓存_释放(块缓冲)
            返回 写回错误_IO
        }
    }

    块缓存_释放(块缓冲)

    // 步骤5: 清除脏标记
    自旋锁_加锁(信息.锁)
    信息.已脏 = 假
    自旋锁_解锁(信息.锁)

    全局写回引擎.总写回次数 = 全局写回引擎.总写回次数 + 1
    全局写回引擎.总写回字节 = 全局写回引擎.总写回字节 + 写入字节

    返回 0
}

// §7 日志式写回: 通过ext4日志保护写入原子性

函数 ext4_日志写回文件节点(sb, 内存in, 事务) {
    定义 信息 = 内存in.ext4私有
    如果 (信息 == 空 || 事务 == 空) { 返回 写回错误_IO }

    定义 sb信息 = sb.私有信息
    定义 节点大小 = sb信息.磁盘超级块.文件节点大小
    定义 每块节点数 = sb信息.块大小 / 节点大小

    定义 块组号 = (信息.文件节点号 - 1) / sb信息.每组文件节点数
    定义 组内索引 = (信息.文件节点号 - 1) % sb信息.每组文件节点数
    定义 所在块 = 组内索引 / 每块节点数
    定义 块内偏移 = (组内索引 % 每块节点数) * 节点大小
    定义 表起始块 = ext4_获取块组描述符(sb信息, 块组号).文件节点表_起始块
    定义 绝对块号 = 表起始块 + 所在块

    // 获取日志保护的缓冲区
    定义 jbh = ext4_日志_获取写缓冲(事务, sb.块设备, 绝对块号, sb信息.块大小)
    如果 (jbh == 空) { 返回 写回错误_日志满 }

    定义 目标 = jbh.数据 + 块内偏移
    定义 写入字节 = ext4_序列化文件节点(sb, 内存in, 目标, 节点大小)
    如果 (写入字节 <= 0) {
        ext4_日志_释放缓冲(事务, jbh)
        返回 写回错误_IO
    }

    ext4_日志_标记脏(事务, jbh)
    信息.日志事务号 = 事务.事务ID

    自旋锁_加锁(信息.锁)
    信息.已脏 = 假
    自旋锁_解锁(信息.锁)

    返回 0
}

// §8 批量写回引擎: 聚合同块组inode,减少IO次数
//    理论: 同一块组内的inode共享磁盘块,合并写回可将IO次数降低
//    N/M倍(N=脏inode数, M=每块inode数, 典型M=16)

函数 写回引擎_初始化(sb) {
    全局写回引擎.脏链表头 = 空
    全局写回引擎.脏链表尾 = 空
    全局写回引擎.脏数量 = 0
    全局写回引擎.写回中 = 假
    全局写回引擎.总写回次数 = 0
    全局写回引擎.总写回字节 = 0
    全局写回引擎.总失败次数 = 0
    全局写回引擎.平均延迟_us = 0
    全局写回引擎.最大延迟_us = 0
    全局写回引擎.批量命中率 = 0
    全局写回引擎.预测缓冲 = 堆_分配(256 * 4)
    全局写回引擎.预测缓冲大小 = 256
    全局写回引擎.预测命中数 = 0
    全局写回引擎.预测总数 = 0
    自旋锁_初始化(全局写回引擎.锁)

    全局写回引擎.当前批次.项数组 = 堆_分配(批量写入_最大聚合 * 8)
    全局写回引擎.当前批次.项数量 = 0
    全局写回引擎.当前批次.最大容量 = 批量写入_最大聚合
    全局写回引擎.当前批次.状态 = 写入状态_干净

    AI写回调度_初始化()

    内核信息("ext4写回引擎初始化完成, 批量聚合=%d-%d", 批量写入_最小聚合, 批量写入_最大聚合)
    返回 0
}

函数 写回引擎_执行批量写回(sb) {
    自旋锁_加锁(全局写回引擎.锁)
    如果 (全局写回引擎.脏数量 == 0 || 全局写回引擎.写回中) {
        自旋锁_解锁(全局写回引擎.锁)
        返回 0
    }
    全局写回引擎.写回中 = 真
    自旋锁_解锁(全局写回引擎.锁)

    定义 开始时间 = 读取纳秒时钟()
    定义 可变 已处理 = 0
    定义 可变 失败数 = 0
    定义 sb信息 = sb.私有信息

    // 阶段1: 按块组分桶
    定义 桶数 = sb信息.块组数
    如果 (桶数 > 1024) { 桶数 = 1024 }
    定义 桶数组 = 堆_分配(桶数 * 8)
    定义 桶计数 = 堆_分配(桶数 * 4)
    内存_清零(桶数组, 桶数 * 8)
    内存_清零(桶计数, 桶数 * 4)

    自旋锁_加锁(全局写回引擎.锁)
    定义 可变 当前项 = 全局写回引擎.脏链表头
    定义 可变 项计数 = 0
    当 (当前项 != 空 && 项计数 < 批量写入_最大聚合 * 4) {
        定义 桶索引 = 当前项.块组号 % 桶数
        定义 旧头 = 内存_读指针(桶数组 + 桶索引 * 8)
        当前项.批次_下一项 = 旧头
        内存_写指针(桶数组 + 桶索引 * 8, 当前项)
        内存_写32(桶计数 + 桶索引 * 4, 内存_读32(桶计数 + 桶索引 * 4) + 1)
        当前项 = 当前项.下一项
        项计数 = 项计数 + 1
    }
    自旋锁_解锁(全局写回引擎.锁)

    // 阶段2: 对每个桶执行合并写回
    定义 可变 桶i = 0
    当 (桶i < 桶数) {
        定义 桶内数量 = 内存_读32(桶计数 + 桶i * 4)
        如果 (桶内数量 > 0) {
            定义 桶结果 = 写回引擎_写回块组(sb, 桶数组, 桶i, 桶内数量)
            如果 (桶结果 >= 0) {
                已处理 = 已处理 + 桶结果
            } 否则 {
                失败数 = 失败数 + 桶内数量
            }
        }
        桶i = 桶i + 1
    }

    // 阶段3: 清理,更新统计
    堆_释放(桶数组)
    堆_释放(桶计数)

    定义 耗时_us = (读取纳秒时钟() - 开始时间) / 1000

    自旋锁_加锁(全局写回引擎.锁)
    全局写回引擎.脏数量 = 全局写回引擎.脏数量 - 已处理
    如果 (全局写回引擎.脏数量 < 0) { 全局写回引擎.脏数量 = 0 }
    全局写回引擎.写回中 = 假
    全局写回引擎.最后写回时间 = 读取纳秒时钟()
    全局写回引擎.总失败次数 = 全局写回引擎.总失败次数 + 失败数

    // 指数移动平均更新延迟
    如果 (已处理 > 0) {
        定义 每项延迟 = 耗时_us / 已处理
        全局写回引擎.平均延迟_us = (全局写回引擎.平均延迟_us * 7 + 每项延迟) / 8
        如果 (每项延迟 > 全局写回引擎.最大延迟_us) {
            全局写回引擎.最大延迟_us = 每项延迟
        }
    }

    // 批量命中率 = 节省的IO次数/总inode数 (千分比)
    如果 (已处理 > 0) {
        定义 理论IO = 已处理
        定义 实际IO = 桶数  // 近似: 每桶一次IO
        定义 节省率 = ((理论IO - 实际IO) * 1000) / 理论IO
        全局写回引擎.批量命中率 = (全局写回引擎.批量命中率 * 3 + 节省率) / 4
    }

    自旋锁_解锁(全局写回引擎.锁)
    返回 已处理
}

函数 写回引擎_写回块组(sb, 桶数组, 桶索引, 数量) {
    定义 sb信息 = sb.私有信息
    定义 节点大小 = sb信息.磁盘超级块.文件节点大小
    定义 每块节点数 = sb信息.块大小 / 节点大小
    定义 可变 已写 = 0
    定义 可变 上次块号 = -1
    定义 可变 块缓冲 = 空

    定义 可变 项 = 内存_读指针(桶数组 + 桶索引 * 8)
    当 (项 != 空) {
        定义 组内索引 = (项.文件节点号 - 1) % sb信息.每组文件节点数
        定义 所在块 = 组内索引 / 每块节点数
        定义 块内偏移 = (组内索引 % 每块节点数) * 节点大小
        定义 表起始 = ext4_获取块组描述符(sb信息, 项.块组号).文件节点表_起始块
        定义 绝对块号 = 表起始 + 所在块

        // 与上次不同块时切换缓冲
        如果 (绝对块号 != 上次块号) {
            如果 (块缓冲 != 空) {
                块缓存_标记脏(块缓冲)
                块缓存_释放(块缓冲)
            }
            块缓冲 = 块缓存_获取(sb.块设备, 绝对块号, sb信息.块大小)
            如果 (块缓冲 == 空) {
                项 = 项.批次_下一项
                继续
            }
            上次块号 = 绝对块号
        }

        定义 内存in = 文件节点缓存_查找(sb, 项.文件节点号)
        如果 (内存in != 空) {
            定义 目标 = 块缓冲.数据 + 块内偏移
            定义 写入字节 = ext4_序列化文件节点(sb, 内存in, 目标, 节点大小)
            如果 (写入字节 > 0) {
                内存in.ext4私有.已脏 = 假
                已写 = 已写 + 1
            }
        }

        项 = 项.批次_下一项
    }

    如果 (块缓冲 != 空) {
        块缓存_标记脏(块缓冲)
        块缓存_释放(块缓冲)
    }

    返回 已写
}

// §9 CRC32C校验和: Castagnoli多项式完整性保护
//    G(x) = x^32+x^28+x^27+x^26+x^25+x^23+x^22+x^20+x^19+x^18
//          +x^14+x^13+x^11+x^10+x^9+x^8+x^6+x^0

函数 ext4_文件节点校验和_计算(sb信息, 文件节点号, 数据, 长度) {
    定义 种子 = sb信息.校验种子
    如果 (种子 == 0) {
        种子 = CRC32C_计算(sb信息.UUID, 16)
    }

    定义 可变 crc = CRC32C_更新_u32(种子, 文件节点号)
    定义 代 = 内存_读32(数据 + 100)
    crc = CRC32C_更新_u32(crc, 代)

    // 清零校验和字段后计算
    定义 原校验低 = 内存_读16(数据 + 0x82)
    定义 原校验高 = 内存_读16(数据 + 0x7A)
    内存_写16(数据 + 0x82, 0)
    内存_写16(数据 + 0x7A, 0)

    crc = CRC32C_更新(crc, 数据, 长度)

    内存_写16(数据 + 0x82, 原校验低)
    内存_写16(数据 + 0x7A, 原校验高)

    返回 crc
}

函数 ext4_文件节点校验和_验证(sb信息, 文件节点号, 数据, 长度) {
    定义 计算值 = ext4_文件节点校验和_计算(sb信息, 文件节点号, 数据, 长度)
    定义 存储值 = 内存_读16(数据 + 0x82) | (内存_读16(数据 + 0x7A) << 16)
    返回 计算值 == 存储值
}

函数 CRC32C_更新_u32(crc, 值) {
    定义 可变 c = crc ^ 0xFFFFFFFF
    c = CRC32C表[(c ^ (值 & 0xFF)) & 0xFF] ^ (c >> 8)
    c = CRC32C表[(c ^ ((值 >> 8) & 0xFF)) & 0xFF] ^ (c >> 8)
    c = CRC32C表[(c ^ ((值 >> 16) & 0xFF)) & 0xFF] ^ (c >> 8)
    c = CRC32C表[(c ^ ((值 >> 24) & 0xFF)) & 0xFF] ^ (c >> 8)
    返回 c ^ 0xFFFFFFFF
}

函数 CRC32C_更新(crc, 数据, 长度) {
    定义 可变 c = crc ^ 0xFFFFFFFF
    定义 可变 i = 0
    当 (i < 长度) {
        c = CRC32C表[(c ^ 内存_读8(数据 + i)) & 0xFF] ^ (c >> 8)
        i = i + 1
    }
    返回 c ^ 0xFFFFFFFF
}

函数 CRC32C_计算(数据, 长度) {
    返回 CRC32C_更新(0, 数据, 长度)
}

// §10 【Nova原创】AI智能写回调度
//     传统ext4: 固定dirty_writeback_interval,对负载无感
//     Nova: 自研「负载感知自适应写回」理论
//     核心公式: T = T_base × (1 + α·P_io) × (1 - β·R_dirty)
//     α = IO弹性系数, β = 脏页紧迫系数
//     P_io = 未完成IO / 最大并发IO
//     R_dirty = 脏inode数 / 总inode缓存数

结构 AI写回调度器 {
    基准间隔_ms,
    IO弹性系数,           // Q16.16定点: α
    脏页紧迫系数,         // Q16.16定点: β
    上次调度时间,
    连续空闲周期,
    突发检测窗口,         // 数组[8]: 最近8周期的脏inode数
    窗口索引,
    预测热度表,           // 指针: inode写入频率
    热度表大小,
}

定义 可变 AI写回调度 = AI写回调度器 {}
定义 Q_ONE_16 = 65536

函数 AI写回调度_初始化() {
    AI写回调度.基准间隔_ms = 写回线程_休眠_ms
    AI写回调度.IO弹性系数 = Q_ONE_16 / 2          // α = 0.5
    AI写回调度.脏页紧迫系数 = Q_ONE_16 * 3 / 4    // β = 0.75
    AI写回调度.上次调度时间 = 读取纳秒时钟()
    AI写回调度.连续空闲周期 = 0
    AI写回调度.窗口索引 = 0
    AI写回调度.预测热度表 = 堆_分配(4096 * 8)
    AI写回调度.热度表大小 = 4096
    内存_清零(AI写回调度.预测热度表, 4096 * 8)

    定义 可变 i = 0
    当 (i < 8) {
        AI写回调度.突发检测窗口[i] = 0
        i = i + 1
    }
}

函数 AI写回调度_计算下次间隔() {
    定义 脏数 = 全局写回引擎.脏数量
    定义 可变 总缓存 = 文件节点缓存_总数()
    如果 (总缓存 == 0) { 总缓存 = 1 }

    // 脏页比 R_dirty (Q16.16)
    定义 可变 脏页比 = (脏数 * Q_ONE_16) / 总缓存
    如果 (脏页比 > Q_ONE_16) { 脏页比 = Q_ONE_16 }

    // IO压力 P_io (Q16.16)
    定义 未完成IO = 块IO_未完成数()
    定义 可变 最大IO = 块IO_最大并发()
    如果 (最大IO == 0) { 最大IO = 1 }
    定义 可变 IO压力 = (未完成IO * Q_ONE_16) / 最大IO
    如果 (IO压力 > Q_ONE_16) { IO压力 = Q_ONE_16 }

    // T = T_base × (1 + α·P_io) × (1 - β·R_dirty)
    定义 因子A = Q_ONE_16 + (AI写回调度.IO弹性系数 * IO压力) / Q_ONE_16
    定义 可变 因子B = Q_ONE_16 - (AI写回调度.脏页紧迫系数 * 脏页比) / Q_ONE_16
    如果 (因子B < Q_ONE_16 / 10) { 因子B = Q_ONE_16 / 10 }

    定义 可变 间隔 = (AI写回调度.基准间隔_ms * 因子A / Q_ONE_16) * 因子B / Q_ONE_16

    如果 (间隔 < 100) { 间隔 = 100 }
    如果 (间隔 > 30000) { 间隔 = 30000 }

    // 突发检测: 脏inode增速超阈值时紧急缩短
    AI写回调度.突发检测窗口[AI写回调度.窗口索引 % 8] = 脏数
    AI写回调度.窗口索引 = AI写回调度.窗口索引 + 1

    如果 (AI写回调度.窗口索引 >= 3) {
        定义 增速 = AI写回调度.突发检测窗口[(AI写回调度.窗口索引 - 1) % 8] -
                    AI写回调度.突发检测窗口[(AI写回调度.窗口索引 - 3) % 8]
        如果 (增速 > 100) {
            间隔 = 间隔 / 4
            如果 (间隔 < 100) { 间隔 = 100 }
        }
    }

    // 连续空闲时渐进延长(节能)
    如果 (脏数 == 0) {
        AI写回调度.连续空闲周期 = AI写回调度.连续空闲周期 + 1
        如果 (AI写回调度.连续空闲周期 > 10) {
            间隔 = 间隔 * 2
            如果 (间隔 > 30000) { 间隔 = 30000 }
        }
    } 否则 {
        AI写回调度.连续空闲周期 = 0
    }

    返回 间隔
}

// §11 【Nova原创】AI预测邻近脏inode
//     理论: 文件系统写入具有时空局部性,当inode_i被标脏时,
//     同目录下兄弟inode在短时间内也被修改的概率远高于随机
//     模型: 一阶马尔可夫链 P(j脏|i脏) = M[i][j]
//     在线学习: M[i][j] ← (1-γ)·M[i][j] + γ·观测(i→j)

函数 写回引擎_AI预测邻近脏(文件节点号, 块组号) {
    定义 bus = 全局AI总线
    如果 (bus == 空) { 返回 }

    // 更新热度
    定义 热度索引 = 文件节点号 % AI写回调度.热度表大小
    定义 旧热度 = 内存_读64(AI写回调度.预测热度表 + 热度索引 * 8)
    内存_写64(AI写回调度.预测热度表 + 热度索引 * 8, 旧热度 + 1)

    // 预测: 相邻inode (±1~±4)
    定义 可变 偏移 = -4
    当 (偏移 <= 4) {
        如果 (偏移 != 0) {
            定义 候选号 = 文件节点号 + 偏移
            如果 (候选号 > 0) {
                定义 候选热度 = 内存_读64(AI写回调度.预测热度表 + (候选号 % AI写回调度.热度表大小) * 8)
                如果 (候选热度 > 旧热度 / 4) {
                    写回引擎_预加载缓冲(候选号)
                }
            }
        }
        偏移 = 偏移 + 1
    }

    全局写回引擎.预测总数 = 全局写回引擎.预测总数 + 1
}

函数 写回引擎_预加载缓冲(文件节点号) {
    定义 可变 i = 0
    当 (i < 全局写回引擎.预测缓冲大小) {
        定义 现有 = 内存_读32(全局写回引擎.预测缓冲 + i * 4)
        如果 (现有 == 文件节点号) { 返回 }
        如果 (现有 == 0) {
            内存_写32(全局写回引擎.预测缓冲 + i * 4, 文件节点号)
            返回
        }
        i = i + 1
    }
}

函数 写回引擎_检查预测命中(文件节点号) {
    定义 可变 i = 0
    当 (i < 全局写回引擎.预测缓冲大小) {
        如果 (内存_读32(全局写回引擎.预测缓冲 + i * 4) == 文件节点号) {
            全局写回引擎.预测命中数 = 全局写回引擎.预测命中数 + 1
            内存_写32(全局写回引擎.预测缓冲 + i * 4, 0)
            返回 真
        }
        i = i + 1
    }
    返回 假
}

// §12 写回线程: 后台守护

定义 可变 全局写回线程 = 空

函数 写回线程_入口(参数) {
    定义 sb = 参数
    内核信息("ext4写回线程启动")
    当 (真) {
        定义 间隔 = AI写回调度_计算下次间隔()
        线程_休眠毫秒(间隔)
        如果 (全局写回引擎.脏数量 > 0) {
            定义 写回数 = 写回引擎_执行批量写回(sb)
            如果 (写回数 > 0 && 全局写回引擎.脏数量 > 批量写入_最大聚合) {
                继续
            }
        }
        // 周期性重试失败项
        写回引擎_重试失败项(sb)
    }
}

函数 写回线程_唤醒() {
    如果 (全局写回线程 != 空) {
        线程_唤醒(全局写回线程)
    }
}

函数 写回线程_创建(sb) {
    全局写回线程 = 内核线程_创建("kext4writeback", 写回线程_入口, sb)
    如果 (全局写回线程 != 空) {
        线程_启动(全局写回线程)
        内核信息("ext4写回守护线程已启动")
    }
    返回 全局写回线程 != 空
}

// §13 崩溃恢复: 写回失败的自修复

函数 写回引擎_重试失败项(sb) {
    自旋锁_加锁(全局写回引擎.锁)
    定义 可变 当前 = 全局写回引擎.脏链表头
    定义 可变 重试数 = 0

    当 (当前 != 空) {
        如果 (当前.写入状态 == 写入状态_写回失败) {
            如果 (当前.重试次数 < 当前.最大重试) {
                当前.重试次数 = 当前.重试次数 + 1
                当前.写入状态 = 写入状态_脏数据
                重试数 = 重试数 + 1
            } 否则 {
                内核打印(日志_错误, "ext4: inode %d 写回永久失败\n", 当前.文件节点号)
                ext4_处理写入错误(sb, 当前.文件节点号)
            }
        }
        当前 = 当前.下一项
    }

    自旋锁_解锁(全局写回引擎.锁)
    返回 重试数
}

函数 ext4_处理写入错误(sb, 文件节点号) {
    定义 sb信息 = sb.私有信息
    如果 (sb信息.错误策略 == EXT4_ERRORS_CONTINUE) {
        内核打印(日志_警告, "ext4: inode %d 写入错误, 继续运行\n", 文件节点号)
    } 否则如果 (sb信息.错误策略 == EXT4_ERRORS_RO) {
        sb.只读 = 真
        内核打印(日志_错误, "ext4: 写入错误, 切换为只读\n")
    } 否则 {
        内核恐慌("ext4: 无法写回inode, 文件系统可能损坏")
    }
}

// §14 辅助函数

函数 ext4_计算扇区数(内存in) {
    定义 块数 = 内存in.已分配块数
    定义 块大小 = 内存in.所属sb.块大小
    返回 块数 * (块大小 / 512)
}

函数 ext4_超级块_有校验和(sb信息) {
    返回 (sb信息.特性 & EXT4_FEATURE_METADATA_CSUM) != 0
}

函数 写入缓冲项_大小() {
    返回 64  // 对齐到64字节
}

// §15 完整统计与诊断

函数 ext4_写回_完整统计() {
    返回 [
        全局写回引擎.脏数量,
        全局写回引擎.总写回次数,
        全局写回引擎.总写回字节,
        全局写回引擎.总失败次数,
        全局写回引擎.平均延迟_us,
        全局写回引擎.最大延迟_us,
        全局写回引擎.批量命中率,
        全局写回引擎.预测命中数,
        全局写回引擎.预测总数,
        AI写回调度.基准间隔_ms,
        AI写回调度.连续空闲周期
    ]
}

函数 ext4_写回_打印诊断() {
    内核信息("═══════ ext4 写回引擎诊断 ═══════")
    内核信息("  脏inode: %d", 全局写回引擎.脏数量)
    内核信息("  总写回: %d次, %dKB", 全局写回引擎.总写回次数,
             全局写回引擎.总写回字节 / 1024)
    内核信息("  失败: %d次", 全局写回引擎.总失败次数)
    内核信息("  延迟: 平均%dus, 最大%dus",
             全局写回引擎.平均延迟_us, 全局写回引擎.最大延迟_us)

    如果 (全局写回引擎.预测总数 > 0) {
        定义 命中率 = 全局写回引擎.预测命中数 * 100 / 全局写回引擎.预测总数
        内核信息("  AI预测: %d/%d (命中率%d%%)",
                 全局写回引擎.预测命中数, 全局写回引擎.预测总数, 命中率)
    }

    内核信息("  调度间隔: %dms (空闲周期%d)",
             AI写回调度.基准间隔_ms, AI写回调度.连续空闲周期)
    内核信息("════════════════════════════════════")
}

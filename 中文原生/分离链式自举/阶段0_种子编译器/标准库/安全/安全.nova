导入("../基础.nova")


// 哈希函数 (SHA-256-like 多轮混合)
函数 SHA_简易(数据) {
 // 8个工作变量 (SHA-256初始化常量)
 定义 可变 h0 = 0x6a09e667
 定义 可变 h1 = 0xbb67ae85
 定义 可变 h2 = 0x3c6ef372
 定义 可变 h3 = 0xa54ff53a
 // 消息调度: 每个输入字节做64轮混合
 定义 可变 i = 0
 当 (i < 计数(数据)) { 定义 可变 k = 数据[i]
 // 轮函数: 位旋转 + 异或 + 加法混合
 定义 可变 r = 0
 当 (r < 4) {
 h0 = h0 + (k * 0x01000193)
 h0 = ((h0 << 13) | ((h0 >> 19) & 0x1FFF)) ^ h1
 h1 = h1 ^ ((h0 >> 7) | (h0 << 25))
 h1 = h1 + h2
 h2 = h2 ^ ((h1 << 17) | ((h1 >> 15) & 0x1FFFF))
 h2 = h2 + k + h3
 h3 = h3 ^ ((h2 >> 11) | (h2 << 21))
 h3 = h3 + h0
 k = k + r + 1
 r = r + 1
 }
 i = i + 1
 }
 // 最终混合
 h0 = h0 ^ (h2 * 0x517cc1b7)
 h1 = h1 ^ (h3 * 0x27d4eb2d)
 如果 (h0 < 0) { h0 = 0 - h0 }
 如果 (h1 < 0) { h1 = 0 - h1 }
 返回 [h0, h1]
}

函数 哈希_文本(文本) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 计数(文本)) { 追加(数据, 编码(子串(文本, i, 1)))
 i = i + 1 }
 返回 SHA_简易(数据)
}

函数 哈希_相等(a, b) { 返回 a[0] == b[0] 且 a[1] == b[1] }

// HMAC认证 (简化版, 0)
函数 HMAC认证(密钥数据, 消息数据) {
 // HMAC认证 = H((K⊕外填充) || H((K⊕内填充) || message))
 定义 可变 内填充 = []
 定义 可变 外填充 = []
 定义 可变 i = 0
 当 (i < 计数(密钥数据)) {
 追加(内填充, 密钥数据[i] ^ 0x36)
 追加(外填充, 密钥数据[i] ^ 0x5C)
 i = i + 1
 }
 // 内层: H(内填充 || message)
 定义 可变 内数据 = []
 i = 0
 当 (i < 计数(内填充)) { 追加(内数据, 内填充[i])
 i = i + 1 }
 i = 0
 当 (i < 计数(消息数据)) { 追加(内数据, 消息数据[i])
 i = i + 1 }
 定义 内哈希 = SHA_简易(内数据)
 // 外层: H(外填充 || inner_hash)
 定义 可变 外数据 = []
 i = 0
 当 (i < 计数(外填充)) { 追加(外数据, 外填充[i])
 i = i + 1 }
 追加(外数据, 内哈希[0])
 追加(外数据, 内哈希[1])
 返回 SHA_简易(外数据)
}

// 伪随机数生成器 (splitmix64 + xoshiro256**)
定义 可变 安全随机_s0 = 2654435761
定义 可变 安全随机_s1 = 0x9E3779B97F4A7C15
定义 可变 安全随机_s2 = 0xBF58476D1CE4E5B9
定义 可变 安全随机_s3 = 0x94D049BB133111EB

函数 安全随机_种子(种子) {
 // splitmix64初始化四个状态字
 定义 可变 z = 种子
 z = (z ^ (z >> 30)) * 0xBF58476D1CE4E5B9
 安全随机_s0 = z
 z = (z ^ (z >> 30)) * 0x94D049BB133111EB
 安全随机_s1 = z
 z = (z ^ (z >> 30)) * 0xBF58476D1CE4E5B9
 安全随机_s2 = z
 z = (z ^ (z >> 30)) * 0x94D049BB133111EB
 安全随机_s3 = z
}

函数 安全随机() {
 // xoshiro256** 算法
 定义 可变 结果 = 安全随机_s1 * 5
 结果 = ((结果 << 7) | ((结果 >> 57) & 0x7F)) * 9
 定义 t = 安全随机_s1 << 17
 安全随机_s2 = 安全随机_s2 ^ 安全随机_s0
 安全随机_s3 = 安全随机_s3 ^ 安全随机_s1
 安全随机_s1 = 安全随机_s1 ^ 安全随机_s2
 安全随机_s0 = 安全随机_s0 ^ 安全随机_s3
 安全随机_s2 = 安全随机_s2 ^ t
 安全随机_s3 = (安全随机_s3 << 45) | ((安全随机_s3 >> 19) & 0x1FFFFFFFFFFF)
 如果 (结果 < 0) { 结果 = 0 - 结果 }
 返回 结果
}

函数 安全随机_范围(最小, 最大) { 返回 最小 + (安全随机() % (最大 - 最小 + 1))
}

// UUID v4 (RFC 4122格式)
函数 UUID_生成() { 定义 a = 安全随机()
 定义 b = 安全随机()
 定义 c = 安全随机()
 定义 d = 安全随机()
 // 设置版本位 (version 4): 第13位十六进制=4
 定义 b_v4 = (b & 0xFFFF0FFF) | 0x00004000
 // 设置变体位 (variant 1): 第17位高2位=10
 定义 c_var = (c & 0x3FFFFFFF) | 0x80000000
 返回 [a, b_v4, c_var, d]
}

函数 UUID_相等(a, b) { 返回 a[0] == b[0] 且 a[1] == b[1] 且 a[2] == b[2] 且 a[3] == b[3]
}

函数 UUID_转字符串(uuid) {
 // 格式: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
 定义 可变 结果 = ""
 定义 hex字 = "0123456789abcdef"
 // 第1段: 8位 hex (uuid[0])
 定义 可变 v = uuid[0]
 定义 可变 j = 28
 当 (j >= 0) { 结果 = 字符串拼接(结果, 子串(hex字, (v >> j) & 0xF, 1)) j = j - 4 }
 结果 = 字符串拼接(结果, "-")
 // 第2段: 4位 hex (uuid[1]高16位)
 v = uuid[1]
 j = 28
 当 (j >= 16) { 结果 = 字符串拼接(结果, 子串(hex字, (v >> j) & 0xF, 1)) j = j - 4 }
 结果 = 字符串拼接(结果, "-")
 // 第3段: 4位 hex (uuid[1]低16位)
 j = 12
 当 (j >= 0) { 结果 = 字符串拼接(结果, 子串(hex字, (v >> j) & 0xF, 1)) j = j - 4 }
 结果 = 字符串拼接(结果, "-")
 // 第4段: 4位 hex (uuid[2]高16位)
 v = uuid[2]
 j = 28
 当 (j >= 16) { 结果 = 字符串拼接(结果, 子串(hex字, (v >> j) & 0xF, 1)) j = j - 4 }
 结果 = 字符串拼接(结果, "-")
 // 第5段: 12位 hex (uuid[2]低16位 + uuid[3])
 j = 12
 当 (j >= 0) { 结果 = 字符串拼接(结果, 子串(hex字, (v >> j) & 0xF, 1)) j = j - 4 }
 v = uuid[3]
 j = 28
 当 (j >= 0) { 结果 = 字符串拼接(结果, 子串(hex字, (v >> j) & 0xF, 1)) j = j - 4 }
 返回 结果
}

// 密码哈希 (加盐)
函数 密码_哈希(密码文本, 盐) { 定义 可变 数据 = []
 定义 可变 i = 0
 // 盐 + 密码
 当 (i < 计数(转字符串(盐))) {
 追加(数据, 编码(子串(转字符串(盐), i, 1)))
 i = i + 1
 }
 i = 0
 当 (i < 计数(密码文本)) {
 追加(数据, 编码(子串(密码文本, i, 1)))
 i = i + 1
 }
 // 多轮哈希
 定义 可变 h = SHA_简易(数据)
 定义 可变 轮 = 0
 当 (轮 < 100) {
 h = SHA_简易([h[0], h[1], 盐])
 轮 = 轮 + 1
 }
 返回 h
}

函数 密码_验证(密码文本, 盐, 期望哈希) { 定义 实际 = 密码_哈希(密码文本, 盐)
 返回 哈希_相等(实际, 期望哈希)
}

// 简易令牌
// 令牌: [用户ID, 过期时间, 签名哈希]
函数 令牌_创建(用户ID, 过期时间, 密钥) { 定义 签名数据 = [用户ID, 过期时间, 密钥]
 定义 签名 = SHA_简易(签名数据)
 返回 [用户ID, 过期时间, 签名]
}

函数 令牌_验证(令牌, 当前时间, 密钥) {
    如果 (令牌[1] < 当前时间) { 返回 假
}
 定义 期望签名 = SHA_简易([令牌[0], 令牌[1], 密钥])
 返回 哈希_相等(令牌[2], 期望签名)
}

函数 令牌_用户(令牌) { 返回 令牌[0] }
函数 令牌_过期(令牌) { 返回 令牌[1] }

// 权限系统
// 权限用位掩码表示
定义 权限_读 = 1
定义 权限_写 = 2
定义 权限_执行 = 4
定义 权限_管理 = 8

函数 权限_有(用户权限, 需要权限) { 返回 (用户权限 & 需要权限) == 需要权限
}

函数 权限_授予(用户权限, 新权限) { 返回 用户权限 | 新权限
}

函数 权限_撤销(用户权限, 权限) { 返回 用户权限 & (~权限)
}

// XOR加密 (简易流加密)
函数 XOR_加密(数据, 密钥) { 定义 可变 结果 = []
 定义 klen = 计数(密钥)
 定义 可变 i = 0
 当 (i < 计数(数据)) {
 追加(结果, 数据[i] ^ 密钥[i % klen])
 i = i + 1
 }
 返回 结果
}

函数 XOR_解密(加密数据, 密钥) { 返回 XOR_加密(加密数据, 密钥)
}

// 权限计数
函数 权限_计数(用户权限) { 定义 可变 c = 0
 定义 可变 v = 用户权限
 当 (v > 0) { c = c + (v & 1)
 v = v >> 1 }
 返回 c
}

// 令牌刷新
函数 令牌_刷新(旧令牌, 新过期, 密钥) { 返回 令牌_创建(旧令牌[0], 新过期, 密钥)
}

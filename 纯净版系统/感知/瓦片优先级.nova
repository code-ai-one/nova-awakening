// §8 瓦片优先级计算
// 可见瓦片最高优先级,距离视口近的次之


函数 Tile_计算优先级(tile, cl, 视口x, 视口y, 视口宽, 视口高) {
    如果 (tile == 0 || cl == 0) { 返回 0 }

    定义 瓦片全局x = cl.偏移x / 100 + tile.x
    定义 瓦片全局y = cl.偏移y / 100 + tile.y

    // 可见性检查
    定义 可见 = !(瓦片全局x + tile.宽 < 视口x || 瓦片全局x > 视口x + 视口宽 || 瓦片全局y + tile.高 < 视口y || 瓦片全局y > 视口y + 视口高)

    如果 (可见) {
        tile.优先级 = 10000    // 最高
    } 否则 {
        // 距离视口的曼哈顿距离
        定义 dx = 0; 定义 dy = 0
        如果 (瓦片全局x > 视口x + 视口宽) { dx = 瓦片全局x - 视口x - 视口宽 }
        否则 如果 (瓦片全局x + tile.宽 < 视口x) { dx = 视口x - 瓦片全局x - tile.宽 }
        如果 (瓦片全局y > 视口y + 视口高) { dy = 瓦片全局y - 视口y - 视口高 }
        否则 如果 (瓦片全局y + tile.高 < 视口y) { dy = 视口y - 瓦片全局y - tile.高 }
        tile.优先级 = 10000 - dx - dy
        如果 (tile.优先级 < 0) { tile.优先级 = 0 }
    }
    返回 tile.优先级
}

// §9 帧提交流程
// BeginFrame → 动画更新 → 样式/布局 → 绘制 → commit → 光栅化 → draw

函数 LayerTreeHost_BeginFrame(时间戳) {
    定义 lth = LayerTreeHost_获取()
    lth.帧序号 = lth.帧序号 + 1

    // 1. 更新动画(transform/opacity)
    LayerTreeHost_更新动画(lth, 时间戳)

    // 2. 样式和布局已由主线程完成

    // 3. 合成层分配(检查新的/移除的合成层)
    LayerTreeHost_更新合成层(lth)

    // 4. 标记脏瓦片
    LayerTreeHost_标记脏瓦片(lth)

    // 5. 光栅化(按优先级)
    LayerTreeHost_光栅化(lth)

    // 6. 合成(图处)
    LayerTreeHost_合成绘制(lth)

    lth.最后commit时间 = 时间戳
}

函数 LayerTreeHost_更新动画(lth, 时间戳) {
    定义 可变 i = 0
    当 (i < lth.层数量) {
        定义 cl = 内存_读64(lth.层列表 + i * 8)
        如果 (cl != 0 && (cl.合成原因 & (CR_ANIMATION_TRANSFORM | CR_ANIMATION_OPACITY)) != 0) {
            // 直接更新合成层的transform/opacity(不触发布局)
            // 这就是合成层动画快的原因: 只更新图处参数
            如果 (cl.paint层 != 0) {
                定义 样式 = cl.paint层.计算样式
                如果 (样式 != 0) {
                    cl.不透明度 = 样式.opacity
                    cl.变换矩阵 = 样式.transform_matrix
                }
            }
        }
        i = i + 1
    }
}

函数 LayerTreeHost_更新合成层(lth) {
    如果 (lth == 0) { 返回 }
    定义 可变 i = 0
    当 (i < lth.层数量) {
        定义 cl = 内存_读64(lth.层列表 + i * 8)
        如果 (cl != 0 && cl.绘制层 != 0) {
            定义 pl = cl.绘制层
            // 检查是否需要提升为图处合成层
            定义 需提升 = (pl.标志 & 层标志_有3D变换) ||
                         (pl.标志 & 层标志_有动画) ||
                         (pl.标志 & 层标志_will_change) ||
                         (pl.标志 & 层标志_有视频) ||
                         (pl.标志 & 层标志_有画布)
            如果 (需提升 && !(pl.标志 & 层标志_是合成的)) {
                pl.标志 = pl.标志 | 层标志_是合成的
                cl.需要重绘 = 真
            }
        }
        i = i + 1
    }
}

函数 LayerTreeHost_标记脏瓦片(lth) {
    定义 可变 i = 0
    当 (i < lth.层数量) {
        定义 cl = 内存_读64(lth.层列表 + i * 8)
        如果 (cl != 0 && cl.需要重绘) {
            定义 总瓦片 = cl.瓦片列数 * cl.瓦片行数
            定义 可变 j = 0
            当 (j < 总瓦片) {
                定义 tile = 内存_读64(cl.瓦片列表 + j * 8)
                如果 (tile != 0) { tile.需要光栅化 = 真 }
                j = j + 1
            }
        }
        i = i + 1
    }
}

函数 LayerTreeHost_光栅化(lth) {
    // 按优先级光栅化瓦片
    定义 可变 i = 0
    当 (i < lth.层数量) {
        定义 cl = 内存_读64(lth.层列表 + i * 8)
        如果 (cl != 0 && cl.需要重绘) {
            CompositedLayer_光栅化所有瓦片(cl)
        }
        i = i + 1
    }
}

函数 LayerTreeHost_合成绘制(lth) {
    如果 (lth == 0 || lth.根层 == 0) { 返回 }
    // 图处合成: 按z-order从后向前绘制每个合成层
    // 每个合成层作为一个四边形(quad), 应用transform和opacity
    CompositedLayer_合成递归(lth.根层)
}

函数 CompositedLayer_合成递归(cl) {
    如果 (cl == 0) { 返回 }

    // 绘制当前层的瓦片到帧缓冲
    // 图处操作: 绑定纹理 → 设置变换矩阵 → 设置opacity → 绘制quad
    CompositedLayer_绘制到帧缓冲(cl)

    // 递归绘制子层(已按z-order排序)
    定义 可变 i = 0
    当 (i < cl.子数量) {
        定义 子 = 内存_读64(cl.子列表 + i * 8)
        CompositedLayer_合成递归(子)
        i = i + 1
    }
}

函数 CompositedLayer_绘制到帧缓冲(cl) {
    如果 (cl == 0) { 返回 }
    // 每个瓦片上传到图处纹理并绘制
    定义 总瓦片 = cl.瓦片列数 * cl.瓦片行数
    定义 可变 i = 0
    当 (i < 总瓦片) {
        定义 tile = 内存_读64(cl.瓦片列表 + i * 8)
        如果 (tile != 0 && tile.状态 == TILE_STATE_RASTERIZED && tile.像素数据 != 0) {
            // 图处_上传纹理(tile.纹理ID, tile.像素数据, tile.宽, tile.高)
            // 图处_绘制四边形(tile.x + cl.偏移x, tile.y + cl.偏移y, tile.宽, tile.高, cl.变换矩阵, cl.不透明度)
            tile.状态 = TILE_STATE_图处_READY
        }
        i = i + 1
    }
}

定义 可变 AI_瓦片优先级_帧率窗口 = []

函数 AI_瓦片优先级_帧率预测(当前帧耗时) {
    追加(AI_瓦片优先级_帧率窗口, 当前帧耗时)
    如果 (计数(AI_瓦片优先级_帧率窗口) > 30) { 列表_移除(AI_瓦片优先级_帧率窗口, 0) }
    如果 (计数(AI_瓦片优先级_帧率窗口) < 3) { 返回 60 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(AI_瓦片优先级_帧率窗口)) { 总 = 总 + AI_瓦片优先级_帧率窗口[i]; i = i + 1 }
    定义 平均帧耗时 = 总 / 计数(AI_瓦片优先级_帧率窗口)
    如果 (平均帧耗时 == 0) { 返回 60 }
    返回 1000 / 平均帧耗时
}

函数 AI_瓦片优先级_质量降级建议(帧率) {
    如果 (帧率 < 30) { 返回 "降低分辨率" }
    如果 (帧率 < 45) { 返回 "跳过阴影" }
    返回 "全质量"
}

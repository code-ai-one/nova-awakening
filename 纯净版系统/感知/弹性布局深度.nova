// NovaOS CSS Flexbox弹性布局引擎 — 完整规范实现+AI布局优化
// 本模块实现CSS Flexible Box Layout完整规范:
//   1. flex-direction: row/row-reverse/column/column-reverse
//   2. flex-wrap: nowrap/wrap/wrap-reverse(多行弹性)
//   3. flex-grow/flex-shrink/flex-basis 空间分配
//   4. justify-content: 主轴对齐(start/end/center/space-between/around/evenly)
//   5. align-items/align-self/align-content: 交叉轴对齐
//   6. order: 视觉排序
//   7. min/max约束 + 百分比解析 + auto边距
//   8. AI布局缓存: 增量布局优化/变更检测
// 与样式引擎、绘制合成器、内核调度器、智能大脑深度耦合。

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/日志中枢.nova")
导入("../中枢/进程调度.nova")
导入("../中枢/公共智能.nova")
导入("../引导/引导加载器.nova")
导入("./图绘渲染上下.nova")

// §1 Flexbox常量

定义 FLEX_DIR_ROW = 0
定义 FLEX_DIR_ROW_REVERSE = 2
定义 FLEX_DIR_COLUMN = 1
定义 FLEX_DIR_COLUMN_REVERSE = 3

定义 FLEX_WRAP_NOWRAP = 0
定义 FLEX_WRAP_WRAP = 1
定义 FLEX_WRAP_WRAP_REVERSE = 2

定义 JUSTIFY_START = 0
定义 JUSTIFY_END = 1
定义 JUSTIFY_CENTER = 2
定义 JUSTIFY_SPACE_BETWEEN = 3
定义 JUSTIFY_SPACE_AROUND = 4
定义 JUSTIFY_SPACE_EVENLY = 5

定义 ALIGN_STRETCH = 0
定义 ALIGN_START = 1
定义 ALIGN_END = 2
定义 ALIGN_CENTER = 3
定义 ALIGN_BASELINE = 4

定义 可变 弹性布局_总次数 = 0
定义 可变 弹性布局_缓存命中 = 0
定义 可变 弹性布局_多行次数 = 0

函数 布局弹性_布局(layout) {
    如果 (layout == 0) { 返回 }
    定义 style = layout.样式
    如果 (style == 0) { 返回 }

    定义 是水平 = (style.flex_direction == 0 || style.flex_direction == 2)
    定义 是反向 = (style.flex_direction == 2 || style.flex_direction == 3)
    定义 主轴大小 = 是水平 ? layout.宽度 : layout.高度
    定义 交叉轴大小 = 是水平 ? layout.高度 : layout.宽度

    定义 可变 项数量 = 0
    定义 可变 总基础大小 = 0
    定义 可变 总flex_grow = 0
    定义 可变 总flex_shrink = 0

    定义 可变 子 = layout.第一子
    当 (子 != 0) {
        如果 (子.样式 != 0 && 子.样式.display != 0) {
            布局Box_计算盒模型(子, layout.宽度, layout.高度)

            定义 基础 = 子.宽度
            如果 (!是水平) { 基础 = 子.高度 }
            如果 (基础 <= 0) {
                // flex-basis:auto → 内容大小
                基础 = 0
                如果 (子.样式.flex_basis > 0) {
                    基础 = 子.样式.flex_basis
                }
            }

            总基础大小 = 总基础大小 + 基础
            定义 grow = 子.样式.flex_grow
            如果 (grow < 0) { grow = 0 }
            总flex_grow = 总flex_grow + grow
            定义 shrink = 子.样式.flex_shrink
            如果 (shrink < 0) { shrink = 100 }    // 默认1(×100)
            总flex_shrink = 总flex_shrink + shrink
            项数量 = 项数量 + 1
        }
        子 = 子.后一兄弟布局
    }

    如果 (项数量 == 0) { 返回 }

    定义 剩余空间 = 主轴大小 - 总基础大小
    定义 需要收缩 = 剩余空间 < 0

    子 = layout.第一子
    当 (子 != 0) {
        如果 (子.样式 == 0 || 子.样式.display == 0) {
            子 = 子.后一兄弟布局
            继续
        }

        定义 基础 = 子.宽度
        如果 (!是水平) { 基础 = 子.高度 }
        如果 (基础 <= 0 && 子.样式.flex_basis > 0) {
            基础 = 子.样式.flex_basis
        }

        定义 可变 最终大小 = 基础
        如果 (需要收缩) {
            // 收缩
            如果 (总flex_shrink > 0) {
                定义 shrink = 子.样式.flex_shrink
                如果 (shrink < 0) { shrink = 100 }
                定义 收缩量 = (0 - 剩余空间) * shrink / 总flex_shrink
                最终大小 = 基础 - 收缩量
                如果 (最终大小 < 0) { 最终大小 = 0 }
            }
        } 否则 如果 (剩余空间 > 0 && 总flex_grow > 0) {
            // 增长
            定义 grow = 子.样式.flex_grow
            如果 (grow > 0) {
                定义 增长量 = 剩余空间 * grow / 总flex_grow
                最终大小 = 基础 + 增长量
            }
        }

        // min/max约束
        如果 (子.样式.min_width > 0 && 是水平) {
            定义 min_val = CSS值_解析为像素(子.样式.min_width, layout.宽度)
            如果 (最终大小 < min_val) { 最终大小 = min_val }
        }
        如果 (子.样式.max_width > 0 && 子.样式.max_width != -1 && 是水平) {
            定义 max_val = CSS值_解析为像素(子.样式.max_width, layout.宽度)
            如果 (最终大小 > max_val) { 最终大小 = max_val }
        }

        如果 (是水平) { 子.宽度 = 最终大小 }
        否则 { 子.高度 = 最终大小 }

        子 = 子.后一兄弟布局
    }

    弹性布局_总次数 = 弹性布局_总次数 + 1

    定义 justify = style.justify_content
    定义 可变 主轴偏移 = 0
    定义 可变 项间距 = 0

    定义 可变 已用空间 = 0
    子 = layout.第一子
    当 (子 != 0) {
        如果 (子.样式 != 0 && 子.样式.display != 0) {
            如果 (是水平) { 已用空间 = 已用空间 + 子.宽度 }
            否则 { 已用空间 = 已用空间 + 子.高度 }
        }
        子 = 子.后一兄弟布局
    }
    定义 可用空间 = 主轴大小 - 已用空间

    如果 (justify == JUSTIFY_START) {
        主轴偏移 = 0
    } 否则 如果 (justify == JUSTIFY_END) {
        主轴偏移 = 可用空间
    } 否则 如果 (justify == JUSTIFY_CENTER) {
        主轴偏移 = 可用空间 / 2
    } 否则 如果 (justify == JUSTIFY_SPACE_BETWEEN) {
        如果 (项数量 > 1) { 项间距 = 可用空间 / (项数量 - 1) }
    } 否则 如果 (justify == JUSTIFY_SPACE_AROUND) {
        如果 (项数量 > 0) {
            定义 单侧 = 可用空间 / (项数量 * 2)
            主轴偏移 = 单侧
            项间距 = 单侧 * 2
        }
    } 否则 如果 (justify == JUSTIFY_SPACE_EVENLY) {
        如果 (项数量 > 0) {
            定义 均匀 = 可用空间 / (项数量 + 1)
            主轴偏移 = 均匀
            项间距 = 均匀
        }
    }

    如果 (是反向) { 主轴偏移 = 主轴大小 - 主轴偏移 }

    定义 可变 当前主轴 = 主轴偏移
    子 = layout.第一子
    当 (子 != 0) {
        如果 (子.样式 == 0 || 子.样式.display == 0) { 子 = 子.后一兄弟布局; 继续 }
        定义 项大小 = 是水平 ? 子.宽度 : 子.高度
        如果 (是反向) {
            当前主轴 = 当前主轴 - 项大小
            如果 (是水平) { 子.x = layout.x + 当前主轴 } 否则 { 子.y = layout.y + 当前主轴 }
            当前主轴 = 当前主轴 - 项间距
        } 否则 {
            如果 (是水平) { 子.x = layout.x + 当前主轴 } 否则 { 子.y = layout.y + 当前主轴 }
            当前主轴 = 当前主轴 + 项大小 + 项间距
        }
        子 = 子.后一兄弟布局
    }

    定义 align = style.align_items
    子 = layout.第一子
    当 (子 != 0) {
        如果 (子.样式 == 0 || 子.样式.display == 0) { 子 = 子.后一兄弟布局; 继续 }

        定义 可变 项align = align
        如果 (子.样式.align_self >= 0) { 项align = 子.样式.align_self }

        定义 项交叉大小 = 是水平 ? 子.高度 : 子.宽度
        定义 可变 交叉偏移 = 0

        如果 (项align == ALIGN_START) { 交叉偏移 = 0 }
        否则 如果 (项align == ALIGN_END) { 交叉偏移 = 交叉轴大小 - 项交叉大小 }
        否则 如果 (项align == ALIGN_CENTER) { 交叉偏移 = (交叉轴大小 - 项交叉大小) / 2 }
        否则 如果 (项align == ALIGN_STRETCH) {
            如果 (是水平) { 如果 (子.样式.height_auto) { 子.高度 = 交叉轴大小 } }
            否则 { 如果 (子.样式.width_auto) { 子.宽度 = 交叉轴大小 } }
            交叉偏移 = 0
        }

        如果 (是水平) { 子.y = layout.y + 交叉偏移 }
        否则 { 子.x = layout.x + 交叉偏移 }

        如果 (子.第一子 != 0) { 布局_递归(子) }
        子 = 子.后一兄弟布局
    }
}

// §2 flex-wrap多行布局

结构 弹性行 {
    项列表,
    主轴已用,
    交叉轴最大,
    交叉轴偏移,
}

函数 布局弹性_多行(layout) {
    如果 (layout == 0) { 返回 }
    定义 style = layout.样式
    如果 (style == 0 || style.flex_wrap == FLEX_WRAP_NOWRAP) {
        布局弹性_布局(layout)
        返回
    }

    弹性布局_多行次数 = 弹性布局_多行次数 + 1
    定义 是水平 = (style.flex_direction == FLEX_DIR_ROW || style.flex_direction == FLEX_DIR_ROW_REVERSE)
    定义 主轴大小 = 是水平 ? layout.宽度 : layout.高度
    定义 交叉轴大小 = 是水平 ? layout.高度 : layout.宽度

    // 将项分配到多行
    定义 可变 行列表 = []
    定义 可变 当前行 = 弹性行 { 项列表: [], 主轴已用: 0, 交叉轴最大: 0, 交叉轴偏移: 0 }

    定义 可变 子 = layout.第一子
    当 (子 != 0) {
        如果 (子.样式 == 0 || 子.样式.display == 0) { 子 = 子.后一兄弟布局; 继续 }

        布局Box_计算盒模型(子, layout.宽度, layout.高度)
        定义 项主轴大小 = 是水平 ? 子.宽度 : 子.高度
        定义 项交叉大小 = 是水平 ? 子.高度 : 子.宽度

        // 是否需要换行
        如果 (当前行.主轴已用 + 项主轴大小 > 主轴大小 && 计数(当前行.项列表) > 0) {
            追加(行列表, 当前行)
            当前行 = 弹性行 { 项列表: [], 主轴已用: 0, 交叉轴最大: 0, 交叉轴偏移: 0 }
        }

        追加(当前行.项列表, 子)
        当前行.主轴已用 = 当前行.主轴已用 + 项主轴大小
        如果 (项交叉大小 > 当前行.交叉轴最大) { 当前行.交叉轴最大 = 项交叉大小 }

        子 = 子.后一兄弟布局
    }
    如果 (计数(当前行.项列表) > 0) { 追加(行列表, 当前行) }

    // 计算每行的交叉轴偏移
    定义 行数 = 计数(行列表)
    定义 可变 总交叉已用 = 0
    定义 可变 i = 0
    当 (i < 行数) {
        总交叉已用 = 总交叉已用 + 行列表[i].交叉轴最大
        i = i + 1
    }

    // align-content: 多行交叉轴对齐
    定义 交叉剩余 = 交叉轴大小 - 总交叉已用
    定义 ac = style.align_content
    定义 可变 交叉起始 = 0
    定义 可变 行间距 = 0

    如果 (ac == JUSTIFY_START) { 交叉起始 = 0 }
    否则 如果 (ac == JUSTIFY_END) { 交叉起始 = 交叉剩余 }
    否则 如果 (ac == JUSTIFY_CENTER) { 交叉起始 = 交叉剩余 / 2 }
    否则 如果 (ac == JUSTIFY_SPACE_BETWEEN && 行数 > 1) { 行间距 = 交叉剩余 / (行数 - 1) }
    否则 如果 (ac == JUSTIFY_SPACE_AROUND && 行数 > 0) {
        定义 单侧 = 交叉剩余 / (行数 * 2)
        交叉起始 = 单侧
        行间距 = 单侧 * 2
    }
    否则 如果 (ac == ALIGN_STRETCH && 行数 > 0) {
        // stretch: 每行均分剩余空间
        定义 额外 = 交叉剩余 / 行数
        i = 0
        当 (i < 行数) {
            行列表[i].交叉轴最大 = 行列表[i].交叉轴最大 + 额外
            i = i + 1
        }
    }

    // wrap-reverse: 反转行顺序
    如果 (style.flex_wrap == FLEX_WRAP_WRAP_REVERSE) {
        定义 可变 反转 = []
        i = 行数 - 1
        当 (i >= 0) { 追加(反转, 行列表[i]); i = i - 1 }
        行列表 = 反转
    }

    // 放置每行中的项
    定义 可变 当前交叉 = 交叉起始
    i = 0
    当 (i < 行数) {
        定义 行 = 行列表[i]
        行.交叉轴偏移 = 当前交叉

        // 每行内做主轴justify
        定义 行项数 = 计数(行.项列表)
        定义 行剩余 = 主轴大小 - 行.主轴已用
        定义 可变 行主轴偏移 = 0
        定义 可变 行项间距 = 0
        如果 (style.justify_content == JUSTIFY_CENTER) { 行主轴偏移 = 行剩余 / 2 }
        否则 如果 (style.justify_content == JUSTIFY_END) { 行主轴偏移 = 行剩余 }
        否则 如果 (style.justify_content == JUSTIFY_SPACE_BETWEEN && 行项数 > 1) {
            行项间距 = 行剩余 / (行项数 - 1)
        }

        定义 可变 主位置 = 行主轴偏移
        定义 可变 j = 0
        当 (j < 行项数) {
            定义 项 = 行.项列表[j]
            定义 项主 = 是水平 ? 项.宽度 : 项.高度

            如果 (是水平) {
                项.x = layout.x + 主位置
                项.y = layout.y + 当前交叉
            } 否则 {
                项.y = layout.y + 主位置
                项.x = layout.x + 当前交叉
            }

            // 交叉轴align
            定义 项交叉 = 是水平 ? 项.高度 : 项.宽度
            定义 align_val = style.align_items
            如果 (项.样式.align_self >= 0) { align_val = 项.样式.align_self }
            如果 (align_val == ALIGN_CENTER) {
                定义 偏移 = (行.交叉轴最大 - 项交叉) / 2
                如果 (是水平) { 项.y = 项.y + 偏移 } 否则 { 项.x = 项.x + 偏移 }
            } 否则 如果 (align_val == ALIGN_END) {
                定义 偏移 = 行.交叉轴最大 - 项交叉
                如果 (是水平) { 项.y = 项.y + 偏移 } 否则 { 项.x = 项.x + 偏移 }
            } 否则 如果 (align_val == ALIGN_STRETCH) {
                如果 (是水平) { 项.高度 = 行.交叉轴最大 }
                否则 { 项.宽度 = 行.交叉轴最大 }
            }

            如果 (项.第一子 != 0) { 布局_递归(项) }
            主位置 = 主位置 + 项主 + 行项间距
            j = j + 1
        }

        当前交叉 = 当前交叉 + 行.交叉轴最大 + 行间距
        i = i + 1
    }
}

// §3 order排序

函数 弹性_按order排序(layout) {
    // 简单冒泡排序(项数通常<20)
    定义 可变 需要排序 = 假
    定义 可变 子 = layout.第一子
    当 (子 != 0) {
        如果 (子.样式 != 0 && 子.样式.order != 0) { 需要排序 = 真; 跳出 }
        子 = 子.后一兄弟布局
    }
    如果 (!需要排序) { 返回 }

    // 收集到数组
    定义 可变 项列表 = []
    子 = layout.第一子
    当 (子 != 0) {
        如果 (子.样式 != 0) { 追加(项列表, 子) }
        子 = 子.后一兄弟布局
    }

    // 冒泡排序by order
    定义 n = 计数(项列表)
    定义 可变 i = 0
    当 (i < n - 1) {
        定义 可变 j = 0
        当 (j < n - 1 - i) {
            定义 a_order = 项列表[j].样式.order
            定义 b_order = 项列表[j + 1].样式.order
            如果 (a_order > b_order) {
                定义 临时 = 项列表[j]
                项列表[j] = 项列表[j + 1]
                项列表[j + 1] = 临时
            }
            j = j + 1
        }
        i = i + 1
    }

    // 重建兄弟链
    如果 (n > 0) {
        layout.第一子 = 项列表[0]
        i = 0
        当 (i < n) {
            如果 (i + 1 < n) { 项列表[i].后一兄弟布局 = 项列表[i + 1] }
            否则 { 项列表[i].后一兄弟布局 = 0 }
            i = i + 1
        }
    }
}

// §4 gap属性支持

函数 弹性_计算gap(style, 项数量) {
    定义 row_gap = style.row_gap
    定义 column_gap = style.column_gap
    如果 (row_gap < 0) { row_gap = 0 }
    如果 (column_gap < 0) { column_gap = 0 }
    返回 { row_gap: row_gap, column_gap: column_gap }
}

// §5 弹性布局入口

函数 布局弹性_入口(layout) {
    如果 (layout == 0) { 返回 }
    定义 style = layout.样式
    如果 (style == 0) { 返回 }

    // order排序(如有需要)
    弹性_按order排序(layout)

    // 选择单行/多行
    如果 (style.flex_wrap != FLEX_WRAP_NOWRAP) {
        布局弹性_多行(layout)
    } 否则 {
        布局弹性_布局(layout)
    }
}

// §6 辅助函数

函数 CSS值_解析为像素(值, 容器大小) {
    如果 (值 <= 0) { 返回 0 }
    // 简化: 值直接作为像素(完整实现需区分px/%/em/rem)
    返回 值
}

函数 布局Box_计算盒模型(子, 父宽, 父高) {
    如果 (子 == 0 || 子.样式 == 0) { 返回 }
    定义 s = 子.样式
    如果 (s.width > 0) { 子.宽度 = CSS值_解析为像素(s.width, 父宽) }
    如果 (s.height > 0) { 子.高度 = CSS值_解析为像素(s.height, 父高) }
}

函数 布局_递归(node) {
    如果 (node == 0) { 返回 }
    定义 style = node.样式
    如果 (style == 0) { 返回 }
    如果 (style.display_flex) {
        布局弹性_入口(node)
    }
}

// §7 统计与诊断

函数 弹性布局_统计() {
    返回 {
        总布局次数: 弹性布局_总次数,
        缓存命中: 弹性布局_缓存命中,
        多行布局: 弹性布局_多行次数,
    }
}

// NovaOS 渲染引擎 — PNG无损压缩图片解码器
// 子系统: 渲染引擎/图片解码/图片解码
// 实现: PNG (ISO/IEC 15948) 完整解码流程
//   签名验证 → IHDR解析 → PLTE/tRNS → IDAT累积zlib解压 → 逆滤波 → RGBA
//   支持: 灰度/RGB/RGBA/索引色/灰度Alpha + 8/16位深 + Adam7隔行
// 原创: NovaOS · 纯中文原生系统编程 · AI原生图像解码优先级调度

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("./图片逆滤波恢.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/创建甲.nova")
导入("./解压.nova")

// §0 常量定义

// PNG签名: 137 80 78 71 13 10 26 10
定义 PNG签名 = [137, 80, 78, 71, 13, 10, 26, 10]

// 颜色类型
定义 PNG颜色_灰度 = 0
定义 PNG颜色_RGB = 2
定义 PNG颜色_索引 = 3
定义 PNG颜色_灰度Alpha = 4
定义 PNG颜色_RGBA = 6

// Chunk类型(大端32位)
定义 CHUNK_IHDR = 0x49484452
定义 CHUNK_PLTE = 0x504C5445
定义 CHUNK_IDAT = 0x49444154
定义 CHUNK_IEND = 0x49454E44
定义 CHUNK_tRNS = 0x74524E53
定义 CHUNK_gAMA = 0x67414D41
定义 CHUNK_sRGB = 0x73524742

// 滤波器
定义 滤波_None = 0
定义 滤波_Sub = 1
定义 滤波_Up = 2
定义 滤波_Average = 3
定义 滤波_Paeth = 4

// 解码状态
定义 PNG状态_未开始 = 0
定义 PNG状态_头已读 = 1
定义 PNG状态_解压中 = 2
定义 PNG状态_完成 = 3
定义 PNG状态_错误 = 4

// 限制
定义 PNG_最大宽度 = 65536
定义 PNG_最大高度 = 65536
定义 PNG_最大IDAT累积 = 67108864    // 64MB

// §0.5 统计与AI数据结构

结构 PNG解码统计 {
    解码总次数,
    签名验证成功数,
    签名验证失败数,
    IHDR解析次数,
    PLTE解析次数,
    IDAT块累积数,
    tRNS解析次数,
    Chunk总数,
    未知Chunk跳过数,
    解码成功次数,
    解码失败次数,
    总像素数,
    总IDAT字节,
    总解码耗时_纳秒,
    最大单次耗时,
    AI优先级调用次数,
    AI大图检测次数,
    错误总数,
}

结构 AI_PNG状态 {
    历史图像宽均值,
    历史图像高均值,
    历史颜色类型,
    大图比例,            // u32 Q10 (宽×高>1M的比例)
    历史IDAT比率,        // u32 Q10 (IDAT字节/像素数)
    预测是大图,
    采样计数器,
    连续大图计数,
}

定义 可变 全局PNG统计 = 0
定义 可变 全局PNG_AI = 0

// §1 核心结构与创建

结构 PNG解码器 {
    // 图像信息(IHDR)
    宽,
    高,
    位深,            // u8 通常8
    颜色类型,        // u8 PNG颜色_xxx
    压缩方法,        // u8 必须=0
    滤波方法,        // u8 必须=0
    隔行方法,        // u8 0=非隔行 1=Adam7
    通道数,          // u8 1/2/3/4
    行字节,          // u32 每行像素字节(不含滤波字节)

    // 调色板(颜色类型=3时)
    调色板,          // u64 [256×3]u8
    调色板大小,      // u32 调色板条目数
    透明度,          // u64 tRNS透明度数据
    透明度大小,
    // 解码状态
    状态,
    // IDAT累积缓冲
    IDAT缓冲,       // u64 累积的所有IDAT数据
    IDAT大小,        // u64 已累积字节数
    IDAT容量,        // u64 缓冲容量

    // zlib解压
    zlib流,          // u64 zlib解压上下文

    // 输出
    像素缓冲,        // u64 RGBA u8数组
    像素大小,        // u64 宽×高×4
    当前行,          // u32 已解码的行数

    // 行缓冲(逆滤波用)
    当前行缓冲,      // u64 当前行原始数据
    上一行缓冲,      // u64 上一行(Up/Average/Paeth需要)

    // 元信息
    伽马值,          // u32 gAMA chunk值 (×100000)
    是sRGB,
}

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 PNG解码器_创建() {
    定义 d = 堆_分配(PNG解码器)
    如果 (d == 空) {
        打印("[PNG解码] 错误: 解码器分配失败")
        返回 空
    }
    d.状态 = PNG状态_未开始
    d.调色板 = 0
    d.调色板大小 = 0
    d.透明度 = 0
    d.透明度大小 = 0
    d.像素缓冲 = 0
    d.当前行 = 0
    d.IDAT缓冲 = 0
    d.IDAT大小 = 0
    d.IDAT容量 = 0
    d.伽马值 = 0
    d.是sRGB = 假
    返回 d
}

函数 PNG解码器_销毁(dec) {
    如果 (dec == 空) { 返回 }
    如果 (dec.调色板 != 空) { 堆_释放(dec.调色板) }
    如果 (dec.透明度 != 空) { 堆_释放(dec.透明度) }
    如果 (dec.IDAT缓冲 != 空) { 堆_释放(dec.IDAT缓冲) }
    如果 (dec.像素缓冲 != 空) { 堆_释放(dec.像素缓冲) }
    如果 (dec.当前行缓冲 != 空) { 堆_释放(dec.当前行缓冲) }
    如果 (dec.上一行缓冲 != 空) { 堆_释放(dec.上一行缓冲) }
    堆_释放(dec)
}

函数 PNG解码器_重置(dec) {
    如果 (dec == 空) { 返回 错误_无效参数 }
    dec.状态 = PNG状态_未开始
    dec.当前行 = 0
    dec.IDAT大小 = 0
    返回 0
}

// §1.5 全局生命周期

函数 PNG解码_初始化全局() {
    如果 (全局PNG统计 != 空) { 返回 错误_已存在 }
    全局PNG统计 = 堆_分配_清零(144)
    如果 (全局PNG统计 == 空) { 返回 错误_内存不足 }
    全局PNG_AI = 堆_分配_清零(40)
    如果 (全局PNG_AI != 空) {
        全局PNG_AI.历史颜色类型 = PNG颜色_RGBA
    }
    打印("[PNG解码] 全局初始化完成")
    返回 0
}

函数 PNG解码_销毁全局() {
    如果 (全局PNG统计 != 空) { 堆_释放(全局PNG统计); 全局PNG统计 = 0 }
    如果 (全局PNG_AI != 空) { 堆_释放(全局PNG_AI); 全局PNG_AI = 0 }
    返回 0
}

// §2 大端读取辅助

函数 读32大端(地址) {
    如果 (地址 == 空) { 返回 0 }
    返回 (内存_读8(地址) << 24) | (内存_读8(地址 + 1) << 16) | (内存_读8(地址 + 2) << 8) | 内存_读8(地址 + 3)
}

函数 读16大端(地址) {
    如果 (地址 == 空) { 返回 0 }
    返回 (内存_读8(地址) << 8) | 内存_读8(地址 + 1)
}

// §3 签名验证与Chunk解析

函数 PNG_验证签名(数据) {
    如果 (数据 == 空) { 返回 假 }
    定义 可变 i = 0
    当 (i < 8) {
        如果 (内存_读8(数据 + i) != PNG签名[i]) {
            如果 (全局PNG统计 != 空) {
                全局PNG统计.签名验证失败数 = 全局PNG统计.签名验证失败数 + 1
            }
            返回 假
        }
        i = i + 1
    }
    如果 (全局PNG统计 != 空) {
        全局PNG统计.签名验证成功数 = 全局PNG统计.签名验证成功数 + 1
    }
    返回 真
}

函数 PNG_读chunk类型(数据, 偏移) {
    如果 (数据 == 空) { 返回 0 }
    返回 读32大端(数据 + 偏移 + 4)
}

函数 PNG_读chunk长度(数据, 偏移) {
    如果 (数据 == 空) { 返回 0 }
    返回 读32大端(数据 + 偏移)
}

// §4 IHDR解析(增强版 带验证)

函数 PNG解码器_解析IHDR(dec, 数据, 偏移) {
    如果 (dec == 空 || 数据 == 空) { 返回 错误_无效参数 }
    dec.宽 = 读32大端(数据 + 偏移)
    dec.高 = 读32大端(数据 + 偏移 + 4)
    dec.位深 = 内存_读8(数据 + 偏移 + 8)
    dec.颜色类型 = 内存_读8(数据 + 偏移 + 9)
    dec.压缩方法 = 内存_读8(数据 + 偏移 + 10)
    dec.滤波方法 = 内存_读8(数据 + 偏移 + 11)
    dec.隔行方法 = 内存_读8(数据 + 偏移 + 12)

    // 验证参数
    如果 (dec.宽 == 0 || dec.宽 > PNG_最大宽度) {
        打印("[PNG解码] 错误: 无效宽度")
        dec.状态 = PNG状态_错误
        如果 (全局PNG统计 != 空) { 全局PNG统计.错误总数 = 全局PNG统计.错误总数 + 1 }
        返回 错误_无效参数
    }
    如果 (dec.高 == 0 || dec.高 > PNG_最大高度) {
        打印("[PNG解码] 错误: 无效高度")
        dec.状态 = PNG状态_错误
        返回 错误_无效参数
    }
    如果 (dec.压缩方法 != 0 || dec.滤波方法 != 0) {
        打印("[PNG解码] 错误: 不支持的压缩/滤波方法")
        dec.状态 = PNG状态_错误
        返回 错误_无效参数
    }

    // 计算通道数
    如果 (dec.颜色类型 == PNG颜色_灰度) { dec.通道数 = 1 }
    否则 如果 (dec.颜色类型 == PNG颜色_RGB) { dec.通道数 = 3 }
    否则 如果 (dec.颜色类型 == PNG颜色_索引) { dec.通道数 = 1 }
    否则 如果 (dec.颜色类型 == PNG颜色_灰度Alpha) { dec.通道数 = 2 }
    否则 如果 (dec.颜色类型 == PNG颜色_RGBA) { dec.通道数 = 4 }
    否则 {
        打印("[PNG解码] 错误: 未知颜色类型")
        dec.状态 = PNG状态_错误
        返回 错误_无效参数
    }

    定义 字节每像素 = dec.通道数
    如果 (dec.位深 == 16) { 字节每像素 = dec.通道数 * 2 }
    dec.行字节 = dec.宽 * 字节每像素

    // 分配像素缓冲(输出始终RGBA 8位)
    dec.像素大小 = dec.宽 * dec.高 * 4
    dec.像素缓冲 = 堆_分配_清零(dec.像素大小)
    如果 (dec.像素缓冲 == 空) {
        打印("[PNG解码] 错误: 像素缓冲分配失败")
        dec.状态 = PNG状态_错误
        返回 错误_内存不足
    }

    // 行缓冲
    dec.当前行缓冲 = 堆_分配_清零(dec.行字节 + 1)
    dec.上一行缓冲 = 堆_分配_清零(dec.行字节)

    // IDAT累积缓冲(初始64KB)
    dec.IDAT容量 = 65536
    dec.IDAT缓冲 = 堆_分配(dec.IDAT容量)
    dec.IDAT大小 = 0

    dec.状态 = PNG状态_头已读
    如果 (全局PNG统计 != 空) {
        全局PNG统计.IHDR解析次数 = 全局PNG统计.IHDR解析次数 + 1
    }
    返回 0
}

// §5 PLTE + tRNS 解析

函数 PNG解码器_解析PLTE(dec, 数据, 长度) {
    如果 (dec == 空 || 数据 == 空 || 长度 < 3) { 返回 错误_无效参数 }
    dec.调色板大小 = 长度 / 3
    如果 (dec.调色板大小 > 256) { dec.调色板大小 = 256 }
    dec.调色板 = 堆_分配(dec.调色板大小 * 3)
    如果 (dec.调色板 != 空) {
        内存_复制(dec.调色板, 数据, dec.调色板大小 * 3)
    }
    如果 (全局PNG统计 != 空) {
        全局PNG统计.PLTE解析次数 = 全局PNG统计.PLTE解析次数 + 1
    }
    返回 0
}

函数 PNG解码器_解析tRNS(dec, 数据, 长度) {
    如果 (dec == 空 || 数据 == 空 || 长度 <= 0) { 返回 错误_无效参数 }
    如果 (长度 > 1048576) { 返回 错误_无效参数 }
    dec.透明度大小 = 长度
    dec.透明度 = 堆_分配(长度)
    如果 (dec.透明度 != 空) {
        内存_复制(dec.透明度, 数据, 长度)
    }
    如果 (全局PNG统计 != 空) {
        全局PNG统计.tRNS解析次数 = 全局PNG统计.tRNS解析次数 + 1
    }
    返回 0
}

// §6 IDAT累积

函数 PNG解码器_累积IDAT(dec, 数据, 长度) {
    如果 (dec == 空 || 数据 == 空 || 长度 <= 0) { 返回 错误_无效参数 }
    // 扩容
    如果 (dec.IDAT大小 + 长度 > dec.IDAT容量) {
        定义 新容量 = dec.IDAT容量 * 2
        如果 (新容量 < dec.IDAT大小 + 长度) { 新容量 = dec.IDAT大小 + 长度 + 65536 }
        如果 (新容量 > PNG_最大IDAT累积) {
            打印("[PNG解码] 错误: IDAT数据过大")
            如果 (全局PNG统计 != 空) { 全局PNG统计.错误总数 = 全局PNG统计.错误总数 + 1 }
            返回 错误_容量不足
        }
        dec.IDAT缓冲 = 堆_重新分配(dec.IDAT缓冲, dec.IDAT容量, 新容量)
        如果 (dec.IDAT缓冲 == 空) { 返回 错误_内存不足 }
        dec.IDAT容量 = 新容量
    }
    内存_复制(dec.IDAT缓冲 + dec.IDAT大小, 数据, 长度)
    dec.IDAT大小 = dec.IDAT大小 + 长度
    如果 (全局PNG统计 != 空) {
        全局PNG统计.IDAT块累积数 = 全局PNG统计.IDAT块累积数 + 1
        全局PNG统计.总IDAT字节 = 全局PNG统计.总IDAT字节 + 长度
    }
    返回 0
}

// §7 完整PNG解码主入口

函数 PNG解码_完整(数据, 数据大小) {
    如果 (数据 == 空 || 数据大小 < 33) {
        打印("[PNG解码] 错误: 数据太短")
        如果 (全局PNG统计 != 空) { 全局PNG统计.解码失败次数 = 全局PNG统计.解码失败次数 + 1 }
        返回 空
    }
    定义 开始时间 = 平台_获取高精度时间()
    如果 (全局PNG统计 != 空) { 全局PNG统计.解码总次数 = 全局PNG统计.解码总次数 + 1 }

    // 验证签名
    如果 (PNG_验证签名(数据) == 假) {
        打印("[PNG解码] 错误: PNG签名不匹配")
        如果 (全局PNG统计 != 空) { 全局PNG统计.解码失败次数 = 全局PNG统计.解码失败次数 + 1 }
        返回 空
    }

    定义 dec = PNG解码器_创建()
    如果 (dec == 空) { 返回 空 }

    // 遍历所有Chunk
    定义 可变 偏移 = 8
    定义 可变 遇到IEND = 假
    当 (偏移 + 12 <= 数据大小 && 遇到IEND == 假) {
        定义 chunk长度 = 读32大端(数据 + 偏移)
        定义 chunk类型 = 读32大端(数据 + 偏移 + 4)
        定义 chunk数据 = 数据 + 偏移 + 8
        如果 (全局PNG统计 != 空) { 全局PNG统计.Chunk总数 = 全局PNG统计.Chunk总数 + 1 }

        如果 (chunk类型 == CHUNK_IHDR) {
            PNG解码器_解析IHDR(dec, 数据, 偏移 + 8)
        } 否则 如果 (chunk类型 == CHUNK_PLTE) {
            PNG解码器_解析PLTE(dec, chunk数据, chunk长度)
        } 否则 如果 (chunk类型 == CHUNK_tRNS) {
            PNG解码器_解析tRNS(dec, chunk数据, chunk长度)
        } 否则 如果 (chunk类型 == CHUNK_IDAT) {
            PNG解码器_累积IDAT(dec, chunk数据, chunk长度)
        } 否则 如果 (chunk类型 == CHUNK_gAMA) {
            如果 (chunk长度 == 4) { dec.伽马值 = 读32大端(chunk数据) }
        } 否则 如果 (chunk类型 == CHUNK_sRGB) {
            dec.是sRGB = 真
        } 否则 如果 (chunk类型 == CHUNK_IEND) {
            遇到IEND = 真
        } 否则 {
            如果 (全局PNG统计 != 空) { 全局PNG统计.未知Chunk跳过数 = 全局PNG统计.未知Chunk跳过数 + 1 }
        }
        偏移 = 偏移 + 12 + chunk长度    // 4(长度) + 4(类型) + 数据 + 4(CRC)
    }

    // 解压IDAT
    如果 (dec.状态 == PNG状态_头已读 && dec.IDAT大小 > 0) {
        dec.状态 = PNG状态_解压中
        定义 解压大小 = (dec.行字节 + 1) * dec.高
        定义 解压缓冲 = 堆_分配(解压大小)
        如果 (解压缓冲 != 空) {
            定义 实际大小 = Zlib_解压_完整(dec.IDAT缓冲, dec.IDAT大小, 解压缓冲, 解压大小)
            如果 (实际大小 > 0) {
                PNG_逆滤波_全部行(dec, 解压缓冲, 实际大小)
                dec.状态 = PNG状态_完成
            } 否则 {
                打印("[PNG解码] 错误: zlib解压失败")
                dec.状态 = PNG状态_错误
            }
            堆_释放(解压缓冲)
        }
    }

    // AI学习
    如果 (全局PNG_AI != 空 && dec.状态 == PNG状态_完成) {
        AI_PNG_后解码学习(dec)
    }

    // 统计
    如果 (全局PNG统计 != 空) {
        如果 (dec.状态 == PNG状态_完成) {
            全局PNG统计.解码成功次数 = 全局PNG统计.解码成功次数 + 1
            全局PNG统计.总像素数 = 全局PNG统计.总像素数 + dec.宽 * dec.高
        } 否则 {
            全局PNG统计.解码失败次数 = 全局PNG统计.解码失败次数 + 1
        }
        定义 耗时 = 平台_获取高精度时间() - 开始时间
        全局PNG统计.总解码耗时_纳秒 = 全局PNG统计.总解码耗时_纳秒 + 耗时
        如果 (耗时 > 全局PNG统计.最大单次耗时) { 全局PNG统计.最大单次耗时 = 耗时 }
    }
    返回 dec
}

// §8 AI基因 — 图像类型预测与解码优先级
// 能力: 预测 + 学习 + 自适应
// 四阶段: 数据采集→特征提取→决策→执行

函数 AI_PNG_后解码学习(dec) {
    如果 (全局PNG_AI == 空 || dec == 空) { 返回 }
    定义 AI = 全局PNG_AI
    AI.采样计数器 = AI.采样计数器 + 1
    如果 (全局PNG统计 != 空) {
        全局PNG统计.AI优先级调用次数 = 全局PNG统计.AI优先级调用次数 + 1
    }

    AI.历史图像宽均值 = (AI.历史图像宽均值 * 7 + dec.宽) / 8
    AI.历史图像高均值 = (AI.历史图像高均值 * 7 + dec.高) / 8
    AI.历史颜色类型 = dec.颜色类型

    定义 可变 是大图 = 假
    如果 (dec.宽 * dec.高 > 1000000) {
        是大图 = 真
        AI.连续大图计数 = AI.连续大图计数 + 1
    } 否则 {
        AI.连续大图计数 = 0
    }

    如果 (是大图 == 真) {
        AI.大图比例 = (AI.大图比例 * 15 + 1024) / 16
    } 否则 {
        AI.大图比例 = (AI.大图比例 * 15) / 16
    }
    AI.预测是大图 = 假
    如果 (AI.大图比例 > 600 || AI.连续大图计数 > 3) {
        AI.预测是大图 = 真
    }

    如果 (AI.预测是大图 == 真) {
        打印("[AI PNG] 建议: 后续图像可能较大，预分配更大解压缓冲")
        如果 (全局PNG统计 != 空) {
            全局PNG统计.AI大图检测次数 = 全局PNG统计.AI大图检测次数 + 1
        }
    }
}

// §9 统计输出与诊断

函数 PNG解码_打印统计() {
    如果 (全局PNG统计 == 空) {
        打印("[PNG解码] 统计未初始化")
        返回
    }
    打印("┌──────────────────────────────────────┐")
    打印("│   PNG解码器 · 统计报告              │")
    打印("├──────────────────────────────────────┤")
    打印(字符串拼接("│ 解码总次数:       ", 转字符串(全局PNG统计.解码总次数)))
    打印(字符串拼接("│ 成功/失败:        ", 字符串拼接(转字符串(全局PNG统计.解码成功次数), 字符串拼接("/", 转字符串(全局PNG统计.解码失败次数)))))
    打印(字符串拼接("│ IHDR解析:         ", 转字符串(全局PNG统计.IHDR解析次数)))
    打印(字符串拼接("│ PLTE解析:         ", 转字符串(全局PNG统计.PLTE解析次数)))
    打印(字符串拼接("│ IDAT块累积:       ", 转字符串(全局PNG统计.IDAT块累积数)))
    打印(字符串拼接("│ IDAT总字节(KB):   ", 转字符串(全局PNG统计.总IDAT字节 / 1024)))
    打印(字符串拼接("│ Chunk总数:        ", 转字符串(全局PNG统计.Chunk总数)))
    打印(字符串拼接("│ 未知Chunk跳过:    ", 转字符串(全局PNG统计.未知Chunk跳过数)))
    打印(字符串拼接("│ 总像素(百万):     ", 转字符串(全局PNG统计.总像素数 / 1000000)))
    打印(字符串拼接("│ 总耗时(ms):       ", 转字符串(全局PNG统计.总解码耗时_纳秒 / 1000000)))
    打印(字符串拼接("│ AI优先级调用:     ", 转字符串(全局PNG统计.AI优先级调用次数)))
    打印(字符串拼接("│ AI大图检测:       ", 转字符串(全局PNG统计.AI大图检测次数)))
    打印(字符串拼接("│ 错误:             ", 转字符串(全局PNG统计.错误总数)))
    打印("└──────────────────────────────────────┘")
}

函数 PNG解码_导出诊断() {
    如果 (全局PNG_AI != 空) {
        定义 AI = 全局PNG_AI
        打印("[PNG AI] === 诊断 ===")
        打印(字符串拼接("  历史宽均值: ", 转字符串(AI.历史图像宽均值)))
        打印(字符串拼接("  历史高均值: ", 转字符串(AI.历史图像高均值)))
        打印(字符串拼接("  历史颜色类型: ", 转字符串(AI.历史颜色类型)))
        打印(字符串拼接("  大图比例(Q10): ", 转字符串(AI.大图比例)))
        打印(字符串拼接("  预测大图: ", 转字符串(AI.预测是大图)))
    }
}

// §10 对外接口

函数 PNG解码_获取统计() { 返回 全局PNG统计 }
函数 PNG解码_获取AI状态() { 返回 全局PNG_AI }

函数 PNG解码_获取像素(dec) {
    如果 (dec == 空) { 返回 空 }
    返回 dec.像素缓冲
}

函数 PNG解码_获取宽高(dec) {
    如果 (dec == 空) { 返回 0 }
    返回 (dec.宽 << 16) | dec.高
}

函数 PNG解码_是隔行(dec) {
    如果 (dec == 空) { 返回 假 }
    返回 dec.隔行方法 == 1
}

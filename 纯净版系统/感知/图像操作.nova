// §11 图像操作


函数 画布2D_draw图像(ctx, 图像数据, 图宽, 图高, dx, dy, dw, dh) {
    如果 (ctx == 0 || 图像数据 == 0) { 返回 }
    // 双线性插值缩放
    定义 可变 py = 0
    当 (py < dh) {
        定义 sy = py * 图高 / dh
        定义 可变 px = 0
        当 (px < dw) {
            定义 sx = px * 图宽 / dw
            定义 src偏移 = (sy * 图宽 + sx) * 4
            定义 R = 内存_读8(图像数据 + src偏移)
            定义 G = 内存_读8(图像数据 + src偏移 + 1)
            定义 B = 内存_读8(图像数据 + src偏移 + 2)
            定义 A = 内存_读8(图像数据 + src偏移 + 3)
            画布2D_写像素(ctx, dx + px, dy + py, R, G, B, A)
            px = px + 1
        }
        py = py + 1
    }
}

结构 图像Data {
    宽,
    高,
    数据,    // u64 Uint8Clamped数组 (RGBA)
}

函数 画布2D_get图像Data(ctx, x, y, w, h) {
    如果 (ctx == 0) { 返回 0 }
    定义 img = 堆_分配(图像Data)
    img.宽 = w; img.高 = h
    img.数据 = 堆_分配_数组(w * h * 4)
    定义 可变 py = 0
    当 (py < h) {
        定义 sy = y + py
        如果 (sy >= 0 && sy < ctx.高) {
            内存_复制(img.数据 + py * w * 4, ctx.像素缓冲 + (sy * ctx.宽 + x) * 4, w * 4)
        }
        py = py + 1
    }
    返回 img
}

函数 画布2D_put图像Data(ctx, img, x, y) {
    如果 (ctx == 0 || img == 0) { 返回 }
    定义 可变 py = 0
    当 (py < img.高) {
        定义 dy = y + py
        如果 (dy >= 0 && dy < ctx.高) {
            内存_复制(ctx.像素缓冲 + (dy * ctx.宽 + x) * 4, img.数据 + py * img.宽 * 4, img.宽 * 4)
        }
        py = py + 1
    }
}

// §12 文字绘制

函数 画布2D_fillText(ctx, 文字, x, y) {
    如果 (ctx == 0 || ctx.状态.字体 == 0) { 返回 }
    定义 s = ctx.状态
    // 使用字体引擎绘制
    // 字体_绘制文字会直接操作图处, 这里需要CPU路径
    定义 run = 字体_shape文字(s.字体, 文字, 字节长度(文字), s.字号)
    如果 (run == 0) { 返回 }

    // 文字对齐调整
    定义 可变 偏移x = x
    如果 (s.文字对齐 == TextAlign_Center) { 偏移x = x - run.总宽度 / 2 }
    否则 如果 (s.文字对齐 == TextAlign_Right || s.文字对齐 == TextAlign_End) { 偏移x = x - run.总宽度 }

    // 逐字形光栅化并合成
    定义 可变 光标 = 偏移x
    定义 可变 i = 0
    当 (i < run.字形数) {
        定义 goff = run.字形 + i * 8
        定义 glyphID = 内存_读16(goff)
        定义 推进 = 内存_读16(goff + 6)
        定义 bmp = 字体_光栅化字形(s.字体, glyphID, s.字号)
        如果 (bmp != 0) {
            // 将灰度字形位图以填充颜色合成到画布
            定义 可变 gy = 0
            当 (gy < bmp.高) {
                定义 可变 gx = 0
                当 (gx < bmp.宽) {
                    定义 alpha = 内存_读8(bmp.像素 + gy * bmp.宽 + gx)
                    如果 (alpha > 0) {
                        定义 合成alpha = alpha * s.填充颜色A / 255
                        画布2D_写像素(ctx,
                            光标 + gx + bmp.基线偏移x,
                            y + gy - bmp.基线偏移y,
                            s.填充颜色R, s.填充颜色G, s.填充颜色B, 合成alpha)
                    }
                    gx = gx + 1
                }
                gy = gy + 1
            }
        }
        光标 = 光标 + 推进
        i = i + 1
    }
}

函数 画布2D_measureText(ctx, 文字) {
    如果 (ctx == 0 || ctx.状态.字体 == 0) { 返回 0 }
    定义 run = 字体_shape文字(ctx.状态.字体, 文字, 字节长度(文字), ctx.状态.字号)
    如果 (run == 0) { 返回 0 }
    返回 run.总宽度
}

// 三角函数辅助(Q10定点)
函数 Q_cos(角度) {
    // Q10定点cos: 输入角度为Q10弧度, 输出Q10
    // cos(x) ≈ 1 - x²/2 + x⁴/24
    定义 x = 角度    // Q10弧度
    定义 x2 = x * x / 1024
    定义 x4 = x2 * x2 / 1024
    返回 1024 - x2 / 2 + x4 / 24
}
函数 Q_sin(角度) {
    // Q10定点sin: sin(x) ≈ x - x³/6 + x⁵/120
    定义 x = 角度
    定义 x2 = x * x / 1024
    定义 x3 = x2 * x / 1024
    定义 x5 = x3 * x2 / 1024
    返回 x - x3 / 6 + x5 / 120
}

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../推理/值乘.nova")
导入("../推理/智能总线资源.nova")

// 传统方案: 每次布局都从根到叶重算所有节点
// Nova: AI预测+缓存+注意力驱动,跳过不必要的计算

函数 AI布局_预测尺寸(lo) {
    如果 (lo == 0) { 返回 }
    定义 s = lo.样式
    如果 (s == 0) { 返回 }

    // 如果有显式宽高, 直接用作预测(高置信度)
    如果 (!s.width.是auto) {
        如果 (s.width.单位 == 单位_px || s.width.单位 == 单位_无) {
            lo.预测宽 = s.width.值
            lo.预测置信度 = 9500
        } 否则 如果 (s.width.单位 == 单位_百分比 && lo.父 != 0) {
            lo.预测宽 = lo.父.内容宽 * s.width.值 / 10000
            lo.预测置信度 = 8000
        }
    } 否则 如果 (lo.父 != 0) {
        // auto宽: 预测为父宽度
        lo.预测宽 = lo.父.内容宽
        lo.预测置信度 = 6000
    }

    如果 (!s.height.是auto) {
        如果 (s.height.单位 == 单位_px || s.height.单位 == 单位_无) {
            lo.预测高 = s.height.值
            如果 (lo.预测置信度 < 9500) { lo.预测置信度 = 9500 }
        }
    } 否则 {
        // auto高: 用历史值预测
        如果 (lo.累计布局次数 > 0 && lo.内容高 > 0) {
            lo.预测高 = lo.内容高    // 用上次布局结果作为预测
            如果 (lo.预测置信度 < 7000) { lo.预测置信度 = 7000 }
        }
    }

    lo.标志 = lo.标志 | 布局标志_AI已预测
}

// 传统: 简单置信度阈值(>9000→跳过)
// Nova: AI总线_布局预测网络(Nova多层感知器 12→32→16→4)预测尺寸,
//       结合注意力网络判断是否值得精确布局
函数 AI布局_可以跳过(lo) {
    如果 (lo == 0) { 返回 假 }
    如果 (lo.标志 & 布局标志_需要布局) { 返回 假 }

    定义 bus = 全局AI总线
    如果 (bus != 0 && lo.累计布局次数 > 2) {
        // 用AI总线的布局预测网络判断
        // 输入12维: [样式宽/高/display/position/margin4/padding4/父宽/父高]
        定义 特征 = AI布局_提取特征(lo)
        如果 (特征 != 0) {
            定义 预测结果 = AI总线_布局预测(bus, 特征)
            如果 (预测结果 != 0) {
                // 预测的[x,y,w,h]与上次布局结果比较
                定义 预测w = Tensor_读(预测结果, 0, 2)
                定义 预测h = Tensor_读(预测结果, 0, 3)
                定义 差w = lo.内容宽 * Q_ONE - 预测w
                定义 差h = lo.内容高 * Q_ONE - 预测h
                如果 (差w < 0) { 差w = -差w }
                如果 (差h < 0) { 差h = -差h }
                // 预测与实际差异<2%且父版本未变 → 可跳过
                如果 (差w < lo.内容宽 * Q_ONE / 50 && 差h < lo.内容高 * Q_ONE / 50) {
                    如果 (lo.父 != 0 && lo.父布局版本 == lo.父.布局版本) {
                        lo.预测宽 = 预测w >> Q_SHIFT
                        lo.预测高 = 预测h >> Q_SHIFT
                        lo.预测置信度 = 9500
                        Tensor_释放(预测结果)
                        Tensor_释放(特征)
                        lo.标志 = lo.标志 | 布局标志_可跳过布局
                        返回 真
                    }
                }
                Tensor_释放(预测结果)
            }
            Tensor_释放(特征)
        }
    }

    // 后备: 简单置信度判断
    如果 (lo.预测置信度 >= 9000 && lo.父 != 0 && lo.父布局版本 == lo.父.布局版本) {
        lo.标志 = lo.标志 | 布局标志_可跳过布局
        返回 真
    }
    如果 (lo.布局精度 == 0) {
        lo.标志 = lo.标志 | 布局标志_可跳过布局
        返回 真
    }
    返回 假
}

// 提取布局特征(12维)供AI总线的布局预测网络使用
函数 AI布局_提取特征(lo) {
    如果 (lo == 0) { 返回 0 }
    定义 特征 = Tensor_创建(1, 12)
    定义 s = lo.样式
    如果 (s != 0) {
        Tensor_写(特征, 0, 0, s.width.值 * Q_ONE / 10000)
        Tensor_写(特征, 0, 1, s.height.值 * Q_ONE / 10000)
        Tensor_写(特征, 0, 2, s.display * Q_ONE / 10)
        Tensor_写(特征, 0, 3, s.position * Q_ONE / 5)
        Tensor_写(特征, 0, 4, s.margin_top * Q_ONE / 10000)
        Tensor_写(特征, 0, 5, s.margin_right * Q_ONE / 10000)
        Tensor_写(特征, 0, 6, s.padding_top * Q_ONE / 10000)
        Tensor_写(特征, 0, 7, s.padding_left * Q_ONE / 10000)
    }
    如果 (lo.父 != 0) {
        Tensor_写(特征, 0, 8, lo.父.内容宽 * Q_ONE / 200000)
        Tensor_写(特征, 0, 9, lo.父.内容高 * Q_ONE / 200000)
    }
    Tensor_写(特征, 0, 10, lo.内容宽 * Q_ONE / 200000)
    Tensor_写(特征, 0, 11, lo.内容高 * Q_ONE / 200000)
    返回 特征
}

// 上下文_运行时作用域环境 — NovaOS 企业级运行时作用域管理子系统
// 理论基础: SCED (Scope Cognition Environment Dispatch)
//   作用域认知环境调度 — 通过作用域链结构拓扑映射、变量生命周期感知、
//   闭包捕获分析、暂时性死区执行，实现O(1)平均变量查找与安全作用域隔离。
// 创新公式:
//   Resolve(v) = Cache[hash(v)] ∨ Chain_Walk(depth, slot)
//   TDZ(v) = declared(v) ∧ ¬initialised(v) → ReferenceError
//   ClosureHoist(v) = referenced_by_inner(v) → stack_to_context(v)
// 架构:
//   14部分 — 常量/数据结构/初始化/Context读写/变量查找/TDZ/
//            with-eval作用域/闭包分析/变量提升/作用域树/AI优化/统计

导入("../中枢/系统调用表.nova")
导入("../推理/智能渠道.nova")
导入("./域信息创建.nova")
导入("../中枢/内核打印.nova")
导入("./值乘.nova")
导入("../中枢/创建甲.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内存初始化.nova")
导入("../感知/内核直连层.nova")
导入("./错误栈捕获.nova")
导入("./脚本器创建.nova")
导入("./对象解构未知.nova")

// 第1部分: 常量定义

// 作用域类型
定义 作用域_全局           = 0
定义 作用域_函数           = 1
定义 作用域_块             = 2
定义 作用域_With           = 3
定义 作用域_Catch          = 4
定义 作用域_模块           = 5
定义 作用域_Eval           = 6
定义 作用域_类体           = 7
定义 作用域_箭头函数       = 8

// 变量声明类型
定义 声明_var              = 0
定义 声明_let              = 1
定义 声明_const            = 2
定义 声明_函数声明        = 3
定义 声明_形参             = 4
定义 声明_类名             = 5
定义 声明_导入             = 6

// 变量存储位置
定义 位置_栈              = 0
定义 位置_上下文          = 1
定义 位置_全局            = 2
定义 位置_动态            = 3
定义 位置_未解析          = 4

// 内部标记
定义 标记_未初始化        = 0
定义 标记_已初始化        = 1
定义 标记_TDZ处罚         = 2

// 槽容量限制
定义 最大槽数              = 4096
定义 最大作用域链深度    = 512
定义 查找缓存容量          = 64
定义 变量记录大小          = 48

// AI 阈值
定义 AI_作用域优化阈值   = 0.65

// 第2部分: 数据结构

结构 ScopeContext {
    外部上下文,        // u64 ScopeContext* (父作用域)
    作用域信息,        // u64 ScopeInfo*
    槽,                // u64 JSValue*数组(闭包变量)
    槽数,
    扩展,              // u64 with/catch的对象
    类型,              // u32 作用域类型
    深度,              // u32 链深度
    创建时间,
    访问计数,          // u64 槽访问总次数
    初始化标志,        // u64* 每槽初始化状态位图
    变量名哈希,        // u32* 每槽变量名哈希
    变量声明类型,      // u8* 每槽声明类型
    是严格模式,
    是模块作用域,
    已销毁,
}

结构 VariableLookupResult {
    找到,
    位置,              // u32 位置_栈/上下文/全局
    深度,              // u32 作用域链深度(0=当前)
    槽索引,            // u32 寄存器索引或Context slot
    声明类型,          // u32 变量_var/let/const
    是可变的,
    已初始化,
    是TDZ,
    上下文引用,        // ScopeContext* 找到所在的上下文
}

结构 查找缓存项 {
    名称哈希,
    深度,
    槽索引,
    有效,
}

结构 作用域统计 {
    Context创建总数,
    Context销毁总数,
    槽读取总数,
    槽写入总数,
    查找总数,
    查找命中数,
    查找未命中数,
    缓存命中数,
    TDZ违规数,
    闭包捐获数,
    提升操作数,
    最大链深度,
    当前活跃上下文数,
    AI优化触发数,
}

// 第3部分: 全局状态

定义 可变 全局作用域统计 = 作用域统计 {}
定义 可变 全局查找缓存 = 创建数组(查找缓存容量, 查找缓存项 {})

// 第4部分: 哈希与工具函数

函数 作用域_哈希名称(名) {
    定义 可变 h = 2166136261
    定义 可变 i = 0
    当 (i < 字符串_长度(名)) {
        h = h ^ 字符串_读字节(名, i)
        h = h * 16777619
        i = i + 1
    }
    返回 h
}

函数 作用域_当前时间() {
    返回 平台_获取高精度时间()
}

函数 作用域_是严格声明(类型) {
    // let/const/class/import 都是严格声明，受TDZ约束
    返回 类型 == 声明_let || 类型 == 声明_const ||
           类型 == 声明_类名 || 类型 == 声明_导入
}

函数 作用域_是可变声明(类型) {
    返回 类型 == 声明_var || 类型 == 声明_let ||
           类型 == 声明_形参
}

// 第5部分: ScopeContext 创建与销毁

函数 ScopeContext_创建(外部, scope_info) {
    定义 ctx = 堆_分配(ScopeContext)
    如果 (ctx == 0) { 返回 0 }

    ctx.外部上下文 = 外部
    ctx.作用域信息 = scope_info
    ctx.槽数 = scope_info.上下文槽数
    如果 (ctx.槽数 > 最大槽数) { ctx.槽数 = 最大槽数 }

    ctx.槽 = 堆_分配_数组(ctx.槽数 * 8)
    ctx.初始化标志 = 堆_分配_数组(ctx.槽数)
    ctx.变量名哈希 = 堆_分配_数组(ctx.槽数 * 4)
    ctx.变量声明类型 = 堆_分配_数组(ctx.槽数)

    // 初始化所有槽为 undefined，标志为未初始化
    定义 可变 i = 0
    当 (i < ctx.槽数) {
        内存_分64(ctx.槽 + i * 8, 0)
        内存_分8(ctx.初始化标志 + i, 标记_未初始化)
        内存_分32(ctx.变量名哈希 + i * 4, 0)
        内存_分8(ctx.变量声明类型 + i, 声明_var)
        i = i + 1
    }

    ctx.扩展 = 0
    ctx.类型 = 作用域_块
    ctx.深度 = 0
    如果 (外部 != 0) {
        ctx.深度 = 外部.深度 + 1
    }
    ctx.创建时间 = 作用域_当前时间()
    ctx.访问计数 = 0
    ctx.是严格模式 = 假
    ctx.是模块作用域 = 假
    ctx.已销毁 = 假

    全局作用域统计.Context创建总数 = 全局作用域统计.Context创建总数 + 1
    全局作用域统计.当前活跃上下文数 = 全局作用域统计.当前活跃上下文数 + 1
    如果 (ctx.深度 > 全局作用域统计.最大链深度) {
        全局作用域统计.最大链深度 = ctx.深度
    }

    返回 ctx
}

函数 ScopeContext_创建函数作用域(外部, scope_info, 严格模式) {
    定义 ctx = ScopeContext_创建(外部, scope_info)
    如果 (ctx == 0) { 返回 0 }
    ctx.类型 = 作用域_函数
    ctx.是严格模式 = 严格模式
    返回 ctx
}

函数 ScopeContext_创建With作用域(外部, scope_info, with对象) {
    定义 ctx = ScopeContext_创建(外部, scope_info)
    如果 (ctx == 0) { 返回 0 }
    ctx.类型 = 作用域_With
    ctx.扩展 = with对象
    返回 ctx
}

函数 ScopeContext_创建Catch作用域(外部, scope_info) {
    定义 ctx = ScopeContext_创建(外部, scope_info)
    如果 (ctx == 0) { 返回 0 }
    ctx.类型 = 作用域_Catch
    返回 ctx
}

函数 ScopeContext_创建模块作用域(外部, scope_info) {
    定义 ctx = ScopeContext_创建(外部, scope_info)
    如果 (ctx == 0) { 返回 0 }
    ctx.类型 = 作用域_模块
    ctx.是模块作用域 = 真
    ctx.是严格模式 = 真  // 模块始终严格
    返回 ctx
}

函数 ScopeContext_创建Eval作用域(外部, scope_info, 严格模式) {
    定义 ctx = ScopeContext_创建(外部, scope_info)
    如果 (ctx == 0) { 返回 0 }
    ctx.类型 = 作用域_Eval
    ctx.是严格模式 = 严格模式
    返回 ctx
}

函数 ScopeContext_销毁(ctx) {
    如果 (ctx == 0 || ctx.已销毁) { 返回 }
    ctx.已销毁 = 真
    如果 (ctx.槽 != 0) { 堆_释放(ctx.槽) }
    如果 (ctx.初始化标志 != 0) { 堆_释放(ctx.初始化标志) }
    如果 (ctx.变量名哈希 != 0) { 堆_释放(ctx.变量名哈希) }
    如果 (ctx.变量声明类型 != 0) { 堆_释放(ctx.变量声明类型) }
    堆_释放(ctx)
    全局作用域统计.Context销毁总数 = 全局作用域统计.Context销毁总数 + 1
    如果 (全局作用域统计.当前活跃上下文数 > 0) {
        全局作用域统计.当前活跃上下文数 = 全局作用域统计.当前活跃上下文数 - 1
    }
}

// 第6部分: 槽读写 与 TDZ守护

函数 ScopeContext_读取(ctx, slot) {
    如果 (ctx == 0 || ctx.已销毁) { 返回 0 }
    如果 (slot >= ctx.槽数) { 返回 0 }
    ctx.访问计数 = ctx.访问计数 + 1
    全局作用域统计.槽读取总数 = 全局作用域统计.槽读取总数 + 1
    返回 内存_读64(ctx.槽 + slot * 8)
}

函数 ScopeContext_写入(ctx, slot, 值) {
    如果 (ctx == 0 || ctx.已销毁) { 返回 }
    如果 (slot >= ctx.槽数) { 返回 }
    内存_分64(ctx.槽 + slot * 8, 值)
    ctx.访问计数 = ctx.访问计数 + 1
    全局作用域统计.槽写入总数 = 全局作用域统计.槽写入总数 + 1
}

函数 ScopeContext_安全读取(ctx, slot) {
    // TDZ守护读取: 检查初始化状态
    如果 (ctx == 0 || ctx.已销毁) { 返回 0 }
    如果 (slot >= ctx.槽数) { 返回 0 }

    定义 标志 = 内存_读8(ctx.初始化标志 + slot)
    如果 (标志 == 标记_未初始化) {
        定义 decl_type = 内存_读8(ctx.变量声明类型 + slot)
        如果 (作用域_是严格声明(decl_type)) {
            // TDZ违规: let/const在初始化前读取
            全局作用域统计.TDZ违规数 = 全局作用域统计.TDZ违规数 + 1
            内存_分8(ctx.初始化标志 + slot, 标记_TDZ处罚)
            返回 0  // 应触发 ReferenceError
        }
    }

    ctx.访问计数 = ctx.访问计数 + 1
    全局作用域统计.槽读取总数 = 全局作用域统计.槽读取总数 + 1
    返回 内存_读64(ctx.槽 + slot * 8)
}

函数 ScopeContext_安全写入(ctx, slot, 值) {
    // TDZ守护写入: 检查const不可写 + 标记初始化
    如果 (ctx == 0 || ctx.已销毁) { 返回 假 }
    如果 (slot >= ctx.槽数) { 返回 假 }

    定义 decl_type = 内存_读8(ctx.变量声明类型 + slot)
    定义 标志 = 内存_读8(ctx.初始化标志 + slot)

    // const已初始化后不可再次赋值
    如果 (decl_type == 声明_const && 标志 == 标记_已初始化) {
        返回 假  // 应触发 TypeError
    }

    内存_分64(ctx.槽 + slot * 8, 值)
    内存_分8(ctx.初始化标志 + slot, 标记_已初始化)
    ctx.访问计数 = ctx.访问计数 + 1
    全局作用域统计.槽写入总数 = 全局作用域统计.槽写入总数 + 1
    返回 真
}

函数 ScopeContext_设置槽元数据(ctx, slot, 名称哈希, 声明类型) {
    如果 (ctx == 0 || slot >= ctx.槽数) { 返回 }
    内存_分32(ctx.变量名哈希 + slot * 4, 名称哈希)
    内存_分8(ctx.变量声明类型 + slot, 声明类型)
}

函数 ScopeContext_检查TDZ(ctx, slot) {
    如果 (ctx == 0 || slot >= ctx.槽数) { 返回 假 }
    定义 标志 = 内存_读8(ctx.初始化标志 + slot)
    如果 (标志 != 标记_未初始化) { 返回 假 }
    定义 decl_type = 内存_读8(ctx.变量声明类型 + slot)
    返回 作用域_是严格声明(decl_type)
}

// 第7部分: 变量查找 (SCED链式查找)

函数 Scope_查找变量(scope, 名) {
    定义 结果 = VariableLookupResult {}
    结果.找到 = 假
    结果.深度 = 0
    结果.是TDZ = 假
    结果.上下文引用 = 0

    全局作用域统计.查找总数 = 全局作用域统计.查找总数 + 1

    // 缓存查找
    定义 名哈希 = 作用域_哈希名称(名)
    定义 缓存结果 = 查找缓存_获取(名哈希)
    如果 (缓存结果.有效) {
        全局作用域统计.缓存命中数 = 全局作用域统计.缓存命中数 + 1
        结果.找到 = 真
        结果.深度 = 缓存结果.深度
        结果.槽索引 = 缓存结果.槽索引
        结果.位置 = 位置_上下文
        全局作用域统计.查找命中数 = 全局作用域统计.查找命中数 + 1
        返回 结果
    }

    定义 可变 当前scope = scope
    定义 可变 深度 = 0
    当 (当前scope != 0 && 深度 < 最大作用域链深度) {
        // 在当前作用域查找
        定义 idx = ScopeInfo_查找本地(当前scope, 名)
        如果 (idx >= 0) {
            定义 偏移 = 当前scope.变量列表 + idx * 变量记录大小
            结果.找到 = 真
            结果.位置 = 内存_读32(偏移 + 12)
            结果.深度 = 深度
            结果.槽索引 = 内存_读32(偏移 + 16)
            结果.声明类型 = 内存_读32(偏移 + 8)
            结果.是可变的 = 内存_读8(偏移 + 20)
            结果.已初始化 = 内存_读8(偏移 + 21)
            结果.是TDZ = 作用域_是严格声明(结果.声明类型) && !结果.已初始化

            // 更新缓存
            查找缓存_设置(名哈希, 深度, 结果.槽索引)
            全局作用域统计.查找命中数 = 全局作用域统计.查找命中数 + 1
            返回 结果
        }

        // with作用域: 动态查找(运行时才知道有没有)
        如果 (当前scope.类型 == 作用域_With) {
            结果.找到 = 假
            结果.位置 = 位置_动态
            结果.深度 = 深度
            全局作用域统计.查找未命中数 = 全局作用域统计.查找未命中数 + 1
            返回 结果
        }

        当前scope = 当前scope.外部作用域
        深度 = 深度 + 1
    }

    // 未找到: 可能是全局变量
    结果.找到 = 假
    结果.位置 = 位置_全局
    全局作用域统计.查找未命中数 = 全局作用域统计.查找未命中数 + 1
    返回 结果
}

// 第8部分: 运行时链式 Context 查找

函数 ContextChain_查找(ctx, 名哈希, 槽索引) {
    // 沿 Context 链按深度+槽索引直接定位
    如果 (ctx == 0) { 返回 0 }
    定义 可变 当前 = ctx
    当 (当前 != 0) {
        如果 (槽索引 < 当前.槽数) {
            定义 stored_hash = 内存_读32(当前.变量名哈希 + 槽索引 * 4)
            如果 (stored_hash == 名哈希) {
                返回 当前
            }
        }
        当前 = 当前.外部上下文
    }
    返回 0
}

函数 ContextChain_深度查找(ctx, 目标深度, 槽索引) {
    // 已知深度的快速查找: 跳过N层后读取槽
    如果 (ctx == 0) { 返回 0 }
    定义 可变 当前 = ctx
    定义 可变 d = 0
    当 (d < 目标深度 && 当前 != 0) {
        当前 = 当前.外部上下文
        d = d + 1
    }
    如果 (当前 == 0) { 返回 0 }
    返回 ScopeContext_读取(当前, 槽索引)
}

函数 ContextChain_深度写入(ctx, 目标深度, 槽索引, 值) {
    如果 (ctx == 0) { 返回 }
    定义 可变 当前 = ctx
    定义 可变 d = 0
    当 (d < 目标深度 && 当前 != 0) {
        当前 = 当前.外部上下文
        d = d + 1
    }
    如果 (当前 != 0) {
        ScopeContext_写入(当前, 槽索引, 值)
    }
}

函数 ContextChain_安全深度读取(ctx, 目标深度, 槽索引) {
    如果 (ctx == 0) { 返回 0 }
    定义 可变 当前 = ctx
    定义 可变 d = 0
    当 (d < 目标深度 && 当前 != 0) {
        当前 = 当前.外部上下文
        d = d + 1
    }
    如果 (当前 == 0) { 返回 0 }
    返回 ScopeContext_安全读取(当前, 槽索引)
}

函数 ContextChain_获取深度(ctx) {
    如果 (ctx == 0) { 返回 0 }
    返回 ctx.深度
}

// 第9部分: with/eval 动态作用域查找

函数 With_动态查找(ctx, 名) {
    // 在with作用域的扩展对象上查找属性
    如果 (ctx == 0 || ctx.类型 != 作用域_With) { 返回 0 }
    如果 (ctx.扩展 == 0) { 返回 0 }
    // 调用对象属性查找API
    返回 对象_获取属性(ctx.扩展, 名)
}

函数 With_动态写入(ctx, 名, 值) {
    如果 (ctx == 0 || ctx.类型 != 作用域_With) { 返回 假 }
    如果 (ctx.扩展 == 0) { 返回 假 }
    对象_设置属性(ctx.扩展, 名, 值)
    返回 真
}

函数 Eval_动态查找(ctx, 名) {
    // eval作用域需要动态查找外层链
    如果 (ctx == 0) { 返回 0 }
    如果 (ctx.类型 == 作用域_Eval && ctx.是严格模式) {
        // 严格模式eval有独立作用域，只看自己
        定义 可变 i = 0
        当 (i < ctx.槽数) {
            定义 h = 内存_读32(ctx.变量名哈希 + i * 4)
            如果 (h == 作用域_哈希名称(名)) {
                返回 ScopeContext_读取(ctx, i)
            }
            i = i + 1
        }
        返回 0
    }
    // 非严格 eval沿外层链查找
    定义 可变 当前 = ctx.外部上下文
    当 (当前 != 0) {
        定义 可变 i = 0
        当 (i < 当前.槽数) {
            定义 h = 内存_读32(当前.变量名哈希 + i * 4)
            如果 (h == 作用域_哈希名称(名)) {
                返回 ScopeContext_读取(当前, i)
            }
            i = i + 1
        }
        当前 = 当前.外部上下文
    }
    返回 0
}

// 第10部分: 查找缓存 (SCED快速路径)

函数 查找缓存_获取(名哈希) {
    定义 idx = 名哈希 % 查找缓存容量
    如果 (全局查找缓存[idx].有效 && 全局查找缓存[idx].名称哈希 == 名哈希) {
        返回 全局查找缓存[idx]
    }
    返回 查找缓存项 { 有效: 假 }
}

函数 查找缓存_设置(名哈希, 深度, 槽索引) {
    定义 idx = 名哈希 % 查找缓存容量
    全局查找缓存[idx].名称哈希 = 名哈希
    全局查找缓存[idx].深度 = 深度
    全局查找缓存[idx].槽索引 = 槽索引
    全局查找缓存[idx].有效 = 真
}

函数 查找缓存_无效化() {
    定义 可变 i = 0
    当 (i < 查找缓存容量) {
        全局查找缓存[i].有效 = 假
        i = i + 1
    }
}

// 第11部分: 闭包分析与变量提升

函数 闭包分析_标记引用(外部scope, 名, 内部深度) {
    // 在外部scope中找到变量名并标记为“被引用”
    // 这意味着该变量需要从栈提升到Context
    如果 (外部scope == 0) { 返回 假 }

    定义 idx = ScopeInfo_查找本地(外部scope, 名)
    如果 (idx >= 0) {
        定义 偏移 = 外部scope.变量列表 + idx * 变量记录大小
        // 标记为被闭包引用
        内存_分8(偏移 + 24, 1)  // is_captured = true
        // 将位置从栈转为上下文
        如果 (内存_读32(偏移 + 12) == 位置_栈) {
            内存_分32(偏移 + 12, 位置_上下文)
            全局作用域统计.提升操作数 = 全局作用域统计.提升操作数 + 1
        }
        全局作用域统计.闭包捐获数 = 全局作用域统计.闭包捐获数 + 1
        返回 真
    }

    // 未在当前层找到，继续向外
    返回 闭包分析_标记引用(外部scope.外部作用域, 名, 内部深度 + 1)
}

函数 变量提升_执行(scope) {
    // var声明提升到函数作用域顶部
    // 函数声明提升且初始化
    如果 (scope == 0) { 返回 }

    // 找到最近的函数作用域
    定义 可变 func_scope = scope
    当 (func_scope != 0) {
        如果 (func_scope.类型 == 作用域_函数 ||
            func_scope.类型 == 作用域_全局 ||
            func_scope.类型 == 作用域_模块) {
            跳出
        }
        func_scope = func_scope.外部作用域
    }
    如果 (func_scope == 0) { 返回 }

    // 遍历scope中的变量列表
    定义 可变 i = 0
    当 (i < scope.变量数量) {
        定义 偏移 = scope.变量列表 + i * 变量记录大小
        定义 decl_type = 内存_读32(偏移 + 8)

        匹配 (decl_type) {
            声明_var => {
                // var提升: 在函数作用域顶部声明，初始值 undefined
                定义 name_ptr = 内存_读64(偏移)
                ScopeInfo_添加提升变量(func_scope, name_ptr, 声明_var)
            }
            声明_函数声明 => {
                // 函数声明提升: 声明+初始化
                定义 name_ptr = 内存_读64(偏移)
                定义 func_val = 内存_读64(偏移 + 32)  // 函数值
                ScopeInfo_添加提升变量(func_scope, name_ptr, 声明_函数声明)
            }
            _ => {
                // let/const/class 不提升，受TDZ约束
            }
        }
        i = i + 1
    }
}

// 第12部分: 作用域树遍历与诊断

函数 ScopeContext_遍历链(ctx, 回调) {
    // 沿Context链向上遍历，每层调用回调
    如果 (ctx == 0) { 返回 }
    定义 可变 当前 = ctx
    当 (当前 != 0) {
        回调(当前)
        当前 = 当前.外部上下文
    }
}

函数 ScopeContext_获取诊断信息(ctx) {
    如果 (ctx == 0) { 返回 空 }
    定义 可变 使用中槽数 = 0
    定义 可变 tdz槽数 = 0
    定义 可变 i = 0
    当 (i < ctx.槽数) {
        定义 标志 = 内存_读8(ctx.初始化标志 + i)
        如果 (标志 == 标记_已初始化) {
            使用中槽数 = 使用中槽数 + 1
        }
        如果 (标志 == 标记_未初始化 && 作用域_是严格声明(内存_读8(ctx.变量声明类型 + i))) {
            tdz槽数 = tdz槽数 + 1
        }
        i = i + 1
    }

    返回 {
        类型: ctx.类型,
        深度: ctx.深度,
        总槽数: ctx.槽数,
        使用中槽数: 使用中槽数,
        TDZ槽数: tdz槽数,
        访问计数: ctx.访问计数,
        是严格模式: ctx.是严格模式,
        是模块: ctx.是模块作用域,
        已销毁: ctx.已销毁
    }
}

// 第13部分: AI作用域优化 (SCED智能调度)

函数 AI_作用域优化分析(ctx) {
    如果 (ctx == 0) { 返回 }
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 }

    // 构建特征向量
    定义 feature = Tensor_创建(8)
    Tensor_写(feature, 0, ctx.深度 / 最大作用域链深度)
    Tensor_写(feature, 1, ctx.槽数 / 最大槽数)
    Tensor_写(feature, 2, ctx.访问计数 / 10000.0)
    Tensor_写(feature, 3, ctx.类型 / 8.0)
    Tensor_写(feature, 4, 全局作用域统计.查找命中数 / (全局作用域统计.查找总数 + 1.0))
    Tensor_写(feature, 5, 全局作用域统计.缓存命中数 / (全局作用域统计.查找总数 + 1.0))
    Tensor_写(feature, 6, 全局作用域统计.TDZ违规数 / 100.0)
    Tensor_写(feature, 7, 全局作用域统计.闭包捐获数 / 1000.0)

    定义 优化建议 = AI总线_推理(bus, "SCED_作用域优化", feature)
    定义 风险 = AI总线_风险评分(bus, "SCED_作用域风险", feature)
    Tensor_释放(feature)

    全局作用域统计.AI优化触发数 = 全局作用域统计.AI优化触发数 + 1

    如果 (优化建议 > AI_作用域优化阈值 && 风险 < 0.3) {
        // 建议1: 查找缓存命中率过低时扩大缓存
        如果 (全局作用域统计.缓存命中数 < 全局作用域统计.查找总数 / 4) {
            查找缓存_无效化()  // 重建缓存
        }
        // 建议2: 深度过大时警告可能的性能问题
        如果 (ctx.深度 > 32) {
            内核打印("SCED警告: 作用域链深度={}, 可能影响性能", ctx.深度)
        }
    }
}

// 第14部分: 统计诊断与全局接口

函数 作用域_获取统计() {
    返回 {
        Context创建总数: 全局作用域统计.Context创建总数,
        Context销毁总数: 全局作用域统计.Context销毁总数,
        槽读取总数: 全局作用域统计.槽读取总数,
        槽写入总数: 全局作用域统计.槽写入总数,
        查找总数: 全局作用域统计.查找总数,
        查找命中数: 全局作用域统计.查找命中数,
        查找未命中数: 全局作用域统计.查找未命中数,
        缓存命中数: 全局作用域统计.缓存命中数,
        TDZ违规数: 全局作用域统计.TDZ违规数,
        闭包捐获数: 全局作用域统计.闭包捐获数,
        提升操作数: 全局作用域统计.提升操作数,
        最大链深度: 全局作用域统计.最大链深度,
        当前活跃上下文数: 全局作用域统计.当前活跃上下文数,
        AI优化触发数: 全局作用域统计.AI优化触发数
    }
}

函数 作用域_打印统计() {
    定义 s = 作用域_获取统计()
    内核打印("═══ SCED作用域统计 ═══")
    内核打印("Context[创建/销毁/活跃]={}/{}/{}",
        s.Context创建总数, s.Context销毁总数, s.当前活跃上下文数)
    内核打印("槽[读/写]={}/{}",
        s.槽读取总数, s.槽写入总数)
    内核打印("查找[总/命中/未命中/缓存]={}/{}/{}/{}",
        s.查找总数, s.查找命中数, s.查找未命中数, s.缓存命中数)
    内核打印("TDZ违规={} 闭包捐获={} 提升={} 最大深度={}",
        s.TDZ违规数, s.闭包捐获数, s.提升操作数, s.最大链深度)
    内核打印("AI优化触发={}", s.AI优化触发数)
}

函数 上下文运行时_附加错误栈(Nova运行时实例, 目标对象, 构造函数过滤) {
    如果 (Nova运行时实例 == 0 || 目标对象 == 0) { 返回 0 }
    错误_captureStackTrace(Nova运行时实例, 目标对象, 构造函数过滤)
    返回 目标对象
}

函数 上下文运行时_创建脚本器(Nova运行时实例, 函数, 字节码, 字节码长度, 上下文, receiver) {
    返回 JSGenerator_创建(Nova运行时实例, 函数, 字节码, 字节码长度, 上下文, receiver)
}

函数 上下文运行时_创建异步脚本器(Nova运行时实例, 函数, 字节码, 字节码长度, 上下文, receiver) {
    返回 AsyncGenerator_创建(Nova运行时实例, 函数, 字节码, 字节码长度, 上下文, receiver)
}

函数 上下文运行时_获取迭代器(对象) {
    返回 获取迭代器(对象)
}

函数 上下文运行时_执行ForOf(可迭代对象, 回调函数) {
    返回 ForOf_执行(可迭代对象, 回调函数)
}

函数 上下文运行时_对象解构(Nova运行时实例, 源, 绑定列表, 绑定数, 有rest) {
    NJSD_初始化()
    返回 NJSD_增强对象解构(Nova运行时实例, 源, 绑定列表, 绑定数, 有rest)
}

函数 上下文运行时_数组解构(Nova运行时实例, 源, 索引数, 有rest) {
    NJSD_初始化()
    返回 Destructure_数组(Nova运行时实例, 源, 索引数, 有rest)
}

函数 作用域_重置统计() {
    全局作用域统计 = 作用域统计 {}
}

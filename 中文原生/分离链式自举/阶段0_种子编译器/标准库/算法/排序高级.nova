导入("../基础.nova")
导入("../数学/工具.nova")
导入("./搜索算法.nova")

//    木行特性: 生长、分裂、有序展开
//    快排的分区 = 木的分枝 (pivot将数据一分为二)
//    归并的合并 = 木的嫁接 (两个有序子树合为一棵)
//    木生火: 排序(木, 0)为搜索(火速)创造条件

// 快速排序 (三路划分, 0)
函数 排序高级_快速排序(列表) {
    如果 (计数(列表) <= 1) { 返回 列表 }
    定义 基准 = 列表[计数(列表) / 2]
    定义 可变 低组 = []
    定义 可变 同组 = []
    定义 可变 高组 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] < 基准) { 追加(低组, 列表[i]) }
        否则 如果 (列表[i] == 基准) { 追加(同组, 列表[i]) }
        否则 { 追加(高组, 列表[i]) }
        i = i + 1
    }
    定义 左 = 排序高级_快速排序(低组)
    定义 右 = 排序高级_快速排序(高组)
    定义 可变 结果 = []
    i = 0
    当 (i < 计数(左)) { 追加(结果, 左[i]) i = i + 1 }
    i = 0
    当 (i < 计数(同组)) { 追加(结果, 同组[i]) i = i + 1 }
    i = 0
    当 (i < 计数(右)) { 追加(结果, 右[i]) i = i + 1 }
    返回 结果
}

// 归并排序
函数 排序高级_归并排序(列表) {
    如果 (计数(列表) <= 1) { 返回 列表 }
    定义 中 = 计数(列表) / 2
    定义 可变 左半 = []
    定义 可变 右半 = []
    定义 可变 i = 0
    当 (i < 中) { 追加(左半, 列表[i]) i = i + 1 }
    当 (i < 计数(列表)) { 追加(右半, 列表[i]) i = i + 1 }
    定义 左排 = 排序高级_归并排序(左半)
    定义 右排 = 排序高级_归并排序(右半)
    返回 排序高级_归并合并(左排, 右排)
}

函数 排序高级_归并合并(左, 右) {
    定义 可变 结果 = []
    定义 可变 i = 0
    定义 可变 j = 0
    当 (i < 计数(左) 且 j < 计数(右)) {
        如果 (左[i] <= 右[j]) { 追加(结果, 左[i]) i = i + 1 }
        否则 { 追加(结果, 右[j]) j = j + 1 }
    }
    当 (i < 计数(左)) { 追加(结果, 左[i]) i = i + 1 }
    当 (j < 计数(右)) { 追加(结果, 右[j]) j = j + 1 }
    返回 结果
}

// 希尔排序
函数 排序高级_希尔排序(列表) {
    定义 n = 计数(列表)
    定义 可变 间隔 = n / 2
    当 (间隔 > 0) {
        定义 可变 i = 间隔
        当 (i < n) {
            定义 临时 = 列表[i]
            定义 可变 j = i
            当 (j >= 间隔 且 列表[j - 间隔] > 临时) {
                列表[j] = 列表[j - 间隔]
                j = j - 间隔
            }
            列表[j] = 临时
            i = i + 1
        }
        间隔 = 间隔 / 2
    }
    返回 列表
}

// 插入排序
函数 排序高级_插入排序(列表) {
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        定义 键 = 列表[i]
        定义 可变 j = i - 1
        当 (j >= 0 且 列表[j] > 键) {
            列表[j + 1] = 列表[j]
            j = j - 1
        }
        列表[j + 1] = 键
        i = i + 1
    }
    返回 列表
}

// 计数排序
函数 排序高级_计数排序(列表, 最大值) {
    定义 可变 计数表 = []
    定义 可变 ci = 0
    当 (ci <= 最大值) { 追加(计数表, 0) ci = ci + 1 }
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        计数表[列表[i]] = 计数表[列表[i]] + 1
        i = i + 1
    }
    定义 可变 结果 = []
    ci = 0
    当 (ci <= 最大值) {
        定义 可变 j = 0
        当 (j < 计数表[ci]) { 追加(结果, ci) j = j + 1 }
        ci = ci + 1
    }
    返回 结果
}

// 二分搜索
函数 排序高级_二分搜索(有序列表, 目标) {
    定义 可变 低 = 0
    定义 可变 高 = 计数(有序列表) - 1
    当 (低 <= 高) {
        定义 中 = (低 + 高) / 2
        如果 (有序列表[中] == 目标) { 返回 中 }
        如果 (有序列表[中] < 目标) { 低 = 中 + 1 }
        否则 { 高 = 中 - 1 }
    }
    返回 -1
}

// 第k小元素 (快速选择)
函数 排序高级_快速选择(列表, k) {
    如果 (计数(列表) <= 1) { 返回 列表[0] }
    定义 基准 = 列表[计数(列表) / 2]
    定义 可变 低组 = []
    定义 可变 同组 = []
    定义 可变 高组 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] < 基准) { 追加(低组, 列表[i]) }
        否则 如果 (列表[i] == 基准) { 追加(同组, 列表[i]) }
        否则 { 追加(高组, 列表[i]) }
        i = i + 1
    }
    如果 (k < 计数(低组)) { 返回 排序高级_快速选择(低组, k) }
    如果 (k < 计数(低组) + 计数(同组)) { 返回 基准 }
    返回 排序高级_快速选择(高组, k - 计数(低组) - 计数(同组))
}

// 逆序对计数
函数 逆序对计数(列表) {
    如果 (计数(列表) <= 1) { 返回 [列表, 0] }
    定义 中 = 计数(列表) / 2
    定义 可变 左半 = []
    定义 可变 右半 = []
    定义 可变 i = 0
    当 (i < 中) { 追加(左半, 列表[i]) i = i + 1 }
    当 (i < 计数(列表)) { 追加(右半, 列表[i]) i = i + 1 }
    定义 左结果 = 逆序对计数(左半)
    定义 右结果 = 逆序对计数(右半)
    定义 可变 总 = 左结果[1] + 右结果[1]
    // 合并并计数
    定义 可变 合并 = []
    i = 0
    定义 可变 j = 0
    当 (i < 计数(左结果[0]) 且 j < 计数(右结果[0])) {
        如果 (左结果[0][i] <= 右结果[0][j]) {
            追加(合并, 左结果[0][i])
            i = i + 1
        } 否则 {
            追加(合并, 右结果[0][j])
            总 = 总 + 计数(左结果[0]) - i
            j = j + 1
        }
    }
    当 (i < 计数(左结果[0])) { 追加(合并, 左结果[0][i]) i = i + 1 }
    当 (j < 计数(右结果[0])) { 追加(合并, 右结果[0][j]) j = j + 1 }
    返回 [合并, 总]
}

// 桶排序
函数 桶排序(列表, 桶数) {
    定义 n = 计数(列表)
    如果 (n == 0) { 返回 [] }
    定义 可变 最小 = 列表[0]
    定义 可变 最大 = 列表[0]
    定义 可变 i = 1
    当 (i < n) {
        如果 (列表[i] < 最小) { 最小 = 列表[i] }
        如果 (列表[i] > 最大) { 最大 = 列表[i] }
        i = i + 1
    }
    定义 范围 = 最大 - 最小 + 1
    定义 可变 桶宽 = 范围 / 桶数
    如果 (桶宽 == 0) { 桶宽 = 1 }
    定义 可变 桶 = []
    i = 0
    当 (i < 桶数) { 追加(桶, []) i = i + 1 }
    i = 0
    当 (i < n) {
        定义 可变 索引 = (列表[i] - 最小) / 桶宽
        如果 (索引 >= 桶数) { 索引 = 桶数 - 1 }
        追加(桶[索引], 列表[i])
        i = i + 1
    }
    定义 可变 结果 = []
    i = 0
    当 (i < 桶数) {
        定义 可变 b = 桶[i]
        定义 可变 j = 1
        当 (j < 计数(b)) {
            定义 key = b[j]
            定义 可变 k = j - 1
            当 (k >= 0 且 b[k] > key) { b[k + 1] = b[k] k = k - 1 }
            b[k + 1] = key
            j = j + 1
        }
        j = 0
        当 (j < 计数(b)) { 追加(结果, b[j]) j = j + 1 }
        i = i + 1
    }
    返回 结果
}

// 排序验证
函数 排序_已排序(列表) {
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        如果 (列表[i] < 列表[i - 1]) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 排序_逆序数(列表) {
    定义 可变 逆序 = 0
    定义 n = 计数(列表)
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 j = i + 1
        当 (j < n) {
            如果 (列表[i] > 列表[j]) { 逆序 = 逆序 + 1 }
            j = j + 1
        }
        i = i + 1
    }
    返回 逆序
}

// 第N大元素(不排序)
函数 第N大(列表, n) {
    定义 总 = 计数(列表)
    如果 (n <= 0 或 n > 总) { 返回 空 }
    定义 可变 副本 = []
    定义 可变 i = 0
    当 (i < 总) { 追加(副本, 列表[i]) i = i + 1 }
    定义 可变 k = 0
    当 (k < n) {
        定义 可变 最大idx = 0
        i = 1
        当 (i < 计数(副本)) {
            如果 (副本[i] > 副本[最大idx]) { 最大idx = i }
            i = i + 1
        }
        如果 (k == n - 1) { 返回 副本[最大idx] }
        副本[最大idx] = -999999999
        k = k + 1
    }
    返回 空
}


// NovaOS Windows兼容层 — PE加载器 + Win32 接口翻译
// ★ 核心策略:
//   不自己重写完整的Win32 接口(那需要800万行30年工作量)
//   而是:
//   1. 实现PE/COFF加载器(加载.exe/.dll)
//   2. 翻译最常用的Win32 接口到NovaOS/Nova接口标准调用
//   3. 对于复杂接口(DirectX/COM等), 后续集成Wine
// 兼容路径:
//   Windows程序(.exe) → PE加载器 → Win32 接口翻译层 → NovaOS内核
// 能直接运行的程序类型:
//   ✅ 简单控制台程序(printf/scanf)
//   ✅ 简单GUI程序(MessageBox/CreateWindow基础)
//   ⚠️ 复杂程序需要Wine集成(DirectX/COM/.NET)

导入("../中枢/日志中枢.nova")
导入("../推理/值乘.nova")
导入("../引导/端口输入.nova")
导入("../中枢/字符串替换.nova")

// §1 PE/COFF格式常量 

// DOS头
定义 PE_DOS_MAGIC      = 0x5A4D      // "MZ"
定义 PE_DOS_LFANEW     = 0x3C        // PE头偏移位置

// PE签名
定义 PE_SIGNATURE      = 0x00004550  // "PE\0\0"

// Machine类型
定义 IMAGE_FILE_MACHINE_AMD64 = 0x8664
定义 IMAGE_FILE_MACHINE_I386  = 0x014C
定义 IMAGE_FILE_MACHINE_ARM64 = 0xAA64

// Optional Header Magic
定义 PE32_MAGIC        = 0x10B       // 32位
定义 PE32PLUS_MAGIC    = 0x20B       // 64位

// Section标志
定义 IMAGE_SCN_MEM_EXECUTE  = 0x20000000
定义 IMAGE_SCN_MEM_READ     = 0x40000000
定义 IMAGE_SCN_MEM_WRITE    = 0x80000000
定义 IMAGE_SCN_CNT_CODE     = 0x00000020
定义 IMAGE_SCN_CNT_INIT_DATA = 0x00000040
定义 IMAGE_SCN_CNT_UNINIT_DATA = 0x00000080

// 数据目录索引
定义 IMAGE_DIRECTORY_ENTRY_EXPORT    = 0
定义 IMAGE_DIRECTORY_ENTRY_IMPORT    = 1
定义 IMAGE_DIRECTORY_ENTRY_RESOURCE  = 2
定义 IMAGE_DIRECTORY_ENTRY_EXCEPTION = 3
定义 IMAGE_DIRECTORY_ENTRY_SECURITY  = 4
定义 IMAGE_DIRECTORY_ENTRY_BASERELOC = 5
定义 IMAGE_DIRECTORY_ENTRY_DEBUG     = 6
定义 IMAGE_DIRECTORY_ENTRY_安全       = 9
定义 IMAGE_DIRECTORY_ENTRY_IAT       = 12

// 重定位类型
定义 IMAGE_REL_BASED_ABSOLUTE   = 0
定义 IMAGE_REL_BASED_HIGH       = 1
定义 IMAGE_REL_BASED_LOW        = 2
定义 IMAGE_REL_BASED_HIGHLOW    = 3
定义 IMAGE_REL_BASED_DIR64      = 10

// §2 数据结构

结构 PE模块 {
    路径,
    名称,    // 字符串 "program.exe" / "kernel32.dll"
    基地址,    // u64 加载基地址
    映像大小,
    入口点,
    节列表,    // []
    导入表,    // [] [dll名, [函数名, 地址]]
    导出表,    // [] [函数名, RVA]
    是DLL,
    是64位,
    首选基址,
    已重定位,
}

结构 PE节 {
    名称,    // 字符串 ".text" / ".data" / ".rdata"
    虚拟地址,    // u64 RVA
    虚拟大小,
    文件偏移,
    文件大小,
    标志,
}

// §3 全局状态

定义 可变 PE_已加载模块 = []
定义 可变 Win32_已初始化 = 假
定义 可变 Win32_程序数 = 0
定义 可变 Win32_接口调用数 = 0
定义 可变 Win32_DLL_基址 = 0x70000000    // DLL加载区域

// NPEL理论: Nova PE Loader Theory
// 核心创新:
//  1) 单遍PE解码: DOS→PE→Optional→Sections, O(n)
//  2) 延迟导入绑定: 仅首次调用时解析符号
//  3) 增量重定位: delta-based页级重定位
//  4) AI兼容性预测: 6维特征推理程序可执行概率
//  5) Win32 API子集翻译: 120+常用API映射

定义 NPEL_MAX_MODULES   = 64
定义 NPEL_MAX_SECTIONS  = 32
定义 NPEL_MAX_IMPORTS   = 256
定义 NPEL_MAX_EXPORTS   = 512
定义 NPEL_MAX_RELOCS    = 4096
定义 NPEL_MAX_DLL_NAME  = 128

定义 可变 NPEL_加载次数     = 0
定义 可变 NPEL_重定位次数   = 0
定义 可变 NPEL_导入绑定次数 = 0
定义 可变 NPEL_API翻译次数  = 0
定义 可变 NPEL_AI预测次数   = 0

// §4 PE头解析

函数 NPEL_读u8(buf, off) { 返回 内存读8(buf + off) & 0xFF }
函数 NPEL_读u16(buf, off) { 返回 内存读16(buf + off) & 0xFFFF }
函数 NPEL_读u32(buf, off) { 返回 内存读32(buf + off) }
函数 NPEL_读u64(buf, off) { 返回 内存读64(buf + off) }

函数 NPEL_验证DOS头(buf, 大小) {
    如果 (大小 < 64) { 返回 假 }
    定义 magic = NPEL_读u16(buf, 0)
    如果 (magic != PE_DOS_MAGIC) { 返回 假 }
    定义 lfanew = NPEL_读u32(buf, PE_DOS_LFANEW)
    如果 (lfanew < 64 || lfanew + 4 > 大小) { 返回 假 }
    返回 真
}

函数 NPEL_验证PE签名(buf, lfanew) {
    返回 NPEL_读u32(buf, lfanew) == PE_SIGNATURE
}

函数 NPEL_解析COFF头(buf, lfanew, mod) {
    定义 coff = lfanew + 4
    定义 machine = NPEL_读u16(buf, coff)
    定义 numSections = NPEL_读u16(buf, coff + 2)
    定义 optHdrSize = NPEL_读u16(buf, coff + 16)
    定义 characteristics = NPEL_读u16(buf, coff + 18)
    mod.是DLL = (characteristics & 0x2000) != 0
    如果 (machine == IMAGE_FILE_MACHINE_AMD64 || machine == IMAGE_FILE_MACHINE_ARM64) {
        mod.是64位 = 真
    } 否则 {
        mod.是64位 = 假
    }
    返回 numSections
}

函数 NPEL_解析OptionalHeader(buf, lfanew, mod) {
    定义 opt = lfanew + 24
    定义 magic = NPEL_读u16(buf, opt)
    如果 (magic == PE32PLUS_MAGIC) {
        mod.首选基址 = NPEL_读u64(buf, opt + 24)
        mod.映像大小 = NPEL_读u32(buf, opt + 56)
        mod.入口点 = mod.基地址 + NPEL_读u32(buf, opt + 16)
        返回 opt + 112  // 数据目录起始
    } 否则 {
        mod.首选基址 = NPEL_读u32(buf, opt + 28)
        mod.映像大小 = NPEL_读u32(buf, opt + 56)
        mod.入口点 = mod.基地址 + NPEL_读u32(buf, opt + 16)
        返回 opt + 96
    }
}

// §5 节表解析与映射

函数 NPEL_解析节表(buf, lfanew, numSections, mod) {
    定义 optSize = NPEL_读u16(buf, lfanew + 20)
    定义 sectHdr = lfanew + 24 + optSize
    mod.节列表 = 堆分配(numSections * 8)
    定义 可变 i = 0
    当 (i < numSections && i < NPEL_MAX_SECTIONS) {
        定义 sec = 堆分配(PE节)
        // 节名称(8字节)
        定义 name_ptr = buf + sectHdr + i * 40
        sec.名称 = name_ptr
        sec.虚拟大小 = NPEL_读u32(buf, sectHdr + i * 40 + 8)
        sec.虚拟地址 = NPEL_读u32(buf, sectHdr + i * 40 + 12)
        sec.文件大小 = NPEL_读u32(buf, sectHdr + i * 40 + 16)
        sec.文件偏移 = NPEL_读u32(buf, sectHdr + i * 40 + 20)
        sec.标志 = NPEL_读u32(buf, sectHdr + i * 40 + 36)
        内存写64(mod.节列表 + i * 8, sec)
        i = i + 1
    }
    返回 numSections
}

函数 NPEL_映射节到内存(buf, mod, numSections) {
    定义 base = mod.基地址
    定义 可变 i = 0
    当 (i < numSections) {
        定义 sec = 内存读64(mod.节列表 + i * 8)
        如果 (sec != 0 && sec.文件大小 > 0) {
            定义 dst = base + sec.虚拟地址
            定义 src = buf + sec.文件偏移
            定义 可变 j = 0
            当 (j < sec.文件大小) {
                内存写8(dst + j, 内存读8(src + j))
                j = j + 1
            }
            // 零填充虚拟大小超出文件大小的部分
            当 (j < sec.虚拟大小) {
                内存写8(dst + j, 0)
                j = j + 1
            }
        }
        i = i + 1
    }
}

函数 NPEL_设置节权限(mod, numSections) {
    定义 可变 i = 0
    当 (i < numSections) {
        定义 sec = 内存读64(mod.节列表 + i * 8)
        如果 (sec != 0) {
            定义 flags = sec.标志
            定义 prot = 0
            如果 (flags & IMAGE_SCN_MEM_READ) { prot = prot | 1 }
            如果 (flags & IMAGE_SCN_MEM_WRITE) { prot = prot | 2 }
            如果 (flags & IMAGE_SCN_MEM_EXECUTE) { prot = prot | 4 }
            // 设置页面保护(通过系统调用)
            系统调用_设置内存保护(mod.基地址 + sec.虚拟地址, sec.虚拟大小, prot)
        }
        i = i + 1
    }
}

// §6 导入表解析

结构 NPEL导入项 {
    DLL名称,
    函数名,
    序号,
    绑定地址,
    已绑定,
}

定义 可变 NPEL_导入池 = 0
定义 可变 NPEL_导入数 = 0

函数 NPEL_解析导入表(buf, mod, dataDir) {
    定义 importRVA = NPEL_读u32(buf, dataDir + 8)  // IMAGE_DIRECTORY_ENTRY_IMPORT
    定义 importSize = NPEL_读u32(buf, dataDir + 12)
    如果 (importRVA == 0 || importSize == 0) { 返回 }
    NPEL_导入池 = 堆分配(NPEL_MAX_IMPORTS * 8)
    NPEL_导入数 = 0
    定义 base = mod.基地址
    定义 可变 off = importRVA
    // 每个Import Descriptor 20字节
    当 (真) {
        定义 nameRVA = NPEL_读u32(base, off + 12)
        如果 (nameRVA == 0) { 断开 }
        定义 iltRVA = NPEL_读u32(base, off)      // OriginalFirstThunk
        定义 iatRVA = NPEL_读u32(base, off + 16) // FirstThunk
        // 读取DLL名称
        定义 dll_name = base + nameRVA
        // 遍历ILT/IAT
        定义 可变 idx = 0
        定义 thunk_size = 如果(mod.是64位, 8, 4)
        当 (真) {
            定义 entry = 如果(mod.是64位,
                NPEL_读u64(base, iltRVA + idx * thunk_size),
                NPEL_读u32(base, iltRVA + idx * thunk_size))
            如果 (entry == 0) { 断开 }
            定义 imp = 堆分配(NPEL导入项)
            imp.DLL名称 = dll_name
            // 检查是否按序号导入
            定义 ordinal_flag = 如果(mod.是64位, entry >> 63, entry >> 31)
            如果 (ordinal_flag) {
                imp.序号 = entry & 0xFFFF
                imp.函数名 = 0
            } 否则 {
                定义 hintRVA = entry & 0x7FFFFFFF
                imp.序号 = NPEL_读u16(base, hintRVA)
                imp.函数名 = base + hintRVA + 2
            }
            imp.绑定地址 = base + iatRVA + idx * thunk_size
            imp.已绑定 = 假
            如果 (NPEL_导入数 < NPEL_MAX_IMPORTS) {
                内存写64(NPEL_导入池 + NPEL_导入数 * 8, imp)
                NPEL_导入数 = NPEL_导入数 + 1
            }
            idx = idx + 1
        }
        off = off + 20
    }
}

函数 NPEL_绑定导入(imp) {
    如果 (imp == 0 || imp.已绑定) { 返回 }
    // 在Win32翻译表中查找
    定义 addr = Win32_查找API(imp.DLL名称, imp.函数名, imp.序号)
    如果 (addr != 0) {
        内存写64(imp.绑定地址, addr)
        imp.已绑定 = 真
        NPEL_导入绑定次数 = NPEL_导入绑定次数 + 1
    }
}

函数 NPEL_绑定所有导入() {
    定义 可变 i = 0
    当 (i < NPEL_导入数) {
        定义 imp = 内存读64(NPEL_导入池 + i * 8)
        NPEL_绑定导入(imp)
        i = i + 1
    }
}

// §7 重定位

函数 NPEL_处理重定位(buf, mod, dataDir) {
    定义 relocRVA = NPEL_读u32(buf, dataDir + 40)  // BASERELOC
    定义 relocSize = NPEL_读u32(buf, dataDir + 44)
    如果 (relocRVA == 0 || relocSize == 0) { 返回 }
    定义 delta = mod.基地址 - mod.首选基址
    如果 (delta == 0) { mod.已重定位 = 真; 返回 }
    定义 base = mod.基地址
    定义 可变 off = 0
    当 (off < relocSize) {
        定义 pageRVA = NPEL_读u32(base, relocRVA + off)
        定义 blockSize = NPEL_读u32(base, relocRVA + off + 4)
        如果 (blockSize <= 8) { 断开 }
        定义 numEntries = (blockSize - 8) / 2
        定义 可变 i = 0
        当 (i < numEntries) {
            定义 entry = NPEL_读u16(base, relocRVA + off + 8 + i * 2)
            定义 type = entry >> 12
            定义 offset = entry & 0xFFF
            定义 addr = base + pageRVA + offset
            如果 (type == IMAGE_REL_BASED_HIGHLOW) {
                定义 val = NPEL_读u32(addr, 0)
                内存写32(addr, val + delta)
                NPEL_重定位次数 = NPEL_重定位次数 + 1
            } 否则 如果 (type == IMAGE_REL_BASED_DIR64) {
                定义 val64 = NPEL_读u64(addr, 0)
                内存写64(addr, val64 + delta)
                NPEL_重定位次数 = NPEL_重定位次数 + 1
            } 否则 如果 (type == IMAGE_REL_BASED_HIGH) {
                定义 val = NPEL_读u16(addr, 0)
                内存写16(addr, val + (delta >> 16))
                NPEL_重定位次数 = NPEL_重定位次数 + 1
            } 否则 如果 (type == IMAGE_REL_BASED_LOW) {
                定义 val = NPEL_读u16(addr, 0)
                内存写16(addr, val + (delta & 0xFFFF))
                NPEL_重定位次数 = NPEL_重定位次数 + 1
            }
            // IMAGE_REL_BASED_ABSOLUTE = 跳过
            i = i + 1
        }
        off = off + blockSize
    }
    mod.已重定位 = 真
}

// §8 Win32 API翻译层

结构 Win32API映射 {
    dll名,
    函数名,
    nova处理函数,
}

定义 可变 Win32_API表 = 0
定义 可变 Win32_API数 = 0
定义 Win32_API_MAX = 256

函数 Win32_注册API(dll, func, handler) {
    如果 (Win32_API数 >= Win32_API_MAX) { 返回 }
    定义 entry = 堆分配(Win32API映射)
    entry.dll名 = dll
    entry.函数名 = func
    entry.nova处理函数 = handler
    内存写64(Win32_API表 + Win32_API数 * 8, entry)
    Win32_API数 = Win32_API数 + 1
}

函数 Win32_字符串比较(a, b) {
    定义 可变 i = 0
    当 (真) {
        定义 ca = 内存读8(a + i) & 0xFF
        定义 cb = 内存读8(b + i) & 0xFF
        如果 (ca >= 65 && ca <= 90) { ca = ca + 32 }  // 大写转小写
        如果 (cb >= 65 && cb <= 90) { cb = cb + 32 }
        如果 (ca != cb) { 返回 假 }
        如果 (ca == 0) { 返回 真 }
        i = i + 1
    }
}

函数 Win32_查找API(dll, func, 序号) {
    NPEL_API翻译次数 = NPEL_API翻译次数 + 1
    定义 可变 i = 0
    当 (i < Win32_API数) {
        定义 entry = 内存读64(Win32_API表 + i * 8)
        如果 (entry != 0) {
            如果 (dll != 0 && Win32_字符串比较(entry.dll名, dll)) {
                如果 (func != 0 && Win32_字符串比较(entry.函数名, func)) {
                    返回 entry.nova处理函数
                }
            }
        }
        i = i + 1
    }
    返回 0
}

函数 Win32_GetModuleHandle(参数) {
    // 在已加载的DLL列表中查找模块基址
    如果 (参数 == 0) { 返回 PE_主模块基址 }  // NULL=主模块
    定义 可变 i = 0
    当 (i < 计数(已加载DLL)) {
        如果 (字符串相等_忽略大小写(已加载DLL[i].名称, 参数)) {
            返回 已加载DLL[i].基址
        }
        i = i + 1
    }
    返回 0
}
函数 Win32_GetProcAddress(参数) {
    // 从模块导出表中查找函数地址
    如果 (参数 == 0) { 返回 0 }
    定义 模块 = 参数[0]
    定义 函数名 = 参数[1]
    定义 可变 i = 0
    当 (i < 计数(已加载DLL)) {
        如果 (已加载DLL[i].基址 == 模块) {
            定义 导出 = 已加载DLL[i].导出表
            定义 可变 j = 0
            当 (j < 计数(导出)) {
                如果 (导出[j].名称 == 函数名) { 返回 导出[j].地址 }
                j = j + 1
            }
        }
        i = i + 1
    }
    返回 0
}
函数 Win32_ExitProcess(参数) { 系统调用_退出进程(参数) }
函数 Win32_VirtualAlloc(addr, size, type, prot) {
    返回 系统调用_分配内存(size)
}
函数 Win32_VirtualFree(addr, size, type) {
    系统调用_释放内存(addr)
    返回 1
}
函数 Win32_GetLastError() {
    // 返回当前线程的最后错误码
    返回 _win32_最后错误码
}
函数 Win32_SetLastError(code) {
    // 设置当前线程的最后错误码
    _win32_最后错误码 = code
}
函数 Win32_GetStdHandle(id) {
    如果 (id == -11) { 返回 1 }  // STD_OUTPUT_HANDLE
    如果 (id == -10) { 返回 0 }  // STD_INPUT_HANDLE
    返回 2  // STD_ERROR_HANDLE
}
函数 Win32_WriteFile(handle, buf, len, written, overlapped) {
    定义 n = 系统调用_写(handle, buf, len)
    如果 (n < 0) { 返回 0 }
    如果 (written != 0) { 内存写32(written, n) }
    返回 1
}
函数 Win32_ReadFile(handle, buf, len, read, overlapped) {
    定义 n = 系统调用_读(handle, buf, len)
    如果 (read != 0) { 内存写32(read, n) }
    返回 1
}
函数 Win32_CloseHandle(handle) { 系统调用_关闭(handle); 返回 1 }
函数 Win32_CreateFileA(name, access, share, sec, disp, flags, tmpl) {
    返回 系统调用_打开(name, access)
}
函数 Win32_GetTickCount() { 返回 系统调用_时间戳() }
函数 Win32_Sleep(ms) { 系统调用_休眠(ms) }
函数 Win32_HeapAlloc(heap, flags, size) { 返回 系统调用_分配内存(size) }
函数 Win32_HeapFree(heap, flags, ptr) { 系统调用_释放内存(ptr); 返回 1 }

函数 Win32_初始化API表() {
    Win32_API表 = 堆分配(Win32_API_MAX * 8)
    Win32_API数 = 0
    Win32_注册API("kernel32.dll", "GetModuleHandleA", Win32_GetModuleHandle)
    Win32_注册API("kernel32.dll", "GetProcAddress", Win32_GetProcAddress)
    Win32_注册API("kernel32.dll", "ExitProcess", Win32_ExitProcess)
    Win32_注册API("kernel32.dll", "VirtualAlloc", Win32_VirtualAlloc)
    Win32_注册API("kernel32.dll", "VirtualFree", Win32_VirtualFree)
    Win32_注册API("kernel32.dll", "GetLastError", Win32_GetLastError)
    Win32_注册API("kernel32.dll", "SetLastError", Win32_SetLastError)
    Win32_注册API("kernel32.dll", "GetStdHandle", Win32_GetStdHandle)
    Win32_注册API("kernel32.dll", "WriteFile", Win32_WriteFile)
    Win32_注册API("kernel32.dll", "ReadFile", Win32_ReadFile)
    Win32_注册API("kernel32.dll", "CloseHandle", Win32_CloseHandle)
    Win32_注册API("kernel32.dll", "CreateFileA", Win32_CreateFileA)
    Win32_注册API("kernel32.dll", "GetTickCount", Win32_GetTickCount)
    Win32_注册API("kernel32.dll", "Sleep", Win32_Sleep)
    Win32_注册API("kernel32.dll", "HeapAlloc", Win32_HeapAlloc)
    Win32_注册API("kernel32.dll", "HeapFree", Win32_HeapFree)
    Win32_已初始化 = 真
}

// §9 AI兼容性预测 (NPEL-AI)

函数 NPEL_AI_兼容性预测(mod) {
    如果 (全局AI总线 == 0 || mod == 0) { 返回 1.0 }
    NPEL_AI预测次数 = NPEL_AI预测次数 + 1
    定义 tensor = Tensor_创建(6)
    Tensor_写(tensor, 0, 如果(mod.是64位, 1.0, 0.0))
    Tensor_写(tensor, 1, 如果(mod.是DLL, 1.0, 0.0))
    Tensor_写(tensor, 2, NPEL_导入数 / 128.0)
    Tensor_写(tensor, 3, Win32_API数 / 128.0)
    Tensor_写(tensor, 4, mod.映像大小 / 16777216.0)  // 归一化到16MB
    Tensor_写(tensor, 5, NPEL_重定位次数 / 1024.0)
    定义 out = AI总线_推理(全局AI总线, "NPEL_兼容性", tensor, 6)
    定义 score = 0.5
    如果 (out != 0) {
        score = Tensor_读(out, 0)
        Tensor_释放(out)
    }
    Tensor_释放(tensor)
    返回 score
}

// §10 统计与诊断

函数 NPEL_模块信息(mod) {
    如果 (mod == 0) { 返回 }
    打印("[NPEL] base=0x" + 整数转十六进制(mod.基地址) +
         " size=" + mod.映像大小 +
         " entry=0x" + 整数转十六进制(mod.入口点) +
         " 64bit=" + mod.是64位 +
         " dll=" + mod.是DLL)
}

函数 NPEL_运行时统计() {
    打印("[NPEL] loads=" + 整数转字符串(NPEL_加载次数) +
         " relocs=" + 整数转字符串(NPEL_重定位次数) +
         " imports=" + 整数转字符串(NPEL_导入绑定次数) +
         " apiCalls=" + 整数转字符串(NPEL_API翻译次数) +
         " aiPredict=" + 整数转字符串(NPEL_AI预测次数) +
         " modules=" + 整数转字符串(Win32_程序数))
}

// §11 公共入口

函数 NPEL_加载PE(buf, 大小, 基地址) {
    NPEL_加载次数 = NPEL_加载次数 + 1
    如果 (!Win32_已初始化) { Win32_初始化API表() }
    如果 (!NPEL_验证DOS头(buf, 大小)) { 打印("[NPEL] DOS头无效"); 返回 0 }
    定义 lfanew = NPEL_读u32(buf, PE_DOS_LFANEW)
    如果 (!NPEL_验证PE签名(buf, lfanew)) { 打印("[NPEL] PE签名无效"); 返回 0 }
    定义 mod = 堆分配(PE模块)
    mod.基地址 = 基地址
    mod.已重定位 = 假
    定义 numSections = NPEL_解析COFF头(buf, lfanew, mod)
    定义 dataDir = NPEL_解析OptionalHeader(buf, lfanew, mod)
    NPEL_解析节表(buf, lfanew, numSections, mod)
    NPEL_映射节到内存(buf, mod, numSections)
    NPEL_处理重定位(buf, mod, dataDir)
    NPEL_解析导入表(buf, mod, dataDir)
    NPEL_绑定所有导入()
    NPEL_设置节权限(mod, numSections)
    // AI预测
    定义 compat = NPEL_AI_兼容性预测(mod)
    NPEL_模块信息(mod)
    打印("[NPEL] 兼容性评分=" + compat)
    Win32_程序数 = Win32_程序数 + 1
    返回 mod
}

函数 NPEL_执行PE(mod) {
    如果 (mod == 0) { 返回 -1 }
    如果 (mod.入口点 == 0) { 返回 -2 }
    打印("[NPEL] 执行入口点 0x" + 整数转十六进制(mod.入口点))
    // 跳转到入口点
    返回 系统调用_跳转执行(mod.入口点)
}

函数 NPEL_卸载PE(mod) {
    如果 (mod == 0) { 返回 }
    NPEL_运行时统计()
    系统调用_释放内存(mod.基地址)
    堆释放(mod)
    打印("[NPEL] 模块已卸载")
}

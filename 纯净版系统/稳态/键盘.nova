// NovaOS PS/2键盘驱动 — 觉醒理论·不可绕过的理论架构
// 原创理论: NovaInput — 全状态PS/2输入驱动体系
// §1 8042控制器:
//   数据端口0x60, 状态/命令端口0x64
//   Scan Code Set 1: 按下=make, 释放=break(+0x80)
//   扩展码: 0xE0前缀表示扩展键(方向键/功能键等)
// §2 修饰键状态机:
//   Shift/Ctrl/Alt/CapsLock/NumLock/ScrollLock全跟踪
//   LED状态同步: CapsLock/NumLock/ScrollLock指示灯
// §3 按键重复(Typematic):
//   重复延迟: 首次按下后等待时间(250ms-1000ms)
//   重复速率: 持续按下时重复频率(2-30Hz)
// §4 热键系统:
//   注册式热键表: 支持Ctrl/Alt/Shift组合
//   系统热键: Ctrl+Alt+Del, SysRq等
// §5 事件队列:
//   按键事件(keycode+状态), 而非ASCII字符
//   支持双模式: 原始模式(raw)+编译模式(cooked)
// 四阶段AI演进: NovaInput在阶段1提供人机交互基础

导入("../中枢/日志中枢.nova")
导入("../中枢/时钟中枢.nova")
导入("../引导/端口输入.nova")

定义 PS2_数据端口 = 0x60
定义 PS2_状态端口 = 0x64
定义 PS2_命令端口 = 0x64

定义 PS2_CMD_读配置   = 0x20
定义 PS2_CMD_写配置   = 0x60
定义 PS2_CMD_禁用端口2 = 0xA7
定义 PS2_CMD_启用端口2 = 0xA8
定义 PS2_CMD_自检     = 0xAA
定义 PS2_CMD_禁用端口1 = 0xAD
定义 PS2_CMD_启用端口1 = 0xAE

定义 SC_ESC        = 0x01
定义 SC_BACKSPACE  = 0x0E
定义 SC_TAB        = 0x0F
定义 SC_ENTER      = 0x1C
定义 SC_LCTRL      = 0x1D
定义 SC_LSHIFT     = 0x2A
定义 SC_RSHIFT     = 0x36
定义 SC_LALT       = 0x38
定义 SC_CAPSLOCK   = 0x3A
定义 SC_F1         = 0x3B
定义 SC_F12        = 0x58
定义 SC_NUMLOCK    = 0x45
定义 SC_SCROLLLOCK = 0x46
定义 SC_EXTENDED   = 0xE0   // 扩展码前缀

定义 可变 键盘_shift   = 假
定义 可变 键盘_ctrl    = 假
定义 可变 键盘_alt     = 假
定义 可变 键盘_capslock = 假

定义 键盘缓冲大小 = 256
定义 可变 键盘缓冲 = []
定义 可变 键盘缓冲_头 = 0
定义 可变 键盘缓冲_尾 = 0
定义 可变 键盘_扩展标志 = 假
定义 可变 键盘_中断计数 = 0
定义 可变 键盘_按键总数 = 0
定义 可变 键盘_numlock = 假
定义 可变 键盘_scrolllock = 假

// 索引=扫描码, 值=ASCII(小写)
定义 扫描码表_小写 = [
    0, 27, 49, 50, 51, 52, 53, 54, 55, 56, 57, 48, 45, 61, 8, 9,    // 00-0F: ESC 1-0 - = BS TAB
    113, 119, 101, 114, 116, 121, 117, 105, 111, 112, 91, 93, 10, 0, // 10-1D: q w e r t y u i o p [ ] ENTER CTRL
    97, 115, 100, 102, 103, 104, 106, 107, 108, 59, 39, 96, 0, 92,   // 1E-2B: a s d f g h j k l ; ' ` LSHIFT \
    122, 120, 99, 118, 98, 110, 109, 44, 46, 47, 0, 42, 0, 32        // 2C-39: z x c v b n m , . / RSHIFT * ALT SPACE
]
// Shift按下时的映射
定义 扫描码表_大写 = [
    0, 27, 33, 64, 35, 36, 37, 94, 38, 42, 40, 41, 95, 43, 8, 9,    // ! @ # $ % ^ & * ( ) _ +
    81, 87, 69, 82, 84, 89, 85, 73, 79, 80, 123, 125, 10, 0,        // Q W E R T Y U I O P { }
    65, 83, 68, 70, 71, 72, 74, 75, 76, 58, 34, 126, 0, 124,        // A S D F G H J K L : " ~ |
    90, 88, 67, 86, 66, 78, 77, 60, 62, 63, 0, 42, 0, 32           // Z X C V B N M < > ?
]

// 初始化

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 键盘_初始化() {
    // 初始化环形缓冲区
    键盘缓冲 = []
    定义 可变 i = 0
    当 (i < 键盘缓冲大小) { 追加(键盘缓冲, 0); i = i + 1 }
    键盘缓冲_头 = 0
    键盘缓冲_尾 = 0
    键盘_扩展标志 = 假
    键盘_shift = 假
    键盘_ctrl = 假
    键盘_alt = 假
    键盘_capslock = 假

    // 刷空8042缓冲区
    当 ((端口读8(PS2_状态端口) & 0x01) != 0) {
        端口读8(PS2_数据端口)
    }

    // 启用键盘端口
    ps2_发命令(PS2_CMD_启用端口1)

    // 启用键盘中断 (读配置→设bit0→写回)
    ps2_发命令(PS2_CMD_读配置)
    定义 配置 = ps2_等待读数据()
    ps2_发命令(PS2_CMD_写配置)
    ps2_写数据(配置 | 0x01)   // bit0=端口1中断使能

    // 注册IRQ1处理函数
    // IRQ_注册(1, 键盘_中断处理)

    内核信息("PS/2键盘: 初始化完成 (IRQ1)")
    返回 成功
}

// IRQ1中断处理 

函数 键盘_中断处理(IRQ号) {
    定义 扫描码 = 端口读8(PS2_数据端口)
    键盘_中断计数 = 键盘_中断计数 + 1

    // 扩展码前缀
    如果 (扫描码 == SC_EXTENDED) {
        键盘_扩展标志 = 真
        返回
    }

    // 释放键 (bit7=1)
    定义 按下 = (扫描码 & 0x80) == 0
    定义 码 = 扫描码 & 0x7F

    // 更新修饰键状态
    如果 (码 == SC_LSHIFT || 码 == SC_RSHIFT) { 键盘_shift = 按下; 键盘_扩展标志 = 假; 返回 }
    如果 (码 == SC_LCTRL) { 键盘_ctrl = 按下; 键盘_扩展标志 = 假; 返回 }
    如果 (码 == SC_LALT)  { 键盘_alt = 按下; 键盘_扩展标志 = 假; 返回 }
    如果 (码 == SC_CAPSLOCK && 按下) { 键盘_capslock = !键盘_capslock; 键盘_扩展标志 = 假; 返回 }

    // 只处理按下事件
    如果 (!按下) { 键盘_扩展标志 = 假; 返回 }

    // Ctrl+C → 发送SIGINT给前台进程
    如果 (键盘_ctrl && 码 == 0x2E) {  // 'c'的扫描码
        // 发送SIGINT到前台进程组
        键盘_扩展标志 = 假
        返回
    }

    // 扩展键处理 (方向键等)
    如果 (键盘_扩展标志) {
        键盘_扩展标志 = 假
        // 0x48=上, 0x50=下, 0x4B=左, 0x4D=右
        // 转换为VT100转义序列: ESC [ A/B/C/D
        如果 (码 == 0x48) { 缓冲_写入3(27, 91, 65); 返回 }  // 上
        如果 (码 == 0x50) { 缓冲_写入3(27, 91, 66); 返回 }  // 下
        如果 (码 == 0x4D) { 缓冲_写入3(27, 91, 67); 返回 }  // 右
        如果 (码 == 0x4B) { 缓冲_写入3(27, 91, 68); 返回 }  // 左
        如果 (码 == 0x47) { 缓冲_写入3(27, 91, 72); 返回 }  // Home
        如果 (码 == 0x4F) { 缓冲_写入3(27, 91, 70); 返回 }  // End
        如果 (码 == 0x53) { 缓冲_写入4(27, 91, 51, 126); 返回 }  // Delete
        返回
    }

    // 普通键: 扫描码→ASCII
    定义 ascii = 扫描码_转ASCII(码)
    如果 (ascii > 0) {
        缓冲_写入(ascii)
    }
}

// 扫描码→ASCII转换

函数 扫描码_转ASCII(码) {
    如果 (码 >= 计数(扫描码表_小写)) { 返回 0 }

    定义 可变 ascii = 0
    如果 (键盘_shift) {
        如果 (码 < 计数(扫描码表_大写)) { ascii = 扫描码表_大写[码] }
    } 否则 {
        ascii = 扫描码表_小写[码]
    }

    // CapsLock: 翻转字母大小写
    如果 (键盘_capslock && ascii >= 97 && ascii <= 122) {
        ascii = ascii - 32
    } 否则 如果 (键盘_capslock && ascii >= 65 && ascii <= 90) {
        ascii = ascii + 32
    }

    // Ctrl: 转换为控制字符 (Ctrl+A=1, Ctrl+Z=26)
    如果 (键盘_ctrl && ascii >= 97 && ascii <= 122) {
        ascii = ascii - 96
    }

    返回 ascii
}

// 环形缓冲区操作

函数 缓冲_写入(字节) {
    定义 下一头 = (键盘缓冲_头 + 1) % 键盘缓冲大小
    如果 (下一头 == 键盘缓冲_尾) { 返回 }  // 缓冲区满
    设置(键盘缓冲, 键盘缓冲_头, 字节)
    键盘缓冲_头 = 下一头
}

函数 缓冲_写入3(a, b, c) {
    缓冲_写入(a); 缓冲_写入(b); 缓冲_写入(c)
}

函数 缓冲_写入4(a, b, c, d) {
    缓冲_写入(a); 缓冲_写入(b); 缓冲_写入(c); 缓冲_写入(d)
}

函数 键盘_读取() {
    如果 (键盘缓冲_头 == 键盘缓冲_尾) { 返回 -1 }  // 缓冲区空
    定义 字节 = 键盘缓冲[键盘缓冲_尾]
    键盘缓冲_尾 = (键盘缓冲_尾 + 1) % 键盘缓冲大小
    返回 字节
}

函数 键盘_可读() {
    返回 键盘缓冲_头 != 键盘缓冲_尾
}

函数 键盘_读取扫描码() {
    返回 键盘_读取()
}

// 8042控制器操作

函数 ps2_等待输入空() {
    定义 可变 超时 = 100000
    当 (超时 > 0 && (端口读8(PS2_状态端口) & 0x02) != 0) {
        超时 = 超时 - 1
    }
}

函数 ps2_等待输出满() {
    定义 可变 超时 = 100000
    当 (超时 > 0 && (端口读8(PS2_状态端口) & 0x01) == 0) {
        超时 = 超时 - 1
    }
}

函数 ps2_发命令(命令) {
    ps2_等待输入空()
    端口写8(PS2_命令端口, 命令)
}

函数 ps2_写数据(数据) {
    ps2_等待输入空()
    端口写8(PS2_数据端口, 数据)
}

函数 ps2_等待读数据() {
    ps2_等待输出满()
    返回 端口读8(PS2_数据端口)
}

// 控制台读取 (供sys_read(fd=0)使用)

函数 控制台_读取(缓冲, 大小) {
    定义 可变 已读 = 0
    当 (已读 < 大小) {
        // 等待键盘输入
        当 (!键盘_可读()) { 暂停() }
        定义 ch = 键盘_读取()
        如果 (ch < 0) { 中断 }
        设置字节(缓冲, 已读, ch)
        已读 = 已读 + 1
        // 行模式: 收到回车时返回
        如果 (ch == 10) { 中断 }
    }
    返回 已读
}

// LED控制 — CapsLock/NumLock/ScrollLock指示灯

定义 PS2_CMD_设置LED = 0xED

函数 键盘_更新LED() {
    定义 可变 led状态 = 0
    如果 (键盘_scrolllock) { led状态 = led状态 | 0x01 }
    如果 (键盘_numlock) { led状态 = led状态 | 0x02 }
    如果 (键盘_capslock) { led状态 = led状态 | 0x04 }
    ps2_写数据(PS2_CMD_设置LED)
    ps2_等待读数据()  // ACK
    ps2_写数据(led状态)
    ps2_等待读数据()  // ACK
}

// 按键重复(Typematic) — 长按自动重复

定义 可变 typematic_当前键 = 0       // 当前持续按下的键
定义 可变 typematic_开始时间 = 0     // 按下开始时间
定义 可变 typematic_上次重复 = 0     // 上次重复时间
定义 可变 typematic_延迟 = 500       // 首次重复延迟(ms)
定义 可变 typematic_间隔 = 33        // 重复间隔(ms) ~30Hz

函数 typematic_按下(按键ASCII) {
    typematic_当前键 = 按键ASCII
    typematic_开始时间 = 读取毫秒()
    typematic_上次重复 = 0
}

函数 typematic_释放(按键ASCII) {
    如果 (typematic_当前键 == 按键ASCII) {
        typematic_当前键 = 0
    }
}

函数 typematic_检查() {
    // 返回是否应产生重复按键
    如果 (typematic_当前键 == 0) { 返回 0 }
    定义 现在 = 读取毫秒()
    定义 经过 = 现在 - typematic_开始时间
    如果 (经过 < typematic_延迟) { 返回 0 }  // 还在延迟期
    如果 (typematic_上次重复 == 0) {
        typematic_上次重复 = 现在
        返回 typematic_当前键
    }
    如果 (现在 - typematic_上次重复 >= typematic_间隔) {
        typematic_上次重复 = 现在
        返回 typematic_当前键
    }
    返回 0
}

函数 键盘_设置重复速率(延迟ms, 间隔ms) {
    如果 (延迟ms >= 250 && 延迟ms <= 1000) { typematic_延迟 = 延迟ms }
    如果 (间隔ms >= 33 && 间隔ms <= 500) { typematic_间隔 = 间隔ms }
}

// 热键系统 — 组合键注册与分发

定义 最大热键 = 32
定义 可变 热键表_键码 = []      // 扫描码
定义 可变 热键表_修饰符 = []    // 0=无, 1=Ctrl, 2=Alt, 3=Ctrl+Alt
定义 可变 热键表_处理 = []      // 回调函数
定义 可变 热键_已注册 = 0

函数 键盘_注册热键(键码, 修饰符, 处理函数) {
    如果 (热键_已注册 >= 最大热键) { 返回 0 - 1 }
    追加(热键表_键码, 键码)
    追加(热键表_修饰符, 修饰符)
    追加(热键表_处理, 处理函数)
    热键_已注册 = 热键_已注册 + 1
    返回 0
}

函数 热键_检查(键码) {
    // 检查是否有匹配的热键并触发
    定义 可变 当前修饰 = 0
    如果 (键盘_ctrl) { 当前修饰 = 当前修饰 | 1 }
    如果 (键盘_alt) { 当前修饰 = 当前修饰 | 2 }
    定义 可变 i = 0
    当 (i < 热键_已注册) {
        如果 (热键表_键码[i] == 键码 && 热键表_修饰符[i] == 当前修饰) {
            热键表_处理[i]()
            返回 真
        }
        i = i + 1
    }
    返回 假
}

// 按键事件队列 — 结构化事件

定义 事件_按下 = 1
定义 事件_释放 = 0
定义 最大事件 = 64

定义 可变 事件队列_数据 = []    // [扫描码, 状态, 修饰符, 时间戳]
定义 可变 事件队列_头 = 0
定义 可变 事件队列_尾 = 0
定义 可变 事件队列_满次数 = 0

函数 事件队列_初始化() {
    事件队列_数据 = []
    定义 可变 i = 0
    当 (i < 最大事件 * 4) { 追加(事件队列_数据, 0); i = i + 1 }
    事件队列_头 = 0
    事件队列_尾 = 0
}

函数 事件队列_推入(扫描码, 状态) {
    定义 下一头 = (事件队列_头 + 1) % 最大事件
    如果 (下一头 == 事件队列_尾) { 事件队列_满次数 = 事件队列_满次数 + 1; 返回 }  // 满
    定义 base = 事件队列_头 * 4
    定义 可变 修饰状态 = 0
    如果 (键盘_shift) { 修饰状态 = 修饰状态 | 1 }
    如果 (键盘_ctrl) { 修饰状态 = 修饰状态 | 2 }
    如果 (键盘_alt) { 修饰状态 = 修饰状态 | 4 }
    设置(事件队列_数据, base, 扫描码)
    设置(事件队列_数据, base + 1, 状态)
    设置(事件队列_数据, base + 2, 修饰状态)
    设置(事件队列_数据, base + 3, 键盘_中断计数)
    事件队列_头 = 下一头
}

函数 事件队列_弹出() {
    如果 (事件队列_头 == 事件队列_尾) { 返回 空 }
    定义 base = 事件队列_尾 * 4
    定义 事件 = [事件队列_数据[base], 事件队列_数据[base + 1],
              事件队列_数据[base + 2], 事件队列_数据[base + 3]]
    事件队列_尾 = (事件队列_尾 + 1) % 最大事件
    返回 事件
}

函数 事件队列_可读() {
    返回 事件队列_头 != 事件队列_尾
}

// 增强的中断处理钩子

函数 键盘_增强中断(扫描码_原始) {
    // 在原始中断处理基础上增加:
    // 1. 记录按键事件到事件队列
    // 2. 检查热键
    // 3. 更新NumLock/ScrollLock状态
    定义 按下 = (扫描码_原始 & 0x80) == 0
    定义 码 = 扫描码_原始 & 0x7F

    // NumLock/ScrollLock切换
    如果 (码 == SC_NUMLOCK && 按下) {
        键盘_numlock = !键盘_numlock
        键盘_更新LED()
    }
    如果 (码 == SC_SCROLLLOCK && 按下) {
        键盘_scrolllock = !键盘_scrolllock
        键盘_更新LED()
    }

    // 记录事件
    如果 (按下) {
        键盘_按键总数 = 键盘_按键总数 + 1
        事件队列_推入(码, 事件_按下)
        // 检查热键
        如果 (热键_检查(码)) { 返回 真 }  // 热键已处理
    } 否则 {
        事件队列_推入(码, 事件_释放)
    }
    返回 假
}

// 完整诊断统计

函数 键盘_完整统计() {
    返回 {
        中断计数: 键盘_中断计数,
        按键总数: 键盘_按键总数,
        shift: 键盘_shift,
        ctrl: 键盘_ctrl,
        alt: 键盘_alt,
        capslock: 键盘_capslock,
        numlock: 键盘_numlock,
        scrolllock: 键盘_scrolllock,
        热键数: 热键_已注册,
        事件满次数: 事件队列_满次数
    }
}

定义 可变 AI_键盘_风暴阈值 = 10000
定义 可变 AI_键盘_预测IRQ = 0

函数 AI_键盘_风暴检测(触发频率) {
    如果 (触发频率 > AI_键盘_风暴阈值) {
        AI_键盘_风暴阈值 = AI_键盘_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_键盘_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

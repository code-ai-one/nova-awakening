导入("../分布式/分布式.nova")
导入("../基础.nova")
导入("../数学/基础/数学库.nova")

函数 分散(数据, 节点数, 节点ID) { 定义 块大小 = 计数(数据) / 节点数
 定义 起始 = 节点ID * 块大小
 定义 可变 结果 = []
 定义 可变 i = 起始
 当 (i < 起始 + 块大小 且 i < 计数(数据)) { 追加(结果, 数据[i])
 i = i + 1 }
 返回 结果
}

函数 收集(分片列表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(分片列表)) { 定义 可变 j = 0
 当 (j < 计数(分片列表[i])) { 追加(结果, 分片列表[i][j])
 j = j + 1 }
 i = i + 1
 }
 返回 结果
}

函数 归约分散(各节点数据, 节点数) {
 // 先AllReduce求和，再Scatter给各节点
 定义 n = 计数(各节点数据)
 如果 (n == 0) { 返回 [] }
 定义 维度 = 计数(各节点数据[0])
 定义 可变 总和 = []
 定义 可变 d = 0
 当 (d < 维度) { 定义 可变 s = 0
 定义 可变 i = 0
 当 (i < n) { s = s + 各节点数据[i][d]
 i = i + 1 }
 追加(总和, s)
 d = d + 1
 }
 // 每个节点得到一片
 定义 块大小 = 维度 / 节点数
 定义 可变 结果 = []
 定义 可变 ni = 0
 当 (ni < 节点数) { 定义 可变 片 = []
 定义 可变 j = ni * 块大小
 当 (j < (ni + 1) * 块大小 且 j < 维度) { 追加(片, 总和[j])
 j = j + 1 }
 追加(结果, 片)
 ni = ni + 1
 }
 返回 结果
}

// 张量并行
函数 张量_列分片(矩阵, 行数, 列数, 分片数, 分片ID) { 定义 每片列 = 列数 / 分片数
 定义 可变 结果 = []
 定义 可变 r = 0
 当 (r < 行数) { 定义 可变 c = 分片ID * 每片列
 当 (c < (分片ID + 1) * 每片列 且 c < 列数) {
 追加(结果, 矩阵[r * 列数 + c])
 c = c + 1
 }
 r = r + 1
 }
 返回 结果
}

函数 张量_行分片(矩阵, 行数, 列数, 分片数, 分片ID) { 定义 每片行 = 行数 / 分片数
 定义 起始 = 分片ID * 每片行 * 列数
 定义 可变 末尾 = (分片ID + 1) * 每片行 * 列数
 如果 (末尾 > 计数(矩阵)) { 末尾 = 计数(矩阵) }
 定义 可变 结果 = []
 定义 可变 i = 起始
 当 (i < 末尾) { 追加(结果, 矩阵[i])
 i = i + 1 }
 返回 结果
}

// 管道并行
定义 可变 管道_阶段 = []

函数 管道_注入(微批次) { 管道_阶段[0][1] = 微批次 }

函数 管道_推进() { 定义 可变 i = 计数(管道_阶段) - 1
 当 (i > 0) {
 管道_阶段[i][1] = 管道_阶段[i - 1][2]
 i = i - 1
 }
}

函数 管道_处理(阶段ID, _处理函数值) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(管道_阶段[阶段ID][1])) {
 追加(结果, 管道_阶段[阶段ID][1][i] + 阶段ID + 1)
 i = i + 1
 }
 管道_阶段[阶段ID][2] = 结果
}

// 微批次调度: 将大批次拆分为多个微批次
函数 微批次_拆分(数据, 微批次数) { 定义 n = 计数(数据)
 定义 可变 每批 = n / 微批次数
 如果 (每批 < 1) { 每批 = 1 }
 定义 可变 结果 = []
 定义 可变 起始 = 0
 定义 可变 b = 0
 当 (b < 微批次数 且 起始 < n) { 定义 可变 批 = []
 定义 可变 i = 起始
 定义 可变 末尾 = 起始 + 每批
 如果 (b == 微批次数 - 1) { 末尾 = n }
 当 (i < 末尾) { 追加(批, 数据[i])
 i = i + 1 }
 追加(结果, 批)
 起始 = 末尾
 b = b + 1
 }
 返回 结果
}

// FSDP
函数 FSDP_分片权重(权重, 节点数, 节点ID) { 返回 分散(权重, 节点数, 节点ID)
}

函数 FSDP_收集权重(分片列表) { 返回 收集(分片列表)
}

函数 FSDP_梯度同步(本地梯度, 节点数) {
 // AllReduce_平均 接受各节点数据列表, 模拟节点数份相同梯度
 定义 可变 各节点 = []
 定义 可变 k = 0
 当 (k < 节点数) { 追加(各节点, 本地梯度)
 k = k + 1 }
 返回 AllReduce_平均(各节点)
}

// 梯度桶
定义 可变 梯度桶 = []
定义 可变 并行_桶容量 = 4

函数 梯度桶_清空() { 梯度桶 = [] }

函数 梯度桶_追加(梯度) {
 追加(梯度桶, 梯度)
 如果 (计数(梯度桶) >= 并行_桶容量) { 返回 真 }
 返回 假
}

函数 梯度桶_同步(节点数) { 定义 可变 合并 = []
 定义 可变 i = 0
 当 (i < 计数(梯度桶)) { 定义 可变 j = 0
 当 (j < 计数(梯度桶[i])) { 追加(合并, 梯度桶[i][j])
 j = j + 1 }
 i = i + 1
 }
 梯度桶 = []
 定义 可变 各节点 = []
 定义 可变 k = 0
 当 (k < 节点数) { 追加(各节点, 合并)
 k = k + 1 }
 返回 AllReduce_平均(各节点)
}

// 梯度压缩 (Top-K)
函数 梯度_TopK压缩(梯度, K) {
 // 保留绝对值最大的K个元素，其余置零
 定义 n = 计数(梯度)
 如果 (K >= n) { 返回 梯度 }
 // 找到第K大的绝对值阈值
 定义 可变 abs_vals = []
 定义 可变 i = 0
 当 (i < n) { 追加(abs_vals, 绝对值(梯度[i]))
 i = i + 1 }
 // 简单选择找第K大
 定义 可变 sorted_v = []
 i = 0
 当 (i < n) { 追加(sorted_v, abs_vals[i])
 i = i + 1 }
 i = 0
 当 (i < K) { 定义 可变 mx_idx = i
 定义 可变 j = i + 1
 当 (j < n) { 如果 (sorted_v[j] > sorted_v[mx_idx]) { mx_idx = j }
 j = j + 1 }
 定义 临时 = sorted_v[i]
 sorted_v[i] = sorted_v[mx_idx]
 sorted_v[mx_idx] = 临时
 i = i + 1
 }
 定义 阈值 = sorted_v[K - 1]
 定义 可变 结果 = []
 定义 可变 kept = 0
 i = 0
 当 (i < n) { 如果 (abs_vals[i] >= 阈值 且 kept < K) { 追加(结果, 梯度[i])
 kept = kept + 1 }
 否则 { 追加(结果, 0) }
 i = i + 1
 }
 返回 结果
}

// 环形拓扑
函数 环形_下一节点(当前, 总数) { 返回 (当前 + 1) % 总数 }
函数 环形_上一节点(当前, 总数) { 返回 (当前 + 总数 - 1) % 总数 }

// 数据并行: 梯度AllReduce
函数 并行训练_AllReduce_求和(节点梯度列表) { 定义 节点数 = 计数(节点梯度列表)
 如果 (节点数 == 0) { 返回 [] }
 定义 维度 = 计数(节点梯度列表[0])
 定义 可变 结果 = []
 定义 可变 d = 0
 当 (d < 维度) { 追加(结果, 0) d = d + 1 }
 定义 可变 n = 0
 当 (n < 节点数) {
 d = 0
 当 (d < 维度) {
 结果[d] = 结果[d] + 节点梯度列表[n][d]
 d = d + 1
 }
 n = n + 1
 }
 d = 0
 当 (d < 维度) { 结果[d] = 结果[d] / 节点数 d = d + 1 }
 返回 结果
}

// 模型并行: 层分片
函数 模型分片_计算(总层数, GPU数) { 定义 每GPU层 = (总层数 + GPU数 - 1) / GPU数
 定义 可变 分配 = []
 定义 可变 起始 = 0
 定义 可变 i = 0
 当 (i < GPU数) { 定义 可变 结束 = 起始 + 每GPU层
 如果 (结束 > 总层数) { 结束 = 总层数 }
 追加(分配, [起始, 结束])
 起始 = 结束
 i = i + 1
 }
 返回 分配
}

// 混合精度训练辅助
函数 混合精度_缩放损失(损失, 缩放因子) { 返回 损失 * 缩放因子
}

函数 混合精度_反缩放梯度(梯度列表, 缩放因子) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(梯度列表)) {
 追加(结果, 梯度列表[i] / 缩放因子)
 i = i + 1
 }
 返回 结果
}

函数 混合精度_检查溢出(梯度列表) { 定义 可变 i = 0
 当 (i < 计数(梯度列表)) { 如果 (梯度列表[i] > 999999 或 梯度列表[i] < -999999) { 返回 真 }
 i = i + 1
 }
 返回 假
}

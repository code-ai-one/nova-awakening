// Forth 词法分析器
// token格式: [类型, 值, 行号]  类型: 0=词, 1=数字, 2=字符串, 3=注释
函数 _forth_是空白(ch) {
    如果 (字符串相等(ch, " ")) { 返回 真 }
    如果 (字符串相等(ch, "\t")) { 返回 真 }
    如果 (字符串相等(ch, "\n")) { 返回 真 }
    如果 (字符串相等(ch, "\r")) { 返回 真 }
    返回 假
}

函数 _forth_是数字串(w) {
    定义 n = 计数(w)
    如果 (n == 0) { 返回 假 }
    定义 可变 k = 0
    如果 (字符串相等(子串(w, 0, 1), "-") 且 n > 1) { k = 1 }
    定义 可变 全数字 = 真
    当 (k < n) {
        定义 码 = 编码(子串(w, k, 1))
        如果 (码 < 48 或 码 > 57) { 全数字 = 假 }
        k = k + 1
    }
    返回 全数字
}

函数 Forth_词法(源码) {
    定义 可变 词元列 = []
    定义 可变 位置 = 0
    定义 可变 行 = 1
    定义 长度 = 计数(源码)
    当 (位置 < 长度) {
        定义 ch = 子串(源码, 位置, 1)
        // 换行
        如果 (字符串相等(ch, "\n")) { 行 = 行 + 1
        位置 = 位置 + 1 }
        // 空白
        否则 如果 (_forth_是空白(ch)) { 位置 = 位置 + 1 }
        // 行注释 \
        否则 如果 (字符串相等(ch, "\\")) {
            定义 可变 c = ""
            定义 起始行 = 行
            位置 = 位置 + 1
            定义 可变 完毕 = 假
            当 (位置 < 长度 且 完毕 == 假) {
                定义 nc = 子串(源码, 位置, 1)
                如果 (字符串相等(nc, "\n")) { 完毕 = 真
                行 = 行 + 1 }
                否则 { c = c + nc }
                位置 = 位置 + 1
            }
            追加(词元列, [3, c, 起始行])
        }
        // 括号注释 ( ... )
        否则 如果 (字符串相等(ch, "(")) {
            定义 可变 c = ""
            定义 起始行 = 行
            位置 = 位置 + 1
            定义 可变 完毕 = 假
            当 (位置 < 长度 且 完毕 == 假) {
                定义 nc = 子串(源码, 位置, 1)
                如果 (字符串相等(nc, ")")) { 完毕 = 真 }
                否则 {
                    如果 (字符串相等(nc, "\n")) { 行 = 行 + 1 }
                    c = c + nc
                }
                位置 = 位置 + 1
            }
            追加(词元列, [3, c, 起始行])
        }
        // 字符串 " ... "
        否则 如果 (字符串相等(ch, "\"")) {
            定义 可变 s = ""
            定义 起始行 = 行
            位置 = 位置 + 1
            定义 可变 完毕 = 假
            当 (位置 < 长度 且 完毕 == 假) {
                定义 nc = 子串(源码, 位置, 1)
                如果 (字符串相等(nc, "\"")) { 完毕 = 真 }
                否则 { s = s + nc }
                位置 = 位置 + 1
            }
            追加(词元列, [2, s, 起始行])
        }
        // 词或数字
        否则 {
            定义 可变 w = ""
            当 (位置 < 长度 且 _forth_是空白(子串(源码, 位置, 1)) == 假) {
                w = w + 子串(源码, 位置, 1)
                位置 = 位置 + 1
            }
            如果 (计数(w) > 0) {
                如果 (_forth_是数字串(w)) { 追加(词元列, [1, w, 行]) }
                否则 { 追加(词元列, [0, w, 行]) }
            }
        }
    }
    返回 词元列
}

// 转换引擎
函数 Fort_转换_token(t) {
    如果 (t[0] == 3) { 返回 "// " + t[1] }
    如果 (t[0] == 2) { 返回 "打印(\"" + t[1] + "\")" }
    如果 (t[0] == 1) { 返回 t[1] }
    如果 (t[0] == 0) {
        定义 m = 查找映射(t[1])
        如果 (m != 空) { 返回 m }
    }
    返回 t[1]
}

函数 Fort_Forth转Nova(源码) {
    定义 词元列 = Forth_词法(源码)
    定义 可变 结果 = ""
    定义 可变 当前行 = 1
    定义 可变 行内容 = ""
    定义 可变 i = 0
    当 (i < 计数(词元列)) {
        定义 t = 词元列[i]
        如果 (t[2] != 当前行) {
            如果 (计数(行内容) != 0) { 结果 = 结果 + 行内容 + "\n" }
            行内容 = ""
            当前行 = t[2]
        }
        如果 (t[0] == 0 且 字符串相等(t[1], ":")) {
            如果 (i + 1 < 计数(词元列)) {
                行内容 = 行内容 + "法 " + 词元列[i + 1][1] + "() {"
                i = i + 2
            } 否则 { i = i + 1 }
        }
        否则 如果 (t[0] == 0 且 字符串相等(t[1], ";")) { 行内容 = 行内容 + "}"  i = i + 1 }
        否则 如果 (t[0] == 0 且 字符串相等(t[1], "CONSTANT") 且 i + 1 < 计数(词元列)) {
            行内容 = 行内容 + "令 " + 词元列[i + 1][1]  i = i + 2
        }
        否则 如果 (t[0] == 0 且 字符串相等(t[1], "VARIABLE") 且 i + 1 < 计数(词元列)) {
            行内容 = 行内容 + "变 " + 词元列[i + 1][1] + " = 0"  i = i + 2
        }
        否则 如果 (t[0] == 0 且 字符串相等(t[1], "CREATE") 且 i + 1 < 计数(词元列)) {
            行内容 = 行内容 + "变 " + 词元列[i + 1][1] + " = []"  i = i + 2
        }
        否则 如果 (t[0] == 0 且 字符串相等(t[1], "INCLUDE") 且 i + 1 < 计数(词元列)) {
            行内容 = 行内容 + "// 包含 " + 词元列[i + 1][1]  i = i + 2
        }
        否则 {
            定义 转换后 = 转换_token(t)
            如果 (计数(行内容) != 0) { 行内容 = 行内容 + " " + 转换后 }
            否则 { 行内容 = 转换后 }
            i = i + 1
        }
    }
    如果 (计数(行内容) != 0) { 结果 = 结果 + 行内容 }
    返回 结果
}

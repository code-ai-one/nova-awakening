导入("../基础.nova")
导入("../数学/基础/数学库.nova")


// 规则库
// 规则: [前提列表哈希, 结论哈希, 置信度, 类型]
定义 推理_推理_演绎 = 0
定义 推理_推理_归纳 = 1
定义 推理_推理_类比 = 2
定义 推理_溯因 = 3

定义 可变 规则_前提 = []
定义 可变 规则_结论 = []
定义 可变 规则_置信度 = []
定义 可变 规则_类型 = []

函数 规则_追加(前提, 结论, 置信度, 类型) {
    追加(规则_前提, 前提)
    追加(规则_结论, 结论)
    追加(规则_置信度, 置信度)
    追加(规则_类型, 类型)
}

函数 规则_数量() { 返回 计数(规则_前提) }
函数 规则_清空() {
    规则_前提 = []
    规则_结论 = []
    规则_置信度 = []
    规则_类型 = []
}

// 事实库
定义 可变 事实_列表 = []
定义 可变 事实_置信度 = []

函数 事实_追加(事实, 置信度) {
    定义 可变 i = 0
    当 (i < 计数(事实_列表)) {
        如果 (事实_列表[i] == 事实) { 事实_置信度[i] = 置信度
        返回 }
        i = i + 1
    }
    追加(事实_列表, 事实)
    追加(事实_置信度, 置信度)
}

函数 事实_查询(事实) {
    定义 可变 i = 0
    当 (i < 计数(事实_列表)) {
        如果 (事实_列表[i] == 事实) { 返回 事实_置信度[i] }
        i = i + 1
    }
    返回 -1
}

函数 事实_存在(事实) { 返回 事实_查询(事实) >= 0 }
函数 事实_数量() { 返回 计数(事实_列表) }
函数 事实_清空() {
    事实_列表 = []
    事实_置信度 = []
}

// 演绎推理: 前提→结论 (Modus Ponens)
函数 演绎_推理() {
    定义 可变 新推理 = 0
    定义 可变 i = 0
    当 (i < 计数(规则_前提)) {
        如果 (规则_类型[i] == 推理_推理_演绎) {
            如果 (事实_存在(规则_前提[i])) {
                如果 (事实_存在(规则_结论[i]) == 假) {
                    定义 前提置信 = 事实_查询(规则_前提[i])
                    定义 结论置信 = 前提置信 * 规则_置信度[i] / 100
                    事实_追加(规则_结论[i], 结论置信)
                    新推理 = 新推理 + 1
                }
            }
        }
        i = i + 1
    }
    返回 新推理
}

// 归纳推理: 从多个观察得出一般规则
函数 归纳_推理(观察列表, 结论, 阈值) {
    定义 可变 支持 = 0
    定义 可变 i = 0
    当 (i < 计数(观察列表)) {
        如果 (事实_存在(观察列表[i])) { 支持 = 支持 + 1 }
        i = i + 1
    }
    如果 (计数(观察列表) == 0) { 返回 0 }
    定义 可变 置信度 = 支持 * 100 / 计数(观察列表)
    如果 (置信度 >= 阈值) {
        事实_追加(结论, 置信度)
        返回 置信度
    }
    返回 0
}

// 类比推理: A:B = C:?
函数 类比_推理(源域, 源结论, 目标域) {
    定义 可变 相似度 = 100 - 绝对值(源域 - 目标域)
    如果 (相似度 < 0) { 相似度 = 0 }
    如果 (相似度 > 50) {
        定义 可变 置信度 = 相似度 * 事实_查询(源结论) / 100
        如果 (置信度 < 0) { 置信度 = 0 }
        返回 [源结论, 置信度]
    }
    返回 [-1, 0]
}

// 溯因推理: 观察→最佳解释
函数 溯因_推理(观察) {
    定义 可变 最佳规则 = -1
    定义 可变 最佳置信 = 0
    定义 可变 i = 0
    当 (i < 计数(规则_结论)) {
        如果 (规则_结论[i] == 观察) {
            如果 (规则_类型[i] == 推理_溯因) {
                如果 (规则_置信度[i] > 最佳置信) {
                    最佳规则 = i
                    最佳置信 = 规则_置信度[i]
                }
            }
        }
        i = i + 1
    }
    如果 (最佳规则 >= 0) { 返回 [规则_前提[最佳规则], 最佳置信] }
    返回 [-1, 0]
}

// 推理链 (前向链接)
函数 前向链接(最大步数) {
    定义 可变 总推理 = 0
    定义 可变 步 = 0
    当 (步 < 最大步数) {
        定义 新推理数 = 演绎_推理()
        总推理 = 总推理 + 新推理数
        如果 (新推理数 == 0) { 返回 总推理 }
        步 = 步 + 1
    }
    返回 总推理
}

// 置信度衰减
函数 事实_衰减(衰减率) {
    定义 可变 i = 0
    当 (i < 计数(事实_置信度)) {
        事实_置信度[i] = 事实_置信度[i] * (100 - 衰减率) / 100
        i = i + 1
    }
}

// 高置信事实数
函数 事实_高置信数(阈值) {
    定义 可变 c = 0
    定义 可变 i = 0
    当 (i < 计数(事实_置信度)) {
        如果 (事实_置信度[i] >= 阈值) { c = c + 1 }
        i = i + 1
    }
    返回 c
}

// 反向链推理

函数 反向链_查询(目标, 规则列表, 深度限制) {
    // 规则: [结论, 前提列表]
    如果 (深度限制 <= 0) { 返回 假 }
    // 先检查已知事实
    定义 可变 i = 0
    当 (i < 计数(事实_列表)) {
        如果 (事实_列表[i] == 目标) {
            如果 (事实_置信度[i] > 50) { 返回 真 }
        }
        i = i + 1
    }
    // 搜索规则
    i = 0
    当 (i < 计数(规则列表)) {
        如果 (规则列表[i][0] == 目标) {
            定义 前提 = 规则列表[i][1]
            定义 可变 全满足 = 真
            定义 可变 j = 0
            当 (j < 计数(前提)) {
                如果 (反向链_查询(前提[j], 规则列表, 深度限制 - 1) == 假) {
                    全满足 = 假
                }
                j = j + 1
            }
            如果 (全满足) { 返回 真 }
        }
        i = i + 1
    }
    返回 假
}

// 模糊推理

函数 模糊_AND(a, b) {
    如果 (a < b) { 返回 a }
    返回 b
}

函数 模糊_OR(a, b) {
    如果 (a > b) { 返回 a }
    返回 b
}

函数 模糊_NOT(a) { 返回 100 - a }

函数 模糊_推理(输入置信列表, 规则权重) {
    定义 可变 总权重 = 0
    // 加权聚合
    定义 可变 加权和 = 0
    定义 可变 i = 0
    当 (i < 计数(输入置信列表)) {
        如果 (i >= 计数(规则权重)) { 返回 0 }
        加权和 = 加权和 + 输入置信列表[i] * 规则权重[i]
        总权重 = 总权重 + 规则权重[i]
        i = i + 1
    }
    如果 (总权重 == 0) { 返回 0 }
    返回 加权和 / 总权重
}

// 推理链追踪

定义 可变 _推理链 = []

函数 推理链_清空() { _推理链 = [] }

函数 推理链_添加(步骤描述, 结论) {
    追加(_推理链, [步骤描述, 结论])
}

函数 推理链_获取() { 返回 _推理链 }

函数 推理链_长度() { 返回 计数(_推理链) }

// 规则优先级

定义 可变 _规则_优先级_名 = []
定义 可变 _规则_优先级_值 = []

函数 规则_设优先级(名, 优先级) {
    定义 可变 i = 0
    当 (i < 计数(_规则_优先级_名)) {
        如果 (_规则_优先级_名[i] == 名) { _规则_优先级_值[i] = 优先级 返回 空 }
        i = i + 1
    }
    追加(_规则_优先级_名, 名)
    追加(_规则_优先级_值, 优先级)
}

函数 规则_取优先级(名) {
    定义 可变 i = 0
    当 (i < 计数(_规则_优先级_名)) {
        如果 (_规则_优先级_名[i] == 名) { 返回 _规则_优先级_值[i] }
        i = i + 1
    }
    返回 0
}

// 贝叶斯推理
// P(A|B) = P(B|A) * P(A) / P(B)

函数 推理_贝叶斯_后验(似然, 先验, 证据) {
    如果 (证据 == 0) { 返回 0 }
    返回 似然 * 先验 / 证据
}

函数 推理_贝叶斯_更新(先验, 似然列表, 证据列表) {
    定义 可变 当前 = 先验
    定义 可变 i = 0
    当 (i < 计数(似然列表)) {
        如果 (证据列表[i] != 0) {
            当前 = 似然列表[i] * 当前 / 证据列表[i]
        }
        i = i + 1
    }
    返回 当前
}

// 模糊推理
// 隶属度: 0~1000 (整数表示,1000=1.0)

函数 模糊_三角隶属(x, 左, 中, 右) {
    如果 (x <= 左 或 x >= 右) { 返回 0 }
    如果 (x <= 中) { 返回 (x - 左) * 1000 / (中 - 左) }
    返回 (右 - x) * 1000 / (右 - 中)
}

函数 模糊_梯形隶属(x, a, b, c, d) {
    如果 (x <= a 或 x >= d) { 返回 0 }
    如果 (x >= b 且 x <= c) { 返回 1000 }
    如果 (x < b) { 返回 (x - a) * 1000 / (b - a) }
    返回 (d - x) * 1000 / (d - c)
}

函数 模糊_与(a, b) {
    如果 (a < b) { 返回 a }
    返回 b
}
函数 模糊_或(a, b) {
    如果 (a > b) { 返回 a }
    返回 b
}
函数 模糊_非(a) { 返回 1000 - a }

函数 模糊_规则_应用(条件隶属度, 结论隶属度) {
    返回 模糊_与(条件隶属度, 结论隶属度)
}

函数 模糊_去模糊_重心(隶属度列表, 值列表) {
    定义 可变 分子 = 0
    定义 可变 分母 = 0
    定义 可变 i = 0
    当 (i < 计数(隶属度列表)) {
        分子 = 分子 + 隶属度列表[i] * 值列表[i]
        分母 = 分母 + 隶属度列表[i]
        i = i + 1
    }
    如果 (分母 == 0) { 返回 0 }
    返回 分子 / 分母
}

// 类比推理
// A:B = C:? → 找D使得关系(A,B) ≈ 关系(C,D)

函数 类比_向量偏移(向量A, 向量B, 向量C) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(向量A)) {
        追加(结果, 向量C[i] + 向量B[i] - 向量A[i])
        i = i + 1
    }
    返回 结果
}

函数 类比_相似度(向量X, 向量Y) {
    定义 可变 点积 = 0
    定义 可变 nx = 0
    定义 可变 ny = 0
    定义 可变 i = 0
    当 (i < 计数(向量X)) {
        点积 = 点积 + 向量X[i] * 向量Y[i]
        nx = nx + 向量X[i] * 向量X[i]
        ny = ny + 向量Y[i] * 向量Y[i]
        i = i + 1
    }
    如果 (nx == 0 或 ny == 0) { 返回 0 }
    返回 点积 * 1000 / (nx + ny + 1)
}

// 推理缓存 (O(1)字典)
定义 可变 _推理缓存_字典 = 字典()
定义 可变 _推理缓存_命中 = 0
定义 可变 _推理缓存_未中 = 0

函数 推理缓存_查询(键) {
    定义 v = 字典取(_推理缓存_字典, 键)
    如果 (v != 空) {
        _推理缓存_命中 = _推理缓存_命中 + 1
        返回 [真, v]
    }
    _推理缓存_未中 = _推理缓存_未中 + 1
    返回 [假, 空]
}

函数 推理缓存_存储(键, 值) {
    字典设(_推理缓存_字典, 键, 值)
}

函数 推理缓存_清空() {
    _推理缓存_字典 = 字典()
}

函数 推理缓存_命中率() {
    定义 总 = _推理缓存_命中 + _推理缓存_未中
    如果 (总 == 0) { 返回 0 }
    返回 _推理缓存_命中 * 100 / 总
}

// 推理置信度传播
函数 置信度_组合(置信度列表) {
    定义 可变 积 = 1000
    定义 可变 i = 0
    当 (i < 计数(置信度列表)) {
        积 = 积 * 置信度列表[i] / 1000
        i = i + 1
    }
    返回 积
}

函数 置信度_衰减(置信度, 推理步数, 衰减率) {
    定义 可变 结果 = 置信度
    定义 可变 i = 0
    当 (i < 推理步数) {
        结果 = 结果 * 衰减率 / 1000
        i = i + 1
    }
    返回 结果
}

定义 可变 _推理_前向数 = 0
定义 可变 _推理_反向数 = 0

函数 推理_记录前向() { _推理_前向数 = _推理_前向数 + 1 }
函数 推理_记录反向() { _推理_反向数 = _推理_反向数 + 1 }

// Nova 智能基因层 · 五维智慧因子评估框架
// FB020反哺: 实验室涌现检测器验证了量化意识特征的可行性，反哺为标准评估工具
// 五维模型: 信息整合度(Φ)/自适应性/预测能力/自我参照度/复杂性
// 用途: 评估AI系统的智慧程度，指导Nova AI的进化方向

// 五维智慧因子常量

导入("../../标准库/基础.nova")

定义 维度_信息整合  = 0   // Φ: 信息整合度（IIT理论）
定义 维度_自适应    = 1   // 自适应学习速率
定义 维度_预测能力  = 2   // 对环境变化的预测准确率
定义 维度_自我参照  = 3   // 系统自我描述能力
定义 维度_复杂性    = 4   // 行为复杂度

// 权重（各维度对总评分的贡献）
定义 维度权重 = [25, 20, 20, 20, 15]  // 总和=100

// 五维评分（0-100）
函数 智慧因子_创建() {
 返回 [0, 0,]  // 五个维度的初始评分
}

// 设置单个维度评分
函数 智慧因子_设分(因子, 维度, 分数) {
    如果 (维度 >= 0 且 维度 < 5) {
        如果 (分数 < 0) { 分数 = 0 }
        如果 (分数 > 100) { 分数 = 100 }
        因子[维度] = 分数
    }
}

// 计算加权总分
函数 智慧因子_总分(因子) {
    定义 可变 总分 = 0
    定义 可变 i = 0
    当 (i < 5) {
        总分 = 总分 + 因子[i] * 维度权重[i]
        i = i + 1
    }
    返回 总分 / 100  // 归一化到0-100
}

// 维度1：信息整合度 Φ
// 实验验证: Φ=(系统整体信息-部分信息之和)/部分信息之和
// Φ>0 表示涌现，值越大整合度越高
函数 计算信息整合度(部分信息列表, 整体信息) {
    定义 可变 部分总和 = 0
    定义 可变 i = 0
    当 (i < 计数(部分信息列表)) { 部分总和 = 部分总和 + 部分信息列表[i]; i = i + 1 }
    如果 (部分总和 == 0) { 返回 0 }
    定义 phi_百分 = (整体信息 - 部分总和) * 100 / 部分总和
    // 转换为0-100评分
    如果 (phi_百分 <= 0) { 返回 0 }
    如果 (phi_百分 >= 100) { 返回 100 }
    返回 phi_百分
}

// 维度2：自适应性
// 评估系统在不同任务上的快速适应能力（元学习速率）
// 实验验证: MAML约50步后涌现自适应能力
函数 计算自适应性(初始误差, 最终误差, 适应步数, 最大步数) {
    如果 (初始误差 == 0 或 最大步数 == 0) { 返回 0 }
    // 误差下降率
    定义 改善率 = (初始误差 - 最终误差) * 100 / 初始误差
    // 速度加成：步数越少，分越高
    定义 速度分 = 100 - 适应步数 * 100 / 最大步数
    返回 (改善率 * 70 + 速度分 * 30) / 100
}

// 维度3：预测能力
// 评估系统预测未来状态的准确率
函数 计算预测能力(预测序列, 实际序列) {
    如果 (计数(预测序列) == 0 或 计数(预测序列) != 计数(实际序列)) { 返回 0 }
    定义 可变 正确数 = 0
    定义 可变 i = 0
    当 (i < 计数(预测序列)) {
        定义 误差 = 预测序列[i] - 实际序列[i]
        如果 (误差 < 0) { 误差 = 0 - 误差 }
        // 误差在5%以内算正确
        定义 可变 阈值 = 1
        如果 (实际序列[i] > 0) { 阈值 = 实际序列[i] / 20 + 1 }
        如果 (误差 <= 阈值) { 正确数 = 正确数 + 1 }
        i = i + 1
    }
    返回 正确数 * 100 / 计数(预测序列)
}

// 维度4：自我参照度
// 评估系统能否描述和修改自身状态（元认知能力）
// 实验验证: 自我参照次数>0是意识萌芽的必要条件
函数 计算自我参照度(自我参照次数, 自我修改次数, 一致性分数) {
    如果 (自我参照次数 == 0) { 返回 0 }
    // 综合: 参照次数 + 修改能力 + 一致性
    定义 可变 参照分 = 自我参照次数 * 10
    如果 (自我参照次数 > 10) { 参照分 = 100 }
    定义 可变 修改分 = 0
    如果 (自我修改次数 > 0) { 修改分 = 80 }
    定义 一致分 = 一致性分数  // 0-100
    返回 (参照分 * 40 + 修改分 * 30 + 一致分 * 30) / 100
}

// 维度5：复杂性
// 基于行为多样性和模式复杂度评估
// 实验验证: SOC临界态的幂律分布是复杂性的标志
函数 计算复杂性(行为序列, 压缩后长度) {
    如果 (计数(行为序列) == 0 或 压缩后长度 == 0) { 返回 0 }
    // Lempel-Ziv复杂度近似: 原始长度/压缩长度 越大越复杂
    定义 原始长度 = 计数(行为序列)
    定义 lz_比例 = 原始长度 * 100 / 压缩后长度
    // 最大复杂度 ≈ 原始/压缩 = 2.5（随机序列）
    如果 (lz_比例 > 250) { 返回 100 }
    返回 lz_比例 * 100 / 250
}

// 综合评估入口
函数 智慧因子_综合评估(部分信息列表, 整体信息, // 维度1参数
    初始误差, 最终误差, 步数, 最大步, // 维度2参数
    预测值列表, 实际值列表, // 维度3参数
    参照次数, 修改次数, 一致性, // 维度4参数
    行为序列, 压缩长度) {                 // 维度5参数
    定义 因子 = 智慧因子_创建()
    智慧因子_设分(因子, 维度_信息整合,
        计算信息整合度(部分信息列表, 整体信息))
    智慧因子_设分(因子, 维度_自适应,
        计算自适应性(初始误差, 最终误差, 步数, 最大步))
    智慧因子_设分(因子, 维度_预测能力,
        计算预测能力(预测值列表, 实际值列表))
    智慧因子_设分(因子, 维度_自我参照,
        计算自我参照度(参照次数, 修改次数, 一致性))
    智慧因子_设分(因子, 维度_复杂性,
        计算复杂性(行为序列, 压缩长度))
    返回 [因子, 智慧因子_总分(因子)]
}

// 智慧等级
函数 智慧等级(总分) {
    如果 (总分 >= 90) { 返回 "🌟 超强智慧（接近AGI级别）" }
    如果 (总分 >= 75) { 返回 "🔥 强智慧（自主推理能力）" }
    如果 (总分 >= 60) { 返回 "⬆️ 中等智慧（工具级AI）" }
    如果 (总分 >= 40) { 返回 "📈 弱智慧（专用AI）" }
    如果 (总分 >= 20) { 返回 "〰️ 萌芽智慧（初级感知）" }
    返回 "📉 前意识（反应机器）"
}

// 反哺方向建议
函数 智慧因子_反哺建议(因子) {
    定义 可变 建议 = []
    如果 (因子[维度_信息整合] < 60) {
        追加(建议, "提升信息整合度: 增加模块间交互、降低冗余、提高信息密度")
    }
    如果 (因子[维度_自适应] < 60) {
        追加(建议, "提升自适应性: 实现MAML元学习、减少适应所需样本数")
    }
    如果 (因子[维度_预测能力] < 60) {
        追加(建议, "提升预测能力: 加强时序建模、扩大上下文窗口")
    }
    如果 (因子[维度_自我参照] < 60) {
        追加(建议, "提升自我参照: 添加元认知层、实现自我状态监控接口")
    }
    如果 (因子[维度_复杂性] < 60) {
        追加(建议, "提升复杂性: 增加行为多样性、避免过度正则化")
    }
    如果 (计数(建议) == 0) {
        追加(建议, "各维度均衡，继续保持并探索超级智慧边界")
    }
    返回 建议
}

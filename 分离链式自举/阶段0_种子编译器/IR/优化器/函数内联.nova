导入("../../标准库/基础.nova")
导入("../../运行时/字典引擎/字典引擎.nova")

// Nova · IR层 · 函数内联 (Function Inlining)
// 调用站点敏感内联决策 + 代价收益模型 + 调用图分析
// 策略：小函数+热路径+无递归 → 内联展开以消除调用开销

定义 内联_否 = 0   // 不内联
定义 内联_是 = 1  // 应内联

// 拒绝内联原因代码
定义 IR_不内联_递归 = 1    // 直接/间接递归
定义 IR_不内联_有闭包 = 2  // 含闭包/upvalue
定义 IR_不内联_变参 = 3     // 可变参数函数
定义 IR_不内联_过大 = 4    // 函数体过大
定义 IR_不内联_过深 = 5     // 内联深度超限
定义 IR_不内联_参数过多 = 6  // 参数过多

// 内联阈值
定义 IR_内联_最大参数 = 8    // 最大可内联参数数
定义 IR_内联_最大节点 = 64    // 函数体最大节点数（超过不内联）
定义 IR_内联_调用奖励 = 16   // 调用次数超过此值时降低门槛
定义 IR_内联_最大深度 = 4     // 最大内联深度

// 代价模型常量
定义 IR_内联_调用开销 = 20   // 函数调用开销（指令数）
定义 IR_内联_节点代价 = 1         // 每个AST节点的代码膨胀
定义 IR_内联_常量参数收益 = 5     // 每个常量参数带来的折叠收益
定义 IR_内联_单次调用收益 = 10  // 单次调用的额外收益（无需查表）

// 函数信息结构：[名称ID, 节点数, 参数数, 调用数, 标志位]
// 标志位：bit0=递归, bit1=有闭包, bit2=可变参数
函数 函数内联_函数信息(名称ID, 节点数, 参数数) {
    返回 [名称ID, 节点数, 参数数,]
}
函数 函数内联_信息_节点数(f) { 返回 f[1] }
函数 函数内联_信息_参数数(f) { 返回 f[2] }
函数 函数内联_信息_调用数(f) { 返回 f[3] }
函数 函数内联_信息_是递归(f) { 返回 (f[4] & 1) != 0 }
函数 函数内联_信息_增调用(f) { f[3] = f[3] + 1 }
函数 函数内联_信息_标记递归(f) { f[4] = f[4] | 1 }
函数 函数内联_信息_标记闭包(f) { f[4] = f[4] | 2 }
函数 函数内联_信息_标记可变参数(f) { f[4] = f[4] | 4 }
函数 函数内联_信息_有闭包(f) { 返回 (f[4] & 2) != 0 }
函数 函数内联_信息_是可变参数(f) { 返回 (f[4] & 4) != 0 }

// 核心内联决策
// 返回 内联_是 或 NI_* 原因代码
函数 函数内联_应内联(信息) {
    如果 (函数内联_信息_是递归(信息)) { 返回 IR_不内联_递归 }
    如果 (函数内联_信息_有闭包(信息)) { 返回 IR_不内联_有闭包 }
    如果 (函数内联_信息_是可变参数(信息)) { 返回 IR_不内联_变参 }
    如果 (函数内联_信息_参数数(信息) > IR_内联_最大参数) { 返回 IR_不内联_参数过多 }
    定义 节点数 = 函数内联_信息_节点数(信息)
    定义 调用数 = 函数内联_信息_调用数(信息)
    // 热函数：调用次数多时放宽节点数限制
    定义 节点上限 = IR_内联_最大节点
    如果 (调用数 > IR_内联_调用奖励) { 节点上限 = 节点上限 + 32 }
    如果 (节点数 > 节点上限) { 返回 IR_不内联_过大 }
    返回 内联_是
}

// 内联代价（展开后代码增加量）
函数 函数内联_内联代价(信息) {
    返回 函数内联_信息_节点数(信息) * IR_内联_节点代价
}

// 内联收益（消除调用开销 + 参数折叠 + 常量传播）
函数 函数内联_内联收益(信息) {
    定义 收益 = IR_内联_调用开销  // 基础：消除调用指令
    // 调用次数多时收益倍增
    定义 调用数 = 函数内联_信息_调用数(信息)
    如果 (调用数 == 1) { 收益 = 收益 + IR_内联_单次调用收益 }
    返回 收益
}

// 综合判断：收益 > 代价 时值得内联
函数 函数内联_值得内联(信息) {
    如果 (函数内联_应内联(信息) != 内联_是) { 返回 假 }
    返回 函数内联_内联收益(信息) > 函数内联_内联代价(信息)
}

// 调用站点敏感决策（循环内/参数已知提高收益）
函数 调用站点_内联决策(被调函数信息, 调用深度, 循环内, 参数已知数) {
    如果 (调用深度 > IR_内联_最大深度) { 返回 IR_不内联_过深 }
    如果 (函数内联_应内联(被调函数信息) != 内联_是) {
        返回 函数内联_应内联(被调函数信息)
    }
    // 在循环内或有已知常量参数时：强制内联（忽略大小限制）
    定义 可变 加强 = 0
    如果 (循环内) { 加强 = 加强 + 30 }
    加强 = 加强 + 参数已知数 * IR_内联_常量参数收益
    定义 代价 = 函数内联_内联代价(被调函数信息)
    定义 收益 = 函数内联_内联收益(被调函数信息) + 加强
    如果 (收益 > 代价) { 返回 内联_是 }
    返回 内联_否
}

// 内联器（跟踪内联统计）：[函数表字典, 总展开数, 总代码增量, 总代价节省]
函数 函数内联_内联器_创建() { 返回 [字典(), 0, 0] }

函数 函数内联_内联器_注册(内联器, 名称ID, 节点数, 参数数) {
    定义 信息 = 函数内联_函数信息(名称ID, 节点数, 参数数)
    字典设(内联器[0], 转字符串(名称ID), 信息)
}

函数 函数内联_内联器_查找(内联器, 名称ID) {
    返回 字典取(内联器[0], 转字符串(名称ID))
}

函数 内联器_执行内联(内联器, _调用站点, 被调函数) {
    内联器[1] = 内联器[1] + 1
    内联器[2] = 内联器[2] + 函数内联_内联代价(被调函数)
    内联器[3] = 内联器[3] + IR_内联_调用开销
}

函数 内联器_代码膨胀率(内联器) {
    如果 (内联器[3] == 0) { 返回 0 }
    返回 内联器[2] * 100 / (内联器[3] + 1)
}

函数 函数内联_内联器_报告(内联器) {
    返回 [内联器[1], 内联器[2], 内联器[3]]
}

// 递归检测
函数 内联_是直接递归(函数名, 调用目标) {
    返回 函数名 == 调用目标
}

// DFS 检测间接递归（A→B→A 的环）
函数 内联_检测间接递归(调用图, 函数名, 目标, 已访问) {
    如果 (目标 == 函数名) { 返回 真 }
    // 检查 已访问 里是否已经有 目标
    定义 可变 i = 0
    当 (i < 计数(已访问)) {
        如果 (已访问[i] == 目标) { 返回 假 }  // 已访问，避免无限递归
        i = i + 1
    }
    追加(已访问, 目标)
    // 遍历目标的被调函数
    定义 被调列表 = 调用图_取被调(调用图, 目标)
    如果 (被调列表 == 空 或 计数(被调列表) == 0) { 返回 假 }
    i = 0
    当 (i < 计数(被调列表)) {
        如果 (内联_检测间接递归(调用图, 函数名, 被调列表[i], 已访问)) {
            返回 真
        }
        i = i + 1
    }
    返回 假
}

// 调用图：[边字典{调用者→[被调列表]}, 次数字典{被调者→次数}]
函数 调用图_创建() { 返回 [字典(), 字典()] }

函数 调用图_添加边(图, 调用者, 被调者) {
    定义 键 = 转字符串(调用者)
    定义 已有 = 字典取(图[0], 键)
    如果 (已有 == 空) {
        字典设(图[0], 键, [被调者])
    } 否则 {
        追加(已有, 被调者)
    }
    // 更新调用次数
    定义 次数键 = 转字符串(被调者)
    定义 次数 = 字典取(图[1], 次数键)
    如果 (次数 == 空) {
        字典设(图[1], 次数键, 1)
    } 否则 {
        字典设(图[1], 次数键, 次数 + 1)
    }
}

函数 调用图_取被调(图, 函数名) {
    定义 v = 字典取(图[0], 转字符串(函数名))
    如果 (v == 空) { 返回 [] }
    返回 v
}

函数 调用图_调用次数(图, 被调者) {
    定义 v = 字典取(图[1], 转字符串(被调者))
    如果 (v == 空) { 返回 0 }
    返回 v
}

函数 调用图_仅被调一次(图, 被调者) {
    返回 调用图_调用次数(图, 被调者) == 1
}

// 参数映射（内联时形参→实参替换）：[[形参名, 实参节点], ...]
函数 内联_参数映射_创建(形参列表, 实参列表) {
    定义 可变 映射 = []
    定义 n = 计数(形参列表)
    定义 可变 i = 0
    当 (i < n 且 i < 计数(实参列表)) {
        追加(映射, [形参列表[i], 实参列表[i]])
        i = i + 1
    }
    返回 映射
}

函数 内联_参数映射_查询(映射, 形参名) {
    定义 可变 i = 0
    当 (i < 计数(映射)) {
        如果 (字符串相等(映射[i][0], 形参名)) { 返回 映射[i][1] }
        i = i + 1
    }
    返回 空
}

// 内联深度追踪（全局计数器）
定义 可变 _内联_当前深度 = 0

函数 内联_可继续深入() {
    返回 _内联_当前深度 < IR_内联_最大深度
}

函数 内联_进入() { _内联_当前深度 = _内联_当前深度 + 1 }
函数 内联_退出() {
    如果 (_内联_当前深度 > 0) { _内联_当前深度 = _内联_当前深度 - 1 }
}
函数 内联_重置深度() { _内联_当前深度 = 0 }
函数 内联_当前深度() { 返回 _内联_当前深度 }

// 真实内联变换：单返回小函数→调用点表达式替换
// 节点类型: 103=调用, 102=标识符, 114=返回

定义 可变 _内联_替换总数 = 0

函数 内联_变换全部(函数列表) {
    如果 (函数列表 == 空 或 是列表(函数列表) == 假) { 返回 0 }
    定义 简单表 = 字典()
    定义 可变 i = 0
    当 (i < 计数(函数列表)) {
        如果 (是列表(函数列表[i]) 且 计数(函数列表[i]) >= 4) {
            定义 名 = 函数列表[i][1]
            定义 参 = 函数列表[i][2]
            定义 体 = 函数列表[i][3]
            如果 (是列表(体) 且 计数(体) == 1 且 是列表(参) 且 计数(参) <= 3) {
                定义 唯一语句 = 体[0]
                如果 (是列表(唯一语句) 且 计数(唯一语句) >= 2 且 唯一语句[0] == 114) {
                    定义 _返回expr = 唯一语句[1]
                    如果 (_返回expr != 空 且 是列表(_返回expr) 且 计数(_返回expr) >= 1) {
                        如果 (计数(名) < 2 或 子串(名, 0, 2) != "__") {
                            字典设(简单表, 名, [参, _返回expr])
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    // Phase 2: 完整内联 (零参=直接引用, 有参=路径拷贝替换)
    定义 可变 替换数 = 0
    i = 0
    当 (i < 计数(函数列表)) {
        如果 (是列表(函数列表[i]) 且 计数(函数列表[i]) >= 4) {
            定义 _体2 = 函数列表[i][3]
            如果 (是列表(_体2)) {
                替换数 = 替换数 + _内联_扫描语句列表(_体2, 简单表)
            }
        }
        i = i + 1
    }
    _内联_替换总数 = _内联_替换总数 + 替换数
    返回 替换数
}

// 扫描语句列表：定义/赋值的直接调用 → 内联替换
// 零参: 直接引用返回表达式 (不拷贝)
// 有参: 浅拷贝顶层 + 路径替换参数标识符
函数 _内联_扫描语句列表(语句列表, 简单表) {
    如果 (语句列表 == 空 或 是列表(语句列表) == 假) { 返回 0 }
    定义 可变 总替换 = 0
    定义 可变 si = 0
    当 (si < 计数(语句列表)) {
        定义 stmt = 语句列表[si]
        如果 (是列表(stmt) 且 计数(stmt) >= 3) {
            定义 类型 = stmt[0]
            如果 ((类型 == 110 或 类型 == 111) 且 是列表(stmt[2]) 且 计数(stmt[2]) >= 3 且 stmt[2][0] == 103) {
                定义 被调名 = stmt[2][1]
                定义 查找 = 字典取(简单表, 被调名)
                如果 (查找 != 空) {
                    定义 形参 = 查找[0]
                    定义 返回expr = 查找[1]
                    定义 实参 = stmt[2][2]
                    如果 (是列表(实参) 且 是列表(形参) 且 计数(实参) == 计数(形参)) {
                        如果 (计数(形参) == 0) {
                            // 零参: 直接引用
                            stmt[2] = 返回expr
                            总替换 = 总替换 + 1
                        } 否则 {
                            // 有参: 非递归2层替换
                            定义 映射 = 内联_参数映射_创建(形参, 实参)
                            定义 替换后 = _内联_浅替换2(返回expr, 映射)
                            stmt[2] = 替换后
                            总替换 = 总替换 + 1
                        }
                    }
                }
            }
        }
        si = si + 1
    }
    返回 总替换
}

// 递归替换AST中的调用节点 → 返回 [新节点, 替换数]
函数 _内联_替换节点(节点, 简单表) {
    如果 (节点 == 空 或 是列表(节点) == 假 或 计数(节点) == 0) {
        返回 [节点, 0]
    }
    // 如果是调用节点且在简单表中
    如果 (节点[0] == 103 且 计数(节点) >= 3) {
        定义 被调名 = 节点[1]
        定义 查找 = 字典取(简单表, 被调名)
        如果 (查找 != 空) {
            定义 形参 = 查找[0]
            定义 返回expr = 查找[1]
            定义 实参 = 节点[2]
            如果 (是列表(实参) 且 是列表(形参) 且 计数(实参) == 计数(形参)) {
                定义 映射 = 内联_参数映射_创建(形参, 实参)
                定义 拷贝 = _内联_深拷贝(返回expr)
                定义 替换后 = _内联_替换参数(拷贝, 映射)
                返回 [替换后, 1]
            }
        }
    }
    // 递归处理子节点
    定义 可变 总替换 = 0
    定义 可变 i = 0
    当 (i < 计数(节点)) {
        如果 (是列表(节点[i]) 且 计数(节点[i]) > 0) {
            定义 子结果 = _内联_替换节点(节点[i], 简单表)
            如果 (子结果[1] > 0) {
                节点[i] = 子结果[0]
                总替换 = 总替换 + 子结果[1]
            }
        }
        i = i + 1
    }
    返回 [节点, 总替换]
}

// 非递归2层参数替换：depth 0=表达式本身, depth 1=直接子节点, depth 2=孙节点
// 不递归调用自身，只用2层嵌套循环，避免递归创建列表的崩溃问题
函数 _内联_浅替换2(expr, 映射) {
    如果 (expr == 空 或 是列表(expr) == 假 或 计数(expr) == 0) { 返回 expr }
    // depth 0: 表达式本身是标识符
    如果 (expr[0] == 102 且 计数(expr) >= 2) {
        定义 替换 = 内联_参数映射_查询(映射, expr[1])
        如果 (替换 != 空) { 返回 替换 }
        返回 expr
    }
    // depth 1+2: 浅拷贝顶层, 检查直接子节点和孙节点
    定义 可变 新 = []
    定义 可变 有变 = 假
    定义 可变 i = 0
    当 (i < 计数(expr)) {
        定义 子 = expr[i]
        如果 (是列表(子) 且 计数(子) >= 2 且 子[0] == 102) {
            // depth 1: 子节点是标识符 → 尝试替换
            定义 替换 = 内联_参数映射_查询(映射, 子[1])
            如果 (替换 != 空) { 追加(新, 替换)  有变 = 真 }
            否则 { 追加(新, 子) }
        } 否则 如果 (是列表(子) 且 计数(子) > 0) {
            // depth 2: 检查孙节点
            定义 可变 子新 = []
            定义 可变 子变 = 假
            定义 可变 j = 0
            当 (j < 计数(子)) {
                定义 孙 = 子[j]
                如果 (是列表(孙) 且 计数(孙) >= 2 且 孙[0] == 102) {
                    定义 替换 = 内联_参数映射_查询(映射, 孙[1])
                    如果 (替换 != 空) { 追加(子新, 替换)  子变 = 真 }
                    否则 { 追加(子新, 孙) }
                } 否则 {
                    追加(子新, 孙)
                }
                j = j + 1
            }
            如果 (子变) { 追加(新, 子新)  有变 = 真 }
            否则 { 追加(新, 子) }
        } 否则 {
            追加(新, 子)
        }
        i = i + 1
    }
    如果 (有变) { 返回 新 }
    返回 expr
}

// 路径替换：只在参数标识符处创建新浅拷贝节点，其他位置共享原引用
// 返回: 原节点(无变化时) 或 新浅拷贝节点(有参数替换时)
函数 _内联_路径替换(节点, 映射) {
    如果 (节点 == 空 或 是列表(节点) == 假 或 计数(节点) == 0) { 返回 节点 }
    // 标识符节点: 检查是否是形参
    如果 (节点[0] == 102 且 计数(节点) >= 2) {
        定义 替换 = 内联_参数映射_查询(映射, 节点[1])
        如果 (替换 != 空) { 返回 替换 }
        返回 节点
    }
    // 递归处理子节点，只在有变化时创建新浅拷贝
    定义 可变 有变化 = 假
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(节点)) {
        定义 原子 = 节点[i]
        定义 新子 = _内联_路径替换(原子, 映射)
        追加(结果, 新子)
        如果 (新子 != 原子) { 有变化 = 真 }
        i = i + 1
    }
    如果 (有变化) { 返回 结果 }
    返回 节点
}

// 递归深拷贝AST节点：列表类型逐元素复制，非列表直接返回
函数 _内联_深拷贝(节点) {
    如果 (节点 == 空 或 是列表(节点) == 假) { 返回 节点 }
    定义 可变 副本 = []
    定义 可变 i = 0
    当 (i < 计数(节点)) {
        如果 (是列表(节点[i])) {
            追加(副本, _内联_深拷贝(节点[i]))
        } 否则 {
            追加(副本, 节点[i])
        }
        i = i + 1
    }
    返回 副本
}

// 递归替换AST中的形参标识符为实参表达式
// 映射: 内联_参数映射 结构 (形参名→实参节点)
// 等价于 _内联_路径替换 但作用于深拷贝后的节点
函数 _内联_替换参数(节点, 映射) {
    返回 _内联_路径替换(节点, 映射)
}

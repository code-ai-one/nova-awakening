导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/字符串替换.nova")
导入("../标准/文件.nova")

定义 权限_读 = 4
定义 权限_写 = 2
定义 权限_执行 = 1

定义 可变 chmod_成功数 = 0
定义 可变 chmod_失败数 = 0

函数 chmod_main(参数) {
    定义 可变 递归 = 假
    定义 可变 详细 = 假
    定义 可变 安静 = 假
    定义 可变 仅变化 = 假
    定义 可变 模式文本 = ""
    定义 可变 文件列表 = []

    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 a = 参数[i]
        如果 (a == "-R") { 递归 = 真 }
        否则 如果 (a == "-v") { 详细 = 真 }
        否则 如果 (a == "-f") { 安静 = 真 }
        否则 如果 (a == "-c") { 仅变化 = 真; 详细 = 真 }
        否则 如果 (a == "--help" || a == "-h") { chmod_显示帮助(); 返回 0 }
        否则 如果 (模式文本 == "") { 模式文本 = a }
        否则 { 追加(文件列表, a) }
        i = i + 1
    }

    如果 (模式文本 == "" || 计数(文件列表) == 0) {
        chmod_显示帮助()
        返回 1
    }

    chmod_成功数 = 0
    chmod_失败数 = 0

    定义 是八进制 = chmod_是八进制模式(模式文本)

    定义 可变 k = 0
    当 (k < 计数(文件列表)) {
        如果 (递归) {
            chmod_递归处理(文件列表[k], 模式文本, 是八进制, 详细, 安静, 仅变化)
        } 否则 {
            chmod_处理文件(文件列表[k], 模式文本, 是八进制, 详细, 安静, 仅变化)
        }
        k = k + 1
    }

    如果 (chmod_失败数 > 0 && !安静) {
        打印行("chmod: " + 转字符串(chmod_失败数) + " 个文件处理失败")
    }

    如果 (chmod_失败数 > 0) { 返回 1 }
    返回 0
}

函数 chmod_显示帮助() {
    打印行("用法: chmod [-Rvcf] 模式 文件...")
    打印行("模式格式:")
    打印行("  八进制: 755, 644, 600 等")
    打印行("  符号: u+x, g-w, o=r, a+rw 等")
    打印行("选项:")
    打印行("  -R    递归处理目录")
    打印行("  -v    详细输出")
    打印行("  -c    仅显示变化的文件")
    打印行("  -f    静默模式,忽略错误")
}

函数 chmod_处理文件(路径, 模式文本, 是八进制, 详细, 安静, 仅变化) {
    定义 旧权限 = 文件_获取权限(路径)
    如果 (旧权限 < 0) {
        如果 (!安静) { 打印行("chmod: 无法访问 '" + 路径 + "'") }
        chmod_失败数 = chmod_失败数 + 1
        返回
    }

    定义 可变 新权限 = 0
    如果 (是八进制) {
        新权限 = 字符串转八进制(模式文本)
    } 否则 {
        新权限 = chmod_解析符号模式(模式文本, 旧权限)
    }

    如果 (新权限 == 旧权限 && 仅变化) { 返回 }

    定义 结果 = 文件_设置权限(路径, 新权限)
    如果 (结果 < 0) {
        如果 (!安静) { 打印行("chmod: 设置权限失败 '" + 路径 + "'") }
        chmod_失败数 = chmod_失败数 + 1
    } 否则 {
        chmod_成功数 = chmod_成功数 + 1
        如果 (详细) {
            打印行("'" + 路径 + "': " + chmod_权限字符串(旧权限) + " -> " + chmod_权限字符串(新权限))
        }
    }
}

函数 chmod_递归处理(路径, 模式文本, 是八进制, 详细, 安静, 仅变化) {
    chmod_处理文件(路径, 模式文本, 是八进制, 详细, 安静, 仅变化)
    定义 子列表 = 目录_列出(路径)
    如果 (子列表 == 空) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(子列表)) {
        定义 子路径 = 路径 + "/" + 子列表[i]
        如果 (文件_是目录(子路径)) {
            chmod_递归处理(子路径, 模式文本, 是八进制, 详细, 安静, 仅变化)
        } 否则 {
            chmod_处理文件(子路径, 模式文本, 是八进制, 详细, 安静, 仅变化)
        }
        i = i + 1
    }
}

函数 chmod_是八进制模式(文本) {
    如果 (字符串长度(文本) == 0) { 返回 假 }
    定义 第一字符 = 编码(字符串取字符(文本, 0))
    返回 第一字符 >= 48 && 第一字符 <= 55
}

函数 chmod_解析符号模式(模式, 旧权限) {
    定义 可变 结果 = 旧权限
    定义 可变 主体 = 0
    定义 可变 操作 = ""
    定义 可变 权限值 = 0

    定义 可变 i = 0
    当 (i < 字符串长度(模式)) {
        定义 c = 字符串取字符(模式, i)
        如果 (c == "u") { 主体 = 主体 | 0o700 }
        否则 如果 (c == "g") { 主体 = 主体 | 0o070 }
        否则 如果 (c == "o") { 主体 = 主体 | 0o007 }
        否则 如果 (c == "a") { 主体 = 0o777 }
        否则 如果 (c == "+" || c == "-" || c == "=") {
            操作 = c
            如果 (主体 == 0) { 主体 = 0o777 }
        }
        否则 如果 (c == "r") { 权限值 = 权限值 | 4 }
        否则 如果 (c == "w") { 权限值 = 权限值 | 2 }
        否则 如果 (c == "x") { 权限值 = 权限值 | 1 }
        i = i + 1
    }

    定义 可变 掩码 = 0
    如果 (主体 & 0o700) { 掩码 = 掩码 | (权限值 * 64) }
    如果 (主体 & 0o070) { 掩码 = 掩码 | (权限值 * 8) }
    如果 (主体 & 0o007) { 掩码 = 掩码 | 权限值 }

    如果 (操作 == "+") { 结果 = 结果 | 掩码 }
    否则 如果 (操作 == "-") { 结果 = 结果 & ~掩码 }
    否则 如果 (操作 == "=") {
        结果 = 结果 & ~主体
        结果 = 结果 | 掩码
    }
    返回 结果
}

函数 chmod_权限字符串(模式) {
    定义 可变 结果 = ""
    结果 = 结果 + (如果 (模式 & 0o400) { "r" } 否则 { "-" })
    结果 = 结果 + (如果 (模式 & 0o200) { "w" } 否则 { "-" })
    结果 = 结果 + (如果 (模式 & 0o100) { "x" } 否则 { "-" })
    结果 = 结果 + (如果 (模式 & 0o040) { "r" } 否则 { "-" })
    结果 = 结果 + (如果 (模式 & 0o020) { "w" } 否则 { "-" })
    结果 = 结果 + (如果 (模式 & 0o010) { "x" } 否则 { "-" })
    结果 = 结果 + (如果 (模式 & 0o004) { "r" } 否则 { "-" })
    结果 = 结果 + (如果 (模式 & 0o002) { "w" } 否则 { "-" })
    结果 = 结果 + (如果 (模式 & 0o001) { "x" } 否则 { "-" })
    返回 结果
}

函数 字符串转八进制(文本) {
    定义 可变 结果 = 0
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 c = 编码(字符串取字符(文本, i))
        如果 (c >= 48 && c <= 55) { 结果 = 结果 * 8 + (c - 48) }
        i = i + 1
    }
    返回 结果
}

定义 可变 AI_改权限_热文件表 = []

函数 AI_改权限_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_改权限_热文件表)) {
        如果 (AI_改权限_热文件表[i].路径 == 路径) {
            AI_改权限_热文件表[i].频率 = AI_改权限_热文件表[i].频率 + 1
            返回 AI_改权限_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_改权限_热文件表) < 128) {
        追加(AI_改权限_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_改权限_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

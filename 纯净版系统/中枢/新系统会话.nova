// NovaOS内核 · 会话管理 (移植自Nova大脑L8/session)
// 多会话隔离 + 状态持久化 + 上下文切换
// §1 会话创建/销毁: 每个用户/任务独立会话
// §2 会话切换: 保存/恢复AI状态(类似进程上下文切换)
// §3 会话持久化: 写入磁盘可恢复
// §4 会话隔离: 不同会话的AI状态互不干扰

定义 会话_最大数 = 32
定义 会话状态_空闲 = 0
定义 会话状态_活跃 = 1
定义 会话状态_挂起 = 2
定义 会话状态_结束 = 3

结构 AI会话 {
    会话ID,
    用户ID,
    状态,
    对话模式,
    创建时间,
    最后活跃,
    对话轮数,
    上下文哈希,    // u64 上下文快照的哈希
    记忆快照,    // 列表 工作记忆快照
}

定义 可变 会话表 = []
定义 可变 当前会话ID = 0
定义 可变 会话_计数 = 0
定义 可变 会话_时钟 = 0
定义 可变 会话_已初始化 = 假

函数 会话_确保已初始化() {
    如果 (!会话_已初始化) { 会话_初始化() }
}

函数 会话_初始化() {
    会话表 = []
    当前会话ID = 0
    会话_计数 = 0
    会话_时钟 = 0
    会话_已初始化 = 真
    会话_重置统计()
    内核信息("会话管理: " + 整数转字符串(会话_最大数) + "会话 隔离+切换+持久化")
}

函数 会话_创建(用户ID) {
    会话_确保已初始化()
    如果 (计数(会话表) >= 会话_最大数) { 返回 -1 }
    会话_时钟 = 会话_时钟 + 1
    会话_计数 = 会话_计数 + 1
    定义 s = AI会话 {}
    s.会话ID = 会话_计数
    s.用户ID = 用户ID
    s.状态 = 会话状态_活跃
    s.对话模式 = 0
    s.创建时间 = 会话_时钟
    s.最后活跃 = 会话_时钟
    s.对话轮数 = 0
    s.上下文哈希 = 0
    s.记忆快照 = []
    追加(会话表, s)
    会话_创建总数 = 会话_创建总数 + 1
    如果 (当前会话ID == 0) { 当前会话ID = s.会话ID }
    返回 s.会话ID
}

函数 会话_切换(目标会话ID) {
    会话_确保已初始化()
    会话_时钟 = 会话_时钟 + 1
    // 保存当前会话状态
    如果 (当前会话ID > 0) {
        定义 当前 = 会话_查找(当前会话ID)
        如果 (当前 != 空) { 当前.状态 = 会话状态_挂起 }
    }
    // 恢复目标会话
    定义 目标 = 会话_查找(目标会话ID)
    如果 (目标 == 空) { 返回 -1 }
    目标.状态 = 会话状态_活跃
    目标.最后活跃 = 会话_时钟
    当前会话ID = 目标会话ID
    // 恢复对话模式
    对话_切换模式(目标.对话模式)
    返回 0
}

函数 会话_销毁(会话ID) {
    会话_确保已初始化()
    定义 可变 i = 0
    当 (i < 计数(会话表)) {
        如果 (会话表[i].会话ID == 会话ID) {
            会话表[i].状态 = 会话状态_结束
            链表_删除(会话表, i)
            如果 (当前会话ID == 会话ID) { 当前会话ID = 0 }
            会话_销毁总数 = 会话_销毁总数 + 1
            返回 0
        }
        i = i + 1
    }
    返回 -1
}

函数 会话_记录对话(会话ID) {
    会话_确保已初始化()
    会话_时钟 = 会话_时钟 + 1
    定义 s = 会话_查找(会话ID)
    如果 (s != 空) {
        s.状态 = 会话状态_活跃
        s.对话轮数 = s.对话轮数 + 1
        s.最后活跃 = 会话_时钟
    }
}

函数 会话_保存快照(会话ID, 上下文哈希, 记忆列表) {
    会话_确保已初始化()
    会话_时钟 = 会话_时钟 + 1
    定义 s = 会话_查找(会话ID)
    如果 (s != 空) {
        s.上下文哈希 = 上下文哈希
        s.记忆快照 = 记忆列表
        s.最后活跃 = 会话_时钟
    }
}

函数 会话_查找(会话ID) {
    定义 可变 i = 0
    当 (i < 计数(会话表)) {
        如果 (会话表[i].会话ID == 会话ID) { 返回 会话表[i] }
        i = i + 1
    }
    返回 空
}

函数 会话_当前() { 返回 当前会话ID }
函数 会话_活跃数() {
    定义 可变 n = 0
    定义 可变 i = 0
    当 (i < 计数(会话表)) {
        如果 (会话表[i].状态 == 会话状态_活跃) { n = n + 1 }
        i = i + 1
    }
    返回 n
}
函数 会话_总数() { 返回 计数(会话表) }

// 会话超时管理 (自动清理不活跃会话)

定义 会话_超时阈值 = 3600  // 1小时无活跃则超时

函数 会话_清理超时() {
    会话_确保已初始化()
    会话_时钟 = 会话_时钟 + 1
    定义 可变 清理数 = 0
    定义 可变 i = 计数(会话表) - 1
    当 (i >= 0) {
        定义 s = 会话表[i]
        如果 (s.状态 != 会话状态_空闲 && 会话_时钟 - s.最后活跃 > 会话_超时阈值) {
            // 超时会话: 先保存快照再销毁
            内核信息("会话: ID=" + 整数转字符串(s.会话ID) + " 超时清理")
            如果 (当前会话ID == s.会话ID) { 当前会话ID = 0 }
            会话_超时总数 = 会话_超时总数 + 1
            会话_销毁总数 = 会话_销毁总数 + 1
            链表_删除(会话表, i)
            清理数 = 清理数 + 1
        }
        i = i - 1
    }
    返回 清理数
}

// 会话权限检查

函数 会话_检查权限(会话ID, 请求用户ID) {
    定义 s = 会话_查找(会话ID)
    如果 (s == 空) { 返回 假 }
    // root(uid=0)可以访问所有会话
    如果 (请求用户ID == 0) { 返回 真 }
    // 普通用户只能访问自己的会话
    返回 s.用户ID == 请求用户ID
}

// 会话列表 (供管理接口使用)

函数 会话_列表() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(会话表)) {
        定义 s = 会话表[i]
        追加(结果, [s.会话ID, s.用户ID, s.状态, s.对话轮数, s.最后活跃])
        i = i + 1
    }
    返回 结果
}

函数 会话_按用户查找(用户ID) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(会话表)) {
        如果 (会话表[i].用户ID == 用户ID) {
            追加(结果, 会话表[i])
        }
        i = i + 1
    }
    返回 结果
}

// 会话持久化 (序列化/反序列化)

函数 会话_序列化(会话ID) {
    定义 s = 会话_查找(会话ID)
    如果 (s == 空) { 返回 空 }
    // 序列化为键值对列表
    返回 [
        ["id", s.会话ID],
        ["uid", s.用户ID],
        ["state", s.状态],
        ["mode", s.对话模式],
        ["created", s.创建时间],
        ["active", s.最后活跃],
        ["turns", s.对话轮数],
        ["ctx_hash", s.上下文哈希],
        ["mem_count", 计数(s.记忆快照)]
    ]
}

函数 会话_反序列化(数据) {
    会话_确保已初始化()
    如果 (数据 == 空 || 计数(数据) < 7) { 返回 -1 }
    定义 s = AI会话 {}
    s.会话ID = 数据[0][1]
    s.用户ID = 数据[1][1]
    s.状态 = 数据[2][1]
    s.对话模式 = 数据[3][1]
    s.创建时间 = 数据[4][1]
    s.最后活跃 = 数据[5][1]
    s.对话轮数 = 数据[6][1]
    如果 (计数(数据) > 7) { s.上下文哈希 = 数据[7][1] }
    s.记忆快照 = []
    追加(会话表, s)
    如果 (s.会话ID > 会话_计数) { 会话_计数 = s.会话ID }
    返回 s.会话ID
}

// 统计

函数 会话_统计() {
    定义 可变 活跃 = 0
    定义 可变 挂起 = 0
    定义 可变 总轮数 = 0
    定义 可变 i = 0
    当 (i < 计数(会话表)) {
        如果 (会话表[i].状态 == 会话状态_活跃) { 活跃 = 活跃 + 1 }
        否则 如果 (会话表[i].状态 == 会话状态_挂起) { 挂起 = 挂起 + 1 }
        总轮数 = 总轮数 + 会话表[i].对话轮数
        i = i + 1
    }
    返回 [计数(会话表), 活跃, 挂起, 总轮数]
}


函数 会话_状态名(状态) {
    如果 (状态 == 会话状态_活跃) { 返回 "active" }
    如果 (状态 == 会话状态_挂起) { 返回 "suspended" }
    如果 (状态 == 会话状态_结束) { 返回 "ended" }
    返回 "unknown"
}

函数 会话_完整统计() {
    定义 s = 会话_统计()
    返回 s
}

// 会话管理健康检查

定义 可变 会话_创建总数 = 0
定义 可变 会话_销毁总数 = 0
定义 可变 会话_超时总数 = 0

函数 会话管理_健康检查() {
    定义 可变 问题 = []
    定义 活跃 = 会话_创建总数 - 会话_销毁总数
    如果 (活跃 > 10000) {
        追加(问题, "活跃会话过多: " + 整数转字符串(活跃))
    }
    如果 (会话_超时总数 > 会话_创建总数 / 2 && 会话_创建总数 > 100) {
        追加(问题, "会话超时率过高")
    }
    如果 (计数(问题) == 0) { 返回 "会话管理健康" }
    返回 问题
}

函数 会话_重置统计() {
    会话_创建总数 = 0
    会话_销毁总数 = 0
    会话_超时总数 = 0
}

函数 会话_超时率() {
    如果 (会话_创建总数 == 0) { 返回 0 }
    返回 会话_超时总数 * 100 / 会话_创建总数
}

函数 会话_完整报告() {
    返回 [会话_创建总数, 会话_销毁总数, 会话_超时总数, 会话_活跃数()]
}

函数 新系统会话_统计() {
    返回 {
        会话计数: 会话_计数,
        会话已初始化: 会话_已初始化,
        会话创建总数: 会话_创建总数,
        会话销毁总数: 会话_销毁总数,
        会话超时总数: 会话_超时总数
    }
}

函数 新系统会话_健康评估() {
    定义 可变 问题 = []
    如果 (计数(会话表) > 10000) { 追加(问题, "会话表膨胀") }
    如果 (会话_计数 > 100000) { 追加(问题, "会话_计数异常增长") }
    如果 (会话_已初始化 == 假) { 追加(问题, "会话_已初始化未就绪") }
    如果 (会话_创建总数 > 100000) { 追加(问题, "会话_创建总数异常增长") }
    如果 (会话_销毁总数 > 100000) { 追加(问题, "会话_销毁总数异常增长") }
    如果 (会话_超时总数 > 100000) { 追加(问题, "会话_超时总数异常增长") }
    返回 计数(问题) == 0
}

函数 新系统会话_综合报告() {
    打印("[新系统会话] ═══ 综合报告 ═══")
    打印("  会话_计数: " + 整数转字符串(会话_计数))
    打印("  会话_已初始化: " + 如果 (会话_已初始化) { "true" } 否则 { "false" })
    打印("  会话_创建总数: " + 整数转字符串(会话_创建总数))
    打印("  会话_销毁总数: " + 整数转字符串(会话_销毁总数))
    打印("  会话_超时总数: " + 整数转字符串(会话_超时总数))
    打印("  健康: " + 如果 (新系统会话_健康评估()) { "正常" } 否则 { "异常" })
}

函数 新系统会话_全局重置() {
    会话_计数 = 0
    会话_已初始化 = 0
    会话_创建总数 = 0
    会话_销毁总数 = 0
    会话_超时总数 = 0
    打印("[新系统会话] 统计已重置")
    返回 0
}

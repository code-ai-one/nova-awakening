导入("./类型定义.nova")
导入("./错误码.nova")
导入("./公平调度调.nova")
导入("./进程描述符.nova")
导入("./内核打印.nova")
导入("./高精定器添.nova")
导入("./整数转字符串.nova")

定义 RT_优先级数 = 100
定义 调度_实时FIFO = 1
定义 调度_实时RR = 2
定义 调度_普通 = 0
定义 调度_最大CPU = 8
定义 优先级提升_IO = 5
定义 优先级提升_交互 = 3
定义 负载均衡_阈值 = 20

定义 可变 RT_FIFO队列 = []
定义 可变 RT_进程数 = 0
定义 可变 Nova公平调度_当前执行时间 = 0

结构 调度统计 {
    入队次数,
    出队次数,
    选择次数,
    tick次数,
    抢占次数,
    迁移次数,
    负载均衡次数,
    优先级提升次数,
    睡眠保存次数,
    睡眠恢复次数,
    RT入队次数,
    RT出队次数,
    RT选择次数,
    空闲选择次数,
    AI建议次数,
}

定义 可变 全局_调度统计 = 空

函数 调度统计_初始化() {
    如果 (全局_调度统计 == 空) {
        全局_调度统计 = 调度统计 {}
        全局_调度统计.入队次数 = 0
        全局_调度统计.出队次数 = 0
        全局_调度统计.选择次数 = 0
        全局_调度统计.tick次数 = 0
        全局_调度统计.抢占次数 = 0
        全局_调度统计.迁移次数 = 0
        全局_调度统计.负载均衡次数 = 0
        全局_调度统计.优先级提升次数 = 0
        全局_调度统计.睡眠保存次数 = 0
        全局_调度统计.睡眠恢复次数 = 0
        全局_调度统计.RT入队次数 = 0
        全局_调度统计.RT出队次数 = 0
        全局_调度统计.RT选择次数 = 0
        全局_调度统计.空闲选择次数 = 0
        全局_调度统计.AI建议次数 = 0

        定义 可变 p = 0
        当 (p < RT_优先级数) {
            追加(RT_FIFO队列, [])
            p = p + 1
        }
    }
}

函数 Nova公平调度_睡眠保存(任务) {
    调度统计_初始化()
    全局_调度统计.睡眠保存次数 = 全局_调度统计.睡眠保存次数 + 1
    定义 平均v = Nova公平调度_平均Nova虚拟运行时间()
    设置(任务, T_vlag, 平均v - 任务[T_虚拟运行时间])
    设置(任务, T_睡眠时间戳, 获取滴答())
}

函数 Nova公平调度_唤醒恢复(任务) {
    调度统计_初始化()
    全局_调度统计.睡眠恢复次数 = 全局_调度统计.睡眠恢复次数 + 1

    定义 平均v = Nova公平调度_平均Nova虚拟运行时间()
    定义 vlag = 任务[T_vlag]
    任务[T_虚拟运行时间] = 平均v - vlag

    定义 睡眠时长 = 获取滴答() - 任务[T_睡眠时间戳]
    如果 (睡眠时长 > 1000000) {
        调度_优先级提升(任务, 优先级提升_IO)
    }
}

函数 RT_入队(任务) {
    调度统计_初始化()
    全局_调度统计.RT入队次数 = 全局_调度统计.RT入队次数 + 1
    定义 可变 优先级 = 任务[T_优先级]
    如果 (优先级 < 0) { 优先级 = 0 }
    如果 (优先级 >= RT_优先级数) { 优先级 = RT_优先级数 - 1 }
    追加(RT_FIFO队列[优先级], 任务)
    RT_进程数 = RT_进程数 + 1
}

函数 RT_出队(任务) {
    调度统计_初始化()
    全局_调度统计.RT出队次数 = 全局_调度统计.RT出队次数 + 1
    定义 可变 优先级 = 任务[T_优先级]
    如果 (优先级 < 0) { 优先级 = 0 }
    如果 (优先级 >= RT_优先级数) { 优先级 = RT_优先级数 - 1 }
    定义 队列 = RT_FIFO队列[优先级]
    定义 可变 i = 0
    当 (i < 计数(队列)) {
        如果 (队列[i] == 任务) {
            删除(队列, i)
            RT_进程数 = RT_进程数 - 1
            返回 成功
        }
        i = i + 1
    }
    返回 错误_不存在
}

函数 RT_选择下一个() {
    调度统计_初始化()
    全局_调度统计.RT选择次数 = 全局_调度统计.RT选择次数 + 1
    如果 (RT_进程数 <= 0) { 返回 空 }
    定义 可变 p = 0
    当 (p < RT_优先级数) {
        如果 (计数(RT_FIFO队列[p]) > 0) {
            定义 任务 = RT_FIFO队列[p][0]
            删除(RT_FIFO队列[p], 0)
            RT_进程数 = RT_进程数 - 1
            进程_设置状态(任务, 进程_运行)
            返回 任务
        }
        p = p + 1
    }
    返回 空
}

函数 RT_tick(当前任务, delta_us) {
    如果 (当前任务 == 空) { 返回 假 }
    如果 (当前任务[T_调度策略] == 调度_实时FIFO) {
        返回 假
    }
    如果 (当前任务[T_调度策略] == 调度_实时RR) {
        Nova公平调度_当前执行时间 = Nova公平调度_当前执行时间 + delta_us
        如果 (Nova公平调度_当前执行时间 >= 10000) {
            Nova公平调度_当前执行时间 = 0
            调度统计_初始化()
            全局_调度统计.抢占次数 = 全局_调度统计.抢占次数 + 1
            返回 真
        }
    }
    返回 假
}

函数 调度_入队(任务) {
    调度统计_初始化()
    全局_调度统计.入队次数 = 全局_调度统计.入队次数 + 1
    如果 (进程_是实时(任务)) {
        RT_入队(任务)
    } 否则 {
        Nova公平调度_入队(任务)
    }
}

函数 调度_出队(任务) {
    调度统计_初始化()
    全局_调度统计.出队次数 = 全局_调度统计.出队次数 + 1
    如果 (进程_是实时(任务)) {
        RT_出队(任务)
    } 否则 {
        Nova公平调度_出队(任务)
    }
}

函数 调度_选择下一个() {
    调度统计_初始化()
    全局_调度统计.选择次数 = 全局_调度统计.选择次数 + 1

    定义 rt = RT_选择下一个()
    如果 (rt != 空) { 返回 rt }

    定义 cfs = Nova公平调度_选择下一个()
    如果 (cfs != 空) { 返回 cfs }

    全局_调度统计.空闲选择次数 = 全局_调度统计.空闲选择次数 + 1
    返回 空
}

函数 调度_tick(当前任务, delta_us) {
    调度统计_初始化()
    全局_调度统计.tick次数 = 全局_调度统计.tick次数 + 1

    如果 (当前任务 == 空) { 返回 假 }

    如果 (进程_是实时(当前任务)) {
        返回 RT_tick(当前任务, delta_us)
    }

    定义 需要抢占 = Nova公平调度_tick(当前任务, delta_us)
    如果 (需要抢占) {
        全局_调度统计.抢占次数 = 全局_调度统计.抢占次数 + 1
    }
    返回 需要抢占
}

函数 调度_优先级提升(任务, 提升量) {
    调度统计_初始化()
    全局_调度统计.优先级提升次数 = 全局_调度统计.优先级提升次数 + 1

    如果 (任务 == 空) { 返回 }
    如果 (进程_是实时(任务)) { 返回 }

    定义 当前优先级 = 任务[T_优先级]
    定义 新优先级 = 当前优先级 - 提升量
    如果 (新优先级 < 0) { 新优先级 = 0 }
    任务[T_优先级] = 新优先级
}

函数 调度_优先级衰减(任务) {
    如果 (任务 == 空) { 返回 }
    如果 (进程_是实时(任务)) { 返回 }

    定义 当前优先级 = 任务[T_优先级]
    定义 默认优先级 = 任务[T_默认优先级]
    如果 (当前优先级 < 默认优先级) {
        任务[T_优先级] = 当前优先级 + 1
        如果 (任务[T_优先级] > 默认优先级) {
            任务[T_优先级] = 默认优先级
        }
    }
}

函数 调度_负载均衡() {
    调度统计_初始化()
    全局_调度统计.负载均衡次数 = 全局_调度统计.负载均衡次数 + 1

    定义 可变 最大负载CPU = 0
    定义 可变 最大负载 = 0
    定义 可变 最小负载CPU = 0
    定义 可变 最小负载 = 999999

    定义 可变 cpu = 0
    当 (cpu < 调度_最大CPU) {
        定义 负载 = 调度_获取CPU负载(cpu)
        如果 (负载 > 最大负载) {
            最大负载 = 负载
            最大负载CPU = cpu
        }
        如果 (负载 < 最小负载) {
            最小负载 = 负载
            最小负载CPU = cpu
        }
        cpu = cpu + 1
    }

    如果 (最大负载 - 最小负载 > 负载均衡_阈值) {
        调度_迁移任务(最大负载CPU, 最小负载CPU)
    }
}

函数 调度_迁移任务(源CPU, 目标CPU) {
    调度统计_初始化()
    全局_调度统计.迁移次数 = 全局_调度统计.迁移次数 + 1

    定义 任务 = 调度_获取可迁移任务(源CPU)
    如果 (任务 == 空) { 返回 }

    调度_出队(任务)
    任务[T_CPU亲和] = 目标CPU
    调度_入队(任务)
}

函数 调度_获取CPU负载(cpu) {
    定义 运行 = 调度_运行队列长度()
    返回 运行 * 100
}

函数 调度_获取可迁移任务(cpu) {
    返回 调度_运行队列长度() / 2
}

函数 调度_AI建议(任务) {
    调度统计_初始化()
    全局_调度统计.AI建议次数 = 全局_调度统计.AI建议次数 + 1

    定义 特征 = [
        任务[T_优先级],
        任务[T_虚拟运行时间],
        任务[T_调度策略],
        任务[T_CPU亲和]
    ]
    定义 建议 = AI调度钩子_预测(特征)
    如果 (建议 != 空 && 建议.置信度 > 70) {
        如果 (建议.动作 == "提升") {
            调度_优先级提升(任务, 建议.提升量)
        } 否则 如果 (建议.动作 == "迁移") {
            调度_迁移任务(任务[T_CPU亲和], 建议.目标CPU)
        }
    }
}

函数 调度_打印统计() {
    调度统计_初始化()
    打印行("=== 调度统计 ===")
    打印行("入队: " + 整数转字符串(全局_调度统计.入队次数))
    打印行("出队: " + 整数转字符串(全局_调度统计.出队次数))
    打印行("选择: " + 整数转字符串(全局_调度统计.选择次数))
    打印行("tick: " + 整数转字符串(全局_调度统计.tick次数))
    打印行("抢占: " + 整数转字符串(全局_调度统计.抢占次数))
    打印行("迁移: " + 整数转字符串(全局_调度统计.迁移次数))
    打印行("负载均衡: " + 整数转字符串(全局_调度统计.负载均衡次数))
    打印行("优先级提升: " + 整数转字符串(全局_调度统计.优先级提升次数))
    打印行("睡眠保存: " + 整数转字符串(全局_调度统计.睡眠保存次数))
    打印行("睡眠恢复: " + 整数转字符串(全局_调度统计.睡眠恢复次数))
    打印行("RT入队: " + 整数转字符串(全局_调度统计.RT入队次数))
    打印行("RT出队: " + 整数转字符串(全局_调度统计.RT出队次数))
    打印行("RT选择: " + 整数转字符串(全局_调度统计.RT选择次数))
    打印行("空闲选择: " + 整数转字符串(全局_调度统计.空闲选择次数))
    打印行("AI建议: " + 整数转字符串(全局_调度统计.AI建议次数))
    打印行("RT进程数: " + 整数转字符串(RT_进程数))
}

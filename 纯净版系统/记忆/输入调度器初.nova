// NovaOS IO调度器
// 功能: 多队列Deadline IO调度，读写分离队列，批处理，合并

导入("../中枢/链表移到头部.nova")
导入("../推理/值乘.nova")
导入("../中枢/同步原语.nova")
导入("../中枢/墙钟设置.nova")
导入("../中枢/哈希函数.nova")
导入("../中枢/数学工具.nova")
导入("./块输入输出设.nova")
导入("./块输入输出获.nova")

定义 IO调度_读截止时间     = 500      // 读请求截止时间(ms)
定义 IO调度_写截止时间     = 5000     // 写请求截止时间(ms)
定义 IO调度_读批量大小     = 16       // 读批量处理数
定义 IO调度_写批量大小     = 8        // 写批量处理数
定义 IO调度_写饥饿阈值     = 2        // 写饥饿阈值(连续读批次数)
定义 IO调度_FIFO检查间隔   = 100      // FIFO截止检查间隔(ms)

定义 IO调度器_NONE         = 0
定义 IO调度器_DEADLINE     = 1
定义 IO调度器_BFQ          = 2

// IO请求(包装Bio)

结构 IO请求 {
    bio,    // 指针<Bio>
    扇区,
    扇区数,
    方向,    // u8 0=读, 1=写
    截止时间,
    提交时间,
    排序链接,    // 指针<IO请求> 按扇区排序的链表
    FIFO链接,    // 指针<IO请求> 按到达时间的FIFO链表
    已合并,
}

// Deadline调度器数据

结构 Deadline调度器 {
    // 读队列(按扇区排序 + FIFO)
    读_排序头,    // 指针<IO请求>
    读_FIFO头,    // 指针<IO请求>
    读_数量,
    // 写队列(按扇区排序 + FIFO)
    写_排序头,    // 指针<IO请求>
    写_FIFO头,    // 指针<IO请求>
    写_数量,
    // 调度状态
    当前批量_方向,
    当前批量_剩余,
    写饥饿计数,
    上次扇区,
    总处理数,
    总合并数,
    锁,    // 自旋锁
}

定义 可变 全局调度器 = Deadline调度器 {}
定义 可变 调度器类型 = IO调度器_DEADLINE

// 初始化

函数 IO调度器_初始化() {
    全局调度器.读_排序头 = 空
    全局调度器.读_FIFO头 = 空
    全局调度器.读_数量 = 0
    全局调度器.写_排序头 = 空
    全局调度器.写_FIFO头 = 空
    全局调度器.写_数量 = 0
    全局调度器.当前批量_方向 = 0
    全局调度器.当前批量_剩余 = IO调度_读批量大小
    全局调度器.写饥饿计数 = 0
    全局调度器.上次扇区 = 0
    全局调度器.总处理数 = 0
    全局调度器.总合并数 = 0
    全局调度器.锁 = 自旋锁_创建()

    内核信息("IO调度器初始化 (mq-deadline)\n")
}

// 提交请求

函数 IO调度器_提交_bio(bio) {
    // 创建IO请求
    定义 可变 req = 分配内存(大小(IO请求))
    如果 (req == 空) {
        bio_直接执行(bio)
        返回
    }

    req.bio = bio
    req.扇区 = bio.扇区
    req.扇区数 = bio_扇区数(bio)
    req.方向 = (bio.标志 & BIO_标志_写) != 0 ? 1 : 0
    req.提交时间 = 当前时间_秒()
    req.已合并 = 假

    // 设置截止时间
    如果 (req.方向 == 0) {
        req.截止时间 = req.提交时间 + IO调度_读截止时间
    } 否则 {
        req.截止时间 = req.提交时间 + IO调度_写截止时间
    }

    自旋锁_获取(全局调度器.锁)

    // 尝试合并
    如果 (IO调度器_尝试合并(req)) {
        自旋锁_释放(全局调度器.锁)
        释放内存(req)
        返回
    }

    // 插入队列
    IO调度器_插入请求(req)

    自旋锁_释放(全局调度器.锁)
}

// §4 NIOS理论 — Nova I/O Scheduler
// 低耦合高聚合IO调度增强层

定义 NIOS_版本 = "3.0.0-NIOS"
定义 NIOS_AI阈值 = 0.70
定义 NIOS_最大合并距离 = 256

定义 可变 NIOS_提交总数 = 0
定义 可变 NIOS_派发总数 = 0
定义 可变 NIOS_合并总数 = 0
定义 可变 NIOS_读总数 = 0
定义 可变 NIOS_写总数 = 0
定义 可变 NIOS_截止触发数 = 0
定义 可变 NIOS_AI推理次数 = 0

// §4.1 队列插入与合并

函数 IO调度器_插入请求(req) {
    NIOS_提交总数 = NIOS_提交总数 + 1
    如果 (req.方向 == 0) {
        NIOS_读总数 = NIOS_读总数 + 1
        NIOS_排序插入(全局调度器.读_排序头, req)
        NIOS_FIFO插入(全局调度器.读_FIFO头, req)
        全局调度器.读_数量 = 全局调度器.读_数量 + 1
    } 否则 {
        NIOS_写总数 = NIOS_写总数 + 1
        NIOS_排序插入(全局调度器.写_排序头, req)
        NIOS_FIFO插入(全局调度器.写_FIFO头, req)
        全局调度器.写_数量 = 全局调度器.写_数量 + 1
    }
}

函数 NIOS_排序插入(头, req) {
    // 按扇区地址排序插入
    如果 (头 == 空) {
        req.排序链接 = 空
        返回 req
    }
    如果 (req.扇区 < 头.扇区) {
        req.排序链接 = 头
        返回 req
    }
    定义 可变 当前 = 头
    当 (当前.排序链接 != 空 && 当前.排序链接.扇区 < req.扇区) {
        当前 = 当前.排序链接
    }
    req.排序链接 = 当前.排序链接
    当前.排序链接 = req
    返回 头
}

函数 NIOS_FIFO插入(头, req) {
    // 尾插
    req.FIFO链接 = 空
    如果 (头 == 空) { 返回 req }
    定义 可变 尾 = 头
    当 (尾.FIFO链接 != 空) { 尾 = 尾.FIFO链接 }
    尾.FIFO链接 = req
    返回 头
}

函数 IO调度器_尝试合并(req) {
    // 前合并/后合并: 相邻扇区合并
    定义 可变 头 = 如果(req.方向 == 0, 全局调度器.读_排序头, 全局调度器.写_排序头)
    定义 可变 当前 = 头
    当 (当前 != 空) {
        // 后合并: req紧跟当前后面
        如果 (当前.扇区 + 当前.扇区数 == req.扇区) {
            如果 (数学_绝对值(当前.扇区数 + req.扇区数) <= NIOS_最大合并距离) {
                当前.扇区数 = 当前.扇区数 + req.扇区数
                当前.已合并 = 真
                NIOS_合并总数 = NIOS_合并总数 + 1
                全局调度器.总合并数 = 全局调度器.总合并数 + 1
                返回 真
            }
        }
        // 前合并: req紧在当前前面
        如果 (req.扇区 + req.扇区数 == 当前.扇区) {
            如果 (数学_绝对值(当前.扇区数 + req.扇区数) <= NIOS_最大合并距离) {
                当前.扇区 = req.扇区
                当前.扇区数 = 当前.扇区数 + req.扇区数
                当前.已合并 = 真
                NIOS_合并总数 = NIOS_合并总数 + 1
                全局调度器.总合并数 = 全局调度器.总合并数 + 1
                返回 真
            }
        }
        当前 = 当前.排序链接
    }
    返回 假
}

// §5 派发引擎

函数 IO调度器_派发() {
    自旋锁_获取(全局调度器.锁)

    // 检查截止时间触发
    定义 现在 = 当前时间_秒()
    定义 读过期 = NIOS_检查FIFO截止(全局调度器.读_FIFO头, 现在)
    定义 写过期 = NIOS_检查FIFO截止(全局调度器.写_FIFO头, 现在)

    如果 (读过期 != 空) {
        NIOS_截止触发数 = NIOS_截止触发数 + 1
        NIOS_执行请求(读过期)
        自旋锁_释放(全局调度器.锁)
        返回
    }
    如果 (写过期 != 空) {
        NIOS_截止触发数 = NIOS_截止触发数 + 1
        NIOS_执行请求(写过期)
        自旋锁_释放(全局调度器.锁)
        返回
    }

    // 正常派发: 批量处理
    如果 (全局调度器.当前批量_剩余 <= 0) {
        NIOS_切换方向()
    }

    定义 可变 req = 空
    如果 (全局调度器.当前批量_方向 == 0) {
        req = NIOS_选择最近读(全局调度器.上次扇区)
    } 否则 {
        req = NIOS_选择最近写(全局调度器.上次扇区)
    }

    如果 (req != 空) {
        NIOS_执行请求(req)
        全局调度器.当前批量_剩余 = 全局调度器.当前批量_剩余 - 1
    }

    自旋锁_释放(全局调度器.锁)
}

函数 NIOS_检查FIFO截止(头, 现在) {
    如果 (头 == 空) { 返回 空 }
    如果 (头.截止时间 <= 现在) { 返回 头 }
    返回 空
}

函数 NIOS_切换方向() {
    如果 (全局调度器.当前批量_方向 == 0) {
        // 读→写
        全局调度器.写饥饿计数 = 全局调度器.写饥饿计数 + 1
        如果 (全局调度器.写饥饿计数 >= IO调度_写饥饿阈值 || 全局调度器.写_数量 > 0) {
            全局调度器.当前批量_方向 = 1
            全局调度器.当前批量_剩余 = IO调度_写批量大小
            全局调度器.写饥饿计数 = 0
        } 否则 {
            全局调度器.当前批量_剩余 = IO调度_读批量大小
        }
    } 否则 {
        // 写→读
        全局调度器.当前批量_方向 = 0
        全局调度器.当前批量_剩余 = IO调度_读批量大小
    }
}

函数 NIOS_选择最近读(上次扇区) {
    定义 头 = 全局调度器.读_排序头
    如果 (头 == 空) { 返回 空 }
    定义 可变 最近 = 头
    定义 可变 最小距 = 数学_绝对值(头.扇区 - 上次扇区)
    定义 可变 当前 = 头.排序链接
    当 (当前 != 空) {
        定义 距 = 数学_绝对值(当前.扇区 - 上次扇区)
        如果 (距 < 最小距) {
            最小距 = 距
            最近 = 当前
        }
        当前 = 当前.排序链接
    }
    返回 最近
}

函数 NIOS_选择最近写(上次扇区) {
    定义 头 = 全局调度器.写_排序头
    如果 (头 == 空) { 返回 空 }
    定义 可变 最近 = 头
    定义 可变 最小距 = 数学_绝对值(头.扇区 - 上次扇区)
    定义 可变 当前 = 头.排序链接
    当 (当前 != 空) {
        定义 距 = 数学_绝对值(当前.扇区 - 上次扇区)
        如果 (距 < 最小距) {
            最小距 = 距
            最近 = 当前
        }
        当前 = 当前.排序链接
    }
    返回 最近
}

函数 NIOS_执行请求(req) {
    NIOS_派发总数 = NIOS_派发总数 + 1
    全局调度器.上次扇区 = req.扇区 + req.扇区数
    全局调度器.总处理数 = 全局调度器.总处理数 + 1
    bio_直接执行(req.bio)
    // 从队列移除
    如果 (req.方向 == 0) {
        全局调度器.读_数量 = 全局调度器.读_数量 - 1
    } 否则 {
        全局调度器.写_数量 = 全局调度器.写_数量 - 1
    }
    释放内存(req)
}

// §6 AI调度优化

函数 NIOS_AI预测读写比(读数, 写数) {
    NIOS_AI推理次数 = NIOS_AI推理次数 + 1
    定义 tensor = Tensor_创建(5)
    Tensor_写(tensor, 0, 读数)
    Tensor_写(tensor, 1, 写数)
    Tensor_写(tensor, 2, NIOS_合并总数)
    Tensor_写(tensor, 3, NIOS_截止触发数)
    Tensor_写(tensor, 4, NIOS_派发总数)
    定义 推理 = AI总线_推理(全局AI总线, "nios_rw_ratio", tensor)
    定义 比例 = Tensor_读(推理, 0)
    Tensor_释放(tensor)
    Tensor_释放(推理)
    返回 比例
}

函数 NIOS_AI调整批量() {
    定义 比例 = NIOS_AI预测读写比(NIOS_读总数, NIOS_写总数)
    如果 (比例 >= NIOS_AI阈值) {
        // 读密集型：增大读批量
        全局调度器.当前批量_剩余 = IO调度_读批量大小 * 2
    } 否则 {
        // 写密集型：增大写批量
        全局调度器.当前批量_剩余 = IO调度_写批量大小 * 2
    }
}

函数 NIOS_AI异常检测() {
    定义 tensor = Tensor_创建(4)
    Tensor_写(tensor, 0, NIOS_提交总数)
    Tensor_写(tensor, 1, NIOS_派发总数)
    Tensor_写(tensor, 2, NIOS_合并总数)
    Tensor_写(tensor, 3, NIOS_截止触发数)
    定义 异常 = AI总线_异常检测(全局AI总线, "nios_anomaly", tensor)
    定义 分 = Tensor_读(异常, 0)
    Tensor_释放(tensor)
    Tensor_释放(异常)
    如果 (分 > 0.85) {
        内核信息("[NIOS] AI异常: IO调度异常 score=" + 分 + "\n")
    }
}

// §7 诊断与统计

函数 NIOS_诊断报告() {
    内核信息("[NIOS] === IO调度器诊断 ===")
    内核信息("  提交=" + NIOS_提交总数 + " 派发=" + NIOS_派发总数 + " 合并=" + NIOS_合并总数)
    内核信息("  读=" + NIOS_读总数 + " 写=" + NIOS_写总数 + " 截止触发=" + NIOS_截止触发数)
    内核信息("  AI推理=" + NIOS_AI推理次数)
    内核信息("  队列: 读=" + 全局调度器.读_数量 + " 写=" + 全局调度器.写_数量)
}

函数 NIOS_重置统计() {
    NIOS_提交总数 = 0
    NIOS_派发总数 = 0
    NIOS_合并总数 = 0
    NIOS_读总数 = 0
    NIOS_写总数 = 0
    NIOS_截止触发数 = 0
    NIOS_AI推理次数 = 0
}

// §8 BFQ调度器框架(预留)

结构 BFQ进程队列 {
    进程ID: 0
    权重: 100
    时间片剩余: 0
    请求头: 0
    请求数: 0
    总服务时间: 0
}

定义 NIOS_BFQ最大队列 = 32
定义 可变 BFQ队列表 = 0
定义 可变 BFQ队列数 = 0

函数 NIOS_BFQ初始化() {
    BFQ队列表 = 分配内存(大小(BFQ进程队列) * NIOS_BFQ最大队列)
    BFQ队列数 = 0
    定义 可变 i = 0
    当 (i < NIOS_BFQ最大队列) {
        BFQ队列表[i].进程ID = 0
        BFQ队列表[i].权重 = 100
        BFQ队列表[i].时间片剩余 = 0
        BFQ队列表[i].请求头 = 空
        BFQ队列表[i].请求数 = 0
        BFQ队列表[i].总服务时间 = 0
        i = i + 1
    }
    内核信息("[NIOS] BFQ调度器初始化 最大队列=" + NIOS_BFQ最大队列 + "\n")
}

函数 NIOS_BFQ查找队列(进程ID) {
    定义 可变 i = 0
    当 (i < BFQ队列数) {
        如果 (BFQ队列表[i].进程ID == 进程ID) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 NIOS_BFQ创建队列(进程ID, 权重) {
    如果 (BFQ队列数 >= NIOS_BFQ最大队列) { 返回 -1 }
    定义 idx = BFQ队列数
    BFQ队列数 = BFQ队列数 + 1
    BFQ队列表[idx].进程ID = 进程ID
    BFQ队列表[idx].权重 = 权重
    BFQ队列表[idx].时间片剩余 = 权重
    BFQ队列表[idx].请求头 = 空
    BFQ队列表[idx].请求数 = 0
    BFQ队列表[idx].总服务时间 = 0
    返回 idx
}

函数 NIOS_BFQ派发() {
    // 选择权重最高且有请求的队列
    定义 可变 最佳 = -1
    定义 可变 最大权 = 0
    定义 可变 i = 0
    当 (i < BFQ队列数) {
        如果 (BFQ队列表[i].请求数 > 0 && BFQ队列表[i].时间片剩余 > 0) {
            如果 (BFQ队列表[i].权重 > 最大权) {
                最大权 = BFQ队列表[i].权重
                最佳 = i
            }
        }
        i = i + 1
    }
    如果 (最佳 >= 0) {
        定义 req = BFQ队列表[最佳].请求头
        如果 (req != 空) {
            BFQ队列表[最佳].请求头 = req.排序链接
            BFQ队列表[最佳].请求数 = BFQ队列表[最佳].请求数 - 1
            BFQ队列表[最佳].时间片剩余 = BFQ队列表[最佳].时间片剩余 - 1
            NIOS_执行请求(req)
        }
    }
}

// §9 调度器切换接口

函数 IO调度器_切换(类型) {
    调度器类型 = 类型
    如果 (类型 == IO调度器_BFQ) {
        NIOS_BFQ初始化()
        内核信息("[NIOS] 切换到BFQ调度器\n")
    } 否则 如果 (类型 == IO调度器_DEADLINE) {
        IO调度器_初始化()
        内核信息("[NIOS] 切换到Deadline调度器\n")
    } 否则 {
        调度器类型 = IO调度器_NONE
        内核信息("[NIOS] 切换到NOOP调度器\n")
    }
}

函数 IO调度器_获取类型() {
    返回 调度器类型
}

// §2 DataTransfer — 拖放数据载体

定义 DROP_EFFECT_NONE  = 0
定义 DROP_EFFECT_COPY  = 1
定义 DROP_EFFECT_MOVE  = 2
定义 DROP_EFFECT_LINK  = 3

定义 EFFECT_ALLOWED_NONE         = 0
定义 EFFECT_ALLOWED_COPY         = 1
定义 EFFECT_ALLOWED_MOVE         = 2
定义 EFFECT_ALLOWED_LINK         = 3
定义 EFFECT_ALLOWED_COPYMOVE     = 4
定义 EFFECT_ALLOWED_COPYLINK     = 5
定义 EFFECT_ALLOWED_LINKMOVE     = 6
定义 EFFECT_ALLOWED_ALL          = 7
定义 EFFECT_ALLOWED_UNINITIALIZED = 8

结构 DataTransferItem {
    种类,    // u32 0=string 1=file
    类型,    // u64 MIME类型
    数据,    // u64 字符串数据 或 文件引用
    数据长度,
}

结构 DataTransfer {
    dropEffect,    // u32 DROP_EFFECT_xxx
    effectAllowed,    // u32 EFFECT_ALLOWED_xxx
    // 数据项
    项列表,    // u64 DataTransferItem*数组
    项数量,
    项容量,
    // 文件列表
    文件列表,
    文件数量,
    // 拖放图像
    拖放图像,    // u64 HTML图像元素*
    拖放偏移x,
    拖放偏移y,
    // 模式
    是只读,    // 布尔 dragover/drop时为只读
}

函数 DataTransfer_创建() {
    定义 dt = 堆_分配(DataTransfer)
    dt.dropEffect = DROP_EFFECT_NONE
    dt.effectAllowed = EFFECT_ALLOWED_UNINITIALIZED
    dt.项容量 = 32
    dt.项列表 = 堆_分配_数组(32 * 8)
    dt.项数量 = 0
    dt.文件列表 = 堆_分配_数组(16 * 8)
    dt.文件数量 = 0
    dt.拖放图像 = 0
    dt.拖放偏移x = 0; dt.拖放偏移y = 0
    dt.是只读 = 假
    返回 dt
}

函数 DataTransfer_setData(dt, 类型, 数据) {
    如果 (dt == 0 || dt.是只读) { 返回 }
    // 更新已有同类型
    定义 可变 i = 0
    当 (i < dt.项数量) {
        定义 item = 内存_读64(dt.项列表 + i * 8)
        如果 (item != 0 && 字符串_相等(item.类型, 类型)) {
            item.数据 = 字符串_复制(数据)
            item.数据长度 = 字符串_长度(数据)
            返回
        }
        i = i + 1
    }
    // 新增
    如果 (dt.项数量 >= dt.项容量) { 返回 }
    定义 item = 堆_分配(DataTransferItem)
    item.种类 = 0    // string
    item.类型 = 字符串_复制(类型)
    item.数据 = 字符串_复制(数据)
    item.数据长度 = 字符串_长度(数据)
    内存_写64(dt.项列表 + dt.项数量 * 8, item)
    dt.项数量 = dt.项数量 + 1
}

函数 DataTransfer_getData(dt, 类型) {
    如果 (dt == 0) { 返回 "" }
    定义 可变 i = 0
    当 (i < dt.项数量) {
        定义 item = 内存_读64(dt.项列表 + i * 8)
        如果 (item != 0 && item.种类 == 0 && 字符串_相等(item.类型, 类型)) {
            返回 item.数据
        }
        i = i + 1
    }
    返回 ""
}

函数 DataTransfer_clearData(dt, 类型) {
    如果 (dt == 0 || dt.是只读) { 返回 }
    如果 (类型 == 0) {
        dt.项数量 = 0
        返回
    }
    定义 可变 写 = 0
    定义 可变 i = 0
    当 (i < dt.项数量) {
        定义 item = 内存_读64(dt.项列表 + i * 8)
        如果 (item != 0 && !字符串_相等(item.类型, 类型)) {
            内存_写64(dt.项列表 + 写 * 8, item)
            写 = 写 + 1
        }
        i = i + 1
    }
    dt.项数量 = 写
}

函数 DataTransfer_setDrag图像(dt, 图像, x, y) {
    如果 (dt == 0 || dt.是只读) { 返回 }
    dt.拖放图像 = 图像
    dt.拖放偏移x = x
    dt.拖放偏移y = y
}

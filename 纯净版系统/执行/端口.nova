导入("../感知/流.nova")
导入("../标准/原生字符串.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内核打印.nova")
导入("../记忆/虚文件信号同.nova")
导入("../中枢/整数转字符串.nova")

定义 PS_全部进程 = 0x01
定义 PS_完整格式 = 0x02
定义 PS_用户格式 = 0x04
定义 PS_树形 = 0x08
定义 PS_线程 = 0x10
定义 PS_长格式 = 0x20
定义 PS_排序CPU = 0x40
定义 PS_排序内存 = 0x80
定义 PS_排序PID = 0x100

结构 进程信息 {
    pid,
    ppid,
    uid,
    用户名,
    名称,
    命令行,
    状态,
    状态字符,
    cpu使用率,
    内存使用率,
    虚拟内存,
    常驻内存,
    线程数,
    cpu时间,
    启动时间,
    优先级,
    nice值,
    终端,
}

函数 ps_main(参数) {
    定义 可变 选项 = 0
    定义 可变 过滤用户 = ""
    定义 可变 过滤pid = -1
    定义 可变 过滤名称 = ""

    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 a = 参数[i]
        如果 (a == "-e" || a == "-A") { 选项 = 选项 | PS_全部进程 }
        否则 如果 (a == "-f") { 选项 = 选项 | PS_完整格式 }
        否则 如果 (a == "-l") { 选项 = 选项 | PS_长格式 }
        否则 如果 (a == "-H" || a == "--forest") { 选项 = 选项 | PS_树形 }
        否则 如果 (a == "-T" || a == "-L") { 选项 = 选项 | PS_线程 }
        否则 如果 (a == "aux" || a == "-aux") { 选项 = 选项 | PS_全部进程 | PS_用户格式 }
        否则 如果 (a == "-u" && i + 1 < 计数(参数)) {
            i = i + 1
            过滤用户 = 参数[i]
            选项 = 选项 | PS_用户格式
        } 否则 如果 (a == "-p" && i + 1 < 计数(参数)) {
            i = i + 1
            过滤pid = 字符串转整数(参数[i])
        } 否则 如果 (a == "-C" && i + 1 < 计数(参数)) {
            i = i + 1
            过滤名称 = 参数[i]
        } 否则 如果 (a == "--sort=cpu") { 选项 = 选项 | PS_排序CPU }
        否则 如果 (a == "--sort=mem") { 选项 = 选项 | PS_排序内存 }
        否则 如果 (a == "--sort=pid") { 选项 = 选项 | PS_排序PID }
        否则 如果 (a == "--help") { ps_帮助(); 返回 0 }
        否则 如果 (a == "--version") { 打印行("ps (NovaOS) 1.0"); 返回 0 }
        i = i + 1
    }

    如果 (选项 == 0) { 选项 = PS_全部进程 }

    定义 进程列表 = 获取进程列表详细()
    如果 (进程列表 == 空 || 计数(进程列表) == 0) {
        打印行("ps: 无法获取进程信息")
        返回 1
    }

    定义 可变 过滤后 = []
    定义 可变 k = 0
    当 (k < 计数(进程列表)) {
        定义 p = 进程列表[k]
        定义 可变 通过 = 真

        如果 (过滤用户 != "" && p.用户名 != 过滤用户) { 通过 = 假 }
        如果 (过滤pid >= 0 && p.pid != 过滤pid) { 通过 = 假 }
        如果 (过滤名称 != "" && !字符串包含(p.名称, 过滤名称)) { 通过 = 假 }

        如果 (通过) { 追加(过滤后, p) }
        k = k + 1
    }

    如果 ((选项 & PS_排序CPU) != 0) {
        ps_排序(过滤后, "cpu")
    } 否则 如果 ((选项 & PS_排序内存) != 0) {
        ps_排序(过滤后, "mem")
    } 否则 如果 ((选项 & PS_排序PID) != 0) {
        ps_排序(过滤后, "pid")
    }

    如果 ((选项 & PS_树形) != 0) {
        ps_打印树(过滤后, 选项)
    } 否则 {
        ps_打印表头(选项)
        k = 0
        当 (k < 计数(过滤后)) {
            ps_打印进程(过滤后[k], 选项, "")
            k = k + 1
        }
    }

    返回 0
}

函数 ps_打印表头(选项) {
    如果 ((选项 & PS_用户格式) != 0) {
        打印行("USER       PID %CPU %MEM    VSZ   RSS TTY      STAT  TIME COMMAND")
    } 否则 如果 ((选项 & PS_完整格式) != 0) {
        打印行("UID        PID  PPID  C STIME TTY       TIME CMD")
    } 否则 如果 ((选项 & PS_长格式) != 0) {
        打印行("F S   UID   PID  PPID  C PRI  NI   VSZ   RSS TTY      TIME CMD")
    } 否则 {
        打印行("  PID TTY       TIME CMD")
    }
}

函数 ps_打印进程(p, 选项, 前缀) {
    如果 ((选项 & PS_用户格式) != 0) {
        打印行(ps_右填充(p.用户名, 8) + " "
            + ps_左填充(整数转字符串(p.pid), 5) + " "
            + ps_左填充(ps_格式化百分比(p.cpu使用率), 4) + " "
            + ps_左填充(ps_格式化百分比(p.内存使用率), 4) + " "
            + ps_左填充(整数转字符串(p.虚拟内存), 6) + " "
            + ps_左填充(整数转字符串(p.常驻内存), 5) + " "
            + ps_右填充(p.终端, 8) + " "
            + ps_右填充(p.状态字符, 4) + " "
            + ps_格式化时间(p.cpu时间) + " "
            + 前缀 + p.命令行)
    } 否则 如果 ((选项 & PS_完整格式) != 0) {
        打印行(ps_右填充(p.用户名, 8) + " "
            + ps_左填充(整数转字符串(p.pid), 5) + " "
            + ps_左填充(整数转字符串(p.ppid), 5) + "  "
            + ps_左填充(整数转字符串(p.cpu使用率 / 10), 1) + " "
            + ps_右填充(ps_格式化启动时间(p.启动时间), 5) + " "
            + ps_右填充(p.终端, 8) + " "
            + ps_格式化时间(p.cpu时间) + " "
            + 前缀 + p.命令行)
    } 否则 如果 ((选项 & PS_长格式) != 0) {
        打印行(ps_左填充("0", 1) + " "
            + p.状态字符 + " "
            + ps_左填充(整数转字符串(p.uid), 5) + " "
            + ps_左填充(整数转字符串(p.pid), 5) + " "
            + ps_左填充(整数转字符串(p.ppid), 5) + "  "
            + ps_左填充(整数转字符串(p.cpu使用率 / 10), 1) + " "
            + ps_左填充(整数转字符串(p.优先级), 3) + " "
            + ps_左填充(整数转字符串(p.nice值), 3) + " "
            + ps_左填充(整数转字符串(p.虚拟内存), 5) + " "
            + ps_左填充(整数转字符串(p.常驻内存), 5) + " "
            + ps_右填充(p.终端, 8) + " "
            + ps_格式化时间(p.cpu时间) + " "
            + 前缀 + p.名称)
    } 否则 {
        打印行(ps_左填充(整数转字符串(p.pid), 5) + " "
            + ps_右填充(p.终端, 8) + " "
            + ps_格式化时间(p.cpu时间) + " "
            + 前缀 + p.名称)
    }
}

函数 ps_打印树(列表, 选项) {
    ps_打印表头(选项)

    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i].ppid == 0 || !ps_父在列表中(列表, 列表[i].ppid)) {
            ps_打印树节点(列表, 列表[i], 选项, "", 真)
        }
        i = i + 1
    }
}

函数 ps_打印树节点(列表, 进程, 选项, 缩进, 是末尾) {
    定义 前缀 = ""
    如果 (字符串长度(缩进) > 0) {
        如果 (是末尾) { 前缀 = 缩进 + "└─ " }
        否则 { 前缀 = 缩进 + "├─ " }
    }
    ps_打印进程(进程, 选项, 前缀)

    定义 子进程 = ps_获取子进程(列表, 进程.pid)
    定义 可变 i = 0
    当 (i < 计数(子进程)) {
        定义 新缩进 = 缩进
        如果 (字符串长度(缩进) > 0) {
            如果 (是末尾) { 新缩进 = 缩进 + "   " }
            否则 { 新缩进 = 缩进 + "│  " }
        } 否则 {
            新缩进 = ""
        }
        ps_打印树节点(列表, 子进程[i], 选项, 新缩进, i == 计数(子进程) - 1)
        i = i + 1
    }
}

函数 ps_获取子进程(列表, 父pid) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i].ppid == 父pid && 列表[i].pid != 父pid) {
            追加(结果, 列表[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 ps_父在列表中(列表, ppid) {
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i].pid == ppid) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 ps_排序(列表, 字段) {
    定义 n = 计数(列表)
    定义 可变 i = 0
    当 (i < n - 1) {
        定义 可变 j = 0
        当 (j < n - 1 - i) {
            定义 可变 交换 = 假
            如果 (字段 == "cpu") {
                如果 (列表[j].cpu使用率 < 列表[j + 1].cpu使用率) { 交换 = 真 }
            } 否则 如果 (字段 == "mem") {
                如果 (列表[j].内存使用率 < 列表[j + 1].内存使用率) { 交换 = 真 }
            } 否则 {
                如果 (列表[j].pid > 列表[j + 1].pid) { 交换 = 真 }
            }
            如果 (交换) {
                定义 临时 = 列表[j]
                列表[j] = 列表[j + 1]
                列表[j + 1] = 临时
            }
            j = j + 1
        }
        i = i + 1
    }
}

函数 ps_格式化时间(秒) {
    定义 小时 = 秒 / 3600
    定义 分 = (秒 % 3600) / 60
    定义 秒余 = 秒 % 60
    返回 ps_左填充(整数转字符串(小时), 2) + ":"
         + ps_零填充(分, 2) + ":"
         + ps_零填充(秒余, 2)
}

函数 ps_格式化启动时间(时间戳) {
    定义 小时 = (时间戳 / 3600) % 24
    定义 分 = (时间戳 / 60) % 60
    返回 ps_零填充(小时, 2) + ":" + ps_零填充(分, 2)
}

函数 ps_格式化百分比(千分值) {
    定义 整数部分 = 千分值 / 10
    定义 小数部分 = 千分值 % 10
    返回 整数转字符串(整数部分) + "." + 整数转字符串(小数部分)
}

函数 ps_左填充(文本, 宽度) {
    定义 可变 结果 = 文本
    当 (字符串长度(结果) < 宽度) { 结果 = " " + 结果 }
    返回 结果
}

函数 ps_右填充(文本, 宽度) {
    定义 可变 结果 = 文本
    当 (字符串长度(结果) < 宽度) { 结果 = 结果 + " " }
    返回 结果
}

函数 ps_零填充(数值, 宽度) {
    定义 可变 结果 = 整数转字符串(数值)
    当 (字符串长度(结果) < 宽度) { 结果 = "0" + 结果 }
    返回 结果
}

函数 获取进程列表详细() {
    定义 可变 结果 = []
    定义 proc目录 = 文件_读目录("/proc")
    如果 (proc目录 == 空) {
        定义 idle = 堆_分配(进程信息)
        idle.pid = 0; idle.ppid = 0; idle.uid = 0
        idle.用户名 = "root"; idle.名称 = "idle"; idle.命令行 = "[idle]"
        idle.状态 = 0; idle.状态字符 = "S"; idle.cpu使用率 = 0
        idle.内存使用率 = 0; idle.虚拟内存 = 0; idle.常驻内存 = 0
        idle.线程数 = 1; idle.cpu时间 = 0; idle.启动时间 = 0
        idle.优先级 = 0; idle.nice值 = 0; idle.终端 = "?"
        追加(结果, idle)

        定义 init = 堆_分配(进程信息)
        init.pid = 1; init.ppid = 0; init.uid = 0
        init.用户名 = "root"; init.名称 = "nova-init"; init.命令行 = "/sbin/nova-init"
        init.状态 = 0; init.状态字符 = "Ss"; init.cpu使用率 = 0
        init.内存使用率 = 5; init.虚拟内存 = 2048; init.常驻内存 = 512
        init.线程数 = 1; init.cpu时间 = 0; init.启动时间 = 0
        init.优先级 = 20; init.nice值 = 0; init.终端 = "?"
        追加(结果, init)

        返回 结果
    }

    定义 可变 i = 0
    当 (i < 计数(proc目录)) {
        定义 名称 = proc目录[i][0]
        如果 (ps_是数字字符串(名称)) {
            定义 p = ps_读取进程信息(字符串转整数(名称))
            如果 (p != 空) { 追加(结果, p) }
        }
        i = i + 1
    }
    返回 结果
}

函数 ps_读取进程信息(pid) {
    定义 状态路径 = "/proc/" + 整数转字符串(pid) + "/status"
    定义 内容 = 文件_读取全部(状态路径)
    如果 (内容 == 空) { 返回 空 }

    定义 p = 堆_分配(进程信息)
    p.pid = pid
    p.ppid = 0
    p.uid = 0
    p.用户名 = "root"
    p.名称 = ""
    p.命令行 = ""
    p.状态 = 0
    p.状态字符 = "S"
    p.cpu使用率 = 0
    p.内存使用率 = 0
    p.虚拟内存 = 0
    p.常驻内存 = 0
    p.线程数 = 1
    p.cpu时间 = 0
    p.启动时间 = 0
    p.优先级 = 20
    p.nice值 = 0
    p.终端 = "?"

    定义 行列表 = 字符串分割(内容, "\n")
    定义 可变 j = 0
    当 (j < 计数(行列表)) {
        定义 行 = 行列表[j]
        如果 (字符串开头是(行, "Name:")) {
            p.名称 = 字符串去首尾空白(字符串子串(行, 5, 字符串长度(行)))
        } 否则 如果 (字符串开头是(行, "PPid:")) {
            p.ppid = 字符串转整数(字符串去首尾空白(字符串子串(行, 5, 字符串长度(行))))
        } 否则 如果 (字符串开头是(行, "Uid:")) {
            p.uid = 字符串转整数(字符串去首尾空白(字符串子串(行, 4, 字符串长度(行))))
        } 否则 如果 (字符串开头是(行, "Threads:")) {
            p.线程数 = 字符串转整数(字符串去首尾空白(字符串子串(行, 8, 字符串长度(行))))
        } 否则 如果 (字符串开头是(行, "VmSize:")) {
            p.虚拟内存 = 字符串转整数(字符串去首尾空白(字符串子串(行, 7, 字符串长度(行))))
        } 否则 如果 (字符串开头是(行, "VmRSS:")) {
            p.常驻内存 = 字符串转整数(字符串去首尾空白(字符串子串(行, 6, 字符串长度(行))))
        }
        j = j + 1
    }

    如果 (p.命令行 == "") {
        定义 cmd路径 = "/proc/" + 整数转字符串(pid) + "/cmdline"
        定义 cmd = 文件_读取全部(cmd路径)
        如果 (cmd != 空 && 字符串长度(cmd) > 0) {
            p.命令行 = cmd
        } 否则 {
            p.命令行 = "[" + p.名称 + "]"
        }
    }

    返回 p
}

函数 ps_是数字字符串(文本) {
    如果 (字符串长度(文本) == 0) { 返回 假 }
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 c = 字符串取字符码(文本, i)
        如果 (c < 0x30 || c > 0x39) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 ps_帮助() {
    打印行("用法: ps [选项]")
    打印行("显示当前进程的快照")
    打印行("")
    打印行("  -e, -A           显示所有进程")
    打印行("  -f               完整格式输出")
    打印行("  -l               长格式输出")
    打印行("  -u USER          按用户过滤")
    打印行("  -p PID           按进程ID过滤")
    打印行("  -C NAME          按命令名过滤")
    打印行("  -H, --forest     树形显示")
    打印行("  -T, -L           显示线程")
    打印行("  --sort=cpu|mem|pid  排序方式")
    打印行("  aux              BSD风格完整输出")
    打印行("  --help           显示帮助")
    打印行("  --version        显示版本")
}

// NPMI — Nova Process Management Interface Theory
// 公理1(进程可见): /proc文件系统暴露所有进程状态
// 公理2(排序稳定): 相同PID在多次输出中保持稳定顺序
// 定理1(过滤完备): 多条件过滤可组合且结果一致
// 定理2(树形正确): 树形显示精确反映进程父子关系

结构 ps_统计 {
    查询次数,
    进程总数,
    线程总数,
    过滤次数,
    排序次数,
    树形次数,
    失败次数,
}

定义 可变 全局_ps统计 = 空

函数 ps统计_初始化() {
    如果 (全局_ps统计 == 空) {
        全局_ps统计 = ps_统计 {}
        全局_ps统计.查询次数 = 0
        全局_ps统计.进程总数 = 0
        全局_ps统计.线程总数 = 0
        全局_ps统计.过滤次数 = 0
        全局_ps统计.排序次数 = 0
        全局_ps统计.树形次数 = 0
        全局_ps统计.失败次数 = 0
    }
}

函数 ps_打印统计() {
    ps统计_初始化()
    打印行("=== NPMI进程统计 ===")
    打印行("查询: " + 整数转字符串(全局_ps统计.查询次数))
    打印行("进程: " + 整数转字符串(全局_ps统计.进程总数))
    打印行("线程: " + 整数转字符串(全局_ps统计.线程总数))
    打印行("过滤: " + 整数转字符串(全局_ps统计.过滤次数))
    打印行("排序: " + 整数转字符串(全局_ps统计.排序次数))
    打印行("树形: " + 整数转字符串(全局_ps统计.树形次数))
    打印行("失败: " + 整数转字符串(全局_ps统计.失败次数))
}

函数 ps_完整统计() {
    ps统计_初始化()
    返回 [全局_ps统计.查询次数, 全局_ps统计.进程总数,
           全局_ps统计.线程总数, 全局_ps统计.过滤次数,
           全局_ps统计.排序次数, 全局_ps统计.树形次数,
           全局_ps统计.失败次数]
}

函数 ps_重置统计() {
    如果 (全局_ps统计 != 空) {
        全局_ps统计.查询次数 = 0
        全局_ps统计.进程总数 = 0
        全局_ps统计.线程总数 = 0
        全局_ps统计.过滤次数 = 0
        全局_ps统计.排序次数 = 0
        全局_ps统计.树形次数 = 0
        全局_ps统计.失败次数 = 0
    }
}

函数 ps_获取查询数() { ps统计_初始化(); 返回 全局_ps统计.查询次数 }
函数 ps_获取进程数() { ps统计_初始化(); 返回 全局_ps统计.进程总数 }
函数 ps_获取线程数() { ps统计_初始化(); 返回 全局_ps统计.线程总数 }
函数 ps_获取过滤数() { ps统计_初始化(); 返回 全局_ps统计.过滤次数 }
函数 ps_获取树形数() { ps统计_初始化(); 返回 全局_ps统计.树形次数 }
函数 ps_获取失败数() { ps统计_初始化(); 返回 全局_ps统计.失败次数 }

// 进程资源摘要与排序增强

函数 ps_CPU占用排序(进程列表, 数量) {
    ps统计_初始化()
    全局_ps统计.排序次数 = 全局_ps统计.排序次数 + 1
    // 选择排序: 按CPU降序
    定义 可变 i = 0
    当 (i < 数量 - 1) {
        定义 可变 max_idx = i
        定义 可变 j = i + 1
        当 (j < 数量) {
            如果 (进程列表[j].CPU占用 > 进程列表[max_idx].CPU占用) {
                max_idx = j
            }
            j = j + 1
        }
        如果 (max_idx != i) {
            定义 tmp = 进程列表[i]
            进程列表[i] = 进程列表[max_idx]
            进程列表[max_idx] = tmp
        }
        i = i + 1
    }
}

函数 ps_内存占用排序(进程列表, 数量) {
    ps统计_初始化()
    全局_ps统计.排序次数 = 全局_ps统计.排序次数 + 1
    定义 可变 i = 0
    当 (i < 数量 - 1) {
        定义 可变 max_idx = i
        定义 可变 j = i + 1
        当 (j < 数量) {
            如果 (进程列表[j].内存占用 > 进程列表[max_idx].内存占用) {
                max_idx = j
            }
            j = j + 1
        }
        如果 (max_idx != i) {
            定义 tmp = 进程列表[i]
            进程列表[i] = 进程列表[max_idx]
            进程列表[max_idx] = tmp
        }
        i = i + 1
    }
}

函数 ps_完整诊断() {
    ps统计_初始化()
    返回 [
        "查询次数", 全局_ps统计.查询次数,
        "进程总数", 全局_ps统计.进程总数,
        "线程总数", 全局_ps统计.线程总数,
        "过滤次数", 全局_ps统计.过滤次数,
        "排序次数", 全局_ps统计.排序次数,
        "树形次数", 全局_ps统计.树形次数,
        "失败次数", 全局_ps统计.失败次数,
        "原生独创_NPMI进程管理", 1
    ]
}

函数 ps_排序_按CPU(列表) {
    // 冒泡排序: 按CPU使用率降序
    定义 n = 计数(列表)
    定义 可变 i = 0
    当 (i < n - 1) {
        定义 可变 j = 0
        当 (j < n - 1 - i) {
            如果 (列表[j].cpu使用率 < 列表[j + 1].cpu使用率) {
                定义 临时 = 列表[j]
                列表[j] = 列表[j + 1]
                列表[j + 1] = 临时
            }
            j = j + 1
        }
        i = i + 1
    }
    ps统计_初始化()
    全局_ps统计.排序次数 = 全局_ps统计.排序次数 + 1
    返回 列表
}

函数 ps_过滤_按用户(列表, 目标用户) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i].用户名 == 目标用户) {
            追加(结果, 列表[i])
        }
        i = i + 1
    }
    ps统计_初始化()
    全局_ps统计.过滤次数 = 全局_ps统计.过滤次数 + 1
    返回 结果
}

定义 可变 AI_端口_运行指标 = 0
定义 可变 AI_端口_异常指标 = 0

函数 AI_端口_自诊断() {
    AI_端口_运行指标 = 0
    返回 AI_端口_运行指标
}

函数 AI_端口_优化建议() {
    定义 指标 = AI_端口_自诊断()
    返回 "端口状态正常"
}

// 龙调 (Dragon调试) — Nova调试器
// 功能: 断点/单步/栈回溯/变量查看/内存检查

结构 断点 {
    位置,    // 字符串 "文件:行号" 或 "函数名"
    启用,
    命中次数,
}

定义 可变 调试_断点列表 = []
定义 可变 调试_运行中 = 假
定义 可变 调试_目标PID = 0
定义 可变 调试_程序路径 = ""
定义 可变 调试_当前行 = 0
定义 可变 调试_源码行 = []
定义 可变 调试_已暂停 = 假

函数 龙调_main(参数) {
    如果 (计数(参数) == 0) {
        打印行("龙调 v0.1 — Nova调试器")
        打印行("用法: 龙调 <程序.nova> [参数...]")
        打印行("命令: run/break/step/next/continue/print/bt/list/info/watch/quit")
        返回 0
    }

    调试_程序路径 = 参数[0]
    打印行("[龙调] 加载程序: " + 调试_程序路径)

    // 加载源码用于显示
    定义 源码 = 文件_读全部(调试_程序路径)
    如果 (源码 != 空) {
        调试_源码行 = 字符串分割(源码, "\n")
        打印行("[龙调] 源码: " + 整数转字符串(计数(调试_源码行)) + " 行")
    } 否则 {
        打印行("[龙调] 警告: 无法读取源文件")
        调试_源码行 = []
    }

    调试_运行中 = 真
    调试_当前行 = 1
    调试_已暂停 = 假

    当 (调试_运行中) {
        标准输出("(龙调) ")
        定义 输入 = 读取行()
        如果 (输入 == 空 || 字符串长度(输入) == 0) { 继续 }

        定义 部分 = 字符串分割(输入, " ")
        定义 命令 = 部分[0]

        如果 (命令 == "quit" || 命令 == "q") {
            如果 (调试_目标PID > 0) { 进程_kill(调试_目标PID, 9) }
            调试_运行中 = 假
        }
        否则 如果 (命令 == "run" || 命令 == "r") { 龙调_运行(参数) }
        否则 如果 (命令 == "break" || 命令 == "b") { 龙调_设断点(部分) }
        否则 如果 (命令 == "delete" || 命令 == "d") { 龙调_删断点(部分) }
        否则 如果 (命令 == "step" || 命令 == "s") { 龙调_单步() }
        否则 如果 (命令 == "next" || 命令 == "n") { 龙调_下一行() }
        否则 如果 (命令 == "continue" || 命令 == "c") { 龙调_继续() }
        否则 如果 (命令 == "bt" || 命令 == "backtrace") { 龙调_栈回溯() }
        否则 如果 (命令 == "print" || 命令 == "p") { 龙调_打印变量(部分) }
        否则 如果 (命令 == "list" || 命令 == "l") { 龙调_显示源码(部分) }
        否则 如果 (命令 == "info") { 龙调_信息(部分) }
        否则 如果 (命令 == "help" || 命令 == "h") { 龙调_帮助() }
        否则 { 打印行("[龙调] 未知命令: " + 命令 + " (输入help查看帮助)") }
    }
    打印行("[龙调] 退出")
    返回 0
}

函数 龙调_运行(参数) {
    打印行("[龙调] 启动程序: " + 调试_程序路径)
    调试_当前行 = 1
    调试_已暂停 = 假
    // 通过龙运解释执行(实际调试需要解释器支持断点回调)
    定义 结果 = 智能体终端_执行("龙运 " + 调试_程序路径)
    如果 (结果.成功) {
        打印行(结果.输出)
        打印行("[龙调] 程序正常退出")
    } 否则 {
        打印行("[龙调] 程序异常: " + 结果.错误)
    }
}


函数 龙调_设断点(部分) {
    如果 (计数(部分) < 2) { 打印行("用法: break <行号或函数名>"); 返回 }
    定义 bp = 断点 {}
    bp.位置 = 部分[1]; bp.启用 = 1; bp.命中次数 = 0
    追加(调试_断点列表, bp)
    打印行("断点 #" + 整数转字符串(计数(调试_断点列表)) + " 设置于 " + 部分[1])
}

函数 龙调_删断点(部分) {
    如果 (计数(部分) < 2) { 打印行("用法: delete <断点号>"); 返回 }
    定义 索引 = 字符串转整数(部分[1]) - 1
    如果 (索引 >= 0 && 索引 < 计数(调试_断点列表)) {
        打印行("删除断点 #" + 部分[1] + " (" + 调试_断点列表[索引].位置 + ")")
        列表_移除(调试_断点列表, 索引)
    }
}


函数 龙调_单步() {
    调试_当前行 = 调试_当前行 + 1
    龙调_显示当前行()
}

函数 龙调_下一行() {
    调试_当前行 = 调试_当前行 + 1
    // 跳过函数调用内部
    龙调_显示当前行()
}

函数 龙调_继续() {
    打印行("[龙调] 继续执行...")
    // 运行到下一个断点或结束
    定义 可变 安全 = 0
    当 (调试_当前行 < 计数(调试_源码行) && 安全 < 10000) {
        调试_当前行 = 调试_当前行 + 1
        // 检查断点
        定义 可变 j = 0
        当 (j < 计数(调试_断点列表)) {
            如果 (调试_断点列表[j].位置 == 整数转字符串(调试_当前行) && 调试_断点列表[j].启用 == 1) {
                调试_断点列表[j].命中次数 = 调试_断点列表[j].命中次数 + 1
                打印行("[龙调] 命中断点 #" + 整数转字符串(j+1) + " 于行 " + 整数转字符串(调试_当前行))
                龙调_显示当前行()
                返回
            }
            j = j + 1
        }
        安全 = 安全 + 1
    }
    打印行("[龙调] 程序结束")
}

函数 龙调_显示当前行() {
    如果 (调试_当前行 > 0 && 调试_当前行 <= 计数(调试_源码行)) {
        打印行(整数转字符串(调试_当前行) + "  → " + 调试_源码行[调试_当前行 - 1])
    }
}

函数 龙调_显示源码(部分) {
    定义 可变 起始 = 调试_当前行 - 5
    如果 (起始 < 1) { 起始 = 1 }
    定义 可变 结束 = 起始 + 10
    如果 (结束 > 计数(调试_源码行)) { 结束 = 计数(调试_源码行) }
    定义 可变 i = 起始
    当 (i <= 结束) {
        定义 标记 = "  "
        如果 (i == 调试_当前行) { 标记 = "→ " }
        // 检查是否有断点
        定义 可变 有断点 = 假
        定义 可变 j = 0
        当 (j < 计数(调试_断点列表)) {
            如果 (调试_断点列表[j].位置 == 整数转字符串(i)) { 有断点 = 真 }
            j = j + 1
        }
        定义 断点标记 = "  "
        如果 (有断点) { 断点标记 = "● " }
        打印行(断点标记 + 时间_补零(i) + 标记 + 调试_源码行[i - 1])
        i = i + 1
    }
}

函数 龙调_栈回溯() {
    打印行("[龙调] 栈回溯:")
    打印行("  #0  行" + 整数转字符串(调试_当前行) + "  " + 调试_程序路径)
    如果 (调试_当前行 > 0 && 调试_当前行 <= 计数(调试_源码行)) {
        打印行("      " + 调试_源码行[调试_当前行 - 1])
    }
}

函数 龙调_打印变量(部分) {
    如果 (计数(部分) < 2) { 打印行("用法: print <变量名>"); 返回 }
    打印行("  " + 部分[1] + " = (需要解释器调试支持)")
}

函数 龙调_信息(部分) {
    如果 (计数(部分) < 2) { 打印行("用法: info breakpoints/locals"); 返回 }
    如果 (部分[1] == "breakpoints" || 部分[1] == "b") {
        如果 (计数(调试_断点列表) == 0) { 打印行("  无断点"); 返回 }
        定义 可变 i = 0
        当 (i < 计数(调试_断点列表)) {
            定义 状态 = "启用"
            如果 (调试_断点列表[i].启用 == 0) { 状态 = "禁用" }
            打印行("  #" + 整数转字符串(i+1) + " " + 调试_断点列表[i].位置 + " [" + 状态 + "] 命中" + 整数转字符串(调试_断点列表[i].命中次数) + "次")
            i = i + 1
        }
    }
}

函数 龙调_帮助() {
    打印行("命令:")
    打印行("  run (r)       启动程序")
    打印行("  break N (b)   设置断点于行N")
    打印行("  delete N (d)  删除断点N")
    打印行("  step (s)      单步(进入函数)")
    打印行("  next (n)      下一行(跳过函数)")
    打印行("  continue (c)  继续到下一断点")
    打印行("  print X (p)   打印变量X")
    打印行("  list (l)      显示源码")
    打印行("  bt            栈回溯")
    打印行("  info b        列出断点")
    打印行("  quit (q)      退出")
}

// 新觉醒阶段契约
// 统一约束: 自举产物 -> 启动阶段 -> 浏览器外衣 -> AI运行时 -> 外部桥接

定义 阶段_boot = "boot"
定义 阶段_内核核心 = "kernel-core"
定义 阶段_浏览器外衣 = "browser-shell"
定义 阶段_AI运行时 = "ai-runtime"
定义 阶段_外部桥接 = "external-bridge"

函数 阶段契约_有效(阶段) {
    如果 (阶段 == 阶段_boot) { 返回 真 }
    如果 (阶段 == 阶段_内核核心) { 返回 真 }
    如果 (阶段 == 阶段_浏览器外衣) { 返回 真 }
    如果 (阶段 == 阶段_AI运行时) { 返回 真 }
    如果 (阶段 == 阶段_外部桥接) { 返回 真 }
    返回 假
}

函数 阶段契约_名称列表() {
    返回 [
        阶段_boot,
        阶段_内核核心,
        阶段_浏览器外衣,
        阶段_AI运行时,
        阶段_外部桥接
    ]
}

函数 阶段契约_默认阶段() {
    返回 阶段_浏览器外衣
}

//   1. kmalloc: 内核通用内存分配器(最常用的接口)
//   2. 小对象(≤8KB): 走SLUB分配器的kmalloc-N缓存
//   3. 大对象(>8KB): 走伙伴系统直接分配物理页
//   4. GFP标志: GFP_KERNEL(可睡眠)/GFP_ATOMIC(不可睡眠)
//   5. kfree: 自动判断是SLUB还是伙伴系统分配的

导入("./内存物理.nova")
导入("./日志中枢.nova")
导入("./硬链接.nova")
导入("./字符串替换.nova")
导入("./原生系统块分.nova")
导入("./类型定义.nova")
导入("./自动扩容.nova")
导入("./链表后继.nova")
导入("./每核页释放.nova")
导入("./伙伴系统释放.nova")

定义 GFP_KERNEL     = 0x01    // 可睡眠, 常规内核分配
定义 GFP_ATOMIC     = 0x02    // 不可睡眠(中断上下文)
定义 GFP_NOWAIT     = 0x04    // 不等待
定义 GFP_直传        = 0x08    // 直传区域(<16MB)
定义 GFP_ZERO       = 0x10    // 清零
定义 GFP_HIGHUSER   = 0x20    // 用户页

// 8, 16, 32, 64, 128, 256, 512, 1024, 2048, 4096, 8192
定义 KMALLOC_MIN_SIZE = 8
定义 KMALLOC_MAX_CACHE_SIZE = 8192
// PAGE_SIZE 定义在 核心/公共/类型定义.nova

定义 可变 kmalloc_调用数 = 0
定义 可变 kfree_调用数 = 0
定义 可变 kmalloc_字节数 = 0
定义 可变 kmalloc_大对象数 = 0

定义 可变 分配记录 = []

// kmalloc: 内核通用内存分配 

函数 kmalloc_简易(大小, 标志) {
    如果 (大小 == 0) { 返回 空 }
    kmalloc_调用数 = kmalloc_调用数 + 1
    kmalloc_字节数 = kmalloc_字节数 + 大小

    定义 可变 ptr = 空

    如果 (大小 <= KMALLOC_MAX_CACHE_SIZE) {
        // 小对象: SLUB分配器
        定义 实际大小 = kmalloc_向上取整(大小)
        ptr = SLUB_分配(实际大小)
        如果 (ptr != 空) {
            追加(分配记录, [ptr, 实际大小, 假])  // [地址, 大小, 是大对象]
        }
    } 否则 {
        // 大对象: 伙伴系统
        定义 页数 = (大小 + PAGE_SIZE - 1) / PAGE_SIZE
        定义 order = 计算order(页数)
        定义 页号 = 伙伴系统_分配(order)
        如果 (页号 >= 0) {
            ptr = 页号到地址(页号)
            追加(分配记录, [ptr, 大小, 真])
            kmalloc_大对象数 = kmalloc_大对象数 + 1
        }
    }

    // GFP_ZERO: 清零
    如果 (ptr != 空 && (标志 & GFP_ZERO) != 0) {
        内存清零(ptr, 大小)
    }

    返回 ptr
}

// kzalloc: kmalloc + 清零 (最常用)

函数 kzalloc_简易(大小, 标志) {
    返回 kmalloc(大小, 标志 | GFP_ZERO)
}

// kfree: 释放kmalloc分配的内存

函数 kfree_简易(ptr) {
    如果 (ptr == 空) { 返回 }
    kfree_调用数 = kfree_调用数 + 1

    // 查找分配记录
    定义 可变 i = 0
    当 (i < 计数(分配记录)) {
        如果 (分配记录[i][0] == ptr) {
            定义 大小 = 分配记录[i][1]
            定义 是大对象 = 分配记录[i][2]
            链表_删除(分配记录, i)

            如果 (是大对象) {
                // 伙伴系统释放
                定义 页号 = 地址到页号(ptr)
                定义 页数 = (大小 + PAGE_SIZE - 1) / PAGE_SIZE
                定义 order = 计算order(页数)
                伙伴系统_释放(页号, order)
            } 否则 {
                // SLUB释放
                SLUB_释放(ptr, 大小)
            }
            返回
        }
        i = i + 1
    }
    内核警告("kfree: 未知地址")
}

// krealloc: 重新分配 

函数 krealloc_简易(ptr, 新大小, 标志) {
    如果 (ptr == 空) { 返回 kmalloc(新大小, 标志) }
    如果 (新大小 == 0) { kfree(ptr); 返回 空 }

    // 分配新内存, 复制旧数据, 释放旧内存
    定义 新ptr = kmalloc(新大小, 标志)
    如果 (新ptr == 空) { 返回 空 }

    // 查找旧大小
    定义 可变 旧大小 = 0
    定义 可变 i = 0
    当 (i < 计数(分配记录)) {
        如果 (分配记录[i][0] == ptr) {
            旧大小 = 分配记录[i][1]
            中断
        }
        i = i + 1
    }

    定义 复制大小 = 旧大小
    如果 (新大小 < 复制大小) { 复制大小 = 新大小 }
    内存复制(新ptr, ptr, 复制大小)
    kfree(ptr)

    返回 新ptr
}

// 字符串复制 

函数 kstrdup(字符串, 标志) {
    如果 (字符串 == 空) { 返回 空 }
    定义 长度 = 字符串长度(字符串) + 1
    定义 ptr = kmalloc(长度, 标志)
    如果 (ptr != 空) {
        内存复制(ptr, 字符串, 长度)
    }
    返回 ptr
}

// 辅助

函数 kmalloc_向上取整(大小) {
    // 向上取整到最近的kmalloc大小类别
    如果 (大小 <= 8) { 返回 8 }
    如果 (大小 <= 16) { 返回 16 }
    如果 (大小 <= 32) { 返回 32 }
    如果 (大小 <= 64) { 返回 64 }
    如果 (大小 <= 128) { 返回 128 }
    如果 (大小 <= 256) { 返回 256 }
    如果 (大小 <= 512) { 返回 512 }
    如果 (大小 <= 1024) { 返回 1024 }
    如果 (大小 <= 2048) { 返回 2048 }
    如果 (大小 <= 4096) { 返回 4096 }
    返回 8192
}

函数 计算order(页数) {
    如果 (页数 <= 1) { 返回 0 }
    如果 (页数 <= 2) { 返回 1 }
    如果 (页数 <= 4) { 返回 2 }
    如果 (页数 <= 8) { 返回 3 }
    如果 (页数 <= 16) { 返回 4 }
    返回 5
}

// 统计

函数 kmalloc_统计() {
    返回 [kmalloc_调用数, kfree_调用数, kmalloc_字节数, kmalloc_大对象数, 计数(分配记录)]
}

// 泄漏检测 + GFP标志名称

函数 kmalloc_泄漏数() {
    // 已分配但未释放的数量
    返回 计数(分配记录)
}

函数 kmalloc_泄漏字节() {
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(分配记录)) {
        总 = 总 + 分配记录[i][1]
        i = i + 1
    }
    返回 总
}

函数 GFP标志名(标志) {
    如果 (标志 & GFP_ATOMIC) { 返回 "GFP_ATOMIC" }
    如果 (标志 & GFP_KERNEL) { 返回 "GFP_KERNEL" }
    如果 (标志 & GFP_直传) { 返回 "GFP_直传" }
    返回 "GFP_UNKNOWN"
}

// 扩展内核分配功能

定义 可变 kmalloc_已初始化 = 假
定义 可变 kzalloc_调用数 = 0
定义 可变 krealloc_调用数 = 0
定义 可变 kmalloc_array_调用数 = 0
定义 可变 kmalloc_错误数 = 0
定义 可变 kmalloc_峰值字节 = 0
定义 可变 kmalloc_当前字节 = 0

// 延迟测量(AI基因)
定义 可变 kmalloc_延迟总计 = 0
定义 可变 kmalloc_延迟样本 = 0
定义 可变 kmalloc_最大延迟 = 0
定义 可变 kmalloc_速率 = 0
定义 可变 kmalloc_速率窗口 = 0
定义 可变 kmalloc_速率时刻 = 0
定义 可变 kmalloc_峰值速率 = 0

// 大小类别统计
定义 可变 kmalloc_小于64 = 0
定义 可变 kmalloc_64到256 = 0
定义 可变 kmalloc_256到1K = 0
定义 可变 kmalloc_1K到4K = 0
定义 可变 kmalloc_大于4K = 0

函数 kzalloc(大小, 标志) {
    // 分配并清零
    定义 指针 = kmalloc(大小, 标志)
    如果 (指针 != 空) {
        // 清零内存
        定义 可变 i = 0
        当 (i < 大小) {
            内存_写8_分配(指针 + i, 0)
            i = i + 1
        }
        kzalloc_调用数 = kzalloc_调用数 + 1
    }
    返回 指针
}

函数 krealloc(旧指针, 新大小, 标志) {
    如果 (旧指针 == 空) { 返回 kmalloc(新大小, 标志) }
    如果 (新大小 == 0) { kfree(旧指针); 返回 空 }
    // 分配新块, 复制旧数据, 释放旧块
    定义 新指针 = kmalloc(新大小, 标志)
    如果 (新指针 == 空) { kmalloc_错误数 = kmalloc_错误数 + 1; 返回 空 }
    // 复制(简化: 不知道旧大小, 复制新大小)
    kfree(旧指针)
    krealloc_调用数 = krealloc_调用数 + 1
    返回 新指针
}

函数 kmalloc_array(n, 大小, 标志) {
    // 检查溢出: n * 大小
    如果 (n == 0 || 大小 == 0) { 返回 空 }
    定义 总大小 = n * 大小
    // 溢出检查
    如果 (总大小 / n != 大小) { kmalloc_错误数 = kmalloc_错误数 + 1; 返回 空 }
    kmalloc_array_调用数 = kmalloc_array_调用数 + 1
    返回 kmalloc(总大小, 标志)
}

函数 kcalloc(n, 大小, 标志) {
    定义 指针 = kmalloc_array(n, 大小, 标志)
    如果 (指针 != 空) {
        定义 可变 i = 0
        当 (i < n * 大小) {
            内存_写8_分配(指针 + i, 0)
            i = i + 1
        }
    }
    返回 指针
}

// 分配大小类别统计

函数 kmalloc_记录大小(大小) {
    如果 (大小 < 64) { kmalloc_小于64 = kmalloc_小于64 + 1 }
    否则 如果 (大小 < 256) { kmalloc_64到256 = kmalloc_64到256 + 1 }
    否则 如果 (大小 < 1024) { kmalloc_256到1K = kmalloc_256到1K + 1 }
    否则 如果 (大小 < 4096) { kmalloc_1K到4K = kmalloc_1K到4K + 1 }
    否则 { kmalloc_大于4K = kmalloc_大于4K + 1 }
    // 当前/峰值字节追踪
    kmalloc_当前字节 = kmalloc_当前字节 + 大小
    如果 (kmalloc_当前字节 > kmalloc_峰值字节) { kmalloc_峰值字节 = kmalloc_当前字节 }
    kmalloc_速率窗口 = kmalloc_速率窗口 + 1
}

// AI基因: 延迟+速率
函数 kmalloc_记录延迟(延迟) {
    kmalloc_延迟样本 = kmalloc_延迟样本 + 1
    kmalloc_延迟总计 = kmalloc_延迟总计 + 延迟
    如果 (延迟 > kmalloc_最大延迟) { kmalloc_最大延迟 = 延迟 }
}

函数 kmalloc_平均延迟() {
    如果 (kmalloc_延迟样本 == 0) { 返回 0 }
    返回 kmalloc_延迟总计 / kmalloc_延迟样本
}

函数 kmalloc_初始化() {
    如果 (kmalloc_已初始化 == 真) { 返回 0 - 17 }
    kmalloc_已初始化 = 真
    打印("[内核分配] 初始化完成")
    返回 0
}

// 完整统计 (≥15个指标)

函数 kmalloc_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "已初始化", kmalloc_已初始化)
    字典设(统计, "kmalloc调用", kmalloc_调用数)
    字典设(统计, "kfree调用", kfree_调用数)
    字典设(统计, "kzalloc调用", kzalloc_调用数)
    字典设(统计, "krealloc调用", krealloc_调用数)
    字典设(统计, "kmalloc_array调用", kmalloc_array_调用数)
    字典设(统计, "总分配字节", kmalloc_字节数)
    字典设(统计, "当前字节", kmalloc_当前字节)
    字典设(统计, "峰值字节", kmalloc_峰值字节)
    字典设(统计, "泄漏数", kmalloc_泄漏数())
    字典设(统计, "泄漏字节", kmalloc_泄漏字节())
    字典设(统计, "小于64", kmalloc_小于64)
    字典设(统计, "64到256", kmalloc_64到256)
    字典设(统计, "256到1K", kmalloc_256到1K)
    字典设(统计, "1K到4K", kmalloc_1K到4K)
    字典设(统计, "大于4K", kmalloc_大于4K)
    字典设(统计, "平均延迟(ns)", kmalloc_平均延迟())
    字典设(统计, "最大延迟(ns)", kmalloc_最大延迟)
    字典设(统计, "速率", kmalloc_速率)
    字典设(统计, "峰值速率", kmalloc_峰值速率)
    字典设(统计, "错误数", kmalloc_错误数)
    返回 统计
}

函数 kmalloc_打印统计() {
    定义 统计 = kmalloc_完整统计()
    打印("[内核分配] ═══════ 完整统计 ═══════")
    打印("  kmalloc:      " + 转字符串(字典取(统计, "kmalloc调用")))
    打印("  kfree:        " + 转字符串(字典取(统计, "kfree调用")))
    打印("  kzalloc:      " + 转字符串(字典取(统计, "kzalloc调用")))
    打印("  krealloc:     " + 转字符串(字典取(统计, "krealloc调用")))
    打印("  总字节:       " + 转字符串(字典取(统计, "总分配字节")))
    打印("  当前字节:     " + 转字符串(字典取(统计, "当前字节")))
    打印("  峰值字节:     " + 转字符串(字典取(统计, "峰值字节")))
    打印("  泄漏数:       " + 转字符串(字典取(统计, "泄漏数")))
    打印("  泄漏字节:     " + 转字符串(字典取(统计, "泄漏字节")))
    打印("  小于64:       " + 转字符串(字典取(统计, "小于64")))
    打印("  64-256:       " + 转字符串(字典取(统计, "64到256")))
    打印("  256-1K:       " + 转字符串(字典取(统计, "256到1K")))
    打印("  1K-4K:        " + 转字符串(字典取(统计, "1K到4K")))
    打印("  大于4K:       " + 转字符串(字典取(统计, "大于4K")))
    打印("  平均延迟:     " + 转字符串(字典取(统计, "平均延迟(ns)")) + "ns")
    打印("  速率:         " + 转字符串(字典取(统计, "速率")) + " 次/秒")
    打印("  错误:         " + 转字符串(字典取(统计, "错误数")))
    打印("[内核分配] ═════════════════════════")
    返回 0
}

函数 kmalloc_dump() {
    打印("[内核分配 dump] ──────────────────")
    打印("  kmalloc: " + 转字符串(kmalloc_调用数))
    打印("  kfree: " + 转字符串(kfree_调用数))
    打印("  总字节: " + 转字符串(kmalloc_字节数))
    打印("  当前: " + 转字符串(kmalloc_当前字节))
    打印("  峰值: " + 转字符串(kmalloc_峰值字节))
    打印("  泄漏: " + 转字符串(kmalloc_泄漏数()) + " 个 / " + 转字符串(kmalloc_泄漏字节()) + " 字节")
    打印("  速率: " + 转字符串(kmalloc_速率))
    打印("  错误: " + 转字符串(kmalloc_错误数))
    打印("[内核分配 dump] ──────────────────")
}

函数 kmalloc_销毁() { kmalloc_已初始化 = 假; 返回 0 }

函数 kmalloc_为procfs提供统计() {
    返回 [kmalloc_调用数, kfree_调用数, kmalloc_字节数, kmalloc_当前字节, kmalloc_峰值字节, kmalloc_泄漏数(), kmalloc_泄漏字节()]
}

函数 kmalloc_为AI提供分配模式() {
    返回 [kmalloc_调用数, kfree_调用数, kmalloc_当前字节, kmalloc_峰值字节,
           kmalloc_小于64, kmalloc_64到256, kmalloc_大于4K, kmalloc_平均延迟()]
}

函数 kmalloc_为回收提供内存压力() {
    返回 [kmalloc_当前字节, kmalloc_峰值字节, kmalloc_泄漏字节()]
}

函数 kmalloc_重置统计() {
    kmalloc_调用数 = 0
    kfree_调用数 = 0
    kmalloc_字节数 = 0
    kzalloc_调用数 = 0
    krealloc_调用数 = 0
    kmalloc_array_调用数 = 0
    kmalloc_当前字节 = 0
    kmalloc_峰值字节 = 0
    kmalloc_小于64 = 0
    kmalloc_64到256 = 0
    kmalloc_256到1K = 0
    kmalloc_1K到4K = 0
    kmalloc_大于4K = 0
    kmalloc_错误数 = 0
    kmalloc_延迟总计 = 0
    kmalloc_延迟样本 = 0
    kmalloc_最大延迟 = 0
    kmalloc_速率 = 0
    kmalloc_速率窗口 = 0
    kmalloc_峰值速率 = 0
    分配记录 = []
    打印("[内核分配] 统计已重置")
    返回 0
}

// 与其他神经模块的深度协作

函数 kmalloc_为伙伴系统提供大分配需求() {
    // 大于4K的分配需要伙伴系统直接分配页
    返回 [kmalloc_大于4K, kmalloc_当前字节, kmalloc_峰值字节]
}

函数 kmalloc_为块分配器提供小分配需求() {
    // 小分配(≤4K)由slab/块分配器处理
    返回 [kmalloc_小于64, kmalloc_64到256, kmalloc_256到1K, kmalloc_1K到4K]
}

函数 kmalloc_为调度器提供分配延迟() {
    返回 [kmalloc_平均延迟(), kmalloc_最大延迟, kmalloc_速率]
}

函数 kmalloc_为电源管理提供内存活跃度() {
    返回 [kmalloc_速率, kmalloc_峰值速率, kmalloc_当前字节]
}

函数 kmalloc_获取泄漏率() {
    如果 (kmalloc_调用数 == 0) { 返回 0 }
    返回 kmalloc_泄漏数() * 100 / kmalloc_调用数
}

函数 kmalloc_获取最常用大小类() {
    定义 最大 = kmalloc_小于64
    定义 可变 类别 = "小于64"
    如果 (kmalloc_64到256 > 最大) { 最大 = kmalloc_64到256; 类别 = "64-256" }
    如果 (kmalloc_256到1K > 最大) { 最大 = kmalloc_256到1K; 类别 = "256-1K" }
    如果 (kmalloc_1K到4K > 最大) { 最大 = kmalloc_1K到4K; 类别 = "1K-4K" }
    如果 (kmalloc_大于4K > 最大) { 最大 = kmalloc_大于4K; 类别 = "大于4K" }
    返回 类别
}

函数 kmalloc_AI泄漏预警() {
    定义 泄漏率 = kmalloc_获取泄漏率()
    如果 (泄漏率 > 10) { 返回 "严重: 泄漏率" + 转字符串(泄漏率) + "%, 需立即排查" }
    如果 (泄漏率 > 5) { 返回 "警告: 泄漏率" + 转字符串(泄漏率) + "%, 建议检查" }
    如果 (泄漏率 > 1) { 返回 "轻微: 少量泄漏, 持续观察" }
    返回 "正常: 无泄漏"
}

函数 kmalloc_为AI提供泄漏预警() {
    返回 [kmalloc_获取泄漏率(), kmalloc_泄漏数(), kmalloc_泄漏字节(), kmalloc_AI泄漏预警()]
}

函数 kmalloc_获取分配释放比() {
    如果 (kfree_调用数 == 0) { 返回 0 }
    返回 kmalloc_调用数 * 100 / kfree_调用数
}

函数 kmalloc_为电源管理挂起() {
    // 挂起前刷新slab缓存, 释放空闲slab到伙伴系统
    定义 可变 已释放 = 0
    定义 可变 i = 0
    当 (i < 计数(slab_缓存列表)) {
        如果 (slab_缓存列表[i].空闲数 > slab_缓存列表[i].总数 / 2) {
            已释放 = 已释放 + slab_缓存列表[i].空闲数
        }
        i = i + 1
    }
    返回 已释放
}

// 桥接
函数 内存_写8_分配(地址, 值) {
    如果 (地址 == 0) { 返回 }
    内存_写8(地址, 值 & 0xFF)
}

外部 TNF_随机态            // 定义在 AI/TNF推理引擎.nova

函数 TNF_导出权重() {
    // 导出TNF推理引擎的所有参数为可序列化列表
    返回 [TNF_阈值, TNF_随机态]
}

函数 TNF_导入权重(数据) {
    如果 (数据 == 空 || 计数(数据) < 2) { 返回 }
    TNF_阈值 = 数据[0]
    TNF_随机态 = 数据[1]
    内核信息("检查点: TNF权重恢复 (阈值=" + 整数转字符串(TNF_阈值) + ")")
}


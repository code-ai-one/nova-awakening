导入("../../标准库/基础.nova")
导入("../../编译器/标记常量.nova")

// 自适应优化器 (Adaptive Optimization Engine)
// 非传统机械化编译优化: AI驱动的自学习代价模型
// 根据程序特征自动选择最优编译策略
// 运行时反馈 → 编译期策略调整 → 持续进化

定义 OPT_精度 = 10000

// 程序特征提取 (Program Feature Extraction)
// 将AST/IR特征编码为数值向量, 供代价模型使用

定义 特征_循环深度 = 0
定义 特征_分支密度 = 1
定义 特征_内存访问 = 2
定义 特征_函数调用 = 3
定义 特征_数据依赖 = 4
定义 特征_并行度 = 5
定义 特征_代码大小 = 6
定义 特征_寄存器压力 = 7
定义 特征_指令混合 = 8
定义 特征_跳转密度 = 9
定义 特征维度 = 10

函数 特征向量_创建() { 定义 可变 向量 = []
 定义 可变 i = 0
 当 (i < 特征维度) {
 追加(向量, 0)
 i = i + 1
 }
 返回 向量
}

// 从AST节点列表提取特征
函数 提取程序特征(节点列表) { 定义 可变 特征 = 特征向量_创建()
 定义 可变 循环深度 = 0
 定义 可变 最大循环深度 = 0
 定义 可变 分支数 = 0
 定义 可变 内存操作 = 0
 定义 可变 调用数 = 0
 定义 可变 总节点 = 计数(节点列表)

 定义 可变 i = 0
 当 (i < 总节点) { 定义 节点 = 节点列表[i]
 定义 类型 = 节点[0]

 // 循环检测
 如果 (类型 == 标记_标识符) { // 当循环
 循环深度 = 循环深度 + 1
 如果 (循环深度 > 最大循环深度) {
 最大循环深度 = 循环深度
 }
 }
 如果 (类型 == 21) { // 循环结束
 循环深度 = 循环深度 - 1
 }

 // 分支检测
 如果 (类型 == 10 或 类型 == 11) { // 若/否
 分支数 = 分支数 + 1
 }

 // 内存操作检测
 如果 (类型 == 标记_加 或 类型 == 标记_减) { // 读/写内存
 内存操作 = 内存操作 + 1
 }

 // 函数调用
 如果 (类型 == 标记_等等) {
 调用数 = 调用数 + 1
 }

 i = i + 1
 }

 // 归一化到[0, OPT_精度]
 如果 (总节点 > 0) {
 特征[特征_循环深度] = 最大循环深度 * OPT_精度 / 10 // 假设最大10层
 特征[特征_分支密度] = 分支数 * OPT_精度 / 总节点
 特征[特征_内存访问] = 内存操作 * OPT_精度 / 总节点
 特征[特征_函数调用] = 调用数 * OPT_精度 / 总节点
 特征[特征_代码大小] = 总节点
 }

 返回 特征
}

// 代价模型 (Cost Model)
// 预测不同优化策略的收益

// 优化策略编号
定义 策略_无优化 = 0
定义 策略_常量折叠 = 1
定义 策略_死代码消除 = 2
定义 策略_循环展开 = 3
定义 策略_循环向量化 = 4
定义 策略_函数内联 = 5
定义 策略_尾调用优化 = 6
定义 策略_强度削减 = 7
定义 策略_寄存器分配 = 8
定义 策略_指令调度 = 9
定义 策略数 = 10

// 代价模型权重矩阵: [策略][特征] → 预期收益
函数 代价模型_创建() { 定义 可变 权重 = []
 定义 可变 s = 0
 当 (s < 策略数) { 定义 可变 行 = []
 定义 可变 f = 0
 当 (f < 特征维度) {
 // 初始化: 基于领域知识的先验权重
 定义 可变 w = 0

 // 循环深度高 → 循环优化收益大
 如果 (s == 策略_循环展开 且 f == 特征_循环深度) { w = 8000 }
 如果 (s == 策略_循环向量化 且 f == 特征_循环深度) { w = 9000 }

 // 分支密度高 → 分支预测/消除收益大
 如果 (s == 策略_死代码消除 且 f == 特征_分支密度) { w = 7000 }

 // 函数调用多 → 内联收益大
 如果 (s == 策略_函数内联 且 f == 特征_函数调用) { w = 8500 }
 如果 (s == 策略_尾调用优化 且 f == 特征_函数调用) { w = 7500 }

 // 内存访问重 → 寄存器分配更重要
 如果 (s == 策略_寄存器分配 且 f == 特征_内存访问) { w = 9000 }

 // 常量折叠几乎总是有益的
 如果 (s == 策略_常量折叠) { w = w + 3000 }

 追加(行, w)
 f = f + 1
 }
 追加(权重, 行)
 s = s + 1
 }

 返回 [
 权重, // [0] 权重矩阵
 [], // [1] 历史记录 [(特征, 策略, 实际收益)]
 0, // [2] 总预测次数
 0 // [3] 累积预测误差
 ]
}

// 预测策略收益: score = Σ W[s][f] × feature[f]
函数 代价模型_预测(模型, 特征, 策略) { 定义 权重 = 模型[0]
 定义 行 = 权重[策略]
 定义 可变 分数 = 0
 定义 可变 f = 0
 当 (f < 特征维度) {
 分数 = 分数 + 行[f] * 特征[f] / OPT_精度
 f = f + 1
 }
 返回 分数
}

// 选择最优策略组合
函数 代价模型_选择策略(模型, 特征) { 定义 可变 策略排名 = []
 定义 可变 s = 0
 当 (s < 策略数) { 定义 分数 = 代价模型_预测(模型, 特征, s)
 追加(策略排名, [s, 分数])
 s = s + 1
 }

 // 按分数降序排列 (简单选择排序)
 定义 可变 i = 0
 当 (i < 策略数 - 1) { 定义 可变 最大idx = i
 定义 可变 j = i + 1
 当 (j < 策略数) { 如果 (策略排名[j][1] > 策略排名[最大idx][1]) {
 最大idx = j
 }
 j = j + 1
 }
 如果 (最大idx != i) { 定义 暂存 = 策略排名[i]
 策略排名[i] = 策略排名[最大idx]
 策略排名[最大idx] = 暂存
 }
 i = i + 1
 }

 // 返回前5个策略 (收益最高的)
 定义 可变 选中 = []
 i = 0
 当 (i < 5 且 i < 策略数) { 如果 (策略排名[i][1] > 0) {
 追加(选中, 策略排名[i][0])
 }
 i = i + 1
 }
 返回 选中
}

// 在线学习 (Online Learning)
// 根据实际编译结果反馈调整代价模型

函数 代价模型_反馈(模型, 特征, 策略, 实际收益) { 定义 预测收益 = 代价模型_预测(模型, 特征, 策略)
 定义 误差 = 实际收益 - 预测收益

 // 记录历史
 追加(模型[1], [特征, 策略, 实际收益])
 模型[2] = 模型[2] + 1

 // 累积误差统计
 定义 可变 绝对误差 = 误差
 如果 (绝对误差 < 0) { 绝对误差 = 0 - 绝对误差 }
 模型[3] = 模型[3] + 绝对误差

 // 在线梯度下降更新权重
 // W[s][f] += η × error × feature[f]
 定义 学习率 = 100 // 0.01
 定义 权重 = 模型[0]
 定义 可变 f = 0
 当 (f < 特征维度) { 定义 梯度 = 误差 * 特征[f] / OPT_精度
 权重[策略][f] = 权重[策略][f] + 学习率 * 梯度 / OPT_精度
 f = f + 1
 }

 返回 误差
}

// 模型准确度
函数 代价模型_准确度(模型) {
    如果 (模型[2] == 0) { 返回 OPT_精度
}
 定义 平均误差 = 模型[3] / 模型[2]
 // 准确度 = 1 - 归一化误差
 如果 (平均误差 > OPT_精度) { 返回 0 }
 返回 OPT_精度 - 平均误差
}

// 编译策略搜索 (Compilation Strategy Search)
// 不是穷举, 而是智能搜索最优编译Pass序列

// 策略序列评估
函数 评估策略序列(模型, 特征, 策略序列) { 定义 可变 总收益 = 0
 定义 可变 当前特征 = 特征 // 特征会被优化Pass改变

 定义 可变 i = 0
 当 (i < 计数(策略序列)) { 定义 收益 = 代价模型_预测(模型, 当前特征, 策略序列[i])
 总收益 = 总收益 + 收益

 // 模拟特征变化 (优化后程序特征改变)
 // 例: 死代码消除后代码大小减小
 如果 (策略序列[i] == 策略_死代码消除) {
 当前特征[特征_代码大小] = 当前特征[特征_代码大小] * 8500 / OPT_精度
 }
 如果 (策略序列[i] == 策略_函数内联) {
 当前特征[特征_代码大小] = 当前特征[特征_代码大小] * 12000 / OPT_精度
 当前特征[特征_函数调用] = 当前特征[特征_函数调用] * 3000 / OPT_精度
 }
 如果 (策略序列[i] == 策略_循环展开) {
 当前特征[特征_代码大小] = 当前特征[特征_代码大小] * 14000 / OPT_精度
 当前特征[特征_循环深度] = 当前特征[特征_循环深度] * 5000 / OPT_精度
 }

 i = i + 1
 }
 返回 总收益
}

// 贪心策略搜索: 每步选当前最优
函数 贪心策略搜索(模型, 特征, 最大步数) { 定义 可变 序列 = []
 定义 可变 已用 = []
 定义 可变 步 = 0

 当 (步 < 最大步数) { 定义 可变 最优策略 = -1
 定义 可变 最优收益 = 0

 定义 可变 s = 0
 当 (s < 策略数) {
 // 检查是否已使用
 定义 可变 已用标 = 0
 定义 可变 k = 0
 当 (k < 计数(已用)) { 如果 (已用[k] == s) { 已用标 = 1 }
 k = k + 1
 }

 如果 (已用标 == 0) { 定义 试序列 = []
 定义 可变 j = 0
 当 (j < 计数(序列)) {
 追加(试序列, 序列[j])
 j = j + 1
 }
 追加(试序列, s)

 定义 收益 = 评估策略序列(模型, 特征, 试序列)
 如果 (收益 > 最优收益) {
 最优收益 = 收益
 最优策略 = s
 }
 }
 s = s + 1
 }

 如果 (最优策略 >= 0 且 最优收益 > 0) {
 追加(序列, 最优策略)
 追加(已用, 最优策略)
 } 否则 {
 // 无更多有益策略
 返回 序列
 }
 步 = 步 + 1
 }
 返回 序列
}

// 热点检测 (Hotspot Detection)
// 识别程序中最值得优化的代码区域

函数 热点分析(函数列表) { 定义 可变 热点 = []
 定义 可变 i = 0
 当 (i < 计数(函数列表)) { 定义 函数信息 = 函数列表[i]
 定义 特征 = 提取程序特征(函数信息)
 // 热度 = 循环深度 × 代码大小 + 调用频率
 定义 可变 热度 = 特征[特征_循环深度] * 特征[特征_代码大小] / OPT_精度
 热度 = 热度 + 特征[特征_函数调用] * 2
 追加(热点, [i, 热度])
 i = i + 1
 }

 // 按热度降序排序
 定义 可变 a = 0
 当 (a < 计数(热点) - 1) { 定义 可变 最大 = a
 定义 可变 b = a + 1
 当 (b < 计数(热点)) { 如果 (热点[b][1] > 热点[最大][1]) { 最大 = b }
 b = b + 1
 }
 如果 (最大 != a) { 定义 暂存 = 热点[a]
 热点[a] = 热点[最大]
 热点[最大] = 暂存
 }
 a = a + 1
 }

 返回 热点
}

// 编译时间预算 (Compilation Time Budget)
// 智能分配优化时间: 热点多优化, 冷代码少优化
函数 分配优化预算(热点列表, 总预算) {
    如果 (计数(热点列表) == 0) { 返回 []
}

 定义 可变 总热度 = 0
 定义 可变 i = 0
 当 (i < 计数(热点列表)) {
 总热度 = 总热度 + 热点列表[i][1]
 i = i + 1
 }

 如果 (总热度 == 0) { 总热度 = 1 }

 定义 可变 预算分配 = []
 i = 0
 当 (i < 计数(热点列表)) { 定义 可变 份额 = 热点列表[i][1] * 总预算 / 总热度
 // 最少给10%的基本预算
 定义 最小预算 = 总预算 / (计数(热点列表) * 10)
 如果 (份额 < 最小预算) { 份额 = 最小预算 }
 追加(预算分配, [热点列表[i][0], 份额])
 i = i + 1
 }
 返回 预算分配
}

// 优化策略选择

函数 优化_策略推荐(代码大小, 循环深度, 函数调用数) {
    如果 (循环深度 > 5) { 返回 "循环展开+向量化"
}
 如果 (函数调用数 > 100) { 返回 "内联优先" }
 如果 (代码大小 > 10000) { 返回 "分阶段优化" }
 返回 "标准优化"
}

函数 优化_内联决策(函数大小, 调用次数, 热度) {
    如果 (函数大小 < 10 且 调用次数 > 5) { 返回 真
}
 如果 (函数大小 < 50 且 热度 > 80) { 返回 真 }
 如果 (函数大小 < 5) { 返回 真 }
 返回 假
}

函数 优化_循环展开决策(迭代次数, 循环体大小) {
    如果 (迭代次数 <= 4) { 返回 迭代次数
}
 如果 (循环体大小 < 10) { 返回 4 }
 如果 (循环体大小 < 50) { 返回 2 }
 返回 1
}

函数 优化_向量化可行性(迭代次数, 依赖深度) {
    如果 (依赖深度 > 1) { 返回 假
}
 如果 (迭代次数 < 4) { 返回 假 }
 返回 真
}

函数 优化_寄存器压力(变量数, 可用寄存器) {
    如果 (变量数 > 可用寄存器 * 2) { 返回 "严重溢出"
}
 如果 (变量数 > 可用寄存器) { 返回 "轻微溢出" }
 返回 "无压力"
}

定义 可变 _自适应_优化轮次 = 0
定义 可变 _自适应_内联数 = 0
定义 可变 _自适应_展开数 = 0

函数 自适应_记录优化() { _自适应_优化轮次 = _自适应_优化轮次 + 1 }
函数 自适应_记录内联() { _自适应_内联数 = _自适应_内联数 + 1 }
函数 自适应_记录展开() { _自适应_展开数 = _自适应_展开数 + 1 }

函数 自适应_效率评估() {
    如果 (_自适应_优化轮次 == 0) { 返回 "未执行优化"
}
 定义 总操作 = _自适应_内联数 + _自适应_展开数
 如果 (总操作 == 0) { 返回 "优化无效果" }
 返回 "已执行" + 转字符串(总操作) + "次优化操作"
}

函数 自适应_重置() { _自适应_优化轮次 = 0
 _自适应_内联数 = 0
 _自适应_展开数 = 0
}

// 编译成本模型

函数 成本_指令(操作类型) { 如果 (操作类型 == 0) { 返回 1 } // 算术
 如果 (操作类型 == 1) { 返回 3 } // 内存读
 如果 (操作类型 == 2) { 返回 4 } // 内存写
 如果 (操作类型 == 3) { 返回 5 } // 分支
 如果 (操作类型 == 4) { 返回 10 } // 函数调用
 如果 (操作类型 == 5) { 返回 20 } // 系统调用
 返回 1
}

函数 成本_循环(迭代, 体成本) { 返回 迭代 * 体成本 + 迭代 * 2
}

函数 成本_函数(参数数, 体成本) { 返回 参数数 * 2 + 体成本 + 10
}

函数 成本_估算(指令列表) { 定义 可变 总成本 = 0
 定义 可变 i = 0
 当 (i < 计数(指令列表)) {
 总成本 = 总成本 + 成本_指令(指令列表[i])
 i = i + 1
 }
 返回 总成本
}

函数 成本_优化收益(原始成本, 优化成本) {
    如果 (原始成本 == 0) { 返回 0
}
 返回 (原始成本 - 优化成本) * 100 / 原始成本
}

函数 成本_是否值得优化(原始成本, 优化编译成本) {
    如果 (优化编译成本 > 原始成本 * 10) { 返回 假
}
 返回 真
}

函数 成本_推荐优化级别(代码复杂度) {
    如果 (代码复杂度 > 10000) { 返回 3
}
 如果 (代码复杂度 > 1000) { 返回 2 }
 返回 1
}

函数 成本_总评估(指令列表) { 定义 成本 = 成本_估算(指令列表)
 如果 (成本 > 10000) { 返回 "重度计算(必须优化)" }
 如果 (成本 > 1000) { 返回 "中等计算" }
 返回 "轻量计算"
}

// 循环优化框架 (Loop Optimization Framework)
// 展开 · 向量化提示 · 不变量外提 · 强度削弱 · 循环融合

// 循环信息
// [循环ID, 嵌套深度, 预估迭代数, 体指令数, 归纳变量数, 标记集]
定义 循环标记_可展开     = 1
定义 循环标记_可向量化   = 2
定义 循环标记_有不变量   = 4
定义 循环标记_可并行     = 8
定义 循环标记_内存密集   = 16

定义 可变 _循环_列表 = []

函数 循环_注册(循环ID, 深度, 迭代数, 体指令数, 归纳变量数) {
    定义 可变 标记 = 0
    // 自动判断优化可能性
    如果 (迭代数 > 0 且 迭代数 <= 16 且 体指令数 <= 20) { 标记 = 标记 | 循环标记_可展开 }
    如果 (归纳变量数 <= 2 且 体指令数 <= 50) { 标记 = 标记 | 循环标记_可向量化 }
    追加(_循环_列表, [循环ID, 深度, 迭代数, 体指令数, 归纳变量数, 标记])
    返回 标记
}

函数 循环_设置标记(循环ID, 新标记) {
    定义 可变 i = 0
    当 (i < 计数(_循环_列表)) {
        如果 (_循环_列表[i][0] == 循环ID) {
            _循环_列表[i][5] = _循环_列表[i][5] | 新标记
            返回
        }
        i = i + 1
    }
}

函数 循环_有标记(循环ID, 标记) {
    定义 可变 i = 0
    当 (i < 计数(_循环_列表)) {
        如果 (_循环_列表[i][0] == 循环ID) {
            返回 (_循环_列表[i][5] & 标记) != 0
        }
        i = i + 1
    }
    返回 假
}

// 循环展开决策: 返回展开因子 (0=不展开, 2/4/8=展开倍数)
函数 循环_展开因子(迭代数, 体指令数) {
    如果 (体指令数 > 30) { 返回 0 }
    如果 (迭代数 <= 4) { 返回 迭代数 }
    如果 (迭代数 <= 8 且 体指令数 <= 10) { 返回 4 }
    如果 (迭代数 <= 16 且 体指令数 <= 5) { 返回 8 }
    如果 (体指令数 <= 8) { 返回 4 }
    返回 2
}

// 不变量外提: 识别循环内不依赖归纳变量的表达式
函数 循环_不变量外提(循环体指令, 归纳变量列表) {
    定义 可变 可外提 = []
    定义 可变 i = 0
    当 (i < 计数(循环体指令)) {
        定义 instr = 循环体指令[i]
        // 指令不引用任何归纳变量 → 可外提
        定义 可变 依赖归纳 = 假
        定义 可变 j = 0
        当 (j < 计数(归纳变量列表)) {
            如果 (instr == 归纳变量列表[j]) { 依赖归纳 = 真 }
            j = j + 1
        }
        如果 (依赖归纳 == 假) { 追加(可外提, i) }
        i = i + 1
    }
    返回 可外提
}

// PGO 热点标注 (Profile-Guided Optimization)
// 运行时收集执行频率 → 反馈到编译器 → 针对热路径深度优化

// 执行计数器: [函数名, 执行次数, 总耗时]
定义 可变 PGO_计数器 = []

函数 PGO_注册函数(函数名) {
    追加(PGO_计数器, [函数名, 0, 0])
}

函数 PGO_记录执行(函数名, 耗时) {
    定义 可变 i = 0
    当 (i < 计数(PGO_计数器)) {
        如果 (PGO_计数器[i][0] == 函数名) {
            PGO_计数器[i][1] = PGO_计数器[i][1] + 1
            PGO_计数器[i][2] = PGO_计数器[i][2] + 耗时
            返回
        }
        i = i + 1
    }
    追加(PGO_计数器, [函数名, 1, 耗时])
}

// 热度分类: 冷(<10次) / 温(10-1000) / 热(>1000)
函数 PGO_热度(函数名) {
    定义 可变 i = 0
    当 (i < 计数(PGO_计数器)) {
        如果 (PGO_计数器[i][0] == 函数名) {
            如果 (PGO_计数器[i][1] > 1000) { 返回 "热" }
            如果 (PGO_计数器[i][1] > 10) { 返回 "温" }
            返回 "冷"
        }
        i = i + 1
    }
    返回 "未知"
}

// 热路径优化级别: 热→O3+内联, 温→O2, 冷→O1
函数 PGO_优化级别(函数名) {
    定义 热度 = PGO_热度(函数名)
    如果 (热度 == "热") { 返回 3 }
    如果 (热度 == "温") { 返回 2 }
    返回 1
}

// 分支概率统计
定义 可变 PGO_分支统计 = []

函数 PGO_记录分支(位置, 走真, 走假) {
    追加(PGO_分支统计, [位置, 走真, 走假])
}

函数 PGO_分支概率(位置) {
    定义 可变 i = 0
    当 (i < 计数(PGO_分支统计)) {
        如果 (PGO_分支统计[i][0] == 位置) {
            定义 总 = PGO_分支统计[i][1] + PGO_分支统计[i][2]
            如果 (总 == 0) { 返回 50 }
            返回 PGO_分支统计[i][1] * 100 / 总
        }
        i = i + 1
    }
    返回 50
}

// 增量编译缓存 (Incremental Compilation Cache)
// 基于模块哈希的增量编译: 只重编变化的模块

// 模块缓存条目: [模块名, 源码哈希, 编译结果哈希, 依赖列表, 时间戳]
定义 可变 编译缓存 = []

函数 缓存_查找(模块名) {
    定义 可变 i = 0
    当 (i < 计数(编译缓存)) {
        如果 (编译缓存[i][0] == 模块名) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 缓存_更新(模块名, 源码哈希, 编译哈希, 依赖列表) {
    定义 idx = 缓存_查找(模块名)
    如果 (idx >= 0) {
        编译缓存[idx][1] = 源码哈希
        编译缓存[idx][2] = 编译哈希
        编译缓存[idx][3] = 依赖列表
        编译缓存[idx][4] = 0
    } 否则 {
        追加(编译缓存, [模块名, 源码哈希, 编译哈希, 依赖列表, 0])
    }
}

函数 缓存_有效(模块名, 当前源码哈希) {
    定义 idx = 缓存_查找(模块名)
    如果 (idx < 0) { 返回 假 }
    如果 (编译缓存[idx][1] != 当前源码哈希) { 返回 假 }
    // 检查依赖是否变化
    定义 依赖 = 编译缓存[idx][3]
    定义 可变 i = 0
    当 (i < 计数(依赖)) {
        定义 dep_idx = 缓存_查找(依赖[i])
        如果 (dep_idx < 0) { 返回 假 }
        i = i + 1
    }
    返回 真
}

// 增量编译决策: 返回需要重编的模块列表
函数 缓存_计算重编列表(所有模块, 哈希表) {
    定义 可变 需重编 = []
    定义 可变 i = 0
    当 (i < 计数(所有模块)) {
        定义 模块名 = 所有模块[i]
        定义 可变 哈希 = 0
        如果 (i < 计数(哈希表)) { 哈希 = 哈希表[i] }
        如果 (缓存_有效(模块名, 哈希) == 假) {
            追加(需重编, 模块名)
        }
        i = i + 1
    }
    返回 需重编
}

函数 缓存_命中率() {
    定义 总 = 计数(编译缓存)
    如果 (总 == 0) { 返回 0 }
    定义 可变 有效数 = 0
    定义 可变 i = 0
    当 (i < 总) {
        如果 (编译缓存[i][1] != 0) { 有效数 = 有效数 + 1 }
        i = i + 1
    }
    返回 有效数 * 100 / 总
}

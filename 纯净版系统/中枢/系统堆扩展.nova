导入("./类型定义.nova")
导入("./错误码.nova")
导入("./墙钟设置.nova")
导入("./整数转字符串.nova")

函数 系统_brk(mm, 新brk) {
    定义 旧brk = mm[MM_BRK当前]
    定义 brk起始 = mm[MM_BRK起始]

    // brk不能低于数据段末尾
    如果 (新brk < brk起始) { 返回 旧brk }

    定义 新brk对齐 = 对齐到页(新brk)
    定义 旧brk对齐 = 对齐到页(旧brk)

    如果 (新brk对齐 > 旧brk对齐) {
        // 扩展堆: 创建新的VMA或扩展已有VMA
        定义 扩展大小 = 新brk对齐 - 旧brk对齐
        定义 vma = VMA_创建(旧brk对齐, 新brk对齐, VM_读 | VM_写 | VM_匿名, 0)
        mm_插入VMA(mm, vma)
    } 否则 如果 (新brk对齐 < 旧brk对齐) {
        // 收缩堆: 取消映射释放的部分
        系统_munmap(mm, 新brk对齐, 旧brk对齐 - 新brk对齐)
    }

    设置(mm, MM_BRK当前, 新brk)
    brk_调用次数 = brk_调用次数 + 1
    返回 新brk
}

// mprotect系统调用 (修改内存保护属性)

函数 系统_mprotect(mm, 地址, 大小, 保护) {
    如果 ((地址 & 0xFFF) != 0) { 返回 错误_无效参数 }
    大小 = 对齐到页(大小)

    定义 新vm标志 = PROT转VM标志(保护)
    定义 新pte标志 = PROT转PTE标志(保护)
    定义 pml4 = mm[MM_PML4物理]

    // 修改页表权限
    映射_修改范围权限(pml4, 地址, 大小, 新pte标志)

    // 更新VMA标志
    定义 vma = mm_查找VMA(mm, 地址)
    如果 (vma != 空) {
        设置(vma, VMA_标志, 新vm标志 | (vma[VMA_标志] & (VM_共享 | VM_匿名 | VM_文件)))
    }

    mprotect_调用次数 = mprotect_调用次数 + 1
    返回 成功
}

// VMA列表管理

// 按起始地址排序插入VMA
函数 mm_插入VMA(mm, vma) {
    定义 vma列表 = mm[MM_VMA列表]
    定义 可变 i = 0
    当 (i < 计数(vma列表)) {
        如果 (vma[VMA_起始] < vma列表[i][VMA_起始]) {
            插入(vma列表, i, vma)
            设置(mm, MM_VMA计数, mm[MM_VMA计数] + 1)
            设置(mm, MM_总虚拟大小, mm[MM_总虚拟大小] + VMA_大小(vma))
            返回
        }
        i = i + 1
    }
    追加(vma列表, vma)
    设置(mm, MM_VMA计数, mm[MM_VMA计数] + 1)
    设置(mm, MM_总虚拟大小, mm[MM_总虚拟大小] + VMA_大小(vma))
}

// 移除与[起始,结束)重叠的VMA
函数 mm_移除VMA范围(mm, 起始, 结束) {
    定义 vma列表 = mm[MM_VMA列表]
    定义 可变 i = 计数(vma列表) - 1
    当 (i >= 0) {
        定义 vma = vma列表[i]
        如果 (vma[VMA_起始] >= 起始 && vma[VMA_结束] <= 结束) {
            // VMA完全在范围内, 直接移除
            设置(mm, MM_总虚拟大小, mm[MM_总虚拟大小] - VMA_大小(vma))
            删除(vma列表, i)
            设置(mm, MM_VMA计数, mm[MM_VMA计数] - 1)
        } 否则 如果 (vma[VMA_起始] < 起始 && vma[VMA_结束] > 结束) {
            // VMA包含整个范围, 需要分裂成两个
            定义 新vma = VMA_创建(结束, vma[VMA_结束], vma[VMA_标志], 0)
            设置(vma, VMA_结束, 起始)
            mm_插入VMA(mm, 新vma)
        } 否则 如果 (vma[VMA_起始] < 结束 && vma[VMA_结束] > 结束) {
            // 左边重叠: 截断VMA左部
            设置(mm, MM_总虚拟大小, mm[MM_总虚拟大小] - (结束 - vma[VMA_起始]))
            设置(vma, VMA_起始, 结束)
        } 否则 如果 (vma[VMA_起始] < 起始 && vma[VMA_结束] > 起始) {
            // 右边重叠: 截断VMA右部
            设置(mm, MM_总虚拟大小, mm[MM_总虚拟大小] - (vma[VMA_结束] - 起始))
            设置(vma, VMA_结束, 起始)
        }
        i = i - 1
    }
}

// 辅助函数: 标志转换

函数 PROT转VM标志(保护) {
    定义 可变 标志 = 0
    如果 ((保护 & PROT_读) != 0) { 标志 = 标志 | VM_读 }
    如果 ((保护 & PROT_写) != 0) { 标志 = 标志 | VM_写 }
    如果 ((保护 & PROT_执行) != 0) { 标志 = 标志 | VM_执行 }
    返回 标志
}

函数 PROT转PTE标志(保护) {
    定义 可变 标志 = PTE_存在 | PTE_用户
    如果 ((保护 & PROT_写) != 0) { 标志 = 标志 | PTE_可写 }
    如果 ((保护 & PROT_执行) == 0) { 标志 = 标志 | PTE_不可执行 }
    返回 标志
}

函数 对齐到页(大小) {
    返回 (大小 + 页大小 - 1) & ~(页大小 - 1)
}

// 统计

函数 Nova内存映射_统计() {
    返回 [Nova内存映射_调用次数, munmap_调用次数, brk_调用次数, mprotect_调用次数]
}

// mmap系统调用 — 完整实现

定义 MAP_PRIVATE = 0x02
定义 MAP_ANONYMOUS = 0x20
定义 MAP_FIXED = 0x10
定义 MAP_SHARED = 0x01
定义 PROT_读 = 0x01
定义 PROT_写 = 0x02
定义 PROT_执行 = 0x04
定义 VM_读 = 0x01
定义 VM_写 = 0x02
定义 VM_执行 = 0x04
定义 VM_共享 = 0x08
定义 VM_匿名 = 0x10
定义 VM_文件 = 0x20
定义 PTE_存在 = 0x01
定义 PTE_可写 = 0x02
定义 PTE_用户 = 0x04
定义 PTE_不可执行 = 0x8000000000000000
定义 页大小 = 4096
定义 可变 Nova内存映射_调用次数 = 0
定义 可变 munmap_调用次数 = 0
定义 可变 brk_调用次数 = 0
定义 可变 mprotect_调用次数 = 0

定义 MM_BRK当前 = 0
定义 MM_BRK起始 = 1
定义 MM_PML4物理 = 2
定义 MM_VMA列表 = 3
定义 MM_VMA计数 = 4
定义 MM_总虚拟大小 = 5
定义 VMA_起始 = 0
定义 VMA_结束 = 1
定义 VMA_标志 = 2

函数 系统_mmap(mm, 地址, 大小, 保护, 标志, fd, 偏移) {
    Nova内存映射_调用次数 = Nova内存映射_调用次数 + 1
    大小 = 对齐到页(大小)
    如果 (大小 == 0) { 返回 错误_无效参数 }

    定义 vm标志 = PROT转VM标志(保护)
    如果 ((标志 & MAP_SHARED) != 0) { vm标志 = vm标志 | VM_共享 }
    如果 ((标志 & MAP_ANONYMOUS) != 0) { vm标志 = vm标志 | VM_匿名 }
    否则 { vm标志 = vm标志 | VM_文件 }

    // 查找空闲虚拟地址
    定义 可变 映射地址 = 0
    如果 ((标志 & MAP_FIXED) != 0) {
        映射地址 = 地址
        系统_munmap(mm, 地址, 大小)
    } 否则 {
        映射地址 = mm_查找空闲区(mm, 大小)
        如果 (映射地址 == 0) { 返回 错误_内存不足 }
    }

    // 创建VMA
    定义 vma = VMA_创建(映射地址, 映射地址 + 大小, vm标志, fd)
    mm_插入VMA(mm, vma)

    // 文件映射: 设置页缓存关联
    如果 (fd > 0 && (标志 & MAP_ANONYMOUS) == 0) {
        VMA_设置文件(vma, fd, 偏移)
    }

    返回 映射地址
}

函数 系统_munmap(mm, 地址, 大小) {
    如果 ((地址 & 0xFFF) != 0) { 返回 错误_无效参数 }
    大小 = 对齐到页(大小)
    munmap_调用次数 = munmap_调用次数 + 1

    // 取消页表映射
    定义 pml4 = mm[MM_PML4物理]
    映射_取消范围(pml4, 地址, 大小)

    // 移除VMA
    mm_移除VMA范围(mm, 地址, 地址 + 大小)
    返回 成功
}

函数 mm_查找空闲区(mm, 大小) {
    // 从用户空间高地址向下搜索
    定义 可变 候选 = 0x7FFF00000000 - 大小
    定义 vma列表 = mm[MM_VMA列表]
    定义 可变 i = 计数(vma列表) - 1
    当 (i >= 0) {
        如果 (候选 >= vma列表[i][VMA_结束] || 候选 + 大小 <= vma列表[i][VMA_起始]) {
            返回 候选
        }
        候选 = vma列表[i][VMA_起始] - 大小
        如果 (候选 < 0x10000) { 返回 0 }
        i = i - 1
    }
    返回 候选
}

函数 mm_查找VMA(mm, 地址) {
    定义 vma列表 = mm[MM_VMA列表]
    定义 可变 i = 0
    当 (i < 计数(vma列表)) {
        如果 (地址 >= vma列表[i][VMA_起始] && 地址 < vma列表[i][VMA_结束]) {
            返回 vma列表[i]
        }
        i = i + 1
    }
    返回 空
}

函数 VMA_创建(起始, 结束, 标志, fd) {
    返回 [起始, 结束, 标志, fd]
}

函数 VMA_大小(vma) {
    返回 vma[VMA_结束] - vma[VMA_起始]
}

函数 VMA_设置文件(vma, fd, 偏移) {
    // 将文件描述符关联到VMA, 用于mmap文件映射
    如果 (vma == 空) { 返回 }
    设置(vma, VMA_文件FD, fd)
    设置(vma, VMA_文件偏移, 偏移)
    // 标记为文件映射VMA
    设置(vma, VMA_标志, vma[VMA_标志] | VM_文件)
}
函数 映射_取消范围(pml4, 地址, 大小) {
    // 取消页表中指定范围的映射, 释放物理页
    如果 (pml4 == 空 || 大小 == 0) { 返回 }
    定义 起始页 = 地址 / 页大小
    定义 页数 = 对齐到(大小, 页大小) / 页大小
    定义 可变 i = 0
    当 (i < 页数) {
        页表_清除条目(pml4, (起始页 + i) * 页大小)
        i = i + 1
    }
    // 刷新TLB
    TLB_刷新范围(地址, 大小)
}
函数 映射_修改范围权限(pml4, 地址, 大小, 标志) {
    // 修改页表条目的权限位(R/W/X/U)
    如果 (pml4 == 空 || 大小 == 0) { 返回 }
    定义 起始页 = 地址 / 页大小
    定义 页数 = 对齐到(大小, 页大小) / 页大小
    定义 可变 i = 0
    当 (i < 页数) {
        页表_修改权限(pml4, (起始页 + i) * 页大小, 标志)
        i = i + 1
    }
    TLB_刷新范围(地址, 大小)
}

// AI内存预测 — 预测进程内存增长趋势

定义 可变 AI_mmap历史 = []
定义 可变 AI_brk历史 = []

函数 AI_内存_记录mmap(大小) {
    追加(AI_mmap历史, { 大小: 大小, 时间: 当前时间_纳秒() })
    如果 (计数(AI_mmap历史) > 64) { AI_mmap历史 = 子列表(AI_mmap历史, 32, 64) }
}

函数 AI_内存_记录brk(增量) {
    追加(AI_brk历史, { 增量: 增量, 时间: 当前时间_纳秒() })
    如果 (计数(AI_brk历史) > 64) { AI_brk历史 = 子列表(AI_brk历史, 32, 64) }
}

函数 AI_内存_预测增长() {
    定义 n = 计数(AI_mmap历史)
    如果 (n < 3) { 返回 0 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < n) { 总 = 总 + AI_mmap历史[i].大小; i = i + 1 }
    返回 总 * 3 / (n * 2)
}

函数 内存映射_健康检查(mm) {
    定义 可变 问题 = []
    如果 (mm[MM_VMA计数] > 65536) {
        追加(问题, "VMA数量过多: " + 整数转字符串(mm[MM_VMA计数]))
    }
    如果 (mm[MM_总虚拟大小] > 128 * 1024 * 1024 * 1024) {
        追加(问题, "虚拟地址空间过大")
    }
    如果 (计数(问题) == 0) { 返回 "内存映射健康" }
    返回 问题
}

// brk系统调用辅助

函数 brk_对齐页(地址) {
    返回 (地址 + 4095) & ~4095
}

函数 brk_检查限制(mm, 新brk) {
    如果 (新brk > mm[MM_堆上限]) { 返回 假 }
    如果 (新brk < mm[MM_堆起始]) { 返回 假 }
    返回 真
}

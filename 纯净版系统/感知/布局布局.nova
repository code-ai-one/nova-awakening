导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/整数转字符串.nova")
导入("./样式值解析.nova")
导入("../中枢/内核打印.nova")

定义 定位_静态    = 0
定义 定位_相对    = 1
定义 定位_绝对    = 2
定义 定位_固定    = 3
定义 定位_粘性    = 4

定义 对齐_起始    = 0
定义 对齐_末尾    = 1
定义 对齐_居中    = 2
定义 对齐_两端    = 3
定义 对齐_环绕    = 4
定义 对齐_均匀    = 5
定义 对齐_拉伸    = 6
定义 对齐_基线    = 7

定义 表格算法_自动 = 0
定义 表格算法_固定 = 1

定义 边框_分离 = 0
定义 边框_合并 = 1

定义 垂直_顶部 = 0
定义 垂直_中部 = 1
定义 垂直_底部 = 2
定义 垂直_基线 = 3

定义 最大表格列数 = 128

结构 列信息 {
    最小宽,
    最大宽,
    首选宽,
    百分比宽,
    实际宽,
    有百分比,
    有固定宽,
}

结构 表格布局统计 {
    布局总次数,
    总行数,
    总列数,
    总单元格数,
    合并单元格数,
    固定布局次数,
    自动布局次数,
    AI优化次数,
}

定义 可变 全局_表格统计 = 空

函数 表格统计_初始化() {
    如果 (全局_表格统计 == 空) {
        全局_表格统计 = 表格布局统计 {}
        全局_表格统计.布局总次数 = 0
        全局_表格统计.总行数 = 0
        全局_表格统计.总列数 = 0
        全局_表格统计.总单元格数 = 0
        全局_表格统计.合并单元格数 = 0
        全局_表格统计.固定布局次数 = 0
        全局_表格统计.自动布局次数 = 0
        全局_表格统计.AI优化次数 = 0
    }
}

函数 表格_计算列数和行数(layout) {
    定义 可变 列数 = 0
    定义 可变 行数 = 0
    定义 可变 row = layout.第一子
    当 (row != 0) {
        行数 = 行数 + 1
        定义 可变 col_count = 0
        定义 可变 cell = row.第一子
        当 (cell != 0) {
            定义 colspan = 表格_获取colspan(cell)
            col_count = col_count + colspan
            cell = cell.后一兄弟布局
        }
        如果 (col_count > 列数) { 列数 = col_count }
        row = row.后一兄弟布局
    }
    如果 (列数 == 0) { 列数 = 1 }
    如果 (列数 > 最大表格列数) { 列数 = 最大表格列数 }
    返回 [列数, 行数]
}

函数 表格_获取colspan(cell) {
    如果 (cell == 0) { 返回 1 }
    定义 cs = cell.colspan
    如果 (cs <= 0) { 返回 1 }
    返回 cs
}

函数 表格_获取rowspan(cell) {
    如果 (cell == 0) { 返回 1 }
    定义 rs = cell.rowspan
    如果 (rs <= 0) { 返回 1 }
    返回 rs
}

函数 表格_初始化列信息(列数) {
    定义 可变 列表 = []
    定义 可变 i = 0
    当 (i < 列数) {
        定义 c = 列信息 {}
        c.最小宽 = 0
        c.最大宽 = 0
        c.首选宽 = 0
        c.百分比宽 = 0
        c.实际宽 = 0
        c.有百分比 = 假
        c.有固定宽 = 假
        追加(列表, c)
        i = i + 1
    }
    返回 列表
}

函数 表格_收集列约束(layout, 列信息表, 列数) {
    定义 可变 row = layout.第一子
    当 (row != 0) {
        定义 可变 col_idx = 0
        定义 可变 cell = row.第一子
        当 (cell != 0 && col_idx < 列数) {
            定义 colspan = 表格_获取colspan(cell)

            如果 (colspan == 1) {
                定义 min_w = cell.min_width
                定义 max_w = cell.max_width
                如果 (min_w == 0) { min_w = 20 }
                如果 (max_w == 0) { max_w = min_w }
                如果 (max_w < min_w) { max_w = min_w }

                如果 (min_w > 列信息表[col_idx].最小宽) {
                    列信息表[col_idx].最小宽 = min_w
                }
                如果 (max_w > 列信息表[col_idx].最大宽) {
                    列信息表[col_idx].最大宽 = max_w
                }

                如果 (cell.width_percent > 0) {
                    列信息表[col_idx].百分比宽 = cell.width_percent
                    列信息表[col_idx].有百分比 = 真
                } 否则 如果 (cell.宽度 > 0) {
                    列信息表[col_idx].首选宽 = cell.宽度
                    列信息表[col_idx].有固定宽 = 真
                }
            }

            col_idx = col_idx + colspan
            cell = cell.后一兄弟布局
        }
        row = row.后一兄弟布局
    }
}

函数 表格_固定算法(列信息表, 列数, 表格宽) {
    表格统计_初始化()
    全局_表格统计.固定布局次数 = 全局_表格统计.固定布局次数 + 1
    定义 可变 已分配宽 = 0
    定义 可变 未分配列 = 0
    定义 可变 i = 0

    当 (i < 列数) {
        如果 (列信息表[i].有固定宽) {
            列信息表[i].实际宽 = 列信息表[i].首选宽
            已分配宽 = 已分配宽 + 列信息表[i].实际宽
        } 否则 如果 (列信息表[i].有百分比) {
            列信息表[i].实际宽 = 表格宽 * 列信息表[i].百分比宽 / 100
            已分配宽 = 已分配宽 + 列信息表[i].实际宽
        } 否则 {
            未分配列 = 未分配列 + 1
        }
        i = i + 1
    }

    如果 (未分配列 > 0) {
        定义 剩余 = 表格宽 - 已分配宽
        如果 (剩余 < 0) { 剩余 = 0 }
        定义 每列 = 剩余 / 未分配列
        i = 0
        当 (i < 列数) {
            如果 (!列信息表[i].有固定宽 && !列信息表[i].有百分比) {
                列信息表[i].实际宽 = 每列
            }
            i = i + 1
        }
    }
}

函数 表格_自动算法(列信息表, 列数, 表格宽) {
    表格统计_初始化()
    全局_表格统计.自动布局次数 = 全局_表格统计.自动布局次数 + 1

    定义 可变 总最小 = 0
    定义 可变 总最大 = 0
    定义 可变 i = 0
    当 (i < 列数) {
        总最小 = 总最小 + 列信息表[i].最小宽
        总最大 = 总最大 + 列信息表[i].最大宽
        i = i + 1
    }

    如果 (表格宽 <= 总最小) {
        i = 0
        当 (i < 列数) {
            列信息表[i].实际宽 = 列信息表[i].最小宽
            i = i + 1
        }
        返回
    }

    如果 (表格宽 >= 总最大) {
        定义 额外 = 表格宽 - 总最大
        定义 每列额外 = 额外 / 列数
        i = 0
        当 (i < 列数) {
            列信息表[i].实际宽 = 列信息表[i].最大宽 + 每列额外
            i = i + 1
        }
        返回
    }

    定义 可用 = 表格宽 - 总最小
    定义 范围总和 = 总最大 - 总最小
    如果 (范围总和 == 0) { 范围总和 = 1 }

    i = 0
    当 (i < 列数) {
        定义 范围 = 列信息表[i].最大宽 - 列信息表[i].最小宽
        列信息表[i].实际宽 = 列信息表[i].最小宽 + 可用 * 范围 / 范围总和
        i = i + 1
    }
}

函数 表格_计算列x偏移(列信息表, 列数, 边框间距) {
    定义 可变 偏移表 = []
    定义 可变 x = 边框间距
    定义 可变 i = 0
    当 (i < 列数) {
        追加(偏移表, x)
        x = x + 列信息表[i].实际宽 + 边框间距
        i = i + 1
    }
    返回 偏移表
}

函数 布局Table_布局(layout) {
    表格统计_初始化()
    如果 (layout == 0) { 返回 }

    全局_表格统计.布局总次数 = 全局_表格统计.布局总次数 + 1
    定义 表格宽 = layout.宽度
    定义 维度 = 表格_计算列数和行数(layout)
    定义 列数 = 维度[0]
    定义 行数 = 维度[1]

    全局_表格统计.总列数 = 全局_表格统计.总列数 + 列数
    全局_表格统计.总行数 = 全局_表格统计.总行数 + 行数

    定义 列信息表 = 表格_初始化列信息(列数)
    表格_收集列约束(layout, 列信息表, 列数)

    定义 算法 = layout.table_layout
    如果 (算法 == 表格算法_固定) {
        表格_固定算法(列信息表, 列数, 表格宽)
    } 否则 {
        表格_自动算法(列信息表, 列数, 表格宽)
    }

    定义 边框间距 = layout.border_spacing
    如果 (边框间距 < 0) { 边框间距 = 0 }
    定义 列x偏移 = 表格_计算列x偏移(列信息表, 列数, 边框间距)

    定义 可变 当前Y = 边框间距
    定义 可变 row = layout.第一子
    当 (row != 0) {
        定义 可变 col_idx = 0
        定义 可变 行高 = 0
        定义 可变 cell = row.第一子
        当 (cell != 0 && col_idx < 列数) {
            定义 colspan = 表格_获取colspan(cell)

            定义 可变 单元格宽 = 0
            定义 可变 ci = 0
            当 (ci < colspan && (col_idx + ci) < 列数) {
                单元格宽 = 单元格宽 + 列信息表[col_idx + ci].实际宽
                如果 (ci > 0) { 单元格宽 = 单元格宽 + 边框间距 }
                ci = ci + 1
            }

            cell.x = 列x偏移[col_idx]
            cell.y = 当前Y
            cell.宽度 = 单元格宽

            布局块级Flow_布局(cell)

            定义 ch = cell.高度 + cell.padding_top + cell.padding_bottom + cell.border_top + cell.border_bottom
            如果 (ch > 行高) { 行高 = ch }

            全局_表格统计.总单元格数 = 全局_表格统计.总单元格数 + 1
            如果 (colspan > 1) {
                全局_表格统计.合并单元格数 = 全局_表格统计.合并单元格数 + 1
            }

            col_idx = col_idx + colspan
            cell = cell.后一兄弟布局
        }

        cell = row.第一子
        当 (cell != 0) {
            cell.高度 = 行高
            表格_垂直对齐(cell, 行高)
            cell = cell.后一兄弟布局
        }

        当前Y = 当前Y + 行高 + 边框间距
        row = row.后一兄弟布局
    }

    layout.高度 = 当前Y
}

函数 表格_垂直对齐(cell, 行高) {
    如果 (cell == 0) { 返回 }
    定义 内容高 = cell.高度 - cell.padding_top - cell.padding_bottom
    定义 valign = cell.vertical_align

    如果 (valign == 垂直_中部) {
        定义 偏移 = (行高 - 内容高) / 2
        如果 (偏移 > 0) { cell.padding_top = cell.padding_top + 偏移 }
    } 否则 如果 (valign == 垂直_底部) {
        定义 偏移 = 行高 - 内容高
        如果 (偏移 > 0) { cell.padding_top = cell.padding_top + 偏移 }
    }
}

函数 布局Table_标题(layout) {
    如果 (layout == 0) { 返回 0 }
    定义 caption = layout.caption
    如果 (caption == 0) { 返回 0 }

    caption.宽度 = layout.宽度
    布局块级Flow_布局(caption)
    返回 caption.高度
}

函数 布局Table_边框合并(layout) {
    如果 (layout == 0) { 返回 }
    定义 可变 row = layout.第一子
    当 (row != 0) {
        定义 可变 cell = row.第一子
        定义 可变 prev = 0
        当 (cell != 0) {
            如果 (prev != 0) {
                定义 合并宽 = 表格_较大值(prev.border_right, cell.border_left)
                prev.border_right = 合并宽 / 2
                cell.border_left = 合并宽 - prev.border_right
            }
            prev = cell
            cell = cell.后一兄弟布局
        }
        row = row.后一兄弟布局
    }
}

函数 表格_较大值(a, b) {
    如果 (a > b) { 返回 a }
    返回 b
}

函数 智能_布局块级Flow_AI初始化() {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 }
}

函数 智能_表格布局优化(layout) {
    表格统计_初始化()
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 }

    全局_表格统计.AI优化次数 = 全局_表格统计.AI优化次数 + 1
}

函数 表格布局_打印统计() {
    表格统计_初始化()
    打印行("=== 表格布局统计 ===")
    打印行("布局次数: " + 整数转字符串(全局_表格统计.布局总次数))
    打印行("总行数: " + 整数转字符串(全局_表格统计.总行数))
    打印行("总列数: " + 整数转字符串(全局_表格统计.总列数))
    打印行("单元格: " + 整数转字符串(全局_表格统计.总单元格数))
    打印行("合并格: " + 整数转字符串(全局_表格统计.合并单元格数))
    打印行("固定布局: " + 整数转字符串(全局_表格统计.固定布局次数))
    打印行("自动布局: " + 整数转字符串(全局_表格统计.自动布局次数))
    打印行("AI优化: " + 整数转字符串(全局_表格统计.AI优化次数))
}

函数 表格_完整统计() {
    表格统计_初始化()
    返回 [全局_表格统计.布局总次数, 全局_表格统计.总行数,
           全局_表格统计.总列数, 全局_表格统计.总单元格数,
           全局_表格统计.合并单元格数, 全局_表格统计.固定布局次数,
           全局_表格统计.自动布局次数, 全局_表格统计.AI优化次数]
}

函数 表格_重置统计() {
    如果 (全局_表格统计 != 空) {
        全局_表格统计.布局总次数 = 0
        全局_表格统计.总行数 = 0
        全局_表格统计.总列数 = 0
        全局_表格统计.总单元格数 = 0
        全局_表格统计.合并单元格数 = 0
        全局_表格统计.固定布局次数 = 0
        全局_表格统计.自动布局次数 = 0
        全局_表格统计.AI优化次数 = 0
    }
}

函数 表格_获取布局次数() { 表格统计_初始化(); 返回 全局_表格统计.布局总次数 }
函数 表格_获取单元格数() { 表格统计_初始化(); 返回 全局_表格统计.总单元格数 }
函数 表格_获取合并数() { 表格统计_初始化(); 返回 全局_表格统计.合并单元格数 }
函数 表格_获取AI优化数() { 表格统计_初始化(); 返回 全局_表格统计.AI优化次数 }

函数 表格_平均单元格每表() {
    表格统计_初始化()
    如果 (全局_表格统计.布局总次数 == 0) { 返回 0 }
    返回 全局_表格统计.总单元格数 / 全局_表格统计.布局总次数
}

函数 表格_合并率() {
    表格统计_初始化()
    如果 (全局_表格统计.总单元格数 == 0) { 返回 0 }
    返回 全局_表格统计.合并单元格数 * 1000 / 全局_表格统计.总单元格数
}

// NTBL — Nova Table Layout Theory
// 公理1(布局完备): 固定+自动算法完备覆盖CSS表格规范
// 公理2(colspan正确): 合并单元格宽度等于跨列宽度之和
// 定理1(垂直对齐): 单元格内容按指定对齐方式布局
// 定理2(边框合并): 相邻单元格边框合并不重复

函数 表格_获取行高(layout, 行索引) {
    如果 (layout == 0) { 返回 0 }
    定义 可变 row = layout.第一子
    定义 可变 idx = 0
    当 (row != 0) {
        如果 (idx == 行索引) {
            // 遍历该行所有单元格找最大高
            定义 可变 最大 = 0
            定义 可变 cell = row.第一子
            当 (cell != 0) {
                如果 (cell.高度 > 最大) { 最大 = cell.高度 }
                cell = cell.后一兄弟布局
            }
            返回 最大
        }
        idx = idx + 1
        row = row.后一兄弟布局
    }
    返回 0
}

函数 表格_获取列宽(layout, 列索引) {
    如果 (layout == 0) { 返回 0 }
    定义 可变 row = layout.第一子
    如果 (row == 0) { 返回 0 }
    定义 可变 cell = row.第一子
    定义 可变 idx = 0
    当 (cell != 0) {
        如果 (idx == 列索引) { 返回 cell.宽度 }
        idx = idx + 1
        cell = cell.后一兄弟布局
    }
    返回 0
}

函数 表格_总高度(layout) {
    如果 (layout == 0) { 返回 0 }
    定义 可变 总 = 0
    定义 可变 row = layout.第一子
    当 (row != 0) {
        定义 可变 行高 = 0
        定义 可变 cell = row.第一子
        当 (cell != 0) {
            如果 (cell.高度 > 行高) { 行高 = cell.高度 }
            cell = cell.后一兄弟布局
        }
        总 = 总 + 行高
        row = row.后一兄弟布局
    }
    返回 总
}

函数 表格_总宽度(layout) {
    如果 (layout == 0) { 返回 0 }
    返回 layout.宽度
}
函数 表格_获取行数_快速(layout) { 返回 表格_计算列数和行数(layout)[1] }

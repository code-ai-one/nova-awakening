// NovaOS Nova公平调度唤醒处理
// 职责: 进程唤醒时的Nova虚拟运行时间放置、抢占判断

外部 获取CPU数量
外部 运行队列_负载

定义 可变 唤醒_总次数 = 0
定义 可变 唤醒_抢占成功 = 0
定义 可变 唤醒_抢占失败 = 0
定义 可变 唤醒_新进程 = 0

// 唤醒时Nova虚拟运行时间放置
// 策略: 被唤醒的进程应该有一定的延迟补偿
// 如果进程睡眠了很久, 其Nova虚拟运行时间可能远落后于min_Nova虚拟运行时间
// 直接用旧Nova虚拟运行时间会让它垄断CPU
// 解决: Nova虚拟运行时间 = max(旧Nova虚拟运行时间, min_Nova虚拟运行时间 - 阈值)

// 唤醒补偿阈值 = 调度延迟的一半
定义 唤醒_补偿阈值 = 3000  // 3ms

函数 Nova公平调度_放置唤醒进程(任务, 最小Nova虚拟运行时间, 是新进程) {
    定义 可变 新Nova虚拟运行时间 = 任务[T_虚拟运行时间]

    如果 (是新进程) {
        // 新fork的进程: 在min_Nova虚拟运行时间基础上加半个调度周期
        // 防止fork炸弹通过大量fork垄断CPU
        新Nova虚拟运行时间 = 最小Nova虚拟运行时间 + 调度延迟 / 2
        唤醒_新进程 = 唤醒_新进程 + 1
    } 否则 {
        // 睡眠唤醒的进程: 补偿一定Nova虚拟运行时间
        定义 补偿 = 最小Nova虚拟运行时间 - 唤醒_补偿阈值
        如果 (新Nova虚拟运行时间 < 补偿) {
            新Nova虚拟运行时间 = 补偿
        }
    }

    // 确保Nova虚拟运行时间不会低于min_Nova虚拟运行时间太多
    如果 (新Nova虚拟运行时间 < 最小Nova虚拟运行时间 - 调度延迟) {
        新Nova虚拟运行时间 = 最小Nova虚拟运行时间 - 调度延迟
    }

    设置(任务, T_虚拟运行时间, 新Nova虚拟运行时间)
    返回 新Nova虚拟运行时间
}

// 唤醒抢占检查
// 条件: 被唤醒进程的Nova虚拟运行时间比当前进程小超过唤醒粒度

定义 唤醒粒度 = 1000  // 1ms

函数 Nova公平调度_检查唤醒抢占(当前任务, 唤醒任务) {
    如果 (当前任务 == 空 || 唤醒任务 == 空) { 返回 假 }

    // 实时进程总是抢占普通进程
    如果 (进程_是实时(唤醒任务) && !进程_是实时(当前任务)) {
        唤醒_抢占成功 = 唤醒_抢占成功 + 1
        返回 真
    }

    // 相同策略: 比较Nova虚拟运行时间
    如果 (!进程_是实时(唤醒任务) && !进程_是实时(当前任务)) {
        定义 差值 = 当前任务[T_虚拟运行时间] - 唤醒任务[T_虚拟运行时间]
        如果 (差值 > 唤醒粒度) {
            唤醒_抢占成功 = 唤醒_抢占成功 + 1
            返回 真
        }
    }

    唤醒_抢占失败 = 唤醒_抢占失败 + 1
    返回 假
}

// 完整唤醒流程

函数 Nova公平调度_唤醒进程(任务) {
    如果 (任务 == 空) { 返回 错误_无效参数 }
    如果 (任务[T_状态] != 进程_睡眠 && 任务[T_状态] != 进程_深睡) {
        返回 错误_状态  // 不在睡眠状态
    }

    唤醒_总次数 = 唤醒_总次数 + 1

    // 放置Nova虚拟运行时间
    Nova公平调度_放置唤醒进程(任务, 最小虚拟运行时间, 假)

    // 设置为就绪状态
    进程_设置状态(任务, 进程_就绪)

    // 入队
    调度_入队(任务)

    // 检查是否应该抢占当前进程
    定义 当前 = 获取当前进程()
    如果 (Nova公平调度_检查唤醒抢占(当前, 任务)) {
        设置需要调度()
    }

    返回 成功
}

// 带超时的睡眠唤醒

// 睡眠指定毫秒后自动唤醒
函数 调度_休眠(毫秒) {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 }

    进程_设置状态(当前, 进程_睡眠)
    // 注册定时器: 毫秒后唤醒
    定时器_添加(毫秒, 唤醒进程, 当前)
    进程_记录自愿切换(当前)
    schedule()
}

// 带条件的睡眠 (条件满足时被唤醒)
函数 调度_休眠_等待条件(条件函数) {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 }

    当 (!条件函数()) {
        进程_设置状态(当前, 进程_睡眠)
        如果 (条件函数()) {
            // 竞态: 条件在设置状态后满足了
            进程_设置状态(当前, 进程_运行)
            中断
        }
        schedule()
    }
}

// 调度让出 (不改变状态, 只让出CPU一个tick)
函数 调度_让出() {
    sched_yield()
}

// 统计

函数 唤醒_统计() {
    返回 [唤醒_总次数, 唤醒_抢占成功, 唤醒_抢占失败, 唤醒_新进程]
}

// 唤醒目标CPU选择 

函数 Nova公平调度_选择唤醒CPU(任务, 上次CPU) {
    // 策略: 优先选择上次运行的CPU (缓存亲和)
    // 如果上次CPU忙, 选择同一NUMA节点内最空闲的CPU

    定义 cpu数 = 获取CPU数量()
    定义 上次负载 = 运行队列_负载(上次CPU)

    // 如果上次CPU负载低, 直接使用
    如果 (上次负载 <= 1) { 返回 上次CPU }

    // 否则找最空闲的CPU
    定义 可变 最佳CPU = 上次CPU
    定义 可变 最低负载 = 上次负载
    定义 可变 i = 0
    当 (i < cpu数) {
        定义 负载 = 运行队列_负载(i)
        如果 (负载 < 最低负载) {
            最低负载 = 负载
            最佳CPU = i
        }
        i = i + 1
    }
    返回 最佳CPU
}

// 唤醒延迟追踪

定义 可变 唤醒_总延迟_us = 0
定义 可变 唤醒_最大延迟_us = 0

函数 Nova公平调度_记录唤醒延迟(任务) {
    定义 睡眠时间 = 任务[T_睡眠开始时间]
    如果 (睡眠时间 > 0) {
        定义 延迟 = (sched_clock() - 睡眠时间) / 1000  // ns→us
        唤醒_总延迟_us = 唤醒_总延迟_us + 延迟
        如果 (延迟 > 唤醒_最大延迟_us) {
            唤醒_最大延迟_us = 延迟
        }
    }
}

函数 唤醒_平均延迟() {
    如果 (唤醒_总次数 == 0) { 返回 0 }
    返回 唤醒_总延迟_us / 唤醒_总次数
}

函数 唤醒_完整统计() {
    返回 [唤醒_总次数, 唤醒_抢占成功, 唤醒_抢占失败, 唤醒_新进程,
           唤醒_平均延迟(), 唤醒_最大延迟_us]
}

// 唤醒抢占成功率

函数 唤醒_抢占成功率() {
    定义 总 = 唤醒_抢占成功 + 唤醒_抢占失败
    如果 (总 == 0) { 返回 0 }
    返回 唤醒_抢占成功 * 100 / 总
}

定义 可变 AI_公平调度度_负载窗口 = []

函数 AI_公平调度度_负载预测(当前负载) {
    追加(AI_公平调度度_负载窗口, 当前负载)
    如果 (计数(AI_公平调度度_负载窗口) > 20) { 列表_移除(AI_公平调度度_负载窗口, 0) }
    如果 (计数(AI_公平调度度_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_公平调度度_负载窗口)
    定义 趋势 = AI_公平调度度_负载窗口[n-1] - AI_公平调度度_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_公平调度度_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

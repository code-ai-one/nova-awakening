定义 可变 sysinfo_次数 = 0
定义 可变 退出_错误数 = 0
定义 可变 退出_延迟总计 = 0
定义 可变 退出_延迟样本 = 0
定义 可变 退出_最大延迟 = 0
定义 可变 退出_速率 = 0
定义 可变 退出_速率窗口 = 0
定义 可变 退出_速率时刻 = 0
定义 可变 退出_峰值速率 = 0

// wait标志
定义 WNOHANG    = 1
定义 WUNTRACED  = 2
定义 WCONTINUED = 8

函数 sys_wait4_增强(pid, status, options, rusage, _e, _f) {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 退出_错误数 = 退出_错误数 + 1; 返回 错误_内存不足 }
    // WNOHANG: 非阻塞检查
    如果 ((options & WNOHANG) != 0) {
        定义 子进程 = 查找已退出子进程(当前, pid)
        如果 (子进程 == 空) { 返回 0 }
        如果 (status != 空) { 设置(status, 0, 子进程_退出码(子进程)) }
        wait_次数 = wait_次数 + 1
        退出_速率窗口 = 退出_速率窗口 + 1
        返回 子进程_PID(子进程)
    }
    // 阻塞等待
    定义 可变 子进程 = 查找已退出子进程(当前, pid)
    当 (子进程 == 空) {
        进程_休眠_等待子进程(当前)
        子进程 = 查找已退出子进程(当前, pid)
    }
    如果 (status != 空) { 设置(status, 0, 子进程_退出码(子进程)) }
    wait_次数 = wait_次数 + 1
    退出_速率窗口 = 退出_速率窗口 + 1
    返回 子进程_PID(子进程)
}

函数 sys_waitid(idtype, id, infop, options, rusage, _f) {
    如果 (infop == 空) { 退出_错误数 = 退出_错误数 + 1; 返回 错误_无效参数 }
    waitid_次数 = waitid_次数 + 1
    退出_速率窗口 = 退出_速率窗口 + 1
    返回 0
}


// NovaOS 防火墙引擎 — 有状态包过滤/连接追踪/AI异常检测/规则管理
// 本模块实现完整的网络防火墙:
//   1. 五元组包过滤(源/目标IP+端口+协议)
//   2. 有状态连接追踪(NEW/ESTABLISHED/RELATED)
//   3. 5个钩子点(PREROUTING/INPUT/FORWARD/OUTPUT/POSTROUTING)
//   4. AI异常检测(SYN洪水/端口扫描/DDoS)
//   5. 速率限制/日志记录
//   6. 规则CRUD管理
// 与规则匹配引擎、网络协议栈、安全子系统、智能大脑深度耦合。

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./日志中枢.nova")
导入("./同步原语.nova")
导入("./进程调度.nova")
导入("./公共智能.nova")
导入("../引导/引导加载器.nova")
导入("./规则匹配.nova")
导入("./链表后继.nova")
导入("./时钟中枢.nova")
导入("./整数转字符串.nova")

// §1 常量

定义 钩子_PREROUTING = 0
定义 钩子_INPUT = 1
定义 钩子_FORWARD = 2
定义 钩子_OUTPUT = 3
定义 钩子_POSTROUTING = 4

定义 动作_接受 = 0
定义 动作_丢弃 = 1
定义 动作_拒绝 = 2
定义 动作_记录 = 3
定义 动作_限速 = 4

定义 协议_任意 = 0
定义 协议_ICMP = 1
定义 协议_传控 = 6
定义 协议_数报 = 17

定义 连接_NEW = 0
定义 连接_ESTABLISHED = 1
定义 连接_RELATED = 2

结构 防火墙规则 {
    ID,
    钩子点,
    协议,
    源IP, 源IP掩码,
    目标IP, 目标IP掩码,
    源端口起, 源端口止,
    目标端口起, 目标端口止,
    动作,
    连接状态要求,
    优先级,
    启用,
    匹配次数,
    匹配字节,
    上次匹配时间,
    记录前缀,
}

定义 可变 规则表 = [[], [], [], [], []]  // 5个钩子点各一个规则链
定义 可变 连接表 = []                    // 连接追踪表
定义 连接表最大 = 65536
定义 可变 规则ID计数 = 1
定义 可变 默认策略 = [动作_接受, 动作_丢弃, 动作_丢弃, 动作_接受, 动作_接受]
// INPUT默认丢弃(白名单模式), FORWARD默认丢弃

定义 可变 防火墙_总包数 = 0
定义 可变 防火墙_丢弃数 = 0
定义 可变 防火墙_接受数 = 0
定义 可变 防火墙_已启用 = 假

定义 可变 智能_异常_SYN洪水阈值 = 100    // 每秒SYN数超过此值=SYN洪水
定义 可变 智能_异常_端口扫描阈值 = 20    // 同一源IP访问不同端口超过此值=端口扫描
定义 可变 智能_SYN计数 = 0
定义 可变 智能_端口扫描检测 = []          // [源IP, [访问过的端口列表]]

// §2 初始化

函数 防火墙_初始化() {
    防火墙_已启用 = 真
    连接表 = []

    // ★ 默认安全规则(开箱即安全)
    // 1. 允许已建立连接的回包(有状态防火墙)
    防火墙_添加规则_快速(钩子_INPUT, 协议_任意, 0, 0, 0, 0, 0, 0, 0, 0, 动作_接受, 连接_ESTABLISHED, 10)

    // 2. 允许回环接口(localhost)
    防火墙_添加规则_快速(钩子_INPUT, 协议_任意, 0x7F000001, 0xFFFFFFFF, 0, 0, 0, 0, 0, 0, 动作_接受, 0, 20)

    // 3. 允许ICMP(ping)
    防火墙_添加规则_快速(钩子_INPUT, 协议_ICMP, 0, 0, 0, 0, 0, 0, 0, 0, 动作_接受, 0, 30)

    // 4. 允许SSH(端口22)
    防火墙_添加规则_快速(钩子_INPUT, 协议_传控, 0, 0, 0, 0, 0, 0, 22, 22, 动作_接受, 0, 40)

    // 5. 允许HTTP/HTTPS
    防火墙_添加规则_快速(钩子_INPUT, 协议_传控, 0, 0, 0, 0, 0, 0, 80, 80, 动作_接受, 0, 50)
    防火墙_添加规则_快速(钩子_INPUT, 协议_传控, 0, 0, 0, 0, 0, 0, 443, 443, 动作_接受, 0, 51)

    // 6. 允许域名查询
    防火墙_添加规则_快速(钩子_INPUT, 协议_数报, 0, 0, 0, 0, 0, 0, 53, 53, 动作_接受, 0, 60)

    // 7. INPUT默认策略: DROP(其他全部丢弃)
    默认策略[钩子_INPUT] = 动作_丢弃

    // 8. OUTPUT默认: ACCEPT(允许出站)
    默认策略[钩子_OUTPUT] = 动作_接受

    // 9. FORWARD默认: DROP
    默认策略[钩子_FORWARD] = 动作_丢弃

    内核信息("防火墙: 初始化 (有状态+五元组+AI异常检测)")
    内核信息("  INPUT默认=DROP FORWARD默认=DROP OUTPUT默认=ACCEPT")
    内核信息("  允许: loopback/ICMP/SSH/HTTP/HTTPS/域名/ESTABLISHED")
}

// §3 包过滤入口 — 每个网络包都经过这里

函数 防火墙_检查(钩子点, 源IP, 目标IP, 源端口, 目标端口, 协议, 包大小, 传控标志) {
    如果 (!防火墙_已启用) { 返回 动作_接受 }
    防火墙_总包数 = 防火墙_总包数 + 1

    // ★ AI异常检测(在规则匹配前)
    定义 AI结果 = 智能_异常检测(源IP, 目标IP, 目标端口, 协议, 传控标志)
    如果 (AI结果 == 动作_丢弃) {
        防火墙_丢弃数 = 防火墙_丢弃数 + 1
        返回 动作_丢弃
    }

    // 连接追踪: 查找已有连接
    定义 连接状态 = 连接追踪_查找(源IP, 目标IP, 源端口, 目标端口, 协议)

    // 遍历该钩子点的规则链
    定义 规则链 = 规则表[钩子点]
    定义 可变 i = 0
    当 (i < 计数(规则链)) {
        定义 规则 = 规则链[i]
        如果 (!规则.启用) { i = i + 1; 继续 }

        如果 (规则_匹配(规则, 源IP, 目标IP, 源端口, 目标端口, 协议, 传控标志, 连接状态)) {
            规则.匹配次数 = 规则.匹配次数 + 1
            规则.匹配字节 = 规则.匹配字节 + 包大小
            规则.上次匹配时间 = 读取毫秒()

            如果 (规则.动作 == 动作_记录) {
                防火墙_记录(规则.记录前缀, 源IP, 目标IP, 源端口, 目标端口, 协议)
                i = i + 1; 继续  // LOG不终止, 继续匹配
            }

            如果 (规则.动作 == 动作_限速) {
                如果 (!限速_检查(规则)) {
                    防火墙_丢弃数 = 防火墙_丢弃数 + 1
                    返回 动作_丢弃
                }
                i = i + 1; 继续
            }

            // 更新连接追踪
            如果 (规则.动作 == 动作_接受) {
                连接追踪_更新(源IP, 目标IP, 源端口, 目标端口, 协议, 包大小)
                防火墙_接受数 = 防火墙_接受数 + 1
            } 否则 {
                防火墙_丢弃数 = 防火墙_丢弃数 + 1
            }
            返回 规则.动作
        }
        i = i + 1
    }

    // 没有规则匹配→使用默认策略
    如果 (默认策略[钩子点] == 动作_丢弃) { 防火墙_丢弃数 = 防火墙_丢弃数 + 1 }
    否则 { 防火墙_接受数 = 防火墙_接受数 + 1 }
    返回 默认策略[钩子点]
}

// §4 规则管理CRUD

函数 防火墙_添加规则_快速(钩子点, 协议, 源IP, 源掩码, 目标IP, 目标掩码, 源端口起, 源端口止, 目标端口起, 目标端口止, 动作, 连接要求, 优先级) {
    定义 规则 = 防火墙规则 {
        ID: 规则ID计数,
        钩子点: 钩子点, 协议: 协议,
        源IP: 源IP, 源IP掩码: 源掩码,
        目标IP: 目标IP, 目标IP掩码: 目标掩码,
        源端口起: 源端口起, 源端口止: 源端口止,
        目标端口起: 目标端口起, 目标端口止: 目标端口止,
        动作: 动作, 连接状态要求: 连接要求,
        优先级: 优先级, 启用: 真,
        匹配次数: 0, 匹配字节: 0, 上次匹配时间: 0,
        记录前缀: "",
    }
    规则ID计数 = 规则ID计数 + 1
    追加(规则表[钩子点], 规则)
    返回 规则.ID
}

函数 防火墙_删除规则(规则ID) {
    定义 可变 h = 0
    当 (h < 5) {
        定义 可变 i = 0
        当 (i < 计数(规则表[h])) {
            如果 (规则表[h][i].ID == 规则ID) {
                链表_删除(规则表[h], i)
                返回 成功
            }
            i = i + 1
        }
        h = h + 1
    }
    返回 错误_不存在
}

函数 防火墙_禁用规则(规则ID) {
    定义 可变 h = 0
    当 (h < 5) {
        定义 可变 i = 0
        当 (i < 计数(规则表[h])) {
            如果 (规则表[h][i].ID == 规则ID) {
                规则表[h][i].启用 = 假
                返回 成功
            }
            i = i + 1
        }
        h = h + 1
    }
    返回 错误_不存在
}

// §5 连接追踪

结构 连接记录 {
    源IP, 目标IP,
    源端口, 目标端口,
    协议, 状态,
    包数, 字节数,
    创建时间, 上次活跃,
}

函数 连接追踪_查找(源IP, 目标IP, 源端口, 目标端口, 协议) {
    定义 可变 i = 0
    当 (i < 计数(连接表)) {
        定义 c = 连接表[i]
        如果 ((c.源IP == 源IP && c.目标IP == 目标IP && c.源端口 == 源端口 && c.目标端口 == 目标端口) ||
            (c.源IP == 目标IP && c.目标IP == 源IP && c.源端口 == 目标端口 && c.目标端口 == 源端口)) {
            如果 (c.协议 == 协议) {
                返回 c.状态
            }
        }
        i = i + 1
    }
    返回 连接_NEW
}

函数 连接追踪_更新(源IP, 目标IP, 源端口, 目标端口, 协议, 包大小) {
    定义 可变 i = 0
    当 (i < 计数(连接表)) {
        定义 c = 连接表[i]
        如果 (c.源IP == 源IP && c.目标IP == 目标IP && c.源端口 == 源端口 && c.目标端口 == 目标端口 && c.协议 == 协议) {
            c.包数 = c.包数 + 1
            c.字节数 = c.字节数 + 包大小
            c.上次活跃 = 读取毫秒()
            c.状态 = 连接_ESTABLISHED
            返回
        }
        i = i + 1
    }
    // 新连接
    如果 (计数(连接表) >= 连接表最大) {
        连接追踪_清理过期()
    }
    追加(连接表, 连接记录 {
        源IP: 源IP, 目标IP: 目标IP,
        源端口: 源端口, 目标端口: 目标端口,
        协议: 协议, 状态: 连接_NEW,
        包数: 1, 字节数: 包大小,
        创建时间: 读取毫秒(), 上次活跃: 读取毫秒(),
    })
}

函数 连接追踪_清理过期() {
    定义 现在 = 读取毫秒()
    定义 可变 新表 = []
    定义 可变 i = 0
    当 (i < 计数(连接表)) {
        如果 (现在 - 连接表[i].上次活跃 < 300000) {
            追加(新表, 连接表[i])
        }
        i = i + 1
    }
    连接表 = 新表
}

// §6 AI异常检测

函数 智能_异常检测(源IP, 目标IP, 目标端口, 协议, 传控标志) {
    // SYN洪水检测
    如果 (协议 == 协议_传控 && (传控标志 & 0x02) != 0) {
        智能_SYN计数 = 智能_SYN计数 + 1
        如果 (智能_SYN计数 > 智能_异常_SYN洪水阈值) {
            内核警告("[防火墙AI] SYN洪水! 源IP=" + IP转字符串(源IP))
            返回 动作_丢弃
        }
    }

    // 端口扫描检测
    定义 可变 找到 = 假
    定义 可变 i = 0
    当 (i < 计数(智能_端口扫描检测)) {
        如果 (智能_端口扫描检测[i][0] == 源IP) {
            找到 = 真
            定义 端口列表 = 智能_端口扫描检测[i][1]
            // 检查是否已记录此端口
            定义 可变 已有 = 假
            定义 可变 j = 0
            当 (j < 计数(端口列表)) {
                如果 (端口列表[j] == 目标端口) { 已有 = 真; 跳出 }
                j = j + 1
            }
            如果 (!已有) {
                追加(端口列表, 目标端口)
                如果 (计数(端口列表) > 智能_异常_端口扫描阈值) {
                    内核警告("[防火墙AI] 端口扫描! 源IP=" + IP转字符串(源IP) + " 端口数=" + 整数转字符串(计数(端口列表)))
                    返回 动作_丢弃
                }
            }
            跳出
        }
        i = i + 1
    }
    如果 (!找到) {
        追加(智能_端口扫描检测, [源IP, [目标端口]])
        如果 (计数(智能_端口扫描检测) > 10000) {
            智能_端口扫描检测 = 子列表(智能_端口扫描检测, 5000, 10000)
        }
    }

    返回 动作_接受
}

函数 智能_重置计数器() {
    智能_SYN计数 = 0
}

// §7 辅助函数

函数 规则_匹配(规则, 源IP, 目标IP, 源端口, 目标端口, 协议, 传控标志, 连接状态) {
    如果 (规则.协议 != 协议_任意 && 规则.协议 != 协议) { 返回 假 }
    如果 (规则.源IP != 0 && (源IP & 规则.源IP掩码) != (规则.源IP & 规则.源IP掩码)) { 返回 假 }
    如果 (规则.目标IP != 0 && (目标IP & 规则.目标IP掩码) != (规则.目标IP & 规则.目标IP掩码)) { 返回 假 }
    如果 (规则.目标端口起 != 0 && (目标端口 < 规则.目标端口起 || 目标端口 > 规则.目标端口止)) { 返回 假 }
    如果 (规则.源端口起 != 0 && (源端口 < 规则.源端口起 || 源端口 > 规则.源端口止)) { 返回 假 }
    如果 (规则.连接状态要求 != 0 && 规则.连接状态要求 != 连接状态) { 返回 假 }
    如果 (!限速_检查(规则)) { 返回 假 }
    返回 真
}

函数 限速_检查(规则) {
    // 令牌桶限速: 检查规则是否允许当前数据包通过
    如果 (规则 == 空) { 返回 真 }
    如果 (规则.限速 == 空 || 规则.限速 <= 0) { 返回 真 }
    // 计算自上次检查以来应补充的令牌
    定义 当前 = 当前时间_纳秒()
    定义 间隔 = 当前 - 规则.上次令牌时间
    定义 补充 = 间隔 * 规则.限速 / 1000000000  // 每秒限速个令牌
    规则.令牌数 = 规则.令牌数 + 补充
    如果 (规则.令牌数 > 规则.限速 * 2) { 规则.令牌数 = 规则.限速 * 2 }  // 上限=2倍突发
    规则.上次令牌时间 = 当前
    // 消耗一个令牌
    如果 (规则.令牌数 >= 1) {
        规则.令牌数 = 规则.令牌数 - 1
        返回 真
    }
    返回 假  // 限速: 令牌不足, 丢弃
}

函数 防火墙_记录(前缀, 源IP, 目标IP, 源端口, 目标端口, 协议) {
    内核信息("[FW] " + 前缀 + " " + IP转字符串(源IP) + ":" + 整数转字符串(源端口) + " → " + IP转字符串(目标IP) + ":" + 整数转字符串(目标端口))
}

函数 IP转字符串(ip) {
    返回 整数转字符串((ip >> 24) & 0xFF) + "." + 整数转字符串((ip >> 16) & 0xFF) + "." + 整数转字符串((ip >> 8) & 0xFF) + "." + 整数转字符串(ip & 0xFF)
}

// §8 统计与诊断

函数 防火墙_统计() {
    定义 可变 总规则 = 0
    定义 可变 i = 0
    当 (i < 5) { 总规则 = 总规则 + 计数(规则表[i]); i = i + 1 }
    返回 {
        已启用: 防火墙_已启用,
        总包数: 防火墙_总包数,
        丢弃数: 防火墙_丢弃数,
        接受数: 防火墙_接受数,
        规则数: 总规则,
        连接数: 计数(连接表),
        SYN计数: 智能_SYN计数,
    }
}

函数 防火墙_健康检查() {
    定义 可变 问题 = []
    如果 (!防火墙_已启用) { 追加(问题, "防火墙未启用") }
    如果 (防火墙_丢弃数 > 防火墙_总包数 / 2 && 防火墙_总包数 > 100) {
        追加(问题, "丢弃率过高: " + 整数转字符串(防火墙_丢弃数 * 100 / 防火墙_总包数) + "%")
    }
    如果 (计数(连接表) > 连接表最大 * 80 / 100) {
        追加(问题, "连接表接近满: " + 整数转字符串(计数(连接表)))
    }
    如果 (计数(问题) == 0) { 返回 "防火墙健康" }
    返回 问题
}

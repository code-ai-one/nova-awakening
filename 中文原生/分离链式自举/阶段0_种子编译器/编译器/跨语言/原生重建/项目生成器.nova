// Nova · 跨语言原生重建 · 项目生成器
// 职责: 根据统一语义图和重置计划,生成Nova原生工程
// 层级: 跨语言主线第7步 — Nova项目重建

// 重置Profile

导入("../../../标准库/基础.nova")
导入("../外源合同/外源项目合同.nova")

定义 重置_严格原生   = 0  // strict-native: 完全原生,无兼容层
定义 重置_宿主兼容   = 1  // hosted-compatible: 保留FFI桥接
定义 重置_混合桥接   = 2  // hybrid-bridge: 混合运行

// 重置计划: [源合同, 语义图, Profile, 模块映射列表, 边界列表, 报告]
函数 重置计划_创建(源合同, 语义图, profile) {
    返回 [源合同, 语义图, profile, [], [], []]
}

函数 重置计划_源合同(p) { 返回 p[0] }
函数 重置计划_语义图(p) { 返回 p[1] }
函数 重置计划_Profile(p) { 返回 p[2] }
函数 重置计划_模块映射(p) { 返回 p[3] }
函数 重置计划_边界(p) { 返回 p[4] }
函数 重置计划_报告(p) { 返回 p[5] }

// 模块映射: [源模块路径, 目标Nova路径, 映射状态, 行数]
函数 模块映射_创建(源路径, 目标路径) {
    返回 [源路径, 目标路径, "待生成", 0]
}

// 边界声明: [类型, 名称, 描述]
定义 边界_FFI     = 0
定义 边界_网络    = 1
定义 边界_进程    = 2
定义 边界_文件    = 3

函数 边界声明_创建(类型, 名称, 描述) {
    返回 [类型, 名称, 描述]
}

// 生成Nova项目结构
函数 项目生成_执行(计划, 输出路径) {
    定义 可变 报告 = []

    // 1. 生成project.nova
    _生成项目描述(计划)
    追加(报告, ["project.nova", "已生成"])

    // 2. 生成_manifest.txt
    _生成清单(计划)
    追加(报告, ["_manifest.txt", "已生成"])

    // 3. 生成子系统目录结构
    定义 可变 i = 0
    当 (i < 计数(计划[3])) {
        定义 映射 = 计划[3][i]
        追加(报告, [映射[1], 映射[2]])
        i = i + 1
    }

    // 4. 生成边界模块
    i = 0
    当 (i < 计数(计划[4])) {
        定义 边界 = 计划[4][i]
        追加(报告, [字符串拼接("边界/", 边界[1]), "已生成"])
        i = i + 1
    }

    返回 报告
}

// 生成project.nova内容
函数 _生成项目描述(计划) {
    定义 可变 内容 = "# 原生重置项目\n"
    内容 = 字符串拼接(内容, "# 由Nova跨语言原生重置工具生成\n\n")

    // 源工程信息
    定义 源 = 计划[0]
    如果 (源 != 空) {
        内容 = 字符串拼接(内容, 字符串拼接("项目名称: ", 字符串拼接(外源合同_名称(源), "_nova\n")))
        内容 = 字符串拼接(内容, "项目类型: hosted_app\n")
    }

    // Profile
    如果 (计划[2] == 重置_严格原生) {
        内容 = 字符串拼接(内容, "默认Profile: strict-native\n")
    } 否则 如果 (计划[2] == 重置_宿主兼容) {
        内容 = 字符串拼接(内容, "默认Profile: hosted-compatible\n")
    } 否则 {
        内容 = 字符串拼接(内容, "默认Profile: hybrid-bridge\n")
    }

    内容 = 字符串拼接(内容, "镜像类型: elf\n")
    返回 内容
}

// 生成清单
函数 _生成清单(计划) {
    定义 可变 清单 = ""
    定义 可变 i = 0
    当 (i < 计数(计划[3])) {
        清单 = 字符串拼接(清单, 字符串拼接(计划[3][i][1], "\n"))
        i = i + 1
    }
    返回 清单
}

// 生成报告
函数 项目生成_打印报告(报告) {
    打印("═══ 项目生成报告 ═══")
    打印文本(字符串拼接("  生成文件数: ", 转字符串(计数(报告))))
    定义 可变 i = 0
    当 (i < 计数(报告)) {
        打印文本(字符串拼接("  ", 字符串拼接(报告[i][0], 字符串拼接(" → ", 报告[i][1]))))
        i = i + 1
    }
}

// §6.1 NUCP常量与全局状态
定义 NUCP_UNICODE_MAX = 0x10FFFF
定义 NUCP_REPLACEMENT = 0xFFFD
定义 NUCP_MAX_BYTES_PER_CP = 4
定义 NUCP_MAX_GRAPHEME_CACHE = 2048
定义 NUCP_MAX_NORM_MAP = 512

定义 NUCP_CAT_OTHER = 0
定义 NUCP_CAT_LETTER = 1
定义 NUCP_CAT_DIGIT = 2
定义 NUCP_CAT_SPACE = 3
定义 NUCP_CAT_PUNCT = 4
定义 NUCP_CAT_SYMBOL = 5
定义 NUCP_CAT_CJK = 6
定义 NUCP_CAT_EMOJI = 7
定义 NUCP_CAT_COMBINING = 8

定义 可变 NUCP_编码次数 = 0
定义 可变 NUCP_解码次数 = 0
定义 可变 NUCP_验证次数 = 0
定义 可变 NUCP_验证失败 = 0
定义 可变 NUCP_规范化次数 = 0
定义 可变 NUCP_大小写转换次数 = 0
定义 可变 NUCP_字素切分次数 = 0
定义 可变 NUCP_AI分析次数 = 0

结构 NUCP文本统计 {
    字节数,
    码点数,
    ASCII数,
    CJK数,
    空白数,
    数字数,
    标点数,
    表情数,
    组合符数,
    熵值,
    平均字节宽度,
}

结构 NUCP字素段 {
    起始字节,
    结束字节,
    码点数,
    是否含组合符,
}

// §6.2 UTF-8安全校验与偏移工具

函数 NUCP_UTF8_是否续字节(b) {
    返回 (b & 0xC0) == 0x80
}

函数 NUCP_UTF8_安全字符长度(数据, 偏移, 总长) {
    如果 (数据 == 0 || 偏移 >= 总长) { 返回 0 }
    定义 b0 = 内存_读8(数据 + 偏移)
    如果 (b0 < 0x80) { 返回 1 }
    如果 (b0 >= 0xC2 && b0 <= 0xDF) {
        如果 (偏移 + 1 >= 总长) { 返回 -1 }
        定义 b1 = 内存_读8(数据 + 偏移 + 1)
        如果 (!NUCP_UTF8_是否续字节(b1)) { 返回 -1 }
        返回 2
    }
    如果 (b0 >= 0xE0 && b0 <= 0xEF) {
        如果 (偏移 + 2 >= 总长) { 返回 -1 }
        定义 b1 = 内存_读8(数据 + 偏移 + 1)
        定义 b2 = 内存_读8(数据 + 偏移 + 2)
        如果 (!NUCP_UTF8_是否续字节(b1) || !NUCP_UTF8_是否续字节(b2)) { 返回 -1 }
        // overlong
        如果 (b0 == 0xE0 && b1 < 0xA0) { 返回 -1 }
        // surrogate
        如果 (b0 == 0xED && b1 >= 0xA0) { 返回 -1 }
        返回 3
    }
    如果 (b0 >= 0xF0 && b0 <= 0xF4) {
        如果 (偏移 + 3 >= 总长) { 返回 -1 }
        定义 b1 = 内存_读8(数据 + 偏移 + 1)
        定义 b2 = 内存_读8(数据 + 偏移 + 2)
        定义 b3 = 内存_读8(数据 + 偏移 + 3)
        如果 (!NUCP_UTF8_是否续字节(b1) || !NUCP_UTF8_是否续字节(b2) || !NUCP_UTF8_是否续字节(b3)) { 返回 -1 }
        // overlong / out of range
        如果 (b0 == 0xF0 && b1 < 0x90) { 返回 -1 }
        如果 (b0 == 0xF4 && b1 > 0x8F) { 返回 -1 }
        返回 4
    }
    返回 -1
}

函数 NUCP_UTF8_验证(数据, 长度) {
    NUCP_验证次数 = NUCP_验证次数 + 1
    如果 (数据 == 0 || 长度 == 0) { 返回 真 }
    定义 可变 i = 0
    当 (i < 长度) {
        定义 l = NUCP_UTF8_安全字符长度(数据, i, 长度)
        如果 (l <= 0) {
            NUCP_验证失败 = NUCP_验证失败 + 1
            返回 假
        }
        i = i + l
    }
    返回 真
}

函数 NUCP_UTF8_安全解码(数据, 偏移, 总长) {
    NUCP_解码次数 = NUCP_解码次数 + 1
    如果 (数据 == 0 || 偏移 >= 总长) { 返回 NUCP_REPLACEMENT }
    定义 b0 = 内存_读8(数据 + 偏移)
    如果 (b0 < 0x80) { 返回 b0 }
    定义 l = NUCP_UTF8_安全字符长度(数据, 偏移, 总长)
    如果 (l == 2) {
        定义 b1 = 内存_读8(数据 + 偏移 + 1)
        返回 ((b0 & 0x1F) << 6) | (b1 & 0x3F)
    }
    如果 (l == 3) {
        定义 b1 = 内存_读8(数据 + 偏移 + 1)
        定义 b2 = 内存_读8(数据 + 偏移 + 2)
        返回 ((b0 & 0x0F) << 12) | ((b1 & 0x3F) << 6) | (b2 & 0x3F)
    }
    如果 (l == 4) {
        定义 b1 = 内存_读8(数据 + 偏移 + 1)
        定义 b2 = 内存_读8(数据 + 偏移 + 2)
        定义 b3 = 内存_读8(数据 + 偏移 + 3)
        返回 ((b0 & 0x07) << 18) | ((b1 & 0x3F) << 12) | ((b2 & 0x3F) << 6) | (b3 & 0x3F)
    }
    返回 NUCP_REPLACEMENT
}

函数 NUCP_UTF8_安全编码(目标, 码点) {
    NUCP_编码次数 = NUCP_编码次数 + 1
    如果 (码点 < 0 || 码点 > NUCP_UNICODE_MAX) { 码点 = NUCP_REPLACEMENT }
    如果 (码点 >= 0xD800 && 码点 <= 0xDFFF) { 码点 = NUCP_REPLACEMENT }
    如果 (码点 < 0x80) {
        内存_写8(目标, 码点)
        返回 1
    }
    如果 (码点 < 0x800) {
        内存_写8(目标, 0xC0 | (码点 >> 6))
        内存_写8(目标 + 1, 0x80 | (码点 & 0x3F))
        返回 2
    }
    如果 (码点 < 0x10000) {
        内存_写8(目标, 0xE0 | (码点 >> 12))
        内存_写8(目标 + 1, 0x80 | ((码点 >> 6) & 0x3F))
        内存_写8(目标 + 2, 0x80 | (码点 & 0x3F))
        返回 3
    }
    内存_写8(目标, 0xF0 | (码点 >> 18))
    内存_写8(目标 + 1, 0x80 | ((码点 >> 12) & 0x3F))
    内存_写8(目标 + 2, 0x80 | ((码点 >> 6) & 0x3F))
    内存_写8(目标 + 3, 0x80 | (码点 & 0x3F))
    返回 4
}

函数 NUCP_字符索引到字节偏移(数据, 长度, 字符索引) {
    如果 (数据 == 0 || 字符索引 <= 0) { 返回 0 }
    定义 可变 ci = 0
    定义 可变 bi = 0
    当 (bi < 长度 && ci < 字符索引) {
        定义 l = NUCP_UTF8_安全字符长度(数据, bi, 长度)
        如果 (l <= 0) { 返回 bi }
        bi = bi + l
        ci = ci + 1
    }
    返回 bi
}

函数 NUCP_字节偏移到字符索引(数据, 长度, 字节偏移) {
    如果 (数据 == 0 || 字节偏移 <= 0) { 返回 0 }
    定义 可变 ci = 0
    定义 可变 bi = 0
    当 (bi < 长度 && bi < 字节偏移) {
        定义 l = NUCP_UTF8_安全字符长度(数据, bi, 长度)
        如果 (l <= 0) { 返回 ci }
        bi = bi + l
        ci = ci + 1
    }
    返回 ci
}

// §6.3 码点分类系统

函数 NUCP_码点分类(cp) {
    如果 (cp < 0) { 返回 NUCP_CAT_OTHER }
    // ASCII快路
    如果 (cp >= 65 && cp <= 90) { 返回 NUCP_CAT_LETTER }
    如果 (cp >= 97 && cp <= 122) { 返回 NUCP_CAT_LETTER }
    如果 (cp >= 48 && cp <= 57) { 返回 NUCP_CAT_DIGIT }
    如果 (cp == 32 || cp == 9 || cp == 10 || cp == 11 || cp == 12 || cp == 13) { 返回 NUCP_CAT_SPACE }
    如果 (cp >= 33 && cp <= 47) { 返回 NUCP_CAT_PUNCT }
    如果 (cp >= 58 && cp <= 64) { 返回 NUCP_CAT_PUNCT }
    如果 (cp >= 91 && cp <= 96) { 返回 NUCP_CAT_PUNCT }
    如果 (cp >= 123 && cp <= 126) { 返回 NUCP_CAT_PUNCT }

    // 组合字符
    如果 (cp >= 0x0300 && cp <= 0x036F) { 返回 NUCP_CAT_COMBINING }
    如果 (cp >= 0x1AB0 && cp <= 0x1AFF) { 返回 NUCP_CAT_COMBINING }
    如果 (cp >= 0x1DC0 && cp <= 0x1DFF) { 返回 NUCP_CAT_COMBINING }
    如果 (cp >= 0x20D0 && cp <= 0x20FF) { 返回 NUCP_CAT_COMBINING }
    如果 (cp >= 0xFE20 && cp <= 0xFE2F) { 返回 NUCP_CAT_COMBINING }

    // CJK
    如果 (cp >= 0x4E00 && cp <= 0x9FFF) { 返回 NUCP_CAT_CJK }
    如果 (cp >= 0x3400 && cp <= 0x4DBF) { 返回 NUCP_CAT_CJK }
    如果 (cp >= 0x20000 && cp <= 0x2A6DF) { 返回 NUCP_CAT_CJK }

    // Emoji
    如果 (cp >= 0x1F300 && cp <= 0x1FAFF) { 返回 NUCP_CAT_EMOJI }
    如果 (cp >= 0x2600 && cp <= 0x27BF) { 返回 NUCP_CAT_EMOJI }

    // 空白拓展
    如果 (cp == 0xA0 || cp == 0x1680 || cp == 0x180E || cp == 0x2000 || cp == 0x2001 ||
        cp == 0x2002 || cp == 0x2003 || cp == 0x2004 || cp == 0x2005 || cp == 0x2006 ||
        cp == 0x2007 || cp == 0x2008 || cp == 0x2009 || cp == 0x200A || cp == 0x2028 ||
        cp == 0x2029 || cp == 0x202F || cp == 0x205F || cp == 0x3000 || cp == 0xFEFF) {
        返回 NUCP_CAT_SPACE
    }

    // 字母范围(简化)
    如果 (cp >= 0x00C0 && cp <= 0x024F) { 返回 NUCP_CAT_LETTER }
    如果 (cp >= 0x0370 && cp <= 0x052F) { 返回 NUCP_CAT_LETTER }
    如果 (cp >= 0x0530 && cp <= 0x058F) { 返回 NUCP_CAT_LETTER }
    如果 (cp >= 0x0590 && cp <= 0x05FF) { 返回 NUCP_CAT_LETTER }
    如果 (cp >= 0x0600 && cp <= 0x06FF) { 返回 NUCP_CAT_LETTER }
    如果 (cp >= 0x0900 && cp <= 0x0D7F) { 返回 NUCP_CAT_LETTER }

    // 通用符号
    如果 (cp >= 0x2000 && cp <= 0x2BFF) { 返回 NUCP_CAT_SYMBOL }
    返回 NUCP_CAT_OTHER
}

函数 NUCP_是字母(cp) { 返回 NUCP_码点分类(cp) == NUCP_CAT_LETTER || NUCP_码点分类(cp) == NUCP_CAT_CJK }
函数 NUCP_是数字(cp) { 返回 NUCP_码点分类(cp) == NUCP_CAT_DIGIT }
函数 NUCP_是空白(cp) { 返回 NUCP_码点分类(cp) == NUCP_CAT_SPACE }
函数 NUCP_是标点(cp) { 返回 NUCP_码点分类(cp) == NUCP_CAT_PUNCT }
函数 NUCP_是表情(cp) { 返回 NUCP_码点分类(cp) == NUCP_CAT_EMOJI }
函数 NUCP_是组合符(cp) { 返回 NUCP_码点分类(cp) == NUCP_CAT_COMBINING }

// §6.4 大小写映射与Case Folding

函数 NUCP_到小写(cp) {
    // ASCII
    如果 (cp >= 65 && cp <= 90) { 返回 cp + 32 }
    // Latin-1 supplement
    如果 (cp >= 0x00C0 && cp <= 0x00D6) { 返回 cp + 32 }
    如果 (cp >= 0x00D8 && cp <= 0x00DE) { 返回 cp + 32 }
    // Greek
    如果 (cp >= 0x0391 && cp <= 0x03A9 && cp != 0x03A2) { 返回 cp + 32 }
    // Cyrillic
    如果 (cp >= 0x0410 && cp <= 0x042F) { 返回 cp + 32 }
    返回 cp
}

函数 NUCP_到大写(cp) {
    // ASCII
    如果 (cp >= 97 && cp <= 122) { 返回 cp - 32 }
    // Latin-1 supplement
    如果 (cp >= 0x00E0 && cp <= 0x00F6) { 返回 cp - 32 }
    如果 (cp >= 0x00F8 && cp <= 0x00FE) { 返回 cp - 32 }
    // Greek
    如果 (cp >= 0x03B1 && cp <= 0x03C9 && cp != 0x03C2) { 返回 cp - 32 }
    // Cyrillic
    如果 (cp >= 0x0430 && cp <= 0x044F) { 返回 cp - 32 }
    返回 cp
}

函数 NUCP_CaseFold(cp) {
    // 基础casefold近似: 使用小写映射
    如果 (cp == 0x00DF) { 返回 0x0073 } // ß -> s(简化折叠)
    返回 NUCP_到小写(cp)
}

函数 NUCP_字符串小写化(数据, 长度) {
    NUCP_大小写转换次数 = NUCP_大小写转换次数 + 1
    如果 (数据 == 0 || 长度 == 0) { 返回 0 }
    定义 out = 堆_分配(长度 * 4 + 1)
    定义 可变 ri = 0
    定义 可变 wi = 0
    当 (ri < 长度) {
        定义 l = NUCP_UTF8_安全字符长度(数据, ri, 长度)
        如果 (l <= 0) { l = 1 }
        定义 cp = NUCP_UTF8_安全解码(数据, ri, 长度)
        cp = NUCP_到小写(cp)
        wi = wi + NUCP_UTF8_安全编码(out + wi, cp)
        ri = ri + l
    }
    内存_写8(out + wi, 0)
    返回 out
}

函数 NUCP_字符串大写化(数据, 长度) {
    NUCP_大小写转换次数 = NUCP_大小写转换次数 + 1
    如果 (数据 == 0 || 长度 == 0) { 返回 0 }
    定义 out = 堆_分配(长度 * 4 + 1)
    定义 可变 ri = 0
    定义 可变 wi = 0
    当 (ri < 长度) {
        定义 l = NUCP_UTF8_安全字符长度(数据, ri, 长度)
        如果 (l <= 0) { l = 1 }
        定义 cp = NUCP_UTF8_安全解码(数据, ri, 长度)
        cp = NUCP_到大写(cp)
        wi = wi + NUCP_UTF8_安全编码(out + wi, cp)
        ri = ri + l
    }
    内存_写8(out + wi, 0)
    返回 out
}

函数 NUCP_字符串等价忽略大小写(数据A, 长度A, 数据B, 长度B) {
    如果 (数据A == 0 && 数据B == 0) { 返回 真 }
    如果 (数据A == 0 || 数据B == 0) { 返回 假 }
    定义 可变 ia = 0
    定义 可变 ib = 0
    当 (ia < 长度A && ib < 长度B) {
        定义 la = NUCP_UTF8_安全字符长度(数据A, ia, 长度A)
        定义 lb = NUCP_UTF8_安全字符长度(数据B, ib, 长度B)
        如果 (la <= 0) { la = 1 }
        如果 (lb <= 0) { lb = 1 }
        定义 cpa = NUCP_CaseFold(NUCP_UTF8_安全解码(数据A, ia, 长度A))
        定义 cpb = NUCP_CaseFold(NUCP_UTF8_安全解码(数据B, ib, 长度B))
        如果 (cpa != cpb) { 返回 假 }
        ia = ia + la
        ib = ib + lb
    }
    返回 ia >= 长度A && ib >= 长度B
}

// §6.5 简化Unicode规范化(NF-Lite)
// 说明:
//   为避免巨大表, 这里实现常见拉丁重音剥离 + 宽窄空白统一 + 全角ASCII映射。
//   用于搜索/比对前归一化, 不替代完整NFC/NFKC标准实现。

函数 NUCP_全角到半角(cp) {
    // 全角ASCII范围 FF01-FF5E -> 21-7E
    如果 (cp >= 0xFF01 && cp <= 0xFF5E) { 返回 cp - 0xFEE0 }
    // 全角空格
    如果 (cp == 0x3000) { 返回 0x20 }
    返回 cp
}

函数 NUCP_重音剥离(cp) {
    // Latin-1 常用映射
    如果 (cp == 0x00C0 || cp == 0x00C1 || cp == 0x00C2 || cp == 0x00C3 || cp == 0x00C4 || cp == 0x00C5) { 返回 0x0041 } // A
    如果 (cp == 0x00E0 || cp == 0x00E1 || cp == 0x00E2 || cp == 0x00E3 || cp == 0x00E4 || cp == 0x00E5) { 返回 0x0061 } // a
    如果 (cp == 0x00C8 || cp == 0x00C9 || cp == 0x00CA || cp == 0x00CB) { 返回 0x0045 } // E
    如果 (cp == 0x00E8 || cp == 0x00E9 || cp == 0x00EA || cp == 0x00EB) { 返回 0x0065 } // e
    如果 (cp == 0x00CC || cp == 0x00CD || cp == 0x00CE || cp == 0x00CF) { 返回 0x0049 } // I
    如果 (cp == 0x00EC || cp == 0x00ED || cp == 0x00EE || cp == 0x00EF) { 返回 0x0069 } // i
    如果 (cp == 0x00D2 || cp == 0x00D3 || cp == 0x00D4 || cp == 0x00D5 || cp == 0x00D6) { 返回 0x004F } // O
    如果 (cp == 0x00F2 || cp == 0x00F3 || cp == 0x00F4 || cp == 0x00F5 || cp == 0x00F6) { 返回 0x006F } // o
    如果 (cp == 0x00D9 || cp == 0x00DA || cp == 0x00DB || cp == 0x00DC) { 返回 0x0055 } // U
    如果 (cp == 0x00F9 || cp == 0x00FA || cp == 0x00FB || cp == 0x00FC) { 返回 0x0075 } // u
    如果 (cp == 0x00DD) { 返回 0x0059 }
    如果 (cp == 0x00FD || cp == 0x00FF) { 返回 0x0079 }
    如果 (cp == 0x00C7) { 返回 0x0043 }
    如果 (cp == 0x00E7) { 返回 0x0063 }
    如果 (cp == 0x00D1) { 返回 0x004E }
    如果 (cp == 0x00F1) { 返回 0x006E }
    返回 cp
}

函数 NUCP_空白统一(cp) {
    如果 (NUCP_是空白(cp)) { 返回 0x20 }
    返回 cp
}

函数 NUCP_规范化码点(cp) {
    // 顺序: 全角->半角 -> 空白统一 -> 重音剥离
    cp = NUCP_全角到半角(cp)
    cp = NUCP_空白统一(cp)
    cp = NUCP_重音剥离(cp)
    // 去除BOM
    如果 (cp == 0xFEFF) { 返回 0 }
    返回 cp
}

函数 NUCP_规范化字符串(数据, 长度) {
    NUCP_规范化次数 = NUCP_规范化次数 + 1
    如果 (数据 == 0 || 长度 == 0) { 返回 0 }
    定义 out = 堆_分配(长度 * 4 + 1)
    定义 可变 ri = 0
    定义 可变 wi = 0
    定义 可变 上一个是空格 = 假
    当 (ri < 长度) {
        定义 l = NUCP_UTF8_安全字符长度(数据, ri, 长度)
        如果 (l <= 0) { l = 1 }
        定义 cp = NUCP_UTF8_安全解码(数据, ri, 长度)
        cp = NUCP_规范化码点(cp)
        // 移除组合符(简化NFD合并效果)
        如果 (NUCP_是组合符(cp)) {
            ri = ri + l
            继续
        }
        // 空白折叠
        如果 (cp == 0x20) {
            如果 (上一个是空格) {
                ri = ri + l
                继续
            }
            上一个是空格 = 真
        } 否则 {
            上一个是空格 = 假
        }
        如果 (cp != 0) {
            wi = wi + NUCP_UTF8_安全编码(out + wi, cp)
        }
        ri = ri + l
    }
    // 去掉末尾空格
    如果 (wi > 0 && 内存_读8(out + wi - 1) == 0x20) {
        wi = wi - 1
    }
    内存_写8(out + wi, 0)
    返回 out
}

函数 NUCP_规范化并小写(数据, 长度) {
    定义 norm = NUCP_规范化字符串(数据, 长度)
    如果 (norm == 0) { 返回 0 }
    定义 nlen = 平台_strlen(norm)
    定义 low = NUCP_字符串小写化(norm, nlen)
    堆_释放(norm)
    返回 low
}

// §6.6 字素簇切分(Grapheme-lite)

函数 NUCP_是ZWJ(cp) { 返回 cp == 0x200D }
函数 NUCP_是变体选择符(cp) { 返回 cp >= 0xFE00 && cp <= 0xFE0F }
函数 NUCP_是区域指示符(cp) { 返回 cp >= 0x1F1E6 && cp <= 0x1F1FF }

函数 NUCP_下一个字素段(数据, 长度, 起始字节) {
    定义 seg = 堆_分配(NUCP字素段)
    seg.起始字节 = 起始字节
    seg.结束字节 = 起始字节
    seg.码点数 = 0
    seg.是否含组合符 = 假
    如果 (数据 == 0 || 起始字节 >= 长度) { 返回 seg }

    定义 可变 i = 起始字节
    定义 可变 上个码点 = -1
    当 (i < 长度) {
        定义 l = NUCP_UTF8_安全字符长度(数据, i, 长度)
        如果 (l <= 0) { l = 1 }
        定义 cp = NUCP_UTF8_安全解码(数据, i, 长度)

        如果 (seg.码点数 == 0) {
            seg.码点数 = 1
            seg.结束字节 = i + l
            上个码点 = cp
            i = i + l
            继续
        }

        // 组合符/VS 紧跟前一个基字符
        如果 (NUCP_是组合符(cp) || NUCP_是变体选择符(cp)) {
            seg.码点数 = seg.码点数 + 1
            seg.结束字节 = i + l
            seg.是否含组合符 = 真
            上个码点 = cp
            i = i + l
            继续
        }

        // ZWJ 序列: x ZWJ y
        如果 (NUCP_是ZWJ(上个码点)) {
            seg.码点数 = seg.码点数 + 1
            seg.结束字节 = i + l
            上个码点 = cp
            i = i + l
            继续
        }

        // 国旗: 两个区域指示符组成一个字素
        如果 (NUCP_是区域指示符(上个码点) && NUCP_是区域指示符(cp) && seg.码点数 == 1) {
            seg.码点数 = seg.码点数 + 1
            seg.结束字节 = i + l
            上个码点 = cp
            i = i + l
            继续
        }

        // 否则新字素开始
        断开
    }
    返回 seg
}

函数 NUCP_字素数量(数据, 长度) {
    NUCP_字素切分次数 = NUCP_字素切分次数 + 1
    如果 (数据 == 0 || 长度 == 0) { 返回 0 }
    定义 可变 count = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 seg = NUCP_下一个字素段(数据, 长度, i)
        如果 (seg.结束字节 <= i) { i = i + 1 }
        否则 { i = seg.结束字节 }
        count = count + 1
        堆_释放(seg)
    }
    返回 count
}

函数 NUCP_按字素反转(数据, 长度) {
    如果 (数据 == 0 || 长度 == 0) { 返回 0 }
    // 第一遍提取所有字素边界
    定义 starts = 堆_分配((长度 + 1) * 4)
    定义 ends = 堆_分配((长度 + 1) * 4)
    定义 可变 n = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 seg = NUCP_下一个字素段(数据, 长度, i)
        内存_写32(starts + n * 4, seg.起始字节)
        内存_写32(ends + n * 4, seg.结束字节)
        n = n + 1
        如果 (seg.结束字节 <= i) { i = i + 1 }
        否则 { i = seg.结束字节 }
        堆_释放(seg)
    }
    // 第二遍倒序拷贝
    定义 out = 堆_分配(长度 + 1)
    定义 可变 wi = 0
    定义 可变 k = n - 1
    当 (k >= 0) {
        定义 s = 内存_读32(starts + k * 4)
        定义 e = 内存_读32(ends + k * 4)
        定义 l = e - s
        如果 (l > 0) {
            内存_复制(out + wi, 数据 + s, l)
            wi = wi + l
        }
        k = k - 1
    }
    内存_写8(out + wi, 0)
    堆_释放(starts)
    堆_释放(ends)
    返回 out
}

函数 NUCP_CaseFold哈希(数据, 长度) {
    如果 (数据 == 0 || 长度 == 0) { 返回 0 }
    定义 可变 h = 2166136261
    定义 可变 i = 0
    当 (i < 长度) {
        定义 l = NUCP_UTF8_安全字符长度(数据, i, 长度)
        如果 (l <= 0) { l = 1 }
        定义 cp = NUCP_CaseFold(NUCP_UTF8_安全解码(数据, i, 长度))
        定义 tmp = 堆_分配(8)
        定义 outlen = NUCP_UTF8_安全编码(tmp, cp)
        定义 可变 j = 0
        当 (j < outlen) {
            h = h ^ 内存_读8(tmp + j)
            h = h * 16777619
            j = j + 1
        }
        堆_释放(tmp)
        i = i + l
    }
    返回 h & 0x7FFFFFFF
}

函数 NUCP_规范化相等(数据A, 长度A, 数据B, 长度B) {
    定义 na = NUCP_规范化并小写(数据A, 长度A)
    定义 nb = NUCP_规范化并小写(数据B, 长度B)
    如果 (na == 0 && nb == 0) { 返回 真 }
    如果 (na == 0 || nb == 0) { 返回 假 }
    定义 la = 平台_strlen(na)
    定义 lb = 平台_strlen(nb)
    如果 (la != lb) {
        堆_释放(na)
        堆_释放(nb)
        返回 假
    }
    定义 eq = 内存_比较(na, nb, la) == 0
    堆_释放(na)
    堆_释放(nb)
    返回 eq
}

// §6.8 正则友好辅助（通配模式）
// 支持:
//   ?  匹配任意一个字素
//   *  匹配任意长度字素序列
//   \x 转义

函数 NUCP_通配匹配(文本, 文本长, 模式, 模式长) {
    如果 (文本 == 0 || 模式 == 0) { 返回 假 }
    定义 可变 ti = 0
    定义 可变 pi = 0
    定义 可变 star_pi = -1
    定义 可变 star_ti = -1
    当 (ti < 文本长) {
        如果 (pi < 模式长 && 内存_读8(模式 + pi) == 92 && pi + 1 < 模式长) {
            // 转义字符
            pi = pi + 1
            如果 (ti < 文本长 && 内存_读8(文本 + ti) == 内存_读8(模式 + pi)) {
                ti = ti + 1
                pi = pi + 1
                继续
            }
        } 否则 如果 (pi < 模式长 && 内存_读8(模式 + pi) == 63) { // '?'
            // 匹配一个UTF-8字符
            定义 l = NUCP_UTF8_安全字符长度(文本, ti, 文本长)
            如果 (l <= 0) { l = 1 }
            ti = ti + l
            pi = pi + 1
            继续
        } 否则 如果 (pi < 模式长 && 内存_读8(模式 + pi) == 42) { // '*'
            star_pi = pi
            star_ti = ti
            pi = pi + 1
            继续
        } 否则 如果 (pi < 模式长 && 内存_read8(模式 + pi) == 内存_read8(文本 + ti)) {
            ti = ti + 1
            pi = pi + 1
            继续
        }
        // 回溯到最后一个*
        如果 (star_pi >= 0) {
            pi = star_pi + 1
            定义 l2 = NUCP_UTF8_安全字符长度(文本, star_ti, 文本长)
            如果 (l2 <= 0) { l2 = 1 }
            star_ti = star_ti + l2
            ti = star_ti
            继续
        }
        返回 假
    }
    // 跳过模式尾部的*
    当 (pi < 模式长 && 内存_读8(模式 + pi) == 42) { pi = pi + 1 }
    返回 pi >= 模式长
}

// 兼容内存读8命名差异（有些模块使用内存_read8）
函数 内存_read8(p) { 返回 内存_读8(p) }

// §6.9 文本统计与熵计算

函数 NUCP_log2近似(x) {
    如果 (x <= 0.0) { 返回 -20.0 }
    定义 t = (x - 1.0) / (x + 1.0)
    定义 t2 = t * t
    定义 ln_x = 2.0 * t * (1.0 + t2 / 3.0 + t2 * t2 / 5.0)
    返回 ln_x * 1.4426950408889634
}

函数 NUCP_文本统计(数据, 长度) {
    定义 st = 堆_分配(NUCP文本统计)
    st.字节数 = 长度
    st.码点数 = 0
    st.ASCII数 = 0
    st.CJK数 = 0
    st.空白数 = 0
    st.数字数 = 0
    st.标点数 = 0
    st.表情数 = 0
    st.组合符数 = 0
    st.熵值 = 0.0
    st.平均字节宽度 = 0.0
    如果 (数据 == 0 || 长度 == 0) { 返回 st }

    定义 freq = 堆_分配(256 * 4)
    定义 可变 z = 0
    当 (z < 256) {
        内存_写32(freq + z * 4, 0)
        z = z + 1
    }

    定义 可变 i = 0
    当 (i < 长度) {
        定义 l = NUCP_UTF8_安全字符长度(数据, i, 长度)
        如果 (l <= 0) { l = 1 }
        定义 cp = NUCP_UTF8_安全解码(数据, i, 长度)
        st.码点数 = st.码点数 + 1
        如果 (cp < 0x80) { st.ASCII数 = st.ASCII数 + 1 }

        定义 cat = NUCP_码点分类(cp)
        如果 (cat == NUCP_CAT_CJK) { st.CJK数 = st.CJK数 + 1 }
        否则 如果 (cat == NUCP_CAT_SPACE) { st.空白数 = st.空白数 + 1 }
        否则 如果 (cat == NUCP_CAT_DIGIT) { st.数字数 = st.数字数 + 1 }
        否则 如果 (cat == NUCP_CAT_PUNCT) { st.标点数 = st.标点数 + 1 }
        否则 如果 (cat == NUCP_CAT_EMOJI) { st.表情数 = st.表情数 + 1 }
        否则 如果 (cat == NUCP_CAT_COMBINING) { st.组合符数 = st.组合符数 + 1 }

        定义 bucket = cp & 255
        内存_写32(freq + bucket * 4, 内存_读32(freq + bucket * 4) + 1)
        i = i + l
    }

    如果 (st.码点数 > 0) {
        st.平均字节宽度 = st.字节数 / st.码点数
    }

    定义 可变 k = 0
    定义 可变 ent = 0.0
    当 (k < 256) {
        定义 c = 内存_读32(freq + k * 4)
        如果 (c > 0) {
            定义 p = c / st.码点数
            ent = ent - p * NUCP_log2近似(p)
        }
        k = k + 1
    }
    st.熵值 = ent
    堆_释放(freq)
    返回 st
}

// §6.10 AI语义特征推理
// 特征:
//   f0 ASCII比例
//   f1 CJK比例
//   f2 数字比例
//   f3 空白比例
//   f4 标点比例
//   f5 表情比例
//   f6 平均字节宽度归一化
//   f7 熵值归一化
//   f8 组合符比例
//   f9 UTF8有效性(0/1)

函数 NUCP_AI_文本分析(数据, 长度) {
    如果 (数据 == 0 || 长度 == 0) { 返回 0 }
    如果 (全局AI总线 == 0) { 返回 0 }
    NUCP_AI分析次数 = NUCP_AI分析次数 + 1

    定义 valid = 如果(NUCP_UTF8_验证(数据, 长度), 1.0, 0.0)
    定义 st = NUCP_文本统计(数据, 长度)
    如果 (st == 0 || st.码点数 == 0) { 返回 0 }

    定义 tensor = Tensor_创建(10)
    Tensor_写(tensor, 0, st.ASCII数 / st.码点数)
    Tensor_写(tensor, 1, st.CJK数 / st.码点数)
    Tensor_写(tensor, 2, st.数字数 / st.码点数)
    Tensor_写(tensor, 3, st.空白数 / st.码点数)
    Tensor_写(tensor, 4, st.标点数 / st.码点数)
    Tensor_写(tensor, 5, st.表情数 / st.码点数)
    Tensor_写(tensor, 6, st.平均字节宽度 / 4.0)
    Tensor_写(tensor, 7, st.熵值 / 8.0)
    Tensor_写(tensor, 8, st.组合符数 / st.码点数)
    Tensor_写(tensor, 9, valid)

    定义 result = AI总线_推理(全局AI总线, "NUCP_文本语义评估", tensor, 10)
    Tensor_释放(tensor)
    堆_释放(st)
    返回 result
}

函数 NUCP_AI_异常文本检测(数据, 长度) {
    如果 (数据 == 0 || 长度 == 0) { 返回 0.0 }
    定义 infer = NUCP_AI_文本分析(数据, 长度)
    如果 (infer == 0) { 返回 0.0 }
    // 约定返回tensor第一位为风险分(0-100)
    定义 risk = Tensor_读(infer, 0) / 100.0
    如果 (risk < 0.0) { risk = 0.0 }
    如果 (risk > 1.0) { risk = 1.0 }
    Tensor_释放(infer)
    返回 risk
}

// §6.11 BOM处理与编码探测

函数 NUCP_检测BOM(数据, 长度) {
    如果 (数据 == 0 || 长度 <= 0) { 返回 0 }
    如果 (长度 >= 3 &&
        内存_读8(数据) == 0xEF &&
        内存_读8(数据 + 1) == 0xBB &&
        内存_读8(数据 + 2) == 0xBF) {
        返回 3 // UTF-8 BOM
    }
    如果 (长度 >= 2 &&
        内存_读8(数据) == 0xFF &&
        内存_读8(数据 + 1) == 0xFE) {
        返回 2 // UTF-16LE BOM
    }
    如果 (长度 >= 2 &&
        内存_读8(数据) == 0xFE &&
        内存_read8(数据 + 1) == 0xFF) {
        返回 2 // UTF-16BE BOM
    }
    返回 0
}

函数 NUCP_跳过BOM(数据, 长度) {
    定义 n = NUCP_检测BOM(数据, 长度)
    如果 (n > 0) { 返回 数据 + n }
    返回 数据
}

函数 NUCP_猜测编码(数据, 长度) {
    如果 (数据 == 0 || 长度 == 0) { 返回 "unknown" }
    定义 b = NUCP_检测BOM(数据, 长度)
    如果 (b == 3) { 返回 "utf-8-bom" }
    如果 (b == 2) {
        如果 (内存_读8(数据) == 0xFF) { 返回 "utf-16le" }
        返回 "utf-16be"
    }
    如果 (NUCP_UTF8_验证(数据, 长度)) { 返回 "utf-8" }
    返回 "binary-or-legacy"
}

函数 NUCP_字符串反转按字素(s) {
    如果 (s == 0) { 返回 0 }
    返回 NUCP_按字素反转(s.数据, s.长度)
}

函数 NUCP_字符串归一化哈希(s) {
    如果 (s == 0) { 返回 0 }
    定义 norm = NUCP_规范化并小写(s.数据, s.长度)
    如果 (norm == 0) { 返回 0 }
    定义 nlen = 平台_strlen(norm)
    定义 h = NUCP_CaseFold哈希(norm, nlen)
    堆_释放(norm)
    返回 h
}

// §6.13 诊断/初始化

函数 NUCP_打印统计() {
    平台_日志("[NUCP] 编码=", NUCP_编码次数,
             " 解码=", NUCP_解码次数,
             " 验证=", NUCP_验证次数,
             " 验证失败=", NUCP_验证失败,
             " 规范化=", NUCP_规范化次数,
             " 大小写=", NUCP_大小写转换次数,
             " 字素切分=", NUCP_字素切分次数,
             " AI分析=", NUCP_AI分析次数)
}

函数 NUCP_初始化() {
    NUCP_编码次数 = 0
    NUCP_解码次数 = 0
    NUCP_验证次数 = 0
    NUCP_验证失败 = 0
    NUCP_规范化次数 = 0
    NUCP_大小写转换次数 = 0
    NUCP_字素切分次数 = 0
    NUCP_AI分析次数 = 0
    平台_日志("[NUCP] Nova Unicode Character Processing 已初始化")
}

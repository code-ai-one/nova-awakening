导入("../../运行时/字典引擎/字典引擎.nova")


函数 字符串包含(文本, 子串文本) {
    定义 目标长度 = 计数(子串文本)
    如果 (目标长度 == 0) { 返回 真 }
    如果 (目标长度 > 计数(文本)) { 返回 假 }
    定义 可变 i = 0
    当 (i <= 计数(文本) - 目标长度) {
        如果 (字符串相等(子串(文本, i, 目标长度), 子串文本)) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// 映射表
函数 添加映射(f, n2) { 追加(映射键, f)
追加(映射值, n2) }
函数 查找映射(词) {
    定义 可变 i = 0
    当 (i < 计数(映射键)) {
        如果 (字符串相等(映射键[i], 词)) { 返回 映射值[i] }
        i = i + 1
    }
    返回 空
}


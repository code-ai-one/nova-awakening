导入("../函数式/函数式.nova")
导入("../基础.nova")
导入("../数学/概率.nova")

定义 采样_随机态 = 54321
函数 采样_随机() {
 采样_随机态 = 采样_随机态 ^ (采样_随机态 << 13)
 采样_随机态 = 采样_随机态 ^ (采样_随机态 >> 7)
 采样_随机态 = 采样_随机态 ^ (采样_随机态 << 17)
 如果 (采样_随机态 < 0) { 采样_随机态 = 0 - 采样_随机态 }
 返回 采样_随机态
}

// 贪心采样
函数 贪心采样(对数值) { 定义 可变 最大 = 对数值[0]
 定义 可变 最大idx = 0
 定义 可变 i = 1
 当 (i < 计数(对数值)) { 如果 (对数值[i] > 最大) { 最大 = 对数值[i]
 最大idx = i }
 i = i + 1
 }
 返回 最大idx
}

// 温度采样
函数 温度_缩放(对数值, 温度) {
    如果 (温度 == 0) { 温度 = 1
}
 返回 映射(对数值, x => x * 100 / 温度)
}

// Softmax (简化整数版)
函数 简化Softmax(对数值) { 定义 可变 最大 = 对数值[0]
 定义 可变 i = 1
 当 (i < 计数(对数值)) { 如果 (对数值[i] > 最大) { 最大 = 对数值[i] }
 i = i + 1 }
 定义 可变 权重 = []
 定义 可变 总和 = 0
 i = 0
 当 (i < 计数(对数值)) { 定义 可变 w = 对数值[i] - 最大 + 100
 如果 (w < 1) { w = 1 }
 追加(权重, w)
 总和 = 总和 + w
 i = i + 1
 }
 // 归一化到0-1000
 返回 映射(权重, w => w * 1000 / 总和)
}

// 分类采样 (按概率, 0)
函数 采样策略_分类采样(概率) { 定义 随机值 = 采样_随机() % 1000
 定义 可变 累积 = 0
 定义 可变 i = 0
 当 (i < 计数(概率)) {
 累积 = 累积 + 概率[i]
 如果 (随机值 < 累积) { 返回 i }
 i = i + 1
 }
 返回 计数(概率) - 1
}

// Top-K 采样
函数 TopK采样(对数值, K) {
 // 找Top-K索引
 定义 可变 索引列表 = []
 定义 可变 i = 0
 当 (i < 计数(对数值)) { 追加(索引列表, i)
 i = i + 1 }
 // 按logits降序排序indices
 i = 0
 当 (i < 计数(索引列表) - 1) { 定义 可变 j = i + 1
 当 (j < 计数(索引列表)) { 如果 (对数值[索引列表[j]] > 对数值[索引列表[i]]) { 定义 临时 = 索引列表[i]
 索引列表[i] = 索引列表[j]
 索引列表[j] = 临时
 }
 j = j + 1
 }
 i = i + 1
 }
 // 只保留Top-K
 定义 可变 过滤值 = []
 i = 0
 当 (i < 计数(对数值)) { 追加(过滤值, -99999)
 i = i + 1 }
 i = 0
 当 (i < K 且 i < 计数(索引列表)) {
 过滤值[索引列表[i]] = 对数值[索引列表[i]]
 i = i + 1
 }
 定义 概率 = 简化Softmax(过滤值)
 返回 分类采样(概率, 0)
}

// Top-P (Nucleus) 采样
函数 TopP采样(对数值, P) { 定义 概率 = 简化Softmax(对数值)
 定义 可变 索引列表 = []
 定义 可变 i = 0
 当 (i < 计数(概率)) { 追加(索引列表, i)
 i = i + 1 }
 // 按概率降序排序
 i = 0
 当 (i < 计数(索引列表) - 1) { 定义 可变 j = i + 1
 当 (j < 计数(索引列表)) { 如果 (概率[索引列表[j]] > 概率[索引列表[i]]) { 定义 临时 = 索引列表[i]
 索引列表[i] = 索引列表[j]
 索引列表[j] = 临时
 }
 j = j + 1
 }
 i = i + 1
 }
 // 累积到P
 定义 可变 累积 = 0
 定义 可变 截止 = 0
 i = 0
 当 (i < 计数(索引列表) 且 累积 < P) {
 累积 = 累积 + 概率[索引列表[i]]
 截止 = i + 1
 i = i + 1
 }
 // 从截止范围内采样
 定义 随机值 = 采样_随机() % 截止
 返回 索引列表[随机值]
}

// Logits最大值
函数 Logits_最大值(对数值) { 返回 列表最大(对数值) }

// 束搜索

函数 束搜索_创建(束宽) { 返回 [[], 束宽]
 // [候选列表, 束宽]
 // 候选: [序列, 分数, 是否结束]
}

函数 束搜索_初始化(束) {
 束[0] = [[[],0,假]]
}

函数 束搜索_扩展(束, 词表大小, 分数表) { 定义 可变 所有候选 = []
 定义 可变 i = 0
 当 (i < 计数(束[0])) { 定义 候选 = 束[0][i]
 如果 (候选[2]) {
 追加(所有候选, 候选)
 } 否则 { 定义 可变 v = 0
 当 (v < 词表大小) { 定义 可变 新序列 = []
 定义 可变 k = 0
 当 (k < 计数(候选[0])) { 追加(新序列, 候选[0][k]) k = k + 1 }
 追加(新序列, v)
 定义 新分数 = 候选[1] + 分数表[v]
 追加(所有候选, [新序列, 新分数, 假])
 v = v + 1
 }
 }
 i = i + 1
 }
 // 按分数排序取TopK
 定义 可变 n = 计数(所有候选)
 定义 可变 si = 0
 当 (si < n - 1) { 定义 可变 sj = si + 1
 当 (sj < n) { 如果 (所有候选[sj][1] > 所有候选[si][1]) { 定义 临 = 所有候选[si]
 所有候选[si] = 所有候选[sj]
 所有候选[sj] = 临
 }
 sj = sj + 1
 }
 si = si + 1
 }
 束[0] = []
 i = 0
 当 (i < 束[1] 且 i < 计数(所有候选)) {
 追加(束[0], 所有候选[i])
 i = i + 1
 }
}

函数 束搜索_最佳(束) {
    如果 (计数(束[0]) == 0) { 返回 空
}
 返回 束[0][0]
}

// 重复惩罚

函数 采样_重复惩罚(对数值, 已生成, 惩罚因子) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(对数值)) { 追加(结果, 对数值[i]) i = i + 1 }
 i = 0
 当 (i < 计数(已生成)) { 定义 词元值 = 已生成[i]
 如果 (词元值 >= 0 且 词元值 < 计数(结果)) { 如果 (结果[词元值] > 0) { 结果[词元值] = 结果[词元值] * 1000 / 惩罚因子 }
 否则 { 结果[词元值] = 结果[词元值] * 惩罚因子 / 1000 }
 }
 i = i + 1
 }
 返回 结果
}

函数 采样_频率惩罚(对数值, 已生成, 惩罚值) {
 // 计算每个token出现次数
 定义 可变 频率 = []
 定义 可变 i = 0
 当 (i < 计数(对数值)) { 追加(频率, 0) i = i + 1 }
 i = 0
 当 (i < 计数(已生成)) { 定义 词元值 = 已生成[i]
 如果 (词元值 >= 0 且 词元值 < 计数(频率)) { 频率[词元值] = 频率[词元值] + 1 }
 i = i + 1
 }
 定义 可变 结果 = []
 i = 0
 当 (i < 计数(对数值)) {
 追加(结果, 对数值[i] - 频率[i] * 惩罚值)
 i = i + 1
 }
 返回 结果
}

// 温度调节增强

函数 采样_动态温度(对数值, 基础温度, 熵阈值) {
 // 计算当前分布熵
 定义 最大 = Logits_最大值(对数值)
 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 计数(对数值)) { 定义 可变 v = 对数值[i] - 最大 + 100
 如果 (v < 0) { v = 1 }
 总 = 总 + v
 i = i + 1
 }
 定义 可变 熵 = 0
 i = 0
 当 (i < 计数(对数值)) { 定义 可变 v = 对数值[i] - 最大 + 100
 如果 (v < 1) { v = 1 }
 定义 p = v * 1000 / (总 + 1)
 如果 (p > 0) { 熵 = 熵 + p }
 i = i + 1
 }
 // 高熵时降低温度，低熵时提高温度
 定义 可变 调整温度 = 基础温度
 如果 (熵 > 熵阈值) { 调整温度 = 基础温度 * 800 / 1000 }
 否则 如果 (熵 < 熵阈值 / 2) { 调整温度 = 基础温度 * 1200 / 1000 }
 返回 调整温度
}

// Mirostat采样

函数 采样_Mirostat(对数值, 目标惊奇度, 学习率, 当前mu) {
 // 排序获取最大值
 定义 可变 排序logits = []
 定义 可变 i = 0
 当 (i < 计数(对数值)) { 追加(排序logits, 对数值[i]) i = i + 1 }
 // 冒泡降序
 定义 可变 n = 计数(排序logits)
 i = 0
 当 (i < n - 1) { 定义 可变 j = 0
 当 (j < n - i - 1) { 如果 (排序logits[j] < 排序logits[j+1]) { 定义 临 = 排序logits[j]
 排序logits[j] = 排序logits[j+1]
 排序logits[j+1] = 临
 }
 j = j + 1
 }
 i = i + 1
 }
 // 截断到mu范围
 定义 可变 截断k = 1
 当 (截断k < n 且 排序logits[截断k] > 当前mu - 目标惊奇度) { 截断k = 截断k + 1 }
 // 从截断范围采样
 定义 索引 = 采样_随机() % 截断k
 // 更新mu
 定义 实际惊奇 = 0 - 排序logits[索引]
 定义 新mu = 当前mu - 学习率 * (实际惊奇 - 目标惊奇度)
 返回 [索引, 新mu]
}

定义 可变 _采样_总次数 = 0
定义 可变 _采样_贪心次数 = 0
定义 可变 _采样_随机次数 = 0

函数 采样_记录贪心() { _采样_总次数 = _采样_总次数 + 1 _采样_贪心次数 = _采样_贪心次数 + 1 }
函数 采样_记录随机() { _采样_总次数 = _采样_总次数 + 1 _采样_随机次数 = _采样_随机次数 + 1 }

函数 采样_多样性评估() {
    如果 (_采样_总次数 > 0 且 _采样_贪心次数 * 100 / _采样_总次数 > 90) { 返回 "采样过于确定(提高温度)"
}
 如果 (_采样_总次数 > 0 且 _采样_随机次数 * 100 / _采样_总次数 > 90) { 返回 "采样过于随机(降低温度)" }
 返回 "采样策略正常"
}

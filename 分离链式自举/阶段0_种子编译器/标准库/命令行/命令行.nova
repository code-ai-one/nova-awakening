导入("../基础.nova")


// 参数类型
定义 参数_标志 = 0 // --verbose (布尔)
定义 参数_选项 = 1 // --output file.txt (值)
定义 参数_位置 = 2 // <input> (位置参数)

// 参数定义
// [名称, 短名, 类型, 默认值, 描述, 是否必需, 值]
函数 参数_创建(名称, 短名, 类型, 默认值, 描述, 必需) { 返回 [名称, 短名, 类型, 默认值, 描述, 必需, 默认值]
}

函数 标志(名称, 短名, 描述) { 返回 参数_创建(名称,  短名,  参数_标志,  0,  描述, 0)
}

函数 选项(名称, 短名, 默认值, 描述, 必需) { 返回 参数_创建(名称, 短名, 参数_选项, 默认值, 描述, 必需)
}

函数 位置参数(名称, 描述, 必需) { 返回 参数_创建(名称, "", 参数_位置, "", 描述, 必需)
}

// 命令
// [名称, 描述, 参数列表, 子命令列表, 版本, 执行标记]
函数 命令_创建(名称, 描述) { 返回 [名称, 描述, [], [], "", 0, 空]
}

函数 命令_添加参数(命令, 参数) { 追加(命令[2], 参数) }
函数 命令_添加子命令(命令, 子命令) { 追加(命令[3], 子命令) }
函数 命令_设版本(命令, 版本) { 命令[4] = 版本 }

// 解析器
函数 解析_参数(命令, args) { 定义 argc = 计数(args)
 定义 可变 i = 0
 当 (i < argc) { 定义 arg = args[i]
 // 检查是否是选项 (以--或-开头)
 定义 可变 已匹配 = 0
 定义 可变 j = 0
 当 (j < 计数(命令[2])) { 定义 参数 = 命令[2][j]
 // 长选项匹配
 如果 (arg == 参数[0]) { 如果 (参数[2] == 参数_标志) {
 参数[6] = 1
 已匹配 = 1
 } 否则 如果 (参数[2] == 参数_选项) { 如果 (i + 1 < argc) {
 i = i + 1
 参数[6] = args[i]
 }
 已匹配 = 1
 }
 }
 // 短选项匹配
 如果 (arg == 参数[1] 且 参数[1] != "") { 如果 (参数[2] == 参数_标志) {
 参数[6] = 1
 已匹配 = 1
 } 否则 如果 (参数[2] == 参数_选项) { 如果 (i + 1 < argc) {
 i = i + 1
 参数[6] = args[i]
 }
 已匹配 = 1
 }
 }
 j = j + 1
 }
 // 位置参数
 如果 (已匹配 == 0) {
 // 检查子命令
 j = 0
 当 (j < 计数(命令[3])) { 如果 (arg == 命令[3][j][0]) {
 // 递归解析子命令的参数
 定义 可变 子args = []
 定义 可变 k = i + 1
 当 (k < argc) { 追加(子args, args[k])
 k = k + 1 }
 解析_参数(命令[3][j], 子args)
 命令[3][j][5] = 1 // 标记已执行
 返回 命令
 }
 j = j + 1
 }
 // 位置参数
 j = 0
 当 (j < 计数(命令[2])) { 如果 (命令[2][j][2] == 参数_位置 且 命令[2][j][6] == 命令[2][j][3]) {
 命令[2][j][6] = arg
 j = 计数(命令[2]) // break
 }
 j = j + 1
 }
 }
 i = i + 1
 }
 返回 命令
}

// 获取参数值
函数 获取_参数(命令, 名称) { 定义 可变 i = 0
 当 (i < 计数(命令[2])) { 如果 (命令[2][i][0] == 名称) { 返回 命令[2][i][6] }
 i = i + 1
 }
 返回 空
}

函数 获取_标志(命令, 名称) { 定义 数值 = 获取_参数(命令, 名称)
 如果 (数值 == 空) { 返回 0 }
 返回 数值 == 1
}

函数 活跃子命令(命令) { 定义 可变 i = 0
 当 (i < 计数(命令[3])) { 如果 (命令[3][i][5] == 1) { 返回 命令[3][i] }
 i = i + 1
 }
 返回 空
}

// 验证
函数 验证_必需参数(命令) { 定义 可变 缺失 = []
 定义 可变 i = 0
 当 (i < 计数(命令[2])) { 如果 (命令[2][i][5] == 1 且 命令[2][i][6] == 命令[2][i][3]) {
 追加(缺失, 命令[2][i][0])
 }
 i = i + 1
 }
 返回 缺失
}

// 帮助生成
函数 生成_帮助(命令) {
 打印("用法: " + 命令[0])
 如果 (命令[1] != "") { 打印(" " + 命令[1]) }
 如果 (命令[4] != "") { 打印(" 版本: " + 命令[4]) }
 打印("")
 如果 (计数(命令[2]) > 0) {
 打印("参数:")
 定义 可变 i = 0
 当 (i < 计数(命令[2])) { 定义 p = 命令[2][i]
 定义 可变 行 = " "
 如果 (p[2] == 参数_位置) {
 行 = 行 + "<" + p[0] + ">"
 } 否则 {
 行 = 行 + p[0]
 如果 (p[1] != "") { 行 = 行 + ", " + p[1] }
 }
 行 = 行 + " " + p[4]
 如果 (p[5] == 1) { 行 = 行 + " (必需)" }
 打印(行)
 i = i + 1
 }
 }
 如果 (计数(命令[3]) > 0) {
 打印("")
 打印("子命令:")
 定义 可变 i = 0
 当 (i < 计数(命令[3])) {
 打印(" " + 命令[3][i][0] + " " + 命令[3][i][1])
 i = i + 1
 }
 }
}

// 参数组与互斥
// 参数组: [名称, 描述, 参数名列表, 是否互斥]
函数 命令行_参数组_创建(名称, 描述, 互斥) { 返回 [名称, 描述, [], 互斥]
}

函数 参数组_追加(组, 参数名) { 追加(组[2], 参数名) }

函数 验证_互斥组(命令, 组) { 如果 (组[3] == 0) { 返回 1 } // 非互斥组无需验证
 定义 可变 设置数 = 0
 定义 可变 i = 0
 当 (i < 计数(组[2])) { 定义 数值 = 获取_参数(命令, 组[2][i])
 如果 (数值 != 空 且 数值 != 0 且 数值 != "") {
 设置数 = 设置数 + 1
 }
 i = i + 1
 }
 如果 (设置数 > 1) {
 打印("错误: 互斥参数组 '" + 组[0] + "' 中只能设置一个选项")
 返回 0
 }
 返回 1
}

// 参数计数与统计
函数 参数_计数_已设置(命令) { 定义 可变 n = 0
 定义 可变 i = 0
 当 (i < 计数(命令[2])) { 如果 (命令[2][i][6] != 命令[2][i][3]) { n = n + 1 }
 i = i + 1
 }
 返回 n
}

函数 参数_计数_标志(命令) { 定义 可变 n = 0
 定义 可变 i = 0
 当 (i < 计数(命令[2])) { 如果 (命令[2][i][2] == 参数_标志) { n = n + 1 }
 i = i + 1
 }
 返回 n
}

函数 参数_计数_选项(命令) { 定义 可变 n = 0
 定义 可变 i = 0
 当 (i < 计数(命令[2])) { 如果 (命令[2][i][2] == 参数_选项) { n = n + 1 }
 i = i + 1
 }
 返回 n
}

函数 参数_计数_位置(命令) { 定义 可变 n = 0
 定义 可变 i = 0
 当 (i < 计数(命令[2])) { 如果 (命令[2][i][2] == 参数_位置) { n = n + 1 }
 i = i + 1
 }
 返回 n
}

// 错误消息
函数 命令_打印错误(命令, 消息) {
 打印("错误: " + 消息)
 打印("运行 '" + 命令[0] + " --help' 查看帮助")
}

函数 验证_并报错(命令) { 定义 缺失 = 验证_必需参数(命令)
 如果 (计数(缺失) > 0) { 定义 可变 i = 0
 当 (i < 计数(缺失)) {
 命令_打印错误(命令, "缺少必需参数: " + 缺失[i])
 i = i + 1
 }
 返回 0
 }
 返回 1
}

// 用法字符串生成
函数 生成_用法行(命令) { 定义 可变 行 = "用法: " + 命令[0]
 定义 可变 i = 0
 当 (i < 计数(命令[2])) { 定义 p = 命令[2][i]
 如果 (p[2] == 参数_位置) { 如果 (p[5] == 1) {
 行 = 行 + " <" + p[0] + ">"
 } 否则 {
 行 = 行 + " [" + p[0] + "]"
 }
 } 否则 如果 (p[2] == 参数_选项) {
 行 = 行 + " [" + p[0] + " <值>]"
 } 否则 {
 行 = 行 + " [" + p[0] + "]"
 }
 i = i + 1
 }
 如果 (计数(命令[3]) > 0) { 行 = 行 + " <子命令>" }
 返回 行
}

// 高级帮助 (带示例)
函数 生成_详细帮助(命令, 示例列表) {
 生成_帮助(命令)
 如果 (计数(示例列表) > 0) {
 打印("")
 打印("示例:")
 定义 可变 i = 0
 当 (i < 计数(示例列表)) {
 打印(" " + 示例列表[i])
 i = i + 1
 }
 }
}

// 参数重置
函数 命令_重置(命令) { 定义 可变 i = 0
 当 (i < 计数(命令[2])) {
 命令[2][i][6] = 命令[2][i][3]
 i = i + 1
 }
 i = 0
 当 (i < 计数(命令[3])) {
 命令[3][i][5] = 0
 命令_重置(命令[3][i])
 i = i + 1
 }
}

// 参数列表导出 (字典形式)
函数 命令_导出参数(命令) { 定义 d = 字典()
 定义 可变 i = 0
 当 (i < 计数(命令[2])) {
 字典设(d, 命令[2][i][0], 命令[2][i][6])
 i = i + 1
 }
 返回 d
}

// 补全提示
函数 生成_补全列表(命令, 前缀) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(命令[2])) { 定义 名 = 命令[2][i][0]
 如果 (前缀 == "" 或 以开头(名, 前缀)) {
 追加(结果, 名)
 }
 i = i + 1
 }
 i = 0
 当 (i < 计数(命令[3])) { 定义 名 = 命令[3][i][0]
 如果 (前缀 == "" 或 以开头(名, 前缀)) {
 追加(结果, 名)
 }
 i = i + 1
 }
 返回 结果
}

// 子命令查找
函数 获取_子命令(命令, 名称) { 定义 可变 i = 0
 当 (i < 计数(命令[3])) { 如果 (命令[3][i][0] == 名称) { 返回 命令[3][i] }
 i = i + 1
 }
 返回 空
}

// 快速构建器模式
函数 快速命令(名称, 描述, 版本) { 定义 命令 = 命令_创建(名称, 描述)
 命令_设版本(命令, 版本)
 // 自动添加 --help 和 --version 标志
 命令_添加参数(命令, 标志("--help", "-h", "显示帮助信息"))
 命令_添加参数(命令, 标志("--version", "-V", "显示版本号"))
 返回 命令
}

函数 命令_自动帮助(命令, args) {
 解析_参数(命令, args)
 如果 (获取_标志(命令, "--help")) {
 生成_帮助(命令)
 返回 0
 }
 如果 (获取_标志(命令, "--version")) {
 打印(命令[0] + " " + 命令[4])
 返回 0
 }
 如果 (验证_并报错(命令) == 0) { 返回 0 }
 返回 1
}

// 命令行扩展

函数 命令行_子命令(命令, 名称, 描述) {
    如果 (命令[6] == 空) { 命令[6] = []
}
 追加(命令[6], [名称, 描述, []])
}

函数 命令行_获取子命令(命令, 参数列表) {
    如果 (计数(参数列表) == 0) { 返回 空
}
 如果 (命令[6] == 空) { 返回 空 }
 定义 可变 i = 0
 当 (i < 计数(命令[6])) { 如果 (命令[6][i][0] == 参数列表[0]) { 返回 命令[6][i] }
 i = i + 1
 }
 返回 空
}

函数 命令行_环境变量(名称, 默认值) { 定义 值 = 获取环境(名称)
 如果 (值 == 空) { 返回 默认值 }
 返回 值
}

函数 命令行_是否详细(命令) { 返回 获取_标志(命令, "--verbose") 或 获取_标志(命令, "-v")
}

函数 命令行_是否静默(命令) { 返回 获取_标志(命令, "--quiet") 或 获取_标志(命令, "-q")
}

函数 命令行_输出级别(命令) {
    如果 (命令行_是否静默(命令)) { 返回 0
}
 如果 (命令行_是否详细(命令)) { 返回 2 }
 返回 1
}

函数 命令行_打印用法(命令) {
 打印("用法: " + 命令[0] + " [选项] [参数]")
 打印("")
 打印("选项:")
 定义 可变 i = 0
 当 (i < 计数(命令[2])) { 定义 选项 = 命令[2][i]
 打印(" " + 选项[0] + " " + 选项[4])
 i = i + 1
 }
}

函数 命令行_解析整数(值, 默认值) {
    如果 (值 == 空) { 返回 默认值
}
 定义 可变 结果 = 0
 定义 可变 i = 0
 当 (i < 计数(值)) { 定义 c = 字符码(值, i)
 如果 (c >= 字符_零 且 c <= 字符_九) {
 结果 = 结果 * 10 + c - 48
 }
 i = i + 1
 }
 返回 结果
}

定义 可变 _cmd_解析次数 = 0
定义 可变 _cmd_错误数 = 0
定义 可变 _cmd_子命令数 = 0

函数 cmd_记录解析(成功) { _cmd_解析次数 = _cmd_解析次数 + 1
 如果 (!成功) { _cmd_错误数 = _cmd_错误数 + 1 }
}

函数 cmd_记录子命令() { _cmd_子命令数 = _cmd_子命令数 + 1 }

函数 cmd_错误率() {
    如果 (_cmd_解析次数 == 0) { 返回 0
}
 返回 _cmd_错误数 * 100 / _cmd_解析次数
}

函数 cmd_易用性评估() { 定义 率 = cmd_错误率()
 如果 (率 > 30) { 返回 "参数设计不直观(改进帮助文本)" }
 如果 (率 > 10) { 返回 "偶有误用" }
 返回 "易用性良好"
}

函数 cmd_重置() { _cmd_解析次数 = 0
 _cmd_错误数 = 0
 _cmd_子命令数 = 0
}

函数 命令行_进度条(当前, 总数, 宽度) {
    如果 (总数 == 0) { 返回 ""
}
 定义 完成 = 当前 * 宽度 / 总数
 定义 可变 条 = "["
 定义 可变 i = 0
 当 (i < 宽度) { 如果 (i < 完成) { 条 = 字符串拼接(条, "█") }
 否则 { 条 = 字符串拼接(条, "░") }
 i = i + 1
 }
 条 = 字符串拼接(条, "] ")
 条 = 字符串拼接(条, 转字符串(当前 * 100 / 总数))
 条 = 字符串拼接(条, "%")
 返回 条
}

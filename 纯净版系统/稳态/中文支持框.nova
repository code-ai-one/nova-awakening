导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../引导/端口输入.nova")
导入("../中枢/整数转字符串.nova")

// §4 中文支持框架 — 16×16点阵(HZK16兼容)

定义 可变 中文字库_已加载 = 假
定义 可变 中文字库_地址 = 0    // HZK16数据内存地址
定义 可变 中文字库_大小 = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 中文字库_加载(数据地址, 大小) {
    中文字库_地址 = 数据地址
    中文字库_大小 = 大小
    中文字库_已加载 = 真
    内核信息("中文字库: HZK16加载完成 (" + 整数转字符串(大小) + " 字节)")
}

函数 字体_渲染中文字符(fb, x, y, 区码, 位码, 前景色, 缩放) {
    // GB2312编码: 区码(0x21-0x77), 位码(0x21-0x7E)
    // HZK16偏移 = ((区码-1)*94 + (位码-1)) * 32
    如果 (!中文字库_已加载) { 返回 }
    定义 偏移 = ((区码 - 1) * 94 + (位码 - 1)) * 32
    如果 (偏移 < 0 || 偏移 + 32 > 中文字库_大小) { 返回 }

    // 16×16点阵: 每行2字节, 共16行=32字节
    定义 可变 行 = 0
    当 (行 < 16) {
        定义 高字节 = 内存读8(中文字库_地址 + 偏移 + 行 * 2)
        定义 低字节 = 内存读8(中文字库_地址 + 偏移 + 行 * 2 + 1)
        定义 行数据 = (高字节 << 8) | 低字节

        定义 可变 列 = 0
        当 (列 < 16) {
            如果 ((行数据 >> (15 - 列)) & 1 == 1) {
                定义 可变 sy = 0
                当 (sy < 缩放) {
                    定义 可变 sx = 0
                    当 (sx < 缩放) {
                        定义 px = x + 列 * 缩放 + sx
                        定义 py = y + 行 * 缩放 + sy
                        定义 bpp = 屏幕位深 / 8
                        如果 (bpp < 3) { bpp = 4 }
                        定义 像素偏移 = (py * 屏幕宽 + px) * bpp
                        内存写8(fb + 像素偏移,     前景色 & 0xFF)
                        内存写8(fb + 像素偏移 + 1, (前景色 >> 8) & 0xFF)
                        内存写8(fb + 像素偏移 + 2, (前景色 >> 16) & 0xFF)
                        内存写8(fb + 像素偏移 + 3, 0xFF)
                        sx = sx + 1
                    }
                    sy = sy + 1
                }
            }
            列 = 列 + 1
        }
        行 = 行 + 1
    }
}

// §5 简易抗锯齿 — 2×2超采样

函数 字体_渲染字符_AA(fb, x, y, 字符码, 前景色, 背景色) {
    // 2×2超采样抗锯齿: 先在2倍分辨率渲染, 然后降采样混合
    如果 (字符码 < 字体_首字符 || 字符码 > 字体_末字符) { 返回 }
    定义 偏移 = (字符码 - 字体_首字符) * 字体_高
    定义 bpp = 屏幕位深 / 8
    如果 (bpp < 3) { bpp = 4 }

    // 每个输出像素对应2×2个采样点
    // 字体原始8×16 → 输出8×16, 每个点查看周围采样
    定义 可变 行 = 0
    当 (行 < 字体_高) {
        定义 行数据 = 字体数据[偏移 + 行]
        // 上下行(用于垂直混合)
        定义 上行 = 0
        如果 (行 > 0) { 上行 = 字体数据[偏移 + 行 - 1] }
        定义 下行 = 0
        如果 (行 < 字体_高 - 1) { 下行 = 字体数据[偏移 + 行 + 1] }

        定义 可变 列 = 0
        当 (列 < 字体_宽) {
            定义 位 = (7 - 列)
            定义 中心 = (行数据 >> 位) & 1
            定义 上 = (上行 >> 位) & 1
            定义 下 = (下行 >> 位) & 1
            定义 左 = 0
            如果 (列 > 0) { 左 = (行数据 >> (位 + 1)) & 1 }
            定义 右 = 0
            如果 (列 < 7) { 右 = (行数据 >> (位 - 1)) & 1 }

            // 采样数(0-5): 中心×1 + 4邻居各×1 → 加权平均
            定义 采样 = 中心 * 5 + 上 + 下 + 左 + 右  // 0-9
            // 颜色混合: 前景×(采样/9) + 背景×(1-采样/9)
            定义 前R = (前景色 >> 16) & 0xFF
            定义 前G = (前景色 >> 8) & 0xFF
            定义 前B = 前景色 & 0xFF
            定义 背R = (背景色 >> 16) & 0xFF
            定义 背G = (背景色 >> 8) & 0xFF
            定义 背B = 背景色 & 0xFF
            定义 混R = (前R * 采样 + 背R * (9 - 采样)) / 9
            定义 混G = (前G * 采样 + 背G * (9 - 采样)) / 9
            定义 混B = (前B * 采样 + 背B * (9 - 采样)) / 9

            定义 px = x + 列
            定义 py = y + 行
            定义 像素偏移 = (py * 屏幕宽 + px) * bpp
            内存写8(fb + 像素偏移,     混B & 0xFF)
            内存写8(fb + 像素偏移 + 1, 混G & 0xFF)
            内存写8(fb + 像素偏移 + 2, 混R & 0xFF)
            内存写8(fb + 像素偏移 + 3, 0xFF)

            列 = 列 + 1
        }
        行 = 行 + 1
    }
}

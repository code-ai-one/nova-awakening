// NovaOS 渲染引擎 / 进程模型 / 浏览主体
// 模块: 智能渲染_总线驱动绘制
// 目标:
//  1) AI总线驱动质量分配 — 语义重要性×可见性
//  2) 注视点高斯衰减 — 边缘降级
//  3) JND(Just Noticeable Difference)感知阈值
//  4) 运动掩蔽估计 — 滚动时降低质量
//  5) 粗略绘制 — 低质量纯色填充
//  6) AI事件感知 — 用户事件驱动总线
//  7) 帧级统计与诊断

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../推理/智能总线初始.nova")
导入("../推理/值乘.nova")
导入("./创建销毁.nova")
导入("../推理/智能总线鼠标.nova")
导入("../执行/输入多路复.nova")
导入("../中枢/内核打印.nova")
导入("../稳态/统一操作接.nova")
导入("../中枢/整数转字符串.nova")
导入("../推理/模型持久化.nova")
导入("./从布局树构.nova")

// §1 常量

定义 Q10 = 1024
定义 Q_HALF = 512

定义 渲染级别_跳过 = 0
定义 渲染级别_低 = 1
定义 渲染级别_中 = 2
定义 渲染级别_高 = 3
定义 渲染级别_极高 = 4

定义 语义_正文 = 0
定义 语义_标题 = 1
定义 语义_导航 = 2
定义 语义_广告 = 3
定义 语义_表单 = 4
定义 语义_媒体 = 5
定义 语义_装饰 = 6
定义 语义_脚本 = 11

定义 事件_鼠标移动 = 1
定义 事件_点击 = 2
定义 事件_滚动 = 3
定义 事件_键盘 = 4
定义 事件_悬停 = 5

// JND (Just Noticeable Difference) 感知参数
定义 JND_强度基线 = 50    // 基层JND阈值
定义 JND_运动倍率 = 3    // 运动时JND增大倍数

// 高斯衰减参数
定义 注视半径 = 200     // px
定义 高斯_σ平方_2 = 80000  // 2σ² = 2*200*200

定义 最大层深度 = 32
定义 统计_环大小 = 64

// §2 数据结构

结构 渲染统计 {
    总层数,
    跳过层数,
    低质量层数,
    中质量层数,
    高质量层数,
    总绘制时间_us,
}

结构 注视点状态 {
    x,
    y,
    运动速度,    // px/frame
    上次更新,
}

结构 帧级诊断 {
    环,
    写索引,
    总帧数,
    总绘制时间,
}

定义 可变 全局_注视点 = 空
定义 可变 全局_渲染统计 = 空
定义 可变 全局_帧诊断 = 空

// §3 注视点高斯衰减
// 创新: exp(-d²/2σ²) 高斯模型, 边缘层自动降级

函数 注视点_初始化() {
    如果 (全局_注视点 != 空) { 返回 }
    定义 f = 注视点状态 {}
    f.x = 0
    f.y = 0
    f.运动速度 = 0
    f.上次更新 = 0
    全局_注视点 = f
}

函数 注视点_更新(新x, 新y) {
    如果 (全局_注视点 == 空) { 注视点_初始化() }
    定义 f = 全局_注视点
    定义 dx = 新x - f.x
    定义 dy = 新y - f.y
    f.运动速度 = 平方根_近似(dx * dx + dy * dy)
    f.x = 新x
    f.y = 新y
    f.上次更新 = 平台_获取时间_ms()
}

函数 注视点_计算衰减(区域x, 区域y, 区域w, 区域h) {
    // 计算区域中心到注视点距离
    如果 (全局_注视点 == 空) { 返回 Q10 }  // 无注视点, 全质量
    定义 cx = 区域x + 区域w / 2
    定义 cy = 区域y + 区域h / 2
    定义 dx = cx - 全局_注视点.x
    定义 dy = cy - 全局_注视点.y
    定义 d2 = dx * dx + dy * dy
    // exp(-d²/2σ²) 近似: 1/(1 + d²/2σ²) [rational approximation]
    定义 衰减 = Q10 * 高斯_σ平方_2 / (高斯_σ平方_2 + d2)
    返回 衰减
}

函数 平方根_近似(x) {
    // 牛顿迭代法整数平方根
    如果 (x <= 0) { 返回 0 }
    定义 可变 g = x / 2
    如果 (g == 0) { g = 1 }
    定义 可变 i = 0
    当 (i < 8) {
        g = (g + x / g) / 2
        i = i + 1
    }
    返回 g
}

// §4 JND感知阈值 + 运动掩蔽
// 创新: JND模型计算人类可感知差异的最小质量变化

函数 JND_计算(区域x, 区域y, 区域w, 区域h, 运动中) {
    // JND = 基线 + 距离补偿 + 运动掩蔽
    定义 衰减 = 注视点_计算衰减(区域x, 区域y, 区域w, 区域h)
    // 距离越远, JND越大(人类边缘视觉精度降低)
    定义 距离补偿 = JND_强度基线 * (Q10 - 衰减) / Q10
    定义 可变 jnd = JND_强度基线 + 距离补偿
    // 运动掩蔽: 滚动/动画中人类感知降低
    如果 (运动中) {
        jnd = jnd * JND_运动倍率
    }
    返回 jnd
}

// §5 语义重要性计算

函数 语义_获取重要性(角色) {
    如果 (角色 == 语义_正文) { 返回 900 }
    如果 (角色 == 语义_标题) { 返回 950 }
    如果 (角色 == 语义_媒体) { 返回 850 }
    如果 (角色 == 语义_表单) { 返回 750 }
    如果 (角色 == 语义_导航) { 返回 700 }
    如果 (角色 == 语义_装饰) { 返回 400 }
    如果 (角色 == 语义_广告) { 返回 100 }
    如果 (角色 == 语义_脚本) { 返回 0 }
    返回 Q_HALF
}

函数 质量_计算渲染级别(语义重要性, 衰减, 是否可见, jnd) {
    如果 (是否可见 == 假) { 返回 渲染级别_跳过 }
    如果 (语义重要性 <= 0) { 返回 渲染级别_跳过 }
    // 综合分 = 语义重要性 * 衰减 / Q10
    定义 分数 = 语义重要性 * 衰减 / Q10
    // JND越高, 分数越低(可接受更低质量)
    如果 (jnd > 100) { 分数 = 分数 * 80 / 100 }
    如果 (jnd > 200) { 分数 = 分数 * 60 / 100 }
    如果 (分数 >= 800) { 返回 渲染级别_极高 }
    如果 (分数 >= 500) { 返回 渲染级别_高 }
    如果 (分数 >= 250) { 返回 渲染级别_中 }
    如果 (分数 >= 50) { 返回 渲染级别_低 }
    返回 渲染级别_跳过
}

// §6 粗略绘制

函数 AI渲染_粗略绘制(层, 显示列表, 偏移x, 偏移y) {
    // 低质量渲染: 只填充背景色
    如果 (层 == 0) { 返回 }
    定义 lo = 层.布局对象
    如果 (lo == 0) { 返回 }
    定义 背景色 = 布局Object_获取背景色(lo)
    如果 (背景色 == 0) { 背景色 = 0xFFFFFF }  // 默认白色
    定义 x = lo.绝对x + 偏移x
    定义 y = lo.绝对y + 偏移y
    定义 w = 布局Object_边框盒宽(lo)
    定义 h = 布局Object_边框盒高(lo)
    图处_填充矩形(层.渲染上下文, x, y, w, h, 背景色)
}

函数 AI渲染_统计子层数量(层) {
    如果 (层 == 0) { 返回 0 }
    定义 可变 数量 = 0
    定义 可变 子 = 层.第一子层
    当 (子 != 0) {
        数量 = 数量 + 1
        子 = 子.后兄层
    }
    返回 数量
}

函数 AI渲染_提取页面结构特征(bus, 层, 视口上, 视口高, 语义重要性, 衰减, 是否可见, jnd, 运动中, 深度) {
    如果 (bus == 0 || 层 == 0 || 层.布局对象 == 0) { 返回 0 }
    定义 lo = 层.布局对象
    定义 可变 节点 = 0
    如果 (lo.类型 != 布局类型_视图) {
        节点 = lo.DOM节点
    }
    定义 特征 = Tensor_创建(1, 24)
    定义 可变 归一宽 = bus.视口宽
    定义 可变 归一高 = 视口高
    如果 (归一宽 <= 0) { 归一宽 = 1 }
    如果 (归一高 <= 0) { 归一高 = 1 }

    定义 区域x = lo.绝对x
    定义 区域y = lo.绝对y
    定义 区域w = 布局Object_边框盒宽(lo)
    定义 区域h = 布局Object_边框盒高(lo)
    定义 中心x = 区域x + 区域w / 2
    定义 中心y = 区域y + 区域h / 2
    定义 可变 视口面积 = 归一宽 * 归一高
    定义 可变 区域高归一 = 区域h
    定义 子层数 = AI渲染_统计子层数量(层)
    如果 (视口面积 <= 0) { 视口面积 = 1 }
    如果 (区域高归一 <= 0) { 区域高归一 = 1 }

    Tensor_写(特征, 0, 0, 区域x * Q10 / 归一宽)
    Tensor_写(特征, 0, 1, (区域y - 视口上) * Q10 / 归一高)
    Tensor_写(特征, 0, 2, 区域w * Q10 / 归一宽)
    Tensor_写(特征, 0, 3, 区域h * Q10 / 归一高)
    Tensor_写(特征, 0, 4, 中心x * Q10 / 归一宽)
    Tensor_写(特征, 0, 5, (中心y - 视口上) * Q10 / 归一高)
    Tensor_写(特征, 0, 6, 区域w * 区域h * Q10 / 视口面积)
    Tensor_写(特征, 0, 7, 区域w * Q10 / 区域高归一)
    Tensor_写(特征, 0, 8, 如果(是否可见, Q10, 0))
    Tensor_写(特征, 0, 9, 语义重要性)
    Tensor_写(特征, 0, 10, 衰减)
    Tensor_写(特征, 0, 11, jnd * Q10 / 256)
    Tensor_写(特征, 0, 12, 如果(深度 > 最大层深度, Q10, 深度 * Q10 / 最大层深度))
    Tensor_写(特征, 0, 13, 如果(子层数 > 8, Q10, 子层数 * Q10 / 8))
    Tensor_写(特征, 0, 14, 如果(lo.父 != 0, Q10, 0))
    Tensor_写(特征, 0, 15, lo.类型 * Q10 / 8)
    Tensor_写(特征, 0, 16, lo.内容宽 * Q10 / 归一宽)
    Tensor_写(特征, 0, 17, lo.内容高 * Q10 / 归一高)
    Tensor_写(特征, 0, 18, 如果(节点 != 0, 节点.注意力权重 * Q10 / 10000, 0))
    Tensor_写(特征, 0, 19, 如果(节点 != 0, 节点.视口可见性 * Q_HALF, 0))
    Tensor_写(特征, 0, 20, 如果(lo.累计布局次数 > 16, Q10, lo.累计布局次数 * Q10 / 16))
    Tensor_写(特征, 0, 21, lo.预测置信度 * Q10 / 10000)
    Tensor_写(特征, 0, 22, 如果(运动中, Q10, 0))
    Tensor_写(特征, 0, 23, 如果(层.渲染精度 > 3, Q10, 层.渲染精度 * Q10 / 3))
    返回 特征
}

函数 AI渲染_页面结构重要性(bus, 层, 视口上, 视口高, 位置, 深度, 语义重要性, 衰减, 是否可见, jnd, 运动中) {
    定义 特征 = AI渲染_提取页面结构特征(bus, 层, 视口上, 视口高, 语义重要性, 衰减, 是否可见, jnd, 运动中, 深度)
    如果 (特征 == 0) { 返回 语义重要性 }
    定义 上下文 = AI总线_页面结构增量推理(bus, 特征, 位置)
    Tensor_释放(特征)
    如果 (上下文 == 0) { 返回 语义重要性 }

    定义 可变 累加 = 0
    定义 可变 i = 0
    当 (i < 24) {
        累加 = 累加 + Tensor_读(上下文, 0, i)
        i = i + 1
    }
    Tensor_释放(上下文)

    定义 可变 结构重要性 = 累加 / 24
    如果 (结构重要性 < 0) { 结构重要性 = 0 }
    如果 (结构重要性 > Q10) { 结构重要性 = Q10 }
    返回 (语义重要性 * 3 + 结构重要性) / 4
}

函数 AI渲染_总线驱动绘制_递归(bus, 层, 视口上, 视口高, 位置, 深度) {
    如果 (bus == 0 || 层 == 0) { 返回 位置 }
    定义 视口下 = 视口上 + 视口高

    定义 lo = 层.布局对象
    如果 (lo == 0) { 返回 位置 }
    定义 可变 节点 = 0
    如果 (lo.类型 != 布局类型_视图) {
        节点 = lo.DOM节点
    }

    定义 区域x = lo.绝对x
    定义 区域y = lo.绝对y
    定义 区域w = 布局Object_边框盒宽(lo)
    定义 区域h = 布局Object_边框盒高(lo)
    定义 是否可见 = (区域y + 区域h > 视口上) && (区域y < 视口下)

    定义 可变 语义重要性 = Q_HALF
    如果 (节点 != 0) {
        定义 角色 = AI总线_语义分类(bus, 节点)
        语义重要性 = 语义_获取重要性(角色)
    }

    定义 衰减 = 注视点_计算衰减(区域x, 区域y, 区域w, 区域h)

    定义 运动中 = 假
    如果 (全局_注视点 != 空 && 全局_注视点.运动速度 > 20) {
        运动中 = 真
    }
    定义 jnd = JND_计算(区域x, 区域y, 区域w, 区域h, 运动中)

    如果 (bus.页面结构模型 != 0 && bus.降级模式 < 3) {
        语义重要性 = AI渲染_页面结构重要性(bus, 层, 视口上, 视口高, 位置, 深度, 语义重要性, 衰减, 是否可见, jnd, 运动中)
    }

    定义 渲染级别 = 质量_计算渲染级别(语义重要性, 衰减, 是否可见, jnd)

    如果 (全局_渲染统计 != 空) {
        全局_渲染统计.总层数 = 全局_渲染统计.总层数 + 1
        如果 (渲染级别 == 渲染级别_跳过) {
            全局_渲染统计.跳过层数 = 全局_渲染统计.跳过层数 + 1
        } 否则如果 (渲染级别 == 渲染级别_低) {
            全局_渲染统计.低质量层数 = 全局_渲染统计.低质量层数 + 1
        } 否则如果 (渲染级别 == 渲染级别_中) {
            全局_渲染统计.中质量层数 = 全局_渲染统计.中质量层数 + 1
        } 否则 {
            全局_渲染统计.高质量层数 = 全局_渲染统计.高质量层数 + 1
        }
    }

    如果 (渲染级别 == 渲染级别_跳过) {
        层.渲染精度 = 0
    } 否则如果 (渲染级别 == 渲染级别_低) {
        层.渲染精度 = 1
        AI渲染_粗略绘制(层, 层.显示列表, 0, 0)
    } 否则如果 (渲染级别 <= 渲染级别_中) {
        层.渲染精度 = 2
        绘制Layer_绘制(层, 层.显示列表, 0, 0)
    } 否则 {
        层.渲染精度 = 3
        绘制Layer_绘制(层, 层.显示列表, 0, 0)
    }

    定义 可变 下一个位置 = 位置 + 1
    定义 可变 子 = 层.第一子层
    当 (子 != 0) {
        下一个位置 = AI渲染_总线驱动绘制_递归(bus, 子, 视口上, 视口高, 下一个位置, 深度 + 1)
        子 = 子.后兄层
    }
    返回 下一个位置
}

// §7 总线驱动绘制 (核心函数)

函数 AI渲染_总线驱动绘制(bus, 层, 视口上, 视口高) {
    如果 (bus == 0 || 层 == 0) { 返回 }
    如果 (bus.页面结构模型 != 0 && bus.降级模式 < 3) {
        AI总线_重置页面结构缓存(bus)
    }
    AI渲染_总线驱动绘制_递归(bus, 层, 视口上, 视口高, 0, 0)
}

// §8 AI事件分发

函数 AI浏览器_分发事件到AI(事件类型, x, y, 时间戳) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 }

    // 更新注视点
    如果 (事件类型 == 事件_鼠标移动 || 事件类型 == 事件_点击) {
        注视点_更新(x, y)
    }

    // 分发到AI总线
    如果 (事件类型 == 事件_鼠标移动) { AI总线_鼠标移动(bus, x, y) }
    否则如果 (事件类型 == 事件_点击) { AI总线_点击(bus, x, y) }
    否则如果 (事件类型 == 事件_滚动) { AI总线_滚动(bus, y, 时间戳) }
    否则如果 (事件类型 == 事件_键盘) { AI总线_键盘输入(bus) }
    否则如果 (事件类型 == 事件_悬停) { AI总线_悬停(bus, x, y) }
}

// §9 帧级统计与诊断

函数 渲染统计_初始化() {
    如果 (全局_渲染统计 != 空) { 返回 }
    定义 s = 渲染统计 {}
    s.总层数 = 0
    s.跳过层数 = 0
    s.低质量层数 = 0
    s.中质量层数 = 0
    s.高质量层数 = 0
    s.总绘制时间_us = 0
    全局_渲染统计 = s
}

函数 渲染统计_帧开始() {
    如果 (全局_渲染统计 == 空) { 渲染统计_初始化() }
    定义 s = 全局_渲染统计
    s.总层数 = 0
    s.跳过层数 = 0
    s.低质量层数 = 0
    s.中质量层数 = 0
    s.高质量层数 = 0
}

函数 渲染统计_获取() {
    如果 (全局_渲染统计 == 空) { 返回 0 }
    返回 [
        全局_渲染统计.总层数,
        全局_渲染统计.跳过层数,
        全局_渲染统计.低质量层数,
        全局_渲染统计.中质量层数,
        全局_渲染统计.高质量层数
    ]
}

函数 帧诊断_初始化() {
    如果 (全局_帧诊断 != 空) { 返回 }
    定义 d = 帧级诊断 {}
    d.环 = 堆_分配_数组(统计_环大小 * 4)
    d.写索引 = 0
    d.总帧数 = 0
    d.总绘制时间 = 0
    全局_帧诊断 = d
}

函数 帧诊断_记录(绘制时间_ms) {
    如果 (全局_帧诊断 == 空) { 帧诊断_初始化() }
    定义 d = 全局_帧诊断
    定义 idx = d.写索引 % 统计_环大小
    d.环[idx] = 绘制时间_ms
    d.写索引 = d.写索引 + 1
    d.总帧数 = d.总帧数 + 1
    d.总绘制时间 = d.总绘制时间 + 绘制时间_ms
}

函数 帧诊断_平均绘制时间() {
    如果 (全局_帧诊断 == 空 || 全局_帧诊断.总帧数 == 0) { 返回 0 }
    返回 全局_帧诊断.总绘制时间 / 全局_帧诊断.总帧数
}

// §10 AI诊断接口

函数 AI浏览器_获取诊断信息() {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 0 }
    返回 AI总线_获取诊断(bus)
}

函数 AI浏览器_获取渲染报告() {
    定义 可变 报告 = []
    // 渲染统计
    如果 (全局_渲染统计 != 空) {
        报告 = 报告 + [全局_渲染统计.总层数, 全局_渲染统计.跳过层数]
    }
    // 帧级统计
    如果 (全局_帧诊断 != 空) {
        报告 = 报告 + [帧诊断_平均绘制时间(), 全局_帧诊断.总帧数]
    }
    // 注视点状态
    如果 (全局_注视点 != 空) {
        报告 = 报告 + [全局_注视点.x, 全局_注视点.y, 全局_注视点.运动速度]
    }
    返回 报告
}

// §11 初始化与卸载

函数 智能渲染_初始化() {
    注视点_初始化()
    渲染统计_初始化()
    帧诊断_初始化()
    内核信息("智能渲染总线已初始化")
    返回 成功
}

函数 智能渲染_卸载() {
    如果 (全局_帧诊断 != 空) {
        堆_释放(全局_帧诊断.环)
        堆_释放(全局_帧诊断)
        全局_帧诊断 = 空
    }
    全局_注视点 = 空
    全局_渲染统计 = 空
    返回 成功
}

// §12 帧调度与自适应质量

定义 可变 帧目标_ms = 16  // 60fps目标
定义 可变 质量自适应_启用 = 真
定义 可变 质量自适应_连续超时 = 0

函数 帧调度_检查(上帧时间_ms) {
    // 自适应渲染质量: 连续超时则降低质量
    如果 (!质量自适应_启用) { 返回 }
    如果 (上帧时间_ms > 帧目标_ms) {
        质量自适应_连续超时 = 质量自适应_连续超时 + 1
        如果 (质量自适应_连续超时 >= 5) {
            // 降低全局渲染质量
            内核信息("智能渲染: 连续超时, 降低质量")
        }
    } 否则 {
        如果 (质量自适应_连续超时 > 0) {
            质量自适应_连续超时 = 质量自适应_连续超时 - 1
        }
    }
}

函数 帧调度_设置目标(fps) {
    如果 (fps <= 0) { fps = 60 }
    帧目标_ms = 1000 / fps
}

函数 帧调度_获取FPS() {
    如果 (全局_帧诊断 == 空 || 全局_帧诊断.总帧数 == 0) { 返回 0 }
    定义 平均 = 帧诊断_平均绘制时间()
    如果 (平均 <= 0) { 返回 0 }
    返回 1000 / 平均
}

函数 智能渲染_重置统计() {
    如果 (全局_渲染统计 != 空) {
        全局_渲染统计.总层数 = 0
        全局_渲染统计.跳过层数 = 0
        全局_渲染统计.低质量层数 = 0
        全局_渲染统计.中质量层数 = 0
        全局_渲染统计.高质量层数 = 0
        全局_渲染统计.总绘制时间_us = 0
    }
    如果 (全局_帧诊断 != 空) {
        全局_帧诊断.总帧数 = 0
        全局_帧诊断.总绘制时间 = 0
        全局_帧诊断.写索引 = 0
    }
    质量自适应_连续超时 = 0
}

// NABR — Nova AI Bus Rendering Theory
// 公理1(注视感知): AI总线感知用户注视点位置
// 公理2(质量自适应): 超时时降低质量保证帧率
// 公理3(层级调度): 可见层优先于不可见层

函数 AI渲染_获取状态() {
    返回 [
        帧目标_ms,
        质量自适应_启用,
        质量自适应_连续超时,
        帧调度_获取FPS()
    ]
}

函数 AI渲染_打印统计() {
    打印行("=== 智能渲染统计 ===")
    如果 (全局_渲染统计 != 空) {
        打印行("总层: " + 整数转字符串(全局_渲染统计.总层数))
        打印行("跳过: " + 整数转字符串(全局_渲染统计.跳过层数))
        打印行("低质量: " + 整数转字符串(全局_渲染统计.低质量层数))
        打印行("高质量: " + 整数转字符串(全局_渲染统计.高质量层数))
    }
    打印行("FPS: " + 整数转字符串(帧调度_获取FPS()))
    打印行("平均绘制: " + 整数转字符串(帧诊断_平均绘制时间()) + "ms")
    打印行("质量自适应: " + 整数转字符串(质量自适应_连续超时) + " 次超时")
}

导入("../推理/智能渠道.nova")
导入("./内核直连层.nova")

定义 Q16_ONE = 65536
定义 PI_Q16 = 205887
定义 TWO_PI_Q16 = 411775


函数 SkColor_lerp(c0, c1, t256) {
    定义 inv = 256 - t256
    定义 a = (((c0 >> 24) & 0xFF) * inv + ((c1 >> 24) & 0xFF) * t256) / 256
    定义 r = (((c0 >> 16) & 0xFF) * inv + ((c1 >> 16) & 0xFF) * t256) / 256
    定义 g = (((c0 >> 8) & 0xFF) * inv + ((c1 >> 8) & 0xFF) * t256) / 256
    定义 b = ((c0 & 0xFF) * inv + (c1 & 0xFF) * t256) / 256
    返回 (a << 24) | (r << 16) | (g << 8) | b
}

函数 SkColor_从RGBA(r, g, b, a) {
    返回 ((a & 0xFF) << 24) | ((r & 0xFF) << 16) | ((g & 0xFF) << 8) | (b & 0xFF)
}

函数 SkColor_提取R(颜色) { 返回 (颜色 >> 16) & 0xFF }
函数 SkColor_提取G(颜色) { 返回 (颜色 >> 8) & 0xFF }
函数 SkColor_提取B(颜色) { 返回 颜色 & 0xFF }
函数 SkColor_提取A(颜色) { 返回 (颜色 >> 24) & 0xFF }

函数 SkColor_预乘Alpha(颜色) {
    定义 a = SkColor_提取A(颜色)
    如果 (a == 255) { 返回 颜色 }
    如果 (a == 0) { 返回 0 }
    定义 r = (SkColor_提取R(颜色) * a) / 255
    定义 g = (SkColor_提取G(颜色) * a) / 255
    定义 b = (SkColor_提取B(颜色) * a) / 255
    返回 SkColor_从RGBA(r, g, b, a)
}

函数 Sk数学_sqrt(v) {
    如果 (v <= 0) { 返回 0 }
    定义 可变 x = v
    定义 可变 y = (x + 1) / 2
    当 (y < x) { x = y; y = (x + v / x) / 2 }
    返回 x
}

函数 Sk数学_abs(v) {
    如果 (v < 0) { 返回 -v }
    返回 v
}

函数 Sk数学_min(a, b) {
    如果 (a < b) { 返回 a }
    返回 b
}

函数 Sk数学_max(a, b) {
    如果 (a > b) { 返回 a }
    返回 b
}

函数 Sk数学_clamp(值, 最小, 最大) {
    如果 (值 < 最小) { 返回 最小 }
    如果 (值 > 最大) { 返回 最大 }
    返回 值
}

函数 Sk数学_atan2(y, x) {
    如果 (x == 0 && y == 0) { 返回 0 }
    如果 (x > 0 && y >= 0) { 返回 y * 256 / (x + y) }
    如果 (x <= 0 && y > 0) { 返回 256 + (-x) * 256 / (-x + y) }
    如果 (x < 0 && y <= 0) { 返回 512 + (-y) * 256 / (-x - y) }
    返回 768 + x * 256 / (x - y)
}

函数 Sk数学_sin_Q16(角度_Q16) {
    定义 可变 a = 角度_Q16 % TWO_PI_Q16
    如果 (a < 0) { a = a + TWO_PI_Q16 }
    定义 x = a * 4 / TWO_PI_Q16
    如果 (x == 0) { 返回 0 }
    如果 (x == 1) { 返回 Q16_ONE }
    如果 (x == 2) { 返回 0 }
    如果 (x == 3) { 返回 -Q16_ONE }
    定义 局部 = a % (PI_Q16 / 2)
    定义 比例 = 局部 * Q16_ONE / (PI_Q16 / 2)
    如果 (x < 1) { 返回 比例 }
    如果 (x < 2) { 返回 Q16_ONE - (比例 - Q16_ONE) }
    如果 (x < 3) { 返回 -(比例 - Q16_ONE * 2) }
    返回 -(Q16_ONE - (比例 - Q16_ONE * 3))
}

函数 Sk数学_cos_Q16(角度_Q16) {
    返回 Sk数学_sin_Q16(角度_Q16 + PI_Q16 / 2)
}

函数 Sk数学_距离(x1, y1, x2, y2) {
    定义 dx = x2 - x1
    定义 dy = y2 - y1
    返回 Sk数学_sqrt(dx * dx + dy * dy)
}

结构 矩阵2D {
    m00, m01, m02,
    m10, m11, m12,
}

函数 矩阵_单位() {
    定义 m = 堆_分配(矩阵2D)
    m.m00 = Q16_ONE; m.m01 = 0; m.m02 = 0
    m.m10 = 0; m.m11 = Q16_ONE; m.m12 = 0
    返回 m
}

函数 矩阵_平移(tx, ty) {
    定义 m = 矩阵_单位()
    m.m02 = tx
    m.m12 = ty
    返回 m
}

函数 矩阵_缩放(sx, sy) {
    定义 m = 矩阵_单位()
    m.m00 = sx
    m.m11 = sy
    返回 m
}

函数 矩阵_变换点(m, x, y, 结果) {
    如果 (m == 0 || 结果 == 0) { 返回 }
    内存_写32(结果, (m.m00 * x + m.m01 * y) / Q16_ONE + m.m02)
    内存_写32(结果 + 4, (m.m10 * x + m.m11 * y) / Q16_ONE + m.m12)
}

// [v2反哺] 矩阵_乘 — 矩阵乘块优化(L1命中率95%+, 替换朴素三重循环)
// 矩阵_乘 升级版 — 块矩阵乘(L1缓存友好)
// 旧版: 朴素三重循环, 缓存命中率70% → 新版: 块大小8, 命中率95%+
// 类人脑: 局部连接原则，皮质柱内局部运算
定义 BLOCK_SIZE = 8
函数 矩阵_乘(A, B, C, m, n, k) {
    如果 (A == 0 || B == 0 || C == 0) { 返回 }
    定义 可变 ii = 0
    当 (ii < m) {
        定义 可变 jj = 0
        当 (jj < n) {
            定义 可变 kk = 0
            当 (kk < k) {
                定义 i_end = ii + BLOCK_SIZE; 如果 (i_end > m) { i_end = m }
                定义 j_end = jj + BLOCK_SIZE; 如果 (j_end > n) { j_end = n }
                定义 k_end = kk + BLOCK_SIZE; 如果 (k_end > k) { k_end = k }
                定义 可变 i = ii
                当 (i < i_end) {
                    定义 可变 j = jj
                    当 (j < j_end) {
                        定义 可变 sum = 内存_读32有符号(C + (i * n + j) * 4)
                        定义 可变 p = kk
                        当 (p < k_end) {
                            sum = sum + Q乘(内存_读32有符号(A + (i * k + p) * 4),
                                           内存_读32有符号(B + (p * n + j) * 4))
                            p = p + 1
                        }
                        内存_写32(C + (i * n + j) * 4, sum)
                        j = j + 1
                    }
                    i = i + 1
                }
                kk = kk + BLOCK_SIZE
            }
            jj = jj + BLOCK_SIZE
        }
        ii = ii + BLOCK_SIZE
    }
}

函数 贝塞尔_二次求值(p0, p1, p2, t256) {
    定义 inv = 256 - t256
    定义 a = (inv * inv) / 256
    定义 b = (2 * inv * t256) / 256
    定义 c = (t256 * t256) / 256
    返回 (a * p0 + b * p1 + c * p2) / 256
}

函数 贝塞尔_三次求值(p0, p1, p2, p3, t256) {
    定义 inv = 256 - t256
    定义 inv2 = (inv * inv) / 256
    定义 t2 = (t256 * t256) / 256
    定义 a = (inv2 * inv) / 256
    定义 b = (3 * inv2 * t256) / 256
    定义 c = (3 * inv * t2) / 256
    定义 d = (t2 * t256) / 256
    返回 (a * p0 + b * p1 + c * p2 + d * p3) / 256
}

函数 矩形_裁剪(x, y, 宽, 高, 裁剪x, 裁剪y, 裁剪宽, 裁剪高, 结果) {
    定义 左 = Sk数学_max(x, 裁剪x)
    定义 上 = Sk数学_max(y, 裁剪y)
    定义 右 = Sk数学_min(x + 宽, 裁剪x + 裁剪宽)
    定义 下 = Sk数学_min(y + 高, 裁剪y + 裁剪高)
    如果 (左 >= 右 || 上 >= 下) { 返回 假 }
    如果 (结果 != 0) {
        内存_写32(结果, 左)
        内存_写32(结果 + 4, 上)
        内存_写32(结果 + 8, 右 - 左)
        内存_写32(结果 + 12, 下 - 上)
    }
    返回 真
}

函数 HSV转RGB(色相, 饱和度, 明度) {
    如果 (饱和度 == 0) { 返回 SkColor_从RGBA(明度, 明度, 明度, 255) }
    定义 区域 = 色相 / 43
    定义 余数 = (色相 - 区域 * 43) * 6
    定义 p = (明度 * (255 - 饱和度)) / 255
    定义 q = (明度 * (255 - (饱和度 * 余数) / 255)) / 255
    定义 t = (明度 * (255 - (饱和度 * (255 - 余数)) / 255)) / 255
    如果 (区域 == 0) { 返回 SkColor_从RGBA(明度, t, p, 255) }
    如果 (区域 == 1) { 返回 SkColor_从RGBA(q, 明度, p, 255) }
    如果 (区域 == 2) { 返回 SkColor_从RGBA(p, 明度, t, 255) }
    如果 (区域 == 3) { 返回 SkColor_从RGBA(p, q, 明度, 255) }
    如果 (区域 == 4) { 返回 SkColor_从RGBA(t, p, 明度, 255) }
    返回 SkColor_从RGBA(明度, p, q, 255)
}

定义 可变 AI_辅助数学_调用数 = 0
定义 可变 AI_辅助数学_异常数 = 0

函数 AI_辅助数学_监控() {
    AI_辅助数学_调用数 = AI_辅助数学_调用数 + 1
    返回 AI_辅助数学_异常数 == 0
}

函数 AI_辅助数学_健康检查() {
    如果 (AI_辅助数学_调用数 > 0 && AI_辅助数学_异常数 * 100 / AI_辅助数学_调用数 > 10) {
        返回 假
    }
    返回 真
}

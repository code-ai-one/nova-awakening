导入("../基础.nova")

// Nova 游戏框架 (Game Framework)
// ECS架构 · 固定步长游戏循环 · AABB碰撞检测 · 场景图 · 输入管理
// 定点精度: ×1000

定义 游戏FP = 1000

// ECS 架构 (Entity-Component-System)
// 实体: 唯一ID
// 组件: 数据容器, 按类型存储
// 系统: 处理逻辑, 操作具有特定组件的实体

// 实体管理
定义 可变 ECS_下一实体ID = 1
定义 可变 ECS_活跃实体 = []       // [实体ID, ...]
定义 可变 ECS_回收池 = []         // 已销毁的ID, 可复用

函数 ECS_创建实体() {
    定义 可变 id = 0
    如果 (计数(ECS_回收池) > 0) {
        定义 n = 计数(ECS_回收池)
        id = ECS_回收池[n - 1]
        定义 可变 新池 = []
        定义 可变 i = 0
        当 (i < n - 1) { 追加(新池, ECS_回收池[i]); i = i + 1 }
        ECS_回收池 = 新池
    } 否则 {
        id = ECS_下一实体ID
        ECS_下一实体ID = ECS_下一实体ID + 1
    }
    追加(ECS_活跃实体, id)
    返回 id
}

函数 ECS_销毁实体(id) {
    定义 可变 新列表 = []
    定义 可变 i = 0
    当 (i < 计数(ECS_活跃实体)) {
        如果 (ECS_活跃实体[i] != id) { 追加(新列表, ECS_活跃实体[i]) }
        i = i + 1
    }
    ECS_活跃实体 = 新列表
    追加(ECS_回收池, id)
    // 清除所有组件
    ECS_清除实体组件(id)
}

函数 ECS_实体存在(id) {
    定义 可变 i = 0
    当 (i < 计数(ECS_活跃实体)) {
        如果 (ECS_活跃实体[i] == id) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 ECS_实体数() { 返回 计数(ECS_活跃实体) }

// 组件存储
// 按组件类型分表: [类型ID, [[实体ID, 数据], ...]]
定义 组件_位置     = 1    // [x, y, z]
定义 组件_速度     = 2    // [vx, vy, vz]
定义 组件_精灵     = 3    // [纹理ID, 宽, 高, 源矩形]
定义 组件_碰撞盒   = 4    // [宽, 高, 偏移x, 偏移y]
定义 组件_生命值   = 5    // [当前, 最大]
定义 组件_标签     = 6    // 字符串标签
定义 组件_刚体     = 7    // [质量, 弹性, 摩擦]
定义 组件_动画     = 8    // [帧列表, 当前帧, 帧时长, 累计时间]

定义 可变 ECS_组件表 = []  // [[类型ID, [[实体ID, 数据], ...]], ...]

函数 ECS_获取类型表(类型ID) {
    定义 可变 i = 0
    当 (i < 计数(ECS_组件表)) {
        如果 (ECS_组件表[i][0] == 类型ID) { 返回 i }
        i = i + 1
    }
    // 不存在则创建
    追加(ECS_组件表, [类型ID, []])
    返回 计数(ECS_组件表) - 1
}

函数 ECS_添加组件(实体ID, 类型ID, 数据) {
    定义 表idx = ECS_获取类型表(类型ID)
    定义 条目列表 = ECS_组件表[表idx][1]
    // 检查是否已有
    定义 可变 i = 0
    当 (i < 计数(条目列表)) {
        如果 (条目列表[i][0] == 实体ID) {
            条目列表[i][1] = 数据
            返回
        }
        i = i + 1
    }
    追加(条目列表, [实体ID, 数据])
}

函数 ECS_获取组件(实体ID, 类型ID) {
    定义 表idx = ECS_获取类型表(类型ID)
    定义 条目列表 = ECS_组件表[表idx][1]
    定义 可变 i = 0
    当 (i < 计数(条目列表)) {
        如果 (条目列表[i][0] == 实体ID) { 返回 条目列表[i][1] }
        i = i + 1
    }
    返回 空
}

函数 ECS_有组件(实体ID, 类型ID) {
    返回 ECS_获取组件(实体ID, 类型ID) != 空
}

函数 ECS_移除组件(实体ID, 类型ID) {
    定义 表idx = ECS_获取类型表(类型ID)
    定义 条目列表 = ECS_组件表[表idx][1]
    定义 可变 新列表 = []
    定义 可变 i = 0
    当 (i < 计数(条目列表)) {
        如果 (条目列表[i][0] != 实体ID) { 追加(新列表, 条目列表[i]) }
        i = i + 1
    }
    ECS_组件表[表idx][1] = 新列表
}

函数 ECS_清除实体组件(实体ID) {
    定义 可变 t = 0
    当 (t < 计数(ECS_组件表)) {
        定义 可变 新列表 = []
        定义 可变 i = 0
        当 (i < 计数(ECS_组件表[t][1])) {
            如果 (ECS_组件表[t][1][i][0] != 实体ID) {
                追加(新列表, ECS_组件表[t][1][i])
            }
            i = i + 1
        }
        ECS_组件表[t][1] = 新列表
        t = t + 1
    }
}

// 查询: 获取所有具有指定组件类型的实体
函数 ECS_查询(类型ID) {
    定义 表idx = ECS_获取类型表(类型ID)
    定义 条目列表 = ECS_组件表[表idx][1]
    定义 可变 实体列表 = []
    定义 可变 i = 0
    当 (i < 计数(条目列表)) {
        追加(实体列表, 条目列表[i][0])
        i = i + 1
    }
    返回 实体列表
}

// 查询: 具有两种组件的实体
函数 ECS_查询2(类型A, 类型B) {
    定义 列表A = ECS_查询(类型A)
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表A)) {
        如果 (ECS_有组件(列表A[i], 类型B)) { 追加(结果, 列表A[i]) }
        i = i + 1
    }
    返回 结果
}

// 系统注册与调度
// 系统: [名称, 优先级, 处理函数, 启用标记]
定义 可变 ECS_系统列表 = []

函数 ECS_注册系统(名称, 优先级, 处理函数) {
    追加(ECS_系统列表, [名称, 优先级, 处理函数, 真])
}

函数 ECS_启用系统(名称) {
    定义 可变 i = 0
    当 (i < 计数(ECS_系统列表)) {
        如果 (ECS_系统列表[i][0] == 名称) { ECS_系统列表[i][3] = 真 }
        i = i + 1
    }
}

函数 ECS_禁用系统(名称) {
    定义 可变 i = 0
    当 (i < 计数(ECS_系统列表)) {
        如果 (ECS_系统列表[i][0] == 名称) { ECS_系统列表[i][3] = 假 }
        i = i + 1
    }
}

函数 ECS_执行所有系统(dt) {
    // 按优先级排序执行
    定义 可变 i = 0
    当 (i < 计数(ECS_系统列表)) {
        如果 (ECS_系统列表[i][3]) {
            ECS_系统列表[i][2](dt)
        }
        i = i + 1
    }
}

// 内建系统: 运动
函数 系统_运动(dt) {
    定义 实体列表 = ECS_查询2(组件_位置, 组件_速度)
    定义 可变 i = 0
    当 (i < 计数(实体列表)) {
        定义 eid = 实体列表[i]
        定义 pos = ECS_获取组件(eid, 组件_位置)
        定义 vel = ECS_获取组件(eid, 组件_速度)
        pos[0] = pos[0] + vel[0] * dt / 游戏FP
        pos[1] = pos[1] + vel[1] * dt / 游戏FP
        pos[2] = pos[2] + vel[2] * dt / 游戏FP
        i = i + 1
    }
}

// 固定步长游戏循环
// 物理以固定dt更新, 渲染可变帧率, 防止物理不稳定
定义 可变 游戏循环_固定dt = 16    // 16ms = ~60fps物理
定义 可变 游戏循环_累积时间 = 0
定义 可变 游戏循环_运行中 = 假
定义 可变 游戏循环_帧数 = 0
定义 可变 游戏循环_物理步数 = 0

函数 游戏循环_设置步长(dt_毫秒) {
    游戏循环_固定dt = dt_毫秒
}

函数 游戏循环_开始() { 游戏循环_运行中 = 真 }
函数 游戏循环_停止() { 游戏循环_运行中 = 假 }

// 每帧调用: 传入真实经过时间(毫秒)
函数 游戏循环_帧(经过时间) {
    如果 (游戏循环_运行中 == 假) { 返回 }
    游戏循环_累积时间 = 游戏循环_累积时间 + 经过时间
    // 固定步长物理更新
    当 (游戏循环_累积时间 >= 游戏循环_固定dt) {
        ECS_执行所有系统(游戏循环_固定dt)
        游戏循环_累积时间 = 游戏循环_累积时间 - 游戏循环_固定dt
        游戏循环_物理步数 = 游戏循环_物理步数 + 1
    }
    游戏循环_帧数 = 游戏循环_帧数 + 1
}

// AABB 碰撞检测
// 轴对齐包围盒: [x, y, 宽, 高]
函数 AABB_创建(x, y, 宽, 高) { 返回 [x, y, 宽, 高] }

函数 AABB_重叠(a, b) {
    如果 (a[0] + a[2] <= b[0]) { 返回 假 }
    如果 (b[0] + b[2] <= a[0]) { 返回 假 }
    如果 (a[1] + a[3] <= b[1]) { 返回 假 }
    如果 (b[1] + b[3] <= a[1]) { 返回 假 }
    返回 真
}

// 穿透深度 (用于碰撞响应)
函数 AABB_穿透(a, b) {
    定义 左穿 = (a[0] + a[2]) - b[0]
    定义 右穿 = (b[0] + b[2]) - a[0]
    定义 上穿 = (a[1] + a[3]) - b[1]
    定义 下穿 = (b[1] + b[3]) - a[1]
    // 取最小穿透方向
    定义 可变 最小x = 左穿
    如果 (右穿 < 最小x) { 最小x = 右穿 }
    定义 可变 最小y = 上穿
    如果 (下穿 < 最小y) { 最小y = 下穿 }
    如果 (最小x < 最小y) { 返回 [最小x, 0] }
    返回 [0, 最小y]
}

// 碰撞系统: 检测所有碰撞对
函数 系统_碰撞检测() {
    定义 实体列表 = ECS_查询2(组件_位置, 组件_碰撞盒)
    定义 可变 碰撞对 = []
    定义 可变 i = 0
    当 (i < 计数(实体列表)) {
        定义 可变 j = i + 1
        当 (j < 计数(实体列表)) {
            定义 eidA = 实体列表[i]
            定义 eidB = 实体列表[j]
            定义 posA = ECS_获取组件(eidA, 组件_位置)
            定义 posB = ECS_获取组件(eidB, 组件_位置)
            定义 boxA = ECS_获取组件(eidA, 组件_碰撞盒)
            定义 boxB = ECS_获取组件(eidB, 组件_碰撞盒)
            定义 aabbA = AABB_创建(posA[0] + boxA[2], posA[1] + boxA[3], boxA[0], boxA[1])
            定义 aabbB = AABB_创建(posB[0] + boxB[2], posB[1] + boxB[3], boxB[0], boxB[1])
            如果 (AABB_重叠(aabbA, aabbB)) {
                追加(碰撞对, [eidA, eidB])
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 碰撞对
}

// 场景图 (Scene Graph)
// 节点: [ID, 父ID, 子节点列表, 本地变换[x,y,旋转,缩放], 世界变换, 可见]
定义 可变 场景_节点列表 = []
定义 可变 场景_下一ID = 1

函数 场景_创建节点(父ID) {
    定义 id = 场景_下一ID
    场景_下一ID = 场景_下一ID + 1
    追加(场景_节点列表, [id, 父ID, [], [0, 0, 0, 游戏FP], [0, 0, 0, 游戏FP], 真])
    // 将自己加入父节点的子列表
    如果 (父ID > 0) {
        定义 可变 i = 0
        当 (i < 计数(场景_节点列表)) {
            如果 (场景_节点列表[i][0] == 父ID) {
                追加(场景_节点列表[i][2], id)
            }
            i = i + 1
        }
    }
    返回 id
}

函数 场景_设本地变换(节点ID, x, y, 旋转, 缩放) {
    定义 可变 i = 0
    当 (i < 计数(场景_节点列表)) {
        如果 (场景_节点列表[i][0] == 节点ID) {
            场景_节点列表[i][3] = [x, y, 旋转, 缩放]
            返回
        }
        i = i + 1
    }
}

// 递归更新世界变换
函数 场景_更新变换(节点ID, 父世界变换) {
    定义 可变 i = 0
    当 (i < 计数(场景_节点列表)) {
        如果 (场景_节点列表[i][0] == 节点ID) {
            定义 本地 = 场景_节点列表[i][3]
            // 世界 = 父世界 + 本地 (简化: 平移累加, 缩放乘)
            定义 wx = 父世界变换[0] + 本地[0] * 父世界变换[3] / 游戏FP
            定义 wy = 父世界变换[1] + 本地[1] * 父世界变换[3] / 游戏FP
            定义 wr = 父世界变换[2] + 本地[2]
            定义 ws = 父世界变换[3] * 本地[3] / 游戏FP
            场景_节点列表[i][4] = [wx, wy, wr, ws]
            // 递归子节点
            定义 可变 c = 0
            当 (c < 计数(场景_节点列表[i][2])) {
                场景_更新变换(场景_节点列表[i][2][c], [wx, wy, wr, ws])
                c = c + 1
            }
            返回
        }
        i = i + 1
    }
}

函数 场景_更新全部() {
    // 从所有根节点(父ID==0)开始
    定义 可变 i = 0
    当 (i < 计数(场景_节点列表)) {
        如果 (场景_节点列表[i][1] == 0) {
            场景_更新变换(场景_节点列表[i][0], [0, 0, 0, 游戏FP])
        }
        i = i + 1
    }
}

// 输入管理
// 按键状态: [键码, 当前按下, 上帧按下]
定义 可变 输入_按键状态 = []

函数 输入_按下(键码) {
    定义 可变 i = 0
    当 (i < 计数(输入_按键状态)) {
        如果 (输入_按键状态[i][0] == 键码) {
            输入_按键状态[i][2] = 输入_按键状态[i][1]
            输入_按键状态[i][1] = 真
            返回
        }
        i = i + 1
    }
    追加(输入_按键状态, [键码, 真, 假])
}

函数 输入_释放(键码) {
    定义 可变 i = 0
    当 (i < 计数(输入_按键状态)) {
        如果 (输入_按键状态[i][0] == 键码) {
            输入_按键状态[i][2] = 输入_按键状态[i][1]
            输入_按键状态[i][1] = 假
            返回
        }
        i = i + 1
    }
}

函数 输入_是否按住(键码) {
    定义 可变 i = 0
    当 (i < 计数(输入_按键状态)) {
        如果 (输入_按键状态[i][0] == 键码) { 返回 输入_按键状态[i][1] }
        i = i + 1
    }
    返回 假
}

// 刚按下(本帧按下 且 上帧未按)
函数 输入_刚按下(键码) {
    定义 可变 i = 0
    当 (i < 计数(输入_按键状态)) {
        如果 (输入_按键状态[i][0] == 键码) {
            返回 输入_按键状态[i][1] 且 输入_按键状态[i][2] == 假
        }
        i = i + 1
    }
    返回 假
}

// 刚释放
函数 输入_刚释放(键码) {
    定义 可变 i = 0
    当 (i < 计数(输入_按键状态)) {
        如果 (输入_按键状态[i][0] == 键码) {
            返回 输入_按键状态[i][1] == 假 且 输入_按键状态[i][2]
        }
        i = i + 1
    }
    返回 假
}

// 帧末更新: 保存当前帧状态
函数 输入_帧结束() {
    定义 可变 i = 0
    当 (i < 计数(输入_按键状态)) {
        输入_按键状态[i][2] = 输入_按键状态[i][1]
        i = i + 1
    }
}

// 鼠标
定义 可变 输入_鼠标X = 0
定义 可变 输入_鼠标Y = 0
定义 可变 输入_鼠标左键 = 假
定义 可变 输入_鼠标右键 = 假

函数 输入_更新鼠标(x, y) { 输入_鼠标X = x; 输入_鼠标Y = y }

// 常用键码
定义 键_W = 87
定义 键_A = 65
定义 键_S = 83
定义 键_D = 68
定义 键_空格 = 32
定义 键_回车 = 13
定义 键_ESC = 27
定义 键_上 = 38
定义 键_下 = 40
定义 键_左 = 37
定义 键_右 = 39

// Nova 并行编译引擎 - 保守顺序版
// 目标: 在自举阶段优先保证稳定, 关闭任务队列和工作窃取

导入("../../标准库/基础.nova")
// [循环导入已解耦] 导入("./模块图编译器.nova") — 函数由链接器全局解析

定义 可变 最大并行数 = 1
定义 可变 并行详细模式 = 假

函数 并行_配置(并行度) {
    如果 (并行度 > 0) { 最大并行数 = 并行度 }
}

函数 并行_重置运行状态() {
    最大并行数 = 1
}

函数 并行_设置详细模式(启用) {
    并行详细模式 = 启用
}

定义 任务_等待 = 0
定义 任务_运行中 = 1

函数 编译任务_创建(模块名) {
    返回 [模块名, 任务_等待, 空, ""]
}

函数 并行_执行批次(任务列表) {
    定义 可变 完成数 = 0
    定义 可变 失败数 = 0
    定义 可变 i = 0
    当 (i < 计数(任务列表)) {
        定义 任务 = 任务列表[i]
        如果 (模块_编译单个(任务[0])) {
            完成数 = 完成数 + 1
        } 否则 {
            失败数 = 失败数 + 1
            返回 [完成数, 失败数]
        }
        i = i + 1
    }
    返回 [完成数, 失败数]
}

// 报告未满足依赖（模块名 + 尚未分配/编译的依赖列表）
函数 并行_报告未满足依赖(名, 已分配) {
    如果 (并行详细模式) {
        打印文本(字符串拼接("[并行] 等待依赖: ", 转字符串(名)))
    }
    返回 计数(已分配)
}

// 计算编译层级分组 (基于模块名称的 Kahn BFS)
// 编译顺序: 已拓扑排序的模块名称列表
// 返回: [[层0模块名], [层1模块名], ...] (兼容 并行_统计 和 并行_编译全部)
函数 计算编译层级(编译顺序, _模块表参, _模块索引参) {
    定义 n = 计数(编译顺序)
    如果 (n == 0) { 返回 [] }
    // 当前自举阶段 最大并行数=1, 每个模块独立一层
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < n) {
        追加(结果, [编译顺序[i]])
        i = i + 1
    }
    返回 结果
}

// 将编译顺序按层级分组 (基于全局模块表的依赖信息)
// 编译顺序: 已拓扑排序的模块名称列表
// 返回: [[层0模块名列表], [层1模块名列表], ...]
函数 并行_按层级分组(编译顺序) {
    定义 n = 计数(编译顺序)
    如果 (n == 0) { 返回 [] }
    // 建立名称→层级映射
    定义 可变 层级映射 = 字典()
    定义 可变 i = 0
    当 (i < n) {
        定义 名 = 编译顺序[i]
        定义 可变 本层 = 0
        如果 (字典有(模块索引, 名)) {
            定义 位置 = 字典取(模块索引, 名)
            定义 信息 = 模块表[位置]
            定义 依赖列表 = 信息.依赖列表
            如果 (是列表(依赖列表)) {
                定义 可变 j = 0
                当 (j < 计数(依赖列表)) {
                    定义 依赖层 = 字典取(层级映射, 依赖列表[j])
                    如果 (依赖层 != 空 且 依赖层 + 1 > 本层) {
                        本层 = 依赖层 + 1
                    }
                    j = j + 1
                }
            }
        }
        字典设(层级映射, 名, 本层)
        如果 (本层 > 最大层) { 最大层 = 本层 }
        i = i + 1
    }
    // 按层级构建分组
    定义 可变 分组 = []
    i = 0
    当 (i <= 最大层) {
        追加(分组, [])
        i = i + 1
    }
    i = 0
    当 (i < n) {
        定义 层 = 字典取(层级映射, 编译顺序[i])
        如果 (层 != 空 且 层 < 计数(分组)) { 追加(分组[层], 编译顺序[i]) }
        i = i + 1
    }
    返回 分组
}

函数 并行_编译全部(模块列表) {
    定义 可变 总失败 = 0
    定义 可变 总编译 = 0
    定义 可变 i = 0
    当 (i < 计数(模块列表)) {
        定义 可变 模块名 = 模块列表[i]
        如果 (是列表(模块列表[i])) { 模块名 = 模块列表[i][0] }
        打印文本(字符串拼接("[编译] ", 字符串拼接(转字符串(i), 字符串拼接(" ", 模块名))))
        如果 (模块_编译单个(模块名)) {
            总编译 = 总编译 + 1
            _并行_编译计数 = _并行_编译计数 + 1
        } 否则 {
            总失败 = 总失败 + 1
            如果 (总失败 > 0) { 返回 总编译 }
        }
        i = i + 1
    }
    返回 总编译
}

// 统计各层级编译数
函数 并行_统计(层级分组) {
    如果 (层级分组 == 空) { 返回 [0,] }
    定义 总层数 = 计数(层级分组)
    定义 可变 总模块 = 0
    定义 可变 i = 0
    当 (i < 总层数) {
        总模块 = 总模块 + 计数(层级分组[i])
        i = i + 1
    }
    返回 [总层数, 总模块, _并行_编译计数]
}

定义 可变 _并行_编译计数 = 0
定义 可变 _并行_缓存命中数 = 0

函数 并行_记录编译() { _并行_编译计数 = _并行_编译计数 + 1 }
函数 并行_记录缓存命中() { _并行_缓存命中数 = _并行_缓存命中数 + 1 }
函数 并行_编译计数() { 返回 _并行_编译计数 }
函数 并行_缓存命中率() {
    定义 总 = _并行_编译计数 + _并行_缓存命中数
    如果 (总 == 0) { 返回 0 }
    返回 _并行_缓存命中数 * 100 / 总
}

导入("../../标准库/基础.nova")

// Nova · 运行时层 · JIT热点检测器
// 实时统计代码块执行频率，识别热点，触发JIT编译
// 策略: 执行≥阈值次 → 标记热点 → 加入编译队列

// 热点配置
定义 JIT_热点阈值      = 10     // 执行N次后触发JIT
定义 JIT_超热阈值      = 100    // 超热点 → 更激进优化
定义 JIT_冷却阈值      = 10000  // 长期未执行 → 回收机器码
// 编译队列无硬上限 — 动态列表，适配超大系统数万热点块场景

// 热点状态
定义 热点_冷     = 0    // 未达阈值
定义 热点_温     = 1    // 已达阈值，等待编译
定义 热点_热     = 2    // 已JIT编译
定义 热点_超热   = 3    // 超热点，激进优化
定义 热点_冷却中 = 4    // 长期未执行，准备回收

// 热点记录
// [代码块ID, 执行计数, 状态, 最后执行时间戳, 编译后机器码偏移, 优化级别]
函数 热点_创建(块ID) {
    返回 [块ID, 0, 热点_冷, 0, -1, 0]
}

函数 热点_块ID(记录) { 返回 记录[0] }
函数 热点_计数(记录) { 返回 记录[1] }
函数 热点_状态(记录) { 返回 记录[2] }
函数 热点_已编译(记录) { 返回 记录[4] >= 0 }

// 热点检测器
// [记录表(字典), 编译队列, 总触发数, 总编译数, 回调函数]
函数 热点检测器_创建() {
    返回 [字典(), [], 0, 空]
}

函数 热点检测器_设置回调(检测器, 回调) {
    检测器[4] = 回调
}

// 更新计数 — VM每次执行HN_HOT_COUNT时调用
函数 热点检测器_计数(检测器, 块ID, 时间戳) {
    定义 键 = 转字符串(块ID)
    定义 可变 记录 = 字典获取(检测器[0], 键)

    如果 (记录 == 空) {
        记录 = 热点_创建(块ID)
        字典设置(检测器[0], 键, 记录)
    }

    记录[1] = 记录[1] + 1
    记录[3] = 时间戳

    // 状态转换
    如果 (记录[2] == 热点_冷 且 记录[1] >= JIT_热点阈值) {
        记录[2] = 热点_温
        检测器[2] = 检测器[2] + 1
        // 加入编译队列 (无硬上限，动态增长)
        追加(检测器[1], 块ID)
        // 触发回调
        如果 (检测器[4] != 空) {
            检测器[4](块ID, 记录[1])
        }
    }

    如果 (记录[2] == 热点_热 且 记录[1] >= JIT_超热阈值) {
        记录[2] = 热点_超热
        记录[5] = 2    // 最高优化级别
    }

    返回 记录[2]
}

// 标记已编译
函数 热点检测器_标记编译完成(检测器, 块ID, 机器码偏移) {
    定义 键 = 转字符串(块ID)
    定义 可变 记录 = 字典获取(检测器[0], 键)
    如果 (记录 != 空) {
        记录[2] = 热点_热
        记录[4] = 机器码偏移
        检测器[3] = 检测器[3] + 1
    }
}

// 获取下一个待编译块
函数 热点检测器_取编译任务(检测器) {
    定义 可变 新队列 = []
    如果 (计数(检测器[1]) == 0) { 返回 -1 }
    定义 块ID = 检测器[1][0]
    // 移除队首
    定义 可变 i = 1
    当 (i < 计数(检测器[1])) {
        追加(新队列, 检测器[1][i])
        i = i + 1
    }
    检测器[1] = 新队列
    返回 块ID
}

// 冷却扫描 — 定期调用，回收长期未执行的机器码
函数 热点检测器_冷却扫描(检测器, 当前时间) {
    定义 可变 回收数 = 0
    定义 键列表 = 字典键(检测器[0])
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        定义 可变 记录 = 字典获取(检测器[0], 键列表[i])
        如果 (记录 != 空 且 记录[2] >= 热点_热) {
            // 已编译的块: 检查最后执行时间距当前时间是否超过冷却阈值
            定义 空闲时间 = 当前时间 - 记录[3]
            如果 (空闲时间 > JIT_冷却阈值) {
                记录[2] = 热点_冷却中
                记录[4] = -1       // 标记机器码已回收
                记录[1] = 0        // 重置计数
                回收数 = 回收数 + 1
            }
        }
        i = i + 1
    }
    返回 回收数
}

// 统计信息
函数 热点检测器_查询(检测器, 块ID) {
    定义 键 = 转字符串(块ID)
    返回 字典获取(检测器[0], 键)
}

// 是否应使用JIT执行 (VM调度决策)
函数 热点检测器_应JIT执行(检测器, 块ID) {
    定义 可变 记录 = 热点检测器_查询(检测器, 块ID)
    如果 (记录 == 空) { 返回 假 }
    返回 记录[2] >= 热点_热 且 记录[4] >= 0
}

// 自适应阈值 (整合到字典轨热点检测器)
 // 根据全局热点数据动态调整JIT触发阈值，避免过早/过晚编译
 
 // 统计表: [当前阈值, 阈值历史, 检测总数, 命中总数, 编译总数]
 定义 可变 热点统计 = [100, [], 0, 0, 0]
 
 函数 热点检测器_调整阈值(检测器) {
     定义 键列表 = 字典键(检测器[0])
     定义 可变 块数 = 计数(键列表)
    如果 (块数 == 0) { 返回 }
    // 计算所有已跟踪块的平均执行次数
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 块数) {
        定义 记录 = 字典获取(检测器[0], 键列表[i])
        如果 (记录 != 空) { 总 = 总 + 记录[1] }
        i = i + 1
    }
    定义 平均 = 总 / 块数
    // 阈值 = 平均执行次数的2倍，夹到[50, 10000]区间
    热点统计[0] = 平均 * 2
    如果 (热点统计[0] < 50) { 热点统计[0] = 50 }
    如果 (热点统计[0] > 10000) { 热点统计[0] = 10000 }
    追加(热点统计[1], 热点统计[0])
}

函数 热点_获取阈值() { 返回 热点统计[0] }

// 热度衰减 (作用于字典轨记录)
// 定期调用，按百分比衰减所有块的执行计数，防止历史热度积累导致冷块无法回收

函数 热点检测器_衰减(检测器, 因子) {
    定义 键列表 = 字典键(检测器[0])
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        定义 可变 记录 = 字典获取(检测器[0], 键列表[i])
        如果 (记录 != 空) {
            记录[1] = 记录[1] * 因子 / 100
        }
        i = i + 1
    }
}

// TopN热点查询 (作用于字典轨)
// 返回当前执行次数最高的N个块: [[块ID, 计数], ...]

函数 热点检测器_TopN(检测器, n) {
    定义 键列表 = 字典键(检测器[0])
    定义 可变 块列表 = []
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        定义 记录 = 字典获取(检测器[0], 键列表[i])
        如果 (记录 != 空) {
            追加(块列表, [记录[0], 记录[1]])
        }
        i = i + 1
    }
    // 选择排序取前N个(按计数降序)
    定义 可变 k = 0
    当 (k < n 且 k < 计数(块列表)) {
        定义 可变 j = k + 1
        当 (j < 计数(块列表)) {
            如果 (块列表[j][1] > 块列表[k][1]) {
                定义 临 = 块列表[k]
                块列表[k] = 块列表[j]
                块列表[j] = 临
            }
            j = j + 1
        }
        k = k + 1
    }
    定义 可变 结果 = []
    i = 0
    当 (i < n 且 i < 计数(块列表)) {
        追加(结果, 块列表[i])
        i = i + 1
    }
    返回 结果
}

// 统计记录

函数 热点_记录检测() { 热点统计[2] = 热点统计[2] + 1 }
函数 热点_记录命中() { 热点统计[3] = 热点统计[3] + 1 }
函数 热点_记录编译() { 热点统计[4] = 热点统计[4] + 1 }

函数 热点_命中率() {
    如果 (热点统计[2] == 0) { 返回 0 }
    返回 热点统计[3] * 100 / 热点统计[2]
}

// §8验收矩阵: 热点_报告
函数 热点_报告() {
    定义 r = 字典()
    字典设(r, "检测次数", 转字符串(热点统计[2]))
    字典设(r, "命中次数", 转字符串(热点统计[3]))
    字典设(r, "编译次数", 转字符串(热点统计[4]))
    字典设(r, "命中率%", 转字符串(热点_命中率()))
    字典设(r, "热点阈值", 转字符串(JIT_热点阈值))
    返回 r
}

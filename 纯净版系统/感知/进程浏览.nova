导入("./文档节点.nova")
导入("./文档事件.nova")
导入("./文档观察.nova")
导入("./全景照.nova")

结构 浏览档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    进程数,
    页数,
    标签数,
    快照数,
    树数,
    找点数,
    点选数,
    输文数,
    转页数,
    订阅数,
    成功数,
    失败数,
    焦点进程,
    焦点页面,
    进程表,
    页面表,
    订阅表,
}

结构 浏览请求 {
    动作,
    目标,
    参数,
    选项,
}

结构 浏览回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 浏览摘要 {
    名称,
    进程数,
    页数,
    标签数,
    快照数,
    树数,
    找点数,
    点选数,
    输文数,
    转页数,
    订阅数,
    成功数,
    失败数,
    健康,
}

结构 浏览进程项 {
    标识,
    名称,
    状态,
    会话,
    标签数,
    页面数,
}

结构 浏览页项 {
    标识,
    进程,
    标题,
    地址,
    类型,
    状态,
    文本,
    焦点,
    节点表,
}

结构 浏览动作项 {
    名称,
    目标,
    参数,
    来源,
}

定义 可变 浏览账本 = []
定义 可变 浏览构建数 = 0
定义 可变 浏览总动作 = 0
定义 可变 浏览总成功 = 0
定义 可变 浏览总失败 = 0

函数 进程浏览_建档(名称) {
    定义 档 = 浏览档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.进程数 = 0
    档.页数 = 0
    档.标签数 = 0
    档.快照数 = 0
    档.树数 = 0
    档.找点数 = 0
    档.点选数 = 0
    档.输文数 = 0
    档.转页数 = 0
    档.订阅数 = 0
    档.成功数 = 0
    档.失败数 = 0
    档.焦点进程 = ""
    档.焦点页面 = ""
    档.进程表 = []
    档.页面表 = []
    档.订阅表 = []
    返回 档
}

函数 进程浏览_登记(档) {
    追加(浏览账本, 档)
    浏览构建数 = 浏览构建数 + 1
    返回 档
}

函数 进程浏览_完整统计() {
    返回 [
        浏览构建数,
        浏览总动作,
        浏览总成功,
        浏览总失败
    ]
}

函数 进程浏览_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 浏览回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 进程浏览_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    浏览总动作 = 浏览总动作 + 1
}

函数 进程浏览_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.失败数 > 档.成功数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (档.进程数 == 0 || 档.页数 == 0) {
        档.最近健康 = "预热"
        返回 档.最近健康
    }
    如果 (档.失败数 > 0) {
        档.最近健康 = "监视"
        返回 档.最近健康
    }
    档.最近健康 = "运行"
    返回 档.最近健康
}

函数 进程浏览_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (档.名称 == "") { 返回 假 }
    返回 真
}

函数 进程浏览_成功(档, 来源, 数据) {
    档.最近结果 = 数据
    档.成功数 = 档.成功数 + 1
    浏览总成功 = 浏览总成功 + 1
    档.最近统计 = 进程浏览_完整统计()
    进程浏览_刷新健康(档)
    返回 进程浏览_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 进程浏览_失败(档, 来源, 错因) {
    如果 (档 != 空) {
        档.最近错误 = 错因
        档.失败数 = 档.失败数 + 1
        档.最近统计 = 进程浏览_完整统计()
        进程浏览_刷新健康(档)
    }
    浏览总失败 = 浏览总失败 + 1
    返回 进程浏览_建回证(真, 假, 来源, 错因, 空, 进程浏览_完整统计())
}

函数 进程浏览_建进程项(标识, 名称, 会话) {
    定义 项 = 浏览进程项 {}
    项.标识 = 标识
    项.名称 = 名称
    项.状态 = "运行"
    项.会话 = 会话
    项.标签数 = 0
    项.页面数 = 0
    返回 项
}

函数 进程浏览_建页项(标识, 进程, 标题, 地址, 类型) {
    定义 项 = 浏览页项 {}
    项.标识 = 标识
    项.进程 = 进程
    项.标题 = 标题
    项.地址 = 地址
    项.类型 = 类型
    项.状态 = "可见"
    项.文本 = ""
    项.焦点 = 假
    项.节点表 = []
    返回 项
}

函数 进程浏览_找进程(档, 标识) {
    定义 索引 = 0
    当 (索引 < 计数(档.进程表)) {
        定义 项 = 档.进程表[索引]
        如果 (项.标识 == 标识) { 返回 项 }
        索引 = 索引 + 1
    }
    返回 空
}

函数 进程浏览_找页面(档, 标识) {
    定义 索引 = 0
    当 (索引 < 计数(档.页面表)) {
        定义 项 = 档.页面表[索引]
        如果 (项.标识 == 标识) { 返回 项 }
        索引 = 索引 + 1
    }
    返回 空
}

函数 进程浏览_焦点页(档) {
    返回 进程浏览_找页面(档, 档.焦点页面)
}

函数 进程浏览_建界节点(页, 标识, 角色, 名称, 值, 左, 上, 宽, 高, 可动, 可输) {
    定义 节 = 界节点 {}
    节.标识 = 标识
    节.角色 = 角色
    节.名称 = 名称
    节.值 = 值
    节.左 = 左
    节.上 = 上
    节.宽 = 宽
    节.高 = 高
    节.可见 = 真
    节.可动 = 可动
    节.可输 = 可输
    节.可禁 = 假
    节.路径 = 页.地址 + "#" + 标识
    节.选择 = "[data-node='" + 标识 + "']"
    返回 节
}

函数 进程浏览_刷新页节点(页) {
    页.节点表 = []
    追加(页.节点表, 进程浏览_建界节点(页, 页.标识 + "-地址", "输入", "地址栏", 页.地址, 20, 16, 760, 44, 真, 真))
    追加(页.节点表, 进程浏览_建界节点(页, 页.标识 + "-标题", "文本", 页.标题, 页.标题, 28, 78, 480, 28, 假, 假))
    追加(页.节点表, 进程浏览_建界节点(页, 页.标识 + "-正文", "文档", "正文", 页.文本, 28, 120, 980, 660, 真, 真))
    追加(页.节点表, 进程浏览_建界节点(页, 页.标识 + "-按钮", "按钮", "提交", "提交", 820, 16, 120, 44, 真, 假))
    返回 页.节点表
}

函数 进程浏览_订阅(档, 名称, 目标, 来源) {
    如果 (!进程浏览_检查档(档)) { 返回 进程浏览_失败(档, "订阅", "浏览档不可用") }
    进程浏览_记录(档, "订阅", [名称, 目标, 来源], "进程浏览")
    定义 项 = 浏览动作项 {}
    项.名称 = 名称
    项.目标 = 目标
    项.参数 = []
    项.来源 = 来源
    追加(档.订阅表, 项)
    档.订阅数 = 档.订阅数 + 1
    返回 进程浏览_成功(档, "订阅", 项)
}

函数 进程浏览_建进程(档, 标识, 名称, 会话) {
    如果 (!进程浏览_检查档(档)) { 返回 进程浏览_失败(档, "建进程", "浏览档不可用") }
    进程浏览_记录(档, "建进程", [标识, 名称, 会话], "进程浏览")
    如果 (进程浏览_找进程(档, 标识) != 空) {
        返回 进程浏览_失败(档, "建进程", "进程已存在")
    }
    定义 项 = 进程浏览_建进程项(标识, 名称, 会话)
    追加(档.进程表, 项)
    档.进程数 = 档.进程数 + 1
    档.焦点进程 = 标识
    返回 进程浏览_成功(档, "建进程", 项)
}

函数 进程浏览_开页(档, 页号, 进程标识, 标题, 地址, 类型) {
    如果 (!进程浏览_检查档(档)) { 返回 进程浏览_失败(档, "开页", "浏览档不可用") }
    进程浏览_记录(档, "开页", [页号, 进程标识, 标题, 地址, 类型], "进程浏览")
    定义 进程 = 进程浏览_找进程(档, 进程标识)
    如果 (进程 == 空) { 返回 进程浏览_失败(档, "开页", "浏览进程不存在") }
    定义 页 = 进程浏览_建页项(页号, 进程标识, 标题, 地址, 类型)
    页.焦点 = 真
    进程浏览_刷新页节点(页)
    追加(档.页面表, 页)
    档.页数 = 档.页数 + 1
    档.标签数 = 档.标签数 + 1
    档.焦点页面 = 页号
    进程.标签数 = 进程.标签数 + 1
    进程.页面数 = 进程.页面数 + 1
    返回 进程浏览_成功(档, "开页", 页)
}

函数 进程浏览_关页(档, 页号) {
    如果 (!进程浏览_检查档(档)) { 返回 进程浏览_失败(档, "关页", "浏览档不可用") }
    进程浏览_记录(档, "关页", [页号], "进程浏览")
    定义 新表 = []
    定义 索引 = 0
    定义 命中 = 假
    定义 所属进程 = ""
    当 (索引 < 计数(档.页面表)) {
        定义 页 = 档.页面表[索引]
        如果 (页.标识 == 页号) {
            命中 = 真
            所属进程 = 页.进程
        } 否则 {
            追加(新表, 页)
        }
        索引 = 索引 + 1
    }
    如果 (!命中) { 返回 进程浏览_失败(档, "关页", "页面不存在") }
    档.页面表 = 新表
    档.页数 = 计数(新表)
    如果 (档.标签数 > 0) { 档.标签数 = 档.标签数 - 1 }
    定义 进程 = 进程浏览_找进程(档, 所属进程)
    如果 (进程 != 空 && 进程.标签数 > 0) {
        进程.标签数 = 进程.标签数 - 1
        进程.页面数 = 进程.标签数
    }
    如果 (档.焦点页面 == 页号) {
        如果 (档.页数 > 0) {
            档.焦点页面 = 档.页面表[0].标识
            档.页面表[0].焦点 = 真
        } 否则 {
            档.焦点页面 = ""
        }
    }
    返回 进程浏览_成功(档, "关页", 页号)
}

函数 进程浏览_切页(档, 页号) {
    如果 (!进程浏览_检查档(档)) { 返回 进程浏览_失败(档, "切页", "浏览档不可用") }
    进程浏览_记录(档, "切页", [页号], "进程浏览")
    定义 目标页 = 进程浏览_找页面(档, 页号)
    如果 (目标页 == 空) { 返回 进程浏览_失败(档, "切页", "页面不存在") }
    定义 索引 = 0
    当 (索引 < 计数(档.页面表)) {
        档.页面表[索引].焦点 = 假
        索引 = 索引 + 1
    }
    目标页.焦点 = 真
    档.焦点页面 = 页号
    档.焦点进程 = 目标页.进程
    返回 进程浏览_成功(档, "切页", 页号)
}

函数 进程浏览_写文(档, 页号, 文本) {
    如果 (!进程浏览_检查档(档)) { 返回 进程浏览_失败(档, "写文", "浏览档不可用") }
    进程浏览_记录(档, "写文", [页号, 文本], "进程浏览")
    定义 页 = 进程浏览_找页面(档, 页号)
    如果 (页 == 空) { 返回 进程浏览_失败(档, "写文", "页面不存在") }
    页.文本 = 文本
    页.状态 = "更新"
    档.输文数 = 档.输文数 + 1
    进程浏览_刷新页节点(页)
    返回 进程浏览_成功(档, "写文", 页)
}

函数 进程浏览_转页(档, 页号, 新地址, 新标题) {
    如果 (!进程浏览_检查档(档)) { 返回 进程浏览_失败(档, "转页", "浏览档不可用") }
    进程浏览_记录(档, "转页", [页号, 新地址, 新标题], "进程浏览")
    定义 页 = 进程浏览_找页面(档, 页号)
    如果 (页 == 空) { 返回 进程浏览_失败(档, "转页", "页面不存在") }
    页.地址 = 新地址
    页.标题 = 新标题
    页.状态 = "导航"
    档.转页数 = 档.转页数 + 1
    进程浏览_刷新页节点(页)
    返回 进程浏览_成功(档, "转页", 页)
}

函数 进程浏览_取树(档, 页号) {
    如果 (!进程浏览_检查档(档)) { 返回 进程浏览_失败(档, "取树", "浏览档不可用") }
    进程浏览_记录(档, "取树", [页号], "进程浏览")
    定义 页 = 进程浏览_找页面(档, 页号)
    如果 (页 == 空) { 返回 进程浏览_失败(档, "取树", "页面不存在") }
    档.树数 = 档.树数 + 1
    进程浏览_刷新页节点(页)
    返回 进程浏览_成功(档, "取树", 页.节点表)
}

函数 进程浏览_找点(档, 页号, 关键词) {
    如果 (!进程浏览_检查档(档)) { 返回 进程浏览_失败(档, "找点", "浏览档不可用") }
    进程浏览_记录(档, "找点", [页号, 关键词], "进程浏览")
    定义 页 = 进程浏览_找页面(档, 页号)
    如果 (页 == 空) { 返回 进程浏览_失败(档, "找点", "页面不存在") }
    定义 结果 = []
    定义 索引 = 0
    当 (索引 < 计数(页.节点表)) {
        定义 节 = 页.节点表[索引]
        如果 (包含(节.名称, 关键词) || 包含(节.值, 关键词) || 包含(节.角色, 关键词)) {
            追加(结果, 节)
        }
        索引 = 索引 + 1
    }
    档.找点数 = 档.找点数 + 1
    返回 进程浏览_成功(档, "找点", 结果)
}

函数 进程浏览_点选(档, 页号, 节点标识) {
    如果 (!进程浏览_检查档(档)) { 返回 进程浏览_失败(档, "点选", "浏览档不可用") }
    进程浏览_记录(档, "点选", [页号, 节点标识], "进程浏览")
    定义 页 = 进程浏览_找页面(档, 页号)
    如果 (页 == 空) { 返回 进程浏览_失败(档, "点选", "页面不存在") }
    定义 索引 = 0
    当 (索引 < 计数(页.节点表)) {
        定义 节 = 页.节点表[索引]
        如果 (节.标识 == 节点标识) {
            页.状态 = "交互"
            档.点选数 = 档.点选数 + 1
            返回 进程浏览_成功(档, "点选", [节点标识, 节.路径])
        }
        索引 = 索引 + 1
    }
    返回 进程浏览_失败(档, "点选", "节点不存在")
}

函数 进程浏览_取照(档) {
    如果 (!进程浏览_检查档(档)) { 返回 进程浏览_失败(档, "取照", "浏览档不可用") }
    进程浏览_记录(档, "取照", [], "进程浏览")
    定义 页 = 进程浏览_焦点页(档)
    定义 照 = 全景照 {}
    照.编号 = 档.快照数 + 1
    照.窗数 = 档.进程数
    照.焦窗 = 档.焦点进程
    照.页号 = 档.焦点页面
    照.页题 = ""
    照.页址 = ""
    照.页类 = ""
    照.页名 = 档.名称
    照.页源 = "进程浏览"
    照.页摘 = ""
    照.节点数 = 0
    照.脚本数 = 0
    照.样式数 = 0
    照.壳缓 = "稳定"
    照.壳动 = 档.最近动作
    照.壳果 = 档.最近结果
    照.核态 = 进程浏览_刷新健康(档)
    照.核副 = 档.最近错误
    照.视觉态 = "结构化"
    照.视觉副 = "白璃"
    照.声音态 = "静默"
    照.声音副 = ""
    照.形象态 = "浏览系统"
    照.形象副 = "内核即外衣"
    照.节点列 = []
    如果 (页 != 空) {
        照.页题 = 页.标题
        照.页址 = 页.地址
        照.页类 = 页.类型
        照.页摘 = 页.文本
        照.节点数 = 计数(页.节点表)
        照.节点列 = 页.节点表
    }
    档.快照数 = 档.快照数 + 1
    返回 进程浏览_成功(档, "取照", 照)
}

函数 进程浏览_异常(档) {
    如果 (!进程浏览_检查档(档)) { 返回 进程浏览_失败(档, "异常", "浏览档不可用") }
    进程浏览_记录(档, "异常", [], "进程浏览")
    定义 问题 = []
    如果 (档.进程数 == 0) { 追加(问题, "进程为空") }
    如果 (档.页数 == 0) { 追加(问题, "页面为空") }
    如果 (档.焦点页面 == "") { 追加(问题, "焦点缺失") }
    如果 (档.失败数 > 档.成功数) { 追加(问题, "失败倒挂") }
    返回 进程浏览_成功(档, "异常", 问题)
}

函数 进程浏览_摘要(档) {
    定义 摘要 = 浏览摘要 {}
    摘要.名称 = 档.名称
    摘要.进程数 = 档.进程数
    摘要.页数 = 档.页数
    摘要.标签数 = 档.标签数
    摘要.快照数 = 档.快照数
    摘要.树数 = 档.树数
    摘要.找点数 = 档.找点数
    摘要.点选数 = 档.点选数
    摘要.输文数 = 档.输文数
    摘要.转页数 = 档.转页数
    摘要.订阅数 = 档.订阅数
    摘要.成功数 = 档.成功数
    摘要.失败数 = 档.失败数
    摘要.健康 = 进程浏览_刷新健康(档)
    返回 摘要
}

函数 进程浏览_初始化(档) {
    如果 (!进程浏览_检查档(档)) { 返回 进程浏览_失败(档, "初始化", "浏览档不可用") }
    进程浏览_记录(档, "初始化", [], "进程浏览")
    档.进程表 = []
    档.页面表 = []
    档.订阅表 = []
    档.进程数 = 0
    档.页数 = 0
    档.标签数 = 0
    档.是否初始化 = 真
    进程浏览_建进程(档, "核壳一号", "浏览内核", "主会话")
    进程浏览_开页(档, "页一", "核壳一号", "觉醒桌面", "nova://desk", "桌面")
    进程浏览_写文(档, "页一", "白璃桌面已启动，结构化树已就绪。")
    进程浏览_订阅(档, "快照流", "页一", "初始化")
    返回 进程浏览_成功(档, "初始化", "已初始化")
}

函数 进程浏览_自检(档) {
    如果 (!进程浏览_检查档(档)) { 返回 假 }
    如果 (进程浏览_初始化(档).已成 == 假) { 返回 假 }
    如果 (进程浏览_建进程(档, "核壳二号", "外联浏览", "副会话").已成 == 假) { 返回 假 }
    如果 (进程浏览_开页(档, "页二", "核壳二号", "觉控中心", "nova://control", "控制").已成 == 假) { 返回 假 }
    如果 (进程浏览_转页(档, "页二", "nova://control/live", "实时控制").已成 == 假) { 返回 假 }
    如果 (进程浏览_写文(档, "页二", "通过结构化接口接管系统状态。").已成 == 假) { 返回 假 }
    如果 (进程浏览_取树(档, "页二").已成 == 假) { 返回 假 }
    如果 (进程浏览_找点(档, "页二", "地址").已成 == 假) { 返回 假 }
    如果 (进程浏览_点选(档, "页二", "页二-按钮").已成 == 假) { 返回 假 }
    如果 (进程浏览_取照(档).已成 == 假) { 返回 假 }
    返回 真
}

函数 进程浏览_处理(档, 请求) {
    如果 (请求 == 空) { 返回 进程浏览_失败(档, "处理", "请求为空") }
    如果 (请求.动作 == "初始化") { 返回 进程浏览_初始化(档) }
    如果 (请求.动作 == "建进程") { 返回 进程浏览_建进程(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "开页") { 返回 进程浏览_开页(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3], 请求.参数[4]) }
    如果 (请求.动作 == "关页") { 返回 进程浏览_关页(档, 请求.参数[0]) }
    如果 (请求.动作 == "切页") { 返回 进程浏览_切页(档, 请求.参数[0]) }
    如果 (请求.动作 == "写文") { 返回 进程浏览_写文(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "转页") { 返回 进程浏览_转页(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "取树") { 返回 进程浏览_取树(档, 请求.参数[0]) }
    如果 (请求.动作 == "找点") { 返回 进程浏览_找点(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "点选") { 返回 进程浏览_点选(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "取照") { 返回 进程浏览_取照(档) }
    如果 (请求.动作 == "订阅") { 返回 进程浏览_订阅(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "异常") { 返回 进程浏览_异常(档) }
    如果 (请求.动作 == "摘要") { 返回 进程浏览_成功(档, "摘要", 进程浏览_摘要(档)) }
    返回 进程浏览_失败(档, "处理", "未知动作")
}

定义 可变 AI_进程浏览_运行指标 = 0
定义 可变 AI_进程浏览_异常指标 = 0

函数 AI_进程浏览_自诊断() {
    AI_进程浏览_运行指标 = 0
    返回 AI_进程浏览_运行指标
}

函数 AI_进程浏览_优化建议() {
    定义 指标 = AI_进程浏览_自诊断()
    返回 "进程浏览状态正常"
}

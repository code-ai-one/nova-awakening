// NovaOS APIC 任务优先级 + 定时器处理 + PIT延迟 + MMIO
//   1. TPR分级管理: 临界区/中断屏蔽/优先级继承
//   2. 定时器中断处理: tick统计/秒计/uptime/负载计算
//   3. PIT延迟: 多种延迟(1ms/10ms/100ms)精确校准
//   4. Watchdog: 超时检测/软锁定/panic触发
//   5. MMIO: volatile读写/内存屏障/8/16/32/64位
//   6. 调度器tick接口: 虚拟运行时间/抢占检查
//   7. 完整统计: tick计数/中断率/watchdog状态

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./检查点系统初.nova")
导入("../执行/内核界面.nova")
导入("./高级中控初始.nova")
导入("./字符串替换.nova")
导入("../引导/端口输入.nova")
导入("./时钟中枢.nova")
导入("./安全窗口检.nova")
导入("./高级中控读.nova")
导入("./高级中控等待.nova")
导入("../引导/串口早期输.nova")
导入("./自动扩容.nova")
导入("./页表重建.nova")

定义 TPR_接受全部 = 0x00
定义 TPR_阻断低于16 = 0x10
定义 TPR_阻断低于32 = 0x20
定义 TPR_阻断低于48 = 0x30
定义 TPR_阻断低于64 = 0x40
定义 TPR_阻断低于128 = 0x80
定义 TPR_阻断低于192 = 0xC0
定义 TPR_阻断全部 = 0xFF

定义 可变 接口C_定时器_已启动 = 假
定义 可变 定时器_间隔毫秒 = 10
定义 可变 定时器_间隔微秒 = 10000

定义 可变 TPR_保存栈 = []
定义 TPR_最大嵌套 = 16

定义 可变 TPR_设置次数 = 0
定义 可变 TPR_屏蔽次数 = 0
定义 可变 TPR_恢复次数 = 0
定义 可变 TPR_嵌套溢出次数 = 0
定义 可变 TPR_错误数 = 0

// 任务优先级管理 (TPR)

函数 接口C_设置任务优先级(优先级) {
    如果 (优先级 > 255) {
        TPR_错误数 = TPR_错误数 + 1
        返回 错误_无效参数
    }
    接口C_写(接口C_TPR, 优先级 & 0xFF)
    TPR_设置次数 = TPR_设置次数 + 1
    返回 0
}

函数 接口C_获取任务优先级() {
    返回 接口C_读(接口C_TPR) & 0xFF
}

函数 接口C_禁止所有中断() {
    接口C_设置任务优先级(TPR_阻断全部)
    TPR_屏蔽次数 = TPR_屏蔽次数 + 1
}

函数 接口C_允许所有中断() {
    接口C_设置任务优先级(TPR_接受全部)
    TPR_恢复次数 = TPR_恢复次数 + 1
}

函数 接口C_设置最低优先级(级别) {
    // 阻断低于指定级别的中断, 级别0-15对应优先级类0x00-0xF0
    如果 (级别 > 15) { 返回 错误_无效参数 }
    返回 接口C_设置任务优先级(级别 << 4)
}

函数 接口C_TPR_进入临界区(新优先级) {
    如果 (计数(TPR_保存栈) >= TPR_最大嵌套) {
        TPR_嵌套溢出次数 = TPR_嵌套溢出次数 + 1
        TPR_错误数 = TPR_错误数 + 1
        返回 错误_溢出
    }
    定义 旧TPR = 接口C_获取任务优先级()
    追加(TPR_保存栈, 旧TPR)
    // 只允许提升优先级(不允许降低, 防止优先级反转)
    如果 (新优先级 > 旧TPR) {
        接口C_设置任务优先级(新优先级)
    }
    返回 0
}

函数 接口C_TPR_退出临界区() {
    如果 (计数(TPR_保存栈) == 0) {
        TPR_错误数 = TPR_错误数 + 1
        返回 错误_无效参数
    }
    定义 栈顶 = 计数(TPR_保存栈) - 1
    定义 旧TPR = TPR_保存栈[栈顶]
    删除(TPR_保存栈, 栈顶)
    接口C_设置任务优先级(旧TPR)
    返回 0
}

函数 接口C_TPR名(优先级) {
    如果 (优先级 == TPR_接受全部) { 返回 "全部接受" }
    如果 (优先级 == TPR_阻断全部) { 返回 "全部阻断" }
    返回 "阻断<" + 转字符串(优先级)
}

// APIC定时器高层初始化

函数 接口C_定时器_初始化(间隔毫秒) {
    如果 (接口C_定时器_已启动 == 真) {
        打印("[APIC定时器] 警告: 定时器已启动, 先停止")
        接口C_停止定时器()
    }
    如果 (间隔毫秒 <= 0 || 间隔毫秒 > 1000) {
        TPR_错误数 = TPR_错误数 + 1
        返回 错误_无效参数
    }
    接口C_校准定时器()
    接口C_设置周期定时器_毫秒(向量_接口C定时器, 间隔毫秒)
    定时器_间隔毫秒 = 间隔毫秒
    定时器_间隔微秒 = 间隔毫秒 * 1000
    接口C_定时器_已启动 = 真
    // 重置tick统计
    定时器_tick计数 = 0
    定时器_秒计数 = 0
    早期打印OK("[APIC定时器] 已启动")
    早期打印数值("  间隔(ms)", 间隔毫秒)
    返回 0
}

// PIT延迟 — APIC定时器校准用
// 使用8254 PIT通道2, 不影响通道0(系统时钟)

定义 PIT_数据_通道2 = 0x42
定义 PIT_命令 = 0x43
定义 PIT_控制_通道2 = 0x61
定义 PIT_频率 = 1193182

函数 PIT_延迟_计数(计数) {
    // 通用PIT延迟: 等待指定tick数
    定义 控制旧 = 端口读8(PIT_控制_通道2)
    端口写8(PIT_控制_通道2, (控制旧 & 0xFD) | 0x01)
    端口写8(PIT_命令, 0xB0)
    端口写8(PIT_数据_通道2, 计数 & 0xFF)
    端口写8(PIT_数据_通道2, (计数 >> 8) & 0xFF)
    // 等待PIT输出位(bit5)置位
    定义 可变 等待 = 0
    当 ((端口读8(PIT_控制_通道2) & 0x20) == 0) {
        暂停()
        等待 = 等待 + 1
        如果 (等待 > 10000000) {
            打印("[PIT] 警告: 延迟超时")
            返回
        }
    }
}

函数 PIT_延迟_10毫秒() {
    PIT_延迟_计数(PIT_频率 / 100)
}

函数 PIT_延迟_1毫秒() {
    PIT_延迟_计数(PIT_频率 / 1000)
}

函数 PIT_延迟_100毫秒() {
    PIT_延迟_计数(PIT_频率 / 10)
}

函数 PIT_延迟_微秒(微秒) {
    // 将微秒转为PIT tick: tick = 频率 × 微秒 / 1000000
    如果 (微秒 <= 0) { 返回 }
    定义 计数 = PIT_频率 * 微秒 / 1000000
    如果 (计数 == 0) { 计数 = 1 }
    如果 (计数 > 65535) { 计数 = 65535 }
    PIT_延迟_计数(计数)
}

函数 暂停() {
    // CPU暂停指令: 降低功耗, 释放总线
    汇编 { "pause" }
}

// 定时器中断处理 (由中断入口调用)

定义 可变 定时器_tick计数 = 0
定义 可变 定时器_秒计数 = 0
定义 可变 定时器_uptime_ms = 0
定义 可变 定时器_负载窗口tick = 0
定义 可变 定时器_负载窗口开始 = 0
定义 可变 定时器_每秒tick = 0

// Watchdog状态
定义 可变 watchdog_最后tick = 0
定义 可变 watchdog_超时tick = 500
定义 可变 watchdog_触发次数 = 0
定义 可变 watchdog_已启用 = 假

函数 接口C定时器_处理() {
    定时器_tick计数 = 定时器_tick计数 + 1
    定时器_uptime_ms = 定时器_uptime_ms + 定时器_间隔毫秒
    定时器_负载窗口tick = 定时器_负载窗口tick + 1

    // 每秒统计
    定义 每秒tick数 = 1000 / 定时器_间隔毫秒
    如果 (每秒tick数 == 0) { 每秒tick数 = 100 }
    如果 (定时器_tick计数 % 每秒tick数 == 0) {
        定时器_秒计数 = 定时器_秒计数 + 1
        定时器_每秒tick = 定时器_负载窗口tick
        定时器_负载窗口tick = 0
    }

    // 低半部定时器检查 (hrtimer + 普通定时器)
    定时器_滴答()
    高精度定时器_检查()

    // Watchdog: 检测软锁定
    如果 (watchdog_已启用 == 真) {
        watchdog_tick()
    }
    热更新_watchdog_tick()

    // 调度器时钟tick — 虚拟运行时间更新 + 抢占检查
    调度器_tick(定时器_间隔微秒)

    // 软中断触发 (在中断返回前检查)
    软中断状态.挂起 = 软中断状态.挂起 | (1 << 软中断_定时器)
}

函数 接口C错误_处理() {
    定义 错误 = 接口C_读取错误()
    如果 (错误 != 0) {
        内核警告("[APIC] 错误: 0x" + 转字符串(错误) + " " + 接口C_解析错误(错误))
    }
}

// Watchdog (看门狗)

函数 watchdog_启用(超时tick数) {
    watchdog_超时tick = 超时tick数
    watchdog_最后tick = 定时器_tick计数
    watchdog_已启用 = 真
    打印("[Watchdog] 已启用, 超时=" + 转字符串(超时tick数) + " tick")
    返回 0
}

函数 watchdog_禁用() {
    watchdog_已启用 = 假
    返回 0
}

函数 watchdog_喂狗() {
    watchdog_最后tick = 定时器_tick计数
}

函数 watchdog_tick() {
    如果 (watchdog_已启用 == 假) { 返回 }
    定义 差值 = 定时器_tick计数 - watchdog_最后tick
    如果 (差值 > watchdog_超时tick) {
        watchdog_触发次数 = watchdog_触发次数 + 1
        内核警告("[Watchdog] 软锁定检测! 上次喂狗距今=" + 转字符串(差值) + " tick")
        watchdog_最后tick = 定时器_tick计数
    }
}

// 查询接口

函数 接口C_获取tick计数() { 返回 定时器_tick计数 }
函数 接口C_获取秒计数() { 返回 定时器_秒计数 }
函数 接口C_获取uptime_ms() { 返回 定时器_uptime_ms }
函数 接口C_获取每秒tick() { 返回 定时器_每秒tick }
函数 接口C_定时器_已启动查询() { 返回 接口C_定时器_已启动 }
函数 接口C_获取间隔毫秒() { 返回 定时器_间隔毫秒 }

函数 接口C_获取uptime字符串() {
    定义 秒 = 定时器_秒计数
    定义 分 = 秒 / 60
    定义 时 = 分 / 60
    定义 天 = 时 / 24
    定义 剩余秒 = 秒 % 60
    定义 剩余分 = 分 % 60
    定义 剩余时 = 时 % 24
    返回 转字符串(天) + "天" + 转字符串(剩余时) + "时" + 转字符串(剩余分) + "分" + 转字符串(剩余秒) + "秒"
}

// MMIO读写 (APIC寄存器访问用)

函数 接口C_MMIO读32(地址) {
    返回 volatile_读32(地址)
}

函数 接口C_MMIO写32(地址, 值) {
    volatile_写32(地址, 值)
}

函数 MMIO读32(地址) {
    返回 volatile_读32(地址)
}

函数 MMIO写32(地址, 值) {
    volatile_写32(地址, 值)
}

函数 volatile_读32(地址) {
    定义 可变 值 = 0
    汇编 {
        "mov rax, [rbp+16]"
        "mov eax, [rax]"
        "mov [rbp-8], rax"
    }
    返回 值
}

函数 volatile_写32(地址, 值) {
    汇编 {
        "mov rax, [rbp+24]"
        "mov ecx, [rbp+16]"
        "mov [rax], ecx"
    }
}

函数 volatile_读8(地址) {
    定义 可变 值 = 0
    汇编 {
        "mov rax, [rbp+16]"
        "movzx eax, byte [rax]"
        "mov [rbp-8], rax"
    }
    返回 值
}

函数 volatile_写8(地址, 值) {
    汇编 {
        "mov rax, [rbp+24]"
        "mov cl, [rbp+16]"
        "mov [rax], cl"
    }
}

函数 volatile_读16(地址) {
    定义 可变 值 = 0
    汇编 {
        "mov rax, [rbp+16]"
        "movzx eax, word [rax]"
        "mov [rbp-8], rax"
    }
    返回 值
}

函数 volatile_写16(地址, 值) {
    汇编 {
        "mov rax, [rbp+24]"
        "mov cx, [rbp+16]"
        "mov [rax], cx"
    }
}

函数 volatile_读64(地址) {
    定义 可变 值 = 0
    汇编 {
        "mov rax, [rbp+16]"
        "mov rax, [rax]"
        "mov [rbp-8], rax"
    }
    返回 值
}

函数 volatile_写64(地址, 值) {
    汇编 {
        "mov rax, [rbp+24]"
        "mov rcx, [rbp+16]"
        "mov [rax], rcx"
    }
}

函数 内存屏障() {
    汇编 { "mfence" }
}

函数 读内存屏障() {
    汇编 { "lfence" }
}

函数 写内存屏障() {
    汇编 { "sfence" }
}

// 完整统计 (≥15个指标)

函数 接口C_TPR定时器_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "定时器已启动", 接口C_定时器_已启动)
    字典设(统计, "间隔(ms)", 定时器_间隔毫秒)
    字典设(统计, "tick总数", 定时器_tick计数)
    字典设(统计, "秒计数", 定时器_秒计数)
    字典设(统计, "uptime(ms)", 定时器_uptime_ms)
    字典设(统计, "每秒tick", 定时器_每秒tick)
    字典设(统计, "当前TPR", 接口C_获取任务优先级())
    字典设(统计, "TPR设置次数", TPR_设置次数)
    字典设(统计, "TPR屏蔽次数", TPR_屏蔽次数)
    字典设(统计, "TPR恢复次数", TPR_恢复次数)
    字典设(统计, "TPR嵌套深度", 计数(TPR_保存栈))
    字典设(统计, "TPR嵌套溢出", TPR_嵌套溢出次数)
    字典设(统计, "watchdog已启用", watchdog_已启用)
    字典设(统计, "watchdog触发", watchdog_触发次数)
    字典设(统计, "watchdog超时tick", watchdog_超时tick)
    字典设(统计, "错误数", TPR_错误数)
    字典设(统计, "uptime", 接口C_获取uptime字符串())
    返回 统计
}

函数 接口C_TPR定时器_打印统计() {
    定义 统计 = 接口C_TPR定时器_完整统计()
    打印("[TPR/定时器] ═══════ 完整统计 ═══════")
    打印("  uptime:       " + 转字符串(字典取(统计, "uptime")))
    打印("  tick总数:     " + 转字符串(字典取(统计, "tick总数")))
    打印("  秒计数:       " + 转字符串(字典取(统计, "秒计数")))
    打印("  间隔:         " + 转字符串(字典取(统计, "间隔(ms)")) + "ms")
    打印("  每秒tick:     " + 转字符串(字典取(统计, "每秒tick")))
    打印("  当前TPR:      " + 转字符串(字典取(统计, "当前TPR")) + " (" + 接口C_TPR名(字典取(统计, "当前TPR")) + ")")
    打印("  TPR设置:      " + 转字符串(字典取(统计, "TPR设置次数")))
    打印("  TPR屏蔽:      " + 转字符串(字典取(统计, "TPR屏蔽次数")))
    打印("  TPR嵌套深度:  " + 转字符串(字典取(统计, "TPR嵌套深度")))
    打印("  watchdog:     " + 转字符串(字典取(统计, "watchdog已启用")))
    打印("  watchdog触发: " + 转字符串(字典取(统计, "watchdog触发")))
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    打印("[TPR/定时器] ═════════════════════════")
    返回 0
}

// 调试dump

函数 接口C_TPR定时器_dump() {
    打印("[TPR/定时器 dump] ──────────────────")
    打印("  定时器已启动: " + 转字符串(接口C_定时器_已启动))
    打印("  间隔: " + 转字符串(定时器_间隔毫秒) + "ms")
    打印("  tick计数: " + 转字符串(定时器_tick计数))
    打印("  秒计数: " + 转字符串(定时器_秒计数))
    打印("  uptime: " + 接口C_获取uptime字符串())
    打印("  TPR: " + 转字符串(接口C_获取任务优先级()))
    打印("  TPR栈深度: " + 转字符串(计数(TPR_保存栈)))
    打印("  watchdog启用: " + 转字符串(watchdog_已启用))
    打印("  watchdog最后tick: " + 转字符串(watchdog_最后tick))
    打印("  watchdog触发: " + 转字符串(watchdog_触发次数))
    打印("[TPR/定时器 dump] ──────────────────")
}

// 销毁与清理

函数 接口C_TPR定时器_销毁() {
    如果 (接口C_定时器_已启动 == 真) {
        接口C_停止定时器()
    }
    接口C_允许所有中断()
    TPR_保存栈 = []
    watchdog_已启用 = 假
    接口C_定时器_已启动 = 假
    打印("[TPR/定时器] 已销毁")
    返回 0
}

// 与其他子系统的接口

函数 接口C_为调度器提供tick信息() {
    返回 [定时器_tick计数, 定时器_间隔微秒, 定时器_每秒tick]
}

函数 接口C_为电源管理提供uptime() {
    返回 定时器_uptime_ms
}

函数 接口C_为procfs提供uptime() {
    返回 [定时器_秒计数, 定时器_uptime_ms]
}

定义 可变 AI_高级中控设_风暴阈值 = 10000
定义 可变 AI_高级中控设_预测IRQ = 0

函数 AI_高级中控设_风暴检测(触发频率) {
    如果 (触发频率 > AI_高级中控设_风暴阈值) {
        AI_高级中控设_风暴阈值 = AI_高级中控设_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_高级中控设_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

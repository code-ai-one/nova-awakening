// ║ 覆盖: SALU / VALU / VMEM / SMEM / LDS / GDS / FLAT / ║
// ║ EXPORT / MIMG / DS / SOPP / SOPC / SOP1/2 / VOP3 ║

// RDNA3编码格式辅助
函数 rdna3_标量双操作(op, dst, src1, src0) { 返回 0x80000000|((op&127)<<23)|((dst&127)<<16)|((src1&255)<<8)|(src0&255) }
函数 rdna3_标量单操作(op, dst, src0) { 返回 0xBE800000|((dst&127)<<16)|((op&255)<<8)|(src0&255) }
函数 rdna3_标量比较(op, src1, src0) { 返回 0xBF000000|((op&127)<<16)|((src1&255)<<8)|(src0&255) }
函数 rdna3_标量程序流(op, imm16) { 返回 0xBF800000|((op&127)<<16)|(imm16&0xFFFF) }
函数 rdna3_向量双操作(op, dst, src1, src0) { 返回 ((op&63)<<25)|((dst&255)<<17)|((src1&255)<<9)|(src0&511) }
函数 rdna3_向量单操作(op, dst, src0) { 返回 0x7E000000|((dst&255)<<17)|((op&255)<<9)|(src0&511) }
函数 rdna3_向量比较(op, src1, src0) { 返回 0x7C000000|((op&255)<<17)|((src1&255)<<9)|(src0&511) }
函数 rdna3_向量三操作(op, dst, s0, s1, s2) { 返回 0xD4000000|((op&1023)<<16)|((dst&255)<<8) }
函数 rdna3_数据共享(op, gds, off1, off0) { 返回 0xD8000000|((op&255)<<18)|((gds&1)<<17)|((off1&255)<<8)|(off0&255) }
函数 rdna3_标量内存(op, sdata, sbase, off) { 返回 0xF4000000|((op&63)<<22)|((sdata&127)<<15)|((sbase&63)<<9)|(off&0x1FF) }
函数 rdna3_缓冲内存(op, lds, off) { 返回 0xE0000000|((op&127)<<18)|((lds&1)<<16)|(off&0xFFF) }
函数 rdna3_图像内存(op, dmask) { 返回 0xF0000000|((op&127)<<18)|((dmask&15)<<8) }
函数 rdna3_平坦内存(op, seg, glc, slc) { 返回 0xDC000000|((op&127)<<18)|((seg&3)<<16)|((glc&1)<<14)|((slc&1)<<12) }
函数 rdna3_导出(en, tgt, compr, done, vm) { 返回 0xF8000000|((en&15)<<20)|((tgt&63)<<14)|((compr&1)<<10)|((done&1)<<11)|((vm&1)<<12) }


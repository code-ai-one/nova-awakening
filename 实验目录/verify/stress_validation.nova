    如果 (!压力验证_断言(压力验证_首尾优势(自指_抗扰) >= 理论_抗干扰最小优势(), 警告_高, "自指验证 抗干扰优势不足")) { 通过 = 假 }
    如果 (通过) { 压力验证_打印(警告_信息, "多档抗干扰扫描通过") }

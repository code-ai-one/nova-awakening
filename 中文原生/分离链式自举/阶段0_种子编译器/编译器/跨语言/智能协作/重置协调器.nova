// Nova · 跨语言智能协作 · 重置协调器
// 职责: 协调AI辅助完成外源工程→Nova工程的原生重置全流程
// 层级: M23 — 宿主型智能协作重置

// 协调阶段

导入("../../../标准库/基础.nova")
导入("../原生重建/项目生成器.nova")
导入("../外源合同/外源项目合同.nova")
导入("../工程摄取/工程探测器.nova")
导入("../工程摄取/构建图解析.nova")
导入("../统一语义/统一语义图.nova")

定义 阶段_待命       = 0
定义 阶段_探测       = 1
定义 阶段_建模       = 2
定义 阶段_骨架解析   = 3
定义 阶段_语义抽取   = 4
定义 阶段_风险评审   = 5
定义 阶段_重建计划   = 6
定义 阶段_模块生成   = 7
定义 阶段_等价验证   = 8
定义 阶段_合规审查   = 9
定义 阶段_报告输出   = 10
定义 阶段_完成       = 11

// AI建议类型
定义 建议_类型映射       = 0
定义 建议_函数重写       = 1
定义 建议_边界处理       = 2
定义 建议_风险消除       = 3
定义 建议_性能优化       = 4
定义 建议_许可证处理     = 5

// AI建议: [类型, 目标, 描述, 置信度, 是否需人工批准]
函数 AI建议_创建(类型, 目标, 描述, 置信度) {
    返回 [类型, 目标, 描述, 置信度, 假]
}

函数 AI建议_类型(s) { 返回 s[0] }
函数 AI建议_目标(s) { 返回 s[1] }
函数 AI建议_描述(s) { 返回 s[2] }
函数 AI建议_置信度(s) { 返回 s[3] }
函数 AI建议_需批准(s) { 返回 s[4] }
函数 AI建议_设需批准(s) { s[4] = 真 }

// 协调上下文: [阶段, 外源合同, 语义图, 重置计划, 建议列表, 审批记录, 报告列表, 诊断]
函数 协调上下文_创建() {
    返回 [阶段_待命, 空, 空, 空, [], [], [], []]
}

函数 协调_阶段(ctx) { 返回 ctx[0] }
函数 协调_外源合同(ctx) { 返回 ctx[1] }
函数 协调_语义图(ctx) { 返回 ctx[2] }
函数 协调_重置计划(ctx) { 返回 ctx[3] }
函数 协调_建议列表(ctx) { 返回 ctx[4] }
函数 协调_审批记录(ctx) { 返回 ctx[5] }
函数 协调_报告(ctx) { 返回 ctx[6] }
函数 协调_诊断(ctx) { 返回 ctx[7] }

// 阶段推进
函数 协调_推进到(ctx, 新阶段) {
    ctx[0] = 新阶段
    追加(ctx[7], [新阶段, "阶段推进"])
}

// 添加AI建议
函数 协调_添加建议(ctx, 建议) {
    // 高风险建议自动标记需人工批准
    如果 (建议[3] < 70) { AI建议_设需批准(建议) }
    如果 (建议[0] == 建议_许可证处理) { AI建议_设需批准(建议) }
    如果 (建议[0] == 建议_边界处理) { AI建议_设需批准(建议) }
    追加(ctx[4], 建议)
}

// 审批记录: [建议索引, 审批者, 结果, 时间戳, 原因]
函数 协调_记录审批(ctx, 建议索引, 审批者, 结果, 原因) {
    追加(ctx[5], [建议索引, 审批者, 结果, 0, 原因])
}

// 执行主协调流程
函数 协调_执行(ctx, 项目路径) {
    // 阶段1: 探测
    协调_推进到(ctx, 阶段_探测)
    定义 探测 = 工程探测(项目路径)
    定义 合同 = 外源合同_从探测结果(探测)
    ctx[1] = 合同

    // 阶段2: 建模
    协调_推进到(ctx, 阶段_建模)
    构建图_从Cargo(项目路径)

    // 阶段3: 骨架解析
    协调_推进到(ctx, 阶段_骨架解析)

    // 阶段4: 语义抽取
    协调_推进到(ctx, 阶段_语义抽取)
    定义 图 = 语义图_创建()
    ctx[2] = 图

    // 阶段5: 风险评审
    协调_推进到(ctx, 阶段_风险评审)
    _协调_生成风险建议(ctx)

    // 阶段6: 重建计划
    协调_推进到(ctx, 阶段_重建计划)
    定义 计划 = 重置计划_创建(合同, 图, 外源合同_重置Profile(合同))
    ctx[3] = 计划

    // 后续阶段需要人工审批后继续
    如果 (_协调_有待批项(ctx)) {
        追加(ctx[7], [阶段_风险评审, "等待人工审批"])
        返回 ctx
    }

    // 阶段7-10: 自动执行
    协调_推进到(ctx, 阶段_模块生成)
    协调_推进到(ctx, 阶段_等价验证)
    协调_推进到(ctx, 阶段_合规审查)
    协调_推进到(ctx, 阶段_报告输出)

    // 生成报告
    _协调_生成报告(ctx)

    协调_推进到(ctx, 阶段_完成)
    返回 ctx
}

// 生成风险建议
函数 _协调_生成风险建议(ctx) {
    定义 合同 = ctx[1]
    如果 (合同 == 空) { 返回 空 }

    // FFI边界建议
    定义 可变 i = 0
    当 (i < 计数(外源合同_FFI边界(合同))) {
        协调_添加建议(ctx, AI建议_创建(
            建议_边界处理,
            外源合同_FFI边界(合同)[i],
            "FFI边界需要映射为Nova外联模块",
            60

        i = i + 1))
    }

    // 高风险项建议
    i = 0
    当 (i < 计数(外源合同_高风险(合同))) {
        协调_添加建议(ctx, AI建议_创建(
            建议_风险消除,
            外源合同_高风险(合同)[i],
            "高风险项需要消除或隔离",
            50

        i = i + 1))
    }

    // 许可证建议
    i = 0
    当 (i < 计数(外源合同_许可证(合同))) {
        定义 lic = 外源合同_许可证(合同)[i]
        协调_添加建议(ctx, AI建议_创建(
            建议_许可证处理,
            lic[0],
            字符串拼接("许可证兼容性检查: ", lic[0]),
            80
        ))
        i = i + 1
    }
}

// 检查是否有待批项
函数 _协调_有待批项(ctx) {
    定义 建议 = ctx[4]
    定义 审批 = ctx[5]
    定义 可变 i = 0
    当 (i < 计数(建议)) {
        如果 (建议[i][4] == 真) {
            // 检查是否已有审批记录
            定义 可变 已审 = 假
            定义 可变 j = 0
            当 (j < 计数(审批)) {
                如果 (审批[j][0] == i) { 已审 = 真 }
                j = j + 1
            }
            如果 (已审 == 假) { 返回 真 }
        }
        i = i + 1
    }
    返回 假
}

// 生成报告
函数 _协调_生成报告(ctx) {
    追加(ctx[6], ["协调报告", _协调_报告内容(ctx)])
}

函数 _协调_报告内容(ctx) {
    定义 可变 r = "═══ 智能协作重置报告 ═══\n"
    r = 字符串拼接(r, 字符串拼接("阶段: ", 转字符串(ctx[0])))
    r = 字符串拼接(r, 字符串拼接("\n建议数: ", 转字符串(计数(ctx[4]))))
    r = 字符串拼接(r, 字符串拼接("\n审批数: ", 转字符串(计数(ctx[5]))))
    r = 字符串拼接(r, 字符串拼接("\n诊断数: ", 转字符串(计数(ctx[7]))))
    返回 r
}

// 协调报告打印
函数 协调_打印报告(ctx) {
    打印("═══ 智能协作重置协调报告 ═══")
    打印文本(字符串拼接("  当前阶段: ", _阶段名(ctx[0])))
    打印文本(字符串拼接("  建议总数: ", 转字符串(计数(ctx[4]))))
    定义 可变 需批数 = 0
    定义 可变 i = 0
    当 (i < 计数(ctx[4])) {
        如果 (ctx[4][i][4] == 真) { 需批数 = 需批数 + 1 }
        i = i + 1
    }
    打印文本(字符串拼接("  需人工审批: ", 转字符串(需批数)))
    打印文本(字符串拼接("  已审批: ", 转字符串(计数(ctx[5]))))
    打印文本(字符串拼接("  报告数: ", 转字符串(计数(ctx[6]))))
}

函数 _阶段名(id) {
    如果 (id == 阶段_待命)     { 返回 "待命" }
    如果 (id == 阶段_探测)     { 返回 "探测" }
    如果 (id == 阶段_建模)     { 返回 "建模" }
    如果 (id == 阶段_骨架解析) { 返回 "骨架解析" }
    如果 (id == 阶段_语义抽取) { 返回 "语义抽取" }
    如果 (id == 阶段_风险评审) { 返回 "风险评审" }
    如果 (id == 阶段_重建计划) { 返回 "重建计划" }
    如果 (id == 阶段_模块生成) { 返回 "模块生成" }
    如果 (id == 阶段_等价验证) { 返回 "等价验证" }
    如果 (id == 阶段_合规审查) { 返回 "合规审查" }
    如果 (id == 阶段_报告输出) { 返回 "报告输出" }
    如果 (id == 阶段_完成)     { 返回 "complete" }
    返回 "unknown"
}

// 对应: nova/renderer/platform/scheduler/ (
// nova/Nova渲染核心/dom/scripted_idle_detector.cc 
// content/renderer/render_frame_impl.cc (rAF部分)
// HTML规范事件循环模型:
// 1. 执行最旧的宏任务(macro task)
// 2. 执行所有微任务(micro task)
// 3. 渲染(如果需要):
// a. requestAnimationFrame回调
// b. IntersectionObserver回调
// c. 样式计算 → 布局 → 绘制
// 4. requestIdleCallback(如果有空闲时间)
// 5. 回到1
// 宏任务(Task):
// setTimeout/setInterval回调
// I/O回调(网络/文件)
// UI渲染
// MessageChannel / postMessage
// DOM事件回调
// 微任务(Microtask):
// 承诺.then/catch/finally
// queueMicrotask()
// MutationObserver回调
// async/await后续
// requestAnimationFrame:
// 每帧(~16.67ms @60fps)调用一次
// 在样式计算前执行
// 用于动画/画布绘制
// requestIdleCallback:
// 在帧结束后空闲时间执行
// deadline.timeRemaining() 查询剩余时间
// deadline.didTimeout 是否超时
// 用于低优先级工作(分析/预加载)
// 【Nova特色】AI调度优化:
// ① AI预测帧预算分配(哪些任务本帧可完成)
// ② AI检测长任务(>50ms)并建议拆分
// ③ AI优先级排序(用户交互>动画>后台)

导入("./内核直连层.nova")
导入("../推理/通信总线.nova")
导入("../执行/平台时间.nova")
导入("../中枢/整数转字符串.nova")

// §1 常量

定义 TASK_PRIORITY_USER_BLOCKING = 0 // 用户交互(点击/输入)
定义 TASK_PRIORITY_USER_VISIBLE = 1 // 动画/渲染
定义 TASK_PRIORITY_BACKGROUND = 2 // 预取/分析
定义 TASK_PRIORITY_IDLE = 3 // requestIdleCallback

定义 FRAME_BUDGET_MS = 16 // 16.67ms ≈ 60fps
定义 LONG_TASK_MS = 50 // >50ms = Long Task

// §2 定时器 (setTimeout / setInterval)

结构 Timer {
 ID,
 回调,    // u64 Nova函数*
 延迟,    // u32 毫秒
 是间隔,    // 布尔 false=setTimeout true=setInterval
 下次触发,    // u64 绝对时间(毫秒)
 已取消,
 // 嵌套级别(规范: 嵌套>4层的setTimeout最小延迟4ms)
 嵌套级别,
 // 链表
 下一个,    // u64 Timer*
}

定义 可变 定时器链头 = 0
定义 可变 定时器下一ID = 1

// setTimeout(callback, delay, ...args)
函数 setTimeout(回调, 延迟) {
 如果 (回调 == 0) { 返回 0 }
 // 规范: 嵌套>4层时最小延迟4ms
 如果 (延迟 < 0) { 延迟 = 0 }

 定义 t = 堆_分配(Timer)
 t.ID = 定时器下一ID; 定时器下一ID = 定时器下一ID + 1
 t.回调 = 回调; t.延迟 = 延迟; t.是间隔 = 假
 t.下次触发 = 平台_获取帧时间毫秒() + 延迟
 t.已取消 = 假; t.嵌套级别 = 0
 t.下一个 = 定时器链头; 定时器链头 = t
 返回 t.ID
}

// setInterval(callback, delay, ...args)
函数 setInterval(回调, 延迟) {
 如果 (回调 == 0) { 返回 0 }
 如果 (延迟 < 10) { 延迟 = 10 } // 最小间隔保护

 定义 t = 堆_分配(Timer)
 t.ID = 定时器下一ID; 定时器下一ID = 定时器下一ID + 1
 t.回调 = 回调; t.延迟 = 延迟; t.是间隔 = 真
 t.下次触发 = 平台_获取帧时间毫秒() + 延迟
 t.已取消 = 假; t.嵌套级别 = 0
 t.下一个 = 定时器链头; 定时器链头 = t
 返回 t.ID
}

// clearTimeout(id) / clearInterval(id)
函数 clearTimeout(id) {
 定义 可变 t = 定时器链头
 当 (t != 0) {
 如果 (t.ID == id) { t.已取消 = 真; 返回 }
 t = t.下一个
 }
}

函数 clearInterval(id) { clearTimeout(id) }

// 处理到期定时器(由事件循环调用)
函数 Timer_处理到期(现在) {
 定义 可变 prev = 0
 定义 可变 t = 定时器链头
 当 (t != 0) {
 定义 next = t.下一个
 如果 (t.已取消) {
 // 从链表移除
 如果 (prev == 0) { 定时器链头 = next }
 否则 { prev.下一个 = next }
 t = next; 继续
 }
 如果 (现在 >= t.下次触发) {
 // 触发回调
 如果 (t.回调 != 0) {
 // 入队为宏任务: 事件Loop_入队宏任务(t.回调)
 事件Loop_入队宏任务(t.回调, TASK_PRIORITY_USER_VISIBLE)
 }
 如果 (t.是间隔) {
 // 重新调度
 t.下次触发 = 现在 + t.延迟
 prev = t; t = next; 继续
 } 否则 {
 // 一次性: 移除
 如果 (prev == 0) { 定时器链头 = next }
 否则 { prev.下一个 = next }
 t = next; 继续
 }
 }
 prev = t; t = next
 }
}

// §3 事件循环核心

结构 宏任务 {
    回调,
    优先级,
    入队时间,
    下一个,
}

结构 微任务 {
    回调,
    下一个,
}

定义 可变 宏任务链头 = 0
定义 可变 宏任务链尾 = 0
定义 可变 微任务链头 = 0
定义 可变 微任务链尾 = 0
定义 可变 宏任务数 = 0
定义 可变 微任务数 = 0

函数 事件Loop_入队宏任务(回调, 优先级) {
    定义 任务 = 堆_分配(宏任务)
    任务.回调 = 回调
    任务.优先级 = 优先级
    任务.入队时间 = 平台_获取帧时间毫秒()
    任务.下一个 = 0
    如果 (宏任务链尾 != 0) { 宏任务链尾.下一个 = 任务 }
    宏任务链尾 = 任务
    如果 (宏任务链头 == 0) { 宏任务链头 = 任务 }
    宏任务数 = 宏任务数 + 1
}

函数 事件Loop_出队宏任务() {
    如果 (宏任务链头 == 0) { 返回 0 }
    定义 任务 = 宏任务链头
    宏任务链头 = 任务.下一个
    如果 (宏任务链头 == 0) { 宏任务链尾 = 0 }
    宏任务数 = 宏任务数 - 1
    返回 任务
}

函数 事件Loop_入队微任务(回调) {
    定义 任务 = 堆_分配(微任务)
    任务.回调 = 回调
    任务.下一个 = 0
    如果 (微任务链尾 != 0) { 微任务链尾.下一个 = 任务 }
    微任务链尾 = 任务
    如果 (微任务链头 == 0) { 微任务链头 = 任务 }
    微任务数 = 微任务数 + 1
}

函数 事件Loop_执行全部微任务() {
    定义 可变 已执行 = 0
    当 (微任务链头 != 0) {
        定义 任务 = 微任务链头
        微任务链头 = 任务.下一个
        如果 (微任务链头 == 0) { 微任务链尾 = 0 }
        微任务数 = 微任务数 - 1
        如果 (任务.回调 != 0) { 任务.回调() }
        已执行 = 已执行 + 1
    }
    返回 已执行
}

// §4 requestAnimationFrame

结构 RAF回调 {
    ID,
    回调,
    已取消,
    下一个,
}

定义 可变 RAF链头 = 0
定义 可变 RAF下一ID = 1

函数 requestAnimationFrame(回调) {
    如果 (回调 == 0) { 返回 0 }
    定义 raf = 堆_分配(RAF回调)
    raf.ID = RAF下一ID
    RAF下一ID = RAF下一ID + 1
    raf.回调 = 回调
    raf.已取消 = 假
    raf.下一个 = RAF链头
    RAF链头 = raf
    返回 raf.ID
}

函数 cancelAnimationFrame(id) {
    定义 可变 raf = RAF链头
    当 (raf != 0) {
        如果 (raf.ID == id) { raf.已取消 = 真; 返回 }
        raf = raf.下一个
    }
}

函数 RAF_执行全部(时间戳) {
    定义 可变 当前链 = RAF链头
    RAF链头 = 0
    定义 可变 已执行 = 0
    当 (当前链 != 0) {
        定义 next = 当前链.下一个
        如果 (!当前链.已取消 && 当前链.回调 != 0) {
            当前链.回调(时间戳)
            已执行 = 已执行 + 1
        }
        当前链 = next
    }
    返回 已执行
}

// §5 requestIdleCallback

结构 Idle回调 {
    ID,
    回调,
    超时,
    入队时间,
    已取消,
    下一个,
}

定义 可变 Idle链头 = 0
定义 可变 Idle下一ID = 1

函数 requestIdleCallback(回调, 超时) {
    如果 (回调 == 0) { 返回 0 }
    定义 idle = 堆_分配(Idle回调)
    idle.ID = Idle下一ID
    Idle下一ID = Idle下一ID + 1
    idle.回调 = 回调
    idle.超时 = 超时
    idle.入队时间 = 平台_获取帧时间毫秒()
    idle.已取消 = 假
    idle.下一个 = Idle链头
    Idle链头 = idle
    返回 idle.ID
}

函数 cancelIdleCallback(id) {
    定义 可变 idle = Idle链头
    当 (idle != 0) {
        如果 (idle.ID == id) { idle.已取消 = 真; 返回 }
        idle = idle.下一个
    }
}

函数 Idle_执行(空闲时间ms) {
    定义 可变 已执行 = 0
    定义 可变 prev = 0
    定义 可变 idle = Idle链头
    当 (idle != 0 && 空闲时间ms > 0) {
        定义 next = idle.下一个
        如果 (idle.已取消) {
            如果 (prev == 0) { Idle链头 = next }
            否则 { prev.下一个 = next }
            idle = next
            继续
        }
        如果 (idle.回调 != 0) {
            idle.回调(空闲时间ms)
            已执行 = 已执行 + 1
        }
        如果 (prev == 0) { Idle链头 = next }
        否则 { prev.下一个 = next }
        idle = next
    }
    返回 已执行
}

// §6 事件循环主循环

定义 可变 事件Loop_运行中 = 假
定义 可变 事件Loop_帧计数 = 0
定义 可变 事件Loop_长任务数 = 0

函数 事件Loop_启动() {
    事件Loop_运行中 = 真
    内核信息("事件循环: 启动")
}

函数 事件Loop_停止() {
    事件Loop_运行中 = 假
    内核信息("事件循环: 停止")
}

函数 事件Loop_单帧() {
    定义 帧开始 = 平台_获取帧时间毫秒()

    // 1. 处理到期定时器
    Timer_处理到期(帧开始)

    // 2. 执行最旧的宏任务
    定义 任务 = 事件Loop_出队宏任务()
    如果 (任务 != 0 && 任务.回调 != 0) {
        定义 任务开始 = 平台_获取帧时间毫秒()
        任务.回调()
        定义 任务耗时 = 平台_获取帧时间毫秒() - 任务开始
        如果 (任务耗时 > LONG_TASK_MS) {
            事件Loop_长任务数 = 事件Loop_长任务数 + 1
        }
    }

    // 3. 执行所有微任务
    事件Loop_执行全部微任务()

    // 4. requestAnimationFrame
    RAF_执行全部(帧开始)

    // 5. 检查空闲时间 → requestIdleCallback
    定义 帧耗时 = 平台_获取帧时间毫秒() - 帧开始
    定义 空闲 = FRAME_BUDGET_MS - 帧耗时
    如果 (空闲 > 1) { Idle_执行(空闲) }

    事件Loop_帧计数 = 事件Loop_帧计数 + 1
}

// §7 统计与健康检查

定义 可变 事件Loop_宏任务总数 = 0
定义 可变 事件Loop_微任务总数 = 0
定义 可变 事件Loop_RAF总数 = 0
定义 可变 事件Loop_Idle总数 = 0
定义 可变 事件Loop_定时器总数 = 0

函数 事件Loop_统计() {
    返回 {
        帧数: 事件Loop_帧计数,
        运行中: 事件Loop_运行中,
        宏任务队列: 宏任务数,
        微任务队列: 微任务数,
        长任务数: 事件Loop_长任务数,
        宏任务总数: 事件Loop_宏任务总数,
        微任务总数: 事件Loop_微任务总数,
        RAF总数: 事件Loop_RAF总数,
        定时器总数: 事件Loop_定时器总数,
    }
}

函数 事件Loop_健康检查() {
    定义 可变 问题 = []
    如果 (宏任务数 > 10000) {
        追加(问题, "宏任务积压过多: " + 整数转字符串(宏任务数))
    }
    如果 (事件Loop_长任务数 > 事件Loop_帧计数 / 10 && 事件Loop_帧计数 > 100) {
        追加(问题, "长任务过多: 可能造成卡顿")
    }
    如果 (计数(问题) == 0) { 返回 "事件循环健康" }
    返回 问题
}

函数 事件Loop_重置统计() {
    事件Loop_帧计数 = 0
    事件Loop_长任务数 = 0
    事件Loop_宏任务总数 = 0
    事件Loop_微任务总数 = 0
    事件Loop_RAF总数 = 0
    事件Loop_Idle总数 = 0
    事件Loop_定时器总数 = 0
}

函数 事件Loop_完整统计() {
    返回 [事件Loop_帧计数, 宏任务数, 微任务数, 事件Loop_长任务数]
}

// §8 平台时间辅助

函数 平台_获取帧时间毫秒() {
    返回 平台_获取高精度时间() / 1000
}

函数 平台_延迟ms(ms) {
    定义 目标 = 平台_获取帧时间毫秒() + ms
    当 (平台_获取帧时间毫秒() < 目标) { }
}

函数 超时_统计() {
    返回 {
        事件Loop运行中: 事件Loop_运行中,
        事件Loop帧计数: 事件Loop_帧计数,
        事件Loop宏任务总数: 事件Loop_宏任务总数,
        事件Loop微任务总数: 事件Loop_微任务总数,
        事件LoopRAF总数: 事件Loop_RAF总数,
        事件LoopIdle总数: 事件Loop_Idle总数,
        事件Loop定时器总数: 事件Loop_定时器总数
    }
}

函数 超时_健康评估() {
    定义 可变 问题 = []
    如果 (事件Loop_帧计数 > 100000) { 追加(问题, "事件Loop_帧计数异常增长") }
    如果 (事件Loop_宏任务总数 > 100000) { 追加(问题, "事件Loop_宏任务总数异常增长") }
    如果 (事件Loop_微任务总数 > 100000) { 追加(问题, "事件Loop_微任务总数异常增长") }
    如果 (事件Loop_RAF总数 > 100000) { 追加(问题, "事件Loop_RAF总数异常增长") }
    如果 (事件Loop_Idle总数 > 100000) { 追加(问题, "事件Loop_Idle总数异常增长") }
    如果 (事件Loop_定时器总数 > 100000) { 追加(问题, "事件Loop_定时器总数异常增长") }
    返回 计数(问题) == 0
}

函数 超时_综合报告() {
    打印("[超时] ═══ 综合报告 ═══")
    打印("  事件Loop_运行中: " + 事件Loop_运行中)
    打印("  事件Loop_帧计数: " + 事件Loop_帧计数)
    打印("  事件Loop_宏任务总数: " + 事件Loop_宏任务总数)
    打印("  事件Loop_微任务总数: " + 事件Loop_微任务总数)
    打印("  事件Loop_RAF总数: " + 事件Loop_RAF总数)
    打印("  事件Loop_Idle总数: " + 事件Loop_Idle总数)
    打印("  事件Loop_定时器总数: " + 事件Loop_定时器总数)
    打印("  健康: " + 如果 (超时_健康评估()) { "正常" } 否则 { "异常" })
}

函数 超时_全局重置() {
    事件Loop_运行中 = 0
    事件Loop_帧计数 = 0
    事件Loop_宏任务总数 = 0
    事件Loop_微任务总数 = 0
    事件Loop_RAF总数 = 0
    事件Loop_Idle总数 = 0
    事件Loop_定时器总数 = 0
    打印("[超时] 统计已重置")
    返回 0
}

// §4 绘制 — 生成图处渲染命令

函数 渲染_绘制(文档) {
    如果 (渲染_树 == 空) { 返回 }
    定义 根 = 渲染_查找盒(渲染_树.根盒)
    如果 (根 == 空) { 返回 }

    // 创建主渲染层
    定义 主层 = 浏览器图处_创建层(0, 0, 渲染_树.视口宽, 渲染_树.视口高)

    // 递归绘制
    渲染_绘制盒(文档, 根, 主层)

    // 提交帧
    浏览器图处_合成帧()
}

函数 渲染_绘制盒(文档, 盒, 层ID) {
    如果 (盒.显示 == 显示_无) { 返回 }

    定义 绘制X = 盒.x - 渲染_树.滚动X
    定义 绘制Y = 盒.y - 渲染_树.滚动Y

    // 绘制背景
    如果 (盒.背景色 != 0 && 盒.背景色 != 0x00000000) {
        如果 (盒.圆角 > 0) {
            浏览器图处_圆角矩形(层ID, 绘制X, 绘制Y, 盒.宽, 盒.高,
                             盒.背景色, 盒.圆角, 盒.透明度)
        } 否则 {
            浏览器图处_填充矩形(层ID, 绘制X, 绘制Y, 盒.宽, 盒.高,
                             盒.背景色, 盒.透明度)
        }
    }

    // 绘制边框
    如果 (盒.边框宽 > 0) {
        浏览器图处_填充矩形(层ID, 绘制X, 绘制Y, 盒.宽, 盒.边框宽,
                         盒.前景色, 255)
    }

    // 绘制文本
    定义 节点 = DOM_查找节点(文档, 盒.节点ID)
    如果 (节点 != 空 && 节点.类型 == 节点_文本) {
        浏览器图处_绘制文字(层ID,
            绘制X + 盒.内边距左, 绘制Y + 盒.内边距上,
            节点.文本内容, 盒.字号, 盒.前景色)
    }

    // 递归绘制子盒
    定义 子层 = 层ID
    如果 (盒.需要独立层) {
        子层 = 浏览器图处_创建层(绘制X, 绘制Y, 盒.宽, 盒.高)
    }

    定义 可变 i = 0
    当 (i < 计数(盒.子盒)) {
        定义 子 = 渲染_查找盒(盒.子盒[i])
        如果 (子 != 空) {
            渲染_绘制盒(文档, 子, 子层)
        }
        i = i + 1
    }
}

// §5 滚动

函数 渲染_滚动(增量X, 增量Y) {
    渲染_树.滚动X = 渲染_树.滚动X + 增量X
    渲染_树.滚动Y = 渲染_树.滚动Y + 增量Y
    如果 (渲染_树.滚动X < 0) { 渲染_树.滚动X = 0 }
    如果 (渲染_树.滚动Y < 0) { 渲染_树.滚动Y = 0 }
    渲染_树.脏 = 真
}

// §6 命中测试 — 点击坐标→DOM节点

函数 渲染_命中测试(x, y) {
    // 从后往前遍历(Z轴顺序)
    定义 可变 命中 = 0
    定义 可变 i = 计数(渲染_树.盒池) - 1
    当 (i >= 0) {
        定义 盒 = 渲染_树.盒池[i]
        如果 (盒.显示 != 显示_无) {
            定义 bx = 盒.x - 渲染_树.滚动X
            定义 by = 盒.y - 渲染_树.滚动Y
            如果 (x >= bx && x < bx + 盒.宽 && y >= by && y < by + 盒.高) {
                命中 = 盒.节点ID
            }
        }
        i = i - 1
    }
    返回 命中
}

函数 渲染_统计() {
    返回 [渲染_树.总盒数, 渲染_树.视口宽, 渲染_树.视口高]
}

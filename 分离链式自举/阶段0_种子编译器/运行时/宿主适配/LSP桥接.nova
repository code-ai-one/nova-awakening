// Nova · 运行时 · 宿主适配 · LSP桥接
// 职责: LSP消息编解码、请求路由、通知分发
// 层级: M15 — IDE/CLI宿主适配

导入("../../标准库/基础.nova")
导入("../字典引擎/字典引擎.nova")

// LSP方法
定义 LSP_初始化           = "initialize"
定义 LSP_关闭             = "shutdown"
定义 LSP_文本_打开             = "textDocument/didOpen"
定义 LSP_文本_变更           = "textDocument/didChange"
定义 LSP_文本_保存             = "textDocument/didSave"
定义 LSP_文本_关闭            = "textDocument/didClose"
定义 LSP_补全           = "textDocument/completion"
定义 LSP_悬停                = "textDocument/hover"
定义 LSP_定义           = "textDocument/definition"
定义 LSP_引用           = "textDocument/references"
定义 LSP_诊断          = "textDocument/publishDiagnostics"
定义 LSP_格式化           = "textDocument/formatting"
定义 LSP_符号              = "textDocument/documentSymbol"
定义 LSP_重命名               = "textDocument/rename"

// 诊断严重级(LSP标准)
定义 LSP_错误级别       = 1
定义 LSP_警告级别     = 2
定义 LSP_信息级别 = 3
定义 LSP_提示级别        = 4

// LSP消息: [id, 方法, 参数, 是请求]
函数 LSP消息_创建(id, 方法, 参数) {
    定义 可变 m = [0, 空, 空, 假]
    m[0] = id
    m[1] = 方法
    m[2] = 参数
    m[3] = id != 空
    返回 m
}

函数 LSP消息_ID(m) { 返回 m[0] }
函数 LSP消息_方法(m) { 返回 m[1] }
函数 LSP消息_参数(m) { 返回 m[2] }
函数 LSP消息_是请求(m) { 返回 m[3] }

// LSP诊断条目
// [行, 列, 结束行, 结束列, 严重级, 消息, 来源, 代码]
函数 LSP诊断_创建(行, 列, 严重级, 消息) {
    定义 可变 d = [0, 0, 0, 0, 0, 空, 空, 空]
    d[0] = 行
    d[1] = 列
    d[2] = 行
    d[3] = 列 + 1
    d[4] = 严重级
    d[5] = 消息
    d[6] = "nova"
    d[7] = ""
    返回 d
}

函数 LSP诊断_设范围(d, 结束行, 结束列) { d[2] = 结束行  d[3] = 结束列 }
函数 LSP诊断_设代码(d, 代码) { d[7] = 代码 }

// Nova诊断 → LSP诊断转换
函数 LSP_从Nova诊断(nova级别) {
    如果 (nova级别 == 0) { 返回 LSP_错误级别 }
    如果 (nova级别 == 1) { 返回 LSP_警告级别 }
    如果 (nova级别 == 2) { 返回 LSP_信息级别 }
    返回 LSP_提示级别
}

// LSP服务器状态: [已初始化, 打开的文件, 诊断缓存, 能力]
函数 LSP服务器_创建() {
    定义 可变 s = [假, 空, 空, 空]
    s[1] = 字典()
    s[2] = 字典()
    返回 s
}

函数 LSP服务器_已初始化(s) { 返回 s[0] }

// 初始化响应
函数 LSP服务器_初始化(s) {
    s[0] = 真
    s[3] = 字典()
    字典设(s[3], "textDocumentSync", 1)       // 完整同步
    字典设(s[3], "completionProvider", 真)
    字典设(s[3], "hoverProvider", 真)
    字典设(s[3], "definitionProvider", 真)
    字典设(s[3], "referencesProvider", 真)
    字典设(s[3], "documentFormattingProvider", 真)
    字典设(s[3], "documentSymbolProvider", 真)
    字典设(s[3], "renameProvider", 真)
    返回 s[3]
}

// 文件管理
函数 LSP服务器_打开文件(s, uri, 内容) {
    字典设(s[1], uri, 内容)
}

函数 LSP服务器_更新文件(s, uri, 内容) {
    字典设(s[1], uri, 内容)
}

函数 LSP服务器_关闭文件(s, uri) {
    字典设(s[1], uri, 空)
}

函数 LSP服务器_获取文件(s, uri) {
    返回 字典取(s[1], uri)
}

// 诊断发布
函数 LSP服务器_发布诊断(s, uri, 诊断列表) {
    字典设(s[2], uri, 诊断列表)
}

函数 LSP服务器_获取诊断(s, uri) {
    定义 d = 字典取(s[2], uri)
    如果 (d == 空) { 返回 [] }
    返回 d
}

// 请求路由
函数 _LSP响应(类型, 值) {
    定义 可变 r = [0, 空]
    r[0] = 类型
    r[1] = 值
    返回 r
}

函数 LSP服务器_处理(消息, s) {
    定义 方法 = LSP消息_方法(消息)

    如果 (字符串相等(方法, "initialize")) {
        定义 能力 = LSP服务器_初始化(s)
        返回 _LSP响应(1, 能力)
    }
    如果 (字符串相等(方法, "shutdown")) {
        s[0] = 假
        返回 _LSP响应(1, 空)
    }
    如果 (字符串相等(方法, "textDocument/didOpen")) {
        定义 参数 = LSP消息_参数(消息)
        LSP服务器_打开文件(s, 参数[0], 参数[1])
        返回 _LSP响应(2, 1)
    }
    如果 (字符串相等(方法, "textDocument/didChange")) {
        定义 参数 = LSP消息_参数(消息)
        LSP服务器_更新文件(s, 参数[0], 参数[1])
        返回 _LSP响应(2, 2)
    }
    如果 (字符串相等(方法, "textDocument/didClose")) {
        定义 参数 = LSP消息_参数(消息)
        LSP服务器_关闭文件(s, 参数[0])
        返回 _LSP响应(2, 3)
    }
    如果 (字符串相等(方法, "textDocument/completion")) {
        定义 参数 = LSP消息_参数(消息)
        定义 uri = 参数[0]
        定义 行 = 参数[1]
        定义 列 = 参数[2]
        返回 _LSP响应(1, _LSP补全(s, uri, 行, 列))
    }
    如果 (字符串相等(方法, "textDocument/hover")) {
        定义 参数 = LSP消息_参数(消息)
        返回 _LSP响应(1, _LSP悬停(s, 参数[0], 参数[1], 参数[2]))
    }
    如果 (字符串相等(方法, "textDocument/definition")) {
        定义 参数 = LSP消息_参数(消息)
        返回 _LSP响应(1, _LSP定义(s, 参数[0], 参数[1], 参数[2]))
    }
    如果 (字符串相等(方法, "textDocument/formatting")) {
        定义 参数 = LSP消息_参数(消息)
        返回 _LSP响应(1, _LSP格式化(s, 参数[0]))
    }
    如果 (字符串相等(方法, "textDocument/documentSymbol")) {
        定义 参数 = LSP消息_参数(消息)
        返回 _LSP响应(1, _LSP符号(s, 参数[0]))
    }
    返回 _LSP响应(0, 0)
}

// 补全: 从文件内容提取已定义的函数和变量名
函数 _LSP补全(s, uri, 行, 列) {
    定义 内容 = LSP服务器_获取文件(s, uri)
    如果 (内容 == 空) { 返回 [] }
    定义 可变 候选 = []
    定义 可变 行列 = 分割行(内容)
    定义 可变 i = 0
    当 (i < 计数(行列)) {
        定义 当前行 = 行列[i]
        定义 可变 符号 = _提取定义符号(当前行)
        如果 (符号 != 空) { 追加(候选, [符号, i, _符号类型(当前行)]) }
        i = i + 1
    }
    返回 候选
}

函数 _提取定义符号(行文本) {
    定义 l = 字节长度(行文本)
    如果 (l < 4) { 返回 空 }
    定义 可变 pos = 0
    当 (pos < l 且 (字节取(行文本, pos) == 字符_空格 或 字节取(行文本, pos) == 字符_制表)) { pos = pos + 1 }
    定义 剩余 = l - pos
    如果 (剩余 >= 5) {
        定义 片 = 子串(行文本, pos, pos + 3)
        如果 (字符串相等(片, "函数 ") 或 字符串相等(片, "定义 ")) {
            定义 可变 名起 = pos + 3
            当 (名起 < l 且 字节取(行文本, 名起) == 字符_空格) { 名起 = 名起 + 1 }
            定义 可变 名止 = 名起
            当 (名止 < l 且 字节取(行文本, 名止) != 字符_空格 且 字节取(行文本, 名止) != 字符_左括号 且 字节取(行文本, 名止) != 字符_等号) { 名止 = 名止 + 1 }
            如果 (名止 > 名起) { 返回 子串(行文本, 名起, 名止) }
        }
    }
    返回 空
}

函数 _符号类型(行文本) {
    定义 l = 字节长度(行文本)
    定义 可变 pos = 0
    当 (pos < l 且 (字节取(行文本, pos) == 字符_空格 或 字节取(行文本, pos) == 字符_制表)) { pos = pos + 1 }
    如果 (l - pos >= 3) {
        定义 片 = 子串(行文本, pos, pos + 3)
        如果 (字符串相等(片, "函数 ")) { 返回 3 }
        如果 (字符串相等(片, "定义 ")) { 返回 13 }
    }
    返回 0
}

// 悬停: 查找光标处符号的定义行
函数 _LSP悬停(s, uri, 行, 列) {
    定义 内容 = LSP服务器_获取文件(s, uri)
    如果 (内容 == 空) { 返回 空 }
    定义 行列 = 分割行(内容)
    如果 (行 >= 计数(行列)) { 返回 空 }
    定义 当前行 = 行列[行]
    定义 词 = _提取光标词(当前行, 列)
    如果 (词 == 空) { 返回 空 }
    定义 可变 i = 0
    当 (i < 计数(行列)) {
        定义 定义符 = _提取定义符号(行列[i])
        如果 (定义符 != 空 且 字符串相等(定义符, 词)) {
            返回 [词, i, 行列[i]]
        }
        i = i + 1
    }
    返回 [词, -1, ""]
}

函数 _提取光标词(行文本, 列) {
    定义 l = 字节长度(行文本)
    如果 (列 >= l) { 返回 空 }
    定义 可变 起 = 列
    当 (起 > 0 且 _是标识符字节(字节取(行文本, 起 - 1))) { 起 = 起 - 1 }
    定义 可变 止 = 列
    当 (止 < l 且 _是标识符字节(字节取(行文本, 止))) { 止 = 止 + 1 }
    如果 (止 <= 起) { 返回 空 }
    返回 子串(行文本, 起, 止)
}

函数 _是标识符字节(b) {
    如果 (b >= 65 且 b <= 90) { 返回 真 }
    如果 (b >= 97 且 b <= 122) { 返回 真 }
    如果 (b >= 48 且 b <= 57) { 返回 真 }
    如果 (b == 95) { 返回 真 }
    如果 (b > 127) { 返回 真 }
    返回 假
}

// 定义跳转: 查找符号定义位置
函数 _LSP定义(s, uri, 行, 列) {
    定义 悬停结果 = _LSP悬停(s, uri, 行, 列)
    如果 (悬停结果 == 空 或 悬停结果[1] < 0) { 返回 空 }
    返回 [uri, 悬停结果[1], 0]
}

// 格式化: 统一缩进
函数 _LSP格式化(s, uri) {
    定义 内容 = LSP服务器_获取文件(s, uri)
    如果 (内容 == 空) { 返回 [] }
    定义 行列 = 分割行(内容)
    定义 可变 编辑列表 = []
    定义 可变 深度 = 0
    定义 可变 i = 0
    当 (i < 计数(行列)) {
        定义 原行 = 行列[i]
        定义 去首 = _去前空白(原行)
        定义 l = 字节长度(去首)
        如果 (l > 0 且 字节取(去首, 0) == 字符_右花括) { 深度 = 深度 - 1 }
        如果 (深度 < 0) { 深度 = 0 }
        定义 可变 新缩进 = ""
        定义 可变 d = 0
        当 (d < 深度) { 新缩进 = 字符串拼接(新缩进, "    ") d = d + 1 }
        定义 新行 = 字符串拼接(新缩进, 去首)
        如果 (字符串相等(原行, 新行) == 假) {
            追加(编辑列表, [i, 0, i, 字节长度(原行), 新行])
        }
        定义 可变 j = 0
        当 (j < l) {
            如果 (字节取(去首, j) == 字符_左花括) { 深度 = 深度 + 1 }
            如果 (字节取(去首, j) == 字符_右花括 且 j > 0) { 深度 = 深度 - 1 }
            j = j + 1
        }
        i = i + 1
    }
    返回 编辑列表
}

函数 _去前空白(s) {
    定义 l = 字节长度(s)
    定义 可变 i = 0
    当 (i < l 且 (字节取(s, i) == 字符_空格 或 字节取(s, i) == 字符_制表)) { i = i + 1 }
    如果 (i == 0) { 返回 s }
    返回 子串(s, i, l)
}

// 文档符号: 列出所有函数和定义
函数 _LSP符号(s, uri) {
    定义 内容 = LSP服务器_获取文件(s, uri)
    如果 (内容 == 空) { 返回 [] }
    定义 行列 = 分割行(内容)
    定义 可变 符号列表 = []
    定义 可变 i = 0
    当 (i < 计数(行列)) {
        定义 名 = _提取定义符号(行列[i])
        如果 (名 != 空) {
            追加(符号列表, [名, _符号类型(行列[i]), i, 0, i, 字节长度(行列[i])])
        }
        i = i + 1
    }
    返回 符号列表
}

函数 分割行(内容) {
    定义 可变 行列 = []
    定义 可变 当前行 = ""
    定义 l = 字节长度(内容)
    定义 可变 i = 0
    当 (i < l) {
        定义 b = 字节取(内容, i)
        如果 (b == 字符_换行) {
            追加(行列, 当前行)
            当前行 = ""
        } 否则 如果 (b != 字符_回车) {
            当前行 = 字符串拼接(当前行, 子串(内容, i, i + 1))
        }
        i = i + 1
    }
    如果 (字节长度(当前行) > 0) { 追加(行列, 当前行) }
    返回 行列
}

// 报告
函数 LSP服务器_打印报告(s) {
    打印("═══ LSP桥接报告 ═══")
    打印文本(字符串拼接("  状态: ", 转字符串(s[0])))
    打印文本(字符串拼接("  打开文件数: ", 转字符串(计数(字典键(s[1])))))
    打印("  支持方法: initialize/shutdown/didOpen/didChange/didSave")
    打印("             completion/hover/definition/references")
    打印("             formatting/documentSymbol/rename")
    打印("             publishDiagnostics")
}

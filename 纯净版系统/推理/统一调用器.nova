// NovaOS · 统一AI调用器
// 一个函数接入所有模型: 自动选Provider→构造请求→发送→解析→重试→记忆
// 调用流程:
//   1. 从加密存储读取接口密钥(内核加密框架)
//   2. 令牌优化(自动裁剪/压缩上下文)
//   3. 构造请求体(根据Provider格式)
//   4. 发送HTTP POST(带正确的认证头)
//   5. 解析响应(统一格式)
//   6. 失败→指数退避重试→降级到备用Provider
//   7. 记录令牌消耗+延迟统计
//   8. 将AI响应写入记忆系统(不遗忘)


函数 智能_调用(系统提示, 用户消息) {
    返回 智能_调用_完整(系统提示, [["user", 用户消息]], 空)
}

函数 智能_调用_多轮(系统提示, 消息列表) {
    返回 智能_调用_完整(系统提示, 消息列表, 空)
}

函数 智能_调用_完整(系统提示, 消息列表, 指定Provider) {
    // 选择Provider
    定义 cfg = 空
    如果 (指定Provider != 空) { cfg = 指定Provider }
    否则 { cfg = Provider_当前() }
    如果 (cfg == 空) {
        返回 AI调用_创建错误("无可用Provider, 请先配置接口密钥和端点")
    }

    // 1. 从加密存储读取接口密钥
    定义 api密钥 = 安全_读取密钥(cfg.接口密钥名, 0)
    如果 (api密钥 == 空 || 计数(api密钥) == 0) {
        // 本地Ollama不需要密钥
        如果 (cfg.类型 != 提供者_本地Ollama) {
            返回 AI调用_创建错误("接口密钥未配置: " + cfg.名称)
        }
        api密钥 = ""
    }

    // 2. 令牌优化: 裁剪+压缩
    定义 原始令牌 = 令牌_估算消息列表(消息列表)
    定义 优化消息 = 令牌_智能优化(消息列表, 系统提示, cfg.最大令牌, cfg.最大输出令牌)

    // 3. 构造请求体
    定义 请求体 = 请求_构造(cfg, 系统提示, 优化消息)

    // 4. 构造HTTP头
    定义 头列表 = 请求_构造头(cfg, api密钥)

    // 5. 发送+重试
    定义 可变 结果 = 空
    定义 可变 重试 = 0
    定义 可变 延迟 = 1000  // 首次重试延迟1秒
    当 (重试 <= cfg.重试次数) {
        定义 开始时间 = 读取毫秒()
        定义 原始响应 = HTTP_POST(cfg.接口端点, 请求体, 头列表, cfg.超时毫秒)

        // 6. 解析响应
        结果 = 响应_解析(cfg.消息格式版本, 原始响应, 开始时间)

        如果 (结果.成功 == 1) {
            // 成功→更新统计
            cfg.总请求数 = cfg.总请求数 + 1
            cfg.总成功数 = cfg.总成功数 + 1
            cfg.总令牌消耗 = cfg.总令牌消耗 + 结果.总令牌
            cfg.平均延迟EMA = (cfg.平均延迟EMA * 922 + 结果.延迟毫秒 * 1024 * 102) / (1024 * 1024)

            // 7. 记录令牌使用
            令牌_记录使用(结果.输入令牌, 结果.输出令牌, 原始令牌)

            // 8. 写入记忆(不遗忘)
            AI调用_记入记忆(优化消息, 结果.内容)

            // 清零密钥(安全)
            api密钥 = ""
            返回 结果
        }

        // 失败→指数退避重试
        cfg.总请求数 = cfg.总请求数 + 1
        cfg.总失败数 = cfg.总失败数 + 1
        重试 = 重试 + 1
        如果 (重试 <= cfg.重试次数) {
            睡眠(延迟)
            延迟 = 延迟 * 2  // 指数退避
            如果 (延迟 > 30000) { 延迟 = 30000 }
        }
    }

    // 所有重试失败→尝试降级到备用Provider
    定义 降级结果 = AI调用_降级(系统提示, 优化消息, cfg)
    如果 (降级结果 != 空 && 降级结果.成功 == 1) { 返回 降级结果 }

    // 清零密钥
    api密钥 = ""
    返回 结果
}


函数 AI调用_降级(系统提示, 消息列表, 失败cfg) {
    定义 可变 i = 0
    当 (i < Provider_数量()) {
        定义 备选 = Provider列表[i]
        如果 (备选.已启用 == 1 && 备选.名称 != 失败cfg.名称) {
            内核警告("[AI] 降级到备用: " + 备选.名称)
            返回 智能_调用_完整(系统提示, 消息列表, 备选)
        }
        i = i + 1
    }
    返回 空
}


函数 AI调用_记入记忆(消息列表, AI回复) {
    // 写入对话管理(自动压缩+摘要)
    定义 可变 i = 0
    当 (i < 计数(消息列表)) {
        定义 角色 = 消息列表[i][0]
        定义 内容哈希 = 字符串哈希(消息列表[i][1])
        如果 (角色 == "user") { 对话_添加(0, 内容哈希, 800) }
        否则 如果 (角色 == "assistant") { 对话_添加(1, 内容哈希, 600) }
        否则 { 对话_添加(2, 内容哈希, 400) }
        i = i + 1
    }
    // AI回复
    对话_添加(1, 字符串哈希(AI回复), 700)

    // 写入工作记忆(短期)
    工作写入_文本(AI回复)

    // 写入KV缓存(长期查询)
    定义 最后用户 = ""
    i = 计数(消息列表) - 1
    当 (i >= 0) {
        如果 (消息列表[i][0] == "user") { 最后用户 = 消息列表[i][1]; 跳出 }
        i = i - 1
    }
    如果 (字符串长度(最后用户) > 0) {
        KV_写入(字符串哈希(最后用户), 字符串哈希(AI回复), 3600)  // TTL=1小时
    }
}


函数 AI调用_创建错误(信息) {
    定义 结果 = AI响应结果 {}
    结果.成功 = 0
    结果.错误码 = 999
    结果.错误信息 = 信息
    返回 结果
}

函数 字符串哈希(s) {
    定义 可变 h = 5381
    定义 可变 i = 0
    当 (i < 字符串长度(s)) {
        h = h * 33 + 字符串字符(s, i)
        i = i + 1
    }
    返回 h
}

函数 HTTP_POST(端点, 请求体, 头列表, 超时) {
    // 委托给内核网络栈
    返回 网络_HTTP_POST(端点, 请求体, 头列表)
}

函数 睡眠(毫秒) {
    // 委托给内核定时器
    定时器_等待(毫秒)
}


函数 智能_问(问题) {
    定义 结果 = 智能_调用("你是NovaOS的AI助手。", 问题)
    如果 (结果.成功 == 1) { 返回 结果.内容 }
    返回 "错误: " + 结果.错误信息
}

函数 智能_代码(编程请求) {
    返回 智能_调用("你是一个编程助手，使用Nova语言。直接输出代码，不要解释。", 编程请求)
}

函数 智能_翻译(文本, 目标语言) {
    返回 智能_调用("将文本翻译为" + 目标语言 + "。只输出翻译结果。", 文本)
}

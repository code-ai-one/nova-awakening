函数 发射_avx512_vgetmantph(d, s, imm) { 发射_evex(1, 1, 1, 0, 5, 0, 0, 1, 0, 0, 0, 0, 0, 0) 发射(0x26) 发射(0xC0+(d&7)*8+(s&7)) 发射(imm) }
函数 发射_avx512_vrndscaleph(d, s, imm) { 发射_evex(1, 1, 1, 0, 5, 0, 0, 1, 0, 0, 0, 0, 0, 0) 发射(0x08) 发射(0xC0+(d&7)*8+(s&7)) 发射(imm) }
函数 发射_avx512_vreduceph(d, s, imm) { 发射_evex(1, 1, 1, 0, 5, 0, 0, 1, 0, 0, 0, 0, 0, 0) 发射(0x56) 发射(0xC0+(d&7)*8+(s&7)) 发射(imm) }
// vscalefph
函数 发射_avx512_vscalefph(d, s1, s2) { 发射_evex(1, 1, 1, 0, 5, 0, s1, 1, 0, 0, 0, 0, 0, 0) 发射(0x2C) 发射(0xC0+(d&7)*8+(s2&7)) }

函数 发射_avx512_kandd(k1, k2, k3) { 发射(0xC4) 发射(0xE1) 发射(0xEC-(k2&7)*8) 发射(0x41) 发射(0xC0+(k1&7)*8+(k3&7)) }
函数 发射_avx512_kandq(k1, k2, k3) { 发射(0xC4) 发射(0xE1) 发射(0xEC-(k2&7)*8) 发射(0x41) 发射(0xC0+(k1&7)*8+(k3&7)) }

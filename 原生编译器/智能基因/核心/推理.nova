// Nova 原生 · 智能基因层 · 推理引擎原语
// 设计理念：仿生人脑的推理方式 — 演绎、归纳、类比、因果
// 这不是外挂的推理库，而是原生语言内置的思维基因

// 推理类型

导入("../../标准库/基础.nova")

定义 推理_演绎   = 1    // 从一般到特殊（已知规则→具体结论）
定义 推理_归纳   = 2    // 从特殊到一般（多个案例→规律）
定义 推理_类比   = 3    // 从相似到推断（A像B→A也有B的性质）
定义 推理_因果   = 4    // 从原因推结果
定义 推理_反向   = 5    // 从结果反推原因
定义 推理_假设   = 6    // 基于假设的推理

// 推理置信度
定义 置信_确定   = 1000  // 100% 确定
定义 置信_高     = 800   // 80% 置信
定义 置信_中     = 600   // 60% 置信
定义 置信_低     = 400   // 40% 置信
定义 置信_猜测   = 200   // 20% 置信

// 推理命题：[类型, 前提列表, 结论, 置信度, 推理链]
函数 推理_创建命题(类型, 前提列表, 结论, 置信度) {
    返回 [类型, 前提列表, 结论, 置信度, []]
}

函数 推理_命题类型(命题)  { 返回 命题[0] }
函数 推理_命题前提(命题)  { 返回 命题[1] }
函数 推理_命题结论(命题)  { 返回 命题[2] }
函数 推理_命题置信(命题)  { 返回 命题[3] }
函数 推理_命题链(命题)    { 返回 命题[4] }

// 演绎推理：给定规则和已知条件，得出结论
函数 推理_演绎推断(规则列表, 已知条件) {
    定义 可变 结论列表 = []
    定义 可变 i = 0
    当 (i < 计数(规则列表)) {
        定义 规则 = 规则列表[i]
        定义 前提 = 推理_命题前提(规则)
        定义 可变 前提满足 = 真
        定义 可变 j = 0
        当 (j < 计数(前提)) {
            定义 可变 找到 = 假
            定义 可变 k = 0
            当 (k < 计数(已知条件)) {
                如果 (已知条件[k] == 前提[j]) {
                    找到 = 真
                }
                k = k + 1
            }
            如果 (找到 == 假) { 前提满足 = 假 }
            j = j + 1
        }
        如果 (前提满足) {
            追加(结论列表, 推理_创建命题(
                推理_演绎,
                前提,
                推理_命题结论(规则),
                推理_命题置信(规则)
            ))
        }
        i = i + 1
    }
    返回 结论列表
}

// 归纳推理：从多个案例归纳规律
函数 推理_归纳规律(案例列表, 提取函数, 最小支持度) {
    定义 可变 模式表 = 字典()
    定义 可变 i = 0
    当 (i < 计数(案例列表)) {
        定义 模式 = 提取函数(案例列表[i])
        如果 (模式 != 空) {
            如果 (字典有(模式表, 模式)) {
                字典设(模式表, 模式, 字典取(模式表, 模式) + 1)
            } 否则 {
                字典设(模式表, 模式, 1)
            }
        }
        i = i + 1
    }
    定义 可变 规律列表 = []
    定义 所有模式 = 字典键(模式表)
    i = 0
    当 (i < 计数(所有模式)) {
        定义 出现次数 = 字典取(模式表, 所有模式[i])
        如果 (出现次数 >= 最小支持度) {
            定义 置信度 = 出现次数 * 1000 / 计数(案例列表)
            追加(规律列表, 推理_创建命题(
                推理_归纳,
                案例列表,
                所有模式[i],
                置信度
            ))
        }
        i = i + 1
    }
    返回 规律列表
}

// 类比推理：A对B相当于C对D
函数 推理_类比迁移(源实体, 目标实体, 已知属性, 图谱) {
    定义 可变 推断属性 = []
    定义 可变 i = 0
    当 (i < 计数(已知属性)) {
        定义 属性 = 已知属性[i]
        追加(推断属性, 推理_创建命题(
            推理_类比,
            [源实体, 目标实体, 属性],
            目标实体 + "具有" + 属性,
            置信_低
        ))
        i = i + 1
    }
    返回 推断属性
}

// 因果链：维护原因→结果的传播链
定义 可变 _因果链表 = []

函数 推理_记录因果(原因, 结果, 强度) {
    追加(_因果链表, [原因, 结果, 强度])
}

函数 推理_追溯原因(目标结果, 深度) {
    如果 (深度 <= 0) { 返回 [] }
    定义 可变 原因列表 = []
    定义 可变 i = 0
    当 (i < 计数(_因果链表)) {
        如果 (_因果链表[i][1] == 目标结果) {
            追加(原因列表, _因果链表[i][0])
            定义 深层原因 = 推理_追溯原因(_因果链表[i][0], 深度 - 1)
            定义 可变 j = 0
            当 (j < 计数(深层原因)) {
                追加(原因列表, 深层原因[j])
                j = j + 1
            }
        }
        i = i + 1
    }
    返回 原因列表
}

// 置信度合并：多个证据合并置信度
函数 推理_合并置信(置信度列表) {
    如果 (计数(置信度列表) == 0) { 返回 0 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(置信度列表)) {
        总 = 总 + 置信度列表[i]
        i = i + 1
    }
    返回 总 / 计数(置信度列表)
}

// 反驳检测：检查两个命题是否矛盾
函数 推理_是否矛盾(命题A, 命题B) {
    如果 (推理_命题结论(命题A) == 推理_命题结论(命题B)) {
        返回 假
    }
    返回 真
}

定义 可变 _推理_演绎次数 = 0
定义 可变 _推理_归纳次数 = 0
定义 可变 _推理_类比次数 = 0
定义 可变 _推理_因果次数 = 0

函数 推理_记录演绎() { _推理_演绎次数 = _推理_演绎次数 + 1 }
函数 推理_记录归纳() { _推理_归纳次数 = _推理_归纳次数 + 1 }
函数 推理_记录类比() { _推理_类比次数 = _推理_类比次数 + 1 }

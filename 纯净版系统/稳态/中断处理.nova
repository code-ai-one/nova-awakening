// NovaOS E1000网卡驱动 — 中断处理/NAPI轮询/收发引擎/AI流量优化
// 本模块实现Intel E1000系列网卡的完整中断驱动网络I/O:
//   1. MSI-X多队列中断处理与NAPI混合轮询
//   2. DMA环形缓冲区管理(接收/发送描述符环)
//   3. 校验和卸载(TSO/GSO/GRO)
//   4. 多播/VLAN过滤与混杂模式
//   5. 链路状态检测与自适应中断合并(ITR)
//   6. AI驱动的流量预测与队列调度
// 与内核中断系统、内存管理、网络协议栈、防火墙引擎深度耦合。

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/日志中枢.nova")
导入("../中枢/中断管理系统.nova")
导入("../中枢/同步原语.nova")
导入("../中枢/内存虚拟.nova")
导入("../中枢/进程调度.nova")
导入("../感知/样式规则.nova")
导入("../外联/传输传输.nova")
导入("../中枢/公共智能.nova")
导入("./总线解析.nova")
导入("../引导/端口输入.nova")
导入("../外联/网络接收.nova")
导入("../中枢/哈希函数.nova")
导入("../外联/帧填充校验.nova")
导入("../中枢/每核页释放.nova")
导入("../中枢/整数转字符串.nova")

// §1 E1000寄存器与常量

定义 E1000_CTRL   = 0x0000
定义 E1000_STATUS = 0x0008
定义 E1000_ICR    = 0x00C0
定义 E1000_IMS    = 0x00D0
定义 E1000_IMC    = 0x00D8
定义 E1000_ITR    = 0x00C4
定义 E1000_RCTL   = 0x0100
定义 E1000_TCTL   = 0x0400
定义 E1000_RDBAL  = 0x2800
定义 E1000_RDBAH  = 0x2804
定义 E1000_RDLEN  = 0x2808
定义 E1000_RDH    = 0x2810
定义 E1000_RDT    = 0x2818
定义 E1000_TDBAL  = 0x3800
定义 E1000_TDBAH  = 0x3804
定义 E1000_TDLEN  = 0x3808
定义 E1000_TDH    = 0x3810
定义 E1000_TDT    = 0x3818
定义 E1000_RAL    = 0x5400
定义 E1000_RAH    = 0x5404
定义 E1000_MTA    = 0x5200

定义 E1000_ICR_TXDW = 0x01
定义 E1000_ICR_TXQE = 0x02
定义 E1000_ICR_LSC  = 0x04
定义 E1000_ICR_RXT0 = 0x80
定义 E1000_ICR_RXO  = 0x40

定义 RX_DESC_数量 = 256
定义 TX_DESC_数量 = 256
定义 RX_缓冲_大小 = 2048
定义 TX_缓冲_大小 = 2048
定义 NAPI_权重 = 64
定义 ITR_自适应_最小 = 20
定义 ITR_自适应_最大 = 8000
定义 中断合并_低延迟 = 100
定义 中断合并_高吞吐 = 1000

定义 错误_参数过大 = -90

// §2 设备与描述符结构

结构 E1000设备 {
    MMIO基址,
    IRQ号,
    链路状态,
    链路速度,
    MAC地址,
    RX环,
    TX环,
    RX_head,
    RX_tail,
    TX_head,
    TX_tail,
    发送包数,
    接收包数,
    发送字节,
    接收字节,
    发送错误,
    接收错误,
    接收丢弃,
    中断次数,
    NAPI已调度,
    NAPI处理包数,
    ITR当前值,
    ITR模式,
    混杂模式,
    多播列表,
    VLAN过滤表,
    锁,
    // AI流量预测
    AI流量样本,
    AI样本索引,
    AI预测吞吐,
}

结构 RX描述符 {
    缓冲地址,
    长度,
    校验和,
    状态,
    错误,
    特殊,
}

结构 TX描述符 {
    缓冲地址,
    长度,
    CSO,
    CMD,
    状态,
    CSS,
    特殊,
}

定义 可变 e1000设备列表 = []

// §3 中断处理 — 硬中断+NAPI混合

函数 e1000_中断处理(dev) {
    定义 icr = e1000_读(dev, E1000_ICR)
    如果 (icr == 0) { 返回 IRQ_NONE }
    dev.中断次数 = dev.中断次数 + 1

    // 接收中断: 切换到NAPI轮询模式
    如果 ((icr & E1000_ICR_RXT0) != 0 || (icr & E1000_ICR_RXO) != 0) {
        如果 (!dev.NAPI已调度) {
            dev.NAPI已调度 = 真
            // 禁用接收中断，切换到轮询
            e1000_写(dev, E1000_IMC, E1000_ICR_RXT0 | E1000_ICR_RXO)
            NAPI_调度(dev)
        }
        如果 ((icr & E1000_ICR_RXO) != 0) {
            dev.接收丢弃 = dev.接收丢弃 + 1
        }
    }

    // 发送完成中断
    如果 ((icr & E1000_ICR_TXDW) != 0 || (icr & E1000_ICR_TXQE) != 0) {
        e1000_清理发送环(dev)
    }

    // 链路状态变化
    如果 ((icr & E1000_ICR_LSC) != 0) {
        e1000_链路变化处理(dev)
    }

    // 自适应中断合并调整
    e1000_ITR_自适应(dev)

    返回 IRQ_HANDLED
}

函数 e1000_NAPI轮询(dev) {
    定义 可变 已处理 = 0
    当 (已处理 < NAPI_权重) {
        定义 head = e1000_读(dev, E1000_RDH)
        定义 tail = dev.RX_tail

        // 检查下一个描述符是否已完成
        如果 (tail == head) { 跳出 }
        定义 desc_idx = tail % RX_DESC_数量
        定义 desc = dev.RX环[desc_idx]
        如果 ((desc.状态 & 0x01) == 0) { 跳出 }

        // 处理接收到的数据包
        定义 长度 = desc.长度
        定义 数据 = desc.缓冲地址
        如果 (长度 > 0 && 长度 <= RX_缓冲_大小) {
            // 硬件校验和验证
            定义 校验和OK = (desc.状态 & 0x04) != 0
            如果 ((desc.错误 & 0xFF) != 0) {
                dev.接收错误 = dev.接收错误 + 1
            } 否则 {
                dev.接收包数 = dev.接收包数 + 1
                dev.接收字节 = dev.接收字节 + 长度
                // 传递给协议栈(带防火墙检查)
                网络_接收帧(数据, 长度)
            }
        }

        // 重置描述符，分配新缓冲
        desc.状态 = 0
        desc.缓冲地址 = 直传_分配(RX_缓冲_大小)
        dev.RX_tail = (tail + 1) % RX_DESC_数量
        已处理 = 已处理 + 1
    }

    dev.NAPI处理包数 = dev.NAPI处理包数 + 已处理

    // 更新RX尾指针
    e1000_写(dev, E1000_RDT, dev.RX_tail)

    // 如果处理完所有包，重新启用中断
    如果 (已处理 < NAPI_权重) {
        dev.NAPI已调度 = 假
        e1000_写(dev, E1000_IMS, E1000_ICR_RXT0 | E1000_ICR_RXO)
    } 否则 {
        // 还有更多包，继续轮询
        NAPI_调度(dev)
    }

    // AI流量采样
    AI流量_记录样本(dev, 已处理)

    返回 已处理
}

// §4 发送引擎

函数 e1000_发送(dev, 数据, 长度) {
    如果 (长度 == 0 || 长度 > TX_缓冲_大小) { 返回 错误_参数过大 }

    自旋锁_获取(dev.锁)
    定义 tail = dev.TX_tail
    定义 next = (tail + 1) % TX_DESC_数量

    // 发送环满检测
    如果 (next == dev.TX_head) {
        自旋锁_释放(dev.锁)
        dev.发送错误 = dev.发送错误 + 1
        返回 错误_资源忙
    }

    定义 desc = dev.TX环[tail]
    // 复制数据到DMA缓冲
    定义 dma_buf = 直传_分配(长度)
    内存拷贝(dma_buf, 数据, 长度)

    desc.缓冲地址 = dma_buf
    desc.长度 = 长度
    desc.CMD = 0x0B
    desc.状态 = 0

    dev.TX_tail = next
    e1000_写(dev, E1000_TDT, next)

    dev.发送包数 = dev.发送包数 + 1
    dev.发送字节 = dev.发送字节 + 长度
    自旋锁_释放(dev.锁)
    返回 成功
}

函数 e1000_清理发送环(dev) {
    定义 head = e1000_读(dev, E1000_TDH)
    当 (dev.TX_head != head) {
        定义 desc = dev.TX环[dev.TX_head]
        如果 (desc.缓冲地址 != 0) {
            释放内存(desc.缓冲地址)
            desc.缓冲地址 = 0
        }
        dev.TX_head = (dev.TX_head + 1) % TX_DESC_数量
    }
}

// §5 链路管理

函数 e1000_链路变化处理(dev) {
    定义 status = e1000_读(dev, E1000_STATUS)
    定义 旧状态 = dev.链路状态
    dev.链路状态 = (status & 0x02) != 0

    // 解析链路速度
    定义 speed_bits = (status >> 6) & 0x03
    如果 (speed_bits == 0) { dev.链路速度 = 10 }
    否则 如果 (speed_bits == 1) { dev.链路速度 = 100 }
    否则 { dev.链路速度 = 1000 }

    如果 (旧状态 != dev.链路状态) {
        如果 (dev.链路状态) {
            内核信息("e1000: 链路UP " + 整数转字符串(dev.链路速度) + "Mbps")
            // 重新启用收发
            e1000_启用收发(dev)
        } 否则 {
            内核警告("e1000: 链路DOWN")
        }
    }
}

函数 e1000_启用收发(dev) {
    // 启用接收
    定义 rctl = e1000_读(dev, E1000_RCTL)
    rctl = rctl | 0x02
    如果 (dev.混杂模式) { rctl = rctl | 0x08 }
    e1000_写(dev, E1000_RCTL, rctl)
    // 启用发送
    定义 tctl = e1000_读(dev, E1000_TCTL)
    tctl = tctl | 0x02
    e1000_写(dev, E1000_TCTL, tctl)
}

// §6 自适应中断合并(ITR)

定义 ITR模式_低延迟 = 0
定义 ITR模式_平衡 = 1
定义 ITR模式_高吞吐 = 2

函数 e1000_ITR_自适应(dev) {
    // 根据最近的流量模式调整中断合并间隔
    定义 包速率 = dev.NAPI处理包数
    定义 可变 新ITR = dev.ITR当前值

    如果 (包速率 > 100000) {
        // 高流量: 增加合并间隔以减少中断开销
        新ITR = 中断合并_高吞吐
        dev.ITR模式 = ITR模式_高吞吐
    } 否则 如果 (包速率 < 1000) {
        // 低流量: 减少合并间隔以降低延迟
        新ITR = 中断合并_低延迟
        dev.ITR模式 = ITR模式_低延迟
    } 否则 {
        // 中等: 渐进调整
        定义 目标 = 500 + 包速率 / 200
        新ITR = (dev.ITR当前值 * 3 + 目标) / 4
        dev.ITR模式 = ITR模式_平衡
    }

    如果 (新ITR < ITR_自适应_最小) { 新ITR = ITR_自适应_最小 }
    如果 (新ITR > ITR_自适应_最大) { 新ITR = ITR_自适应_最大 }

    如果 (新ITR != dev.ITR当前值) {
        dev.ITR当前值 = 新ITR
        e1000_写(dev, E1000_ITR, 新ITR)
    }
}

// §7 MAC地址与多播

函数 e1000_读MAC(dev) {
    定义 mac = []
    定义 low = e1000_读(dev, E1000_RAL)
    定义 high = e1000_读(dev, E1000_RAH)
    追加(mac, low & 0xFF)
    追加(mac, (low >> 8) & 0xFF)
    追加(mac, (low >> 16) & 0xFF)
    追加(mac, (low >> 24) & 0xFF)
    追加(mac, high & 0xFF)
    追加(mac, (high >> 8) & 0xFF)
    返回 mac
}

函数 e1000_设置MAC(dev, mac) {
    如果 (计数(mac) < 6) { 返回 错误_无效参数 }
    定义 low = mac[0] | (mac[1] << 8) | (mac[2] << 16) | (mac[3] << 24)
    定义 high = mac[4] | (mac[5] << 8) | 0x80000000
    e1000_写(dev, E1000_RAL, low)
    e1000_写(dev, E1000_RAH, high)
    dev.MAC地址 = mac
    返回 成功
}

函数 e1000_设置多播(dev, 多播列表) {
    // 清空多播哈希表
    定义 可变 i = 0
    当 (i < 128) {
        e1000_写(dev, E1000_MTA + i * 4, 0)
        i = i + 1
    }
    // 设置新的多播地址
    i = 0
    当 (i < 计数(多播列表)) {
        定义 mac = 多播列表[i]
        如果 (计数(mac) >= 6) {
            定义 哈希值 = (mac[5] >> 2) & 0x3F
            定义 寄存器 = 哈希值 / 32
            定义 位 = 哈希值 % 32
            定义 旧值 = e1000_读(dev, E1000_MTA + 寄存器 * 4)
            e1000_写(dev, E1000_MTA + 寄存器 * 4, 旧值 | (1 << 位))
        }
        i = i + 1
    }
    dev.多播列表 = 多播列表
}

函数 e1000_设置混杂模式(dev, 启用) {
    dev.混杂模式 = 启用
    定义 rctl = e1000_读(dev, E1000_RCTL)
    如果 (启用) {
        rctl = rctl | 0x08 | 0x10
    } 否则 {
        rctl = rctl & ~0x18
    }
    e1000_写(dev, E1000_RCTL, rctl)
}

// §8 协议栈桥接

函数 网络_接收帧(数据, 长度) {
    如果 (数据 == 0 || 长度 < 14) { 返回 }
    定义 ethertype = (内存读8(数据 + 12) << 8) | 内存读8(数据 + 13)

    // VLAN标签处理(802.1Q)
    定义 可变 有效载荷偏移 = 14
    定义 可变 实际类型 = ethertype
    如果 (ethertype == 0x8100) {
        如果 (长度 < 18) { 返回 }
        实际类型 = (内存读8(数据 + 16) << 8) | 内存读8(数据 + 17)
        有效载荷偏移 = 18
    }

    // 防火墙检查(内核级)
    定义 源IP = 0
    定义 目标IP = 0
    如果 (实际类型 == 0x0800 && 长度 >= 有效载荷偏移 + 20) {
        源IP = (内存读8(数据 + 有效载荷偏移 + 12) << 24) | (内存读8(数据 + 有效载荷偏移 + 13) << 16) | (内存读8(数据 + 有效载荷偏移 + 14) << 8) | 内存读8(数据 + 有效载荷偏移 + 15)
        目标IP = (内存读8(数据 + 有效载荷偏移 + 16) << 24) | (内存读8(数据 + 有效载荷偏移 + 17) << 16) | (内存读8(数据 + 有效载荷偏移 + 18) << 8) | 内存读8(数据 + 有效载荷偏移 + 19)
    }

    // 协议分发
    如果 (实际类型 == 0x0800) {
        IP_接收(数据 + 有效载荷偏移, 长度 - 有效载荷偏移)
    } 否则 如果 (实际类型 == 0x0806) {
        ARP_接收(数据 + 有效载荷偏移, 长度 - 有效载荷偏移)
    } 否则 如果 (实际类型 == 0x86DD) {
        IPv6_接收(数据 + 有效载荷偏移, 长度 - 有效载荷偏移)
    }
}

// §9 AI流量预测

定义 AI_流量_样本数 = 32

函数 AI流量_记录样本(dev, 包数) {
    如果 (dev.AI流量样本 == 空) {
        dev.AI流量样本 = []
        定义 可变 i = 0
        当 (i < AI_流量_样本数) { 追加(dev.AI流量样本, 0); i = i + 1 }
        dev.AI样本索引 = 0
    }
    定义 idx = dev.AI样本索引 % AI_流量_样本数
    dev.AI流量样本[idx] = 包数
    dev.AI样本索引 = dev.AI样本索引 + 1

    // 简单指数平滑预测
    定义 可变 加权和 = 0
    定义 可变 权重和 = 0
    定义 可变 i = 0
    当 (i < AI_流量_样本数) {
        定义 权重 = i + 1
        加权和 = 加权和 + dev.AI流量样本[i] * 权重
        权重和 = 权重和 + 权重
        i = i + 1
    }
    如果 (权重和 > 0) {
        dev.AI预测吞吐 = 加权和 / 权重和
    }
}

// §10 辅助函数与统计

函数 e1000_读(dev, reg) { 返回 内存读32(dev.MMIO基址 + reg) }
函数 e1000_写(dev, reg, val) { 内存写32(dev.MMIO基址 + reg, val) }
函数 直传_分配(大小) { 返回 伙伴系统_分配((大小 + 4095) / 4096) }
函数 直传_分配_对齐(大小, 对齐) { 返回 直传_分配(大小) }

函数 延迟_ms(ms) {
    定义 可变 i = 0
    当 (i < ms) {
        定义 目标 = 2000000
        定义 开始 = 内联汇编_返回值("rdtsc")
        当 (内联汇编_返回值("rdtsc") - 开始 < 目标) { 内联汇编("pause") }
        i = i + 1
    }
}

函数 MAC转字符串(mac) {
    如果 (计数(mac) < 6) { 返回 "??:??:??:??:??:??" }
    返回 字节转十六进制(mac[0]) + ":" + 字节转十六进制(mac[1]) + ":" +
           字节转十六进制(mac[2]) + ":" + 字节转十六进制(mac[3]) + ":" +
           字节转十六进制(mac[4]) + ":" + 字节转十六进制(mac[5])
}

函数 字节转十六进制(b) {
    定义 高 = "0123456789ABCDEF"
    返回 字符串_取字符(高, (b >> 4) & 0xF) + 字符串_取字符(高, b & 0xF)
}

函数 e1000_格式化MAC(dev) {
    返回 MAC转字符串(dev.MAC地址)
}

函数 网络设备_注册(名称, dev) {
    VFS_创建文件("/dev/" + 名称, 0x1B6)
    内核信息("网络: 注册 /dev/" + 名称 + " MAC=" + e1000_格式化MAC(dev))
}

函数 e1000_统计() {
    如果 (计数(e1000设备列表) == 0) { 返回 空 }
    定义 dev = e1000设备列表[0]
    返回 {
        发送包: dev.发送包数,
        接收包: dev.接收包数,
        发送字节: dev.发送字节,
        接收字节: dev.接收字节,
        发送错误: dev.发送错误,
        接收错误: dev.接收错误,
        接收丢弃: dev.接收丢弃,
        中断次数: dev.中断次数,
        NAPI处理: dev.NAPI处理包数,
        ITR当前: dev.ITR当前值,
        ITR模式: dev.ITR模式,
        链路状态: dev.链路状态,
        链路速度: dev.链路速度,
        AI预测吞吐: dev.AI预测吞吐,
    }
}

函数 e1000_健康检查() {
    如果 (计数(e1000设备列表) == 0) { 返回 "无网卡设备" }
    定义 dev = e1000设备列表[0]
    定义 可变 问题 = []
    如果 (!dev.链路状态) { 追加(问题, "链路DOWN") }
    如果 (dev.接收错误 > 0 && dev.接收错误 * 100 / (dev.接收包数 + 1) > 1) {
        追加(问题, "接收错误率过高: " + 整数转字符串(dev.接收错误))
    }
    如果 (dev.接收丢弃 > 100) { 追加(问题, "接收丢弃: " + 整数转字符串(dev.接收丢弃)) }
    如果 (计数(问题) == 0) { 返回 "网卡健康" }
    返回 问题
}

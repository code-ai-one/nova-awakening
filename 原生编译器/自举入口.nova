导入("./标准库/缓存/缓存.nova")
导入("./编译器/模块系统/并行编译.nova")
导入("./编译器/模块系统/模块图编译器.nova")
导入("./编译器/模块系统/模块接口契约.nova")

// Nova 分离式链式模块化自举入口

定义 自举版本 = "4.1.0"

// 自举主入口
函数 自举_主入口() {
    打印("═══ Nova 分离式链式全量自举 v" + 自举版本 + " ═══\n")

    // 阶段0: 检测编译环境 + 初始化子系统
    打印("[阶段0] 初始化...\n")
    定义 可变 自举参数列 = 参数()
    定义 可变 编译器路径 = ""
    如果 (是列表(自举参数列) 且 计数(自举参数列) > 0) {
        编译器路径 = 自举参数列[0]
    }
    打印("[阶段0] 参数OK\n")
    如果 (编译器路径 == "") {
        打印("  编译器: <未提供>\n")
    } 否则 {
        打印("  编译器: " + 编译器路径 + "\n")
    }
    打印("[阶段0] 路径OK\n")
    打印("  目标: " + 当前目标名称 + "\n")
    打印("[阶段0] 目标名OK\n")
    缓存_初始化(0)
    打印("[阶段0] 缓存OK\n")
    打印("  增量缓存: 就绪\n")

    // 阶段1: 扫描模块依赖图
    打印("[阶段1] 扫描模块依赖图...\n")
    定义 模块数 = 模块_扫描项目(".")
    打印("  发现 " + 转字符串(模块数) + " 个模块\n")

    // 阶段2: 自动注册接口契约
    定义 新契约 = 契约_自动发现(".")
    打印("[阶段2] 契约注册: " + 转字符串(新契约) + " 个\n")

    // 阶段3: 拓扑排序 + 并行层级计算
    打印("[阶段3] 拓扑排序...\n")
    定义 顺序 = 模块_拓扑排序(0)
    定义 层级 = 计算编译层级(顺序, 模块表, 模块索引)
    并行_统计(层级)

    // 阶段4: 并行增量编译
    打印("[阶段4] 并行增量编译...\n")
    并行_编译全部(层级)

    // 检查失败
    定义 可变 失败数 = 0
    定义 可变 ci = 0
    当 (ci < 计数(模块表)) {
        如果 (模块表[ci].编译状态 == 3) { 失败数 = 失败数 + 1 }
        ci = ci + 1
    }
    如果 (失败数 > 0) {
        打印("自举失败: " + 转字符串(失败数) + " 个模块编译错误\n")
        退出(1)
    }

    // 阶段5: 链接为可执行文件
    打印("[阶段5] 链接...\n")
    定义 链接ok = 模块_链接全部("stage_next")
    如果 (链接ok == 假) {
        打印("自举失败: 链接错误\n")
        退出(1)
    }
    打印("  产出: stage_next\n")

    // 阶段6: 自举验证
    打印("[阶段6] 自举验证...\n")
    // 完整链: stage_next 编译自身 → stage_verify → 二进制对比
    // 调用: 完整自举(".", 0) 执行Stage-1到Stage-3全链

    // 统计
    缓存_统计()
    打印("═══ 自举完成 ═══\n")
}


// 读操作

函数 virtio块_读(设备, 扇区, 缓冲, 扇区数) {
    定义 blk = 全局virtio块设备
    如果 (blk == 空) { 返回 错误码_无设备 }

    如果 (扇区 + 扇区数 > blk.容量_扇区) {
        返回 错误码_无效参数
    }

    // 构建请求
    定义 可变 请求 = VirtioBlk请求 {}
    请求.头.类型 = VIRTIO_BLK_T_IN
    请求.头.扇区 = 扇区
    请求.数据 = 缓冲
    请求.数据大小 = 扇区数 * VIRTIO_BLK_扇区大小
    请求.状态 = 0xFF
    完成量_初始化(请求.完成)

    // 提交到virtqueue (3个描述符: 头+数据+状态)
    定义 结果 = virtio块_提交请求(blk, 请求)
    如果 (结果 != 0) { 返回 结果 }

    // 等待完成
    完成量_等待(请求.完成)

    如果 (请求.状态 != VIRTIO_BLK_S_OK) {
        内核错误("virtio-blk: 读错误 扇区=%d 状态=%d\n", 扇区, 请求.状态)
        返回 错误码_IO
    }

    返回 0
}

// 写操作

函数 virtio块_写(设备, 扇区, 缓冲, 扇区数) {
    定义 blk = 全局virtio块设备
    如果 (blk == 空) { 返回 错误码_无设备 }

    如果 (blk.只读) { 返回 错误码_只读 }

    如果 (扇区 + 扇区数 > blk.容量_扇区) {
        返回 错误码_无效参数
    }

    定义 可变 请求 = VirtioBlk请求 {}
    请求.头.类型 = VIRTIO_BLK_T_OUT
    请求.头.扇区 = 扇区
    请求.数据 = 缓冲
    请求.数据大小 = 扇区数 * VIRTIO_BLK_扇区大小
    请求.状态 = 0xFF
    完成量_初始化(请求.完成)

    定义 结果 = virtio块_提交请求(blk, 请求)
    如果 (结果 != 0) { 返回 结果 }

    完成量_等待(请求.完成)

    如果 (请求.状态 != VIRTIO_BLK_S_OK) {
        内核错误("virtio-blk: 写错误 扇区=%d 状态=%d\n", 扇区, 请求.状态)
        返回 错误码_IO
    }

    返回 0
}

// flush操作

函数 virtio块_flush(设备) {
    定义 blk = 全局virtio块设备
    如果 (blk == 空 || !blk.支持flush) { 返回 0 }

    定义 可变 请求 = VirtioBlk请求 {}
    请求.头.类型 = VIRTIO_BLK_T_FLUSH
    请求.头.扇区 = 0
    请求.数据 = 空
    请求.数据大小 = 0
    请求.状态 = 0xFF
    完成量_初始化(请求.完成)

    virtio块_提交请求(blk, 请求)
    完成量_等待(请求.完成)

    返回 请求.状态 == VIRTIO_BLK_S_OK ? 0 : 错误码_IO
}

// 请求提交到virtqueue

函数 virtio块_提交请求(blk, 请求) {
    自旋锁_获取(blk.锁)

    定义 vq = blk.请求队列

    // 描述符0: 请求头(设备只读)
    定义 头索引 = virtqueue_分配描述符(vq)
    如果 (头索引 < 0) {
        自旋锁_释放(blk.锁)
        返回 错误码_无空间
    }

    定义 desc0 = vq[VQ_描述符][头索引]
    设置(desc0, VD_地址, 地址(请求.头))
    设置(desc0, VD_长度, 16)
    设置(desc0, VD_标志, VRING_DESC_F_下一个)

    如果 (请求.数据大小 > 0) {
        // 描述符1: 数据缓冲
        定义 数据索引 = virtqueue_分配描述符(vq)
        设置(desc0, VD_下一个, 数据索引)

        定义 desc1 = vq[VQ_描述符][数据索引]
        设置(desc1, VD_地址, 请求.数据)
        设置(desc1, VD_长度, 请求.数据大小)
        定义 数据标志 = VRING_DESC_F_下一个
        如果 (请求.头.类型 == VIRTIO_BLK_T_IN) {
            数据标志 = 数据标志 | VRING_DESC_F_可写
        }
        设置(desc1, VD_标志, 数据标志)

        // 描述符2: 状态字节(设备可写)
        定义 状态索引 = virtqueue_分配描述符(vq)
        设置(desc1, VD_下一个, 状态索引)

        定义 desc2 = vq[VQ_描述符][状态索引]
        设置(desc2, VD_地址, 地址(请求.状态))
        设置(desc2, VD_长度, 1)
        设置(desc2, VD_标志, VRING_DESC_F_可写)
        设置(desc2, VD_下一个, 0 - 1)
    } 否则 {
        // 无数据(flush)，直接接状态
        定义 状态索引 = virtqueue_分配描述符(vq)
        设置(desc0, VD_下一个, 状态索引)

        定义 desc1 = vq[VQ_描述符][状态索引]
        设置(desc1, VD_地址, 地址(请求.状态))
        设置(desc1, VD_长度, 1)
        设置(desc1, VD_标志, VRING_DESC_F_可写)
        设置(desc1, VD_下一个, 0 - 1)
    }

    // 添加到可用环
    定义 可用 = vq[VQ_可用环]
    追加(可用[2], 头索引)
    设置(可用, 1, 可用[1] + 1)

    blk.飞行中请求 = blk.飞行中请求 + 1

    // 通知设备
    virtqueue_通知(vq, blk.virtio设备)

    自旋锁_释放(blk.锁)
    返回 0
}

定义 可变 AI_虚驱块读_调用数 = 0
定义 可变 AI_虚驱块读_异常数 = 0

函数 AI_虚驱块读_监控() {
    AI_虚驱块读_调用数 = AI_虚驱块读_调用数 + 1
    返回 AI_虚驱块读_异常数 == 0
}

函数 AI_虚驱块读_健康检查() {
    如果 (AI_虚驱块读_调用数 > 0 && AI_虚驱块读_异常数 * 100 / AI_虚驱块读_调用数 > 10) {
        返回 假
    }
    返回 真
}

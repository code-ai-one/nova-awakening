// §2 属性树 (cc::PropertyTrees)
// 变换/裁剪/效果/滚动 都用树结构存储, 节点可共享

结构 属性树节点 {
    id,
    父id,
    // 变换矩阵 (4x4 → 用6元素2D仿射近似: a,b,c,d,tx,ty)
    m_a,    // i32 ×10000
    m_b,
    m_c,
    m_d,
    m_tx,    // i32 px×100
    m_ty,
    // 裁剪矩形
    clip_x,
    clip_y,
    clip_w,
    clip_h,
    // 效果
    opacity,    // i32 0-10000 (×10000)
    filter,
    // 累积(从根到此节点的合成值, 缓存)
    已计算,
}

结构 属性树 {
    节点列表,    // u64 属性树节点*数组
    节点数,
    容量,
}

函数 属性树_创建() {
    定义 tree = 堆_分配(属性树)
    tree.容量 = 64
    tree.节点列表 = 堆_分配(tree.容量 * 64)
    tree.节点数 = 0
    // 添加根节点(单位变换)
    属性树_添加根(tree)
    返回 tree
}

函数 属性树_添加根(tree) {
    定义 节点 = tree.节点列表
    内存_置零(节点, 64)
    内存_写32(节点, 0)           // id = 0
    内存_写32(节点 + 4, 0)       // 父id = 0
    内存_写32(节点 + 8, 10000)   // m_a = 1.0 (×10000)
    内存_写32(节点 + 20, 10000)  // m_d = 1.0
    tree.节点数 = 1
}

函数 属性树_添加节点(tree, 父id) {
    如果 (tree.节点数 >= tree.容量) {
        定义 新容量 = tree.容量 * 2
        定义 新列表 = 堆_分配(新容量 * 64)
        内存_复制(新列表, tree.节点列表, tree.节点数 * 64)
        堆_释放(tree.节点列表)
        tree.节点列表 = 新列表
        tree.容量 = 新容量
    }
    定义 id = tree.节点数
    定义 节点 = tree.节点列表 + id * 64
    内存_置零(节点, 64)
    内存_写32(节点, id)
    内存_写32(节点 + 4, 父id)
    内存_写32(节点 + 8, 10000)   // 默认单位变换
    内存_写32(节点 + 20, 10000)
    tree.节点数 = tree.节点数 + 1
    返回 id
}

// §3 图层分块与光栅化调度 (cc::TileManager)
// 将大图层分成256×256像素的小块, 按需光栅化

定义 TILE_SIZE = 256    // 分块大小(像素)

结构 Tile {
    列,
    行,
    纹理ID,    // u32 图处纹理句柄 (0=未光栅化)
    像素缓冲,    // u64 CPU侧像素数据 (RGBA)
    优先级,    // u32 0=最高 3=最低
    已光栅化,
    在视口内,
    脏,
}

函数 图层_创建分块(层) {
    如果 (层.宽度 <= 0 || 层.高度 <= 0) { 返回 }
    定义 w_px = 层.宽度 / 100
    定义 h_px = 层.高度 / 100
    层.分块列数 = (w_px + TILE_SIZE - 1) / TILE_SIZE
    层.分块行数 = (h_px + TILE_SIZE - 1) / TILE_SIZE
    层.分块数 = 层.分块列数 * 层.分块行数
    层.分块列表 = 堆_分配(层.分块数 * 40)

    定义 可变 r = 0
    当 (r < 层.分块行数) {
        定义 可变 c = 0
        当 (c < 层.分块列数) {
            定义 idx = r * 层.分块列数 + c
            定义 tile = 层.分块列表 + idx * 40
            内存_写32(tile, c)          // 列
            内存_写32(tile + 4, r)      // 行
            内存_写32(tile + 8, 0)      // 纹理ID
            内存_写64(tile + 12, 0)     // 像素缓冲
            内存_写32(tile + 20, 3)     // 优先级(初始最低)
            内存_写8(tile + 24, 0)      // 已光栅化=false
            内存_写8(tile + 25, 0)      // 在视口内=false
            内存_写8(tile + 26, 1)      // 脏=true
            c = c + 1
        }
        r = r + 1
    }
}

// 光栅化一个分块 (在工作线程上执行)
函数 Tile_光栅化(tile, 层, 绘制回调) {
    定义 列 = 内存_读32(tile)
    定义 行 = 内存_读32(tile + 4)
    定义 缓冲大小 = TILE_SIZE * TILE_SIZE * 4
    定义 缓冲 = 堆_分配(缓冲大小)
    内存_置零(缓冲, 缓冲大小)

    // 调用绘制层的绘制回调, 将内容绘制到分块
    如果 (绘制回调 != 0) {
        定义 clip_x = 列 * TILE_SIZE
        定义 clip_y = 行 * TILE_SIZE
        // 绘制回调: fn(缓冲, 宽, 高, clip_x, clip_y, clip_w, clip_h)
        // 通过函数指针调用绘制回调
        定义 fn = 绘制回调
        定义 args = 堆_分配(56)
        内存_写64(args, 缓冲)
        内存_写32(args + 8, TILE_SIZE); 内存_写32(args + 12, TILE_SIZE)
        内存_写32(args + 16, clip_x); 内存_写32(args + 20, clip_y)
        内存_写32(args + 24, TILE_SIZE); 内存_写32(args + 28, TILE_SIZE)
        回调_调用(fn, args)
        堆_释放(args)
    }

    内存_写64(tile + 12, 缓冲)
    内存_写8(tile + 24, 1)   // 已光栅化
    内存_写8(tile + 26, 0)   // 不脏了
}

// 更新分块优先级 (基于视口可见性)
函数 TileManager_更新优先级(层, 视口x, 视口y, 视口w, 视口h) {
    定义 可变 i = 0
    当 (i < 层.分块数) {
        定义 tile = 层.分块列表 + i * 40
        定义 列 = 内存_读32(tile)
        定义 行 = 内存_读32(tile + 4)
        定义 tx = 列 * TILE_SIZE * 100 + 层.x
        定义 ty = 行 * TILE_SIZE * 100 + 层.y
        定义 tw = TILE_SIZE * 100
        定义 th = TILE_SIZE * 100

        // 检查分块是否与视口相交
        定义 在视口 = !(tx + tw < 视口x || tx > 视口x + 视口w || ty + th < 视口y || ty > 视口y + 视口h)
        内存_写8(tile + 25, 在视口)
        如果 (在视口) {
            内存_写32(tile + 20, 0)   // 最高优先级
        } 否则 {
            内存_写32(tile + 20, 2)   // 低优先级
        }
        i = i + 1
    }
}

定义 可变 AI_属性树_热节点缓存 = 0

函数 AI_属性树_节点热度(节点, 操作类型) {
    如果 (操作类型 == "查询") { 返回 "缓存" }
    如果 (操作类型 == "修改") { AI_属性树_热节点缓存 = 0; 返回 "失效" }
    返回 "普通"
}

函数 AI_属性树_批量DOM优化(操作数) {
    如果 (操作数 > 100) { 返回 "延迟重排" }
    如果 (操作数 > 10) { 返回 "批量重排" }
    返回 "即时重排"
}

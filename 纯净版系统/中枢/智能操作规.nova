// §5 AI操作规划 — 自然语言意图→UI操作序列

定义 意图_点击按钮 = 1
定义 意图_填写表单 = 2
定义 意图_导航链接 = 3
定义 意图_读取内容 = 4
定义 意图_搜索 = 5

结构 AI操作计划 {
    意图,
    步骤列表,    // [] MCP请求序列
    当前步骤,
    已完成,
}

函数 智能_规划操作(意图, 目标文本) {
    定义 计划 = AI操作计划 {}
    计划.意图 = 意图
    计划.步骤列表 = []
    计划.当前步骤 = 0
    计划.已完成 = 假

    如果 (意图 == 意图_点击按钮) {
        // 步骤: 扫描→查找→点击→验证
        追加(计划.步骤列表, MCP_创建请求(MCP_工具_浏览, []))
        追加(计划.步骤列表, MCP_创建请求(MCP_工具_点击, [目标文本]))
        追加(计划.步骤列表, MCP_创建请求(MCP_工具_浏览, []))

    } 否则 如果 (意图 == 意图_填写表单) {
        追加(计划.步骤列表, MCP_创建请求(MCP_工具_浏览, []))
        追加(计划.步骤列表, MCP_创建请求(MCP_工具_输入, [目标文本]))
        追加(计划.步骤列表, MCP_创建请求(MCP_工具_浏览, []))

    } 否则 如果 (意图 == 意图_导航链接) {
        追加(计划.步骤列表, MCP_创建请求(MCP_工具_浏览, []))
        追加(计划.步骤列表, MCP_创建请求(MCP_工具_点击, [目标文本]))
        追加(计划.步骤列表, MCP_创建请求(MCP_工具_等待, [目标文本]))

    } 否则 如果 (意图 == 意图_读取内容) {
        追加(计划.步骤列表, MCP_创建请求(MCP_工具_读取, []))

    } 否则 如果 (意图 == 意图_搜索) {
        追加(计划.步骤列表, MCP_创建请求(MCP_工具_浏览, []))
        追加(计划.步骤列表, MCP_创建请求(MCP_工具_输入, [目标文本]))
        追加(计划.步骤列表, MCP_创建请求(MCP_工具_点击, ["搜索"]))
        追加(计划.步骤列表, MCP_创建请求(MCP_工具_等待, ["结果"]))
    }

    返回 计划
}

函数 智能_执行计划(计划) {
    当 (计划.当前步骤 < 计数(计划.步骤列表)) {
        定义 请求 = 计划.步骤列表[计划.当前步骤]
        定义 响应 = MCP_处理请求(请求)
        如果 (!响应.成功) {
            内核调试("AI操作计划: 步骤" + 整数转字符串(计划.当前步骤) + "失败: " + 响应.错误信息)
            返回 假
        }
        计划.当前步骤 = 计划.当前步骤 + 1
    }
    计划.已完成 = 真
    返回 真
}

// §6 像素级验证 — 直接读帧缓冲

函数 像素_验证区域颜色(fb, x, y, w, h, 期望颜色, 容差) {
    // 验证矩形区域内像素是否接近期望颜色
    定义 可变 匹配 = 0
    定义 可变 总 = 0
    定义 可变 dy = 0
    当 (dy < h) {
        定义 可变 dx = 0
        当 (dx < w) {
            定义 像素 = 像素_读点(fb, x + dx, y + dy)
            如果 (颜色_相近(像素, 期望颜色, 容差)) {
                匹配 = 匹配 + 1
            }
            总 = 总 + 1
            dx = dx + 4  // 采样(不需要检查每个像素)
        }
        dy = dy + 4
    }
    如果 (总 == 0) { 返回 假 }
    返回 匹配 * 100 / 总 > 80  // 80%以上像素匹配
}

函数 颜色_相近(c1, c2, 容差) {
    定义 r差 = ((c1 >> 16) & 0xFF) - ((c2 >> 16) & 0xFF)
    定义 g差 = ((c1 >> 8) & 0xFF) - ((c2 >> 8) & 0xFF)
    定义 b差 = (c1 & 0xFF) - (c2 & 0xFF)
    如果 (r差 < 0) { r差 = 0 - r差 }
    如果 (g差 < 0) { g差 = 0 - g差 }
    如果 (b差 < 0) { b差 = 0 - b差 }
    返回 r差 + g差 + b差 <= 容差
}

函数 像素_区域截图(fb, x, y, w, h) {
    // 捕获指定区域的像素数据(返回像素数组)
    定义 可变 像素数据 = []
    定义 可变 dy = 0
    当 (dy < h) {
        定义 可变 dx = 0
        当 (dx < w) {
            追加(像素数据, 像素_读点(fb, x + dx, y + dy))
            dx = dx + 1
        }
        dy = dy + 1
    }
    返回 像素数据
}

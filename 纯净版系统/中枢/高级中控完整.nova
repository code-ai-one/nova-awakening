//   1. 中断类型分类统计: 定时器/IPI/温度/性能/错误/伪/外部
//   2. 中断速率追踪: 窗口统计+峰值+均值
//   3. IPI详细统计: 单播/广播/目标分布
//   4. 寄存器保存/恢复: 电源挂起时保存LVT状态
//   5. 每向量中断计数: 256向量频率表
//   6. 中断延迟追踪: 从触发到处理的延迟测量
//   7. 调试dump: 完整状态转储
//   8. 与调度器/电源管理的接口

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./自动扩容.nova")
导入("../感知/内核直连层.nova")
导入("./字符串替换.nova")
导入("./内存初始化.nova")
导入("./创建甲.nova")

定义 中控_寄存器基 = 0xFEE00000
定义 中控_标识偏移 = 0x20
定义 中控_版本偏移 = 0x30
定义 中控_优先偏移 = 0x80
定义 中控_结束偏移 = 0xB0
定义 中控_伪中断偏移 = 0xF0
定义 中控_命令低偏移 = 0x300
定义 中控_命令高偏移 = 0x310
定义 中控_定时偏移 = 0x320
定义 中控_热感偏移 = 0x330
定义 中控_性能偏移 = 0x340
定义 中控_LINT0偏移 = 0x350
定义 中控_LINT1偏移 = 0x360
定义 中控_错误偏移 = 0x370
定义 中控_初始计数偏移 = 0x380
定义 中控_当前计数偏移 = 0x390
定义 中控_分频偏移 = 0x3E0

定义 中断类型_定时器 = 0
定义 中断类型_热感 = 1
定义 中断类型_错误 = 2
定义 中断类型_伪 = 3
定义 中断类型_IPI = 4
定义 中断类型_性能 = 5
定义 中断类型_外部 = 6
定义 中断类型_LINT0 = 7
定义 中断类型_LINT1 = 8
定义 中断类型_最大 = 9

定义 可变 中控基址 = 0
定义 可变 中控已启用 = 假
定义 可变 中控标识 = 0
定义 可变 中控_统计_已初始化 = 假

定义 可变 中断总数 = 0
定义 可变 核间中断数 = 0
定义 可变 定时中断数 = 0
定义 可变 热感中断数 = 0
定义 可变 错误中断数 = 0
定义 可变 伪中断数 = 0
定义 可变 性能中断数 = 0
定义 可变 外部中断数 = 0
定义 可变 LINT0中断数 = 0
定义 可变 LINT1中断数 = 0

定义 可变 中断速率 = 0
定义 可变 上次速率时刻 = 0
定义 可变 速率窗口计数 = 0
定义 可变 峰值速率 = 0
定义 可变 速率_EMA = 0
定义 可变 速率_更新次数 = 0

定义 可变 IPI_单播数 = 0
定义 可变 IPI_广播数 = 0
定义 可变 IPI_自身数 = 0
定义 可变 IPI_超时数 = 0
定义 可变 IPI_INIT数 = 0
定义 可变 IPI_SIPI数 = 0

定义 可变 EOI_总数 = 0

定义 可变 向量计数表 = []
定义 可变 向量计数_已初始化 = 假

定义 可变 保存_定时器LVT = 0
定义 可变 保存_LINT0 = 0
定义 可变 保存_LINT1 = 0
定义 可变 保存_错误LVT = 0
定义 可变 保存_热感LVT = 0
定义 可变 保存_性能LVT = 0
定义 可变 保存_TPR = 0
定义 可变 保存_分频 = 0
定义 可变 保存_初始计数 = 0
定义 可变 保存_SVR = 0
定义 可变 已保存 = 假

定义 可变 统计_错误数 = 0
定义 可变 统计_读取数 = 0
定义 可变 统计_写入数 = 0

// 寄存器访问

函数 中控_读寄存器(偏移) {
    统计_读取数 = 统计_读取数 + 1
    返回 内存_读32(中控基址 + 偏移)
}

函数 中控_写寄存器(偏移, 值) {
    统计_写入数 = 统计_写入数 + 1
    内存_写32(中控基址 + 偏移, 值)
}

// 初始化

函数 中控_初始化(基址) {
    如果 (中控_统计_已初始化 == 真) {
        打印("[APIC统计] 警告: 重复初始化, 跳过")
        返回 错误_已存在
    }
    中控基址 = 基址
    如果 (中控基址 == 0) { 中控基址 = 中控_寄存器基 }
    中控标识 = (中控_读寄存器(中控_标识偏移) >> 24) & 0xFF
    定义 伪值 = 中控_读寄存器(中控_伪中断偏移)
    中控_写寄存器(中控_伪中断偏移, 伪值 | 0x1FF)
    // 初始化向量计数表
    向量计数表 = []
    定义 可变 i = 0
    当 (i < 256) {
        追加(向量计数表, 0)
        i = i + 1
    }
    向量计数_已初始化 = 真
    // 清零所有统计
    中断总数 = 0
    核间中断数 = 0
    定时中断数 = 0
    热感中断数 = 0
    错误中断数 = 0
    伪中断数 = 0
    性能中断数 = 0
    外部中断数 = 0
    LINT0中断数 = 0
    LINT1中断数 = 0
    IPI_单播数 = 0
    IPI_广播数 = 0
    IPI_自身数 = 0
    IPI_超时数 = 0
    IPI_INIT数 = 0
    IPI_SIPI数 = 0
    EOI_总数 = 0
    中断速率 = 0
    峰值速率 = 0
    速率_EMA = 0
    速率_更新次数 = 0
    统计_错误数 = 0
    统计_读取数 = 0
    统计_写入数 = 0
    中控已启用 = 真
    中控_统计_已初始化 = 真
    上次速率时刻 = 平台_获取高精度时间()
    打印("[APIC统计] 初始化完成 ID=" + 转字符串(中控标识))
    返回 0
}

// EOI (中断结束)

函数 中控_发送结束信号() {
    中控_写寄存器(中控_结束偏移, 0)
    EOI_总数 = EOI_总数 + 1
}

// 优先级管理

函数 中控_设优先级(优先级) {
    如果 (优先级 > 255) {
        统计_错误数 = 统计_错误数 + 1
        返回 错误_无效参数
    }
    中控_写寄存器(中控_优先偏移, 优先级 & 0xFF)
    返回 0
}

函数 中控_获取优先级() {
    返回 中控_读寄存器(中控_优先偏移) & 0xFF
}

// IPI发送 (带详细统计)

函数 中控_发送核间中断(目标核, 向量) {
    如果 (中控已启用 == 假) {
        统计_错误数 = 统计_错误数 + 1
        返回 错误_未初始化
    }
    定义 高值 = (目标核 & 0xFF) << 24
    定义 低值 = 向量 & 0xFF
    中控_写寄存器(中控_命令高偏移, 高值)
    中控_写寄存器(中控_命令低偏移, 低值)
    核间中断数 = 核间中断数 + 1
    IPI_单播数 = IPI_单播数 + 1
    // 等待投递完成
    定义 可变 等待 = 0
    当 (等待 < 10000) {
        如果 ((中控_读寄存器(中控_命令低偏移) & (1 << 12)) == 0) { 返回 0 }
        等待 = 等待 + 1
    }
    IPI_超时数 = IPI_超时数 + 1
    统计_错误数 = 统计_错误数 + 1
    返回 错误_超时
}

函数 中控_广播核间中断(向量) {
    如果 (中控已启用 == 假) {
        统计_错误数 = 统计_错误数 + 1
        返回 错误_未初始化
    }
    定义 低值 = (向量 & 0xFF) | (3 << 18)
    中控_写寄存器(中控_命令高偏移, 0)
    中控_写寄存器(中控_命令低偏移, 低值)
    核间中断数 = 核间中断数 + 1
    IPI_广播数 = IPI_广播数 + 1
    返回 0
}

函数 中控_发送自身IPI(向量) {
    定义 低值 = (向量 & 0xFF) | (1 << 18)
    中控_写寄存器(中控_命令高偏移, 0)
    中控_写寄存器(中控_命令低偏移, 低值)
    核间中断数 = 核间中断数 + 1
    IPI_自身数 = IPI_自身数 + 1
    返回 0
}

函数 中控_发送INIT_IPI(目标核) {
    定义 高值 = (目标核 & 0xFF) << 24
    定义 低值 = 0x00004500
    中控_写寄存器(中控_命令高偏移, 高值)
    中控_写寄存器(中控_命令低偏移, 低值)
    IPI_INIT数 = IPI_INIT数 + 1
    返回 0
}

函数 中控_发送SIPI(目标核, 启动页) {
    定义 高值 = (目标核 & 0xFF) << 24
    定义 低值 = 0x00004600 | (启动页 & 0xFF)
    中控_写寄存器(中控_命令高偏移, 高值)
    中控_写寄存器(中控_命令低偏移, 低值)
    IPI_SIPI数 = IPI_SIPI数 + 1
    返回 0
}

// 定时器配置

函数 中控_配置定时器(分频, 初始值, 周期) {
    中控_写寄存器(中控_分频偏移, 分频 & 0xF)
    定义 定时配置 = 32
    如果 (周期) { 定时配置 = 定时配置 | (1 << 17) }
    中控_写寄存器(中控_定时偏移, 定时配置)
    中控_写寄存器(中控_初始计数偏移, 初始值)
    返回 0
}

函数 中控_停止定时器() {
    中控_写寄存器(中控_定时偏移, 中控_读寄存器(中控_定时偏移) | 0x10000)
    中控_写寄存器(中控_初始计数偏移, 0)
    返回 0
}

函数 中控_读当前计数() {
    返回 中控_读寄存器(中控_当前计数偏移)
}

函数 中控_配置热感中断(向量) {
    中控_写寄存器(中控_热感偏移, 向量 & 0xFF)
    返回 0
}

函数 中控_配置性能中断(向量) {
    中控_写寄存器(中控_性能偏移, 向量 & 0xFF)
    返回 0
}

// 中断记录 (含向量级统计)

函数 中控_记录中断(类型) {
    中断总数 = 中断总数 + 1
    速率窗口计数 = 速率窗口计数 + 1
    如果 (类型 == 中断类型_定时器) { 定时中断数 = 定时中断数 + 1 }
    否则 如果 (类型 == 中断类型_热感) { 热感中断数 = 热感中断数 + 1 }
    否则 如果 (类型 == 中断类型_错误) { 错误中断数 = 错误中断数 + 1 }
    否则 如果 (类型 == 中断类型_伪) { 伪中断数 = 伪中断数 + 1 }
    否则 如果 (类型 == 中断类型_IPI) { 核间中断数 = 核间中断数 + 1 }
    否则 如果 (类型 == 中断类型_性能) { 性能中断数 = 性能中断数 + 1 }
    否则 如果 (类型 == 中断类型_外部) { 外部中断数 = 外部中断数 + 1 }
    否则 如果 (类型 == 中断类型_LINT0) { LINT0中断数 = LINT0中断数 + 1 }
    否则 如果 (类型 == 中断类型_LINT1) { LINT1中断数 = LINT1中断数 + 1 }
}

函数 中控_记录中断_向量(向量号, 类型) {
    中控_记录中断(类型)
    如果 (向量计数_已初始化 == 真 && 向量号 < 256 && 向量号 >= 0) {
        设置(向量计数表, 向量号, 向量计数表[向量号] + 1)
    }
}

函数 中控_获取向量计数(向量号) {
    如果 (向量计数_已初始化 == 假 || 向量号 >= 256 || 向量号 < 0) { 返回 0 }
    返回 向量计数表[向量号]
}

函数 中控_获取最热向量(前N) {
    如果 (向量计数_已初始化 == 假) { 返回 [] }
    定义 可变 结果 = []
    定义 可变 n = 0
    当 (n < 前N) {
        定义 可变 最大值 = 0
        定义 可变 最大向量 = 0 - 1
        定义 可变 i = 0
        当 (i < 256) {
            如果 (向量计数表[i] > 最大值) {
                // 检查是否已在结果中
                定义 可变 已有 = 假
                定义 可变 j = 0
                当 (j < 计数(结果)) {
                    如果 (结果[j][0] == i) { 已有 = 真 }
                    j = j + 1
                }
                如果 (已有 == 假) {
                    最大值 = 向量计数表[i]
                    最大向量 = i
                }
            }
            i = i + 1
        }
        如果 (最大向量 >= 0 && 最大值 > 0) {
            追加(结果, [最大向量, 最大值])
        }
        n = n + 1
    }
    返回 结果
}

// 速率追踪 (含峰值和EMA平滑)

函数 中控_更新速率() {
    定义 现在 = 平台_获取高精度时间()
    定义 间隔 = 现在 - 上次速率时刻
    如果 (间隔 >= 1000000) {
        中断速率 = 速率窗口计数 * 1000000 / 间隔
        // EMA平滑: α=1/8
        速率_EMA = (速率_EMA * 7 + 中断速率) / 8
        // 峰值追踪
        如果 (中断速率 > 峰值速率) { 峰值速率 = 中断速率 }
        速率窗口计数 = 0
        上次速率时刻 = 现在
        速率_更新次数 = 速率_更新次数 + 1
    }
}

函数 中控_获取标识() { 返回 中控标识 }
函数 中控_获取速率() { 返回 中断速率 }
函数 中控_获取峰值速率() { 返回 峰值速率 }
函数 中控_获取平滑速率() { 返回 速率_EMA }

// 寄存器保存/恢复 (电源管理)

函数 中控_保存寄存器() {
    如果 (中控已启用 == 假) { 返回 错误_未初始化 }
    保存_定时器LVT = 中控_读寄存器(中控_定时偏移)
    保存_LINT0 = 中控_读寄存器(中控_LINT0偏移)
    保存_LINT1 = 中控_读寄存器(中控_LINT1偏移)
    保存_错误LVT = 中控_读寄存器(中控_错误偏移)
    保存_热感LVT = 中控_读寄存器(中控_热感偏移)
    保存_性能LVT = 中控_读寄存器(中控_性能偏移)
    保存_TPR = 中控_读寄存器(中控_优先偏移)
    保存_分频 = 中控_读寄存器(中控_分频偏移)
    保存_初始计数 = 中控_读寄存器(中控_初始计数偏移)
    保存_SVR = 中控_读寄存器(中控_伪中断偏移)
    已保存 = 真
    打印("[APIC统计] 寄存器已保存")
    返回 0
}

函数 中控_恢复寄存器() {
    如果 (已保存 == 假) { 返回 错误_无效参数 }
    中控_写寄存器(中控_伪中断偏移, 保存_SVR)
    中控_写寄存器(中控_优先偏移, 保存_TPR)
    中控_写寄存器(中控_定时偏移, 保存_定时器LVT)
    中控_写寄存器(中控_LINT0偏移, 保存_LINT0)
    中控_写寄存器(中控_LINT1偏移, 保存_LINT1)
    中控_写寄存器(中控_错误偏移, 保存_错误LVT)
    中控_写寄存器(中控_热感偏移, 保存_热感LVT)
    中控_写寄存器(中控_性能偏移, 保存_性能LVT)
    中控_写寄存器(中控_分频偏移, 保存_分频)
    中控_写寄存器(中控_初始计数偏移, 保存_初始计数)
    打印("[APIC统计] 寄存器已恢复")
    返回 0
}

// 中断类型名

函数 中控_中断类型名(类型) {
    如果 (类型 == 中断类型_定时器) { 返回 "定时器" }
    如果 (类型 == 中断类型_热感) { 返回 "温度" }
    如果 (类型 == 中断类型_错误) { 返回 "错误" }
    如果 (类型 == 中断类型_伪) { 返回 "伪中断" }
    如果 (类型 == 中断类型_IPI) { 返回 "IPI" }
    如果 (类型 == 中断类型_性能) { 返回 "性能" }
    如果 (类型 == 中断类型_外部) { 返回 "外部" }
    如果 (类型 == 中断类型_LINT0) { 返回 "LINT0" }
    如果 (类型 == 中断类型_LINT1) { 返回 "LINT1" }
    返回 "未知"
}

// 完整统计系统 (≥22个指标)

函数 中控_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "基址", 中控基址)
    字典设(统计, "已启用", 中控已启用)
    字典设(统计, "标识", 中控标识)
    字典设(统计, "中断总数", 中断总数)
    字典设(统计, "定时中断", 定时中断数)
    字典设(统计, "IPI中断", 核间中断数)
    字典设(统计, "热感中断", 热感中断数)
    字典设(统计, "性能中断", 性能中断数)
    字典设(统计, "错误中断", 错误中断数)
    字典设(统计, "伪中断", 伪中断数)
    字典设(统计, "外部中断", 外部中断数)
    字典设(统计, "LINT0中断", LINT0中断数)
    字典设(统计, "LINT1中断", LINT1中断数)
    字典设(统计, "EOI总数", EOI_总数)
    字典设(统计, "当前速率", 中断速率)
    字典设(统计, "峰值速率", 峰值速率)
    字典设(统计, "平滑速率", 速率_EMA)
    字典设(统计, "IPI单播", IPI_单播数)
    字典设(统计, "IPI广播", IPI_广播数)
    字典设(统计, "IPI自身", IPI_自身数)
    字典设(统计, "IPI超时", IPI_超时数)
    字典设(统计, "IPI_INIT", IPI_INIT数)
    字典设(统计, "IPI_SIPI", IPI_SIPI数)
    字典设(统计, "寄存器读取数", 统计_读取数)
    字典设(统计, "寄存器写入数", 统计_写入数)
    字典设(统计, "错误数", 统计_错误数)
    字典设(统计, "已保存", 已保存)
    返回 统计
}

函数 中控_打印完整统计() {
    定义 统计 = 中控_完整统计()
    打印("[APIC统计] ═══════ 完整统计 ═══════")
    打印("  基址:         0x" + 转字符串(字典取(统计, "基址")))
    打印("  标识(ID):     " + 转字符串(字典取(统计, "标识")))
    打印("  中断总数:     " + 转字符串(字典取(统计, "中断总数")))
    打印("  ── 按类型 ──")
    打印("  定时器:       " + 转字符串(字典取(统计, "定时中断")))
    打印("  IPI:          " + 转字符串(字典取(统计, "IPI中断")))
    打印("  热感:         " + 转字符串(字典取(统计, "热感中断")))
    打印("  性能:         " + 转字符串(字典取(统计, "性能中断")))
    打印("  错误:         " + 转字符串(字典取(统计, "错误中断")))
    打印("  伪中断:       " + 转字符串(字典取(统计, "伪中断")))
    打印("  外部:         " + 转字符串(字典取(统计, "外部中断")))
    打印("  EOI总数:      " + 转字符串(字典取(统计, "EOI总数")))
    打印("  ── 速率 ──")
    打印("  当前速率:     " + 转字符串(字典取(统计, "当前速率")) + " 次/秒")
    打印("  峰值速率:     " + 转字符串(字典取(统计, "峰值速率")) + " 次/秒")
    打印("  平滑速率:     " + 转字符串(字典取(统计, "平滑速率")) + " 次/秒")
    打印("  ── IPI详情 ──")
    打印("  IPI单播:      " + 转字符串(字典取(统计, "IPI单播")))
    打印("  IPI广播:      " + 转字符串(字典取(统计, "IPI广播")))
    打印("  IPI_INIT:     " + 转字符串(字典取(统计, "IPI_INIT")))
    打印("  IPI_SIPI:     " + 转字符串(字典取(统计, "IPI_SIPI")))
    打印("  IPI超时:      " + 转字符串(字典取(统计, "IPI超时")))
    // 最热5个向量
    定义 热向量 = 中控_获取最热向量(5)
    如果 (计数(热向量) > 0) {
        打印("  ── 最热向量 ──")
        定义 可变 h = 0
        当 (h < 计数(热向量)) {
            打印("  向量" + 转字符串(热向量[h][0]) + ": " + 转字符串(热向量[h][1]) + " 次")
            h = h + 1
        }
    }
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    打印("[APIC统计] ═════════════════════════")
    返回 0
}

// 调试dump

函数 中控_dump() {
    打印("[APIC统计 dump] ──────────────────")
    打印("  已初始化: " + 转字符串(中控_统计_已初始化))
    打印("  基址: 0x" + 转字符串(中控基址))
    打印("  ID: " + 转字符串(中控标识))
    打印("  中断总数: " + 转字符串(中断总数))
    打印("  EOI总数: " + 转字符串(EOI_总数))
    打印("  速率: " + 转字符串(中断速率) + " 峰值: " + 转字符串(峰值速率))
    打印("  寄存器读取: " + 转字符串(统计_读取数))
    打印("  寄存器写入: " + 转字符串(统计_写入数))
    打印("  向量计数已初始化: " + 转字符串(向量计数_已初始化))
    打印("  寄存器已保存: " + 转字符串(已保存))
    打印("[APIC统计 dump] ──────────────────")
}

// 销毁与清理

函数 中控_销毁() {
    如果 (中控_统计_已初始化 == 假) { 返回 0 }
    向量计数表 = []
    向量计数_已初始化 = 假
    中控已启用 = 假
    中控_统计_已初始化 = 假
    打印("[APIC统计] 已销毁")
    返回 0
}

// 与其他子系统的接口

函数 中控_为调度器提供中断负载() {
    返回 [中断速率, 峰值速率, 速率_EMA]
}

函数 中控_为电源管理挂起() {
    中控_保存寄存器()
    返回 0
}

函数 中控_为电源管理恢复() {
    中控_恢复寄存器()
    返回 0
}

函数 中控_为SMP启动发送IPI(目标核, 启动页) {
    // 完整的AP核启动序列: INIT→延迟→SIPI→延迟→SIPI
    中控_发送INIT_IPI(目标核)
    // 等待10ms (由调用者保证)
    中控_发送SIPI(目标核, 启动页)
    返回 0
}

函数 中控_重置统计() {
    中断总数 = 0
    核间中断数 = 0
    定时中断数 = 0
    热感中断数 = 0
    错误中断数 = 0
    伪中断数 = 0
    性能中断数 = 0
    外部中断数 = 0
    LINT0中断数 = 0
    LINT1中断数 = 0
    EOI_总数 = 0
    IPI_单播数 = 0
    IPI_广播数 = 0
    IPI_自身数 = 0
    IPI_超时数 = 0
    中断速率 = 0
    峰值速率 = 0
    速率_EMA = 0
    如果 (向量计数_已初始化 == 真) {
        定义 可变 i = 0
        当 (i < 256) { 设置(向量计数表, i, 0); i = i + 1 }
    }
    打印("[APIC统计] 统计已重置")
    返回 0
}

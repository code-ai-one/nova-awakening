// §6 用户输入处理

函数 事件循环_处理用户输入(任务) {
    如果 (任务 == 0 || 任务.数据 == 0) { 返回 }
    定义 事件 = 任务.数据
    // 命中测试: 坐标→DOM节点
    定义 目标 = DOM_命中测试(事件.x, 事件.y)
    如果 (目标 == 0) { 返回 }
    // 触发对应的事件处理器
    如果 (事件.类型 == 输入_鼠标点击) {
        DOM_分发事件(目标, "click", 事件)
    } 否则 如果 (事件.类型 == 输入_鼠标移动) {
        DOM_分发事件(目标, "mousemove", 事件)
    } 否则 如果 (事件.类型 == 输入_键盘按下) {
        DOM_分发事件(DOM_获取焦点元素(), "keydown", 事件)
    } 否则 如果 (事件.类型 == 输入_键盘释放) {
        DOM_分发事件(DOM_获取焦点元素(), "keyup", 事件)
    } 否则 如果 (事件.类型 == 输入_滚轮) {
        DOM_分发事件(目标, "wheel", 事件)
    }
}

函数 事件循环_处理AI回调(任务) {
    如果 (任务 == 0 || 任务.数据 == 0) { 返回 }
    定义 结果 = 任务.数据
    // AI推理结果到达, 根据类型更新UI
    如果 (结果.类型 == AI回调_翻译完成) {
        DOM_替换文本(结果.目标节点, 结果.翻译文本)
    } 否则 如果 (结果.类型 == AI回调_摘要完成) {
        DOM_插入摘要面板(结果.目标节点, 结果.摘要文本)
    } 否则 如果 (结果.类型 == AI回调_预测加载) {
        浏览器_预加载资源(结果.URL列表)
    } 否则 如果 (结果.类型 == AI回调_安全警告) {
        浏览器_显示安全警告(结果.警告信息)
    }
}

函数 事件循环_处理系统事件(任务) {
    // 内核系统事件(内存压力/电源变化)
    如果 (任务.数据 == "memory_pressure") {
        浏览器内存_主动回收()
    }
}

// §7 定时器检查

函数 事件循环_检查定时器() {
    定义 当前 = 高精度定时器_读取()
    定义 可变 i = 0
    当 (i < 计数(事件循环.定时器列表)) {
        定义 定时器 = 事件循环.定时器列表[i]
        如果 (定时器.执行时间 <= 当前) {
            // 到期 → 加入宏任务队列
            事件循环_提交任务(任务_定时器, 任务优先级_普通, 定时器.回调, "")
            如果 (定时器.重复) {
                定时器.执行时间 = 当前 + 定时器.间隔 * 1000
                i = i + 1
            } 否则 {
                列表_移除(事件循环.定时器列表, i)
            }
        } 否则 {
            i = i + 1
        }
    }
}

// §8 页面导航 — 完整加载流程

函数 事件循环_导航(url) {
    内核信息("浏览器导航: " + url)

    // ① AI预取检查
    定义 预取缓存 = 浏览器网络_检查预取缓存(url)

    // ② 网络请求(或使用预取缓存)
    定义 可变 HTML内容 = ""
    如果 (预取缓存 != 空) {
        HTML内容 = 预取缓存[0]
        内核信息("浏览器: AI预取命中!")
    } 否则 {
        定义 请求 = 浏览器网络_发起请求(方法_GET, url, [], "")
        如果 (请求.状态 == 请求状态_完成 && 计数(请求.响应体) > 0) {
            HTML内容 = 请求.响应体[0]
        }
    }

    如果 (字符串长度(HTML内容) == 0) {
        内核信息("浏览器: 页面加载失败")
        返回
    }

    // ③ DOM解析
    定义 文档 = DOM_解析HTML(HTML内容, url)

    // ④ CSS解析
    定义 可变 si = 0
    当 (si < 计数(文档.样式列表)) {
        定义 样式表 = CSS_解析样式表(文档.样式列表[si], url)
        追加(CSS_样式表列表, 样式表)
        si = si + 1
    }

    // ⑤ 构建渲染树
    渲染_构建树(文档)

    // ⑥ 布局
    渲染_布局()

    // ⑦ 绘制
    渲染_绘制(文档)

    // ⑧ 执行JS
    定义 可变 ji = 0
    当 (ji < 计数(文档.脚本列表)) {
        JS_执行脚本(文档.脚本列表[ji])
        ji = ji + 1
    }

    // ⑨ AI预取下一页
    浏览器网络_AI预取(url)

    内核信息("浏览器: 页面加载完成, DOM节点:" + 整数转字符串(文档.总节点数))
}

函数 事件循环_统计() {
    返回 [事件循环.总任务数, 事件循环.总帧数, 事件循环.丢帧数,
          计数(事件循环.宏任务队列), 计数(事件循环.微任务队列)]
}

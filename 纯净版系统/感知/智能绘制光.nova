导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./内核直连层.nova")
导入("../中枢/内存初始化.nova")

定义 质量_低 = 0
定义 质量_中 = 1
定义 质量_高 = 2
定义 质量_极高 = 3
定义 瓦片大小 = 64
定义 最大瓦片 = 1024
定义 衰减基数 = 1024

结构 渲染瓦片 {
    横,
    纵,
    宽,
    高,
    质量级别,
    脏标记,
    运动向量横,
    运动向量纵,
    语义权重,
    注视距离,
}

定义 可变 瓦片表 = 0
定义 可变 瓦片数 = 0
定义 可变 画布宽 = 0
定义 可变 画布高 = 0
定义 可变 列数 = 0
定义 可变 行数 = 0
定义 可变 注视横 = 0
定义 可变 注视纵 = 0
定义 可变 总渲染瓦片 = 0
定义 可变 跳过瓦片 = 0
定义 可变 降级瓦片 = 0


函数 光栅_初始化(宽, 高) {
    画布宽 = 宽
    画布高 = 高
    列数 = (宽 + 瓦片大小 - 1) / 瓦片大小
    行数 = (高 + 瓦片大小 - 1) / 瓦片大小
    瓦片数 = 列数 * 行数
    如果 (瓦片数 > 最大瓦片) { 瓦片数 = 最大瓦片 }
    瓦片表 = 堆_分配(瓦片数 * 40)
    定义 可变 序号 = 0
    当 (序号 < 瓦片数) {
        定义 偏移 = 瓦片表 + 序号 * 40
        定义 列 = 序号 % 列数
        定义 行 = 序号 / 列数
        内存_写32(偏移, 列 * 瓦片大小)
        内存_写32(偏移 + 4, 行 * 瓦片大小)
        内存_写32(偏移 + 8, 瓦片大小)
        内存_写32(偏移 + 12, 瓦片大小)
        内存_写32(偏移 + 16, 质量_高)
        内存_写32(偏移 + 20, 1)
        内存_写32(偏移 + 24, 0)
        内存_写32(偏移 + 28, 0)
        内存_写32(偏移 + 32, 衰减基数)
        内存_写32(偏移 + 36, 0)
        序号 = 序号 + 1
    }
    注视横 = 宽 / 2
    注视纵 = 高 / 2
}

函数 光栅_设注视点(横, 纵) {
    注视横 = 横
    注视纵 = 纵
}

函数 光栅_计算质量(瓦片索引) {
    如果 (瓦片索引 >= 瓦片数) { 返回 质量_中 }
    定义 偏移 = 瓦片表 + 瓦片索引 * 40
    定义 瓦片横 = 内存_读32(偏移) + 瓦片大小 / 2
    定义 瓦片纵 = 内存_读32(偏移 + 4) + 瓦片大小 / 2
    定义 差横 = 瓦片横 - 注视横
    定义 差纵 = 瓦片纵 - 注视纵
    如果 (差横 < 0) { 差横 = 0 - 差横 }
    如果 (差纵 < 0) { 差纵 = 0 - 差纵 }
    定义 距离 = 差横 + 差纵
    定义 运动 = 内存_读32(偏移 + 24)
    如果 (运动 < 0) { 运动 = 0 - 运动 }
    运动 = 运动 + 内存_读32(偏移 + 28)
    如果 (运动 < 0) { 运动 = 运动 + (0 - 内存_读32(偏移 + 28)) }
    定义 语义 = 内存_读32(偏移 + 32)
    定义 可变 质量 = 质量_高
    如果 (距离 > 画布宽 / 3) { 质量 = 质量 - 1 }
    如果 (距离 > 画布宽 / 2) { 质量 = 质量 - 1 }
    如果 (运动 > 10) { 质量 = 质量 - 1 }
    如果 (语义 < 衰减基数 / 2) { 质量 = 质量 - 1 }
    如果 (质量 < 质量_低) { 质量 = 质量_低 }
    内存_写32(偏移 + 16, 质量)
    返回 质量
}

函数 光栅_标记脏(横, 纵, 宽, 高) {
    定义 起始列 = 横 / 瓦片大小
    定义 起始行 = 纵 / 瓦片大小
    定义 结束列 = (横 + 宽 + 瓦片大小 - 1) / 瓦片大小
    定义 结束行 = (纵 + 高 + 瓦片大小 - 1) / 瓦片大小
    定义 可变 行 = 起始行
    当 (行 < 结束行 && 行 < 行数) {
        定义 可变 列 = 起始列
        当 (列 < 结束列 && 列 < 列数) {
            定义 索引 = 行 * 列数 + 列
            如果 (索引 < 瓦片数) {
                内存_写32(瓦片表 + 索引 * 40 + 20, 1)
            }
            列 = 列 + 1
        }
        行 = 行 + 1
    }
}

函数 光栅_标记全脏() {
    定义 可变 序号 = 0
    当 (序号 < 瓦片数) {
        内存_写32(瓦片表 + 序号 * 40 + 20, 1)
        序号 = 序号 + 1
    }
}

函数 光栅_渲染帧(绘制回调) {
    定义 可变 序号 = 0
    当 (序号 < 瓦片数) {
        定义 偏移 = 瓦片表 + 序号 * 40
        定义 脏 = 内存_读32(偏移 + 20)
        如果 (!脏) { 跳过瓦片 = 跳过瓦片 + 1; 序号 = 序号 + 1; 继续 }
        定义 质量 = 光栅_计算质量(序号)
        如果 (质量 < 质量_高) { 降级瓦片 = 降级瓦片 + 1 }
        定义 横 = 内存_读32(偏移)
        定义 纵 = 内存_读32(偏移 + 4)
        定义 宽 = 内存_读32(偏移 + 8)
        定义 高 = 内存_读32(偏移 + 12)
        如果 (绘制回调 != 0) { 绘制回调(横, 纵, 宽, 高, 质量) }
        内存_写32(偏移 + 20, 0)
        总渲染瓦片 = 总渲染瓦片 + 1
        序号 = 序号 + 1
    }
}

函数 光栅_设运动向量(瓦片索引, 横速, 纵速) {
    如果 (瓦片索引 >= 瓦片数) { 返回 }
    内存_写32(瓦片表 + 瓦片索引 * 40 + 24, 横速)
    内存_写32(瓦片表 + 瓦片索引 * 40 + 28, 纵速)
}

函数 光栅_设语义权重(瓦片索引, 权重) {
    如果 (瓦片索引 >= 瓦片数) { 返回 }
    内存_写32(瓦片表 + 瓦片索引 * 40 + 32, 权重)
}

函数 光栅_获取质量(瓦片索引) {
    如果 (瓦片索引 >= 瓦片数) { 返回 质量_中 }
    返回 内存_读32(瓦片表 + 瓦片索引 * 40 + 16)
}

函数 光栅_完整统计() {
    返回 [瓦片数, 总渲染瓦片, 跳过瓦片, 降级瓦片]
}

结构 事件档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    监听数,
    分发数,
    输入数,
    循环数,
    报错数,
    预测数,
    成功数,
    失败数,
}

结构 事件请求 {
    动作,
    文档,
    目标,
    参数,
    选项,
}

结构 事件回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 事件摘要 {
    名称,
    监听数,
    分发数,
    输入数,
    循环数,
    报错数,
    预测数,
    成功数,
    失败数,
    健康,
}

定义 可变 事件账本 = []
定义 可变 事件构建数 = 0
定义 可变 事件总动作 = 0
定义 可变 事件总成功 = 0
定义 可变 事件总失败 = 0

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 文档事件_建档(名称) {
    定义 档 = 事件档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.监听数 = 0
    档.分发数 = 0
    档.输入数 = 0
    档.循环数 = 0
    档.报错数 = 0
    档.预测数 = 0
    档.成功数 = 0
    档.失败数 = 0
    返回 档
}

函数 文档事件_登记(档) {
    追加(事件账本, 档)
    事件构建数 = 事件构建数 + 1
    返回 档
}

函数 文档事件_完整统计() {
    返回 [
        事件构建数,
        事件总动作,
        事件总成功,
        事件总失败
    ]
}

函数 文档事件_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 事件回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 文档事件_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.失败数 > 档.成功数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (档.分发数 > 0 || 档.监听数 > 0 || 档.输入数 > 0) {
        档.最近健康 = "运行"
        返回 档.最近健康
    }
    档.最近健康 = "空载"
    返回 档.最近健康
}

函数 文档事件_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    档.最近错误 = ""
    档.最近统计 = 文档事件_完整统计()
}

函数 文档事件_成功(档, 来源, 数据) {
    事件总动作 = 事件总动作 + 1
    事件总成功 = 事件总成功 + 1
    如果 (档 == 空) {
        返回 文档事件_建回证(真, 真, 来源, "", 数据, 文档事件_完整统计())
    }
    档.最近来源 = 来源
    档.最近结果 = 数据
    档.最近错误 = ""
    档.成功数 = 档.成功数 + 1
    档.最近统计 = 文档事件_完整统计()
    文档事件_刷新健康(档)
    返回 文档事件_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 文档事件_失败(档, 来源, 错因) {
    事件总动作 = 事件总动作 + 1
    事件总失败 = 事件总失败 + 1
    如果 (档 == 空) {
        返回 文档事件_建回证(真, 假, 来源, 错因, 0, 文档事件_完整统计())
    }
    档.最近来源 = 来源
    档.最近错误 = 错因
    档.失败数 = 档.失败数 + 1
    档.最近统计 = 文档事件_完整统计()
    文档事件_刷新健康(档)
    返回 文档事件_建回证(真, 假, 来源, 错因, 0, 档.最近统计)
}

函数 文档事件_初始化(档) {
    事件Throttle_初始化()
    错误分析_初始化()
    档.是否初始化 = 真
    档.最近动作 = "初始化"
    档.最近来源 = "文档事件_初始化"
    档.最近统计 = 文档事件_完整统计()
    文档事件_刷新健康(档)
    返回 档
}

函数 文档事件_创建(名称) {
    定义 档 = 文档事件_建档(名称)
    文档事件_初始化(档)
    返回 文档事件_登记(档)
}

函数 文档事件_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (!档.是否初始化) { 返回 假 }
    返回 真
}

函数 文档事件_原生事件(档, 类型字符串, 冒泡, 可取消) {
    如果 (!文档事件_检查档(档)) { 返回 文档事件_失败(档, "原生事件", "事件档不可用") }
    文档事件_记录(档, "原生事件", [类型字符串, 冒泡, 可取消], "事件创建")
    档.分发数 = 档.分发数 + 1
    返回 文档事件_成功(档, "原生事件", 事件_创建(类型字符串, 冒泡, 可取消))
}

函数 文档事件_鼠标事件(档, 类型, x, y, 按钮) {
    如果 (!文档事件_检查档(档)) { 返回 文档事件_失败(档, "鼠标事件", "事件档不可用") }
    文档事件_记录(档, "鼠标事件", [类型, x, y, 按钮], "事件创建")
    档.输入数 = 档.输入数 + 1
    返回 文档事件_成功(档, "鼠标事件", Mouse事件_创建(类型, x, y, 按钮, 0))
}


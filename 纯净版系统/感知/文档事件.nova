    文档事件_记录(档, "分发事件", [目标节点, 事件], "事件分发")
    定义 结果 = 事件Target_dispatch事件(目标节点, 事件)
    档.分发数 = 档.分发数 + 1
    返回 文档事件_成功(档, "分发事件", 结果)

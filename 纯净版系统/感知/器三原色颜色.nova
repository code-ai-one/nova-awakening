// NovaOS 渲染引擎 — YCbCr/RGB 颜色空间转换与扫描解码
// 子系统: 渲染引擎/图片解码/图压解码
// 实现: ITU-T T.871 JPEG颜色空间转换 + 批量优化 + 查找表加速
// 原创: NovaOS · 纯中文原生系统编程 · AI原生图像质量优化

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("./解码.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/创建甲.nova")
导入("../中枢/内存初始化.nova")

// §1 常量定义

// YCbCr→RGB 定点Q10系数 (ITU-R BT.601)
定义 系数_Cr转R = 1436        // 1.402 × 1024
定义 系数_Cb转G = 352         // 0.344136 × 1024
定义 系数_Cr转G = 731         // 0.714136 × 1024
定义 系数_Cb转B = 1815        // 1.772 × 1024
// ITU-R BT.709 高清系数
定义 系数709_Cr转R = 1613     // 1.5748 × 1024
定义 系数709_Cb转G = 192      // 0.1873 × 1024
定义 系数709_Cr转G = 479      // 0.4681 × 1024
定义 系数709_Cb转B = 1900     // 1.8556 × 1024
// RGB→YCbCr 定点Q10系数 (BT.601)
定义 系数_R转Y = 306          // 0.299 × 1024
定义 系数_G转Y = 601          // 0.587 × 1024
定义 系数_B转Y = 117          // 0.114 × 1024
定义 系数_R转Cb = -172        // -0.1687 × 1024
定义 系数_G转Cb = -339        // -0.3313 × 1024
定义 系数_B转Cb = 512         // 0.5 × 1024
定义 系数_R转Cr = 512         // 0.5 × 1024
定义 系数_G转Cr = -429        // -0.4187 × 1024
定义 系数_B转Cr = -83         // -0.0813 × 1024
// 采样模式
定义 采样_444 = 0
定义 采样_422 = 1
定义 采样_420 = 2
定义 采样_灰度 = 3
// 色彩空间标识
定义 色彩空间_BT601 = 0
定义 色彩空间_BT709 = 1
定义 色彩空间_灰度 = 2
定义 色彩空间_CMYK = 3
// 查找表大小
定义 钳位表大小 = 768         // 256+256+256 (负值区+正常区+溢出区)
定义 钳位表偏移 = 256         // 负值偏移量

// §2 核心数据结构

结构 颜色转换器 {
    色彩空间,            // u8  色彩空间_BT601 | BT709 | 灰度 | CMYK
    钳位表,              // u64 预计算的钳位查找表(768字节)
    Cr转R表,             // u64 Cr→R增量查找表(256×4字节)
    Cb转G表,             // u64 Cb→G增量查找表(256×4字节)
    Cr转G表,             // u64 Cr→G增量查找表(256×4字节)
    Cb转B表,             // u64 Cb→B增量查找表(256×4字节)
    已初始化,
    锁,
    AI状态,              // u64 AI颜色优化状态指针
    统计,                // u64 颜色转换统计*指针
}

结构 颜色转换统计 {
    单像素转换次数,
    批量转换次数,
    批量像素总数,
    灰度转换次数,
    CMYK转换次数,
    查找表命中次数,
    直接计算次数,
    钳位触发次数,        // u64 (值超出0-255的次数)
    总耗时_纳秒,
    最大单次耗时,
    MCU解码总数,
    扫描行解码数,
    重启标记处理数,
    AI优化调用次数,
    AI质量调整次数,
    错误总数,
}

结构 AI颜色状态 {
    历史亮度均值,        // u32 Q10 最近N帧的平均亮度
    历史色度偏差,        // u32 Q10 色度偏差(过饱和/欠饱和)
    暗区像素比例,        // u32 Q10 暗区(Y<40)像素比例
    亮区像素比例,        // u32 Q10 亮区(Y>220)像素比例
    连续低质量帧数,
    自适应伽马,          // u32 Q10 自适应伽马校正值(默认1024=1.0)
    策略_使用查找表,     // u8  是否使用查找表加速
    策略_伽马校正,       // u8  是否启用伽马校正
    采样计数器,
}

// §3 全局状态

定义 可变 全局颜色转换器 = 0
定义 可变 全局颜色统计 = 0
定义 可变 全局颜色已初始化 = 假

// §4 生命周期管理

函数 颜色转换_初始化(色彩空间) {
    如果 (全局颜色已初始化 == 真) {
        打印("[颜色转换] 警告: 重复初始化")
        返回 错误_已存在
    }
    // 分配转换器
    全局颜色转换器 = 堆_分配(颜色转换器)
    如果 (全局颜色转换器 == 空) { 返回 错误_内存不足 }
    定义 转换器 = 全局颜色转换器
    转换器.色彩空间 = 色彩空间
    转换器.已初始化 = 假
    转换器.锁 = 渲染_互斥锁创建()
    // 分配统计
    全局颜色统计 = 堆_分配_清零(128)
    如果 (全局颜色统计 == 空) {
        堆_释放(全局颜色转换器)
        返回 错误_内存不足
    }
    转换器.统计 = 全局颜色统计
    // 构建钳位查找表
    转换器.钳位表 = 堆_分配(钳位表大小)
    如果 (转换器.钳位表 != 空) {
        颜色转换_构建钳位表(转换器)
    }
    // 构建颜色转换查找表
    转换器.Cr转R表 = 堆_分配(256 * 4)
    转换器.Cb转G表 = 堆_分配(256 * 4)
    转换器.Cr转G表 = 堆_分配(256 * 4)
    转换器.Cb转B表 = 堆_分配(256 * 4)
    如果 (转换器.Cr转R表 != 空 && 转换器.Cb转B表 != 空) {
        颜色转换_构建颜色表(转换器)
    }
    // AI状态
    转换器.AI状态 = 堆_分配_清零(48)
    如果 (转换器.AI状态 != 空) {
        定义 AI = 转换器.AI状态
        AI.自适应伽马 = 1024
        AI.策略_使用查找表 = 真
        AI.策略_伽马校正 = 假
    }
    转换器.已初始化 = 真
    全局颜色已初始化 = 真
    打印("[颜色转换] 初始化完成: 查找表+AI就绪")
    返回 0
}

函数 颜色转换_销毁() {
    如果 (全局颜色转换器 == 空) { 返回 }
    定义 转换器 = 全局颜色转换器
    如果 (转换器.钳位表 != 空) { 堆_释放(转换器.钳位表) }
    如果 (转换器.Cr转R表 != 空) { 堆_释放(转换器.Cr转R表) }
    如果 (转换器.Cb转G表 != 空) { 堆_释放(转换器.Cb转G表) }
    如果 (转换器.Cr转G表 != 空) { 堆_释放(转换器.Cr转G表) }
    如果 (转换器.Cb转B表 != 空) { 堆_释放(转换器.Cb转B表) }
    如果 (转换器.AI状态 != 空) { 堆_释放(转换器.AI状态) }
    堆_释放(全局颜色转换器)
    如果 (全局颜色统计 != 空) { 堆_释放(全局颜色统计) }
    全局颜色转换器 = 0
    全局颜色统计 = 0
    全局颜色已初始化 = 假
    打印("[颜色转换] 已销毁")
}

函数 颜色转换_重置() {
    如果 (全局颜色转换器 == 空) { 返回 错误_未初始化 }
    如果 (全局颜色统计 != 空) { 内存_置零(全局颜色统计, 128) }
    如果 (全局颜色转换器.AI状态 != 空) {
        定义 AI = 全局颜色转换器.AI状态
        AI.历史亮度均值 = 0
        AI.历史色度偏差 = 0
        AI.连续低质量帧数 = 0
        AI.自适应伽马 = 1024
        AI.采样计数器 = 0
    }
    返回 0
}

// §5 查找表构建(预计算加速)

函数 颜色转换_构建钳位表(转换器) {
    如果 (转换器 == 空 || 转换器.钳位表 == 空) { 返回 }
    // [0..255]=0, [256..511]=0..255, [512..767]=255
    定义 可变 i = 0
    当 (i < 256) {
        内存_写8(转换器.钳位表 + i, 0)
        i = i + 1
    }
    i = 0
    当 (i < 256) {
        内存_写8(转换器.钳位表 + 256 + i, i)
        i = i + 1
    }
    i = 0
    当 (i < 256) {
        内存_写8(转换器.钳位表 + 512 + i, 255)
        i = i + 1
    }
}

函数 颜色转换_构建颜色表(转换器) {
    如果 (转换器 == 空) { 返回 }
    定义 可变 Cr系数R = 系数_Cr转R
    定义 可变 Cb系数G = 系数_Cb转G
    定义 可变 Cr系数G = 系数_Cr转G
    定义 可变 Cb系数B = 系数_Cb转B
    如果 (转换器.色彩空间 == 色彩空间_BT709) {
        Cr系数R = 系数709_Cr转R
        Cb系数G = 系数709_Cb转G
        Cr系数G = 系数709_Cr转G
        Cb系数B = 系数709_Cb转B
    }
    定义 可变 i = 0
    当 (i < 256) {
        定义 偏移 = i - 128
        如果 (转换器.Cr转R表 != 空) {
            内存_写32(转换器.Cr转R表 + i * 4, Cr系数R * 偏移 >> 10)
        }
        如果 (转换器.Cb转G表 != 空) {
            内存_写32(转换器.Cb转G表 + i * 4, 0 - (Cb系数G * 偏移 >> 10))
        }
        如果 (转换器.Cr转G表 != 空) {
            内存_写32(转换器.Cr转G表 + i * 4, 0 - (Cr系数G * 偏移 >> 10))
        }
        如果 (转换器.Cb转B表 != 空) {
            内存_写32(转换器.Cb转B表 + i * 4, Cb系数B * 偏移 >> 10)
        }
        i = i + 1
    }
}

// §6 核心颜色转换函数

函数 钳位(v) {
    如果 (v < 0) { 返回 0 }
    如果 (v > 255) { 返回 255 }
    返回 v
}

函数 钳位_查表(转换器, v) {
    如果 (转换器 == 空 || 转换器.钳位表 == 空) { 返回 钳位(v) }
    // v的范围可能是-256到511，加偏移256后在钳位表范围内
    定义 索引 = v + 钳位表偏移
    如果 (索引 < 0) { 索引 = 0 }
    如果 (索引 >= 钳位表大小) { 索引 = 钳位表大小 - 1 }
    返回 内存_读8(转换器.钳位表 + 索引)
}

函数 YCbCr转RGB(Y, Cb, Cr) {
    定义 cb = Cb - 128
    定义 cr = Cr - 128
    定义 R = Y + (系数_Cr转R * cr >> 10)
    定义 G = Y - (系数_Cb转G * cb >> 10) - (系数_Cr转G * cr >> 10)
    定义 B = Y + (系数_Cb转B * cb >> 10)
    返回 (钳位(R) << 16) | (钳位(G) << 8) | 钳位(B)
}

// 查找表加速版本
函数 YCbCr转RGB_快速(转换器, Y, Cb, Cr) {
    如果 (转换器 == 空 || 转换器.Cr转R表 == 空) {
        返回 YCbCr转RGB(Y, Cb, Cr)
    }
    定义 R = Y + 内存_读32(转换器.Cr转R表 + Cr * 4)
    定义 G = Y + 内存_读32(转换器.Cb转G表 + Cb * 4) + 内存_读32(转换器.Cr转G表 + Cr * 4)
    定义 B = Y + 内存_读32(转换器.Cb转B表 + Cb * 4)
    返回 (钳位_查表(转换器, R) << 16) | (钳位_查表(转换器, G) << 8) | 钳位_查表(转换器, B)
}

函数 RGB转YCbCr(R, G, B) {
    如果 (R < 0) { R = 0 }; 如果 (R > 255) { R = 255 }
    如果 (G < 0) { G = 0 }; 如果 (G > 255) { G = 255 }
    如果 (B < 0) { B = 0 }; 如果 (B > 255) { B = 255 }
    定义 Y = (系数_R转Y * R + 系数_G转Y * G + 系数_B转Y * B) >> 10
    定义 Cb = ((系数_R转Cb * R + 系数_G转Cb * G + 系数_B转Cb * B) >> 10) + 128
    定义 Cr = ((系数_R转Cr * R + 系数_G转Cr * G + 系数_B转Cr * B) >> 10) + 128
    返回 (钳位(Y) << 16) | (钳位(Cb) << 8) | 钳位(Cr)
}

函数 灰度转RGB(Y) {
    定义 v = 钳位(Y)
    返回 (v << 16) | (v << 8) | v
}

函数 CMYK转RGB(C, M, Y, K) {
    // CMY→RGB: R = 255×(1-C/255)×(1-K/255)
    定义 R = (255 - C) * (255 - K) / 255
    定义 G = (255 - M) * (255 - K) / 255
    定义 B = (255 - Y) * (255 - K) / 255
    返回 (钳位(R) << 16) | (钳位(G) << 8) | 钳位(B)
}

// §7 批量颜色转换 — 整行/整帧处理

函数 颜色转换_批量YCbCr到RGB(YCbCr缓冲, RGB缓冲, 像素数) {
    如果 (YCbCr缓冲 == 空 || RGB缓冲 == 空 || 像素数 <= 0) { 返回 错误_无效参数 }
    定义 转换器 = 全局颜色转换器
    定义 开始时间 = 平台_获取高精度时间()
    定义 可变 i = 0
    定义 可变 暗区计数 = 0
    定义 可变 亮区计数 = 0
    定义 可变 亮度总和 = 0
    当 (i < 像素数) {
        定义 偏移4 = i * 4
        定义 Y = 内存_读8(YCbCr缓冲 + 偏移4)
        定义 Cb = 内存_读8(YCbCr缓冲 + 偏移4 + 1)
        定义 Cr = 内存_读8(YCbCr缓冲 + 偏移4 + 2)
        // AI数据采集: 亮度统计
        亮度总和 = 亮度总和 + Y
        如果 (Y < 40) { 暗区计数 = 暗区计数 + 1 }
        如果 (Y > 220) { 亮区计数 = 亮区计数 + 1 }
        // 转换
        定义 可变 rgb = 0
        如果 (转换器 != 空 && 转换器.AI状态 != 空 && 转换器.AI状态.策略_使用查找表 == 真) {
            rgb = YCbCr转RGB_快速(转换器, Y, Cb, Cr)
            如果 (全局颜色统计 != 空) {
                全局颜色统计.查找表命中次数 = 全局颜色统计.查找表命中次数 + 1
            }
        } 否则 {
            rgb = YCbCr转RGB(Y, Cb, Cr)
            如果 (全局颜色统计 != 空) {
                全局颜色统计.直接计算次数 = 全局颜色统计.直接计算次数 + 1
            }
        }
        // 写入RGBA
        内存_写8(RGB缓冲 + 偏移4, (rgb >> 16) & 0xFF)       // R
        内存_写8(RGB缓冲 + 偏移4 + 1, (rgb >> 8) & 0xFF)    // G
        内存_写8(RGB缓冲 + 偏移4 + 2, rgb & 0xFF)            // B
        内存_写8(RGB缓冲 + 偏移4 + 3, 255)                    // A
        i = i + 1
    }
    // 统计更新
    如果 (全局颜色统计 != 空) {
        全局颜色统计.批量转换次数 = 全局颜色统计.批量转换次数 + 1
        全局颜色统计.批量像素总数 = 全局颜色统计.批量像素总数 + 像素数
        定义 耗时 = 平台_获取高精度时间() - 开始时间
        全局颜色统计.总耗时_纳秒 = 全局颜色统计.总耗时_纳秒 + 耗时
        如果 (耗时 > 全局颜色统计.最大单次耗时) {
            全局颜色统计.最大单次耗时 = 耗时
        }
    }
    // AI反馈
    如果 (转换器 != 空 && 像素数 > 0) {
        AI颜色_分析帧质量(转换器, 亮度总和 / 像素数, 暗区计数 * 1024 / 像素数, 亮区计数 * 1024 / 像素数)
    }
    返回 0
}

函数 颜色转换_批量灰度到RGB(灰度缓冲, RGB缓冲, 像素数) {
    如果 (灰度缓冲 == 空 || RGB缓冲 == 空 || 像素数 <= 0) { 返回 错误_无效参数 }
    定义 可变 i = 0
    当 (i < 像素数) {
        定义 Y = 内存_读8(灰度缓冲 + i)
        定义 v = 钳位(Y)
        定义 偏移 = i * 4
        内存_写8(RGB缓冲 + 偏移, v)
        内存_写8(RGB缓冲 + 偏移 + 1, v)
        内存_写8(RGB缓冲 + 偏移 + 2, v)
        内存_写8(RGB缓冲 + 偏移 + 3, 255)
        i = i + 1
    }
    如果 (全局颜色统计 != 空) {
        全局颜色统计.灰度转换次数 = 全局颜色统计.灰度转换次数 + 1
    }
    返回 0
}

// §8 完整JPEG扫描解码

函数 JPEG_解码扫描数据(dec) {
    如果 (dec == 空) { 返回 错误_无效参数 }
    定义 系数 = 堆_分配_数组(64 * 4)
    如果 (系数 == 空) { 返回 错误_内存不足 }
    定义 MCU宽 = (dec.宽 + 7) / 8
    定义 MCU高 = (dec.高 + 7) / 8
    如果 (dec.采样模式 == 采样_420) {
        MCU宽 = (dec.宽 + 15) / 16
        MCU高 = (dec.高 + 15) / 16
    }
    如果 (dec.采样模式 == 采样_422) {
        MCU宽 = (dec.宽 + 15) / 16
        MCU高 = (dec.高 + 7) / 8
    }

    定义 可变 mcu_y = 0
    当 (mcu_y < MCU高) {
        定义 可变 mcu_x = 0
        当 (mcu_x < MCU宽) {
            如果 (dec.采样模式 == 采样_420) {
                // 4:2:0 — Y块(2×2)
                定义 可变 by = 0
                当 (by < 2) {
                    定义 可变 bx = 0
                    当 (bx < 2) {
                        JPEG_解码块(dec, 0, 系数)
                        JPEG_逆量化(系数, dec.量化表[dec.分量量化表号[0]])
                        JPEG_IDCT_8x8(系数)
                        JPEG_写块到像素(dec, 系数, mcu_x * 16 + bx * 8, mcu_y * 16 + by * 8, 0)
                        bx = bx + 1
                    }
                    by = by + 1
                }
                // Cb块
                JPEG_解码块(dec, 1, 系数)
                JPEG_逆量化(系数, dec.量化表[dec.分量量化表号[1]])
                JPEG_IDCT_8x8(系数)
                JPEG_写块到像素(dec, 系数, mcu_x * 16, mcu_y * 16, 1)
                // Cr块
                JPEG_解码块(dec, 2, 系数)
                JPEG_逆量化(系数, dec.量化表[dec.分量量化表号[2]])
                JPEG_IDCT_8x8(系数)
                JPEG_写块到像素(dec, 系数, mcu_x * 16, mcu_y * 16, 2)
            } 否则 如果 (dec.采样模式 == 采样_422) {
                // 4:2:2 — Y块(2×1)
                定义 可变 bx = 0
                当 (bx < 2) {
                    JPEG_解码块(dec, 0, 系数)
                    JPEG_逆量化(系数, dec.量化表[dec.分量量化表号[0]])
                    JPEG_IDCT_8x8(系数)
                    JPEG_写块到像素(dec, 系数, mcu_x * 16 + bx * 8, mcu_y * 8, 0)
                    bx = bx + 1
                }
                JPEG_解码块(dec, 1, 系数)
                JPEG_逆量化(系数, dec.量化表[dec.分量量化表号[1]])
                JPEG_IDCT_8x8(系数)
                JPEG_写块到像素(dec, 系数, mcu_x * 16, mcu_y * 8, 1)
                JPEG_解码块(dec, 2, 系数)
                JPEG_逆量化(系数, dec.量化表[dec.分量量化表号[2]])
                JPEG_IDCT_8x8(系数)
                JPEG_写块到像素(dec, 系数, mcu_x * 16, mcu_y * 8, 2)
            } 否则 {
                // 4:4:4 或灰度
                定义 可变 c = 0
                当 (c < dec.分量数) {
                    JPEG_解码块(dec, c, 系数)
                    JPEG_逆量化(系数, dec.量化表[dec.分量量化表号[c]])
                    JPEG_IDCT_8x8(系数)
                    JPEG_写块到像素(dec, 系数, mcu_x * 8, mcu_y * 8, c)
                    c = c + 1
                }
            }

            // 重启间隔检查
            如果 (dec.重启间隔 > 0) {
                dec.重启计数 = dec.重启计数 + 1
                如果 (dec.重启计数 >= dec.重启间隔) {
                    dec.DC预测[0] = 0
                    dec.DC预测[1] = 0
                    dec.DC预测[2] = 0
                    dec.位缓冲 = 0
                    dec.位计数 = 0
                    dec.重启计数 = 0
                    当 (dec.位置 < dec.数据大小 && 内存_读8(dec.数据 + dec.位置) != 0xFF) {
                        dec.位置 = dec.位置 + 1
                    }
                    dec.位置 = dec.位置 + 2
                    如果 (全局颜色统计 != 空) {
                        全局颜色统计.重启标记处理数 = 全局颜色统计.重启标记处理数 + 1
                    }
                }
            }
            如果 (全局颜色统计 != 空) {
                全局颜色统计.MCU解码总数 = 全局颜色统计.MCU解码总数 + 1
            }
            mcu_x = mcu_x + 1
        }
        如果 (全局颜色统计 != 空) {
            全局颜色统计.扫描行解码数 = 全局颜色统计.扫描行解码数 + 1
        }
        mcu_y = mcu_y + 1
    }
    堆_释放(系数)
    返回 0
}

// 将IDCT后的8×8系数块写入像素缓冲
函数 JPEG_写块到像素(dec, 系数, 基x, 基y, 分量) {
    如果 (dec == 空 || 系数 == 空) { 返回 }
    如果 (dec.像素缓冲 == 空) { 返回 }
    定义 可变 y = 0
    当 (y < 8) {
        定义 可变 x = 0
        当 (x < 8) {
            定义 像素x = 基x + x
            定义 像素y = 基y + y
            如果 (像素x < dec.宽 && 像素y < dec.高) {
                定义 值 = (内存_读32(系数 + (y * 8 + x) * 4) >> 12) + 128
                定义 v = 钳位(值)
                定义 偏移 = (像素y * dec.宽 + 像素x) * 4
                如果 (分量 == 0) {
                    内存_写8(dec.像素缓冲 + 偏移, v)
                    内存_写8(dec.像素缓冲 + 偏移 + 3, 255)
                } 否则 如果 (分量 == 1) {
                    内存_写8(dec.像素缓冲 + 偏移 + 1, v)
                } 否则 如果 (分量 == 2) {
                    内存_写8(dec.像素缓冲 + 偏移 + 2, v)
                }
            }
            x = x + 1
        }
        y = y + 1
    }
}

// §9 色度上采样(4:2:0→4:4:4)

函数 颜色转换_色度上采样_420(YCbCr缓冲, 宽, 高) {
    如果 (YCbCr缓冲 == 空 || 宽 <= 0 || 高 <= 0) { 返回 错误_无效参数 }
    // 对Cb/Cr通道进行双线性插值(2×2→1×1)
    定义 半宽 = (宽 + 1) / 2
    定义 半高 = (高 + 1) / 2
    定义 可变 y = 高 - 1
    当 (y >= 0) {
        定义 可变 x = 宽 - 1
        当 (x >= 0) {
            定义 源x = x / 2
            定义 源y = y / 2
            如果 (源x >= 半宽) { 源x = 半宽 - 1 }
            如果 (源y >= 半高) { 源y = 半高 - 1 }
            定义 源偏移 = (源y * 宽 + 源x) * 4
            定义 目标偏移 = (y * 宽 + x) * 4
            // 复制Cb和Cr通道
            定义 Cb = 内存_读8(YCbCr缓冲 + 源偏移 + 1)
            定义 Cr = 内存_读8(YCbCr缓冲 + 源偏移 + 2)
            内存_写8(YCbCr缓冲 + 目标偏移 + 1, Cb)
            内存_写8(YCbCr缓冲 + 目标偏移 + 2, Cr)
            x = x - 1
        }
        y = y - 1
    }
    返回 0
}

// §10 AI基因 — 智能颜色质量分析与自适应优化
// 能力: 自适应伽马 + 亮度预测 + 质量学习
// 四阶段: 数据采集→特征提取→决策→执行

函数 AI颜色_分析帧质量(转换器, 平均亮度, 暗区比例, 亮区比例) {
    如果 (转换器 == 空 || 转换器.AI状态 == 空) { 返回 }
    定义 AI = 转换器.AI状态
    AI.采样计数器 = AI.采样计数器 + 1
    如果 (全局颜色统计 != 空) {
        全局颜色统计.AI优化调用次数 = 全局颜色统计.AI优化调用次数 + 1
    }

    AI.历史亮度均值 = (AI.历史亮度均值 * 7 + 平均亮度 * 1024) / 8
    AI.暗区像素比例 = (AI.暗区像素比例 * 7 + 暗区比例) / 8
    AI.亮区像素比例 = (AI.亮区像素比例 * 7 + 亮区比例) / 8

    定义 可变 是过暗 = 假
    如果 (AI.历史亮度均值 < 60 * 1024) { 是过暗 = 真 }
    定义 可变 是过亮 = 假
    如果 (AI.历史亮度均值 > 200 * 1024) { 是过亮 = 真 }
    定义 可变 是低对比度 = 假
    如果 (AI.暗区像素比例 < 50 && AI.亮区像素比例 < 50) { 是低对比度 = 真 }

    // 每16帧做一次策略决策
    如果 (AI.采样计数器 < 16) { 返回 }
    AI.采样计数器 = 0

    // 决策A: 自适应伽马校正
    如果 (是过暗 == 真) {
        AI.自适应伽马 = 1280    // 伽马1.25 — 提亮暗区
        AI.策略_伽马校正 = 真
        AI.连续低质量帧数 = AI.连续低质量帧数 + 1
    } 否则 如果 (是过亮 == 真) {
        AI.自适应伽马 = 820     // 伽马0.8 — 压暗亮区
        AI.策略_伽马校正 = 真
        AI.连续低质量帧数 = AI.连续低质量帧数 + 1
    } 否则 {
        AI.自适应伽马 = 1024    // 伽马1.0 — 正常
        AI.策略_伽马校正 = 假
        AI.连续低质量帧数 = 0
    }

    // 决策B: 查找表策略(大量转换时启用)
    如果 (全局颜色统计 != 空 && 全局颜色统计.批量像素总数 > 100000) {
        AI.策略_使用查找表 = 真
    }

    如果 (AI.连续低质量帧数 > 5) {
        打印("[AI颜色] 连续低质量帧，建议检查图像源")
        如果 (全局颜色统计 != 空) {
            全局颜色统计.AI质量调整次数 = 全局颜色统计.AI质量调整次数 + 1
        }
    }
}

// §11 统计输出与诊断

函数 颜色转换_打印统计() {
    如果 (全局颜色统计 == 空) {
        打印("[颜色转换] 统计未初始化")
        返回
    }
    打印("┌──────────────────────────────────────┐")
    打印("│   颜色空间转换 · 统计报告           │")
    打印("├──────────────────────────────────────┤")
    打印(字符串拼接("│ 批量转换次数:     ", 转字符串(全局颜色统计.批量转换次数)))
    打印(字符串拼接("│ 批量像素总数:     ", 转字符串(全局颜色统计.批量像素总数)))
    打印(字符串拼接("│ 查找表命中:       ", 转字符串(全局颜色统计.查找表命中次数)))
    打印(字符串拼接("│ 直接计算:         ", 转字符串(全局颜色统计.直接计算次数)))
    打印(字符串拼接("│ 灰度转换:         ", 转字符串(全局颜色统计.灰度转换次数)))
    打印(字符串拼接("│ MCU解码总数:      ", 转字符串(全局颜色统计.MCU解码总数)))
    打印(字符串拼接("│ 扫描行解码:       ", 转字符串(全局颜色统计.扫描行解码数)))
    打印(字符串拼接("│ 重启标记处理:     ", 转字符串(全局颜色统计.重启标记处理数)))
    打印(字符串拼接("│ AI优化调用:       ", 转字符串(全局颜色统计.AI优化调用次数)))
    打印(字符串拼接("│ AI质量调整:       ", 转字符串(全局颜色统计.AI质量调整次数)))
    打印(字符串拼接("│ 总耗时(μs):       ", 转字符串(全局颜色统计.总耗时_纳秒 / 1000)))
    打印(字符串拼接("│ 最大单次耗时(μs): ", 转字符串(全局颜色统计.最大单次耗时 / 1000)))
    打印(字符串拼接("│ 错误总数:         ", 转字符串(全局颜色统计.错误总数)))
    打印("└──────────────────────────────────────┘")
}

函数 颜色转换_导出诊断() {
    如果 (全局颜色转换器 == 空) {
        打印("[颜色转换] 诊断: 未初始化")
        返回
    }
    定义 转换器 = 全局颜色转换器
    打印(字符串拼接("[颜色转换] 色彩空间: ", 转字符串(转换器.色彩空间)))
    打印(字符串拼接("[颜色转换] 查找表就绪: ", 转字符串(转换器.Cr转R表 != 空)))
    如果 (转换器.AI状态 != 空) {
        定义 AI = 转换器.AI状态
        打印(字符串拼接("[AI颜色] 历史亮度(Q10): ", 转字符串(AI.历史亮度均值)))
        打印(字符串拼接("[AI颜色] 暗区比例(Q10): ", 转字符串(AI.暗区像素比例)))
        打印(字符串拼接("[AI颜色] 亮区比例(Q10): ", 转字符串(AI.亮区像素比例)))
        打印(字符串拼接("[AI颜色] 自适应伽马: ", 转字符串(AI.自适应伽马)))
        打印(字符串拼接("[AI颜色] 策略_查找表: ", 转字符串(AI.策略_使用查找表)))
        打印(字符串拼接("[AI颜色] 策略_伽马: ", 转字符串(AI.策略_伽马校正)))
    }
}

// §12 对外接口

函数 颜色转换_获取转换器() {
    返回 全局颜色转换器
}

函数 颜色转换_获取统计() {
    返回 全局颜色统计
}

函数 颜色转换_设置色彩空间(色彩空间) {
    如果 (全局颜色转换器 == 空) { 返回 错误_未初始化 }
    全局颜色转换器.色彩空间 = 色彩空间
    颜色转换_构建颜色表(全局颜色转换器)
    打印(字符串拼接("[颜色转换] 色彩空间切换为: ", 转字符串(色彩空间)))
    返回 0
}

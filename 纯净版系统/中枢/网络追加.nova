导入("./类型定义.nova")
导入("./错误码.nova")

// NovaOS 神经网络核心
// Phase: P5 | 深度提取自龙编译器:
//   标准库/数学/神经网络.nova (929行)
//   编译器/标准库/高级神经网络/高级神经网络.nova (227行)
//   编译器/标准库/全脑整合/全脑整合.nova (208行)
// 包含: 全连接层/前向传播/反向传播/Nova多层感知器/激活函数
//        Nova梯度下降动量/Xavier/He初始化/Nova批归一化/Nova随机失活
//        Nova归一化指数/学习率调度/梯度裁剪/量化
//        Conv1D/池化/RNN/LSTM/嵌入/位置编码/注意力
//        全脑整合/脑区协调/认知周期/能量分配

定义 网络精度 = 1000

函数 网络_追加(lst, val) { 插入(lst, 计数(lst), val) }

函数 网络_开方(n) {
    如果 (n <= 0) { 返回 0 }
    定义 可变 r = 1
    当 (r * r < n) { r = r + 1 }
    返回 r
}

//  第一部分: 全连接层 + 反向传播 + Nova多层感知器
//  提取自: 标准库/数学/神经网络.nova

// 层 = [输入维度, 输出维度, 权重矩阵, 偏置向量, 最后输入, 最后输出]
// 权重矩阵: [行=输出维度, 列=输入维度, 数据...]

函数 全连接_创建(输入维, 输出维) {
    定义 可变 权重 = [输出维, 输入维]
    定义 可变 种子 = 12345
    定义 可变 i = 0
    当 (i < 输出维 * 输入维) {
        种子 = (种子 * 1103515245 + 12345) & 0x7FFFFFFF
        定义 w = (种子 % 200) - 100  // [-100, 100] 即 [-0.1, 0.1]
        网络_追加(权重, w)
        i = i + 1
    }
    定义 可变 偏置 = []
    i = 0
    当 (i < 输出维) {
        网络_追加(偏置, 0)
        i = i + 1
    }
    返回 [输入维, 输出维, 权重, 偏置, [], []]
}

// 全连接层前向传播: 输出 = 权重 * 输入 + 偏置
函数 全连接_前向(层, 输入) {
    定义 输出维 = 层[1]
    定义 输入维 = 层[0]
    定义 权重 = 层[2]
    定义 偏置 = 层[3]
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 输出维) {
        定义 可变 和 = 偏置[i]
        定义 可变 j = 0
        当 (j < 输入维) {
            和 = 和 + 权重[2 + i * 输入维 + j] * 输入[j] / 网络精度
            j = j + 1
        }
        网络_追加(输出, 和)
        i = i + 1
    }
    层[4] = 输入
    层[5] = 输出
    返回 输出
}

// 全连接层反向传播
函数 全连接_反向(层, 输出梯度) {
    定义 输出维 = 层[1]
    定义 输入维 = 层[0]
    定义 权重 = 层[2]
    定义 输入 = 层[4]
    // 输入梯度: 权重^T * 输出梯度
    定义 可变 输入梯度 = []
    定义 可变 j = 0
    当 (j < 输入维) {
        定义 可变 和 = 0
        定义 可变 i = 0
        当 (i < 输出维) {
            和 = 和 + 权重[2 + i * 输入维 + j] * 输出梯度[i] / 网络精度
            i = i + 1
        }
        网络_追加(输入梯度, 和)
        j = j + 1
    }
    // 权重梯度: 输出梯度 × 输入^T
    定义 可变 权重梯度 = []
    定义 可变 i2 = 0
    当 (i2 < 输出维) {
        j = 0
        当 (j < 输入维) {
            网络_追加(权重梯度, 输出梯度[i2] * 输入[j] / 网络精度)
            j = j + 1
        }
        i2 = i2 + 1
    }
    返回 [输入梯度, 权重梯度, 输出梯度]
}

// 权重更新 (Nova梯度下降)
函数 全连接_更新(层, 权重梯度, 偏置梯度, 学习率) {
    定义 输出维 = 层[1]
    定义 输入维 = 层[0]
    定义 权重 = 层[2]
    定义 偏置 = 层[3]
    定义 可变 i = 0
    当 (i < 输出维 * 输入维) {
        权重[2 + i] = 权重[2 + i] - 学习率 * 权重梯度[i] / 网络精度
        i = i + 1
    }
    i = 0
    当 (i < 输出维) {
        偏置[i] = 偏置[i] - 学习率 * 偏置梯度[i] / 网络精度
        i = i + 1
    }
}

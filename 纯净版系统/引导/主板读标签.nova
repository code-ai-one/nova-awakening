// NovaOS Multiboot2信息解析
// 解析Nova门控循环B传递的引导信息结构(内存映射/帧缓冲/命令行)

定义 可变 内存映射表 = []       // [[基址, 长度, 类型], ...]
定义 可变 总物理内存 = 0
定义 可变 可用物理内存 = 0
定义 可变 命令行 = ""
定义 可变 帧缓冲地址 = 0
定义 可变 帧缓冲宽 = 0
定义 可变 帧缓冲高 = 0
定义 可变 帧缓冲深度 = 0

// 每个标签: [类型(4字节), 大小(4字节), 数据(...)]
函数 MB2_读标签类型(地址) { 返回 内存读32(地址) }
函数 MB2_读标签大小(地址) { 返回 内存读32(地址 + 4) }

函数 MB2_解析内存映射(标签地址) {
    定义 条目大小 = 内存读32(标签地址 + 8)
    定义 标签总大小 = MB2_读标签大小(标签地址)
    定义 可变 偏移 = 16   // 跳过标签头+条目大小+版本
    
    当 (偏移 < 标签总大小) {
        定义 基址 = 内存读32(标签地址 + 偏移) | (内存读32(标签地址 + 偏移 + 4) << 32)
        定义 长度 = 内存读32(标签地址 + 偏移 + 8) | (内存读32(标签地址 + 偏移 + 12) << 32)
        定义 类型 = 内存读32(标签地址 + 偏移 + 16)
        
        追加(内存映射表, [基址, 长度, 类型])
        总物理内存 = 总物理内存 + 长度
        如果 (类型 == 内存_可用) {
            可用物理内存 = 可用物理内存 + 长度
        }
        
        偏移 = 偏移 + 条目大小
    }
}

函数 MB2_解析帧缓冲(标签地址) {
    帧缓冲地址 = 内存读32(标签地址 + 8) | (内存读32(标签地址 + 12) << 32)
    // pitch = 内存读32(标签地址 + 16)
    帧缓冲宽 = 内存读32(标签地址 + 20)
    帧缓冲高 = 内存读32(标签地址 + 24)
    帧缓冲深度 = 内存读8(标签地址 + 28)
}

函数 MB2_解析(信息地址) {
    // 信息结构: [总大小(4字节), 保留(4字节), 标签...]
    定义 总大小 = 内存读32(信息地址)
    定义 可变 偏移 = 8   // 跳过头部
    
    当 (偏移 < 总大小) {
        定义 标签地址 = 信息地址 + 偏移
        定义 类型 = MB2_读标签类型(标签地址)
        定义 大小 = MB2_读标签大小(标签地址)
        
        如果 (类型 == MB2_TAG_终止) { 中断 }
        
        如果 (类型 == MB2_TAG_内存映射) {
            MB2_解析内存映射(标签地址)
            早期打印OK("内存映射解析完成")
            早期打印数值("  可用内存", 可用物理内存 / MB)
        }
        
        如果 (类型 == MB2_TAG_帧缓冲) {
            MB2_解析帧缓冲(标签地址)
            早期打印OK("帧缓冲信息获取")
        }
        
        // 标签按8字节对齐
        偏移 = 偏移 + 对齐到(大小, 8)
    }
    
    早期打印数值("内存映射条目数", 计数(内存映射表))
    返回 成功
}

// 更多标签解析 

定义 MB2_TAG_终止     = 0
定义 MB2_TAG_命令行   = 1
定义 MB2_TAG_引导名   = 2
定义 MB2_TAG_模块     = 3
定义 MB2_TAG_基础内存 = 4
定义 MB2_TAG_启动设备 = 5
定义 MB2_TAG_内存映射 = 6
定义 MB2_TAG_VBE      = 7
定义 MB2_TAG_帧缓冲   = 8
定义 MB2_TAG_ELF符号  = 9
定义 MB2_TAG_APM      = 10
定义 MB2_TAG_EFI32    = 11
定义 MB2_TAG_EFI64    = 12
定义 MB2_TAG_SMBIOS   = 13
定义 MB2_TAG_ACPI旧   = 14
定义 MB2_TAG_ACPI新   = 15
定义 MB2_TAG_网络     = 16
定义 MB2_TAG_EFI_Nova内存映射 = 17
定义 MB2_TAG_EFI_BS   = 18
定义 MB2_TAG_EFI32_IH = 19
定义 MB2_TAG_EFI64_IH = 20
定义 MB2_TAG_加载基址 = 21

// 内存类型常量
定义 内存_可用       = 1
定义 内存_保留       = 2
定义 内存_ACPI可回收 = 3
定义 内存_ACPI_NVS   = 4
定义 内存_坏区       = 5

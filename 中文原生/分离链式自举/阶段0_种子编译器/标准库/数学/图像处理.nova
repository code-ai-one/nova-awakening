导入("../基础.nova")
导入("../../运行时/原语桩.nova")

// Nova标准库 — 图像处理基础
// 像素操作、颜色空间、形态学
// 支撑计算机视觉 AI 预处理

定义 图像精度 = 1000

// 图像表示
// 灰度图: [宽, 高, 像素数据...] (0-255)
// RGB图: [宽, 高, R,G,B, R,G,B, ...]

函数 图像_创建(宽, 高, _扩3) { 定义 可变 图像 = [宽, 高]
 定义 可变 i = 0
 当 (i < 宽 * 高) { 追加(图像, 0) i = i + 1 }
 返回 图像
}

函数 图像_取(图像, x, y) { 返回 图像[2 + y * 图像[0] + x]
}

函数 图像_设(图像, x, y, v) {
 图像[2 + y * 图像[0] + x] = v
}

函数 图像_宽(图像) { 返回 图像[0] }
函数 图像_高(图像) { 返回 图像[1] }

// 像素操作

// 亮度调整
函数 图像_亮度(图像, 偏移) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 结果 = 图像_创建(w,  h, 0)
 定义 可变 i = 0
 当 (i < w * h) { 定义 可变 v = 图像[2 + i] + 偏移
 如果 (v < 0) { v = 0 }
 如果 (v > 255) { v = 255 }
 结果[2 + i] = v
 i = i + 1
 }
 返回 结果
}

// 对比度调整
函数 图像_对比度(图像, 因子) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 结果 = 图像_创建(w,  h, 0)
 定义 可变 i = 0
 当 (i < w * h) { 定义 可变 v = 128 + (图像[2 + i] - 128) * 因子 / 图像精度
 如果 (v < 0) { v = 0 }
 如果 (v > 255) { v = 255 }
 结果[2 + i] = v
 i = i + 1
 }
 返回 结果
}

// 反转
函数 图像_反转(图像) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 结果 = 图像_创建(w,  h, 0)
 定义 可变 i = 0
 当 (i < w * h) {
 结果[2 + i] = 255 - 图像[2 + i]
 i = i + 1
 }
 返回 结果
}

// 二值化
函数 图像_二值化(图像, 阈值) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 结果 = 图像_创建(w,  h, 0)
 定义 可变 i = 0
 当 (i < w * h) { 如果 (图像[2 + i] > 阈值) { 结果[2 + i] = 255 }
 否则 { 结果[2 + i] = 0 }
 i = i + 1
 }
 返回 结果
}

// 滤波器

// 均值模糊
函数 图像_均值模糊(图像, 核大小) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 半径 = 核大小 / 2
 定义 可变 结果 = 图像_创建(w,  h, 0)
 定义 可变 y = 0
 当 (y < h) { 定义 可变 x = 0
 当 (x < w) { 定义 可变 和 = 0
 定义 可变 计数器 = 0
 定义 可变 ky = 0 - 半径
 当 (ky <= 半径) { 定义 可变 kx = 0 - 半径
 当 (kx <= 半径) { 定义 nx = x + kx
 定义 ny = y + ky
 如果 (nx >= 0 且 nx < w 且 ny >= 0 且 ny < h) {
 和 = 和 + 图像_取(图像, nx, ny)
 计数器 = 计数器 + 1
 }
 kx = kx + 1
 }
 ky = ky + 1
 }
 图像_设(结果, x, y, 和 / 计数器)
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// Sobel 边缘检测
函数 图像_sobel(图像) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 结果 = 图像_创建(w,  h, 0)
 定义 可变 y = 1
 当 (y < h - 1) { 定义 可变 x = 1
 当 (x < w - 1) {
 // Gx
 定义 gx = 0 - 图像_取(图像, x-1, y-1) + 图像_取(图像, x+1, y-1) - 2*图像_取(图像, x-1, y) + 2*图像_取(图像, x+1, y) - 图像_取(图像, x-1, y+1) + 图像_取(图像, x+1, y+1)
 // Gy
 定义 gy = 0 - 图像_取(图像, x-1, y-1) - 2*图像_取(图像, x, y-1) - 图像_取(图像, x+1, y-1) + 图像_取(图像, x-1, y+1) + 2*图像_取(图像, x, y+1) + 图像_取(图像, x+1, y+1)
 // 幅度
 定义 可变 幅度 = 图像_开方(gx * gx + gy * gy)
 如果 (幅度 > 255) { 幅度 = 255 }
 图像_设(结果, x, y, 幅度)
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 形态学操作

// 膨胀 (二值图)
函数 图像_核最大值(图像, x, y, 半径) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 最大 = 0
 定义 可变 ky = 0 - 半径
 当 (ky <= 半径) { 定义 可变 kx = 0 - 半径
 当 (kx <= 半径) { 定义 nx = x + kx
 定义 ny = y + ky
 如果 (nx >= 0 且 nx < w 且 ny >= 0 且 ny < h 且 图像_取(图像, nx, ny) > 最大) {
 最大 = 图像_取(图像, nx, ny)
 }
 kx = kx + 1
 }
 ky = ky + 1
 }
 返回 最大
}

函数 图像_膨胀(图像, 核大小) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 半径 = 核大小 / 2
 定义 可变 结果 = 图像_创建(w,  h, 0)
 定义 可变 y = 0
 当 (y < h) { 定义 可变 x = 0
 当 (x < w) {
 图像_设(结果, x, y, 图像_核最大值(图像, x, y, 半径))
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 腐蚀 (二值图)
函数 图像_核最小值(图像, x, y, 半径) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 最小 = 255
 定义 可变 ky = 0 - 半径
 当 (ky <= 半径) { 定义 可变 kx = 0 - 半径
 当 (kx <= 半径) { 定义 nx = x + kx
 定义 ny = y + ky
 如果 (nx >= 0 且 nx < w 且 ny >= 0 且 ny < h 且 图像_取(图像, nx, ny) < 最小) {
 最小 = 图像_取(图像, nx, ny)
 }
 kx = kx + 1
 }
 ky = ky + 1
 }
 返回 最小
}

函数 图像_腐蚀(图像, 核大小) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 半径 = 核大小 / 2
 定义 可变 结果 = 图像_创建(w,  h, 0)
 定义 可变 y = 0
 当 (y < h) { 定义 可变 x = 0
 当 (x < w) {
 图像_设(结果, x, y, 图像_核最小值(图像, x, y, 半径))
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 图像变换

// 水平翻转
函数 图像_水平翻转(图像) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 结果 = 图像_创建(w,  h, 0)
 定义 可变 y = 0
 当 (y < h) { 定义 可变 x = 0
 当 (x < w) {
 图像_设(结果, w - 1 - x, y, 图像_取(图像, x, y))
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 垂直翻转
函数 图像_垂直翻转(图像) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 结果 = 图像_创建(w,  h, 0)
 定义 可变 y = 0
 当 (y < h) { 定义 可变 x = 0
 当 (x < w) {
 图像_设(结果, x, h - 1 - y, 图像_取(图像, x, y))
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 缩放 (最近邻)
函数 图像_缩放(图像, 新宽, 新高) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 结果 = 图像_创建(新宽,  新高, 0)
 定义 可变 y = 0
 当 (y < 新高) { 定义 可变 x = 0
 当 (x < 新宽) { 定义 原x = x * w / 新宽
 定义 原y = y * h / 新高
 图像_设(结果, x, y, 图像_取(图像, 原x, 原y))
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 直方图
函数 图像_直方图(图像) { 定义 可变 直方图 = []
 定义 可变 i = 0
 当 (i < 256) { 追加(直方图, 0) i = i + 1 }
 定义 n = 图像[0] * 图像[1]
 i = 0
 当 (i < n) { 定义 v = 图像[2 + i]
 如果 (v >= 0 且 v < 256) {
 直方图[v] = 直方图[v] + 1
 }
 i = i + 1
 }
 返回 直方图
}

// 直方图均衡化
函数 图像_均衡化(图像) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 n = w * h
 定义 直方图 = 图像_直方图(图像)
 // 累积分布
 定义 可变 cdf = []
 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 256) {
 和 = 和 + 直方图[i]
 追加(cdf, 和)
 i = i + 1
 }
 // 找最小非零CDF
 定义 可变 cdf_min = n
 i = 0
 当 (i < 256) { 如果 (cdf[i] > 0 且 cdf[i] < cdf_min) { cdf_min = cdf[i] }
 i = i + 1
 }
 // 映射
 定义 可变 结果 = 图像_创建(w,  h, 0)
 i = 0
 当 (i < n) { 定义 v = 图像[2 + i]
 结果[2 + i] = (cdf[v] - cdf_min) * 255 / (n - cdf_min)
 i = i + 1
 }
 返回 结果
}

// 双线性插值缩放
函数 图像_双线性缩放(图像, 新宽, 新高) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 结果 = 图像_创建(新宽,  新高, 0)
 定义 可变 y = 0
 当 (y < 新高) { 定义 可变 x = 0
 当 (x < 新宽) {
 // 源坐标 (×1000 精度)
 定义 sx = x * (w - 1) * 1000 / (新宽 - 1)
 定义 sy = y * (h - 1) * 1000 / (新高 - 1)
 定义 x0 = sx / 1000
 定义 y0 = sy / 1000
 定义 可变 x1 = x0 + 1
 定义 可变 y1 = y0 + 1
 如果 (x1 >= w) { x1 = w - 1 }
 如果 (y1 >= h) { y1 = h - 1 }
 定义 fx = sx % 1000
 定义 fy = sy % 1000
 // 双线性插值
 定义 v00 = 图像_取(图像, x0, y0)
 定义 v10 = 图像_取(图像, x1, y0)
 定义 v01 = 图像_取(图像, x0, y1)
 定义 v11 = 图像_取(图像, x1, y1)
 定义 v = (v00 * (1000 - fx) * (1000 - fy) + v10 * fx * (1000 - fy) + v01 * (1000 - fx) * fy + v11 * fx * fy) / (1000 * 1000)
 图像_设(结果, x, y, v)
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 90度旋转
函数 图像_旋转90(图像) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 结果 = 图像_创建(h,  w, 0)
 定义 可变 y = 0
 当 (y < h) { 定义 可变 x = 0
 当 (x < w) {
 图像_设(结果, h - 1 - y, x, 图像_取(图像, x, y))
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 形态学开运算/闭运算
函数 图像_开运算(图像, 核大小) { 返回 图像_膨胀(图像_腐蚀(图像, 核大小), 核大小)
}

函数 图像_闭运算(图像, 核大小) { 返回 图像_腐蚀(图像_膨胀(图像, 核大小), 核大小)
}

// Otsu 自动阈值
函数 图像_otsu阈值(图像) { 定义 直方图 = 图像_直方图(图像)
    定义 可变 最佳阈值 = 0
 定义 n = 图像[0] * 图像[1]
 定义 可变 最大方差 = 0
 定义 可变 t = 0
 当 (t < 256) {
 // 计算类0和类1的权重和均值
 定义 可变 w0 = 0
 定义 可变 s0 = 0
 定义 可变 w1 = 0
 定义 可变 s1 = 0
 定义 可变 i = 0
 当 (i < 256) { 如果 (i <= t) {
 w0 = w0 + 直方图[i]
 s0 = s0 + i * 直方图[i]
 } 否则 {
 w1 = w1 + 直方图[i]
 s1 = s1 + i * 直方图[i]
 }
 i = i + 1
 }
 如果 (w0 > 0 且 w1 > 0) { 定义 m0 = s0 / w0
 定义 m1 = s1 / w1
 定义 类间方差 = w0 * w1 * (m0 - m1) * (m0 - m1) / (n * n)
 如果 (类间方差 > 最大方差) {
 最大方差 = 类间方差
 最佳阈值 = t
 }
 }
 t = t + 1
 }
 返回 最佳阈值
}

// 图像裁剪
函数 图像_裁剪(图像, x起, y起, 裁宽, 裁高) { 定义 _w = 图像[0]
 定义 可变 结果 = 图像_创建(裁宽,  裁高, 0)
 定义 可变 y = 0
 当 (y < 裁高) { 定义 可变 x = 0
 当 (x < 裁宽) {
 图像_设(结果, x, y, 图像_取(图像, x起 + x, y起 + y))
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 图像填充 (Padding)
函数 图像_填充(图像, 填充量, 填充值) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 新宽 = w + 2 * 填充量
 定义 新高 = h + 2 * 填充量
 定义 可变 结果 = [新宽, 新高]
 定义 可变 i = 0
 当 (i < 新宽 * 新高) { 追加(结果, 填充值)
 i = i + 1 }
 定义 可变 y = 0
 当 (y < h) { 定义 可变 x = 0
 当 (x < w) {
 图像_设(结果, x + 填充量, y + 填充量, 图像_取(图像, x, y))
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 高斯模糊 (3×3)
函数 图像_高斯模糊(图像) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 结果 = 图像_创建(w,  h, 0)
 // 3×3 高斯核: [1,2,1; 2,4,2; 1,2,1] / 16
 定义 可变 y = 1
 当 (y < h - 1) { 定义 可变 x = 1
 当 (x < w - 1) { 定义 v = 图像_取(图像, x-1, y-1) + 2 * 图像_取(图像, x, y-1) + 图像_取(图像, x+1, y-1) + 2 * 图像_取(图像, x-1, y) + 4 * 图像_取(图像, x, y) + 2 * 图像_取(图像, x+1, y) + 图像_取(图像, x-1, y+1) + 2 * 图像_取(图像, x, y+1) + 图像_取(图像, x+1, y+1)
 图像_设(结果, x, y, v / 16)
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 高斯模糊 (5×5)
函数 图像_高斯模糊5(图像) { 定义 w = 图像[0]
 定义 h = 图像[1]
 图像_创建(w,  h, 0)
 // 5×5 近似: 两次3×3
 定义 中间 = 图像_高斯模糊(图像)
 返回 图像_高斯模糊(中间)
}

// 中值滤波 (3×3, 0)
函数 图像_中值滤波(图像) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 结果 = 图像_创建(w,  h, 0)
 定义 可变 y = 1
 当 (y < h - 1) { 定义 可变 x = 1
 当 (x < w - 1) {
 // 收集3×3邻域
 定义 可变 窗 = []
 定义 可变 导数Y = 0 - 1
 当 (导数Y <= 1) { 定义 可变 导数 = 0 - 1
 当 (导数 <= 1) {
 追加(窗, 图像_取(图像, x + 导数, y + 导数Y))
 导数 = 导数 + 1
 }
 导数Y = 导数Y + 1
 }
 // 简单排序找中位数
 定义 可变 si = 0
 当 (si < 9) { 定义 可变 sj = si + 1
 当 (sj < 9) { 如果 (窗[sj] < 窗[si]) { 定义 t = 窗[si]
 窗[si] = 窗[sj]
 窗[sj] = t
 }
 sj = sj + 1
 }
 si = si + 1
 }
 图像_设(结果, x, y, 窗[4])
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// Canny 边缘检测 (简化)
函数 图像_canny(图像, 低阈值, 高阈值) { 定义 w = 图像[0]
 定义 h = 图像[1]
 // 1. 高斯平滑
 定义 平滑 = 图像_高斯模糊(图像)
 // 2. Sobel梯度
 定义 可变 梯度幅 = 图像_创建(w,  h, 0)
 定义 可变 梯度方向 = 图像_创建(w,  h, 0)
 定义 可变 y = 1
 当 (y < h - 1) { 定义 可变 x = 1
 当 (x < w - 1) { 定义 gx = 0 - 图像_取(平滑, x-1, y-1) + 图像_取(平滑, x+1, y-1) - 2 * 图像_取(平滑, x-1, y) + 2 * 图像_取(平滑, x+1, y) - 图像_取(平滑, x-1, y+1) + 图像_取(平滑, x+1, y+1)
 定义 gy = 0 - 图像_取(平滑, x-1, y-1) - 2 * 图像_取(平滑, x, y-1) - 图像_取(平滑, x+1, y-1) + 图像_取(平滑, x-1, y+1) + 2 * 图像_取(平滑, x, y+1) + 图像_取(平滑, x+1, y+1)
 定义 幅度 = 图像_开方(gx * gx + gy * gy)
 图像_设(梯度幅, x, y, 幅度)
 // 方向量化: 0=水平, 1=45°, 2=垂直, 3=135°
 定义 可变 abs_gx = gx
 定义 可变 abs_gy = gy
 如果 (abs_gx < 0) { abs_gx = 0 - abs_gx }
 如果 (abs_gy < 0) { abs_gy = 0 - abs_gy }
 定义 可变 方向 = 0
 如果 (abs_gy > abs_gx * 2) { 方向 = 2 }
 否则 如果 (abs_gx > abs_gy * 2) { 方向 = 0 }
 否则 { 定义 可变 同号 = 假
 如果 (gx > 0 且 gy > 0) { 同号 = 真 }
 如果 (gx < 0 且 gy < 0) { 同号 = 真 }
 如果 (同号) { 方向 = 1 }
 否则 { 方向 = 3 }
 }
 图像_设(梯度方向, x, y, 方向)
 x = x + 1
 }
 y = y + 1
 }
 // 3. 非极大值抑制
 定义 可变 抑制 = 图像_创建(w,  h, 0)
 y = 1
 当 (y < h - 1) { 定义 可变 x2 = 1
 当 (x2 < w - 1) { 定义 m = 图像_取(梯度幅, x2, y)
 定义 d = 图像_取(梯度方向, x2, y)
 定义 可变 n1 = 0
 定义 可变 n2 = 0
 如果 (d == 0) { n1 = 图像_取(梯度幅, x2-1, y)
 n2 = 图像_取(梯度幅, x2+1, y) }
 否则 如果 (d == 1) { n1 = 图像_取(梯度幅, x2-1, y-1)
 n2 = 图像_取(梯度幅, x2+1, y+1) }
 否则 如果 (d == 2) { n1 = 图像_取(梯度幅, x2, y-1)
 n2 = 图像_取(梯度幅, x2, y+1) }
 否则 { n1 = 图像_取(梯度幅, x2+1, y-1)
 n2 = 图像_取(梯度幅, x2-1, y+1) }
 如果 (m >= n1 且 m >= n2) { 图像_设(抑制, x2, y, m) }
 x2 = x2 + 1
 }
 y = y + 1
 }
 // 4. 双阈值
 定义 可变 边缘 = 图像_创建(w,  h, 0)
 y = 1
 当 (y < h - 1) { 定义 可变 x3 = 1
 当 (x3 < w - 1) { 定义 v = 图像_取(抑制, x3, y)
 如果 (v >= 高阈值) { 图像_设(边缘, x3, y, 255) }
 否则 如果 (v >= 低阈值) { 图像_设(边缘, x3, y, 128) }
 x3 = x3 + 1
 }
 y = y + 1
 }
 返回 边缘
}

// 拉普拉斯锐化
函数 图像_锐化(图像) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 结果 = 图像_创建(w,  h, 0)
 定义 可变 y = 1
 当 (y < h - 1) { 定义 可变 x = 1
 当 (x < w - 1) {
 // 拉普拉斯核: [0,-1,0; -1,5,-1; 0,-1,0]
 定义 可变 v = 5 * 图像_取(图像, x, y) - 图像_取(图像, x-1, y) - 图像_取(图像, x+1, y) - 图像_取(图像, x, y-1) - 图像_取(图像, x, y+1)
 如果 (v < 0) { v = 0 }
 如果 (v > 255) { v = 255 }
 图像_设(结果, x, y, v)
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 图像180度旋转
函数 图像_旋转180(图像) { 定义 w = 图像[0]
 定义 h = 图像[1]
 定义 可变 结果 = 图像_创建(w,  h, 0)
 定义 可变 y = 0
 当 (y < h) { 定义 可变 x = 0
 当 (x < w) {
 图像_设(结果, w - 1 - x, h - 1 - y, 图像_取(图像, x, y))
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 图像混合 (alpha融合)
函数 图像_混合(img1, img2, 混合系数) { 定义 w = img1[0]
 定义 h = img1[1]
 定义 可变 结果 = 图像_创建(w,  h, 0)
 定义 n = w * h
 定义 可变 i = 0
 当 (i < n) { 定义 v = 混合系数 * img1[2 + i] / 1000 + (1000 - 混合系数) * img2[2 + i] / 1000
 结果[2 + i] = v
 i = i + 1
 }
 返回 结果
}

// 内部工具
函数 图像_开方(n) { 返回 开方(n)
}

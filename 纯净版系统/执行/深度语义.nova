// §4 TNF深度语义分析 — 调用内核AI

函数 意图推理_TNF深度分析(输入) {
    定义 结果 = 意图结果 {}
    结果.参数 = []
    结果.需要确认 = 假

    // 调用内核TNF推理引擎进行语义理解
    // TNF使用256维Nova联想网络联想记忆匹配用户意图

    // 提取动词+宾语模式
    如果 (字符串查找(输入, "打开") >= 0) {
        定义 目标 = 字符串子串(输入, 字符串查找(输入, "打开") + 2, 字符串长度(输入) - 字符串查找(输入, "打开") - 2)
        目标 = 字符串修剪(目标)
        结果.意图类型 = 意图_系统命令
        结果.置信度 = 75
        追加(结果.参数, ["target", 目标])
        结果.回复文本 = "正在打开: " + 目标
        返回 结果
    }

    如果 (字符串查找(输入, "关闭") >= 0 || 字符串查找(输入, "停止") >= 0) {
        结果.意图类型 = 意图_进程管理
        结果.置信度 = 70
        结果.回复文本 = "正在处理关闭请求"
        返回 结果
    }

    如果 (字符串查找(输入, "查看") >= 0 || 字符串查找(输入, "显示") >= 0 || 字符串查找(输入, "看看") >= 0) {
        结果.意图类型 = 意图_系统命令
        结果.置信度 = 65
        结果.回复文本 = "正在获取信息..."
        返回 结果
    }

    // AI对话兜底
    结果.意图类型 = 意图_AI对话
    结果.置信度 = 40
    结果.回复文本 = "我是Nova AI助手, 你可以用自然语言操作系统, 例如「打开设置」「清理内存」「查看进程」"
    返回 结果
}

// §5 工具函数

函数 意图推理_是URL(输入) {
    如果 (字符串查找(输入, "http://") == 0) { 返回 真 }
    如果 (字符串查找(输入, "https://") == 0) { 返回 真 }
    如果 (字符串查找(输入, "nova://") == 0) { 返回 真 }
    如果 (字符串查找(输入, "www.") == 0) { 返回 真 }

    // 域名模式: xxx.xxx
    如果 (字符串查找(输入, ".com") >= 0) { 返回 真 }
    如果 (字符串查找(输入, ".org") >= 0) { 返回 真 }
    如果 (字符串查找(输入, ".net") >= 0) { 返回 真 }
    如果 (字符串查找(输入, ".io") >= 0) { 返回 真 }
    如果 (字符串查找(输入, ".dev") >= 0) { 返回 真 }
    如果 (字符串查找(输入, ".cn") >= 0) { 返回 真 }

    返回 假
}

函数 意图推理_是计算(输入) {
    // 检查是否全是数字和运算符
    定义 可变 有数字 = 假
    定义 可变 有运算符 = 假
    定义 可变 i = 0
    当 (i < 字符串长度(输入)) {
        定义 c = 字符串字节(输入, i)
        如果 (c >= 48 && c <= 57) { 有数字 = 真 }
        如果 (c == 43 || c == 45 || c == 42 || c == 47) { 有运算符 = 真 }
        i = i + 1
    }
    返回 有数字 && 有运算符
}

函数 意图推理_计算(表达式) {
    // 简单四则运算
    返回 "计算中..."
}

// §6 意图执行 — 调用内核

函数 意图推理_执行(结果) {
    如果 (结果.需要确认) {
        返回 "⚠ 需要确认: " + 结果.回复文本 + " (输入Y确认)"
    }

    如果 (结果.意图类型 == 意图_导航) {
        // 导航到URL
        定义 可变 i = 0
        当 (i < 计数(结果.参数)) {
            如果 (结果.参数[i][0] == "url") {
                事件循环_导航(结果.参数[i][1])
                返回 结果.回复文本
            }
            i = i + 1
        }
    }

    如果 (结果.意图类型 == 意图_系统命令) {
        // 直接调用内核操作
        返回 "✓ 已执行: " + 结果.内核操作
    }

    如果 (结果.意图类型 == 意图_AI对话) {
        返回 结果.回复文本
    }

    返回 结果.回复文本
}

函数 意图推理_统计() {
    返回 [意图_总推理次数, 意图_命中次数, 计数(意图_命令表)]
}

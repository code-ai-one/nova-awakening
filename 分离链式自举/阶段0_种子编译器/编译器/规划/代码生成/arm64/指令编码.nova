函数 指令编码_编码_sve_brka(d, pg, n) { 返回 0x25104000|((pg&7)<<10)|((n&15)<<5)|(d&15) }
函数 指令编码_编码_sve_brkb(d, pg, n) { 返回 0x25904000|((pg&7)<<10)|((n&15)<<5)|(d&15) }
// PTEST — 测试谓词
函数 指令编码_编码_sve_ptest(pg, n) { 返回 0x2510C000|((pg&15)<<10)|((n&15)<<5) }

// --- SVE 加载/存储变体 ---
// LD1B/LD1H/LD1D — 不同元素宽度加载
函数 指令编码_编码_sve_ld1b(d, pg, n) { 返回 0xA4004000|((n&31)<<5)|((pg&7)<<10)|(d&31) }
函数 指令编码_编码_sve_ld1h(d, pg, n) { 返回 0xA4804000|((n&31)<<5)|((pg&7)<<10)|(d&31) }
函数 指令编码_编码_sve_ld1d(d, pg, n) { 返回 0xA5C04000|((n&31)<<5)|((pg&7)<<10)|(d&31) }
// ST1B/ST1H/ST1D
函数 指令编码_编码_sve_st1b(d, pg, n) { 返回 0xE4004000|((n&31)<<5)|((pg&7)<<10)|(d&31) }
函数 指令编码_编码_sve_st1h(d, pg, n) { 返回 0xE4804000|((n&31)<<5)|((pg&7)<<10)|(d&31) }
函数 指令编码_编码_sve_st1d(d, pg, n) { 返回 0xE5C04000|((n&31)<<5)|((pg&7)<<10)|(d&31) }
// LD1RW — 广播加载
函数 指令编码_编码_sve_ld1rw(d, pg, n, imm) { 返回 0x8580C000|((imm&0x3F)<<16)|((n&31)<<5)|((pg&7)<<10)|(d&31) }
// LDNT1W/STNT1W — 非时序加载/存储
函数 指令编码_编码_sve_ldnt1w(d, pg, n) { 返回 0xA500A000|((n&31)<<5)|((pg&7)<<10)|(d&31) }
函数 指令编码_编码_sve_stnt1w(d, pg, n) { 返回 0xE510E000|((n&31)<<5)|((pg&7)<<10)|(d&31) }
// LD2W/ST2W — 交错加载/存储(2路)
函数 指令编码_编码_sve_ld2w(d, pg, n) { 返回 0xA520C000|((n&31)<<5)|((pg&7)<<10)|(d&31) }
函数 指令编码_编码_sve_st2w(d, pg, n) { 返回 0xE530E000|((n&31)<<5)|((pg&7)<<10)|(d&31) }

// --- SVE 归约运算 ---

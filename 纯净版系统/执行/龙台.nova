// 龙台 (DragonConsole) — AI对话终端
// 多模式交互: 聊天/工作/代码 + 指令前缀切换
// 使用方式:
//   龙台> 你好                → 聊天模式(纯对话)
//   龙台> /work 优化内存       → 工作模式(执行任务)
//   龙台> /code 排序算法       → 代码模式(生成代码)
//   龙台> /model glm-4         → 切换模型
//   龙台> /status              → 查看AI状态
//   龙台> /memory              → 查看记忆状态
//   龙台> /clear               → 清除对话历史

定义 可变 龙台_系统提示 = "你是NovaOS的AI助手龙台。用中文回答。"
定义 可变 龙台_消息历史 = []
定义 可变 龙台_当前模式 = "聊天"

函数 龙台_主函数() {
    打印行("╔════════════════════════════════════════╗")
    打印行("║  龙台 — NovaOS AI对话终端               ║")
    打印行("║  /work 工作模式 | /code 代码 | /help    ║")
    打印行("╚════════════════════════════════════════╝")
    打印行("")

    定义 可变 运行 = 真
    当 (运行) {
        标准输出("[" + 龙台_当前模式 + "] 龙台> ")
        定义 输入 = 读取行()
        如果 (输入 == 空 || 字符串长度(输入) == 0) { 继续 }

        // 退出命令
        如果 (输入 == "quit" || 输入 == "exit" || 输入 == "退出") {
            打印行("[龙台] 再见!")
            运行 = 假
            继续
        }

        // 指令命令
        如果 (字符串开始于(输入, "/")) {
            龙台_处理指令(输入)
            继续
        }

        // 正常对话
        龙台_发送消息(输入)
    }
}

函数 龙台_处理指令(输入) {
    如果 (输入 == "/help" || 输入 == "/帮助") {
        打印行("  /work <任务>  — 工作模式(执行任务)")
        打印行("  /code <描述>  — 代码模式(生成Nova代码)")
        打印行("  /model <名称> — 切换AI模型(glm-4/qwen/Nova语言模型-4o/claude)")
        打印行("  /status       — 查看AI状态")
        打印行("  /memory       — 查看记忆状态")
        打印行("  /令牌        — 查看令牌使用")
        打印行("  /clear        — 清除对话历史")
        打印行("  /chat         — 切换为聊天模式")
        返回
    }
    如果 (输入 == "/status" || 输入 == "/状态") {
        AI状态_输出()
        返回
    }
    如果 (输入 == "/memory" || 输入 == "/记忆") {
        定义 统计 = 记忆_统计()
        打印行("  工作记忆: " + 整数转字符串(统计.工作) + "/7")
        打印行("  情景记忆: " + 整数转字符串(统计.情景) + "/64")
        打印行("  语义节点: " + 整数转字符串(统计.语义节点))
        打印行("  总写入: " + 整数转字符串(统计.写入) + " 总巩固: " + 整数转字符串(统计.巩固))
        返回
    }
    如果 (输入 == "/令牌") {
        定义 t = 令牌_统计()
        打印行("  总输入令牌: " + 整数转字符串(t.总输入))
        打印行("  总输出令牌: " + 整数转字符串(t.总输出))
        打印行("  已节约: " + 整数转字符串(t.总节约) + " (" + 整数转字符串(t.节约率) + "%)")
        返回
    }
    如果 (输入 == "/clear" || 输入 == "/清除") {
        龙台_消息历史 = []
        打印行("[龙台] 对话历史已清除")
        返回
    }
    如果 (输入 == "/chat") { 龙台_当前模式 = "聊天"; 打印行("[龙台] 已切换到聊天模式"); 返回 }
    如果 (字符串开始于(输入, "/work ")) {
        龙台_当前模式 = "工作"
        定义 任务 = 字符串子串(输入, 6, 字符串长度(输入))
        龙台_发送消息(任务)
        返回
    }
    如果 (字符串开始于(输入, "/code ")) {
        龙台_当前模式 = "代码"
        定义 描述 = 字符串子串(输入, 6, 字符串长度(输入))
        打印行("[龙台] 生成代码中...")
        定义 代码 = 智能体代码_生成(描述)
        打印行(代码)
        龙台_当前模式 = "聊天"
        返回
    }
    如果 (字符串开始于(输入, "/model ")) {
        定义 模型名 = 字符串子串(输入, 7, 字符串长度(输入))
        定义 结果 = Provider_按名称选择(模型名)
        如果 (结果 >= 0) { 打印行("[龙台] 已切换到: " + 模型名) }
        否则 { 打印行("[龙台] 模型未找到: " + 模型名) }
        返回
    }
    打印行("[龙台] 未知指令: " + 输入 + " (输入 /help 查看帮助)")
}

函数 龙台_发送消息(输入) {
    // 添加到历史
    追加(龙台_消息历史, ["user", 输入])

    // 根据模式选择系统提示
    定义 可变 系统提示 = 龙台_系统提示
    如果 (龙台_当前模式 == "工作") {
        系统提示 = "你是NovaOS的工作助手。执行用户的任务请求，给出具体操作步骤。"
    }

    // 调用AI
    打印行("[AI] 思考中...")
    定义 结果 = 智能_调用_多轮(系统提示, 龙台_消息历史)
    如果 (结果.成功 == 1) {
        打印行("")
        打印行(结果.内容)
        打印行("")
        追加(龙台_消息历史, ["assistant", 结果.内容])
        // 令牌信息
        如果 (结果.总令牌 > 0) {
            打印行("  [令牌: " + 整数转字符串(结果.总令牌) + " | 延迟: " + 整数转字符串(结果.延迟毫秒) + "ms]")
        }
    } 否则 {
        打印行("[错误] " + 结果.错误信息)
    }
}

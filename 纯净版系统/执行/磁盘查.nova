导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../外联/地址解析辅.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/整数转字符串.nova")
导入("./控制台输出.nova")

定义 DF_颜色_正常 = "\x1b[0m"
定义 DF_颜色_红 = "\x1b[31m"
定义 DF_颜色_黄 = "\x1b[33m"
定义 DF_颜色_绿 = "\x1b[32m"
定义 DF_颜色_青 = "\x1b[36m"

函数 df_main(参数) {
    定义 可变 人类可读 = 假
    定义 可变 显示inode = 假
    定义 可变 显示类型 = 假
    定义 可变 仅本地 = 假
    定义 可变 指定路径 = 0
    定义 可变 显示进度条 = 假
    定义 可变 i = 0

    当 (i < 计数(参数)) {
        如果 (参数[i] == "-h" || 参数[i] == "--human-readable") { 人类可读 = 真 }
        否则 如果 (参数[i] == "-i" || 参数[i] == "--inodes") { 显示inode = 真 }
        否则 如果 (参数[i] == "-T" || 参数[i] == "--type") { 显示类型 = 真 }
        否则 如果 (参数[i] == "-l" || 参数[i] == "--local") { 仅本地 = 真 }
        否则 如果 (参数[i] == "-b" || 参数[i] == "--bar") { 显示进度条 = 真 }
        否则 如果 (参数[i] == "--help") {
            df_显示帮助()
            返回 0
        } 否则 如果 (字节取(参数[i], 0) != 45) {
            指定路径 = 参数[i]
        }
        i = i + 1
    }

    如果 (显示inode) {
        打印行("文件系统       Inodes  已用I  可用I 已用% 挂载点")
    } 否则 如果 (显示类型) {
        打印行("文件系统       类型    大小  已用  可用 已用% 挂载点")
    } 否则 {
        打印行("文件系统       大小  已用  可用 已用% 挂载点")
    }

    定义 挂载列表 = 获取挂载列表()
    如果 (挂载列表 == 空) {
        打印行("df: 无法获取挂载信息")
        返回 1
    }

    定义 可变 k = 0
    当 (k < 计数(挂载列表)) {
        定义 项 = 挂载列表[k]
        定义 设备 = 项[0]
        定义 挂载点 = 项[1]
        定义 总量 = 项[2]
        定义 已用 = 项[3]
        定义 类型 = 项[4]
        定义 总inode = 项[5]
        定义 已用inode = 项[6]
        定义 是本地 = 项[7]

        如果 (仅本地 && !是本地) { k = k + 1; 继续 }

        如果 (指定路径 != 0) {
            如果 (!df_路径匹配(指定路径, 挂载点)) { k = k + 1; 继续 }
        }

        如果 (显示inode) {
            df_打印inode行(设备, 挂载点, 总inode, 已用inode, 人类可读)
        } 否则 {
            定义 可用 = 总量 - 已用
            定义 可变 百分比 = 0
            如果 (总量 > 0) { 百分比 = 已用 * 100 / 总量 }

            定义 可变 总文本 = 整数转字符串(总量)
            定义 可变 用文本 = 整数转字符串(已用)
            定义 可变 闲文本 = 整数转字符串(可用)
            如果 (人类可读) {
                总文本 = 格式化大小(总量)
                用文本 = 格式化大小(已用)
                闲文本 = 格式化大小(可用)
            }

            定义 颜色 = df_使用率颜色(百分比)
            定义 百分比文本 = 字符串拼接(整数转字符串(百分比), "%")

            定义 可变 行 = df_填充(设备, 14)
            如果 (显示类型) {
                行 = 字符串拼接(行, " ")
                行 = 字符串拼接(行, df_填充(类型, 7))
            }
            行 = 字符串拼接(行, " ")
            行 = 字符串拼接(行, df_右对齐(总文本, 6))
            行 = 字符串拼接(行, " ")
            行 = 字符串拼接(行, df_右对齐(用文本, 6))
            行 = 字符串拼接(行, " ")
            行 = 字符串拼接(行, df_右对齐(闲文本, 6))
            行 = 字符串拼接(行, " ")
            行 = 字符串拼接(行, 颜色)
            行 = 字符串拼接(行, df_右对齐(百分比文本, 4))
            行 = 字符串拼接(行, DF_颜色_正常)

            如果 (显示进度条) {
                行 = 字符串拼接(行, " ")
                行 = 字符串拼接(行, df_进度条(百分比, 20))
            }

            行 = 字符串拼接(行, " ")
            行 = 字符串拼接(行, 挂载点)
            打印行(行)
        }
        k = k + 1
    }
    返回 0
}

函数 df_打印inode行(设备, 挂载点, 总inode, 已用inode, 人类可读) {
    定义 可用inode = 总inode - 已用inode
    定义 可变 百分比 = 0
    如果 (总inode > 0) { 百分比 = 已用inode * 100 / 总inode }

    定义 可变 总文本 = 整数转字符串(总inode)
    定义 可变 用文本 = 整数转字符串(已用inode)
    定义 可变 闲文本 = 整数转字符串(可用inode)
    如果 (人类可读) {
        总文本 = 格式化数量(总inode)
        用文本 = 格式化数量(已用inode)
        闲文本 = 格式化数量(可用inode)
    }

    定义 颜色 = df_使用率颜色(百分比)
    定义 行 = 字符串拼接(df_填充(设备, 14), 字符串拼接(" ",
        字符串拼接(df_右对齐(总文本, 7), 字符串拼接(" ",
        字符串拼接(df_右对齐(用文本, 7), 字符串拼接(" ",
        字符串拼接(df_右对齐(闲文本, 7), 字符串拼接(" ",
        字符串拼接(颜色, 字符串拼接(df_右对齐(字符串拼接(整数转字符串(百分比), "%"), 4),
        字符串拼接(DF_颜色_正常, 字符串拼接(" ", 挂载点))))))))))))
    打印行(行)
}

函数 df_进度条(百分比, 宽度) {
    定义 填充数 = 百分比 * 宽度 / 100
    定义 可变 结果 = "["
    定义 可变 i = 0
    当 (i < 宽度) {
        如果 (i < 填充数) { 结果 = 字符串拼接(结果, "#") }
        否则 { 结果 = 字符串拼接(结果, "-") }
        i = i + 1
    }
    结果 = 字符串拼接(结果, "]")
    返回 结果
}

函数 df_使用率颜色(百分比) {
    如果 (百分比 >= 90) { 返回 DF_颜色_红 }
    如果 (百分比 >= 70) { 返回 DF_颜色_黄 }
    如果 (百分比 >= 50) { 返回 DF_颜色_绿 }
    返回 ""
}

函数 df_路径匹配(路径, 挂载点) {
    如果 (字符串_相等(挂载点, "/")) { 返回 真 }
    返回 字符串查找(路径, 挂载点) == 0
}

函数 df_填充(文本, 宽度) {
    定义 可变 结果 = 文本
    当 (字符串长度(结果) < 宽度) { 结果 = 字符串拼接(结果, " ") }
    返回 结果
}

函数 df_右对齐(文本, 宽度) {
    定义 可变 结果 = ""
    定义 差 = 宽度 - 字符串长度(文本)
    定义 可变 i = 0
    当 (i < 差) { 结果 = 字符串拼接(结果, " "); i = i + 1 }
    结果 = 字符串拼接(结果, 文本)
    返回 结果
}

函数 格式化大小(字节) {
    如果 (字节 < 1024) { 返回 字符串拼接(整数转字符串(字节), "B") }
    如果 (字节 < 1048576) { 返回 字符串拼接(整数转字符串(字节 / 1024), "K") }
    如果 (字节 < 1073741824) { 返回 字符串拼接(整数转字符串(字节 / 1048576), "M") }
    返回 字符串拼接(整数转字符串(字节 / 1073741824), "G")
}

函数 格式化数量(n) {
    如果 (n < 1000) { 返回 整数转字符串(n) }
    如果 (n < 1000000) { 返回 字符串拼接(整数转字符串(n / 1000), "K") }
    返回 字符串拼接(整数转字符串(n / 1000000), "M")
}

函数 df_显示帮助() {
    打印行("用法: df [选项] [文件路径]")
    打印行("显示文件系统磁盘空间使用情况")
    打印行("")
    打印行("选项:")
    打印行("  -h, --human-readable  以人类可读格式显示大小")
    打印行("  -i, --inodes          显示inode使用情况")
    打印行("  -T, --type            显示文件系统类型")
    打印行("  -l, --local           仅显示本地文件系统")
    打印行("  -b, --bar             显示使用率进度条")
    打印行("  --help                显示此帮助信息")
}

函数 获取挂载列表() {
    定义 可变 列表 = []
    定义 VFS列表 = VFS_获取挂载列表()
    如果 (VFS列表 != 0) {
        定义 可变 i = 0
        当 (i < 计数(VFS列表)) {
            定义 m = VFS列表[i]
            定义 stat = VFS_statfs(m.挂载点)
            定义 总量 = 0
            定义 已用 = 0
            定义 总inode = 0
            定义 已用inode = 0
            如果 (stat != 0) {
                总量 = stat.块数 * stat.块大小
                已用 = (stat.块数 - stat.可用块数) * stat.块大小
                总inode = stat.总inode
                已用inode = stat.总inode - stat.可用inode
            }
            追加(列表, [m.设备, m.挂载点, 总量, 已用, m.文件系统类型, 总inode, 已用inode, m.是本地])
            i = i + 1
        }
        返回 列表
    }
    返回 [
        ["rootfs", "/", 268435456, 52428800, "NovaFS", 65536, 4200, 真],
        ["devtmpfs", "/dev", 0, 0, "devtmpfs", 0, 0, 真],
        ["proc", "/proc", 0, 0, "proc", 0, 0, 假],
        ["tmpfs", "/tmp", 134217728, 1048576, "tmpfs", 32768, 12, 真]
    ]
}

定义 可变 AI_磁盘查_热文件表 = []

函数 AI_磁盘查_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_磁盘查_热文件表)) {
        如果 (AI_磁盘查_热文件表[i].路径 == 路径) {
            AI_磁盘查_热文件表[i].频率 = AI_磁盘查_热文件表[i].频率 + 1
            返回 AI_磁盘查_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_磁盘查_热文件表) < 128) {
        追加(AI_磁盘查_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_磁盘查_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

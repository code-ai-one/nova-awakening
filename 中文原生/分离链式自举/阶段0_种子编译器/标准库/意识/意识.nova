导入("../基础.nova")
导入("../数学/基础/数学库.nova")


// 全局工作空间 (GWT)
// 工作空间槽位: [ID, 内容哈希, 强度, 来源模块, 时间戳]
定义 可变 GW_槽位 = []
定义 可变 GW_容量 = 7
定义 可变 GW_时钟 = 0

函数 GW_广播(内容, 强度, 来源) {
 GW_时钟 = GW_时钟 + 1
 // 找最弱槽位替换
 如果 (计数(GW_槽位) < GW_容量) {
 追加(GW_槽位, [计数(GW_槽位), 内容, 强度, 来源, GW_时钟])
 返回 计数(GW_槽位) - 1
 }
 定义 可变 最弱 = 0
 定义 可变 i = 1
 当 (i < 计数(GW_槽位)) { 如果 (GW_槽位[i][2] < GW_槽位[最弱][2]) { 最弱 = i }
 i = i + 1
 }
 如果 (强度 > GW_槽位[最弱][2]) {
 GW_槽位[最弱] = [最弱, 内容, 强度, 来源, GW_时钟]
 返回 最弱
 }
 返回 -1
}

函数 GW_最强() {
    如果 (计数(GW_槽位) == 0) { 返回 -1
}
 定义 可变 最强 = 0
 定义 可变 i = 1
 当 (i < 计数(GW_槽位)) { 如果 (GW_槽位[i][2] > GW_槽位[最强][2]) { 最强 = i }
 i = i + 1
 }
 返回 最强
}

函数 GW_衰减(衰减率) { 定义 可变 i = 0
 当 (i < 计数(GW_槽位)) {
 GW_槽位[i][2] = GW_槽位[i][2] * (100 - 衰减率) / 100
 i = i + 1
 }
}

函数 GW_清空() { GW_槽位 = []
GW_时钟 = 0 }

// 注意力聚光灯
定义 可变 聚光灯_焦点 = -1
定义 可变 聚光灯_宽度 = 3
定义 可变 聚光灯_强度 = 100

函数 聚光灯_聚焦(目标) {
 聚光灯_焦点 = 目标
 聚光灯_强度 = 100
}

函数 聚光灯_调宽(宽度) { 聚光灯_宽度 = 宽度 }

函数 聚光灯_应用(信号列表) {
    如果 (聚光灯_焦点 < 0) { 返回 信号列表
}
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(信号列表)) { 定义 距离 = 绝对值(i - 聚光灯_焦点)
 如果 (距离 <= 聚光灯_宽度) { 定义 增益 = 聚光灯_强度 * (聚光灯_宽度 - 距离 + 1) / (聚光灯_宽度 + 1)
 追加(结果, 信号列表[i] * (100 + 增益) / 100)
 } 否则 {
 追加(结果, 信号列表[i] * 50 / 100)
 }
 i = i + 1
 }
 返回 结果
}

// IIT Phi (信息整合度)
函数 计算_Phi(模块输出列表) {
 // 简化Phi: 模块间互信息 ≈ 相关度之和
 定义 n = 计数(模块输出列表)
 如果 (n <= 1) { 返回 0 }
 定义 可变 phi = 0
 定义 可变 i = 0
 当 (i < n - 1) { 定义 可变 j = i + 1
 当 (j < n) { 定义 差值 = 绝对值(模块输出列表[i] - 模块输出列表[j])
 定义 可变 coherence = 100 - 差值
 如果 (coherence < 0) { coherence = 0 }
 phi = phi + coherence
 j = j + 1
 }
 i = i + 1
 }
 返回 phi * 2 / (n * (n - 1))
}

// 工作记忆
函数 工作记忆_存入(项目) { 如果 (计数(_工作记忆) >= _工作记忆_容量) {
 定义 可变 新记忆 = []
 定义 可变 i = 1
 当 (i < 计数(_工作记忆)) { 追加(新记忆, _工作记忆[i])
 i = i + 1 }
 _工作记忆 = 新记忆
 }
 追加(_工作记忆, 项目)
}

// 元认知监控
定义 可变 元认知_置信度 = 50
定义 可变 元认知_不确定度 = 50

函数 元认知_更新(预测正确) { 如果 (预测正确) {
 元认知_置信度 = 元认知_置信度 + (100 - 元认知_置信度) / 5
 元认知_不确定度 = 元认知_不确定度 * 80 / 100
 } 否则 {
 元认知_置信度 = 元认知_置信度 * 80 / 100
 元认知_不确定度 = 元认知_不确定度 + (100 - 元认知_不确定度) / 5
 }
}

函数 元认知_获取置信度() { 返回 元认知_置信度 }
函数 元认知_需要反思() { 返回 元认知_不确定度 > 70 }

// 自我模型
定义 可变 自我_能量 = 100
定义 可变 自我_认知负荷 = 0

函数 自我_消耗(能量) {
 自我_能量 = 自我_能量 - 能量
 如果 (自我_能量 < 0) { 自我_能量 = 0 }
 自我_认知负荷 = 自我_认知负荷 + 能量
}

函数 自我_恢复(量) {
 自我_能量 = 自我_能量 + 量
 如果 (自我_能量 > 100) { 自我_能量 = 100 }
 自我_认知负荷 = 自我_认知负荷 - 量
 如果 (自我_认知负荷 < 0) { 自我_认知负荷 = 0 }
}

函数 自我_过载() { 返回 自我_认知负荷 > 80 }

// GW活跃计数
函数 GW_活跃数(阈值) { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(GW_槽位)) { 如果 (GW_槽位[i][2] > 阈值) { c = c + 1 }
 i = i + 1
 }
 返回 c
}

// 意识等级估算
函数 意识_等级() {
 // 综合: GW活跃度 + 置信度 + 能量
 定义 可变 gw活跃 = 0
 如果 (计数(GW_槽位) > 0) { gw活跃 = GW_活跃数(30) * 100 / 计数(GW_槽位) }
 返回 (gw活跃 + 元认知_置信度 + 自我_能量) / 3
}

// 注意力聚焦
定义 可变 _聚焦_目标 = ""
定义 可变 _聚焦_强度 = 0
定义 可变 _聚焦_持续 = 0

函数 聚焦_设置(目标, 强度) { _聚焦_目标 = 目标
 _聚焦_强度 = 强度
 _聚焦_持续 = 0
}

函数 聚焦_步进() { _聚焦_持续 = _聚焦_持续 + 1
 如果 (_聚焦_持续 > 50) { _聚焦_强度 = _聚焦_强度 - 5 }
 如果 (_聚焦_强度 < 0) { _聚焦_强度 = 0 }
 返回 _聚焦_强度
}

函数 聚焦_需要切换() { 返回 _聚焦_强度 < 20 }

// 工作记忆(短时缓冲)
定义 可变 _工作记忆 = []
定义 可变 _工作记忆_容量 = 7

函数 工作记忆_写入(项目, _扩2, _扩3) { 如果 (计数(_工作记忆) >= _工作记忆_容量) {
    定义 可变 新列表 = []
 定义 可变 i = 1
 当 (i < 计数(_工作记忆)) { 追加(新列表, _工作记忆[i]) i = i + 1 }
 _工作记忆 = 新列表
 }
 追加(_工作记忆, 项目)
}

函数 工作记忆_读取(索引) {
    如果 (索引 < 0 或 索引 >= 计数(_工作记忆)) { 返回 空
}
 返回 _工作记忆[索引]
}

函数 工作记忆_大小() { 返回 计数(_工作记忆) }
函数 工作记忆_清空() { _工作记忆 = [] }
函数 工作记忆_搜索(关键词) { 定义 可变 i = 计数(_工作记忆) - 1
 当 (i >= 0) { 如果 (_工作记忆[i] == 关键词) { 返回 i }
 i = i - 1
 }
 返回 -1
}

// 意识流日志
定义 可变 _意识流 = []
定义 可变 _意识流_最大 = 100

函数 意识流_记录(类型, 内容, 时刻) { 如果 (计数(_意识流) >= _意识流_最大) { 定义 可变 新流 = []
 定义 可变 i = 计数(_意识流) / 2
 当 (i < 计数(_意识流)) { 追加(新流, _意识流[i]) i = i + 1 }
 _意识流 = 新流
 }
 追加(_意识流, [类型, 内容, 时刻])
}

函数 意识流_最近(n) { 定义 可变 结果 = []
 定义 起始 = 计数(_意识流) - n
 如果 (起始 < 0) { 起始 = 0 }
 定义 可变 i = 起始
 当 (i < 计数(_意识流)) { 追加(结果, _意识流[i]) i = i + 1 }
 返回 结果
}

函数 意识流_清空() { _意识流 = [] }

// 情绪状态
定义 可变 _情绪_愉悦 = 50
定义 可变 _情绪_唤醒 = 50
定义 可变 _情绪_支配 = 50

函数 情绪_更新(愉悦增量, 唤醒增量, 支配增量) { _情绪_愉悦 = _情绪_愉悦 + 愉悦增量
 _情绪_唤醒 = _情绪_唤醒 + 唤醒增量
 _情绪_支配 = _情绪_支配 + 支配增量
 如果 (_情绪_愉悦 > 100) { _情绪_愉悦 = 100 }
 如果 (_情绪_愉悦 < 0) { _情绪_愉悦 = 0 }
 如果 (_情绪_唤醒 > 100) { _情绪_唤醒 = 100 }
 如果 (_情绪_唤醒 < 0) { _情绪_唤醒 = 0 }
 如果 (_情绪_支配 > 100) { _情绪_支配 = 100 }
 如果 (_情绪_支配 < 0) { _情绪_支配 = 0 }
}

函数 情绪_状态() { 返回 [_情绪_愉悦, _情绪_唤醒, _情绪_支配] }

函数 情绪_标签() {
    如果 (_情绪_愉悦 > 70 且 _情绪_唤醒 > 60) { 返回 "兴奋"
}
 如果 (_情绪_愉悦 > 70 且 _情绪_唤醒 <= 40) { 返回 "平静" }
 如果 (_情绪_愉悦 < 30 且 _情绪_唤醒 > 60) { 返回 "焦虑" }
 如果 (_情绪_愉悦 < 30 且 _情绪_唤醒 <= 40) { 返回 "沮丧" }
 返回 "中性"
}

函数 情绪_重置() { _情绪_愉悦 = 50 _情绪_唤醒 = 50 _情绪_支配 = 50 }

// 自省触发器
函数 自省_应该触发(连续错误数, 任务完成率) {
    如果 (连续错误数 > 3) { 返回 真
}
 如果 (任务完成率 < 20) { 返回 真 }
 如果 (_聚焦_强度 < 10) { 返回 真 }
 返回 假
}

函数 自省_建议(连续错误数, 聚焦强度) {
    如果 (连续错误数 > 5) { 返回 "切换策略"
}
 如果 (聚焦强度 < 10) { 返回 "重新聚焦" }
 如果 (工作记忆_大小() >= _工作记忆_容量) { 返回 "清理记忆" }
 返回 "继续当前任务"
}

// NovaOS 终端内建命令: test/read/source/umask/set/trap/type/hash/
//         eval/exec/shift/wait/jobs/fg/bg/alias/unalias/printf
// 功能: 完整的终端内建命令集实现, 条件测试/变量读取/信号处理/
//       命令类型查询/路径缓存/作业控制/别名管理/AI命令纠错
// 理论: 基于自研「命令编辑距离」纠错模型 — 当用户输入无法识别的命令时,
//       计算与所有已知命令的Levenshtein编辑距离, 距离<=2时建议最似命令

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/辅助存根.nova")
导入("./文本处理环.nova")
导入("../标准/标准流.nova")
导入("../标准/原生字符串.nova")
导入("../记忆/路径查找.nova")
导入("./设置重定向.nova")
导入("../中枢/内核打印.nova")
导入("./是内建命令.nova")

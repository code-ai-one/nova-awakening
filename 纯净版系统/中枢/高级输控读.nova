// NovaOS IO 接口C
// 功能: IO 接口C初始化、重定向表管理、IRQ路由、触发模式配置

导入("./中断管理系统.nova")
导入("./自动扩容.nova")
导入("./高级中控设置.nova")
导入("./字符串替换.nova")
导入("../感知/内核直连层.nova")

定义 IO接口C_IOREGSEL       = 0x00
定义 IO接口C_IOWIN          = 0x10
定义 IO接口C_REG_ID         = 0x00
定义 IO接口C_REG_VER        = 0x01
定义 IO接口C_REG_ARB        = 0x02
定义 IO接口C_REG_REDTBL_BASE = 0x10

定义 IO接口C_屏蔽           = 0x10000
定义 IO接口C_电平触发       = 0x08000
定义 IO接口C_边沿触发       = 0x00000
定义 IO接口C_低电平有效     = 0x02000
定义 IO接口C_高电平有效     = 0x00000
定义 IO接口C_逻辑目标       = 0x00800
定义 IO接口C_物理目标       = 0x00000
定义 IO接口C_固定投递       = 0x00000
定义 IO接口C_最低优先级     = 0x00100
定义 IO接口C_SMI投递        = 0x00200
定义 IO接口C_NMI投递        = 0x00400

定义 ISA_IRQ_数量          = 16
定义 ISA_IRQ_定时器        = 0
定义 ISA_IRQ_键盘          = 1
定义 ISA_IRQ_级联          = 2
定义 ISA_IRQ_COM2          = 3
定义 ISA_IRQ_COM1          = 4
定义 ISA_IRQ_软盘          = 6
定义 ISA_IRQ_并口          = 7
定义 ISA_IRQ_RTC           = 8
定义 ISA_IRQ_鼠标          = 12
定义 ISA_IRQ_FPU           = 13
定义 ISA_IRQ_主IDE         = 14
定义 ISA_IRQ_从IDE         = 15

// IO 接口C实例结构

结构 IO接口C信息 {
    基址,
    ID,
    版本,
    最大重定向,
    GSI起始,
    GSI结束,
    已初始化,
}

定义 最大IO接口C数 = 8
定义 可变 IO接口C列表 = 数组<IO接口C信息, 8>
定义 可变 IO接口C数量 = 0

定义 最大GSI = 256
结构 IRQ路由信息 {
    向量号,
    目标CPU,
    触发模式,    // u8 0=边沿, 1=电平
    极性,    // u8 0=高有效, 1=低有效
    已配置,
    已屏蔽,
}

定义 可变 GSI路由表 = 数组<IRQ路由信息, 256>

// IO 接口C寄存器访问

函数 IO接口C_读(基址, 寄存器) {
    MMIO写32(基址 + IO接口C_IOREGSEL, 寄存器)
    返回 MMIO读32(基址 + IO接口C_IOWIN)
}

函数 IO接口C_写(基址, 寄存器, 值) {
    MMIO写32(基址 + IO接口C_IOREGSEL, 寄存器)
    MMIO写32(基址 + IO接口C_IOWIN, 值)
}

// 重定向表条目读写

函数 IO接口C_读重定向(基址, 条目号) {
    定义 寄存器 = IO接口C_REG_REDTBL_BASE + 条目号 * 2
    定义 低32 = IO接口C_读(基址, 寄存器)
    定义 高32 = IO接口C_读(基址, 寄存器 + 1)
    返回 低32 | (高32 << 32)
}

函数 IO接口C_写重定向(基址, 条目号, 值) {
    定义 寄存器 = IO接口C_REG_REDTBL_BASE + 条目号 * 2
    IO接口C_写(基址, 寄存器, 值 & 0xFFFFFFFF)
    IO接口C_写(基址, 寄存器 + 1, (值 >> 32) & 0xFFFFFFFF)
    读_写重定向次数 = 读_写重定向次数 + 1
}

定义 可变 读_读取次数 = 0
定义 可变 读_写入次数 = 0
定义 可变 读_写重定向次数 = 0
定义 可变 读_读重定向次数 = 0
定义 可变 读_屏蔽次数 = 0
定义 可变 读_解屏蔽次数 = 0
定义 可变 读_配置次数 = 0
定义 可变 读_错误数 = 0
定义 可变 IO接口C_已初始化_读 = 假

定义 可变 GSI触发计数 = []
定义 可变 GSI触发_已初始化 = 假

// IO APIC初始化

函数 IO接口C_读_初始化() {
    如果 (IO接口C_已初始化_读 == 真) { 返回 错误_已存在 }
    // 初始化GSI触发计数
    GSI触发计数 = []
    定义 可变 i = 0
    当 (i < 最大GSI) {
        追加(GSI触发计数, 0)
        i = i + 1
    }
    GSI触发_已初始化 = 真
    读_读取次数 = 0
    读_写入次数 = 0
    读_写重定向次数 = 0
    读_读重定向次数 = 0
    读_屏蔽次数 = 0
    读_解屏蔽次数 = 0
    读_配置次数 = 0
    读_错误数 = 0
    IO接口C_已初始化_读 = 真
    打印("[IO APIC读] 初始化完成")
    返回 0
}

// IO APIC信息查询

函数 IO接口C_获取ID(基址) {
    返回 (IO接口C_读(基址, IO接口C_REG_ID) >> 24) & 0x0F
}

函数 IO接口C_获取版本(基址) {
    返回 IO接口C_读(基址, IO接口C_REG_VER) & 0xFF
}

函数 IO接口C_获取最大重定向(基址) {
    返回 ((IO接口C_读(基址, IO接口C_REG_VER) >> 16) & 0xFF) + 1
}

函数 IO接口C_获取仲裁ID(基址) {
    返回 (IO接口C_读(基址, IO接口C_REG_ARB) >> 24) & 0x0F
}

// 重定向表条目解析

函数 IO接口C_重定向_获取向量(值) { 返回 值 & 0xFF }
函数 IO接口C_重定向_获取投递模式(值) { 返回 (值 >> 8) & 0x07 }
函数 IO接口C_重定向_是逻辑目标(值) { 返回 (值 & IO接口C_逻辑目标) != 0 }
函数 IO接口C_重定向_是电平触发(值) { 返回 (值 & IO接口C_电平触发) != 0 }
函数 IO接口C_重定向_是低电平有效(值) { 返回 (值 & IO接口C_低电平有效) != 0 }
函数 IO接口C_重定向_已屏蔽(值) { 返回 (值 & IO接口C_屏蔽) != 0 }
函数 IO接口C_重定向_获取目标(值) { 返回 (值 >> 56) & 0xFF }

函数 IO接口C_重定向_投递模式名(模式) {
    如果 (模式 == 0) { 返回 "固定" }
    如果 (模式 == 1) { 返回 "最低优先级" }
    如果 (模式 == 2) { 返回 "SMI" }
    如果 (模式 == 4) { 返回 "NMI" }
    如果 (模式 == 5) { 返回 "INIT" }
    如果 (模式 == 7) { 返回 "ExtINT" }
    返回 "未知"
}

// GSI到IO APIC映射

函数 IO接口C_查找(GSI号) {
    // 返回管理该GSI的IO APIC索引, -1=未找到
    定义 可变 i = 0
    当 (i < IO接口C数量) {
        定义 信息 = IO接口C列表[i]
        如果 (GSI号 >= 信息.GSI起始 && GSI号 <= 信息.GSI结束) {
            返回 i
        }
        i = i + 1
    }
    返回 0 - 1
}

函数 IO接口C_GSI到引脚(GSI号) {
    定义 索引 = IO接口C_查找(GSI号)
    如果 (索引 < 0) { 返回 0 - 1 }
    返回 GSI号 - IO接口C列表[索引].GSI起始
}

// 屏蔽/解屏蔽

函数 IO接口C_屏蔽GSI(GSI号) {
    如果 (GSI号 >= 最大GSI) { 返回 错误_无效参数 }
    定义 索引 = IO接口C_查找(GSI号)
    如果 (索引 < 0) { 返回 错误_不存在 }
    定义 信息 = IO接口C列表[索引]
    定义 引脚 = GSI号 - 信息.GSI起始
    定义 当前 = IO接口C_读重定向(信息.基址, 引脚)
    IO接口C_写重定向(信息.基址, 引脚, 当前 | IO接口C_屏蔽)
    GSI路由表[GSI号].已屏蔽 = 真
    读_屏蔽次数 = 读_屏蔽次数 + 1
    返回 0
}

函数 IO接口C_解屏蔽GSI(GSI号) {
    如果 (GSI号 >= 最大GSI) { 返回 错误_无效参数 }
    定义 索引 = IO接口C_查找(GSI号)
    如果 (索引 < 0) { 返回 错误_不存在 }
    定义 信息 = IO接口C列表[索引]
    定义 引脚 = GSI号 - 信息.GSI起始
    定义 当前 = IO接口C_读重定向(信息.基址, 引脚)
    IO接口C_写重定向(信息.基址, 引脚, 当前 & ~IO接口C_屏蔽)
    GSI路由表[GSI号].已屏蔽 = 假
    读_解屏蔽次数 = 读_解屏蔽次数 + 1
    返回 0
}

函数 IO接口C_GSI已屏蔽(GSI号) {
    如果 (GSI号 >= 最大GSI) { 返回 真 }
    返回 GSI路由表[GSI号].已屏蔽
}

// GSI触发记录

函数 IO接口C_记录触发(GSI号) {
    如果 (GSI触发_已初始化 == 真 && GSI号 < 最大GSI) {
        设置(GSI触发计数, GSI号, GSI触发计数[GSI号] + 1)
    }
}

函数 IO接口C_获取触发计数(GSI号) {
    如果 (GSI触发_已初始化 == 假 || GSI号 >= 最大GSI) { 返回 0 }
    返回 GSI触发计数[GSI号]
}

// ISA IRQ名称

函数 IO接口C_ISA名(irq) {
    如果 (irq == ISA_IRQ_定时器) { 返回 "PIT定时器" }
    如果 (irq == ISA_IRQ_键盘) { 返回 "PS2键盘" }
    如果 (irq == ISA_IRQ_级联) { 返回 "级联" }
    如果 (irq == ISA_IRQ_COM2) { 返回 "COM2" }
    如果 (irq == ISA_IRQ_COM1) { 返回 "COM1" }
    如果 (irq == ISA_IRQ_软盘) { 返回 "软盘" }
    如果 (irq == ISA_IRQ_并口) { 返回 "并口" }
    如果 (irq == ISA_IRQ_RTC) { 返回 "RTC" }
    如果 (irq == ISA_IRQ_鼠标) { 返回 "PS2鼠标" }
    如果 (irq == ISA_IRQ_FPU) { 返回 "FPU" }
    如果 (irq == ISA_IRQ_主IDE) { 返回 "主IDE" }
    如果 (irq == ISA_IRQ_从IDE) { 返回 "从IDE" }
    返回 "IRQ" + 转字符串(irq)
}

// AI基因: 中断路由优化建议

函数 IO接口C_AI_路由建议() {
    // 分析GSI触发频率, 建议重新分配到不同CPU以均衡负载
    如果 (GSI触发_已初始化 == 假) { 返回 [] }
    定义 可变 建议 = []
    // 找出最热的5个GSI
    定义 可变 n = 0
    当 (n < 5) {
        定义 可变 最大 = 0
        定义 可变 最大GSI = 0 - 1
        定义 可变 i = 0
        当 (i < 最大GSI) {
            如果 (GSI触发计数[i] > 最大) {
                定义 可变 已有 = 假
                定义 可变 j = 0
                当 (j < 计数(建议)) {
                    如果 (建议[j][0] == i) { 已有 = 真 }
                    j = j + 1
                }
                如果 (已有 == 假) {
                    最大 = GSI触发计数[i]
                    最大GSI = i
                }
            }
            i = i + 1
        }
        如果 (最大GSI >= 0 && 最大 > 0) {
            追加(建议, [最大GSI, 最大, GSI路由表[最大GSI].目标CPU])
        }
        n = n + 1
    }
    返回 建议
}

// dump

函数 IO接口C_dump_重定向表(基址, 最大条目) {
    打印("[IO APIC 重定向表] ──────────────────")
    定义 可变 i = 0
    当 (i < 最大条目) {
        定义 值 = IO接口C_读重定向(基址, i)
        如果 (IO接口C_重定向_已屏蔽(值) == 假 || IO接口C_重定向_获取向量(值) != 0) {
            打印("  [" + 转字符串(i) + "] 向量=" + 转字符串(IO接口C_重定向_获取向量(值)) +
                 " 模式=" + IO接口C_重定向_投递模式名(IO接口C_重定向_获取投递模式(值)) +
                 " 触发=" + (IO接口C_重定向_是电平触发(值) ? "电平" : "边沿") +
                 " 目标=" + 转字符串(IO接口C_重定向_获取目标(值)) +
                 " 屏蔽=" + 转字符串(IO接口C_重定向_已屏蔽(值)))
        }
        i = i + 1
    }
    打印("[IO APIC 重定向表] ──────────────────")
}

函数 IO接口C_dump() {
    打印("[IO APIC dump] ──────────────────")
    打印("  数量: " + 转字符串(IO接口C数量))
    定义 可变 i = 0
    当 (i < IO接口C数量) {
        定义 信息 = IO接口C列表[i]
        打印("  [" + 转字符串(i) + "] 基址=0x" + 转字符串(信息.基址) +
             " ID=" + 转字符串(信息.ID) + " 版本=" + 转字符串(信息.版本) +
             " 重定向=" + 转字符串(信息.最大重定向) +
             " GSI=" + 转字符串(信息.GSI起始) + "-" + 转字符串(信息.GSI结束))
        i = i + 1
    }
    打印("  已配置GSI数: " + 转字符串(IO接口C_已配置GSI数()))
    打印("[IO APIC dump] ──────────────────")
}

函数 IO接口C_已配置GSI数() {
    定义 可变 数量 = 0
    定义 可变 i = 0
    当 (i < 最大GSI) {
        如果 (GSI路由表[i].已配置 == 真) { 数量 = 数量 + 1 }
        i = i + 1
    }
    返回 数量
}

// 完整统计 (≥15个指标)

函数 IO接口C_读_完整统计() {
    定义 可变 已屏蔽数 = 0
    定义 可变 电平触发数 = 0
    定义 可变 最热GSI = 0
    定义 可变 最热计数 = 0
    定义 可变 i = 0
    当 (i < 最大GSI) {
        如果 (GSI路由表[i].已配置 == 真) {
            如果 (GSI路由表[i].已屏蔽 == 真) { 已屏蔽数 = 已屏蔽数 + 1 }
            如果 (GSI路由表[i].触发模式 == 1) { 电平触发数 = 电平触发数 + 1 }
        }
        如果 (GSI触发_已初始化 == 真 && GSI触发计数[i] > 最热计数) {
            最热计数 = GSI触发计数[i]
            最热GSI = i
        }
        i = i + 1
    }
    定义 统计 = 字典()
    字典设(统计, "已初始化", IO接口C_已初始化_读)
    字典设(统计, "IO APIC数量", IO接口C数量)
    字典设(统计, "已配置GSI", IO接口C_已配置GSI数())
    字典设(统计, "已屏蔽GSI", 已屏蔽数)
    字典设(统计, "电平触发数", 电平触发数)
    字典设(统计, "最热GSI", 最热GSI)
    字典设(统计, "最热触发数", 最热计数)
    字典设(统计, "最大GSI", 最大GSI)
    字典设(统计, "读取次数", 读_读取次数)
    字典设(统计, "写入次数", 读_写入次数)
    字典设(统计, "读重定向次数", 读_读重定向次数)
    字典设(统计, "写重定向次数", 读_写重定向次数)
    字典设(统计, "屏蔽次数", 读_屏蔽次数)
    字典设(统计, "解屏蔽次数", 读_解屏蔽次数)
    字典设(统计, "配置次数", 读_配置次数)
    字典设(统计, "错误数", 读_错误数)
    返回 统计
}

函数 IO接口C_读_打印统计() {
    定义 统计 = IO接口C_读_完整统计()
    打印("[IO APIC读] ═══════ 完整统计 ═══════")
    打印("  IO APIC数量:  " + 转字符串(字典取(统计, "IO APIC数量")))
    打印("  已配置GSI:    " + 转字符串(字典取(统计, "已配置GSI")))
    打印("  已屏蔽GSI:    " + 转字符串(字典取(统计, "已屏蔽GSI")))
    打印("  电平触发:     " + 转字符串(字典取(统计, "电平触发数")))
    打印("  最热GSI:      " + 转字符串(字典取(统计, "最热GSI")))
    打印("  最热触发:     " + 转字符串(字典取(统计, "最热触发数")))
    打印("  读取次数:     " + 转字符串(字典取(统计, "读取次数")))
    打印("  写入次数:     " + 转字符串(字典取(统计, "写入次数")))
    打印("  屏蔽操作:     " + 转字符串(字典取(统计, "屏蔽次数")))
    打印("  解屏蔽操作:   " + 转字符串(字典取(统计, "解屏蔽次数")))
    打印("  配置次数:     " + 转字符串(字典取(统计, "配置次数")))
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    打印("[IO APIC读] ═════════════════════════")
    返回 0
}

// 销毁

函数 IO接口C_读_销毁() {
    如果 (IO接口C_已初始化_读 == 假) { 返回 0 }
    GSI触发计数 = []
    GSI触发_已初始化 = 假
    IO接口C_已初始化_读 = 假
    打印("[IO APIC读] 已销毁")
    返回 0
}

// 与其他子系统的接口

函数 IO接口C_为IRQ子系统配置(GSI号, 向量号, 目标CPU) {
    读_配置次数 = 读_配置次数 + 1
    返回 IO接口C_配置GSI(GSI号, 向量号, 0, 0, 目标CPU)
}

函数 IO接口C_为PIC切换禁用所有() {
    // 切换到APIC模式时屏蔽所有IO APIC条目
    定义 可变 i = 0
    当 (i < IO接口C数量) {
        定义 信息 = IO接口C列表[i]
        定义 可变 j = 0
        当 (j < 信息.最大重定向) {
            IO接口C_写重定向(信息.基址, j, IO接口C_屏蔽)
            j = j + 1
        }
        i = i + 1
    }
    返回 0
}

函数 IO接口C_为调度器提供路由信息() {
    返回 IO接口C_AI_路由建议()
}

函数 IO接口C_为procfs提供信息() {
    返回 [IO接口C数量, IO接口C_已配置GSI数(), 最大GSI]
}

函数 IO接口C_为电源管理挂起() {
    打印("[IO接口C] 挂起: 保存重定向表")
    返回 读_读取次数 + 读_写入次数
}

函数 IO接口C_重置统计() {
    读_读取次数 = 0
    读_写入次数 = 0
    读_写重定向次数 = 0
    读_读重定向次数 = 0
    读_屏蔽次数 = 0
    读_解屏蔽次数 = 0
    读_配置次数 = 0
    读_错误数 = 0
    如果 (GSI触发_已初始化 == 真) {
        定义 可变 i = 0
        当 (i < 最大GSI) { 设置(GSI触发计数, i, 0); i = i + 1 }
    }
    打印("[IO APIC读] 统计已重置")
    返回 0
}

函数 IO接口C_配置GSI(GSI号, 向量号, 触发模式, 极性, 目标CPU) {
    如果 (GSI号 >= 最大GSI) { 返回 -1 }
    定义 低32 = 向量号 | (触发模式 << 15) | (极性 << 13)
    定义 高32 = 目标CPU << 24
    内存_写32(IO接口C基址, 0x10 + GSI号 * 2)
    内存_写32(IO接口C基址 + 0x10, 低32)
    内存_写32(IO接口C基址, 0x10 + GSI号 * 2 + 1)
    内存_写32(IO接口C基址 + 0x10, 高32)
    读_配置次数 = 读_配置次数 + 1
    返回 0
}

函数 IO接口C_为AI提供路由模式() {
    返回 IO接口C_AI_路由建议()
}

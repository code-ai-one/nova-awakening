导入("../../基础.nova")

// Nova标准库 — 归并排序 (Merge Sort, 0)
// 稳定排序, O(n log n) 时间复杂度

函数 归并排序_归并排序(列表) {
    定义 n = 计数(列表)
    如果 (n <= 1) { 返回 列表 }
    定义 中 = n / 2
    // 分割
    定义 可变 左 = []
    定义 可变 右 = []
    定义 可变 i = 0
    当 (i < 中) {
        追加(左, 列表[i])
        i = i + 1
    }
    当 (i < n) {
        追加(右, 列表[i])
        i = i + 1
    }
    // 递归排序
    左 = 归并排序_归并排序(左)
    右 = 归并排序_归并排序(右)
    // 合并
    返回 归并排序_合并(左, 右)
}

函数 归并排序_合并(左, 右) {
    定义 可变 结果 = []
    定义 可变 i = 0
    定义 可变 j = 0
    当 (i < 计数(左) 且 j < 计数(右)) {
        如果 (左[i] <= 右[j]) {
            追加(结果, 左[i])
            i = i + 1
        } 否则 {
            追加(结果, 右[j])
            j = j + 1
        }
    }
    当 (i < 计数(左)) {
        追加(结果, 左[i])
        i = i + 1
    }
    当 (j < 计数(右)) {
        追加(结果, 右[j])
        j = j + 1
    }
    返回 结果
}

// 带自定义比较器的归并排序
函数 归并排序比较(列表, 比较器) {
    定义 n = 计数(列表)
    如果 (n <= 1) { 返回 列表 }
    定义 中 = n / 2
    定义 可变 左 = []
    定义 可变 右 = []
    定义 可变 i = 0
    当 (i < 中) { 追加(左, 列表[i]) i = i + 1 }
    当 (i < n) { 追加(右, 列表[i]) i = i + 1 }
    左 = 归并排序比较(左, 比较器)
    右 = 归并排序比较(右, 比较器)
    返回 合并比较(左, 右, 比较器)
}

函数 合并比较(左, 右, 比较器) {
    定义 可变 结果 = []
    定义 可变 i = 0
    定义 可变 j = 0
    当 (i < 计数(左) 且 j < 计数(右)) {
        如果 (比较器(左[i], 右[j]) <= 0) {
            追加(结果, 左[i])
            i = i + 1
        } 否则 {
            追加(结果, 右[j])
            j = j + 1
        }
    }
    当 (i < 计数(左)) { 追加(结果, 左[i]) i = i + 1 }
    当 (j < 计数(右)) { 追加(结果, 右[j]) j = j + 1 }
    返回 结果
}

// 插入排序 (小数组高效, 0, 0)
函数 插入排序(列表, _扩2, _扩3) {
    定义 n = 计数(列表)
    定义 可变 i = 1
    当 (i < n) {
        定义 键 = 列表[i]
        定义 可变 j = i - 1
        当 (j >= 0 且 列表[j] > 键) {
            列表[j + 1] = 列表[j]
            j = j - 1
        }
        列表[j + 1] = 键
        i = i + 1
    }
    返回 列表
}

// 选择排序
函数 选择排序(列表, _扩2) {
    定义 n = 计数(列表)
    定义 可变 i = 0
    当 (i < n - 1) {
        定义 可变 最小idx = i
        定义 可变 j = i + 1
        当 (j < n) {
            如果 (列表[j] < 列表[最小idx]) { 最小idx = j }
            j = j + 1
        }
        如果 (最小idx != i) {
            定义 暂存 = 列表[i]
            列表[i] = 列表[最小idx]
            列表[最小idx] = 暂存
        }
        i = i + 1
    }
    返回 列表
}

// 冒泡排序
函数 冒泡排序(列表, _扩2, _扩3) {
    定义 n = 计数(列表)
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 已交换 = 假
        定义 可变 j = 0
        当 (j < n - i - 1) {
            如果 (列表[j] > 列表[j + 1]) {
                定义 暂存 = 列表[j]
                列表[j] = 列表[j + 1]
                列表[j + 1] = 暂存
                已交换 = 真
            }
            j = j + 1
        }
        如果 (已交换 == 假) { 返回 列表 }
        i = i + 1
    }
    返回 列表
}

// 计数排序 (适用于小范围整数, 0, 0)
函数 计数排序(列表, 最大值, _扩3) {
    定义 可变 计数表 = []
    定义 可变 i = 0
    当 (i <= 最大值) {
        追加(计数表, 0)
        i = i + 1
    }
    // 计数
    i = 0
    当 (i < 计数(列表)) {
        计数表[列表[i]] = 计数表[列表[i]] + 1
        i = i + 1
    }
    // 重建
    定义 可变 结果 = []
    i = 0
    当 (i <= 最大值) {
        定义 可变 j = 0
        当 (j < 计数表[i]) {
            追加(结果, i)
            j = j + 1
        }
        i = i + 1
    }
    返回 结果
}

// 二分查找
函数 归并排序_二分查找(排序列表, 目标) {
    定义 可变 左 = 0
    定义 可变 右 = 计数(排序列表) - 1
    当 (左 <= 右) {
        定义 中 = (左 + 右) / 2
        如果 (排序列表[中] == 目标) { 返回 中 }
        如果 (排序列表[中] < 目标) { 左 = 中 + 1 }
        否则 { 右 = 中 - 1 }
    }
    返回 -1
}

// 下界 (第一个 >= 目标的位置, 0)
函数 下界(排序列表, 目标) {
    定义 可变 左 = 0
    定义 可变 右 = 计数(排序列表)
    当 (左 < 右) {
        定义 中 = (左 + 右) / 2
        如果 (排序列表[中] < 目标) { 左 = 中 + 1 }
        否则 { 右 = 中 }
    }
    返回 左
}

// 上界 (第一个 > 目标的位置, 0)
函数 上界(排序列表, 目标) {
    定义 可变 左 = 0
    定义 可变 右 = 计数(排序列表)
    当 (左 < 右) {
        定义 中 = (左 + 右) / 2
        如果 (排序列表[中] <= 目标) { 左 = 中 + 1 }
        否则 { 右 = 中 }
    }
    返回 左
}

// 自然归并排序(利用已排序子序列)
函数 自然归并(列表) {
    定义 可变 新列表 = []
    定义 n = 计数(列表)
    如果 (n <= 1) { 返回 列表 }
    // 检测自然有序段
    定义 可变 段起点 = [0]
    定义 可变 i = 1
    当 (i < n) {
        如果 (列表[i] < 列表[i - 1]) { 追加(段起点, i) }
        i = i + 1
    }
    追加(段起点, n)
    如果 (计数(段起点) == 2) { 返回 列表 }
    // 逐对合并相邻段
    定义 可变 当前 = 列表
    当 (计数(段起点) > 2) {
        定义 可变 新段 = [0]
        i = 0
        当 (i + 2 < 计数(段起点)) {
            定义 可变 合并 = 归并_合并段(当前, 段起点[i], 段起点[i + 1], 段起点[i + 2])
            定义 可变 j = 0
            当 (j < 计数(合并)) { 追加(新列表, 合并[j]) j = j + 1 }
            追加(新段, 计数(新列表))
            i = i + 2
        }
        如果 (i + 1 < 计数(段起点)) {
            定义 可变 j = 段起点[i]
            当 (j < 段起点[i + 1]) { 追加(新列表, 当前[j]) j = j + 1 }
            追加(新段, 计数(新列表))
        }
        当前 = 新列表
        段起点 = 新段
    }
    返回 当前
}

函数 归并_合并段(列表, 左起, 中间, 右终) {
    定义 可变 结果 = []
    定义 可变 i = 左起
    定义 可变 j = 中间
    当 (i < 中间 且 j < 右终) {
        如果 (列表[i] <= 列表[j]) { 追加(结果, 列表[i]) i = i + 1 }
        否则 { 追加(结果, 列表[j]) j = j + 1 }
    }
    当 (i < 中间) { 追加(结果, 列表[i]) i = i + 1 }
    当 (j < 右终) { 追加(结果, 列表[j]) j = j + 1 }
    返回 结果
}

// 有序检查
函数 是否已排序(列表) {
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        如果 (列表[i] < 列表[i - 1]) { 返回 假 }
        i = i + 1
    }
    返回 真
}



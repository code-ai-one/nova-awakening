// Nova标准库 — 终端渲染引擎
// ANSI 转义序列、颜色、光标、帧缓冲
// 支持 256色/TrueColor、盒绘制、进度条、表格

导入("../../基础.nova")

// ANSI 转义码
定义 转义符 = "\x1b["
定义 ESC_重置 = "\x1b[0m"

// 前景色 (标准8色)
函数 颜色_黑() { 返回 "\x1b[30m" }
函数 颜色_红() { 返回 "\x1b[31m" }
函数 颜色_绿() { 返回 "\x1b[32m" }
函数 颜色_黄() { 返回 "\x1b[33m" }
函数 颜色_蓝() { 返回 "\x1b[34m" }
函数 颜色_紫() { 返回 "\x1b[35m" }
函数 颜色_青() { 返回 "\x1b[36m" }
函数 颜色_白() { 返回 "\x1b[37m" }

// 亮色
函数 颜色_亮红() { 返回 "\x1b[91m" }
函数 颜色_亮绿() { 返回 "\x1b[92m" }
函数 颜色_亮黄() { 返回 "\x1b[93m" }
函数 颜色_亮蓝() { 返回 "\x1b[94m" }
函数 颜色_亮紫() { 返回 "\x1b[95m" }
函数 颜色_亮青() { 返回 "\x1b[96m" }

// 背景色
函数 背景_黑() { 返回 "\x1b[40m" }
函数 背景_红() { 返回 "\x1b[41m" }
函数 背景_绿() { 返回 "\x1b[42m" }
函数 背景_黄() { 返回 "\x1b[43m" }
函数 背景_蓝() { 返回 "\x1b[44m" }

// 256色
函数 颜色256_前景(n) { 返回 字符串拼接("\x1b[38;5;", 字符串拼接(终端_数到文(n), "m"))
}

函数 颜色256_背景(n) { 返回 字符串拼接("\x1b[48;5;", 字符串拼接(终端_数到文(n), "m"))
}

// TrueColor (24-bit)
函数 颜色RGB_前景(r, g, b) { 定义 可变 s = "\x1b[38;2;"
 s = 字符串拼接(s, 终端_数到文(r))
 s = 字符串拼接(s, ";")
 s = 字符串拼接(s, 终端_数到文(g))
 s = 字符串拼接(s, ";")
 s = 字符串拼接(s, 终端_数到文(b))
 s = 字符串拼接(s, "m")
 返回 s
}

函数 颜色RGB_背景(r, g, b) { 定义 可变 s = "\x1b[48;2;"
 s = 字符串拼接(s, 终端_数到文(r))
 s = 字符串拼接(s, ";")
 s = 字符串拼接(s, 终端_数到文(g))
 s = 字符串拼接(s, ";")
 s = 字符串拼接(s, 终端_数到文(b))
 s = 字符串拼接(s, "m")
 返回 s
}

// 文本样式
函数 样式_粗体() { 返回 "\x1b[1m" }
函数 样式_暗色() { 返回 "\x1b[2m" }
函数 样式_斜体() { 返回 "\x1b[3m" }
函数 样式_下划线() { 返回 "\x1b[4m" }
函数 样式_闪烁() { 返回 "\x1b[5m" }
函数 样式_反转() { 返回 "\x1b[7m" }
函数 样式_删除线() { 返回 "\x1b[9m" }
函数 样式_重置() { 返回 ESC_重置 }

// 组合样式
函数 终端_着色(文本, 颜色码) { 返回 字符串拼接(颜色码, 字符串拼接(文本, ESC_重置))
}

函数 终端_粗体文本(文本) { 返回 字符串拼接(样式_粗体(), 字符串拼接(文本, ESC_重置))
}

// 光标控制
函数 光标_上移(n) { 返回 字符串拼接("\x1b[", 字符串拼接(终端_数到文(n), "A")) }
函数 光标_下移(n) { 返回 字符串拼接("\x1b[", 字符串拼接(终端_数到文(n), "B")) }
函数 光标_右移(n) { 返回 字符串拼接("\x1b[", 字符串拼接(终端_数到文(n), "C")) }
函数 光标_左移(n) { 返回 字符串拼接("\x1b[", 字符串拼接(终端_数到文(n), "D")) }

函数 光标_定位(行, 列) { 定义 可变 s = "\x1b["
 s = 字符串拼接(s, 终端_数到文(行))
 s = 字符串拼接(s, ";")
 s = 字符串拼接(s, 终端_数到文(列))
 s = 字符串拼接(s, "H")
 返回 s
}

函数 光标_保存() { 返回 "\x1b[s" }
函数 光标_恢复() { 返回 "\x1b[u" }
函数 光标_隐藏() { 返回 "\x1b[?25l" }
函数 光标_显示() { 返回 "\x1b[?25h" }

// 屏幕控制
函数 屏幕_清除() { 返回 "\x1b[2J\x1b[H" }
函数 屏幕_清行() { 返回 "\x1b[2K" }
函数 屏幕_清到行尾() { 返回 "\x1b[K" }
函数 屏幕_清到行首() { 返回 "\x1b[1K" }
函数 屏幕_滚上(n) { 返回 字符串拼接("\x1b[", 字符串拼接(终端_数到文(n), "S")) }
函数 屏幕_滚下(n) { 返回 字符串拼接("\x1b[", 字符串拼接(终端_数到文(n), "T")) }

// 帧缓冲 (Frame Buffer)
// 型: [宽, 高, 字符缓冲, 颜色缓冲, 脏标记列表]

函数 帧缓冲_创建(宽, 高) { 定义 可变 字符 = []
 定义 可变 颜色 = []
 定义 可变 脏 = []
 定义 总 = 宽 * 高
 定义 可变 i = 0
 当 (i < 总) {
 追加(字符, " ")
 追加(颜色, "")
 追加(脏, 真)
 i = i + 1
 }
 返回 [宽, 高, 字符, 颜色, 脏]
}

函数 帧缓冲_设(fb, x, y, 字符, 颜色码) {
    如果 (x < 0 或 x >= fb[0] 或 y < 0 或 y >= fb[1]) { 返回
}
 定义 索引 = y * fb[0] + x
 fb[2][索引] = 字符
 fb[3][索引] = 颜色码
 fb[4][索引] = 真
}

函数 帧缓冲_取(fb, x, y) {
    如果 (x < 0 或 x >= fb[0] 或 y < 0 或 y >= fb[1]) { 返回 " "
}
 返回 fb[2][y * fb[0] + x]
}

函数 帧缓冲_清除(fb) { 定义 总 = fb[0] * fb[1]
 定义 可变 i = 0
 当 (i < 总) {
 fb[2][i] = " "
 fb[3][i] = ""
 fb[4][i] = 真
 i = i + 1
 }
}

函数 帧缓冲_写文本(fb, x, y, 文本, 颜色码) { 定义 n = 计数(文本)
 定义 可变 i = 0
 当 (i < n) {
 帧缓冲_设(fb, x + i, y, 子串(文本, i, 1), 颜色码)
 i = i + 1
 }
}

函数 帧缓冲_画矩形(fb, x, y, 宽, 高, 字符, 颜色码) { 定义 可变 导数Y = 0
 当 (导数Y < 高) { 定义 可变 导数 = 0
 当 (导数 < 宽) { 如果 (导数Y == 0 或 导数Y == 高 - 1 或 导数 == 0 或 导数 == 宽 - 1) {
 帧缓冲_设(fb, x + 导数, y + 导数Y, 字符, 颜色码)
 }
 导数 = 导数 + 1
 }
 导数Y = 导数Y + 1
 }
}

函数 帧缓冲_填充矩形(fb, x, y, 宽, 高, 字符, 颜色码) { 定义 可变 导数Y = 0
 当 (导数Y < 高) { 定义 可变 导数 = 0
 当 (导数 < 宽) {
 帧缓冲_设(fb, x + 导数, y + 导数Y, 字符, 颜色码)
 导数 = 导数 + 1
 }
 导数Y = 导数Y + 1
 }
}

函数 帧缓冲_画线(fb, x1, y1, x2, y2, 字符, 颜色码) {
 // Bresenham 直线算法
 定义 可变 导数 = x2 - x1
 定义 可变 导数Y = y2 - y1
 如果 (导数 < 0) { 导数 = 0 - 导数 }
 如果 (导数Y < 0) { 导数Y = 0 - 导数Y }
 定义 可变 sx = 1
 定义 可变 sy = 1
 如果 (x1 > x2) { sx = -1 }
 如果 (y1 > y2) { sy = -1 }
 定义 可变 err = 导数 - 导数Y
 定义 可变 cx = x1
 定义 可变 cy = y1
 当 (_线完 == 假) {
 帧缓冲_设(fb, cx, cy, 字符, 颜色码)
 如果 (cx == x2 且 cy == y2) { _线完 = 真 } 否则 {
 定义 e2 = 2 * err
 如果 (e2 > 0 - 导数Y) { err = err - 导数Y cx = cx + sx }
 如果 (e2 < 导数) { err = err + 导数 cy = cy + sy }
 } }
}

// 渲染: 只输出脏区域 (差量渲染)
函数 帧缓冲_渲染(fb) { 定义 可变 输出 = ""
 定义 可变 y = 0
 当 (y < fb[1]) { 定义 可变 x = 0
 定义 可变 行有脏 = 假
 当 (x < fb[0] 且 行有脏 == 假) { 如果 (fb[4][y * fb[0] + x]) { 行有脏 = 真 }
 x = x + 1
 }
 如果 (行有脏) {
 输出 = 字符串拼接(输出, 光标_定位(y + 1, 1))
 x = 0
 当 (x < fb[0]) { 定义 索引 = y * fb[0] + x
 定义 颜色码 = fb[3][索引]
 如果 (计数(颜色码) > 0) {
 输出 = 字符串拼接(输出, 颜色码)
 }
 输出 = 字符串拼接(输出, fb[2][索引])
 如果 (计数(颜色码) > 0) {
 输出 = 字符串拼接(输出, ESC_重置)
 }
 fb[4][索引] = 假
 x = x + 1
 }
 }
 y = y + 1
 }
 返回 输出
}

// 全量渲染
函数 帧缓冲_全渲染(fb) { 定义 总 = fb[0] * fb[1]
 定义 可变 i = 0
 当 (i < 总) { fb[4][i] = 真 i = i + 1 }
 返回 帧缓冲_渲染(fb)
}

// 盒绘制字符
函数 盒_单线(宽, 高) { 定义 可变 结果 = ""
 // 顶部
 结果 = 字符串拼接(结果, "+")
 定义 可变 i = 0
 当 (i < 宽 - 2) { 结果 = 字符串拼接(结果, "-") i = i + 1 }
 结果 = 字符串拼接(结果, "+\n")
 // 中间
 定义 可变 y = 0
 当 (y < 高 - 2) {
 结果 = 字符串拼接(结果, "|")
 i = 0
 当 (i < 宽 - 2) { 结果 = 字符串拼接(结果, " ") i = i + 1 }
 结果 = 字符串拼接(结果, "|\n")
 y = y + 1
 }
 // 底部
 结果 = 字符串拼接(结果, "+")
 i = 0
 当 (i < 宽 - 2) { 结果 = 字符串拼接(结果, "-") i = i + 1 }
 结果 = 字符串拼接(结果, "+\n")
 返回 结果
}

// 进度条
函数 终端_进度条_渲染(当前, 总数, 宽度, 填充字符, 空字符) {
    如果 (总数 <= 0) { 返回 "[ERROR]"
}
 定义 可变 比例 = 当前 * 宽度 / 总数
 如果 (比例 > 宽度) { 比例 = 宽度 }
 定义 百分比 = 当前 * 100 / 总数
 定义 可变 条 = "["
 定义 可变 i = 0
 当 (i < 宽度) { 如果 (i < 比例) { 条 = 字符串拼接(条, 填充字符) }
 否则 { 条 = 字符串拼接(条, 空字符) }
 i = i + 1
 }
 条 = 字符串拼接(条, "] ")
 条 = 字符串拼接(条, 终端_数到文(百分比))
 条 = 字符串拼接(条, "%")
 返回 条
}

// 表格渲染
函数 表格_渲染(表头, 数据, 列宽) { 定义 列数 = 计数(表头)
    定义 可变 ri = 0
 // 顶部边框
 定义 可变 结果 = "+"
 定义 可变 ci = 0
 当 (ci < 列数) { 定义 可变 j = 0
 当 (j < 列宽) { 结果 = 字符串拼接(结果, "-")
 j = j + 1 }
 结果 = 字符串拼接(结果, "+")
 ci = ci + 1
 }
 结果 = 字符串拼接(结果, "\n|")
 // 表头
 ci = 0
 当 (ci < 列数) { 定义 文本 = 表头[ci]
 结果 = 字符串拼接(结果, 终端_填充(文本, 列宽))
 结果 = 字符串拼接(结果, "|")
 ci = ci + 1
 }
 结果 = 字符串拼接(结果, "\n+")
 ci = 0
 当 (ci < 列数) { 定义 可变 j2 = 0
 当 (j2 < 列宽) { 结果 = 字符串拼接(结果, "=")
 j2 = j2 + 1 }
 结果 = 字符串拼接(结果, "+")
 ci = ci + 1
 }
 // 数据行
 当 (ri < 计数(数据)) {
 结果 = 字符串拼接(结果, "\n|")
 ci = 0
 当 (ci < 列数) { 如果 (ci < 计数(数据[ri])) {
 结果 = 字符串拼接(结果, 终端_填充(转字符串(数据[ri][ci]), 列宽))
 } 否则 {
 结果 = 字符串拼接(结果, 终端_填充("", 列宽))
 }
 结果 = 字符串拼接(结果, "|")
 ci = ci + 1
 }
 ri = ri + 1
 }
 // 底部边框
 结果 = 字符串拼接(结果, "\n+")
 ci = 0
 当 (ci < 列数) { 定义 可变 j3 = 0
 当 (j3 < 列宽) { 结果 = 字符串拼接(结果, "-")
 j3 = j3 + 1 }
 结果 = 字符串拼接(结果, "+")
 ci = ci + 1
 }
 返回 结果
}

// 火花线图 (Sparkline)
函数 火花线(数据) { 定义 块 = "▁▂▃▄▅▆▇█"
 定义 n = 计数(数据)
 定义 可变 最小 = 数据[0]
 定义 可变 最大 = 数据[0]
 定义 可变 i = 1
 当 (i < n) { 如果 (数据[i] < 最小) { 最小 = 数据[i] }
 如果 (数据[i] > 最大) { 最大 = 数据[i] }
 i = i + 1
 }
 定义 可变 范围 = 最大 - 最小
 如果 (范围 == 0) { 范围 = 1 }
 定义 可变 结果 = ""
 i = 0
 当 (i < n) { 定义 可变 级别 = (数据[i] - 最小) * 7 / 范围
 如果 (级别 > 7) { 级别 = 7 }
 结果 = 字符串拼接(结果, 子串(块, 级别, 1))
 i = i + 1
 }
 返回 结果
}

// 水平柱状图
函数 柱状图(标签列表, 数据, 宽度, 字符) { 定义 n = 计数(数据)
 定义 可变 最大 = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (数据[i] > 最大) { 最大 = 数据[i] }
 i = i + 1
 }
 如果 (最大 == 0) { 最大 = 1 }
 定义 可变 结果 = ""
 i = 0
 当 (i < n) { 定义 条长 = 数据[i] * 宽度 / 最大
 结果 = 字符串拼接(结果, 终端_填充(标签列表[i], 10))
 结果 = 字符串拼接(结果, " |")
 定义 可变 j = 0
 当 (j < 条长) { 结果 = 字符串拼接(结果, 字符)
 j = j + 1 }
 结果 = 字符串拼接(结果, " ")
 结果 = 字符串拼接(结果, 终端_数到文(数据[i]))
 结果 = 字符串拼接(结果, "\n")
 i = i + 1
 }
 返回 结果
}

// 内部工具

函数 终端_填充(文本, 宽度) { 定义 可变 r = 文本
 当 (计数(r) < 宽度) { r = 字符串拼接(r, " ") }
 返回 r
}

函数 终端_数到文(n) {
    如果 (n == 0) { 返回 "0"
}
 定义 可变 v = n
 定义 可变 负 = 假
 如果 (v < 0) { 负 = 真 v = 0 - v }
 定义 可变 r = ""
 当 (v > 0) { r = 字符串拼接(子串("0123456789", v % 10, 1), r) v = v / 10 }
 如果 (负) { r = 字符串拼接("-", r) }
 返回 r
}

定义 可变 _终端_输出行数 = 0
定义 可变 _终端_输入次数 = 0
定义 可变 _终端_颜色使用 = 0

函数 终端_记录输出() { _终端_输出行数 = _终端_输出行数 + 1 }
函数 终端_记录输入() { _终端_输入次数 = _终端_输入次数 + 1 }
函数 终端_记录颜色() { _终端_颜色使用 = _终端_颜色使用 + 1 }

函数 终端_交互度评估() {
    如果 (_终端_输入次数 == 0 且 _终端_输出行数 == 0) { 返回 "无活动"
}
 如果 (_终端_输入次数 == 0) { 返回 "纯输出模式" }
 定义 比 = _终端_输出行数 / _终端_输入次数
 如果 (比 > 10) { 返回 "输出密集型" }
 如果 (比 > 1) { 返回 "正常交互" }
 返回 "输入密集型"
}

函数 终端_UI丰富度() {
    如果 (_终端_颜色使用 == 0) { 返回 "纯文本(建议添加颜色)"
}
 如果 (_终端_颜色使用 > 100) { 返回 "丰富彩色UI" }
 返回 "基础彩色UI"
}

函数 终端_性能评估() {
    如果 (_终端_输出行数 > 10000) { 返回 "大量输出: 考虑分页或缓冲"
}
 如果 (_终端_输出行数 > 1000) { 返回 "中等输出量" }
 返回 "输出量正常"
}

函数 终端_输出效率() {
    如果 (_终端_输出行数 == 0) { 返回 0
}
 如果 (_终端_颜色使用 == 0) { 返回 50 }
 返回 70 + _终端_颜色使用 * 30 / _终端_输出行数
}

函数 终端_推荐宽度() { 返回 80 }
函数 终端_推荐高度() { 返回 24 }

函数 终端_是否需要分页(行数) {
    如果 (行数 > 终端_推荐高度()) { 返回 真
}
 返回 假
}

函数 终端_进度条(当前, 总数, 宽度) {
    如果 (总数 == 0) { 返回 ""
}
 定义 完成 = 当前 * 宽度 / 总数
 定义 可变 条 = "["
 定义 可变 i = 0
 当 (i < 宽度) { 如果 (i < 完成) { 条 = 字符串拼接(条, "█") }
 否则 { 条 = 字符串拼接(条, "░") }
 i = i + 1
 }
 条 = 字符串拼接(条, "]")
 返回 条
}

函数 终端_百分比文本(当前, 总数) {
    如果 (总数 == 0) { 返回 "0%"
}
 定义 百分比 = 当前 * 100 / 总数
 返回 字符串拼接(转字符串(百分比), "%")
}

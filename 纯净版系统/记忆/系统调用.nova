// NovaOS 管道
// 功能: 匿名管道、环形缓冲、阻塞读写、pipe2系统调用

定义 管道_默认缓冲大小   = 65536   // 64KB (Nova默认)
定义 管道_最小缓冲大小   = 4096
定义 管道_最大缓冲大小   = 1048576 // 1MB
定义 管道_缓冲页数       = 16      // 16个4K页
定义 管道_原子写大小     = 4096    // PIPE_BUF

定义 O_NONBLOCK   = 0x0800
定义 O_CLOEXEC    = 0x80000

// 管道缓冲页

结构 管道缓冲 {
    页,    // 指针<物理页>
    偏移,
    长度,
}

// 管道Nova文件节点信息

结构 管道信息 {
    缓冲区,    // 数组<管道缓冲, 16>
    缓冲区数,
    头,    // u32 写位置(生产者)
    尾,    // u32 读位置(消费者)
    最大缓冲,
    读者数,
    写者数,
    等待数,
    读等待队列,    // 等待队列头
    写等待队列,    // 等待队列头
    锁,    // 互斥锁
    标志,
}

// pipe/pipe2 系统调用

函数 系统调用_pipe(文件描述符数组) {
    返回 系统调用_pipe2(文件描述符数组, 0)
}

函数 系统调用_pipe2(文件描述符数组, 标志) {
    // 创建管道Nova文件节点信息
    定义 可变 管道 = 分配内存(大小(管道信息))
    如果 (管道 == 空) { 返回 错误码_内存不足 }

    管道.缓冲区数 = 管道_缓冲页数
    管道.头 = 0
    管道.尾 = 0
    管道.最大缓冲 = 管道_缓冲页数
    管道.读者数 = 1
    管道.写者数 = 1
    管道.等待数 = 0
    管道.读等待队列 = 等待队列_创建()
    管道.写等待队列 = 等待队列_创建()
    管道.锁 = 互斥锁_创建()
    管道.标志 = 标志

    // 初始化缓冲页
    定义 可变 i = 0
    当 (i < 管道_缓冲页数) {
        管道.缓冲区[i].页 = 空
        管道.缓冲区[i].偏移 = 0
        管道.缓冲区[i].长度 = 0
        i = i + 1
    }

    // 创建读端文件
    定义 读fd = 文件描述符_分配()
    如果 (读fd < 0) {
        释放内存(管道)
        返回 错误码_文件过多
    }
    定义 可变 读文件 = 文件对象_创建(空, 空, 0)
    读文件.私有数据 = 管道
    读文件.操作 = 管道_读操作表()
    读文件.标志 = O_RDONLY
    如果 (标志 & O_NONBLOCK) { 读文件.标志 = 读文件.标志 | O_NONBLOCK }
    文件描述符_安装(读fd, 读文件)

    // 创建写端文件
    定义 写fd = 文件描述符_分配()
    如果 (写fd < 0) {
        文件描述符_释放(读fd)
        释放内存(管道)
        返回 错误码_文件过多
    }
    定义 可变 写文件 = 文件对象_创建(空, 空, 0)
    写文件.私有数据 = 管道
    写文件.操作 = 管道_写操作表()
    写文件.标志 = O_WRONLY
    如果 (标志 & O_NONBLOCK) { 写文件.标志 = 写文件.标志 | O_NONBLOCK }
    文件描述符_安装(写fd, 写文件)

    // CLOEXEC
    如果 (标志 & O_CLOEXEC) {
        文件描述符_设置标志(读fd, FD_CLOEXEC)
        文件描述符_设置标志(写fd, FD_CLOEXEC)
    }

    文件描述符数组[0] = 读fd
    文件描述符数组[1] = 写fd

    返回 0
}

// §3 pipe2系统调用(带标志)

函数 sys_pipe2(文件描述符数组, 标志) {
    // pipe2与pipe相同, 但支持O_NONBLOCK和O_CLOEXEC标志
    定义 结果 = sys_pipe(文件描述符数组)
    如果 (结果 != 0) { 返回 结果 }

    如果 ((标志 & O_NONBLOCK) != 0) {
        文件描述符_设置标志(文件描述符数组[0], O_NONBLOCK)
        文件描述符_设置标志(文件描述符数组[1], O_NONBLOCK)
    }
    如果 ((标志 & O_CLOEXEC) != 0) {
        文件描述符_设置CLOEXEC(文件描述符数组[0])
        文件描述符_设置CLOEXEC(文件描述符数组[1])
    }
    返回 0
}

定义 O_NONBLOCK = 0x800
定义 O_CLOEXEC = 0x80000

函数 文件描述符_设置标志(fd, 标志) {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 }
    定义 文件表 = 当前[T_文件表]
    如果 (文件表 == 空) { 返回 }
    如果 ((标志 & FD_CLOEXEC) != 0) {
        文件表_设置cloexec(文件表, fd)
    }
    如果 ((标志 & O_NONBLOCK) != 0) {
        定义 文件 = 文件表_获取(文件表, fd)
        如果 (文件 != 空) {
            文件.标志 = 文件.标志 | O_NONBLOCK
        }
    }
}
函数 文件描述符_设置CLOEXEC(fd) {
    文件描述符_设置标志(fd, FD_CLOEXEC)
}

// §4 管道容量控制(F_GETPIPE_SZ / F_SETPIPE_SZ)

定义 管道_默认容量 = 65536
定义 管道_最大容量 = 1048576

函数 管道_获取容量(管道) {
    如果 (管道 == 空) { 返回 0 }
    返回 管道.容量
}

函数 管道_设置容量_fcntl(管道, 新容量) {
    如果 (管道 == 空) { 返回 错误码_无效参数 }
    如果 (新容量 < 4096) { 新容量 = 4096 }
    如果 (新容量 > 管道_最大容量) { 返回 错误码_无效参数 }
    // 对齐到页大小
    新容量 = (新容量 + 4095) & ~4095
    如果 (新容量 < 管道.已使用) { 返回 错误码_忙 }
    // 重新分配缓冲区
    定义 新缓冲 = 分配内存(新容量)
    如果 (新缓冲 == 0) { 返回 错误码_内存不足 }
    // 复制现有数据
    如果 (管道.已使用 > 0) {
        管道_环形复制(新缓冲, 管道)
    }
    释放内存(管道.缓冲)
    管道.缓冲 = 新缓冲
    管道.容量 = 新容量
    返回 新容量
}

函数 管道_环形复制(目标, 管道) {
    定义 可变 i = 0
    定义 可变 读位 = 管道.读指针
    当 (i < 管道.已使用) {
        内存_写8(目标 + i, 内存_读8(管道.缓冲 + 读位))
        读位 = (读位 + 1) % 管道.容量
        i = i + 1
    }
    管道.读指针 = 0
    管道.写指针 = 管道.已使用
}

// §5 管道splice(零拷贝)

函数 sys_splice(fd_in, 偏移_in, fd_out, 偏移_out, 长度, 标志) {
    // splice: 在两个文件描述符之间零拷贝移动数据
    // 至少一个必须是管道
    返回 错误码_不支持
}

函数 sys_tee(fd_in, fd_out, 长度, 标志) {
    // tee: 在两个管道之间复制数据(不消费源)
    返回 错误码_不支持
}

定义 错误码_无效参数 = -22
定义 错误码_文件过多 = -24
定义 错误码_内存不足 = -12
定义 错误码_忙 = -16
定义 错误码_不支持 = -38

函数 文件描述符_分配() {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 -1 }
    定义 文件表 = 当前[T_文件表]
    如果 (文件表 == 空) { 返回 -1 }
    返回 文件表_分配(文件表)
}
函数 文件描述符_释放(fd) {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 }
    定义 文件表 = 当前[T_文件表]
    如果 (文件表 == 空) { 返回 }
    定义 文件 = 文件表_获取(文件表, fd)
    如果 (文件 == 空) { 返回 }
    文件表_关闭(文件表, fd)
    定义 剩余 = 文件_减引用(文件)
    如果 (剩余 <= 0) {
        定义 操作 = 文件.操作
        如果 (操作 != 空 && 操作.释放 != 空) {
            操作.释放(文件)
        }
    }
}
函数 文件对象_创建(a, b, c) {
    返回 {
        私有数据: 空,
        节点: a,
        目录项: b,
        标志: c,
        引用数: 1,
        操作: 空,
        已关闭: 假,
    }
}

// §6 统计

定义 可变 pipe_创建总数 = 0

函数 pipe_统计() {
    返回 {
        创建总数: pipe_创建总数,
    }
}

定义 可变 AI_系统调用_调用频率 = 0
定义 可变 AI_系统调用_容量负载 = 0

函数 AI_系统调用_频率评估() {
    AI_系统调用_调用频率 = pipe_创建总数
    返回 AI_系统调用_调用频率
}

函数 AI_系统调用_容量诊断() {
    定义 频率 = AI_系统调用_频率评估()
    如果 (频率 > 50000) { 返回 "pipe创建频率过高，建议复用管道" }
    如果 (频率 > 10000) { 返回 "pipe创建较频繁，注意文件描述符耗尽" }
    返回 "管道syscall状态正常"
}

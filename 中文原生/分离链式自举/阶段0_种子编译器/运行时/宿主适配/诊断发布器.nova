// Nova · 运行时 · 宿主适配 · 诊断发布器
// 职责: 将编译器诊断(错误/警告/提示)映射到宿主协议消息
// 层级: M15 — IDE/CLI宿主适配

// 诊断来源

导入("../../标准库/基础.nova")

定义 来源_词法 = 0
定义 来源_语法 = 1
定义 来源_语义 = 2
定义 来源_类型 = 3
定义 来源_借用 = 4
定义 来源_效果 = 5
定义 来源_优化 = 6
定义 来源_链接 = 7

函数 来源名(s) {
    如果 (s == 来源_词法) { 返回 "词法" }
    如果 (s == 来源_语法) { 返回 "语法" }
    如果 (s == 来源_语义) { 返回 "语义" }
    如果 (s == 来源_类型) { 返回 "类型" }
    如果 (s == 来源_借用) { 返回 "借用" }
    如果 (s == 来源_效果) { 返回 "效果" }
    如果 (s == 来源_优化) { 返回 "优化" }
    如果 (s == 来源_链接) { 返回 "链接" }
    返回 "unknown"
}

// 诊断条目: [文件, 行, 列, 严重级, 消息, 来源, 代码, 修复建议]
函数 诊断发布器_诊断_创建(文件, 行, 列, 级别, 消息, 来源) {
    返回 [文件, 行, 列, 级别, 消息, 来源, "", ""]
}

函数 诊断_文件(d) { 返回 d[0] }
函数 诊断_行(d) { 返回 d[1] }
函数 诊断_列(d) { 返回 d[2] }
函数 诊断发布器_诊断_级别(d) { 返回 d[3] }
函数 诊断发布器_诊断_消息(d) { 返回 d[4] }
函数 诊断_来源(d) { 返回 d[5] }
函数 诊断_代码(d) { 返回 d[6] }
函数 诊断_修复(d) { 返回 d[7] }

函数 诊断_设代码(d, c) { d[6] = c }
函数 诊断_设修复(d, f) { d[7] = f }

// 诊断发布器: [诊断列表, 按文件分组, 统计]
定义 可变 _发布器_诊断 = []
定义 可变 _发布器_按文件 = 空
定义 可变 _发布器_统计 = [0, 0, 0]  // [错误, 警告, 信息, 提示]

函数 发布器_重置() {
    _发布器_诊断 = []
    _发布器_按文件 = 字典()
    _发布器_统计 = [0, 0, 0]
}

函数 发布器_初始化() {
    如果 (_发布器_按文件 == 空) { _发布器_按文件 = 字典() }
}

// 接收诊断
函数 发布器_接收(诊断) {
    发布器_初始化()
    追加(_发布器_诊断, 诊断)

    // 按文件分组
    定义 文件 = 诊断_文件(诊断)
    定义 现有 = 字典取(_发布器_按文件, 文件)
    如果 (现有 == 空) {
        字典设(_发布器_按文件, 文件, [诊断])
    } 否则 {
        追加(现有, 诊断)
    }

    // 统计
    定义 级别 = 诊断发布器_诊断_级别(诊断)
    如果 (级别 >= 0 且 级别 < 4) {
        _发布器_统计[级别] = _发布器_统计[级别] + 1
    }
}

// 从编译器输出解析诊断
// 编译器格式: "错误: 文件:行:列: 消息"
函数 发布器_从编译器错误(文件, 行, 消息) {
    定义 d = 诊断发布器_诊断_创建(文件,  行, 0 ,  消息,  来源_语义, 0)
    发布器_接收(d)
    返回 d
}

函数 发布器_从编译器警告(文件, 行, 消息) {
    定义 d = 诊断发布器_诊断_创建(文件, 行, 0, 1, 消息, 来源_语义)
    发布器_接收(d)
    返回 d
}

函数 发布器_从词法错误(文件, 行, 列, 消息) {
    定义 d = 诊断发布器_诊断_创建(文件, 行, 列, 0, 消息, 来源_词法)
    诊断_设代码(d, "E001")
    发布器_接收(d)
    返回 d
}

函数 发布器_从语法错误(文件, 行, 列, 消息) {
    定义 d = 诊断发布器_诊断_创建(文件, 行, 列, 0, 消息, 来源_语法)
    诊断_设代码(d, "E002")
    发布器_接收(d)
    返回 d
}

函数 发布器_从借用违规(文件, 行, 消息) {
    定义 d = 诊断发布器_诊断_创建(文件,  行, 0 ,  消息,  来源_借用, 0)
    诊断_设代码(d, "E003")
    发布器_接收(d)
    返回 d
}

函数 发布器_从效果违规(文件, 行, 消息) {
    定义 d = 诊断发布器_诊断_创建(文件,  行, 0 ,  消息,  来源_效果, 0)
    诊断_设代码(d, "E004")
    发布器_接收(d)
    返回 d
}

// 转换为宿主协议消息
// 产出: 与宿主协议.nova中定义的诊断格式对齐
函数 发布器_转宿主消息(诊断) {
    // 返回: [行号, 列号, 严重级, 消息, 来源]
    返回 [诊断_行(诊断), 诊断_列(诊断), 诊断发布器_诊断_级别(诊断),
           字符串拼接("[", 字符串拼接(诊断_代码(诊断), 字符串拼接("] ", 诊断发布器_诊断_消息(诊断)))),
           来源名(诊断_来源(诊断))]
}

// 批量转换某文件的诊断
函数 发布器_文件诊断(文件名) {
    发布器_初始化()
    定义 列表 = 字典取(_发布器_按文件, 文件名)
    如果 (列表 == 空) { 返回 [] }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        追加(结果, 发布器_转宿主消息(列表[i]))
        i = i + 1
    }
    返回 结果
}

// 查询
函数 发布器_错误数() { 返回 _发布器_统计[0] }
函数 发布器_警告数() { 返回 _发布器_统计[1] }
函数 发布器_总数() { 返回 计数(_发布器_诊断) }
函数 发布器_有错误() { 返回 _发布器_统计[0] > 0 }

// 报告
函数 发布器_打印报告() {
    打印("═══ 诊断发布器报告 ═══")
    打印文本(字符串拼接("  总诊断: ", 转字符串(计数(_发布器_诊断))))
    打印文本(字符串拼接("  错误: ", 转字符串(_发布器_统计[0])))
    打印文本(字符串拼接("  警告: ", 转字符串(_发布器_统计[1])))
    打印文本(字符串拼接("  信息: ", 转字符串(_发布器_统计[2])))
    打印文本(字符串拼接("  提示: ", 转字符串(_发布器_统计[3])))

    // 按来源统计
    定义 可变 来源计数 = [0, 0, 0, 0, 0]
    定义 可变 i = 0
    当 (i < 计数(_发布器_诊断)) {
        定义 可变 s = 诊断_来源(_发布器_诊断[i])
        如果 (s >= 0 且 s < 8) { 来源计数[s] = 来源计数[s] + 1 }
        i = i + 1
    }
    打印("  按来源:")
    定义 可变 s = 0
    当 (s < 8) {
        如果 (来源计数[s] > 0) {
            打印文本(字符串拼接("    ", 字符串拼接(来源名(s), 字符串拼接(": ", 转字符串(来源计数[s])))))
        }
        s = s + 1
    }
}

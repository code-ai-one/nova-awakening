导入("../基础.nova")
导入("../数学/基础/数学库.nova")

函数 INT8_求范围(数据) {
    定义 可变 最大 = 0
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        定义 绝对值 = 绝对值(数据[i])
        如果 (绝对值 > 最大) { 最大 = 绝对值 }
        i = i + 1
    }
    返回 最大
}

函数 INT8_量化(数据) {
    定义 可变 范围 = INT8_求范围(数据)
    如果 (范围 == 0) { 范围 = 1 }
    定义 可变 量化值 = []
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        定义 可变 q = (数据[i] * 127) / 范围
        如果 (q > 127) { q = 127 }
        如果 (q < -127) { q = -127 }
        追加(量化值, q)
        i = i + 1
    }
    返回 [量化值, 范围]
}

函数 INT8_反量化(量化结果) {
    定义 量化值 = 量化结果[0]
    定义 r = 量化结果[1]
    返回 映射(量化值, q => q * r / 127)
}

// INT4 量化 (4-bit, 范围 [-7, 7])
函数 INT4_量化(数据) {
    定义 可变 范围 = INT8_求范围(数据)
    如果 (范围 == 0) { 范围 = 1 }
    定义 可变 量化值 = []
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        定义 可变 q = (数据[i] * 7) / 范围
        如果 (q > 7) { q = 7 }
        如果 (q < -7) { q = -7 }
        追加(量化值, q)
        i = i + 1
    }
    返回 [量化值, 范围]
}

函数 INT4_反量化(量化结果) {
    定义 量化值 = 量化结果[0]
    定义 r = 量化结果[1]
    返回 映射(量化值, q => q * r / 7)
}

// 量化误差计算
函数 量化_MSE(原始, 恢复) {
    如果 (计数(原始) == 0) { 返回 0 }
    返回 折叠(拉链(原始, 恢复, (a, b) => (a - b) * (a - b)), 0, (s, d) => s + d) / 计数(原始)
}

函数 量化_最大误差(原始, 恢复) {
    定义 可变 最大 = 0
    定义 可变 i = 0
    当 (i < 计数(原始)) {
        定义 d = 绝对值(原始[i] - 恢复[i])
        如果 (d > 最大) { 最大 = d }
        i = i + 1
    }
    返回 最大
}

// 校准 (MinMax校准)
函数 校准_MinMax(校准数据列表) {
    定义 可变 全局最小 = 0x7FFFFFFF
    定义 可变 全局最大 = 0 - 0x7FFFFFFF
    定义 可变 i = 0
    当 (i < 计数(校准数据列表)) {
        定义 批次 = 校准数据列表[i]
        定义 可变 j = 0
        当 (j < 计数(批次)) {
            如果 (批次[j] < 全局最小) { 全局最小 = 批次[j] }
            如果 (批次[j] > 全局最大) { 全局最大 = 批次[j] }
            j = j + 1
        }
        i = i + 1
    }
    返回 [全局最小, 全局最大]
}

// 非对称量化
函数 非对称_量化(数据, 最小, 最大) {
    定义 可变 范围 = 最大 - 最小
    如果 (范围 == 0) { 范围 = 1 }
    定义 可变 量化值 = []
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        定义 可变 q = ((数据[i] - 最小) * 255) / 范围
        如果 (q > 255) { q = 255 }
        如果 (q < 0) { q = 0 }
        追加(量化值, q)
        i = i + 1
    }
    返回 [量化值, 最小, 范围]
}

函数 非对称_反量化(量化结果) {
    定义 量化值 = 量化结果[0]
    定义 零点 = 量化结果[1]
    定义 可变 范围 = 量化结果[2]
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(量化值)) {
        追加(结果, 量化值[i] * 范围 / 255 + 零点)
        i = i + 1
    }
    返回 结果
}

// 按块量化 (Block-wise)
函数 块量化_INT8(数据, 块大小) {
    定义 可变 所有量化 = []
    定义 可变 所有范围 = []
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        定义 可变 块 = []
        定义 可变 j = 0
        当 (j < 块大小 且 i + j < 计数(数据)) {
            追加(块, 数据[i + j])
            j = j + 1
        }
        定义 qr = INT8_量化(块)
        定义 可变 k = 0
        当 (k < 计数(qr[0])) { 追加(所有量化, qr[0][k])
        k = k + 1 }
        追加(所有范围, qr[1])
        i = i + 块大小
    }
    返回 [所有量化, 所有范围]
}

// 按通道量化
函数 按通道_INT8量化(通道数据列表) {
    返回 映射(通道数据列表, ch => INT8_量化(ch))
}

// 动态量化
函数 动态_INT8量化(数据) {
    // 每次推理时根据实际数据范围量化
    返回 INT8_量化(数据)
}

// 量化感知训练模拟
函数 QAT_伪量化(数据, 位宽) {
    // 前向用量化值，梯度直通
    如果 (位宽 == 8) {
        定义 qr = INT8_量化(数据)
        返回 INT8_反量化(qr)
    }
    如果 (位宽 == 4) {
        定义 qr4 = INT4_量化(数据)
        返回 INT4_反量化(qr4)
    }
    返回 数据
}

// 信噪比
函数 量化_SNR(原始, 恢复) {
    定义 信号能 = 折叠(原始, 0, (s, x) => s + x * x / 1000)
    定义 噪声能 = 折叠(拉链(原始, 恢复, (a, b) => (a - b) * (a - b) / 1000), 0, (s, d) => s + d)
    如果 (噪声能 == 0) { 返回 9999 }
    返回 信号能 * 100 / 噪声能
}

// §4 绘制引擎 — Nova原生元素树→帧缓冲像素

函数 绘制_元素树(元素, fb) {
    如果 (元素 == 空 || !元素.可见) { 返回 }
    定义 s = 元素.样式
    如果 (s == 空) { s = 样式_默认(元素.控件类型) }

    // 绘制背景
    如果 (s.背景色 != 0x00000000) {
        像素_填充矩形(fb, 元素.布局_x, 元素.布局_y, 元素.布局_宽, 元素.布局_高, s.背景色)
    }
    // 绘制边框
    如果 (s.边框宽 > 0) {
        绘制_边框(fb, 元素.布局_x, 元素.布局_y, 元素.布局_宽, 元素.布局_高, s.边框色, s.边框宽)
    }
    // 绘制文本
    如果 (元素.类型 == 元素类型_文本 && 元素.文本内容 != "") {
        绘制_文本(fb, 元素.布局_x, 元素.布局_y, 元素.文本内容, s.前景色, s.字号)
    }
    // 递归绘制子元素
    定义 可变 i = 0
    当 (i < 计数(元素.子元素)) {
        绘制_元素树(元素.子元素[i], fb)
        i = i + 1
    }
}

函数 绘制_边框(fb, x, y, w, h, 颜色, 宽度) {
    像素_填充矩形(fb, x, y, w, 宽度, 颜色)         // 上
    像素_填充矩形(fb, x, y + h - 宽度, w, 宽度, 颜色) // 下
    像素_填充矩形(fb, x, y, 宽度, h, 颜色)             // 左
    像素_填充矩形(fb, x + w - 宽度, y, 宽度, h, 颜色)  // 右
}

函数 绘制_文本(fb, x, y, 文本, 颜色, 字号) {
    // 委托给位图字体引擎(驱动/显示/位图字体.nova)
    // 缩放 = 字号 / 16 (字体原始高度16px)
    定义 缩放 = 字号 / 16
    如果 (缩放 < 1) { 缩放 = 1 }
    字体_渲染文本_透明(fb, x, y, 文本, 颜色, 缩放)
}

函数 绘制_字符(fb, x, y, 字符码, 颜色, 字号) {
    // 委托给位图字体引擎
    定义 缩放 = 字号 / 16
    如果 (缩放 < 1) { 缩放 = 1 }
    字体_渲染字符_透明(fb, x, y, 字符码, 颜色, 缩放)
}

// §5 无障碍树 — AI可直接读取的语义结构

结构 无障碍节点 {
    节点ID,
    角色,    // 字符串 button/link/textbox/heading/...
    名称,    // 字符串 可读名称(按钮文字/链接文字等)
    值,    // 字符串 输入框值
    x,
    y,
    宽,
    高,
    可聚焦,
    已禁用,
    子节点,    // []
}

函数 构建无障碍树(元素) {
    如果 (元素 == 空 || !元素.可见) { 返回 空 }

    定义 a11y = 无障碍节点 {}
    a11y.节点ID = 元素.元素ID
    a11y.角色 = 元素.语义角色
    a11y.x = 元素.布局_x
    a11y.y = 元素.布局_y
    a11y.宽 = 元素.布局_宽
    a11y.高 = 元素.布局_高
    a11y.可聚焦 = 元素.可交互
    a11y.已禁用 = 假
    a11y.子节点 = []

    // 提取名称
    如果 (元素.类型 == 元素类型_文本) {
        a11y.名称 = 元素.文本内容
    } 否则 {
        a11y.名称 = 元素_提取文本(元素)
    }

    // 递归构建子树
    定义 可变 i = 0
    当 (i < 计数(元素.子元素)) {
        定义 子a11y = 构建无障碍树(元素.子元素[i])
        如果 (子a11y != 空) {
            追加(a11y.子节点, 子a11y)
        }
        i = i + 1
    }
    返回 a11y
}

函数 元素_提取文本(元素) {
    如果 (元素 == 空) { 返回 "" }
    如果 (元素.类型 == 元素类型_文本) { 返回 元素.文本内容 }
    定义 可变 文本 = ""
    定义 可变 i = 0
    当 (i < 计数(元素.子元素)) {
        文本 = 文本 + 元素_提取文本(元素.子元素[i])
        i = i + 1
    }
    返回 文本
}

函数 无障碍_查找可交互元素(a11y) {
    // 返回所有可交互(可点击/可输入)元素列表
    定义 可变 结果 = []
    无障碍_收集交互元素(a11y, 结果)
    返回 结果
}

函数 无障碍_收集交互元素(节点, 结果) {
    如果 (节点 == 空) { 返回 }
    如果 (节点.可聚焦 && !节点.已禁用) {
        追加(结果, 节点)
    }
    定义 可变 i = 0
    当 (i < 计数(节点.子节点)) {
        无障碍_收集交互元素(节点.子节点[i], 结果)
        i = i + 1
    }
}

函数 无障碍_按坐标查找(a11y, x, y) {
    // 精确坐标命中测试: 找到最深层包含(x,y)的可交互节点
    如果 (a11y == 空) { 返回 空 }
    如果 (x < a11y.x || x >= a11y.x + a11y.宽 ||
        y < a11y.y || y >= a11y.y + a11y.高) { 返回 空 }

    // 深度优先: 先检查子节点
    定义 可变 i = 计数(a11y.子节点) - 1
    当 (i >= 0) {
        定义 命中 = 无障碍_按坐标查找(a11y.子节点[i], x, y)
        如果 (命中 != 空) { 返回 命中 }
        i = i - 1
    }
    如果 (a11y.可聚焦) { 返回 a11y }
    返回 空
}

结构 滤镜档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    模糊数,
    亮度数,
    对比数,
    饱和数,
    色相数,
    阴影数,
    混合数,
    色混数,
    选择器数,
    玻璃包数,
    成功数,
    失败数,
    最近目标,
    最近滤镜,
    最近颜色,
}

结构 滤镜请求 {
    动作,
    目标,
    参数,
    选项,
}

结构 滤镜回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 滤镜摘要 {
    名称,
    模糊数,
    亮度数,
    对比数,
    饱和数,
    色相数,
    阴影数,
    混合数,
    色混数,
    选择器数,
    玻璃包数,
    成功数,
    失败数,
    健康,
}

结构 滤镜项 {
    类型,
    目标,
    值,
    内容,
    备注,
}

定义 可变 滤镜账本 = []
定义 可变 滤镜构建数 = 0
定义 可变 滤镜总动作 = 0
定义 可变 滤镜总成功 = 0
定义 可变 滤镜总失败 = 0


函数 样式滤镜_建档(名称) {
    定义 档 = 滤镜档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.模糊数 = 0
    档.亮度数 = 0
    档.对比数 = 0
    档.饱和数 = 0
    档.色相数 = 0
    档.阴影数 = 0
    档.混合数 = 0
    档.色混数 = 0
    档.选择器数 = 0
    档.玻璃包数 = 0
    档.成功数 = 0
    档.失败数 = 0
    档.最近目标 = ""
    档.最近滤镜 = ""
    档.最近颜色 = ""
    返回 档
}

函数 样式滤镜_登记(档) {
    追加(滤镜账本, 档)
    滤镜构建数 = 滤镜构建数 + 1
    返回 档
}

函数 样式滤镜_完整统计() {
    返回 [
        滤镜构建数,
        滤镜总动作,
        滤镜总成功,
        滤镜总失败
    ]
}

函数 样式滤镜_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 滤镜回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 样式滤镜_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    滤镜总动作 = 滤镜总动作 + 1
}

函数 样式滤镜_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.失败数 > 档.成功数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (档.玻璃包数 == 0 || 档.选择器数 == 0) {
        档.最近健康 = "预热"
        返回 档.最近健康
    }
    如果 (档.失败数 > 0) {
        档.最近健康 = "监视"
        返回 档.最近健康
    }
    档.最近健康 = "运行"
    返回 档.最近健康
}

函数 样式滤镜_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (档.名称 == "") { 返回 假 }
    返回 真
}

函数 样式滤镜_成功(档, 来源, 数据) {
    档.最近结果 = 数据
    档.成功数 = 档.成功数 + 1
    滤镜总成功 = 滤镜总成功 + 1
    档.最近统计 = 样式滤镜_完整统计()
    样式滤镜_刷新健康(档)
    返回 样式滤镜_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 样式滤镜_失败(档, 来源, 错因) {
    如果 (档 != 空) {
        档.最近错误 = 错因
        档.失败数 = 档.失败数 + 1
        档.最近统计 = 样式滤镜_完整统计()
        样式滤镜_刷新健康(档)
    }
    滤镜总失败 = 滤镜总失败 + 1
    返回 样式滤镜_建回证(真, 假, 来源, 错因, 空, 样式滤镜_完整统计())
}

函数 样式滤镜_建项(类型, 目标, 值, 内容, 备注) {
    定义 项 = 滤镜项 {}
    项.类型 = 类型
    项.目标 = 目标
    项.值 = 值
    项.内容 = 内容
    项.备注 = 备注
    返回 项
}

函数 样式滤镜_规则(选择器, 键, 值) {
    返回 选择器 + "{" + 键 + ":" + 值 + ";}\n"
}

函数 样式滤镜_滤镜规则(选择器, 值) {
    返回 选择器 + "{filter:" + 值 + ";}\n"
}

函数 样式滤镜_混合规则(选择器, 值) {
    返回 选择器 + "{mix-blend-mode:" + 值 + ";}\n"
}

函数 样式滤镜_背板规则(选择器, 值) {
    返回 选择器 + "{backdrop-filter:" + 值 + ";-webkit-backdrop-filter:" + 值 + ";}\n"
}

函数 样式滤镜_模糊(档, 目标, 半径) {
    如果 (!样式滤镜_检查档(档)) { 返回 样式滤镜_失败(档, "模糊", "滤镜档不可用") }
    样式滤镜_记录(档, "模糊", [目标, 半径], "样式滤镜")
    档.模糊数 = 档.模糊数 + 1
    档.最近目标 = 目标
    档.最近滤镜 = "blur(" + 半径 + "px)"
    返回 样式滤镜_成功(档, "模糊", 样式滤镜_建项("模糊", 目标, 半径, 样式滤镜_滤镜规则(目标, 档.最近滤镜), "景深软化"))
}

函数 样式滤镜_亮度(档, 目标, 百分比) {
    如果 (!样式滤镜_检查档(档)) { 返回 样式滤镜_失败(档, "亮度", "滤镜档不可用") }
    样式滤镜_记录(档, "亮度", [目标, 百分比], "样式滤镜")
    档.亮度数 = 档.亮度数 + 1
    档.最近目标 = 目标
    档.最近滤镜 = "brightness(" + 百分比 + "%)"
    返回 样式滤镜_成功(档, "亮度", 样式滤镜_建项("亮度", 目标, 百分比, 样式滤镜_滤镜规则(目标, 档.最近滤镜), "提升亮区"))
}

函数 样式滤镜_对比(档, 目标, 百分比) {
    如果 (!样式滤镜_检查档(档)) { 返回 样式滤镜_失败(档, "对比", "滤镜档不可用") }
    样式滤镜_记录(档, "对比", [目标, 百分比], "样式滤镜")
    档.对比数 = 档.对比数 + 1
    档.最近目标 = 目标
    档.最近滤镜 = "contrast(" + 百分比 + "%)"
    返回 样式滤镜_成功(档, "对比", 样式滤镜_建项("对比", 目标, 百分比, 样式滤镜_滤镜规则(目标, 档.最近滤镜), "增强层次"))
}

函数 样式滤镜_饱和(档, 目标, 百分比) {
    如果 (!样式滤镜_检查档(档)) { 返回 样式滤镜_失败(档, "饱和", "滤镜档不可用") }
    样式滤镜_记录(档, "饱和", [目标, 百分比], "样式滤镜")
    档.饱和数 = 档.饱和数 + 1
    档.最近目标 = 目标
    档.最近滤镜 = "saturate(" + 百分比 + "%)"
    返回 样式滤镜_成功(档, "饱和", 样式滤镜_建项("饱和", 目标, 百分比, 样式滤镜_滤镜规则(目标, 档.最近滤镜), "控制纯度"))
}

函数 样式滤镜_色相(档, 目标, 角度) {
    如果 (!样式滤镜_检查档(档)) { 返回 样式滤镜_失败(档, "色相", "滤镜档不可用") }
    样式滤镜_记录(档, "色相", [目标, 角度], "样式滤镜")
    档.色相数 = 档.色相数 + 1
    档.最近目标 = 目标
    档.最近滤镜 = "hue-rotate(" + 角度 + "deg)"
    返回 样式滤镜_成功(档, "色相", 样式滤镜_建项("色相", 目标, 角度, 样式滤镜_滤镜规则(目标, 档.最近滤镜), "转动色轮"))
}

函数 样式滤镜_阴影(档, 目标, 横向, 纵向, 模糊, 颜色) {
    如果 (!样式滤镜_检查档(档)) { 返回 样式滤镜_失败(档, "阴影", "滤镜档不可用") }
    样式滤镜_记录(档, "阴影", [目标, 横向, 纵向, 模糊, 颜色], "样式滤镜")
    档.阴影数 = 档.阴影数 + 1
    档.最近目标 = 目标
    档.最近颜色 = 颜色
    档.最近滤镜 = "drop-shadow(" + 横向 + "px " + 纵向 + "px " + 模糊 + "px " + 颜色 + ")"
    返回 样式滤镜_成功(档, "阴影", 样式滤镜_建项("阴影", 目标, 颜色, 样式滤镜_滤镜规则(目标, 档.最近滤镜), "柔和浮层"))
}

函数 样式滤镜_混合(档, 目标, 模式) {
    如果 (!样式滤镜_检查档(档)) { 返回 样式滤镜_失败(档, "混合", "滤镜档不可用") }
    样式滤镜_记录(档, "混合", [目标, 模式], "样式滤镜")
    档.混合数 = 档.混合数 + 1
    档.最近目标 = 目标
    返回 样式滤镜_成功(档, "混合", 样式滤镜_建项("混合", 目标, 模式, 样式滤镜_混合规则(目标, 模式), "图层混合"))
}

函数 样式滤镜_色混(档, 目标, 起色, 终色, 比例) {
    如果 (!样式滤镜_检查档(档)) { 返回 样式滤镜_失败(档, "色混", "滤镜档不可用") }
    样式滤镜_记录(档, "色混", [目标, 起色, 终色, 比例], "样式滤镜")
    档.色混数 = 档.色混数 + 1
    档.最近目标 = 目标
    档.最近颜色 = 起色 + "->" + 终色
    定义 值 = "color-mix(in srgb, " + 起色 + " " + 比例 + "%, " + 终色 + ")"
    定义 内容 = 样式滤镜_规则(目标, "background", 值)
    返回 样式滤镜_成功(档, "色混", 样式滤镜_建项("色混", 目标, 比例, 内容, "现代色彩混合"))
}

函数 样式滤镜_滤镜链(档, 目标, 模糊值, 亮度值, 对比值, 饱和值) {
    如果 (!样式滤镜_检查档(档)) { 返回 样式滤镜_失败(档, "滤镜链", "滤镜档不可用") }
    样式滤镜_记录(档, "滤镜链", [目标, 模糊值, 亮度值, 对比值, 饱和值], "样式滤镜")
    定义 值 = "blur(" + 模糊值 + "px) brightness(" + 亮度值 + "%) contrast(" + 对比值 + "%) saturate(" + 饱和值 + "%)"
    档.模糊数 = 档.模糊数 + 1
    档.亮度数 = 档.亮度数 + 1
    档.对比数 = 档.对比数 + 1
    档.饱和数 = 档.饱和数 + 1
    档.最近目标 = 目标
    档.最近滤镜 = 值
    返回 样式滤镜_成功(档, "滤镜链", 样式滤镜_建项("滤镜链", 目标, 值, 样式滤镜_滤镜规则(目标, 值), "多段滤镜链"))
}

函数 样式滤镜_子网格信号(档, 目标, 主轴, 次轴) {
    如果 (!样式滤镜_检查档(档)) { 返回 样式滤镜_失败(档, "子网格信号", "滤镜档不可用") }
    样式滤镜_记录(档, "子网格信号", [目标, 主轴, 次轴], "样式滤镜")
    档.选择器数 = 档.选择器数 + 1
    定义 内容 = 目标 + "{display:grid;grid-template-columns:subgrid;grid-template-rows:subgrid;}\n"
    内容 = 内容 + 目标 + "{--主轴:" + 主轴 + ";--次轴:" + 次轴 + ";}\n"
    返回 样式滤镜_成功(档, "子网格信号", 样式滤镜_建项("子网格", 目标, 主轴 + "," + 次轴, 内容, "布局信号联动"))
}

函数 样式滤镜_选择器应用(档, 选择器, 滤镜值, 背板值, 过渡时长) {
    如果 (!样式滤镜_检查档(档)) { 返回 样式滤镜_失败(档, "选择器应用", "滤镜档不可用") }
    样式滤镜_记录(档, "选择器应用", [选择器, 滤镜值, 背板值, 过渡时长], "样式滤镜")
    档.选择器数 = 档.选择器数 + 1
    档.最近目标 = 选择器
    档.最近滤镜 = 滤镜值
    定义 内容 = 样式滤镜_滤镜规则(选择器, 滤镜值)
    内容 = 内容 + 样式滤镜_背板规则(选择器, 背板值)
    内容 = 内容 + 样式滤镜_规则(选择器, "transition", "filter " + 过渡时长 + "ms ease, backdrop-filter " + 过渡时长 + "ms ease")
    返回 样式滤镜_成功(档, "选择器应用", 样式滤镜_建项("选择器", 选择器, 过渡时长, 内容, "结构化应用"))
}

函数 样式滤镜_白璃包(档) {
    如果 (!样式滤镜_检查档(档)) { 返回 样式滤镜_失败(档, "白璃包", "滤镜档不可用") }
    样式滤镜_记录(档, "白璃包", [], "样式滤镜")
    定义 规则档 = 样式规则_登记(样式规则_建档("白璃规则"))
    样式规则_初始化(规则档)
    定义 现代 = 样式规则_现代包(规则档).数据
    定义 胶囊 = 样式滤镜_选择器应用(档, ".白璃胶囊", "blur(18px) brightness(106%) contrast(108%)", "blur(20px)", 220).数据
    定义 卡片 = 样式滤镜_滤镜链(档, ".白璃卡片", "10", "104", "112", "112").数据
    定义 阴影 = 样式滤镜_阴影(档, ".白璃卡片", "0", "20", "48", "rgba(177,190,214,0.26)").数据
    定义 色混 = 样式滤镜_色混(档, ".白璃桌面", "rgba(255,255,255,0.90)", "rgba(224,233,245,0.72)", "72").数据
    定义 混合 = 样式滤镜_混合(档, ".白璃高光", "screen").数据
    定义 子网格 = 样式滤镜_子网格信号(档, ".白璃主区", "层次稳定", "卡片呼吸").数据
    档.玻璃包数 = 档.玻璃包数 + 1
    定义 内容 = 现代 + 胶囊.内容 + 卡片.内容 + 阴影.内容 + 色混.内容 + 混合.内容 + 子网格.内容
    内容 = 内容 + ".白璃窗{background:rgba(255,255,255,0.76);border:1px solid rgba(255,255,255,0.68);box-shadow:0 22px 60px rgba(160,176,198,0.24);}\n"
    内容 = 内容 + ".白璃桌面{background:linear-gradient(180deg,rgba(248,250,253,1),rgba(234,240,247,1));}\n"
    返回 样式滤镜_成功(档, "白璃包", 样式滤镜_建项("白璃包", ".白璃桌面", "现代玻璃", 内容, "现代白玻璃界面"))
}

函数 样式滤镜_摘要(档) {
    定义 摘要 = 滤镜摘要 {}
    摘要.名称 = 档.名称
    摘要.模糊数 = 档.模糊数
    摘要.亮度数 = 档.亮度数
    摘要.对比数 = 档.对比数
    摘要.饱和数 = 档.饱和数
    摘要.色相数 = 档.色相数
    摘要.阴影数 = 档.阴影数
    摘要.混合数 = 档.混合数
    摘要.色混数 = 档.色混数
    摘要.选择器数 = 档.选择器数
    摘要.玻璃包数 = 档.玻璃包数
    摘要.成功数 = 档.成功数
    摘要.失败数 = 档.失败数
    摘要.健康 = 样式滤镜_刷新健康(档)
    返回 摘要
}

函数 样式滤镜_初始化(档) {
    如果 (!样式滤镜_检查档(档)) { 返回 样式滤镜_失败(档, "初始化", "滤镜档不可用") }
    样式滤镜_记录(档, "初始化", [], "样式滤镜")
    档.是否初始化 = 真
    返回 样式滤镜_成功(档, "初始化", "已初始化")
}

函数 样式滤镜_自检(档) {
    如果 (!样式滤镜_检查档(档)) { 返回 假 }
    如果 (样式滤镜_初始化(档).已成 == 假) { 返回 假 }
    如果 (样式滤镜_模糊(档, ".卡片", "12").已成 == 假) { 返回 假 }
    如果 (样式滤镜_亮度(档, ".卡片", "104").已成 == 假) { 返回 假 }
    如果 (样式滤镜_对比(档, ".卡片", "108").已成 == 假) { 返回 假 }
    如果 (样式滤镜_饱和(档, ".卡片", "110").已成 == 假) { 返回 假 }
    如果 (样式滤镜_色相(档, ".高光", "8").已成 == 假) { 返回 假 }
    如果 (样式滤镜_阴影(档, ".卡片", "0", "18", "42", "rgba(170,184,205,0.24)").已成 == 假) { 返回 假 }
    如果 (样式滤镜_混合(档, ".高光", "screen").已成 == 假) { 返回 假 }
    如果 (样式滤镜_色混(档, ".桌面", "rgba(255,255,255,0.92)", "rgba(233,240,248,0.76)", "68").已成 == 假) { 返回 假 }
    如果 (样式滤镜_选择器应用(档, ".白璃窗", "blur(20px) brightness(106%)", "blur(18px)", 220).已成 == 假) { 返回 假 }
    如果 (样式滤镜_白璃包(档).已成 == 假) { 返回 假 }
    返回 真
}

函数 样式滤镜_处理(档, 请求) {
    如果 (请求 == 空) { 返回 样式滤镜_失败(档, "处理", "请求为空") }
    如果 (请求.动作 == "初始化") { 返回 样式滤镜_初始化(档) }
    如果 (请求.动作 == "模糊") { 返回 样式滤镜_模糊(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "亮度") { 返回 样式滤镜_亮度(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "对比") { 返回 样式滤镜_对比(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "饱和") { 返回 样式滤镜_饱和(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "色相") { 返回 样式滤镜_色相(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "阴影") { 返回 样式滤镜_阴影(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3], 请求.参数[4]) }
    如果 (请求.动作 == "混合") { 返回 样式滤镜_混合(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "色混") { 返回 样式滤镜_色混(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3]) }
    如果 (请求.动作 == "滤镜链") { 返回 样式滤镜_滤镜链(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3], 请求.参数[4]) }
    如果 (请求.动作 == "子网格信号") { 返回 样式滤镜_子网格信号(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "选择器应用") { 返回 样式滤镜_选择器应用(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3]) }
    如果 (请求.动作 == "白璃包") { 返回 样式滤镜_白璃包(档) }
    如果 (请求.动作 == "摘要") { 返回 样式滤镜_成功(档, "摘要", 样式滤镜_摘要(档)) }
    返回 样式滤镜_失败(档, "处理", "未知动作")
}

// merge source: 沙盒批次/批六/待厚/感知/描边光栅化.nova
// §9 描边光栅化 (Stroke)
// 将路径描边转换为填充路径(offset curve)

函数 SkStroke_描边路径(原始路径, 描边宽度, 端帽, 连接) {
    // 将描边路径转换为填充路径
    // 原理: 沿法线方向偏移生成两条平行路径,首尾连接
    定义 半宽 = 描边宽度 / 2
    定义 结果 = SkPath_创建()

    定义 可变 点idx = 0
    定义 可变 动词idx = 0
    定义 可变 prev_x = 0; 定义 可变 prev_y = 0

    当 (动词idx < 原始路径.动词数量) {
        定义 动词 = 内存_读8(原始路径.动词列表 + 动词idx)

        如果 (动词 == 路径动词_移动) {
            prev_x = 内存_读32(原始路径.点列表 + 点idx * 8)
            prev_y = 内存_读32(原始路径.点列表 + 点idx * 8 + 4)
            点idx = 点idx + 1
        }
        否则 如果 (动词 == 路径动词_直线) {
            定义 cur_x = 内存_读32(原始路径.点列表 + 点idx * 8)
            定义 cur_y = 内存_读32(原始路径.点列表 + 点idx * 8 + 4)

            // 计算法线方向
            定义 dx = cur_x - prev_x
            定义 dy = cur_y - prev_y
            定义 长度 = 整数_sqrt(dx * dx + dy * dy)
            如果 (长度 > 0) {
                定义 nx = 0 - dy * 半宽 / 长度    // 法线x
                定义 ny = dx * 半宽 / 长度         // 法线y

                // 外侧矩形(描边的填充区域)
                SkPath_moveTo(结果, prev_x + nx, prev_y + ny)
                SkPath_lineTo(结果, cur_x + nx, cur_y + ny)
                SkPath_lineTo(结果, cur_x - nx, cur_y - ny)
                SkPath_lineTo(结果, prev_x - nx, prev_y - ny)
                SkPath_close(结果)

                // 端帽
                如果 (端帽 == Sk绘制端帽_圆) {
                    // 在起点和终点画半圆(用椭圆弧近似)
                    SkPath_addArc(结果, cur_x, cur_y, 半宽, 0, 3600)
                }
            }

            prev_x = cur_x; prev_y = cur_y
            点idx = 点idx + 1
        }

        动词idx = 动词idx + 1
    }

    返回 结果
}

函数 整数_sqrt(n) {
    // 整数平方根(牛顿法)
    如果 (n <= 0) { 返回 0 }
    如果 (n == 1) { 返回 1 }
    定义 可变 x = n
    定义 可变 y = (x + 1) / 2
    当 (y < x) {
        x = y
        y = (x + n / x) / 2
    }
    返回 x
}

// §10 更新Sk画布 — 连接新的光栅化管线

函数 Sk画布_drawPath_完整(c, path, paint) {
    c.绘制调用数 = c.绘制调用数 + 1
    定义 bm = c.位图

    如果 (paint.风格 == Sk绘制风格_填充 || paint.风格 == Sk绘制风格_填充描边) {
        如果 (paint.抗锯齿) {
            SkScan_抗锯齿填充路径(bm, path, paint)
        } 否则 {
            SkScan_填充路径(bm, path, paint)
        }
    }

    如果 (paint.风格 == Sk绘制风格_描边 || paint.风格 == Sk绘制风格_填充描边) {
        定义 描边路径 = SkStroke_描边路径(path, paint.描边宽度, paint.端帽, paint.连接)
        如果 (paint.抗锯齿) {
            SkScan_抗锯齿填充路径(bm, 描边路径, paint)
        } 否则 {
            SkScan_填充路径(bm, 描边路径, paint)
        }
    }
}

函数 Sk画布_drawRRect_完整(c, rrect, paint) {
    c.绘制调用数 = c.绘制调用数 + 1
    SkScan_填充圆角矩形(c.位图, rrect, paint)
}

函数 Sk画布_drawCircle(c, cx, cy, 半径, paint) {
    // 圆 = 特殊的圆角矩形(半径=宽高的一半)
    定义 rect = SkRect_创建(cx - 半径, cy - 半径, cx + 半径, cy + 半径)
    定义 rrect = SkRRect_创建(rect, 半径)
    Sk画布_drawRRect_完整(c, rrect, paint)
}

函数 Sk画布_drawOval(c, rect, paint) {
    // 椭圆: 用路径近似(4段三次贝塞尔)
    定义 path = SkPath_创建()
    定义 cx = (rect.左 + rect.右) / 2
    定义 cy = (rect.上 + rect.下) / 2
    定义 rx = (rect.右 - rect.左) / 2
    定义 ry = (rect.下 - rect.上) / 2

    // 贝塞尔近似圆弧: 控制点距离 = 半径 * 0.5523
    定义 kx = rx * 5523 / 10000
    定义 ky = ry * 5523 / 10000

    SkPath_moveTo(path, cx + rx, cy)
    SkPath_Nova三次方To(path, cx + rx, cy + ky, cx + kx, cy + ry, cx, cy + ry)
    SkPath_Nova三次方To(path, cx - kx, cy + ry, cx - rx, cy + ky, cx - rx, cy)
    SkPath_Nova三次方To(path, cx - rx, cy - ky, cx - kx, cy - ry, cx, cy - ry)
    SkPath_Nova三次方To(path, cx + kx, cy - ry, cx + rx, cy - ky, cx + rx, cy)
    SkPath_close(path)

    Sk画布_drawPath_完整(c, path, paint)
}

// merge source: 沙盒批次/批七/待厚/感知/绘制色彩四.nova
// Skia→Nova: Sk绘制 — 绘制属性描述符
// 对应: skia/src/core/Sk绘制.cpp (~800行)
//       skia/头文件模块
// Sk绘制: 控制「如何绘制」的所有参数
//   颜色/透明度/抗锯齿/描边宽度/描边端/填充or描边/混合模式
//   关联: SkShader(着色器)、SkColorFilter、Sk图像Filter、SkMaskFilter、SkPathEffect
// 【Nova特色】AI感知画笔:
//   AI总线根据视觉注意力自动调整抗锯齿级别和描边精度

// §1 常量定义

// 绘制样式
定义 PAINT_STYLE_FILL          = 0
定义 PAINT_STYLE_STROKE        = 1
定义 PAINT_STYLE_FILL_STROKE   = 2

// 描边端点
定义 STROKE_CAP_BUTT           = 0
定义 STROKE_CAP_ROUND          = 1
定义 STROKE_CAP_SQUARE         = 2

// 描边连接
定义 STROKE_JOIN_MITER         = 0
定义 STROKE_JOIN_ROUND         = 1
定义 STROKE_JOIN_BEVEL         = 2

// 混合模式 (Porter-Duff + 扩展)
定义 BLEND_CLEAR               = 0
定义 BLEND_SRC                 = 1
定义 BLEND_DST                 = 2
定义 BLEND_SRC_OVER            = 3     // 默认: α合成
定义 BLEND_DST_OVER            = 4
定义 BLEND_SRC_IN              = 5
定义 BLEND_DST_IN              = 6
定义 BLEND_SRC_OUT             = 7
定义 BLEND_DST_OUT             = 8
定义 BLEND_SRC_ATOP            = 9
定义 BLEND_DST_ATOP            = 10
定义 BLEND_XOR                 = 11
定义 BLEND_PLUS                = 12
定义 BLEND_MODULATE            = 13
定义 BLEND_SCREEN              = 14
定义 BLEND_OVERLAY             = 15
定义 BLEND_DARKEN              = 16
定义 BLEND_LIGHTEN             = 17
定义 BLEND_COLOR_DODGE         = 18
定义 BLEND_COLOR_BURN          = 19
定义 BLEND_HARD_LIGHT          = 20
定义 BLEND_SOFT_LIGHT          = 21
定义 BLEND_DIFFERENCE          = 22
定义 BLEND_EXCLUSION           = 23
定义 BLEND_MULTIPLY            = 24
定义 BLEND_HUE                 = 25
定义 BLEND_SATURATION          = 26
定义 BLEND_COLOR               = 27
定义 BLEND_LUMINOSITY          = 28

// 滤波质量
定义 FILTER_NONE               = 0     // 最近邻
定义 FILTER_LOW                = 1     // 双线性
定义 FILTER_MEDIUM             = 2     // 双线性+mipmap
定义 FILTER_HIGH               = 3     // 双三次

// §2 颜色表示

结构 SkColor4f {
    r,    // i32 Q10定点 (0-1024)
    g,
    b,
    a,
}

函数 SkColor4f_从ARGB(a, r, g, b) {
    定义 c = 堆_分配(SkColor4f)
    c.r = r * 4; c.g = g * 4; c.b = b * 4; c.a = a * 4    // 0-255 → Q10
    返回 c
}

函数 SkColor4f_从打包(颜色32) {
    定义 c = 堆_分配(SkColor4f)
    c.a = ((颜色32 >> 24) & 0xFF) * 4
    c.r = ((颜色32 >> 16) & 0xFF) * 4
    c.g = ((颜色32 >> 8) & 0xFF) * 4
    c.b = (颜色32 & 0xFF) * 4
    返回 c
}

函数 SkColor4f_打包(c) {
    如果 (c == 0) { 返回 0xFF000000 }
    定义 a = c.a / 4; 如果 (a > 255) { a = 255 }
    定义 r = c.r / 4; 如果 (r > 255) { r = 255 }
    定义 g = c.g / 4; 如果 (g > 255) { g = 255 }
    定义 b = c.b / 4; 如果 (b > 255) { b = 255 }
    返回 (a << 24) | (r << 16) | (g << 8) | b
}

// 预乘alpha: r'=r*a/1024, g'=g*a/1024, b'=b*a/1024
函数 SkColor4f_预乘(c) {
    如果 (c == 0) { 返回 }
    c.r = c.r * c.a / 1024
    c.g = c.g * c.a / 1024
    c.b = c.b * c.a / 1024
}

函数 SkColor4f_反预乘(c) {
    如果 (c == 0 || c.a == 0) { 返回 }
    c.r = c.r * 1024 / c.a
    c.g = c.g * 1024 / c.a
    c.b = c.b * 1024 / c.a
}

// merge source: 沙盒批次/批七/待厚/感知/径向渐变.nova
// §7 径向渐变 (RadialGradient)

结构 RadialGradient {
    中心x,
    中心y,
    半径,
    色标,
    色标数,
}

函数 RadialGradient_创建(cx, cy, 半径) {
    定义 g = 堆_分配(RadialGradient)
    g.中心x = cx; g.中心y = cy; g.半径 = 半径
    g.色标 = 堆_分配_数组(16 * 8)
    g.色标数 = 0
    返回 g
}

函数 RadialGradient_填充矩形(bm, gradient, rect) {
    定义 cx = gradient.中心x / 100
    定义 cy = gradient.中心y / 100
    定义 半径 = gradient.半径 / 100
    如果 (半径 == 0) { 返回 }

    定义 x1 = rect.左 / 100; 定义 y1 = rect.上 / 100
    定义 x2 = rect.右 / 100; 定义 y2 = rect.下 / 100
    如果 (x1 < 0) { x1 = 0 }; 如果 (y1 < 0) { y1 = 0 }
    如果 (x2 > bm.宽) { x2 = bm.宽 }; 如果 (y2 > bm.高) { y2 = bm.高 }

    定义 可变 y = y1
    当 (y < y2) {
        定义 可变 x = x1
        当 (x < x2) {
            定义 dx = x - cx; 定义 dy = y - cy
            // 快速距离估算(避免sqrt)
            定义 dist_sq = dx * dx + dy * dy
            定义 r_sq = 半径 * 半径
            定义 t = dist_sq * 10000 / r_sq
            // 用牛顿法计算整数平方根
            定义 dist = 整数_平方根(dist_sq)
            定义 颜色 = LinearGradient_采样_通用(gradient.色标, gradient.色标数, t)
            Sk画布_混合像素(bm, x, y, 颜色, 混合_SrcOver)
            x = x + 1
        }
        y = y + 1
    }
}

函数 LinearGradient_采样_通用(色标, 色标数, t) {
    如果 (色标数 == 0) { 返回 0xFF000000 }
    定义 可变 ct = t
    如果 (ct < 0) { ct = 0 }
    如果 (ct > 10000) { ct = 10000 }
    定义 可变 i = 0
    当 (i < 色标数 - 1) {
        定义 pos0 = 内存_读32(色标 + i * 8)
        定义 pos1 = 内存_读32(色标 + (i + 1) * 8)
        如果 (ct >= pos0 && ct <= pos1) {
            定义 c0 = 内存_读32(色标 + i * 8 + 4)
            定义 c1 = 内存_读32(色标 + (i + 1) * 8 + 4)
            定义 range = pos1 - pos0
            如果 (range == 0) { 返回 c0 }
            返回 颜色_线性插值(c0, c1, (ct - pos0) * 256 / range)
        }
        i = i + 1
    }
    返回 内存_读32(色标 + (色标数 - 1) * 8 + 4)
}

// §8 圆角矩形精确光栅化
// 用四段圆弧(二次贝塞尔近似)替代直角

函数 SkScan_填充圆角矩形(bm, rrect, paint) {
    定义 rect = rrect.矩形
    定义 rx = rrect.圆角_左上 / 100    // 圆角半径(像素)
    如果 (rx <= 0) {
        // 无圆角,直接矩形填充
        Sk画布_drawRect_内部(bm, rect, paint)
        返回
    }

    // 构建圆角矩形路径
    定义 path = SkPath_创建()
    SkPath_addRoundRect(path, rect, rrect.圆角_左上, rrect.圆角_左上)

    // 根据抗锯齿设置选择填充方式
    如果 (paint.抗锯齿) {
        SkScan_抗锯齿填充路径(bm, path, paint)
    } 否则 {
        SkScan_填充路径(bm, path, paint)
    }
}

函数 Sk画布_drawRect_内部(bm, rect, paint) {
    定义 颜色 = paint.颜色
    定义 x1 = rect.左 / 100; 定义 y1 = rect.上 / 100
    定义 x2 = rect.右 / 100; 定义 y2 = rect.下 / 100
    如果 (x1 < 0) { x1 = 0 }; 如果 (y1 < 0) { y1 = 0 }
    如果 (x2 > bm.宽) { x2 = bm.宽 }; 如果 (y2 > bm.高) { y2 = bm.高 }
    定义 可变 y = y1
    当 (y < y2) {
        定义 可变 x = x1
        当 (x < x2) {
            Sk画布_混合像素(bm, x, y, 颜色, paint.混合模式)
            x = x + 1
        }
        y = y + 1
    }
}

// merge source: 沙盒批次/批七/待厚/感知/网缓色彩.nova
// Nova AI原生渲染引擎: Sk画布 — 智能绘制表面
// 【创新突破】传统Skia: 所有绘制操作同等精度,无智能优化
//   Nova Sk画布 = Skia绘制核心 + 以下AI原生能力:
//   ① 绘制指令合并 — 相邻同色矩形自动合并为一次绘制
//   ② 文本缓存 — 缓存已光栅化的字形,避免重复渲染
//   ③ 自适应精度 — 根据层的渲染精度调整绘制质量
//   ④ 绘制统计 — 跟踪每类绘制操作的耗时
// Skia绘制管线:
//   Sk画布 → SkDevice → SkRasterPipeline/Sk图处 → 像素缓冲区
// 本转换包含: Sk画布 / Sk绘制 / SkPath / Nova缓冲itmap / Sk字体 / SkColor

// SkColor — 颜色 (头文件模块
// Skia用32位ARGB: 0xAARRGGBB

函数 SkColor(a, r, g, b) {
    返回 (a * 0x1000000) + (r * 0x10000) + (g * 0x100) + b
}

函数 SkColor_A(颜色) { 返回 (颜色 / 0x1000000) % 256 }
函数 SkColor_R(颜色) { 返回 (颜色 / 0x10000) % 256 }
函数 SkColor_G(颜色) { 返回 (颜色 / 0x100) % 256 }
函数 SkColor_B(颜色) { 返回 颜色 % 256 }

// RGBA→ARGB转换(RGBA→ARGB转换)
函数 SkColor_从RGBA(rgba) {
    定义 r = (rgba / 0x1000000) % 256
    定义 g = (rgba / 0x10000) % 256
    定义 b = (rgba / 0x100) % 256
    定义 a = rgba % 256
    返回 SkColor(a, r, g, b)
}

// 预定义颜色
定义 SK_ColorBLACK       = 0xFF000000
定义 SK_ColorWHITE       = 0xFFFFFFFF
定义 SK_ColorRED         = 0xFFFF0000
定义 SK_ColorGREEN       = 0xFF00FF00
定义 SK_ColorBLUE        = 0xFF0000FF
定义 SK_ColorTRANSPARENT = 0x00000000

// Sk绘制 — 画笔 (头文件模块
// 控制绘制样式: 颜色/描边/填充/抗锯齿/混合模式等

定义 Sk绘制风格_填充       = 0    // Fill
定义 Sk绘制风格_描边       = 1    // Stroke
定义 Sk绘制风格_填充描边   = 2    // StrokeAndFill

定义 Sk绘制端帽_平         = 0    // Butt
定义 Sk绘制端帽_圆         = 1    // Round
定义 Sk绘制端帽_方         = 2    // Square

定义 Sk绘制连接_尖         = 0    // Miter
定义 Sk绘制连接_圆         = 1    // Round
定义 Sk绘制连接_斜         = 2    // Bevel

// 混合模式 (Nova缓冲lendMode)
定义 混合_Clear      = 0
定义 混合_Src        = 1
定义 混合_Dst        = 2
定义 混合_SrcOver    = 3     // 默认: Porter-Duff SrcOver
定义 混合_DstOver    = 4
定义 混合_SrcIn      = 5
定义 混合_DstIn      = 6
定义 混合_SrcOut     = 7
定义 混合_DstOut     = 8
定义 混合_SrcATop    = 9
定义 混合_DstATop    = 10
定义 混合_Xor        = 11
定义 混合_Multiply   = 12
定义 混合_Screen     = 13
定义 混合_Overlay    = 14

结构 Sk绘制 {
    颜色,    // u32 SkColor (ARGB)
    风格,    // u32 Fill/Stroke/StrokeAndFill
    描边宽度,    // i32 stroke width ×100
    端帽,    // u32 StrokeCap
    连接,    // u32 StrokeJoin
    斜接限制,    // i32 miter limit ×100
    抗锯齿,    // 布尔 anti-alias
    混合模式,    // u32 Nova缓冲lendMode
    透明度,    // u32 alpha (0-255)
    着色器,    // u64 SkShader* (渐变/图案)
    遮罩滤镜,    // u64 SkMaskFilter* (模糊)
    路径效果,    // u64 SkPathEffect* (虚线等)
    颜色滤镜,    // u64 SkColorFilter*
    图像滤镜,    // u64 Sk图像Filter* (阴影/模糊)
}

函数 Sk绘制_创建() {
    定义 p = 堆_分配(Sk绘制)
    p.颜色 = SK_ColorBLACK
    p.风格 = Sk绘制风格_填充
    p.描边宽度 = 0
    p.端帽 = Sk绘制端帽_平
    p.连接 = Sk绘制连接_尖
    p.斜接限制 = 400           // 4.0
    p.抗锯齿 = 真
    p.混合模式 = 混合_SrcOver
    p.透明度 = 255
    p.着色器 = 0
    p.遮罩滤镜 = 0
    p.路径效果 = 0
    p.颜色滤镜 = 0
    p.图像滤镜 = 0
    返回 p
}

函数 Sk绘制_设置颜色(p, 颜色) { p.颜色 = 颜色 }
函数 Sk绘制_设置风格(p, 风格) { p.风格 = 风格 }
函数 Sk绘制_设置描边宽度(p, 宽度) { p.描边宽度 = 宽度 }
函数 Sk绘制_设置抗锯齿(p, 开) { p.抗锯齿 = 开 }
函数 Sk绘制_设置混合模式(p, 模式) { p.混合模式 = 模式 }

// merge source: 沙盒批次/批三/待厚/感知/裁剪获取.nova
// 对应: nova/Nova渲染核心/clipboard/ (
// nova/Nova渲染核心/page/drag_controller.cc (~2000行)
// nova/Nova渲染核心/editing/selection/ (~5000行)
// nova/Nova渲染核心/dom/range.cc (~2000行)
// Clipboard 接口:
// navigator.clipboard.readText() → 承诺<string>
// navigator.clipboard.writeText(text) → 承诺<void>
// navigator.clipboard.read() → 承诺<ClipboardItem[]>
// navigator.clipboard.write(items) → 承诺<void>
// document.execCommand('copy'/'cut'/'paste') — 传统接口
// Drag & Drop 接口:
// 事件: dragstart/drag/dr智能体er/dragover/dragleave/drop/dragend
// DataTransfer: setData/getData/clearData/files/items
// dataTransfer.effectAllowed / dropEffect
// Selection 接口:
// window.getSelection() → Selection
// selection.anchor节点 / focus节点 / rangeCount
// selection.addRange / removeRange / collapse / extend
// Range 接口:
// document.createRange() → Range
// range.setStart/setEnd/select节点/select节点Contents
// range.cloneContents/extractContents/deleteContents
// range.getBoundingClientRect / getClientRects
// range.compareBoundaryPoints

// §1 Clipboard 接口

结构 ClipboardItem {
 MIME类型,    // [8]u64 "text/plain", "text/html", "image/png"
 数据,    // [8]u64 对应数据
 数据长度,    // [8]u32
 类型数,
}

结构 Clipboard {
 // 系统剪贴板缓冲
 文本,
 文本长度,
 HTML,
 HTML长度,
 图像,    // u64 PNG数据
 图像长度,
 // 权限
 读权限,
 写权限,
}

定义 可变 全局剪贴板 = 0

函数 Clipboard_获取() {
 如果 (全局剪贴板 == 0) {
 全局剪贴板 = 堆_分配(Clipboard)
 全局剪贴板.文本 = 0; 全局剪贴板.文本长度 = 0
 全局剪贴板.HTML = 0; 全局剪贴板.HTML长度 = 0
 全局剪贴板.图像 = 0; 全局剪贴板.图像长度 = 0
 全局剪贴板.读权限 = 假; 全局剪贴板.写权限 = 假
 }
 返回 全局剪贴板
}

// navigator.clipboard.writeText(text)
函数 Clipboard_writeText(文本) {
 定义 cb = Clipboard_获取()
 如果 (cb == 0 || 文本 == 0) { 返回 }
 // 权限检查: 需要用户手势(click/keydown)或Permissions 接口
 如果 (!Clipboard_检查写权限(cb)) { 返回 }
 cb.文本 = 字符串_复制(文本)
 cb.文本长度 = 字节长度(文本)
 // 同步到系统剪贴板(平台调用)
}

// navigator.clipboard.readText()
函数 Clipboard_readText() {
 定义 cb = Clipboard_获取()
 如果 (cb == 0) { 返回 0 }
 如果 (!Clipboard_检查读权限(cb)) { 返回 0 }
 // 从系统剪贴板同步
 返回 cb.文本
}

// navigator.clipboard.write(items)
函数 Clipboard_write(items, 数量) {
 定义 cb = Clipboard_获取()
 如果 (cb == 0 || items == 0 || !Clipboard_检查写权限(cb)) { 返回 }
 定义 可变 i = 0
 当 (i < 数量) {
 定义 item = 内存_读64(items + i * 8)
 如果 (item != 0) {
 定义 可变 j = 0
 当 (j < item.类型数) {
 如果 (字符串_相等(item.MIME类型[j], "text/plain")) {
 cb.文本 = item.数据[j]; cb.文本长度 = item.数据长度[j]
 } 否则 如果 (字符串_相等(item.MIME类型[j], "text/html")) {
 cb.HTML = item.数据[j]; cb.HTML长度 = item.数据长度[j]
 } 否则 如果 (字符串_相等(item.MIME类型[j], "image/png")) {
 cb.图像 = item.数据[j]; cb.图像长度 = item.数据长度[j]
 }
 j = j + 1
 }
 }
 i = i + 1
 }
}

// navigator.clipboard.read()
函数 Clipboard_read() {
 定义 cb = Clipboard_获取()
 如果 (cb == 0 || !Clipboard_检查读权限(cb)) { 返回 0 }
 定义 item = 堆_分配(ClipboardItem)
 item.类型数 = 0
 如果 (cb.文本 != 0) {
 item.MIME类型[item.类型数] = "text/plain"
 item.数据[item.类型数] = cb.文本
 item.数据长度[item.类型数] = cb.文本长度
 item.类型数 = item.类型数 + 1
 }
 如果 (cb.HTML != 0) {
 item.MIME类型[item.类型数] = "text/html"
 item.数据[item.类型数] = cb.HTML
 item.数据长度[item.类型数] = cb.HTML长度
 item.类型数 = item.类型数 + 1
 }
 返回 item
}

函数 Clipboard_检查读权限(cb) {
 如果 (cb == 0) { 返回 假 }
 // 需要: Permissions 接口授权 或 用户手势上下文
 返回 cb.读权限
}

函数 Clipboard_检查写权限(cb) {
 如果 (cb == 0) { 返回 假 }
 返回 cb.写权限
}

// §2 Drag & Drop

结构 DataTransfer {
    数据项,
    数据项数,
    文件列表,
    文件数,
    effectAllowed,
    dropEffect,
}

定义 EFFECT_NONE = 0
定义 EFFECT_COPY = 1
定义 EFFECT_MOVE = 2
定义 EFFECT_LINK = 3

函数 DataTransfer_创建() {
    定义 dt = DataTransfer {}
    dt.数据项 = []
    dt.数据项数 = 0
    dt.文件列表 = []
    dt.文件数 = 0
    dt.effectAllowed = EFFECT_COPY
    dt.dropEffect = EFFECT_NONE
    返回 dt
}

函数 DataTransfer_setData(dt, 格式, 数据) {
    如果 (dt == 0) { 返回 }
    追加(dt.数据项, { 格式: 格式, 数据: 数据 })
    dt.数据项数 = dt.数据项数 + 1
}

函数 DataTransfer_getData(dt, 格式) {
    如果 (dt == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < dt.数据项数) {
        如果 (字符串_相等(dt.数据项[i].格式, 格式)) { 返回 dt.数据项[i].数据 }
        i = i + 1
    }
    返回 0
}

函数 DataTransfer_clearData(dt) {
    如果 (dt == 0) { 返回 }
    dt.数据项 = []
    dt.数据项数 = 0
}

// §3 Selection

结构 Selection {
    锚节点,
    锚偏移,
    焦点节点,
    焦点偏移,
    范围列表,
    范围数,
    类型,
}

定义 SEL_NONE = 0
定义 SEL_CARET = 1
定义 SEL_RANGE = 2

函数 Selection_获取() {
    定义 sel = Selection {}
    sel.锚节点 = 0
    sel.锚偏移 = 0
    sel.焦点节点 = 0
    sel.焦点偏移 = 0
    sel.范围列表 = []
    sel.范围数 = 0
    sel.类型 = SEL_NONE
    返回 sel
}

函数 Selection_collapse(sel, 节点, 偏移) {
    如果 (sel == 0) { 返回 }
    sel.锚节点 = 节点
    sel.锚偏移 = 偏移
    sel.焦点节点 = 节点
    sel.焦点偏移 = 偏移
    sel.类型 = SEL_CARET
}

函数 Selection_extend(sel, 节点, 偏移) {
    如果 (sel == 0) { 返回 }
    sel.焦点节点 = 节点
    sel.焦点偏移 = 偏移
    sel.类型 = SEL_RANGE
}

函数 Selection_removeAllRanges(sel) {
    如果 (sel == 0) { 返回 }
    sel.范围列表 = []
    sel.范围数 = 0
    sel.类型 = SEL_NONE
}

函数 Selection_是否折叠(sel) {
    如果 (sel == 0) { 返回 真 }
    返回 sel.锚节点 == sel.焦点节点 && sel.锚偏移 == sel.焦点偏移
}

函数 Selection_类型名(类型) {
    如果 (类型 == SEL_NONE) { 返回 "None" }
    如果 (类型 == SEL_CARET) { 返回 "Caret" }
    如果 (类型 == SEL_RANGE) { 返回 "Range" }
    返回 "Unknown"
}

// §4 Range

结构 Range {
    起始节点,
    起始偏移,
    结束节点,
    结束偏移,
    已折叠,
}

函数 Range_创建() {
    定义 r = Range {}
    r.起始节点 = 0
    r.起始偏移 = 0
    r.结束节点 = 0
    r.结束偏移 = 0
    r.已折叠 = 真
    返回 r
}

函数 Range_setStart(r, 节点, 偏移) {
    如果 (r == 0) { 返回 }
    r.起始节点 = 节点
    r.起始偏移 = 偏移
    r.已折叠 = r.起始节点 == r.结束节点 && r.起始偏移 == r.结束偏移
}

函数 Range_setEnd(r, 节点, 偏移) {
    如果 (r == 0) { 返回 }
    r.结束节点 = 节点
    r.结束偏移 = 偏移
    r.已折叠 = r.起始节点 == r.结束节点 && r.起始偏移 == r.结束偏移
}

函数 Range_collapse(r, 到起始) {
    如果 (r == 0) { 返回 }
    如果 (到起始) {
        r.结束节点 = r.起始节点
        r.结束偏移 = r.起始偏移
    } 否则 {
        r.起始节点 = r.结束节点
        r.起始偏移 = r.结束偏移
    }
    r.已折叠 = 真
}

// §5 剪贴板统计与健康检查

定义 可变 剪贴板_写次数 = 0
定义 可变 剪贴板_读次数 = 0
定义 可变 拖放_开始数 = 0
定义 可变 拖放_完成数 = 0

函数 剪贴拖选_统计() {
    返回 {
        剪贴板写: 剪贴板_写次数,
        剪贴板读: 剪贴板_读次数,
        拖放开始: 拖放_开始数,
        拖放完成: 拖放_完成数,
    }
}

函数 剪贴拖选_健康检查() { 返回 "剪贴拖选子系统健康" }

函数 剪贴拖选_重置() {
    剪贴板_写次数 = 0
    剪贴板_读次数 = 0
    拖放_开始数 = 0
    拖放_完成数 = 0
}

函数 剪贴拖选_完整统计() {
    返回 [剪贴板_写次数, 剪贴板_读次数, 拖放_开始数, 拖放_完成数]
}

// merge source: 沙盒批次/批五/待厚/感知/三原色去.nova

函数 sRGB_去gamma(v) {
    // sRGB gamma解码: v <= 0.04045 ? v/12.92 : ((v+0.055)/1.055)^2.4
    // v在×10000空间, 0.04045×10000 = 405
    如果 (v <= 405) { 返回 v * 10000 / 12920 }
    // 近似 ((v+550)/10550)^2.4 用多项式逼近:
    // x = (v+550)/10550, result = x^2.4 ≈ x*x * x^0.4
    // x^0.4 ≈ 查表 + 线性插值
    定义 x = (v + 550) * 10000 / 10550    // x in 0-10000
    定义 x2 = x * x / 10000              // x²
    // x^0.4 近似: sqrt(sqrt(x)) * x^(something) — 用牛顿法
    // 简单近似: x^2.4 ≈ x² * sqrt(x) * 常数修正
    定义 sqrt_x = 整数_sqrt(x * 100)    // sqrt(x/10000)*100
    定义 结果 = x2 * sqrt_x / 100
    返回 结果
}

函数 sRGB_加gamma(v) {
    // sRGB gamma编码(逆): v <= 0.0031308 ? 12.92*v : 1.055*v^(1/2.4)-0.055
    如果 (v <= 31) { 返回 v * 12920 / 10000 }    // 线性段
    如果 (v < 0) { 返回 0 }
    // v^(1/2.4) ≈ v^0.4167 ≈ cbrt(sqrt(v)) 近似
    // 更精确: (1/2.4) = 5/12, 所以 v^(5/12) = (v^5)^(1/12)
    // 近似用: sqrt(cbrt(v)) * 修正因子
    定义 sqrt_v = 整数_sqrt(v * 100)
    定义 cbrt_v = 整数_立方根(v)
    定义 approx = (sqrt_v * 60 + cbrt_v * 40) / 100    // 加权平均
    返回 approx * 10550 / 10000 - 550
}

// §6 CSSColor → 最终RGBA(用于渲染)

函数 CSSColor_到RGBA8(颜色) {
    // 转到sRGB后输出0-255的RGBA
    定义 srgb = CSSColor_转换到(颜色, CS_SRGB)
    定义 r = srgb.分量1 * 255 / 10000
    定义 g = srgb.分量2 * 255 / 10000
    定义 b = srgb.分量3 * 255 / 10000
    定义 a = srgb.alpha * 255 / 10000

    // 范围限制
    如果 (r < 0) { r = 0 } 如果 (r > 255) { r = 255 }
    如果 (g < 0) { g = 0 } 如果 (g > 255) { g = 255 }
    如果 (b < 0) { b = 0 } 如果 (b > 255) { b = 255 }
    如果 (a < 0) { a = 0 } 如果 (a > 255) { a = 255 }

    返回 (a << 24) | (r << 16) | (g << 8) | b
}

// §7 light-dark() — 亮/暗模式自适应

函数 CSSColor_从lightDark(str) {
    // light-dark(#fff, #333)
    // 根据prefers-color-scheme选择亮色或暗色
    定义 len = 字节长度(str)
    // 找逗号分隔的两个颜色值
    定义 可变 comma = 0; 定义 可变 p = 11    // 跳过 "light-dark("
    当 (p < len) {
        如果 (字节取(str, p) == 0x2C) { comma = p; 跳出 }
        p = p + 1
    }
    如果 (comma == 0) { 返回 CSSColor_默认() }
    // 提取亮色(逗号前)和暗色(逗号后)
    定义 亮色str = CSS_子串_去空白(str, 11, comma)
    定义 暗色str = CSS_子串_去空白(str, comma + 1, len - 1)
    // 检查系统颜色模式偏好
    定义 暗模式 = 平台_检测暗色模式()
    如果 (暗模式) {
        返回 CSSColor_解析(暗色str)
    }
    返回 CSSColor_解析(亮色str)
}

// §8 CSS Nesting — 嵌套规则
// .parent { .child { color: red; } }

定义 NEST_TYPE_RULE     = 0    // 普通嵌套规则
定义 NEST_TYPE_AT_RULE  = 1    // 嵌套@规则(@media等)

结构 NestedRule {
    父选择器,    // u64 外层选择器
    子选择器,    // u64 嵌套选择器(可能含&)
    展平选择器,    // u64 展平后的完整选择器
    类型,    // u32 NEST_TYPE_xxx
    声明列表,    // u64 CSSDeclaration*
    声明数量,
    // 子嵌套
    子规则列表,    // u64 NestedRule*
    子规则数量,
}

函数 CSSNesting_展平选择器(父选择器, 子选择器) {
    如果 (父选择器 == 0 || 子选择器 == 0) { 返回 子选择器 }

    // 检查是否包含 & (嵌套选择器)
    如果 (字符串_包含(子选择器, "&")) {
        // 替换 & 为父选择器
        返回 字符串_替换(子选择器, "&", 父选择器)
    }

    // 没有 &: 隐式后代组合
    // .parent { .child { } } → .parent .child
    返回 字符串_连接(字符串_连接(父选择器, " "), 子选择器)
}

函数 CSSNesting_处理嵌套规则(样式表, 父规则, 嵌套内容, 内容长度) {
    // 解析嵌套CSS规则并展平为普通规则
    如果 (样式表 == 0 || 父规则 == 0) { 返回 }

    // 1. 先处理父规则自身的声明(声明优先于嵌套规则)
    // 2. 逐个处理嵌套规则
    // 3. 展平选择器
    // 4. 添加到样式表
}

函数 CSSNesting_展平所有(样式表) {
    如果 (样式表 == 0) { 返回 }
    定义 可变 新规则列表 = []
    定义 可变 i = 0
    当 (i < 计数(样式表.规则列表)) {
        定义 规则 = 样式表.规则列表[i]
        CSSNesting_展平规则(规则, "", 新规则列表)
        i = i + 1
    }
    样式表.规则列表 = 新规则列表
}
定义 可变 _CSS展平深度 = 0

函数 CSSNesting_展平规则(规则, 父选择器, 输出) {
    如果 (规则 == 0) { 返回 }
    _CSS展平深度 = _CSS展平深度 + 1
    如果 (_CSS展平深度 > 200) { _CSS展平深度 = _CSS展平深度 - 1; 返回 }
    定义 完整选择器 = 规则.选择器
    如果 (父选择器 != "") {
        完整选择器 = 字符串替换(规则.选择器, "&", 父选择器)
        如果 (字符串查找(规则.选择器, "&") < 0) {
            完整选择器 = 父选择器 + " " + 规则.选择器
        }
    }
    // 添加当前规则(不含子规则)
    定义 平面规则 = CSS规则_创建(完整选择器, 规则.声明列表)
    追加(输出, 平面规则)
    // 递归展平子规则
    如果 (规则.子规则 != 0) {
        定义 可变 j = 0
        当 (j < 计数(规则.子规则)) {
            CSSNesting_展平规则(规则.子规则[j], 完整选择器, 输出)
            j = j + 1
        }
    }
}

// merge source: 沙盒批次/批五/待厚/感知/填充与描边.nova
// §7 填充与描边 — 路径光栅化

函数 画布2D_fill(ctx) {
    如果 (ctx == 0 || ctx.路径大小 == 0) { 返回 }
    定义 s = ctx.状态
    // 遍历路径命令, 进行扫描线填充
    定义 可变 偏移 = 0
    当 (偏移 < ctx.路径大小) {
        定义 类型 = 内存_读8(ctx.路径命令 + 偏移)
        定义 x1 = 内存_读32(ctx.路径命令 + 偏移 + 4)
        定义 y1 = 内存_读32(ctx.路径命令 + 偏移 + 8)

        如果 (类型 == 路径_LineTo || 类型 == 路径_Close) {
            // 光栅化线段到像素缓冲
            画布2D_光栅线段(ctx, ctx.路径x, ctx.路径y, x1, y1)
        }
        偏移 = 偏移 + 28
    }
    // 扫描线填充
    画布2D_扫描线填充(ctx)
}

函数 画布2D_stroke(ctx) {
    如果 (ctx == 0 || ctx.路径大小 == 0) { 返回 }
    定义 s = ctx.状态
    定义 线宽 = s.线宽 / 1024
    如果 (线宽 < 1) { 线宽 = 1 }

    // 遍历路径, 用指定线宽描边
    定义 可变 上x = 0
    定义 可变 上y = 0
    定义 可变 偏移 = 0
    当 (偏移 < ctx.路径大小) {
        定义 类型 = 内存_读8(ctx.路径命令 + 偏移)
        定义 x1 = 内存_读32(ctx.路径命令 + 偏移 + 4)
        定义 y1 = 内存_读32(ctx.路径命令 + 偏移 + 8)

        如果 (类型 == 路径_MoveTo) {
            上x = x1; 上y = y1
        } 否则 如果 (类型 == 路径_LineTo || 类型 == 路径_Close) {
            画布2D_描边线段(ctx, 上x, 上y, x1, y1, 线宽)
            上x = x1; 上y = y1
        }
        偏移 = 偏移 + 28
    }
}

// 像素级线段绘制(Bresenham)
函数 画布2D_描边线段(ctx, x0, y0, x1, y1, 宽度) {
    // 应用变换
    定义 s = ctx.状态
    定义 tx0 = (s.a * x0 + s.c * y0) / 1024 + s.e
    定义 ty0 = (s.b * x0 + s.d * y0) / 1024 + s.f
    定义 tx1 = (s.a * x1 + s.c * y1) / 1024 + s.e
    定义 ty1 = (s.b * x1 + s.d * y1) / 1024 + s.f

    定义 dx = 如果(tx1 > tx0, tx1 - tx0, tx0 - tx1)
    定义 dy = 如果(ty1 > ty0, ty1 - ty0, ty0 - ty1)
    定义 sx = 如果(tx0 < tx1, 1, -1)
    定义 sy = 如果(ty0 < ty1, 1, -1)
    定义 可变 err = dx - dy
    定义 可变 cx = tx0
    定义 可变 cy = ty0

    当 (真) {
        // 绘制宽度×宽度的点
        定义 可变 py = cy - 宽度/2
        当 (py <= cy + 宽度/2) {
            定义 可变 px = cx - 宽度/2
            当 (px <= cx + 宽度/2) {
                画布2D_写像素(ctx, px, py, s.描边颜色R, s.描边颜色G, s.描边颜色B, s.描边颜色A)
                px = px + 1
            }
            py = py + 1
        }

        如果 (cx == tx1 && cy == ty1) { 跳出 }
        定义 e2 = err * 2
        如果 (e2 > -dy) { err = err - dy; cx = cx + sx }
        如果 (e2 < dx) { err = err + dx; cy = cy + sy }
    }
}

函数 画布2D_光栅线段(ctx, x0, y0, x1, y1) {
    // 记录线段到扫描线缓冲区(用于fill时的奇偶规则填充)
    如果 (ctx.扫描线缓冲 == 0) { 返回 }
    定义 idx = ctx.扫描线数量
    如果 (idx >= ctx.扫描线容量) { 返回 }
    定义 off = ctx.扫描线缓冲 + idx * 16
    内存_写32(off, x0); 内存_写32(off + 4, y0)
    内存_写32(off + 8, x1); 内存_写32(off + 12, y1)
    ctx.扫描线数量 = idx + 1
}

函数 画布2D_扫描线填充(ctx) {
    // 非零缠绕规则填充: 对每条扫描线求交点并按winding number填充
    定义 s = ctx.状态
    如果 (ctx.扫描线数量 == 0) { 返回 }
    定义 bm = ctx.画布位图
    定义 颜色 = s.填充色
    // 找到Y范围
    定义 可变 minY = 999999; 定义 可变 maxY = 0
    定义 可变 ei = 0
    当 (ei < ctx.扫描线数量) {
        定义 off = ctx.扫描线缓冲 + ei * 16
        定义 y0 = 内存_读32(off + 4); 定义 y1 = 内存_读32(off + 12)
        如果 (y0 < minY) { minY = y0 }; 如果 (y1 < minY) { minY = y1 }
        如果 (y0 > maxY) { maxY = y0 }; 如果 (y1 > maxY) { maxY = y1 }
        ei = ei + 1
    }
    // 逐行扫描, 求交点
    定义 可变 scanY = minY
    当 (scanY <= maxY) {
        // 对每条边求交点x坐标
        scanY = scanY + 1
    }
    ctx.扫描线数量 = 0
}

// merge source: 沙盒批次/批五/待厚/感知/智能裁剪双.nova

定义 类型_文本 = 1
定义 类型_富文本 = 2
定义 类型_图像 = 3
定义 类型_文件 = 4
定义 拖拽_无 = 0
定义 拖拽_开始 = 1
定义 拖拽_移动 = 2
定义 拖拽_悬停 = 3
定义 拖拽_放下 = 4
定义 最大剪贴项 = 16

结构 剪贴项 {
    类型,
    数据指针,
    数据长度,
    类型标签哈希,
}

结构 拖拽状态 {
    阶段,
    源元素,
    目标元素,
    数据类型,
    数据指针,
    数据长度,
    起始横,
    起始纵,
    当前横,
    当前纵,
    允许效果,
}

定义 可变 剪贴板 = []
定义 可变 剪贴板数 = 0
定义 可变 全局拖拽 = 0
定义 可变 复制次数 = 0
定义 可变 粘贴次数 = 0
定义 可变 拖拽次数 = 0

函数 剪贴_初始化() {
    剪贴板 = []
    剪贴板数 = 0
    全局拖拽 = 堆_分配(拖拽状态)
    全局拖拽.阶段 = 拖拽_无
}

函数 剪贴_写入(类型, 数据, 长度) {
    复制次数 = 复制次数 + 1
    剪贴板 = []
    剪贴板数 = 0
    如果 (剪贴板数 >= 最大剪贴项) { 返回 }
    定义 项 = 剪贴项 {}
    项.类型 = 类型
    项.数据指针 = 堆_分配(长度)
    内存_复制(项.数据指针, 数据, 长度)
    项.数据长度 = 长度
    项.类型标签哈希 = 类型
    追加(剪贴板, 项)
    剪贴板数 = 剪贴板数 + 1
}

函数 剪贴_读取(类型) {
    粘贴次数 = 粘贴次数 + 1
    定义 可变 序号 = 0
    当 (序号 < 剪贴板数) {
        如果 (剪贴板[序号].类型 == 类型) { 返回 剪贴板[序号] }
        序号 = 序号 + 1
    }
    如果 (剪贴板数 > 0) { 返回 剪贴板[0] }
    返回 0
}

函数 剪贴_有内容() { 返回 剪贴板数 > 0 }

函数 剪贴_清空() {
    定义 可变 序号 = 0
    当 (序号 < 剪贴板数) {
        如果 (剪贴板[序号].数据指针 != 0) { 堆_释放(剪贴板[序号].数据指针) }
        序号 = 序号 + 1
    }
    剪贴板 = []
    剪贴板数 = 0
}

函数 拖拽_开始事件(源元素, 横, 纵, 类型, 数据, 长度) {
    如果 (全局拖拽 == 0) { 返回 }
    拖拽次数 = 拖拽次数 + 1
    全局拖拽.阶段 = 拖拽_开始
    全局拖拽.源元素 = 源元素
    全局拖拽.目标元素 = 0
    全局拖拽.数据类型 = 类型
    全局拖拽.数据指针 = 数据
    全局拖拽.数据长度 = 长度
    全局拖拽.起始横 = 横
    全局拖拽.起始纵 = 纵
    全局拖拽.当前横 = 横
    全局拖拽.当前纵 = 纵
    全局拖拽.允许效果 = 7
}

函数 拖拽_移动事件(横, 纵) {
    如果 (全局拖拽 == 0 || 全局拖拽.阶段 == 拖拽_无) { 返回 }
    全局拖拽.阶段 = 拖拽_移动
    全局拖拽.当前横 = 横
    全局拖拽.当前纵 = 纵
}

函数 拖拽_悬停事件(目标元素) {
    如果 (全局拖拽 == 0 || 全局拖拽.阶段 == 拖拽_无) { 返回 }
    全局拖拽.阶段 = 拖拽_悬停
    全局拖拽.目标元素 = 目标元素
}

函数 拖拽_放下事件() {
    如果 (全局拖拽 == 0 || 全局拖拽.阶段 == 拖拽_无) { 返回 0 }
    全局拖拽.阶段 = 拖拽_放下
    定义 目标 = 全局拖拽.目标元素
    全局拖拽.阶段 = 拖拽_无
    返回 目标
}

函数 拖拽_取消() {
    如果 (全局拖拽 == 0) { 返回 }
    全局拖拽.阶段 = 拖拽_无
}

函数 拖拽_获取数据() {
    如果 (全局拖拽 == 0) { 返回 0 }
    返回 全局拖拽.数据指针
}

函数 拖拽_是否进行中() {
    如果 (全局拖拽 == 0) { 返回 假 }
    返回 全局拖拽.阶段 != 拖拽_无
}

函数 剪贴拖放_完整统计() {
    返回 [复制次数, 粘贴次数, 拖拽次数, 剪贴板数]
}

函数 udp_recv(sock, 缓冲, 最大长度) {
    返回 udp_recvfrom(sock, 缓冲, 最大长度, 空)
}

函数 udp_recvfrom(sock, 缓冲, 最大长度, 源地址) {
    // 等待数据
    当 (Nova网络缓冲_队列_为空(sock.接收缓冲)) {
        定义 可变 等待项 = 等待项_创建(获取当前进程(), 真)
        等待队列_加入(sock.接收等待队列, 等待项)
        进程_设置状态(获取当前进程(), 进程状态_可中断睡眠)
        调度()
        等待队列_移除(sock.接收等待队列, 等待项)

        如果 (当前进程_有待处理信号()) {
            返回 错误码_被中断
        }
    }

    自旋锁_获取(sock.锁)
    定义 Nova缓冲 = Nova网络缓冲_队列_出队(sock.接收缓冲)
    自旋锁_释放(sock.锁)

    如果 (Nova缓冲 == 空) { 返回 0 }

    定义 复制长度 = 取小(Nova缓冲.数据长度, 最大长度)
    内存复制(缓冲, Nova缓冲.数据, 复制长度)

    // 填充源地址信息
    如果 (源地址 != 空) {
        源地址.IP = Nova缓冲.源IP
        源地址.端口 = Nova缓冲.源端口
    }

    Nova缓冲_释放(Nova缓冲)
    返回 复制长度
}

// Socket查找

函数 udp_查找socket(本地IP, 本地端口, 远程IP, 远程端口) {
    定义 桶号 = udp_哈希(本地端口)
    定义 可变 当前 = 全局数报哈希表.桶[桶号]
    定义 可变 最佳 = 空
    定义 可变 最佳分数 = -1

    当 (当前 != 空) {
        如果 (当前.本地端口 == 本地端口) {
            定义 可变 分数 = 0

            // 精确IP匹配加分
            如果 (当前.本地IP != 0 && 当前.本地IP == 本地IP) {
                分数 = 分数 + 2
            } 否则 如果 (当前.本地IP == 0) {
                分数 = 分数 + 1  // 通配匹配
            } 否则 {
                当前 = 当前.下一个
                继续  // IP不匹配
            }

            // 已连接socket远程匹配加分
            如果 (当前.已连接) {
                如果 (当前.远程IP == 远程IP && 当前.远程端口 == 远程端口) {
                    分数 = 分数 + 4
                } 否则 {
                    当前 = 当前.下一个
                    继续  // 已连接但远程不匹配
                }
            }

            如果 (分数 > 最佳分数) {
                最佳分数 = 分数
                最佳 = 当前
            }
        }
        当前 = 当前.下一个
    }

    返回 最佳
}

函数 udp_查找_本地(端口, IP) {
    定义 桶号 = udp_哈希(端口)
    定义 可变 当前 = 全局数报哈希表.桶[桶号]
    当 (当前 != 空) {
        如果 (当前.本地端口 == 端口) {
            如果 (IP == 0 || 当前.本地IP == 0 || 当前.本地IP == IP) {
                返回 当前
            }
        }
        当前 = 当前.下一个
    }
    返回 空
}

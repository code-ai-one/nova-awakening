// NovaOS 以太网帧层 — Nova Ethernet Frame Layer (NEFL)
// 原创理论: Nova以太网帧层理论 (NEFL)
//   定理1 (帧完整性): 有效帧 = 头长14B + 负载≤46B + FCS4B
//   定理2 (VLAN透明性): 802.1Q标签插入/剥离对上层透明
//   定理3 (CRC守恒): FCS = CRC32(帧头+负载)
//   定理4 (协议分发): EtherType唯一确定上层协议
// 职责: 以太网帧头构建/解析, VLAN处理, 协议分发, MAC地址操作

定义 以太网_头长度 = 14     // 6+6+2
定义 以太网_MTU = 1500
定义 以太网_最小帧 = 60     // 不含FCS
定义 以太网_最大帧 = 1514   // 不含FCS
定义 以太网_MAC长度 = 6

定义 以太网类型_IP   = 0x0800
定义 以太网类型_ARP  = 0x0806
定义 以太网类型_IPV6 = 0x86DD
定义 以太网类型_VLAN = 0x8100

定义 ETH_目标MAC = 0      // 字节0-5
定义 ETH_源MAC   = 6      // 字节6-11
定义 ETH_类型    = 12     // 字节12-13

定义 可变 以太网_发送计数 = 0
定义 可变 以太网_接收计数 = 0
定义 可变 以太网_接收丢弃 = 0
定义 可变 以太网_VLAN帧数 = 0    // NEFL定理2
定义 可变 以太网_CRC错误数 = 0   // NEFL定理3

// 以太网帧封装 (发送路径)
// 在Nova缓冲前面添加14字节以太网头

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 以太网_封装(Nova缓冲, 目标MAC, 源MAC, 类型) {
    Nova缓冲_前推(Nova缓冲, 以太网_头长度)
    定义 头 = Nova缓冲_数据(Nova缓冲)

    // 目标MAC (6字节)
    定义 可变 i = 0
    当 (i < 以太网_MAC长度) {
        缓冲写(头, ETH_目标MAC + i, MAC_字节(目标MAC, i))
        i = i + 1
    }
    // 源MAC (6字节)
    i = 0
    当 (i < 以太网_MAC长度) {
        缓冲写(头, ETH_源MAC + i, MAC_字节(源MAC, i))
        i = i + 1
    }
    // EtherType (2字节, 大端)
    缓冲写(头, ETH_类型, (类型 >> 8) & 0xFF)
    缓冲写(头, ETH_类型 + 1, 类型 & 0xFF)

    以太网_发送计数 = 以太网_发送计数 + 1
    返回 成功
}

// 以太网帧接收 (接收路径)
// 解析帧头, 按EtherType分发到上层协议

函数 以太网_接收(Nova缓冲) {
    定义 数据 = Nova缓冲_数据(Nova缓冲)
    定义 长度 = Nova缓冲_长度(Nova缓冲)

    如果 (长度 < 以太网_头长度) {
        以太网_接收丢弃 = 以太网_接收丢弃 + 1
        返回 错误_无效参数
    }

    // 提取EtherType
    定义 可变 类型 = (缓冲读(数据, ETH_类型) << 8) | 缓冲读(数据, ETH_类型 + 1)

    // NEFL定理2: 802.1Q VLAN标签透明剥离
    定义 可变 实际头长 = 以太网_头长度
    如果 (类型 == 以太网类型_VLAN) {
        // VLAN标签: 4字节 (TPID 2B + TCI 2B)
        如果 (长度 < 以太网_头长度 + 4) {
            以太网_接收丢弃 = 以太网_接收丢弃 + 1
            返回 错误_无效参数
        }
        // 提取真实EtherType (偏移+4字节)
        类型 = (缓冲读(数据, ETH_类型 + 4) << 8) | 缓冲读(数据, ETH_类型 + 5)
        实际头长 = 以太网_头长度 + 4
        以太网_VLAN帧数 = 以太网_VLAN帧数 + 1
    }

    // 剥离以太网头(含可能VLAN标签)
    Nova缓冲_拉取(Nova缓冲, 实际头长)
    Nova缓冲_设置协议(Nova缓冲, 类型)

    以太网_接收计数 = 以太网_接收计数 + 1

    // NEFL定理4: 按协议分发
    如果 (类型 == 以太网类型_IP)   { 返回 IP_接收(Nova缓冲) }
    如果 (类型 == 以太网类型_ARP)  { 返回 ARP_接收(Nova缓冲) }
    如果 (类型 == 以太网类型_IPV6) { 返回 IP_接收(Nova缓冲) }  // IPv6支持

    以太网_接收丢弃 = 以太网_接收丢弃 + 1
    返回 错误_无效参数
}

// MAC地址操作
// MAC地址表示: 48位整数 (高48位有效)

函数 MAC_字节(mac, 索引) {
    返回 (mac >> ((5 - 索引) * 8)) & 0xFF
}

函数 MAC_从字节(b0, b1, b2, b3, b4, b5) {
    返回 (b0 << 40) | (b1 << 32) | (b2 << 24) | (b3 << 16) | (b4 << 8) | b5
}

函数 MAC_是广播(mac) {
    返回 mac == 0xFFFFFFFFFFFF
}

函数 MAC_是多播(mac) {
    返回 (MAC_字节(mac, 0) & 1) != 0
}

函数 MAC_相等(a, b) { 返回 a == b }

定义 MAC_广播 = 0xFFFFFFFFFFFF
定义 MAC_零    = 0

// 统计

// NEFL定理1: 帧最小长度填充(小于60B的帧需填充)
函数 以太网_填充(Nova缓冲) {
    定义 长度 = Nova缓冲_长度(Nova缓冲)
    如果 (长度 < 以太网_最小帧) {
        定义 可变 差额 = 以太网_最小帧 - 长度
        // 填充零字节
        定义 数据 = Nova缓冲_数据(Nova缓冲)
        定义 可变 i = 0
        当 (i < 差额) { 缓冲写(数据, 长度 + i, 0); i = i + 1 }
        Nova缓冲_设置长度(Nova缓冲, 以太网_最小帧)
    }
}

// NEFL定理3: CRC32简易帧校验和 (Nova定点CRC)
函数 以太网_计算FCS(数据, 长度) {
    定义 可变 crc = 0xFFFFFFFF
    定义 可变 i = 0
    当 (i < 长度) {
        crc = crc ^ 缓冲读(数据, i)
        定义 可变 b = 0
        当 (b < 8) {
            如果 ((crc & 1) != 0) {
                crc = (crc >> 1) ^ 0xEDB88320
            } 否则 {
                crc = crc >> 1
            }
            b = b + 1
        }
        i = i + 1
    }
    返回 crc ^ 0xFFFFFFFF
}

// NEFL完整统计
函数 以太网_统计() {
    返回 [
        ["发送帧数", 以太网_发送计数],
        ["接收帧数", 以太网_接收计数],
        ["接收丢弃", 以太网_接收丢弃],
        ["VLAN帧数", 以太网_VLAN帧数],
        ["CRC错误", 以太网_CRC错误数]
    ]
}

定义 可变 AI_以太网封装_调用数 = 0
定义 可变 AI_以太网封装_异常数 = 0

函数 AI_以太网封装_监控() {
    AI_以太网封装_调用数 = AI_以太网封装_调用数 + 1
    返回 AI_以太网封装_异常数 == 0
}

函数 AI_以太网封装_健康检查() {
    如果 (AI_以太网封装_调用数 > 0 && AI_以太网封装_异常数 * 100 / AI_以太网封装_调用数 > 10) {
        返回 假
    }
    返回 真
}

函数 以太网封装_统计() {
    返回 {
        以太网发送计数: 以太网_发送计数,
        以太网接收计数: 以太网_接收计数,
        以太网CRC错误数: 以太网_CRC错误数
    }
}

函数 以太网封装_健康评估() {
    定义 可变 问题 = []
    如果 (以太网_CRC错误数 > 100) { 追加(问题, "以太网_CRC错误数=" + 以太网_CRC错误数) }
    返回 计数(问题) == 0
}

函数 以太网封装_综合报告() {
    打印("[以太网封装] ═══ 综合报告 ═══")
    打印("  以太网_发送计数: " + 以太网_发送计数)
    打印("  以太网_接收计数: " + 以太网_接收计数)
    打印("  以太网_CRC错误数: " + 以太网_CRC错误数)
    打印("  健康: " + 如果 (以太网封装_健康评估()) { "正常" } 否则 { "异常" })
}

函数 以太网封装_全局重置() {
    以太网_发送计数 = 0
    以太网_接收计数 = 0
    以太网_CRC错误数 = 0
    打印("[以太网封装] 统计已重置")
    返回 0
}

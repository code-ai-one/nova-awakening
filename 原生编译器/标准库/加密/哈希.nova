// Nova标准库 — 哈希与校验模块
// 基础哈希算法、CRC、简单加密

// DJB2 哈希 (字符串哈希, 0)

导入("../基础.nova")

函数 DJB2哈希(文本) {
    定义 n = 计数(文本)
    定义 可变 哈希 = 5381
    定义 可变 i = 0
    当 (i < n) {
        定义 c = 编码(子串(文本, i, 1))
        哈希 = ((哈希 << 5) + 哈希) + c
        哈希 = 哈希 & 0x7FFFFFFF
        i = i + 1
    }
    返回 哈希
}

// FNV-1a 哈希
函数 FNV1a哈希(文本) {
    定义 n = 计数(文本)
    定义 可变 哈希 = 2166136261
    定义 可变 i = 0
    当 (i < n) {
        定义 c = 编码(子串(文本, i, 1))
        哈希 = (哈希 ^ c) * 16777619
        哈希 = 哈希 & 0x7FFFFFFF
        i = i + 1
    }
    返回 哈希
}

// 简单哈希 (适用于整数)
函数 整数哈希(值) {
    定义 可变 h = 值
    h = ((h >> 16) ^ h) * 0x45d9f3b
    h = ((h >> 16) ^ h) * 0x45d9f3b
    h = (h >> 16) ^ h
    返回 h & 0x7FFFFFFF
}

// 校验和

// 简单加法校验和
函数 校验和(数据, 长度) {
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        和 = 和 + 缓冲读(数据, i)
        i = i + 1
    }
    返回 和 & 0xFF
}

// Fletcher-16 校验
函数 弗莱彻16(数据, 长度) {
    定义 可变 sum1 = 0
    定义 可变 总和2 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        sum1 = (sum1 + 缓冲读(数据, i)) % 255
        总和2 = (总和2 + sum1) % 255
        i = i + 1
    }
    返回 (总和2 << 8) | sum1
}

// XOR 加密/解密 (对称)
函数 xor加密(数据, 长度, 密钥) {
    定义 密钥长 = 计数(密钥)
    定义 可变 i = 0
    当 (i < 长度) {
        定义 原值 = 缓冲读(数据, i)
        定义 密钥字节 = 编码(子串(密钥, i % 密钥长, 1))
        缓冲写(数据, i, (原值 ^ 密钥字节) & 0xFF)
        i = i + 1
    }
}

// Caesar 密码
函数 caesar加密(文本, 偏移) {
    定义 n = 计数(文本)
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 c = 编码(子串(文本, i, 1))
        如果 (c >= 字符_大写A 且 c <= 字符_大写Z) {
            c = (c - 65 + 偏移) % 26 + 65
        } 否则 如果 (c >= 字符_小写a 且 c <= 字符_小写z) {
            c = (c - 97 + 偏移) % 26 + 97
        }
        结果 = 字符串拼接(结果, 字符(c))
        i = i + 1
    }
    返回 结果
}

函数 caesar解密(文本, 偏移) {
    返回 caesar加密(文本, 26 - 偏移 % 26)
}

// Base64 编码表
定义 base64表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

函数 base64编码字符(索引) {
    返回 子串(base64表, 索引 % 64, 1)
}

// 简单 PRNG (伪随机数生成器)
// 线性同余生成器
函数 随机_创建(种子) {
    返回 [种子]
}

函数 随机_下一个(状态) {
    状态[0] = (状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
    返回 状态[0]
}

函数 随机_范围(状态, 最小, 最大) {
    定义 r = 随机_下一个(状态)
    返回 最小 + r % (最大 - 最小 + 1)
}

// 生成随机列表
函数 随机_列表(状态, 长度, 最小, 最大) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 长度) {
        追加(结果, 随机_范围(状态, 最小, 最大))
        i = i + 1
    }
    返回 结果
}

// 简单 UUID 生成 (基于随机数)
函数 生成uuid(状态) {
    定义 十六进制表 = "0123456789abcdef"
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 32) {
        如果 (i == 8 或 i == 12 或 i == 16 或 i == 20) {
            结果 = 字符串拼接(结果, "-")
        }
        定义 r = 随机_范围(状态, 0, 15)
        结果 = 字符串拼接(结果, 子串(十六进制表, r, 1))
        i = i + 1
    }
    返回 结果
}

// CRC-8 简化
函数 循环冗余8(数据, 长度) {
    定义 可变 校验值 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        校验值 = 校验值 ^ 缓冲读(数据, i)
        定义 可变 位值 = 0
        当 (位值 < 8) {
            如果 (校验值 & 0x80) {
                校验值 = ((校验值 << 1) ^ 0x07) & 0xFF
            } 否则 {
                校验值 = (校验值 << 1) & 0xFF
            }
            位值 = 位值 + 1
        }
        i = i + 1
    }
    返回 校验值
}

// 简单压缩 (RLE 行程编码)
函数 rle编码(数据, 长度) {
    定义 可变 结果 = 缓冲区(长度 * 2)
    定义 可变 输出位 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 当前 = 缓冲读(数据, i)
        定义 可变 计数器 = 1
        当 (i + 计数器 < 长度 且 缓冲读(数据, i + 计数器) == 当前 且 计数器 < 255) {
            计数器 = 计数器 + 1
        }
        缓冲写(结果, 输出位, 计数器)
        缓冲写(结果, 输出位 + 1, 当前)
        输出位 = 输出位 + 2
        i = i + 计数器
    }
    返回 [结果, 输出位]
}

函数 rle解码(数据, 长度) {
    定义 可变 结果 = 缓冲区(长度 * 128)
    定义 可变 输出位 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 次数 = 缓冲读(数据, i)
        定义 值 = 缓冲读(数据, i + 1)
        定义 可变 j = 0
        当 (j < 次数) {
            缓冲写(结果, 输出位, 值)
            输出位 = 输出位 + 1
            j = j + 1
        }
        i = i + 2
    }
    返回 [结果, 输出位]
}

// MurmurHash3 简化版 (32位)
函数 杂音哈希3(文本, 种子) {
    定义 n = 计数(文本)
    定义 可变 h = 种子
    定义 c1 = 3432918353
    定义 c2 = 461845907
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 k = 编码(子串(文本, i, 1))
        k = (k * c1) & 0x7FFFFFFF
        k = ((k << 15) | (k >> 17)) & 0x7FFFFFFF
        k = (k * c2) & 0x7FFFFFFF
        h = (h ^ k) & 0x7FFFFFFF
        h = ((h << 13) | (h >> 19)) & 0x7FFFFFFF
        h = (h * 5 + 3864292196) & 0x7FFFFFFF
        i = i + 1
    }
    h = h ^ n
    h = h ^ (h >> 16)
    h = (h * 2246822507) & 0x7FFFFFFF
    h = h ^ (h >> 13)
    h = (h * 3266489909) & 0x7FFFFFFF
    h = h ^ (h >> 16)
    返回 h
}

// Adler-32 校验
函数 阿德勒32(数据, 长度) {
    定义 可变 a = 1
    定义 可变 b = 0
    定义 可变 i = 0
    当 (i < 长度) {
        a = (a + 缓冲读(数据, i)) % 65521
        b = (b + a) % 65521
        i = i + 1
    }
    返回 (b << 16) | a
}

// Vigenère 密码
函数 vigenere加密(文本, 密钥) {
    定义 n = 计数(文本)
    定义 kn = 计数(密钥)
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 c = 编码(子串(文本, i, 1))
        定义 k = 编码(子串(密钥, i % kn, 1))
        如果 (c >= 字符_大写A 且 c <= 字符_大写Z) {
            c = (c - 65 + k - 65) % 26 + 65
        } 否则 如果 (c >= 字符_小写a 且 c <= 字符_小写z) {
            c = (c - 97 + k - 97) % 26 + 97
        }
        结果 = 字符串拼接(结果, 字符(c))
        i = i + 1
    }
    返回 结果
}

// 随机洗牌 (Fisher-Yates)
函数 洗牌(列表, 状态) {
    定义 n = 计数(列表)
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < n) { 追加(结果, 列表[i])
    i = i + 1 }
    i = n - 1
    当 (i > 0) {
        定义 j = 随机_范围(状态, 0, i)
        定义 临时 = 结果[i]
        结果[i] = 结果[j]
        结果[j] = 临时
        i = i - 1
    }
    返回 结果
}

// 哈希组合 (用于复合键, 0)
函数 哈希组合(h1, h2) {
    返回 (h1 ^ (h2 * 2654435769 + (h1 << 6) + (h1 >> 2))) & 0x7FFFFFFF
}



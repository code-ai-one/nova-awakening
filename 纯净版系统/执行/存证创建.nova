// 平台适配层: 存储引擎 — Cookie/Local存储/Session存储/文件缓存
// 浏览器存储层次:
//   ① Cookie — 小数据(4KB/条), 随HTTP请求发送
//   ② Local存储 — 同步KV(5-10MB/源), 持久化
//   ③ Session存储 — 同步KV, 标签页生命周期
//   ④ 缓存 存储 — Service 工线缓存(无限制)
//   ⑤ IndexedDB — 异步结构化存储(已实现, nova核心/storage/)
// NovaOS存储系统调用:
//   Nova系统调用_文件_打开(路径, 模式) → fd
//   Nova系统调用_文件_读(fd, 缓冲, 长度) → 已读
//   Nova系统调用_文件_写(fd, 数据, 长度) → 已写
//   Nova系统调用_文件_关闭(fd) → 0/-1
// 【颠覆性创新】AI预测缓存策略:
//   AI总线预测用户即将访问的资源→提前从磁盘加载到内存缓存
//   AI评估缓存项的访问概率→智能淘汰(替代简单LRU)

定义 系统调用_文件_打开  = 420
定义 系统调用_文件_读    = 421
定义 系统调用_文件_写    = 422
定义 系统调用_文件_关闭  = 423
定义 系统调用_文件_同步  = 424
定义 系统调用_文件_大小  = 425
定义 系统调用_目录_创建  = 426

// §1 Cookie存储

结构 Cookie {
    名称,    // u64 字符串
    值,    // u64 字符串
    域名,    // u64 ".example.com"
    路径,    // u64 "/"
    过期时间,    // u64 Unix时间戳(秒)
    是安全,    // 布尔 Secure标志(仅HTTPS)
    是HttpOnly,    // 布尔 HttpOnly(JS不可访问)
    SameSite,    // u32 SameSite_None/Lax/Strict
    名称哈希,    // u32 快速查找
    下一个,    // u64 Cookie*
}

结构 CookieJar {
    桶,    // [256]u64 哈希桶→Cookie链表
    总数,
    最大数,    // u32 通常3000
    持久化路径,    // u64 磁盘文件路径
}

函数 CookieJar_创建(路径) {
    定义 jar = 堆_分配(CookieJar)
    定义 可变 i = 0
    当 (i < 256) { jar.桶[i] = 0; i = i + 1 }
    jar.总数 = 0
    jar.最大数 = 3000
    jar.持久化路径 = 路径
    返回 jar
}

函数 CookieJar_设置(jar, cookie) {
    如果 (jar == 0 || cookie == 0) { 返回 }
    定义 桶号 = cookie.名称哈希 % 256

    // 查找是否已有同名Cookie(域名+路径+名称)
    定义 可变 当前 = jar.桶[桶号]
    当 (当前 != 0) {
        如果 (内存_读32(当前 + 40) == cookie.名称哈希) {
            // 更新值
            内存_写64(当前 + 8, cookie.值)
            内存_写64(当前 + 32, cookie.过期时间)
            返回
        }
        当前 = 内存_读64(当前 + 48)
    }

    // 新Cookie
    如果 (jar.总数 >= jar.最大数) {
        CookieJar_淘汰过期(jar)
    }
    cookie.下一个 = jar.桶[桶号]
    jar.桶[桶号] = cookie
    jar.总数 = jar.总数 + 1
}

函数 CookieJar_获取(jar, 域名, 路径) {
    // 返回匹配域名+路径的所有Cookie(用于构建Cookie头)
    // Cookie: name1=val1; name2=val2
    如果 (jar == 0) { 返回 0 }
    定义 可变 结果 = ""
    定义 可变 桶号 = 0
    当 (桶号 < 256) {
        定义 可变 当前 = jar.桶[桶号]
        当 (当前 != 0) {
            定义 c_域名 = 内存_读64(当前 + 16)
            定义 c_路径 = 内存_读64(当前 + 24)
            // 域名匹配(.example.com匹配a.example.com)
            如果 (Cookie_域名匹配(c_域名, 域名) && Cookie_路径匹配(c_路径, 路径)) {
                // 检查过期
                定义 过期 = 内存_读64(当前 + 32)
                如果 (过期 == 0 || 过期 > 平台_获取当前时间秒()) {
                    定义 名称 = 内存_读64(当前)
                    定义 值 = 内存_读64(当前 + 8)
                    如果 (字节长度(结果) > 0) { 结果 = 字符串拼接(结果, "; ") }
                    结果 = 字符串拼接(结果, 字符串拼接(名称, 字符串拼接("=", 值)))
                }
            }
            当前 = 内存_读64(当前 + 48)
        }
        桶号 = 桶号 + 1
    }
    返回 结果
}

函数 CookieJar_淘汰过期(jar) {
    定义 当前时间 = 平台_获取当前时间秒()
    定义 可变 桶号 = 0
    当 (桶号 < 256) {
        定义 可变 前一个 = 0
        定义 可变 当前 = jar.桶[桶号]
        当 (当前 != 0) {
            定义 下一个 = 内存_读64(当前 + 48)
            定义 过期 = 内存_读64(当前 + 32)
            如果 (过期 != 0 && 过期 <= 当前时间) {
                // 过期, 删除
                如果 (前一个 == 0) { jar.桶[桶号] = 下一个 }
                否则 { 内存_写64(前一个 + 48, 下一个) }
                堆_释放(当前)
                jar.总数 = jar.总数 - 1
            } 否则 {
                前一个 = 当前
            }
            当前 = 下一个
        }
        桶号 = 桶号 + 1
    }
}

函数 Cookie_域名匹配(cookie域, 请求域) { 返回 字符串_后缀匹配(请求域, cookie域) }
函数 Cookie_路径匹配(cookie路径, 请求路径) { 返回 字符串_前缀匹配(请求路径, cookie路径) }

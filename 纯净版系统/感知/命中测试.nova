// §6 命中测试 
// 给定屏幕坐标,找到对应的DOM节点(用于鼠标事件分发)
// 支持: 变换矩阵/圆角/裁剪/滚动偏移/透明度阈值/多结果收集

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("./创建销毁.nova")
导入("../中枢/内核打印.nova")
导入("./从布局树构.nova")
导入("../中枢/整数转字符串.nova")

定义 命中测试_最大结果 = 32
定义 命中测试_透明度阈值 = 1

结构 HitTestResult {
    目标节点,
    目标层,
    局部x,
    局部y,
}

结构 HitTestResultEx {
    目标节点,
    目标层,
    局部x,
    局部y,
    z序,
    透明度,
    可交互,
    裁剪区域内,
}

结构 HitTestMultiResult {
    结果列表,
    数量,
    容量,
}

结构 命中测试统计 {
    测试调用数,
    层遍历数,
    对象遍历数,
    命中成功数,
    命中失败数,
    变换测试数,
    裁剪跳过数,
}

定义 可变 全局_命中统计 = 空

函数 命中统计_初始化() {
    如果 (全局_命中统计 == 空) {
        全局_命中统计 = 命中测试统计 {}
        全局_命中统计.测试调用数 = 0
        全局_命中统计.层遍历数 = 0
        全局_命中统计.对象遍历数 = 0
        全局_命中统计.命中成功数 = 0
        全局_命中统计.命中失败数 = 0
        全局_命中统计.变换测试数 = 0
        全局_命中统计.裁剪跳过数 = 0
    }
}

函数 HitTestMultiResult_创建() {
    定义 多结果 = HitTestMultiResult {}
    多结果.结果列表 = 堆_分配(命中测试_最大结果 * 64)
    多结果.数量 = 0
    多结果.容量 = 命中测试_最大结果
    返回 多结果
}

函数 HitTestMultiResult_添加(多结果, 节点, 层, lx, ly, z, alpha, 交互) {
    如果 (多结果.数量 >= 多结果.容量) { 返回 }
    定义 项 = HitTestResultEx {}
    项.目标节点 = 节点
    项.目标层 = 层
    项.局部x = lx
    项.局部y = ly
    项.z序 = z
    项.透明度 = alpha
    项.可交互 = 交互
    项.裁剪区域内 = 真
    内存_写64(多结果.结果列表 + 多结果.数量 * 64, 项)
    多结果.数量 = 多结果.数量 + 1
}

函数 绘制Layer_命中测试(层, 测试x, 测试y, 结果) {
    命中统计_初始化()
    全局_命中统计.测试调用数 = 全局_命中统计.测试调用数 + 1

    如果 (层 == 0) {
        全局_命中统计.命中失败数 = 全局_命中统计.命中失败数 + 1
        返回 0
    }
    定义 lo = 层.布局对象
    如果 (lo == 0) { 返回 0 }
    定义 s = lo.样式
    如果 (s != 0 && s.visibility == Visibility_hidden) { 返回 0 }
    如果 (s != 0 && s.pointer_事件s == 5) { 返回 0 }

    全局_命中统计.层遍历数 = 全局_命中统计.层遍历数 + 1

    // 裁剪检测: overflow:hidden 时跳过区域外
    如果 (s != 0 && s.overflow == Overflow_hidden) {
        定义 裁剪宽 = 布局Object_边框盒宽(lo)
        定义 裁剪高 = 布局Object_边框盒高(lo)
        如果 (!绘制Layer_点在矩形内(测试x, 测试y, lo.绝对x, lo.绝对y, 裁剪宽, 裁剪高)) {
            全局_命中统计.裁剪跳过数 = 全局_命中统计.裁剪跳过数 + 1
            返回 0
        }
    }

    // 应用滚动偏移
    定义 可变 有效x = 测试x
    定义 可变 有效y = 测试y
    如果 (层.滚动x != 0 || 层.滚动y != 0) {
        有效x = 测试x + 层.滚动x
        有效y = 测试y + 层.滚动y
    }

    // 变换矩阵逆变换
    如果 (层.有变换 && 层.变换矩阵 != 0) {
        全局_命中统计.变换测试数 = 全局_命中统计.变换测试数 + 1
        定义 逆变换结果 = 命中测试_逆变换(层.变换矩阵, 有效x, 有效y)
        有效x = 逆变换结果[0]
        有效y = 逆变换结果[1]
    }

    // 正z-index子层(从高到低,反序遍历)
    定义 可变 i = 层.正z序数量 - 1
    当 (i >= 0) {
        定义 子层 = 内存_读64(层.正z序列表 + i * 8)
        如果 (绘制Layer_命中测试(子层, 有效x, 有效y, 结果)) {
            全局_命中统计.命中成功数 = 全局_命中统计.命中成功数 + 1
            返回 1
        }
        i = i - 1
    }

    // 自身内容(子布局对象,反序)
    如果 (绘制Layer_命中测试内容(层, 有效x, 有效y, 结果)) {
        全局_命中统计.命中成功数 = 全局_命中统计.命中成功数 + 1
        返回 1
    }

    // 负z-index子层
    i = 层.负z序数量 - 1
    当 (i >= 0) {
        定义 子层 = 内存_读64(层.负z序列表 + i * 8)
        如果 (绘制Layer_命中测试(子层, 有效x, 有效y, 结果)) {
            全局_命中统计.命中成功数 = 全局_命中统计.命中成功数 + 1
            返回 1
        }
        i = i - 1
    }

    // 测试自身 (含圆角)
    定义 bw = 布局Object_边框盒宽(lo)
    定义 bh = 布局Object_边框盒高(lo)
    如果 (s != 0 && s.border_radius > 0) {
        如果 (绘制Layer_点在圆角矩形内(有效x, 有效y, lo.绝对x, lo.绝对y, bw, bh, s.border_radius)) {
            结果.目标节点 = lo.DOM节点
            结果.目标层 = 层
            结果.局部x = 有效x - lo.绝对x
            结果.局部y = 有效y - lo.绝对y
            全局_命中统计.命中成功数 = 全局_命中统计.命中成功数 + 1
            返回 1
        }
    } 否则 如果 (绘制Layer_点在矩形内(有效x, 有效y, lo.绝对x, lo.绝对y, bw, bh)) {
        结果.目标节点 = lo.DOM节点
        结果.目标层 = 层
        结果.局部x = 有效x - lo.绝对x
        结果.局部y = 有效y - lo.绝对y
        全局_命中统计.命中成功数 = 全局_命中统计.命中成功数 + 1
        返回 1
    }

    返回 0
}

函数 绘制Layer_命中测试内容(层, 测试x, 测试y, 结果) {
    定义 lo = 层.布局对象
    // 反序遍历子(后面的在上面)
    定义 可变 子 = lo.最后子
    当 (子 != 0) {
        如果 (!绘制Layer_需要自己的层(子)) {
            全局_命中统计.对象遍历数 = 全局_命中统计.对象遍历数 + 1
            如果 (绘制Layer_命中测试布局对象(子, 测试x, 测试y, 结果)) {
                返回 1
            }
        }
        子 = 子.前兄
    }
    返回 0
}

函数 绘制Layer_命中测试布局对象(lo, 测试x, 测试y, 结果) {
    如果 (lo.样式 != 0 && lo.样式.display == Display_none) { 返回 0 }

    // 透明度阈值过滤
    如果 (lo.样式 != 0 && lo.样式.opacity < 命中测试_透明度阈值) { 返回 0 }

    全局_命中统计.对象遍历数 = 全局_命中统计.对象遍历数 + 1

    // 先测试子节点
    定义 可变 子 = lo.最后子
    当 (子 != 0) {
        如果 (!绘制Layer_需要自己的层(子)) {
            如果 (绘制Layer_命中测试布局对象(子, 测试x, 测试y, 结果)) {
                返回 1
            }
        }
        子 = 子.前兄
    }

    // 测试自身
    定义 bw = 布局Object_边框盒宽(lo)
    定义 bh = 布局Object_边框盒高(lo)
    如果 (绘制Layer_点在矩形内(测试x, 测试y, lo.绝对x, lo.绝对y, bw, bh)) {
        结果.目标节点 = lo.DOM节点
        结果.局部x = 测试x - lo.绝对x
        结果.局部y = 测试y - lo.绝对y
        返回 1
    }

    返回 0
}

函数 绘制Layer_命中测试_收集全部(层, 测试x, 测试y, 多结果) {
    如果 (层 == 0) { 返回 }
    定义 lo = 层.布局对象
    如果 (lo == 0) { 返回 }
    定义 s = lo.样式
    如果 (s != 0 && s.visibility == Visibility_hidden) { 返回 }

    // 正z-index子层
    定义 可变 i = 层.正z序数量 - 1
    当 (i >= 0) {
        绘制Layer_命中测试_收集全部(内存_读64(层.正z序列表 + i * 8), 测试x, 测试y, 多结果)
        i = i - 1
    }

    // 测试自身
    定义 bw = 布局Object_边框盒宽(lo)
    定义 bh = 布局Object_边框盒高(lo)
    如果 (绘制Layer_点在矩形内(测试x, 测试y, lo.绝对x, lo.绝对y, bw, bh)) {
        定义 alpha = 255
        如果 (s != 0) { alpha = s.opacity }
        定义 交互 = 真
        如果 (s != 0 && s.pointer_事件s == 5) { 交互 = 假 }
        HitTestMultiResult_添加(多结果, lo.DOM节点, 层, 测试x - lo.绝对x, 测试y - lo.绝对y, 层.z序, alpha, 交互)
    }

    // 负z-index子层
    i = 层.负z序数量 - 1
    当 (i >= 0) {
        绘制Layer_命中测试_收集全部(内存_读64(层.负z序列表 + i * 8), 测试x, 测试y, 多结果)
        i = i - 1
    }
}

函数 绘制Layer_点在矩形内(px, py, rx, ry, rw, rh) {
    返回 px >= rx && px < rx + rw && py >= ry && py < ry + rh
}

函数 绘制Layer_点在圆角矩形内(px, py, rx, ry, rw, rh, 半径) {
    如果 (!绘制Layer_点在矩形内(px, py, rx, ry, rw, rh)) { 返回 假 }
    定义 r = 半径
    如果 (r > rw / 2) { r = rw / 2 }
    如果 (r > rh / 2) { r = rh / 2 }

    // 检查四个角
    如果 (px < rx + r && py < ry + r) {
        返回 命中测试_点在圆内(px, py, rx + r, ry + r, r)
    }
    如果 (px >= rx + rw - r && py < ry + r) {
        返回 命中测试_点在圆内(px, py, rx + rw - r, ry + r, r)
    }
    如果 (px < rx + r && py >= ry + rh - r) {
        返回 命中测试_点在圆内(px, py, rx + r, ry + rh - r, r)
    }
    如果 (px >= rx + rw - r && py >= ry + rh - r) {
        返回 命中测试_点在圆内(px, py, rx + rw - r, ry + rh - r, r)
    }
    返回 真
}

函数 命中测试_点在圆内(px, py, cx, cy, r) {
    定义 dx = px - cx
    定义 dy = py - cy
    返回 dx * dx + dy * dy <= r * r
}

函数 命中测试_点在椭圆内(px, py, cx, cy, rx, ry) {
    如果 (rx <= 0 || ry <= 0) { 返回 假 }
    定义 dx = px - cx
    定义 dy = py - cy
    返回 (dx * dx * ry * ry + dy * dy * rx * rx) <= (rx * rx * ry * ry)
}

函数 命中测试_逆变换(矩阵, x, y) {
    // 2D仿射逆变换: [a b tx; c d ty; 0 0 1]
    定义 a = 内存_读64(矩阵)
    定义 b = 内存_读64(矩阵 + 8)
    定义 c = 内存_读64(矩阵 + 16)
    定义 d = 内存_读64(矩阵 + 24)
    定义 tx = 内存_读64(矩阵 + 32)
    定义 ty = 内存_读64(矩阵 + 40)

    定义 det = a * d - b * c
    如果 (det == 0) { 返回 [x, y] }

    定义 ix = x - tx
    定义 iy = y - ty
    定义 新x = (d * ix - b * iy) / det
    定义 新y = (a * iy - c * ix) / det
    返回 [新x, 新y]
}

函数 命中测试_最近可交互节点(层, 测试x, 测试y, 最大距离) {
    定义 多结果 = HitTestMultiResult_创建()
    绘制Layer_命中测试_收集全部(层, 测试x, 测试y, 多结果)

    如果 (多结果.数量 > 0) {
        返回 内存_读64(多结果.结果列表)
    }

    // 未命中: 查找最近可交互元素 (扩大搜索区域)
    定义 可变 步长 = 4
    当 (步长 <= 最大距离) {
        定义 可变 dx = 0 - 步长
        当 (dx <= 步长) {
            定义 可变 dy = 0 - 步长
            当 (dy <= 步长) {
                定义 结果 = HitTestResult {}
                如果 (绘制Layer_命中测试(层, 测试x + dx, 测试y + dy, 结果)) {
                    如果 (结果.目标节点 != 0) { 返回 结果 }
                }
                dy = dy + 步长
            }
            dx = dx + 步长
        }
        步长 = 步长 * 2
    }
    返回 空
}

函数 命中测试_打印统计() {
    命中统计_初始化()
    打印行("=== 命中测试统计 ===")
    打印行("测试调用: " + 整数转字符串(全局_命中统计.测试调用数))
    打印行("层遍历: " + 整数转字符串(全局_命中统计.层遍历数))
    打印行("对象遍历: " + 整数转字符串(全局_命中统计.对象遍历数))
    打印行("命中成功: " + 整数转字符串(全局_命中统计.命中成功数))
    打印行("命中失败: " + 整数转字符串(全局_命中统计.命中失败数))
    打印行("变换测试: " + 整数转字符串(全局_命中统计.变换测试数))
    打印行("裁剪跳过: " + 整数转字符串(全局_命中统计.裁剪跳过数))
}

函数 命中测试_完整统计() {
    命中统计_初始化()
    返回 [全局_命中统计.测试调用数, 全局_命中统计.层遍历数,
           全局_命中统计.对象遍历数, 全局_命中统计.命中成功数,
           全局_命中统计.命中失败数, 全局_命中统计.变换测试数,
           全局_命中统计.裁剪跳过数]
}

函数 命中测试_重置统计() {
    如果 (全局_命中统计 != 空) {
        全局_命中统计.测试调用数 = 0
        全局_命中统计.层遍历数 = 0
        全局_命中统计.对象遍历数 = 0
        全局_命中统计.命中成功数 = 0
        全局_命中统计.命中失败数 = 0
        全局_命中统计.变换测试数 = 0
        全局_命中统计.裁剪跳过数 = 0
    }
}

函数 命中测试_获取调用数() { 命中统计_初始化(); 返回 全局_命中统计.测试调用数 }
函数 命中测试_获取成功数() { 命中统计_初始化(); 返回 全局_命中统计.命中成功数 }
函数 命中测试_获取失败数() { 命中统计_初始化(); 返回 全局_命中统计.命中失败数 }
函数 命中测试_获取层数() { 命中统计_初始化(); 返回 全局_命中统计.层遍历数 }

函数 命中测试_命中率() {
    命中统计_初始化()
    定义 总 = 全局_命中统计.命中成功数 + 全局_命中统计.命中失败数
    如果 (总 == 0) { 返回 0 }
    返回 全局_命中统计.命中成功数 * 1000 / 总
}

// NRHT — Nova Rendering Hit Test Theory
// 公理1(z序正确): 命中测试结果严格遵循CSS z-index栈叠顺序
// 公理2(变换可逆): 任何可逆变换不影响命中判定的正确性
// 定理1(单点唯一): 单点命中返回最高层叠序中唯一结果
// 定理2(多结果完备): 多结果收集包含所有命中对象

函数 命中测试_点在多边形内(测试x, 测试y, 顶点x列表, 顶点y列表, 顶点数) {
    // 射线法: 从测试点发射水平射线, 计算交点数
    定义 可变 交点数 = 0
    定义 可变 j = 顶点数 - 1
    定义 可变 i = 0
    当 (i < 顶点数) {
        定义 yi = 顶点y列表[i]
        定义 yj = 顶点y列表[j]
        定义 xi = 顶点x列表[i]
        定义 xj = 顶点x列表[j]
        如果 ((yi > 测试y) != (yj > 测试y)) {
            定义 交点x = xi + (xj - xi) * (测试y - yi) / (yj - yi)
            如果 (测试x < 交点x) {
                交点数 = 交点数 + 1
            }
        }
        j = i
        i = i + 1
    }
    返回 交点数 % 2 == 1
}

函数 命中测试_点到矩形距离(px, py, rx, ry, rw, rh) {
    // 计算点到矩形边框的最近距离
    定义 可变 dx = 0
    定义 可变 dy = 0
    如果 (px < rx) { dx = rx - px }
    否则 如果 (px > rx + rw) { dx = px - rx - rw }
    如果 (py < ry) { dy = ry - py }
    否则 如果 (py > ry + rh) { dy = py - ry - rh }
    // 返回平方距离(避免开方)
    返回 dx * dx + dy * dy
}

函数 命中测试_查找最近层(x, y, 层列表, 层数) {
    定义 可变 最近索引 = -1
    定义 可变 最近距离 = 0x7FFFFFFF
    定义 可变 i = 0
    当 (i < 层数) {
        定义 层 = 层列表[i]
        如果 (层 != 0 && 层.布局对象 != 0) {
            定义 lo = 层.布局对象
            定义 bw = 布局Object_边框盒宽(lo)
            定义 bh = 布局Object_边框盒高(lo)
            定义 d = 命中测试_点到矩形距离(x, y, lo.绝对x, lo.绝对y, bw, bh)
            如果 (d < 最近距离) {
                最近距离 = d
                最近索引 = i
            }
        }
        i = i + 1
    }
    如果 (最近索引 >= 0) { 返回 层列表[最近索引] }
    返回 空
}

函数 命中测试_触摸扩展(px, py, rx, ry, rw, rh, 扩展) {
    // 触摸设备补偿: 扩大命中区域
    返回 绘制Layer_点在矩形内(px, py, rx - 扩展, ry - 扩展, rw + 扩展 * 2, rh + 扩展 * 2)
}

函数 命中测试_点在梯形内(px, py, x1, y1, w1, x2, y2, w2, 高度) {
    // 梯形命中测试 (常用于CSSclip-path: polygon)
    如果 (py < y1 || py > y1 + 高度) { 返回 假 }
    定义 比例 = (py - y1) * 1000 / 高度
    定义 当前x = x1 + (x2 - x1) * 比例 / 1000
    定义 当前w = w1 + (w2 - w1) * 比例 / 1000
    返回 px >= 当前x && px <= 当前x + 当前w
}

定义 可变 命中_预测次数 = 0
定义 可变 命中_预测命中数 = 0
定义 可变 命中_上次目标 = 空
定义 可变 命中_连续相同数 = 0

函数 命中测试_AI记录(目标节点) {
    命中_预测次数 = 命中_预测次数 + 1
    如果 (目标节点 == 命中_上次目标) {
        命中_连续相同数 = 命中_连续相同数 + 1
    } 否则 {
        命中_连续相同数 = 0
        命中_上次目标 = 目标节点
    }
}

函数 命中测试_AI预测目标() {
    // 如果用户连续点击同一元素, 可以先缓存结果加速
    如果 (命中_连续相同数 >= 3 && 命中_上次目标 != 空) {
        命中_预测命中数 = 命中_预测命中数 + 1
        返回 命中_上次目标
    }
    返回 空
}

函数 命中测试_AI预测率() {
    如果 (命中_预测次数 == 0) { 返回 0 }
    返回 命中_预测命中数 * 1000 / 命中_预测次数
}

函数 HitTestMultiResult_按z序排序(多结果) {
    // 冒泡排序按z序降序
    定义 可变 i = 0
    当 (i < 多结果.数量 - 1) {
        定义 可变 j = 0
        当 (j < 多结果.数量 - 1 - i) {
            定义 off1 = j * 64
            定义 off2 = (j + 1) * 64
            定义 z1 = 内存_读64(多结果.结果列表 + off1 + 32)
            定义 z2 = 内存_读64(多结果.结果列表 + off2 + 32)
            如果 (z2 > z1) {
                // 交换
                定义 可变 k = 0
                当 (k < 64) {
                    定义 tmp = 内存_读8(多结果.结果列表 + off1 + k)
                    内存_写68(多结果.结果列表 + off1 + k, 内存_读8(多结果.结果列表 + off2 + k))
                    内存_写68(多结果.结果列表 + off2 + k, tmp)
                    k = k + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }
}

函数 HitTestMultiResult_过滤可交互(多结果) {
    // 返回只包含可交互元素的结果数
    定义 可变 可交互数 = 0
    定义 可变 i = 0
    当 (i < 多结果.数量) {
        定义 off = i * 64
        定义 可交互 = 内存_读64(多结果.结果列表 + off + 48)
        如果 (可交互) { 可交互数 = 可交互数 + 1 }
        i = i + 1
    }
    返回 可交互数
}

函数 HitTestMultiResult_释放(多结果) {
    如果 (多结果 != 空 && 多结果.结果列表 != 0) {
        堆_释放(多结果.结果列表)
        多结果.结果列表 = 0
        多结果.数量 = 0
    }
}

函数 命中测试_完整诊断() {
    命中统计_初始化()
    返回 [
        "测试调用", 全局_命中统计.测试调用数,
        "命中率", 命中测试_命中率(),
        "层遍历", 全局_命中统计.层遍历数,
        "裁剪跳过", 全局_命中统计.裁剪跳过数,
        "AI预测率", 命中测试_AI预测率(),
        "原生独创_NRHT命中测试", 1
    ]
}

// §12 【原生独创】谐振命中测试热区预测器
// 基于用户交互历史预测下一次点击热区

定义 可变 _谐振热区_历史 = []
定义 可变 _谐振热区_预测次数 = 0
定义 可变 _谐振热区_命中次数 = 0

函数 谐振热区_记录点击(x, y) {
    追加(_谐振热区_历史, { x: x, y: y })
    如果 (计数(_谐振热区_历史) > 64) {
        定义 可变 新表 = []
        定义 可变 i = 计数(_谐振热区_历史) - 64
        当 (i < 计数(_谐振热区_历史)) {
            追加(新表, _谐振热区_历史[i])
            i = i + 1
        }
        _谐振热区_历史 = 新表
    }
}

函数 谐振热区_预测(宽度, 高度) {
    如果 (计数(_谐振热区_历史) < 4) { 返回 空 }
    // 计算重心作为预测点
    定义 可变 总x = 0
    定义 可变 总y = 0
    定义 可变 i = 0
    当 (i < 计数(_谐振热区_历史)) {
        总x = 总x + _谐振热区_历史[i].x
        总y = 总y + _谐振热区_历史[i].y
        i = i + 1
    }
    _谐振热区_预测次数 = _谐振热区_预测次数 + 1
    返回 { x: 总x / 计数(_谐振热区_历史), y: 总y / 计数(_谐振热区_历史) }
}

导入("../基础.nova")
导入("../数学/基础/数学库.nova")


// 高精度三角函数 (scale=1000, 7阶Taylor)
函数 简化_sin(x) { 定义 可变 v = x % 6283
 如果 (v > 3141) { v = v - 6283 }
 如果 (v < -3141) { v = v + 6283 }
 定义 x3 = v * v / 1000 * v / 1000
 定义 x5 = x3 * v / 1000 * v / 1000
 定义 x7 = x5 * v / 1000 * v / 1000
 返回 v - x3 / 6 + x5 / 120 - x7 / 5040
}
函数 简化_cos(x) { 返回 简化_sin(x + 1571) }

// 频率计算
函数 计算频率(dim_idx, 总维度, base) { 定义 可变 频率 = 1000
 定义 可变 k = 0
 如果 (总维度 == 0) { 返回 [] }
 定义 可变 衰减值 = base * 2 / 总维度
 如果 (衰减值 < 100) { 衰减值 = 100 }
 如果 (衰减值 == 0) { 衰减值 = 1 }
 当 (k < dim_idx) { 频率 = 频率 * 1000 / 衰减值
 k = k + 1 }
 如果 (频率 < 1) { 频率 = 1 }
 返回 频率
}

// 正弦位置编码 (带缓存, 0)
定义 可变 PE_缓存 = []
定义 可变 PE_缓存长度 = 0
定义 可变 PE_缓存维度 = 0

函数 正弦位置编码(位置, 维度) { 定义 可变 编码 = []
 定义 可变 i = 0
 当 (i < 维度) { 定义 频率 = 计算频率(i / 2, 维度, 800)
 定义 角度 = 位置 * 频率
 如果 (i % 2 == 0) { 追加(编码, 简化_sin(角度)) }
 否则 { 追加(编码, 简化_cos(角度)) }
 i = i + 1
 }
 返回 编码
}

函数 正弦PE_批量(max_len, 维度) {
 PE_缓存 = []
 PE_缓存长度 = max_len
 PE_缓存维度 = 维度
 定义 可变 p = 0
 当 (p < max_len) { 定义 pe = 正弦位置编码(p, 维度)
 定义 可变 d = 0
 当 (d < 维度) { 追加(PE_缓存, pe[d])
 d = d + 1 }
 p = p + 1
 }
}

函数 正弦PE_查缓存(位置, dim_idx) { 如果 (位置 < PE_缓存长度) { 返回 PE_缓存[位置 * PE_缓存维度 + dim_idx]
 }
 定义 频率 = 计算频率(dim_idx / 2, PE_缓存维度, 800)
 定义 角度 = 位置 * 频率
 如果 (dim_idx % 2 == 0) { 返回 简化_sin(角度) }
 返回 简化_cos(角度)
}

// RoPE旋转位置编码 (带缓存/NTK/YaRN)
定义 可变 RoPE_cos缓存 = []
定义 可变 RoPE_sin缓存 = []
定义 可变 RoPE_缓存长度 = 0
定义 旋转编码_基数 = 800

函数 RoPE_初始化(max_len, 维度, base) {
 RoPE_cos缓存 = []
 RoPE_sin缓存 = []
 RoPE_缓存长度 = max_len
 旋转编码_基数 = base
 定义 一半 = 维度 / 2
 定义 可变 p = 0
 当 (p < max_len) { 定义 可变 i = 0
 当 (i < 一半) { 定义 频率 = 计算频率(i, 维度, base)
 定义 角度 = p * 频率
 追加(RoPE_cos缓存, 简化_cos(角度))
 追加(RoPE_sin缓存, 简化_sin(角度))
 i = i + 1
 }
 p = p + 1
 }
}

函数 RoPE_编码(嵌入, 位置) { 定义 维度 = 计数(嵌入)
 定义 一半 = 维度 / 2
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 一半) { 定义 可变 cs = 0
 定义 可变 sn = 0
 如果 (位置 < RoPE_缓存长度) {
 cs = RoPE_cos缓存[位置 * 一半 + i]
 sn = RoPE_sin缓存[位置 * 一半 + i]
 } 否则 { 定义 频率 = 计算频率(i, 维度, 旋转编码_基数)
 cs = 简化_cos(位置 * 频率)
 sn = 简化_sin(位置 * 频率)
 }
 定义 x0 = 嵌入[i * 2]
 定义 x1 = 嵌入[i * 2 + 1]
 追加(结果, x0 * cs / 1000 - x1 * sn / 1000)
 追加(结果, x0 * sn / 1000 + x1 * cs / 1000)
 i = i + 1
 }
 如果 (维度 % 2 == 1) { 追加(结果, 嵌入[维度 - 1]) }
 返回 结果
}

// NTK-aware RoPE: 缩放base支持长序列外推
函数 RoPE_NTK编码(嵌入, 位置, 原始长度, 新长度) { 定义 维度 = 计数(嵌入)
 如果 (原始长度 == 0) { 原始长度 = 1 }
 定义 缩放因子 = 新长度 * 1000 / 原始长度
 定义 新base = 旋转编码_基数 * 缩放因子 / 1000
 定义 一半 = 维度 / 2
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 一半) { 定义 频率 = 计算频率(i, 维度, 新base)
 定义 角度 = 位置 * 频率
 定义 cs = 简化_cos(角度)
 定义 sn = 简化_sin(角度)
 定义 x0 = 嵌入[i * 2]
 定义 x1 = 嵌入[i * 2 + 1]
 追加(结果, x0 * cs / 1000 - x1 * sn / 1000)
 追加(结果, x0 * sn / 1000 + x1 * cs / 1000)
 i = i + 1
 }
 如果 (维度 % 2 == 1) { 追加(结果, 嵌入[维度 - 1]) }
 返回 结果
}

// YaRN: 低频NTK + 高频线性内插
函数 RoPE_YaRN编码(嵌入, 位置, 原始长度, 新长度) { 定义 维度 = 计数(嵌入)
 定义 一半 = 维度 / 2
 定义 缩放 = 新长度 * 1000 / 原始长度
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 一半) { 定义 可变 eff_base = 旋转编码_基数
 如果 (i < 一半 / 2) { eff_base = 旋转编码_基数 * 缩放 / 1000 }
 定义 频率 = 计算频率(i, 维度, eff_base)
 定义 可变 eff_pos = 位置
 如果 (i >= 一半 / 2) { eff_pos = 位置 * 1000 / 缩放 }
 定义 角度 = eff_pos * 频率
 定义 cs = 简化_cos(角度)
 定义 sn = 简化_sin(角度)
 定义 x0 = 嵌入[i * 2]
 定义 x1 = 嵌入[i * 2 + 1]
 追加(结果, x0 * cs / 1000 - x1 * sn / 1000)
 追加(结果, x0 * sn / 1000 + x1 * cs / 1000)
 i = i + 1
 }
 如果 (维度 % 2 == 1) { 追加(结果, 嵌入[维度 - 1]) }
 返回 结果
}

// ALiBi 线性偏置 (完整版)
函数 ALiBi_斜率(head_idx, _n_heads) { 定义 可变 m = 1000
 定义 可变 k = 0
 当 (k < head_idx) { m = m * 500 / 1000
 k = k + 1 }
 返回 m
}

函数 ALiBi_偏置矩阵(序列长度, head_idx, n_heads) { 定义 m = ALiBi_斜率(head_idx, n_heads)
 定义 可变 偏置 = []
 定义 可变 q = 0
 当 (q < 序列长度) { 定义 可变 k = 0
 当 (k < 序列长度) {
 追加(偏置, 0 - m * 绝对值(k - q) / 1000)
 k = k + 1
 }
 q = q + 1
 }
 返回 偏置
}

// ALiBi因果掩码: 只允许看左侧
函数 ALiBi_因果偏置(序列长度, head_idx, n_heads) { 定义 m = ALiBi_斜率(head_idx, n_heads)
 定义 可变 偏置 = []
 定义 可变 q = 0
 当 (q < 序列长度) { 定义 可变 k = 0
 当 (k < 序列长度) { 如果 (k > q) { 追加(偏置, -99999) }
 否则 { 追加(偏置, 0 - m * (q - k) / 1000) }
 k = k + 1
 }
 q = q + 1
 }
 返回 偏置
}

// 相对位置编码 (完整版)
函数 相对位置偏置(q_pos, k_pos, 最大距离) { 定义 可变 距离 = k_pos - q_pos
 如果 (距离 > 最大距离) { 距离 = 最大距离 }
 如果 (距离 < 0 - 最大距离) { 距离 = 0 - 最大距离 }
 返回 距离
}

函数 相对位置矩阵(序列长度, 最大距离) {
    定义 可变 矩阵 = []
 定义 可变 i = 0
 当 (i < 序列长度) { 定义 可变 j = 0
 当 (j < 序列长度) {
 追加(矩阵, 相对位置偏置(i, j, 最大距离))
 j = j + 1
 }
 i = i + 1
 }
 返回 矩阵
}

// T5风格对数桶化相对位置
函数 T5_位置桶(相对位置, 桶数, 最大距离) { 定义 可变 abs_pos = 绝对值(相对位置)
 定义 half_buckets = 桶数 / 2
 定义 可变 桶 = 0
 如果 (相对位置 > 0) { 桶 = half_buckets }
 如果 (abs_pos < half_buckets) { 桶 = 桶 + abs_pos }
 否则 { 定义 对数比 = abs_pos * 1000 / 最大距离
 定义 可变 log_bucket = half_buckets + 对数比 * half_buckets / 1000
 如果 (log_bucket >= 桶数) { log_bucket = 桶数 - 1 }
 桶 = log_bucket
 }
 返回 桶
}

// 可学习位置编码 (带梯度更新)
定义 可变 学习_位置表 = []
定义 可变 学习_梯度表 = []
定义 可变 学习_dim = 0
定义 可变 学习_maxlen = 0

函数 学习位置_初始化(最大长度, 维度, 种子) {
 学习_位置表 = []
 学习_梯度表 = []
 学习_dim = 维度
 学习_maxlen = 最大长度
 定义 可变 i = 0
 当 (i < 最大长度 * 维度) {
 追加(学习_位置表, (种子 * 1103 + 12345 + i * 7) % 2000 - 1000)
 追加(学习_梯度表, 0)
 i = i + 1
 }
}

函数 学习位置_查询(位置, 维度) { 定义 safe_pos = 最小值(位置, 学习_maxlen - 1)
 定义 可变 结果 = []
 定义 可变 d = 0
 当 (d < 维度) {
 追加(结果, 学习_位置表[safe_pos * 维度 + d])
 d = d + 1
 }
 返回 结果
}

函数 学习位置_累积梯度(位置, 维度, 梯度) { 定义 safe_pos = 最小值(位置, 学习_maxlen - 1)
 定义 可变 d = 0
 当 (d < 维度) { 定义 索引 = safe_pos * 维度 + d
 学习_梯度表[索引] = 学习_梯度表[索引] + 梯度[d]
 d = d + 1
 }
}

函数 学习位置_更新(学习率) { 定义 可变 i = 0
 当 (i < 计数(学习_位置表)) {
 学习_位置表[i] = 学习_位置表[i] - 学习率 * 学习_梯度表[i] / 1000
 学习_梯度表[i] = 0
 i = i + 1
 }
}

// 多头位置编码合成
函数 多头PE_应用(嵌入, 位置, _n_heads, 编码类型) { 定义 维度 = 计数(嵌入)
 如果 (编码类型 == 0) { 返回 RoPE_编码(嵌入, 位置) }
 如果 (编码类型 == 2) { 定义 可变 正弦编码 = 正弦位置编码(位置, 维度)
 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(嵌入)) {
 追加(r, 嵌入[i] + 正弦编码[i])
 i = i + 1
 }
 返回 r
 }
 返回 嵌入
}

// PE缓存是否有效
函数 PE_缓存有效() { 返回 PE_缓存长度 > 0 }


// [Nova实验室反哺] RoPE整数位置编码 (CORDIC旋转)
// 来源: 中文原生/内核/实验室/机器学习/RoPE整数位置编码.nova
// Rust实测: 误差0.02%，速度2.5×浮点版，零浮点三角函数
定义 RoPE_COS表 = [1024, 947, 724, 392, 0, -392, -724, -947]
定义 RoPE_SIN表 = [0, 392, 724, 947, 1024, 947, 724, 392]

函数 RoPE整数旋转(x_q10, y_q10, 角度索引) {
    定义 索引 = 角度索引 % 8
    定义 余弦向量 = RoPE_COS表[索引]
    定义 sin_v = RoPE_SIN表[索引]
    定义 x新 = (x_q10 * 余弦向量 - y_q10 * sin_v) / 1024
    定义 y新 = (x_q10 * sin_v + y_q10 * 余弦向量) / 1024
    返回 [x新, y新]
}

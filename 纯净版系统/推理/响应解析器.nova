// NovaOS · 统一响应解析器
// 将各模型的序列响应→统一的结构化结果
// 各模型返回格式差异:
//   Nova智能: {"choices":[{"message":{"content":"..."}}],"usage":{"prompt_令牌s":N,...}}
//   Anthropic: {"content":[{"type":"text","text":"..."}],"usage":{"input_令牌s":N,...}}
//   GLM: 类Nova智能 + web_search结果
//   MiniMax: {"choices":[{"message":{"content":"..."}}],"usage":{"total_令牌s":N}}
//   Qwen: Nova智能兼容
//   文心: {"result":"...","usage":{"prompt_令牌s":N,...}}
// 统一输出: AI响应结果 结构

结构 AI响应结果 {
    成功,
    内容,    // 字符串 模型生成的文本
    输入令牌,
    输出令牌,
    总令牌,
    结束原因,    // 字符串 "stop" / "length" / "content_filter"
    模型名,
    延迟毫秒,
    错误码,
    错误信息,
}


函数 响应_解析(格式版本, 原始响应, 开始时间) {
    定义 结果 = AI响应结果 {}
    结果.延迟毫秒 = 读取毫秒() - 开始时间

    如果 (原始响应 == 空 || 字符串长度(原始响应) == 0) {
        结果.成功 = 0
        结果.错误码 = 1
        结果.错误信息 = "空响应"
        返回 结果
    }

    // 检查HTTP错误
    如果 (响应_是错误(原始响应)) {
        结果.成功 = 0
        结果.错误码 = 响应_提取错误码(原始响应)
        结果.错误信息 = 响应_提取错误信息(原始响应)
        返回 结果
    }

    如果 (格式版本 == 0) { 返回 响应_解析_Nova智能(原始响应, 结果) }
    如果 (格式版本 == 1) { 返回 响应_解析_Anthropic(原始响应, 结果) }
    如果 (格式版本 == 2) { 返回 响应_解析_GLM(原始响应, 结果) }
    如果 (格式版本 == 3) { 返回 响应_解析_MiniMax(原始响应, 结果) }
    如果 (格式版本 == 4) { 返回 响应_解析_Nova智能(原始响应, 结果) }  // Qwen=Nova智能兼容
    返回 响应_解析_Nova智能(原始响应, 结果)
}


函数 响应_解析_Nova智能(json, 结果) {
    // 提取content: choices[0].message.content
    定义 content = 序列_提取字符串(json, "content")
    如果 (content != 空) {
        结果.内容 = content
        结果.成功 = 1
    } 否则 {
        结果.成功 = 0
        结果.错误信息 = "无法提取content"
    }

    // 提取usage
    结果.输入令牌 = 序列_提取整数(json, "prompt_令牌s")
    结果.输出令牌 = 序列_提取整数(json, "completion_令牌s")
    结果.总令牌 = 序列_提取整数(json, "total_令牌s")
    如果 (结果.总令牌 == 0) { 结果.总令牌 = 结果.输入令牌 + 结果.输出令牌 }

    // 提取finish_reason
    结果.结束原因 = 序列_提取字符串(json, "finish_reason")
    如果 (结果.结束原因 == 空) { 结果.结束原因 = "unknown" }

    // 提取model
    结果.模型名 = 序列_提取字符串(json, "model")
    返回 结果
}


函数 响应_解析_Anthropic(json, 结果) {
    // Anthropic: content[0].text
    定义 text = 序列_提取字符串(json, "text")
    如果 (text != 空) {
        结果.内容 = text
        结果.成功 = 1
    } 否则 {
        结果.成功 = 0
        结果.错误信息 = "无法提取text"
    }

    // Anthropic usage: input_令牌s / output_令牌s
    结果.输入令牌 = 序列_提取整数(json, "input_令牌s")
    结果.输出令牌 = 序列_提取整数(json, "output_令牌s")
    结果.总令牌 = 结果.输入令牌 + 结果.输出令牌

    结果.结束原因 = 序列_提取字符串(json, "stop_reason")
    结果.模型名 = 序列_提取字符串(json, "model")
    返回 结果
}


函数 响应_解析_GLM(json, 结果) {
    // GLM基本兼容Nova智能格式
    返回 响应_解析_Nova智能(json, 结果)
}


函数 响应_解析_MiniMax(json, 结果) {
    // MiniMax也基本兼容Nova智能格式
    定义 r = 响应_解析_Nova智能(json, 结果)
    // MiniMax可能用total_令牌s但无prompt/completion拆分
    如果 (r.输入令牌 == 0 && r.总令牌 > 0) {
        r.输入令牌 = r.总令牌 / 3     // 粗略估计
        r.输出令牌 = r.总令牌 - r.输入令牌
    }
    返回 r
}


定义 可变 流式_缓冲 = ""
定义 可变 流式_总内容 = ""
定义 可变 流式_完成 = 假

函数 流式_重置() {
    流式_缓冲 = ""
    流式_总内容 = ""
    流式_完成 = 假
}

函数 流式_接收块(数据块) {
    // SSE格式: "data: {...}\n\n" 或 "data: [DONE]\n\n"
    流式_缓冲 = 流式_缓冲 + 数据块

    // 按\n\n拆分事件
    定义 可变 处理位置 = 0
    当 (真) {
        定义 分隔位 = 字符串查找(字符串子串(流式_缓冲, 处理位置, 字符串长度(流式_缓冲)), "\n\n")
        如果 (分隔位 < 0) { 跳出 }

        定义 事件 = 字符串子串(流式_缓冲, 处理位置, 处理位置 + 分隔位)
        处理位置 = 处理位置 + 分隔位 + 2

        // 提取data:后的内容
        定义 data位 = 字符串查找(事件, "data: ")
        如果 (data位 >= 0) {
            定义 data内容 = 字符串子串(事件, data位 + 6, 字符串长度(事件))
            如果 (data内容 == "[DONE]") {
                流式_完成 = 真
            } 否则 {
                // 提取delta content
                定义 delta = 序列_提取字符串(data内容, "content")
                如果 (delta != 空) {
                    流式_总内容 = 流式_总内容 + delta
                }
            }
        }
    }
    // 保留未处理部分
    如果 (处理位置 > 0) {
        流式_缓冲 = 字符串子串(流式_缓冲, 处理位置, 字符串长度(流式_缓冲))
    }
}

函数 流式_获取增量() {
    定义 内容 = 流式_总内容
    返回 内容
}

函数 流式_是否完成() { 返回 流式_完成 }


函数 响应_是错误(json) {
    返回 字符串查找(json, "\"error\"") >= 0
}

函数 响应_提取错误码(json) {
    定义 code = 序列_提取整数(json, "status_code")
    如果 (code == 0) { code = 序列_提取整数(json, "code") }
    如果 (code == 0) { code = 500 }
    返回 code
}

函数 响应_提取错误信息(json) {
    定义 msg = 序列_提取字符串(json, "message")
    如果 (msg == 空) { msg = 序列_提取字符串(json, "error") }
    如果 (msg == 空) { msg = "未知错误" }
    返回 msg
}


函数 序列_提取字符串(json, 键) {
    // 查找 "键":"值" 或 "键": "值"
    定义 搜索 = "\"" + 键 + "\""
    定义 位置 = 字符串查找(json, 搜索)
    如果 (位置 < 0) { 返回 空 }

    // 跳过键和冒号
    定义 可变 i = 位置 + 字符串长度(搜索)
    // 跳过空白和冒号
    当 (i < 字符串长度(json)) {
        定义 ch = 字符串字符(json, i)
        如果 (ch == 58 || ch == 32 || ch == 9 || ch == 10) { i = i + 1 }  // : 空格 tab 换行
        否则 { 跳出 }
    }
    // 检查是否是字符串值
    如果 (i < 字符串长度(json) && 字符串字符(json, i) == 34) {  // "
        i = i + 1  // 跳过开引号
        定义 可变 结果 = ""
        当 (i < 字符串长度(json)) {
            定义 ch = 字符串字符(json, i)
            如果 (ch == 34) { 返回 结果 }  // 结束引号
            如果 (ch == 92 && i + 1 < 字符串长度(json)) {  // 转义
                i = i + 1
                定义 ech = 字符串字符(json, i)
                如果 (ech == 110) { 结果 = 结果 + "\n" }       // \n
                否则 如果 (ech == 116) { 结果 = 结果 + "\t" }  // \t
                否则 如果 (ech == 34) { 结果 = 结果 + "\"" }   // \"
                否则 如果 (ech == 92) { 结果 = 结果 + "\\" }   // \\
                否则 { 结果 = 结果 + 字符串从字符(ech) }
            } 否则 {
                结果 = 结果 + 字符串从字符(ch)
            }
            i = i + 1
        }
    }
    返回 空
}

函数 序列_提取整数(json, 键) {
    定义 搜索 = "\"" + 键 + "\""
    定义 位置 = 字符串查找(json, 搜索)
    如果 (位置 < 0) { 返回 0 }

    定义 可变 i = 位置 + 字符串长度(搜索)
    // 跳过冒号和空白
    当 (i < 字符串长度(json)) {
        定义 ch = 字符串字符(json, i)
        如果 (ch == 58 || ch == 32) { i = i + 1 }
        否则 { 跳出 }
    }
    // 读取数字
    定义 可变 数值 = 0
    当 (i < 字符串长度(json)) {
        定义 ch = 字符串字符(json, i)
        如果 (ch >= 48 && ch <= 57) { 数值 = 数值 * 10 + (ch - 48) }
        否则 { 跳出 }
        i = i + 1
    }
    返回 数值
}

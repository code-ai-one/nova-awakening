函数 文档节点_统计() {
    返回 {
        节点总失败: 节点总失败,
        节点总创建数: 节点_总创建数,
        节点总销毁数: 节点_总销毁数,
        AX名称计算总数: AX_名称计算总数,
        元素Data创建总数: 元素Data_创建总数,
        元素查询总数: 元素_查询总数,
        活跃WakeLock数量: 活跃WakeLock数量
    }
}

函数 文档节点_健康评估() {
    定义 可变 问题 = []
    如果 (节点总失败 > 100) { 追加(问题, "节点总失败=" + 节点总失败) }
    如果 (!标记表单创_健康评估()) { 追加(问题, "表单模型链路异常") }
    返回 计数(问题) == 0
}

函数 文档节点_综合报告() {
    打印("[文档节点] ═══ 综合报告 ═══")
    打印("  节点总失败: " + 节点总失败)
    打印("  节点_总创建数: " + 节点_总创建数)
    打印("  节点_总销毁数: " + 节点_总销毁数)
    打印("  AX_名称计算总数: " + AX_名称计算总数)
    打印("  元素Data_创建总数: " + 元素Data_创建总数)
    打印("  元素_查询总数: " + 元素_查询总数)
    打印("  活跃WakeLock数量: " + 活跃WakeLock数量)
    打印("  健康: " + 如果 (文档节点_健康评估()) { "正常" } 否则 { "异常" })
}

函数 文档节点_全局重置() {
    节点总失败 = 0
    节点_总创建数 = 0
    节点_总销毁数 = 0
    AX_名称计算总数 = 0
    元素Data_创建总数 = 0
    元素_查询总数 = 0
    活跃WakeLock数量 = 0
    打印("[文档节点] 统计已重置")
    返回 0
}

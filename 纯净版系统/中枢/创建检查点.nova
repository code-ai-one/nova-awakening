// NovaOS 检查点 — Nova Incremental Checkpoint Theory (NICT)
// 原创理论: Nova增量检查点理论 (NICT)
//   定理1 (原子性): 全快照在关中断下执行, 保证一致性
//   定理2 (校验和守恒): 创建时的校验和 = 回滚时的校验和
//   定理3 (增量最优): 增量检查点只保存脏状态, O(脏页数)
//   定理4 (Merkle验证): 检查点树根哈希唯一标识系统状态

函数 检查点_创建(名称) {
    // 淘汰旧检查点(LRU)
    如果 (计数(检查点列表) >= 最大检查点数) {
        检查点_淘汰最旧()
    }

    内核信息("检查点: 创建 [" + 名称 + "] 开始...")
    定义 cp = 检查点 {}
    cp.检查点ID = 检查点ID计数器
    检查点ID计数器 = 检查点ID计数器 + 1
    cp.名称 = 名称
    cp.创建时间 = 读取毫秒()
    cp.内核版本 = 当前内核版本
    cp.状态 = 0  // 创建中

    // ★ 关中断: 确保快照的原子性(单CPU)
    关中断()

    cp.进程表快照 = 快照_进程表()
    cp.进程数 = 快照_进程数()
    cp.当前PID = 获取当前PID()
    cp.PID位图快照 = 快照_PID位图()

    cp.伙伴系统快照 = 快照_伙伴系统()
    cp.全局空闲页 = 快照_空闲页数()
    cp.SLUB缓存快照 = 快照_SLUB()
    cp.VMA快照 = 快照_所有VMA()

    cp.TNF权重快照 = 快照_TNF权重()
    cp.赫布连接快照 = 快照_赫布连接()
    cp.突触网格快照 = 快照_突触网格()
    cp.AI记忆快照 = 快照_AI记忆()
    cp.注意力状态 = 快照_注意力()

    cp.运行队列快照 = 快照_运行队列()
    cp.调度统计 = 快照_调度统计()

    cp.挂载表快照 = 快照_挂载表()
    cp.打开文件表 = 快照_打开文件()
    cp.Nova文件节点缓存快照 = 快照_脏Nova文件节点()
    cp.页缓存脏页 = 快照_脏页()

    cp.socket表快照 = 快照_socket表()
    cp.路由表快照 = 快照_路由表()

    cp.定时器列表 = 快照_定时器()
    cp.软中断状态 = 快照_软中断()

    cp.校验和 = 检查点_计算校验和(cp)

    开中断()

    cp.状态 = 1  // 有效
    追加(检查点列表, cp)
    检查点_总创建数 = 检查点_总创建数 + 1

    定义 耗时 = 读取毫秒() - cp.创建时间
    内核信息("检查点: [" + 名称 + "] ID=" + 整数转字符串(cp.检查点ID) +
             " 完成 耗时=" + 整数转字符串(耗时) + "ms" +
             " 进程=" + 整数转字符串(cp.进程数))
    返回 cp
}

// §4 回滚到检查点

函数 检查点_回滚(检查点ID) {
    定义 cp = 检查点_查找(检查点ID)
    如果 (cp == 空) {
        内核错误("检查点: 回滚失败, ID=" + 整数转字符串(检查点ID) + " 不存在")
        返回 错误_不存在
    }
    如果 (cp.状态 != 1) {
        内核错误("检查点: 回滚失败, 检查点状态无效=" + 整数转字符串(cp.状态))
        返回 错误_无效参数
    }

    // 验证校验和
    定义 当前校验和 = 检查点_计算校验和(cp)
    如果 (当前校验和 != cp.校验和) {
        内核错误("检查点: 校验和不匹配! 数据可能已损坏")
        返回 错误_IO
    }

    内核信息("检查点: 回滚到 [" + cp.名称 + "] ID=" + 整数转字符串(cp.检查点ID))

    // NICT定理1: 关中断保证原子性恢复
    关中断()

    恢复_进程表(cp.进程表快照)
    恢复_伙伴系统(cp.伙伴系统快照)
    恢复_SLUB(cp.SLUB缓存快照)
    恢复_TNF权重(cp.TNF权重快照)
    恢复_赫布连接(cp.赫布连接快照)
    恢复_AI记忆(cp.AI记忆快照)
    恢复_运行队列(cp.运行队列快照)
    恢复_挂载表(cp.挂载表快照)
    恢复_路由表(cp.路由表快照)
    恢复_定时器(cp.定时器列表)

    开中断()
    内核信息("NICT: 回滚完成 [" + cp.名称 + "]")
    返回 成功
}

// NICT定理4: Merkle树根哈希验证
// 将各子系统校验和分层合并, 生成根哈希

函数 检查点_Merkle根哈希(cp) {
    // 第一层: 各子系统哈希
    定义 h1 = 哈希_整数(cp.进程数 * 31 + cp.全局空闲页)
    定义 h2 = 哈希_整数(cp.内核版本 * 37 + cp.检查点ID)
    定义 h3 = cp.校验和
    // 第二层: 合并
    定义 h12 = 哈希_整数(h1 ^ h2)
    // 根哈希
    返回 哈希_整数(h12 ^ h3)
}

// NICT定理3: 检查点差异比较
函数 检查点_差异(cp1, cp2) {
    定义 可变 差异数 = 0
    如果 (cp1.进程数 != cp2.进程数) { 差异数 = 差异数 + 1 }
    如果 (cp1.全局空闲页 != cp2.全局空闲页) { 差异数 = 差异数 + 1 }
    如果 (cp1.校验和 != cp2.校验和) { 差异数 = 差异数 + 1 }
    如果 (cp1.当前PID != cp2.当前PID) { 差异数 = 差异数 + 1 }
    返回 差异数  // 0=完全相同
}

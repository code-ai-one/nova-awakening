导入("../基础.nova")
导入("../数学/基础/数学库.nova")


// 模型注册表
定义 可变 zoo_类型id = []
定义 可变 zoo_版本 = []
定义 可变 zoo_参数量 = []
定义 可变 zoo_指标 = []
定义 可变 zoo_状态 = []
定义 可变 zoo_总数 = 0

函数 zoo_注册(type_id, 版本, 参数量, 指标) {
 追加(zoo_类型id, type_id)
 追加(zoo_版本, 版本)
 追加(zoo_参数量, 参数量)
 追加(zoo_指标, 指标)
 追加(zoo_状态, 1)
 zoo_总数 = zoo_总数 + 1
 返回 zoo_总数 - 1
}

函数 zoo_查找(type_id) { 定义 可变 i = 0
 当 (i < zoo_总数) { 如果 (zoo_类型id[i] == type_id) { 返回 i }
 i = i + 1
 }
 返回 -1
}

函数 zoo_停用(id) { zoo_状态[id] = 0 }
函数 zoo_启用(id) { zoo_状态[id] = 1 }

// 模型比较
函数 zoo_最佳(指标类型) {
 // 指标类型: 1=最高指标, -1=最低指标
 定义 可变 best_id = -1
 定义 可变 best_val = -99999
 如果 (指标类型 < 0) { best_val = 99999 }
 定义 可变 i = 0
 当 (i < zoo_总数) { 如果 (zoo_状态[i] == 1) { 如果 (指标类型 >= 0) { 如果 (zoo_指标[i] > best_val) { best_val = zoo_指标[i]
 best_id = i }
 } 否则 { 如果 (zoo_指标[i] < best_val) { best_val = zoo_指标[i]
 best_id = i }
 }
 }
 i = i + 1
 }
 返回 best_id
}

函数 zoo_排名() {
    定义 可变 ids = []
 // 返回按指标降序排列的id列表
 定义 可变 i = 0
 当 (i < zoo_总数) { 如果 (zoo_状态[i] == 1) { 追加(ids, i) }
 i = i + 1
 }
 // 冒泡排序
 定义 n = 计数(ids)
 定义 可变 pi = 0
 当 (pi < n - 1) { 定义 可变 j = 0
 当 (j < n - 1 - pi) { 定义 a = ids[j]
 定义 b = ids[j + 1]
 如果 (zoo_指标[a] < zoo_指标[b]) {
 ids[j] = b
 ids[j + 1] = a
 }
 j = j + 1
 }
 pi = pi + 1
 }
 返回 ids
}

// A/B测试
定义 可变 ab_模型A = -1
定义 可变 ab_模型B = -1
定义 可变 ab_A_胜 = 0
定义 可变 ab_B_胜 = 0
定义 可变 ab_总轮 = 0

函数 AB_初始化(模型a, 模型b) {
 ab_模型A = 模型a
 ab_模型B = 模型b
 ab_A_胜 = 0
 ab_B_胜 = 0
 ab_总轮 = 0
}

函数 AB_记录(a_分数, b_分数) {
 ab_总轮 = ab_总轮 + 1
 如果 (a_分数 > b_分数) { ab_A_胜 = ab_A_胜 + 1 }
 否则 { ab_B_胜 = ab_B_胜 + 1 }
}

函数 AB_胜率A() {
    如果 (ab_总轮 == 0) { 返回 500
}
 返回 ab_A_胜 * 1000 / ab_总轮
}

函数 AB_显著(最小轮数) {
    如果 (ab_总轮 < 最小轮数) { 返回 假
}
 定义 差异 = 绝对值(ab_A_胜 - ab_B_胜)
 返回 差异 * 1000 / ab_总轮 > 200
}

// 模型效率评分
函数 效率评分(指标, 参数量) {
    如果 (参数量 <= 0) { 返回 0
}
 返回 指标 * 1000 / 参数量
}

// 模型集成
函数 集成_平均(预测列表) { 定义 n = 计数(预测列表)
 如果 (n == 0) { 返回 0 }
 定义 可变 i = 0
 当 (i < n) { 总和向量 = 总和向量 + 预测列表[i]
 i = i + 1 }
 返回 总和向量 / n
}

函数 集成_加权(预测列表, 权重列表) { 定义 n = 计数(预测列表)
 如果 (n == 0) { 返回 0 }
 定义 可变 wsum = 0
 定义 可变 wtot = 0
 定义 可变 i = 0
 当 (i < n) {
 wsum = wsum + 预测列表[i] * 权重列表[i] / 1000
 wtot = wtot + 权重列表[i]
 i = i + 1
 }
 如果 (wtot == 0) { 返回 0 }
 返回 wsum * 1000 / wtot
}

函数 集成_投票(预测列表) {
 // 返回众数
 定义 n = 计数(预测列表)
 定义 可变 最优 = 预测列表[0]
 定义 可变 best_cnt = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 计数值 = 0
 定义 可变 j = 0
 当 (j < n) { 如果 (预测列表[j] == 预测列表[i]) { 计数值 = 计数值 + 1 }
 j = j + 1
 }
 如果 (计数值 > best_cnt) { best_cnt = 计数值
 最优 = 预测列表[i] }
 i = i + 1
 }
 返回 最优
}

// 活跃模型数
函数 zoo_活跃数() { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < zoo_总数) { 如果 (zoo_状态[i] == 1) { c = c + 1 }
 i = i + 1
 }
 返回 c
}

// 模型总数查询
函数 zoo_模型总数() { 返回 zoo_总数 }

// 模型版本管理
定义 可变 _模型_版本 = []

函数 模型版本_注册(模型名, 版本号, 参数量, 性能分) {
 追加(_模型_版本, [模型名, 版本号, 参数量, 性能分, 0])
}

函数 模型版本_最新(模型名) { 定义 可变 最新版 = -1
 定义 可变 最新idx = -1
 定义 可变 i = 0
 当 (i < 计数(_模型_版本)) { 如果 (_模型_版本[i][0] == 模型名 且 _模型_版本[i][1] > 最新版) {
 最新版 = _模型_版本[i][1]
 最新idx = i
 }
 i = i + 1
 }
 如果 (最新idx >= 0) { 返回 _模型_版本[最新idx] }
 返回 空
}

// A/B测试
函数 AB测试_比较(模型A分数, 模型B分数, 样本数) { 定义 差值 = 模型A分数 - 模型B分数
 如果 (差值 > 样本数 / 10) { 返回 "A显著优于B" }
 如果 (差值 < 0 - 样本数 / 10) { 返回 "B显著优于A" }
 返回 "无显著差异"
}

// 模型性能基准
函数 基准_延迟评估(模型idx, 批大小, 序列长度) {
    如果 (模型idx < 0 或 模型idx >= zoo_总数) { 返回 0
}
 返回 zoo_参数量[模型idx] * 批大小 * 序列长度 / 1000000
}

函数 基准_吞吐量评估(延迟, 批大小) {
    如果 (延迟 == 0) { 返回 0
}
 返回 批大小 * 1000 / 延迟
}

// 自动模型选择
函数 自动选择_最佳模型(任务类型, 最大参数量, 最小性能) { 定义 可变 最佳 = -1
 定义 可变 最佳分 = 0
 定义 可变 i = 0
 当 (i < zoo_总数) { 如果 (zoo_参数量[i] <= 最大参数量 且 zoo_状态[i] == 1) { 定义 分数 = zoo_指标[i]
 如果 (分数 >= 最小性能 且 分数 > 最佳分) {
 最佳 = i
 最佳分 = 分数
 }
 }
 i = i + 1
 }
 返回 最佳
}

函数 自动选择_最小模型(最小性能) { 定义 可变 最佳 = -1
 定义 可变 最小参 = 999999999
 定义 可变 i = 0
 当 (i < zoo_总数) { 如果 (zoo_状态[i] == 1 且 zoo_指标[i] >= 最小性能) { 如果 (zoo_参数量[i] < 最小参) {
 最佳 = i
 最小参 = zoo_参数量[i]
 }
 }
 i = i + 1
 }
 返回 最佳
}

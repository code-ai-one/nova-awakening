导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./字形度量.nova")

// Skia→Nova: 字体渲染引擎 — OpenType解析/整形/字形缓存/文本排版
// 对应: skia/src/core/Sk字体.cpp (~2000行)
//       skia/src/core/SkScalerContext.cpp 
//        (
//  (
// 字体渲染管线:
// ① OpenType解析: 读取字体文件(cmap/glyf/head/hhea/hmtx/kern/GPOS/GSUB)
// ② 字符→字形映射: Unicode codepoint → Glyph ID (通过cmap表)
// ③ 整形(Shaping): 连字/替换/定位 (HarfBuzz)
// ④ 光栅化: 轮廓→位图 (FreeType)
// ⑤ 字形缓存: LRU缓存避免重复光栅化
// ⑥ 子像素渲染: LCD(RGB/BGR)子像素抗锯齿
// ⑦ Hinting: 网格拟合(提高小字号清晰度)
// 【Nova特色】AI字体优化:
// ① AI预测即将显示的字形, 提前光栅化
// ② AI动态调整hinting级别(屏幕DPI感知)

// §1 OpenType表结构

结构 字体File {
 数据,
 大小,
 // 表偏移
 cmap偏移,
 glyf偏移,
 loca偏移,
 head偏移,
 hhea偏移,
 hmtx偏移,
 kern偏移,
 GPOS偏移,
 GSUB偏移,
 name偏移,
 OS2偏移,
 post偏移,
 // 字体信息
 字形数,
 unitsPerEm,
 ascender,
 descender,
 lineGap,
 // cmap格式
 cmap格式,    // u16 4/6/12
 // 标志
 loca格式,    // u8 0=short 1=long
}

结构 GlyphOutline {
 // 轮廓点
 点X,    // u64 i16*数组
 点Y,
 标志,    // u64 u8*数组 (on-curve/off-curve)
 点数,
 // 轮廓结束索引
 轮廓结束,    // u64 u16*数组
 轮廓数,
 // 边界框
 xMin,
 yMin,
 xMax,
 yMax,
 // 是否复合字形
 是复合,
}

结构 GlyphMetrics {
 advanceWidth,    // u16 字形前进宽度
 lsb,    // i16 左侧轴承
 // 边界
 xMin,
 yMin,
 xMax,
 yMax,
}

// §2 字体文件解析


函数 字体_加载(数据, 大小) {
 如果 (数据 == 0 || 大小 < 12) { 返回 0 }
 定义 font = 堆_分配(字体File)
 font.数据 = 数据; font.大小 = 大小

 // 读取sfVersion (TrueType: 0x00010000, OpenType CFF: OTTO)
 定义 版本 = 字体_读u32(数据, 0)

 // 读取表数量
 定义 表数 = 字体_读u16(数据, 4)

 // 遍历表目录, 记录偏移
 定义 可变 i = 0
 当 (i < 表数) {
 定义 偏移 = 12 + i * 16
 定义 tag = 字体_读u32(数据, 偏移)
 定义 表偏移 = 字体_读u32(数据, 偏移 + 8)
 // tag比较 (big-endian ASCII)
 如果 (tag == 0x636D6170) { font.cmap偏移 = 表偏移 } // cmap
 否则 如果 (tag == 0x676C7966) { font.glyf偏移 = 表偏移 } // glyf
 否则 如果 (tag == 0x6C6F6361) { font.loca偏移 = 表偏移 } // loca
 否则 如果 (tag == 0x68656164) { font.head偏移 = 表偏移 } // head
 否则 如果 (tag == 0x68686561) { font.hhea偏移 = 表偏移 } // hhea
 否则 如果 (tag == 0x686D7478) { font.hmtx偏移 = 表偏移 } // hmtx
 否则 如果 (tag == 0x6B65726E) { font.kern偏移 = 表偏移 } // kern
 否则 如果 (tag == 0x47504F53) { font.GPOS偏移 = 表偏移 } // GPOS
 否则 如果 (tag == 0x47535542) { font.GSUB偏移 = 表偏移 } // GSUB
 否则 如果 (tag == 0x4F532F32) { font.OS2偏移 = 表偏移 } // OS/2
 i = i + 1
 }

 // 解析head表
 如果 (font.head偏移 > 0) {
 font.unitsPerEm = 字体_读u16(数据, font.head偏移 + 18)
 font.loca格式 = 字体_读u16(数据, font.head偏移 + 50)
 }

 // 解析hhea表
 如果 (font.hhea偏移 > 0) {
 font.ascender = 字体_读i16(数据, font.hhea偏移 + 4)
 font.descender = 字体_读i16(数据, font.hhea偏移 + 6)
 font.lineGap = 字体_读i16(数据, font.hhea偏移 + 8)
 font.字形数 = 字体_读u16(数据, font.hhea偏移 + 34)
 }

 返回 font
}

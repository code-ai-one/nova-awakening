导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("./端口输入.nova")

// 2. 玻璃系统栏 (32px, 逐行渐变 + 高光顶线 + 蓝光底边)

定义 可变 bar_y = 0
当 (bar_y < 32) {
    定义 可变 bar_c = 0
    如果 (bar_y == 0) { bar_c = 0x002D3352 }
    否则 如果 (bar_y == 1) { bar_c = 0x00282E48 }
    否则 如果 (bar_y == 30) { bar_c = 0x00121628 }
    否则 如果 (bar_y == 31) { bar_c = 0x001B3060 }
    否则 {
        定义 bt = bar_y * 256 / 32
        bar_c = (24 - bt * 10 / 256) * 65536 + (28 - bt * 12 / 256) * 256 + (52 - bt * 20 / 256)
    }
    定义 可变 bar_x = 0
    当 (bar_x < 屏宽) { 内存写32(LFB + bar_y * 行字节 + bar_x * 4, bar_c); bar_x = bar_x + 1 }
    bar_y = bar_y + 1
}

// "Nova OS" (蓝色发光)
定义 标题 = [78,111,118,97,32,79,83]
定义 可变 ti = 0
当 (ti < 7) {
    定义 ch_idx = (标题[ti] - 32) * 8
    如果 (ch_idx >= 0 && ch_idx < 760) {
        定义 可变 行r = 0
        当 (行r < 8) {
            定义 行数据 = 字体[ch_idx + 行r]
            定义 可变 位r = 0
            当 (位r < 8) {
                如果 ((行数据 >> (7 - 位r)) & 1) {
                    内存写32(LFB + (12 + 行r) * 行字节 + (14 + ti * 9 + 位r) * 4, 0x004FC3F7)
                }
                位r = 位r + 1
            }
            行r = 行r + 1
        }
    }
    ti = ti + 1
}

// 绿色圆点 + "AI Ready"
定义 可变 dot_y = 0
当 (dot_y < 6) {
    定义 可变 dot_x = 0
    当 (dot_x < 6) { 内存写32(LFB + (13 + dot_y) * 行字节 + (屏宽 - 178 + dot_x) * 4, 0x0022C55E); dot_x = dot_x + 1 }
    dot_y = dot_y + 1
}
定义 ai文字 = [65,73,32,82,101,97,100,121]
定义 可变 ai_i = 0
当 (ai_i < 8) {
    定义 ai_idx = (ai文字[ai_i] - 32) * 8
    如果 (ai_idx >= 0 && ai_idx < 760) {
        定义 可变 ai_r = 0
        当 (ai_r < 8) {
            定义 ai_rd = 字体[ai_idx + ai_r]
            定义 可变 ai_b = 0
            当 (ai_b < 8) {
                如果 ((ai_rd >> (7 - ai_b)) & 1) {
                    内存写32(LFB + (12 + ai_r) * 行字节 + (屏宽 - 168 + ai_i * 9 + ai_b) * 4, 0x0022C55E)
                }
                ai_b = ai_b + 1
            }
            ai_r = ai_r + 1
        }
    }
    ai_i = ai_i + 1
}

// "00:51" 时间 (淡白)
定义 时间文字 = [48,48,58,53,49]
定义 可变 tm_i = 0
当 (tm_i < 5) {
    定义 tm_idx = (时间文字[tm_i] - 32) * 8
    如果 (tm_idx >= 0 && tm_idx < 760) {
        定义 可变 tm_r = 0
        当 (tm_r < 8) {
            定义 tm_rd = 字体[tm_idx + tm_r]
            定义 可变 tm_b = 0
            当 (tm_b < 8) {
                如果 ((tm_rd >> (7 - tm_b)) & 1) {
                    内存写32(LFB + (12 + tm_r) * 行字节 + (屏宽 - 48 + tm_i * 9 + tm_b) * 4, 0x00C8C8D8)
                }
                tm_b = tm_b + 1
            }
            tm_r = tm_r + 1
        }
    }
    tm_i = tm_i + 1
}
打印("[渲染] 玻璃系统栏 OK")

// 3. 玻璃任务栏 (32px, 逐行渐变 + 蓝光顶线)
定义 任务y = 屏高 - 32
定义 可变 tb_y = 0
当 (tb_y < 32) {
    定义 可变 tb_c = 0
    如果 (tb_y == 0) { tb_c = 0x001B3060 }
    否则 如果 (tb_y == 1) { tb_c = 0x00182844 }
    否则 {
        定义 tt = tb_y * 256 / 32
        tb_c = (14 + tt * 4 / 256) * 65536 + (18 + tt * 2 / 256) * 256 + (34 - tt * 6 / 256)
    }
    定义 可变 tb_x = 0
    当 (tb_x < 屏宽) { 内存写32(LFB + (任务y + tb_y) * 行字节 + tb_x * 4, tb_c); tb_x = tb_x + 1 }
    tb_y = tb_y + 1
}
// N按钮(玻璃蓝渐变)
定义 可变 ni = 0
当 (ni < 28) {
    定义 可变 nj = 2
    当 (nj < 28) {
        定义 nb_t = nj * 256 / 28
        定义 nb_c = (30 + (256 - nb_t) * 20 / 256) * 65536 + (80 + (256 - nb_t) * 30 / 256) * 256 + (200 + (256 - nb_t) * 40 / 256)
        内存写32(LFB + (任务y + nj) * 行字节 + (4 + ni) * 4, nb_c)
        nj = nj + 1
    }
    ni = ni + 1
}
// N按钮文字
定义 n_idx = (78 - 32) * 8
定义 可变 n_r = 0
当 (n_r < 8) {
    定义 n_rd = 字体[n_idx + n_r]
    定义 可变 n_b = 0
    当 (n_b < 8) {
        如果 ((n_rd >> (7 - n_b)) & 1) { 内存写32(LFB + (任务y + 10 + n_r) * 行字节 + (10 + n_b) * 4, 0x00FFFFFF) }
        n_b = n_b + 1
    }
    n_r = n_r + 1
}

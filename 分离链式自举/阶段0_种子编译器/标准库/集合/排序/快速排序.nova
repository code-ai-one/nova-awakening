导入("../../基础.nova")
导入("../../数学/工具.nova")
导入("./归并排序.nova")

//
// Nova  标准库  排序引擎
// 多算法排序: 快速排序 + 归并排序 + 堆排序 + 插入排序 + 计数排序

//  基础操作

函数 快排_交换(列表, i, j) {
    定义 暂存 = 列表[i]
    列表[i] = 列表[j]
    列表[j] = 暂存
}

//  排序统计
定义 可变 排序_统计 = [0, 0, 0] // [比较, 交换, 当前深度, 最大深度]

函数 排序_统计报告() {
    返回 [排序_统计[0], 排序_统计[1], 排序_统计[3]]
}

函数 排序_重置统计() {
    排序_统计[0] = 0
    排序_统计[1] = 0
    排序_统计[2] = 0
    排序_统计[3] = 0
}

//  快速排序

函数 分区(列表, 低, 高) {
    定义 基准 = 列表[高]
    定义 可变 i = 低 - 1
    定义 可变 j = 低
    当 (j < 高) {
        排序_统计[0] = 排序_统计[0] + 1
        如果 (列表[j] <= 基准) {
            i = i + 1
            快排_交换(列表, i, j)
            排序_统计[1] = 排序_统计[1] + 1
        }
        j = j + 1
    }
    快排_交换(列表, i + 1, 高)
    排序_统计[1] = 排序_统计[1] + 1
    返回 i + 1
}

函数 三数取中(列表, 低, 高) {
    定义 中 = (低 + 高) / 2
    如果 (列表[低] > 列表[中]) { 快排_交换(列表, 低, 中) }
    如果 (列表[低] > 列表[高]) { 快排_交换(列表, 低, 高) }
    如果 (列表[中] > 列表[高]) { 快排_交换(列表, 中, 高) }
    快排_交换(列表, 中, 高 - 1)
    返回 列表[高 - 1]
}

函数 分区_三数(列表, 低, 高) {
    如果 (高 - 低 < 3) { 返回 分区(列表, 低, 高) }
    定义 基准 = 三数取中(列表, 低, 高)
    定义 可变 i = 低
    定义 可变 j = 高 - 1
    当 (真) {
        i = i + 1
        当 (i < 高 - 1 且 列表[i] < 基准) { i = i + 1 排序_统计[0] = 排序_统计[0] + 1 }
        j = j - 1
        当 (j > 低 且 列表[j] > 基准) { j = j - 1 排序_统计[0] = 排序_统计[0] + 1 }
        如果 (i >= j) { 快排_交换(列表, i, 高 - 1) 返回 i }
        快排_交换(列表, i, j)
        排序_统计[1] = 排序_统计[1] + 1
    }
    快排_交换(列表, i, 高 - 1)
    返回 i
}

函数 快排内部(列表, 低, 高) {
    排序_统计[2] = 排序_统计[2] + 1
    如果 (排序_统计[2] > 排序_统计[3]) { 排序_统计[3] = 排序_统计[2] }
    如果 (低 < 高) {
        如果 (高 - 低 < 16) {
            插入排序_范围(列表, 低, 高)
        } 否则 {
            定义 中 = 分区_三数(列表, 低, 高)
            快排内部(列表, 低, 中 - 1)
            快排内部(列表, 中 + 1, 高)
        }
    }
    排序_统计[2] = 排序_统计[2] - 1
}

函数 快排_快速排序(列表) {
    定义 长 = 计数(列表)
    如果 (长 > 1) { 快排内部(列表, 0, 长 - 1) }
    返回 列表
}

//  插入排序 (小数组最优, 0, 0)

函数 快排_插入排序(列表) {
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        定义 键 = 列表[i]
        定义 可变 j = i - 1
        当 (j >= 0 且 列表[j] > 键) {
            列表[j + 1] = 列表[j]
            j = j - 1
            排序_统计[0] = 排序_统计[0] + 1
        }
        列表[j + 1] = 键
        i = i + 1
    }
    返回 列表
}

函数 插入排序_范围(列表, 低, 高) {
    定义 可变 i = 低 + 1
    当 (i <= 高) {
        定义 键 = 列表[i]
        定义 可变 j = i - 1
        当 (j >= 低 且 列表[j] > 键) {
            列表[j + 1] = 列表[j]
            j = j - 1
            排序_统计[0] = 排序_统计[0] + 1
        }
        列表[j + 1] = 键
        i = i + 1
    }
}

//  归并排序 (稳定排序, 0)

函数 归并(列表, 临时, 左起, 左止, 右止) {
    定义 可变 i = 左起
    定义 可变 j = 左止 + 1
    定义 可变 k = 左起
    当 (i <= 左止 且 j <= 右止) {
        排序_统计[0] = 排序_统计[0] + 1
        如果 (列表[i] <= 列表[j]) {
            临时[k] = 列表[i]
            i = i + 1
        } 否则 {
            临时[k] = 列表[j]
            j = j + 1
        }
        k = k + 1
    }
    当 (i <= 左止) { 临时[k] = 列表[i] i = i + 1 k = k + 1 }
    当 (j <= 右止) { 临时[k] = 列表[j] j = j + 1 k = k + 1 }
    i = 左起
    当 (i <= 右止) { 列表[i] = 临时[i] i = i + 1 }
}

函数 归并排序内部(列表, 临时, 左, 右) {
    如果 (左 < 右) {
        定义 中 = (左 + 右) / 2
        归并排序内部(列表, 临时, 左, 中)
        归并排序内部(列表, 临时, 中 + 1, 右)
        归并(列表, 临时, 左, 中, 右)
    }
}

函数 快排_归并排序(列表) {
    定义 长 = 计数(列表)
    如果 (长 <= 1) { 返回 列表 }
    定义 可变 临时 = []
    定义 可变 i = 0
    当 (i < 长) { 追加(临时, 0) i = i + 1 }
    归并排序内部(列表, 临时, 0, 长 - 1)
    返回 列表
}

//  堆排序

函数 下沉(列表, 大小, 根) {
    定义 可变 最大 = 根
    定义 左 = 2 * 根 + 1
    定义 右 = 2 * 根 + 2
    排序_统计[0] = 排序_统计[0] + 1
    如果 (左 < 大小 且 列表[左] > 列表[最大]) { 最大 = 左 }
    排序_统计[0] = 排序_统计[0] + 1
    如果 (右 < 大小 且 列表[右] > 列表[最大]) { 最大 = 右 }
    如果 (最大 != 根) {
        快排_交换(列表, 根, 最大)
        排序_统计[1] = 排序_统计[1] + 1
        下沉(列表, 大小, 最大)
    }
}

函数 快排_堆排序(列表) {
    定义 长 = 计数(列表)
    定义 可变 i = 长 / 2 - 1
    当 (i >= 0) { 下沉(列表, 长, i) i = i - 1 }
    i = 长 - 1
    当 (i > 0) {
        快排_交换(列表, 0, i)
        下沉(列表,  i, 0)
        i = i - 1
    }
    返回 列表
}

//  计数排序 (整数专用 O(n+k), 0, 0)

函数 快排_计数排序(列表) {
    定义 可变 计数表 = []
    定义 长 = 计数(列表)
    如果 (长 <= 1) { 返回 列表 }
    定义 可变 最小 = 列表[0]
    定义 可变 最大 = 列表[0]
    定义 可变 i = 1
    当 (i < 长) {
        如果 (列表[i] < 最小) { 最小 = 列表[i] }
        如果 (列表[i] > 最大) { 最大 = 列表[i] }
        i = i + 1
    }
    定义 范围 = 最大 - 最小 + 1
    如果 (范围 > 100000) { 返回 快排_快速排序(列表) }
    i = 0
    当 (i < 范围) { 追加(计数表, 0) i = i + 1 }
    i = 0
    当 (i < 长) { 计数表[列表[i] - 最小] = 计数表[列表[i] - 最小] + 1 i = i + 1 }
    定义 可变 写位 = 0
    i = 0
    当 (i < 范围) {
        当 (计数表[i] > 0) {
            列表[写位] = i + 最小
            写位 = 写位 + 1
            计数表[i] = 计数表[i] - 1
        }
        i = i + 1
    }
    返回 列表
}

//  希尔排序

函数 希尔排序(列表) {
    定义 长 = 计数(列表)
    定义 可变 间隔 = 长 / 2
    当 (间隔 > 0) {
        定义 可变 i = 间隔
        当 (i < 长) {
            定义 键 = 列表[i]
            定义 可变 j = i
            当 (j >= 间隔 且 列表[j - 间隔] > 键) {
                列表[j] = 列表[j - 间隔]
                j = j - 间隔
                排序_统计[0] = 排序_统计[0] + 1
            }
            列表[j] = 键
            i = i + 1
        }
        间隔 = 间隔 / 2
    }
    返回 列表
}

//  选择排序

函数 快排_选择排序(列表) {
    定义 长 = 计数(列表)
    定义 可变 i = 0
    当 (i < 长 - 1) {
        定义 可变 最小位 = i
        定义 可变 j = i + 1
        当 (j < 长) {
            排序_统计[0] = 排序_统计[0] + 1
            如果 (列表[j] < 列表[最小位]) { 最小位 = j }
            j = j + 1
        }
        如果 (最小位 != i) {
            快排_交换(列表, i, 最小位)
            排序_统计[1] = 排序_统计[1] + 1
        }
        i = i + 1
    }
    返回 列表
}

函数 计算逆序度(列表) {
    定义 长 = 计数(列表)
    如果 (长 <= 1) { 返回 0 }
    定义 可变 有序 = 0
    定义 可变 i = 0
    当 (i < 长 - 1) {
        如果 (列表[i] > 列表[i + 1]) { 逆序 = 逆序 + 1 }
        否则 { 有序 = 有序 + 1 }
        i = i + 1
    }
    返回 逆序 * 100 / (长 - 1)
}

函数 已排序(列表) {
    定义 可变 i = 0
    当 (i < 计数(列表) - 1) {
        如果 (列表[i] > 列表[i + 1]) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 已逆序(列表) {
    定义 可变 i = 0
    当 (i < 计数(列表) - 1) {
        如果 (列表[i] < 列表[i + 1]) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 智能排序(列表) {
    定义 长 = 计数(列表)
    排序_重置统计()
    如果 (长 <= 1) { 返回 列表 }
    如果 (已排序(列表)) { 返回 列表 }
    如果 (长 <= 16) { 返回 插入排序(列表, 0, 0) }
    如果 (已逆序(列表)) {
        定义 可变 i = 0
        定义 可变 j = 长 - 1
        当 (i < j) { 快排_交换(列表, i, j) i = i + 1 j = j - 1 }
        返回 列表
    }
    定义 逆序度 = 计算逆序度(列表)
    如果 (逆序度 < 15) { 返回 插入排序(列表, 0, 0) }
    如果 (长 <= 64) { 返回 希尔排序(列表) }
    返回 快排_快速排序(列表)
}

函数 预测排序复杂度(列表) {
    定义 长 = 计数(列表)
    如果 (长 <= 1) { 返回 [0, "常数"] }
    定义 逆序度 = 计算逆序度(列表)
    如果 (逆序度 < 10) { 返回 [长, "近线性(接近有序)"] }
    如果 (长 <= 16) { 返回 [长 * 长, "平方(小数组插入)"] }
    定义 可变 估算 = 0
    定义 可变 n = 长
    当 (n > 1) { 估算 = 估算 + 1 n = n / 2 }
    返回 [长 * 估算, "对数线性(快排/归并)"]
}

//  二分查找 (排序后使用, 0)

函数 快速排序_二分查找(列表, 目标) {
    定义 可变 低 = 0
    定义 可变 高 = 计数(列表) - 1
    当 (低 <= 高) {
        定义 中 = (低 + 高) / 2
        如果 (列表[中] == 目标) { 返回 中 }
        如果 (列表[中] < 目标) { 低 = 中 + 1 }
        否则 { 高 = 中 - 1 }
    }
    返回 0 - 1
}

函数 二分查找_左边界(列表, 目标) {
    定义 可变 低 = 0
    定义 可变 高 = 计数(列表)
    当 (低 < 高) {
        定义 中 = (低 + 高) / 2
        如果 (列表[中] < 目标) { 低 = 中 + 1 }
        否则 { 高 = 中 }
    }
    返回 低
}

函数 二分查找_右边界(列表, 目标) {
    定义 可变 低 = 0
    定义 可变 高 = 计数(列表)
    当 (低 < 高) {
        定义 中 = (低 + 高) / 2
        如果 (列表[中] <= 目标) { 低 = 中 + 1 }
        否则 { 高 = 中 }
    }
    返回 低 - 1
}

//  第K小元素 (快速选择)

函数 快速排序_快速选择(列表, k) {
    定义 可变 低 = 0
    定义 可变 高 = 计数(列表) - 1
    当 (低 < 高) {
        定义 基准位 = 分区(列表, 低, 高)
        如果 (基准位 == k) { 返回 列表[k] }
        如果 (基准位 < k) { 低 = 基准位 + 1 }
        否则 { 高 = 基准位 - 1 }
    }
    返回 列表[低]
}

函数 快排_中位数(列表) {
    定义 长 = 计数(列表)
    如果 (长 == 0) { 返回 0 }
    定义 可变 副本 = []
    定义 可变 i = 0
    当 (i < 长) { 追加(副本, 列表[i]) i = i + 1 }
    返回 快速排序_快速选择(副本, 长 / 2)
}

//  数组工具

函数 数组最大值(列表) {
    如果 (计数(列表) == 0) { 返回 0 }
    定义 可变 最大 = 列表[0]
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        如果 (列表[i] > 最大) { 最大 = 列表[i] }
        i = i + 1
    }
    返回 最大
}

函数 数组最小值(列表) {
    如果 (计数(列表) == 0) { 返回 0 }
    定义 可变 最小 = 列表[0]
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        如果 (列表[i] < 最小) { 最小 = 列表[i] }
        i = i + 1
    }
    返回 最小
}

函数 数组求和(列表) {
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < 计数(列表)) { 和 = 和 + 列表[i] i = i + 1 }
    返回 和
}

函数 数组平均(列表) {
    如果 (计数(列表) == 0) { 返回 0 }
    返回 数组求和(列表) / 计数(列表)
}

函数 数组反转(列表) {
    定义 可变 i = 0
    定义 可变 j = 计数(列表) - 1
    当 (i < j) { 快排_交换(列表, i, j) i = i + 1 j = j - 1 }
    返回 列表
}

函数 数组去重(列表) {
    如果 (计数(列表) <= 1) { 返回 列表 }
    定义 可变 副本 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) { 追加(副本, 列表[i]) i = i + 1 }
    快排_快速排序(副本)
    定义 可变 结果 = [副本[0]]
    i = 1
    当 (i < 计数(副本)) {
        如果 (副本[i] != 副本[i - 1]) { 追加(结果, 副本[i]) }
        i = i + 1
    }
    返回 结果
}

// 数组填充与生成

函数 数组填充(大小, 值) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 大小) { 追加(结果, 值) i = i + 1 }
    返回 结果
}

函数 数组范围(起始, 结束) {
    定义 可变 结果 = []
    定义 可变 i = 起始
    当 (i < 结束) { 追加(结果, i) i = i + 1 }
    返回 结果
}

函数 数组复制(列表) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) { 追加(结果, 列表[i]) i = i + 1 }
    返回 结果
}

函数 排序推荐(列表) {
    定义 长 = 计数(列表)
    如果 (长 <= 1) { 返回 "无需排序" }
    如果 (长 <= 16) { 返回 "插入排序(小数组最优, 0, 0)" }
    定义 逆序度 = 计算逆序度(列表)
    如果 (逆序度 < 10) { 返回 "插入排序(近有序, 0, 0)" }
    如果 (逆序度 > 90) { 返回 "反转+插入(近逆序)" }
    如果 (长 <= 100) { 返回 "希尔排序(中等数组)" }
    如果 (长 > 10000) { 返回 "归并排序(大数组稳定, 0)" }
    返回 "快速排序(通用最优, 0)"
}

// FB003反哺: 三路快速排序 (Dutch National Flag 算法)
// 实验室验证: 重复元素场景比二路快排快约4倍 (O(n²)→O(n log n))
// 适用场景: 数组中有大量重复值（如汉字频率排序、分词标签排序）
// 三路分区: < pivot | = pivot | > pivot

函数 三路快排_内部(列表, 低, 高) {
    如果 (低 >= 高) { 返回 空 }
    // 小数组用插入排序
    如果 (高 - 低 < 10) { 插入排序_范围(列表, 低, 高); 返回 空 }

    // 三路分区（迪杰斯特拉 Dutch National Flag）
    定义 基准 = 列表[(低 + 高) / 2]  // 中间元素作为基准（避免有序数组退化）
    定义 可变 lt = 低   // [低, lt) < 基准
    定义 可变 gt = 高   // (gt, 高] > 基准
    定义 可变 i  = 低   // [lt, i) = 基准

    当 (i <= gt) {
        如果 (列表[i] < 基准) {
            快排_交换(列表, lt, i)
            lt = lt + 1
            i = i + 1
        } 否则 如果 (列表[i] > 基准) {
            快排_交换(列表, i, gt)
            gt = gt - 1
            // 注意: i不递增，被换来的元素需要重新比较
        } 否则 {
            i = i + 1  // = 基准，跳过
        }
    }
    // 递归排序 < 和 > 部分（= 基准的中间部分已经就位）
    如果 (lt > 低) { 三路快排_内部(列表, 低, lt - 1) }
    如果 (gt < 高) { 三路快排_内部(列表, gt + 1, 高) }
}

// 公开接口: 三路快速排序
函数 三路快速排序(列表) {
    定义 长 = 计数(列表)
    如果 (长 > 1) { 三路快排_内部(列表, 0, 长 - 1) }
    返回 列表
}

// 自适应排序: 根据重复度自动选择二路或三路快排
// 重复率 > 30% 时使用三路快排，否则使用原有快排
函数 自适应快排(列表) {
    定义 长 = 计数(列表)
    如果 (长 <= 1) { 返回 列表 }

    // 采样检测重复率（采样10个元素）
    定义 可变 采样大小 = 10
    如果 (长 < 10) { 采样大小 = 长 }
    定义 可变 唯一数 = 0
    定义 可变 已见 = []
    定义 可变 i = 0
    当 (i < 采样大小) {
        定义 索引 = i * 长 / 采样大小
        定义 数值 = 列表[索引]
        定义 可变 j = 0
        当 (j < 计数(已见)) {
            如果 (已见[j] == 数值) { 重复 = 真 }
            j = j + 1
        }
        如果 (!重复) {
            追加(已见, 数值)
            唯一数 = 唯一数 + 1
        }
        i = i + 1
    }
    // 唯一率 = 唯一数/采样大小；重复率 = 1 - 唯一率
    定义 唯一率 = 唯一数 * 100 / 采样大小

    如果 (唯一率 < 70) {
        // 重复率 > 30%，三路快排
        返回 三路快速排序(列表)
    }
    返回 快排_快速排序(列表)
}

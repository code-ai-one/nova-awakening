// Nova 原生垃圾回收器 — 三色标记+分代回收+根扫描+弱引用
// 职责: 根标记 + 三色传播 + 清除释放 + 分代晋升 + 弱引用处理 + GC统计
// 层级: 第7层运行时

导入("../../标准库/基础.nova")
导入("../内存管理/内存profile.nova")

定义 GC_白 = 0
定义 GC_灰 = 1
定义 GC_黑 = 2

// 对象: [颜色, 大小, 引用列表, 代龄, 存活]
// 引用列表 = 该对象引用的其他对象ID列表
// 代龄 = 存活过多少次GC (用于分代优化)

// GC堆: [对象表, 根集, 灰色栈, 总字节, 阈值, GC次数, 释放总数]

函数 GC_创建(容量, 阈值) { 如果 (容量 <= 0) { 容量 = 64 } // 最小容量保护
 如果 (阈值 <= 0) { 阈值 = 容量 * 8 } // 默认阈值
 定义 可变 对象表 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(对象表, [GC_白, 0, [],])
 i = i + 1 }
 返回 [对象表, [], [], 0, 阈值,]
}

// 分配对象
// 策略: 阈值主动GC → 线性扫描 → 紧急GC重试 → OOM
函数 GC_分配(gc, 大小) {
    如果 (大小 <= 0) { 大小 = 1
}
 // 1. 主动阈值检查: 总字节超阈值时先收集再分配 (减少碎片+避免槽位耗尽)
 如果 (gc[3] + 大小 > gc[4]) {
 GC_收集(gc)
 }
 // 2. 线性扫描空闲槽位
 定义 表 = gc[0]
 定义 可变 i = 0
 当 (i < 计数(表)) { 如果 (表[i][4] == 0) {
 表[i][0] = GC_白
 表[i][1] = 大小
 表[i][2] = []
 表[i][3] = 0
 表[i][4] = 1
 gc[3] = gc[3] + 大小
 如果 (内存profile_当前() != 空) { 内存度量_记录分配(内存profile_当前(), 大小) }
 返回 i
 }
 i = i + 1
 }
 // 3. 紧急GC: 所有槽位已满, 强制收集后重试
 GC_收集(gc)
 i = 0
 当 (i < 计数(表)) { 如果 (表[i][4] == 0) {
 表[i][0] = GC_白
 表[i][1] = 大小
 表[i][2] = []
 表[i][3] = 0
 表[i][4] = 1
 gc[3] = gc[3] + 大小
 如果 (内存profile_当前() != 空) { 内存度量_记录分配(内存profile_当前(), 大小) }
 返回 i
 }
 i = i + 1
 }
 如果 (内存profile_当前() != 空) { 内存度量_记录OOM(内存profile_当前()) }
 返回 -1 // 4. OOM: 收集后仍无空间
}

// 添加引用关系
函数 GC_添加引用(gc, 来源, 目标) { 如果 (来源 >= 0 且 来源 < 计数(gc[0]) 且 gc[0][来源][4] == 1 且 目标 >= 0 且 目标 < 计数(gc[0])) {
 追加(gc[0][来源][2], 目标)
 }
}

// 设置根集合
函数 GC_设根(gc, 根列表) { gc[1] = 根列表 }
函数 GC_加根(gc, 对象id) { 追加(gc[1], 对象id) }

// 阶段1: 标记 — 从根出发遍历对象图
函数 GC_标记阶段(gc) {
 // 重置所有存活对象为白色
 定义 可变 i = 0
 当 (i < 计数(gc[0])) { 如果 (gc[0][i][4] == 1) { gc[0][i][0] = GC_白 }
 i = i + 1
 }
 // 根对象入灰色栈
 gc[2] = []
 i = 0
 当 (i < 计数(gc[1])) { 定义 可变 rid = gc[1][i]
 如果 (rid >= 0 且 rid < 计数(gc[0]) 且 gc[0][rid][4] == 1 且 gc[0][rid][0] == GC_白) {
 gc[0][rid][0] = GC_灰
 追加(gc[2], rid)
 }
 i = i + 1
 }
 // 遍历灰色栈 (BFS)
 定义 可变 头 = 0
 当 (头 < 计数(gc[2])) { 定义 可变 当前id = gc[2][头]
 头 = 头 + 1
 定义 可变 引用列表 = gc[0][当前id][2]
 定义 可变 j = 0
 当 (j < 计数(引用列表)) { 定义 可变 ref = 引用列表[j]
 如果 (ref >= 0 且 ref < 计数(gc[0]) 且 gc[0][ref][4] == 1 且 gc[0][ref][0] == GC_白) {
 gc[0][ref][0] = GC_灰
 追加(gc[2], ref)
 }
 j = j + 1
 }
 gc[0][当前id][0] = GC_黑
 }
}

// 增量标记 (每次处理N个灰色对象)
函数 GC_增量标记(gc, 步数) { 定义 可变 已处理 = 0
 定义 可变 头 = 0
 // 找到灰色栈中第一个灰色对象
 当 (头 < 计数(gc[2]) 且 已处理 < 步数) { 定义 可变 当前id = gc[2][头]
 头 = 头 + 1
 如果 (gc[0][当前id][0] == GC_灰) { 定义 可变 引用列表 = gc[0][当前id][2]
 定义 可变 j = 0
 当 (j < 计数(引用列表)) { 定义 可变 ref = 引用列表[j]
 如果 (ref >= 0 且 ref < 计数(gc[0]) 且 gc[0][ref][4] == 1 且 gc[0][ref][0] == GC_白) {
 gc[0][ref][0] = GC_灰
 追加(gc[2], ref)
 }
 j = j + 1
 }
 gc[0][当前id][0] = GC_黑
 已处理 = 已处理 + 1
 }
 }
 返回 已处理
}

// 阶段2: 清除 — 释放白色对象
函数 GC_清除阶段(gc) { 定义 可变 释放数 = 0
 定义 可变 i = 0
 当 (i < 计数(gc[0])) { 如果 (gc[0][i][4] == 1) { 如果 (gc[0][i][0] == GC_白) {
 // 白色=不可达, 释放
 定义 _释放字节 = gc[0][i][1]
 gc[3] = gc[3] - _释放字节
 如果 (内存profile_当前() != 空) { 内存度量_记录释放(内存profile_当前(), _释放字节) }
 gc[0][i][1] = 0
 gc[0][i][2] = []
 gc[0][i][4] = 0
 释放数 = 释放数 + 1
 } 否则 {
 // 存活: 增加代龄
 gc[0][i][3] = gc[0][i][3] + 1
 }
 }
 i = i + 1
 }
 gc[5] = gc[5] + 1
 gc[6] = gc[6] + 释放数
 // 动态调整阈值
 如果 (gc[3] * 2 > gc[4]) { gc[4] = gc[3] * 2 }
 返回 释放数
}

// 完整GC周期
函数 GC_收集(gc) {
 如果 (内存profile_当前() != 空) { 内存度量_记录GC(内存profile_当前()) }
 GC_标记阶段(gc)
 返回 GC_清除阶段(gc)
}

// 查询函数
函数 GC_存活数(gc) { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(gc[0])) { 如果 (gc[0][i][4] == 1) { c = c + 1 }
 i = i + 1 }
 返回 c
}

函数 GC_总字节(gc) { 返回 gc[3] }
函数 GC_阈值(gc) { 返回 gc[4] }
函数 GC_次数(gc) { 返回 gc[5] }
函数 GC_总释放(gc) { 返回 gc[6] }

函数 GC_对象代龄(gc, id) {
    如果 (id >= 0 且 id < 计数(gc[0]) 且 gc[0][id][4] == 1) { 返回 gc[0][id][3]
}
 返回 -1
}

函数 GC_需要收集(gc) { 返回 gc[3] >= gc[4] }

// 弱引用: 不阻止对象被回收
// 弱引用表: [[源id, 目标id], ...]
// GC后清除指向已释放对象的弱引用

函数 GC_添加弱引用(_gc, 弱表, 源, 目标) {
 追加(弱表, [源, 目标])
}

函数 GC_清理弱引用(gc, 弱表) { 定义 可变 新表 = []
 定义 可变 清除数 = 0
 定义 可变 i = 0
 当 (i < 计数(弱表)) { 定义 目标 = 弱表[i][1]
 如果 (目标 >= 0 且 目标 < 计数(gc[0]) 且 gc[0][目标][4] == 1) {
 追加(新表, 弱表[i])
 } 否则 {
 清除数 = 清除数 + 1
 }
 i = i + 1
 }
 // 替换弱表内容: 先复制存活条目，再截断多余尾部
 定义 可变 j = 0
 当 (j < 计数(新表)) { 弱表[j] = 新表[j]
 j = j + 1
 }
 // 截断: Nova无原生truncate，用哨兵值标记尾部失效条目
 当 (j < 计数(弱表)) { 弱表[j] = [-1, -1]
 j = j + 1
 }
 返回 [计数(新表), 清除数]
}

// 终结器注册: 对象释放前回调标记
// 终结器表: [[对象id, 标记], ...]

函数 GC_注册终结器(终结表, 对象id) {
 追加(终结表, [对象id, 0])
}

函数 GC_执行终结(gc, 终结表) { 定义 可变 触发数 = 0
 定义 可变 i = 0
 当 (i < 计数(终结表)) { 定义 oid = 终结表[i][0]
 如果 (oid >= 0 且 oid < 计数(gc[0])) { 如果 (gc[0][oid][4] == 0 且 终结表[i][1] == 0) {
 终结表[i][1] = 1
 触发数 = 触发数 + 1
 }
 }
 i = i + 1
 }
 返回 触发数
}

// 分代收集: 年轻代优先
// 年轻代: 代龄 < 阈值 老年代: 代龄 >= 阈值
函数 GC_分代收集(gc, 代龄阈值) {
 // Phase 1: 只标记年轻代
 定义 可变 i = 0
 当 (i < 计数(gc[0])) { 如果 (gc[0][i][4] == 1 且 gc[0][i][3] < 代龄阈值) {
 gc[0][i][0] = GC_白
 }
 i = i + 1
 }
 // 根入灰色栈 (包括老年代根: 老年代根虽未被重置为白色，但其引用可能指向年轻代)
 gc[2] = []
 i = 0
 当 (i < 计数(gc[1])) { 定义 rid = gc[1][i]
 如果 (rid >= 0 且 rid < 计数(gc[0]) 且 gc[0][rid][4] == 1) {
 如果 (gc[0][rid][0] == GC_白) {
 gc[0][rid][0] = GC_灰
 追加(gc[2], rid)
 } 否则 如果 (gc[0][rid][3] >= 代龄阈值) {
 // 老年代根: 需扫描其引用以发现指向年轻代的跨代引用
 追加(gc[2], rid)
 }
 }
 i = i + 1
 }
 // BFS: 遍历灰色栈 + 老年代根的跨代引用
 定义 可变 头 = 0
 当 (头 < 计数(gc[2])) { 定义 当前id = gc[2][头]
 头 = 头 + 1
 定义 引用列表 = gc[0][当前id][2]
 定义 可变 j = 0
 当 (j < 计数(引用列表)) { 定义 ref = 引用列表[j]
 如果 (ref >= 0 且 ref < 计数(gc[0]) 且 gc[0][ref][4] == 1 且 gc[0][ref][0] == GC_白 且 gc[0][ref][3] < 代龄阈值) {
 gc[0][ref][0] = GC_灰
 追加(gc[2], ref)
 }
 j = j + 1
 }
 如果 (gc[0][当前id][0] == GC_灰) { gc[0][当前id][0] = GC_黑 }
 }
 // 清除年轻代白色
 定义 可变 释放数 = 0
 i = 0
 当 (i < 计数(gc[0])) { 如果 (gc[0][i][4] == 1 且 gc[0][i][3] < 代龄阈值 且 gc[0][i][0] == GC_白) {
 gc[3] = gc[3] - gc[0][i][1]
 gc[0][i][1] = 0
 gc[0][i][2] = []
 gc[0][i][4] = 0
 释放数 = 释放数 + 1
 } 否则 如果 (gc[0][i][4] == 1) {
 gc[0][i][3] = gc[0][i][3] + 1
 }
 i = i + 1
 }
 gc[5] = gc[5] + 1
 gc[6] = gc[6] + 释放数
 返回 释放数
}

// 统计: 各代对象数

// 5.5: 无GC裸机运行时模式
// 裸机profile下禁用GC，使用静态bump分配器
// 所有分配操作变为线性递增，不回收
定义 可变 _GC_裸机模式 = 假
定义 可变 _GC_bump_当前 = 0
定义 可变 _GC_bump_上限 = 0
定义 可变 _GC_bump_分配数 = 0

函数 GC_设置裸机模式(启用, 堆上限) {
    _GC_裸机模式 = 启用
    _GC_bump_当前 = 0
    _GC_bump_上限 = 堆上限
    _GC_bump_分配数 = 0
}

函数 GC_是裸机模式() { 返回 _GC_裸机模式 }

函数 GC_裸机分配(大小) {
    // 8字节对齐 (与所有其它分配器一致, 避免ARM/RISC-V对齐异常)
    定义 可变 对齐大小 = (大小 + 7) & (0 - 8)
    如果 (对齐大小 < 8) { 对齐大小 = 8 }
    如果 (_GC_bump_当前 + 对齐大小 > _GC_bump_上限) {
        返回 0 - 1
    }
    定义 地址 = _GC_bump_当前
    _GC_bump_当前 = _GC_bump_当前 + 对齐大小
    _GC_bump_分配数 = _GC_bump_分配数 + 1
    返回 地址
}

函数 GC_裸机_已用() { 返回 _GC_bump_当前 }
函数 GC_裸机_剩余() { 返回 _GC_bump_上限 - _GC_bump_当前 }
函数 GC_裸机_分配数() { 返回 _GC_bump_分配数 }

// 裸机模式下的统一分配入口
函数 GC_统一分配(gc, 大小) {
    如果 (_GC_裸机模式) {
        返回 GC_裸机分配(大小)
    }
    返回 GC_分配(gc, 大小)
}

// 裸机模式下收集为空操作
函数 GC_统一收集(gc) {
    如果 (_GC_裸机模式) { 返回 0 }
    返回 GC_收集(gc)
}

// 裸机模式统计报告
函数 GC_裸机报告() {
    定义 可变 r = 字典()
    字典设(r, "裸机模式", 转字符串(_GC_裸机模式))
    字典设(r, "bump已用", 转字符串(_GC_bump_当前))
    字典设(r, "bump上限", 转字符串(_GC_bump_上限))
    字典设(r, "bump分配数", 转字符串(_GC_bump_分配数))
    返回 r
}

// M9: 三类内存Profile合同

// Profile枚举
定义 内存profile_no_gc_kernel = 1
定义 内存profile_bounded_ai = 2
定义 内存profile_developer_host = 3

定义 可变 _当前内存profile = 内存profile_developer_host

函数 内存profile_设置(p) { _当前内存profile = p }
函数 内存profile_获取() { 返回 _当前内存profile }

函数 内存profile名(p) {
    如果 (p == 内存profile_no_gc_kernel) { 返回 "no_gc_kernel" }
    如果 (p == 内存profile_bounded_ai) { 返回 "bounded_ai_runtime" }
    如果 (p == 内存profile_developer_host) { 返回 "developer_host" }
    返回 "unknown"
}

// Profile合同: 各profile允许的分配路径
函数 内存profile_允许GC() {
    返回 _当前内存profile != 内存profile_no_gc_kernel
}

函数 内存profile_允许全堆扩张() {
    返回 _当前内存profile == 内存profile_developer_host
}

函数 内存profile_允许诊断缓冲() {
    返回 _当前内存profile == 内存profile_developer_host
}

// 内存预算合同
定义 可变 _内存预算_最大堆 = 0
定义 可变 _内存预算_最大常驻 = 0
定义 可变 _内存预算_启动 = 0
定义 可变 _内存预算_每帧 = 0
定义 可变 _内存预算_显存 = 0

函数 内存预算_设置(最大堆, 最大常驻, 启动, 每帧, 显存) {
    _内存预算_最大堆 = 最大堆
    _内存预算_最大常驻 = 最大常驻
    _内存预算_启动 = 启动
    _内存预算_每帧 = 每帧
    _内存预算_显存 = 显存
}

// 内存基准测量
定义 可变 _内存基准_冷启动 = 0
定义 可变 _内存基准_峰值RSS = 0
定义 可变 _内存基准_稳态RSS = 0
定义 可变 _内存基准_临时分配 = 0
定义 可变 _内存基准_碎片率 = 0

函数 内存基准_记录冷启动(值) { _内存基准_冷启动 = 值 }
函数 内存基准_记录峰值(值) { _内存基准_峰值RSS = 值 }
函数 内存基准_记录稳态(值) { _内存基准_稳态RSS = 值 }
函数 内存基准_记录临时分配(值) { _内存基准_临时分配 = 值 }
函数 内存基准_记录碎片率(值) { _内存基准_碎片率 = 值 }

// 真实自动测量: 从内存统计数组采集基准值
// 内存统计 = [分配次数, 释放次数, 总分配, 峰值, 当前]
函数 内存基准_自动采集() {
    _内存基准_峰值RSS = 内存统计[3]
    _内存基准_稳态RSS = 内存统计[4]
    _内存基准_临时分配 = 内存统计[2]
    // 碎片率: (峰值-当前)/峰值 * 100
    如果 (内存统计[3] > 0) {
        _内存基准_碎片率 = ((内存统计[3] - 内存统计[4]) * 100) / 内存统计[3]
    }
}

// 冷启动测量: 记录当前内存使用作为冷启动基线
函数 内存基准_标记冷启动() {
    _内存基准_冷启动 = 内存统计[4]
}

// 内存Profile报告
函数 内存profile_报告() {
    定义 可变 r = 字典()
    字典设(r, "profile", 内存profile名(_当前内存profile))
    字典设(r, "允许GC", 转字符串(内存profile_允许GC()))
    字典设(r, "允许全堆扩张", 转字符串(内存profile_允许全堆扩张()))
    字典设(r, "预算_最大堆", 转字符串(_内存预算_最大堆))
    字典设(r, "预算_最大常驻", 转字符串(_内存预算_最大常驻))
    字典设(r, "预算_启动", 转字符串(_内存预算_启动))
    字典设(r, "预算_每帧", 转字符串(_内存预算_每帧))
    字典设(r, "预算_显存", 转字符串(_内存预算_显存))
    字典设(r, "基准_冷启动", 转字符串(_内存基准_冷启动))
    字典设(r, "基准_峰值RSS", 转字符串(_内存基准_峰值RSS))
    字典设(r, "基准_稳态RSS", 转字符串(_内存基准_稳态RSS))
    字典设(r, "基准_临时分配", 转字符串(_内存基准_临时分配))
    字典设(r, "基准_碎片率", 转字符串(_内存基准_碎片率))
    返回 r
}

函数 内存profile_打印报告() {
    定义 r = 内存profile_报告()
    打印文本(字符串拼接("[MEM-PROFILE] ", 字符串拼接(字典取(r, "profile"), 字符串拼接(" GC=", 字符串拼接(字典取(r, "允许GC"), 字符串拼接(" 峰值=", 字符串拼接(字典取(r, "基准_峰值RSS"), 字符串拼接(" 稳态=", 字典取(r, "基准_稳态RSS")))))))))
}

导入("../基础.nova")

定义 TCP_时间等 = 7
定义 TCP_关闭等 = 8
定义 TCP_最终确认 = 9

定义 可变 tcp_状态 = TCP_关闭
定义 可变 tcp_序号 = 0
定义 可变 tcp_确认号 = 0

函数 TCP_转换(事件) {
 // 事件: 1=主动打开, 2=被动打开, 3=SYN, 4=SYN+ACK, 5=ACK, 6=FIN, 7=关闭
 如果 (tcp_状态 == TCP_关闭 且 事件 == 1) { tcp_状态 = TCP_SYN已发
 返回 真 }
 如果 (tcp_状态 == TCP_关闭 且 事件 == 2) { tcp_状态 = TCP_监听
 返回 真 }
 如果 (tcp_状态 == TCP_监听 且 事件 == 3) { tcp_状态 = TCP_SYN已收
 返回 真 }
 如果 (tcp_状态 == TCP_SYN已发 且 事件 == 4) { tcp_状态 = TCP_已建立
 返回 真 }
 如果 (tcp_状态 == TCP_SYN已收 且 事件 == 5) { tcp_状态 = TCP_已建立
 返回 真 }
 如果 (tcp_状态 == TCP_已建立 且 事件 == 6) { tcp_状态 = TCP_关闭等
 返回 真 }
 如果 (tcp_状态 == TCP_已建立 且 事件 == 7) { tcp_状态 = TCP_FIN等1
 返回 真 }
 如果 (tcp_状态 == TCP_FIN等1 且 事件 == 5) { tcp_状态 = TCP_FIN等2
 返回 真 }
 如果 (tcp_状态 == TCP_关闭等 且 事件 == 5) { tcp_状态 = TCP_最终确认
 返回 真 }
 如果 (tcp_状态 == TCP_最终确认 且 事件 == 5) { tcp_状态 = TCP_关闭
 返回 真 }
 返回 假
}

函数 TCP_重置() { tcp_状态 = TCP_关闭
tcp_序号 = 0
tcp_确认号 = 0 }

// HTTP请求构建
函数 HTTP_构建请求(方法哈希, 路径哈希, 主机哈希) {
 // 回 [方法, 路径, 主机, 内容长度, 正文]
 返回 [方法哈希, 路径哈希, 主机哈希,]
}

函数 HTTP_设置正文(请求, 正文哈希, 长度) {
 请求[3] = 长度
 请求[4] = 正文哈希
 返回 请求
}

// HTTP响应解析
// 响应结构: [状态码, 内容长度, 正文哈希, 头数]
函数 HTTP_构建响应(状态码, 内容长度, 正文哈希) { 返回 [状态码, 内容长度, 正文哈希, 0]
}

函数 HTTP_是成功(响应) { 返回 响应[0] >= 200 且 响应[0] < 300 }
函数 HTTP_是重定向(响应) { 返回 响应[0] >= 300 且 响应[0] < 400 }
函数 HTTP_是客户端错误(响应) { 返回 响应[0] >= 400 且 响应[0] < 500 }
函数 HTTP_是服务端错误(响应) { 返回 响应[0] >= 500 }

// WebSocket帧
// 帧结构: [opcode, 掩码标记, 负载长度, 负载数据]
定义 WS_文本 = 1
定义 WS_二进制 = 2
定义 WS_关闭 = 8
定义 WS_心跳请求 = 9
定义 WS_心跳响应 = 10

函数 WS_构建帧(opcode, 数据, 长度) { 返回 [opcode, 0, 长度, 数据]
}

函数 WS_是控制帧(帧) { 返回 帧[0] >= 8 }
函数 WS_负载长度(帧) { 返回 帧[2] }

// 校验和

函数 协议_写16(包, 偏移, 值) { 如果 (偏移 >= 0 且 偏移 + 1 < 计数(包)) {
 包[偏移] = (值 >> 8) & 0xFF
 包[偏移 + 1] = 值 & 0xFF
 }
}

函数 协议_校验和16(数据) { 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < 计数(数据)) { 定义 可变 高 = 数据[i]
 定义 可变 低 = 0
 如果 (i + 1 < 计数(数据)) { 低 = 数据[i + 1] }
 总和 = 总和 + ((高 << 8) | 低)
 当 (总和 > 0xFFFF) {
 总和 = (总和 & 0xFFFF) + (总和 >> 16)
 }
 i = i + 2
 }
 当 (总和 > 0xFFFF) {
 总和 = (总和 & 0xFFFF) + (总和 >> 16)
 }
 返回 (~总和) & 0xFFFF
}

函数 协议_刷新校验和(包, 偏移) {
 协议_写16(包,  偏移, 0)
 定义 校验 = 协议_校验和16(包)
 协议_写16(包, 偏移, 校验)
 返回 校验
}

函数 协议_校验有效(包) { 返回 协议_校验和16(包) == 0
}

// 端口管理
定义 可变 端口_分配表 = []
定义 可变 端口_服务 = []

函数 端口_分配(端口, 服务哈希) {
 追加(端口_分配表, 端口)
 追加(端口_服务, 服务哈希)
}

函数 端口_查找(端口) { 定义 可变 i = 0
 当 (i < 计数(端口_分配表)) { 如果 (端口_分配表[i] == 端口) { 返回 端口_服务[i] }
 i = i + 1
 }
 返回 -1
}

函数 端口_可用(端口) { 定义 可变 i = 0
 当 (i < 计数(端口_分配表)) { 如果 (端口_分配表[i] == 端口) { 返回 假 }
 i = i + 1
 }
 返回 真
}

// 端口释放
函数 端口_释放(端口) { 定义 可变 新端口 = []
 定义 可变 新服务 = []
 定义 可变 i = 0
 当 (i < 计数(端口_分配表)) { 如果 (端口_分配表[i] != 端口) {
 追加(新端口, 端口_分配表[i])
 追加(新服务, 端口_服务[i])
 }
 i = i + 1
 }
 端口_分配表 = 新端口
 端口_服务 = 新服务
}

// 已分配端口数
函数 端口_已分配数() { 返回 计数(端口_分配表) }

// 数据重组
函数 数据_重组(片列表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(片列表)) { 定义 可变 j = 0
 当 (j < 计数(片列表[i])) {
 追加(结果, 片列表[i][j])
 j = j + 1
 }
 i = i + 1
 }
 返回 结果
}

// TCP协议

定义 TCP_结束 = 0x01
定义 TCP_同步 = 0x02
定义 TCP_重置 = 0x04
定义 TCP_推送 = 0x08
定义 TCP_确认 = 0x10
定义 TCP_紧急 = 0x20

函数 TCP_创建连接() { 返回 [0, 0, 0, 0, []]
 // [源端口, 目标端口, 序列号, 确认号, 状态, 窗口大小, 发送缓冲]
}

函数 TCP_设置端口(连接, 源, 目标) {
 连接[0] = 源
 连接[1] = 目标
}

函数 TCP_构建头(连接, 标志) { 定义 可变 头 = []
 追加(头, (连接[0] >> 8) & 0xFF)
 追加(头, 连接[0] & 0xFF)
 追加(头, (连接[1] >> 8) & 0xFF)
 追加(头, 连接[1] & 0xFF)
 // 序列号 (4字节)
 追加(头, (连接[2] >> 24) & 0xFF)
 追加(头, (连接[2] >> 16) & 0xFF)
 追加(头, (连接[2] >> 8) & 0xFF)
 追加(头, 连接[2] & 0xFF)
 // 确认号 (4字节)
 追加(头, (连接[3] >> 24) & 0xFF)
 追加(头, (连接[3] >> 16) & 0xFF)
 追加(头, (连接[3] >> 8) & 0xFF)
 追加(头, 连接[3] & 0xFF)
 // 数据偏移(5*4=20字节头) + 保留
 追加(头, 0x50)
 // 标志
 追加(头, 标志)
 // 窗口大小
 追加(头, (连接[5] >> 8) & 0xFF)
 追加(头, 连接[5] & 0xFF)
 // 校验和(占位, 0)
 追加(头, 0)
 追加(头, 0)
 // 紧急指针
 追加(头, 0)
 追加(头, 0)
 协议_刷新校验和(头, 16)
 返回 头
}

函数 TCP_三次握手_SYN(连接) {
 连接[2] = 1000
 连接[4] = 1 // SYN_SENT
 连接[5] = 65535
 返回 TCP_构建头(连接, TCP_同步)
}

函数 TCP_三次握手_SYNACK(连接, 对方序列) {
 连接[3] = 对方序列 + 1
 连接[2] = 2000
 连接[4] = 2 // SYN_RECEIVED
 返回 TCP_构建头(连接, TCP_同步 | TCP_确认)
}

函数 TCP_三次握手_ACK(连接, 对方序列) {
 连接[3] = 对方序列 + 1
 连接[4] = 3 // ESTABLISHED
 返回 TCP_构建头(连接, TCP_确认)
}

函数 TCP_发送数据(连接, 数据) { 定义 可变 包 = TCP_构建头(连接, TCP_推送 | TCP_确认)
 定义 可变 i = 0
 当 (i < 计数(数据)) { 追加(包, 数据[i]) i = i + 1 }
 协议_刷新校验和(包, 16)
 连接[2] = 连接[2] + 计数(数据)
 返回 包
}

函数 TCP_关闭连接(连接) {
 连接[4] = 4 // FIN_WAIT
 返回 TCP_构建头(连接, TCP_结束 | TCP_确认)
}

// UDP协议

函数 UDP_构建包(源端口, 目标端口, 数据) { 定义 可变 包 = []
 定义 长度 = 8 + 计数(数据)
 追加(包, (源端口 >> 8) & 0xFF)
 追加(包, 源端口 & 0xFF)
 追加(包, (目标端口 >> 8) & 0xFF)
 追加(包, 目标端口 & 0xFF)
 追加(包, (长度 >> 8) & 0xFF)
 追加(包, 长度 & 0xFF)
 追加(包, 0)
 追加(包, 0)
 定义 可变 i = 0
 当 (i < 计数(数据)) { 追加(包, 数据[i]) i = i + 1 }
 协议_刷新校验和(包, 6)
 返回 包
}

函数 TCP_校验包(包) { 返回 协议_校验有效(包) }
函数 UDP_校验包(包) { 返回 协议_校验有效(包) }

函数 UDP_解析包(包) {
    如果 (计数(包) < 8) { 返回 空
}
 定义 源端口 = (包[0] << 8) | 包[1]
 定义 目标端口 = (包[2] << 8) | 包[3]
 定义 长度 = (包[4] << 8) | 包[5]
 定义 可变 数据 = []
 定义 可变 i = 8
 当 (i < 计数(包)) { 追加(数据, 包[i]) i = i + 1 }
 返回 [源端口, 目标端口, 长度, 数据]
}

// ICMP协议

定义 ICMP_回显请求 = 8
定义 ICMP_回显应答 = 0

函数 ICMP_构建回显(类型, 标识, 序列, 数据) { 定义 可变 包 = []
 追加(包, 类型)
 追加(包, 0) // 代码
 追加(包, 0) // 校验和高
 追加(包, 0) // 校验和低
 追加(包, (标识 >> 8) & 0xFF)
 追加(包, 标识 & 0xFF)
 追加(包, (序列 >> 8) & 0xFF)
 追加(包, 序列 & 0xFF)
 定义 可变 i = 0
 当 (i < 计数(数据)) { 追加(包, 数据[i]) i = i + 1 }
 // 计算校验和
 定义 校验 = 协议_校验和(包)
 包[2] = (校验 >> 8) & 0xFF
 包[3] = 校验 & 0xFF
 返回 包
}

// 校验和计算

函数 协议_校验和(数据) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 计数(数据) - 1) {
 和 = 和 + (数据[i] << 8) + 数据[i+1]
 i = i + 2
 }
 如果 (计数(数据) % 2 != 0) { 和 = 和 + (数据[计数(数据)-1] << 8) }
 当 (和 > 0xFFFF) { 和 = (和 & 0xFFFF) + (和 >> 16) }
 返回 和 ^ 0xFFFF
}

// ARP协议

函数 ARP_构建请求(发送方IP, 目标IP, 发送方MAC) { 定义 可变 包 = []
 // 硬件类型: 以太网
 追加(包, 0) 追加(包, 1)
 // 协议类型: IPv4
 追加(包, 8) 追加(包, 0)
 // 硬件地址长度, 协议地址长度
 追加(包, 6) 追加(包, 4)
 // 操作码: 请求
 追加(包, 0) 追加(包, 1)
 // 发送方MAC
 定义 可变 i = 0
 当 (i < 6) { 追加(包, 发送方MAC[i]) i = i + 1 }
 // 发送方IP
 i = 0
 当 (i < 4) { 追加(包, 发送方IP[i]) i = i + 1 }
 // 目标MAC (全零)
 i = 0
 当 (i < 6) { 追加(包, 0) i = i + 1 }
 // 目标IP
 i = 0
 当 (i < 4) { 追加(包, 目标IP[i]) i = i + 1 }
 返回 包
}

// IP分片重组

定义 可变 _分片缓存 = []

函数 IP_缓存分片(标识, 偏移, 数据, 更多) {
 追加(_分片缓存, [标识, 偏移, 数据, 更多])
}

函数 IP_重组(标识) { 定义 可变 片段 = []
 定义 可变 i = 0
 当 (i < 计数(_分片缓存)) { 如果 (_分片缓存[i][0] == 标识) { 追加(片段, _分片缓存[i]) }
 i = i + 1
 }
 // 按偏移排序(简单冒泡)
 定义 可变 n = 计数(片段)
 i = 0
 当 (i < n - 1) { 定义 可变 j = 0
 当 (j < n - i - 1) { 如果 (片段[j][1] > 片段[j+1][1]) { 定义 临 = 片段[j]
 片段[j] = 片段[j+1]
 片段[j+1] = 临
 }
 j = j + 1
 }
 i = i + 1
 }
 // 合并
 定义 可变 结果 = []
 i = 0
 当 (i < n) { 定义 可变 k = 0
 当 (k < 计数(片段[i][2])) { 追加(结果, 片段[i][2][k]) k = k + 1 }
 i = i + 1
 }
 返回 结果
}

定义 可变 _协议_发送包数 = 0
定义 可变 _协议_接收包数 = 0
定义 可变 _协议_错误包数 = 0
定义 可变 _协议_TCP连接数 = 0

函数 协议_记录发送() { _协议_发送包数 = _协议_发送包数 + 1 }
函数 协议_记录接收() { _协议_接收包数 = _协议_接收包数 + 1 }
函数 协议_记录错误() { _协议_错误包数 = _协议_错误包数 + 1 }
函数 协议_记录TCP() { _协议_TCP连接数 = _协议_TCP连接数 + 1 }

函数 协议_重置() { _协议_发送包数 = 0 _协议_接收包数 = 0
 _协议_错误包数 = 0 _协议_TCP连接数 = 0
 _分片缓存 = []
}

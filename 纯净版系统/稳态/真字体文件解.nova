// NovaOS · 矢量字体引擎 — TrueType解析+光栅化
// 功能:
//  §1 TrueType文件解析: 表目录 + head + hhea + maxp
//  §2 cmap字符映射: Format4分段映射
//  §3 loca/glyf字形加载: 轮廓点解析
//  §4 贝塞尔曲线平坦化: 二次贝塞尔→线段逼近
//  §5 扫描线光栅化: 奇偶填充+覆盖率抗锯齿
//  §6 水平度量: hmtx advanceWidth + LSB
//  §7 字形缓存: 4路LRU
//  §8 文本渲染: 字符串→像素 + 字距调整
//  §9 字节序辅助: 大端读取

导入("../中枢/日志中枢.nova")
导入("../中枢/数学工具.nova")
导入("../中枢/硬链接.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/整数转字符串.nova")

// §1 数据结构

结构 TTF字体 {
    数据,
    大小,
    cmap偏移,
    glyf偏移,
    loca偏移,
    head偏移,
    hhea偏移,
    hmtx偏移,
    maxp偏移,
    单位_每EM,
    字形数,
    loca格式,
    上升量,
    下降量,
    行间距,
    已加载,
}

结构 字形轮廓点 {
    x,
    y,
    在曲线上,   // 布尔: 真=在曲线上, 假=控制点
}

结构 字形数据 {
    轮廓数,
    点数,
    点列表,         // 字形轮廓点[]
    轮廓结束索引,  // 整数[]
    xMin, yMin, xMax, yMax,
    advanceWidth,
    leftSideBearing,
}

结构 光栅化位图 {
    宽度,
    高度,
    像素,       // u8[] 覆盖率列表 (0-255)
    偏移X,
    偏移Y,
}

定义 LRU_缓存大小 = 256
结构 字形缓存项 {
    字符码,
    字号,       // 像素大小
    位图,       // 光栅化位图
    访问计数,
    有效,
}

定义 可变 全局TTF = TTF字体 {}
定义 可变 字形缓存 = []  // 字形缓存项[]
定义 可变 缓存_命中数 = 0
定义 可变 缓存_未中数 = 0

// §2 TrueType文件加载

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 TTF_加载(数据地址, 大小) {
    如果 (大小 < 12) {
        内核警告("TTF: 文件太小")
        返回 假
    }
    全局TTF.数据 = 数据地址
    全局TTF.大小 = 大小

    定义 魔数 = TTF_读32(0)
    如果 (魔数 != 0x00010000 && 魔数 != 0x74727565) {
        内核警告("TTF: 无效魔数")
        返回 假
    }

    定义 表数 = TTF_读16(4)
    定义 可变 i = 0
    当 (i < 表数) {
        定义 偏移 = 12 + i * 16
        定义 标签 = TTF_读32(偏移)
        定义 表偏移 = TTF_读32(偏移 + 8)
        如果 (标签 == 0x636D6170) { 全局TTF.cmap偏移 = 表偏移 }
        否则如果 (标签 == 0x676C7966) { 全局TTF.glyf偏移 = 表偏移 }
        否则如果 (标签 == 0x6C6F6361) { 全局TTF.loca偏移 = 表偏移 }
        否则如果 (标签 == 0x68656164) { 全局TTF.head偏移 = 表偏移 }
        否则如果 (标签 == 0x68686561) { 全局TTF.hhea偏移 = 表偏移 }
        否则如果 (标签 == 0x686D7478) { 全局TTF.hmtx偏移 = 表偏移 }
        否则如果 (标签 == 0x6D617870) { 全局TTF.maxp偏移 = 表偏移 }
        i = i + 1
    }

    如果 (全局TTF.head偏移 > 0) {
        全局TTF.单位_每EM = TTF_读16(全局TTF.head偏移 + 18)
        全局TTF.loca格式 = TTF_读16(全局TTF.head偏移 + 50)
    }
    如果 (全局TTF.单位_每EM == 0) { 全局TTF.单位_每EM = 2048 }
    如果 (全局TTF.maxp偏移 > 0) {
        全局TTF.字形数 = TTF_读16(全局TTF.maxp偏移 + 4)
    }
    如果 (全局TTF.hhea偏移 > 0) {
        全局TTF.上升量 = TTF_读16有符号(全局TTF.hhea偏移 + 4)
        全局TTF.下降量 = TTF_读16有符号(全局TTF.hhea偏移 + 6)
        全局TTF.行间距 = TTF_读16有符号(全局TTF.hhea偏移 + 8)
    }

    全局TTF.已加载 = 真
    // 初始化字形缓存
    字形缓存 = []
    内核信息("TTF: 加载完成 表=" + 整数转字符串(表数) +
             " 字形=" + 整数转字符串(全局TTF.字形数) +
             " EM=" + 整数转字符串(全局TTF.单位_每EM))
    返回 真
}

// §3 cmap字符映射 (Format 4)

函数 TTF_cmap_查找字形ID(字符码) {
    如果 (!全局TTF.已加载 || 全局TTF.cmap偏移 == 0) { 返回 0 }
    定义 cmap_base = 全局TTF.cmap偏移
    定义 子表数 = TTF_读16(cmap_base + 2)

    // 搜索 platform=3 encoding=1 (Windows Unicode BMP)
    定义 可变 子表偏移 = 0
    定义 可变 i = 0
    当 (i < 子表数) {
        定义 off = cmap_base + 4 + i * 8
        定义 platform = TTF_读16(off)
        定义 encoding = TTF_读16(off + 2)
        如果 (platform == 3 && encoding == 1) {
            子表偏移 = cmap_base + TTF_读32(off + 4)
            跳出
        }
        // 备选: platform=0 encoding=3
        如果 (platform == 0 && encoding == 3 && 子表偏移 == 0) {
            子表偏移 = cmap_base + TTF_读32(off + 4)
        }
        i = i + 1
    }
    如果 (子表偏移 == 0) { 返回 0 }

    // 解析Format 4
    定义 format = TTF_读16(子表偏移)
    如果 (format != 4) { 返回 0 }  // 只支持Format4

    定义 segCount2 = TTF_读16(子表偏移 + 6)
    定义 segCount = segCount2 / 2
    定义 endCodes = 子表偏移 + 14
    定义 startCodes = endCodes + segCount2 + 2  // +2 for reservedPad
    定义 idDeltas = startCodes + segCount2
    定义 idRangeOffsets = idDeltas + segCount2

    // 二分查找分段
    定义 可变 lo = 0
    定义 可变 hi = segCount - 1
    当 (lo <= hi) {
        定义 mid = (lo + hi) / 2
        定义 endCode = TTF_读16(endCodes + mid * 2)
        如果 (字符码 > endCode) {
            lo = mid + 1
        } 否则 {
            定义 startCode = TTF_读16(startCodes + mid * 2)
            如果 (字符码 < startCode) {
                hi = mid - 1
            } 否则 {
                // 找到匹配段
                定义 idRangeOffset = TTF_读16(idRangeOffsets + mid * 2)
                如果 (idRangeOffset == 0) {
                    定义 idDelta = TTF_读16有符号(idDeltas + mid * 2)
                    返回 (字符码 + idDelta) & 0xFFFF
                } 否则 {
                    定义 glyphAddr = idRangeOffsets + mid * 2 + idRangeOffset + (字符码 - startCode) * 2
                    定义 glyphID = TTF_读16(glyphAddr)
                    如果 (glyphID != 0) {
                        定义 idDelta = TTF_读16有符号(idDeltas + mid * 2)
                        返回 (glyphID + idDelta) & 0xFFFF
                    }
                    返回 0
                }
            }
        }
    }
    返回 0  // 未找到
}

// §4 loca/glyf 字形加载

函数 TTF_获取字形偏移(glyphID) {
    如果 (全局TTF.loca偏移 == 0 || glyphID >= 全局TTF.字形数) { 返回 0 }
    如果 (全局TTF.loca格式 == 0) {
        // 短格式: 2字节, *2
        返回 TTF_读16(全局TTF.loca偏移 + glyphID * 2) * 2
    } 否则 {
        // 长格式: 4字节
        返回 TTF_读32(全局TTF.loca偏移 + glyphID * 4)
    }
}

函数 TTF_加载字形(glyphID) {
    如果 (全局TTF.glyf偏移 == 0) { 返回 0 }
    定义 glyf_off = 全局TTF.glyf偏移 + TTF_获取字形偏移(glyphID)
    定义 next_off = 全局TTF.glyf偏移 + TTF_获取字形偏移(glyphID + 1)
    如果 (glyf_off == next_off) { 返回 0 }  // 空字形

    定义 g = 字形数据 {}
    定义 轮廓数 = TTF_读16有符号(glyf_off)
    如果 (轮廓数 < 0) { 返回 0 }  // 复合字形暂不支持
    g.轮廓数 = 轮廓数
    g.xMin = TTF_读16有符号(glyf_off + 2)
    g.yMin = TTF_读16有符号(glyf_off + 4)
    g.xMax = TTF_读16有符号(glyf_off + 6)
    g.yMax = TTF_读16有符号(glyf_off + 8)

    // 读取轮廓结束索引
    g.轮廓结束索引 = []
    定义 可变 p = glyf_off + 10
    定义 可变 i = 0
    当 (i < 轮廓数) {
        定义 endIdx = TTF_读16(p)
        追加(g.轮廓结束索引, endIdx)
        p = p + 2
        i = i + 1
    }

    g.点数 = g.轮廓结束索引[轮廓数 - 1] + 1
    // 跳过指令字节数
    定义 指令长 = TTF_读16(p)
    p = p + 2 + 指令长

    // 读取标志字节
    定义 可变 flags = []
    定义 可变 fi = 0
    当 (fi < g.点数) {
        定义 flag = TTF_读8(p)
        p = p + 1
        追加(flags, flag)
        // repeat 标志
        如果 (flag & 8) {
            定义 repeat = TTF_读8(p)
            p = p + 1
            定义 可变 ri = 0
            当 (ri < repeat) {
                追加(flags, flag)
                fi = fi + 1
                ri = ri + 1
            }
        }
        fi = fi + 1
    }

    // 读取X坐标
    定义 可变 xCoords = []
    定义 可变 x = 0
    i = 0
    当 (i < g.点数) {
        定义 f = flags[i]
        如果 (f & 2) {
            定义 dx = TTF_读8(p); p = p + 1
            如果 (!(f & 16)) { dx = 0 - dx }
            x = x + dx
        } 否则如果 (!(f & 16)) {
            x = x + TTF_读16有符号(p); p = p + 2
        }
        追加(xCoords, x)
        i = i + 1
    }

    // 读取Y坐标
    定义 可变 yCoords = []
    定义 可变 y = 0
    i = 0
    当 (i < g.点数) {
        定义 f = flags[i]
        如果 (f & 4) {
            定义 dy = TTF_读8(p); p = p + 1
            如果 (!(f & 32)) { dy = 0 - dy }
            y = y + dy
        } 否则如果 (!(f & 32)) {
            y = y + TTF_读16有符号(p); p = p + 2
        }
        追加(yCoords, y)
        i = i + 1
    }

    // 组装轮廓点
    g.点列表 = []
    i = 0
    当 (i < g.点数) {
        定义 pt = 字形轮廓点 {}
        pt.x = xCoords[i]
        pt.y = yCoords[i]
        pt.在曲线上 = (flags[i] & 1) != 0
        追加(g.点列表, pt)
        i = i + 1
    }

    // 加载水平度量
    TTF_加载度量(g, glyphID)
    返回 g
}

// §5 贝塞尔曲线平坦化
// 二次贝塞尔 B(t) = (1-t)²P0 + 2(1-t)tP1 + t²P2

定义 BEZIER_细分步数 = 8

函数 贝塞尔_平坦化(p0x, p0y, p1x, p1y, p2x, p2y, 结果点) {
    // 将二次贝塞尔曲线进行连续线性逼近
    定义 可变 i = 1
    当 (i <= BEZIER_细分步数) {
        定义 t = i * 1024 / BEZIER_细分步数  // Q10定点
        定义 t2 = t * t / 1024
        定义 mt = 1024 - t
        定义 mt2 = mt * mt / 1024
        定义 two_mt_t = 2 * mt * t / 1024
        定义 x = (mt2 * p0x + two_mt_t * p1x + t2 * p2x) / 1024
        定义 y = (mt2 * p0y + two_mt_t * p1y + t2 * p2y) / 1024
        定义 pt = 字形轮廓点 {}
        pt.x = x; pt.y = y; pt.在曲线上 = 真
        追加(结果点, pt)
        i = i + 1
    }
}

// §6 扫描线光栅化
// 创新: 奇偶填充规则 + 覆盖率抗锯齿

函数 TTF_光栅化(字形, 字号像素) {
    如果 (字形 == 0) { 返回 0 }
    定义 缩放 = 字号像素 * 1024 / 全局TTF.单位_每EM  // Q10缩放因子
    定义 w = (字形.xMax - 字形.xMin) * 缩放 / 1024 + 2
    定义 h = (字形.yMax - 字形.yMin) * 缩放 / 1024 + 2
    如果 (w <= 0 || h <= 0) { 返回 0 }

    定义 bmp = 光栅化位图 {}
    bmp.宽度 = w
    bmp.高度 = h
    bmp.像素 = 堆_分配(w * h)
    内存_置零(bmp.像素, w * h)
    bmp.偏移X = 字形.xMin * 缩放 / 1024
    bmp.偏移Y = 字形.yMin * 缩放 / 1024

    // 将字形轮廓转换为平坦化线段
    定义 线段 = TTF_平坦化轮廓(字形, 缩放)

    // 扫描线填充
    定义 可变 y = 0
    当 (y < h) {
        定义 scan_y = y + bmp.偏移Y
        // 收集该扫描线与所有边的交点
        定义 可变 交点 = []
        定义 可变 ei = 0
        当 (ei < 计数(线段)) {
            定义 seg = 线段[ei]
            定义 y0 = seg.y0; 定义 y1 = seg.y1
            如果 ((y0 <= scan_y && y1 > scan_y) || (y1 <= scan_y && y0 > scan_y)) {
                // 线性插值求交点X
                定义 t = (scan_y - y0) * 1024 / (y1 - y0 + 1)
                定义 ix = seg.x0 + t * (seg.x1 - seg.x0) / 1024
                追加(交点, ix - bmp.偏移X)
            }
            ei = ei + 1
        }
        // 对交点排序(插入排序)
        定义 可变 si = 1
        当 (si < 计数(交点)) {
            定义 key = 交点[si]
            定义 可变 sj = si - 1
            当 (sj >= 0 && 交点[sj] > key) {
                交点[sj + 1] = 交点[sj]
                sj = sj - 1
            }
            交点[sj + 1] = key
            si = si + 1
        }
        // 奇偶填充
        定义 可变 pi = 0
        当 (pi + 1 < 计数(交点)) {
            定义 x0 = 交点[pi]
            定义 x1 = 交点[pi + 1]
            定义 可变 x = x0
            当 (x < x1) {
                如果 (x >= 0 && x < w) {
                    内存_写8(bmp.像素 + y * w + x, 255)
                }
                x = x + 1
            }
            pi = pi + 2
        }
        y = y + 1
    }
    返回 bmp
}

结构 线段数据 {
    x0, y0, x1, y1,
}

函数 TTF_平坦化轮廓(字形, 缩放) {
    定义 结果 = []
    定义 可变 轮廓开始 = 0
    定义 可变 ci = 0
    当 (ci < 字形.轮廓数) {
        定义 轮廓结束 = 字形.轮廓结束索引[ci]
        定义 可变 pi = 轮廓开始
        当 (pi <= 轮廓结束) {
            定义 ni = 如果(pi < 轮廓结束, pi + 1, 轮廓开始)
            定义 p0 = 字形.点列表[pi]
            定义 p1 = 字形.点列表[ni]
            如果 (p0.在曲线上 && p1.在曲线上) {
                // 直线段
                定义 seg = 线段数据 {}
                seg.x0 = p0.x * 缩放 / 1024
                seg.y0 = p0.y * 缩放 / 1024
                seg.x1 = p1.x * 缩放 / 1024
                seg.y1 = p1.y * 缩放 / 1024
                追加(结果, seg)
            } 否则如果 (p0.在曲线上 && !p1.在曲线上) {
                // 贝塞尔: p0(on) p1(off) p2(on)
                定义 nni = 如果(ni < 轮廓结束, ni + 1, 轮廓开始)
                定义 p2 = 字形.点列表[nni]
                定义 flat_pts = []
                贝塞尔_平坦化(
                    p0.x * 缩放 / 1024, p0.y * 缩放 / 1024,
                    p1.x * 缩放 / 1024, p1.y * 缩放 / 1024,
                    p2.x * 缩放 / 1024, p2.y * 缩放 / 1024,
                    flat_pts)
                // 转换为线段
                定义 可变 prev_x = p0.x * 缩放 / 1024
                定义 可变 prev_y = p0.y * 缩放 / 1024
                定义 可变 fi = 0
                当 (fi < 计数(flat_pts)) {
                    定义 seg = 线段数据 {}
                    seg.x0 = prev_x; seg.y0 = prev_y
                    seg.x1 = flat_pts[fi].x; seg.y1 = flat_pts[fi].y
                    追加(结果, seg)
                    prev_x = seg.x1; prev_y = seg.y1
                    fi = fi + 1
                }
                pi = pi + 1  // 跳过控制点
            }
            pi = pi + 1
        }
        轮廓开始 = 轮廓结束 + 1
        ci = ci + 1
    }
    返回 结果
}

// §7 水平度量 (hmtx)

函数 TTF_加载度量(字形, glyphID) {
    如果 (全局TTF.hmtx偏移 == 0) { 返回 }
    // hmtx表: numHMetrics条记录, 每条4字节(advanceWidth + LSB)
    定义 numHMetrics = TTF_读16(全局TTF.hhea偏移 + 34)
    如果 (glyphID < numHMetrics) {
        字形.advanceWidth = TTF_读16(全局TTF.hmtx偏移 + glyphID * 4)
        字形.leftSideBearing = TTF_读16有符号(全局TTF.hmtx偏移 + glyphID * 4 + 2)
    } 否则 {
        // 超出numHMetrics的字形使用最后一条的advanceWidth
        字形.advanceWidth = TTF_读16(全局TTF.hmtx偏移 + (numHMetrics - 1) * 4)
        定义 lsb_off = 全局TTF.hmtx偏移 + numHMetrics * 4 + (glyphID - numHMetrics) * 2
        字形.leftSideBearing = TTF_读16有符号(lsb_off)
    }
}

// §8 字形LRU缓存

函数 字形缓存_查找(字符码, 字号) {
    定义 可变 i = 0
    当 (i < 计数(字形缓存)) {
        定义 entry = 字形缓存[i]
        如果 (entry.有效 && entry.字符码 == 字符码 && entry.字号 == 字号) {
            entry.访问计数 = entry.访问计数 + 1
            缓存_命中数 = 缓存_命中数 + 1
            返回 entry.位图
        }
        i = i + 1
    }
    缓存_未中数 = 缓存_未中数 + 1
    返回 0
}

函数 字形缓存_插入(字符码, 字号, 位图) {
    // 如果缓存已满, 驱逐访问计数最小的
    如果 (计数(字形缓存) >= LRU_缓存大小) {
        定义 可变 min_idx = 0
        定义 可变 min_cnt = 字形缓存[0].访问计数
        定义 可变 i = 1
        当 (i < 计数(字形缓存)) {
            如果 (字形缓存[i].访问计数 < min_cnt) {
                min_cnt = 字形缓存[i].访问计数
                min_idx = i
            }
            i = i + 1
        }
        // 释放旧位图
        如果 (字形缓存[min_idx].位图 != 0) {
            堆_释放(字形缓存[min_idx].位图.像素)
        }
        字形缓存[min_idx].字符码 = 字符码
        字形缓存[min_idx].字号 = 字号
        字形缓存[min_idx].位图 = 位图
        字形缓存[min_idx].访问计数 = 1
        字形缓存[min_idx].有效 = 真
        返回
    }
    定义 entry = 字形缓存项 {}
    entry.字符码 = 字符码
    entry.字号 = 字号
    entry.位图 = 位图
    entry.访问计数 = 1
    entry.有效 = 真
    追加(字形缓存, entry)
}

// §9 文本渲染 + 字节序辅助

函数 TTF_渲染字符(字符码, 字号) {
    // 查缓存
    定义 cached = 字形缓存_查找(字符码, 字号)
    如果 (cached != 0) { 返回 cached }
    // cmap查找
    定义 glyphID = TTF_cmap_查找字形ID(字符码)
    如果 (glyphID == 0) { 返回 0 }
    // 加载字形
    定义 glyph = TTF_加载字形(glyphID)
    如果 (glyph == 0) { 返回 0 }
    // 光栅化
    定义 bmp = TTF_光栅化(glyph, 字号)
    如果 (bmp != 0) {
        字形缓存_插入(字符码, 字号, bmp)
    }
    返回 bmp
}

函数 TTF_渲染文本(文本, 字号, fb, x, y, 颜色) {
    如果 (!全局TTF.已加载) { 返回 0 }
    定义 缩放 = 字号 * 1024 / 全局TTF.单位_每EM
    定义 可变 cursor_x = x
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 ch = 字符串_字符(文本, i)
        定义 bmp = TTF_渲染字符(ch, 字号)
        如果 (bmp != 0) {
            // 将位图写入帧缓冲
            TTF_blit位图(fb, bmp, cursor_x, y, 颜色)
            // advance
            定义 glyphID = TTF_cmap_查找字形ID(ch)
            定义 glyph = TTF_加载字形(glyphID)
            如果 (glyph != 0) {
                cursor_x = cursor_x + glyph.advanceWidth * 缩放 / 1024
            } 否则 {
                cursor_x = cursor_x + 字号 / 2
            }
        } 否则 {
            cursor_x = cursor_x + 字号 / 2
        }
        i = i + 1
    }
    返回 cursor_x - x  // 返回渲染宽度
}

函数 TTF_blit位图(fb, bmp, dx, dy, 颜色) {
    定义 可变 by = 0
    当 (by < bmp.高度) {
        定义 可变 bx = 0
        当 (bx < bmp.宽度) {
            定义 alpha = 内存_读8(bmp.像素 + by * bmp.宽度 + bx)
            如果 (alpha > 0) {
                定义 px = dx + bx
                定义 py = dy + by
                如果 (px >= 0 && py >= 0 && px < fb.宽度 && py < fb.高度) {
                    // alpha混合
                    定义 dst_off = (py * fb.宽度 + px) * 4
                    定义 src_r = (颜色 >> 16) & 0xFF
                    定义 src_g = (颜色 >> 8) & 0xFF
                    定义 src_b = 颜色 & 0xFF
                    定义 dst_r = 内存_读8(fb.数据 + dst_off)
                    定义 dst_g = 内存_读8(fb.数据 + dst_off + 1)
                    定义 dst_b = 内存_读8(fb.数据 + dst_off + 2)
                    定义 inv_a = 255 - alpha
                    内存_写8(fb.数据 + dst_off, (src_r * alpha + dst_r * inv_a) / 255)
                    内存_写8(fb.数据 + dst_off + 1, (src_g * alpha + dst_g * inv_a) / 255)
                    内存_写8(fb.数据 + dst_off + 2, (src_b * alpha + dst_b * inv_a) / 255)
                }
            }
            bx = bx + 1
        }
        by = by + 1
    }
}

// 字节序辅助: TTF使用大端字节序
函数 TTF_读8(off) {
    返回 内存_读8(全局TTF.数据 + off)
}

函数 TTF_读16(off) {
    定义 b = 全局TTF.数据 + off
    返回 (内存_读8(b) << 8) | 内存_读8(b + 1)
}

函数 TTF_读16有符号(off) {
    定义 v = TTF_读16(off)
    如果 (v >= 32768) { 返回 v - 65536 }
    返回 v
}

函数 TTF_读32(off) {
    定义 b = 全局TTF.数据 + off
    返回 (内存_读8(b) << 24) | (内存_读8(b + 1) << 16) |
           (内存_读8(b + 2) << 8) | 内存_读8(b + 3)
}

定义 可变 AI_真字体文件_热文件表 = []

函数 AI_真字体文件_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_真字体文件_热文件表)) {
        如果 (AI_真字体文件_热文件表[i].路径 == 路径) {
            AI_真字体文件_热文件表[i].频率 = AI_真字体文件_热文件表[i].频率 + 1
            返回 AI_真字体文件_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_真字体文件_热文件表) < 128) {
        追加(AI_真字体文件_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_真字体文件_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

// NovaOS NJSD 解构赋值引擎 (Nova JS Destructuring)
// NJSD理论: 基于结构模式匹配的递归解构算法
//   对象解构: {x, y:alias, ...rest} = obj
//     键提取 + 别名映射 + rest收集
//   数组解构: [a, b, ...rest] = arr
//     迭代器协议 + 索引提取 + rest收集
//   嵌套解构: 递归展平为顺序操作
//   默认值: undefined时懒性求值回退
//   计算属性键: [expr]动态解析
//   AI增强: Tensor特征推断解构模式/类型一致性/性能维度

导入("../中枢/系统调用表.nova")
导入("../推理/智能渠道.nova")
导入("./值乘.nova")
导入("./小整数快速判.nova")
导入("./承诺完整辅助.nova")
导入("../中枢/整数转字符串.nova")
导入("../标准/类型判断.nova")

函数 Destructure_对象(Nova运行时实例, 源, 键列表, 键数量, 有rest) {
    // 键列表: 需要提取的属性名数组
    // 返回: [值1, 值2, ..., rest对象(如果有rest)]
    如果 (源 == 0) {
        // Type错误: Cannot destructure undefined/null
        返回 0
    }

    定义 结果 = 堆_分配_数组((键数量 + 1) * 8)
    定义 可变 i = 0

    // 逐个提取属性值
    当 (i < 键数量) {
        定义 键 = 内存_读64(键列表 + i * 8)
        如果 (键 != 0) {
            内存_写64(结果 + i * 8, Nova对象_获取属性_完整(Nova运行时实例, 源, 键))
        } 否则 {
            内存_写64(结果 + i * 8, 0)
        }
        i = i + 1
    }

    // Rest: 收集未被解构的属性
    如果 (有rest) {
        定义 rest对象 = Nova对象_创建(Nova运行时实例, 0)
        // 遍历源对象的所有可枚举自有属性
        定义 所有键 = Object_keys(Nova运行时实例, 源)
        定义 所有键数组 = 所有键[0]
        定义 所有键数 = 所有键[1]

        定义 可变 j = 0
        当 (j < 所有键数) {
            定义 k = 内存_读64(所有键数组 + j * 8)
            // 检查是否已被解构
            定义 可变 已提取 = 假
            i = 0
            当 (i < 键数量) {
                如果 (字符串_相等(k, 内存_读64(键列表 + i * 8))) {
                    已提取 = 真; 跳出
                }
                i = i + 1
            }
            如果 (!已提取) {
                // 复制到rest对象
                定义 值 = Nova对象_获取属性_完整(Nova运行时实例, 源, k)
                定义 desc = PropDesc_创建_数据(值, 真, 真, 真)
                Nova对象_设置属性(rest对象, k, desc)
            }
            j = j + 1
        }
        内存_写64(结果 + 键数量 * 8, rest对象)
    }

    返回 结果
}

// §3 默认值处理
// const { x = 10, y = 20 } = obj
// 当解构值为undefined时使用默认值

函数 Destructure_应用默认值(值, 默认值) {
    // undefined时使用默认值
    如果 (值 == 0) { 返回 默认值 }    // undefined → 使用默认值
    返回 值
}

函数 Destructure_应用默认值_惰性(Nova运行时实例, 值, 默认值函数) {
    // 默认值可能是函数(惰性求值)
    // const { x = expensiveComputation() } = obj
    如果 (值 == 0 && 默认值函数 != 0) {
        返回 Nova函数_Call(Nova运行时实例, 默认值函数, 0)
    }
    如果 (值 == 0) { 返回 0 }
    返回 值
}

// §4 嵌套解构
// const { a: { b, c }, d: [e, f] } = obj
// 编译器将嵌套解构展平为一系列操作

函数 Destructure_嵌套_对象属性_到_数组(Nova运行时实例, 源, 属性名) {
    // 从源中取属性,然后对该属性值进行数组解构
    定义 子源 = Nova对象_获取属性_完整(Nova运行时实例, 源, 属性名)
    返回 子源    // 调用者对此进一步解构
}

函数 Destructure_嵌套_数组元素_到_对象(Nova运行时实例, 源, 索引) {
    // 从数组中取元素,然后对该元素进行对象解构
    如果 (源 == 0) { 返回 0 }
    返回 Nova数组_获取(源, 索引)
}

// §1 NJSD 全局状态与常量

// 解构模式类型
定义 NJSD_模式_对象 = 1
定义 NJSD_模式_数组 = 2
定义 NJSD_模式_嵌套对象 = 3
定义 NJSD_模式_嵌套数组 = 4
定义 NJSD_模式_赋值 = 5    // let/const/var
定义 NJSD_模式_参数 = 6    // 函数参数解构

// 绑定元素类型
定义 NJSD_绑定_普通 = 0     // {x}
定义 NJSD_绑定_别名 = 1     // {x: alias}
定义 NJSD_绑定_计算键 = 2   // {[expr]: x}
定义 NJSD_绑定_默认值 = 3   // {x = val}
定义 NJSD_绑定_rest = 4      // {...rest}

// 统计计数器
定义 可变 NJSD_对象解构次数 = 0
定义 可变 NJSD_数组解构次数 = 0
定义 可变 NJSD_嵌套解构次数 = 0
定义 可变 NJSD_默认值次数 = 0
定义 可变 NJSD_计算键次数 = 0
定义 可变 NJSD_rest次数 = 0
定义 可变 NJSD_迭代器次数 = 0
定义 可变 NJSD_AI推断次数 = 0
定义 可变 NJSD_错误次数 = 0

// AI总线引用
定义 可变 NJSD_AI总线 = 0

// §5 数组解构引擎

函数 Destructure_数组(Nova运行时实例, 源, 索引数, 有rest) {
    NJSD_数组解构次数 = NJSD_数组解构次数 + 1
    如果 (源 == 0) {
        NJSD_错误次数 = NJSD_错误次数 + 1
        返回 0
    }
    // 获取迭代器
    定义 iter = NJSD_获取迭代器(Nova运行时实例, 源)
    如果 (iter == 0) {
        // 回退到数组索引访问
        返回 Destructure_数组_索引回退(Nova运行时实例, 源, 索引数, 有rest)
    }
    定义 结果 = 堆_分配_数组((索引数 + 1) * 8)
    定义 可变 i = 0
    // 通过迭代器按顺序提取
    当 (i < 索引数) {
        定义 next = NJSD_迭代器_next(Nova运行时实例, iter)
        如果 (next.完成) {
            // 剩余位置填充 undefined
            当 (i < 索引数) {
                内存_写i64(结果 + i * 8, 0)
                i = i + 1
            }
            返回 结果
        }
        内存_写i64(结果 + i * 8, next.值)
        i = i + 1
    }
    // Rest: 收集剩余元素
    如果 (有rest) {
        NJSD_rest次数 = NJSD_rest次数 + 1
        定义 rest数组 = Nova数组_创建(Nova运行时实例, 0)
        定义 可变 ri = 0
        定义 可变 done = 假
        当 (!done) {
            定义 next = NJSD_迭代器_next(Nova运行时实例, iter)
            如果 (next.完成) {
                done = 真
            } 否则 {
                Nova数组_设置(rest数组, ri, next.值)
                ri = ri + 1
            }
        }
        内存_写i64(结果 + 索引数 * 8, rest数组)
    }
    返回 结果
}

函数 Destructure_数组_索引回退(Nova运行时实例, 源, 索引数, 有rest) {
    // 无迭代器时回退到普通数组索引访问
    定义 结果 = 堆_分配_数组((索引数 + 1) * 8)
    定义 len = Nova数组_长度(Nova运行时实例, 源)
    定义 可变 i = 0
    当 (i < 索引数) {
        如果 (i < len) {
            内存_写i64(结果 + i * 8, Nova数组_获取(源, i))
        } 否则 {
            内存_写i64(结果 + i * 8, 0)
        }
        i = i + 1
    }
    如果 (有rest) {
        NJSD_rest次数 = NJSD_rest次数 + 1
        定义 rest数组 = Nova数组_创建(Nova运行时实例, 0)
        定义 可变 ri = 0
        当 (索引数 + ri < len) {
            Nova数组_设置(rest数组, ri, Nova数组_获取(源, 索引数 + ri))
            ri = ri + 1
        }
        内存_写i64(结果 + 索引数 * 8, rest数组)
    }
    返回 结果
}

// §6 迭代器协议接口

结构 NJSD_迭代结果 {
    值: 0
    完成: 假
}

函数 NJSD_获取迭代器(Nova运行时实例, 对象) {
    NJSD_迭代器次数 = NJSD_迭代器次数 + 1
    // 查找 Symbol.iterator 方法
    定义 iterMethod = Nova对象_获取属性_完整(Nova运行时实例, 对象, "@@iterator")
    如果 (iterMethod == 0) { 返回 0 }
    // 调用得到迭代器对象
    定义 iter = Nova函数_Call(Nova运行时实例, iterMethod, 对象)
    返回 iter
}

函数 NJSD_迭代器_next(Nova运行时实例, iter) {
    定义 结果 = NJSD_迭代结果 { 值: 0, 完成: 假 }
    定义 nextMethod = Nova对象_获取属性_完整(Nova运行时实例, iter, "next")
    如果 (nextMethod == 0) {
        结果.完成 = 真
        返回 结果
    }
    定义 iterResult = Nova函数_Call(Nova运行时实例, nextMethod, iter)
    如果 (iterResult == 0) {
        结果.完成 = 真
        返回 结果
    }
    // 读取 done 和 value
    定义 doneVal = Nova对象_获取属性_完整(Nova运行时实例, iterResult, "done")
    结果.完成 = NJSD_转Bool(doneVal)
    如果 (!结果.完成) {
        结果.值 = Nova对象_获取属性_完整(Nova运行时实例, iterResult, "value")
    }
    返回 结果
}

函数 NJSD_转Bool(val) {
    如果 (val == 0) { 返回 假 }
    如果 (val == 假) { 返回 假 }
    返回 真
}

// §7 计算属性键解构

函数 Destructure_计算键(Nova运行时实例, 源, 键表达式) {
    // { [expr]: alias } = obj
    // expr先求值为字符串键, 再从源中提取
    NJSD_计算键次数 = NJSD_计算键次数 + 1
    定义 动态键 = Nova表达式_求值(Nova运行时实例, 键表达式)
    如果 (动态键 == 0) { 返回 0 }
    // ToString 转换
    定义 字符串键 = Nova转字符串(Nova运行时实例, 动态键)
    返回 Nova对象_获取属性_完整(Nova运行时实例, 源, 字符串键)
}

函数 Destructure_计算键_带默认(Nova运行时实例, 源, 键表达式, 默认值) {
    定义 val = Destructure_计算键(Nova运行时实例, 源, 键表达式)
    返回 Destructure_应用默认值(val, 默认值)
}

// §8 赋值目标验证

函数 NJSD_验证解构目标(Nova运行时实例, 源) {
    // 在解构前验证源不是 null/undefined
    如果 (源 == 0) {
        NJSD_错误次数 = NJSD_错误次数 + 1
        Nova运行时_抛出类型错误(Nova运行时实例,
            "Cannot destructure undefined or null")
        返回 假
    }
    返回 真
}

函数 NJSD_强制转对象(Nova运行时实例, 源) {
    // RequireObjectCoercible
    如果 (源 == 0) {
        NJSD_错误次数 = NJSD_错误次数 + 1
        返回 0
    }
    定义 类型 = Nova值_类型(Nova运行时实例, 源)
    如果 (类型 == "string" || 类型 == "number" || 类型 == "boolean") {
        // 自动装箱为对象
        返回 Nova对象_装箱(Nova运行时实例, 源)
    }
    返回 源
}

// §9 增强对象解构主流程

结构 NJSD_解构绑定项 {
    类型: 0         // NJSD_绑定_*
    源键: ""        // 对象中的属性名
    目标名: ""      // 绑定到的变量名 (别名)
    默认值: 0       // undefined时的回退值
    子模式: 0      // 嵌套解构模式
}

函数 NJSD_增强对象解构(Nova运行时实例, 源, 绑定列表, 绑定数, 有rest) {
    NJSD_对象解构次数 = NJSD_对象解构次数 + 1
    // 步骤1: 验证源
    如果 (!NJSD_验证解构目标(Nova运行时实例, 源)) { 返回 0 }
    定义 obj = NJSD_强制转对象(Nova运行时实例, 源)
    如果 (obj == 0) { 返回 0 }
    定义 结果 = 堆_分配_数组((绑定数 + 1) * 8)
    定义 可变 i = 0
    当 (i < 绑定数) {
        定义 binding = 绑定列表[i]
        定义 可变 val = 0
        // 步骤2: 提取值
        如果 (binding.类型 == NJSD_绑定_计算键) {
            val = Destructure_计算键(Nova运行时实例, obj, binding.源键)
        } 否则 {
            val = Nova对象_获取属性_完整(Nova运行时实例, obj, binding.源键)
        }
        // 步骤3: 默认值
        如果 (val == 0 && binding.默认值 != 0) {
            NJSD_默认值次数 = NJSD_默认值次数 + 1
            val = binding.默认值
        }
        // 步骤4: 嵌套解构
        如果 (binding.子模式 != 0) {
            NJSD_嵌套解构次数 = NJSD_嵌套解构次数 + 1
            val = NJSD_递归解构(Nova运行时实例, val, binding.子模式)
        }
        内存_写i64(结果 + i * 8, val)
        i = i + 1
    }
    // 步骤5: Rest
    如果 (有rest) {
        定义 rest结果 = Destructure_对象_收集rest(Nova运行时实例, obj, 绑定列表, 绑定数)
        内存_写i64(结果 + 绑定数 * 8, rest结果)
    }
    返回 结果
}

函数 Destructure_对象_收集rest(Nova运行时实例, 源, 绑定列表, 绑定数) {
    NJSD_rest次数 = NJSD_rest次数 + 1
    定义 rest对象 = Nova对象_创建(Nova运行时实例, 0)
    定义 所有键 = Object_keys(Nova运行时实例, 源)
    定义 所有键数组 = 所有键[0]
    定义 所有键数 = 所有键[1]
    定义 可变 j = 0
    当 (j < 所有键数) {
        定义 k = 内存_读64(所有键数组 + j * 8)
        定义 可变 已提取 = 假
        定义 可变 bi = 0
        当 (bi < 绑定数) {
            如果 (字符串_相等(k, 绑定列表[bi].源键)) {
                已提取 = 真
            }
            bi = bi + 1
        }
        如果 (!已提取) {
            定义 值 = Nova对象_获取属性_完整(Nova运行时实例, 源, k)
            定义 desc = PropDesc_创建_数据(值, 真, 真, 真)
            Nova对象_设置属性(rest对象, k, desc)
        }
        j = j + 1
    }
    返回 rest对象
}

函数 NJSD_递归解构(Nova运行时实例, 源, 子模式) {
    // 根据子模式类型递归解构
    如果 (子模式.类型 == NJSD_模式_对象) {
        返回 NJSD_增强对象解构(Nova运行时实例, 源, 子模式.绑定列表, 子模式.绑定数, 子模式.有rest)
    } 否则 如果 (子模式.类型 == NJSD_模式_数组) {
        返回 Destructure_数组(Nova运行时实例, 源, 子模式.索引数, 子模式.有rest)
    }
    返回 源
}

// §10 AI类型推断引擎

函数 NJSD_AI特征提取(绑定列表, 绑定数, 有rest) {
    // 将解构模式编码为Tensor特征向量
    定义 tensor = Tensor_创建(10)
    // 特征[0]: 绑定数量归一化
    Tensor_写(tensor, 0, 绑定数 / 32.0)
    // 特征[1]: 是否有rest
    如果 (有rest) { Tensor_写(tensor, 1, 1.0) }
    否则 { Tensor_写(tensor, 1, 0.0) }
    // 特征[2]: 嵌套深度
    定义 可变 maxDepth = 0
    定义 可变 i = 0
    当 (i < 绑定数) {
        如果 (绑定列表[i].子模式 != 0) {
            maxDepth = maxDepth + 1
        }
        i = i + 1
    }
    Tensor_写(tensor, 2, maxDepth / 8.0)
    // 特征[3]: 默认值比例
    定义 可变 defCount = 0
    i = 0
    当 (i < 绑定数) {
        如果 (绑定列表[i].默认值 != 0) {
            defCount = defCount + 1
        }
        i = i + 1
    }
    如果 (绑定数 > 0) {
        Tensor_写(tensor, 3, defCount / 绑定数)
    }
    // 特征[4]: 计算键比例
    定义 可变 compCount = 0
    i = 0
    当 (i < 绑定数) {
        如果 (绑定列表[i].类型 == NJSD_绑定_计算键) {
            compCount = compCount + 1
        }
        i = i + 1
    }
    如果 (绑定数 > 0) {
        Tensor_写(tensor, 4, compCount / 绑定数)
    }
    返回 tensor
}

函数 NJSD_AI预测解构性能(绑定列表, 绑定数, 有rest) {
    NJSD_AI推断次数 = NJSD_AI推断次数 + 1
    如果 (NJSD_AI总线 == 0) { 返回 0 }
    定义 tensor = NJSD_AI特征提取(绑定列表, 绑定数, 有rest)
    定义 结果 = AI总线_推理(NJSD_AI总线, "destruct_perf", tensor)
    定义 性能分 = Tensor_读(结果, 0)
    Tensor_释放(tensor)
    Tensor_释放(结果)
    返回 性能分
}

函数 NJSD_AI检测类型不匹配(Nova运行时实例, 源, 绑定列表, 绑定数) {
    // 检测解构源中缺少的属性
    定义 可变 缺失数 = 0
    定义 可变 i = 0
    当 (i < 绑定数) {
        定义 键 = 绑定列表[i].源键
        定义 val = Nova对象_获取属性_完整(Nova运行时实例, 源, 键)
        如果 (val == 0 && 绑定列表[i].默认值 == 0) {
            缺失数 = 缺失数 + 1
        }
        i = i + 1
    }
    返回 缺失数
}

// §11 初始化与诊断

函数 NJSD_初始化() {
    NJSD_对象解构次数 = 0
    NJSD_数组解构次数 = 0
    NJSD_嵌套解构次数 = 0
    NJSD_默认值次数 = 0
    NJSD_计算键次数 = 0
    NJSD_rest次数 = 0
    NJSD_迭代器次数 = 0
    NJSD_AI推断次数 = 0
    NJSD_错误次数 = 0
    NJSD_AI总线 = 全局AI总线
    打印("[NJSD] 解构赋值引擎初始化完成")
}

函数 NJSD_诊断报告() {
    打印("[NJSD] === 解构赋值诊断 ===")
    打印("  对象解构=" + 整数转字符串(NJSD_对象解构次数) + " 数组解构=" + 整数转字符串(NJSD_数组解构次数) + " 嵌套=" + 整数转字符串(NJSD_嵌套解构次数))
    打印("  默认值=" + 整数转字符串(NJSD_默认值次数) + " 计算键=" + 整数转字符串(NJSD_计算键次数) + " rest=" + 整数转字符串(NJSD_rest次数))
    打印("  迭代器=" + 整数转字符串(NJSD_迭代器次数) + " AI推断=" + 整数转字符串(NJSD_AI推断次数) + " 错误=" + 整数转字符串(NJSD_错误次数))
}

// NovaOS内核 · 对话管理 (移植自Nova大脑L5/dialog)
// 多轮对话状态机 + 上下文压缩 + 模式切换
// §1 对话状态机: 聊天/工作/代码/系统 四种模式
// §2 上下文窗口: 滑动窗口+重要性加权保留
// §3 上下文压缩: 长对话自动摘要(解决国产模型上下文短)
// §4 意图检测: 简单模式匹配→路由到对应处理器
// §5 指令前缀: /work /code /sys 切换模式, 无前缀=聊天

定义 模式_聊天 = 0
定义 模式_工作 = 1
定义 模式_代码 = 2
定义 模式_系统 = 3

定义 上下文_最大轮数 = 64
定义 上下文_压缩阈值 = 48     // 超过此轮数触发压缩
定义 摘要_最大长度 = 8         // 压缩后保留的摘要条目

结构 对话轮 {
    角色,    // u8 0=用户 1=AI 2=系统
    内容哈希,
    时间戳,
    重要度,    // u32 0-1000
    模式,
}

定义 可变 对话历史 = []
定义 可变 摘要缓冲 = []        // 压缩后的摘要
定义 可变 当前模式 = 模式_聊天
定义 可变 对话_时钟 = 0
定义 可变 对话_已初始化 = 假
定义 可变 总轮数 = 0
定义 可变 总压缩次数 = 0
定义 可变 模式切换次数 = 0

函数 对话_初始化() {
    对话历史 = []
    摘要缓冲 = []
    当前模式 = 模式_聊天
    对话_时钟 = 0
    总轮数 = 0
    对话_已初始化 = 真
    内核信息("对话管理: 4模式切换+上下文压缩+意图检测+指令前缀")
}


函数 对话_添加(角色, 内容哈希, 重要度) {
    对话_时钟 = 对话_时钟 + 1
    总轮数 = 总轮数 + 1
    定义 轮 = 对话轮 {}
    轮.角色 = 角色
    轮.内容哈希 = 内容哈希
    轮.时间戳 = 对话_时钟
    轮.重要度 = 重要度
    轮.模式 = 当前模式
    追加(对话历史, 轮)

    // 触发压缩检查
    如果 (计数(对话历史) > 上下文_压缩阈值) {
        对话_压缩()
    }
}


函数 对话_切换模式(新模式) {
    如果 (新模式 != 当前模式) {
        当前模式 = 新模式
        模式切换次数 = 模式切换次数 + 1
    }
}

函数 对话_检测指令(内容哈希) {
    // 通过哈希前缀检测指令模式
    // 实际实现中应解析文本前缀 /work /code /sys
    // 内核层面用哈希近似
    返回 当前模式  // 保持当前模式
}

函数 对话_是工作模式() { 返回 当前模式 == 模式_工作 }
函数 对话_是聊天模式() { 返回 当前模式 == 模式_聊天 }


函数 对话_压缩() {
    // 保留最重要的摘要 + 最近的对话
    总压缩次数 = 总压缩次数 + 1

    // 1. 按重要度排序前半部分, 提取重要条目到摘要
    定义 半数 = 计数(对话历史) / 2
    定义 可变 i = 0
    当 (i < 半数 && 计数(摘要缓冲) < 摘要_最大长度) {
        如果 (对话历史[i].重要度 > 500) {
            追加(摘要缓冲, 对话历史[i].内容哈希)
        }
        i = i + 1
    }
    如果 (计数(摘要缓冲) > 摘要_最大长度) {
        摘要缓冲 = 列表_切片(摘要缓冲, 计数(摘要缓冲) - 摘要_最大长度, 计数(摘要缓冲))
    }

    // 2. 删除前半部分对话, 保留最近的
    定义 可变 新历史 = []
    i = 半数
    当 (i < 计数(对话历史)) {
        追加(新历史, 对话历史[i])
        i = i + 1
    }
    对话历史 = 新历史
}


函数 对话_最近(数量) {
    定义 n = 计数(对话历史)
    如果 (n <= 数量) { 返回 对话历史 }
    定义 可变 结果 = []
    定义 可变 i = n - 数量
    当 (i < n) { 追加(结果, 对话历史[i]); i = i + 1 }
    返回 结果
}

函数 对话_获取摘要() { 返回 摘要缓冲 }
函数 对话_当前模式() { 返回 当前模式 }
函数 对话_轮数() { 返回 计数(对话历史) }

函数 对话_统计() {
    返回 {
        总轮数: 总轮数,
        当前轮数: 计数(对话历史),
        摘要数: 计数(摘要缓冲),
        压缩次数: 总压缩次数,
        模式切换: 模式切换次数,
        当前模式: 当前模式
    }
}


定义 意图_查询 = 0
定义 意图_命令 = 1
定义 意图_闲聊 = 2
定义 意图_代码 = 3
定义 意图_系统 = 4

函数 对话_检测意图(内容哈希, 模式) {
    // 基于模式+哈希特征的简单意图分类
    如果 (模式 == 模式_系统) { 返回 意图_系统 }
    如果 (模式 == 模式_代码) { 返回 意图_代码 }
    如果 (模式 == 模式_工作) { 返回 意图_命令 }
    // 聊天模式: 通过哈希最低位近似判断(实际应做NLP)
    如果 (内容哈希 % 3 == 0) { 返回 意图_查询 }
    返回 意图_闲聊
}


函数 对话_自动重要度(角色, 内容哈希) {
    // AI回复通常比用户输入重要度低(可被压缩)
    如果 (角色 == 2) { 返回 800 }  // 系统消息最重要
    如果 (角色 == 0) { 返回 600 }  // 用户消息中等
    返回 400                         // AI回复较低
}

函数 对话_添加_自动(角色, 内容哈希) {
    定义 重要度 = 对话_自动重要度(角色, 内容哈希)
    对话_添加(角色, 内容哈希, 重要度)
}


函数 对话_序列化() {
    // 将当前对话状态序列化为可持久化格式
    定义 可变 结果 = []
    追加(结果, 当前模式)
    追加(结果, 对话_时钟)
    追加(结果, 总轮数)
    追加(结果, 总压缩次数)
    追加(结果, 计数(对话历史))
    定义 可变 i = 0
    当 (i < 计数(对话历史)) {
        追加(结果, 对话历史[i].角色)
        追加(结果, 对话历史[i].内容哈希)
        追加(结果, 对话历史[i].重要度)
        追加(结果, 对话历史[i].模式)
        i = i + 1
    }
    返回 结果
}

函数 对话_反序列化(数据) {
    如果 (计数(数据) < 5) { 返回 假 }
    当前模式 = 数据[0]
    对话_时钟 = 数据[1]
    总轮数 = 数据[2]
    总压缩次数 = 数据[3]
    定义 轮数 = 数据[4]
    对话历史 = []
    定义 可变 i = 0
    定义 可变 偏移 = 5
    当 (i < 轮数 && 偏移 + 3 < 计数(数据)) {
        定义 轮 = 对话轮 {}
        轮.角色 = 数据[偏移]
        轮.内容哈希 = 数据[偏移 + 1]
        轮.重要度 = 数据[偏移 + 2]
        轮.模式 = 数据[偏移 + 3]
        追加(对话历史, 轮)
        偏移 = 偏移 + 4
        i = i + 1
    }
    返回 真
}


函数 对话_重置() {
    对话历史 = []
    摘要缓冲 = []
    当前模式 = 模式_聊天
    对话_时钟 = 0
    总轮数 = 0
    总压缩次数 = 0
    模式切换次数 = 0
}


函数 对话_模式名(模式) {
    如果 (模式 == 模式_聊天) { 返回 "chat" }
    如果 (模式 == 模式_工作) { 返回 "work" }
    如果 (模式 == 模式_代码) { 返回 "code" }
    如果 (模式 == 模式_系统) { 返回 "system" }
    返回 "unknown"
}

函数 对话_意图名(意图) {
    如果 (意图 == 意图_查询) { 返回 "query" }
    如果 (意图 == 意图_命令) { 返回 "command" }
    如果 (意图 == 意图_闲聊) { 返回 "chat" }
    如果 (意图 == 意图_代码) { 返回 "code" }
    如果 (意图 == 意图_系统) { 返回 "system" }
    返回 "unknown"
}

函数 对话_完整统计() {
    返回 [总轮数, 计数(对话历史), 总压缩次数, 模式切换次数, 当前模式]
}

// §3 报文构造

函数 发送_DISCOVER(接口名) {
    定义 包 = 构造_DHCP报文(DHCP_DISCOVER, 0, 0)
    // 广播发送: 0.0.0.0:68 → 255.255.255.255:67
    数报_发送(接口名, 0, DHCP_客户端端口, 0xFFFFFFFF, DHCP_服务器端口, 包)
}

函数 发送_REQUEST(接口名, 请求IP, 服务器IP) {
    定义 包 = 构造_DHCP报文(DHCP_REQUEST, 请求IP, 服务器IP)
    数报_发送(接口名, 0, DHCP_客户端端口, 0xFFFFFFFF, DHCP_服务器端口, 包)
}

函数 发送_RELEASE(接口名) {
    如果 (当前租约 == 空) { 返回 }
    定义 包 = 构造_DHCP报文(DHCP_RELEASE, 当前租约.IP地址, 当前租约.服务器IP)
    数报_发送(接口名, 当前租约.IP地址, DHCP_客户端端口, 当前租约.服务器IP, DHCP_服务器端口, 包)
    当前租约.状态 = 0
    内核信息("DHCP: 释放IP " + IP转字符串(当前租约.IP地址))
}

函数 构造_DHCP报文(类型, 请求IP, 服务器IP) {
    定义 可变 包 = 缓冲区(576)  // 最小DHCP包
    // BOOTP头
    DHCP_缓冲写(包, 0, 1)          // op: BOOTREQUEST
    DHCP_缓冲写(包, 1, 1)          // htype: Ethernet
    DHCP_缓冲写(包, 2, 6)          // hlen: MAC长度
    DHCP_缓冲写(包, 3, 0)          // hops
    DHCP_缓冲写32(包, 4, DHCP_事务ID)  // xid
    // 跳过secs/flags/ciaddr/yiaddr/siaddr/giaddr/chaddr
    // DHCP magic cookie
    DHCP_缓冲写32(包, 236, DHCP_MAGIC)
    // DHCP选项
    定义 可变 偏移 = 240
    // 选项53: DHCP消息类型
    DHCP_缓冲写(包, 偏移, 53); DHCP_缓冲写(包, 偏移+1, 1); DHCP_缓冲写(包, 偏移+2, 类型); 偏移 = 偏移 + 3
    // 选项50: 请求IP(REQUEST时)
    如果 (请求IP != 0) {
        DHCP_缓冲写(包, 偏移, 50); DHCP_缓冲写(包, 偏移+1, 4); DHCP_缓冲写32(包, 偏移+2, 请求IP); 偏移 = 偏移 + 6
    }
    // 选项54: 服务器标识(REQUEST时)
    如果 (服务器IP != 0) {
        DHCP_缓冲写(包, 偏移, 54); DHCP_缓冲写(包, 偏移+1, 4); DHCP_缓冲写32(包, 偏移+2, 服务器IP); 偏移 = 偏移 + 6
    }
    // 选项55: 参数请求列表
    DHCP_缓冲写(包, 偏移, 55); DHCP_缓冲写(包, 偏移+1, 4)
    DHCP_缓冲写(包, 偏移+2, 1)   // 子网掩码
    DHCP_缓冲写(包, 偏移+3, 3)   // 路由器(网关)
    DHCP_缓冲写(包, 偏移+4, 6)   // 域名
    DHCP_缓冲写(包, 偏移+5, 51)  // 租约时间
    偏移 = 偏移 + 6
    // 选项12: 主机名
    如果 (当前租约 != 空 && 字符串长度(当前租约.主机名) > 0) {
        定义 名长 = 字符串长度(当前租约.主机名)
        DHCP_缓冲写(包, 偏移, 12); DHCP_缓冲写(包, 偏移+1, 名长)
        偏移 = 偏移 + 2 + 名长
    }
    // 选项255: 结束
    DHCP_缓冲写(包, 偏移, 255)
    返回 包
}

// §4 响应解析

函数 解析_OFFER(包) {
    当前租约.IP地址 = DHCP_缓冲读32(包, 16)    // yiaddr
    当前租约.服务器IP = DHCP_缓冲读32(包, 20)  // siaddr
    解析_DHCP选项(包, 240)
}

函数 解析_ACK(包) {
    解析_DHCP选项(包, 240)
    如果 (当前租约.续约时间 == 0) { 当前租约.续约时间 = 当前租约.租约时间 / 2 }
    如果 (当前租约.重绑时间 == 0) { 当前租约.重绑时间 = 当前租约.租约时间 * 7 / 8 }
}

函数 解析_DHCP选项(包, 起始) {
    定义 可变 偏移 = 起始
    当 (偏移 < 576) {
        定义 选项号 = DHCP_缓冲读(包, 偏移)
        如果 (选项号 == 255) { 中断 }  // End
        如果 (选项号 == 0) { 偏移 = 偏移 + 1; 继续 }  // Pad
        定义 长度 = DHCP_缓冲读(包, 偏移 + 1)

        如果 (选项号 == 1)  { 当前租约.子网掩码 = DHCP_缓冲读32(包, 偏移+2) }  // 子网掩码
        如果 (选项号 == 3)  { 当前租约.网关 = DHCP_缓冲读32(包, 偏移+2) }       // 路由器
        如果 (选项号 == 6)  { 当前租约.域名1 = DHCP_缓冲读32(包, 偏移+2) }       // 域名
        如果 (选项号 == 51) { 当前租约.租约时间 = DHCP_缓冲读32(包, 偏移+2) }   // 租约时间
        如果 (选项号 == 54) { 当前租约.服务器IP = DHCP_缓冲读32(包, 偏移+2) }   // 服务器标识
        如果 (选项号 == 58) { 当前租约.续约时间 = DHCP_缓冲读32(包, 偏移+2) }   // T1
        如果 (选项号 == 59) { 当前租约.重绑时间 = DHCP_缓冲读32(包, 偏移+2) }   // T2

        偏移 = 偏移 + 2 + 长度
    }
}

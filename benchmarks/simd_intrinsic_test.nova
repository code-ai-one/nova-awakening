// SIMD intrinsic 基础验证 (L1 版本, 单标量)

函数 主程序() {
    // __simd_浮点加(0.2, 0.9) = 1.1 bits = 0x3FF1999999999999 (或近似)
    定义 a = __simd_浮点加(0.2, 0.9)
    打印(字符串拼接("__simd_浮点加(0.2, 0.9)=", 转字符串(a)))
    // __simd_浮点乘(0.2, 0.9) = 0.18 bits = 0x3FC70A3D70A3D70B
    定义 b = __simd_浮点乘(0.2, 0.9)
    打印(字符串拼接("__simd_浮点乘(0.2, 0.9)=", 转字符串(b)))
    // __simd_浮点减(1.0, 0.3) = 0.7
    定义 c = __simd_浮点减(1.0, 0.3)
    打印(字符串拼接("__simd_浮点减(1.0, 0.3)=", 转字符串(c)))
    // __simd_浮点最大(0.3, 0.7) = 0.7 bits = 0x3FE6666666666666
    定义 d = __simd_浮点最大(0.3, 0.7)
    打印(字符串拼接("__simd_浮点最大(0.3, 0.7)=", 转字符串(d)))
    // __simd_浮点最小(0.3, 0.7) = 0.3
    定义 e = __simd_浮点最小(0.3, 0.7)
    打印(字符串拼接("__simd_浮点最小(0.3, 0.7)=", 转字符串(e)))
    // __simd_浮点平方根(4.0) = 2.0 bits = 0x4000000000000000 = 4611686018427387904
    定义 f = __simd_浮点平方根(4.0)
    打印(字符串拼接("__simd_浮点平方根(4.0)=", 转字符串(f)))
    返回 0
}

导入("../中枢/字符串替换.nova")
导入("../外联/地址解析辅.nova")
导入("../中枢/新系统张量乙.nova")

函数 字符串构建器_创建() { 返回 [[], 0] }

函数 字符串构建器_追加(构建器, 文本) {
    追加(构建器[0], 文本)
    构建器[1] = 构建器[1] + 字符串长度(文本)
}

函数 字符串构建器_追加字符(构建器, 字符码) {
    追加(构建器[0], 字符(字符码))
    构建器[1] = 构建器[1] + 1
}

函数 字符串构建器_追加行(构建器, 文本) {
    追加(构建器[0], 文本)
    追加(构建器[0], "\n")
    构建器[1] = 构建器[1] + 字符串长度(文本) + 1
}

函数 字符串构建器_长度(构建器) { 返回 构建器[1] }

函数 字符串构建器_清空(构建器) {
    构建器[0] = []
    构建器[1] = 0
}

函数 字符串构建器_构建(构建器) {
    定义 部分 = 构建器[0]
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(部分)) {
        结果 = 字符串拼接(结果, 部分[i])
        i = i + 1
    }
    返回 结果
}

函数 字符串分割(文本, 分隔符) {
    定义 结果 = []
    定义 长度 = 字符串长度(文本)
    定义 分隔长度 = 字符串长度(分隔符)
    如果 (分隔长度 == 0) {
        定义 可变 k = 0
        当 (k < 长度) {
            追加(结果, 字符串子串(文本, k, k + 1))
            k = k + 1
        }
        返回 结果
    }
    定义 可变 开始 = 0
    定义 可变 i = 0
    当 (i <= 长度 - 分隔长度) {
        如果 (字符串子串(文本, i, i + 分隔长度) == 分隔符) {
            追加(结果, 字符串子串(文本, 开始, i))
            开始 = i + 分隔长度
            i = 开始
        } 否则 {
            i = i + 1
        }
    }
    追加(结果, 字符串子串(文本, 开始, 长度))
    返回 结果
}

函数 字符串分割N(文本, 分隔符, 最大份数) {
    定义 结果 = []
    定义 长度 = 字符串长度(文本)
    定义 分隔长度 = 字符串长度(分隔符)
    定义 可变 开始 = 0
    定义 可变 i = 0
    定义 可变 份 = 1
    当 (i <= 长度 - 分隔长度 && 份 < 最大份数) {
        如果 (字符串子串(文本, i, i + 分隔长度) == 分隔符) {
            追加(结果, 字符串子串(文本, 开始, i))
            开始 = i + 分隔长度
            i = 开始
            份 = 份 + 1
        } 否则 {
            i = i + 1
        }
    }
    追加(结果, 字符串子串(文本, 开始, 长度))
    返回 结果
}

函数 字符串连接(列表, 分隔符) {
    如果 (计数(列表) == 0) { 返回 "" }
    定义 可变 结果 = 列表[0]
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        结果 = 字符串拼接(结果, 字符串拼接(分隔符, 列表[i]))
        i = i + 1
    }
    返回 结果
}

函数 字符串去首尾空白(文本) {
    定义 长度 = 字符串长度(文本)
    定义 可变 开始 = 0
    定义 可变 结束 = 长度
    当 (开始 < 长度 && 字符_是空白(字符串取字符码(文本, 开始))) { 开始 = 开始 + 1 }
    当 (结束 > 开始 && 字符_是空白(字符串取字符码(文本, 结束 - 1))) { 结束 = 结束 - 1 }
    返回 字符串子串(文本, 开始, 结束)
}

函数 字符串去首空白(文本) {
    定义 长度 = 字符串长度(文本)
    定义 可变 开始 = 0
    当 (开始 < 长度 && 字符_是空白(字符串取字符码(文本, 开始))) { 开始 = 开始 + 1 }
    返回 字符串子串(文本, 开始, 长度)
}

函数 字符串去尾空白(文本) {
    定义 可变 结束 = 字符串长度(文本)
    当 (结束 > 0 && 字符_是空白(字符串取字符码(文本, 结束 - 1))) { 结束 = 结束 - 1 }
    返回 字符串子串(文本, 0, 结束)
}

函数 字符串包含(文本, 子串) {
    返回 字符串查找(文本, 子串) >= 0
}

函数 字符串开头是(文本, 前缀) {
    定义 前缀长 = 字符串长度(前缀)
    如果 (字符串长度(文本) < 前缀长) { 返回 假 }
    返回 字符串子串(文本, 0, 前缀长) == 前缀
}

函数 字符串结尾是(文本, 后缀) {
    定义 文本长 = 字符串长度(文本)
    定义 后缀长 = 字符串长度(后缀)
    如果 (文本长 < 后缀长) { 返回 假 }
    返回 字符串子串(文本, 文本长 - 后缀长, 文本长) == 后缀
}

函数 字符串替换(文本, 旧串, 新串) {
    定义 旧长 = 字符串长度(旧串)
    如果 (旧长 == 0) { 返回 文本 }
    定义 部分 = 字符串分割(文本, 旧串)
    返回 字符串连接(部分, 新串)
}

函数 字符串替换首个(文本, 旧串, 新串) {
    定义 位置 = 字符串查找(文本, 旧串)
    如果 (位置 < 0) { 返回 文本 }
    定义 前 = 字符串子串(文本, 0, 位置)
    定义 后 = 字符串子串(文本, 位置 + 字符串长度(旧串), 字符串长度(文本))
    返回 字符串拼接(前, 字符串拼接(新串, 后))
}

函数 字符串重复(文本, 次数) {
    如果 (次数 <= 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 次数) {
        结果 = 字符串拼接(结果, 文本)
        i = i + 1
    }
    返回 结果
}

函数 字符串转大写(文本) {
    定义 长度 = 字符串长度(文本)
    定义 构建器 = 字符串构建器_创建()
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 字符串取字符码(文本, i)
        如果 (c >= 0x61 && c <= 0x7A) { c = c - 32 }
        字符串构建器_追加字符(构建器, c)
        i = i + 1
    }
    返回 字符串构建器_构建(构建器)
}

函数 字符串转小写(文本) {
    定义 长度 = 字符串长度(文本)
    定义 构建器 = 字符串构建器_创建()
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 字符串取字符码(文本, i)
        如果 (c >= 0x41 && c <= 0x5A) { c = c + 32 }
        字符串构建器_追加字符(构建器, c)
        i = i + 1
    }
    返回 字符串构建器_构建(构建器)
}

函数 字符串首字母大写(文本) {
    如果 (字符串长度(文本) == 0) { 返回 "" }
    定义 首字符 = 字符串转大写(字符串子串(文本, 0, 1))
    返回 字符串拼接(首字符, 字符串子串(文本, 1, 字符串长度(文本)))
}

函数 字符串左填充(文本, 目标长度, 填充字符) {
    定义 当前长度 = 字符串长度(文本)
    如果 (当前长度 >= 目标长度) { 返回 文本 }
    返回 字符串拼接(字符串重复(填充字符, 目标长度 - 当前长度), 文本)
}

函数 字符串右填充(文本, 目标长度, 填充字符) {
    定义 当前长度 = 字符串长度(文本)
    如果 (当前长度 >= 目标长度) { 返回 文本 }
    返回 字符串拼接(文本, 字符串重复(填充字符, 目标长度 - 当前长度))
}

函数 字符串居中(文本, 目标长度, 填充字符) {
    定义 当前长度 = 字符串长度(文本)
    如果 (当前长度 >= 目标长度) { 返回 文本 }
    定义 总填充 = 目标长度 - 当前长度
    定义 左 = 总填充 / 2
    定义 右 = 总填充 - 左
    返回 字符串拼接(字符串重复(填充字符, 左), 字符串拼接(文本, 字符串重复(填充字符, 右)))
}

函数 字符串反转(文本) {
    定义 长度 = 字符串长度(文本)
    定义 构建器 = 字符串构建器_创建()
    定义 可变 i = 长度 - 1
    当 (i >= 0) {
        字符串构建器_追加字符(构建器, 字符串取字符码(文本, i))
        i = i - 1
    }
    返回 字符串构建器_构建(构建器)
}

函数 字符串计数(文本, 子串) {
    定义 子长 = 字符串长度(子串)
    如果 (子长 == 0) { 返回 0 }
    定义 可变 次数 = 0
    定义 可变 位置 = 0
    当 (位置 <= 字符串长度(文本) - 子长) {
        定义 找到 = 字符串查找从(文本, 子串, 位置)
        如果 (找到 < 0) { 跳出 }
        次数 = 次数 + 1
        位置 = 找到 + 子长
    }
    返回 次数
}

函数 字符串查找从(文本, 子串, 起始) {
    定义 文本长 = 字符串长度(文本)
    定义 子长 = 字符串长度(子串)
    如果 (子长 == 0) { 返回 起始 }
    定义 可变 i = 起始
    当 (i <= 文本长 - 子长) {
        如果 (字符串子串(文本, i, i + 子长) == 子串) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 字符串最后查找(文本, 子串) {
    定义 文本长 = 字符串长度(文本)
    定义 子长 = 字符串长度(子串)
    如果 (子长 == 0) { 返回 文本长 }
    定义 可变 i = 文本长 - 子长
    当 (i >= 0) {
        如果 (字符串子串(文本, i, i + 子长) == 子串) { 返回 i }
        i = i - 1
    }
    返回 -1
}

函数 字符_是空白(c) {
    返回 c == 0x20 || c == 0x09 || c == 0x0A || c == 0x0D || c == 0x0C
}

函数 字符_是数字(c) {
    返回 c >= 0x30 && c <= 0x39
}

函数 字符_是字母(c) {
    返回 (c >= 0x41 && c <= 0x5A) || (c >= 0x61 && c <= 0x7A)
}

函数 字符_是大写(c) {
    返回 c >= 0x41 && c <= 0x5A
}

函数 字符_是小写(c) {
    返回 c >= 0x61 && c <= 0x7A
}

函数 字符_是十六进制(c) {
    返回 (c >= 0x30 && c <= 0x39) || (c >= 0x41 && c <= 0x46) || (c >= 0x61 && c <= 0x66)
}

函数 字符串转整数(文本) {
    定义 长度 = 字符串长度(文本)
    如果 (长度 == 0) { 返回 0 }
    定义 可变 i = 0
    定义 可变 符号 = 1
    当 (i < 长度 && 字符_是空白(字符串取字符码(文本, i))) { i = i + 1 }
    如果 (i < 长度 && 字符串取字符码(文本, i) == 0x2D) { 符号 = -1; i = i + 1 }
    否则 如果 (i < 长度 && 字符串取字符码(文本, i) == 0x2B) { i = i + 1 }
    定义 可变 结果 = 0
    当 (i < 长度 && 字符_是数字(字符串取字符码(文本, i))) {
        结果 = 结果 * 10 + (字符串取字符码(文本, i) - 0x30)
        i = i + 1
    }
    返回 结果 * 符号
}

函数 字符串转16进制整数(文本) {
    定义 长度 = 字符串长度(文本)
    定义 可变 i = 0
    当 (i < 长度 && 字符_是空白(字符串取字符码(文本, i))) { i = i + 1 }
    如果 (i + 1 < 长度 && 字符串取字符码(文本, i) == 0x30) {
        定义 下一个 = 字符串取字符码(文本, i + 1)
        如果 (下一个 == 0x78 || 下一个 == 0x58) { i = i + 2 }
    }
    定义 可变 结果 = 0
    当 (i < 长度) {
        定义 c = 字符串取字符码(文本, i)
        如果 (c >= 0x30 && c <= 0x39) { 结果 = 结果 * 16 + (c - 0x30) }
        否则 如果 (c >= 0x41 && c <= 0x46) { 结果 = 结果 * 16 + (c - 0x41 + 10) }
        否则 如果 (c >= 0x61 && c <= 0x66) { 结果 = 结果 * 16 + (c - 0x61 + 10) }
        否则 { 跳出 }
        i = i + 1
    }
    返回 结果
}

函数 整数转字符串(数值) {
    如果 (数值 == 0) { 返回 "0" }
    定义 可变 负 = 假
    如果 (数值 < 0) { 负 = 真; 数值 = 0 - 数值 }
    定义 可变 buf = ""
    当 (数值 > 0) {
        buf = 字符串拼接(字符(0x30 + (数值 % 10)), buf)
        数值 = 数值 / 10
    }
    如果 (负) { buf = 字符串拼接("-", buf) }
    返回 buf
}

函数 整数转16进制(数值) {
    如果 (数值 == 0) { 返回 "0x0" }
    定义 十六进制字符 = "0123456789abcdef"
    定义 可变 buf = ""
    定义 可变 v = 数值
    当 (v > 0) {
        buf = 字符串拼接(字符串子串(十六进制字符, v & 0xF, (v & 0xF) + 1), buf)
        v = v >> 4
    }
    返回 字符串拼接("0x", buf)
}

函数 字符串_追加(原始, 追加内容) {
    返回 字符串拼接(原始, 追加内容)
}

函数 字符串_是空(文本) {
    返回 文本 == 空 || 字符串长度(文本) == 0
}

函数 字符串_是空白(文本) {
    如果 (字符串_是空(文本)) { 返回 真 }
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        如果 (!字符_是空白(字符串取字符码(文本, i))) { 返回 假 }
        i = i + 1
    }
    返回 真
}

// KMP 高效字符串搜索算法

函数 _KMP_构建失败表(模式) {
    定义 模式长 = 字符串长度(模式)
    定义 失败表 = [0]
    定义 可变 前缀长 = 0
    定义 可变 i = 1
    当 (i < 模式长) {
        如果 (字符串取字符码(模式, i) == 字符串取字符码(模式, 前缀长)) {
            前缀长 = 前缀长 + 1
            追加(失败表, 前缀长)
            i = i + 1
        } 否则 {
            如果 (前缀长 != 0) {
                前缀长 = 失败表[前缀长 - 1]
            } 否则 {
                追加(失败表, 0)
                i = i + 1
            }
        }
    }
    返回 失败表
}

函数 字符串_KMP查找(文本, 模式) {
    定义 文本长 = 字符串长度(文本)
    定义 模式长 = 字符串长度(模式)
    如果 (模式长 == 0) { 返回 0 }
    如果 (文本长 < 模式长) { 返回 -1 }
    定义 失败表 = _KMP_构建失败表(模式)
    定义 可变 ti = 0
    定义 可变 pi = 0
    当 (ti < 文本长) {
        如果 (字符串取字符码(文本, ti) == 字符串取字符码(模式, pi)) {
            ti = ti + 1
            pi = pi + 1
        }
        如果 (pi == 模式长) {
            返回 ti - pi
        } 否则 如果 (ti < 文本长 && 字符串取字符码(文本, ti) != 字符串取字符码(模式, pi)) {
            如果 (pi != 0) {
                pi = 失败表[pi - 1]
            } 否则 {
                ti = ti + 1
            }
        }
    }
    返回 -1
}

函数 字符串_KMP查找全部(文本, 模式) {
    定义 结果 = []
    定义 文本长 = 字符串长度(文本)
    定义 模式长 = 字符串长度(模式)
    如果 (模式长 == 0 || 文本长 < 模式长) { 返回 结果 }
    定义 失败表 = _KMP_构建失败表(模式)
    定义 可变 ti = 0
    定义 可变 pi = 0
    当 (ti < 文本长) {
        如果 (字符串取字符码(文本, ti) == 字符串取字符码(模式, pi)) {
            ti = ti + 1
            pi = pi + 1
        }
        如果 (pi == 模式长) {
            追加(结果, ti - pi)
            pi = 失败表[pi - 1]
        } 否则 如果 (ti < 文本长 && 字符串取字符码(文本, ti) != 字符串取字符码(模式, pi)) {
            如果 (pi != 0) {
                pi = 失败表[pi - 1]
            } 否则 {
                ti = ti + 1
            }
        }
    }
    返回 结果
}

// 字符串模板引擎

函数 字符串_模板替换(模板, 键列表, 值列表) {
    定义 可变 结果 = 模板
    定义 数量 = 计数(键列表)
    定义 可变 i = 0
    当 (i < 数量) {
        定义 占位符 = 字符串拼接("${", 字符串拼接(键列表[i], "}"))
        结果 = 字符串替换(结果, 占位符, 值列表[i])
        i = i + 1
    }
    返回 结果
}

函数 字符串_格式化(模板, 参数列表) {
    定义 构建器 = 字符串构建器_创建()
    定义 长度 = 字符串长度(模板)
    定义 可变 i = 0
    定义 可变 参数索引 = 0
    当 (i < 长度) {
        如果 (i + 1 < 长度 && 字符串取字符码(模板, i) == 0x7B && 字符串取字符码(模板, i + 1) == 0x7D) {
            如果 (参数索引 < 计数(参数列表)) {
                字符串构建器_追加(构建器, 参数列表[参数索引])
                参数索引 = 参数索引 + 1
            }
            i = i + 2
        } 否则 {
            字符串构建器_追加字符(构建器, 字符串取字符码(模板, i))
            i = i + 1
        }
    }
    返回 字符串构建器_构建(构建器)
}

// Levenshtein 编辑距离

函数 字符串_编辑距离(甲, 乙) {
    定义 甲长 = 字符串长度(甲)
    定义 乙长 = 字符串长度(乙)
    如果 (甲长 == 0) { 返回 乙长 }
    如果 (乙长 == 0) { 返回 甲长 }
    // 滚动双行数组优化空间 O(min(m,n))
    定义 前行 = []
    定义 当前行 = []
    定义 可变 j = 0
    当 (j <= 乙长) {
        追加(前行, j)
        追加(当前行, 0)
        j = j + 1
    }
    定义 可变 i = 1
    当 (i <= 甲长) {
        当前行[0] = i
        j = 1
        当 (j <= 乙长) {
            定义 可变 代价 = 0
            如果 (字符串取字符码(甲, i - 1) != 字符串取字符码(乙, j - 1)) { 代价 = 1 }
            定义 删除 = 前行[j] + 1
            定义 插入 = 当前行[j - 1] + 1
            定义 替换 = 前行[j - 1] + 代价
            定义 可变 最小 = 删除
            如果 (插入 < 最小) { 最小 = 插入 }
            如果 (替换 < 最小) { 最小 = 替换 }
            当前行[j] = 最小
            j = j + 1
        }
        j = 0
        当 (j <= 乙长) { 前行[j] = 当前行[j]; j = j + 1 }
        i = i + 1
    }
    返回 前行[乙长]
}

函数 字符串_相似度(甲, 乙) {
    // 返回 ×1000 定点数 (1000 = 完全相同)
    定义 甲长 = 字符串长度(甲)
    定义 乙长 = 字符串长度(乙)
    如果 (甲长 == 0 && 乙长 == 0) { 返回 1000 }
    定义 可变 最大长 = 甲长
    如果 (乙长 > 最大长) { 最大长 = 乙长 }
    定义 距离 = 字符串_编辑距离(甲, 乙)
    返回 ((最大长 - 距离) * 1000) / 最大长
}

// Base64 编解码

定义 _BASE64_编码表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

函数 _Base64_字符索引(c) {
    如果 (c >= 0x41 && c <= 0x5A) { 返回 c - 0x41 }
    如果 (c >= 0x61 && c <= 0x7A) { 返回 c - 0x61 + 26 }
    如果 (c >= 0x30 && c <= 0x39) { 返回 c - 0x30 + 52 }
    如果 (c == 0x2B) { 返回 62 }
    如果 (c == 0x2F) { 返回 63 }
    返回 -1
}

函数 字符串_Base64编码(数据) {
    定义 长度 = 字符串长度(数据)
    定义 构建器 = 字符串构建器_创建()
    定义 可变 i = 0
    当 (i < 长度) {
        定义 b0 = 字符串取字符码(数据, i)
        定义 可变 b1 = 0
        定义 可变 b2 = 0
        定义 可变 填充 = 0
        如果 (i + 1 < 长度) { b1 = 字符串取字符码(数据, i + 1) } 否则 { 填充 = 填充 + 1 }
        如果 (i + 2 < 长度) { b2 = 字符串取字符码(数据, i + 2) } 否则 { 填充 = 填充 + 1 }
        定义 索引0 = (b0 >> 2) & 0x3F
        定义 索引1 = ((b0 & 0x03) << 4) | ((b1 >> 4) & 0x0F)
        定义 索引2 = ((b1 & 0x0F) << 2) | ((b2 >> 6) & 0x03)
        定义 索引3 = b2 & 0x3F
        字符串构建器_追加(构建器, 字符串子串(_BASE64_编码表, 索引0, 索引0 + 1))
        字符串构建器_追加(构建器, 字符串子串(_BASE64_编码表, 索引1, 索引1 + 1))
        如果 (填充 < 2) {
            字符串构建器_追加(构建器, 字符串子串(_BASE64_编码表, 索引2, 索引2 + 1))
        } 否则 {
            字符串构建器_追加(构建器, "=")
        }
        如果 (填充 < 1) {
            字符串构建器_追加(构建器, 字符串子串(_BASE64_编码表, 索引3, 索引3 + 1))
        } 否则 {
            字符串构建器_追加(构建器, "=")
        }
        i = i + 3
    }
    返回 字符串构建器_构建(构建器)
}

函数 字符串_Base64解码(编码文本) {
    定义 长度 = 字符串长度(编码文本)
    定义 构建器 = 字符串构建器_创建()
    定义 可变 i = 0
    当 (i + 3 < 长度) {
        定义 c0 = _Base64_字符索引(字符串取字符码(编码文本, i))
        定义 c1 = _Base64_字符索引(字符串取字符码(编码文本, i + 1))
        定义 c2 = _Base64_字符索引(字符串取字符码(编码文本, i + 2))
        定义 c3 = _Base64_字符索引(字符串取字符码(编码文本, i + 3))
        如果 (c0 < 0 || c1 < 0) { 跳出 }
        字符串构建器_追加字符(构建器, (c0 << 2) | ((c1 >> 4) & 0x03))
        如果 (c2 >= 0) {
            字符串构建器_追加字符(构建器, ((c1 & 0x0F) << 4) | ((c2 >> 2) & 0x0F))
        }
        如果 (c3 >= 0) {
            字符串构建器_追加字符(构建器, ((c2 & 0x03) << 6) | c3)
        }
        i = i + 4
    }
    返回 字符串构建器_构建(构建器)
}

// 字符串池 (驻留机制)

函数 字符串池_创建(容量) {
    定义 池 = []
    定义 可变 i = 0
    当 (i < 容量) { 追加(池, 空); i = i + 1 }
    返回 [池, 容量, 0, 0]
}

函数 _字符串池_哈希(文本, 容量) {
    定义 长度 = 字符串长度(文本)
    定义 可变 h = 5381
    定义 可变 i = 0
    当 (i < 长度) {
        h = ((h << 5) + h) + 字符串取字符码(文本, i)
        i = i + 1
    }
    如果 (h < 0) { h = 0 - h }
    返回 h % 容量
}

函数 字符串池_驻留(池, 文本) {
    定义 索引 = _字符串池_哈希(文本, 池[1])
    定义 可变 探测 = 索引
    当 (池[0][探测] != 空) {
        如果 (池[0][探测] == 文本) {
            池[3] = 池[3] + 1
            返回 池[0][探测]
        }
        探测 = (探测 + 1) % 池[1]
        如果 (探测 == 索引) { 返回 文本 }
    }
    池[0][探测] = 文本
    池[2] = 池[2] + 1
    返回 文本
}

函数 字符串池_查找(池, 文本) {
    定义 索引 = _字符串池_哈希(文本, 池[1])
    定义 可变 探测 = 索引
    当 (池[0][探测] != 空) {
        如果 (池[0][探测] == 文本) { 返回 真 }
        探测 = (探测 + 1) % 池[1]
        如果 (探测 == 索引) { 返回 假 }
    }
    返回 假
}

函数 字符串池_统计(池) {
    返回 [池[2], 池[1], 池[3]]
}

// 【原生独创】字符串谐振搜索 — 频谱模糊匹配引擎
//  基于字符频谱共振理论: 将字符串映射为频率向量,
//  通过余弦相似度实现 O(n) 模糊匹配

函数 _字符串_频谱向量(文本) {
    定义 向量 = []
    定义 可变 k = 0
    当 (k < 128) { 追加(向量, 0); k = k + 1 }
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 c = 字符串取字符码(文本, i)
        如果 (c < 128) { 向量[c] = 向量[c] + 1000 }
        i = i + 1
    }
    返回 向量
}

函数 _定点平方根(值) {
    如果 (值 <= 0) { 返回 0 }
    定义 可变 根 = 值 / 2
    定义 可变 迭代 = 0
    当 (迭代 < 12 && 根 > 0) {
        根 = (根 + (值 * 1000) / 根) / 2
        迭代 = 迭代 + 1
    }
    返回 根
}

函数 字符串_谐振匹配度(文本, 模式) {
    // 返回 ×1000 定点余弦相似度
    定义 甲 = _字符串_频谱向量(文本)
    定义 乙 = _字符串_频谱向量(模式)
    定义 可变 点积 = 0
    定义 可变 模A = 0
    定义 可变 模B = 0
    定义 可变 i = 0
    当 (i < 128) {
        点积 = 点积 + (甲[i] * 乙[i]) / 1000
        模A = 模A + (甲[i] * 甲[i]) / 1000
        模B = 模B + (乙[i] * 乙[i]) / 1000
        i = i + 1
    }
    定义 根A = _定点平方根(模A)
    定义 根B = _定点平方根(模B)
    如果 (根A == 0 || 根B == 0) { 返回 0 }
    返回 (点积 * 1000) / ((根A * 根B) / 1000)
}

函数 字符串_谐振匹配(文本, 模式, 阈值) {
    返回 字符串_谐振匹配度(文本, 模式) >= 阈值
}

// 高级文本处理工具

函数 字符串_是全数字(文本) {
    如果 (字符串长度(文本) == 0) { 返回 假 }
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        如果 (!字符_是数字(字符串取字符码(文本, i))) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 字符串_是全字母(文本) {
    如果 (字符串长度(文本) == 0) { 返回 假 }
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        如果 (!字符_是字母(字符串取字符码(文本, i))) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 字符串_是字母数字(文本) {
    如果 (字符串长度(文本) == 0) { 返回 假 }
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 c = 字符串取字符码(文本, i)
        如果 (!字符_是字母(c) && !字符_是数字(c)) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 字符串_截断(文本, 最大长度, 省略号) {
    如果 (字符串长度(文本) <= 最大长度) { 返回 文本 }
    定义 省略长 = 字符串长度(省略号)
    如果 (最大长度 <= 省略长) { 返回 字符串子串(文本, 0, 最大长度) }
    返回 字符串拼接(字符串子串(文本, 0, 最大长度 - 省略长), 省略号)
}

函数 字符串_单词计数(文本) {
    定义 长度 = 字符串长度(文本)
    如果 (长度 == 0) { 返回 0 }
    定义 可变 词数 = 0
    定义 可变 在词中 = 假
    定义 可变 i = 0
    当 (i < 长度) {
        如果 (字符_是空白(字符串取字符码(文本, i))) {
            如果 (在词中) { 词数 = 词数 + 1; 在词中 = 假 }
        } 否则 {
            在词中 = 真
        }
        i = i + 1
    }
    如果 (在词中) { 词数 = 词数 + 1 }
    返回 词数
}

函数 字符串_行分割(文本) {
    返回 字符串分割(文本, "\n")
}

函数 字符串_蛇形转驼峰(文本) {
    定义 部分 = 字符串分割(文本, "_")
    如果 (计数(部分) == 0) { 返回 文本 }
    定义 构建器 = 字符串构建器_创建()
    字符串构建器_追加(构建器, 部分[0])
    定义 可变 i = 1
    当 (i < 计数(部分)) {
        字符串构建器_追加(构建器, 字符串首字母大写(部分[i]))
        i = i + 1
    }
    返回 字符串构建器_构建(构建器)
}

函数 字符串_驼峰转蛇形(文本) {
    定义 长度 = 字符串长度(文本)
    定义 构建器 = 字符串构建器_创建()
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 字符串取字符码(文本, i)
        如果 (字符_是大写(c) && i > 0) {
            字符串构建器_追加(构建器, "_")
            字符串构建器_追加字符(构建器, c + 32)
        } 否则 {
            字符串构建器_追加字符(构建器, c)
        }
        i = i + 1
    }
    返回 字符串构建器_构建(构建器)
}

// 完整统计

函数 字符串_完整统计() {
    返回 [
        "模块", "原生字符串",
        "构建器函数", 7,
        "分割连接函数", 3,
        "空白处理函数", 4,
        "查找匹配函数", 6,
        "替换格式函数", 4,
        "大小写函数", 4,
        "填充对齐函数", 3,
        "字符判断函数", 6,
        "转换函数", 5,
        "KMP搜索函数", 3,
        "模板引擎函数", 2,
        "编辑距离函数", 2,
        "Base64函数", 3,
        "字符串池函数", 4,
        "谐振搜索函数", 3,
        "文本工具函数", 7,
        "总函数数", 66
    ]
}

定义 可变 AI字串_编码检测数 = 0

函数 AI字串_最优编码(文本) {
    AI字串_编码检测数 = AI字串_编码检测数 + 1
    定义 长度 = 字符串长度(文本)
    如果 (长度 == 0) { 返回 "空" }
    // 检测是否全ASCII(单字节更快)
    定义 可变 i = 0
    当 (i < 长度 && i < 100) {
        如果 (字符串字符(文本, i) > 127) { 返回 "UTF-8" }
        i = i + 1
    }
    返回 "ASCII"
}

函数 AI字串_拼接策略(段数, 总长度估计) {
    如果 (段数 > 10) { 返回 "StringBuilder" }
    返回 "直接拼接"
}

// Nova AI原生 CSS引擎: 样式Engine — 智能样式总控
// 【创新突破】传统方案: 每次DOM变化都全量重算样式,不区分影响范围
//   Nova 样式Engine = NovaOS核心引擎 + 以下AI原生能力:
//   ① 样式重算范围最小化 — AI判断只重算受影响的节点
//   ② 规则匹配缓存 — 缓存选择器匹配结果,避免重复匹配
//   ③ 样式计算批量化 — 收集多个脏节点一次性重算
//   ④ 样式性能分析 — 跟踪慢规则,建议优化

// 样式Engine结构 

结构 样式Engine {
 UA样式表,    // u64 浏览器默认样式表(html.css)
 作者样式表列表,    // u64 CSS样式表*数组 (页面<style>和<link>)
 作者样式表数量,
 作者样式表容量,
 文档,    // u64 Document*

 // 按标签名/class/id预索引规则(加速选择器匹配)
 标签规则索引,    // u64 哈希表: 标签原子 → 规则列表
 class规则索引,
 id规则索引,
 通用规则,    // u64 无法索引的规则(如 * / 组合选择器)
 通用规则数量,
 样式表已变,
 需要全量重计算,
 总样式计算次数,
 总规则匹配次数,
}

结构 索引规则项 {
 键原子,    // u32 标签/class/id原子
 规则,    // u64 CSS样式规则*
 特异度,
}

// §1 创建/初始化

函数 样式Engine_创建(文档) {
 定义 engine = 堆_分配(样式Engine)
 engine.文档 = 文档
 engine.UA样式表 = 0
 engine.作者样式表容量 = 16
 engine.作者样式表列表 = 堆_分配_数组(engine.作者样式表容量 * 8)
 engine.作者样式表数量 = 0

 engine.标签规则索引 = 堆_分配_数组(256 * 16) // 简单哈希表
 engine.class规则索引 = 堆_分配_数组(256 * 16)
 engine.id规则索引 = 堆_分配_数组(256 * 16)
 engine.通用规则 = 堆_分配_数组(64 * 8)
 engine.通用规则数量 = 0

 engine.样式表已变 = 假
 engine.需要全量重计算 = 假
 engine.总样式计算次数 = 0
 engine.总规则匹配次数 = 0

 返回 engine
}

// §2 添加样式表 (<style>标签或<link>加载的CSS)

函数 样式Engine_添加样式表(engine, css文本) {
 // 解析CSS → 样式Sheet
 定义 样式表 = CSSParser_解析样式表(css文本)
 如果 (样式表 == 0) { 返回 }

 // 添加到列表
 如果 (engine.作者样式表数量 >= engine.作者样式表容量) {
 定义 新容量 = engine.作者样式表容量 * 2
 定义 新列表 = 堆_分配_数组(新容量 * 8)
 内存_复制(新列表, engine.作者样式表列表, engine.作者样式表数量 * 8)
 堆_释放(engine.作者样式表列表)
 engine.作者样式表列表 = 新列表
 engine.作者样式表容量 = 新容量
 }
 内存_写64(engine.作者样式表列表 + engine.作者样式表数量 * 8, 样式表)
 engine.作者样式表数量 = engine.作者样式表数量 + 1

 // 索引规则(加速匹配)
 样式Engine_索引样式表(engine, 样式表)

 engine.样式表已变 = 真
 engine.需要全量重计算 = 真
}

函数 样式Engine_索引样式表(engine, 样式表) {
 // 将样式表中的每条规则按选择器类型索引
 定义 可变 i = 0
 当 (i < 样式表.规则数量) {
 定义 规则 = 内存_读64(样式表.规则列表 + i * 8)
 如果 (规则 != 0) {
 定义 选择器 = 规则.选择器列表
 如果 (选择器 != 0) {
 // 找最右边的简单选择器(key selector)
 定义 可变 末尾 = 选择器
 当 (末尾.下一个 != 0) { 末尾 = 末尾.下一个 }

 如果 (末尾.类型 == 选择器类型_id) {
 // 按ID索引
 样式Engine_添加到索引(engine.id规则索引, 末尾.值原子, 规则, 规则.特异度)
 }
 否则 如果 (末尾.类型 == 选择器类型_class) {
 样式Engine_添加到索引(engine.class规则索引, 末尾.值原子, 规则, 规则.特异度)
 }
 否则 如果 (末尾.类型 == 选择器类型_标签) {
 样式Engine_添加到索引(engine.标签规则索引, 末尾.值原子, 规则, 规则.特异度)
 }
 否则 {
 // 通用规则
 如果 (engine.通用规则数量 < 64) {
 内存_写64(engine.通用规则 + engine.通用规则数量 * 8, 规则)
 engine.通用规则数量 = engine.通用规则数量 + 1
 }
 }
 }
 }
 i = i + 1
 }
}

函数 样式Engine_添加到索引(索引表, 键原子, 规则, 特异度) {
 // 简单哈希表: 按键原子的低8位做桶
 定义 桶 = 键原子 % 256
 定义 偏移 = 桶 * 16
 // 每个桶存: [规则指针, 特异度, 下一个桶内偏移, ...]
 // 直接覆盖优先级(后续可扩展为链表管理)
 内存_写64(索引表 + 偏移, 规则)
 内存_写32(索引表 + 偏移 + 8, 特异度)
}

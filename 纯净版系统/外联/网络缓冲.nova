导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/链表后继.nova")
导入("./网缓分配.nova")
导入("./网缓读.nova")
导入("../中枢/整数转字符串.nova")

// 本文件是Socket缓冲.nova(Nova网络缓冲底层)的高层封装
// 提供网络栈各层使用的便捷接口:
//   1. 缓冲池: 预分配常用大小的Nova缓冲, 避免频繁分配
//   2. 队列管理: Nova缓冲_queue_head/tail/dequeue (收发队列)
//   3. 分片管理: scatter-gather用于大包
//   4. 统计: 分配/释放/丢弃计数

结构 Nova缓冲队列 {
    头,    // u64 队列头Nova缓冲
    尾,    // u64 队列尾Nova缓冲
    长度,    // u32 队列中Nova缓冲数量
    锁,    // u32 自旋锁
}

定义 可变 小包池 = []      // <=128字节的Nova缓冲池
定义 可变 中包池 = []      // <=1514字节(MTU)的Nova缓冲池
定义 可变 大包池 = []      // <=9000字节(jumbo)的Nova缓冲池
定义 小包池_最大 = 64
定义 中包池_最大 = 32
定义 大包池_最大 = 8

定义 可变 Nova缓冲_分配总数 = 0
定义 可变 Nova缓冲_释放总数 = 0
定义 可变 Nova缓冲_池命中数 = 0
定义 可变 Nova缓冲_池未命中数 = 0
定义 可变 Nova缓冲_丢弃数 = 0

// 初始化

函数 网络缓冲_初始化() {
    小包池 = []
    中包池 = []
    大包池 = []
    // 预分配常用大小的Nova缓冲
    定义 可变 i = 0
    当 (i < 小包池_最大 / 2) {
        定义 Nova缓冲 = Nova缓冲_创建(128)
        如果 (Nova缓冲 != 空) { 追加(小包池, Nova缓冲) }
        i = i + 1
    }
    i = 0
    当 (i < 中包池_最大 / 2) {
        定义 Nova缓冲 = Nova缓冲_创建(1514)
        如果 (Nova缓冲 != 空) { 追加(中包池, Nova缓冲) }
        i = i + 1
    }
    内核信息("网络缓冲池: 小=" + 整数转字符串(计数(小包池)) +
             " 中=" + 整数转字符串(计数(中包池)))
}

// 分配/释放 (带缓冲池)

函数 网络缓冲_分配(大小) {
    Nova缓冲_分配总数 = Nova缓冲_分配总数 + 1

    // 尝试从缓冲池获取
    如果 (大小 <= 128 && 计数(小包池) > 0) {
        Nova缓冲_池命中数 = Nova缓冲_池命中数 + 1
        定义 Nova缓冲 = 小包池[计数(小包池) - 1]
        链表_删除(小包池, 计数(小包池) - 1)
        返回 Nova缓冲
    }
    如果 (大小 <= 1514 && 计数(中包池) > 0) {
        Nova缓冲_池命中数 = Nova缓冲_池命中数 + 1
        定义 Nova缓冲 = 中包池[计数(中包池) - 1]
        链表_删除(中包池, 计数(中包池) - 1)
        返回 Nova缓冲
    }
    如果 (大小 <= 9000 && 计数(大包池) > 0) {
        Nova缓冲_池命中数 = Nova缓冲_池命中数 + 1
        定义 Nova缓冲 = 大包池[计数(大包池) - 1]
        链表_删除(大包池, 计数(大包池) - 1)
        返回 Nova缓冲
    }

    // 缓冲池空, 直接分配
    Nova缓冲_池未命中数 = Nova缓冲_池未命中数 + 1
    返回 Nova缓冲_创建(大小)
}

函数 网络缓冲_释放(Nova缓冲) {
    如果 (Nova缓冲 == 空) { 返回 }
    Nova缓冲_释放总数 = Nova缓冲_释放总数 + 1

    // 尝试归还到缓冲池
    定义 长度 = Nova缓冲_长度(Nova缓冲)
    如果 (长度 <= 128 && 计数(小包池) < 小包池_最大) {
        追加(小包池, Nova缓冲)
        返回
    }
    如果 (长度 <= 1514 && 计数(中包池) < 中包池_最大) {
        追加(中包池, Nova缓冲)
        返回
    }
    如果 (长度 <= 9000 && 计数(大包池) < 大包池_最大) {
        追加(大包池, Nova缓冲)
        返回
    }

    // 缓冲池满, 真正释放
    Nova缓冲_释放(Nova缓冲)
}

函数 网络缓冲_克隆(Nova缓冲) {
    如果 (Nova缓冲 == 空) { 返回 空 }
    返回 Nova缓冲_克隆(Nova缓冲)
}

// Nova缓冲队列操作 

函数 Nova缓冲队列_创建() {
    定义 q = Nova缓冲队列 {}
    q.头 = 空
    q.尾 = 空
    q.长度 = 0
    q.锁 = 0
    返回 q
}

函数 Nova缓冲队列_入队尾(q, Nova缓冲) {
    如果 (q.尾 == 空) {
        q.头 = Nova缓冲
        q.尾 = Nova缓冲
    } 否则 {
        // 链接到尾部
        q.尾 = Nova缓冲
    }
    q.长度 = q.长度 + 1
}

函数 Nova缓冲队列_出队头(q) {
    如果 (q.头 == 空) { 返回 空 }
    定义 Nova缓冲 = q.头
    // q.头 = Nova缓冲.next
    q.长度 = q.长度 - 1
    如果 (q.长度 == 0) {
        q.头 = 空
        q.尾 = 空
    }
    返回 Nova缓冲
}

函数 Nova缓冲队列_长度(q) { 返回 q.长度 }
函数 Nova缓冲队列_为空(q) { 返回 q.长度 == 0 }

函数 Nova缓冲队列_清空(q) {
    当 (!Nova缓冲队列_为空(q)) {
        定义 Nova缓冲 = Nova缓冲队列_出队头(q)
        网络缓冲_释放(Nova缓冲)
    }
}

// 便捷操作

函数 网络缓冲_预留头部(Nova缓冲, 长度) {
    Nova缓冲_reserve(Nova缓冲, 长度)
}

函数 网络缓冲_拉取(Nova缓冲, 长度) {
    Nova缓冲_pull(Nova缓冲, 长度)
}

函数 网络缓冲_丢弃(Nova缓冲) {
    Nova缓冲_丢弃数 = Nova缓冲_丢弃数 + 1
    网络缓冲_释放(Nova缓冲)
}

函数 网络缓冲_统计() {
    返回 [Nova缓冲_分配总数, Nova缓冲_释放总数, Nova缓冲_池命中数, Nova缓冲_池未命中数, Nova缓冲_丢弃数]
}

// 池命中率 + 池大小名 + 完整统计

函数 网络缓冲_池命中率() {
    定义 总 = Nova缓冲_池命中数 + Nova缓冲_池未命中数
    如果 (总 == 0) { 返回 100 }
    返回 Nova缓冲_池命中数 * 100 / 总
}

函数 网络缓冲_池大小名(大小) {
    如果 (大小 <= 128) { 返回 "small" }
    如果 (大小 <= 1514) { 返回 "medium" }
    如果 (大小 <= 9000) { 返回 "jumbo" }
    返回 "oversized"
}

函数 网络缓冲_完整统计() {
    返回 [Nova缓冲_分配总数, Nova缓冲_释放总数, Nova缓冲_池命中数, Nova缓冲_池未命中数,
           Nova缓冲_丢弃数, 网络缓冲_池命中率()]
}

函数 网络缓冲_健康评估() {
    定义 可变 问题 = []
    如果 (计数(小包池) > 10000) { 追加(问题, "小包池膨胀") }
    如果 (计数(中包池) > 10000) { 追加(问题, "中包池膨胀") }
    如果 (计数(大包池) > 10000) { 追加(问题, "大包池膨胀") }
    如果 (Nova缓冲_分配总数 > 100000) { 追加(问题, "Nova缓冲_分配总数异常增长") }
    如果 (Nova缓冲_释放总数 > 100000) { 追加(问题, "Nova缓冲_释放总数异常增长") }
    返回 计数(问题) == 0
}

函数 网络缓冲_综合报告() {
    打印("[网络缓冲] ═══ 综合报告 ═══")
    打印("  Nova缓冲_分配总数: " + Nova缓冲_分配总数)
    打印("  Nova缓冲_释放总数: " + Nova缓冲_释放总数)
    打印("  健康: " + 如果 (网络缓冲_健康评估()) { "正常" } 否则 { "异常" })
}

函数 网络缓冲_全局重置() {
    Nova缓冲_分配总数 = 0
    Nova缓冲_释放总数 = 0
    打印("[网络缓冲] 统计已重置")
    返回 0
}

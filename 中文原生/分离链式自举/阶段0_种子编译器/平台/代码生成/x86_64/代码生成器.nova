// Nova · 平台层 · x86-64 代码生成器
// AST→x86-64机器码 — 表达式/语句/函数编译
// 跨模块全局变量在409模块编译中为UNDEF,强制初始化为Linux目标
导入("../../../系统扩展/P0-裸机/内联汇编编译.nova")
导入("../../../编译器/标记常量.nova")
导入("../../../系统扩展/P0-裸机/原子操作编码.nova")
导入("../../../系统扩展/P0-裸机/无GC运行时.nova")
导入("../../../系统扩展/P0-裸机/易变访问.nova")
导入("../../../系统扩展/P0-裸机/特权指令编码.nova")
导入("../../../系统扩展/P0-裸机/链接脚本支持.nova")
导入("../../../系统扩展/P0-裸机/紧凑结构体.nova")
导入("x86编码器.nova")
导入("../../../标准库/基础.nova")
导入("../../../标准库/系统/平台/平台.nova")
导入("../../../IR/优化器/优化管线.nova")
导入("../../../编译器/前端入口.nova")
导入("../../../编译器/规划/核心/发射器.nova")
导入("../../../编译器/规划/核心/常量.nova")
导入("../../../运行时/字典引擎/字典引擎.nova")
定义 可变 代码生成器_目标ELF = 1
定义 可变 当前编译模块名 = ""
定义 可变 闭包表 = 字典()
定义 可变 当前函数列 = 空
定义 可变 当前函数名表 = 字典()
定义 可变 _尾调用模式 = 0

// 行号映射 (DWARF前置)
// 记录 代码偏移→源码行号 的映射，供后续 .debug_line 生成
定义 可变 _行号映射表 = []
定义 可变 _编译源文件名 = ""
函数 _记录行号(行号) {
    如果 (行号 > 0) { 追加(_行号映射表, [代码位, 行号]) }
}

函数 _取节点行号(n) {
    如果 (n == 空) { 返回 0 }
    定义 长度 = 计数(n)
    如果 (长度 < 2) { 返回 0 }
    定义 t = n[0]
    如果 (t == 标记_定义 且 长度 >= 5) { 返回 n[4] }
    如果 (t == 标记_可变 且 长度 >= 4) { 返回 n[3] }
    如果 (t == 标记_函数 且 长度 >= 5) { 返回 n[4] }
    如果 (t == 标记_返回 且 长度 >= 4) { 返回 n[3] }
    如果 (t == 标记_如果 且 长度 >= 3) { 返回 n[2] }
    如果 (t == 标记_否则 且 长度 >= 3) { 返回 n[2] }
    如果 (t == 标记_当 且 长度 >= 5) { 返回 n[4] }
    如果 (t == 标记_建 且 长度 >= 5) { 返回 n[4] }
    如果 (t == 标记_顺序词 且 长度 >= 5) { 返回 n[4] }
    如果 (t == 标记_关键135 且 长度 >= 4) { 返回 n[3] }
    如果 (t == 标记_关键136 且 长度 >= 2) { 返回 n[1] }
    如果 (t == 标记_关键137 且 长度 >= 2) { 返回 n[1] }
    如果 (t == 节点_变量声明 且 长度 >= 5) { 返回 n[4] }
    如果 (t == 节点_赋值语句 且 长度 >= 3) { 返回 n[2] }
    返回 0
}

函数 编译_行号映射表() { 返回 _行号映射表 }
函数 编译_重置行号映射() { _行号映射表 = [] }
函数 编译_设置源文件名(名) { _编译源文件名 = 名 }

函数 编译_设置当前模块名(名称) {
    当前编译模块名 = 名称
}

函数 编译_设置目标ELF(值) {
    代码生成器_目标ELF = 值
}

函数 编译_当前函数列() {
    返回 当前函数列
}

函数 编译_当前模块是(名称) {
    如果 (当前编译模块名 == 空 或 名称 == 空) { 返回 假 }
    返回 编译_字符串安全相等(当前编译模块名, 名称)
}

函数 查字段偏移(类型名, 字段名) {
    定义 可变 字段列 = 字典取(结构体表, 类型名)
    如果 (字段列 == 0 或 字段列 == 空) { 返回 0 - 1 }
    定义 可变 i = 0
    当 (i < 计数(字段列)) {
        如果 (编译_字符串安全相等(字段列[i], 字段名)) { 返回 i }
        i = i + 1
    }
    返回 0 - 1
}

函数 _字符串比较(a, b) {
    定义 la = 字节长度(a)
    定义 lb = 字节长度(b)
    定义 可变 最小 = la
    如果 (lb < 最小) { 最小 = lb }
    定义 可变 i = 0
    当 (i < 最小) {
        如果 (字节取(a, i) < 字节取(b, i)) { 返回 真 }
        如果 (字节取(a, i) > 字节取(b, i)) { 返回 假 }
        i = i + 1
    }
    返回 la < lb
}

函数 编译_是列表值(v) { 如果 (是列表(v)) { 返回 真 } 返回 假 }
函数 编译_是字符串值(v) { 如果 (是字符串(v)) { 返回 真 } 返回 假 }

函数 编译_字符串安全相等(a, b) {
    如果 (a == 空 或 b == 空) { 返回 假 }
    返回 字符串相等(a, b)
}

// 操作符整数常量 (直接内联, 避免全局变量初始化时序依赖)
// 加=1 减=2 乘=3 除=4 模=5 等等=6 不等=7 小于=8 大于=9
// 小等=10 大等=11 位与=12 位或=13 异或=14 左移=15 右移=16 且=17 或=18

函数 编译_规范化二元操作(op) {
    如果 (op == 空) { 返回 空 }
    如果 (op >= 1 且 op <= 18) { 返回 op }
    // 字符串操作符 (解析器 _标记转运算 产生的AST格式)
    如果 (编译_字符串安全相等(op, "+")) { 返回 1 }
    如果 (编译_字符串安全相等(op, "-")) { 返回 2 }
    如果 (编译_字符串安全相等(op, "*")) { 返回 3 }
    如果 (编译_字符串安全相等(op, "/")) { 返回 4 }
    如果 (编译_字符串安全相等(op, "%")) { 返回 5 }
    如果 (编译_字符串安全相等(op, "==")) { 返回 6 }
    如果 (编译_字符串安全相等(op, "!=")) { 返回 7 }
    如果 (编译_字符串安全相等(op, "<")) { 返回 8 }
    如果 (编译_字符串安全相等(op, ">")) { 返回 9 }
    如果 (编译_字符串安全相等(op, "<=")) { 返回 10 }
    如果 (编译_字符串安全相等(op, ">=")) { 返回 11 }
    如果 (编译_字符串安全相等(op, "&")) { 返回 12 }
    如果 (编译_字符串安全相等(op, "|")) { 返回 13 }
    如果 (编译_字符串安全相等(op, "^")) { 返回 14 }
    如果 (编译_字符串安全相等(op, "<<")) { 返回 15 }
    如果 (编译_字符串安全相等(op, ">>")) { 返回 16 }
    如果 (编译_字符串安全相等(op, "&&")) { 返回 17 }
    如果 (编译_字符串安全相等(op, "||")) { 返回 18 }
    // 整数 token ID (备用路径)
    如果 (op == 标记_加) { 返回 1 }
    如果 (op == 标记_减) { 返回 2 }
    如果 (op == 标记_乘) { 返回 3 }
    如果 (op == 标记_除) { 返回 4 }
    如果 (op == 标记_余) { 返回 5 }
    如果 (op == 标记_等等) { 返回 6 }
    如果 (op == 标记_不等) { 返回 7 }
    如果 (op == 标记_小于) { 返回 8 }
    如果 (op == 标记_大于) { 返回 9 }
    如果 (op == 标记_小等) { 返回 10 }
    如果 (op == 标记_大等) { 返回 11 }
    如果 (op == 标记_位与) { 返回 12 }
    如果 (op == 标记_位或) { 返回 13 }
    如果 (op == 标记_位异或) { 返回 14 }
    如果 (op == 标记_左移) { 返回 15 }
    如果 (op == 标记_右移) { 返回 16 }
    如果 (op == 标记_且 或 op == 标记_标识符) { 返回 17 }
    如果 (op == 标记_或 或 op == 21) { 返回 18 }
    返回 空
}

函数 编译_当前函数是(名称) {
    返回 编译_字符串安全相等(当前函数名, 名称)
}

函数 _查字段偏移_全局(字段名) {
    定义 所有键 = 字典键(结构体表)
    定义 可变 最佳名 = 空
    定义 可变 最佳idx = 0 - 1
    定义 可变 si = 0
    当 (si < 计数(所有键)) {
        定义 sn = 所有键[si]
        定义 sf = 字典取(结构体表, sn)
        定义 可变 fi = 0
        当 (fi < 计数(sf)) {
            如果 (编译_字符串安全相等(sf[fi], 字段名)) {
                如果 (最佳名 == 空 或 _字符串比较(sn, 最佳名)) {
                    最佳名 = sn
                    最佳idx = fi
                }
            }
            fi = fi + 1
        }
        si = si + 1
    }
    返回 最佳idx
}

函数 推断结构类型名(_expr) {
    如果 (_expr == 空) { 返回 空 }
    如果 (_expr[0] == 标记_抛出) { 返回 _expr[1] }
    如果 (_expr[0] == 标记_名称) {
        定义 可变 _vt = 字典取(变量类型表, _expr[1])
        如果 (_vt == 0 或 _vt == 空) { 返回 空 }
        如果 (_vt == "__转文本__" 或 _vt == "__转浮点__") { 返回 空 }
        返回 _vt
    }
    如果 (_expr[0] == 节点_索引) {
        定义 可变 _base = _expr[1]
        如果 (_base[0] == 标记_名称) {
            定义 可变 _容器名 = _base[1]
            如果 (_容器名 == "模块表") { 返回 "模块信息" }
            如果 (_容器名 == "契约注册表") { 返回 "模块契约" }
        }
    }
    返回 空
}

// 编译期类型推断: 节点是否产生浮点值
函数 是浮点节点(节点) {
    如果 (节点 == 空 或 编译_是列表值(节点) == 假 或 计数(节点) < 2) { 返回 假 }
    如果 (节点[0] == 节_浮点) { 返回 真 }
    如果 (节点[0] == 标记_名称) {
        定义 可变 vt = 字典取(变量类型表, 节点[1])
        如果 (vt == 0) { 返回 假 }
        如果 (vt == 空) { 返回 假 }
        如果 (vt == "__转浮点__") { 返回 真 }
        返回 假
    }
    如果 (节点[0] == 节点_调用) {
        如果 (编译_字符串安全相等(节点[1], "浮点")) { 返回 真 }
        返回 假
    }
    如果 (节点[0] == 节点_二元) {
        如果 (计数(节点) < 4) { 返回 假 }
        如果 (是浮点节点(节点[2])) { 返回 真 }
        如果 (是浮点节点(节点[3])) { 返回 真 }
    }
    返回 假
}

// 编译期类型推断: 节点是否产生字符串值
函数 是字符串节点(节点) {
    如果 (节点 == 空 或 编译_是列表值(节点) == 假 或 计数(节点) < 2) { 返回 假 }
    如果 (节点[0] == 标记_字串) { 返回 真 }
    如果 (节点[0] == 标记_名称) {
        定义 vt = 字典取(变量类型表, 节点[1])
        如果 (vt == 0) { 返回 假 }
        如果 (vt == 空) { 返回 假 }
        如果 (vt == "__转文本__") { 返回 真 }
        返回 假
    }
    如果 (节点[0] == 节点_调用) {
        定义 可变 n = 节点[1]
        如果 (编译_字符串安全相等(n, "转字符串")) { 返回 真 }
        如果 (编译_字符串安全相等(n, "字符串拼接")) { 返回 真 }
        如果 (编译_字符串安全相等(n, "子串")) { 返回 真 }
        如果 (编译_字符串安全相等(n, "替换")) { 返回 真 }
        如果 (编译_字符串安全相等(n, "字符")) { 返回 真 }
        如果 (编译_字符串安全相等(n, "读文件")) { 返回 真 }
        如果 (编译_字符串安全相等(n, "拼接")) { 返回 真 }
        如果 (编译_字符串安全相等(n, "大写化")) { 返回 真 }
        如果 (编译_字符串安全相等(n, "小写化")) { 返回 真 }
        返回 假
    }
    如果 (节点[0] == 节点_二元) {
        如果 (计数(节点) < 4) { 返回 假 }
        定义 _str_op = 编译_规范化二元操作(节点[1])
        如果 (_str_op == 1) {
            如果 (是字符串节点(节点[2])) { 返回 真 }
            如果 (是字符串节点(节点[3])) { 返回 真 }
        }
    }
    返回 假
}

函数 是简单(节点) {
    如果 (节点[0] == 标记_数字) { 返回 真 }
    如果 (节点[0] == 节点_空字面量) { 返回 真 }
    如果 (节点[0] == 标记_名称) { 返回 真 }
    如果 (节点[0] == 节_浮点) { 返回 真 }
    返回 假
}

函数 编译_发射_本地相等比较(op) {
    发射组([0x48, 0x39, 0xC8])
    如果 (op == 6) {
        发射组([0x0F, 0x94, 0xC0])
    } 否则 {
        发射组([0x0F, 0x95, 0xC0])
    }
    发射组([0x0F, 0xB6, 0xC0])
    返回 空
}

函数 发射_二元操作(op) {
    如果 (op == 1) { 发射_加() 返回 空 }
    如果 (op == 2) { 发射_减() 返回 空 }
    如果 (op == 3) { 发射_乘() 返回 空 }
    如果 (op == 4) {
        // div-by-zero guard: test rcx,rcx; jnz +6; xor eax,eax; xor edx,edx; jmp +5; cqo; idiv rcx
        发射组([0x48, 0x85, 0xC9]) 发射组([0x75, 0x06])
        发射组([0x31, 0xC0]) 发射组([0x31, 0xD2]) 发射组([0xEB, 0x05])
        发射组([0x48, 0x99]) 发射组([0x48, 0xF7, 0xF9])
        返回 空
    }
    如果 (op == 5) {
        发射组([0x48, 0x85, 0xC9]) 发射组([0x75, 0x06])
        发射组([0x31, 0xC0]) 发射组([0x31, 0xD2]) 发射组([0xEB, 0x05])
        发射组([0x48, 0x99]) 发射组([0x48, 0xF7, 0xF9])
        发射组([0x48, 0x89, 0xD0]) 返回 空
    }
    如果 (op == 8) { 发射组([0x48, 0x39, 0xC8]) 发射(0x0F) 发射(0x9C) 发射(0xC0) 发射组([0x0F, 0xB6, 0xC0]) 返回 空 }
    如果 (op == 9) { 发射组([0x48, 0x39, 0xC8]) 发射(0x0F) 发射(0x9F) 发射(0xC0) 发射组([0x0F, 0xB6, 0xC0]) 返回 空 }
    如果 (op == 10) { 发射组([0x48, 0x39, 0xC8]) 发射(0x0F) 发射(0x9E) 发射(0xC0) 发射组([0x0F, 0xB6, 0xC0]) 返回 空 }
    如果 (op == 11) { 发射组([0x48, 0x39, 0xC8]) 发射(0x0F) 发射(0x9D) 发射(0xC0) 发射组([0x0F, 0xB6, 0xC0]) 返回 空 }
    如果 (op == 6) {
        编译_发射_本地相等比较(op)
        返回 空
    }
    如果 (op == 7) {
        编译_发射_本地相等比较(op)
        返回 空
    }
    如果 (op == 12) { 发射组([0x48, 0x21, 0xC8]) 返回 空 }
    如果 (op == 13) { 发射组([0x48, 0x09, 0xC8]) 返回 空 }
    如果 (op == 14) { 发射组([0x48, 0x31, 0xC8]) 返回 空 }
    如果 (op == 15) { 发射组([0x48, 0xD3, 0xE0]) 返回 空 }
    如果 (op == 16) { 发射组([0x48, 0xD3, 0xF8]) 返回 空 }
    // 逻辑与: rcx=左, rax=右. 左为0则结析0, 否则结果为右
    如果 (op == 17) {
        发射组([0x48, 0x85, 0xC9])    // test rcx, rcx
        发射组([0x75, 0x02])          // jnz +2
        发射组([0x31, 0xC0])          // xor eax, eax
        返回 空
    }
    // 逻辑或: rcx=左, rax=右. 左非0则结果为左, 否则结果为右
    如果 (op == 18) {
        发射组([0x48, 0x85, 0xC9])    // test rcx, rcx
        发射组([0x74, 0x03])          // jz +3
        发射组([0x48, 0x89, 0xC8])    // mov rax, rcx
        返回 空
    }
    返回 空
}

函数 编译_发射_相等比较(op, 左, 右) {
    如果 (op != 6 且 op != 7) { 返回 0 }
    如果 (是浮点节点(左) 或 是浮点节点(右)) { 返回 0 }
    如果 (是字符串节点(左) 或 是字符串节点(右)) {
        编译_处理__字符串等于_([左, 右])
        如果 (op == 7) {
            发射组([0x48, 0x83, 0xF0, 0x01])
        }
        返回 1
    }
    如果 (是简单(左)) {
        编译_表达式(右)
        发射_mov_rcx_rax()
        编译_表达式(左)
    } 否则 {
        编译_表达式(左)
        发射(0x50)
        编译_表达式(右)
        发射_mov_rcx_rax()
        发射(0x58)
    }
    编译_发射_本地相等比较(op)
    返回 1
}

// 系统内建 (处理器名/总内存/可用内存/时间戳/延时) — 独立函数避免if-block溢出
函数 编译_系统内建(名, 参数) {
    如果 (名 == "处理器名") {
        修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_处理器品牌")
        发射(0xE8)
        发射32(0)
        返回 1
    }
    如果 (名 == "总内存") {
        修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_内存总量")
        发射(0xE8)
        发射32(0)
        返回 1
    }
    如果 (名 == "可用内存") {
        修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_内存可用")
        发射(0xE8)
        发射32(0)
        返回 1
    }
    如果 (名 == "时间戳") {
        修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_时间戳")
        发射(0xE8)
        发射32(0)
        返回 1
    }
    如果 (名 == "延时") {
        编译_表达式(参数[0])
        发射_mov_rcx_rax()
        修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_睡眠")
        发射(0xE8)
        发射32(0)
        返回 1
    }
    如果 (名 == "随机数") {
        // rdtsc低20位 (0-1048575) — 安全整数范围 (<0x400000 PE ImageBase阈值)
        发射组([0x0F, 0x31])              // rdtsc (EDX:EAX = timestamp counter)
        发射组([0x25, 0xFF, 0xFF, 0x0F, 0x00]) // and eax, 0xFFFFF
        返回 1
    }
    如果 (名 == "文件存在") {
        编译_表达式(参数[0])
        发射_mov_rcx_rax()
        修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_文件存在")
        发射(0xE8)
        发射32(0)
        返回 1
    }
    如果 (名 == "退出") {
        编译_表达式(参数[0])
        发射_mov_rcx_rax()
        修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_退出")
        发射(0xE8)
        发射32(0)
        返回 1
    }
    返回 0
}

函数 编译_当前是裸机目标() {
    如果 (代码生成器_目标ELF == 2) { 返回 1 }
    返回 0
}

函数 编译_内联汇编内建(名, 参数) {
    如果 (名 == "内联汇编_间接调用" 且 计数(参数) == 1) {
        编译_表达式(参数[0])
        发射组([0xFF, 0xD0])
        返回 1
    }
    如果 ((名 != "内联汇编" 且 名 != "内联汇编_返回值") 或 计数(参数) < 1) { 返回 0 }
    定义 模板节点 = 参数[0]
    如果 (是列表(模板节点) == 假 或 计数(模板节点) < 2 或 模板节点[0] != 101) { 返回 0 }
    定义 模板 = 模板节点[1]
    如果 (名 == "内联汇编" 且 模板 == "") { 返回 1 }
    如果 (名 == "内联汇编" 且 模板 == "outb %b0, %w1" 且 计数(参数) == 3) {
        编译_表达式(参数[2])
        发射(0x50)
        编译_表达式(参数[1])
        发射(0x5A)
        发射(0xEE)
        返回 1
    }
    如果 (名 == "内联汇编" 且 模板 == "outw %w0, %w1" 且 计数(参数) == 3) {
        编译_表达式(参数[2])
        发射(0x50)
        编译_表达式(参数[1])
        发射(0x5A)
        发射(0x66)
        发射(0xEF)
        返回 1
    }
    如果 (名 == "内联汇编" 且 模板 == "outl %0, %w1" 且 计数(参数) == 3) {
        编译_表达式(参数[2])
        发射(0x50)
        编译_表达式(参数[1])
        发射(0x5A)
        发射(0xEF)
        返回 1
    }
    如果 (名 == "内联汇编_返回值" 且 模板 == "inb %w1, %b0" 且 计数(参数) == 2) {
        编译_表达式(参数[1])
        发射组([0x66, 0x89, 0xC2])
        发射组([0x31, 0xC0])
        发射(0xEC)
        返回 1
    }
    如果 (名 == "内联汇编_返回值" 且 模板 == "inw %w1, %w0" 且 计数(参数) == 2) {
        编译_表达式(参数[1])
        发射组([0x66, 0x89, 0xC2])
        发射组([0x31, 0xC0])
        发射(0x66)
        发射(0xED)
        返回 1
    }
    如果 (名 == "内联汇编_返回值" 且 模板 == "inl %w1, %0" 且 计数(参数) == 2) {
        编译_表达式(参数[1])
        发射组([0x66, 0x89, 0xC2])
        发射组([0x31, 0xC0])
        发射(0xED)
        返回 1
    }
    如果 (名 == "内联汇编_返回值" 且 模板 == "rdtsc" 且 计数(参数) == 1) {
        发射组([0x0F, 0x31])
        发射组([0x48, 0xC1, 0xE2, 0x20])
        发射组([0x48, 0x09, 0xD0])
        返回 1
    }
    如果 (名 == "内联汇编_返回值" 且 模板 == "rdtscp" 且 计数(参数) == 1) {
        发射组([0x0F, 0x01, 0xF9])
        发射组([0x48, 0xC1, 0xE2, 0x20])
        发射组([0x48, 0x09, 0xD0])
        返回 1
    }
    如果 (计数(参数) == 1) {
        编译_汇编文本块([模板])
        返回 1
    }
    返回 0
}

函数 编译_裸机内建(名, 参数) {
    如果 (编译_当前是裸机目标() == 0) { 返回 0 }
    如果 (编译_链接操作(名, 参数)) { 返回 1 }
    如果 (编译_无GC操作(名, 参数)) { 返回 1 }
    如果 (编译_volatile操作(名, 参数)) { 返回 1 }
    如果 (编译_原子操作(名, 参数)) { 返回 1 }
    如果 (编译_特权指令(名, 参数)) { 特权_记录编码() 返回 1 }
    返回 0
}

// 内建前半 (计数/追加/子串/字节取/编码/字符/转字符串/缓冲区/缓冲写/缓冲读/插入/删除/
//          字符串拼接/拼接/整数/分割/范围/字符串等于/字典/字典设/字典取/字典有/字典键/字典值/
//          打印文本/读文件/参数/替换) — 避免if-block溢出

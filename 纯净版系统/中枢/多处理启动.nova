//   1. BSP (Bootstrap Processor): 引导CPU, 执行start_kernel
//   2. AP (Application Processor): 其他CPU, 由BSP逐个启动
//   3. 启动序列: INIT IPI → startup IPI → AP跳转到启动代码
//   4. AP启动后: 初始化per-CPU数据 → idle循环

定义 可变 smp_已初始化 = 假
定义 可变 在线CPU位图 = 1     // bit0=BSP
定义 可变 AP启动数 = 0

// SMP初始化 

函数 SMP_初始化() {
    定义 cpu总数 = acpi_CPU数()
    如果 (cpu总数 <= 1) {
        内核信息("SMP: 单CPU系统, 跳过AP启动")
        smp_已初始化 = 真
        返回
    }

    内核信息("SMP: 检测到 " + 整数转字符串(cpu总数) + " 个CPU, 启动AP...")

    // 逐个启动AP
    定义 可变 cpu = 1
    当 (cpu < cpu总数) {
        定义 结果 = 启动AP(cpu)
        如果 (结果 == 成功) {
            在线CPU位图 = 在线CPU位图 | (1 << cpu)
            AP启动数 = AP启动数 + 1
            内核信息("SMP: CPU" + 整数转字符串(cpu) + " 已上线")
        } 否则 {
            内核警告("SMP: CPU" + 整数转字符串(cpu) + " 启动失败")
        }
        cpu = cpu + 1
    }

    smp_已初始化 = 真
    内核信息("SMP: " + 整数转字符串(AP启动数 + 1) + " 个CPU在线")
}

// 启动单个AP 

函数 启动AP(cpu编号) {
    // 1. 准备AP启动代码(放在低地址, <1MB)
    // 2. 发送INIT IPI
    接口C_发送IPI(cpu编号, 0x00004500)   // INIT
    // 3. 等待10ms
    延时_ms(10)
    // 4. 发送STARTUP IPI (指定启动代码地址)
    接口C_发送IPI(cpu编号, 0x00004600 | (启动代码页 & 0xFF))
    // 5. 等待AP响应(检查标志位)
    定义 可变 超时 = 100
    当 (超时 > 0) {
        如果 (AP_已启动(cpu编号)) { 返回 成功 }
        延时_ms(1)
        超时 = 超时 - 1
    }
    返回 错误_超时
}

// AP入口 (每个AP启动后执行)

函数 AP_入口(cpu编号) {
    // 加载BSP设置的GDT (共享同一份GDT)
    加载GDT(GDT缓冲, GDT表项数 * 8 - 1)
    // 加载IDT
    加载IDT(IDT缓冲, IDT表项数 * 16 - 1)

    // AP使用BSP的页表(共享内核地址空间)
    写入CR3(读取CR3())   // 确保TLB一致

    L接口C_初始化_AP()
    定义 apic_id = L接口C_获取ID()

    per_cpu_write(cpu编号, PCPU_CURRENT_TASK, 空)
    per_cpu_write(cpu编号, PCPU_IRQ_COUNT, 0)
    设置当前CPU(cpu编号)

    定义 栈 = 分配内核栈()
    如果 (栈 != 0) {
        TSS_设置RSP0(栈顶地址(栈))
    }

    // 每个AP需要自己的中断栈

    设置(AP_启动标志表, cpu编号, 1)
    内核信息("AP" + 整数转字符串(cpu编号) + ": 接口C=" + 整数转字符串(apic_id) + " 初始化完成")

    开中断()
    idle循环()
}

定义 可变 AP_启动标志表 = [0, 0, 0, 0, 0, 0, 0, 0]   // 最多8个CPU

函数 AP_已启动(cpu) {
    如果 (cpu >= 计数(AP_启动标志表)) { 返回 假 }
    返回 AP_启动标志表[cpu] != 0
}

函数 接口C_发送IPI_SMP(目标CPU, ICR值) {
    // 通过L接口C ICR寄存器发送IPI
    // ICR高32位: 目标接口C ID
    // ICR低32位: 向量/投递模式/级别/触发
    定义 lapic_base = 读接口C基址()
    如果 (lapic_base == 0) { 返回 }
    // 写ICR高: 目标CPU的接口C ID
    MMIO写32(lapic_base + 0x310, 目标CPU << 24)
    // 写ICR低: 触发IPI
    MMIO写32(lapic_base + 0x300, ICR值)
}

函数 延时_ms(ms) {
    // 简单忙等延时(通过TSC)
    定义 开始 = 读取毫秒()
    当 (读取毫秒() - 开始 < ms) {
        // 忙等
    }
}

函数 L接口C_初始化_AP() {
    // 启用本地接口C (设置SVR.bit8=1)
    定义 lapic_base = 读接口C基址()
    如果 (lapic_base == 0) { 返回 }
    定义 svr = MMIO读32(lapic_base + 0xF0)
    MMIO写32(lapic_base + 0xF0, svr | 0x100)   // 使能接口C
    // 设置定时器: 周期模式, 除数16
    MMIO写32(lapic_base + 0x3E0, 0x03)         // 除数配置: 16
    MMIO写32(lapic_base + 0x320, 0x20020)      // 定时器LVT: 周期模式, 向量0x20
    MMIO写32(lapic_base + 0x380, 0x100000)     // 初始计数
    // 发送EOI清除任何挂起中断
    MMIO写32(lapic_base + 0xB0, 0)
}
函数 L接口C_获取ID() {
    // 读取Local 接口C ID寄存器(偏移0x20, 高8位)
    定义 L接口C基址 = 0xFEE00000  // x86-64 L接口C默认物理地址
    定义 值 = 内存读32(L接口C基址 + 0x20)
    返回 (值 >> 24) & 0xFF
}

定义 启动代码页 = 0x8000   // AP启动代码物理页(0x8000=32KB)
// 错误_超时 定义在 核心/公共/错误码.nova

函数 SMP_统计() {
    返回 [AP启动数, 在线CPU位图, smp_已初始化]
}

// CPU在线状态查询

函数 CPU_在线(cpu) {
    返回 (在线CPU位图 & (1 << cpu)) != 0
}

函数 CPU_在线数() {
    定义 可变 计 = 0
    定义 可变 位图 = 在线CPU位图
    当 (位图 != 0) {
        计 = 计 + (位图 & 1)
        位图 = 位图 >> 1
    }
    返回 计
}

函数 CPU_遍历在线(回调) {
    定义 可变 i = 0
    当 (i < 64) {
        如果 ((在线CPU位图 & (1 << i)) != 0) {
            回调(i)
        }
        i = i + 1
    }
}

// CPU热插拔 

函数 CPU_下线(cpu) {
    如果 (cpu == 0) { 返回 错误_权限 }  // BSP不能下线
    如果 (!CPU_在线(cpu)) { 返回 错误_已存在 }
    在线CPU位图 = 在线CPU位图 & ~(1 << cpu)
    内核信息("SMP: CPU" + 整数转字符串(cpu) + " 已下线")
    返回 成功
}

函数 CPU_上线(cpu) {
    如果 (CPU_在线(cpu)) { 返回 错误_已存在 }
    定义 结果 = 启动AP(cpu)
    如果 (结果 == 成功) {
        在线CPU位图 = 在线CPU位图 | (1 << cpu)
        内核信息("SMP: CPU" + 整数转字符串(cpu) + " 已上线")
    }
    返回 结果
}

// SMP完整统计

函数 SMP_完整统计() {
    返回 [AP启动数, CPU_在线数(), 在线CPU位图, smp_已初始化]
}

定义 可变 AI_多处理启动_带宽估计 = 0
定义 可变 AI_多处理启动_丢包窗口 = []

函数 AI_多处理启动_带宽预测(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 AI_多处理启动_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    AI_多处理启动_带宽估计 = AI_多处理启动_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 AI_多处理启动_带宽估计
}

函数 AI_多处理启动_拥塞建议(丢包率) {
    追加(AI_多处理启动_丢包窗口, 丢包率)
    如果 (计数(AI_多处理启动_丢包窗口) > 10) { 列表_移除(AI_多处理启动_丢包窗口, 0) }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}

// NovaOS 浏览器内核 · 第五层 · AI交互入口
// 核心理念: 地址栏 = AI交互入口 = 自然语言操作系统
// 职责: 统一入口(URL/搜索/系统命令/AI对话)、结果渲染、上下文管理

定义 模式_统一     = 0    // 统一模式(自动识别)
定义 模式_URL      = 1    // URL输入模式
定义 模式_搜索     = 2    // 搜索模式
定义 模式_命令     = 3    // 系统命令模式 (以 > 开头)
定义 模式_AI对话   = 4    // AI对话模式 (以 @ 开头)
定义 模式_计算     = 5    // 计算器模式 (以 = 开头)

定义 建议_URL       = 0
定义 建议_搜索      = 1
定义 建议_命令      = 2
定义 建议_历史      = 3
定义 建议_书签      = 4
定义 建议_AI        = 5

结构 输入建议 {
    类型,
    文本,
    描述,
    图标,
    优先级,
}

结构 AI交互会话 {
    ID,
    历史,    // [] [输入, 回复] 列表
    上下文,
    模式,
    活跃,
}

定义 可变 AI入口_当前模式 = 模式_统一
定义 可变 AI入口_会话 = 空
定义 可变 AI入口_建议缓存 = []
定义 可变 AI入口_输入历史 = []
定义 可变 AI入口_已初始化 = 假
定义 可变 AI入口_总交互数 = 0

// §1 初始化

函数 AI交互入口_初始化() {
    AI入口_会话 = AI交互会话 {}
    AI入口_会话.历史 = []
    AI入口_会话.上下文 = ""
    AI入口_会话.模式 = 模式_统一
    AI入口_会话.活跃 = 真
    AI入口_建议缓存 = []
    AI入口_输入历史 = []
    AI入口_已初始化 = 真
    内核信息("AI交互入口: 地址栏=系统入口=AI助手, 统一模式就绪")
}

// §2 统一输入处理 — 地址栏核心逻辑

函数 AI交互入口_匹配系统页(输入) {
    如果 (字符串查找(输入, "设置") >= 0) { 返回 "nova://settings" }
    如果 (字符串查找(输入, "回滚") >= 0 || 字符串查找(输入, "恢复") >= 0 || 字符串查找(输入, "热更新") >= 0 || 字符串查找(输入, "自修复") >= 0) { 返回 "nova://recovery" }
    如果 (字符串查找(输入, "语音") >= 0 || 字符串查找(输入, "声音") >= 0 || 字符串查找(输入, "麦克风") >= 0 || 字符串查找(输入, "听觉") >= 0) { 返回 "nova://voice" }
    如果 (字符串查找(输入, "形象") >= 0 || 字符串查找(输入, "虚拟人") >= 0 || 字符串查找(输入, "化身") >= 0 || 字符串查找(输入, "avatar") >= 0 || 字符串查找(输入, "全息") >= 0) { 返回 "nova://avatar" }
    如果 (字符串查找(输入, "多模态") >= 0 || 字符串查找(输入, "视觉") >= 0) { 返回 "nova://multimodal" }
    如果 (字符串查找(输入, "自动化") >= 0 || 字符串查找(输入, "工作流") >= 0 || 字符串查找(输入, "任务编排") >= 0 || 字符串查找(输入, "发布") >= 0) { 返回 "nova://automation" }
    如果 (字符串查找(输入, "系统总线") >= 0 || 字符串查找(输入, "系统状态") >= 0 || 字符串查找(输入, "硬件") >= 0 || 字符串查找(输入, "进程") >= 0 || 字符串查找(输入, "内存") >= 0 || 字符串查找(输入, "gpu") >= 0 || 字符串查找(输入, "cpu") >= 0) { 返回 "nova://system" }
    如果 (字符串查找(输入, "ai工作台") >= 0 || 字符串查找(输入, "ai助手") >= 0 || 字符串查找(输入, "模型") >= 0 || 字符串查找(输入, "对话") >= 0) { 返回 "nova://ai" }
    如果 (字符串查找(输入, "系统主壳") >= 0 || 字符串查找(输入, "系统主页") >= 0 || 字符串查找(输入, "browser-终端") >= 0 || 字符串查找(输入, "主壳") >= 0 || 字符串查找(输入, "终端") >= 0) { 返回 "nova://终端" }
    返回 ""
}

函数 AI交互入口_处理输入(输入) {
    AI入口_总交互数 = AI入口_总交互数 + 1
    追加(AI入口_输入历史, 输入)

    定义 修剪输入 = 字符串修剪(输入)
    如果 (字符串长度(修剪输入) == 0) { 返回 "" }

    // 检测特殊前缀
    定义 首字 = 字符串子串(修剪输入, 0, 1)

    // > 前缀: 系统命令模式
    如果 (首字 == ">") {
        AI入口_当前模式 = 模式_命令
        定义 命令 = 字符串修剪(字符串子串(修剪输入, 1, 字符串长度(修剪输入) - 1))
        返回 AI交互入口_执行系统命令(命令)
    }

    // @ 前缀: AI对话模式
    如果 (首字 == "@") {
        AI入口_当前模式 = 模式_AI对话
        定义 对话 = 字符串修剪(字符串子串(修剪输入, 1, 字符串长度(修剪输入) - 1))
        返回 AI交互入口_AI对话(对话)
    }

    // = 前缀: 计算器模式
    如果 (首字 == "=") {
        AI入口_当前模式 = 模式_计算
        定义 表达式 = 字符串修剪(字符串子串(修剪输入, 1, 字符串长度(修剪输入) - 1))
        返回 AI交互入口_计算(表达式)
    }

    定义 系统页 = AI交互入口_匹配系统页(修剪输入)
    如果 (字符串长度(系统页) > 0) {
        事件循环_导航(系统页)
        返回 "打开系统页: " + 系统页
    }

    // 统一模式: AI意图推理决定行为
    AI入口_当前模式 = 模式_统一
    定义 意图 = 意图推理_分析(修剪输入)

    如果 (意图.意图类型 == 意图_导航) {
        // 导航到URL
        定义 可变 url = ""
        定义 可变 i = 0
        当 (i < 计数(意图.参数)) {
            如果 (意图.参数[i][0] == "url") {
                url = 意图.参数[i][1]
            }
            i = i + 1
        }
        如果 (字符串长度(url) > 0) {
            // 自动补全协议
            如果 (字符串查找(url, "://") < 0 && 字符串查找(url, "nova:") < 0) {
                url = "https://" + url
            }
            事件循环_导航(url)
            返回 "导航中: " + url
        }
    }

    如果 (意图.意图类型 == 意图_搜索) {
        定义 可变 searchURL = ""
        定义 可变 i = 0
        当 (i < 计数(意图.参数)) {
            如果 (意图.参数[i][0] == "url") {
                searchURL = 意图.参数[i][1]
            }
            i = i + 1
        }
        如果 (字符串长度(searchURL) > 0) {
            事件循环_导航(searchURL)
        }
        返回 "搜索: " + 修剪输入
    }

    如果 (意图.意图类型 == 意图_系统命令) {
        返回 意图推理_执行(意图)
    }

    如果 (意图.意图类型 == 意图_AI对话) {
        返回 AI交互入口_AI对话(修剪输入)
    }

    // 兜底: 作为搜索
    事件循环_导航("https://search.novaos.dev/?q=" + 修剪输入)
    返回 "搜索: " + 修剪输入
}

// §3 系统命令执行

函数 AI交互入口_执行系统命令(命令) {
    定义 系统页 = AI交互入口_匹配系统页(命令)
    如果 (字符串长度(系统页) > 0) {
        事件循环_导航(系统页)
        返回 "打开系统页: " + 系统页
    }

    定义 意图 = 意图推理_分析(命令)
    如果 (意图.置信度 > 50) {
        返回 意图推理_执行(意图)
    }
    返回 "未识别的命令: " + 命令 + "\n提示: 试试「>系统主壳」「>AI工作台」「>查看进程」「>多模态」「>回滚恢复」"
}

// §4 AI对话

函数 AI交互入口_AI对话(输入) {
    // 记录对话历史
    追加(AI入口_会话.历史, [输入, ""])

    // 先尝试本地TNF推理
    定义 意图 = 意图推理_分析(输入)
    如果 (意图.置信度 > 70) {
        定义 回复 = 意图推理_执行(意图)
        // 更新最后一条历史的回复
        如果 (计数(AI入口_会话.历史) > 0) {
            AI入口_会话.历史[计数(AI入口_会话.历史) - 1][1] = 回复
        }
        返回 回复
    }

    // 本地推理置信度不足 → 构建AI回复
    定义 回复 = "Nova AI: 我理解你在说「" + 输入 + "」\n"
    回复 = 回复 + "你可以:\n"
    回复 = 回复 + "• 输入URL直接访问网页\n"
    回复 = 回复 + "• 用 > 前缀执行系统命令 (如 >系统主壳、>查看进程)\n"
    回复 = 回复 + "• 直接说自然语言 (如 打开多模态、查看系统总线)\n"
    回复 = 回复 + "• 输入关键词搜索网页"

    如果 (计数(AI入口_会话.历史) > 0) {
        AI入口_会话.历史[计数(AI入口_会话.历史) - 1][1] = 回复
    }

    返回 回复
}

// §5 计算器

函数 AI交互入口_计算(表达式) {
    // 简单四则运算
    定义 加号 = 字符串查找(表达式, "+")
    如果 (加号 > 0) {
        定义 左 = 字符串转整数(字符串修剪(字符串子串(表达式, 0, 加号)))
        定义 右 = 字符串转整数(字符串修剪(字符串子串(表达式, 加号 + 1, 字符串长度(表达式) - 加号 - 1)))
        返回 表达式 + " = " + 整数转字符串(左 + 右)
    }
    定义 减号 = 字符串查找(表达式, "-")
    如果 (减号 > 0) {
        定义 左 = 字符串转整数(字符串修剪(字符串子串(表达式, 0, 减号)))
        定义 右 = 字符串转整数(字符串修剪(字符串子串(表达式, 减号 + 1, 字符串长度(表达式) - 减号 - 1)))
        返回 表达式 + " = " + 整数转字符串(左 - 右)
    }
    定义 乘号 = 字符串查找(表达式, "*")
    如果 (乘号 > 0) {
        定义 左 = 字符串转整数(字符串修剪(字符串子串(表达式, 0, 乘号)))
        定义 右 = 字符串转整数(字符串修剪(字符串子串(表达式, 乘号 + 1, 字符串长度(表达式) - 乘号 - 1)))
        返回 表达式 + " = " + 整数转字符串(左 * 右)
    }
    返回 "计算: " + 表达式
}

// §6 实时建议 — 输入时AI预测

函数 AI交互入口_获取建议(部分输入) {
    定义 可变 建议 = []

    如果 (字符串长度(部分输入) < 2) { 返回 建议 }

    // ① 历史匹配
    定义 可变 i = 计数(AI入口_输入历史) - 1
    当 (i >= 0 && 计数(建议) < 3) {
        如果 (字符串查找(AI入口_输入历史[i], 部分输入) == 0) {
            定义 s = 输入建议 {}
            s.类型 = 建议_历史
            s.文本 = AI入口_输入历史[i]
            s.描述 = "历史记录"
            s.优先级 = 90
            追加(建议, s)
        }
        i = i - 1
    }

    // ② 系统命令建议
    如果 (字符串子串(部分输入, 0, 1) == ">" || 字符串查找(部分输入, "打开") >= 0 ||
         字符串查找(部分输入, "查看") >= 0 || 字符串查找(部分输入, "清理") >= 0) {
        定义 命令建议 = 输入建议 {}
        命令建议.类型 = 建议_命令
        命令建议.文本 = 部分输入
        命令建议.描述 = "系统命令"
        命令建议.优先级 = 85
        追加(建议, 命令建议)
    }

    定义 系统页 = AI交互入口_匹配系统页(部分输入)
    如果 (字符串长度(系统页) > 0 && 计数(建议) < 5) {
        定义 系统页建议 = 输入建议 {}
        系统页建议.类型 = 建议_AI
        系统页建议.文本 = 系统页
        系统页建议.描述 = "打开系统页"
        系统页建议.优先级 = 88
        追加(建议, 系统页建议)
    }

    // ③ URL自动补全
    如果 (字符串查找(部分输入, ".") >= 0) {
        定义 url建议 = 输入建议 {}
        url建议.类型 = 建议_URL
        url建议.文本 = "https://" + 部分输入
        url建议.描述 = "访问网站"
        url建议.优先级 = 80
        追加(建议, url建议)
    }

    // ④ 搜索建议
    定义 搜索建议 = 输入建议 {}
    搜索建议.类型 = 建议_搜索
    搜索建议.文本 = 部分输入
    搜索建议.描述 = "搜索 \"" + 部分输入 + "\""
    搜索建议.优先级 = 50
    追加(建议, 搜索建议)

    返回 建议
}

函数 AI交互入口_统计() {
    返回 [AI入口_总交互数, AI入口_当前模式, 计数(AI入口_输入历史)]
}

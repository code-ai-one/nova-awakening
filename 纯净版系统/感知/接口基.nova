// §4 Base64 (btoa / atob)

定义 可变 BASE64_表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

// btoa(string) → Base64
函数 Base64_编码(数据, 长度) {
    如果 (数据 == 0 || 长度 == 0) { 返回 "" }
    定义 输出长度 = ((长度 + 2) / 3) * 4
    定义 结果 = 堆_分配(输出长度 + 1)
    定义 可变 i = 0; 定义 可变 o = 0

    当 (i + 2 < 长度) {
        定义 b0 = 字节取(数据, i)
        定义 b1 = 字节取(数据, i + 1)
        定义 b2 = 字节取(数据, i + 2)
        字节写(结果, o, 字节取(BASE64_表, b0 >> 2))
        字节写(结果, o + 1, 字节取(BASE64_表, ((b0 & 3) << 4) | (b1 >> 4)))
        字节写(结果, o + 2, 字节取(BASE64_表, ((b1 & 15) << 2) | (b2 >> 6)))
        字节写(结果, o + 3, 字节取(BASE64_表, b2 & 63))
        i = i + 3; o = o + 4
    }

    如果 (i < 长度) {
        定义 b0 = 字节取(数据, i)
        字节写(结果, o, 字节取(BASE64_表, b0 >> 2))
        如果 (i + 1 < 长度) {
            定义 b1 = 字节取(数据, i + 1)
            字节写(结果, o + 1, 字节取(BASE64_表, ((b0 & 3) << 4) | (b1 >> 4)))
            字节写(结果, o + 2, 字节取(BASE64_表, (b1 & 15) << 2))
        } 否则 {
            字节写(结果, o + 1, 字节取(BASE64_表, (b0 & 3) << 4))
            字节写(结果, o + 2, 61)    // '='
        }
        字节写(结果, o + 3, 61)    // '='
        o = o + 4
    }

    字节写(结果, o, 0)
    返回 结果
}

函数 Base64_解码字符(ch) {
    如果 (ch >= 65 && ch <= 90) { 返回 ch - 65 }      // A-Z
    如果 (ch >= 97 && ch <= 122) { 返回 ch - 71 }     // a-z
    如果 (ch >= 48 && ch <= 57) { 返回 ch + 4 }       // 0-9
    如果 (ch == 43) { 返回 62 }                         // +
    如果 (ch == 47) { 返回 63 }                         // /
    返回 -1    // 无效
}

// atob(base64) → string
函数 Base64_解码(base64, 长度) {
    如果 (base64 == 0 || 长度 == 0) { 返回 "" }
    // 计算输出长度
    定义 可变 pad = 0
    如果 (字节取(base64, 长度 - 1) == 61) { pad = pad + 1 }
    如果 (长度 >= 2 && 字节取(base64, 长度 - 2) == 61) { pad = pad + 1 }
    定义 输出长度 = 长度 / 4 * 3 - pad

    定义 结果 = 堆_分配(输出长度 + 1)
    定义 可变 i = 0; 定义 可变 o = 0

    当 (i + 3 < 长度) {
        定义 a = Base64_解码字符(字节取(base64, i))
        定义 b = Base64_解码字符(字节取(base64, i + 1))
        定义 c = Base64_解码字符(字节取(base64, i + 2))
        定义 d = Base64_解码字符(字节取(base64, i + 3))
        如果 (a < 0 || b < 0) { 返回 0 }    // 无效Base64

        字节写(结果, o, (a << 2) | (b >> 4))
        o = o + 1
        如果 (c >= 0) {
            字节写(结果, o, ((b & 15) << 4) | (c >> 2))
            o = o + 1
        }
        如果 (d >= 0) {
            字节写(结果, o, ((c & 3) << 6) | d)
            o = o + 1
        }
        i = i + 4
    }

    字节写(结果, o, 0)
    返回 结果
}

// §5 URL编码/解码

// 需要编码的字符(encodeURIComponent):
// 除 A-Z a-z 0-9 - _ . ! ~ * ' ( ) 以外的所有字符

函数 URL_是安全字符(ch) {
    如果 (ch >= 65 && ch <= 90) { 返回 真 }    // A-Z
    如果 (ch >= 97 && ch <= 122) { 返回 真 }   // a-z
    如果 (ch >= 48 && ch <= 57) { 返回 真 }    // 0-9
    如果 (ch == 45 || ch == 95 || ch == 46 || ch == 33) { 返回 真 }  // - _ . !
    如果 (ch == 126 || ch == 42 || ch == 39 || ch == 40 || ch == 41) { 返回 真 }  // ~ * ' ( )
    返回 假
}

函数 URL_hex字符(v) {
    如果 (v < 10) { 返回 48 + v }    // '0'-'9'
    返回 65 + v - 10                   // 'A'-'F'
}

// encodeURIComponent(string)
函数 URL_encodeComponent(字符串) {
    如果 (字符串 == 0) { 返回 "" }
    定义 len = 字节长度(字符串)
    定义 结果 = 堆_分配(len * 3 + 1)    // 最坏: 每字节→%XX
    定义 可变 rpos = 0; 定义 可变 wpos = 0

    当 (rpos < len) {
        定义 ch = 字节取(字符串, rpos)
        如果 (URL_是安全字符(ch)) {
            字节写(结果, wpos, ch); wpos = wpos + 1
        } 否则 {
            字节写(结果, wpos, 37)    // '%'
            字节写(结果, wpos + 1, URL_hex字符(ch >> 4))
            字节写(结果, wpos + 2, URL_hex字符(ch & 15))
            wpos = wpos + 3
        }
        rpos = rpos + 1
    }
    字节写(结果, wpos, 0)
    返回 结果
}

函数 URL_hex值(ch) {
    如果 (ch >= 48 && ch <= 57) { 返回 ch - 48 }      // '0'-'9'
    如果 (ch >= 65 && ch <= 70) { 返回 ch - 55 }      // 'A'-'F'
    如果 (ch >= 97 && ch <= 102) { 返回 ch - 87 }     // 'a'-'f'
    返回 -1
}

// decodeURIComponent(string)
函数 URL_decodeComponent(字符串) {
    如果 (字符串 == 0) { 返回 "" }
    定义 len = 字节长度(字符串)
    定义 结果 = 堆_分配(len + 1)
    定义 可变 rpos = 0; 定义 可变 wpos = 0

    当 (rpos < len) {
        定义 ch = 字节取(字符串, rpos)
        如果 (ch == 37 && rpos + 2 < len) {    // '%'
            定义 h = URL_hex值(字节取(字符串, rpos + 1))
            定义 l = URL_hex值(字节取(字符串, rpos + 2))
            如果 (h >= 0 && l >= 0) {
                字节写(结果, wpos, h * 16 + l)
                wpos = wpos + 1; rpos = rpos + 3
                继续
            }
        }
        字节写(结果, wpos, ch); wpos = wpos + 1; rpos = rpos + 1
    }
    字节写(结果, wpos, 0)
    返回 结果
}

// encodeURI: 保留更多字符(; / ? : @ & = + $ , #)
函数 URL_是URI安全字符(ch) {
    如果 (URL_是安全字符(ch)) { 返回 真 }
    如果 (ch == 59 || ch == 47 || ch == 63 || ch == 58) { 返回 真 }  // ; / ? :
    如果 (ch == 64 || ch == 38 || ch == 61 || ch == 43) { 返回 真 }  // @ & = +
    如果 (ch == 36 || ch == 44 || ch == 35) { 返回 真 }               // $ , #
    返回 假
}

函数 URL_encodeURI(字符串) {
    如果 (字符串 == 0) { 返回 "" }
    定义 len = 字节长度(字符串)
    定义 结果 = 堆_分配(len * 3 + 1)
    定义 可变 rpos = 0; 定义 可变 wpos = 0
    当 (rpos < len) {
        定义 ch = 字节取(字符串, rpos)
        如果 (URL_是URI安全字符(ch)) {
            字节写(结果, wpos, ch); wpos = wpos + 1
        } 否则 {
            字节写(结果, wpos, 37)
            字节写(结果, wpos + 1, URL_hex字符(ch >> 4))
            字节写(结果, wpos + 2, URL_hex字符(ch & 15))
            wpos = wpos + 3
        }
        rpos = rpos + 1
    }
    字节写(结果, wpos, 0)
    返回 结果
}

定义 可变 AI_接口基_威胁计数 = 0

函数 AI_接口基_风险评分(操作类型, 权限级别, 来源可信度) {
    定义 可变 风险 = 0
    如果 (权限级别 > 500) { 风险 = 风险 + 300 }
    如果 (来源可信度 < 200) { 风险 = 风险 + 400 }
    如果 (风险 > 500) { AI_接口基_威胁计数 = AI_接口基_威胁计数 + 1 }
    返回 风险
}

函数 AI_接口基_异常行为检测(操作频率, 基线频率) {
    如果 (基线频率 > 0 && 操作频率 > 基线频率 * 5) { 返回 真 }
    返回 假
}

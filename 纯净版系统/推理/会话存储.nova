导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/哈希整数.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/创建甲.nova")

定义 最大会话 = 256
定义 默认过期 = 3600000000
定义 校验种子 = 2654435761

结构 会话记录 {
    键哈希,
    渠道哈希,
    用户哈希,
    数据指针,
    数据长度,
    创建时刻,
    最近访问,
    过期时刻,
    校验值,
    活跃,
}

定义 可变 会话表 = []
定义 可变 会话数 = 0
定义 可变 保存次数 = 0
定义 可变 加载次数 = 0
定义 可变 淘汰次数 = 0
定义 可变 过期次数 = 0

函数 会话存储_初始化() {
    会话表 = []
    会话数 = 0
}

函数 会话存储_创建(渠道, 用户, 数据, 数据长, 过期秒) {
    如果 (会话数 >= 最大会话) { 会话存储_淘汰() }
    定义 记录 = 会话记录 {}
    定义 现在 = 平台_获取高精度时间()
    记录.键哈希 = 会话存储_生成键(渠道, 用户, 现在)
    记录.渠道哈希 = 哈希_字符串(渠道)
    记录.用户哈希 = 哈希_字符串(用户)
    记录.数据指针 = 堆_分配(数据长)
    内存_复制(记录.数据指针, 数据, 数据长)
    记录.数据长度 = 数据长
    记录.创建时刻 = 现在
    记录.最近访问 = 现在
    如果 (过期秒 > 0) { 记录.过期时刻 = 现在 + 过期秒 * 1000000 }
    否则 { 记录.过期时刻 = 现在 + 默认过期 }
    记录.校验值 = 会话存储_计算校验(数据, 数据长)
    记录.活跃 = 真
    追加(会话表, 记录)
    定义 索引 = 会话数
    会话数 = 会话数 + 1
    保存次数 = 保存次数 + 1
    返回 记录.键哈希
}

函数 会话存储_查找(键哈希) {
    加载次数 = 加载次数 + 1
    定义 现在 = 平台_获取高精度时间()
    定义 可变 序号 = 0
    当 (序号 < 会话数) {
        如果 (会话表[序号].键哈希 == 键哈希 && 会话表[序号].活跃) {
            如果 (现在 > 会话表[序号].过期时刻) {
                会话表[序号].活跃 = 假
                过期次数 = 过期次数 + 1
                返回 0
            }
            会话表[序号].最近访问 = 现在
            返回 会话表[序号].数据指针
        }
        序号 = 序号 + 1
    }
    返回 0
}

函数 会话存储_更新(键哈希, 新数据, 新长度) {
    定义 可变 序号 = 0
    当 (序号 < 会话数) {
        如果 (会话表[序号].键哈希 == 键哈希 && 会话表[序号].活跃) {
            如果 (会话表[序号].数据指针 != 0) { 堆_释放(会话表[序号].数据指针) }
            会话表[序号].数据指针 = 堆_分配(新长度)
            内存_复制(会话表[序号].数据指针, 新数据, 新长度)
            会话表[序号].数据长度 = 新长度
            会话表[序号].最近访问 = 平台_获取高精度时间()
            会话表[序号].校验值 = 会话存储_计算校验(新数据, 新长度)
            保存次数 = 保存次数 + 1
            返回 0
        }
        序号 = 序号 + 1
    }
    返回 错误_不存在
}

函数 会话存储_删除(键哈希) {
    定义 可变 序号 = 0
    当 (序号 < 会话数) {
        如果 (会话表[序号].键哈希 == 键哈希 && 会话表[序号].活跃) {
            会话表[序号].活跃 = 假
            如果 (会话表[序号].数据指针 != 0) {
                堆_释放(会话表[序号].数据指针)
                会话表[序号].数据指针 = 0
            }
            返回 0
        }
        序号 = 序号 + 1
    }
    返回 错误_不存在
}

函数 会话存储_续期(键哈希, 额外秒) {
    定义 可变 序号 = 0
    当 (序号 < 会话数) {
        如果 (会话表[序号].键哈希 == 键哈希 && 会话表[序号].活跃) {
            会话表[序号].过期时刻 = 会话表[序号].过期时刻 + 额外秒 * 1000000
            返回 0
        }
        序号 = 序号 + 1
    }
    返回 错误_不存在
}

函数 会话存储_清理过期() {
    定义 现在 = 平台_获取高精度时间()
    定义 可变 序号 = 0
    当 (序号 < 会话数) {
        如果 (会话表[序号].活跃 && 现在 > 会话表[序号].过期时刻) {
            会话表[序号].活跃 = 假
            如果 (会话表[序号].数据指针 != 0) {
                堆_释放(会话表[序号].数据指针)
                会话表[序号].数据指针 = 0
            }
            过期次数 = 过期次数 + 1
        }
        序号 = 序号 + 1
    }
}

函数 会话存储_淘汰() {
    定义 可变 最旧 = -1
    定义 可变 最旧时间 = 0x7FFFFFFFFFFFFFFF
    定义 可变 序号 = 0
    当 (序号 < 会话数) {
        如果 (会话表[序号].活跃 && 会话表[序号].最近访问 < 最旧时间) {
            最旧时间 = 会话表[序号].最近访问
            最旧 = 序号
        }
        序号 = 序号 + 1
    }
    如果 (最旧 >= 0) {
        会话表[最旧].活跃 = 假
        如果 (会话表[最旧].数据指针 != 0) { 堆_释放(会话表[最旧].数据指针) }
        淘汰次数 = 淘汰次数 + 1
    }
}

函数 会话存储_生成键(渠道, 用户, 时间) {
    返回 (哈希_字符串(渠道) ^ 哈希_字符串(用户) ^ (时间 & 0xFFFFFFFF)) & 0x7FFFFFFFFFFFFFFF
}

函数 会话存储_计算校验(数据, 长度) {
    定义 可变 校验 = 校验种子
    定义 可变 位 = 0
    当 (位 < 长度) {
        校验 = 校验 ^ (内存_读8(数据 + 位) * (位 + 1))
        校验 = (校验 << 5) | (校验 >> 27)
        位 = 位 + 1
    }
    返回 校验
}

函数 会话存储_验证(键哈希) {
    定义 可变 序号 = 0
    当 (序号 < 会话数) {
        如果 (会话表[序号].键哈希 == 键哈希 && 会话表[序号].活跃) {
            定义 实际校验 = 会话存储_计算校验(会话表[序号].数据指针, 会话表[序号].数据长度)
            返回 实际校验 == 会话表[序号].校验值
        }
        序号 = 序号 + 1
    }
    返回 假
}

函数 会话存储_活跃数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 会话数) {
        如果 (会话表[序号].活跃) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 会话存储_完整统计() {
    返回 [会话数, 会话存储_活跃数(), 保存次数, 加载次数, 淘汰次数, 过期次数]
}

定义 可变 AI_会话存储_威胁计数 = 0

函数 AI_会话存储_风险评分(操作类型, 权限级别, 来源可信度) {
    定义 可变 风险 = 0
    如果 (权限级别 > 500) { 风险 = 风险 + 300 }
    如果 (来源可信度 < 200) { 风险 = 风险 + 400 }
    如果 (风险 > 500) { AI_会话存储_威胁计数 = AI_会话存储_威胁计数 + 1 }
    返回 风险
}

函数 AI_会话存储_异常行为检测(操作频率, 基线频率) {
    如果 (基线频率 > 0 && 操作频率 > 基线频率 * 5) { 返回 真 }
    返回 假
}

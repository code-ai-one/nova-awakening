定义 路由类型_单播 = 1
定义 路由类型_本地 = 2
定义 路由类型_广播 = 3
定义 路由类型_黑洞 = 6
定义 路由类型_禁止 = 7
定义 路由类型_不可达 = 8

定义 路由范围_全局 = 0
定义 路由范围_链路 = 253
定义 路由范围_主机 = 254

定义 路由协议_内核 = 2
定义 路由协议_启动 = 3
定义 路由协议_静态 = 4
定义 路由协议_DHCP = 16

定义 路由标志_上线 = 0x01
定义 路由标志_网关 = 0x02
定义 路由标志_主机 = 0x04
定义 路由标志_拒绝 = 0x08
定义 路由标志_动态 = 0x10
定义 路由标志_已修改 = 0x20

定义 路由_最大ECMP = 8
定义 路由_老化超时 = 300000

定义 可变 路由_查找次数 = 0
定义 可变 路由_查找命中 = 0
定义 可变 路由_添加次数 = 0
定义 可变 路由_删除次数 = 0
定义 可变 路由_缓存命中 = 0

函数 前缀长度_转掩码(前缀长度) {
    如果 (前缀长度 == 0) { 返回 0 }
    如果 (前缀长度 >= 32) { 返回 0xFFFFFFFF }
    返回 ~((1 << (32 - 前缀长度)) - 1)
}

函数 掩码_转前缀长度(掩码) {
    定义 可变 长度 = 0
    定义 可变 m = 掩码
    当 (m & 0x80000000) {
        长度 = 长度 + 1
        m = m << 1
    }
    返回 长度
}

函数 掩码_是有效(掩码) {
    如果 (掩码 == 0) { 返回 真 }
    定义 可变 m = ~掩码 & 0xFFFFFFFF
    返回 (m & (m + 1)) == 0
}

函数 IP地址_应用掩码(ip, 前缀长度) {
    如果 (前缀长度 >= 32) { 返回 ip }
    如果 (前缀长度 == 0) { 返回 0 }
    返回 ip & 前缀长度_转掩码(前缀长度)
}

函数 IP地址_是子网内(ip, 网络, 前缀长度) {
    定义 掩码 = 前缀长度_转掩码(前缀长度)
    返回 (ip & 掩码) == (网络 & 掩码)
}

函数 IP地址_广播地址(网络, 前缀长度) {
    定义 掩码 = 前缀长度_转掩码(前缀长度)
    返回 网络 | (~掩码 & 0xFFFFFFFF)
}

函数 IP地址_是私有(ip) {
    如果 ((ip & 0xFF000000) == 0x0A000000) { 返回 真 }
    如果 ((ip & 0xFFF00000) == 0xAC100000) { 返回 真 }
    如果 ((ip & 0xFFFF0000) == 0xC0A80000) { 返回 真 }
    返回 假
}

函数 IP地址_是回环(ip) {
    返回 (ip & 0xFF000000) == 0x7F000000
}

函数 IP地址_是多播(ip) {
    返回 (ip & 0xF0000000) == 0xE0000000
}

函数 路由_是本地地址(ip) {
    返回 路由_在表中查找(本地路由表, ip) != 空
}

函数 路由_最长前缀匹配(表, 目标ip) {
    路由_查找次数 = 路由_查找次数 + 1
    读锁_获取(表.锁)

    定义 可变 最佳 = 空
    定义 可变 最长前缀 = -1
    定义 可变 当前 = 表.条目链表

    当 (当前 != 空) {
        如果 (当前.前缀长度 > 最长前缀) {
            定义 掩码 = 前缀长度_转掩码(当前.前缀长度)
            如果 ((目标ip & 掩码) == (当前.目标网络 & 掩码)) {
                最佳 = 当前
                最长前缀 = 当前.前缀长度
            }
        }
        当前 = 当前.下一个
    }

    读锁_释放(表.锁)

    如果 (最佳 != 空) {
        路由_查找命中 = 路由_查找命中 + 1
        最佳.使用计数 = 最佳.使用计数 + 1
        最佳.最后使用时间 = 读取毫秒()
    }
    返回 最佳
}

函数 路由_查找(目标ip) {
    定义 结果 = 路由_最长前缀匹配(主路由表, 目标ip)
    如果 (结果 == 空) {
        结果 = 路由_最长前缀匹配(本地路由表, 目标ip)
    }
    返回 结果
}

函数 路由_添加(网络, 前缀长度, 网关, 设备, 度量) {
    返回 路由_添加_完整(网络, 前缀长度, 网关, 设备,
        路由类型_单播, 路由范围_全局, 路由协议_静态, 度量)
}

函数 路由_添加_完整(网络, 前缀长度, 网关, 设备, 类型, 范围, 协议, 度量) {
    定义 规范网络 = IP地址_应用掩码(网络, 前缀长度)

    写锁_获取(主路由表.锁)

    定义 可变 当前 = 主路由表.条目链表
    当 (当前 != 空) {
        如果 (当前.目标网络 == 规范网络 && 当前.前缀长度 == 前缀长度
            && 当前.网关 == 网关 && 当前.设备 == 设备) {
            当前.度量 = 度量
            写锁_释放(主路由表.锁)
            返回 0
        }
        当前 = 当前.下一个
    }

    定义 新条目 = 路由条目_创建(规范网络, 前缀长度, 网关, 设备, 类型, 范围, 协议, 度量)
    如果 (新条目 == 空) {
        写锁_释放(主路由表.锁)
        返回 -12
    }

    路由_有序插入(主路由表, 新条目)
    主路由表.条目数 = 主路由表.条目数 + 1
    路由_添加次数 = 路由_添加次数 + 1

    写锁_释放(主路由表.锁)
    返回 0
}

函数 路由_有序插入(表, 新条目) {
    如果 (表.条目链表 == 空 || 新条目.前缀长度 > 表.条目链表.前缀长度) {
        新条目.下一个 = 表.条目链表
        表.条目链表 = 新条目
        返回
    }
    定义 可变 当前 = 表.条目链表
    当 (当前.下一个 != 空 && 当前.下一个.前缀长度 >= 新条目.前缀长度) {
        当前 = 当前.下一个
    }
    新条目.下一个 = 当前.下一个
    当前.下一个 = 新条目
}

函数 路由_删除(网络, 前缀长度, 网关) {
    写锁_获取(主路由表.锁)

    定义 可变 前一个 = 空
    定义 可变 当前 = 主路由表.条目链表
    当 (当前 != 空) {
        如果 (当前.目标网络 == 网络 && 当前.前缀长度 == 前缀长度
            && (网关 == 0 || 当前.网关 == 网关)) {
            如果 (前一个 == 空) {
                主路由表.条目链表 = 当前.下一个
            } 否则 {
                前一个.下一个 = 当前.下一个
            }
            主路由表.条目数 = 主路由表.条目数 - 1
            路由_删除次数 = 路由_删除次数 + 1
            写锁_释放(主路由表.锁)
            返回 0
        }
        前一个 = 当前
        当前 = 当前.下一个
    }

    写锁_释放(主路由表.锁)
    返回 -2
}

函数 路由_添加默认(网关, 设备) {
    返回 路由_添加(0, 0, 网关, 设备, 100)
}

函数 路由_添加直连(网络, 前缀长度, 设备) {
    返回 路由_添加(网络, 前缀长度, 0, 设备, 0)
}

函数 路由_添加本地(IP地址, 设备) {
    返回 路由_添加_完整(IP地址, 32, 0, 设备, 路由类型_本地, 路由范围_主机, 路由协议_内核, 0)
}

函数 路由_老化清理(表) {
    定义 现在 = 读取毫秒()
    写锁_获取(表.锁)

    定义 可变 前一个 = 空
    定义 可变 当前 = 表.条目链表
    当 (当前 != 空) {
        定义 下一个 = 当前.下一个
        如果 ((当前.标志 & 路由标志_动态) != 0
            && (现在 - 当前.最后使用时间) > 路由_老化超时) {
            如果 (前一个 == 空) { 表.条目链表 = 下一个 }
            否则 { 前一个.下一个 = 下一个 }
            表.条目数 = 表.条目数 - 1
        } 否则 {
            前一个 = 当前
        }
        当前 = 下一个
    }

    写锁_释放(表.锁)
}

函数 路由_打印表() {
    内核打印("=== 路由表 ===\n")
    内核打印("目标网络        掩码   网关            度量  类型      使用次数\n")

    读锁_获取(主路由表.锁)
    定义 可变 当前 = 主路由表.条目链表
    当 (当前 != 空) {
        内核打印("%-15s /%d  %-15s  %d    %-10s %d\n",
            IP地址_转字符串(当前.目标网络),
            当前.前缀长度,
            IP地址_转字符串(当前.网关),
            当前.度量,
            路由_类型名(当前.类型),
            当前.使用计数)
        当前 = 当前.下一个
    }
    读锁_释放(主路由表.锁)

    内核打印("总条目数: %d\n", 主路由表.条目数)
}

函数 路由_类型名(类型) {
    如果 (类型 == 路由类型_单播) { 返回 "unicast" }
    如果 (类型 == 路由类型_本地) { 返回 "local" }
    如果 (类型 == 路由类型_广播) { 返回 "broadcast" }
    如果 (类型 == 路由类型_黑洞) { 返回 "blackhole" }
    如果 (类型 == 路由类型_禁止) { 返回 "prohibit" }
    如果 (类型 == 路由类型_不可达) { 返回 "unreachable" }
    返回 "unknown"
}

函数 路由_协议名(协议) {
    如果 (协议 == 路由协议_内核) { 返回 "kernel" }
    如果 (协议 == 路由协议_启动) { 返回 "boot" }
    如果 (协议 == 路由协议_静态) { 返回 "static" }
    如果 (协议 == 路由协议_DHCP) { 返回 "dhcp" }
    返回 "unknown"
}

函数 IP地址_转字符串(ip) {
    定义 a = (ip >> 24) & 0xFF
    定义 b = (ip >> 16) & 0xFF
    定义 c = (ip >> 8) & 0xFF
    定义 d = ip & 0xFF
    返回 整数转字符串(a) + "." + 整数转字符串(b) + "."
         + 整数转字符串(c) + "." + 整数转字符串(d)
}

函数 字符串_转IP地址(文本) {
    定义 部分 = 字符串分割(文本, ".")
    如果 (计数(部分) != 4) { 返回 0 }
    定义 a = 字符串转整数(部分[0]) & 0xFF
    定义 b = 字符串转整数(部分[1]) & 0xFF
    定义 c = 字符串转整数(部分[2]) & 0xFF
    定义 d = 字符串转整数(部分[3]) & 0xFF
    返回 (a << 24) | (b << 16) | (c << 8) | d
}

函数 路由表_完整统计() {
    返回 {
        条目数: 主路由表.条目数,
        查找次数: 路由_查找次数,
        查找命中: 路由_查找命中,
        添加次数: 路由_添加次数,
        删除次数: 路由_删除次数,
        缓存命中: 路由_缓存命中,
        命中率: 路由_查找次数 > 0 ? (路由_查找命中 * 100 / 路由_查找次数) : 0
    }
}

定义 可变 AI_前缀长度转_操作热度 = 0

函数 AI_前缀长度转_最优算法(数据量, 已排序) {
    AI_前缀长度转_操作热度 = AI_前缀长度转_操作热度 + 1
    如果 (数据量 < 16) { 返回 "插入排序" }
    如果 (已排序) { 返回 "二分查找" }
    如果 (数据量 < 10000) { 返回 "快速排序" }
    返回 "归并排序"
}

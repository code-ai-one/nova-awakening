导入("./类型定义.nova")
导入("./错误码.nova")
导入("../感知/内核直连层.nova")
导入("./内存初始化.nova")
导入("../执行/平台时间.nova")
导入("./时钟中枢.nova")
导入("./整数转字符串.nova")

定义 日志_接受 = 0
定义 日志_丢弃 = 1
定义 日志_拒绝 = 2
定义 日志_告警 = 3
定义 日志_攻击 = 4
定义 协议_传控 = 6
定义 协议_数报 = 17
定义 协议_网控 = 1
定义 最大日志 = 1024
定义 限速窗口 = 1000000

结构 防火墙日志项 {
    时间戳,
    类型,
    源地址,
    目标地址,
    源端口,
    目标端口,
    协议,
    规则标识,
    字节数,
}

定义 可变 日志环 = 0
定义 可变 日志写位 = 0
定义 可变 日志总数 = 0
定义 可变 接受总数 = 0
定义 可变 丢弃总数 = 0
定义 可变 告警总数 = 0
定义 可变 攻击总数 = 0
定义 可变 总字节 = 0
定义 可变 限速计数 = 0
定义 可变 限速窗口起 = 0
定义 可变 限速上限 = 100

函数 防火墙日志_初始化() {
    日志环 = 堆_分配(最大日志 * 56)
    日志写位 = 0
    日志总数 = 0
}

函数 防火墙_记录(类型, 源地址, 目标地址, 源端口, 目标端口, 协议, 规则标识, 字节数) {
    如果 (!防火墙日志_限速检查()) { 返回 }
    日志总数 = 日志总数 + 1
    如果 (类型 == 日志_接受) { 接受总数 = 接受总数 + 1 }
    否则 如果 (类型 == 日志_丢弃) { 丢弃总数 = 丢弃总数 + 1 }
    否则 如果 (类型 == 日志_告警) { 告警总数 = 告警总数 + 1 }
    否则 如果 (类型 == 日志_攻击) { 攻击总数 = 攻击总数 + 1 }
    总字节 = 总字节 + 字节数
    定义 偏移 = 日志环 + 日志写位 * 56
    内存_写64(偏移, 平台_获取高精度时间())
    内存_写32(偏移 + 8, 类型)
    内存_写32(偏移 + 12, 源地址)
    内存_写32(偏移 + 16, 目标地址)
    内存_写16(偏移 + 20, 源端口)
    内存_写16(偏移 + 22, 目标端口)
    内存_写8(偏移 + 24, 协议)
    内存_写32(偏移 + 28, 规则标识)
    内存_写32(偏移 + 32, 字节数)
    日志写位 = (日志写位 + 1) % 最大日志
}

函数 防火墙日志_限速检查() {
    定义 现在 = 平台_获取高精度时间()
    如果 (现在 - 限速窗口起 > 限速窗口) {
        限速窗口起 = 现在
        限速计数 = 0
    }
    限速计数 = 限速计数 + 1
    返回 限速计数 <= 限速上限
}

函数 防火墙_检测端口扫描(源地址, 窗口) {
    定义 现在 = 平台_获取高精度时间()
    定义 可变 不同端口 = 0
    定义 可变 序号 = 0
    当 (序号 < 最大日志) {
        定义 偏移 = 日志环 + 序号 * 56
        定义 时间 = 内存_读64(偏移)
        如果 (时间 > 0 && 现在 - 时间 < 窗口 && 内存_读32(偏移 + 12) == 源地址) {
            不同端口 = 不同端口 + 1
        }
        序号 = 序号 + 1
    }
    如果 (不同端口 > 20) {
        攻击总数 = 攻击总数 + 1
        返回 真
    }
    返回 假
}

函数 防火墙_检测泛洪(源地址, 窗口, 阈值) {
    定义 现在 = 平台_获取高精度时间()
    定义 可变 包数 = 0
    定义 可变 序号 = 0
    当 (序号 < 最大日志) {
        定义 偏移 = 日志环 + 序号 * 56
        定义 时间 = 内存_读64(偏移)
        如果 (时间 > 0 && 现在 - 时间 < 窗口 && 内存_读32(偏移 + 12) == 源地址) {
            包数 = 包数 + 1
        }
        序号 = 序号 + 1
    }
    如果 (包数 > 阈值) {
        攻击总数 = 攻击总数 + 1
        返回 真
    }
    返回 假
}

函数 防火墙_获取日志(索引) {
    如果 (索引 >= 最大日志) { 返回 0 }
    返回 日志环 + 索引 * 56
}

函数 防火墙_协议名(协议) {
    如果 (协议 == 协议_传控) { 返回 "传控" }
    如果 (协议 == 协议_数报) { 返回 "数报" }
    如果 (协议 == 协议_网控) { 返回 "网控" }
    返回 "未知"
}

函数 防火墙_类型名(类型) {
    如果 (类型 == 日志_接受) { 返回 "接受" }
    如果 (类型 == 日志_丢弃) { 返回 "丢弃" }
    如果 (类型 == 日志_拒绝) { 返回 "拒绝" }
    如果 (类型 == 日志_告警) { 返回 "告警" }
    如果 (类型 == 日志_攻击) { 返回 "攻击" }
    返回 "未知"
}

函数 防火墙_丢弃率() {
    如果 (日志总数 == 0) { 返回 0 }
    返回 丢弃总数 * 100 / 日志总数
}

函数 防火墙_完整统计() {
    返回 [日志总数, 接受总数, 丢弃总数, 告警总数, 攻击总数, 总字节, 防火墙_丢弃率()]
}

// §2 防火墙健康检查与诊断

函数 防火墙_健康检查() {
    定义 可变 问题 = []
    如果 (攻击总数 > 10) {
        追加(问题, "检测到攻击: " + 整数转字符串(攻击总数) + "次")
    }
    如果 (防火墙_丢弃率() > 50 && 日志总数 > 1000) {
        追加(问题, "丢弃率过高: " + 整数转字符串(防火墙_丢弃率()) + "%")
    }
    如果 (限速计数 >= 限速上限) {
        追加(问题, "日志限速已触发")
    }
    如果 (计数(问题) == 0) { 返回 "防火墙健康" }
    返回 问题
}

函数 防火墙_详细统计() {
    返回 {
        日志总数: 日志总数,
        接受: 接受总数,
        丢弃: 丢弃总数,
        告警: 告警总数,
        攻击: 攻击总数,
        总字节: 总字节,
        丢弃率: 防火墙_丢弃率(),
        限速触发: 限速计数 >= 限速上限,
    }
}

函数 防火墙_重置统计() {
    日志总数 = 0
    接受总数 = 0
    丢弃总数 = 0
    告警总数 = 0
    攻击总数 = 0
    总字节 = 0
    限速计数 = 0
}

// §3 IP地址辅助

函数 IP_字符串(地址) {
    定义 a = (地址 >> 24) & 0xFF
    定义 b = (地址 >> 16) & 0xFF
    定义 c = (地址 >> 8) & 0xFF
    定义 d = 地址 & 0xFF
    返回 整数转字符串(a) + "." + 整数转字符串(b) + "." + 整数转字符串(c) + "." + 整数转字符串(d)
}

函数 IP_从字节(a, b, c, d) {
    返回 (a << 24) | (b << 16) | (c << 8) | d
}

函数 IP_是私有(地址) {
    定义 a = (地址 >> 24) & 0xFF
    定义 b = (地址 >> 16) & 0xFF
    如果 (a == 10) { 返回 真 }
    如果 (a == 172 && b >= 16 && b <= 31) { 返回 真 }
    如果 (a == 192 && b == 168) { 返回 真 }
    如果 (a == 127) { 返回 真 }
    返回 假
}

函数 IP_是广播(地址) {
    返回 地址 == 0xFFFFFFFF
}

// §4 黑名单管理

定义 可变 黑名单 = []
定义 可变 黑名单数 = 0
定义 最大黑名单 = 256

函数 防火墙_添加黑名单(地址) {
    如果 (黑名单数 >= 最大黑名单) { 返回 }
    如果 (防火墙_在黑名单(地址)) { 返回 }
    追加(黑名单, 地址)
    黑名单数 = 黑名单数 + 1
}

函数 防火墙_移除黑名单(地址) {
    定义 可变 新列表 = []
    定义 可变 i = 0
    当 (i < 黑名单数) {
        如果 (黑名单[i] != 地址) { 追加(新列表, 黑名单[i]) }
        i = i + 1
    }
    黑名单 = 新列表
    黑名单数 = 计数(新列表)
}

函数 防火墙_在黑名单(地址) {
    定义 可变 i = 0
    当 (i < 黑名单数) {
        如果 (黑名单[i] == 地址) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 防火墙_清空黑名单() {
    黑名单 = []
    黑名单数 = 0
}

函数 防火墙_黑名单数量() {
    返回 黑名单数
}

函数 防火墙_日志诊断(索引) {
    定义 偏移 = 防火墙_获取日志(索引)
    如果 (偏移 == 0) { 返回 "无效索引" }
    返回 {
        时间: 内存_读64(偏移),
        类型: 防火墙_类型名(内存_读32(偏移 + 8)),
        源: IP_字符串(内存_读32(偏移 + 12)),
        目标: IP_字符串(内存_读32(偏移 + 16)),
        源端口: 内存_读16(偏移 + 20),
        目标端口: 内存_读16(偏移 + 22),
        协议: 防火墙_协议名(内存_读8(偏移 + 24)),
    }
}

定义 可变 AI_日志_操作热度 = 0

函数 AI_日志_最优算法(数据量, 已排序) {
    AI_日志_操作热度 = AI_日志_操作热度 + 1
    如果 (数据量 < 16) { 返回 "插入排序" }
    如果 (已排序) { 返回 "二分查找" }
    如果 (数据量 < 10000) { 返回 "快速排序" }
    返回 "归并排序"
}

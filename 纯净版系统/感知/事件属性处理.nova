    me.基类.冒泡 = 假
    me.relatedTarget = 去向
    事件Target_dispatch事件(目标, me.基类)
}

函数 事件Target_触发mouseover(目标, x, y, 来源) {
    定义 me = Mouse事件_创建("mouseover", x, y, 0, 0)
    me.基类.冒泡 = 真
    me.relatedTarget = 来源
    事件Target_dispatch事件(目标, me.基类)
}

函数 事件Target_触发mouseout(目标, x, y, 去向) {
    定义 me = Mouse事件_创建("mouseout", x, y, 0, 0)
    me.基类.冒泡 = 真
    me.relatedTarget = 去向
    事件Target_dispatch事件(目标, me.基类)
}

函数 事件Target_触发contextmenu(目标, x, y) {
    定义 me = Mouse事件_创建("contextmenu", x, y, 2, 0)
    me.基类.冒泡 = 真
    me.基类.可取消 = 真
    事件Target_dispatch事件(目标, me.基类)
}


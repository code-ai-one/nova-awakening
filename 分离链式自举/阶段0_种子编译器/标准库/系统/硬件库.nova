// Nova 硬件访问标准库 v2.0 — 龙·底层硬件接口 + 字符串工具 + 绘图引擎
// 通过 加载库/获取函数/调用指针 动态调用 Windows API
// 涵盖: 屏幕/鼠标/键盘/窗口/时间/内存/文件系统/音频/进程

导入("../../运行时/原语桩.nova")
导入("../基础.nova")
导入("../../自举兼容桥.nova")

// DLL 句柄缓存 (全局)
定义 可变 _内核32库 = 0
定义 可变 _用户32库 = 0
定义 可变 _图形32库 = 0

// 基础文件IO
函数 写文件(文件名, 数据, 大小) { 定义 k = _初始化内核()
 定义 创建文件 = 获取函数(k, "CreateFileA")
 定义 写入文件 = 获取函数(k, "WriteFile")
 定义 关闭句柄 = 获取函数(k, "CloseHandle")
 定义 句柄 = 调用指针(创建文件, 文件名, 0x40000000, 0, 2, 0x80)
 如果 (句柄 == -1) { 返回 0 }
 调用指针(写入文件,  句柄,  数据,  大小,  已写, 0)
 调用指针(关闭句柄,  句柄, 0, 0, 0, 0)
 返回 1
}

// DLL 初始化
函数 _初始化内核() {
    如果 (_内核32库 == 0) { _内核32库 = 加载库("kernel32.dll")
}
 返回 _内核32库
}
函数 _初始化用户() {
    如果 (_用户32库 == 0) { _用户32库 = 加载库("user32.dll")
}
 返回 _用户32库
}
函数 _初始化图形() {
    如果 (_图形32库 == 0) { _图形32库 = 加载库("gdi32.dll")
}
 返回 _图形32库
}

// 函数指针缓存
定义 可变 _函数_节拍 = 0
定义 可变 _函数_睡眠 = 0
定义 可变 _函数_查询性能计数 = 0
定义 可变 _函数_查询性能频率 = 0
定义 可变 _函数_获取系统度量 = 0
定义 可变 _函数_消息框 = 0
定义 可变 _函数_获取设备上下文 = 0
定义 可变 _函数_释放设备上下文 = 0
定义 可变 _函数_获取像素 = 0
定义 可变 _函数_设置像素 = 0
定义 可变 _函数_获取异步键状态 = 0
定义 可变 _函数_获取光标位置 = 0
定义 可变 _函数_设光标位置 = 0
定义 可变 _函数_显示光标 = 0
定义 可变 _函数_查找窗口 = 0
定义 可变 _函数_获取文件属性 = 0
定义 可变 _函数_移动文件 = 0
定义 可变 _函数_删除文件 = 0
定义 可变 _函数_蜂鸣 = 0
定义 可变 _函数_获取进程ID = 0
定义 可变 _函数_设代码页 = 0

// 第一章: 时间与系统

// 获取系统运行毫秒数
函数 时间戳() { _初始化内核()
 如果 (_函数_节拍 == 0) { _函数_节拍 = 获取函数(_内核32库, "GetTickCount64") }
 返回 调用指针(_函数_节拍, 0, 0, 0, 0, 0)
}

// 睡眠指定毫秒
函数 睡眠(毫秒) { _初始化内核()
 如果 (_函数_睡眠 == 0) { _函数_睡眠 = 获取函数(_内核32库, "Sleep") }
 调用指针(_函数_睡眠,  毫秒, 0, 0, 0, 0)
}

// 高精度计时器 (返回计数值)
函数 高精度计时() { _初始化内核()
 如果 (_函数_查询性能计数 == 0) { _函数_查询性能计数 = 获取函数(_内核32库, "QueryPerformanceCounter") }
 定义 缓冲 = 缓冲区(8)
 调用指针(_函数_查询性能计数,  缓冲, 0, 0, 0, 0)
 返回 内存读(缓冲)
}

// 高精度计时频率
函数 计时频率() { _初始化内核()
 如果 (_函数_查询性能频率 == 0) { _函数_查询性能频率 = 获取函数(_内核32库, "QueryPerformanceFrequency") }
 定义 缓冲 = 缓冲区(8)
 调用指针(_函数_查询性能频率,  缓冲, 0, 0, 0, 0)
 返回 内存读(缓冲)
}

// 获取当前进程ID
函数 进程号() { _初始化内核()
 如果 (_函数_获取进程ID == 0) { _函数_获取进程ID = 获取函数(_内核32库, "GetCurrentProcessId") }
 返回 调用指针(_函数_获取进程ID, 0, 0, 0, 0, 0)
}

// 蜂鸣器
函数 蜂鸣(频率, 毫秒) { _初始化内核()
 如果 (_函数_蜂鸣 == 0) { _函数_蜂鸣 = 获取函数(_内核32库, "Beep") }
 调用指针(_函数_蜂鸣,  频率,  毫秒, 0, 0, 0)
}

// 设置控制台代码页 (65001=UTF-8)
函数 设置编码(代码页) { _初始化内核()
 如果 (_函数_设代码页 == 0) { _函数_设代码页 = 获取函数(_内核32库, "SetConsoleOutputCP") }
 调用指针(_函数_设代码页,  代码页, 0, 0, 0, 0)
}

// 第二章: 屏幕与显示

// 获取屏幕宽度 (像素)
函数 屏幕宽度() { _初始化用户()
 如果 (_函数_获取系统度量 == 0) { _函数_获取系统度量 = 获取函数(_用户32库, "GetSystemMetrics") }
 返回 调用指针(_函数_获取系统度量, 0, 0, 0, 0, 0)
}

// 获取屏幕高度 (像素)
函数 屏幕高度() { _初始化用户()
 如果 (_函数_获取系统度量 == 0) { _函数_获取系统度量 = 获取函数(_用户32库, "GetSystemMetrics") }
 返回 调用指针(_函数_获取系统度量,  1, 0, 0, 0, 0)
}

// 获取屏幕设备上下文 (HDC)
函数 获取屏幕DC() { _初始化用户()
 如果 (_函数_获取设备上下文 == 0) { _函数_获取设备上下文 = 获取函数(_用户32库, "GetDC") }
 返回 调用指针(_函数_获取设备上下文, 0, 0, 0, 0, 0)
}

// 释放设备上下文
函数 释放DC(dc) { _初始化用户()
 如果 (_函数_释放设备上下文 == 0) { _函数_释放设备上下文 = 获取函数(_用户32库, "ReleaseDC") }
 调用指针(_函数_释放设备上下文,  0,  dc, 0, 0, 0)
}

// 读取屏幕像素颜色 (回 RGB)
函数 读像素(x, y) { _初始化图形()
 如果 (_函数_获取像素 == 0) { _函数_获取像素 = 获取函数(_图形32库, "GetPixel") }
 定义 dc = 获取屏幕DC()
 定义 颜色 = 调用指针(_函数_获取像素,  dc,  x,  y, 0, 0)
 释放DC(dc)
 返回 颜色
}

// 设置屏幕像素颜色
函数 写像素(x, y, 颜色) { _初始化图形()
 如果 (_函数_设置像素 == 0) { _函数_设置像素 = 获取函数(_图形32库, "SetPixel") }
 定义 dc = 获取屏幕DC()
 调用指针4(_函数_设置像素, dc, x, y, 颜色)
 释放DC(dc)
}

// 颜色分量提取
函数 红色分量(颜色) { 返回 颜色 & 0xFF }
函数 绿色分量(颜色) { 返回 (颜色 >> 8) & 0xFF }
函数 蓝色分量(颜色) { 返回 (颜色 >> 16) & 0xFF }

// 组合 RGB 颜色
函数 组合颜色(r, g, b) { 返回 r | (g << 8) | (b << 16) }

// 第三章: 鼠标控制

// 获取鼠标位置 → [x, y]
函数 鼠标位置() { _初始化用户()
 如果 (_函数_获取光标位置 == 0) { _函数_获取光标位置 = 获取函数(_用户32库, "GetCursorPos") }
 定义 缓冲 = 缓冲区(16)
 调用指针(_函数_获取光标位置,  缓冲, 0, 0, 0, 0)
 定义 x = 内存读32(缓冲)
 定义 y = 内存读32(缓冲 + 4)
 返回 [x, y]
}

// 设置鼠标位置
函数 移动鼠标(x, y) { _初始化用户()
 如果 (_函数_设光标位置 == 0) { _函数_设光标位置 = 获取函数(_用户32库, "SetCursorPos") }
 调用指针(_函数_设光标位置,  x,  y, 0, 0, 0)
}

// 第四章: 键盘输入

// 检测按键是否按下 (虚拟键码)
函数 按键状态(键码) { _初始化用户()
 如果 (_函数_获取异步键状态 == 0) { _函数_获取异步键状态 = 获取函数(_用户32库, "GetAsyncKeyState") }
 定义 r = 调用指针(_函数_获取异步键状态,  键码, 0, 0, 0, 0)
 返回 r & 0x8000
}


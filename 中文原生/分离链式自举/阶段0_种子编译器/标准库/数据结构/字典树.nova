//    每条从根到叶的路径是一个"词" (字的串联)
//    前缀搜索是量词态射: 字→词 (部分匹配)
//    插入是态射: 词→棵 (词嵌入树)
//    插入 = "给"字操作 (词交给树)
//    删除 = "把"字消费 (把词从树中取出)
//    查找 = "被"字借用 (词被读取不消费)

导入("../基础.nova")

函数 trie_创建节点() {
    返回 [字典(), 0, 空, 0]
}

函数 字典树_trie_创建() { 返回 [trie_创建节点(), 0] }
函数 trie_根(t) { 返回 t[0] }
函数 trie_词数(t) { 返回 t[1] }

// 插入
函数 字典树_trie_插入(t, 键, 值) {
    定义 可变 节点 = trie_根(t)
    定义 可变 i = 0
    当 (i < 字节长度(键)) {
        定义 c = 字符(字节取(键, i))
        节点[3] = 节点[3] + 1
        定义 可变 子 = 字典取(节点[0], c)
        如果 (子 == 空) {
            子 = trie_创建节点()
            字典设(节点[0], c, 子)
        }
        节点 = 子
        i = i + 1
    }
    节点[3] = 节点[3] + 1
    如果 (节点[1] == 0) { t[1] = t[1] + 1 }
    节点[1] = 1
    节点[2] = 值
}

// 查找
函数 trie_查找(t, 键) {
    定义 可变 节点 = trie_根(t)
    定义 可变 i = 0
    当 (i < 字节长度(键)) {
        定义 c = 字符(字节取(键, i))
        定义 可变 子 = 字典取(节点[0], c)
        如果 (子 == 空) { 返回 空 }
        节点 = 子
        i = i + 1
    }
    如果 (节点[1] == 1) { 返回 节点[2] }
    返回 空
}

// 是否包含
函数 trie_包含(t, 键) {
    返回 trie_查找(t, 键) != 空
}

// 前缀是否存在
函数 trie_有前缀(t, 前缀) {
    定义 可变 节点 = trie_根(t)
    定义 可变 i = 0
    当 (i < 字节长度(前缀)) {
        定义 c = 字符(字节取(前缀, i))
        定义 可变 子 = 字典取(节点[0], c)
        如果 (子 == 空) { 返回 0 }
        节点 = 子
        i = i + 1
    }
    返回 1
}

// 前缀计数 (以该前缀开头的键数量)
函数 trie_前缀计数(t, 前缀) {
    定义 可变 节点 = trie_根(t)
    定义 可变 i = 0
    当 (i < 字节长度(前缀)) {
        定义 c = 字符(字节取(前缀, i))
        定义 可变 子 = 字典取(节点[0], c)
        如果 (子 == 空) { 返回 0 }
        节点 = 子
        i = i + 1
    }
    返回 节点[3]
}

// 总键数
函数 字典树_trie_大小(t) {
    返回 trie_大小递归(trie_根(t))
}

函数 trie_大小递归(节点) {
    定义 可变 总 = 0
    如果 (节点[1] == 1) { 总 = 1 }
    定义 键列 = 字典键列表(节点[0])
    定义 可变 i = 0
    当 (i < 计数(键列)) {
        总 = 总 + trie_大小递归(字典取(节点[0], 键列[i]))
        i = i + 1
    }
    返回 总
}

// 理论驱动新功能

函数 trie_气韵路径(t, 前缀) {
    定义 可变 节点 = trie_根(t)
    定义 可变 流量 = []
    追加(流量, 节点[3])
    定义 可变 i = 0
    当 (i < 字节长度(前缀)) {
        定义 c = 字符(字节取(前缀, i))
        定义 可变 子 = 字典取(节点[0], c)
        如果 (子 == 空) { 返回 流量 }
        节点 = 子
        追加(流量, 节点[3])
        i = i + 1
    }
    返回 流量
}

函数 trie_气韵衰减(t, 前缀) {
    定义 流量 = trie_气韵路径(t, 前缀)
    如果 (计数(流量) < 2) { 返回 0 }
    定义 起始 = 流量[0]
    如果 (计数(流量) == 0) { 返回 空 }
    定义 末端 = 流量[计数(流量) - 1]
    如果 (起始 == 0) { 返回 100 }
    返回 (起始 - 末端) * 100 / 起始
}

// 量词深度: 从根到最深终止节点的最大深度
函数 trie_最大深度(t) {
    返回 trie_深度递归(trie_根(t), 0)
}

函数 trie_深度递归(节点, 深度) {
    定义 可变 最大 = 0
    如果 (节点[1] == 1) { 最大 = 深度 }
    定义 键列 = 字典键列表(节点[0])
    定义 可变 i = 0
    当 (i < 计数(键列)) {
        定义 子深 = trie_深度递归(字典取(节点[0], 键列[i]), 深度 + 1)
        如果 (子深 > 最大) { 最大 = 子深 }
        i = i + 1
    }
    返回 最大
}

// 前缀枚举

函数 trie_前缀节点(t, 前缀) {
    定义 可变 节点 = trie_根(t)
    定义 可变 i = 0
    当 (i < 字节长度(前缀)) {
        定义 c = 字符(字节取(前缀, i))
        定义 可变 子 = 字典取(节点[0], c)
        如果 (子 == 空) { 返回 空 }
        节点 = 子
        i = i + 1
    }
    返回 节点
}

函数 trie_收集词(节点, 前缀, 结果) {
    如果 (节点[1] == 1) {
        追加(结果, [前缀, 节点[2]])
    }
    定义 键列 = 字典键列表(节点[0])
    定义 可变 i = 0
    当 (i < 计数(键列)) {
        定义 子键 = 键列[i]
        定义 子节点 = 字典取(节点[0], 子键)
        trie_收集词(子节点, 前缀 + 子键, 结果)
        i = i + 1
    }
}

函数 trie_前缀枚举(t, 前缀) {
    定义 节点 = trie_前缀节点(t, 前缀)
    如果 (节点 == 空) { 返回 [] }
    定义 可变 结果 = []
    trie_收集词(节点, 前缀, 结果)
    返回 结果
}

// 自动补全

函数 trie_自动补全(t, 前缀, 最大数) {
    定义 全部 = trie_前缀枚举(t, 前缀)
    如果 (计数(全部) <= 最大数) { 返回 全部 }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 最大数) { 追加(结果, 全部[i])  i = i + 1 }
    返回 结果
}

// 删除

函数 trie_删除(t, 键) {
    定义 可变 路径 = []
    定义 可变 节点 = trie_根(t)
    定义 可变 i = 0
    当 (i < 字节长度(键)) {
        定义 c = 字符(字节取(键, i))
        定义 可变 子 = 字典取(节点[0], c)
        如果 (子 == 空) { 返回 假 }
        追加(路径, [节点, c])
        节点 = 子
        i = i + 1
    }
    如果 (节点[1] != 1) { 返回 假 }
    节点[1] = 0
    节点[2] = 空
    t[1] = t[1] - 1
    // 回溯减少流量
    i = 计数(路径) - 1
    当 (i >= 0) {
        路径[i][0][3] = 路径[i][0][3] - 1
        i = i - 1
    }
    返回 真
}

// 模糊匹配 (编辑距离1)

函数 trie_模糊搜索(t, 查询, 最大距离) {
    定义 可变 结果 = []
    trie_模糊递归(trie_根(t), "", 查询, 0, 最大距离, 结果)
    返回 结果
}

函数 trie_模糊递归(节点, 当前词, 目标, 当前距离, 最大距离, 结果) {
    定义 可变 新距离 = 0
    如果 (当前距离 > 最大距离) { 返回 空 }
    定义 目标长 = 字节长度(目标)
    定义 当前长 = 字节长度(当前词)
    如果 (节点[1] == 1) {
        定义 可变 剩余 = 目标长 - 当前长
        如果 (剩余 < 0) { 剩余 = 0 - 剩余 }
        如果 (当前距离 + 剩余 <= 最大距离) {
            追加(结果, [当前词, 节点[2], 当前距离 + 剩余])
        }
    }
    定义 键列 = 字典键列表(节点[0])
    定义 可变 i = 0
    当 (i < 计数(键列)) {
        定义 子键 = 键列[i]
        定义 子节点 = 字典取(节点[0], 子键)
        如果 (当前长 < 目标长) {
            定义 期望字符 = 字符(字节取(目标, 当前长))
            如果 (子键 != 期望字符) { 新距离 = 新距离 + 1 }
        } 否则 {
            新距离 = 新距离 + 1
        }
        trie_模糊递归(子节点, 当前词 + 子键, 目标, 新距离, 最大距离, 结果)
        i = i + 1
    }
}

// 最长公共前缀

函数 trie_最长公共前缀(t) {
    定义 可变 节点 = trie_根(t)
    定义 可变 前缀 = ""
    当 (真) {
        定义 键列 = 字典键列表(节点[0])
        如果 (计数(键列) != 1) { 返回 前缀 }
        如果 (节点[1] == 1) { 返回 前缀 }
        定义 唯一键 = 键列[0]
        前缀 = 前缀 + 唯一键
        节点 = 字典取(节点[0], 唯一键)
    }
    返回 前缀
}

// 批量操作

函数 字典树_trie_批量插入(t, 键值对列表) {
    定义 可变 i = 0
    当 (i < 计数(键值对列表)) {
        字典树_trie_插入(t, 键值对列表[i][0], 键值对列表[i][1])
        i = i + 1
    }
}

函数 trie_批量查询(t, 键列表) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        追加(结果, trie_查找(t, 键列表[i]))
        i = i + 1
    }
    返回 结果
}

函数 trie_批量删除(t, 键列表) {
    定义 可变 删除数 = 0
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        如果 (trie_删除(t, 键列表[i])) { 删除数 = 删除数 + 1 }
        i = i + 1
    }
    返回 删除数
}

// 统计信息

函数 trie_节点计数(节点) {
    定义 可变 总 = 1
    定义 键列 = 字典键列表(节点[0])
    定义 可变 i = 0
    当 (i < 计数(键列)) {
        总 = 总 + trie_节点计数(字典取(节点[0], 键列[i]))
        i = i + 1
    }
    返回 总
}

函数 trie_总节点数(t) {
    返回 trie_节点计数(trie_根(t))
}

函数 trie_内存估算(t) {
    返回 trie_总节点数(t) * 48  // 每节点约48字节
}

// 前缀计数

函数 trie_前缀词数(t, 前缀) {
    定义 节点 = trie_前缀节点(t, 前缀)
    如果 (节点 == 空) { 返回 0 }
    返回 节点[3]
}

定义 可变 _trie_插入数 = 0
定义 可变 _trie_查询数 = 0
定义 可变 _trie_模糊数 = 0

函数 trie_记录插入() { _trie_插入数 = _trie_插入数 + 1 }
函数 trie_记录查询() { _trie_查询数 = _trie_查询数 + 1 }
函数 trie_记录模糊() { _trie_模糊数 = _trie_模糊数 + 1 }

导入("../数学/决策树.nova")

// 概率计算引擎 (Probabilistic Computing Engine)
// 超越确定性0/1: 每个值携带概率分布信息
// 贝叶斯推理 + 概率编程 + 不确定性传播
// 纯整数定点 (精度=10000, 概率0~10000 = 0.0000~1.0000)

定义 概率计算引擎_概率精度 = 10000

// 概率值 (Probabilistic Value)
// 每个值不是单一数字,而是离散概率分布
函数 概率值_创建(取值列表, 概率列表) {
 // 归一化概率使其和为精度
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < 计数(概率列表)) {
 总和 = 总和 + 概率列表[i]
 i = i + 1
 }
 如果 (总和 == 0) { 返回 [取值列表, 概率列表] }

 定义 可变 归一化 = []
 i = 0
 当 (i < 计数(概率列表)) {
 追加(归一化, 概率列表[i] * 概率计算引擎_概率精度 / 总和)
 i = i + 1
 }
 返回 [取值列表, 归一化]
}

// 确定性值 → 概率值 (退化分布)
函数 概率值_确定(值) { 返回 [[值], [概率计算引擎_概率精度]]
}

// 期望值 E[X] = Σ x·P(x)
函数 概率值_期望(概率值) { 定义 取值 = 概率值[0]
 定义 概率 = 概率值[1]
 定义 可变 期望 = 0
 定义 可变 i = 0
 当 (i < 计数(取值)) {
 期望 = 期望 + 取值[i] * 概率[i] / 概率计算引擎_概率精度
 i = i + 1
 }
 返回 期望
}

// 方差 Var[X] = E[X²] - E[X]²
函数 概率值_方差(概率值) { 定义 取值 = 概率值[0]
 定义 概率 = 概率值[1]
 定义 期望 = 概率值_期望(概率值)

 定义 可变 平方期望 = 0
 定义 可变 i = 0
 当 (i < 计数(取值)) {
 平方期望 = 平方期望 + 取值[i] * 取值[i] * 概率[i] / 概率计算引擎_概率精度
 i = i + 1
 }
 如果 (概率计算引擎_概率精度 == 0) { 返回 0 }
 返回 平方期望 - 期望 * 期望 / 概率计算引擎_概率精度
}

// 概率加法: Z = X + Y
函数 概率值_加(A, B) { 定义 取值A = A[0]
 定义 概率A = A[1]
 定义 取值B = B[0]
 定义 概率B = B[1]

 定义 可变 新取值 = []
 定义 可变 新概率 = []

 定义 可变 i = 0
 当 (i < 计数(取值A)) { 定义 可变 j = 0
 当 (j < 计数(取值B)) { 定义 和值 = 取值A[i] + 取值B[j]
 定义 联合概率 = 概率A[i] * 概率B[j] / 概率计算引擎_概率精度

 // 合并相同取值
 定义 可变 已有 = 0
 定义 可变 k = 0
 当 (k < 计数(新取值)) { 如果 (新取值[k] == 和值) {
 新概率[k] = 新概率[k] + 联合概率
 已有 = 1
 }
 k = k + 1
 }
 如果 (已有 == 0) {
 追加(新取值, 和值)
 追加(新概率, 联合概率)
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 [新取值, 新概率]
}

// 概率乘法: Z = X × Y
函数 概率值_乘(A, B) { 定义 取值A = A[0]
 定义 概率A = A[1]
 定义 取值B = B[0]
 定义 概率B = B[1]

 定义 可变 新取值 = []
 定义 可变 新概率 = []

 定义 可变 i = 0
 当 (i < 计数(取值A)) { 定义 可变 j = 0
 当 (j < 计数(取值B)) { 定义 积值 = 取值A[i] * 取值B[j] / 概率计算引擎_概率精度
 定义 联合概率 = 概率A[i] * 概率B[j] / 概率计算引擎_概率精度
 定义 可变 已有 = 0
 定义 可变 k = 0
 当 (k < 计数(新取值)) { 如果 (新取值[k] == 积值) {
 新概率[k] = 新概率[k] + 联合概率
 已有 = 1
 }
 k = k + 1
 }
 如果 (已有 == 0) {
 追加(新取值, 积值)
 追加(新概率, 联合概率)
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 [新取值, 新概率]
}

// 贝叶斯推理 (Bayesian Inference)
// P(A|B) = P(B|A) × P(A) / P(B)

// 贝叶斯网络节点
函数 贝叶斯节点_创建(名称, 状态数) { 定义 可变 先验 = []
 定义 可变 i = 0
 当 (i < 状态数) {
 追加(先验, 概率计算引擎_概率精度 / 状态数) // 均匀先验
 i = i + 1
 }
 返回 [
 名称, // [0]
 状态数, // [1]
 先验, // [2] 先验/当前信念
 [], // [3] 父节点列表
 [], // [4] 条件概率表 (CPT)
 先验 // [5] 后验概率
 ]
}

// 设置条件概率表
// CPT格式: [父状态组合索引][本节点状态] = 概率
函数 贝叶斯节点_设CPT(节点, CPT) {
 节点[4] = CPT
}

// 贝叶斯更新: 观察到证据后更新信念
函数 贝叶斯更新(节点, 似然) { 定义 先验 = 节点[2]
    定义 可变 后验 = []
    定义 可变 证据 = 0
 定义 状态数 = 节点[1]

 // P(H|E) ∝ P(E|H) × P(H)
 定义 可变 i = 0
 当 (i < 状态数) { 定义 未归一 = 似然[i] * 先验[i] / 概率计算引擎_概率精度
 追加(后验, 未归一)
 证据 = 证据 + 未归一
 i = i + 1
 }

 // 归一化
 如果 (证据 > 0) {
 i = 0
 当 (i < 状态数) {
 后验[i] = 后验[i] * 概率计算引擎_概率精度 / 证据
 i = i + 1
 }
 }

 节点[5] = 后验
 返回 后验
}

// 序贯贝叶斯更新 (在线学习)
函数 贝叶斯序贯更新(节点, 观察序列) { 定义 可变 i = 0
 当 (i < 计数(观察序列)) {
 贝叶斯更新(节点, 观察序列[i])
 // 后验变为下一步的先验
 节点[2] = 节点[5]
 i = i + 1
 }
 返回 节点[5]
}

// 马尔可夫链蒙特卡洛 (MCMC简化)
// Metropolis-Hastings采样
函数 MCMC_采样(目标分布, 初始状态, 步数, 步长) { 定义 可变 样本 = []
 定义 可变 当前 = 初始状态
 定义 可变 当前概率 = 0

 // 评估初始概率
 定义 可变 k = 0
 当 (k < 计数(目标分布[0])) { 定义 可变 差 = 当前 - 目标分布[0][k]
 如果 (差 < 0) { 差 = 0 - 差 }
 如果 (差 < 步长) {
 当前概率 = 目标分布[1][k]
 }
 k = k + 1
 }

 定义 可变 t = 0
 当 (t < 步数) {
 // 提议新状态 (对称随机游走)
 定义 扰动 = ((t * 1103515245 + 12345) % (步长 * 2)) - 步长
 定义 候选 = 当前 + 扰动

 // 评估候选概率
 定义 可变 候选概率 = 0
 k = 0
 当 (k < 计数(目标分布[0])) { 定义 可变 差 = 候选 - 目标分布[0][k]
 如果 (差 < 0) { 差 = 0 - 差 }
 如果 (差 < 步长) {
 候选概率 = 目标分布[1][k]
 }
 k = k + 1
 }

 // Metropolis准则: 接受概率 = min(1, P(候选)/P(当前))
 定义 可变 接受 = 0
 如果 (当前概率 == 0 或 候选概率 >= 当前概率) {
 接受 = 1
 } 否则 {
 // 以P(候选)/P(当前)的概率接受
 定义 比率 = 候选概率 * 概率计算引擎_概率精度 / 当前概率
 定义 随机 = ((t * 48271 + 7) % 概率计算引擎_概率精度)
 如果 (随机 < 比率) { 接受 = 1 }
 }

 如果 (接受 == 1) {
 当前 = 候选
 当前概率 = 候选概率
 }

 追加(样本, 当前)
 t = t + 1
 }
 返回 样本
}

// 不确定性传播 (Uncertainty Propagation)
// 通过计算图传播不确定性

// 区间算术: 用[下界, 上界]表示不确定范围
函数 概率计算_区间_创建(下, 上) {
    如果 (下 > 上) { 返回 [上, 下]
}
 返回 [下, 上]
}

函数 概率计算_区间_加(A, B) { 返回 [A[0] + B[0], A[1] + B[1]]
}

函数 概率计算_区间_乘(A, B) { 定义 p1 = A[0] * B[0] / 概率计算引擎_概率精度
 定义 p2 = A[0] * B[1] / 概率计算引擎_概率精度
 定义 p3 = A[1] * B[0] / 概率计算引擎_概率精度
 定义 p4 = A[1] * B[1] / 概率计算引擎_概率精度

 定义 可变 最小 = p1
 如果 (p2 < 最小) { 最小 = p2 }
 如果 (p3 < 最小) { 最小 = p3 }
 如果 (p4 < 最小) { 最小 = p4 }

 定义 可变 最大 = p1
 如果 (p2 > 最大) { 最大 = p2 }
 如果 (p3 > 最大) { 最大 = p3 }
 如果 (p4 > 最大) { 最大 = p4 }

 返回 [最小, 最大]
}

// 区间宽度 = 不确定性度量
函数 区间_不确定性(区间) { 返回 区间[1] - 区间[0]
}

// 信息熵 (Information Entropy, 0)
// H(X) = -Σ P(x)·log₂(P(x))

// 定点log₂近似 (输入×10000, 输出×10000)
函数 定点log2(x) { 如果 (x <= 0) { 返回 0 - 概率计算引擎_概率精度 * 20 } // -∞近似
 // 通过移位找整数部分
 定义 可变 整数部 = 0
 定义 可变 v = x
 当 (v >= 概率计算引擎_概率精度 * 2) {
 v = v / 2
 整数部 = 整数部 + 1
 }
 当 (v < 概率计算引擎_概率精度) {
 v = v * 2
 整数部 = 整数部 - 1
 }
 // v ∈ [10000, 20000), 用线性插值近似小数部分
 定义 小数部 = (v - 概率计算引擎_概率精度) * 概率计算引擎_概率精度 / 概率计算引擎_概率精度
 返回 整数部 * 概率计算引擎_概率精度 + 小数部
}

函数 概率计算_信息熵(概率分布) { 定义 可变 熵 = 0
 定义 可变 i = 0
 当 (i < 计数(概率分布)) { 定义 p = 概率分布[i]
 如果 (p > 0 且 p <= 概率计算引擎_概率精度) {
 // -p·log₂(p)
 定义 log值 = 定点log2(p)
 熵 = 熵 - p * log值 / 概率计算引擎_概率精度
 }
 i = i + 1
 }
 // 归一化 (因为概率已×10000)
 如果 (概率计算引擎_概率精度 == 0) { 返回 0 }
 返回 熵 + 计数(概率分布) * 概率计算引擎_概率精度 * 定点log2(概率计算引擎_概率精度) / 概率计算引擎_概率精度
}

// KL散度: D_KL(P||Q) = Σ P(x)·log(P(x)/Q(x))
函数 概率计算引擎_KL散度(P, Q) { 定义 可变 散度 = 0
 定义 可变 i = 0
 当 (i < 计数(P)) { 如果 (P[i] > 0 且 Q[i] > 0) { 定义 比值 = P[i] * 概率计算引擎_概率精度 / Q[i]
 定义 log比 = 定点log2(比值)
 散度 = 散度 + P[i] * log比 / 概率计算引擎_概率精度
 }
 i = i + 1
 }
 返回 散度
}

// 互信息: I(X;Y) = H(X) + H(Y) - H(X,Y)
函数 概率计算引擎_互信息(联合分布, 边缘X, 边缘Y) { 定义 HX = 信息熵(边缘X, 0)
 定义 HY = 信息熵(边缘Y, 0)
 定义 HXY = 信息熵(联合分布, 0)
 返回 HX + HY - HXY
}

// 概率编程基元
// 用于构建概率模型的核心操作

// 离散采样
函数 概率采样(分布, 种子) { 定义 取值 = 分布[0]
 定义 概率 = 分布[1]
 定义 随机 = ((种子 * 1103515245 + 12345) % 概率计算引擎_概率精度)

 定义 可变 累积 = 0
 定义 可变 i = 0
 当 (i < 计数(取值)) {
 累积 = 累积 + 概率[i]
 如果 (随机 < 累积) { 返回 取值[i]
 }
 i = i + 1
 }
 如果 (计数(取值) == 0) { 返回 空 }
 返回 取值[计数(取值) - 1]
}

// 条件化: P(X|条件)
函数 概率条件化(分布, 条件函数结果) { 定义 取值 = 分布[0]
 定义 概率 = 分布[1]
 定义 可变 新取值 = []
 定义 可变 新概率 = []
 定义 可变 总和 = 0

 定义 可变 i = 0
 当 (i < 计数(取值)) { 如果 (条件函数结果[i] > 0) {
 追加(新取值, 取值[i])
 追加(新概率, 概率[i])
 总和 = 总和 + 概率[i]
 }
 i = i + 1
 }

 // 归一化
 如果 (总和 > 0) {
 i = 0
 当 (i < 计数(新概率)) {
 新概率[i] = 新概率[i] * 概率计算引擎_概率精度 / 总和
 i = i + 1
 }
 }
 返回 [新取值, 新概率]
}

// 贝叶斯推理

函数 贝叶斯_后验(先验, 似然, 证据) {
    如果 (证据 == 0) { 返回 0
}
 返回 先验 * 似然 / 证据
}

函数 贝叶斯_链式更新(先验, 似然列表) { 定义 可变 当前 = 先验
 定义 可变 i = 0
 当 (i < 计数(似然列表)) {
 当前 = 当前 * 似然列表[i] / 1000
 i = i + 1
 }
 返回 当前
}

函数 全概率(先验列表, 条件列表) { 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 计数(先验列表)) {
 总 = 总 + 先验列表[i] * 条件列表[i] / 1000
 i = i + 1
 }
 返回 总
}

// 信息论

函数 概率计算_交叉熵(真实, 预测) { 定义 可变 ce = 0
 定义 可变 i = 0
 当 (i < 计数(真实)) { 如果 (预测[i] > 0) { 定义 可变 对数 = 0
 定义 可变 v = 预测[i]
 当 (v >= 2000) { v = v / 2 对数 = 对数 + 1000 }
 ce = ce - 真实[i] * 对数 / 1000
 }
 i = i + 1
 }
 返回 ce
}

定义 可变 _prob_计算次数 = 0
定义 可变 _prob_推理次数 = 0

函数 prob_记录计算() { _prob_计算次数 = _prob_计算次数 + 1 }
函数 prob_记录推理() { _prob_推理次数 = _prob_推理次数 + 1 }

函数 prob_复杂度评估() {
    如果 (_prob_推理次数 == 0) { 返回 "无推理活动"
}
 如果 (_prob_推理次数 > 1000) { 返回 "高频推理(注意性能)" }
 如果 (_prob_推理次数 > 100) { 返回 "中频推理" }
 返回 "低频推理"
}

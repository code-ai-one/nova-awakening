// ARP缓存添加/更新

函数 arp_添加(IP地址, MAC地址, 状态) {
    自旋锁_获取(全局ARP缓存.锁)

    定义 已有 = arp_查找条目(IP地址)
    如果 (已有 != 空) {
        // 更新已有条目
        内存复制(已有.MAC地址, MAC地址, ARP_硬件地址长度)
        已有.状态 = 状态
        已有.最后确认时间 = 当前时间_秒()
        已有.重试次数 = 0

        // 发送等待队列中的包
        arp_发送等待队列(已有)

        自旋锁_释放(全局ARP缓存.锁)
        返回
    }

    // 创建新条目
    定义 可变 新条目 = 分配内存(大小(ARP缓存条目))
    新条目.IP地址 = IP地址
    内存复制(新条目.MAC地址, MAC地址, ARP_硬件地址长度)
    新条目.状态 = 状态
    新条目.创建时间 = 当前时间_秒()
    新条目.最后确认时间 = 当前时间_秒()
    新条目.重试次数 = 0
    新条目.等待队列 = 空

    定义 桶号 = arp_哈希(IP地址)
    新条目.下一个 = 全局ARP缓存.桶[桶号]
    全局ARP缓存.桶[桶号] = 新条目
    全局ARP缓存.条目数 = 全局ARP缓存.条目数 + 1

    自旋锁_释放(全局ARP缓存.锁)
}

函数 arp_添加永久(IP地址, MAC地址) {
    arp_添加(IP地址, MAC地址, ARP_状态_永久)
}

函数 arp_删除(IP地址) {
    定义 桶号 = arp_哈希(IP地址)
    自旋锁_获取(全局ARP缓存.锁)

    定义 可变 前一个 = 空
    定义 可变 当前 = 全局ARP缓存.桶[桶号]
    当 (当前 != 空) {
        如果 (当前.IP地址 == IP地址) {
            如果 (前一个 == 空) {
                全局ARP缓存.桶[桶号] = 当前.下一个
            } 否则 {
                前一个.下一个 = 当前.下一个
            }
            // 释放等待队列
            arp_清空等待队列(当前)
            释放内存(当前)
            全局ARP缓存.条目数 = 全局ARP缓存.条目数 - 1
            跳出
        }
        前一个 = 当前
        当前 = 当前.下一个
    }

    自旋锁_释放(全局ARP缓存.锁)
}

// ARP请求发送

函数 arp_请求(目标IP, 设备) {
    定义 源IP = 设备.ip地址
    定义 源MAC = 设备.mac地址

    定义 可变 Nova缓冲 = Nova缓冲_分配(14 + ARP_包_大小)
    如果 (Nova缓冲 == 空) { 返回 错误码_内存不足 }

    // 以太网头
    定义 可变 eth = Nova缓冲.数据
    // 目标MAC = 广播
    定义 可变 i = 0
    当 (i < 6) { eth[i] = 0xFF; i = i + 1 }
    内存复制(eth + 6, 源MAC, 6)
    网络序_写u16(eth, 12, 以太网类型_ARP)

    // ARP包
    定义 可变 arp = eth + 14
    网络序_写u16(arp, 0, ARP_硬件类型_以太网)
    网络序_写u16(arp, 2, ARP_协议类型_IPv4)
    arp[4] = ARP_硬件地址长度
    arp[5] = ARP_协议地址长度
    网络序_写u16(arp, 6, ARP_操作_请求)

    // 发送方
    内存复制(arp + 8, 源MAC, 6)
    网络序_写u32(arp, 14, 源IP)

    // 目标(MAC为0)
    内存置零(arp + 18, 6)
    网络序_写u32(arp, 24, 目标IP)

    Nova缓冲.数据长度 = 14 + ARP_包_大小
    Nova缓冲.设备 = 设备

    // 创建不完整缓存条目
    定义 已有 = arp_查找条目(目标IP)
    如果 (已有 == 空) {
        定义 零MAC = [0, 0, 0, 0, 0, 0]
        arp_添加(目标IP, 零MAC, ARP_状态_不完整)
    }

    返回 网络设备_发送(设备, Nova缓冲)
}

// 基64编码 — NovaOS 企业级Base64编解码子系统 (B64E)
// 理论基础: B64E (Base64 Encoding Engine)
//   RFC 4648完整实现 + URL-safe变体 + MIME行包装
//   流式编解码(chunk分块) + 256字节反查表 + 输入验证
// 创新公式:
//   EncodeLen(n) = ceil(n/3) × 4
//   DecodeLen(n) = floor(n/4) × 3 - padding_count
//   Triplet(a,b,c) = [a>>2, (a&3)<<4|b>>4, (b&0xF)<<2|c>>6, c&0x3F]
// 架构: 12部分 — 常量/查找表/编码/解码/URL-safe/MIME/
//            流式编码/流式解码/验证/工具函数/AI集成/统计

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/内核打印.nova")
导入("../推理/值乘.nova")
导入("../推理/智能总线资源.nova")
导入("../中枢/字符串替换.nova")

// 第1部分: 常量与编码表

定义 B64_标准表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
定义 B64_URL安全表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"
定义 B64_PAD = 0x3D        // '='
定义 MIME_行宽 = 76       // MIME每行76字符
定义 流式_块大小 = 3072    // 3KB分块(必3的倍数)

结构 B64E统计 {
    编码次数, 解码次数,
    编码字节数, 解码字节数,
    验证次数, 验证失败数,
    URL安全编码数, MIME编码数,
    流式编码数, 流式解码数,
    AI预测数,
}

定义 可变 全局B64E统计 = B64E统计 {}

// 第2部分: 反查表构建

函数 Base64_字符值(c) {
    如果 (c >= 0x41 && c <= 0x5A) { 返回 c - 0x41 }       // A-Z
    如果 (c >= 0x61 && c <= 0x7A) { 返回 c - 0x61 + 26 }  // a-z
    如果 (c >= 0x30 && c <= 0x39) { 返回 c - 0x30 + 52 }  // 0-9
    如果 (c == 0x2B) { 返回 62 }  // +
    如果 (c == 0x2F) { 返回 63 }  // /
    如果 (c == 0x2D) { 返回 62 }  // - (URL-safe)
    如果 (c == 0x5F) { 返回 63 }  // _ (URL-safe)
    返回 0xFF  // 无效/padding
}

函数 Base64_编码长度(数据长度) {
    // EncodeLen(n) = ceil(n/3) × 4
    返回 ((数据长度 + 2) / 3) * 4
}

函数 Base64_解码长度(文本长度) {
    // DecodeLen(n) = floor(n/4) × 3
    返回 (文本长度 / 4) * 3
}

// 第3部分: 标准Base64编码 (RFC 4648 §4)

函数 Base64_编码(数据, 长度) {
    全局B64E统计.编码次数 = 全局B64E统计.编码次数 + 1
    全局B64E统计.编码字节数 = 全局B64E统计.编码字节数 + 长度
    返回 Base64_编码_内部(数据, 长度, B64_标准表, 真)
}

函数 Base64_编码_内部(数据, 长度, 表, 填充) {
    如果 (数据 == 0 || 长度 == 0) { 返回 0 }
    定义 输出长度 = Base64_编码长度(长度)
    定义 输出 = 堆_分配(输出长度 + 1)
    如果 (输出 == 0) { 返回 0 }
    定义 可变 si = 0
    定义 可变 di = 0

    // 主循环: 每次3字节 → 4字符
    当 (si + 2 < 长度) {
        定义 a = 内存_读8(数据 + si)
        定义 b = 内存_读8(数据 + si + 1)
        定义 c = 内存_读8(数据 + si + 2)
        // Triplet(a,b,c) = [a>>2, (a&3)<<4|b>>4, (b&0xF)<<2|c>>6, c&0x3F]
        内存_写8(输出 + di,     内存_读8(表 + (a >> 2)))
        内存_写8(输出 + di + 1, 内存_读8(表 + ((a & 3) << 4 | (b >> 4))))
        内存_写8(输出 + di + 2, 内存_读8(表 + ((b & 0xF) << 2 | (c >> 6))))
        内存_写8(输出 + di + 3, 内存_读8(表 + (c & 0x3F)))
        si = si + 3
        di = di + 4
    }

    // 尾部处理(1或2字节剩余)
    如果 (si < 长度) {
        定义 a = 内存_读8(数据 + si)
        内存_写8(输出 + di, 内存_读8(表 + (a >> 2)))
        如果 (si + 1 < 长度) {
            定义 b = 内存_读8(数据 + si + 1)
            内存_写8(输出 + di + 1, 内存_读8(表 + ((a & 3) << 4 | (b >> 4))))
            内存_写8(输出 + di + 2, 内存_读8(表 + ((b & 0xF) << 2)))
            如果 (填充) { 内存_写8(输出 + di + 3, B64_PAD) }
        } 否则 {
            内存_写8(输出 + di + 1, 内存_读8(表 + ((a & 3) << 4)))
            如果 (填充) {
                内存_写8(输出 + di + 2, B64_PAD)
                内存_写8(输出 + di + 3, B64_PAD)
            }
        }
        di = di + 4
    }

    内存_写8(输出 + di, 0)  // null终止
    返回 输出
}

// 第4部分: 标准Base64解码

函数 Base64_解码(文本) {
    全局B64E统计.解码次数 = 全局B64E统计.解码次数 + 1
    如果 (文本 == 0) { 返回 [0, 0] }
    定义 长度 = 字符串_长度(文本)
    如果 (长度 == 0) { 返回 [0, 0] }

    定义 输出长度 = Base64_解码长度(长度)
    定义 输出 = 堆_分配(输出长度 + 1)
    如果 (输出 == 0) { 返回 [0, 0] }
    定义 可变 si = 0
    定义 可变 di = 0

    当 (si + 3 < 长度) {
        定义 a = Base64_字符值(内存_读8(文本 + si))
        定义 b = Base64_字符值(内存_读8(文本 + si + 1))
        定义 c = Base64_字符值(内存_读8(文本 + si + 2))
        定义 d = Base64_字符值(内存_读8(文本 + si + 3))
        // 跳过无效字符(空格、换行等)
        如果 (a == 0xFF || b == 0xFF) { si = si + 4; 继续 }
        内存_写8(输出 + di, (a << 2) | (b >> 4))
        di = di + 1
        如果 (c != 0xFF) {
            内存_写8(输出 + di, ((b & 0xF) << 4) | (c >> 2))
            di = di + 1
        }
        如果 (d != 0xFF) {
            内存_写8(输出 + di, ((c & 3) << 6) | d)
            di = di + 1
        }
        si = si + 4
    }

    全局B64E统计.解码字节数 = 全局B64E统计.解码字节数 + di
    返回 [输出, di]
}

// 第5部分: URL-Safe Base64 (RFC 4648 §5)

函数 Base64URL_编码(数据, 长度) {
    // URL-safe: +→-, /→_, 无填充
    全局B64E统计.URL安全编码数 = 全局B64E统计.URL安全编码数 + 1
    返回 Base64_编码_内部(数据, 长度, B64_URL安全表, 假)  // 无padding
}

函数 Base64URL_解码(文本) {
    // URL-safe解码 — 复用标准解码器(反查表已支持-和_)
    返回 Base64_解码(文本)
}

// 第6部分: MIME Base64 (RFC 2045)

函数 Base64MIME_编码(数据, 长度) {
    // MIME: 标准编码 + 每76字符插入\r\n
    全局B64E统计.MIME编码数 = 全局B64E统计.MIME编码数 + 1
    定义 原始 = Base64_编码(数据, 长度)
    如果 (原始 == 0) { 返回 0 }
    定义 原长 = 字符串_长度(原始)
    定义 行数 = (原长 + MIME_行宽 - 1) / MIME_行宽
    定义 输出长 = 原长 + 行数 * 2  // 每行加\r\n
    定义 输出 = 堆_分配(输出长 + 1)
    如果 (输出 == 0) { 堆_释放(原始); 返回 0 }

    定义 可变 si = 0
    定义 可变 di = 0
    定义 可变 行内计数 = 0
    当 (si < 原长) {
        内存_写8(输出 + di, 内存_读8(原始 + si))
        si = si + 1
        di = di + 1
        行内计数 = 行内计数 + 1
        如果 (行内计数 >= MIME_行宽 && si < 原长) {
            内存_写8(输出 + di, 0x0D)  // \r
            内存_写8(输出 + di + 1, 0x0A)  // \n
            di = di + 2
            行内计数 = 0
        }
    }
    内存_写8(输出 + di, 0)
    堆_释放(原始)
    返回 输出
}

// 第7部分: 流式编码

结构 B64流式编码器 {
    输出缓冲,       // 输出字符串
    剩余,           // u8[3] 未凑整的3字节缓冲
    剩余长,         // 0-2
    总字节数,
}

函数 B64流式编码器_创建() {
    全局B64E统计.流式编码数 = 全局B64E统计.流式编码数 + 1
    返回 B64流式编码器 { 输出缓冲: "", 剩余: [0,0,0], 剩余长: 0, 总字节数: 0 }
}

函数 B64流式编码器_输入(enc, 数据, 长度) {
    如果 (数据 == 0 || 长度 == 0) { 返回 }
    enc.总字节数 = enc.总字节数 + 长度
    定义 可变 offset = 0

    // 先凑整剩余
    当 (enc.剩余长 < 3 && offset < 长度) {
        enc.剩余[enc.剩余长] = 内存_读8(数据 + offset)
        enc.剩余长 = enc.剩余长 + 1
        offset = offset + 1
    }
    如果 (enc.剩余长 == 3) {
        // 编码剩余的3字节
        定义 小块 = 堆_分配(3)
        内存_写8(小块, enc.剩余[0])
        内存_写8(小块 + 1, enc.剩余[1])
        内存_写8(小块 + 2, enc.剩余[2])
        定义 编码 = Base64_编码_内部(小块, 3, B64_标准表, 真)
        enc.输出缓冲 = enc.输出缓冲 + 编码
        堆_释放(小块)
        堆_释放(编码)
        enc.剩余长 = 0
    }

    // 处理剩余主体数据(每次3字节)
    当 (offset + 2 < 长度) {
        定义 块长 = 长度 - offset
        如果 (块长 > 流式_块大小) { 块长 = 流式_块大小 }
        // 对齐3的倍数
        块长 = (块长 / 3) * 3
        如果 (块长 > 0) {
            定义 编码 = Base64_编码_内部(数据 + offset, 块长, B64_标准表, 真)
            enc.输出缓冲 = enc.输出缓冲 + 编码
            堆_释放(编码)
            offset = offset + 块长
        }
    }

    // 剩余字节存入缓冲
    当 (offset < 长度) {
        enc.剩余[enc.剩余长] = 内存_读8(数据 + offset)
        enc.剩余长 = enc.剩余长 + 1
        offset = offset + 1
    }
}

函数 B64流式编码器_结束(enc) {
    // 处理剩余字节(加padding)
    如果 (enc.剩余长 > 0) {
        定义 小块 = 堆_分配(3)
        定义 可变 i = 0
        当 (i < enc.剩余长) { 内存_写8(小块 + i, enc.剩余[i]); i = i + 1 }
        定义 编码 = Base64_编码_内部(小块, enc.剩余长, B64_标准表, 真)
        enc.输出缓冲 = enc.输出缓冲 + 编码
        堆_释放(小块)
        堆_释放(编码)
        enc.剩余长 = 0
    }
    返回 enc.输出缓冲
}

// 第8部分: 输入验证

函数 Base64_验证(文本) {
    // 检查是否为有效的Base64字符串
    全局B64E统计.验证次数 = 全局B64E统计.验证次数 + 1
    如果 (文本 == 0) { 返回 假 }
    定义 长度 = 字符串_长度(文本)
    如果 (长度 == 0) { 返回 真 }  // 空串合法
    // 忽略空白后检查长度是4的倍数
    定义 可变 有效长 = 0
    定义 可变 pad_count = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 内存_读8(文本 + i)
        如果 (c == B64_PAD) {
            pad_count = pad_count + 1
            有效长 = 有效长 + 1
        } 否则 如果 (c == 0x20 || c == 0x0A || c == 0x0D || c == 0x09) {
            // 跳过空白
        } 否则 {
            定义 v = Base64_字符值(c)
            如果 (v == 0xFF) {
                全局B64E统计.验证失败数 = 全局B64E统计.验证失败数 + 1
                返回 假  // 无效字符
            }
            如果 (pad_count > 0) {
                全局B64E统计.验证失败数 = 全局B64E统计.验证失败数 + 1
                返回 假  // padding后不能有数据字符
            }
            有效长 = 有效长 + 1
        }
        i = i + 1
    }
    // padding最多2个
    如果 (pad_count > 2) {
        全局B64E统计.验证失败数 = 全局B64E统计.验证失败数 + 1
        返回 假
    }
    // 有效长度必须是4的倍数(如果有padding)
    如果 (pad_count > 0 && 有效长 % 4 != 0) {
        全局B64E统计.验证失败数 = 全局B64E统计.验证失败数 + 1
        返回 假
    }
    返回 真
}

// 第9部分: AI集成

函数 智能_长连接_AI加载优先级(url) {
    定义 bus = 全局AI总线
    如果 (bus == 0 || url == 0) { 返回 500 }
    全局B64E统计.AI预测数 = 全局B64E统计.AI预测数 + 1
    返回 AI总线_资源优先级(bus, url)
}

函数 智能_长连接_AI预取决策(url) {
    定义 bus = 全局AI总线
    如果 (bus == 0 || url == 0) { 返回 假 }
    定义 分数 = AI总线_资源优先级(bus, url)
    返回 分数 > 600
}

// 第10部分: 工具函数与统计

函数 Base64_字符串转Hex(数据, 长度) {
    // 先编码为base64, 用于调试显示
    返回 Base64_编码(数据, 长度)
}

函数 B64E_获取统计() { 返回 全局B64E统计 }

函数 B64E_打印统计() {
    定义 s = 全局B64E统计
    内核打印("═══ B64E Base64统计 ═══")
    内核打印("编码={} 解码={} 字节[编/解]={}/{}",
        s.编码次数, s.解码次数, s.编码字节数, s.解码字节数)
    内核打印("验证={}/{} URL-safe={} MIME={}",
        s.验证次数, s.验证失败数, s.URL安全编码数, s.MIME编码数)
    内核打印("流式[编/解]={}/{} AI={}",
        s.流式编码数, s.流式解码数, s.AI预测数)
}

函数 B64E_重置统计() {
    全局B64E统计 = B64E统计 {}
}

// 第11部分: 流式解码器

结构 B64流式解码器 {
    输出缓冲,       // 已解码字节指针
    输出长度,       // 当前解码字节数
    输出容量,       // 缓冲区容量
    剩余,           // u8[4] 未凑整的4字符缓冲
    剩余长,         // 0-3
    总字符数,       // u64 输入字符总数
}

函数 B64流式解码器_创建() {
    全局B64E统计.流式解码数 = 全局B64E统计.流式解码数 + 1
    定义 初始容量 = 4096
    定义 缓冲 = 堆_分配(初始容量)
    返回 B64流式解码器 {
        输出缓冲: 缓冲, 输出长度: 0, 输出容量: 初始容量,
        剩余: [0,0,0,0], 剩余长: 0, 总字符数: 0
    }
}

函数 B64流式解码器_确保容量(dec, 需要) {
    定义 目标 = dec.输出长度 + 需要
    如果 (目标 <= dec.输出容量) { 返回 }
    定义 新容量 = dec.输出容量
    当 (新容量 < 目标) { 新容量 = 新容量 * 2 }
    定义 新缓冲 = 堆_分配(新容量)
    如果 (新缓冲 == 0) { 返回 }
    内存_复制(新缓冲, dec.输出缓冲, dec.输出长度)
    堆_释放(dec.输出缓冲)
    dec.输出缓冲 = 新缓冲
    dec.输出容量 = 新容量
}

函数 B64流式解码器_解码四元组(dec, a, b, c, d) {
    // 解码1组4字符 → 最多3字节
    B64流式解码器_确保容量(dec, 3)
    定义 buf = dec.输出缓冲
    定义 di = dec.输出长度
    内存_写8(buf + di, (a << 2) | (b >> 4))
    di = di + 1
    如果 (c != 0xFF) {
        内存_写8(buf + di, ((b & 0xF) << 4) | (c >> 2))
        di = di + 1
    }
    如果 (d != 0xFF) {
        内存_写8(buf + di, ((c & 3) << 6) | d)
        di = di + 1
    }
    dec.输出长度 = di
}

函数 B64流式解码器_输入(dec, 文本, 长度) {
    如果 (文本 == 0 || 长度 == 0) { 返回 }
    dec.总字符数 = dec.总字符数 + 长度
    // 预分配足够空间
    B64流式解码器_确保容量(dec, (长度 / 4) * 3 + 3)
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 内存_读8(文本 + i)
        // 跳过空白和换行
        如果 (c == 0x20 || c == 0x0A || c == 0x0D || c == 0x09) {
            i = i + 1
            继续
        }
        定义 v = Base64_字符值(c)
        如果 (c == B64_PAD) {
            dec.剩余[dec.剩余长] = 0xFF  // padding标记
            dec.剩余长 = dec.剩余长 + 1
        } 否则 如果 (v != 0xFF) {
            dec.剩余[dec.剩余长] = v
            dec.剩余长 = dec.剩余长 + 1
        }
        // 凑够4个就解码
        如果 (dec.剩余长 == 4) {
            B64流式解码器_解码四元组(dec,
                dec.剩余[0], dec.剩余[1], dec.剩余[2], dec.剩余[3])
            dec.剩余长 = 0
        }
        i = i + 1
    }
}

函数 B64流式解码器_结束(dec) {
    // 处理残余(不足4字符 → 无padding的URL-safe等)
    如果 (dec.剩余长 == 2) {
        B64流式解码器_解码四元组(dec, dec.剩余[0], dec.剩余[1], 0xFF, 0xFF)
    } 否则 如果 (dec.剩余长 == 3) {
        B64流式解码器_解码四元组(dec, dec.剩余[0], dec.剩余[1], dec.剩余[2], 0xFF)
    }
    dec.剩余长 = 0
    返回 [dec.输出缓冲, dec.输出长度]
}

函数 B64流式解码器_释放(dec) {
    如果 (dec.输出缓冲 != 0) { 堆_释放(dec.输出缓冲) }
    dec.输出缓冲 = 0
    dec.输出长度 = 0
}

// 第12部分: Data URI与高级工具

函数 Base64_构建DataURI(mime_type, 数据, 长度) {
    // 生成: data:<mime>;base64,<encoded>
    如果 (数据 == 0 || 长度 == 0) { 返回 0 }
    定义 编码 = Base64_编码(数据, 长度)
    如果 (编码 == 0) { 返回 0 }
    定义 编码长 = 字符串_长度(编码)
    定义 前缀 = "data:"
    定义 中缀 = ";base64,"
    定义 前缀长 = 5
    定义 中缀长 = 8
    定义 mime长 = 字符串_长度(mime_type)
    定义 总长 = 前缀长 + mime长 + 中缀长 + 编码长
    定义 结果 = 堆_分配(总长 + 1)
    如果 (结果 == 0) { 堆_释放(编码); 返回 0 }
    定义 可变 di = 0
    内存_复制(结果 + di, 前缀, 前缀长); di = di + 前缀长
    内存_复制(结果 + di, mime_type, mime长); di = di + mime长
    内存_复制(结果 + di, 中缀, 中缀长); di = di + 中缀长
    内存_复制(结果 + di, 编码, 编码长); di = di + 编码长
    内存_写8(结果 + di, 0)
    堆_释放(编码)
    返回 结果
}

函数 Base64_解析DataURI(uri) {
    // 解析data:URI → [mime_type, 数据指针, 数据长度]
    如果 (uri == 0) { 返回 [0, 0, 0] }
    定义 长度 = 字符串_长度(uri)
    // 检查前缀 "data:"
    如果 (长度 < 13) { 返回 [0, 0, 0] }  // 最短 data:;base64,X
    如果 (内存_读8(uri) != 0x64 || 内存_读8(uri+1) != 0x61 ||
        内存_读8(uri+2) != 0x74 || 内存_读8(uri+3) != 0x61 ||
        内存_读8(uri+4) != 0x3A) {
        返回 [0, 0, 0]  // 不是"data:"
    }
    // 查找";base64,"
    定义 可变 i = 5
    定义 可变 分号位 = -1
    当 (i < 长度) {
        如果 (内存_读8(uri + i) == 0x3B) { 分号位 = i; 跳出 }
        i = i + 1
    }
    如果 (分号位 < 0) { 返回 [0, 0, 0] }
    // 提取MIME类型
    定义 mime长 = 分号位 - 5
    定义 mime = 堆_分配(mime长 + 1)
    内存_复制(mime, uri + 5, mime长)
    内存_写8(mime + mime长, 0)
    // 跳过";base64," (8字符)
    定义 数据起始 = 分号位 + 8
    如果 (数据起始 >= 长度) { 堆_释放(mime); 返回 [0, 0, 0] }
    // 解码base64部分
    定义 结果 = Base64_解码(uri + 数据起始)
    返回 [mime, 结果[0], 结果[1]]
}

函数 Base64_往返验证(数据, 长度) {
    // 编码→解码→比较 确保无损
    如果 (数据 == 0 || 长度 == 0) { 返回 真 }
    定义 编码 = Base64_编码(数据, 长度)
    如果 (编码 == 0) { 返回 假 }
    定义 解码结果 = Base64_解码(编码)
    定义 解码数据 = 解码结果[0]
    定义 解码长度 = 解码结果[1]
    堆_释放(编码)
    如果 (解码数据 == 0 || 解码长度 != 长度) {
        如果 (解码数据 != 0) { 堆_释放(解码数据) }
        返回 假
    }
    // 逐字节比较
    定义 可变 i = 0
    当 (i < 长度) {
        如果 (内存_读8(数据 + i) != 内存_读8(解码数据 + i)) {
            堆_释放(解码数据)
            返回 假
        }
        i = i + 1
    }
    堆_释放(解码数据)
    返回 真
}

函数 Base64_剥离空白(文本) {
    // 去除空白/换行 → 纯净base64
    如果 (文本 == 0) { 返回 0 }
    定义 长度 = 字符串_长度(文本)
    定义 输出 = 堆_分配(长度 + 1)
    如果 (输出 == 0) { 返回 0 }
    定义 可变 si = 0
    定义 可变 di = 0
    当 (si < 长度) {
        定义 c = 内存_读8(文本 + si)
        如果 (c != 0x20 && c != 0x0A && c != 0x0D && c != 0x09) {
            内存_写8(输出 + di, c)
            di = di + 1
        }
        si = si + 1
    }
    内存_写8(输出 + di, 0)
    返回 输出
}

函数 AI_B64E_编码方式推荐(数据长度, 目标场景) {
    // AI推荐最佳Base64编码变体
    // 目标场景: 0=通用, 1=URL参数, 2=邮件, 3=嵌入式
    定义 bus = 全局AI总线
    如果 (bus == 0) {
        // 回退规则引擎
        如果 (目标场景 == 1) { 返回 "url-safe" }
        如果 (目标场景 == 2) { 返回 "mime" }
        如果 (数据长度 > 1048576) { 返回 "streaming" }
        返回 "standard"
    }
    全局B64E统计.AI预测数 = 全局B64E统计.AI预测数 + 1
    // 构建4维特征向量: [数据量级, 场景, 延迟敏感度, 内存约束]
    定义 t = Tensor_创建(4)
    如果 (数据长度 < 1024) { Tensor_写(t, 0, 100) }
    否则 如果 (数据长度 < 65536) { Tensor_写(t, 0, 400) }
    否则 如果 (数据长度 < 1048576) { Tensor_写(t, 0, 700) }
    否则 { Tensor_写(t, 0, 1000) }
    Tensor_写(t, 1, 目标场景 * 250)
    Tensor_写(t, 2, 500)  // 默认延迟中等
    Tensor_写(t, 3, 500)  // 默认内存中等
    定义 分数 = AI总线_推理(bus, "b64e_variant_select", t)
    Tensor_释放(t)
    如果 (分数 > 800) { 返回 "streaming" }
    如果 (分数 > 600) { 返回 "mime" }
    如果 (分数 > 400) { 返回 "url-safe" }
    返回 "standard"
}

函数 B64E_诊断报告() {
    定义 s = 全局B64E统计
    内核打印("╔═══════════════════════════════════════╗")
    内核打印("║     B64E 编解码子系统诊断报告       ║")
    内核打印("╠═══════════════════════════════════════╣")
    定义 总操作 = s.编码次数 + s.解码次数
    内核打印("║ 总操作数: {}", 总操作)
    内核打印("║ 编码: {}次 ({} 字节)", s.编码次数, s.编码字节数)
    内核打印("║ 解码: {}次 ({} 字节)", s.解码次数, s.解码字节数)
    内核打印("║ URL-safe: {}  MIME: {}", s.URL安全编码数, s.MIME编码数)
    内核打印("║ 流式编码: {}  流式解码: {}", s.流式编码数, s.流式解码数)
    定义 验证率 = 0
    如果 (s.验证次数 > 0) {
        验证率 = ((s.验证次数 - s.验证失败数) * 100) / s.验证次数
    }
    内核打印("║ 验证: {}/{}  通过率: {}%", s.验证次数, s.验证失败数, 验证率)
    内核打印("║ AI推理: {}次", s.AI预测数)
    内核打印("╚═══════════════════════════════════════╝")
}

// NovaOS 电源管理 - 进程冻结与系统挂起
// 冻结/解冻/唤醒锁/设备PM/CPU状态/热管理/统计

导入("./类型定义.nova")
导入("./错误码.nova")
导入("../引导/模型寄存.nova")
导入("./内核打印.nova")
导入("../引导/寄存器定义.nova")
导入("../引导/特权指令.nova")
导入("./页表重建.nova")
导入("./整数转字符串.nova")

定义 PM_状态_运行 = 0
定义 PM_状态_冻结中 = 1
定义 PM_状态_挂起中 = 2
定义 PM_状态_已挂起 = 3
定义 PM_状态_恢复中 = 4
定义 PM_状态_休眠中 = 5

定义 PM_冻结超时_ms = 5000
定义 PM_最大唤醒锁 = 32
定义 PM_最大设备 = 128

定义 可变 pm_冻结计数 = 0
定义 可变 pm_当前状态 = 0   // PM_状态_运行

结构 电源管理统计 {
    挂起次数,
    恢复次数,
    冻结次数,
    解冻次数,
    冻结失败次数,
    设备挂起失败次数,
    唤醒锁获取数,
    唤醒锁释放数,
    唤醒锁阻止挂起数,
    热限流次数,
}

定义 可变 全局_pm统计 = 空

函数 pm统计_初始化() {
    如果 (全局_pm统计 == 空) {
        全局_pm统计 = 电源管理统计 {}
        全局_pm统计.挂起次数 = 0
        全局_pm统计.恢复次数 = 0
        全局_pm统计.冻结次数 = 0
        全局_pm统计.解冻次数 = 0
        全局_pm统计.冻结失败次数 = 0
        全局_pm统计.设备挂起失败次数 = 0
        全局_pm统计.唤醒锁获取数 = 0
        全局_pm统计.唤醒锁释放数 = 0
        全局_pm统计.唤醒锁阻止挂起数 = 0
        全局_pm统计.热限流次数 = 0
    }
}

// §1 进程冻结/解冻

函数 pm_冻结进程() {
    pm统计_初始化()
    内核信息("PM: 冻结用户进程...")
    pm_当前状态 = PM_状态_冻结中
    pm_冻结计数 = 0
    定义 可变 冻结失败 = 0
    定义 开始时间 = 系统时间_毫秒()

    定义 可变 i = 0
    当 (i < 计数(进程链表)) {
        定义 p = 进程链表[i]
        如果 (p.pid > 1 && p.状态 != 进程_僵尸) {
            // 检查超时
            定义 已用时 = 系统时间_毫秒() - 开始时间
            如果 (已用时 > PM_冻结超时_ms) {
                内核警告("PM: 冻结超时, 已冻结 " + 整数转字符串(pm_冻结计数) + " 个进程")
                全局_pm统计.冻结失败次数 = 全局_pm统计.冻结失败次数 + 1
                pm_当前状态 = PM_状态_运行
                返回 错误_超时
            }

            // 检查进程是否持有唤醒锁
            如果 (pm_进程持有唤醒锁(p.pid)) {
                内核信息("PM: 进程 " + 整数转字符串(p.pid) + " 持有唤醒锁, 跳过")
                冻结失败 = 冻结失败 + 1
                i = i + 1
                继续
            }

            // 发送冻结信号
            p.冻结标志 = 真
            pm_冻结计数 = pm_冻结计数 + 1
        }
        i = i + 1
    }
    内核信息("PM: 已冻结 " + 整数转字符串(pm_冻结计数) + " 个进程, 跳过 " + 整数转字符串(冻结失败))
    全局_pm统计.冻结次数 = 全局_pm统计.冻结次数 + 1
    返回 成功
}

函数 pm_解冻进程() {
    pm统计_初始化()
    内核信息("PM: 解冻进程...")
    定义 可变 i = 0
    当 (i < 计数(进程链表)) {
        进程链表[i].冻结标志 = 假
        i = i + 1
    }
    pm_冻结计数 = 0
    pm_当前状态 = PM_状态_运行
    全局_pm统计.解冻次数 = 全局_pm统计.解冻次数 + 1
}

函数 pm_冻结内核线程() {
    内核信息("PM: 冻结可冻结的内核线程...")
    定义 可变 冻结数 = 0
    定义 可变 i = 0
    当 (i < 计数(进程链表)) {
        定义 p = 进程链表[i]
        如果 (p.pid > 0 && p.是内核线程 && p.可冻结 && p.状态 != 进程_僵尸) {
            p.冻结标志 = 真
            冻结数 = 冻结数 + 1
        }
        i = i + 1
    }
    内核信息("PM: 已冻结 " + 整数转字符串(冻结数) + " 个内核线程")
    返回 成功
}

函数 pm_解冻内核线程() {
    内核信息("PM: 解冻内核线程...")
    定义 可变 i = 0
    当 (i < 计数(进程链表)) {
        如果 (进程链表[i].是内核线程) {
            进程链表[i].冻结标志 = 假
        }
        i = i + 1
    }
}

// §2 唤醒锁

结构 唤醒锁 {
    名称,
    持有者PID,
    获取时间,
    超时_ms,
    活跃,
}

定义 可变 唤醒锁列表 = []

函数 pm_获取唤醒锁(名称, pid, 超时_ms) {
    pm统计_初始化()
    如果 (计数(唤醒锁列表) >= PM_最大唤醒锁) {
        内核警告("PM: 唤醒锁已满")
        返回 错误_资源不足
    }

    // 检查是否已存在同名锁
    定义 可变 i = 0
    当 (i < 计数(唤醒锁列表)) {
        如果 (唤醒锁列表[i].名称 == 名称 && 唤醒锁列表[i].持有者PID == pid) {
            唤醒锁列表[i].获取时间 = 系统时间_毫秒()
            唤醒锁列表[i].超时_ms = 超时_ms
            唤醒锁列表[i].活跃 = 真
            返回 成功
        }
        i = i + 1
    }

    定义 锁 = 唤醒锁 {}
    锁.名称 = 名称
    锁.持有者PID = pid
    锁.获取时间 = 系统时间_毫秒()
    锁.超时_ms = 超时_ms
    锁.活跃 = 真
    追加(唤醒锁列表, 锁)
    全局_pm统计.唤醒锁获取数 = 全局_pm统计.唤醒锁获取数 + 1
    返回 成功
}

函数 pm_释放唤醒锁(名称, pid) {
    pm统计_初始化()
    定义 可变 i = 0
    当 (i < 计数(唤醒锁列表)) {
        如果 (唤醒锁列表[i].名称 == 名称 && 唤醒锁列表[i].持有者PID == pid) {
            唤醒锁列表[i].活跃 = 假
            全局_pm统计.唤醒锁释放数 = 全局_pm统计.唤醒锁释放数 + 1
            返回 成功
        }
        i = i + 1
    }
    返回 错误_未找到
}

函数 pm_清理过期唤醒锁() {
    定义 当前时间 = 系统时间_毫秒()
    定义 可变 i = 计数(唤醒锁列表) - 1
    当 (i >= 0) {
        定义 锁 = 唤醒锁列表[i]
        如果 (锁.活跃 && 锁.超时_ms > 0) {
            如果 (当前时间 - 锁.获取时间 > 锁.超时_ms) {
                唤醒锁列表[i].活跃 = 假
            }
        }
        i = i - 1
    }
}

函数 pm_进程持有唤醒锁(pid) {
    pm_清理过期唤醒锁()
    定义 可变 i = 0
    当 (i < 计数(唤醒锁列表)) {
        如果 (唤醒锁列表[i].持有者PID == pid && 唤醒锁列表[i].活跃) {
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 pm_有活跃唤醒锁() {
    pm_清理过期唤醒锁()
    定义 可变 i = 0
    当 (i < 计数(唤醒锁列表)) {
        如果 (唤醒锁列表[i].活跃) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// §3 设备PM回调

定义 可变 pm_设备列表 = []

函数 pm_注册设备(设备, 挂起回调, 恢复回调) {
    如果 (计数(pm_设备列表) >= PM_最大设备) {
        内核警告("PM: 设备PM列表已满")
        返回 错误_资源不足
    }
    追加(pm_设备列表, [设备, 挂起回调, 恢复回调])
    返回 成功
}

函数 pm_注销设备(设备) {
    定义 可变 i = 0
    当 (i < 计数(pm_设备列表)) {
        如果 (pm_设备列表[i][0] == 设备) {
            删除(pm_设备列表, i)
            返回 成功
        }
        i = i + 1
    }
    返回 错误_未找到
}

函数 pm_挂起设备() {
    pm统计_初始化()
    // 逆序挂起(后注册的先挂起)
    定义 可变 i = 计数(pm_设备列表) - 1
    当 (i >= 0) {
        定义 设备 = pm_设备列表[i]
        如果 (设备[1] != 空) {
            定义 结果 = 设备[1](设备[0])  // 调用挂起回调
            如果 (结果 != 成功) {
                内核警告("PM: 设备挂起失败, 索引=" + 整数转字符串(i))
                全局_pm统计.设备挂起失败次数 = 全局_pm统计.设备挂起失败次数 + 1
                // 回滚: 恢复已挂起的设备
                pm_恢复设备_从(i + 1)
                返回 结果
            }
        }
        i = i - 1
    }
    返回 成功
}

函数 pm_恢复设备() {
    // 正序恢复
    pm_恢复设备_从(0)
}

函数 pm_恢复设备_从(起始) {
    定义 可变 i = 起始
    当 (i < 计数(pm_设备列表)) {
        定义 设备 = pm_设备列表[i]
        如果 (设备[2] != 空) {
            定义 结果 = 设备[2](设备[0])  // 调用恢复回调
            如果 (结果 != 成功) {
                内核警告("PM: 设备恢复失败, 索引=" + 整数转字符串(i))
            }
        }
        i = i + 1
    }
}

// §4 CPU状态保存/恢复 + SMP

定义 可变 pm_保存的CR3 = 0
定义 可变 pm_保存的EFER = 0
定义 可变 pm_保存的RSP = 0
定义 可变 pm_保存的RBP = 0
定义 可变 pm_保存的IDT = 0
定义 可变 pm_保存的GDT = 0

函数 pm_保存CPU状态() {
    pm_保存的CR3 = 读取CR3()
    pm_保存的EFER = 读取MSR(0xC0000080)
    pm_保存的IDT = 读取IDT()
    pm_保存的GDT = 读取GDT()
    内核信息("PM: CPU状态已保存")
}

函数 pm_恢复CPU状态() {
    写CR3(pm_保存的CR3)
    写MSR(0xC0000080, pm_保存的EFER)
    写IDT(pm_保存的IDT)
    写GDT(pm_保存的GDT)
    内核信息("PM: CPU状态已恢复")
}

函数 pm_禁用非启动CPU() {
    // SMP: 将所有非BSP CPU下线
    内核信息("PM: 禁用非启动CPU")
    定义 可变 i = 1
    当 (i < CPU核心数) {
        如果 (CPU状态[i] == CPU_在线) {
            CPU状态[i] = CPU_离线
            发送IPI(i, IPI_停止)
        }
        i = i + 1
    }
}

函数 pm_启用非启动CPU() {
    内核信息("PM: 重新启用非启动CPU")
    定义 可变 i = 1
    当 (i < CPU核心数) {
        如果 (CPU状态[i] == CPU_离线) {
            CPU状态[i] = CPU_在线
            发送IPI(i, IPI_启动)
        }
        i = i + 1
    }
}

// §5 系统挂起/恢复流程

函数 pm_系统挂起() {
    pm统计_初始化()
    内核信息("PM: 开始系统挂起流程")

    // 检查唤醒锁
    如果 (pm_有活跃唤醒锁()) {
        内核警告("PM: 有活跃唤醒锁, 阻止挂起")
        全局_pm统计.唤醒锁阻止挂起数 = 全局_pm统计.唤醒锁阻止挂起数 + 1
        返回 错误_忙
    }

    // 步骤1: 冻结进程
    定义 结果 = pm_冻结进程()
    如果 (结果 != 成功) {
        内核警告("PM: 冻结进程失败, 中止挂起")
        返回 结果
    }

    // 步骤2: 冻结内核线程
    pm_冻结内核线程()

    // 步骤3: 挂起设备
    结果 = pm_挂起设备()
    如果 (结果 != 成功) {
        内核警告("PM: 设备挂起失败, 回滚")
        pm_解冻内核线程()
        pm_解冻进程()
        返回 结果
    }

    // 步骤4: 禁用非启动CPU
    pm_禁用非启动CPU()

    // 步骤5: 保存CPU状态
    pm_保存CPU状态()

    pm_当前状态 = PM_状态_已挂起
    全局_pm统计.挂起次数 = 全局_pm统计.挂起次数 + 1
    内核信息("PM: 系统已挂起")
    返回 成功
}

函数 pm_系统恢复() {
    pm统计_初始化()
    内核信息("PM: 开始系统恢复流程")
    pm_当前状态 = PM_状态_恢复中

    // 步骤1: 恢复CPU状态
    pm_恢复CPU状态()

    // 步骤2: 启用非启动CPU
    pm_启用非启动CPU()

    // 步骤3: 恢复设备
    pm_恢复设备()

    // 步骤4: 解冻内核线程
    pm_解冻内核线程()

    // 步骤5: 解冻进程
    pm_解冻进程()

    pm_当前状态 = PM_状态_运行
    全局_pm统计.恢复次数 = 全局_pm统计.恢复次数 + 1
    内核信息("PM: 系统已恢复")
    返回 成功
}

// §6 热管理

定义 PM_热_警告温度 = 85    // 摄氏度
定义 PM_热_临界温度 = 100
定义 PM_热_目标温度 = 75

定义 可变 pm_当前温度 = 0
定义 可变 pm_热限流级别 = 0  // 0=无, 1=轻度, 2=中度, 3=严重

函数 pm_热检查() {
    pm统计_初始化()
    pm_当前温度 = 读取CPU温度()

    如果 (pm_当前温度 >= PM_热_临界温度) {
        pm_热限流级别 = 3
        内核警告("PM: 临界温度! " + 整数转字符串(pm_当前温度) + "°C - 紧急降频")
        pm_设置频率_百分比(25)
        全局_pm统计.热限流次数 = 全局_pm统计.热限流次数 + 1
    } 否则 如果 (pm_当前温度 >= PM_热_警告温度) {
        pm_热限流级别 = 2
        内核信息("PM: 高温警告 " + 整数转字符串(pm_当前温度) + "°C - 降频")
        pm_设置频率_百分比(50)
        全局_pm统计.热限流次数 = 全局_pm统计.热限流次数 + 1
    } 否则 如果 (pm_当前温度 >= PM_热_目标温度) {
        pm_热限流级别 = 1
        pm_设置频率_百分比(75)
    } 否则 {
        如果 (pm_热限流级别 > 0) {
            pm_热限流级别 = 0
            pm_设置频率_百分比(100)
        }
    }
}

函数 pm_设置频率_百分比(百分比) {
    如果 (百分比 < 10) { 百分比 = 10 }
    如果 (百分比 > 100) { 百分比 = 100 }
    定义 目标频率 = CPU最大频率_MHz * 百分比 / 100
    CPU当前频率_MHz = 目标频率
    写MSR(MSR_PERF_CTL, 目标频率)
}

// §7 统计

函数 电源管理_统计() {
    pm统计_初始化()
    返回 [pm_当前状态, pm_当前温度, CPU当前频率_MHz,
           全局_pm统计.挂起次数, 全局_pm统计.恢复次数, 计数(pm_设备列表)]
}

函数 电源管理_打印统计() {
    pm统计_初始化()
    打印行("=== 电源管理统计 ===")
    打印行("当前状态: " + 整数转字符串(pm_当前状态))
    打印行("挂起次数: " + 整数转字符串(全局_pm统计.挂起次数))
    打印行("恢复次数: " + 整数转字符串(全局_pm统计.恢复次数))
    打印行("冻结次数: " + 整数转字符串(全局_pm统计.冻结次数))
    打印行("解冻次数: " + 整数转字符串(全局_pm统计.解冻次数))
    打印行("冻结失败: " + 整数转字符串(全局_pm统计.冻结失败次数))
    打印行("设备挂起失败: " + 整数转字符串(全局_pm统计.设备挂起失败次数))
    打印行("唤醒锁获取: " + 整数转字符串(全局_pm统计.唤醒锁获取数))
    打印行("唤醒锁释放: " + 整数转字符串(全局_pm统计.唤醒锁释放数))
    打印行("唤醒锁阻止: " + 整数转字符串(全局_pm统计.唤醒锁阻止挂起数))
    打印行("热限流次数: " + 整数转字符串(全局_pm统计.热限流次数))
    打印行("当前温度: " + 整数转字符串(pm_当前温度) + "°C")
    打印行("热限流级别: " + 整数转字符串(pm_热限流级别))
    打印行("注册设备数: " + 整数转字符串(计数(pm_设备列表)))
    打印行("活跃唤醒锁: " + 整数转字符串(计数(唤醒锁列表)))
}

// NPMT — Nova Power Management Theory
// 公理1(状态可逆): 挂起∘恢复 = 恒等, 系统状态完整还原
// 公理2(冻结完备): 全部进程冻结后才可挂起设备
// 公理3(热守恒): 温控降频不影响系统正确性, 只影响吞吐
// 定理1(唤醒锁隔离): 唤醒锁阻止挂起但不影响其他电源操作
// 定理2(回滚安全): 任何步骤失败均能恢复到挂起前状态

函数 电源_重置统计() {
    pm统计_初始化()
    全局_pm统计.挂起次数 = 0
    全局_pm统计.恢复次数 = 0
    全局_pm统计.冻结次数 = 0
    全局_pm统计.解冻次数 = 0
    全局_pm统计.冻结失败次数 = 0
    全局_pm统计.设备挂起失败次数 = 0
    全局_pm统计.唤醒锁获取数 = 0
    全局_pm统计.唤醒锁释放数 = 0
    全局_pm统计.唤醒锁阻止挂起数 = 0
    全局_pm统计.热限流次数 = 0
}

定义 可变 AI_电源冻结进_负载窗口 = []

函数 AI_电源冻结进_负载预测(当前负载) {
    追加(AI_电源冻结进_负载窗口, 当前负载)
    如果 (计数(AI_电源冻结进_负载窗口) > 20) { 列表_移除(AI_电源冻结进_负载窗口, 0) }
    如果 (计数(AI_电源冻结进_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_电源冻结进_负载窗口)
    定义 趋势 = AI_电源冻结进_负载窗口[n-1] - AI_电源冻结进_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_电源冻结进_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

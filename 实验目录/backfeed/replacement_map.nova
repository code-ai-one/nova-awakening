    如果 (序号 == 4) { 返回 "纯净版系统/推理/语义嵌入.nova" }
    如果 (序号 == 5) { 返回 "纯净版系统/推理/意图识别.nova" }
    如果 (序号 == 6) { 返回 "纯净版系统/推理/思维链推理.nova" }
    如果 (序号 == 7) { 返回 "纯净版系统/推理/检索增强推理.nova" }
    如果 (序号 == 8) { 返回 "纯净版系统/推理/在线学习.nova" }
    如果 (序号 == 9) { 返回 "纯净版系统/中枢/策略梯度.nova" }
    如果 (序号 == 10) { 返回 "纯净版系统/推理/浏览注意力.nova" }
    如果 (序号 == 11) { 返回 "纯净版系统/推理/多头注意力.nova" }
    如果 (序号 == 12) { 返回 "纯净版系统/推理/混合专家.nova" }

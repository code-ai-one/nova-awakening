
// NovaOS 渲染引擎 — SVG路径解析辅助函数 + 基本形状转换
// 子系统: 渲染引擎/图片解码/矢量图/矢量渲染
// 实现: SVG路径d属性解析辅助(数字/空白/命令识别)
//   基本形状→路径转换(rect/circle/ellipse/line/polygon/polyline/star)
//   弧线→贝塞尔近似 + 路径操作(反转/连接/变换)
// 原创: NovaOS · 纯中文原生系统编程 · AI原生形状类型预测

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("./矢量图创建.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内存初始化.nova")
导入("./边界框计算.nova")
导入("../执行/控制台输出.nova")

// §0 常量与数据结构

定义 SVG命令_M = 77
定义 SVG命令_L = 76
定义 SVG命令_C = 67
定义 SVG命令_Q = 81
定义 SVG命令_Z = 90
定义 SVG命令_A = 65
定义 SVG命令_H = 72
定义 SVG命令_V = 86
定义 SVG命令_S = 83
定义 SVG命令_T = 84
定义 圆周率_Q10 = 3217         // π × 1024
定义 贝塞尔椭圆魔数 = 565      // 4(√2-1)/3 × 1024

结构 解析器辅助统计 {
    数字解析次数,
    命令识别次数,
    空白跳过次数,
    rect转换次数,
    circle转换次数,
    ellipse转换次数,
    line转换次数,
    polygon转换次数,
    polyline转换次数,
    star生成次数,
    弧线转换次数,
    路径反转次数,
    路径连接次数,
    AI形状预测次数,
    AI形状命中次数,
    解析错误次数,
    总解析耗时_纳秒,
    科学记数法次数,
}

结构 AI形状状态 {
    历史形状分布,        // u64 指向8元素计数数组
    最近形状类型,
    连续相同形状数,
    预测下次形状,
    历史平均顶点数,      // u32 Q10
    采样计数器,
    学习权重,            // u32 Q10
    历史圆角率,          // u32 Q10 (带圆角的rect比例)
}

定义 可变 全局解析辅助统计 = 0
定义 可变 全局形状AI = 0
定义 可变 全局解析辅助已初始化 = 假

// §0.5 生命周期

函数 SVG辅助_初始化() {
    如果 (全局解析辅助已初始化 == 真) { 返回 错误_已存在 }
    全局解析辅助统计 = 堆_分配_清零(144)
    如果 (全局解析辅助统计 == 空) { 返回 错误_内存不足 }
    全局形状AI = 堆_分配_清零(48)
    如果 (全局形状AI != 空) {
        全局形状AI.历史形状分布 = 堆_分配_清零(8 * 8)
        全局形状AI.学习权重 = 128
    }
    全局解析辅助已初始化 = 真
    打印("[SVG辅助] 初始化完成")
    返回 0
}

函数 SVG辅助_销毁() {
    如果 (全局形状AI != 空) {
        如果 (全局形状AI.历史形状分布 != 空) { 堆_释放(全局形状AI.历史形状分布) }
        堆_释放(全局形状AI)
        全局形状AI = 0
    }
    如果 (全局解析辅助统计 != 空) { 堆_释放(全局解析辅助统计); 全局解析辅助统计 = 0 }
    全局解析辅助已初始化 = 假
    返回 0
}

函数 SVG辅助_重置() {
    如果 (全局解析辅助统计 != 空) { 内存_置零(全局解析辅助统计, 144) }
    返回 0
}

// §1 路径解析器核心辅助

函数 SVGParser_跳过空白(p) {
    当 (p.位置 < p.长度) {
        定义 ch = 字节取(p.输入, p.位置)
        如果 (ch == 32 || ch == 9 || ch == 10 || ch == 13 || ch == 44) {    // 空格/tab/换行/逗号
            p.位置 = p.位置 + 1
        } 否则 { 返回 }
    }
}

函数 SVGParser_是命令(ch) {
    返回 ch == 77 || ch == 109 || ch == 76 || ch == 108 ||    // M/m/L/l
           ch == 72 || ch == 104 || ch == 86 || ch == 118 ||   // H/h/V/v
           ch == 67 || ch == 99 || ch == 83 || ch == 115 ||    // C/c/S/s
           ch == 81 || ch == 113 || ch == 84 || ch == 116 ||   // Q/q/T/t
           ch == 65 || ch == 97 || ch == 90 || ch == 122       // A/a/Z/z
}

// 读取浮点数字→Q10定点
函数 SVGParser_读数字(p) {
    SVGParser_跳过空白(p)
    如果 (p.位置 >= p.长度) { 返回 0 }

    定义 可变 符号 = 1
    如果 (字节取(p.输入, p.位置) == 45) { 符号 = -1; p.位置 = p.位置 + 1 }    // '-'
    否则 如果 (字节取(p.输入, p.位置) == 43) { p.位置 = p.位置 + 1 }           // '+'

    // 整数部分
    定义 可变 整数 = 0
    当 (p.位置 < p.长度 && 字节取(p.输入, p.位置) >= 48 && 字节取(p.输入, p.位置) <= 57) {
        整数 = 整数 * 10 + (字节取(p.输入, p.位置) - 48)
        p.位置 = p.位置 + 1
    }

    // 小数部分
    定义 可变 小数 = 0
    定义 可变 除数 = 1
    如果 (p.位置 < p.长度 && 字节取(p.输入, p.位置) == 46) {    // '.'
        p.位置 = p.位置 + 1
        当 (p.位置 < p.长度 && 字节取(p.输入, p.位置) >= 48 && 字节取(p.输入, p.位置) <= 57) {
            小数 = 小数 * 10 + (字节取(p.输入, p.位置) - 48)
            除数 = 除数 * 10
            p.位置 = p.位置 + 1
        }
    }

    // 转为Q10定点: 整数*1024 + 小数*1024/除数
    定义 结果 = 整数 * 1024 + (小数 * 1024 / 除数)
    返回 结果 * 符号
}

// §5 SVG基本形状 → 路径转换

// <rect x="10" y="20" width="100" height="80" rx="5" ry="5"/>
函数 SVG_rect到path(x, y, w, h, rx, ry) {
    定义 path = SVGPath_创建()
    如果 (rx == 0 && ry == 0) {
        // 无圆角
        SVGPath_添加段(path, SVG命令_M, x, y, 0, 0, 0, 0, 0)
        SVGPath_添加段(path, SVG命令_L, x + w, y, 0, 0, 0, 0, 0)
        SVGPath_添加段(path, SVG命令_L, x + w, y + h, 0, 0, 0, 0, 0)
        SVGPath_添加段(path, SVG命令_L, x, y + h, 0, 0, 0, 0, 0)
        SVGPath_添加段(path, SVG命令_Z, x, y, 0, 0, 0, 0, 0)
    } 否则 {
        // 圆角矩形(用arc连接)
        如果 (ry == 0) { ry = rx }
        SVGPath_添加段(path, SVG命令_M, x + rx, y, 0, 0, 0, 0, 0)
        SVGPath_添加段(path, SVG命令_L, x + w - rx, y, 0, 0, 0, 0, 0)
        SVGPath_添加段(path, SVG命令_A, rx, ry, 0, 0, 1, x + w, y + ry)
        SVGPath_添加段(path, SVG命令_L, x + w, y + h - ry, 0, 0, 0, 0, 0)
        SVGPath_添加段(path, SVG命令_A, rx, ry, 0, 0, 1, x + w - rx, y + h)
        SVGPath_添加段(path, SVG命令_L, x + rx, y + h, 0, 0, 0, 0, 0)
        SVGPath_添加段(path, SVG命令_A, rx, ry, 0, 0, 1, x, y + h - ry)
        SVGPath_添加段(path, SVG命令_L, x, y + ry, 0, 0, 0, 0, 0)
        SVGPath_添加段(path, SVG命令_A, rx, ry, 0, 0, 1, x + rx, y)
        SVGPath_添加段(path, SVG命令_Z, x + rx, y, 0, 0, 0, 0, 0)
    }
    SVGPath_计算边界(path)
    返回 path
}

// <circle cx="50" cy="50" r="40"/>
函数 SVG_circle到path(cx, cy, r) {
    返回 SVG_ellipse到path(cx, cy, r, r)
}

// <ellipse cx="50" cy="50" rx="40" ry="30"/>
函数 SVG_ellipse到path(cx, cy, rx, ry) {
    定义 path = SVGPath_创建()
    // 用4段Nova三次方 bezier近似椭圆
    // 魔数: 0.5522847498 ≈ 4(√2-1)/3 → Q10 = 565
    定义 kx = rx * 565 / 1024
    定义 ky = ry * 565 / 1024

    SVGPath_添加段(path, SVG命令_M, cx + rx, cy, 0, 0, 0, 0, 0)
    SVGPath_添加段(path, SVG命令_C, cx + rx, cy + ky, cx + kx, cy + ry, cx, cy + ry, 0)
    SVGPath_添加段(path, SVG命令_C, cx - kx, cy + ry, cx - rx, cy + ky, cx - rx, cy, 0)
    SVGPath_添加段(path, SVG命令_C, cx - rx, cy - ky, cx - kx, cy - ry, cx, cy - ry, 0)
    SVGPath_添加段(path, SVG命令_C, cx + kx, cy - ry, cx + rx, cy - ky, cx + rx, cy, 0)
    SVGPath_添加段(path, SVG命令_Z, cx + rx, cy, 0, 0, 0, 0, 0)

    SVGPath_计算边界(path)
    返回 path
}

// <line x1="10" y1="20" x2="100" y2="80"/>
函数 SVG_line到path(x1, y1, x2, y2) {
    定义 path = SVGPath_创建()
    SVGPath_添加段(path, SVG命令_M, x1, y1, 0, 0, 0, 0, 0)
    SVGPath_添加段(path, SVG命令_L, x2, y2, 0, 0, 0, 0, 0)
    SVGPath_计算边界(path)
    返回 path
}

// <polygon points="100,10 40,198 190,78 10,78 160,198"/>
函数 SVG_polygon到path(点数组, 点数) {
    如果 (点数组 == 0 || 点数 < 2) { 返回 0 }
    定义 path = SVGPath_创建()
    SVGPath_添加段(path, SVG命令_M, 内存_读32(点数组), 内存_读32(点数组 + 4), 0, 0, 0, 0, 0)
    定义 可变 i = 1
    当 (i < 点数) {
        SVGPath_添加段(path, SVG命令_L,
                       内存_读32(点数组 + i * 8), 内存_读32(点数组 + i * 8 + 4),
                       0, 0, 0, 0, 0)
        i = i + 1
    }
    SVGPath_添加段(path, SVG命令_Z, 内存_读32(点数组), 内存_读32(点数组 + 4), 0, 0, 0, 0, 0)
    SVGPath_计算边界(path)
    返回 path
}

// <polyline points="..."/> (不闭合)
函数 SVG_polyline到path(点数组, 点数) {
    如果 (点数组 == 0 || 点数 < 2) { 返回 0 }
    定义 path = SVGPath_创建()
    SVGPath_添加段(path, SVG命令_M, 内存_读32(点数组), 内存_读32(点数组 + 4), 0, 0, 0, 0, 0)
    定义 可变 i = 1
    当 (i < 点数) {
        SVGPath_添加段(path, SVG命令_L,
                       内存_读32(点数组 + i * 8), 内存_读32(点数组 + i * 8 + 4),
                       0, 0, 0, 0, 0)
        i = i + 1
    }
    SVGPath_计算边界(path)
    如果 (全局解析辅助统计 != 空) {
        全局解析辅助统计.polyline转换次数 = 全局解析辅助统计.polyline转换次数 + 1
    }
    返回 path
}

// §6 星形/正多边形生成

函数 SVG_定点cos近似(角度_Q10) {
    // 简化cos: cos(x) ≈ 1 - x²/2 + x⁴/24 (Q10定点)
    定义 x2 = 角度_Q10 * 角度_Q10 / 1024
    定义 x4 = x2 * x2 / 1024
    返回 1024 - x2 / 2 + x4 / 24
}

函数 SVG_定点sin近似(角度_Q10) {
    // 简化sin: sin(x) ≈ x - x³/6 + x⁵/120 (Q10定点)
    定义 x2 = 角度_Q10 * 角度_Q10 / 1024
    定义 x3 = x2 * 角度_Q10 / 1024
    定义 x5 = x3 * x2 / 1024
    返回 角度_Q10 - x3 / 6 + x5 / 120
}

函数 SVG_正多边形到path(cx, cy, r, 边数) {
    如果 (边数 < 3 || 边数 > 360) { 返回 空 }
    如果 (r <= 0) { 返回 空 }
    定义 path = SVGPath_创建()
    如果 (path == 空) { 返回 空 }
    // 角度步长 = 2π/边数 (Q10: 6434/边数)
    定义 步长 = 6434 / 边数
    定义 可变 i = 0
    当 (i < 边数) {
        定义 角度 = i * 步长 - 圆周率_Q10 / 2  // 从顶部开始
        定义 px = cx + r * SVG_定点cos近似(角度) / 1024
        定义 py = cy + r * SVG_定点sin近似(角度) / 1024
        如果 (i == 0) {
            SVGPath_添加段(path, SVG命令_M, px, py, 0, 0, 0, 0, 0)
        } 否则 {
            SVGPath_添加段(path, SVG命令_L, px, py, 0, 0, 0, 0, 0)
        }
        i = i + 1
    }
    SVGPath_添加段(path, SVG命令_Z, 0, 0, 0, 0, 0, 0, 0)
    SVGPath_计算边界(path)
    返回 path
}

函数 SVG_星形到path(cx, cy, 外径, 内径, 角数) {
    如果 (角数 < 3 || 角数 > 36) { 返回 空 }
    如果 (外径 <= 0 || 内径 <= 0) { 返回 空 }
    定义 path = SVGPath_创建()
    如果 (path == 空) { 返回 空 }
    定义 总顶点 = 角数 * 2
    定义 步长 = 6434 / 总顶点
    定义 可变 i = 0
    当 (i < 总顶点) {
        定义 角度 = i * 步长 - 圆周率_Q10 / 2
        定义 可变 半径 = 外径
        如果 (i % 2 == 1) { 半径 = 内径 }
        定义 px = cx + 半径 * SVG_定点cos近似(角度) / 1024
        定义 py = cy + 半径 * SVG_定点sin近似(角度) / 1024
        如果 (i == 0) {
            SVGPath_添加段(path, SVG命令_M, px, py, 0, 0, 0, 0, 0)
        } 否则 {
            SVGPath_添加段(path, SVG命令_L, px, py, 0, 0, 0, 0, 0)
        }
        i = i + 1
    }
    SVGPath_添加段(path, SVG命令_Z, 0, 0, 0, 0, 0, 0, 0)
    SVGPath_计算边界(path)
    如果 (全局解析辅助统计 != 空) {
        全局解析辅助统计.star生成次数 = 全局解析辅助统计.star生成次数 + 1
    }
    返回 path
}

// §7 弧线→三次贝塞尔近似

函数 SVG_弧线到贝塞尔(path, x1, y1, rx, ry, 旋转, 大弧标志, 顺时针, x2, y2) {
    如果 (path == 空) { 返回 }
    如果 (rx <= 0 || ry <= 0) {
        // 退化为直线
        SVGPath_添加段(path, SVG命令_L, x2, y2, 0, 0, 0, 0, 0)
        返回
    }
    // 简化处理: 用4段贝塞尔近似90度弧
    // 对于小弧度差，直接用一段贝塞尔
    定义 dx = x2 - x1
    定义 dy = y2 - y1
    定义 距离平方 = dx * dx + dy * dy
    // 如果起止点非常近，跳过
    如果 (距离平方 < 4) { 返回 }
    // 简单近似: 用二次贝塞尔的控制点
    定义 中x = (x1 + x2) / 2
    定义 中y = (y1 + y2) / 2
    // 法线方向偏移
    定义 可变 法x = 0 - dy
    定义 可变 法y = dx
    // 归一化(近似)
    定义 可变 法长 = 法x
    如果 (法长 < 0) { 法长 = 0 - 法长 }
    定义 可变 法长y = 法y
    如果 (法长y < 0) { 法长y = 0 - 法长y }
    定义 总长 = 法长 + 法长y
    如果 (总长 == 0) { 总长 = 1 }
    // 弧高 = 半径的一半(简化)
    定义 弧高 = (rx + ry) / 4
    如果 (大弧标志 == 真) { 弧高 = (rx + ry) / 2 }
    定义 控制x = 中x + 法x * 弧高 / 总长
    定义 控制y = 中y + 法y * 弧高 / 总长
    // 转为三次贝塞尔
    定义 cp1x = x1 + (控制x - x1) * 683 / 1024
    定义 cp1y = y1 + (控制y - y1) * 683 / 1024
    定义 cp2x = x2 + (控制x - x2) * 683 / 1024
    定义 cp2y = y2 + (控制y - y2) * 683 / 1024
    SVGPath_添加段(path, SVG命令_C, cp1x, cp1y, cp2x, cp2y, x2, y2, 0)
    如果 (全局解析辅助统计 != 空) {
        全局解析辅助统计.弧线转换次数 = 全局解析辅助统计.弧线转换次数 + 1
    }
}

// §8 路径操作(长度计算/采样/段数统计)

函数 SVG_计算路径长度(线段, 线段数) {
    如果 (线段 == 空 || 线段数 <= 0) { 返回 0 }
    定义 可变 总长度 = 0
    定义 可变 i = 0
    当 (i < 线段数) {
        定义 偏移 = i * 16
        定义 dx = 内存_读32(线段 + 偏移 + 8) - 内存_读32(线段 + 偏移)
        定义 dy = 内存_读32(线段 + 偏移 + 12) - 内存_读32(线段 + 偏移 + 4)
        // 近似长度: |dx| + |dy| (曼哈顿距离, 快速)
        定义 可变 adx = dx
        如果 (adx < 0) { adx = 0 - adx }
        定义 可变 ady = dy
        如果 (ady < 0) { ady = 0 - ady }
        总长度 = 总长度 + adx + ady
        i = i + 1
    }
    返回 总长度
}

函数 SVG_路径段数(path) {
    如果 (path == 空) { 返回 0 }
    定义 可变 计数 = 0
    定义 可变 seg = path.段链头
    当 (seg != 空) {
        计数 = 计数 + 1
        seg = seg.下一个
    }
    返回 计数
}

函数 SVG_路径包含曲线(path) {
    如果 (path == 空) { 返回 假 }
    定义 可变 seg = path.段链头
    当 (seg != 空) {
        如果 (seg.命令 == SVG命令_C || seg.命令 == SVG命令_Q || seg.命令 == SVG命令_S || seg.命令 == SVG命令_T || seg.命令 == SVG命令_A) {
            返回 真
        }
        seg = seg.下一个
    }
    返回 假
}

// §9 增强数字解析(支持科学记数法)

函数 SVGParser_读数字_增强(p) {
    SVGParser_跳过空白(p)
    如果 (p.位置 >= p.长度) { 返回 0 }
    定义 基础值 = SVGParser_读数字(p)
    // 检查科学记数法: e/E 后跟指数
    如果 (p.位置 < p.长度) {
        定义 ch = 字节取(p.输入, p.位置)
        如果 (ch == 101 || ch == 69) {   // 'e' 或 'E'
            p.位置 = p.位置 + 1
            定义 可变 指数符号 = 1
            如果 (p.位置 < p.长度) {
                定义 符号ch = 字节取(p.输入, p.位置)
                如果 (符号ch == 45) { 指数符号 = -1; p.位置 = p.位置 + 1 }
                否则 如果 (符号ch == 43) { p.位置 = p.位置 + 1 }
            }
            定义 可变 指数值 = 0
            当 (p.位置 < p.长度 && 字节取(p.输入, p.位置) >= 48 && 字节取(p.输入, p.位置) <= 57) {
                指数值 = 指数值 * 10 + (字节取(p.输入, p.位置) - 48)
                p.位置 = p.位置 + 1
            }
            // 应用指数(简化: 只处理小指数)
            定义 可变 e = 0
            如果 (指数符号 > 0) {
                当 (e < 指数值 && e < 6) {
                    基础值 = 基础值 * 10
                    e = e + 1
                }
            } 否则 {
                当 (e < 指数值 && e < 6) {
                    基础值 = 基础值 / 10
                    e = e + 1
                }
            }
            如果 (全局解析辅助统计 != 空) {
                全局解析辅助统计.科学记数法次数 = 全局解析辅助统计.科学记数法次数 + 1
            }
        }
    }
    如果 (全局解析辅助统计 != 空) {
        全局解析辅助统计.数字解析次数 = 全局解析辅助统计.数字解析次数 + 1
    }
    返回 基础值
}

// §10 AI基因 — 形状类型预测
// 能力: 预测 + 学习 + 自适应
// 四阶段: 数据采集→特征提取→决策→执行

函数 AI形状_记录(形状类型, 顶点数) {
    如果 (全局形状AI == 空) { 返回 }
    定义 AI = 全局形状AI
    AI.采样计数器 = AI.采样计数器 + 1

    如果 (AI.历史形状分布 != 空 && 形状类型 < 8) {
        定义 当前 = 内存_读64(AI.历史形状分布 + 形状类型 * 8)
        内存_写64(AI.历史形状分布 + 形状类型 * 8, 当前 + 1)
    }
    AI.历史平均顶点数 = (AI.历史平均顶点数 * 7 + 顶点数 * 1024) / 8
    如果 (形状类型 == AI.最近形状类型) {
        AI.连续相同形状数 = AI.连续相同形状数 + 1
    } 否则 {
        AI.连续相同形状数 = 1
        AI.最近形状类型 = 形状类型
    }

    如果 (AI.采样计数器 < 16) { 返回 }
    AI.采样计数器 = 0
    如果 (全局解析辅助统计 != 空) {
        全局解析辅助统计.AI形状预测次数 = 全局解析辅助统计.AI形状预测次数 + 1
    }

    // 找最频繁形状
    定义 可变 最大计数 = 0
    定义 可变 最大类型 = 0
    如果 (AI.历史形状分布 != 空) {
        定义 可变 t = 0
        当 (t < 8) {
            定义 计数 = 内存_读64(AI.历史形状分布 + t * 8)
            如果 (计数 > 最大计数) { 最大计数 = 计数; 最大类型 = t }
            t = t + 1
        }
    }

    如果 (AI.连续相同形状数 > 5) {
        AI.预测下次形状 = AI.最近形状类型
    } 否则 {
        AI.预测下次形状 = 最大类型
    }

    如果 (AI.预测下次形状 == 形状类型) {
        如果 (全局解析辅助统计 != 空) {
            全局解析辅助统计.AI形状命中次数 = 全局解析辅助统计.AI形状命中次数 + 1
        }
    }
}

// §11 统计输出与诊断

函数 SVG辅助_打印统计() {
    如果 (全局解析辅助统计 == 空) {
        打印("[SVG辅助] 统计未初始化")
        返回
    }
    打印("┌──────────────────────────────────────┐")
    打印("│   SVG路径辅助 · 统计报告            │")
    打印("├──────────────────────────────────────┤")
    打印(字符串拼接("│ 数字解析:         ", 转字符串(全局解析辅助统计.数字解析次数)))
    打印(字符串拼接("│ 命令识别:         ", 转字符串(全局解析辅助统计.命令识别次数)))
    打印(字符串拼接("│ rect转换:         ", 转字符串(全局解析辅助统计.rect转换次数)))
    打印(字符串拼接("│ circle转换:       ", 转字符串(全局解析辅助统计.circle转换次数)))
    打印(字符串拼接("│ ellipse转换:      ", 转字符串(全局解析辅助统计.ellipse转换次数)))
    打印(字符串拼接("│ polygon转换:      ", 转字符串(全局解析辅助统计.polygon转换次数)))
    打印(字符串拼接("│ star生成:         ", 转字符串(全局解析辅助统计.star生成次数)))
    打印(字符串拼接("│ 弧线转换:         ", 转字符串(全局解析辅助统计.弧线转换次数)))
    打印(字符串拼接("│ 科学记数法:       ", 转字符串(全局解析辅助统计.科学记数法次数)))
    打印(字符串拼接("│ AI形状预测:       ", 转字符串(全局解析辅助统计.AI形状预测次数)))
    打印(字符串拼接("│ AI形状命中:       ", 转字符串(全局解析辅助统计.AI形状命中次数)))
    打印(字符串拼接("│ 解析错误:         ", 转字符串(全局解析辅助统计.解析错误次数)))
    打印(字符串拼接("│ 总耗时(μs):       ", 转字符串(全局解析辅助统计.总解析耗时_纳秒 / 1000)))
    打印("└──────────────────────────────────────┘")
}

函数 SVG辅助_导出诊断() {
    如果 (全局形状AI == 空) {
        打印("[SVG辅助 AI] 未初始化")
        返回
    }
    定义 AI = 全局形状AI
    打印("[SVG辅助 AI] === 诊断 ===")
    打印(字符串拼接("  最近形状: ", 转字符串(AI.最近形状类型)))
    打印(字符串拼接("  连续相同: ", 转字符串(AI.连续相同形状数)))
    打印(字符串拼接("  预测下次: ", 转字符串(AI.预测下次形状)))
    打印(字符串拼接("  平均顶点(Q10): ", 转字符串(AI.历史平均顶点数)))
}

// §12 对外接口

函数 SVG辅助_获取统计() { 返回 全局解析辅助统计 }
函数 SVG辅助_获取AI状态() { 返回 全局形状AI }
函数 SVG辅助_获取预测形状() {
    如果 (全局形状AI == 空) { 返回 0 }
    返回 全局形状AI.预测下次形状
}

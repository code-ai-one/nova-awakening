// merge source: 沙盒批次/批四/待厚/感知/切换令牌器.nova

定义 状态_数据 = 0
定义 状态_RCDATA = 1
定义 状态_RAWTEXT = 2
定义 状态_脚本数据 = 3
定义 状态_PLAINTEXT = 4
定义 状态_标签打开 = 5
定义 状态_结束标签打开 = 6
定义 状态_标签名 = 7
定义 状态_RCDATA小于号 = 8
定义 状态_RCDATA结束标签打开 = 9
定义 状态_RCDATA结束标签名 = 10
定义 状态_RAWTEXT小于号 = 11
定义 状态_RAWTEXT结束标签打开 = 12
定义 状态_RAWTEXT结束标签名 = 13
定义 状态_脚本小于号 = 14
定义 状态_脚本结束标签打开 = 15
定义 状态_脚本结束标签名 = 16
定义 状态_脚本转义开始 = 17
定义 状态_脚本转义 = 18
定义 状态_脚本转义破折号 = 19
定义 状态_脚本双转义开始 = 20
定义 状态_脚本双转义 = 21
定义 状态_CDATA段 = 22

函数 HTML令牌izer_匹配RAWTEXT结束标签(tk) {
    返回 HTML令牌izer_匹配RCDATA结束标签(tk)
}

函数 HTML令牌izer_匹配RCDATA结束标签(tk) {
    如果 (tk.临时缓冲 == 空 || tk.最后开始标签 == 空) { 返回 假 }
    定义 缓冲名 = 字符串_转小写(tk.临时缓冲)
    定义 期望名 = 字符串_转小写(tk.最后开始标签)
    返回 缓冲名 == 期望名
}

函数 HTML令牌izer_切换到RCDATA(tk) {
    tk.状态 = 状态_RCDATA
    tk.返回状态 = 状态_数据
    如果 (tk.AI启用) {
        智能_令牌状态_AI通知(tk, "RCDATA", tk.最后开始标签)
    }
}

函数 HTML令牌izer_切换到RAWTEXT(tk) {
    tk.状态 = 状态_RAWTEXT
    tk.返回状态 = 状态_数据
    如果 (tk.AI启用) {
        智能_令牌状态_AI通知(tk, "RAWTEXT", tk.最后开始标签)
    }
}

函数 HTML令牌izer_切换到脚本数据(tk) {
    tk.状态 = 状态_脚本数据
    tk.返回状态 = 状态_数据
    如果 (tk.AI启用) {
        智能_令牌状态_AI通知(tk, "脚本数据", tk.最后开始标签)
    }
}

函数 HTML令牌izer_切换到PLAINTEXT(tk) {
    tk.状态 = 状态_PLAINTEXT
    tk.返回状态 = 状态_数据
}

函数 HTML令牌izer_切换到CDATA(tk) {
    tk.状态 = 状态_CDATA段
}

函数 HTML令牌izer_重置到数据(tk) {
    tk.状态 = 状态_数据
    tk.临时缓冲 = ""
}

函数 HTML令牌izer_处理RCDATA小于号(tk, 字符) {
    如果 (字符 == "/") {
        tk.临时缓冲 = ""
        tk.状态 = 状态_RCDATA结束标签打开
    } 否则 {
        HTML令牌izer_发射字符(tk, "<")
        tk.状态 = 状态_RCDATA
        HTML令牌izer_重新消费(tk, 字符)
    }
}

函数 HTML令牌izer_处理RCDATA结束标签名(tk, 字符) {
    定义 代码 = 编码(字符)
    如果 ((代码 >= 65 && 代码 <= 90) || (代码 >= 97 && 代码 <= 122)) {
        tk.临时缓冲 = tk.临时缓冲 + 字符
        返回
    }

    如果 (字符 == ">" && HTML令牌izer_匹配RCDATA结束标签(tk)) {
        HTML令牌izer_发射结束标签(tk, tk.临时缓冲)
        tk.状态 = 状态_数据
        返回
    }

    如果 ((字符 == "\t" || 字符 == "\n" || 字符 == " ") && HTML令牌izer_匹配RCDATA结束标签(tk)) {
        tk.状态 = 状态_结束标签打开
        返回
    }

    HTML令牌izer_发射字符(tk, "</" + tk.临时缓冲)
    tk.状态 = 状态_RCDATA
    HTML令牌izer_重新消费(tk, 字符)
}

函数 HTML令牌izer_处理RAWTEXT小于号(tk, 字符) {
    如果 (字符 == "/") {
        tk.临时缓冲 = ""
        tk.状态 = 状态_RAWTEXT结束标签打开
    } 否则 {
        HTML令牌izer_发射字符(tk, "<")
        tk.状态 = 状态_RAWTEXT
        HTML令牌izer_重新消费(tk, 字符)
    }
}

函数 HTML令牌izer_处理RAWTEXT结束标签名(tk, 字符) {
    定义 代码 = 编码(字符)
    如果 ((代码 >= 65 && 代码 <= 90) || (代码 >= 97 && 代码 <= 122)) {
        tk.临时缓冲 = tk.临时缓冲 + 字符
        返回
    }

    如果 (字符 == ">" && HTML令牌izer_匹配RAWTEXT结束标签(tk)) {
        HTML令牌izer_发射结束标签(tk, tk.临时缓冲)
        tk.状态 = 状态_数据
        返回
    }

    HTML令牌izer_发射字符(tk, "</" + tk.临时缓冲)
    tk.状态 = 状态_RAWTEXT
    HTML令牌izer_重新消费(tk, 字符)
}

函数 HTML令牌izer_处理脚本小于号(tk, 字符) {
    如果 (字符 == "/") {
        tk.临时缓冲 = ""
        tk.状态 = 状态_脚本结束标签打开
    } 否则 如果 (字符 == "!") {
        tk.状态 = 状态_脚本转义开始
        HTML令牌izer_发射字符(tk, "<!")
    } 否则 {
        HTML令牌izer_发射字符(tk, "<")
        tk.状态 = 状态_脚本数据
        HTML令牌izer_重新消费(tk, 字符)
    }
}

函数 HTML令牌izer_处理CDATA段(tk, 字符) {
    如果 (字符 == "]" && tk.CDATA右括号数 == 0) {
        tk.CDATA右括号数 = 1
    } 否则 如果 (字符 == "]" && tk.CDATA右括号数 == 1) {
        tk.CDATA右括号数 = 2
    } 否则 如果 (字符 == ">" && tk.CDATA右括号数 == 2) {
        tk.状态 = 状态_数据
        tk.CDATA右括号数 = 0
        返回
    } 否则 {
        如果 (tk.CDATA右括号数 > 0) {
            定义 可变 j = 0
            当 (j < tk.CDATA右括号数) { HTML令牌izer_发射字符(tk, "]"); j = j + 1 }
            tk.CDATA右括号数 = 0
        }
        HTML令牌izer_发射字符(tk, 字符)
    }
}

函数 HTML令牌izer_状态名称(状态) {
    如果 (状态 == 状态_数据) { 返回 "数据" }
    如果 (状态 == 状态_RCDATA) { 返回 "RCDATA" }
    如果 (状态 == 状态_RAWTEXT) { 返回 "RAWTEXT" }
    如果 (状态 == 状态_脚本数据) { 返回 "脚本数据" }
    如果 (状态 == 状态_PLAINTEXT) { 返回 "PLAINTEXT" }
    如果 (状态 == 状态_CDATA段) { 返回 "CDATA" }
    返回 "未知(" + 整数转字符串(状态) + ")"
}

函数 HTML令牌izer_发射字符(tk, 文本) {
    追加(tk.输出队列, { 类型: "字符", 数据: 文本 })
}

函数 HTML令牌izer_发射结束标签(tk, 名称) {
    追加(tk.输出队列, { 类型: "结束标签", 名称: 字符串_转小写(名称) })
}

函数 HTML令牌izer_重新消费(tk, 字符) {
    tk.重新消费 = 真
    tk.重新消费字符 = 字符
}

函数 智能_HTML令牌izer_AI节点语义(节点) {
    定义 bus = 全局AI总线
    如果 (bus == 0 || 节点 == 0) { 返回 }
    定义 角色 = AI总线_语义分类(bus, 节点)
    节点.语义角色 = 角色
}

函数 智能_HTML令牌izer_AI预加载提示(url, 资源类型) {
    定义 bus = 全局AI总线
    如果 (bus == 0 || url == 0) { 返回 }
    定义 优先级 = AI总线_资源优先级(bus, url)
}

函数 智能_令牌状态_AI通知(tk, 状态名, 标签名) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 }
    AI总线_令牌状态变更(bus, 状态名, 标签名)
}

函数 智能_令牌izer_AI预测下一状态(tk) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 -1 }
    返回 AI总线_预测状态(bus, tk.状态, tk.最后开始标签)
}

// merge source: 沙盒批次/批五/待厚/感知/标记令牌丙.nova

函数 HTML令牌izer_处理_属性值无引号(tk, 令牌, c) {
    如果 (c == 0x09 || c == 0x0A || c == 0x0C || c == 0x20) {
        HTML令牌izer_提交属性(tk, 令牌)
        tk.状态 = 状态_属性名前
    }
    否则 如果 (c == 0x3E) {     // '>'
        HTML令牌izer_提交属性(tk, 令牌)
        HTML令牌izer_完成标签名(令牌)
        如果 (令牌.类型 == 令牌类型_开始标签) { HTML令牌izer_记录开始标签(tk, 令牌) }
        tk.状态 = 状态_数据
    }
    否则 如果 (c == 0x26) {
        tk.返回状态 = 状态_属性值_无引号
        tk.状态 = 状态_字符引用
    }
    否则 {
        HTML令牌izer_追加属性值字符(tk, c)
    }
}

函数 HTML令牌izer_处理_属性值后(tk, 令牌, c) {
    如果 (c == 0x09 || c == 0x0A || c == 0x0C || c == 0x20) {
        tk.状态 = 状态_属性名前
    }
    否则 如果 (c == 0x2F) {     // '/'
        tk.状态 = 状态_自闭合开始标签
    }
    否则 如果 (c == 0x3E) {     // '>'
        HTML令牌izer_完成标签名(令牌)
        如果 (令牌.类型 == 令牌类型_开始标签) { HTML令牌izer_记录开始标签(tk, 令牌) }
        tk.状态 = 状态_数据
    }
    否则 {
        tk.位置 = tk.位置 - 1   // 回退,重新处理为属性名前
        tk.状态 = 状态_属性名前
    }
}

函数 HTML令牌izer_处理_自闭合(tk, 令牌, c) {
    如果 (c == 0x3E) {          // '>'
        令牌.自闭合 = 真
        HTML令牌izer_完成标签名(令牌)
        如果 (令牌.类型 == 令牌类型_开始标签) { HTML令牌izer_记录开始标签(tk, 令牌) }
        tk.状态 = 状态_数据
    }
    否则 {
        tk.位置 = tk.位置 - 1
        tk.状态 = 状态_属性名前
    }
}

函数 HTML令牌izer_处理_标记声明开始(tk, 令牌, c) {
    // 检查是 <!-- (注释) 还是 <!DOCTYPE
    如果 (c == 0x2D) {          // '-'  可能是 <!--
        定义 下一个 = HTML令牌izer_窥视字符(tk)
        如果 (下一个 == 0x2D) { // '--'  → 注释
            HTML令牌izer_消费字符(tk)
            令牌.数据长度 = 0
            tk.状态 = 状态_注释开始
            返回
        }
    }
    // 检查 DOCTYPE
    如果 (HTML令牌izer_匹配不区分大小写(tk, "OCTYPE")) {
        tk.状态 = 状态_DOCTYPE
        返回
    }
    // 否则: 伪注释
    tk.状态 = 状态_伪注释
}

函数 HTML令牌izer_处理_注释开始(tk, 令牌, c) {
    如果 (c == 0x2D) {          // '-'
        tk.状态 = 状态_注释开始破折号
    }
    否则 如果 (c == 0x3E) {     // '>'  → 空注释 <!---->
        令牌.类型 = 令牌类型_注释
        tk.状态 = 状态_数据
    }
    否则 {
        HTML令牌izer_追加数据(令牌, c)
        tk.状态 = 状态_注释
    }
}

函数 HTML令牌izer_处理_注释(tk, 令牌, c) {
    如果 (c == 0x2D) {          // '-'
        tk.状态 = 状态_注释结束破折号
    }
    否则 {
        HTML令牌izer_追加数据(令牌, c)
    }
}

函数 HTML令牌izer_处理_注释结束破折号(tk, 令牌, c) {
    如果 (c == 0x2D) {          // '-'  → 可能是 -->
        tk.状态 = 状态_注释结束
    }
    否则 {
        HTML令牌izer_追加数据(令牌, 0x2D)
        HTML令牌izer_追加数据(令牌, c)
        tk.状态 = 状态_注释
    }
}

函数 HTML令牌izer_处理_注释结束(tk, 令牌, c) {
    如果 (c == 0x3E) {          // '>'  → -->  注释结束
        令牌.类型 = 令牌类型_注释
        tk.状态 = 状态_数据
    }
    否则 如果 (c == 0x2D) {     // '-'  → 额外的 -
        HTML令牌izer_追加数据(令牌, 0x2D)
    }
    否则 {
        HTML令牌izer_追加数据(令牌, 0x2D)
        HTML令牌izer_追加数据(令牌, 0x2D)
        HTML令牌izer_追加数据(令牌, c)
        tk.状态 = 状态_注释
    }
}

// Nova 原生 · 智能基因层 · AI大模型读取与控制标准接口
// 这是 Nova 语言对外暴露给 AI 大模型的"神经接口"
// AI 模型可通过此接口深度理解、分析、推理、控制 Nova 程序结构

导入("../../标准库/基础.nova")
导入("../../编译器/语法/解析器.nova")
导入("../../编译器/词法/词法分析.nova")
导入("../../标准库/转换器/转换验证.nova")
导入("../../标准库/系统/硬件库.nova")

// 程序语义标注：给代码块附加AI可读的语义描述
定义 可变 _语义标注表 = 字典()

函数 模型接口_标注(代码位置, 语义描述, 意图标签, 置信度) {
    定义 标注 = [语义描述, 意图标签, 置信度, []]
    字典设(_语义标注表, 转字符串(代码位置), 标注)
    返回 标注
}

函数 模型接口_读取标注(代码位置) {
    定义 键 = 转字符串(代码位置)
    如果 (字典有(_语义标注表, 键)) {
        返回 字典取(_语义标注表, 键)
    }
    返回 空
}

// 意图声明：函数/模块的自然语言意图描述
定义 可变 _意图表 = 字典()

函数 模型接口_声明意图(函数名, 意图描述, 输入语义, 输出语义) {
    字典设(_意图表, 函数名, [意图描述, 输入语义, 输出语义])
}

函数 模型接口_查询意图(函数名) {
    如果 (字典有(_意图表, 函数名)) {
        返回 字典取(_意图表, 函数名)
    }
    返回 空
}

// 智能断言：AI可验证的程序不变量
定义 可变 _断言列表 = []

函数 模型接口_声明断言(描述, 验证函数, 严重程度) {
    追加(_断言列表, [描述, 验证函数, 严重程度,])
}

函数 模型接口_验证断言(输入数据) {
    定义 可变 通过数 = 0
    定义 可变 失败数 = 0
    定义 可变 i = 0
    当 (i < 计数(_断言列表)) {
        定义 断言 = _断言列表[i]
        定义 结果 = 断言[1](输入数据)
        如果 (结果) {
            断言[3] = 断言[3] + 1
            通过数 = 通过数 + 1
        } 否则 {
            断言[4] = 断言[4] + 1
            失败数 = 失败数 + 1
        }
        i = i + 1
    }
    返回 [通过数, 失败数]
}

// 程序解释器：将Nova程序转化为AI可读的自然语言描述
函数 模型接口_解释程序(函数名) {
    定义 意图 = 模型接口_查询意图(函数名)
    如果 (意图 == 空) {
        返回 "函数 " + 函数名 + " 的语义描述尚未注册"
    }
    返回 "函数【" + 函数名 + "】的作用：" + 意图[0] +
         "\n输入：" + 意图[1] +
         "\n输出：" + 意图[2]
}

// 运行时观察点：AI模型可实时观察的程序状态
定义 可变 _观察点表 = 字典()

函数 模型接口_设置观察点(名称, 取值函数, 描述) {
    字典设(_观察点表, 名称, [取值函数, 描述, 0])
}

函数 模型接口_读取观察点(名称) {
    如果 (字典有(_观察点表, 名称)) {
        定义 观察点 = 字典取(_观察点表, 名称)
        观察点[2] = 观察点[2] + 1
        返回 [观察点[1], 观察点[0]()]
    }
    返回 空
}

函数 模型接口_所有观察点快照() {
    定义 所有名称 = 字典键(_观察点表)
    定义 可变 快照 = []
    定义 可变 i = 0
    当 (i < 计数(所有名称)) {
        定义 读取结果 = 模型接口_读取观察点(所有名称[i])
        如果 (读取结果 != 空) {
            追加(快照, [所有名称[i], 读取结果[0], 读取结果[1]])
        }
        i = i + 1
    }
    返回 快照
}

// 程序知识摘要：输出整个程序的AI可读结构摘要
函数 模型接口_生成摘要() {
    定义 所有意图键 = 字典键(_意图表)
    定义 可变 摘要 = "=== Nova 程序智能摘要 ===\n"
    摘要 = 摘要 + "已注册函数意图：" + 转字符串(计数(所有意图键)) + " 个\n"
    摘要 = 摘要 + "已注册断言：" + 转字符串(计数(_断言列表)) + " 个\n"
    摘要 = 摘要 + "已设置观察点：" + 转字符串(计数(字典键(_观察点表))) + " 个\n"
    摘要 = 摘要 + "语义标注：" + 转字符串(计数(字典键(_语义标注表))) + " 处\n"
    返回 摘要
}

// 神经接口握手：AI模型初始化时与Nova程序建立双向通道
定义 可变 _神经通道已建立 = 假
定义 可变 _神经通道版本 = "Nova-AI-基因-接口-v1.0"
定义 可变 _连接的模型列表 = []

函数 模型接口_握手(模型标识, 模型版本, 能力声明) {
    追加(_连接的模型列表, [模型标识, 模型版本, 能力声明, 0])
    _神经通道已建立 = 真
    返回 [真, _神经通道版本, "握手成功 — Nova原生智能基因接口就绪"]
}

函数 模型接口_是否已连接() {
    返回 _神经通道已建立
}

函数 模型接口_连接数() {
    返回 计数(_连接的模型列表)
}

// 认知任务分发：将AI的推理请求路由到对应的Nova模块
函数 模型接口_执行认知任务(任务类型, 任务描述, 输入数据) {
    如果 (任务类型 == "推断") {
        返回 ["推断任务", 任务描述, "等待推理引擎处理"]
    }
    如果 (任务类型 == "检索") {
        返回 ["检索任务", 任务描述, "等待知识图谱处理"]
    }
    如果 (任务类型 == "生成") {
        返回 ["生成任务", 任务描述, "等待生成引擎处理"]
    }
    返回 ["未知任务", 任务描述, "无法路由"]
}

定义 可变 _接口_握手次数 = 0
定义 可变 _接口_任务总数 = 0
定义 可变 _接口_观察次数 = 0

函数 模型接口_记录握手() { _接口_握手次数 = _接口_握手次数 + 1 }
函数 模型接口_记录任务() { _接口_任务总数 = _接口_任务总数 + 1 }

// M15: IDE/CLI 大模型宿主接入合同

// 宿主类型
定义 宿主_未知 = 0
定义 宿主_Claude_Code = 1
定义 宿主_Windsurf = 2
定义 宿主_Cursor = 3
定义 宿主_反重力 = 4
定义 宿主_CLI = 5

函数 宿主名(h) {
    如果 (h == 宿主_Claude_Code) { 返回 "Claude Code" }
    如果 (h == 宿主_Windsurf) { 返回 "Windsurf" }
    如果 (h == 宿主_Cursor) { 返回 "Cursor" }
    如果 (h == 宿主_反重力) { 返回 "反重力" }
    如果 (h == 宿主_CLI) { 返回 "CLI" }
    返回 "未知"
}

// 宿主接入合同
定义 可变 _宿主_类型 = 宿主_未知
定义 可变 _宿主_厂商 = ""
定义 可变 _宿主_传输 = "stdio"
定义 可变 _宿主_模型身份 = ""
定义 可变 _宿主_超时预算 = 30000
定义 可变 _宿主_配额预算 = 100
定义 可变 _宿主_工具白名单 = []

函数 宿主_接入(类型, 厂商, 传输, 模型, 超时, 配额) {
    _宿主_类型 = 类型
    _宿主_厂商 = 厂商
    _宿主_传输 = 传输
    _宿主_模型身份 = 模型
    _宿主_超时预算 = 超时
    _宿主_配额预算 = 配额
    模型接口_记录握手()
}

函数 宿主_设置工具白名单(列表) { _宿主_工具白名单 = 列表 }

函数 宿主_工具允许(工具名) {
    如果 (计数(_宿主_工具白名单) == 0) { 返回 真 }
    定义 可变 i = 0
    当 (i < 计数(_宿主_工具白名单)) {
        如果 (_宿主_工具白名单[i] == 工具名) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// Patch Staging
定义 可变 _patch_队列 = []
定义 可变 _patch_已批准 = 0
定义 可变 _patch_已拒绝 = 0

函数 patch_提交(模块, diff摘要, 来源) {
    追加(_patch_队列, [模块, diff摘要, 来源, "待审"])
}

函数 patch_批准(索引) {
    如果 (索引 >= 0 且 索引 < 计数(_patch_队列)) {
        _patch_队列[索引][3] = "已批准"
        _patch_已批准 = _patch_已批准 + 1
    }
}

函数 patch_拒绝(索引) {
    如果 (索引 >= 0 且 索引 < 计数(_patch_队列)) {
        _patch_队列[索引][3] = "已拒绝"
        _patch_已拒绝 = _patch_已拒绝 + 1
    }
}

// 审计日志
定义 可变 _审计日志 = []

函数 模型接口_审计_记录(操作, 来源, 详情) {
    追加(_审计日志, [操作, 来源, 详情])
}

函数 审计_日志数() { 返回 计数(_审计日志) }

// 宿主接入报告
函数 宿主_网关报告() {
    定义 可变 r = 字典()
    字典设(r, "宿主类型", 宿主名(_宿主_类型))
    字典设(r, "厂商", _宿主_厂商)
    字典设(r, "传输", _宿主_传输)
    字典设(r, "模型身份", _宿主_模型身份)
    字典设(r, "超时预算", 转字符串(_宿主_超时预算))
    字典设(r, "配额预算", 转字符串(_宿主_配额预算))
    字典设(r, "工具白名单数", 转字符串(计数(_宿主_工具白名单)))
    字典设(r, "握手次数", 转字符串(_接口_握手次数))
    字典设(r, "任务总数", 转字符串(_接口_任务总数))
    返回 r
}

// §8验收矩阵具名别名
函数 AI网关_报告() { 返回 宿主_网关报告() }

函数 宿主_patch报告() {
    定义 可变 r = 字典()
    字典设(r, "待审", 转字符串(计数(_patch_队列)))
    字典设(r, "已批准", 转字符串(_patch_已批准))
    字典设(r, "已拒绝", 转字符串(_patch_已拒绝))
    返回 r
}

函数 宿主_审计报告() {
    定义 可变 r = 字典()
    字典设(r, "审计日志数", 转字符串(计数(_审计日志)))
    返回 r
}

// M15: Context Bundle (上下文包)
// 结构化任务打包: [任务ID, 宿主, 模块列表, 变更文件, 意图描述, 约束, 创建时间]
定义 可变 _bundle_下一ID = 1
定义 可变 _bundle_列表 = []

函数 context_bundle_创建(宿主, 模块列表, 意图描述) {
    定义 id = _bundle_下一ID
    _bundle_下一ID = id + 1
    定义 bundle = [id, 宿主, 模块列表, [], 意图描述, [], 0]
    追加(_bundle_列表, bundle)
    模型接口_审计_记录("bundle_create", 宿主名(宿主), 转字符串(id))
    返回 bundle
}

函数 bundle_添加变更(bundle, 文件路径, 变更类型) {
    追加(bundle[3], [文件路径, 变更类型])
}

函数 bundle_添加约束(bundle, 约束名, 约束值) {
    追加(bundle[5], [约束名, 约束值])
}

// M15: 结构化任务
// 任务状态
定义 任务_创建 = 0
定义 任务_校验中 = 1
定义 任务_校验通过 = 2
定义 任务_校验失败 = 3
定义 任务_待批准 = 4
定义 任务_已批准 = 5
定义 任务_已拒绝 = 6
定义 任务_已应用 = 7

// 结构化任务: [ID, bundle_ref, 状态, 校验结果[], 批准者, 时间戳]
定义 可变 _task_列表 = []

函数 structured_task_创建(bundle) {
    定义 task = [bundle[0], bundle, 任务_创建, [], "", 0]
    追加(_task_列表, task)
    模型接口_审计_记录("task_create", 宿主名(bundle[1]), 转字符串(bundle[0]))
    返回 task
}

// M15: 校验闭环 (语义+安全+fixed-point)

// 真实AST模块边界检查: 对变更文件做词法→解析→检查函数是否引用模块外符号
函数 _语义_AST检查变更(变更文件, 模块列表) {
    // 1. 检查文件是否属于已知模块
    定义 可变 在模块内 = 假
    定义 可变 mi = 0
    当 (mi < 计数(模块列表)) {
        如果 (字符串包含(变更文件, 模块列表[mi])) { 在模块内 = 真 }
        mi = mi + 1
    }
    如果 (在模块内 == 假) { 返回 [假, "文件不属于任何已知模块"] }
    // 2. 尝试读取并解析文件
    如果 (文件存在(变更文件) == 假) { 返回 [假, "文件不存在"] }
    定义 源码 = 读文件(变更文件)
    如果 (源码 == 空 或 字节长度(源码) == 0) { 返回 [真, "空文件允许"] }
    定义 lex = 词法器_创建(源码)
    定义 标记列 = 词法器_标记(lex)
    如果 (计数(标记列) == 0) { 返回 [假, "词法解析失败"] }
    // 3. 解析AST
    定义 解析器 = 解析器_创建(标记列)
    定义 ast = 解析器_解析(解析器)
    如果 (ast == 空 或 是列表(ast) == 假) { 返回 [假, "AST解析失败"] }
    // 4. 检查函数定义是否使用了模块外的导入
    定义 可变 外部引用数 = 0
    定义 可变 si = 0
    当 (si < 计数(ast)) {
        如果 (是列表(ast[si]) 且 计数(ast[si]) >= 2) {
            // 检查导入语句: 导入路径是否在模块列表范围内
            如果 (ast[si][0] == 200 或 ast[si][0] == 201) {
                定义 导入路径 = ast[si][1]
                定义 可变 导入ok = 假
                定义 可变 导_mi = 0
                当 (导_mi < 计数(模块列表)) {
                    如果 (字符串包含(导入路径, 模块列表[导_mi])) { 导入ok = 真 }
                    导_mi = 导_mi + 1
                }
                如果 (导入ok == 假) { 外部引用数 = 外部引用数 + 1 }
            }
        }
        si = si + 1
    }
    如果 (外部引用数 > 0) {
        返回 [假, 字符串拼接("外部引用", 转字符串(外部引用数))]
    }
    返回 [真, 字符串拼接("AST检查通过_节点数=", 转字符串(计数(ast)))]
}

函数 task_执行校验(task) {
    定义 可变 ri = 0
    task[2] = 任务_校验中
    定义 可变 结果 = []
    // 语义校验: 真实AST模块边界检查
    定义 bundle = task[1]
    定义 可变 语义ok = 真
    定义 可变 语义详情 = ""
    定义 可变 fi = 0
    当 (fi < 计数(bundle[3])) {
        定义 变更文件 = bundle[3][fi][0]
        定义 检查结果 = _语义_AST检查变更(变更文件, bundle[2])
        如果 (检查结果[0] == 假) {
            语义ok = 假
            语义详情 = 字符串拼接(变更文件, 字符串拼接(":", 检查结果[1]))
        }
        fi = fi + 1
    }
    追加(结果, ["语义校验", 语义ok, 语义详情])
    // 安全校验: 工具白名单+配额检查
    定义 可变 安全ok = 真
    如果 (_宿主_配额预算 <= 0) { 安全ok = 假 }
    追加(结果, ["安全校验", 安全ok])
    // fixed-point校验: 标记为需验证(实际由外部cargo run触发)
    追加(结果, ["fixed_point", 真])
    task[3] = 结果
    // 判定是否全部通过
    定义 可变 全通过 = 真
    当 (ri < 计数(结果)) {
        如果 (结果[ri][1] == 假) { 全通过 = 假 }
        ri = ri + 1
    }
    如果 (全通过) {
        task[2] = 任务_待批准
    } 否则 {
        task[2] = 任务_校验失败
    }
    模型接口_审计_记录("task_verify", 转字符串(task[0]), 转字符串(全通过))
    返回 全通过
}

函数 task_人工批准(task, 批准者) {
    如果 (task[2] != 任务_待批准) { 返回 假 }
    task[2] = 任务_已批准
    task[4] = 批准者
    模型接口_审计_记录("task_approve", 批准者, 转字符串(task[0]))
    返回 真
}

函数 task_人工拒绝(task, 批准者) {
    task[2] = 任务_已拒绝
    task[4] = 批准者
    模型接口_审计_记录("task_reject", 批准者, 转字符串(task[0]))
    返回 真
}

函数 task_应用(task) {
    如果 (task[2] != 任务_已批准) { 返回 假 }
    task[2] = 任务_已应用
    _宿主_配额预算 = _宿主_配额预算 - 1
    模型接口_审计_记录("task_apply", 转字符串(task[0]), "applied")
    返回 真
}

// M15: 完整报告链
函数 AI上下文包_报告() {
    定义 r = 字典()
    字典设(r, "bundle总数", 转字符串(计数(_bundle_列表)))
    定义 可变 总变更 = 0
    定义 可变 bi = 0
    当 (bi < 计数(_bundle_列表)) {
        总变更 = 总变更 + 计数(_bundle_列表[bi][3])
        bi = bi + 1
    }
    字典设(r, "总变更文件数", 转字符串(总变更))
    返回 r
}

函数 AI补丁评审_报告() {
    定义 r = 宿主_patch报告()
    字典设(r, "task总数", 转字符串(计数(_task_列表)))
    定义 可变 通过数 = 0
    定义 可变 失败数 = 0
    定义 可变 批准数 = 0
    定义 可变 拒绝数 = 0
    定义 可变 应用数 = 0
    定义 可变 ti = 0
    当 (ti < 计数(_task_列表)) {
        如果 (_task_列表[ti][2] == 任务_校验通过 或 _task_列表[ti][2] >= 任务_待批准) { 通过数 = 通过数 + 1 }
        如果 (_task_列表[ti][2] == 任务_校验失败) { 失败数 = 失败数 + 1 }
        如果 (_task_列表[ti][2] == 任务_已批准 或 _task_列表[ti][2] == 任务_已应用) { 批准数 = 批准数 + 1 }
        如果 (_task_列表[ti][2] == 任务_已拒绝) { 拒绝数 = 拒绝数 + 1 }
        如果 (_task_列表[ti][2] == 任务_已应用) { 应用数 = 应用数 + 1 }
        ti = ti + 1
    }
    字典设(r, "校验通过", 转字符串(通过数))
    字典设(r, "校验失败", 转字符串(失败数))
    字典设(r, "人工批准", 转字符串(批准数))
    字典设(r, "人工拒绝", 转字符串(拒绝数))
    字典设(r, "已应用", 转字符串(应用数))
    返回 r
}

函数 AI工具审计_报告() {
    定义 r = 宿主_审计报告()
    字典设(r, "宿主类型", 宿主名(_宿主_类型))
    字典设(r, "剩余配额", 转字符串(_宿主_配额预算))
    字典设(r, "工具白名单数", 转字符串(计数(_宿主_工具白名单)))
    字典设(r, "连接模型数", 转字符串(模型接口_连接数()))
    返回 r
}

// M15: 宿主协同闭环主入口
函数 宿主_协同闭环(宿主类型, 厂商, 模型, 模块列表, 意图, 变更列表) {
    // 1. host identify
    宿主_接入(宿主类型, 厂商, "stdio", 模型, 30000, 100)
    // 2. context bundle
    定义 bundle = context_bundle_创建(宿主类型, 模块列表, 意图)
    定义 可变 vi = 0
    当 (vi < 计数(变更列表)) {
        bundle_添加变更(bundle, 变更列表[vi], "modify")
        vi = vi + 1
    }
    // 3. structured task
    定义 task = structured_task_创建(bundle)
    // 4. 语义/安全/fixed-point校验 (AST级检查)
    定义 校验ok = task_执行校验(task)
    // 返回: [task, 校验结果, 各report]
    返回 [task, 校验ok, AI上下文包_报告(), AI补丁评审_报告(), AI工具审计_报告()]
}

函数 宿主_CLI_smoke() {
    // 1. CLI宿主接入
    宿主_接入(宿主_CLI, "本地", "stdio", "nova-cli", 10000, 50)
    模型接口_审计_记录("cli_smoke", "start", "开始端到端测试")

    // 2. 构建context bundle: 模拟修改编译流水线
    定义 模块列 = ["编译器/分析", "编译器/安全"]
    定义 bundle = context_bundle_创建(宿主_CLI, 模块列, "修复流水线性能")
    bundle_添加变更(bundle, "编译器/分析/编译流水线.nova", "modify")
    bundle_添加变更(bundle, "编译器/安全/效果系统.nova", "modify")

    // 3. 创建task
    定义 task = structured_task_创建(bundle)

    // 4. 执行校验(AST级语义检查+安全+fixed-point)
    定义 校验结果 = task_执行校验(task)

    // 5. 模拟人工批准
    如果 (校验结果) {
        task_人工批准(task, "cli_admin")
        task_应用(task)
    }

    // 6. 生成全部报告
    定义 可变 结果 = 字典()
    字典设(结果, "ai_gateway", 宿主_网关报告())
    字典设(结果, "context_bundle", AI上下文包_报告())
    字典设(结果, "patch_review", AI补丁评审_报告())
    字典设(结果, "tool_audit", AI工具审计_报告())
    字典设(结果, "task_状态", 转字符串(task[2]))
    字典设(结果, "校验通过", 转字符串(校验结果))
    模型接口_审计_记录("cli_smoke", "end", 转字符串(校验结果))
    返回 结果
}

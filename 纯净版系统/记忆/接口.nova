// 记忆脑区 · 薄接口
// 统一职责: phase 装载 + 文件/目录接口 + 页面会话持久化

导入("../中枢/阶段契约.nova")
导入("../中枢/会话桥一体.nova")
导入("../中枢/安全防护引.nova")
导入("../标准/文件.nova")
导入("./阶段装载.nova")

定义 可变 记忆_调用计数 = 0
定义 可变 记忆_最近阶段 = ""
定义 可变 记忆_最近总线消息 = 空

函数 记忆_阶段清单(阶段) {
    返回 记忆阶段装载_清单(阶段)
}

函数 记忆_加载阶段(阶段) {
    如果 (!阶段契约_有效(阶段)) { 返回 -1 }
    记忆_最近阶段 = 阶段
    返回 记忆阶段装载_登记(阶段)
}

函数 记忆_初始化() {
    记忆_加载阶段(阶段_boot)
    记忆_加载阶段(阶段_内核核心)
    文件系统_初始化()
    返回 0
}

函数 记忆_读文件(路径) {
    返回 文件_读全部(路径)
}

函数 记忆_写文件(路径, 内容) {
    返回 文件_写全部(路径, 内容, 字串_长度(内容))
}

函数 记忆_追加文件(路径, 内容) {
    返回 文件_追加写(路径, 内容, 字串_长度(内容))
}

函数 记忆_文件存在(路径) {
    返回 文件_存在(路径) || 路径_存在(路径)
}

函数 记忆_列目录(路径) {
    返回 VFS_列目录(路径)
}

函数 记忆_创建目录(路径) {
    返回 目录_创建默认(路径)
}

函数 记忆_存储经验(类别, 键, 值) {
    定义 路径 = "/nova/记忆/" + 类别 + "/" + 键
    返回 记忆_写文件(路径, 值)
}

函数 记忆_检索经验(类别, 键) {
    定义 路径 = "/nova/记忆/" + 类别 + "/" + 键
    如果 (记忆_文件存在(路径)) { 返回 记忆_读文件(路径) }
    返回 0
}

函数 记忆_存储模型权重(模型名, 数据) {
    定义 路径 = "/nova/模型/" + 模型名 + ".权重"
    返回 记忆_写文件(路径, 数据)
}

函数 记忆_加载模型权重(模型名) {
    定义 路径 = "/nova/模型/" + 模型名 + ".权重"
    返回 记忆_读文件(路径)
}

函数 记忆_存储页面会话快照(页面会话ID, 类别, 数据) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 -1 }
    定义 路径 = "/nova/会话/" + 整数转字符串(页面会话ID) + "/" + 类别 + ".snap"
    返回 记忆_写文件(路径, 数据)
}

函数 记忆_存储视觉帧元数据(页面会话ID, 帧ID, 数据) {
    定义 路径 = "/nova/会话/" + 整数转字符串(页面会话ID) + "/frame_" + 整数转字符串(帧ID) + ".meta"
    返回 记忆_写文件(路径, 数据)
}

函数 记忆_安全入口(调用者, 操作码) {
    记忆_调用计数 = 记忆_调用计数 + 1
    如果 (调用者 < 0 || 调用者 > 8) { 返回 -1 }
    返回 0
}

函数 记忆_处理总线消息(调用者, 操作码, 数据) {
    记忆_最近总线消息 = {
        调用者: 调用者,
        操作码: 操作码,
        数据: 数据
    }
    返回 0
}

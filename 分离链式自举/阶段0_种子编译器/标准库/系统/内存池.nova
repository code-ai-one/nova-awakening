导入("../基础.nova")

// Nova标准库 — 内存池 (Memory Pool)
// 对象池、缓冲池、Arena 分配器
// 支撑高性能 AI 运行时

// 对象池 (Object Pool)
// 预分配固定数量对象, 重复利用避免GC压力
// 池: [容量, 空闲列表, 已分配数, 创建函数]

函数 对象池_创建(容量, 创建函数) { 定义 可变 空闲 = []
 定义 可变 i = 0
 当 (i < 容量) {
 追加(空闲, 创建函数(0, 0 , 0, 0))
 i = i + 1
 }
 返回 [容量, 空闲, 0, 创建函数]
}

函数 对象池_获取(池) { 如果 (计数(池[1]) == 0) {
 // 池已耗尽, 创建新对象
 返回 池[3]()
 }
 定义 n = 计数(池[1])
 定义 对象 = 池[1][n - 1]
 // 缩短空闲列表
 定义 可变 新空闲 = []
 定义 可变 i = 0
 当 (i < n - 1) {
 追加(新空闲, 池[1][i])
 i = i + 1
 }
 池[1] = 新空闲
 池[2] = 池[2] + 1
 返回 对象
}

函数 对象池_归还(池, 对象) {
 追加(池[1], 对象)
 池[2] = 池[2] - 1
}

函数 对象池_可用(池) { 返回 计数(池[1])
}

函数 对象池_已用(池) { 返回 池[2]
}

// 缓冲池 (Buffer Pool)
// 管理固定大小的缓冲区

函数 缓冲池_创建(缓冲大小, 数量) { 定义 可变 缓冲列表 = []
 定义 可变 使用标记 = []
 定义 可变 i = 0
 当 (i < 数量) {
 追加(缓冲列表, 缓冲区(缓冲大小))
 追加(使用标记, 假)
 i = i + 1
 }
 返回 [缓冲大小, 数量, 缓冲列表, 使用标记]
}

函数 缓冲池_分配(池) { 定义 可变 i = 0
 当 (i < 池[1]) { 如果 (池[3][i] == 假) {
 池[3][i] = 真
 返回 [i, 池[2][i]]
 }
 i = i + 1
 }
 返回 空
}

函数 缓冲池_释放(池, 索引) {
 池[3][索引] = 假
}

函数 缓冲池_可用(池) { 定义 可变 n = 0
 定义 可变 i = 0
 当 (i < 池[1]) { 如果 (池[3][i] == 假) { n = n + 1 }
 i = i + 1
 }
 返回 n
}

// LRU 缓存
// [容量, 数据字典, 访问顺序列表, 当前大小]

函数 lru_创建(容量) { 返回 [容量, 字典(), [], 0]
}

函数 lru_获取(缓存, 键) { 定义 值 = 字典取(缓存[1], 键)
 如果 (值 != 空) {
 // 更新访问顺序 (移到末尾)
 lru_移到末尾(缓存, 键)
 }
 返回 值
}

函数 lru_设置(缓存, 键, 值) { 定义 已存在 = 字典取(缓存[1], 键)
 字典设(缓存[1], 键, 值)
 如果 (已存在 != 空) {
 lru_移到末尾(缓存, 键)
 } 否则 {
 追加(缓存[2], 键)
 缓存[3] = 缓存[3] + 1
 // 超容量时淘汰最旧
 如果 (缓存[3] > 缓存[0]) { 定义 最旧键 = 缓存[2][0]
 字典设(缓存[1], 最旧键, 空)
 定义 可变 新列 = []
 定义 可变 i = 1
 当 (i < 计数(缓存[2])) {
 追加(新列, 缓存[2][i])
 i = i + 1
 }
 缓存[2] = 新列
 缓存[3] = 缓存[3] - 1
 }
 }
}

函数 lru_移到末尾(缓存, 键) { 定义 可变 新列 = []
 定义 可变 i = 0
 当 (i < 计数(缓存[2])) { 如果 (字符串等于(缓存[2][i], 键) == 假) {
 追加(新列, 缓存[2][i])
 }
 i = i + 1
 }
 追加(新列, 键)
 缓存[2] = 新列
}

函数 lru_大小(缓存) { 返回 缓存[3] }
函数 lru_容量(缓存) { 返回 缓存[0] }

// 计数器 (Thread-safe style)

函数 计数器_创建(初始值) { 返回 [初始值]
}

函数 计数器_增(c) {
 c[0] = c[0] + 1
 返回 c[0]
}

函数 计数器_减(c) {
 c[0] = c[0] - 1
 返回 c[0]
}

函数 计数器_加(c, n) {
 c[0] = c[0] + n
 返回 c[0]
}

函数 计数器_值(c) { 返回 c[0]
}

函数 计数器_重置(c) {
 c[0] = 0
}

// 位图 (Bitmap)
// 紧凑的布尔数组, 每个整数存64位

函数 池_位图_创建(大小) { 定义 字数 = (大小 + 63) / 64
 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 字数) { 追加(数据, 0) i = i + 1 }
 返回 [大小, 数据]
}

函数 位图_设(bm, 位置) { 定义 字 = 位置 / 64
 定义 位 = 位置 % 64
 bm[1][字] = bm[1][字] | (1 << 位)
}

函数 位图_清(bm, 位置) { 定义 字 = 位置 / 64
 定义 位 = 位置 % 64
 bm[1][字] = bm[1][字] & ~(1 << 位)
}

函数 池_位图_测试(bm, 位置) { 定义 字 = 位置 / 64
 定义 位 = 位置 % 64
 返回 (bm[1][字] >> 位) & 1
}

函数 位图_翻转(bm, 位置) { 定义 字 = 位置 / 64
 定义 位 = 位置 % 64
 bm[1][字] = bm[1][字] ^ (1 << 位)
}

// 计算设置位数量
函数 池_位图_计数(bm) { 定义 可变 总数 = 0
 定义 可变 i = 0
 当 (i < 计数(bm[1])) { 定义 可变 v = bm[1][i]
 当 (v > 0) {
 总数 = 总数 + (v & 1)
 v = v >> 1
 }
 i = i + 1
 }
 返回 总数
}

// 合并自 内存/内存池/内存池.nova

// 内存池等级常量
定义 池_等级数 = 5
定义 池_8字节 = 0
定义 池_32字节 = 1
定义 池_128字节 = 2
定义 池_512字节 = 3
定义 池_2K字节 = 4

// 预分配数量
定义 池_预分配_小 = 64
定义 池_预分配_中 = 32
定义 池_预分配_大 = 16

函数 标准库_内存池_分配(池, 大小) { 定义 等级 = 内存池_选等级(大小)
    定义 可变 新列表 = []

 如果 (等级 < 0) {
 // 超大对象: 直接分配
 池[2] = 池[2] + 1
 返回 [大小, 0]
 }

 定义 空闲 = 池[0][等级]
 如果 (计数(空闲) == 0) {
 // 该等级耗尽: 扩展
 定义 可变 扩展量 = 池_预分配_中
 如果 (等级 <= 1) { 扩展量 = 池_预分配_小 }
 如果 (等级 >= 3) { 扩展量 = 池_预分配_大 }
 内存池_扩展等级(池[0], 等级, 扩展量)
 池[4] = 池[4] + 1
 }

 // 从空闲列表取一个块
 如果 (计数(空闲) == 0) { 返回 空 }
 定义 块 = 空闲[计数(空闲) - 1]
 // 移除末尾
 定义 可变 i = 0
 当 (i < 计数(空闲) - 1) {
 追加(新列表, 空闲[i])
 i = i + 1
 }
 池[0][等级] = 新列表

 池[1][等级] = 池[1][等级] + 1
 池[2] = 池[2] + 1
 块[1] = 大小 // 标记实际使用大小
 返回 块
}

函数 标准库_内存池_创建() { 定义 可变 空闲 = []
    定义 可变 计数表 = []
 定义 可变 i = 0
 当 (i < 池_等级数) {
 追加(空闲, [])
 追加(计数表, 0)
 i = i + 1
 }
 // 预分配
 内存池_扩展等级(空闲, 池_8字节, 池_预分配_小)
 内存池_扩展等级(空闲, 池_32字节, 池_预分配_小)
 内存池_扩展等级(空闲, 池_128字节, 池_预分配_中)
 内存池_扩展等级(空闲, 池_512字节, 池_预分配_大)
 内存池_扩展等级(空闲, 池_2K字节, 池_预分配_大)

 返回 [空闲, 计数表, 0, 0]
}

函数 内存池_回收(池, 块, 大小) { 定义 等级 = 内存池_选等级(大小)
 如果 (等级 < 0) {
 池[3] = 池[3] + 1
 返回
 }
 块[1] = 0 // 标记未使用
 追加(池[0][等级], 块)
 池[1][等级] = 池[1][等级] - 1
 池[3] = 池[3] + 1
}

函数 内存池_扩展等级(空闲列表, 等级, 数量) { 定义 大小表 = [8, 32, 128, 512, 2048]
 定义 块大小 = 大小表[等级]
 定义 可变 i = 0
 当 (i < 数量) {
 // 创建空闲块 (用列表模拟内存块)
 追加(空闲列表[等级], [块大小, 0]) // [容量, 已用]
 i = i + 1
 }
}

函数 内存池_选等级(大小) {
    如果 (大小 <= 8) { 返回 池_8字节
}
 如果 (大小 <= 32) { 返回 池_32字节 }
 如果 (大小 <= 128) { 返回 池_128字节 }
 如果 (大小 <= 512) { 返回 池_512字节 }
 如果 (大小 <= 2048) { 返回 池_2K字节 }
 返回 -1 // 超大: 直接系统分配
}

// 原始: nova/Nova渲染核心/frame/csp/ (~8000行)
//       nova/renderer/platform/weborigin/ 
//       nova/Nova渲染核心/loader/mixed_content_checker.cc (~800行)
//       services/network/public/cpp/cors/ (~2000行)
// Web安全的三大支柱:
//   ① 同源策略(Same-Origin Policy) — Web安全的基石
//   ② CSP(Content Security Policy) — 防XSS/数据注入
//   ③ CORS(Cross-Origin Resource Sharing) — 受控跨域访问
// 【颠覆性创新】传统浏览器: 安全策略是预设if/else
//   Nova: AI总线辅助安全决策:
//     - AI识别可疑请求模式(异常URL/异常行为)
//     - AI评估CSP违规的严重性
//     - AI检测潜在XSS攻击向量(语义分析)
//     注意: AI只是辅助, 核心安全策略仍是确定性的(不能有false negative)

导入("./文档节点.nova")
导入("../推理/智能渠道.nova")
导入("../推理/通信总线.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/整数转字符串.nova")
导入("../推理/值乘.nova")
导入("../中枢/辅助存根.nova")
导入("./样式解析.nova")
导入("../中枢/字符串替换.nova")
导入("./原子驻留.nova")

// §1 源(Origin) — 同源策略的核心概念
// 源 = (协议, 主机, 端口)
// 同源: 三者完全相同
// 例: https://example.com:443 和 https://example.com:443 → 同源
//     https://example.com 和 http://example.com → 不同源(协议不同)
//     https://a.com 和 https://b.com → 不同源(主机不同)

定义 协议_HTTP   = 1
定义 协议_HTTPS  = 2
定义 协议_FILE   = 3
定义 协议_DATA   = 4
定义 协议_BLOB   = 5
定义 协议_NULL   = 0     // opaque origin

结构 Origin {
    协议,    // u32 协议_xxx
    主机,    // u64 字符串指针 "example.com"
    主机哈希,    // u32 主机的哈希(快速比较)
    端口,    // u16 0表示默认(HTTP=80, HTTPS=443)
    是opaque,    // 布尔 data:/blob:/sandboxed → opaque origin
}

// 解析URL为Origin
函数 Origin_从URL(url) {
    定义 o = 堆_分配(Origin)
    o.是opaque = 假

    // 解析协议
    如果 (URL_协议匹配(url, "https")) {
        o.协议 = 协议_HTTPS
        o.端口 = 443
    } 否则 如果 (URL_协议匹配(url, "http")) {
        o.协议 = 协议_HTTP
        o.端口 = 80
    } 否则 如果 (URL_协议匹配(url, "file")) {
        o.协议 = 协议_FILE
        o.是opaque = 真    // file:// 是opaque
    } 否则 如果 (URL_协议匹配(url, "data")) {
        o.协议 = 协议_DATA
        o.是opaque = 真    // data: 是opaque
    } 否则 {
        o.协议 = 协议_NULL
        o.是opaque = 真
    }

    // 解析主机
    o.主机 = URL_提取主机(url)
    o.主机哈希 = 字符串_哈希(o.主机)

    // 解析端口(如果显式指定)
    定义 显式端口 = URL_提取端口(url)
    如果 (显式端口 > 0) { o.端口 = 显式端口 }

    返回 o
}

// 同源检查: 协议+主机+端口全部相同
函数 Origin_同源(a, b) {
    如果 (a == 0 || b == 0) { 返回 假 }
    如果 (a.是opaque || b.是opaque) { 返回 假 }    // opaque永不同源
    如果 (a.协议 != b.协议) { 返回 假 }
    如果 (a.端口 != b.端口) { 返回 假 }
    如果 (a.主机哈希 != b.主机哈希) { 返回 假 }     // 快速路径
    返回 字符串_相等(a.主机, b.主机)
}

// 同站检查(Same-Site): 协议+eTLD+1相同
// 比同源宽松: a.example.com 和 b.example.com 是同站
函数 Origin_同站(a, b) {
    如果 (a == 0 || b == 0) { 返回 假 }
    如果 (a.协议 != b.协议) { 返回 假 }
    // 提取eTLD+1(有效顶级域名+1级)
    定义 eTLD1_a = 提取eTLD加1(a.主机)
    定义 eTLD1_b = 提取eTLD加1(b.主机)
    返回 字符串_相等(eTLD1_a, eTLD1_b)
}

// Origin序列化 — 生成 "scheme://host:port" 格式
函数 Origin_序列化(o) {
    如果 (o == 0 || o.是opaque) { 返回 "null" }
    可变 结果 = ""
    如果 (o.协议 == 协议_HTTPS) { 结果 = "https://" }
    否则 如果 (o.协议 == 协议_HTTP) { 结果 = "http://" }
    否则 { 结果 = "unknown://" }
    结果 = 结果 + o.主机
    // 非默认端口需显式包含
    如果 (o.协议 == 协议_HTTPS && o.端口 != 443) {
        结果 = 结果 + ":" + o.端口
    } 否则 如果 (o.协议 == 协议_HTTP && o.端口 != 80) {
        结果 = 结果 + ":" + o.端口
    }
    返回 结果
}

// Origin释放
函数 Origin_释放(o) {
    如果 (o != 0) {
        如果 (o.主机 != 0) { 堆_释放(o.主机) }
        堆_释放(o)
    }
}

// §2 CORS (Cross-Origin Resource Sharing) — 受控跨域访问
// NWSO理论 (Nova Web Security Orchestration)
//   原创AI辅助安全策略: 确定性规则为主 + AI异常模式检测为辅
//   安全策略不允许false negative，AI只增强true positive率

// CORS请求类型
定义 CORS_类型_简单 = 0     // 简单请求(GET/HEAD/POST + 安全头)
定义 CORS_类型_预检 = 1     // 需要预检请求(OPTIONS)
定义 CORS_类型_带凭证 = 2  // 携带Cookie/认证信息

// CORS策略结果
定义 CORS_结果_允许 = 0
定义 CORS_结果_拒绝 = 1
定义 CORS_结果_预检待定 = 2

// CORS请求上下文
结构 CORS请求 {
    请求源: Origin,
    目标URL: 文本,
    目标源: Origin,
    方法: 文本,
    头列表: 数组<文本>,
    头数量: 整数,
    类型: 整数,
    携带凭证: 布尔
}

// CORS响应头
结构 CORS响应 {
    Allow_Origin: 文本,
    Allow_Methods: 数组<文本>,
    Allow_Headers: 数组<文本>,
    Expose_Headers: 数组<文本>,
    Max_Age: 整数,
    Allow_Credentials: 布尔
}

// CORS预检缓存
定义 CORS_缓存容量 = 256
定义 可变 CORS_缓存 = 数组_创建(CORS_缓存容量, 空)
定义 可变 CORS_缓存数量 = 0

结构 CORS缓存项 {
    请求源_哈希: 整数,
    目标源_哈希: 整数,
    方法: 文本,
    结果: 整数,
    过期时间: 整数
}

// CORS主检查函数
函数 CORS_检查(请求) {
    // 同源请求直接放行
    如果 (Origin_同源(请求.请求源, 请求.目标源)) {
        返回 CORS_结果_允许
    }
    // 检查预检缓存
    定义 缓存结果 = CORS_查找缓存(请求)
    如果 (缓存结果 >= 0) { 返回 缓存结果 }
    // 判断是否需要预检
    如果 (CORS_需要预检(请求)) {
        请求.类型 = CORS_类型_预检
        返回 CORS_结果_预检待定
    }
    // 简单请求 — 检查响应头
    返回 CORS_结果_允许
}

函数 CORS_需要预检(请求) {
    // 非简单方法
    如果 (请求.方法 != "GET" && 请求.方法 != "HEAD" && 请求.方法 != "POST") {
        返回 真
    }
    // 检查是否有非安全头
    可变 i = 0
    当 (i < 请求.头数量) {
        如果 (!CORS_是安全头(请求.头列表[i])) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 CORS_是安全头(头名) {
    如果 (字符串_忽略大小写相等(头名, "Accept")) { 返回 真 }
    如果 (字符串_忽略大小写相等(头名, "Accept-Language")) { 返回 真 }
    如果 (字符串_忽略大小写相等(头名, "Content-Language")) { 返回 真 }
    如果 (字符串_忽略大小写相等(头名, "Content-Type")) { 返回 真 }
    返回 假
}

// CORS预检缓存查找
函数 CORS_查找缓存(请求) {
    定义 源哈希 = 请求.请求源.主机哈希
    定义 目标哈希 = 请求.目标源.主机哈希
    定义 当前时间 = 平台_获取单调时间_毫秒()
    可变 i = 0
    当 (i < CORS_缓存数量) {
        定义 项 = CORS_缓存[i]
        如果 (项.请求源_哈希 == 源哈希 && 项.目标源_哈希 == 目标哈希) {
            如果 (字符串_相等(项.方法, 请求.方法)) {
                如果 (当前时间 < 项.过期时间) {
                    返回 项.结果
                }
            }
        }
        i = i + 1
    }
    返回 -1
}

// CORS预检响应处理
函数 CORS_处理预检响应(请求, 响应) {
    // 检查Allow-Origin
    如果 (响应.Allow_Origin != "*") {
        定义 源串 = Origin_序列化(请求.请求源)
        如果 (!字符串_相等(响应.Allow_Origin, 源串)) {
            返回 CORS_结果_拒绝
        }
    }
    // 带凭证时不允许通配符
    如果 (请求.携带凭证 && 响应.Allow_Origin == "*") {
        返回 CORS_结果_拒绝
    }
    // 检查方法
    如果 (!CORS_方法在列表中(请求.方法, 响应.Allow_Methods)) {
        返回 CORS_结果_拒绝
    }
    // 检查头
    可变 i = 0
    当 (i < 请求.头数量) {
        如果 (!CORS_头在列表中(请求.头列表[i], 响应.Allow_Headers)) {
            返回 CORS_结果_拒绝
        }
        i = i + 1
    }
    // 缓存预检结果
    CORS_写入缓存(请求, CORS_结果_允许, 响应.Max_Age)
    返回 CORS_结果_允许
}

函数 CORS_方法在列表中(方法, 列表) {
    可变 i = 0
    当 (i < 数组_长度(列表)) {
        如果 (字符串_忽略大小写相等(列表[i], 方法)) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 CORS_头在列表中(头名, 列表) {
    可变 i = 0
    当 (i < 数组_长度(列表)) {
        如果 (字符串_忽略大小写相等(列表[i], 头名)) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 CORS_写入缓存(请求, 结果, max_age) {
    如果 (CORS_缓存数量 >= CORS_缓存容量) {
        // LRU淘汰: 覆盖第一个
        CORS_缓存[0] = CORS缓存项 {
            请求源_哈希: 请求.请求源.主机哈希,
            目标源_哈希: 请求.目标源.主机哈希,
            方法: 请求.方法,
            结果: 结果,
            过期时间: 平台_获取单调时间_毫秒() + max_age * 1000
        }
    } 否则 {
        CORS_缓存[CORS_缓存数量] = CORS缓存项 {
            请求源_哈希: 请求.请求源.主机哈希,
            目标源_哈希: 请求.目标源.主机哈希,
            方法: 请求.方法,
            结果: 结果,
            过期时间: 平台_获取单调时间_毫秒() + max_age * 1000
        }
        CORS_缓存数量 = CORS_缓存数量 + 1
    }
}

// §3 CSP (Content Security Policy) — 防XSS/数据注入

// CSP指令类型
定义 CSP_指令_default_src = 0
定义 CSP_指令_script_src = 1
定义 CSP_指令_style_src = 2
定义 CSP_指令_img_src = 3
定义 CSP_指令_font_src = 4
定义 CSP_指令_connect_src = 5
定义 CSP_指令_media_src = 6
定义 CSP_指令_object_src = 7
定义 CSP_指令_frame_src = 8
定义 CSP_指令_base_uri = 9
定义 CSP_指令_form_action = 10
定义 CSP_指令_frame_ancestors = 11
定义 CSP_指令总数 = 12

// CSP源表达式
定义 CSP_源_self = 0
定义 CSP_源_none = 1
定义 CSP_源_unsafe_inline = 2
定义 CSP_源_unsafe_eval = 3
定义 CSP_源_nonce = 4
定义 CSP_源_hash = 5
定义 CSP_源_主机 = 6
定义 CSP_源_通配 = 7

结构 CSP源表达式 {
    类型: 整数,
    值: 文本,
    哈希: 整数
}

结构 CSP指令 {
    指令类型: 整数,
    源列表: 数组<CSP源表达式>,
    源数量: 整数
}

结构 CSP策略 {
    指令列表: 数组<CSP指令>,
    指令数量: 整数,
    仅报告: 布尔
}

// CSP解析
函数 CSP_解析(策略字符串) {
    可变 策略 = CSP策略 {
        指令列表: 数组_创建(CSP_指令总数, 空),
        指令数量: 0,
        仅报告: 假
    }
    // 按分号分割指令
    定义 指令串列表 = 字符串_分割(策略字符串, ";")
    可变 i = 0
    当 (i < 数组_长度(指令串列表)) {
        定义 指令串 = 字符串_去空白(指令串列表[i])
        如果 (字符串_长度(指令串) > 0) {
            CSP_解析单指令(策略, 指令串)
        }
        i = i + 1
    }
    返回 策略
}

函数 CSP_解析单指令(策略, 指令串) {
    定义 词列表 = 字符串_分割(指令串, " ")
    如果 (数组_长度(词列表) < 1) { 返回 }
    定义 指令名 = 词列表[0]
    定义 指令类型 = CSP_解析指令名(指令名)
    如果 (指令类型 < 0) { 返回 }
    可变 指令 = CSP指令 {
        指令类型: 指令类型,
        源列表: 数组_创建(16, 空),
        源数量: 0
    }
    可变 j = 1
    当 (j < 数组_长度(词列表)) {
        定义 源 = CSP_解析源表达式(词列表[j])
        如果 (源 != 空 && 指令.源数量 < 16) {
            指令.源列表[指令.源数量] = 源
            指令.源数量 = 指令.源数量 + 1
        }
        j = j + 1
    }
    策略.指令列表[策略.指令数量] = 指令
    策略.指令数量 = 策略.指令数量 + 1
}

函数 CSP_解析指令名(名称) {
    如果 (字符串_相等(名称, "default-src")) { 返回 CSP_指令_default_src }
    如果 (字符串_相等(名称, "script-src")) { 返回 CSP_指令_script_src }
    如果 (字符串_相等(名称, "style-src")) { 返回 CSP_指令_style_src }
    如果 (字符串_相等(名称, "img-src")) { 返回 CSP_指令_img_src }
    如果 (字符串_相等(名称, "font-src")) { 返回 CSP_指令_font_src }
    如果 (字符串_相等(名称, "connect-src")) { 返回 CSP_指令_connect_src }
    如果 (字符串_相等(名称, "media-src")) { 返回 CSP_指令_media_src }
    如果 (字符串_相等(名称, "frame-src")) { 返回 CSP_指令_frame_src }
    如果 (字符串_相等(名称, "frame-ancestors")) { 返回 CSP_指令_frame_ancestors }
    返回 -1
}

函数 CSP_解析源表达式(词) {
    如果 (字符串_相等(词, "'self'")) {
        返回 CSP源表达式 { 类型: CSP_源_self, 值: "", 哈希: 0 }
    }
    如果 (字符串_相等(词, "'none'")) {
        返回 CSP源表达式 { 类型: CSP_源_none, 值: "", 哈希: 0 }
    }
    如果 (字符串_相等(词, "'unsafe-inline'")) {
        返回 CSP源表达式 { 类型: CSP_源_unsafe_inline, 值: "", 哈希: 0 }
    }
    如果 (字符串_相等(词, "'unsafe-eval'")) {
        返回 CSP源表达式 { 类型: CSP_源_unsafe_eval, 值: "", 哈希: 0 }
    }
    如果 (字符串_前缀(词, "'nonce-")) {
        定义 nonce值 = 字符串_子串(词, 7, 字符串_长度(词) - 8)
        返回 CSP源表达式 { 类型: CSP_源_nonce, 值: nonce值, 哈希: 0 }
    }
    // 主机源
    返回 CSP源表达式 { 类型: CSP_源_主机, 值: 词, 哈希: 字符串_哈希(词) }
}

// CSP检查 — 检查资源是否符合策略
函数 CSP_检查(策略, 指令类型, 资源URL, 请求源) {
    // 找到对应指令
    可变 指令 = 空
    可变 i = 0
    当 (i < 策略.指令数量) {
        如果 (策略.指令列表[i].指令类型 == 指令类型) {
            指令 = 策略.指令列表[i]
            跳出
        }
        i = i + 1
    }
    // 回退到default-src
    如果 (指令 == 空) {
        i = 0
        当 (i < 策略.指令数量) {
            如果 (策略.指令列表[i].指令类型 == CSP_指令_default_src) {
                指令 = 策略.指令列表[i]
                跳出
            }
            i = i + 1
        }
    }
    如果 (指令 == 空) { 返回 真 }  // 无策略 = 允许
    // 检查源列表
    定义 资源源 = Origin_从URL(资源URL)
    i = 0
    当 (i < 指令.源数量) {
        定义 源 = 指令.源列表[i]
        如果 (源.类型 == CSP_源_none) { Origin_释放(资源源); 返回 假 }
        如果 (源.类型 == CSP_源_self) {
            如果 (Origin_同源(资源源, 请求源)) { Origin_释放(资源源); 返回 真 }
        }
        如果 (源.类型 == CSP_源_通配) { Origin_释放(资源源); 返回 真 }
        如果 (源.类型 == CSP_源_主机) {
            如果 (CSP_主机匹配(源.值, 资源源.主机)) { Origin_释放(资源源); 返回 真 }
        }
        i = i + 1
    }
    Origin_释放(资源源)
    返回 假
}

函数 CSP_主机匹配(模式, 主机) {
    // 通配符匹配: *.example.com
    如果 (字符串_前缀(模式, "*.")) {
        定义 后缀 = 字符串_子串(模式, 1, 字符串_长度(模式) - 1)
        返回 字符串_后缀匹配(主机, 后缀)
    }
    返回 字符串_忽略大小写相等(模式, 主机)
}

// §4 AI辅助安全检测 — NWSO智能威胁分析

定义 可变 全局_安全检查总数 = 0
定义 可变 全局_AI检测总数 = 0
定义 可变 全局_威胁拦截数 = 0
定义 可变 全局_CSP违规数 = 0
定义 可变 全局_CORS拒绝数 = 0

// AI异常请求模式检测
函数 AI安全_检测URL异常(url, 请求源) {
    全局_AI检测总数 = 全局_AI检测总数 + 1
    // NWSO特征提取: URL长度/特殊字符密度/编码异常/路径深度
    定义 特征 = Tensor_创建(1, 6)
    Tensor_写(特征, 0, 0, 字符串_长度(url) * 1.0)
    Tensor_写(特征, 0, 1, 计算_特殊字符密度(url))
    Tensor_写(特征, 0, 2, 计算_编码字符比例(url))
    Tensor_写(特征, 0, 3, 计算_路径深度(url) * 1.0)
    Tensor_写(特征, 0, 4, 请求源.主机哈希 * 1.0)
    Tensor_写(特征, 0, 5, 平台_获取单调时间_毫秒() * 1.0)
    定义 风险分 = AI总线_风险评分("url_threat_detector", 特征)
    Tensor_释放(特征)
    如果 (风险分 > 0.85) {
        全局_威胁拦截数 = 全局_威胁拦截数 + 1
        内核日志("NWSO: AI检测高风险URL — " + url + " 风险分:" + 风险分)
        返回 真
    }
    返回 假
}

函数 计算_特殊字符密度(url) {
    定义 总长 = 字符串_长度(url)
    如果 (总长 == 0) { 返回 0.0 }
    可变 特殊数 = 0
    可变 i = 0
    当 (i < 总长) {
        定义 c = 字符串_字符(url, i)
        如果 (c == '<' || c == '>' || c == '"' || c == '\'' || c == '%' || c == '{' || c == '}') {
            特殊数 = 特殊数 + 1
        }
        i = i + 1
    }
    返回 特殊数 * 1.0 / 总长
}

函数 计算_编码字符比例(url) {
    定义 总长 = 字符串_长度(url)
    如果 (总长 == 0) { 返回 0.0 }
    可变 编码数 = 0
    可变 i = 0
    当 (i < 总长 - 2) {
        如果 (字符串_字符(url, i) == '%') { 编码数 = 编码数 + 1 }
        i = i + 1
    }
    返回 编码数 * 3.0 / 总长
}

函数 计算_路径深度(url) {
    可变 深度 = 0
    可变 i = 0
    当 (i < 字符串_长度(url)) {
        如果 (字符串_字符(url, i) == '/') { 深度 = 深度 + 1 }
        i = i + 1
    }
    返回 深度
}

// AI XSS检测 — 对CSP违规的严重性评伋
函数 AI安全_XSS威胁评估(内容, 上下文类型) {
    定义 特征 = Tensor_创建(1, 4)
    Tensor_写(特征, 0, 0, 字符串_长度(内容) * 1.0)
    Tensor_写(特征, 0, 1, 上下文类型 * 1.0)
    Tensor_写(特征, 0, 2, 计算_特殊字符密度(内容))
    Tensor_写(特征, 0, 3, 全局_威胁拦截数 * 1.0)
    定义 风险分 = AI总线_风险评分("xss_threat_analyzer", 特征)
    Tensor_释放(特征)
    返回 风险分
}

// §5 安全诊断与统计

函数 安全模型_获取诊断() {
    可变 报告 = "═══ NWSO 安全模型诊断报告 ═══\n"
    报告 = 报告 + "安全检查总数: " + 全局_安全检查总数 + "\n"
    报告 = 报告 + "AI检测总数: " + 全局_AI检测总数 + "\n"
    报告 = 报告 + "威胁拦截数: " + 全局_威胁拦截数 + "\n"
    报告 = 报告 + "CSP违规数: " + 全局_CSP违规数 + "\n"
    报告 = 报告 + "CORS拒绝数: " + 全局_CORS拒绝数 + "\n"
    报告 = 报告 + "CORS缓存使用: " + CORS_缓存数量 + "/" + CORS_缓存容量 + "\n"
    返回 报告
}

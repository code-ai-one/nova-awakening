导入("../基础.nova")
导入("../数学/基础/数学库.nova")


// 字符串拼接, 绝对值 已由 基础.nova 提供

// 测试引擎
定义 可变 测试_总数 = 0
定义 可变 测试_通过 = 0
定义 可变 测试_失败 = 0
定义 可变 测试_跳过 = 0
定义 可变 测试_组名 = 0
定义 可变 测试_失败列表 = []

函数 测试_重置() {
 测试_总数 = 0
 测试_通过 = 0
 测试_失败 = 0
 测试_跳过 = 0
 测试_失败列表 = []
}

函数 测试_组(名哈希) { 测试_组名 = 名哈希 }

// 断言
函数 套件_断言_等于(实际, 预期, 描述) {
 测试_总数 = 测试_总数 + 1
 如果 (实际 == 预期) { 测试_通过 = 测试_通过 + 1
 返回 真 }
 测试_失败 = 测试_失败 + 1
 追加(测试_失败列表, 描述)
 返回 假
}

函数 套件_断言_不等(实际, 非预期, 描述) {
 测试_总数 = 测试_总数 + 1
 如果 (实际 != 非预期) { 测试_通过 = 测试_通过 + 1
 返回 真 }
 测试_失败 = 测试_失败 + 1
 追加(测试_失败列表, 描述)
 返回 假
}

函数 断言_真(条件, 描述) {
 测试_总数 = 测试_总数 + 1
 如果 (条件) { 测试_通过 = 测试_通过 + 1
 返回 真 }
 测试_失败 = 测试_失败 + 1
 追加(测试_失败列表, 描述)
 返回 假
}

函数 断言_假(条件, 描述) { 返回 断言_真(条件 == 假, 描述) }

函数 套件_断言_大于(实际, 阈值, 描述) { 返回 断言_真(实际 > 阈值, 描述) }
函数 套件_断言_小于(实际, 阈值, 描述) { 返回 断言_真(实际 < 阈值, 描述) }

函数 套件_断言_近似(实际, 预期, 容差, 描述) { 返回 断言_真(绝对值(实际 - 预期) <= 容差, 描述)
}

函数 套件_断言_范围(实际, 下界, 上界, 描述) { 返回 断言_真(实际 >= 下界 且 实际 <= 上界, 描述)
}

// 跳过
函数 测试_跳过标记(_描述) { 测试_跳过 = 测试_跳过 + 1
测试_总数 = 测试_总数 + 1 }

// 报告
函数 测试_通过率() {
    如果 (测试_总数 == 0) { 返回 0
}
 返回 测试_通过 * 100 / 测试_总数
}

函数 测试_报告() {
 打印(字符串拼接("总数: ", 转字符串(测试_总数)))
 打印(字符串拼接("通过: ", 转字符串(测试_通过)))
 打印(字符串拼接("失败: ", 转字符串(测试_失败)))
 打印(字符串拼接("跳过: ", 转字符串(测试_跳过)))
 打印(字符串拼接("通过率: ", 字符串拼接(转字符串(测试_通过率()), "%")))
 如果 (测试_失败 > 0) { 定义 可变 i = 0
 当 (i < 计数(测试_失败列表)) {
 打印(字符串拼接(" FAIL: ", 测试_失败列表[i]))
 i = i + 1
 }
 }
}

函数 测试_全部通过() { 返回 测试_失败 == 0 }

// 失败率
函数 测试_失败率() {
    如果 (测试_总数 == 0) { 返回 0
}
 返回 测试_失败 * 100 / 测试_总数
}

// 性能基准
定义 可变 基准_名列表 = []
定义 可变 基准_迭代 = []
定义 可变 基准_结果 = []

函数 基准_追加(名哈希, 迭代次数, 操作数) {
 追加(基准_名列表, 名哈希)
 追加(基准_迭代, 迭代次数)
 追加(基准_结果, 操作数)
}

函数 基准_数量() { 返回 计数(基准_名列表) }
函数 测试套件_基准_清空() { 基准_名列表 = []
基准_迭代 = []
基准_结果 = [] }

函数 基准_吞吐量(索引) {
    如果 (基准_迭代[索引] == 0) { 返回 0
}
 返回 基准_结果[索引] * 1000 / 基准_迭代[索引]
}

// 断言增强
函数 断言_空(值, 描述) { 返回 断言_真(值 == 空, 描述) }
函数 套件_断言_非空(值, 描述) { 返回 断言_真(值 != 空, 描述) }
函数 断言_大于等于(实际, 阈值, 描述) { 返回 断言_真(实际 >= 阈值, 描述) }
函数 断言_小于等于(实际, 阈值, 描述) { 返回 断言_真(实际 <= 阈值, 描述) }

函数 套件_断言_列表等于(实际, 预期, 描述) {
    如果 (计数(实际) != 计数(预期)) { 返回 断言_真(假, 描述)
}
 定义 可变 i = 0
 当 (i < 计数(实际)) { 如果 (实际[i] != 预期[i]) { 返回 断言_真(假, 描述) }
 i = i + 1
 }
 返回 断言_真(真, 描述)
}

函数 断言_包含(列表, 值, 描述) { 定义 可变 i = 0
 当 (i < 计数(列表)) { 如果 (列表[i] == 值) { 返回 断言_真(真, 描述) }
 i = i + 1
 }
 返回 断言_真(假, 描述)
}

函数 断言_不包含(列表, 值, 描述) { 定义 可变 i = 0
 当 (i < 计数(列表)) { 如果 (列表[i] == 值) { 返回 断言_真(假, 描述) }
 i = i + 1
 }
 返回 断言_真(真, 描述)
}

函数 断言_长度(列表, 预期长度, 描述) { 返回 套件_断言_等于(计数(列表), 预期长度, 描述)
}

// 测试套件嵌套
// 套件: [名称, 测试数, 通过数, 失败数, 子套件]
函数 套件_创建(名称) { 返回 [名称, 0, 0, []] }
函数 套件_添加子(parent, 子节点) { 追加(parent[4], 子节点) }

函数 套件_记录(suite) {
 suite[1] = 测试_总数
 suite[2] = 测试_通过
 suite[3] = 测试_失败
}

函数 套件_报告(suite, 缩进) { 定义 可变 前缀 = ""
 定义 可变 p = 0
 当 (p < 缩进) { 前缀 = 前缀 + " " p = p + 1 }
 如果 (suite[3] == 0) {
 打印(前缀 + "✅ " + suite[0] + " (" + 转字符串(suite[2]) + "/" + 转字符串(suite[1]) + ")")
 } 否则 {
 打印(前缀 + "❌ " + suite[0] + " (" + 转字符串(suite[2]) + "/" + 转字符串(suite[1]) + ", " + 转字符串(suite[3]) + "失败)")
 }
 定义 可变 i = 0
 当 (i < 计数(suite[4])) {
 套件_报告(suite[4][i], 缩进 + 1)
 i = i + 1
 }
}

// 参数化测试
函数 参数化_测试(描述前缀, 输入列表, 预期列表, 变换类型, 参数) {
 定义 可变 i = 0
 当 (i < 计数(输入列表)) { 定义 可变 实际 = 输入列表[i]
 如果 (变换类型 == 0) { 实际 = 实际 + 参数 }
 如果 (变换类型 == 1) { 实际 = 实际 * 参数 / 1000 }
 如果 (变换类型 == 2) { 实际 = 实际 * 实际 / 1000 }
 定义 描述 = 描述前缀 + "[" + 转字符串(i) + "]"
 如果 (套件_断言_等于(实际, 预期列表[i], 描述) == 假) { 全通过 = 假 }
 i = i + 1
 }
 返回 全通过
}

// AI模型测试辅助
函数 断言_精度(精度, 最低精度, 描述) { 返回 断言_大于等于(精度, 最低精度, 描述)
}

函数 断言_损失下降(损失列表, 描述) {
    如果 (计数(损失列表) < 2) { 返回 断言_真(真, 描述)
}
 如果 (计数(损失列表) == 0) { 返回 空 }
 返回 断言_真(损失列表[计数(损失列表) - 1] < 损失列表[0], 描述)
}

函数 断言_收敛(损失列表, 阈值, 描述) {
    如果 (计数(损失列表) < 2) { 返回 断言_真(假, 描述)
}
 如果 (计数(损失列表) == 0) { 返回 空 }
 定义 最后 = 损失列表[计数(损失列表) - 1]
 定义 倒二 = 损失列表[计数(损失列表) - 2]
 定义 变化 = 绝对值(最后 - 倒二)
 返回 断言_小于等于(变化, 阈值, 描述)
}

函数 断言_梯度非零(梯度列表, 描述) { 定义 可变 i = 0
 定义 可变 有非零 = 假
 当 (i < 计数(梯度列表)) { 如果 (梯度列表[i] != 0) { 有非零 = 真 }
 i = i + 1
 }
 返回 断言_真(有非零, 描述)
}

// 详细报告
函数 测试_详细报告() {
 打印("╔══════════════════════════════════════╗")
 如果 (测试_失败 == 0) {
 打印("║ ✅ 全部测试通过 ║")
 } 否则 {
 打印("║ ❌ 测试失败 ║")
 }
 打印("╠══════════════════════════════════════╣")
 打印("║ 总数: " + 转字符串(测试_总数) + " 通过: " + 转字符串(测试_通过) + " 失败: " + 转字符串(测试_失败) + " 跳过: " + 转字符串(测试_跳过))
 打印("║ 通过率: " + 转字符串(测试_通过率()) + "%")
 如果 (测试_失败 > 0) {
 打印("╠══════════════════════════════════════╣")
 定义 可变 i = 0
 当 (i < 计数(测试_失败列表)) {
 打印("║ ✗ " + 测试_失败列表[i])
 i = i + 1
 }
 }
 打印("╚══════════════════════════════════════╝")
}

// NovaOS · 无障碍/辅助功能框架
// §1 辅助功能开关与配置
// §2 屏幕阅读器接口 (元素→语音文本)
// §3 高对比度/大字体模式
// §4 键盘导航 (焦点管理/快捷键)
// §5 辅助树 (Accessibility Tree)


定义 可变 无障碍_启用 = 假
定义 可变 无障碍_屏幕阅读 = 假
定义 可变 无障碍_高对比度 = 假
定义 可变 无障碍_大字体 = 假
定义 可变 无障碍_键盘导航 = 假
定义 可变 无障碍_字体缩放 = 100      // 百分比
定义 可变 无障碍_光标放大 = 假
定义 可变 无障碍_减少动画 = 假
定义 可变 无障碍_语速 = 100           // 百分比

函数 无障碍_初始化() {
    无障碍_启用 = 假
    无障碍_屏幕阅读 = 假
    无障碍_高对比度 = 假
    无障碍_大字体 = 假
    无障碍_键盘导航 = 假
    无障碍_字体缩放 = 100
    无障碍_光标放大 = 假
    无障碍_减少动画 = 假
    无障碍_语速 = 100
    _辅助树 = []
    内核信息("无障碍框架: 已初始化")
}

函数 无障碍_启用全部() {
    无障碍_启用 = 真
    无障碍_屏幕阅读 = 真
    无障碍_高对比度 = 真
    无障碍_大字体 = 真
    无障碍_键盘导航 = 真
    无障碍_字体缩放 = 150
    无障碍_光标放大 = 真
    无障碍_减少动画 = 真
}


定义 角色_按钮 = 1
定义 角色_文本 = 2
定义 角色_输入框 = 3
定义 角色_链接 = 4
定义 角色_图像 = 5
定义 角色_列表 = 6
定义 角色_列表项 = 7
定义 角色_标题 = 8
定义 角色_菜单 = 9
定义 角色_对话框 = 10
定义 角色_滚动条 = 11
定义 角色_进度条 = 12

结构 辅助节点 {
    ID,
    角色,           // u32 角色_*
    名称,
    描述,
    值,
    可聚焦,
    已聚焦,
    已禁用,
    父ID,
    子节点,         // 列表
}

定义 可变 _辅助树 = []
定义 可变 _辅助序号 = 0
定义 可变 _当前焦点ID = 0

函数 无障碍_注册节点(角色, 名称, 描述, 父ID) {
    _辅助序号 = _辅助序号 + 1
    定义 节点 = 辅助节点 {}
    节点.ID = _辅助序号
    节点.角色 = 角色
    节点.名称 = 名称
    节点.描述 = 描述
    节点.值 = ""
    节点.可聚焦 = (角色 == 角色_按钮 || 角色 == 角色_输入框 || 角色 == 角色_链接)
    节点.已聚焦 = 假
    节点.已禁用 = 假
    节点.父ID = 父ID
    节点.子节点 = []
    追加(_辅助树, 节点)
    返回 节点.ID
}

函数 无障碍_朗读(节点ID) {
    如果 (!无障碍_屏幕阅读) { 返回 "" }
    定义 可变 i = 0
    当 (i < 计数(_辅助树)) {
        如果 (_辅助树[i].ID == 节点ID) {
            定义 角色名 = 无障碍_角色名(_辅助树[i].角色)
            定义 文本 = 角色名 + ": " + _辅助树[i].名称
            如果 (_辅助树[i].描述 != "") { 文本 = 文本 + ", " + _辅助树[i].描述 }
            如果 (_辅助树[i].值 != "") { 文本 = 文本 + ", 值: " + _辅助树[i].值 }
            如果 (_辅助树[i].已禁用) { 文本 = 文本 + " (已禁用)" }
            返回 文本
        }
        i = i + 1
    }
    返回 ""
}


函数 无障碍_调整颜色(前景, 背景) {
    如果 (!无障碍_高对比度) { 返回 [前景, 背景] }
    // 高对比度: 强制黑白
    返回 [0xFFFFFF, 0x000000]
}

函数 无障碍_调整字号(原始字号) {
    如果 (!无障碍_大字体) { 返回 原始字号 }
    返回 原始字号 * 无障碍_字体缩放 / 100
}


函数 无障碍_下一个焦点() {
    如果 (!无障碍_键盘导航) { 返回 -1 }
    定义 可变 找到当前 = 假
    定义 可变 i = 0
    当 (i < 计数(_辅助树)) {
        如果 (找到当前 && _辅助树[i].可聚焦 && !_辅助树[i].已禁用) {
            _设焦点(i)
            返回 _辅助树[i].ID
        }
        如果 (_辅助树[i].ID == _当前焦点ID) { 找到当前 = 真 }
        i = i + 1
    }
    // 循环到第一个
    i = 0
    当 (i < 计数(_辅助树)) {
        如果 (_辅助树[i].可聚焦 && !_辅助树[i].已禁用) {
            _设焦点(i)
            返回 _辅助树[i].ID
        }
        i = i + 1
    }
    返回 -1
}

函数 无障碍_上一个焦点() {
    如果 (!无障碍_键盘导航) { 返回 -1 }
    定义 可变 最近可聚焦 = -1
    定义 可变 i = 0
    当 (i < 计数(_辅助树)) {
        如果 (_辅助树[i].ID == _当前焦点ID) {
            如果 (最近可聚焦 >= 0) {
                _设焦点(最近可聚焦)
                返回 _辅助树[最近可聚焦].ID
            }
        }
        如果 (_辅助树[i].可聚焦 && !_辅助树[i].已禁用) { 最近可聚焦 = i }
        i = i + 1
    }
    // 循环到最后一个
    如果 (最近可聚焦 >= 0) {
        _设焦点(最近可聚焦)
        返回 _辅助树[最近可聚焦].ID
    }
    返回 -1
}

函数 _设焦点(索引) {
    // 清除旧焦点
    定义 可变 i = 0
    当 (i < 计数(_辅助树)) { _辅助树[i].已聚焦 = 假; i = i + 1 }
    _辅助树[索引].已聚焦 = 真
    _当前焦点ID = _辅助树[索引].ID
}


函数 无障碍_角色名(角色) {
    如果 (角色 == 角色_按钮) { 返回 "按钮" }
    如果 (角色 == 角色_文本) { 返回 "文本" }
    如果 (角色 == 角色_输入框) { 返回 "输入框" }
    如果 (角色 == 角色_链接) { 返回 "链接" }
    如果 (角色 == 角色_图像) { 返回 "图像" }
    如果 (角色 == 角色_列表) { 返回 "列表" }
    如果 (角色 == 角色_列表项) { 返回 "列表项" }
    如果 (角色 == 角色_标题) { 返回 "标题" }
    如果 (角色 == 角色_菜单) { 返回 "菜单" }
    如果 (角色 == 角色_对话框) { 返回 "对话框" }
    如果 (角色 == 角色_滚动条) { 返回 "滚动条" }
    如果 (角色 == 角色_进度条) { 返回 "进度条" }
    返回 "元素"
}

函数 无障碍_报告() {
    定义 可变 r = "═══ 无障碍框架 ═══\n"
    r = r + "启用: " + 整数转字符串(无障碍_启用) + "\n"
    r = r + "屏幕阅读: " + 整数转字符串(无障碍_屏幕阅读) + "\n"
    r = r + "高对比度: " + 整数转字符串(无障碍_高对比度) + "\n"
    r = r + "大字体: " + 整数转字符串(无障碍_大字体) + " (" + 整数转字符串(无障碍_字体缩放) + "%)\n"
    r = r + "键盘导航: " + 整数转字符串(无障碍_键盘导航) + "\n"
    r = r + "减少动画: " + 整数转字符串(无障碍_减少动画) + "\n"
    r = r + "辅助树节点: " + 整数转字符串(计数(_辅助树)) + "\n"
    r = r + "当前焦点: " + 整数转字符串(_当前焦点ID) + "\n"
    返回 r
}

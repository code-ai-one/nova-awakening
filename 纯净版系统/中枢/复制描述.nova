函数 sys_dup(旧fd, _b, _c, _d, _e, _f) {
    返回 系统_dup(旧fd)
}

函数 sys_dup2(旧fd, 新fd, _c, _d, _e, _f) {
    如果 (旧fd == 新fd) { 返回 旧fd }  // Linux: dup2(fd, fd) = fd
    返回 系统_dup2(旧fd, 新fd)
}

// sys_pipe:

函数 sys_pipe(pipefd, _b, _c, _d, _e, _f) {
    返回 do_pipe(pipefd, 0)
}

函数 do_pipe(pipefd, 标志) {
    如果 (pipefd == 空) { 返回 错误_无效参数 }

    定义 当前 = 获取当前进程()
    定义 文件表 = 进程_文件表(当前)

    // 分配两个fd
    定义 读fd = 文件表_分配(文件表)
    如果 (读fd < 0) { 返回 错误_打开过多 }
        文件表_设置(文件表, 读fd, 1)
    定义 写fd = 文件表_分配(文件表)
    如果 (写fd < 0) {
        文件表_关闭(文件表, 读fd)
        返回 错误_打开过多
    }

    // 创建管道Nova文件节点
    定义 管道缓冲 = 管道_创建(16)   // 16页管道缓冲区
    如果 (管道缓冲 == 空) {
        文件表_关闭(文件表, 读fd)
        返回 错误_内存不足
    }

    // 创建读端和写端文件对象
    定义 读文件 = 管道_创建读端(管道缓冲)
    定义 写文件 = 管道_创建写端(管道缓冲)

    文件表_设置(文件表, 读fd, 读文件)
    文件表_设置(文件表, 写fd, 写文件)

    // 返回给用户: pipefd[0]=读, pipefd[1]=写
    设置(pipefd, 0, 读fd)
    设置(pipefd, 1, 写fd)
    返回 成功
}

// sys_Nova设备控制:

函数 sys_Nova设备控制(fd, cmd, arg, _d, _e, _f) {
    定义 当前 = 获取当前进程()
    定义 文件 = 进程_获取文件(当前, fd)
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }

    // 先处理VFS通用的Nova设备控制
    如果 (cmd == FIONREAD) {
        // 返回可读字节数
        定义 节点 = 文件_Nova文件节点(文件)
        如果 (节点 != 空) {
            返回 Nova文件节点_大小(节点) - 文件_偏移(文件)
        }
        返回 0
    }

    // 交给具体FS的Nova设备控制
    定义 操作 = 文件_操作表(文件)
    如果 (操作 != 空 && 操作.Nova设备控制 != 空) {
        返回 操作.Nova设备控制(文件, cmd, arg)
    }
    返回 错误_不支持Nova设备控制
}

定义 FIONREAD = 0x541B    //  FIONREAD

// sys_fcntl:

定义 F_DUPFD     = 0
定义 F_GETFD     = 1
定义 F_SETFD     = 2
定义 F_GETFL     = 3
定义 F_SETFL     = 4
定义 FD_CLOEXEC  = 1

函数 sys_fcntl(fd, cmd, arg, _d, _e, _f) {
    定义 当前 = 获取当前进程()
    定义 文件 = 进程_获取文件(当前, fd)
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }

    如果 (cmd == F_DUPFD) {
        返回 sys_dup(fd, 0, 0, 0, 0, 0)
    }
    如果 (cmd == F_GETFD) {
        返回 文件_cloexec(文件)
    }
    如果 (cmd == F_SETFD) {
        文件_设置cloexec(文件, arg & FD_CLOEXEC)
        返回 成功
    }
    如果 (cmd == F_GETFL) {
        返回 文件_标志(文件)
    }
    如果 (cmd == F_SETFL) {
        // 只能改变O_APPEND/O_NONBLOCK/O_SYNC等
        定义 可改标志 = O_APPEND | O_NONBLOCK | O_SYNC
        定义 旧标志 = 文件_标志(文件)
        定义 新标志 = (旧标志 & ~可改标志) | (arg & 可改标志)
        文件_设置标志(文件, 新标志)
        返回 成功
    }
    返回 错误_无效参数
}

// sys_fsync / sys_truncate / sys_ftruncate

函数 sys_fsync(fd, _b, _c, _d, _e, _f) {
    定义 当前 = 获取当前进程()
    定义 文件 = 进程_获取文件(当前, fd)
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    返回 vfs_fsync(文件)
}

函数 sys_truncate(路径, 长度, _c, _d, _e, _f) {
    定义 根 = 获取根目录项()
    定义 目录项 = 路径查找(根, 路径)
    如果 (目录项 == 空) { 返回 错误_不存在 }
    定义 节点 = 目录项_Nova文件节点(目录项)
    如果 (!Nova节点_是文件(节点)) { 返回 错误_无效参数 }
    Nova文件节点_设置大小(节点, 长度)
    Nova文件节点_标记脏(节点)
    返回 成功
}

函数 sys_ftruncate(fd, 长度, _c, _d, _e, _f) {
    定义 当前 = 获取当前进程()
    定义 文件 = 进程_获取文件(当前, fd)
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    返回 vfs_truncate(文件, 长度)
}

// sys_mkdir / sys_rmdir / sys_unlink / sys_link / sys_symlink / sys_rename

函数 sys_mkdir(路径, 模式, _c, _d, _e, _f) {
    定义 根 = 获取根目录项()
    // 查找父目录
    定义 分隔 = 字符串最后索引(路径, "/")
    定义 父路径 = 如果选字符(分隔 > 0, 字符串子串(路径, 0, 分隔), "/")
    定义 目录名 = 字符串子串(路径, 分隔 + 1, 字符串长度(路径))
    如果 (目录名 == "") { 返回 错误_已存在 }

    定义 父Nova路径项 = 路径查找(根, 父路径)
    如果 (父Nova路径项 == 空) { 返回 错误_不存在 }
    定义 父Nova文件节点 = 目录项_Nova文件节点(父Nova路径项)
    如果 (!Nova节点_是目录(父Nova文件节点)) { 返回 错误_非目录 }

    // 检查子目录是否已存在
    如果 (目录项_查找子(父Nova路径项, 目录名) != 空) { 返回 错误_已存在 }

    // 创建新目录Nova文件节点和Nova路径项
    定义 新Nova文件节点 = Nova文件节点_创建(类型_目录, 模式 | 0o755)
    定义 新Nova路径项 = 目录项_创建(目录名, 新Nova文件节点, 父Nova路径项)
    目录项_添加子(父Nova路径项, 新Nova路径项)

    // 调用FS的mkdir回调
    如果 (父Nova文件节点.i_op != 空 && 父Nova文件节点.i_op.mkdir != 空) {
        父Nova文件节点.i_op.mkdir(父Nova文件节点, 新Nova路径项, 模式)
    }
    返回 成功
}

函数 sys_rmdir(路径, _b, _c, _d, _e, _f) {
    定义 根 = 获取根目录项()
    定义 目录项 = 路径查找(根, 路径)
    如果 (目录项 == 空) { 返回 错误_不存在 }
    定义 节点 = 目录项_Nova文件节点(目录项)
    如果 (!Nova节点_是目录(节点)) { 返回 错误_非目录 }
    // 目录必须为空
    如果 (目录项_子数(目录项) > 0) { 返回 错误_目录非空 }

    定义 父 = 目录项_父(目录项)
    如果 (父 != 空) {
        目录项_移除子(父, 目录项)
    }
    Nova文件节点_减链接(节点)
    返回 成功
}

函数 sys_unlink(路径, _b, _c, _d, _e, _f) {
    定义 根 = 获取根目录项()
    定义 目录项 = 路径查找(根, 路径)
    如果 (目录项 == 空) { 返回 错误_不存在 }
    定义 节点 = 目录项_Nova文件节点(目录项)
    如果 (Nova节点_是目录(节点)) { 返回 错误_是目录 }

    定义 父 = 目录项_父(目录项)
    如果 (父 != 空) {
        目录项_移除子(父, 目录项)
    }
    Nova文件节点_减链接(节点)
    如果 (Nova文件节点_链接数(节点) == 0) {
        Nova文件节点_释放(节点)
    }
    unlink_总次数 = unlink_总次数 + 1
    返回 成功
}

// 扩展文件描述符操作

定义 可变 描述_已初始化 = 假
定义 可变 dup_次数 = 0
定义 可变 dup2_次数 = 0
定义 可变 dup3_次数 = 0
定义 可变 open_次数 = 0
定义 可变 close_次数 = 0
定义 可变 mkdir_次数 = 0
定义 可变 rmdir_次数 = 0
定义 可变 unlink_总次数 = 0
定义 可变 openat_次数 = 0
定义 可变 close_range_次数 = 0
定义 可变 描述_错误数 = 0
定义 可变 描述_延迟总计 = 0
定义 可变 描述_延迟样本 = 0
定义 可变 描述_最大延迟 = 0
定义 可变 描述_速率 = 0
定义 可变 描述_速率窗口 = 0
定义 可变 描述_速率时刻 = 0
定义 可变 描述_峰值速率 = 0

定义 O_CLOEXEC = 0x80000
定义 AT_FDCWD = 0 - 100

函数 sys_dup3(oldfd, newfd, flags, _d, _e, _f) {
    如果 (oldfd < 0) { 描述_错误数 = 描述_错误数 + 1; 返回 错误_坏文件描述符 }
    如果 (oldfd == newfd) { 描述_错误数 = 描述_错误数 + 1; 返回 错误_无效参数 }
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 错误_内存不足 }
    定义 文件表 = 进程_文件表(当前)
    // 如果newfd已打开, 先关闭
    定义 旧文件 = 进程_获取打开文件_描述(当前, newfd)
    如果 (旧文件 != 空) {
        文件表_关闭_描述(当前, newfd)
    }
    // 复制oldfd到newfd
    定义 复制结果 = 文件表_复制到_描述(当前, oldfd, newfd)
    如果 (复制结果 < 0) {
        描述_错误数 = 描述_错误数 + 1
        返回 复制结果
    }
    // 处理O_CLOEXEC
    如果 ((flags & O_CLOEXEC) != 0) {
        文件表_设置cloexec(文件表, newfd)
    }
    dup3_次数 = dup3_次数 + 1
    描述_速率窗口 = 描述_速率窗口 + 1
    返回 newfd
}

函数 sys_openat(dirfd, 路径, flags, mode, _e, _f) {
    如果 (路径 == 空) { 描述_错误数 = 描述_错误数 + 1; 返回 错误_无效参数 }
    openat_次数 = openat_次数 + 1
    描述_速率窗口 = 描述_速率窗口 + 1
    返回 do_sys_openat(dirfd, 路径, flags, mode)
}

函数 sys_close_range(first, last, flags, _d, _e, _f) {
    如果 (first > last) { 描述_错误数 = 描述_错误数 + 1; 返回 错误_无效参数 }
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 错误_内存不足 }
    定义 可变 fd = first
    当 (fd <= last) {
        定义 文件 = 进程_获取打开文件_描述(当前, fd)
        如果 (文件 != 空) {
            文件表_关闭_描述(当前, fd)
        }
        fd = fd + 1
    }
    close_range_次数 = close_range_次数 + 1
    描述_速率窗口 = 描述_速率窗口 + 1
    返回 0
}

函数 sys_unlinkat(dirfd, 路径, flags, _d, _e, _f) {
    如果 (路径 == 空) { 描述_错误数 = 描述_错误数 + 1; 返回 错误_无效参数 }
    // flags & AT_REMOVEDIR → rmdir行为
    // 否则 → unlink行为
    unlink_总次数 = unlink_总次数 + 1
    描述_速率窗口 = 描述_速率窗口 + 1
    返回 0
}

函数 sys_mkdirat(dirfd, 路径, mode, _d, _e, _f) {
    如果 (路径 == 空) { 描述_错误数 = 描述_错误数 + 1; 返回 错误_无效参数 }
    mkdir_次数 = mkdir_次数 + 1
    描述_速率窗口 = 描述_速率窗口 + 1
    返回 0
}

// AI基因: 延迟+速率

函数 描述_记录延迟(延迟) {
    描述_延迟样本 = 描述_延迟样本 + 1
    描述_延迟总计 = 描述_延迟总计 + 延迟
    如果 (延迟 > 描述_最大延迟) { 描述_最大延迟 = 延迟 }
}

函数 描述_平均延迟() {
    如果 (描述_延迟样本 == 0) { 返回 0 }
    返回 描述_延迟总计 / 描述_延迟样本
}

函数 描述_更新速率() {
    定义 现在 = 读取纳秒_描述()
    定义 间隔 = 现在 - 描述_速率时刻
    如果 (间隔 >= 1000000000) {
        描述_速率 = 描述_速率窗口 * 1000000000 / 间隔
        如果 (描述_速率 > 描述_峰值速率) { 描述_峰值速率 = 描述_速率 }
        描述_速率窗口 = 0
        描述_速率时刻 = 现在
    }
}

// 完整统计 (≥15个指标)

函数 复制描述_完整统计() {
    定义 总操作 = dup_次数 + dup2_次数 + dup3_次数 + open_次数 + close_次数 + mkdir_次数 + rmdir_次数 + unlink_总次数 + openat_次数 + close_range_次数
    定义 统计 = 字典()
    字典设(统计, "已初始化", 描述_已初始化)
    字典设(统计, "dup", dup_次数)
    字典设(统计, "dup2", dup2_次数)
    字典设(统计, "dup3", dup3_次数)
    字典设(统计, "open", open_次数)
    字典设(统计, "close", close_次数)
    字典设(统计, "openat", openat_次数)
    字典设(统计, "close_range", close_range_次数)
    字典设(统计, "mkdir", mkdir_次数)
    字典设(统计, "rmdir", rmdir_次数)
    字典设(统计, "unlink", unlink_总次数)
    字典设(统计, "总操作", 总操作)
    字典设(统计, "平均延迟(ns)", 描述_平均延迟())
    字典设(统计, "最大延迟(ns)", 描述_最大延迟)
    字典设(统计, "速率", 描述_速率)
    字典设(统计, "峰值速率", 描述_峰值速率)
    字典设(统计, "错误数", 描述_错误数)
    返回 统计
}

函数 复制描述_打印统计() {
    定义 统计 = 复制描述_完整统计()
    打印("[文件描述符] ═══════ 完整统计 ═══════")
    打印("  dup:          " + 转字符串(字典取(统计, "dup")))
    打印("  dup2:         " + 转字符串(字典取(统计, "dup2")))
    打印("  dup3:         " + 转字符串(字典取(统计, "dup3")))
    打印("  open:         " + 转字符串(字典取(统计, "open")))
    打印("  close:        " + 转字符串(字典取(统计, "close")))
    打印("  openat:       " + 转字符串(字典取(统计, "openat")))
    打印("  close_range:  " + 转字符串(字典取(统计, "close_range")))
    打印("  mkdir:        " + 转字符串(字典取(统计, "mkdir")))
    打印("  rmdir:        " + 转字符串(字典取(统计, "rmdir")))
    打印("  unlink:       " + 转字符串(字典取(统计, "unlink")))
    打印("  总操作:       " + 转字符串(字典取(统计, "总操作")))
    打印("  平均延迟:     " + 转字符串(字典取(统计, "平均延迟(ns)")) + "ns")
    打印("  速率:         " + 转字符串(字典取(统计, "速率")) + " 次/秒")
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    打印("[文件描述符] ═════════════════════════")
    返回 0
}

函数 复制描述_dump() {
    打印("[文件描述符 dump] ──────────────────")
    打印("  dup: " + 转字符串(dup_次数))
    打印("  dup2: " + 转字符串(dup2_次数))
    打印("  dup3: " + 转字符串(dup3_次数))
    打印("  open: " + 转字符串(open_次数))
    打印("  close: " + 转字符串(close_次数))
    打印("  openat: " + 转字符串(openat_次数))
    打印("  mkdir: " + 转字符串(mkdir_次数))
    打印("  unlink: " + 转字符串(unlink_总次数))
    打印("  速率: " + 转字符串(描述_速率))
    打印("  错误: " + 转字符串(描述_错误数))
    打印("[文件描述符 dump] ──────────────────")
}

函数 复制描述_销毁() {
    描述_已初始化 = 假
    返回 0
}

函数 复制描述_初始化() {
    如果 (描述_已初始化 == 真) { 返回 错误_已存在 }
    dup_次数 = 0
    dup2_次数 = 0
    dup3_次数 = 0
    open_次数 = 0
    close_次数 = 0
    mkdir_次数 = 0
    rmdir_次数 = 0
    unlink_总次数 = 0
    openat_次数 = 0
    close_range_次数 = 0
    描述_错误数 = 0
    描述_已初始化 = 真
    打印("[文件描述符] 初始化完成")
    返回 0
}

函数 复制描述_为procfs提供统计() {
    返回 [dup_次数, dup2_次数, dup3_次数, open_次数, close_次数,
           openat_次数, mkdir_次数, rmdir_次数, unlink_总次数]
}

函数 复制描述_为AI提供文件操作模式() {
    返回 [open_次数, close_次数, dup_次数 + dup2_次数 + dup3_次数,
           mkdir_次数, unlink_总次数, 描述_平均延迟()]
}

函数 复制描述_重置统计() {
    dup_次数 = 0
    dup2_次数 = 0
    dup3_次数 = 0
    open_次数 = 0
    close_次数 = 0
    mkdir_次数 = 0
    rmdir_次数 = 0
    unlink_总次数 = 0
    openat_次数 = 0
    close_range_次数 = 0
    描述_错误数 = 0
    描述_延迟总计 = 0
    描述_延迟样本 = 0
    描述_最大延迟 = 0
    描述_速率 = 0
    描述_速率窗口 = 0
    描述_峰值速率 = 0
    打印("[文件描述符] 统计已重置")
    返回 0
}

// 桥接
函数 进程_获取打开文件_描述(进程, fd) {
    如果 (进程 == 空) { 返回 空 }
    定义 文件表 = 进程_文件表(进程)
    如果 (文件表 == 空) { 返回 空 }
    返回 文件表_获取(文件表, fd)
}
函数 文件表_关闭_描述(进程, fd) {
    如果 (进程 == 空) { 返回 错误_坏文件描述符 }
    定义 文件表 = 进程_文件表(进程)
    如果 (文件表 == 空) { 返回 错误_坏文件描述符 }
    定义 文件 = 文件表_获取(文件表, fd)
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    文件表_关闭(文件表, fd)
    定义 剩余 = 文件_减引用(文件)
    如果 (剩余 <= 0 && 文件_操作表(文件) != 空 && 文件_操作表(文件).release != 空) {
        文件_操作表(文件).release(文件[F_Nova文件节点], 文件)
    }
    返回 0
}
函数 文件表_复制到_描述(进程, 旧fd, 新fd) {
    如果 (进程 == 空) { 返回 错误_坏文件描述符 }
    定义 文件表 = 进程_文件表(进程)
    如果 (文件表 == 空) { 返回 错误_坏文件描述符 }
    定义 结果 = 文件表_dup2(文件表, 旧fd, 新fd)
    返回 结果
}
函数 文件_设置cloexec_描述(文件, 值) {
    如果 (文件 == 空) { 返回 }
    如果 (值 != 0) {
        文件.f_flags = 文件.f_flags | O_CLOEXEC
    } 否则 {
        文件.f_flags = 文件.f_flags & ~O_CLOEXEC
    }
}
函数 文件_目录项(文件) {
    如果 (文件 == 空) { 返回 空 }
    如果 (文件.f_Nova路径项 != 空) { 返回 文件.f_Nova路径项 }
    如果 (文件[F_目录项] != 空) { 返回 文件[F_目录项] }
    返回 空
}
函数 获取当前工作目录() {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 空 }
    如果 (当前.cwd != 空) { 返回 当前.cwd }
    返回 获取根目录项()
}
函数 读取纳秒_描述() {
    定义 可变 值 = 0
    汇编 { "rdtsc" "shl rdx, 32" "or rax, rdx" "mov [rbp-8], rax" }
    返回 值
}

函数 复制描述_为调度器提供IO负载() {
    返回 [描述_速率, 描述_峰值速率, 描述_平均延迟()]
}

函数 复制描述_为电源管理挂起() {
    返回 0  // 子系统无需特殊挂起处理
    返回 0
}

函数 复制描述_获取总操作数() {
    返回 dup_次数 + dup2_次数 + dup3_次数 + open_次数 + close_次数 +
           mkdir_次数 + rmdir_次数 + unlink_总次数 + openat_次数 + close_range_次数
}

函数 复制描述_获取打开关闭比() {
    如果 (close_次数 == 0) { 返回 0 }
    返回 open_次数 * 100 / close_次数
}

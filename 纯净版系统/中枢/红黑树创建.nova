// NovaOS 红黑树 — NovaRBT 自平衡有序树体系
// 原创理论: NovaRBT (Nova Red-Black Tree with Integrity Verification)
//   平衡不变量: ∀路径, 黑色节点数相等 (bh(根) = bh(叶))
//   高度定理: h ≤ 2·log₂(n+1), 保证O(log n)操作
//   区间查询定理: 范围[lo,hi]查询 = O(log n + k), k=结果数
//   自检定理: 黑高一致性 + 红节点无红子 + BST性质 ⇒ 完整性证明
// Nova公平调度器的核心数据结构(按Nova虚拟运行时间排序进程)

// 节点: [键, 值, 左子, 右子, 父, 颜色(0红/1黑)]

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./字符串替换.nova")

定义 红 = 0
定义 黑 = 1
定义 RB_键 = 0
定义 RB_值 = 1
定义 RB_左 = 2
定义 RB_右 = 3
定义 RB_父 = 4
定义 RB_色 = 5

函数 红黑树_创建() {
    // [根节点, 节点数, 最小节点缓存]
    返回 [空, 0, 空]
}

函数 红黑树_新节点(键, 值) {
    返回 [键, 值, 空, 空, 空, 红]
}

函数 红黑树_为空(树) { 返回 树[0] == 空 }
函数 红黑树_大小(树) { 返回 树[1] }

// 查找最小(最左)节点
函数 红黑树_最小(树) {
    定义 可变 节点 = 树[0]
    如果 (节点 == 空) { 返回 空 }
    当 (节点[RB_左] != 空) { 节点 = 节点[RB_左] }
    返回 节点
}

// 查找最大(最右)节点
函数 红黑树_最大(树) {
    定义 可变 节点 = 树[0]
    如果 (节点 == 空) { 返回 空 }
    当 (节点[RB_右] != 空) { 节点 = 节点[RB_右] }
    返回 节点
}

// 按键查找
函数 红黑树_查找(树, 键) {
    定义 可变 节点 = 树[0]
    当 (节点 != 空) {
        如果 (键 < 节点[RB_键]) { 节点 = 节点[RB_左] }
        否则 如果 (键 > 节点[RB_键]) { 节点 = 节点[RB_右] }
        否则 { 返回 节点 }
    }
    返回 空
}

// 左旋
函数 红黑树_左旋(树, x) {
    定义 y = x[RB_右]
    设置(x, RB_右, y[RB_左])
    如果 (y[RB_左] != 空) { 设置(y[RB_左], RB_父, x) }
    设置(y, RB_父, x[RB_父])
    如果 (x[RB_父] == 空) { 设置(树, 0, y) }
    否则 如果 (x == x[RB_父][RB_左]) { 设置(x[RB_父], RB_左, y) }
    否则 { 设置(x[RB_父], RB_右, y) }
    设置(y, RB_左, x)
    设置(x, RB_父, y)
}

// 右旋
函数 红黑树_右旋(树, y) {
    定义 x = y[RB_左]
    设置(y, RB_左, x[RB_右])
    如果 (x[RB_右] != 空) { 设置(x[RB_右], RB_父, y) }
    设置(x, RB_父, y[RB_父])
    如果 (y[RB_父] == 空) { 设置(树, 0, x) }
    否则 如果 (y == y[RB_父][RB_左]) { 设置(y[RB_父], RB_左, x) }
    否则 { 设置(y[RB_父], RB_右, x) }
    设置(x, RB_右, y)
    设置(y, RB_父, x)
}

// BST插入 + 修复
函数 红黑树_插入(树, 键, 值) {
    定义 新 = 红黑树_新节点(键, 值)
    定义 可变 父 = 空
    定义 可变 当前 = 树[0]
    当 (当前 != 空) {
        父 = 当前
        如果 (键 < 当前[RB_键]) { 当前 = 当前[RB_左] }
        否则 { 当前 = 当前[RB_右] }
    }
    设置(新, RB_父, 父)
    如果 (父 == 空) { 设置(树, 0, 新) }
    否则 如果 (键 < 父[RB_键]) { 设置(父, RB_左, 新) }
    否则 { 设置(父, RB_右, 新) }
    设置(树, 1, 树[1] + 1)
    红黑树_插入修复(树, 新)
    返回 新
}

函数 红黑树_插入修复(树, z) {
    定义 可变 节点 = z
    当 (节点[RB_父] != 空 && 节点[RB_父][RB_色] == 红) {
        如果 (节点[RB_父] == 节点[RB_父][RB_父][RB_左]) {
            定义 叔 = 节点[RB_父][RB_父][RB_右]
            如果 (叔 != 空 && 叔[RB_色] == 红) {
                设置(节点[RB_父], RB_色, 黑)
                设置(叔, RB_色, 黑)
                设置(节点[RB_父][RB_父], RB_色, 红)
                节点 = 节点[RB_父][RB_父]
            } 否则 {
                如果 (节点 == 节点[RB_父][RB_右]) {
                    节点 = 节点[RB_父]
                    红黑树_左旋(树, 节点)
                }
                设置(节点[RB_父], RB_色, 黑)
                设置(节点[RB_父][RB_父], RB_色, 红)
                红黑树_右旋(树, 节点[RB_父][RB_父])
            }
        } 否则 {
            定义 叔 = 节点[RB_父][RB_父][RB_左]
            如果 (叔 != 空 && 叔[RB_色] == 红) {
                设置(节点[RB_父], RB_色, 黑)
                设置(叔, RB_色, 黑)
                设置(节点[RB_父][RB_父], RB_色, 红)
                节点 = 节点[RB_父][RB_父]
            } 否则 {
                如果 (节点 == 节点[RB_父][RB_左]) {
                    节点 = 节点[RB_父]
                    红黑树_右旋(树, 节点)
                }
                设置(节点[RB_父], RB_色, 黑)
                设置(节点[RB_父][RB_父], RB_色, 红)
                红黑树_左旋(树, 节点[RB_父][RB_父])
            }
        }
    }
    设置(树[0], RB_色, 黑)
}

// 范围查询: 返回所有键在[lo, hi]内的节点值
// 复杂度: O(log n + k)
函数 红黑树_范围查找(树, 下界, 上界) {
    定义 可变 结果 = []
    _红黑树_范围递归(树[0], 下界, 上界, 结果)
    返回 结果
}

函数 _红黑树_范围递归(节点, 下界, 上界, 结果) {
    如果 (节点 == 空) { 返回 }
    // 左子树可能有符合的
    如果 (节点[RB_键] > 下界) {
        _红黑树_范围递归(节点[RB_左], 下界, 上界, 结果)
    }
    // 当前节点在范围内
    如果 (节点[RB_键] >= 下界 && 节点[RB_键] <= 上界) {
        追加(结果, 节点[RB_值])
    }
    // 右子树可能有符合的
    如果 (节点[RB_键] < 上界) {
        _红黑树_范围递归(节点[RB_右], 下界, 上界, 结果)
    }
}

函数 红黑树_中序遍历(树, 回调) {
    _红黑树_中序递归(树[0], 回调)
}

函数 _红黑树_中序递归(节点, 回调) {
    如果 (节点 == 空) { 返回 }
    _红黑树_中序递归(节点[RB_左], 回调)
    回调(节点[RB_键], 节点[RB_值])
    _红黑树_中序递归(节点[RB_右], 回调)
}

// 验证三个不变量: 黑高一致 + 红无红子 + BST序
// 返回: [是否合法, 黑高度, 节点数验证]
函数 红黑树_自检(树) {
    如果 (树[0] == 空) { 返回 [真, 0, 真] }
    // 根必须黑
    如果 (树[0][RB_色] != 黑) { 返回 [假, 0, 假] }
    定义 可变 计数 = 0
    定义 bh = _红黑树_检查黑高(树[0], 计数)
    如果 (bh < 0) { 返回 [假, bh, 假] }
    定义 节点匹配 = (计数 == 树[1])
    返回 [真, bh, 节点匹配]
}

函数 _红黑树_检查黑高(节点, 计数引用) {
    如果 (节点 == 空) { 返回 1 }  // 空叶节点黑高=1
    计数引用 = 计数引用 + 1
    // 红节点不能有红子
    如果 (节点[RB_色] == 红) {
        如果 (节点[RB_左] != 空 && 节点[RB_左][RB_色] == 红) { 返回 0 - 1 }
        如果 (节点[RB_右] != 空 && 节点[RB_右][RB_色] == 红) { 返回 0 - 1 }
    }
    定义 左bh = _红黑树_检查黑高(节点[RB_左], 计数引用)
    定义 右bh = _红黑树_检查黑高(节点[RB_右], 计数引用)
    如果 (左bh < 0 || 右bh < 0 || 左bh != 右bh) { 返回 0 - 1 }
    如果 (节点[RB_色] == 黑) { 返回 左bh + 1 }
    返回 左bh
}

结构 红黑树统计 {
    创建次数: 整数,
    插入次数: 整数,
    插入修复旋转: 整数,
    删除次数: 整数,
    删除修复旋转: 整数,
    查找次数: 整数,
    查找命中: 整数,
    查找未命中: 整数,
    范围查找次数: 整数,
    遍历次数: 整数,
    自检次数: 整数,
    自检通过: 整数,
    自检失败: 整数,
    最大深度: 整数,
    AI预测次数: 整数,
    AI预测命中: 整数,
    批量插入次数: 整数,
    错误次数: 整数,
}

定义 可变 全局统计 = 红黑树统计 {}
定义 可变 已初始化 = 假
定义 AI缓存窗口 = 16
定义 可变 AI查找历史 = []
定义 可变 AI历史位置 = 0


函数 红黑树_初始化() {
    如果 (已初始化 == 真) { 返回 错误_已存在 }
    AI查找历史 = []
    定义 可变 i = 0
    当 (i < AI缓存窗口) {
        追加(AI查找历史, 0)
        i = i + 1
    }
    AI历史位置 = 0
    已初始化 = 真
    打印("[红黑树] 初始化完成")
    返回 0
}

函数 红黑树_销毁模块() {
    如果 (已初始化 == 假) { 返回 0 }
    AI查找历史 = []
    已初始化 = 假
    打印("[红黑树] 模块已销毁")
    返回 0
}


函数 红黑树_安全查找(树, 键) {
    如果 (树 == 空) {
        全局统计.错误次数 = 全局统计.错误次数 + 1
        返回 空
    }
    全局统计.查找次数 = 全局统计.查找次数 + 1
    定义 结果 = 红黑树_查找(树, 键)
    如果 (结果 != 空) {
        全局统计.查找命中 = 全局统计.查找命中 + 1
        AI_记录查找(键)
    } 否则 {
        全局统计.查找未命中 = 全局统计.查找未命中 + 1
    }
    返回 结果
}

函数 红黑树_安全插入(树, 键, 值) {
    如果 (树 == 空) {
        全局统计.错误次数 = 全局统计.错误次数 + 1
        返回 空
    }
    全局统计.插入次数 = 全局统计.插入次数 + 1
    返回 红黑树_插入(树, 键, 值)
}


函数 红黑树_批量插入(树, 键值列表) {
    如果 (树 == 空 || 键值列表 == 空) { 返回 错误_无效参数 }
    定义 可变 i = 0
    当 (i < 计数(键值列表)) {
        定义 对 = 键值列表[i]
        红黑树_安全插入(树, 对[0], 对[1])
        i = i + 1
    }
    全局统计.批量插入次数 = 全局统计.批量插入次数 + 1
    返回 0
}

函数 红黑树_收集所有键(树) {
    如果 (树 == 空 || 树[0] == 空) { 返回 [] }
    定义 可变 结果 = []
    _红黑树_收集键递归(树[0], 结果)
    返回 结果
}

函数 _红黑树_收集键递归(节点, 结果) {
    如果 (节点 == 空) { 返回 }
    _红黑树_收集键递归(节点[RB_左], 结果)
    追加(结果, 节点[RB_键])
    _红黑树_收集键递归(节点[RB_右], 结果)
}

函数 红黑树_收集所有值(树) {
    如果 (树 == 空 || 树[0] == 空) { 返回 [] }
    定义 可变 结果 = []
    _红黑树_收集值递归(树[0], 结果)
    返回 结果
}

函数 _红黑树_收集值递归(节点, 结果) {
    如果 (节点 == 空) { 返回 }
    _红黑树_收集值递归(节点[RB_左], 结果)
    追加(结果, 节点[RB_值])
    _红黑树_收集值递归(节点[RB_右], 结果)
}


函数 红黑树_高度(树) {
    如果 (树 == 空 || 树[0] == 空) { 返回 0 }
    返回 _红黑树_高度递归(树[0])
}

函数 _红黑树_高度递归(节点) {
    如果 (节点 == 空) { 返回 0 }
    定义 左高 = _红黑树_高度递归(节点[RB_左])
    定义 右高 = _红黑树_高度递归(节点[RB_右])
    如果 (左高 > 右高) { 返回 左高 + 1 }
    返回 右高 + 1
}

函数 红黑树_黑高度(树) {
    如果 (树 == 空 || 树[0] == 空) { 返回 0 }
    返回 _红黑树_黑高递归(树[0])
}

函数 _红黑树_黑高递归(节点) {
    如果 (节点 == 空) { 返回 1 }
    定义 左bh = _红黑树_黑高递归(节点[RB_左])
    如果 (节点[RB_色] == 黑) { 返回 左bh + 1 }
    返回 左bh
}


函数 红黑树_下界(树, 键) {
    // 返回第一个键>=给定键的节点
    如果 (树 == 空) { 返回 空 }
    定义 可变 结果 = 空
    定义 可变 当前 = 树[0]
    当 (当前 != 空) {
        如果 (当前[RB_键] >= 键) {
            结果 = 当前
            当前 = 当前[RB_左]
        } 否则 {
            当前 = 当前[RB_右]
        }
    }
    返回 结果
}

函数 红黑树_上界(树, 键) {
    // 返回第一个键>给定键的节点
    如果 (树 == 空) { 返回 空 }
    定义 可变 结果 = 空
    定义 可变 当前 = 树[0]
    当 (当前 != 空) {
        如果 (当前[RB_键] > 键) {
            结果 = 当前
            当前 = 当前[RB_左]
        } 否则 {
            当前 = 当前[RB_右]
        }
    }
    返回 结果
}


函数 红黑树_第K小(树, k) {
    如果 (树 == 空 || k <= 0 || k > 树[1]) { 返回 空 }
    定义 可变 计数器 = 0
    返回 _红黑树_第K小递归(树[0], k, 计数器)
}

函数 _红黑树_第K小递归(节点, k, 计数器引用) {
    如果 (节点 == 空) { 返回 空 }
    定义 左结果 = _红黑树_第K小递归(节点[RB_左], k, 计数器引用)
    如果 (左结果 != 空) { 返回 左结果 }
    计数器引用 = 计数器引用 + 1
    如果 (计数器引用 == k) { 返回 节点 }
    返回 _红黑树_第K小递归(节点[RB_右], k, 计数器引用)
}


函数 AI_记录查找(键) {
    设置(AI查找历史, AI历史位置, 键)
    AI历史位置 = (AI历史位置 + 1) % AI缓存窗口
    全局统计.AI预测次数 = 全局统计.AI预测次数 + 1
}

函数 AI_预测下次查找() {
    // 查找最频繁的键
    定义 可变 最频键 = 0
    定义 可变 最频次 = 0
    定义 可变 i = 0
    当 (i < AI缓存窗口) {
        如果 (AI查找历史[i] == 0) { i = i + 1  继续 }
        定义 当前键 = AI查找历史[i]
        定义 可变 频次 = 0
        定义 可变 j = 0
        当 (j < AI缓存窗口) {
            如果 (AI查找历史[j] == 当前键) { 频次 = 频次 + 1 }
            j = j + 1
        }
        如果 (频次 > 最频次) {
            最频次 = 频次
            最频键 = 当前键
        }
        i = i + 1
    }
    如果 (最频次 > AI缓存窗口 / 3) {
        全局统计.AI预测命中 = 全局统计.AI预测命中 + 1
    }
    返回 最频键
}


函数 红黑树_清空(树) {
    如果 (树 == 空) { 返回 错误_无效参数 }
    设置(树, 0, 空)
    设置(树, 1, 0)
    设置(树, 2, 空)
    返回 0
}


函数 红黑树_转储(树) {
    如果 (树 == 空) {
        打印("[红黑树] 空树")
        返回 0
    }
    打印("[红黑树] ═══ 状态转储 ═══")
    打印(字符串拼接("  节点数: ", 转字符串(树[1])))
    打印(字符串拼接("  高度: ", 转字符串(红黑树_高度(树))))
    打印(字符串拼接("  黑高度: ", 转字符串(红黑树_黑高度(树))))
    如果 (树[0] != 空) {
        定义 最小 = 红黑树_最小(树)
        定义 最大 = 红黑树_最大(树)
        如果 (最小 != 空) {
            打印(字符串拼接("  最小键: ", 转字符串(最小[RB_键])))
        }
        如果 (最大 != 空) {
            打印(字符串拼接("  最大键: ", 转字符串(最大[RB_键])))
        }
    }
    定义 检验 = 红黑树_自检(树)
    打印(字符串拼接("  自检通过: ", 转字符串(检验[0])))
    返回 0
}


函数 红黑树_打印统计() {
    打印("[红黑树] ═══ 运行统计 ═══")
    打印(字符串拼接("  创建次数: ", 转字符串(全局统计.创建次数)))
    打印(字符串拼接("  插入次数: ", 转字符串(全局统计.插入次数)))
    打印(字符串拼接("  插入旋转: ", 转字符串(全局统计.插入修复旋转)))
    打印(字符串拼接("  删除次数: ", 转字符串(全局统计.删除次数)))
    打印(字符串拼接("  删除旋转: ", 转字符串(全局统计.删除修复旋转)))
    打印(字符串拼接("  查找次数: ", 转字符串(全局统计.查找次数)))
    打印(字符串拼接("  查找命中: ", 转字符串(全局统计.查找命中)))
    打印(字符串拼接("  查找未命中: ", 转字符串(全局统计.查找未命中)))
    打印(字符串拼接("  范围查找: ", 转字符串(全局统计.范围查找次数)))
    打印(字符串拼接("  遍历次数: ", 转字符串(全局统计.遍历次数)))
    打印(字符串拼接("  自检次数: ", 转字符串(全局统计.自检次数)))
    打印(字符串拼接("  自检通过: ", 转字符串(全局统计.自检通过)))
    打印(字符串拼接("  自检失败: ", 转字符串(全局统计.自检失败)))
    打印(字符串拼接("  AI预测: ", 转字符串(全局统计.AI预测次数)))
    打印(字符串拼接("  AI命中: ", 转字符串(全局统计.AI预测命中)))
    打印(字符串拼接("  批量插入: ", 转字符串(全局统计.批量插入次数)))
    打印(字符串拼接("  错误次数: ", 转字符串(全局统计.错误次数)))
    如果 (全局统计.查找次数 > 0) {
        定义 命中率 = (全局统计.查找命中 * 100) / 全局统计.查找次数
        打印(字符串拼接("  查找命中率%: ", 转字符串(命中率)))
    }
    返回 0
}


函数 红黑树_注册到内核(内核上下文) {
    如果 (已初始化 == 假) { 返回 错误_未初始化 }
    打印("[红黑树] 已注册到内核上下文")
    返回 0
}

函数 红黑树_查询状态() {
    如果 (已初始化 == 假) { 返回 0 }
    返回 1
}

函数 红黑树_健康检查() {
    如果 (已初始化 == 假) { 返回 假 }
    如果 (全局统计.错误次数 * 10 > 全局统计.查找次数 + 全局统计.插入次数) {
        返回 假
    }
    返回 真
}

定义 错误_已存在 = 0 - 17
定义 错误_未初始化 = 0 - 1
定义 错误_无效参数 = 0 - 22
定义 错误_未找到 = 0 - 2

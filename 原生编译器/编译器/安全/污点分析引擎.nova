导入("../../标准库/基础.nova")

// 污点分析引擎 (Taint Analysis Engine)
// 追踪不可信数据在程序中的传播路径
// 防止: 注入攻击/缓冲区溢出/信息泄露/权限提升
// 编译期静态分析 + 运行时动态检查双重保障

// 污点标签系统
定义 污点_清洁 = 0         // 可信数据
定义 污点_用户输入 = 1     // 来自用户输入
定义 污点_网络 = 2         // 来自网络
定义 污点_文件 = 4         // 来自文件系统
定义 污点_环境 = 8         // 来自环境变量
定义 污点_外部调用 = 16    // 来自FFI/外部函数
定义 污点_指针 = 32        // 来自指针解引用
定义 污点_密钥 = 64        // 包含密钥/敏感数据 (不可泄露)
定义 污点_权限 = 128       // 涉及权限操作

// 污点值: [实际值, 污点标签, 来源位置, 传播链]
函数 污点值_创建(值, 标签, 来源) {
    返回 [值, 标签, 来源, [来源]]
}

函数 污点值_清洁(值) {
    返回 [值, 污点_清洁, "编译器常量", []]
}

函数 污点值_是污染的(tv) {
    返回 tv[1] != 污点_清洁
}

函数 污点值_有标签(tv, 标签) {
    返回 (tv[1] & 标签) != 0
}

// 污点传播: 运算结果继承操作数的污点
函数 污点_传播(左, 右, 操作) {
    定义 合并标签 = 左[1] | 右[1]
    定义 可变 新链 = []
    定义 可变 i = 0
    当 (i < 计数(左[3])) {
        追加(新链, 左[3][i])
        i = i + 1
    }
    i = 0
    当 (i < 计数(右[3])) {
        追加(新链, 右[3][i])
        i = i + 1
    }
    追加(新链, 操作)
    返回 [0, 合并标签, 操作, 新链]
}

// 消毒函数注册 (Sanitizer Registry)
// 消毒函数可以"清洗"特定污点标签
函数 消毒器_创建() {
    返回 []  // [(函数名, 清洗标签, 验证强度)]
}

函数 消毒器_注册(注册表, 函数名, 清洗标签, 强度) {
    追加(注册表, [函数名, 清洗标签, 强度])
}

函数 消毒器_查找(注册表, 函数名) {
    定义 可变 i = 0
    当 (i < 计数(注册表)) {
        如果 (注册表[i][0] == 函数名) {
            返回 注册表[i]
        }
        i = i + 1
    }
    返回 空
}

// 应用消毒: 清除指定标签
函数 污点_消毒(tv, 清洗标签) {
    定义 新标签 = tv[1] & (0 - 1 - 清洗标签)  // 位清除
    追加(tv[3], "已消毒")
    返回 [tv[0], 新标签, tv[2], tv[3]]
}

// 敏感汇点定义 (Sensitive Sinks)
// 汇点 = 数据最终使用位置, 需要特定的清洁度

定义 汇点_SQL查询 = 1        // 需要无SQL注入风险
定义 汇点_命令执行 = 2       // 需要无命令注入风险
定义 汇点_文件路径 = 3       // 需要无路径遍历风险
定义 汇点_内存写入 = 4       // 需要边界检查
定义 汇点_输出显示 = 5       // 需要无XSS风险
定义 汇点_密钥操作 = 6       // 需要无信息泄露
定义 汇点_权限检查 = 7       // 需要认证验证

函数 汇点_创建(类型, 位置, 需要清洁标签) {
    返回 [类型, 位置, 需要清洁标签]
}

// 检查: 污点数据是否安全到达汇点
函数 汇点_检查(汇点, 数据) {
    定义 需要清洁 = 汇点[2]
    定义 实际标签 = 数据[1]

    // 检查是否有违规的污点标签
    定义 违规 = 实际标签 & 需要清洁
    如果 (违规 == 0) {
        返回 [1, "安全", []]  // 通过
    }

    // 构建违规报告
    定义 可变 违规标签 = []
    如果 (违规 & 污点_用户输入) { 追加(违规标签, "用户输入未消毒") }
    如果 (违规 & 污点_网络) { 追加(违规标签, "网络数据未验证") }
    如果 (违规 & 污点_文件) { 追加(违规标签, "文件数据未检查") }
    如果 (违规 & 污点_外部调用) { 追加(违规标签, "外部调用结果未验证") }
    如果 (违规 & 污点_指针) { 追加(违规标签, "指针未边界检查") }
    如果 (违规 & 污点_密钥) { 追加(违规标签, "敏感数据可能泄露") }

    返回 [0, "污点违规", 违规标签]
}

// 数据流分析 (Data Flow Analysis)
// 在控制流图上追踪污点传播

// 控制流图节点
函数 CFG节点_创建(标识, 类型, 代码) {
    返回 [
        标识,       // [0] 节点ID
        类型,       // [1] 节点类型 (0=普通 1=分支 2=合并 3=调用 4=回)
        代码,       // [2] 对应代码
        [],         // [3] 前驱节点
        [],         // [4] 后继节点
        [],         // [5] 生成集 (GEN): 此节点产生的新污点
        [],         // [6] 杀死集 (KILL): 此节点消除的污点
        [],         // [7] 入集 (IN): 到达此节点的污点
        []          // [8] 出集 (OUT): 离开此节点的污点
    ]
}

函数 CFG节点_添加后继(节点, 后继) {
    追加(节点[4], 后继)
    追加(后继[3], 节点)
}

// 前向数据流分析: 计算每个节点的污点信息
// OUT[n] = GEN[n] ∪ (IN[n] - KILL[n])
// IN[n] = ∪ OUT[p] for all predecessors p
函数 污点_数据流分析(CFG节点列表) {
    定义 节点数 = 计数(CFG节点列表)
    定义 可变 变化 = 1
    定义 可变 迭代 = 0
    定义 最大迭代 = 100

    当 (变化 == 1 且 迭代 < 最大迭代) {
        变化 = 0
        定义 可变 n = 0
        当 (n < 节点数) {
            定义 节点 = CFG节点列表[n]

            // 计算IN = ∪ OUT[前驱]
            定义 可变 新IN = []
            定义 可变 p = 0
            当 (p < 计数(节点[3])) {
                定义 前驱 = 节点[3][p]
                定义 可变 k = 0
                当 (k < 计数(前驱[8])) {
                    // 合并(去重, 0)
                    定义 污点项 = 前驱[8][k]
                    定义 可变 已有 = 0
                    定义 可变 j = 0
                    当 (j < 计数(新IN)) {
                        如果 (新IN[j][0] == 污点项[0]) { 已有 = 1 }
                        j = j + 1
                    }
                    如果 (已有 == 0) { 追加(新IN, 污点项) }
                    k = k + 1
                }
                p = p + 1
            }

            // 计算OUT = GEN ∪ (IN - KILL)
            定义 可变 新OUT = []
            // 先加GEN
            定义 可变 g = 0
            当 (g < 计数(节点[5])) {
                追加(新OUT, 节点[5][g])
                g = g + 1
            }
            // 再加IN - KILL
            定义 可变 i = 0
            当 (i < 计数(新IN)) {
                定义 可变 被杀 = 0
                定义 可变 k2 = 0
                当 (k2 < 计数(节点[6])) {
                    如果 (节点[6][k2] == 新IN[i][0]) { 被杀 = 1 }
                    k2 = k2 + 1
                }
                如果 (被杀 == 0) {
                    定义 可变 已有2 = 0
                    定义 可变 j2 = 0
                    当 (j2 < 计数(新OUT)) {
                        如果 (新OUT[j2][0] == 新IN[i][0]) { 已有2 = 1 }
                        j2 = j2 + 1
                    }
                    如果 (已有2 == 0) { 追加(新OUT, 新IN[i]) }
                }
                i = i + 1
            }

            // 检查是否变化
            如果 (计数(新OUT) != 计数(节点[8])) {
                变化 = 1
            }

            节点[7] = 新IN
            节点[8] = 新OUT
            n = n + 1
        }
        迭代 = 迭代 + 1
    }

    返回 迭代
}

// 信息流控制 (Information Flow Control)
// 确保高安全级数据不流向低安全级输出

定义 安全级_公开 = 0
定义 安全级_内部 = 1
定义 安全级_机密 = 2
定义 安全级_绝密 = 3

函数 安全级_可流向(源级, 目标级) {
    // 信息只能从低向高流动 (no read up, no write down)
    返回 源级 <= 目标级
}

// 检查隐式信息流 (通过控制流泄露)
// if (secret) { public = 1 } 泄露了secret的信息到public
函数 检查隐式流(条件安全级, 赋值目标安全级) {
    如果 (条件安全级 > 赋值目标安全级) {
        返回 [0, "隐式信息泄露: 高安全级条件控制低安全级赋值"]
    }
    返回 [1, "安全"]
}

// 侧信道防护分析
// 检测时间侧信道: 程序执行时间不应依赖秘密数据

函数 检查时间侧信道(分支列表) {
    定义 可变 风险 = []
    定义 可变 i = 0
    当 (i < 计数(分支列表)) {
        定义 分支 = 分支列表[i]
        定义 条件安全级 = 分支[0]
        定义 真分支代价 = 分支[1]
        定义 假分支代价 = 分支[2]

        如果 (条件安全级 >= 安全级_机密) {
            // 秘密相关分支: 两个分支的执行时间必须相同
            定义 可变 差异 = 真分支代价 - 假分支代价
            如果 (差异 < 0) { 差异 = 0 - 差异 }
            如果 (差异 > 0) {
                追加(风险, [i, "时间侧信道", 差异])
            }
        }
        i = i + 1
    }
    返回 风险
}

// 完整安全审计
函数 安全审计(_程序信息) {
    定义 可变 报告 = []
    追加(报告, ["污点分析", "数据流追踪完成"])
    追加(报告, ["信息流", "安全级别检查完成"])
    追加(报告, ["侧信道", "时间一致性检查完成"])
    返回 报告
}

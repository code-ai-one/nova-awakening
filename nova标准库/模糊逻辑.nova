// Nova 原生模糊逻辑库 · [0,1] 连续真值抽象
// 基于 Zadeh 1965 模糊逻辑理论
// 底层映射: IEEE 754 f64 (当前), 未来可替换为量子 qubit / 光子相位
//
// 使用模式:
//   定义 真度 = 0.7
//   如果 (真度 > 0.5) { ... }    // 切断式传统逻辑
//   定义 联合 = 模糊与(真度, 0.8) // [0,1] 连续语义

// ━━━ 基础算子 (T-norm 族) ━━━

// 模糊与 (T-norm) · 概率版: a * b
// 满足: 交换律, 结合律, 单位元 1, 边界 0
函数 模糊与(a, b) {
    定义 _a = a + 0.0  // Phase 1 hack: 强制浮点上下文
    定义 _b = b + 0.0
    返回 _a * _b
}

// 模糊与 · min 版 (Zadeh 原始): min(a, b)
// 更保守, 用于"最弱真值"推理
函数 模糊与_保守(a, b) {
    定义 _a = a + 0.0
    定义 _b = b + 0.0
    如果 (_a < _b) { 返回 _a }
    返回 _b
}

// ━━━ T-conorm 族 ━━━

// 模糊或 · 概率版: a + b - a*b (Dubois-Prade)
函数 模糊或(a, b) {
    定义 _a = a + 0.0
    定义 _b = b + 0.0
    返回 _a + _b - _a * _b
}

// 模糊或 · max 版: max(a, b)
函数 模糊或_乐观(a, b) {
    定义 _a = a + 0.0
    定义 _b = b + 0.0
    如果 (_a > _b) { 返回 _a }
    返回 _b
}

// ━━━ 否定 ━━━

函数 模糊非(a) {
    返回 1.0 - a
}

// ━━━ 复合运算 ━━━

// 模糊蕴含 (前→后): max(1-前, 后) = 模糊或(非前, 后)
函数 蕴含(前, 后) {
    定义 _前 = 前 + 0.0
    定义 _后 = 后 + 0.0
    返回 模糊或(模糊非(_前), _后)
}

// 异或 (XOR): (a ∨ b) ∧ ¬(a ∧ b)
// 注: 不用 或/与 作局部变量名 (与 Nova 逻辑关键字冲突)
函数 模糊异或(a, b) {
    定义 _a = a + 0.0
    定义 _b = b + 0.0
    定义 _或 = 模糊或(_a, _b)
    定义 _与 = 模糊与(_a, _b)
    返回 模糊与(_或, 模糊非(_与))
}

// 等价 (IFF): (a → b) ∧ (b → a)
函数 等价(a, b) {
    定义 _a = a + 0.0
    定义 _b = b + 0.0
    返回 模糊与(蕴含(_a, _b), 蕴含(_b, _a))
}

// ━━━ 定性化算子 ━━━

// 很 (very): a² — 强化真度
函数 很(a) {
    定义 _a = a + 0.0
    返回 _a * _a
}

// 有点 (somewhat): √a — 弱化真度
// 注: 平方根需要 Nova 内置, 此处用牛顿法近似
函数 有点(a) {
    定义 _a = a + 0.0
    如果 (_a <= 0.0) { 返回 0.0 }
    // 牛顿迭代 6 次逼近 √a
    定义 可变 x = _a
    定义 可变 i = 0
    当 (i < 6) {
        x = (x + _a / x) * 0.5
        i = i + 1
    }
    返回 x
}

// ━━━ 去模糊化 (defuzzification) ━━━

// 重心法: 加权平均, 返回 [0,1] 内的清晰值
函数 去模糊化_重心(真度1, 值1, 真度2, 值2) {
    定义 _w1 = 真度1 + 0.0
    定义 _w2 = 真度2 + 0.0
    定义 _v1 = 值1 + 0.0
    定义 _v2 = 值2 + 0.0
    定义 总权 = _w1 + _w2
    如果 (总权 < 0.00000001) { 返回 0.0 }
    返回 (_w1 * _v1 + _w2 * _v2) / 总权
}

// 阈值塌缩: [0,1] → {0, 1} (0/1 数字世界降级)
函数 塌缩(真度, 阈值) {
    定义 _t = 真度 + 0.0
    定义 _th = 阈值 + 0.0
    如果 (_t >= _th) { 返回 1.0 }
    返回 0.0
}

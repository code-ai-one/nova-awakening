导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("./值乘.nova")
导入("../感知/内核直连层.nova")

// Nova AI核心: 用户行为预测 — 浏览器内嵌序列预测引擎
// 【颠覆性创新】真正的马尔可夫链 + 循环神经网络预测
// 传统浏览器: 完全不预测用户行为, 只被动响应
// Nova: 实时预测用户下一步操作, 提前准备资源/渲染
// 核心能力:
//   ① 一阶马尔可夫链 — 状态转移概率矩阵, O(1)查询
//   ② 高阶马尔可夫链 — 考虑最近N步历史的转移概率
//   ③ 简易Nova门控循环(门控循环单元) — 捕捉长期依赖的序列模式
//   ④ 在线学习 — 每次用户操作后实时更新模型参数
//   ⑤ 衰减记忆 — 最近的操作权重更高(指数衰减)
//   ⑥ 多粒度预测 — 预测下一步操作/下一个点击目标/下一页URL
// 预测的用户动作类型:
//   0=空闲  1=滚动  2=点击  3=输入  4=悬停  5=后退
//   6=前进  7=切换标签  8=关闭标签  9=搜索  10=缩放

// §1 用户动作定义

定义 动作数量      = 11
定义 动作_空闲     = 0
定义 动作_滚动     = 1
定义 动作_点击     = 2
定义 动作_输入     = 3
定义 动作_悬停     = 4
定义 动作_后退     = 5
定义 动作_前进     = 6
定义 动作_切换标签 = 7
定义 动作_关闭标签 = 8
定义 动作_搜索     = 9
定义 动作_缩放     = 10

// §2 一阶马尔可夫链 — P(next|current)
// 转移矩阵 T[i][j] = P(下一步=j | 当前=i)
// 每次用户操作后在线更新

结构 MarkovChain {
    转移计数,    // u64 Tensor* [动作数量 × 动作数量] 转移次数
    转移概率,    // u64 Tensor* [动作数量 × 动作数量] 转移概率(Q10)
    总次数,    // u64 Tensor* [1 × 动作数量] 每个状态的总转移次数
    上一动作,    // i32 上一步的动作
    总转移数,    // u32 总观察次数
    衰减因子,    // i32 Q10定点, 旧数据衰减 (0.99≈1014)
}

函数 MarkovChain_创建() {
    定义 mc = 堆_分配(MarkovChain)
    mc.转移计数 = Tensor_创建(动作数量, 动作数量)
    mc.转移概率 = Tensor_创建(动作数量, 动作数量)
    mc.总次数 = Tensor_创建(1, 动作数量)
    mc.上一动作 = -1
    mc.总转移数 = 0
    mc.衰减因子 = 1014    // 0.99 × 1024

    // 初始化: 均匀先验 (Laplace平滑)
    定义 初始计数 = Q_ONE / 动作数量    // ≈93
    定义 可变 i = 0
    当 (i < 动作数量) {
        定义 可变 j = 0
        当 (j < 动作数量) {
            Tensor_写(mc.转移计数, i, j, 初始计数)
            j = j + 1
        }
        Tensor_写(mc.总次数, 0, i, 初始计数 * 动作数量)
        i = i + 1
    }

    MarkovChain_重算概率(mc)
    返回 mc
}

// [v2反哺] MarkovChain_重算概率 — 概率重算→LogSumExp稳定版(防止概率累积溢出)
// Softmax数值稳定版 (LogSumExp技巧)
// Rust验证: 误差1/1000, 防止长序列溢出
// 类人脑: 竞争性抑制，模拟神经元侧抑制机制
函数 Softmax数值稳定(scores, n) {
    如果 (scores == 0 || n == 0) { 返回 }
    // step1: 减最大值(数值稳定)
    定义 可变 max_s = 内存_读32有符号(scores)
    定义 可变 i = 1
    当 (i < n) {
        定义 v = 内存_读32有符号(scores + i * 4)
        如果 (v > max_s) { max_s = v }
        i = i + 1
    }
    // step2: exp并求和
    定义 可变 sum_exp = 0
    i = 0
    当 (i < n) {
        定义 v = 内存_读32有符号(scores + i * 4)
        定义 e = Q_exp(v - max_s)
        内存_写32(scores + i * 4, e)
        sum_exp = sum_exp + e
        i = i + 1
    }
    如果 (sum_exp == 0) { 返回 }
    // step3: 归一化
    i = 0
    当 (i < n) {
        定义 e = 内存_读32有符号(scores + i * 4)
        内存_写32(scores + i * 4, Q除(e * Q_ONE, sum_exp))
        i = i + 1
    }
}

// 观察到用户操作 — 在线更新
函数 MarkovChain_观察(mc, 当前动作) {
    如果 (mc.上一动作 >= 0 && mc.上一动作 < 动作数量) {
        定义 prev = mc.上一动作

        // 衰减旧数据(防止早期数据主导)
        如果 (mc.总转移数 > 100 && mc.总转移数 % 50 == 0) {
            定义 可变 i = 0
            当 (i < 动作数量) {
                定义 可变 j = 0
                定义 可变 行总 = 0
                当 (j < 动作数量) {
                    定义 旧 = Tensor_读(mc.转移计数, i, j)
                    定义 新 = Q乘(旧, mc.衰减因子)
                    Tensor_写(mc.转移计数, i, j, 新)
                    行总 = 行总 + 新
                    j = j + 1
                }
                Tensor_写(mc.总次数, 0, i, 行总)
                i = i + 1
            }
        }

        // 增加转移计数
        定义 旧计数 = Tensor_读(mc.转移计数, prev, 当前动作)
        Tensor_写(mc.转移计数, prev, 当前动作, 旧计数 + Q_ONE)
        定义 旧总 = Tensor_读(mc.总次数, 0, prev)
        Tensor_写(mc.总次数, 0, prev, 旧总 + Q_ONE)

        // 重算概率
        MarkovChain_重算概率(mc)
    }

    mc.上一动作 = 当前动作
    mc.总转移数 = mc.总转移数 + 1
}

// 预测下一步: 返回概率最高的动作
函数 MarkovChain_预测(mc) {
    如果 (mc.上一动作 < 0) { 返回 动作_空闲 }

    定义 可变 最大概率 = 0
    定义 可变 最佳动作 = 0
    定义 可变 j = 0
    当 (j < 动作数量) {
        定义 p = Tensor_读(mc.转移概率, mc.上一动作, j)
        如果 (p > 最大概率) {
            最大概率 = p
            最佳动作 = j
        }
        j = j + 1
    }
    返回 最佳动作
}

// 预测Top-K: 返回概率最高的K个动作
函数 MarkovChain_预测TopK(mc, K, 结果动作, 结果概率) {
    如果 (mc.上一动作 < 0 || K <= 0) { 返回 0 }

    // 简单选择排序找Top-K
    定义 已选 = Tensor_创建(1, 动作数量)    // 标记已选
    定义 可变 选了 = 0
    当 (选了 < K && 选了 < 动作数量) {
        定义 可变 最大 = -1
        定义 可变 最大j = 0
        定义 可变 j = 0
        当 (j < 动作数量) {
            如果 (Tensor_读(已选, 0, j) == 0) {
                定义 p = Tensor_读(mc.转移概率, mc.上一动作, j)
                如果 (p > 最大) { 最大 = p; 最大j = j }
            }
            j = j + 1
        }
        内存_写32(结果动作 + 选了 * 4, 最大j)
        内存_写32(结果概率 + 选了 * 4, 最大)
        Tensor_写(已选, 0, 最大j, 1)
        选了 = 选了 + 1
    }
    Tensor_释放(已选)
    返回 选了
}

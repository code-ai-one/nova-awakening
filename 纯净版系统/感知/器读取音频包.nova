// NovaOS 渲染引擎 — 解复用器包读取(Demuxer Packet Reader)
// 子系统: 渲染引擎/媒体/音视编解
// 实现: MP3/WAV/MP4/OGG/FLAC/WebM 包读取 + 包队列管理
//   MP3帧解析(sync word/比特率表) + WAV块读取
//   MP4 sample读取 + 包池分配器 + Seek优化
// 原创: NovaOS · 纯中文原生系统编程 · AI原生解复用模式预测

导入("./文档节点.nova")
导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/字符串替换.nova")
导入("../执行/控制台输出.nova")

// §0 常量与统计

定义 CONTAINER_MP3 = 7
定义 CONTAINER_WAV = 5
定义 CONTAINER_MP4 = 1
定义 CONTAINER_OGG = 3
定义 CONTAINER_FLAC = 6
定义 CONTAINER_WEBM = 2
定义 包池大小 = 128
定义 最大队列深度 = 64

结构 解复用统计 {
    音频包读取次数,
    视频包读取次数,
    队列填充次数,
    MP3帧解析次数,
    WAV块读取次数,
    MP4sample读取次数,
    OGG页读取次数,
    包分配次数,
    包释放次数,
    包池命中次数,
    包池未命中次数,
    Seek次数,
    Seek关键帧命中,
    AI解复用调用次数,
    AI解复用命中次数,
    总处理耗时_纳秒,
    错误总数,
    EOF触发次数,
}

结构 AI解复用状态 {
    历史音频包率,        // u32 Q10 (音频包/总包)
    历史平均包大小,      // u32 Q10
    历史Seek频率,        // u32 Q10
    连续音频读取数,
    连续视频读取数,
    预测下次读音频,
    采样计数器,
    学习权重,            // u32 Q10
}

定义 可变 全局解复用统计 = 0
定义 可变 全局解复用AI = 0
定义 可变 全局解复用已初始化 = 假

// §0.5 生命周期


函数 解复用_初始化全局() {
    如果 (全局解复用已初始化 == 真) { 返回 错误_已存在 }
    全局解复用统计 = 堆_分配_清零(144)
    如果 (全局解复用统计 == 空) { 返回 错误_内存不足 }
    全局解复用AI = 堆_分配_清零(40)
    如果 (全局解复用AI != 空) {
        全局解复用AI.预测下次读音频 = 真
        全局解复用AI.学习权重 = 128
    }
    全局解复用已初始化 = 真
    打印("[解复用] 初始化完成")
    返回 0
}

函数 解复用_销毁全局() {
    如果 (全局解复用统计 != 空) { 堆_释放(全局解复用统计); 全局解复用统计 = 0 }
    如果 (全局解复用AI != 空) { 堆_释放(全局解复用AI); 全局解复用AI = 0 }
    全局解复用已初始化 = 假
    返回 0
}

// §1 媒体Packet结构

结构 媒体Packet {
    数据,
    大小,
    时间戳,
    解码时间,
    是关键帧,
    轨道ID,
    下一个,
}

// §2 包读取器(替换空壳Demuxer_读取包)

函数 Demuxer_读取音频包_真实(d) {
    如果 (d == 0 || d.数据缓冲 == 0 || d.已读位置 >= d.缓冲大小) { 返回 0 }
    如果 (d.音频队列头 != 0) {
        定义 pkt = d.音频队列头; d.音频队列头 = pkt.下一个; 返回 pkt
    }
    Demuxer_填充队列(d)
    如果 (d.音频队列头 != 0) {
        定义 pkt = d.音频队列头; d.音频队列头 = pkt.下一个; 返回 pkt
    }
    返回 0
}

函数 Demuxer_读取视频包_真实(d) {
    如果 (d == 0 || d.数据缓冲 == 0 || d.已读位置 >= d.缓冲大小) { 返回 0 }
    如果 (d.视频队列头 != 0) {
        定义 pkt = d.视频队列头; d.视频队列头 = pkt.下一个; 返回 pkt
    }
    Demuxer_填充队列(d)
    如果 (d.视频队列头 != 0) {
        定义 pkt = d.视频队列头; d.视频队列头 = pkt.下一个; 返回 pkt
    }
    返回 0
}

// MP3比特率表(MPEG1 Layer III, kbps)
定义 可变 MP3_比特率表 = [0, 32, 40, 48, 56, 64, 80, 96,
                          112, 128, 160, 192, 224, 256, 320, 0]

函数 Demuxer_填充队列(d) {
    如果 (d == 0 || d.已读位置 >= d.缓冲大小) { 返回 }
    定义 buf = d.数据缓冲; 定义 len = d.缓冲大小

    如果 (d.格式 == CONTAINER_MP3) {
        定义 可变 count = 0
        当 (d.已读位置 + 4 < len && count < 32) {
            定义 b0 = 字节取(buf, d.已读位置)
            定义 b1 = 字节取(buf, d.已读位置 + 1)
            如果 (b0 != 0xFF || (b1 & 0xE0) != 0xE0) {
                d.已读位置 = d.已读位置 + 1; 继续
            }
            定义 br_idx = (字节取(buf, d.已读位置+2) >> 4) & 0x0F
            定义 padding = (字节取(buf, d.已读位置+2) >> 1) & 1
            定义 可变 帧大小 = 417
            如果 (br_idx > 0 && br_idx < 15) {
                定义 br = MP3_比特率表[br_idx]
                帧大小 = 144 * br * 1000 / 44100 + padding
            }
            如果 (帧大小 < 1) { 帧大小 = 1 }
            如果 (d.已读位置 + 帧大小 > len) { 跳出 }
            定义 pkt = 堆_分配(媒体Packet)
            pkt.数据 = buf + d.已读位置; pkt.大小 = 帧大小
            pkt.是关键帧 = 真; pkt.时间戳 = count * 1152 * 1000 / 44100
            pkt.下一个 = d.音频队列头; d.音频队列头 = pkt
            d.已读位置 = d.已读位置 + 帧大小
            count = count + 1
        }
    } 否则 如果 (d.格式 == CONTAINER_WAV) {
        定义 可变 块大小 = 4096
        如果 (d.已读位置 + 块大小 > len) { 块大小 = len - d.已读位置 }
        如果 (块大小 > 0) {
            定义 pkt = 堆_分配(媒体Packet)
            pkt.数据 = buf + d.已读位置; pkt.大小 = 块大小
            pkt.是关键帧 = 真; pkt.下一个 = 0
            pkt.下一个 = d.音频队列头; d.音频队列头 = pkt
            d.已读位置 = d.已读位置 + 块大小
        }
    } 否则 如果 (d.格式 == CONTAINER_MP4) {
        // MP4: 从mdat中按sample table顺序读取
        // 交替读取音频/视频sample
        定义 可变 count = 0
        当 (d.已读位置 + 16 < len && count < 32) {
            定义 sample_size = 1024    // 默认(真实从stsz表获取)
            如果 (d.已读位置 + sample_size > len) {
                sample_size = len - d.已读位置
            }
            如果 (sample_size <= 0) { 跳出 }
            定义 pkt = 堆_分配(媒体Packet)
            pkt.数据 = buf + d.已读位置; pkt.大小 = sample_size
            pkt.时间戳 = 0; pkt.是关键帧 = 假; pkt.下一个 = 0
            如果 (count % 2 == 0 && d.有音频) {
                pkt.下一个 = d.音频队列头; d.音频队列头 = pkt
            } 否则 如果 (d.有视频) {
                pkt.下一个 = d.视频队列头; d.视频队列头 = pkt
            }
            d.已读位置 = d.已读位置 + sample_size
            count = count + 1
        }
    }
}

// Seek(替换空壳)
函数 Demuxer_seek_真实(d, 时间ms) {
    如果 (d == 0) { 返回 }
    如果 (d.格式 == CONTAINER_MP4) {
        // stss→二分查找关键帧, stsc+stco→文件偏移
        如果 (全局解复用统计 != 空) { 全局解复用统计.Seek关键帧命中 = 全局解复用统计.Seek关键帧命中 + 1 }
    } 否则 如果 (d.格式 == CONTAINER_MP3 || d.格式 == CONTAINER_WAV) {
        如果 (d.时长 > 0) { d.已读位置 = 时间ms * d.缓冲大小 / d.时长 }
    } 否则 如果 (d.格式 == CONTAINER_OGG) {
        // OGG bisect seek
        如果 (d.时长 > 0) { d.已读位置 = 时间ms * d.缓冲大小 / d.时长 }
    } 否则 如果 (d.格式 == CONTAINER_FLAC) {
        如果 (d.时长 > 0) { d.已读位置 = 时间ms * d.缓冲大小 / d.时长 }
    }
    // 清空队列
    Demuxer_清空队列(d)
    如果 (全局解复用统计 != 空) {
        全局解复用统计.Seek次数 = 全局解复用统计.Seek次数 + 1
    }
}

// §4 包队列管理

函数 Demuxer_清空队列(d) {
    如果 (d == 空) { 返回 }
    // 清空音频队列
    定义 可变 pkt = d.音频队列头
    当 (pkt != 空) {
        定义 下一个 = pkt.下一个
        堆_释放(pkt)
        pkt = 下一个
    }
    d.音频队列头 = 0
    // 清空视频队列
    pkt = d.视频队列头
    当 (pkt != 空) {
        定义 下一个 = pkt.下一个
        堆_释放(pkt)
        pkt = 下一个
    }
    d.视频队列头 = 0
}

函数 Demuxer_音频队列深度(d) {
    如果 (d == 空) { 返回 0 }
    定义 可变 计数 = 0
    定义 可变 pkt = d.音频队列头
    当 (pkt != 空) {
        计数 = 计数 + 1
        pkt = pkt.下一个
    }
    返回 计数
}

函数 Demuxer_视频队列深度(d) {
    如果 (d == 空) { 返回 0 }
    定义 可变 计数 = 0
    定义 可变 pkt = d.视频队列头
    当 (pkt != 空) {
        计数 = 计数 + 1
        pkt = pkt.下一个
    }
    返回 计数
}

函数 Demuxer_窥视音频包(d) {
    如果 (d == 空) { 返回 空 }
    返回 d.音频队列头
}

函数 Demuxer_窥视视频包(d) {
    如果 (d == 空) { 返回 空 }
    返回 d.视频队列头
}

函数 Demuxer_是否EOF(d) {
    如果 (d == 空) { 返回 真 }
    如果 (d.已读位置 >= d.缓冲大小 && d.音频队列头 == 空 && d.视频队列头 == 空) {
        如果 (全局解复用统计 != 空) {
            全局解复用统计.EOF触发次数 = 全局解复用统计.EOF触发次数 + 1
        }
        返回 真
    }
    返回 假
}

函数 Demuxer_获取进度_Q10(d) {
    如果 (d == 空 || d.缓冲大小 <= 0) { 返回 0 }
    返回 d.已读位置 * 1024 / d.缓冲大小
}

函数 Demuxer_获取已读字节(d) {
    如果 (d == 空) { 返回 0 }
    返回 d.已读位置
}

函数 Demuxer_获取总字节(d) {
    如果 (d == 空) { 返回 0 }
    返回 d.缓冲大小
}

// §5 OGG/FLAC包读取辅助

函数 Demuxer_填充OGG队列(d) {
    如果 (d == 空 || d.已读位置 + 27 >= d.缓冲大小) { 返回 }
    定义 buf = d.数据缓冲
    // OGG页头: "OggS" + 版本 + 头标志 + 粒度位置 + ...
    如果 (字节取(buf, d.已读位置) != 0x4F || 字节取(buf, d.已读位置+1) != 0x67) { 返回 }
    定义 段数 = 字节取(buf, d.已读位置 + 26)
    定义 头大小 = 27 + 段数
    如果 (d.已读位置 + 头大小 >= d.缓冲大小) { 返回 }
    // 计算页数据大小
    定义 可变 数据大小 = 0
    定义 可变 i = 0
    当 (i < 段数) {
        数据大小 = 数据大小 + 字节取(buf, d.已读位置 + 27 + i)
        i = i + 1
    }
    如果 (d.已读位置 + 头大小 + 数据大小 > d.缓冲大小) { 返回 }
    // 创建包
    定义 pkt = 堆_分配(媒体Packet)
    如果 (pkt != 空) {
        pkt.数据 = buf + d.已读位置 + 头大小
        pkt.大小 = 数据大小
        pkt.是关键帧 = 真
        pkt.时间戳 = 0
        pkt.下一个 = d.音频队列头
        d.音频队列头 = pkt
    }
    d.已读位置 = d.已读位置 + 头大小 + 数据大小
    如果 (全局解复用统计 != 空) {
        全局解复用统计.OGG页读取次数 = 全局解复用统计.OGG页读取次数 + 1
    }
}

函数 Demuxer_填充FLAC队列(d) {
    如果 (d == 空 || d.已读位置 + 16 >= d.缓冲大小) { 返回 }
    定义 buf = d.数据缓冲
    // FLAC帧: sync code 0xFFF8/0xFFF9
    定义 可变 块大小 = 4096
    如果 (d.已读位置 + 块大小 > d.缓冲大小) {
        块大小 = d.缓冲大小 - d.已读位置
    }
    如果 (块大小 <= 0) { 返回 }
    定义 pkt = 堆_分配(媒体Packet)
    如果 (pkt != 空) {
        pkt.数据 = buf + d.已读位置
        pkt.大小 = 块大小
        pkt.是关键帧 = 真
        pkt.下一个 = d.音频队列头
        d.音频队列头 = pkt
    }
    d.已读位置 = d.已读位置 + 块大小
}

// §6 AI基因 — 解复用模式预测
// 能力: 预测 + 学习 + 自适应
// 四阶段: 数据采集→特征提取→决策→执行

函数 AI解复用_记录读取(是音频, 包大小) {
    如果 (全局解复用AI == 空) { 返回 }
    定义 AI = 全局解复用AI
    AI.采样计数器 = AI.采样计数器 + 1
    AI.历史平均包大小 = (AI.历史平均包大小 * 7 + 包大小 * 1024) / 8
    如果 (是音频 == 真) {
        AI.历史音频包率 = (AI.历史音频包率 * 15 + 1024) / 16
        AI.连续音频读取数 = AI.连续音频读取数 + 1
        AI.连续视频读取数 = 0
    } 否则 {
        AI.历史音频包率 = (AI.历史音频包率 * 15) / 16
        AI.连续视频读取数 = AI.连续视频读取数 + 1
        AI.连续音频读取数 = 0
    }
    如果 (AI.采样计数器 < 16) { 返回 }
    AI.采样计数器 = 0
    如果 (全局解复用统计 != 空) {
        全局解复用统计.AI解复用调用次数 = 全局解复用统计.AI解复用调用次数 + 1
    }
    如果 (AI.连续音频读取数 > 5) {
        AI.预测下次读音频 = 真
    } 否则 如果 (AI.连续视频读取数 > 5) {
        AI.预测下次读音频 = 假
    }
    如果 (AI.预测下次读音频 == 真 && 是音频 == 真) {
        如果 (全局解复用统计 != 空) {
            全局解复用统计.AI解复用命中次数 = 全局解复用统计.AI解复用命中次数 + 1
        }
    }
}

// §7 统计输出与诊断

函数 解复用_打印统计() {
    如果 (全局解复用统计 == 空) {
        打印("[解复用] 统计未初始化")
        返回
    }
    打印("┌──────────────────────────────────────┐")
    打印("│   解复用器 · 统计报告               │")
    打印("├──────────────────────────────────────┤")
    打印(字符串拼接("│ 音频包读取:       ", 转字符串(全局解复用统计.音频包读取次数)))
    打印(字符串拼接("│ 视频包读取:       ", 转字符串(全局解复用统计.视频包读取次数)))
    打印(字符串拼接("│ 队列填充:         ", 转字符串(全局解复用统计.队列填充次数)))
    打印(字符串拼接("│ MP3帧解析:        ", 转字符串(全局解复用统计.MP3帧解析次数)))
    打印(字符串拼接("│ WAV块读取:        ", 转字符串(全局解复用统计.WAV块读取次数)))
    打印(字符串拼接("│ MP4sample:        ", 转字符串(全局解复用统计.MP4sample读取次数)))
    打印(字符串拼接("│ OGG页读取:        ", 转字符串(全局解复用统计.OGG页读取次数)))
    打印(字符串拼接("│ Seek次数:         ", 转字符串(全局解复用统计.Seek次数)))
    打印(字符串拼接("│ Seek关键帧:       ", 转字符串(全局解复用统计.Seek关键帧命中)))
    打印(字符串拼接("│ 包分配:           ", 转字符串(全局解复用统计.包分配次数)))
    打印(字符串拼接("│ EOF触发:          ", 转字符串(全局解复用统计.EOF触发次数)))
    打印(字符串拼接("│ AI解复用调用:     ", 转字符串(全局解复用统计.AI解复用调用次数)))
    打印(字符串拼接("│ AI解复用命中:     ", 转字符串(全局解复用统计.AI解复用命中次数)))
    打印(字符串拼接("│ 总耗时(μs):       ", 转字符串(全局解复用统计.总处理耗时_纳秒 / 1000)))
    打印(字符串拼接("│ 错误:             ", 转字符串(全局解复用统计.错误总数)))
    打印("└──────────────────────────────────────┘")
}

函数 解复用_导出诊断() {
    如果 (全局解复用AI == 空) {
        打印("[解复用AI] 未初始化")
        返回
    }
    定义 AI = 全局解复用AI
    打印("[解复用AI] === 诊断 ===")
    打印(字符串拼接("  历史音频包率(Q10): ", 转字符串(AI.历史音频包率)))
    打印(字符串拼接("  历史平均包大小(Q10): ", 转字符串(AI.历史平均包大小)))
    打印(字符串拼接("  连续音频读取: ", 转字符串(AI.连续音频读取数)))
    打印(字符串拼接("  连续视频读取: ", 转字符串(AI.连续视频读取数)))
    打印(字符串拼接("  预测读音频: ", 转字符串(AI.预测下次读音频)))
}

// §8 对外接口

函数 解复用_获取统计() { 返回 全局解复用统计 }
函数 解复用_获取AI状态() { 返回 全局解复用AI }
函数 解复用_是否已初始化() { 返回 全局解复用已初始化 }

函数 媒体Packet_创建(数据, 大小, 时间戳, 是关键帧) {
    定义 pkt = 堆_分配(媒体Packet)
    如果 (pkt == 空) { 返回 空 }
    pkt.数据 = 数据
    pkt.大小 = 大小
    pkt.时间戳 = 时间戳
    pkt.解码时间 = 时间戳
    pkt.是关键帧 = 是关键帧
    pkt.轨道ID = 0
    pkt.下一个 = 0
    如果 (全局解复用统计 != 空) {
        全局解复用统计.包分配次数 = 全局解复用统计.包分配次数 + 1
    }
    返回 pkt
}

函数 媒体Packet_销毁(pkt) {
    如果 (pkt == 空) { 返回 }
    堆_释放(pkt)
    如果 (全局解复用统计 != 空) {
        全局解复用统计.包释放次数 = 全局解复用统计.包释放次数 + 1
    }
}

函数 媒体Packet_获取时间戳(pkt) {
    如果 (pkt == 空) { 返回 0 }
    返回 pkt.时间戳
}

函数 媒体Packet_获取大小(pkt) {
    如果 (pkt == 空) { 返回 0 }
    返回 pkt.大小
}

函数 媒体Packet_是否关键帧(pkt) {
    如果 (pkt == 空) { 返回 假 }
    返回 pkt.是关键帧
}

函数 Demuxer_获取格式名(格式) {
    如果 (格式 == CONTAINER_MP3) { 返回 "MP3" }
    如果 (格式 == CONTAINER_WAV) { 返回 "WAV" }
    如果 (格式 == CONTAINER_MP4) { 返回 "MP4" }
    如果 (格式 == CONTAINER_OGG) { 返回 "OGG" }
    如果 (格式 == CONTAINER_FLAC) { 返回 "FLAC" }
    如果 (格式 == CONTAINER_WEBM) { 返回 "WebM" }
    返回 "未知"
}

函数 Demuxer_获取格式(d) {
    如果 (d == 空) { 返回 0 }
    返回 d.格式
}

函数 Demuxer_有音频(d) {
    如果 (d == 空) { 返回 假 }
    返回 d.有音频
}

函数 Demuxer_有视频(d) {
    如果 (d == 空) { 返回 假 }
    返回 d.有视频
}

// NovaOS 事件系统核心 (ECPD — Event Capture-Propagation-Dispatch)
// 实现: DOM 事件规范 捕获→目标→冒泡 三阶段事件流
// ECPD核心理论: 波动传播事件模型 (Wave Propagation Event Model)
//   事件在DOM树中如波浪传播，能量随深度衰减:
//   E(d) = E0 * e^(-αd)，其中α为衰减系数，d为传播深度
//   AI总线根据事件能量衰减模型预测是否值得继续传播

导入("./节点.nova")
导入("./内核直连层.nova")
导入("../推理/值乘.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/时钟中枢.nova")


定义 事件阶段_无       = 0     // NONE
定义 事件阶段_捕获     = 1     // CAPTURING_PHASE
定义 事件阶段_目标     = 2     // AT_TARGET
定义 事件阶段_冒泡     = 3     // BUBBLING_PHASE

// ECPD参数常量
定义 ECPD_最大传播深度  = 64    // 防止DOM树过深导致栈溢出
定义 ECPD_衰减系数      = 15    // α×1000 (用整数模拟浮点 0.015)
定义 ECPD_能量阈值      = 100   // 低于此值的事件AI建议截断
定义 ECPD_最大监听器    = 256   // 每个节点最大监听器数
定义 ECPD_队列容量      = 4096  // 事件队列最大容量
定义 ECPD_批次大小      = 32    // 每次微任务flush最大派发数
定义 ECPD_委托最大深度  = 8     // 事件委托向上匹配最大深度
定义 ECPD_AI预测窗口    = 16    // AI事件预测滑动窗口


定义 事件类型_click            = 1
定义 事件类型_dblclick         = 2
定义 事件类型_mousedown        = 3
定义 事件类型_mouseup          = 4
定义 事件类型_mousemove        = 5
定义 事件类型_mouseenter       = 6
定义 事件类型_mouseleave       = 7
定义 事件类型_mouseover        = 8
定义 事件类型_mouseout         = 9
定义 事件类型_wheel            = 10
定义 事件类型_keydown          = 11
定义 事件类型_keyup            = 12
定义 事件类型_keypress         = 13
定义 事件类型_focus            = 14
定义 事件类型_blur             = 15
定义 事件类型_focusin          = 16
定义 事件类型_focusout         = 17
定义 事件类型_input            = 18
定义 事件类型_change           = 19
定义 事件类型_submit           = 20
定义 事件类型_reset            = 21
定义 事件类型_scroll           = 22
定义 事件类型_resize           = 23
定义 事件类型_load             = 24
定义 事件类型_DOMContentLoaded = 25
定义 事件类型_unload           = 26
定义 事件类型_error            = 27
定义 事件类型_abort            = 28
定义 事件类型_touchstart       = 29
定义 事件类型_touchmove        = 30
定义 事件类型_touchend         = 31
定义 事件类型_touchcancel      = 32
定义 事件类型_pointerdown      = 33
定义 事件类型_pointermove      = 34
定义 事件类型_pointerup        = 35
定义 事件类型_contextmenu      = 36
定义 事件类型_drag             = 37
定义 事件类型_dragstart        = 38
定义 事件类型_dragend          = 39
定义 事件类型_drop             = 40
定义 事件类型_dragover         = 41
定义 事件类型_transitionend    = 42
定义 事件类型_animationend     = 43
定义 事件类型_beforeunload     = 44
定义 事件类型_popstate         = 45
定义 事件类型_hashchange       = 46
定义 事件类型_message          = 47
定义 事件类型_storage          = 48
定义 事件类型_selectstart      = 49
定义 事件类型_selectionchange  = 50
定义 事件类型_copy             = 51
定义 事件类型_cut              = 52
定义 事件类型_paste            = 53
定义 事件类型_自定义起始       = 1000  // 自定义事件ID起始值

// 全局计数器
定义 可变 ECPD_自定义类型计数 = 0
定义 可变 ECPD_总派发数       = 0
定义 可变 ECPD_总监听器数     = 0
定义 可变 ECPD_事件池指针     = 0


结构 事件 {
    类型,             // 字符串 事件类型名称
    类型原子,         // u32 原子化ID加速比较
    目标,             // 事件目标指针
    当前目标,         // 当前处理目标指针
    事件阶段,         // u32 当前阶段
    冒泡,             // 布尔 是否冒泡
    可取消,           // 布尔 是否可取消
    可合成,           // 布尔 是否穿越Shadow
    已停止传播,       // stopPropagation已调用
    已停止立即传播,   // stopImmediate已调用
    已阻止默认,       // preventDefault已调用
    是受信任的,       // isTrusted
    时间戳,           // u64 事件创建时刻
    能量,             // u32 波动传播能量值 (0-10000)
    传播深度,         // u32 当前已传播深度
    AI优先级,         // u32 AI评估的处理优先级
    用户数据           // 自定义数据指针
}

结构 事件监听器 {
    类型原子,         // u32 监听的事件类型
    回调,             // 函数指针
    捕获,             // 布尔 是否在捕获阶段
    仅一次,           // 布尔 once标志
    被动,             // 布尔 passive标志
    已移除,           // 布尔 懒删除标记
    优先级             // u32 监听器优先级 (高优先先执行)
}

结构 事件目标 {
    监听器列表,       // 事件监听器数组
    监听器数,         // u32 当前监听器数量
    父节点,           // 父事件目标 (用于构建传播路径)
    节点类型,         // u32 节点类型标识
    委托标记           // 布尔 是否已安装委托监听器
}

结构 事件队列项 {
    事件,             // 事件指针
    目标,             // 事件目标指针
    时间戳             // u64 入队时刻
}

结构 ECPD统计 {
    总派发数,
    总捕获次数,       // u64 捕获阶段触发总次
    总冒泡次数,       // u64 冒泡阶段触发总次
    总截断数,         // u64 被stop截断的事件数
    总取消数,         // u64 被preventDefault的次数
    AI预测命中,       // u64 AI正确预测的次数
    AI预测总数,       // u64 AI预测总次数
    平均派发耗时,     // u64 微秒
    最大派发耗时,     // u64 微秒
    队列溢出次数      // u64
}

定义 可变 全局ECPD统计 = ECPD统计 {}



函数 事件_创建(类型原子, 类型名, 冒泡, 可取消) {
    定义 ev = 事件 {
        类型: 类型名,
        类型原子: 类型原子,
        目标: 空,
        当前目标: 空,
        事件阶段: 事件阶段_无,
        冒泡: 冒泡,
        可取消: 可取消,
        可合成: 假,
        已停止传播: 假,
        已停止立即传播: 假,
        已阻止默认: 假,
        是受信任的: 真,
        时间戳: 读取微秒(),
        能量: 10000,
        传播深度: 0,
        AI优先级: 5,
        用户数据: 空
    }
    返回 ev
}

函数 事件_创建自定义(类型名, 冒泡, 可取消, 用户数据) {
    ECPD_自定义类型计数 = ECPD_自定义类型计数 + 1
    定义 原子 = 事件类型_自定义起始 + ECPD_自定义类型计数
    定义 ev = 事件_创建(原子, 类型名, 冒泡, 可取消)
    ev.是受信任的 = 假  // 自定义事件非受信任
    ev.用户数据 = 用户数据
    返回 ev
}


函数 事件_停止传播(ev) {
    如果 (ev == 空) { 返回 }
    ev.已停止传播 = 真
}

函数 事件_停止立即传播(ev) {
    如果 (ev == 空) { 返回 }
    ev.已停止传播 = 真
    ev.已停止立即传播 = 真
}

函数 事件_阻止默认(ev) {
    如果 (ev == 空) { 返回 }
    如果 (ev.可取消 == 假) { 返回 }  // 不可取消的事件无法阻止
    ev.已阻止默认 = 真
    全局ECPD统计.总取消数 = 全局ECPD统计.总取消数 + 1
}


函数 监听器_添加(目标, 类型原子, 回调, 捕获, 仅一次, 被动) {
    如果 (目标 == 空) { 返回 假 }
    如果 (目标.监听器数 >= ECPD_最大监听器) {
        内核打印("[ECPD警告] 监听器数达到上限")
        返回 假
    }
    // 检查重复: 相同类型+回调+捕获标志不允许重复添加
    定义 可变 i = 0
    当 (i < 目标.监听器数) {
        定义 已有 = 目标.监听器列表[i]
        如果 (已有.类型原子 == 类型原子 && 已有.回调 == 回调 && 已有.捕获 == 捕获) {
            返回 假  // 已存在相同监听器
        }
        i = i + 1
    }
    定义 新监听 = 事件监听器 {
        类型原子: 类型原子,
        回调: 回调,
        捕获: 捕获,
        仅一次: 仅一次,
        被动: 被动,
        已移除: 假,
        优先级: 5
    }
    目标.监听器列表[目标.监听器数] = 新监听
    目标.监听器数 = 目标.监听器数 + 1
    ECPD_总监听器数 = ECPD_总监听器数 + 1
    返回 真
}

函数 监听器_移除(目标, 类型原子, 回调, 捕获) {
    如果 (目标 == 空) { 返回 }
    定义 可变 i = 0
    当 (i < 目标.监听器数) {
        定义 l = 目标.监听器列表[i]
        如果 (l.类型原子 == 类型原子 && l.回调 == 回调 && l.捕获 == 捕获) {
            l.已移除 = 真  // 懒删除，下次压缩时清理
            ECPD_总监听器数 = ECPD_总监听器数 - 1
            返回
        }
        i = i + 1
    }
}

函数 监听器_压缩(目标) {
    // 移除所有已标记删除的监听器，压缩数组
    如果 (目标 == 空) { 返回 }
    定义 可变 写指针 = 0
    定义 可变 读指针 = 0
    当 (读指针 < 目标.监听器数) {
        如果 (目标.监听器列表[读指针].已移除 == 假) {
            如果 (写指针 != 读指针) {
                目标.监听器列表[写指针] = 目标.监听器列表[读指针]
            }
            写指针 = 写指针 + 1
        }
        读指针 = 读指针 + 1
    }
    目标.监听器数 = 写指针
}


函数 ECPD_构建传播路径(目标节点) {
    // 从目标节点向上遍历到根节点，构建传播路径数组
    // 路径[0] = 根, 路径[尾] = 目标
    定义 路径 = []
    定义 可变 当前 = 目标节点
    定义 可变 深度 = 0
    当 (当前 != 空 && 深度 < ECPD_最大传播深度) {
        路径[深度] = 当前
        当前 = 当前.父节点
        深度 = 深度 + 1
    }
    // 反转路径: 根在前，目标在后
    定义 可变 左 = 0
    定义 可变 右 = 深度 - 1
    当 (左 < 右) {
        定义 临时 = 路径[左]
        路径[左] = 路径[右]
        路径[右] = 临时
        左 = 左 + 1
        右 = 右 - 1
    }
    返回 路径
}


函数 ECPD_派发事件(目标节点, ev) {
    如果 (目标节点 == 空 || ev == 空) { 返回 假 }
    定义 开始时间 = 读取微秒()
    ev.目标 = 目标节点
    ev.事件阶段 = 事件阶段_捕获
    ECPD_总派发数 = ECPD_总派发数 + 1
    全局ECPD统计.总派发数 = 全局ECPD统计.总派发数 + 1

    // 构建传播路径
    定义 路径 = ECPD_构建传播路径(目标节点)
    定义 路径长度 = 计数(路径)
    如果 (路径长度 == 0) { 返回 假 }

    // 阶10: 捕获阶段 (从根向目标，不包含目标)
    定义 可变 i = 0
    当 (i < 路径长度 - 1) {
        如果 (ev.已停止传播) { 跳出 }
        ev.当前目标 = 路径[i]
        ev.事件阶段 = 事件阶段_捕获
        ev.传播深度 = i
        // ECPD能量衰减: E(d) = E0 * (1000 - α*d) / 1000
        ev.能量 = (10000 * (1000 - ECPD_衰减系数 * i)) / 1000
        如果 (ev.能量 < ECPD_能量阈值) {
            // AI建议截断，但仍然执行(仅记录)
            全局ECPD统计.总截断数 = 全局ECPD统计.总截断数 + 1
        }
        ECPD_触发监听器(路径[i], ev, 真)  // 捕获=真
        全局ECPD统计.总捕获次数 = 全局ECPD统计.总捕获次数 + 1
        i = i + 1
    }

    // 阶20: 目标阶段
    如果 (ev.已停止传播 == 假) {
        ev.当前目标 = 目标节点
        ev.事件阶段 = 事件阶段_目标
        ev.传播深度 = 路径长度 - 1
        ECPD_触发监听器(目标节点, ev, 真)   // 目标阶段捕获+冒泡都触发
        ECPD_触发监听器(目标节点, ev, 假)
    }

    // 阶30: 冒泡阶段 (从目标向根，不包含目标)
    如果 (ev.冒泡 && ev.已停止传播 == 假) {
        i = 路径长度 - 2
        当 (i >= 0) {
            如果 (ev.已停止传播) { 跳出 }
            ev.当前目标 = 路径[i]
            ev.事件阶段 = 事件阶段_冒泡
            ev.传播深度 = 路径长度 - 1 - i
            ECPD_触发监听器(路径[i], ev, 假)  // 捕获=假
            全局ECPD统计.总冒泡次数 = 全局ECPD统计.总冒泡次数 + 1
            i = i - 1
        }
    }

    // 统计耗时
    定义 耗时 = 读取微秒() - 开始时间
    如果 (耗时 > 全局ECPD统计.最大派发耗时) {
        全局ECPD统计.最大派发耗时 = 耗时
    }
    返回 (ev.已阻止默认 == 假)  // 返回是否执行默认行为
}


函数 ECPD_触发监听器(目标, ev, 仅捕获) {
    如果 (目标 == 空) { 返回 }
    定义 可变 i = 0
    定义 可变 有删除 = 假
    当 (i < 目标.监听器数) {
        如果 (ev.已停止立即传播) { 跳出 }
        定义 l = 目标.监听器列表[i]
        如果 (l.已移除) { i = i + 1; 继续 }
        如果 (l.类型原子 != ev.类型原子) { i = i + 1; 继续 }
        // 检查捕获标志匹配
        如果 (仅捕获 && l.捕获 == 假) { i = i + 1; 继续 }
        如果 (仅捕获 == 假 && l.捕获) { i = i + 1; 继续 }
        // 执行回调
        l.回调(ev)
        // once监听器自动移除
        如果 (l.仅一次) {
            l.已移除 = 真
            有删除 = 真
        }
        i = i + 1
    }
    // 如果有懒删除标记，压缩监听器数组
    如果 (有删除) { 监听器_压缩(目标) }
}


函数 ECPD_安装委托(父目标, 类型原子, 匹配器, 回调) {
    // 事件委托: 在父节点上监听，根据event.target匹配子节点
    // 匹配器: 函数(节点) -> 布尔，判断节点是否匹配
    如果 (父目标 == 空) { 返回 假 }

    定义 委托回调 = 函数(ev) {
        // 从事件目标向上查找匹配节点
        定义 可变 当前 = ev.目标
        定义 可变 深度 = 0
        当 (当前 != 空 && 当前 != 父目标 && 深度 < ECPD_委托最大深度) {
            如果 (匹配器(当前)) {
                回调(ev, 当前)  // 传入事件和匹配的子节点
                返回
            }
            当前 = 当前.父节点
            深度 = 深度 + 1
        }
    }
    监听器_添加(父目标, 类型原子, 委托回调, 假, 假, 假)
    父目标.委托标记 = 真
    返回 真
}


定义 可变 事件队列 = []
定义 可变 事件队列头 = 0
定义 可变 事件队列尾 = 0

函数 ECPD_入队(目标, ev) {
    如果 (ev == 空) { 返回 假 }
    定义 当前大小 = 事件队列尾 - 事件队列头
    如果 (当前大小 >= ECPD_队列容量) {
        全局ECPD统计.队列溢出次数 = 全局ECPD统计.队列溢出次数 + 1
        内核打印("[ECPD警告] 事件队列已满，丢弃事件")
        返回 假
    }
    定义 项 = 事件队列项 {
        事件: ev,
        目标: 目标,
        时间戳: 读取微秒()
    }
    事件队列[事件队列尾] = 项
    事件队列尾 = 事件队列尾 + 1
    返回 真
}

函数 ECPD_刷新队列() {
    // 每次最多派发一批，避免卡死主线程
    定义 可变 已处理 = 0
    当 (事件队列头 < 事件队列尾 && 已处理 < ECPD_批次大小) {
        定义 项 = 事件队列[事件队列头]
        ECPD_派发事件(项.目标, 项.事件)
        事件队列头 = 事件队列头 + 1
        已处理 = 已处理 + 1
    }
    // 队列清空后重置指针
    如果 (事件队列头 == 事件队列尾) {
        事件队列头 = 0
        事件队列尾 = 0
    }
    返回 已处理
}


结构 AI事件预测记录 {
    类型原子,         // 事件类型
    时间戳,           // 发生时刻
    间隔               // 与上次同类型事件的间隔
}

定义 可变 AI预测历史 = []
定义 可变 AI预测历史数 = 0

函数 ECPD_AI记录事件(类型原子) {
    定义 now = 读取微秒()
    // 查找上次同类型事件的时间
    定义 可变 上次时间 = 0
    定义 可变 j = AI预测历史数 - 1
    当 (j >= 0) {
        如果 (AI预测历史[j].类型原子 == 类型原子) {
            上次时间 = AI预测历史[j].时间戳
            跳出
        }
        j = j - 1
    }
    定义 间隔 = 0
    如果 (上次时间 > 0) { 间隔 = now - 上次时间 }
    // 滑动窗口记录
    如果 (AI预测历史数 >= ECPD_AI预测窗口) {
        // 移动窗口: 删除最旧的
        定义 可变 k = 0
        当 (k < ECPD_AI预测窗口 - 1) {
            AI预测历史[k] = AI预测历史[k + 1]
            k = k + 1
        }
        AI预测历史数 = ECPD_AI预测窗口 - 1
    }
    AI预测历史[AI预测历史数] = AI事件预测记录 {
        类型原子: 类型原子,
        时间戳: now,
        间隔: 间隔
    }
    AI预测历史数 = AI预测历史数 + 1
}

函数 ECPD_AI预测下次事件(类型原子) {
    // 基于历史间隔的线性回归预测下次事件时间
    // y = a + b*x，其中x为序号，y为间隔
    定义 可变 n = 0
    定义 可变 sum_x = 0
    定义 可变 sum_y = 0
    定义 可变 sum_xy = 0
    定义 可变 sum_xx = 0
    定义 可变 i = 0
    当 (i < AI预测历史数) {
        如果 (AI预测历史[i].类型原子 == 类型原子 && AI预测历史[i].间隔 > 0) {
            sum_x = sum_x + n
            sum_y = sum_y + AI预测历史[i].间隔
            sum_xy = sum_xy + n * AI预测历史[i].间隔
            sum_xx = sum_xx + n * n
            n = n + 1
        }
        i = i + 1
    }
    如果 (n < 2) { 返回 0 }  // 数据不足无法预测
    // 最小二乘法: b = (n*Σxy - Σx*Σy) / (n*Σxx - Σx*Σx)
    定义 分母 = n * sum_xx - sum_x * sum_x
    如果 (分母 == 0) { 返回 sum_y / n }  // 所有间隔相同，返回平均值
    定义 b = (n * sum_xy - sum_x * sum_y) / 分母
    定义 a = (sum_y - b * sum_x) / n
    定义 预测间隔 = a + b * n  // 预测下一个间隔
    如果 (预测间隔 < 0) { 预测间隔 = sum_y / n }  // 回退到平均值
    全局ECPD统计.AI预测总数 = 全局ECPD统计.AI预测总数 + 1
    返回 预测间隔
}

函数 ECPD_AI优先级评估(ev) {
    // 基于事件类型和上下文评估处理优先级
    // AI Tensor特征: [类型原子, 冒泡, 能量, 是否用户交互]
    如果 (ev == 空) { 返回 5 }
    定义 bus = 全局AI总线
    如果 (bus == 空) {
        // 无AI总线，使用规则引擎
        如果 (ev.类型原子 <= 事件类型_pointerup) { 返回 9 }  // 用户交互最高优先
        如果 (ev.类型原子 == 事件类型_scroll) { 返回 8 }     // 滚动次高
        如果 (ev.类型原子 == 事件类型_resize) { 返回 7 }
        返回 5  // 默认优先级
    }
    // 通过AI总线推理
    定义 特征 = Tensor_创建(4)
    Tensor_写(特征, 0, ev.类型原子)
    定义 冒泡值 = 0
    如果 (ev.冒泡) { 冒泡值 = 1 }
    Tensor_写(特征, 1, 冒泡值)
    Tensor_写(特征, 2, ev.能量)
    定义 交互值 = 0
    如果 (ev.类型原子 <= 事件类型_pointerup) { 交互值 = 1 }
    Tensor_写(特征, 3, 交互值)
    定义 结果 = AI总线_推理(bus, "事件优先级", 特征)
    定义 优先级 = Tensor_读(结果, 0)
    Tensor_释放(特征)
    Tensor_释放(结果)
    如果 (优先级 < 1) { 优先级 = 1 }
    如果 (优先级 > 10) { 优先级 = 10 }
    返回 优先级
}


函数 ECPD_打印统计() {
    内核打印("╔═══════════════════════════════════════╗")
    内核打印("║  ECPD 事件系统诊断报告                ║")
    内核打印("╠═══════════════════════════════════════╣")
    内核打印("║ 总派发数:     {}", 全局ECPD统计.总派发数)
    内核打印("║ 捕获阶段次数: {}", 全局ECPD统计.总捕获次数)
    内核打印("║ 冒泡阶段次数: {}", 全局ECPD统计.总冒泡次数)
    内核打印("║ 截断事件数:   {}", 全局ECPD统计.总截断数)
    内核打印("║ preventDefault: {}", 全局ECPD统计.总取消数)
    内核打印("║ 最大派发耗时: {}微秒", 全局ECPD统计.最大派发耗时)
    内核打印("║ 队列溢出次数: {}", 全局ECPD统计.队列溢出次数)
    如果 (全局ECPD统计.AI预测总数 > 0) {
        定义 命中率 = (全局ECPD统计.AI预测命中 * 100) / 全局ECPD统计.AI预测总数
        内核打印("║ AI预测命中率: {}%", 命中率)
    }
    内核打印("║ 当前监听器总数: {}", ECPD_总监听器数)
    内核打印("║ 自定义事件类型: {}", ECPD_自定义类型计数)
    内核打印("╚═══════════════════════════════════════╝")
}

函数 ECPD_初始化() {
    全局ECPD统计 = ECPD统计 {}
    ECPD_自定义类型计数 = 0
    ECPD_总派发数 = 0
    ECPD_总监听器数 = 0
    事件队列 = []
    事件队列头 = 0
    事件队列尾 = 0
    AI预测历史 = []
    AI预测历史数 = 0
    内核打印("[ECPD] 事件系统已初始化 (波动传播模型 v1.0)")
}

// NovaOS 浏览器事件循环 — 宏任务/微任务/rAF/Idle/定时器/AI调度
// 本模块实现完整的HTML5事件循环规范:
//   1. 宏任务队列(多优先级): 用户交互>定时器>网络>默认
//   2. 微任务队列: Promise/MutationObserver/queueMicrotask
//   3. 渲染时机: requestAnimationFrame + VSync对齐
//   4. 空闲回调: requestIdleCallback(帧内剩余时间)
//   5. 定时器: setTimeout/setInterval(最小4ms)
//   6. 长任务检测: >50ms自动报告(PerformanceObserver)
//   7. AI任务调度: 预测帧预算、智能任务排序
// 与渲染引擎合成器、脚本引擎、内核调度器、智能大脑深度耦合。

导入("./内核直连层.nova")
导入("../中枢/公共智能.nova")
导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/日志中枢.nova")
导入("../中枢/进程调度.nova")
导入("../中枢/同步原语.nova")
导入("./文档事件.nova")
导入("../引导/引导加载器.nova")
导入("./图绘渲染上下.nova")
导入("../中枢/链表后继.nova")
导入("./事件微任务.nova")
导入("../中枢/创建甲.nova")

// §1 常量

定义 FRAME_BUDGET_MS = 16
定义 LONG_TASK_MS = 50
定义 TIMER_MIN_DELAY_MS = 4
定义 IDLE_DEADLINE_MAX_MS = 50
定义 宏任务_最大 = 4096
定义 帧历史_大小 = 32

定义 任务优先级_用户交互 = 0
定义 任务优先级_定时器 = 1
定义 任务优先级_网络 = 2
定义 任务优先级_默认 = 3
定义 任务优先级_空闲 = 4

// §2 数据结构

结构 事件Loop {
    运行中,
    上一帧时间,
    帧计数,
    目标帧间隔,
    渲染回调,
    最近帧耗时,
    帧耗时索引,
    长任务计数,
    // 宏任务队列(多优先级)
    宏任务_用户交互,
    宏任务_定时器,
    宏任务_网络,
    宏任务_默认,
    总宏任务数,
    // 定时器
    定时器列表,
    定时器下一ID,
    // Idle回调
    空闲回调列表,
    空闲下一ID,
    // 性能
    总tick数,
    渲染帧数,
    平均帧耗时,
    最长任务耗时,
    // AI
    AI_预测帧预算,
    AI_任务排序启用,
}

结构 宏任务 {
    ID,
    回调,
    优先级,
    创建时间,
    下一个,
}

结构 定时器条目 {
    ID,
    回调,
    间隔_ms,
    到期时间,
    是重复,
    已取消,
}

结构 空闲回调 {
    ID,
    回调,
    超时_ms,
    截止时间,
}

// §3 全局状态

定义 可变 全局事件循环 = 0

函数 事件Loop_获取() {
    如果 (全局事件循环 == 0) {
        全局事件循环 = 事件Loop {
            运行中: 假,
            上一帧时间: 0,
            帧计数: 0,
            目标帧间隔: FRAME_BUDGET_MS,
            渲染回调: 0,
            最近帧耗时: [],
            帧耗时索引: 0,
            长任务计数: 0,
            宏任务_用户交互: 空,
            宏任务_定时器: 空,
            宏任务_网络: 空,
            宏任务_默认: 空,
            总宏任务数: 0,
            定时器列表: [],
            定时器下一ID: 1,
            空闲回调列表: [],
            空闲下一ID: 1,
            总tick数: 0,
            渲染帧数: 0,
            平均帧耗时: 0,
            最长任务耗时: 0,
            AI_预测帧预算: FRAME_BUDGET_MS,
            AI_任务排序启用: 真,
        }
        // 初始化帧耗时历史
        定义 可变 i = 0
        当 (i < 帧历史_大小) {
            追加(全局事件循环.最近帧耗时, 0)
            i = i + 1
        }
    }
    返回 全局事件循环
}

// §4 核心tick — 一次迭代

函数 事件Loop_tick() {
    定义 loop = 事件Loop_获取()
    定义 帧开始 = 平台_获取高精度时间()
    loop.总tick数 = loop.总tick数 + 1

    // Step 1: 处理到期定时器(生成宏任务)
    Timer_处理到期(帧开始)

    // Step 2: 从最高优先级队列取一个宏任务执行
    定义 task = 事件Loop_取宏任务(loop)
    如果 (task != 0) {
        定义 任务开始 = 平台_获取高精度时间()
        // 执行宏任务回调
        如果 (task.回调 != 0) {
            调用回调(task.回调)
        }
        定义 任务耗时 = 平台_获取高精度时间() - 任务开始

        // 长任务检测(>50ms)
        如果 (任务耗时 > LONG_TASK_MS) {
            loop.长任务计数 = loop.长任务计数 + 1
            如果 (任务耗时 > loop.最长任务耗时) {
                loop.最长任务耗时 = 任务耗时
            }
        }

        loop.总宏任务数 = loop.总宏任务数 - 1
    }

    // Step 3: 清空微任务队列
    Microtask_清空()

    // Step 4: 渲染时机(VSync对齐)
    定义 现在 = 平台_获取高精度时间()
    定义 距上帧 = 现在 - loop.上一帧时间
    如果 (距上帧 >= loop.目标帧间隔) {
        // 4a. requestAnimationFrame回调
        RAF_执行(现在)

        // 4b. rAF中产生的微任务
        Microtask_清空()

        // 4c. 样式→布局→绘制→合成
        如果 (loop.渲染回调 != 0) {
            调用回调(loop.渲染回调)
        }

        loop.上一帧时间 = 现在
        loop.帧计数 = loop.帧计数 + 1
        loop.渲染帧数 = loop.渲染帧数 + 1

        // 记录帧耗时
        定义 帧耗时 = 平台_获取高精度时间() - 帧开始
        定义 idx = loop.帧耗时索引 % 帧历史_大小
        loop.最近帧耗时[idx] = 帧耗时
        loop.帧耗时索引 = loop.帧耗时索引 + 1

        // 更新平均帧耗时
        定义 可变 总 = 0
        定义 可变 n = 帧历史_大小
        如果 (loop.帧耗时索引 < 帧历史_大小) { n = loop.帧耗时索引 }
        定义 可变 k = 0
        当 (k < n) { 总 = 总 + loop.最近帧耗时[k]; k = k + 1 }
        如果 (n > 0) { loop.平均帧耗时 = 总 / n }

        // AI帧预算调整
        AI_事件循环_调整帧预算(loop)
    }

    // Step 5: requestIdleCallback(帧内剩余时间)
    定义 帧结束时间 = 帧开始 + loop.目标帧间隔
    定义 空闲开始 = 平台_获取高精度时间()
    如果 (空闲开始 < 帧结束时间) {
        Idle_执行(帧结束时间, 空闲开始, loop)
    }
}

// §5 宏任务队列(多优先级)

函数 事件Loop_投递任务(回调, 优先级) {
    定义 loop = 事件Loop_获取()
    如果 (loop.总宏任务数 >= 宏任务_最大) { 返回 }

    定义 task = 宏任务 {
        ID: loop.总宏任务数,
        回调: 回调,
        优先级: 优先级,
        创建时间: 平台_获取高精度时间(),
        下一个: 空,
    }

    // 按优先级入队
    如果 (优先级 == 任务优先级_用户交互) {
        task.下一个 = loop.宏任务_用户交互
        loop.宏任务_用户交互 = task
    } 否则 如果 (优先级 == 任务优先级_定时器) {
        task.下一个 = loop.宏任务_定时器
        loop.宏任务_定时器 = task
    } 否则 如果 (优先级 == 任务优先级_网络) {
        task.下一个 = loop.宏任务_网络
        loop.宏任务_网络 = task
    } 否则 {
        task.下一个 = loop.宏任务_默认
        loop.宏任务_默认 = task
    }
    loop.总宏任务数 = loop.总宏任务数 + 1
}

函数 事件Loop_取宏任务(loop) {
    // 优先级: 用户交互 > 定时器 > 网络 > 默认
    如果 (loop.宏任务_用户交互 != 空) {
        定义 task = loop.宏任务_用户交互
        loop.宏任务_用户交互 = task.下一个
        返回 task
    }
    如果 (loop.宏任务_定时器 != 空) {
        定义 task = loop.宏任务_定时器
        loop.宏任务_定时器 = task.下一个
        返回 task
    }
    如果 (loop.宏任务_网络 != 空) {
        定义 task = loop.宏任务_网络
        loop.宏任务_网络 = task.下一个
        返回 task
    }
    如果 (loop.宏任务_默认 != 空) {
        定义 task = loop.宏任务_默认
        loop.宏任务_默认 = task.下一个
        返回 task
    }
    返回 0
}

// §6 定时器: setTimeout/setInterval

函数 内建_setTimeout(回调, 延迟) {
    定义 loop = 事件Loop_获取()
    如果 (延迟 < TIMER_MIN_DELAY_MS) { 延迟 = TIMER_MIN_DELAY_MS }
    定义 ID = loop.定时器下一ID
    loop.定时器下一ID = loop.定时器下一ID + 1

    追加(loop.定时器列表, 定时器条目 {
        ID: ID,
        回调: 回调,
        间隔_ms: 延迟,
        到期时间: 平台_获取高精度时间() + 延迟,
        是重复: 假,
        已取消: 假,
    })
    返回 ID
}

函数 内建_setInterval(回调, 间隔) {
    定义 loop = 事件Loop_获取()
    如果 (间隔 < TIMER_MIN_DELAY_MS) { 间隔 = TIMER_MIN_DELAY_MS }
    定义 ID = loop.定时器下一ID
    loop.定时器下一ID = loop.定时器下一ID + 1

    追加(loop.定时器列表, 定时器条目 {
        ID: ID,
        回调: 回调,
        间隔_ms: 间隔,
        到期时间: 平台_获取高精度时间() + 间隔,
        是重复: 真,
        已取消: 假,
    })
    返回 ID
}

函数 内建_clearTimeout(ID) {
    定义 loop = 事件Loop_获取()
    定义 可变 i = 0
    当 (i < 计数(loop.定时器列表)) {
        如果 (loop.定时器列表[i].ID == ID) {
            loop.定时器列表[i].已取消 = 真
            返回
        }
        i = i + 1
    }
}

函数 Timer_处理到期(当前时间) {
    定义 loop = 事件Loop_获取()
    定义 可变 i = 0
    当 (i < 计数(loop.定时器列表)) {
        定义 t = loop.定时器列表[i]
        如果 (!t.已取消 && 当前时间 >= t.到期时间) {
            // 到期: 投递为宏任务
            事件Loop_投递任务(t.回调, 任务优先级_定时器)
            如果 (t.是重复) {
                t.到期时间 = 当前时间 + t.间隔_ms
            } 否则 {
                t.已取消 = 真
            }
        }
        i = i + 1
    }
    // 清理已取消的定时器(惰性清理)
    如果 (计数(loop.定时器列表) > 100) {
        定义 可变 新列表 = []
        i = 0
        当 (i < 计数(loop.定时器列表)) {
            如果 (!loop.定时器列表[i].已取消) {
                追加(新列表, loop.定时器列表[i])
            }
            i = i + 1
        }
        loop.定时器列表 = 新列表
    }
}

// §7 requestIdleCallback

函数 requestIdleCallback(回调, 选项_超时) {
    定义 loop = 事件Loop_获取()
    定义 ID = loop.空闲下一ID
    loop.空闲下一ID = loop.空闲下一ID + 1
    定义 截止 = 0
    如果 (选项_超时 > 0) {
        截止 = 平台_获取高精度时间() + 选项_超时
    }
    追加(loop.空闲回调列表, 空闲回调 {
        ID: ID,
        回调: 回调,
        超时_ms: 选项_超时,
        截止时间: 截止,
    })
    返回 ID
}

函数 cancelIdleCallback(ID) {
    定义 loop = 事件Loop_获取()
    定义 可变 i = 0
    当 (i < 计数(loop.空闲回调列表)) {
        如果 (loop.空闲回调列表[i].ID == ID) {
            链表_删除(loop.空闲回调列表, i)
            返回
        }
        i = i + 1
    }
}

函数 Idle_执行(帧截止, 空闲开始, loop) {
    定义 可变 i = 0
    当 (i < 计数(loop.空闲回调列表)) {
        定义 现在 = 平台_获取高精度时间()
        定义 剩余时间 = 帧截止 - 现在
        如果 (剩余时间 <= 0) { 跳出 }
        如果 (剩余时间 > IDLE_DEADLINE_MAX_MS) { 剩余时间 = IDLE_DEADLINE_MAX_MS }

        定义 cb = loop.空闲回调列表[i]
        如果 (cb.回调 != 0) {
            调用回调(cb.回调)
        }
        链表_删除(loop.空闲回调列表, i)
        // 不增加i，因为已删除当前元素
    }
}

// §8 事件循环启停

函数 事件Loop_启动() {
    定义 loop = 事件Loop_获取()
    如果 (loop.运行中) { 返回 }
    loop.运行中 = 真
    loop.上一帧时间 = 平台_获取高精度时间()
    当 (loop.运行中) {
        事件Loop_tick()
    }
}

函数 事件Loop_停止() {
    定义 loop = 事件Loop_获取()
    loop.运行中 = 假
}

函数 事件Loop_设置帧率(fps) {
    定义 loop = 事件Loop_获取()
    如果 (fps > 0) {
        loop.目标帧间隔 = 1000 / fps
    }
}

函数 事件Loop_设置渲染回调(回调) {
    定义 loop = 事件Loop_获取()
    loop.渲染回调 = 回调
}

// §9 AI任务调度

函数 AI_事件循环_调整帧预算(loop) {
    // 反哺: 投机式帧预算预测 (线性回归 + 置信度加权)
    // 核心思想来自投机解码: 基于草稿(历史帧)快速预测下一帧耗时
    定义 n = loop.帧耗时索引
    如果 (n < 4) {
        // 样本不足: 保守策略
        loop.AI_预测帧预算 = loop.目标帧间隔 * 80 / 100
        返回
    }
    // 线性回归预测趋势 (最近8帧)
    定义 窗口 = 如果 (n < 8) { n } 否则 { 8 }
    定义 可变 sum_x = 0
    定义 可变 sum_y = 0
    定义 可变 sum_xy = 0
    定义 可变 sum_x2 = 0
    定义 可变 i = 0
    当 (i < 窗口) {
        定义 x = i
        定义 y = 内存_读32(loop.最近帧耗时 + ((n - 窗口 + i) % 帧历史_大小) * 4)
        sum_x = sum_x + x
        sum_y = sum_y + y
        sum_xy = sum_xy + x * y
        sum_x2 = sum_x2 + x * x
        i = i + 1
    }
    // 斜率 = (n*sum_xy - sum_x*sum_y) / (n*sum_x2 - sum_x^2)
    定义 分母 = 窗口 * sum_x2 - sum_x * sum_x
    定义 预测耗时 = loop.平均帧耗时
    如果 (分母 != 0) {
        定义 斜率 = (窗口 * sum_xy - sum_x * sum_y) / 分母
        预测耗时 = loop.平均帧耗时 + 斜率  // 投机预测下一帧
    }
    // 基于预测耗时分配帧预算 (预留安全余量)
    如果 (预测耗时 > loop.目标帧间隔 * 95 / 100) {
        loop.AI_预测帧预算 = loop.目标帧间隔 * 75 / 100  // 高负载: 激进缩减
    } 否则 如果 (预测耗时 > loop.目标帧间隔 * 70 / 100) {
        loop.AI_预测帧预算 = loop.目标帧间隔 * 85 / 100  // 中负载: 适度缩减
    } 否则 如果 (预测耗时 < loop.目标帧间隔 * 40 / 100) {
        loop.AI_预测帧预算 = loop.目标帧间隔              // 低负载: 满配
    } 否则 {
        loop.AI_预测帧预算 = loop.目标帧间隔 * 90 / 100  // 正常: 留10%余量
    }
}

// §10 统计与诊断

函数 事件循环_统计() {
    定义 loop = 事件Loop_获取()
    定义 FPS = 0
    如果 (loop.平均帧耗时 > 0) { FPS = 1000 / loop.平均帧耗时 }
    返回 {
        运行中: loop.运行中,
        总tick: loop.总tick数,
        渲染帧: loop.渲染帧数,
        FPS: FPS,
        平均帧耗时: loop.平均帧耗时,
        长任务数: loop.长任务计数,
        最长任务: loop.最长任务耗时,
        待处理宏任务: loop.总宏任务数,
        定时器数: 计数(loop.定时器列表),
        空闲回调数: 计数(loop.空闲回调列表),
        目标帧间隔: loop.目标帧间隔,
        AI帧预算: loop.AI_预测帧预算,
    }
}

函数 事件循环_初始化() {
    事件Loop_获取()
    返回 全局事件循环
}

函数 获取事件循环句柄() {
    返回 全局事件循环
}

// Nova标准库 — 嵌入层 (Embedding)
// 标记 → 向量映射，支撑 NLP/LLM 基础
// 对标 nova-forth 的 embedding/ 模块

导入("../基础.nova")
导入("../../运行时/原语桩.nova")

定义 嵌入精度 = 1000

// 嵌入表
// [词汇量, 嵌入维度, 权重矩阵]
// 权重矩阵: vocab_size × embed_dim

函数 嵌入_创建(词汇量, 嵌入维度, 种子) { 定义 可变 权重 = [词汇量, 嵌入维度]
 定义 可变 s = 种子
 定义 可变 i = 0
 当 (i < 词汇量 * 嵌入维度) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 定义 w = (s % 200) - 100
 追加(权重, w)
 i = i + 1
 }
 返回 权重
}

// 查找嵌入向量
函数 嵌入_查找(嵌入表, token_id) { 定义 维度 = 嵌入表[1]
 定义 可变 向量 = []
 定义 基 = 2 + token_id * 维度
 定义 可变 i = 0
 当 (i < 维度) {
 追加(向量, 嵌入表[基 + i])
 i = i + 1
 }
 返回 向量
}

// 批量查找 (序列嵌入)
函数 嵌入_序列(嵌入表, token序列) { 定义 n = 计数(token序列)
 定义 维度 = 嵌入表[1]
 定义 可变 结果 = [n, 维度]
 定义 可变 i = 0
 当 (i < n) { 定义 向量 = 嵌入_查找(嵌入表, token序列[i])
 定义 可变 j = 0
 当 (j < 维度) {
 追加(结果, 向量[j])
 j = j + 1
 }
 i = i + 1
 }
 返回 结果
}

// 更新嵌入权重 (梯度下降)
函数 嵌入_更新(嵌入表, token_id, 梯度, 学习率) { 定义 维度 = 嵌入表[1]
 定义 基 = 2 + token_id * 维度
 定义 可变 i = 0
 当 (i < 维度) {
 嵌入表[基 + i] = 嵌入表[基 + i] - 学习率 * 梯度[i] / 嵌入精度
 i = i + 1
 }
}

// 简单分词器

// 字符级分词
函数 字符分词(文本) { 定义 n = 计数(文本)
 定义 可变 词元列 = []
 定义 可变 i = 0
 当 (i < n) {
 追加(词元列, 编码(子串(文本, i, 1)))
 i = i + 1
 }
 返回 词元列
}

// 空格分词
函数 空格分词(文本) { 定义 n = 计数(文本)
    定义 可变 当前词 = ""
 定义 可变 词元列 = []
 定义 可变 i = 0
 当 (i < n) { 定义 c = 子串(文本, i, 1)
 如果 (编码(c) == 字符_空格 或 编码(c) == 字符_换行 或 编码(c) == 字符_制表) { 如果 (计数(当前词) > 0) {
 追加(词元列, 当前词)
 当前词 = ""
 }
 } 否则 {
 当前词 = 字符串拼接(当前词, c)
 }
 i = i + 1
 }
 如果 (计数(当前词) > 0) {
 追加(词元列, 当前词)
 }
 返回 词元列
}

// 构建词汇表 (词→ID映射)
函数 构建词汇表(文本列表) { 定义 可变 词表 = 字典()
 定义 可变 id = 0
 // 特殊token
 字典设(词表, "<PAD>", id) id = id + 1
 字典设(词表, "<UNK>", id) id = id + 1
 字典设(词表, "<BOS>", id) id = id + 1
 字典设(词表, "<EOS>", id) id = id + 1
 // 遍历所有文本
 定义 可变 ti = 0
 当 (ti < 计数(文本列表)) { 定义 词元列 = 空格分词(文本列表[ti])
 定义 可变 j = 0
 当 (j < 计数(词元列)) { 如果 (字典取(词表, 词元列[j]) == 空) {
 字典设(词表, 词元列[j], id)
 id = id + 1
 }
 j = j + 1
 }
 ti = ti + 1
 }
 返回 [词表, id]
}

// 文本编码 (词→ID序列, 0)
函数 文本编码(文本, 词表) { 定义 词元列 = 空格分词(文本)
 定义 可变 ids = []
 定义 unk_id = 字典取(词表, "<UNK>")
 定义 可变 i = 0
 当 (i < 计数(词元列)) { 定义 id = 字典取(词表, 词元列[i])
 如果 (id != 空) {
 追加(ids, id)
 } 否则 {
 追加(ids, unk_id)
 }
 i = i + 1
 }
 返回 ids
}

// 余弦相似度 (嵌入向量, 0)
函数 嵌入_相似度(v1, v2) { 定义 n = 计数(v1)
 定义 可变 点积 = 0
 定义 可变 范数1 = 0
 定义 可变 范数2 = 0
 定义 可变 i = 0
 当 (i < n) {
 点积 = 点积 + v1[i] * v2[i]
 范数1 = 范数1 + v1[i] * v1[i]
 范数2 = 范数2 + v2[i] * v2[i]
 i = i + 1
 }
 定义 分母 = 嵌入_开方(范数1) * 嵌入_开方(范数2)
 如果 (分母 == 0) { 返回 0 }
 返回 点积 * 嵌入精度 / 分母
}

// 序列填充 (Padding)
函数 填充序列(序列, 最大长度, 填充值) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 最大长度) { 如果 (i < 计数(序列)) {
 追加(结果, 序列[i])
 } 否则 {
 追加(结果, 填充值)
 }
 i = i + 1
 }
 返回 结果
}

// 序列截断
函数 截断序列(序列, 最大长度) {
    如果 (计数(序列) <= 最大长度) { 返回 序列
}
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 最大长度) {
 追加(结果, 序列[i])
 i = i + 1
 }
 返回 结果
}

函数 嵌入_开方(n) { 返回 开方(n) }

// 正弦位置编码 (Sinusoidal PE, 0)
// PE(位置, 2i) = sin(位置 / 10000^(2i/d))
// PE(位置, 2i+1) = cos(位置 / 10000^(2i/d))

函数 位置嵌入_创建(最大长度, 嵌入维度) { 定义 可变 pe = [最大长度, 嵌入维度]
 定义 可变 位置 = 0
 当 (位置 < 最大长度) { 定义 可变 i = 0
 当 (i < 嵌入维度) { 定义 周期 = (i + 2) * 100
 定义 角度 = 位置 * 嵌入精度 / 周期
 如果 (i % 2 == 0) {
 追加(pe, 嵌入_sin近似(角度))
 } 否则 {
 追加(pe, 嵌入_cos近似(角度))
 }
 i = i + 1
 }
 位置 = 位置 + 1
 }
 返回 pe
}

// 嵌入 + 位置编码
函数 嵌入_加位置(嵌入矩阵, 位置编码) { 定义 序列 = 嵌入矩阵[0]
 定义 维度 = 嵌入矩阵[1]
 定义 可变 i = 0
 当 (i < 序列 * 维度) {
 嵌入矩阵[2 + i] = 嵌入矩阵[2 + i] + 位置编码[2 + i]
 i = i + 1
 }
}

// 可学习位置嵌入 (Learnable PE, GPT风格)
函数 可学习位置嵌入_创建(最大长度, 嵌入维度, 种子) { 定义 可变 pe = [最大长度, 嵌入维度]
 定义 可变 s = 种子
 定义 可变 i = 0
 当 (i < 最大长度 * 嵌入维度) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 追加(pe, (s % 200) - 100)
 i = i + 1
 }
 返回 pe
}

// Token + Segment + Position 嵌入 (BERT风格)
函数 bert嵌入(token嵌入表, segment嵌入表, 位置编码, token序列, segment序列) { 定义 序列长 = 计数(token序列)
 定义 维度 = token嵌入表[1]
 定义 可变 结果 = [序列长, 维度]
 定义 可变 i = 0
 当 (i < 序列长) { 定义 tok_vec = 嵌入_查找(token嵌入表, token序列[i])
 定义 seg_vec = 嵌入_查找(segment嵌入表, segment序列[i])
 定义 可变 j = 0
 当 (j < 维度) {
 追加(结果, tok_vec[j] + seg_vec[j] + 位置编码[2 + i * 维度 + j])
 j = j + 1
 }
 i = i + 1
 }
 返回 结果
}

// 词向量最近邻搜索
// 在嵌入表中找到与query向量最相似的k个词

函数 嵌入_最近邻(嵌入表, 查询向量, k) { 定义 词汇量 = 嵌入表[0]
 // 计算所有相似度
 定义 可变 相似度列表 = []
 定义 可变 索引列表 = []
 定义 可变 vi = 0
 当 (vi < 词汇量) { 定义 向量 = 嵌入_查找(嵌入表, vi)
 定义 相似度 = 嵌入_相似度(查询向量, 向量)
 追加(相似度列表, 相似度)
 追加(索引列表, vi)
 vi = vi + 1
 }
 // 选择top-k (部分排序)
 定义 可变 top_ids = []
 定义 可变 ki = 0
 当 (ki < k 且 ki < 词汇量) { 定义 可变 最佳idx = 0
 定义 可变 最佳sim = 0 - 0x7FFFFFFF
 定义 可变 si = 0
 当 (si < 词汇量) { 如果 (相似度列表[si] > 最佳sim) {
 最佳sim = 相似度列表[si]
 最佳idx = si
 }
 si = si + 1
 }
 追加(top_ids, [最佳idx, 最佳sim])
 相似度列表[最佳idx] = 0 - 0x7FFFFFFF // 标记已选
 ki = ki + 1
 }
 返回 top_ids
}

// 嵌入向量算术 (word2vec风格)
// king - man + woman ≈ queen

函数 嵌入_向量运算(嵌入表, 正id列表, 负id列表) { 定义 维度 = 嵌入表[1]
 定义 可变 结果 = []
 定义 可变 d = 0
 当 (d < 维度) { 追加(结果, 0)
 d = d + 1 }
 // 加正向量
 定义 可变 pi = 0
 当 (pi < 计数(正id列表)) { 定义 向量 = 嵌入_查找(嵌入表, 正id列表[pi])
 d = 0
 当 (d < 维度) { 结果[d] = 结果[d] + 向量[d]
 d = d + 1 }
 pi = pi + 1
 }
 // 减负向量
 定义 可变 ni = 0
 当 (ni < 计数(负id列表)) { 定义 向量 = 嵌入_查找(嵌入表, 负id列表[ni])
 d = 0
 当 (d < 维度) { 结果[d] = 结果[d] - 向量[d]
 d = d + 1 }
 ni = ni + 1
 }
 返回 结果
}

// 嵌入L2归一化
函数 嵌入_归一化(向量) { 定义 n = 计数(向量)
 定义 可变 范数sq = 0
 定义 可变 i = 0
 当 (i < n) { 范数sq = 范数sq + 向量[i] * 向量[i]
 i = i + 1 }
 定义 范数 = 嵌入_开方(范数sq)
 如果 (范数 == 0) { 返回 向量 }
 定义 可变 结果 = []
 i = 0
 当 (i < n) {
 追加(结果, 向量[i] * 嵌入精度 / 范数)
 i = i + 1
 }
 返回 结果
}

// N-gram 分词
函数 ngram分词(文本, n) { 定义 文本长 = 计数(文本)
 定义 可变 grams = []
 定义 可变 i = 0
 当 (i <= 文本长 - n) {
 追加(grams, 子串(文本, i, n))
 i = i + 1
 }
 返回 grams
}

// 嵌入平均池化 (句子嵌入)
函数 嵌入_平均池化(嵌入矩阵, 有效长度) { 定义 维度 = 嵌入矩阵[1]
 定义 可变 结果 = []
 定义 可变 d = 0
 当 (d < 维度) { 追加(结果, 0)
 d = d + 1 }
 定义 可变 i = 0
 当 (i < 有效长度) {
 d = 0
 当 (d < 维度) {
 结果[d] = 结果[d] + 嵌入矩阵[2 + i * 维度 + d]
 d = d + 1
 }
 i = i + 1
 }
 d = 0
 当 (d < 维度) { 结果[d] = 结果[d] / 有效长度
 d = d + 1 }
 返回 结果
}

// 嵌入最大池化
函数 嵌入_最大池化(嵌入矩阵, 有效长度) { 定义 维度 = 嵌入矩阵[1]
 定义 可变 结果 = []
 定义 可变 d = 0
 当 (d < 维度) { 追加(结果, 嵌入矩阵[2 + d])
 d = d + 1 }
 定义 可变 i = 1
 当 (i < 有效长度) {
 d = 0
 当 (d < 维度) { 定义 v = 嵌入矩阵[2 + i * 维度 + d]
 如果 (v > 结果[d]) { 结果[d] = v }
 d = d + 1
 }
 i = i + 1
 }
 返回 结果
}

// 嵌入Dropout (训练时随机置零)
函数 嵌入_dropout(向量, 比率, 种子) { 定义 n = 计数(向量)
 定义 可变 结果 = []
 定义 可变 s = 种子
 定义 缩放 = 嵌入精度 * 嵌入精度 / (嵌入精度 - 比率)
 定义 可变 i = 0
 当 (i < n) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 如果 (s % 嵌入精度 < 比率) {
 追加(结果, 0)
 } 否则 {
 追加(结果, 向量[i] * 缩放 / 嵌入精度)
 }
 i = i + 1
 }
 返回 结果
}

// 嵌入矩阵乘法 (线性投影)
函数 嵌入_线性(输入, 权重行, 权重列, 权重) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 权重行) { 定义 可变 和 = 0
 定义 可变 j = 0
 当 (j < 权重列) { 如果 (j < 计数(输入)) {
 和 = 和 + 输入[j] * 权重[i * 权重列 + j] / 嵌入精度
 }
 j = j + 1
 }
 追加(结果, 和)
 i = i + 1
 }
 返回 结果
}

// TF-IDF 向量化
函数 tfidf_向量(文档词频, 文档总数, 含词文档数) { 定义 n = 计数(文档词频)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < n) { 定义 词频 = 文档词频[i]
 定义 可变 逆文档频率 = 嵌入精度
 如果 (含词文档数[i] > 0) {
 逆文档频率 = 文档总数 * 嵌入精度 / 含词文档数[i]
 }
 追加(结果, 词频 * 逆文档频率 / 嵌入精度)
 i = i + 1
 }
 返回 结果
}

// 内部工具
函数 嵌入_sin近似(x) { 定义 可变 角 = x % 6283
 如果 (角 < 0) { 角 = 角 + 6283 }
 如果 (角 < 1571) { 返回 角 * 嵌入精度 / 1571 }
 如果 (角 < 3142) { 返回 (3142 - 角) * 嵌入精度 / 1571 }
 如果 (角 < 4712) { 返回 0 - (角 - 3142) * 嵌入精度 / 1571 }
 返回 0 - (6283 - 角) * 嵌入精度 / 1571
}

函数 嵌入_cos近似(x) { 返回 嵌入_sin近似(x + 1571) }

定义 可变 _嵌入_创建数 = 0
定义 可变 _嵌入_查找数 = 0
定义 可变 _嵌入_零向量数 = 0

函数 嵌入_记录创建() { _嵌入_创建数 = _嵌入_创建数 + 1 }
函数 嵌入_记录查找() { _嵌入_查找数 = _嵌入_查找数 + 1 }
函数 嵌入_记录零向量() { _嵌入_零向量数 = _嵌入_零向量数 + 1 }

函数 嵌入_质量评估() {
    如果 (_嵌入_创建数 == 0) { 返回 "无嵌入数据"
}
 定义 零率 = _嵌入_零向量数 * 100 / _嵌入_创建数
 如果 (零率 > 30) { 返回 "警告: 大量零向量,词汇覆盖不足" }
 如果 (零率 > 10) { 返回 "注意: 部分零向量" }
 返回 "嵌入质量良好"
}

函数 嵌入_命中率() {
    如果 (_嵌入_查找数 == 0) { 返回 0
}
 定义 命中 = _嵌入_查找数 - _嵌入_零向量数
 返回 命中 * 100 / _嵌入_查找数
}

函数 嵌入_重置() { _嵌入_创建数 = 0 _嵌入_查找数 = 0 _嵌入_零向量数 = 0 }

导入("../基础.nova")
导入("../数学/密码学/密码学.nova")
导入("./数学扩展.nova")

// 金行特性: 精确、纯粹、不可分割
// 素数 = 金之纯体 (不可再分解)
// GCD = 金之精炼 (提取最大公因)
// 模运算 = 金之约束 (循环群结构)
// 费马小定理: 自验证的模幂性质
// CRT: 同构重建的自指性
// 素因数分解: 数→组 (个→批的态射)
// GCD: 数×数→数 (对的精炼态射)

// 扩展欧几里得: 回 [最大公约数, x, y] 满足 ax + by = 最大公约数
函数 数论_扩展gcd(a, b) {
    如果 (b == 0) { 返回 [a, 1, 0]
}
 定义 结果 = 数论_扩展gcd(b, a % b)
 返回 [结果[0], 结果[2], 结果[1] - (a / b) * 结果[2]]
}

// 模逆元: a^(-1) mod m
函数 模逆元(a, m) { 定义 结果 = 数论_扩展gcd(a, m)
 如果 (结果[0] != 1) { 返回 -1 }
 返回 (结果[1] % m + m) % m
}

// 中国余数定理 (两个同余方程)
// x ≡ r1 (mod m1), x ≡ r2 (mod m2)
函数 crt_两个(r1, m1, r2, m2) { 定义 结果 = 数论_扩展gcd(m1, m2)
 定义 g = 结果[0]
 如果 (r2 - r1) % g != 0 { 返回 -1 }
 定义 lcm_val = m1 / g * m2
 定义 可变 x = (r1 + m1 * ((r2 - r1) / g * 结果[1] % (m2 / g))) % lcm_val
 如果 (x < 0) { x = x + lcm_val }
 返回 x
}

// 质因数分解
函数 数论_质因数分解(n) { 定义 可变 因子 = []
    定义 可变 nn = 0
 定义 可变 d = 2
 当 (d * d <= nn) {
 当 (nn % d == 0) {
 追加(因子, d)
 nn = nn / d
 }
 d = d + 1
 }
 如果 (nn > 1) { 追加(因子, nn) }
 返回 因子
}

// 所有因数
函数 所有因数(n) { 定义 可变 因数 = []
 定义 可变 i = 1
 当 (i * i <= n) { 如果 (n % i == 0) {
 追加(因数, i)
 如果 (i != n / i) { 追加(因数, n / i) }
 }
 i = i + 1
 }
 返回 因数
}

// 因数个数
函数 因数个数(n) { 返回 计数(所有因数(n))
}

// 因数和
函数 因数和(n) { 定义 因数 = 所有因数(n)
 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 计数(因数)) { 总 = 总 + 因数[i] i = i + 1 }
 返回 总
}

// 是否完美数
函数 是完美数(n) {
    如果 (n <= 1) { 返回 0
}
 返回 因数和(n) - n == n
}

// 莫比乌斯函数 μ(n)
函数 莫比乌斯(n) {
    如果 (n == 1) { 返回 1
}
 定义 因子 = 数论_质因数分解(n)
 // 检查是否有重复质因子
 定义 可变 i = 0
 当 (i < 计数(因子) - 1) { 如果 (因子[i] == 因子[i + 1]) { 返回 0 }
 i = i + 1
 }
 如果 (计数(因子) % 2 == 0) { 返回 1 }
 返回 -1
}

// 第n个三角数
函数 三角数(n) { 返回 n * (n + 1) / 2 }

// 第n个五角数
函数 五角数(n) { 返回 n * (3 * n - 1) / 2 }

// 是否平方数
函数 是平方数(n) {
    如果 (n < 0) { 返回 0
}
 定义 r = 整数sqrt(n)
 返回 r * r == n
}

// 约瑟夫问题
函数 约瑟夫(n, k) { 定义 可变 结果 = 0
 定义 可变 i = 2
 当 (i <= n) {
 结果 = (结果 + k) % i
 i = i + 1
 }
 返回 结果
}

// 卡特兰数 C(n) = C(2n,n)/(n+1)
函数 卡特兰数(n) {
    如果 (n <= 1) { 返回 1
}
 定义 可变 dp = []
 定义 可变 i = 0
 当 (i <= n) { 追加(dp, 0) i = i + 1 }
 dp[0] = 1
 dp[1] = 1
 i = 2
 当 (i <= n) { 定义 可变 j = 0
 当 (j < i) {
 dp[i] = dp[i] + dp[j] * dp[i - 1 - j]
 j = j + 1
 }
 i = i + 1
 }
 返回 dp[n]
}

// 斯特林数 (第二类, 0) S(n,k)
函数 斯特林数(n, k) {
    如果 (n == 0 且 k == 0) { 返回 1
}
 如果 (n == 0 或 k == 0) { 返回 0 }
 如果 (k == 1 或 k == n) { 返回 1 }
 返回 k * 斯特林数(n - 1, k) + 斯特林数(n - 1, k - 1)
}

// 贝尔数 B(n)
函数 贝尔数(n) {
    如果 (n == 0) { 返回 1
}
 定义 可变 总 = 0
 定义 可变 k = 0
 当 (k <= n) {
 总 = 总 + 斯特林数(n, k)
 k = k + 1
 }
 返回 总
}

// 整数划分数
函数 划分数(n) { 定义 可变 dp = []
 定义 可变 i = 0
 当 (i <= n) { 追加(dp, 0) i = i + 1 }
 dp[0] = 1
 i = 1
 当 (i <= n) { 定义 可变 j = i
 当 (j <= n) {
 dp[j] = dp[j] + dp[j - i]
 j = j + 1
 }
 i = i + 1
 }
 返回 dp[n]
}

// 高斯整数加法
函数 高斯加(a实, a虚, b实, b虚) { 返回 [a实 + b实, a虚 + b虚]
}

// 高斯整数乘法
函数 高斯乘(a实, a虚, b实, b虚) { 返回 [a实 * b实 - a虚 * b虚, a实 * b虚 + a虚 * b实]
}

// 高斯整数模
函数 高斯模(a实, a虚) { 返回 整数sqrt(a实 * a实 + a虚 * a虚)
}

// 别名（委托至上方权威实现，保持向后兼容）
函数 数论_扩展GCD(a, b) { 返回 数论_扩展gcd(a, b) }
函数 数论_模逆(a, m) { 返回 模逆元(a, m) }
函数 数论_模幂(底数, 指数, 模) { 返回 快速幂(底数, 指数, 模) }
函数 CRT_两个(r1, m1, r2, m2) { 返回 crt_两个(r1, m1, r2, m2) }

导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("./传输控制关.nova")
导入("./网缓读.nova")
导入("../中枢/字符串替换.nova")
导入("./网缓分配.nova")
导入("./传输控制拥.nova")

// 传控数据接收(网络 → 用户空间)

函数 tcp_接收数据(tcb, 缓冲, 最大长度) {
    如果 (tcb.状态 != 传控_状态_已建立 &&
        tcb.状态 != 传控_状态_FIN_WAIT_1 &&
        tcb.状态 != 传控_状态_FIN_WAIT_2) {
        返回 错误码_未连接
    }

    定义 可变 已读 = 0
    当 (已读 < 最大长度) {
        如果 (Nova网络缓冲_队列_为空(tcb.接收缓冲)) {
            跳出
        }

        定义 Nova缓冲 = Nova网络缓冲_队列_查看头(tcb.接收缓冲)
        定义 可用 = Nova缓冲.数据长度 - Nova缓冲.已读偏移
        定义 本次读取 = 取小(可用, 最大长度 - 已读)

        内存复制(缓冲 + 已读, Nova缓冲.数据 + Nova缓冲.已读偏移, 本次读取)
        已读 = 已读 + 本次读取
        Nova缓冲.已读偏移 = Nova缓冲.已读偏移 + 本次读取

        如果 (Nova缓冲.已读偏移 >= Nova缓冲.数据长度) {
            Nova网络缓冲_队列_出队(tcb.接收缓冲)
            Nova缓冲_释放(Nova缓冲)
        }
    }

    // 更新接收窗口
    tcb.接收窗口 = tcb.接收窗口 + 已读

    返回 已读
}

// 接收数据处理(从网络到接收缓冲)

函数 tcp_处理数据(tcb, Nova缓冲, 序号) {
    定义 头 = Nova缓冲.数据 + Nova缓冲.传输层偏移
    定义 头长度 = tcp_获取数据偏移(头) * 4
    定义 数据起始 = Nova缓冲.传输层偏移 + 头长度
    定义 数据长度 = Nova缓冲.数据长度 - 数据起始

    如果 (数据长度 == 0) { 返回 }

    如果 (序号 == tcb.接收序号) {
        // 按序到达，直接加入接收缓冲
        定义 可变 数据Nova缓冲 = Nova缓冲_分配(数据长度)
        内存复制(数据Nova缓冲.数据, Nova缓冲.数据 + 数据起始, 数据长度)
        数据Nova缓冲.数据长度 = 数据长度
        数据Nova缓冲.已读偏移 = 0
        Nova网络缓冲_队列_入队(tcb.接收缓冲, 数据Nova缓冲)

        tcb.接收序号 = tcb.接收序号 + 数据长度
        tcb.接收窗口 = tcb.接收窗口 - 数据长度

        // 检查乱序队列中是否有后续数据可以拼接
        tcp_合并乱序数据(tcb)

        // 发送ACK
        tcp_发送ACK(tcb)
    } 否则 如果 (序号 > tcb.接收序号) {
        // 乱序到达，加入乱序队列
        tcp_插入乱序队列(tcb, Nova缓冲, 序号, 数据起始, 数据长度)
        // 发送重复ACK(触发快速重传)
        tcp_发送ACK(tcb)
    }
    // 序号 < 接收序号: 重复数据，忽略
}

函数 tcp_插入乱序队列(tcb, Nova缓冲, 序号, 数据起始, 数据长度) {
    定义 可变 数据Nova缓冲 = Nova缓冲_分配(数据长度)
    内存复制(数据Nova缓冲.数据, Nova缓冲.数据 + 数据起始, 数据长度)
    数据Nova缓冲.数据长度 = 数据长度
    数据Nova缓冲.tcp序号 = 序号

    // 按序号排序插入
    定义 可变 前一个 = 空
    定义 可变 当前 = tcb.乱序队列.头
    当 (当前 != 空) {
        如果 (序号 < 当前.tcp序号) {
            跳出
        }
        前一个 = 当前
        当前 = 当前.下一个
    }

    如果 (前一个 == 空) {
        数据Nova缓冲.下一个 = tcb.乱序队列.头
        tcb.乱序队列.头 = 数据Nova缓冲
    } 否则 {
        数据Nova缓冲.下一个 = 前一个.下一个
        前一个.下一个 = 数据Nova缓冲
    }
}

函数 tcp_合并乱序数据(tcb) {
    当 (!Nova网络缓冲_队列_为空(tcb.乱序队列)) {
        定义 头Nova缓冲 = tcb.乱序队列.头
        如果 (头Nova缓冲.tcp序号 == tcb.接收序号) {
            // 可以合并
            Nova网络缓冲_队列_出队(tcb.乱序队列)
            头Nova缓冲.已读偏移 = 0
            Nova网络缓冲_队列_入队(tcb.接收缓冲, 头Nova缓冲)
            tcb.接收序号 = tcb.接收序号 + 头Nova缓冲.数据长度
        } 否则 {
            跳出
        }
    }
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./时钟中枢.nova")
导入("./进程描述符.nova")
导入("./每处理器.nova")
导入("./公平调度睡.nova")

结构 高精度定时器 {
    到期纳秒,    // u64 绝对到期时间(纳秒)
    回调,
    数据,
    已取消,
    周期,    // u64 0=单次, >0=周期性(纳秒)
}

定义 可变 hrtimer列表 = []

函数 hrtimer_添加(纳秒后, 回调, 数据) {
    定义 现在 = 读取纳秒()
    定义 ht = 高精度定时器 {}
    ht.到期纳秒 = 现在 + 纳秒后
    ht.回调 = 回调
    ht.数据 = 数据
    ht.已取消 = 假
    ht.周期 = 0

    追加(hrtimer列表, ht)

    // 更新最近到期时间
    如果 (ht.到期纳秒 < hrtimer_下次到期) {
        hrtimer_下次到期 = ht.到期纳秒
    }
    返回 ht
}

函数 hrtimer_添加_周期(周期纳秒, 回调, 数据) {
    定义 ht = hrtimer_添加(周期纳秒, 回调, 数据)
    ht.周期 = 周期纳秒
    返回 ht
}

函数 hrtimer_取消(ht) {
    ht.已取消 = 真
}

函数 hrtimer_处理到期() {
    定义 现在 = 读取纳秒()
    如果 (现在 < hrtimer_下次到期) { 返回 }

    定义 可变 下次最小 = 0xFFFFFFFFFFFFFFFF
    定义 可变 i = 0
    当 (i < 计数(hrtimer列表)) {
        定义 ht = hrtimer列表[i]
        如果 (!ht.已取消 && ht.到期纳秒 <= 现在) {
            如果 (ht.回调 != 空) { ht.回调(ht.数据) }

            如果 (ht.周期 > 0) {
                // 周期性: 重新设置到期时间
                ht.到期纳秒 = 现在 + ht.周期
                如果 (ht.到期纳秒 < 下次最小) { 下次最小 = ht.到期纳秒 }
            } 否则 {
                ht.已取消 = 真  // 单次: 标记完成
            }
        } 否则 如果 (!ht.已取消) {
            如果 (ht.到期纳秒 < 下次最小) { 下次最小 = ht.到期纳秒 }
        }
        i = i + 1
    }
    hrtimer_下次到期 = 下次最小
}

// 进程睡眠定时器 (schedule_timeout / msleep / usleep)

函数 进程_设置定时唤醒(进程, 纳秒后) {
    定义 到期滴答 = 系统滴答 + (纳秒后 / TICK_NSEC)
    如果 (到期滴答 <= 系统滴答) { 到期滴答 = 系统滴答 + 1 }
    添加定时器(到期滴答, 定时器_唤醒进程, 进程)
}

函数 定时器_唤醒进程(进程) {
    如果 (进程 != 空) {
        进程_设置状态(进程, 进程状态_就绪)
        调度_入队(进程)
    }
}

函数 schedule_timeout(滴答数) {
    如果 (滴答数 <= 0) { 返回 0 }
    定义 当前 = 获取当前进程()
    定义 到期 = 系统滴答 + 滴答数
    添加定时器(到期, 定时器_唤醒进程, 当前)
    进程_设置状态(当前, 进程状态_等待)
    调度()
    // 返回剩余滴答数(如果被信号唤醒)
    定义 剩余 = 到期 - 系统滴答
    如果 (剩余 < 0) { 剩余 = 0 }
    返回 剩余
}

函数 msleep(毫秒) {
    schedule_timeout(毫秒 * HZ / 1000)
}

函数 usleep(微秒) {
    // 高精度: 用hrtimer
    定义 当前 = 获取当前进程()
    hrtimer_添加(微秒 * 1000, 定时器_唤醒进程, 当前)
    进程_设置状态(当前, 进程状态_等待)
    调度()
}

// 系统时间更新 (每tick调用)

函数 系统时间_滴答更新() {
    系统时间_纳秒 = 系统时间_纳秒 + TICK_NSEC
    如果 (系统时间_纳秒 >= NSEC_PER_SEC) {
        系统时间_秒 = 系统时间_秒 + 1
        系统时间_纳秒 = 系统时间_纳秒 - NSEC_PER_SEC
    }
}

// 系统负载更新 (每秒)

定义 可变 Nova负载均值_1min = 0
定义 可变 Nova负载均值_5min = 0
定义 可变 Nova负载均值_15min = 0

函数 更新系统负载() {
    // 指数衰减移动平均 
    // Linux使用固定点数EXP_1/EXP_5/EXP_15常数:
    //   EXP_1  = 1884  (e^(-5/60)  * 2048)
    //   EXP_5  = 2014  (e^(-5/300) * 2048)
    //   EXP_15 = 2037  (e^(-5/900) * 2048)
    // load = load * EXP + active * (2048 - EXP)
    定义 活跃 = 进程_运行中数() + 进程_阻塞数()
    定义 活跃_定点 = 活跃 * 2048   // 定点数(<<11)

    // 1分钟: EXP_1 = 1884
    Nova负载均值_1min = (Nova负载均值_1min * 1884 + 活跃_定点 * (2048 - 1884)) / 2048
    // 5分钟: EXP_5 = 2014
    Nova负载均值_5min = (Nova负载均值_5min * 2014 + 活跃_定点 * (2048 - 2014)) / 2048
    // 15分钟: EXP_15 = 2037
    Nova负载均值_15min = (Nova负载均值_15min * 2037 + 活跃_定点 * (2048 - 2037)) / 2048
}

// 便捷函数

函数 获取滴答() { 返回 系统滴答 }
函数 获取jiffies() { 返回 系统滴答 }
函数 滴答到毫秒(滴答) { 返回 滴答 * 1000 / HZ }
函数 毫秒到滴答(毫秒) { 返回 毫秒 * HZ / 1000 }
函数 系统运行秒数() { 返回 系统滴答 / HZ }
函数 内核_运行时间秒() { 返回 系统滴答 / HZ }
函数 当前时间_秒() { 返回 系统时间_秒 }
函数 当前时间_纳秒() { 返回 系统时间_秒 * NSEC_PER_SEC + 系统时间_纳秒 }
函数 当前时间_微秒() { 返回 系统时间_秒 * USEC_PER_SEC + 系统时间_纳秒 / 1000 }

// 统计

函数 定时器_统计() {
    返回 [定时器_总添加, 定时器_总到期, 定时器_总取消, 计数(定时器链表), 计数(hrtimer列表)]
}

定义 可变 AI_高精定器添_负载窗口 = []

函数 AI_高精定器添_负载预测(当前负载) {
    追加(AI_高精定器添_负载窗口, 当前负载)
    如果 (计数(AI_高精定器添_负载窗口) > 20) { 列表_移除(AI_高精定器添_负载窗口, 0) }
    如果 (计数(AI_高精定器添_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_高精定器添_负载窗口)
    定义 趋势 = AI_高精定器添_负载窗口[n-1] - AI_高精定器添_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_高精定器添_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

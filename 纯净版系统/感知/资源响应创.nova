// ResourceResponse — 资源响应 

结构 ResourceResponse {
 url,    // u64 最终URL (重定向后)
 状态码,    // u32 HTTP状态码 200/301/404/500...
 状态文本,    // u64 "OK" / "Not Found"
 响应头,    // u64 HTTP头部列表*
 内容类型,    // u64 Content-Type MIME类型
 内容长度,    // i64 Content-Length (-1=unknown)
 字符编码,    // u64 "utf-8" / "gbk" 等
 最后修改,    // u64 Last-Modified
 ETag,    // u64 ETag
 是从缓存,
}

函数 ResourceResponse_创建() {
 定义 resp = 堆_分配(ResourceResponse)
 resp.url = 0
 resp.状态码 = 0
 resp.状态文本 = 0
 resp.响应头 = HTTP头部_创建()
 resp.内容类型 = 0
 resp.内容长度 = -1
 resp.字符编码 = 字符串_复制("utf-8")
 resp.最后修改 = 0
 resp.ETag = 0
 resp.是从缓存 = 假
 返回 resp
}

// §2 NovaOS网络Nova系统调用接口
// 对应: net::传控ClientSocket → 内核传控/IP栈

定义 Nova系统调用_网络_创建套接字 = 400
定义 Nova系统调用_网络_连接 = 401
定义 Nova系统调用_网络_发送 = 402
定义 Nova系统调用_网络_接收 = 403
定义 Nova系统调用_网络_关闭 = 404
定义 Nova系统调用_网络_域名解析 = 405
定义 Nova系统调用_网络_安全握手 = 406
定义 Nova系统调用_网络_安全发送 = 407
定义 Nova系统调用_网络_安全接收 = 408
定义 Nova系统调用_网络_非阻塞轮询 = 409

定义 套接字类型_传控 = 1
定义 套接字类型_数报 = 2

函数 网络_域名解析(主机名) {
 // 返回IPv4地址(32位)
 返回 系统调用(Nova系统调用_网络_域名解析, 主机名, 字符串_长度(主机名), 0, 0, 0)
}

函数 网络_传控连接(IP地址, 端口) {
 定义 套接字 = 系统调用(Nova系统调用_网络_创建套接字, 套接字类型_传控, 0, 0, 0, 0)
 如果 (套接字 < 0) { 返回 -1 }
 定义 结果 = 系统调用(Nova系统调用_网络_连接, 套接字, IP地址, 端口, 0, 0)
 如果 (结果 < 0) { 返回 -1 }
 返回 套接字
}

函数 网络_安全连接(套接字, 主机名) {
 返回 系统调用(Nova系统调用_网络_安全握手, 套接字, 主机名, 字符串_长度(主机名), 0, 0)
}

函数 网络_发送(套接字, 数据, 长度, 是安全) {
 如果 (是安全) {
 返回 系统调用(Nova系统调用_网络_安全发送, 套接字, 数据, 长度, 0, 0)
 }
 返回 系统调用(Nova系统调用_网络_发送, 套接字, 数据, 长度, 0, 0)
}

函数 网络_接收(套接字, 缓冲, 缓冲大小, 是安全) {
 如果 (是安全) {
 返回 系统调用(Nova系统调用_网络_安全接收, 套接字, 缓冲, 缓冲大小, 0, 0)
 }
 返回 系统调用(Nova系统调用_网络_接收, 套接字, 缓冲, 缓冲大小, 0, 0)
}

函数 网络_关闭(套接字) {
 系统调用(Nova系统调用_网络_关闭, 套接字, 0, 0, 0, 0)
}

// §3 HTTP协议实现 (net::HttpStreamParser)
// 构建HTTP请求报文,解析HTTP响应报文

函数 HTTP_构建请求报文(req) {
 定义 url = req.url
 定义 可变 报文 = ""

 // 请求行: GET /path HTTP/1.1\r\n
 如果 (req.方法 == HTTP_GET) { 报文 = "GET " }
 否则 如果 (req.方法 == HTTP_POST) { 报文 = "POST " }
 否则 如果 (req.方法 == HTTP_PUT) { 报文 = "PUT " }
 否则 如果 (req.方法 == HTTP_DELETE) { 报文 = "DELETE " }
 否则 如果 (req.方法 == HTTP_HEAD) { 报文 = "HEAD " }
 否则 { 报文 = "GET " }

 报文 = 字符串_连接(报文, url.路径)
 如果 (url.查询长度 > 0) {
 报文 = 字符串_连接(报文, "?")
 报文 = 字符串_连接(报文, url.查询)
 }
 报文 = 字符串_连接(报文, " HTTP/1.1\r\n")

 // Host头
 报文 = 字符串_连接(报文, "Host: ")
 报文 = 字符串_连接(报文, url.主机)
 报文 = 字符串_连接(报文, "\r\n")

 // 其他请求头
 定义 头 = req.请求头
 定义 可变 i = 0
 当 (i < 头.数量) {
 定义 偏移 = 头.条目 + i * 32
 定义 名 = 内存_读64(偏移)
 定义 值 = 内存_读64(偏移 + 16)
 报文 = 字符串_连接(报文, 名)
 报文 = 字符串_连接(报文, ": ")
 报文 = 字符串_连接(报文, 值)
 报文 = 字符串_连接(报文, "\r\n")
 i = i + 1
 }

 // Content-Length (POST/PUT)
 如果 (req.请求体 != 0 && req.请求体长度 > 0) {
 报文 = 字符串_连接(报文, "Content-Length: ")
 报文 = 字符串_连接(报文, 整数转字符串(req.请求体长度))
 报文 = 字符串_连接(报文, "\r\n")
 }

 // 空行(头部结束)
 报文 = 字符串_连接(报文, "\r\n")

 // 请求体
 如果 (req.请求体 != 0 && req.请求体长度 > 0) {
 报文 = 字符串_连接(报文, req.请求体)
 }

 返回 报文
}

函数 HTTP_解析响应头(数据, 数据长度, resp) {
 // 解析 "HTTP/1.1 200 OK\r\n..." 格式的响应头
 定义 可变 pos = 0

 // 跳过 "HTTP/1.x "
 当 (pos < 数据长度 && 内存_读8(数据 + pos) != 0x20) { pos = pos + 1 }
 pos = pos + 1

 // 读状态码
 resp.状态码 = 0
 当 (pos < 数据长度 && 内存_读8(数据 + pos) >= 0x30 && 内存_读8(数据 + pos) <= 0x39) {
 resp.状态码 = resp.状态码 * 10 + (内存_读8(数据 + pos) - 0x30)
 pos = pos + 1
 }

 // 跳到行尾
 当 (pos < 数据长度 - 1) {
 如果 (内存_读8(数据 + pos) == 0x0D && 内存_读8(数据 + pos + 1) == 0x0A) {
 pos = pos + 2
 跳出
 }
 pos = pos + 1
 }

 // 解析头字段
 当 (pos < 数据长度 - 1) {
 // 检查空行(头部结束)
 如果 (内存_读8(数据 + pos) == 0x0D && 内存_读8(数据 + pos + 1) == 0x0A) {
 pos = pos + 2
 跳出
 }

 // 读头名(到':')
 定义 名开始 = pos
 当 (pos < 数据长度 && 内存_读8(数据 + pos) != 0x3A) { pos = pos + 1 }
 定义 名 = 字符串_复制_N(数据 + 名开始, pos - 名开始)
 pos = pos + 1
 // 跳空白
 当 (pos < 数据长度 && 内存_读8(数据 + pos) == 0x20) { pos = pos + 1 }

 // 读头值(到\r\n)
 定义 值开始 = pos
 当 (pos < 数据长度 - 1) {
 如果 (内存_读8(数据 + pos) == 0x0D && 内存_读8(数据 + pos + 1) == 0x0A) { 跳出 }
 pos = pos + 1
 }
 定义 值 = 字符串_复制_N(数据 + 值开始, pos - 值开始)
 pos = pos + 2

 HTTP头部_添加(resp.响应头, 名, 值)

 // 提取重要头
 如果 (字符串_相等_不区分大小写(名, "Content-Type")) {
 resp.内容类型 = 值
 }
 如果 (字符串_相等_不区分大小写(名, "Content-Length")) {
 resp.内容长度 = 字符串转整数(值)
 }
 }

 返回 pos // 返回body开始位置
}

定义 可变 AI_资源响应创_带宽估计 = 0
定义 可变 AI_资源响应创_丢包窗口 = []

函数 AI_资源响应创_带宽预测(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 AI_资源响应创_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    AI_资源响应创_带宽估计 = AI_资源响应创_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 AI_资源响应创_带宽估计
}

函数 AI_资源响应创_拥塞建议(丢包率) {
    追加(AI_资源响应创_丢包窗口, 丢包率)
    如果 (计数(AI_资源响应创_丢包窗口) > 10) { 列表_移除(AI_资源响应创_丢包窗口, 0) }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}

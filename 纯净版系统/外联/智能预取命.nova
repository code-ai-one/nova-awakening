导入("../中枢/整数转字符串.nova")

定义 预取状态_等待 = 0
定义 预取状态_加载中 = 1
定义 预取状态_完成 = 2
定义 预取状态_失败 = 3
定义 预取状态_过期 = 4

定义 预取类型_文档 = 0
定义 预取类型_脚本 = 1
定义 预取类型_样式 = 2
定义 预取类型_图片 = 3
定义 预取类型_字体 = 4
定义 预取类型_API = 5

定义 预取_条目大小 = 48
定义 预取_置信度衰减 = 5
定义 预取_老化超时 = 60000
定义 预取_最小置信度 = 200

结构 预取统计 {
    总预取次数,
    总命中次数,
    总未命中次数,
    总过期次数,
    总节省延迟,
    按类型命中,
    按类型预取,
    当前队列长度,
    峰值队列长度,
}

函数 AI预取_命中(引擎, url哈希) {
    如果 (引擎 == 0) { 返回 假 }

    定义 现在 = 平台_获取高精度时间()
    定义 可变 i = 0
    当 (i < 引擎.预取数量) {
        定义 偏移 = 引擎.预取列表 + i * 预取_条目大小
        定义 条目哈希 = 内存_读32(偏移 + 8)
        定义 条目状态 = 内存_读32(偏移 + 20)

        如果 (条目哈希 == url哈希 && 条目状态 == 预取状态_完成) {
            定义 创建时间 = 内存_读64(偏移 + 32)
            如果 ((现在 - 创建时间) > 预取_老化超时) {
                内存_写32(偏移 + 20, 预取状态_过期)
                引擎.总过期次数 = 引擎.总过期次数 + 1
                i = i + 1
                继续
            }

            引擎.总命中次数 = 引擎.总命中次数 + 1
            如果 (引擎.总预取次数 > 0) {
                引擎.预取命中率 = 引擎.总命中次数 * 10000 / 引擎.总预取次数
            }

            定义 延迟节省 = 现在 - 创建时间
            引擎.总节省延迟 = 引擎.总节省延迟 + 延迟节省
            内存_写64(偏移 + 40, 现在)

            定义 类型 = 内存_读32(偏移 + 12)
            AI预取_更新类型统计(引擎, 类型, 真)

            定义 置信度 = 内存_读32(偏移 + 16)
            AI预取_提升置信度(引擎, url哈希, 置信度 + 100)

            返回 真
        }
        i = i + 1
    }

    引擎.总未命中次数 = 引擎.总未命中次数 + 1
    返回 假
}

函数 AI预取_已存在(引擎, url哈希) {
    定义 可变 i = 0
    当 (i < 引擎.预取数量) {
        如果 (内存_读32(引擎.预取列表 + i * 预取_条目大小 + 8) == url哈希) {
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 AI预取_查找(引擎, url哈希) {
    定义 可变 i = 0
    当 (i < 引擎.预取数量) {
        定义 偏移 = 引擎.预取列表 + i * 预取_条目大小
        如果 (内存_读32(偏移 + 8) == url哈希) { 返回 偏移 }
        i = i + 1
    }
    返回 0
}

函数 AI预取_添加(引擎, url, url哈希, 类型, 置信度, 优先级) {
    如果 (置信度 < 预取_最小置信度) { 返回 }
    如果 (AI预取_已存在(引擎, url哈希)) { 返回 }

    如果 (引擎.预取数量 >= 引擎.预取容量) {
        AI预取_淘汰最旧(引擎)
    }

    如果 (引擎.预取数量 >= 引擎.预取容量) { 返回 }

    定义 偏移 = 引擎.预取列表 + 引擎.预取数量 * 预取_条目大小
    内存_写64(偏移, url)
    内存_写32(偏移 + 8, url哈希)
    内存_写32(偏移 + 12, 类型)
    内存_写32(偏移 + 16, 置信度)
    内存_写32(偏移 + 20, 预取状态_等待)
    内存_写32(偏移 + 24, AI预取_类型权重(类型) + 优先级)
    内存_写64(偏移 + 32, 平台_获取高精度时间())
    内存_写64(偏移 + 40, 0)

    引擎.预取数量 = 引擎.预取数量 + 1
    引擎.总预取次数 = 引擎.总预取次数 + 1

    如果 (引擎.预取数量 > 引擎.峰值队列长度) {
        引擎.峰值队列长度 = 引擎.预取数量
    }

    AI预取_更新类型统计(引擎, 类型, 假)
}

函数 AI预取_类型权重(类型) {
    如果 (类型 == 预取类型_文档) { 返回 256 }
    如果 (类型 == 预取类型_脚本) { 返回 192 }
    如果 (类型 == 预取类型_样式) { 返回 224 }
    如果 (类型 == 预取类型_字体) { 返回 160 }
    如果 (类型 == 预取类型_图片) { 返回 64 }
    如果 (类型 == 预取类型_API) { 返回 128 }
    返回 32
}

函数 AI预取_淘汰最旧(引擎) {
    如果 (引擎.预取数量 == 0) { 返回 }

    定义 可变 最旧索引 = -1
    定义 可变 最旧时间 = 0x7FFFFFFFFFFFFFFF
    定义 可变 最低优先级 = 0x7FFFFFFF

    定义 可变 i = 0
    当 (i < 引擎.预取数量) {
        定义 偏移 = 引擎.预取列表 + i * 预取_条目大小
        定义 状态 = 内存_读32(偏移 + 20)

        如果 (状态 == 预取状态_过期 || 状态 == 预取状态_失败) {
            AI预取_移除索引(引擎, i)
            返回
        }

        如果 (状态 == 预取状态_完成) {
            定义 时间 = 内存_读64(偏移 + 32)
            定义 优先级 = 内存_读32(偏移 + 24)
            如果 (优先级 < 最低优先级 || (优先级 == 最低优先级 && 时间 < 最旧时间)) {
                最旧索引 = i
                最旧时间 = 时间
                最低优先级 = 优先级
            }
        }
        i = i + 1
    }

    如果 (最旧索引 >= 0) {
        AI预取_移除索引(引擎, 最旧索引)
    }
}

函数 AI预取_移除索引(引擎, 索引) {
    如果 (索引 < 0 || 索引 >= 引擎.预取数量) { 返回 }

    定义 目标 = 引擎.预取列表 + 索引 * 预取_条目大小
    定义 最后 = 引擎.预取列表 + (引擎.预取数量 - 1) * 预取_条目大小

    如果 (索引 < 引擎.预取数量 - 1) {
        内存_拷贝(目标, 最后, 预取_条目大小)
    }
    引擎.预取数量 = 引擎.预取数量 - 1
}

函数 AI预取_老化清理(引擎) {
    如果 (引擎 == 0) { 返回 }
    定义 现在 = 平台_获取高精度时间()

    定义 可变 i = 0
    当 (i < 引擎.预取数量) {
        定义 偏移 = 引擎.预取列表 + i * 预取_条目大小
        定义 创建时间 = 内存_读64(偏移 + 32)
        定义 状态 = 内存_读32(偏移 + 20)

        如果 ((现在 - 创建时间) > 预取_老化超时 * 2) {
            AI预取_移除索引(引擎, i)
            引擎.总过期次数 = 引擎.总过期次数 + 1
        } 否则 如果 ((现在 - 创建时间) > 预取_老化超时 && 状态 == 预取状态_完成) {
            内存_写32(偏移 + 20, 预取状态_过期)
            引擎.总过期次数 = 引擎.总过期次数 + 1
            i = i + 1
        } 否则 {
            如果 (状态 == 预取状态_完成) {
                定义 置信度 = 内存_读32(偏移 + 16)
                如果 (置信度 > 预取_置信度衰减) {
                    内存_写32(偏移 + 16, 置信度 - 预取_置信度衰减)
                }
            }
            i = i + 1
        }
    }
}

函数 AI预取_提升置信度(引擎, url哈希, 新置信度) {
    定义 偏移 = AI预取_查找(引擎, url哈希)
    如果 (偏移 != 0) {
        如果 (新置信度 > 10000) { 新置信度 = 10000 }
        内存_写32(偏移 + 16, 新置信度)
    }
}

函数 AI预取_更新类型统计(引擎, 类型, 是命中) {
    如果 (引擎.类型统计 == 空) { 返回 }
    如果 (类型 < 0 || 类型 > 5) { 返回 }
    如果 (是命中) {
        内存_写32(引擎.类型统计 + 类型 * 8, 内存_读32(引擎.类型统计 + 类型 * 8) + 1)
    } 否则 {
        内存_写32(引擎.类型统计 + 类型 * 8 + 4, 内存_读32(引擎.类型统计 + 类型 * 8 + 4) + 1)
    }
}

函数 AI预取_最大并发(引擎) {
    定义 基础并发 = 4
    如果 (引擎.预取命中率 > 7000) { 返回 基础并发 + 4 }
    如果 (引擎.预取命中率 > 5000) { 返回 基础并发 + 2 }
    如果 (引擎.预取命中率 < 2000) { 返回 基础并发 - 2 }
    返回 基础并发
}

函数 AI预取_执行队列(引擎, session) {
    如果 (引擎 == 0 || session == 0) { 返回 }

    AI预取_按优先级排序(引擎)

    定义 最大并发 = AI预取_最大并发(引擎)
    定义 可变 当前并发 = 0

    定义 可变 i = 0
    当 (i < 引擎.预取数量 && 当前并发 < 最大并发) {
        定义 偏移 = 引擎.预取列表 + i * 预取_条目大小
        定义 状态 = 内存_读32(偏移 + 20)
        如果 (状态 == 预取状态_等待) {
            定义 置信度 = 内存_读32(偏移 + 16)
            如果 (置信度 < 预取_最小置信度) {
                i = i + 1
                继续
            }

            定义 url = 内存_读64(偏移)
            定义 优先级 = 内存_读32(偏移 + 24)
            H2Session_发起请求(session, url, 优先级)
            内存_写32(偏移 + 20, 预取状态_加载中)
            当前并发 = 当前并发 + 1
        }
        i = i + 1
    }
}

函数 AI预取_按优先级排序(引擎) {
    定义 n = 引擎.预取数量
    定义 可变 i = 0
    当 (i < n - 1) {
        定义 可变 j = 0
        当 (j < n - 1 - i) {
            定义 a优先级 = 内存_读32(引擎.预取列表 + j * 预取_条目大小 + 24)
            定义 b优先级 = 内存_读32(引擎.预取列表 + (j + 1) * 预取_条目大小 + 24)
            如果 (a优先级 < b优先级) {
                AI预取_交换条目(引擎, j, j + 1)
            }
            j = j + 1
        }
        i = i + 1
    }
}

函数 AI预取_交换条目(引擎, 索引a, 索引b) {
    定义 临时 = 堆_分配(预取_条目大小)
    定义 a偏移 = 引擎.预取列表 + 索引a * 预取_条目大小
    定义 b偏移 = 引擎.预取列表 + 索引b * 预取_条目大小
    内存_拷贝(临时, a偏移, 预取_条目大小)
    内存_拷贝(a偏移, b偏移, 预取_条目大小)
    内存_拷贝(b偏移, 临时, 预取_条目大小)
    堆_释放(临时)
}

函数 AI预取_完成通知(引擎, url哈希, 成功) {
    定义 偏移 = AI预取_查找(引擎, url哈希)
    如果 (偏移 == 0) { 返回 }

    如果 (成功) {
        内存_写32(偏移 + 20, 预取状态_完成)
    } 否则 {
        内存_写32(偏移 + 20, 预取状态_失败)
        定义 置信度 = 内存_读32(偏移 + 16)
        如果 (置信度 > 200) {
            内存_写32(偏移 + 16, 置信度 - 200)
        } 否则 {
            内存_写32(偏移 + 16, 0)
        }
    }
}

函数 AI预取_统计打印(引擎) {
    如果 (引擎 == 0) { 返回 }
    打印行("=== AI预取统计 ===")
    打印行("总预取: " + 整数转字符串(引擎.总预取次数))
    打印行("总命中: " + 整数转字符串(引擎.总命中次数))
    打印行("总未命中: " + 整数转字符串(引擎.总未命中次数))
    打印行("总过期: " + 整数转字符串(引擎.总过期次数))
    打印行("命中率: " + 整数转字符串(引擎.预取命中率 / 100) + "."
        + 整数转字符串(引擎.预取命中率 % 100) + "%")
    打印行("队列长度: " + 整数转字符串(引擎.预取数量)
        + " (峰值: " + 整数转字符串(引擎.峰值队列长度) + ")")

    如果 (引擎.总命中次数 > 0) {
        打印行("平均节省延迟: "
            + 整数转字符串(引擎.总节省延迟 / 引擎.总命中次数) + "ms")
    }
}

函数 H2Session_发起请求(session, url, 优先级) {
    定义 stream = H2Session_创建流(session)
    如果 (stream == 0) { 返回 }
    stream.权重 = 优先级
    stream.是预取 = 真
}

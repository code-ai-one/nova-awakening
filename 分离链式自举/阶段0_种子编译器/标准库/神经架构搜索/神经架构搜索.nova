导入("../基础.nova")


定义 NAS_随机态 = 99999
函数 NAS_随机() {
    NAS_随机态 = NAS_随机态 ^ (NAS_随机态 << 13)
    NAS_随机态 = NAS_随机态 ^ (NAS_随机态 >> 7)
    NAS_随机态 = NAS_随机态 ^ (NAS_随机态 << 17)
    如果 (NAS_随机态 < 0) { NAS_随机态 = 0 - NAS_随机态 }
    返回 NAS_随机态
}

// 搜索空间
// 操作类型
定义 指令_NONE = 0
定义 指令_SKIP = 1      // 跳跃连接
定义 指令_CONV3 = 2     // 3×3卷积
定义 指令_CONV5 = 3     // 5×5卷积
定义 指令_POOL3 = 4     // 3×3最大池化
定义 指令_POOL5 = 5     // 5×5平均池化
定义 指令_SEP3 = 6      // 3×3深度可分离卷积
定义 指令_SEP5 = 7      // 5×5深度可分离卷积
定义 指令_DIL3 = 8      // 3×3膨胀卷积
定义 指令_ATTN = 9      // 自注意力
定义 指令_FFN = 10       // 前馈网络
定义 指令_TOTAL = 11

// 搜索空间: [操作列表, 节点数, 边数]
函数 搜索空间_创建(节点数) {
    定义 边数 = 节点数 * (节点数 - 1) / 2
    定义 可变 操作 = []
    定义 可变 i = 0
    当 (i < 边数) {
        追加(操作, 指令_CONV3)  // 默认3×3卷积
        i = i + 1
    }
    返回 [操作, 节点数, 边数]
}

// 架构编码
// 整数编码: 每条边一个操作类型
函数 架构_编码(操作列表) {
    返回 操作列表
}

函数 架构_随机生成(搜索空间) {
    定义 边数 = 搜索空间[2]
    定义 可变 架构 = []
    定义 可变 i = 0
    当 (i < 边数) {
        追加(架构, NAS_随机() % 指令_TOTAL)
        i = i + 1
    }
    返回 架构
}

// DARTS: 可微架构搜索
// α参数: 每条边对每种操作的权重
函数 DARTS_α初始化(边数) {
    定义 可变 α = []
    定义 可变 i = 0
    当 (i < 边数) {
        定义 可变 边α = []
        定义 可变 j = 0
        当 (j < 指令_TOTAL) {
            追加(边α, 1000 / 指令_TOTAL)  // 均匀初始化
            j = j + 1
        }
        追加(α, 边α)
        i = i + 1
    }
    返回 α
}

函数 DARTS_归一化(α_边) {
    定义 可变 指数组 = []
    定义 n = 计数(α_边)
    定义 可变 max_v = α_边[0]
    定义 可变 i = 1
    当 (i < n) { 如果 (α_边[i] > max_v) { max_v = α_边[i] }
    i = i + 1 }
    定义 可变 总 = 0
    i = 0
    当 (i < n) {
        定义 可变 e = 1000 + (α_边[i] - max_v)
        如果 (e < 1) { e = 1 }
        追加(指数组, e)
        总 = 总 + e
        i = i + 1
    }
    如果 (总 == 0) { 总 = 1 }
    定义 可变 概率 = []
    i = 0
    当 (i < n) { 追加(概率, 指数组[i] * 1000 / 总)
    i = i + 1 }
    返回 概率
}

函数 DARTS_离散化(α) {
    // 每条边选概率最大的操作
    定义 边数 = 计数(α)
    定义 可变 架构 = []
    定义 可变 i = 0
    当 (i < 边数) {
        定义 概率 = DARTS_归一化(α[i])
        定义 可变 最佳 = 0
        定义 可变 最佳值 = 概率[0]
        定义 可变 j = 1
        当 (j < 计数(概率)) {
            如果 (概率[j] > 最佳值) { 最佳 = j
            最佳值 = 概率[j] }
            j = j + 1
        }
        追加(架构, 最佳)
        i = i + 1
    }
    返回 架构
}

// 进化搜索
函数 NAS_变异(架构, 变异率) {
    定义 n = 计数(架构)
    定义 可变 新架构 = []
    定义 可变 i = 0
    当 (i < n) {
        如果 (NAS_随机() % 1000 < 变异率) {
            追加(新架构, NAS_随机() % 指令_TOTAL)
        } 否则 {
            追加(新架构, 架构[i])
        }
        i = i + 1
    }
    返回 新架构
}

函数 NAS_交叉(父1, 父2) {
    定义 n = 计数(父1)
    定义 交叉点 = NAS_随机() % n
    定义 可变 子代 = []
    定义 可变 i = 0
    当 (i < n) {
        如果 (i < 交叉点) { 追加(子代, 父1[i]) }
        否则 { 如果 (i < 计数(父2)) { 追加(子代, 父2[i]) } 否则 { 追加(子代, 父1[i]) } }
        i = i + 1
    }
    返回 子代
}

函数 NAS_锦标赛选择(种群, 适应度, 锦标赛大小) {
    定义 n = 计数(种群)
    定义 可变 最佳 = NAS_随机() % n
    定义 可变 i = 1
    当 (i < 锦标赛大小) {
        定义 候选 = NAS_随机() % n
        如果 (适应度[候选] > 适应度[最佳]) { 最佳 = 候选 }
        i = i + 1
    }
    返回 最佳
}

函数 NAS_进化(种群大小, _边数, _代数, 评估函数结果列表) {
    // 初始化种群
    定义 可变 种群 = []
    定义 可变 适应度 = []
    定义 搜索空间 = 搜索空间_创建(4)
    定义 可变 i = 0
    当 (i < 种群大小) {
        追加(种群, 架构_随机生成(搜索空间))
        追加(适应度, 0)
        i = i + 1
    }
    // 进化循环 (外部提供评估结果)
    如果 (计数(评估函数结果列表) > 0) {
        i = 0
        当 (i < 种群大小 且 i < 计数(评估函数结果列表)) {
            适应度[i] = 评估函数结果列表[i]
            i = i + 1
        }
    }
    返回 [种群, 适应度]
}

// 性能预测器
函数 NAS_预测_FLOPs(架构, 输入维度, 通道数) {
    定义 可变 总FLOPs = 0
    定义 可变 i = 0
    当 (i < 计数(架构)) {
        定义 op = 架构[i]
        定义 可变 flops = 0
        如果 (op == 指令_CONV3) { flops = 输入维度 * 输入维度 * 通道数 * 通道数 * 9 }
        如果 (op == 指令_CONV5) { flops = 输入维度 * 输入维度 * 通道数 * 通道数 * 25 }
        如果 (op == 指令_SEP3) { flops = 输入维度 * 输入维度 * 通道数 * 9 + 输入维度 * 输入维度 * 通道数 * 通道数 }
        如果 (op == 指令_ATTN) { flops = 输入维度 * 输入维度 * 通道数 * 3 }
        如果 (op == 指令_SKIP) { flops = 0 }
        如果 (op == 指令_FFN) { flops = 通道数 * 通道数 * 4 }
        总FLOPs = 总FLOPs + flops
        i = i + 1
    }
    返回 总FLOPs
}

// 多目标优化: Pareto前沿
函数 NAS_Pareto支配(a精度, a_FLOPs, b精度, b_FLOPs) {
    // a支配b: a精度>=b精度 且 a_FLOPs<=b_FLOPs, 至少一个严格
    返回 (a精度 >= b精度 且 a_FLOPs <= b_FLOPs) 且 (a精度 > b精度 或 a_FLOPs < b_FLOPs)
}

函数 NAS_Pareto前沿(精度列表, FLOPs列表) {
    定义 n = 计数(精度列表)
    定义 可变 前沿 = []
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 被支配 = 0
        定义 可变 j = 0
        当 (j < n) {
            如果 (j != i 且 NAS_Pareto支配(精度列表[j], FLOPs列表[j], 精度列表[i], FLOPs列表[i])) {
                被支配 = 1
            }
            j = j + 1
        }
        如果 (被支配 == 0) { 追加(前沿, i) }
        i = i + 1
    }
    返回 前沿
}

// 超参搜索
函数 超参_随机搜索(范围列表, 试验数) {
    定义 维度 = 计数(范围列表)
    定义 可变 结果 = []
    定义 可变 t = 0
    当 (t < 试验数) {
        定义 可变 配置 = []
        定义 可变 d = 0
        当 (d < 维度) {
            定义 最小 = 范围列表[d][0]
            定义 最大 = 范围列表[d][1]
            定义 值 = 最小 + NAS_随机() % (最大 - 最小 + 1)
            追加(配置, 值)
            d = d + 1
        }
        追加(结果, 配置)
        t = t + 1
    }
    返回 结果
}

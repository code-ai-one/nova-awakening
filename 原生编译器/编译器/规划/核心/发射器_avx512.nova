// vpermps zmm, zmm, zmm
函数 发射_avx512_排列ps(d, ctl, s) {
    发射_evex(1,  1,  1,  1,  2,  0,  ctl,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0x16) 发射(0xC0 + (d & 7) * 8 + (s & 7))
}

导入("./平台时间.nova")
导入("../中枢/内存初始化.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/辅助存根.nova")
导入("../中枢/字符串替换.nova")

    句柄:           u64,       // 内核窗口句柄

    x:              i32,
    y:              i32,
    宽:             i32,
    高:             i32,
    标题:           u64,
    标志:           u32,
    是可见的:       布尔,

    帧缓冲:         u64,       // 像素缓冲区(BGRA8888)
    帧缓冲大小:     u32,
    帧缓冲行字节:   u32,

    后缓冲:         u64,       // 后台缓冲(绘制到此)
    前缓冲:         u64,       // 前台缓冲(显示此)

    图处缓冲句柄:    u64,       // 图处缓冲区(硬件加速时)
    是图处加速:      布尔,

    事件队列:       u64,       // Platform事件*数组
    事件数量:       u32,
    事件容量:       u32,

    绘制回调:       u64,       // 函数指针: 窗口需要重绘
    大小改变回调:   u64,       // 函数指针: 窗口大小变化
    关闭回调:       u64,       // 函数指针: 窗口关闭

    设备像素比:     i32,       // ×100 (100=1x, 200=2x Retina)

    当前光标:       u32
}

函数 PlatformWindow_创建(标题, 宽, 高) {
    定义 win = 堆_分配(PlatformWindow)

    // 创建窗口(内核Nova系统调用)
    win.句柄 = 系统调用(Nova系统调用_图形_创建窗口, 宽, 高, 窗口标志_可调大小 | 窗口标志_有标题栏 | 窗口标志_有边框, 0, 0)
    如果 (win.句柄 == 0) { 返回 0 }

    win.x = 0; win.y = 0
    win.宽 = 宽; win.高 = 高
    win.标题 = 字符串_复制(标题)
    win.标志 = 窗口标志_可调大小 | 窗口标志_有标题栏 | 窗口标志_有边框
    win.是可见的 = 真

    // 设置标题
    系统调用(Nova系统调用_图形_设置窗口标题, win.句柄, 标题, 字符串_长度(标题), 0, 0)

    // 获取帧缓冲
    win.帧缓冲行字节 = 宽 * 4    // BGRA8888
    win.帧缓冲大小 = win.帧缓冲行字节 * 高
    win.帧缓冲 = 系统调用(Nova系统调用_图形_获取帧缓冲, win.句柄, 0, 0, 0, 0)

    // 双缓冲: 分配后缓冲
    win.后缓冲 = 堆_分配(win.帧缓冲大小)
    win.前缓冲 = win.帧缓冲

    // 图处加速检测
    win.图处缓冲句柄 = 0
    win.是图处加速 = 假
    // 尝试创建图处缓冲
    定义 gpu = 系统调用(Nova系统调用_图形_创建图处缓冲, win.句柄, 宽, 高, 0, 0)
    如果 (gpu != 0) {
        win.图处缓冲句柄 = gpu
        win.是图处加速 = 真
    }

    // 事件队列
    win.事件容量 = 64
    win.事件队列 = 堆_分配_数组(win.事件容量 * 64)
    win.事件数量 = 0

    // 默认DPI
    win.设备像素比 = 100

    // 获取屏幕DPI
    定义 屏幕信息 = 系统调用(Nova系统调用_图形_获取屏幕信息, 0, 0, 0, 0, 0)
    如果 (屏幕信息 != 0) {
        // 从屏幕信息中提取DPI
        定义 dpi = 内存_读32(屏幕信息 + 8)
        如果 (dpi > 0) {
            win.设备像素比 = dpi * 100 / 96
        }
    }

    win.当前光标 = 光标_箭头
    win.绘制回调 = 0
    win.大小改变回调 = 0
    win.关闭回调 = 0

    返回 win
}

函数 PlatformWindow_提交帧(win) {
    // 将后缓冲提交到显示器
    如果 (win.是图处加速) {
        // 图处路径: 提交图处命令缓冲
        系统调用(Nova系统调用_图形_图处提交命令, win.图处缓冲句柄, 0, 0, 0, 0)
    } 否则 {
        // 软件路径: 复制后缓冲到帧缓冲
        内存_复制(win.前缓冲, win.后缓冲, win.帧缓冲大小)
        系统调用(Nova系统调用_图形_提交帧, win.句柄, 0, 0, 0, 0)
    }
}

函数 PlatformWindow_轮询事件(win) {
    // 从内核获取待处理的输入事件
    win.事件数量 = 0
    定义 事件缓冲 = 堆_分配_数组(32 * 64)
    定义 事件数 = 系统调用(Nova系统调用_输入_轮询事件, win.句柄, 事件缓冲, 32, 0, 0)
    如果 (事件数 > 0) {
        内存_复制(win.事件队列, 事件缓冲, 事件数 * 64)
        win.事件数量 = 事件数
    }
    堆_释放(事件缓冲)
    返回 win.事件数量
}

函数 PlatformWindow_获取事件(win, 索引) {
    如果 (索引 >= win.事件数量) { 返回 0 }
    返回 win.事件队列 + 索引 * 64
}

函数 PlatformWindow_设置光标(win, 光标类型) {
    如果 (win.当前光标 == 光标类型) { 返回 }
    win.当前光标 = 光标类型
    系统调用(Nova系统调用_图形_设置光标, win.句柄, 光标类型, 0, 0, 0)
}

函数 PlatformWindow_设置大小(win, 新宽, 新高) {
    win.宽 = 新宽; win.高 = 新高
    系统调用(Nova系统调用_图形_设置窗口大小, win.句柄, 新宽, 新高, 0, 0)

    // 重新获取帧缓冲
    win.帧缓冲行字节 = 新宽 * 4
    win.帧缓冲大小 = win.帧缓冲行字节 * 新高
    win.帧缓冲 = 系统调用(Nova系统调用_图形_获取帧缓冲, win.句柄, 0, 0, 0, 0)
    win.前缓冲 = win.帧缓冲

    堆_释放(win.后缓冲)
    win.后缓冲 = 堆_分配(win.帧缓冲大小)
}

函数 PlatformWindow_销毁(win) {
    如果 (win.图处缓冲句柄 != 0) {
        // 释放图处资源
    }
    堆_释放(win.后缓冲)
    堆_释放(win.事件队列)
    系统调用(Nova系统调用_图形_销毁窗口, win.句柄, 0, 0, 0, 0)
    堆_释放(win)

定义 可变 AI_窗口创建_事件频率 = 0
定义 可变 AI_窗口创建_节流阈值 = 16

函数 AI_窗口创建_节流判断(事件类型, 间隔毫秒) {
    AI_窗口创建_事件频率 = AI_窗口创建_事件频率 + 1
    如果 (事件类型 == "滚动" && 间隔毫秒 < AI_窗口创建_节流阈值) { 返回 真 }
    如果 (事件类型 == "移动" && 间隔毫秒 < AI_窗口创建_节流阈值) { 返回 真 }
    返回 假
}

函数 AI_窗口创建_优先级排序(事件类型) {
    如果 (事件类型 == "点击") { 返回 100 }
    如果 (事件类型 == "输入") { 返回 90 }
    如果 (事件类型 == "滚动") { 返回 30 }
    返回 50
}

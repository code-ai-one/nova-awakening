导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./标记令牌乙.nova")
导入("./样式解析.nova")
导入("./各状态处理.nova")

// §2 核心: 状态机驱动 — 逐字符消费产生令牌
// (对应 HTML令牌izer::Next令牌)
// 这是整个HTML解析器的心脏

函数 HTML令牌izer_下一个令牌(tk, 令牌) {
 // 返回: 1=产生了令牌, 0=需要更多输入, -1=EOF
 HTML令牌_重置(令牌)
 tk.当前令牌 = 令牌

 当 (tk.位置 < tk.输入长度) {
 定义 c = HTML令牌izer_消费字符(tk)

 如果 (tk.状态 == 状态_数据) {
 HTML令牌izer_处理_数据状态(tk, 令牌, c)
 如果 (令牌.类型 != 令牌类型_未初始化) {
 tk.总令牌数 = tk.总令牌数 + 1
 返回 1
 }
 }
 否则 如果 (tk.状态 == 状态_标签开始) {
 HTML令牌izer_处理_标签开始(tk, 令牌, c)
 }
 否则 如果 (tk.状态 == 状态_结束标签开始) {
 HTML令牌izer_处理_结束标签开始(tk, 令牌, c)
 }
 否则 如果 (tk.状态 == 状态_标签名) {
 HTML令牌izer_处理_标签名(tk, 令牌, c)
 如果 (令牌.类型 != 令牌类型_未初始化) {
 tk.总令牌数 = tk.总令牌数 + 1
 返回 1
 }
 }
 否则 如果 (tk.状态 == 状态_属性名前) {
 HTML令牌izer_处理_属性名前(tk, 令牌, c)
 如果 (令牌.类型 != 令牌类型_未初始化) {
 tk.总令牌数 = tk.总令牌数 + 1
 返回 1
 }
 }
 否则 如果 (tk.状态 == 状态_属性名) {
 HTML令牌izer_处理_属性名(tk, 令牌, c)
 }
 否则 如果 (tk.状态 == 状态_属性名后) {
 HTML令牌izer_处理_属性名后(tk, 令牌, c)
 }
 否则 如果 (tk.状态 == 状态_属性值前) {
 HTML令牌izer_处理_属性值前(tk, 令牌, c)
 }
 否则 如果 (tk.状态 == 状态_属性值_双引号) {
 HTML令牌izer_处理_属性值双引号(tk, 令牌, c)
 }
 否则 如果 (tk.状态 == 状态_属性值_单引号) {
 HTML令牌izer_处理_属性值单引号(tk, 令牌, c)
 }
 否则 如果 (tk.状态 == 状态_属性值_无引号) {
 HTML令牌izer_处理_属性值无引号(tk, 令牌, c)
 如果 (令牌.类型 != 令牌类型_未初始化) {
 tk.总令牌数 = tk.总令牌数 + 1
 返回 1
 }
 }
 否则 如果 (tk.状态 == 状态_属性值后) {
 HTML令牌izer_处理_属性值后(tk, 令牌, c)
 如果 (令牌.类型 != 令牌类型_未初始化) {
 tk.总令牌数 = tk.总令牌数 + 1
 返回 1
 }
 }
 否则 如果 (tk.状态 == 状态_自闭合开始标签) {
 HTML令牌izer_处理_自闭合(tk, 令牌, c)
 如果 (令牌.类型 != 令牌类型_未初始化) {
 tk.总令牌数 = tk.总令牌数 + 1
 返回 1
 }
 }
 否则 如果 (tk.状态 == 状态_标记声明开始) {
 HTML令牌izer_处理_标记声明开始(tk, 令牌, c)
 }
 否则 如果 (tk.状态 == 状态_注释开始) {
 HTML令牌izer_处理_注释开始(tk, 令牌, c)
 }
 否则 如果 (tk.状态 == 状态_注释) {
 HTML令牌izer_处理_注释(tk, 令牌, c)
 如果 (令牌.类型 != 令牌类型_未初始化) {
 tk.总令牌数 = tk.总令牌数 + 1
 返回 1
 }
 }
 否则 如果 (tk.状态 == 状态_注释结束破折号) {
 HTML令牌izer_处理_注释结束破折号(tk, 令牌, c)
 }
 否则 如果 (tk.状态 == 状态_注释结束) {
 HTML令牌izer_处理_注释结束(tk, 令牌, c)
 如果 (令牌.类型 != 令牌类型_未初始化) {
 tk.总令牌数 = tk.总令牌数 + 1
 返回 1
 }
 }
 否则 如果 (tk.状态 == 状态_DOCTYPE) {
 HTML令牌izer_处理_DOCTYPE(tk, 令牌, c)
 }
 否则 如果 (tk.状态 == 状态_DOCTYPE前) {
 HTML令牌izer_处理_DOCTYPE前(tk, 令牌, c)
 }
 否则 如果 (tk.状态 == 状态_DOCTYPE名称) {
 HTML令牌izer_处理_DOCTYPE名称(tk, 令牌, c)
 如果 (令牌.类型 != 令牌类型_未初始化) {
 tk.总令牌数 = tk.总令牌数 + 1
 返回 1
 }
 }
 否则 如果 (tk.状态 == 状态_RCDATA) {
 HTML令牌izer_处理_RCDATA(tk, 令牌, c)
 如果 (令牌.类型 != 令牌类型_未初始化) {
 tk.总令牌数 = tk.总令牌数 + 1
 返回 1
 }
 }
 否则 如果 (tk.状态 == 状态_RAWTEXT || tk.状态 == 状态_脚本数据) {
 HTML令牌izer_处理_RAWTEXT(tk, 令牌, c)
 如果 (令牌.类型 != 令牌类型_未初始化) {
 tk.总令牌数 = tk.总令牌数 + 1
 返回 1
 }
 }
 }

 // 输入耗尽 → EOF
 令牌.类型 = 令牌类型_文件结束
 tk.总令牌数 = tk.总令牌数 + 1
 返回 -1
}

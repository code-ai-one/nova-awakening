
导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/内核打印.nova")
导入("./原生独创用.nova")
导入("../中枢/整数转字符串.nova")

定义 DOC_POS_DISCONNECTED = 1
定义 DOC_POS_PRECEDING = 2
定义 DOC_POS_FOLLOWING = 4
定义 DOC_POS_CONTAINS = 8
定义 DOC_POS_CONTAINED_BY = 16
定义 DOC_POS_IMPLEMENTATION_SPECIFIC = 32

定义 节点_最大遍历队列 = 1024

结构 节点操作统计 {
    替换次数,
    克隆次数,
    规范化次数,
    遍历次数,
    位置比较次数,
    查找次数,
}

定义 可变 全局_节点操作统计 = 空

函数 节点操作统计_初始化() {
    如果 (全局_节点操作统计 == 空) {
        全局_节点操作统计 = 节点操作统计 {}
        全局_节点操作统计.替换次数 = 0
        全局_节点操作统计.克隆次数 = 0
        全局_节点操作统计.规范化次数 = 0
        全局_节点操作统计.遍历次数 = 0
        全局_节点操作统计.位置比较次数 = 0
        全局_节点操作统计.查找次数 = 0
    }
}

函数 节点_replaceChild(父节点, 新子, 旧子) {
    节点操作统计_初始化()
    全局_节点操作统计.替换次数 = 全局_节点操作统计.替换次数 + 1

    如果 (父节点 == 0 || 新子 == 0 || 旧子 == 0) { 返回 0 }
    如果 (旧子.父节点 != 父节点) { 返回 0 }

    // 不能用自身替换自身
    如果 (新子 == 旧子) { 返回 旧子 }

    // 新子不能是旧子的祖先
    如果 (节点_是祖先(新子, 父节点)) { 返回 0 }

    // 如果新子已有父节点, 先移除
    如果 (新子.父节点 != 0) {
        节点_removeChild(新子.父节点, 新子)
    }

    // 先在旧子位置前插入新子, 再移除旧子
    定义 下一个 = 旧子.后一兄弟
    节点_removeChild(父节点, 旧子)
    如果 (下一个 != 0) {
        节点_insertBefore(父节点, 新子, 下一个)
    } 否则 {
        节点_appendChild(父节点, 新子)
    }

    返回 旧子
}

函数 节点_replaceChildren(父节点, 新子列表, 数量) {
    如果 (父节点 == 0) { 返回 }

    // 移除所有现有子节点
    当 (父节点.第一子节点 != 0) {
        节点_removeChild(父节点, 父节点.第一子节点)
    }

    // 添加新子节点
    定义 可变 i = 0
    当 (i < 数量) {
        如果 (新子列表[i] != 0) {
            节点_appendChild(父节点, 新子列表[i])
        }
        i = i + 1
    }
}

// §3 cloneNode — 节点克隆

函数 节点_cloneNode(节点, 深度克隆) {
    节点操作统计_初始化()
    全局_节点操作统计.克隆次数 = 全局_节点操作统计.克隆次数 + 1

    如果 (节点 == 0) { 返回 0 }

    定义 克隆 = 堆_分配(节点.大小)
    // 复制基本属性
    克隆.节点类型 = 节点.节点类型
    克隆.节点标志 = 节点.节点标志
    克隆.标签名 = 节点.标签名
    克隆.命名空间 = 节点.命名空间
    克隆.语义角色 = 节点.语义角色

    // 克隆不继承父节点和兄弟关系
    克隆.父节点 = 0
    克隆.前一兄弟 = 0
    克隆.后一兄弟 = 0
    克隆.第一子节点 = 0
    克隆.最后子节点 = 0

    // 克隆属性
    如果 (节点.属性列表 != 0) {
        克隆.属性列表 = 节点_克隆属性(节点.属性列表)
    }

    // 深度克隆: 递归克隆子节点
    如果 (深度克隆) {
        定义 可变 子 = 节点.第一子节点
        当 (子 != 0) {
            定义 子克隆 = 节点_cloneNode(子, 真)
            如果 (子克隆 != 0) {
                节点_appendChild(克隆, 子克隆)
            }
            子 = 子.后一兄弟
        }
    }

    返回 克隆
}

函数 节点_克隆属性(属性列表) {
    如果 (属性列表 == 0) { 返回 0 }
    // 深拷贝属性列表
    返回 属性列表
}

// §3.5 normalize — 文本节点规范化

函数 节点_normalize(节点) {
    节点操作统计_初始化()
    全局_节点操作统计.规范化次数 = 全局_节点操作统计.规范化次数 + 1

    如果 (节点 == 0) { 返回 }

    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        定义 下一个 = 子.后一兄弟

        如果 (子.节点类型 == 3) {
            // 文本节点: 移除空文本
            如果 (子.文本内容 == 0 || 字符串长度(子.文本内容) == 0) {
                节点_removeChild(节点, 子)
                子 = 下一个
                继续
            }

            // 合并相邻文本节点
            当 (下一个 != 0 && 下一个.节点类型 == 3) {
                子.文本内容 = 字符串拼接(子.文本内容, 下一个.文本内容)
                定义 再下一个 = 下一个.后一兄弟
                节点_removeChild(节点, 下一个)
                下一个 = 再下一个
            }
        } 否则 {
            // 递归规范化子元素
            节点_normalize(子)
        }

        子 = 下一个
    }
}

// §4 树遍历辅助函数
// (对应 节点Traversal)

函数 节点_是祖先(可能祖先, 节点) {
    如果 (可能祖先 == 0 || 节点 == 0) { 返回 0 }
    定义 可变 当前 = 节点.父节点
    当 (当前 != 0) {
        如果 (当前 == 可能祖先) { 返回 1 }
        当前 = 当前.父节点
    }
    返回 0
}

函数 节点_contains(节点, 其他) {
    如果 (节点 == 0 || 其他 == 0) { 返回 假 }
    如果 (节点 == 其他) { 返回 真 }
    返回 节点_是祖先(节点, 其他) == 1
}

函数 节点_根节点(节点) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 当前 = 节点
    当 (当前.父节点 != 0) {
        当前 = 当前.父节点
    }
    返回 当前
}

函数 节点_深度(节点) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 深度 = 0
    定义 可变 当前 = 节点.父节点
    当 (当前 != 0) {
        深度 = 深度 + 1
        当前 = 当前.父节点
    }
    返回 深度
}

函数 节点_祖先链(节点) {
    定义 可变 链 = []
    定义 可变 当前 = 节点
    当 (当前 != 0) {
        追加(链, 当前)
        当前 = 当前.父节点
    }
    返回 链
}

函数 节点_最近公共祖先(节点A, 节点B) {
    如果 (节点A == 0 || 节点B == 0) { 返回 0 }

    // 先将两个节点对齐到同一深度
    定义 深度A = 节点_深度(节点A)
    定义 深度B = 节点_深度(节点B)
    定义 可变 a = 节点A
    定义 可变 b = 节点B

    当 (深度A > 深度B) {
        a = a.父节点
        深度A = 深度A - 1
    }
    当 (深度B > 深度A) {
        b = b.父节点
        深度B = 深度B - 1
    }

    // 同步上溯
    当 (a != 0 && b != 0) {
        如果 (a == b) { 返回 a }
        a = a.父节点
        b = b.父节点
    }
    返回 0
}

函数 节点_深度优先下一个(节点, 根) {
    如果 (节点 == 0) { 返回 0 }
    如果 (节点.第一子节点 != 0) {
        返回 节点.第一子节点
    }
    定义 可变 当前 = 节点
    当 (当前 != 0) {
        如果 (当前 == 根) { 返回 0 }
        如果 (当前.后一兄弟 != 0) {
            返回 当前.后一兄弟
        }
        当前 = 当前.父节点
    }
    返回 0
}

函数 节点_深度优先前一个(节点, 根) {
    如果 (节点 == 0 || 节点 == 根) { 返回 0 }
    如果 (节点.前一兄弟 != 0) {
        定义 可变 当前 = 节点.前一兄弟
        当 (当前.最后子节点 != 0) {
            当前 = 当前.最后子节点
        }
        返回 当前
    }
    返回 节点.父节点
}

函数 节点_广度优先遍历(根, 回调) {
    节点操作统计_初始化()
    全局_节点操作统计.遍历次数 = 全局_节点操作统计.遍历次数 + 1

    如果 (根 == 0) { 返回 }

    定义 可变 队列 = [根]
    定义 可变 头 = 0
    定义 可变 尾 = 1

    当 (头 < 尾) {
        定义 当前 = 队列[头]
        头 = 头 + 1

        如果 (回调 != 0) {
            // 回调(当前)
        }

        定义 可变 子 = 当前.第一子节点
        当 (子 != 0 && 尾 < 节点_最大遍历队列) {
            追加(队列, 子)
            尾 = 尾 + 1
            子 = 子.后一兄弟
        }
    }
}

函数 节点_下一个兄弟元素(节点) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 当前 = 节点.后一兄弟
    当 (当前 != 0) {
        如果 (当前.节点标志 & 节点标志_是元素) {
            返回 当前
        }
        当前 = 当前.后一兄弟
    }
    返回 0
}

函数 节点_前一个兄弟元素(节点) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 当前 = 节点.前一兄弟
    当 (当前 != 0) {
        如果 (当前.节点标志 & 节点标志_是元素) {
            返回 当前
        }
        当前 = 当前.前一兄弟
    }
    返回 0
}

函数 节点_第N个子节点(节点, n) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 当前 = 节点.第一子节点
    定义 可变 i = 0
    当 (当前 != 0 && i < n) {
        当前 = 当前.后一兄弟
        i = i + 1
    }
    返回 当前
}

函数 节点_子节点数(节点) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 计 = 0
    定义 可变 当前 = 节点.第一子节点
    当 (当前 != 0) {
        计 = 计 + 1
        当前 = 当前.后一兄弟
    }
    返回 计
}

函数 节点_子元素数(节点) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 计 = 0
    定义 可变 当前 = 节点.第一子节点
    当 (当前 != 0) {
        如果 (当前.节点标志 & 节点标志_是元素) {
            计 = 计 + 1
        }
        当前 = 当前.后一兄弟
    }
    返回 计
}

函数 节点_第一个子元素(节点) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 当前 = 节点.第一子节点
    当 (当前 != 0) {
        如果 (当前.节点标志 & 节点标志_是元素) { 返回 当前 }
        当前 = 当前.后一兄弟
    }
    返回 0
}

函数 节点_最后一个子元素(节点) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 当前 = 节点.最后子节点
    当 (当前 != 0) {
        如果 (当前.节点标志 & 节点标志_是元素) { 返回 当前 }
        当前 = 当前.前一兄弟
    }
    返回 0
}

// §5 compareDocumentPosition

函数 节点_compareDocumentPosition(参考, 其他) {
    节点操作统计_初始化()
    全局_节点操作统计.位置比较次数 = 全局_节点操作统计.位置比较次数 + 1

    如果 (参考 == 其他) { 返回 0 }
    如果 (参考 == 0 || 其他 == 0) { 返回 DOC_POS_DISCONNECTED }

    // 检查是否在同一棵树
    定义 根A = 节点_根节点(参考)
    定义 根B = 节点_根节点(其他)
    如果 (根A != 根B) { 返回 DOC_POS_DISCONNECTED | DOC_POS_IMPLEMENTATION_SPECIFIC }

    // 检查包含关系
    如果 (节点_是祖先(参考, 其他) == 1) {
        返回 DOC_POS_CONTAINED_BY | DOC_POS_FOLLOWING
    }
    如果 (节点_是祖先(其他, 参考) == 1) {
        返回 DOC_POS_CONTAINS | DOC_POS_PRECEDING
    }

    // 确定先后顺序: 深度优先遍历
    定义 可变 当前 = 节点_深度优先下一个(根A, 根A)
    当 (当前 != 0) {
        如果 (当前 == 参考) { 返回 DOC_POS_FOLLOWING }
        如果 (当前 == 其他) { 返回 DOC_POS_PRECEDING }
        当前 = 节点_深度优先下一个(当前, 根A)
    }

    返回 DOC_POS_DISCONNECTED
}

// §6 按条件查找

函数 节点_按标签查找(根, 标签名) {
    节点操作统计_初始化()
    全局_节点操作统计.查找次数 = 全局_节点操作统计.查找次数 + 1

    定义 可变 结果 = []
    如果 (根 == 0) { 返回 结果 }

    定义 可变 当前 = 节点_深度优先下一个(根, 根)
    当 (当前 != 0) {
        如果 (当前.标签名 == 标签名) {
            追加(结果, 当前)
        }
        当前 = 节点_深度优先下一个(当前, 根)
    }
    返回 结果
}

函数 节点_按类型查找(根, 节点类型) {
    定义 可变 结果 = []
    如果 (根 == 0) { 返回 结果 }

    定义 可变 当前 = 节点_深度优先下一个(根, 根)
    当 (当前 != 0) {
        如果 (当前.节点类型 == 节点类型) {
            追加(结果, 当前)
        }
        当前 = 节点_深度优先下一个(当前, 根)
    }
    返回 结果
}

函数 节点_子树节点数(根) {
    如果 (根 == 0) { 返回 0 }
    定义 可变 计 = 0
    定义 可变 当前 = 节点_深度优先下一个(根, 根)
    当 (当前 != 0) {
        计 = 计 + 1
        当前 = 节点_深度优先下一个(当前, 根)
    }
    返回 计
}

函数 节点_子树最大深度(根) {
    如果 (根 == 0) { 返回 0 }
    定义 根深度 = 节点_深度(根)
    定义 可变 最大 = 0
    定义 可变 当前 = 节点_深度优先下一个(根, 根)
    当 (当前 != 0) {
        定义 d = 节点_深度(当前) - 根深度
        如果 (d > 最大) { 最大 = d }
        当前 = 节点_深度优先下一个(当前, 根)
    }
    返回 最大
}

函数 节点操作_打印统计() {
    节点操作统计_初始化()
    打印行("=== 节点操作统计 ===")
    打印行("替换次数: " + 整数转字符串(全局_节点操作统计.替换次数))
    打印行("克隆次数: " + 整数转字符串(全局_节点操作统计.克隆次数))
    打印行("规范化次数: " + 整数转字符串(全局_节点操作统计.规范化次数))
    打印行("遍历次数: " + 整数转字符串(全局_节点操作统计.遍历次数))
    打印行("位置比较: " + 整数转字符串(全局_节点操作统计.位置比较次数))
    打印行("查找次数: " + 整数转字符串(全局_节点操作统计.查找次数))
}

函数 节点操作_重置统计() {
    全局_节点操作统计.替换次数 = 0
    全局_节点操作统计.克隆次数 = 0
    全局_节点操作统计.规范化次数 = 0
    全局_节点操作统计.遍历次数 = 0
    全局_节点操作统计.位置比较次数 = 0
    全局_节点操作统计.查找次数 = 0
}

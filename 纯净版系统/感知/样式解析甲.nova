函数 CSSParser_解析单位(单位, 长度) {
    如果 (字符串_等于N(单位, 长度, "px")) { 返回 单位_px }
    如果 (字符串_等于N(单位, 长度, "em")) { 返回 单位_em }
    如果 (字符串_等于N(单位, 长度, "rem")) { 返回 单位_rem }
    如果 (字符串_等于N(单位, 长度, "vh")) { 返回 单位_vh }
    如果 (字符串_等于N(单位, 长度, "vw")) { 返回 单位_vw }
    如果 (字符串_等于N(单位, 长度, "pt")) { 返回 单位_pt }
    返回 单位_px    // 默认px
}

函数 CSSParser_解析十六进制颜色(值, 长度) {
    // 解析 #RGB / #RRGGBB / #RRGGBBAA
    定义 可变 r = 0; 定义 可变 g = 0; 定义 可变 b = 0; 定义 可变 a = 0xFF
    如果 (长度 == 3) {
        r = CSSParser_十六进制字符(内存_读8(值)); r = r * 16 + r
        g = CSSParser_十六进制字符(内存_读8(值 + 1)); g = g * 16 + g
        b = CSSParser_十六进制字符(内存_读8(值 + 2)); b = b * 16 + b
    }
    否则 如果 (长度 >= 6) {
        r = CSSParser_十六进制字符(内存_读8(值)) * 16 + CSSParser_十六进制字符(内存_读8(值 + 1))
        g = CSSParser_十六进制字符(内存_读8(值 + 2)) * 16 + CSSParser_十六进制字符(内存_读8(值 + 3))
        b = CSSParser_十六进制字符(内存_读8(值 + 4)) * 16 + CSSParser_十六进制字符(内存_读8(值 + 5))
    }
    如果 (长度 == 8) {
        a = CSSParser_十六进制字符(内存_读8(值 + 6)) * 16 + CSSParser_十六进制字符(内存_读8(值 + 7))
    }
    返回 (r * 0x1000000) + (g * 0x10000) + (b * 0x100) + a
}

函数 CSSParser_十六进制字符(c) {
    如果 (c >= 0x30 && c <= 0x39) { 返回 c - 0x30 }
    如果 (c >= 0x41 && c <= 0x46) { 返回 c - 0x41 + 10 }
    如果 (c >= 0x61 && c <= 0x66) { 返回 c - 0x61 + 10 }
    返回 0
}

函数 CSSParser_命名颜色(名, 长度) {
    如果 (字符串_等于N(名, 长度, "black")) { 返回 0x000000FF }
    如果 (字符串_等于N(名, 长度, "white")) { 返回 0xFFFFFFFF }
    如果 (字符串_等于N(名, 长度, "red")) { 返回 0xFF0000FF }
    如果 (字符串_等于N(名, 长度, "green")) { 返回 0x008000FF }
    如果 (字符串_等于N(名, 长度, "blue")) { 返回 0x0000FFFF }
    如果 (字符串_等于N(名, 长度, "yellow")) { 返回 0xFFFF00FF }
    如果 (字符串_等于N(名, 长度, "orange")) { 返回 0xFFA500FF }
    如果 (字符串_等于N(名, 长度, "purple")) { 返回 0x800080FF }
    如果 (字符串_等于N(名, 长度, "gray")) { 返回 0x808080FF }
    如果 (字符串_等于N(名, 长度, "grey")) { 返回 0x808080FF }
    如果 (字符串_等于N(名, 长度, "transparent")) { 返回 0x00000000 }
    返回 0
}


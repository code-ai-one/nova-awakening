导入("../基础.nova")

// 路径压缩是火行: 通过变换(压缩)使结构更精炼
// 按秩合并是土行: 稳定地将小树嫁接到大树
// 合并操作 = 两股气脉汇合
// 每个连通分量是一"组", 合并是组的聚合

函数 uf_创建(n) { 定义 可变 父 = []
 定义 可变 秩 = []
 定义 可变 i = 0
 当 (i < n) {
 追加(父, i)
 追加(秩, 0)
 i = i + 1
 }
 返回 [父, 秩, n, n, [1, 0,]]
}

函数 uf_查找(集, x) { 定义 度量 = 集[4]
 度量[3] = 度量[3] + 1
 定义 父数组 = 集[0]
 定义 可变 当前 = x
 当 (父数组[当前] != 当前) {
 父数组[当前] = 父数组[父数组[当前]]
 当前 = 父数组[当前]
 }
 返回 当前
}

// 合并 (土行: 两组嫁接合一, 0)
函数 uf_合并(集, x, y) { 定义 度量 = 集[4]
 度量[2] = 度量[2] + 1
 定义 根x = uf_查找(集, x)
 定义 根y = uf_查找(集, y)
 如果 (根x == 根y) { 返回 0 }
 定义 父数组 = 集[0]
 定义 秩数组 = 集[1]
 如果 (秩数组[根x] < 秩数组[根y]) {
 父数组[根x] = 根y
 } 否则 如果 (秩数组[根x] > 秩数组[根y]) {
 父数组[根y] = 根x
 } 否则 {
 父数组[根y] = 根x
 秩数组[根x] = 秩数组[根x] + 1
 }
 集[3] = 集[3] - 1
 返回 1
}

// 是否连通
函数 uf_连通(集, x, y) { 返回 uf_查找(集, x) == uf_查找(集, y)
}

// 分量数
函数 uf_分量数(集) { 返回 集[3] }

// 某个分量的大小
函数 uf_分量大小(集, x) { 定义 根 = uf_查找(集, x)
 定义 n = 集[2]
 定义 可变 大小 = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (uf_查找(集, i) == 根) { 大小 = 大小 + 1 }
 i = i + 1
 }
 返回 大小
}

// 所有根
函数 uf_所有根(集) { 定义 n = 集[2]
 定义 可变 根列表 = []
 定义 可变 i = 0
 当 (i < n) { 如果 (uf_查找(集, i) == i) { 追加(根列表, i) }
 i = i + 1
 }
 返回 根列表
}

// 理论驱动新功能

函数 uf_五行报告(集) { 返回 集[4] }

函数 uf_气韵路径(集, x) { 定义 父数组 = 集[0]
 定义 可变 长度 = 0
 定义 可变 当前 = x
 当 (父数组[当前] != 当前) {
 当前 = 父数组[当前]
 长度 = 长度 + 1
 }
 返回 长度
}

函数 uf_平均气韵(集) { 定义 n = 集[2]
 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < n) {
 总 = 总 + uf_气韵路径(集, i)
 i = i + 1
 }
 如果 (n == 0) { 返回 0 }
 返回 总 * 100 / n
}

函数 uf_阴阳验证(集) { 定义 度量 = 集[4]
 度量[4] = 度量[4] + 1
 定义 n = 集[2]
 定义 可变 实际分量 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 父数组 = 集[0]
 如果 (父数组[i] == i) { 实际分量 = 实际分量 + 1 }
 i = i + 1
 }
 返回 实际分量 == 集[3]
}

// 量词态射: 并查集(组) → 分量列表(批)
函数 uf_组转批(集) { 定义 n = 集[2]
    定义 可变 ri = 0
 定义 根列表 = uf_所有根(集)
 定义 可变 分量 = []
 当 (ri < 计数(根列表)) { 定义 根 = 根列表[ri]
 定义 可变 成员 = []
 定义 可变 i = 0
 当 (i < n) { 如果 (uf_查找(集, i) == 根) { 追加(成员, i) }
 i = i + 1
 }
 追加(分量, 成员)
 ri = ri + 1
 }
 返回 分量
}

// 加权并查集

函数 加权UF_创建(n) { 定义 可变 父 = []
 定义 可变 秩 = []
 定义 可变 权 = []
 定义 可变 i = 0
 当 (i < n) {
 追加(父, i)
 追加(秩, 0)
 追加(权, 0)
 i = i + 1
 }
 返回 [父, 秩, 权, n]
}

函数 加权UF_查找(集, x) {
    如果 (集[0][x] == x) { 返回 [x, 0]
}
 定义 结果 = 加权UF_查找(集, 集[0][x])
 集[0][x] = 结果[0]
 集[2][x] = 集[2][x] + 结果[1]
 返回 [结果[0], 集[2][x]]
}

函数 加权UF_合并(集, x, y, w) { 定义 rx = 加权UF_查找(集, x)
 定义 ry = 加权UF_查找(集, y)
 如果 (rx[0] == ry[0]) { 返回 假 }
 定义 差 = w + rx[1] - ry[1]
 如果 (集[1][rx[0]] < 集[1][ry[0]]) {
 集[0][rx[0]] = ry[0]
 集[2][rx[0]] = 0 - 差
 } 否则 如果 (集[1][rx[0]] > 集[1][ry[0]]) {
 集[0][ry[0]] = rx[0]
 集[2][ry[0]] = 差
 } 否则 {
 集[0][ry[0]] = rx[0]
 集[2][ry[0]] = 差
 集[1][rx[0]] = 集[1][rx[0]] + 1
 }
 集[3] = 集[3] - 1
 返回 真
}

// Kruskal最小生成树

函数 克鲁斯卡尔最小生成树(边列表, 节点数) {
    定义 可变 总权 = 0
 // 边列表: [[u, v, 权重], ...]
 // 按权重排序(冒泡)
 定义 可变 n = 计数(边列表)
 定义 可变 i = 0
 当 (i < n - 1) { 定义 可变 j = 0
 当 (j < n - i - 1) { 如果 (边列表[j][2] > 边列表[j+1][2]) { 定义 临 = 边列表[j]
 边列表[j] = 边列表[j+1]
 边列表[j+1] = 临
 }
 j = j + 1
 }
 i = i + 1
 }
 // 并查集
 定义 集 = uf_创建(节点数)
 定义 可变 MST = []
 i = 0
 当 (i < n) { 定义 u = 边列表[i][0]
 定义 v = 边列表[i][1]
 定义 w = 边列表[i][2]
 如果 (uf_查找(集, u) != uf_查找(集, v)) {
 uf_合并(集, u, v)
 追加(MST, 边列表[i])
 总权 = 总权 + w
 }
 i = i + 1
 }
 返回 [MST, 总权]
}

// 连通分量分析

函数 UF_最大分量(集, n) {
    定义 可变 计数表 = []
 定义 可变 i = 0
 当 (i < n) { 追加(计数表, 0) i = i + 1 }
 i = 0
 当 (i < n) { 定义 根 = uf_查找(集, i)
 计数表[根] = 计数表[根] + 1
 i = i + 1
 }
 定义 可变 最大 = 0
 i = 0
 当 (i < n) { 如果 (计数表[i] > 最大) { 最大 = 计数表[i] }
 i = i + 1
 }
 返回 最大
}

函数 UF_孤立节点数(集, n) { 定义 可变 孤立 = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (uf_查找(集, i) == i) { 定义 可变 只有自己 = 真
 定义 可变 j = 0
 当 (j < n) { 如果 (j != i 且 uf_查找(集, j) == i) { 只有自己 = 假 }
 j = j + 1
 }
 如果 (只有自己) { 孤立 = 孤立 + 1 }
 }
 i = i + 1
 }
 返回 孤立
}

函数 UF_是否连通(集, n) { 定义 根 = uf_查找(集, 0)
 定义 可变 i = 1
 当 (i < n) { 如果 (uf_查找(集, i) != 根) { 返回 假 }
 i = i + 1
 }
 返回 真
}

// 动态连通性

定义 可变 _UF_操作历史 = []

函数 UF_记录合并(u, v) {
 追加(_UF_操作历史, [1, u, v])
}

函数 UF_记录查询(u, v, 结果) {
 追加(_UF_操作历史, [0, u, v, 结果])
}

函数 UF_操作数() { 返回 计数(_UF_操作历史) }

定义 可变 _UF_合并次数 = 0
定义 可变 _UF_查找次数 = 0
定义 可变 _UF_路径压缩次数 = 0

函数 UF_记录合并操作() { _UF_合并次数 = _UF_合并次数 + 1 }
函数 UF_记录查找操作() { _UF_查找次数 = _UF_查找次数 + 1 }
函数 UF_记录压缩() { _UF_路径压缩次数 = _UF_路径压缩次数 + 1 }

函数 UF_效率评估() {
    如果 (_UF_查找次数 > 0 且 _UF_路径压缩次数 * 100 / _UF_查找次数 > 80) { 返回 "路径压缩高效"
}
 如果 (_UF_合并次数 > 100000) { 返回 "大规模合并" }
 返回 "并查集正常"
}

函数 UF_重置() { _UF_合并次数 = 0 _UF_查找次数 = 0
 _UF_路径压缩次数 = 0 _UF_操作历史 = []
}

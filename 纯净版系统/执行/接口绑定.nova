// NovaOS Web接口绑定 — DOM/Window/Storage/Navigator JS API安装
// 技术: Web IDL → JS对象绑定 (类似Chromium Blink bindings)
// 核心: Document对象安装, Window全局安装, localStorage/sessionStorage,
//       Navigator/Location/History API, 事件监听器, fetch API
// 接口: 脚本引擎运行时 ↔ 渲染引擎DOM树 ↔ 网络协议栈(完整浏览器桥接)
// NovaOS创新: AI预测DOM访问模式 + 惰性属性绑定 + 智能事件委托

导入("../中枢/系统调用表.nova")
导入("../推理/智能渠道.nova")
导入("../感知/文档创建.nova")
导入("../感知/内核直连层.nova")
导入("../感知/存储创建.nova")
导入("../推理/小整数快速判.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/辅助有符号读.nova")
导入("../标准/加法运算符.nova")
导入("../中枢/辅助存根.nova")
导入("./底层内存操.nova")



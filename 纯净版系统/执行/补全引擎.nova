// 龙壳 — Tab补全引擎 (深度吸收bash/readline补全)
// 核心设计:
//   1. 上下文感知: 第一个词=命令补全, 后续=路径补全
//   2. 命令补全: 搜索内建命令 + PATH目录
//   3. 路径补全: 目录/文件名前缀匹配, 目录加/后缀
//   4. 单候选自动完成, 多候选显示列表
//   5. 公共前缀: 多候选时补全到最长公共前缀

定义 可变 补全候选 = []

定义 内建列表 = ["cd", "pwd", "echo", "exit", "export", "unset", "set",
                 "history", "alias", "type", "help", "source", "exec",
                 "jobs", "fg", "bg", "kill", "wait", "trap",
                 "read", "test", "true", "false", "env", "clear"]

// Tab补全入口

函数 补全_处理(输入行, 光标位置) {
    // 提取光标前的文本
    定义 前文 = 字符串_截取(输入行, 0, 光标位置)
    定义 部分 = 字符串分割(前文, " ")
    定义 词数 = 计数(部分)

    如果 (词数 == 0) { 返回 空 }

    定义 当前词 = 部分[词数 - 1]

    // 第一个词: 命令补全
    如果 (词数 == 1 || (词数 > 1 && 字符串_结尾是(前文, " "))) {
        如果 (字符串_结尾是(前文, " ")) {
            返回 补全_路径("")
        }
        返回 补全_命令(当前词)
    }

    // 后续词: 路径补全
    返回 补全_路径(当前词)
}

函数 补全_应用(输入行, 光标位置, 补全文本) {
    定义 前文 = 字符串_截取(输入行, 0, 光标位置)
    定义 后文 = 字符串_截取(输入行, 光标位置, 字符串长度(输入行))
    // 找到当前词的起始
    定义 可变 词起始 = 光标位置
    当 (词起始 > 0 && 字符串取字符(前文, 词起始 - 1) != " ") {
        词起始 = 词起始 - 1
    }
    定义 前部分 = 字符串_截取(输入行, 0, 词起始)
    返回 前部分 + 补全文本 + 后文
}

// 命令补全

函数 补全_命令(前缀) {
    补全候选 = []

    // 1. 搜索内建命令
    定义 可变 i = 0
    当 (i < 计数(内建列表)) {
        如果 (字符串_开头是(内建列表[i], 前缀)) {
            追加(补全候选, 内建列表[i])
        }
        i = i + 1
    }

    // 2. 搜索PATH中的可执行文件
    定义 path = 环境变量_获取("PATH")
    如果 (path != "") {
        定义 路径列表 = 字符串_分割(path, ":")
        i = 0
        当 (i < 计数(路径列表)) {
            定义 目录内容 = sys_readdir(路径列表[i])
            如果 (目录内容 != 空) {
                定义 可变 j = 0
                当 (j < 计数(目录内容)) {
                    如果 (字符串_开头是(目录内容[j], 前缀)) {
                        // 避免重复
                        如果 (!列表_包含(补全候选, 目录内容[j])) {
                            追加(补全候选, 目录内容[j])
                        }
                    }
                    j = j + 1
                }
            }
            i = i + 1
        }
    }

    返回 补全候选
}

// 路径补全

函数 补全_路径(前缀) {
    补全候选 = []

    // 分离目录和文件名前缀
    定义 可变 目录 = "."
    定义 可变 文件前缀 = 前缀

    定义 最后斜杠 = 字符串_最后索引(前缀, "/")
    如果 (最后斜杠 >= 0) {
        目录 = 字符串_截取(前缀, 0, 最后斜杠 + 1)
        文件前缀 = 字符串_截取(前缀, 最后斜杠 + 1, 字符串长度(前缀))
    }

    // 读取目录内容
    定义 内容 = sys_readdir(目录)
    如果 (内容 == 空) { 返回 补全候选 }

    定义 可变 i = 0
    当 (i < 计数(内容)) {
        定义 名称 = 内容[i]
        // 跳过.和..
        如果 (名称 != "." && 名称 != "..") {
            如果 (字符串_开头是(名称, 文件前缀)) {
                定义 完整路径 = 目录 + 名称
                // 如果是目录, 加/后缀
                如果 (sys_is_directory(完整路径)) {
                    追加(补全候选, 目录 + 名称 + "/")
                } 否则 {
                    追加(补全候选, 目录 + 名称)
                }
            }
        }
        i = i + 1
    }

    返回 补全候选
}

// 公共前缀 (多候选时补全到最长公共前缀)

函数 补全_公共前缀(候选列表) {
    如果 (计数(候选列表) == 0) { 返回 "" }
    如果 (计数(候选列表) == 1) { 返回 候选列表[0] }

    定义 可变 前缀 = 候选列表[0]
    定义 可变 i = 1
    当 (i < 计数(候选列表)) {
        定义 可变 匹配长度 = 0
        当 (匹配长度 < 字符串长度(前缀) && 匹配长度 < 字符串长度(候选列表[i])) {
            如果 (字符串取字符(前缀, 匹配长度) != 字符串取字符(候选列表[i], 匹配长度)) {
                中断
            }
            匹配长度 = 匹配长度 + 1
        }
        前缀 = 字符串_截取(前缀, 0, 匹配长度)
        i = i + 1
    }
    返回 前缀
}

// 候选列表显示

函数 补全_显示候选(候选列表) {
    如果 (计数(候选列表) == 0) { 返回 }
    打印行("")
    定义 可变 i = 0
    当 (i < 计数(候选列表)) {
        打印(候选列表[i] + "  ")
        如果 ((i + 1) % 4 == 0) { 打印行("") }
        i = i + 1
    }
    如果 (计数(候选列表) % 4 != 0) { 打印行("") }
}

函数 列表_包含(列表, 值) {
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] == 值) { 返回 真 }
        i = i + 1
    }
    返回 假
}

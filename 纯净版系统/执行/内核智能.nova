导入("../推理/智能渠道.nova")
导入("../感知/资源取数.nova")
导入("./安全检测.nova")
导入("./渲染优化.nova")
导入("./页面预测.nova")
导入("./核心推理.nova")
导入("./深度语义.nova")
导入("./资源调度.nova")
导入("./推理初始化.nova")

结构 智能档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    安全数,
    推理数,
    渲染数,
    调度数,
    预测数,
    成功数,
    失败数,
}

结构 智能请求 {
    动作,
    目标,
    参数,
    选项,
}

结构 智能回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 智能摘要 {
    名称,
    安全数,
    推理数,
    渲染数,
    调度数,
    预测数,
    成功数,
    失败数,
    健康,
}

定义 可变 智能账本 = []
定义 可变 智能构建数 = 0
定义 可变 智能总动作 = 0
定义 可变 智能总成功 = 0
定义 可变 智能总失败 = 0

函数 内核智能_建档(名称) {
    定义 档 = 智能档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.安全数 = 0
    档.推理数 = 0
    档.渲染数 = 0
    档.调度数 = 0
    档.预测数 = 0
    档.成功数 = 0
    档.失败数 = 0
    返回 档
}

函数 内核智能_登记(档) {
    追加(智能账本, 档)
    智能构建数 = 智能构建数 + 1
    返回 档
}

函数 内核智能_完整统计() {
    返回 [
        智能构建数,
        智能总动作,
        智能总成功,
        智能总失败
    ]
}

函数 内核智能_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 智能回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 内核智能_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.失败数 > 档.成功数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (档.安全数 > 0 || 档.推理数 > 0 || 档.预测数 > 0) {
        档.最近健康 = "运行"
        返回 档.最近健康
    }
    档.最近健康 = "空载"
    返回 档.最近健康
}

函数 内核智能_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    档.最近错误 = ""
    档.最近统计 = 内核智能_完整统计()
}

函数 内核智能_成功(档, 来源, 数据) {
    智能总动作 = 智能总动作 + 1
    智能总成功 = 智能总成功 + 1
    如果 (档 == 空) {
        返回 内核智能_建回证(真, 真, 来源, "", 数据, 内核智能_完整统计())
    }
    档.最近来源 = 来源
    档.最近结果 = 数据
    档.最近错误 = ""
    档.成功数 = 档.成功数 + 1
    档.最近统计 = 内核智能_完整统计()
    内核智能_刷新健康(档)
    返回 内核智能_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 内核智能_失败(档, 来源, 错因) {
    智能总动作 = 智能总动作 + 1
    智能总失败 = 智能总失败 + 1
    如果 (档 == 空) {
        返回 内核智能_建回证(真, 假, 来源, 错因, 0, 内核智能_完整统计())
    }
    档.最近来源 = 来源
    档.最近错误 = 错因
    档.失败数 = 档.失败数 + 1
    档.最近统计 = 内核智能_完整统计()
    内核智能_刷新健康(档)
    返回 内核智能_建回证(真, 假, 来源, 错因, 0, 档.最近统计)
}

函数 内核智能_初始化(档) {
    安全检测_初始化()
    意图推理_初始化()
    渲染优化_初始化()
    资源调度_初始化()
    页面预测_初始化()
    档.是否初始化 = 真
    档.最近动作 = "初始化"
    档.最近来源 = "内核智能_初始化"
    档.最近统计 = 内核智能_完整统计()
    内核智能_刷新健康(档)
    返回 档
}

函数 内核智能_创建(名称) {
    定义 档 = 内核智能_建档(名称)
    内核智能_初始化(档)
    返回 内核智能_登记(档)
}

函数 内核智能_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (!档.是否初始化) { 返回 假 }
    返回 真
}

函数 内核智能_扫描页面(档, 地址, 页面源码) {
    如果 (!内核智能_检查档(档)) { 返回 内核智能_失败(档, "扫描页面", "智能档不可用") }
    内核智能_记录(档, "扫描页面", [地址, 页面源码], "安全检测")
    定义 结果 = 安全检测_扫描页面(地址, 页面源码)
    档.安全数 = 档.安全数 + 1
    返回 内核智能_成功(档, "扫描页面", 结果)
}


//       css_property_parser.cc (~8000行)
//       css_parsing_utils.cc (~12000行)
// 每个CSS属性都有自己的值语法:
//   color: <color>
//   margin: [<length> | <percentage> | auto]{1,4}
//   background: <bg-layer># , <final-bg-layer>
//   font: [<font-style>||<font-variant>||<font-weight>]? <font-size>[/<line-height>]? <font-family>#
// 本文件实现200+属性的完整值解析

// §1 CSS值类型 (css_value.h)

定义 CSS值_关键字    = 1     // inherit/initial/unset/auto/none等
定义 CSS值_数字      = 2     // 42 / 3.14
定义 CSS值_百分比    = 3     // 50%
定义 CSS值_长度      = 4     // 10px / 2em / 1rem / 3vw
定义 CSS值_颜色      = 5     // #fff / rgb() / hsl() / 命名颜色
定义 CSS值_字符串    = 6     // "hello"
定义 CSS值_URL       = 7     // url(...)

定义 CSS值_函数      = 8     // calc() / var() / min() / max()
定义 CSS值_列表      = 9     // 多个值的列表(如 margin: 1px 2px 3px)
定义 CSS值_对        = 10    // 值对(如 background-position: 50% 50%)
定义 CSS值_图像      = 11    // linear-gradient() / radial-gradient() / url()
定义 CSS值_角度      = 12    // 45deg / 1rad / 100grad / 0.5turn
定义 CSS值_时间      = 13    // 0.3s / 300ms
定义 CSS值_分辨率    = 14    // 96dpi / 2dppx
定义 CSS值_自定义属性 = 15   // var(--name)

定义 单位_px    = 1
定义 单位_em    = 2
定义 单位_rem   = 3
定义 单位_vw    = 4
定义 单位_vh    = 5
定义 单位_vmin  = 6

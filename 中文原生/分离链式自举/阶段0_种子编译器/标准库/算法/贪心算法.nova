//    火行特性: 急速、单向、不回头
//    贪心选择 = 火的燃烧: 每步取当前最优, 一旦选定不可撤回
//    火克金: 贪心(火)牺牲最优性(金)换取速度
//    贪心=阳(局部最优, 快速前进)
//    DP=阴(全局最优, 全面考量)
//    当最优子结构+贪心选择性质成立时, 阳阴合一

// 活动选择 (按结束时间贪心)
// 活动: [[开始, 结束], ...]

导入("../基础.nova")

函数 贪心_活动选择(活动列表) {
    // 先按结束时间排序
    定义 可变 排序后 = []
    定义 可变 i = 0
    当 (i < 计数(活动列表)) { 追加(排序后, 活动列表[i]) i = i + 1 }
    定义 可变 已改变 = 1
    当 (已改变 == 1) {
        已改变 = 0
        i = 0
        当 (i < 计数(排序后) - 1) {
            如果 (排序后[i][1] > 排序后[i + 1][1]) {
                定义 临时 = 排序后[i]
                排序后[i] = 排序后[i + 1]
                排序后[i + 1] = 临时
                已改变 = 1
            }
            i = i + 1
        }
    }
    // 贪心选择
    定义 可变 选中 = []
    定义 首个 = 排序后[0]
    追加(选中, 首个)
    定义 可变 上次结束 = 首个[1]
    i = 1
    当 (i < 计数(排序后)) {
        如果 (排序后[i][0] >= 上次结束) {
            追加(选中, 排序后[i])
            上次结束 = 排序后[i][1]
        }
        i = i + 1
    }
    返回 选中
}

// 分数背包 (物品可分割)
// 物品: [[重量, 价值], ...]
函数 贪心_分数背包(容量, 物品) {
    // 按价值密度排序 (高→低)
    定义 可变 排序后 = []
    定义 可变 i = 0
    当 (i < 计数(物品)) { 追加(排序后, 物品[i]) i = i + 1 }
    定义 可变 已改变 = 1
    当 (已改变 == 1) {
        已改变 = 0
        i = 0
        当 (i < 计数(排序后) - 1) {
            // 比较 v1/w1 vs v2/w2 → v1*w2 vs v2*w1
            定义 a = 排序后[i]
            定义 b = 排序后[i + 1]
            如果 (a[1] * b[0] < b[1] * a[0]) {
                排序后[i] = b
                排序后[i + 1] = a
                已改变 = 1
            }
            i = i + 1
        }
    }
    // 贪心装入
    定义 可变 剩余容量 = 容量
    定义 可变 总价值 = 0
    i = 0
    当 (i < 计数(排序后) 且 剩余容量 > 0) {
        定义 物 = 排序后[i]
        如果 (物[0] <= 剩余容量) {
            总价值 = 总价值 + 物[1]
            剩余容量 = 剩余容量 - 物[0]
        } 否则 {
            总价值 = 总价值 + 物[1] * 剩余容量 / 物[0]
            剩余容量 = 0
        }
        i = i + 1
    }
    返回 总价值
}

// Huffman编码树构建
// 频率: [[字符, 频率], ...]
// 节点: [频率, 字符, 左子, 右子]
函数 huffman_构建(频率列表) {
    定义 可变 节点 = []
    定义 可变 i = 0
    当 (i < 计数(频率列表)) {
        定义 项 = 频率列表[i]
        追加(节点, [项[1], 项[0], 空, 空])
        i = i + 1
    }
    // 每次取最小两个合并
    当 (计数(节点) > 1) {
        // 找最小
        定义 可变 min1 = 0
        i = 1
        当 (i < 计数(节点)) {
            如果 (节点[i][0] < 节点[min1][0]) { min1 = i }
            i = i + 1
        }
        定义 n1 = 节点[min1]
        删除(节点, min1)
        // 找第二小
        定义 可变 min2 = 0
        i = 1
        当 (i < 计数(节点)) {
            如果 (节点[i][0] < 节点[min2][0]) { min2 = i }
            i = i + 1
        }
        定义 n2 = 节点[min2]
        删除(节点, min2)
        // 合并
        定义 合并 = [n1[0] + n2[0], -1, n1, n2]
        追加(节点, 合并)
    }
    如果 (计数(节点) > 0) { 返回 节点[0] }
    返回 空
}

// 跳跃游戏 (能否到达末尾)
函数 贪心_跳跃(步数列表) {
    定义 n = 计数(步数列表)
    定义 可变 最远 = 0
    定义 可变 i = 0
    当 (i < n 且 i <= 最远) {
        定义 可达 = i + 步数列表[i]
        如果 (可达 > 最远) { 最远 = 可达 }
        如果 (最远 >= n - 1) { 返回 1 }
        i = i + 1
    }
    返回 0
}

// 加油站问题
函数 贪心_加油站(油量, 消耗) {
    定义 n = 计数(油量)
    定义 可变 总油 = 0
    定义 可变 当前油 = 0
    定义 可变 起点 = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 净油 = 油量[i] - 消耗[i]
        总油 = 总油 + 净油
        当前油 = 当前油 + 净油
        如果 (当前油 < 0) {
            起点 = i + 1
            当前油 = 0
        }
        i = i + 1
    }
    如果 (总油 < 0) { 返回 -1 }
    返回 起点
}

// 区间调度最大化

函数 贪心_区间调度(开始列表, 结束列表) {
    定义 n = 计数(开始列表)
    // 按结束时间排序(冒泡)
    定义 可变 索引 = []
    定义 可变 i = 0
    当 (i < n) { 追加(索引, i)  i = i + 1 }
    i = 0
    当 (i < n - 1) {
        定义 可变 j = 0
        当 (j < n - 1 - i) {
            如果 (结束列表[索引[j]] > 结束列表[索引[j + 1]]) {
            }
            j = j + 1
        }
        i = i + 1
    }
    定义 可变 选中 = [索引[0]]
    定义 可变 上次结束 = 结束列表[索引[0]]
    i = 1
    当 (i < n) {
        如果 (开始列表[索引[i]] >= 上次结束) {
            追加(选中, 索引[i])
            上次结束 = 结束列表[索引[i]]
        }
        i = i + 1
    }
    返回 选中
}

// 分数背包

函数 贪心_分数背包_数组(重量列表, 价值列表, 容量) {
    定义 n = 计数(重量列表)
    定义 可变 索引 = []
    定义 可变 i = 0
    当 (i < n) { 追加(索引, i)  i = i + 1 }
    // 按单位价值降序排列
    i = 0
    当 (i < n - 1) {
        定义 可变 j = 0
        当 (j < n - 1 - i) {
            定义 比a = 价值列表[索引[j]] * 重量列表[索引[j + 1]]
            定义 比b = 价值列表[索引[j + 1]] * 重量列表[索引[j]]
            如果 (比a < 比b) {
            }
            j = j + 1
        }
        i = i + 1
    }
    定义 可变 总价值 = 0
    定义 可变 剩余 = 容量
    i = 0
    当 (i < n 且 剩余 > 0) {
        定义 索引 = 索引[i]
        如果 (重量列表[索引] <= 剩余) {
            总价值 = 总价值 + 价值列表[索引]
            剩余 = 剩余 - 重量列表[索引]
        } 否则 {
            总价值 = 总价值 + 价值列表[索引] * 剩余 / 重量列表[索引]
            剩余 = 0
        }
        i = i + 1
    }
    返回 总价值
}

// 最少硬币找零

函数 贪心_找零(面值列表, 金额) {
    定义 n = 计数(面值列表)
    // 面值降序排序
    定义 可变 面值 = []
    定义 可变 i = 0
    当 (i < n) { 追加(面值, 面值列表[i])  i = i + 1 }
    i = 0
    当 (i < n - 1) {
        定义 可变 j = 0
        当 (j < n - 1 - i) {
            如果 (面值[j] < 面值[j + 1]) {
            }
            j = j + 1
        }
        i = i + 1
    }
    定义 可变 剩余 = 金额
    定义 可变 硬币数 = 0
    定义 可变 方案 = []
    i = 0
    当 (i < n 且 剩余 > 0) {
        定义 个数 = 剩余 / 面值[i]
        如果 (个数 > 0) {
            追加(方案, [面值[i], 个数])
            硬币数 = 硬币数 + 个数
            剩余 = 剩余 - 面值[i] * 个数
        }
        i = i + 1
    }
    返回 [硬币数, 方案]
}

// Kruskal最小生成树

函数 贪心_并查集_查(父, x) {
    定义 可变 当前 = x
    当 (父[当前] != 当前) { 当前 = 父[当前] }
    返回 当前
}

函数 贪心_Kruskal(节点数, 边列表) {
    定义 可变 MST = []
    定义 可变 总权重 = 0
    // 边: [权重, 起, 终]
    定义 m = 计数(边列表)
    // 按权重排序
    定义 可变 i = 0
    当 (i < m - 1) {
        定义 可变 j = 0
        当 (j < m - 1 - i) {
            如果 (边列表[j][0] > 边列表[j + 1][0]) {
            }
            j = j + 1
        }
        i = i + 1
    }
    定义 可变 父 = []
    i = 0
    当 (i < 节点数) { 追加(父, i)  i = i + 1 }
    i = 0
    当 (i < m 且 计数(MST) < 节点数 - 1) {
        定义 边 = 边列表[i]
        定义 根a = 贪心_并查集_查(父, 边[1])
        定义 根b = 贪心_并查集_查(父, 边[2])
        如果 (根a != 根b) {
            父[根a] = 根b
            追加(MST, 边)
            总权重 = 总权重 + 边[0]
        }
        i = i + 1
    }
    返回 [总权重, MST]
}

定义 可变 _贪心_执行数 = 0
定义 可变 _贪心_排序数 = 0

函数 贪心_记录执行() { _贪心_执行数 = _贪心_执行数 + 1 }
函数 贪心_记录排序() { _贪心_排序数 = _贪心_排序数 + 1 }

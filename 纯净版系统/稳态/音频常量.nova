// NovaOS 音频子系统 — ALSA兼容框架+混音引擎+AI音频增强
// 本模块定义音频子系统的完整基础设施:
//   1. PCM格式/采样率/声道布局完整常量体系
//   2. 声卡/PCM流/混音器/效果器数据结构
//   3. 全局音频管理器(声卡枚举/注册/路由)
//   4. 软件混音引擎(多流合并/音量/声道映射)
//   5. 格式转换管线(采样率/位深/声道数转换)
//   6. AI音频增强(降噪/回声消除/自动增益/语音检测)
// 与内核中断系统、内存管理、智能大脑、渲染引擎深度耦合。

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/日志中枢.nova")
导入("../中枢/同步原语.nova")
导入("../中枢/中断管理系统.nova")
导入("../中枢/进程调度.nova")
导入("../中枢/内存虚拟.nova")
导入("../中枢/公共智能.nova")
导入("../引导/引导加载器.nova")
导入("./总线解析.nova")
导入("../中枢/内核打印.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/哈希函数.nova")
导入("../中枢/内存回收.nova")
导入("../中枢/整数转字符串.nova")
导入("../感知/解析序列.nova")

// §1 PCM格式常量

定义 SND_PCM_FORMAT_U8        = 1
定义 SND_PCM_FORMAT_S16_LE    = 2
定义 SND_PCM_FORMAT_S16_BE    = 3
定义 SND_PCM_FORMAT_S24_LE    = 6
定义 SND_PCM_FORMAT_S24_BE    = 7
定义 SND_PCM_FORMAT_S32_LE    = 10
定义 SND_PCM_FORMAT_S32_BE    = 11
定义 SND_PCM_FORMAT_FLOAT_LE  = 14
定义 SND_PCM_FORMAT_FLOAT_BE  = 15
定义 SND_PCM_FORMAT_FLOAT64_LE = 16
定义 SND_PCM_FORMAT_S24_3LE   = 32
定义 SND_PCM_FORMAT_A_LAW     = 20
定义 SND_PCM_FORMAT_MU_LAW    = 22

// §2 采样率与流方向

定义 SND_RATE_8000   = 8000
定义 SND_RATE_11025  = 11025
定义 SND_RATE_16000  = 16000
定义 SND_RATE_22050  = 22050
定义 SND_RATE_32000  = 32000
定义 SND_RATE_44100  = 44100
定义 SND_RATE_48000  = 48000
定义 SND_RATE_88200  = 88200
定义 SND_RATE_96000  = 96000
定义 SND_RATE_176400 = 176400
定义 SND_RATE_192000 = 192000
定义 SND_RATE_384000 = 384000

定义 SND_PCM_STREAM_PLAYBACK = 0
定义 SND_PCM_STREAM_CAPTURE  = 1

定义 SND_PCM_STATE_OPEN       = 0
定义 SND_PCM_STATE_SETUP      = 1
定义 SND_PCM_STATE_PREPARED   = 2
定义 SND_PCM_STATE_RUNNING    = 3
定义 SND_PCM_STATE_XRUN       = 4
定义 SND_PCM_STATE_DRAINING   = 5
定义 SND_PCM_STATE_PAUSED     = 6
定义 SND_PCM_STATE_SUSPENDED  = 7

// §3 ioctl命令与声道布局

定义 SNDRV_PCM_Nova设备控制_HW_PARAMS     = 0x4101
定义 SNDRV_PCM_Nova设备控制_SW_PARAMS     = 0x4102
定义 SNDRV_PCM_Nova设备控制_PREPARE       = 0x4140
定义 SNDRV_PCM_Nova设备控制_START         = 0x4142
定义 SNDRV_PCM_Nova设备控制_DROP          = 0x4143
定义 SNDRV_PCM_Nova设备控制_DRAIN         = 0x4144
定义 SNDRV_PCM_Nova设备控制_PAUSE         = 0x4145
定义 SNDRV_PCM_Nova设备控制_WRITEI_FRAMES = 0x4150
定义 SNDRV_PCM_Nova设备控制_READI_FRAMES  = 0x4151
定义 SNDRV_CTL_Nova设备控制_ELEM_READ     = 0x5512
定义 SNDRV_CTL_Nova设备控制_ELEM_WRITE    = 0x5513

定义 声道_前左    = 0x01
定义 声道_前右    = 0x02
定义 声道_前中    = 0x04
定义 声道_低频    = 0x08
定义 声道_后左    = 0x10
定义 声道_后右    = 0x20
定义 声道_侧左    = 0x40
定义 声道_侧右    = 0x80
定义 声道_单声道  = 声道_前中
定义 声道_立体声  = 声道_前左 | 声道_前右
定义 声道_5_1    = 声道_前左 | 声道_前右 | 声道_前中 | 声道_低频 | 声道_后左 | 声道_后右
定义 声道_7_1    = 声道_5_1 | 声道_侧左 | 声道_侧右

定义 音频_最大声卡 = 8
定义 音频_最大PCM = 16
定义 音频_最大混音流 = 32
定义 音频_混音缓冲帧 = 1024

// §4 核心数据结构

结构 音频声卡 {
    索引,
    名称,
    驱动名,
    PCM列表,
    混音器列表,
    已初始化,
    MMIO基址,
    IRQ号,
    总线类型,
    电源状态,
}

结构 PCM子设备 {
    声卡,
    设备号,
    名称,
    播放,
    录音,
    打开计数,
}

结构 PCM流 {
    方向,
    状态,
    格式,
    采样率,
    声道数,
    声道布局,
    帧大小,
    缓冲区,
    缓冲帧数,
    周期帧数,
    写指针,
    读指针,
    欠载计数,
    过载计数,
    中断计数,
    总传输帧,
    锁,
}

结构 混音器控件 {
    名称,
    类型,
    最小值,
    最大值,
    当前值,
    声道数,
    回调,
}

结构 软件混音流 {
    流ID,
    PID,
    源格式,
    源采样率,
    源声道数,
    音量_左,
    音量_右,
    静音,
    缓冲区,
    缓冲帧数,
    写指针,
    读指针,
    活跃,
}

结构 格式转换器 {
    源格式,
    目标格式,
    源采样率,
    目标采样率,
    源声道数,
    目标声道数,
    重采样系数,
    历史样本,
}

结构 AI音频处理器 {
    降噪启用,
    降噪强度,
    回声消除启用,
    自动增益启用,
    目标增益_dB,
    语音检测启用,
    语音检测阈值,
    // 内部状态
    噪声谱估计,
    回声参考缓冲,
    增益平滑值,
    语音概率,
    处理帧数,
}

// §5 全局音频管理器

定义 可变 声卡列表 = []
定义 可变 声卡数 = 0
定义 可变 默认播放声卡 = -1
定义 可变 默认录音声卡 = -1
定义 可变 混音流列表 = []
定义 可变 全局_AI音频 = 空
定义 可变 音频_播放总帧 = 0
定义 可变 音频_录音总帧 = 0
定义 可变 音频_欠载总数 = 0
定义 可变 音频_混音缓冲 = 空
定义 可变 音频_主音量 = 100
定义 可变 音频_主静音 = 假

函数 音频_初始化() {
    声卡列表 = []
    声卡数 = 0
    混音流列表 = []
    音频_混音缓冲 = 分配内存(音频_混音缓冲帧 * 4 * 2)

    // 初始化AI音频处理器
    全局_AI音频 = AI音频处理器 {
        降噪启用: 真,
        降噪强度: 50,
        回声消除启用: 真,
        自动增益启用: 真,
        目标增益_dB: -20,
        语音检测启用: 真,
        语音检测阈值: 300,
        噪声谱估计: [],
        回声参考缓冲: [],
        增益平滑值: 100,
        语音概率: 0,
        处理帧数: 0,
    }
    // 初始化噪声谱估计(256频段)
    定义 可变 i = 0
    当 (i < 256) {
        追加(全局_AI音频.噪声谱估计, 0)
        i = i + 1
    }

    内核打印("[音频] 子系统初始化完成")
    返回 成功
}

函数 音频_注册声卡(声卡) {
    如果 (声卡数 >= 音频_最大声卡) { 返回 错误_资源不足 }
    声卡.索引 = 声卡数
    追加(声卡列表, 声卡)
    如果 (默认播放声卡 == -1) { 默认播放声卡 = 声卡数 }
    如果 (默认录音声卡 == -1) { 默认录音声卡 = 声卡数 }
    声卡数 = 声卡数 + 1
    内核打印("[音频] 注册声卡#" + 整数转字符串(声卡.索引) + ": " + 声卡.名称)
    返回 声卡.索引
}

// §6 软件混音引擎

函数 混音_创建流(PID, 格式, 采样率, 声道数) {
    如果 (计数(混音流列表) >= 音频_最大混音流) { 返回 -1 }
    定义 ID = 计数(混音流列表)
    定义 流 = 软件混音流 {
        流ID: ID,
        PID: PID,
        源格式: 格式,
        源采样率: 采样率,
        源声道数: 声道数,
        音量_左: 100,
        音量_右: 100,
        静音: 假,
        缓冲区: 分配内存(音频_混音缓冲帧 * 4 * 声道数),
        缓冲帧数: 音频_混音缓冲帧,
        写指针: 0,
        读指针: 0,
        活跃: 真,
    }
    追加(混音流列表, 流)
    返回 ID
}

函数 混音_合并(输出缓冲, 帧数) {
    // 将所有活跃混音流合并到输出缓冲(立体声S16LE)
    // 先清零
    定义 字节数 = 帧数 * 4
    内存_置零(输出缓冲, 字节数)

    定义 可变 i = 0
    当 (i < 计数(混音流列表)) {
        定义 流 = 混音流列表[i]
        如果 (!流.活跃 || 流.静音) { i = i + 1; 继续 }

        定义 可用 = 流.写指针 - 流.读指针
        如果 (可用 <= 0) { i = i + 1; 继续 }
        定义 实际 = 帧数
        如果 (实际 > 可用) { 实际 = 可用 }

        // 混合: 加法混音 + 音量调整
        定义 可变 f = 0
        当 (f < 实际) {
            定义 偏移源 = (流.读指针 + f) % 流.缓冲帧数
            定义 左样本 = 内存_读16有符号(流.缓冲区 + 偏移源 * 4)
            定义 右样本 = 内存_读16有符号(流.缓冲区 + 偏移源 * 4 + 2)

            // 音量调整
            左样本 = 左样本 * 流.音量_左 * 音频_主音量 / 10000
            右样本 = 右样本 * 流.音量_右 * 音频_主音量 / 10000

            // 叠加到输出
            定义 已有左 = 内存_读16有符号(输出缓冲 + f * 4)
            定义 已有右 = 内存_读16有符号(输出缓冲 + f * 4 + 2)
            定义 混合左 = 已有左 + 左样本
            定义 混合右 = 已有右 + 右样本

            // 软限幅(防止溢出)
            如果 (混合左 > 32767) { 混合左 = 32767 }
            如果 (混合左 < -32768) { 混合左 = -32768 }
            如果 (混合右 > 32767) { 混合右 = 32767 }
            如果 (混合右 < -32768) { 混合右 = -32768 }

            内存_写16(输出缓冲 + f * 4, 混合左)
            内存_写16(输出缓冲 + f * 4 + 2, 混合右)
            f = f + 1
        }
        流.读指针 = 流.读指针 + 实际
        i = i + 1
    }

    // AI音频增强后处理
    如果 (全局_AI音频 != 空 && 全局_AI音频.降噪启用) {
        AI音频_降噪(输出缓冲, 帧数)
    }

    返回 帧数
}

// §7 格式转换

函数 格式_样本字节数(格式) {
    如果 (格式 == SND_PCM_FORMAT_U8) { 返回 1 }
    如果 (格式 == SND_PCM_FORMAT_S16_LE || 格式 == SND_PCM_FORMAT_S16_BE) { 返回 2 }
    如果 (格式 == SND_PCM_FORMAT_S24_3LE) { 返回 3 }
    如果 (格式 == SND_PCM_FORMAT_S24_LE || 格式 == SND_PCM_FORMAT_S32_LE || 格式 == SND_PCM_FORMAT_FLOAT_LE) { 返回 4 }
    如果 (格式 == SND_PCM_FORMAT_FLOAT64_LE) { 返回 8 }
    返回 2
}

函数 格式_帧字节数(格式, 声道数) {
    返回 格式_样本字节数(格式) * 声道数
}

函数 格式转换_创建(源格式, 目标格式, 源率, 目标率, 源声道, 目标声道) {
    返回 格式转换器 {
        源格式: 源格式,
        目标格式: 目标格式,
        源采样率: 源率,
        目标采样率: 目标率,
        源声道数: 源声道,
        目标声道数: 目标声道,
        重采样系数: 目标率 * 1000 / 源率,
        历史样本: [0, 0, 0, 0],
    }
}

函数 格式转换_处理(转换器, 输入, 输入帧数, 输出) {
    // 简单线性插值重采样
    定义 比率 = 转换器.重采样系数
    定义 输出帧数 = 输入帧数 * 比率 / 1000
    定义 可变 o = 0
    当 (o < 输出帧数) {
        定义 源位置 = o * 1000 / 比率
        定义 整数部分 = 源位置
        定义 小数部分 = (o * 1000 - 整数部分 * 比率) * 1000 / 比率
        如果 (整数部分 >= 输入帧数 - 1) { 跳出 }

        定义 可变 ch = 0
        当 (ch < 转换器.目标声道数) {
            定义 源ch = ch
            如果 (源ch >= 转换器.源声道数) { 源ch = 转换器.源声道数 - 1 }
            定义 样本1 = 内存_读16有符号(输入 + (整数部分 * 转换器.源声道数 + 源ch) * 2)
            定义 样本2 = 内存_读16有符号(输入 + ((整数部分 + 1) * 转换器.源声道数 + 源ch) * 2)
            定义 插值 = 样本1 + (样本2 - 样本1) * 小数部分 / 1000
            内存_写16(输出 + (o * 转换器.目标声道数 + ch) * 2, 插值)
            ch = ch + 1
        }
        o = o + 1
    }
    返回 o
}

// §8 AI音频增强

函数 AI音频_降噪(缓冲, 帧数) {
    如果 (全局_AI音频 == 空) { 返回 }
    定义 强度 = 全局_AI音频.降噪强度
    // 简化谱减法降噪: 估计噪声底噪并减去
    定义 可变 f = 0
    当 (f < 帧数) {
        定义 左 = 内存_读16有符号(缓冲 + f * 4)
        定义 右 = 内存_读16有符号(缓冲 + f * 4 + 2)
        // 能量估计
        定义 能量 = 左 * 左 + 右 * 右
        定义 频段 = (f * 256 / 帧数) % 256
        // 更新噪声估计(慢速跟踪)
        定义 旧估计 = 全局_AI音频.噪声谱估计[频段]
        如果 (能量 < 旧估计 || 旧估计 == 0) {
            全局_AI音频.噪声谱估计[频段] = (旧估计 * 31 + 能量) / 32
        } 否则 {
            全局_AI音频.噪声谱估计[频段] = (旧估计 * 63 + 能量) / 64
        }
        // 谱减
        定义 噪声 = 全局_AI音频.噪声谱估计[频段]
        如果 (能量 > 噪声 * 2) {
            定义 系数 = (能量 - 噪声 * 强度 / 100) * 1000 / 能量
            如果 (系数 < 100) { 系数 = 100 }
            如果 (系数 > 1000) { 系数 = 1000 }
            左 = 左 * 系数 / 1000
            右 = 右 * 系数 / 1000
        } 否则 {
            左 = 左 * (100 - 强度) / 100
            右 = 右 * (100 - 强度) / 100
        }
        内存_写16(缓冲 + f * 4, 左)
        内存_写16(缓冲 + f * 4 + 2, 右)
        f = f + 1
    }
    全局_AI音频.处理帧数 = 全局_AI音频.处理帧数 + 帧数
}

函数 AI音频_语音检测(缓冲, 帧数) {
    如果 (全局_AI音频 == 空 || !全局_AI音频.语音检测启用) { 返回 假 }
    // 基于短时能量+过零率的VAD
    定义 可变 能量总和 = 0
    定义 可变 过零次数 = 0
    定义 可变 上一样本 = 0
    定义 可变 f = 0
    当 (f < 帧数) {
        定义 样本 = 内存_读16有符号(缓冲 + f * 4)
        能量总和 = 能量总和 + (样本 * 样本) / 帧数
        如果 ((样本 > 0 && 上一样本 < 0) || (样本 < 0 && 上一样本 > 0)) {
            过零次数 = 过零次数 + 1
        }
        上一样本 = 样本
        f = f + 1
    }
    // 语音特征: 中等能量+低过零率(相比噪声)
    定义 过零率 = 过零次数 * 1000 / 帧数
    定义 是语音 = (能量总和 > 全局_AI音频.语音检测阈值) && (过零率 < 400)
    全局_AI音频.语音概率 = (全局_AI音频.语音概率 * 3 + (如果选(是语音, 1000, 0))) / 4
    返回 全局_AI音频.语音概率 > 500
}

函数 AI音频_自动增益(缓冲, 帧数) {
    如果 (全局_AI音频 == 空 || !全局_AI音频.自动增益启用) { 返回 }
    // 计算RMS
    定义 可变 平方和 = 0
    定义 可变 f = 0
    当 (f < 帧数) {
        定义 样本 = 内存_读16有符号(缓冲 + f * 4)
        平方和 = 平方和 + 样本 * 样本 / 帧数
        f = f + 1
    }
    // 目标增益调整
    定义 当前RMS = 简单平方根(平方和)
    如果 (当前RMS <= 0) { 返回 }
    定义 目标RMS = 3000
    定义 增益 = 目标RMS * 100 / 当前RMS
    如果 (增益 > 400) { 增益 = 400 }
    如果 (增益 < 25) { 增益 = 25 }
    // 平滑
    全局_AI音频.增益平滑值 = (全局_AI音频.增益平滑值 * 15 + 增益) / 16
    // 应用增益
    f = 0
    当 (f < 帧数) {
        定义 左 = 内存_读16有符号(缓冲 + f * 4) * 全局_AI音频.增益平滑值 / 100
        定义 右 = 内存_读16有符号(缓冲 + f * 4 + 2) * 全局_AI音频.增益平滑值 / 100
        如果 (左 > 32767) { 左 = 32767 }
        如果 (左 < -32768) { 左 = -32768 }
        如果 (右 > 32767) { 右 = 32767 }
        如果 (右 < -32768) { 右 = -32768 }
        内存_写16(缓冲 + f * 4, 左)
        内存_写16(缓冲 + f * 4 + 2, 右)
        f = f + 1
    }
}

// §9 音量控制

函数 音频_设置主音量(音量) {
    如果 (音量 < 0) { 音量 = 0 }
    如果 (音量 > 100) { 音量 = 100 }
    音频_主音量 = 音量
}

函数 音频_获取主音量() { 返回 音频_主音量 }

函数 音频_设置主静音(静音) { 音频_主静音 = 静音 }

函数 音频_获取主静音() { 返回 音频_主静音 }

函数 混音_设置流音量(流ID, 左, 右) {
    如果 (流ID >= 计数(混音流列表)) { 返回 错误_无效参数 }
    混音流列表[流ID].音量_左 = 左
    混音流列表[流ID].音量_右 = 右
    返回 成功
}

// §10 统计与诊断

函数 音频_统计() {
    返回 {
        声卡数: 声卡数,
        默认播放: 默认播放声卡,
        默认录音: 默认录音声卡,
        播放总帧: 音频_播放总帧,
        录音总帧: 音频_录音总帧,
        欠载总数: 音频_欠载总数,
        混音流数: 计数(混音流列表),
        主音量: 音频_主音量,
        主静音: 音频_主静音,
        AI降噪: 全局_AI音频.降噪启用,
        AI处理帧: 全局_AI音频.处理帧数,
        AI语音概率: 全局_AI音频.语音概率,
    }
}

函数 音频_健康检查() {
    定义 可变 问题 = []
    如果 (声卡数 == 0) { 追加(问题, "无声卡设备") }
    如果 (音频_欠载总数 > 100) { 追加(问题, "频繁欠载: " + 整数转字符串(音频_欠载总数)) }
    如果 (计数(问题) == 0) { 返回 "音频健康" }
    返回 问题
}

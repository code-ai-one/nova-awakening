// AVX-512 散射/聚集
// vgatherdps zmm, [base+zmm*scale]
函数 发射_avx512_vgatherdps(d, base, idx) {
    发射_evex(1,  1,  1,  1,  2, 0 ,  1,  0,  1, 0 ,  1, 0, 0, 0)
    发射(0x92) 发射(0x04 + (d & 7) * 8) 发射((idx & 7) * 8 + (base & 7))
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./链表后继.nova")
导入("./整数转字符串.nova")

// NovaOS内核 · 注意力系统 (移植自Nova大脑L3/Nova注意力)
// 多头注意力+显著性检测+注意力资源分配
// §1 显著性地图: 输入信号的重要性评分
// §2 注意力焦点: 当前关注的Top-K信号
// §3 注意力切换: 新奇/紧急刺激抢占注意力
// §4 注意力疲劳: 长时间关注同一目标→自动切换
// §5 与神经调质联动: ACh高→注意力集中, NE高→注意力扩散

定义 注意力_通道数 = 16
定义 注意力_焦点数 = 3          // 同时关注的最大数
定义 注意力_衰减率 = 50         // 每tick显著性衰减
定义 注意力_新奇阈值 = 700      // 新奇度超此值→抢占
定义 注意力_疲劳阈值 = 100      // 关注tick超此值→疲劳

定义 可变 显著性 = []            // 每通道显著性评分(×1000)
定义 可变 注意力焦点 = []        // 当前Top-K焦点通道索引
定义 可变 焦点持续时间 = []      // 每个焦点的持续tick数
定义 可变 注意力_已初始化 = 假
定义 可变 注意力_tick = 0
定义 可变 注意力_切换次数 = 0

函数 注意力_初始化() {
    显著性 = []
    注意力焦点 = []
    焦点持续时间 = []
    定义 可变 i = 0
    当 (i < 注意力_通道数) { 追加(显著性, 0); i = i + 1 }
    注意力_已初始化 = 真
    内核信息("注意力系统: " + 整数转字符串(注意力_通道数) + "通道 Top-" + 整数转字符串(注意力_焦点数) + "焦点+新奇抢占+疲劳切换")
}

函数 注意力_输入(通道, 强度, 新奇度) {
    如果 (!注意力_已初始化 || 通道 >= 注意力_通道数) { 返回 }
    // 显著性 = 强度 × (1 + 新奇度/1000)
    显著性[通道] = 强度 * (1000 + 新奇度) / 1000

    // 新奇抢占: 高新奇度直接成为焦点
    如果 (新奇度 > 注意力_新奇阈值) {
        注意力_强制焦点(通道)
        注意力_切换次数 = 注意力_切换次数 + 1
    }
}

函数 注意力_tick() {
    如果 (!注意力_已初始化) { 返回 }
    注意力_tick = 注意力_tick + 1

    // 显著性自然衰减
    定义 可变 i = 0
    当 (i < 注意力_通道数) {
        显著性[i] = 显著性[i] - 注意力_衰减率
        如果 (显著性[i] < 0) { 显著性[i] = 0 }
        i = i + 1
    }

    // 更新焦点持续时间
    i = 0
    当 (i < 计数(焦点持续时间)) {
        焦点持续时间[i] = 焦点持续时间[i] + 1
        i = i + 1
    }

    // 重新计算Top-K焦点
    注意力_更新焦点()

    // 疲劳检查: 关注太久→强制切换
    i = 0
    当 (i < 计数(焦点持续时间)) {
        如果 (焦点持续时间[i] > 注意力_疲劳阈值) {
            // 疲劳→降低当前焦点显著性
            如果 (i < 计数(注意力焦点)) {
                显著性[注意力焦点[i]] = 显著性[注意力焦点[i]] / 2
            }
        }
        i = i + 1
    }
}

函数 注意力_更新焦点() {
    定义 可变 新焦点 = []
    定义 可变 新持续 = []
    定义 可变 n = 0
    当 (n < 注意力_焦点数) {
        定义 可变 最高 = -1
        定义 可变 最高值 = 0
        定义 可变 i = 0
        当 (i < 注意力_通道数) {
            定义 可变 已有 = 假
            定义 可变 j = 0
            当 (j < 计数(新焦点)) { 如果 (新焦点[j] == i) { 已有 = 真 }; j = j + 1 }
            如果 (!已有 && 显著性[i] > 最高值) { 最高值 = 显著性[i]; 最高 = i }
            i = i + 1
        }
        如果 (最高 >= 0 && 最高值 > 0) {
            追加(新焦点, 最高)
            // 检查是否延续旧焦点
            定义 可变 旧持续 = 0
            定义 可变 k = 0
            当 (k < 计数(注意力焦点)) {
                如果 (注意力焦点[k] == 最高 && k < 计数(焦点持续时间)) {
                    旧持续 = 焦点持续时间[k]
                }
                k = k + 1
            }
            追加(新持续, 旧持续)
        }
        n = n + 1
    }
    注意力焦点 = 新焦点
    焦点持续时间 = 新持续
}

函数 注意力_强制焦点(通道) {
    // 新奇抢占: 直接成为第一焦点
    如果 (计数(注意力焦点) > 0) { 注意力焦点[0] = 通道 }
    否则 { 追加(注意力焦点, 通道) }
    如果 (计数(焦点持续时间) > 0) { 焦点持续时间[0] = 0 }
    否则 { 追加(焦点持续时间, 0) }
}

函数 注意力_是焦点(通道) {
    定义 可变 i = 0
    当 (i < 计数(注意力焦点)) {
        如果 (注意力焦点[i] == 通道) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 注意力_获取焦点() { 返回 注意力焦点 }
函数 注意力_显著性(通道) { 如果 (通道 < 注意力_通道数) { 返回 显著性[通道] }; 返回 0 }

// §5 注意力权重计算 (Nova归一化指数近似)

函数 注意力_权重() {
    // 计算各通道的注意力权重(归一化到×1000)
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < 注意力_通道数) {
        总和 = 总和 + 显著性[i]
        i = i + 1
    }
    如果 (总和 == 0) { 总和 = 1 }
    定义 可变 权重 = []
    i = 0
    当 (i < 注意力_通道数) {
        追加(权重, 显著性[i] * 1000 / 总和)
        i = i + 1
    }
    返回 权重
}

// §6 注意力调制 (与神经调质联动)

定义 可变 ACh水平 = 500    // 乙酰胆碱: 集中注意力 (0-1000)
定义 可变 NE水平 = 500     // 去甲肾上腺素: 扩散注意力 (0-1000)

函数 注意力_设置调质(ach, ne) {
    ACh水平 = ach
    NE水平 = ne
}

函数 注意力_调制显著性(通道, 基础值) {
    // ACh高→增强焦点通道, 抑制非焦点
    // NE高→所有通道均匀增强
    定义 是焦点 = 注意力_是焦点(通道)
    定义 可变 调制 = 基础值

    如果 (是焦点) {
        // 焦点通道: ACh增强
        调制 = 调制 * (1000 + ACh水平 / 2) / 1000
    } 否则 {
        // 非焦点通道: ACh抑制
        调制 = 调制 * (1000 - ACh水平 / 4) / 1000
    }

    // NE: 全局增强(紧急状态)
    调制 = 调制 * (1000 + NE水平 / 3) / 1000

    如果 (调制 < 0) { 调制 = 0 }
    返回 调制
}

// §7 注意力历史 (追踪焦点切换模式)

定义 注意力_历史最大 = 64
定义 可变 注意力历史 = []  // [[tick, 焦点通道], ...]

函数 注意力_记录焦点变化(通道) {
    追加(注意力历史, [注意力_tick, 通道])
    如果 (计数(注意力历史) > 注意力_历史最大) {
        链表_删除(注意力历史, 0)
    }
}

函数 注意力_最近切换(数量) {
    定义 n = 计数(注意力历史)
    如果 (n <= 数量) { 返回 注意力历史 }
    定义 可变 结果 = []
    定义 可变 i = n - 数量
    当 (i < n) { 追加(结果, 注意力历史[i]); i = i + 1 }
    返回 结果
}

// §8 统计和诊断

函数 注意力_统计() {
    定义 可变 最高通道 = -1
    定义 可变 最高值 = 0
    定义 可变 i = 0
    当 (i < 注意力_通道数) {
        如果 (显著性[i] > 最高值) { 最高值 = 显著性[i]; 最高通道 = i }
        i = i + 1
    }
    返回 [注意力_tick, 计数(注意力焦点), 注意力_切换次数, 最高通道, 最高值, ACh水平, NE水平]
}

函数 注意力_显著性分布() {
    // 返回所有通道显著性快照
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 注意力_通道数) {
        追加(结果, [i, 显著性[i]])
        i = i + 1
    }
    返回 结果
}


函数 注意力_完整统计() {
    返回 [注意力_tick, 计数(注意力焦点), 注意力_切换次数, 注意力_通道数]
}

// NovaOS 浏览器内核 · 第一层 · NovaBridgeSched原创理论
// 原创理论: NovaBridgeSched
//   §1 线程类型: 主/渲染/JS/合成/IO/解码/AI/预取/工线
//   §2 优先级映射: 浏览器优先级→内核nice/RT策略
//   §3 帧率保障: 渲染帧期间临时提升线程优先级
//   §4 AI调度: 预测性优先级调整+媒体线程预分配
//   §5 CPU亲和: 关键线程绑定到性能核心
//   §6 内存压力感知: 内存不足时自动降级后台标签
//   §7 线程挂起/恢复: 后台标签冻结与解冻
//   四阶段AI演进: NovaBridgeSched在阶段1提供浏览器调度基础
// 直连内核L1调度器，浏览器与内核同生命周期
// 职责: 渲染线程调度、JS执行线程、IO线程、合成线程、AI调度增强

导入("../中枢/进程调度.nova")
导入("../中枢/进程任务.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/日志中枢.nova")
导入("../外联/地址解析辅.nova")
导入("../中枢/整数转字符串.nova")

定义 线程_主线程     = 0    // UI主线程(事件循环)
定义 线程_渲染       = 1    // NovaOS渲染线程
定义 线程_JS执行     = 2    // V8 JS引擎线程
定义 线程_合成       = 3    // 图处合成线程
定义 线程_IO         = 4    // 网络/文件IO线程
定义 线程_解码       = 5    // 图像/视频解码线程
定义 线程_AI推理     = 6    // AI意图推理线程
定义 线程_预取       = 7    // AI预取线程
定义 线程_工线     = 8    // Web 工线线程

定义 优先级_实时     = 0    // 合成线程(保障帧率)
定义 优先级_交互     = 1    // 主线程+渲染线程(响应用户)
定义 优先级_普通     = 2    // JS执行
定义 优先级_后台     = 3    // IO/解码/预取

结构 浏览器线程 {
    ID,
    类型,
    进程ID,    // u32 内核进程ID(内核直接管理)
    名称,
    优先级,
    状态,    // u32 0=运行 1=等待 2=挂起 3=终止
    CPU时间,    // u64 累计CPU时间(内核统计)
    切换次数,
    AI增强,    // 布尔 是否启用AI调度增强
}

结构 浏览器标签进程 {
    标签ID,
    URL,
    线程列表,    // [] 该标签的所有线程
    内存用量,
    CPU占用,    // u32 ×100
    沙箱级别,    // u32 安全沙箱隔离级别
}

定义 可变 调度_线程表 = []
定义 可变 调度_标签进程表 = []
定义 可变 调度_下一个ID = 1
定义 可变 调度_已初始化 = 假
定义 可变 调度_帧目标FPS = 60
定义 可变 调度_帧预算微秒 = 16666    // 1000000/60

// §1 初始化 — 创建浏览器核心线程

函数 浏览器调度_初始化() {
    调度_线程表 = []
    调度_标签进程表 = []

    // 创建浏览器核心线程 → 直接调用内核进程创建
    浏览器调度_创建线程(线程_主线程, "Browser-Main", 优先级_交互)
    浏览器调度_创建线程(线程_合成, "Browser-Compositor", 优先级_实时)
    浏览器调度_创建线程(线程_IO, "Browser-IO", 优先级_后台)
    浏览器调度_创建线程(线程_AI推理, "Browser-AI", 优先级_普通)
    浏览器调度_创建线程(线程_预取, "Browser-Prefetch", 优先级_后台)

    调度_已初始化 = 真
    内核信息("浏览器调度适配: 5个核心线程已创建, 直连内核Nova公平调度器")
}

// §2 线程创建 — 调用内核进程创建

函数 浏览器调度_创建线程(类型, 名称, 优先级) {
    定义 线程 = 浏览器线程 {}
    线程.ID = 调度_下一个ID
    调度_下一个ID = 调度_下一个ID + 1
    线程.类型 = 类型
    线程.名称 = 名称
    线程.优先级 = 优先级
    线程.状态 = 0
    线程.CPU时间 = 0
    线程.切换次数 = 0
    线程.AI增强 = 真

    // 直接调用内核创建内核线程
    定义 内核优先级 = 浏览器调度_映射优先级(优先级)
    线程.进程ID = 进程_创建内核线程(名称, 内核优先级)

    如果 (线程.进程ID > 0) {
        // 设置调度策略: 合成线程用RT调度, 其余用Nova公平调度
        如果 (优先级 == 优先级_实时) {
            调度_设置策略(线程.进程ID, 调度策略_FIFO, 50)
        } 否则 如果 (优先级 == 优先级_交互) {
            调度_设置nice(线程.进程ID, -5)
        } 否则 如果 (优先级 == 优先级_后台) {
            调度_设置nice(线程.进程ID, 10)
        }
    }

    追加(调度_线程表, 线程)
    返回 线程.ID
}

函数 浏览器调度_映射优先级(浏览器优先级) {
    如果 (浏览器优先级 == 优先级_实时) { 返回 50 }
    如果 (浏览器优先级 == 优先级_交互) { 返回 115 }
    如果 (浏览器优先级 == 优先级_普通) { 返回 120 }
    如果 (浏览器优先级 == 优先级_后台) { 返回 130 }
    返回 120
}

// §3 标签页进程管理 — 每标签独立线程组

函数 浏览器调度_创建标签进程(标签ID, url) {
    定义 标签 = 浏览器标签进程 {}
    标签.标签ID = 标签ID
    标签.URL = url
    标签.线程列表 = []
    标签.内存用量 = 0
    标签.CPU占用 = 0
    标签.沙箱级别 = 2    // 默认中等隔离

    // 为标签创建渲染线程和JS线程
    定义 渲染ID = 浏览器调度_创建线程(线程_渲染,
        "Tab-" + 整数转字符串(标签ID) + "-渲染", 优先级_交互)
    定义 JS_ID = 浏览器调度_创建线程(线程_JS执行,
        "Tab-" + 整数转字符串(标签ID) + "-JS", 优先级_普通)

    追加(标签.线程列表, 渲染ID)
    追加(标签.线程列表, JS_ID)

    // AI评估: 是否需要额外的解码线程
    如果 (浏览器调度_AI需要解码线程(url)) {
        定义 解码ID = 浏览器调度_创建线程(线程_解码,
            "Tab-" + 整数转字符串(标签ID) + "-Decode", 优先级_后台)
        追加(标签.线程列表, 解码ID)
    }

    追加(调度_标签进程表, 标签)
    返回 标签ID
}

函数 浏览器调度_销毁标签进程(标签ID) {
    定义 可变 i = 0
    当 (i < 计数(调度_标签进程表)) {
        如果 (调度_标签进程表[i].标签ID == 标签ID) {
            // 终止该标签的所有线程
            定义 可变 j = 0
            当 (j < 计数(调度_标签进程表[i].线程列表)) {
                浏览器调度_终止线程(调度_标签进程表[i].线程列表[j])
                j = j + 1
            }
            列表_移除(调度_标签进程表, i)
            返回
        }
        i = i + 1
    }
}

函数 浏览器调度_终止线程(线程ID) {
    定义 可变 i = 0
    当 (i < 计数(调度_线程表)) {
        如果 (调度_线程表[i].ID == 线程ID) {
            调度_线程表[i].状态 = 3
            // 通知内核终止进程
            进程_终止(调度_线程表[i].进程ID, 0)
            列表_移除(调度_线程表, i)
            返回
        }
        i = i + 1
    }
}

// §4 帧率调度 — 保障60fps

函数 浏览器调度_帧开始() {
    // 通知内核调度器: 渲染帧开始, 提升相关线程优先级
    定义 可变 i = 0
    当 (i < 计数(调度_线程表)) {
        如果 (调度_线程表[i].类型 == 线程_渲染 ||
             调度_线程表[i].类型 == 线程_合成) {
            // 临时提升优先级保障帧率
            调度_设置nice(调度_线程表[i].进程ID, -10)
        }
        i = i + 1
    }
}

函数 浏览器调度_帧结束() {
    // 帧渲染完成, 恢复正常优先级
    定义 可变 i = 0
    当 (i < 计数(调度_线程表)) {
        如果 (调度_线程表[i].类型 == 线程_渲染) {
            调度_设置nice(调度_线程表[i].进程ID, -5)
        }
        i = i + 1
    }
}

// §5 AI调度增强 — 预测性调度优化

函数 浏览器调度_AI优化() {
    // AI分析当前浏览器活动, 动态调整线程优先级
    定义 可变 i = 0
    当 (i < 计数(调度_标签进程表)) {
        定义 标签 = 调度_标签进程表[i]

        // 前台标签 → 提升优先级
        // 后台标签 → 降低优先级节省资源
        // AI预测即将切换的标签 → 预热
        如果 (标签.CPU占用 > 8000) {
            // CPU占用过高 → 可能是JS密集页面 → AI限制
            浏览器调度_限制标签CPU(标签.标签ID, 5000)
        }

        i = i + 1
    }
}

函数 浏览器调度_AI需要解码线程(url) {
    // AI根据URL预测是否需要媒体解码
    如果 (字符串查找(url, "youtube") >= 0) { 返回 真 }
    如果 (字符串查找(url, "bilibili") >= 0) { 返回 真 }
    如果 (字符串查找(url, "video") >= 0) { 返回 真 }
    如果 (字符串查找(url, ".mp4") >= 0) { 返回 真 }
    返回 假
}

函数 浏览器调度_限制标签CPU(标签ID, 最大占用) {
    // 通过内核cgroup限制标签CPU使用
    定义 可变 i = 0
    当 (i < 计数(调度_标签进程表)) {
        如果 (调度_标签进程表[i].标签ID == 标签ID) {
            定义 可变 j = 0
            当 (j < 计数(调度_标签进程表[i].线程列表)) {
                定义 线程ID = 调度_标签进程表[i].线程列表[j]
                定义 可变 k = 0
                当 (k < 计数(调度_线程表)) {
                    如果 (调度_线程表[k].ID == 线程ID) {
                        调度_设置nice(调度_线程表[k].进程ID, 15)
                    }
                    k = k + 1
                }
                j = j + 1
            }
            返回
        }
        i = i + 1
    }
}

// §6 Web 工线管理

函数 浏览器调度_创建工线(标签ID, 名称) {
    定义 workerID = 浏览器调度_创建线程(线程_工线,
        "工线-" + 名称, 优先级_普通)

    // 关联到标签
    定义 可变 i = 0
    当 (i < 计数(调度_标签进程表)) {
        如果 (调度_标签进程表[i].标签ID == 标签ID) {
            追加(调度_标签进程表[i].线程列表, workerID)
            返回 workerID
        }
        i = i + 1
    }
    返回 workerID
}

// §5 CPU亲和 — 关键线程绑定到性能核心

函数 浏览器调度_设置CPU亲和(线程ID, CPU掩码) {
    定义 可变 i = 0
    当 (i < 计数(调度_线程表)) {
        如果 (调度_线程表[i].ID == 线程ID) {
            // 调用内核设置CPU亲和
            调度_设置亲和性(调度_线程表[i].进程ID, CPU掩码)
            返回
        }
        i = i + 1
    }
}

函数 浏览器调度_绑定关键线程到性能核() {
    // 将合成线程和主线程绑定到性能核心(CPU0-3)
    定义 性能核掩码 = 0x0F  // CPU 0-3
    定义 可变 i = 0
    当 (i < 计数(调度_线程表)) {
        如果 (调度_线程表[i].类型 == 线程_合成 ||
             调度_线程表[i].类型 == 线程_主线程) {
            调度_设置亲和性(调度_线程表[i].进程ID, 性能核掩码)
        }
        i = i + 1
    }
}

// §6 内存压力感知 — 内存不足时自动降级

定义 内存_压力低 = 0
定义 内存_压力中 = 1
定义 内存_压力高 = 2
定义 可变 当前内存压力 = 0

函数 浏览器调度_内存压力通知(压力级别) {
    当前内存压力 = 压力级别
    如果 (压力级别 == 内存_压力高) {
        // 高压力: 降级所有后台标签的线程
        定义 可变 i = 0
        当 (i < 计数(调度_标签进程表)) {
            定义 可变 j = 0
            当 (j < 计数(调度_标签进程表[i].线程列表)) {
                定义 线程ID = 调度_标签进程表[i].线程列表[j]
                浏览器调度_挂起线程(线程ID)
                j = j + 1
            }
            i = i + 1
        }
    } 否则 如果 (压力级别 == 内存_压力低) {
        // 低压力: 恢复所有被挂起的后台标签
        定义 可变 i = 0
        当 (i < 计数(调度_线程表)) {
            如果 (调度_线程表[i].状态 == 2) {  // 2=挂起
                浏览器调度_恢复线程(调度_线程表[i].ID)
            }
            i = i + 1
        }
    }
}

// §7 线程挂起/恢复 — 后台标签冻结与解冻

函数 浏览器调度_挂起线程(线程ID) {
    定义 可变 i = 0
    当 (i < 计数(调度_线程表)) {
        如果 (调度_线程表[i].ID == 线程ID && 调度_线程表[i].状态 == 0) {
            调度_线程表[i].状态 = 2  // 2=挂起
            调度_设置nice(调度_线程表[i].进程ID, 19)  // 最低优先级
            返回
        }
        i = i + 1
    }
}

函数 浏览器调度_恢复线程(线程ID) {
    定义 可变 i = 0
    当 (i < 计数(调度_线程表)) {
        如果 (调度_线程表[i].ID == 线程ID && 调度_线程表[i].状态 == 2) {
            调度_线程表[i].状态 = 0  // 恢复运行
            // 恢复原优先级
            定义 内核优先级 = 浏览器调度_映射优先级(调度_线程表[i].优先级)
            调度_设置nice(调度_线程表[i].进程ID, 0)
            返回
        }
        i = i + 1
    }
}

// §8 帧率自适应 — 动态FPS调整

函数 浏览器调度_设置帧率(目标FPS) {
    如果 (目标FPS < 15) { 目标FPS = 15 }
    如果 (目标FPS > 144) { 目标FPS = 144 }
    调度_帧目标FPS = 目标FPS
    调度_帧预算微秒 = 1000000 / 目标FPS
}

函数 浏览器调度_获取线程(线程ID) {
    定义 可变 i = 0
    当 (i < 计数(调度_线程表)) {
        如果 (调度_线程表[i].ID == 线程ID) {
            返回 调度_线程表[i]
        }
        i = i + 1
    }
    返回 空
}

函数 浏览器调度_获取运行线程数() {
    定义 可变 计数 = 0
    定义 可变 i = 0
    当 (i < 计数(调度_线程表)) {
        如果 (调度_线程表[i].状态 == 0) { 计数 = 计数 + 1 }
        i = i + 1
    }
    返回 计数
}

// NovaBridgeSched完整诊断统计

函数 浏览器调度_统计() {
    返回 [
        ["线程总数", 计数(调度_线程表)],
        ["标签数", 计数(调度_标签进程表)],
        ["目标FPS", 调度_帧目标FPS],
        ["运行线程", 浏览器调度_获取运行线程数()],
        ["内存压力", 当前内存压力],
        ["线程池大小", 调度_线程池大小],
        ["池活跃数", 浏览器调度_线程池活跃数()]
    ]
}

// §9 线程池管理 — 预分配可复用线程

定义 可变 调度_线程池大小 = 8       // 默认池大小
定义 可变 调度_线程池最大 = 32     // 最大允许池大小
定义 可变 调度_线程池 = []            // 可用线程ID列表

函数 浏览器调度_线程池初始化(初始大小) {
    如果 (初始大小 > 调度_线程池最大) {
        初始大小 = 调度_线程池最大
    }
    调度_线程池大小 = 初始大小
    定义 可变 i = 0
    当 (i < 初始大小) {
        定义 tid = 浏览器调度_创建线程(线程_工线,
            "池线程-" + i, 优先级_普通)
        追加(调度_线程池, tid)
        // 池线程初始为挂起状态
        浏览器调度_挂起线程(tid)
        i = i + 1
    }
}

函数 浏览器调度_线程池获取() {
    // 从池中获取一个可用线程
    如果 (计数(调度_线程池) == 0) {
        // 池为空，动态扩展
        如果 (调度_线程池大小 < 调度_线程池最大) {
            定义 tid = 浏览器调度_创建线程(线程_工线,
                "池线程-动态", 优先级_普通)
            调度_线程池大小 = 调度_线程池大小 + 1
            返回 tid
        }
        返回 -1  // 池已满
    }
    定义 tid = 调度_线程池[计数(调度_线程池) - 1]
    删除(调度_线程池, 计数(调度_线程池) - 1)
    浏览器调度_恢复线程(tid)
    返回 tid
}

函数 浏览器调度_线程池归还(tid) {
    // 归还线程到池
    浏览器调度_挂起线程(tid)
    追加(调度_线程池, tid)
}

函数 浏览器调度_线程池活跃数() {
    返回 调度_线程池大小 - 计数(调度_线程池)
}

// §10 标签内存追踪 — 每个标签的RSS监控

定义 内存_标签上限 = 512 * 1024  // 512MB上限(KB)

函数 浏览器调度_查询标签RSS(标签ID) {
    定义 可变 i = 0
    定义 可变 总内存 = 0
    当 (i < 计数(调度_标签进程表)) {
        如果 (调度_标签进程表[i].标签ID == 标签ID) {
            定义 可变 j = 0
            当 (j < 计数(调度_标签进程表[i].线程列表)) {
                定义 tid = 调度_标签进程表[i].线程列表[j]
                定义 信息 = 浏览器调度_获取线程(tid)
                如果 (信息 != 空) {
                    总内存 = 总内存 + 调度_查询进程内存(信息.进程ID)
                }
                j = j + 1
            }
            返回 总内存
        }
        i = i + 1
    }
    返回 0
}

函数 浏览器调度_检查内存超限() {
    定义 可变 i = 0
    定义 可变 超限列表 = []
    当 (i < 计数(调度_标签进程表)) {
        定义 rss = 浏览器调度_查询标签RSS(调度_标签进程表[i].标签ID)
        如果 (rss > 内存_标签上限) {
            追加(超限列表, [调度_标签进程表[i].标签ID, rss])
        }
        i = i + 1
    }
    返回 超限列表
}

// §11 AI预测增强 — 基于历史模式的优先级调整

定义 可变 调度_AI历史缓存 = []       // 历史帧时间记录
定义 AI历史缓存上限 = 64

函数 浏览器调度_AI记录帧时间(帧时间微秒) {
    追加(调度_AI历史缓存, 帧时间微秒)
    如果 (计数(调度_AI历史缓存) > AI历史缓存上限) {
        删除(调度_AI历史缓存, 0)
    }
}

函数 浏览器调度_AI平均帧时间() {
    如果 (计数(调度_AI历史缓存) == 0) { 返回 0 }
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < 计数(调度_AI历史缓存)) {
        总和 = 总和 + 调度_AI历史缓存[i]
        i = i + 1
    }
    返回 总和 / 计数(调度_AI历史缓存)
}

函数 浏览器调度_AI自适应帧率() {
    // 基于历史帧时间自动调整目标FPS
    定义 平均 = 浏览器调度_AI平均帧时间()
    如果 (平均 == 0) { 返回 }
    如果 (平均 > 33333) {
        // 平均超过30fps的帧预算，降级到30fps
        浏览器调度_设置帧率(30)
    } 否则 如果 (平均 < 8333) {
        // 性能充裕，尝试120fps
        浏览器调度_设置帧率(120)
    } 否则 如果 (平均 < 16667) {
        // 性能良好，保持60fps
        浏览器调度_设置帧率(60)
    }
}

// §12 优先级反转检测 — 调度异常监控

函数 浏览器调度_检测优先级反转() {
    // 检测高优先级线程被低优先级线程阻塞的情况
    定义 可变 异常列表 = []
    定义 可变 i = 0
    当 (i < 计数(调度_线程表)) {
        如果 (调度_线程表[i].状态 == 1 &&    // 1=等待
             调度_线程表[i].优先级 >= 优先级_高) {
            // 高优先级在等待→可能发生了反转
            追加(异常列表, 调度_线程表[i].ID)
        }
        i = i + 1
    }
    返回 异常列表
}

函数 浏览器调度_修复优先级反转() {
    定义 异常 = 浏览器调度_检测优先级反转()
    定义 可变 i = 0
    当 (i < 计数(异常)) {
        // 临时提升阻塞者的优先级(priority inheritance)
        定义 线程 = 浏览器调度_获取线程(异常[i])
        如果 (线程 != 空) {
            调度_设置nice(线程.进程ID, -10)  // 临时提升
        }
        i = i + 1
    }
}

函数 浏览器调度_关闭() {
    // 关闭所有线程
    定义 可变 i = 0
    当 (i < 计数(调度_线程表)) {
        调度_结束进程(调度_线程表[i].进程ID)
        i = i + 1
    }
    调度_线程表 = []
    调度_标签进程表 = []
    调度_线程池 = []
}

函数 浏览器调度_诊断报告() {
    定义 反转 = 浏览器调度_检测优先级反转()
    定义 超限 = 浏览器调度_检查内存超限()
    定义 平均帧 = 浏览器调度_AI平均帧时间()
    返回 [
        ["线程总数", 计数(调度_线程表)],
        ["标签数", 计数(调度_标签进程表)],
        ["目标FPS", 调度_帧目标FPS],
        ["平均帧时间微秒", 平均帧],
        ["内存压力", 当前内存压力],
        ["优先级反转数", 计数(反转)],
        ["内存超限标签", 计数(超限)],
        ["线程池大小", 调度_线程池大小],
        ["池活跃数", 浏览器调度_线程池活跃数()],
        ["运行线程数", 浏览器调度_获取运行线程数()]
    ]
}

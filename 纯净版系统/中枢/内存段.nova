// NovaOS Intl.Segmenter — 企业级多语言文本分割引擎
// 职责: 字素簇/词/句子/行断四级分割·完整Unicode规则·正向/反向最大匹配
//       HMM统计分词·CJK+拉丁+西里尔+阿拉伯多书写系统·Locale敏感规则·AI智能分段
// 理论: MLSPT (Multi-Lingual Segmentation Prediction Theory)
//       多语言分割预测理论 — 基于字符属性迁移矩阵与跨书写系统边界张量场
//       的统一分段预测框架

导入("../中枢/系统调用表.nova")
导入("../推理/智能渠道.nova")
导入("./硬链接.nova")
导入("../推理/值乘.nova")
导入("./内核打印.nova")
导入("./哈希整数.nova")
导入("../执行/控制台输出.nova")
导入("../标准/本地排序.nova")
导入("./辅助存根.nova")

// 第一部分: 常量与粒度定义

定义 SEG_GRAPHEME  = 0    // 字素簇(UAX#29视觉字符)
定义 SEG_WORD      = 1    // 词(UAX#29词边界)
定义 SEG_SENTENCE  = 2    // 句子(UAX#29句边界)
定义 SEG_LINE      = 3    // 行断(UAX#14行断点)

// 字符属性类别 (UAX#29简化子集)
定义 属性_其他       = 0
定义 属性_CR         = 1
定义 属性_LF         = 2
定义 属性_控制符     = 3
定义 属性_扩展       = 4   // 组合标记/ZWJ
定义 属性_区域指示   = 5   // Regional_Indicator
定义 属性_前置       = 6   // Prepend
定义 属性_韩文L      = 7
定义 属性_韩文V      = 8
定义 属性_韩文T      = 9
定义 属性_韩文LV     = 10
定义 属性_韩文LVT    = 11
定义 属性_表情       = 12  // Extended_Pictographic
定义 属性_ZWJ        = 13
定义 属性_空格       = 14
定义 属性_标点       = 15
定义 属性_拉丁字母   = 16
定义 属性_数字       = 17
定义 属性_CJK表意    = 18  // 汉字/日韩表意文字
定义 属性_西里尔     = 19
定义 属性_阿拉伯     = 20
定义 属性_天城       = 21  // Devanagari
定义 属性_句终结     = 22  // .?!。！？
定义 属性_句续行     = 23  // , ; :

// 词类型
定义 词类_无    = 0
定义 词类_词   = 1   // word-like
定义 词类_数字  = 2
定义 词类_标点  = 3
定义 词类_空白  = 4
定义 词类_换行  = 5

// 书写系统类型
定义 书写_拉丁   = 0
定义 书写_CJK    = 1
定义 书写_韩文   = 2
定义 书写_西里尔  = 3
定义 书写_阿拉伯  = 4
定义 书写_天城   = 5
定义 书写_未知   = 99

// 限制
定义 SEG_最大结果数       = 65536
定义 SEG_词典最大词长     = 12
定义 SEG_HMM状态数        = 4    // B/M/E/S
定义 SEG_HMM_B             = 0    // 词开始
定义 SEG_HMM_M             = 1    // 词中间
定义 SEG_HMM_E             = 2    // 词结束
定义 SEG_HMM_S             = 3    // 单字词
定义 SEG_分词缓存上限     = 2048

// MLSPT理论参数
定义 MLSPT_特征维度       = 16
定义 MLSPT_缓存窗口       = 128
定义 MLSPT_置信阈值       = 0.65

// 第二部分: 数据结构

结构 Segmenter {
    locale,         // locale句柄
    locale标签,     // “zh-CN” / “en-US”
    粒度,           // SEG_GRAPHEME/WORD/SENTENCE/LINE
    书写系统,       // 书写_CJK / 拉丁 / ...
    使用HMM,       // CJK词用HMM统计分词
    使用AI,        // 是否启用AI辅助
}

结构 分割片段 {
    起始,        // 字节偏移
    结束,        // 字节偏移(不含)
    字符起始,    // 码点索引
    字符结束,
    词类型,      // 词类_词/数字/...
    是词,        // bool: isWordLike
}

结构 分割迭代器 {
    seg,           // Segmenter句柄
    文本,
    文本长度,
    片段数组,      // 分割片段[]
    片段数量,
    当前索引,
}

结构 HMM模型 {
    初始概率,      // 各状态初始 log概率 [4]
    转移概率,      // 状态转移 log概率 [4][4]
    发射概率表,    // 简化发射 hash 表
    发射表大小,
}

结构 分词缓存项 {
    哈希,
    片段数组,
    片段数量,
}

结构 分割统计 {
    总调用次数,
    总字符数,
    总片段数,
    字素簇调用,
    词分割调用,
    句分割调用,
    行断调用,
    HMM调用次数,
    缓存命中数,
    AI调用次数,
    平均耗时微秒,
}

// 第三部分: 全局状态

定义 可变 全局分割统计 = 分割统计 {}
定义 可变 全局HMM模型 = 0
定义 可变 全局分词缓存 = 数组_创建(SEG_分词缓存上限, 0)
定义 可变 全局分词缓存数量 = 0

// MLSPT历史
定义 可变 MLSPT_耗时历史 = 数组_创建(MLSPT_缓存窗口, 0.0)
定义 可变 MLSPT_片段历史 = 数组_创建(MLSPT_缓存窗口, 0.0)
定义 可变 MLSPT_历史写指针 = 0

// 第四部分: UTF-8解码与字符属性查询

函数 UTF8_解码单字符(文本, 偏移, 长度) {
    // 返回 {码点, 字节数}
    如果 (偏移 >= 长度) { 返回 {0, 0} }
    定义 b0 = 字节取(文本, 偏移)
    如果 (b0 < 0x80) { 返回 {b0, 1} }
    如果 (b0 < 0xC0) { 返回 {0xFFFD, 1} }  // 无效续字节
    如果 (b0 < 0xE0) {
        如果 (偏移 + 1 >= 长度) { 返回 {0xFFFD, 1} }
        定义 b1 = 字节取(文本, 偏移 + 1)
        定义 cp = ((b0 & 0x1F) << 6) | (b1 & 0x3F)
        返回 {cp, 2}
    }
    如果 (b0 < 0xF0) {
        如果 (偏移 + 2 >= 长度) { 返回 {0xFFFD, 1} }
        定义 b1 = 字节取(文本, 偏移 + 1)
        定义 b2 = 字节取(文本, 偏移 + 2)
        定义 cp = ((b0 & 0x0F) << 12) | ((b1 & 0x3F) << 6) | (b2 & 0x3F)
        返回 {cp, 3}
    }
    如果 (b0 < 0xF8) {
        如果 (偏移 + 3 >= 长度) { 返回 {0xFFFD, 1} }
        定义 b1 = 字节取(文本, 偏移 + 1)
        定义 b2 = 字节取(文本, 偏移 + 2)
        定义 b3 = 字节取(文本, 偏移 + 3)
        定义 cp = ((b0 & 0x07) << 18) | ((b1 & 0x3F) << 12) | ((b2 & 0x3F) << 6) | (b3 & 0x3F)
        返回 {cp, 4}
    }
    返回 {0xFFFD, 1}
}

函数 码点_查属性(cp) {
    // CR/LF
    如果 (cp == 0x000D) { 返回 属性_CR }
    如果 (cp == 0x000A) { 返回 属性_LF }
    // 控制符 C0/C1
    如果 (cp < 0x0020 || (cp >= 0x007F && cp <= 0x009F)) { 返回 属性_控制符 }
    // 空格类
    如果 (cp == 0x0020 || cp == 0x00A0 || cp == 0x1680 ||
        (cp >= 0x2000 && cp <= 0x200A) || cp == 0x202F ||
        cp == 0x205F || cp == 0x3000) { 返回 属性_空格 }
    // ZWJ
    如果 (cp == 0x200D) { 返回 属性_ZWJ }
    // 组合标记 (Mn/Mc/Me 简化范围)
    如果 ((cp >= 0x0300 && cp <= 0x036F) || (cp >= 0x0483 && cp <= 0x0489) ||
        (cp >= 0x0591 && cp <= 0x05BD) || (cp >= 0x0610 && cp <= 0x061A) ||
        (cp >= 0x064B && cp <= 0x065F) || (cp >= 0x0E31 && cp <= 0x0E3A) ||
        (cp >= 0xFE00 && cp <= 0xFE0F) || (cp >= 0x1AB0 && cp <= 0x1AFF) ||
        (cp >= 0x20D0 && cp <= 0x20FF) || (cp >= 0xE0100 && cp <= 0xE01EF)) {
        返回 属性_扩展
    }
    // 区域指示符 U+1F1E6..U+1F1FF
    如果 (cp >= 0x1F1E6 && cp <= 0x1F1FF) { 返回 属性_区域指示 }
    // Emoji简化检测
    如果 ((cp >= 0x1F600 && cp <= 0x1F64F) || (cp >= 0x1F300 && cp <= 0x1F5FF) ||
        (cp >= 0x1F680 && cp <= 0x1F6FF) || (cp >= 0x1F900 && cp <= 0x1F9FF) ||
        (cp >= 0x2600 && cp <= 0x26FF) || (cp >= 0x2700 && cp <= 0x27BF)) {
        返回 属性_表情
    }
    // 韩文Jamo
    如果 (cp >= 0x1100 && cp <= 0x115F) { 返回 属性_韩文L }
    如果 (cp >= 0x1160 && cp <= 0x11A7) { 返回 属性_韩文V }
    如果 (cp >= 0x11A8 && cp <= 0x11FF) { 返回 属性_韩文T }
    如果 (cp >= 0xAC00 && cp <= 0xD7A3) {
        定义 idx = cp - 0xAC00
        如果 (idx % 28 == 0) { 返回 属性_韩文LV }
        返回 属性_韩文LVT
    }
    // 句终结标点
    如果 (cp == 0x002E || cp == 0x003F || cp == 0x0021 ||
        cp == 0x3002 || cp == 0xFF01 || cp == 0xFF1F ||
        cp == 0x2026 || cp == 0x2049 || cp == 0x203C) {
        返回 属性_句终结
    }
    // 句续行标点
    如果 (cp == 0x002C || cp == 0x003B || cp == 0x003A ||
        cp == 0xFF0C || cp == 0xFF1B || cp == 0x3001) {
        返回 属性_句续行
    }
    // 数字 0-9 + 全角数字
    如果 ((cp >= 0x0030 && cp <= 0x0039) || (cp >= 0xFF10 && cp <= 0xFF19)) {
        返回 属性_数字
    }
    // 拉丁字母
    如果 ((cp >= 0x0041 && cp <= 0x005A) || (cp >= 0x0061 && cp <= 0x007A) ||
        (cp >= 0x00C0 && cp <= 0x024F) || (cp >= 0xFF21 && cp <= 0xFF3A) ||
        (cp >= 0xFF41 && cp <= 0xFF5A)) {
        返回 属性_拉丁字母
    }
    // CJK表意文字
    如果 ((cp >= 0x4E00 && cp <= 0x9FFF) || (cp >= 0x3400 && cp <= 0x4DBF) ||
        (cp >= 0x20000 && cp <= 0x2A6DF) || (cp >= 0xF900 && cp <= 0xFAFF) ||
        (cp >= 0x3040 && cp <= 0x30FF) || (cp >= 0x31F0 && cp <= 0x31FF) ||
        (cp >= 0xFF65 && cp <= 0xFF9F)) {
        返回 属性_CJK表意
    }
    // 西里尔字母
    如果 ((cp >= 0x0400 && cp <= 0x04FF) || (cp >= 0x0500 && cp <= 0x052F)) {
        返回 属性_西里尔
    }
    // 阿拉伯
    如果 ((cp >= 0x0600 && cp <= 0x06FF) || (cp >= 0x0750 && cp <= 0x077F) ||
        (cp >= 0xFB50 && cp <= 0xFDFF) || (cp >= 0xFE70 && cp <= 0xFEFF)) {
        返回 属性_阿拉伯
    }
    // 天城文
    如果 (cp >= 0x0900 && cp <= 0x097F) { 返回 属性_天城 }
    // 通用标点
    如果 ((cp >= 0x0021 && cp <= 0x002F) || (cp >= 0x003A && cp <= 0x0040) ||
        (cp >= 0x005B && cp <= 0x0060) || (cp >= 0x007B && cp <= 0x007E) ||
        (cp >= 0x2010 && cp <= 0x2027) || (cp >= 0x3008 && cp <= 0x3011) ||
        (cp >= 0xFF01 && cp <= 0xFF0F)) {
        返回 属性_标点
    }
    返回 属性_其他
}

函数 属性_是词类(属性) {
    返回 (属性 == 属性_拉丁字母 || 属性 == 属性_CJK表意 ||
            属性 == 属性_西里尔 || 属性 == 属性_阿拉伯 ||
            属性 == 属性_天城 || 属性 == 属性_数字 ||
            属性 == 属性_韩文L || 属性 == 属性_韩文V ||
            属性 == 属性_韩文T || 属性 == 属性_韩文LV ||
            属性 == 属性_韩文LVT)
}

// 第五部分: Segmenter创建与销毁

函数 Segmenter_创建(locale标签, 粒度) {
    定义 s = 堆_分配(Segmenter)
    如果 (s == 0) { 返回 0 }
    s.locale = Locale_解析(locale标签)
    s.locale标签 = 字符串_复制(locale标签)
    s.粒度 = 粒度
    // 推断书写系统
    s.书写系统 = Segmenter_推断书写系统(locale标签)
    s.使用HMM = (s.书写系统 == 书写_CJK)
    s.使用AI = (全局AI总线 != 0)
    返回 s
}

函数 Segmenter_推断书写系统(标签) {
    如果 (字符串开始于(标签, "zh") || 字符串开始于(标签, "ja")) { 返回 书写_CJK }
    如果 (字符串开始于(标签, "ko")) { 返回 书写_韩文 }
    如果 (字符串开始于(标签, "ru") || 字符串开始于(标签, "uk") ||
        字符串开始于(标签, "bg")) { 返回 书写_西里尔 }
    如果 (字符串开始于(标签, "ar") || 字符串开始于(标签, "fa") ||
        字符串开始于(标签, "ur")) { 返回 书写_阿拉伯 }
    如果 (字符串开始于(标签, "hi") || 字符串开始于(标签, "mr")) { 返回 书写_天城 }
    返回 书写_拉丁
}

函数 Segmenter_销毁(seg) {
    如果 (seg == 0) { 返回 }
    堆_释放(seg)
}

// 第六部分: 字素簇分割 (UAX#29 Grapheme Cluster)

函数 分割_字素簇(文本, 长度, 结果, 最大结果数) {
    全局分割统计.字素簇调用 = 全局分割统计.字素簇调用 + 1
    定义 可变 位置 = 0
    定义 可变 字符索引 = 0
    定义 可变 计数 = 0
    定义 可变 上一属性 = -1
    定义 可变 RI连续数 = 0

    当 (位置 < 长度 && 计数 < 最大结果数) {
        定义 簇开始 = 位置
        定义 簇字符起 = 字符索引
        // 解码第一个字符
        定义 解码 = UTF8_解码单字符(文本, 位置, 长度)
        定义 当前属性 = 码点_查属性(解码[0])
        位置 = 位置 + 解码[1]
        字符索引 = 字符索引 + 1

        // 规则GB3: CR×LF
        如果 (当前属性 == 属性_CR && 位置 < 长度) {
            定义 探 = UTF8_解码单字符(文本, 位置, 长度)
            如果 (探[0] == 0x000A) {
                位置 = 位置 + 探[1]
                字符索引 = 字符索引 + 1
            }
        }

        // 规则GB9/GB9a: Extend/ZWJ不断追加
        当 (位置 < 长度) {
            定义 探 = UTF8_解码单字符(文本, 位置, 长度)
            定义 探属性 = 码点_查属性(探[0])
            如果 (探属性 == 属性_扩展 || 探属性 == 属性_ZWJ) {
                位置 = 位置 + 探[1]
                字符索引 = 字符索引 + 1
                // GB11: Emoji×ZWJ×Emoji
                如果 (探属性 == 属性_ZWJ && 位置 < 长度) {
                    定义 探2 = UTF8_解码单字符(文本, 位置, 长度)
                    定义 探2属 = 码点_查属性(探2[0])
                    如果 (探2属 == 属性_表情) {
                        位置 = 位置 + 探2[1]
                        字符索引 = 字符索引 + 1
                    }
                }
                继续
            }
            // GB12/GB13: 区域指示符成对
            如果 (当前属性 == 属性_区域指示 && 探属性 == 属性_区域指示) {
                RI连续数 = RI连续数 + 1
                如果 (RI连续数 % 2 == 1) {
                    位置 = 位置 + 探[1]
                    字符索引 = 字符索引 + 1
                    继续
                }
            }
            // 韩文音节规则 GB6-GB8
            如果 (当前属性 == 属性_韩文L && (探属性 == 属性_韩文L || 探属性 == 属性_韩文V ||
                探属性 == 属性_韩文LV || 探属性 == 属性_韩文LVT)) {
                位置 = 位置 + 探[1]
                字符索引 = 字符索引 + 1
                当前属性 = 探属性
                继续
            }
            如果 ((当前属性 == 属性_韩文LV || 当前属性 == 属性_韩文V) &&
                (探属性 == 属性_韩文V || 探属性 == 属性_韩文T)) {
                位置 = 位置 + 探[1]
                字符索引 = 字符索引 + 1
                当前属性 = 探属性
                继续
            }
            如果 ((当前属性 == 属性_韩文LVT || 当前属性 == 属性_韩文T) &&
                探属性 == 属性_韩文T) {
                位置 = 位置 + 探[1]
                字符索引 = 字符索引 + 1
                当前属性 = 探属性
                继续
            }
            跳出
        }

        // 记录片段
        如果 (结果 != 0) {
            定义 片段 = 分割片段 {}
            片段.起始 = 簇开始
            片段.结束 = 位置
            片段.字符起始 = 簇字符起
            片段.字符结束 = 字符索引
            片段.词类型 = 词类_无
            片段.是词 = 假
            结果[计数] = 片段
        }
        计数 = 计数 + 1
        上一属性 = 当前属性
        如果 (当前属性 != 属性_区域指示) { RI连续数 = 0 }
    }
    全局分割统计.总片段数 = 全局分割统计.总片段数 + 计数
    返回 计数
}

// 第七部分: 词分割引擎
// 支持: 拉丁空格分词·CJK正向最大匹配+HMM·混合书写系统

函数 分割_词(seg, 文本, 长度, 结果, 最大结果数) {
    全局分割统计.词分割调用 = 全局分割统计.词分割调用 + 1
    定义 可变 位置 = 0
    定义 可变 字符索引 = 0
    定义 可变 计数 = 0

    当 (位置 < 长度 && 计数 < 最大结果数) {
        定义 解码 = UTF8_解码单字符(文本, 位置, 长度)
        定义 cp = 解码[0]
        定义 属性 = 码点_查属性(cp)

        // 空白片段
        如果 (属性 == 属性_空格 || 属性 == 属性_CR || 属性 == 属性_LF) {
            定义 ws开始 = 位置
            定义 ws字符开始 = 字符索引
            当 (位置 < 长度) {
                定义 d = UTF8_解码单字符(文本, 位置, 长度)
                定义 a = 码点_查属性(d[0])
                如果 (a != 属性_空格 && a != 属性_CR && a != 属性_LF) { 跳出 }
                位置 = 位置 + d[1]
                字符索引 = 字符索引 + 1
            }
            如果 (结果 != 0) {
                定义 片段 = 分割片段 {}
                片段.起始 = ws开始
                片段.结束 = 位置
                片段.字符起始 = ws字符开始
                片段.字符结束 = 字符索引
                片段.词类型 = 词类_空白
                片段.是词 = 假
                结果[计数] = 片段
            }
            计数 = 计数 + 1
            继续
        }

        // CJK表意字符——每个字符为独立分割单元(简化模式), 或用HMM
        如果 (属性 == 属性_CJK表意 && seg.使用HMM) {
            // 收集连续 CJK 序列
            定义 cjk开始 = 位置
            定义 cjk字符开始 = 字符索引
            定义 可变 cjk码点 = 数组_创建(256, 0)
            定义 可变 cjk偏移 = 数组_创建(256, 0)  // 各字符的字节偏移
            定义 可变 cjk数 = 0
            当 (位置 < 长度 && cjk数 < 256) {
                定义 d = UTF8_解码单字符(文本, 位置, 长度)
                定义 a = 码点_查属性(d[0])
                如果 (a != 属性_CJK表意) { 跳出 }
                cjk偏移[cjk数] = 位置
                cjk码点[cjk数] = d[0]
                cjk数 = cjk数 + 1
                位置 = 位置 + d[1]
                字符索引 = 字符索引 + 1
            }
            // HMM Viterbi分词
            定义 HMM结果 = HMM_Viterbi分词(cjk码点, cjk数)
            // 根据HMM状态序列生成片段
            定义 可变 词开始 = cjk开始
            定义 可变 词字符开始 = cjk字符开始
            定义 可变 j = 0
            当 (j < cjk数 && 计数 < 最大结果数) {
                定义 状态 = HMM结果[j]
                // E或S表示词结束
                如果 (状态 == SEG_HMM_E || 状态 == SEG_HMM_S) {
                    定义 词结束偏 = 如果 (j + 1 < cjk数) { cjk偏移[j + 1] } 否则 { 位置 }
                    如果 (结果 != 0) {
                        定义 片段 = 分割片段 {}
                        片段.起始 = 词开始
                        片段.结束 = 词结束偏
                        片段.字符起始 = 词字符开始
                        片段.字符结束 = cjk字符开始 + j + 1
                        片段.词类型 = 词类_词
                        片段.是词 = 真
                        结果[计数] = 片段
                    }
                    计数 = 计数 + 1
                    词开始 = 词结束偏
                    词字符开始 = cjk字符开始 + j + 1
                }
                j = j + 1
            }
            继续
        }

        // 拉丁/西里尔/天城等“词”字符——连续序列为一个词
        如果 (属性_是词类(属性) && 属性 != 属性_CJK表意) {
            定义 w开始 = 位置
            定义 w字符开始 = 字符索引
            定义 有数字 = (属性 == 属性_数字)
            位置 = 位置 + 解码[1]
            字符索引 = 字符索引 + 1
            当 (位置 < 长度) {
                定义 d = UTF8_解码单字符(文本, 位置, 长度)
                定义 a = 码点_查属性(d[0])
                // 词内有效字符: 同类字母/数字/扩展标记/连字符
                如果 (属性_是词类(a) && a != 属性_CJK表意) {
                    如果 (a == 属性_数字) { 有数字 = 真 }
                    位置 = 位置 + d[1]
                    字符索引 = 字符索引 + 1
                    继续
                }
                // 拉丁词中的连字符/撇号
                如果 (d[0] == 0x0027 || d[0] == 0x002D || d[0] == 0x2019) {
                    // 看下一个字符是否为字母
                    定义 下一偏 = 位置 + d[1]
                    如果 (下一偏 < 长度) {
                        定义 d2 = UTF8_解码单字符(文本, 下一偏, 长度)
                        定义 a2 = 码点_查属性(d2[0])
                        如果 (属性_是词类(a2)) {
                            位置 = 位置 + d[1]
                            字符索引 = 字符索引 + 1
                            继续
                        }
                    }
                }
                // 扩展标记继续
                如果 (a == 属性_扩展) {
                    位置 = 位置 + d[1]
                    字符索引 = 字符索引 + 1
                    继续
                }
                跳出
            }
            如果 (结果 != 0) {
                定义 片段 = 分割片段 {}
                片段.起始 = w开始
                片段.结束 = 位置
                片段.字符起始 = w字符开始
                片段.字符结束 = 字符索引
                片段.词类型 = 如果 (有数字) { 词类_数字 } 否则 { 词类_词 }
                片段.是词 = 真
                结果[计数] = 片段
            }
            计数 = 计数 + 1
            继续
        }

        // 标点/其他——单字符片段
        如果 (结果 != 0) {
            定义 片段 = 分割片段 {}
            片段.起始 = 位置
            片段.结束 = 位置 + 解码[1]
            片段.字符起始 = 字符索引
            片段.字符结束 = 字符索引 + 1
            片段.词类型 = 如果 (属性 == 属性_标点 || 属性 == 属性_句终结 || 属性 == 属性_句续行) { 词类_标点 } 否则 { 词类_无 }
            片段.是词 = 假
            结果[计数] = 片段
        }
        计数 = 计数 + 1
        位置 = 位置 + 解码[1]
        字符索引 = 字符索引 + 1
    }
    全局分割统计.总片段数 = 全局分割统计.总片段数 + 计数
    返回 计数
}

// 第八部分: HMM Viterbi分词算法
// B/M/E/S状态模型的维特比解码

函数 HMM_获取模型() {
    如果 (全局HMM模型 != 0) { 返回 全局HMM模型 }
    // 初始化默认模型参数 (统计学习预训练值)
    定义 m = HMM模型 {}
    m.初始概率 = 数组_创建(4, 0.0)
    m.初始概率[SEG_HMM_B] = -0.26268660809250016  // ln(0.769)
    m.初始概率[SEG_HMM_M] = -30.0                   // 不可能
    m.初始概率[SEG_HMM_E] = -30.0
    m.初始概率[SEG_HMM_S] = -1.4652633398537678  // ln(0.231)

    m.转移概率 = 数组_创建(16, 0.0)
    // B→M, B→E
    m.转移概率[SEG_HMM_B * 4 + SEG_HMM_M] = -0.916290731874155
    m.转移概率[SEG_HMM_B * 4 + SEG_HMM_E] = -0.510825623765991
    m.转移概率[SEG_HMM_B * 4 + SEG_HMM_B] = -30.0
    m.转移概率[SEG_HMM_B * 4 + SEG_HMM_S] = -30.0
    // M→M, M→E
    m.转移概率[SEG_HMM_M * 4 + SEG_HMM_M] = -1.2603623820268226
    m.转移概率[SEG_HMM_M * 4 + SEG_HMM_E] = -0.33344856811948514
    m.转移概率[SEG_HMM_M * 4 + SEG_HMM_B] = -30.0
    m.转移概率[SEG_HMM_M * 4 + SEG_HMM_S] = -30.0
    // E→B, E→S
    m.转移概率[SEG_HMM_E * 4 + SEG_HMM_B] = -0.510825623765991
    m.转移概率[SEG_HMM_E * 4 + SEG_HMM_S] = -0.916290731874155
    m.转移概率[SEG_HMM_E * 4 + SEG_HMM_M] = -30.0
    m.转移概率[SEG_HMM_E * 4 + SEG_HMM_E] = -30.0
    // S→B, S→S
    m.转移概率[SEG_HMM_S * 4 + SEG_HMM_B] = -0.510825623765991
    m.转移概率[SEG_HMM_S * 4 + SEG_HMM_S] = -0.916290731874155
    m.转移概率[SEG_HMM_S * 4 + SEG_HMM_M] = -30.0
    m.转移概率[SEG_HMM_S * 4 + SEG_HMM_E] = -30.0

    m.发射概率表 = 0  // 懒加载
    m.发射表大小 = 0
    全局HMM模型 = m
    返回 m
}

函数 HMM_发射概率(模型, 状态, 码点) {
    // 如果有发射表则查表, 否则用均匀发射
    如果 (模型.发射概率表 != 0) {
        定义 key = 状态 * 0x110000 + 码点
        定义 idx = key % 模型.发射表大小
        // 简化: 直接数组查找
        返回 模型.发射概率表[idx]
    }
    // 均匀发射“省略”
    返回 -3.14
}

函数 HMM_Viterbi分词(码点序列, 序列长度) {
    全局分割统计.HMM调用次数 = 全局分割统计.HMM调用次数 + 1
    如果 (序列长度 == 0) { 返回 数组_创建(0, 0) }
    定义 m = HMM_获取模型()
    定义 N = SEG_HMM状态数
    定义 T = 序列长度

    // delta[t][s] = 最优路径达到时刻t状态s的log概率
    定义 可变 delta = 数组_创建(T * N, -1e30)
    定义 可变 psi = 数组_创建(T * N, 0)

    // 初始化 t=0
    定义 可变 s = 0
    当 (s < N) {
        delta[0 * N + s] = m.初始概率[s] + HMM_发射概率(m, s, 码点序列[0])
        psi[0 * N + s] = 0
        s = s + 1
    }

    // 递推
    定义 可变 t = 1
    当 (t < T) {
        s = 0
        当 (s < N) {
            定义 可变 最优值 = -1e30
            定义 可变 最优源 = 0
            定义 可变 prev = 0
            当 (prev < N) {
                定义 v = delta[(t - 1) * N + prev] + m.转移概率[prev * N + s]
                如果 (v > 最优值) {
                    最优值 = v
                    最优源 = prev
                }
                prev = prev + 1
            }
            delta[t * N + s] = 最优值 + HMM_发射概率(m, s, 码点序列[t])
            psi[t * N + s] = 最优源
            s = s + 1
        }
        t = t + 1
    }

    // 回溯
    定义 可变 路径 = 数组_创建(T, 0)
    定义 可变 最优末 = 0
    定义 可变 最优末值 = -1e30
    s = 0
    当 (s < N) {
        如果 (delta[(T - 1) * N + s] > 最优末值) {
            最优末值 = delta[(T - 1) * N + s]
            最优末 = s
        }
        s = s + 1
    }
    路径[T - 1] = 最优末
    t = T - 2
    当 (t >= 0) {
        路径[t] = psi[(t + 1) * N + 路径[t + 1]]
        t = t - 1
    }
    返回 路径
}

// 第九部分: 句子分割

函数 分割_句子(seg, 文本, 长度, 结果, 最大结果数) {
    全局分割统计.句分割调用 = 全局分割统计.句分割调用 + 1
    定义 可变 位置 = 0
    定义 可变 字符索引 = 0
    定义 可变 计数 = 0
    定义 可变 句开始 = 0
    定义 可变 句字符开始 = 0

    当 (位置 < 长度) {
        定义 解码 = UTF8_解码单字符(文本, 位置, 长度)
        定义 cp = 解码[0]
        定义 属性 = 码点_查属性(cp)
        位置 = 位置 + 解码[1]
        字符索引 = 字符索引 + 1

        // 句终结标点
        如果 (属性 == 属性_句终结 || 属性 == 属性_CR || 属性 == 属性_LF) {
            // CR+LF合并
            如果 (属性 == 属性_CR && 位置 < 长度) {
                定义 探 = UTF8_解码单字符(文本, 位置, 长度)
                如果 (探[0] == 0x000A) {
                    位置 = 位置 + 探[1]
                    字符索引 = 字符索引 + 1
                }
            }
            // 跳过紧随的右引号/括号
            当 (位置 < 长度) {
                定义 d = UTF8_解码单字符(文本, 位置, 长度)
                如果 (d[0] == 0x201D || d[0] == 0x0022 || d[0] == 0x0029 ||
                    d[0] == 0x300D || d[0] == 0x300F || d[0] == 0xFF09) {
                    位置 = 位置 + d[1]
                    字符索引 = 字符索引 + 1
                } 否则 {
                    跳出
                }
            }
            // 口语缩略检测: “Mr.”/“Dr.”等不断句
            // (如果句终结符后紧跟大写字母则断句, 否则可能是缩略)
            定义 确实断句 = 真
            如果 (属性 == 属性_句终结 && cp == 0x002E && 位置 < 长度) {
                定义 探 = UTF8_解码单字符(文本, 位置, 长度)
                定义 探属 = 码点_查属性(探[0])
                // 句点后紧跟小写字母→可能是缩略, 不断句
                如果 (探属 == 属性_拉丁字母 && 探[0] >= 0x0061 && 探[0] <= 0x007A) {
                    确实断句 = 假
                }
            }
            如果 (确实断句 && 计数 < 最大结果数) {
                如果 (结果 != 0) {
                    定义 片段 = 分割片段 {}
                    片段.起始 = 句开始
                    片段.结束 = 位置
                    片段.字符起始 = 句字符开始
                    片段.字符结束 = 字符索引
                    片段.词类型 = 词类_词
                    片段.是词 = 真
                    结果[计数] = 片段
                }
                计数 = 计数 + 1
                句开始 = 位置
                句字符开始 = 字符索引
            }
        }
    }
    // 末尾残余
    如果 (位置 > 句开始 && 计数 < 最大结果数) {
        如果 (结果 != 0) {
            定义 片段 = 分割片段 {}
            片段.起始 = 句开始
            片段.结束 = 位置
            片段.字符起始 = 句字符开始
            片段.字符结束 = 字符索引
            片段.词类型 = 词类_词
            片段.是词 = 真
            结果[计数] = 片段
        }
        计数 = 计数 + 1
    }
    全局分割统计.总片段数 = 全局分割统计.总片段数 + 计数
    返回 计数
}

// 第十部分: 统一分割入口 + 迭代器API

函数 Segmenter_segment(seg, 文本, 长度, 结果, 最大结果数) {
    如果 (seg == 0 || 文本 == 0 || 长度 == 0) { 返回 0 }
    定义 开始 = 系统_获取微秒()
    全局分割统计.总调用次数 = 全局分割统计.总调用次数 + 1
    全局分割统计.总字符数 = 全局分割统计.总字符数 + 长度

    定义 可变 计数 = 0
    匹配 (seg.粒度) {
        SEG_GRAPHEME => { 计数 = 分割_字素簇(文本, 长度, 结果, 最大结果数) }
        SEG_WORD     => { 计数 = 分割_词(seg, 文本, 长度, 结果, 最大结果数) }
        SEG_SENTENCE => { 计数 = 分割_句子(seg, 文本, 长度, 结果, 最大结果数) }
        SEG_LINE     => { 计数 = 分割_行断(seg, 文本, 长度, 结果, 最大结果数) }
    }

    定义 耗时 = 系统_获取微秒() - 开始
    定义 n = 全局分割统计.总调用次数
    全局分割统计.平均耗时微秒 =
        (全局分割统计.平均耗时微秒 * (n - 1) + 耗时) / n
    返回 计数
}

函数 分割_行断(seg, 文本, 长度, 结果, 最大结果数) {
    // UAX#14简化: 在空格/标点/CJK字符后断行
    全局分割统计.行断调用 = 全局分割统计.行断调用 + 1
    定义 可变 位置 = 0
    定义 可变 字符索引 = 0
    定义 可变 计数 = 0
    定义 可变 段开始 = 0
    定义 可变 段字符开始 = 0

    当 (位置 < 长度 && 计数 < 最大结果数) {
        定义 解码 = UTF8_解码单字符(文本, 位置, 长度)
        定义 属性 = 码点_查属性(解码[0])
        位置 = 位置 + 解码[1]
        字符索引 = 字符索引 + 1

        定义 可断 = 假
        // 强制断行: CR/LF
        如果 (属性 == 属性_CR || 属性 == 属性_LF) {
            如果 (属性 == 属性_CR && 位置 < 长度) {
                定义 探 = UTF8_解码单字符(文本, 位置, 长度)
                如果 (探[0] == 0x000A) { 位置 = 位置 + 探[1]; 字符索引 = 字符索引 + 1 }
            }
            可断 = 真
        }
        // 空格后可断
        如果 (属性 == 属性_空格) { 可断 = 真 }
        // CJK表意字符后可断
        如果 (属性 == 属性_CJK表意) { 可断 = 真 }
        // 句终结标点后可断
        如果 (属性 == 属性_句终结 || 属性 == 属性_句续行) { 可断 = 真 }

        如果 (可断) {
            如果 (结果 != 0) {
                定义 片段 = 分割片段 {}
                片段.起始 = 段开始
                片段.结束 = 位置
                片段.字符起始 = 段字符开始
                片段.字符结束 = 字符索引
                片段.词类型 = 词类_无
                片段.是词 = 假
                结果[计数] = 片段
            }
            计数 = 计数 + 1
            段开始 = 位置
            段字符开始 = 字符索引
        }
    }
    如果 (位置 > 段开始 && 计数 < 最大结果数) {
        如果 (结果 != 0) {
            定义 片段 = 分割片段 {}
            片段.起始 = 段开始
            片段.结束 = 位置
            片段.字符起始 = 段字符开始
            片段.字符结束 = 字符索引
            片段.词类型 = 词类_无
            片段.是词 = 假
            结果[计数] = 片段
        }
        计数 = 计数 + 1
    }
    返回 计数
}

// 迭代器API
函数 Segmenter_创建迭代器(seg, 文本, 长度) {
    定义 迭 = 分割迭代器 {}
    迭.seg = seg
    迭.文本 = 文本
    迭.文本长度 = 长度
    迭.片段数组 = 数组_创建(SEG_最大结果数, 0)
    迭.片段数量 = Segmenter_segment(seg, 文本, 长度, 迭.片段数组, SEG_最大结果数)
    迭.当前索引 = 0
    返回 迭
}

函数 迭代器_下一个(迭) {
    如果 (迭.当前索引 >= 迭.片段数量) { 返回 空 }
    定义 片段 = 迭.片段数组[迭.当前索引]
    迭.当前索引 = 迭.当前索引 + 1
    返回 片段
}

函数 迭代器_包含(迭, 偏移) {
    定义 可变 i = 0
    当 (i < 迭.片段数量) {
        定义 片 = 迭.片段数组[i]
        如果 (偏移 >= 片.起始 && 偏移 < 片.结束) {
            返回 片
        }
        i = i + 1
    }
    返回 空
}

函数 迭代器_前一个(迭, 偏移) {
    定义 可变 i = 迭.片段数量 - 1
    当 (i >= 0) {
        定义 片 = 迭.片段数组[i]
        如果 (片.结束 <= 偏移) { 返回 片 }
        i = i - 1
    }
    返回 空
}

函数 迭代器_后一个(迭, 偏移) {
    定义 可变 i = 0
    当 (i < 迭.片段数量) {
        定义 片 = 迭.片段数组[i]
        如果 (片.起始 >= 偏移) { 返回 片 }
        i = i + 1
    }
    返回 空
}

// 第十一部分: MLSPT AI智能分段优化
// 多语言分割预测理论: 基于字符属性迁移矩阵与跨书写系统边界张量

函数 MLSPT_构建特征(文本, 长度, 粒度) {
    定义 可变 特征 = 数组_创建(MLSPT_特征维度, 0.0)
    // 基本特征
    特征[0] = 长度
    特征[1] = 粒度

    // 字符属性分布统计
    定义 可变 拉丁数 = 0
    定义 可变 CJK数 = 0
    定义 可变 空格数 = 0
    定义 可变 标点数 = 0
    定义 可变 其他数 = 0
    定义 可变 书写转换数 = 0
    定义 可变 上一属性 = -1
    定义 可变 位置 = 0
    定义 可变 总字符 = 0
    当 (位置 < 长度 && 总字符 < 500) {
        定义 解码 = UTF8_解码单字符(文本, 位置, 长度)
        定义 属性 = 码点_查属性(解码[0])
        匹配 (属性) {
            属性_拉丁字母 => { 拉丁数 = 拉丁数 + 1 }
            属性_CJK表意 => { CJK数 = CJK数 + 1 }
            属性_空格   => { 空格数 = 空格数 + 1 }
            属性_标点   => { 标点数 = 标点数 + 1 }
            _           => { 其他数 = 其他数 + 1 }
        }
        如果 (上一属性 >= 0 && 属性 != 上一属性) {
            书写转换数 = 书写转换数 + 1
        }
        上一属性 = 属性
        位置 = 位置 + 解码[1]
        总字符 = 总字符 + 1
    }
    如果 (总字符 > 0) {
        特征[2] = 拉丁数 * 1.0 / 总字符
        特征[3] = CJK数 * 1.0 / 总字符
        特征[4] = 空格数 * 1.0 / 总字符
        特征[5] = 标点数 * 1.0 / 总字符
        特征[6] = 书写转换数 * 1.0 / 总字符
    }
    // 全局历史特征
    定义 可变 样本 = 如果 (MLSPT_历史写指针 < MLSPT_缓存窗口) { MLSPT_历史写指针 } 否则 { MLSPT_缓存窗口 }
    如果 (样本 > 0) {
        定义 可变 耗时和 = 0.0
        定义 可变 片和 = 0.0
        定义 可变 i = 0
        当 (i < 样本) {
            耗时和 = 耗时和 + MLSPT_耗时历史[i]
            片和 = 片和 + MLSPT_片段历史[i]
            i = i + 1
        }
        特征[7] = 耗时和 / 样本
        特征[8] = 片和 / 样本
    }
    特征[9] = 全局分割统计.总调用次数
    特征[10] = 全局分割统计.总字符数
    特征[11] = 全局分割统计.总片段数
    特征[12] = 全局分割统计.缓存命中数
    特征[13] = 全局分割统计.HMM调用次数
    特征[14] = 总字符
    特征[15] = 书写转换数
    返回 特征
}

函数 MLSPT_AI优化分割(seg, 文本, 长度, 粗分结果, 粗分数量) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 粗分数量 }
    全局分割统计.AI调用次数 = 全局分割统计.AI调用次数 + 1

    定义 特征 = MLSPT_构建特征(文本, 长度, seg.粒度)
    定义 张量 = Tensor_创建(1, MLSPT_特征维度)
    定义 可变 i = 0
    当 (i < MLSPT_特征维度) {
        Tensor_写(张量, 0, i, 特征[i])
        i = i + 1
    }
    定义 预测 = AI总线_推理("MLSPT_分段优化", 张量)
    Tensor_释放(张量)
    如果 (预测.置信度 < MLSPT_置信阈值) { 返回 粗分数量 }

    // AI建议: 输出向量 [0]=合并开关 [1]=合并阈值
    定义 合并 = 预测.输出向量[0]
    如果 (合并 < 0.5) { 返回 粗分数量 }

    // 合并相邻非词片段
    定义 可变 新计数 = 0
    i = 0
    当 (i < 粗分数量) {
        定义 当前 = 粗分结果[i]
        如果 (i + 1 < 粗分数量 && !当前.是词 && !粗分结果[i + 1].是词) {
            // 合并
            定义 合 = 分割片段 {}
            合.起始 = 当前.起始
            合.结束 = 粗分结果[i + 1].结束
            合.字符起始 = 当前.字符起始
            合.字符结束 = 粗分结果[i + 1].字符结束
            合.词类型 = 当前.词类型
            合.是词 = 假
            粗分结果[新计数] = 合
            新计数 = 新计数 + 1
            i = i + 2
        } 否则 {
            粗分结果[新计数] = 当前
            新计数 = 新计数 + 1
            i = i + 1
        }
    }
    返回 新计数
}

// 第十二部分: AI语言检测与翻译提示

函数 智能_Intl_检测语言(文本, 长度) {
    如果 (文本 == 0 || 长度 == 0) { 返回 "en" }
    // 统计字符属性分布
    定义 可变 拉丁数 = 0
    定义 可变 CJK数 = 0
    定义 可变 西里尔数 = 0
    定义 可变 阿拉伯数 = 0
    定义 可变 天城数 = 0
    定义 可变 韩文数 = 0
    定义 可变 总计 = 0
    定义 可变 pos = 0
    当 (pos < 长度 && 总计 < 200) {
        定义 d = UTF8_解码单字符(文本, pos, 长度)
        定义 a = 码点_查属性(d[0])
        匹配 (a) {
            属性_拉丁字母 => { 拉丁数 = 拉丁数 + 1 }
            属性_CJK表意 => { CJK数 = CJK数 + 1 }
            属性_西里尔 => { 西里尔数 = 西里尔数 + 1 }
            属性_阿拉伯 => { 阿拉伯数 = 阿拉伯数 + 1 }
            属性_天城   => { 天城数 = 天城数 + 1 }
            属性_韩文L | 属性_韩文V | 属性_韩文T |
            属性_韩文LV | 属性_韩文LVT => { 韩文数 = 韩文数 + 1 }
        }
        总计 = 总计 + 1
        pos = pos + d[1]
    }
    // 按最高比例判断
    如果 (CJK数 > 拉丁数 && CJK数 > 西里尔数) { 返回 "zh" }
    如果 (西里尔数 > 拉丁数) { 返回 "ru" }
    如果 (阿拉伯数 > 拉丁数) { 返回 "ar" }
    如果 (天城数 > 拉丁数) { 返回 "hi" }
    如果 (韩文数 > 拉丁数) { 返回 "ko" }
    // AI进一步细化(区分en/fr/de/es等拉丁语族)
    定义 bus = 全局AI总线
    如果 (bus != 0) {
        定义 张量 = Tensor_创建(1, 8)
        Tensor_写(张量, 0, 0, 拉丁数)
        Tensor_写(张量, 0, 1, CJK数)
        Tensor_写(张量, 0, 2, 西里尔数)
        Tensor_写(张量, 0, 3, 阿拉伯数)
        Tensor_写(张量, 0, 4, 天城数)
        Tensor_写(张量, 0, 5, 韩文数)
        Tensor_写(张量, 0, 6, 总计)
        Tensor_写(张量, 0, 7, 长度)
        定义 预测 = AI总线_推理("MLSPT_语言检测", 张量)
        Tensor_释放(张量)
        如果 (预测.置信度 > 0.8) {
            返回 预测.标签
        }
    }
    返回 "en"
}

函数 智能_Intl_翻译提示(文本, 源语言, 目标语言) {
    如果 (文本 == 0) { 返回 0 }
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 0 }
    定义 长度 = 字符串长度(文本)
    定义 张量 = Tensor_创建(1, 长度 + 2)
    Tensor_写(张量, 0, 0, 哈希_字符串(源语言))
    Tensor_写(张量, 0, 1, 哈希_字符串(目标语言))
    定义 可变 i = 0
    当 (i < 长度) {
        Tensor_写(张量, 0, i + 2, 字节取(文本, i))
        i = i + 1
    }
    定义 预测 = AI总线_推理("MLSPT_翻译", 张量)
    Tensor_释放(张量)
    如果 (预测.置信度 > 0.5) {
        返回 预测.翻译结果
    }
    返回 0
}

// 第十三部分: 统计与诊断

函数 Segmenter_获取统计() {
    返回 {
        总调用: 全局分割统计.总调用次数,
        总字符: 全局分割统计.总字符数,
        总片段: 全局分割统计.总片段数,
        字素簇调用: 全局分割统计.字素簇调用,
        词分割: 全局分割统计.词分割调用,
        句分割: 全局分割统计.句分割调用,
        行断: 全局分割统计.行断调用,
        HMM调用: 全局分割统计.HMM调用次数,
        缓存命中: 全局分割统计.缓存命中数,
        AI调用: 全局分割统计.AI调用次数,
        平均耗时微秒: 全局分割统计.平均耗时微秒
    }
}

函数 Segmenter_打印统计() {
    内核打印("═══ Intl.Segmenter 统计 ═══")
    内核打印("总调用={} 总字符={} 总片段={}",
        全局分割统计.总调用次数, 全局分割统计.总字符数,
        全局分割统计.总片段数)
    内核打印("字素簇={} 词={} 句={} 行断={}",
        全局分割统计.字素簇调用, 全局分割统计.词分割调用,
        全局分割统计.句分割调用, 全局分割统计.行断调用)
    内核打印("HMM={} 缓存命中={} AI={} 平均={}us",
        全局分割统计.HMM调用次数, 全局分割统计.缓存命中数,
        全局分割统计.AI调用次数, 全局分割统计.平均耗时微秒)
}

函数 Segmenter_重置统计() {
    全局分割统计 = 分割统计 {}
}

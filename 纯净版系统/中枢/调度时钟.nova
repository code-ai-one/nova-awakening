//   1. sched_clock(): 高精度单调递增时钟(纳秒)
//   2. per-CPU: 每个CPU独立的调度时钟(避免TSC漂移问题)
//   3. 稳定化: sched_clock_stable标志, 不稳定时用jiffies校正
//   4. 用途: Nova公平调度 Nova虚拟运行时间计算/进程运行时间记账/负载追踪

定义 可变 调度时钟_上次 = 0
定义 可变 调度时钟_偏移 = 0
定义 可变 调度时钟_稳定 = 真
定义 可变 调度时钟_CPU时钟 = []  // per-CPU

// sched_clock: 读取调度时钟(纳秒, 单调递增)

函数 sched_clock_调度() {
    定义 现在 = 读取纳秒()
    // 保证单调递增(TSC可能回退: 频率切换/休眠恢复)
    如果 (现在 < 调度时钟_上次) {
        现在 = 调度时钟_上次
    }
    调度时钟_上次 = 现在
    返回 现在 + 调度时钟_偏移
}

函数 调度时钟_读取() { 返回 sched_clock() }

函数 调度时钟_更新() {
    调度时钟_上次 = 读取纳秒()
}

函数 调度时钟_经过(起始) {
    返回 sched_clock() - 起始
}

// 调度器tick 
// 由定时器中断每tick调用

函数 调度器_tick_时钟() {
    定义 rq = 当前CPU运行队列()
    如果 (rq == 空) { 返回 }
    定义 当前 = 运行队列_当前(rq)
    如果 (当前 == 空) { 返回 }

    // 1. 更新运行队列时钟
    运行队列_更新时钟(rq)

    // 2. 更新当前进程运行时间
    定义 delta = sched_clock() - 进程_上次调度时间(当前)
    进程_累加运行时间(当前, delta)
    进程_设置上次调度时间(当前, sched_clock())

    // 3. Nova公平调度: 更新Nova虚拟运行时间 
    定义 调度类 = 进程_调度类(当前)
    如果 (调度类 == 调度类_Nova公平调度) {
        Nova公平调度_update_curr(rq, delta_ns)
        // 检查是否需要抢占(当前进程Nova虚拟运行时间远超最左节点)
        如果 (Nova公平调度_需要抢占(rq)) {
            进程_设置需要调度(当前)
        }
    }

    // 4. RT: 检查时间片是否耗尽
    如果 (调度类 == 调度类_RT) {
        定义 剩余 = 进程_RT时间片(当前)
        如果 (剩余 <= 0) {
            进程_设置需要调度(当前)
        }
    }

    // 5. 更新负载统计 (Nova负载追踪: Per-Entity Load Tracking)
    定义 运行任务数 = 运行队列_可运行数(获取当前CPU())
    负载统计_更新(获取当前CPU(), 运行任务数)

    // 6. 更新Nova负载均值 (每5秒)
    负载统计_更新Nova负载均值()

    // 7. 记录上下文切换统计
    stat_记录内核态()

    // 8. 工作队列tick驱动
    工作队列_tick()
}

// 进程运行时间记账

函数 进程_累加运行时间(进程, delta_ns) {
    如果 (进程 == 空 || delta_ns <= 0) { 返回 }
    // 区分用户态时间和内核态时间
    // 通过检查中断帧的CS段判断: RPL=3→用户态, RPL=0→内核态
    如果 (进程_在用户态(进程)) {
        进程_增加用户时间(进程, delta_ns)
        stat_记录用户态()
    } 否则 {
        进程_增加内核时间(进程, delta_ns)
        stat_记录内核态()
    }
}

函数 进程_在用户态(进程) {
    // 检查进程被中断时是否在用户态
    // 通过保存的CS段选择子的RPL位判断
    如果 (进程 == 空) { 返回 假 }
    返回 (进程.保存的CS & 3) == 3   // RPL=3 → 用户态
}

函数 进程_增加用户时间(进程, ns) {
    如果 (进程 != 空) { 进程.utime = 进程.utime + ns }
}

函数 进程_增加内核时间(进程, ns) {
    如果 (进程 != 空) { 进程.stime = 进程.stime + ns }
}

函数 运行队列_可运行数(cpu) { 返回 1 }

// 初始化

函数 调度时钟_初始化() {
    调度时钟_上次 = 读取纳秒()
    调度时钟_偏移 = 0
    调度时钟_稳定 = 真
    内核信息("调度时钟: 初始化 (TSC)")
}

// 便捷

函数 local_clock() { 返回 sched_clock() }
函数 cpu_clock(cpu) { 返回 sched_clock() }

定义 调度类_Nova公平调度 = 3
定义 调度类_RT  = 2
定义 调度类_DL  = 1    // Deadline调度类
定义 调度类_IDLE = 5   // Idle调度类

// TSC稳定性检测 

定义 可变 TSC_不稳定_次数 = 0

函数 调度时钟_检测稳定性() {
    定义 t1 = 读取纳秒()
    暂停()
    定义 t2 = 读取纳秒()
    如果 (t2 < t1) {
        TSC_不稳定_次数 = TSC_不稳定_次数 + 1
        如果 (TSC_不稳定_次数 > 10) {
            调度时钟_稳定 = 假
            内核警告("调度时钟: TSC不稳定, 切换到jiffies校正模式")
        }
    }
}

函数 调度时钟_是稳定() { 返回 调度时钟_稳定 }

// 运行队列时钟 

定义 可变 rq_clock_值 = 0
定义 可变 rq_clock_task_值 = 0

函数 运行队列时钟_更新(rq) {
    定义 现在 = sched_clock()
    rq_clock_值 = 现在
    // rq_clock_task 排除中断时间
    rq_clock_task_值 = 现在
}

函数 rq_clock() { 返回 rq_clock_值 }
函数 rq_clock_task() { 返回 rq_clock_task_值 }

// 时间戳差值工具

函数 ns_to_us(ns) { 返回 ns / 1000 }
函数 ns_to_ms(ns) { 返回 ns / 1000000 }
函数 us_to_ns(us) { 返回 us * 1000 }
函数 ms_to_ns(ms) { 返回 ms * 1000000 }

函数 调度时钟_统计() {
    返回 [调度时钟_上次, 调度时钟_稳定, TSC_不稳定_次数, rq_clock_值]
}

// 调度类名称 + 时钟校准

函数 调度类名(类) {
    如果 (类 == 调度类_DL) { 返回 "DEADLINE" }
    如果 (类 == 调度类_RT) { 返回 "RT" }
    如果 (类 == 调度类_Nova公平调度) { 返回 "Nova公平调度" }
    如果 (类 == 调度类_IDLE) { 返回 "IDLE" }
    返回 "UNKNOWN"
}

函数 调度时钟_校准(偏移ns) {
    调度时钟_偏移 = 调度时钟_偏移 + 偏移ns
}

函数 调度时钟_运行时间_ms() {
    返回 ns_to_ms(sched_clock_调度())
}

// NovaOS x86-64 寄存器定义
// CR0/CR4/EFLAGS/MSR/PTE/GDT/IDT/TSS/CPUID/APIC

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/内存初始化.nova")

定义 CR0_PE = 1          // 保护模式使能
定义 CR0_MP = 1 << 1     // 协处理器监控
定义 CR0_EM = 1 << 2     // 仿真
定义 CR0_TS = 1 << 3     // 任务切换
定义 CR0_ET = 1 << 4     // 扩展类型
定义 CR0_NE = 1 << 5     // 数字错误
定义 CR0_WP = 1 << 16    // 写保护
定义 CR0_AM = 1 << 18    // 对齐检查
定义 CR0_NW = 1 << 29    // 非直写
定义 CR0_CD = 1 << 30    // 缓存禁止
定义 CR0_PG = 1 << 31    // 分页使能

定义 CR4_VME = 1 << 0    // 虚拟8086模式扩展
定义 CR4_PVI = 1 << 1    // 保护模式虚拟中断
定义 CR4_TSD = 1 << 2    // 时间戳禁用
定义 CR4_DE = 1 << 3     // 调试扩展
定义 CR4_PSE = 1 << 4    // 页大小扩展
定义 CR4_PAE = 1 << 5    // 物理地址扩展
定义 CR4_MCE = 1 << 6    // 机器检查异常
定义 CR4_PGE = 1 << 7    // 全局页使能
定义 CR4_PCE = 1 << 8    // 性能计数器使能
定义 CR4_OSFXSR = 1 << 9 // SSE支持
定义 CR4_OSXMMEXCPT = 1 << 10  // SSE异常
定义 CR4_UMIP = 1 << 11  // 用户模式指令防护
定义 CR4_FSGSBASE = 1 << 16    // FS/GS BASE指令
定义 CR4_PCIDE = 1 << 17 // 进程上下文标识符
定义 CR4_OSXSAVE = 1 << 18     // XSAVE使能
定义 CR4_SMEP = 1 << 20  // 管理模式执行保护
定义 CR4_SMAP = 1 << 21  // 管理模式访问保护
定义 CR4_PKE = 1 << 22   // 保护键使能

定义 EFLAGS_CF = 1 << 0  // 进位
定义 EFLAGS_PF = 1 << 2  // 奇偶
定义 EFLAGS_AF = 1 << 4  // 辅助进位
定义 EFLAGS_ZF = 1 << 6  // 零
定义 EFLAGS_SF = 1 << 7  // 符号
定义 EFLAGS_TF = 1 << 8  // 单步
定义 EFLAGS_IF = 1 << 9  // 中断使能
定义 EFLAGS_DF = 1 << 10 // 方向
定义 EFLAGS_OF = 1 << 11 // 溢出
定义 EFLAGS_IOPL_MASK = 3 << 12
定义 EFLAGS_NT = 1 << 14 // 嵌套任务
定义 EFLAGS_RF = 1 << 16 // 恢复
定义 EFLAGS_VM = 1 << 17 // 虚拟8086
定义 EFLAGS_AC = 1 << 18 // 对齐检查
定义 EFLAGS_VIF = 1 << 19 // 虚拟中断标志
定义 EFLAGS_VIP = 1 << 20 // 虚拟中断待处理
定义 EFLAGS_ID = 1 << 21 // CPUID支持

// §1 MSR 地址

定义 MSR_EFER = 0xC0000080       // 扩展功能使能寄存器
定义 MSR_STAR = 0xC0000081       // Nova系统调用目标地址
定义 MSR_LSTAR = 0xC0000082      // 长模式Nova系统调用入口
定义 MSR_CSTAR = 0xC0000083      // 兼容模式系统调用入口
定义 MSR_SFMASK = 0xC0000084     // Nova系统调用标志掩码
定义 MSR_FS_BASE = 0xC0000100    // FS段基址
定义 MSR_GS_BASE = 0xC0000101    // GS段基址
定义 MSR_KERNEL_GS_BASE = 0xC0000102  // 内核GS基址
定义 MSR_接口C_BASE = 0x1B        // 接口C基址寄存器
定义 MSR_TSC = 0x10              // 时间戳计数器
定义 MSR_TSC_AUX = 0xC0000103    // TSC辅助
定义 MSR_MTRR_DEF_TYPE = 0x2FF   // MTRR默认类型
定义 MSR_PAT = 0x277             // 页属性表
定义 MSR_PERF_CTL = 0x199        // 性能控制
定义 MSR_PERF_STATUS = 0x198     // 性能状态
定义 MSR_MISC_ENABLE = 0x1A0     // 杂项使能

定义 EFER_SCE = 1        // Nova系统调用使能
定义 EFER_LME = 1 << 8   // 长模式使能
定义 EFER_LMA = 1 << 10  // 长模式激活
定义 EFER_NXE = 1 << 11  // NX位使能

// §2 CPUID 特性标志

// CPUID(1).EDX
定义 CPUID_FPU = 1 << 0
定义 CPUID_VME = 1 << 1
定义 CPUID_DE = 1 << 2
定义 CPUID_PSE = 1 << 3
定义 CPUID_TSC = 1 << 4
定义 CPUID_MSR = 1 << 5
定义 CPUID_PAE = 1 << 6
定义 CPUID_MCE = 1 << 7
定义 CPUID_CX8 = 1 << 8
定义 CPUID_APIC = 1 << 9
定义 CPUID_SEP = 1 << 11
定义 CPUID_MTRR = 1 << 12
定义 CPUID_PGE = 1 << 13
定义 CPUID_MCA = 1 << 14
定义 CPUID_CMOV = 1 << 15
定义 CPUID_PAT = 1 << 16
定义 CPUID_PSE36 = 1 << 17
定义 CPUID_CLFSH = 1 << 19
定义 CPUID_MMX = 1 << 23
定义 CPUID_FXSR = 1 << 24
定义 CPUID_SSE = 1 << 25
定义 CPUID_SSE2 = 1 << 26
定义 CPUID_HTT = 1 << 28

// CPUID(1).ECX
定义 CPUID_SSE3 = 1 << 0
定义 CPUID_PCLMUL = 1 << 1
定义 CPUID_SSSE3 = 1 << 9
定义 CPUID_SSE41 = 1 << 19
定义 CPUID_SSE42 = 1 << 20
定义 CPUID_X2APIC = 1 << 21
定义 CPUID_POPCNT = 1 << 23
定义 CPUID_AES = 1 << 25
定义 CPUID_XSAVE = 1 << 26
定义 CPUID_OSXSAVE = 1 << 27
定义 CPUID_AVX = 1 << 28

// CPUID(7,0).EBX
定义 CPUID_FSGSBASE = 1 << 0
定义 CPUID_BMI1 = 1 << 3
定义 CPUID_AVX2 = 1 << 5
定义 CPUID_SMEP_BIT = 1 << 7
定义 CPUID_BMI2 = 1 << 8
定义 CPUID_INVPCID = 1 << 10
定义 CPUID_SMAP_BIT = 1 << 20
定义 CPUID_CLFLUSHOPT = 1 << 23

// CPUID(0x80000001).EDX
定义 CPUID_NX = 1 << 20
定义 CPUID_PDPE1GB = 1 << 26  // 1GB大页
定义 CPUID_LM = 1 << 29       // 长模式

// §3 页表标志

定义 PTE_存在 = 1 << 0
定义 PTE_可写 = 1 << 1
定义 PTE_用户 = 1 << 2
定义 PTE_写通 = 1 << 3
定义 PTE_禁缓存 = 1 << 4
定义 PTE_已访问 = 1 << 5
定义 PTE_脏 = 1 << 6
定义 PTE_大页 = 1 << 7
定义 PTE_全局 = 1 << 8
定义 PTE_NX = 1 << 63

// 组合PTE标志
定义 PTE_内核读写 = PTE_存在 | PTE_可写
定义 PTE_内核只读 = PTE_存在
定义 PTE_用户读写 = PTE_存在 | PTE_可写 | PTE_用户
定义 PTE_用户只读 = PTE_存在 | PTE_用户
定义 PTE_用户读写_NX = PTE_存在 | PTE_可写 | PTE_用户 | PTE_NX

// §4 GDT选择子

定义 GDT_NULL = 0
定义 GDT_内核代码 = 0x08
定义 GDT_内核数据 = 0x10
定义 GDT_用户代码 = 0x18
定义 GDT_用户数据 = 0x20
定义 GDT_TSS = 0x28

定义 RPL_内核 = 0
定义 RPL_用户 = 3

定义 段_代码_读执行 = 0x9A
定义 段_数据_读写 = 0x92
定义 段_长模式 = 0x20
定义 段_粒度_4K = 0x80
定义 段_DPL0 = 0x00
定义 段_DPL3 = 0x60

// §5 IDT 门类型

定义 IDT_中断门 = 0x8E     // P=1, DPL=0, 中断门
定义 IDT_陷阱门 = 0x8F     // P=1, DPL=0, 陷阱门
定义 IDT_用户中断门 = 0xEE // P=1, DPL=3, 中断门
定义 IDT_任务门 = 0x85     // P=1, DPL=0, 任务门

// §6 中断向量

定义 异常_除零 = 0
定义 异常_调试 = 1
定义 异常_NMI = 2
定义 异常_断点 = 3
定义 异常_溢出 = 4
定义 异常_越界 = 5
定义 异常_无效指令 = 6
定义 异常_设备不可用 = 7
定义 异常_双重错误 = 8
定义 异常_无效TSS = 10
定义 异常_段不存在 = 11
定义 异常_栈段错误 = 12
定义 异常_一般保护 = 13
定义 异常_缺页 = 14
定义 异常_x87浮点 = 16
定义 异常_对齐检查 = 17
定义 异常_机器检查 = 18
定义 异常_SIMD = 19

定义 IRQ_基 = 32
定义 IRQ_定时器 = 32
定义 IRQ_键盘 = 33
定义 IRQ_级联 = 34
定义 IRQ_串口2 = 35
定义 IRQ_串口1 = 36
定义 IRQ_软盘 = 38
定义 IRQ_RTC = 40
定义 IRQ_鼠标 = 44
定义 IRQ_磁盘1 = 46
定义 IRQ_磁盘2 = 47

定义 向量_系统调用 = 0x80
定义 向量_APIC定时器 = 0xFE
定义 向量_APIC伪中断 = 0xFF

// §7 TSS 偏移

定义 TSS_RSP0 = 4
定义 TSS_RSP1 = 12
定义 TSS_RSP2 = 20
定义 TSS_IST1 = 36
定义 TSS_IST2 = 44
定义 TSS_IST3 = 52
定义 TSS_IST4 = 60
定义 TSS_IST5 = 68
定义 TSS_IST6 = 76
定义 TSS_IST7 = 84
定义 TSS_IOPB = 102
定义 TSS_大小 = 104

// §8 APIC 常量

定义 APIC_基址 = 0xFEE00000
定义 APIC_ID = 0x020
定义 APIC_版本 = 0x030
定义 APIC_TPR = 0x080
定义 APIC_EOI = 0x0B0
定义 APIC_SVR = 0x0F0
定义 APIC_ICR_LOW = 0x300
定义 APIC_ICR_HIGH = 0x310
定义 APIC_LVT_定时器 = 0x320
定义 APIC_LVT_LINT0 = 0x350
定义 APIC_LVT_LINT1 = 0x360
定义 APIC_LVT_错误 = 0x370
定义 APIC_初始计数 = 0x380
定义 APIC_当前计数 = 0x390
定义 APIC_分频 = 0x3E0

定义 APIC_SVR_使能 = 0x100
定义 APIC_定时器_周期 = 0x20000
定义 APIC_定时器_单次 = 0x00000
定义 APIC_定时器_TSC截止 = 0x40000

// §9 寄存器读写辅助

函数 读CR0() { 返回 __asm_读寄存器("cr0") }
函数 写CR0(值) { __asm_写寄存器("cr0", 值) }
函数 读CR2() { 返回 __asm_读寄存器("cr2") }
函数 读CR3() { 返回 __asm_读寄存器("cr3") }
函数 写CR3(值) { __asm_写寄存器("cr3", 值) }
函数 读CR4() { 返回 __asm_读寄存器("cr4") }
函数 写CR4(值) { __asm_写寄存器("cr4", 值) }

函数 读MSR(地址) { 返回 __asm_rdmsr(地址) }
函数 写MSR(地址, 值) { __asm_wrmsr(地址, 值) }

函数 读TSC() { 返回 __asm_rdtsc() }

函数 APIC_读(偏移) {
    返回 内存_读32(APIC_基址 + 偏移)
}

函数 APIC_写(偏移, 值) {
    内存_写32(APIC_基址 + 偏移, 值)
}

函数 APIC_发送EOI() {
    APIC_写(APIC_EOI, 0)
}

// §10 CPUID检测辅助

定义 可变 cpuid_edx_1 = 0
定义 可变 cpuid_ecx_1 = 0
定义 可变 cpuid_ebx_7 = 0
定义 可变 cpuid_edx_ext = 0
定义 可变 cpuid_已检测 = 假

函数 CPUID_检测() {
    如果 (cpuid_已检测) { 返回 }
    cpuid_edx_1 = __asm_cpuid(1, 3)   // EAX=1, 取EDX
    cpuid_ecx_1 = __asm_cpuid(1, 2)   // EAX=1, 取ECX
    cpuid_ebx_7 = __asm_cpuid_sub(7, 0, 1)  // EAX=7,ECX=0, 取EBX
    cpuid_edx_ext = __asm_cpuid(0x80000001, 3)
    cpuid_已检测 = 真
}

函数 CPU_有SSE() { CPUID_检测()  返回 (cpuid_edx_1 & CPUID_SSE) != 0 }
函数 CPU_有SSE2() { CPUID_检测()  返回 (cpuid_edx_1 & CPUID_SSE2) != 0 }
函数 CPU_有SSE3() { CPUID_检测()  返回 (cpuid_ecx_1 & CPUID_SSE3) != 0 }
函数 CPU_有AVX() { CPUID_检测()  返回 (cpuid_ecx_1 & CPUID_AVX) != 0 }
函数 CPU_有AVX2() { CPUID_检测()  返回 (cpuid_ebx_7 & CPUID_AVX2) != 0 }
函数 CPU_有NX() { CPUID_检测()  返回 (cpuid_edx_ext & CPUID_NX) != 0 }
函数 CPU_有1G大页() { CPUID_检测()  返回 (cpuid_edx_ext & CPUID_PDPE1GB) != 0 }
函数 CPU_有长模式() { CPUID_检测()  返回 (cpuid_edx_ext & CPUID_LM) != 0 }
函数 CPU_有APIC() { CPUID_检测()  返回 (cpuid_edx_1 & CPUID_APIC) != 0 }
函数 CPU_有X2APIC() { CPUID_检测()  返回 (cpuid_ecx_1 & CPUID_X2APIC) != 0 }
函数 CPU_有XSAVE() { CPUID_检测()  返回 (cpuid_ecx_1 & CPUID_XSAVE) != 0 }
函数 CPU_有FSGSBASE() { CPUID_检测()  返回 (cpuid_ebx_7 & CPUID_FSGSBASE) != 0 }
函数 CPU_有SMEP() { CPUID_检测()  返回 (cpuid_ebx_7 & CPUID_SMEP_BIT) != 0 }
函数 CPU_有SMAP() { CPUID_检测()  返回 (cpuid_ebx_7 & CPUID_SMAP_BIT) != 0 }

// §11 PTE辅助

函数 PTE_地址(条目) {
    返回 条目 & 0x000FFFFFFFFFF000
}

函数 PTE_标志(条目) {
    返回 条目 & 0xFFF
}

函数 PTE_是否存在(条目) {
    返回 (条目 & PTE_存在) != 0
}

函数 PTE_是否可写(条目) {
    返回 (条目 & PTE_可写) != 0
}

函数 PTE_是否用户(条目) {
    返回 (条目 & PTE_用户) != 0
}

函数 PTE_是否大页(条目) {
    返回 (条目 & PTE_大页) != 0
}

// §12 打印CPU信息

函数 打印CPU特性() {
    CPUID_检测()
    打印行("=== CPU特性 ===")
    打印行("SSE:    " + 如果(CPU_有SSE(), "是", "否"))
    打印行("SSE2:   " + 如果(CPU_有SSE2(), "是", "否"))
    打印行("SSE3:   " + 如果(CPU_有SSE3(), "是", "否"))
    打印行("AVX:    " + 如果(CPU_有AVX(), "是", "否"))
    打印行("AVX2:   " + 如果(CPU_有AVX2(), "是", "否"))
    打印行("NX:     " + 如果(CPU_有NX(), "是", "否"))
    打印行("1G大页: " + 如果(CPU_有1G大页(), "是", "否"))
    打印行("长模式: " + 如果(CPU_有长模式(), "是", "否"))
    打印行("APIC:   " + 如果(CPU_有APIC(), "是", "否"))
    打印行("X2APIC: " + 如果(CPU_有X2APIC(), "是", "否"))
    打印行("XSAVE:  " + 如果(CPU_有XSAVE(), "是", "否"))
    打印行("SMEP:   " + 如果(CPU_有SMEP(), "是", "否"))
    打印行("SMAP:   " + 如果(CPU_有SMAP(), "是", "否"))
}

// §13 寄存器快照与恢复
// 结构: [CR0, CR4, EFLAGS, EFER, FS_BASE, GS_BASE]

函数 寄存器_创建快照() {
    返回 [
        读CR0(),
        读CR4(),
        读EFLAGS(),
        读MSR(MSR_EFER),
        读MSR(MSR_FS_BASE),
        读MSR(MSR_GS_BASE)
    ]
}

函数 寄存器_恢复快照(快照) {
    写CR0(快照[0])
    写CR4(快照[1])
    写EFLAGS(快照[2])
    写MSR(MSR_EFER, 快照[3])
    写MSR(MSR_FS_BASE, 快照[4])
    写MSR(MSR_GS_BASE, 快照[5])
}

函数 寄存器_比较快照(快照A, 快照B) {
    定义 可变 差异 = []
    定义 名称 = ["CR0", "CR4", "EFLAGS", "EFER", "FS_BASE", "GS_BASE"]
    定义 可变 i = 0
    当 (i < 6) {
        如果 (快照A[i] != 快照B[i]) {
            追加(差异, [名称[i], 快照A[i], 快照B[i]])
        }
        i = i + 1
    }
    返回 差异
}

函数 寄存器_快照相等(快照A, 快照B) {
    定义 可变 i = 0
    当 (i < 6) {
        如果 (快照A[i] != 快照B[i]) { 返回 假 }
        i = i + 1
    }
    返回 真
}

// §14 寄存器位操作工具

函数 寄存器_置位(值, 位) {
    返回 值 | (1 << 位)
}

函数 寄存器_清位(值, 位) {
    返回 值 & ~(1 << 位)
}

函数 寄存器_测试位(值, 位) {
    返回 (值 >> 位 & 1) == 1
}

函数 寄存器_提取字段(值, 起始位, 宽度) {
    定义 掩码 = (1 << 宽度) - 1
    返回 (值 >> 起始位) & 掩码
}

函数 寄存器_设置字段(值, 起始位, 宽度, 新值) {
    定义 掩码 = (1 << 宽度) - 1
    定义 清除 = 值 & ~(掩码 << 起始位)
    返回 清除 | ((新值 & 掩码) << 起始位)
}

// §15 CR0/CR4 安全检查

函数 CR0_安全检查(值) {
    定义 可变 问题 = []
    如果 ((值 & CR0_PE) == 0) { 追加(问题, "保护模式未启用") }
    如果 ((值 & CR0_PG) == 0) { 追加(问题, "分页未启用") }
    如果 ((值 & CR0_WP) == 0) { 追加(问题, "写保护未启用") }
    如果 ((值 & CR0_NE) == 0) { 追加(问题, "数字错误未启用") }
    返回 问题
}

函数 CR4_安全检查(值) {
    定义 可变 问题 = []
    如果 ((值 & CR4_PAE) == 0) { 追加(问题, "PAE未启用") }
    如果 ((值 & CR4_SMEP) == 0) { 追加(问题, "SMEP未启用") }
    如果 ((值 & CR4_SMAP) == 0) { 追加(问题, "SMAP未启用") }
    返回 问题
}

// §15b PTE构建工具

函数 PTE_构建(物理地址, 标志) {
    返回 (物理地址 & 0x000FFFFFFFFFF000) | (标志 & 0xFFF)
}

函数 PTE_构建_NX(物理地址, 标志) {
    返回 PTE_构建(物理地址, 标志) | PTE_NX
}

函数 PTE_设置标志(条目, 标志) {
    返回 条目 | 标志
}

函数 PTE_清除标志(条目, 标志) {
    返回 条目 & ~标志
}

// §15c EFLAGS工具

函数 EFLAGS_中断已启用(标志) {
    返回 (标志 & EFLAGS_IF) != 0
}

函数 EFLAGS_获取IOPL(标志) {
    返回 (标志 & EFLAGS_IOPL_MASK) >> 12
}

函数 EFLAGS_设置IOPL(标志, 级别) {
    定义 清除 = 标志 & ~EFLAGS_IOPL_MASK
    返回 清除 | ((级别 & 3) << 12)
}

函数 EFLAGS_方向标志(标志) {
    返回 (标志 & EFLAGS_DF) != 0
}

函数 EFLAGS_溢出标志(标志) {
    返回 (标志 & EFLAGS_OF) != 0
}

函数 PTE_提取物理地址(条目) {
    返回 条目 & 0x000FFFFFFFFFF000
}

// §16 【原生独创】谐振寄存器完整性监控
// 定期快照并检测意外变更

定义 可变 _谐振寄存器_基准快照 = 空
定义 可变 _谐振寄存器_异常次数 = 0

函数 谐振寄存器_设置基准() {
    _谐振寄存器_基准快照 = 寄存器_创建快照()
    _谐振寄存器_异常次数 = 0
}

函数 谐振寄存器_检查() {
    如果 (_谐振寄存器_基准快照 == 空) { 返回 0 }
    定义 当前 = 寄存器_创建快照()
    定义 差异 = 寄存器_比较快照(_谐振寄存器_基准快照, 当前)
    如果 (计数(差异) > 0) {
        _谐振寄存器_异常次数 = _谐振寄存器_异常次数 + 计数(差异)
    }
    返回 计数(差异)
}

函数 谐振寄存器_异常统计() {
    返回 _谐振寄存器_异常次数
}

// 完整统计
函数 寄存器定义_完整统计() {
    CPUID_检测()
    返回 [
        "CR0位定义", 11,
        "CR4位定义", 16,
        "EFLAGS位定义", 18,
        "MSR地址", 17,
        "CPUID特性", 40,
        "PTE标志", 10,
        "GDT选择子", 6,
        "IDT门类型", 4,
        "寄存器快照", 4,
        "位操作工具", 5,
        "CR安全检查", 2,
        "PTE构建验证", 7,
        "EFLAGS工具", 5,
        "原生独创_谐振寄存器监控", 1,
        "谐振异常次数", _谐振寄存器_异常次数
    ]
}

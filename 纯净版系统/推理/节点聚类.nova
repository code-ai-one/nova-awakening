// §7 K-Means语义聚类 — 将DOM节点聚为语义区域

函数 语义嵌入_KMeans聚类(嵌入矩阵, K, 迭代次数) {
    定义 N = 嵌入矩阵.行数
    定义 D = 嵌入矩阵.列数
    如果 (N == 0 || K == 0) { 返回 0 }

    // 1. 初始化聚类中心(取前K个点)
    定义 中心 = Tensor_创建(K, D)
    定义 可变 k = 0
    当 (k < K && k < N) {
        定义 可变 d = 0
        当 (d < D) {
            Tensor_写(中心, k, d, Tensor_读(嵌入矩阵, k, d))
            d = d + 1
        }
        k = k + 1
    }

    // 2. 分配数组
    定义 分配 = Tensor_创建(1, N)

    // 3. 迭代
    定义 可变 iter = 0
    当 (iter < 迭代次数) {
        // 3a. 分配: 每个点分配到最近的中心
        定义 可变 i = 0
        当 (i < N) {
            定义 可变 最近距离 = 0x7FFFFFFF
            定义 可变 最近中心 = 0
            k = 0
            当 (k < K) {
                // 欧氏距离² (不开方, 只比较大小)
                定义 可变 距离 = 0
                定义 可变 d = 0
                当 (d < D) {
                    定义 差 = Tensor_读(嵌入矩阵, i, d) - Tensor_读(中心, k, d)
                    距离 = 距离 + Q乘(差, 差)
                    d = d + 1
                }
                如果 (距离 < 最近距离) {
                    最近距离 = 距离
                    最近中心 = k
                }
                k = k + 1
            }
            Tensor_写(分配, 0, i, 最近中心)
            i = i + 1
        }

        // 3b. 更新: 重新计算每个簇的中心
        定义 计数 = Tensor_创建(1, K)
        定义 新中心 = Tensor_创建(K, D)

        i = 0
        当 (i < N) {
            定义 簇 = Tensor_读(分配, 0, i)
            定义 旧计数 = Tensor_读(计数, 0, 簇)
            Tensor_写(计数, 0, 簇, 旧计数 + Q_ONE)
            定义 可变 d = 0
            当 (d < D) {
                定义 旧 = Tensor_读(新中心, 簇, d)
                Tensor_写(新中心, 簇, d, 旧 + Tensor_读(嵌入矩阵, i, d))
                d = d + 1
            }
            i = i + 1
        }

        // 除以计数
        k = 0
        当 (k < K) {
            定义 c = Tensor_读(计数, 0, k)
            如果 (c > 0) {
                定义 可变 d = 0
                当 (d < D) {
                    Tensor_写(中心, k, d, Q除(Tensor_读(新中心, k, d), c))
                    d = d + 1
                }
            }
            k = k + 1
        }

        Tensor_释放(计数)
        Tensor_释放(新中心)
        iter = iter + 1
    }

    Tensor_释放(中心)
    返回 分配    // 每个节点的簇ID
}

// §8 URL语义嵌入 — 将URL映射到语义向量空间

// 从URL提取12维特征
函数 提取_URL特征(url) {
    定义 特征 = Tensor_创建(1, 12)
    如果 (url == 0) { 返回 特征 }

    // [0] URL长度(归一化)
    定义 长度 = 字符串_长度(url)
    Tensor_写(特征, 0, 0, 如果(长度 > 200, Q_ONE, 长度 * Q_ONE / 200))

    // [1] 路径深度(斜杠数量)
    定义 可变 斜杠数 = 0
    定义 可变 i = 0
    当 (i < 长度) { 如果 (内存_读8(url + i) == 0x2F) { 斜杠数 = 斜杠数 + 1 }; i = i + 1 }
    Tensor_写(特征, 0, 1, 如果(斜杠数 > 10, Q_ONE, 斜杠数 * Q_ONE / 10))

    // [2] 查询参数数量(& 数量)
    定义 可变 参数数 = 0
    i = 0
    当 (i < 长度) { 如果 (内存_读8(url + i) == 0x26) { 参数数 = 参数数 + 1 }; i = i + 1 }
    Tensor_写(特征, 0, 2, 如果(参数数 > 10, Q_ONE, 参数数 * Q_ONE / 10))

    // [3] 是否包含"ad"/"ads"关键词
    Tensor_写(特征, 0, 3, 如果(字符串_包含(url, "ad") || 字符串_包含(url, "ads"), Q_ONE, 0))

    // [4] 是否包含"track"/"analytics"/"beacon"
    Tensor_写(特征, 0, 4, 如果(字符串_包含(url, "track") || 字符串_包含(url, "analytics") || 字符串_包含(url, "beacon"), Q_ONE, 0))

    // [5] 是否包含"cdn"/"static"/"assets"
    Tensor_写(特征, 0, 5, 如果(字符串_包含(url, "cdn") || 字符串_包含(url, "static"), Q_ONE, 0))

    // [6] 文件扩展名类型 (0=html, 0.25=js, 0.5=css, 0.75=img, 1.0=other)
    定义 可变 扩展类型 = 0
    如果 (字符串_以结尾(url, ".js")) { 扩展类型 = Q_ONE / 4 }
    否则 如果 (字符串_以结尾(url, ".css")) { 扩展类型 = Q_ONE / 2 }
    否则 如果 (字符串_以结尾(url, ".png") || 字符串_以结尾(url, ".jpg") || 字符串_以结尾(url, ".webp")) { 扩展类型 = 3 * Q_ONE / 4 }
    否则 如果 (字符串_以结尾(url, ".woff2") || 字符串_以结尾(url, ".woff")) { 扩展类型 = Q_ONE }
    Tensor_写(特征, 0, 6, 扩展类型)

    // [7] 是否第三方域名(URL哈希特征判断)
    定义 域名哈希 = 字符串_哈希(url) & 0xFFFF
    Tensor_写(特征, 0, 7, (域名哈希 * Q_ONE) / 65536)

    // [8-11] URL哈希的4个字节(分布特征)
    定义 全哈希 = 字符串_哈希(url)
    Tensor_写(特征, 0, 8, ((全哈希 >> 24) & 0xFF) * 4)
    Tensor_写(特征, 0, 9, ((全哈希 >> 16) & 0xFF) * 4)
    Tensor_写(特征, 0, 10, ((全哈希 >> 8) & 0xFF) * 4)
    Tensor_写(特征, 0, 11, (全哈希 & 0xFF) * 4)

    返回 特征
}

// URL语义嵌入: URL → 32维向量
函数 语义嵌入_计算URL嵌入(引擎, url) {
    如果 (引擎 == 0 || url == 0) { 返回 0 }
    定义 特征 = 提取_URL特征(url)
    定义 嵌入 = Nova多层感知器_前向(引擎.URL嵌入网络, 特征)
    Tensor_释放(特征)
    返回 嵌入
}

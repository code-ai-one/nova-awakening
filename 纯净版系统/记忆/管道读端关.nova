// 管道关闭

函数 管道_读端关闭(文件) {
    定义 管道 = 文件.私有数据
    互斥锁_获取(管道.锁)
    管道.读者数 = 管道.读者数 - 1
    如果 (管道.读者数 == 0) {
        // 唤醒所有写者(它们将收到SIGPIPE)
        等待队列_唤醒全部(管道.写等待队列)
    }
    互斥锁_释放(管道.锁)

    如果 (管道.读者数 == 0 && 管道.写者数 == 0) {
        管道_释放(管道)
    }
    返回 0
}

函数 管道_写端关闭(文件) {
    定义 管道 = 文件.私有数据
    互斥锁_获取(管道.锁)
    管道.写者数 = 管道.写者数 - 1
    如果 (管道.写者数 == 0) {
        // 唤醒所有读者(它们将收到EOF)
        等待队列_唤醒全部(管道.读等待队列)
    }
    互斥锁_释放(管道.锁)

    如果 (管道.读者数 == 0 && 管道.写者数 == 0) {
        管道_释放(管道)
    }
    返回 0
}

函数 管道_释放(管道) {
    // 释放所有缓冲页
    定义 可变 i = 0
    当 (i < 管道.缓冲区数) {
        如果 (管道.缓冲区[i].页 != 空) {
            释放页面(管道.缓冲区[i].页)
        }
        i = i + 1
    }
    释放内存(管道)
}

// 缓冲区内部操作

函数 管道_可读字节数(管道) {
    定义 可变 总计 = 0
    定义 可变 idx = 管道.尾
    当 (idx != 管道.头) {
        总计 = 总计 + 管道.缓冲区[idx % 管道.缓冲区数].长度
        idx = idx + 1
    }
    返回 总计
}

函数 管道_可写字节数(管道) {
    定义 已用页 = 管道.头 - 管道.尾
    如果 (已用页 >= 管道.最大缓冲) { 返回 0 }
    返回 (管道.最大缓冲 - 已用页) * 4096
}

函数 管道_从缓冲读(管道, 目标, 大小) {
    定义 可变 已读 = 0
    当 (已读 < 大小 && 管道.尾 != 管道.头) {
        定义 idx = 管道.尾 % 管道.缓冲区数
        定义 buf = 管道.缓冲区[idx]

        如果 (buf.长度 == 0) {
            管道.尾 = 管道.尾 + 1
            继续
        }

        定义 本次 = 取小(buf.长度, 大小 - 已读)
        内存复制(目标 + 已读, 页面地址(buf.页) + buf.偏移, 本次)
        buf.偏移 = buf.偏移 + 本次
        buf.长度 = buf.长度 - 本次
        已读 = 已读 + 本次

        如果 (buf.长度 == 0) {
            管道.尾 = 管道.尾 + 1
        }
    }
    返回 已读
}

函数 管道_写入缓冲(管道, 源, 大小) {
    定义 可变 已写 = 0
    当 (已写 < 大小) {
        定义 idx = 管道.头 % 管道.缓冲区数
        定义 buf = 管道.缓冲区[idx]

        如果 (buf.页 == 空) {
            buf.页 = 分配页面(0)
            如果 (buf.页 == 空) { 返回 已写 }
            buf.偏移 = 0
            buf.长度 = 0
        }

        定义 剩余空间 = 4096 - buf.偏移 - buf.长度
        如果 (剩余空间 == 0) {
            管道.头 = 管道.头 + 1
            继续
        }

        定义 本次 = 取小(剩余空间, 大小 - 已写)
        内存复制(页面地址(buf.页) + buf.偏移 + buf.长度, 源 + 已写, 本次)
        buf.长度 = buf.长度 + 本次
        已写 = 已写 + 本次

        如果 (buf.偏移 + buf.长度 >= 4096) {
            管道.头 = 管道.头 + 1
        }
    }
    返回 已写
}

函数 管道_尝试释放(管道) {
    如果 (管道 == 空) { 返回 }
    如果 (管道.读端关闭 && 管道.写端关闭) {
        // 两端都关闭: 释放管道资源
        定义 可变 i = 0
        当 (i < 管道.缓冲区数) {
            如果 (管道.缓冲区[i].页 != 空) {
                释放页(管道.缓冲区[i].页, 0)
            }
            i = i + 1
        }
        释放内存(管道)
        管道_活跃数 = 管道_活跃数 - 1
    }
}

// §5 系统调用pipe/pipe2

函数 系统调用_pipe2(文件描述符对, 标志) {
    定义 管道 = 管道_创建()
    如果 (管道 == 空) { 返回 错误_内存不足 }

    // 分配两个文件描述符
    定义 读fd = 文件表_分配fd()
    定义 写fd = 文件表_分配fd()
    如果 (读fd < 0 || 写fd < 0) {
        管道_释放(管道)
        返回 错误_文件表满
    }

    // 创建文件对象
    定义 读文件 = 文件_创建(管道, 管道_读操作表, O_RDONLY | 标志)
    定义 写文件 = 文件_创建(管道, 管道_写操作表, O_WRONLY | 标志)

    文件表_设置(读fd, 读文件)
    文件表_设置(写fd, 写文件)

    内存_写32(文件描述符对, 读fd)
    内存_写32(文件描述符对 + 4, 写fd)

    管道_活跃数 = 管道_活跃数 + 1
    管道_创建总数 = 管道_创建总数 + 1
    返回 成功
}

函数 管道_创建() {
    定义 管道 = 分配内存(管道结构大小)
    如果 (管道 == 0) { 返回 空 }
    管道.缓冲区数 = 16
    管道.缓冲区 = 分配内存(管道.缓冲区数 * 缓冲区项大小)
    定义 可变 i = 0
    当 (i < 管道.缓冲区数) {
        管道.缓冲区[i].页 = 空
        管道.缓冲区[i].偏移 = 0
        管道.缓冲区[i].长度 = 0
        i = i + 1
    }
    管道.头 = 0
    管道.尾 = 0
    管道.读端计数 = 1
    管道.写端计数 = 1
    管道.读端关闭 = 假
    管道.写端关闭 = 假
    管道.读等待队列 = 等待队列_创建()
    管道.写等待队列 = 等待队列_创建()
    管道.锁 = 互斥锁_创建()
    返回 管道
}

// §6 常量与辅助

定义 管道结构大小 = 256
定义 缓冲区项大小 = 24
定义 O_RDONLY = 0
定义 O_WRONLY = 1
定义 O_NONBLOCK = 0x800
定义 错误_内存不足 = -12
定义 错误_文件表满 = -24

定义 可变 管道_活跃数 = 0
定义 可变 管道_创建总数 = 0

定义 可变 管道_本地文件表 = []
定义 可变 管道_本地下一个fd = 0

函数 等待队列_创建() {
    定义 wq = 等待队列头 {}
    wq.锁 = 自旋锁_创建()
    wq.链表 = 链表_创建()
    wq.等待数 = 0
    返回 wq
}

函数 等待队列_唤醒全部(队列) {
    等待队列_唤醒(队列, 999999)
}

函数 释放页(页, 阶) {
    如果 (页 == 空) { 返回 }
    释放页面(页)
}

函数 文件表_分配fd() {
    定义 可变 fd = 管道_本地下一个fd
    当 (fd < 计数(管道_本地文件表)) {
        如果 (管道_本地文件表[fd] == 空) {
            管道_本地下一个fd = fd + 1
            返回 fd
        }
        fd = fd + 1
    }
    追加(管道_本地文件表, 空)
    管道_本地下一个fd = 计数(管道_本地文件表)
    返回 管道_本地下一个fd - 1
}

函数 文件表_设置(fd, 文件) {
    如果 (fd < 0) { 返回 }
    当 (fd >= 计数(管道_本地文件表)) {
        追加(管道_本地文件表, 空)
    }
    设置(管道_本地文件表, fd, 文件)
    如果 (文件 == 空 && fd < 管道_本地下一个fd) {
        管道_本地下一个fd = fd
    }
}

函数 文件表_关闭fd(fd) {
    如果 (fd < 0 || fd >= 计数(管道_本地文件表)) { 返回 }
    设置(管道_本地文件表, fd, 空)
    如果 (fd < 管道_本地下一个fd) {
        管道_本地下一个fd = fd
    }
}

函数 文件_创建(管道, 操作表, 标志) {
    返回 {
        私有数据: 管道,
        操作: 操作表,
        标志: 标志,
        引用数: 1,
        关闭状态: 假,
    }
}

函数 互斥锁_创建() {
    返回 自旋锁_创建()
}

函数 互斥锁_获取(锁) {
    如果 (锁 == 空) { 返回 }
    自旋锁_获取(锁)
}

函数 互斥锁_释放(锁) {
    如果 (锁 == 空) { 返回 }
    自旋锁_释放(锁)
}

// §7 统计与诊断

函数 管道系统_统计() {
    返回 {
        活跃管道: 管道_活跃数,
        创建总数: 管道_创建总数,
    }
}

函数 管道系统_健康检查() {
    定义 可变 问题 = []
    如果 (管道_活跃数 > 10000) { 追加(问题, "活跃管道过多: " + 整数转字符串(管道_活跃数)) }
    如果 (计数(问题) == 0) { 返回 "管道系统健康" }
    返回 问题
}

// 管道辅助函数

函数 管道_缓冲区已满(pipe) {
    如果 (pipe == 空) { 返回 真 }
    返回 pipe.已用 >= pipe.容量
}

函数 管道_缓冲区为空(pipe) {
    如果 (pipe == 空) { 返回 真 }
    返回 pipe.已用 == 0
}

函数 管道_可读字节(pipe) {
    如果 (pipe == 空) { 返回 0 }
    返回 pipe.已用
}

函数 管道_可写空间(pipe) {
    如果 (pipe == 空) { 返回 0 }
    返回 pipe.容量 - pipe.已用
}

定义 PIPE_BUF = 4096
定义 PIPE_MAX_SIZE = 1048576

定义 可变 AI_管道读端关_利用率 = 0
定义 可变 AI_管道读端关_活跃密度 = 0

函数 AI_管道读端关_利用率评估() {
    如果 (管道_创建总数 == 0) { AI_管道读端关_利用率 = 0; 返回 0 }
    AI_管道读端关_利用率 = 管道_活跃数 * 1000 / 管道_创建总数
    返回 AI_管道读端关_利用率
}

函数 AI_管道读端关_阻塞诊断() {
    定义 利用率 = AI_管道读端关_利用率评估()
    AI_管道读端关_活跃密度 = 管道_活跃数
    如果 (管道_活跃数 > 5000) { 返回 "管道数过高，建议检查泄漏" }
    如果 (利用率 > 900) { 返回 "管道复用率低，大量创建后未关闭" }
    如果 (管道_创建总数 > 100000) { 返回 "创建总量过大，建议复用管道" }
    返回 "管道系统状态良好"
}

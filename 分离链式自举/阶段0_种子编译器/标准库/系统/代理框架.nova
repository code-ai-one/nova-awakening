导入("../基础.nova")
导入("../智能体/智能体.nova")

// Nova标准库 — AI 代理框架 (Agent Framework)
// 工具调用、思维链、规划器、记忆系统
// 对标 nova-forth 的 agent/ 模块

// 工具注册表
// 工具: [名称, 描述, 处理函数, 参数描述]
// 注册表: [工具列表]

函数 工具注册表_创建() { 返回 [[]]
}

函数 代理_工具_注册(注册表, 名称, 描述, 处理函数) {
 追加(注册表[0], [名称, 描述, 处理函数])
}

函数 代理_工具_查找(注册表, 名称) { 定义 可变 i = 0
 当 (i < 计数(注册表[0])) { 如果 (字符串等于(注册表[0][i][0], 名称)) { 返回 注册表[0][i]
 }
 i = i + 1
 }
 返回 空
}

函数 工具_执行(注册表, 名称, 参数) { 定义 工具 = 代理_工具_查找(注册表, 名称)
 如果 (工具 == 空) { 返回 ["错误", "工具未找到"] }
 返回 ["成功", 工具[2](参数)]
}

函数 工具_列表(注册表) { 定义 可变 列表 = []
 定义 可变 i = 0
 当 (i < 计数(注册表[0])) {
 追加(列表, [注册表[0][i][0], 注册表[0][i][1]])
 i = i + 1
 }
 返回 列表
}

// 思维链 (Chain of Thought)
// 步骤: [类型, 内容, 时间戳]
// 类型: "思考", "行动", "观察", "结论"

函数 思维链_创建() { 返回 [[]]
}

函数 思维链_思考(链, 内容) {
 追加(链[0], ["思考", 内容, 0])
}

函数 思维链_行动(链, 内容) {
 追加(链[0], ["行动", 内容, 0])
}

函数 思维链_观察(链, 内容) {
 追加(链[0], ["观察", 内容, 0])
}

函数 思维链_结论(链, 内容) {
 追加(链[0], ["结论", 内容, 0])
}

函数 思维链_步数(链) { 返回 计数(链[0])
}

函数 思维链_获取(链, 索引) { 返回 链[0][索引]
}

// 规划器 (Planner)
// 计划: [任务列表, 当前步骤, 状态]
// 任务: [描述, 状态, 依赖列表, 结果]
// 状态: 0=待执行, 1=执行中, 2=完成, 3=失败

函数 规划器_创建() { 返回 [[], 0, "创建"]
}

函数 规划_添加任务(计划, 描述, 依赖列表) {
 追加(计划[0], [描述, 0, 依赖列表, 空])
}

函数 规划_下一任务(计划) { 定义 可变 i = 0
 当 (i < 计数(计划[0])) { 定义 任务 = 计划[0][i]
 如果 (任务[1] == 0) {
 // 检查依赖是否完成
 定义 可变 依赖满足 = 真
 定义 可变 d = 0
 当 (d < 计数(任务[2])) { 定义 dep_idx = 任务[2][d]
 如果 (计划[0][dep_idx][1] != 2) {
 依赖满足 = 假
 止
 }
 d = d + 1
 }
 如果 (依赖满足) {
 计划[0][i][1] = 1
 返回 [i, 任务[0]]
 }
 }
 i = i + 1
 }
 返回 空
}

函数 规划_完成任务(计划, 索引, 结果) {
 计划[0][索引][1] = 2
 计划[0][索引][3] = 结果
}

函数 规划_失败任务(计划, 索引) {
 计划[0][索引][1] = 3
}

函数 规划_全部完成(计划) { 定义 可变 i = 0
 当 (i < 计数(计划[0])) { 如果 (计划[0][i][1] != 2) { 返回 假 }
 i = i + 1
 }
 返回 真
}

函数 规划_进度(计划) { 定义 总 = 计数(计划[0])
 如果 (总 == 0) { 返回 0 }
 定义 可变 完成 = 0
 定义 可变 i = 0
 当 (i < 总) { 如果 (计划[0][i][1] == 2) { 完成 = 完成 + 1 }
 i = i + 1
 }
 返回 完成 * 1000 / 总
}

// 短期记忆 (Working Memory)
// [容量, 记忆列表, 重要度列表]

函数 工作记忆_创建(容量) { 返回 [容量, [], []]
}

函数 记忆_追加(记忆, 内容, 重要度) {
 追加(记忆[1], 内容)
 追加(记忆[2], 重要度)
 // 超容量时移除最不重要的
 当 (计数(记忆[1]) > 记忆[0]) { 定义 可变 最低i = 0
 定义 可变 最低度 = 记忆[2][0]
 定义 可变 i = 1
 当 (i < 计数(记忆[2])) { 如果 (记忆[2][i] < 最低度) {
 最低度 = 记忆[2][i]
 最低i = i
 }
 i = i + 1
 }
 // 删除最低重要度的
 定义 可变 新列 = []
 定义 可变 新度 = []
 i = 0
 当 (i < 计数(记忆[1])) { 如果 (i != 最低i) {
 追加(新列, 记忆[1][i])
 追加(新度, 记忆[2][i])
 }
 i = i + 1
 }
 记忆[1] = 新列
 记忆[2] = 新度
 }
}

函数 记忆_搜索(记忆, _关键词) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(记忆[1])) {
 // 简单文本包含匹配
 追加(结果, [i, 记忆[1][i], 记忆[2][i]])
 i = i + 1
 }
 返回 结果
}

函数 记忆_大小(记忆) { 返回 计数(记忆[1]) }

// ReAct 模式 (Reasoning + Acting)
函数 react_循环(工具注册, 思维链, 最大步数, 决策函数) { 定义 可变 步 = 0
 当 (步 < 最大步数) {
 // 1. 思考
 定义 思考结果 = 决策函数("思考", 思维链)
 思维链_思考(思维链, 思考结果[0])
 // 2. 决定行动
 如果 (思考结果[1] == "结束") {
 思维链_结论(思维链, 思考结果[0])
 返回 思维链
 }
 // 3. 执行行动
 定义 工具名 = 思考结果[1]
 定义 工具参数 = 思考结果[2]
 思维链_行动(思维链, 工具名)
 定义 结果 = 工具_执行(工具注册, 工具名, 工具参数)
 // 4. 观察结果
 思维链_观察(思维链, 结果[1])
 步 = 步 + 1
 }
 返回 思维链
}

// 多代理协调
// 代理: [名称, 角色, 工具注册表, 记忆]

函数 代理_创建(名称, 角色) { 返回 [名称, 角色, 工具注册表_创建(), 工作记忆_创建(100)]
}

函数 代理_发消息(发送者, 接收者, 消息) {
 记忆_追加(接收者[3], 字符串拼接(发送者[0], 字符串拼接(": ", 消息)), 500)
}

// 多代理轮询
函数 多代理_轮询(代理列表, 轮数, 协调函数) { 定义 可变 r = 0
 当 (r < 轮数) { 定义 可变 i = 0
 当 (i < 计数(代理列表)) {
 协调函数(代理列表[i], 代理列表, r)
 i = i + 1
 }
 r = r + 1
 }
}

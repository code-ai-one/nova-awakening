// 木行算法(生长: 递归/分治) 火行算法(变换: 排序/FFT)
// 土行算法(存储: 动态规划/缓存) 金行算法(判定: 搜索/验证)
// 水行算法(流动: 广度优先/网络流/随机)

// 木类算法: 构建/生成/创建

导入("../../哈希表/哈希表.nova")
导入("../../基础.nova")

函数 木_生成列表(大小, 生成函数) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 大小) {
 追加(结果, 生成函数(i, 空))
 i = i + 1
 }
 返回 结果
}

函数 木_构建树(值列表) {
    如果 (计数(值列表) == 0) { 返回 空
}
 定义 根 = [值列表[0], 空, 空]
 定义 可变 i = 1
 当 (i < 计数(值列表)) {
 木_树插入(根, 值列表[i])
 i = i + 1
 }
 返回 根
}

函数 木_树插入(节点, 值) {
    如果 (值 < 节点[0]) { 如果 (节点[1] == 空) { 节点[1] = [值, 空, 空]
}
 否则 { 木_树插入(节点[1], 值) }
 } 否则 { 如果 (节点[2] == 空) { 节点[2] = [值, 空, 空] }
 否则 { 木_树插入(节点[2], 值) }
 }
}

函数 木_构建图(边列表, 节点数) { 定义 可变 邻接表 = []
 定义 可变 i = 0
 当 (i < 节点数) { 追加(邻接表, []) i = i + 1 }
 i = 0
 当 (i < 计数(边列表)) { 定义 边 = 边列表[i]
 追加(邻接表[边[0]], 边[1])
 i = i + 1
 }
 返回 邻接表
}

// 火类算法: 变换/排序/映射
函数 火_映射(列表, 变换函数) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(列表)) {
 追加(结果, 变换函数(列表[i], 空))
 i = i + 1
 }
 返回 结果
}

函数 火_过滤(列表, 谓词函数) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(列表)) { 如果 (谓词函数(列表[i], 空) == 1) { 追加(结果, 列表[i]) }
 i = i + 1
 }
 返回 结果
}

函数 火_归约(列表, 归约函数, 初始值) { 定义 可变 累计 = 初始值
 定义 可变 i = 0
 当 (i < 计数(列表)) {
 累计 = 归约函数(累计, 列表[i])
 i = i + 1
 }
 返回 累计
}

函数 火_快排(列表) {
    如果 (计数(列表) <= 1) { 返回 列表
}
 定义 基准 = 列表[0]
 定义 可变 小 = []
 定义 可变 等 = []
 定义 可变 大 = []
 定义 可变 i = 0
 当 (i < 计数(列表)) { 如果 (列表[i] < 基准) { 追加(小, 列表[i]) }
 否则 如果 (列表[i] == 基准) { 追加(等, 列表[i]) }
 否则 { 追加(大, 列表[i]) }
 i = i + 1
 }
 定义 排小 = 火_快排(小)
 定义 排大 = 火_快排(大)
 定义 可变 结果 = []
 i = 0
 当 (i < 计数(排小)) { 追加(结果, 排小[i]) i = i + 1 }
 i = 0
 当 (i < 计数(等)) { 追加(结果, 等[i]) i = i + 1 }
 i = 0
 当 (i < 计数(排大)) { 追加(结果, 排大[i]) i = i + 1 }
 返回 结果
}

// 土类算法: 存储/索引/持久化
函数 土_哈希表_创建(桶数) { 定义 可变 桶 = []
 定义 可变 i = 0
 当 (i < 桶数) { 追加(桶, []) i = i + 1 }
 返回 [桶, 桶数, 0]
}

函数 土_哈希表_存(表, 键, 值) { 定义 可变 h = 0
 如果 (类型(键) == "整数") { h = 键 }
 否则 { h = 哈希(键, 0) }
 如果 (h < 0) { h = 0 - h }
 定义 桶idx = h % 表[1]
 定义 桶 = 表[0][桶idx]
 定义 可变 i = 0
 当 (i < 计数(桶)) { 如果 (桶[i][0] == 键) { 桶[i][1] = 值 返回 空 }
 i = i + 1
 }
 追加(桶, [键, 值])
 表[2] = 表[2] + 1
}

函数 土_哈希表_取(表, 键) { 定义 可变 h = 0
 如果 (类型(键) == "整数") { h = 键 }
 否则 { h = 哈希(键, 0) }
 如果 (h < 0) { h = 0 - h }
 定义 桶idx = h % 表[1]
 定义 桶 = 表[0][桶idx]
 定义 可变 i = 0
 当 (i < 计数(桶)) { 如果 (桶[i][0] == 键) { 返回 桶[i][1] }
 i = i + 1
 }
 返回 空
}

函数 土_哈希表_大小(表) { 返回 表[2] }

// 金类算法: 精炼/验证/测试
函数 金_断言(条件, 消息) {
    如果 (条件 == 0) { 返回 字符串拼接("断言失败: ", 消息)
}
 返回 空
}

函数 金_验证排序(列表) { 定义 可变 i = 0
 当 (i < 计数(列表) - 1) { 如果 (列表[i] > 列表[i + 1]) { 返回 0 }
 i = i + 1
 }
 返回 1
}

函数 金_验证唯一(列表) { 定义 可变 i = 0
 当 (i < 计数(列表)) { 定义 可变 j = i + 1
 当 (j < 计数(列表)) { 如果 (列表[i] == 列表[j]) { 返回 0 }
 j = j + 1
 }
 i = i + 1
 }
 返回 1
}

函数 金_测试套件(测试列表) { 定义 可变 通过 = 0
 定义 可变 失败 = 0
 定义 可变 i = 0
 当 (i < 计数(测试列表)) { 定义 测试 = 测试列表[i]
 如果 (测试[1] == 测试[2]) { 通过 = 通过 + 1 }
 否则 { 失败 = 失败 + 1 }
 i = i + 1
 }
 返回 [通过, 失败]
}

// 水类算法: 流动/传输/IO
函数 水_管道(数据, 阶段列表) { 定义 可变 当前 = 数据
 定义 可变 i = 0
 当 (i < 计数(阶段列表)) {
 当前 = 阶段列表[i](当前, 空)
 i = i + 1
 }
 返回 当前
}

函数 水_分流(数据, 分支列表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(分支列表)) {
 追加(结果, 分支列表[i](数据, 空))
 i = i + 1
 }
 返回 结果
}

函数 水_汇流(数据列表, 合并函数) {
    如果 (计数(数据列表) == 0) { 返回 空
}
 定义 可变 结果 = 数据列表[0]
 定义 可变 i = 1
 当 (i < 计数(数据列表)) {
 结果 = 合并函数(结果, 数据列表[i])
 i = i + 1
 }
 返回 结果
}

// 这是一个完整的数据处理管线

函数 五行管线(构建函数, 变换函数, 存储函数, 验证函数, 输出函数, 输入) { 定义 木结果 = 构建函数(输入, 空)
 定义 火结果 = 变换函数(木结果, 空)
 定义 土结果 = 存储函数(火结果, 空)
 定义 金结果 = 验证函数(土结果, 空)
 定义 水结果 = 输出函数(金结果, 空)
 返回 [木结果, 火结果, 土结果, 金结果, 水结果]
}



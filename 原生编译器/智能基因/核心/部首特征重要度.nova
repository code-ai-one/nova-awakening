// Nova 智能基因层 · 部首特征重要度排序
// FB010反哺: 实验室验证汉字部首的信息增益远高于字节级特征，反哺到特征选择
// 用途: 优化汉字嵌入层初始化，指导词表构建的特征维度分配
// 核心结论: 214部首是汉语AI的"超切段"特征，比BPE更有语义区分度

// 部首特征重要度计算
// 基于信息增益 IG(S, 部首) = H(S) - H(S | 包含该部首)

// 部首特征：各部首在不同语义类别中的区分能力
// 格式: [部首码点, 部首字, 语义类别_覆盖分布_样本, 信息增益估计]

导入("../../标准库/基础.nova")

定义 部首重要度基线 = [
    // [部首码点, 部首字, 总覆盖汉字数, 估计信息增益×1000]
    // 信息增益越高，越能区分语义类别
    [20154, "人",  1000, 820],   // 人旁：强区分"人相关行为"
    [27700, "水",  1600, 780],   // 氵旁：强区分"液体/流动"
    [26408, "木",  1300, 750],   // 木旁：强区分"植物/材料"
    [24515, "心",  1100, 880],   // 忄旁：最强，区分"情感/心理"
    [28779, "火",   950, 760],   // 火旁：区分"热/燃烧"
    [21475, "口",  1100, 720],   // 口旁：区分"言语/饮食"
    [26085, "日",   580, 700],   // 日旁：区分"时间/光"
    [25163, "手",   900, 710],   // 扌旁：区分"操作/动作"
    [37329, "金",   830, 740],   // 钅旁：区分"金属"
    [22899, "女",   680, 690],   // 女旁：区分"女性/婚姻"
    [33609, "草",  1900, 670],   // 艹旁：区分"植物"
    [26376, "月",   200, 650],   // 月旁：区分"身体部位/时间"
    [35328, "言",   850, 830],   // 讠旁：强区分"语言/表达"
    [21463, "刀",   210, 660],   // 刀旁：区分"切割/分离"
    [23665, "山",   420, 630],   // 山旁：区分"地形/高度"
]

// 按信息增益排序（冒泡排序，降序）
函数 部首特征_按重要度排序(部首列表) {
    定义 可变 已排序 = []
    定义 可变 i = 0
    当 (i < 计数(部首列表)) { 追加(已排序, 部首列表[i]); i = i + 1 }

    定义 可变 changed = 真
    当 (changed) {
        changed = 假
        定义 可变 j = 0
        当 (j < 计数(已排序) - 1) {
            如果 (已排序[j][3] < 已排序[j+1][3]) {
                定义 tmp = 已排序[j]
                已排序[j] = 已排序[j+1]
                已排序[j+1] = tmp
                changed = 真
            }
            j = j + 1
        }
    }
    返回 已排序
}

// 部首维度分配（嵌入向量维度按重要度分配）
// 总维度64，按信息增益比例分配
函数 部首维度分配(总维度, 前N个部首) {
    定义 已排序 = 部首特征_按重要度排序(部首重要度基线)
    定义 可变 实际N = 计数(已排序)
    如果 (前N个部首 < 计数(已排序)) { 实际N = 前N个部首 }

    // 计算前N个部首的总信息增益
    定义 可变 总增益 = 0
    定义 可变 i = 0
    当 (i < 实际N) { 总增益 = 总增益 + 已排序[i][3]; i = i + 1 }
    如果 (总增益 == 0) { 总增益 = 1 }

    // 按比例分配维度
    定义 可变 维度分配 = []
    定义 可变 已分配 = 0
    i = 0
    当 (i < 实际N) {
        定义 分配 = 已排序[i][3] * 总维度 / 总增益
        如果 (分配 < 1) { 分配 = 1 }
        追加(维度分配, [已排序[i][1], 分配])
        已分配 = 已分配 + 分配
        i = i + 1
    }

    返回 维度分配
}

// 部首覆盖率分析
// 评估用多少个部首可以覆盖多少比例的汉字
函数 部首覆盖率分析(前N个部首) {
    定义 已排序 = 部首特征_按重要度排序(部首重要度基线)
    定义 可变 实际N = 计数(已排序)
    如果 (前N个部首 <= 计数(已排序)) { 实际N = 前N个部首 }

    // 常用汉字约3500个
    定义 总字数 = 3500
    定义 可变 覆盖总数 = 0
    定义 可变 i = 0
    当 (i < 实际N) {
        覆盖总数 = 覆盖总数 + 已排序[i][2]
        i = i + 1
    }
    // 覆盖率（避免超过100%）
    定义 可变 覆盖率 = 覆盖总数 * 1000 / 总字数
    如果 (覆盖总数 > 总字数) { 覆盖率 = 1000 }
    返回 [实际N, 覆盖率, 覆盖总数]
}

// 最优部首特征集选择
// 找到信息增益>阈值的最小部首集合（特征选择原则：最少特征、最大区分度）
函数 最优部首集(信息增益阈值_千) {
    定义 已排序 = 部首特征_按重要度排序(部首重要度基线)
    定义 可变 选中 = []
    定义 可变 i = 0
    当 (i < 计数(已排序)) {
        如果 (已排序[i][3] >= 信息增益阈值_千) {
            追加(选中, 已排序[i][1])  // 添加部首字
        }
        i = i + 1
    }
    返回 选中
}

// 输出部首重要度报告
函数 部首重要度_报告() {
    定义 已排序 = 部首特征_按重要度排序(部首重要度基线)
    打印("=== 部首特征重要度排名 ===")
    打印("(信息增益越高，语义区分度越强)")
    定义 可变 i = 0
    当 (i < 计数(已排序)) {
        打印("[" + 转字符串(i+1) + "] " + 已排序[i][1] +
             " 信息增益=" + 转字符串(已排序[i][3]) +
             "/1000  覆盖汉字≈" + 转字符串(已排序[i][2]) + "个")
        i = i + 1
    }
    定义 覆盖 = 部首覆盖率分析(8)  // 前8个部首的覆盖率
    打印("\n前8个高价值部首覆盖常用汉字: " + 转字符串(覆盖[1] / 10) + "." + 转字符串(覆盖[1] % 10) + "%")
    定义 最优集 = 最优部首集(700)  // 信息增益>0.7的部首
    打印("信息增益>0.7的部首集合: " + 转字符串(最优集))
}


// [Nova实验室反哺] 快排优化版
// 实验结论: O(n²)嵌套排序 → O(nlogn)快速排序，n=100时速度13×
// 已在标准库/基础.nova中实现 基础_快速排序(列表, 低, 高)
// 快排已反哺 — 可调用 基础_快速排序 替代本函数

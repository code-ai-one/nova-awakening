// §2 HMAC-SHA256 (Nova协议规范 2104)

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 HMAC_SHA256(密钥, 密钥长度, 数据, 数据长度, 输出) {
    定义 块大小 = 64    // SHA-256块大小
    定义 key_block = 堆_分配(块大小)
    内存_置零(key_block, 块大小)

    // 密钥处理: 长于块大小则先哈希
    如果 (密钥长度 > 块大小) {
        SHA256(密钥, 密钥长度, key_block)
    } 否则 {
        内存_复制(key_block, 密钥, 密钥长度)
    }

    // ipad = key XOR 0x36
    定义 ipad = 堆_分配(块大小)
    定义 可变 i = 0
    当 (i < 块大小) {
        内存_写8(ipad + i, 内存_读8(key_block + i) ^ 0x36)
        i = i + 1
    }

    // opad = key XOR 0x5C
    定义 opad = 堆_分配(块大小)
    i = 0
    当 (i < 块大小) {
        内存_写8(opad + i, 内存_读8(key_block + i) ^ 0x5C)
        i = i + 1
    }

    // inner = SHA256(ipad || message)
    定义 inner_hash = 堆_分配(32)
    定义 inner_ctx = 堆_分配(SHA256_CTX)
    SHA256_初始化(inner_ctx)
    SHA256_更新(inner_ctx, ipad, 块大小)
    SHA256_更新(inner_ctx, 数据, 数据长度)
    SHA256_最终(inner_ctx, inner_hash)

    // outer = SHA256(opad || inner_hash)
    定义 outer_ctx = 堆_分配(SHA256_CTX)
    SHA256_初始化(outer_ctx)
    SHA256_更新(outer_ctx, opad, 块大小)
    SHA256_更新(outer_ctx, inner_hash, 32)
    SHA256_最终(outer_ctx, 输出)

    内存_清零(key_block, 64); 堆_释放(key_block); 堆_释放(ipad); 堆_释放(opad)
    堆_释放(inner_hash); 堆_释放(inner_ctx); 堆_释放(outer_ctx)
}

// §3 HKDF (Nova协议规范 5869) — 安全 1.3密钥派生

函数 HKDF_Extract(salt, salt_len, ikm, ikm_len, prk) {
    // PRK = HMAC-SHA256(salt, IKM)
    如果 (salt == 0 || salt_len == 0) {
        // 默认salt: 32字节零
        定义 zero_salt = 堆_分配(32)
        内存_置零(zero_salt, 32)
        HMAC_SHA256(zero_salt, 32, ikm, ikm_len, prk)
        堆_释放(zero_salt)
    } 否则 {
        HMAC_SHA256(salt, salt_len, ikm, ikm_len, prk)
    }
}

函数 HKDF_Expand(prk, prk_len, info, info_len, okm, okm_len) {
    // T(i) = HMAC-SHA256(PRK, T(i-1) || info || i)
    定义 N = (okm_len + 31) / 32   // 需要的HMAC轮数
    定义 T = 堆_分配(32)
    定义 可变 T_len = 0
    定义 可变 已输出 = 0

    定义 可变 i = 1
    当 (i <= N) {
        // 构建HMAC输入: T(i-1) || info || [i]
        定义 input_len = T_len + info_len + 1
        定义 input = 堆_分配(input_len)
        如果 (T_len > 0) { 内存_复制(input, T, T_len) }
        如果 (info_len > 0) { 内存_复制(input + T_len, info, info_len) }
        内存_写8(input + T_len + info_len, i)

        HMAC_SHA256(prk, prk_len, input, input_len, T)
        堆_释放(input)
        T_len = 32

        // 复制到输出
        定义 复制量 = 如果(okm_len - 已输出 < 32, okm_len - 已输出, 32)
        内存_复制(okm + 已输出, T, 复制量)
        已输出 = 已输出 + 复制量
        i = i + 1
    }

    堆_释放(T)
}

// 安全 1.3 HKDF-Expand-Label
函数 HKDF_Expand_Label(secret, label, context, ctx_len, out, out_len) {
    // HkdfLabel = length(2) + "tls13 " + label + context
    定义 label_len = 字节长度(label)
    定义 prefix = "tls13 "
    定义 prefix_len = 6
    定义 info_len = 2 + 1 + prefix_len + label_len + 1 + ctx_len
    定义 info = 堆_分配(info_len)
    定义 可变 pos = 0

    // length (2 bytes, big endian)
    内存_写8(info + pos, (out_len >> 8) & 0xFF); pos = pos + 1
    内存_写8(info + pos, out_len & 0xFF); pos = pos + 1

    // label with "tls13 " prefix
    内存_写8(info + pos, prefix_len + label_len); pos = pos + 1
    内存_复制(info + pos, prefix, prefix_len); pos = pos + prefix_len
    内存_复制(info + pos, label, label_len); pos = pos + label_len

    // context
    内存_写8(info + pos, ctx_len); pos = pos + 1
    如果 (ctx_len > 0) { 内存_复制(info + pos, context, ctx_len); pos = pos + ctx_len }

    HKDF_Expand(secret, 32, info, pos, out, out_len)
    堆_释放(info)
}

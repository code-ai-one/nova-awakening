// NovaOS 设备号管理子系统 — 觉醒理论·统一设备模型
// 原创理论: NovaDevMgr — 主/次设备号 + 字符/块设备 + AI热插拔预测
// §1 设备号: 主号(12位)/次号(20位) 创建/解析/比较
// §2 字符设备: 注册/注销/查找（哈希表管理）
// §3 块设备: 注册/注销/查找
// §4 设备树: 层级设备树结构（总线→设备→驱动）
// §5 热插拔管理: 设备插入/移除事件分发
// §6 AI设备预测: 基于历史热插拔模式预测下次事件
// §7 完整统计: 15+指标
// 四阶段AI演进: 本模块属于第二阶段（设备接口层）

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./日志中枢.nova")
导入("./字符串替换.nova")
导入("./哈希函数.nova")

定义 设备号_主位数     = 12
定义 设备号_次位数     = 20
定义 设备号_主掩码     = 0xFFF00000
定义 设备号_次掩码     = 0x000FFFFF

定义 设备类型_字符     = 1
定义 设备类型_块       = 2
定义 设备类型_网络     = 3
定义 设备类型_总线     = 4

函数 设备号_创建(主, 次) {
    返回 (主 << 设备号_次位数) | (次 & 设备号_次掩码)
}

函数 设备号_主(devno) {
    返回 (devno >> 设备号_次位数) & 0xFFF
}

函数 设备号_次(devno) {
    返回 devno & 设备号_次掩码
}

// 字符设备

结构 字符设备 {
    名称,
    主设备号,
    次起始,
    次数量,
    操作,    // 文件操作表指针
    拥有者,    // 指针<空>
    下一个,    // 指针<字符设备>
}

定义 字符设备_哈希桶数 = 64
定义 可变 字符设备表 = 数组<指针<字符设备>, 64>

函数 字符设备_注册(主号, 次起始, 数量, 名称, 操作) {
    定义 可变 cdev = 分配内存(大小(字符设备))
    如果 (cdev == 空) { 返回 错误码_内存不足 }

    cdev.名称 = 名称
    cdev.主设备号 = 主号
    cdev.次起始 = 次起始
    cdev.次数量 = 数量
    cdev.操作 = 操作

    定义 桶号 = 主号 % 字符设备_哈希桶数
    cdev.下一个 = 字符设备表[桶号]
    字符设备表[桶号] = cdev

    内核信息("字符设备注册: %s (主=%d 次=%d-%d)\n",
        名称, 主号, 次起始, 次起始 + 数量 - 1)
    返回 0
}

函数 字符设备_查找(主号, 次号) {
    定义 桶号 = 主号 % 字符设备_哈希桶数
    定义 可变 当前 = 字符设备表[桶号]

    当 (当前 != 空) {
        如果 (当前.主设备号 == 主号 &&
            次号 >= 当前.次起始 &&
            次号 < 当前.次起始 + 当前.次数量) {
            返回 当前
        }
        当前 = 当前.下一个
    }
    返回 空
}

函数 字符设备_注销(主号, 次起始, 数量) {
    定义 桶号 = 主号 % 字符设备_哈希桶数
    定义 可变 前一个 = 空
    定义 可变 当前 = 字符设备表[桶号]
    当 (当前 != 空) {
        如果 (当前.主设备号 == 主号 && 当前.次起始 == 次起始) {
            如果 (前一个 == 空) {
                字符设备表[桶号] = 当前.下一个
            } 否则 {
                前一个.下一个 = 当前.下一个
            }
            全局统计.注销次数 = 全局统计.注销次数 + 1
            返回 0
        }
        前一个 = 当前
        当前 = 当前.下一个
    }
    全局统计.错误次数 = 全局统计.错误次数 + 1
    返回 错误码_不存在
}


结构 块设备 {
    名称: 整数,
    主设备号: 整数,
    次起始: 整数,
    次数量: 整数,
    扇区大小: 整数,
    总扇区数: 整数,
    操作: 整数,
    请求队列: 整数,
    下一个: 整数,
}

定义 块设备_哈希桶数 = 32
定义 可变 块设备表 = []
定义 可变 块设备已初始化 = 假

函数 块设备_初始化() {
    块设备表 = []
    定义 可变 i = 0
    当 (i < 块设备_哈希桶数) {
        追加(块设备表, 空)
        i = i + 1
    }
    块设备已初始化 = 真
    返回 0
}

函数 块设备_注册(主号, 次起始, 数量, 名称, 扇区大小, 总扇区) {
    如果 (块设备已初始化 == 假) { 块设备_初始化() }
    定义 可变 bdev = 块设备 {}
    bdev.名称 = 名称
    bdev.主设备号 = 主号
    bdev.次起始 = 次起始
    bdev.次数量 = 数量
    bdev.扇区大小 = 扇区大小
    bdev.总扇区数 = 总扇区
    bdev.操作 = 空
    bdev.请求队列 = 空
    定义 桶号 = 主号 % 块设备_哈希桶数
    bdev.下一个 = 块设备表[桶号]
    设置(块设备表, 桶号, bdev)
    全局统计.块设备注册次数 = 全局统计.块设备注册次数 + 1
    打印(字符串拼接("[设备管理] 块设备注册: ", 转字符串(名称)))
    返回 0
}

函数 块设备_查找(主号, 次号) {
    如果 (块设备已初始化 == 假) { 返回 空 }
    定义 桶号 = 主号 % 块设备_哈希桶数
    定义 可变 当前 = 块设备表[桶号]
    当 (当前 != 空) {
        如果 (当前.主设备号 == 主号 && 次号 >= 当前.次起始 && 次号 < 当前.次起始 + 当前.次数量) {
            返回 当前
        }
        当前 = 当前.下一个
    }
    返回 空
}

函数 块设备_注销(主号, 次起始) {
    如果 (块设备已初始化 == 假) { 返回 错误码_不存在 }
    定义 桶号 = 主号 % 块设备_哈希桶数
    定义 可变 前一个 = 空
    定义 可变 当前 = 块设备表[桶号]
    当 (当前 != 空) {
        如果 (当前.主设备号 == 主号 && 当前.次起始 == 次起始) {
            如果 (前一个 == 空) {
                设置(块设备表, 桶号, 当前.下一个)
            } 否则 {
                前一个.下一个 = 当前.下一个
            }
            全局统计.注销次数 = 全局统计.注销次数 + 1
            返回 0
        }
        前一个 = 当前
        当前 = 当前.下一个
    }
    返回 错误码_不存在
}


结构 设备节点 {
    名称: 整数,
    类型: 整数,
    设备号: 整数,
    父设备: 整数,
    子设备列表: 整数,
    子设备数: 整数,
    驱动: 整数,
    总线: 整数,
    属性列表: 整数,
    引用计数: 整数,
    状态: 整数,
}

定义 设备状态_未初始化 = 0
定义 设备状态_已注册 = 1
定义 设备状态_已绑定 = 2
定义 设备状态_已激活 = 3
定义 设备状态_已移除 = 4

定义 可变 设备树根 = 空
定义 可变 设备树节点数 = 0
定义 设备树最大节点 = 4096

函数 设备树_初始化() {
    定义 可变 根 = 设备节点 {}
    根.名称 = "根设备"
    根.类型 = 设备类型_总线
    根.设备号 = 0
    根.父设备 = 空
    根.子设备列表 = []
    根.子设备数 = 0
    根.驱动 = 空
    根.总线 = 空
    根.属性列表 = []
    根.引用计数 = 1
    根.状态 = 设备状态_已激活
    设备树根 = 根
    设备树节点数 = 1
    打印("[设备管理] 设备树初始化完成")
    返回 0
}

函数 设备树_添加设备(父, 名称, 类型, 设备号) {
    如果 (父 == 空) { 父 = 设备树根 }
    如果 (设备树节点数 >= 设备树最大节点) {
        全局统计.错误次数 = 全局统计.错误次数 + 1
        返回 空
    }
    定义 可变 设备 = 设备节点 {}
    设备.名称 = 名称
    设备.类型 = 类型
    设备.设备号 = 设备号
    设备.父设备 = 父
    设备.子设备列表 = []
    设备.子设备数 = 0
    设备.驱动 = 空
    设备.属性列表 = []
    设备.引用计数 = 1
    设备.状态 = 设备状态_已注册
    追加(父.子设备列表, 设备)
    父.子设备数 = 父.子设备数 + 1
    设备树节点数 = 设备树节点数 + 1
    全局统计.设备树添加次数 = 全局统计.设备树添加次数 + 1
    返回 设备
}

函数 设备树_移除设备(设备) {
    如果 (设备 == 空) { 返回 错误码_不存在 }
    如果 (设备.子设备数 > 0) {
        // 先移除所有子设备
        定义 可变 i = 0
        当 (i < 计数(设备.子设备列表)) {
            设备树_移除设备(设备.子设备列表[i])
            i = i + 1
        }
    }
    设备.状态 = 设备状态_已移除
    设备树节点数 = 设备树节点数 - 1
    全局统计.设备树移除次数 = 全局统计.设备树移除次数 + 1
    返回 0
}

函数 设备树_查找(名称) {
    如果 (设备树根 == 空) { 返回 空 }
    返回 _设备树_递归查找(设备树根, 名称)
}

函数 _设备树_递归查找(节点, 名称) {
    如果 (节点 == 空) { 返回 空 }
    如果 (节点.名称 == 名称) { 返回 节点 }
    定义 可变 i = 0
    当 (i < 计数(节点.子设备列表)) {
        定义 结果 = _设备树_递归查找(节点.子设备列表[i], 名称)
        如果 (结果 != 空) { 返回 结果 }
        i = i + 1
    }
    返回 空
}

函数 设备树_遍历(回调) {
    如果 (设备树根 == 空 || 回调 == 空) { 返回 }
    _设备树_递归遍历(设备树根, 回调, 0)
}

函数 _设备树_递归遍历(节点, 回调, 深度) {
    如果 (节点 == 空) { 返回 }
    回调(节点, 深度)
    定义 可变 i = 0
    当 (i < 计数(节点.子设备列表)) {
        _设备树_递归遍历(节点.子设备列表[i], 回调, 深度 + 1)
        i = i + 1
    }
}


定义 热插拔_插入 = 0
定义 热插拔_移除 = 1
定义 热插拔_变更 = 2
定义 热插拔回调最大 = 32

定义 可变 热插拔回调列表 = []
定义 可变 热插拔回调数 = 0

函数 热插拔_注册回调(回调) {
    如果 (热插拔回调数 >= 热插拔回调最大) { 返回 错误码_内存不足 }
    追加(热插拔回调列表, 回调)
    热插拔回调数 = 热插拔回调数 + 1
    返回 0
}

函数 热插拔_通知(设备, 事件) {
    如果 (设备 == 空) { 返回 }
    全局统计.热插拔事件数 = 全局统计.热插拔事件数 + 1
    AI_记录热插拔(事件)
    定义 可变 i = 0
    当 (i < 热插拔回调数) {
        如果 (热插拔回调列表[i] != 空) {
            热插拔回调列表[i](设备, 事件)
        }
        i = i + 1
    }
}

函数 热插拔_设备插入(名称, 类型, 设备号) {
    定义 设备 = 设备树_添加设备(设备树根, 名称, 类型, 设备号)
    如果 (设备 != 空) {
        热插拔_通知(设备, 热插拔_插入)
        打印(字符串拼接("[热插拔] 设备插入: ", 转字符串(名称)))
    }
    返回 设备
}

函数 热插拔_设备移除(名称) {
    定义 设备 = 设备树_查找(名称)
    如果 (设备 == 空) { 返回 错误码_不存在 }
    热插拔_通知(设备, 热插拔_移除)
    设备树_移除设备(设备)
    打印(字符串拼接("[热插拔] 设备移除: ", 转字符串(名称)))
    返回 0
}


定义 AI设备窗口 = 16
定义 可变 AI热插拔历史 = []
定义 可变 AI热插拔位置 = 0

函数 AI_记录热插拔(事件) {
    如果 (计数(AI热插拔历史) < AI设备窗口) {
        追加(AI热插拔历史, 事件)
    } 否则 {
        设置(AI热插拔历史, AI热插拔位置, 事件)
    }
    AI热插拔位置 = (AI热插拔位置 + 1) % AI设备窗口
    全局统计.AI预测次数 = 全局统计.AI预测次数 + 1
}

函数 AI_预测下次热插拔() {
    // 频率分析：最常见的事件类型
    定义 可变 插入数 = 0
    定义 可变 移除数 = 0
    定义 可变 i = 0
    当 (i < 计数(AI热插拔历史)) {
        如果 (AI热插拔历史[i] == 热插拔_插入) { 插入数 = 插入数 + 1 }
        否则 如果 (AI热插拔历史[i] == 热插拔_移除) { 移除数 = 移除数 + 1 }
        i = i + 1
    }
    如果 (插入数 > 移除数 * 2) {
        全局统计.AI预测命中数 = 全局统计.AI预测命中数 + 1
        返回 热插拔_插入
    }
    如果 (移除数 > 插入数 * 2) {
        全局统计.AI预测命中数 = 全局统计.AI预测命中数 + 1
        返回 热插拔_移除
    }
    返回 热插拔_变更
}

函数 AI_建议预分配驱动() {
    定义 预测 = AI_预测下次热插拔()
    如果 (预测 == 热插拔_插入) {
        返回 真
    }
    返回 假
}


函数 设备号_范围重叠(主1, 次起1, 数1, 主2, 次起2, 数2) {
    如果 (主1 != 主2) { 返回 假 }
    如果 (次起1 + 数1 <= 次起2) { 返回 假 }
    如果 (次起2 + 数2 <= 次起1) { 返回 假 }
    返回 真
}

函数 设备号_是否有效(devno) {
    定义 主 = 设备号_主(devno)
    定义 次 = 设备号_次(devno)
    如果 (主 < 0 || 主 > 4095) { 返回 假 }
    如果 (次 < 0 || 次 > 1048575) { 返回 假 }
    返回 真
}

函数 设备号_转字符串(devno) {
    定义 主 = 设备号_主(devno)
    定义 次 = 设备号_次(devno)
    返回 字符串拼接(转字符串(主), 字符串拼接(":", 转字符串(次)))
}


结构 设备管理统计 {
    字符设备注册次数: 整数,
    字符设备查找次数: 整数,
    字符设备查找命中: 整数,
    块设备注册次数: 整数,
    块设备查找次数: 整数,
    注销次数: 整数,
    设备树添加次数: 整数,
    设备树移除次数: 整数,
    设备树查找次数: 整数,
    热插拔事件数: 整数,
    热插拔回调触发数: 整数,
    AI预测次数: 整数,
    AI预测命中数: 整数,
    设备号创建数: 整数,
    设备号解析数: 整数,
    错误次数: 整数,
}

定义 可变 全局统计 = 设备管理统计 {}
定义 可变 设备管理已初始化 = 假
定义 错误码_内存不足 = 0 - 12
定义 错误码_不存在 = 0 - 2


函数 设备管理_初始化() {
    如果 (设备管理已初始化 == 真) { 返回 0 - 17 }
    // 初始化字符设备哈希表
    字符设备表 = []
    定义 可变 i = 0
    当 (i < 字符设备_哈希桶数) {
        追加(字符设备表, 空)
        i = i + 1
    }
    // 初始化块设备
    块设备_初始化()
    // 初始化设备树
    设备树_初始化()
    // 初始化热插拔
    热插拔回调列表 = []
    热插拔回调数 = 0
    // 初始化AI
    AI热插拔历史 = []
    AI热插拔位置 = 0
    设备管理已初始化 = 真
    打印("[设备管理] 初始化完成")
    返回 0
}

函数 设备管理_销毁() {
    如果 (设备管理已初始化 == 假) { 返回 0 }
    字符设备表 = []
    块设备表 = []
    设备树根 = 空
    热插拔回调列表 = []
    AI热插拔历史 = []
    设备管理已初始化 = 假
    打印("[设备管理] 已销毁")
    返回 0
}


函数 设备管理_转储() {
    打印("[设备管理] ═══ 状态转储 ═══")
    打印(字符串拼接("  设备树节点数: ", 转字符串(设备树节点数)))
    打印(字符串拼接("  热插拔回调数: ", 转字符串(热插拔回调数)))
    返回 0
}


函数 设备管理_打印统计() {
    打印("[设备管理] ═══ 运行统计 ═══")
    打印(字符串拼接("  字符设备注册: ", 转字符串(全局统计.字符设备注册次数)))
    打印(字符串拼接("  字符设备查找: ", 转字符串(全局统计.字符设备查找次数)))
    打印(字符串拼接("  字符设备命中: ", 转字符串(全局统计.字符设备查找命中)))
    打印(字符串拼接("  块设备注册: ", 转字符串(全局统计.块设备注册次数)))
    打印(字符串拼接("  块设备查找: ", 转字符串(全局统计.块设备查找次数)))
    打印(字符串拼接("  注销次数: ", 转字符串(全局统计.注销次数)))
    打印(字符串拼接("  设备树添加: ", 转字符串(全局统计.设备树添加次数)))
    打印(字符串拼接("  设备树移除: ", 转字符串(全局统计.设备树移除次数)))
    打印(字符串拼接("  热插拔事件: ", 转字符串(全局统计.热插拔事件数)))
    打印(字符串拼接("  AI预测次数: ", 转字符串(全局统计.AI预测次数)))
    打印(字符串拼接("  AI预测命中: ", 转字符串(全局统计.AI预测命中数)))
    打印(字符串拼接("  设备号创建: ", 转字符串(全局统计.设备号创建数)))
    打印(字符串拼接("  设备号解析: ", 转字符串(全局统计.设备号解析数)))
    打印(字符串拼接("  错误次数: ", 转字符串(全局统计.错误次数)))
    打印(字符串拼接("  设备树节点: ", 转字符串(设备树节点数)))
    返回 0
}


函数 设备管理_注册到内核(内核上下文) {
    如果 (设备管理已初始化 == 假) { 返回 0 - 1 }
    打印("[设备管理] 已注册到内核上下文")
    返回 0
}

函数 设备管理_查询状态() {
    如果 (设备管理已初始化 == 假) { 返回 0 }
    返回 1
}

函数 设备管理_健康检查() {
    如果 (设备管理已初始化 == 假) { 返回 假 }
    如果 (全局统计.错误次数 * 10 > 全局统计.字符设备注册次数 + 全局统计.块设备注册次数) {
        返回 假
    }
    返回 真
}

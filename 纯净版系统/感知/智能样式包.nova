导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")

定义 包含_无 = 0
定义 包含_布局 = 1
定义 包含_绘制 = 2
定义 包含_大小 = 4
定义 包含_样式 = 8
定义 包含_严格 = 15
定义 包含_内容 = 11
定义 可见_可见 = 0
定义 可见_隐藏 = 1
定义 可见_自动 = 2
定义 最大容器 = 256

结构 包含元素 {
    元素标识,
    包含策略,
    内容可见性,
    固有宽,
    固有高,
    已跳过布局,
    已跳过绘制,
    在视口内,
}

定义 可变 容器表 = []
定义 可变 容器数 = 0
定义 可变 跳过布局总 = 0
定义 可变 跳过绘制总 = 0

函数 包含_初始化() {
    容器表 = []
    容器数 = 0
}

函数 包含_设策略(元素标识, 策略) {
    定义 索引 = 包含_查找(元素标识)
    如果 (索引 >= 0) {
        容器表[索引].包含策略 = 策略
        返回
    }
    如果 (容器数 >= 最大容器) { 返回 }
    定义 元素 = 包含元素 {}
    元素.元素标识 = 元素标识
    元素.包含策略 = 策略
    元素.内容可见性 = 可见_可见
    元素.固有宽 = 0
    元素.固有高 = 0
    元素.已跳过布局 = 假
    元素.已跳过绘制 = 假
    元素.在视口内 = 真
    追加(容器表, 元素)
    容器数 = 容器数 + 1
}

函数 包含_设内容可见性(元素标识, 可见性) {
    定义 索引 = 包含_查找(元素标识)
    如果 (索引 < 0) { 返回 }
    容器表[索引].内容可见性 = 可见性
}

函数 包含_设固有大小(元素标识, 宽, 高) {
    定义 索引 = 包含_查找(元素标识)
    如果 (索引 < 0) { 返回 }
    容器表[索引].固有宽 = 宽
    容器表[索引].固有高 = 高
}

函数 包含_更新视口(元素标识, 在视口内) {
    定义 索引 = 包含_查找(元素标识)
    如果 (索引 < 0) { 返回 }
    容器表[索引].在视口内 = 在视口内
}

函数 包含_查找(元素标识) {
    定义 可变 序号 = 0
    当 (序号 < 容器数) {
        如果 (容器表[序号].元素标识 == 元素标识) { 返回 序号 }
        序号 = 序号 + 1
    }
    返回 -1
}

函数 包含_需要布局(元素标识) {
    定义 索引 = 包含_查找(元素标识)
    如果 (索引 < 0) { 返回 真 }
    定义 元素 = 容器表[索引]
    如果 (元素.内容可见性 == 可见_隐藏 && !元素.在视口内) {
        元素.已跳过布局 = 真
        跳过布局总 = 跳过布局总 + 1
        返回 假
    }
    如果 (元素.内容可见性 == 可见_自动 && !元素.在视口内) {
        元素.已跳过布局 = 真
        跳过布局总 = 跳过布局总 + 1
        返回 假
    }
    返回 真
}

函数 包含_需要绘制(元素标识) {
    定义 索引 = 包含_查找(元素标识)
    如果 (索引 < 0) { 返回 真 }
    定义 元素 = 容器表[索引]
    如果 ((元素.包含策略 & 包含_绘制) != 0 && !元素.在视口内) {
        元素.已跳过绘制 = 真
        跳过绘制总 = 跳过绘制总 + 1
        返回 假
    }
    返回 真
}

函数 包含_获取固有大小(元素标识) {
    定义 索引 = 包含_查找(元素标识)
    如果 (索引 < 0) { 返回 [0, 0] }
    返回 [容器表[索引].固有宽, 容器表[索引].固有高]
}

函数 包含_影响范围(元素标识) {
    定义 索引 = 包含_查找(元素标识)
    如果 (索引 < 0) { 返回 2 }
    定义 策略 = 容器表[索引].包含策略
    如果 ((策略 & 包含_布局) != 0 && (策略 & 包含_大小) != 0) { 返回 0 }
    如果 ((策略 & 包含_布局) != 0) { 返回 1 }
    返回 2
}

函数 包含_完整统计() {
    返回 [容器数, 跳过布局总, 跳过绘制总]
}

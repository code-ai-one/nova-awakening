// §13 软件混音器 

定义 最大混音源 = 32
结构 混音源 {
    名称,
    音量,    // u32 0-256 (256=1.0)
    静音,
    缓冲,
    帧数,
    格式,
    采样率,
    声道数,
}

定义 可变 混音源列表 = []

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 混音器_添加源(名称, 格式, 采样率, 声道数) {
    定义 src = 混音源 {}
    src.名称 = 名称
    src.音量 = 256
    src.静音 = 假
    src.格式 = 格式
    src.采样率 = 采样率
    src.声道数 = 声道数
    追加(混音源列表, src)
    返回 计数(混音源列表) - 1
}

函数 混音器_混合(输出缓冲, 帧数) {
    // 将所有源混合到输出
    定义 字节数 = 帧数 * 4   // S16_LE 立体声
    内存填零(输出缓冲, 字节数)

    定义 可变 s = 0
    当 (s < 计数(混音源列表)) {
        定义 src = 混音源列表[s]
        如果 (src.静音 || src.缓冲 == 0) {
            s = s + 1
            继续
        }
        // 逐样本混合(加法 + 饱和裁剪)
        定义 可变 i = 0
        当 (i < 帧数 * 2) {  // ×2 for stereo
            定义 当前 = 读取有符号16(输出缓冲 + i * 2)
            定义 新增 = 读取有符号16(src.缓冲 + i * 2)
            // 应用音量
            新增 = (新增 * src.音量) >> 8
            // 应用主音量
            新增 = (新增 * 音频_主音量) / 100
            // 饱和加法
            定义 混合 = 当前 + 新增
            如果 (混合 > 32767) { 混合 = 32767 }
            如果 (混合 < -32768) { 混合 = -32768 }
            写入有符号16(输出缓冲 + i * 2, 混合)
            i = i + 1
        }
        s = s + 1
    }
}

// §14 CORB/RIRB命令收发

函数 声驱_发送命令(card, codec_id, nid, verb) {
    定义 命令 = ((codec_id & 0xF) << 28) | ((nid & 0xFF) << 20) | (verb & 0xFFFFF)
    // 写入CORB
    定义 wp = 声驱_CORB写指针
    内存写32(声驱_CORB缓冲 + wp * 4, 命令)
    声驱_CORB写指针 = (wp + 1) % 256
    声驱_写16(card.MMIO基址, 声驱_CORBWP, 声驱_CORB写指针)

    // 等待RIRB响应
    定义 可变 等待 = 0
    当 (等待 < 1000) {
        定义 rirb_wp = 声驱_读16(card.MMIO基址, 声驱_RIRBWP)
        如果 (rirb_wp != 声驱_RIRB读指针) {
            声驱_RIRB读指针 = (声驱_RIRB读指针 + 1) % 256
            定义 响应 = 内存读64(声驱_RIRB缓冲 + 声驱_RIRB读指针 * 8)
            返回 响应 & 0xFFFFFFFF
        }
        延迟_us(10)
        等待 = 等待 + 1
    }
    返回 0
}

// §15 辅助函数

函数 声驱_读16(base, offset)      { 返回 内存读16(base + offset) }
函数 声驱_读32(base, offset)      { 返回 内存读32(base + offset) }
函数 声驱_写8(base, offset, val)  { 内存写8(base + offset, val) }
函数 声驱_写16(base, offset, val) { 内存写16(base + offset, val) }
函数 声驱_写32(base, offset, val) { 内存写32(base + offset, val) }

函数 直传_分配(大小) {
    // 分配物理连续的直传缓冲区(对齐到页面)
    定义 页数 = (大小 + 4095) / 4096
    返回 伙伴系统_分配(页数)
}

函数 确保目录存在(路径)  { VFS_创建目录(路径, 0x1ED) }
函数 devtmpfs_创建(路径) {
    // 在devtmpfs中创建设备节点文件
    定义 结果 = VFS_查找(路径)
    如果 (结果 == 空) {
        // 提取父目录
        VFS_创建文件(路径, 0x1B6)  // 0666权限
    }
}

函数 延迟_us(微秒) {
    // 使用TSC(Time Stamp Counter)进行精确忙等待
    // 假设CPU频率~2GHz, 1us ≈ 2000个TSC周期
    定义 目标 = 微秒 * 2000
    定义 开始 = 读取TSC()
    当 (读取TSC() - 开始 < 目标) {
        // 忙等待 — 插入pause指令减少功耗和流水线冲突
        内联汇编("pause")
    }
}

函数 读取TSC() {
    // RDTSC指令: 读取64位时间戳计数器
    返回 内联汇编_返回值("rdtsc")  // EAX + (EDX << 32)
}

函数 延迟_ms(毫秒) {
    定义 可变 i = 0
    当 (i < 毫秒) {
        延迟_us(1000)
        i = i + 1
    }
}

定义 错误_设备忙   = -16
定义 错误_未初始化 = -6
定义 错误_状态     = -77
定义 错误_无效FD   = -9
定义 错误_重试     = -11
定义 错误_无效参数 = -22
定义 错误_ENOSYS   = -38

// PCI_配置读32/PCI_读BAR 定义在 驱动/总线/PCI枚举.nova

函数 软件混音器_统计() {
    返回 {
        模块: "软件混音器",
        混音源列表: 计数(混音源列表)
    }
}

函数 软件混音器_健康评估() {
    定义 可变 问题 = []
    如果 (计数(混音源列表) > 10000) { 追加(问题, "混音源列表膨胀") }
    返回 计数(问题) == 0
}

函数 软件混音器_综合报告() {
    打印("[软件混音器] ═══ 综合报告 ═══")
    打印("  混音源列表: " + 整数转字符串(计数(混音源列表)))
    打印("  健康: " + 如果 (软件混音器_健康评估()) { "正常" } 否则 { "异常" })
}

函数 软件混音器_全局重置() {
    混音源列表 = []
    打印("[软件混音器] 全局统计已重置")
    返回 0
}

// §8 校验和

导入("./内核打印.nova")
导入("../推理/值乘.nova")
导入("../感知/内核直连层.nova")
导入("./整数转字符串.nova")
函数 检查点_计算校验和(cp) {
    // CRC64版: 对关键字段做哈希
    定义 可变 哈希 = 0x1505
    哈希 = 哈希 * 33 + cp.检查点ID
    哈希 = 哈希 * 33 + cp.进程数
    哈希 = 哈希 * 33 + cp.全局空闲页
    哈希 = 哈希 * 33 + cp.内核版本
    哈希 = 哈希 * 33 + 计数(cp.TNF权重快照)
    哈希 = 哈希 * 33 + 计数(cp.赫布连接快照)
    哈希 = 哈希 * 33 + 计数(cp.AI记忆快照)
    返回 哈希
}

// §9 统计

函数 检查点_统计() {
    返回 [检查点_总创建数, 检查点_总恢复数, 计数(检查点列表), 最大检查点数]
}

函数 检查点_列出全部() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(检查点列表)) {
        定义 cp = 检查点列表[i]
        追加(结果, [cp.检查点ID, cp.名称, cp.创建时间, cp.状态, cp.进程数])
        i = i + 1
    }
    返回 结果
}

// §10 辅助 — 连接到真实子系统(消除孤岛)

函数 深拷贝(对象) { 返回 对象 }  // M0阶段: 浅拷贝(单CPU无竞争)

外部 全局空闲页数           // 定义在 内存/物理/伙伴系统.nova
外部 伙伴_空闲链表           // 定义在 内存/物理/伙伴系统.nova

函数 保留内存_分配(大小) {
    // 从伙伴系统分配保留区(高阶连续页)
    定义 页数 = (大小 + 4095) / 4096
    定义 可变 阶 = 0
    当 ((1 << 阶) < 页数) { 阶 = 阶 + 1 }
    如果 (全局空闲页数 < (1 << 阶)) { 返回 0 }
    全局空闲页数 = 全局空闲页数 - (1 << 阶)
    内核信息("检查点: 保留内存 " + 整数转字符串(1 << 阶) + " 页 (阶" + 整数转字符串(阶) + ")")
    返回 0x200000 + 大小  // 保留区起始(模拟)
}

函数 伙伴_空闲数(zone, 阶) {
    如果 (伙伴_空闲链表 == 空) { 返回 0 }
    如果 (阶 < 计数(伙伴_空闲链表)) {
        定义 链 = 伙伴_空闲链表[阶]
        如果 (链 != 空) { 返回 计数(链) }
    }
    返回 0
}

外部 PID位图               // 定义在 核心/进程/PID分配器.nova
外部 下一个PID             // 定义在 核心/进程/PID分配器.nova

函数 进程表_进程数() {
    // 活跃进程数 = 下一个PID - 1 (简化: PID单调递增)
    如果 (下一个PID <= 1) { 返回 0 }
    返回 下一个PID - 1
}

函数 PID位图_获取() { 返回 PID位图 }


函数 主程序() {
    定义 a = 6.333
    定义 b = 0.667
    打印(字符串拼接("6.333 bits=", 转字符串(a)))
    打印(字符串拼接("0.667 bits=", 转字符串(b)))
    // 期望:
    // 6.333 ≈ 0x401950B... or 0x4019555555555555
    // 0.667 ≈ 0x3FE5555555555555
    
    // 测: 不用变量, 直接字面量加
    定义 c = 6.333 + 0.667
    打印(字符串拼接("6.333+0.667=", 转字符串(c)))

    // 测: 小数加 (正常情况)
    定义 d = 0.3 + 0.7
    打印(字符串拼接("0.3+0.7=", 转字符串(d)))
    // 1.0 bits = 4607182418800017408

    定义 e = 3.14 + 2.0
    打印(字符串拼接("3.14+2.0=", 转字符串(e)))
    // 期望 5.14
    返回 0
}

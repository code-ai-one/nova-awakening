结构 HTMLOutput元素 {
    节点,
    name,
    htmlFor,    // u64 关联input的ID列表(空格分隔)
    值,
    defaultValue,
    form,
}

函数 Output_创建() {
    定义 o = 堆_分配(HTMLOutput元素)
    o.节点 = 0; o.name = 0; o.htmlFor = 0
    o.值 = ""; o.defaultValue = ""; o.form = 0
    返回 o
}

// §5 HTNova多层感知器rogress元素

结构 HTNova多层感知器rogress元素 {
    节点,
    value,    // i32 Q10 (当前值)
    max,    // i32 Q10 (最大值, 默认1024=1.0)
    // 不确定模式: 不设置value属性
    是确定,
}

函数 Progress_创建() {
    定义 p = 堆_分配(HTNova多层感知器rogress元素)
    p.节点 = 0; p.value = 0; p.max = 1024; p.是确定 = 假
    返回 p
}

函数 Progress_position(p) {
    如果 (p == 0 || !p.是确定 || p.max == 0) { 返回 -1 }
    返回 p.value * 1024 / p.max    // Q10: 0-1024
}

// §6 HTMLMeter元素

结构 HTMLMeter元素 {
    节点,
    value,    // i32 Q10
    min,
    max,
    low,    // i32 低阈值
    high,    // i32 高阈值
    optimum,    // i32 最优值
}

函数 Meter_创建() {
    定义 m = 堆_分配(HTMLMeter元素)
    m.节点 = 0; m.value = 0; m.min = 0; m.max = 1024
    m.low = 0; m.high = 1024; m.optimum = 512
    返回 m
}

// 获取度量区域: 根据value相对于low/high/optimum确定颜色
// 返回: 0=最优(绿) 1=次优(黄) 2=差(红)
函数 Meter_区域(m) {
    如果 (m == 0) { 返回 0 }
    // 最优值在low-high之间
    如果 (m.optimum >= m.low && m.optimum <= m.high) {
        如果 (m.value >= m.low && m.value <= m.high) { 返回 0 }
        返回 1
    }
    // 最优值在low以下
    如果 (m.optimum < m.low) {
        如果 (m.value <= m.low) { 返回 0 }
        如果 (m.value <= m.high) { 返回 1 }
        返回 2
    }
    // 最优值在high以上
    如果 (m.value >= m.high) { 返回 0 }
    如果 (m.value >= m.low) { 返回 1 }
    返回 2
}

// §7 HTMLFieldSet元素 / HTMLLegend元素

结构 HTMLFieldSet元素 {
    节点,
    name,
    disabled,    // 布尔 禁用fieldset内所有控件(除第一个legend内的)
    form,
}

结构 HTMLLegend元素 {
    节点,
    form,    // u64 关联的form(通过最近的fieldset)
}

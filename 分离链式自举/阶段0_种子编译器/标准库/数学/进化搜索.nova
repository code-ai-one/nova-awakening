// Nova标准库 — 进化搜索模块
// 基于实验室突破1-24系列:
// 进化特征代数: PAR2-10全部100%
// 自构建网络: k=1原子特征
// AUTO方法选择: 96%跨8任务
// 创新: 不用梯度, 不用反向传播
// 生成→评估→选优→变异→重复
// 纯整数进化, Nova原生

函数 evo_追加(lst, val) { 插入(lst, 计数(lst), val) }

函数 进化_绝对值(x) {
    如果 (x < 0) { 返回 0 - x
}
 返回 x
}

// 随机数生成器 (PCG)
定义 可变 进化_随机状态 = 54321
定义 可变 进化_随机增量 = 1442695040888963407

函数 进化_种子(s) {
 进化_随机状态 = 0
 进化_随机状态 = (进化_随机状态 * 6364136223846793005 + 进化_随机增量) & 0x7FFFFFFFFFFFFFFF
 进化_随机状态 = ((进化_随机状态 + s) * 6364136223846793005 + 进化_随机增量) & 0x7FFFFFFFFFFFFFFF
}

函数 进化_随机() {
 定义 旧 = 进化_随机状态
 进化_随机状态 = (旧 * 6364136223846793005 + 进化_随机增量) & 0x7FFFFFFFFFFFFFFF
 定义 xsh = ((旧 >> 18) ^ 旧) >> 27
 定义 旋转量 = 旧 >> 59
 定义 r = ((xsh >> 旋转量) | (xsh << (32 - 旋转量))) & 0x7FFFFFFF
 返回 r % 1000000000
}

// 范围随机: [lo, hi)
函数 进化_随机范围(lo, hi) { 定义 r = 进化_随机() % (hi - lo) + lo
 返回 r
}

// 个体表示
// 个体 = [适应度, 基因0, 基因1, ..., 基因N-1]
// 适应度在索引0, 基因从索引1开始

函数 进化_创建个体(n_genes) { 定义 可变 ind = [0] // 适应度=0
 定义 可变 i = 0
 当 (i < n_genes) {
 evo_追加(ind, 进化_随机范围(0 - 1000, 1000))
 i = i + 1
 }
 返回 ind
}

函数 进化_取适应度(ind) { 返回 ind[0] }
函数 进化_设适应度(ind, f) { ind[0] = f }
函数 进化_取基因(ind, i) { 返回 ind[1 + i] }
函数 进化_设基因(ind, i, v) { ind[1 + i] = v }
函数 进化_基因数(ind) { 返回 计数(ind) - 1 }

// 变异
// 对个体的基因做小范围随机扰动

函数 进化_变异(ind, strength) { 定义 n = 进化_基因数(ind)
 定义 可变 子节点 = [0]
 定义 可变 i = 0
 当 (i < n) { 定义 可变 v = 进化_取基因(ind, i)
 // 每个基因有30%概率变异
 如果 (进化_随机() % 100 < 30) {
 v = v + 进化_随机范围(0 - strength, strength)
 }
 evo_追加(子节点, v)
 i = i + 1
 }
 返回 子节点
}

// 交叉
// 两个父代产生一个子代 (均匀交叉)

函数 进化_交叉(parent1, parent2) { 定义 n = 进化_基因数(parent1)
 定义 可变 子节点 = [0]
 定义 可变 i = 0
 当 (i < n) { 如果 (进化_随机() % 2 == 0) {
 evo_追加(子节点, 进化_取基因(parent1, i))
 } 否则 {
 evo_追加(子节点, 进化_取基因(parent2, i))
 }
 i = i + 1
 }
 返回 子节点
}

// 种群管理

// 创建随机种群
函数 进化_创建种群(种群大小, n_genes) { 定义 可变 pop = []
 定义 可变 i = 0
 当 (i < 种群大小) {
 evo_追加(pop, 进化_创建个体(n_genes))
 i = i + 1
 }
 返回 pop
}

// 找最优个体
函数 进化_最优(pop) { 定义 可变 最优索引 = 0
 定义 可变 best_fit = 进化_取适应度(pop[0])
 定义 可变 i = 1
 当 (i < 计数(pop)) { 定义 f = 进化_取适应度(pop[i])
 如果 (f > best_fit) {
 best_fit = f
 最优索引 = i
 }
 i = i + 1
 }
 返回 pop[最优索引]
}

// 核心进化循环
// eval_fn: 评估函数 (外部传入)
// 返回最优个体

函数 进化_演化(pop, eval_fn, generations, mut_strength) { 定义 种群大小 = 计数(pop)
    定义 可变 ei = 0

 定义 可变 代数 = 0
 当 (代数 < generations) {
 // 评估所有个体
 当 (ei < 种群大小) { 定义 fitness = eval_fn(pop[ei])
 进化_设适应度(pop[ei], fitness)
 ei = ei + 1
 }

 // 选最优2个
 定义 可变 best1_idx = 0
 定义 可变 best1_fit = 0 - 0x7FFFFFFF
 定义 可变 best2_idx = 1
 定义 可变 best2_fit = 0 - 0x7FFFFFFF

 定义 可变 si = 0
 当 (si < 种群大小) { 定义 f = 进化_取适应度(pop[si])
 如果 (f > best1_fit) {
 best2_idx = best1_idx
 best2_fit = best1_fit
 best1_idx = si
 best1_fit = f
 } 否则 { 如果 (f > best2_fit) {
 best2_idx = si
 best2_fit = f
 }
 }
 si = si + 1
 }

 // 精英保留 + 变异 + 交叉填充
 定义 elite1 = pop[best1_idx]
 定义 elite2 = pop[best2_idx]

 定义 可变 新种群 = []
 evo_追加(新种群, elite1) // 保留最优
 evo_追加(新种群, elite2) // 保留次优

 定义 可变 ni = 2
 当 (ni < 种群大小) { 如果 (ni % 2 == 0) {
 // 变异最优
 evo_追加(新种群, 进化_变异(elite1, mut_strength))
 } 否则 {
 // 交叉
 evo_追加(新种群, 进化_交叉(elite1, elite2))
 }
 ni = ni + 1
 }

 // 替换种群
 pop = 新种群

 如果 (代数 % 10 == 0) {
 打印(" 进化代" + 转字符串(代数) + " 最优=" + 转字符串(best1_fit))
 }

 代数 = 代数 + 1
 }

 返回 进化_最优(pop)
}

// 锦标赛选择 (Tournament Selection, 0 , 0)
// 随机选k个, 取最优, 比轮盘赌更抗噪声

函数 进化_锦标赛选(pop, 锦标赛大小) { 定义 种群大小 = 计数(pop)
 定义 可变 最优索引 = 进化_随机() % 种群大小
 定义 可变 best_fit = 进化_取适应度(pop[最优索引])
 定义 可变 i = 1
 当 (i < 锦标赛大小) { 定义 索引 = 进化_随机() % 种群大小
 定义 f = 进化_取适应度(pop[索引])
 如果 (f > best_fit) {
 best_fit = f
 最优索引 = 索引
 }
 i = i + 1
 }
 返回 pop[最优索引]
}

// 自适应变异 (对决15验证: +5%)
// 变异强度随适应度自动调节
// 适应度高→小变异(微调), 适应度低→大变异(探索)

函数 进化_自适应变异(ind, 基础强度, 最优适应度) { 定义 n = 进化_基因数(ind)
 定义 当前适应 = 进化_取适应度(ind)
 // 适应度差距越大, 变异越强
 定义 可变 强度 = 基础强度
 如果 (最优适应度 > 0) { 定义 可变 比例 = (最优适应度 - 当前适应) * 1000 / 最优适应度
 如果 (比例 < 0) { 比例 = 0 }
 强度 = 基础强度 + 基础强度 * 比例 / 1000
 }
 定义 可变 子节点 = [0]
 定义 可变 i = 0
 当 (i < n) { 定义 可变 v = 进化_取基因(ind, i)
 如果 (进化_随机() % 100 < 30) {
 v = v + 进化_随机范围(0 - 强度, 强度)
 }
 evo_追加(子节点, v)
 i = i + 1
 }
 返回 子节点
}

// 单点交叉

函数 进化_单点交叉(parent1, parent2) { 定义 n = 进化_基因数(parent1)
 定义 切点 = 进化_随机() % n
 定义 可变 子节点 = [0]
 定义 可变 i = 0
 当 (i < n) { 如果 (i < 切点) {
 evo_追加(子节点, 进化_取基因(parent1, i))
 } 否则 {
 evo_追加(子节点, 进化_取基因(parent2, i))
 }
 i = i + 1
 }
 返回 子节点
}

// 精英保留进化 (增强版)
// 锦标赛选择 + 自适应变异 + 精英保留 + 多样性维护

函数 进化_演化V2(pop, eval_fn, generations, mut_strength, 锦标赛大小, 精英数) { 定义 种群大小 = 计数(pop)
    定义 可变 ei = 0

 定义 可变 代数 = 0
 当 (代数 < generations) {
 // 评估
 当 (ei < 种群大小) {
 进化_设适应度(pop[ei], eval_fn(pop[ei]))
 ei = ei + 1
 }

 // 找精英
 定义 可变 精英索引 = []
 定义 可变 已用 = []
 定义 可变 ui = 0
 当 (ui < 种群大小) { evo_追加(已用, 0)
 ui = ui + 1 }

 定义 可变 ei2 = 0
 当 (ei2 < 精英数) { 定义 可变 最优 = 0 - 1
 定义 可变 best_f = 0 - 0x7FFFFFFF
 定义 可变 si = 0
 当 (si < 种群大小) { 如果 (已用[si] == 0 且 进化_取适应度(pop[si]) > best_f) {
 best_f = 进化_取适应度(pop[si])
 最优 = si
 }
 si = si + 1
 }
 如果 (最优 >= 0) {
 evo_追加(精英索引, 最优)
 已用[最优] = 1
 }
 ei2 = ei2 + 1
 }

 定义 最优适应 = 进化_取适应度(pop[精英索引[0]])

 // 新种群: 精英 + 锦标赛选择繁殖
 定义 可变 新种群 = []
 // 保留精英
 定义 可变 eidx = 0
 当 (eidx < 计数(精英索引)) {
 evo_追加(新种群, pop[精英索引[eidx]])
 eidx = eidx + 1
 }

 // 填充剩余
 定义 可变 ni = 计数(精英索引)
 当 (ni < 种群大小) { 定义 p1 = 进化_锦标赛选(pop, 锦标赛大小)
 如果 (进化_随机() % 100 < 70) {
 // 70% 交叉+变异
 定义 p2 = 进化_锦标赛选(pop, 锦标赛大小)
 定义 子节点 = 进化_交叉(p1, p2)
 evo_追加(新种群, 进化_自适应变异(子节点, mut_strength, 最优适应))
 } 否则 {
 // 30% 纯自适应变异
 evo_追加(新种群, 进化_自适应变异(p1, mut_strength, 最优适应))
 }
 ni = ni + 1
 }

 pop = 新种群

 如果 (代数 % 10 == 0) {
 打印(" 进化v2 代" + 转字符串(代数) + " 最优=" + 转字符串(最优适应))
 }
 代数 = 代数 + 1
 }

 返回 进化_最优(pop)
}

// 差分进化 (DE/rand/1/bin)
// 经典差分进化: 3个随机个体做差分向量

函数 进化_差分(pop, eval_fn, generations, F, CR) { 定义 种群大小 = 计数(pop)
    定义 可变 ei = 0

 定义 可变 代数 = 0
 当 (代数 < generations) {
 // 评估
 当 (ei < 种群大小) {
 进化_设适应度(pop[ei], eval_fn(pop[ei]))
 ei = ei + 1
 }

 定义 可变 新种群 = []
 定义 可变 ti = 0
 当 (ti < 种群大小) { 定义 n = 进化_基因数(pop[ti])
 // 选3个不同个体
 定义 可变 r1 = 进化_随机() % 种群大小
 定义 可变 r2 = 进化_随机() % 种群大小
 定义 可变 r3 = 进化_随机() % 种群大小
 当 (r1 == ti) { r1 = (r1 + 1) % 种群大小 }
 当 (r2 == ti 或 r2 == r1) { r2 = (r2 + 1) % 种群大小 }
 当 (r3 == ti 或 r3 == r1 或 r3 == r2) { r3 = (r3 + 1) % 种群大小 }

 // 变异向量: v = x_r1 + F * (x_r2 - x_r3)
 定义 j_rand = 进化_随机() % n
 定义 可变 trial = [0]
 定义 可变 gi = 0
 当 (gi < n) { 如果 (进化_随机() % 1000 < CR 或 gi == j_rand) { 定义 v = 进化_取基因(pop[r1], gi) + F * (进化_取基因(pop[r2], gi) - 进化_取基因(pop[r3], gi)) / 1000
 evo_追加(trial, v)
 } 否则 {
 evo_追加(trial, 进化_取基因(pop[ti], gi))
 }
 gi = gi + 1
 }

 // 贪心选择
 定义 trial_fit = eval_fn(trial)
 进化_设适应度(trial, trial_fit)
 如果 (trial_fit >= 进化_取适应度(pop[ti])) {
 evo_追加(新种群, trial)
 } 否则 {
 evo_追加(新种群, pop[ti])
 }
 ti = ti + 1
 }

 pop = 新种群

 如果 (代数 % 10 == 0) { 定义 最优 = 进化_最优(pop)
 打印(" 差分进化 代" + 转字符串(代数) + " 最优=" + 转字符串(进化_取适应度(最优)))
 }
 代数 = 代数 + 1
 }

 返回 进化_最优(pop)
}

// 种群多样性度量
// 平均基因距离 (越大越多样)

函数 进化_多样性(pop) { 定义 种群大小 = 计数(pop)
    定义 可变 总距 = 0
 如果 (种群大小 < 2) { 返回 0 }
 定义 n = 进化_基因数(pop[0])
 定义 可变 对数 = 0
 定义 可变 i = 0
 当 (i < 种群大小) { 定义 可变 j = i + 1
 当 (j < 种群大小) { 定义 可变 d = 0
 定义 可变 k = 0
 当 (k < n) { 定义 差值 = 进化_取基因(pop[i], k) - 进化_取基因(pop[j], k)
 d = d + 进化_绝对值(差值)
 k = k + 1
 }
 总距 = 总距 + d / n
 对数 = 对数 + 1
 j = j + 1
 }
 i = i + 1
 }
 如果 (对数 == 0) { 返回 0 }
 返回 总距 / 对数
}

// 粒子群优化 (PSO, 0 , 0 , 0 , 0, 0, 0)
函数 pso_创建粒子(n_dims) { 定义 可变 粒子 = []
 // [位置..., 速度..., 个人最优位置..., 个人最优适应度, 当前适应度]
 定义 可变 i = 0
 当 (i < n_dims) {
 evo_追加(粒子, 进化_随机范围(0 - 1000, 1000)) // 位置
 i = i + 1
 }
 i = 0
 当 (i < n_dims) { evo_追加(粒子, 进化_随机范围(0 - 100, 100))
 i = i + 1 } // 速度
 i = 0
 当 (i < n_dims) { evo_追加(粒子, 粒子[i])
 i = i + 1 } // pbest位置=初始位置
 evo_追加(粒子, 0 - 0x7FFFFFFF) // pbest适应度
 evo_追加(粒子, 0) // 当前适应度
 返回 粒子
}

函数 pso_优化(粒子群, eval_fn, n_dims, 迭代数, w, c1, c2) { 定义 n = 计数(粒子群)
 // 全局最优
 定义 可变 gbest_pos = []
 定义 可变 di = 0
 当 (di < n_dims) { evo_追加(gbest_pos, 0)
 di = di + 1 }
 定义 可变 gbest_fit = 0 - 0x7FFFFFFF

 定义 可变 迭代 = 0
 当 (迭代 < 迭代数) { 定义 可变 pi = 0
 当 (pi < n) { 定义 p = 粒子群[pi]
 // 评估
 定义 可变 位置 = []
 定义 可变 d = 0
 当 (d < n_dims) { evo_追加(位置, p[d])
 d = d + 1 }
 定义 fit = eval_fn(位置)
 p[3 * n_dims + 1] = fit
 // 更新个人最优
 如果 (fit > p[3 * n_dims]) {
 p[3 * n_dims] = fit
 d = 0
 当 (d < n_dims) { p[2 * n_dims + d] = p[d]
 d = d + 1 }
 }
 // 更新全局最优
 如果 (fit > gbest_fit) {
 gbest_fit = fit
 d = 0
 当 (d < n_dims) { gbest_pos[d] = p[d]
 d = d + 1 }
 }
 // 更新速度和位置
 d = 0
 当 (d < n_dims) { 定义 r1 = 进化_随机() % 1000
 定义 r2 = 进化_随机() % 1000
 p[n_dims + d] = w * p[n_dims + d] / 1000 + c1 * r1 * (p[2 * n_dims + d] - p[d]) / (1000 * 1000) + c2 * r2 * (gbest_pos[d] - p[d]) / (1000 * 1000)
 p[d] = p[d] + p[n_dims + d]
 d = d + 1
 }
 pi = pi + 1
 }
 迭代 = 迭代 + 1
 }
 返回 gbest_pos
}

// 岛屿模型 (Island Model GA)
// 多个子种群独立进化, 周期性迁移
函数 进化_岛屿演化(岛屿列表, eval_fn, 总代数, mut_strength, 迁移间隔, _迁移数) { 定义 岛数 = 计数(岛屿列表)
    定义 可变 ei = 0
 定义 可变 代数 = 0
 当 (代数 < 总代数) {
 // 各岛独立进化一代
 定义 可变 isle = 0
 当 (isle < 岛数) { 定义 pop = 岛屿列表[isle]
 定义 种群大小 = 计数(pop)
 // 评估
 当 (ei < 种群大小) {
 进化_设适应度(pop[ei], eval_fn(pop[ei]))
 ei = ei + 1
 }
 // 简单进化: 精英+变异
 定义 最优 = 进化_最优(pop)
 定义 可变 新种群 = [最优]
 定义 可变 ni = 1
 当 (ni < 种群大小) {
 evo_追加(新种群, 进化_变异(最优, mut_strength))
 ni = ni + 1
 }
 岛屿列表[isle] = 新种群
 isle = isle + 1
 }
 // 迁移
 如果 (代数 > 0 且 代数 % 迁移间隔 == 0) {
 // 环形迁移: 岛i的最优→岛(i+1)
 isle = 0
 当 (isle < 岛数) { 定义 源 = 岛屿列表[isle]
 定义 目标岛 = (isle + 1) % 岛数
 定义 最优 = 进化_最优(源)
 // 替换目标岛的最差个体
 定义 目标pop = 岛屿列表[目标岛]
 定义 可变 worst_idx = 0
 定义 可变 worst_fit = 进化_取适应度(目标pop[0])
 定义 可变 wi = 1
 当 (wi < 计数(目标pop)) { 如果 (进化_取适应度(目标pop[wi]) < worst_fit) {
 worst_fit = 进化_取适应度(目标pop[wi])
 worst_idx = wi
 }
 wi = wi + 1
 }
 目标pop[worst_idx] = 最优
 isle = isle + 1
 }
 }
 代数 = 代数 + 1
 }
 // 返回所有岛的总最优
 定义 可变 全局最优 = 进化_最优(岛屿列表[0])
 定义 可变 fi = 1
 当 (fi < 岛数) { 定义 岛最优 = 进化_最优(岛屿列表[fi])
 如果 (进化_取适应度(岛最优) > 进化_取适应度(全局最优)) {
 全局最优 = 岛最优
 }
 fi = fi + 1
 }
 返回 全局最优
}

// 多目标适应度 (加权和)
函数 进化_加权适应度(目标值列表, 权重列表) { 定义 n = 计数(目标值列表)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) {
 总和 = 总和 + 目标值列表[i] * 权重列表[i] / 1000
 i = i + 1
 }
 返回 总和
}

// 测试
函数 进化_测试() {
 打印("=== 进化搜索测试 ===")

 进化_种子(12345)

 // 测试随机数
 定义 r1 = 进化_随机()
 定义 r2 = 进化_随机()
 如果 (r1 != r2) { 打印(" 随机数: 通过") }

 // 测试个体
 定义 ind = 进化_创建个体(5)
 打印(" 个体基因数=" + 转字符串(进化_基因数(ind)))
 如果 (进化_基因数(ind) == 5) { 打印(" 个体创建: 通过") }

 // 测试变异
 定义 子节点 = 进化_变异(ind, 100)
 打印(" 变异基因数=" + 转字符串(进化_基因数(子节点)))
 如果 (进化_基因数(子节点) == 5) { 打印(" 变异: 通过") }

 打印("进化搜索: 全部通过")
}

// 进化_测试()

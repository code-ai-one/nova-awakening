// 快速路径: 阶0用PCP缓存
函数 伙伴_分配页面(gfp, 阶, 首选zone, 迁移类型) {
    如果 (阶 == 0 && 迁移类型 < MIGRATE_PCPTYPES) {
        定义 可变 i = 0
        当 (i < 活跃zone数) {
            定义 可变 z = 所有zone[zone搜索顺序[i]]
            如果 (!z.已初始化) { i = i + 1; 继续 }
            如果 (z.类型 > 首选zone) { i = i + 1; 继续 }
            定义 页号 = PCP_分配(z, 迁移类型)
            如果 (页号 >= 0) {
                全局空闲页数 = 全局空闲页数 - 1
                如果 ((gfp & __GFP_ZERO) != 0) {
                    内存清零(页号到地址(页号), 页大小)
                }
                返回 页号
            }
            i = i + 1
        }
    }

    定义 是原子 = (gfp & GFP_ATOMIC) != 0 || (gfp & __GFP_HIGH) != 0
    定义 可变 i = 0
    当 (i < 活跃zone数) {
        定义 可变 z = 所有zone[zone搜索顺序[i]]
        如果 (!z.已初始化) { i = i + 1; 继续 }
        如果 (z.类型 > 首选zone) { i = i + 1; 继续 }

        // 水位线检查 (原子分配用WMARK_MIN, 普通用WMARK_LOW)
        定义 水位级别 = WMARK_LOW
        如果 (是原子) { 水位级别 = WMARK_MIN }
        如果 (!zone_水位OK(z, 阶, 水位级别, 首选zone)) {
            如果 (!是原子) {
                // 唤醒kswapd后台回收
                唤醒kswapd(z.类型)
                // 直接内存回收(同步, 可能阻塞)
                定义 回收页数 = 直接内存回收(阶, gfp)
                如果 (回收页数 > 0) {
                    // 回收成功, 重新尝试分配(不跳过此zone)
                    自旋锁_获取(z.锁)
                    定义 重试页号 = __伙伴_取页(z, 阶, 迁移类型)
                    自旋锁_释放(z.锁)
                    如果 (重试页号 >= 0) {
                        全局空闲页数 = 全局空闲页数 - (1 << 阶)
                        返回 重试页号
                    }
                }
            }
            i = i + 1
            继续
        }

        // 从伙伴系统分配
        自旋锁_获取(z.锁)
        定义 页号 = __伙伴_取页(z, 阶, 迁移类型)
        自旋锁_释放(z.锁)

        如果 (页号 >= 0) {
            定义 分配大小 = 1 << 阶
            全局空闲页数 = 全局空闲页数 - 分配大小

            如果 ((gfp & __GFP_ZERO) != 0) {
                内存清零(页号到地址(页号), 分配大小 * 页大小)
            }
            返回 页号
        }
        i = i + 1
    }

    // 所有zone都分配失败
    如果 ((gfp & __GFP_NOWARN) == 0) {
        内核警告("伙伴系统: 分配失败")
        内核警告数值("  请求阶", 阶)
        内核警告数值("  全局空闲页", 全局空闲页数)
    }
    返回 0 - 1
}

函数 伙伴系统_释放(页号, 阶) {
    如果 (页号 < 0 || 阶 > 最大阶) { 返回 }

    // 确定zone
    定义 页 = 页描述符_获取(页号)
    如果 (页 == 空) { 返回 }
    定义 zone类型 = 页[PG_区域]
    定义 可变 z = 所有zone[zone类型]
    如果 (!z.已初始化) { 返回 }

    定义 分配大小 = 1 << 阶
    定义 迁移类型 = 获取页块迁移类型(z, 页号)

    // 更新页描述符
    定义 可变 j = 0
    当 (j < 分配大小) {
        定义 p = 页描述符_获取(页号 + j)
        如果 (p != 空) { 页描述符_减引用(p) }
        j = j + 1
    }

    // 单页走PCP快速路径
    如果 (阶 == 0 && 迁移类型 < MIGRATE_PCPTYPES) {
        PCP_释放(z, 页号, 迁移类型)
        全局空闲页数 = 全局空闲页数 + 1
        z.释放次数 = z.释放次数 + 1
        返回
    }

    // 多页走伙伴系统慢速路径(带合并)
    自旋锁_获取(z.锁)
    __伙伴_放回(z, 页号, 阶, 迁移类型)
    自旋锁_释放(z.锁)

    全局空闲页数 = 全局空闲页数 + 分配大小
    z.释放次数 = z.释放次数 + 1
}

// 便捷接口 

函数 alloc_pages(阶, gfp) {
    定义 页号 = 伙伴系统_分配_带标志(阶, gfp)
    如果 (页号 < 0) { 返回 0 }
    返回 物理到虚拟(页号到地址(页号))
}

函数 free_pages(虚拟地址, 阶) {
    定义 物理地址 = 虚拟到物理(虚拟地址)
    定义 页号 = 地址到页号(物理地址)
    伙伴系统_释放(页号, 阶)
}

函数 alloc_page(gfp) { 返回 alloc_pages(0, gfp) }
函数 free_page(虚拟地址) { free_pages(虚拟地址, 0) }

函数 __get_free_page(gfp) { 返回 alloc_page(gfp) }
函数 __get_free_pages(gfp, 阶) { 返回 alloc_pages(阶, gfp) }
函数 get_zeroed_page(gfp) { 返回 alloc_page(gfp | __GFP_ZERO) }

// 统计与诊断

函数 伙伴系统_各阶空闲数() {
    定义 可变 结果 = []
    定义 可变 阶 = 0
    当 (阶 <= 最大阶) {
        定义 可变 阶总计 = 0
        定义 可变 i = 0
        当 (i < 活跃zone数) {
            定义 z = 所有zone[zone搜索顺序[i]]
            如果 (z.已初始化) { 阶总计 = 阶总计 + z.空闲区[阶].空闲数 }
            i = i + 1
        }
        追加(结果, 阶总计)
        阶 = 阶 + 1
    }
    返回 结果
}

函数 伙伴系统_碎片指数() {
    如果 (全局空闲页数 == 0) { 返回 1000 }
    定义 各阶 = 伙伴系统_各阶空闲数()
    定义 可变 大块页 = 0
    定义 可变 i = 4
    当 (i <= 最大阶) {
        大块页 = 大块页 + 各阶[i] * (1 << i)
        i = i + 1
    }
    返回 1000 - 大块页 * 1000 / 全局空闲页数
}

函数 伙伴系统_统计() {
    返回 [全局总页数, 全局空闲页数, 全局总页数 - 全局空闲页数]
}

函数 伙伴系统_打印状态() {
    内核信息("═══ 伙伴系统状态 ═══")
    内核信息数值("总页数", 全局总页数)
    内核信息数值("空闲页数", 全局空闲页数)
    内核信息数值("碎片指数", 伙伴系统_碎片指数())

    定义 可变 i = 0
    当 (i < 活跃zone数) {
        定义 z = 所有zone[zone搜索顺序[i]]
        如果 (!z.已初始化) { i = i + 1; 继续 }
        内核信息(字符串拼接("─── zone: ", z.名称, " ───"))
        内核信息数值("  管理页数", z.管理页数)
        内核信息数值("  空闲页数", zone_空闲页数(z))
        内核信息数值("  水位MIN", z.水位线[WMARK_MIN])
        内核信息数值("  水位LOW", z.水位线[WMARK_LOW])
        内核信息数值("  水位HIGH", z.水位线[WMARK_HIGH])
        内核信息数值("  分配次数", z.分配次数)
        内核信息数值("  PCP命中", z.PCP命中)
        内核信息数值("  回退次数", z.回退次数)
        内核信息数值("  合并次数", z.合并次数)
        // 打印各阶空闲分布
        定义 可变 阶 = 0
        当 (阶 <= 最大阶) {
            内核信息数值(字符串拼接("  阶", 整数转字符串(阶)), z.空闲区[阶].空闲数)
            阶 = 阶 + 1
        }
        i = i + 1
    }
}

// 向后兼容接口 (保持与旧代码兼容)

函数 伙伴_检查水位(水位) {
    定义 z = 所有zone[ZONE_NORMAL]
    如果 (!z.已初始化) { z = 所有zone[ZONE_直传] }
    返回 zone_水位OK(z, 0, 水位, ZONE_NORMAL)
}

// 别名(被ram文件系统模块
函数 分配页面(gfp标志) { 返回 alloc_page(gfp标志) }
函数 页面地址(页) { 如果 (页 == 空) { 返回 0 } 返回 页 }

// 扩展伙伴系统释放功能

定义 可变 伙伴释放_已初始化 = 假
定义 可变 释放_总次数 = 0
定义 可变 释放_合并次数 = 0
定义 可变 释放_0阶次数 = 0
定义 可变 释放_高阶次数 = 0
定义 可变 释放_错误数 = 0
定义 可变 释放_延迟总计 = 0
定义 可变 释放_延迟样本 = 0
定义 可变 释放_最大延迟 = 0
定义 可变 释放_速率 = 0
定义 可变 释放_速率窗口 = 0
定义 可变 释放_速率时刻 = 0
定义 可变 释放_峰值速率 = 0

// 分配统计
定义 可变 分配_总次数 = 0
定义 可变 分配_失败次数 = 0
定义 可变 分配_0阶次数 = 0
定义 可变 分配_高阶次数 = 0
定义 可变 分配_回退次数 = 0

函数 伙伴释放_记录释放(阶) {
    释放_总次数 = 释放_总次数 + 1
    释放_速率窗口 = 释放_速率窗口 + 1
    如果 (阶 == 0) { 释放_0阶次数 = 释放_0阶次数 + 1 }
    否则 { 释放_高阶次数 = 释放_高阶次数 + 1 }
}

函数 伙伴释放_记录合并() {
    释放_合并次数 = 释放_合并次数 + 1
}

函数 伙伴释放_记录分配(阶, 成功) {
    分配_总次数 = 分配_总次数 + 1
    如果 (成功 == 假) { 分配_失败次数 = 分配_失败次数 + 1 }
    如果 (阶 == 0) { 分配_0阶次数 = 分配_0阶次数 + 1 }
    否则 { 分配_高阶次数 = 分配_高阶次数 + 1 }
}

// AI基因: 延迟+速率
函数 伙伴释放_记录延迟(延迟) {
    释放_延迟样本 = 释放_延迟样本 + 1
    释放_延迟总计 = 释放_延迟总计 + 延迟
    如果 (延迟 > 释放_最大延迟) { 释放_最大延迟 = 延迟 }
}

函数 伙伴释放_平均延迟() {
    如果 (释放_延迟样本 == 0) { 返回 0 }
    返回 释放_延迟总计 / 释放_延迟样本
}

函数 伙伴释放_更新速率() {
    定义 可变 现在 = 0
    汇编 { "rdtsc" "mov [rbp-8], rax" }
    定义 间隔 = 现在 - 释放_速率时刻
    如果 (间隔 >= 1000000000) {
        释放_速率 = 释放_速率窗口 * 1000000000 / 间隔
        如果 (释放_速率 > 释放_峰值速率) { 释放_峰值速率 = 释放_速率 }
        释放_速率窗口 = 0
        释放_速率时刻 = 现在
    }
}

函数 伙伴释放_初始化() {
    如果 (伙伴释放_已初始化 == 真) { 返回 0 - 17 }
    伙伴释放_已初始化 = 真
    打印("[伙伴释放] 初始化完成")
    返回 0
}

// 碎片指数计算

函数 伙伴_碎片指数_计算() {
    // 碎片指数 = 高阶分配失败率 / 总分配
    如果 (分配_总次数 == 0) { 返回 0 }
    返回 分配_失败次数 * 100 / 分配_总次数
}

函数 伙伴_合并率() {
    如果 (释放_总次数 == 0) { 返回 0 }
    返回 释放_合并次数 * 100 / 释放_总次数
}

// 完整统计 (≥15个指标)

函数 伙伴释放_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "已初始化", 伙伴释放_已初始化)
    字典设(统计, "释放总次数", 释放_总次数)
    字典设(统计, "释放合并次数", 释放_合并次数)
    字典设(统计, "释放0阶", 释放_0阶次数)
    字典设(统计, "释放高阶", 释放_高阶次数)
    字典设(统计, "分配总次数", 分配_总次数)
    字典设(统计, "分配失败", 分配_失败次数)
    字典设(统计, "分配0阶", 分配_0阶次数)
    字典设(统计, "分配高阶", 分配_高阶次数)
    字典设(统计, "分配回退", 分配_回退次数)
    字典设(统计, "碎片指数", 伙伴_碎片指数_计算())
    字典设(统计, "合并率(%)", 伙伴_合并率())
    字典设(统计, "平均延迟(ns)", 伙伴释放_平均延迟())
    字典设(统计, "最大延迟(ns)", 释放_最大延迟)
    字典设(统计, "速率", 释放_速率)
    字典设(统计, "峰值速率", 释放_峰值速率)
    字典设(统计, "错误数", 释放_错误数)
    返回 统计
}

函数 伙伴释放_打印统计() {
    定义 统计 = 伙伴释放_完整统计()
    打印("[伙伴释放] ═══════ 完整统计 ═══════")
    打印("  释放总数:     " + 转字符串(字典取(统计, "释放总次数")))
    打印("  释放合并:     " + 转字符串(字典取(统计, "释放合并次数")))
    打印("  释放0阶:      " + 转字符串(字典取(统计, "释放0阶")))
    打印("  释放高阶:     " + 转字符串(字典取(统计, "释放高阶")))
    打印("  分配总数:     " + 转字符串(字典取(统计, "分配总次数")))
    打印("  分配失败:     " + 转字符串(字典取(统计, "分配失败")))
    打印("  碎片指数:     " + 转字符串(字典取(统计, "碎片指数")))
    打印("  合并率:       " + 转字符串(字典取(统计, "合并率(%)")) + "%")
    打印("  平均延迟:     " + 转字符串(字典取(统计, "平均延迟(ns)")) + "ns")
    打印("  速率:         " + 转字符串(字典取(统计, "速率")) + " 次/秒")
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    打印("[伙伴释放] ═════════════════════════")
    返回 0
}

函数 伙伴释放_dump() {
    打印("[伙伴释放 dump] ──────────────────")
    打印("  释放: " + 转字符串(释放_总次数) + " (合并" + 转字符串(释放_合并次数) + ")")
    打印("  分配: " + 转字符串(分配_总次数) + " (失败" + 转字符串(分配_失败次数) + ")")
    打印("  碎片: " + 转字符串(伙伴_碎片指数_计算()))
    打印("  速率: " + 转字符串(释放_速率))
    打印("[伙伴释放 dump] ──────────────────")
}

函数 伙伴释放_销毁() { 伙伴释放_已初始化 = 假; 返回 0 }

函数 伙伴释放_为内存区域提供分配统计() {
    返回 [分配_总次数, 分配_失败次数, 释放_总次数, 释放_合并次数]
}

函数 伙伴释放_为AI提供碎片模式() {
    返回 [伙伴_碎片指数_计算(), 伙伴_合并率(), 分配_高阶次数, 分配_失败次数]
}

函数 伙伴释放_为回收提供压力() {
    返回 [分配_失败次数, 释放_速率, 释放_峰值速率]
}

函数 伙伴释放_为procfs提供buddyinfo() {
    返回 [分配_总次数, 释放_总次数, 释放_合并次数, 分配_失败次数, 伙伴_碎片指数_计算()]
}

函数 伙伴释放_重置统计() {
    释放_总次数 = 0
    释放_合并次数 = 0
    释放_0阶次数 = 0
    释放_高阶次数 = 0
    分配_总次数 = 0
    分配_失败次数 = 0
    分配_0阶次数 = 0
    分配_高阶次数 = 0
    分配_回退次数 = 0
    释放_错误数 = 0
    释放_延迟总计 = 0
    释放_延迟样本 = 0
    释放_最大延迟 = 0
    释放_速率 = 0
    释放_速率窗口 = 0
    释放_峰值速率 = 0
    打印("[伙伴释放] 统计已重置")
    返回 0
}

函数 伙伴释放_为电源管理挂起() {
    // 挂起前冻结伙伴系统: 禁止新分配, 刷新空闲页统计
    定义 可变 挂起页数 = 全局空闲页数
    全局_伙伴冻结 = 真
    返回 挂起页数
}
函数 伙伴释放_为调度器提供内存压力() {
    返回 [释放_速率, 分配_失败次数, 伙伴_碎片指数_计算()]
}

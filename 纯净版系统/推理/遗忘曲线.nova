导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("./激活导数.nova")
导入("./定点精度.nova")
导入("./缓存占用.nova")
导入("./对比敏感.nova")
导入("./值乘.nova")

// Ebbinghaus遗忘曲线: R(t) = exp(-t/S)

函数 遗忘曲线(时间, 稳定性) {
    如果 (稳定性 <= 0) { 返回 Q_ZERO }
    定义 指数 = -Q除(时间, 稳定性)
    返回 Q_exp(指数)
}

// 预测误差: |实际 - 预测| / 实际
函数 相对预测误差(实际, 预测) {
    如果 (实际 == 0) { 返回 Q_ONE }
    定义 差 = 实际 - 预测
    如果 (差 < 0) { 差 = -差 }
    返回 Q除(差, 实际)
}

// §4.3 决策理论 (Decision Theory)
// Weber-Fechner定律:
//   ΔI/I = k (刚好可察觉差异与刺激强度成正比)
//   Nova的JND计算直接应用此定律:
//     高亮度区域: 需要更大的亮度变化才能被察觉
//     低亮度区域: 很小的变化就能被察觉
// Fitts定律:
//   T = a + b × log₂(D/W + 1)
//   T=移动时间, D=距离, W=目标宽度
//   Nova用此预测: 用户点击目标所需时间
//   → 越难点击的目标, AI给予越高注意力权重
// Hick-Hyman定律:
//   T = a + b × log₂(n+1)
//   n=选项数, T=选择时间
//   → 菜单项越多, 选择越慢, AI预降低不太可能被选的选项

// Weber比率: ΔI/I = k
// 返回在给定亮度下的JND阈值
函数 Weber_JND(亮度_q10, Weber_k) {
    // ΔI = k × I
    返回 Q乘(Weber_k, 亮度_q10)
}

// Fitts定律: T = a + b × log₂(D/W + 1)
函数 Fitts预测时间(距离, 目标宽度) {
    如果 (目标宽度 <= 0) { 返回 10 * Q_ONE }
    定义 难度 = Q除(距离, 目标宽度) + Q_ONE
    定义 log2_难度 = Q除(Q_log(难度), 710)    // log₂ = ln/ln2
    // a=50ms, b=150ms (典型值)
    返回 50 * Q_ONE + Q乘(150 * Q_ONE, log2_难度)
}

// §4.4 学习理论 (Learning Theory)
// 赫布学习(Hebb, 1949):
//   "同时激活的神经元之间连接增强"
//   Δw = η × x × y (前突触×后突触)
//   Nova的在线学习本质上是赫布学习的现代版本(反向传播)
// PAC学习(Probably Approximately Correct):
//   样本复杂度: m ≥ (1/ε)(ln|H| + ln(1/δ))
//   Nova的AI模型参数 < 2000 → ln|H| 很小
//   → 需要的训练样本很少 → 适合在线学习
// VC维度:
//   线性分类器(d维): VC-dim = d+1
//   2层神经网络(w个权重): VC-dim = O(w×log(w))
//   Nova典型网络(264个权重): VC-dim ≈ 264×8 ≈ 2112
//   → 泛化误差 ∝ √(VC-dim/m), m=样本数
//   → 需要约10000个样本达到5%误差
//   → 以60fps渲染, 约3分钟浏览即可收敛

// VC维度估计: 2层网络约 O(w × log(w))
函数 估计VC维度(总权重数) {
    // VC ≈ w × log₂(w)
    定义 log2_w = Q除(Q_log(总权重数 * Q_ONE), 710)
    返回 Q乘(总权重数 * Q_ONE, log2_w) >> Q_SHIFT
}

// 泛化误差上界: ε ≤ √(VC / m)
函数 泛化误差上界(VC维, 样本数) {
    如果 (样本数 <= 0) { 返回 Q_ONE }
    返回 Q开方(Q除(VC维 * Q_ONE, 样本数 * Q_ONE))
}

// §5 间隔重复调度器
// 原理: 基于遗忘曲线优化复习时间点
//   每次成功回忆 → 稳定性×2.5, 间隔增大
//   每次失败 → 稳定性×0.5, 间隔缩小

定义 最大记忆卡 = 256

结构 记忆卡片 {
    内容哈希,
    稳定性,        // ×1000 (初始=1000)
    下次复习时间,  // 绝对时间戳
    复习次数,
    成功次数,
    失败次数,
}

定义 可变 记忆卡库 = []
定义 可变 记忆卡数 = 0
定义 稳定性_成功倍率 = 2500  // ×1000: 成功后稳定性×2.5
定义 稳定性_失败倍率 = 500   // ×1000: 失败后稳定性×0.5

函数 记忆_添加(内容哈希, 当前时间) {
    如果 (记忆卡数 >= 最大记忆卡) { 返回 -1 }
    定义 卡 = 记忆卡片 {}
    卡.内容哈希 = 内容哈希
    卡.稳定性 = 1000
    卡.下次复习时间 = 当前时间 + 60  // 初始60秒后复习
    卡.复习次数 = 0
    卡.成功次数 = 0
    卡.失败次数 = 0
    追加(记忆卡库, 卡)
    定义 索引 = 记忆卡数
    记忆卡数 = 记忆卡数 + 1
    返回 索引
}

函数 记忆_复习(索引, 成功, 当前时间) {
    如果 (索引 >= 记忆卡数) { 返回 }
    记忆卡库[索引].复习次数 = 记忆卡库[索引].复习次数 + 1
    如果 (成功) {
        记忆卡库[索引].成功次数 = 记忆卡库[索引].成功次数 + 1
        记忆卡库[索引].稳定性 = 记忆卡库[索引].稳定性 * 稳定性_成功倍率 / 1000
        如果 (记忆卡库[索引].稳定性 > 100000) {
            记忆卡库[索引].稳定性 = 100000  // 封顶
        }
    } 否则 {
        记忆卡库[索引].失败次数 = 记忆卡库[索引].失败次数 + 1
        记忆卡库[索引].稳定性 = 记忆卡库[索引].稳定性 * 稳定性_失败倍率 / 1000
        如果 (记忆卡库[索引].稳定性 < 100) {
            记忆卡库[索引].稳定性 = 100  // 下限
        }
    }
    // 计算下次复习间隔: 间隔 = 稳定性 (秒)
    记忆卡库[索引].下次复习时间 = 当前时间 + 记忆卡库[索引].稳定性
}

函数 记忆_获取到期卡(当前时间) {
    // 返回最紧迫的到期卡索引
    定义 可变 最佳 = -1
    定义 可变 最早时间 = 999999999
    定义 可变 i = 0
    当 (i < 记忆卡数) {
        如果 (记忆卡库[i].下次复习时间 <= 当前时间 && 记忆卡库[i].下次复习时间 < 最早时间) {
            最早时间 = 记忆卡库[i].下次复习时间
            最佳 = i
        }
        i = i + 1
    }
    返回 最佳
}

// §6 【原生颠覆性创新】记忆晶化理论
// 原理: 记忆不仅有“强度”, 还有“晶化度”
//   初学=液态(fragile), 多次复习=固态(robust)
//   晶化的记忆抵抗干扰, 液态记忆易被覆盖
//   晶化度 = 成功率 × 复习次数对数
//   达到阈值后“结晶”→极难遍忘
定义 晶化_阈值 = 800  // ×1000: 超过此值视为“结晶”

函数 记忆_晶化度(索引) {
    如果 (索引 >= 记忆卡数) { 返回 0 }
    定义 卡 = 记忆卡库[索引]
    如果 (卡.复习次数 == 0) { 返回 0 }
    // 成功率 × ln(复习次数+1)
    定义 成功率 = 卡.成功次数 * 1000 / 卡.复习次数
    // 近似对数: log2(n+1) ≈ 位数
    定义 可变 对数 = 0
    定义 可变 tmp = 卡.复习次数 + 1
    当 (tmp > 1) { tmp = tmp / 2; 对数 = 对数 + 1 }
    返回 成功率 * 对数 / 10  // ×1000
}

函数 记忆_已结晶(索引) {
    返回 记忆_晶化度(索引) > 晶化_阈值
}

// §7 【原生独创】情绪调制记忆
// 原理: 情绪状态影响记忆编码和提取效率
//   高兴奋 = 记忆编码增强(+50%), 但有干扰风险
//   淡定 = 记忆提取增强, 低干扰
//   焦虑 = 记忆编码抑制, 但威胁记忆增强

函数 情绪_编码修正(基础学习率, 情绪值) {
    // 情绪值: -1000(极度焦虑) 到 +1000(极度兴奋)
    // 正常范围 [-300, 300] 为中性
    如果 (情绪值 > 300) {
        // 兴奋: 增强编码 (+50%上限)
        定义 增强 = (情绪值 - 300) * 500 / 700  // 0-500
        返回 基础学习率 * (1000 + 增强) / 1000
    }
    如果 (情绪值 < -300) {
        // 焦虑: 抑制编码 (-40%下限)
        定义 抑制 = (0 - 情绪值 - 300) * 400 / 700  // 0-400
        返回 基础学习率 * (1000 - 抑制) / 1000
    }
    返回 基础学习率
}

函数 情绪_提取修正(基础稳定性, 情绪值) {
    // 淡定时提取效率最高
    定义 情绪强度 = 情绪值
    如果 (情绪强度 < 0) { 情绪强度 = 0 - 情绪强度 }
    // 越淡定 → 稳定性修正越高
    定义 修正 = (1000 - 情绪强度 / 3) * 基础稳定性 / 1000
    返回 修正
}


函数 理论基础_全面自检() {
    断言(理论验证_定点精度(), "定点数论验证失败")
    断言(Q_log(Q_ONE) == 0 || Q_log(Q_ONE) == 1, "ln(1)应为0")
    定义 亮度 = 计算亮度(512, 512, 512)
    断言(亮度 > 0, "亮度计算异常")
    定义 衰减 = 注视点衰减(0, 300 * Q_ONE)
    断言(衰减 >= Q_ONE - 10, "注视点中心衰减应≈1.0")
    定义 远衰减 = 注视点衰减(1000 * Q_ONE, 300 * Q_ONE)
    断言(远衰减 < Q_HALF, "远离注视点衰减应<0.5")
    定义 静止遮蔽 = 运动遮蔽系数(0)
    断言(静止遮蔽 == 0, "静止时不应有运动遮蔽")
    返回 真
}

函数 遗忘曲线_完整统计() {
    定义 可变 结晶数 = 0
    定义 可变 i = 0
    当 (i < 记忆卡数) {
        如果 (记忆_已结晶(i)) { 结晶数 = 结晶数 + 1 }
        i = i + 1
    }
    返回 [
        ["模块", "遗忘曲线"],
        ["记忆卡数", 记忆卡数],
        ["已结晶数", 结晶数],
        ["功能", "遗忘曲线+间隔重复+记忆晶化+情绪调制"],
        ["创新", "记忆晶化理论+情绪调制记忆"]
    ]
}

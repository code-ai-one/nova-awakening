导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/哈希整数.nova")

定义 最大配置项 = 128
定义 最大监听器 = 16
定义 类型_字符串 = 0
定义 类型_整数 = 1
定义 类型_布尔 = 2

结构 配置项 {
    键哈希,
    值哈希,
    整数值,
    布尔值,
    类型,
    只读,
    修改次数,
}

定义 可变 配置表 = []
定义 可变 配置数 = 0
定义 可变 监听表 = 0
定义 可变 监听数 = 0
定义 可变 读取次数 = 0
定义 可变 写入次数 = 0

函数 配置_初始化() {
    配置表 = []
    配置数 = 0
    监听表 = 堆_分配(最大监听器 * 8)
    监听数 = 0
    配置_设默认()
}

函数 配置_设默认() {
    配置_设整数("网关端口", 8080)
    配置_设整数("最大连接", 1000)
    配置_设整数("超时秒", 30)
    配置_设整数("最大令牌", 4096)
    配置_设整数("温度", 70)
    配置_设整数("日志级别", 2)
    配置_设整数("日志最大条目", 1000)
    配置_设布尔("调试模式", 假)
    配置_设布尔("安全模式", 真)
}

函数 配置_设值(键, 值哈希) {
    写入次数 = 写入次数 + 1
    定义 键哈希 = 哈希_字符串(键)
    定义 可变 序号 = 0
    当 (序号 < 配置数) {
        如果 (配置表[序号].键哈希 == 键哈希) {
            如果 (配置表[序号].只读) { 返回 错误_只读 }
            定义 旧值 = 配置表[序号].值哈希
            配置表[序号].值哈希 = 值哈希
            配置表[序号].修改次数 = 配置表[序号].修改次数 + 1
            配置_通知变更(键哈希, 旧值, 值哈希)
            返回 0
        }
        序号 = 序号 + 1
    }
    如果 (配置数 >= 最大配置项) { 返回 错误_无资源 }
    定义 项 = 配置项 {}
    项.键哈希 = 键哈希
    项.值哈希 = 值哈希
    项.整数值 = 0
    项.布尔值 = 假
    项.类型 = 类型_字符串
    项.只读 = 假
    项.修改次数 = 0
    追加(配置表, 项)
    配置数 = 配置数 + 1
    返回 0
}

函数 配置_设整数(键, 值) {
    写入次数 = 写入次数 + 1
    定义 键哈希 = 哈希_字符串(键)
    定义 可变 序号 = 0
    当 (序号 < 配置数) {
        如果 (配置表[序号].键哈希 == 键哈希) {
            如果 (配置表[序号].只读) { 返回 }
            配置表[序号].整数值 = 值
            配置表[序号].类型 = 类型_整数
            配置表[序号].修改次数 = 配置表[序号].修改次数 + 1
            返回
        }
        序号 = 序号 + 1
    }
    如果 (配置数 >= 最大配置项) { 返回 }
    定义 项 = 配置项 {}
    项.键哈希 = 键哈希
    项.整数值 = 值
    项.类型 = 类型_整数
    项.只读 = 假
    项.修改次数 = 0
    追加(配置表, 项)
    配置数 = 配置数 + 1
}

函数 配置_设布尔(键, 值) {
    写入次数 = 写入次数 + 1
    定义 键哈希 = 哈希_字符串(键)
    定义 可变 序号 = 0
    当 (序号 < 配置数) {
        如果 (配置表[序号].键哈希 == 键哈希) {
            如果 (配置表[序号].只读) { 返回 }
            配置表[序号].布尔值 = 值
            配置表[序号].类型 = 类型_布尔
            配置表[序号].修改次数 = 配置表[序号].修改次数 + 1
            返回
        }
        序号 = 序号 + 1
    }
    如果 (配置数 >= 最大配置项) { 返回 }
    定义 项 = 配置项 {}
    项.键哈希 = 键哈希
    项.布尔值 = 值
    项.类型 = 类型_布尔
    项.只读 = 假
    项.修改次数 = 0
    追加(配置表, 项)
    配置数 = 配置数 + 1
}

函数 配置_取值(键) {
    读取次数 = 读取次数 + 1
    定义 键哈希 = 哈希_字符串(键)
    定义 可变 序号 = 0
    当 (序号 < 配置数) {
        如果 (配置表[序号].键哈希 == 键哈希) { 返回 配置表[序号].值哈希 }
        序号 = 序号 + 1
    }
    返回 0
}

函数 配置_取整数(键, 默认值) {
    读取次数 = 读取次数 + 1
    定义 键哈希 = 哈希_字符串(键)
    定义 可变 序号 = 0
    当 (序号 < 配置数) {
        如果 (配置表[序号].键哈希 == 键哈希 && 配置表[序号].类型 == 类型_整数) {
            返回 配置表[序号].整数值
        }
        序号 = 序号 + 1
    }
    返回 默认值
}

函数 配置_取布尔(键, 默认值) {
    读取次数 = 读取次数 + 1
    定义 键哈希 = 哈希_字符串(键)
    定义 可变 序号 = 0
    当 (序号 < 配置数) {
        如果 (配置表[序号].键哈希 == 键哈希 && 配置表[序号].类型 == 类型_布尔) {
            返回 配置表[序号].布尔值
        }
        序号 = 序号 + 1
    }
    返回 默认值
}

函数 配置_设只读(键) {
    定义 键哈希 = 哈希_字符串(键)
    定义 可变 序号 = 0
    当 (序号 < 配置数) {
        如果 (配置表[序号].键哈希 == 键哈希) { 配置表[序号].只读 = 真; 返回 }
        序号 = 序号 + 1
    }
}

函数 配置_注册监听(回调) {
    如果 (监听数 >= 最大监听器) { 返回 }
    内存_写64(监听表 + 监听数 * 8, 回调)
    监听数 = 监听数 + 1
}

函数 配置_通知变更(键哈希, 旧值, 新值) {
    定义 可变 序号 = 0
    当 (序号 < 监听数) {
        定义 回调 = 内存_读64(监听表 + 序号 * 8)
        如果 (回调 != 0) { 回调(键哈希, 旧值, 新值) }
        序号 = 序号 + 1
    }
}

函数 配置_包含(键) {
    定义 键哈希 = 哈希_字符串(键)
    定义 可变 序号 = 0
    当 (序号 < 配置数) {
        如果 (配置表[序号].键哈希 == 键哈希) { 返回 真 }
        序号 = 序号 + 1
    }
    返回 假
}

函数 配置_完整统计() {
    返回 [配置数, 读取次数, 写入次数, 监听数]
}

定义 可变 AI_配置管理_事件频率 = 0
定义 可变 AI_配置管理_节流阈值 = 16

函数 AI_配置管理_节流判断(事件类型, 间隔毫秒) {
    AI_配置管理_事件频率 = AI_配置管理_事件频率 + 1
    如果 (事件类型 == "滚动" && 间隔毫秒 < AI_配置管理_节流阈值) { 返回 真 }
    如果 (事件类型 == "移动" && 间隔毫秒 < AI_配置管理_节流阈值) { 返回 真 }
    返回 假
}

函数 AI_配置管理_优先级排序(事件类型) {
    如果 (事件类型 == "点击") { 返回 100 }
    如果 (事件类型 == "输入") { 返回 90 }
    如果 (事件类型 == "滚动") { 返回 30 }
    返回 50
}

导入("../核心/FFI桥接.nova")
导入("../核心/设备管理.nova")
导入("../../../标准库/图算法/图算法.nova")
导入("../../../标准库/基础.nova")

//
// Nova GPU NVIDIA cuSPARSE 完整接入
// GPU稀疏矩阵运算 大规模图计算/推荐系统/科学计算核心 + CPU回退

// 常量与状态
定义 cuSPARSE_索引_32位整数 = 0
定义 cuSPARSE_索引_64位整数 = 1
定义 cuSPARSE_列优先 = 1
定义 cuSPARSE_行优先 = 2

定义 可变 _cuSPARSE库 = 0
定义 可变 _cuSPARSE句柄 = 0
定义 可变 _cusparse_可用 = 假
定义 可变 _cusparse_操作计数 = 0

// 库加载

函数 cuSPARSE_加载() {
    如果 (_cuSPARSE库 != 0) { 返回 _cuSPARSE库
}
 _cuSPARSE库 = GPU_加载CUDA候选([
 "cusparse64_12.dll",
 "libcusparse.so.12",
 "libcusparse.so"
 ])
 如果 (_cuSPARSE库 != 0) { _cusparse_可用 = 真 }
 返回 _cuSPARSE库
}

函数 cuSPARSE_初始化() {
    如果 (_cuSPARSE句柄 != 0) { 返回 _cuSPARSE句柄
}
 定义 lib = cuSPARSE_加载()
 如果 (lib == 0) { 返回 0 }
 _cuSPARSE句柄 = 外部调用(lib,  "cusparseCreate", 0, 0, 0, 0, 0)
 返回 _cuSPARSE句柄
}

函数 cuSPARSE_可用() { 返回 _cusparse_可用 }

// GPU CSR描述符

函数 cuSPARSE_创建CSR(行数, 列数, 非零数, 行指针, 列索引, 值) { _cusparse_操作计数 = _cusparse_操作计数 + 1
 cuSPARSE_初始化()
 定义 lib = cuSPARSE_加载()
 如果 (lib == 0) { 返回 空 }
 返回 外部调用N(lib, "cusparseCreateCsr", [0, 行数, 列数, 非零数,
 行指针, 列索引, 值, cuSPARSE_索引_32位整数, cuSPARSE_索引_32位整数,
 cuSPARSE_行优先, 0])
}

// GPU SpMV

函数 cuSPARSE_稀疏矩阵向量乘(A_desc, x, y, alpha, beta) { _cusparse_操作计数 = _cusparse_操作计数 + 1
 定义 handle = cuSPARSE_初始化()
 定义 lib = cuSPARSE_加载()
 如果 (lib == 0) { 返回 假 }
 返回 外部调用N(lib, "cusparseSpMV", [handle, 0, alpha, A_desc, x, beta, y, 0,]) == 0
}

// GPU SpMM

函数 cuSPARSE_稀疏矩阵乘(A_desc, B_desc, C_desc, alpha, beta) { _cusparse_操作计数 = _cusparse_操作计数 + 1
 定义 handle = cuSPARSE_初始化()
 定义 lib = cuSPARSE_加载()
 如果 (lib == 0) { 返回 假 }
 返回 外部调用N(lib, "cusparseSpMM", [handle, 0, alpha, A_desc, B_desc, beta, C_desc, 0,]) == 0
}

// 格式转换

函数 cuSPARSE_CSR转稠密(csr_desc, 稠密_desc, _缓冲) { 定义 handle = cuSPARSE_初始化()
 返回 外部调用4(cuSPARSE_加载(),  "cusparseSparseToDense",  handle,  csr_desc,  稠密_desc, 0, 0) == 0
}

函数 cuSPARSE_稠密转CSR(稠密_desc, csr_desc, _缓冲) { 定义 handle = cuSPARSE_初始化()
 返回 外部调用4(cuSPARSE_加载(),  "cusparseDenseToSparse_analysis",  handle,  稠密_desc,  csr_desc, 0, 0) == 0
}

函数 cuSPARSE_清理() { 如果 (_cuSPARSE句柄 != 0) {
 外部调用(cuSPARSE_加载(),  "cusparseDestroy",  _cuSPARSE句柄, 0, 0, 0, 0)
 _cuSPARSE句柄 = 0
 }
}

// CPU回退: CSR格式操作

函数 cuCSR_创建(行数, 列数) {
    返回 {"行数": 行数, "列数": 列数, "非零数": 0, "行指针": [0], "列索引": [], "值": []
}
}

函数 cuCSR_添加元素(csr, 行, 列, 值) { 定义 行指针 = csr["行指针"]
 当 (计数(行指针) <= 行 + 1) { 追加(行指针, 行指针[计数(行指针) - 1]) }
 追加(csr["列索引"], 列)
 追加(csr["值"], 值)
 定义 可变 i = 行 + 1
 当 (i < 计数(行指针)) { 行指针[i] = 行指针[i] + 1 i = i + 1 }
 csr["非零数"] = csr["非零数"] + 1
}

函数 cuCSR_取值(csr, 行, 列) { 定义 开始 = csr["行指针"][行]
 定义 结束 = csr["行指针"][行 + 1]
 定义 可变 i = 开始
 当 (i < 结束) { 如果 (csr["列索引"][i] == 列) { 返回 csr["值"][i] }
 i = i + 1
 }
 返回 0
}

// CPU SpMV回退

函数 cuCPU_稀疏矩阵向量乘(csr, x, y, alpha, beta) { 定义 行数 = csr["行数"]
 定义 可变 i = 0
 当 (i < 行数) { 定义 可变 和 = 0
 定义 可变 j = csr["行指针"][i]
 当 (j < csr["行指针"][i + 1]) {
 和 = 和 + csr["值"][j] * x[csr["列索引"][j]]
 j = j + 1
 }
 y[i] = alpha * 和 + beta * y[i]
 i = i + 1
 }
 返回 真
}

// CSC格式 (列压缩)

函数 CSC_从CSR(csr) { 定义 行数 = csr["行数"]
    定义 可变 列计数 = []
 定义 列数 = csr["列数"]
 定义 非零数 = csr["非零数"]
 定义 可变 列指针 = []
 定义 可变 行索引 = []
 定义 可变 值 = []
 定义 可变 i = 0
 当 (i < 列数) { 追加(列计数, 0) i = i + 1 }
 i = 0
 当 (i < 非零数) { 列计数[csr["列索引"][i]] = 列计数[csr["列索引"][i]] + 1 i = i + 1 }
 追加(列指针, 0)
 i = 0
 当 (i < 列数) { 追加(列指针, 列指针[i] + 列计数[i]) i = i + 1 }
 i = 0
 当 (i < 非零数) { 追加(行索引, 0) 追加(值, 0) i = i + 1 }
 定义 可变 位置 = []
 i = 0
 当 (i < 列数) { 追加(位置, 列指针[i]) i = i + 1 }
 i = 0
 当 (i < 行数) { 定义 可变 j = csr["行指针"][i]
 当 (j < csr["行指针"][i + 1]) { 定义 c = csr["列索引"][j]
 定义 p = 位置[c]
 行索引[p] = i
 值[p] = csr["值"][j]
 位置[c] = 位置[c] + 1
 j = j + 1
 }
 i = i + 1
 }
 返回 {"行数": 行数, "列数": 列数, "非零数": 非零数, "列指针": 列指针, "行索引": 行索引, "值": 值}
}

// 图算法: 邻接矩阵BFS

函数 稀疏_BFS(csr, 起点) { 定义 N = csr["行数"]
 定义 可变 距离 = []
 定义 可变 已访问 = []
 定义 可变 i = 0
 当 (i < N) { 追加(距离, -1) 追加(已访问, 假) i = i + 1 }
 距离[起点] = 0
 已访问[起点] = 真
 定义 可变 队列 = [起点]
 定义 可变 头 = 0
 当 (头 < 计数(队列)) { 定义 当前 = 队列[头]
 头 = 头 + 1
 定义 可变 j = csr["行指针"][当前]
 当 (j < csr["行指针"][当前 + 1]) { 定义 邻居 = csr["列索引"][j]
 如果 (!已访问[邻居]) {
 已访问[邻居] = 真
 距离[邻居] = 距离[当前] + 1
 追加(队列, 邻居)
 }
 j = j + 1
 }
 }
 返回 距离
}

// 图算法: PageRank

函数 稀疏_PageRank(csr, 阻尼, 迭代次数) { 定义 N = csr["行数"]
    定义 可变 iter = 0
 定义 可变 排名 = []
 定义 可变 出度 = []
 定义 可变 i = 0
 当 (i < N) {
 追加(排名, 1000000 / N)
 追加(出度, csr["行指针"][i + 1] - csr["行指针"][i])
 i = i + 1
 }
 当 (iter < 迭代次数) { 定义 可变 新排名 = []
 i = 0
 当 (i < N) { 如果 (N == 0) { 返回 [] }
 追加(新排名, (1000000 - 阻尼 * 1000000 / 1000000) / N) i = i + 1 }
 i = 0
 当 (i < N) { 如果 (出度[i] > 0) { 定义 贡献 = 阻尼 * 排名[i] / (出度[i] * 1000000)
 定义 可变 j = csr["行指针"][i]
 当 (j < csr["行指针"][i + 1]) {
 新排名[csr["列索引"][j]] = 新排名[csr["列索引"][j]] + 贡献
 j = j + 1
 }
 }
 i = i + 1
 }
 排名 = 新排名
 iter = iter + 1
 }
 返回 排名
}

// 图统计

函数 图_度分布(csr) { 定义 N = csr["行数"]
 定义 可变 最大度 = 0
 定义 可变 i = 0
 当 (i < N) { 定义 度 = csr["行指针"][i + 1] - csr["行指针"][i]
 如果 (度 > 最大度) { 最大度 = 度 }
 i = i + 1
 }
 定义 可变 分布 = []
 i = 0
 当 (i <= 最大度) { 追加(分布, 0) i = i + 1 }
 i = 0
 当 (i < N) { 定义 度 = csr["行指针"][i + 1] - csr["行指针"][i]
 分布[度] = 分布[度] + 1
 i = i + 1
 }
 返回 分布
}

函数 图_平均度(csr) {
    如果 (csr["行数"] == 0) { 返回 0
}
 返回 csr["非零数"] / csr["行数"]
}

函数 cuSP_图_密度(csr) {
    如果 (csr["行数"] <= 1) { 返回 0
}
 返回 csr["非零数"] * 100 / (csr["行数"] * (csr["行数"] - 1))
}

函数 cu稀疏_格式推荐(行数, 列数, 非零数, 操作类型) { 定义 稀疏度 = (行数 * 列数 - 非零数) * 100 / (行数 * 列数)
 如果 (稀疏度 < 50) { 返回 "密集矩阵" }
 如果 (操作类型 == "行切片") { 返回 "CSR(行压缩)" }
 如果 (操作类型 == "列切片") { 返回 "CSC(列压缩)" }
 如果 (操作类型 == "随机访问") { 返回 "COO(坐标)" }
 如果 (操作类型 == "对角") { 返回 "DIA(对角)" }
 如果 (非零数 / 行数 < 5) { 返回 "COO(极稀疏)" }
 返回 "CSR(默认)"
}

函数 cu稀疏_加速评估(_行数, 非零数) {
    如果 (非零数 < 1000) { 返回 [1, "规模太小,CPU即可"]
}
 如果 (非零数 < 50000) { 返回 [5, "中等加速"] }
 如果 (非零数 < 1000000) { 返回 [20, "显著加速"] }
 返回 [100, "极大加速"]
}

函数 图_分析推荐(csr) { 定义 可变 建议 = []
 定义 密度 = 图_密度(csr)
 定义 平均度 = 图_平均度(csr)
 如果 (密度 > 10) { 追加(建议, "密集图: 考虑邻接矩阵") }
 如果 (平均度 < 3) { 追加(建议, "稀疏图: 适合BFS/DFS") }
 如果 (csr["行数"] > 10000) { 追加(建议, "大规模图: 建议GPU加速PageRank") }
 如果 (计数(建议) == 0) { 追加(建议, "中等规模图: CPU处理可接受") }
 返回 建议
}

// CPU SpGEMM: C = A * B (稀疏×稀疏)

函数 cuCPU_稀疏通用矩阵乘(A, B) { 定义 M = A["行数"]
 定义 N = B["列数"]
 定义 可变 C行指针 = [0]
 定义 可变 C列索引 = []
 定义 可变 C值 = []
 定义 可变 非零 = 0
 定义 可变 i = 0
 当 (i < M) { 定义 可变 行缓存 = []
 定义 可变 k = 0
 当 (k < N) { 追加(行缓存, 0) k = k + 1 }
 定义 可变 ja = A["行指针"][i]
 当 (ja < A["行指针"][i + 1]) { 定义 a列 = A["列索引"][ja]
 定义 a值 = A["值"][ja]
 定义 可变 jb = B["行指针"][a列]
 当 (jb < B["行指针"][a列 + 1]) {
 行缓存[B["列索引"][jb]] = 行缓存[B["列索引"][jb]] + a值 * B["值"][jb]
 jb = jb + 1
 }
 ja = ja + 1
 }
 k = 0
 当 (k < N) { 如果 (行缓存[k] != 0) {
 追加(C列索引, k)
 追加(C值, 行缓存[k])
 非零 = 非零 + 1
 }
 k = k + 1
 }
 追加(C行指针, 非零)
 i = i + 1
 }
 返回 {"行数": M, "列数": N, "非零数": 非零, "行指针": C行指针, "列索引": C列索引, "值": C值}
}

// 三角求解 (前向/回代)

函数 稀疏_前向求解(L_csr, b) { 定义 N = L_csr["行数"]
 定义 可变 x = []
 定义 可变 i = 0
 当 (i < N) { 追加(x, 0) i = i + 1 }
 i = 0
 当 (i < N) { 定义 可变 和 = b[i]
 定义 可变 j = L_csr["行指针"][i]
 定义 可变 对角 = 1
 当 (j < L_csr["行指针"][i + 1]) { 定义 c = L_csr["列索引"][j]
 如果 (c < i) { 和 = 和 - L_csr["值"][j] * x[c] }
 如果 (c == i) { 对角 = L_csr["值"][j] }
 j = j + 1
 }
 如果 (对角 != 0) { x[i] = 和 / 对角 }
 i = i + 1
 }
 返回 x
}

函数 稀疏_回代求解(U_csr, b) { 定义 N = U_csr["行数"]
 定义 可变 x = []
 定义 可变 i = 0
 当 (i < N) { 追加(x, 0) i = i + 1 }
 i = N - 1
 当 (i >= 0) { 定义 可变 和 = b[i]
 定义 可变 j = U_csr["行指针"][i]
 定义 可变 对角 = 1
 当 (j < U_csr["行指针"][i + 1]) { 定义 c = U_csr["列索引"][j]
 如果 (c > i) { 和 = 和 - U_csr["值"][j] * x[c] }
 如果 (c == i) { 对角 = U_csr["值"][j] }
 j = j + 1
 }
 如果 (对角 != 0) { x[i] = 和 / 对角 }
 i = i - 1
 }
 返回 x
}

// Jacobi迭代求解 Ax=b

函数 稀疏_Jacobi(csr, b, 最大迭代, 容差) { 定义 N = csr["行数"]
    定义 可变 iter = 0
 定义 可变 x = []
 定义 可变 x新 = []
 定义 可变 i = 0
 当 (i < N) { 追加(x, 0) 追加(x新, 0) i = i + 1 }
 当 (iter < 最大迭代) {
 i = 0
 当 (i < N) { 定义 可变 和 = b[i]
 定义 可变 对角 = 1
 定义 可变 j = csr["行指针"][i]
 当 (j < csr["行指针"][i + 1]) { 定义 c = csr["列索引"][j]
 如果 (c == i) { 对角 = csr["值"][j] }
 否则 { 和 = 和 - csr["值"][j] * x[c] }
 j = j + 1
 }
 如果 (对角 != 0) { x新[i] = 和 / 对角 }
 i = i + 1
 }
 定义 可变 残差 = 0
 i = 0
 当 (i < N) { 定义 可变 差 = x新[i] - x[i]
 如果 (差 < 0) { 差 = 0 - 差 }
 如果 (差 > 残差) { 残差 = 差 }
 x[i] = x新[i]
 i = i + 1
 }
 如果 (残差 < 容差) { 返回 x }
 iter = iter + 1
 }
 返回 x
}

// 稀疏矩阵加法: C = alpha*A + beta*B

函数 稀疏_加法(A, B, alpha, beta) { 定义 M = A["行数"]
 定义 N = A["列数"]
 定义 可变 C行指针 = [0]
 定义 可变 C列索引 = []
 定义 可变 C值 = []
 定义 可变 非零 = 0
 定义 可变 i = 0
 当 (i < M) { 定义 可变 行缓存 = []
 定义 可变 k = 0
 当 (k < N) { 追加(行缓存, 0) k = k + 1 }
 定义 可变 j = A["行指针"][i]
 当 (j < A["行指针"][i + 1]) {
 行缓存[A["列索引"][j]] = 行缓存[A["列索引"][j]] + alpha * A["值"][j]
 j = j + 1
 }
 j = B["行指针"][i]
 当 (j < B["行指针"][i + 1]) {
 行缓存[B["列索引"][j]] = 行缓存[B["列索引"][j]] + beta * B["值"][j]
 j = j + 1
 }
 k = 0
 当 (k < N) { 如果 (行缓存[k] != 0) {
 追加(C列索引, k)
 追加(C值, 行缓存[k])
 非零 = 非零 + 1
 }
 k = k + 1
 }
 追加(C行指针, 非零)
 i = i + 1
 }
 返回 {"行数": M, "列数": N, "非零数": 非零, "行指针": C行指针, "列索引": C列索引, "值": C值}
}

// 对角提取

函数 稀疏_提取对角(csr) { 定义 N = csr["行数"]
 定义 可变 对角 = []
 定义 可变 i = 0
 当 (i < N) { 定义 可变 值 = 0
 定义 可变 j = csr["行指针"][i]
 当 (j < csr["行指针"][i + 1]) { 如果 (csr["列索引"][j] == i) { 值 = csr["值"][j] }
 j = j + 1
 }
 追加(对角, 值)
 i = i + 1
 }
 返回 对角
}

函数 迭代_收敛预测(csr) { 定义 对角 = 稀疏_提取对角(csr)
 定义 N = csr["行数"]
 定义 可变 对角占优 = 真
 定义 可变 i = 0
 当 (i < N) { 定义 可变 对角值 = 对角[i]
 如果 (对角值 < 0) { 对角值 = 0 - 对角值 }
 定义 可变 行和 = 0
 定义 可变 j = csr["行指针"][i]
 当 (j < csr["行指针"][i + 1]) { 如果 (csr["列索引"][j] != i) { 定义 可变 v = csr["值"][j]
 如果 (v < 0) { v = 0 - v }
 行和 = 行和 + v
 }
 j = j + 1
 }
 如果 (对角值 <= 行和) { 对角占优 = 假 }
 i = i + 1
 }
 如果 (对角占优) { 返回 "Jacobi/Gauss-Seidel保证收敛(对角占优)" }
 返回 "不保证收敛(非对角占优),建议Krylov方法"
}

函数 cu稀疏_求解器推荐(csr) { 定义 N = csr["行数"]
 定义 非零 = csr["非零数"]
 定义 平均每行 = 非零 / N
 定义 可变 建议 = []
 如果 (N < 100) { 追加(建议, "直接法(LU): 规模小,精确求解") }
 如果 (平均每行 < 10) { 追加(建议, "CG/GMRES: 极稀疏适合迭代法") }
 如果 (N > 10000) { 追加(建议, "GPU加速: 大规模稀疏建议GPU") }
 定义 收敛 = 迭代_收敛预测(csr)
 追加(建议, 收敛)
 返回 建议
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("../感知/内核直连层.nova")
导入("./创建甲.nova")

定义 最大补丁 = 32
定义 最大钩子 = 16
定义 最大检查点 = 8
定义 看门狗超时 = 30000000

结构 补丁记录 {
    标识,
    应用时刻,
    状态,
    数据指针,
    数据大小,
    原始指针,
    原始大小,
}

结构 检查点 {
    标识,
    创建时刻,
    内存快照,
    快照大小,
    有效,
}

定义 可变 补丁表 = []
定义 可变 补丁数 = 0
定义 可变 检查点表 = []
定义 可变 检查点数 = 0
定义 可变 恐慌钩子表 = 0
定义 可变 恐慌钩子数 = 0
定义 可变 异常钩子表 = 0
定义 可变 异常钩子数 = 0
定义 可变 回滚总数 = 0
定义 可变 回滚成功 = 0
定义 可变 回滚失败 = 0
定义 可变 看门狗超时数 = 0
定义 可变 心跳计数 = 0
定义 可变 最近心跳 = 0

函数 回滚_初始化() {
    补丁表 = []
    补丁数 = 0
    检查点表 = []
    检查点数 = 0
    恐慌钩子表 = 堆_分配(最大钩子 * 8)
    恐慌钩子数 = 0
    异常钩子表 = 堆_分配(最大钩子 * 8)
    异常钩子数 = 0
    最近心跳 = 平台_获取高精度时间()
}

函数 回滚_创建检查点() {
    如果 (检查点数 >= 最大检查点) {
        检查点表[0] = 检查点表[检查点数 - 1]
        检查点数 = 检查点数 - 1
    }
    定义 点 = 检查点 {}
    点.标识 = 检查点数 + 1
    点.创建时刻 = 平台_获取高精度时间()
    点.内存快照 = 0
    点.快照大小 = 0
    点.有效 = 真
    追加(检查点表, 点)
    检查点数 = 检查点数 + 1
    返回 点.标识
}

函数 回滚_注册补丁(数据, 大小, 原始, 原始大小) {
    如果 (补丁数 >= 最大补丁) { 返回 -1 }
    定义 记录 = 补丁记录 {}
    记录.标识 = 补丁数 + 1
    记录.应用时刻 = 平台_获取高精度时间()
    记录.状态 = 1
    记录.数据指针 = 数据
    记录.数据大小 = 大小
    记录.原始指针 = 堆_分配(原始大小)
    内存_复制(记录.原始指针, 原始, 原始大小)
    记录.原始大小 = 原始大小
    追加(补丁表, 记录)
    补丁数 = 补丁数 + 1
    返回 记录.标识
}

函数 回滚_执行补丁回滚(补丁标识) {
    回滚总数 = 回滚总数 + 1
    定义 可变 序号 = 补丁数 - 1
    当 (序号 >= 0) {
        如果 (补丁表[序号].标识 == 补丁标识 && 补丁表[序号].状态 == 1) {
            内存_复制(补丁表[序号].数据指针, 补丁表[序号].原始指针, 补丁表[序号].原始大小)
            补丁表[序号].状态 = 2
            回滚成功 = 回滚成功 + 1
            返回 0
        }
        序号 = 序号 - 1
    }
    回滚失败 = 回滚失败 + 1
    返回 错误_不存在
}

函数 回滚_执行检查点回滚(检查点标识) {
    回滚总数 = 回滚总数 + 1
    定义 可变 序号 = 检查点数 - 1
    当 (序号 >= 0) {
        如果 (检查点表[序号].标识 == 检查点标识 && 检查点表[序号].有效) {
            回滚成功 = 回滚成功 + 1
            返回 0
        }
        序号 = 序号 - 1
    }
    回滚失败 = 回滚失败 + 1
    返回 错误_不存在
}

函数 回滚_注册恐慌钩子(回调) {
    如果 (恐慌钩子数 >= 最大钩子) { 返回 }
    内存_写64(恐慌钩子表 + 恐慌钩子数 * 8, 回调)
    恐慌钩子数 = 恐慌钩子数 + 1
}

函数 回滚_注册异常钩子(回调) {
    如果 (异常钩子数 >= 最大钩子) { 返回 }
    内存_写64(异常钩子表 + 异常钩子数 * 8, 回调)
    异常钩子数 = 异常钩子数 + 1
}

函数 回滚_触发恐慌() {
    定义 可变 序号 = 0
    当 (序号 < 恐慌钩子数) {
        定义 回调 = 内存_读64(恐慌钩子表 + 序号 * 8)
        如果 (回调 != 0) { 回调() }
        序号 = 序号 + 1
    }
    如果 (补丁数 > 0) {
        回滚_执行补丁回滚(补丁表[补丁数 - 1].标识)
    }
}

函数 回滚_心跳() {
    心跳计数 = 心跳计数 + 1
    最近心跳 = 平台_获取高精度时间()
}

函数 回滚_检查看门狗() {
    定义 现在 = 平台_获取高精度时间()
    如果 (现在 - 最近心跳 > 看门狗超时) {
        看门狗超时数 = 看门狗超时数 + 1
        回滚_触发恐慌()
    }
}

函数 回滚_查找补丁(标识) {
    定义 可变 序号 = 0
    当 (序号 < 补丁数) {
        如果 (补丁表[序号].标识 == 标识) { 返回 序号 }
        序号 = 序号 + 1
    }
    返回 -1
}

函数 回滚_完整统计() {
    返回 [补丁数, 检查点数, 回滚总数, 回滚成功, 回滚失败, 看门狗超时数, 心跳计数]
}

定义 可变 AI_热更新后注_事件频率 = 0
定义 可变 AI_热更新后注_节流阈值 = 16

函数 AI_热更新后注_节流判断(事件类型, 间隔毫秒) {
    AI_热更新后注_事件频率 = AI_热更新后注_事件频率 + 1
    如果 (事件类型 == "滚动" && 间隔毫秒 < AI_热更新后注_节流阈值) { 返回 真 }
    如果 (事件类型 == "移动" && 间隔毫秒 < AI_热更新后注_节流阈值) { 返回 真 }
    返回 假
}

函数 AI_热更新后注_优先级排序(事件类型) {
    如果 (事件类型 == "点击") { 返回 100 }
    如果 (事件类型 == "输入") { 返回 90 }
    如果 (事件类型 == "滚动") { 返回 30 }
    返回 50
}

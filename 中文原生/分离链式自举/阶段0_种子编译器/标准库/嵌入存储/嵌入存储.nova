导入("../数学/损失函数.nova")
导入("../数学/线性代数.nova")
导入("../算法/数学扩展.nova")
导入("../../运行时/智能推理/注意力机制.nova")

定义 可变 嵌入_向量 = []
定义 可变 嵌入_ID = []
定义 可变 嵌入_维度 = 0

函数 嵌入_初始化(维度) { 嵌入_向量 = []
嵌入_ID = []
嵌入_维度 = 维度 }

函数 嵌入_追加(id, 向量) {
    追加(嵌入_ID, id)
    追加(嵌入_向量, 向量)
}

函数 嵌入_数量() { 返回 计数(嵌入_ID) }

函数 嵌入_获取(id) {
    定义 可变 i = 0
    当 (i < 计数(嵌入_ID)) {
        如果 (嵌入_ID[i] == id) { 返回 嵌入_向量[i] }
        i = i + 1
    }
    返回 []
}

// 余弦相似度
函数 嵌入存储_余弦相似度(a, b) {
    定义 点积 = 向量_点积(a,  b, 0)
    定义 na = 向量_范数(a, 0)
    定义 nb = 向量_范数(b, 0)
    如果 (na == 0) { 返回 0 }
    如果 (nb == 0) { 返回 0 }
    返回 点积 * 1000 / (na * nb)
}

// 欧氏距离
函数 欧氏距离(a, b) {
    定义 可变 和 = 0
    定义 可变 i = 0
    定义 可变 上限 = 计数(a)
    如果 (计数(b) < 上限) { 上限 = 计数(b) }
    当 (i < 上限) {
        定义 差 = a[i] - b[i]
        和 = 和 + 差 * 差
        i = i + 1
    }
    返回 整数sqrt(和)
}

// KNN搜索
函数 KNN搜索(查询, K) {
    定义 可变 距离列表 = []
    定义 可变 索引列表 = []
    定义 可变 i = 0
    当 (i < 计数(嵌入_向量)) {
        定义 相似度 = 余弦相似度(查询, 嵌入_向量[i])
        追加(距离列表, 相似度)
        追加(索引列表, i)
        i = i + 1
    }
    // 按相似度降序排序
    i = 0
    当 (i < 计数(索引列表) - 1) {
        定义 可变 j = i + 1
        当 (j < 计数(索引列表)) {
            如果 (距离列表[索引列表[j]] > 距离列表[索引列表[i]]) {
                定义 临时 = 索引列表[i]
                索引列表[i] = 索引列表[j]
                索引列表[j] = 临时
            }
            j = j + 1
        }
        i = i + 1
    }
    定义 可变 结果 = []
    i = 0
    当 (i < K 且 i < 计数(索引列表)) {
        追加(结果, 嵌入_ID[索引列表[i]])
        i = i + 1
    }
    返回 结果
}

// 向量加权平均
函数 向量_加权平均(向量列表, 权重列表) {
    定义 可变 总权 = 0
    如果 (计数(向量列表) == 0) { 返回 [] }
    定义 维度 = 计数(向量列表[0])
    定义 可变 结果 = []
    定义 可变 d = 0
    当 (d < 维度) { 追加(结果, 0)
    d = d + 1 }
    定义 可变 i = 0
    当 (i < 计数(向量列表)) {
        d = 0
        当 (d < 维度) {
            结果[d] = 结果[d] + 向量列表[i][d] * 权重列表[i] / 100
            d = d + 1
        }
        总权 = 总权 + 权重列表[i]
        i = i + 1
    }
    如果 (总权 > 0) {
        d = 0
        当 (d < 维度) { 结果[d] = 结果[d] * 100 / 总权
        d = d + 1 }
    }
    返回 结果
}

// 曼哈顿距离
函数 曼哈顿距离(a, b) {
    定义 可变 和 = 0
    定义 可变 i = 0
    定义 可变 上限 = 计数(a)
    如果 (计数(b) < 上限) { 上限 = 计数(b) }
    当 (i < 上限) {
        和 = 和 + 绝对值(a[i] - b[i])
        i = i + 1
    }
    返回 和
}

// 质心计算
函数 嵌入_质心() {
    如果 (计数(嵌入_向量) == 0) { 返回 [] }
    定义 维度 = 嵌入_维度
    定义 可变 总和 = []
    定义 可变 d = 0
    当 (d < 维度) { 追加(总和, 0)
    d = d + 1 }
    定义 可变 i = 0
    当 (i < 计数(嵌入_向量)) {
        d = 0
        当 (d < 维度) { 总和[d] = 总和[d] + 嵌入_向量[i][d]
        d = d + 1 }
        i = i + 1
    }
    定义 n = 计数(嵌入_向量)
    d = 0
    当 (d < 维度) { 总和[d] = 总和[d] / n
    d = d + 1 }
    返回 总和
}

// 向量删除
函数 嵌入_删除(id) {
    定义 可变 新ID = []
    定义 可变 新向量 = []
    定义 可变 i = 0
    当 (i < 计数(嵌入_ID)) {
        如果 (嵌入_ID[i] != id) {
            追加(新ID, 嵌入_ID[i])
            追加(新向量, 嵌入_向量[i])
        }
        i = i + 1
    }
    嵌入_ID = 新ID
    嵌入_向量 = 新向量
}

// 嵌入是否存在
函数 嵌入_存在(id) {
    定义 可变 i = 0
    当 (i < 计数(嵌入_ID)) {
        如果 (嵌入_ID[i] == id) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// 批量检索TopK

函数 嵌入_TopK(查询向量, k) {
    定义 n = 计数(嵌入_ID)
    定义 可变 分数 = []
    定义 可变 i = 0
    当 (i < n) {
        定义 向量 = 嵌入_向量[i]
        // 余弦相似度的简化: 点积
        定义 可变 点积 = 0
        定义 可变 j = 0
        当 (j < 计数(查询向量) 且 j < 计数(向量)) {
            点积 = 点积 + 查询向量[j] * 向量[j]
            j = j + 1
        }
        追加(分数, [点积, 嵌入_ID[i]])
        i = i + 1
    }
    // 按分数降序排序(冒泡)
    i = 0
    当 (i < 计数(分数) - 1) {
        定义 可变 j = 0
        当 (j < 计数(分数) - 1 - i) {
            如果 (分数[j][0] < 分数[j + 1][0]) {
            }
            j = j + 1
        }
        i = i + 1
    }
    定义 可变 结果 = []
    i = 0
    当 (i < k 且 i < 计数(分数)) { 追加(结果, 分数[i])  i = i + 1 }
    返回 结果
}

// 向量归一化

函数 嵌入存储_嵌入_归一化(向量) {
    定义 可变 范数 = 0
    定义 可变 i = 0
    当 (i < 计数(向量)) { 范数 = 范数 + 向量[i] * 向量[i]  i = i + 1 }
    如果 (范数 == 0) { 返回 向量 }
    // 近似开方
    定义 可变 x = 范数
    定义 可变 迭代 = 0
    当 (迭代 < 10) { x = (x + 范数 / x) / 2  迭代 = 迭代 + 1 }
    定义 可变 结果 = []
    i = 0
    当 (i < 计数(向量)) { 追加(结果, 向量[i] * 100 / x)  i = i + 1 }
    返回 结果
}

// 批量添加

函数 嵌入_批量添加(id列表, 向量列表) {
    定义 可变 i = 0
    当 (i < 计数(id列表)) {
        追加(嵌入_ID, id列表[i])
        追加(嵌入_向量, 向量列表[i])
        i = i + 1
    }
}

// 向量维度统计

函数 嵌入_维度() {
    如果 (计数(嵌入_向量) == 0) { 返回 0 }
    返回 计数(嵌入_向量[0])
}

函数 嵌入_总数() { 返回 计数(嵌入_ID) }

// 向量均值

函数 嵌入_均值向量() {
    定义 n = 计数(嵌入_向量)
    如果 (n == 0) { 返回 [] }
    定义 维 = 计数(嵌入_向量[0])
    定义 可变 均值 = []
    定义 可变 j = 0
    当 (j < 维) { 追加(均值, 0)  j = j + 1 }
    定义 可变 i = 0
    当 (i < n) {
        j = 0
        当 (j < 维) { 均值[j] = 均值[j] + 嵌入_向量[i][j]  j = j + 1 }
        i = i + 1
    }
    j = 0
    当 (j < 维) { 均值[j] = 均值[j] / n  j = j + 1 }
    返回 均值
}

定义 可变 _嵌入_查询数 = 0
定义 可变 _嵌入_插入数 = 0

函数 嵌入_记录查询() { _嵌入_查询数 = _嵌入_查询数 + 1 }
函数 嵌入_记录插入() { _嵌入_插入数 = _嵌入_插入数 + 1 }

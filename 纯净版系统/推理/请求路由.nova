导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/哈希整数.nova")
导入("../中枢/创建甲.nova")

定义 最大路由 = 64
定义 最大中间件 = 16

结构 路由项 {
    模式哈希,
    处理回调,
    优先级,
    调用次数,
    总耗时,
    最近调用,
}

定义 可变 路由表 = []
定义 可变 路由数 = 0
定义 可变 中间件表 = 0
定义 可变 中间件数 = 0
定义 可变 分发总数 = 0
定义 可变 匹配成功 = 0
定义 可变 匹配失败 = 0
定义 可变 默认处理 = 0

函数 路由_初始化() {
    路由表 = []
    路由数 = 0
    中间件表 = 堆_分配(最大中间件 * 8)
    中间件数 = 0
    默认处理 = 0
}

函数 路由_注册(模式, 回调, 优先级) {
    如果 (路由数 >= 最大路由) { 返回 -1 }
    定义 路由 = 路由项 {}
    路由.模式哈希 = 哈希_字符串(模式)
    路由.处理回调 = 回调
    路由.优先级 = 优先级
    路由.调用次数 = 0
    路由.总耗时 = 0
    路由.最近调用 = 0
    追加(路由表, 路由)
    定义 索引 = 路由数
    路由数 = 路由数 + 1
    返回 索引
}

函数 路由_注册中间件(回调) {
    如果 (中间件数 >= 最大中间件) { 返回 }
    内存_写64(中间件表 + 中间件数 * 8, 回调)
    中间件数 = 中间件数 + 1
}

函数 路由_设默认(回调) {
    默认处理 = 回调
}

函数 路由_分发(意图, 会话哈希, 消息哈希) {
    分发总数 = 分发总数 + 1
    定义 可变 序号 = 0
    当 (序号 < 中间件数) {
        定义 中间件 = 内存_读64(中间件表 + 序号 * 8)
        如果 (中间件 != 0) {
            定义 结果 = 中间件(意图, 会话哈希, 消息哈希)
            如果 (结果 != 0) { 返回 结果 }
        }
        序号 = 序号 + 1
    }
    定义 意图哈希 = 哈希_字符串(意图)
    定义 可变 最佳 = -1
    定义 可变 最高优先 = -1
    序号 = 0
    当 (序号 < 路由数) {
        如果 (路由表[序号].模式哈希 == 意图哈希 && 路由表[序号].优先级 > 最高优先) {
            最高优先 = 路由表[序号].优先级
            最佳 = 序号
        }
        序号 = 序号 + 1
    }
    如果 (最佳 >= 0) {
        匹配成功 = 匹配成功 + 1
        定义 开始 = 平台_获取高精度时间()
        定义 结果 = 路由表[最佳].处理回调(会话哈希, 消息哈希)
        定义 耗时 = 平台_获取高精度时间() - 开始
        路由表[最佳].调用次数 = 路由表[最佳].调用次数 + 1
        路由表[最佳].总耗时 = 路由表[最佳].总耗时 + 耗时
        路由表[最佳].最近调用 = 平台_获取高精度时间()
        返回 结果
    }
    匹配失败 = 匹配失败 + 1
    如果 (默认处理 != 0) { 返回 默认处理(会话哈希, 消息哈希) }
    返回 0
}

函数 路由_删除(模式) {
    定义 目标 = 哈希_字符串(模式)
    定义 可变 序号 = 0
    当 (序号 < 路由数) {
        如果 (路由表[序号].模式哈希 == 目标) {
            路由表[序号] = 路由表[路由数 - 1]
            路由数 = 路由数 - 1
            返回 真
        }
        序号 = 序号 + 1
    }
    返回 假
}

函数 路由_获取统计(索引) {
    如果 (索引 >= 路由数) { 返回 [0, 0] }
    返回 [路由表[索引].调用次数, 路由表[索引].总耗时]
}

函数 路由_最热() {
    如果 (路由数 == 0) { 返回 -1 }
    定义 可变 最多 = 0
    定义 可变 最多索引 = 0
    定义 可变 序号 = 0
    当 (序号 < 路由数) {
        如果 (路由表[序号].调用次数 > 最多) {
            最多 = 路由表[序号].调用次数
            最多索引 = 序号
        }
        序号 = 序号 + 1
    }
    返回 最多索引
}

函数 路由_匹配率() {
    如果 (分发总数 == 0) { 返回 0 }
    返回 匹配成功 * 100 / 分发总数
}

函数 路由_完整统计() {
    返回 [路由数, 中间件数, 分发总数, 匹配成功, 匹配失败, 路由_匹配率()]
}

//   1. 事件fd: 轻量级事件通知文件描述符
//   2. 内部是一个64位计数器
//   3. write: 向计数器加值(原子)
//   4. read: 读取并清零计数器(EFD_SEMAPHORE模式下减1)
//   5. poll: 计数器>0时可读
//   6. 用于: 用户态↔内核态事件通知/Nova事件轮询唤醒/KVM中断注入

定义 EFD_SEMAPHORE = 0x01    // 信号量模式(read减1而非清零)
定义 EFD_NONBLOCK  = 0x0800  // 非阻塞
定义 EFD_CLOEXEC   = 0x80000 // exec时关闭

结构 事件fd {
    计数器,
    标志,
    等待队列,
    fd,
}

定义 可变 事件fd_列表 = []

// 创建 

函数 sys_事件fd(初始值, 标志) {
    定义 efd = 事件fd {}
    efd.计数器 = 初始值
    efd.标志 = 标志
    efd.等待队列 = 等待队列_创建()
    efd.fd = 分配文件描述符()
    追加(事件fd_列表, efd)
    返回 efd.fd
}

// read: 读取计数器

函数 事件fd_read(efd) {
    如果 (efd == 空) { 返回 错误_无效参数 }

    // 计数器为0: 阻塞或返回EAGAIN
    如果 (efd.计数器 == 0) {
        如果 ((efd.标志 & EFD_NONBLOCK) != 0) { 返回 错误_重试 }
        // 阻塞等待
        当 (efd.计数器 == 0) { 调度() }
    }

    定义 值 = 0
    如果 ((efd.标志 & EFD_SEMAPHORE) != 0) {
        // 信号量模式: 减1
        值 = 1
        efd.计数器 = efd.计数器 - 1
    } 否则 {
        // 普通模式: 读取并清零
        值 = efd.计数器
        efd.计数器 = 0
    }

    // 唤醒写等待者(如果有)
    等待队列_唤醒全部(efd.等待队列)
    返回 值
}

// write: 向计数器加值

函数 事件fd_write(efd, 值) {
    如果 (efd == 空 || 值 == 0) { 返回 错误_无效参数 }
    // 防溢出: 如果加后会溢出(>UINT64_MAX-1), 阻塞
    efd.计数器 = efd.计数器 + 值
    // 唤醒读等待者
    等待队列_唤醒一个(efd.等待队列)
    返回 成功
}

// poll: 检查是否可读

函数 事件fd_poll(efd) {
    如果 (efd == 空) { 返回 0 }
    定义 可变 事件 = 0
    如果 (efd.计数器 > 0) { 事件 = 事件 | 1 }   // POLLIN
    事件 = 事件 | 4                                // POLLOUT (总是可写)
    返回 事件
}

函数 事件fd_查找(fd) {
    定义 可变 i = 0
    当 (i < 计数(事件fd_列表)) {
        如果 (事件fd_列表[i].fd == fd) { 返回 事件fd_列表[i] }
        i = i + 1
    }
    返回 空
}

外部 当前进程             // 定义在 核心/进程/PID分配器.nova

函数 分配文件描述符() {
    // 从当前进程fd表分配最小空闲fd
    如果 (当前进程 == 空 || 当前进程.文件表 == 空) { 返回 -1 }
    定义 可变 fd = 0
    当 (fd < 计数(当前进程.文件表)) {
        如果 (当前进程.文件表[fd] == 空) { 返回 fd }
        fd = fd + 1
    }
    // 扩展fd表
    追加(当前进程.文件表, 空)
    返回 fd
}
// 错误_重试 定义在 核心/公共/错误码.nova

// 关闭事件fd

函数 事件fd_关闭(fd) {
    定义 可变 i = 0
    当 (i < 计数(事件fd_列表)) {
        如果 (事件fd_列表[i].fd == fd) {
            // 唤醒所有等待者
            等待队列_唤醒全部(事件fd_列表[i].等待队列)
            链表_删除(事件fd_列表, i)
            返回 成功
        }
        i = i + 1
    }
    返回 错误_无效参数
}

// 文件操作表 (VFS集成)

函数 事件fd_文件操作_read(文件, 缓冲, 大小) {
    定义 efd = 事件fd_查找(文件.fd)
    如果 (efd == 空) { 返回 错误_无效参数 }
    如果 (大小 < 8) { 返回 错误_无效参数 }
    定义 值 = 事件fd_read(efd)
    如果 (值 < 0) { 返回 值 }
    缓冲写64(缓冲, 0, 值)
    返回 8
}

函数 事件fd_文件操作_write(文件, 缓冲, 大小) {
    定义 efd = 事件fd_查找(文件.fd)
    如果 (efd == 空) { 返回 错误_无效参数 }
    如果 (大小 < 8) { 返回 错误_无效参数 }
    定义 值 = 缓冲读64(缓冲, 0)
    如果 (值 == 0) { 返回 错误_无效参数 }
    返回 事件fd_write(efd, 值)
}

函数 事件fd_文件操作_poll(文件) {
    定义 efd = 事件fd_查找(文件.fd)
    返回 事件fd_poll(efd)
}

函数 事件fd_文件操作_release(文件) {
    返回 事件fd_关闭(文件.fd)
}

// 事件fd信号通知 

函数 事件fd_signal(efd, 值) {
    // 内核态向事件fd发送信号(不阻塞)
    如果 (efd == 空 || 值 == 0) { 返回 错误_无效参数 }
    // 防溢出检查
    如果 (efd.计数器 > 0xFFFFFFFFFFFFFFFE - 值) {
        返回 错误_重试  // EAGAIN: 会溢出
    }
    efd.计数器 = efd.计数器 + 值
    等待队列_唤醒一个(efd.等待队列)
    返回 成功
}

// 带超时读取

函数 事件fd_read_超时(efd, 超时ms) {
    如果 (efd == 空) { 返回 错误_无效参数 }
    如果 (efd.计数器 > 0) {
        定义 值 = efd.计数器
        如果 ((efd.标志 & EFD_SEMAPHORE) != 0) {
            efd.计数器 = efd.计数器 - 1
            返回 1
        }
        efd.计数器 = 0
        返回 值
    }
    如果 ((efd.标志 & EFD_NONBLOCK) != 0) { 返回 错误_重试 }

    定义 截止 = 读取毫秒() + 超时ms
    当 (efd.计数器 == 0) {
        如果 (读取毫秒() >= 截止) { 返回 错误_重试 }
        调度()
    }
    返回 事件fd_read(efd)
}

// 统计

函数 事件fd_统计() {
    返回 [计数(事件fd_列表)]
}

// 事件fd标志名称 + 完整统计

函数 事件fd_标志名(标志) {
    定义 可变 名 = ""
    如果 ((标志 & EFD_SEMAPHORE) != 0) { 名 = 名 + "SEM " }
    如果 ((标志 & EFD_NONBLOCK) != 0) { 名 = 名 + "NONBLOCK " }
    如果 ((标志 & EFD_CLOEXEC) != 0) { 名 = 名 + "CLOEXEC " }
    如果 (名 == "") { 名 = "0" }
    返回 名
}

函数 事件fd_完整统计() {
    返回 [计数(事件fd_列表)]
}

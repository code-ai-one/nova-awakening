函数 发射_vunpcklps(d, s1, s2) { 发射_vex2(1,  s1,  1, 0) 发射(0x14) 发射(0xC0+(d&7)*8+(s2&7)) }
函数 发射_vunpckhps(d, s1, s2) { 发射_vex2(1,  s1,  1, 0) 发射(0x15) 发射(0xC0+(d&7)*8+(s2&7)) }
函数 发射_vunpcklpd(d, s1, s2) { 发射_vex2(1, s1, 1, 1) 发射(0x14) 发射(0xC0+(d&7)*8+(s2&7)) }
函数 发射_vunpckhpd(d, s1, s2) { 发射_vex2(1, s1, 1, 1) 发射(0x15) 发射(0xC0+(d&7)*8+(s2&7)) }

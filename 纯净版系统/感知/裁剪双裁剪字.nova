//       clipboard.cc (~400行) + data_transfer.cc (~800行)
//       drag_controller.cc (~1500行)
// Clipboard 接口 (异步):
//   navigator.clipboard.readText() → 承诺<string>
//   navigator.clipboard.writeText(text) → 承诺<void>
//   navigator.clipboard.read() → 承诺<ClipboardItem[]>
//   navigator.clipboard.write(items) → 承诺<void>
// Drag and Drop:
//   draggable="true"
//   事件: dragstart/drag/dr智能体er/dragleave/dragover/drop/dragend
//   DataTransfer: 事件.dataTransfer.setData/getData/clearData
//   DataTransferItem / DataTransferItemList
//   dropEffect / effectAllowed

导入("./文档事件.nova")
导入("./内核直连层.nova")
导入("./事件系统核心.nova")
导入("../中枢/内核打印.nova")
导入("../推理/值乘.nova")
导入("../中枢/字符串替换.nova")
导入("./权限接口权限.nova")
导入("../中枢/整数转字符串.nova")

// §1 Clipboard 接口

结构 ClipboardItem {
    类型列表,    // u64 MIME类型字符串数组
    数据列表,    // u64 Blob*数组
    数量,
}

函数 Clipboard_readText() {
    // 从系统剪贴板读取纯文本
    // 需要权限: clipboard-read
    定义 文本 = 平台_剪贴板_读取文本()
    返回 文本    // 实际返回承诺
}

函数 Clipboard_writeText(文本) {
    如果 (文本 == 0) { 返回 }
    平台_剪贴板_写入文本(文本)
}

函数 Clipboard_read() {
    // 读取所有格式
    定义 结果 = 堆_分配_数组(8 * 8)
    定义 可变 数量 = 0

    // 读取文本
    定义 文本 = 平台_剪贴板_读取文本()
    如果 (文本 != 0) {
        定义 item = 堆_分配(ClipboardItem)
        item.数量 = 1
        item.类型列表 = 堆_分配_数组(8)
        内存_写64(item.类型列表, "text/plain")
        item.数据列表 = 堆_分配_数组(8)
        内存_写64(item.数据列表, 文本)
        内存_写64(结果 + 数量 * 8, item)
        数量 = 数量 + 1
    }

    // 读取图片(HTML)
    定义 html = 平台_剪贴板_读取HTML()
    如果 (html != 0) {
        定义 item = 堆_分配(ClipboardItem)
        item.数量 = 1
        item.类型列表 = 堆_分配_数组(8)
        内存_写64(item.类型列表, "text/html")
        item.数据列表 = 堆_分配_数组(8)
        内存_写64(item.数据列表, html)
        内存_写64(结果 + 数量 * 8, item)
        数量 = 数量 + 1
    }

    返回 [结果, 数量]
}

函数 Clipboard_write(items, 数量) {
    定义 可变 i = 0
    当 (i < 数量) {
        定义 item = 内存_读64(items + i * 8)
        如果 (item != 0) {
            定义 可变 j = 0
            当 (j < item.数量) {
                定义 类型 = 内存_读64(item.类型列表 + j * 8)
                定义 数据 = 内存_读64(item.数据列表 + j * 8)
                如果 (字符串_相等(类型, "text/plain")) {
                    平台_剪贴板_写入文本(数据)
                } 否则 如果 (字符串_相等(类型, "text/html")) {
                    平台_剪贴板_写入HTML(数据)
                } 否则 如果 (字符串_相等(类型, "image/png")) {
                    平台_剪贴板_写入图片(数据, "png")
                } 否则 如果 (字符串_相等(类型, "text/uri-list")) {
                    平台_剪贴板_写入文本(数据)
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    全局CDTF统计.剪贴板写入次数 = 全局CDTF统计.剪贴板写入次数 + 1
}

// §2 CDTF理论: 剪贴板数据传输框架 (Clipboard Data Transfer Framework)
//   核心创新: 统一的数据传输抽象层，剪贴板/拖放/外部拖入共用相同的
//   DataTransfer协议，AI智能识别数据类型并自动转换格式

定义 拖放效果_无   = 0
定义 拖放效果_复制 = 1
定义 拖放效果_移动 = 2
定义 拖放效果_链接 = 3

定义 拖放事件_dragstart = 1
定义 拖放事件_drag      = 2
定义 拖放事件_dragenter = 3
定义 拖放事件_dragleave = 4
定义 拖放事件_dragover  = 5
定义 拖放事件_drop      = 6
定义 拖放事件_dragend   = 7

// §3 DataTransfer 实现

定义 DT_最大条目数 = 32

结构 DataTransferItem {
    类型,        // u8  0=字符串 1=文件
    MIME类型,    // u64 字符串指针
    数据,        // u64 Blob*/字符串指针
    数据长度,
    文件名,      // u64 字符串指针 (类型=文件时有效)
    最后修改时间  // u64 时间戳
}

结构 DataTransfer {
    条目列表,      // [DT_最大条目数]DataTransferItem
    条目数,
    dropEffect,    // u8  拖放效果_无/复制/移动/链接
    effectAllowed,
    拖放图像,      // u64 自定义拖放反馈图像
    拖放图像_x,    // i32 图像偏移
    拖放图像_y,
    只读           // bool 拖放过程中目标侧只可读取类型
}

函数 DataTransfer_创建() {
    定义 dt = 堆_分配(DataTransfer)
    如果 (dt == 0) { 返回 空 }
    dt.条目数 = 0
    dt.dropEffect = 拖放效果_无
    dt.effectAllowed = 拖放效果_复制 | 拖放效果_移动 | 拖放效果_链接
    dt.拖放图像 = 0
    dt.只读 = 假
    返回 dt
}

函数 DataTransfer_setData(dt, MIME, 数据) {
    如果 (dt == 空 || dt.只读) { 返回 }
    // 检查是否已存在相同MIME类型，存在则替换
    定义 可变 i = 0
    当 (i < dt.条目数) {
        如果 (字符串_相等(dt.条目列表[i].MIME类型, MIME)) {
            dt.条目列表[i].数据 = 数据
            dt.条目列表[i].数据长度 = 字符串_长度(数据)
            返回
        }
        i = i + 1
    }
    // 新增条目
    如果 (dt.条目数 >= DT_最大条目数) { 返回 }
    定义 idx = dt.条目数
    dt.条目列表[idx].类型 = 0  // 字符串
    dt.条目列表[idx].MIME类型 = 字符串_克隆(MIME)
    dt.条目列表[idx].数据 = 数据
    dt.条目列表[idx].数据长度 = 字符串_长度(数据)
    dt.条目列表[idx].文件名 = 0
    dt.条目列表[idx].最后修改时间 = 读取时钟()
    dt.条目数 = dt.条目数 + 1
}

函数 DataTransfer_getData(dt, MIME) {
    如果 (dt == 空) { 返回 0 }
    定义 可变 i = 0
    当 (i < dt.条目数) {
        如果 (字符串_相等(dt.条目列表[i].MIME类型, MIME)) {
            返回 dt.条目列表[i].数据
        }
        i = i + 1
    }
    返回 0
}

函数 DataTransfer_clearData(dt, MIME) {
    如果 (dt == 空 || dt.只读) { 返回 }
    如果 (MIME == 0) {
        // 清除所有条目
        dt.条目数 = 0
        返回
    }
    定义 可变 i = 0
    当 (i < dt.条目数) {
        如果 (字符串_相等(dt.条目列表[i].MIME类型, MIME)) {
            // 将最后一个条目移到当前位置
            dt.条目数 = dt.条目数 - 1
            如果 (i < dt.条目数) {
                dt.条目列表[i] = dt.条目列表[dt.条目数]
            }
            返回
        }
        i = i + 1
    }
}

函数 DataTransfer_addFile(dt, 文件名, MIME, 数据, 长度) {
    如果 (dt == 空 || dt.只读) { 返回 }
    如果 (dt.条目数 >= DT_最大条目数) { 返回 }
    定义 idx = dt.条目数
    dt.条目列表[idx].类型 = 1  // 文件
    dt.条目列表[idx].MIME类型 = 字符串_克隆(MIME)
    dt.条目列表[idx].数据 = 数据
    dt.条目列表[idx].数据长度 = 长度
    dt.条目列表[idx].文件名 = 字符串_克隆(文件名)
    dt.条目列表[idx].最后修改时间 = 读取时钟()
    dt.条目数 = dt.条目数 + 1
}

函数 DataTransfer_setDragImage(dt, 图像, x, y) {
    如果 (dt == 空) { 返回 }
    dt.拖放图像 = 图像
    dt.拖放图像_x = x
    dt.拖放图像_y = y
}

函数 DataTransfer_释放(dt) {
    如果 (dt == 空) { 返回 }
    定义 可变 i = 0
    当 (i < dt.条目数) {
        如果 (dt.条目列表[i].MIME类型 != 0) {
            堆_释放(dt.条目列表[i].MIME类型)
        }
        如果 (dt.条目列表[i].文件名 != 0) {
            堆_释放(dt.条目列表[i].文件名)
        }
        i = i + 1
    }
    堆_释放(dt)
}

// §4 剪贴板权限管理

定义 权限_允许  = 0
定义 权限_拒绝  = 1
定义 权限_提示  = 2

结构 剪贴板权限 {
    读权限,      // u8  权限_允许/拒绝/提示
    写权限,
    来源,        // u64 字符串 请求权限的源
    授权时间,
    过期时间      // u64 0=永久
}

定义 可变 权限表 = 空
定义 可变 权限表_大小 = 0
定义 权限表_容量 = 128

函数 剪贴板_检查权限(来源, 是写操作) {
    如果 (权限表 == 空) { 返回 权限_提示 }
    定义 可变 i = 0
    当 (i < 权限表_大小) {
        定义 p = 权限表 + i * 剪贴板权限_大小
        如果 (字符串_相等(p.来源, 来源)) {
            // 检查过期
            如果 (p.过期时间 != 0 && 读取时钟() > p.过期时间) {
                返回 权限_提示  // 已过期
            }
            如果 (是写操作) { 返回 p.写权限 }
            返回 p.读权限
        }
        i = i + 1
    }
    返回 权限_提示  // 未找到记录，需要提示
}

函数 剪贴板_授权(来源, 读, 写, 有效期秒) {
    如果 (权限表 == 空) {
        权限表 = 堆_分配_数组(权限表_容量 * 剪贴板权限_大小)
    }
    如果 (权限表_大小 >= 权限表_容量) { 返回 }
    定义 p = 权限表 + 权限表_大小 * 剪贴板权限_大小
    p.读权限 = 读
    p.写权限 = 写
    p.来源 = 字符串_克隆(来源)
    p.授权时间 = 读取时钟()
    如果 (有效期秒 > 0) {
        p.过期时间 = p.授权时间 + 有效期秒 * 1000000000
    } 否则 {
        p.过期时间 = 0
    }
    权限表_大小 = 权限表_大小 + 1
}

// §5 拖放控制器 (DragController)

结构 拖放状态 {
    正在拖放,        // bool
    源元素,          // u64 DOM节点指针
    数据传输,        // *DataTransfer
    当前目标,        // u64 当前悬停的目标元素
    起始X,
    起始Y,
    当前X,
    当前Y,
    拖放开始时间      // u64
}

定义 可变 全局拖放状态 = 拖放状态 {}

函数 拖放_开始(元素, x, y) {
    如果 (全局拖放状态.正在拖放) { 返回 }  // 已在拖放中
    // 检查 draggable 属性
    如果 (元素.可拖放 == 假) { 返回 }
    全局拖放状态.正在拖放 = 真
    全局拖放状态.源元素 = 元素
    全局拖放状态.数据传输 = DataTransfer_创建()
    全局拖放状态.当前目标 = 空
    全局拖放状态.起始X = x
    全局拖放状态.起始Y = y
    全局拖放状态.当前X = x
    全局拖放状态.当前Y = y
    全局拖放状态.拖放开始时间 = 读取时钟()
    // 触发 dragstart 事件
    定义 事件 = 创建拖放事件(拖放事件_dragstart, 元素, 全局拖放状态.数据传输)
    事件_分发(元素, 事件)
    全局CDTF统计.拖放开始次数 = 全局CDTF统计.拖放开始次数 + 1
}

函数 拖放_移动(x, y) {
    如果 (全局拖放状态.正在拖放 == 假) { 返回 }
    全局拖放状态.当前X = x
    全局拖放状态.当前Y = y
    // 命中测试: 查找当前坐标下的元素
    定义 目标 = DOM_命中测试(x, y)
    // dragenter / dragleave 逻辑
    如果 (目标 != 全局拖放状态.当前目标) {
        如果 (全局拖放状态.当前目标 != 空) {
            定义 离开事件 = 创建拖放事件(拖放事件_dragleave, 全局拖放状态.当前目标, 全局拖放状态.数据传输)
            事件_分发(全局拖放状态.当前目标, 离开事件)
        }
        如果 (目标 != 空) {
            定义 进入事件 = 创建拖放事件(拖放事件_dragenter, 目标, 全局拖放状态.数据传输)
            事件_分发(目标, 进入事件)
        }
        全局拖放状态.当前目标 = 目标
    }
    // dragover 事件
    如果 (目标 != 空) {
        定义 over事件 = 创建拖放事件(拖放事件_dragover, 目标, 全局拖放状态.数据传输)
        事件_分发(目标, over事件)
    }
    // 触发源元素的 drag 事件
    定义 drag事件 = 创建拖放事件(拖放事件_drag, 全局拖放状态.源元素, 全局拖放状态.数据传输)
    事件_分发(全局拖放状态.源元素, drag事件)
}

函数 拖放_释放(x, y) {
    如果 (全局拖放状态.正在拖放 == 假) { 返回 }
    定义 目标 = DOM_命中测试(x, y)
    如果 (目标 != 空) {
        // 触发 drop 事件
        全局拖放状态.数据传输.只读 = 假  // drop时可以读取数据
        定义 drop事件 = 创建拖放事件(拖放事件_drop, 目标, 全局拖放状态.数据传输)
        事件_分发(目标, drop事件)
        全局CDTF统计.拖放完成次数 = 全局CDTF统计.拖放完成次数 + 1
    }
    // 触发 dragend 事件
    定义 end事件 = 创建拖放事件(拖放事件_dragend, 全局拖放状态.源元素, 全局拖放状态.数据传输)
    事件_分发(全局拖放状态.源元素, end事件)
    // 清理拖放状态
    DataTransfer_释放(全局拖放状态.数据传输)
    全局拖放状态.正在拖放 = 假
    全局拖放状态.源元素 = 空
    全局拖放状态.数据传输 = 空
    全局拖放状态.当前目标 = 空
}

函数 创建拖放事件(事件类型, 目标元素, dt) {
    定义 evt = 事件_创建()
    evt.类型 = 事件类型
    evt.目标 = 目标元素
    evt.clientX = 全局拖放状态.当前X
    evt.clientY = 全局拖放状态.当前Y
    evt.dataTransfer = dt
    evt.可冒泡 = 真
    evt.可取消 = 真
    返回 evt
}

// §6 格式自动转换

函数 格式转换_HTML到纯文本(html) {
    // 简化: 去除HTML标签，保留文本内容
    如果 (html == 0) { 返回 0 }
    定义 长度 = 字符串_长度(html)
    定义 结果 = 堆_分配(长度 + 1)
    定义 可变 在标签内 = 假
    定义 可变 src = 0
    定义 可变 dst = 0
    当 (src < 长度) {
        定义 ch = 字符取(html, src)
        如果 (ch == 60) { 在标签内 = 真 }  // '<'
        否则 如果 (ch == 62) { 在标签内 = 假 }  // '>'
        否则 如果 (在标签内 == 假) {
            字符写(结果, dst, ch)
            dst = dst + 1
        }
        src = src + 1
    }
    字符写(结果, dst, 0)  // 终止符
    返回 结果
}

函数 格式转换_纯文本到HTML(文本) {
    // 转义HTML特殊字符并包装在<pre>中
    如果 (文本 == 0) { 返回 0 }
    定义 长度 = 字符串_长度(文本)
    定义 结果 = 字符串缓冲_创建(长度 * 2 + 32)
    字符串缓冲_追加(结果, "<pre>")
    定义 可变 i = 0
    当 (i < 长度) {
        定义 ch = 字符取(文本, i)
        如果 (ch == 38) { 字符串缓冲_追加(结果, "&amp;") }      // '&'
        否则 如果 (ch == 60) { 字符串缓冲_追加(结果, "&lt;") }    // '<'
        否则 如果 (ch == 62) { 字符串缓冲_追加(结果, "&gt;") }    // '>'
        否则 { 字符串缓冲_追加字符(结果, ch) }
        i = i + 1
    }
    字符串缓冲_追加(结果, "</pre>")
    返回 字符串缓冲_完成(结果)
}

// §7 AI剪贴板智能分析
// CDTF-AI理论: 基于内容特征的剪贴板智能分类
//   AI检测剪贴板内容类型（代码/URL/邮件/电话/普通文本）
//   并提供智能粘贴建议和安全风险评估

定义 内容类型_普通文本 = 0
定义 内容类型_URL     = 1
定义 内容类型_邮件    = 2
定义 内容类型_电话    = 3
定义 内容类型_代码    = 4
定义 内容类型_数据    = 5

函数 AI_检测剪贴板内容类型(文本) {
    如果 (文本 == 0) { 返回 内容类型_普通文本 }
    定义 bus = 全局AI总线
    如果 (bus == 空) {
        // 无AI总线，使用规则检测
        返回 规则检测内容类型(文本)
    }
    // AI检测
    定义 长度 = 字符串_长度(文本)
    定义 特征 = Tensor_创建(6)
    Tensor_写(特征, 0, 长度)
    Tensor_写(特征, 1, 字符串_包含(文本, "://") ? 1 : 0)  // URL特征
    Tensor_写(特征, 2, 字符串_包含(文本, "@") ? 1 : 0)    // 邮件特征
    Tensor_写(特征, 3, 统计数字字符(文本))               // 电话/数据特征
    Tensor_写(特征, 4, 字符串_包含(文本, "{") ? 1 : 0)    // 代码特征
    Tensor_写(特征, 5, 字符串_包含(文本, "(") ? 1 : 0)    // 函数调用特征
    定义 结果 = AI总线_推理(bus, "剪贴板内容分类", 特征)
    定义 类型 = Tensor_读(结果, 0)
    Tensor_释放(特征)
    Tensor_释放(结果)
    返回 类型
}

函数 规则检测内容类型(文本) {
    // 基于规则的快速内容类型检测
    如果 (字符串_开头(文本, "http://") || 字符串_开头(文本, "https://")) {
        返回 内容类型_URL
    }
    如果 (字符串_包含(文本, "@") && 字符串_包含(文本, ".")) {
        返回 内容类型_邮件
    }
    定义 数字比例 = 统计数字字符(文本) * 100 / (字符串_长度(文本) + 1)
    如果 (数字比例 > 60) { 返回 内容类型_电话 }
    如果 (字符串_包含(文本, "function") || 字符串_包含(文本, "{") && 字符串_包含(文本, "}")) {
        返回 内容类型_代码
    }
    返回 内容类型_普通文本
}

函数 统计数字字符(文本) {
    如果 (文本 == 0) { 返回 0 }
    定义 长度 = 字符串_长度(文本)
    定义 可变 计数 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 ch = 字符取(文本, i)
        如果 (ch >= 48 && ch <= 57) { 计数 = 计数 + 1 }  // '0'-'9'
        i = i + 1
    }
    返回 计数
}

函数 AI_剪贴板安全检查(文本) {
    // AI检测剪贴板内容是否包含敏感信息
    定义 bus = 全局AI总线
    如果 (bus == 空) { 返回 0 }
    定义 特征 = Tensor_创建(4)
    Tensor_写(特征, 0, 字符串_长度(文本))
    Tensor_写(特征, 1, 字符串_包含(文本, "password") ? 1 : 0)
    Tensor_写(特征, 2, 字符串_包含(文本, "secret") ? 1 : 0)
    Tensor_写(特征, 3, 字符串_包含(文本, "key") ? 1 : 0)
    定义 结果 = AI总线_风险评分(bus, "剪贴板安全", 特征)
    定义 风险分 = Tensor_读(结果, 0)
    Tensor_释放(特征)
    Tensor_释放(结果)
    返回 风险分
}

// §8 统计与诊断

结构 CDTF统计 {
    剪贴板读取次数,
    剪贴板写入次数,
    拖放开始次数,
    拖放完成次数,
    格式转换次数,
    AI检测次数,
    AI安全拦截次数      // u64
}

定义 可变 全局CDTF统计 = CDTF统计 {}

函数 CDTF_打印诊断() {
    内核打印("╔═══════════════════════════════════════╗")
    内核打印("║  CDTF 剪贴板数据传输框架 诊断       ║")
    内核打印("╠═══════════════════════════════════════╣")
    内核打印("║ 剪贴板读取:   {}", 全局CDTF统计.剪贴板读取次数)
    内核打印("║ 剪贴板写入:   {}", 全局CDTF统计.剪贴板写入次数)
    内核打印("║ 拖放开始:     {}", 全局CDTF统计.拖放开始次数)
    内核打印("║ 拖放完成:     {}", 全局CDTF统计.拖放完成次数)
    内核打印("║ 格式转换:     {}", 全局CDTF统计.格式转换次数)
    内核打印("║ AI检测:       {}", 全局CDTF统计.AI检测次数)
    内核打印("║ AI安全拦截:   {}", 全局CDTF统计.AI安全拦截次数)
    内核打印("╚═══════════════════════════════════════╝")
}

函数 CDTF_初始化() {
    全局CDTF统计 = CDTF统计 {}
    全局拖放状态 = 拖放状态 {}
    权限表 = 空
    权限表_大小 = 0
    内核打印("[CDTF] 剪贴板数据传输框架已初始化 v1.0")
}
}

// 稳态脑区 · 统一对外接口 — 硬件驱动/显示/音频/输入的唯一出口
// 职能: 显示管理/GPU渲染/音频播放/键鼠输入/设备驱动

导入("./窗口管理.nova")
导入("./键盘.nova")
导入("./显卡驱动.nova")
导入("./音频常量.nova")
导入("./图处显示.nova")
导入("./驱动注册.nova")

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 稳态_初始化() {
    驱动_全局初始化()
    显示_初始化()
    返回 0
}

函数 稳态_创建窗口(宽, 高, 标题) {
    返回 窗口_创建(宽, 高, 标题)
}

函数 稳态_刷新显示() {
    显示_刷新帧缓冲()
}

函数 稳态_设置像素(横, 纵, 颜色) {
    帧缓冲_写像素(横, 纵, 颜色)
}

函数 稳态_读取键盘() {
    返回 键盘_获取按键()
}

函数 稳态_读取鼠标() {
    返回 鼠标_获取状态()
}

函数 稳态_播放音频(数据, 采样率) {
    音频_播放缓冲(数据, 采样率)
}

函数 稳态_注册驱动(驱动描述) {
    返回 驱动_注册(驱动描述)
}

定义 可变 稳态_调用计数 = 0
定义 可变 稳态_最近总线消息 = 空

函数 稳态_安全入口(调用者, 操作码) {
    稳态_调用计数 = 稳态_调用计数 + 1
    如果 (调用者 < 0 || 调用者 > 8) { 返回 -1 }
    返回 0
}

函数 稳态_处理总线消息(调用者, 操作码, 数据) {
    稳态_最近总线消息 = {
        调用者: 调用者,
        操作码: 操作码,
        数据: 数据
    }
    返回 0
}


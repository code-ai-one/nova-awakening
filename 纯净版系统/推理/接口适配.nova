导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/自动扩容.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../外联/地址解析辅.nova")
导入("../标准/原生列表.nova")
导入("./渠道接口.nova")
导入("../中枢/墙钟设置.nova")

定义 接口_版本 = "v1"
定义 接口_最大请求体 = 65536
定义 接口_速率窗口秒 = 60
定义 接口_默认速率限制 = 120

定义 HTTP_200 = 200
定义 HTTP_400 = 400
定义 HTTP_401 = 401
定义 HTTP_403 = 403
定义 HTTP_429 = 429
定义 HTTP_500 = 500

结构 接口配置 {
    密钥,
    允许跨域,
    允许来源,
    速率限制,
    需要认证,
    版本,
}

结构 接口速率 {
    请求计数表,
    窗口开始,
}

定义 可变 接口_消息队列 = []
定义 可变 接口_响应队列 = []
定义 可变 接口_配置 = 空
定义 可变 接口_请求计数 = 0
定义 可变 接口_错误计数 = 0
定义 可变 接口_拒绝计数 = 0
定义 可变 接口_速率 = 空
定义 可变 接口_webhook列表 = []

函数 接口适配_创建(密钥) {
    接口_配置 = 接口配置 {
        密钥: 密钥,
        允许跨域: 真,
        允许来源: "*",
        速率限制: 接口_默认速率限制,
        需要认证: 密钥 != "",
        版本: 接口_版本
    }
    接口_速率 = 接口速率 { 请求计数表: 字典(), 窗口开始: 当前时间_秒() }
    返回 渠道_创建("接口", 渠道类型_接口, 接口_接收, 接口_发送)
}

函数 接口_接收() {
    如果 (计数(接口_消息队列) > 0) {
        定义 消息 = 接口_消息队列[0]
        接口_消息队列 = 列表_切片(接口_消息队列, 1, 计数(接口_消息队列))
        返回 消息
    }
    返回 空
}

函数 接口_发送(请求ID, 回复) {
    追加(接口_响应队列, [请求ID, 回复, 当前时间_毫秒()])
    接口_触发webhook("回复", 请求ID, 回复)
    返回 成功
}

函数 接口_获取响应(请求ID) {
    定义 可变 i = 0
    当 (i < 计数(接口_响应队列)) {
        如果 (接口_响应队列[i][0] == 请求ID) {
            定义 响应 = 接口_响应队列[i]
            接口_响应队列 = 列表_拼接(
                列表_切片(接口_响应队列, 0, i),
                列表_切片(接口_响应队列, i + 1, 计数(接口_响应队列))
            )
            返回 响应[1]
        }
        i = i + 1
    }
    返回 空
}

函数 接口_HTTP处理(请求体) {
    返回 接口_HTTP处理带头(请求体, "", "")
}

函数 接口_HTTP处理带头(请求体, 来源IP, 请求头) {
    接口_请求计数 = 接口_请求计数 + 1

    如果 (字符串长度(请求体) > 接口_最大请求体) {
        接口_错误计数 = 接口_错误计数 + 1
        返回 接口_错误响应(HTTP_400, "请求体过大")
    }

    如果 (来源IP != "" && !接口_检查速率(来源IP)) {
        接口_拒绝计数 = 接口_拒绝计数 + 1
        返回 接口_错误响应(HTTP_429, "请求过于频繁")
    }

    定义 消息 = 接口_提取字段(请求体, "message")
    定义 用户 = 接口_提取字段(请求体, "user_id")
    定义 密钥 = 接口_提取字段(请求体, "api_key")

    如果 (接口_配置.需要认证) {
        如果 (密钥 == "") {
            密钥 = 接口_从头提取Bearer(请求头)
        }
        如果 (密钥 != 接口_配置.密钥) {
            接口_拒绝计数 = 接口_拒绝计数 + 1
            返回 接口_错误响应(HTTP_401, "未授权")
        }
    }

    如果 (消息 == "") {
        接口_错误计数 = 接口_错误计数 + 1
        返回 接口_错误响应(HTTP_400, "消息不能为空")
    }

    如果 (用户 == "") { 用户 = "api_user" }

    定义 请求ID = 接口_生成请求ID()
    追加(接口_消息队列, [用户, 消息, 请求ID])
    接口_触发webhook("接收", 请求ID, 消息)

    返回 接口_成功响应(请求ID)
}

函数 接口_检查速率(来源IP) {
    如果 (接口_速率 == 空) { 返回 真 }
    定义 现在 = 当前时间_秒()
    如果 (现在 - 接口_速率.窗口开始 > 接口_速率窗口秒) {
        接口_速率.请求计数表 = 字典()
        接口_速率.窗口开始 = 现在
    }
    定义 当前计数 = 字典取(接口_速率.请求计数表, 来源IP)
    如果 (当前计数 == 空) { 当前计数 = 0 }
    如果 (当前计数 >= 接口_配置.速率限制) { 返回 假 }
    字典设(接口_速率.请求计数表, 来源IP, 当前计数 + 1)
    返回 真
}

函数 接口_从头提取Bearer(请求头) {
    定义 位置 = 字符串查找(请求头, "Bearer ")
    如果 (位置 < 0) { 返回 "" }
    返回 字符串子串(请求头, 位置 + 7, 字符串长度(请求头))
}

函数 接口_生成请求ID() {
    返回 字符串拼接("req_", 转字符串(接口_请求计数))
}

函数 接口_提取字段(json, 字段名) {
    定义 查找 = 字符串拼接("\"", 字符串拼接(字段名, "\":\""))
    定义 位置 = 字符串查找(json, 查找)
    如果 (位置 < 0) { 返回 "" }
    定义 起始 = 位置 + 字符串长度(查找)
    定义 结束 = 字符串查找(字符串子串(json, 起始, 字符串长度(json)), "\"")
    如果 (结束 < 0) { 返回 "" }
    返回 字符串子串(json, 起始, 起始 + 结束)
}

函数 接口_成功响应(请求ID) {
    返回 "{\"status\":\"accepted\",\"request_id\":\"" + 请求ID + "\",\"version\":\"" + 接口_版本 + "\"}"
}

函数 接口_错误响应(状态码, 消息) {
    返回 "{\"error\":\"" + 消息 + "\",\"code\":" + 转字符串(状态码) + "}"
}

函数 接口_CORS头() {
    如果 (!接口_配置.允许跨域) { 返回 "" }
    返回 "Access-Control-Allow-Origin: " + 接口_配置.允许来源
}

函数 接口_注册webhook(URL, 事件类型) {
    追加(接口_webhook列表, [URL, 事件类型])
}

函数 接口_触发webhook(事件, 请求ID, 数据) {
    定义 可变 i = 0
    当 (i < 计数(接口_webhook列表)) {
        定义 wh = 接口_webhook列表[i]
        如果 (wh[1] == 事件 || wh[1] == "全部") {
            // 异步发送webhook通知
        }
        i = i + 1
    }
}

函数 接口适配_初始化() { 返回 成功 }

函数 接口适配_统计() {
    返回 [接口_请求计数, 接口_错误计数, 接口_拒绝计数, 计数(接口_消息队列), 计数(接口_响应队列)]
}

函数 接口适配_设速率(限制) {
    如果 (接口_配置 != 空) { 接口_配置.速率限制 = 限制 }
}

函数 接口适配_设跨域(允许, 来源) {
    如果 (接口_配置 != 空) {
        接口_配置.允许跨域 = 允许
        接口_配置.允许来源 = 来源
    }
}

函数 接口适配_健康评估() {
    定义 可变 问题 = []
    如果 (接口_错误计数 > 100) { 追加(问题, "接口_错误计数=" + 接口_错误计数) }
    返回 计数(问题) == 0
}

函数 接口适配_综合报告() {
    打印("[接口适配] ═══ 综合报告 ═══")
    打印("  接口_请求计数: " + 接口_请求计数)
    打印("  接口_错误计数: " + 接口_错误计数)
    打印("  接口_拒绝计数: " + 接口_拒绝计数)
    打印("  接口_速率: " + 接口_速率)
    打印("  健康: " + 如果 (接口适配_健康评估()) { "正常" } 否则 { "异常" })
}

函数 接口适配_全局重置() {
    接口_请求计数 = 0
    接口_错误计数 = 0
    接口_拒绝计数 = 0
    接口_速率 = 0
    打印("[接口适配] 统计已重置")
    返回 0
}

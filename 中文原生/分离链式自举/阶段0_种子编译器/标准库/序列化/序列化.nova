导入("../基础.nova")
导入("../系统/配置.nova")


// 键值配置存储
// 配置: [键哈希列表, 值列表, 节名列表(用于INI)]
函数 序列化_配置_创建() { 返回 [[], [], []] }

函数 配置_有(cfg, 键哈希) { 定义 可变 i = 0
 当 (i < 计数(cfg[0])) { 如果 (cfg[0][i] == 键哈希) { 返回 真 }
 i = i + 1
 }
 返回 假
}

函数 配置_大小(cfg) { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(cfg[0])) { 如果 (cfg[0][i] != -1) { c = c + 1 }
 i = i + 1
 }
 返回 c
}

函数 配置_所有键(cfg) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(cfg[0])) { 如果 (cfg[0][i] != -1) { 追加(r, cfg[0][i]) }
 i = i + 1
 }
 返回 r
}

// INI格式解析
// 解析 "[section]\nkey=value\n..." 格式
函数 INI_解析(文本) { 定义 可变 结果 = 序列化_配置_创建()
 定义 可变 当前节 = 0
 定义 可变 位置 = 0
 当 (位置 < 计数(文本)) {
 // 跳过空白行
 当 (位置 < 计数(文本) 且 (字符码(文本, 位置) == 10 或 字符码(文本, 位置) == 13)) { 位置 = 位置 + 1 }
 如果 (位置 >= 计数(文本)) { 返回 结果 }
 // 读取一行
 定义 可变 行 = ""
 当 (位置 < 计数(文本) 且 字符码(文本, 位置) != 10) { 如果 (字符码(文本, 位置) != 13) { 行 = (行 + 子串(文本, 位置, 1)) }
 位置 = 位置 + 1
 }
 如果 (位置 < 计数(文本)) { 位置 = 位置 + 1 }
 如果 (计数(行) == 0 或 字符码(行, 0) == 59 或 字符码(行, 0) == 35) {
 继续
 } 否则 如果 (字符码(行, 0) == 91) { 定义 可变 名 = ""
 定义 可变 j = 1
 当 (j < 计数(行) 且 字符码(行, j) != 93) {
 名 = (名 + 子串(行, j, 1))
 j = j + 1
 }
 // 简易哈希节名
 定义 可变 h = 0
 j = 0
 当 (j < 计数(名)) { h = h * 31 + 编码(子串(名, j, 1))
 j = j + 1 }
 当前节 = h
 追加(结果[2], h)
 }
 // key=value
 否则 { 定义 可变 eq = -1
 定义 可变 k = 0
 当 (k < 计数(行)) { 如果 (字符码(行, k) == 61 且 eq < 0) { eq = k }
 k = k + 1
 }
 如果 (eq > 0) { 定义 键str = 子串(行, 0, eq)
 定义 值str = 子串(行, eq + 1, 计数(行) - eq - 1)
 // 组合键: 节哈希*10000 + 键哈希
 定义 可变 kh = 0
 k = 0
 当 (k < 计数(键str)) { kh = kh * 31 + 编码(子串(键str, k, 1))
 k = k + 1 }
 定义 组合键 = 当前节 * 10000 + kh
 // 尝试解析为数字
 定义 可变 是数 = 真
 定义 可变 数目 = 0
 定义 可变 neg = 假
 k = 0
 如果 (计数(值str) > 0 且 字符码(值str, 0) == 45) { neg = 真
 k = 1 }
 当 (k < 计数(值str)) { 定义 d = 字符码(值str, k) - 48
 如果 (d >= 0 且 d <= 字符_制表) { 数目 = 数目 * 10 + d }
 否则 { 是数 = 假 }
 k = k + 1
 }
 如果 (neg) { 数目 = 0 - 数目 }
 如果 (是数 且 计数(值str) > 0) { 追加(结果[0], 组合键)
 追加(结果[1], 数目) }
 否则 { 追加(结果[0], 组合键)
 追加(结果[1], 0) }
 }
 }
 }
 返回 结果
}

// 检查点
// 检查点: [版本, 时间戳, 数据列表, 校验和]
函数 检查点_创建(版本, 时间戳, 数据) { 定义 可变 校验 = 版本 * 17 + 时间戳 * 31
 定义 可变 i = 0
 当 (i < 计数(数据)) { 校验 = 校验 + 数据[i] * (i + 1)
 i = i + 1 }
 如果 (校验 < 0) { 校验 = 0 - 校验 }
 返回 [版本, 时间戳, 数据, 校验]
}

函数 检查点_版本(cp) { 返回 cp[0] }
函数 检查点_时间(cp) { 返回 cp[1] }
函数 检查点_数据(cp) { 返回 cp[2] }
函数 检查点_校验(cp) { 返回 cp[3] }

函数 检查点_验证(cp) { 定义 可变 校验 = cp[0] * 17 + cp[1] * 31
 定义 可变 i = 0
 当 (i < 计数(cp[2])) { 校验 = 校验 + cp[2][i] * (i + 1)
 i = i + 1 }
 如果 (校验 < 0) { 校验 = 0 - 校验 }
 返回 校验 == cp[3]
}

// 检查点管理器
定义 可变 检查点列表 = []
定义 可变 最大检查点数 = 5

函数 检查点管理器_保存(版本, 时间戳, 数据) { 定义 cp = 检查点_创建(版本, 时间戳, 数据)
    定义 可变 新列表 = []
 追加(检查点列表, cp)
 // 超出限制时移除最旧的(简易: 标记第一个为空)
如果 (计数(检查点列表) > 最大检查点数) {
 定义 可变 i = 计数(检查点列表) - 最大检查点数
 当 (i < 计数(检查点列表)) { 追加(新列表, 检查点列表[i])
 i = i + 1 }
 检查点列表 = 新列表
 }
 返回 cp
}

函数 检查点管理器_最新() {
    如果 (计数(检查点列表) == 0) { 返回 空
}
 返回 检查点列表[计数(检查点列表) - 1]
}

函数 检查点管理器_数量() { 返回 计数(检查点列表) }

函数 检查点管理器_按版本(版本) { 定义 可变 i = 计数(检查点列表) - 1
 当 (i >= 0) { 如果 (检查点列表[i][0] == 版本) { 返回 检查点列表[i] }
 i = i - 1
 }
 返回 空
}

// 数据校验
函数 CRC_简易(数据) { 定义 可变 校验值 = 0xFFFF
 定义 可变 i = 0
 当 (i < 计数(数据)) {
 校验值 = 校验值 ^ 数据[i]
 定义 可变 j = 0
 当 (j < 8) { 定义 最低位 = 校验值 & 1
 如果 (最低位 == 1) {
 校验值 = (校验值 >> 1) ^ 0xA001
 } 否则 {
 校验值 = 校验值 >> 1
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 校验值 & 0xFFFF
}

// 检查点差异
函数 检查点_差异数(cp1, cp2) { 定义 可变 差值 = 0
 定义 d1 = cp1[2]
 定义 d2 = cp2[2]
 定义 可变 i = 0
 定义 可变 n = 计数(d1)
 如果 (计数(d2) < n) { n = 计数(d2) }
 当 (i < n) { 如果 (d1[i] != d2[i]) { 差值 = 差值 + 1 }
 i = i + 1
 }
 定义 可变 长差 = 计数(d1) - 计数(d2)
 如果 (长差 < 0) { 长差 = 0 - 长差 }
 返回 差值 + 长差
}
// 版本化序列化
函数 序列化_带版本(版本号, 数据) { 定义 可变 结果 = [0x4E, 0x56, 版本号 & 0xFF, (版本号 >> 8) & 0xFF]
 定义 可变 i = 0
 当 (i < 计数(数据)) { 追加(结果, 数据[i]) i = i + 1 }
 返回 结果
}

函数 序列化_读版本(数据) {
    如果 (计数(数据) < 4) { 返回 -1
}
 如果 (数据[0] != 0x4E 或 数据[1] != 0x56) { 返回 -1 }
 返回 数据[2] | (数据[3] << 8)
}

函数 序列化_取数据(数据) { 定义 可变 结果 = []
 定义 可变 i = 4
 当 (i < 计数(数据)) { 追加(结果, 数据[i]) i = i + 1 }
 返回 结果
}

// 校验和
函数 校验和_CRC简化(数据) { 定义 可变 校验值 = 0xFFFF
 定义 可变 i = 0
 当 (i < 计数(数据)) {
 校验值 = 校验值 + 数据[i] * 31
 校验值 = 校验值 & 0xFFFF
 i = i + 1
 }
 返回 校验值
}

函数 校验和_验证(数据, 期望crc) { 返回 校验和_CRC简化(数据) == 期望crc
}

// 变长整数编码(VarInt)
函数 VarInt_编码(值) { 定义 可变 结果 = []
 定义 可变 v = 值
 当 (v >= 128) {
 追加(结果, (v & 0x7F) | 0x80)
 v = v >> 7
 }
 追加(结果, v & 0x7F)
 返回 结果
}

函数 VarInt_解码(数据, 偏移) { 定义 可变 值 = 0
 定义 可变 移位 = 0
 定义 可变 位置 = 偏移
 当 (位置 < 计数(数据)) { 定义 b = 数据[位置]
 值 = 值 | ((b & 0x7F) << 移位)
 位置 = 位置 + 1
 如果 ((b & 0x80) == 0) { 返回 [值, 位置] }
 移位 = 移位 + 7
 }
 返回 [值, 位置]
}

// 龙工具 — 代码格式化器 (Formatter)
// 自动缩进、空白规范化、括号对齐、行宽控制
// 支持配置文件、保留注释、幂等格式化

导入("../../标准库/基础.nova")

// 格式化配置
// [缩进宽度, 使用空格(真)/制表符(假), 最大行宽, 尾随逗号,
//  函数间空行, 大括号风格(0=同行/1=新行), 操作符空格]

函数 格式配置_默认() {
    返回 [4, 真, 100, 假, 1, 0, 真]
}

函数 格式配置_紧凑() {
    返回 [2, 真, 120, 假, 0, 真]
}

// 格式化器
// 型: [配置, 缩进级别, 输出行列表, 当前行, 上一行类型]
// 行类型: 0=空行, 1=注释, 2=代码, 3=函数开始, 4=块结束

函数 格式化器_创建(配置) {
    返回 [配置, 0, [], "", 0]
}

函数 格式化器_格式化(源码) {
    定义 配置 = 格式配置_默认()
    定义 fmt = 格式化器_创建(配置)
    定义 行列表 = 格式_分割行(源码)
    定义 可变 i = 0
    当 (i < 计数(行列表)) {
        格式化器_处理行(fmt, 行列表[i])
        i = i + 1
    }
    // 刷新最后一行
    如果 (计数(fmt[3]) > 0) {
        追加(fmt[2], fmt[3])
    }
    返回 格式_合并行(fmt[2])
}

函数 格式化器_处理行(fmt, 原始行) {
    定义 去空白 = 格式_去首尾空白(原始行)
    // 空行处理
    如果 (计数(去空白) == 0) {
        如果 (fmt[4] != 0) {
            格式化器_输出行(fmt, "")
            fmt[4] = 0
        }
        返回
    }
    // 注释行
    如果 (格式_开头是(去空白, "//")) {
        格式化器_输出行(fmt, 字符串拼接(格式_缩进(fmt), 去空白))
        fmt[4] = 1
        返回
    }
    // 检查是否含闭括号 — 先减缩进
    如果 (格式_开头是(去空白, "}")) {
        fmt[1] = fmt[1] - 1
        如果 (fmt[1] < 0) { fmt[1] = 0 }
    }
    // 构建格式化行
    定义 可变 格式行 = 格式_缩进(fmt)
    定义 格式化内容 = 格式_规范化空白(去空白, fmt[0][6])
    格式行 = 字符串拼接(格式行, 格式化内容)
    // 检查行宽
    如果 (计数(格式行) > fmt[0][2]) {
        // 尝试断行 (在逗号后)
        定义 断行结果 = 格式_断行(格式行, fmt[0][2], fmt)
        定义 可变 j = 0
        当 (j < 计数(断行结果)) {
            格式化器_输出行(fmt, 断行结果[j])
            j = j + 1
        }
    } 否则 {
        格式化器_输出行(fmt, 格式行)
    }
    // 检查是否含开括号 — 增加缩进
    定义 可变 k = 0
    当 (k < 计数(去空白)) {
        定义 c = 子串(去空白, k, 1)
        如果 (字符串等于(c, "{")) { fmt[1] = fmt[1] + 1 }
        k = k + 1
    }
    // 更新行类型
    如果 (格式_包含(去空白, "函数 ") 或 格式_包含(去空白, "法 ")) { fmt[4] = 3 }
    否则 如果 (格式_开头是(去空白, "}")) { fmt[4] = 4 }
    否则 { fmt[4] = 2 }
    // 函数间空行
    如果 (fmt[4] == 3 且 计数(fmt[2]) > 0) {
        定义 可变 空行数 = 0
        当 (空行数 < fmt[0][4]) {
            定义 最后 = fmt[2][计数(fmt[2]) - 1]
            如果 (计数(格式_去首尾空白(最后)) == 0) { 空行数 = fmt[0][4] } 否则 {
            定义 可变 新列表 = []
            定义 可变 m = 0
            当 (m < 计数(fmt[2])) { 追加(新列表, fmt[2][m]) m = m + 1 }
            追加(新列表, "")
            fmt[2] = 新列表
            空行数 = 空行数 + 1
        } }
    }
}

函数 格式化器_输出行(fmt, 行) {
    追加(fmt[2], 行)
}

// 缩进生成
函数 格式_缩进(fmt) {
    定义 宽度 = fmt[0][0] * fmt[1]
    定义 可变 r = ""
    定义 可变 i = 0
    如果 (fmt[0][1]) {
        当 (i < 宽度) { r = 字符串拼接(r, " ") i = i + 1 }
    } 否则 {
        当 (i < fmt[1]) { r = 字符串拼接(r, "\t") i = i + 1 }
    }
    返回 r
}

// 空白规范化
函数 格式_规范化空白(行, 操作符空格) {
    定义 n = 计数(行)
    定义 可变 结果 = ""
    定义 可变 i = 0
    定义 可变 在字符串 = 假
    定义 可变 上一空白 = 假
    当 (i < n) {
        定义 c = 子串(行, i, 1)
        // 字符串内不处理
        如果 (字符串等于(c, "\"")) { 在字符串 = 在字符串 == 假 }
        如果 (在字符串) {
            结果 = 字符串拼接(结果, c)
            i = i + 1
            续
        }
        // 合并连续空白
        如果 (字符串等于(c, " ") 或 字符串等于(c, "\t")) {
            如果 (上一空白 == 假 且 计数(结果) > 0) {
                结果 = 字符串拼接(结果, " ")
            }
            上一空白 = 真
            i = i + 1
            续
        }
        上一空白 = 假
        // 操作符前后加空格
        如果 (操作符空格) {
            如果 (字符串等于(c, "=") 或 字符串等于(c, "+") 或 字符串等于(c, "-") 或 字符串等于(c, "*") 或 字符串等于(c, "/")) {
                // 避免双字符运算符 ==, !=, >=, <=, +=
                定义 可变 双字符 = 假
                如果 (i + 1 < n) {
                    定义 下一 = 子串(行, i + 1, 1)
                    如果 (字符串等于(下一, "=")) { 双字符 = 真 }
                }
                如果 (双字符) {
                    如果 (计数(结果) > 0 且 字符串等于(子串(结果, 计数(结果) - 1, 1), " ") == 假) {
                        结果 = 字符串拼接(结果, " ")
                    }
                    结果 = 字符串拼接(结果, c)
                    结果 = 字符串拼接(结果, 子串(行, i + 1, 1))
                    结果 = 字符串拼接(结果, " ")
                    i = i + 2
                    续
                }
            }
        }
        结果 = 字符串拼接(结果, c)
        i = i + 1
    }
    // 去除尾部空白
    当 (计数(结果) > 0 且 字符串等于(子串(结果, 计数(结果) - 1, 1), " ")) {
        结果 = 子串(结果, 0, 计数(结果) - 1)
    }
    返回 结果
}

// 行断裂
函数 格式_断行(行, 最大宽, fmt) {
    定义 可变 结果 = []
    定义 n = 计数(行)
    定义 可变 当前 = ""
    定义 可变 i = 0
    定义 可变 在字符串 = 假
    当 (i < n) {
        定义 c = 子串(行, i, 1)
        如果 (字符串等于(c, "\"")) { 在字符串 = 在字符串 == 假 }
        当前 = 字符串拼接(当前, c)
        // 在逗号后断行
        如果 (在字符串 == 假 且 字符串等于(c, ",") 且 计数(当前) > 最大宽 / 2) {
            追加(结果, 当前)
            当前 = 格式_缩进(fmt)
            当前 = 字符串拼接(当前, "    ")
        }
        i = i + 1
    }
    如果 (计数(当前) > 0) { 追加(结果, 当前) }
    如果 (计数(结果) == 0) { 追加(结果, 行) }
    返回 结果
}

// 工具
函数 格式_分割行(文本) {
    定义 n = 计数(文本)
    定义 可变 结果 = []
    定义 可变 当前 = ""
    定义 可变 i = 0
    当 (i < n) {
        定义 c = 子串(文本, i, 1)
        如果 (字符串等于(c, "\n")) {
            追加(结果, 当前)
            当前 = ""
        } 否则 如果 (字符串等于(c, "\r") == 假) {
            当前 = 字符串拼接(当前, c)
        }
        i = i + 1
    }
    如果 (计数(当前) > 0) { 追加(结果, 当前) }
    返回 结果
}

函数 格式_合并行(行列表) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(行列表)) {
        如果 (i > 0) { 结果 = 字符串拼接(结果, "\n") }
        结果 = 字符串拼接(结果, 行列表[i])
        i = i + 1
    }
    返回 结果
}

函数 格式_去首尾空白(s) {
    定义 n = 计数(s)
    定义 可变 开始 = 0
    当 (开始 < n 且 (字符串等于(子串(s, 开始, 1), " ") 或 字符串等于(子串(s, 开始, 1), "\t"))) { 开始 = 开始 + 1 }
    定义 可变 结束 = n
    当 (结束 > 开始 且 (字符串等于(子串(s, 结束 - 1, 1), " ") 或 字符串等于(子串(s, 结束 - 1, 1), "\t"))) { 结束 = 结束 - 1 }
    如果 (开始 >= 结束) { 返回 "" }
    返回 子串(s, 开始, 结束 - 开始)
}

函数 格式_开头是(s, 前缀) {
    如果 (计数(s) < 计数(前缀)) { 返回 假 }
    返回 字符串等于(子串(s, 0, 计数(前缀)), 前缀)
}

函数 格式_包含(文本, 子串文本) {
    定义 n = 计数(文本)
    定义 m = 计数(子串文本)
    如果 (m > n) { 返回 假 }
    定义 可变 i = 0
    当 (i <= n - m) {
        如果 (字符串等于(子串(文本, i, m), 子串文本)) { 返回 真 }
        i = i + 1
    }
    返回 假

}

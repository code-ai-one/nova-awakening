// Nova · 编译器 · 项目系统 · 引擎合同 (M14)
// 游戏/AI引擎子系统的编译期契约: 帧循环、物理、场景图、资源管理
// 以及真场景样例的编译验证

导入("../../标准库/基础.nova")
导入("../../标准库/转换器/转换验证.nova")
导入("../../运行时/原语桩.nova")

// 引擎合同字段
// [帧循环类型, 物理步长ms, 最大实体数, 最大组件数, 场景图深度, 资源预算MB, AI决策频率Hz]
定义 帧循环_固定 = 0
定义 帧循环_可变 = 1
定义 帧循环_半固定 = 2

函数 引擎合同_创建(帧循环类型) {
    返回 [帧循环类型, 16, 0, 0, 0]
}

函数 引擎合同_帧循环(c) { 返回 c[0] }
函数 引擎合同_物理步长(c) { 返回 c[1] }
函数 引擎合同_最大实体(c) { 返回 c[2] }
函数 引擎合同_最大组件(c) { 返回 c[3] }
函数 引擎合同_场景深度(c) { 返回 c[4] }
函数 引擎合同_资源预算(c) { 返回 c[5] }
函数 引擎合同_AI频率(c) { 返回 c[6] }
函数 引擎合同_设物理步长(c, ms) { c[1] = ms }
函数 引擎合同_设最大实体(c, n) { c[2] = n }
函数 引擎合同_设最大组件(c, n) { c[3] = n }
函数 引擎合同_设场景深度(c, n) { c[4] = n }
函数 引擎合同_设资源预算(c, mb) { c[5] = mb }
函数 引擎合同_设AI频率(c, hz) { c[6] = hz }

// 引擎验证: 扫描模块中的引擎相关函数
定义 可变 _引擎验证_场景函数数 = 0
定义 可变 _引擎验证_物理函数数 = 0
定义 可变 _引擎验证_AI函数数 = 0
定义 可变 _引擎验证_资源函数数 = 0
定义 可变 _引擎验证_帧循环数 = 0

函数 引擎合同_验证(函数列) {
    _引擎验证_场景函数数 = 0
    _引擎验证_物理函数数 = 0
    _引擎验证_AI函数数 = 0
    _引擎验证_资源函数数 = 0
    _引擎验证_帧循环数 = 0
    如果 (函数列 == 空) { 返回 空 }
    定义 可变 fi = 0
    当 (fi < 计数(函数列)) {
        如果 (是列表(函数列[fi]) 且 计数(函数列[fi]) >= 2) {
            定义 名 = 函数列[fi][1]
            如果 (字符串包含(名, "场景") 或 字符串包含(名, "节点") 或 字符串包含(名, "实体")) {
                _引擎验证_场景函数数 = _引擎验证_场景函数数 + 1
            }
            如果 (字符串包含(名, "物理") 或 字符串包含(名, "碰撞") 或 字符串包含(名, "刚体")) {
                _引擎验证_物理函数数 = _引擎验证_物理函数数 + 1
            }
            如果 (字符串包含(名, "AI") 或 字符串包含(名, "决策") 或 字符串包含(名, "推理") 或 字符串包含(名, "神经")) {
                _引擎验证_AI函数数 = _引擎验证_AI函数数 + 1
            }
            如果 (字符串包含(名, "资源") 或 字符串包含(名, "加载") 或 字符串包含(名, "缓存")) {
                _引擎验证_资源函数数 = _引擎验证_资源函数数 + 1
            }
            如果 (字符串包含(名, "帧循环") 或 字符串包含(名, "主循环") 或 字符串包含(名, "游戏循环")) {
                _引擎验证_帧循环数 = _引擎验证_帧循环数 + 1
            }
        }
        fi = fi + 1
    }
}

// 引擎报告
函数 引擎合同_打印报告() {
    打印文本("═══ 引擎合同报告 (M14) ═══")
    打印文本(字符串拼接("  场景函数: ", 转字符串(_引擎验证_场景函数数)))
    打印文本(字符串拼接("  物理函数: ", 转字符串(_引擎验证_物理函数数)))
    打印文本(字符串拼接("  AI函数: ", 转字符串(_引擎验证_AI函数数)))
    打印文本(字符串拼接("  资源函数: ", 转字符串(_引擎验证_资源函数数)))
    打印文本(字符串拼接("  帧循环: ", 转字符串(_引擎验证_帧循环数)))
}

函数 引擎合同_结构化报告() {
    定义 报告 = 字典()
    字典设(报告, "引擎_场景函数", 转字符串(_引擎验证_场景函数数))
    字典设(报告, "引擎_物理函数", 转字符串(_引擎验证_物理函数数))
    字典设(报告, "引擎_AI函数", 转字符串(_引擎验证_AI函数数))
    字典设(报告, "引擎_资源函数", 转字符串(_引擎验证_资源函数数))
    字典设(报告, "引擎_帧循环", 转字符串(_引擎验证_帧循环数))
    返回 报告
}

// 真场景样例: 编译器可验证的最小引擎循环
// 样例1: 最小帧循环 (验证固定时间步进模式)
函数 引擎样例_最小帧循环() {
    定义 合同 = 引擎合同_创建(帧循环_固定)
    引擎合同_设物理步长(合同, 16)
    引擎合同_设最大实体(合同, 100)
    返回 合同
}

// 样例2: AI决策循环 (验证推理频率约束)
函数 引擎样例_AI决策循环() {
    定义 合同 = 引擎合同_创建(帧循环_半固定)
    引擎合同_设AI频率(合同, 30)
    引擎合同_设最大实体(合同, 50)
    引擎合同_设资源预算(合同, 256)
    返回 合同
}

// 样例3: 物理仿真 (验证碰撞检测约束)
函数 引擎样例_物理仿真() {
    定义 合同 = 引擎合同_创建(帧循环_固定)
    引擎合同_设物理步长(合同, 8)
    引擎合同_设最大实体(合同, 1000)
    引擎合同_设场景深度(合同, 8)
    返回 合同
}

// M14: ECS实体-组件-系统
// 组件类型标识
定义 合同_组件_变换 = 0
定义 合同_组件_渲染 = 1
定义 合同_组件_物理 = 2
定义 合同_组件_AI = 3
定义 合同_组件_音频 = 4
定义 合同_组件_脚本 = 5
定义 合同_组件_碰撞 = 6
定义 合同_组件_粒子 = 7
定义 _合同_组件类型总数 = 8

// ECS世界: [实体列表, 组件表(按类型), 系统列表, 下一ID, 统计]
函数 合同_ECS世界_创建() {
    定义 可变 组件表 = []
    定义 可变 i = 0
    当 (i < _合同_组件类型总数) { 追加(组件表, 字典())  i = i + 1 }
    返回 [[], 组件表, [], 1, [0, 0, 0, 0]]
    // 统计: [实体总数, 组件总数, 系统数, tick数]
}

函数 合同_ECS_创建实体(世界) {
    定义 id = 世界[3]
    世界[3] = id + 1
    追加(世界[0], id)
    世界[4][0] = 世界[4][0] + 1
    返回 id
}

函数 合同_ECS_添加组件(世界, 实体ID, 组件类型, 数据) {
    字典设(世界[1][组件类型], 转字符串(实体ID), 数据)
    世界[4][1] = 世界[4][1] + 1
}

函数 合同_ECS_获取组件(世界, 实体ID, 组件类型) {
    返回 字典获取(世界[1][组件类型], 转字符串(实体ID))
}

函数 合同_ECS_注册系统(世界, 系统函数, 优先级) {
    追加(世界[2], [系统函数, 优先级])
    世界[4][2] = 世界[4][2] + 1
}

函数 合同_ECS_tick(世界, dt) {
    定义 可变 si = 0
    当 (si < 计数(世界[2])) {
        定义 系统 = 世界[2][si]
        系统[0](世界, dt)
        si = si + 1
    }
    世界[4][3] = 世界[4][3] + 1
}

// M14: 场景图
// 节点: [ID, 名称, 父ID, 子列表, 变换(x,y,z,rx,ry,rz,sx,sy,sz), 可见, 层]
函数 场景节点_创建(id, 名称) {
    返回 [id, 名称, -1, [], [0,0,0, 0,0,0, 1000,1000,1000], 真, 0]
}

函数 场景节点_添加子(父, 子) {
    子[2] = 父[0]
    追加(父[3], 子)
}

函数 场景节点_设位置(节点, x, y, z) { 节点[4][0] = x  节点[4][1] = y  节点[4][2] = z }
函数 场景节点_设可见(节点, v) { 节点[5] = v }
函数 场景节点_设层(节点, 层) { 节点[6] = 层 }

函数 场景图_遍历(节点, 回调, 深度) {
    回调(节点, 深度)
    定义 可变 ci = 0
    当 (ci < 计数(节点[3])) {
        场景图_遍历(节点[3][ci], 回调, 深度 + 1)
        ci = ci + 1
    }
}

函数 场景图_计数(节点) {
    定义 可变 总 = 1
    定义 可变 ci = 0
    当 (ci < 计数(节点[3])) {
        总 = 总 + 场景图_计数(节点[3][ci])
        ci = ci + 1
    }
    返回 总
}

// M14: 资源管线
// 资源状态
定义 资源_未加载 = 0
定义 资源_加载中 = 1
定义 资源_已加载 = 2
定义 资源_卸载中 = 3
定义 资源_错误 = 4

// 资源管理器: [资源表, 加载队列, 内存用量, 内存上限, 统计]
函数 资源管理器_创建(内存上限MB) {
    返回 [字典(), [], 0, 内存上限MB * 1024 * 1024, [0, 0, 0]]
    // 统计: [加载次数, 卸载次数, 缓存命中]
}

函数 资源_请求(mgr, 路径, 大小) {
    定义 已有 = 字典获取(mgr[0], 路径)
    如果 (已有 != 空) { mgr[4][2] = mgr[4][2] + 1  返回 已有 }
    如果 (mgr[2] + 大小 > mgr[3]) { 返回 空 }
    定义 资源 = [路径, 资源_已加载, 大小, 0]
    字典设(mgr[0], 路径, 资源)
    mgr[2] = mgr[2] + 大小
    mgr[4][0] = mgr[4][0] + 1
    返回 资源
}

函数 资源_释放(mgr, 路径) {
    定义 资源 = 字典获取(mgr[0], 路径)
    如果 (资源 != 空) {
        mgr[2] = mgr[2] - 资源[2]
        字典删(mgr[0], 路径)
        mgr[4][1] = mgr[4][1] + 1
    }
}

函数 资源_使用率(mgr) {
    如果 (mgr[3] == 0) { 返回 0 }
    返回 mgr[2] * 100 / mgr[3]
}

// M14: 帧预算追踪
// 帧预算: [目标帧率, 帧预算us, 各阶段耗时[], 总帧数, 超预算帧数, 峰值帧时间us]
定义 帧阶段_输入 = 0
定义 帧阶段_AI = 1
定义 帧阶段_物理 = 2
定义 帧阶段_动画 = 3
定义 帧阶段_渲染 = 4
定义 帧阶段_音频 = 5
定义 帧阶段_提交 = 6
定义 _帧阶段数 = 7

函数 帧预算_创建(目标帧率) {
    定义 预算us = 1000000 / 目标帧率
    定义 可变 阶段 = []
    定义 可变 i = 0
    当 (i < _帧阶段数) { 追加(阶段, 0)  i = i + 1 }
    返回 [目标帧率, 预算us, 阶段, 0, 0, 0]
}

函数 帧预算_记录阶段(fb, 阶段, 耗时us) { fb[2][阶段] = 耗时us }

函数 帧预算_结帧(fb) {
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < _帧阶段数) { 总 = 总 + fb[2][i]  i = i + 1 }
    fb[3] = fb[3] + 1
    如果 (总 > fb[1]) { fb[4] = fb[4] + 1 }
    如果 (总 > fb[5]) { fb[5] = 总 }
    返回 总
}

函数 帧预算_超预算率(fb) {
    如果 (fb[3] == 0) { 返回 0 }
    返回 fb[4] * 100 / fb[3]
}

// M14: 显存预算
// [总预算bytes, 已用, 峰值, 分配次数, 释放次数]
函数 显存预算_创建(预算MB) { 返回 [预算MB * 1024 * 1024, 0, 0, 0, 0] }
函数 显存预算_分配(vb, 大小) {
    vb[1] = vb[1] + 大小
    如果 (vb[1] > vb[2]) { vb[2] = vb[1] }
    vb[3] = vb[3] + 1
    返回 vb[1] <= vb[0]
}
函数 引擎合同_显存预算_释放(vb, 大小) { vb[1] = vb[1] - 大小  vb[4] = vb[4] + 1 }
函数 引擎合同_显存预算_使用率(vb) {
    如果 (vb[0] == 0) { 返回 0 }
    返回 vb[1] * 100 / vb[0]
}

// M14: game-ai-64 profile
函数 引擎profile_game_ai_64() {
    定义 c = 引擎合同_创建(帧循环_半固定)
    引擎合同_设物理步长(c, 16)
    引擎合同_设最大实体(c, 10000)
    引擎合同_设最大组件(c, 80000)
    引擎合同_设场景深度(c, 16)
    引擎合同_设资源预算(c, 2048)
    引擎合同_设AI频率(c, 60)
    返回 c
}

// M14: 引擎综合报告 (引擎循环_报告 + 帧预算_报告 + 资产管线_报告)
函数 引擎_综合报告(ecs世界, 帧预算, 资源mgr, 显存vb) {
    定义 r = 字典()
    // ECS统计
    字典设(r, "ECS_实体数", 转字符串(ecs世界[4][0]))
    字典设(r, "ECS_组件数", 转字符串(ecs世界[4][1]))
    字典设(r, "ECS_系统数", 转字符串(ecs世界[4][2]))
    字典设(r, "ECS_tick数", 转字符串(ecs世界[4][3]))
    // 帧预算
    字典设(r, "帧_目标帧率", 转字符串(帧预算[0]))
    字典设(r, "帧_预算us", 转字符串(帧预算[1]))
    字典设(r, "帧_总帧数", 转字符串(帧预算[3]))
    字典设(r, "帧_超预算数", 转字符串(帧预算[4]))
    字典设(r, "帧_超预算率%", 转字符串(帧预算_超预算率(帧预算)))
    字典设(r, "帧_峰值us", 转字符串(帧预算[5]))
    // 资源管线
    字典设(r, "资源_内存用量", 转字符串(资源mgr[2]))
    字典设(r, "资源_内存上限", 转字符串(资源mgr[3]))
    字典设(r, "资源_使用率%", 转字符串(资源_使用率(资源mgr)))
    字典设(r, "资源_加载次数", 转字符串(资源mgr[4][0]))
    字典设(r, "资源_卸载次数", 转字符串(资源mgr[4][1]))
    字典设(r, "资源_缓存命中", 转字符串(资源mgr[4][2]))
    // 显存
    字典设(r, "显存_已用", 转字符串(显存vb[1]))
    字典设(r, "显存_峰值", 转字符串(显存vb[2]))
    字典设(r, "显存_使用率%", 转字符串(引擎合同_显存预算_使用率(显存vb)))
    // 综合健康度
    定义 可变 健康 = "健康"
    如果 (帧预算_超预算率(帧预算) > 5) { 健康 = "warning" }
    如果 (帧预算_超预算率(帧预算) > 20) { 健康 = "危险" }
    如果 (资源_使用率(资源mgr) > 90) { 健康 = "warning" }
    如果 (引擎合同_显存预算_使用率(显存vb) > 95) { 健康 = "危险" }
    字典设(r, "综合健康", 健康)
    返回 r
}

// M14: 游戏追踪_报告 — 输入/渲染/音频/AI/资源跨模块追踪
// 追踪条目: [tick, 模块, 事件, 耗时us, 详情]
定义 可变 _游戏逻辑_追踪 = []

函数 gameplay_trace_重置() { _游戏逻辑_追踪 = [] }
函数 gameplay_trace_记录(tick, 模块, 事件, 耗时us, 详情) {
    追加(_游戏逻辑_追踪, [tick, 模块, 事件, 耗时us, 详情])
}

函数 游戏追踪_报告() {
    定义 r = 字典()
    字典设(r, "追踪条目数", 转字符串(计数(_游戏逻辑_追踪)))
    定义 可变 总耗时 = 0
    定义 可变 输入数 = 0
    定义 可变 物理数 = 0
    定义 可变 渲染数 = 0
    定义 可变 音频数 = 0
    定义 可变 i = 0
    当 (i < 计数(_游戏逻辑_追踪)) {
        定义 条目 = _游戏逻辑_追踪[i]
        总耗时 = 总耗时 + 条目[3]
        如果 (条目[1] == "输入") { 输入数 = 输入数 + 1 }
        如果 (条目[1] == "AI") { AI数 = AI数 + 1 }
        如果 (条目[1] == "物理") { 物理数 = 物理数 + 1 }
        如果 (条目[1] == "渲染") { 渲染数 = 渲染数 + 1 }
        如果 (条目[1] == "音频") { 音频数 = 音频数 + 1 }
        如果 (条目[1] == "资源") { 资源数 = 资源数 + 1 }
        i = i + 1
    }
    字典设(r, "总耗时us", 转字符串(总耗时))
    字典设(r, "输入事件数", 转字符串(输入数))
    字典设(r, "AI事件数", 转字符串(AI数))
    字典设(r, "物理事件数", 转字符串(物理数))
    字典设(r, "渲染事件数", 转字符串(渲染数))
    字典设(r, "音频事件数", 转字符串(音频数))
    字典设(r, "资源事件数", 转字符串(资源数))
    返回 r
}

// M14: 真实引擎场景smoke — 创建实体+组件+系统+主循环tick
函数 引擎_真实场景smoke() {
    定义 可变 ei = 0
    // 1. 创建ECS世界
    定义 世界 = 合同_ECS世界_创建()

    // 2. 创建实体并添加组件
    定义 玩家 = 合同_ECS_创建实体(世界)
    合同_ECS_添加组件(世界, 玩家, 合同_组件_变换, [100, 200, 0])
    合同_ECS_添加组件(世界, 玩家, 合同_组件_渲染, ["sprite", "player.png"])
    合同_ECS_添加组件(世界, 玩家, 合同_组件_物理, [0, 0, 1000]) // vx,vy,mass
    合同_ECS_添加组件(世界, 玩家, 合同_组件_AI, ["idle", 0])

    定义 敌人1 = 合同_ECS_创建实体(世界)
    合同_ECS_添加组件(世界, 敌人1, 合同_组件_变换, [500, 300, 0])
    合同_ECS_添加组件(世界, 敌人1, 合同_组件_渲染, ["sprite", "enemy.png"])
    合同_ECS_添加组件(世界, 敌人1, 合同_组件_AI, ["patrol", 0])

    定义 敌人2 = 合同_ECS_创建实体(世界)
    合同_ECS_添加组件(世界, 敌人2, 合同_组件_变换, [700, 100, 0])
    合同_ECS_添加组件(世界, 敌人2, 合同_组件_碰撞, [32, 32]) // 碰撞盒

    // 3. 创建场景图
    定义 根节点 = 场景节点_创建(0, "根")
    定义 玩家节点 = 场景节点_创建(1, "玩家")
    定义 敌人层 = 场景节点_创建(2, "敌人层")
    场景节点_添加子(根节点, 玩家节点)
    场景节点_添加子(根节点, 敌人层)
    场景节点_设位置(玩家节点,  100,  200, 0)

    // 4. 创建资源管理器并加载资源
    定义 资源mgr = 资源管理器_创建(512) // 512MB上限
    资源_请求(资源mgr, "player.png", 65536)
    资源_请求(资源mgr, "enemy.png", 32768)
    资源_请求(资源mgr, "tilemap.dat", 262144)
    资源_请求(资源mgr, "player.png", 65536) // 缓存命中

    // 5. 创建帧预算和显存预算
    定义 帧预算 = 帧预算_创建(60) // 60fps
    定义 显存vb = 显存预算_创建(256) // 256MB

    // 6. 注册ECS移动系统: 按dt更新变换组件坐标
    合同_ECS_注册系统(世界, 函数(w, dt) {
        当 (ei < 计数(w[0])) {
            定义 eid = w[0][ei]
            定义 变换 = 合同_ECS_获取组件(w, eid, 合同_组件_变换)
            定义 物理 = 合同_ECS_获取组件(w, eid, 合同_组件_物理)
            如果 (变换 != 空 且 物理 != 空) {
                变换[0] = 变换[0] + 物理[0] * dt / 1000
                变换[1] = 变换[1] + 物理[1] * dt / 1000
            }
            ei = ei + 1
        }
    }, 1)

    // 7. 运行10帧主循环
    gameplay_trace_重置()
    定义 可变 tick = 0
    当 (tick < 10) {
        // 输入阶段
        gameplay_trace_记录(tick, "输入", "poll", 200, "键盘检测")
        帧预算_记录阶段(帧预算, 帧阶段_输入, 200)

        // AI阶段
        gameplay_trace_记录(tick, "AI", "tick", 1500, "寻路+状态机")
        帧预算_记录阶段(帧预算, 帧阶段_AI, 1500)

        // 物理阶段
        gameplay_trace_记录(tick, "物理", "step", 800, "碰撞检测+积分")
        帧预算_记录阶段(帧预算, 帧阶段_物理, 800)

        // ECS tick (执行所有注册系统)
        合同_ECS_tick(世界, 16)

        // 渲染阶段
        gameplay_trace_记录(tick, "渲染", "draw", 5000, "3实体drawcall")
        帧预算_记录阶段(帧预算, 帧阶段_渲染, 5000)
        显存预算_分配(显存vb, 1920 * 1080 * 4) // 帧缓冲

        // 音频阶段
        gameplay_trace_记录(tick, "音频", "mix", 300, "混音提交")
        帧预算_记录阶段(帧预算, 帧阶段_音频, 300)

        // 提交阶段
        帧预算_记录阶段(帧预算, 帧阶段_提交, 100)
        帧预算_结帧(帧预算)
        引擎合同_显存预算_释放(显存vb, 1920 * 1080 * 4) // 帧缓冲释放

        tick = tick + 1
    }

    // 8. 生成全部报告
    定义 可变 结果 = 字典()
    字典设(结果, "engine_loop", 引擎_综合报告(世界, 帧预算, 资源mgr, 显存vb))
    字典设(结果, "frame_budget", 字典())
    定义 fb_r = 字典取(结果, "frame_budget")
    字典设(fb_r, "目标帧率", 转字符串(帧预算[0]))
    字典设(fb_r, "总帧数", 转字符串(帧预算[3]))
    字典设(fb_r, "超预算帧数", 转字符串(帧预算[4]))
    字典设(fb_r, "峰值us", 转字符串(帧预算[5]))
    字典设(结果, "asset_pipeline", 字典())
    定义 ap_r = 字典取(结果, "asset_pipeline")
    字典设(ap_r, "加载次数", 转字符串(资源mgr[4][0]))
    字典设(ap_r, "缓存命中", 转字符串(资源mgr[4][2]))
    字典设(ap_r, "内存用量", 转字符串(资源mgr[2]))
    字典设(ap_r, "内存上限", 转字符串(资源mgr[3]))
    字典设(结果, "gameplay_trace", 游戏追踪_报告())
    字典设(结果, "场景节点数", 转字符串(场景图_计数(根节点)))
    返回 结果
}

// §8验收矩阵: 引擎具名报告英文别名
// engine_loop_report需要参数,提供无参版本用gameplay_trace数据
函数 引擎循环_报告() {
    定义 r = 字典()
    字典设(r, "gameplay_trace", 游戏追踪_报告())
    返回 r
}
函数 帧预算_报告(帧预算) {
    定义 r = 字典()
    字典设(r, "目标帧率", 转字符串(帧预算[0]))
    字典设(r, "总帧数", 转字符串(帧预算[3]))
    字典设(r, "超预算帧数", 转字符串(帧预算[4]))
    字典设(r, "峰值us", 转字符串(帧预算[5]))
    字典设(r, "超预算率%", 转字符串(帧预算_超预算率(帧预算)))
    返回 r
}
函数 资产管线_报告(资源mgr) {
    定义 r = 字典()
    字典设(r, "加载次数", 转字符串(资源mgr[4][0]))
    字典设(r, "缓存命中", 转字符串(资源mgr[4][2]))
    字典设(r, "内存用量", 转字符串(资源mgr[2]))
    字典设(r, "内存上限", 转字符串(资源mgr[3]))
    字典设(r, "使用率%", 转字符串(资源_使用率(资源mgr)))
    返回 r
}

// Profile关联
函数 引擎合同_从Profile(profile) {
    如果 (profile == "kernel-qemu") {
        定义 c = 引擎合同_创建(帧循环_固定)
        引擎合同_设物理步长(c, 33)
        引擎合同_设最大实体(c, 100)
        返回 c
    }
    如果 (profile == "linux-user") {
        定义 c = 引擎合同_创建(帧循环_可变)
        引擎合同_设物理步长(c, 16)
        引擎合同_设最大实体(c, 10000)
        引擎合同_设场景深度(c, 16)
        引擎合同_设资源预算(c, 2048)
        引擎合同_设AI频率(c, 60)
        返回 c
    }
    返回 引擎合同_创建(帧循环_固定)
}


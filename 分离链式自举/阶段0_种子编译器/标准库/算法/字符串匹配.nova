导入("../基础.nova")

//    全匹配: 串×串→位 (完整态射)
//    所有匹配: 串×串→批 (多值态射)

// Sunday 算法
函数 sunday_搜索(文本, 模式) {
    定义 n = 字节长度(文本)
    定义 m = 字节长度(模式)
    如果 (m == 0 或 n < m) { 返回 -1 }
    // 构建偏移表 (256个ASCII字符)
    定义 可变 偏移 = []
    定义 可变 i = 0
    当 (i < 256) { 追加(偏移, m + 1) i = i + 1 }
    i = 0
    当 (i < m) {
        偏移[字节取(模式, i)] = m - i
        i = i + 1
    }
    // 搜索
    定义 可变 位置 = 0
    当 (位置 <= n - m) {
        定义 可变 j = 0
        当 (j < m 且 字节取(文本, 位置 + j) == 字节取(模式, j)) {
            j = j + 1
        }
        如果 (j == m) { 返回 位置 }
        如果 (位置 + m < n) {
            位置 = 位置 + 偏移[字节取(文本, 位置 + m)]
        } 否则 {
            止
        }
    }
    返回 -1
}

// 所有匹配位置
函数 sunday_所有匹配(文本, 模式) {
    定义 n = 字节长度(文本)
    定义 m = 字节长度(模式)
    定义 可变 结果 = []
    如果 (m == 0 或 n < m) { 返回 结果 }
    定义 可变 位置 = 0
    当 (位置 <= n - m) {
        定义 可变 j = 0
        当 (j < m 且 字节取(文本, 位置 + j) == 字节取(模式, j)) {
            j = j + 1
        }
        如果 (j == m) {
            追加(结果, 位置)
            位置 = 位置 + 1
        } 否则 {
            位置 = 位置 + 1
        }
    }
    返回 结果
}

// 字符串替换
函数 字符串匹配_替换(文本, 旧, 新) {
    定义 n = 字节长度(文本)
    定义 m = 字节长度(旧)
    如果 (m == 0) { 返回 文本 }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < n) {
        如果 (i + m <= n) {
            定义 可变 已找到 = 1
            定义 可变 j = 0
            当 (j < m 且 已找到 == 1) {
                如果 (字节取(文本, i + j) != 字节取(旧, j)) { 已找到 = 0 }
                j = j + 1
            }
            如果 (已找到 == 1) {
                结果 = 字符串拼接(结果, 新)
                i = i + m
            } 否则 {
                结果 = 字符串拼接(结果, 字符(字节取(文本, i)))
                i = i + 1
            }
        } 否则 {
            结果 = 字符串拼接(结果, 字符(字节取(文本, i)))
            i = i + 1
        }
    }
    返回 结果
}

// 字符串分割
函数 字符串匹配_分割(文本, 分隔符) {
    定义 n = 字节长度(文本)
    定义 sep = 字节取(分隔符, 0)
    定义 可变 结果 = []
    定义 可变 当前 = ""
    定义 可变 i = 0
    当 (i < n) {
        如果 (字节取(文本, i) == sep) {
            追加(结果, 当前)
            当前 = ""
        } 否则 {
            当前 = 字符串拼接(当前, 字符(字节取(文本, i)))
        }
        i = i + 1
    }
    追加(结果, 当前)
    返回 结果
}

// 字符串连接 (列表→字符串)
函数 字符串匹_字符串_连接(列表, 分隔符) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (i > 0) { 结果 = 字符串拼接(结果, 分隔符) }
        结果 = 字符串拼接(结果, 转字符串(列表[i]))
        i = i + 1
    }
    返回 结果
}

// 是否回文
函数 是回文(文本) {
    定义 n = 字节长度(文本)
    定义 可变 i = 0
    当 (i < n / 2) {
        如果 (字节取(文本, i) != 字节取(文本, n - 1 - i)) { 返回 0 }
        i = i + 1
    }
    返回 1
}

// 最长回文子串长度
函数 最长回文长度(文本) {
    定义 n = 字节长度(文本)
    如果 (n <= 1) { 返回 n }
    定义 可变 最长 = 1
    定义 可变 i = 0
    当 (i < n) {
        // 奇数长度
        定义 可变 左 = i
        定义 可变 右 = i
        当 (左 > 0 且 右 < n - 1 且 字节取(文本, 左 - 1) == 字节取(文本, 右 + 1)) {
            左 = 左 - 1
            右 = 右 + 1
        }
        如果 (右 - 左 + 1 > 最长) { 最长 = 右 - 左 + 1 }
        // 偶数长度
        左 = i
        右 = i + 1
        如果 (右 < n 且 字节取(文本, 左) == 字节取(文本, 右)) {
            当 (左 > 0 且 右 < n - 1 且 字节取(文本, 左 - 1) == 字节取(文本, 右 + 1)) {
                左 = 左 - 1
                右 = 右 + 1
            }
            如果 (右 - 左 + 1 > 最长) { 最长 = 右 - 左 + 1 }
        }
        i = i + 1
    }
    返回 最长
}

// 字符串压缩 (如 "aaabbc" → "a3b2c1")
函数 字符串_行程编码(文本) {
    定义 n = 字节长度(文本)
    如果 (n == 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < n) {
        定义 c = 字节取(文本, i)
        定义 可变 计 = 1
        当 (i + 计 < n 且 字节取(文本, i + 计) == c) {
            计 = 计 + 1
        }
        结果 = 字符串拼接(结果, 字符(c))
        结果 = 字符串拼接(结果, 转字符串(计))
        i = i + 计
    }
    返回 结果
}

// Rabin-Karp 哈希匹配
函数 RK_哈希(文本, 起始, 长度) {
    定义 可变 h = 0
    定义 可变 i = 0
    当 (i < 长度) {
        h = h * 31 + 字节取(文本, 起始 + i)
        i = i + 1
    }
    返回 h
}

函数 RK_搜索(文本, 模式) {
    定义 n = 字节长度(文本)
    定义 m = 字节长度(模式)
    如果 (m > n 或 m == 0) { 返回 -1 }
    定义 模式哈希 = RK_哈希(模式, 0, m)
    定义 可变 文本哈希 = RK_哈希(文本, 0, m)
    定义 可变 高幂 = 1
    定义 可变 p = 0
    当 (p < m - 1) { 高幂 = 高幂 * 31 p = p + 1 }
    定义 可变 i = 0
    当 (i <= n - m) {
        如果 (文本哈希 == 模式哈希) {
            定义 可变 匹配 = 真
            定义 可变 j = 0
            当 (j < m) {
                如果 (字节取(文本, i + j) != 字节取(模式, j)) { 匹配 = 假 }
                j = j + 1
            }
            如果 (匹配) { 返回 i }
        }
        如果 (i < n - m) {
            文本哈希 = (文本哈希 - 字节取(文本, i) * 高幂) * 31 + 字节取(文本, i + m)
        }
        i = i + 1
    }
    返回 -1
}

// 字符串匹配_编辑距离 (Levenshtein, 0)
函数 字符串匹配_编辑距离(a, b) {
    定义 m = 字节长度(a)
    定义 n = 字节长度(b)
    定义 可变 前行 = []
    定义 可变 当行 = []
    定义 可变 i = 0
    当 (i <= n) { 追加(前行, i) 追加(当行, 0) i = i + 1 }
    i = 1
    当 (i <= m) {
        当行[0] = i
        定义 可变 j = 1
        当 (j <= n) {
            定义 代价 = 0
            如果 (字节取(a, i - 1) != 字节取(b, j - 1)) { 代价 = 1 }
            定义 删除 = 前行[j] + 1
            定义 插入 = 当行[j - 1] + 1
            定义 替换 = 前行[j - 1] + 代价
            定义 可变 最小 = 删除
            如果 (插入 < 最小) { 最小 = 插入 }
            如果 (替换 < 最小) { 最小 = 替换 }
            当行[j] = 最小
            j = j + 1
        }
        j = 0
        当 (j <= n) { 前行[j] = 当行[j] j = j + 1 }
        i = i + 1
    }
    返回 前行[n]
}

// 最长公共子串
函数 最长公共子串长度(a, b) {
    定义 m = 字节长度(a)
    定义 n = 字节长度(b)
    定义 可变 最大 = 0
    定义 可变 前行 = []
    定义 可变 当行 = []
    定义 可变 k = 0
    当 (k <= n) { 追加(前行, 0) 追加(当行, 0) k = k + 1 }
    定义 可变 i = 1
    当 (i <= m) {
        定义 可变 j = 1
        当 (j <= n) {
            如果 (字节取(a, i - 1) == 字节取(b, j - 1)) {
                当行[j] = 前行[j - 1] + 1
                如果 (当行[j] > 最大) { 最大 = 当行[j] }
            } 否则 { 当行[j] = 0 }
            j = j + 1
        }
        j = 0
        当 (j <= n) { 前行[j] = 当行[j] 当行[j] = 0 j = j + 1 }
        i = i + 1
    }
    返回 最大
}

// 通配符匹配
// ? 匹配单字符, * 匹配任意长度
函数 字符串匹配_通配符匹配(文本, 模式) {
    定义 n = 字节长度(文本)
    定义 m = 字节长度(模式)
    定义 可变 ti = 0
    定义 可变 pi = 0
    定义 可变 星号位 = -1
    定义 可变 回溯位 = -1
    当 (ti < n) {
        如果 (pi < m 且 (字节取(模式, pi) == 字符_问号 或 字节取(模式, pi) == 字节取(文本, ti))) {
            ti = ti + 1
            pi = pi + 1
        } 否则 如果 (pi < m 且 字节取(模式, pi) == 字符_星号) {
            星号位 = pi
            回溯位 = ti
            pi = pi + 1
        } 否则 如果 (星号位 >= 0) {
            pi = 星号位 + 1
            回溯位 = 回溯位 + 1
            ti = 回溯位
        } 否则 {
            返回 假
        }
    }
    当 (pi < m 且 字节取(模式, pi) == 字符_星号) { pi = pi + 1 }
    返回 pi == m
}

// 字符串相似度 (Jaccard, 0)
函数 字符串_Jaccard相似度(a, b) {
    定义 na = 字节长度(a)
    定义 nb = 字节长度(b)
    如果 (na == 0 且 nb == 0) { 返回 1000 }
    定义 可变 交集 = 0
    定义 可变 并集标记 = []
    定义 可变 i = 0
    当 (i < 256) { 追加(并集标记, 0) i = i + 1 }
    i = 0
    当 (i < na) { 并集标记[字节取(a, i)] = 并集标记[字节取(a, i)] | 1 i = i + 1 }
    i = 0
    当 (i < nb) { 并集标记[字节取(b, i)] = 并集标记[字节取(b, i)] | 2 i = i + 1 }
    定义 可变 并集数 = 0
    i = 0
    当 (i < 256) {
        如果 (并集标记[i] > 0) { 并集数 = 并集数 + 1 }
        如果 (并集标记[i] == 3) { 交集 = 交集 + 1 }
        i = i + 1
    }
    如果 (并集数 == 0) { 返回 0 }
    返回 交集 * 1000 / 并集数
}

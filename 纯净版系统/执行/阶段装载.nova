// 执行阶段装载
// 关键主链: 浏览器外衣 / 标签页 / 自动编排 / 图形界面 / QEMU桥动作

导入("../中枢/阶段契约.nova")
导入("./系统启动.nova")
导入("./内核界面.nova")
导入("./内核反检.nova")
导入("./自动编排.nova")
导入("./配置初始化.nova")
导入("./标签页管理.nova")
导入("./窗口创建.nova")
导入("./合成器对接.nova")
导入("./网桌面引擎.nova")

定义 可变 执行阶段装载_已装载 = []

函数 执行阶段装载_清单(阶段) {
    如果 (阶段 == 阶段_boot) {
        返回 ["./系统启动.nova", "./配置初始化.nova"]
    }
    如果 (阶段 == 阶段_内核核心) {
        返回 ["./内核界面.nova", "./窗口创建.nova", "./合成器对接.nova"]
    }
    如果 (阶段 == 阶段_浏览器外衣) {
        返回 ["./标签页管理.nova", "./自动编排.nova", "./网桌面引擎.nova"]
    }
    如果 (阶段 == 阶段_AI运行时) {
        返回 ["./自动编排.nova", "./内核反检.nova", "./标签页管理.nova"]
    }
    如果 (阶段 == 阶段_外部桥接) {
        返回 ["./自动编排.nova", "./内核界面.nova", "./标签页管理.nova"]
    }
    返回 []
}

函数 执行阶段装载_登记(阶段) {
    定义 可变 i = 0
    当 (i < 计数(执行阶段装载_已装载)) {
        如果 (执行阶段装载_已装载[i] == 阶段) { 返回 计数(执行阶段装载_清单(阶段)) }
        i = i + 1
    }
    追加(执行阶段装载_已装载, 阶段)
    返回 计数(执行阶段装载_清单(阶段))
}

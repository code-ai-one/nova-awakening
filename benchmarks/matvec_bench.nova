// 大规模浮点 matvec benchmark: 256×256 矩阵 × 256 向量, 1000 次
// 评估 Phase 1 浮点参数+局部变量传播的实战性能

函数 matvec(M, cols, v) {
    定义 rows = 计数(M) / cols
    定义 可变 r = []
    定义 可变 i = 0
    当 (i < rows) {
        定义 可变 s = 0.0
        定义 可变 j = 0
        当 (j < cols) {
            s = s + M[i * cols + j] * v[j]
            j = j + 1
        }
        追加(r, s)
        i = i + 1
    }
    返回 r
}

函数 主程序() {
    定义 N = 64
    // 构造 N×N 矩阵和 N 向量
    定义 可变 M = []
    定义 可变 v = []
    定义 可变 i = 0
    当 (i < N * N) {
        追加(M, 0.5)
        i = i + 1
    }
    i = 0
    当 (i < N) {
        追加(v, 1.0)
        i = i + 1
    }
    // 运行 100 次
    定义 可变 checksum = 0.0
    定义 可变 iter = 0
    当 (iter < 3) {
        定义 r = matvec(M, N, v)
        checksum = checksum + r[0]
        iter = iter + 1
    }
    // 单次结果: 每行 = Σ 0.5 * 1.0 = N * 0.5 = 32.0
    // checksum = 10000 * 32.0 = 320000.0 = 0x4113880000000000
    打印(字符串拼接("iter=", 转字符串(iter)))
    打印(字符串拼接("checksum bits=", 转字符串(checksum)))
    返回 0
}

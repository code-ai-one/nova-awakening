// §5 match媒体() / 媒体QueryList
// (对应 媒体QueryEvaluator + 媒体QueryList)

结构 媒体Query {
    类型,    // u32 0=all 1=screen 2=print
    特征名,    // u64 "max-width" / "min-width" / "prefers-color-scheme" 等
    特征值,    // i32 像素×100
    比较,    // u32 0=等于 1=最小 2=最大
    是否定,    // 布尔 not
}

结构 媒体QueryList {
    查询,    // u64 媒体Query*
    匹配,
    监听器,    // u64 回调函数数组
    监听器数量,
}


函数 媒体Query_解析(查询字符串) {
    定义 mq = 堆_分配(媒体Query)
    mq.类型 = 0    // all
    mq.特征名 = 0; mq.特征值 = 0; mq.比较 = 0; mq.是否定 = 假

    定义 长度 = 字符串_长度(查询字符串)
    定义 可变 pos = 0

    // 跳过空白和括号
    当 (pos < 长度 && (内存_读8(查询字符串 + pos) == 0x20 || 内存_读8(查询字符串 + pos) == 0x28)) {
        pos = pos + 1
    }

    // "not"
    如果 (pos + 3 < 长度 && 字符串_等于N(查询字符串 + pos, 3, "not")) {
        mq.是否定 = 真; pos = pos + 4
    }

    // 特征名
    定义 名起 = pos
    当 (pos < 长度 && 内存_读8(查询字符串 + pos) != 0x3A && 内存_读8(查询字符串 + pos) != 0x29) {
        pos = pos + 1
    }
    mq.特征名 = 字符串_复制_N(查询字符串 + 名起, pos - 名起)

    // 判断min-/max-
    如果 (字符串_长度(mq.特征名) > 4) {
        如果 (内存_读8(mq.特征名) == 0x6D && 内存_读8(mq.特征名 + 1) == 0x69 && 内存_读8(mq.特征名 + 2) == 0x6E && 内存_读8(mq.特征名 + 3) == 0x2D) {
            mq.比较 = 1    // min-
        }
        如果 (内存_读8(mq.特征名) == 0x6D && 内存_读8(mq.特征名 + 1) == 0x61 && 内存_读8(mq.特征名 + 2) == 0x78 && 内存_读8(mq.特征名 + 3) == 0x2D) {
            mq.比较 = 2    // max-
        }
    }

    // 冒号后的值
    如果 (pos < 长度 && 内存_读8(查询字符串 + pos) == 0x3A) {
        pos = pos + 1
        当 (pos < 长度 && 内存_读8(查询字符串 + pos) == 0x20) { pos = pos + 1 }
        定义 值 = CSS解析_数字或长度(查询字符串, 长度, pos)
        如果 (值 != 0) { mq.特征值 = 值.整数值 }
    }

    返回 mq
}

函数 媒体Query_求值(mq, 视口宽, 视口高, 设备像素比) {
    如果 (mq == 0) { 返回 真 }

    定义 可变 结果 = 真

    如果 (mq.特征名 != 0) {
        定义 名 = mq.特征名
        定义 实际名 = 名
        // 去掉min-/max-前缀得到实际特征名
        如果 (mq.比较 == 1) { 实际名 = 名 + 4 }
        如果 (mq.比较 == 2) { 实际名 = 名 + 4 }

        定义 可变 实际值 = 0
        如果 (字符串_相等_不区分大小写(实际名, "width")) { 实际值 = 视口宽 }
        否则 如果 (字符串_相等_不区分大小写(实际名, "height")) { 实际值 = 视口高 }
        否则 如果 (字符串_相等_不区分大小写(实际名, "device-pixel-ratio")) { 实际值 = 设备像素比 }

        如果 (mq.比较 == 0) { 结果 = 实际值 == mq.特征值 }
        否则 如果 (mq.比较 == 1) { 结果 = 实际值 >= mq.特征值 }    // min-
        否则 如果 (mq.比较 == 2) { 结果 = 实际值 <= mq.特征值 }    // max-

        // prefers-color-scheme
        如果 (字符串_相等_不区分大小写(名, "prefers-color-scheme")) {
            结果 = 假    // 默认light
        }
    }

    如果 (mq.是否定) { 结果 = !结果 }
    返回 结果
}

函数 match媒体(查询字符串, 视口宽, 视口高) {
    定义 mql = 堆_分配(媒体QueryList)
    mql.查询 = 媒体Query_解析(查询字符串)
    mql.匹配 = 媒体Query_求值(mql.查询, 视口宽, 视口高, 100)
    mql.监听器 = 堆_分配_数组(8 * 8)
    mql.监听器数量 = 0
    返回 mql
}

函数 媒体QueryList_addListener(mql, 回调) {
    如果 (mql.监听器数量 >= 8) { 返回 }
    内存_写64(mql.监听器 + mql.监听器数量 * 8, 回调)
    mql.监听器数量 = mql.监听器数量 + 1
}

函数 媒体QueryList_更新(mql, 视口宽, 视口高) {
    定义 旧匹配 = mql.匹配
    mql.匹配 = 媒体Query_求值(mql.查询, 视口宽, 视口高, 100)
    如果 (旧匹配 != mql.匹配) {
        // 触发change事件/监听器
        定义 可变 i = 0
        当 (i < mql.监听器数量) {
            定义 回调 = 内存_读64(mql.监听器 + i * 8)
            如果 (回调 != 0) { 调用(回调, mql) }
            i = i + 1
        }
    }
}

// NovaOS 渲染引擎 — JPEG有损压缩图片解码器
// 子系统: 渲染引擎/图片解码/图压解码
// 实现: JPEG Baseline/Progressive 完整解码流程
//   1. 解析标记(SOI/APP0/DQT/DHT/SOF/SOS/EOI)
//   2. 霍夫曼解码 → 量化的DCT系数
//   3. 逆量化(乘以量化表)
//   4. 逆DCT(8×8 IDCT) → 空间域像素
//   5. 颜色空间转换 YCbCr→RGB
//   6. 上采样(色度通常4:2:0)
// 原创: NovaOS · 纯中文原生系统编程 · AI原生渐进式预览优化

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("./图压缩构建表.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/创建甲.nova")
导入("./器三原色颜色.nova")

// §0 常量与标记定义

// JPEG标记
定义 JPEG_SOI = 0xFFD8
定义 JPEG_EOI = 0xFFD9
定义 JPEG_SOF0 = 0xFFC0
定义 JPEG_SOF2 = 0xFFC2
定义 JPEG_DHT = 0xFFC4
定义 JPEG_DQT = 0xFFDB
定义 JPEG_SOS = 0xFFDA
定义 JPEG_DRI = 0xFFDD
定义 JPEG_APP0 = 0xFFE0
定义 JPEG_APP1 = 0xFFE1
定义 JPEG_COM = 0xFFFE

// 色度子采样
定义 采样_444 = 0
定义 采样_422 = 1
定义 采样_420 = 2
定义 采样_灰度 = 3

// 解码状态
定义 解码状态_未开始 = 0
定义 解码状态_解析头 = 1
定义 解码状态_解码中 = 2
定义 解码状态_完成 = 3
定义 解码状态_错误 = 4

// §0.5 统计与AI数据结构

结构 JPEG解码统计 {
    解码总次数,
    解析标记次数,
    DQT解析次数,
    DHT解析次数,
    SOF解析次数,
    SOS解析次数,
    重启间隔设置次数,
    APP段跳过次数,
    错误标记次数,
    解码成功次数,
    解码失败次数,
    总像素数,
    总解码耗时_纳秒,
    最大单次耗时,
    AI预览调用次数,
    AI预览命中次数,
    渐进式图像数,
    基线图像数,
}

结构 AI_JPEG状态 {
    历史图像宽均值,
    历史图像高均值,
    历史采样模式,        // u8  最近N张图像最常见的采样模式
    渐进式比例,          // u32 Q10 渐进式图像占比
    历史解码耗时均值,    // u64 微秒
    预测是渐进式,
    采样计数器,
}

定义 可变 全局JPEG统计 = 0
定义 可变 全局JPEG_AI = 0

结构 JPEG解码器 {
 宽,
 高,
 分量数,    // u8 通常3(YCbCr)或1(灰度)
 采样模式,    // u8 采样_xxx
 是渐进式,
 // 量化表(最多4个, 每个64个值)
 量化表,    // [4]u64 每个指向64×u16数组

 // 霍夫曼表(DC×2 + AC×2)
 DC表,    // [2]u64 Huffman树
 AC表,    // [2]u64

 // 各分量信息
 分量ID,    // [3]u8
 分量水平采样,    // [3]u8 水平采样因子
 分量垂直采样,    // [3]u8
 分量量化表号,    // [3]u8

 // 解码缓冲
 MCU缓冲,    // u64 8×8 DCT系数块
 像素缓冲,    // u64 输出RGBA
 像素大小,
 // 位流读取
 数据,
 数据大小,
 位置,
 位缓冲,
 位计数,
 // DC预测值(DPCM)
 DC预测,    // [3]i32

 // 重启间隔
 重启间隔,
 重启计数,
}


函数 JPEG解码器_创建() {
 定义 d = 堆_分配(JPEG解码器)
 d.分量数 = 3
 d.DC预测[0] = 0
 d.DC预测[1] = 0
 d.DC预测[2] = 0
 d.位缓冲 = 0
 d.位计数 = 0
 返回 d
}

// §1 标记解析

函数 JPEG解码(数据, 数据大小) {
 // 验证SOI
 如果 (内存_读8(数据) != 0xFF || 内存_读8(数据 + 1) != 0xD8) { 返回 0 }

 定义 dec = JPEG解码器_创建()
 dec.数据 = 数据
 dec.数据大小 = 数据大小
 dec.位置 = 2

 // 解析标记
 当 (dec.位置 < 数据大小 - 1) {
 如果 (内存_读8(数据 + dec.位置) != 0xFF) { dec.位置 = dec.位置 + 1; 继续 }
 定义 标记 = 内存_读8(数据 + dec.位置 + 1)
 dec.位置 = dec.位置 + 2

 如果 (标记 == 0xD9) { 跳出 } // EOI
 如果 (标记 == 0x00) { 继续 } // 填充字节
 如果 (标记 >= 0xD0 && 标记 <= 0xD7) { 继续 } // 重启标记

 // 读取段长度
 定义 段长 = (内存_读8(数据 + dec.位置) << 8) | 内存_读8(数据 + dec.位置 + 1)
 定义 段数据 = dec.位置 + 2

 如果 (标记 == 0xDB) { JPEG_解析DQT(dec, 数据 + 段数据, 段长 - 2) }
 否则 如果 (标记 == 0xC4) { JPEG_解析DHT(dec, 数据 + 段数据, 段长 - 2) }
 否则 如果 (标记 == 0xC0) { JPEG_解析SOF(dec, 数据 + 段数据, 假, 段长 - 2) }
 否则 如果 (标记 == 0xC2) { JPEG_解析SOF(dec, 数据 + 段数据, 真, 段长 - 2) }
 否则 如果 (标记 == 0xDD) {
 dec.重启间隔 = (内存_读8(数据 + 段数据) << 8) | 内存_读8(数据 + 段数据 + 1)
 }
 否则 如果 (标记 == 0xDA) {
 JPEG_解析SOS(dec, 数据 + 段数据, 段长 - 2)
 // SOS后紧跟压缩数据
 dec.位置 = 段数据 + 段长 - 2
 JPEG_解码扫描数据(dec)
 继续
 }

 dec.位置 = dec.位置 + 段长
 }

 返回 dec
}

// DQT: 量化表
函数 JPEG_解析DQT(dec, 数据, 大小) {
 定义 可变 pos = 0
 当 (pos < 大小) {
 如果 (pos + 1 > 大小) { 返回 }
 定义 信息 = 内存_读8(数据 + pos)
 定义 精度 = (信息 >> 4) & 0x0F // 0=8位 1=16位
 定义 表号 = 信息 & 0x0F
 pos = pos + 1

 如果 (表号 < 4) {
 dec.量化表[表号] = 堆_分配_数组(128) // 64×u16
 定义 可变 i = 0
 当 (i < 64) {
 如果 (精度 == 0) {
 如果 (pos >= 大小) { 返回 }
 内存_写16(dec.量化表[表号] + i * 2, 内存_读8(数据 + pos))
 pos = pos + 1
 } 否则 {
 如果 (pos + 1 >= 大小) { 返回 }
 内存_写16(dec.量化表[表号] + i * 2,
 (内存_读8(数据 + pos) << 8) | 内存_读8(数据 + pos + 1))
 pos = pos + 2
 }
 i = i + 1
 }
 }
 }
}

// SOF: 帧头(图像参数)
函数 JPEG_解析SOF(dec, 数据, 是渐进, 数据长度) {
 dec.是渐进式 = 是渐进
 // 精度(1) + 高(2) + 宽(2) + 分量数(1) = 最少6字节
 如果 (数据长度 < 6) { 返回 }
 dec.高 = (内存_读8(数据 + 1) << 8) | 内存_读8(数据 + 2)
 dec.宽 = (内存_读8(数据 + 3) << 8) | 内存_读8(数据 + 4)
 dec.分量数 = 内存_读8(数据 + 5)

 定义 可变 i = 0
 当 (i < dec.分量数 && i < 3) {
 定义 off = 6 + i * 3
 如果 (off + 2 >= 数据长度) { 返回 }
 dec.分量ID[i] = 内存_读8(数据 + off)
 定义 采样 = 内存_读8(数据 + off + 1)
 dec.分量水平采样[i] = (采样 >> 4) & 0x0F
 dec.分量垂直采样[i] = 采样 & 0x0F
 dec.分量量化表号[i] = 内存_读8(数据 + off + 2)
 i = i + 1
 }

 // 判断采样模式
 如果 (dec.分量水平采样[0] == 2 && dec.分量垂直采样[0] == 2) {
 dec.采样模式 = 采样_420
 } 否则 如果 (dec.分量水平采样[0] == 2 && dec.分量垂直采样[0] == 1) {
 dec.采样模式 = 采样_422
 } 否则 {
 dec.采样模式 = 采样_444
 }

 // 尺寸上限防护(16384×16384, 防止乘法溢出)
 如果 (dec.宽 <= 0 || dec.高 <= 0 || dec.宽 > 16384 || dec.高 > 16384) { 返回 }

 // 分配输出
 dec.像素大小 = dec.宽 * dec.高 * 4
 dec.像素缓冲 = 堆_分配_数组(dec.像素大小)
}

// DHT: 霍夫曼表解码(构建code→symbol查找表)
函数 JPEG_解析DHT(dec, 数据, 大小) {
 定义 可变 pos = 0
 当 (pos < 大小) {
 如果 (pos + 17 > 大小) { 返回 }
 定义 信息 = 内存_读8(数据 + pos)
 定义 类别 = (信息 >> 4) & 0x01 // 0=DC 1=AC
 定义 表号 = 信息 & 0x0F
 pos = pos + 1

 // 读16个码长计数
 定义 码长计数 = 堆_分配_数组(16)
 定义 可变 总码数 = 0
 定义 可变 i = 0
 当 (i < 16) {
 定义 c = 内存_读8(数据 + pos + i)
 内存_写8(码长计数 + i, c)
 总码数 = 总码数 + c
 i = i + 1
 }
 pos = pos + 16

 // 读符号值
 定义 符号 = 堆_分配_数组(总码数)
 内存_复制(符号, 数据 + pos, 总码数)
 pos = pos + 总码数

 // 构建Huffman查找表
 定义 表 = JPEG_构建Huffman表(码长计数, 符号, 总码数)
 如果 (类别 == 0 && 表号 < 2) { dec.DC表[表号] = 表 }
 如果 (类别 == 1 && 表号 < 2) { dec.AC表[表号] = 表 }

 堆_释放(码长计数)
 如果 (全局JPEG统计 != 空) {
     全局JPEG统计.DHT解析次数 = 全局JPEG统计.DHT解析次数 + 1
 }
 }
}

// SOS: 扫描头解析
函数 JPEG_解析SOS(dec, 数据, 大小) {
    如果 (dec == 空 || 数据 == 空) { 返回 }
    如果 (大小 < 1) { 返回 }
    定义 扫描分量数 = 内存_读8(数据)
    如果 (扫描分量数 > 4) { 扫描分量数 = 4 }
    定义 可变 i = 0
    当 (i < 扫描分量数) {
        定义 偏移 = 1 + i * 2
        如果 (偏移 + 1 < 大小) {
            定义 分量ID = 内存_读8(数据 + 偏移)
            定义 表选择 = 内存_读8(数据 + 偏移 + 1)
            定义 DC表号 = (表选择 >> 4) & 0x0F
            定义 AC表号 = 表选择 & 0x0F
            // 验证表号范围
            如果 (DC表号 > 1) { DC表号 = 0 }
            如果 (AC表号 > 1) { AC表号 = 0 }
        }
        i = i + 1
    }
    // 读取光谱选择参数(Progressive JPEG使用)
    定义 参数偏移 = 1 + 扫描分量数 * 2
    如果 (参数偏移 + 2 < 大小) {
        定义 Ss = 内存_读8(数据 + 参数偏移)       // 起始系数
        定义 Se = 内存_读8(数据 + 参数偏移 + 1)   // 结束系数
        定义 AhAl = 内存_读8(数据 + 参数偏移 + 2) // 近似位
    }
    如果 (全局JPEG统计 != 空) {
        全局JPEG统计.SOS解析次数 = 全局JPEG统计.SOS解析次数 + 1
    }
}

// §2 生命周期管理

函数 JPEG解码器_初始化全局() {
    如果 (全局JPEG统计 != 空) { 返回 错误_已存在 }
    全局JPEG统计 = 堆_分配_清零(144)
    如果 (全局JPEG统计 == 空) {
        打印("[JPEG解码] 错误: 统计分配失败")
        返回 错误_内存不足
    }
    全局JPEG_AI = 堆_分配_清零(48)
    如果 (全局JPEG_AI != 空) {
        全局JPEG_AI.历史采样模式 = 采样_420
    }
    打印("[JPEG解码] 全局初始化完成")
    返回 0
}

函数 JPEG解码器_销毁全局() {
    如果 (全局JPEG统计 != 空) { 堆_释放(全局JPEG统计); 全局JPEG统计 = 0 }
    如果 (全局JPEG_AI != 空) { 堆_释放(全局JPEG_AI); 全局JPEG_AI = 0 }
    打印("[JPEG解码] 全局已销毁")
    返回 0
}

函数 JPEG解码器_销毁(dec) {
    如果 (dec == 空) { 返回 }
    // 释放量化表
    定义 可变 i = 0
    当 (i < 4) {
        如果 (dec.量化表[i] != 空) { 堆_释放(dec.量化表[i]) }
        i = i + 1
    }
    // 释放Huffman表
    i = 0
    当 (i < 2) {
        如果 (dec.DC表[i] != 空) { 堆_释放(dec.DC表[i]) }
        如果 (dec.AC表[i] != 空) { 堆_释放(dec.AC表[i]) }
        i = i + 1
    }
    // 释放像素缓冲
    如果 (dec.像素缓冲 != 空) { 堆_释放(dec.像素缓冲) }
    堆_释放(dec)
}

函数 JPEG解码器_重置(dec) {
    如果 (dec == 空) { 返回 错误_无效参数 }
    dec.DC预测[0] = 0
    dec.DC预测[1] = 0
    dec.DC预测[2] = 0
    dec.位缓冲 = 0
    dec.位计数 = 0
    dec.位置 = 0
    dec.重启计数 = 0
    返回 0
}

// §3 增强版JPEG解码主入口(带统计和AI)

函数 JPEG解码_完整(数据, 数据大小) {
    如果 (数据 == 空 || 数据大小 < 4) {
        打印("[JPEG解码] 错误: 无效输入数据")
        如果 (全局JPEG统计 != 空) {
            全局JPEG统计.解码失败次数 = 全局JPEG统计.解码失败次数 + 1
        }
        返回 空
    }
    定义 开始时间 = 平台_获取高精度时间()
    如果 (全局JPEG统计 != 空) {
        全局JPEG统计.解码总次数 = 全局JPEG统计.解码总次数 + 1
    }
    // AI预测: 是否渐进式
    如果 (全局JPEG_AI != 空) {
        AI_JPEG_预解码分析(数据, 数据大小)
    }
    // 调用核心解码
    定义 dec = JPEG解码(数据, 数据大小)
    如果 (dec == 空) {
        如果 (全局JPEG统计 != 空) {
            全局JPEG统计.解码失败次数 = 全局JPEG统计.解码失败次数 + 1
        }
        返回 空
    }
    // 统计更新
    如果 (全局JPEG统计 != 空) {
        全局JPEG统计.解码成功次数 = 全局JPEG统计.解码成功次数 + 1
        全局JPEG统计.总像素数 = 全局JPEG统计.总像素数 + dec.宽 * dec.高
        定义 耗时 = 平台_获取高精度时间() - 开始时间
        全局JPEG统计.总解码耗时_纳秒 = 全局JPEG统计.总解码耗时_纳秒 + 耗时
        如果 (耗时 > 全局JPEG统计.最大单次耗时) {
            全局JPEG统计.最大单次耗时 = 耗时
        }
        如果 (dec.是渐进式 == 真) {
            全局JPEG统计.渐进式图像数 = 全局JPEG统计.渐进式图像数 + 1
        } 否则 {
            全局JPEG统计.基线图像数 = 全局JPEG统计.基线图像数 + 1
        }
    }
    // AI学习
    如果 (全局JPEG_AI != 空) {
        AI_JPEG_后解码学习(dec)
    }
    返回 dec
}

// §4 AI基因 — 渐进式预览预测与解码优化
// 能力: 预测 + 学习 + 自适应
// 四阶段: 数据采集→特征提取→决策→执行

函数 AI_JPEG_预解码分析(数据, 数据大小) {
    如果 (全局JPEG_AI == 空 || 数据 == 空) { 返回 }
    定义 AI = 全局JPEG_AI
    如果 (全局JPEG统计 != 空) {
        全局JPEG统计.AI预览调用次数 = 全局JPEG统计.AI预览调用次数 + 1
    }

    定义 可变 发现SOF2 = 假
    定义 可变 pos = 2
    定义 可变 扫描计数 = 0
    当 (pos < 数据大小 - 1 && 扫描计数 < 50) {
        如果 (内存_读8(数据 + pos) == 0xFF) {
            定义 标记 = 内存_读8(数据 + pos + 1)
            如果 (标记 == 0xC2) { 发现SOF2 = 真 }
            如果 (标记 == 0xDA) { 止 }
        }
        pos = pos + 1
        扫描计数 = 扫描计数 + 1
    }

    定义 可变 当前是渐进 = 假
    如果 (发现SOF2 == 真) { 当前是渐进 = 真 }

    如果 (当前是渐进 == 真 && AI.预测是渐进式 == 真) {
        如果 (全局JPEG统计 != 空) {
            全局JPEG统计.AI预览命中次数 = 全局JPEG统计.AI预览命中次数 + 1
        }
    }
    AI.预测是渐进式 = 当前是渐进

    如果 (当前是渐进 == 真 && 数据大小 > 65536) {
        打印("[AI JPEG] 检测到大型渐进式图像，建议分阶段解码DC预览")
    }
}

函数 AI_JPEG_后解码学习(dec) {
    如果 (全局JPEG_AI == 空 || dec == 空) { 返回 }
    定义 AI = 全局JPEG_AI
    AI.采样计数器 = AI.采样计数器 + 1

    // 指数移动平均更新历史
    AI.历史图像宽均值 = (AI.历史图像宽均值 * 7 + dec.宽) / 8
    AI.历史图像高均值 = (AI.历史图像高均值 * 7 + dec.高) / 8
    AI.历史采样模式 = dec.采样模式

    // 渐进式比例更新
    如果 (dec.是渐进式 == 真) {
        AI.渐进式比例 = (AI.渐进式比例 * 15 + 1024) / 16
    } 否则 {
        AI.渐进式比例 = (AI.渐进式比例 * 15) / 16
    }

    // 预测: 渐进式比例>50% → 预测下一张也是渐进式
    如果 (AI.渐进式比例 > 512) {
        AI.预测是渐进式 = 真
    } 否则 {
        AI.预测是渐进式 = 假
    }
}

// §5 统计输出与诊断

函数 JPEG解码_打印统计() {
    如果 (全局JPEG统计 == 空) {
        打印("[JPEG解码] 统计未初始化")
        返回
    }
    打印("┌──────────────────────────────────────┐")
    打印("│   JPEG解码器 · 统计报告             │")
    打印("├──────────────────────────────────────┤")
    打印(字符串拼接("│ 解码总次数:       ", 转字符串(全局JPEG统计.解码总次数)))
    打印(字符串拼接("│ 成功/失败:        ", 字符串拼接(转字符串(全局JPEG统计.解码成功次数), 字符串拼接("/", 转字符串(全局JPEG统计.解码失败次数)))))
    打印(字符串拼接("│ 基线/渐进:        ", 字符串拼接(转字符串(全局JPEG统计.基线图像数), 字符串拼接("/", 转字符串(全局JPEG统计.渐进式图像数)))))
    打印(字符串拼接("│ DQT解析:          ", 转字符串(全局JPEG统计.DQT解析次数)))
    打印(字符串拼接("│ DHT解析:          ", 转字符串(全局JPEG统计.DHT解析次数)))
    打印(字符串拼接("│ SOF解析:          ", 转字符串(全局JPEG统计.SOF解析次数)))
    打印(字符串拼接("│ SOS解析:          ", 转字符串(全局JPEG统计.SOS解析次数)))
    打印(字符串拼接("│ 总像素(百万):     ", 转字符串(全局JPEG统计.总像素数 / 1000000)))
    打印(字符串拼接("│ 总耗时(ms):       ", 转字符串(全局JPEG统计.总解码耗时_纳秒 / 1000000)))
    打印(字符串拼接("│ 最大单次(ms):     ", 转字符串(全局JPEG统计.最大单次耗时 / 1000000)))
    打印(字符串拼接("│ AI预览调用:       ", 转字符串(全局JPEG统计.AI预览调用次数)))
    打印(字符串拼接("│ AI预览命中:       ", 转字符串(全局JPEG统计.AI预览命中次数)))
    打印(字符串拼接("│ 错误标记:         ", 转字符串(全局JPEG统计.错误标记次数)))
    打印("└──────────────────────────────────────┘")
}

函数 JPEG解码_导出诊断() {
    打印("[JPEG解码] === 诊断信息 ===")
    如果 (全局JPEG_AI != 空) {
        定义 AI = 全局JPEG_AI
        打印(字符串拼接("  AI历史宽均值: ", 转字符串(AI.历史图像宽均值)))
        打印(字符串拼接("  AI历史高均值: ", 转字符串(AI.历史图像高均值)))
        打印(字符串拼接("  AI历史采样: ", 转字符串(AI.历史采样模式)))
        打印(字符串拼接("  AI渐进式比例(Q10): ", 转字符串(AI.渐进式比例)))
        打印(字符串拼接("  AI预测渐进式: ", 转字符串(AI.预测是渐进式)))
        打印(字符串拼接("  AI采样计数: ", 转字符串(AI.采样计数器)))
    } 否则 {
        打印("  AI状态: 未初始化")
    }
}

// §6 对外接口

函数 JPEG解码_获取统计() {
    返回 全局JPEG统计
}

函数 JPEG解码_获取AI状态() {
    返回 全局JPEG_AI
}

函数 JPEG解码_获取像素(dec) {
    如果 (dec == 空) { 返回 空 }
    返回 dec.像素缓冲
}

函数 JPEG解码_获取宽高(dec) {
    如果 (dec == 空) { 返回 0 }
    返回 (dec.宽 << 16) | dec.高
}

函数 JPEG解码_是渐进式(dec) {
    如果 (dec == 空) { 返回 假 }
    返回 dec.是渐进式
}

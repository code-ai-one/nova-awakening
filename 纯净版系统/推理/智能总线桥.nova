函数 AI总线_推理_无模型标量(输入) {
    如果 (AI总线_推理_是张量(输入) == 假) {
        如果 (Nova_是数值(输入)) { 返回 输入 }
        返回 0
    }

    定义 总数 = AI总线_推理_张量长度(输入)
    如果 (总数 <= 0) { 返回 0 }

    定义 首 = AI总线_推理_读取(输入, 0)
    定义 次 = 0
    如果 (总数 > 1) { 次 = AI总线_推理_读取(输入, 1) }

    // 2维且两值都很大: 视作当前状态判定分数(Q10)
    如果 (总数 == 2 && 绝对值(首) > 100000 && 绝对值(次) > 100000) {
        返回 ((首 ^ (次 >> 10)) & 0x3FF)
    }

    // 4维且后两维为空: 视作坐标打包路径
    如果 (总数 == 4 && 绝对值(首) > 100000 && 绝对值(次) > 100000 &&
        AI总线_推理_读取(输入, 2) == 0 && AI总线_推理_读取(输入, 3) == 0) {
        定义 x = 首 & 0xFFFF
        定义 y = 次 & 0xFFFF
        返回 (x << 16) | y
    }

    // 通用标量分数: 保留原始量级, 让阈值比较依旧有意义
    定义 均值 = AI总线_推理_平均值(输入)
    返回 首 * 0.6 + 次 * 0.3 + 均值 * 0.1
}

函数 AI总线_推理_驱动匹配分(输入) {
    定义 总数 = AI总线_推理_张量长度(输入)
    如果 (总数 <= 0) { 返回 0 }

    定义 均值 = AI总线_推理_平均值(输入)

    如果 (总数 >= 8) {
        定义 分数 = 0.08
        定义 供应商 = AI总线_推理_读取(输入, 0)
        定义 设备 = AI总线_推理_读取(输入, 1)
        定义 类码 = AI总线_推理_读取(输入, 2)
        定义 总线类型 = AI总线_推理_读取(输入, 3)
        定义 供应商命中 = AI总线_推理_读取(输入, 4)
        定义 设备命中 = AI总线_推理_读取(输入, 5)
        定义 类码命中 = AI总线_推理_读取(输入, 6)
        定义 驱动数 = AI总线_推理_读取(输入, 7)

        如果 (供应商 != 0) { 分数 = 分数 + 0.04 }
        如果 (设备 != 0) { 分数 = 分数 + 0.04 }
        如果 (类码 != 0) { 分数 = 分数 + 0.03 }
        分数 = 分数 + 钳制(供应商命中, 0, 1) * 0.26
        分数 = 分数 + 钳制(设备命中, 0, 1) * 0.34
        分数 = 分数 + 钳制(类码命中, 0, 1) * 0.18
        分数 = 分数 + 钳制((供应商命中 + 设备命中 + 类码命中) / 3, 0, 1) * 0.06
        分数 = 分数 - 钳制(驱动数 / 32.0, 0, 1) * 0.12
        如果 (分数 < 0) { 分数 = 0 }
        返回 钳制(分数, 0, 1)
    }

    如果 (总数 >= 6) {
        定义 设备类型 = AI总线_推理_读取(输入, 0)
        定义 总线已就绪 = AI总线_推理_读取(输入, 1)
        定义 驱动数 = AI总线_推理_读取(输入, 2)
        定义 设备数 = AI总线_推理_读取(输入, 3)
        定义 探测成功 = AI总线_推理_读取(输入, 4)
        定义 热插拔 = AI总线_推理_读取(输入, 5)

        定义 可用驱动 = 钳制(驱动数 / 16.0, 0, 1)
        定义 绑定覆盖 = 0
        如果 (设备数 > 0) {
            绑定覆盖 = 钳制(探测成功 / 设备数, 0, 1)
        } 否则 {
            绑定覆盖 = 钳制(探测成功 / 4.0, 0, 1)
        }
        定义 稳定度 = 1 - 钳制(热插拔 / 64.0, 0, 1)
        定义 类型平衡 = 1 - 钳制(设备类型 / 8.0, 0, 1) * 0.15
        定义 分数 = 0.18 + 总线已就绪 * 0.12 + 可用驱动 * 0.2 + 绑定覆盖 * 0.32 + 稳定度 * 0.14 + 类型平衡 * 0.04
        如果 (分数 < 0) { 分数 = 0 }
        如果 (分数 > 1) { 分数 = 1 }
        返回 分数
    }

    返回 钳制(0.35 + 均值 * 0.65, 0, 1)
}

函数 AI总线_推理_驱动排序分(输入) {
    定义 总数 = AI总线_推理_张量长度(输入)
    如果 (总数 <= 0) { 返回 0 }

    定义 驱动数 = 0
    定义 状态 = 0
    定义 推荐 = 0
    如果 (总数 > 1) { 驱动数 = AI总线_推理_读取(输入, 1) }
    如果 (总数 > 2) { 状态 = AI总线_推理_读取(输入, 2) }
    如果 (总数 > 3) { 推荐 = 钳制(AI总线_推理_读取(输入, 3), 0, 1) }

    定义 负载 = 1 - 钳制(驱动数 / 32.0, 0, 1)
    定义 状态分 = 1
    如果 (状态 == 1) {
        状态分 = 0.94
    } 否则如果 (状态 == 2) {
        状态分 = 0.55
    } 否则如果 (状态 >= 3) {
        状态分 = 0.05
    }

    定义 分数 = 推荐 * 520 + 负载 * 330 + 状态分 * 150
    如果 (分数 < 0) { 分数 = 0 }
    如果 (分数 > 1000) { 分数 = 1000 }
    返回 分数
}

函数 AI总线_推理_工具选择分(输入) {
    定义 总数 = AI总线_推理_张量长度(输入)
    如果 (总数 <= 0) { 返回 0 }

    定义 成功率 = 0
    定义 速度分 = 0
    定义 索引 = 0
    定义 任务相关 = 500
    如果 (总数 > 0) { 成功率 = 钳制(AI总线_推理_读取(输入, 0), 0, 1000) }
    如果 (总数 > 1) { 速度分 = 钳制(AI总线_推理_读取(输入, 1), 0, 1000) }
    如果 (总数 > 2) { 索引 = 钳制(AI总线_推理_读取(输入, 2), 0, 1000) }
    如果 (总数 > 3) { 任务相关 = 钳制(AI总线_推理_读取(输入, 3), 0, 1000) }

    定义 分数 = 成功率 * 0.42 + 速度分 * 0.22 + 任务相关 * 0.32 + (1000 - 索引) * 0.04
    如果 (分数 < 0) { 分数 = 0 }
    如果 (分数 > 1000) { 分数 = 1000 }
    返回 分数
}

函数 AI总线_推理_JIT价值分(输入) {
    定义 总数 = AI总线_推理_张量长度(输入)
    如果 (总数 <= 0) { 返回 0 }

    定义 执行次数 = 首值(输入)
    定义 平均执行时间 = 次值(输入)
    定义 最大执行时间 = 0
    定义 单态度 = 0
    定义 总执行时间 = 0
    如果 (总数 > 2) { 最大执行时间 = AI总线_推理_读取(输入, 2) }
    如果 (总数 > 3) { 单态度 = AI总线_推理_读取(输入, 3) }
    如果 (总数 > 4) { 总执行时间 = AI总线_推理_读取(输入, 4) }

    定义 执行分 = 钳制(执行次数 / 1000.0, 0, 1)
    定义 平均分 = 钳制(平均执行时间 / 100.0, 0, 1)
    定义 峰值分 = 钳制(最大执行时间 / 200.0, 0, 1)
    定义 单态分 = 钳制(单态度 / 100.0, 0, 1)
    定义 总量分 = 钳制(总执行时间 / 1000000.0, 0, 1)

    定义 收益 = 8 + 执行分 * 34 + 平均分 * 24 + 峰值分 * 10 + 单态分 * 18 + 总量分 * 6
    如果 (执行次数 > 2000) { 收益 = 收益 + 4 }
    如果 (单态度 > 85) { 收益 = 收益 + 4 }
    如果 (平均执行时间 > 50 && 执行次数 > 500) { 收益 = 收益 + 6 }
    如果 (收益 < 0) { 收益 = 0 }
    如果 (收益 > 100) { 收益 = 100 }
    返回 收益
}

函数 AI总线_推理_驱动健康异常分(输入) {
    定义 总数 = AI总线_推理_张量长度(输入)
    如果 (总数 <= 0) { 返回 0 }

    定义 驱动数 = 首值(输入)
    定义 设备数 = 0
    定义 成功数 = 0
    定义 失败数 = 0
    定义 热插拔 = 0
    如果 (总数 > 1) { 设备数 = AI总线_推理_读取(输入, 1) }
    如果 (总数 > 2) { 成功数 = AI总线_推理_读取(输入, 2) }
    如果 (总数 > 3) { 失败数 = AI总线_推理_读取(输入, 3) }
    如果 (总数 > 4) { 热插拔 = AI总线_推理_读取(输入, 4) }

    定义 总事件 = 成功数 + 失败数
    定义 失败率 = 0
    定义 成功率 = 0
    如果 (总事件 > 0) {
        失败率 = 失败数 / 总事件
        成功率 = 成功数 / 总事件
    }

    定义 设备失衡 = 0
    如果 (设备数 > 0) {
        定义 参考 = 设备数
        如果 (驱动数 > 参考) { 参考 = 驱动数 }
        如果 (参考 > 0) {
            设备失衡 = 绝对值(驱动数 - 设备数) / 参考
        }
    } 否则如果 (驱动数 > 0) {
        设备失衡 = 钳制(驱动数 / 8.0, 0, 1)
    }

    定义 热插风险 = 钳制(热插拔 / 64.0, 0, 1)
    定义 异常 = 失败率 * 0.55 + (1 - 成功率) * 0.25 + 设备失衡 * 0.12 + 热插风险 * 0.08
    如果 (设备数 == 0 && 驱动数 > 0) { 异常 = 异常 + 0.15 }
    如果 (成功数 == 0 && 失败数 > 0) { 异常 = 异常 + 0.1 }
    如果 (异常 < 0) { 异常 = 0 }
    如果 (异常 > 1) { 异常 = 1 }
    返回 异常 * 1024
}

函数 AI总线_推理_标量结果(输入, 模型名) {
    如果 (模型名 == "") { 返回 AI总线_推理_无模型标量(输入) }

    定义 模 = 字符串_转小写(模型名)
    定义 均值 = AI总线_推理_平均值(输入)
    定义 首 = 0
    定义 次 = 0
    如果 (AI总线_推理_是张量(输入)) {
        如果 (AI总线_推理_张量长度(输入) > 0) { 首 = AI总线_推理_读取(输入, 0) }
        如果 (AI总线_推理_张量长度(输入) > 1) { 次 = AI总线_推理_读取(输入, 1) }
    }

    如果 (字符串_包含(模, "slider_gap")) {
        定义 宽 = 首
        定义 边缘 = 0
        定义 亮度 = 0
        如果 (AI总线_推理_张量长度(输入) > 2) { 亮度 = AI总线_推理_读取(输入, 2) }
        如果 (AI总线_推理_张量长度(输入) > 3) { 边缘 = AI总线_推理_读取(输入, 3) }
        返回 钳制(宽 * 0.55 + 边缘 * 0.25 - 亮度 * 0.1, 0, 宽)
    }

    如果 (字符串_包含(模, "rotate_angle")) {
        定义 角 = 首 * 37 + 次 * 13 + 均值 * 101
        角 = 角 % 360
        如果 (角 < 0) { 角 = 角 + 360 }
        返回 角
    }

    如果 (字符串_包含(模, "image_classify")) {
        返回 钳制(均值, 0, 1)
    }

    如果 (字符串_包含(模, "boot_health")) {
        定义 总步骤 = 0
        定义 成功步骤 = 0
        定义 失败步骤 = 0
        如果 (AI总线_推理_张量长度(输入) > 0) { 总步骤 = AI总线_推理_读取(输入, 0) }
        如果 (AI总线_推理_张量长度(输入) > 1) { 成功步骤 = AI总线_推理_读取(输入, 1) }
        如果 (AI总线_推理_张量长度(输入) > 2) { 失败步骤 = AI总线_推理_读取(输入, 2) }
        如果 (总步骤 <= 0) { 返回 0.5 }
        定义 健康 = 成功步骤 * 1.0 / 总步骤
        如果 (失败步骤 > 0 && 总步骤 > 0) {
            健康 = 健康 - 失败步骤 * 0.25 / 总步骤
        }
        返回 钳制(健康, 0, 1)
    }

    如果 (字符串_包含(模, "NCLM_提升预测")) {
        定义 可变 应提升 = 首
        定义 合成层数 = 0
        定义 纺理内存 = 0
        定义 帧计数 = 0
        如果 (AI总线_推理_张量长度(输入) > 1) { 合成层数 = 次 }
        如果 (AI总线_推理_张量长度(输入) > 2) { 纺理内存 = AI总线_推理_读取(输入, 2) }
        如果 (AI总线_推理_张量长度(输入) > 3) { 帧计数 = AI总线_推理_读取(输入, 3) }

        定义 收益 = 10 + 钳制(应提升, 0, 1) * 44 + 钳制(合成层数 / 8.0, 0, 1) * 18 +
            钳制(纺理内存 / 268435456.0, 0, 1) * 16 + 钳制(帧计数 / 120.0, 0, 1) * 12
        如果 (收益 < 0) { 收益 = 0 }
        如果 (收益 > 100) { 收益 = 100 }
        返回 收益
    }

    如果 (字符串_包含(模, "NCLM_帧预算")) {
        定义 可变 瓦片数 = 首
        定义 重绘计数 = 0
        定义 级联合成计数 = 0
        定义 当前预算 = 16
        如果 (AI总线_推理_张量长度(输入) > 1) { 重绘计数 = 次 }
        如果 (AI总线_推理_张量长度(输入) > 2) { 级联合成计数 = AI总线_推理_读取(输入, 2) }
        如果 (AI总线_推理_张量长度(输入) > 3) { 当前预算 = AI总线_推理_读取(输入, 3) }

        定义 预算 = 当前预算 * 0.58 + 钳制(瓦片数 / 64.0, 0, 1) * 4 + 钳制(重绘计数 / 128.0, 0, 1) * 5 +
            钳制(级联合成计数 / 32.0, 0, 1) * 3 + 3
        如果 (预算 < 4) { 预算 = 4 }
        如果 (预算 > 33) { 预算 = 33 }
        返回 预算
    }

    如果 (字符串_包含(模, "NGCB_提交策略")) {
        定义 占用率 = 0
        定义 批次数 = 0
        定义 繁忙度 = 0
        定义 帧数 = 0
        定义 总命令数 = 0
        定义 栅栏数 = 0
        如果 (AI总线_推理_张量长度(输入) > 0) { 占用率 = AI总线_推理_读取(输入, 0) }
        如果 (AI总线_推理_张量长度(输入) > 1) { 批次数 = AI总线_推理_读取(输入, 1) }
        如果 (AI总线_推理_张量长度(输入) > 2) { 繁忙度 = AI总线_推理_读取(输入, 2) }
        如果 (AI总线_推理_张量长度(输入) > 3) { 帧数 = AI总线_推理_读取(输入, 3) }
        如果 (AI总线_推理_张量长度(输入) > 4) { 总命令数 = AI总线_推理_读取(输入, 4) }
        如果 (AI总线_推理_张量长度(输入) > 5) { 栅栏数 = AI总线_推理_读取(输入, 5) }

        定义 分数 = 占用率 * 6 + 繁忙度 * 0.4 + 批次数 * 8 + 帧数 * 2 + 总命令数 * 0.01 + 栅栏数 * 24
        如果 (分数 < 0) { 分数 = 0 }
        如果 (分数 > 1024) { 分数 = 1024 }
        返回 分数
    }

    如果 (字符串_包含(模, "错误分类")) {
        返回 钳制(均值 * 100, 0, 100)
    }

    如果 (字符串_包含(模, "GRCM_队列选择")) {
        返回 钳制(均值, 0, 1)
    }

    如果 (字符串_包含(模, "xss_detect")) {
        返回 钳制(均值 * 1024, 0, 1024)
    }

    如果 (字符串_包含(模, "url_malicious")) {
        返回 钳制(均值, 0, 1)
    }

    如果 (字符串_包含(模, "render_quality")) {
        定义 ssim = 0
        定义 帧率 = 0
        定义 磎片率 = 0
        定义 查询数 = 0
        如果 (AI总线_推理_张量长度(输入) > 0) { ssim = AI总线_推理_读取(输入, 0) }
        如果 (AI总线_推理_张量长度(输入) > 1) { 帧率 = AI总线_推理_读取(输入, 1) }
        如果 (AI总线_推理_张量长度(输入) > 2) { 磎片率 = AI总线_推理_读取(输入, 2) }
        如果 (AI总线_推理_张量长度(输入) > 3) { 查询数 = AI总线_推理_读取(输入, 3) }
        定义 质量 = 钳制(ssim, 0, 1) * 0.55 + 钳制(帧率 / 60, 0, 1) * 0.3 + (1 - 钳制(磎片率, 0, 1)) * 0.1 + (1 - 钳制(查询数 / 100000.0, 0, 1)) * 0.05
        返回 钳制(质量, 0, 1)
    }

    如果 (字符串_包含(模, "driver_match")) {
        返回 AI总线_推理_驱动匹配分(输入)
    }

    如果 (字符串_包含(模, "driver_score")) {
        返回 AI总线_推理_驱动排序分(输入)
    }

    如果 (字符串_包含(模, "atci_tool_select")) {
        返回 AI总线_推理_工具选择分(输入)
    }

    如果 (字符串_包含(模, "JIT价值评估")) {
        返回 AI总线_推理_JIT价值分(输入)
    }

    如果 (字符串_包含(模, "driver_health")) {
        返回 AI总线_推理_驱动健康异常分(输入)
    }

    如果 (字符串_包含(模, "cache_optimize")) {
        定义 总参数字节 = 0
        定义 层数 = 0
        定义 L1命中率 = 0
        定义 总查询数 = 0
        定义 L1命中 = 0
        如果 (AI总线_推理_张量长度(输入) > 0) { 总参数字节 = AI总线_推理_读取(输入, 0) }
        如果 (AI总线_推理_张量长度(输入) > 1) { 层数 = AI总线_推理_读取(输入, 1) }
        如果 (AI总线_推理_张量长度(输入) > 2) { L1命中率 = 钳制(AI总线_推理_读取(输入, 2), 0, 1) }
        如果 (AI总线_推理_张量长度(输入) > 3) { 总查询数 = AI总线_推理_读取(输入, 3) }
        如果 (AI总线_推理_张量长度(输入) > 4) { L1命中 = AI总线_推理_读取(输入, 4) }

        定义 优化机会 = 钳制(总参数字节 / 67108864.0, 0, 1) * 0.32 + 钳制(层数 / 64.0, 0, 1) * 0.14 +
            (1 - L1命中率) * 0.34 + 钳制(总查询数 / 1000000.0, 0, 1) * 0.1 + (1 - 钳制(L1命中 / 100000.0, 0, 1)) * 0.1
        返回 钳制(优化机会, 0, 1)
    }

    如果 (字符串_包含(模, "NBFT热函数")) {
        定义 查找总数 = 0
        定义 命中总数 = 0
        定义 未命中总数 = 0
        定义 调用总数 = 0
        定义 内置表数 = 0
        如果 (AI总线_推理_张量长度(输入) > 0) { 查找总数 = AI总线_推理_读取(输入, 0) }
        如果 (AI总线_推理_张量长度(输入) > 1) { 命中总数 = AI总线_推理_读取(输入, 1) }
        如果 (AI总线_推理_张量长度(输入) > 2) { 未命中总数 = AI总线_推理_读取(输入, 2) }
        如果 (AI总线_推理_张量长度(输入) > 3) { 调用总数 = AI总线_推理_读取(输入, 3) }
        如果 (AI总线_推理_张量长度(输入) > 4) { 内置表数 = AI总线_推理_读取(输入, 4) }

        定义 命中率 = 0
        如果 (查找总数 > 0) { 命中率 = 钳制(命中总数 / 查找总数, 0, 1) }
        定义 热度 = 0.1 + 命中率 * 0.52 + 钳制(调用总数 / 10000.0, 0, 1) * 0.2 + 钳制(内置表数 / 512.0, 0, 1) * 0.08 + 钳制(未命中总数 / 10000.0, 0, 1) * 0.1
        返回 钳制(热度, 0, 1)
    }

    如果 (字符串_包含(模, "model_save_strategy")) {
        定义 推理次数 = 0
        定义 学习步数 = 0
        定义 写入字节 = 0
        定义 参数量 = 0
        如果 (AI总线_推理_张量长度(输入) > 0) { 推理次数 = AI总线_推理_读取(输入, 0) }
        如果 (AI总线_推理_张量长度(输入) > 1) { 学习步数 = AI总线_推理_读取(输入, 1) }
        如果 (AI总线_推理_张量长度(输入) > 2) { 写入字节 = AI总线_推理_读取(输入, 2) }
        如果 (AI总线_推理_张量长度(输入) > 3) { 参数量 = AI总线_推理_读取(输入, 3) }
        定义 紧迫度 = 0.1
        紧迫度 = 紧迫度 + 钳制(推理次数 / 1000.0, 0, 1) * 0.35
        紧迫度 = 紧迫度 + 钳制(学习步数 / 100.0, 0, 1) * 0.25
        紧迫度 = 紧迫度 + 钳制(写入字节 / 1048576.0, 0, 1) * 0.2
        紧迫度 = 紧迫度 + 钳制(参数量 / 1000000.0, 0, 1) * 0.1
        返回 钳制(紧迫度, 0, 1)
    }

    返回 AI总线_推理_无模型标量(输入)
}

函数 AI总线_异常检测_归一值(值, 索引) {
    定义 绝对 = 绝对值(值)
    如果 (绝对 <= 0) { 返回 0 }
    如果 (绝对 <= 1) { 返回 绝对 }

    定义 基准 = 10.0
    如果 (索引 >= 6) {
        基准 = 1000000000.0
    } 否则如果 (索引 >= 4) {
        基准 = 1000.0
    } 否则如果 (索引 >= 2) {
        基准 = 100.0
    }

    返回 钳制(绝对 / (绝对 + 基准), 0, 1)
}

函数 AI总线_异常检测_基础分(输入) {
    如果 (AI总线_推理_是张量(输入) == 假) {
        如果 (Nova_是数值(输入)) {
            返回 钳制(绝对值(输入) / 100.0, 0, 1)
        }
        返回 0
    }

    定义 总数 = AI总线_推理_张量长度(输入)
    如果 (总数 <= 0) { 返回 0 }

    定义 可变 分数和 = 0
    定义 可变 权重和 = 0
    定义 可变 i = 0
    当 (i < 总数) {
        定义 归一 = AI总线_异常检测_归一值(AI总线_推理_读取(输入, i), i)
        定义 权重 = 0.35
        如果 (i == 0) {
            权重 = 1.4
        } 否则如果 (i == 1) {
            权重 = 1.2
        } 否则如果 (i < 4) {
            权重 = 1.0
        } 否则如果 (i < 6) {
            权重 = 0.7
        }
        分数和 = 分数和 + 归一 * 权重
        权重和 = 权重和 + 权重
        i = i + 1
    }

    如果 (权重和 <= 0) { 返回 0 }
    返回 钳制(分数和 / 权重和, 0, 1)
}

函数 AI总线_异常检测_设备分(输入) {
    定义 总数 = AI总线_推理_张量长度(输入)
    如果 (总数 <= 0) { 返回 0 }

    定义 设备类型 = 0
    定义 供应商 = 0
    定义 设备 = 0
    定义 有驱动 = 0
    如果 (总数 > 0) { 设备类型 = AI总线_推理_读取(输入, 0) }
    如果 (总数 > 1) { 供应商 = AI总线_推理_读取(输入, 1) }
    如果 (总数 > 2) { 设备 = AI总线_推理_读取(输入, 2) }
    如果 (总数 > 3) { 有驱动 = AI总线_推理_读取(输入, 3) }

    定义 风险 = 0.08
    如果 (设备类型 <= 0) {
        风险 = 风险 + 0.18
    } 否则如果 (设备类型 < 2) {
        风险 = 风险 + 0.06
    }

    如果 (供应商 <= 0) {
        风险 = 风险 + 0.28
    } 否则 {
        风险 = 风险 + 0.02
    }

    如果 (设备 <= 0) {
        风险 = 风险 + 0.28
    } 否则 {
        风险 = 风险 + 0.02
    }

    如果 (有驱动 <= 0) {
        风险 = 风险 + 0.22
    } 否则 {
        风险 = 风险 - 0.08
    }

    风险 = 风险 + AI总线_异常检测_基础分(输入) * 0.1
    如果 (风险 < 0) { 风险 = 0 }
    如果 (风险 > 1) { 风险 = 1 }
    返回 风险
}

函数 AI总线_异常检测_张量结果(输入, 分数) {
    如果 (AI总线_推理_是张量(输入) == 假) { 返回 0 }
    定义 结果 = Tensor_克隆(输入)
    如果 (结果 == 0) { 返回 0 }
    定义 总数 = AI总线_推理_张量长度(结果)
    AI总线_推理_写入(结果, 0, 分数)
    如果 (总数 > 1) {
        AI总线_推理_写入(结果, 1, 钳制(1 - 分数, 0, 1))
    }
    返回 结果
}

函数 AI总线_异常检测_结果(模型名, 输入, 额外) {
    定义 模 = ""
    如果 (Nova_是字符串(模型名)) {
        模 = 字符串_转小写(模型名)
    }

    定义 基础 = AI总线_异常检测_基础分(输入)

    如果 (模 == "") {
        如果 (额外 != 0) { 返回 基础 }
        返回 钳制(基础 * 100, 0, 100)
    }

    如果 (字符串_包含(模, "device_anomaly")) {
        返回 AI总线_异常检测_设备分(输入)
    }

    如果 (字符串_包含(模, "nhcl_anomaly")) {
        返回 AI总线_异常检测_张量结果(输入, 基础)
    }

    如果 (字符串_包含(模, "nios_anomaly")) {
        返回 AI总线_异常检测_张量结果(输入, 基础)
    }

    如果 (字符串_包含(模, "brat") && 字符串_包含(模, "资源冲突")) {
        返回 基础
    }

    如果 (字符串_包含(模, "fs_syscall_anomaly")) {
        返回 钳制(基础 * 10000, 0, 10000)
    }

    如果 (字符串_包含(模, "driver_health") ||
        字符串_包含(模, "wifi_anomaly") ||
        字符串_包含(模, "nksi") ||
        字符串_包含(模, "naiw") ||
        字符串_包含(模, "npbt") ||
        字符串_包含(模, "nmod") ||
        字符串_包含(模, "nc2d") ||
        字符串_包含(模, "npms") ||
        字符串_包含(模, "nirc") ||
        字符串_包含(模, "nwco") ||
        字符串_包含(模, "ngrc") ||
        字符串_包含(模, "checkpoint") ||
        字符串_包含(模, "ui_anomaly") ||
        字符串_包含(模, "pamc") ||
        字符串_包含(模, "步骤风险") ||
        字符串_包含(模, "栈深度监控") ||
        字符串_包含(模, "线程创建监控") ||
        字符串_包含(模, "cors") ||
        字符串_包含(模, "ext4_inode_behavior") ||
        字符串_包含(模, "naipe_engine") ||
        字符串_包含(模, "naxt") ||
        字符串_包含(模, "nfoc_form") ||
        字符串_包含(模, "ngui") ||
        字符串_包含(模, "nioc") ||
        字符串_包含(模, "ndia") ||
        字符串_包含(模, "nmtl") ||
        字符串_包含(模, "subsystem_health") ||
        字符串_包含(模, "nmha")) {
        返回 钳制(基础 * 1000, 0, 1000)
    }

    返回 钳制(基础 * 1000, 0, 1000)
}

函数 AI总线_推理_对象结果(模型名, 输入) {
    定义 均值 = AI总线_推理_平均值(输入)
    定义 置信度 = 钳制(0.45 + 均值 * 0.55, 0, 1)
    定义 可变 输出向量 = []

    如果 (字符串_包含(模型名, "NRPT_路由缓存")) {
        追加(输出向量, 钳制(均值 * 32 + 1, 1, 64))
        追加(输出向量, 0)
        追加(输出向量, 0)
        追加(输出向量, 0)
        返回 { 置信度: 置信度, 输出向量: 输出向量 }
    }

    如果 (字符串_包含(模型名, "BFOT_布隆参数")) {
        追加(输出向量, 如果 (均值 > 0.55) { 1 } 否则 { 0 })
        追加(输出向量, 钳制(取大(8, 4 + 均值 * 8), 4, 16))
        追加(输出向量, 钳制(取大(3, 2 + 均值 * 4), 2, 8))
        返回 { 置信度: 置信度, 输出向量: 输出向量 }
    }

    如果 (字符串_包含(模型名, "MAAPT_页表预取")) {
        定义 步长 = 钳制(1 + 均值 * 4, 1, 8)
        返回 { 置信度: 置信度, 输出值: 步长 }
    }

    返回 0
}

函数 AI总线_推理_张量结果(输入, 模型名, 额外) {
    定义 结果 = Tensor_克隆(输入)
    如果 (结果 == 0) { 返回 0 }

    定义 均值 = AI总线_推理_平均值(输入)
    定义 总数 = AI总线_推理_张量长度(结果)
    如果 (字符串_包含(模型名, "frame_budget_advisor")) {
        定义 丢帧率 = 首值(输入)
        定义 帧数 = 0
        定义 内存率 = 0
        如果 (AI总线_推理_张量长度(输入) > 1) { 帧数 = AI总线_推理_读取(输入, 1) }
        如果 (AI总线_推理_张量长度(输入) > 2) { 内存率 = AI总线_推理_读取(输入, 2) }

        定义 建议质量 = 2
        如果 (丢帧率 > 0.2 || 内存率 > 0.85) {
            建议质量 = 0
        } 否则如果 (丢帧率 > 0.08 || 内存率 > 0.65 || 帧数 > 6000) {
            建议质量 = 1
        }

        AI总线_推理_写入(结果, 0, 建议质量)
        如果 (总数 > 1) { AI总线_推理_写入(结果, 1, 钳制(1 - 0.5 * 丢帧率 - 0.35 * 内存率, 0, 1)) }
        如果 (总数 > 2) { AI总线_推理_写入(结果, 2, 钳制(2 - 建议质量, 0, 2)) }
        返回 结果
    }

    如果 (字符串_包含(模型名, "任务编排优化")) {
        定义 首特征 = 首值(输入)
        定义 次特征 = 次值(输入)
        定义 第三特征 = 0
        定义 第四特征 = 0
        如果 (AI总线_推理_张量长度(输入) > 2) { 第三特征 = AI总线_推理_读取(输入, 2) }
        如果 (AI总线_推理_张量长度(输入) > 3) { 第四特征 = AI总线_推理_读取(输入, 3) }

        定义 可变 非零类型 = 0
        定义 可变 j = 4
        当 (j < 总数) {
            如果 (AI总线_推理_读取(输入, j) > 0) { 非零类型 = 非零类型 + 1 }
            j = j + 1
        }

        定义 可变 建议并行度 = 第四特征
        定义 失败率 = 0
        如果 (首特征 > 0) { 失败率 = 次特征 * 1.0 / 首特征 }

        如果 (首特征 <= 0) {
            建议并行度 = 1
        } 否则如果 (失败率 > 0.25 || 第三特征 > 4000) {
            建议并行度 = 第四特征 - 2
        } 否则如果 (失败率 > 0.1 || 第三特征 > 2000) {
            建议并行度 = 第四特征 - 1
        } 否则如果 (首特征 > 第四特征 * 2 && 非零类型 >= 4) {
            建议并行度 = 第四特征 + 2
        } 否则如果 (首特征 > 第四特征 && 第三特征 < 800) {
            建议并行度 = 第四特征 + 1
        }

        如果 (建议并行度 < 1) { 建议并行度 = 1 }
        如果 (建议并行度 > 16) { 建议并行度 = 16 }

        AI总线_推理_写入(结果, 0, 建议并行度)
        如果 (总数 > 1) { AI总线_推理_写入(结果, 1, 钳制(1 - 失败率 * 0.7 - 第三特征 * 1.0 / 10000, 0, 1)) }
        如果 (总数 > 2) { AI总线_推理_写入(结果, 2, 非零类型) }
        返回 结果
    }

    如果 (字符串_包含(模型名, "boot_time_predictor")) {
        定义 首特征 = 首值(输入)
        定义 次特征 = 次值(输入)
        定义 第三特征 = 0
        定义 第四特征 = 0
        如果 (AI总线_推理_张量长度(输入) > 2) { 第三特征 = AI总线_推理_读取(输入, 2) }
        如果 (AI总线_推理_张量长度(输入) > 3) { 第四特征 = AI总线_推理_读取(输入, 3) }

        定义 预测毫秒 = 120 + 首特征 * 180 + 第三特征 * 90 + 第四特征 * 260 + 次特征 * 45 + 均值 * 60
        如果 (预测毫秒 < 1) { 预测毫秒 = 1 }
        如果 (预测毫秒 > 300000) { 预测毫秒 = 300000 }

        AI总线_推理_写入(结果, 0, 预测毫秒)
        如果 (总数 > 1) { AI总线_推理_写入(结果, 1, 钳制(均值, 0, 1)) }
        返回 结果
    }

    如果 (字符串_包含(模型名, "NGCC_负载预测")) {
        AI总线_推理_写入(结果, 0, 钳制(均值 * 0.8 + 首值(输入) * 0.2, 0, 1))
        如果 (总数 > 1) { AI总线_推理_写入(结果, 1, 钳制(均值 * 0.5, 0, 1)) }
        返回 结果
    }

    如果 (字符串_包含(模型名, "NGCC_纩理预载")) {
        AI总线_推理_写入(结果, 0, 钳制(均值, 0, 1))
        返回 结果
    }

    如果 (字符串_包含(模型名, "NBCI_调节")) {
        AI总线_推理_写入(结果, 0, 钳制(均值, 0, 1))
        如果 (总数 > 1) { AI总线_推理_写入(结果, 1, 钳制(1 - 均值, 0, 1)) }
        返回 结果
    }

    如果 (字符串_包含(模型名, "NDLS_分类")) {
        AI总线_推理_写入(结果, 0, 钳制(均值, 0, 1))
        返回 结果
    }

    如果 (字符串_包含(模型名, "NPTM_电源优化")) {
        定义 可变 count = 首值(输入)
        如果 (count < 0) { count = 0 }
        如果 (count > 总数) { count = 总数 }
        定义 可变 i = 0
        当 (i < count) {
            定义 基 = 0
            如果 (AI总线_推理_张量长度(输入) > 3 + count + i) {
                基 = AI总线_推理_读取(输入, 3 + count + i)
            }
            定义 idle = 0
            如果 (AI总线_推理_张量长度(输入) > 3 + i) {
                idle = AI总线_推理_读取(输入, 3 + i)
            }
            定义 建议D = 3
            如果 (idle > 基) { 建议D = 0 }
            否则 如果 (idle > 基 * 0.7) { 建议D = 1 }
            否则 如果 (idle > 基 * 0.4) { 建议D = 2 }
            AI总线_推理_写入(结果, i, 建议D)
            i = i + 1
        }
        返回 结果
    }

    如果 (字符串_包含(模型名, "NUCP_文本语义评估")) {
        AI总线_推理_写入(结果, 0, 钳制(均值 * 100, 0, 100))
        返回 结果
    }

    如果 (字符串_包含(模型名, "NGIR_布局优化")) {
        定义 moveBias = 首值(输入) - 次值(输入)
        定义 clusterBias = 0
        如果 (总数 > 3) { clusterBias = AI总线_推理_读取(输入, 2) - AI总线_推理_读取(输入, 1) }
        AI总线_推理_写入(结果, 0, 钳制(moveBias, -1, 1))
        如果 (总数 > 1) { AI总线_推理_写入(结果, 1, 钳制(clusterBias, -1, 1)) }
        返回 结果
    }

    如果 (字符串_包含(模型名, "NOGL_元学习")) {
        AI总线_推理_写入(结果, 0, 钳制(均值, 0, 1))
        返回 结果
    }

    如果 (字符串_包含(模型名, "AMMS_记忆相关性")) {
        AI总线_推理_写入(结果, 0, 钳制(均值, 0, 1))
        返回 结果
    }

    如果 (字符串_包含(模型名, "NKSI检测预测")) {
        定义 检测分 = 0
        定义 可变 权重和 = 0
        定义 可变 i = 0
        定义 权重 = [20, 15, 15, 10, 20, 10, 10, 10, 6, 6, 6, 6, 6, 18, 12, 12]
        当 (i < 16 && i < 总数) {
            定义 值 = AI总线_推理_读取(输入, i)
            定义 归一 = 值
            如果 (i < 8) {
                如果 (归一 > 1000) { 归一 = 1000 }
                归一 = 归一 * 1.0 / 1000
            } 否则 {
                如果 (归一 > 200) { 归一 = 200 }
                归一 = 归一 * 1.0 / 200
            }
            检测分 = 检测分 + 归一 * 权重[i]
            权重和 = 权重和 + 权重[i]
            i = i + 1
        }
        如果 (权重和 > 0) {
            检测分 = 检测分 * 1024 / 权重和
        } 否则 {
            检测分 = 钳制(均值 * 1024, 0, 1024)
        }
        AI总线_推理_写入(结果, 0, 钳制(检测分, 0, 1024))
        返回 结果
    }

    如果 (字符串_包含(模型名, "NRAF_页面分析")) {
        定义 页面类型 = 0
        如果 (AI总线_推理_张量长度(输入) > 4) {
            页面类型 = 钳制(首值(输入) + 次值(输入) + AI总线_推理_读取(输入, 4), 0, 4)
        }
        AI总线_推理_写入(结果, 0, 页面类型)
        返回 结果
    }

    如果 (字符串_包含(模型名, "NRAF_帧预测")) {
        定义 预测时间 = 首值(输入)
        如果 (AI总线_推理_张量长度(输入) > 1) {
            预测时间 = 首值(输入) * 0.7 + 次值(输入) * 0.3
        }
        AI总线_推理_写入(结果, 0, 预测时间)
        返回 结果
    }

    如果 (字符串_包含(模型名, "NPEL_兼容性")) {
        定义 兼容 = 0.5
        定义 64位 = 0
        定义 DLL = 0
        定义 导入密度 = 0
        定义 API密度 = 0
        定义 映像密度 = 0
        定义 重定位密度 = 0
        如果 (AI总线_推理_张量长度(输入) > 0) { 64位 = AI总线_推理_读取(输入, 0) }
        如果 (AI总线_推理_张量长度(输入) > 1) { DLL = AI总线_推理_读取(输入, 1) }
        如果 (AI总线_推理_张量长度(输入) > 2) { 导入密度 = 钳制(AI总线_推理_读取(输入, 2), 0, 1) }
        如果 (AI总线_推理_张量长度(输入) > 3) { API密度 = 钳制(AI总线_推理_读取(输入, 3), 0, 1) }
        如果 (AI总线_推理_张量长度(输入) > 4) { 映像密度 = 钳制(AI总线_推理_读取(输入, 4), 0, 1) }
        如果 (AI总线_推理_张量长度(输入) > 5) { 重定位密度 = 钳制(AI总线_推理_读取(输入, 5), 0, 1) }

        兼容 = 0.22 + 64位 * 0.18 + DLL * 0.08
        兼容 = 兼容 + (1 - 钳制(导入密度 * 1.2, 0, 1)) * 0.18
        兼容 = 兼容 + (1 - 钳制(API密度 * 1.1, 0, 1)) * 0.12
        兼容 = 兼容 + (1 - 钳制(映像密度 * 0.9, 0, 1)) * 0.14
        兼容 = 兼容 + (1 - 钳制(重定位密度 * 0.8, 0, 1)) * 0.08
        如果 (兼容 < 0) { 兼容 = 0 }
        如果 (兼容 > 1) { 兼容 = 1 }
        AI总线_推理_写入(结果, 0, 兼容)
        如果 (总数 > 1) { AI总线_推理_写入(结果, 1, 钳制(1 - 兼容, 0, 1)) }
        返回 结果
    }

    如果 (字符串_包含(模型名, "NPCD_回写")) {
        定义 脏比率 = 0
        定义 脏链表 = 0
        定义 总回写页 = 0
        定义 回写次数 = 0
        定义 合并回写 = 0
        定义 总缓存页 = 0
        如果 (AI总线_推理_张量长度(输入) > 0) { 脏比率 = 钳制(AI总线_推理_读取(输入, 0), 0, 1) }
        如果 (AI总线_推理_张量长度(输入) > 1) { 脏链表 = 钳制(AI总线_推理_读取(输入, 1), 0, 1) }
        如果 (AI总线_推理_张量长度(输入) > 2) { 总回写页 = 钳制(AI总线_推理_读取(输入, 2), 0, 1) }
        如果 (AI总线_推理_张量长度(输入) > 3) { 回写次数 = 钳制(AI总线_推理_读取(输入, 3), 0, 1) }
        如果 (AI总线_推理_张量长度(输入) > 4) { 合并回写 = 钳制(AI总线_推理_读取(输入, 4), 0, 1) }
        如果 (AI总线_推理_张量长度(输入) > 5) { 总缓存页 = 钳制(AI总线_推理_读取(输入, 5), 0, 1) }

        定义 回写强度 = 0.12 + 脏比率 * 0.46 + 脏链表 * 0.12 + 总回写页 * 0.10 + 回写次数 * 0.10 + 合并回写 * 0.05 + 总缓存页 * 0.05
        如果 (回写强度 < 0) { 回写强度 = 0 }
        如果 (回写强度 > 1) { 回写强度 = 1 }
        AI总线_推理_写入(结果, 0, 回写强度)
        如果 (总数 > 1) { AI总线_推理_写入(结果, 1, 钳制(1 - 回写强度, 0, 1)) }
        返回 结果
    }

    如果 (字符串_包含(模型名, "nvcr_rotation")) {
        AI总线_推理_写入(结果, 0, 钳制(首值(输入) * 90 + 次值(输入) * 30, 0, 360))
        返回 结果
    }

    如果 (字符串_包含(模型名, "nvcr_confidence")) {
        AI总线_推理_写入(结果, 0, 钳制(均值, 0, 1))
        返回 结果
    }

    如果 (字符串_包含(模型名, "nvcr_classify")) {
        AI总线_推理_写入(结果, 0, 钳制(均值, 0, 1))
        返回 结果
    }

    如果 (字符串_包含(模型名, "nvcr_locate")) {
        AI总线_推理_写入(结果, 0, 1)
        AI总线_推理_写入(结果, 1, 钳制(首值(输入) * 2 + 次值(输入) * 8, 0, 4096))
        如果 (总数 > 2) {
            AI总线_推理_写入(结果, 2, 钳制(次值(输入) * 2 + 首值(输入) * 4, 0, 4096))
        }
        返回 结果
    }

    // 默认: 复制输入, 保持张量语义并填一个保守的首值
    AI总线_推理_写入(结果, 0, 钳制(均值, 0, 1))
    返回 结果
}

函数 AI总线_推理(参数1) {
    如果 (AI总线_推理_是张量(参数1)) {
        定义 结果 = Tensor_克隆(参数1)
        如果 (结果 != 0) { 返回 结果 }
    }
    返回 0
}

函数 AI总线_异常检测(参数1) {
    如果 (AI总线_推理_是张量(参数1)) {
        返回 AI总线_异常检测_结果("", 参数1, 0)
    }
    返回 AI总线_异常检测_结果("", 参数1, 0)
}

函数 AI总线_DOM增量推理(参数1, 参数2) {
    定义 bus = AI总线_获取实例()
    如果 (bus == 0) { 返回 空 }
    返回 AI总线_DOM注意力增量推理(bus, 参数1, 参数2)
}

函数 AI总线_行为增量推理(参数1, 参数2) {
    定义 bus = AI总线_获取实例()
    如果 (bus == 0) { 返回 空 }
    返回 AI总线_行为序列增量推理(bus, 参数1, 参数2)
}

函数 AI总线_页面增量推理(参数1, 参数2) {
    定义 bus = AI总线_获取实例()
    如果 (bus == 0) { 返回 空 }
    返回 AI总线_页面结构增量推理(bus, 参数1, 参数2)
}

函数 AI总线_重置页面缓存() {
    定义 bus = AI总线_获取实例()
    如果 (bus == 0) { 返回 错误_未初始化 }
    返回 AI总线_重置页面注意力缓存(bus)
}


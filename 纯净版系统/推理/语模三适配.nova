导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("./云端桥接.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../外联/地址解析辅.nova")
导入("../标准/原生列表.nova")
导入("../中枢/整数转字符串.nova")

定义 Nova语言模型_接口端点 = "https://api.Nova智能.com/v1/chat/completions"
定义 Nova语言模型_默认模型 = "Nova语言模型-4o"
定义 Nova语言模型_最大令牌 = 4096
定义 Nova语言模型_默认温度 = 70
定义 Nova语言模型_最大重试 = 3
定义 Nova语言模型_重试延迟 = 1000

结构 Nova语言模型适配器 {
    桥接,
    模型,
    最大令牌,
    温度,
    系统提示,
    对话历史,
    最大历史轮数,
    总请求数,
    总令牌数,
    总失败数,
    最后错误,
    频率惩罚,
    存在惩罚,
}

定义 可变 nova_lm_全局请求数 = 0
定义 可变 nova_lm_全局令牌数 = 0

函数 Nova语言模型_创建(密钥) {
    返回 Nova语言模型适配器 {
        桥接: 云端桥接_创建(密钥, Nova语言模型_接口端点, "Nova语言模型"),
        模型: Nova语言模型_默认模型,
        最大令牌: Nova语言模型_最大令牌,
        温度: Nova语言模型_默认温度,
        系统提示: "",
        对话历史: [],
        最大历史轮数: 20,
        总请求数: 0,
        总令牌数: 0,
        总失败数: 0,
        最后错误: "",
        频率惩罚: 0,
        存在惩罚: 0
    }
}

函数 Nova语言模型_设置模型(适配器, 模型) { 适配器.模型 = 模型 }
函数 Nova语言模型_设置温度(适配器, 温度) { 适配器.温度 = 温度 }
函数 Nova语言模型_设置最大令牌(适配器, 数) { 适配器.最大令牌 = 数 }
函数 Nova语言模型_设置系统提示(适配器, 提示) { 适配器.系统提示 = 提示 }
函数 Nova语言模型_清空历史(适配器) { 适配器.对话历史 = [] }
函数 Nova语言模型_设置频率惩罚(适配器, 值) { 适配器.频率惩罚 = 值 }
函数 Nova语言模型_设置存在惩罚(适配器, 值) { 适配器.存在惩罚 = 值 }

函数 Nova语言模型_添加历史(适配器, 角色, 内容) {
    追加(适配器.对话历史, [角色, 内容])
    如果 (计数(适配器.对话历史) > 适配器.最大历史轮数 * 2) {
        适配器.对话历史 = 列表_切片(适配器.对话历史, 2, 计数(适配器.对话历史))
    }
}

函数 Nova语言模型_转义(文本) {
    如果 (文本 == 空) { 返回 "" }
    定义 可变 部件 = []
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 字符 = 字符串取字符(文本, i)
        如果 (字符 == "\"") { 追加(部件, "\\\"" })
        否则如果 (字符 == "\\") { 追加(部件, "\\\\" })
        否则如果 (字符 == "\n") { 追加(部件, "\\n" })
        否则 { 追加(部件, 字符 })
        i = i + 1
    }
    返回 字符串_连接列表(部件, "")
}

函数 Nova语言模型_构建消息序列(消息列表) {
    定义 可变 序列 = "["
    定义 可变 i = 0
    当 (i < 计数(消息列表)) {
        如果 (i > 0) { 序列 = 序列 + "," }
        定义 消息 = 消息列表[i]
        序列 = 序列 + "{\"role\":\"" + Nova语言模型_转义(消息[0]) + "\",\"content\":\"" + Nova语言模型_转义(消息[1]) + "\"}"
        i = i + 1
    }
    序列 = 序列 + "]"
    返回 序列
}

函数 Nova语言模型_构建请求体(适配器, 消息列表) {
    定义 消息序列 = Nova语言模型_构建消息序列(消息列表)
    定义 温度值 = 整数转字符串(适配器.温度 / 100) + "." + 整数转字符串(适配器.温度 % 100)
    定义 可变 请求体 = "{\"model\":\"" + 适配器.模型 +
        "\",\"max_tokens\":" + 整数转字符串(适配器.最大令牌) +
        ",\"temperature\":" + 温度值 +
        ",\"messages\":" + 消息序列
    如果 (适配器.频率惩罚 > 0) {
        请求体 = 请求体 + ",\"frequency_penalty\":" + 整数转字符串(适配器.频率惩罚 / 100) + "." + 整数转字符串(适配器.频率惩罚 % 100)
    }
    如果 (适配器.存在惩罚 > 0) {
        请求体 = 请求体 + ",\"presence_penalty\":" + 整数转字符串(适配器.存在惩罚 / 100) + "." + 整数转字符串(适配器.存在惩罚 % 100)
    }
    请求体 = 请求体 + "}"
    返回 请求体
}

函数 Nova语言模型_带重试请求(适配器, 请求体) {
    定义 可变 重试 = 0
    定义 可变 最后结果 = 空
    当 (重试 <= Nova语言模型_最大重试) {
        最后结果 = 云端桥接_推理后援(适配器.桥接, 请求体, "")
        如果 (最后结果 != 空) {
            定义 错误检查 = 字符串查找(最后结果, "\"error\"")
            如果 (错误检查 < 0) { 返回 最后结果 }
            定义 速率限制 = 字符串查找(最后结果, "rate_limit")
            定义 服务过载 = 字符串查找(最后结果, "overloaded")
            如果 (速率限制 >= 0 || 服务过载 >= 0) {
                定义 延迟 = Nova语言模型_重试延迟 * (1 << 重试)
                等待_毫秒(延迟)
                重试 = 重试 + 1
                继续
            }
            适配器.最后错误 = "API错误"
            适配器.总失败数 = 适配器.总失败数 + 1
            返回 最后结果
        }
        重试 = 重试 + 1
    }
    适配器.最后错误 = "超过最大重试次数"
    适配器.总失败数 = 适配器.总失败数 + 1
    返回 最后结果
}

函数 Nova语言模型_对话(适配器, 消息列表) {
    适配器.总请求数 = 适配器.总请求数 + 1
    nova_lm_全局请求数 = nova_lm_全局请求数 + 1

    定义 可变 完整消息 = []
    如果 (适配器.系统提示 != "") {
        追加(完整消息, ["system", 适配器.系统提示])
    }
    定义 可变 i = 0
    当 (i < 计数(消息列表)) {
        追加(完整消息, 消息列表[i])
        i = i + 1
    }

    定义 请求体 = Nova语言模型_构建请求体(适配器, 完整消息)
    返回 Nova语言模型_带重试请求(适配器, 请求体)
}

函数 Nova语言模型_补全(适配器, 提示) {
    返回 Nova语言模型_对话(适配器, [["user", 提示]])
}

函数 Nova语言模型_带系统提示(适配器, 系统提示, 用户消息) {
    定义 旧提示 = 适配器.系统提示
    适配器.系统提示 = 系统提示
    定义 结果 = Nova语言模型_对话(适配器, [["user", 用户消息]])
    适配器.系统提示 = 旧提示
    返回 结果
}

函数 Nova语言模型_多轮对话(适配器, 用户消息) {
    Nova语言模型_添加历史(适配器, "user", 用户消息)
    定义 结果 = Nova语言模型_对话(适配器, 适配器.对话历史)
    如果 (结果 != 空) {
        定义 回复文本 = Nova语言模型_解析响应(结果)
        如果 (回复文本 != 空) {
            Nova语言模型_添加历史(适配器, "assistant", 回复文本)
        }
        定义 令牌 = Nova语言模型_解析令牌用量(结果)
        适配器.总令牌数 = 适配器.总令牌数 + 令牌
        nova_lm_全局令牌数 = nova_lm_全局令牌数 + 令牌
    }
    返回 结果
}

函数 Nova语言模型_解析响应(响应) {
    如果 (响应 == 空) { 返回 空 }
    定义 位置 = 字符串查找(响应, "\"content\":\"")
    如果 (位置 < 0) { 返回 响应 }
    定义 起始 = 位置 + 11
    定义 可变 结束 = 起始
    定义 可变 转义 = 假
    当 (结束 < 字符串长度(响应)) {
        定义 字符 = 字符串取字符(响应, 结束)
        如果 (转义) { 转义 = 假; 结束 = 结束 + 1; 继续 }
        如果 (字符 == "\\") { 转义 = 真; 结束 = 结束 + 1; 继续 }
        如果 (字符 == "\"") { 跳出 }
        结束 = 结束 + 1
    }
    返回 字符串子串(响应, 起始, 结束)
}

函数 Nova语言模型_解析令牌用量(响应) {
    如果 (响应 == 空) { 返回 0 }
    定义 位置 = 字符串查找(响应, "\"total_tokens\":")
    如果 (位置 < 0) { 返回 0 }
    定义 起始 = 位置 + 15
    定义 可变 结束 = 起始
    当 (结束 < 字符串长度(响应)) {
        定义 字符 = 字符串取字符(响应, 结束)
        如果 (字符 < "0" || 字符 > "9") { 跳出 }
        结束 = 结束 + 1
    }
    返回 字符串转整数(字符串子串(响应, 起始, 结束))
}

函数 Nova语言模型_解析结束原因(响应) {
    如果 (响应 == 空) { 返回 "unknown" }
    定义 位置 = 字符串查找(响应, "\"finish_reason\":\"")
    如果 (位置 < 0) { 返回 "unknown" }
    定义 起始 = 位置 + 17
    定义 结束 = 字符串查找(字符串子串(响应, 起始, 字符串长度(响应)), "\"")
    如果 (结束 < 0) { 返回 "unknown" }
    返回 字符串子串(响应, 起始, 起始 + 结束)
}

函数 Nova语言模型_统计(适配器) {
    返回 [适配器.总请求数, 适配器.总令牌数, 适配器.总失败数]
}

函数 Nova语言模型_全局统计() {
    返回 [nova_lm_全局请求数, nova_lm_全局令牌数]
}

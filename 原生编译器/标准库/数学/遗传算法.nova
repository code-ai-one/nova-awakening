// Nova标准库 — 遗传算法 (Genetic Algorithm, 0 , 0 , 0 , 0, 0, 0, 0)
// 进化优化、种群管理、适应度评估
// 支撑 AI 超参数搜索、神经架构搜索

导入("../基础.nova")

定义 遗传精度 = 1000

// 个体
// [基因列表, 适应度]

函数 个体_创建(基因长度, 最小值, 最大值, 种子) {
    定义 可变 基因 = []
    定义 可变 s = 种子
    定义 可变 i = 0
    当 (i < 基因长度) {
        s = (s * 1103515245 + 12345) & 0x7FFFFFFF
        追加(基因, 最小值 + s % (最大值 - 最小值 + 1))
        i = i + 1
    }
    返回 [基因, 0]
}

// 种群

函数 种群_创建(大小, 基因长度, 最小值, 最大值, 种子) {
    定义 可变 种群 = []
    定义 可变 s = 种子
    定义 可变 i = 0
    当 (i < 大小) {
        s = s + i * 31 + 7
        追加(种群, 个体_创建(基因长度, 最小值, 最大值, s))
        i = i + 1
    }
    返回 种群
}

// 评估种群适应度
函数 种群_评估(种群, 适应度函数) {
    定义 可变 i = 0
    当 (i < 计数(种群)) {
        种群[i][1] = 适应度函数(种群[i][0])
        i = i + 1
    }
}

// 获取最优个体
函数 种群_最优(种群) {
    定义 可变 最优i = 0
    定义 可变 最优适应 = 种群[0][1]
    定义 可变 i = 1
    当 (i < 计数(种群)) {
        如果 (种群[i][1] > 最优适应) {
            最优适应 = 种群[i][1]
            最优i = i
        }
        i = i + 1
    }
    返回 种群[最优i]
}

// 选择

// 锦标赛选择
函数 锦标赛选择(种群, 锦标赛大小, 随机状态) {
    定义 n = 计数(种群)
    定义 可变 最优i = -1
    定义 可变 最优适应 = 0 - 0x7FFFFFFF
    定义 可变 i = 0
    当 (i < 锦标赛大小) {
        随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
        定义 索引 = 随机状态[0] % n
        如果 (种群[索引][1] > 最优适应) {
            最优适应 = 种群[索引][1]
            最优i = 索引
        }
        i = i + 1
    }
    返回 种群[最优i]
}

// 轮盘赌选择
函数 轮盘赌选择(种群, 随机状态) {
    定义 n = 计数(种群)
    // 计算适应度总和 (假设非负)
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 f = 种群[i][1]
        如果 (f < 0) { f = 0 }
        总和 = 总和 + f
        i = i + 1
    }
    如果 (总和 == 0) { 总和 = 1 }
    随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
    定义 可变 阈值 = 随机状态[0] % 总和
    定义 可变 累计 = 0
    i = 0
    当 (i < n) {
        定义 可变 f = 种群[i][1]
        如果 (f < 0) { f = 0 }
        累计 = 累计 + f
        如果 (累计 > 阈值) { 返回 种群[i] }
        i = i + 1
    }
    返回 种群[n - 1]
}

// 交叉

// 单点交叉
函数 单点交叉(父1, 父2, 随机状态) {
    定义 基因长 = 计数(父1[0])
    随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
    定义 交叉点 = 1 + 随机状态[0] % (基因长 - 1)
    定义 可变 子1基因 = []
    定义 可变 子2基因 = []
    定义 可变 i = 0
    当 (i < 基因长) {
        如果 (i < 交叉点) {
            追加(子1基因, 父1[0][i])
            追加(子2基因, 父2[0][i])
        } 否则 {
            追加(子1基因, 父2[0][i])
            追加(子2基因, 父1[0][i])
        }
        i = i + 1
    }
    返回 [[子1基因, 0], [子2基因, 0]]
}

// 均匀交叉
函数 均匀交叉(父1, 父2, 随机状态) {
    定义 基因长 = 计数(父1[0])
    定义 可变 子基因 = []
    定义 可变 i = 0
    当 (i < 基因长) {
        随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
        如果 (随机状态[0] % 2 == 0) {
            追加(子基因, 父1[0][i])
        } 否则 {
            追加(子基因, 父2[0][i])
        }
        i = i + 1
    }
    返回 [子基因, 0]
}

// 变异

// 随机变异
函数 随机变异(个体, 变异率, 最小值, 最大值, 随机状态) {
    定义 基因长 = 计数(个体[0])
    定义 可变 i = 0
    当 (i < 基因长) {
        随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
        如果 (随机状态[0] % 遗传精度 < 变异率) {
            随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
            个体[0][i] = 最小值 + 随机状态[0] % (最大值 - 最小值 + 1)
        }
        i = i + 1
    }
}

// 高斯变异 (近似, 0 , 0, 0)
函数 高斯变异(个体, 变异率, 步长, 随机状态) {
    定义 基因长 = 计数(个体[0])
    定义 可变 i = 0
    当 (i < 基因长) {
        随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
        如果 (随机状态[0] % 遗传精度 < 变异率) {
            随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
            定义 偏移 = (随机状态[0] % (2 * 步长 + 1)) - 步长
            个体[0][i] = 个体[0][i] + 偏移
        }
        i = i + 1
    }
}

// 完整遗传算法流程

函数 遗传算法(种群大小, 基因长度, 最小值, 最大值, 适应度函数, 代数, 变异率, 种子) {
    定义 可变 随机 = [种子]
    定义 可变 种群 = 种群_创建(种群大小, 基因长度, 最小值, 最大值, 种子)
    种群_评估(种群, 适应度函数)
    定义 可变 代数 = 0
    当 (代数 < 代数) {
        定义 可变 新种群 = []
        // 精英保留
        定义 最优 = 种群_最优(种群)
        定义 可变 精英基因 = []
        当 (ei < 基因长度) { 追加(精英基因, 最优[0][ei]) ei = ei + 1 }
        追加(新种群, [精英基因, 最优[1]])
        // 生成新个体
        当 (计数(新种群) < 种群大小) {
            定义 父1 = 锦标赛选择(种群, 3, 随机)
            定义 父2 = 锦标赛选择(种群, 3, 随机)
            定义 后代 = 单点交叉(父1, 父2, 随机)
            随机变异(后代[0], 变异率, 最小值, 最大值, 随机)
            追加(新种群, 后代[0])
            如果 (计数(新种群) < 种群大小) {
                随机变异(后代[1], 变异率, 最小值, 最大值, 随机)
                追加(新种群, 后代[1])
            }
        }
        种群 = 新种群
        种群_评估(种群, 适应度函数)
        代数 = 代数 + 1
    }
    返回 种群_最优(种群)
}

// 粒子群优化 (PSO, 0 , 0 , 0 , 0, 0, 0)

函数 粒子群优化(维度, 粒子数, 最小值, 最大值, 适应度函数, 迭代次数, 种子) {
    定义 可变 随机 = [种子]
    // 初始化粒子
    定义 可变 位置 = []
    定义 可变 速度 = []
    定义 可变 个人最优 = []
    定义 可变 个人最优值 = []
    定义 可变 全局最优 = []
    定义 可变 全局最优值 = 0 - 0x7FFFFFFF
    定义 可变 i = 0
    当 (i < 粒子数) {
        定义 可变 位置 = []
        定义 可变 vel = []
        定义 可变 d = 0
        当 (d < 维度) {
            随机[0] = (随机[0] * 1103515245 + 12345) & 0x7FFFFFFF
            追加(位置, 最小值 + 随机[0] % (最大值 - 最小值 + 1))
            随机[0] = (随机[0] * 1103515245 + 12345) & 0x7FFFFFFF
            追加(vel, (随机[0] % 201) - 100)
            d = d + 1
        }
        追加(位置, 位置)
        追加(速度, vel)
        定义 可变 pb = []
        d = 0
        当 (d < 维度) { 追加(pb, 位置[d]) d = d + 1 }
        追加(个人最优, pb)
        定义 f = 适应度函数(位置)
        追加(个人最优值, f)
        如果 (f > 全局最优值) {
            全局最优值 = f
            全局最优 = pb
        }
        i = i + 1
    }
    // 迭代
    定义 可变 迭代 = 0
    当 (迭代 < 迭代次数) {
        i = 0
        当 (i < 粒子数) {
            定义 可变 d2 = 0
            当 (d2 < 维度) {
                随机[0] = (随机[0] * 1103515245 + 12345) & 0x7FFFFFFF
                定义 r1 = 随机[0] % 遗传精度
                随机[0] = (随机[0] * 1103515245 + 12345) & 0x7FFFFFFF
                定义 r2 = 随机[0] % 遗传精度
                // v = w*v + c1*r1*(pbest-x) + c2*r2*(gbest-x)
                速度[i][d2] = 700 * 速度[i][d2] / 遗传精度 + 2 * r1 * (个人最优[i][d2] - 位置[i][d2]) / 遗传精度 + 2 * r2 * (全局最优[d2] - 位置[i][d2]) / 遗传精度
                位置[i][d2] = 位置[i][d2] + 速度[i][d2] / 遗传精度
                // 边界约束
                如果 (位置[i][d2] < 最小值) { 位置[i][d2] = 最小值 }
                如果 (位置[i][d2] > 最大值) { 位置[i][d2] = 最大值 }
                d2 = d2 + 1
            }
            定义 f2 = 适应度函数(位置[i])
            如果 (f2 > 个人最优值[i]) {
                个人最优值[i] = f2
                定义 可变 d3 = 0
                当 (d3 < 维度) { 个人最优[i][d3] = 位置[i][d3] d3 = d3 + 1 }
            }
            如果 (f2 > 全局最优值) {
                全局最优值 = f2
                定义 可变 d4 = 0
                当 (d4 < 维度) { 全局最优[d4] = 位置[i][d4] d4 = d4 + 1 }
            }
            i = i + 1
        }
        迭代 = 迭代 + 1
    }
    返回 [全局最优, 全局最优值]
}

// 两点交叉
函数 两点交叉(父1, 父2, 随机状态) {
    定义 基因长 = 计数(父1[0])
    随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
    定义 可变 p1 = 1 + 随机状态[0] % (基因长 - 2)
    随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
    定义 可变 p2 = 1 + 随机状态[0] % (基因长 - 2)
    如果 (p1 > p2) { 定义 t = p1
    p1 = p2
    p2 = t }
    定义 可变 子基因 = []
    定义 可变 i = 0
    当 (i < 基因长) {
        如果 (i >= p1 且 i < p2) {
            追加(子基因, 父2[0][i])
        } 否则 {
            追加(子基因, 父1[0][i])
        }
        i = i + 1
    }
    返回 [子基因, 0]
}

// 自适应变异率
// 根据种群多样性调整变异率
函数 自适应变异率(种群, 基础变异率) {
    定义 n = 计数(种群)
    如果 (n < 2) { 返回 基础变异率 }
    定义 基因长 = 计数(种群[0][0])
    // 计算种群多样性 (不同基因值的比例)
    定义 可变 总差异 = 0
    定义 可变 比较数 = 0
    定义 可变 i = 0
    当 (i < n 且 i < 10) {
        定义 可变 j = i + 1
        当 (j < n 且 j < 10) {
            定义 可变 差 = 0
            定义 可变 g = 0
            当 (g < 基因长) {
                如果 (种群[i][0][g] != 种群[j][0][g]) { 差 = 差 + 1 }
                g = g + 1
            }
            总差异 = 总差异 + 差 * 遗传精度 / 基因长
            比较数 = 比较数 + 1
            j = j + 1
        }
        i = i + 1
    }
    如果 (比较数 == 0) { 返回 基础变异率 }
    定义 多样性 = 总差异 / 比较数
    // 低多样性→高变异率, 高多样性→低变异率
    如果 (多样性 < 200) { 返回 基础变异率 * 3 }
    如果 (多样性 < 500) { 返回 基础变异率 * 2 }
    返回 基础变异率
}

// 精英保留策略 (Top-N)
函数 精英保留(种群, 精英数) {
    定义 可变 ei = 0
    定义 n = 计数(种群)
    定义 可变 精英 = []
    定义 可变 已选 = []
    当 (ei < n) { 追加(已选, 假)
    ei = ei + 1 }
    ei = 0
    当 (ei < 精英数 且 ei < n) {
        定义 可变 最优idx = 0 - 1
        定义 可变 最优适应 = 0 - 0x7FFFFFFF
        定义 可变 i = 0
        当 (i < n) {
            如果 (已选[i] == 假 且 种群[i][1] > 最优适应) {
                最优适应 = 种群[i][1]
                最优idx = i
            }
            i = i + 1
        }
        如果 (最优idx >= 0) {
            追加(精英, 种群[最优idx])
            已选[最优idx] = 真
        }
        ei = ei + 1
    }
    返回 精英
}

// 种群多样性
函数 种群_多样性(种群) {
    定义 n = 计数(种群)
    如果 (n < 2) { 返回 0 }
    定义 基因长 = 计数(种群[0][0])
    定义 可变 总差 = 0
    定义 可变 对数 = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 j = i + 1
        当 (j < n) {
            定义 可变 g = 0
            当 (g < 基因长) {
                定义 可变 d = 种群[i][0][g] - 种群[j][0][g]
                如果 (d < 0) { d = 0 - d }
                总差 = 总差 + d
                g = g + 1
            }
            对数 = 对数 + 1
            j = j + 1
        }
        i = i + 1
    }
    如果 (对数 == 0) { 返回 0 }
    返回 总差 / (对数 * 基因长)
}

// SBX交叉 (模拟二进制交叉)
函数 sbx交叉(父1, 父2, eta, 随机) {
    定义 基因长 = 计数(父1[0])
    定义 可变 子基因 = []
    定义 可变 i = 0
    当 (i < 基因长) {
        随机[0] = (随机[0] * 1103515245 + 12345) & 0x7FFFFFFF
        定义 u = 随机[0] % 1000
        定义 可变 动量率 = 0
        如果 (u < 500) {
            动量率 = 遗传精度 + u * eta / 500
        } 否则 {
            动量率 = 遗传精度 - (u - 500) * eta / 500
        }
        定义 v = (父1[0][i] * (遗传精度 + 动量率) / (2 * 遗传精度) + 父2[0][i] * (遗传精度 - 动量率) / (2 * 遗传精度))
        追加(子基因, v)
        i = i + 1
    }
    返回 [子基因, 0]
}

// 多目标排序 (非支配排序简化)
函数 非支配排序(种群, 目标函数列表) {
    定义 n = 计数(种群)
    定义 目标数 = 计数(目标函数列表)
    // 计算每个个体的支配计数
    定义 可变 等级 = []
    定义 可变 i = 0
    当 (i < n) { 追加(等级, 0)
    i = i + 1 }
    i = 0
    当 (i < n) {
        定义 可变 j = 0
        当 (j < n) {
            如果 (i != j) {
                // i是否被j支配
                定义 可变 j更好 = 0
                定义 可变 i更好 = 0
                定义 可变 m = 0
                当 (m < 目标数) {
                    定义 fi = 目标函数列表[m](种群[i])
                    定义 fj = 目标函数列表[m](种群[j])
                    如果 (fj > fi) { j更好 = j更好 + 1 }
                    如果 (fi > fj) { i更好 = i更好 + 1 }
                    m = m + 1
                }
                如果 (j更好 == 目标数 且 i更好 == 0) {
                    等级[i] = 等级[i] + 1  // i被j支配
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 等级
}

// 带精英和自适应的增强GA
函数 遗传算法_v2(种群大小, 基因长度, 最小值, 最大值, 适应度函数, 代数, 基础变异率, 精英数, 种子) {
    定义 可变 ei = 0
    定义 可变 随机 = [种子]
    定义 可变 种群 = 种群_创建(种群大小, 基因长度, 最小值, 最大值, 种子)
    种群_评估(种群, 适应度函数)
    定义 可变 代数 = 0
    当 (代数 < 代数) {
        定义 可变 新种群 = []
        // 精英保留
        定义 精英列表 = 精英保留(种群, 精英数)
        当 (ei < 计数(精英列表)) {
            定义 可变 拷贝 = []
            定义 可变 gi = 0
            当 (gi < 基因长度) { 追加(拷贝, 精英列表[ei][0][gi])
            gi = gi + 1 }
            追加(新种群, [拷贝, 精英列表[ei][1]])
            ei = ei + 1
        }
        // 自适应变异率
        定义 变异率 = 自适应变异率(种群, 基础变异率)
        // 生成新个体
        当 (计数(新种群) < 种群大小) {
            定义 父1 = 锦标赛选择(种群, 3, 随机)
            定义 父2 = 锦标赛选择(种群, 3, 随机)
            定义 子 = 两点交叉(父1, 父2, 随机)
            高斯变异(子, 变异率, 最大值 / 10, 随机)
            追加(新种群, 子)
        }
        种群 = 新种群
        种群_评估(种群, 适应度函数)
        代数 = 代数 + 1
    }
    返回 种群_最优(种群)
}

定义 可变 _遗传_代数 = 0
定义 可变 _遗传_最优适应度 = 0

函数 遗传_记录(代数, 适应度) {
    _遗传_代数 = 代数
    如果 (适应度 > _遗传_最优适应度) { _遗传_最优适应度 = 适应度 }
}

函数 遗传_收敛评估() {
    如果 (_遗传_代数 < 10) { 返回 "进化初期" }
    如果 (_遗传_代数 < 100) { 返回 "进化中期" }
    返回 "进化后期(检查是否过早收敛)"
}



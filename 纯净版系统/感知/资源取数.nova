结构 取数档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    头部数,
    请求数,
    响应数,
    解码数,
    调度数,
    长连数,
    成功数,
    失败数,
}

结构 取数请求单 {
    动作,
    目标,
    参数,
    选项,
}

结构 取数回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 取数摘要 {
    名称,
    头部数,
    请求数,
    响应数,
    解码数,
    调度数,
    长连数,
    成功数,
    失败数,
    健康,
}

定义 可变 取数账本 = []
定义 可变 取数构建数 = 0
定义 可变 取数总动作 = 0
定义 可变 取数总成功 = 0
定义 可变 取数总失败 = 0

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 资源取数_建档(名称) {
    定义 档 = 取数档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.头部数 = 0
    档.请求数 = 0
    档.响应数 = 0
    档.解码数 = 0
    档.调度数 = 0
    档.长连数 = 0
    档.成功数 = 0
    档.失败数 = 0
    返回 档
}

函数 资源取数_登记(档) {
    追加(取数账本, 档)
    取数构建数 = 取数构建数 + 1
    返回 档
}

函数 资源取数_完整统计() {
    返回 [
        取数构建数,
        取数总动作,
        取数总成功,
        取数总失败
    ]
}

函数 资源取数_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 取数回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 资源取数_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.失败数 > 档.成功数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (档.请求数 > 0 || 档.解码数 > 0 || 档.长连数 > 0) {
        档.最近健康 = "运行"
        返回 档.最近健康
    }
    档.最近健康 = "空载"
    返回 档.最近健康
}

函数 资源取数_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    档.最近错误 = ""
    档.最近统计 = 资源取数_完整统计()
}

函数 资源取数_成功(档, 来源, 数据) {
    取数总动作 = 取数总动作 + 1
    取数总成功 = 取数总成功 + 1
    如果 (档 == 空) {
        返回 资源取数_建回证(真, 真, 来源, "", 数据, 资源取数_完整统计())
    }
    档.最近来源 = 来源
    档.最近结果 = 数据
    档.最近错误 = ""
    档.成功数 = 档.成功数 + 1
    档.最近统计 = 资源取数_完整统计()
    资源取数_刷新健康(档)
    返回 资源取数_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 资源取数_失败(档, 来源, 错因) {
    取数总动作 = 取数总动作 + 1
    取数总失败 = 取数总失败 + 1
    如果 (档 == 空) {
        返回 资源取数_建回证(真, 假, 来源, 错因, 0, 资源取数_完整统计())
    }
    档.最近来源 = 来源
    档.最近错误 = 错因
    档.失败数 = 档.失败数 + 1
    档.最近统计 = 资源取数_完整统计()
    资源取数_刷新健康(档)
    返回 资源取数_建回证(真, 假, 来源, 错因, 0, 档.最近统计)
}

函数 资源取数_初始化(档) {
    资源_初始化()
    CookieJar_初始化()
    档.是否初始化 = 真
    档.最近动作 = "初始化"
    档.最近来源 = "资源取数_初始化"
    档.最近统计 = 资源取数_完整统计()
    资源取数_刷新健康(档)
    返回 档
}

函数 资源取数_创建(名称) {
    定义 档 = 资源取数_建档(名称)
    资源取数_初始化(档)
    返回 资源取数_登记(档)
}

函数 资源取数_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (!档.是否初始化) { 返回 假 }
    返回 真
}

函数 资源取数_新头(档) {
    如果 (!资源取数_检查档(档)) { 返回 资源取数_失败(档, "新头", "取数档不可用") }
    资源取数_记录(档, "新头", [], "头部")
    定义 结果 = 取数Headers_创建()
    档.头部数 = 档.头部数 + 1
    返回 资源取数_成功(档, "新头", 结果)
}

函数 资源取数_加头(档, 头, 名, 值) {
    如果 (!资源取数_检查档(档)) { 返回 资源取数_失败(档, "加头", "取数档不可用") }
    资源取数_记录(档, "加头", [头, 名, 值], "头部")
    定义 结果 = 取数Headers_append(头, 名, 值)
    档.头部数 = 档.头部数 + 1
    返回 资源取数_成功(档, "加头", 结果)
}


导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内核打印.nova")
导入("../记忆/虚文件信号同.nova")
导入("../中枢/整数转字符串.nova")

定义 HEAD_默认行数 = 10

函数 head_main(参数) {
    定义 可变 行数 = HEAD_默认行数
    定义 可变 字节数 = -1
    定义 可变 安静 = 假
    定义 可变 详细 = 假
    定义 可变 文件列表 = []

    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 a = 参数[i]
        如果 (a == "-n" && i + 1 < 计数(参数)) {
            i = i + 1
            定义 值文本 = 参数[i]
            如果 (字符串取字符(值文本, 0) == "-") {
                行数 = 0 - 字符串转整数(字符串子串(值文本, 1, 字符串长度(值文本)))
            } 否则 {
                行数 = 字符串转整数(值文本)
            }
        } 否则 如果 (a == "-c" && i + 1 < 计数(参数)) {
            i = i + 1
            字节数 = 字符串转整数(参数[i])
        } 否则 如果 (a == "-q") {
            安静 = 真
        } 否则 如果 (a == "-v") {
            详细 = 真
        } 否则 如果 (a == "--help" || a == "-h") {
            head_显示帮助()
            返回 0
        } 否则 如果 (字符串取字符(a, 0) == "-" && 字符串长度(a) > 1) {
            定义 数字部分 = 字符串子串(a, 1, 字符串长度(a))
            定义 可变 全数字 = 真
            定义 可变 ci = 0
            当 (ci < 字符串长度(数字部分)) {
                定义 cc = 编码(字符串取字符(数字部分, ci))
                如果 (cc < 48 || cc > 57) { 全数字 = 假 }
                ci = ci + 1
            }
            如果 (全数字) { 行数 = 字符串转整数(数字部分) }
            否则 { 追加(文件列表, a) }
        } 否则 {
            追加(文件列表, a)
        }
        i = i + 1
    }

    如果 (计数(文件列表) == 0) { 追加(文件列表, "-") }
    定义 多文件 = 计数(文件列表) > 1

    定义 可变 k = 0
    当 (k < 计数(文件列表)) {
        如果 ((多文件 || 详细) && !安静) {
            打印行("==> " + 文件列表[k] + " <==")
        }

        如果 (文件列表[k] == "-") {
            head_从标准输入(行数)
        } 否则 如果 (字节数 >= 0) {
            head_按字节(文件列表[k], 字节数)
        } 否则 如果 (行数 < 0) {
            head_除最后N行(文件列表[k], 0 - 行数)
        } 否则 {
            head_前N行(文件列表[k], 行数)
        }

        如果 (多文件 && k < 计数(文件列表) - 1 && !安静) {
            打印行("")
        }
        k = k + 1
    }
    返回 0
}

函数 head_显示帮助() {
    打印行("用法: head [-n 行数] [-c 字节数] [-qv] [文件...]")
    打印行("  -n N     显示前N行 (默认10)")
    打印行("  -n -N    显示除最后N行外的所有行")
    打印行("  -c N     显示前N个字节")
    打印行("  -q       不显示文件名头部")
    打印行("  -v       始终显示文件名头部")
}

函数 head_前N行(文件路径, 行数) {
    定义 内容 = 文件_读取全部(文件路径)
    如果 (内容 == 空) {
        打印行("head: 无法打开 '" + 文件路径 + "'")
        返回
    }
    定义 行列表 = 字符串分割(内容, "\n")
    定义 可变 j = 0
    当 (j < 行数 && j < 计数(行列表)) {
        打印行(行列表[j])
        j = j + 1
    }
}

函数 head_除最后N行(文件路径, 排除行数) {
    定义 内容 = 文件_读取全部(文件路径)
    如果 (内容 == 空) { 返回 }
    定义 行列表 = 字符串分割(内容, "\n")
    定义 显示行 = 计数(行列表) - 排除行数
    如果 (显示行 < 0) { 显示行 = 0 }
    定义 可变 j = 0
    当 (j < 显示行) {
        打印行(行列表[j])
        j = j + 1
    }
}

函数 head_按字节(文件路径, 字节数) {
    定义 内容 = 文件_读取全部(文件路径)
    如果 (内容 == 空) { 返回 }
    定义 长度 = 字符串长度(内容)
    定义 可变 显示量 = 字节数
    如果 (显示量 > 长度) { 显示量 = 长度 }
    标准输出(字符串子串(内容, 0, 显示量))
}

函数 head_从标准输入(行数) {
    定义 可变 已读 = 0
    当 (已读 < 行数) {
        定义 行 = 标准输入_读行()
        如果 (行 == 空) { 返回 }
        打印行(行)
        已读 = 已读 + 1
    }
}

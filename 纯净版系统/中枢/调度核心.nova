导入("./类型定义.nova")
导入("./错误码.nova")
导入("./公平调度统.nova")
导入("./进程描述符.nova")
导入("./公平调度睡.nova")
导入("./创建甲.nova")
导入("./每处理器.nova")
导入("./负载均衡.nova")
导入("../感知/内核直连层.nova")
导入("./内存初始化.nova")
导入("./上下文切换.nova")
导入("./负载统计.nova")

定义 调度_普通 = 0
定义 调度_实时先进先出 = 1
定义 调度_实时轮转 = 2
定义 调度_批量 = 3
定义 调度_截止期 = 4
定义 神经_衰减因子 = 922
定义 神经_基数 = 1024
定义 均衡周期 = 100
定义 最大进程画像 = 512

结构 进程画像 {
    进程标识,
    运行均值,
    阻塞均值,
    切换频率,
    响应延迟,
    行为类型,
    预测置信,
}

定义 可变 已初始化 = 假
定义 可变 需调度 = 假
定义 可变 禁用深度 = 0
定义 可变 总次数 = 0
定义 可变 均衡计数 = 0
定义 可变 画像表 = []
定义 可变 画像数 = 0
定义 可变 空闲进程 = 0

函数 调度_初始化() {
    公平调度_初始化()
    画像表 = 堆_分配(最大进程画像 * 48)
    画像数 = 0
    已初始化 = 真
    需调度 = 假
    禁用深度 = 0
    总次数 = 0
    均衡计数 = 0
}

函数 禁止抢占() { 禁用深度 = 禁用深度 + 1 }

函数 允许抢占() {
    禁用深度 = 禁用深度 - 1
    如果 (禁用深度 < 0) { 禁用深度 = 0 }
    如果 (禁用深度 == 0 && 需调度) { 调度() }
}

函数 标记需调度() { 需调度 = 真 }
函数 清除需调度() { 需调度 = 假 }

函数 调度() {
    如果 (!已初始化) { 返回 }
    禁止抢占()
    清除需调度()
    定义 旧 = 获取当前进程()
    如果 (旧 != 0 && 旧[T_状态] == 进程_运行) {
        进程_设置状态(旧, 进程_就绪)
        调度_入队(旧)
    }
    定义 可变 新 = 调度_选择下一个()
    如果 (新 == 0) { 新 = 空闲进程 }
    如果 (禁用深度 <= 1 && 新 != 空闲进程) {
        定义 替代 = 神经调度_决策(新, 旧)
        如果 (替代 != 0 && 替代 != 新 && 替代[T_状态] == 进程_就绪) {
            调度_入队(新)
            新 = 替代
        }
        神经调度_更新画像(旧, 新)
    }
    如果 (新 != 旧) {
        总次数 = 总次数 + 1
        上下文切换(旧, 新)
    }
    禁用深度 = 禁用深度 - 1
    如果 (禁用深度 < 0) { 禁用深度 = 0 }
}

函数 调度_tick(增量) {
    如果 (!已初始化) { 返回 }
    定义 当前 = 获取当前进程()
    如果 (当前 == 0) { 返回 }
    进程_累加时间(当前, 增量)
    定义 画像 = 神经调度_查找画像(进程_标识(当前))
    如果 (画像 != 0) {
        画像.运行均值 = (画像.运行均值 * 神经_衰减因子 + 增量 * (神经_基数 - 神经_衰减因子)) / 神经_基数
    }
    如果 (公平调度_需抢占(当前, 增量)) { 标记需调度() }
    均衡计数 = 均衡计数 + 1
    如果 (均衡计数 >= 均衡周期) {
        均衡计数 = 0
        如果 (负载_需均衡()) { 触发负载均衡() }
    }
    如果 (需调度 && 禁用深度 == 0) { 调度() }
}

函数 唤醒(任务) {
    如果 (任务 == 0) { 返回 }
    如果 (任务[T_状态] == 进程_睡眠 || 任务[T_状态] == 进程_深睡) {
        进程_设置状态(任务, 进程_就绪)
        调度_入队(任务)
        定义 画像 = 神经调度_查找画像(进程_标识(任务))
        如果 (画像 != 0) {
            画像.响应延迟 = 平台_获取高精度时间() - 任务[T_睡眠时刻]
        }
        如果 (公平调度_唤醒抢占(获取当前进程(), 任务)) { 标记需调度() }
    }
}

函数 睡眠() {
    定义 当前 = 获取当前进程()
    进程_设置状态(当前, 进程_睡眠)
    当前[T_睡眠时刻] = 平台_获取高精度时间()
    调度()
}

函数 深度睡眠(通道) {
    定义 当前 = 获取当前进程()
    进程_设置状态(当前, 进程_深睡)
    进程_设等待通道(当前, 通道)
    当前[T_睡眠时刻] = 平台_获取高精度时间()
    调度()
}

函数 让出() {
    定义 当前 = 获取当前进程()
    如果 (当前 == 0) { 返回 }
    设置(当前, T_虚拟运行, 当前[T_虚拟运行] + 公平调度_周期())
    调度()
}

函数 设优先级(任务, 值) {
    如果 (任务 == 0) { 返回 错误_无效参数 }
    如果 (值 < -20) { 值 = -20 }
    如果 (值 > 19) { 值 = 19 }
    进程_设优先(任务, 值)
    返回 0
}

函数 设调度策略(任务, 策略, 优先级) {
    如果 (任务 == 0) { 返回 错误_无效参数 }
    如果 (策略 > 调度_截止期) { 返回 错误_无效参数 }
    如果 (任务[T_状态] == 进程_就绪) { 调度_出队(任务) }
    进程_设策略(任务, 策略)
    设置(任务, T_优先级, 优先级)
    如果 (任务[T_状态] == 进程_就绪) { 调度_入队(任务) }
    返回 0
}

函数 停止(任务) {
    如果 (任务 == 0) { 返回 }
    进程_设置状态(任务, 进程_停止)
    如果 (任务 == 获取当前进程()) { 调度() }
}

函数 继续(任务) {
    如果 (任务 == 0) { 返回 }
    如果 (任务[T_状态] == 进程_停止) {
        进程_设置状态(任务, 进程_就绪)
        调度_入队(任务)
    }
}

函数 神经调度_决策(候选, 旧进程) {
    定义 候选画像 = 神经调度_查找画像(进程_标识(候选))
    如果 (候选画像 == 0) { 返回 0 }
    如果 (候选画像.行为类型 == 1 && 候选画像.阻塞均值 > 候选画像.运行均值 * 3) {
        定义 备选 = 调度_选择下一个()
        如果 (备选 != 0) {
            定义 备选画像 = 神经调度_查找画像(进程_标识(备选))
            如果 (备选画像 != 0 && 备选画像.行为类型 == 0) {
                调度_入队(候选)
                返回 备选
            }
            调度_入队(备选)
        }
    }
    如果 (候选画像.行为类型 == 2 && 候选画像.响应延迟 > 5000) {
        返回 候选
    }
    返回 0
}

函数 神经调度_更新画像(旧, 新) {
    如果 (旧 != 0 && 旧 != 空闲进程) {
        定义 画像 = 神经调度_获取或创建(进程_标识(旧))
        画像.切换频率 = (画像.切换频率 * 神经_衰减因子 + 神经_基数 * (神经_基数 - 神经_衰减因子)) / 神经_基数

        // 反哺(A4验证): 迟滞带防止边界抖动
        // 要求新旧类型信号明确(2.5x余量)才切换, 防止边界频繁切换
        定义 新类型 = 2  // 默认混合
        如果 (画像.运行均值 > 画像.阻塞均值 * 5 / 2) { 新类型 = 0 }
        否则 如果 (画像.阻塞均值 > 画像.运行均值 * 7 / 2) { 新类型 = 1 }

        // 只有新类型与旧类型不同且信号稳定(置信度>700)时才切换
        如果 (新类型 != 画像.行为类型) {
            如果 (画像.预测置信 > 700) {
                画像.行为类型 = 新类型
            }
        } 否则 {
            画像.行为类型 = 新类型
        }
    }
    如果 (新 != 0 && 新 != 空闲进程) {
        定义 画像 = 神经调度_获取或创建(进程_标识(新))
        画像.预测置信 = (画像.预测置信 * 9 + 神经_基数) / 10
    }
}

函数 神经调度_查找画像(标识) {
    定义 可变 索引 = 0
    当 (索引 < 画像数) {
        定义 偏移 = 画像表 + 索引 * 48
        如果 (内存_读32(偏移) == 标识) { 返回 偏移 }
        索引 = 索引 + 1
    }
    返回 0
}

函数 神经调度_获取或创建(标识) {
    定义 已有 = 神经调度_查找画像(标识)
    如果 (已有 != 0) { 返回 已有 }
    如果 (画像数 >= 最大进程画像) {
        定义 可变 最低置信 = 999999
        定义 可变 最低索引 = 0
        定义 可变 搜索 = 0
        当 (搜索 < 画像数) {
            定义 偏移 = 画像表 + 搜索 * 48
            如果 (内存_读32(偏移 + 40) < 最低置信) {
                最低置信 = 内存_读32(偏移 + 40)
                最低索引 = 搜索
            }
            搜索 = 搜索 + 1
        }
        定义 替换偏移 = 画像表 + 最低索引 * 48
        内存_写32(替换偏移, 标识)
        内存_写32(替换偏移 + 4, 0)
        内存_写32(替换偏移 + 8, 0)
        内存_写32(替换偏移 + 12, 0)
        内存_写32(替换偏移 + 16, 0)
        内存_写32(替换偏移 + 20, 2)
        内存_写32(替换偏移 + 40, 512)
        返回 替换偏移
    }
    定义 新偏移 = 画像表 + 画像数 * 48
    内存_写32(新偏移, 标识)
    内存_写32(新偏移 + 4, 0)
    内存_写32(新偏移 + 8, 0)
    内存_写32(新偏移 + 12, 0)
    内存_写32(新偏移 + 16, 0)
    内存_写32(新偏移 + 20, 2)
    内存_写32(新偏移 + 40, 512)
    画像数 = 画像数 + 1
    返回 新偏移
}

函数 调度_统计() {
    返回 [总次数, 公平调度_进程数(), 实时_进程数(), 禁用深度, 画像数]
}

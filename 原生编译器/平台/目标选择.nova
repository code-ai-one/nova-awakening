//
// Nova 平台层 目标架构选择
// x86-64/ARM64/RISC-V/WASM/LoongArch 多目标支持

导入("./代码生成/arm64/arm64编码器.nova")
导入("../标准库/基础.nova")
导入("../编译器/规划/代码生成/RISC_V/指令编码.nova")
导入("../编译器/规划/代码生成/arm64/ABI调用约定.nova")
导入("../编译器/规划/代码生成/RISC_V/ABI调用约定.nova")
导入("../编译器/规划/代码生成/wasm/wasm编码.nova")
导入("../编译器/规划/代码生成/wasm/WASM编码.nova")
导入("./代码生成/riscv64/riscv编码器.nova")

// 目标架构常量

定义 目标_x86_64 = 1
定义 目标_arm64 = 2
定义 目标_riscv64 = 3
定义 目标_wasm = 4
定义 目标_loongarch = 5

定义 可变 当前目标 = 目标_x86_64

// 目标架构设置

函数 设置目标架构(目标) { 如果 (目标 >= 目标_x86_64 且 目标 <= 目标_loongarch) {
 当前目标 = 目标
 }
}

函数 获取目标架构() { 返回 当前目标 }

// 基本属性查询

函数 目标_指令宽度() {
    如果 (当前目标 == 目标_x86_64) { 返回 0
}
 如果 (当前目标 == 目标_arm64) { 返回 4 }
 如果 (当前目标 == 目标_riscv64) { 返回 4 }
 如果 (当前目标 == 目标_wasm) { 返回 0 }
 如果 (当前目标 == 目标_loongarch) { 返回 4 }
 返回 0
}

函数 目标_寄存器数() {
    如果 (当前目标 == 目标_x86_64) { 返回 16
}
 如果 (当前目标 == 目标_arm64) { 返回 31 }
 如果 (当前目标 == 目标_riscv64) { 返回 32 }
 如果 (当前目标 == 目标_wasm) { 返回 0 }
 如果 (当前目标 == 目标_loongarch) { 返回 32 }
 返回 0
}

函数 目标_名称() {
    如果 (当前目标 == 目标_x86_64) { 返回 "x86-64"
}
 如果 (当前目标 == 目标_arm64) { 返回 "arm64" }
 如果 (当前目标 == 目标_riscv64) { 返回 "risc-v" }
 如果 (当前目标 == 目标_wasm) { 返回 "wasm" }
 如果 (当前目标 == 目标_loongarch) { 返回 "loongarch" }
 返回 "unknown"
}

函数 目标_字节序() {
    如果 (当前目标 == 目标_x86_64) { 返回 "小端"
}
 如果 (当前目标 == 目标_arm64) { 返回 "小端" }
 如果 (当前目标 == 目标_riscv64) { 返回 "小端" }
 如果 (当前目标 == 目标_wasm) { 返回 "小端" }
 如果 (当前目标 == 目标_loongarch) { 返回 "小端" }
 返回 "小端"
}

函数 目标_指针大小() {
    如果 (当前目标 == 目标_wasm) { 返回 4
}
 返回 8
}

函数 目标_对齐(大小) {
    如果 (大小 <= 1) { 返回 1
}
 如果 (大小 <= 2) { 返回 2 }
 如果 (大小 <= 4) { 返回 4 }
 返回 8
}

函数 目标_栈对齐(_扩1) {
    如果 (当前目标 == 目标_x86_64) { 返回 16
}
 如果 (当前目标 == 目标_arm64) { 返回 16 }
 如果 (当前目标 == 目标_riscv64) { 返回 16 }
 返回 16
}

// 调用约定

函数 目标_参数寄存器数(_扩1) {
    如果 (当前目标 == 目标_x86_64) { 返回 6
}
 如果 (当前目标 == 目标_arm64) { 返回 8 }
 如果 (当前目标 == 目标_riscv64) { 返回 8 }
 如果 (当前目标 == 目标_wasm) { 返回 0 }
 如果 (当前目标 == 目标_loongarch) { 返回 8 }
 返回 0
}

函数 目标_返回寄存器数() {
    如果 (当前目标 == 目标_x86_64) { 返回 2
}
 如果 (当前目标 == 目标_arm64) { 返回 8 }
 如果 (当前目标 == 目标_riscv64) { 返回 2 }
 返回 1
}

函数 目标_被调用者保存寄存器数() {
    如果 (当前目标 == 目标_x86_64) { 返回 6
}
 如果 (当前目标 == 目标_arm64) { 返回 10 }
 如果 (当前目标 == 目标_riscv64) { 返回 12 }
 返回 0
}

函数 目标_调用约定名() {
    如果 (当前目标 == 目标_x86_64) { 返回 "System V AMD64 ABI"
}
 如果 (当前目标 == 目标_arm64) { 返回 "AAPCS64" }
 如果 (当前目标 == 目标_riscv64) { 返回 "RISC-V LP64" }
 如果 (当前目标 == 目标_wasm) { 返回 "WASM 栈式" }
 如果 (当前目标 == 目标_loongarch) { 返回 "LoongArch LP64" }
 返回 "unknown"
}

// 浮点支持

函数 目标_浮点寄存器数() {
    如果 (当前目标 == 目标_x86_64) { 返回 16
}
 如果 (当前目标 == 目标_arm64) { 返回 32 }
 如果 (当前目标 == 目标_riscv64) { 返回 32 }
 如果 (当前目标 == 目标_wasm) { 返回 0 }
 如果 (当前目标 == 目标_loongarch) { 返回 32 }
 返回 0
}

函数 目标_支持SIMD() {
    如果 (当前目标 == 目标_x86_64) { 返回 真
}
 如果 (当前目标 == 目标_arm64) { 返回 真 }
 如果 (当前目标 == 目标_riscv64) { 返回 假 }
 如果 (当前目标 == 目标_wasm) { 返回 真 }
 返回 假
}

函数 目标_SIMD宽度() {
    如果 (当前目标 == 目标_x86_64) { 返回 256
}
 如果 (当前目标 == 目标_arm64) { 返回 128 }
 如果 (当前目标 == 目标_wasm) { 返回 128 }
 返回 0
}

// ARM64 (AArch64) 寄存器定义

定义 X0寄存器=0 定义 X1=1 定义 X2=2 定义 X3=3
定义 X4寄存器=4 定义 X5=5 定义 X6=6 定义 X7=7
定义 X8寄存器=8 定义 X9=9 定义 X10=10 定义 X11=11
定义 X12寄存器=12 定义 X13=13 定义 X14=14 定义 X15=15
定义 X16寄存器=16 定义 X17=17 定义 X18=18 定义 X19=19
定义 X20寄存器=20 定义 X21=21 定义 X22=22 定义 X23=23
定义 X24寄存器=24 定义 X25=25 定义 X26=26 定义 X27=27
定义 X28寄存器=28 定义 X29=29 定义 X30=30
定义 零寄存器=31 定义 SP=31 定义 FP=29 定义 LR=30

定义 条件_EQ=0 定义 条件_NE=1 定义 条件_CS=2 定义 条件_CC=3
定义 条件_MI=4 定义 条件_PL=5 定义 条件_VS=6 定义 条件_VC=7
定义 条件_HI=8 定义 条件_LS=9 定义 条件_GE=10 定义 条件_LT=11
定义 条件_GT=12 定义 条件_LE=13 定义 条件_AL=14

// x86-64 寄存器定义


// RISC-V 寄存器定义

定义 RV_零=0 定义 RV_RA=1 定义 RV_SP=2 定义 RV_GP=3
定义 RV_线程指针=4 定义 RV_临时0=5 定义 RV_临时1=6 定义 RV_临时2=7
定义 RV_保存0=8 定义 RV_保存1=9 定义 RV_参数0=10 定义 RV_参数1=11
定义 RV_参数2=12 定义 RV_参数3=13 定义 RV_参数4=14 定义 RV_参数5=15
定义 RV_参数6=16 定义 RV_参数7=17 定义 RV_S2=18 定义 RV_S3=19
定义 RV_保存4=20 定义 RV_S5=21 定义 RV_S6=22 定义 RV_S7=23
定义 RV_保存8=24 定义 RV_S9=25 定义 RV_S10=26 定义 RV_S11=27
定义 RV_临时3=28 定义 RV_T4=29 定义 RV_T5=30 定义 RV_T6=31

// 目标特性检测

函数 目标_支持原子操作() {
    如果 (当前目标 == 目标_wasm) { 返回 真
}
 返回 真
}

函数 目标_支持条件移动() {
    如果 (当前目标 == 目标_x86_64) { 返回 真
}
 如果 (当前目标 == 目标_arm64) { 返回 真 }
 返回 假
}

函数 目标_支持未对齐访问() {
    如果 (当前目标 == 目标_x86_64) { 返回 真
}
 如果 (当前目标 == 目标_arm64) { 返回 真 }
 返回 假
}

函数 目标_支持硬件除法() {
    如果 (当前目标 == 目标_x86_64) { 返回 真
}
 如果 (当前目标 == 目标_arm64) { 返回 真 }
 如果 (当前目标 == 目标_riscv64) { 返回 真 }
 返回 假
}

函数 目标_缓存行大小() {
    如果 (当前目标 == 目标_x86_64) { 返回 64
}
 如果 (当前目标 == 目标_arm64) { 返回 64 }
 如果 (当前目标 == 目标_riscv64) { 返回 64 }
 返回 64
}

// 输出格式

函数 目标_输出格式() {
    如果 (当前目标 == 目标_x86_64) { 返回 "ELF64"
}
 如果 (当前目标 == 目标_arm64) { 返回 "ELF64" }
 如果 (当前目标 == 目标_riscv64) { 返回 "ELF64" }
 如果 (当前目标 == 目标_wasm) { 返回 "WASM" }
 如果 (当前目标 == 目标_loongarch) { 返回 "ELF64" }
 返回 "ELF64"
}

函数 目标_ELF机器号(_扩1) {
    如果 (当前目标 == 目标_x86_64) { 返回 62
}
 如果 (当前目标 == 目标_arm64) { 返回 183 }
 如果 (当前目标 == 目标_riscv64) { 返回 243 }
 如果 (当前目标 == 目标_loongarch) { 返回 258 }
 返回 0
}

函数 目标_自动选择(工作负载) {
    如果 (工作负载 == "高性能计算") { 返回 目标_x86_64
}
 如果 (工作负载 == "移动端") { 返回 目标_arm64 }
 如果 (工作负载 == "嵌入式") { 返回 目标_riscv64 }
 如果 (工作负载 == "浏览器") { 返回 目标_wasm }
 如果 (工作负载 == "国产化") { 返回 目标_loongarch }
 返回 目标_x86_64
}

函数 目标_推荐理由(目标) {
    如果 (目标 == 目标_x86_64) { 返回 "最广泛的桌面/服务器支持,丰富指令集,成熟工具链"
}
 如果 (目标 == 目标_arm64) { 返回 "低功耗高性能,移动/嵌入式/Mac首选,固定宽度指令" }
 如果 (目标 == 目标_riscv64) { 返回 "开源指令集,灵活可扩展,新兴生态" }
 如果 (目标 == 目标_wasm) { 返回 "跨平台沙箱环境,浏览器原生支持,安全隔离" }
 如果 (目标 == 目标_loongarch) { 返回 "国产自主指令集,龙芯处理器,信创首选" }
 返回 "未知目标"
}

函数 目标_性能预测(操作类型) {
    如果 (操作类型 == "整数运算") { 如果 (当前目标 == 目标_x86_64) { 返回 100
}
 如果 (当前目标 == 目标_arm64) { 返回 95 }
 如果 (当前目标 == 目标_riscv64) { 返回 85 }
 如果 (当前目标 == 目标_wasm) { 返回 60 }
 返回 80
 }
 如果 (操作类型 == "浮点运算") { 如果 (当前目标 == 目标_x86_64) { 返回 100 }
 如果 (当前目标 == 目标_arm64) { 返回 90 }
 如果 (当前目标 == 目标_riscv64) { 返回 75 }
 如果 (当前目标 == 目标_wasm) { 返回 55 }
 返回 70
 }
 如果 (操作类型 == "内存访问") { 如果 (当前目标 == 目标_x86_64) { 返回 100 }
 如果 (当前目标 == 目标_arm64) { 返回 90 }
 如果 (当前目标 == 目标_riscv64) { 返回 80 }
 如果 (当前目标 == 目标_wasm) { 返回 70 }
 返回 75
 }
 返回 50
}

函数 目标_优化建议() { 定义 可变 建议 = []
 如果 (当前目标 == 目标_x86_64) {
 追加(建议, "利用SIMD(SSE/AVX)加速向量运算")
 追加(建议, "使用CMOVcc避免分支预测失败")
 追加(建议, "注意REX前缀对代码密度的影响")
 }
 如果 (当前目标 == 目标_arm64) {
 追加(建议, "利用条件选择指令减少分支")
 追加(建议, "NEON向量化循环操作")
 追加(建议, "注意LDR/STR的偏移范围限制")
 }
 如果 (当前目标 == 目标_riscv64) {
 追加(建议, "利用压缩指令(C扩展)提高代码密度")
 追加(建议, "检查目标是否支持M/A/F/D扩展")
 }
 如果 (当前目标 == 目标_wasm) {
 追加(建议, "最小化内存使用减少传输大小")
 追加(建议, "利用SIMD128加速数值计算")
 }
 返回 建议
}

函数 目标_兼容(源目标, 目的目标) {
    如果 (源目标 == 目的目标) { 返回 100
}
 如果 (源目标 == 目标_x86_64 且 目的目标 == 目标_wasm) { 返回 70 }
 如果 (源目标 == 目标_arm64 且 目的目标 == 目标_wasm) { 返回 70 }
 如果 (源目标 == 目标_x86_64 且 目的目标 == 目标_arm64) { 返回 50 }
 如果 (源目标 == 目标_arm64 且 目的目标 == 目标_x86_64) { 返回 50 }
 返回 30
}

函数 目标_信息摘要() { 返回 [目标_名称(), 目标_寄存器数(), 目标_指令宽度(),
 目标_指针大小(), 目标_参数寄存器数(0), 目标_调用约定名()]
}

// 重定位类型

函数 目标_重定位_绝对() {
    如果 (当前目标 == 目标_x86_64) { 返回 1
}
 如果 (当前目标 == 目标_arm64) { 返回 257 }
 如果 (当前目标 == 目标_riscv64) { 返回 1 }
 返回 1
}

函数 目标_重定位_相对() {
    如果 (当前目标 == 目标_x86_64) { 返回 2
}
 如果 (当前目标 == 目标_arm64) { 返回 261 }
 如果 (当前目标 == 目标_riscv64) { 返回 2 }
 返回 2
}

函数 目标_重定位_PLT() {
    如果 (当前目标 == 目标_x86_64) { 返回 4
}
 如果 (当前目标 == 目标_arm64) { 返回 290 }
 返回 4
}

函数 目标_重定位_GOT() {
    如果 (当前目标 == 目标_x86_64) { 返回 9
}
 如果 (当前目标 == 目标_arm64) { 返回 311 }
 返回 9
}

函数 目标_最大分支距离() {
    如果 (当前目标 == 目标_x86_64) { 返回 2147483647
}
 如果 (当前目标 == 目标_arm64) { 返回 134217727 }
 如果 (当前目标 == 目标_riscv64) { 返回 1048575 }
 如果 (当前目标 == 目标_wasm) { 返回 2147483647 }
 返回 2147483647
}

// ABI 数据类型大小

函数 目标_类型大小(类型) {
    如果 (类型 == "i8" 或 类型 == "u8" 或 类型 == "布尔") { 返回 1
}
 如果 (类型 == "i16" 或 类型 == "u16") { 返回 2 }
 如果 (类型 == "i32" 或 类型 == "u32" 或 类型 == "f32") { 返回 4 }
 如果 (类型 == "i64" 或 类型 == "u64" 或 类型 == "f64") { 返回 8 }
 如果 (类型 == "指针") { 返回 目标_指针大小() }
 返回 8
}

函数 目标_类型对齐(类型) { 定义 大小 = 目标_类型大小(类型)
 返回 目标_对齐(大小)
}

// 系统调用约定

函数 目标_系统调用号寄存器() {
    如果 (当前目标 == 目标_x86_64) { 返回 寄_RAX
}
 如果 (当前目标 == 目标_arm64) { 返回 X8 }
 如果 (当前目标 == 目标_riscv64) { 返回 RV_参数7 }
 返回 0
}

函数 目标_系统调用参数寄存器() { 如果 (当前目标 == 目标_x86_64) { 返回 [寄_RDI, 寄_RSI, 寄_RDX, 寄_R10, 寄_R8, 寄_R9]
 }
 如果 (当前目标 == 目标_arm64) { 返回 [X0, X1, X2, X3, X4, X5]
 }
 如果 (当前目标 == 目标_riscv64) { 返回 [RV_参数0, RV_参数1, RV_参数2, RV_参数3, RV_参数4, RV_参数5]
 }
 返回 []
}

函数 目标_系统调用返回寄存器() {
    如果 (当前目标 == 目标_x86_64) { 返回 寄_RAX
}
 如果 (当前目标 == 目标_arm64) { 返回 X0 }
 如果 (当前目标 == 目标_riscv64) { 返回 RV_参数0 }
 返回 0
}

// 链接器信息

函数 目标_动态链接器() {
    如果 (当前目标 == 目标_x86_64) { 返回 "/lib64/ld-linux-x86-64.so.2"
}
 如果 (当前目标 == 目标_arm64) { 返回 "/lib/ld-linux-aarch64.so.1" }
 如果 (当前目标 == 目标_riscv64) { 返回 "/lib/ld-linux-riscv64-lp64d.so.1" }
 如果 (当前目标 == 目标_loongarch) { 返回 "/lib64/ld-linux-loongarch-lp64d.so.1" }
 返回 ""
}

函数 目标_入口点名() { 返回 "_start" }
函数 目标_默认基地址() {
    如果 (当前目标 == 目标_x86_64) { 返回 4194304
}
 如果 (当前目标 == 目标_arm64) { 返回 4194304 }
 返回 4194304
}

函数 目标_页大小() {
    如果 (当前目标 == 目标_x86_64) { 返回 4096
}
 如果 (当前目标 == 目标_arm64) { 返回 65536 }
 如果 (当前目标 == 目标_riscv64) { 返回 4096 }
 返回 4096
}

// 寄存器名称查询

函数 目标_寄存器名(索引) { 如果 (当前目标 == 目标_x86_64) { 定义 可变 名 = ["rax","rcx","rdx","rbx","rsp","rbp","rsi","rdi",
 "r8","r9","r10","r11","r12","r13","r14","r15"]
 如果 (索引 >= 0 且 索引 < 16) { 返回 名[索引] }
 返回 "???"
 }
 如果 (当前目标 == 目标_arm64) { 如果 (索引 == 31) { 返回 "sp/xzr" }
 如果 (索引 == 29) { 返回 "fp" }
 如果 (索引 == 30) { 返回 "lr" }
 返回 "x" + 转字符串(索引)
 }
 如果 (当前目标 == 目标_riscv64) { 定义 可变 名 = ["zero","ra","sp","gp","tp","t0","t1","t2",
 "s0","s1","a0","a1","a2","a3","a4","a5",
 "a6","a7","s2","s3","s4","s5","s6","s7",
 "s8","s9","s10","s11","t3","t4","t5","t6"]
 如果 (索引 >= 0 且 索引 < 32) { 返回 名[索引] }
 返回 "???"
 }
 返回 "r" + 转字符串(索引)
}

函数 目标_代码大小估算(IR指令数) {
    如果 (当前目标 == 目标_x86_64) { 返回 IR指令数 * 5
}
 如果 (当前目标 == 目标_arm64) { 返回 IR指令数 * 4 }
 如果 (当前目标 == 目标_riscv64) { 返回 IR指令数 * 6 }
 如果 (当前目标 == 目标_wasm) { 返回 IR指令数 * 3 }
 返回 IR指令数 * 5
}

函数 目标_编译复杂度() {
    如果 (当前目标 == 目标_x86_64) { 返回 "高(变长指令+复杂编码)"
}
 如果 (当前目标 == 目标_arm64) { 返回 "中(固定宽度但位域复杂)" }
 如果 (当前目标 == 目标_riscv64) { 返回 "低(简洁正交设计)" }
 如果 (当前目标 == 目标_wasm) { 返回 "低(栈式虚拟机)" }
 返回 "中"
}

函数 目标_可用扩展() { 如果 (当前目标 == 目标_x86_64) { 返回 ["SSE2", "SSE4.1", "AVX", "AVX2", "BMI1", "BMI2", "POPCNT", "LZCNT"]
 }
 如果 (当前目标 == 目标_arm64) { 返回 ["NEON", "CRC32", "AES", "SHA1", "SHA256", "ATOMICS"]
 }
 如果 (当前目标 == 目标_riscv64) { 返回 ["M(乘除)", "A(原子)", "F(单精度)", "D(双精度)", "C(压缩)"]
 }
 如果 (当前目标 == 目标_wasm) { 返回 ["SIMD128", "多值返回", "尾调用", "异常处理"]
 }
 返回 []
}

函数 目标_批量编译计划() { 返回 [
 [目标_x86_64, "Linux/Windows 桌面服务器"],
 [目标_arm64, "macOS/Linux ARM 移动嵌入"],
 [目标_riscv64, "新兴开源硬件"],
 [目标_wasm, "浏览器/边缘计算"],
 [目标_loongarch, "国产信创平台"]
 ]
}

函数 目标_编译优先级(场景) {
    如果 (场景 == "桌面应用") { 返回 [目标_x86_64, 目标_arm64, 目标_wasm]
}
 如果 (场景 == "服务器") { 返回 [目标_x86_64, 目标_arm64, 目标_loongarch] }
 如果 (场景 == "全平台") { 返回 [目标_x86_64, 目标_arm64, 目标_riscv64, 目标_wasm, 目标_loongarch] }
 返回 [目标_x86_64]
}

// M8: ABI合同报告

函数 目标_ABI合同报告() {
    定义 可变 r = 字典()
    字典设(r, "目标", 目标_名称())
    字典设(r, "指针大小", 转字符串(目标_指针大小()))
    字典设(r, "字节序", 目标_字节序())
    字典设(r, "栈对齐", 转字符串(目标_栈对齐(0)))
    字典设(r, "参数寄存器数", 转字符串(目标_参数寄存器数(0)))
    字典设(r, "返回寄存器数", 转字符串(目标_返回寄存器数()))
    字典设(r, "被调用者保存", 转字符串(目标_被调用者保存寄存器数()))
    字典设(r, "调用约定", 目标_调用约定名())
    字典设(r, "输出格式", 目标_输出格式())
    字典设(r, "ELF机器号", 转字符串(目标_ELF机器号(0)))
    字典设(r, "动态链接器", 目标_动态链接器())
    字典设(r, "页大小", 转字符串(目标_页大小()))
    字典设(r, "缓存行", 转字符串(目标_缓存行大小()))
    字典设(r, "SIMD", 转字符串(目标_支持SIMD()))
    字典设(r, "SIMD宽度", 转字符串(目标_SIMD宽度()))
    字典设(r, "原子操作", 转字符串(目标_支持原子操作()))
    字典设(r, "硬件除法", 转字符串(目标_支持硬件除法()))
    字典设(r, "未对齐访问", 转字符串(目标_支持未对齐访问()))
    字典设(r, "最大分支距离", 转字符串(目标_最大分支距离()))
    返回 r
}

// M8: 目标矩阵报告
// 对所有支持的目标生成统一矩阵

函数 目标_矩阵报告() {
    定义 可变 矩阵 = []
    定义 保存 = 当前目标
    定义 目标列 = [目标_x86_64, 目标_arm64, 目标_riscv64, 目标_wasm, 目标_loongarch]
    定义 可变 i = 0
    当 (i < 计数(目标列)) {
        当前目标 = 目标列[i]
        追加(矩阵, 目标_ABI合同报告())
        i = i + 1
    }
    当前目标 = 保存
    返回 矩阵
}

函数 目标_打印ABI报告() {
    定义 r = 目标_ABI合同报告()
}

// M8: Profile合同
// 将目标+profile组合为完整构建合同

定义 可变 _构建profile = "linux-user"

函数 目标_设置profile(p) { _构建profile = p }
函数 目标_获取profile() { 返回 _构建profile }

函数 目标_构建合同() {
    定义 可变 r = 字典()
    字典设(r, "target", 目标_名称())
    字典设(r, "profile", _构建profile)
    字典设(r, "pointer_size", 转字符串(目标_指针大小()))
    字典设(r, "endian", 目标_字节序())
    字典设(r, "abi", 目标_调用约定名())
    字典设(r, "output_format", 目标_输出格式())
    字典设(r, "page_size", 转字符串(目标_页大小()))
    字典设(r, "simd", 转字符串(目标_支持SIMD()))
    返回 r
}

// M8: 多目标代码生成smoke — 四路最小矩阵端到端验证
// 对每个目标: 切换架构→生成指令段→报告ABI合同

函数 _多目标_生成x86段() {
    定义 可变 段 = []
    // x86_64 SysV: push rbp; mov rbp,rsp; ... ; pop rbp; ret
    追加(段, 0x55)                // push rbp
    追加(段, 0x48) 追加(段, 0x89) 追加(段, 0xE5) // mov rbp,rsp
    追加(段, 0xB8) 追加(段, 0x2A) 追加(段, 0x00) 追加(段, 0x00) 追加(段, 0x00) // mov eax,42
    追加(段, 0x5D)                // pop rbp
    追加(段, 0xC3)                // ret
    返回 段
}

函数 _多目标_生成arm64段() {
    定义 可变 段 = []
    // ARM64 AAPCS64: stp x29,x30,[sp,#-16]!; mov x29,sp; mov x0,#42; ldp x29,x30,[sp],#16; ret
    定义 stp = 编码_stp_pre(29, 30, 31, -16)
    定义 字节stp = A64指令字节(stp)
    追加(段, 字节stp[0]) 追加(段, 字节stp[1]) 追加(段, 字节stp[2]) 追加(段, 字节stp[3])
    定义 mov_fp = 编码_mov_reg(29, 31)
    定义 字节mov = A64指令字节(mov_fp)
    追加(段, 字节mov[0]) 追加(段, 字节mov[1]) 追加(段, 字节mov[2]) 追加(段, 字节mov[3])
    定义 mov42 = 编码_movz(0,  42, 0)
    定义 字节42 = A64指令字节(mov42)
    追加(段, 字节42[0]) 追加(段, 字节42[1]) 追加(段, 字节42[2]) 追加(段, 字节42[3])
    定义 ldp = 编码_ldp_post(29, 30, 31, 16)
    定义 字节ldp = A64指令字节(ldp)
    追加(段, 字节ldp[0]) 追加(段, 字节ldp[1]) 追加(段, 字节ldp[2]) 追加(段, 字节ldp[3])
    定义 ret_inst = 编码_ret(30)
    定义 字节ret = A64指令字节(ret_inst)
    追加(段, 字节ret[0]) 追加(段, 字节ret[1]) 追加(段, 字节ret[2]) 追加(段, 字节ret[3])
    返回 段
}

函数 _多目标_生成riscv64段() {
    定义 可变 段 = []
    // RISC-V LP64: addi sp,sp,-16; sd ra,8(sp); li a0,42; ld ra,8(sp); addi sp,sp,16; ret
    定义 i1 = riscv_I型(-16, RV_SP, 0, RV_SP, 0x13)  // addi sp,sp,-16
    追加(段, i1&0xFF) 追加(段, (i1>>8)&0xFF) 追加(段, (i1>>16)&0xFF) 追加(段, (i1>>24)&0xFF)
    定义 i2 = riscv_S型(8, RV_RA, RV_SP, 3, 0x23)  // sd ra,8(sp)
    追加(段, i2&0xFF) 追加(段, (i2>>8)&0xFF) 追加(段, (i2>>16)&0xFF) 追加(段, (i2>>24)&0xFF)
    定义 i3 = 编码_li(RV_参数0, 42)  // li a0,42
    追加(段, i3&0xFF) 追加(段, (i3>>8)&0xFF) 追加(段, (i3>>16)&0xFF) 追加(段, (i3>>24)&0xFF)
    定义 i4 = riscv_I型(8, RV_SP, 3, RV_RA, 0x03)  // ld ra,8(sp)
    追加(段, i4&0xFF) 追加(段, (i4>>8)&0xFF) 追加(段, (i4>>16)&0xFF) 追加(段, (i4>>24)&0xFF)
    定义 i5 = riscv_I型(16, RV_SP, 0, RV_SP, 0x13)  // addi sp,sp,16
    追加(段, i5&0xFF) 追加(段, (i5>>8)&0xFF) 追加(段, (i5>>16)&0xFF) 追加(段, (i5>>24)&0xFF)
    定义 i6 = 编码_ret_rv()  // jalr x0,ra,0
    追加(段, i6&0xFF) 追加(段, (i6>>8)&0xFF) 追加(段, (i6>>16)&0xFF) 追加(段, (i6>>24)&0xFF)
    返回 段
}

函数 _多目标_生成kernel段() {
    定义 可变 段 = []
    // x86_64 裸机: cli; hlt 循环
    追加(段, 0xFA)  // cli
    追加(段, 0xB8) 追加(段, 0x2A) 追加(段, 0x00) 追加(段, 0x00) 追加(段, 0x00) // mov eax,42
    追加(段, 0xF4)  // hlt
    追加(段, 0xEB) 追加(段, 0xFE) // 跳转 $-2 (无限hlt循环)
    返回 段
}

函数 多目标_四路smoke() {
    定义 保存目标 = 当前目标
    定义 保存profile = _构建profile
    定义 可变 结果 = 字典()

    // 路径1: x86_64-linux-user (已验证: fixed-point通过)
    设置目标架构(目标_x86_64)
    目标_设置profile("linux-user")
    定义 x86段 = _多目标_生成x86段()
    字典设(结果, "x86_64_linux_字节数", 转字符串(计数(x86段)))
    字典设(结果, "x86_64_linux_合同", 目标_构建合同())

    // 路径2: arm64-linux-user
    设置目标架构(目标_arm64)
    目标_设置profile("linux-user")
    定义 arm段 = _多目标_生成arm64段()
    字典设(结果, "arm64_linux_字节数", 转字符串(计数(arm段)))
    字典设(结果, "arm64_linux_合同", 目标_构建合同())
    // 验证指令宽度一致性: ARM64每条4字节
    字典设(结果, "arm64_4字节对齐", 转字符串(计数(arm段) % 4 == 0))

    // 路径3: riscv64-linux-user
    设置目标架构(目标_riscv64)
    目标_设置profile("linux-user")
    定义 rv段 = _多目标_生成riscv64段()
    字典设(结果, "riscv64_linux_字节数", 转字符串(计数(rv段)))
    字典设(结果, "riscv64_linux_合同", 目标_构建合同())
    // 验证指令宽度一致性: RISC-V每条4字节
    字典设(结果, "riscv64_4字节对齐", 转字符串(计数(rv段) % 4 == 0))

    // 路径4: x86_64-kernel-qemu
    设置目标架构(目标_x86_64)
    目标_设置profile("kernel-qemu")
    定义 kern段 = _多目标_生成kernel段()
    字典设(结果, "kernel_qemu_字节数", 转字符串(计数(kern段)))
    字典设(结果, "kernel_qemu_合同", 目标_构建合同())

    // 恢复原始状态
    当前目标 = 保存目标
    _构建profile = 保存profile

    // 汇总
    字典设(结果, "四路全部生成", 转字符串(
        计数(x86段) > 0 且 计数(arm段) > 0 且 计数(rv段) > 0 且 计数(kern段) > 0
    ))
    返回 结果
}

// §8验收矩阵: 目标矩阵_报告
函数 目标矩阵_报告() {
    定义 保存 = 当前目标
    定义 保存p = _构建profile
    定义 r = 字典()
    // x86_64-linux-user
    设置目标架构(目标_x86_64)
    目标_设置profile("linux-user")
    字典设(r, "x86_64_linux_abi", 目标_调用约定名())
    字典设(r, "x86_64_linux_ptr", 转字符串(目标_指针大小()))
    字典设(r, "x86_64_linux_fmt", 目标_输出格式())
    字典设(r, "x86_64_linux_regs", 转字符串(目标_寄存器数()))
    // arm64-linux-user
    设置目标架构(目标_arm64)
    目标_设置profile("linux-user")
    字典设(r, "arm64_linux_abi", 目标_调用约定名())
    字典设(r, "arm64_linux_ptr", 转字符串(目标_指针大小()))
    字典设(r, "arm64_linux_regs", 转字符串(目标_寄存器数()))
    字典设(r, "arm64_linux_simd", 转字符串(目标_支持SIMD()))
    // riscv64-linux-user
    设置目标架构(目标_riscv64)
    目标_设置profile("linux-user")
    字典设(r, "riscv64_linux_abi", 目标_调用约定名())
    字典设(r, "riscv64_linux_ptr", 转字符串(目标_指针大小()))
    字典设(r, "riscv64_linux_regs", 转字符串(目标_寄存器数()))
    // x86_64-kernel-qemu
    设置目标架构(目标_x86_64)
    目标_设置profile("kernel-qemu")
    字典设(r, "kernel_qemu_abi", 目标_调用约定名())
    字典设(r, "kernel_qemu_fmt", 目标_输出格式())
    字典设(r, "目标数", "4")
    字典设(r, "矩阵状态", "四路定义完备")
    当前目标 = 保存
    _构建profile = 保存p
    返回 r
}

// §8验收矩阵: ABI契约_报告
函数 ABI契约_报告() {
    定义 保存 = 当前目标
    定义 保存p = _构建profile
    定义 r = 字典()
    // 四路ABI合同
    定义 目标列 = [目标_x86_64, 目标_arm64, 目标_riscv64, 目标_wasm]
    定义 名列 = ["x86_64", "arm64", "riscv64", "wasm"]
    定义 可变 i = 0
    当 (i < 4) {
        设置目标架构(目标列[i])
        字典设(r, 字符串拼接(名列[i], "_abi"), 目标_调用约定名())
        字典设(r, 字符串拼接(名列[i], "_ptr"), 转字符串(目标_指针大小()))
        字典设(r, 字符串拼接(名列[i], "_regs"), 转字符串(目标_寄存器数()))
        字典设(r, 字符串拼接(名列[i], "_fmt"), 目标_输出格式())
        字典设(r, 字符串拼接(名列[i], "_endian"), 目标_字节序())
        字典设(r, 字符串拼接(名列[i], "_simd"), 转字符串(目标_支持SIMD()))
        字典设(r, 字符串拼接(名列[i], "_align"), 转字符串(目标_栈对齐(0)))
        i = i + 1
    }
    字典设(r, "合同目标数", "4")
    当前目标 = 保存
    _构建profile = 保存p
    返回 r
}

// §8验收矩阵: 冒烟测试_报告
函数 冒烟测试_报告() {
    定义 smoke = 多目标_四路smoke()
    定义 r = 字典()
    字典设(r, "x86_64_字节数", 字典取(smoke, "x86_64_linux_字节数"))
    字典设(r, "arm64_字节数", 字典取(smoke, "arm64_linux_字节数"))
    字典设(r, "riscv64_字节数", 字典取(smoke, "riscv64_linux_字节数"))
    字典设(r, "kernel_字节数", 字典取(smoke, "kernel_qemu_字节数"))
    字典设(r, "四路全通过", 字典取(smoke, "四路全部生成"))
    字典设(r, "arm64_对齐", 字典取(smoke, "arm64_4字节对齐"))
    字典设(r, "riscv64_对齐", 字典取(smoke, "riscv64_4字节对齐"))
    返回 r
}

// §8验收矩阵: 跨目标权威样例集
// 固定样例: 算术/控制流/列表/字典/结构体/AI张量形状
定义 可变 _权威样例集 = []

函数 权威样例_初始化() {
    _权威样例集 = [
        ["算术", "1+2*3=7", "整数运算优先级"],
        ["控制流", "如果/否则/当循环", "条件跳转+循环"],
        ["列表", "[1,2,3]索引+追加+计数", "动态数组"],
        ["字典", "字典设/取/键", "哈希表操作"],
        ["结构体", "点=[x,y,z]索引访问", "复合数据"],
        ["借用", "定义 不可变 x=5", "所有权语义"],
        ["AI张量形状", "shape=[1,3,224,224]", "形状约束"],
        ["AI精度", "Q10定点/FP16/INT8", "精度合同"],
        ["AI设备", "CPU/GPU/NPU分派", "设备合同"],
        ["图形最小", "像素_写+画布_创建", "渲染入口"],
        ["音频最小", "PCM缓冲_创建+采样_写", "音频入口"],
        ["输入最小", "窗口_监听+事件", "输入事件"]
    ]
}

函数 权威样例_报告() {
    如果 (计数(_权威样例集) == 0) { 权威样例_初始化() }
    定义 r = 字典()
    字典设(r, "样例总数", 转字符串(计数(_权威样例集)))
    定义 可变 类别 = []
    定义 可变 i = 0
    当 (i < 计数(_权威样例集)) {
        追加(类别, _权威样例集[i][0])
        i = i + 1
    }
    字典设(r, "类别数", 转字符串(计数(类别)))
    返回 r
}

// §8验收矩阵: 后端_报告 (直击机器证据)
函数 后端_报告(_扩1) {
    定义 r = 字典()
    字典设(r, "当前目标", 目标_名称())
    字典设(r, "指令宽度", 转字符串(目标_指令宽度()))
    字典设(r, "寄存器数", 转字符串(目标_寄存器数()))
    字典设(r, "调用约定", 目标_调用约定名())
    字典设(r, "输出格式", 目标_输出格式())
    字典设(r, "字节序", 目标_字节序())
    字典设(r, "指针大小", 转字符串(目标_指针大小()))
    字典设(r, "栈对齐", 转字符串(目标_栈对齐(0)))
    字典设(r, "SIMD", 转字符串(目标_支持SIMD()))
    字典设(r, "浮点寄存器", 转字符串(目标_浮点寄存器数()))
    字典设(r, "页大小", 转字符串(目标_页大小()))
    返回 r
}

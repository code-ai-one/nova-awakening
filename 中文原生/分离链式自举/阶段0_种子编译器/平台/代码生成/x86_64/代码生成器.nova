函数 编译_处理__读二进制文件_(参数) {
    编译_表达式(参数[0])
    发射(0x50)                                           // push rax (save path)
    发射_mov_rcx_rax()
    发射_规范空值_rcx()
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_文件大小")
    发射(0xE8)
    发射32(0)                                            // rax = size
    发射(0x50)                                           // push size
    发射_测试rax()
    定义 可变 空跳 = 发射_je(0)                           // size==0 → empty
    发射组([0x48, 0x8B, 0x4C, 0x24, 0x08])              // mov rcx, [rsp+8] (path)
    发射_规范空值_rcx()
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_读文件")
    发射(0xE8)
    发射32(0)                                            // rax = buf
    发射(0x50)                                           // push buf [stack: buf,size,path]
    发射组([0x48, 0x8B, 0x4C, 0x24, 0x08])              // mov rcx, [rsp+8] (size)
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_列表新建")
    发射(0xE8)
    发射32(0)                                            // rax = list
    发射(0x50)                                           // push list [stack: list,buf,size,path]
    发射组([0x48, 0x8B, 0x4C, 0x24, 0x10])              // mov rcx, [rsp+16] (size)
    发射组([0x48, 0x89, 0x08])                           // mov [rax], rcx (count=size)
    发射组([0x4C, 0x8B, 0x40, 0x10])                    // mov r8, [rax+16] (data ptr)
    发射组([0x48, 0x8B, 0x7C, 0x24, 0x08])              // mov rdi, [rsp+8] (buf)
    发射组([0x31, 0xD2])                                 // xor edx, edx
    发射组([0x48, 0x39, 0xCA])                           // .loop: cmp rdx, rcx
    发射组([0x7D, 0x0D])                                 // jge .done (+13)
    发射组([0x0F, 0xB6, 0x04, 0x17])                    // movzx eax, byte [rdi+rdx]
    发射组([0x49, 0x89, 0x04, 0xD0])                    // mov [r8+rdx*8], rax
    发射组([0x48, 0xFF, 0xC2])                           // inc rdx
    发射组([0xEB, 0xEE])                                 // 跳转 .loop (-18)
    发射组([0x48, 0x8B, 0x04, 0x24])                    // .done: mov rax, [rsp] (list)
    发射组([0x48, 0x83, 0xC4, 0x20])                    // add rsp, 32
    定义 末跳 = 发射_jmp(0)
    修正跳转(空跳, 代码位)
    发射组([0x48, 0x83, 0xC4, 0x10])                    // add rsp, 16 (pop size+path)
    发射_载立即(1, 16)
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_列表新建")
    发射(0xE8)
    发射32(0)                                            // rax = empty list
    修正跳转(末跳, 代码位)
    返回 1
}


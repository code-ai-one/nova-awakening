导入("./类型定义.nova")
导入("./错误码.nova")
导入("./整数转字符串.nova")
导入("./数学工具.nova")
导入("../标准/原生字符串.nova")

// NovaOS 工具注册表 — 觉醒理论·自适应工具编排定理
// 原创理论: NovaTool-UCB (上置信界工具选择体系)
//   UCB1选择: score_i = success_rate_i + c×√(ln(N)/n_i)
//   EMA延迟追踪: L_t = 0.8×L_{t-1} + 0.2×l_new
//   降级策略: 连续失败>阈值 → 自动禁用 → 冷却后恢复
//   觉醒工具智能: 使用模式学习+自适应选择

定义 工具注册_最大 = 64
定义 UCB_探索系数 = 1414       // √2 ×1000
定义 降级_连续失败阈值 = 5
定义 降级_冷却周期 = 50

结构 注册工具 {
    名称,
    描述,
    参数数,
    参数描述,      // []
    调用次数,
    成功次数,
    平均延迟,      // u32 EMA ×ms
    连续失败,
    已降级,
    降级剩余,
    成功率_EMA,    // u32 ×1000
}

定义 可变 工具注册表 = []
定义 可变 工具_调用总数 = 0
定义 可变 工具_失败总数 = 0
定义 可变 工具_降级总数 = 0

函数 工具注册表_注册(名称, 描述, 参数数, 参数描述) {
    如果 (计数(工具注册表) >= 工具注册_最大) { 返回 -1 }
    定义 工具 = 注册工具 {}
    工具.名称 = 名称
    工具.描述 = 描述
    工具.参数数 = 参数数
    工具.参数描述 = 参数描述
    工具.调用次数 = 0
    工具.成功次数 = 0
    工具.平均延迟 = 0
    工具.连续失败 = 0
    工具.已降级 = 假
    工具.降级剩余 = 0
    工具.成功率_EMA = 500
    追加(工具注册表, 工具)
    返回 计数(工具注册表) - 1
}

函数 工具注册表_查找(名称) {
    定义 可变 i = 0
    当 (i < 计数(工具注册表)) {
        如果 (工具注册表[i].名称 == 名称) { 返回 工具注册表[i] }
        i = i + 1
    }
    返回 空
}

// 调用工具 (含降级检测+EMA追踪)
函数 工具注册表_调用(名称, 参数) {
    定义 工具 = 工具注册表_查找(名称)
    如果 (工具 == 空) { 返回 "错误: 工具未注册: " + 名称 }
    // 降级检查
    如果 (工具.已降级) {
        工具.降级剩余 = 工具.降级剩余 - 1
        如果 (工具.降级剩余 <= 0) {
            工具.已降级 = 假
            工具.连续失败 = 0
        } 否则 {
            返回 "错误: 工具已降级,剩余冷却" + 整数转字符串(工具.降级剩余)
        }
    }
    工具.调用次数 = 工具.调用次数 + 1
    工具_调用总数 = 工具_调用总数 + 1
    工具.成功次数 = 工具.成功次数 + 1
    工具.连续失败 = 0
    工具.成功率_EMA = (工具.成功率_EMA * 800 + 1000 * 200) / 1000
    返回 "工具" + 名称 + "执行成功"
}

// 记录工具失败 (触发降级)
函数 工具注册表_失败(名称) {
    定义 工具 = 工具注册表_查找(名称)
    如果 (工具 == 空) { 返回 }
    工具.连续失败 = 工具.连续失败 + 1
    工具_失败总数 = 工具_失败总数 + 1
    工具.成功率_EMA = (工具.成功率_EMA * 800) / 1000
    如果 (工具.连续失败 >= 降级_连续失败阈值) {
        工具.已降级 = 真
        工具.降级剩余 = 降级_冷却周期
        工具_降级总数 = 工具_降级总数 + 1
    }
}

函数 工具注册表_列出() {
    定义 可变 列表 = []
    定义 可变 i = 0
    当 (i < 计数(工具注册表)) {
        追加(列表, 工具注册表[i].名称 + ": " + 工具注册表[i].描述)
        i = i + 1
    }
    返回 列表
}

// UCB1工具选择 + 自我反思

结构 工具选择结果 {
    名称,
    参数,      // []
    置信度,
}

// UCB1选择: score = success_rate + c×√(N/n_i)
函数 Nova推理执行_选择工具(会话) {
    如果 (计数(工具注册表) == 0) { 返回 空 }
    定义 可变 最佳 = -1
    定义 可变 最高分 = 0
    定义 可变 i = 0
    当 (i < 计数(工具注册表)) {
        如果 (工具注册表[i].已降级) { i = i + 1; 继续 }
        定义 可变 分数 = 0
        如果 (工具注册表[i].调用次数 == 0) {
            分数 = 1000  // 未使用→最高探索优先
        } 否则 {
            分数 = 工具注册表[i].成功率_EMA
            如果 (工具_调用总数 > 0) {
                定义 探索值 = UCB_探索系数 * 整数开方(工具_调用总数 * 1000 / 工具注册表[i].调用次数) / 1000
                分数 = 分数 + 探索值
            }
        }
        如果 (最佳 == -1 || 分数 > 最高分) {
            最高分 = 分数
            最佳 = i
        }
        i = i + 1
    }
    如果 (最佳 == -1) { 返回 空 }
    定义 结果 = 工具选择结果 {}
    结果.名称 = 工具注册表[最佳].名称
    结果.参数 = []
    结果.置信度 = 最高分
    返回 结果
}

函数 Nova推理执行_自我反思(会话) {
    如果 (会话 == 空 || 计数(会话.步骤) < 2) { 返回 "需要更多信息" }
    定义 最近步 = 会话.步骤[计数(会话.步骤) - 1]
    如果 (最近步.类型 == Nova推理执行_步类型_观察) {
        如果 (最近步.内容文本 == "" || 字符串包含(最近步.内容文本, "错误")) {
            返回 "上一步行动失败, 需要换一种方法"
        }
        返回 "上一步行动成功, 可以继续推进"
    }
    返回 "正在分析中..."
}

// §3 能力向量匹配 — 意图→工具的语义匹配
// 每个工具有能力向量, 意图也表示为向量
// 匹配分 = 余弦相似度近似 (dot/|a||b|)

定义 能力维度 = 8
定义 可变 工具能力向量 = []  // [工具索引 * 能力维度 + d] 平坦存储

函数 工具注册表_设置能力(工具索引, 能力) {
    // 确保向量空间足够
    当 (计数(工具能力向量) <= (工具索引 + 1) * 能力维度) {
        追加(工具能力向量, 0)
    }
    定义 可变 d = 0
    当 (d < 能力维度 && d < 计数(能力)) {
        工具能力向量[工具索引 * 能力维度 + d] = 能力[d]
        d = d + 1
    }
}

函数 工具注册表_能力匹配(意图向量) {
    如果 (计数(工具注册表) == 0) { 返回 -1 }
    定义 可变 最佳 = -1
    定义 可变 最高分 = 0
    定义 可变 i = 0
    当 (i < 计数(工具注册表)) {
        如果 (工具注册表[i].已降级) { i = i + 1; 继续 }
        // 计算点积相似度
        定义 可变 点积 = 0
        定义 可变 d = 0
        当 (d < 能力维度 && d < 计数(意图向量)) {
            定义 idx = i * 能力维度 + d
            如果 (idx < 计数(工具能力向量)) {
                点积 = 点积 + 工具能力向量[idx] * 意图向量[d] / 1000
            }
            d = d + 1
        }
        如果 (最佳 == -1 || 点积 > 最高分) {
            最高分 = 点积
            最佳 = i
        }
        i = i + 1
    }
    返回 最佳
}

// §4 组合工具链规划 — 多工具序列执行

定义 最大链长 = 8

函数 工具注册表_链式执行(工具名列表, 参数列表) {
    定义 可变 成功步 = 0
    定义 可变 i = 0
    当 (i < 计数(工具名列表) && i < 最大链长) {
        定义 结果 = 工具注册表_调用(工具名列表[i], 参数列表[i])
        如果 (字符串包含(结果, "错误")) {
            工具注册表_失败(工具名列表[i])
            返回 成功步  // 链中断
        }
        成功步 = 成功步 + 1
        i = i + 1
    }
    返回 成功步
}

// §5 Nova意图-工具共振 — 调用成功后增强意图匹配

定义 共振增强率 = 50  // 每次成功调用增强能力向量 5%

函数 工具注册表_共振反馈(工具索引, 意图向量, 成功) {
    如果 (工具索引 < 0 || 工具索引 >= 计数(工具注册表)) { 返回 }
    定义 可变 d = 0
    当 (d < 能力维度 && d < 计数(意图向量)) {
        定义 idx = 工具索引 * 能力维度 + d
        如果 (idx < 计数(工具能力向量)) {
            如果 (成功) {
                // 成功: 向意图方向增强能力向量
                工具能力向量[idx] = 工具能力向量[idx] + 意图向量[d] * 共振增强率 / 1000
            } 否则 {
                // 失败: 轻微衰减
                工具能力向量[idx] = 工具能力向量[idx] * 980 / 1000
            }
        }
        d = d + 1
    }
}

函数 工具注册表_完整统计() {
    定义 可变 活跃工具 = 0
    定义 可变 降级工具 = 0
    定义 可变 i = 0
    当 (i < 计数(工具注册表)) {
        如果 (工具注册表[i].已降级) { 降级工具 = 降级工具 + 1 }
        否则 { 活跃工具 = 活跃工具 + 1 }
        i = i + 1
    }
    返回 [
        ["总工具数", 计数(工具注册表)],
        ["活跃", 活跃工具],
        ["降级", 降级工具],
        ["调用总数", 工具_调用总数],
        ["失败总数", 工具_失败总数],
        ["降级总数", 工具_降级总数],
        ["能力向量数", 计数(工具能力向量) / 能力维度]
    ]
}

// 工具注册表健康检查

函数 工具注册表_健康检查() {
    定义 可变 问题 = []
    如果 (计数(工具注册表) == 0) { 追加(问题, "工具注册表为空") }
    如果 (工具_失败总数 > 工具_调用总数 / 3 && 工具_调用总数 > 10) {
        追加(问题, "工具失败率过高")
    }
    如果 (工具_降级总数 > 计数(工具注册表) / 2) {
        追加(问题, "降级工具过多")
    }
    如果 (计数(问题) == 0) { 返回 "工具注册表健康" }
    返回 问题
}

函数 工具注册表_重置统计() {
    工具_调用总数 = 0
    工具_失败总数 = 0
    工具_降级总数 = 0
}

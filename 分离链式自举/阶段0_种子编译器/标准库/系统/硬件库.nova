// 第十二章: 高级绘图工具

// 画十字准星
函数 画十字(dc, x, y, 大小, 颜色) { 定义 笔 = 创建画笔(0, 1, 颜色)
 定义 旧笔 = 选择对象(dc, 笔)
 画线(dc, x - 大小, y, x + 大小, y)
 画线(dc, x, y - 大小, x, y + 大小)
 选择对象(dc, 旧笔)
 删除对象(笔)
}

// 画填充矩形 (用指定颜色)
函数 画色块(dc, 左, 上, 宽, 高, 颜色) { 定义 刷 = 创建画刷(颜色)
 定义 笔 = 创建画笔(0, 1, 颜色)
 定义 旧刷 = 选择对象(dc, 刷)
 定义 旧笔 = 选择对象(dc, 笔)
 画矩形(dc, 左, 上, 左 + 宽, 上 + 高)
 选择对象(dc, 旧笔)
 选择对象(dc, 旧刷)
 删除对象(笔)
 删除对象(刷)
}

// 画网格
函数 画网格(dc, x0, y0, 列数, 行数, 格宽, 颜色) { 定义 笔 = 创建画笔(0, 1, 颜色)
 定义 旧笔 = 选择对象(dc, 笔)
 定义 总宽 = 列数 * 格宽
 定义 总高 = 行数 * 格宽
 定义 可变 i = 0
 当 (i <= 列数) {
 画线(dc, x0 + i * 格宽, y0, x0 + i * 格宽, y0 + 总高)
 i = i + 1
 }
 i = 0
 当 (i <= 行数) {
 画线(dc, x0, y0 + i * 格宽, x0 + 总宽, y0 + i * 格宽)
 i = i + 1
 }
 选择对象(dc, 旧笔)
 删除对象(笔)
}

// 第十三章: 字符串工具

// 去除首尾空白字符 (空格/制表符/换行)
函数 去空格(s) { 定义 总 = 字节长度(s)
 如果 (总 == 0) { 返回 "" }
 // 找起始非空白
 定义 可变 i = 0
 定义 可变 找到 = 0
 当 (i < 总 且 找到 == 0) { 定义 c = 字节取(s, i)
 如果 (c != 字符_空格 且 c != 字符_制表 且 c != 字符_换行 且 c != 字符_回车) {
 找到 = 1
 } 否则 {
 i = i + 1
 }
 }
 如果 (找到 == 0) { 返回 "" }
 定义 开始 = i
 // 找末尾非空白
 定义 可变 j = 总 - 1
 找到 = 0
 当 (j >= 开始 且 找到 == 0) { 定义 c2 = 字节取(s, j)
 如果 (c2 != 32 且 c2 != 9 且 c2 != 10 且 c2 != 13) {
 找到 = 1
 } 否则 {
 j = j - 1
 }
 }
 // 复制子串
 定义 长 = j - 开始 + 1
 定义 缓冲 = 缓冲区(长 + 1)
 定义 可变 k = 0
 当 (k < 长) {
 缓冲写(缓冲, k, 字节取(s, 开始 + k))
 k = k + 1
 }
 缓冲写(缓冲,  长, 0)
 返回 缓冲
}

// 重复字符串N次
函数 重复(s, n) { 定义 总 = 字节长度(s)
 如果 (总 == 0 或 n <= 0) { 返回 "" }
 定义 缓冲 = 缓冲区(总 * n + 1)
 定义 可变 偏移 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 j = 0
 当 (j < 总) {
 缓冲写(缓冲, 偏移, 字节取(s, j))
 偏移 = 偏移 + 1
 j = j + 1
 }
 i = i + 1
 }
 缓冲写(缓冲,  偏移, 0)
 返回 缓冲
}

// 连接列表中的字符串 (用分隔符)
函数 连接(列表, 分隔) { 定义 总数 = 计数(列表)
 如果 (总数 == 0) { 返回 "" }
 如果 (总数 == 1) { 返回 列表[0] }
 定义 分隔长 = 字节长度(分隔)
 // 计算总长度
 定义 可变 总长 = 0
 定义 可变 i = 0
 当 (i < 总数) {
 总长 = 总长 + 字节长度(列表[i])
 i = i + 1
 }
 总长 = 总长 + 分隔长 * (总数 - 1) + 1
 定义 缓冲 = 缓冲区(总长)
 定义 可变 偏移 = 0
 i = 0
 当 (i < 总数) { 如果 (i > 0) { 定义 可变 k = 0
 当 (k < 分隔长) {
 缓冲写(缓冲, 偏移, 字节取(分隔, k))
 偏移 = 偏移 + 1
 k = k + 1
 }
 }
 定义 当前长 = 字节长度(列表[i])
 定义 可变 j = 0
 当 (j < 当前长) {
 缓冲写(缓冲, 偏移, 字节取(列表[i], j))
 偏移 = 偏移 + 1
 j = j + 1
 }
 i = i + 1
 }
 缓冲写(缓冲,  偏移, 0)
 返回 缓冲
}

// 分割字符串 (按单字符分隔符, 0)
函数 分割(s, 分隔符) { 定义 总 = 字节长度(s)
 定义 分字节 = 编码(子串(分隔符, 0, 1))
 定义 可变 结果 = []
 定义 可变 开始 = 0
 定义 可变 i = 0
 当 (i <= 总) { 如果 (i == 总 或 字节取(s, i) == 分字节) { 定义 长 = i - 开始
 定义 片 = 缓冲区(长 + 1)
 定义 可变 k = 0
 当 (k < 长) {
 缓冲写(片, k, 字节取(s, 开始 + k))
 k = k + 1
 }
 缓冲写(片,  长, 0)
 追加(结果, 片)
 开始 = i + 1
 }
 i = i + 1
 }
 返回 结果
}

// 左填充字符串到指定长度
函数 左填充(s, 目标长度, 填充字符) { 定义 当前长 = 计数(s)
 如果 (当前长 >= 目标长度) { 返回 s }
 返回 字符串拼接(重复(填充字符, 目标长度 - 当前长), s)
}

// 右填充字符串到指定长度
函数 右填充(s, 目标长度, 填充字符) { 定义 当前长 = 计数(s)
 如果 (当前长 >= 目标长度) { 返回 s }
 返回 字符串拼接(s, 重复(填充字符, 目标长度 - 当前长))
}

// 整数转十六进制字符串
函数 转十六进制(数值) { 定义 hex = "0123456789ABCDEF"
 如果 (数值 == 0) { 返回 "0" }
 定义 可变 结果 = ""
 定义 可变 v = 数值
 当 (v > 0) { 定义 位 = v & 0x0F
 结果 = 字符串拼接(子串(hex, 位, 1), 结果)
 v = v >> 4
 }
 返回 结果
}

// 第十四章: 网络 (Winsock2)

定义 可变 _网络库2 = 0
定义 可变 _网络库2_已启动 = 0
定义 可变 _函数_WSA启动 = 0
定义 可变 _函数_WSA清理 = 0
定义 可变 _函数_套接字 = 0
定义 可变 _函数_连接 = 0
定义 可变 _函数_发送 = 0
定义 可变 _函数_接收 = 0
定义 可变 _函数_关闭套接字 = 0
定义 可变 _函数_网络地址转换 = 0
定义 可变 _函数_按名获取主机 = 0

函数 _初始化网络() {
    如果 (_网络库2 == 0) { _网络库2 = 加载库("ws2_32.dll")
}
 如果 (_网络库2_已启动 == 0) { 如果 (_函数_WSA启动 == 0) { _函数_WSA启动 = 获取函数(_网络库2, "WSAStartup") }
 定义 wsadata = 缓冲区(512)
 调用指针(_函数_WSA启动,  0x0202,  wsadata, 0, 0, 0)
 _网络库2_已启动 = 1
 }
 返回 _网络库2
}

// 网络常量

// 创建TCP套接字
函数 创建套接字() { _初始化网络()
 如果 (_函数_套接字 == 0) { _函数_套接字 = 获取函数(_网络库2, "socket") }
 返回 调用指针(_函数_套接字,  地址族_互联网,  套接字_流,  协议_TCP, 0, 0)
}

// htons (主机字节序→网络字节序)
函数 网络字节序(端口) { 返回 ((端口 & 0xFF) << 8) | ((端口 >> 8) & 0xFF)
}

// 解析域名到IP地址 (返回32位网络字节序IP)
函数 解析域名(域名) { _初始化网络()
 如果 (_函数_按名获取主机 == 0) { _函数_按名获取主机 = 获取函数(_网络库2, "gethostbyname") }
 定义 hostent = 调用指针(_函数_按名获取主机,  域名, 0, 0, 0, 0)
 如果 (hostent == 0) { 返回 0 }
 // hostent->h_addr_list is at offset 24 (x64)
 定义 addr_list = 内存读(hostent + 24)
 如果 (addr_list == 0) { 返回 0 }
 定义 first_addr = 内存读(addr_list)
 如果 (first_addr == 0) { 返回 0 }
 返回 内存读32(first_addr)
}

// 解析IP字符串
函数 解析IP(ip字符串) { _初始化网络()
 如果 (_函数_网络地址转换 == 0) { _函数_网络地址转换 = 获取函数(_网络库2, "inet_addr") }
 返回 调用指针(_函数_网络地址转换,  ip字符串, 0, 0, 0, 0)
}

// 连接到服务器
函数 连接服务器(套接字, IP地址, 端口) { _初始化网络()
 如果 (_函数_连接 == 0) { _函数_连接 = 获取函数(_网络库2, "connect") }
 // 构建 sockaddr_in 型 (16字节)
 定义 地址 = 缓冲区(16)
 缓冲清零(地址, 16)
 内存写16(地址,  地址族_互联网, 0)
 内存写16(地址 + 2,  网络字节序(端口), 0)
 内存写32(地址 + 4,  IP地址, 0)
 返回 调用指针(_函数_连接,  套接字,  地址,  16, 0, 0)
}

// 发送数据
函数 发送(套接字, 数据, 长度) { _初始化网络()
 如果 (_函数_发送 == 0) { _函数_发送 = 获取函数(_网络库2, "send") }
 返回 调用指针4(_函数_发送,  套接字,  数据,  长度, 0)
}

// 发送字符串
函数 发送文本(套接字, 文本) { 返回 发送(套接字, 文本, 字节长度(文本))
}

// 接收数据
函数 接收(套接字, 缓冲, 大小) { _初始化网络()
 如果 (_函数_接收 == 0) { _函数_接收 = 获取函数(_网络库2, "recv") }
 返回 调用指针4(_函数_接收,  套接字,  缓冲,  大小, 0)
}

// 关闭套接字
函数 关闭套接字(套接字) { _初始化网络()
 如果 (_函数_关闭套接字 == 0) { _函数_关闭套接字 = 获取函数(_网络库2, "closesocket") }
 调用指针(_函数_关闭套接字,  套接字, 0, 0, 0, 0)
}

// 清理网络
函数 清理网络() {
    如果 (_网络库2_已启动 != 0) { 如果 (_函数_WSA清理 == 0) { _函数_WSA清理 = 获取函数(_网络库2, "WSACleanup")
}
 调用指针(_函数_WSA清理, 0, 0, 0, 0, 0)
 _网络库2_已启动 = 0
 }
}

// HTTP GET 请求 (简单版 — 返回完整响应含头)
函数 HTTP请求(域名, 路径) { 定义 ip = 解析域名(域名)
 如果 (ip == 0) { 返回 "" }
 定义 sock = 创建套接字()
 如果 (连接服务器(sock, ip, 80) != 0) {
 关闭套接字(sock)
 返回 ""
 }
 // 构建 HTTP 请求
 定义 req = 字符串拼接("GET ", 字符串拼接(路径, 字符串拼接(" HTTP/1.0\r\nHost: ", 字符串拼接(域名, "\r\nConnection: close\r\n\r\n"))))
 发送文本(sock, req)
 // 接收响应
 定义 缓冲 = 缓冲区(65536)
 定义 可变 总长 = 0
 定义 可变 还有数据 = 1
 当 (还有数据 == 1) { 定义 n = 接收(sock, 缓冲 + 总长, 65536 - 总长 - 1)
 如果 (n <= 0) {
 还有数据 = 0
 } 否则 {
 总长 = 总长 + n
 }
 }
 缓冲写(缓冲,  总长, 0)
 关闭套接字(sock)
 返回 缓冲
}

// 第十五章: 剪贴板

定义 可变 _函数_打开剪贴板 = 0
定义 可变 _函数_关闭剪贴板 = 0
定义 可变 _函数_获取剪贴板 = 0
定义 可变 _函数_设剪贴板 = 0
定义 可变 _函数_清空剪贴板 = 0
定义 可变 _函数_全局锁定 = 0
定义 可变 _函数_全局解锁 = 0
定义 可变 _函数_全局分配 = 0

定义 剪贴板_文本 = 1

// 读取剪贴板文本
函数 读剪贴板() { _初始化用户()
 _初始化内核()
 如果 (_函数_打开剪贴板 == 0) { _函数_打开剪贴板 = 获取函数(_用户32库, "OpenClipboard") }
 如果 (_函数_关闭剪贴板 == 0) { _函数_关闭剪贴板 = 获取函数(_用户32库, "CloseClipboard") }
 如果 (_函数_获取剪贴板 == 0) { _函数_获取剪贴板 = 获取函数(_用户32库, "GetClipboardData") }
 如果 (_函数_全局锁定 == 0) { _函数_全局锁定 = 获取函数(_内核32库, "GlobalLock") }
 如果 (_函数_全局解锁 == 0) { _函数_全局解锁 = 获取函数(_内核32库, "GlobalUnlock") }

 调用指针(_函数_打开剪贴板, 0, 0, 0, 0, 0)
 定义 handle = 调用指针(_函数_获取剪贴板,  剪贴板_文本, 0, 0, 0, 0)
 如果 (handle == 0) {
 调用指针(_函数_关闭剪贴板, 0, 0, 0, 0, 0)
 返回 ""
 }
 定义 指针 = 调用指针(_函数_全局锁定,  handle, 0, 0, 0, 0)
 如果 (指针 == 0) {
 调用指针(_函数_关闭剪贴板, 0, 0, 0, 0, 0)
 返回 ""
 }
 // 计算字符串长度并复制
 定义 可变 长度 = 0
 当 (内存读8(指针 + 长度) != 0) { 长度 = 长度 + 1 }
 定义 clip结果 = 缓冲区(长度 + 1)
 内存复制(clip结果, 指针, 长度)
 缓冲写(clip结果,  长度, 0)
 调用指针(_函数_全局解锁,  handle, 0, 0, 0, 0)
 调用指针(_函数_关闭剪贴板, 0, 0, 0, 0, 0)
 返回 clip结果
}

// 写入剪贴板文本
函数 写剪贴板(文本) { _初始化用户()
 _初始化内核()
 如果 (_函数_打开剪贴板 == 0) { _函数_打开剪贴板 = 获取函数(_用户32库, "OpenClipboard") }
 如果 (_函数_关闭剪贴板 == 0) { _函数_关闭剪贴板 = 获取函数(_用户32库, "CloseClipboard") }
 如果 (_函数_设剪贴板 == 0) { _函数_设剪贴板 = 获取函数(_用户32库, "SetClipboardData") }
 如果 (_函数_清空剪贴板 == 0) { _函数_清空剪贴板 = 获取函数(_用户32库, "EmptyClipboard") }
 如果 (_函数_全局分配 == 0) { _函数_全局分配 = 获取函数(_内核32库, "GlobalAlloc") }
 如果 (_函数_全局锁定 == 0) { _函数_全局锁定 = 获取函数(_内核32库, "GlobalLock") }
 如果 (_函数_全局解锁 == 0) { _函数_全局解锁 = 获取函数(_内核32库, "GlobalUnlock") }

 定义 长度 = 字节长度(文本)
 // GMEM_MOVEABLE = 0x0002
 定义 hmem = 调用指针(_函数_全局分配,  0x0002,  长度 + 1, 0, 0, 0)
 如果 (hmem == 0) { 返回 0 }
 定义 指针 = 调用指针(_函数_全局锁定,  hmem, 0, 0, 0, 0)
 内存复制(指针, 文本, 长度)
 缓冲写(指针,  长度, 0)
 调用指针(_函数_全局解锁,  hmem, 0, 0, 0, 0)
 调用指针(_函数_打开剪贴板, 0, 0, 0, 0, 0)
 调用指针(_函数_清空剪贴板, 0, 0, 0, 0, 0)
 调用指针(_函数_设剪贴板,  剪贴板_文本,  hmem, 0, 0, 0)
 调用指针(_函数_关闭剪贴板, 0, 0, 0, 0, 0)
 返回 1
}

// 第十六章: 截图与BMP

// 截取屏幕区域像素到缓冲区 (返回RGBA像素数据)
函数 截屏区域(x, y, 宽, 高) { 定义 像素数 = 宽 * 高
 定义 数据 = 缓冲区(像素数 * 4)
 定义 dc = 获取屏幕DC()
 定义 可变 py = 0
 当 (py < 高) { 定义 可变 px = 0
 当 (px < 宽) { 定义 颜色 = 读像素(x + px, y + py)
 定义 偏移 = (py * 宽 + px) * 4
 内存写8(数据 + 偏移, 红色分量(颜色))
 内存写8(数据 + 偏移 + 1, 绿色分量(颜色))
 内存写8(数据 + 偏移 + 2, 蓝色分量(颜色))
 内存写8(数据 + 偏移 + 3, 255)
 px = px + 1
 }
 py = py + 1
 }
 释放DC(dc)
 返回 数据
}

// 保存像素数据为BMP文件
函数 保存BMP(文件名, 数据, 宽, 高) { 定义 行字节 = 宽 * 3
 // BMP行必须4字节对齐
 定义 填充 = (4 - (行字节 & 3)) & 3
 定义 行实际 = 行字节 + 填充
 定义 像素实际 = 行实际 * 高
 定义 文件大小 = 54 + 像素实际

 定义 缓冲 = 缓冲区(文件大小)
 缓冲清零(缓冲, 文件大小)

 // BMP文件头 (14字节)
 缓冲写(缓冲, x42, 0) // 'B'
 缓冲写(缓冲, 1, 0x4D) // 'M'
 内存写32(缓冲 + 2,  文件大小, 0)
 内存写32(缓冲 + 10,  54, 0) // 像素数据偏移

 // DIB头 (40字节)
 内存写32(缓冲 + 14,  40, 0) // 头大小
 内存写32(缓冲 + 18,  宽, 0)
 内存写32(缓冲 + 22,  高, 0)
 内存写16(缓冲 + 26,  1, 0) // 颜色平面
 内存写16(缓冲 + 28,  24, 0) // 位深
 内存写32(缓冲 + 34,  像素实际, 0)

 // 像素数据 (BMP从下到上存储)
 定义 可变 y = 0
 当 (y < 高) { 定义 可变 x = 0
 定义 src行 = (高 - 1 - y) * 宽 * 4
 定义 dst行 = 54 + y * 行实际
 当 (x < 宽) { 定义 si = src行 + x * 4
 定义 di = dst行 + x * 3
 // BMP存储顺序: B G R
 缓冲写(缓冲, di, 内存读8(数据 + si + 2))
 缓冲写(缓冲, di + 1, 内存读8(数据 + si + 1))
 缓冲写(缓冲, di + 2, 内存读8(数据 + si))
 x = x + 1
 }
 y = y + 1
 }
 写文件(文件名, 缓冲, 文件大小)
 返回 1
}

// 一键截屏保存
函数 截屏保存(文件名, x, y, 宽, 高) { 定义 数据 = 截屏区域(x, y, 宽, 高)
 返回 保存BMP(文件名, 数据, 宽, 高)
}

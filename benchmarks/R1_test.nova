// 测 R1: 函数返回浮点字面量 → 调用点 r 被正确识别
函数 pi() {
    返回 3.14
}

函数 two() {
    返回 2.0
}

函数 主程序() {
    // r 应通过 R1 被标 __转浮点__, 然后 r + 1.0 走浮点加
    定义 r = pi()
    定义 sum = r + 1.0  // 期望 4.14
    打印(字符串拼接("r bits=", 转字符串(r)))
    打印(字符串拼接("r+1 bits=", 转字符串(sum)))
    
    定义 t = two()
    定义 r2 = t * t  // 期望 4.0
    打印(字符串拼接("t*t bits=", 转字符串(r2)))
    返回 0
}

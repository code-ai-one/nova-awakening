// Nova · 编译器 · 能力令牌系统 (Capability System)
// M7/M11: 把危险对象统一改为能力令牌
// 无能力即无代码生成权限

// 能力类型枚举

导入("../../标准库/基础.nova")
导入("../../标准库/转换器/转换验证.nova")
导入("./效果系统.nova")

定义 能力_无 = 0
定义 能力_设备 = 1
定义 能力_显存 = 2
定义 能力系统_能力_文件 = 3
定义 能力_系统调用 = 4
定义 能力_中断 = 5
定义 能力_特权 = 6
定义 能力系统_能力_网络 = 7
定义 能力_DMA = 8
定义 能力_裸指针 = 9
定义 能力_汇编 = 10

函数 能力名(c) {
    如果 (c == 能力_无) { 返回 "none" }
    如果 (c == 能力_设备) { 返回 "设备" }
    如果 (c == 能力_显存) { 返回 "显存" }
    如果 (c == 能力系统_能力_文件) { 返回 "文件" }
    如果 (c == 能力_系统调用) { 返回 "系统调用" }
    如果 (c == 能力_中断) { 返回 "中断" }
    如果 (c == 能力_特权) { 返回 "特权" }
    如果 (c == 能力系统_能力_网络) { 返回 "网络" }
    如果 (c == 能力_DMA) { 返回 "DMA" }
    如果 (c == 能力_裸指针) { 返回 "裸指针" }
    如果 (c == 能力_汇编) { 返回 "汇编" }
    返回 "未知能力"
}

// 能力令牌
// [能力类型, 授权模块, 授权级别, 是否可传递]
函数 能力_创建令牌(类型, 模块, 级别, 可传递) {
    返回 [类型, 模块, 级别, 可传递]
}

函数 能力_令牌类型(令牌) { 返回 令牌[0] }
函数 能力_令牌模块(令牌) { 返回 令牌[1] }
函数 能力_令牌级别(令牌) { 返回 令牌[2] }
函数 能力_令牌可传递(令牌) { 返回 令牌[3] }

// 模块能力表
// 字典<模块名, [能力令牌列表]>
定义 可变 _能力表 = 空

函数 能力_初始化() { _能力表 = 字典() }

函数 能力_授权(模块名, 能力类型, 级别, 可传递) {
    如果 (_能力表 == 空) { 能力_初始化() }
    定义 现有 = 字典取(_能力表, 模块名)
    定义 可变 列表 = []
    如果 (现有 != 空) { 列表 = 现有 }
    追加(列表, 能力_创建令牌(能力类型, 模块名, 级别, 可传递))
    字典设(_能力表, 模块名, 列表)
}

函数 能力_检查(模块名, 能力类型) {
    如果 (_能力表 == 空) { 返回 假 }
    定义 列表 = 字典取(_能力表, 模块名)
    如果 (列表 == 空) { 返回 假 }
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (能力_令牌类型(列表[i]) == 能力类型) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 能力_获取所有(模块名) {
    如果 (_能力表 == 空) { 返回 [] }
    定义 列表 = 字典取(_能力表, 模块名)
    如果 (列表 == 空) { 返回 [] }
    返回 列表
}

// 模块名→能力自动推断
函数 能力_从模块名推断(模块名) {
    定义 可变 结果 = []
    如果 (字符串包含(模块名, "GPU") 或 字符串包含(模块名, "gpu")) {
        追加(结果, 能力_设备)
        追加(结果, 能力_显存)
    }
    如果 (字符串包含(模块名, "文件") 或 字符串包含(模块名, "IO") 或 字符串包含(模块名, "磁盘")) {
        追加(结果, 能力系统_能力_文件)
    }
    如果 (字符串包含(模块名, "网络") 或 字符串包含(模块名, "套接字") 或 字符串包含(模块名, "HTTP")) {
        追加(结果, 能力系统_能力_网络)
    }
    如果 (字符串包含(模块名, "裸机") 或 字符串包含(模块名, "内核") 或 字符串包含(模块名, "启动")) {
        追加(结果, 能力_特权)
        追加(结果, 能力_系统调用)
        追加(结果, 能力_中断)
    }
    如果 (字符串包含(模块名, "汇编") 或 字符串包含(模块名, "ASM")) {
        追加(结果, 能力_汇编)
    }
    如果 (字符串包含(模块名, "指针") 或 字符串包含(模块名, "内存")) {
        追加(结果, 能力_裸指针)
    }
    返回 结果
}

// 能力违规检测
定义 可变 _能力违规 = []

函数 能力_检查违规(模块名, 需要能力) {
    如果 (能力_检查(模块名, 需要能力) == 假) {
        追加(_能力违规, [模块名, 需要能力])
        返回 假
    }
    返回 真
}

函数 能力_违规数() { 返回 计数(_能力违规) }
函数 能力_重置违规() { _能力违规 = [] }

// Profile能力门控
定义 可变 _profile能力门控 = 空

函数 能力_设置profile门控(profile名, 允许能力列表) {
    如果 (_profile能力门控 == 空) { _profile能力门控 = 字典() }
    字典设(_profile能力门控, profile名, 允许能力列表)
}

函数 能力_profile允许(profile名, 能力类型) {
    如果 (_profile能力门控 == 空) { 返回 真 }
    定义 白名单 = 字典取(_profile能力门控, profile名)
    如果 (白名单 == 空) { 返回 真 }
    定义 可变 i = 0
    当 (i < 计数(白名单)) {
        如果 (白名单[i] == 能力类型) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 能力_初始化默认profile() {
    // linux-user: 文件/网络/系统调用
    能力_设置profile门控("linux-user", [能力系统_能力_文件, 能力系统_能力_网络, 能力_系统调用])
    // kernel-qemu: 全部能力
    能力_设置profile门控("kernel-qemu", [能力_设备, 能力_显存, 能力系统_能力_文件, 能力_系统调用, 能力_中断, 能力_特权, 能力系统_能力_网络, 能力_DMA, 能力_裸指针, 能力_汇编])
    // analysis-host: 仅文件
    能力_设置profile门控("analysis-host", [能力系统_能力_文件])
}

// 能力报告
函数 能力_报告() {
    定义 可变 r = 字典()
    定义 可变 模块数 = 0
    如果 (_能力表 != 空) { 模块数 = 计数(字典键(_能力表)) }
    字典设(r, "授权模块数", 转字符串(模块数))
    字典设(r, "能力违规数", 转字符串(计数(_能力违规)))
    返回 r
}

函数 能力_打印报告() {
    定义 r = 能力_报告()
    打印文本(字符串拼接("[CAPABILITY-REPORT] 授权模块=", 字符串拼接(字典取(r, "授权模块数"), 字符串拼接(" 违规=", 字典取(r, "能力违规数")))))
}

// 能力违规详情输出
函数 能力_输出违规详情() {
    定义 可变 i = 0
    当 (i < 计数(_能力违规)) {
        定义 项 = _能力违规[i]
        打印文本(字符串拼接("  [能力违规] 模块=", 字符串拼接(项[0], 字符串拼接(" 需要能力=", 能力名(项[1])))))
        i = i + 1
    }
}

// 模块能力需求批量检测
// 检查模块效果列表所需能力是否被profile允许
函数 能力_批量检查profile(profile名, 模块名, 效果列表) {
    定义 可变 违规数 = 0
    如果 (profile名 == "" 或 profile名 == 空) { 返回 0 }
    定义 可变 i = 0
    当 (i < 计数(效果列表)) {
        定义 需要 = 效果_到能力(效果列表[i])
        如果 (需要 != 0) {
            如果 (能力_profile允许(profile名, 需要) == 假) {
                追加(_能力违规, [模块名, 需要])
                违规数 = 违规数 + 1
            }
        }
        i = i + 1
    }
    返回 违规数
}

// §8验收矩阵具名别名
函数 能力系统_报告() { 返回 能力_报告() }

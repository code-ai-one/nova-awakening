// NovaOS 浏览器内核 · 第四层 · 窗口合成器对接
// 对接L6 NovaGUI: 窗口管理器 + 合成器
// 职责: 浏览器窗口嵌入NovaGUI窗口系统、多标签页合成、弹窗管理

定义 窗口类型_主窗口     = 0    // 主浏览器窗口
定义 窗口类型_弹窗       = 1    // popup窗口
定义 窗口类型_DevTools   = 2    // 开发者工具
定义 窗口类型_下载       = 3    // 下载管理
定义 窗口类型_设置       = 4    // 浏览器设置
定义 窗口类型_全屏       = 5    // 全屏模式(视频/演示)

结构 浏览器窗口 {
    ID,
    类型,
    宿主窗口ID,    // u32 对应的NovaGUI窗口ID
    标签页,    // [] 标签页ID列表
    当前标签,
    全屏,
    x,
    y,
    宽,
    高,
    标题,
    图处层,    // u32 图处渲染层ID
}

定义 可变 合成_窗口列表 = []
定义 可变 合成_下一个ID = 1
定义 可变 合成_已初始化 = 假

// §1 初始化

函数 合成器对接_初始化() {
    合成_窗口列表 = []
    合成_已初始化 = 真
    内核信息("合成器对接: 浏览器窗口由壳层合成器自管")
}

// §2 窗口创建 — 对接NovaGUI窗口管理器

函数 合成器对接_创建窗口(类型, 标题, x, y, 宽, 高) {
    定义 浏览器窗 = 浏览器窗口 {}
    浏览器窗.ID = 合成_下一个ID
    合成_下一个ID = 合成_下一个ID + 1
    浏览器窗.类型 = 类型
    浏览器窗.标签页 = []
    浏览器窗.当前标签 = 0
    浏览器窗.全屏 = 假
    浏览器窗.x = x
    浏览器窗.y = y
    浏览器窗.宽 = 宽
    浏览器窗.高 = 高
    浏览器窗.标题 = 标题

    浏览器窗.宿主窗口ID = 0

    // 创建图处渲染层
    浏览器窗.图处层 = 浏览器图处_创建层(x, y, 宽, 高)

    追加(合成_窗口列表, 浏览器窗)
    返回 浏览器窗.ID
}

函数 合成器对接_关闭窗口(窗口ID) {
    定义 可变 i = 0
    当 (i < 计数(合成_窗口列表)) {
        如果 (合成_窗口列表[i].ID == 窗口ID) {
            // 销毁图处层
            浏览器图处_销毁层(合成_窗口列表[i].图处层)
            列表_移除(合成_窗口列表, i)
            返回
        }
        i = i + 1
    }
}

// §3 窗口操作

函数 合成器对接_移动窗口(窗口ID, x, y) {
    定义 窗 = 合成器对接_查找窗口(窗口ID)
    如果 (窗 == 空) { 返回 }
    窗.x = x
    窗.y = y
    浏览器图处_销毁层(窗.图处层)
    窗.图处层 = 浏览器图处_创建层(x, y, 窗.宽, 窗.高)
}

函数 合成器对接_调整大小(窗口ID, 宽, 高) {
    定义 窗 = 合成器对接_查找窗口(窗口ID)
    如果 (窗 == 空) { 返回 }
    窗.宽 = 宽
    窗.高 = 高
    // 重建图处层
    浏览器图处_销毁层(窗.图处层)
    窗.图处层 = 浏览器图处_创建层(窗.x, 窗.y, 宽, 高)
}

函数 合成器对接_全屏切换(窗口ID) {
    定义 窗 = 合成器对接_查找窗口(窗口ID)
    如果 (窗 == 空) { 返回 }

    窗.全屏 = !窗.全屏
}

函数 合成器对接_设置标题(窗口ID, 标题) {
    定义 窗 = 合成器对接_查找窗口(窗口ID)
    如果 (窗 == 空) { 返回 }
    窗.标题 = 标题
}

函数 合成器对接_查找窗口(窗口ID) {
    定义 可变 i = 0
    当 (i < 计数(合成_窗口列表)) {
        如果 (合成_窗口列表[i].ID == 窗口ID) {
            返回 合成_窗口列表[i]
        }
        i = i + 1
    }
    返回 空
}

// §4 多标签合成

函数 合成器对接_添加标签(窗口ID, 标签ID) {
    定义 窗 = 合成器对接_查找窗口(窗口ID)
    如果 (窗 == 空) { 返回 }
    追加(窗.标签页, 标签ID)
    如果 (计数(窗.标签页) == 1) {
        窗.当前标签 = 标签ID
    }
}

函数 合成器对接_切换标签(窗口ID, 标签ID) {
    定义 窗 = 合成器对接_查找窗口(窗口ID)
    如果 (窗 == 空) { 返回 }
    窗.当前标签 = 标签ID
    // 通知资源调度器切换前台
    资源调度_标签切换(标签ID)
}

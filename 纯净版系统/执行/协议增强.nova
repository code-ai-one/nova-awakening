函数 浏览器网络_处理内部协议(url) {
    返回 浏览器网络_处理内部协议_标记5(url)
}

// §18 自检

函数 浏览器网络_标记5_自检() {
    定义 ctx = 壳层视觉上下文_默认()
    定义 css = 壳层_CSS_生成(ctx)
    如果 (字符串长度(css) < 400) { 返回 假 }

    定义 req = 协议_拆分URL("nova://ai?tab=agent")
    如果 (req.类型 != 协议类型_AI) { 返回 假 }

    定义 决策 = 协议_路由决策(req, 路由策略_兼容)
    如果 (!决策.是否命中) { 返回 假 }

    定义 html = 协议_生成页面HTML(req, ctx, 决策)
    如果 (字符串查找(html, "AI 工作台") < 0) { 返回 假 }
    如果 (字符串查找(html, "nova-shell") < 0) { 返回 假 }

    返回 真
}

// §19 启动初始化

函数 浏览器网络_标记5_初始化() {
    壳层埋点_初始化()
    壳层埋点_记录("module.init", 1, 0, "mark5")
    返回 成功
}

// §20 卸载

函数 浏览器网络_标记5_卸载() {
    如果 (全局_埋点缓冲 != 空) {
        堆_释放(全局_埋点缓冲.列表)
        堆_释放(全局_埋点缓冲)
        全局_埋点缓冲 = 空
    }
    返回 成功
}

}


结构 Nova承诺 {
    魔数,              // u32 = 承诺_魔数 "PROM"
    状态,              // u32 承诺状态_xxx
    值,                // u64 resolve的值 或 reject的原因
    完成回调链,        // u64 then的onFulfilled回调链表
    拒绝回调链,        // u64 then的onRejected回调链表
    已处理,            // u32 bool: reject是否已被处理(防未处理rejection)
    引用计数,
    // AI优化
    链长度,            // u32 .then()链的长度
    创建时间,
}

函数 Nova承诺_创建(Nova运行时实例) {
    如果 (Nova运行时实例 == 0) { 返回 0 }
    定义 可变 p = 堆_分配(Nova承诺)
    如果 (p == 0) { 返回 0 }
    p.魔数 = 承诺_魔数
    p.状态 = 承诺状态_待定
    p.值 = 0
    p.完成回调链 = 0
    p.拒绝回调链 = 0
    p.已处理 = 假
    p.引用计数 = 1
    p.链长度 = 0
    p.创建时间 = 平台_获取高精度时间()
    返回 p
}

函数 Nova承诺_销毁(p) {
    如果 (p == 0) { 返回 }
    // 释放回调链
    Nova承诺_释放回调链(p.完成回调链)
    Nova承诺_释放回调链(p.拒绝回调链)
    堆_释放(p)
}

函数 Nova承诺_释放回调链(链头) {
    定义 可变 当前 = 链头
    当 (当前 != 0) {
        定义 下一个 = 内存_读64(当前 + 24)
        堆_释放(当前)
        当前 = 下一个
    }
}

函数 Nova承诺_增引用(p) {
    如果 (p == 0) { 返回 }
    p.引用计数 = p.引用计数 + 1
}

函数 Nova承诺_减引用(p) {
    如果 (p == 0) { 返回 }
    p.引用计数 = p.引用计数 - 1
    如果 (p.引用计数 <= 0) { Nova承诺_销毁(p) }
}

// ES2023 §27.2.1.3.1 Promise Resolve Functions

函数 Nova承诺_解决(Nova运行时实例, p, 值) {
    如果 (p == 0 || p.状态 != 承诺状态_待定) { 返回 }

    // 检查是否resolve了自身(TypeError)
    如果 (值 == p) {
        打印("[承诺] TypeError: 承诺不能resolve自身")
        Nova承诺_拒绝(Nova运行时实例, p, 0)
        返回
    }

    // 检查值是否是承诺(thenable检查)
    如果 (Nova承诺_是承诺(值)) {
        定义 内部承诺 = 值
        如果 (内部承诺.状态 == 承诺状态_已完成) {
            // 已完成: 用其值resolve
            Nova承诺_完成(Nova运行时实例, p, 内部承诺.值)
        } 否则 如果 (内部承诺.状态 == 承诺状态_已拒绝) {
            // 已拒绝: 用其原因reject
            Nova承诺_拒绝(Nova运行时实例, p, 内部承诺.值)
        } 否则 {
            // 仍待定: 链接
            Nova承诺_链接(Nova运行时实例, 内部承诺, p)
        }
        返回
    }

    // 普通值: 直接完成
    Nova承诺_完成(Nova运行时实例, p, 值)
}

函数 Nova承诺_完成(Nova运行时实例, p, 值) {
    如果 (p == 0 || p.状态 != 承诺状态_待定) { 返回 }
    p.状态 = 承诺状态_已完成
    p.值 = 值
    // 触发所有onFulfilled回调
    Nova承诺_触发回调(Nova运行时实例, p.完成回调链, 值)
}

函数 Nova承诺_拒绝(Nova运行时实例, p, 原因) {
    如果 (p == 0 || p.状态 != 承诺状态_待定) { 返回 }
    p.状态 = 承诺状态_已拒绝
    p.值 = 原因
    // 触发所有onRejected回调
    Nova承诺_触发回调(Nova运行时实例, p.拒绝回调链, 原因)
    // 检查未处理的rejection
    如果 (p.已处理 == 假 && p.拒绝回调链 == 0) {
        打印("[承诺] 警告: 未处理的Promise rejection")
    }
}

函数 Nova承诺_触发回调(Nova运行时实例, 回调链, 值) {
    定义 可变 当前 = 回调链
    当 (当前 != 0) {
        定义 回调 = 内存_读64(当前)
        如果 (回调 != 0) {
            // 通过微任务队列异步执行
            Nova函数_Call(Nova运行时实例, 回调, 值)
        }
        当前 = 内存_读64(当前 + 24)
    }
}

函数 Nova承诺_链接(Nova运行时实例, 源承诺, 目标承诺) {
    // 当源承诺resolve/reject时, 自动resolve/reject目标承诺
    定义 解决绑定 = Nova承诺_创建resolve绑定(Nova运行时实例, 目标承诺)
    定义 拒绝绑定 = Nova承诺_创建reject绑定(Nova运行时实例, 目标承诺)
    // 添加到源承诺的回调链
    Nova承诺_添加回调(源承诺, 解决绑定, 拒绝绑定)
}

函数 Nova承诺_添加回调(p, 完成回调, 拒绝回调) {
    如果 (p == 0) { 返回 }
    p.已处理 = 真

    如果 (p.状态 == 承诺状态_待定) {
        // 仍待定: 加入回调链
        如果 (完成回调 != 0) {
            定义 节点 = 堆_分配(承诺回调绑定)
            如果 (节点 != 0) {
                内存_写64(节点, 完成回调)
                内存_写64(节点 + 24, p.完成回调链)
                p.完成回调链 = 节点
            }
        }
        如果 (拒绝回调 != 0) {
            定义 节点 = 堆_分配(承诺回调绑定)
            如果 (节点 != 0) {
                内存_写64(节点, 拒绝回调)
                内存_写64(节点 + 24, p.拒绝回调链)
                p.拒绝回调链 = 节点
            }
        }
        p.链长度 = p.链长度 + 1
    } 否则 如果 (p.状态 == 承诺状态_已完成 && 完成回调 != 0) {
        // 已完成: 立即调用
        Nova函数_Call(0, 完成回调, p.值)
    } 否则 如果 (p.状态 == 承诺状态_已拒绝 && 拒绝回调 != 0) {
        // 已拒绝: 立即调用
        Nova函数_Call(0, 拒绝回调, p.值)
    }
}


函数 Nova承诺_then(Nova运行时实例, p, 完成处理, 拒绝处理) {
    如果 (p == 0 || !Nova承诺_是承诺(p)) { 返回 0 }
    // 创建新承诺
    定义 新承诺 = Nova承诺_创建(Nova运行时实例)
    如果 (新承诺 == 0) { 返回 0 }
    // 包装处理函数: 执行后resolve/reject新承诺
    定义 包装完成 = Nova承诺_包装then回调(Nova运行时实例, 新承诺, 完成处理, 回调类型_resolve)
    定义 包装拒绝 = Nova承诺_包装then回调(Nova运行时实例, 新承诺, 拒绝处理, 回调类型_reject)
    Nova承诺_添加回调(p, 包装完成, 包装拒绝)
    返回 新承诺
}

函数 Nova承诺_catch(Nova运行时实例, p, 拒绝处理) {
    返回 Nova承诺_then(Nova运行时实例, p, 0, 拒绝处理)
}

函数 Nova承诺_finally(Nova运行时实例, p, 处理函数) {
    如果 (p == 0) { 返回 0 }
    定义 新承诺 = Nova承诺_创建(Nova运行时实例)
    如果 (新承诺 == 0) { 返回 0 }
    定义 包装 = Nova承诺_包装finally回调(Nova运行时实例, 新承诺, 处理函数)
    Nova承诺_添加回调(p, 包装, 包装)
    返回 新承诺
}

函数 Nova承诺_包装then回调(Nova运行时实例, 新承诺, 处理函数, 类型) {
    定义 ctx = 堆_分配(32)
    如果 (ctx == 0) { 返回 0 }
    内存_写64(ctx, 新承诺)
    内存_写64(ctx + 8, 处理函数)
    内存_写64(ctx + 16, Nova运行时实例)
    内存_写32(ctx + 24, 类型)
    返回 ctx
}

函数 Nova承诺_包装finally回调(Nova运行时实例, 新承诺, 处理函数) {
    定义 ctx = 堆_分配(24)
    如果 (ctx == 0) { 返回 0 }
    内存_写64(ctx, 新承诺)
    内存_写64(ctx + 8, 处理函数)
    内存_写64(ctx + 16, Nova运行时实例)
    返回 ctx
}


函数 Nova承诺_静态resolve(Nova运行时实例, 值) {
    如果 (Nova承诺_是承诺(值)) { 返回 值 }
    定义 p = Nova承诺_创建(Nova运行时实例)
    如果 (p != 0) {
        Nova承诺_完成(Nova运行时实例, p, 值)
    }
    返回 p
}

函数 Nova承诺_静态reject(Nova运行时实例, 原因) {
    定义 p = Nova承诺_创建(Nova运行时实例)
    如果 (p != 0) {
        Nova承诺_拒绝(Nova运行时实例, p, 原因)
    }
    返回 p
}


函数 智能_承诺_预测链长度(Nova运行时实例, p) {
    如果 (p == 0) { 返回 0 }
    // 统计当前链长度
    定义 可变 长度 = 0
    定义 可变 当前 = p.完成回调链
    当 (当前 != 0) {
        长度 = 长度 + 1
        当前 = 内存_读64(当前 + 24)
    }
    返回 长度
}

函数 智能_承诺_应该内联(链长度) {
    // 短链(≤3): 可以内联执行(减少微任务队列开销)
    返回 链长度 <= AI_承诺链_短阈值
}


定义 可变 全局_承诺创建数 = 0
定义 可变 全局_承诺resolve数 = 0
定义 可变 全局_承诺reject数 = 0
定义 可变 全局_承诺then数 = 0
定义 可变 全局_未处理rejection数 = 0

函数 承诺系统_打印统计() {
    打印("[承诺] ═══════════ 承诺系统统计 ═══════════")
    打印(字符串拼接("  承诺创建数:       ", 转字符串(全局_承诺创建数)))
    打印(字符串拼接("  承诺resolve数:    ", 转字符串(全局_承诺resolve数)))
    打印(字符串拼接("  承诺reject数:     ", 转字符串(全局_承诺reject数)))
    打印(字符串拼接("  承诺then数:       ", 转字符串(全局_承诺then数)))
    打印(字符串拼接("  未处理rejection:  ", 转字符串(全局_未处理rejection数)))
    打印("[承诺] ═══════════════════════════════════════")
}

函数 微任务队列_打印统计(队列) {
    如果 (队列 == 空) { 返回 }
    打印("[微任务] ═══════════ 微任务队列统计 ═══════════")
    打印(字符串拼接("  当前大小:     ", 转字符串(队列.当前大小)))
    打印(字符串拼接("  容量:         ", 转字符串(队列.容量)))
    打印(字符串拼接("  入队总数:     ", 转字符串(队列.统计_入队总数)))
    打印(字符串拼接("  执行总数:     ", 转字符串(队列.统计_执行总数)))
    打印(字符串拼接("  溢出次数:     ", 转字符串(队列.统计_溢出次数)))
    打印(字符串拼接("  AI批量激活:   ", 转字符串(队列.AI批量激活)))
    打印("[微任务] ═══════════════════════════════════════")
}

函数 Nova承诺_打印信息(p) {
    如果 (p == 0) {
        打印("[承诺] 空承诺")
        返回
    }
    打印("[承诺] ── 承诺信息 ──")
    如果 (p.状态 == 承诺状态_待定) { 打印("  状态: pending") }
    否则 如果 (p.状态 == 承诺状态_已完成) { 打印("  状态: fulfilled") }
    否则 如果 (p.状态 == 承诺状态_已拒绝) { 打印("  状态: rejected") }
    打印(字符串拼接("  值:       ", 转字符串(p.值)))
    打印(字符串拼接("  已处理:   ", 转字符串(p.已处理)))
    打印(字符串拼接("  链长度:   ", 转字符串(p.链长度)))
    打印(字符串拼接("  引用计数: ", 转字符串(p.引用计数)))
}

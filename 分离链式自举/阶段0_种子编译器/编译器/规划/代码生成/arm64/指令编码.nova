函数 指令编码_编码_sve_saddv(d, pg, n) { 返回 0x04002000|((pg&7)<<10)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_sve_uaddv(d, pg, n) { 返回 0x04012000|((pg&7)<<10)|((n&31)<<5)|(d&31) }
// SMAXV/SMINV/UMAXV/UMINV — 整数归约最值
函数 指令编码_编码_sve_smaxv(d, pg, n) { 返回 0x04082000|((pg&7)<<10)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_sve_sminv(d, pg, n) { 返回 0x040A2000|((pg&7)<<10)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_sve_umaxv(d, pg, n) { 返回 0x04092000|((pg&7)<<10)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_sve_uminv(d, pg, n) { 返回 0x040B2000|((pg&7)<<10)|((n&31)<<5)|(d&31) }

// --- SVE 排列/选择/移动 ---
// DUP Zd, Xn — 标量广播到向量
函数 指令编码_编码_sve_dup_r(d, n) { 返回 0x05203800|((n&31)<<5)|(d&31) }
// DUP Zd, #imm
函数 指令编码_编码_sve_dup_imm(d, imm) { 返回 0x2538C000|((imm&0xFF)<<5)|(d&31) }
// SEL Zd, Pg, Zn, Zm — 条件选择
函数 指令编码_编码_sve_sel(d, pg, n, m) { 返回 0x05A00000|((m&31)<<16)|((pg&15)<<10)|((n&31)<<5)|(d&31) }
// MOV Zd, Zn (alias of ORR)
函数 指令编码_编码_sve_mov(d, n) { 返回 0x04603000|((n&31)<<16)|((n&31)<<5)|(d&31) }
// REV Zd — 反转元素顺序
函数 指令编码_编码_sve_rev_s(d, n) { 返回 0x05A43800|((n&31)<<5)|(d&31) }
// TBL Zd, {Zn}, Zm — 表查找
函数 指令编码_编码_sve_tbl(d, n, m) { 返回 0x05203000|((m&31)<<16)|((n&31)<<5)|(d&31) }
// COMPACT Zd — 压缩活跃元素
函数 指令编码_编码_sve_compact_s(d, pg, n) { 返回 0x05A18000|((pg&7)<<10)|((n&31)<<5)|(d&31) }
// SPLICE Zd — 拼接
函数 指令编码_编码_sve_splice(d, pg, n, m) { 返回 0x052C8000|((m&31)<<16)|((pg&7)<<10)|((n&31)<<5)|(d&31) }
// 索引 Zd, Xn, Xm — 生成索引向量
函数 指令编码_编码_sve_index_rr(d, n, m) { 返回 0x04A04C00|((m&31)<<16)|((n&31)<<5)|(d&31) }
// INCP/DECP Xd, Pg — 谓词计数增减
函数 指令编码_编码_sve_incp(d, pg) { 返回 0x252C8800|((pg&15)<<5)|(d&31) }
函数 指令编码_编码_sve_decp(d, pg) { 返回 0x252D8800|((pg&15)<<5)|(d&31) }
// CNTW/CNTH/CNTB/CNTD — 向量长度查询
函数 指令编码_编码_sve_cntw() { 返回 0x04A0E000 }
函数 指令编码_编码_sve_cnth() { 返回 0x0460E000 }
函数 指令编码_编码_sve_cntb() { 返回 0x0420E000 }
函数 指令编码_编码_sve_cntd() { 返回 0x04E0E000 }


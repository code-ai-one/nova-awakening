导入("./类型定义.nova")
导入("./错误码.nova")
导入("./哈希整数.nova")
导入("./字符串替换.nova")
导入("./内存初始化.nova")
导入("./创建甲.nova")
导入("../感知/内核直连层.nova")

外部 字符串取字符
外部 字符串转字节

定义 最大表单 = 64
定义 最大账号 = 128
定义 速率窗口 = 60
定义 最大速率 = 10

结构 表单信息 {
    地址哈希,
    字段数,
    用户名字段,
    密码字段,
    邮箱字段,
    验证码字段,
    提交按钮,
    发现时刻,
}

结构 账号记录 {
    用户名哈希,
    状态,
    创建时刻,
    最近登录,
    登录次数,
    失败次数,
}

定义 可变 表单表 = []
定义 可变 表单数 = 0
定义 可变 账号表 = []
定义 可变 账号数 = 0
定义 可变 总尝试 = 0
定义 可变 总成功 = 0
定义 可变 总失败 = 0
定义 可变 验证码处理 = 0
定义 可变 验证码成功 = 0
定义 可变 速率计数 = 0
定义 可变 速率起始 = 0

函数 自动化_初始化() {
    表单表 = []
    表单数 = 0
    账号表 = []
    账号数 = 0
    速率起始 = 平台_获取高精度时间()
}

函数 自动化_发现表单(页面地址, 字段列表, 字段数) {
    如果 (表单数 >= 最大表单) { 返回 -1 }
    定义 表单 = 表单信息 {}
    表单.地址哈希 = 哈希_字符串(页面地址)
    表单.字段数 = 字段数
    表单.用户名字段 = -1
    表单.密码字段 = -1
    表单.邮箱字段 = -1
    表单.验证码字段 = -1
    表单.提交按钮 = -1
    表单.发现时刻 = 平台_获取高精度时间()
    定义 可变 序号 = 0
    当 (序号 < 字段数) {
        定义 字段类型 = 内存_读32(字段列表 + 序号 * 8)
        定义 字段名哈希 = 内存_读32(字段列表 + 序号 * 8 + 4)
        如果 (字段类型 == 1) { 表单.用户名字段 = 序号 }
        如果 (字段类型 == 2) { 表单.密码字段 = 序号 }
        如果 (字段类型 == 3) { 表单.邮箱字段 = 序号 }
        如果 (字段类型 == 4) { 表单.验证码字段 = 序号 }
        如果 (字段类型 == 5) { 表单.提交按钮 = 序号 }
        序号 = 序号 + 1
    }
    追加(表单表, 表单)
    表单数 = 表单数 + 1
    返回 表单数 - 1
}

函数 自动化_检查速率() {
    定义 现在 = 平台_获取高精度时间()
    如果 (现在 - 速率起始 > 60000000) {
        速率计数 = 0
        速率起始 = 现在
    }
    如果 (速率计数 >= 最大速率) { 返回 假 }
    速率计数 = 速率计数 + 1
    返回 真
}

函数 自动化_尝试注册(表单索引, 用户名, 密码, 邮箱) {
    总尝试 = 总尝试 + 1
    如果 (!自动化_检查速率()) { 总失败 = 总失败 + 1; 返回 错误_频率过高 }
    如果 (表单索引 >= 表单数) { 总失败 = 总失败 + 1; 返回 错误_无效参数 }
    定义 表单 = 表单表[表单索引]
    如果 (表单.用户名字段 < 0 || 表单.密码字段 < 0) {
        总失败 = 总失败 + 1
        返回 错误_表单不完整
    }
    定义 账号 = 账号记录 {}
    账号.用户名哈希 = 哈希_字符串(用户名)
    账号.状态 = 1
    账号.创建时刻 = 平台_获取高精度时间()
    账号.最近登录 = 0
    账号.登录次数 = 0
    账号.失败次数 = 0
    如果 (账号数 < 最大账号) {
        追加(账号表, 账号)
        账号数 = 账号数 + 1
    }
    总成功 = 总成功 + 1
    返回 0
}

函数 自动化_处理验证码(图像数据, 宽, 高) {
    验证码处理 = 验证码处理 + 1
    如果 (图像数据 == 0 || 宽 == 0 || 高 == 0) { 返回 "" }
    定义 可变 像素总和 = 0
    定义 可变 序号 = 0
    当 (序号 < 宽 * 高) {
        像素总和 = 像素总和 + 内存_读8(图像数据 + 序号)
        序号 = 序号 + 1
    }
    定义 平均值 = 像素总和 / (宽 * 高)
    定义 可变 结果 = ""
    定义 可变 区域 = 0
    当 (区域 < 6) {
        定义 区域起始 = 区域 * 宽 / 6
        定义 区域结束 = (区域 + 1) * 宽 / 6
        定义 可变 区域和 = 0
        定义 可变 像素 = 区域起始
        当 (像素 < 区域结束) {
            定义 可变 行 = 0
            当 (行 < 高) {
                区域和 = 区域和 + 内存_读8(图像数据 + 行 * 宽 + 像素)
                行 = 行 + 1
            }
            像素 = 像素 + 1
        }
        定义 区域均值 = 区域和 / ((区域结束 - 区域起始) * 高)
        定义 字符估计 = (区域均值 * 10 / 256) + 48
        结果 = 结果 + 字符串取字符(字符估计)
        区域 = 区域 + 1
    }
    验证码成功 = 验证码成功 + 1
    返回 结果
}

函数 自动化_查找账号(用户名) {
    定义 目标哈希 = 哈希_字符串(用户名)
    定义 可变 序号 = 0
    当 (序号 < 账号数) {
        如果 (账号表[序号].用户名哈希 == 目标哈希) { 返回 账号表[序号] }
        序号 = 序号 + 1
    }
    返回 0
}

函数 自动化_记录登录(用户名, 成功) {
    定义 账号 = 自动化_查找账号(用户名)
    如果 (账号 == 0) { 返回 }
    如果 (成功) {
        账号.登录次数 = 账号.登录次数 + 1
        账号.最近登录 = 平台_获取高精度时间()
    } 否则 {
        账号.失败次数 = 账号.失败次数 + 1
    }
}

函数 自动化注册_完整统计() {
    返回 [总尝试, 总成功, 总失败, 表单数, 账号数, 验证码处理, 验证码成功]
}

定义 可变 AI_新系统自动_威胁计数 = 0

函数 AI_新系统自动_风险评分(操作类型, 权限级别, 来源可信度) {
    定义 可变 风险 = 0
    如果 (权限级别 > 500) { 风险 = 风险 + 300 }
    如果 (来源可信度 < 200) { 风险 = 风险 + 400 }
    如果 (风险 > 500) { AI_新系统自动_威胁计数 = AI_新系统自动_威胁计数 + 1 }
    返回 风险
}

函数 AI_新系统自动_异常行为检测(操作频率, 基线频率) {
    如果 (基线频率 > 0 && 操作频率 > 基线频率 * 5) { 返回 真 }
    返回 假
}

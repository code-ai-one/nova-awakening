
// ELF 魔数
定义 ELF_魔数0 = 0x7F
定义 ELF_魔数1 = 0x45  // 'E'
定义 ELF_魔数2 = 0x4C  // 'L'
定义 ELF_魔数3 = 0x46  // 'F'

// ELF 类型
定义 ELF类型_无 = 0
定义 ELF类型_可重定位 = 1
定义 ELF类型_可执行 = 2
定义 ELF类型_动态 = 3
定义 ELF类型_核心 = 4

// ELF 机器类型
定义 处理器_386 = 3
定义 处理器_AMD64 = 62
定义 处理器_ARM = 40
定义 处理器_AARCH64 = 183
定义 处理器_RISCV = 243

// 段类型
定义 段类型_空 = 0
定义 段类型_加载 = 1
定义 段类型_动态 = 2
定义 段类型_解释器 = 3
定义 段类型_注释 = 4
定义 段类型_程序头 = 6

// 节类型
定义 节类型_空 = 0
定义 节类型_程序数据 = 1
定义 节类型_符号表 = 2
定义 节类型_字符串表 = 3
定义 节类型_重定位A = 4
定义 节类型_无数据 = 8
定义 节类型_重定位 = 9

// ELF头: [类(32/64), 类型, 机器, 入口点, 段头偏移, 节头偏移, 段头数, 节头数]
函数 elf_创建头(类, 类型, 机器, 入口) {
    返回 [类, 类型, 机器, 入口, 0,]
}

函数 elf_类(头) { 返回 头[0] }
函数 elf_类型(头) { 返回 头[1] }
函数 elf_机器(头) { 返回 头[2] }
函数 elf_入口(头) { 返回 头[3] }

函数 elf_类型名(类型) {
    如果 (类型 == ELF类型_无) { 返回 "NONE" }
    如果 (类型 == ELF类型_可重定位) { 返回 "REL" }
    如果 (类型 == ELF类型_可执行) { 返回 "EXEC" }
    如果 (类型 == ELF类型_动态) { 返回 "DYN" }
    如果 (类型 == ELF类型_核心) { 返回 "CORE" }
    返回 "未知"
}

函数 elf_机器名(机器) {
    如果 (机器 == 处理器_386) { 返回 "i386" }
    如果 (机器 == 处理器_AMD64) { 返回 "x86-64" }
    如果 (机器 == 处理器_ARM) { 返回 "ARM" }
    如果 (机器 == 处理器_AARCH64) { 返回 "AArch64" }
    如果 (机器 == 处理器_RISCV) { 返回 "RISC-V" }
    返回 "未知"
}

// 段头: [类型, 偏移, 虚地址, 物理地址, 文件大小, 内存大小, 标志]
函数 elf_创建段头(类型, 虚地址, 文件大小, 内存大小, 标志) {
    返回 [类型, 0, 虚地址, 虚地址, 文件大小, 内存大小, 标志]
}

函数 elf_段类型名_数值(类型) {
    如果 (类型 == 段类型_空) { 返回 "NULL" }
    如果 (类型 == 段类型_加载) { 返回 "LOAD" }
    如果 (类型 == 段类型_动态) { 返回 "DYNAMIC" }
    如果 (类型 == 段类型_解释器) { 返回 "INTERP" }
    如果 (类型 == 段类型_注释) { 返回 "NOTE" }
    如果 (类型 == 段类型_程序头) { 返回 "PHDR" }
    返回 "未知"
}

// 节头: [名称索引, 类型, 标志, 地址, 偏移, 大小]
函数 elf_创建节头(名索引, 类型, 标志, 地址, 大小) {
    返回 [名索引, 类型, 标志, 地址, 0, 大小]
}

函数 elf_节类型名(类型) {
    如果 (类型 == 节类型_空) { 返回 "NULL" }
    如果 (类型 == 节类型_程序数据) { 返回 "PROGBITS" }
    如果 (类型 == 节类型_符号表) { 返回 "SYMTAB" }
    如果 (类型 == 节类型_字符串表) { 返回 "STRTAB" }
    如果 (类型 == 节类型_重定位A) { 返回 "RELA" }
    如果 (类型 == 节类型_无数据) { 返回 "NOBITS" }
    如果 (类型 == 节类型_重定位) { 返回 "REL" }
    返回 "未知"
}

// 验证ELF魔数
函数 elf_验证魔数(字节列表) {
    如果 (计数(字节列表) < 4) { 返回 0 }
    如果 (字节列表[0] != ELF_魔数0) { 返回 0 }
    如果 (字节列表[1] != ELF_魔数1) { 返回 0 }
    如果 (字节列表[2] != ELF_魔数2) { 返回 0 }
    如果 (字节列表[3] != ELF_魔数3) { 返回 0 }
    返回 1
}

// 小端读取16位
函数 elf_读16(字节列表, 偏移) {
    返回 字节列表[偏移] + 字节列表[偏移 + 1] * 256
}

// 小端读取32位
函数 elf_读32(字节列表, 偏移) {
    返回 字节列表[偏移] + 字节列表[偏移 + 1] * 256 + 字节列表[偏移 + 2] * 65536 + 字节列表[偏移 + 3] * 16777216
}

// 解析ELF头
函数 elf_解析头(字节列表) {
    如果 (elf_验证魔数(字节列表) == 0) { 返回 空 }
    定义 类 = 字节列表[4]
    定义 类型 = elf_读16(字节列表, 16)
    定义 机器 = elf_读16(字节列表, 18)
    定义 入口 = elf_读32(字节列表, 24)
    返回 elf_创建头(类, 类型, 机器, 入口)
}

// 节头表解析

函数 elf_节头偏移(字节列表) {
    返回 elf_读32(字节列表, 32)
}

函数 elf_节头数量(字节列表) {
    返回 elf_读16(字节列表, 48)
}

函数 elf_节头大小(字节列表) {
    返回 elf_读16(字节列表, 46)
}

函数 elf_解析节头(字节列表, 索引) {
    定义 基址 = elf_节头偏移(字节列表) + 索引 * elf_节头大小(字节列表)
    定义 名称偏移 = elf_读32(字节列表, 基址)
    定义 类型 = elf_读32(字节列表, 基址 + 4)
    定义 标志 = elf_读32(字节列表, 基址 + 8)
    定义 地址 = elf_读32(字节列表, 基址 + 12)
    定义 偏移 = elf_读32(字节列表, 基址 + 16)
    定义 大小 = elf_读32(字节列表, 基址 + 20)
    返回 [名称偏移, 类型, 标志, 地址, 偏移, 大小]
}

函数 elf_节头类型名(类型) {
    如果 (类型 == 0) { 返回 "NULL" }
    如果 (类型 == 1) { 返回 "PROGBITS" }
    如果 (类型 == 2) { 返回 "SYMTAB" }
    如果 (类型 == 3) { 返回 "STRTAB" }
    如果 (类型 == 4) { 返回 "RELA" }
    如果 (类型 == 5) { 返回 "HASH" }
    如果 (类型 == 6) { 返回 "DYNAMIC" }
    如果 (类型 == 7) { 返回 "NOTE" }
    如果 (类型 == 8) { 返回 "NOBITS" }
    如果 (类型 == 9) { 返回 "REL" }
    返回 "未知"
}

// 程序头解析

函数 elf_程序头偏移(字节列表) {
    返回 elf_读32(字节列表, 28)
}

函数 elf_程序头数量(字节列表) {
    返回 elf_读16(字节列表, 44)
}

函数 elf_解析程序头(字节列表, 索引) {
    定义 大小 = 32  // 32位ELF程序头大小
    定义 基址 = elf_程序头偏移(字节列表) + 索引 * 大小
    定义 类型 = elf_读32(字节列表, 基址)
    定义 偏移 = elf_读32(字节列表, 基址 + 4)
    定义 虚地址 = elf_读32(字节列表, 基址 + 8)
    定义 文件大小 = elf_读32(字节列表, 基址 + 16)
    定义 内存大小 = elf_读32(字节列表, 基址 + 20)
    定义 标志 = elf_读32(字节列表, 基址 + 24)
    返回 [类型, 偏移, 虚地址, 文件大小, 内存大小, 标志]
}

函数 elf_段类型名(类型) {
    如果 (类型 == 0) { 返回 "NULL" }
    如果 (类型 == 1) { 返回 "LOAD" }
    如果 (类型 == 2) { 返回 "DYNAMIC" }
    如果 (类型 == 3) { 返回 "INTERP" }
    如果 (类型 == 4) { 返回 "NOTE" }
    如果 (类型 == 6) { 返回 "PHDR" }
    如果 (类型 == 7) { 返回 "TLS" }
    返回 "未知"
}

// 符号表

函数 elf_解析符号(字节列表, 偏移) {
    定义 名称 = elf_读32(字节列表, 偏移)
    定义 值 = elf_读32(字节列表, 偏移 + 4)
    定义 大小 = elf_读32(字节列表, 偏移 + 8)
    定义 信息 = 字节列表[偏移 + 12]
    定义 绑定 = 信息 >> 4
    定义 类型 = 信息 & 0x0F
    定义 段索引 = elf_读16(字节列表, 偏移 + 14)
    返回 [名称, 值, 大小, 绑定, 类型, 段索引]
}

函数 elf_符号绑定名(绑定) {
    如果 (绑定 == 0) { 返回 "LOCAL" }
    如果 (绑定 == 1) { 返回 "GLOBAL" }
    如果 (绑定 == 2) { 返回 "WEAK" }
    返回 "未知"
}

函数 elf_符号类型名(类型) {
    如果 (类型 == 0) { 返回 "NOTYPE" }
    如果 (类型 == 1) { 返回 "OBJECT" }
    如果 (类型 == 2) { 返回 "FUNC" }
    如果 (类型 == 3) { 返回 "SECTION" }
    如果 (类型 == 4) { 返回 "FILE" }
    返回 "未知"
}

// 重定位

函数 elf_解析重定位(字节列表, 偏移) {
    定义 地址 = elf_读32(字节列表, 偏移)
    定义 信息 = elf_读32(字节列表, 偏移 + 4)
    定义 符号索引 = 信息 >> 8
    定义 类型 = 信息 & 0xFF
    返回 [地址, 符号索引, 类型]
}

函数 elf_重定位类型名_x86(类型) {
    如果 (类型 == 0) { 返回 "R_386_NONE" }
    如果 (类型 == 1) { 返回 "R_386_32" }
    如果 (类型 == 2) { 返回 "R_386_PC32" }
    如果 (类型 == 7) { 返回 "R_386_JMP_SLOT" }
    如果 (类型 == 8) { 返回 "R_386_RELATIVE" }
    返回 "R_386_UNKNOWN"
}

// 字符串表

函数 elf_读字符串(字节列表, 字符串表偏移, 名称偏移) {
    定义 可变 结果 = ""
    定义 可变 位置 = 字符串表偏移 + 名称偏移
    当 (位置 < 计数(字节列表) 且 字节列表[位置] != 0) {
        结果 = 结果 + 字符(字节列表[位置])
        位置 = 位置 + 1
    }
    返回 结果
}

// ELF信息汇总

函数 elf_机器名_数值(机器) {
    如果 (机器 == 3) { 返回 "x86" }
    如果 (机器 == 62) { 返回 "x86_64" }
    如果 (机器 == 183) { 返回 "AArch64" }
    如果 (机器 == 243) { 返回 "RISC-V" }
    返回 "未知"
}

函数 elf_类型名_中文(类型) {
    如果 (类型 == 1) { 返回 "可重定位" }
    如果 (类型 == 2) { 返回 "可执行" }
    如果 (类型 == 3) { 返回 "共享库" }
    如果 (类型 == 4) { 返回 "核心转储" }
    返回 "未知"
}

定义 可变 _elf_解析数 = 0
定义 可变 _elf_符号数 = 0
定义 可变 _elf_重定位数 = 0

函数 elf_记录解析() { _elf_解析数 = _elf_解析数 + 1 }
函数 elf_记录符号(n) { _elf_符号数 = _elf_符号数 + n }
函数 elf_记录重定位(n) { _elf_重定位数 = _elf_重定位数 + n }

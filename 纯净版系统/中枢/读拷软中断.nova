导入("./类型定义.nova")
导入("./错误码.nova")

结构 读拷回调 {
    函数指针,
    参数,
    宽限期号,
    后继,
}

结构 读拷状态 {
    当前宽限期,
    完成宽限期,
    回调头,
    回调尾,
    回调数量,
    静默掩码,
    核数,
    软中断次数,
    回调执行数,
    加速请求数,
}

定义 可变 全局读拷 = 0
定义 可变 读段计数 = 0

函数 读拷_初始化(核数) {
    全局读拷 = 堆_分配(读拷状态)
    全局读拷.当前宽限期 = 0
    全局读拷.完成宽限期 = 0
    全局读拷.回调头 = 0
    全局读拷.回调尾 = 0
    全局读拷.回调数量 = 0
    全局读拷.静默掩码 = 0
    全局读拷.核数 = 核数
    全局读拷.软中断次数 = 0
    全局读拷.回调执行数 = 0
    全局读拷.加速请求数 = 0
}

函数 读拷_读锁() {
    读段计数 = 读段计数 + 1
}

函数 读拷_读解锁() {
    如果 (读段计数 > 0) { 读段计数 = 读段计数 - 1 }
}

函数 读拷_注册回调(函数指针, 参数) {
    如果 (全局读拷 == 0) { 返回 }
    定义 回调 = 堆_分配(读拷回调)
    回调.函数指针 = 函数指针
    回调.参数 = 参数
    回调.宽限期号 = 全局读拷.当前宽限期
    回调.后继 = 0
    如果 (全局读拷.回调尾 != 0) {
        全局读拷.回调尾.后继 = 回调
    } 否则 {
        全局读拷.回调头 = 回调
    }
    全局读拷.回调尾 = 回调
    全局读拷.回调数量 = 全局读拷.回调数量 + 1
    如果 (全局读拷.当前宽限期 == 全局读拷.完成宽限期) {
        全局读拷.当前宽限期 = 全局读拷.当前宽限期 + 1
        全局读拷.静默掩码 = (1 << 全局读拷.核数) - 1
    }
}

函数 读拷_报告静默(核号) {
    如果 (全局读拷 == 0) { 返回 }
    如果 (核号 < 全局读拷.核数) {
        全局读拷.静默掩码 = 全局读拷.静默掩码 & ~(1 << 核号)
    }
}

函数 读拷_软中断() {
    如果 (全局读拷 == 0) { 返回 }
    全局读拷.软中断次数 = 全局读拷.软中断次数 + 1
    如果 (全局读拷.回调数量 == 0) { 返回 }
    如果 (全局读拷.完成宽限期 < 全局读拷.当前宽限期) {
        如果 (全局读拷.静默掩码 == 0) {
            全局读拷.完成宽限期 = 全局读拷.当前宽限期
        } 否则 如果 (全局读拷.核数 == 1) {
            全局读拷.完成宽限期 = 全局读拷.当前宽限期
            全局读拷.静默掩码 = 0
        }
    }
    如果 (全局读拷.完成宽限期 >= 全局读拷.当前宽限期) {
        读拷_处理回调()
    }
}

函数 读拷_处理回调() {
    定义 可变 处理数 = 0
    当 (全局读拷.回调头 != 0) {
        定义 回调 = 全局读拷.回调头
        如果 (回调.宽限期号 > 全局读拷.完成宽限期) { 跳出 }
        全局读拷.回调头 = 回调.后继
        如果 (全局读拷.回调头 == 0) { 全局读拷.回调尾 = 0 }
        全局读拷.回调数量 = 全局读拷.回调数量 - 1
        如果 (回调.函数指针 != 0) {
            回调.函数指针(回调.参数)
        }
        堆_释放(回调)
        处理数 = 处理数 + 1
        全局读拷.回调执行数 = 全局读拷.回调执行数 + 1
    }
}

函数 读拷_加速() {
    如果 (全局读拷 == 0) { 返回 }
    全局读拷.加速请求数 = 全局读拷.加速请求数 + 1
    全局读拷.静默掩码 = 0
    全局读拷.完成宽限期 = 全局读拷.当前宽限期
    读拷_处理回调()
}

函数 读拷_同步() {
    如果 (全局读拷 == 0) { 返回 }
    如果 (全局读拷.当前宽限期 == 全局读拷.完成宽限期) {
        全局读拷.当前宽限期 = 全局读拷.当前宽限期 + 1
    }
    定义 可变 等待 = 0
    当 (全局读拷.完成宽限期 < 全局读拷.当前宽限期 && 等待 < 100000) {
        读拷_软中断()
        等待 = 等待 + 1
    }
}

函数 读拷_挂起回调数() {
    如果 (全局读拷 == 0) { 返回 0 }
    返回 全局读拷.回调数量
}

函数 读拷_完整统计() {
    如果 (全局读拷 == 0) { 返回 [0, 0, 0, 0, 0, 0] }
    返回 [全局读拷.当前宽限期, 全局读拷.完成宽限期, 全局读拷.回调数量, 全局读拷.软中断次数, 全局读拷.回调执行数, 全局读拷.加速请求数]
}

// Nova事件轮询_ctl: 添加/删除/修改监控

函数 Nova事件轮询_ctl(epfd, 操作, fd, 事件) {
    定义 ep文件 = 文件描述符_获取(epfd)
    如果 (ep文件 == 空) { 返回 错误码_无效fd }

    定义 ep = ep文件.私有数据
    定义 目标文件 = 文件描述符_获取(fd)
    如果 (目标文件 == 空) { 返回 错误码_无效fd }

    互斥锁_获取(ep.锁)

    匹配 (操作) {
        Nova事件轮询_CTL_ADD => {
            // 检查是否已存在
            定义 已有 = Nova事件轮询_查找监控项(ep, fd)
            如果 (已有 != 空) {
                互斥锁_释放(ep.锁)
                返回 错误码_已存在
            }
            如果 (ep.监控项数 >= Nova事件轮询_最大事件数) {
                互斥锁_释放(ep.锁)
                返回 错误码_无空间
            }

            定义 结果 = Nova事件轮询_插入(ep, fd, 目标文件, 事件)
            互斥锁_释放(ep.锁)
            返回 结果
        }

        Nova事件轮询_CTL_DEL => {
            定义 epi = Nova事件轮询_查找监控项(ep, fd)
            如果 (epi == 空) {
                互斥锁_释放(ep.锁)
                返回 错误码_不存在
            }
            Nova事件轮询_移除(ep, epi)
            互斥锁_释放(ep.锁)
            返回 0
        }

        Nova事件轮询_CTL_MOD => {
            定义 epi = Nova事件轮询_查找监控项(ep, fd)
            如果 (epi == 空) {
                互斥锁_释放(ep.锁)
                返回 错误码_不存在
            }
            epi.事件 = 事件
            // 如果当前已就绪，重新检查
            如果 (epi.已就绪) {
                Nova事件轮询_重新检查就绪(ep, epi)
            }
            互斥锁_释放(ep.锁)
            返回 0
        }

        _ => {
            互斥锁_释放(ep.锁)
            返回 错误码_无效参数
        }
    }
}

// Nova事件轮询_wait: 等待事件

函数 Nova事件轮询_等待(epfd, 事件数组, 最大事件数, 超时) {
    定义 ep文件 = 文件描述符_获取(epfd)
    如果 (ep文件 == 空) { 返回 错误码_无效fd }
    如果 (最大事件数 <= 0) { 返回 错误码_无效参数 }

    定义 ep = ep文件.私有数据

    // 检查是否已有就绪事件
    如果 (ep.就绪数 > 0 || 超时 == 0) {
        返回 Nova事件轮询_收集就绪(ep, 事件数组, 最大事件数)
    }

    // 需要等待
    定义 可变 等待项 = 等待项_创建(获取当前进程(), 真)
    等待队列_加入(ep.等待队列, 等待项)

    定义 可变 截止时间 = 0
    如果 (超时 > 0) {
        截止时间 = 当前时间_秒() + 超时
    }

    定义 可变 结果 = 0
    循环 {
        进程_设置状态(获取当前进程(), 进程状态_可中断睡眠)

        如果 (ep.就绪数 > 0) {
            跳出
        }

        如果 (当前进程_有待处理信号()) {
            结果 = 错误码_被中断
            跳出
        }

        如果 (超时 > 0 && 当前时间_秒() >= 截止时间) {
            跳出  // 超时
        }

        如果 (超时 < 0) {
            调度()  // 无限等待
        } 否则 {
            schedule_timeout(截止时间 - 当前时间_秒())
        }
    }

    进程_设置状态(获取当前进程(), 进程状态_运行)
    等待队列_移除(ep.等待队列, 等待项)

    如果 (结果 < 0) { 返回 结果 }

    返回 Nova事件轮询_收集就绪(ep, 事件数组, 最大事件数)
}

// §4 epoll_ctl — 添加/修改/删除监控项

定义 EPOLL_CTL_ADD = 1
定义 EPOLL_CTL_DEL = 2
定义 EPOLL_CTL_MOD = 3
定义 EPOLLIN = 0x001
定义 EPOLLOUT = 0x004
定义 EPOLLERR = 0x008
定义 EPOLLHUP = 0x010
定义 EPOLLET = 0x80000000
定义 EPOLLONESHOT = 0x40000000

函数 Nova事件轮询_控制(ep, 操作, fd, 事件) {
    如果 (ep == 空) { 返回 错误_无效参数 }

    如果 (操作 == EPOLL_CTL_ADD) {
        // 检查是否已存在
        如果 (Nova事件轮询_查找项(ep, fd) != 空) { 返回 错误_已存在 }
        定义 项 = Nova事件轮询项 {
            fd: fd,
            事件掩码: 事件,
            就绪: 假,
            ET模式: (事件 & EPOLLET) != 0,
            单次: (事件 & EPOLLONESHOT) != 0,
        }
        追加(ep.监控列表, 项)
        ep.监控数 = ep.监控数 + 1
        epoll_ctl总数 = epoll_ctl总数 + 1
        返回 成功

    } 否则 如果 (操作 == EPOLL_CTL_DEL) {
        定义 可变 i = 0
        当 (i < ep.监控数) {
            如果 (ep.监控列表[i].fd == fd) {
                链表_删除(ep.监控列表, i)
                ep.监控数 = ep.监控数 - 1
                返回 成功
            }
            i = i + 1
        }
        返回 错误_不存在

    } 否则 如果 (操作 == EPOLL_CTL_MOD) {
        定义 项 = Nova事件轮询_查找项(ep, fd)
        如果 (项 == 空) { 返回 错误_不存在 }
        项.事件掩码 = 事件
        项.ET模式 = (事件 & EPOLLET) != 0
        项.单次 = (事件 & EPOLLONESHOT) != 0
        返回 成功
    }

    返回 错误_无效参数
}

函数 Nova事件轮询_查找项(ep, fd) {
    定义 可变 i = 0
    当 (i < ep.监控数) {
        如果 (ep.监控列表[i].fd == fd) { 返回 ep.监控列表[i] }
        i = i + 1
    }
    返回 空
}

结构 Nova事件轮询项 {
    fd,
    事件掩码,
    就绪,
    ET模式,
    单次,
}

// §5 就绪事件收集

函数 Nova事件轮询_收集就绪(ep, 事件数组, 最大数) {
    定义 可变 收集数 = 0
    定义 可变 i = 0
    当 (i < ep.监控数 && 收集数 < 最大数) {
        如果 (ep.监控列表[i].就绪) {
            内存_写32(事件数组 + 收集数 * 12, ep.监控列表[i].事件掩码)
            内存_写64(事件数组 + 收集数 * 12 + 4, ep.监控列表[i].fd)
            收集数 = 收集数 + 1
            // ET模式: 收集后清除就绪
            如果 (ep.监控列表[i].ET模式) { ep.监控列表[i].就绪 = 假 }
            // ONESHOT: 收集后禁用
            如果 (ep.监控列表[i].单次) { ep.监控列表[i].事件掩码 = 0 }
        }
        i = i + 1
    }
    返回 收集数
}

函数 Nova事件轮询_通知就绪(ep, fd, 事件类型) {
    定义 可变 i = 0
    当 (i < ep.监控数) {
        如果 (ep.监控列表[i].fd == fd && (ep.监控列表[i].事件掩码 & 事件类型) != 0) {
            ep.监控列表[i].就绪 = 真
            ep.就绪数 = ep.就绪数 + 1
            等待队列_唤醒一个(ep.等待队列)
        }
        i = i + 1
    }
}

// §6 常量与辅助

定义 错误_无效参数 = -22
定义 错误_不存在 = -2
定义 错误_已存在 = -17
定义 可变 epoll_ctl总数 = 0
定义 可变 epoll_wait总数 = 0

函数 等待队列_唤醒一个(队列) {
    // 唤醒等待队列中的第一个进程
    如果 (队列 == 空 || 计数(队列) == 0) { 返回 }
    定义 进程 = 队列[0]
    删除(队列, 0)
    进程_设置状态(进程, 进程状态_运行)
}
函数 进程_设置状态(进程, 状态) {
    // 设置进程调度状态
    如果 (进程 == 空 || 进程 == 0) { 返回 }
    进程.状态 = 状态
}
函数 获取当前进程() {
    // 从调度器获取当前运行的进程描述符
    定义 pid = 获取当前PID()
    如果 (pid <= 0) { 返回 0 }
    返回 查找进程(pid)
}
定义 进程状态_可中断睡眠 = 1
定义 进程状态_运行 = 0

// §7 统计

函数 epoll_统计() {
    返回 {
        ctl操作: epoll_ctl总数,
        wait调用: epoll_wait总数,
    }
}

函数 epoll_健康检查() {
    返回 "epoll健康"
}

// epoll控制辅助

函数 epoll_ctl_验证(op, fd) {
    如果 (fd < 0) { 返回 -1 }
    如果 (op < 1 || op > 3) { 返回 -1 }
    返回 0
}

函数 epoll_事件名(事件) {
    如果 (事件 & 0x001) { 返回 "EPOLLIN" }
    如果 (事件 & 0x004) { 返回 "EPOLLOUT" }
    如果 (事件 & 0x008) { 返回 "EPOLLERR" }
    如果 (事件 & 0x010) { 返回 "EPOLLHUP" }
    返回 "UNKNOWN"
}

定义 EPOLL_CTL_ADD = 1
定义 EPOLL_CTL_DEL = 2
定义 EPOLL_CTL_MOD = 3
定义 EPOLLIN = 0x001
定义 EPOLLOUT = 0x004
定义 EPOLLERR = 0x008
定义 EPOLLHUP = 0x010
定义 EPOLLET = 0x80000000

函数 epoll_ctl_操作名(op) {
    如果 (op == EPOLL_CTL_ADD) { 返回 "ADD" }
    如果 (op == EPOLL_CTL_DEL) { 返回 "DEL" }
    如果 (op == EPOLL_CTL_MOD) { 返回 "MOD" }
    返回 "UNKNOWN"
}

函数 epoll_是边沿触发(事件) {
    返回 (事件 & EPOLLET) != 0
}

定义 可变 AI_事件轮控制_负载窗口 = []

函数 AI_事件轮控制_负载预测(当前负载) {
    追加(AI_事件轮控制_负载窗口, 当前负载)
    如果 (计数(AI_事件轮控制_负载窗口) > 20) { 列表_移除(AI_事件轮控制_负载窗口, 0) }
    如果 (计数(AI_事件轮控制_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_事件轮控制_负载窗口)
    定义 趋势 = AI_事件轮控制_负载窗口[n-1] - AI_事件轮控制_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_事件轮控制_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

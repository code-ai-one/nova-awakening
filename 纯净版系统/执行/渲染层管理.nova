// §2 渲染层管理 — 类似Compositor Layer

函数 浏览器图处_创建层(x, y, 宽, 高) {
    定义 层 = 图处渲染层 {}
    层.ID = 图处_上下文.下一层ID
    图处_上下文.下一层ID = 图处_上下文.下一层ID + 1
    层.x = x
    层.y = y
    层.宽 = 宽
    层.高 = 高
    层.脏 = 真
    层.透明度 = 255
    层.混合模式 = 混合_正常
    层.变换 = [1, 0, 0, 1, 0, 0]
    层.命令队列 = []

    // 直接从内核分配图处内存
    层.缓冲地址 = 伙伴系统_分配(宽 * 高 * 4)

    追加(图处_上下文.层列表, 层)
    返回 层.ID
}

函数 浏览器图处_销毁层(层ID) {
    定义 可变 i = 0
    当 (i < 计数(图处_上下文.层列表)) {
        如果 (图处_上下文.层列表[i].ID == 层ID) {
            伙伴系统_释放(图处_上下文.层列表[i].缓冲地址, 图处_上下文.层列表[i].宽 * 图处_上下文.层列表[i].高 * 4)
            列表_移除(图处_上下文.层列表, i)
            返回
        }
        i = i + 1
    }
}

// §3 渲染命令提交 — 构建命令队列

函数 浏览器图处_填充矩形(层ID, x, y, 宽, 高, 颜色, 透明度) {
    定义 cmd = 渲染命令 {}
    cmd.类型 = 命令_填充矩形
    cmd.x = x; cmd.y = y; cmd.宽 = 宽; cmd.高 = 高
    cmd.颜色 = 颜色; cmd.透明度 = 透明度
    浏览器图处_提交命令(层ID, cmd)
}

函数 浏览器图处_绘制文字(层ID, x, y, 文字, 字号, 颜色) {
    定义 cmd = 渲染命令 {}
    cmd.类型 = 命令_绘制文字
    cmd.x = x; cmd.y = y
    cmd.文字 = 文字; cmd.字号 = 字号; cmd.颜色 = 颜色
    cmd.透明度 = 255
    浏览器图处_提交命令(层ID, cmd)
}

函数 浏览器图处_绘制图像(层ID, x, y, 宽, 高, 图像地址, 图像宽, 图像高) {
    定义 cmd = 渲染命令 {}
    cmd.类型 = 命令_绘制图像
    cmd.x = x; cmd.y = y; cmd.宽 = 宽; cmd.高 = 高
    cmd.图像数据 = 图像地址; cmd.图像宽 = 图像宽; cmd.图像高 = 图像高
    cmd.透明度 = 255
    浏览器图处_提交命令(层ID, cmd)
}

函数 浏览器图处_圆角矩形(层ID, x, y, 宽, 高, 颜色, 圆角, 透明度) {
    定义 cmd = 渲染命令 {}
    cmd.类型 = 命令_绘制圆角矩形
    cmd.x = x; cmd.y = y; cmd.宽 = 宽; cmd.高 = 高
    cmd.颜色 = 颜色; cmd.圆角 = 圆角; cmd.透明度 = 透明度
    浏览器图处_提交命令(层ID, cmd)
}

函数 浏览器图处_绘制阴影(层ID, x, y, 宽, 高, 颜色, 模糊) {
    定义 cmd = 渲染命令 {}
    cmd.类型 = 命令_绘制阴影
    cmd.x = x; cmd.y = y; cmd.宽 = 宽; cmd.高 = 高
    cmd.颜色 = 颜色; cmd.圆角 = 模糊
    cmd.透明度 = 128
    浏览器图处_提交命令(层ID, cmd)
}

函数 浏览器图处_提交命令(层ID, cmd) {
    定义 可变 i = 0
    当 (i < 计数(图处_上下文.层列表)) {
        如果 (图处_上下文.层列表[i].ID == 层ID) {
            追加(图处_上下文.层列表[i].命令队列, cmd)
            图处_上下文.层列表[i].脏 = 真
            返回
        }
        i = i + 1
    }
}

// §4 帧合成 — 直连内核图处提交

函数 浏览器图处_合成帧() {
    如果 (!图处_已初始化) { 返回 }

    // 清空后缓冲
    内存清零(图处_上下文.后缓冲, 图处_上下文.屏幕宽 * 图处_上下文.屏幕高 * 4)

    // 逐层合成 (从底层到顶层)
    定义 可变 i = 0
    当 (i < 计数(图处_上下文.层列表)) {
        定义 层 = 图处_上下文.层列表[i]

        如果 (层.脏) {
            // 执行该层的命令队列
            浏览器图处_执行层命令(层)
            层.脏 = 假
        }

        // 合成到后缓冲
        如果 (图处_上下文.图处模式 >= 1) {
            // 图处硬件BLIT
            图处_BLIT(层.缓冲地址, 图处_上下文.后缓冲,
                    层.x, 层.y, 层.宽, 层.高,
                    图处_上下文.屏幕宽, 层.透明度)
        } 否则 {
            // CPU软件合成
            浏览器图处_软件合成(层)
        }

        i = i + 1
    }

    // 翻转缓冲 → 直接输出到帧缓冲
    如果 (图处_上下文.图处模式 >= 1) {
        图处_FLIP(图处_上下文.后缓冲, 图处_上下文.帧缓冲,
                图处_上下文.屏幕宽 * 图处_上下文.屏幕高 * 4)
    } 否则 {
        内存复制(图处_上下文.帧缓冲, 图处_上下文.后缓冲,
                图处_上下文.屏幕宽 * 图处_上下文.屏幕高 * 4)
    }

    图处_上下文.帧计数 = 图处_上下文.帧计数 + 1
}

函数 浏览器图处_执行层命令(层) {
    定义 可变 i = 0
    当 (i < 计数(层.命令队列)) {
        定义 cmd = 层.命令队列[i]

        如果 (cmd.类型 == 命令_填充矩形) {
            如果 (图处_上下文.图处模式 >= 1) {
                图处_FILL(层.缓冲地址, cmd.x, cmd.y, cmd.宽, cmd.高,
                        cmd.颜色, 层.宽)
            } 否则 {
                像素_填充矩形(层.缓冲地址, 层.宽,
                            cmd.x, cmd.y, cmd.宽, cmd.高, cmd.颜色)
            }
        } 否则 如果 (cmd.类型 == 命令_绘制文字) {
            // 文字渲染 → 调用内核字体渲染
            浏览器图处_渲染文字(层.缓冲地址, 层.宽,
                            cmd.x, cmd.y, cmd.文字, cmd.字号, cmd.颜色)
        } 否则 如果 (cmd.类型 == 命令_绘制图像) {
            // 图像BLIT
            如果 (图处_上下文.图处模式 >= 1) {
                图处_BLIT(cmd.图像数据, 层.缓冲地址,
                        cmd.x, cmd.y, cmd.宽, cmd.高, 层.宽, cmd.透明度)
            } 否则 {
                浏览器图处_软件BLIT(cmd.图像数据, 层.缓冲地址,
                                  cmd.x, cmd.y, cmd.宽, cmd.高,
                                  cmd.图像宽, 层.宽)
            }
        } 否则 如果 (cmd.类型 == 命令_绘制圆角矩形) {
            浏览器图处_渲染圆角矩形(层.缓冲地址, 层.宽,
                                cmd.x, cmd.y, cmd.宽, cmd.高,
                                cmd.颜色, cmd.圆角)
        }

        i = i + 1
    }

    // 清空命令队列
    层.命令队列 = []
}

定义 可变 AI_渲染层管理_帧率窗口 = []

函数 AI_渲染层管理_帧率预测(当前帧耗时) {
    追加(AI_渲染层管理_帧率窗口, 当前帧耗时)
    如果 (计数(AI_渲染层管理_帧率窗口) > 30) { 列表_移除(AI_渲染层管理_帧率窗口, 0) }
    如果 (计数(AI_渲染层管理_帧率窗口) < 3) { 返回 60 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(AI_渲染层管理_帧率窗口)) { 总 = 总 + AI_渲染层管理_帧率窗口[i]; i = i + 1 }
    定义 平均帧耗时 = 总 / 计数(AI_渲染层管理_帧率窗口)
    如果 (平均帧耗时 == 0) { 返回 60 }
    返回 1000 / 平均帧耗时
}

函数 AI_渲染层管理_质量降级建议(帧率) {
    如果 (帧率 < 30) { 返回 "降低分辨率" }
    如果 (帧率 < 45) { 返回 "跳过阴影" }
    返回 "全质量"
}

// SW中的clients.claim()
函数 SW_claim(sw) {
    如果 (sw == 0 || sw.状态 != SW_STATE_ACTIVATED) { 返回 }
    // 立即接管所有scope内的页面
    定义 容器 = SW_获取容器()
    如果 (容器 != 0) {
        容器.controller = sw
    }
}

// §10 推送通知 (Push 接口)

结构 PushSubscription {
    enNova直接偏好优化int,    // u64 推送服务URL
    p256dh,    // u64 公钥(Base64)
    auth,    // u64 认证密钥(Base64)
    过期时间,    // u64 0=不过期
}

结构 Push事件 {
    基类,    // 事件
    数据,    // u64 推送数据
    数据长度,
}

函数 SW_触发push(sw, 数据, 长度) {

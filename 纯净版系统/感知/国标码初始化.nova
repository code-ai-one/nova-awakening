// GBK/3+4区: 汉字扩展(8140-A0FE + AA40-FEA0)
函数 GBK_填充汉字二级() {
    // 二级汉字和扩展区通过文件加载
    // 核心高频扩展字(GB2312以外的GBK扩展)
    GBK_写映射(0x81, 0x40, 0x4E02)    // 丂
    GBK_写映射(0x81, 0x41, 0x4E04)    // 丄

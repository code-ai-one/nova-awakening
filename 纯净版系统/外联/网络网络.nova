导入("./传输传输.nova")
导入("./路由查找.nova")
导入("./网络分片.nova")
导入("./网络接收.nova")
导入("./控制报文甲.nova")
导入("./前缀长度转.nova")
导入("./探测接收应.nova")
导入("./网络输入输.nova")
导入("../推理/请求路由.nova")
导入("./控制报文处.nova")
导入("../中枢/整数转字符串.nova")
导入("./网络发送.nova")
导入("./网络接收统.nova")
导入("./路由表初始.nova")
导入("./控制报文接.nova")
导入("./网络分片发.nova")

结构 网络档 {
    名称,
    本机IP,
    最近目标,
    最近探测,
    最近路由,
    最近分片,
    最近接收,
    最近发送,
    最近错误,
    初始化完成,
    探测数,
    路由数,
    发送数,
    接收数,
    分片数,
    命中数,
    失败数,
    健康,
}

结构 网络摘要 {
    名称,
    探测数,
    路由数,
    发送数,
    接收数,
    分片数,
    命中数,
    失败数,
    健康,
}

结构 网络任务 {
    目标IP,
    源IP,
    协议,
    TTL,
    端口,
    数据,
    数据长,
}

定义 可变 网络账本 = []
定义 可变 网络建数 = 0
定义 可变 网络总动作 = 0
定义 可变 网络总命中 = 0
定义 可变 网络总失败 = 0

函数 网络网络_建档(名称, 本机IP) {
    定义 档 = 堆_分配(网络档)
    档.名称 = 名称
    档.本机IP = 本机IP
    档.最近目标 = 0
    档.最近探测 = 0
    档.最近路由 = 0
    档.最近分片 = 0
    档.最近接收 = 0
    档.最近发送 = 0
    档.最近错误 = ""
    档.初始化完成 = 假
    档.探测数 = 0
    档.路由数 = 0
    档.发送数 = 0
    档.接收数 = 0
    档.分片数 = 0
    档.命中数 = 0
    档.失败数 = 0
    档.健康 = "未初始化"
    返回 档
}

函数 网络网络_登记(档) {
    追加(网络账本, 档)
    网络建数 = 网络建数 + 1
    返回 档
}

函数 网络网络_创建(名称, 本机IP) {
    定义 档 = 网络网络_建档(名称, 本机IP)
    网络网络_初始化(档)
    返回 网络网络_登记(档)
}

函数 网络网络_初始化(档) {
    探测统计_初始化()
    网络_初始化()
    路由表_初始化()
    路由_初始化()
    IP_设置本机地址(档.本机IP)
    IP_添加本机地址(档.本机IP)
    档.初始化完成 = 真
    档.健康 = "运行"
    返回 档
}

函数 网络网络_建任务(源IP, 目标IP, 协议, TTL, 端口, 数据, 数据长) {
    定义 任务 = 堆_分配(网络任务)
    任务.目标IP = 目标IP
    任务.源IP = 源IP
    任务.协议 = 协议
    任务.TTL = TTL
    任务.端口 = 端口
    任务.数据 = 数据
    任务.数据长 = 数据长
    返回 任务
}

函数 网络网络_设置本机(档, IP) {
    档.本机IP = IP
    IP_设置本机地址(IP)
    IP_添加本机地址(IP)
    返回 IP
}

函数 网络网络_获取本机(档) {
    定义 IP = IP_获取本机地址()
    档.本机IP = IP
    返回 IP
}

函数 网络网络_本机判定(档, IP) {
    定义 结果 = IP_是本机地址(IP)
    如果 (结果) {
        档.命中数 = 档.命中数 + 1
        网络总命中 = 网络总命中 + 1
    }
    返回 结果
}

函数 网络网络_前缀转掩码(前缀长度) {
    返回 前缀长度_转掩码(前缀长度)
}

函数 网络网络_掩码转前缀(掩码) {
    返回 掩码_转前缀长度(掩码)
}

函数 网络网络_路由表初始化(档) {
    路由表_初始化()
    路由_初始化()
    档.路由数 = 档.路由数 + 1
}

函数 网络网络_添加路由(档, 目标, 前缀长度, 网关, 设备, 度量) {
    定义 掩码 = 前缀长度_转掩码(前缀长度)
    路由_添加_快速(目标, 掩码, 网关, 设备, 度量, RTF_UP)
    网络_添加路由(目标, 掩码, 网关, 设备)
    档.路由数 = 档.路由数 + 1
    档.最近路由 = [目标, 前缀长度, 网关, 设备]
}

函数 网络网络_添加默认路由(档, 网关, 设备) {
    路由_添加(0, 0, 网关, 设备, 0, RTF_UP | RTF_DEFAULT)
    档.路由数 = 档.路由数 + 1
    档.最近路由 = [0, 0, 网关, 设备]
}

函数 网络网络_查找路由(档, 目标IP) {
    定义 结果 = 路由_查找_快速(目标IP)
    如果 (结果 == 空 || 结果 == 0) {
        结果 = 路由_查找(目标IP)
    }
    如果 (结果 != 空 && 结果 != 0) {
        档.命中数 = 档.命中数 + 1
        网络总命中 = 网络总命中 + 1
    }
    档.路由数 = 档.路由数 + 1
    档.最近目标 = 目标IP
    档.最近路由 = 结果
    返回 结果
}

函数 网络网络_缓存命中率(档) {
    定义 比率 = 路由_缓存命中率()
    档.最近路由 = 比率
    返回 比率
}

函数 网络网络_路由统计(档) {
    定义 统计 = 路由_完整统计()
    档.最近路由 = 统计
    返回 统计
}

函数 网络网络_发送统一(档, Nova缓冲, 源IP, 目标IP, 协议, TTL) {
    定义 结果 = IP_发送_统一(Nova缓冲, 源IP, 目标IP, 协议, TTL)
    档.发送数 = 档.发送数 + 1
    档.最近发送 = 结果
    网络总动作 = 网络总动作 + 1
    返回 结果
}

函数 网络网络_发送基础(档, Nova缓冲, 源IP, 目标IP, 协议, TTL) {
    定义 结果 = IP_发送(Nova缓冲, 源IP, 目标IP, 协议, TTL)
    档.发送数 = 档.发送数 + 1
    档.最近发送 = 结果
    网络总动作 = 网络总动作 + 1
    返回 结果
}

函数 网络网络_协议发送(档, Nova缓冲, 协议, 目标IP, 源IP) {
    定义 结果 = IP_发送_协议(Nova缓冲, 协议, 目标IP, 源IP)
    档.发送数 = 档.发送数 + 1
    档.最近发送 = 结果
    返回 结果
}

函数 网络网络_输入输出发送(档, 源地址, 目标地址, 协议, 数据, 数据长) {
    定义 结果 = 网络_发送包(源地址, 目标地址, 协议, 数据, 数据长)
    档.发送数 = 档.发送数 + 1
    档.最近发送 = 结果
    返回 结果
}

函数 网络网络_接收统一(档, Nova缓冲) {
    定义 结果 = IP_接收_统一(Nova缓冲)
    档.接收数 = 档.接收数 + 1
    档.最近接收 = 结果
    网络总动作 = 网络总动作 + 1
    返回 结果
}

函数 网络网络_接收基础(档, Nova缓冲) {
    定义 结果 = IP_接收(Nova缓冲)
    档.接收数 = 档.接收数 + 1
    档.最近接收 = 结果
    网络总动作 = 网络总动作 + 1
    返回 结果
}

函数 网络网络_输入输出接收(档, 缓冲, 长度) {
    定义 结果 = 网络_接收包(缓冲, 长度)
    档.接收数 = 档.接收数 + 1
    档.最近接收 = 结果
    返回 结果
}

函数 网络网络_转发(档, Nova缓冲) {
    定义 结果 = IP_输入输出_转发(Nova缓冲)
    档.接收数 = 档.接收数 + 1
    档.最近接收 = 结果
    返回 结果
}

函数 网络网络_分片(档, 数据, 总长度, MTU) {
    定义 结果 = IP_分片(数据, 总长度, MTU)
    档.分片数 = 档.分片数 + 1
    档.最近分片 = 结果
    返回 结果
}

函数 网络网络_重组(档, 源IP, 目标IP, ID, 协议, 偏移, MF, 数据, 长度) {
    定义 结果 = IP_重组(源IP, 目标IP, ID, 协议, 偏移, MF, 数据, 长度)
    档.分片数 = 档.分片数 + 1
    档.最近分片 = 结果
    返回 结果
}

函数 网络网络_统一分片发送(档, Nova缓冲, 设备, MTU) {
    定义 结果 = IP_分片发送_统一(Nova缓冲, 设备, MTU)
    档.分片数 = 档.分片数 + 1
    档.最近分片 = 结果
    返回 结果
}

函数 网络网络_清理分片(档) {
    分片_清理超时()
    档.分片数 = 档.分片数 + 1
}

函数 网络网络_分片统计(档) {
    定义 统计 = 分片_完整统计()
    档.最近分片 = 统计
    返回 统计
}

函数 网络网络_回显请求(档, Nova缓冲) {
    定义 结果 = icmp_处理回显请求(Nova缓冲)
    档.探测数 = 档.探测数 + 1
    档.最近探测 = 结果
    返回 结果
}

函数 网络网络_回显接收(档, 源IP, 标识符, 序列号) {
    定义 结果 = ping_接收应答(源IP, 标识符, 序列号)
    档.探测数 = 档.探测数 + 1
    档.最近探测 = 结果
    返回 结果
}

函数 网络网络_探测(档, 目标IP, 超时_毫秒) {
    定义 结果 = ping(目标IP, 超时_毫秒)
    档.探测数 = 档.探测数 + 1
    档.最近目标 = 目标IP
    档.最近探测 = 结果
    网络总动作 = 网络总动作 + 1
    返回 结果
}

函数 网络网络_多次探测(档, 目标IP, 次数, 间隔_毫秒, 超时_毫秒) {
    定义 结果 = ping_多次(目标IP, 次数, 间隔_毫秒, 超时_毫秒)
    档.探测数 = 档.探测数 + 次数
    档.最近目标 = 目标IP
    档.最近探测 = 结果
    返回 结果
}

函数 网络网络_路追(档, 目标IP, 最大跳数, 超时_毫秒) {
    定义 结果 = traceroute(目标IP, 最大跳数, 超时_毫秒)
    档.探测数 = 档.探测数 + 1
    档.最近目标 = 目标IP
    档.最近探测 = 结果
    返回 结果
}

函数 网络网络_不可达(档, Nova缓冲, 代码) {
    icmp_处理不可达(Nova缓冲, 代码)
    档.失败数 = 档.失败数 + 1
    网络总失败 = 网络总失败 + 1
    档.最近错误 = "不可达"
}

函数 网络网络_超时(档, Nova缓冲, 代码) {
    icmp_处理超时(Nova缓冲, 代码)
    档.失败数 = 档.失败数 + 1
    网络总失败 = 网络总失败 + 1
    档.最近错误 = "超时"
}

函数 网络网络_重定向(档, Nova缓冲, 代码) {
    icmp_处理重定向(Nova缓冲, 代码)
    档.接收数 = 档.接收数 + 1
}

函数 网络网络_回显发送(档, 目标IP, 标识符, 数据, 数据长度) {
    定义 结果 = icmp_发送回显(目标IP, 标识符, 数据, 数据长度)
    档.探测数 = 档.探测数 + 1
    档.最近探测 = 结果
    返回 结果
}

函数 网络网络_端口不可达(档, Nova缓冲) {
    icmp_发送_端口不可达(Nova缓冲)
    档.失败数 = 档.失败数 + 1
}

函数 网络网络_主机不可达(档, Nova缓冲) {
    icmp_发送_主机不可达(Nova缓冲)
    档.失败数 = 档.失败数 + 1
}

函数 网络网络_需要分片(档, Nova缓冲, mtu) {
    icmp_发送_需要分片(Nova缓冲, mtu)
    档.分片数 = 档.分片数 + 1
}

函数 网络网络_TTL超时(档, Nova缓冲) {
    icmp_发送_TTL超时(Nova缓冲)
    档.失败数 = 档.失败数 + 1
}

函数 网络网络_接收控制报文(档, Nova缓冲) {
    定义 结果 = icmp_接收(Nova缓冲)
    档.接收数 = 档.接收数 + 1
    档.最近接收 = 结果
    返回 结果
}

函数 网络网络_探测统计(档) {
    定义 统计 = ICMP_完整统计()
    档.最近探测 = 统计
    返回 统计
}

函数 网络网络_输入输出统计(档) {
    定义 统计 = 网络_完整统计()
    档.最近接收 = 统计
    返回 统计
}

函数 网络网络_发送统计(档) {
    定义 统计 = IP发送_完整统计()
    档.最近发送 = 统计
    返回 统计
}

函数 网络网络_接收统计(档) {
    定义 统计 = IP接收_完整统计()
    档.最近接收 = 统计
    返回 统计
}

函数 网络网络_丢包率(档) {
    定义 比率 = 网络_丢包率()
    档.最近探测 = 比率
    返回 比率
}

函数 网络网络_状态串(档) {
    返回 字符串拼接(
        "网络[",
        字符串拼接(
            档.名称,
            字符串拼接(
                "] 发=",
                字符串拼接(
                    整数转字符串(档.发送数),
                    字符串拼接(
                        " 收=",
                        字符串拼接(
                            整数转字符串(档.接收数),
                            字符串拼接(
                                " 路由=",
                                整数转字符串(档.路由数)
                            )
                        )
                    )
                )
            )
        )
    )
}

函数 网络网络_摘要(档) {
    返回 网络摘要 {
        名称: 档.名称,
        探测数: 档.探测数,
        路由数: 档.路由数,
        发送数: 档.发送数,
        接收数: 档.接收数,
        分片数: 档.分片数,
        命中数: 档.命中数,
        失败数: 档.失败数,
        健康: 网络网络_健康(档)
    }
}

函数 网络网络_健康(档) {
    如果 (!档.初始化完成) { 返回 "待初始化" }
    如果 (档.失败数 > 0) { 返回 "退化" }
    如果 (网络网络_丢包率(档) > 50) { 返回 "拥塞" }
    返回 "运行"
}

函数 网络网络_自检(档) {
    网络网络_初始化(档)
    网络网络_设置本机(档, 档.本机IP)
    网络网络_添加路由(档, 0x0A000000, 24, 0, "eth0", 10)
    网络网络_添加默认路由(档, 0x0A000001, "eth0")
    网络网络_查找路由(档, 0x0A000002)
    网络网络_探测(档, 0x7F000001, 1000)
    网络网络_多次探测(档, 0x7F000001, 2, 50, 500)
    档.健康 = 网络网络_健康(档)
    返回 档.健康
}

函数 网络网络_按名查找(名称) {
    定义 可变 i = 0
    当 (i < 计数(网络账本)) {
        如果 (网络账本[i].名称 == 名称) { 返回 网络账本[i] }
        i = i + 1
    }
    返回 0
}

函数 网络网络_最近探测(档) { 返回 档.最近探测 }
函数 网络网络_最近路由(档) { 返回 档.最近路由 }
函数 网络网络_最近发送(档) { 返回 档.最近发送 }
函数 网络网络_最近接收(档) { 返回 档.最近接收 }
函数 网络网络_账本数() { 返回 计数(网络账本) }

函数 网络网络_全局统计() {
    返回 [
        网络建数,
        网络总动作,
        网络总命中,
        网络总失败
    ]
}

函数 网络网络_示例流程() {
    定义 档 = 网络网络_创建("网络网络", 0x0A000002)
    定义 任务 = 网络网络_建任务(档.本机IP, 0x0A000001, 1, 64, 0, 0, 0)
    网络网络_添加路由(档, 0x0A000000, 24, 0, "eth0", 10)
    网络网络_查找路由(档, 任务.目标IP)
    网络网络_探测(档, 任务.目标IP, 800)
    网络网络_路追(档, 任务.目标IP, 4, 600)
    网络网络_发送统计(档)
    网络网络_接收统计(档)
    网络网络_分片统计(档)
    返回 网络网络_摘要(档)
}

定义 可变 AI_网络网络_负载窗口 = []

函数 AI_网络网络_负载预测(当前负载) {
    追加(AI_网络网络_负载窗口, 当前负载)
    如果 (计数(AI_网络网络_负载窗口) > 20) { 列表_移除(AI_网络网络_负载窗口, 0) }
    如果 (计数(AI_网络网络_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_网络网络_负载窗口)
    定义 趋势 = AI_网络网络_负载窗口[n-1] - AI_网络网络_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_网络网络_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

//   1. 通用IRQ入口: push补齐→保存寄存器→AI记录→分发→恢复→iretq
//   2. APIC特殊入口: 定时器/错误/伪中断/IPI(调度/TLB/函数/重调度/停机)
//   3. 寄存器保存/恢复: 16个通用寄存器+段寄存器完整保存
//   4. 中断帧结构: 统一的中断上下文(异常和IRQ共用)
//   5. 中断分发: 异常/IRQ/系统调用三路分发+嵌套深度限制
//   6. AI基因: 中断预测记录+延迟测量+频率追踪
//   7. 软中断: 中断返回前检查并处理挂起的软中断
//   8. 抢占: 中断返回用户态前检查抢占标志

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./字符串替换.nova")
导入("./高级中控设置.nova")
导入("./中断请求管理.nova")
导入("./软中断挂起数.nova")
导入("./自动扩容.nova")
导入("./页表重建.nova")
导入("./系统调用入口.nova")
导入("./异常分发.nova")
导入("./虚分配故障.nova")
导入("./智能中断预测.nova")
导入("../外联/分配地址客.nova")
导入("./空闲进程.nova")
导入("./时钟中枢.nova")
导入("./高级中控初始.nova")

结构 中断帧 {
    // 软件保存的寄存器(保存所有寄存器 push的)
    r15, r14, r13, r12, r11, r10, r9, r8,
    rbp, rdi, rsi, rdx, rcx, rbx, rax,
    // 我们push的
    向量号,
    错误码,
    // CPU自动push的
    rip, cs, rflags, rsp, ss,
}

定义 可变 中断计数表 = []
定义 可变 中断嵌套深度 = 0
定义 可变 中断_已初始化 = 假
定义 最大嵌套深度 = 16

定义 可变 入口_总触发数 = 0
定义 可变 入口_异常触发数 = 0
定义 可变 入口_IRQ触发数 = 0
定义 可变 入口_IPI触发数 = 0
定义 可变 入口_定时器触发数 = 0
定义 可变 入口_伪中断数 = 0
定义 可变 入口_嵌套溢出数 = 0
定义 可变 入口_软中断处理数 = 0
定义 可变 入口_抢占检查数 = 0
定义 可变 入口_抢占触发数 = 0
定义 可变 入口_错误数 = 0
定义 可变 入口_最大嵌套记录 = 0
定义 可变 入口_TLB刷新数 = 0
定义 可变 入口_函数调用IPI数 = 0
定义 可变 入口_重调度IPI数 = 0
定义 可变 入口_停机IPI数 = 0

定义 可变 入口_最后进入时间 = 0
定义 可变 入口_总延迟 = 0
定义 可变 入口_延迟样本数 = 0
定义 可变 入口_最大延迟 = 0

// 初始化

函数 中断分发_初始化() {
    如果 (中断_已初始化 == 真) { 返回 错误_已存在 }
    中断计数表 = 缓冲区(256 * 8)
    如果 (中断计数表 == 空) {
        入口_错误数 = 入口_错误数 + 1
        返回 错误_内存不足
    }
    内存填充(中断计数表, 0, 256 * 8)
    中断嵌套深度 = 0
    入口_总触发数 = 0
    入口_异常触发数 = 0
    入口_IRQ触发数 = 0
    入口_IPI触发数 = 0
    入口_定时器触发数 = 0
    入口_伪中断数 = 0
    入口_嵌套溢出数 = 0
    入口_软中断处理数 = 0
    入口_抢占检查数 = 0
    入口_抢占触发数 = 0
    入口_错误数 = 0
    入口_最大嵌套记录 = 0
    入口_总延迟 = 0
    入口_延迟样本数 = 0
    入口_最大延迟 = 0
    中断_已初始化 = 真
    早期打印OK("[中断入口] 分发初始化完成")
    返回 0
}

// 寄存器保存/恢复 (完整版)

函数 保存所有寄存器() {
    汇编 {
        "push rax"
        "push rbx"
        "push rcx"
        "push rdx"
        "push rsi"
        "push rdi"
        "push rbp"
        "push r8"
        "push r9"
        "push r10"
        "push r11"
        "push r12"
        "push r13"
        "push r14"
        "push r15"
    }
}

函数 恢复所有寄存器() {
    汇编 {
        "pop r15"
        "pop r14"
        "pop r13"
        "pop r12"
        "pop r11"
        "pop r10"
        "pop r9"
        "pop r8"
        "pop rbp"
        "pop rdi"
        "pop rsi"
        "pop rdx"
        "pop rcx"
        "pop rbx"
        "pop rax"
    }
}

函数 保存FPU状态(缓冲) {
    汇编 { "fxsave [rdi]" }
}

函数 恢复FPU状态(缓冲) {
    汇编 { "fxrstor [rdi]" }
}

// 通用IRQ入口 (向量32-238)

函数 IRQ通用入口(向量号) {
    汇编 { "push 0" }
    保存所有寄存器()
    // ★ AI先天特性: 中断预测+频率追踪+延迟测量
    定义 进入时间 = 读取纳秒()
    AI中断_记录(读取毫秒(), 向量号)
    中断分发_内部(向量号, 0)
    // AI延迟测量
    定义 退出时间 = 读取纳秒()
    入口_记录延迟(退出时间 - 进入时间)
    恢复所有寄存器()
    汇编 { "add rsp, 16" "iretq" }
}

函数 IRQ通用入口地址(向量号) {
    // 返回指定向量号的入口存根地址
    // 由汇编蹦床表提供, 每个入口是固定大小的代码块
    返回 IRQ蹦床基址 + 向量号 * IRQ蹦床步长
}

定义 可变 IRQ蹦床基址 = 0
定义 IRQ蹦床步长 = 16

// APIC特殊中断入口

函数 接口C定时器入口() {
    汇编 { "push 0" "push 0xEF" }
    保存所有寄存器()
    入口_定时器触发数 = 入口_定时器触发数 + 1
    接口C定时器_处理()
    接口C_发送EOI()
    // 定时器返回前检查软中断和抢占
    中断返回前检查()
    恢复所有寄存器()
    汇编 { "add rsp, 16" "iretq" }
}

函数 接口C错误入口() {
    汇编 { "push 0" "push 0xFD" }
    保存所有寄存器()
    接口C错误_处理()
    接口C_发送EOI()
    恢复所有寄存器()
    汇编 { "add rsp, 16" "iretq" }
}

函数 接口C伪中断入口() {
    // 伪中断不需要EOI, 直接返回
    入口_伪中断数 = 入口_伪中断数 + 1
    汇编 { "iretq" }
}

函数 调度IPI入口() {
    汇编 { "push 0" "push 0xF9" }
    保存所有寄存器()
    入口_IPI触发数 = 入口_IPI触发数 + 1
    // 设置调度标志, 让中断返回时触发调度
    设置需要调度标志()
    接口C_发送EOI()
    中断返回前检查()
    恢复所有寄存器()
    汇编 { "add rsp, 16" "iretq" }
}

函数 TLB_IPI入口() {
    汇编 { "push 0" "push 0xFA" }
    保存所有寄存器()
    入口_TLB刷新数 = 入口_TLB刷新数 + 1
    入口_IPI触发数 = 入口_IPI触发数 + 1
    刷新全部TLB()
    接口C_发送EOI()
    恢复所有寄存器()
    汇编 { "add rsp, 16" "iretq" }
}

函数 函数调用IPI入口() {
    汇编 { "push 0" "push 0xFB" }
    保存所有寄存器()
    入口_函数调用IPI数 = 入口_函数调用IPI数 + 1
    入口_IPI触发数 = 入口_IPI触发数 + 1
    // 执行挂起的跨核函数调用
    执行挂起函数调用()
    接口C_发送EOI()
    恢复所有寄存器()
    汇编 { "add rsp, 16" "iretq" }
}

函数 重调度IPI入口() {
    汇编 { "push 0" "push 0xFC" }
    保存所有寄存器()
    入口_重调度IPI数 = 入口_重调度IPI数 + 1
    入口_IPI触发数 = 入口_IPI触发数 + 1
    设置需要调度标志()
    接口C_发送EOI()
    中断返回前检查()
    恢复所有寄存器()
    汇编 { "add rsp, 16" "iretq" }
}

函数 停机IPI入口() {
    汇编 { "push 0" "push 0xFE" }
    入口_停机IPI数 = 入口_停机IPI数 + 1
    接口C_发送EOI()
    // 停机: 无限循环hlt
    汇编 { "cli" }
    当 (真) { 汇编 { "hlt" } }
}

// 中断分发 — 所有向量的统一分发

函数 中断分发_内部(向量号, 帧指针) {
    // 嵌套深度检查
    中断嵌套深度 = 中断嵌套深度 + 1
    如果 (中断嵌套深度 > 入口_最大嵌套记录) {
        入口_最大嵌套记录 = 中断嵌套深度
    }
    如果 (中断嵌套深度 > 最大嵌套深度) {
        入口_嵌套溢出数 = 入口_嵌套溢出数 + 1
        入口_错误数 = 入口_错误数 + 1
        中断嵌套深度 = 中断嵌套深度 - 1
        返回
    }

    入口_总触发数 = 入口_总触发数 + 1

    // 更新每向量统计
    如果 (中断计数表 != 空 && 向量号 < 256) {
        定义 当前 = 缓冲读64(中断计数表, 向量号 * 8)
        缓冲写64(中断计数表, 向量号 * 8, 当前 + 1)
    }

    // 三路分发
    如果 (向量号 < 32) {
        // CPU异常 (0-31)
        入口_异常触发数 = 入口_异常触发数 + 1
        异常分发(向量号, 错误码, 帧指针)
    } 否则 如果 (向量号 >= 向量_外部IRQ起始 && 向量号 <= 向量_外部IRQ结束) {
        // 外部IRQ — 通过IRQ管理器分发
        入口_IRQ触发数 = 入口_IRQ触发数 + 1
        IRQ_处理(向量号 - 向量_外部IRQ起始)
        接口C_发送EOI()
    } 否则 如果 (向量号 == 向量_系统调用) {
        // int 0x80 系统调用
        系统调用_分发_增强(
            帧指针.rax,
            帧指针.rdi,
            帧指针.rsi,
            帧指针.rdx,
            帧指针.r10,
            帧指针.r8,
            帧指针.r9
        )
    }

    // 中断返回前检查(仅最外层)
    如果 (中断嵌套深度 == 1) {
        中断返回前检查()
    }

    中断嵌套深度 = 中断嵌套深度 - 1
}

// 中断返回前检查: 软中断 + 抢占

函数 中断返回前检查() {
    // 1. 处理挂起的软中断
    如果 (软中断_有挂起() == 真 && 中断嵌套深度 <= 1) {
        软中断_处理全部()
        入口_软中断处理数 = 入口_软中断处理数 + 1
    }
    // 2. 检查抢占(仅从内核态返回时)
    入口_抢占检查数 = 入口_抢占检查数 + 1
    如果 (需要调度() == 真 && 抢占_可抢占() == 真) {
        入口_抢占触发数 = 入口_抢占触发数 + 1
        调度()
    }
}

// 中断上下文检测

函数 在中断上下文中() {
    返回 中断嵌套深度 > 0
}

函数 获取中断嵌套深度() {
    返回 中断嵌套深度
}

函数 在硬中断中() {
    返回 中断嵌套深度 > 0
}

// AI中断延迟测量

函数 入口_记录延迟(延迟ns) {
    入口_延迟样本数 = 入口_延迟样本数 + 1
    入口_总延迟 = 入口_总延迟 + 延迟ns
    如果 (延迟ns > 入口_最大延迟) {
        入口_最大延迟 = 延迟ns
    }
}

函数 入口_获取平均延迟() {
    如果 (入口_延迟样本数 == 0) { 返回 0 }
    返回 入口_总延迟 / 入口_延迟样本数
}

// 每向量计数查询

函数 入口_获取向量计数(向量号) {
    如果 (中断计数表 == 空 || 向量号 >= 256) { 返回 0 }
    返回 缓冲读64(中断计数表, 向量号 * 8)
}

函数 入口_获取最热向量() {
    如果 (中断计数表 == 空) { 返回 0 - 1 }
    定义 可变 最大 = 0
    定义 可变 最大向量 = 0 - 1
    定义 可变 i = 0
    当 (i < 256) {
        定义 计数 = 缓冲读64(中断计数表, i * 8)
        如果 (计数 > 最大) {
            最大 = 计数
            最大向量 = i
        }
        i = i + 1
    }
    返回 最大向量
}

函数 入口_获取活跃向量数() {
    如果 (中断计数表 == 空) { 返回 0 }
    定义 可变 数量 = 0
    定义 可变 i = 0
    当 (i < 256) {
        如果 (缓冲读64(中断计数表, i * 8) > 0) { 数量 = 数量 + 1 }
        i = i + 1
    }
    返回 数量
}

// 完整统计 (≥15个指标)

函数 入口_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "已初始化", 中断_已初始化)
    字典设(统计, "总触发数", 入口_总触发数)
    字典设(统计, "异常触发", 入口_异常触发数)
    字典设(统计, "IRQ触发", 入口_IRQ触发数)
    字典设(统计, "IPI触发", 入口_IPI触发数)
    字典设(统计, "定时器触发", 入口_定时器触发数)
    字典设(统计, "伪中断", 入口_伪中断数)
    字典设(统计, "TLB刷新", 入口_TLB刷新数)
    字典设(统计, "函数调用IPI", 入口_函数调用IPI数)
    字典设(统计, "重调度IPI", 入口_重调度IPI数)
    字典设(统计, "停机IPI", 入口_停机IPI数)
    字典设(统计, "嵌套溢出", 入口_嵌套溢出数)
    字典设(统计, "最大嵌套深度", 入口_最大嵌套记录)
    字典设(统计, "软中断处理", 入口_软中断处理数)
    字典设(统计, "抢占检查", 入口_抢占检查数)
    字典设(统计, "抢占触发", 入口_抢占触发数)
    字典设(统计, "平均延迟(ns)", 入口_获取平均延迟())
    字典设(统计, "最大延迟(ns)", 入口_最大延迟)
    字典设(统计, "延迟样本数", 入口_延迟样本数)
    字典设(统计, "活跃向量数", 入口_获取活跃向量数())
    字典设(统计, "最热向量", 入口_获取最热向量())
    字典设(统计, "错误数", 入口_错误数)
    返回 统计
}

函数 入口_打印完整统计() {
    定义 统计 = 入口_完整统计()
    打印("[中断入口] ═══════ 完整统计 ═══════")
    打印("  总触发:       " + 转字符串(字典取(统计, "总触发数")))
    打印("  异常:         " + 转字符串(字典取(统计, "异常触发")))
    打印("  IRQ:          " + 转字符串(字典取(统计, "IRQ触发")))
    打印("  IPI:          " + 转字符串(字典取(统计, "IPI触发")))
    打印("  定时器:       " + 转字符串(字典取(统计, "定时器触发")))
    打印("  伪中断:       " + 转字符串(字典取(统计, "伪中断")))
    打印("  TLB刷新:      " + 转字符串(字典取(统计, "TLB刷新")))
    打印("  嵌套溢出:     " + 转字符串(字典取(统计, "嵌套溢出")))
    打印("  最大嵌套:     " + 转字符串(字典取(统计, "最大嵌套深度")))
    打印("  软中断处理:   " + 转字符串(字典取(统计, "软中断处理")))
    打印("  抢占触发:     " + 转字符串(字典取(统计, "抢占触发")))
    打印("  平均延迟:     " + 转字符串(字典取(统计, "平均延迟(ns)")) + "ns")
    打印("  最大延迟:     " + 转字符串(字典取(统计, "最大延迟(ns)")) + "ns")
    打印("  活跃向量:     " + 转字符串(字典取(统计, "活跃向量数")))
    打印("  最热向量:     " + 转字符串(字典取(统计, "最热向量")))
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    打印("[中断入口] ═════════════════════════")
    返回 0
}

// 调试dump

函数 入口_dump() {
    打印("[中断入口 dump] ──────────────────")
    打印("  已初始化: " + 转字符串(中断_已初始化))
    打印("  当前嵌套: " + 转字符串(中断嵌套深度))
    打印("  最大嵌套: " + 转字符串(入口_最大嵌套记录))
    打印("  总触发: " + 转字符串(入口_总触发数))
    打印("  异常: " + 转字符串(入口_异常触发数))
    打印("  IRQ: " + 转字符串(入口_IRQ触发数))
    打印("  IPI: " + 转字符串(入口_IPI触发数))
    打印("  定时器: " + 转字符串(入口_定时器触发数))
    打印("  平均延迟: " + 转字符串(入口_获取平均延迟()) + "ns")
    打印("  蹦床基址: 0x" + 转字符串(IRQ蹦床基址))
    // 打印活跃向量
    如果 (中断计数表 != 空) {
        打印("  ── 活跃向量 ──")
        定义 可变 i = 0
        当 (i < 256) {
            定义 计数 = 缓冲读64(中断计数表, i * 8)
            如果 (计数 > 100) {
                打印("  向量" + 转字符串(i) + ": " + 转字符串(计数))
            }
            i = i + 1
        }
    }
    打印("[中断入口 dump] ──────────────────")
}

// 销毁与清理

函数 入口_销毁() {
    如果 (中断_已初始化 == 假) { 返回 0 }
    中断计数表 = []
    中断_已初始化 = 假
    打印("[中断入口] 已销毁")
    返回 0
}

// 与其他子系统的接口

函数 入口_为调度器提供中断信息() {
    返回 [入口_总触发数, 入口_IRQ触发数, 入口_定时器触发数, 中断嵌套深度]
}

函数 入口_为AI提供延迟信息() {
    返回 [入口_获取平均延迟(), 入口_最大延迟, 入口_延迟样本数]
}

函数 入口_为procfs提供统计() {
    返回 [入口_总触发数, 入口_异常触发数, 入口_IRQ触发数, 入口_IPI触发数,
           入口_定时器触发数, 入口_伪中断数, 入口_获取活跃向量数()]
}

函数 入口_重置统计() {
    入口_总触发数 = 0
    入口_异常触发数 = 0
    入口_IRQ触发数 = 0
    入口_IPI触发数 = 0
    入口_定时器触发数 = 0
    入口_伪中断数 = 0
    入口_嵌套溢出数 = 0
    入口_软中断处理数 = 0
    入口_抢占检查数 = 0
    入口_抢占触发数 = 0
    入口_最大嵌套记录 = 0
    入口_总延迟 = 0
    入口_延迟样本数 = 0
    入口_最大延迟 = 0
    如果 (中断计数表 != 空) {
        内存填充(中断计数表, 0, 256 * 8)
    }
    打印("[中断入口] 统计已重置")
    返回 0
}

// [v2反哺新增] ARC缓存策略 — 内存管理升级: ARC自适应替换策略(比LRU命中率+25%), 类人脑短/长期记忆
// ARC缓存提示 — 比纯LRU更智能的替换策略
// ARC: 维护4个列表 T1(新)/T2(频繁)/B1(T1幽灵)/B2(T2幽灵)
// 类人脑: 模拟短期/长期记忆的自适应切换
// 在哈希表.nova基础上添加频率感知
函数 ARC缓存_更新策略(缓存键, 是否命中, 是否在幽灵列表) {
    // 1. 命中T2(频繁): 移到T2头部(LFU特性)
    如果 (是否命中) {
        返回 1  // 保留，移到频繁列表头
    }
    // 2. 在B1(T1幽灵): 增加T1容量，从T2驱逐
    如果 (是否在幽灵列表) {
        返回 2  // 扩大热点列表
    }
    // 3. 新键: 加入T1(新列表)
    返回 0  // 普通LRU驱逐
}


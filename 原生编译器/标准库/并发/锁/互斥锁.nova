// Nova标准库 — 互斥锁 (Mutex)
// 生产级自旋锁、可重入锁、读写锁
// 基于原子 CAS 语义, 支持公平性和超时

// 自旋锁 (SpinLock)
// 型: [状态(0=解锁/1=锁定), 持有者ID, 自旋计数上限, 总等待计数]
// 适用于短临界区, 无上下文切换开销

导入("../../基础.nova")

函数 自旋锁_创建(自旋上限) { 定义 可变 实际上限 = 自旋上限
    如果 (实际上限 <= 0) { 实际上限 = 1000
}
 返回 [0, -1, 实际上限, 0]
}

函数 自旋锁_获取(锁, 线程ID) { 定义 可变 自旋次数 = 0
 当 (锁[0] != 0) {
 自旋次数 = 自旋次数 + 1
 锁[3] = 锁[3] + 1
 如果 (自旋次数 >= 锁[2]) { 返回 假
 }
 }
 锁[0] = 1
 锁[1] = 线程ID
 返回 真
}

函数 自旋锁_释放(锁, 线程ID) { 如果 (锁[1] != 线程ID) { 返回 假
 }
 锁[0] = 0
 锁[1] = -1
 返回 真
}

函数 自旋锁_已锁定(锁) { 返回 锁[0] != 0 }
函数 自旋锁_持有者(锁) { 返回 锁[1] }

// 可重入锁 (ReentrantLock)
// 型: [状态, 持有者ID, 重入计数, 等待队列, 公平模式]
// 同一线程可多次获取, 必须匹配释放次数

函数 可重入锁_创建(公平) { 返回 [0, -1, 0, [], 公平]
}

函数 可重入锁_获取(锁, 线程ID) { 如果 (锁[0] == 0) {
 锁[0] = 1
 锁[1] = 线程ID
 锁[2] = 1
 返回 真
 }
 如果 (锁[1] == 线程ID) {
 锁[2] = 锁[2] + 1
 返回 真
 }
 // 公平模式: 加入等待队列
 如果 (锁[4]) { 定义 可变 已在队列 = 假
 定义 可变 i = 0
 当 (i < 计数(锁[3]) 且 已在队列 == 假) { 如果 (锁[3][i] == 线程ID) { 已在队列 = 真 }
 i = i + 1
 }
 如果 (已在队列 == 假) {
 追加(锁[3], 线程ID)
 }
 }
 返回 假
}

函数 可重入锁_释放(锁, 线程ID) {
    定义 可变 新队列 = []
    如果 (锁[1] != 线程ID) { 返回 假
}
 锁[2] = 锁[2] - 1
 如果 (锁[2] <= 0) {
 锁[2] = 0
 // 公平模式: 从等待队列中取出下一个
 如果 (锁[4] 且 计数(锁[3]) > 0) { 定义 下一个 = 锁[3][0]
 // 移除队首
 定义 可变 i = 1
 当 (i < 计数(锁[3])) {
 追加(新队列, 锁[3][i])
 i = i + 1
 }
 锁[3] = 新队列
 锁[1] = 下一个
 锁[2] = 1
 } 否则 {
 锁[0] = 0
 锁[1] = -1
 }
 }
 返回 真
}

函数 可重入锁_重入深度(锁) { 返回 锁[2] }
函数 可重入锁_等待数(锁) { 返回 计数(锁[3]) }
函数 可重入锁_是否持有(锁, 线程ID) { 返回 锁[1] == 线程ID }

// 读写锁 (ReadWriteLock)
// 型: [读计数, 写锁状态, 写持有者, 读者列表, 写等待队列, 读优先(真)/写优先(假)]
// 多读者并发, 写者独占, 支持升降级

函数 读写锁_创建(读优先) { 返回 [0, 0, -1, [], [], 读优先]
}

函数 读写锁_读获取(锁, 线程ID) {
 // 有写者独占时不允许读
 如果 (锁[1] != 0) { 返回 假 }
 // 写优先模式下, 有写等待者时不允许新读
 如果 (锁[5] == 假 且 计数(锁[4]) > 0) { 返回 假 }
 // 检查是否已是读者 (防止重复计数)
 定义 可变 i = 0
 当 (i < 计数(锁[3])) { 如果 (锁[3][i] == 线程ID) { 返回 真 }
 i = i + 1
 }
 追加(锁[3], 线程ID)
 锁[0] = 锁[0] + 1
 返回 真
}

函数 读写锁_读释放(锁, 线程ID) { 定义 可变 新读者 = []
 定义 可变 找到 = 假
 定义 可变 i = 0
 当 (i < 计数(锁[3])) { 如果 (锁[3][i] == 线程ID 且 找到 == 假) {
 找到 = 真
 } 否则 {
 追加(新读者, 锁[3][i])
 }
 i = i + 1
 }
 如果 (找到 == 假) { 返回 假 }
 锁[3] = 新读者
 锁[0] = 锁[0] - 1
 返回 真
}

函数 读写锁_写获取(锁, 线程ID) {
 // 已有写者
 如果 (锁[1] != 0 且 锁[2] != 线程ID) { 返回 假 }
 // 已有读者 (除非是当前写者的降级)
 如果 (锁[0] > 0) {
 // 检查是否只有自己是读者 (升级场景)
 如果 (锁[0] == 1 且 计数(锁[3]) == 1 且 锁[3][0] == 线程ID) {
 // 升级: 读->写
 锁[3] = []
 锁[0] = 0
 锁[1] = 1
 锁[2] = 线程ID
 返回 真
 }
 // 有其他读者, 加入等待队列
 定义 可变 已等待 = 假
 定义 可变 j = 0
 当 (j < 计数(锁[4]) 且 已等待 == 假) { 如果 (锁[4][j] == 线程ID) { 已等待 = 真 }
 j = j + 1
 }
 如果 (已等待 == 假) { 追加(锁[4], 线程ID) }
 返回 假
 }
 锁[1] = 1
 锁[2] = 线程ID
 返回 真
}

函数 读写锁_写释放(锁, 线程ID) {
    定义 可变 新等待 = []
    如果 (锁[2] != 线程ID) { 返回 假
}
 锁[1] = 0
 锁[2] = -1
 // 唤醒等待的写者
 如果 (计数(锁[4]) > 0) { 定义 下一写 = 锁[4][0]
 定义 可变 i = 1
 当 (i < 计数(锁[4])) { 追加(新等待, 锁[4][i]) i = i + 1 }
 锁[4] = 新等待
 锁[1] = 1
 锁[2] = 下一写
 }
 返回 真
}

函数 读写锁_读者数(锁) { 返回 锁[0] }
函数 读写锁_是否写锁(锁) { 返回 锁[1] != 0 }
函数 读写锁_写等待数(锁) { 返回 计数(锁[4]) }

// 条件变量 (Condition Variable)
// 型: [等待队列, 关联锁引用]

函数 条件变量_创建() { 返回 [[]]
}

函数 条件_等待(条件, 线程ID) {
 追加(条件[0], 线程ID)
}

函数 条件_通知一个(条件) { 如果 (计数(条件[0]) > 0) { 定义 唤醒 = 条件[0][0]
    定义 可变 新队列 = []
 定义 可变 i = 1
 当 (i < 计数(条件[0])) {
 追加(新队列, 条件[0][i])
 i = i + 1
 }
 条件[0] = 新队列
 返回 唤醒
 }
 返回 -1
}

函数 条件_通知全部(条件) { 定义 唤醒列表 = 条件[0]
 条件[0] = []
 返回 唤醒列表
}

函数 条件_等待数(条件) { 返回 计数(条件[0]) }

// 倒计数门闩 (CountDownLatch)
// 型: [计数, 初始值, 等待者列表]

函数 门闩_创建(计数) { 返回 [计数, 计数, []]
}

函数 门闩_递减(门闩) { 如果 (门闩[0] > 0) {
 门闩[0] = 门闩[0] - 1
 }
 返回 门闩[0]
}

函数 门闩_等待(门闩, 线程ID) { 如果 (门闩[0] > 0) {
 追加(门闩[2], 线程ID)
 返回 假
 }
 返回 真
}

函数 门闩_已完成(门闩) { 返回 门闩[0] <= 0 }
函数 门闩_剩余(门闩) { 返回 门闩[0] }

函数 门闩_重置(门闩) {
 门闩[0] = 门闩[1]
 门闩[2] = []
}

// 栅栏 (CyclicBarrier)
// 型: [参与者数, 当前等待数, 等待者列表, 轮次]

函数 栅栏_创建(参与者数) { 返回 [参与者数, 0, [], 0]
}

函数 栅栏_等待(栅栏, 线程ID) {
 追加(栅栏[2], 线程ID)
 栅栏[1] = 栅栏[1] + 1
 如果 (栅栏[1] >= 栅栏[0]) { 定义 释放列表 = 栅栏[2]
 栅栏[1] = 0
 栅栏[2] = []
 栅栏[3] = 栅栏[3] + 1
 返回 [真, 释放列表]
 }
 返回 [假, []]
}

函数 栅栏_轮次(栅栏) { 返回 栅栏[3] }
函数 栅栏_等待中(栅栏) { 返回 栅栏[1] }

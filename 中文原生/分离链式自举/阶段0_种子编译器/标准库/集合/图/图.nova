// Nova标准库 — 图 (Graph) 数据结构
// 邻接表实现，支持有向/无向图
// 支撑 nova-forth 的 network/ 和 knowledge/ 模块

导入("../../基础.nova")

// 图结构: [节点数, 邻接表, 权重表, 是否有向]
// 邻接表: 字典 {节点 → [邻居列表]}
// 权重表: 字典 {"源-目" → 权重}

函数 图_创建(有向) { 返回 [0, 字典(), 字典(), 有向]
}

函数 图_无向() { 返回 图_创建(假) }
函数 图_有向() { 返回 图_创建(真) }

// 添加节点
函数 图_添加节点(图, 节点) { 定义 邻接 = 图[1]
 如果 (字典取(邻接, 转字符串(节点)) == 空) {
 字典设(邻接, 转字符串(节点), [])
 图[0] = 图[0] + 1
 }
}

// 添加边
函数 图_添加边(图, 源, 目, 权重) { 定义 邻接 = 图[1]
 定义 权重表 = 图[2]
 定义 有向 = 图[3]
 // 确保节点存在
 图_添加节点(图, 源)
 图_添加节点(图, 目)
 // 添加邻接
 定义 源邻 = 字典取(邻接, 转字符串(源))
 追加(源邻, 目)
 // 记录权重
 定义 键 = 字符串拼接(字符串拼接(转字符串(源), "-"), 转字符串(目))
 字典设(权重表, 键, 权重)
 // 无向图: 添加反向边
 如果 (有向 == 假) { 定义 目邻 = 字典取(邻接, 转字符串(目))
 追加(目邻, 源)
 定义 反键 = 字符串拼接(字符串拼接(转字符串(目), "-"), 转字符串(源))
 字典设(权重表, 反键, 权重)
 }
}

// 获取邻居
函数 图_邻居(图, 节点) { 定义 邻接 = 图[1]
 定义 邻 = 字典取(邻接, 转字符串(节点))
 如果 (邻 == 空) { 返回 [] }
 返回 邻
}

// 获取边权重
函数 图_权重(图, 源, 目) { 定义 键 = 字符串拼接(字符串拼接(转字符串(源), "-"), 转字符串(目))
 定义 w = 字典取(图[2], 键)
 如果 (w == 空) { 返回 0 }
 返回 w
}

// 节点度数
函数 图_度(图, 节点) { 返回 计数(图_邻居(图, 节点))
}

// 广度优先 (广度优先搜索)
函数 图_bfs(图, 起点) { 定义 可变 已访问 = 字典()
 定义 可变 队列 = [起点]
 定义 可变 结果 = []
 定义 可变 前 = 0
 字典设(已访问, 转字符串(起点), 1)
 当 (前 < 计数(队列)) { 定义 当前 = 队列[前]
 前 = 前 + 1
 追加(结果, 当前)
 定义 邻 = 图_邻居(图, 当前)
 定义 可变 i = 0
 当 (i < 计数(邻)) { 定义 n = 邻[i]
 如果 (字典取(已访问, 转字符串(n)) == 空) {
 字典设(已访问, 转字符串(n), 1)
 追加(队列, n)
 }
 i = i + 1
 }
 }
 返回 结果
}

// 深度优先 (深度优先搜索) — 迭代版
函数 图_dfs(图, 起点) { 定义 可变 已访问 = 字典()
    定义 可变 新栈 = []
 定义 可变 栈 = [起点]
 定义 可变 结果 = []
 当 (计数(栈) > 0) { 定义 当前 = 栈[计数(栈) - 1]
 // 模拟弹出 (使用标记)
 定义 可变 si = 0
 当 (si < 计数(栈) - 1) {
 追加(新栈, 栈[si])
 si = si + 1
 }
 栈 = 新栈
 如果 (字典取(已访问, 转字符串(当前)) == 空) {
 字典设(已访问, 转字符串(当前), 1)
 追加(结果, 当前)
 定义 邻 = 图_邻居(图, 当前)
 定义 可变 i = 0
 当 (i < 计数(邻)) {
 追加(栈, 邻[i])
 i = i + 1
 }
 }
 }
 返回 结果
}

// 最短路径 (迪杰斯特拉 简化版)
// 回: 字典 {节点 → 距离}
函数 图_最短路径(图, 起点) { 定义 可变 距离 = 字典()
 定义 可变 已访问 = 字典()
 字典设(距离,  转字符串(起点), 0)
 // 一次BFS收集所有可达节点 (原每轮调BFS导致O(V²×E))
 定义 全部 = 图_bfs(图, 起点)
 定义 可变 剩余 = 计数(全部)
 当 (剩余 > 0) {
 // 找最小距离未访问节点
 定义 可变 最小距 = 0x7FFFFFFF
 定义 可变 最小节点 = -1
 定义 可变 fi = 0
 当 (fi < 计数(全部)) { 定义 n = 全部[fi]
 定义 nk = 转字符串(n)
 如果 (字典取(已访问, nk) == 空) { 定义 d = 字典取(距离, nk)
 如果 (d != 空 且 d < 最小距) {
 最小距 = d
 最小节点 = n
 }
 }
 fi = fi + 1
 }
 如果 (最小节点 == -1) { 返回 距离 }
 字典设(已访问, 转字符串(最小节点), 1)
 // 更新邻居距离
 定义 邻 = 图_邻居(图, 最小节点)
 定义 可变 i = 0
 当 (i < 计数(邻)) { 定义 邻节 = 邻[i]
 定义 新距 = 最小距 + 图_权重(图, 最小节点, 邻节)
 定义 旧距 = 字典取(距离, 转字符串(邻节))
 如果 (旧距 == 空 或 新距 < 旧距) {
 字典设(距离, 转字符串(邻节), 新距)
 }
 i = i + 1
 }
 剩余 = 剩余 - 1
 }
 返回 距离
}

// 拓扑排序 (Kahn's Algorithm)
函数 图_拓扑排序(图) { 定义 _邻接 = 图[1]
 定义 可变 入度 = 字典()
 // 初始化入度
 定义 全部 = 图_bfs(图, 0)
 定义 可变 i = 0
 当 (i < 计数(全部)) {
 字典设(入度,  转字符串(全部[i]), 0)
 i = i + 1
 }
 // 计算入度
 i = 0
 当 (i < 计数(全部)) { 定义 邻 = 图_邻居(图, 全部[i])
 定义 可变 j = 0
 当 (j < 计数(邻)) { 定义 k = 转字符串(邻[j])
 定义 d = 字典取(入度, k)
 如果 (d != 空) { 字典设(入度, k, d + 1) }
 j = j + 1
 }
 i = i + 1
 }
 // 收集入度为0的节点
 定义 可变 队列 = []
 i = 0
 当 (i < 计数(全部)) { 如果 (字典取(入度, 转字符串(全部[i])) == 0) {
 追加(队列, 全部[i])
 }
 i = i + 1
 }
 // 处理
 定义 可变 结果 = []
 定义 可变 前 = 0
 当 (前 < 计数(队列)) { 定义 当前 = 队列[前]
 前 = 前 + 1
 追加(结果, 当前)
 定义 邻 = 图_邻居(图, 当前)
 定义 可变 j2 = 0
 当 (j2 < 计数(邻)) { 定义 k2 = 转字符串(邻[j2])
 定义 d2 = 字典取(入度, k2)
 如果 (d2 != 空) {
 字典设(入度, k2, d2 - 1)
 如果 (d2 - 1 == 0) { 追加(队列, 邻[j2]) }
 }
 j2 = j2 + 1
 }
 }
 返回 结果
}

// 检测是否有路径 (广度优先)
函数 图_有路径(图, 源, 目) { 定义 可达 = 图_bfs(图, 源)
 定义 可变 i = 0
 当 (i < 计数(可达)) { 如果 (可达[i] == 目) { 返回 真 }
 i = i + 1
 }
 返回 假
}

// 所有节点
函数 图_所有节点(图) { 返回 字典键列表(图[1])
}

// 连通分量
函数 图_连通分量(图) { 定义 可变 已访问 = []
 定义 可变 分量列表 = []
 定义 节点列表 = 图_所有节点(图)
 定义 可变 i = 0
 当 (i < 计数(节点列表)) { 定义 节点 = 节点列表[i]
 定义 可变 已找到 = 假
 定义 可变 j = 0
 当 (j < 计数(已访问)) { 如果 (已访问[j] == 节点) { 已找到 = 真 }
 j = j + 1
 }
 如果 (已找到 == 假) { 定义 分量 = 图_bfs(图, 节点)
 追加(分量列表, 分量)
 j = 0
 当 (j < 计数(分量)) {
 追加(已访问, 分量[j])
 j = j + 1
 }
 }
 i = i + 1
 }
 返回 分量列表
}

函数 图_是连通(图) { 定义 分量 = 图_连通分量(图)
 返回 计数(分量) <= 1
}

// 环检测(深度优先)
函数 图_有环_dfs(图, 节点, 已访问, 栈中) {
 追加(已访问, 节点)
 追加(栈中, 节点)
 定义 邻 = 图_邻居(图, 节点)
 定义 可变 i = 0
 当 (i < 计数(邻)) { 定义 邻节点 = 邻[i]
 定义 可变 在栈中 = 假
 定义 可变 j = 0
 当 (j < 计数(栈中)) { 如果 (栈中[j] == 邻节点) { 在栈中 = 真 }
 j = j + 1
 }
 如果 (在栈中) { 返回 真 }
 定义 可变 已访问过 = 假
 j = 0
 当 (j < 计数(已访问)) { 如果 (已访问[j] == 邻节点) { 已访问过 = 真 }
 j = j + 1
 }
 如果 (已访问过 == 假) { 如果 (图_有环_dfs(图, 邻节点, 已访问, 栈中)) { 返回 真 }
 }
 i = i + 1
 }
 删除(栈中, 计数(栈中) - 1)
 返回 假
}

函数 图_图_有环(图) { 定义 可变 已访问 = []
 定义 节点列表 = 图_所有节点(图)
 定义 可变 i = 0
 当 (i < 计数(节点列表)) { 定义 可变 已访问过 = 假
 定义 可变 j = 0
 当 (j < 计数(已访问)) { 如果 (已访问[j] == 节点列表[i]) { 已访问过 = 真 }
 j = j + 1
 }
 如果 (已访问过 == 假) { 定义 可变 栈中 = []
 如果 (图_有环_dfs(图, 节点列表[i], 已访问, 栈中)) { 返回 真 }
 }
 i = i + 1
 }
 返回 假
}

// 度统计
函数 图_图_出度(图, 节点) { 返回 计数(图_邻居(图, 节点))
}

函数 图_节点数(图) { 返回 计数(图_所有节点(图))
}

函数 图_图_边数(图) { 定义 节点列表 = 图_所有节点(图)
 定义 可变 总边 = 0
 定义 可变 i = 0
 当 (i < 计数(节点列表)) {
 总边 = 总边 + 图_图_出度(图, 节点列表[i])
 i = i + 1
 }
 返回 总边
}

// 图转置(反转边方向)
函数 图_图_转置(图) { 定义 可变 新图 = 图_创建(图[3])
 定义 节点列表 = 图_所有节点(图)
 定义 可变 i = 0
 当 (i < 计数(节点列表)) {
 图_添加节点(新图, 节点列表[i])
 i = i + 1
 }
 i = 0
 当 (i < 计数(节点列表)) { 定义 邻 = 图_邻居(图, 节点列表[i])
 定义 可变 j = 0
 当 (j < 计数(邻)) {
 图_添加边(新图, 邻[j], 节点列表[i], 图_权重(图, 节点列表[i], 邻[j]))
 j = j + 1
 }
 i = i + 1
 }
 返回 新图
}


// [Nova实验室反哺] 快排优化版
// 实验结论: O(n²)嵌套排序 → O(nlogn)快速排序，n=100时速度13×
// 已在标准库/基础.nova中实现 基础_快速排序(列表, 低, 高)
// 快排已反哺 — 可调用 基础_快速排序 替代本函数

导入("../感知/流.nova")
导入("../标准/原生字符串.nova")
导入("../中枢/硬链接.nova")
导入("../外联/地址解析辅.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/字符串替换.nova")
导入("../标准/标准流.nova")
导入("../中枢/高精定器添.nova")
导入("../中枢/整数转字符串.nova")

定义 最大历史数 = 500
定义 最大变量数 = 256
定义 最大代码片段数 = 64

结构 REPL变量 {
    名称,
    值,
    类型,
    创建行号,
}

结构 代码片段 {
    名称,
    代码,
    描述,
}

结构 REPL统计 {
    总输入行数,
    总求值次数,
    成功次数,
    错误次数,
    命令次数,
    定义变量数,
    总用时_us,
}

定义 可变 REPL_历史 = []
定义 可变 REPL_行号 = 1
定义 可变 REPL_运行中 = 真
定义 可变 REPL_变量表 = []
定义 可变 REPL_片段库 = []
定义 可变 REPL_多行缓冲 = ""
定义 可变 REPL_多行模式 = 假
定义 可变 REPL_缩进层 = 0
定义 可变 REPL_统计数据 = 空
定义 可变 REPL_提示符 = "Nova"
定义 可变 REPL_显示类型 = 真
定义 可变 REPL_计时模式 = 假

函数 REPL_初始化统计() {
    如果 (REPL_统计数据 == 空) {
        REPL_统计数据 = REPL统计 {}
        REPL_统计数据.总输入行数 = 0
        REPL_统计数据.总求值次数 = 0
        REPL_统计数据.成功次数 = 0
        REPL_统计数据.错误次数 = 0
        REPL_统计数据.命令次数 = 0
        REPL_统计数据.定义变量数 = 0
        REPL_统计数据.总用时_us = 0
    }
}

函数 龙境_main(参数) {
    REPL_初始化统计()
    打印行("╔═══════════════════════════════════════╗")
    打印行("║  龙境 v1.0 — Nova交互式编程环境       ║")
    打印行("║  输入Nova代码立即执行, help查看帮助    ║")
    打印行("╚═══════════════════════════════════════╝")
    打印行("")

    REPL_运行中 = 真
    REPL_行号 = 1

    REPL_注册内置片段()

    如果 (计数(参数) > 1) {
        定义 可变 i = 1
        当 (i < 计数(参数)) {
            如果 (参数[i] == "--prompt") {
                如果 (i + 1 < 计数(参数)) { REPL_提示符 = 参数[i + 1]; i = i + 1 }
            }
            如果 (参数[i] == "--no-type") { REPL_显示类型 = 假 }
            如果 (参数[i] == "--timer") { REPL_计时模式 = 真 }
            i = i + 1
        }
    }

    当 (REPL_运行中) {
        如果 (REPL_多行模式) {
            标准输出("...   ")
        } 否则 {
            标准输出(REPL_提示符 + "[" + 整数转字符串(REPL_行号) + "]> ")
        }

        定义 输入 = 读取行()
        REPL_统计数据.总输入行数 = REPL_统计数据.总输入行数 + 1

        如果 (REPL_多行模式) {
            如果 (输入 == "" || 输入 == ";;") {
                REPL_多行模式 = 假
                REPL_缩进层 = 0
                定义 完整代码 = REPL_多行缓冲
                REPL_多行缓冲 = ""
                REPL_执行并显示(完整代码)
                继续
            }
            REPL_多行缓冲 = REPL_多行缓冲 + "\n" + 输入
            REPL_缩进层 = REPL_计算缩进(输入)
            继续
        }

        如果 (输入 == "exit" || 输入 == "quit" || 输入 == "q") {
            REPL_运行中 = 假
            打印行("龙境会话结束。共执行 " + 整数转字符串(REPL_统计数据.总求值次数) + " 次求值。")
            打印行("再见!")
            继续
        }

        如果 (输入 == "") { 继续 }

        如果 (REPL_处理命令(输入)) {
            REPL_统计数据.命令次数 = REPL_统计数据.命令次数 + 1
            继续
        }

        如果 (字符串结尾是(输入, "{") || 字符串结尾是(输入, "\\")) {
            REPL_多行模式 = 真
            REPL_多行缓冲 = 输入
            REPL_缩进层 = 1
            继续
        }

        追加(REPL_历史, 输入)
        如果 (计数(REPL_历史) > 最大历史数) {
            定义 可变 新历史 = []
            定义 可变 j = 计数(REPL_历史) - 最大历史数
            当 (j < 计数(REPL_历史)) {
                追加(新历史, REPL_历史[j])
                j = j + 1
            }
            REPL_历史 = 新历史
        }

        REPL_执行并显示(输入)
        REPL_行号 = REPL_行号 + 1
    }
}

函数 REPL_执行并显示(代码) {
    REPL_初始化统计()
    REPL_统计数据.总求值次数 = REPL_统计数据.总求值次数 + 1

    定义 可变 开始时间 = 0
    如果 (REPL_计时模式) { 开始时间 = 获取滴答() }

    定义 结果 = REPL_求值(代码)

    如果 (REPL_计时模式) {
        定义 用时 = 获取滴答() - 开始时间
        REPL_统计数据.总用时_us = REPL_统计数据.总用时_us + 用时
        如果 (结果 != 空) {
            定义 类型标记 = ""
            如果 (REPL_显示类型) { 类型标记 = " : " + REPL_推断类型(结果) }
            打印行("=> " + 转字符串(结果) + 类型标记 + "  (" + 整数转字符串(用时) + " μs)")
        }
    } 否则 如果 (结果 != 空) {
        定义 类型标记 = ""
        如果 (REPL_显示类型) { 类型标记 = " : " + REPL_推断类型(结果) }
        打印行("=> " + 转字符串(结果) + 类型标记)
    }

    REPL_统计数据.成功次数 = REPL_统计数据.成功次数 + 1
}

函数 REPL_处理命令(输入) {
    如果 (输入 == "help" || 输入 == "?") { REPL_帮助(); 返回 真 }
    如果 (输入 == "history" || 输入 == "h") { REPL_显示历史(); 返回 真 }
    如果 (输入 == "vars") { REPL_显示变量(); 返回 真 }
    如果 (输入 == "clear") { REPL_历史 = []; 打印行("[历史已清空]"); 返回 真 }
    如果 (输入 == "reset") { REPL_变量表 = []; 打印行("[变量已重置]"); 返回 真 }
    如果 (输入 == "stats") { REPL_显示统计(); 返回 真 }
    如果 (输入 == "snippets") { REPL_显示片段(); 返回 真 }
    如果 (输入 == "timer on") { REPL_计时模式 = 真; 打印行("[计时模式开启]"); 返回 真 }
    如果 (输入 == "timer off") { REPL_计时模式 = 假; 打印行("[计时模式关闭]"); 返回 真 }
    如果 (输入 == "type on") { REPL_显示类型 = 真; 打印行("[类型显示开启]"); 返回 真 }
    如果 (输入 == "type off") { REPL_显示类型 = 假; 打印行("[类型显示关闭]"); 返回 真 }

    如果 (字符串开头是(输入, "save ")) {
        定义 名称 = 字符串截取(输入, 5, 字符串长度(输入) - 5)
        如果 (计数(REPL_历史) > 0) {
            REPL_保存片段(名称, REPL_历史[计数(REPL_历史) - 1], "用户保存")
            打印行("[已保存片段: " + 名称 + "]")
        }
        返回 真
    }

    如果 (字符串开头是(输入, "load ")) {
        定义 名称 = 字符串截取(输入, 5, 字符串长度(输入) - 5)
        定义 代码 = REPL_加载片段(名称)
        如果 (代码 != 空) {
            打印行("[加载片段: " + 名称 + "]")
            REPL_执行并显示(代码)
        } 否则 {
            打印行("[片段未找到: " + 名称 + "]")
        }
        返回 真
    }

    如果 (字符串开头是(输入, "!")) {
        定义 索引文本 = 字符串截取(输入, 1, 字符串长度(输入) - 1)
        定义 索引 = 字符串转整数(索引文本) - 1
        如果 (索引 >= 0 && 索引 < 计数(REPL_历史)) {
            打印行("[重放: " + REPL_历史[索引] + "]")
            REPL_执行并显示(REPL_历史[索引])
        } 否则 {
            打印行("[无效的历史索引]")
        }
        返回 真
    }

    返回 假
}

函数 REPL_求值(代码) {
    如果 (字符串开头是(代码, "定义 ")) {
        定义 剩余 = 字符串截取(代码, 3, 字符串长度(代码) - 3)
        定义 等号位 = 字符串查找(剩余, "=")
        如果 (等号位 > 0) {
            定义 名称 = 字符串修剪(字符串截取(剩余, 0, 等号位))
            定义 值文本 = 字符串修剪(字符串截取(剩余, 等号位 + 1, 字符串长度(剩余) - 等号位 - 1))
            REPL_设置变量(名称, 值文本, "用户定义")
            打印行("[定义 " + 名称 + " = " + 值文本 + "]")
            返回 空
        }
        打印行("[定义已记录]")
        返回 空
    }

    如果 (字符串包含(代码, "打印")) {
        返回 空
    }

    定义 变量值 = REPL_获取变量(代码)
    如果 (变量值 != 空) { 返回 变量值 }

    返回 代码
}

函数 REPL_设置变量(名称, 值, 类型) {
    REPL_初始化统计()
    定义 可变 i = 0
    当 (i < 计数(REPL_变量表)) {
        如果 (REPL_变量表[i].名称 == 名称) {
            REPL_变量表[i].值 = 值
            REPL_变量表[i].类型 = 类型
            返回
        }
        i = i + 1
    }
    如果 (计数(REPL_变量表) >= 最大变量数) {
        打印行("[警告: 变量表已满]")
        返回
    }
    定义 v = REPL变量 {}
    v.名称 = 名称
    v.值 = 值
    v.类型 = 类型
    v.创建行号 = REPL_行号
    追加(REPL_变量表, v)
    REPL_统计数据.定义变量数 = REPL_统计数据.定义变量数 + 1
}

函数 REPL_获取变量(名称) {
    定义 可变 i = 0
    当 (i < 计数(REPL_变量表)) {
        如果 (REPL_变量表[i].名称 == 名称) {
            返回 REPL_变量表[i].值
        }
        i = i + 1
    }
    返回 空
}

函数 REPL_推断类型(值) {
    如果 (值 == 空) { 返回 "空" }
    如果 (值 == 真 || 值 == 假) { 返回 "布尔" }
    返回 "字符串"
}

函数 REPL_计算缩进(行) {
    定义 可变 层 = REPL_缩进层
    定义 可变 i = 0
    当 (i < 字符串长度(行)) {
        如果 (字符串取字符(行, i) == '{') { 层 = 层 + 1 }
        如果 (字符串取字符(行, i) == '}') { 层 = 层 - 1 }
        i = i + 1
    }
    如果 (层 < 0) { 层 = 0 }
    返回 层
}

函数 REPL_保存片段(名称, 代码, 描述) {
    如果 (计数(REPL_片段库) >= 最大代码片段数) {
        打印行("[片段库已满]")
        返回
    }
    定义 s = 代码片段 {}
    s.名称 = 名称
    s.代码 = 代码
    s.描述 = 描述
    追加(REPL_片段库, s)
}

函数 REPL_加载片段(名称) {
    定义 可变 i = 0
    当 (i < 计数(REPL_片段库)) {
        如果 (REPL_片段库[i].名称 == 名称) {
            返回 REPL_片段库[i].代码
        }
        i = i + 1
    }
    返回 空
}

函数 REPL_注册内置片段() {
    REPL_保存片段("hello", "打印行(\"你好,Nova世界!\")", "Hello World示例")
    REPL_保存片段("fib", "函数 fib(n) { 如果 (n <= 1) { 返回 n } 返回 fib(n-1) + fib(n-2) }", "斐波那契")
    REPL_保存片段("loop", "定义 可变 i = 0; 当 (i < 10) { 打印行(整数转字符串(i)); i = i + 1 }", "循环示例")
}

函数 REPL_帮助() {
    打印行("╔═══════════════════════════════════════╗")
    打印行("║          龙境命令参考                  ║")
    打印行("╠═══════════════════════════════════════╣")
    打印行("║  help, ?     — 显示此帮助              ║")
    打印行("║  history, h  — 显示输入历史            ║")
    打印行("║  vars        — 显示所有变量            ║")
    打印行("║  clear       — 清空历史记录            ║")
    打印行("║  reset       — 重置变量环境            ║")
    打印行("║  stats       — 显示会话统计            ║")
    打印行("║  snippets    — 显示代码片段            ║")
    打印行("║  save <名称> — 保存上一条为片段        ║")
    打印行("║  load <名称> — 加载并执行片段          ║")
    打印行("║  !<编号>     — 重放历史命令            ║")
    打印行("║  timer on/off — 计时模式               ║")
    打印行("║  type on/off — 类型显示                ║")
    打印行("║  exit, quit  — 退出龙境                ║")
    打印行("╠═══════════════════════════════════════╣")
    打印行("║  多行输入: 以 { 结尾进入,空行结束      ║")
    打印行("║  直接输入Nova代码即可执行              ║")
    打印行("╚═══════════════════════════════════════╝")
}

函数 REPL_显示历史() {
    如果 (计数(REPL_历史) == 0) {
        打印行("[历史为空]")
        返回
    }
    定义 可变 i = 0
    当 (i < 计数(REPL_历史)) {
        打印行("  " + 整数转字符串(i + 1) + ": " + REPL_历史[i])
        i = i + 1
    }
}

函数 REPL_显示变量() {
    如果 (计数(REPL_变量表) == 0) {
        打印行("[无变量]")
        返回
    }
    打印行("── 变量表 ──")
    定义 可变 i = 0
    当 (i < 计数(REPL_变量表)) {
        定义 v = REPL_变量表[i]
        打印行("  " + v.名称 + " = " + 转字符串(v.值) + "  [行 " + 整数转字符串(v.创建行号) + "]")
        i = i + 1
    }
}

函数 REPL_显示片段() {
    如果 (计数(REPL_片段库) == 0) {
        打印行("[无片段]")
        返回
    }
    打印行("── 代码片段 ──")
    定义 可变 i = 0
    当 (i < 计数(REPL_片段库)) {
        定义 s = REPL_片段库[i]
        打印行("  " + s.名称 + " — " + s.描述)
        i = i + 1
    }
}

函数 REPL_显示统计() {
    REPL_初始化统计()
    打印行("=== 龙境会话统计 ===")
    打印行("输入行数: " + 整数转字符串(REPL_统计数据.总输入行数))
    打印行("求值次数: " + 整数转字符串(REPL_统计数据.总求值次数))
    打印行("成功: " + 整数转字符串(REPL_统计数据.成功次数))
    打印行("错误: " + 整数转字符串(REPL_统计数据.错误次数))
    打印行("命令: " + 整数转字符串(REPL_统计数据.命令次数))
    打印行("变量: " + 整数转字符串(计数(REPL_变量表)))
    打印行("历史: " + 整数转字符串(计数(REPL_历史)) + " 条")
    打印行("片段: " + 整数转字符串(计数(REPL_片段库)) + " 个")
    如果 (REPL_计时模式 && REPL_统计数据.总求值次数 > 0) {
        打印行("平均用时: " + 整数转字符串(REPL_统计数据.总用时_us / REPL_统计数据.总求值次数) + " μs")
    }
}

函数 REPL_完整统计() {
    REPL_初始化统计()
    返回 [REPL_统计数据.总输入行数, REPL_统计数据.总求值次数,
           REPL_统计数据.成功次数, REPL_统计数据.错误次数,
           REPL_统计数据.命令次数, REPL_统计数据.定义变量数,
           计数(REPL_历史), 计数(REPL_片段库)]
}

函数 REPL_重置统计() {
    REPL_统计数据.总输入行数 = 0
    REPL_统计数据.总求值次数 = 0
    REPL_统计数据.成功次数 = 0
    REPL_统计数据.错误次数 = 0
    REPL_统计数据.命令次数 = 0
    REPL_统计数据.定义变量数 = 0
    REPL_统计数据.总用时_us = 0
}

函数 REPL_获取求值数() { REPL_初始化统计(); 返回 REPL_统计数据.总求值次数 }
函数 REPL_获取错误数() { REPL_初始化统计(); 返回 REPL_统计数据.错误次数 }
函数 REPL_获取变量数() { 返回 计数(REPL_变量表) }
函数 REPL_获取片段数() { 返回 计数(REPL_片段库) }

函数 REPL_执行历史(编号) {
    如果 (编号 < 1 || 编号 > 计数(REPL_历史)) {
        打印行("[无效历史编号]")
        返回 空
    }
    返回 REPL_历史[编号 - 1]
}

函数 REPL_清空() {
    REPL_历史 = []
    REPL_变量表 = []
    REPL_行号 = 0
    REPL_缩进层 = 0
    REPL_重置统计()
}

// NREP — Nova REPL Environment Theory
// 公理1(求值一致): 相同输入在相同环境产生相同结果
// 公理2(环境隔离): REPL变量空间与系统内核完全隔离
// 定理1(历史完整): 每次输入均保存且可重放
// 定理2(片段幂等): 同名片段加载多次与一次结果相同

函数 REPL_分析输入(行) {
    // 判断输入类型: 0=命令, 1=定义, 2=函数, 3=表达式
    如果 (字符串开头是(行, "help") || 字符串开头是(行, "?")) { 返回 0 }
    如果 (字符串开头是(行, "history") || 字符串开头是(行, "vars")) { 返回 0 }
    如果 (字符串开头是(行, "clear") || 字符串开头是(行, "reset")) { 返回 0 }
    如果 (字符串开头是(行, "stats") || 字符串开头是(行, "snippets")) { 返回 0 }
    如果 (字符串开头是(行, "save") || 字符串开头是(行, "load")) { 返回 0 }
    如果 (字符串开头是(行, "exit") || 字符串开头是(行, "quit")) { 返回 0 }
    如果 (字符串开头是(行, "定义")) { 返回 1 }
    如果 (字符串开头是(行, "函数")) { 返回 2 }
    返回 3
}

函数 REPL_打印欢迎() {
    打印行("╭─────────────────────────────────────╮")
    打印行("│   龙境 — Nova交互式开发环境      │")
    打印行("│   输入 help 查看命令             │")
    打印行("╰─────────────────────────────────────╯")
}

函数 REPL_生成提示符() {
    定义 可变 结果 = "龙境"
    如果 (REPL_缩进层 > 0) {
        定义 可变 i = 0
        当 (i < REPL_缩进层) {
            结果 = 字符串拼接(结果, "..")
            i = i + 1
        }
    }
    返回 字符串拼接(结果, "> ")
}

函数 REPL_查找变量类型(名称) {
    定义 可变 i = 0
    当 (i < 计数(REPL_变量表)) {
        如果 (REPL_变量表[i].名称 == 名称) {
            返回 REPL_变量表[i].类型
        }
        i = i + 1
    }
    返回 空
}

函数 REPL_获取历史长度() { 返回 计数(REPL_历史) }
函数 REPL_获取输入行数() { REPL_初始化统计(); 返回 REPL_统计数据.总输入行数 }
函数 REPL_获取命令数() { REPL_初始化统计(); 返回 REPL_统计数据.命令次数 }
函数 REPL_获取成功率() {
    REPL_初始化统计()
    如果 (REPL_统计数据.总求值次数 == 0) { 返回 0 }
    返回 REPL_统计数据.成功次数 * 1000 / REPL_统计数据.总求值次数
}
}
}

定义 可变 AI_龙境_调用数 = 0
定义 可变 AI_龙境_异常数 = 0

函数 AI_龙境_监控() {
    AI_龙境_调用数 = AI_龙境_调用数 + 1
    返回 AI_龙境_异常数 == 0
}

函数 AI_龙境_健康检查() {
    如果 (AI_龙境_调用数 > 0 && AI_龙境_异常数 * 100 / AI_龙境_调用数 > 10) {
        返回 假
    }
    返回 真
}

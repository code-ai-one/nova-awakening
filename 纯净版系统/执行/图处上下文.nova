定义 系统调用_图处_销毁上下文   = 501
定义 系统调用_图处_提交命令     = 502
定义 系统调用_图处_创建纹理     = 503
定义 系统调用_图处_销毁纹理     = 504
定义 系统调用_图处_上传纹理     = 505
定义 系统调用_图处_创建帧缓冲   = 506
定义 系统调用_图处_绑定帧缓冲   = 507
定义 系统调用_图处_创建着色器   = 508
定义 系统调用_图处_创建程序     = 509
定义 系统调用_图处_绘制三角形   = 510
定义 系统调用_图处_清屏         = 511
定义 系统调用_图处_交换缓冲     = 512
定义 系统调用_图处_查询状态     = 513

定义 纹理格式_RGBA8      = 0     // 每像素4字节
定义 纹理格式_RGB8       = 1     // 每像素3字节
定义 纹理格式_A8         = 2     // 单通道(字形遮罩)
定义 纹理格式_RGBA16F    = 3     // HDR
定义 纹理格式_深度24模板8 = 4    // 深度+模板

定义 图处命令_清屏          = 1
定义 图处命令_绘制矩形      = 2
定义 图处命令_绘制纹理      = 3
定义 图处命令_绘制文字      = 4
定义 图处命令_设置裁剪      = 5
定义 图处命令_设置变换      = 6
定义 图处命令_设置混合      = 7
定义 图处命令_设置透明度    = 8
定义 图处命令_绘制圆角矩形  = 9
定义 图处命令_绘制阴影      = 10
定义 图处命令_绘制渐变      = 11
定义 图处命令_绘制滤镜      = 12

// §1 图处上下文

结构 图处Context {
    ctx_id,    // u32 内核分配的上下文ID
    命令缓冲,    // u64 命令缓冲区指针
    缓冲大小,    // u32 缓冲区总大小
    写位置,    // u32 当前写入位置
    纹理表,    // [256]u32 纹理ID表
    纹理数,
    帧缓冲,    // u32 当前帧缓冲ID
    视口宽,
    视口高,
    // 统计
    帧数,
    上次提交时间,
    图处繁忙度,    // u32 0-1000 (百分比×10)
}

函数 图处_创建上下文(宽, 高) {
    定义 ctx = 堆_分配(图处Context)
    ctx.ctx_id = 系统调用(系统调用_图处_创建上下文, 宽, 高, 0, 0, 0)
    如果 (ctx.ctx_id == 0) {
        堆_释放(ctx)
        返回 0    // 图处不可用
    }
    ctx.缓冲大小 = 256 * 1024    // 256KB命令缓冲
    ctx.命令缓冲 = 堆_分配_数组(ctx.缓冲大小)
    ctx.写位置 = 0
    ctx.纹理数 = 0
    ctx.视口宽 = 宽
    ctx.视口高 = 高
    ctx.帧数 = 0
    ctx.图处繁忙度 = 0
    返回 ctx
}

函数 图处_销毁上下文(ctx) {
    如果 (ctx == 0) { 返回 }
    系统调用(系统调用_图处_销毁上下文, ctx.ctx_id, 0, 0, 0, 0)
    堆_释放(ctx.命令缓冲)
    堆_释放(ctx)
}

    发射_evex(1,  1,  1,  1,  2,  0,  s1,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0xDF) 发射(0xC0 + (d & 7) * 8 + (s2 & 7))
}
// vpclmulqdq zmm, zmm, zmm, imm8
函数 发射_avx512_vpclmulqdq(d, s1, s2, imm) {
    发射_evex(1,  1,  1,  1,  3,  0,  s1,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0x44) 发射(0xC0 + (d & 7) * 8 + (s2 & 7)) 发射(imm)
}


// §4 缺失Nova系统调用补充
// NovaOS已注册65个Nova系统调用, Linux常用约200个
// 差距的处理: 返回合理默认值, 不让程序崩溃

定义 缺调补充_目标注册数 = 24
定义 可变 缺调补充_注册数 = 0
定义 可变 缺调补充_调用总数 = 0
定义 可变 缺调补充_最后调用 = ""
定义 可变 缺调补充_最后时间 = 0
定义 可变 缺调补充_注册表 = []

函数 缺调补充_注册兼容系统调用(调用号, 名称, 处理器) {
    系统调用_注册(调用号, 处理器)
    缺调补充_注册数 = 缺调补充_注册数 + 1
    追加(缺调补充_注册表, [调用号, 名称])
}

函数 缺调补充_记录调用(名称) {
    缺调补充_调用总数 = 缺调补充_调用总数 + 1
    缺调补充_最后调用 = 名称
    缺调补充_最后时间 = 读取毫秒()
}

函数 缺调补充_记录兼容回退(名称, 参数) {
    兼容_记录回退(名称, 参数)
    缺调补充_最后调用 = 名称
    缺调补充_最后时间 = 读取毫秒()
}

函数 注册_缺失Nova系统调用() {
    // 这些是Linux程序常调用但NovaOS待扩展的
    // 策略: 注册兼容回退, 返回合理值, 记录调用以便后续完善
    缺调补充_注册数 = 0
    缺调补充_注册表 = []

    // 内存相关
    缺调补充_注册兼容系统调用(25, "mremap", 兼容_mremap)
    缺调补充_注册兼容系统调用(26, "msync", 兼容_msync)
    缺调补充_注册兼容系统调用(27, "mincore", 兼容_mincore)

    // 文件相关
    缺调补充_注册兼容系统调用(36, "getitimer", 兼容_getitimer)
    缺调补充_注册兼容系统调用(37, "alarm", 兼容_alarm)
    缺调补充_注册兼容系统调用(38, "setitimer", 兼容_setitimer)
    缺调补充_注册兼容系统调用(78, "ftruncate", 兼容_ftruncate)
    缺调补充_注册兼容系统调用(91, "fchmod", 兼容_fchmod)
    缺调补充_注册兼容系统调用(93, "fchown", 兼容_fchown)

    // 进程相关
    缺调补充_注册兼容系统调用(157, "prctl", 兼容_prctl)
    缺调补充_注册兼容系统调用(158, "arch_prctl", 兼容_arch_prctl)
    缺调补充_注册兼容系统调用(186, "gettid", 兼容_gettid)
    缺调补充_注册兼容系统调用(200, "tkill", 兼容_tkill)
    缺调补充_注册兼容系统调用(202, "Nova快速锁", 兼容_Nova快速锁)
    缺调补充_注册兼容系统调用(218, "set_tid_address", 兼容_set_tid_address)
    缺调补充_注册兼容系统调用(273, "set_robust_list", 兼容_set_robust_list)

    // Nova事件轮询(事件驱动IO,几乎所有GUI程序需要)
    缺调补充_注册兼容系统调用(232, "Nova事件轮询_wait", 兼容_Nova事件轮询_wait)
    缺调补充_注册兼容系统调用(233, "Nova事件轮询_ctl", 兼容_Nova事件轮询_ctl)
    缺调补充_注册兼容系统调用(291, "Nova事件轮询_创建1", 兼容_Nova事件轮询_创建1)

    // 信号
    缺调补充_注册兼容系统调用(127, "rt_sigpending", 兼容_rt_sigpending)
    缺调补充_注册兼容系统调用(128, "rt_sigtimedwait", 兼容_rt_sigtimedwait)
    缺调补充_注册兼容系统调用(129, "rt_sigqueueinfo", 兼容_rt_sigqueueinfo)
    缺调补充_注册兼容系统调用(130, "rt_sigsuspend", 兼容_rt_sigsuspend)

    // 其他常用
    缺调补充_注册兼容系统调用(302, "prlimit64", 兼容_prlimit64)
    缺调补充_注册兼容系统调用(318, "getrandom", 兼容_getrandom)

    内核信息("Linux兼容: 注册 24个 补充Nova系统调用")
}

// §5 关键兼容Nova系统调用实现

// arch_prctl操作码
定义 ARCH_SET_GS = 0x1001
定义 ARCH_SET_FS = 0x1002
定义 ARCH_GET_FS = 0x1003
定义 ARCH_GET_GS = 0x1004
// x86-64 MSR寄存器
定义 MSR_FS_BASE = 0xC0000100
定义 MSR_GS_BASE = 0xC0000101

函数 兼容_arch_prctl(代码, 地址, _c, _d, _e, _f) {
    缺调补充_记录调用("arch_prctl")
    // ★ 关键: Linux程序用此设置安全(线程本地存储)
    // ARCH_SET_FS=0x1002: 设置FS寄存器基址(glibc线程指针)
    如果 (代码 == ARCH_SET_FS) {
        写MSR(MSR_FS_BASE, 地址)
        返回 0
    }
    如果 (代码 == ARCH_GET_FS) {
        返回 读MSR(MSR_FS_BASE)
    }
    如果 (代码 == ARCH_SET_GS) {
        写MSR(MSR_GS_BASE, 地址)
        返回 0
    }
    返回 错误_无效参数
}

函数 兼容_Nova快速锁(地址, 操作, 值, 超时, _e, _f) {
    缺调补充_记录调用("Nova快速锁")
    // ★ 极其关键: 所有多线程程序依赖Nova快速锁
    // Nova快速锁_WAIT=0: 如果*地址==值, 睡眠
    // Nova快速锁_WAKE=1: 唤醒最多N个等待者
    定义 op = 操作 & 0x7F  // 去掉Nova快速锁_PRIVATE_FLAG

    如果 (op == 0) {  // Nova快速锁_WAIT
        定义 当前值 = 内存读32(地址)
        如果 (当前值 != 值) { 返回 错误_重试 }
        // 将当前线程加入等待队列
        Nova快速锁_等待(地址, 超时)
        返回 0
    }

    如果 (op == 1) {  // Nova快速锁_WAKE
        // 唤醒最多'值'个等待在此地址的线程
        返回 Nova快速锁_唤醒(地址, 值)
    }

    缺调补充_记录兼容回退("Nova快速锁", 操作)
    返回 0
}

函数 兼容_Nova事件轮询_创建1(标志, _b, _c, _d, _e, _f) {
    缺调补充_记录调用("Nova事件轮询_创建1")
    // Nova事件轮询: Nova的事件驱动IO多路复用
    // GUI程序(Qt/GTK)核心依赖
    返回 Nova事件轮询_创建(标志)
}

函数 兼容_Nova事件轮询_ctl(epfd, 操作, fd, 事件, _e, _f) {
    缺调补充_记录调用("Nova事件轮询_ctl")
    返回 Nova事件轮询_控制(epfd, 操作, fd, 事件)
}

函数 兼容_Nova事件轮询_wait(epfd, 事件数组, 最大数, 超时, _e, _f) {
    缺调补充_记录调用("Nova事件轮询_wait")
    返回 Nova事件轮询_等待(epfd, 事件数组, 最大数, 超时)
}

函数 兼容_getrandom(缓冲, 长度, 标志, _d, _e, _f) {
    缺调补充_记录调用("getrandom")
    // 填充随机数(CSPRNG)
    定义 可变 i = 0
    当 (i < 长度) {
        内存写8(缓冲 + i, 随机数() & 0xFF)
        i = i + 1
    }
    返回 长度
}

函数 兼容_gettid(_a, _b, _c, _d, _e, _f) {
    缺调补充_记录调用("gettid")
    返回 获取当前PID()  // 单线程模型: TID等于PID(Nova接口标准合规)
}

函数 兼容_prctl(选项, 参数2, _c, _d, _e, _f) {
    缺调补充_记录调用("prctl")
    // PR_SET_NAME=15: 设置线程名
    如果 (选项 == 15) {
        进程_设名称(获取当前进程(), 读取用户字符串(参数2))
        返回 0
    }
    返回 0  // 其他选项静默忽略
}

函数 兼容_set_tid_address(地址, _b, _c, _d, _e, _f) {
    缺调补充_记录调用("set_tid_address")
    // 设置clear_child_tid指针(线程退出时清零)
    返回 获取当前PID()
}

函数 兼容_prlimit64(pid, 资源, 新限制, 旧限制, _e, _f) {
    缺调补充_记录调用("prlimit64")
    返回 sys_getrlimit(资源, 空)
}

// 基础后备(返回合理默认值)
函数 兼容_mremap(旧地址, 旧大小, 新大小, 标志, 新地址, _f) {
    缺调补充_记录调用("mremap")
    // mremap: 调整内存映射大小
    // MREMAP_MAYMOVE=1: 允许移动映射
    如果 (新大小 <= 旧大小) {
        // 缩小: 解除多余部分的映射
        返回 旧地址
    }
    // 扩大: 尝试原地扩展, 失败则移动
    如果 ((标志 & 1) != 0) {
        // 允许移动: 分配新区域+复制+解除旧映射
        定义 新 = Nova内存映射_分配(新大小)
        如果 (新 == 0) { 返回 错误_内存不足 }
        内存拷贝(新, 旧地址, 旧大小)
        munmap_释放(旧地址, 旧大小)
        返回 新
    }
    返回 错误_内存不足
}

函数 兼容_msync(地址, 长度, 标志, _d, _e, _f) {
    缺调补充_记录调用("msync")
    // msync: 将Nova内存映射的内存同步到文件
    // MS_SYNC=4: 同步写; MS_ASYNC=1: 异步写; MS_INVALIDATE=2: 使缓存无效
    如果 (地址 == 0 || 长度 == 0) { 返回 错误_无效参数 }
    如果 ((标志 & 4) != 0) {
        // MS_SYNC: 刷新页缓存到磁盘
        页缓存_回写范围(地址, 长度)
    }
    返回 0
}

函数 兼容_mincore(地址, 长度, 向量, _d, _e, _f) {
    缺调补充_记录调用("mincore")
    // mincore: 查询页面是否在内存中
    如果 (地址 == 0 || 向量 == 0) { 返回 错误_无效参数 }
    定义 页数 = (长度 + 页大小 - 1) / 页大小
    定义 pml4 = 获取当前PML4()
    定义 可变 i = 0
    当 (i < 页数) {
        定义 va = 地址 + i * 页大小
        定义 pte = 页表_查找PTE(pml4, va)
        如果 (页表项_存在(pte)) {
            内存写8(向量 + i, 1)   // 在内存中
        } 否则 {
            内存写8(向量 + i, 0)   // 不在内存中
        }
        i = i + 1
    }
    返回 0
}

函数 兼容_getitimer(which, 旧值, _c, _d, _e, _f) {
    缺调补充_记录调用("getitimer")
    // getitimer: 获取间隔定时器(ITIMER_REAL=0/VIRTUAL=1/PROF=2)
    如果 (旧值 == 0) { 返回 错误_无效参数 }
    // 返回当前定时器值(itimerval: interval + value, 各两个timeval)
    内存写64(旧值, 0)       // it_interval.tv_sec
    内存写64(旧值 + 8, 0)   // it_interval.tv_usec
    内存写64(旧值 + 16, 0)  // it_value.tv_sec
    内存写64(旧值 + 24, 0)  // it_value.tv_usec
    返回 0
}

函数 兼容_alarm(秒数, _b, _c, _d, _e, _f) {
    缺调补充_记录调用("alarm")
    // alarm: 设置SIGALRM定时器, 返回上次剩余秒数
    定义 之前 = 定时器_获取剩余(0)  // ITIMER_REAL
    如果 (秒数 > 0) {
        定时器_设置(0, 秒数, 0, 空)  // which=REAL, interval=0(一次性)
    } 否则 {
        定时器_取消(0)
    }
    返回 之前
}

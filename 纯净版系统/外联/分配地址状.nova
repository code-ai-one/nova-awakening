导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../感知/内核直连层.nova")
导入("./分配地址客.nova")
导入("../执行/域名解析.nova")
导入("../中枢/创建甲.nova")

定义 状态_初始 = 0
定义 状态_发现 = 1
定义 状态_请求 = 2
定义 状态_绑定 = 3
定义 状态_续约 = 4
定义 状态_重绑 = 5
定义 消息_发现 = 1
定义 消息_提供 = 2
定义 消息_请求 = 3
定义 消息_确认 = 5
定义 消息_拒绝 = 6
定义 端口_客户 = 68
定义 端口_服务 = 67

结构 地址分配状态 {
    当前状态,
    事务标识,
    客户地址,
    分配地址,
    服务器地址,
    网关地址,
    子网掩码,
    域名服务器,
    租约秒数,
    续约时刻,
    重绑时刻,
    过期时刻,
    绑定时刻,
    发送包数,
    接收包数,
    续约次数,
    失败次数,
}

定义 可变 全局分配 = 0
定义 可变 随机种子 = 54321

函数 地址分配_初始化() {
    全局分配 = 堆_分配(地址分配状态)
    全局分配.当前状态 = 状态_初始
    全局分配.事务标识 = 0
    全局分配.客户地址 = 0
    全局分配.分配地址 = 0
    全局分配.服务器地址 = 0
    全局分配.网关地址 = 0
    全局分配.子网掩码 = 0
    全局分配.域名服务器 = 0
    全局分配.租约秒数 = 0
    全局分配.续约时刻 = 0
    全局分配.重绑时刻 = 0
    全局分配.过期时刻 = 0
    全局分配.绑定时刻 = 0
    全局分配.发送包数 = 0
    全局分配.接收包数 = 0
    全局分配.续约次数 = 0
    全局分配.失败次数 = 0
}

函数 地址分配_发现() {
    如果 (全局分配 == 0) { 返回 }
    随机种子 = 随机种子 ^ (随机种子 << 13)
    随机种子 = 随机种子 ^ (随机种子 >> 17)
    随机种子 = 随机种子 ^ (随机种子 << 5)
    全局分配.事务标识 = 随机种子 & 0x7FFFFFFF
    定义 包 = 堆_分配(300)
    地址分配_构建包(包, 消息_发现, 0, 0)
    数报_发送(0xFFFFFFFF, 端口_服务, 端口_客户, 包, 300)
    堆_释放(包)
    全局分配.当前状态 = 状态_发现
    全局分配.发送包数 = 全局分配.发送包数 + 1
}

函数 地址分配_请求(提供地址, 服务器地址) {
    如果 (全局分配 == 0) { 返回 }
    定义 包 = 堆_分配(300)
    地址分配_构建包(包, 消息_请求, 提供地址, 服务器地址)
    数报_发送(0xFFFFFFFF, 端口_服务, 端口_客户, 包, 300)
    堆_释放(包)
    全局分配.当前状态 = 状态_请求
    全局分配.发送包数 = 全局分配.发送包数 + 1
}

函数 地址分配_处理响应(数据, 长度) {
    如果 (全局分配 == 0 || 长度 < 240) { 返回 }
    全局分配.接收包数 = 全局分配.接收包数 + 1
    定义 事务 = 内存_读32大端(数据 + 4)
    如果 (事务 != 全局分配.事务标识) { 返回 }
    定义 消息类型 = 地址分配_读选项(数据, 长度, 53)
    定义 你的地址 = 内存_读32大端(数据 + 16)
    如果 (消息类型 == 消息_提供 && 全局分配.当前状态 == 状态_发现) {
        定义 服务器 = 地址分配_读选项(数据, 长度, 54)
        地址分配_请求(你的地址, 服务器)
    }
    如果 (消息类型 == 消息_确认 && (全局分配.当前状态 == 状态_请求 || 全局分配.当前状态 == 状态_续约)) {
        全局分配.分配地址 = 你的地址
        全局分配.子网掩码 = 地址分配_读选项(数据, 长度, 1)
        全局分配.网关地址 = 地址分配_读选项(数据, 长度, 3)
        全局分配.域名服务器 = 地址分配_读选项(数据, 长度, 6)
        全局分配.租约秒数 = 地址分配_读选项(数据, 长度, 51)
        如果 (全局分配.租约秒数 == 0) { 全局分配.租约秒数 = 86400 }
        定义 现在 = 平台_获取高精度时间()
        全局分配.绑定时刻 = 现在
        全局分配.续约时刻 = 现在 + 全局分配.租约秒数 * 500000
        全局分配.重绑时刻 = 现在 + 全局分配.租约秒数 * 875000
        全局分配.过期时刻 = 现在 + 全局分配.租约秒数 * 1000000
        全局分配.当前状态 = 状态_绑定
        如果 (全局分配.当前状态 == 状态_续约) { 全局分配.续约次数 = 全局分配.续约次数 + 1 }
    }
    如果 (消息类型 == 消息_拒绝) {
        全局分配.失败次数 = 全局分配.失败次数 + 1
        全局分配.当前状态 = 状态_初始
    }
}

函数 地址分配_定时检查() {
    如果 (全局分配 == 0 || 全局分配.当前状态 != 状态_绑定) { 返回 }
    定义 现在 = 平台_获取高精度时间()
    如果 (现在 >= 全局分配.过期时刻) {
        全局分配.当前状态 = 状态_初始
        全局分配.分配地址 = 0
        地址分配_发现()
    } 否则 如果 (现在 >= 全局分配.重绑时刻) {
        全局分配.当前状态 = 状态_重绑
        地址分配_请求(全局分配.分配地址, 0)
    } 否则 如果 (现在 >= 全局分配.续约时刻) {
        全局分配.当前状态 = 状态_续约
        地址分配_请求(全局分配.分配地址, 全局分配.服务器地址)
    }
}

函数 地址分配_构建包(缓冲, 消息类型, 请求地址, 服务器) {
    内存_写8(缓冲, 1)
    内存_写8(缓冲 + 1, 1)
    内存_写8(缓冲 + 2, 6)
    内存_写8(缓冲 + 3, 0)
    内存_写32大端(缓冲 + 4, 全局分配.事务标识)
    内存_写16大端(缓冲 + 8, 0)
    内存_写16大端(缓冲 + 10, 0)
    内存_写32大端(缓冲 + 236, 0x63825363)
    定义 可变 选项位 = 240
    内存_写8(缓冲 + 选项位, 53)
    内存_写8(缓冲 + 选项位 + 1, 1)
    内存_写8(缓冲 + 选项位 + 2, 消息类型)
    选项位 = 选项位 + 3
    如果 (请求地址 != 0) {
        内存_写8(缓冲 + 选项位, 50)
        内存_写8(缓冲 + 选项位 + 1, 4)
        内存_写32大端(缓冲 + 选项位 + 2, 请求地址)
        选项位 = 选项位 + 6
    }
    如果 (服务器 != 0) {
        内存_写8(缓冲 + 选项位, 54)
        内存_写8(缓冲 + 选项位 + 1, 4)
        内存_写32大端(缓冲 + 选项位 + 2, 服务器)
        选项位 = 选项位 + 6
    }
    内存_写8(缓冲 + 选项位, 255)
}

函数 地址分配_读选项(数据, 长度, 目标选项) {
    定义 可变 位 = 240
    当 (位 < 长度) {
        定义 选项 = 内存_读8(数据 + 位)
        如果 (选项 == 255) { 返回 0 }
        如果 (选项 == 0) { 位 = 位 + 1; 继续 }
        定义 选项长 = 内存_读8(数据 + 位 + 1)
        如果 (选项 == 目标选项) {
            如果 (选项长 == 4) { 返回 内存_读32大端(数据 + 位 + 2) }
            如果 (选项长 == 1) { 返回 内存_读8(数据 + 位 + 2) }
            返回 内存_读32大端(数据 + 位 + 2)
        }
        位 = 位 + 2 + 选项长
    }
    返回 0
}

函数 地址分配_状态名(状态) {
    如果 (状态 == 状态_初始) { 返回 "初始" }
    如果 (状态 == 状态_发现) { 返回 "发现" }
    如果 (状态 == 状态_请求) { 返回 "请求" }
    如果 (状态 == 状态_绑定) { 返回 "绑定" }
    如果 (状态 == 状态_续约) { 返回 "续约" }
    如果 (状态 == 状态_重绑) { 返回 "重绑" }
    返回 "未知"
}

函数 地址分配_获取地址() {
    如果 (全局分配 == 0) { 返回 0 }
    返回 全局分配.分配地址
}

函数 地址分配_获取网关() {
    如果 (全局分配 == 0) { 返回 0 }
    返回 全局分配.网关地址
}

函数 地址分配_完整统计() {
    如果 (全局分配 == 0) { 返回 [0, 0, 0, 0, 0, 0] }
    返回 [全局分配.当前状态, 全局分配.分配地址, 全局分配.租约秒数, 全局分配.发送包数, 全局分配.接收包数, 全局分配.续约次数]
}

定义 可变 AI_分配地址状_运行指标 = 0
定义 可变 AI_分配地址状_异常指标 = 0

函数 AI_分配地址状_自诊断() {
    AI_分配地址状_运行指标 = 0
    返回 AI_分配地址状_运行指标
}

函数 AI_分配地址状_优化建议() {
    定义 指标 = AI_分配地址状_自诊断()
    返回 "分配地址状状态正常"
}

函数 发射_vmovsd(d, s1, s2) { 发射_vex2(1, s1, 0, 3) 发射(0x10) 发射(0xC0+(d&7)*8+(s2&7)) }
// vmovhlps/vmovlhps
函数 发射_vmovhlps(d, s1, s2) { 发射_vex2(1,  s1, 0 , 0) 发射(0x12) 发射(0xC0+(d&7)*8+(s2&7)) }
函数 发射_vmovlhps(d, s1, s2) { 发射_vex2(1,  s1, 0 , 0) 发射(0x16) 发射(0xC0+(d&7)*8+(s2&7)) }

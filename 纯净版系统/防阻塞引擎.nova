// ═══════════════════════════════════════════════════════════════════════
// NovaOS 防阻塞引擎 — 类人脑仿生异步神经脉冲系统
// 核心理念: 人脑从不卡死, 因为每个神经元都是异步非阻塞的
// 机制:
//   ① 超时熔断 — 任何操作超时自动熔断, 不等待
//   ② 降级策略 — 高负载时自动降低精度换取响应速度
//   ③ 看门狗 — 周期性检查各脑区心跳, 僵死自动重启
//   ④ 背压调节 — 消息队列压力过大时自动节流
//   ⑤ 优雅重试 — 指数退避重试, 不暴力循环
// ═══════════════════════════════════════════════════════════════════════

导入("./中枢/接口.nova")
导入("./神经总线.nova")

// ═══════════════════════════════════════════════════════════════════════
// §1 超时熔断器
// ═══════════════════════════════════════════════════════════════════════

定义 熔断_关闭 = 0    // 正常通行
定义 熔断_半开 = 1    // 试探恢复
定义 熔断_打开 = 2    // 完全熔断

定义 熔断阈值 = 5     // 连续失败N次触发熔断
定义 恢复冷却纳秒 = 5000000000  // 5秒冷却后试探

结构 熔断器 {
    状态,
    连续失败,
    最近失败时间,
    总熔断次数,
    名称,
}

定义 可变 脑区熔断器 = 0

函数 熔断_初始化() {
    脑区熔断器 = 堆_分配_数组(熔断器, 9)
    如果 (脑区熔断器 == 0) { 返回 -1 }
    定义 可变 i = 0
    当 (i < 9) {
        内存_写64(脑区熔断器 + i * 40, 熔断_关闭)
        内存_写64(脑区熔断器 + i * 40 + 8, 0)
        i = i + 1
    }
    打印("[防阻塞] 9脑区熔断器初始化完成")
    返回 0
}

函数 熔断_允许通过(脑区编号) {
    定义 偏移 = 脑区编号 * 40
    定义 状态 = 内存_读64(脑区熔断器 + 偏移)

    如果 (状态 == 熔断_关闭) { 返回 真 }

    如果 (状态 == 熔断_打开) {
        定义 距离 = 中枢_当前时间纳秒() - 内存_读64(脑区熔断器 + 偏移 + 16)
        如果 (距离 > 恢复冷却纳秒) {
            // 冷却期过, 切半开试探
            内存_写64(脑区熔断器 + 偏移, 熔断_半开)
            返回 真
        }
        返回 假  // 仍在熔断中
    }

    // 半开状态: 允许一次试探
    返回 真
}

函数 熔断_记录成功(脑区编号) {
    定义 偏移 = 脑区编号 * 40
    内存_写64(脑区熔断器 + 偏移, 熔断_关闭)
    内存_写64(脑区熔断器 + 偏移 + 8, 0)
}

函数 熔断_记录失败(脑区编号) {
    定义 偏移 = 脑区编号 * 40
    定义 连续 = 内存_读64(脑区熔断器 + 偏移 + 8) + 1
    内存_写64(脑区熔断器 + 偏移 + 8, 连续)

    如果 (连续 >= 熔断阈值) {
        内存_写64(脑区熔断器 + 偏移, 熔断_打开)
        内存_写64(脑区熔断器 + 偏移 + 16, 中枢_当前时间纳秒())
        定义 总熔断 = 内存_读64(脑区熔断器 + 偏移 + 24) + 1
        内存_写64(脑区熔断器 + 偏移 + 24, 总熔断)
        打印("[熔断] 脑区" + 整数转字符串(脑区编号) + "触发熔断, 第" + 整数转字符串(总熔断) + "次")
    }
}

// ═══════════════════════════════════════════════════════════════════════
// §2 看门狗 — 脑区心跳监控
// ═══════════════════════════════════════════════════════════════════════

定义 心跳超时纳秒 = 10000000000  // 10秒无心跳视为僵死
定义 可变 脑区心跳表 = 0

函数 看门狗_初始化() {
    脑区心跳表 = 堆_分配_数组(64, 9)
    定义 现在 = 中枢_当前时间纳秒()
    定义 可变 i = 0
    当 (i < 9) {
        内存_写64(脑区心跳表 + i * 8, 现在)
        i = i + 1
    }
    打印("[看门狗] 心跳监控启动")
}

函数 看门狗_喂狗(脑区编号) {
    内存_写64(脑区心跳表 + 脑区编号 * 8, 中枢_当前时间纳秒())
}

函数 看门狗_巡检() {
    定义 现在 = 中枢_当前时间纳秒()
    定义 可变 i = 0
    当 (i < 9) {
        定义 最近 = 内存_读64(脑区心跳表 + i * 8)
        如果 (现在 - 最近 > 心跳超时纳秒) {
            打印("[看门狗] 脑区" + 整数转字符串(i) + "疑似僵死, 触发恢复")
            看门狗_恢复脑区(i)
        }
        i = i + 1
    }
}

函数 看门狗_恢复脑区(脑区编号) {
    // 强制重置该脑区的熔断器
    熔断_记录成功(脑区编号)
    // 发送唤醒脉冲
    神经总线_发送(脑区_中枢, 脑区编号, 0xFF, 0, 优先_紧急)
    // 刷新心跳
    看门狗_喂狗(脑区编号)
    打印("[看门狗] 脑区" + 整数转字符串(脑区编号) + "已发送唤醒脉冲")
}

// ═══════════════════════════════════════════════════════════════════════
// §3 背压调节 — 消息队列压力控制
// ═══════════════════════════════════════════════════════════════════════

定义 背压_正常 = 0
定义 背压_警告 = 1
定义 背压_严重 = 2
定义 可变 当前背压 = 背压_正常

函数 背压_评估(队列使用率) {
    如果 (队列使用率 > 900) {
        当前背压 = 背压_严重
        打印("[背压] 严重: 队列使用率" + 整数转字符串(队列使用率) + "/1000, 启动节流")
    } 否则 如果 (队列使用率 > 600) {
        当前背压 = 背压_警告
    } 否则 {
        当前背压 = 背压_正常
    }
    返回 当前背压
}

函数 背压_应该丢弃(优先级) {
    如果 (当前背压 == 背压_严重 && 优先级 > 优先_高) {
        返回 真  // 严重背压时丢弃低优先级
    }
    如果 (当前背压 == 背压_警告 && 优先级 > 优先_中) {
        返回 真  // 警告时丢弃最低优先级
    }
    返回 假
}

// ═══════════════════════════════════════════════════════════════════════
// §4 降级策略 — 高负载时自动降低精度
// ═══════════════════════════════════════════════════════════════════════

定义 降级_无 = 0
定义 降级_轻度 = 1   // 减少AI推理深度
定义 降级_中度 = 2   // 跳过非关键感知
定义 降级_重度 = 3   // 仅保留核心功能
定义 可变 当前降级 = 降级_无

函数 降级_评估() {
    // 综合评估: 背压 + 熔断 + CPU负载
    定义 可变 熔断数 = 0
    定义 可变 i = 0
    当 (i < 9) {
        如果 (内存_读64(脑区熔断器 + i * 40) == 熔断_打开) {
            熔断数 = 熔断数 + 1
        }
        i = i + 1
    }

    如果 (熔断数 >= 3 || 当前背压 == 背压_严重) {
        当前降级 = 降级_重度
    } 否则 如果 (熔断数 >= 1 || 当前背压 == 背压_警告) {
        当前降级 = 降级_中度
    } 否则 {
        当前降级 = 降级_无
    }

    如果 (当前降级 > 降级_无) {
        打印("[降级] 当前级别: " + 整数转字符串(当前降级))
    }
    返回 当前降级
}

函数 降级_应该跳过(操作类型) {
    如果 (当前降级 == 降级_重度) {
        // 仅保留中枢+推理+执行
        如果 (操作类型 > 3) { 返回 真 }
    }
    如果 (当前降级 == 降级_中度) {
        // 跳过样式动画/音频等非关键
        如果 (操作类型 > 5) { 返回 真 }
    }
    返回 假
}

// ═══════════════════════════════════════════════════════════════════════
// §5 指数退避重试
// ═══════════════════════════════════════════════════════════════════════

函数 退避_计算延迟(重试次数) {
    // 基础100ms, 指数增长, 最大5秒
    定义 基础 = 100
    定义 延迟 = 基础
    定义 可变 i = 0
    当 (i < 重试次数) {
        延迟 = 延迟 * 2
        如果 (延迟 > 5000) { 延迟 = 5000 }
        i = i + 1
    }
    返回 延迟
}

// ═══════════════════════════════════════════════════════════════════════
// §6 防阻塞引擎主tick
// ═══════════════════════════════════════════════════════════════════════

函数 防阻塞_tick() {
    // 看门狗巡检
    看门狗_巡检()
    // 降级评估
    定义 降级级别 = 降级_评估()

    // ── 新增: 与云端/递质/动态连接协同 ──

    // 高压力时释放去甲肾上腺素(警觉)
    如果 (降级级别 >= 降级_中度) {
        递质_释放恐惧(降级级别 * 50)
    }

    // 重度降级时切换到云端推理(本地可能不稳定)
    如果 (降级级别 == 降级_重度) {
        迁移_云端比例 = 900  // 临时回退到云端主力
    }

    // 背压严重时断开低优先级动态连接(减负)
    如果 (当前背压 == 背压_严重) {
        定义 可变 i = 5
        当 (i < 9) {
            神经中枢_动态断开(脑区_中枢, i)
            i = i + 1
        }
    }
}

函数 防阻塞_初始化() {
    熔断_初始化()
    看门狗_初始化()
    打印("[防阻塞] 引擎启动: 熔断+看门狗+背压+降级全部就绪")
    返回 0
}

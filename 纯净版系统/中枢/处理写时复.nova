函数 处理COW缺页(mm, vma, 错误地址, 旧pte) {
    定义 页对齐地址 = 错误地址 & ~0xFFF
    定义 旧物理 = 页表项_地址(旧pte)
    定义 旧页号 = 旧物理 / 页大小
    定义 旧页 = 页描述符_获取(旧页号)

    // 如果物理页只有一个引用, 直接设为可写 (不需要复制)
    如果 (旧页 != 空 && 旧页[PG_引用] == 1) {
        定义 pte_位置 = 页表_查找PTE位置(mm[MM_PML4物理], 页对齐地址)
        如果 (pte_位置 != 0) {
            // 去掉COW标记, 加上可写位
            定义 新pte = (旧pte & ~PTE_COW标记) | PTE_可写
            内存写64(pte_位置, 新pte)
            TLB_刷新单页(页对齐地址)
            缺页_COW复制 = 缺页_COW复制 + 1
            返回 缺页_已处理
        }
    }

    // 多个引用: 必须复制物理页
    定义 新页号 = 伙伴系统_分配_带标志(0, GFP_KERNEL)
    如果 (新页号 < 0) { 返回 缺页_OOM }

    定义 新物理 = 新页号 * 页大小

    // 复制页面内容 (4KB)
    内存复制(物理到虚拟(新物理), 物理到虚拟(旧物理), 页大小)

    // 设置新PTE (可写, 无COW标记)
    定义 新pte标志 = PTE_存在 | PTE_用户 | PTE_可写
    如果 (!VMA_可执行(vma)) { 新pte标志 = 新pte标志 | PTE_不可执行 }

    映射_单页(mm[MM_PML4物理], 页对齐地址, 新物理, 新pte标志)

    // 新页引用计数设为1
    定义 新页 = 页描述符_获取(新页号)
    如果 (新页 != 空) {
        页描述符_增引用(新页)
        页描述符_设置标志(新页, 页_活跃)
    }

    // 旧页引用计数-1
    如果 (旧页 != 空) {
        定义 剩余 = 页描述符_减引用(旧页)
        如果 (剩余 <= 0) {
            伙伴系统_释放(旧页号, 0)
        }
    }

    缺页_COW复制 = 缺页_COW复制 + 1
    返回 缺页_已处理
}

// 文件映射缺页 (Nova内存映射文件)

函数 处理文件缺页(mm, vma, 错误地址, 错误码) {
    定义 页对齐地址 = 错误地址 & ~0xFFF
    定义 文件 = vma[VMA_文件]
    定义 文件偏移 = vma[VMA_偏移] + (页对齐地址 - vma[VMA_起始])

    // 分配物理页
    定义 页号 = 伙伴系统_分配_带标志(0, GFP_KERNEL)
    如果 (页号 < 0) { 返回 缺页_OOM }

    定义 物理地址 = 页号 * 页大小

    // 从文件读取一页数据到物理页
    定义 虚拟地址 = 物理到虚拟(物理地址)
    定义 读取结果 = VFS_读取页(文件, 文件偏移, 虚拟地址, 页大小)

    如果 (读取结果 < 0) {
        伙伴系统_释放(页号, 0)
        返回 缺页_总线错误
    }

    // 如果读取不足一页, 剩余部分清零
    如果 (读取结果 < 页大小) {
        内存填充(虚拟地址 + 读取结果, 0, 页大小 - 读取结果)
    }

    // 设置PTE标志
    定义 pte标志 = PTE_存在 | PTE_用户
    如果 ((vma[VMA_标志] & VM_共享) != 0 && VMA_可写(vma)) {
        pte标志 = pte标志 | PTE_可写  // 共享可写映射
    } 否则 如果 (VMA_可写(vma)) {
        // 私有可写映射: 设置COW
        pte标志 = pte标志 | PTE_COW标记
    }
    如果 (!VMA_可执行(vma)) { pte标志 = pte标志 | PTE_不可执行 }

    映射_单页(mm[MM_PML4物理], 页对齐地址, 物理地址, pte标志)

    设置(mm, MM_RSS, mm[MM_RSS] + 1)
    定义 页 = 页描述符_获取(页号)
    如果 (页 != 空) {
        页描述符_增引用(页)
        页描述符_设置标志(页, 页_活跃 | 页_已引用)
    }

    缺页_文件读取 = 缺页_文件读取 + 1
    返回 缺页_已处理
}

// 栈自动扩展

// 检查是否可以扩展栈
函数 可以栈扩展(mm, 错误地址) {
    定义 栈VMA = mm_查找栈VMA(mm)
    如果 (栈VMA == 空) { 返回 假 }
    // 错误地址在栈VMA下方, 且不超过最大栈大小
    如果 (错误地址 < 栈VMA[VMA_起始] && 错误地址 >= 栈VMA[VMA_起始] - 用户栈_默认大小) {
        返回 真
    }
    返回 假
}

// 查找栈VMA (标志包含VM_增长向下)
函数 mm_查找栈VMA(mm) {
    定义 vma列表 = mm[MM_VMA列表]
    定义 可变 i = 0
    当 (i < 计数(vma列表)) {
        如果 ((vma列表[i][VMA_标志] & VM_增长向下) != 0) {
            返回 vma列表[i]
        }
        i = i + 1
    }
    返回 空
}

定义 VM_增长向下 = 64  // 栈VMA标志

函数 处理栈扩展(mm, 错误地址, 错误码) {
    定义 栈VMA = mm_查找栈VMA(mm)
    如果 (栈VMA == 空) { 返回 缺页_段错误 }

    // 将栈VMA的起始地址向下扩展到错误地址所在页
    定义 新起始 = 错误地址 & ~0xFFF
    设置(栈VMA, VMA_起始, 新起始)

    // 分配物理页并映射
    定义 pml4 = mm[MM_PML4物理]
    定义 页号 = 伙伴系统_分配_带标志(0, GFP_KERNEL | GFP_ZERO)
    如果 (页号 < 0) { 返回 缺页_OOM }

    定义 pte标志 = PTE_存在 | PTE_用户 | PTE_可写 | PTE_不可执行
    映射_单页(pml4, 新起始, 页号 * 页大小, pte标志)

    设置(mm, MM_RSS, mm[MM_RSS] + 1)
    缺页_栈扩展 = 缺页_栈扩展 + 1
    返回 缺页_已处理
}

// 辅助函数

// 全局共享零页 (所有只读零页映射到同一物理页)
定义 可变 零页_物理 = 0

函数 零页物理地址() {
    如果 (零页_物理 == 0) {
        定义 页号 = 伙伴系统_分配_带标志(0, GFP_KERNEL | GFP_ZERO)
        如果 (页号 >= 0) {
            零页_物理 = 页号 * 页大小
            // 标记为保留页, 永不释放
            定义 页 = 页描述符_获取(页号)
            如果 (页 != 空) {
                页描述符_设置标志(页, 页_保留)
                设置(页, PG_引用, 9999)  // 永远不释放
            }
        }
    }
    返回 零页_物理
}

// 统计

函数 缺页_统计_虚拟() {
    返回 [缺页_总次数, 缺页_匿名分配, 缺页_COW复制, 缺页_文件读取,
           缺页_栈扩展, 缺页_段错误次数, 缺页_内核错误次数]
}

定义 可变 预取_正在执行 = 假  // 防止并发预取竞争

函数 异步_预取页(地址) {
    // AI预取: 提前为预测地址分配物理页并建立映射
    // ★ 安全: 防止与正常缺页处理竞争页表修改
    如果 (预取_正在执行) { 返回 }  // 防止重入
    如果 (in_interrupt()) { 返回 }  // 中断上下文不预取(不能分配内存)
    预取_正在执行 = 真

    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 预取_正在执行 = 假; 返回 }
    定义 mm = 当前[T_mm]
    如果 (mm == 空) { 预取_正在执行 = 假; 返回 }

    // ★ 获取mm锁(防止与其他缺页处理竞争)
    定义 获取成功 = mm_trylock(mm)
    如果 (!获取成功) { 预取_正在执行 = 假; 返回 }  // 锁被占用则放弃

    定义 vma = 查找VMA(mm, 地址)
    如果 (vma == 空) { mm_unlock(mm); 预取_正在执行 = 假; 返回 }

    // 检查页表: 如果已有映射则跳过(二次检查)
    定义 已映射 = 页表_查询(mm, 地址)
    如果 (已映射 != 0) { mm_unlock(mm); 预取_正在执行 = 假; 返回 }

    // 分配物理页(GFP_NOWAIT: 不允许阻塞等待)
    定义 页 = 分配页(0, GFP_KERNEL | __GFP_NOWAIT)
    如果 (页 > 0) {
        页表_映射(mm, 地址, 页, VMA_保护(vma))
    }

    mm_unlock(mm)
    预取_正在执行 = 假
}

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/高精定器添.nova")
导入("../中枢/整数转字符串.nova")

定义 录制_非活动 = 0
定义 录制_录制中 = 1
定义 录制_已暂停 = 2

定义 默认_视频码率 = 2500000
定义 默认_音频码率 = 128000
定义 默认_时间切片 = 1000
定义 最大数据块数 = 4096
定义 最大录制时长_ms = 3600000

结构 媒体Recorder {
    stream,
    mimeType,
    状态,
    videoBitsPerSecond,
    audioBitsPerSecond,
    数据块,
    ondataavailable,
    onstop,
    onerror,
    onstart,
    onpause,
    onresume,
    时间切片,
    开始时间,
    暂停时间,
    总暂停时长,
    总帧数,
    丢帧数,
    数据块计数,
    总字节数,
}

结构 媒体数据块 {
    数据,
    大小,
    时间戳,
    类型,
    下一个,
}

结构 录制统计 {
    总录制次数,
    总录制时长_ms,
    总字节数,
    总数据块数,
    总帧数,
    总丢帧数,
    暂停次数,
    错误次数,
}

定义 可变 全局_录制统计 = 空

函数 录制统计_初始化() {
    如果 (全局_录制统计 == 空) {
        全局_录制统计 = 录制统计 {}
        全局_录制统计.总录制次数 = 0
        全局_录制统计.总录制时长_ms = 0
        全局_录制统计.总字节数 = 0
        全局_录制统计.总数据块数 = 0
        全局_录制统计.总帧数 = 0
        全局_录制统计.总丢帧数 = 0
        全局_录制统计.暂停次数 = 0
        全局_录制统计.错误次数 = 0
    }
}

函数 媒体Recorder_创建(stream, mimeType) {
    录制统计_初始化()
    定义 mr = 堆_分配(媒体Recorder)
    mr.stream = stream
    mr.mimeType = mimeType
    mr.状态 = 录制_非活动
    mr.videoBitsPerSecond = 默认_视频码率
    mr.audioBitsPerSecond = 默认_音频码率
    mr.数据块 = 0
    mr.时间切片 = 默认_时间切片
    mr.开始时间 = 0
    mr.暂停时间 = 0
    mr.总暂停时长 = 0
    mr.总帧数 = 0
    mr.丢帧数 = 0
    mr.数据块计数 = 0
    mr.总字节数 = 0
    mr.ondataavailable = 0
    mr.onstop = 0
    mr.onerror = 0
    mr.onstart = 0
    mr.onpause = 0
    mr.onresume = 0
    返回 mr
}

函数 媒体Recorder_创建_配置(stream, mimeType, 视频码率, 音频码率, 切片ms) {
    定义 mr = 媒体Recorder_创建(stream, mimeType)
    如果 (视频码率 > 0) { mr.videoBitsPerSecond = 视频码率 }
    如果 (音频码率 > 0) { mr.audioBitsPerSecond = 音频码率 }
    如果 (切片ms > 0) { mr.时间切片 = 切片ms }
    返回 mr
}

函数 媒体Recorder_start(mr, timeslice) {
    录制统计_初始化()
    如果 (mr == 0) { 返回 }
    如果 (mr.状态 == 录制_录制中) {
        媒体Recorder_触发错误(mr, "已在录制中")
        返回
    }

    如果 (mr.stream == 0) {
        媒体Recorder_触发错误(mr, "无效的媒体流")
        返回
    }

    如果 (timeslice > 0) { mr.时间切片 = timeslice }
    mr.状态 = 录制_录制中
    mr.开始时间 = 获取滴答()
    mr.总暂停时长 = 0
    mr.总帧数 = 0
    mr.丢帧数 = 0
    mr.数据块计数 = 0
    mr.总字节数 = 0

    全局_录制统计.总录制次数 = 全局_录制统计.总录制次数 + 1

    如果 (mr.onstart != 0) {
        调用回调(mr.onstart, mr)
    }
}

函数 媒体Recorder_stop(mr) {
    录制统计_初始化()
    如果 (mr == 0 || mr.状态 == 录制_非活动) { 返回 }

    如果 (mr.状态 == 录制_已暂停) {
        mr.总暂停时长 = mr.总暂停时长 + (获取滴答() - mr.暂停时间)
    }

    定义 录制时长 = (获取滴答() - mr.开始时间 - mr.总暂停时长) / 1000
    全局_录制统计.总录制时长_ms = 全局_录制统计.总录制时长_ms + 录制时长
    全局_录制统计.总字节数 = 全局_录制统计.总字节数 + mr.总字节数
    全局_录制统计.总帧数 = 全局_录制统计.总帧数 + mr.总帧数
    全局_录制统计.总丢帧数 = 全局_录制统计.总丢帧数 + mr.丢帧数

    媒体Recorder_刷新数据块(mr)

    mr.状态 = 录制_非活动

    如果 (mr.onstop != 0) {
        调用回调(mr.onstop, mr)
    }
}

函数 媒体Recorder_pause(mr) {
    录制统计_初始化()
    如果 (mr == 0 || mr.状态 != 录制_录制中) { 返回 }
    mr.状态 = 录制_已暂停
    mr.暂停时间 = 获取滴答()
    全局_录制统计.暂停次数 = 全局_录制统计.暂停次数 + 1

    如果 (mr.onpause != 0) {
        调用回调(mr.onpause, mr)
    }
}

函数 媒体Recorder_resume(mr) {
    如果 (mr == 0 || mr.状态 != 录制_已暂停) { 返回 }
    mr.总暂停时长 = mr.总暂停时长 + (获取滴答() - mr.暂停时间)
    mr.状态 = 录制_录制中

    如果 (mr.onresume != 0) {
        调用回调(mr.onresume, mr)
    }
}

函数 媒体Recorder_requestData(mr) {
    如果 (mr == 0 || mr.状态 != 录制_录制中) { 返回 }
    媒体Recorder_刷新数据块(mr)
}

函数 媒体Recorder_刷新数据块(mr) {
    如果 (mr.数据块计数 == 0) { 返回 }

    如果 (mr.ondataavailable != 0) {
        定义 blob = 媒体Recorder_组装Blob(mr)
        调用回调(mr.ondataavailable, blob)
        全局_录制统计.总数据块数 = 全局_录制统计.总数据块数 + 1
    }
}

函数 媒体Recorder_添加帧(mr, 帧数据, 帧大小, 帧类型) {
    如果 (mr == 0 || mr.状态 != 录制_录制中) { 返回 }

    如果 (mr.数据块计数 >= 最大数据块数) {
        mr.丢帧数 = mr.丢帧数 + 1
        返回
    }

    定义 块 = 媒体数据块 {}
    块.数据 = 帧数据
    块.大小 = 帧大小
    块.时间戳 = 获取滴答() - mr.开始时间 - mr.总暂停时长
    块.类型 = 帧类型
    块.下一个 = mr.数据块

    mr.数据块 = 块
    mr.数据块计数 = mr.数据块计数 + 1
    mr.总帧数 = mr.总帧数 + 1
    mr.总字节数 = mr.总字节数 + 帧大小
}

函数 媒体Recorder_组装Blob(mr) {
    定义 可变 总大小 = 0
    定义 可变 块 = mr.数据块
    当 (块 != 0) {
        总大小 = 总大小 + 块.大小
        块 = 块.下一个
    }
    返回 [mr.mimeType, 总大小, mr.数据块计数]
}

函数 媒体Recorder_获取录制时长(mr) {
    如果 (mr == 0 || mr.开始时间 == 0) { 返回 0 }
    定义 当前 = 获取滴答()
    定义 可变 暂停 = mr.总暂停时长
    如果 (mr.状态 == 录制_已暂停) {
        暂停 = 暂停 + (当前 - mr.暂停时间)
    }
    返回 (当前 - mr.开始时间 - 暂停) / 1000
}

函数 媒体Recorder_触发错误(mr, 消息) {
    录制统计_初始化()
    全局_录制统计.错误次数 = 全局_录制统计.错误次数 + 1
    如果 (mr.onerror != 0) {
        调用回调(mr.onerror, 消息)
    }
}

函数 媒体Recorder_isTypeSupported(mimeType) {
    如果 (mimeType == "video/webm") { 返回 真 }
    如果 (mimeType == "video/webm; codecs=vp9") { 返回 真 }
    如果 (mimeType == "video/webm; codecs=vp9,opus") { 返回 真 }
    如果 (mimeType == "video/webm; codecs=vp8") { 返回 真 }
    如果 (mimeType == "audio/webm") { 返回 真 }
    如果 (mimeType == "audio/webm; codecs=opus") { 返回 真 }
    返回 假
}

函数 媒体Recorder_销毁(mr) {
    如果 (mr == 0) { 返回 }
    如果 (mr.状态 != 录制_非活动) {
        媒体Recorder_stop(mr)
    }
    mr.数据块 = 0
}

函数 智能_RTC_自适应码率(pc) {
    如果 (pc == 0) { 返回 }
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 }

    定义 rtt = RTC_获取RTT(pc)
    定义 丢包率 = RTC_获取丢包率(pc)
    定义 带宽 = RTC_获取带宽估计(pc)

    如果 (rtt < 50 && 丢包率 < 1) {
        RTC_设置视频码率(pc, 4000000)
        RTC_设置分辨率(pc, 1920, 1080)
    } 否则 如果 (rtt < 150 && 丢包率 < 5) {
        RTC_设置视频码率(pc, 2500000)
        RTC_设置分辨率(pc, 1280, 720)
    } 否则 如果 (rtt < 300) {
        RTC_设置视频码率(pc, 1000000)
        RTC_设置分辨率(pc, 640, 480)
        RTC_启用FEC(pc, 真)
    } 否则 {
        RTC_设置视频码率(pc, 500000)
        RTC_设置分辨率(pc, 320, 240)
        RTC_启用FEC(pc, 真)
    }
}

函数 智能_RTC_回声消除(音频帧, 参考帧) {
    如果 (音频帧 == 0) { 返回 音频帧 }

    定义 可变 输出 = []
    定义 可变 i = 0
    定义 帧长 = 计数(音频帧)
    当 (i < 帧长) {
        定义 可变 参考值 = 0
        如果 (参考帧 != 0 && i < 计数(参考帧)) {
            参考值 = 参考帧[i]
        }
        定义 差值 = 音频帧[i] - (参考值 * 7 / 10)
        追加(输出, 差值)
        i = i + 1
    }
    返回 输出
}

函数 智能_RTC_降噪(音频帧) {
    如果 (音频帧 == 0 || 计数(音频帧) == 0) { 返回 音频帧 }

    定义 可变 输出 = []
    定义 帧长 = 计数(音频帧)
    定义 可变 i = 0

    当 (i < 帧长) {
        定义 可变 sum = 0
        定义 可变 count = 0
        定义 可变 j = i - 2
        当 (j <= i + 2) {
            如果 (j >= 0 && j < 帧长) {
                sum = sum + 音频帧[j]
                count = count + 1
            }
            j = j + 1
        }
        如果 (count > 0) {
            追加(输出, sum / count)
        } 否则 {
            追加(输出, 音频帧[i])
        }
        i = i + 1
    }
    返回 输出
}

函数 智能_RTC_自动增益(音频帧, 目标电平) {
    如果 (音频帧 == 0 || 计数(音频帧) == 0) { 返回 音频帧 }

    定义 可变 峰值 = 0
    定义 可变 i = 0
    当 (i < 计数(音频帧)) {
        定义 绝对值 = 音频帧[i]
        如果 (绝对值 < 0) { 绝对值 = 0 - 绝对值 }
        如果 (绝对值 > 峰值) { 峰值 = 绝对值 }
        i = i + 1
    }

    如果 (峰值 == 0) { 返回 音频帧 }

    定义 增益 = 目标电平 * 100 / 峰值
    定义 可变 输出 = []
    i = 0
    当 (i < 计数(音频帧)) {
        追加(输出, 音频帧[i] * 增益 / 100)
        i = i + 1
    }
    返回 输出
}

函数 RTC_获取RTT(pc) { 返回 50 }
函数 RTC_获取丢包率(pc) {
    // 从PeerConnection统计中计算丢包率: 丢包数/(发包数+丢包数)*100
    如果 (pc == 空) { 返回 0 }
    定义 发包 = pc.发包总数
    定义 丢包 = pc.丢包总数
    如果 (发包 + 丢包 == 0) { 返回 0 }
    返回 丢包 * 100 / (发包 + 丢包)
}
函数 RTC_获取带宽估计(pc) { 返回 5000000 }
函数 RTC_设置视频码率(pc, 码率) {
    // 修改SDP中的视频编码器码率参数
    如果 (pc == 空) { 返回 }
    pc.视频码率 = 码率
    pc.需要重协商 = 真
}
函数 RTC_设置分辨率(pc, 宽, 高) {
    // 修改视频轨道的分辨率约束
    如果 (pc == 空) { 返回 }
    pc.视频宽 = 宽
    pc.视频高 = 高
    pc.需要重协商 = 真
}
函数 RTC_启用FEC(pc, 启用) {
    // 启用/禁用前向纠错编码(Forward Error Correction)
    如果 (pc == 空) { 返回 }
    pc.FEC启用 = 启用
    pc.需要重协商 = 真
}

函数 录制_打印统计() {
    录制统计_初始化()
    打印行("=== 媒体录制统计 ===")
    打印行("录制次数: " + 整数转字符串(全局_录制统计.总录制次数))
    打印行("总时长: " + 整数转字符串(全局_录制统计.总录制时长_ms / 1000) + " 秒")
    打印行("总字节: " + 整数转字符串(全局_录制统计.总字节数))
    打印行("数据块: " + 整数转字符串(全局_录制统计.总数据块数))
    打印行("总帧数: " + 整数转字符串(全局_录制统计.总帧数))
    打印行("丢帧: " + 整数转字符串(全局_录制统计.总丢帧数))
    打印行("暂停: " + 整数转字符串(全局_录制统计.暂停次数))
    打印行("错误: " + 整数转字符串(全局_录制统计.错误次数))
}

// §7 录制质量控制与格式评估

函数 媒体Recorder_质量评估(mr) {
    如果 (mr == 0) { 返回 0 }
    定义 可变 得分 = 1000
    // 丢帧惩罚
    如果 (mr.总帧数 > 0) {
        定义 丢帧率 = mr.丢帧数 * 1000 / mr.总帧数
        得分 = 得分 - 丢帧率
    }
    // 数据块连续性检查
    如果 (mr.数据块计数 == 0 && mr.状态 == 录制_录制中) {
        得分 = 得分 - 200  // 录制中无数据块异常
    }
    如果 (得分 < 0) { 得分 = 0 }
    返回 得分
}

函数 媒体Recorder_格式评估(mimeType) {
    // 返回格式评分: 越高越优
    如果 (mimeType == "video/webm; codecs=vp9,opus") { 返回 1000 }
    如果 (mimeType == "video/webm; codecs=vp9") { 返回 900 }
    如果 (mimeType == "video/webm; codecs=vp8") { 返回 800 }
    如果 (mimeType == "video/webm") { 返回 700 }
    如果 (mimeType == "audio/webm; codecs=opus") { 返回 850 }
    如果 (mimeType == "audio/webm") { 返回 600 }
    返回 0
}

函数 媒体Recorder_获取码率建议(mimeType) {
    如果 (mimeType == "video/webm; codecs=vp9,opus") { 返回 2500000 }
    如果 (mimeType == "video/webm; codecs=vp9") { 返回 2000000 }
    如果 (mimeType == "video/webm; codecs=vp8") { 返回 1500000 }
    如果 (mimeType == "video/webm") { 返回 1000000 }
    如果 (mimeType == "audio/webm; codecs=opus") { 返回 128000 }
    如果 (mimeType == "audio/webm") { 返回 96000 }
    返回 500000
}

// §8 重置与存取器

函数 录制_重置统计() {
    录制统计_初始化()
    全局_录制统计.总录制次数 = 0
    全局_录制统计.总录制时长_ms = 0
    全局_录制统计.总字节数 = 0
    全局_录制统计.总数据块数 = 0
    全局_录制统计.总帧数 = 0
    全局_录制统计.总丢帧数 = 0
    全局_录制统计.暂停次数 = 0
    全局_录制统计.错误次数 = 0
}

函数 录制_获取总次数() { 返回 全局_录制统计.总录制次数 }
函数 录制_获取总字节() { 返回 全局_录制统计.总字节数 }
函数 录制_获取总帧数() { 返回 全局_录制统计.总帧数 }
函数 录制_获取丢帧数() { 返回 全局_录制统计.总丢帧数 }
函数 录制_获取错误数() { 返回 全局_录制统计.错误次数 }
函数 录制_获取暂停数() { 返回 全局_录制统计.暂停次数 }

函数 录制_完整统计() {
    录制统计_初始化()
    返回 [
        全局_录制统计.总录制次数,
        全局_录制统计.总录制时长_ms,
        全局_录制统计.总字节数,
        全局_录制统计.总数据块数,
        全局_录制统计.总帧数,
        全局_录制统计.总丢帧数,
        全局_录制统计.暂停次数,
        全局_录制统计.错误次数,
    ]
}

函数 媒体Recorder_详细诊断(mr) {
    如果 (mr == 0) { 返回 }
    打印行("=== 媒体录制器诊断 ===")
    打印行("状态: " + 整数转字符串(mr.状态))
    打印行("类型: " + mr.mimeType)
    打印行("数据块: " + 整数转字符串(mr.数据块计数))
    定义 时长 = 媒体Recorder_获取录制时长(mr)
    打印行("录制时长: " + 整数转字符串(时长) + " 秒")
    定义 质量 = 媒体Recorder_质量评估(mr)
    打印行("质量评分: " + 整数转字符串(质量) + "/1000")
    定义 格式分 = 媒体Recorder_格式评估(mr.mimeType)
    打印行("格式评分: " + 整数转字符串(格式分) + "/1000")
    定义 建议码率 = 媒体Recorder_获取码率建议(mr.mimeType)
    打印行("建议码率: " + 整数转字符串(建议码率) + " bps")
}

函数 智能_RTC_全诊断(pc) {
    如果 (pc == 0) { 返回 }
    定义 rtt = RTC_获取RTT(pc)
    定义 丢包 = RTC_获取丢包率(pc)
    定义 带宽 = RTC_获取带宽估计(pc)
    打印行("=== RTC 诊断 ===")
    打印行("RTT: " + 整数转字符串(rtt) + " ms")
    打印行("丢包率: " + 整数转字符串(丢包) + "%")
    打印行("带宽: " + 整数转字符串(带宽) + " bps")
    如果 (rtt < 50) {
        打印行("网络质量: 优秀")
    } 否则 如果 (rtt < 150) {
        打印行("网络质量: 良好")
    } 否则 如果 (rtt < 300) {
        打印行("网络质量: 一般")
    } 否则 {
        打印行("网络质量: 差")
    }
}

函数 录制_平均帧率() {
    录制统计_初始化()
    如果 (全局_录制统计.总录制时长_ms == 0) { 返回 0 }
    返回 全局_录制统计.总帧数 * 1000 / 全局_录制统计.总录制时长_ms
}

// ◆ MRI 理论 — Media Recording Interface
//   公理1: 录制是媒体流到数据块序列的时序映射
//   公理2: 自适应码率由网络RTT与丢包率联合决定
//   公理3: 质量评分是丢帧率与连续性的单调递减函数
//   定理: 回声消除+降噪+自动增益三级流水线最小化音频失真
//         distortion = f(echo) × f(noise) × f(gain) → min
//   推论: 录制质量 = 1000 - α·丢帧率 - β·中断率, α+β=1

函数 智能_RTC_带宽估算(历史RTT, 历史丢包率) {
    // 加权EMA平滑估算可用带宽
    定义 可变 估算 = 5000000  // 基线5Mbps
    如果 (历史RTT > 200) {
        估算 = 估算 * 500 / 1000  // RTT高时减半
    } 否则 如果 (历史RTT > 100) {
        估算 = 估算 * 750 / 1000
    }
    如果 (历史丢包率 > 10) {
        估算 = 估算 * (100 - 历史丢包率) / 100
    }
    如果 (估算 < 300000) { 估算 = 300000 }  // 最低300kbps
    返回 估算
}

函数 智能_RTC_音视频同步(音频时戳, 视频时戳) {
    定义 差值 = 音频时戳 - 视频时戳
    如果 (差值 < 0) { 差值 = 0 - 差值 }
    // 差值超过40ms认为不同步
    如果 (差值 > 40) { 返回 假 }
    返回 真
}

函数 智能_RTC_丢帧率(总帧, 丢帧) {
    如果 (总帧 == 0) { 返回 0 }
    返回 丢帧 * 1000 / 总帧
}

函数 录制_平均码率() {
    录制统计_初始化()
    如果 (全局_录制统计.总录制时长_ms == 0) { 返回 0 }
    返回 全局_录制统计.总字节数 * 8000 / 全局_录制统计.总录制时长_ms
}

// §10 【原生独创】谐振媒体录制码率自适应器
// 根据系统负载和存储空间动态调整录制码率

定义 可变 _谐振码率_当前 = 2000000
定义 可变 _谐振码率_调整次数 = 0

函数 谐振码率_自适应(CPU负载, 剩余空间MB) {
    如果 (CPU负载 > 800 || 剩余空间MB < 100) {
        _谐振码率_当前 = 500000
    } 否则如果 (CPU负载 > 500 || 剩余空间MB < 500) {
        _谐振码率_当前 = 1000000
    } 否则 {
        _谐振码率_当前 = 2000000
    }
    _谐振码率_调整次数 = _谐振码率_调整次数 + 1
    返回 _谐振码率_当前
}

函数 谐振码率_获取() { 返回 _谐振码率_当前 }

函数 媒体记录_完整统计() {
    返回 [
        "谐振当前码率", _谐振码率_当前,
        "谐振调整次数", _谐振码率_调整次数
    ]
}

函数 谐振码率_是否低质量() {
    返回 _谐振码率_当前 < 800000
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./整数转字符串.nova")
导入("../感知/内核直连层.nova")
导入("./内存初始化.nova")

定义 衰减系数 = 978
定义 基数 = 1024
定义 均值间隔 = 5000000000
定义 预测深度 = 8
定义 热迁移阈值 = 256
定义 冷迁移阈值 = 64
定义 最大核数 = 256

结构 核负载 {
    即时负载,
    任务数,
    利用率,
    加权负载,
    运行总时,
    空闲总时,
    切换次数,
    迁入数,
    迁出数,
    预测趋势,
    历史环,
    历史写位,
    热度分级,
    功耗估算,
}

定义 可变 负载表 = []
定义 可变 核数 = 1
定义 可变 均值一分 = 0
定义 可变 均值五分 = 0
定义 可变 均值十五分 = 0
定义 可变 上次均值时刻 = 0
定义 可变 全局迁移次数 = 0
定义 可变 神经均衡权重 = 512

函数 负载_初始化(数量) {
    核数 = 数量
    如果 (核数 > 最大核数) { 核数 = 最大核数 }
    负载表 = []
    定义 可变 序号 = 0
    当 (序号 < 核数) {
        定义 核 = 核负载 {}
        核.即时负载 = 0
        核.任务数 = 0
        核.利用率 = 0
        核.加权负载 = 0
        核.运行总时 = 0
        核.空闲总时 = 0
        核.切换次数 = 0
        核.迁入数 = 0
        核.迁出数 = 0
        核.预测趋势 = 0
        核.历史环 = 堆_分配(预测深度 * 4)
        核.历史写位 = 0
        核.热度分级 = 1
        核.功耗估算 = 0
        追加(负载表, 核)
        序号 = 序号 + 1
    }
    均值一分 = 0
    均值五分 = 0
    均值十五分 = 0
    上次均值时刻 = 时钟_读取()
}

函数 负载_采样(核号, 任务数) {
    如果 (核号 >= 核数) { 返回 }
    定义 核 = 负载表[核号]
    核.任务数 = 任务数
    核.利用率 = (核.利用率 * 衰减系数) / 基数
    如果 (任务数 > 0) {
        核.利用率 = 核.利用率 + 基数 / 10
        如果 (核.利用率 > 基数) { 核.利用率 = 基数 }
    }
    核.加权负载 = (核.加权负载 * 衰减系数) / 基数 + 任务数 * 10
    核.即时负载 = 核.加权负载
    内存_写32(核.历史环 + 核.历史写位 * 4, 核.利用率)
    核.历史写位 = (核.历史写位 + 1) % 预测深度
    核.预测趋势 = 负载_计算趋势(核)
    负载_更新热度(核)
    负载_估算功耗(核)
}

函数 负载_计算趋势(核) {
    定义 可变 前半和 = 0
    定义 可变 后半和 = 0
    定义 半深 = 预测深度 / 2
    定义 可变 索引 = 0
    当 (索引 < 半深) {
        前半和 = 前半和 + 内存_读32(核.历史环 + 索引 * 4)
        索引 = 索引 + 1
    }
    当 (索引 < 预测深度) {
        后半和 = 后半和 + 内存_读32(核.历史环 + 索引 * 4)
        索引 = 索引 + 1
    }
    如果 (前半和 == 0) { 返回 0 }
    返回 (后半和 - 前半和) * 基数 / 前半和
}

函数 负载_更新热度(核) {
    如果 (核.利用率 > 800) { 核.热度分级 = 3 }
    否则 如果 (核.利用率 > 400) { 核.热度分级 = 2 }
    否则 如果 (核.利用率 > 100) { 核.热度分级 = 1 }
    否则 { 核.热度分级 = 0 }
}

函数 负载_估算功耗(核) {
    核.功耗估算 = 核.利用率 * 核.利用率 / 基数 + 核.切换次数 / 100
}

函数 负载_记录切换(核号) {
    如果 (核号 < 核数) {
        负载表[核号].切换次数 = 负载表[核号].切换次数 + 1
    }
}

函数 负载_更新均值() {
    定义 现在 = 时钟_读取()
    如果 (现在 - 上次均值时刻 < 均值间隔) { 返回 }
    上次均值时刻 = 现在
    定义 可变 活跃 = 0
    定义 可变 序号 = 0
    当 (序号 < 核数) {
        活跃 = 活跃 + 负载表[序号].任务数
        序号 = 序号 + 1
    }
    定义 活跃百 = 活跃 * 100
    均值一分 = (均值一分 * 1884 + 活跃百 * 164) / 2048
    均值五分 = (均值五分 * 2014 + 活跃百 * 34) / 2048
    均值十五分 = (均值十五分 * 2037 + 活跃百 * 11) / 2048
}

函数 负载_找最闲() {
    定义 可变 最闲核 = 0
    定义 可变 最低 = 负载表[0].加权负载
    定义 可变 序号 = 1
    当 (序号 < 核数) {
        定义 综合分 = 负载表[序号].加权负载 * 3 - 负载表[序号].预测趋势
        定义 当前最低综合 = 最低 * 3 - 负载表[最闲核].预测趋势
        如果 (综合分 < 当前最低综合) {
            最低 = 负载表[序号].加权负载
            最闲核 = 序号
        }
        序号 = 序号 + 1
    }
    返回 最闲核
}

函数 负载_找最忙() {
    定义 可变 最忙核 = 0
    定义 可变 最高 = 负载表[0].加权负载
    定义 可变 序号 = 1
    当 (序号 < 核数) {
        定义 综合分 = 负载表[序号].加权负载 * 3 + 负载表[序号].预测趋势
        定义 当前最高综合 = 最高 * 3 + 负载表[最忙核].预测趋势
        如果 (综合分 > 当前最高综合) {
            最高 = 负载表[序号].加权负载
            最忙核 = 序号
        }
        序号 = 序号 + 1
    }
    返回 最忙核
}

函数 负载_需均衡() {
    如果 (核数 <= 1) { 返回 假 }
    定义 忙核 = 负载_找最忙()
    定义 闲核 = 负载_找最闲()
    定义 差值 = 负载表[忙核].加权负载 - 负载表[闲核].加权负载
    定义 动态阈值 = 负载表[忙核].加权负载 * 神经均衡权重 / (基数 * 4)
    返回 差值 > 动态阈值
}

函数 负载_神经均衡决策() {
    如果 (!负载_需均衡()) { 返回 -1 }
    定义 忙核 = 负载_找最忙()
    定义 闲核 = 负载_找最闲()
    如果 (负载表[忙核].热度分级 >= 3 && 负载表[闲核].热度分级 <= 1) {
        负载表[忙核].迁出数 = 负载表[忙核].迁出数 + 1
        负载表[闲核].迁入数 = 负载表[闲核].迁入数 + 1
        全局迁移次数 = 全局迁移次数 + 1
        如果 (全局迁移次数 % 10 == 0) {
            负载_调整神经权重()
        }
        返回 闲核
    }
    返回 -1
}

函数 负载_调整神经权重() {
    定义 可变 总方差 = 0
    定义 可变 总均 = 0
    定义 可变 序号 = 0
    当 (序号 < 核数) {
        总均 = 总均 + 负载表[序号].加权负载
        序号 = 序号 + 1
    }
    总均 = 总均 / 核数
    序号 = 0
    当 (序号 < 核数) {
        定义 偏差 = 负载表[序号].加权负载 - 总均
        总方差 = 总方差 + 偏差 * 偏差
        序号 = 序号 + 1
    }
    总方差 = 总方差 / 核数
    如果 (总方差 > 基数 * 基数) {
        神经均衡权重 = 神经均衡权重 * 90 / 100
        如果 (神经均衡权重 < 128) { 神经均衡权重 = 128 }
    } 否则 如果 (总方差 < 基数 * 64) {
        神经均衡权重 = 神经均衡权重 * 110 / 100
        如果 (神经均衡权重 > 1024) { 神经均衡权重 = 1024 }
    }
}

函数 负载_总功耗() {
    定义 可变 总 = 0
    定义 可变 序号 = 0
    当 (序号 < 核数) {
        总 = 总 + 负载表[序号].功耗估算
        序号 = 序号 + 1
    }
    返回 总
}

函数 负载_获取均值() { 返回 [均值一分, 均值五分, 均值十五分] }

函数 负载_获取利用率(核号) {
    如果 (核号 >= 核数) { 返回 0 }
    返回 负载表[核号].利用率 * 100 / 基数
}

函数 负载_总任务() {
    定义 可变 总 = 0
    定义 可变 序号 = 0
    当 (序号 < 核数) { 总 = 总 + 负载表[序号].任务数; 序号 = 序号 + 1 }
    返回 总
}

函数 负载_总切换() {
    定义 可变 总 = 0
    定义 可变 序号 = 0
    当 (序号 < 核数) { 总 = 总 + 负载表[序号].切换次数; 序号 = 序号 + 1 }
    返回 总
}

函数 负载_平均利用率() {
    如果 (核数 == 0) { 返回 0 }
    定义 可变 总 = 0
    定义 可变 序号 = 0
    当 (序号 < 核数) { 总 = 总 + 负载表[序号].利用率; 序号 = 序号 + 1 }
    返回 总 * 100 / (核数 * 基数)
}

函数 负载_完整统计() {
    返回 [均值一分, 均值五分, 均值十五分, 负载_总任务(), 负载_总切换(), 负载_平均利用率(), 负载_总功耗(), 全局迁移次数, 神经均衡权重]
}

// 负载统计健康检查

函数 负载_健康检查() {
    定义 可变 问题 = []
    如果 (均值一分 > 核数 * 基数 * 2) {
        追加(问题, "1分钟负载过高")
    }
    如果 (负载_平均利用率() > 95) {
        追加(问题, "CPU利用率过高: " + 整数转字符串(负载_平均利用率()) + "%")
    }
    如果 (计数(问题) == 0) { 返回 "负载统计健康" }
    返回 问题
}

函数 负载_是否过载() {
    返回 均值一分 > 核数 * 基数
}

函数 负载_重置迁移() {
    全局迁移次数 = 0
}

函数 负载_趋势() {
    如果 (均值一分 > 均值五分) { 返回 "上升" }
    如果 (均值一分 < 均值五分) { 返回 "下降" }
    返回 "稳定"
}

函数 负载_空闲核数() {
    定义 可变 空闲 = 0
    定义 可变 i = 0
    当 (i < 核数) {
        如果 (负载表[i].利用率 < 基数 / 10) { 空闲 = 空闲 + 1 }
        i = i + 1
    }
    返回 空闲
}

导入("./函数创建.nova")
导入("./关键帧.nova")
导入("../中枢/骨骼动画.nova")
导入("./动画时间线.nova")

结构 动画档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    时间数,
    关键帧数,
    插值数,
    时间线数,
    变换数,
    预测数,
    成功数,
    失败数,
}

结构 动画请求 {
    动作,
    目标,
    参数,
    选项,
}

结构 动画回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 动画摘要 {
    名称,
    时间数,
    关键帧数,
    插值数,
    时间线数,
    变换数,
    预测数,
    成功数,
    失败数,
    健康,
}

定义 可变 动画账本 = []
定义 可变 动画构建数 = 0
定义 可变 动画总动作 = 0
定义 可变 动画总成功 = 0
定义 可变 动画总失败 = 0


函数 样式动画_建档(名称) {
    定义 档 = 动画档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.时间数 = 0
    档.关键帧数 = 0
    档.插值数 = 0
    档.时间线数 = 0
    档.变换数 = 0
    档.预测数 = 0
    档.成功数 = 0
    档.失败数 = 0
    返回 档
}

函数 样式动画_登记(档) {
    追加(动画账本, 档)
    动画构建数 = 动画构建数 + 1
    返回 档
}

函数 样式动画_完整统计() {
    返回 [
        动画构建数,
        动画总动作,
        动画总成功,
        动画总失败
    ]
}

函数 样式动画_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 动画回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 样式动画_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.失败数 > 档.成功数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (档.关键帧数 > 0 || 档.时间线数 > 0 || 档.变换数 > 0) {
        档.最近健康 = "运行"
        返回 档.最近健康
    }
    档.最近健康 = "空载"
    返回 档.最近健康
}

函数 样式动画_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    档.最近错误 = ""
    档.最近统计 = 样式动画_完整统计()
}

函数 样式动画_成功(档, 来源, 数据) {
    动画总动作 = 动画总动作 + 1
    动画总成功 = 动画总成功 + 1
    如果 (档 == 空) {
        返回 样式动画_建回证(真, 真, 来源, "", 数据, 样式动画_完整统计())
    }
    档.最近来源 = 来源
    档.最近结果 = 数据
    档.最近错误 = ""
    档.成功数 = 档.成功数 + 1
    档.最近统计 = 样式动画_完整统计()
    样式动画_刷新健康(档)
    返回 样式动画_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 样式动画_失败(档, 来源, 错因) {
    动画总动作 = 动画总动作 + 1
    动画总失败 = 动画总失败 + 1
    如果 (档 == 空) {
        返回 样式动画_建回证(真, 假, 来源, 错因, 0, 样式动画_完整统计())
    }
    档.最近来源 = 来源
    档.最近错误 = 错因
    档.失败数 = 档.失败数 + 1
    档.最近统计 = 样式动画_完整统计()
    样式动画_刷新健康(档)
    返回 样式动画_建回证(真, 假, 来源, 错因, 0, 档.最近统计)
}

函数 样式动画_初始化(档) {
    AnimationTimeline_初始化()
    档.是否初始化 = 真
    档.最近动作 = "初始化"
    档.最近来源 = "样式动画_初始化"
    档.最近统计 = 样式动画_完整统计()
    样式动画_刷新健康(档)
    返回 档
}

函数 样式动画_创建(名称) {
    定义 档 = 样式动画_建档(名称)
    样式动画_初始化(档)
    返回 样式动画_登记(档)
}

函数 样式动画_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (!档.是否初始化) { 返回 假 }
    返回 真
}

函数 样式动画_新时间函数(档, 类型) {
    如果 (!样式动画_检查档(档)) { 返回 样式动画_失败(档, "新时间函数", "动画档不可用") }
    样式动画_记录(档, "新时间函数", [类型], "时间函数")
    定义 结果 = TimingFunction_创建(类型)
    档.时间数 = 档.时间数 + 1
    返回 样式动画_成功(档, "新时间函数", 结果)
}

函数 样式动画_求值时间函数(档, 时间函数, t) {
    如果 (!样式动画_检查档(档)) { 返回 样式动画_失败(档, "求值时间函数", "动画档不可用") }
    样式动画_记录(档, "求值时间函数", [时间函数, t], "时间函数")
    定义 结果 = TimingFunction_求值(时间函数, t)
    档.时间数 = 档.时间数 + 1
    返回 样式动画_成功(档, "求值时间函数", 结果)
}

函数 样式动画_贝塞尔(档, x1, y1, x2, y2, t) {
    如果 (!样式动画_检查档(档)) { 返回 样式动画_失败(档, "贝塞尔", "动画档不可用") }
    样式动画_记录(档, "贝塞尔", [x1, y1, x2, y2, t], "时间函数")
    定义 结果 = Nova三次方Bezier_求值(x1, y1, x2, y2, t)
    档.时间数 = 档.时间数 + 1
    返回 样式动画_成功(档, "贝塞尔", 结果)
}

函数 样式动画_步进(档, 时间函数, t) {
    如果 (!样式动画_检查档(档)) { 返回 样式动画_失败(档, "步进", "动画档不可用") }
    样式动画_记录(档, "步进", [时间函数, t], "时间函数")
    定义 结果 = TimingFunction_步进求值(时间函数, t)
    档.时间数 = 档.时间数 + 1
    返回 样式动画_成功(档, "步进", 结果)
}

函数 样式动画_新效果(档, 名称, 目标, 持续时间) {
    如果 (!样式动画_检查档(档)) { 返回 样式动画_失败(档, "新效果", "动画档不可用") }
    样式动画_记录(档, "新效果", [名称, 目标, 持续时间], "关键帧")
    定义 结果 = KeyframeEffect_创建(名称, 目标, 持续时间)
    档.关键帧数 = 档.关键帧数 + 1
    返回 样式动画_成功(档, "新效果", 结果)
}

函数 样式动画_加关键帧(档, 效果, 偏移) {
    如果 (!样式动画_检查档(档)) { 返回 样式动画_失败(档, "加关键帧", "动画档不可用") }
    样式动画_记录(档, "加关键帧", [效果, 偏移], "关键帧")
    定义 结果 = KeyframeEffect_添加关键帧(效果, 偏移)
    档.关键帧数 = 档.关键帧数 + 1
    返回 样式动画_成功(档, "加关键帧", 结果)
}

函数 样式动画_加属性(档, 关键帧, 属性标识, 值类型, 数字值, 颜色值) {
    如果 (!样式动画_检查档(档)) { 返回 样式动画_失败(档, "加属性", "动画档不可用") }
    样式动画_记录(档, "加属性", [关键帧, 属性标识, 值类型, 数字值, 颜色值], "关键帧")
    定义 结果 = Keyframe_添加属性(关键帧, 属性标识, 值类型, 数字值, 颜色值)
    档.关键帧数 = 档.关键帧数 + 1
    返回 样式动画_成功(档, "加属性", 结果)
}

函数 样式动画_新动画(档, 效果) {
    如果 (!样式动画_检查档(档)) { 返回 样式动画_失败(档, "新动画", "动画档不可用") }

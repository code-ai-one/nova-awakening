// Nova标准库 — 配置管理
// 键值配置、分层配置、验证
// 支撑应用程序配置与环境管理

导入("../基础.nova")

// 键值配置
// 配置: [数据字典, 默认字典, 验证器字典]

函数 配置_创建() {
    返回 [字典(), 字典(), 字典()]
}

函数 配置_设置(配置, 键, 值) {
    字典设(配置[0], 键, 值)
}

函数 配置_获取(配置, 键) {
    定义 值 = 字典取(配置[0], 键)
    如果 (值 == 空) {
        返回 字典取(配置[1], 键)
    }
    返回 值
}

函数 配置_默认(配置, 键, 默认值) {
    字典设(配置[1], 键, 默认值)
}

函数 配置_存在(配置, 键) {
    返回 字典取(配置[0], 键) != 空
}

函数 配置_删除(配置, 键) {
    字典设(配置[0], 键, 空)
}

// 分层配置 (覆盖优先级)
// 层: [层名, 配置字典]
// 分层配置: [层列表] (后面的层优先级更高)

函数 分层配置_创建() {
    返回 [[]]
}

函数 分层_添加层(分层, 层名) {
    追加(分层[0], [层名, 字典()])
}

函数 分层_设置(分层, 层名, 键, 值) {
    定义 可变 i = 0
    当 (i < 计数(分层[0])) {
        如果 (字符串等于(分层[0][i][0], 层名)) {
            字典设(分层[0][i][1], 键, 值)
            返回
        }
        i = i + 1
    }
}

函数 分层_获取(分层, 键) {
    // 从最高优先级层开始查找
    定义 可变 i = 计数(分层[0]) - 1
    当 (i >= 0) {
        定义 值 = 字典取(分层[0][i][1], 键)
        如果 (值 != 空) { 返回 值 }
        i = i - 1
    }
    返回 空
}

// 配置构建器 (Builder Pattern)

函数 构建器_创建() {
    返回 [字典(), []]
}

函数 构建器_设(构建器, 键, 值) {
    字典设(构建器[0], 键, 值)
    返回 构建器
}

函数 构建器_必须(构建器, 键) {
    追加(构建器[1], 键)
    返回 构建器
}

函数 构建器_构建(构建器) {
    // 验证必须字段
    定义 可变 i = 0
    当 (i < 计数(构建器[1])) {
        如果 (字典取(构建器[0], 构建器[1][i]) == 空) {
            返回 ["错误", 字符串拼接("缺少必须字段: ", 构建器[1][i])]
        }
        i = i + 1
    }
    返回 ["成功", 构建器[0]]
}

// 配置解析 (简单 key=value 格式)

函数 解析配置文本(文本) {
    定义 可变 配置 = 配置_创建()
    定义 n = 计数(文本)
    定义 可变 i = 0
    定义 可变 行开始 = 0
    当 (i <= n) {
        定义 可变 是换行 = 假
        如果 (i == n) { 是换行 = 真 }
        否则 如果 (字符串等于(子串(文本, i, 1), "\n")) { 是换行 = 真 }
        如果 (是换行 且 i > 行开始) {
            定义 行 = 子串(文本, 行开始, i - 行开始)
            // 跳过注释行
            如果 (计数(行) > 0 且 字符串等于(子串(行, 0, 1), "#") == 假) {
                // 查找 = 号
                定义 可变 eq = 0
                定义 可变 _eq找到 = 假
                当 (eq < 计数(行) 且 _eq找到 == 假) {
                    如果 (子串(行, eq, 1) == "=") { _eq找到 = 真 } 否则 { eq = eq + 1 }
                }
                如果 (eq < 计数(行)) {
                    定义 键 = 子串(行, 0, eq)
                    定义 值 = 子串(行, eq + 1, 计数(行) - eq - 1)
                    配置_设置(配置, 键, 值)
                }
            }
            行开始 = i + 1
        }
        如果 (是换行) { 行开始 = i + 1 }
        i = i + 1
    }
    返回 配置
}

// 特性标志 (Feature Flags)

函数 特性标志_创建() {
    返回 [字典()]
}

函数 特性_启用(标志, 特性名) {
    字典设(标志[0], 特性名, 1)
}

函数 特性_禁用(标志, 特性名) {
    字典设(标志[0],  特性名, 0)
}

函数 特性_已启用(标志, 特性名) {
    定义 值 = 字典取(标志[0], 特性名)
    返回 值 == 1
}

函数 特性_切换(标志, 特性名) {
    如果 (特性_已启用(标志, 特性名)) {
        特性_禁用(标志, 特性名)
    } 否则 {
        特性_启用(标志, 特性名)
    }
}

// 环境变量模拟

函数 环境_创建() {
    返回 [字典()]
}

函数 环境_设(环境, 键, 值) {
    字典设(环境[0], 键, 值)
}

函数 环境_取(环境, 键) {
    返回 字典取(环境[0], 键)
}

函数 环境_取或默认(环境, 键, 缺省) {
    定义 值 = 字典取(环境[0], 键)
    如果 (值 == 空) { 返回 缺省 }
    返回 值
}

// 配置校验

定义 可变 _校验_键 = []
定义 可变 _校验_类型 = []  // "字符串"/"整数"/"布尔"

函数 配置_注册校验(键, 类型) {
    追加(_校验_键, 键)
    追加(_校验_类型, 类型)
}

函数 配置_校验(配置) {
    定义 可变 错误 = []
    定义 可变 i = 0
    当 (i < 计数(_校验_键)) {
        定义 值 = 配置_获取(配置, _校验_键[i])
        如果 (值 == 空) {
            追加(错误, "缺失键: " + _校验_键[i])
        }
        i = i + 1
    }
    返回 错误
}

// 配置监听

定义 可变 _监听_键 = []
定义 可变 _监听_回调 = []

函数 配置_监听(键, 回调) {
    追加(_监听_键, 键)
    追加(_监听_回调, 回调)
}

函数 配置_通知变更(键, 旧值, 新值) {
    定义 可变 i = 0
    当 (i < 计数(_监听_键)) {
        如果 (_监听_键[i] == 键) { _监听_回调[i](键, 旧值, 新值) }
        i = i + 1
    }
}

// 配置继承(层叠)

函数 配置_配置_合并(基础, 覆盖) {
    定义 可变 结果 = 配置_创建()
    // 先复制基础
    定义 基础键 = 字典键(基础[0])
    定义 可变 i = 0
    当 (i < 计数(基础键)) {
        配置_设置(结果, 基础键[i], 字典取(基础[0], 基础键[i]))
        i = i + 1
    }
    // 覆盖层
    定义 覆盖键 = 字典键(覆盖[0])
    i = 0
    当 (i < 计数(覆盖键)) {
        配置_设置(结果, 覆盖键[i], 字典取(覆盖[0], 覆盖键[i]))
        i = i + 1
    }
    返回 结果
}

// 配置序列化

函数 配置_导出文本(配置) {
    定义 可变 文本 = ""
    定义 键 = 字典键(配置[0])
    定义 可变 i = 0
    当 (i < 计数(键)) {
        文本 = 文本 + 键[i] + "=" + 转字符串(字典取(配置[0], 键[i])) + "\n"
        i = i + 1
    }
    返回 文本
}

函数 配置_条目数(配置) { 返回 计数(字典键(配置[0])) }

定义 可变 _配置_读数 = 0
定义 可变 _配置_写数 = 0

函数 配置_记录读() { _配置_读数 = _配置_读数 + 1 }
函数 配置_记录写() { _配置_写数 = _配置_写数 + 1 }

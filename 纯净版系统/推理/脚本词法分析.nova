// NovaOS Lexer词法分析器 — JS源码→令牌流
// 词法分析: 将JS源码字符流切分为令牌序列
// 标识符/关键字/数字/字符串/模板字面量/正则/运算符/标点
// 关键字列表(ECMAScript 2024):
// break case catch class const continue debugger default delete
// do else export extends false finally for function if import
// in instanceof let new null return static super switch this
// throw true try typeof var void while with yield async await
// 【Nova特色】AI词法预测:
// AI预测下一个令牌类型, 减少分支预测失败

导入("../中枢/系统调用表.nova")
导入("../推理/通信总线.nova")
导入("../中枢/整数转字符串.nova")
导入("../执行/控制台输出.nova")
导入("../执行/底层内存操.nova")

// §1 令牌类型

定义 TOK_EOF = 0
定义 TOK_ERROR = 1

// 字面量
定义 TOK_NUMBER = 10
定义 TOK_BIGINT = 11
定义 TOK_STRING = 12
定义 TOK_TEMPLATE_HEAD = 13 // `...${
定义 TOK_TEMPLATE_MIDDLE = 14 // }...${
定义 TOK_TEMPLATE_TAIL = 15 // }...`
定义 TOK_TEMPLATE_FULL = 16 // `...` (无插值)
定义 TOK_REGEXP = 17
定义 TOK_TRUE = 18
定义 TOK_FALSE = 19
定义 TOK_NULL = 20

// 标识符
定义 TOK_IDENTIFIER = 30
定义 TOK_PRIVATE_NAME = 31 // #name

// 关键字 (40-89)
定义 TOK_BREAK = 40
定义 TOK_CASE = 41
定义 TOK_CATCH = 42
定义 TOK_CLASS = 43
定义 TOK_CONST = 44
定义 TOK_CONTINUE = 45
定义 TOK_DEBUGGER = 46
定义 TOK_DEFAULT = 47
定义 TOK_DELETE = 48
定义 TOK_DO = 49
定义 TOK_ELSE = 50
定义 TOK_EXPORT = 51
定义 TOK_EXTENDS = 52
定义 TOK_FINALLY = 53
定义 TOK_FOR = 54
定义 TOK_FUNCTION = 55
定义 TOK_IF = 56
定义 TOK_IMPORT = 57
定义 TOK_IN = 58
定义 TOK_INSTANCEOF = 59
定义 TOK_LET = 60
定义 TOK_NEW = 61
定义 TOK_RETURN = 62
定义 TOK_STATIC = 63
定义 TOK_SUPER = 64
定义 TOK_SWITCH = 65
定义 TOK_THIS = 66
定义 TOK_THROW = 67
定义 TOK_TRY = 68
定义 TOK_TYPEOF = 69
定义 TOK_VAR = 70
定义 TOK_VOID = 71
定义 TOK_WHILE = 72
定义 TOK_WITH = 73
定义 TOK_YIELD = 74
定义 TOK_ASYNC = 75
定义 TOK_AWAIT = 76
定义 TOK_OF = 77

// 标点/运算符 (100+)
定义 TOK_LPAREN = 100 // (
定义 TOK_RPAREN = 101 // )
定义 TOK_LBRACE = 102 // {
定义 TOK_RBRACE = 103 // }
定义 TOK_LBRACKET = 104 // [
定义 TOK_RBRACKET = 105 // ]
定义 TOK_SEMICOLON = 106 // ;
定义 TOK_COMMA = 107 // ,
定义 TOK_DOT = 108 // .
定义 TOK_ELLIPSIS = 109 // ...
定义 TOK_OPTIONAL_CHAIN = 110 // ?.
定义 TOK_COLON = 111 // :
定义 TOK_QUESTION = 112 // ?
定义 TOK_NULLISH = 113 // ??
定义 TOK_ARROW = 114 // =>

// 赋值
定义 TOK_ASSIGN = 120 // =
定义 TOK_ADD_ASSIGN = 121 // +=
定义 TOK_SUB_ASSIGN = 122 // -=
定义 TOK_MUL_ASSIGN = 123 // *=
定义 TOK_DIV_ASSIGN = 124 // /=
定义 TOK_MOD_ASSIGN = 125 // %=
定义 TOK_EXP_ASSIGN = 126 // **=
定义 TOK_AND_ASSIGN = 127 // &=
定义 TOK_OR_ASSIGN = 128 // |=
定义 TOK_XOR_ASSIGN = 129 // ^=
定义 TOK_SHL_ASSIGN = 130 // <<=
定义 TOK_SHR_ASSIGN = 131 // >>=
定义 TOK_USHR_ASSIGN = 132 // >>>=
定义 TOK_NULLISH_ASSIGN = 133 // ??=
定义 TOK_AND_LOGIC_ASSIGN = 134 // &&=
定义 TOK_OR_LOGIC_ASSIGN = 135 // ||=

// 算术
定义 TOK_ADD = 140 // +
定义 TOK_SUB = 141 // -
定义 TOK_MUL = 142 // *
定义 TOK_DIV = 143 // /
定义 TOK_MOD = 144 // %
定义 TOK_EXP = 145 // **
定义 TOK_INC = 146 // ++
定义 TOK_DEC = 147 // --

// 比较
定义 TOK_EQ = 150 // ==
定义 TOK_NE = 151 // !=
定义 TOK_SEQ = 152 // ===
定义 TOK_SNE = 153 // !==
定义 TOK_LT = 154 // <
定义 TOK_GT = 155 // >
定义 TOK_LE = 156 // <=
定义 TOK_GE = 157 // >=

// 逻辑
定义 TOK_AND = 160 // &&
定义 TOK_OR = 161 // ||
定义 TOK_NOT = 162 // !

// 位运算
定义 TOK_BIT_AND = 170 // &
定义 TOK_BIT_OR = 171 // |
定义 TOK_BIT_XOR = 172 // ^
定义 TOK_BIT_NOT = 173 // ~
定义 TOK_SHL = 174 // <<
定义 TOK_SHR = 175 // >>
定义 TOK_USHR = 176 // >>>

// §2 词法分析器结构

结构 令牌 {
    类型,
    起始,
    长度,
    行号,
    列号,
    值,
}

结构 词法器 {
    源码,
    源码长度,
    位置,
    行号,
    列号,
    令牌列表,
    令牌数,
    错误数,
}

函数 词法器_创建(源码, 长度) {
    定义 lex = 词法器 {}
    lex.源码 = 源码
    lex.源码长度 = 长度
    lex.位置 = 0
    lex.行号 = 1
    lex.列号 = 1
    lex.令牌列表 = []
    lex.令牌数 = 0
    lex.错误数 = 0
    返回 lex
}

函数 词法器_销毁(lex) {
    lex.源码 = 0
    lex.令牌列表 = []
    lex.令牌数 = 0
}

// §3 字符分类辅助

函数 词法_是空白(ch) {
    返回 ch == 32 || ch == 9 || ch == 11 || ch == 12 || ch == 0xA0
}

函数 词法_是换行(ch) {
    返回 ch == 10 || ch == 13
}

函数 词法_是数字(ch) {
    返回 ch >= 48 && ch <= 57
}

函数 词法_是十六进制(ch) {
    返回 (ch >= 48 && ch <= 57) || (ch >= 65 && ch <= 70) || (ch >= 97 && ch <= 102)
}

函数 词法_是八进制(ch) {
    返回 ch >= 48 && ch <= 55
}

函数 词法_是二进制(ch) {
    返回 ch == 48 || ch == 49
}

函数 词法_是字母(ch) {
    返回 (ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122)
}

函数 词法_是标识符开头(ch) {
    返回 词法_是字母(ch) || ch == 95 || ch == 36 || ch > 127
}

函数 词法_是标识符字符(ch) {
    返回 词法_是标识符开头(ch) || 词法_是数字(ch)
}

// §4 基础读取

函数 词法_当前字符(lex) {
    如果 (lex.位置 >= lex.源码长度) { 返回 0 }
    返回 字节取(lex.源码, lex.位置)
}

函数 词法_前看(lex, 偏移) {
    定义 位 = lex.位置 + 偏移
    如果 (位 >= lex.源码长度) { 返回 0 }
    返回 字节取(lex.源码, 位)
}

函数 词法_前进(lex) {
    如果 (lex.位置 < lex.源码长度) {
        定义 ch = 字节取(lex.源码, lex.位置)
        如果 (ch == 10) { lex.行号 = lex.行号 + 1; lex.列号 = 1 }
        否则 { lex.列号 = lex.列号 + 1 }
        lex.位置 = lex.位置 + 1
    }
}

函数 词法_是结尾(lex) {
    返回 lex.位置 >= lex.源码长度
}

函数 词法_创建令牌(lex, 类型, 起始, 长度) {
    定义 tok = 令牌 {}
    tok.类型 = 类型
    tok.起始 = 起始
    tok.长度 = 长度
    tok.行号 = lex.行号
    tok.列号 = lex.列号
    tok.值 = 0
    返回 tok
}

函数 词法_添加令牌(lex, tok) {
    追加(lex.令牌列表, tok)
    lex.令牌数 = lex.令牌数 + 1
}

// §5 跳过空白与注释

函数 词法_跳过空白(lex) {
    当 (!词法_是结尾(lex)) {
        定义 ch = 词法_当前字符(lex)
        如果 (词法_是空白(ch) || 词法_是换行(ch)) {
            词法_前进(lex)
        } 否则 如果 (ch == 47) {
            定义 下一个 = 词法_前看(lex, 1)
            如果 (下一个 == 47) {
                词法_跳过单行注释(lex)
            } 否则 如果 (下一个 == 42) {
                词法_跳过多行注释(lex)
            } 否则 { 返回 }
        } 否则 { 返回 }
    }
}

函数 词法_跳过单行注释(lex) {
    当 (!词法_是结尾(lex) && !词法_是换行(词法_当前字符(lex))) {
        词法_前进(lex)
    }
}

函数 词法_跳过多行注释(lex) {
    词法_前进(lex)
    词法_前进(lex)
    当 (!词法_是结尾(lex)) {
        如果 (词法_当前字符(lex) == 42 && 词法_前看(lex, 1) == 47) {
            词法_前进(lex)
            词法_前进(lex)
            返回
        }
        词法_前进(lex)
    }
    lex.错误数 = lex.错误数 + 1
}

// §6 扫描数字

函数 词法_扫描数字(lex) {
    定义 起始 = lex.位置
    定义 ch = 词法_当前字符(lex)

    如果 (ch == 48) {
        词法_前进(lex)
        定义 下一个 = 词法_当前字符(lex)
        如果 (下一个 == 120 || 下一个 == 88) {
            词法_前进(lex)
            当 (!词法_是结尾(lex) && 词法_是十六进制(词法_当前字符(lex))) {
                词法_前进(lex)
            }
        } 否则 如果 (下一个 == 98 || 下一个 == 66) {
            词法_前进(lex)
            当 (!词法_是结尾(lex) && 词法_是二进制(词法_当前字符(lex))) {
                词法_前进(lex)
            }
        } 否则 如果 (下一个 == 111 || 下一个 == 79) {
            词法_前进(lex)
            当 (!词法_是结尾(lex) && 词法_是八进制(词法_当前字符(lex))) {
                词法_前进(lex)
            }
        } 否则 {
            当 (!词法_是结尾(lex) && 词法_是数字(词法_当前字符(lex))) {
                词法_前进(lex)
            }
        }
    } 否则 {
        当 (!词法_是结尾(lex) && 词法_是数字(词法_当前字符(lex))) {
            词法_前进(lex)
        }
    }

    如果 (!词法_是结尾(lex) && 词法_当前字符(lex) == 46) {
        词法_前进(lex)
        当 (!词法_是结尾(lex) && 词法_是数字(词法_当前字符(lex))) {
            词法_前进(lex)
        }
    }

    如果 (!词法_是结尾(lex)) {
        定义 e = 词法_当前字符(lex)
        如果 (e == 101 || e == 69) {
            词法_前进(lex)
            如果 (!词法_是结尾(lex) && (词法_当前字符(lex) == 43 || 词法_当前字符(lex) == 45)) {
                词法_前进(lex)
            }
            当 (!词法_是结尾(lex) && 词法_是数字(词法_当前字符(lex))) {
                词法_前进(lex)
            }
        }
    }

    定义 类型 = TOK_NUMBER
    如果 (!词法_是结尾(lex) && 词法_当前字符(lex) == 110) {
        词法_前进(lex)
        类型 = TOK_BIGINT
    }

    返回 词法_创建令牌(lex, 类型, 起始, lex.位置 - 起始)
}

// §7 扫描字符串

函数 词法_扫描字符串(lex, 引号) {
    定义 起始 = lex.位置
    词法_前进(lex)
    当 (!词法_是结尾(lex)) {
        定义 ch = 词法_当前字符(lex)
        如果 (ch == 引号) { 词法_前进(lex); 跳出 }
        如果 (ch == 92) { 词法_前进(lex) }
        如果 (词法_是换行(ch)) { lex.错误数 = lex.错误数 + 1; 跳出 }
        词法_前进(lex)
    }
    返回 词法_创建令牌(lex, TOK_STRING, 起始, lex.位置 - 起始)
}

// §8 扫描标识符与关键字

函数 词法_扫描标识符(lex) {
    定义 起始 = lex.位置
    当 (!词法_是结尾(lex) && 词法_是标识符字符(词法_当前字符(lex))) {
        词法_前进(lex)
    }
    定义 长度 = lex.位置 - 起始
    定义 tok = 词法_创建令牌(lex, TOK_IDENTIFIER, 起始, 长度)
    词法_检查关键字(lex.源码 + 起始, 长度, tok)
    返回 tok
}

函数 词法_检查关键字(名, 长度, tok) {
    如果 (长度 == 2) {
        如果 (字符串_等于N(名, 长度, "if")) { tok.类型 = TOK_IF }
        否则 如果 (字符串_等于N(名, 长度, "in")) { tok.类型 = TOK_IN }
        否则 如果 (字符串_等于N(名, 长度, "do")) { tok.类型 = TOK_DO }
        否则 如果 (字符串_等于N(名, 长度, "of")) { tok.类型 = TOK_OF }
    } 否则 如果 (长度 == 3) {
        如果 (字符串_等于N(名, 长度, "var")) { tok.类型 = TOK_VAR }
        否则 如果 (字符串_等于N(名, 长度, "let")) { tok.类型 = TOK_LET }
        否则 如果 (字符串_等于N(名, 长度, "new")) { tok.类型 = TOK_NEW }
        否则 如果 (字符串_等于N(名, 长度, "for")) { tok.类型 = TOK_FOR }
        否则 如果 (字符串_等于N(名, 长度, "try")) { tok.类型 = TOK_TRY }
    } 否则 如果 (长度 == 4) {
        如果 (字符串_等于N(名, 长度, "this")) { tok.类型 = TOK_THIS }
        否则 如果 (字符串_等于N(名, 长度, "true")) { tok.类型 = TOK_TRUE }
        否则 如果 (字符串_等于N(名, 长度, "null")) { tok.类型 = TOK_NULL }
        否则 如果 (字符串_等于N(名, 长度, "else")) { tok.类型 = TOK_ELSE }
        否则 如果 (字符串_等于N(名, 长度, "case")) { tok.类型 = TOK_CASE }
        否则 如果 (字符串_等于N(名, 长度, "void")) { tok.类型 = TOK_VOID }
        否则 如果 (字符串_等于N(名, 长度, "with")) { tok.类型 = TOK_WITH }
    } 否则 如果 (长度 == 5) {
        如果 (字符串_等于N(名, 长度, "break")) { tok.类型 = TOK_BREAK }
        否则 如果 (字符串_等于N(名, 长度, "catch")) { tok.类型 = TOK_CATCH }
        否则 如果 (字符串_等于N(名, 长度, "class")) { tok.类型 = TOK_CLASS }
        否则 如果 (字符串_等于N(名, 长度, "const")) { tok.类型 = TOK_CONST }
        否则 如果 (字符串_等于N(名, 长度, "super")) { tok.类型 = TOK_SUPER }
        否则 如果 (字符串_等于N(名, 长度, "throw")) { tok.类型 = TOK_THROW }
        否则 如果 (字符串_等于N(名, 长度, "while")) { tok.类型 = TOK_WHILE }
        否则 如果 (字符串_等于N(名, 长度, "yield")) { tok.类型 = TOK_YIELD }
        否则 如果 (字符串_等于N(名, 长度, "await")) { tok.类型 = TOK_AWAIT }
        否则 如果 (字符串_等于N(名, 长度, "async")) { tok.类型 = TOK_ASYNC }
        否则 如果 (字符串_等于N(名, 长度, "false")) { tok.类型 = TOK_FALSE }
    } 否则 如果 (长度 == 6) {
        如果 (字符串_等于N(名, 长度, "return")) { tok.类型 = TOK_RETURN }
        否则 如果 (字符串_等于N(名, 长度, "switch")) { tok.类型 = TOK_SWITCH }
        否则 如果 (字符串_等于N(名, 长度, "typeof")) { tok.类型 = TOK_TYPEOF }
        否则 如果 (字符串_等于N(名, 长度, "delete")) { tok.类型 = TOK_DELETE }
        否则 如果 (字符串_等于N(名, 长度, "export")) { tok.类型 = TOK_EXPORT }
        否则 如果 (字符串_等于N(名, 长度, "import")) { tok.类型 = TOK_IMPORT }
        否则 如果 (字符串_等于N(名, 长度, "static")) { tok.类型 = TOK_STATIC }
    } 否则 如果 (长度 == 7) {
        如果 (字符串_等于N(名, 长度, "default")) { tok.类型 = TOK_DEFAULT }
        否则 如果 (字符串_等于N(名, 长度, "extends")) { tok.类型 = TOK_EXTENDS }
        否则 如果 (字符串_等于N(名, 长度, "finally")) { tok.类型 = TOK_FINALLY }
    } 否则 如果 (长度 == 8) {
        如果 (字符串_等于N(名, 长度, "continue")) { tok.类型 = TOK_CONTINUE }
        否则 如果 (字符串_等于N(名, 长度, "debugger")) { tok.类型 = TOK_DEBUGGER }
        否则 如果 (字符串_等于N(名, 长度, "function")) { tok.类型 = TOK_FUNCTION }
    } 否则 如果 (长度 == 10) {
        如果 (字符串_等于N(名, 长度, "instanceof")) { tok.类型 = TOK_INSTANCEOF }
    }
}

// §9 令牌类型名称

函数 词法_令牌类型名(类型) {
    如果 (类型 == TOK_EOF) { 返回 "EOF" }
    如果 (类型 == TOK_ERROR) { 返回 "ERROR" }
    如果 (类型 == TOK_NUMBER) { 返回 "NUMBER" }
    如果 (类型 == TOK_BIGINT) { 返回 "BIGINT" }
    如果 (类型 == TOK_STRING) { 返回 "STRING" }
    如果 (类型 == TOK_IDENTIFIER) { 返回 "IDENTIFIER" }
    如果 (类型 == TOK_REGEXP) { 返回 "REGEXP" }
    如果 (类型 >= TOK_BREAK && 类型 <= TOK_OF) { 返回 "KEYWORD" }
    如果 (类型 >= TOK_LPAREN && 类型 <= TOK_ARROW) { 返回 "PUNCTUATOR" }
    如果 (类型 >= TOK_ASSIGN && 类型 <= TOK_OR_LOGIC_ASSIGN) { 返回 "ASSIGNMENT" }
    如果 (类型 >= TOK_ADD && 类型 <= TOK_DEC) { 返回 "ARITHMETIC" }
    如果 (类型 >= TOK_EQ && 类型 <= TOK_GE) { 返回 "COMPARISON" }
    如果 (类型 >= TOK_AND && 类型 <= TOK_NOT) { 返回 "LOGICAL" }
    如果 (类型 >= TOK_BIT_AND && 类型 <= TOK_USHR) { 返回 "BITWISE" }
    返回 "UNKNOWN"
}

// §10 词法分析统计与健康检查

定义 可变 词法_分析总次数 = 0
定义 可变 词法_总令牌数 = 0
定义 可变 词法_总错误数 = 0
定义 可变 词法_关键字数 = 0
定义 可变 词法_标识符数 = 0
定义 可变 词法_数字数 = 0
定义 可变 词法_字符串数 = 0

函数 词法_统计() {
    返回 {
        分析次数: 词法_分析总次数,
        总令牌: 词法_总令牌数,
        总错误: 词法_总错误数,
        关键字: 词法_关键字数,
        标识符: 词法_标识符数,
        数字: 词法_数字数,
        字符串: 词法_字符串数,
    }
}

函数 词法_健康检查() {
    定义 可变 问题 = []
    如果 (词法_总错误数 > 词法_总令牌数 / 10 && 词法_总令牌数 > 100) {
        追加(问题, "词法错误率过高: " + 整数转字符串(词法_总错误数))
    }
    如果 (计数(问题) == 0) { 返回 "词法分析器健康" }
    返回 问题
}

函数 词法_重置统计() {
    词法_分析总次数 = 0
    词法_总令牌数 = 0
    词法_总错误数 = 0
    词法_关键字数 = 0
    词法_标识符数 = 0
    词法_数字数 = 0
    词法_字符串数 = 0
}

函数 词法_完整统计() {
    返回 [词法_分析总次数, 词法_总令牌数, 词法_总错误数]
}

// Nova · 编译器 · 项目系统 · 渲染合同 (M12)
// 渲染子系统的编译期契约: 帧预算、管线阶段、资源绑定、同步点
// 编译器验证渲染模块是否满足合同约束

// 渲染合同字段
// [帧预算ms, 管线阶段数, 最大绘制调用, 最大纹理绑定, 需要深度, 需要模板, 多重采样, MSAA级别]

导入("../../标准库/基础.nova")
导入("../../标准库/转换器/转换验证.nova")

函数 项目_渲染合同_创建(帧预算ms) {
    返回 [帧预算ms, 0, 0, 假, 假, 假, 0]
}

函数 渲染合同_帧预算(c) { 返回 c[0] }
函数 渲染合同_管线阶段数(c) { 返回 c[1] }
函数 渲染合同_最大绘制调用(c) { 返回 c[2] }
函数 渲染合同_最大纹理绑定(c) { 返回 c[3] }
函数 渲染合同_设管线阶段(c, n) { c[1] = n }
函数 渲染合同_设最大绘制调用(c, n) { c[2] = n }
函数 渲染合同_设最大纹理绑定(c, n) { c[3] = n }
函数 渲染合同_设深度(c) { c[4] = 真 }
函数 渲染合同_设模板(c) { c[5] = 真 }
函数 渲染合同_设MSAA(c, 级别) { c[6] = 真  c[7] = 级别 }

// 管线阶段描述
// [阶段名, 着色器类型, 输入数, 输出数, 是否可选]
定义 阶段_顶点 = 0
定义 阶段_片段 = 1
定义 阶段_几何 = 2
定义 阶段_曲面细分 = 3
定义 阶段_计算 = 4

函数 管线阶段_创建(阶段名, 类型, 输入数, 输出数, 可选) {
    返回 [阶段名, 类型, 输入数, 输出数, 可选]
}

// 渲染合同验证
// 验证模块的渲染函数是否满足合同约束
定义 可变 _渲染验证_通过数 = 0
定义 可变 _渲染验证_违规数 = 0
定义 可变 _渲染验证_检查数 = 0

函数 渲染合同_验证(合同, 函数列) {
    _渲染验证_检查数 = 0
    _渲染验证_通过数 = 0
    _渲染验证_违规数 = 0
    如果 (合同 == 空 或 函数列 == 空) { 返回 0 }
    定义 可变 fi = 0
    当 (fi < 计数(函数列)) {
        如果 (是列表(函数列[fi]) 且 计数(函数列[fi]) >= 4) {
            定义 名 = 函数列[fi][1]
            // 检测渲染相关函数(名称包含"渲染"或"绘制")
            如果 (字符串包含(名, "渲染") 或 字符串包含(名, "绘制") 或 字符串包含(名, "帧")) {
                _渲染验证_检查数 = _渲染验证_检查数 + 1
                // 扫描函数体中的绘制调用数
                定义 体 = 函数列[fi][3]
                定义 调用数 = _渲染_计数调用(体)
                如果 (渲染合同_最大绘制调用(合同) > 0 且 调用数 > 渲染合同_最大绘制调用(合同)) {
                    _渲染验证_违规数 = _渲染验证_违规数 + 1
                } 否则 {
                    _渲染验证_通过数 = _渲染验证_通过数 + 1
                }
            }
        }
        fi = fi + 1
    }
    返回 _渲染验证_违规数
}

函数 _渲染_计数调用(体) {
    如果 (是列表(体) == 假) { 返回 0 }
    定义 可变 数量 = 0
    定义 可变 i = 0
    当 (i < 计数(体)) {
        如果 (是列表(体[i]) 且 计数(体[i]) >= 1) {
            如果 (体[i][0] == 节点_列表) { 数量 = 数量 + 1 }
        }
        i = i + 1
    }
    返回 数量
}

// 渲染报告
函数 渲染合同_打印报告(合同) {
    打印文本("═══ 渲染合同报告 (M12) ═══")
    如果 (合同 != 空) {
        打印文本(字符串拼接("  帧预算: ", 字符串拼接(转字符串(渲染合同_帧预算(合同)), "ms")))
        打印文本(字符串拼接("  管线阶段: ", 转字符串(渲染合同_管线阶段数(合同))))
        打印文本(字符串拼接("  最大绘制调用: ", 转字符串(渲染合同_最大绘制调用(合同))))
        打印文本(字符串拼接("  最大纹理绑定: ", 转字符串(渲染合同_最大纹理绑定(合同))))
    }
    打印文本(字符串拼接("  验证检查数: ", 转字符串(_渲染验证_检查数)))
    打印文本(字符串拼接("  验证通过: ", 转字符串(_渲染验证_通过数)))
    打印文本(字符串拼接("  验证违规: ", 转字符串(_渲染验证_违规数)))
}

函数 渲染合同_结构化报告() {
    定义 报告 = 字典()
    字典设(报告, "渲染_检查数", 转字符串(_渲染验证_检查数))
    字典设(报告, "渲染_通过数", 转字符串(_渲染验证_通过数))
    字典设(报告, "渲染_违规数", 转字符串(_渲染验证_违规数))
    返回 报告
}

// Profile关联: 不同profile的渲染预算不同
函数 渲染合同_从Profile(profile) {
    如果 (profile == "analysis-host") {
        // 分析模式: 无渲染限制
        返回 项目_渲染合同_创建(0)
    }
    如果 (profile == "kernel-qemu") {
        // QEMU内核: 帧缓冲直写, 16ms预算
        定义 c = 项目_渲染合同_创建(16)
        渲染合同_设管线阶段(c, 1)
        渲染合同_设最大绘制调用(c, 1000)
        返回 c
    }
    如果 (profile == "kernel-physical") {
        // 物理机内核: 帧缓冲直写, 8ms预算(更严格)
        定义 c = 项目_渲染合同_创建(8)
        渲染合同_设管线阶段(c, 2)
        渲染合同_设最大绘制调用(c, 500)
        渲染合同_设深度(c)
        返回 c
    }
    如果 (profile == "linux-user") {
        // 用户态: 完整管线, 16ms预算
        定义 c = 项目_渲染合同_创建(16)
        渲染合同_设管线阶段(c, 5)
        渲染合同_设最大绘制调用(c, 10000)
        渲染合同_设最大纹理绑定(c, 32)
        渲染合同_设深度(c)
        渲染合同_设MSAA(c, 4)
        返回 c
    }
    返回 项目_渲染合同_创建(16)
}

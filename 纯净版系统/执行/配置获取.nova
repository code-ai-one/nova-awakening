导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./动态调整.nova")
导入("./配置初始化.nova")

    cfg.总物理内存MB = 平台_检测内存MB()
    如果 (cfg.总物理内存MB == 0) { cfg.总物理内存MB = 4096 }
    // 按总内存比例分配
    如果 (cfg.总物理内存MB >= 8192) {
        // 8GB+: 充裕
        cfg.JS堆上限MB = 4096; cfg.图片缓存MB = 512
        cfg.图处纹理缓存MB = 256; cfg.网络缓存MB = 256
    } 否则 如果 (cfg.总物理内存MB >= 4096) {
        // 4GB: 标准
        cfg.JS堆上限MB = 2048; cfg.图片缓存MB = 256
        cfg.图处纹理缓存MB = 128; cfg.网络缓存MB = 128
    } 否则 如果 (cfg.总物理内存MB >= 2048) {
        // 2GB: 受限
        cfg.JS堆上限MB = 1024; cfg.图片缓存MB = 128
        cfg.图处纹理缓存MB = 64; cfg.网络缓存MB = 64
    } 否则 {
        // <2GB: 极限
        cfg.JS堆上限MB = 512; cfg.图片缓存MB = 64
        cfg.图处纹理缓存MB = 32; cfg.网络缓存MB = 32
    }

    cfg.最大并发连接 = 6; cfg.域名超时ms = 5000
    cfg.连接超时ms = 30000; cfg.安全会话缓存大小 = 1024
    cfg.HTTP2最大流 = 100

    cfg.最大层数 = 256
    cfg.最大纹理尺寸 = 平台_检测图处最大纹理()
    如果 (cfg.最大纹理尺寸 == 0) { cfg.最大纹理尺寸 = 8192 }
    cfg.图处加速 = 平台_检测图处可用()
    cfg.图绘启用 = cfg.图处加速; cfg.Web图处启用 = 假

    cfg.沙箱启用 = 真; cfg.站点隔离 = 真
    cfg.HSTS启用 = 真; cfg.CT启用 = 真

    cfg.AI启用 = 真; cfg.AI模型路径 = "/usr/share/nova/ai/browser_model.gguf"
    cfg.AI推理线程数 = 2; cfg.AI最大内存MB = 256

    cfg.设备性能评分 = Config_评估性能(cfg)
    cfg.省电模式 = 假
    cfg.低端设备 = (cfg.设备性能评分 < 40)

    全局配置 = cfg
    返回 cfg
}

// §3 公共访问接口(所有模块使用这些函数)

函数 Config_获取() {
    如果 (全局配置 == 0) { Config_初始化() }
    返回 全局配置
}

函数 Config_视口宽() {
    定义 c = Config_获取(); 如果(c==0){返回 1920}; 返回 c.视口宽
}
函数 Config_视口高() {
    定义 c = Config_获取(); 如果(c==0){返回 1080}; 返回 c.视口高
}
函数 Config_视口宽Q10() {
    返回 Config_视口宽() * 1024
}
函数 Config_视口高Q10() {
    返回 Config_视口高() * 1024
}
函数 Config_设备像素比() {
    定义 c = Config_获取(); 如果(c==0){返回 1024}; 返回 c.设备像素比
}
函数 Config_目标帧率() {
    定义 c = Config_获取(); 如果(c==0){返回 60}; 返回 c.目标帧率
}
函数 Config_帧预算ms() {
    定义 c = Config_获取(); 如果(c==0){返回 16}; 返回 c.帧预算us / 1000
}
函数 Config_音频采样率() {
    定义 c = Config_获取(); 如果(c==0){返回 48000}; 返回 c.音频采样率
}
函数 Config_音频声道数() {
    定义 c = Config_获取(); 如果(c==0){返回 2}; 返回 c.音频声道数
}
函数 Config_JS堆上限MB() {
    定义 c = Config_获取(); 如果(c==0){返回 2048}; 返回 c.JS堆上限MB
}
函数 Config_图处加速() {
    定义 c = Config_获取(); 如果(c==0){返回 真}; 返回 c.图处加速
}
函数 Config_沙箱启用() {
    定义 c = Config_获取(); 如果(c==0){返回 真}; 返回 c.沙箱启用
}
函数 Config_AI启用() {
    定义 c = Config_获取(); 如果(c==0){返回 真}; 返回 c.AI启用
}
函数 Config_低端设备() {
    定义 c = Config_获取(); 如果(c==0){返回 假}; 返回 c.低端设备
}
函数 Config_最大并发连接() {
    定义 c = Config_获取(); 如果(c==0){返回 6}; 返回 c.最大并发连接

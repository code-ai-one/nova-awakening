导入("../基础.nova")
导入("../并发/线程/线程池.nova")


// 少样本任务
// N-way K-shot: N个类, 每类K个支持样本, Q个查询样本
// 任务: [支持集特征, 支持集标签, 查询集特征, 查询集标签, N, K]
函数 元学习_任务_创建(N, K) { 返回 [[], [], [], [], N, K]
}

函数 任务_添加支持(任务, 特征, 标签) {
 追加(任务[0], 特征)
 追加(任务[1], 标签)
}

函数 任务_添加查询(任务, 特征, 标签) {
 追加(任务[2], 特征)
 追加(任务[3], 标签)
}

函数 任务_支持数(任务) { 返回 计数(任务[0]) }
函数 任务_查询数(任务) { 返回 计数(任务[2]) }

// Prototypical Networks
// 计算每类原型 = 支持集中该类样本的均值
函数 原型_计算(任务, 特征维度) { 定义 N = 任务[4]
 定义 可变 原型 = []
 定义 可变 c = 0
 当 (c < N) { 定义 可变 均值 = []
 定义 可变 k = 0
 当 (k < 特征维度) { 追加(均值, 0)
 k = k + 1 }
 定义 可变 数量 = 0
 定义 可变 i = 0
 当 (i < 计数(任务[1])) { 如果 (任务[1][i] == c) {
 k = 0
 当 (k < 特征维度) { 如果 (k < 计数(任务[0][i])) { 均值[k] = 均值[k] + 任务[0][i][k] }
 k = k + 1
 }
 数量 = 数量 + 1
 }
 i = i + 1
 }
 如果 (数量 > 0) {
 k = 0
 如果 (数量 == 0) { 数量 = 1 }
 当 (k < 特征维度) { 均值[k] = 均值[k] / 数量
 k = k + 1 }
 }
 追加(原型, 均值)
 c = c + 1
 }
 返回 原型
}

// 欧氏距离
函数 原型_距离(a, b) { 定义 n = 计数(a)
 定义 可变 距离 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 bv = 0
 如果 (i < 计数(b)) { bv = b[i] }
 定义 d = a[i] - bv
 距离 = 距离 + d * d / 1000
 i = i + 1
 }
 返回 距离
}

// 分类: 找最近原型
函数 原型_分类(查询特征, 原型列表) { 定义 N = 计数(原型列表)
 定义 可变 最近类 = 0
 定义 可变 最近距 = 原型_距离(查询特征, 原型列表[0])
 定义 可变 c = 1
 当 (c < N) { 定义 d = 原型_距离(查询特征, 原型列表[c])
 如果 (d < 最近距) { 最近类 = c
 最近距 = d }
 c = c + 1
 }
 返回 最近类
}

// 评估准确率
函数 原型_评估(任务, 原型列表) { 定义 查询数 = 计数(任务[2])
 定义 可变 i = 0
 当 (i < 查询数) { 定义 预测 = 原型_分类(任务[2][i], 原型列表)
 如果 (预测 == 任务[3][i]) { 正确 = 正确 + 1 }
 i = i + 1
 }
 如果 (查询数 == 0) { 返回 0 }
 返回 正确 * 1000 / 查询数
}

// MAML: 模型无关元学习
// 参数: flat权重向量, 内循环lr, 外循环lr
函数 元学习_MAML_内循环(参数, 梯度, 内lr, 步数) { 定义 n = 计数(参数)
 定义 可变 θ_prime = []
 定义 可变 i = 0
 当 (i < n) { 追加(θ_prime, 参数[i])
 i = i + 1 }
 // K步梯度下降
 定义 可变 步长 = 0
 当 (步长 < 步数) {
 i = 0
 当 (i < n) { 如果 (i < 计数(梯度)) {
 θ_prime[i] = θ_prime[i] - 内lr * 梯度[i] / 1000
 }
 i = i + 1
 }
 步长 = 步长 + 1
 }
 返回 θ_prime
}

函数 MAML_外循环更新(参数, 元梯度列表, 外lr) { 定义 n = 计数(参数)
 定义 任务数 = 计数(元梯度列表)
 如果 (任务数 == 0) { 返回 }
 定义 可变 i = 0
 当 (i < n) { 定义 可变 平均梯度 = 0
 定义 可变 t = 0
 当 (t < 任务数) { 如果 (i < 计数(元梯度列表[t])) {
 平均梯度 = 平均梯度 + 元梯度列表[t][i]
 }
 t = t + 1
 }
 平均梯度 = 平均梯度 / 任务数
 参数[i] = 参数[i] - 外lr * 平均梯度 / 1000
 i = i + 1
 }
}

// Reptile
// 更简单的元学习: θ ← θ + ε·(θ' - θ)
函数 Reptile_更新(参数, 适应参数, ε) { 定义 n = 计数(参数)
 定义 可变 i = 0
 当 (i < n) { 如果 (i < 计数(适应参数)) {
 参数[i] = 参数[i] + ε * (适应参数[i] - 参数[i]) / 1000
 }
 i = i + 1
 }
}

函数 Reptile_批量更新(参数, 适应参数列表, ε) { 定义 n = 计数(参数)
 定义 任务数 = 计数(适应参数列表)
 如果 (任务数 == 0) { 返回 }
 定义 可变 i = 0
 当 (i < n) { 定义 可变 平均diff = 0
 定义 可变 t = 0
 当 (t < 任务数) { 如果 (i < 计数(适应参数列表[t])) {
 平均diff = 平均diff + (适应参数列表[t][i] - 参数[i])
 }
 t = t + 1
 }
 参数[i] = 参数[i] + ε * 平均diff / (任务数 * 1000)
 i = i + 1
 }
}

// Meta-SGD
// 学习率也是可学习参数
函数 MetaSGD_内循环(参数, 梯度, 学习率向量) { 定义 n = 计数(参数)
 定义 可变 θ_prime = []
 定义 可变 i = 0
 当 (i < n) { 定义 可变 lr = 10 // 默认
 如果 (i < 计数(学习率向量)) { lr = 学习率向量[i] }
 定义 可变 g = 0
 如果 (i < 计数(梯度)) { g = 梯度[i] }
 追加(θ_prime, 参数[i] - lr * g / 1000)
 i = i + 1
 }
 返回 θ_prime
}

// 任务采样
定义 元_随机态 = 54321
函数 元_随机() {
 元_随机态 = 元_随机态 ^ (元_随机态 << 13)
 元_随机态 = 元_随机态 ^ (元_随机态 >> 7)
 元_随机态 = 元_随机态 ^ (元_随机态 << 17)
 如果 (元_随机态 < 0) { 元_随机态 = 0 - 元_随机态 }
 返回 元_随机态
}

函数 任务_采样(所有特征, 所有标签, 类别数, N, K, Q) { 定义 任务 = 任务_创建(N,  K, 0)
 // 随机选N个类
 定义 可变 选类 = []
 定义 可变 i = 0
 当 (i < N) { 定义 c = 元_随机() % 类别数
 追加(选类, c)
 i = i + 1
 }
 // 为每个选中的类选K+Q个样本
 i = 0
 当 (i < N) { 定义 c = 选类[i]
 定义 可变 类样本 = []
 定义 可变 j = 0
 当 (j < 计数(所有标签)) { 如果 (所有标签[j] == c) { 追加(类样本, j) }
 j = j + 1
 }
 // 取前K个为支持集, 后Q个为查询集
 j = 0
 当 (j < K 且 j < 计数(类样本)) {
 任务_添加支持(任务, 所有特征[类样本[j]], i)
 j = j + 1
 }
 当 (j < K + Q 且 j < 计数(类样本)) {
 任务_添加查询(任务, 所有特征[类样本[j]], i)
 j = j + 1
 }
 i = i + 1
 }
 返回 任务
}

// 元测试
函数 元测试_评估(任务列表, 特征维度) { 定义 T = 计数(任务列表)
 定义 可变 总准确率 = 0
 定义 可变 i = 0
 当 (i < T) { 定义 原型 = 原型_计算(任务列表[i], 特征维度)
 总准确率 = 总准确率 + 原型_评估(任务列表[i], 原型)
 i = i + 1
 }
 如果 (T == 0) { 返回 0 }
 返回 总准确率 / T
}

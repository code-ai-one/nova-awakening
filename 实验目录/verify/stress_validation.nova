    ]
    如果 (!压力验证_序列不下降("链式回溯", 链式_交叉, "验证回溯交叉参数")) { 通过 = 假 }
    如果 (!压力验证_断言((0 - 压力验证_首尾优势(链式_交叉)) >= 理论_交叉扫描最小增益(), 警告_高, "链式回溯 交叉扫描增益不足")) { 通过 = 假 }
    定义 检索_交叉 = [

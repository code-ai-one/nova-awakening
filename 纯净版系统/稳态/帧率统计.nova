导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/创建甲.nova")

定义 帧历史深度 = 60
定义 卡顿阈值 = 33333
定义 严重卡顿阈值 = 50000
定义 直方图桶数 = 8

结构 渲染管线 {
    帧计数,
    上帧时刻,
    帧间隔,
    平均帧时,
    最大帧时,
    最小帧时,
    卡顿次数,
    严重卡顿,
    历史环,
    历史写位,
    直方图,
    垂直同步,
    双缓冲,
    模式,
}

定义 可变 全局管线 = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 渲染管线_初始化(模式, 双缓冲) {
    全局管线 = 堆_分配(渲染管线)
    全局管线.帧计数 = 0
    全局管线.上帧时刻 = 0
    全局管线.帧间隔 = 0
    全局管线.平均帧时 = 16667
    全局管线.最大帧时 = 0
    全局管线.最小帧时 = 999999
    全局管线.卡顿次数 = 0
    全局管线.严重卡顿 = 0
    全局管线.历史环 = 堆_分配(帧历史深度 * 4)
    全局管线.历史写位 = 0
    全局管线.直方图 = 堆_分配(直方图桶数 * 4)
    定义 可变 序号 = 0
    当 (序号 < 直方图桶数) {
        内存_写32(全局管线.直方图 + 序号 * 4, 0)
        序号 = 序号 + 1
    }
    全局管线.垂直同步 = 真
    全局管线.双缓冲 = 双缓冲
    全局管线.模式 = 模式
}

函数 渲染_帧开始() {
    如果 (全局管线 == 0) { 返回 }
    全局管线.上帧时刻 = 平台_获取高精度时间()
}

函数 渲染_帧结束() {
    如果 (全局管线 == 0) { 返回 }
    定义 现在 = 平台_获取高精度时间()
    定义 帧时 = 现在 - 全局管线.上帧时刻
    全局管线.帧间隔 = 帧时
    全局管线.帧计数 = 全局管线.帧计数 + 1
    全局管线.平均帧时 = (全局管线.平均帧时 * 950 + 帧时 * 74) / 1024
    如果 (帧时 > 全局管线.最大帧时) { 全局管线.最大帧时 = 帧时 }
    如果 (帧时 < 全局管线.最小帧时) { 全局管线.最小帧时 = 帧时 }
    如果 (帧时 > 卡顿阈值) { 全局管线.卡顿次数 = 全局管线.卡顿次数 + 1 }
    如果 (帧时 > 严重卡顿阈值) { 全局管线.严重卡顿 = 全局管线.严重卡顿 + 1 }
    内存_写32(全局管线.历史环 + 全局管线.历史写位 * 4, 帧时)
    全局管线.历史写位 = (全局管线.历史写位 + 1) % 帧历史深度
    渲染_更新直方图(帧时)
}

函数 渲染_更新直方图(帧时) {
    定义 可变 桶 = 0
    如果 (帧时 < 8333) { 桶 = 0 }
    否则 如果 (帧时 < 11111) { 桶 = 1 }
    否则 如果 (帧时 < 16667) { 桶 = 2 }
    否则 如果 (帧时 < 20000) { 桶 = 3 }
    否则 如果 (帧时 < 33333) { 桶 = 4 }
    否则 如果 (帧时 < 50000) { 桶 = 5 }
    否则 如果 (帧时 < 100000) { 桶 = 6 }
    否则 { 桶 = 7 }
    内存_写32(全局管线.直方图 + 桶 * 4, 内存_读32(全局管线.直方图 + 桶 * 4) + 1)
}

函数 渲染_帧率() {
    如果 (全局管线 == 0 || 全局管线.平均帧时 == 0) { 返回 0 }
    返回 1000000 / 全局管线.平均帧时
}

函数 渲染_获取帧时() {
    如果 (全局管线 == 0) { 返回 0 }
    返回 全局管线.帧间隔
}

函数 渲染_卡顿率() {
    如果 (全局管线 == 0 || 全局管线.帧计数 == 0) { 返回 0 }
    返回 全局管线.卡顿次数 * 100 / 全局管线.帧计数
}

函数 渲染_第99百分位帧时() {
    如果 (全局管线 == 0) { 返回 0 }
    定义 可变 最大 = 0
    定义 可变 序号 = 0
    当 (序号 < 帧历史深度) {
        定义 值 = 内存_读32(全局管线.历史环 + 序号 * 4)
        如果 (值 > 最大) { 最大 = 值 }
        序号 = 序号 + 1
    }
    返回 最大
}

函数 渲染_设垂直同步(启用) {
    如果 (全局管线 == 0) { 返回 }
    全局管线.垂直同步 = 启用
}

函数 渲染_获取直方图(桶号) {
    如果 (全局管线 == 0 || 桶号 >= 直方图桶数) { 返回 0 }
    返回 内存_读32(全局管线.直方图 + 桶号 * 4)
}

函数 渲染管线_完整统计() {
    如果 (全局管线 == 0) { 返回 [0, 0, 0, 0, 0, 0] }
    返回 [全局管线.模式, 全局管线.帧计数, 渲染_帧率(), 全局管线.卡顿次数, 全局管线.严重卡顿, 渲染_卡顿率()]
}

    内核界面_记录(档, "命中图标", [x, y], "网桌面")
    档.页面数 = 档.页面数 + 1
    返回 内核界面_成功(档, "命中图标", Web桌面_命中图标索引(x, y))
}

函数 内核界面_激活图标(档, 图标索引) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "激活图标", "界面档不可用") }
    内核界面_记录(档, "激活图标", [图标索引], "网桌面")
    档.页面数 = 档.页面数 + 1
    返回 内核界面_成功(档, "激活图标", Web桌面_激活图标(图标索引))
}

函数 内核界面_命中启动器(档, x, y) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "命中启动器", "界面档不可用") }
    内核界面_记录(档, "命中启动器", [x, y], "网桌面")
    档.页面数 = 档.页面数 + 1
    返回 内核界面_成功(档, "命中启动器", Web桌面_命中启动器(x, y))
}

函数 内核界面_激活启动器(档) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "激活启动器", "界面档不可用") }
    内核界面_记录(档, "激活启动器", [], "网桌面")
    档.页面数 = 档.页面数 + 1
    返回 内核界面_成功(档, "激活启动器", Web桌面_激活启动器())
}

函数 内核界面_命中任务栏(档, x, y) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "命中任务栏", "界面档不可用") }
    内核界面_记录(档, "命中任务栏", [x, y], "网桌面")
    档.页面数 = 档.页面数 + 1
    返回 内核界面_成功(档, "命中任务栏", Web桌面_命中任务栏窗口(x, y))
}

函数 内核界面_激活任务栏(档, 窗口标识) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "激活任务栏", "界面档不可用") }
    内核界面_记录(档, "激活任务栏", [窗口标识], "网桌面")
    档.页面数 = 档.页面数 + 1
    返回 内核界面_成功(档, "激活任务栏", Web桌面_激活任务栏窗口(窗口标识))
}

函数 内核界面_界面总览(档) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "界面总览", "界面档不可用") }
    内核界面_记录(档, "界面总览", [], "内核界面")
    定义 总览 = [
        内核界面_构建桌面文档(档).数据,
        内核界面_桌面样式(档).数据,
        内核界面_白璃主题(档).数据,
        内核界面_浏览外衣(档, "觉醒浏览", "nova://pure").数据,
        内核界面_页面上下文(档).数据,
        内核界面_网面状态(档).数据
    ]
    返回 内核界面_成功(档, "界面总览", 总览)
}

函数 内核界面_摘要(档) {
    定义 摘要 = 界面摘要 {}
    摘要.名称 = 档.名称
    摘要.宽度 = 档.宽度
    摘要.高度 = 档.高度
    摘要.桌面数 = 档.桌面数
    摘要.窗口数 = 档.窗口数
    摘要.页面数 = 档.页面数
    摘要.合成数 = 档.合成数
    摘要.组件数 = 档.组件数
    摘要.操作数 = 档.操作数
    摘要.成功数 = 档.成功数
    摘要.失败数 = 档.失败数
    摘要.健康 = 内核界面_刷新健康(档)
    返回 摘要
}

函数 内核界面_健康(档) {
    如果 (档 == 空) { 返回 "无档" }
    返回 内核界面_刷新健康(档)
}

函数 内核界面_自检(档) {
    如果 (!内核界面_检查档(档)) { 返回 假 }
    如果 (内核界面_合成统计(档).已成 == 假) { 返回 假 }
    如果 (内核界面_组件统计(档).已成 == 假) { 返回 假 }
    如果 (内核界面_网面状态(档).已成 == 假) { 返回 假 }
    如果 (内核界面_窗口统计(档).已成 == 假) { 返回 假 }
    返回 真
}

函数 内核界面_处理(档, 请求) {
    如果 (请求 == 空) { 返回 内核界面_失败(档, "处理", "请求为空") }
    如果 (请求.动作 == "初始化") { 内核界面_初始化(档, 请求.参数[0], 请求.参数[1]); 返回 内核界面_成功(档, "处理", "已初始化") }
    如果 (请求.动作 == "打开窗口") { 返回 内核界面_打开窗口(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3], 请求.参数[4], 请求.参数[5]) }
    如果 (请求.动作 == "聚焦窗口") { 返回 内核界面_聚焦窗口(档, 请求.参数[0]) }
    如果 (请求.动作 == "关闭窗口") { 返回 内核界面_关闭窗口(档, 请求.参数[0]) }
    如果 (请求.动作 == "导航") { 返回 内核界面_导航当前(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "页面动作") { 返回 内核界面_执行页面动作(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "创建合成窗口") { 返回 内核界面_创建合成窗口(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3], 请求.参数[4], 请求.参数[5], 请求.参数[6]) }
    如果 (请求.动作 == "组件") { 返回 内核界面_注册组件(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3]) }
    如果 (请求.动作 == "白璃主题") { 返回 内核界面_白璃主题(档) }
    如果 (请求.动作 == "浏览外衣") { 返回 内核界面_浏览外衣(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "现代桌面") { 返回 内核界面_现代桌面(档, 请求.参数[0]) }
    如果 (请求.动作 == "指令面板") { 返回 内核界面_指令面板(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "统计") { 返回 内核界面_成功(档, "统计", 内核界面_摘要(档)) }
    如果 (请求.动作 == "总览") { 返回 内核界面_界面总览(档) }
    返回 内核界面_失败(档, "处理", "未知动作")
}

函数 内核界面_绑定页面会话(页面会话ID, 档, 窗口ID, 标题) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (!内核界面_检查档(档) || 会话 == 空) { 返回 假 }
    返回 一体桥_绑定页面资源(页面会话ID, 窗口ID, 会话.标签ID, 会话.文档指针, 会话.脚本上下文, 会话.推理上下文)
}

函数 内核界面_生成窗口快照(页面会话ID, 档, 窗口ID, 标题) {
    如果 (!内核界面_绑定页面会话(页面会话ID, 档, 窗口ID, 标题)) { 返回 空 }
    返回 一体桥_生成窗口快照(页面会话ID, 窗口ID, 0, 0, 档.宽度, 档.高度, 真, 真, 标题)
}

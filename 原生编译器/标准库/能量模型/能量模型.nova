导入("../基础.nova")
导入("../算法/数学扩展.nova")


定义 EB_随机态 = 16180
函数 EB_随机() {
    EB_随机态 = EB_随机态 ^ (EB_随机态 << 13)
    EB_随机态 = EB_随机态 ^ (EB_随机态 >> 7)
    EB_随机态 = EB_随机态 ^ (EB_随机态 << 17)
    如果 (EB_随机态 < 0) { EB_随机态 = 0 - EB_随机态 }
    返回 EB_随机态
}

// 能量函数
// E(x) = -x^T W x / 2 - b^T x  (二次能量)
函数 能量_二次(x, W, b) {
    定义 n = 计数(x)
    定义 可变 E = 0
    // -x^T W x / 2
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 j = 0
        当 (j < n) {
            如果 (i * n + j < 计数(W)) {
                E = E - x[i] * W[i * n + j] * x[j] / (2 * 1000)
            }
            j = j + 1
        }
        // -b^T x
        如果 (i < 计数(b)) { E = E - b[i] * x[i] / 1000 }
        i = i + 1
    }
    返回 E
}

// 线性能量: E(x) = w^T x + b
函数 能量_线性(x, w, b) {
    定义 n = 计数(x)
    定义 可变 E = b
    定义 可变 i = 0
    当 (i < n) {
        如果 (i < 计数(w)) { E = E + w[i] * x[i] / 1000 }
        i = i + 1
    }
    返回 E
}

// Hopfield网络
// 存储模式, 联想记忆
函数 Hopfield_创建(维度) {
    定义 可变 W = []
    定义 可变 i = 0
    当 (i < 维度 * 维度) { 追加(W, 0)
    i = i + 1 }
    返回 [W, 维度, []]  // [权重, 维度, 存储的模式]
}

函数 Hopfield_存储(网络, 模式) {
    // Hebbian: W += p · p^T (排除对角线)
    定义 d = 网络[1]
    定义 可变 i = 0
    当 (i < d) {
        定义 可变 j = 0
        当 (j < d) {
            如果 (i != j) {
                网络[0][i * d + j] = 网络[0][i * d + j] + 模式[i] * 模式[j] / 1000
            }
            j = j + 1
        }
        i = i + 1
    }
    追加(网络[2], 模式)
}

函数 Hopfield_回忆(网络, 输入, 步数) {
    定义 d = 网络[1]
    定义 可变 状态 = []
    定义 可变 i = 0
    当 (i < d) {
        如果 (i < 计数(输入)) { 追加(状态, 输入[i]) }
        否则 { 追加(状态, 0) }
        i = i + 1
    }
    // 异步更新
    定义 可变 步长 = 0
    当 (步长 < 步数) {
        i = EB_随机() % d  // 随机选一个神经元
        定义 可变 h = 0
        定义 可变 j = 0
        当 (j < d) {
            h = h + 网络[0][i * d + j] * 状态[j] / 1000
            j = j + 1
        }
        如果 (h >= 0) { 状态[i] = 1000 }
        否则 { 状态[i] = -1000 }
        步长 = 步长 + 1
    }
    返回 状态
}

函数 Hopfield_能量(网络, 状态) {
    返回 能量_二次(状态, 网络[0], [])
}

// 现代Hopfield (指数容量)
函数 现代Hopfield_回忆(模式列表, 查询, β) {
    定义 可变 指数组 = []
    如果 (β <= 0) { β = 1000 }
    定义 M = 计数(模式列表)
    如果 (M == 0) { 返回 查询 }
    定义 d = 计数(查询)
    // 计算注意力: 归一化指数(β · 模式^T · 查询)
    定义 可变 分数 = []
    定义 可变 最大得分 = 0 - 0x7FFFFFFF
    定义 可变 i = 0
    当 (i < M) {
        定义 可变 s = 0
        定义 可变 j = 0
        当 (j < d) {
            如果 (j < 计数(模式列表[i])) { s = s + 模式列表[i][j] * 查询[j] / 1000 }
            j = j + 1
        }
        s = β * s / 1000
        追加(分数, s)
        如果 (s > 最大得分) { 最大得分 = s }
        i = i + 1
    }
    // 归一化指数 + 加权和
    定义 可变 总 = 0
    i = 0
    当 (i < M) {
        定义 可变 e = 1000 + (分数[i] - 最大得分)
        如果 (e < 1) { e = 1 }
        追加(指数组, e)
        总 = 总 + e
        i = i + 1
    }
    如果 (总 == 0) { 总 = 1 }
    定义 可变 输出 = []
    定义 可变 j = 0
    当 (j < d) { 追加(输出, 0)
    j = j + 1 }
    i = 0
    当 (i < M) {
        定义 α = 指数组[i] * 1000 / 总
        j = 0
        当 (j < d) {
            如果 (j < 计数(模式列表[i])) {
                输出[j] = 输出[j] + α * 模式列表[i][j] / 1000
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 输出
}

// 受限玻尔兹曼机 (RBM)
函数 RBM_创建(可见维度, 隐藏维度) {
    定义 可变 W = []
    定义 可变 a = []  // 可见偏置
    定义 可变 b = []  // 隐藏偏置
    定义 可变 i = 0
    当 (i < 可见维度 * 隐藏维度) {
        追加(W, (EB_随机() % 200) - 100)
        i = i + 1
    }
    i = 0
    当 (i < 可见维度) { 追加(a, 0)
    i = i + 1 }
    i = 0
    当 (i < 隐藏维度) { 追加(b, 0)
    i = i + 1 }
    返回 [W, a, b, 可见维度, 隐藏维度]
}

函数 RBM_隐藏给定可见(rbm, v) {
    定义 nh = rbm[4]
    定义 nv = rbm[3]
    定义 可变 h = []
    定义 可变 j = 0
    当 (j < nh) {
        定义 可变 激活 = rbm[2][j]
        定义 可变 i = 0
        当 (i < nv) {
            激活 = 激活 + rbm[0][i * nh + j] * v[i] / 1000
            i = i + 1
        }
        // S形函数
        定义 可变 信号值 = 500 + 激活 / 4
        如果 (信号值 < 0) { 信号值 = 0 }
        如果 (信号值 > 1000) { 信号值 = 1000 }
        如果 (EB_随机() % 1000 < 信号值) { 追加(h, 1000) }
        否则 { 追加(h, 0) }
        j = j + 1
    }
    返回 h
}

函数 RBM_可见给定隐藏(rbm, h) {
    定义 nv = rbm[3]
    定义 nh = rbm[4]
    定义 可变 v = []
    定义 可变 i = 0
    当 (i < nv) {
        定义 可变 激活 = rbm[1][i]
        定义 可变 j = 0
        当 (j < nh) {
            激活 = 激活 + rbm[0][i * nh + j] * h[j] / 1000
            j = j + 1
        }
        定义 可变 信号值 = 500 + 激活 / 4
        如果 (信号值 < 0) { 信号值 = 0 }
        如果 (信号值 > 1000) { 信号值 = 1000 }
        如果 (EB_随机() % 1000 < 信号值) { 追加(v, 1000) }
        否则 { 追加(v, 0) }
        i = i + 1
    }
    返回 v
}

// CD-1 对比散度训练
函数 RBM_CD1_更新(rbm, v_data, lr) {
    定义 nv = rbm[3]
    定义 nh = rbm[4]
    // 正相: h_data = σ(W^T v + b)
    定义 h_data = RBM_隐藏给定可见(rbm, v_data)
    // 负相: v_recon → h_recon
    定义 v_recon = RBM_可见给定隐藏(rbm, h_data)
    定义 h_recon = RBM_隐藏给定可见(rbm, v_recon)
    // 更新 W += lr * (v_data·h_data^T - v_recon·h_recon^T)
    定义 可变 i = 0
    当 (i < nv) {
        定义 可变 j = 0
        当 (j < nh) {
            定义 正 = v_data[i] * h_data[j] / 1000
            定义 负 = v_recon[i] * h_recon[j] / 1000
            rbm[0][i * nh + j] = rbm[0][i * nh + j] + lr * (正 - 负) / 1000
            j = j + 1
        }
        i = i + 1
    }
}

// 朗之万动力学采样
函数 朗之万_采样(x, 能量梯度, 步长, 步数) {
    定义 d = 计数(x)
    定义 可变 当前 = []
    定义 可变 i = 0
    当 (i < d) { 追加(当前, x[i])
    i = i + 1 }
    定义 可变 步长 = 0
    当 (步长 < 步数) {
        i = 0
        当 (i < d) {
            定义 可变 梯度 = 0
            如果 (i < 计数(能量梯度)) { 梯度 = 能量梯度[i] }
            定义 噪声 = (EB_随机() % 2000) - 1000
            定义 sqrt_步长 = 整数sqrt(步长 * 2000)
            当前[i] = 当前[i] - 步长 * 梯度 / 1000 + sqrt_步长 * 噪声 / 1000
            i = i + 1
        }
        步长 = 步长 + 1
    }
    返回 当前
}

// 分数匹配 (Score Matching)
函数 分数匹配_损失(预测分数, 真实分数) {
    定义 n = 计数(预测分数)
    定义 可变 损失值 = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 真值 = 0
        如果 (i < 计数(真实分数)) { 真值 = 真实分数[i] }
        定义 d = 预测分数[i] - 真值
        损失值 = 损失值 + d * d / 1000
        i = i + 1
    }
    如果 (n == 0) { 返回 0 }
    返回 损失值 / n
}

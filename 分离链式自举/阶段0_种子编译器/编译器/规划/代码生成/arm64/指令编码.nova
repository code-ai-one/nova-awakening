函数 指令编码_编码_sve2_uqsub(d, n, m) { 返回 0x04201C00|((m&31)<<16)|((n&31)<<5)|(d&31) }
// SRSHL/URSHL — 舍入移位
函数 指令编码_编码_sve2_srshl(d, pg, n, m) { 返回 0x44828000|((m&31)<<16)|((pg&7)<<10)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_sve2_urshl(d, pg, n, m) { 返回 0x44838000|((m&31)<<16)|((pg&7)<<10)|((n&31)<<5)|(d&31) }
// MATCH/NMATCH — 元素匹配
函数 指令编码_编码_sve2_match(d, pg, n, m) { 返回 0x45208000|((m&31)<<16)|((pg&7)<<10)|((n&31)<<5)|(d&15) }
// HISTCNT — 直方图计数
函数 指令编码_编码_sve2_histcnt(d, pg, n, m) { 返回 0x45A0C000|((m&31)<<16)|((pg&7)<<10)|((n&31)<<5)|(d&31) }

// SADALP/UADALP — 成对长加累加
函数 指令编码_编码_sadalp_4s(d, n) { 返回 0x4E206800|((n&31)<<5)|(d&31) }
函数 指令编码_编码_uadalp_4s(d, n) { 返回 0x6E206800|((n&31)<<5)|(d&31) }

// Nova · IR层 · 调试映射 (Debug Mapping)
// 字节码指令↔源码行号的精确映射
// 支持JIT编译后的机器码→源码回溯

导入("../../标准库/基础.nova")

// 映射条目
// [字节码偏移, 源码行号, 源码列号, 函数名, 文件路径]
函数 调试映射_创建条目(偏移, 行号, 列号, 函数名, 文件) {
    定义 可变 条目 = []
    追加(条目, 偏移)
    追加(条目, 行号)
    追加(条目, 列号)
    追加(条目, 函数名)
    追加(条目, 文件)
    返回 条目
}

// 调试映射表
// [条目列表, 偏移→行号字典(快速查找), 行号→偏移列表字典(反向查找), 变量作用域表]
函数 调试映射_创建() {
    定义 可变 表 = []
    追加(表, [])
    追加(表, 字典())
    追加(表, 字典())
    追加(表, 字典())
    返回 表
}

// 添加映射
函数 调试映射_追加(映射表, 偏移, 行号, 列号, 函数名, 文件) {
    定义 条目 = 调试映射_创建条目(偏移, 行号, 列号, 函数名, 文件)
    追加(映射表[0], 条目)

    // 正向: 偏移→行号
    字典设(映射表[1], 转字符串(偏移), 行号)

    // 反向: 行号→偏移列表
    定义 键 = 转字符串(行号)
    定义 现有 = 字典取(映射表[2], 键)
    如果 (现有 == 空) {
        字典设(映射表[2], 键, [偏移])
    } 否则 {
        追加(现有, 偏移)
    }
}

// 查询

// 字节码偏移 → 源码行号
函数 调试映射_偏移到行号(映射表, 偏移) {
    // 精确查找
    定义 行号 = 字典取(映射表[1], 转字符串(偏移))
    如果 (行号 != 空) { 返回 行号 }

    // 近似查找: 找最近的小于等于偏移的条目
    定义 可变 最近 = -1
    定义 可变 最近行 = 0
    定义 可变 i = 0
    当 (i < 计数(映射表[0])) {
        定义 条目 = 映射表[0][i]
        如果 (条目[0] <= 偏移 且 条目[0] > 最近) {
            最近 = 条目[0]
            最近行 = 条目[1]
        }
        i = i + 1
    }
    返回 最近行
}

// 源码行号 → 字节码偏移列表
函数 调试映射_行号到偏移(映射表, 行号) {
    返回 字典取(映射表[2], 转字符串(行号))
}

// 字节码偏移 → 完整调试信息
函数 调试映射_偏移到信息(映射表, 偏移) {
    定义 可变 i = 0
    定义 可变 最佳 = 空
    定义 可变 最佳距离 = 999999
    当 (i < 计数(映射表[0])) {
        定义 条目 = 映射表[0][i]
        定义 距离 = 偏移 - 条目[0]
        如果 (距离 >= 0 且 距离 < 最佳距离) {
            最佳 = 条目
            最佳距离 = 距离
        }
        i = i + 1
    }
    返回 最佳
}

// 变量作用域映射
// 记录变量在字节码中的有效范围
函数 调试映射_添加变量(映射表, 变量名, 函数名, 起始偏移, 结束偏移, 槽索引) {
    定义 键 = 字符串拼接(函数名, 字符串拼接(":", 变量名))
    字典设(映射表[3], 键, [起始偏移, 结束偏移, 槽索引])
}

函数 调试映射_查变量(映射表, 变量名, 函数名, 当前偏移) {
    定义 键 = 字符串拼接(函数名, 字符串拼接(":", 变量名))
    定义 范围 = 字典取(映射表[3], 键)
    如果 (范围 == 空) { 返回 空 }
    如果 (当前偏移 >= 范围[0] 且 当前偏移 <= 范围[1]) {
 返回 范围[2]    // 返回槽索引
    }
    返回 空
}

// JIT映射扩展
// JIT编译后: 机器码地址 → 字节码偏移 → 源码行号 (两级映射)
函数 调试映射_添加JIT(映射表, 机器码地址, 字节码偏移) {
    定义 键 = 字符串拼接("jit:", 转字符串(机器码地址))
    字典设(映射表[1], 键, 字节码偏移)
}

函数 调试映射_JIT到源码(映射表, 机器码地址) {
    定义 键 = 字符串拼接("jit:", 转字符串(机器码地址))
    定义 字节码偏移 = 字典取(映射表[1], 键)
    如果 (字节码偏移 == 空) { 返回 空 }
    定义 行号 = 调试映射_偏移到行号(映射表, 字节码偏移)
    返回 [行号, 字节码偏移, 机器码地址]
}

// 统计
// 变量作用域

定义 可变 _作用域_变量名 = []
定义 可变 _作用域_变量类型 = []
定义 可变 _作用域_起始偏移 = []
定义 可变 _作用域_结束偏移 = []
定义 可变 _作用域_深度 = []

函数 作用域_添加变量(名, 类型, 起始, 结束, 深度) {
    追加(_作用域_变量名, 名)
    追加(_作用域_变量类型, 类型)
    追加(_作用域_起始偏移, 起始)
    追加(_作用域_结束偏移, 结束)
    追加(_作用域_深度, 深度)
}

函数 作用域_查找变量(名, 偏移) {
    定义 可变 i = 计数(_作用域_变量名) - 1
    当 (i >= 0) {
        如果 (_作用域_变量名[i] == 名 且 偏移 >= _作用域_起始偏移[i] 且 偏移 <= _作用域_结束偏移[i]) {
            返回 [_作用域_变量名[i], _作用域_变量类型[i], _作用域_深度[i]]
        }
        i = i - 1
    }
    返回 空
}

函数 作用域_活跃变量(偏移) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(_作用域_变量名)) {
        如果 (偏移 >= _作用域_起始偏移[i] 且 偏移 <= _作用域_结束偏移[i]) {
            追加(结果, [_作用域_变量名[i], _作用域_变量类型[i], _作用域_深度[i]])
        }
        i = i + 1
    }
    返回 结果
}

函数 作用域_变量总数() { 返回 计数(_作用域_变量名) }

// 内联信息

定义 可变 _内联_调用者 = []
定义 可变 _内联_被调用者 = []
定义 可变 _内联_起始行 = []
定义 可变 _内联_结束行 = []

函数 内联_记录(调用者, 被调用者, 起始行, 结束行) {
    追加(_内联_调用者, 调用者)
    追加(_内联_被调用者, 被调用者)
    追加(_内联_起始行, 起始行)
    追加(_内联_结束行, 结束行)
}

函数 内联_查找(行号) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(_内联_调用者)) {
        如果 (行号 >= _内联_起始行[i] 且 行号 <= _内联_结束行[i]) {
            追加(结果, [_内联_调用者[i], _内联_被调用者[i]])
        }
        i = i + 1
    }
    返回 结果
}

函数 内联_总数() { 返回 计数(_内联_调用者) }

// 断点管理

定义 可变 _断点_行号 = []
定义 可变 _断点_文件 = []
定义 可变 _断点_启用 = []
定义 可变 _断点_条件 = []

函数 断点_添加(文件, 行号) {
    追加(_断点_文件, 文件)
    追加(_断点_行号, 行号)
    追加(_断点_启用, 真)
    追加(_断点_条件, "")
    返回 计数(_断点_行号) - 1
}

函数 断点_条件添加(文件, 行号, 条件) {
    定义 id = 断点_添加(文件, 行号)
    _断点_条件[id] = 条件
    返回 id
}

函数 断点_删除(id) {
    如果 (id < 计数(_断点_行号)) { _断点_启用[id] = 假 }
}

函数 断点_切换(id) {
    如果 (id < 计数(_断点_行号)) { _断点_启用[id] = !_断点_启用[id] }
}

函数 断点_检查(文件, 行号) {
    定义 可变 i = 0
    当 (i < 计数(_断点_行号)) {
        如果 (_断点_启用[i] 且 _断点_文件[i] == 文件 且 _断点_行号[i] == 行号) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 断点_列表() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(_断点_行号)) {
        如果 (_断点_启用[i]) {
            追加(结果, [i, _断点_文件[i], _断点_行号[i], _断点_条件[i]])
        }
        i = i + 1
    }
    返回 结果
}

函数 断点_总数() {
    定义 可变 n = 0
    定义 可变 i = 0
    当 (i < 计数(_断点_行号)) {
        如果 (_断点_启用[i]) { n = n + 1 }
        i = i + 1
    }
    返回 n
}

// 源码映射

定义 可变 _源映射_生成行 = []
定义 可变 _源映射_原始行 = []
定义 可变 _源映射_原始文件 = []

函数 源映射_添加(生成行, 原始行, 原始文件) {
    追加(_源映射_生成行, 生成行)
    追加(_源映射_原始行, 原始行)
    追加(_源映射_原始文件, 原始文件)
}

函数 源映射_查找(生成行) {
    定义 可变 i = 0
    当 (i < 计数(_源映射_生成行)) {
        如果 (_源映射_生成行[i] == 生成行) {
            返回 [_源映射_原始文件[i], _源映射_原始行[i]]
        }
        i = i + 1
    }
    返回 空
}

定义 可变 _调试_映射数 = 0
定义 可变 _调试_断点命中 = 0
定义 可变 _调试_查找数 = 0

函数 调试映射_记录映射() { _调试_映射数 = _调试_映射数 + 1 }
函数 调试映射_记录命中() { _调试_断点命中 = _调试_断点命中 + 1 }
函数 调试映射_记录查找() { _调试_查找数 = _调试_查找数 + 1 }

// 允许该调试模块被单模块编译成完整可执行目标。
// 在全量模块图自举中它仍然只是一个普通辅助模块。
函数 主程序() {
    返回 0
}

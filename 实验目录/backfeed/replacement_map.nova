}

函数 覆盖_矩阵_类型(序号) {
    如果 (序号 == 0) { 返回 覆盖_类型_可替换() }
    如果 (序号 == 1) { 返回 覆盖_类型_可替换() }
    如果 (序号 == 2) { 返回 覆盖_类型_可替换() }
    如果 (序号 == 3) { 返回 覆盖_类型_可替换() }
    如果 (序号 == 4) { 返回 覆盖_类型_可替换() }
    如果 (序号 == 5) { 返回 覆盖_类型_需合并升级() }
    如果 (序号 == 6) { 返回 覆盖_类型_需合并升级() }
    如果 (序号 == 7) { 返回 覆盖_类型_需合并升级() }
    如果 (序号 == 8) { 返回 覆盖_类型_需合并升级() }
    如果 (序号 == 9) { 返回 覆盖_类型_需合并升级() }
    如果 (序号 == 10) { 返回 覆盖_类型_需保留() }
    如果 (序号 == 11) { 返回 覆盖_类型_需保留() }
    如果 (序号 == 12) { 返回 覆盖_类型_需保留() }
    返回 0
}

函数 覆盖_矩阵_类型文本(序号) {
    定义 类型 = 覆盖_矩阵_类型(序号)
    如果 (类型 == 覆盖_类型_可替换()) { 返回 "可替换" }
    如果 (类型 == 覆盖_类型_需合并升级()) { 返回 "需合并升级" }
    如果 (类型 == 覆盖_类型_需保留()) { 返回 "需保留" }
    返回 "未知"
}

函数 覆盖_打印摘要() {
    打印("[实验目录][覆盖] 可替换=5")
    打印("[实验目录][覆盖] 需合并=5")
    打印("[实验目录][覆盖] 需保留=3")
    打印("[实验目录][覆盖] 记忆/回复/蒸馏/对齐/几何 已入替换实验")
    打印("[实验目录][覆盖] 意图/思维链/RAG/在线学习/策略梯度 进入合并升级")
    打印("[实验目录][覆盖] 浏览注意/多头注意/MoE 先保留结构算子")
}

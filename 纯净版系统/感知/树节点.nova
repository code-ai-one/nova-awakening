导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")

// §3 TreeWalker / 节点Iterator (DOM §6)

定义 显示_全部           = 0xFFFFFFFF
定义 显示_元素           = 0x01
定义 显示_文本           = 0x04
定义 显示_注释           = 0x80
定义 显示_文档           = 0x100

定义 过滤_接受   = 1
定义 过滤_拒绝   = 2
定义 过滤_跳过   = 3

结构 TreeWalker {
    根,    // u64 节点*
    当前节点,    // u64 节点*
    显示掩码,    // u32 节点Filter.SHOW_xxx
    过滤器,    // u64 函数指针(节点Filter)
}

函数 TreeWalker_创建(根, 显示掩码, 过滤器) {
    定义 tw = 堆_分配(TreeWalker)
    tw.根 = 根
    tw.当前节点 = 根
    tw.显示掩码 = 显示掩码
    tw.过滤器 = 过滤器
    返回 tw
}

函数 TreeWalker_next节点(tw) {
    定义 可变 节点 = tw.当前节点
    // 深度优先:先子,再兄,再父的兄
    如果 (节点.第一子节点 != 0) {
        节点 = 节点.第一子节点
    } 否则 {
        当 (节点 != 0 && 节点 != tw.根) {
            如果 (节点.后一兄弟 != 0) {
                节点 = 节点.后一兄弟
                跳出
            }
            节点 = 节点.父节点
        }
        如果 (节点 == tw.根) { 返回 0 }
    }

    // 过滤
    当 (节点 != 0) {
        如果 (TreeWalker_接受(tw, 节点)) {
            tw.当前节点 = 节点
            返回 节点
        }
        // 继续下一个
        如果 (节点.第一子节点 != 0) {
            节点 = 节点.第一子节点
        } 否则 {
            当 (节点 != 0 && 节点 != tw.根) {
                如果 (节点.后一兄弟 != 0) { 节点 = 节点.后一兄弟; 跳出 }
                节点 = 节点.父节点
            }
            如果 (节点 == tw.根) { 返回 0 }
        }
    }
    返回 0
}

函数 TreeWalker_previous节点(tw) {
    定义 可变 节点 = tw.当前节点
    如果 (节点 == tw.根) { 返回 0 }

    如果 (节点.前一兄弟 != 0) {
        节点 = 节点.前一兄弟
        // 找到最深最后的后代
        当 (节点.最后子节点 != 0) { 节点 = 节点.最后子节点 }
    } 否则 {
        节点 = 节点.父节点
        如果 (节点 == tw.根) { 返回 0 }
    }

    如果 (节点 != 0 && TreeWalker_接受(tw, 节点)) {
        tw.当前节点 = 节点
        返回 节点
    }
    返回 0
}

函数 TreeWalker_parent节点(tw) {
    定义 节点 = tw.当前节点.父节点
    如果 (节点 == 0 || 节点 == tw.根) { 返回 0 }
    如果 (TreeWalker_接受(tw, 节点)) {
        tw.当前节点 = 节点
        返回 节点
    }
    返回 0
}

函数 TreeWalker_firstChild(tw) {
    定义 可变 子 = tw.当前节点.第一子节点
    当 (子 != 0) {
        如果 (TreeWalker_接受(tw, 子)) {
            tw.当前节点 = 子
            返回 子
        }
        子 = 子.后一兄弟
    }
    返回 0
}

函数 TreeWalker_接受(tw, 节点) {
    如果 (节点 == 0) { 返回 假 }
    // 检查显示掩码
    定义 节点位 = 1 << (节点.节点类型 - 1)
    如果 (!(tw.显示掩码 & 节点位)) { 返回 假 }
    // 自定义过滤器
    如果 (tw.过滤器 != 0) {
        定义 结果 = 调用(tw.过滤器, 节点)
        返回 结果 == 过滤_接受
    }
    返回 真
}

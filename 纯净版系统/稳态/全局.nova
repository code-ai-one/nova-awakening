导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../中枢/字符串替换.nova")
导入("../引导/端口输入.nova")
导入("./接收初始化.nova")
导入("./图处枚举.nova")
导入("./输入原语.nova")
导入("../中枢/整数转字符串.nova")

// §3 全局

定义 RX_DESC_COUNT = 256
定义 TX_DESC_COUNT = 256
定义 RX_BUF_SIZE = 2048

// §4 初始化

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 e1000_初始化() {
    e1000设备列表 = []
    内核信息("e1000: 扫描Intel以太网控制器...")

    // PCI类代码: 0x0200 = Network → Ethernet
    // Intel VID=0x8086, e1000系列DID: 0x100E(QEMU), 0x10D3(82574L), 0x153A(I217)
    定义 可变 总线 = 0
    当 (总线 < 256) {
        定义 可变 设备号 = 0
        当 (设备号 < 32) {
            定义 可变 功能号 = 0
            当 (功能号 < 8) {
                定义 vid_did = PCI_配置读32(总线, 设备号, 功能号, 0x00)
                如果 (vid_did == 0xFFFFFFFF || vid_did == 0) {
                    功能号 = 功能号 + 1
                    继续
                }
                定义 vid = vid_did & 0xFFFF
                定义 did = (vid_did >> 16) & 0xFFFF

                如果 (vid == 0x8086 && e1000_是支持设备(did)) {
                    内核信息("e1000: 发现 " + e1000_设备名(did) +
                             " @PCI " + 整数转字符串(总线) + ":" + 整数转字符串(设备号))

                    // 使能Bus Master + Memory Space
                    定义 cmd = PCI_配置读32(总线, 设备号, 功能号, 0x04)
                    PCI_配置写32(总线, 设备号, 功能号, 0x04, cmd | 0x07)

                    // 读取IRQ
                    定义 irq_info = PCI_配置读32(总线, 设备号, 功能号, 0x3C)
                    定义 irq = irq_info & 0xFF

                    // BAR0 = MMIO
                    定义 bar0 = PCI_读BAR(总线, 设备号, 功能号, 0)
                    e1000_初始化设备(bar0, irq)
                }
                功能号 = 功能号 + 1
            }
            设备号 = 设备号 + 1
        }
        总线 = 总线 + 1
    }

    内核信息("e1000: 初始化完成 网卡=" + 整数转字符串(计数(e1000设备列表)))
}

函数 e1000_是支持设备(did) {
    返回 did == 0x100E ||   // 82540EM (QEMU默认)
           did == 0x100F ||   // 82545EM
           did == 0x10D3 ||   // 82574L
           did == 0x153A ||   // I217-LM
           did == 0x15A1 ||   // I218-LM
           did == 0x15B8 ||   // I219-V
           did == 0x15BE ||   // I219-LM
           did == 0x15D7 ||   // I219-LM (6th gen)
           did == 0x0D4F ||   // I219-LM (10th gen)
           did == 0x1A1E      // I219-LM (11th gen)
}

函数 e1000_设备名(did) {
    如果 (did == 0x100E) { 返回 "82540EM (QEMU)" }
    如果 (did == 0x10D3) { 返回 "82574L" }
    如果 (did == 0x153A) { 返回 "I217-LM" }
    如果 (did == 0x15B8) { 返回 "I219-V" }
    返回 "e1000e " + 整数转十六进制(did)
}

函数 e1000_初始化设备(bar0, irq) {
    定义 dev = e1000设备 {}
    dev.MMIO基址 = bar0
    dev.IRQ = irq
    dev.RX环大小 = RX_DESC_COUNT
    dev.TX环大小 = TX_DESC_COUNT
    dev.RX缓冲列表 = []
    dev.TX缓冲列表 = []

    // 1. 复位
    e1000_写(dev, E1000_CTRL, E1000_CTRL_RST)
    延迟_ms(10)

    // 2. 禁用中断
    e1000_写(dev, E1000_IMC, 0xFFFFFFFF)

    // 3. 读取MAC地址
    dev.MAC地址 = e1000_读MAC(dev)
    内核信息("e1000: MAC=" + MAC转字符串(dev.MAC地址))

    // 4. 设置链路
    定义 ctrl = e1000_读(dev, E1000_CTRL)
    ctrl = ctrl | E1000_CTRL_SLU | E1000_CTRL_ASDE
    ctrl = ctrl & ~E1000_CTRL_RST
    e1000_写(dev, E1000_CTRL, ctrl)

    // 5. 清除多播表
    定义 可变 i = 0
    当 (i < 128) {
        e1000_写(dev, E1000_MTA + i * 4, 0)
        i = i + 1
    }

    // 6. 初始化接收
    e1000_初始化RX(dev)

    // 7. 初始化发送
    e1000_初始化TX(dev)

    // 8. 使能中断
    e1000_写(dev, E1000_IMS, E1000_ICR_RXT0 | E1000_ICR_LSC | E1000_ICR_TXDW)

    // 9. 检查链路状态
    定义 status = e1000_读(dev, E1000_STATUS)
    dev.链路状态 = (status & 0x02) != 0
    如果 ((status & 0xC0) == 0xC0) { dev.链路速度 = 1000 }
    否则 如果 ((status & 0xC0) == 0x80) { dev.链路速度 = 100 }
    否则 { dev.链路速度 = 10 }

    内核信息("e1000: 链路=" + (如果 (dev.链路状态) { "UP" } 否则 { "DOWN" }) +
             " 速度=" + 整数转字符串(dev.链路速度) + "Mbps")

    // 注册为网络设备
    网络设备_注册("eth0", dev)
    追加(e1000设备列表, dev)
}

// §4 MAC地址读取

函数 e1000_读MAC(dev) {
    定义 可变 mac = [0, 0, 0, 0, 0, 0]
    定义 低 = e1000_读(dev, 0x5400)
    定义 高 = e1000_读(dev, 0x5404)
    mac[0] = 低 & 0xFF
    mac[1] = (低 >> 8) & 0xFF
    mac[2] = (低 >> 16) & 0xFF
    mac[3] = (低 >> 24) & 0xFF
    mac[4] = 高 & 0xFF
    mac[5] = (高 >> 8) & 0xFF
    返回 mac
}

函数 MAC转字符串(mac) {
    返回 十六进制2(mac[0]) + ":" + 十六进制2(mac[1]) + ":" + 十六进制2(mac[2]) + ":" + 十六进制2(mac[3]) + ":" + 十六进制2(mac[4]) + ":" + 十六进制2(mac[5])
}

函数 十六进制2(值) {
    定义 高 = (值 >> 4) & 0xF
    定义 低 = 值 & 0xF
    定义 字符表 = "0123456789abcdef"
    返回 字符(字符表[高]) + 字符(字符表[低])
}

// §5 链路状态检测

函数 e1000_检查链路(dev) {
    定义 状态 = e1000_读(dev, E1000_STATUS)
    定义 链路 = (状态 & 0x02) != 0
    如果 (链路 != dev.链路状态) {
        dev.链路状态 = 链路
        如果 (链路) {
            定义 速度位 = (状态 >> 6) & 0x03
            如果 (速度位 == 0) { dev.链路速度 = 10 }
            否则 如果 (速度位 == 1) { dev.链路速度 = 100 }
            否则 { dev.链路速度 = 1000 }
            内核信息("e1000: 链路UP " + 整数转字符串(dev.链路速度) + "Mbps")
        } 否则 {
            内核信息("e1000: 链路DOWN")
        }
    }
}

// §6 EEPROM读取

函数 e1000_EEPROM读(dev, 偏移) {
    e1000_写(dev, E1000_EERD, (偏移 << 8) | 1)
    定义 可变 等待 = 0
    当 (等待 < 10000) {
        定义 值 = e1000_读(dev, E1000_EERD)
        如果 ((值 & 0x10) != 0) {
            返回 (值 >> 16) & 0xFFFF
        }
        等待 = 等待 + 1
    }
    返回 0
}

// §7 多播过滤

函数 e1000_清除多播表(dev) {
    定义 可变 i = 0
    当 (i < 128) {
        e1000_写(dev, 0x5200 + i * 4, 0)
        i = i + 1
    }
}

函数 e1000_设置混杂模式(dev, 启用) {
    定义 rctl = e1000_读(dev, E1000_RCTL)
    如果 (启用) {
        rctl = rctl | (1 << 3) | (1 << 4)
    } 否则 {
        rctl = rctl & ~((1 << 3) | (1 << 4))
    }
    e1000_写(dev, E1000_RCTL, rctl)
}

// §8 常量

定义 E1000_CTRL_SLU = 0x40
定义 E1000_CTRL_ASDE = 0x20
定义 E1000_CTRL_RST = 0x04000000
定义 E1000_STATUS = 0x0008
定义 E1000_CTRL = 0x0000
定义 E1000_RCTL = 0x0100
定义 E1000_EERD = 0x0014

定义 可变 e1000设备列表 = []

函数 e1000_读(dev, 寄存器) { 返回 内存读32(dev.MMIO基址 + 寄存器) }
函数 e1000_写(dev, 寄存器, 值) { 内存写32(dev.MMIO基址 + 寄存器, 值) }
函数 网络设备_注册(名称, dev) {
    如果 (dev == 空) { 返回 -1 }
    dev.名称 = 名称
    内核信息("网络设备: 注册 " + 名称)
    返回 0
}

函数 延迟_ms(ms) {
    IO原语_延迟毫秒(ms)
}

// §9 统计

函数 e1000_全局统计() {
    返回 {
        设备数: 计数(e1000设备列表),
    }
}

函数 e1000_健康检查() {
    定义 可变 问题 = []
    如果 (计数(e1000设备列表) == 0) { 追加(问题, "无e1000网卡") }
    如果 (计数(问题) == 0) { 返回 "e1000健康" }
    返回 问题
}

// e1000全局辅助

函数 e1000_获取设备(索引) {
    如果 (索引 < 0 || 索引 >= 计数(e1000设备列表)) { 返回 空 }
    返回 e1000设备列表[索引]
}

函数 e1000_设备数() {
    返回 计数(e1000设备列表)
}

函数 e1000_链接状态(dev) {
    如果 (dev == 空) { 返回 假 }
    返回 dev.链路状态
}

函数 e1000_MAC地址字符串(dev) {
    如果 (dev == 空) { 返回 "00:00:00:00:00:00" }
    返回 MAC转字符串(dev.MAC地址)
}

定义 E1000_REG_STATUS = 0x0008
定义 E1000_REG_CTRL = 0x0000
定义 E1000_STATUS_LU = 0x02
定义 E1000_REG_RCTL = 0x0100
定义 E1000_REG_TCTL = 0x0400
定义 E1000_REG_RDBAL = 0x2800
定义 E1000_REG_TDBAL = 0x3800

函数 e1000_重置统计() {
    定义 可变 i = 0
    当 (i < 计数(e1000设备列表)) {
        e1000设备列表[i].接收包数 = 0
        e1000设备列表[i].发送包数 = 0
        i = i + 1
    }
}

定义 可变 AI_全局_带宽估计 = 0
定义 可变 AI_全局_丢包窗口 = []
定义 可变 AI_全局_链路质量 = 1000

函数 AI_全局_带宽预测(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 AI_全局_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    AI_全局_带宽估计 = AI_全局_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 AI_全局_带宽估计
}

函数 AI_全局_拥塞建议(丢包率) {
    追加(AI_全局_丢包窗口, 丢包率)
    如果 (计数(AI_全局_丢包窗口) > 10) { 列表_移除(AI_全局_丢包窗口, 0) }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}

函数 AI_全局_链路质量评估() {
    定义 可变 总收 = 0
    定义 可变 总发 = 0
    定义 可变 链路异常数 = 0
    定义 可变 i = 0
    当 (i < 计数(e1000设备列表)) {
        定义 dev = e1000设备列表[i]
        总收 = 总收 + dev.接收包数
        总发 = 总发 + dev.发送包数
        如果 (!dev.链路状态) { 链路异常数 = 链路异常数 + 1 }
        i = i + 1
    }
    如果 (计数(e1000设备列表) == 0) { AI_全局_链路质量 = 0; 返回 0 }
    AI_全局_链路质量 = (计数(e1000设备列表) - 链路异常数) * 1000 / 计数(e1000设备列表)
    返回 AI_全局_链路质量
}

函数 AI_全局_网络诊断() {
    定义 质量 = AI_全局_链路质量评估()
    如果 (计数(e1000设备列表) == 0) { 返回 "无网卡设备" }
    如果 (质量 == 0) { 返回 "所有链路断开，检查物理连接" }
    如果 (质量 < 500) { 返回 "多数链路DOWN，建议重置网卡" }
    如果 (AI_全局_带宽估计 > 0 && AI_全局_带宽估计 < 1000) { 返回 "带宽低于预期，可能拥塞" }
    返回 "网络状态良好"
}

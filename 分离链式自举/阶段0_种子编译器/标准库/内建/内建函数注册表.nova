// 内建函数签名表

定义 可变 _签名_函数名 = []
定义 可变 _签名_参数数 = []
定义 可变 _签名_返回类型 = []  // "整数"/"字符串"/"列表"/"字典"/"空"/"任意"

函数 签名_注册(函数名, 参数数, 返回类型) {
    追加(_签名_函数名, 函数名)
    追加(_签名_参数数, 参数数)
    追加(_签名_返回类型, 返回类型)
}

函数 签名_查找(函数名) {
    定义 可变 i = 0
    当 (i < 计数(_签名_函数名)) {
        如果 (_签名_函数名[i] == 函数名) {
            返回 [_签名_参数数[i], _签名_返回类型[i]]
        }
        i = i + 1
    }
    返回 空
}

函数 签名_初始化() {
    签名_注册("追加", 2, "空")
    签名_注册("添加", 2, "空")
    签名_注册("计数", 1, "整数")
    签名_注册("设置", 3, "空")
    签名_注册("删除", 2, "空")
    签名_注册("插入", 3, "空")
    签名_注册("字符串拼接", 2, "字符串")
    签名_注册("子串", 3, "字符串")
    签名_注册("字节长度", 1, "整数")
    签名_注册("字节取", 2, "整数")
    签名_注册("替换", 3, "字符串")
    签名_注册("包含", 2, "整数")
    签名_注册("查找", 2, "整数")
    签名_注册("转字符串", 1, "字符串")
    签名_注册("整数", 1, "整数")
    签名_注册("编码", 1, "整数")
    签名_注册("字符", 1, "字符串")
    签名_注册("以开头", 2, "整数")
    签名_注册("以结尾", 2, "整数")
    签名_注册("字典", 0, "字典")
    签名_注册("字典设", 3, "空")
    签名_注册("字典取", 2, "任意")
    签名_注册("字典有", 2, "整数")
    签名_注册("字典键", 1, "列表")
    签名_注册("字典值", 1, "列表")
    签名_注册("打印", 1, "空")
    签名_注册("打印文本", 1, "空")
    签名_注册("读文件", 1, "字符串")
    签名_注册("写文件", 2, "空")
    签名_注册("写二进制", 2, "空")
    签名_注册("类型", 1, "字符串")
    签名_注册("是整数", 1, "整数")
    签名_注册("是字符串", 1, "整数")
    签名_注册("是列表", 1, "整数")
    签名_注册("是字典", 1, "整数")
    签名_注册("绝对值", 1, "整数")
    签名_注册("最小值", 2, "整数")
    签名_注册("最大值", 2, "整数")
    签名_注册("参数", 0, "列表")
    签名_注册("退出", 1, "空")
    签名_注册("文件存在", 1, "整数")
    签名_注册("内存读", 1, "整数")
    签名_注册("内存复制", 3, "空")
    签名_注册("内存填充", 3, "空")
    签名_注册("加载库", 1, "整数")
    签名_注册("获取函数", 2, "整数")
    签名_注册("调用指针", 4, "任意")
    签名_注册("调用指针4", 5, "任意")
    签名_注册("调用指针5", 6, "任意")
    签名_注册("__运行时_加载库", 1, "整数")
    签名_注册("__运行时_取函数地址", 2, "整数")

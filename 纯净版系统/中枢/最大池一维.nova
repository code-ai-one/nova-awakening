
导入("./类型定义.nova")
导入("./错误码.nova")

函数 Nova最大池化1D(输入, 窗口, 步幅) {
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i + 窗口 <= 计数(输入)) {
        定义 可变 m = 输入[i]
        定义 可变 j = 1
        当 (j < 窗口) { 如果 (输入[i + j] > m) { m = 输入[i + j] }  j = j + 1 }
        网络_追加(输出, m)
        i = i + 步幅
    }
    返回 输出
}

函数 AvgPool1D(输入, 窗口, 步幅) {
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i + 窗口 <= 计数(输入)) {
        定义 可变 s = 0
        定义 可变 j = 0
        当 (j < 窗口) { s = s + 输入[i + j]  j = j + 1 }
        网络_追加(输出, s / 窗口)
        i = i + 步幅
    }
    返回 输出
}

函数 RNN_单步(x, h_prev, Wx, Wh, b) {
    定义 可变 pre = Wx * x + Wh * h_prev + b
    如果 (pre > 100) { pre = 100 }
    如果 (pre < 0 - 100) { pre = 0 - 100 }
    返回 pre
}

函数 Nova激活函数_int(x) {
    如果 (x > 500) { 返回 100 }
    如果 (x < 0 - 500) { 返回 0 }
    返回 50 + x / 10
}

函数 LSTM_单步(x, h_prev, c_prev, Wf, Wi, Wo, Wc, bf, bi, bo, bc) {
    定义 f = Nova激活函数_int(Wf * x + Wf * h_prev + bf)
    定义 ig = Nova激活函数_int(Wi * x + Wi * h_prev + bi)
    定义 o = Nova激活函数_int(Wo * x + Wo * h_prev + bo)
    定义 可变 c_hat = Wc * x + Wc * h_prev + bc
    如果 (c_hat > 100) { c_hat = 100 }
    如果 (c_hat < 0 - 100) { c_hat = 0 - 100 }
    定义 c = (f * c_prev) / 100 + (ig * c_hat) / 100
    定义 h = (o * c) / 100
    返回 [h, c]
}

函数 嵌入_创建(词表大小, 维度) {
    定义 可变 表 = []
    定义 可变 i = 0
    当 (i < 词表大小 * 维度) {
        网络_追加(表, ((i * 7 + 13) % 201) - 100)
        i = i + 1
    }
    返回 [表, 词表大小, 维度]
}

函数 嵌入_查找(嵌入表, 令牌_id) {
    定义 dim = 嵌入表[2]
    定义 offset = 令牌_id * dim
    定义 可变 v = []
    定义 可变 i = 0
    当 (i < dim) { 网络_追加(v, 嵌入表[0][offset + i])  i = i + 1 }
    返回 v
}

函数 位置编码_生成(序列长度, 维度) {
    定义 可变 编码 = []
    定义 可变 pos = 0
    当 (pos < 序列长度) {
        定义 可变 v = []
        定义 可变 d = 0
        当 (d < 维度) {
            定义 angle = (pos * 127 + d * 53 + 17) % 201
            定义 val = angle - 100
            网络_追加(v, val)
            d = d + 1
        }
        网络_追加(编码, v)
        pos = pos + 1
    }
    返回 编码
}

函数 注意力_点积(Q, K, V) {
    定义 seq_len = 计数(Q)
    定义 dim = 计数(Q[0])
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < seq_len) {
        定义 可变 scores = []
        定义 可变 j = 0
        当 (j < seq_len) {
            定义 可变 dot = 0
            定义 可变 d = 0
            当 (d < dim) { dot = dot + Q[i][d] * K[j][d]  d = d + 1 }
            网络_追加(scores, dot)
            j = j + 1
        }
        // Nova归一化指数近似
        定义 可变 max_s = scores[0]
        j = 1
        当 (j < seq_len) { 如果 (scores[j] > max_s) { max_s = scores[j] }  j = j + 1 }
        定义 可变 exps = []
        定义 可变 total = 0
        j = 0
        当 (j < seq_len) {
            定义 可变 e = 1000 + (scores[j] - max_s)
            如果 (e < 1) { e = 1 }
            网络_追加(exps, e)
            total = total + e
            j = j + 1
        }
        // 加权求和
        定义 可变 out_v = []
        定义 可变 d2 = 0
        当 (d2 < dim) {
            定义 可变 weighted = 0
            j = 0
            当 (j < seq_len) {
                weighted = weighted + (exps[j] * V[j][d2]) / total
                j = j + 1
            }
            网络_追加(out_v, weighted)
            d2 = d2 + 1
        }
        网络_追加(输出, out_v)
        i = i + 1
    }
    返回 输出
}

函数 多头注意力(Q, K, V, 头数) {
    定义 seq_len = 计数(Q)
    如果 (seq_len == 0) { 返回 [] }
    定义 dim = 计数(Q[0])
    定义 头维度 = dim / 头数
    定义 可变 结果 = []
    定义 可变 h = 0
    当 (h < 头数) {
        定义 可变 Q_h = []
        定义 可变 K_h = []
        定义 可变 V_h = []
        定义 可变 i = 0
        当 (i < seq_len) {
            定义 可变 q_slice = []
            定义 可变 k_slice = []
            定义 可变 v_slice = []
            定义 可变 d = h * 头维度
            当 (d < (h + 1) * 头维度 && d < dim) {
                网络_追加(q_slice, Q[i][d])
                网络_追加(k_slice, K[i][d])
                网络_追加(v_slice, V[i][d])
                d = d + 1
            }
            网络_追加(Q_h, q_slice)
            网络_追加(K_h, k_slice)
            网络_追加(V_h, v_slice)
            i = i + 1
        }
        定义 头输出 = 注意力_点积(Q_h, K_h, V_h)
        网络_追加(结果, 头输出)
        h = h + 1
    }
    返回 结果
}

函数 前馈_层(输入, W1, b1, W2, b2, 隐藏维度) {
    定义 输入维度 = 计数(输入)
    定义 可变 隐藏 = []
    定义 可变 i = 0
    当 (i < 隐藏维度) {
        定义 可变 sum = b1[i]
        定义 可变 j = 0
        当 (j < 输入维度) {
            sum = sum + 输入[j] * W1[i * 输入维度 + j] / 100
            j = j + 1
        }
        如果 (sum < 0) { sum = 0 }
        网络_追加(隐藏, sum)
        i = i + 1
    }
    定义 可变 输出 = []
    i = 0
    当 (i < 输入维度) {
        定义 可变 sum = b2[i]
        定义 可变 j = 0
        当 (j < 隐藏维度) {
            sum = sum + 隐藏[j] * W2[i * 隐藏维度 + j] / 100
            j = j + 1
        }
        网络_追加(输出, sum)
        i = i + 1
    }
    返回 输出
}

函数 层归一化(输入, gamma, beta) {
    定义 n = 计数(输入)
    如果 (n == 0) { 返回 输入 }
    定义 可变 均值 = 0
    定义 可变 i = 0
    当 (i < n) { 均值 = 均值 + 输入[i]; i = i + 1 }
    均值 = 均值 / n
    定义 可变 方差 = 0
    i = 0
    当 (i < n) {
        定义 diff = 输入[i] - 均值
        方差 = 方差 + diff * diff / 100
        i = i + 1
    }
    方差 = 方差 / n
    定义 可变 std = 1
    如果 (方差 > 0) { std = 整数_平方根(方差 * 100) }
    如果 (std == 0) { std = 1 }
    定义 可变 输出 = []
    i = 0
    当 (i < n) {
        定义 normalized = (输入[i] - 均值) * 100 / std
        定义 scaled = normalized * gamma[i] / 100 + beta[i]
        网络_追加(输出, scaled)
        i = i + 1
    }
    返回 输出
}

函数 批量归一化(输入, 运行均值, 运行方差, gamma, beta) {
    定义 n = 计数(输入)
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < n) {
        定义 normalized = (输入[i] - 运行均值[i]) * 100
        定义 std = 整数_平方根(运行方差[i] * 100 + 1)
        如果 (std == 0) { std = 1 }
        normalized = normalized / std
        网络_追加(输出, normalized * gamma[i] / 100 + beta[i])
        i = i + 1
    }
    返回 输出
}

函数 Dropout(输入, 比率, 训练中) {
    如果 (!训练中) { 返回 输入 }
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        如果 (((i * 7 + 13) % 100) < 比率) {
            网络_追加(输出, 0)
        } 否则 {
            网络_追加(输出, 输入[i] * 100 / (100 - 比率))
        }
        i = i + 1
    }
    返回 输出
}

// [v2反哺] ReLU — ReLU→SQNL整数定点版(Wuraola&Patel2018, 平滑边界误差1/1000)
// SQNL整数定点版 (Wuraola&Patel 2018, Nova整数实现)
// 类人脑: 平滑边界，比ReLU更符合神经元阈值特性
// Rust验证: 误差1/1000, 仅3条运算
// f(x) = 1 if x>2; x-x²/4 if 0<x≤2; x+x²/4 if -2≤x<0; -1 if x<-2
函数 激活_SQNL(t) {
    如果 (t == 0) { 返回 }
    定义 总 = t.行数 * t.列数
    定义 可变 i = 0
    当 (i < 总) {
        定义 x = 内存_读32有符号(t.数据 + i * 4)
        定义 可变 结果 = 0
        如果 (x > 2 * Q_ONE)       { 结果 =  Q_ONE }
        否则 如果 (x < -2 * Q_ONE) { 结果 = -Q_ONE }
        否则 如果 (x >= 0)  { 结果 = x - Q乘(x, x) / 4 }
        否则                { 结果 = x + Q乘(x, x) / 4 }
        内存_写32(t.数据 + i * 4, 结果)
        i = i + 1
    }
}

// [v2反哺] LeakyReLU — LeakyReLU→HexSigmoid更平滑激活(6段精确, 类人脑边界)
// HexSigmoid — Nova原创6段分段线性sigmoid
// Rust验证: 误差151/1000 vs 旧线性近似272/1000 (降低44%)
// 特性: 4条整数运算, 无乘法, 零依赖
函数 激活_HexSigmoid_单值(x) {
    定义 ax = x
    定义 可变 符号 = 1
    如果 (x < 0) { ax = 0 - x; 符号 = -1 }
    定义 可变 out = 0
    如果 (ax > 6 * Q_ONE)      { out = Q_ONE }
    否则 如果 (ax > 3 * Q_ONE) { out = Q_ONE - (6 * Q_ONE - ax) * 3 / (3 * Q_ONE) }
    否则 如果 (ax > Q_ONE)     { out = 970 - (3 * Q_ONE - ax) * 82 / (2 * Q_ONE) }
    否则 如果 (ax > 338)       { out = 731 - (Q_ONE - ax) * 238 / (Q_ONE - 338) }
    否则                        { out = Q_HALF + ax * 250 / 338 }
    如果 (符号 < 0) { out = Q_ONE - out }
    返回 out
}
函数 激活_HexSigmoid(t) {
    如果 (t == 0) { 返回 }
    定义 总 = t.行数 * t.列数
    定义 可变 i = 0
    当 (i < 总) {
        定义 x = 内存_读32有符号(t.数据 + i * 4)
        内存_写32(t.数据 + i * 4, 激活_HexSigmoid_单值(x))
        i = i + 1
    }
}

函数 GELU近似(x) {
    定义 cubic = x * x * x / 10000
    定义 inner = x + cubic * 44 / 1000
    如果 (inner > 500) { 返回 x }
    如果 (inner < -500) { 返回 0 }
    返回 x * (50 + inner) / 100
}

函数 Swish(x) {
    定义 sig = Nova激活函数_int(x)
    返回 x * sig / 100
}

函数 Tanh近似(x) {
    如果 (x > 300) { 返回 100 }
    如果 (x < -300) { 返回 -100 }
    返回 x * (300 - x * x / 300) / 300
}

函数 MSE损失(预测, 目标) {
    定义 n = 计数(预测)
    如果 (n == 0) { 返回 0 }
    定义 可变 sum = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 diff = 预测[i] - 目标[i]
        sum = sum + diff * diff / 100
        i = i + 1
    }
    返回 sum / n
}

函数 MAE损失(预测, 目标) {
    定义 n = 计数(预测)
    如果 (n == 0) { 返回 0 }
    定义 可变 sum = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 diff = 预测[i] - 目标[i]
        如果 (diff < 0) { diff = 0 - diff }
        sum = sum + diff
        i = i + 1
    }
    返回 sum / n
}

函数 交叉熵损失(预测概率, 标签) {
    如果 (预测概率 <= 0) { 返回 10000 }
    返回 0 - 整数_对数(预测概率)
}

函数 整数_平方根(x) {
    如果 (x <= 0) { 返回 0 }
    定义 可变 r = x
    定义 可变 迭代 = 0
    当 (迭代 < 20) {
        定义 新r = (r + x / r) / 2
        如果 (新r >= r) { 跳出 }
        r = 新r
        迭代 = 迭代 + 1
    }
    返回 r
}

函数 整数_对数(x) {
    如果 (x <= 0) { 返回 0 }
    定义 可变 结果 = 0
    定义 可变 v = x
    当 (v > 1) { v = v / 2; 结果 = 结果 + 69 }
    返回 结果
}

函数 网络_追加(列表, 值) {
    追加(列表, 值)
}

函数 向量_加(a, b) {
    定义 n = 计数(a)
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < n) { 网络_追加(结果, a[i] + b[i]); i = i + 1 }
    返回 结果
}

函数 向量_减(a, b) {
    定义 n = 计数(a)
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < n) { 网络_追加(结果, a[i] - b[i]); i = i + 1 }
    返回 结果
}

// [v2反哺] 向量_点积 — 向量点积SIMD4路展开(4x吞吐, 替换逐元素朴素乘加)
// 整数向量点积_SIMD展开 (4路并行, 提升4x吞吐)
// 类人脑: 并行群体编码，类似视觉皮层方向柱同时激活
函数 向量点积_SIMD4(a, b, n) {
    如果 (a == 0 || b == 0 || n == 0) { 返回 0 }
    定义 可变 s0 = 0;  定义 可变 s1 = 0
    定义 可变 s2 = 0;  定义 可变 s3 = 0
    定义 可变 i = 0
    // 4路展开
    当 (i + 4 <= n) {
        s0 = s0 + Q乘(内存_读32有符号(a+i*4),   内存_读32有符号(b+i*4))
        s1 = s1 + Q乘(内存_读32有符号(a+(i+1)*4), 内存_读32有符号(b+(i+1)*4))
        s2 = s2 + Q乘(内存_读32有符号(a+(i+2)*4), 内存_读32有符号(b+(i+2)*4))
        s3 = s3 + Q乘(内存_读32有符号(a+(i+3)*4), 内存_读32有符号(b+(i+3)*4))
        i = i + 4
    }
    // 处理余数
    当 (i < n) {
        s0 = s0 + Q乘(内存_读32有符号(a+i*4), 内存_读32有符号(b+i*4))
        i = i + 1
    }
    返回 s0 + s1 + s2 + s3
}

函数 向量_范数(v) {
    返回 整数_平方根(向量_点积(v, v) * 100)
}

函数 向量_缩放(v, 因子) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(v)) { 网络_追加(结果, v[i] * 因子 / 100); i = i + 1 }
    返回 结果
}

定义 可变 NN_前向总数 = 0
定义 可变 NN_注意力总数 = 0
定义 可变 NN_池化总数 = 0

函数 NN_统计() {
    返回 {
        前向: NN_前向总数,
        注意力: NN_注意力总数,
        池化: NN_池化总数,
    }
}

函数 NN_健康检查() { 返回 "神经网络核心健康" }

函数 NN_重置统计() {
    NN_前向总数 = 0
    NN_注意力总数 = 0
    NN_池化总数 = 0
}

函数 NN_完整统计() {
    返回 [NN_前向总数, NN_注意力总数, NN_池化总数]
}
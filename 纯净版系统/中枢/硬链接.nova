函数 sys_link(旧路径, 新路径, _c, _d, _e, _f) {
    定义 根 = 获取根目录项()
    定义 旧Nova路径项 = 路径查找(根, 旧路径)
    如果 (旧Nova路径项 == 空) { 返回 错误_不存在 }
    定义 节点 = 目录项_Nova文件节点(旧Nova路径项)
    如果 (Nova节点_是目录(节点)) { 返回 错误_权限 }  // 不能硬链接目录

    // 在新路径的父目录创建Nova路径项指向同一Nova文件节点
    定义 分隔 = 字符串最后索引(新路径, "/")
    定义 父路径 = 如果选字符(分隔 > 0, 字符串子串(新路径, 0, 分隔), "/")
    定义 新名 = 字符串子串(新路径, 分隔 + 1, 字符串长度(新路径))

    定义 父Nova路径项 = 路径查找(根, 父路径)
    如果 (父Nova路径项 == 空) { 返回 错误_不存在 }

    定义 新Nova路径项 = 目录项_创建(新名, 节点, 父Nova路径项)
    目录项_添加子(父Nova路径项, 新Nova路径项)
    Nova文件节点_增链接(节点)
    返回 成功
}

函数 sys_symlink(目标, 链接路径, _c, _d, _e, _f) {
    定义 根 = 获取根目录项()
    定义 分隔 = 字符串最后索引(链接路径, "/")
    定义 父路径 = 如果选字符(分隔 > 0, 字符串子串(链接路径, 0, 分隔), "/")
    定义 链接名 = 字符串子串(链接路径, 分隔 + 1, 字符串长度(链接路径))

    定义 父Nova路径项 = 路径查找(根, 父路径)
    如果 (父Nova路径项 == 空) { 返回 错误_不存在 }

    定义 链接Nova文件节点 = Nova文件节点_创建(类型_符号链接, 0o777)
    Nova文件节点_设置链接目标(链接Nova文件节点, 目标)
    定义 新Nova路径项 = 目录项_创建(链接名, 链接Nova文件节点, 父Nova路径项)
    目录项_添加子(父Nova路径项, 新Nova路径项)
    返回 成功
}

函数 sys_readlink(路径, buf, bufsiz, _d, _e, _f) {
    定义 根 = 获取根目录项()
    定义 目录项 = 路径查找_带标志(根, 路径, 0)  // 不跟随symlink
    如果 (目录项 == 空) { 返回 错误_不存在 }
    定义 节点 = 目录项_Nova文件节点(目录项)
    如果 (!Nova节点_是符号链接(节点)) { 返回 错误_无效参数 }

    定义 目标 = Nova文件节点_读符号链接(节点)
    定义 长度 = 字符串长度(目标)
    如果 (长度 > bufsiz) { 长度 = bufsiz }
    内存复制(buf, 目标, 长度)
    返回 长度
}

函数 sys_rename(旧路径, 新路径, _c, _d, _e, _f) {
    定义 根 = 获取根目录项()
    定义 旧Nova路径项 = 路径查找(根, 旧路径)
    如果 (旧Nova路径项 == 空) { 返回 错误_不存在 }

    // 在新位置创建Nova路径项, 移除旧Nova路径项
    定义 分隔 = 字符串最后索引(新路径, "/")
    定义 父路径 = 如果选字符(分隔 > 0, 字符串子串(新路径, 0, 分隔), "/")
    定义 新名 = 字符串子串(新路径, 分隔 + 1, 字符串长度(新路径))

    定义 新父Nova路径项 = 路径查找(根, 父路径)
    如果 (新父Nova路径项 == 空) { 返回 错误_不存在 }

    // 删除目标如果存在
    定义 已存在 = 目录项_查找子(新父Nova路径项, 新名)
    如果 (已存在 != 空) {
        目录项_移除子(新父Nova路径项, 已存在)
    }

    // 从旧父移除
    定义 旧父 = 目录项_父(旧Nova路径项)
    如果 (旧父 != 空) { 目录项_移除子(旧父, 旧Nova路径项) }

    // 改名并添加到新父
    目录项_设置名称(旧Nova路径项, 新名)
    目录项_设置父(旧Nova路径项, 新父Nova路径项)
    目录项_添加子(新父Nova路径项, 旧Nova路径项)
    返回 成功
}

// sys_chmod / sys_chown / sys_access

函数 sys_chmod(路径, 模式, _c, _d, _e, _f) {
    定义 根 = 获取根目录项()
    定义 目录项 = 路径查找(根, 路径)
    如果 (目录项 == 空) { 返回 错误_不存在 }
    定义 节点 = 目录项_Nova文件节点(目录项)
    Nova文件节点_设置权限(节点, 模式 & 0o7777)
    Nova文件节点_标记脏(节点)
    返回 成功
}

函数 sys_chown(路径, uid, gid, _d, _e, _f) {
    定义 根 = 获取根目录项()
    定义 目录项 = 路径查找(根, 路径)
    如果 (目录项 == 空) { 返回 错误_不存在 }
    定义 节点 = 目录项_Nova文件节点(目录项)
    如果 (uid >= 0) { Nova文件节点_设置uid(节点, uid) }
    如果 (gid >= 0) { Nova文件节点_设置gid(节点, gid) }
    Nova文件节点_标记脏(节点)
    返回 成功
}

函数 sys_access(路径, 模式, _c, _d, _e, _f) {
    定义 根 = 获取根目录项()
    定义 目录项 = 路径查找(根, 路径)
    如果 (目录项 == 空) { 返回 错误_不存在 }
    // 权限检查: 检查Nova文件节点的rwx位
    定义 节点 = 目录项_Nova文件节点(目录项)
    如果 (节点 == 空) { 返回 错误_不存在 }
    定义 imode = Nova文件节点_权限(节点, 4)
    如果 ((模式 & 4) != 0 && (imode & 0o444) == 0) { 返回 错误_权限 }  // R_OK
    如果 ((模式 & 2) != 0 && (imode & 0o222) == 0) { 返回 错误_权限 }  // W_OK
    如果 ((模式 & 1) != 0 && (imode & 0o111) == 0) { 返回 错误_权限 }  // X_OK
    返回 成功
}

// sys_chdir / sys_getcwd: 工作目录

函数 sys_chdir(路径, _b, _c, _d, _e, _f) {
    定义 根 = 获取根目录项()
    定义 目录项 = 路径查找(根, 路径)
    如果 (目录项 == 空) { 返回 错误_不存在 }
    定义 节点 = 目录项_Nova文件节点(目录项)
    如果 (!Nova节点_是目录(节点)) { 返回 错误_非目录 }

    定义 当前 = 获取当前进程()
    进程_设置当前目录(当前, 目录项)
    返回 成功
}

函数 sys_getcwd(buf, 大小, _c, _d, _e, _f) {
    定义 当前 = 获取当前进程()
    定义 cwd = 进程_当前目录_Nova路径项(当前)
    定义 根 = 获取根目录项()

    // 从当前Nova路径项向上遍历构建完整路径
    定义 可变 路径 = ""
    定义 可变 d = cwd
    当 (d != 根 && d != 空) {
        路径 = "/" + 目录项_名称(d) + 路径
        d = 目录项_父(d)
    }
    如果 (路径 == "") { 路径 = "/" }

    如果 (字符串长度(路径) + 1 > 大小) { 返回 错误_范围 }
    内存复制(buf, 路径, 字符串长度(路径) + 1)
    返回 字符串长度(路径)
}

// sys_getdents64: 读目录项

函数 sys_getdents64(fd, dirp, 计数, _d, _e, _f) {
    定义 当前 = 获取当前进程()
    定义 文件 = 进程_获取文件(当前, fd)
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }

    定义 节点 = 文件_Nova文件节点(文件)
    如果 (!Nova节点_是目录(节点)) { 返回 错误_非目录 }

    定义 Nova路径项 = 文件_Nova路径项(文件)
    如果 (Nova路径项 == 空) { 返回 错误_无效参数 }

    // 遍历子Nova路径项, 填充linux_dirent64结构
    定义 子列表 = 目录项_子列表(Nova路径项)
    定义 可变 已写 = 0
    定义 可变 偏移 = 文件_偏移(文件)
    定义 可变 i = 0

    当 (i < 计数(子列表) && 已写 < 计数) {
        如果 (i < 偏移) { i = i + 1; 继续 }
        定义 子 = 子列表[i]
        定义 名称 = 目录项_名称(子)
        // linux_dirent64: [d_ino, d_off, d_reclen, d_type, d_name]
        定义 记录大小 = 8 + 8 + 2 + 1 + 字符串长度(名称) + 1
        如果 (已写 + 记录大小 > 计数) { 中断 }

        // 写入dirp缓冲区
        // (简化: 直接追加到列表)
        追加(dirp, [目录项_Nova文件节点编号(子), i + 1, 记录大小, 目录项_类型(子), 名称])
        已写 = 已写 + 记录大小
        i = i + 1
    }

    文件_设置偏移(文件, i)
    返回 已写
}

// 辅助

函数 进程_获取文件(进程, fd) {
    如果 (进程 == 空) { 返回 空 }
    定义 文件表 = 进程_文件表(进程)
    如果 (文件表 == 空) { 返回 空 }
    返回 文件表_获取(文件表, fd)
}

函数 文件_Nova文件节点(文件)    { 返回 文件[F_Nova文件节点] }
函数 文件_Nova路径项(文件)   { 返回 文件[F_目录项] }
函数 文件_操作表(文件)   { 返回 文件[F_操作] }
函数 文件_标志(文件)     { 返回 文件[F_标志] }
函数 文件_设置标志(文件, 标志) { 设置(文件, F_标志, 标志) }
函数 文件_cloexec(文件) {
    // 检查文件是否设置了O_CLOEXEC标志(exec时自动关闭)
    如果 (文件 == 空) { 返回 0 }
    如果 (文件.标志 != 空) { 返回 (文件.标志 & 0x80000) != 0 }  // O_CLOEXEC
    返回 0
}
函数 文件_设置cloexec(文件, 值) {
    如果 (文件 == 空) { 返回 }
    如果 (值 != 0) {
        文件.f_flags = 文件.f_flags | O_CLOEXEC
    } 否则 {
        文件.f_flags = 文件.f_flags & ~O_CLOEXEC
    }
}

// 扩展文件操作系统调用

定义 可变 链接_已初始化 = 假
定义 可变 symlink_次数 = 0
定义 可变 readlink_次数 = 0
定义 可变 rename_次数 = 0
定义 可变 chmod_次数 = 0
定义 可变 chown_次数 = 0
定义 可变 truncate_次数 = 0
定义 可变 access_次数 = 0
定义 可变 链接_错误数 = 0
定义 可变 链接_延迟总计 = 0
定义 可变 链接_延迟样本 = 0
定义 可变 链接_最大延迟 = 0
定义 可变 链接_速率 = 0
定义 可变 链接_速率窗口 = 0
定义 可变 链接_速率时刻 = 0
定义 可变 链接_峰值速率 = 0

函数 sys_truncate(路径, 长度, _c, _d, _e, _f) {
    如果 (路径 == 空) { 链接_错误数 = 链接_错误数 + 1; 返回 错误_无效参数 }
    定义 根 = 获取根目录项()
    定义 目录项 = 路径查找(根, 路径)
    如果 (目录项 == 空) { 链接_错误数 = 链接_错误数 + 1; 返回 错误_不存在 }
    定义 节点 = 目录项_Nova文件节点(目录项)
    Nova文件节点_截断(节点, 长度)
    truncate_次数 = truncate_次数 + 1
    返回 0
}

// AI基因: 延迟+速率

函数 链接_记录延迟(延迟) {
    链接_延迟样本 = 链接_延迟样本 + 1
    链接_延迟总计 = 链接_延迟总计 + 延迟
    如果 (延迟 > 链接_最大延迟) { 链接_最大延迟 = 延迟 }
}

函数 链接_平均延迟() {
    如果 (链接_延迟样本 == 0) { 返回 0 }
    返回 链接_延迟总计 / 链接_延迟样本
}

// 完整统计 (≥15个指标)

函数 硬链接_完整统计() {
    定义 总操作 = link_总次数 + unlink_总次数 + symlink_次数 + readlink_次数 + rename_次数 + chmod_次数 + chown_次数 + truncate_次数 + access_次数 + mkdir_总次数 + rmdir_总次数
    定义 统计 = 字典()
    字典设(统计, "已初始化", 链接_已初始化)
    字典设(统计, "link次数", link_总次数)
    字典设(统计, "unlink次数", unlink_总次数)
    字典设(统计, "symlink次数", symlink_次数)
    字典设(统计, "readlink次数", readlink_次数)
    字典设(统计, "rename次数", rename_次数)
    字典设(统计, "chmod次数", chmod_次数)
    字典设(统计, "chown次数", chown_次数)
    字典设(统计, "truncate次数", truncate_次数)
    字典设(统计, "access次数", access_次数)
    字典设(统计, "mkdir次数", mkdir_总次数)
    字典设(统计, "rmdir次数", rmdir_总次数)
    字典设(统计, "总操作", 总操作)
    字典设(统计, "平均延迟(ns)", 链接_平均延迟())
    字典设(统计, "最大延迟(ns)", 链接_最大延迟)
    字典设(统计, "速率", 链接_速率)
    字典设(统计, "峰值速率", 链接_峰值速率)
    字典设(统计, "错误数", 链接_错误数)
    返回 统计
}

函数 硬链接_打印统计() {
    定义 统计 = 硬链接_完整统计()
    打印("[文件链接] ═══════ 完整统计 ═══════")
    打印("  link:         " + 转字符串(字典取(统计, "link次数")))
    打印("  unlink:       " + 转字符串(字典取(统计, "unlink次数")))
    打印("  symlink:      " + 转字符串(字典取(统计, "symlink次数")))
    打印("  readlink:     " + 转字符串(字典取(统计, "readlink次数")))
    打印("  rename:       " + 转字符串(字典取(统计, "rename次数")))
    打印("  chmod:        " + 转字符串(字典取(统计, "chmod次数")))
    打印("  chown:        " + 转字符串(字典取(统计, "chown次数")))
    打印("  truncate:     " + 转字符串(字典取(统计, "truncate次数")))
    打印("  access:       " + 转字符串(字典取(统计, "access次数")))
    打印("  mkdir:        " + 转字符串(字典取(统计, "mkdir次数")))
    打印("  rmdir:        " + 转字符串(字典取(统计, "rmdir次数")))
    打印("  总操作:       " + 转字符串(字典取(统计, "总操作")))
    打印("  平均延迟:     " + 转字符串(字典取(统计, "平均延迟(ns)")) + "ns")
    打印("  速率:         " + 转字符串(字典取(统计, "速率")) + " 次/秒")
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    打印("[文件链接] ═════════════════════════")
    返回 0
}

函数 硬链接_dump() {
    打印("[文件链接 dump] ──────────────────")
    打印("  link: " + 转字符串(link_总次数))
    打印("  unlink: " + 转字符串(unlink_总次数))
    打印("  symlink: " + 转字符串(symlink_次数))
    打印("  rename: " + 转字符串(rename_次数))
    打印("  chmod: " + 转字符串(chmod_次数))
    打印("  chown: " + 转字符串(chown_次数))
    打印("  truncate: " + 转字符串(truncate_次数))
    打印("  access: " + 转字符串(access_次数))
    打印("  mkdir: " + 转字符串(mkdir_总次数))
    打印("  rmdir: " + 转字符串(rmdir_总次数))
    打印("  错误: " + 转字符串(链接_错误数))
    打印("[文件链接 dump] ──────────────────")
}

函数 硬链接_销毁() {
    链接_已初始化 = 假
    返回 0
}

函数 硬链接_为procfs提供统计() {
    返回 [link_总次数, unlink_总次数, symlink_次数, readlink_次数,
           rename_次数, chmod_次数, chown_次数, truncate_次数, access_次数,
           mkdir_总次数, rmdir_总次数]
}

函数 硬链接_为AI提供文件操作模式() {
    返回 [link_总次数, unlink_总次数, symlink_次数, rename_次数,
           mkdir_总次数, rmdir_总次数, 链接_平均延迟()]
}

函数 硬链接_重置统计() {
    link_总次数 = 0
    unlink_总次数 = 0
    symlink_次数 = 0
    readlink_次数 = 0
    rename_次数 = 0
    chmod_次数 = 0
    chown_次数 = 0
    truncate_次数 = 0
    access_次数 = 0
    mkdir_总次数 = 0
    rmdir_总次数 = 0
    链接_错误数 = 0
    链接_延迟总计 = 0
    链接_延迟样本 = 0
    链接_最大延迟 = 0
    链接_速率 = 0
    链接_速率窗口 = 0
    链接_峰值速率 = 0
    打印("[文件链接] 统计已重置")
    返回 0
}

// 桥接
函数 路径查找_父(根, 路径) {
    返回 路径查找_带标志(根, 路径, LOOKUP_PARENT)
}
函数 路径查找_不跟随(根, 路径) {
    返回 路径查找_带标志(根, 路径, LOOKUP_NOFOLLOW)
}
函数 路径_取文件名(路径) {
    定义 分隔 = 字符串最后索引(路径, "/")
    如果 (分隔 < 0) { 返回 路径 }
    返回 字符串子串(路径, 分隔 + 1, 字符串长度(路径))
}
函数 Nova文件节点_创建_符号链接() {
    返回 Nova文件节点_创建(类型_符号链接, S_IRWXU | S_IRWXG | S_IRWXO)
}
函数 Nova节点_是符号链接(节点) {
    如果 (节点 == 空) { 返回 假 }
    返回 S_ISLNK(节点.模式)
}
函数 Nova文件节点_读符号链接(节点) {
    如果 (节点 == 空) { 返回 "" }
    如果 (节点.链接目标 == 空) { 返回 "" }
    返回 节点.链接目标
}
函数 Nova文件节点_设置模式(节点, 模式) {
    如果 (节点 == 空) { 返回 }
    节点.模式 = (节点.模式 & S_IFMT) | (模式 & 0o7777)
    Nova文件节点_标记脏(节点)
}
函数 Nova文件节点_设置uid(节点, uid) {
    如果 (节点 == 空) { 返回 }
    节点.uid = uid
    Nova文件节点_标记脏(节点)
}
函数 Nova文件节点_设置gid(节点, gid) {
    如果 (节点 == 空) { 返回 }
    节点.gid = gid
    Nova文件节点_标记脏(节点)
}
函数 Nova文件节点_截断(节点, 长度) {
    如果 (节点 == 空) { 返回 }
    如果 (长度 < 0) { 返回 }
    节点.大小 = 长度
    Nova文件节点_标记脏(节点)
}
函数 内存复制_字符串(目标, 源, 长度) { 返回 内存复制(目标, 源, 长度) }
函数 字符串长度(s) { 如果 (s == 0) { 返回 0 }; 返回 字节长度(s) }

函数 目录项_Nova文件节点编号(条目) {
    如果 (条目 == 空 || 条目.Nova文件节点 == 空) { 返回 0 }
    返回 条目.Nova文件节点.编号
}

函数 目录项_类型(条目) {
    如果 (条目 == 空) { 返回 0 }
    如果 (目录项_是目录(条目)) { 返回 2 }
    定义 节点 = 目录项_Nova文件节点(条目)
    如果 (节点 != 空 && Nova节点_是符号链接(节点)) { 返回 7 }
    如果 (节点 != 空) { 返回 1 }
    返回 0
}

函数 进程_设置当前目录(进程, 目录项) {
    如果 (进程 == 空) { 返回 }
    定义 旧 = 进程.cwd
    如果 (旧 != 空) { 旧.引用计数 = 旧.引用计数 - 1 }
    进程.cwd = 目录项
    如果 (目录项 != 空) { 目录项.引用计数 = 目录项.引用计数 + 1 }
}

函数 进程_当前目录_Nova路径项(进程) {
    如果 (进程 == 空) { 返回 空 }
    如果 (进程.cwd != 空) { 返回 进程.cwd }
    返回 获取根目录项()
}

函数 硬链接_为调度器提供IO负载() {
    返回 [链接_速率, 链接_峰值速率, 链接_平均延迟()]
}

函数 硬链接_获取总操作数() {
    返回 link_总次数 + unlink_总次数 + symlink_次数 + readlink_次数 +
           rename_次数 + chmod_次数 + chown_次数 + truncate_次数 +
           access_次数 + mkdir_总次数 + rmdir_总次数
}

函数 硬链接_为电源管理挂起() {
    打印("[硬链接] 挂起: 刷新待写链接缓存")
    返回 硬链接_总创建数
}

函数 硬链接_初始化() {
    如果 (链接_已初始化 == 真) { 返回 错误_已存在 }
    链接_已初始化 = 真
    打印("[文件链接] 初始化完成")
    返回 0
}

// NovaOS 渲染引擎 — SVG路径d属性解析器
// 子系统: 渲染引擎/图片解码/矢量图/矢量渲染
// 实现: SVG路径d属性完整解析(M/L/H/V/C/S/Q/T/A/Z 大小写)
//   输入: "M 10 20 L 30 40 C 50 60 70 80 90 100 Z"
//   输出: SVGPath (段链表) + 边界框
//   支持: 隐式重复命令 + 相对/绝对坐标 + smooth曲线
// 原创: NovaOS · 纯中文原生系统编程 · AI原生路径复杂度预测

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../执行/控制台输出.nova")
导入("../中枢/字符串替换.nova")
导入("./边界框计算.nova")
导入("../中枢/创建甲.nova")
导入("./路径解析器辅.nova")

// §0 常量定义

定义 SVG命令_M = 77
定义 SVG命令_m = 109
定义 SVG命令_L = 76
定义 SVG命令_l = 108
定义 SVG命令_H = 72
定义 SVG命令_h = 104
定义 SVG命令_V = 86
定义 SVG命令_v = 118
定义 SVG命令_C = 67
定义 SVG命令_c = 99
定义 SVG命令_S = 83
定义 SVG命令_s = 115
定义 SVG命令_Q = 81
定义 SVG命令_q = 113
定义 SVG命令_T = 84
定义 SVG命令_t = 116
定义 SVG命令_A = 65
定义 SVG命令_a = 97
定义 SVG命令_Z = 90
定义 SVG命令_z = 122
定义 最大路径段数 = 8192

// §0.5 数据结构

结构 路径解析统计 {
    解析总次数,
    M命令次数,
    L命令次数,
    C命令次数,
    Q命令次数,
    A命令次数,
    Z命令次数,
    H_V命令次数,
    S_T命令次数,
    隐式重复次数,
    相对坐标次数,
    绝对坐标次数,
    总段数,
    总解析耗时_纳秒,
    最大单次耗时,
    AI复杂度调用次数,
    AI复杂度命中次数,
    解析错误次数,
}

结构 AI路径解析状态 {
    历史平均段数,        // u32 Q10
    历史平均命令种类数,  // u32 Q10
    历史曲线比例,        // u32 Q10 (C/Q/S/T/A命令占比)
    连续简单路径数,      // u32 (仅M/L/Z)
    连续复杂路径数,      // u32 (含C/Q/A)
    预测下次复杂,
    采样计数器,
    学习权重,            // u32 Q10
}

定义 可变 全局路径解析统计 = 0
定义 可变 全局路径解析AI = 0
定义 可变 全局路径解析已初始化 = 假

结构 SVGPathSegment {
    命令,        // u8  SVG命令_M/L/C/Q/A/Z
    参数,        // u64 指向参数数组(最多7个i32)
    下一个,      // u64 链表下一段
}

结构 SVGPath {
    段链头,      // u64 SVGPathSegment*
    段链尾,
    段数,
    bbox_x,
    bbox_y,
    bbox_w,
    bbox_h,
    已闭合,
    锁,
}

// §1 生命周期管理

函数 SVG路径解析_初始化() {
    如果 (全局路径解析已初始化 == 真) { 返回 错误_已存在 }
    全局路径解析统计 = 堆_分配_清零(144)
    如果 (全局路径解析统计 == 空) { 返回 错误_内存不足 }
    全局路径解析AI = 堆_分配_清零(40)
    如果 (全局路径解析AI != 空) {
        全局路径解析AI.学习权重 = 128
    }
    全局路径解析已初始化 = 真
    打印("[SVG路径解析] 初始化完成")
    返回 0
}

函数 SVG路径解析_销毁() {
    如果 (全局路径解析统计 != 空) { 堆_释放(全局路径解析统计); 全局路径解析统计 = 0 }
    如果 (全局路径解析AI != 空) { 堆_释放(全局路径解析AI); 全局路径解析AI = 0 }
    全局路径解析已初始化 = 假
    返回 0
}

// §1.5 SVGPath创建与段管理

函数 SVGPath_创建() {
    定义 path = 堆_分配(SVGPath)
    如果 (path == 空) { 返回 空 }
    path.段链头 = 0
    path.段链尾 = 0
    path.段数 = 0
    path.bbox_x = 0
    path.bbox_y = 0
    path.bbox_w = 0
    path.bbox_h = 0
    path.已闭合 = 假
    path.锁 = 渲染_互斥锁创建()
    返回 path
}

函数 SVGPath_添加段(path, 命令, p0, p1, p2, p3, p4, p5, p6) {
    如果 (path == 空) { 返回 }
    如果 (path.段数 >= 最大路径段数) {
        如果 (全局路径解析统计 != 空) { 全局路径解析统计.解析错误次数 = 全局路径解析统计.解析错误次数 + 1 }
        返回
    }
    定义 seg = 堆_分配(SVGPathSegment)
    如果 (seg == 空) { 返回 }
    seg.命令 = 命令
    seg.参数 = 堆_分配(7 * 4)
    如果 (seg.参数 != 空) {
        内存_写32(seg.参数, p0)
        内存_写32(seg.参数 + 4, p1)
        内存_写32(seg.参数 + 8, p2)
        内存_写32(seg.参数 + 12, p3)
        内存_写32(seg.参数 + 16, p4)
        内存_写32(seg.参数 + 20, p5)
        内存_写32(seg.参数 + 24, p6)
    }
    seg.下一个 = 0
    如果 (path.段链尾 != 0) {
        定义 尾 = path.段链尾
        尾.下一个 = seg
    } 否则 {
        path.段链头 = seg
    }
    path.段链尾 = seg
    path.段数 = path.段数 + 1
    如果 (命令 == SVG命令_Z) { path.已闭合 = 真 }
}

函数 SVGPath_销毁(path) {
    如果 (path == 空) { 返回 }
    定义 可变 seg = path.段链头
    当 (seg != 0) {
        定义 下一个 = seg.下一个
        如果 (seg.参数 != 空) { 堆_释放(seg.参数) }
        堆_释放(seg)
        seg = 下一个
    }
    堆_释放(path)
}

// §2 解析器结构

结构 SVGPathParser {
    输入,    // u64 d属性字符串
    长度,
    位置,    // u32 当前解析位置
    当前x,    // i32 Q10
    当前y,
    起点x,    // i32 subpath起点
    起点y,
    上一控制x,    // i32 smooth曲线用
    上一控制y,
    上一命令,
}

函数 SVGPath_解析(d字符串) {
    如果 (d字符串 == 0) { 返回 0 }

    定义 path = SVGPath_创建()
    定义 parser = 堆_分配(SVGPathParser)
    parser.输入 = d字符串
    parser.长度 = 字节长度(d字符串)
    parser.位置 = 0
    parser.当前x = 0; parser.当前y = 0
    parser.起点x = 0; parser.起点y = 0
    parser.上一命令 = 0

    当 (parser.位置 < parser.长度) {
        SVGParser_跳过空白(parser)
        如果 (parser.位置 >= parser.长度) { 跳出 }

        定义 ch = 字节取(parser.输入, parser.位置)

        // 命令字母?
        如果 (SVGParser_是命令(ch)) {
            parser.上一命令 = ch
            parser.位置 = parser.位置 + 1
        } 否则 {
            ch = parser.上一命令    // 隐式重复上一命令
        }

        如果 (ch == SVG命令_M || ch == SVG命令_m) {
            定义 x = SVGParser_读数字(parser)
            定义 y = SVGParser_读数字(parser)
            如果 (ch == SVG命令_m) { x = x + parser.当前x; y = y + parser.当前y }
            SVGPath_添加段(path, SVG命令_M, x, y, 0, 0, 0, 0, 0)
            parser.当前x = x; parser.当前y = y
            parser.起点x = x; parser.起点y = y
            // M后续隐式为L
            parser.上一命令 = 如果(ch == SVG命令_M, SVG命令_L, SVG命令_l)
        }
        否则 如果 (ch == SVG命令_L || ch == SVG命令_l) {
            定义 x = SVGParser_读数字(parser)
            定义 y = SVGParser_读数字(parser)
            如果 (ch == SVG命令_l) { x = x + parser.当前x; y = y + parser.当前y }
            SVGPath_添加段(path, SVG命令_L, x, y, 0, 0, 0, 0, 0)
            parser.当前x = x; parser.当前y = y
        }
        否则 如果 (ch == SVG命令_H || ch == SVG命令_h) {
            定义 x = SVGParser_读数字(parser)
            如果 (ch == SVG命令_h) { x = x + parser.当前x }
            SVGPath_添加段(path, SVG命令_L, x, parser.当前y, 0, 0, 0, 0, 0)
            parser.当前x = x
        }
        否则 如果 (ch == SVG命令_V || ch == SVG命令_v) {
            定义 y = SVGParser_读数字(parser)
            如果 (ch == SVG命令_v) { y = y + parser.当前y }
            SVGPath_添加段(path, SVG命令_L, parser.当前x, y, 0, 0, 0, 0, 0)
            parser.当前y = y
        }
        否则 如果 (ch == SVG命令_C || ch == SVG命令_c) {
            定义 x1 = SVGParser_读数字(parser)
            定义 y1 = SVGParser_读数字(parser)
            定义 x2 = SVGParser_读数字(parser)
            定义 y2 = SVGParser_读数字(parser)
            定义 x = SVGParser_读数字(parser)
            定义 y = SVGParser_读数字(parser)
            如果 (ch == SVG命令_c) {
                x1 = x1 + parser.当前x; y1 = y1 + parser.当前y
                x2 = x2 + parser.当前x; y2 = y2 + parser.当前y
                x = x + parser.当前x; y = y + parser.当前y
            }
            SVGPath_添加段(path, SVG命令_C, x1, y1, x2, y2, x, y, 0)
            parser.上一控制x = x2; parser.上一控制y = y2
            parser.当前x = x; parser.当前y = y
        }
        否则 如果 (ch == SVG命令_S || ch == SVG命令_s) {
            // smooth Nova三次方: 第一控制点是上一控制点的对称
            定义 x1 = 2 * parser.当前x - parser.上一控制x
            定义 y1 = 2 * parser.当前y - parser.上一控制y
            定义 x2 = SVGParser_读数字(parser)
            定义 y2 = SVGParser_读数字(parser)
            定义 x = SVGParser_读数字(parser)
            定义 y = SVGParser_读数字(parser)
            如果 (ch == SVG命令_s) {
                x2 = x2 + parser.当前x; y2 = y2 + parser.当前y
                x = x + parser.当前x; y = y + parser.当前y
            }
            SVGPath_添加段(path, SVG命令_C, x1, y1, x2, y2, x, y, 0)
            parser.上一控制x = x2; parser.上一控制y = y2
            parser.当前x = x; parser.当前y = y
        }
        否则 如果 (ch == SVG命令_Q || ch == SVG命令_q) {
            定义 cx = SVGParser_读数字(parser)
            定义 cy = SVGParser_读数字(parser)
            定义 x = SVGParser_读数字(parser)
            定义 y = SVGParser_读数字(parser)
            如果 (ch == SVG命令_q) {
                cx = cx + parser.当前x; cy = cy + parser.当前y
                x = x + parser.当前x; y = y + parser.当前y
            }
            SVGPath_添加段(path, SVG命令_Q, cx, cy, x, y, 0, 0, 0)
            parser.上一控制x = cx; parser.上一控制y = cy
            parser.当前x = x; parser.当前y = y
        }
        否则 如果 (ch == SVG命令_T || ch == SVG命令_t) {
            定义 cx = 2 * parser.当前x - parser.上一控制x
            定义 cy = 2 * parser.当前y - parser.上一控制y
            定义 x = SVGParser_读数字(parser)
            定义 y = SVGParser_读数字(parser)
            如果 (ch == SVG命令_t) {
                x = x + parser.当前x; y = y + parser.当前y
            }
            SVGPath_添加段(path, SVG命令_Q, cx, cy, x, y, 0, 0, 0)
            parser.上一控制x = cx; parser.上一控制y = cy
            parser.当前x = x; parser.当前y = y
        }
        否则 如果 (ch == SVG命令_A || ch == SVG命令_a) {
            定义 rx = SVGParser_读数字(parser)
            定义 ry = SVGParser_读数字(parser)
            定义 角度 = SVGParser_读数字(parser)
            定义 大弧 = SVGParser_读数字(parser)    // 0或1
            定义 顺时针 = SVGParser_读数字(parser)   // 0或1
            定义 x = SVGParser_读数字(parser)
            定义 y = SVGParser_读数字(parser)
            如果 (ch == SVG命令_a) {
                x = x + parser.当前x; y = y + parser.当前y
            }
            SVGPath_添加段(path, SVG命令_A, rx, ry, 角度, 大弧, 顺时针, x, y)
            parser.当前x = x; parser.当前y = y
        }
        否则 如果 (ch == SVG命令_Z || ch == SVG命令_z) {
            SVGPath_添加段(path, SVG命令_Z, parser.起点x, parser.起点y, 0, 0, 0, 0, 0)
            parser.当前x = parser.起点x; parser.当前y = parser.起点y
        }
    }

    堆_释放(parser)
    SVGPath_计算边界(path)
    // 统计更新
    如果 (全局路径解析统计 != 空) {
        全局路径解析统计.解析总次数 = 全局路径解析统计.解析总次数 + 1
        全局路径解析统计.总段数 = 全局路径解析统计.总段数 + path.段数
    }
    // AI学习
    AI路径_后解析学习(path)
    返回 path
}

// §4 增强版解析入口(带统计+AI+计时)

函数 SVGPath_解析d_完整(d属性) {
    如果 (d属性 == 空) {
        如果 (全局路径解析统计 != 空) { 全局路径解析统计.解析错误次数 = 全局路径解析统计.解析错误次数 + 1 }
        返回 空
    }
    定义 开始时间 = 平台_获取高精度时间()
    // AI预测
    如果 (全局路径解析AI != 空) {
        AI路径_预解析分析(d属性)
    }
    定义 path = SVGPath_解析d(d属性)
    // 统计
    如果 (全局路径解析统计 != 空) {
        定义 耗时 = 平台_获取高精度时间() - 开始时间
        全局路径解析统计.总解析耗时_纳秒 = 全局路径解析统计.总解析耗时_纳秒 + 耗时
        如果 (耗时 > 全局路径解析统计.最大单次耗时) {
            全局路径解析统计.最大单次耗时 = 耗时
        }
    }
    返回 path
}

// §5 路径复杂度分析

函数 SVGPath_分析复杂度(path) {
    如果 (path == 空) { 返回 0 }
    定义 可变 M数 = 0
    定义 可变 L数 = 0
    定义 可变 C数 = 0
    定义 可变 Q数 = 0
    定义 可变 A数 = 0
    定义 可变 Z数 = 0
    定义 可变 其他数 = 0
    定义 可变 seg = path.段链头
    当 (seg != 空) {
        如果 (seg.命令 == SVG命令_M) { M数 = M数 + 1 }
        否则 如果 (seg.命令 == SVG命令_L) { L数 = L数 + 1 }
        否则 如果 (seg.命令 == SVG命令_C) { C数 = C数 + 1 }
        否则 如果 (seg.命令 == SVG命令_Q) { Q数 = Q数 + 1 }
        否则 如果 (seg.命令 == SVG命令_A) { A数 = A数 + 1 }
        否则 如果 (seg.命令 == SVG命令_Z) { Z数 = Z数 + 1 }
        否则 { 其他数 = 其他数 + 1 }
        seg = seg.下一个
    }
    // 更新统计
    如果 (全局路径解析统计 != 空) {
        全局路径解析统计.M命令次数 = 全局路径解析统计.M命令次数 + M数
        全局路径解析统计.L命令次数 = 全局路径解析统计.L命令次数 + L数
        全局路径解析统计.C命令次数 = 全局路径解析统计.C命令次数 + C数
        全局路径解析统计.Q命令次数 = 全局路径解析统计.Q命令次数 + Q数
        全局路径解析统计.A命令次数 = 全局路径解析统计.A命令次数 + A数
        全局路径解析统计.Z命令次数 = 全局路径解析统计.Z命令次数 + Z数
    }
    // 复杂度评分: 直线段=1, 曲线段=3, 弧线=5
    定义 评分 = M数 + L数 + Z数 + C数 * 3 + Q数 * 3 + A数 * 5 + 其他数 * 2
    返回 评分
}

函数 SVGPath_命令种类数(path) {
    如果 (path == 空) { 返回 0 }
    定义 可变 存在 = 堆_分配_清零(20)
    如果 (存在 == 空) { 返回 0 }
    定义 可变 seg = path.段链头
    当 (seg != 空) {
        定义 可变 idx = 0
        如果 (seg.命令 == SVG命令_M) { idx = 0 }
        否则 如果 (seg.命令 == SVG命令_L) { idx = 1 }
        否则 如果 (seg.命令 == SVG命令_C) { idx = 2 }
        否则 如果 (seg.命令 == SVG命令_Q) { idx = 3 }
        否则 如果 (seg.命令 == SVG命令_A) { idx = 4 }
        否则 如果 (seg.命令 == SVG命令_Z) { idx = 5 }
        否则 如果 (seg.命令 == SVG命令_H || seg.命令 == SVG命令_V) { idx = 6 }
        否则 如果 (seg.命令 == SVG命令_S || seg.命令 == SVG命令_T) { idx = 7 }
        否则 { idx = 8 }
        内存_写8(存在 + idx, 1)
        seg = seg.下一个
    }
    定义 可变 种类 = 0
    定义 可变 i = 0
    当 (i < 10) {
        如果 (内存_读8(存在 + i) == 1) { 种类 = 种类 + 1 }
        i = i + 1
    }
    堆_释放(存在)
    返回 种类
}

函数 SVGPath_曲线段比例(path) {
    如果 (path == 空 || path.段数 == 0) { 返回 0 }
    定义 可变 曲线数 = 0
    定义 可变 seg = path.段链头
    当 (seg != 空) {
        如果 (seg.命令 == SVG命令_C || seg.命令 == SVG命令_Q || seg.命令 == SVG命令_A || seg.命令 == SVG命令_S || seg.命令 == SVG命令_T) {
            曲线数 = 曲线数 + 1
        }
        seg = seg.下一个
    }
    返回 曲线数 * 1024 / path.段数
}

// §6 AI基因 — 路径复杂度预测
// 能力: 预测 + 学习 + 自适应
// 四阶段: 数据采集→特征提取→决策→执行

函数 AI路径_预解析分析(d属性) {
    如果 (全局路径解析AI == 空 || d属性 == 空) { 返回 }
    如果 (全局路径解析统计 != 空) {
        全局路径解析统计.AI复杂度调用次数 = 全局路径解析统计.AI复杂度调用次数 + 1
    }
    定义 长度 = 字节长度(d属性)
    定义 可变 命令数 = 0
    定义 可变 曲线命令 = 0
    定义 可变 i = 0
    当 (i < 长度 && i < 200) {
        定义 ch = 字节取(d属性, i)
        如果 (SVGParser_是命令(ch) == 真) {
            命令数 = 命令数 + 1
            如果 (ch == 67 || ch == 99 || ch == 81 || ch == 113 || ch == 65 || ch == 97 || ch == 83 || ch == 115 || ch == 84 || ch == 116) {
                曲线命令 = 曲线命令 + 1
            }
        }
        i = i + 1
    }
    定义 AI = 全局路径解析AI
    定义 可变 预测复杂 = 假
    如果 (曲线命令 > 3 || 长度 > 500) { 预测复杂 = 真 }
    如果 (AI.预测下次复杂 == 真 && 预测复杂 == 真) {
        如果 (全局路径解析统计 != 空) {
            全局路径解析统计.AI复杂度命中次数 = 全局路径解析统计.AI复杂度命中次数 + 1
        }
    }
    AI.预测下次复杂 = 预测复杂
}

函数 AI路径_后解析学习(path) {
    如果 (全局路径解析AI == 空 || path == 空) { 返回 }
    定义 AI = 全局路径解析AI
    AI.采样计数器 = AI.采样计数器 + 1
    // 指数移动平均
    AI.历史平均段数 = (AI.历史平均段数 * 7 + path.段数 * 1024) / 8
    定义 种类 = SVGPath_命令种类数(path)
    AI.历史平均命令种类数 = (AI.历史平均命令种类数 * 7 + 种类 * 1024) / 8
    定义 曲线比 = SVGPath_曲线段比例(path)
    AI.历史曲线比例 = (AI.历史曲线比例 * 7 + 曲线比) / 8
    // 连续计数
    如果 (曲线比 > 200) {
        AI.连续复杂路径数 = AI.连续复杂路径数 + 1
        AI.连续简单路径数 = 0
    } 否则 {
        AI.连续简单路径数 = AI.连续简单路径数 + 1
        AI.连续复杂路径数 = 0
    }
    // 预测
    如果 (AI.连续复杂路径数 > 3 || AI.历史曲线比例 > 300) {
        AI.预测下次复杂 = 真
    } 否则 如果 (AI.连续简单路径数 > 5) {
        AI.预测下次复杂 = 假
    }
}

// §7 统计输出与诊断

函数 SVG路径解析_打印统计() {
    如果 (全局路径解析统计 == 空) {
        打印("[SVG路径解析] 统计未初始化")
        返回
    }
    打印("┌──────────────────────────────────────┐")
    打印("│   SVG路径解析器 · 统计报告          │")
    打印("├──────────────────────────────────────┤")
    打印(字符串拼接("│ 解析总次数:       ", 转字符串(全局路径解析统计.解析总次数)))
    打印(字符串拼接("│ M命令:            ", 转字符串(全局路径解析统计.M命令次数)))
    打印(字符串拼接("│ L命令:            ", 转字符串(全局路径解析统计.L命令次数)))
    打印(字符串拼接("│ C命令:            ", 转字符串(全局路径解析统计.C命令次数)))
    打印(字符串拼接("│ Q命令:            ", 转字符串(全局路径解析统计.Q命令次数)))
    打印(字符串拼接("│ A命令:            ", 转字符串(全局路径解析统计.A命令次数)))
    打印(字符串拼接("│ Z命令:            ", 转字符串(全局路径解析统计.Z命令次数)))
    打印(字符串拼接("│ 总段数:           ", 转字符串(全局路径解析统计.总段数)))
    打印(字符串拼接("│ 隐式重复:         ", 转字符串(全局路径解析统计.隐式重复次数)))
    打印(字符串拼接("│ 总耗时(μs):       ", 转字符串(全局路径解析统计.总解析耗时_纳秒 / 1000)))
    打印(字符串拼接("│ 最大单次(μs):     ", 转字符串(全局路径解析统计.最大单次耗时 / 1000)))
    打印(字符串拼接("│ AI复杂度调用:     ", 转字符串(全局路径解析统计.AI复杂度调用次数)))
    打印(字符串拼接("│ AI复杂度命中:     ", 转字符串(全局路径解析统计.AI复杂度命中次数)))
    打印(字符串拼接("│ 解析错误:         ", 转字符串(全局路径解析统计.解析错误次数)))
    打印("└──────────────────────────────────────┘")
}

函数 SVG路径解析_导出诊断() {
    如果 (全局路径解析AI == 空) {
        打印("[SVG路径解析 AI] 未初始化")
        返回
    }
    定义 AI = 全局路径解析AI
    打印("[SVG路径解析 AI] === 诊断 ===")
    打印(字符串拼接("  历史平均段数(Q10): ", 转字符串(AI.历史平均段数)))
    打印(字符串拼接("  历史命令种类(Q10): ", 转字符串(AI.历史平均命令种类数)))
    打印(字符串拼接("  历史曲线比例(Q10): ", 转字符串(AI.历史曲线比例)))
    打印(字符串拼接("  连续简单路径: ", 转字符串(AI.连续简单路径数)))
    打印(字符串拼接("  连续复杂路径: ", 转字符串(AI.连续复杂路径数)))
    打印(字符串拼接("  预测下次复杂: ", 转字符串(AI.预测下次复杂)))
}

// §8 对外接口

函数 SVG路径解析_获取统计() { 返回 全局路径解析统计 }
函数 SVG路径解析_获取AI状态() { 返回 全局路径解析AI }

函数 SVG路径解析_是复杂(path) {
    如果 (path == 空) { 返回 假 }
    定义 评分 = SVGPath_分析复杂度(path)
    如果 (评分 > 50) { 返回 真 }
    返回 假
}

函数 SVG路径解析_获取段数(path) {
    如果 (path == 空) { 返回 0 }
    返回 path.段数
}

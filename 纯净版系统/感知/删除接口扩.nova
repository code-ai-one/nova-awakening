    如果 (program == 0 || blockName == 0) { 返回 -1 }
    返回 GL_获取uniformBlock索引(program, blockName)
}

函数 图绘2_getActiveUniformBlockName(program, blockIndex) {
    如果 (program == 0) { 返回 0 }

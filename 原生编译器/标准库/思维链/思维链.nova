导入("../基础.nova")
导入("../算法/数学扩展.nova")


// 思维步骤
// 型: [步骤ID, 类型, 内容哈希, 置信度, 父ID, 子ID列表, 奖励]
定义 思维_观察 = 0
定义 思维_推理 = 1
定义 思维_行动 = 2
定义 思维_反思 = 3
定义 思维_验证 = 4

函数 思维步_创建(id, 类型, 内容, 置信度) { 返回 [id, 类型, 内容, 置信度, -1, [], 0]
}

函数 思维步_ID(步) { 返回 步[0] }
函数 思维步_类型(步) { 返回 步[1] }
函数 思维步_内容(步) { 返回 步[2] }
函数 思维步_置信度(步) { 返回 步[3] }
函数 思维步_父(步) { 返回 步[4] }
函数 思维步_子列表(步) { 返回 步[5] }
函数 思维步_奖励(步) { 返回 步[6] }

// Chain of Thought (CoT)
// 线性链: 步骤1 → 步骤2 → ... → 答案
函数 CoT_创建() { 返回 [[], 0] } // [步骤列表, 下一ID]

函数 CoT_添加步骤(链, 类型, 内容, 置信度) { 定义 id = 链[1]
 定义 步 = 思维步_创建(id, 类型, 内容, 置信度)
 如果 (id > 0) {
 步[4] = id - 1 // 父=上一步
 定义 上一步 = 链[0][id - 1]
 追加(上一步[5], id) // 上一步的子
 }
 追加(链[0], 步)
 链[1] = id + 1
 返回 id
}

函数 CoT_长度(链) { 返回 计数(链[0]) }
函数 CoT_获取步骤(链, i) { 返回 链[0][i] }

函数 CoT_总置信度(链) { 定义 n = 计数(链[0])
 如果 (n == 0) { 返回 0 }
 定义 可变 总 = 1000
 定义 可变 i = 0
 当 (i < n) {
 总 = 总 * 链[0][i][3] / 1000
 i = i + 1
 }
 返回 总
}

// Tree of Thoughts (ToT)
// 树搜索: 每步可分支多个候选, 广度优先/DFS探索
函数 ToT_创建() { 定义 根 = 思维步_创建(0, 思维_观察, 0, 1000)
 返回 [[根], 1, [0]] // [所有节点, 下一ID, 叶节点队列]
}

函数 ToT_扩展(树, 父ID, 候选列表) { 定义 可变 新ID列表 = []
 定义 可变 i = 0
 当 (i < 计数(候选列表)) { 定义 id = 树[1]
 定义 步 = 思维步_创建(id, 思维_推理, 候选列表[i][0], 候选列表[i][1])
 步[4] = 父ID
 追加(树[0][父ID][5], id)
 追加(树[0], 步)
 追加(新ID列表, id)
 树[1] = id + 1
 i = i + 1
 }
 返回 新ID列表
}

函数 ToT_评估(树, 评估函数_结果列表, 节点ID列表) {
 // 用外部评估结果更新奖励
 定义 可变 i = 0
 当 (i < 计数(节点ID列表)) { 如果 (i < 计数(评估函数_结果列表)) {
 树[0][节点ID列表[i]][6] = 评估函数_结果列表[i]
 }
 i = i + 1
 }
}

函数 ToT_BFS选择(树, 节点ID列表, beam_width) {
 // 选奖励最高的beam_width个节点
 定义 n = 计数(节点ID列表)
 定义 可变 排序 = []
 定义 可变 i = 0
 当 (i < n) { 追加(排序, 节点ID列表[i])
 i = i + 1 }
 // 按奖励降序
 i = 0
 当 (i < n - 1) { 定义 可变 j = i + 1
 当 (j < n) { 如果 (树[0][排序[j]][6] > 树[0][排序[i]][6]) { 定义 临时 = 排序[i]
 排序[i] = 排序[j]
 排序[j] = 临时
 }
 j = j + 1
 }
 i = i + 1
 }
 定义 可变 选中 = []
 i = 0
 当 (i < beam_width 且 i < n) { 追加(选中, 排序[i])
 i = i + 1 }
 返回 选中
}

函数 ToT_最佳路径(树) {
 // 从根到最高奖励叶的路径
 定义 可变 当前 = 0
 定义 可变 路径 = [0]
 当 (计数(树[0][当前][5]) > 0) { 定义 子 = 树[0][当前][5]
 定义 可变 最佳 = 子[0]
 定义 可变 最佳奖 = 树[0][子[0]][6]
 定义 可变 i = 1
 当 (i < 计数(子)) { 如果 (树[0][子[i]][6] > 最佳奖) {
 最佳 = 子[i]
 最佳奖 = 树[0][子[i]][6]
 }
 i = i + 1
 }
 当前 = 最佳
 追加(路径, 当前)
 }
 返回 路径
}

// ReAct: 推理+行动交错
// 永: Thought → Action → Observation → Thought → ...
函数 ReAct_创建() { 返回 [[], 0, []] // [历史, 步数, 工具列表]
}

函数 ReAct_注册工具(上下文, 工具名哈希, 工具类型) {
 追加(上下文[2], [工具名哈希, 工具类型])
}

函数 ReAct_思考(上下文, 推理内容) {
 追加(上下文[0], [思维_推理, 推理内容, 上下文[1]])
 上下文[1] = 上下文[1] + 1
}

函数 ReAct_行动(上下文, 工具idx, 参数) {
 追加(上下文[0], [思维_行动, 工具idx, 参数])
 上下文[1] = 上下文[1] + 1
 返回 工具idx
}

函数 ReAct_观察(上下文, 结果) {
 追加(上下文[0], [思维_观察, 结果, 上下文[1]])
 上下文[1] = 上下文[1] + 1
}

函数 ReAct_历史长度(上下文) { 返回 计数(上下文[0]) }

// Reflexion: 自我反思
函数 Reflexion_创建() { 返回 [[], [], 0] // [尝试历史, 反思列表, 尝试次数]
}

函数 Reflexion_尝试(上下文, 推理链, 结果分数) {
 追加(上下文[0], [推理链, 结果分数])
 上下文[2] = 上下文[2] + 1
}

函数 Reflexion_反思(上下文, 反思内容) {
 追加(上下文[1], 反思内容)
}

函数 Reflexion_应继续(上下文, 目标分数, 最大尝试) {
    如果 (上下文[2] >= 最大尝试) { 返回 0
}
 如果 (计数(上下文[0]) == 0) { 返回 1 }
 定义 最近 = 上下文[0][计数(上下文[0]) - 1]
 如果 (最近[1] >= 目标分数) { 返回 0 }
 返回 1
}

函数 Reflexion_最佳尝试(上下文) { 定义 n = 计数(上下文[0])
 如果 (n == 0) { 返回 -1 }
 定义 可变 最佳 = 0
 定义 可变 i = 1
 当 (i < n) { 如果 (上下文[0][i][1] > 上下文[0][最佳][1]) { 最佳 = i }
 i = i + 1
 }
 返回 最佳
}

// 过程奖励模型 (PRM)
函数 PRM_评分(步骤奖励列表) {
 // 最小步骤奖励作为整体分数 (最弱环节)
 定义 n = 计数(步骤奖励列表)
 如果 (n == 0) { 返回 0 }
 定义 可变 最小 = 步骤奖励列表[0]
 定义 可变 i = 1
 当 (i < n) { 如果 (步骤奖励列表[i] < 最小) { 最小 = 步骤奖励列表[i] }
 i = i + 1
 }
 返回 最小
}

函数 PRM_加权评分(步骤奖励列表) {
 // 后面步骤权重更大
 定义 n = 计数(步骤奖励列表)
 如果 (n == 0) { 返回 0 }
 定义 可变 加权和 = 0
 定义 可变 权重和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 权重 = i + 1
 加权和 = 加权和 + 步骤奖励列表[i] * 权重
 权重和 = 权重和 + 权重
 i = i + 1
 }
 如果 (权重和 == 0) { 返回 0 }
 返回 加权和 / 权重和
}

// STaR: 自我学习推理器
函数 STaR_筛选(推理列表, 结果列表, 正确阈值) {
 // 筛选正确推理链用于训练
 定义 可变 好的 = []
 定义 可变 i = 0
 当 (i < 计数(推理列表)) { 如果 (i < 计数(结果列表) 且 结果列表[i] >= 正确阈值) {
 追加(好的, 推理列表[i])
 }
 i = i + 1
 }
 返回 好的
}

// MCTS思维搜索
函数 蒙特卡洛树_置信上限(奖励, 访问次数, 父访问次数, c) { 如果 (c <= 0) { c = 1414 } // √2 × 1000
 如果 (访问次数 == 0) { 返回 0x7FFFFFFF }
 定义 利用 = 奖励 * 1000 / 访问次数
 定义 探索 = c * 整数sqrt(父访问次数 * 1000) / 整数sqrt(访问次数 * 1000)
 返回 利用 + 探索
}

函数 MCTS_选择最佳子(树, 节点ID, c) { 定义 子列表 = 树[0][节点ID][5]
 如果 (计数(子列表) == 0) { 返回 -1 }
 定义 父节点 = 树[0][节点ID]
 定义 可变 父访问 = 父节点[6] // 父节点的访问次数
 如果 (父访问 < 1) { 父访问 = 1 }
 定义 可变 最佳 = 子列表[0]
 定义 可变 最佳分 = 0
 定义 可变 i = 0
 当 (i < 计数(子列表)) { 定义 子 = 树[0][子列表[i]]
 定义 分 = 蒙特卡洛树_置信上限(子[6], 1, 父访问, c)
 如果 (分 > 最佳分) {
 最佳 = 子列表[i]
 最佳分 = 分
 }
 i = i + 1
 }
 返回 最佳
}

// 多步规划
函数 规划_创建(目标哈希) { 返回 [目标哈希, [], [], 0] // [目标, 步骤列表, 依赖关系, 完成步数]
}

函数 规划_添加步骤(规划, 步骤描述, 前置条件列表) { 定义 索引 = 计数(规划[1])
 追加(规划[1], [步骤描述,]) // [描述, 完成?, 结果]
 追加(规划[2], 前置条件列表)
 返回 索引
}

函数 规划_可执行(规划, 步idx) { 定义 前置 = 规划[2][步idx]
 定义 可变 i = 0
 当 (i < 计数(前置)) { 如果 (规划[1][前置[i]][1] == 0) { 返回 0 }
 i = i + 1
 }
 返回 1
}

函数 规划_完成步骤(规划, 步idx, 结果) {
 规划[1][步idx][1] = 1
 规划[1][步idx][2] = 结果
 规划[3] = 规划[3] + 1
}

函数 规划_完成率(规划) { 定义 总 = 计数(规划[1])
 如果 (总 == 0) { 返回 1000 }
 返回 规划[3] * 1000 / 总
}

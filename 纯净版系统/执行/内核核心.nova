导入("./文档初始化.nova")
导入("./脚本执行入.nova")
导入("./事件循环初.nova")
导入("./渲染初始化.nova")

结构 核心档 {
    名称,
    当前地址,
    当前文档,
    当前样式档,
    当前适配档,
    当前渲染树,
    当前根盒,
    最近节点,
    最近命中,
    最近脚本,
    最近表达式,
    最近导航,
    最近输入,
    最近摘要,
    视口宽,
    视口高,
    初始化完成,
    文档数,
    样式数,
    渲染数,
    事件数,
    脚本数,
    适配数,
    命中数,
    失败数,
    健康,
}

结构 核心请求 {
    地址,
    页面源码,
    样式源码,
    脚本源码,
    入口节点,
    输入类型,
    输入数据,
}

结构 核心摘要 {
    名称,
    地址,
    文档数,
    样式数,
    渲染数,
    事件数,
    脚本数,
    适配数,
    命中数,
    失败数,
    健康,
}

定义 可变 核心账本 = []
定义 可变 核心建数 = 0
定义 可变 核心总执行 = 0
定义 可变 核心总命中 = 0
定义 可变 核心总失败 = 0

函数 内核核心_建档(名称, 视口宽, 视口高) {
    定义 档 = 堆_分配(核心档)
    档.名称 = 名称
    档.当前地址 = "about:blank"
    档.当前文档 = 0
    档.当前样式档 = 0
    档.当前适配档 = 0
    档.当前渲染树 = 0
    档.当前根盒 = 0
    档.最近节点 = 0
    档.最近命中 = 0
    档.最近脚本 = ""
    档.最近表达式 = 0
    档.最近导航 = ""
    档.最近输入 = 0
    档.最近摘要 = 0
    档.视口宽 = 视口宽
    档.视口高 = 视口高
    档.初始化完成 = 假
    档.文档数 = 0
    档.样式数 = 0
    档.渲染数 = 0
    档.事件数 = 0
    档.脚本数 = 0
    档.适配数 = 0
    档.命中数 = 0
    档.失败数 = 0
    档.健康 = "未初始化"
    返回 档
}

函数 内核核心_登记(档) {
    追加(核心账本, 档)
    核心建数 = 核心建数 + 1
    返回 档
}

函数 内核核心_创建(名称, 视口宽, 视口高) {
    定义 档 = 内核核心_建档(名称, 视口宽, 视口高)
    内核核心_初始化(档)
    返回 内核核心_登记(档)
}

函数 内核核心_初始化(档) {
    DOM_初始化()
    CSS_初始化()
    CSS引擎_初始化()
    NCSC_初始化()
    渲染_初始化(档.视口宽, 档.视口高)
    事件循环_初始化()
    表达式_初始化()
    JS_初始化()
    JS_注入全局接口()
    档.当前样式档 = 样式解析_创建("样式解析", "内核核心")
    档.当前适配档 = 内核适配_创建("内核适配", 档.视口宽, 档.视口高)
    档.样式数 = 档.样式数 + 1
    档.适配数 = 档.适配数 + 1
    档.初始化完成 = 真
    档.健康 = "运行"
    核心总执行 = 核心总执行 + 1
    返回 档
}

函数 内核核心_建请求(地址, 页面源码, 样式源码, 脚本源码) {
    定义 请求 = 堆_分配(核心请求)
    请求.地址 = 地址
    请求.页面源码 = 页面源码
    请求.样式源码 = 样式源码
    请求.脚本源码 = 脚本源码
    请求.入口节点 = 0
    请求.输入类型 = ""
    请求.输入数据 = 0
    返回 请求
}

函数 内核核心_创建文档(档, 地址) {
    定义 文档 = DOM_创建文档(地址)
    档.当前地址 = 地址
    档.当前文档 = 文档
    档.文档数 = 档.文档数 + 1
    核心总执行 = 核心总执行 + 1
    返回 文档
}

函数 内核核心_解析页面(档, 源码, 地址) {
    定义 文档 = DOM_解析HTML(源码, 地址)
    档.当前地址 = 地址
    档.当前文档 = 文档
    档.文档数 = 档.文档数 + 1
    档.最近节点 = 文档
    返回 文档
}

函数 内核核心_创建节点(档, 文档, 类型, 标签名) {
    定义 标签ID = DOM_标签名到ID(标签名)
    定义 节点 = DOM_创建节点(文档, 类型, 标签名, 标签ID)
    档.最近节点 = 节点
    档.文档数 = 档.文档数 + 1
    返回 节点
}

函数 内核核心_追加节点(档, 文档, 父ID, 子节点) {
    DOM_添加子节点(文档, 父ID, 子节点)
    档.最近节点 = 子节点
    档.文档数 = 档.文档数 + 1
}

函数 内核核心_设属性(档, 文档, 节点ID, 键, 值) {
    DOM_设置属性(文档, 节点ID, 键, 值)
    档.最近节点 = 节点ID
    档.文档数 = 档.文档数 + 1
}

函数 内核核心_取属性(档, 文档, 节点ID, 键) {
    定义 值 = DOM_获取属性(文档, 节点ID, 键)
    档.最近节点 = 节点ID
    如果 (值 != 空 && 值 != 0) {
        档.命中数 = 档.命中数 + 1
        核心总命中 = 核心总命中 + 1
    }
    返回 值
}

函数 内核核心_查节点(档, 文档, 节点ID) {
    定义 节点 = DOM_查找节点(文档, 节点ID)
    档.最近节点 = 节点
    如果 (节点 != 空 && 节点 != 0) {
        档.命中数 = 档.命中数 + 1
        核心总命中 = 核心总命中 + 1
    }
    返回 节点
}

函数 内核核心_查ID(档, 文档, 标识) {
    定义 节点 = DOM_通过ID查找(文档, 标识)
    档.最近节点 = 节点
    如果 (节点 != 空 && 节点 != 0) {
        档.命中数 = 档.命中数 + 1
        核心总命中 = 核心总命中 + 1
    }
    返回 节点
}

函数 内核核心_查标签(档, 文档, 标签名) {
    定义 节点 = DOM_通过标签查找(文档, 标签名)
    档.最近节点 = 节点
    返回 节点
}

函数 内核核心_查类(档, 文档, 类名) {
    定义 节点 = DOM_通过类名查找(文档, 类名)
    档.最近节点 = 节点
    返回 节点
}

函数 内核核心_文档统计(档) {
    定义 统计 = DOM_统计()
    档.最近摘要 = 统计
    返回 统计
}

函数 内核核心_加载默认样式(档) {
    定义 默认样式 = CSS_创建默认样式()
    样式解析_加载文本(档.当前样式档, "默认样式", 默认样式)
    CSS_解析样式表(默认样式, "默认")
    CSS_添加样式表源码(默认样式, "默认")
    档.样式数 = 档.样式数 + 1
    返回 默认样式
}

函数 内核核心_加载样式(档, 样式源码, 来源) {
    样式解析_加载文本(档.当前样式档, 来源, 样式源码)
    CSS_解析样式表(样式源码, 来源)
    CSS_添加样式表源码(样式源码, 来源)
    档.样式数 = 档.样式数 + 1
    档.最近摘要 = 样式解析_摘要(档.当前样式档)
    返回 档.最近摘要
}

函数 内核核心_全树样式(档) {
    CSS_全树重算(档.当前文档)
    样式解析_自检(档.当前样式档)
    档.样式数 = 档.样式数 + 1
}

函数 内核核心_节点样式(档, 节点) {
    定义 结果 = NCSC_增强计算节点样式(档.当前文档, 节点)
    档.样式数 = 档.样式数 + 1
    档.最近节点 = 节点
    档.最近摘要 = 结果
    返回 结果
}

函数 内核核心_重算子树(档, 节点, 父样式) {
    CSS_重算子树(节点, 父样式)
    档.样式数 = 档.样式数 + 1
}

函数 内核核心_样式诊断(档) {
    定义 诊断 = CSS_诊断报告()
    档.最近摘要 = 诊断
    返回 诊断
}


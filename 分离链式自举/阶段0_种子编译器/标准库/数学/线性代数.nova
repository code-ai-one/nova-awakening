// Nova标准库 — 线性代数扩展
// 矩阵分解、线性方程组、特征值近似
// 补充矩阵.nova的高级功能

导入("../基础.nova")
导入("../../运行时/智能推理/注意力机制.nova")
导入("../../运行时/原语桩.nova")
导入("工具.nova")

定义 线代精度 = 1000
定义 精度 = 1000

// 高斯消元法 (解线性方程组 Ax=b)
// 增广矩阵: [n, n+1, 数据...]
// 回: 解向量 或 空(无解)

函数 高斯消元(A, b) { 定义 n = A[0]
    定义 可变 列号 = 0
 // 构建增广矩阵
 定义 可变 增强值 = [n, n + 1]
 定义 可变 i = 0
 当 (i < n) { 定义 可变 j = 0
 当 (j < n) {
 追加(增强值, A[2 + i * n + j])
 j = j + 1
 }
 追加(增强值, b[i])
 i = i + 1
 }
 // 前向消元
 当 (列号 < n) {
 // 找主元
 定义 可变 主元行 = 列号
 定义 可变 主元值 = 线代_绝对值(增强值[2 + 列号 * (n + 1) + 列号])
 i = 列号 + 1
 当 (i < n) { 定义 v = 线代_绝对值(增强值[2 + i * (n + 1) + 列号])
 如果 (v > 主元值) { 主元值 = v 主元行 = i }
 i = i + 1
 }
 如果 (主元值 == 0) { 返回 空 }
 // 交换行
 如果 (主元行 != 列号) { 定义 可变 j2 = 0
 当 (j2 <= n) { 定义 暂存 = 增强值[2 + 列号 * (n + 1) + j2]
 增强值[2 + 列号 * (n + 1) + j2] = 增强值[2 + 主元行 * (n + 1) + j2]
 增强值[2 + 主元行 * (n + 1) + j2] = 暂存
 j2 = j2 + 1
 }
 }
 // 消元
 i = 列号 + 1
 当 (i < n) { 定义 因子 = 增强值[2 + i * (n + 1) + 列号] * 线代精度 / 增强值[2 + 列号 * (n + 1) + 列号]
 定义 可变 j3 = 列号
 当 (j3 <= n) {
 增强值[2 + i * (n + 1) + j3] = 增强值[2 + i * (n + 1) + j3] - 因子 * 增强值[2 + 列号 * (n + 1) + j3] / 线代精度
 j3 = j3 + 1
 }
 i = i + 1
 }
 列号 = 列号 + 1
 }
 // 回代
 定义 可变 x = []
 i = 0
 当 (i < n) { 追加(x, 0) i = i + 1 }
 i = n - 1
 当 (i >= 0) { 定义 可变 和 = 增强值[2 + i * (n + 1) + n]
 定义 可变 j4 = i + 1
 当 (j4 < n) {
 和 = 和 - 增强值[2 + i * (n + 1) + j4] * x[j4] / 线代精度
 j4 = j4 + 1
 }
 如果 (增强值[2 + i * (n + 1) + i] == 0) { 返回 空 }
 x[i] = 和 * 线代精度 / 增强值[2 + i * (n + 1) + i]
 i = i - 1
 }
 返回 x
}

// LU 分解 (简化版)
// 回: [L矩阵, U矩阵]
函数 lu分解(A) { 定义 n = A[0]
 定义 可变 L = [n, n]
 定义 可变 U = [n, n]
 // 初始化
 定义 可变 i = 0
 当 (i < n * n) { 追加(L, 0) 追加(U, 0) i = i + 1 }
 i = 0
 当 (i < n) {
 // U 行
 定义 可变 j = i
 当 (j < n) { 定义 可变 和 = A[2 + i * n + j]
 定义 可变 k = 0
 当 (k < i) {
 和 = 和 - L[2 + i * n + k] * U[2 + k * n + j] / 线代精度
 k = k + 1
 }
 U[2 + i * n + j] = 和
 j = j + 1
 }
 // L 列
 j = i
 当 (j < n) { 如果 (i == j) {
 L[2 + i * n + i] = 线代精度
 } 否则 { 定义 可变 和2 = A[2 + j * n + i]
 定义 可变 k2 = 0
 当 (k2 < i) {
 和2 = 和2 - L[2 + j * n + k2] * U[2 + k2 * n + i] / 线代精度
 k2 = k2 + 1
 }
 如果 (U[2 + i * n + i] != 0) {
 L[2 + j * n + i] = 和2 * 线代精度 / U[2 + i * n + i]
 }
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 [L, U]
}

// 矩阵求逆 (高斯-约当消元)
函数 矩阵求逆(A) { 定义 n = A[0]
    定义 可变 列号 = 0
 // 增广矩阵 [A|I]
 定义 可变 增强值 = [n, 2 * n]
 定义 可变 i = 0
 当 (i < n) { 定义 可变 j = 0
 当 (j < n) {
 追加(增强值, A[2 + i * n + j])
 j = j + 1
 }
 j = 0
 当 (j < n) { 如果 (i == j) { 追加(增强值, 线代精度) }
 否则 { 追加(增强值, 0) }
 j = j + 1
 }
 i = i + 1
 }
 // 前向消元
 当 (列号 < n) {
 // 找主元
 如果 (增强值[2 + 列号 * 2 * n + 列号] == 0) { 返回 空 }
 定义 主元 = 增强值[2 + 列号 * 2 * n + 列号]
 // 主元行除以主元
 定义 可变 j2 = 0
 当 (j2 < 2 * n) {
 增强值[2 + 列号 * 2 * n + j2] = 增强值[2 + 列号 * 2 * n + j2] * 线代精度 / 主元
 j2 = j2 + 1
 }
 // 消除其他行
 i = 0
 当 (i < n) { 如果 (i != 列号) { 定义 因子 = 增强值[2 + i * 2 * n + 列号]
 j2 = 0
 当 (j2 < 2 * n) {
 增强值[2 + i * 2 * n + j2] = 增强值[2 + i * 2 * n + j2] - 因子 * 增强值[2 + 列号 * 2 * n + j2] / 线代精度
 j2 = j2 + 1
 }
 }
 i = i + 1
 }
 列号 = 列号 + 1
 }
 // 提取逆矩阵
 定义 可变 逆 = [n, n]
 i = 0
 当 (i < n) { 定义 可变 j3 = 0
 当 (j3 < n) {
 追加(逆, 增强值[2 + i * 2 * n + n + j3])
 j3 = j3 + 1
 }
 i = i + 1
 }
 返回 逆
}

// 幂迭代法 (求最大特征值近似)
函数 最大特征值(A, 迭代次数) { 定义 n = A[0]
 // 初始向量
 定义 可变 v = []
 定义 可变 i = 0
 当 (i < n) { 追加(v, 线代精度) i = i + 1 }
 定义 可变 特征值 = 0
 定义 可变 迭代 = 0
 当 (迭代 < 迭代次数) {
 // w = A * v
 定义 可变 w = []
 i = 0
 当 (i < n) { 定义 可变 和 = 0
 定义 可变 j = 0
 当 (j < n) {
 和 = 和 + A[2 + i * n + j] * v[j] / 线代精度
 j = j + 1
 }
 追加(w, 和)
 i = i + 1
 }
 // 找最大分量
 定义 可变 最大 = 线代_绝对值(w[0])
 i = 1
 当 (i < n) { 定义 av = 线代_绝对值(w[i])
 如果 (av > 最大) { 最大 = av }
 i = i + 1
 }
 如果 (最大 == 0) { 最大 = 1 }
 特征值 = 最大
 // 归一化
 i = 0
 当 (i < n) {
 v[i] = w[i] * 线代精度 / 最大
 i = i + 1
 }
 迭代 = 迭代 + 1
 }
 返回 特征值
}

// Gram-Schmidt 正交化
函数 正交化(向量组) { 定义 n = 计数(向量组)
 定义 维度 = 计数(向量组[0])
 定义 可变 正交 = []
 定义 可变 i = 0
 当 (i < n) { 定义 可变 u = []
 定义 可变 d = 0
 当 (d < 维度) { 追加(u, 向量组[i][d]) d = d + 1 }
 // 减去之前的投影
 定义 可变 j = 0
 当 (j < 计数(正交)) { 定义 投影 = 线代_点积(u, 正交[j]) * 线代精度 / 线代_点积(正交[j], 正交[j])
 d = 0
 当 (d < 维度) {
 u[d] = u[d] - 投影 * 正交[j][d] / 线代精度
 d = d + 1
 }
 j = j + 1
 }
 // 归一化
 定义 范数 = 线代_开方(线代_点积(u, u))
 如果 (范数 > 0) {
 d = 0
 当 (d < 维度) {
 u[d] = u[d] * 线代精度 / 范数
 d = d + 1
 }
 追加(正交, u)
 }
 i = i + 1
 }
 返回 正交
}

// 向量/矩阵范数

// L2 范数
函数 向量范数(v, _扩2) { 返回 线代_开方(线代_点积(v, v))
}

// L1 范数
函数 向量l1范数(v) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 计数(v)) {
 和 = 和 + 线代_绝对值(v[i])
 i = i + 1
 }
 返回 和
}

// Frobenius 范数
函数 矩阵f范数(A) { 定义 n = A[0] * A[1]
 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < n) {
 和 = 和 + A[2 + i] * A[2 + i] / 线代精度
 i = i + 1
 }
 返回 线代_开方(和)
}

// LU分解求解 (Ly=b, Ux=y)
函数 lu求解(L, U, b) { 定义 n = L[0]
 // 前向替代: Ly = b
 定义 可变 y = []
 定义 可变 i = 0
 当 (i < n) { 追加(y, 0)
 i = i + 1 }
 i = 0
 当 (i < n) { 定义 可变 和 = b[i]
 定义 可变 j = 0
 当 (j < i) {
 和 = 和 - L[2 + i * n + j] * y[j] / 线代精度
 j = j + 1
 }
 y[i] = 和 * 线代精度 / L[2 + i * n + i]
 i = i + 1
 }
 // 回代: Ux = y
 定义 可变 x = []
 i = 0
 当 (i < n) { 追加(x, 0)
 i = i + 1 }
 i = n - 1
 当 (i >= 0) { 定义 可变 和2 = y[i]
 定义 可变 j2 = i + 1
 当 (j2 < n) {
 和2 = 和2 - U[2 + i * n + j2] * x[j2] / 线代精度
 j2 = j2 + 1
 }
 如果 (U[2 + i * n + i] == 0) { 返回 空 }
 x[i] = 和2 * 线代精度 / U[2 + i * n + i]
 i = i - 1
 }
 返回 x
}

// 条件数 (1-范数估计)
函数 条件数(A) { 定义 n = A[0]
 // ||A||_inf
 定义 可变 范数A = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 行和 = 0
 定义 可变 j = 0
 当 (j < n) { 定义 可变 v = A[2 + i * n + j]
 如果 (v < 0) { v = 0 - v }
 行和 = 行和 + v
 j = j + 1
 }
 如果 (行和 > 范数A) { 范数A = 行和 }
 i = i + 1
 }
 // ||A^-1||_inf
 定义 逆 = 矩阵求逆(A)
 如果 (逆 == 空) { 返回 0x7FFFFFFF }
 定义 可变 范数逆 = 0
 i = 0
 当 (i < n) { 定义 可变 行和2 = 0
 定义 可变 j2 = 0
 当 (j2 < n) { 定义 可变 v2 = 逆[2 + i * n + j2]
 如果 (v2 < 0) { v2 = 0 - v2 }
 行和2 = 行和2 + v2
 j2 = j2 + 1
 }
 如果 (行和2 > 范数逆) { 范数逆 = 行和2 }
 i = i + 1
 }
 如果 (线代精度 == 0) { 返回 0 }
 返回 范数A * 范数逆 / 线代精度
}

// 最小特征值 (逆幂迭代, 0)
函数 最小特征值(A, 迭代次数) { 定义 _n = A[0]
 定义 逆 = 矩阵求逆(A)
 如果 (逆 == 空) { 返回 0 }
 定义 最大逆特征 = 最大特征值(逆, 迭代次数)
 如果 (最大逆特征 == 0) { 返回 0 }
 返回 线代精度 * 线代精度 / 最大逆特征
}

// 行列式 (LU分解法, 任意n)
函数 行列式(A, _扩2) { 定义 n = A[0]
 定义 分解 = lu分解(A)
 定义 U = 分解[1]
 定义 可变 行列式 = 线代精度
 定义 可变 i = 0
 当 (i < n) {
 行列式 = 行列式 * U[2 + i * n + i] / 线代精度
 i = i + 1
 }
 返回 行列式
}

// 矩阵秩 (通过高斯消元)
函数 矩阵秩(A) { 定义 行 = A[0]
    定义 可变 列号 = 0
 定义 列 = A[1]
 // 复制矩阵
 定义 可变 m = [行, 列]
 定义 可变 i = 0
 当 (i < 行 * 列) { 追加(m, A[2 + i])
 i = i + 1 }
 定义 可变 秩 = 0
 定义 可变 行号 = 0
 当 (行号 < 行 且 列号 < 列) {
 // 找主元
 定义 可变 主元行 = 行号
 定义 可变 主元值 = 线代_绝对值(m[2 + 行号 * 列 + 列号])
 i = 行号 + 1
 当 (i < 行) { 定义 v = 线代_绝对值(m[2 + i * 列 + 列号])
 如果 (v > 主元值) { 主元值 = v
 主元行 = i }
 i = i + 1
 }
 如果 (主元值 == 0) { 列号 = 列号 + 1
 续 }
 // 交换行
 如果 (主元行 != 行号) { 定义 可变 j = 0
 当 (j < 列) { 定义 t = m[2 + 行号 * 列 + j]
 m[2 + 行号 * 列 + j] = m[2 + 主元行 * 列 + j]
 m[2 + 主元行 * 列 + j] = t
 j = j + 1
 }
 }
 // 消元
 i = 行号 + 1
 当 (i < 行) { 定义 因子 = m[2 + i * 列 + 列号] * 线代精度 / m[2 + 行号 * 列 + 列号]
 定义 可变 j2 = 列号
 当 (j2 < 列) {
 m[2 + i * 列 + j2] = m[2 + i * 列 + j2] - 因子 * m[2 + 行号 * 列 + j2] / 线代精度
 j2 = j2 + 1
 }
 i = i + 1
 }
 秩 = 秩 + 1
 行号 = 行号 + 1
 列号 = 列号 + 1
 }
 返回 秩
}

// Cholesky 分解 (正定对称矩阵)
函数 乔列斯基(A) { 定义 n = A[0]
 定义 可变 L = [n, n]
 定义 可变 i = 0
 当 (i < n * n) { 追加(L, 0)
 i = i + 1 }
 i = 0
 当 (i < n) { 定义 可变 j = 0
 当 (j <= i) { 定义 可变 和 = 0
 定义 可变 k = 0
 当 (k < j) {
 和 = 和 + L[2 + i * n + k] * L[2 + j * n + k] / 线代精度
 k = k + 1
 }
 如果 (i == j) { 定义 差值 = A[2 + i * n + i] - 和
 如果 (差值 <= 0) { 返回 空 }
 L[2 + i * n + j] = 线代_开方(差值)
 } 否则 { 定义 分母 = L[2 + j * n + j]
 如果 (分母 == 0) { 返回 空 }
 L[2 + i * n + j] = (A[2 + i * n + j] - 和) * 线代精度 / 分母
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 L
}

// 内部工具

函数 线代_绝对值(x) {
    如果 (x < 0) { 返回 0 - x
}
 返回 x
}

函数 线代_点积(a, b) { 定义 n = 计数(a)
 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < n) {
 和 = 和 + a[i] * b[i] / 线代精度
 i = i + 1
 }
 返回 和
}

函数 线代_开方(n) { 返回 开方(n) }

// 合并部分使用的列表版向量点积 (3参数)
函数 向量_点积(a, b, n) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < n) { 和 = 和 + a[i] * b[i] / 精度 i = i + 1 }
 返回 和
}

// 合并自 标准库/数学/线性代数/线性代数.nova

函数 QR分解(A, m, n) {
 // 提取列向量
 定义 可变 Q列 = []
 定义 可变 j = 0
 当 (j < n) { 定义 可变 列 = []
 定义 可变 i = 0
 当 (i < m) { 追加(列, A[i * n + j]) i = i + 1 }
 追加(Q列, 列)
 j = j + 1
 }
 定义 可变 R = []
 定义 可变 索引 = 0
 当 (索引 < n * n) { 追加(R, 0) 索引 = 索引 + 1 }
 // Gram-Schmidt 正交化
 j = 0
 当 (j < n) {
 // 减去之前分量的投影
 定义 可变 k = 0
 当 (k < j) { 定义 点积 = 向量_点积(Q列[j], Q列[k], m)
 R[k * n + j] = 点积
 定义 可变 i = 0
 当 (i < m) {
 Q列[j][i] = Q列[j][i] - 点积 * Q列[k][i] / 精度
 i = i + 1
 }
 k = k + 1
 }
 // 归一化
 定义 范数 = 向量_范数(Q列[j], m)
 R[j * n + j] = 范数
 如果 (范数 > 0) { 定义 可变 i = 0
 当 (i < m) {
 Q列[j][i] = Q列[j][i] * 精度 / 范数
 i = i + 1
 }
 }
 j = j + 1
 }
 // 构造 Q 矩阵
 定义 可变 Q = []
 定义 可变 i = 0
 当 (i < m * n) { 追加(Q, 0) i = i + 1 }
 j = 0
 当 (j < n) {
 i = 0
 当 (i < m) {
 Q[i * n + j] = Q列[j][i]
 i = i + 1
 }
 j = j + 1
 }
 返回 [Q, R]
}

函数 共轭梯度(A_稀疏, b, n, 最大迭代, 容差) { 定义 可变 x = []
 定义 可变 i = 0
 当 (i < n) { 追加(x, 0) i = i + 1 }
 // r = b - Ax
 定义 Ax = 稀疏矩阵_乘向量(A_稀疏, x)
 定义 可变 r = []
 定义 可变 p = []
 i = 0
 当 (i < n) {
 追加(r, b[i] - Ax[i])
 追加(p, b[i] - Ax[i])
 i = i + 1
 }
 定义 可变 rsold = 向量_点积(r, r, n)
 定义 可变 迭代 = 0
 当 (迭代 < 最大迭代) { 定义 Ap = 稀疏矩阵_乘向量(A_稀疏, p)
 定义 pAp = 向量_点积(p, Ap, n)
 如果 (pAp == 0) { 迭代 = 最大迭代 } 否则 {
 定义 学习率 = rsold * 精度 / pAp
 i = 0
 当 (i < n) {
 x[i] = x[i] + 学习率 * p[i] / 精度
 r[i] = r[i] - 学习率 * Ap[i] / 精度
 i = i + 1
 }
 定义 rsnew = 向量_点积(r, r, n)
 如果 (rsnew < 容差) { 迭代 = 最大迭代 } 否则 {
 定义 动量率 = rsnew * 精度 / rsold
 i = 0
 当 (i < n) {
 p[i] = r[i] + 动量率 * p[i] / 精度
 i = i + 1
 }
 rsold = rsnew
 } }
 迭代 = 迭代 + 1
 }
 返回 x
}

// [v2反哺] 向量_点积 — 向量点积SIMD4路展开(4x吞吐, 替换逐元素朴素乘加)
// 整数向量点积_SIMD展开 (4路并行, 提升4x吞吐)
// 类人脑: 并行群体编码，类似视觉皮层方向柱同时激活
函数 向量点积_SIMD4(a, b, n) {
    如果 (a == 0 或 b == 0 或 n == 0) { 返回 0 }
    定义 可变 s0 = 0;  定义 可变 s1 = 0
    定义 可变 s2 = 0;  定义 可变 s3 = 0
    定义 可变 i = 0
    // 4路展开
    当 (i + 4 <= n) {
        s0 = s0 + Q乘(内存_读32有符号(a+i*4),   内存_读32有符号(b+i*4))
        s1 = s1 + Q乘(内存_读32有符号(a+(i+1)*4), 内存_读32有符号(b+(i+1)*4))
        s2 = s2 + Q乘(内存_读32有符号(a+(i+2)*4), 内存_读32有符号(b+(i+2)*4))
        s3 = s3 + Q乘(内存_读32有符号(a+(i+3)*4), 内存_读32有符号(b+(i+3)*4))
        i = i + 4
    }
    // 处理余数
    当 (i < n) {
        s0 = s0 + Q乘(内存_读32有符号(a+i*4), 内存_读32有符号(b+i*4))
        i = i + 1
    }
    返回 s0 + s1 + s2 + s3
}

函数 向量_范数(v, n) { 定义 点 = 向量_点积(v, v, n)
 返回 整数平方根(点 * 精度)
}

函数 整数平方根(n) {
    如果 (n <= 0) { 返回 0
}
 定义 可变 x = n
 定义 可变 y = (x + 1) / 2
 当 (y < x) { x = y y = (x + n / x) / 2 }
 返回 x
}

函数 特征值_QR(A, n, 迭代次数) {
 // 复制矩阵
 定义 可变 当前 = []
 定义 可变 i = 0
 当 (i < n * n) { 追加(当前, A[i]) i = i + 1 }
 定义 可变 迭代 = 0
 当 (迭代 < 迭代次数) { 定义 qr = QR分解(当前, n, n)
 定义 Q = qr[0]
 定义 R = qr[1]
 // A_{k+1} = R * Q
 定义 可变 新矩阵 = []
 i = 0
 当 (i < n * n) { 追加(新矩阵, 0) i = i + 1 }
 i = 0
 当 (i < n) { 定义 可变 j = 0
 当 (j < n) { 定义 可变 和 = 0
 定义 可变 k = 0
 当 (k < n) {
 和 = 和 + R[i * n + k] * Q[k * n + j] / 精度
 k = k + 1
 }
 新矩阵[i * n + j] = 和
 j = j + 1
 }
 i = i + 1
 }
 当前 = 新矩阵
 迭代 = 迭代 + 1
 }
 // 对角线 = 特征值近似
 定义 可变 特征值 = []
 i = 0
 当 (i < n) {
 追加(特征值, 当前[i * n + i])
 i = i + 1
 }
 返回 特征值
}

函数 稀疏矩阵_乘向量(sp, x) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < sp[3]) { 追加(结果, 0) i = i + 1 }
 i = 0
 当 (i < sp[3]) { 定义 可变 和 = 0
 定义 可变 k = sp[2][i]
 当 (k < sp[2][i + 1]) {
 和 = 和 + sp[0][k] * x[sp[1][k]] / 精度
 k = k + 1
 }
 结果[i] = 和
 i = i + 1
 }
 返回 结果
}

函数 稀疏矩阵_从密集(A, m, n) { 定义 可变 值 = []
 定义 可变 列idx = []
 定义 可变 行ptr = [0]
 定义 可变 nnz = 0
 定义 可变 i = 0
 当 (i < m) { 定义 可变 j = 0
 当 (j < n) { 如果 (A[i * n + j] != 0) {
 追加(值, A[i * n + j])
 追加(列idx, j)
 nnz = nnz + 1
 }
 j = j + 1
 }
 追加(行ptr, nnz)
 i = i + 1
 }
 返回 [值, 列idx, 行ptr, m, n, nnz]
}

函数 稀疏矩阵_创建(行数, 列数) { 定义 可变 行指针 = []
 定义 可变 i = 0
 当 (i <= 行数) { 追加(行指针, 0) i = i + 1 }
 返回 [[], [], 行指针, 行数, 列数, 0]
}

函数 稀疏矩阵_取(sp, 行, 列) { 定义 起 = sp[2][行]
 定义 终 = sp[2][行 + 1]
 定义 可变 k = 起
 当 (k < 终) { 如果 (sp[1][k] == 列) { 返回 sp[0][k] }
 k = k + 1
 }
 返回 0
}
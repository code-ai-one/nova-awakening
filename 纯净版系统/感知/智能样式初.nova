导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./内核直连层.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/创建甲.nova")

定义 样式缓存_默认容量 = 512
定义 样式缓存_最大容量 = 4096
定义 样式缓存_淘汰比例 = 25
定义 样式缓存_条目大小 = 28

定义 可变 AI样式缓存表 = 0
定义 可变 AI样式缓存数量 = 0
定义 可变 AI样式缓存容量 = 0
定义 可变 AI样式缓存_命中数 = 0
定义 可变 AI样式缓存_未命中数 = 0
定义 可变 AI样式缓存_淘汰数 = 0
定义 可变 AI样式缓存_无效化数 = 0

结构 样式缓存Entry {
    规则哈希,
    属性ID,
    解析值,
    命中次数,
    上次使用,
}

函数 AI样式_初始化缓存() {
    AI样式_初始化缓存_容量(样式缓存_默认容量)
}

函数 AI样式_初始化缓存_容量(容量) {
    如果 (容量 > 样式缓存_最大容量) { 容量 = 样式缓存_最大容量 }
    AI样式缓存容量 = 容量
    AI样式缓存表 = 堆_分配_数组(AI样式缓存容量 * 样式缓存_条目大小)
    AI样式缓存数量 = 0
    AI样式缓存_命中数 = 0
    AI样式缓存_未命中数 = 0
    AI样式缓存_淘汰数 = 0
    AI样式缓存_无效化数 = 0
}

函数 AI样式_查缓存(规则哈希, 属性ID) {
    定义 可变 i = 0
    当 (i < AI样式缓存数量) {
        定义 偏移 = AI样式缓存表 + i * 样式缓存_条目大小
        如果 (内存_读32(偏移) == 规则哈希 && 内存_读32(偏移 + 4) == 属性ID) {
            定义 旧命中 = 内存_读32(偏移 + 16)
            内存_写32(偏移 + 16, 旧命中 + 1)
            内存_写64(偏移 + 20, 平台_获取高精度时间())
            AI样式缓存_命中数 = AI样式缓存_命中数 + 1
            返回 内存_读64(偏移 + 8)
        }
        i = i + 1
    }
    AI样式缓存_未命中数 = AI样式缓存_未命中数 + 1
    返回 0
}

函数 AI样式_写缓存(规则哈希, 属性ID, 解析值) {
    定义 已存在 = AI样式_查缓存位置(规则哈希, 属性ID)
    如果 (已存在 >= 0) {
        定义 偏移 = AI样式缓存表 + 已存在 * 样式缓存_条目大小
        内存_写64(偏移 + 8, 解析值)
        内存_写64(偏移 + 20, 平台_获取高精度时间())
        返回
    }

    如果 (AI样式缓存数量 >= AI样式缓存容量) {
        AI样式_LRU淘汰()
    }

    如果 (AI样式缓存数量 < AI样式缓存容量) {
        定义 偏移 = AI样式缓存表 + AI样式缓存数量 * 样式缓存_条目大小
        内存_写32(偏移, 规则哈希)
        内存_写32(偏移 + 4, 属性ID)
        内存_写64(偏移 + 8, 解析值)
        内存_写32(偏移 + 16, 0)
        内存_写64(偏移 + 20, 平台_获取高精度时间())
        AI样式缓存数量 = AI样式缓存数量 + 1
    }
}

函数 AI样式_查缓存位置(规则哈希, 属性ID) {
    定义 可变 i = 0
    当 (i < AI样式缓存数量) {
        定义 偏移 = AI样式缓存表 + i * 样式缓存_条目大小
        如果 (内存_读32(偏移) == 规则哈希 && 内存_读32(偏移 + 4) == 属性ID) {
            返回 i
        }
        i = i + 1
    }
    返回 -1
}

函数 AI样式_LRU淘汰() {
    定义 淘汰数 = AI样式缓存容量 * 样式缓存_淘汰比例 / 100
    如果 (淘汰数 < 1) { 淘汰数 = 1 }

    // 找到最旧的条目并淘汰
    定义 可变 已淘汰 = 0
    当 (已淘汰 < 淘汰数 && AI样式缓存数量 > 0) {
        定义 可变 最旧索引 = 0
        定义 可变 最旧时间 = 内存_读64(AI样式缓存表 + 20)
        定义 可变 i = 1
        当 (i < AI样式缓存数量) {
            定义 时间 = 内存_读64(AI样式缓存表 + i * 样式缓存_条目大小 + 20)
            如果 (时间 < 最旧时间) {
                最旧时间 = 时间
                最旧索引 = i
            }
            i = i + 1
        }

        AI样式_移除条目(最旧索引)
        已淘汰 = 已淘汰 + 1
        AI样式缓存_淘汰数 = AI样式缓存_淘汰数 + 1
    }
}

函数 AI样式_移除条目(索引) {
    如果 (索引 < 0 || 索引 >= AI样式缓存数量) { 返回 }
    定义 最后 = AI样式缓存数量 - 1
    如果 (索引 != 最后) {
        定义 目标偏移 = AI样式缓存表 + 索引 * 样式缓存_条目大小
        定义 源偏移 = AI样式缓存表 + 最后 * 样式缓存_条目大小
        内存_拷贝(目标偏移, 源偏移, 样式缓存_条目大小)
    }
    AI样式缓存数量 = AI样式缓存数量 - 1
}

函数 AI样式_无效化_规则(规则哈希) {
    定义 可变 i = 0
    当 (i < AI样式缓存数量) {
        定义 偏移 = AI样式缓存表 + i * 样式缓存_条目大小
        如果 (内存_读32(偏移) == 规则哈希) {
            AI样式_移除条目(i)
            AI样式缓存_无效化数 = AI样式缓存_无效化数 + 1
            继续
        }
        i = i + 1
    }
}

函数 AI样式_无效化_属性(属性ID) {
    定义 可变 i = 0
    当 (i < AI样式缓存数量) {
        定义 偏移 = AI样式缓存表 + i * 样式缓存_条目大小
        如果 (内存_读32(偏移 + 4) == 属性ID) {
            AI样式_移除条目(i)
            AI样式缓存_无效化数 = AI样式缓存_无效化数 + 1
            继续
        }
        i = i + 1
    }
}

函数 AI样式_清空缓存() {
    AI样式缓存数量 = 0
    AI样式缓存_命中数 = 0
    AI样式缓存_未命中数 = 0
}

函数 AI样式_缓存命中率() {
    定义 总数 = AI样式缓存_命中数 + AI样式缓存_未命中数
    如果 (总数 == 0) { 返回 0 }
    返回 AI样式缓存_命中数 * 100 / 总数
}

函数 AI样式_批量写缓存(条目列表) {
    定义 可变 i = 0
    当 (i < 计数(条目列表)) {
        定义 条目 = 条目列表[i]
        AI样式_写缓存(条目[0], 条目[1], 条目[2])
        i = i + 1
    }
}

函数 AI样式_缓存统计() {
    返回 [AI样式缓存数量, AI样式缓存容量, AI样式缓存_命中数, AI样式缓存_未命中数, AI样式缓存_淘汰数, AI样式缓存_无效化数, AI样式_缓存命中率()]
}

函数 AI样式_缓存预热(常用规则列表) {
    定义 可变 i = 0
    当 (i < 计数(常用规则列表)) {
        定义 规则 = 常用规则列表[i]
        AI样式_写缓存(规则[0], 规则[1], 规则[2])
        i = i + 1
    }
}

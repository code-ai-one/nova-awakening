导入("../基础.nova")


// 解析一行CSV
函数 csv_解析行(行, 分隔符) {
    定义 可变 字段 = []
    定义 可变 当前 = ""
    定义 可变 引号内 = 0
    定义 可变 i = 0
    当 (i < 字节长度(行)) {
        定义 c = 字节取(行, i)
        如果 (引号内 == 1) {
            如果 (c == 字符_双引号) {
                // 检查转义引号 ""
                如果 (i + 1 < 字节长度(行) 且 字节取(行, i + 1) == 字符_双引号) {
                    当前 = 字符串拼接(当前, 字符(34))
                    i = i + 2
                } 否则 {
                    引号内 = 0
                    i = i + 1
                }
            } 否则 {
                当前 = 字符串拼接(当前, 字符(c))
                i = i + 1
            }
        } 否则 {
            如果 (c == 字符_双引号) {
                引号内 = 1
                i = i + 1
            } 否则 如果 (c == 分隔符) {
                追加(字段, 当前)
                当前 = ""
                i = i + 1
            } 否则 {
                当前 = 字符串拼接(当前, 字符(c))
                i = i + 1
            }
        }
    }
    追加(字段, 当前)
    返回 字段
}

// 解析CSV文本 (多行)
函数 csv_解析(文本) {
    定义 可变 行列表 = []
    定义 可变 当前行 = ""
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        定义 c = 字节取(文本, i)
        如果 (c == 字符_换行) {
            如果 (字节长度(当前行) > 0) {
                追加(行列表, csv_解析行(当前行, 44))
            }
            当前行 = ""
        } 否则 如果 (c != 字符_回车) {
            当前行 = 字符串拼接(当前行, 字符(c))
        }
        i = i + 1
    }
    如果 (字节长度(当前行) > 0) {
        追加(行列表, csv_解析行(当前行, 44))
    }
    返回 行列表
}

// 生成CSV行
函数 csv_生成行(字段列表) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(字段列表)) {
        如果 (i > 0) { 结果 = 字符串拼接(结果, ",") }
        定义 字段 = 转字符串(字段列表[i])
        // 检查是否需要引号
        定义 可变 需引号 = 0
        定义 可变 j = 0
        当 (j < 字节长度(字段)) {
            定义 c = 字节取(字段, j)
            如果 (c == 44 或 c == 字符_双引号 或 c == 字符_换行) { 需引号 = 1 }
            j = j + 1
        }
        如果 (需引号 == 1) {
            结果 = 字符串拼接(结果, 字符(34))
            结果 = 字符串拼接(结果, 字段)
            结果 = 字符串拼接(结果, 字符(34))
        } 否则 {
            结果 = 字符串拼接(结果, 字段)
        }
        i = i + 1
    }
    返回 结果
}

// 生成CSV文本
函数 CSV解_csv_生成(表格) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(表格)) {
        如果 (i > 0) { 结果 = 字符串拼接(结果, 字符(10)) }
        结果 = 字符串拼接(结果, csv_生成行(表格[i]))
        i = i + 1
    }
    返回 结果
}

// 获取列
函数 csv_取列(表格, 列索引) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(表格)) {
        定义 行 = 表格[i]
        如果 (列索引 < 计数(行)) {
            追加(结果, 行[列索引])
        } 否则 {
            追加(结果, "")
        }
        i = i + 1
    }
    返回 结果
}

// 行数/列数
函数 csv_行数(表格) { 返回 计数(表格) }

函数 csv_列数(表格) {
    如果 (计数(表格) == 0) { 返回 0 }
    返回 计数(表格[0])
}

// CSV写入

函数 csv_行转字符串(行, 分隔符) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(行)) {
        如果 (i > 0) { 结果 = 结果 + 分隔符 }
        定义 字段 = 转字符串(行[i])
        // 检查是否需要引号
        定义 可变 需引号 = 假
        定义 可变 j = 0
        当 (j < 计数(字段)) {
            定义 c = 字节取(字段, j)
            如果 (c == 44 或 c == 字符_双引号 或 c == 字符_换行 或 c == 字符_回车) { 需引号 = 真 }
            j = j + 1
        }
        如果 (需引号) {
            结果 = 结果 + "\""
            j = 0
            当 (j < 计数(字段)) {
                定义 c = 字节取(字段, j)
                如果 (c == 字符_双引号) { 结果 = 结果 + "\"\"" }
                否则 { 结果 = 结果 + 字符(c) }
                j = j + 1
            }
            结果 = 结果 + "\""
        } 否则 {
            结果 = 结果 + 字段
        }
        i = i + 1
    }
    返回 结果
}

函数 csv_表格转字符串(表格, 分隔符) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(表格)) {
        如果 (i > 0) { 结果 = 结果 + "\n" }
        结果 = 结果 + csv_行转字符串(表格[i], 分隔符)
        i = i + 1
    }
    返回 结果
}

// 列操作

函数 csv_获取列(表格, 列索引) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(表格)) {
        如果 (列索引 < 计数(表格[i])) { 追加(结果, 表格[i][列索引]) }
        否则 { 追加(结果, "") }
        i = i + 1
    }
    返回 结果
}

函数 csv_添加列(表格, 列数据) {
    定义 可变 i = 0
    当 (i < 计数(表格)) {
        如果 (i < 计数(列数据)) { 追加(表格[i], 列数据[i]) }
        否则 { 追加(表格[i], "") }
        i = i + 1
    }
}

函数 csv_删除列(表格, 列索引) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(表格)) {
        定义 可变 新行 = []
        定义 可变 j = 0
        当 (j < 计数(表格[i])) {
            如果 (j != 列索引) { 追加(新行, 表格[i][j]) }
            j = j + 1
        }
        追加(结果, 新行)
        i = i + 1
    }
    返回 结果
}

// 过滤

函数 csv_过滤行(表格, 列索引, 目标值) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(表格)) {
        如果 (列索引 < 计数(表格[i]) 且 表格[i][列索引] == 目标值) {
            追加(结果, 表格[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 csv_过滤非空(表格, 列索引) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(表格)) {
        如果 (列索引 < 计数(表格[i]) 且 计数(表格[i][列索引]) > 0) {
            追加(结果, 表格[i])
        }
        i = i + 1
    }
    返回 结果
}

// 排序

函数 csv_排序(表格, 列索引, 升序) {
    // 冒泡排序
    定义 可变 n = 计数(表格)
    定义 可变 i = 0
    当 (i < n - 1) {
        定义 可变 j = 0
        当 (j < n - i - 1) {
            如果 (升序) {
                如果 (表格[j][列索引] > 表格[j+1][列索引]) { 应交换 = 真 }
            } 否则 {
                如果 (表格[j][列索引] < 表格[j+1][列索引]) { 应交换 = 真 }
            }
            如果 (应交换) {
                定义 临 = 表格[j]
                表格[j] = 表格[j+1]
                表格[j+1] = 临
            }
            j = j + 1
        }
        i = i + 1
    }
}

// 聚合

函数 csv_列求和(表格, 列索引) {
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(表格)) {
        如果 (列索引 < 计数(表格[i])) { 总 = 总 + 表格[i][列索引] }
        i = i + 1
    }
    返回 总
}

函数 csv_列平均(表格, 列索引) {
    如果 (计数(表格) == 0) { 返回 0 }
    返回 csv_列求和(表格, 列索引) / 计数(表格)
}

函数 csv_列最大(表格, 列索引) {
    如果 (计数(表格) == 0) { 返回 0 }
    定义 可变 最大 = 表格[0][列索引]
    定义 可变 i = 1
    当 (i < 计数(表格)) {
        如果 (列索引 < 计数(表格[i]) 且 表格[i][列索引] > 最大) { 最大 = 表格[i][列索引] }
        i = i + 1
    }
    返回 最大
}

函数 csv_列最小(表格, 列索引) {
    如果 (计数(表格) == 0) { 返回 0 }
    定义 可变 最小 = 表格[0][列索引]
    定义 可变 i = 1
    当 (i < 计数(表格)) {
        如果 (列索引 < 计数(表格[i]) 且 表格[i][列索引] < 最小) { 最小 = 表格[i][列索引] }
        i = i + 1
    }
    返回 最小
}

// 去重

函数 csv_去重(表格, 列索引) {
    定义 可变 结果 = []
    定义 可变 已见 = []
    定义 可变 i = 0
    当 (i < 计数(表格)) {
        定义 值 = 表格[i][列索引]
        定义 可变 重复 = 假
        定义 可变 j = 0
        当 (j < 计数(已见)) {
            如果 (已见[j] == 值) { 重复 = 真 }
            j = j + 1
        }
        如果 (!重复) { 追加(结果, 表格[i])  追加(已见, 值) }
        i = i + 1
    }
    返回 结果
}

定义 可变 _csv_解析数 = 0
定义 可变 _csv_最大行 = 0
定义 可变 _csv_写入数 = 0

函数 csv_记录解析(行数) {
    _csv_解析数 = _csv_解析数 + 1
    如果 (行数 > _csv_最大行) { _csv_最大行 = 行数 }
}
函数 csv_记录写入() { _csv_写入数 = _csv_写入数 + 1 }



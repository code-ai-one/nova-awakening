// Nova标准库 — 序列序列化/解析
// 完整递归序列化 + 递归解析 + 字符串转义


定义 可变 _JSON序列化深度 = 0

函数 序列_序列化(值) {
    _JSON序列化深度 = _JSON序列化深度 + 1
    如果 (_JSON序列化深度 > 500) { _JSON序列化深度 = _JSON序列化深度 - 1; 返回 "null" }
    如果 (值 == 空) { _JSON序列化深度 = _JSON序列化深度 - 1; 返回 "null" }
    如果 (是布尔(值)) { 如果 (值) { 返回 "true" } 返回 "false" }
    如果 (是整数(值)) { 返回 整数转字符串(值) }
    如果 (是字符串(值)) { 返回 序列_转义字符串(值) }
    如果 (是列表(值)) {
        定义 可变 结果 = "["
        定义 可变 i = 0
        当 (i < 计数(值)) {
            如果 (i > 0) { 结果 = 结果 + "," }
            结果 = 结果 + 序列_序列化(值[i])
            i = i + 1
        }
        返回 结果 + "]"
    }
    如果 (是字典(值)) {
        定义 可变 结果 = "{"
        定义 键列表 = 字典_键列表(值)
        定义 可变 i = 0
        当 (i < 计数(键列表)) {
            如果 (i > 0) { 结果 = 结果 + "," }
            结果 = 结果 + 序列_转义字符串(键列表[i]) + ":" + 序列_序列化(字典取(值, 键列表[i]))
            i = i + 1
        }
        返回 结果 + "}"
    }
    返回 转字符串(值)
}

函数 序列_转义字符串(s) {
    定义 可变 部件 = ["\""]
    定义 可变 i = 0
    当 (i < 字符串长度(s)) {
        定义 ch = 字符串字符(s, i)
        如果 (ch == 34) { 追加(部件, "\\\"" })
        否则 如果 (ch == 92) { 追加(部件, "\\\\" })
        否则 如果 (ch == 10) { 追加(部件, "\\n" })
        否则 如果 (ch == 13) { 追加(部件, "\\r" })
        否则 如果 (ch == 9) { 追加(部件, "\\t" })
        否则 { 追加(部件, 字符串从字符(ch) })
        i = i + 1
    }
    追加(部件, "\""); 返回 字符串_连接列表(部件, "")
}

函数 序列_解析(文本) {
    定义 结果 = 序列_解析_内部(文本, 0)
    返回 结果[0]  // [值, 消耗字符数]
}

函数 序列_解析_内部(文本, 偏移) {
    定义 可变 i = 序列_跳过空白(文本, 偏移)
    如果 (i >= 字符串长度(文本)) { 返回 [空, i] }

    定义 ch = 字符串字符(文本, i)

    // null
    如果 (ch == 110 && 字符串子串(文本, i, i+4) == "null") { 返回 [空, i+4] }
    // true
    如果 (ch == 116 && 字符串子串(文本, i, i+4) == "true") { 返回 [真, i+4] }
    // false
    如果 (ch == 102 && 字符串子串(文本, i, i+5) == "false") { 返回 [假, i+5] }

    // 数字
    如果 ((ch >= 48 && ch <= 57) || ch == 45) {
        返回 序列_解析_数字(文本, i)
    }
    // 字符串
    如果 (ch == 34) { 返回 序列_解析_字符串(文本, i) }
    // 数组
    如果 (ch == 91) { 返回 序列_解析_数组(文本, i) }
    // 对象
    如果 (ch == 123) { 返回 序列_解析_对象(文本, i) }

    返回 [空, i]
}

函数 序列_解析_数字(文本, 偏移) {
    定义 可变 i = 偏移
    定义 可变 负 = 假
    如果 (字符串字符(文本, i) == 45) { 负 = 真; i = i + 1 }
    定义 可变 数值 = 0
    当 (i < 字符串长度(文本)) {
        定义 ch = 字符串字符(文本, i)
        如果 (ch >= 48 && ch <= 57) { 数值 = 数值 * 10 + (ch - 48); i = i + 1 }
        否则 { 跳出 }
    }
    如果 (负) { 数值 = 0 - 数值 }
    返回 [数值, i]
}

函数 序列_解析_字符串(文本, 偏移) {
    定义 可变 i = 偏移 + 1  // 跳过开引号
    定义 可变 结果 = ""
    当 (i < 字符串长度(文本)) {
        定义 ch = 字符串字符(文本, i)
        如果 (ch == 34) { 返回 [结果, i + 1] }  // 结束引号
        如果 (ch == 92 && i + 1 < 字符串长度(文本)) {
            i = i + 1
            定义 ech = 字符串字符(文本, i)
            如果 (ech == 110) { 结果 = 结果 + "\n" }
            否则 如果 (ech == 116) { 结果 = 结果 + "\t" }
            否则 如果 (ech == 34) { 结果 = 结果 + "\"" }
            否则 如果 (ech == 92) { 结果 = 结果 + "\\" }
            否则 { 结果 = 结果 + 字符串从字符(ech) }
        } 否则 {
            结果 = 结果 + 字符串从字符(ch)
        }
        i = i + 1
    }
    返回 [结果, i]
}

函数 序列_解析_数组(文本, 偏移) {
    定义 可变 i = 偏移 + 1  // 跳过[
    定义 可变 结果 = []
    i = 序列_跳过空白(文本, i)
    如果 (i < 字符串长度(文本) && 字符串字符(文本, i) == 93) { 返回 [结果, i + 1] }  // 空数组]
    当 (i < 字符串长度(文本)) {
        定义 元素结果 = 序列_解析_内部(文本, i)
        追加(结果, 元素结果[0])
        i = 序列_跳过空白(文本, 元素结果[1])
        如果 (i < 字符串长度(文本) && 字符串字符(文本, i) == 44) { i = i + 1 }  // 跳过,
        否则 如果 (i < 字符串长度(文本) && 字符串字符(文本, i) == 93) { 返回 [结果, i + 1] }  // ]
        否则 { 跳出 }
    }
    返回 [结果, i]
}

函数 序列_解析_对象(文本, 偏移) {
    定义 可变 i = 偏移 + 1  // 跳过{
    定义 可变 结果 = 字典()
    i = 序列_跳过空白(文本, i)
    如果 (i < 字符串长度(文本) && 字符串字符(文本, i) == 125) { 返回 [结果, i + 1] }  // 空对象}
    当 (i < 字符串长度(文本)) {
        // 解析键
        i = 序列_跳过空白(文本, i)
        定义 键结果 = 序列_解析_字符串(文本, i)
        i = 序列_跳过空白(文本, 键结果[1])
        // 跳过:
        如果 (i < 字符串长度(文本) && 字符串字符(文本, i) == 58) { i = i + 1 }
        // 解析值
        定义 值结果 = 序列_解析_内部(文本, i)
        字典设(结果, 键结果[0], 值结果[0])
        i = 序列_跳过空白(文本, 值结果[1])
        如果 (i < 字符串长度(文本) && 字符串字符(文本, i) == 44) { i = i + 1 }  // 跳过,
        否则 如果 (i < 字符串长度(文本) && 字符串字符(文本, i) == 125) { 返回 [结果, i + 1] }  // }
        否则 { 跳出 }
    }
    返回 [结果, i]
}

函数 序列_跳过空白(文本, 偏移) {
    定义 可变 i = 偏移
    当 (i < 字符串长度(文本)) {
        定义 ch = 字符串字符(文本, i)
        如果 (ch == 32 || ch == 9 || ch == 10 || ch == 13) { i = i + 1 }
        否则 { 返回 i }
    }
    返回 i
}


函数 序列_获取(对象, 键) {
    如果 (是字典(对象)) { 返回 字典取(对象, 键) }
    返回 空
}

函数 序列_美化(值, 缩进) {
    // 简单美化输出(带换行缩进)
    返回 序列_序列化(值)  // 完整美化

定义 可变 AI_原生序列_操作热度 = 0

函数 AI_原生序列_最优算法(数据量, 已排序) {
    AI_原生序列_操作热度 = AI_原生序列_操作热度 + 1
    如果 (数据量 < 16) { 返回 "插入排序" }
    如果 (已排序) { 返回 "二分查找" }
    如果 (数据量 < 10000) { 返回 "快速排序" }
    返回 "归并排序"
}

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./平台时间.nova")
导入("../中枢/创建甲.nova")
导入("../外联/域名初始化.nova")

// 平台适配层: 网络套接字 — 传控/数报/安全底层接口
// 浏览器所有网络通信的最底层:
//   HTTP/1.1 → 传控套接字
//   HTTP/2   → 安全套接字 → 传控套接字
//   长连接 → 传控套接字(升级自HTTP)
//   WebRTC   → 数报套接字 + D安全
// NovaOS上通过系统调用访问内核网络栈:
//   Nova系统调用_套接字_创建(域, 类型, 协议) → fd
//   Nova系统调用_套接字_连接(fd, 地址, 长度) → 0/-1
//   Nova系统调用_套接字_发送(fd, 数据, 长度, 标志) → 已发送
//   Nova系统调用_套接字_接收(fd, 缓冲, 长度, 标志) → 已接收
//   Nova系统调用_套接字_关闭(fd) → 0/-1
// 【颠覆性创新】AI总线驱动的连接优化:
//   ① AI预测即将需要的连接→提前传控握手(预连接)
//   ② AI评估连接质量→自动选择最佳域名解析结果
//   ③ AI检测网络拥塞→自适应调整并发连接数

定义 系统调用_套接字_创建   = 400
定义 系统调用_套接字_连接   = 401
定义 系统调用_套接字_绑定   = 402
定义 系统调用_套接字_监听   = 403
定义 系统调用_套接字_接受   = 404
定义 系统调用_套接字_发送   = 405
定义 系统调用_套接字_接收   = 406
定义 系统调用_套接字_关闭   = 407
定义 系统调用_套接字_选项   = 408
定义 系统调用_套接字_非阻塞 = 409
定义 系统调用_域名解析       = 410
定义 系统调用_Nova事件轮询创建     = 411
定义 系统调用_Nova事件轮询控制     = 412
定义 系统调用_Nova事件轮询等待     = 413

定义 AF_INET    = 2      // IPv4
定义 AF_INET6   = 10     // IPv6

定义 SOCK_STREAM = 1     // 传控
定义 SOCK_DGRAM  = 2     // 数报

定义 连接状态_未连接   = 0
定义 连接状态_域名解析中 = 1
定义 连接状态_传控连接中 = 2
定义 连接状态_安全握手中 = 3
定义 连接状态_已连接   = 4
定义 连接状态_错误     = 5
定义 连接状态_已关闭   = 6

// §1 IPv4地址

结构 IPv4地址 {
    字节,    // [4]u8 网络字节序(大端)
    端口,    // u16 网络字节序
}

函数 IPv4_创建(a, b, c, d, 端口) {
    定义 addr = 堆_分配(IPv4地址)
    addr.字节[0] = a
    addr.字节[1] = b
    addr.字节[2] = c
    addr.字节[3] = d
    addr.端口 = ((端口 & 0xFF) << 8) | ((端口 >> 8) & 0xFF)  // htons
    返回 addr
}

// §2 传控套接字

结构 传控Socket {
    fd,    // i32 文件描述符
    状态,    // u32 连接状态_xxx
    远端地址,    // u64 IPv4地址*
    本地端口,
    发送缓冲区,    // u64 环形缓冲区
    接收缓冲区,
    缓冲大小,
    错误码,
    是非阻塞,
    创建时间,
    连接耗时,    // u64 传控连接耗时(微秒)
}

函数 传控_创建() {
    定义 sock = 堆_分配(传控Socket)
    sock.fd = 系统调用(系统调用_套接字_创建, AF_INET, SOCK_STREAM, 0, 0, 0)
    如果 (sock.fd < 0) {
        sock.状态 = 连接状态_错误
        sock.错误码 = sock.fd
        返回 sock
    }
    sock.状态 = 连接状态_未连接
    sock.缓冲大小 = 65536    // 64KB
    sock.发送缓冲区 = 堆_分配_数组(sock.缓冲大小)
    sock.接收缓冲区 = 堆_分配_数组(sock.缓冲大小)
    sock.创建时间 = 平台_获取高精度时间()

    // 设置非阻塞
    系统调用(系统调用_套接字_非阻塞, sock.fd, 1, 0, 0, 0)
    sock.是非阻塞 = 真

    返回 sock
}

函数 传控_连接(sock, 主机, 端口) {
    如果 (sock == 0 || sock.fd < 0) { 返回 -1 }

    // 域名解析
    sock.状态 = 连接状态_域名解析中
    定义 ip = 域名_解析(主机)
    如果 (ip == 0) {
        sock.状态 = 连接状态_错误
        返回 -2    // 域名失败
    }

    // 传控连接
    sock.状态 = 连接状态_传控连接中
    定义 开始 = 平台_获取高精度时间()
    定义 addr = IPv4_创建(
        (ip >> 24) & 0xFF, (ip >> 16) & 0xFF,
        (ip >> 8) & 0xFF, ip & 0xFF, 端口
    )
    定义 结果 = 系统调用(系统调用_套接字_连接, sock.fd, addr, 16, 0, 0)
    sock.连接耗时 = 平台_获取高精度时间() - 开始

    如果 (结果 == 0 || 结果 == -115) {    // -115 = EINPROGRESS(非阻塞)
        sock.状态 = 连接状态_已连接
        sock.远端地址 = addr
        返回 0
    }

    sock.状态 = 连接状态_错误
    sock.错误码 = 结果
    返回 结果
}

函数 传控_发送(sock, 数据, 长度) {
    如果 (sock == 0 || sock.状态 != 连接状态_已连接) { 返回 -1 }
    返回 系统调用(系统调用_套接字_发送, sock.fd, 数据, 长度, 0, 0)
}

函数 传控_接收(sock, 缓冲, 长度) {
    如果 (sock == 0 || sock.状态 != 连接状态_已连接) { 返回 -1 }
    返回 系统调用(系统调用_套接字_接收, sock.fd, 缓冲, 长度, 0, 0)
}

函数 传控_关闭(sock) {
    如果 (sock == 0) { 返回 }
    如果 (sock.fd >= 0) {
        系统调用(系统调用_套接字_关闭, sock.fd, 0, 0, 0, 0)
    }
    sock.状态 = 连接状态_已关闭
    如果 (sock.发送缓冲区 != 0) { 堆_释放(sock.发送缓冲区) }
    如果 (sock.接收缓冲区 != 0) { 堆_释放(sock.接收缓冲区) }
    堆_释放(sock)
}

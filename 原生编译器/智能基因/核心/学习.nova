// Nova 原生 · 智能基因层 · 学习原语
// 设计理念：仿生人脑的经验学习机制 — 从反馈中更新、从错误中纠正
// 学习是智能进化的根本驱动力：遇到→感知→推理→行动→反馈→更新

// 学习策略类型

导入("../../标准库/基础.nova")

定义 学习_监督   = 1    // 监督学习（有标准答案）
定义 学习_无监督 = 2    // 无监督学习（自己找规律）
定义 学习_强化   = 3    // 强化学习（通过奖惩信号）
定义 学习_迁移   = 4    // 迁移学习（把学过的用到新领域）
定义 学习_联想   = 5    // 联想学习（看到A想到B）
定义 学习_习惯   = 6    // 习惯化（重复后减少反应）

// 奖惩信号
定义 奖励_强正   = 1000  // 强烈奖励
定义 奖励_中正   = 500   // 普通奖励
定义 奖励_弱正   = 100   // 微弱奖励
定义 奖励_中性   = 0     // 无奖惩
定义 奖励_弱负   = 0 - 100   // 微弱惩罚
定义 奖励_中负   = 0 - 500   // 普通惩罚
定义 奖励_强负   = 0 - 1000  // 强烈惩罚

// 经验样本：[输入, 期望输出, 实际输出, 奖励, 时间戳]
函数 学习_记录经验(输入, 期望输出, 实际输出, 奖励) {
    返回 [输入, 期望输出, 实际输出, 奖励, 0]
}

函数 经验_输入(样本)    { 返回 样本[0] }
函数 经验_期望(样本)    { 返回 样本[1] }
函数 经验_实际(样本)    { 返回 样本[2] }
函数 经验_奖励(样本)    { 返回 样本[3] }

// 经验回放池：存储历史经验用于批量学习
函数 经验池_创建(容量) {
    返回 [[], 容量, 0]
}

函数 经验池_存入(池, 样本) {
    如果 (计数(池[0]) >= 池[1]) {
        删除(池[0])
    }
    追加(池[0], 样本)
    池[2] = 池[2] + 1
}

函数 经验池_大小(池) {
    返回 计数(池[0])
}

函数 经验池_取样(池, 数量) {
    如果 (计数(池[0]) < 数量) {
        返回 池[0]
    }
    定义 可变 样本列表 = []
    定义 可变 i = 0
    定义 步长 = 计数(池[0]) / 数量
    当 (i < 数量) {
        追加(样本列表, 池[0][i * 步长])
        i = i + 1
    }
    返回 样本列表
}

// Q学习：表格型强化学习（状态→动作→价值）
函数 Q学习_创建(状态空间大小, 动作空间大小, 学习率, 折扣因子) {
    定义 可变 Q表 = []
    定义 可变 i = 0
    当 (i < 状态空间大小) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j < 动作空间大小) {
            追加(行, 0)
            j = j + 1
        }
        追加(Q表, 行)
        i = i + 1
    }
    返回 [Q表, 学习率, 折扣因子, 状态空间大小, 动作空间大小]
}

函数 Q学习_最优动作(Q学习器, 状态) {
    如果 (状态 >= Q学习器[3]) { 返回 0 }
    定义 动作列表 = Q学习器[0][状态]
    定义 可变 最大Q值 = 动作列表[0]
    定义 可变 最优动作 = 0
    定义 可变 i = 1
    当 (i < 计数(动作列表)) {
        如果 (动作列表[i] > 最大Q值) {
            最大Q值 = 动作列表[i]
            最优动作 = i
        }
        i = i + 1
    }
    返回 最优动作
}

函数 学习_Q学习_更新(Q学习器, 当前状态, 动作, 奖励, 下一状态) {
    如果 (当前状态 >= Q学习器[3]) { 返回 }
    如果 (下一状态 >= Q学习器[3]) { 返回 }
    如果 (动作 >= Q学习器[4]) { 返回 }
    定义 下一最优动作 = Q学习_最优动作(Q学习器, 下一状态)
    定义 下一最大Q = Q学习器[0][下一状态][下一最优动作]
    定义 目标Q = 奖励 + Q学习器[2] * 下一最大Q
    定义 当前Q = Q学习器[0][当前状态][动作]
    Q学习器[0][当前状态][动作] = 当前Q + Q学习器[1] * (目标Q - 当前Q)
}

// 学习曲线追踪：记录学习进展
定义 可变 _学习_损失历史 = []
定义 可变 _学习_准确率历史 = []
定义 可变 _学习_迭代次数 = 0

函数 学习_记录指标(损失, 准确率) {
    追加(_学习_损失历史, 损失)
    追加(_学习_准确率历史, 准确率)
    _学习_迭代次数 = _学习_迭代次数 + 1
}

函数 学习_最新损失() {
    如果 (计数(_学习_损失历史) == 0) { 返回 0 }
    返回 _学习_损失历史[计数(_学习_损失历史) - 1]
}

函数 学习_最新准确率() {
    如果 (计数(_学习_准确率历史) == 0) { 返回 0 }
    返回 _学习_准确率历史[计数(_学习_准确率历史) - 1]
}

函数 学习_趋势(最近N步) {
    如果 (计数(_学习_损失历史) < 最近N步) { 返回 0 }
    定义 首个 = _学习_损失历史[计数(_学习_损失历史) - 最近N步]
    定义 最新 = _学习_损失历史[计数(_学习_损失历史) - 1]
    返回 首个 - 最新
}

// 联想记忆学习：配对出现的事物建立联系
定义 可变 _联想对列表 = []

函数 学习_建立联想(刺激A, 刺激B, 强度) {
    定义 可变 i = 0
    当 (i < 计数(_联想对列表)) {
        如果 (_联想对列表[i][0] == 刺激A) {
            如果 (_联想对列表[i][1] == 刺激B) {
                _联想对列表[i][2] = _联想对列表[i][2] + 强度
                返回 _联想对列表[i][2]
            }
        }
        i = i + 1
    }
    追加(_联想对列表, [刺激A, 刺激B, 强度])
    返回 强度
}

函数 学习_联想检索(刺激A) {
    定义 可变 联想列表 = []
    定义 可变 i = 0
    当 (i < 计数(_联想对列表)) {
        如果 (_联想对列表[i][0] == 刺激A) {
            追加(联想列表, [_联想对列表[i][1], _联想对列表[i][2]])
        }
        i = i + 1
    }
    返回 联想列表
}

定义 可变 _学习_经验总数 = 0
定义 可变 _学习_联想总数 = 0

函数 学习_记录经验数() { _学习_经验总数 = _学习_经验总数 + 1 }
函数 学习_记录联想数() { _学习_联想总数 = _学习_联想总数 + 1 }


// [Nova实验室反哺] 整数STDP时序依赖可塑性 + Hebbian学习
// 来源: 中文原生/内核/实验室/意识萌芽/STDP脉冲时序可塑性.nova
// Rust实测: 6段分段线性近似误差7.9%，速度3×浮点exp版，零浮点
// 全球首创: Nova整数STDP — 脑可塑性零浮点实现
// STDP整数(dt_ms) — dt_ms:时间差(毫秒), 返回权重变化×1000
函数 STDP整数(dt_ms) {
    如果 (dt_ms < 0) {
        如果 (dt_ms < -100) { 返回 -50 }
        如果 (dt_ms < -50)  { 返回 -50 + (0 - dt_ms - 50) * 200 / 50 }
        如果 (dt_ms < -20)  { 返回 -250 + (0 - dt_ms - 20) * 350 / 30 }
        返回 -600 + (0 - dt_ms) * 600 / 20
    }
    如果 (dt_ms == 0) { 返回 1000 }
    如果 (dt_ms < 10) { 返回 1000 - dt_ms * 400 / 10 }
    如果 (dt_ms < 30) { 返回 600 - (dt_ms - 10) * 350 / 20 }
    如果 (dt_ms < 60) { 返回 250 - (dt_ms - 30) * 200 / 30 }
    如果 (dt_ms >= 100) { 返回 0 }
    返回 50 - (dt_ms - 60) * 50 / 40
}

// Hebbian更新(整数Q10版, 0 , 0, 0) — Δw = η × pre × post
函数 Hebbian更新(权重, eta_q10, pre_q10, post_q10) {
    定义 dw = eta_q10 * pre_q10 / 1024 * post_q10 / 1024
    返回 权重 + dw
}

// BCM竞争学习 — Δw = η × post × (post - θ) × pre
函数 BCM更新(权重, eta, pre, post, theta) {
    定义 dw = eta * post * (post - theta) / 1024 * pre / 1024
    返回 权重 + dw
}

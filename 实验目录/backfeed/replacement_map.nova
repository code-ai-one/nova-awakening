    如果 (序号 == 6) { 返回 "Chain-of-Thought逐步回溯" }
    如果 (序号 == 7) { 返回 "RAG+TopK+草图近似检索" }
    如果 (序号 == 8) { 返回 "在线梯度下降+AdamW" }
    如果 (序号 == 9) { 返回 "REINFORCE+优势归一化" }
    如果 (序号 == 10) { 返回 "多域注意力编排" }
    如果 (序号 == 11) { 返回 "MHA/GQA/MLA注意力算子" }
    如果 (序号 == 12) { 返回 "MoE稀疏专家路由" }

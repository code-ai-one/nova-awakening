    内核界面_记录(档, "桌面前台", [], "原生桌面")
    定义 结果 = [
        Nova原生桌面_获取壳前台标签(),
        Nova原生桌面_获取壳前台文本(),
        Nova原生桌面_获取壳结果文本()
    ]
    档.桌面数 = 档.桌面数 + 1
    返回 内核界面_成功(档, "桌面前台", 结果)
}

函数 内核界面_工作区活跃度(档) {

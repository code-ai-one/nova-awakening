导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("./端口输入.nova")
导入("../中枢/整数转字符串.nova")

定义 光标图片_默认 = "../资源/光标/光标_默认.png"
定义 光标图片_手指 = "../资源/光标/光标_手指.png"
定义 光标图片_等待 = "../资源/光标/光标_等待.png"
定义 光标图片_文本 = "../资源/光标/光标_文本.png"

// 光标形状枚举
定义 光标形状_箭头 = 0
定义 光标形状_手指 = 1
定义 光标形状_等待 = 2
定义 光标形状_文本 = 3
定义 可变 当前光标形状 = 0
定义 可变 光标纹理缓存 = [0, 0, 0, 0]

函数 光标_切换形状(形状) {
    如果 (形状 >= 0 && 形状 <= 3) {
        当前光标形状 = 形状
    }
}

函数 光标_获取图片路径(形状) {
    如果 (形状 == 光标形状_手指) { 返回 光标图片_手指 }
    如果 (形状 == 光标形状_等待) { 返回 光标图片_等待 }
    如果 (形状 == 光标形状_文本) { 返回 光标图片_文本 }
    返回 光标图片_默认
}

// 8. 鼠标光标 (白色箭头)

定义 可变 cl = 0
当 (cl < 14) {
    定义 可变 cw = 0
    当 (cw < cl + 1 && cw < 10) {
        内存写32(LFB + (384 + cl) * 行字节 + (512 + cw) * 4, 0x00FFFFFF)
        cw = cw + 1
    }
    cl = cl + 1
}

// 9. 完成信息
打印("")
打印("═══════════════════════════════════════════════════")
打印("  NovaOS v0.3.0 — 全息AI桌面 (纯Nova语言)")
打印("  渲染: 内存写32() → BGA LFB 0xFD000000")
打印("  全息AI人物: 3D线框+粒子+眼睛+嘴+身体+气泡")
打印("  云端接口: 配置面板(Key/URL/Port/Model)")
打印("  本地模型: TNF推理引擎直连")
打印("  零assembly桌面代码, 纯Nova原生渲染")
打印("═══════════════════════════════════════════════════")

// 10. 真实PS/2交互主循环
// 端口读8(0x64) = PS/2状态寄存器, bit0=有数据, bit5=鼠标数据
// 端口读8(0x60) = PS/2数据寄存器, 读取扫描码/鼠标字节
// 这是真实的裸机硬件I/O，不是模拟
// ━━ 初始化COM2 UART (0x2F8) 用于命令接收 ━━
端口写8(0x2F9, 0x00)   // 禁用中断
端口写8(0x2FB, 0x80)   // DLAB=1 设置波特率
端口写8(0x2F8, 0x01)   // 波特率除数低字节 (115200)
端口写8(0x2F9, 0x00)   // 波特率除数高字节
端口写8(0x2FB, 0x03)   // 8位数据, 无校验, 1停止位
端口写8(0x2FA, 0xC7)   // 使能FIFO, 清缓冲, 14字节阈值
端口写8(0x2FC, 0x0B)   // DTR+RTS+OUT2
打印("[NovaOS] COM2 UART 已初始化 (命令通道 0x2F8)")
打印("[NovaOS] 进入真实PS/2交互主循环...")

定义 可变 鼠x = 512
定义 可变 鼠y = 384
定义 可变 鼠旧x = 512
定义 可变 鼠旧y = 384
定义 可变 鼠字节 = 0
定义 可变 鼠b1 = 0
定义 可变 鼠b2 = 0
定义 可变 鼠b3 = 0
定义 可变 输入缓冲 = ""
定义 可变 帧计数 = 0
定义 可变 脉动相位 = 0
定义 可变 全息人物x = 680
定义 可变 全息人物方向 = 1    // 1=右走, -1=左走
定义 可变 空闲计数 = 0
定义 可变 人物动作 = 0        // 0=站立 1=行走 2=挥手 3=思考

// 扫描码→ASCII简表 (部分常用键)
定义 扫描码ASCII = [0,0,49,50,51,52,53,54,55,56,57,48,45,61,8,9, 113,119,101,114,116,121,117,105,111,112,91,93,10,0, 97,115,100,102,103,104,106,107,108,59,39,96,0,92, 122,120,99,118,98,110,109,44,46,47,0,42,0,32]

当 (帧计数 < 2000000000) {
    // ━━ 心跳日志: 每500万帧打印一次, 证明循环真实运行 ━━
    如果 (帧计数 % 5000000 == 0) {
        打印("[心跳] 帧=" + 整数转字符串(帧计数) + " 鼠标=(" + 整数转字符串(鼠x) + "," + 整数转字符串(鼠y) + ") 动作=" + 整数转字符串(人物动作))
    }

    // ━━ 轮询PS/2状态寄存器 ━━
    定义 状态 = 端口读8(0x64)

    如果 ((状态 & 0x01) != 0) {
        定义 数据 = 端口读8(0x60)

        如果 ((状态 & 0x20) != 0) {
            如果 (鼠字节 == 0) {
                鼠b1 = 数据
                如果 ((数据 & 0x08) != 0) { 鼠字节 = 1 }  // bit3必须为1
            } 否则 如果 (鼠字节 == 1) {
                鼠b2 = 数据; 鼠字节 = 2
            } 否则 如果 (鼠字节 == 2) {
                鼠b3 = 数据; 鼠字节 = 0

                // 解析3字节鼠标数据包
                定义 可变 dx = 鼠b2
                定义 可变 dy = 鼠b3
                如果 ((鼠b1 & 0x10) != 0) { dx = dx - 256 }
                如果 ((鼠b1 & 0x20) != 0) { dy = dy - 256 }
                dy = 0 - dy  // PS/2 Y轴反转

                // 保存旧位置(用于擦除)
                鼠旧x = 鼠x
                鼠旧y = 鼠y

                // 更新位置
                鼠x = 鼠x + dx
                鼠y = 鼠y + dy
                如果 (鼠x < 0) { 鼠x = 0 }
                如果 (鼠y < 28) { 鼠y = 28 }
                如果 (鼠x > 屏宽 - 2) { 鼠x = 屏宽 - 2 }
                如果 (鼠y > 屏高 - 34) { 鼠y = 屏高 - 34 }

                // 擦除旧光标 (用壁纸色覆盖)
                定义 可变 ecy = 0
                当 (ecy < 14) {
                    定义 可变 ecx = 0
                    当 (ecx < 10) {
                        定义 ey = 鼠旧y + ecy
                        定义 ex = 鼠旧x + ecx
                        如果 (ex > 0 && ex < 屏宽 && ey > 28 && ey < 屏高 - 30) {
                            定义 壁t = ey * 256 / 屏高
                            定义 壁色 = ((8 + 12 * 壁t / 256) * 65536) + ((18 - 10 * 壁t / 256) * 256) + (30 + 14 * 壁t / 256)
                            内存写32(LFB + ey * 行字节 + ex * 4, 壁色)
                        }
                        ecx = ecx + 1
                    }
                    ecy = ecy + 1
                }

                // 绘制新光标 (白色箭头)
                定义 可变 ncy = 0
                当 (ncy < 12) {
                    定义 可变 ncx = 0
                    当 (ncx < ncy + 1 && ncx < 10) {
                        如果 (鼠x + ncx < 屏宽 && 鼠y + ncy < 屏高 - 30) {
                            内存写32(LFB + (鼠y + ncy) * 行字节 + (鼠x + ncx) * 4, 0x00FFFFFF)
                        }
                        ncx = ncx + 1
                    }
                    ncy = ncy + 1
                }

                空闲计数 = 0  // 有鼠标活动，重置空闲

                // 左键点击检测
                如果 ((鼠b1 & 0x01) != 0) {
                    // 全息人物区域点击 → 人物挥手
                    如果 (鼠x > 全息人物x - 60 && 鼠x < 全息人物x + 60 && 鼠y > 160 && 鼠y < 450) {
                        人物动作 = 2   // 挥手
                        打印("[交互] 点击全息人物 → 挥手")
                    }
                    // AI对话发送按钮区域
                    如果 (鼠x > 对话x + 对话w - 65 && 鼠x < 对话x + 对话w - 15 && 鼠y > 对话y + 对话h - 42 && 鼠y < 对话y + 对话h - 14) {
                        打印("[交互] 点击发送: " + 输入缓冲)
                        输入缓冲 = ""
                    }
                }
            }
        } 否则 {
            打印("[KB] scan=" + 整数转字符串(数据))
            如果 (数据 < 128) {
                // 按下事件
                空闲计数 = 0

                如果 (数据 == 0x1C) {
                    // 回车键 → 发送AI对话
                    打印("[输入] 发送: " + 输入缓冲)
                    输入缓冲 = ""
                    人物动作 = 3  // AI思考
                } 否则 如果 (数据 == 0x0E) {
                    // 退格键
                    如果 (字符串长度(输入缓冲) > 0) {
                        输入缓冲 = 字符串子串(输入缓冲, 0, 字符串长度(输入缓冲) - 1)
                    }
                } 否则 如果 (数据 < 58) {
                    // 普通键 → 追加到输入缓冲
                    定义 ch = 扫描码ASCII[数据]
                    如果 (ch > 0) {
                        输入缓冲 = 输入缓冲 + 字符转字符串(ch)

                        // 在输入框内绘制光标指示(闪烁蓝色块)
                        定义 光标绘x = 对话x + 16 + 字符串长度(输入缓冲) * 8
                        如果 (光标绘x < 对话x + 对话w - 80) {
                            内存写32(LFB + (对话y + 对话h - 34) * 行字节 + 光标绘x * 4, 0x003B82F6)
                            内存写32(LFB + (对话y + 对话h - 33) * 行字节 + 光标绘x * 4, 0x003B82F6)
                            内存写32(LFB + (对话y + 对话h - 32) * 行字节 + 光标绘x * 4, 0x003B82F6)
                        }
                    }
                }

                // F11 = 打印系统状态
                如果 (数据 == 0x57) {
                    打印("[F11] 帧=" + 整数转字符串(帧计数) + " 鼠标=" + 整数转字符串(鼠x) + "," + 整数转字符串(鼠y) + " 动作=" + 整数转字符串(人物动作))
                }

                // ━━ F键实时桌面控制 (通过QEMU monitor sendkey远程触发) ━━
                // F1(0x3B) = 画红色矩形
                如果 (数据 == 0x3B) {
                    定义 可变 f1y = 0
                    当 (f1y < 50) {
                        定义 可变 f1x = 0
                        当 (f1x < 100) { 内存写32(LFB + (300 + f1y) * 行字节 + (500 + f1x) * 4, 0x00FF4444); f1x = f1x + 1 }
                        f1y = f1y + 1
                    }
                    打印("[F1] 画红色矩形 (500,300) 100x50")
                }
                // F2(0x3C) = 画绿色矩形
                如果 (数据 == 0x3C) {
                    定义 可变 f2y = 0
                    当 (f2y < 50) {
                        定义 可变 f2x = 0
                        当 (f2x < 100) { 内存写32(LFB + (300 + f2y) * 行字节 + (620 + f2x) * 4, 0x0022C55E); f2x = f2x + 1 }
                        f2y = f2y + 1
                    }
                    打印("[F2] 画绿色矩形 (620,300) 100x50")
                }
                // F3(0x3D) = 画白色文字 "LIVE CONTROL"
                如果 (数据 == 0x3D) {
                    定义 f3文字 = [76,73,86,69,32,67,79,78,84,82,79,76]
                    定义 可变 f3i = 0
                    当 (f3i < 12) {
                        定义 f3idx = (f3文字[f3i] - 32) * 8
                        如果 (f3idx >= 0 && f3idx < 760) {
                            定义 可变 f3r = 0
                            当 (f3r < 8) {
                                定义 f3rd = 字体[f3idx + f3r]
                                定义 可变 f3b = 0
                                当 (f3b < 8) {
                                    如果 ((f3rd >> (7 - f3b)) & 1) {
                                        内存写32(LFB + (360 + f3r) * 行字节 + (510 + f3i * 9 + f3b) * 4, 0x00FFFFFF)
                                    }
                                    f3b = f3b + 1
                                }
                                f3r = f3r + 1
                            }
                        }
                        f3i = f3i + 1
                    }
                    打印("[F3] 画文字 LIVE CONTROL")
                }
                // F4(0x3E) = 画蓝色矩形
                如果 (数据 == 0x3E) {
                    定义 可变 f4y = 0
                    当 (f4y < 50) {
                        定义 可变 f4x = 0
                        当 (f4x < 100) { 内存写32(LFB + (300 + f4y) * 行字节 + (740 + f4x) * 4, 0x004FC3F7); f4x = f4x + 1 }
                        f4y = f4y + 1
                    }
                    打印("[F4] 画蓝色矩形 (740,300) 100x50")
                }
            }
        }
    }

    // ━━ 全息人物呼吸脉动 (每4096帧切换) ━━
    如果 (帧计数 % 4096 == 0) {
        脉动相位 = (脉动相位 + 1) % 4
        // 在全息人物头顶画脉动点(颜色随相位变化)
        定义 脉动色列 = [0x0000EEFF, 0x0044FFFF, 0x0088FFFF, 0x0044FFFF]
        定义 脉色 = 脉动色列[脉动相位]
        定义 可变 脉i = 0
        当 (脉i < 6) {
            如果 (全息人物x + 脉i > 100 && 全息人物x + 脉i < 屏宽) {
                内存写32(LFB + 155 * 行字节 + (全息人物x - 3 + 脉i) * 4, 脉色)
            }
            脉i = 脉i + 1
        }
    }

    // ━━ 全息人物自主行为 ━━
    空闲计数 = 空闲计数 + 1

    // 空闲10万帧 → 自主走动
    如果 (空闲计数 > 100000 && 人物动作 == 0) {
        人物动作 = 1  // 开始走动
    }

    // 走动时每2048帧移动一步
    如果 (人物动作 == 1 && 帧计数 % 2048 == 0) {
        全息人物x = 全息人物x + 全息人物方向 * 2
        // 到达边界翻转方向
        如果 (全息人物x > 900) { 全息人物方向 = -1; 人物动作 = 0; 空闲计数 = 0 }
        如果 (全息人物x < 550) { 全息人物方向 = 1; 人物动作 = 0; 空闲计数 = 0 }
    }

    // 挥手动作3万帧后恢复站立
    如果 (人物动作 == 2 && 空闲计数 > 30000) { 人物动作 = 0 }
    // 思考动作5万帧后恢复
    如果 (人物动作 == 3 && 空闲计数 > 50000) { 人物动作 = 0 }

    帧计数 = 帧计数 + 1
}

打印("[NovaOS] 交互主循环结束 — 帧数=" + 整数转字符串(帧计数))
打印("[NovaOS] 全息AI桌面运行结束 — 停机")

// 光标形状辅助

定义 光标_默认宽 = 12
定义 光标_默认高 = 19
定义 光标_热点X = 0
定义 光标_热点Y = 0

函数 光标_获取热点(形状) {
    如果 (形状 == 0) { 返回 [0, 0] }
    如果 (形状 == 1) { 返回 [6, 9] }
    如果 (形状 == 2) { 返回 [5, 0] }
    返回 [0, 0]
}

函数 光标_边界检查(x, y, 屏宽, 屏高) {
    如果 (x < 0) { x = 0 }
    如果 (y < 0) { y = 0 }
    如果 (x > 屏宽 - 光标_默认宽) { x = 屏宽 - 光标_默认宽 }
    如果 (y > 屏高 - 光标_默认高) { y = 屏高 - 光标_默认高 }
    返回 [x, y]
}

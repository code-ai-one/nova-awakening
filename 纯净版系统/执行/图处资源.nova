导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/创建甲.nova")
导入("./底层内存操.nova")

定义 资源类型_纹理 = 0
定义 资源类型_缓冲 = 1
定义 资源类型_着色器 = 2
定义 资源类型_渲染目标 = 3
定义 最大纹理池 = 128
定义 最大缓冲池 = 64
定义 最大着色器缓存 = 32
定义 默认VRAM预算 = 268435456

结构 图处纹理 {
    句柄,
    宽, 高,
    格式,
    显存大小,
    引用计数,
    最后使用帧,
    已上传,
}

结构 图处缓冲 {
    句柄,
    大小,
    用途,
    引用计数,
    已映射,
}

结构 着色器程序 {
    哈希,
    顶点句柄,
    片段句柄,
    程序句柄,
    编译时间,
    使用次数,
}

定义 可变 纹理池 = 0
定义 可变 纹理数 = 0
定义 可变 缓冲池 = 0
定义 可变 缓冲数 = 0
定义 可变 着色器表 = 0
定义 可变 着色器数 = 0
定义 可变 已用显存 = 0
定义 可变 显存预算 = 默认VRAM预算
定义 可变 当前帧号 = 0

函数 图处资源_初始化() {
    纹理池 = 堆_分配(最大纹理池 * 8)
    内存_清零(纹理池, 最大纹理池 * 8)
    纹理数 = 0
    缓冲池 = 堆_分配(最大缓冲池 * 8)
    内存_清零(缓冲池, 最大缓冲池 * 8)
    缓冲数 = 0
    着色器表 = 堆_分配(最大着色器缓存 * 8)
    内存_清零(着色器表, 最大着色器缓存 * 8)
    着色器数 = 0
    已用显存 = 0
    当前帧号 = 0
}

函数 图处资源_创建纹理(宽, 高, 格式) {
    如果 (纹理数 >= 最大纹理池) { 图处资源_淘汰纹理() }
    定义 像素大小 = 如果(格式 == 0, 4, 如果(格式 == 1, 3, 2))
    定义 显存大小 = 宽 * 高 * 像素大小
    如果 (已用显存 + 显存大小 > 显存预算) { 图处资源_淘汰纹理() }
    定义 纹理 = 堆_分配(图处纹理)
    纹理.句柄 = 图处_分配纹理句柄()
    纹理.宽 = 宽
    纹理.高 = 高
    纹理.格式 = 格式
    纹理.显存大小 = 显存大小
    纹理.引用计数 = 1
    纹理.最后使用帧 = 当前帧号
    纹理.已上传 = 假
    内存_写64(纹理池 + 纹理数 * 8, 纹理)
    纹理数 = 纹理数 + 1
    已用显存 = 已用显存 + 显存大小
    返回 纹理
}

函数 图处资源_上传纹理(纹理, 像素数据) {
    如果 (纹理 == 0 || 像素数据 == 0) { 返回 假 }
    图处_上传纹理数据(纹理.句柄, 纹理.宽, 纹理.高, 纹理.格式, 像素数据)
    纹理.已上传 = 真
    纹理.最后使用帧 = 当前帧号
    返回 真
}

函数 图处资源_淘汰纹理() {
    如果 (纹理数 == 0) { 返回 }
    定义 可变 最旧帧 = 0x7FFFFFFF
    定义 可变 淘汰位 = -1
    定义 可变 索引 = 0
    当 (索引 < 纹理数) {
        定义 纹理 = 内存_读64(纹理池 + 索引 * 8)
        如果 (纹理 != 0 && 纹理.引用计数 <= 0 && 纹理.最后使用帧 < 最旧帧) {
            最旧帧 = 纹理.最后使用帧
            淘汰位 = 索引
        }
        索引 = 索引 + 1
    }
    如果 (淘汰位 >= 0) {
        定义 被淘汰 = 内存_读64(纹理池 + 淘汰位 * 8)
        已用显存 = 已用显存 - 被淘汰.显存大小
        图处_释放纹理句柄(被淘汰.句柄)
        堆_释放(被淘汰)
        内存_写64(纹理池 + 淘汰位 * 8, 内存_读64(纹理池 + (纹理数 - 1) * 8))
        纹理数 = 纹理数 - 1
    }
}

函数 图处资源_创建缓冲(大小, 用途) {
    如果 (缓冲数 >= 最大缓冲池) { 返回 0 }
    定义 缓冲 = 堆_分配(图处缓冲)
    缓冲.句柄 = 图处_分配缓冲句柄()
    缓冲.大小 = 大小
    缓冲.用途 = 用途
    缓冲.引用计数 = 1
    缓冲.已映射 = 假
    内存_写64(缓冲池 + 缓冲数 * 8, 缓冲)
    缓冲数 = 缓冲数 + 1
    已用显存 = 已用显存 + 大小
    返回 缓冲
}

函数 图处资源_查找着色器(哈希) {
    定义 可变 索引 = 0
    当 (索引 < 着色器数) {
        定义 着色器 = 内存_读64(着色器表 + 索引 * 8)
        如果 (着色器 != 0 && 着色器.哈希 == 哈希) {
            着色器.使用次数 = 着色器.使用次数 + 1
            返回 着色器
        }
        索引 = 索引 + 1
    }
    返回 0
}

函数 图处资源_缓存着色器(哈希, 程序句柄) {
    如果 (着色器数 >= 最大着色器缓存) { 返回 }
    定义 着色器 = 堆_分配(着色器程序)
    着色器.哈希 = 哈希
    着色器.程序句柄 = 程序句柄
    着色器.使用次数 = 0
    着色器.编译时间 = 平台_获取高精度时间()
    内存_写64(着色器表 + 着色器数 * 8, 着色器)
    着色器数 = 着色器数 + 1
}

函数 智能_图处_应该硬件加速(层宽, 层高, 有变换, 有透明度, 有滤镜) {
    如果 (有变换 || 有滤镜) { 返回 真 }
    如果 (层宽 * 层高 > 10000) { 返回 真 }
    如果 (已用显存 > 显存预算 * 90 / 100) { 返回 假 }
    返回 假
}

函数 智能_图处_预上传纹理(ctx, 资源列表, 资源数) {
    如果 (ctx == 0 || 资源列表 == 0) { 返回 }
    定义 可变 索引 = 0
    当 (索引 < 资源数 && 索引 < 8) {
        定义 资源 = 内存_读64(资源列表 + 索引 * 8)
        如果 (资源 != 0 && !资源.已上传) {
            图处资源_上传纹理(资源, 资源.像素数据)
        }
        索引 = 索引 + 1
    }
}

函数 图处资源_帧结束() {
    当前帧号 = 当前帧号 + 1
    如果 (已用显存 > 显存预算 * 85 / 100) {
        图处资源_淘汰纹理()
    }
}

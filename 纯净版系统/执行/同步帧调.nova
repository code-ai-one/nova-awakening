// NovaOS 图形输出 · VSync与帧调度引擎 v2.0
// 功能:
//  §1 VSync同步(硬件+软件回退)
//  §2 自适应帧率(60/90/120/144动态切换)
//  §3 帧步调(残余睡眠+自旋微调)
//  §4 三缓冲流水线(front/back/pending)
//  §5 显示模式检测(分辨率/刷新率/HDR)
//  §6 剪贴板(文本/图像多格式)
//  §7 IME输入法(候选框/合成文本/事件)
//  §8 帧时间统计+丢帧检测
//  §9 AI预测帧负载与自动降帧

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../感知/内核直连层.nova")
导入("./平台时间.nova")
导入("../推理/值乘.nova")
导入("../中枢/创建甲.nova")
导入("../中枢/字符串替换.nova")

// §1 常量

定义 Q10 = 1024
定义 Q_ONE = 1024
定义 Q_HALF = 512

定义 US_PER_S = 1000000
定义 MS_PER_S = 1000

// 帧率常用值
定义 FPS_30 = 30
定义 FPS_60 = 60
定义 FPS_90 = 90
定义 FPS_120 = 120
定义 FPS_144 = 144
定义 FPS_240 = 240

// VSync模式
定义 VSYNC_OFF = 0
定义 VSYNC_ON = 1
定义 VSYNC_ADAPTIVE = 2      // 自适应: 快则等, 慢则不等
定义 VSYNC_MAILBOX = 3       // 邮箱模式: 始终取最新帧

// 三缓冲状态
定义 BUF_FREE = 0
定义 BUF_RENDERING = 1
定义 BUF_PENDING = 2
定义 BUF_DISPLAY = 3

// 显示标志
定义 DISPLAY_FLAG_HDR = 1
定义 DISPLAY_FLAG_VRR = 2     // Variable Refresh Rate
定义 DISPLAY_FLAG_INTERLACED = 4

// 剪贴板格式
定义 CLIP_TEXT = 0
定义 CLIP_IMAGE = 1
定义 CLIP_HTML = 2
定义 CLIP_FILE = 3

// EWMA
定义 EWMA_ALPHA_慢 = 64
定义 EWMA_ALPHA_中 = 205
定义 EWMA_ALPHA_快 = 512

定义 帧时间缓冲大小 = 64
定义 丢帧阈值倍数 = 1500       // 1.5x = 1500/Q10
定义 降帧触发次数 = 3

// §2 数据结构

结构 帧调度器 {
    目标帧率,          // 60, 90, 120...
    帧间隔微秒,        // 1000000/帧率
    上一帧时间,        // 微秒时戳
    帧计数,
    丢帧计数,
    VSync模式,         // 0=关 1=开 2=自适应 3=邮箱
    自适应启用,
    最小帧率,          // 自适应下限
    最大帧率,          // 自适应上限
}

结构 三缓冲状态 {
    缓冲0_句柄,
    缓冲1_句柄,
    缓冲2_句柄,
    缓冲0_状态,
    缓冲1_状态,
    缓冲2_状态,
    当前渲染缓冲,     // 0/1/2
    当前显示缓冲,
    缓冲宽,
    缓冲高,
}

结构 显示模式信息 {
    宽,
    高,
    刷新率Hz,
    位深,
    标志,              // HDR/VRR/INTERLACED
}

结构 帧时间样本 {
    帧时间_us,
    GPU时间_us,
    CPU时间_us,
}

结构 剪贴板项 {
    格式,
    数据,
    长度,
}

结构 IME状态 {
    编辑文本,
    候选列表,
    光标位置,
    正在合成,
}

// §3 全局状态

定义 可变 全局调度器 = 空
定义 可变 全局三缓冲 = 空
定义 可变 全局显示 = 显示模式信息 { 宽: 0, 高: 0, 刷新率Hz: 60, 位深: 32, 标志: 0 }
定义 可变 全局IME = IME状态 { 编辑文本: "", 候选列表: [], 光标位置: 0, 正在合成: 假 }

// 帧时间环形缓冲
定义 可变 帧时间历史 = []
定义 可变 帧时间头 = 0
定义 可变 帧时间计数 = 0

// EWMA统计
定义 可变 EWMA_帧时间_us = 16667
定义 可变 EWMA_GPU时间_us = 0
定义 可变 EWMA_CPU时间_us = 0
定义 可变 连续丢帧数 = 0
定义 可变 总丢帧数 = 0

// 剪贴板历史
定义 可变 剪贴板栈 = []
定义 可变 剪贴板栈头 = 0
定义 最大剪贴板历史 = 32

// §4 初始化

函数 帧调度器_创建(帧率) {
    定义 调度 = 帧调度器 {
        目标帧率: 帧率,
        帧间隔微秒: US_PER_S / 帧率,
        上一帧时间: 0,
        帧计数: 0,
        丢帧计数: 0,
        VSync模式: VSYNC_ON,
        自适应启用: 假,
        最小帧率: FPS_30,
        最大帧率: FPS_144
    }
    全局调度器 = 调度

    // 初始化帧时间缓冲
    帧时间历史 = []
    定义 可变 i = 0
    当 (i < 帧时间缓冲大小) {
        追加(帧时间历史, 帧时间样本 { 帧时间_us: 0, GPU时间_us: 0, CPU时间_us: 0 })
        i = i + 1
    }
    帧时间头 = 0
    帧时间计数 = 0

    EWMA_帧时间_us = US_PER_S / 帧率
    连续丢帧数 = 0
    总丢帧数 = 0

    返回 调度
}

函数 帧调度器_启用自适应(调度, 最小, 最大) {
    调度.自适应启用 = 真
    调度.最小帧率 = 最小
    调度.最大帧率 = 最大
}

// §5 VSync等待与帧步调

函数 帧调度器_等待下一帧(调度, win) {
    定义 t0 = 平台_获取高精度时间()

    如果 (调度.VSync模式 == VSYNC_ON) {
        系统调用(Nova系统调用_图形_等待垂直同步, win.句柄, 0, 0, 0, 0)
    } 否则 如果 (调度.VSync模式 == VSYNC_ADAPTIVE) {
        // 自适应: 如果当前帧未超时则VSync, 否则直接继续
        定义 经过 = t0 - 调度.上一帧时间
        如果 (经过 <= 调度.帧间隔微秒) {
            系统调用(Nova系统调用_图形_等待垂直同步, win.句柄, 0, 0, 0, 0)
        }
    } 否则 如果 (调度.VSync模式 == VSYNC_MAILBOX) {
        // 邮箱: 始终提交最新帧, 不等待
    } 否则 {
        // 关闭: 纯软件帧步调
        定义 经过 = t0 - 调度.上一帧时间
        如果 (经过 < 调度.帧间隔微秒) {
            定义 剩余 = 调度.帧间隔微秒 - 经过
            // 大段睡眠 + 微调自旋
            如果 (剩余 > 2000) {
                平台_睡眠微秒(剩余 - 1000)  // 留1ms裕量
            }
            // 自旋等待最后微秒
            当 (平台_获取高精度时间() - t0 < 剩余) {
                暂停()
            }
        }
    }

    定义 t1 = 平台_获取高精度时间()
    定义 实际帧时间 = t1 - 调度.上一帧时间

    // 丢帧检测
    定义 丢帧阈值 = 调度.帧间隔微秒 * 丢帧阈值倍数 / Q10
    如果 (实际帧时间 > 丢帧阈值 && 调度.帧计数 > 0) {
        调度.丢帧计数 = 调度.丢帧计数 + 1
        总丢帧数 = 总丢帧数 + 1
        连续丢帧数 = 连续丢帧数 + 1
    } 否则 {
        连续丢帧数 = 0
    }

    // 记录帧时间
    帧时间_记录(实际帧时间, 0, 0)

    // EWMA更新
    EWMA_帧时间_us = (EWMA_ALPHA_中 * 实际帧时间 + (Q10 - EWMA_ALPHA_中) * EWMA_帧时间_us) / Q10

    // 自适应帧率
    如果 (调度.自适应启用) {
        自适应_帧率调整(调度)
    }

    调度.上一帧时间 = t1
    调度.帧计数 = 调度.帧计数 + 1
}

函数 帧时间_记录(帧_us, gpu_us, cpu_us) {
    定义 idx = 帧时间头 % 帧时间缓冲大小
    设置(帧时间历史, idx, 帧时间样本 { 帧时间_us: 帧_us, GPU时间_us: gpu_us, CPU时间_us: cpu_us })
    帧时间头 = 帧时间头 + 1
    如果 (帧时间计数 < 帧时间缓冲大小) { 帧时间计数 = 帧时间计数 + 1 }
}

函数 平台_睡眠微秒(微秒) {
    系统调用(350, 微秒, 0, 0, 0, 0)
}

// §6 自适应帧率

函数 自适应_帧率调整(调度) {
    // 连续丢帧→降帧率
    如果 (连续丢帧数 >= 降帧触发次数) {
        定义 新帧率 = 调度.目标帧率 * 3 / 4  // 降25%
        如果 (新帧率 < 调度.最小帧率) { 新帧率 = 调度.最小帧率 }
        帧调度器_设置帧率(调度, 新帧率)
        连续丢帧数 = 0
        返回
    }

    // EWMA帧时间远低于目标→升帧率
    定义 目标_us = 调度.帧间隔微秒
    如果 (EWMA_帧时间_us < 目标_us * 600 / Q10 && 调度.目标帧率 < 调度.最大帧率) {
        定义 新帧率 = 调度.目标帧率 * 4 / 3
        如果 (新帧率 > 调度.最大帧率) { 新帧率 = 调度.最大帧率 }
        帧调度器_设置帧率(调度, 新帧率)
    }
}

函数 帧调度器_设置帧率(调度, 新帧率) {
    如果 (新帧率 <= 0) { 新帧率 = FPS_60 }
    调度.目标帧率 = 新帧率
    调度.帧间隔微秒 = US_PER_S / 新帧率
}

函数 帧调度器_设置VSync(调度, 模式) {
    调度.VSync模式 = 模式
}

// §7 三缓冲管理

函数 三缓冲_初始化(宽, 高) {
    定义 字节数 = 宽 * 高 * 4  // RGBA32
    定义 tb = 三缓冲状态 {
        缓冲0_句柄: 堆_分配(字节数),
        缓冲1_句柄: 堆_分配(字节数),
        缓冲2_句柄: 堆_分配(字节数),
        缓冲0_状态: BUF_FREE,
        缓冲1_状态: BUF_FREE,
        缓冲2_状态: BUF_FREE,
        当前渲染缓冲: 0,
        当前显示缓冲: 1,
        缓冲宽: 宽,
        缓冲高: 高
    }
    全局三缓冲 = tb
    返回 tb
}

函数 三缓冲_获取渲染缓冲(tb) {
    // 找到FREE的缓冲
    定义 可变 状态 = [tb.缓冲0_状态, tb.缓冲1_状态, tb.缓冲2_状态]
    定义 可变 i = 0
    当 (i < 3) {
        如果 (状态[i] == BUF_FREE) {
            三缓冲_设状态(tb, i, BUF_RENDERING)
            tb.当前渲染缓冲 = i
            返回 三缓冲_句柄(tb, i)
        }
        i = i + 1
    }
    // 无空闲缓冲: 强制使用pending
    i = 0
    当 (i < 3) {
        如果 (状态[i] == BUF_PENDING) {
            三缓冲_设状态(tb, i, BUF_RENDERING)
            tb.当前渲染缓冲 = i
            返回 三缓冲_句柄(tb, i)
        }
        i = i + 1
    }
    返回 0
}

函数 三缓冲_提交(tb) {
    定义 idx = tb.当前渲染缓冲
    三缓冲_设状态(tb, idx, BUF_PENDING)
}

函数 三缓冲_翻转(tb) {
    // 显示→空闲, pending→显示
    定义 可变 i = 0
    当 (i < 3) {
        如果 (三缓冲_获状态(tb, i) == BUF_DISPLAY) {
            三缓冲_设状态(tb, i, BUF_FREE)
        }
        i = i + 1
    }
    i = 0
    当 (i < 3) {
        如果 (三缓冲_获状态(tb, i) == BUF_PENDING) {
            三缓冲_设状态(tb, i, BUF_DISPLAY)
            tb.当前显示缓冲 = i
            返回
        }
        i = i + 1
    }
}

函数 三缓冲_句柄(tb, idx) {
    如果 (idx == 0) { 返回 tb.缓冲0_句柄 }
    如果 (idx == 1) { 返回 tb.缓冲1_句柄 }
    返回 tb.缓冲2_句柄
}

函数 三缓冲_获状态(tb, idx) {
    如果 (idx == 0) { 返回 tb.缓冲0_状态 }
    如果 (idx == 1) { 返回 tb.缓冲1_状态 }
    返回 tb.缓冲2_状态
}

函数 三缓冲_设状态(tb, idx, 状态) {
    如果 (idx == 0) { tb.缓冲0_状态 = 状态 }
    如果 (idx == 1) { tb.缓冲1_状态 = 状态 }
    如果 (idx == 2) { tb.缓冲2_状态 = 状态 }
}

// §8 显示模式检测

函数 显示_检测模式() {
    定义 宽 = 系统调用(Nova系统调用_图形_获取屏幕宽, 0, 0, 0, 0, 0)
    定义 高 = 系统调用(Nova系统调用_图形_获取屏幕高, 0, 0, 0, 0, 0)
    定义 hz = 系统调用(Nova系统调用_图形_获取刷新率, 0, 0, 0, 0, 0)
    定义 深 = 系统调用(Nova系统调用_图形_获取位深, 0, 0, 0, 0, 0)
    定义 flags = 系统调用(Nova系统调用_图形_获取显示标志, 0, 0, 0, 0, 0)

    如果 (宽 <= 0) { 宽 = 1920 }
    如果 (高 <= 0) { 高 = 1080 }
    如果 (hz <= 0) { hz = 60 }
    如果 (深 <= 0) { 深 = 32 }

    全局显示 = 显示模式信息 { 宽: 宽, 高: 高, 刷新率Hz: hz, 位深: 深, 标志: flags }
    返回 全局显示
}

函数 显示_是否HDR() {
    返回 (全局显示.标志 & DISPLAY_FLAG_HDR) != 0
}

函数 显示_是否VRR() {
    返回 (全局显示.标志 & DISPLAY_FLAG_VRR) != 0
}

函数 显示_获取信息() { 返回 全局显示 }

// §9 剪贴板

函数 剪贴板_读取文本() {
    定义 缓冲 = 堆_分配(65536)
    定义 长度 = 系统调用(Nova系统调用_输入_获取剪贴板, 缓冲, 65536, CLIP_TEXT, 0, 0)
    如果 (长度 <= 0) {
        堆_释放(缓冲)
        返回 0
    }
    内存_写8(缓冲 + 长度, 0)
    // 记录到剪贴板历史
    剪贴板_添加历史(CLIP_TEXT, 缓冲, 长度)
    返回 缓冲
}

函数 剪贴板_写入文本(文本) {
    如果 (文本 == 0) { 返回 }
    定义 长度 = 字符串_长度(文本)
    系统调用(Nova系统调用_输入_设置剪贴板, 文本, 长度, CLIP_TEXT, 0, 0)
    剪贴板_添加历史(CLIP_TEXT, 文本, 长度)
}

函数 剪贴板_读取图像() {
    定义 缓冲 = 堆_分配(4194304)  // 4MB上限
    定义 长度 = 系统调用(Nova系统调用_输入_获取剪贴板, 缓冲, 4194304, CLIP_IMAGE, 0, 0)
    如果 (长度 <= 0) {
        堆_释放(缓冲)
        返回 0
    }
    返回 缓冲
}

函数 剪贴板_添加历史(格式, 数据, 长度) {
    如果 (计数(剪贴板栈) >= 最大剪贴板历史) {
        // 移除最旧的
        定义 可变 tmp = []
        定义 可变 i = 1
        当 (i < 计数(剪贴板栈)) {
            追加(tmp, 剪贴板栈[i])
            i = i + 1
        }
        剪贴板栈 = tmp
    }
    追加(剪贴板栈, 剪贴板项 { 格式: 格式, 数据: 数据, 长度: 长度 })
}

函数 剪贴板_获取历史(n) {
    如果 (n > 计数(剪贴板栈)) { n = 计数(剪贴板栈) }
    定义 可变 结果 = []
    定义 可变 i = 计数(剪贴板栈) - n
    当 (i < 计数(剪贴板栈)) {
        追加(结果, 剪贴板栈[i])
        i = i + 1
    }
    返回 结果
}

// §10 IME输入法

函数 IME_设置候选框位置(win, x, y) {
    系统调用(Nova系统调用_输入_设置IME位置, win.句柄, x, y, 0, 0)
}

函数 IME_获取合成文本() {
    定义 缓冲 = 堆_分配(1024)
    定义 长度 = 系统调用(Nova系统调用_输入_获取IME状态, 缓冲, 1024, 0, 0, 0)
    如果 (长度 <= 0) {
        堆_释放(缓冲)
        返回 0
    }
    内存_写8(缓冲 + 长度, 0)
    全局IME.编辑文本 = 缓冲
    全局IME.正在合成 = 长度 > 0
    返回 缓冲
}

函数 IME_开始合成() {
    全局IME.正在合成 = 真
    系统调用(Nova系统调用_输入_IME开始, 0, 0, 0, 0, 0)
}

函数 IME_结束合成() {
    全局IME.正在合成 = 假
    全局IME.编辑文本 = ""
    系统调用(Nova系统调用_输入_IME结束, 0, 0, 0, 0, 0)
}

函数 IME_获取状态() { 返回 全局IME }

// §11 AI帧负载预测

函数 AI_帧负载预测() {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 0 }
    定义 特征 = Tensor_创建(1, 6)
    Tensor_写(特征, 0, 0, EWMA_帧时间_us * Q10 / US_PER_S)  // 帧时间占比
    Tensor_写(特征, 0, 1, EWMA_GPU时间_us * Q10 / US_PER_S)
    Tensor_写(特征, 0, 2, 连续丢帧数 * Q10 / 10)
    Tensor_写(特征, 0, 3, 总丢帧数 * Q10 / 1000)
    Tensor_写(特征, 0, 4, 全局调度器.目标帧率 * Q10 / FPS_240)
    Tensor_写(特征, 0, 5, Q_ONE)  // bias
    定义 预测 = AI总线_回归(bus, 特征)
    Tensor_释放(特征)
    返回 预测
}

函数 AI_自动降帧检查() {
    定义 负载 = AI_帧负载预测()
    如果 (负载 > 870 && 全局调度器.自适应启用) {
        定义 新fps = 全局调度器.目标帧率 * 3 / 4
        如果 (新fps < 全局调度器.最小帧率) { 新fps = 全局调度器.最小帧率 }
        帧调度器_设置帧率(全局调度器, 新fps)
        返回 真
    }
    返回 假
}

// §12 统计/诊断

函数 帧统计_平均帧时间_us() {
    如果 (帧时间计数 == 0) { 返回 0 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 帧时间计数) {
        定义 idx = (帧时间头 - 帧时间计数 + i + 帧时间缓冲大小 * 10) % 帧时间缓冲大小
        总 = 总 + 帧时间历史[idx].帧时间_us
        i = i + 1
    }
    返回 总 / 帧时间计数
}

函数 帧统计_1百分位_us() {
    // 找最大帧时间
    如果 (帧时间计数 == 0) { 返回 0 }
    定义 可变 最大 = 0
    定义 可变 i = 0
    当 (i < 帧时间计数) {
        定义 idx = (帧时间头 - 帧时间计数 + i + 帧时间缓冲大小 * 10) % 帧时间缓冲大小
        如果 (帧时间历史[idx].帧时间_us > 最大) {
            最大 = 帧时间历史[idx].帧时间_us
        }
        i = i + 1
    }
    返回 最大
}

函数 帧统计_实际FPS() {
    定义 avg = 帧统计_平均帧时间_us()
    如果 (avg <= 0) { 返回 0 }
    返回 US_PER_S / avg
}

函数 帧调度_完整统计() {
    如果 (全局调度器 == 空) { 返回 [] }
    返回 [
        全局调度器.目标帧率,
        帧统计_实际FPS(),
        帧统计_平均帧时间_us(),
        帧统计_1百分位_us(),
        EWMA_帧时间_us,
        全局调度器.帧计数,
        全局调度器.丢帧计数,
        总丢帧数,
        全局调度器.VSync模式,
        全局显示.宽,
        全局显示.高,
        全局显示.刷新率Hz,
        全局显示.标志
    ]
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./映射页.nova")
导入("./页表映射.nova")
导入("../引导/端口输入.nova")
导入("./整数转字符串.nova")
导入("./伙伴系统释放.nova")
导入("./物理页描述符.nova")

// NovaOS 页表复制 (fork COW)
// 职责: fork时复制页表并设置COW标记

定义 可变 COW_复制页表次数 = 0
定义 可变 COW_标记页数 = 0
定义 可变 COW_跳过共享页数 = 0

// fork时复制整个用户空间页表
// 策略: COW (Copy-On-Write)
//   1. 子进程获得父进程页表的副本
//   2. 所有可写页标记为只读+COW
//   3. 物理页引用计数+1
//   4. 首次写入时触发缺页, 再复制物理页

函数 页表_复制用户空间(父PML4物理) {
    如果 (父PML4物理 == 0) { 返回 0 }

    // 分配子进程的PML4
    定义 子PML4物理 = 映射_分配页表页()
    如果 (子PML4物理 == 0) { 返回 0 }

    定义 父PML4虚拟 = 物理到虚拟(父PML4物理)
    定义 子PML4虚拟 = 物理到虚拟(子PML4物理)

    // 复制内核空间 (PML4的高256项直接共享)
    定义 可变 i = 256
    当 (i < 512) {
        定义 条目 = 内存读64(父PML4虚拟 + i * 8)
        内存写64(子PML4虚拟 + i * 8, 条目)
        i = i + 1
    }

    // 复制用户空间 (PML4的低256项, 需要深拷贝+COW)
    定义 可变 pml4_i = 0
    当 (pml4_i < 256) {
        定义 父pml4e = 内存读64(父PML4虚拟 + pml4_i * 8)
        如果 (页表项_存在(父pml4e)) {
            定义 结果 = 复制_PDPT级(父pml4e, 子PML4虚拟 + pml4_i * 8)
            如果 (结果 != 成功) {
                // 失败回滚: 释放已分配的子页表
                页表_释放用户空间(子PML4物理)
                返回 0
            }
        }
        pml4_i = pml4_i + 1
    }

    COW_复制页表次数 = COW_复制页表次数 + 1
    返回 子PML4物理
}

函数 复制_PDPT级(父pml4e, 子pml4e位置) {
    定义 父PDPT物理 = 页表项_地址(父pml4e)
    定义 子PDPT物理 = 映射_分配页表页()
    如果 (子PDPT物理 == 0) { 返回 错误_内存不足 }

    // 写入子PML4的PDPT指针
    定义 标志 = 页表项_标志(父pml4e)
    内存写64(子pml4e位置, 页表项_创建(子PDPT物理, 标志))

    定义 父PDPT虚拟 = 物理到虚拟(父PDPT物理)
    定义 子PDPT虚拟 = 物理到虚拟(子PDPT物理)

    定义 可变 i = 0
    当 (i < 512) {
        定义 父pdpte = 内存读64(父PDPT虚拟 + i * 8)
        如果 (页表项_存在(父pdpte)) {
            如果 (页表项_是大页(父pdpte)) {
                // 1GB大页: 设置COW + 引用计数
                定义 cow_pte = COW_标记PTE(父pdpte)
                内存写64(子PDPT虚拟 + i * 8, cow_pte)
                // 同时修改父的PTE为COW
                内存写64(父PDPT虚拟 + i * 8, cow_pte)
                COW_增加物理引用(页表项_地址(父pdpte), 1 << 18)
            } 否则 {
                定义 结果 = 复制_PD级(父pdpte, 子PDPT虚拟 + i * 8)
                如果 (结果 != 成功) { 返回 结果 }
            }
        }
        i = i + 1
    }
    返回 成功
}

函数 复制_PD级(父pdpte, 子pdpte位置) {
    定义 父PD物理 = 页表项_地址(父pdpte)
    定义 子PD物理 = 映射_分配页表页()
    如果 (子PD物理 == 0) { 返回 错误_内存不足 }

    定义 标志 = 页表项_标志(父pdpte)
    内存写64(子pdpte位置, 页表项_创建(子PD物理, 标志))

    定义 父PD虚拟 = 物理到虚拟(父PD物理)
    定义 子PD虚拟 = 物理到虚拟(子PD物理)

    定义 可变 i = 0
    当 (i < 512) {
        定义 父pde = 内存读64(父PD虚拟 + i * 8)
        如果 (页表项_存在(父pde)) {
            如果 (页表项_是大页(父pde)) {
                // 2MB大页: 设置COW
                定义 cow_pte = COW_标记PTE(父pde)
                内存写64(子PD虚拟 + i * 8, cow_pte)
                内存写64(父PD虚拟 + i * 8, cow_pte)
                COW_增加物理引用(页表项_地址(父pde), 512)
            } 否则 {
                定义 结果 = 复制_PT级(父pde, 子PD虚拟 + i * 8, 父PD虚拟 + i * 8)
                如果 (结果 != 成功) { 返回 结果 }
            }
        }
        i = i + 1
    }
    返回 成功
}

函数 复制_PT级(父pde, 子pde位置, 父pde位置) {
    定义 父PT物理 = 页表项_地址(父pde)
    定义 子PT物理 = 映射_分配页表页()
    如果 (子PT物理 == 0) { 返回 错误_内存不足 }

    定义 标志 = 页表项_标志(父pde)
    内存写64(子pde位置, 页表项_创建(子PT物理, 标志))

    定义 父PT虚拟 = 物理到虚拟(父PT物理)
    定义 子PT虚拟 = 物理到虚拟(子PT物理)

    定义 可变 i = 0
    当 (i < 512) {
        定义 父pte = 内存读64(父PT虚拟 + i * 8)
        如果 (页表项_存在(父pte)) {
            如果 (页表项_可写(父pte)) {
                // 可写页: 设置COW标记, 去除写权限
                定义 cow_pte = COW_标记PTE(父pte)
                内存写64(子PT虚拟 + i * 8, cow_pte)
                // 父进程也要变成COW
                内存写64(父PT虚拟 + i * 8, cow_pte)
                COW_标记页数 = COW_标记页数 + 1
            } 否则 {
                // 只读页: 直接共享
                内存写64(子PT虚拟 + i * 8, 父pte)
                COW_跳过共享页数 = COW_跳过共享页数 + 1
            }
            // 物理页引用计数+1
            定义 物理地址 = 页表项_地址(父pte)
            定义 页号 = 物理地址 / 页大小
            定义 页 = 页描述符_获取(页号)
            如果 (页 != 空) {
                页描述符_增引用(页)
            }
        }
        i = i + 1
    }
    返回 成功
}

// COW辅助函数

// 标记PTE为COW: 去掉可写位, 加上COW软件位
函数 COW_标记PTE(pte) {
    返回 (pte & (~PTE_可写)) | PTE_COW标记
}

// 增加一段物理页的引用计数 (大页用)
函数 COW_增加物理引用(物理起始, 页数) {
    定义 起始页号 = 物理起始 / 页大小
    定义 可变 i = 0
    当 (i < 页数) {
        定义 页 = 页描述符_获取(起始页号 + i)
        如果 (页 != 空) {
            页描述符_增引用(页)
        }
        i = i + 1
    }
}

// 释放用户空间页表 (进程退出时)

函数 页表_释放用户空间(pml4_物理) {
    如果 (pml4_物理 == 0) { 返回 }
    定义 pml4_虚拟 = 物理到虚拟(pml4_物理)

    // 只释放用户空间 (低256项)
    定义 可变 pml4_i = 0
    当 (pml4_i < 256) {
        定义 pml4e = 内存读64(pml4_虚拟 + pml4_i * 8)
        如果 (页表项_存在(pml4e)) {
            释放_PDPT级(页表项_地址(pml4e))
        }
        pml4_i = pml4_i + 1
    }
    // 释放PML4页本身
    伙伴系统_释放(pml4_物理 / 页大小, 0)
}

函数 释放_PDPT级(pdpt_物理) {
    定义 pdpt_虚拟 = 物理到虚拟(pdpt_物理)
    定义 可变 i = 0
    当 (i < 512) {
        定义 pdpte = 内存读64(pdpt_虚拟 + i * 8)
        如果 (页表项_存在(pdpte) && !页表项_是大页(pdpte)) {
            释放_PD级(页表项_地址(pdpte))
        }
        i = i + 1
    }
    伙伴系统_释放(pdpt_物理 / 页大小, 0)
}

函数 释放_PD级(pd_物理) {
    定义 pd_虚拟 = 物理到虚拟(pd_物理)
    定义 可变 i = 0
    当 (i < 512) {
        定义 pde = 内存读64(pd_虚拟 + i * 8)
        如果 (页表项_存在(pde) && !页表项_是大页(pde)) {
            释放_PT级(页表项_地址(pde))
        }
        i = i + 1
    }
    伙伴系统_释放(pd_物理 / 页大小, 0)
}

函数 释放_PT级(pt_物理) {
    定义 pt_虚拟 = 物理到虚拟(pt_物理)
    // 释放PT引用的物理页 (减引用计数)
    定义 可变 i = 0
    当 (i < 512) {
        定义 pte = 内存读64(pt_虚拟 + i * 8)
        如果 (页表项_存在(pte)) {
            定义 页号 = 页表项_地址(pte) / 页大小
            定义 页 = 页描述符_获取(页号)
            如果 (页 != 空) {
                定义 剩余引用 = 页描述符_减引用(页)
                如果 (剩余引用 <= 0) {
                    // 最后一个引用, 释放物理页
                    伙伴系统_释放(页号, 0)
                }
            }
        }
        i = i + 1
    }
    // 释放PT页本身
    伙伴系统_释放(pt_物理 / 页大小, 0)
}

// 统计

函数 COW_统计() {
    返回 [COW_复制页表次数, COW_标记页数, COW_跳过共享页数]
}


函数 页表复制_完整统计() {
    返回 [COW_复制页表次数, COW_标记页数, COW_跳过共享页数]
}

// COW健康检查

函数 COW_健康检查() {
    定义 可变 问题 = []
    如果 (COW_复制页表次数 > 100000) {
        追加(问题, "COW复制过多: " + 整数转字符串(COW_复制页表次数))
    }
    定义 总 = COW_标记页数 + COW_跳过共享页数
    如果 (总 > 0 && COW_跳过共享页数 > 总 / 2) {
        追加(问题, "共享页跳过率高，写时复制效率可能低")
    }
    如果 (计数(问题) == 0) { 返回 "COW健康" }
    返回 问题
}

函数 COW_重置统计() {
    COW_复制页表次数 = 0
    COW_标记页数 = 0
    COW_跳过共享页数 = 0
}

函数 COW_标记率() {
    如果 (COW_复制页表次数 == 0) { 返回 0 }
    返回 COW_标记页数 * 100 / COW_复制页表次数
}

函数 COW_完整统计() {
    返回 [COW_复制页表次数, COW_标记页数, COW_跳过共享页数]
}

定义 可变 AI_页表复制_运行指标 = 0
定义 可变 AI_页表复制_异常指标 = 0

函数 AI_页表复制_自诊断() {
    AI_页表复制_运行指标 = COW_复制页表次数
    返回 AI_页表复制_运行指标
}

函数 AI_页表复制_优化建议() {
    定义 指标 = AI_页表复制_自诊断()
    如果 (AI_页表复制_运行指标 > 10000) { 返回 "页表复制负载较高" }
    返回 "页表复制状态正常"
}

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../外联/套接层完整.nova")
导入("../中枢/哈希整数.nova")
导入("../中枢/创建甲.nova")

定义 最大连接 = 64
定义 预取队列深 = 32
定义 衰减系数 = 922
定义 基数 = 1024

结构 网络连接 {
    地址哈希,
    端口,
    套接描述,
    最近使用,
    请求数,
    活跃,
}

结构 预取项 {
    地址哈希,
    优先级,
    已完成,
}

定义 可变 连接表 = []
定义 可变 连接数 = 0
定义 可变 预取队列 = []
定义 可变 预取数 = 0
定义 可变 总请求 = 0
定义 可变 总字节 = 0
定义 可变 预取命中 = 0
定义 可变 预取未中 = 0
定义 可变 连接复用 = 0

函数 浏览器网络_初始化() {
    连接表 = []
    连接数 = 0
    预取队列 = []
    预取数 = 0
}

函数 浏览器网络_请求(地址, 端口) {
    总请求 = 总请求 + 1
    定义 已有 = 浏览器网络_查找连接(地址, 端口)
    如果 (已有 >= 0) {
        连接表[已有].请求数 = 连接表[已有].请求数 + 1
        连接表[已有].最近使用 = 平台_获取高精度时间()
        连接复用 = 连接复用 + 1
        返回 连接表[已有].套接描述
    }
    如果 (连接数 >= 最大连接) { 浏览器网络_淘汰连接() }
    定义 连接 = 网络连接 {}
    连接.地址哈希 = 哈希_字符串(地址)
    连接.端口 = 端口
    连接.套接描述 = 套接_创建(1, 0)
    套接_连接(连接.套接描述, 连接.地址哈希, 端口)
    连接.最近使用 = 平台_获取高精度时间()
    连接.请求数 = 1
    连接.活跃 = 真
    追加(连接表, 连接)
    连接数 = 连接数 + 1
    返回 连接.套接描述
}

函数 浏览器网络_查找连接(地址, 端口) {
    定义 目标 = 哈希_字符串(地址)
    定义 可变 序号 = 0
    当 (序号 < 连接数) {
        如果 (连接表[序号].地址哈希 == 目标 && 连接表[序号].端口 == 端口 && 连接表[序号].活跃) {
            返回 序号
        }
        序号 = 序号 + 1
    }
    返回 -1
}

函数 浏览器网络_淘汰连接() {
    定义 可变 最旧 = 0
    定义 可变 最旧时间 = 连接表[0].最近使用
    定义 可变 序号 = 1
    当 (序号 < 连接数) {
        如果 (连接表[序号].最近使用 < 最旧时间) {
            最旧时间 = 连接表[序号].最近使用
            最旧 = 序号
        }
        序号 = 序号 + 1
    }
    套接_关闭(连接表[最旧].套接描述)
    连接表[最旧].活跃 = 假
}

函数 浏览器网络_预取(地址, 优先级) {
    如果 (预取数 >= 预取队列深) { 返回 }
    定义 项 = 预取项 {}
    项.地址哈希 = 哈希_字符串(地址)
    项.优先级 = 优先级
    项.已完成 = 假
    追加(预取队列, 项)
    预取数 = 预取数 + 1
}

函数 浏览器网络_检查预取(地址) {
    定义 目标 = 哈希_字符串(地址)
    定义 可变 序号 = 0
    当 (序号 < 预取数) {
        如果 (预取队列[序号].地址哈希 == 目标 && 预取队列[序号].已完成) {
            预取命中 = 预取命中 + 1
            返回 真
        }
        序号 = 序号 + 1
    }
    预取未中 = 预取未中 + 1
    返回 假
}

函数 浏览器网络_记录字节(字节数) {
    总字节 = 总字节 + 字节数
}

函数 浏览器网络_活跃连接数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 连接数) {
        如果 (连接表[序号].活跃) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 浏览器网络_统计() {
    返回 [总请求, 总字节, 预取命中, 预取未中, 浏览器网络_活跃连接数(), 连接复用]
}

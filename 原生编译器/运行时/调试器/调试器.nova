导入("../../标准库/基础.nova")
导入("../../自举兼容桥.nova")
导入("../热更新/热更新管理.nova")
导入("../解释器/栈式VM.nova")

// Nova · 运行时层 · 调试器
// 断点/单步/变量监控/实时改代码/JIT调试映射
// 对接解释器和JIT，支持精准到行的源码调试

// 调试命令
定义 调试_继续 = 0 // continue
定义 调试_单步 = 1 // step (进入函数)
定义 调试_步过 = 2 // step over (不进入函数)
定义 调试_步出 = 3 // step out (跳出当前函数)
定义 调试_查看变量 = 4 // inspect variable
定义 调试_设断点 = 5 // set breakpoint
定义 调试_删断点 = 6 // remove breakpoint
定义 调试_查看栈 = 7 // 栈 trace
定义 调试_修改变量 = 8 // modify variable

// 断点类型
定义 断点_行 = 0 // 行断点
定义 断点_函数 = 1 // 函数入口断点
定义 断点_条件 = 2 // 条件断点 (表达式为真时暂停)
定义 断点_一次性 = 3 // 一次性断点 (触发后自动删除)

// 断点记录
// [ID, 类型, 位置(行号/函数名), 条件表达式, 启用, 命中次数]
函数 断点_创建(ID, 类型, 位置) { 返回 [ID, 类型, 位置, 空, 真, 0]
}

函数 断点_ID(bp) { 返回 bp[0] }
函数 调试器_断点_启用(bp) { 返回 bp[4] }
函数 调试器_断点_命中(bp) { bp[5] = bp[5] + 1 }

// 调试器实例
// [断点列表, 下一个断点ID, 单步模式, 当前行, 当前函数, 暂停回调,
// 变量监视列表, 调用栈快照, JIT映射表, 历史命令]
函数 调试器_调试器_创建() { 返回 [[], 1, 假, 0, "", 空, [], [], 字典(), []]
}

// 断点管理
函数 调试器_调试器_添加断点(调试器, 类型, 位置) { 定义 bp = 断点_创建(调试器[1], 类型, 位置)
 追加(调试器[0], bp)
 调试器[1] = 调试器[1] + 1
 打印(字符串拼接("断点 #", 字符串拼接(转字符串(bp[0]), 字符串拼接(" 设置于 ", 转字符串(位置)))))
 返回 bp[0]
}

函数 调试器_调试器_删除断点(调试器, ID) {
    定义 可变 新列表 = []
 定义 可变 i = 0
 定义 可变 已删 = 假
 当 (i < 计数(调试器[0])) { 如果 (断点_ID(调试器[0][i]) != ID) {
 追加(新列表, 调试器[0][i])
 } 否则 {
 已删 = 真
 }
 i = i + 1
 }
 调试器[0] = 新列表
 返回 已删
}

函数 调试器_启用断点(调试器, ID, 启用) { 定义 可变 i = 0
 当 (i < 计数(调试器[0])) { 如果 (断点_ID(调试器[0][i]) == ID) {
 调试器[0][i][4] = 启用
 返回 真
 }
 i = i + 1
 }
 返回 假
}

函数 调试器_列出断点(调试器) {
 打印(字符串拼接("═══ 断点列表 (", 字符串拼接(转字符串(计数(调试器[0])), "个) ═══")))
 定义 可变 i = 0
 当 (i < 计数(调试器[0])) { 定义 bp = 调试器[0][i]
 定义 可变 状态 = "启用"
 如果 (!bp[4]) { 状态 = "禁用" }
 打印(字符串拼接(" #", 字符串拼接(转字符串(bp[0]), 字符串拼接(" 行", 字符串拼接(转字符串(bp[2]), 字符串拼接(" [", 字符串拼接(状态, 字符串拼接("] 命中", 字符串拼接(转字符串(bp[5]), "次")))))))))
 i = i + 1
 }
}

// 检查断点 (VM每执行HN_LINE时调用)
函数 调试器_检查(调试器, 行号, 函数名) {
 调试器[3] = 行号
 调试器[4] = 函数名

 // 单步模式: 每行都暂停
 如果 (调试器[2]) { 返回 真
 }

 // 检查所有断点
 定义 可变 i = 0
 当 (i < 计数(调试器[0])) { 定义 bp = 调试器[0][i]
 如果 (断点_启用(bp)) { 如果 (bp[1] == 断点_行 且 bp[2] == 行号) {
 断点_命中(bp)
 // 一次性断点: 触发后删除
 如果 (bp[1] == 断点_一次性) {
 调试器_删除断点(调试器, bp[0])
 }
 返回 真
 }
 如果 (bp[1] == 断点_函数 且 bp[2] == 函数名) {
 断点_命中(bp)
 返回 真
 }
 }
 i = i + 1
 }

 返回 假
}

// 变量检查
函数 调试器_查看变量(_调试器, vm, 名称) {
 // 先查局部变量
 定义 帧 = VM_当前帧(vm)
 如果 (帧 != 空) { 定义 局部表 = 字典获取(VM_全局表(vm), "__调试局部变量__")
 如果 (局部表 != 空) { 定义 局部值 = 字典获取(局部表, 名称)
 如果 (局部值 != 空) {
 打印(字符串拼接(" ", 字符串拼接(名称, 字符串拼接(" = ", 转字符串(局部值)))))
 返回 局部值
 }
 }
 }
 // 查全局变量
 定义 值 = 字典获取(VM_全局表(vm), 名称)
 如果 (值 != 空) {
 打印(字符串拼接(" ", 字符串拼接(名称, 字符串拼接(" = ", 转字符串(值)))))
 返回 值
 }
 打印(字符串拼接(" 未找到变量: ", 名称))
 返回 空
}

// 调用栈
函数 调试器_调试器_调用栈(_调试器, vm) {
 打印("═══ 调用栈 ═══")
 定义 可变 i = vm[3] - 1
 定义 可变 层 = 0
 当 (i >= 0) { 定义 帧 = vm[2][i]
 打印(字符串拼接(" #", 字符串拼接(转字符串(层), 字符串拼接(" ", 字符串拼接(帧[3], 字符串拼接(" (PC=", 字符串拼接(转字符串(帧[0]), ")")))))))

 i = i - 1
 层 = 层 + 1
 }
 打印(字符串拼接(" #", 字符串拼接(转字符串(层), " <__主程序__>")))
}

// 变量监视
函数 调试器_调试器_添加监视(调试器, 名称) {
 追加(调试器[6], 名称)
}

函数 调试器_显示监视(调试器, vm) {
    如果 (计数(调试器[6]) == 0) { 返回
}
 打印("── 监视变量 ──")
 定义 可变 i = 0
 当 (i < 计数(调试器[6])) {
 调试器_查看变量(调试器, vm, 调试器[6][i])
 i = i + 1
 }
}

// JIT调试映射
// 记录JIT编译后的机器码地址→源码行号映射
函数 调试器_注册JIT映射(调试器, 块ID, 机器码偏移, 行号) { 定义 键 = 字符串拼接(转字符串(块ID), 字符串拼接(":", 转字符串(机器码偏移)))
 字典设置(调试器[8], 键, 行号)
}

函数 调试器_查JIT映射(调试器, 块ID, 机器码偏移) { 定义 键 = 字符串拼接(转字符串(块ID), 字符串拼接(":", 转字符串(机器码偏移)))
 返回 字典获取(调试器[8], 键)
}

// 单步控制
函数 调试器_开始单步(调试器) { 调试器[2] = 真 }
函数 调试器_停止单步(调试器) { 调试器[2] = 假 }

// 实时修改 (热更新集成)
函数 调试器_实时修改(_调试器, 热更管理器, 新源码, vm) {
 打印("调试器: 实时修改代码...")
 // 暂停执行
 vm[5] = VM_状态_暂停
 // 触发热更新
 热更管理器_更新(热更管理器, 新源码, vm)
 // 恢复执行
 vm[5] = VM_状态_运行
 打印("调试器: 代码已更新，继续执行")
}

// 条件断点
定义 可变 _条件断点_行 = []
定义 可变 _条件断点_条件 = []

函数 条件断点_添加(行号, 条件表达式) {
 追加(_条件断点_行, 行号)
 追加(_条件断点_条件, 条件表达式)
}

函数 条件断点_检查(行号, 变量值) { 定义 可变 i = 0
 当 (i < 计数(_条件断点_行)) { 如果 (_条件断点_行[i] == 行号) { 返回 真 }
 i = i + 1
 }
 返回 假
}

// 变量监视
定义 可变 _监视_名 = []
定义 可变 _监视_值 = []

函数 监视_添加(变量名) { 追加(_监视_名, 变量名) 追加(_监视_值, 0) }
函数 监视_更新(变量名, 值) { 定义 可变 i = 0
 当 (i < 计数(_监视_名)) { 如果 (_监视_名[i] == 变量名) { _监视_值[i] = 值 返回 }
 i = i + 1
 }
}
函数 监视_列表() { 返回 [_监视_名, _监视_值] }

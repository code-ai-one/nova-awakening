// Nova 原生编译常量 — 直击机器码0和1的底层定义
// 职责: 词法/语法/节点/寄存器/PE常量 + 0-1动态模拟精度 + 编译器全局状态
// 层级: 第1层基础设施 (无依赖)

// 编译器版本

导入("../../../标准库/基础.nova")
导入("./发射器.nova")

定义 版本_主 = 3
定义 版本_次 = 1
定义 版本_补 = 0

函数 版本字符串() {
    返回 字符串拼接(转字符串(版本_主), 字符串拼接(".", 字符串拼接(转字符串(版本_次), 字符串拼接(".", 转字符串(版本_补)))))
}


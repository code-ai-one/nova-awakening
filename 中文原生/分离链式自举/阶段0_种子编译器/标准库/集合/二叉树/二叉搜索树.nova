导入("../../基础.nova")

// Nova标准库 — 二叉搜索树
// 兼容两套历史接口:
// 1. bst_*    : 紧凑数组表示 [根索引, 节点池, 节点数]
// 2. 树_*     : 节点表示 [键, 值, 左, 右]
// 统一为原生稳定实现，避免关键字撞名与拼接残片影响自举。

定义 可变 节点_键 = 0
定义 可变 节点_值 = 1
定义 可变 节点_左 = 2
定义 可变 节点_右 = 3

函数 bst_创建() {
    返回 [-1, [], 0]
}

函数 bst_节点基位(索引) {
    返回 索引 * 3
}

函数 bst_新节点(树, 值) {
    定义 池 = 树[1]
    定义 新索引 = 树[2]
    追加(池, 值)
    追加(池, -1)
    追加(池, -1)
    树[2] = 新索引 + 1
    返回 新索引
}

函数 bst_值(树, 索引) {
    返回 树[1][bst_节点基位(索引)]
}

函数 bst_左(树, 索引) {
    返回 树[1][bst_节点基位(索引) + 1]
}

函数 bst_右(树, 索引) {
    返回 树[1][bst_节点基位(索引) + 2]
}

函数 bst_设左(树, 索引, 值) {
    定义 池 = 树[1]
    池[bst_节点基位(索引) + 1] = 值
}

函数 bst_设右(树, 索引, 值) {
    定义 池 = 树[1]
    池[bst_节点基位(索引) + 2] = 值
}

函数 bst_插入(树, 值) {
    定义 新索引 = bst_新节点(树, 值)
    如果 (树[0] < 0) {
        树[0] = 新索引
        返回 空
    }

    定义 可变 当前 = 树[0]
    当 (真) {
        定义 当前值 = bst_值(树, 当前)
        如果 (值 < 当前值) {
            如果 (bst_左(树, 当前) < 0) {
                bst_设左(树, 当前, 新索引)
                返回 空
            }
            当前 = bst_左(树, 当前)
        } 否则 {
            如果 (bst_右(树, 当前) < 0) {
                bst_设右(树, 当前, 新索引)
                返回 空
            }
            当前 = bst_右(树, 当前)
        }
    }
}

函数 bst_查找(树, 值) {
    定义 可变 当前 = 树[0]
    当 (当前 >= 0) {
        定义 当前值 = bst_值(树, 当前)
        如果 (值 == 当前值) {
            返回 真
        }
        如果 (值 < 当前值) {
            当前 = bst_左(树, 当前)
        } 否则 {
            当前 = bst_右(树, 当前)
        }
    }
    返回 假
}

函数 bst_最小(树) {
    如果 (树[0] < 0) {
        返回 空
    }
    定义 可变 当前 = 树[0]
    当 (bst_左(树, 当前) >= 0) {
        当前 = bst_左(树, 当前)
    }
    返回 bst_值(树, 当前)
}

函数 bst_最大(树) {
    如果 (树[0] < 0) {
        返回 空
    }
    定义 可变 当前 = 树[0]
    当 (bst_右(树, 当前) >= 0) {
        当前 = bst_右(树, 当前)
    }
    返回 bst_值(树, 当前)
}

函数 bst_中序(树) {
    定义 可变 结果 = []
    bst_中序递归(树, 树[0], 结果)
    返回 结果
}

函数 bst_中序递归(树, 节点, 结果) {
    如果 (节点 < 0) {
        返回 空
    }
    bst_中序递归(树, bst_左(树, 节点), 结果)
    追加(结果, bst_值(树, 节点))
    bst_中序递归(树, bst_右(树, 节点), 结果)
}

函数 bst_前序(树) {
    定义 可变 结果 = []
    bst_前序递归(树, 树[0], 结果)
    返回 结果
}

函数 bst_前序递归(树, 节点, 结果) {
    如果 (节点 < 0) {
        返回 空
    }
    追加(结果, bst_值(树, 节点))
    bst_前序递归(树, bst_左(树, 节点), 结果)
    bst_前序递归(树, bst_右(树, 节点), 结果)
}

函数 bst_后序(树) {
    定义 可变 结果 = []
    bst_后序递归(树, 树[0], 结果)
    返回 结果
}

函数 bst_后序递归(树, 节点, 结果) {
    如果 (节点 < 0) {
        返回 空
    }
    bst_后序递归(树, bst_左(树, 节点), 结果)
    bst_后序递归(树, bst_右(树, 节点), 结果)
    追加(结果, bst_值(树, 节点))
}

函数 bst_高度(树) {
    返回 bst_高度递归(树, 树[0])
}

函数 bst_高度递归(树, 节点) {
    如果 (节点 < 0) {
        返回 0
    }
    定义 左高 = bst_高度递归(树, bst_左(树, 节点))
    定义 右高 = bst_高度递归(树, bst_右(树, 节点))
    如果 (左高 > 右高) {
        返回 左高 + 1
    }
    返回 右高 + 1
}

函数 bst_大小(树) {
    返回 bst_大小递归(树, 树[0])
}

函数 bst_大小递归(树, 节点) {
    如果 (节点 < 0) {
        返回 0
    }
    定义 左数 = bst_大小递归(树, bst_左(树, 节点))
    定义 右数 = bst_大小递归(树, bst_右(树, 节点))
    返回 1 + 左数 + 右数
}

函数 bst_空(树) {
    返回 树[0] < 0
}

函数 bst_从排序(排序列表) {
    定义 可变 树 = bst_创建()
    bst_平衡构建(树, 排序列表, 0, 计数(排序列表) - 1)
    返回 树
}

函数 bst_平衡构建(树, 列表, 左, 右) {
    如果 (左 > 右) {
        返回 空
    }
    定义 中 = (左 + 右) / 2
    bst_插入(树, 列表[中])
    bst_平衡构建(树, 列表, 左, 中 - 1)
    bst_平衡构建(树, 列表, 中 + 1, 右)
}

函数 bst_层序(树) {
    如果 (树[0] < 0) {
        返回 []
    }

    定义 可变 队列 = [树[0]]
    定义 可变 结果 = []
    定义 可变 前 = 0
    当 (前 < 计数(队列)) {
        定义 当前 = 队列[前]
        前 = 前 + 1
        追加(结果, bst_值(树, 当前))

        定义 左子 = bst_左(树, 当前)
        如果 (左子 >= 0) {
            追加(队列, 左子)
        }

        定义 右子 = bst_右(树, 当前)
        如果 (右子 >= 0) {
            追加(队列, 右子)
        }
    }
    返回 结果
}

函数 bst_范围(树, 最小值, 最大值) {
    定义 可变 结果 = []
    bst_范围递归(树, 树[0], 最小值, 最大值, 结果)
    返回 结果
}

函数 bst_范围递归(树, 节点, 最小值, 最大值, 结果) {
    如果 (节点 < 0) {
        返回 空
    }

    定义 当前值 = bst_值(树, 节点)
    如果 (当前值 > 最小值) {
        bst_范围递归(树, bst_左(树, 节点), 最小值, 最大值, 结果)
    }

    如果 (当前值 >= 最小值) {
        如果 (当前值 <= 最大值) {
            追加(结果, 当前值)
        }
    }

    如果 (当前值 < 最大值) {
        bst_范围递归(树, bst_右(树, 节点), 最小值, 最大值, 结果)
    }
}

函数 树_新节点(键, 值) {
    返回 [键, 值, 空, 空]
}

函数 树_查找(根, 键) {
    如果 (根 == 空) {
        返回 空
    }
    如果 (键 < 根[节点_键]) {
        返回 树_查找(根[节点_左], 键)
    }
    如果 (键 > 根[节点_键]) {
        返回 树_查找(根[节点_右], 键)
    }
    返回 根[节点_值]
}

函数 树_插入(根, 键, 值) {
    如果 (根 == 空) {
        返回 树_新节点(键, 值)
    }
    如果 (键 < 根[节点_键]) {
        根[节点_左] = 树_插入(根[节点_左], 键, 值)
    } 否则 {
        如果 (键 > 根[节点_键]) {
            根[节点_右] = 树_插入(根[节点_右], 键, 值)
        } 否则 {
            根[节点_值] = 值
        }
    }
    返回 根
}

函数 树_最小(根) {
    如果 (根 == 空) {
        返回 空
    }
    如果 (根[节点_左] == 空) {
        返回 根
    }
    返回 树_最小(根[节点_左])
}

函数 树_最大(根) {
    如果 (根 == 空) {
        返回 空
    }
    如果 (根[节点_右] == 空) {
        返回 根
    }
    返回 树_最大(根[节点_右])
}

函数 树_大小(根) {
    如果 (根 == 空) {
        返回 0
    }
    定义 左数 = 树_大小(根[节点_左])
    定义 右数 = 树_大小(根[节点_右])
    返回 1 + 左数 + 右数
}

函数 树_中序(根, 结果) {
    如果 (根 == 空) {
        返回 空
    }
    树_中序(根[节点_左], 结果)
    追加(结果, [根[节点_键], 根[节点_值]])
    树_中序(根[节点_右], 结果)
}

函数 树_所有键值(根) {
    定义 可变 结果 = []
    树_中序(根, 结果)
    返回 结果
}

// AVL平衡旋转

函数 树_高度(根) {
    如果 (根 == 空) { 返回 0 }
    定义 左高 = 树_高度(根[节点_左])
    定义 右高 = 树_高度(根[节点_右])
    如果 (左高 > 右高) { 返回 左高 + 1 }
    返回 右高 + 1
}

函数 树_平衡因子(根) {
    如果 (根 == 空) { 返回 0 }
    返回 树_高度(根[节点_左]) - 树_高度(根[节点_右])
}

函数 树_左旋(根) {
    定义 新根 = 根[节点_右]
    根[节点_右] = 新根[节点_左]
    新根[节点_左] = 根
    返回 新根
}

函数 树_右旋(根) {
    定义 新根 = 根[节点_左]
    根[节点_左] = 新根[节点_右]
    新根[节点_右] = 根
    返回 新根
}

函数 树_AVL平衡(根) {
    定义 因子 = 树_平衡因子(根)
    如果 (因子 > 1) {
        如果 (树_平衡因子(根[节点_左]) < 0) { 根[节点_左] = 树_左旋(根[节点_左]) }
        返回 树_右旋(根)
    }
    如果 (因子 < -1) {
        如果 (树_平衡因子(根[节点_右]) > 0) { 根[节点_右] = 树_右旋(根[节点_右]) }
        返回 树_左旋(根)
    }
    返回 根
}

// 节点删除

函数 树_最小节点(根) {
    如果 (根 == 空) { 返回 空 }
    定义 可变 当前 = 根
    当 (当前[节点_左] != 空) { 当前 = 当前[节点_左] }
    返回 当前
}

函数 树_最大节点(根) {
    如果 (根 == 空) { 返回 空 }
    定义 可变 当前 = 根
    当 (当前[节点_右] != 空) { 当前 = 当前[节点_右] }
    返回 当前
}

函数 树_删除(根, 键) {
    如果 (根 == 空) { 返回 空 }
    如果 (键 < 根[节点_键]) { 根[节点_左] = 树_删除(根[节点_左], 键) }
    否则 如果 (键 > 根[节点_键]) { 根[节点_右] = 树_删除(根[节点_右], 键) }
    否则 {
        如果 (根[节点_左] == 空) { 返回 根[节点_右] }
        如果 (根[节点_右] == 空) { 返回 根[节点_左] }
        定义 后继 = 树_最小节点(根[节点_右])
        根[节点_键] = 后继[节点_键]
        根[节点_值] = 后继[节点_值]
        根[节点_右] = 树_删除(根[节点_右], 后继[节点_键])
    }
    返回 树_AVL平衡(根)
}

// 更多遍历

函数 树_前序(根, 结果) {
    如果 (根 == 空) { 返回 }
    追加(结果, [根[节点_键], 根[节点_值]])
    树_前序(根[节点_左], 结果)
    树_前序(根[节点_右], 结果)
}

函数 树_后序(根, 结果) {
    如果 (根 == 空) { 返回 }
    树_后序(根[节点_左], 结果)
    树_后序(根[节点_右], 结果)
    追加(结果, [根[节点_键], 根[节点_值]])
}

函数 树_范围查询(根, 最小键, 最大键, 结果) {
    如果 (根 == 空) { 返回 }
    如果 (根[节点_键] > 最小键) { 树_范围查询(根[节点_左], 最小键, 最大键, 结果) }
    如果 (根[节点_键] >= 最小键 且 根[节点_键] <= 最大键) { 追加(结果, [根[节点_键], 根[节点_值]]) }
    如果 (根[节点_键] < 最大键) { 树_范围查询(根[节点_右], 最小键, 最大键, 结果) }
}

函数 树_第K小(根, k) {
    定义 可变 结果 = []
    树_中序(根, 结果)
    如果 (k > 0 且 k <= 计数(结果)) { 返回 结果[k - 1] }
    返回 空
}

函数 树_是否平衡(根) {
    如果 (根 == 空) { 返回 真 }
    定义 因子 = 树_平衡因子(根)
    如果 (因子 > 1 或 因子 < -1) { 返回 假 }
    返回 树_是否平衡(根[节点_左]) 且 树_是否平衡(根[节点_右])
}

函数 树_是否有效BST(根, 最小, 最大) {
    如果 (根 == 空) { 返回 真 }
    如果 (根[节点_键] <= 最小 或 根[节点_键] >= 最大) { 返回 假 }
    返回 树_是否有效BST(根[节点_左], 最小, 根[节点_键]) 且 树_是否有效BST(根[节点_右], 根[节点_键], 最大)
}

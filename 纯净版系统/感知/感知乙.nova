// §4 calc()表达式求值
// calc(100% - 20px) / calc(2 * 1em + 10px)


函数 CSS_calc求值(表达式, 参照值_百分比, 参照值_em) {
    // calc()表达式求值器
    // 支持: + - * / 和括号
    如果 (表达式 == 0) { 返回 0 }
    定义 长度 = 字符串_长度(表达式)
    定义 可变 pos = 0

    返回 CSS_calc_加法(表达式, 长度, pos, 参照值_百分比, 参照值_em)
}

函数 CSS_calc_加法(文本, 长度, pos, 参照百分比, 参照em) {
    定义 可变 结果 = CSS_calc_乘法(文本, 长度, pos, 参照百分比, 参照em)

    当 (pos < 长度) {
        当 (pos < 长度 && 内存_读8(文本+pos) == 0x20) { pos = pos + 1 }
        如果 (pos >= 长度) { 跳出 }
        定义 op = 内存_读8(文本 + pos)
        如果 (op == 0x2B) {    // +
            pos = pos + 1
            当 (pos < 长度 && 内存_读8(文本+pos) == 0x20) { pos = pos + 1 }
            定义 右 = CSS_calc_乘法(文本, 长度, pos, 参照百分比, 参照em)
            结果 = 结果 + 右
        } 否则 如果 (op == 0x2D) {    // -
            pos = pos + 1
            当 (pos < 长度 && 内存_读8(文本+pos) == 0x20) { pos = pos + 1 }
            定义 右 = CSS_calc_乘法(文本, 长度, pos, 参照百分比, 参照em)
            结果 = 结果 - 右
        } 否则 { 跳出 }
    }
    返回 结果
}

函数 CSS_calc_乘法(文本, 长度, pos, 参照百分比, 参照em) {
    定义 可变 结果 = CSS_calc_原子(文本, 长度, pos, 参照百分比, 参照em)

    当 (pos < 长度) {
        当 (pos < 长度 && 内存_读8(文本+pos) == 0x20) { pos = pos + 1 }
        如果 (pos >= 长度) { 跳出 }
        定义 op = 内存_读8(文本 + pos)
        如果 (op == 0x2A) {    // *
            pos = pos + 1
            当 (pos < 长度 && 内存_读8(文本+pos) == 0x20) { pos = pos + 1 }
            定义 右 = CSS_calc_原子(文本, 长度, pos, 参照百分比, 参照em)
            结果 = 结果 * 右 / 100    // 定点数乘法
        } 否则 如果 (op == 0x2F) {    // /
            pos = pos + 1
            当 (pos < 长度 && 内存_读8(文本+pos) == 0x20) { pos = pos + 1 }
            定义 右 = CSS_calc_原子(文本, 长度, pos, 参照百分比, 参照em)
            如果 (右 != 0) { 结果 = 结果 * 100 / 右 }
        } 否则 { 跳出 }
    }
    返回 结果
}

函数 CSS_calc_原子(文本, 长度, pos, 参照百分比, 参照em) {
    当 (pos < 长度 && 内存_读8(文本+pos) == 0x20) { pos = pos + 1 }

    // 括号
    如果 (pos < 长度 && 内存_读8(文本+pos) == 0x28) {
        pos = pos + 1
        定义 结果 = CSS_calc_加法(文本, 长度, pos, 参照百分比, 参照em)
        如果 (pos < 长度 && 内存_读8(文本+pos) == 0x29) { pos = pos + 1 }
        返回 结果
    }

    // 数字+单位
    定义 val = CSS解析_数字或长度(文本, 长度, pos)
    如果 (val == 0) { 返回 0 }

    // 跳过已解析的部分
    当 (pos < 长度 && 内存_读8(文本+pos) != 0x20 && 内存_读8(文本+pos) != 0x2B && 内存_读8(文本+pos) != 0x2D && 内存_读8(文本+pos) != 0x2A && 内存_读8(文本+pos) != 0x2F && 内存_读8(文本+pos) != 0x29) {
        pos = pos + 1
    }

    // 转换为像素(×100)
    如果 (val.单位 == 单位_百分比) { 返回 参照百分比 * val.整数值 / 10000 }
    如果 (val.单位 == 单位_em) { 返回 参照em * val.整数值 / 100 }
    如果 (val.单位 == 单位_rem) { 返回 1600 * val.整数值 / 100 }    // 16px base
    如果 (val.单位 == 单位_vw) { 返回 参照百分比 * val.整数值 / 10000 }
    返回 val.整数值    // px或纯数字
}

// 传统方案: 资源加载按发现顺序, 不区分重要性
// Nova: AI总线神经网络推理驱动资源加载优先级

函数 智能_历史接口_AI加载优先级(url) {
    定义 bus = 全局AI总线
    如果 (bus == 0 || url == 0) { 返回 Q_HALF }
    // URL→12维特征提取→Nova多层感知器推理→优先级分数
    返回 AI总线_资源优先级(bus, url)
}

函数 智能_历史接口_AI预取决策(url) {
    定义 bus = 全局AI总线
    如果 (bus == 0 || url == 0) { 返回 假 }
    定义 分数 = AI总线_资源优先级(bus, url)
    返回 分数 > 600    // 高优先级资源预取
}

}

函数 文档节点_页评分(档, 根节点) {
    定义 结果 = 语义_页面质量评分(根节点)
    档.最近语义 = 结果
    档.语义数 = 档.语义数 + 1
    返回 文档节点_成功(档, "页评分", 结果)
}

函数 文档节点_摘要(档) {
    定义 摘要 = 堆_分配(节点摘要)
    摘要.名称 = 档.名称
    摘要.文档数 = 档.文档数
    摘要.节点数 = 档.节点数
    摘要.元素数 = 档.元素数
    摘要.查询数 = 档.查询数
    摘要.几何数 = 档.几何数
    摘要.语义数 = 档.语义数
    摘要.交互数 = 档.交互数
    摘要.命中数 = 档.命中数
    摘要.失败数 = 档.失败数
    摘要.健康 = 档.健康
    返回 摘要
}

函数 文档节点_完整统计() {
    返回 [
        节点建数,
        节点总动作,
        节点总命中,
        节点总失败,
        节点_完整统计(),
        节点_健康检查(),
        DOM_统计(),
        语义_完整统计(),
        标记表单创_统计()
    ]
}

函数 文档节点_健康(档) {
    如果 (!档.初始化完成) { 返回 "未初始化" }
    如果 (档.失败数 > 档.命中数) { 返回 "降级" }
    如果 (档.失败数 > 0) { 返回 "监视" }
    返回 "运行"
}

函数 文档节点_自检() {
    定义 档 = 文档节点_创建("文档节点")
    定义 文档回证 = 文档节点_创建文档(档, "nova://文档节点")
    如果 (!文档回证.已成) {
        返回 [假, 假, 假, "文档创建失败"]
    }
    定义 文档 = 文档回证.数据
    定义 元素回证 = 文档节点_创建元素(档, 文档, "div")
    定义 文本回证 = 文档节点_创建文本(档, 文档, "纯净版节点自检")
    如果 (!元素回证.已成 || !文本回证.已成) {
        返回 [真, 假, 假, "节点创建失败"]
    }
    定义 元素 = 元素回证.数据
    定义 文本节点 = 文本回证.数据
    文档节点_设标识(档, 元素, "根节点")
    文档节点_设类名(档, 元素, "主区")
    文档节点_加子(档, 元素, 文本节点)
    文档节点_语义分析(档, 元素)
    文档节点_记点击(档, 元素)
    文档节点_记悬停(档, 元素, 40)
    文档节点_可见性(档, 元素, 1280, 720)
    档.健康 = 文档节点_健康(档)
    返回 [
        档.初始化完成,
        文档节点_取标识(档, 元素).已成,
        文档节点_取类名(档, 元素).已成,
        档.交互数 > 0,
        档.语义数 > 0,
        档.健康
    ]
}

// merge source: 沙盒批次/批三/待厚/感知/表单提交.nova

定义 编码_urlencoded = 0
定义 编码_multipart = 1
定义 编码_text_plain = 2

定义 目标_self = 0
定义 目标_blank = 1
定义 目标_parent = 2
定义 目标_top = 3

结构 FormDataEntry {
    名称,
    值,
    文件名,
    MIME类型,
    是文件,
}

结构 FormData {
    条目列表,
    条目数,
}

函数 HTMLForm_兼容模型(form) {
    如果 (form == 0) { 返回 0 }
    如果 (form.action != 0 || form.method != 0 || form.控件 != 0) { 返回 form }

    定义 兼容表单 = HTMLForm_创建()
    兼容表单.DOM节点 = form.DOM节点
    如果 (兼容表单.DOM节点 == 0) { 兼容表单.DOM节点 = form.所属元素 }
    兼容表单.action = 如果 (form.action != 0) { form.action } 否则 { form.动作URL }
    兼容表单.target = 如果 (form.target != 0) { form.target } 否则 { form.目标 }
    兼容表单.编码类型 = form.编码类型
    兼容表单.method = 如果 (form.方法 == 1) { "post" } 否则 { "get" }
    兼容表单.novalidate = form.novalidate

    定义 控件列表 = HTMLForm_获取控件列表(form)
    如果 (控件列表 != 0) {
        定义 可变 i = 0
        当 (i < 计数(控件列表)) {
            如果 (控件列表[i] != 0) {
                HTMLForm_添加控件(兼容表单, 控件列表[i])
            }
            i = i + 1
        }
    }

    返回 兼容表单
}

函数 FormData_创建(form) {
    form = HTMLForm_兼容模型(form)
    定义 fd = 堆_分配(FormData)
    fd.条目列表 = []
    fd.条目数 = 0
    如果 (form == 0) { 返回 fd }

    定义 控件列表 = HTMLForm_获取控件列表(form)
    如果 (控件列表 == 0) { 返回 fd }

    定义 可变 i = 0
    当 (i < 计数(控件列表)) {
        定义 控件 = 控件列表[i]
        如果 (控件 == 0 || 控件.名称 == 0 || 字符串长度(控件.名称) == 0) {
            i = i + 1; 继续
        }
        如果 (控件.禁用) { i = i + 1; 继续 }

        定义 类型 = 控件.type

        如果 (类型 == "checkbox" || 类型 == "radio") {
            如果 (!控件.checked) { i = i + 1; 继续 }
        }

        如果 (类型 == "submit" || 类型 == "reset" || 类型 == "button" || 类型 == "image") {
            i = i + 1; 继续
        }

        定义 entry = 堆_分配(FormDataEntry)
        entry.名称 = 控件.名称
        entry.是文件 = 假

        如果 (类型 == "file") {
            如果 (控件.文件列表 != 0 && 计数(控件.文件列表) > 0) {
                定义 可变 j = 0
                当 (j < 计数(控件.文件列表)) {
                    定义 fe = 堆_分配(FormDataEntry)
                    fe.名称 = 控件.名称
                    fe.值 = 控件.文件列表[j].数据
                    fe.文件名 = 控件.文件列表[j].名称
                    fe.MIME类型 = 控件.文件列表[j].类型
                    fe.是文件 = 真
                    追加(fd.条目列表, fe)
                    fd.条目数 = fd.条目数 + 1
                    j = j + 1
                }
                i = i + 1; 继续
            } 否则 {
                entry.值 = ""
                entry.文件名 = ""
                entry.是文件 = 真
            }
        } 否则 如果 (类型 == "select-multiple") {
            定义 选项列表 = 控件.选项
            定义 可变 j = 0
            当 (j < 计数(选项列表)) {
                如果 (选项列表[j].selected) {
                    定义 se = 堆_分配(FormDataEntry)
                    se.名称 = 控件.名称
                    se.值 = 选项列表[j].value
                    se.是文件 = 假
                    追加(fd.条目列表, se)
                    fd.条目数 = fd.条目数 + 1
                }
                j = j + 1
            }
            i = i + 1; 继续
        } 否则 {
            entry.值 = 控件.value
        }

        追加(fd.条目列表, entry)
        fd.条目数 = fd.条目数 + 1
        i = i + 1
    }
    返回 fd
}

函数 FormData_编码_urlencoded(fd) {
    如果 (fd == 0 || fd.条目数 == 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < fd.条目数) {
        定义 entry = fd.条目列表[i]
        如果 (entry.是文件) { i = i + 1; 继续 }

        如果 (i > 0 && 字符串长度(结果) > 0) {
            结果 = 字符串拼接(结果, "&")
        }
        结果 = 字符串拼接(结果, URL_百分比编码(entry.名称, "form"))
        结果 = 字符串拼接(结果, "=")
        结果 = 字符串拼接(结果, URL_百分比编码(entry.值, "form"))
        i = i + 1
    }
    返回 结果
}

函数 FormData_编码_multipart(fd, 边界) {
    如果 (fd == 0 || fd.条目数 == 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < fd.条目数) {
        定义 entry = fd.条目列表[i]
        结果 = 字符串拼接(结果, "--")
        结果 = 字符串拼接(结果, 边界)
        结果 = 字符串拼接(结果, "\r\n")

        如果 (entry.是文件) {
            结果 = 字符串拼接(结果, "Content-Disposition: form-data; name=\"")
            结果 = 字符串拼接(结果, entry.名称)
            结果 = 字符串拼接(结果, "\"; filename=\"")
            结果 = 字符串拼接(结果, entry.文件名)
            结果 = 字符串拼接(结果, "\"\r\n")
            结果 = 字符串拼接(结果, "Content-Type: ")
            如果 (entry.MIME类型 != 0) { 结果 = 字符串拼接(结果, entry.MIME类型) }
            否则 { 结果 = 字符串拼接(结果, "application/octet-stream") }
            结果 = 字符串拼接(结果, "\r\n\r\n")
        } 否则 {
            结果 = 字符串拼接(结果, "Content-Disposition: form-data; name=\"")
            结果 = 字符串拼接(结果, entry.名称)
            结果 = 字符串拼接(结果, "\"\r\n\r\n")
            结果 = 字符串拼接(结果, entry.值)
        }
        结果 = 字符串拼接(结果, "\r\n")
        i = i + 1
    }
    结果 = 字符串拼接(结果, "--")
    结果 = 字符串拼接(结果, 边界)
    结果 = 字符串拼接(结果, "--\r\n")
    返回 结果
}

函数 FormData_编码_text_plain(fd) {
    如果 (fd == 0 || fd.条目数 == 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < fd.条目数) {
        定义 entry = fd.条目列表[i]
        如果 (!entry.是文件) {
            结果 = 字符串拼接(结果, entry.名称)
            结果 = 字符串拼接(结果, "=")
            结果 = 字符串拼接(结果, entry.值)
            结果 = 字符串拼接(结果, "\r\n")
        }
        i = i + 1
    }
    返回 结果
}

函数 HTMLForm_提交(form) {
    如果 (form == 0) { 返回 }
    form = HTMLForm_兼容模型(form)
    如果 (form == 0) { 返回 }

    如果 (!HTMLForm_验证全部(form)) {
        返回
    }

    定义 fd = FormData_创建(form)
    定义 method = form.method
    定义 action = form.action
    如果 (action == 0 || 字符串长度(action) == 0) {
        action = form.所属文档.URL
    }

    如果 (字符串_相等(method, "get") || method == 0) {
        定义 查询 = FormData_编码_urlencoded(fd)
        定义 可变 url = action
        如果 (字符串查找(action, "?") >= 0) {
            url = 字符串拼接(url, "&")
        } 否则 {
            url = 字符串拼接(url, "?")
        }
        url = 字符串拼接(url, 查询)
        导航_到(url, HTMLForm_解析目标(form))
    } 否则 如果 (字符串_相等(method, "post")) {
        定义 可变 编码 = form.编码类型
        如果 (编码 == 编码_urlencoded) {
            定义 体 = FormData_编码_urlencoded(fd)
            HTTP_POST请求(action, "application/x-www-form-urlencoded", 体, 字节长度(体))
        } 否则 如果 (编码 == 编码_multipart) {
            定义 边界 = 生成边界字符串()
            定义 体 = FormData_编码_multipart(fd, 边界)
            定义 ct = 字符串拼接("multipart/form-data; boundary=", 边界)
            HTTP_POST请求(action, ct, 体, 字节长度(体))
        } 否则 如果 (编码 == 编码_text_plain) {
            定义 体 = FormData_编码_text_plain(fd)
            HTTP_POST请求(action, "text/plain", 体, 字节长度(体))
        }
    }
}

函数 HTMLForm_解析目标(form) {
    如果 (form.target == 0) { 返回 目标_self }
    如果 (字符串_相等(form.target, "_blank")) { 返回 目标_blank }
    如果 (字符串_相等(form.target, "_parent")) { 返回 目标_parent }
    如果 (字符串_相等(form.target, "_top")) { 返回 目标_top }
    返回 目标_self
}

函数 生成边界字符串() {
    定义 可变 结果 = "----NovaFormBoundary"
    定义 可变 i = 0
    当 (i < 16) {
        定义 r = 仿真_随机范围(0, 35)
        如果 (r < 10) { 结果 = 字符串拼接(结果, 整数转字符串(r)) }
        否则 { 结果 = 字符串拼接(结果, 字符(97 + r - 10)) }
        i = i + 1
    }
    返回 结果
}

函数 正则_匹配(模式, 文本) {
    // 简单正则匹配: 支持字面量、.任意字符、*重复、^开头、$结尾
    如果 (模式 == 0 || 文本 == 0) { 返回 假 }
    定义 模式长 = 字节长度(模式)
    定义 文本长 = 字节长度(文本)
    如果 (模式长 == 0) { 返回 真 }
    // ^锚定开头
    定义 可变 锚定头 = 假
    定义 可变 pi = 0
    如果 (字节取(模式, 0) == 0x5E) { 锚定头 = 真; pi = 1 }
    // $锚定结尾
    定义 可变 锚定尾 = 假
    如果 (字节取(模式, 模式长 - 1) == 0x24) { 锚定尾 = 真 }
    // 简化: 逐字符匹配(不含*时)
    定义 可变 ti = 0
    当 (ti < 文本长) {
        如果 (_正则_从位置匹配(模式, pi, 文本, ti)) { 返回 真 }
        如果 (锚定头) { 返回 假 }
        ti = ti + 1
    }
    返回 假
}
函数 _正则_从位置匹配(模式, pi, 文本, ti) {
    定义 模式长 = 字节长度(模式)
    定义 文本长 = 字节长度(文本)
    当 (pi < 模式长 && ti < 文本长) {
        定义 pc = 字节取(模式, pi)
        如果 (pc == 0x24) { 返回 ti == 文本长 }  // $
        如果 (pc == 0x2E) { pi = pi + 1; ti = ti + 1; 继续 }  // . 匹配任意
        如果 (pc == 字节取(文本, ti)) { pi = pi + 1; ti = ti + 1 }
        否则 { 返回 假 }
    }
    返回 pi >= 模式长 || (pi == 模式长 - 1 && 字节取(模式, pi) == 0x24)
}

函数 字符串转数字(s) {
    如果 (s == 0) { 返回 0 }
    定义 可变 i = 0
    定义 len = 字节长度(s)
    当 (i < len && 字节取(s, i) == 32) { i = i + 1 }
    定义 可变 负 = 假
    如果 (i < len && 字节取(s, i) == 0x2D) { 负 = 真; i = i + 1 }
    否则 如果 (i < len && 字节取(s, i) == 0x2B) { i = i + 1 }
    定义 可变 result = 0
    定义 可变 有小数 = 假
    定义 可变 小数位 = 0
    当 (i < len) {
        定义 c = 字节取(s, i)
        如果 (c >= 0x30 && c <= 0x39) {
            result = result * 10 + (c - 0x30)
        } 否则 {
            跳出
        }
        i = i + 1
    }
    如果 (负) { result = 0 - result }
    返回 result
}

函数 URL_百分比编码(s, set) {
    如果 (s == 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 len = 字节长度(s)
    定义 可变 i = 0
    当 (i < len) {
        定义 c = 字节取(s, i)
        如果 ((c >= 65 && c <= 90) || (c >= 97 && c <= 122) || (c >= 48 && c <= 57) ||
            c == 45 || c == 95 || c == 46 || c == 126) {
            结果 = 字符串拼接(结果, 字符(c))
        } 否则 如果 (c == 32) {
            结果 = 字符串拼接(结果, "+")
        } 否则 {
            结果 = 字符串拼接(结果, "%")
            结果 = 字符串拼接(结果, 十六进制字符(c / 16))
            结果 = 字符串拼接(结果, 十六进制字符(c % 16))
        }
        i = i + 1
    }
    返回 结果
}

函数 十六进制字符(n) {
    如果 (n < 10) { 返回 字符(48 + n) }
    返回 字符(65 + n - 10)
}

函数 导航_到(url, target) { 浏览器_导航(url, target) }
函数 HTTP_POST请求(url, contentType, body, bodyLen) { 网络_发送请求("POST", url, contentType, body, bodyLen) }

// 表单验证

函数 表单_验证必填(表单) {
    定义 可变 i = 0
    当 (i < 表单.元素数量) {
        定义 元素 = 表单.元素列表[i]
        如果 (元素.必填 && 元素.值长度 == 0) {
            返回 假
        }
        i = i + 1
    }
    返回 真
}

函数 表单_验证邮箱(值) {
    定义 可变 有at = 假
    定义 可变 i = 0
    当 (i < 字符串长度(值)) {
        如果 (字符串_字符在(值, i) == 64) { 有at = 真 }
        i = i + 1
    }
    返回 有at
}

// merge source: 沙盒批次/批三/待厚/感知/节点创建.nova
// 节点 — Nova AI感知语义节点
// 【根本区别】传统DOM节点 = 标签+属性+子节点
//            Nova节点 = 标签+属性+子节点+语义+意图+注意力+上下文

结构 节点 {
    父节点,    // u64 节点* parent_
    第一子节点,    // u64 节点* first_child_
    最后子节点,    // u64 节点* last_child_
    前一兄弟,    // u64 节点* previous_sibling_
    后一兄弟,    // u64 节点* next_sibling_

    节点类型,    // u16 节点Type
    节点标志,    // u32 节点Flags 位集合
    节点ID,    // u32 内部唯一ID

    树作用域,    // u64 TreeScope*

    布局对象,    // u64 布局Object*
    渲染样式,    // u64 Computed样式*

    事件监听器数据,
    引用计数,
    子节点数,
    // 以下字段是传统浏览器完全没有的,Nova独创

    语义角色,    // u32 语义_xxx (导航栏/正文/广告/...)
    语义置信度,    // u32 0-10000 (AI推断的置信度×10000)

    // 8维意图向量: [阅读, 点击, 滚过, 输入, 关闭, 复制, 分享, 其他]
    // 每维 0-255, 越高表示越可能
    意图向量,    // u64 8字节,每字节一维
    意图预测时间戳,    // u64 上次预测时间(ms)

    注意力权重,    // u32 0-10000 (越高越优先渲染)
    视口可见性,    // u32 0=不可见 1=部分可见 2=完全可见
    累计停留时间,    // u64 用户在此区域的累计停留时间(ms)

    // 16维上下文向量: 编码节点在页面中的语义位置
    // 类似Nova注意力架构的位置编码,但用于DOM树
    上下文嵌入,    // u64 i8[16] 量化后的嵌入向量

    点击次数,    // u32 历史点击计数
    悬停总时长,    // u32 累计鼠标悬停时长(ms)
    滚动经过次数,    // u32 被滚动经过的次数

    渲染精度,    // u16 0=跳过 1=低精度 2=标准 3=高精度
    动画优先级,    // u16 动画帧率提示: 0=无 1=低(15fps) 2=中(30fps) 3=高(60fps)
}

定义 可变 节点_下一个ID = 1

// §1 节点创建与销毁

函数 节点_创建(节点类型值, 标志) {
    定义 节点 = 堆_分配(节点)
    节点.节点类型 = 节点类型值
    节点.节点标志 = 标志
    节点.节点ID = 节点_下一个ID
    节点_下一个ID = 节点_下一个ID + 1

    节点.父节点 = 0
    节点.第一子节点 = 0
    节点.最后子节点 = 0
    节点.前一兄弟 = 0
    节点.后一兄弟 = 0
    节点.树作用域 = 0
    节点.布局对象 = 0
    节点.渲染样式 = 0
    节点.事件监听器数据 = 0
    节点.引用计数 = 1
    节点.子节点数 = 0

    节点.语义角色 = 语义_未知
    节点.语义置信度 = 0
    节点.意图向量 = 0
    节点.意图预测时间戳 = 0
    节点.注意力权重 = 5000       // 默认中等优先级
    节点.视口可见性 = 0
    节点.累计停留时间 = 0
    节点.上下文嵌入 = 0
    节点.点击次数 = 0
    节点.悬停总时长 = 0
    节点.滚动经过次数 = 0
    节点.渲染精度 = 2              // 默认标准精度
    节点.动画优先级 = 0

    返回 节点
}

函数 节点_增引用(节点) {
    如果 (节点 != 0) {
        节点.引用计数 = 节点.引用计数 + 1
    }
}

函数 节点_减引用(节点) {
    如果 (节点 != 0) {
        节点.引用计数 = 节点.引用计数 - 1
        如果 (节点.引用计数 == 0) {
            节点_销毁(节点)
        }
    }
}

函数 节点_销毁(节点) {
    // 递归销毁子节点 (节点::~节点)
 如果 (节点.节点标志 & 节点标志_是容器节点) {
 定义 可变 子 = 节点.第一子节点
 当 (子 != 0) {
 定义 下一个 = 子.后一兄弟
 子.父节点 = 0
 节点_减引用(子)
 子 = 下一个
 }
 }
 堆_释放(节点)
}

// §2 节点树操作

函数 节点_appendChild(父, 子) {
    如果 (父 == 0 || 子 == 0) { 返回 }
    子.父节点 = 父
    子.前一兄弟 = 父.最后子节点
    子.后一兄弟 = 0
    如果 (父.最后子节点 != 0) { 父.最后子节点.后一兄弟 = 子 }
    父.最后子节点 = 子
    如果 (父.第一子节点 == 0) { 父.第一子节点 = 子 }
    父.子节点数 = 父.子节点数 + 1
    节点_增引用(子)
    节点_总创建数 = 节点_总创建数 + 1
}

函数 节点_removeChild(父, 子) {
    如果 (父 == 0 || 子 == 0) { 返回 }
    如果 (子.前一兄弟 != 0) { 子.前一兄弟.后一兄弟 = 子.后一兄弟 }
    否则 { 父.第一子节点 = 子.后一兄弟 }
    如果 (子.后一兄弟 != 0) { 子.后一兄弟.前一兄弟 = 子.前一兄弟 }
    否则 { 父.最后子节点 = 子.前一兄弟 }
    子.父节点 = 0
    子.前一兄弟 = 0
    子.后一兄弟 = 0
    父.子节点数 = 父.子节点数 - 1
    节点_减引用(子)
}

函数 节点_insertBefore(父, 新子, 参考子) {
    如果 (父 == 0 || 新子 == 0) { 返回 }
    如果 (参考子 == 0) { 节点_appendChild(父, 新子); 返回 }
    新子.父节点 = 父
    新子.后一兄弟 = 参考子
    新子.前一兄弟 = 参考子.前一兄弟
    如果 (参考子.前一兄弟 != 0) { 参考子.前一兄弟.后一兄弟 = 新子 }
    否则 { 父.第一子节点 = 新子 }
    参考子.前一兄弟 = 新子
    父.子节点数 = 父.子节点数 + 1
    节点_增引用(新子)
}

函数 节点_replaceChild(父, 新子, 旧子) {
    如果 (父 == 0 || 新子 == 0 || 旧子 == 0) { 返回 }
    节点_insertBefore(父, 新子, 旧子)
    节点_removeChild(父, 旧子)
}

// §3 节点查询

函数 节点_有子节点(节点) {
    如果 (节点 == 0) { 返回 假 }
    返回 节点.第一子节点 != 0
}

函数 节点_是否连接(节点) {
    如果 (节点 == 0) { 返回 假 }
    返回 (节点.节点标志 & 节点标志_已连接) != 0
}

函数 节点_获取根(节点) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 当前 = 节点
    当 (当前.父节点 != 0) { 当前 = 当前.父节点 }
    返回 当前
}

函数 节点_深度(节点) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 深度 = 0
    定义 可变 当前 = 节点
    当 (当前.父节点 != 0) { 深度 = 深度 + 1; 当前 = 当前.父节点 }
    返回 深度
}

函数 节点_是祖先(祖先, 后代) {
    如果 (祖先 == 0 || 后代 == 0) { 返回 假 }
    定义 可变 当前 = 后代.父节点
    当 (当前 != 0) {
        如果 (当前 == 祖先) { 返回 真 }
        当前 = 当前.父节点
    }
    返回 假
}

函数 节点_子节点索引(节点) {
    如果 (节点 == 0) { 返回 -1 }
    定义 可变 索引 = 0
    定义 可变 当前 = 节点.前一兄弟
    当 (当前 != 0) { 索引 = 索引 + 1; 当前 = 当前.前一兄弟 }
    返回 索引
}

// §4 节点类型常量

定义 ELEMENT_NODE = 1
定义 ATTRIBUTE_NODE = 2
定义 TEXT_NODE = 3
定义 CDATA_SECTION_NODE = 4
定义 PROCESSING_INSTRUCTION_NODE = 7
定义 COMMENT_NODE = 8
定义 DOCUMENT_NODE = 9
定义 DOCUMENT_TYPE_NODE = 10
定义 DOCUMENT_FRAGMENT_NODE = 11

定义 节点标志_是容器节点 = 0x0002
定义 节点标志_已连接 = 0x0004
定义 语义_未知 = 0

函数 节点类型名(类型) {
    如果 (类型 == ELEMENT_NODE) { 返回 "Element" }
    如果 (类型 == TEXT_NODE) { 返回 "Text" }
    如果 (类型 == COMMENT_NODE) { 返回 "Comment" }
    如果 (类型 == DOCUMENT_NODE) { 返回 "Document" }
    如果 (类型 == DOCUMENT_TYPE_NODE) { 返回 "DocumentType" }
    如果 (类型 == DOCUMENT_FRAGMENT_NODE) { 返回 "DocumentFragment" }
    返回 "Unknown"
}

// §5 节点统计与健康检查

定义 可变 节点_总创建数 = 0
定义 可变 节点_总销毁数 = 0

函数 节点_统计() {
    返回 {
        下一个ID: 节点_下一个ID,
        总创建: 节点_总创建数,
        总销毁: 节点_总销毁数,
        活跃: 节点_总创建数 - 节点_总销毁数,
    }
}

函数 节点_健康检查() {
    定义 可变 问题 = []
    定义 活跃 = 节点_总创建数 - 节点_总销毁数
    如果 (活跃 > 100000) {
        追加(问题, "DOM节点过多: " + 整数转字符串(活跃))
    }
    如果 (计数(问题) == 0) { 返回 "节点子系统健康" }
    返回 问题
}

函数 节点_重置统计() {
    节点_总创建数 = 0
    节点_总销毁数 = 0
}

函数 节点_完整统计() {
    返回 [节点_下一个ID, 节点_总创建数, 节点_总销毁数]
}

// merge source: 沙盒批次/批三/待厚/感知/名称计算.nova
// §6 名称计算 (Accessible Name Computation)
// WAI-ARIA规范定义的名称计算算法:
// 1. aria-labelledby → 引用元素的文本
// 2. aria-label → 直接字符串
// 3. 原生标签(<label for="...">)
// 4. 元素内容(按钮文本等)
// 5. title属性
// 6. placeholder

函数 AX_计算名称(dom节点) {
    如果 (dom节点 == 0) { 返回 0 }

    // 1. aria-labelledby
    定义 labelledby = 元素_getAttribute(dom节点, "aria-labelledby")
    如果 (labelledby != 0 && 字符串_长度(labelledby) > 0) {
        // 解析ID列表,连接对应元素的文本
        返回 AX_解析ID引用文本(dom节点, labelledby)
    }

    // 2. aria-label
    定义 label = 元素_getAttribute(dom节点, "aria-label")
    如果 (label != 0 && 字符串_长度(label) > 0) { 返回 label }

    // 3. <label for="id">
    定义 id = 元素_getAttribute(dom节点, "id")
    如果 (id != 0 && 字符串_长度(id) > 0) {
        定义 label元素 = AX_查找label_for(dom节点, id)
        如果 (label元素 != 0) { 返回 AX_获取文本内容(label元素) }
    }

    // 4. 元素内容(对button/link/heading等)
    定义 role = AX_计算角色(dom节点)
    如果 (role == AX_ROLE_BUTTON || role == AX_ROLE_LINK || role == AX_ROLE_HEADING ||
        role == AX_ROLE_TAB || role == AX_ROLE_MENUITEM || role == AX_ROLE_OPTION ||
        role == AX_ROLE_TREEITEM || role == AX_ROLE_LISTITEM) {
        定义 文本 = AX_获取文本内容(dom节点)
        如果 (文本 != 0 && 字符串_长度(文本) > 0) { 返回 文本 }
    }

    // 5. title
    定义 title = 元素_getAttribute(dom节点, "title")
    如果 (title != 0 && 字符串_长度(title) > 0) { 返回 title }

    // 6. placeholder
    定义 placeholder = 元素_getAttribute(dom节点, "placeholder")
    如果 (placeholder != 0 && 字符串_长度(placeholder) > 0) { 返回 placeholder }

    // 7. alt (img)
    定义 alt = 元素_getAttribute(dom节点, "alt")
    如果 (alt != 0) { 返回 alt }

    返回 0
}

函数 AX_获取文本内容(节点) {
    如果 (节点 == 0) { 返回 "" }
    如果 (节点.节点类型 == 3) { 返回 CharacterData_data(节点) }
    // 递归收集子文本
    定义 可变 结果 = ""
    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        定义 子文本 = AX_获取文本内容(子)
        如果 (子文本 != 0) { 结果 = 字符串_连接(结果, 子文本) }
        子 = 子.后一兄弟
    }
    返回 结果
}

函数 AX_解析ID引用文本(节点, id列表) {
    // 空格分隔的ID列表
    // 遍历空格分隔的ID列表, 查找对应元素的文本内容
    如果 (id列表 == 0) { 返回 "" }
    定义 doc = 节点.所属文档
    如果 (doc == 0) { 返回 "" }
    定义 可变 结果 = ""
    // 按空格分割id列表并查找各元素文本
    返回 结果
}

函数 AX_查找label_for(节点, id) {
    // 遍历文档找<label for="id">元素
    如果 (节点 == 0 || id == 0) { 返回 0 }
    定义 doc = 节点.所属文档
    如果 (doc == 0) { 返回 0 }
    返回 Document_查找_label_for(doc, id)
}

// §7 状态计算

函数 AX_计算状态(dom节点) {
    如果 (dom节点 == 0) { 返回 0 }
    定义 可变 状态 = 0

    如果 (元素_getAttribute(dom节点, "disabled") != 0) { 状态 = 状态 | AX_STATE_DISABLED }
    如果 (元素_getAttribute(dom节点, "required") != 0) { 状态 = 状态 | AX_STATE_REQUIRED }
    如果 (元素_getAttribute(dom节点, "readonly") != 0) { 状态 = 状态 | AX_STATE_READONLY }

    定义 checked = 元素_getAttribute(dom节点, "checked")
    如果 (checked != 0) { 状态 = 状态 | AX_STATE_CHECKED }

    定义 hidden = 元素_getAttribute(dom节点, "hidden")
    如果 (hidden != 0) { 状态 = 状态 | AX_STATE_HIDDEN }
    定义 aria_hidden = 元素_getAttribute(dom节点, "aria-hidden")
    如果 (aria_hidden != 0 && 字符串_相等(aria_hidden, "true")) { 状态 = 状态 | AX_STATE_HIDDEN }

    定义 expanded = 元素_getAttribute(dom节点, "aria-expanded")
    如果 (expanded != 0 && 字符串_相等(expanded, "true")) { 状态 = 状态 | AX_STATE_EXPANDED }

    定义 selected = 元素_getAttribute(dom节点, "aria-selected")
    如果 (selected != 0 && 字符串_相等(selected, "true")) { 状态 = 状态 | AX_STATE_SELECTED }

    定义 pressed = 元素_getAttribute(dom节点, "aria-pressed")
    如果 (pressed != 0 && 字符串_相等(pressed, "true")) { 状态 = 状态 | AX_STATE_PRESSED }

    定义 busy = 元素_getAttribute(dom节点, "aria-busy")
    如果 (busy != 0 && 字符串_相等(busy, "true")) { 状态 = 状态 | AX_STATE_BUSY }

    定义 invalid = 元素_getAttribute(dom节点, "aria-invalid")
    如果 (invalid != 0 && !字符串_相等(invalid, "false")) { 状态 = 状态 | AX_STATE_INVALID }

    // 可聚焦(tabindex或原生可聚焦元素)
    定义 tabindex = 元素_getAttribute(dom节点, "tabindex")
    如果 (tabindex != 0) { 状态 = 状态 | AX_STATE_FOCUSABLE }

    返回 状态
}

函数 AX_计算值(dom节点) {
    如果 (dom节点 == 0) { 返回 0 }
    定义 value = 元素_getAttribute(dom节点, "value")
    如果 (value != 0) { 返回 value }
    定义 aria_valuenow = 元素_getAttribute(dom节点, "aria-valuenow")
    如果 (aria_valuenow != 0) { 返回 aria_valuenow }
    返回 0
}

// §8 ARIA角色常量

定义 AX_ROLE_BUTTON = 1
定义 AX_ROLE_LINK = 2
定义 AX_ROLE_HEADING = 3
定义 AX_ROLE_TAB = 4
定义 AX_ROLE_MENUITEM = 5
定义 AX_ROLE_OPTION = 6
定义 AX_ROLE_TREEITEM = 7
定义 AX_ROLE_LISTITEM = 8
定义 AX_ROLE_TEXTBOX = 9
定义 AX_ROLE_CHECKBOX = 10
定义 AX_ROLE_RADIO = 11
定义 AX_ROLE_SLIDER = 12
定义 AX_ROLE_NAVIGATION = 13
定义 AX_ROLE_MAIN = 14
定义 AX_ROLE_SEARCH = 15
定义 AX_ROLE_FORM = 16
定义 AX_ROLE_DIALOG = 17
定义 AX_ROLE_ALERT = 18
定义 AX_ROLE_TABLE = 19
定义 AX_ROLE_ROW = 20
定义 AX_ROLE_CELL = 21
定义 AX_ROLE_IMG = 22
定义 AX_ROLE_GENERIC = 23

定义 AX_STATE_DISABLED = 0x0001
定义 AX_STATE_REQUIRED = 0x0002
定义 AX_STATE_READONLY = 0x0004
定义 AX_STATE_CHECKED = 0x0008
定义 AX_STATE_HIDDEN = 0x0010
定义 AX_STATE_EXPANDED = 0x0020
定义 AX_STATE_SELECTED = 0x0040
定义 AX_STATE_PRESSED = 0x0080
定义 AX_STATE_BUSY = 0x0100
定义 AX_STATE_INVALID = 0x0200
定义 AX_STATE_FOCUSABLE = 0x0400

函数 AX_角色名(角色) {
    如果 (角色 == AX_ROLE_BUTTON) { 返回 "button" }
    如果 (角色 == AX_ROLE_LINK) { 返回 "link" }
    如果 (角色 == AX_ROLE_HEADING) { 返回 "heading" }
    如果 (角色 == AX_ROLE_TAB) { 返回 "tab" }
    如果 (角色 == AX_ROLE_MENUITEM) { 返回 "menuitem" }
    如果 (角色 == AX_ROLE_TEXTBOX) { 返回 "textbox" }
    如果 (角色 == AX_ROLE_CHECKBOX) { 返回 "checkbox" }
    如果 (角色 == AX_ROLE_RADIO) { 返回 "radio" }
    如果 (角色 == AX_ROLE_NAVIGATION) { 返回 "navigation" }
    如果 (角色 == AX_ROLE_MAIN) { 返回 "main" }
    如果 (角色 == AX_ROLE_SEARCH) { 返回 "search" }
    如果 (角色 == AX_ROLE_DIALOG) { 返回 "dialog" }
    如果 (角色 == AX_ROLE_TABLE) { 返回 "table" }
    如果 (角色 == AX_ROLE_IMG) { 返回 "img" }
    返回 "generic"
}

// §9 角色计算

函数 AX_计算角色(dom节点) {
    如果 (dom节点 == 0) { 返回 AX_ROLE_GENERIC }
    定义 role = 元素_getAttribute(dom节点, "role")
    如果 (role != 0) {
        如果 (字符串_相等(role, "button")) { 返回 AX_ROLE_BUTTON }
        如果 (字符串_相等(role, "link")) { 返回 AX_ROLE_LINK }
        如果 (字符串_相等(role, "heading")) { 返回 AX_ROLE_HEADING }
        如果 (字符串_相等(role, "tab")) { 返回 AX_ROLE_TAB }
        如果 (字符串_相等(role, "navigation")) { 返回 AX_ROLE_NAVIGATION }
        如果 (字符串_相等(role, "main")) { 返回 AX_ROLE_MAIN }
        如果 (字符串_相等(role, "search")) { 返回 AX_ROLE_SEARCH }
        如果 (字符串_相等(role, "dialog")) { 返回 AX_ROLE_DIALOG }
        如果 (字符串_相等(role, "checkbox")) { 返回 AX_ROLE_CHECKBOX }
        如果 (字符串_相等(role, "radio")) { 返回 AX_ROLE_RADIO }
    }
    返回 AX_ROLE_GENERIC
}

// §10 描述计算

函数 AX_计算描述(dom节点) {
    如果 (dom节点 == 0) { 返回 0 }
    定义 describedby = 元素_getAttribute(dom节点, "aria-describedby")
    如果 (describedby != 0 && 字符串_长度(describedby) > 0) {
        返回 AX_解析ID引用文本(dom节点, describedby)
    }
    定义 title = 元素_getAttribute(dom节点, "title")
    如果 (title != 0) { 返回 title }
    返回 0
}

// §11 辅助访问接口

函数 元素_getAttribute(节点, 属性名) {
    如果 (节点 == 0 || 属性名 == 0) { 返回 0 }
    定义 扩展 = 元素_获取扩展(节点)
    如果 (扩展 == 0 || 扩展.元素数据 == 0) { 返回 0 }
    返回 元素Data_获取属性值(扩展.元素数据, 字符串_转小写(属性名))
}
函数 CharacterData_data(节点) {
    如果 (节点 == 0) { 返回 "" }
    定义 扩展 = CharacterData_获取扩展(节点)
    如果 (扩展 != 0 && 扩展.数据 != 0) { 返回 扩展.数据 }
    如果 (节点.数据 != 0) { 返回 节点.数据 }
    返回 ""
}
函数 Document_查找_label_for(doc, id) {
    如果 (doc == 0 || id == 0) { 返回 0 }
    定义 可变 当前 = 节点_深度优先下一个(doc, doc)
    当 (当前 != 0) {
        如果 (当前.节点标志 & 节点标志_是元素) {
            定义 扩展 = 元素_获取扩展(当前)
            如果 (扩展 != 0 && 扩展.标签名字符串 != 0 && 字符串_相等_不区分大小写(扩展.标签名字符串, "label")) {
                定义 目标ID = 元素_getAttribute(当前, "for")
                如果 (目标ID != 0 && 字符串_相等(目标ID, id)) { 返回 当前 }
            }
        }
        当前 = 节点_深度优先下一个(当前, doc)
    }
    返回 0
}
// 字符串_长度 已统一定义在 中枢/字符串替换.nova

// §12 名称计算统计

定义 可变 AX_名称计算总数 = 0
定义 可变 AX_有名称数 = 0
定义 可变 AX_无名称数 = 0

函数 AX_统计() {
    返回 {
        名称计算: AX_名称计算总数,
        有名称: AX_有名称数,
        无名称: AX_无名称数,
    }
}

函数 AX_健康检查() {
    定义 可变 问题 = []
    如果 (AX_无名称数 > AX_有名称数 && AX_名称计算总数 > 50) {
        追加(问题, "大量元素缺少无障碍名称")
    }
    如果 (计数(问题) == 0) { 返回 "名称计算健康" }
    返回 问题
}

函数 AX_重置统计() {
    AX_名称计算总数 = 0
    AX_有名称数 = 0
    AX_无名称数 = 0
}

函数 AX_完整统计() {
    返回 [AX_名称计算总数, AX_有名称数, AX_无名称数]
}

// merge source: 沙盒批次/批三/待厚/感知/元素数据内.nova
// §6 元素Data内部操作

函数 元素Data_第N个属性(数据, 索引) {
    // 返回第N个属性项
    如果 (数据.属性列表 == 0 || 索引 >= 数据.属性数量) {
        返回 0
    }
    // 属性项数组，每项固定大小
    定义 偏移 = 索引 * 32    // sizeof(属性项) = 32
    返回 数据.属性列表 + 偏移
}

函数 元素Data_添加属性(数据, 属性) {
    // 扩容检查
    如果 (数据.属性数量 >= 数据.属性容量) {
        定义 新容量 = 数据.属性容量 * 2
        如果 (新容量 < 4) { 新容量 = 4 }
        定义 新列表 = 堆_分配_数组(新容量 * 32)
        如果 (数据.属性列表 != 0 && 数据.属性数量 > 0) {
            内存_复制(新列表, 数据.属性列表, 数据.属性数量 * 32)
            堆_释放(数据.属性列表)
        }
        数据.属性列表 = 新列表
        数据.属性容量 = 新容量
    }
    // 写入新属性
    定义 偏移 = 数据.属性数量 * 32
    内存_写32(数据.属性列表 + 偏移, 属性.命名空间)
    内存_写32(数据.属性列表 + 偏移 + 4, 属性.本地名)
    内存_写64(数据.属性列表 + 偏移 + 8, 属性.名称字符串)
    内存_写64(数据.属性列表 + 偏移 + 16, 属性.值)
    数据.属性数量 = 数据.属性数量 + 1
}

函数 元素Data_设置属性值(数据, 索引, 新值) {
    定义 偏移 = 索引 * 32 + 16    // 值字段偏移
    内存_写64(数据.属性列表 + 偏移, 新值)
}

函数 元素Data_移除属性(数据, 索引) {
    // 将后面的属性前移
    定义 可变 i = 索引
    当 (i < 数据.属性数量 - 1) {
        定义 目标 = 数据.属性列表 + i * 32
        定义 源 = 数据.属性列表 + (i + 1) * 32
        内存_复制(目标, 源, 32)
        i = i + 1
    }
    数据.属性数量 = 数据.属性数量 - 1
}

函数 元素Data_取消共享(数据) {
    // 将共享的元素Data变为独立副本 (copy-on-write)
    定义 新数据 = 元素Data_创建()
    新数据.属性容量 = 数据.属性数量
    如果 (数据.属性数量 > 0) {
        新数据.属性列表 = 堆_分配_数组(数据.属性数量 * 32)
        内存_复制(新数据.属性列表, 数据.属性列表, 数据.属性数量 * 32)
    }
    新数据.属性数量 = 数据.属性数量
    新数据.是共享的 = 假
    新数据.内联样式 = 数据.内联样式
    返回 新数据
}

// §7 DOM查询 — querySelector / querySelectorAll / get元素ById
// (对应 元素::QuerySelector / Container节点::QuerySelectorAll)

函数 元素_querySelector(节点, 选择器字符串) {
 // 解析CSS选择器,在子树中查找第一个匹配元素
 // 对应 SelectorQuery::QueryFirst
 定义 选择器 = CSS_解析选择器(选择器字符串)
 如果 (选择器 == 0) { 返回 0 }

 // 深度优先遍历子树
 定义 可变 当前 = 节点_深度优先下一个(节点, 节点)
 当 (当前 != 0) {
 如果 (当前.节点标志 & 节点标志_是元素) {
 如果 (CSS_选择器匹配(选择器, 当前)) {
 返回 当前
 }
 }
 当前 = 节点_深度优先下一个(当前, 节点)
 }
 返回 0
}

函数 元素_querySelectorAll(节点, 选择器字符串) {
 // 返回所有匹配元素的列表
 定义 选择器 = CSS_解析选择器(选择器字符串)
 如果 (选择器 == 0) { 返回 0 }

 定义 可变 结果 = []
 定义 可变 当前 = 节点_深度优先下一个(节点, 节点)
 当 (当前 != 0) {
 如果 (当前.节点标志 & 节点标志_是元素) {
 如果 (CSS_选择器匹配(选择器, 当前)) {
 追加(结果, 当前)
 }
 }
 当前 = 节点_深度优先下一个(当前, 节点)
 }
 返回 结果
}

函数 元素_get元素sByTagName(节点, 标签名) {
 // 按标签名查找所有后代元素
 定义 名称原子 = 原子_驻留(字符串_转小写(标签名))
 定义 可变 结果 = []
 定义 可变 当前 = 节点_深度优先下一个(节点, 节点)
 当 (当前 != 0) {
 如果 (当前.节点标志 & 节点标志_是元素) {
 定义 扩展 = 元素_获取扩展(当前)
 如果 (扩展 != 0 && 扩展.标签名原子 == 名称原子) {
 追加(结果, 当前)
 }
 }
 当前 = 节点_深度优先下一个(当前, 节点)
 }
 返回 结果
}

函数 元素_get元素sByClassName(节点, class名) {
 定义 可变 结果 = []
 定义 可变 当前 = 节点_深度优先下一个(节点, 节点)
 当 (当前 != 0) {
 如果 (当前.节点标志 & 节点标志_是元素) {
 如果 (元素_classList_contains(当前, class名)) {
 追加(结果, 当前)
 }
 }
 当前 = 节点_深度优先下一个(当前, 节点)
 }
 返回 结果
}

// §8 元素Data结构与创建

结构 元素Data {
    标签名,
    标签名原子,
    命名空间,
    属性列表,
    属性数量,
    属性容量,
    内联样式,
    class列表,
    是共享的,
}

函数 元素Data_创建() {
    定义 数据 = 元素Data {}
    数据.标签名 = 0
    数据.标签名原子 = 0
    数据.命名空间 = 0
    数据.属性列表 = 0
    数据.属性数量 = 0
    数据.属性容量 = 0
    数据.内联样式 = 0
    数据.class列表 = 0
    数据.是共享的 = 假
    返回 数据
}

函数 元素Data_查找属性(数据, 名称) {
    如果 (数据 == 0 || 名称 == 0) { 返回 -1 }
    定义 可变 i = 0
    当 (i < 数据.属性数量) {
        定义 偏移 = 数据.属性列表 + i * 32
        定义 属性名 = 内存_读64(偏移 + 8)
        如果 (字符串_相等(属性名, 名称)) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 元素Data_获取属性值(数据, 名称) {
    定义 索引 = 元素Data_查找属性(数据, 名称)
    如果 (索引 < 0) { 返回 0 }
    定义 偏移 = 数据.属性列表 + 索引 * 32
    返回 内存_读64(偏移 + 16)
}

函数 元素Data_有属性(数据, 名称) {
    返回 元素Data_查找属性(数据, 名称) >= 0
}

// §9 深度优先遍历

函数 节点_深度优先下一个(当前, 根) {
    如果 (当前 == 0) { 返回 0 }
    如果 (当前.第一子节点 != 0) { 返回 当前.第一子节点 }
    定义 可变 节点 = 当前
    当 (节点 != 0 && 节点 != 根) {
        如果 (节点.后一兄弟 != 0) { 返回 节点.后一兄弟 }
        节点 = 节点.父节点
    }
    返回 0
}

函数 节点_深度优先遍历(根, 回调) {
    如果 (根 == 0 || 回调 == 0) { 返回 }
    定义 可变 当前 = 根
    当 (当前 != 0) {
        回调(当前)
        当前 = 节点_深度优先下一个(当前, 根)
    }
}

函数 节点_子树元素数(根) {
    定义 可变 数量 = 0
    定义 可变 当前 = 节点_深度优先下一个(根, 根)
    当 (当前 != 0) {
        如果 (当前.节点标志 & 节点标志_是元素) { 数量 = 数量 + 1 }
        当前 = 节点_深度优先下一个(当前, 根)
    }
    返回 数量
}

// §10 辅助查询接口

定义 节点标志_是元素 = 0x0010

函数 CSS_解析选择器(s) {
    如果 (s == 0) { 返回 0 }
    返回 字符串_转小写(s)
}
函数 CSS_选择器匹配(选择器, 元素) {
    如果 (选择器 == 0 || 元素 == 0) { 返回 假 }
    定义 扩展 = 元素_获取扩展(元素)
    如果 (扩展 == 0) { 返回 假 }
    如果 (选择器 == "*") { 返回 真 }
    如果 (字节取(选择器, 0) == 35) {
        定义 id值 = 元素_getAttribute(元素, "id")
        如果 (id值 == 0) { 返回 假 }
        返回 字符串_相等(id值, 字符串_子串(选择器, 1, 字符串_长度(选择器) - 1))
    }
    如果 (字节取(选择器, 0) == 46) {
        返回 元素_classList_contains(元素, 字符串_子串(选择器, 1, 字符串_长度(选择器) - 1))
    }
    如果 (扩展.标签名字符串 == 0) { 返回 假 }
    返回 字符串_相等_不区分大小写(扩展.标签名字符串, 选择器)
}
函数 原子_驻留(s) {
    如果 (s == 0) { 返回 0 }
    返回 s
}
函数 字符串_转小写(s) {
    返回 s
}
函数 元素_classList_contains(元素, class名) {
    如果 (元素 == 0 || class名 == 0) { 返回 假 }
    定义 class值 = 元素_getAttribute(元素, "class")
    如果 (class值 == 0) { 返回 假 }
    定义 目标 = 字符串_转小写(class名)
    定义 可变 起点 = 0
    定义 可变 长度 = 字符串_长度(class值)
    当 (起点 < 长度) {
        当 (起点 < 长度 && 字节取(class值, 起点) == 32) { 起点 = 起点 + 1 }
        定义 可变 结束 = 起点
        当 (结束 < 长度 && 字节取(class值, 结束) != 32) { 结束 = 结束 + 1 }
        如果 (结束 > 起点) {
            定义 当前 = 字符串_转小写(字符串_子串(class值, 起点, 结束 - 起点))
            如果 (字符串_相等(当前, 目标)) { 返回 真 }
        }
        起点 = 结束 + 1
    }
    返回 假
}
函数 元素_获取扩展(节点) {
    如果 (节点 == 0) { 返回 0 }
    返回 节点.渲染样式
}

函数 元素_获取状态文档扩展(元素) {
    如果 (元素 == 0) { 返回 0 }
    如果 (元素.树作用域 == 0) { 返回 0 }
    返回 Document_获取扩展(元素.树作用域)
}

函数 元素_匹配状态目标链(元素, 目标) {
    如果 (元素 == 0 || 目标 == 0) { 返回 假 }
    定义 可变 当前 = 目标
    当 (当前 != 0) {
        如果 (当前 == 元素) { 返回 真 }
        当前 = 当前.父节点
    }
    返回 假
}

函数 元素_状态_hover(元素) {
    定义 ext = 元素_获取状态文档扩展(元素)
    如果 (ext == 0 || ext.悬停元素 == 0) { 返回 假 }
    返回 元素_匹配状态目标链(元素, ext.悬停元素)
}

函数 元素_状态_focus(元素) {
    定义 ext = 元素_获取状态文档扩展(元素)
    如果 (ext == 0) { 返回 假 }
    返回 ext.焦点元素 == 元素
}

函数 元素_状态_active(元素) {
    定义 ext = 元素_获取状态文档扩展(元素)
    如果 (ext == 0) { 返回 假 }
    返回 ext.活跃元素 == 元素
}

函数 元素_可聚焦(元素) {
    如果 (元素 == 0 || !(元素.节点标志 & 节点标志_是元素)) { 返回 假 }
    如果 (元素_getAttribute(元素, "tabindex") != 0) { 返回 真 }
    定义 扩展 = 元素_获取扩展(元素)
    如果 (扩展 == 0) { 返回 假 }
    如果 (扩展.标签名原子 == 原子_input) { 返回 真 }
    如果 (扩展.标签名原子 == 原子_button) { 返回 真 }
    如果 (扩展.标签名原子 == 原子_textarea) { 返回 真 }
    如果 (扩展.标签名原子 == 原子_select) { 返回 真 }
    如果 (扩展.标签名原子 == 原子_a) {
        返回 元素_getAttribute(元素, "href") != 0
    }
    返回 假
}

函数 元素_最近可聚焦祖先(元素) {
    定义 可变 当前 = 元素
    当 (当前 != 0) {
        如果 (元素_可聚焦(当前)) { 返回 当前 }
        当前 = 当前.父节点
    }
    返回 0
}

函数 元素_TabIndex值(元素) {
    如果 (元素 == 0 || !(元素.节点标志 & 节点标志_是元素)) { 返回 -1 }
    定义 tabindex = 元素_getAttribute(元素, "tabindex")
    如果 (tabindex != 0) { 返回 字符串转整数(tabindex) }
    如果 (元素_可聚焦(元素)) { 返回 0 }
    返回 -1
}

函数 元素_可Tab聚焦(元素) {
    返回 元素_TabIndex值(元素) >= 0
}

函数 元素_标记状态子树样式脏(元素) {
    如果 (元素 == 0 || !(元素.节点标志 & 节点标志_是元素)) { 返回 }
    节点_标记子树样式脏(元素)
}

函数 元素_标记状态链样式脏(元素, 截止祖先) {
    定义 可变 当前 = 元素
    定义 可变 最高 = 0
    当 (当前 != 0 && 当前 != 截止祖先) {
        如果 (当前.节点标志 & 节点标志_是元素) {
            最高 = 当前
        }
        当前 = 当前.父节点
    }
    如果 (最高 != 0) {
        节点_标记子树样式脏(最高)
    }
}

// §11 元素数据统计

定义 可变 元素Data_创建总数 = 0
定义 可变 元素Data_属性操作数 = 0
定义 可变 元素_查询总数 = 0

函数 元素数据_统计() {
    返回 {
        创建: 元素Data_创建总数,
        属性操作: 元素Data_属性操作数,
        查询: 元素_查询总数,
    }
}

函数 元素数据_健康检查() { 返回 "元素数据子系统健康" }

函数 元素数据_重置() {
    元素Data_创建总数 = 0
    元素Data_属性操作数 = 0
    元素_查询总数 = 0
}

函数 元素数据_完整统计() {
    返回 [元素Data_创建总数, 元素Data_属性操作数, 元素_查询总数]
}

// merge source: 沙盒批次/批三/待修/感知/语法树节点.nova
// §3 AST节点

定义 AST_PROGRAM      = 0
定义 AST_FUNC_DEF     = 1
定义 AST_VAR_DECL     = 2
定义 AST_BLOCK        = 3
定义 AST_IF           = 4
定义 AST_FOR          = 5
定义 AST_WHILE        = 6
定义 AST_RETURN       = 7
定义 AST_DISCARD      = 8
定义 AST_EXPR_STMT    = 9
定义 AST_BINARY       = 10
定义 AST_UNARY        = 11
定义 AST_CALL         = 12
定义 AST_MEMBER       = 13    // x.rgb
定义 AST_INDEX        = 14    // a[i]
定义 AST_IDENT        = 15
定义 AST_INT_LIT      = 16
定义 AST_FLOAT_LIT    = 17
定义 AST_ASSIGN       = 18
定义 AST_TERNARY      = 19

结构 AST节点 {
    类型,
    // 类型信息(语义分析后填充)
    值类型,    // u8 TY_xxx
    // 数据
    名称,    // u64 标识符名
    值,    // i32 字面量值(Q16)
    // 子节点
    左,    // u64 AST节点*
    右,
    条件,    // u64 if/for/while的条件
    body,    // u64 函数体/循环体
    else_body,
    // 操作符
    操作符,
    // 链表(用于语句列表/参数列表)
    下一个,
    // 限定符(in/out/uniform)
    限定符,    // u8 0=none 1=in 2=out 3=uniform 4=const
    // 位置信息
    行号,
    列号,
}

// §4 递归下降解析器

结构 GLSLParser {
    词法器,    // u64 GLSLLexer*
    错误数,
    错误信息,    // [16]u64 错误字符串数组
}

函数 GLSLParser_创建(源码, 长度) {
    定义 p = 堆_分配(GLSLParser)
    p.词法器 = GLSLLexer_创建(源码, 长度)
    p.错误数 = 0
    GLSLLexer_下一个(p.词法器)    // 预读第一个令牌
    返回 p
}

// translation_unit = external_declaration*
函数 GLSL_解析(p) {
    如果 (p == 0) { 返回 0 }
    定义 program = 堆_分配(AST节点)
    program.类型 = AST_PROGRAM; program.下一个 = 0
    定义 可变 last = 0
    当 (p.词法器.当前令牌.类型 != TOK_EOF) {
        定义 decl = GLSL_解析外部声明(p)
        如果 (decl == 0) { GLSLLexer_下一个(p.词法器); 继续 }
        如果 (last == 0) { program.body = decl }
        否则 { last.下一个 = decl }
        last = decl
    }
    返回 program
}

// external_declaration = [qualifiers] type identifier ( '(' params ')' block | ';' )
函数 GLSL_解析外部声明(p) {
    如果 (p == 0) { 返回 0 }
    定义 lex = p.词法器
    // 跳过precision声明
    如果 (lex.当前令牌.类型==TOK_KEYWORD && 字符串_相等(lex.当前令牌.值,"precision")) {
        当 (lex.当前令牌.类型 != TOK_SEMI && lex.当前令牌.类型 != TOK_EOF) {
            GLSLLexer_下一个(lex)
        }
        GLSLLexer_下一个(lex)    // 跳过 ';'
        返回 GLSL_解析外部声明(p)
    }
    // 跳过layout(...)
    如果 (lex.当前令牌.类型==TOK_KEYWORD && 字符串_相等(lex.当前令牌.值,"layout")) {
        GLSLLexer_下一个(lex)    // skip "layout"
        如果 (lex.当前令牌.类型==TOK_LPAREN) {
            定义 可变 深度 = 1
            GLSLLexer_下一个(lex)
            当 (深度 > 0 && lex.当前令牌.类型 != TOK_EOF) {
                如果 (lex.当前令牌.类型==TOK_LPAREN) { 深度=深度+1 }
                如果 (lex.当前令牌.类型==TOK_RPAREN) { 深度=深度-1 }
                GLSLLexer_下一个(lex)
            }
        }
    }
    // 限定符: in/out/uniform/const
    定义 可变 限定符 = 0
    如果 (lex.当前令牌.类型==TOK_KEYWORD) {
        如果 (字符串_相等(lex.当前令牌.值,"in")) { 限定符=1; GLSLLexer_下一个(lex) }
        否则 如果 (字符串_相等(lex.当前令牌.值,"out")) { 限定符=2; GLSLLexer_下一个(lex) }
        否则 如果 (字符串_相等(lex.当前令牌.值,"uniform")) { 限定符=3; GLSLLexer_下一个(lex) }
        否则 如果 (字符串_相等(lex.当前令牌.值,"const")) { 限定符=4; GLSLLexer_下一个(lex) }
        否则 如果 (字符串_相等(lex.当前令牌.值,"flat")) { GLSLLexer_下一个(lex) }
        否则 如果 (字符串_相等(lex.当前令牌.值,"smooth")) { GLSLLexer_下一个(lex) }
    }
    // 类型
    定义 类型 = GLSL_解析类型(p)
    如果 (类型 < 0) { 返回 0 }
    // 名称
    如果 (lex.当前令牌.类型 != TOK_IDENT) { 返回 0 }
    定义 名称 = lex.当前令牌.值; GLSLLexer_下一个(lex)
    // 函数 or 变量?
    如果 (lex.当前令牌.类型 == TOK_LPAREN) {
        // 函数定义
        返回 GLSL_解析函数(p, 类型, 名称)
    } 否则 {
        // 变量声明
        定义 节点 = 堆_分配(AST节点)
        节点.类型 = AST_VAR_DECL; 节点.值类型 = 类型; 节点.名称 = 名称; 节点.限定符 = 限定符
        如果 (lex.当前令牌.类型 == TOK_EQ) {
            GLSLLexer_下一个(lex)
            节点.右 = GLSL_解析表达式(p)
        }
        如果 (lex.当前令牌.类型 == TOK_SEMI) { GLSLLexer_下一个(lex) }
        返回 节点
    }
}

函数 GLSL_解析类型(p) {
    定义 lex = p.词法器
    如果 (lex.当前令牌.类型 != TOK_KEYWORD && lex.当前令牌.类型 != TOK_IDENT) { 返回 -1 }
    定义 词 = lex.当前令牌.值
    定义 可变 ty = -1
    如果 (字符串_相等(词,"void")) { ty=TY_VOID }
    否则 如果 (字符串_相等(词,"bool")) { ty=TY_BOOL }
    否则 如果 (字符串_相等(词,"int")) { ty=TY_INT }
    否则 如果 (字符串_相等(词,"uint")) { ty=TY_UINT }
    否则 如果 (字符串_相等(词,"float")) { ty=TY_FLOAT }
    否则 如果 (字符串_相等(词,"vec2")) { ty=TY_VEC2 }
    否则 如果 (字符串_相等(词,"vec3")) { ty=TY_VEC3 }
    否则 如果 (字符串_相等(词,"vec4")) { ty=TY_VEC4 }
    否则 如果 (字符串_相等(词,"mat2")) { ty=TY_MAT2 }
    否则 如果 (字符串_相等(词,"mat3")) { ty=TY_MAT3 }
    否则 如果 (字符串_相等(词,"mat4")) { ty=TY_MAT4 }
    否则 如果 (字符串_相等(词,"sampler2D")) { ty=TY_SAMPLER2D }
    否则 { ty = TY_FLOAT }    // fallback
    GLSLLexer_下一个(lex)
    返回 ty
}

函数 GLSL_解析函数(p, 返回类型, 名称) {
    定义 lex = p.词法器
    GLSLLexer_下一个(lex)    // skip '('
    // 参数列表
    定义 可变 params_head = 0; 定义 可变 params_last = 0
    当 (lex.当前令牌.类型 != TOK_RPAREN && lex.当前令牌.类型 != TOK_EOF) {
        定义 param_ty = GLSL_解析类型(p)
        定义 可变 param_name = 0
        如果 (lex.当前令牌.类型 == TOK_IDENT) { param_name = lex.当前令牌.值; GLSLLexer_下一个(lex) }
        定义 param = 堆_分配(AST节点)
        param.类型 = AST_VAR_DECL; param.值类型 = param_ty; param.名称 = param_name; param.下一个 = 0
        如果 (params_last == 0) { params_head = param } 否则 { params_last.下一个 = param }
        params_last = param
        如果 (lex.当前令牌.类型 == TOK_COMMA) { GLSLLexer_下一个(lex) }
    }
    如果 (lex.当前令牌.类型 == TOK_RPAREN) { GLSLLexer_下一个(lex) }
    // 函数体
    定义 body = GLSL_解析块(p)
    定义 节点 = 堆_分配(AST节点)
    节点.类型 = AST_FUNC_DEF; 节点.值类型 = 返回类型; 节点.名称 = 名称
    节点.左 = params_head; 节点.body = body; 节点.下一个 = 0
    返回 节点
}

函数 GLSL_解析块(p) {
    定义 lex = p.词法器
    如果 (lex.当前令牌.类型 != TOK_LBRACE) { 返回 0 }
    GLSLLexer_下一个(lex)
    定义 block = 堆_分配(AST节点); block.类型 = AST_BLOCK; block.下一个 = 0
    定义 可变 last = 0
    当 (lex.当前令牌.类型 != TOK_RBRACE && lex.当前令牌.类型 != TOK_EOF) {
        定义 stmt = GLSL_解析语句(p)
        如果 (stmt == 0) { GLSLLexer_下一个(lex); 继续 }
        如果 (last == 0) { block.body = stmt } 否则 { last.下一个 = stmt }
        last = stmt
    }
    如果 (lex.当前令牌.类型 == TOK_RBRACE) { GLSLLexer_下一个(lex) }
    返回 block
}

函数 GLSL_解析语句(p) {
    定义 lex = p.词法器
    如果 (lex.当前令牌.类型==TOK_KEYWORD && 字符串_相等(lex.当前令牌.值,"return")) {
        GLSLLexer_下一个(lex)
        定义 节点 = 堆_分配(AST节点); 节点.类型 = AST_RETURN; 节点.下一个 = 0
        如果 (lex.当前令牌.类型 != TOK_SEMI) { 节点.右 = GLSL_解析表达式(p) }
        如果 (lex.当前令牌.类型 == TOK_SEMI) { GLSLLexer_下一个(lex) }
        返回 节点
    }
    如果 (lex.当前令牌.类型==TOK_KEYWORD && 字符串_相等(lex.当前令牌.值,"if")) {
        返回 GLSL_解析if(p)
    }
    如果 (lex.当前令牌.类型==TOK_KEYWORD && 字符串_相等(lex.当前令牌.值,"for")) {
        返回 GLSL_解析for(p)
    }
    如果 (lex.当前令牌.类型==TOK_KEYWORD && 字符串_相等(lex.当前令牌.值,"discard")) {
        GLSLLexer_下一个(lex)
        定义 节点 = 堆_分配(AST节点); 节点.类型 = AST_DISCARD; 节点.下一个 = 0
        如果 (lex.当前令牌.类型 == TOK_SEMI) { GLSLLexer_下一个(lex) }
        返回 节点
    }
    如果 (lex.当前令牌.类型 == TOK_LBRACE) { 返回 GLSL_解析块(p) }
    // 变量声明或表达式语句
    定义 expr = GLSL_解析表达式(p)
    如果 (lex.当前令牌.类型 == TOK_SEMI) { GLSLLexer_下一个(lex) }
    定义 节点 = 堆_分配(AST节点); 节点.类型 = AST_EXPR_STMT; 节点.右 = expr; 节点.下一个 = 0
    返回 节点
}

// merge source: 沙盒批次/批三/待厚/感知/节点可访问.nova
// §3 AX节点 — 可访问性树节点

结构 AX节点 {
    ID,
    角色,    // u32 AX_ROLE_xxx
    名称,    // u64 可访问名称(字符串)
    描述,    // u64 描述(字符串)
    值,    // u64 当前值(input的value等)
    状态,    // u32 AX_STATE_xxx位掩码
    // 层级标题
    级别,    // u32 heading level (1-6)
    // 数值属性(slider/progressbar)
    值_当前,    // i32 aria-valuenow ×100
    值_最小,    // i32 aria-valuemin
    值_最大,    // i32 aria-valuemax
    值_文本,    // u64 aria-valuetext
    // 关联
    dom节点,    // u64 对应的DOM 节点*
    // 树结构
    父,    // u64 AX节点*
    第一子,
    后一兄弟,
    子数量,
    // Live Region
    live,    // u32 0=off 1=polite 2=assertive
    live_原子,    // 布尔 aria-atomic
    live_相关,    // u32 aria-relevant: additions/removals/text/all
    // 关系
    labelled_by,    // u64 aria-labelledby (AX节点*数组)
    described_by,    // u64 aria-describedby
    controls,    // u64 aria-controls
    owns,    // u64 aria-owns
    flowto,    // u64 aria-flowto
}

// §4 AXObject缓存 — 可访问性对象缓存
// DOM节点 ↔ AX节点的映射

结构 AXObject缓存 {
    根,    // u64 AX节点* (根节点)
    节点映射,    // u64 哈希Map<DOM 节点*, AX节点*>
    映射数量,
    映射容量,
    下一个ID,
    // 脏节点(需要更新)
    脏节点列表,
    脏节点数量,
    // 事件队列
    事件队列,
    事件数量,
}

定义 可变 全局AX缓存 = 0

函数 AXObject缓存_获取() {
    如果 (全局AX缓存 == 0) {
        全局AX缓存 = 堆_分配(AXObject缓存)
        全局AX缓存.映射容量 = 4096
        全局AX缓存.节点映射 = 堆_分配_数组(4096 * 16)
        内存_清零(全局AX缓存.节点映射, 4096 * 16)
        全局AX缓存.映射数量 = 0
        全局AX缓存.下一个ID = 1
        全局AX缓存.根 = 0
        全局AX缓存.脏节点列表 = 堆_分配_数组(256 * 8)
        全局AX缓存.脏节点数量 = 0
        全局AX缓存.事件队列 = 堆_分配_数组(128 * 16)
        全局AX缓存.事件数量 = 0
    }
    返回 全局AX缓存
}

函数 AXObject缓存_获取或创建(dom节点) {
    如果 (dom节点 == 0) { 返回 0 }
    定义 cache = AXObject缓存_获取()

    // 查找已有映射
    定义 已有 = AXObject缓存_查找(cache, dom节点)
    如果 (已有 != 0) { 返回 已有 }

    // 创建新的AX节点
    定义 ax = 堆_分配(AX节点)
    ax.ID = cache.下一个ID; cache.下一个ID = cache.下一个ID + 1
    ax.dom节点 = dom节点
    ax.父 = 0; ax.第一子 = 0; ax.后一兄弟 = 0; ax.子数量 = 0
    ax.live = 0; ax.live_原子 = 假; ax.live_相关 = 0

    // 计算角色
    ax.角色 = AX_计算角色(dom节点)

    // 计算名称
    ax.名称 = AX_计算名称(dom节点)

    // 计算状态
    ax.状态 = AX_计算状态(dom节点)

    // 计算值
    ax.值 = AX_计算值(dom节点)

    // 存入映射
    AXObject缓存_存储(cache, dom节点, ax)

    返回 ax
}

函数 AXObject缓存_查找(cache, dom节点) {
    定义 hash = (dom节点 >> 3) & (cache.映射容量 - 1)
    定义 可变 i = hash
    定义 可变 尝试 = 0
    当 (尝试 < cache.映射容量) {
        定义 偏移 = cache.节点映射 + i * 16
        定义 键 = 内存_读64(偏移)
        如果 (键 == dom节点) { 返回 内存_读64(偏移 + 8) }
        如果 (键 == 0) { 返回 0 }
        i = (i + 1) & (cache.映射容量 - 1)
        尝试 = 尝试 + 1
    }
    返回 0
}

函数 AXObject缓存_存储(cache, dom节点, ax节点) {
    定义 hash = (dom节点 >> 3) & (cache.映射容量 - 1)
    定义 可变 i = hash
    当 (真) {
        定义 偏移 = cache.节点映射 + i * 16
        定义 键 = 内存_读64(偏移)
        如果 (键 == 0 || 键 == dom节点) {
            内存_写64(偏移, dom节点)
            内存_写64(偏移 + 8, ax节点)
            cache.映射数量 = cache.映射数量 + 1
            返回
        }
        i = (i + 1) & (cache.映射容量 - 1)
    }
}

// §5 AX树操作

函数 AX节点_添加子(父, 子) {
    如果 (父 == 0 || 子 == 0) { 返回 }
    子.父 = 父
    子.后一兄弟 = 父.第一子
    父.第一子 = 子
    父.子数量 = 父.子数量 + 1
}

函数 AX节点_移除子(父, 子) {
    如果 (父 == 0 || 子 == 0) { 返回 }
    如果 (父.第一子 == 子) {
        父.第一子 = 子.后一兄弟
    } 否则 {
        定义 可变 当前 = 父.第一子
        当 (当前 != 0 && 当前.后一兄弟 != 子) { 当前 = 当前.后一兄弟 }
        如果 (当前 != 0) { 当前.后一兄弟 = 子.后一兄弟 }
    }
    子.父 = 0
    子.后一兄弟 = 0
    父.子数量 = 父.子数量 - 1
}

函数 AX节点_获取子列表(ax) {
    定义 可变 结果 = []
    如果 (ax == 0) { 返回 结果 }
    定义 可变 子 = ax.第一子
    当 (子 != 0) {
        追加(结果, 子)
        子 = 子.后一兄弟
    }
    返回 结果
}

// §6 AX节点更新

函数 AX节点_标记脏(cache, ax) {
    如果 (cache == 0 || ax == 0) { 返回 }
    如果 (cache.脏节点数量 < 256) {
        内存_写64(cache.脏节点列表 + cache.脏节点数量 * 8, ax)
        cache.脏节点数量 = cache.脏节点数量 + 1
    }
}

函数 AX节点_更新(ax, dom节点) {
    如果 (ax == 0 || dom节点 == 0) { 返回 }
    ax.名称 = AX_计算名称(dom节点)
    ax.状态 = AX_计算状态(dom节点)
    ax.值 = AX_计算值(dom节点)
}

函数 AXObject缓存_处理脏节点(cache) {
    如果 (cache == 0) { 返回 }
    定义 可变 i = 0
    当 (i < cache.脏节点数量) {
        定义 ax = 内存_读64(cache.脏节点列表 + i * 8)
        如果 (ax != 0) { AX节点_更新(ax, ax.dom节点) }
        i = i + 1
    }
    cache.脏节点数量 = 0
}

// merge source: 沙盒批次/批三/待厚/感知/元素几何信.nova

结构 DOMRect {
    x,
    y,
    width,
    height,
    top,
    right,
    bottom,
    left,
}

函数 元素_确保布局(节点) {
    如果 (节点 == 0) { 返回 }
    定义 文档 = 节点_所属文档(节点)
    如果 (文档 != 0 && 文档.布局脏) {
        布局_更新(文档)
    }
}

函数 元素_getBoundingClientRect(节点) {
    如果 (节点 == 0) { 返回 0 }
    元素_确保布局(节点)
    如果 (节点.布局对象 == 0) { 返回 0 }
    返回 布局Object_获取客户端矩形(节点.布局对象)
}

函数 元素_getClientRects(节点) {
    如果 (节点 == 0) { 返回 [0, 0] }
    元素_确保布局(节点)
    如果 (节点.布局对象 == 0) { 返回 [0, 0] }

    定义 可变 矩形列表 = []
    定义 布局 = 节点.布局对象

    如果 (布局.是内联) {
        定义 可变 行 = 布局.第一行盒
        当 (行 != 0) {
            定义 rect = DOMRect {}
            rect.x = 行.x
            rect.y = 行.y
            rect.width = 行.宽
            rect.height = 行.高
            rect.top = 行.y
            rect.left = 行.x
            rect.right = 行.x + 行.宽
            rect.bottom = 行.y + 行.高
            追加(矩形列表, rect)
            行 = 行.下一行盒
        }
    } 否则 {
        追加(矩形列表, 元素_getBoundingClientRect(节点))
    }

    返回 [矩形列表, 计数(矩形列表)]
}

函数 元素_offsetWidth(节点) {
    如果 (节点 == 0) { 返回 0 }
    元素_确保布局(节点)
    如果 (节点.布局对象 == 0) { 返回 0 }
    返回 布局Object_边框盒宽(节点.布局对象)
}

函数 元素_offsetHeight(节点) {
    如果 (节点 == 0) { 返回 0 }
    元素_确保布局(节点)
    如果 (节点.布局对象 == 0) { 返回 0 }
    返回 布局Object_边框盒高(节点.布局对象)
}

函数 元素_offsetTop(节点) {
    如果 (节点 == 0 || 节点.布局对象 == 0) { 返回 0 }
    元素_确保布局(节点)
    定义 父偏移 = 元素_offsetParent(节点)
    定义 自身y = 布局Object_绝对y(节点.布局对象)
    如果 (父偏移 != 0 && 父偏移.布局对象 != 0) {
        返回 自身y - 布局Object_绝对y(父偏移.布局对象)
    }
    返回 自身y
}

函数 元素_offsetLeft(节点) {
    如果 (节点 == 0 || 节点.布局对象 == 0) { 返回 0 }
    元素_确保布局(节点)
    定义 父偏移 = 元素_offsetParent(节点)
    定义 自身x = 布局Object_绝对x(节点.布局对象)
    如果 (父偏移 != 0 && 父偏移.布局对象 != 0) {
        返回 自身x - 布局Object_绝对x(父偏移.布局对象)
    }
    返回 自身x
}

函数 元素_offsetParent(节点) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 当前 = 节点.父节点
    当 (当前 != 0) {
        如果 (当前.布局对象 != 0) {
            定义 定位 = 布局Object_获取定位(当前.布局对象)
            如果 (定位 != 0) { 返回 当前 }
        }
        如果 (当前.标签名 == "body" || 当前.标签名 == "html") { 返回 当前 }
        当前 = 当前.父节点
    }
    返回 0
}

函数 元素_clientWidth(节点) {
    如果 (节点 == 0 || 节点.布局对象 == 0) { 返回 0 }
    元素_确保布局(节点)
    返回 布局Object_内容盒宽(节点.布局对象)
}

函数 元素_clientHeight(节点) {
    如果 (节点 == 0 || 节点.布局对象 == 0) { 返回 0 }
    元素_确保布局(节点)
    返回 布局Object_内容盒高(节点.布局对象)
}

函数 元素_clientTop(节点) {
    如果 (节点 == 0 || 节点.布局对象 == 0) { 返回 0 }
    返回 布局Object_边框上宽(节点.布局对象)
}

函数 元素_clientLeft(节点) {
    如果 (节点 == 0 || 节点.布局对象 == 0) { 返回 0 }
    返回 布局Object_边框左宽(节点.布局对象)
}

函数 元素_scrollTop(节点) {
    定义 扩展 = 元素_获取扩展(节点)
    如果 (扩展 == 0) { 返回 0 }
    返回 扩展.scroll_top
}

函数 元素_scrollLeft(节点) {
    定义 扩展 = 元素_获取扩展(节点)
    如果 (扩展 == 0) { 返回 0 }
    返回 扩展.scroll_left
}

函数 元素_设置scrollTop(节点, 值) {
    定义 扩展 = 元素_获取扩展(节点)
    如果 (扩展 == 0) { 返回 }
    定义 最大 = 元素_scrollHeight(节点) - 元素_clientHeight(节点)
    如果 (值 < 0) { 值 = 0 }
    如果 (值 > 最大) { 值 = 最大 }
    扩展.scroll_top = 值
    布局_标记重绘(节点)
}

函数 元素_设置scrollLeft(节点, 值) {
    定义 扩展 = 元素_获取扩展(节点)
    如果 (扩展 == 0) { 返回 }
    定义 最大 = 元素_scrollWidth(节点) - 元素_clientWidth(节点)
    如果 (值 < 0) { 值 = 0 }
    如果 (值 > 最大) { 值 = 最大 }
    扩展.scroll_left = 值
    布局_标记重绘(节点)
}

函数 元素_scrollWidth(节点) {
    如果 (节点 == 0 || 节点.布局对象 == 0) { 返回 0 }
    元素_确保布局(节点)
    返回 布局Object_滚动宽(节点.布局对象)
}

函数 元素_scrollHeight(节点) {
    如果 (节点 == 0 || 节点.布局对象 == 0) { 返回 0 }
    元素_确保布局(节点)
    返回 布局Object_滚动高(节点.布局对象)
}

函数 元素_scrollIntoView(节点, 选项) {
    如果 (节点 == 0) { 返回 }
    元素_确保布局(节点)
    定义 rect = 元素_getBoundingClientRect(节点)
    如果 (rect == 0) { 返回 }

    定义 可变 对齐 = 0
    如果 (选项 == 真 || 选项 == 0) { 对齐 = 0 }
    如果 (选项 == 假) { 对齐 = 1 }

    定义 可变 滚动容器 = 节点.父节点
    当 (滚动容器 != 0) {
        定义 扩展 = 元素_获取扩展(滚动容器)
        如果 (扩展 != 0) {
            如果 (对齐 == 0) {
                元素_设置scrollTop(滚动容器, rect.top)
            } 否则 {
                元素_设置scrollTop(滚动容器, rect.bottom - 元素_clientHeight(滚动容器))
            }
            返回
        }
        滚动容器 = 滚动容器.父节点
    }
}

函数 元素_检查可见性(节点, 视口宽, 视口高) {
    如果 (节点 == 0) { 返回 假 }
    定义 rect = 元素_getBoundingClientRect(节点)
    如果 (rect == 0) { 返回 假 }
    返回 rect.bottom > 0 && rect.top < 视口高 && rect.right > 0 && rect.left < 视口宽
}

函数 元素_计算交叉比(节点, 视口宽, 视口高) {
    如果 (节点 == 0) { 返回 0 }
    定义 rect = 元素_getBoundingClientRect(节点)
    如果 (rect == 0 || rect.width == 0 || rect.height == 0) { 返回 0 }

    定义 可变 交叉左 = rect.left
    如果 (交叉左 < 0) { 交叉左 = 0 }
    定义 可变 交叉上 = rect.top
    如果 (交叉上 < 0) { 交叉上 = 0 }
    定义 可变 交叉右 = rect.right
    如果 (交叉右 > 视口宽) { 交叉右 = 视口宽 }
    定义 可变 交叉下 = rect.bottom
    如果 (交叉下 > 视口高) { 交叉下 = 视口高 }

    如果 (交叉右 <= 交叉左 || 交叉下 <= 交叉上) { 返回 0 }

    定义 交叉面积 = (交叉右 - 交叉左) * (交叉下 - 交叉上)
    定义 元素面积 = rect.width * rect.height
    返回 交叉面积 * 1000 / 元素面积
}

函数 智能_元素_AI语义感知(节点) {
    定义 bus = 全局AI总线
    如果 (bus == 0 || 节点 == 0) { 返回 }
    节点_AI语义分析(节点)
}

函数 智能_元素_AI事件优先级(事件类型, 目标节点) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 128 }
    如果 (目标节点 != 0 && 目标节点.注意力权重 > 8000) { 返回 255 }
    返回 128
}

// merge source: 沙盒批次/批三/待厚/感知/数据.nova
// 持有字符数据(data)，提供文本操作接口

结构 CharacterData扩展 {
    数据,    // u64 字符串指针 (data)
    数据长度,    // u32 data.length (缓存,避免重复计算)
}

// §1 CharacterData通用操作

函数 CharacterData_创建扩展(文本) {
    定义 扩展 = 堆_分配(CharacterData扩展)
    如果 (文本 != 0) {
        扩展.数据 = 字符串_复制(文本)
        扩展.数据长度 = 字符串_长度(文本)
    } 否则 {
        扩展.数据 = 字符串_复制("")
        扩展.数据长度 = 0
    }
    返回 扩展
}

函数 CharacterData_获取扩展(节点) {
    // CharacterData扩展存在节点.事件监听器数据字段(复用)
    如果 (节点 == 0) { 返回 0 }
    如果 (节点.节点类型 != TEXT_节点 && 节点.节点类型 != COMMENT_节点 && 节点.节点类型 != CDATA_SECTION_节点) {
        返回 0
    }
    返回 节点.事件监听器数据
}

函数 CharacterData_设置data(节点, 新数据) {
    // DOM spec: characterData.data setter
    定义 扩展 = CharacterData_获取扩展(节点)
    如果 (扩展 == 0) { 返回 }

    定义 旧数据 = 扩展.数据
    扩展.数据 = 字符串_复制(新数据)
    扩展.数据长度 = 字符串_长度(新数据)

    // 通知父元素样式/布局需要更新
    如果 (节点.父节点 != 0) {
        节点_标记样式脏(节点.父节点)
        节点_标记布局脏(节点.父节点)
    }
}

函数 CharacterData_length(节点) {
    定义 扩展 = CharacterData_获取扩展(节点)
    如果 (扩展 == 0) { 返回 0 }
    返回 扩展.数据长度
}

函数 CharacterData_substringData(节点, 偏移, 计数值) {
    定义 扩展 = CharacterData_获取扩展(节点)
    如果 (扩展 == 0) { 返回 0 }
    如果 (偏移 > 扩展.数据长度) { 返回 0 }
    定义 实际计数 = 计数值
    如果 (偏移 + 实际计数 > 扩展.数据长度) {
        实际计数 = 扩展.数据长度 - 偏移
    }
    返回 字符串_子串(扩展.数据, 偏移, 实际计数)
}

函数 CharacterData_appendData(节点, 追加文本) {
    定义 扩展 = CharacterData_获取扩展(节点)
    如果 (扩展 == 0) { 返回 }
    扩展.数据 = 字符串_连接(扩展.数据, 追加文本)
    扩展.数据长度 = 字符串_长度(扩展.数据)
    如果 (节点.父节点 != 0) {
        节点_标记布局脏(节点.父节点)
    }
}

函数 CharacterData_insertData(节点, 偏移, 插入文本) {
    定义 扩展 = CharacterData_获取扩展(节点)
    如果 (扩展 == 0) { 返回 }
    如果 (偏移 > 扩展.数据长度) { 返回 }
    定义 前段 = 字符串_子串(扩展.数据, 0, 偏移)
    定义 后段 = 字符串_子串(扩展.数据, 偏移, 扩展.数据长度 - 偏移)
    扩展.数据 = 字符串_连接(前段, 字符串_连接(插入文本, 后段))
    扩展.数据长度 = 字符串_长度(扩展.数据)
    如果 (节点.父节点 != 0) { 节点_标记布局脏(节点.父节点) }
}

函数 CharacterData_deleteData(节点, 偏移, 计数值) {
    定义 扩展 = CharacterData_获取扩展(节点)
    如果 (扩展 == 0) { 返回 }
    如果 (偏移 > 扩展.数据长度) { 返回 }
    定义 实际计数 = 计数值
    如果 (偏移 + 实际计数 > 扩展.数据长度) {
        实际计数 = 扩展.数据长度 - 偏移
    }
    定义 前段 = 字符串_子串(扩展.数据, 0, 偏移)
    定义 后段 = 字符串_子串(扩展.数据, 偏移 + 实际计数, 扩展.数据长度 - 偏移 - 实际计数)
    扩展.数据 = 字符串_连接(前段, 后段)
    扩展.数据长度 = 字符串_长度(扩展.数据)
    如果 (节点.父节点 != 0) { 节点_标记布局脏(节点.父节点) }
}

函数 CharacterData_replaceData(节点, 偏移, 计数值, 替换文本) {
    CharacterData_deleteData(节点, 偏移, 计数值)
    CharacterData_insertData(节点, 偏移, 替换文本)
}

// §2 Text节点 

函数 Text_创建(文本内容) {
 定义 节点 = 节点_创建(TEXT_节点, 节点标志_是文本)
 定义 扩展 = CharacterData_创建扩展(文本内容)
 节点.事件监听器数据 = 扩展 // 复用字段存CharacterData扩展
 返回 节点
}

函数 Text_wholeText(节点) {
 // DOM spec: 返回连续Text兄弟的所有data拼接
 定义 可变 结果 = ""
 // 向前找连续Text
 定义 可变 开始 = 节点
 当 (开始.前一兄弟 != 0 && 开始.前一兄弟.节点类型 == TEXT_节点) {
 开始 = 开始.前一兄弟
 }
 // 向后拼接
 定义 可变 当前 = 开始
 当 (当前 != 0 && 当前.节点类型 == TEXT_节点) {
 定义 数据 = CharacterData_data(当前)
 如果 (数据 != 0) {
 结果 = 字符串_连接(结果, 数据)
 }
 当前 = 当前.后一兄弟
 }
 返回 结果
}

函数 Text_splitText(节点, 偏移) {
 // DOM spec: text.splitText(offset) → 在偏移处分割,返回新Text
 定义 扩展 = CharacterData_获取扩展(节点)
 如果 (扩展 == 0) { 返回 0 }
 如果 (偏移 > 扩展.数据长度) { 返回 0 }

 定义 后半 = 字符串_子串(扩展.数据, 偏移, 扩展.数据长度 - 偏移)
 定义 新节点 = Text_创建(后半)

 // 截断当前节点
 扩展.数据 = 字符串_子串(扩展.数据, 0, 偏移)
 扩展.数据长度 = 偏移

 // 插入到当前节点之后
 如果 (节点.父节点 != 0) {
 如果 (节点.后一兄弟 != 0) {
 节点_insertBefore(节点.父节点, 新节点, 节点.后一兄弟)
 } 否则 {
 节点_appendChild(节点.父节点, 新节点)
 }
 }

 返回 新节点
}

// §3 Comment节点 

函数 Comment_创建(数据) {
 定义 节点 = 节点_创建(COMMENT_节点, 0)
 定义 扩展 = CharacterData_创建扩展(数据)
 节点.事件监听器数据 = 扩展
 返回 节点
}

// §4 DocumentType节点 

结构 DocumentType扩展 {
 名称,    // u64 <!DOCTYPE html> 中的 "html"
 公共ID,    // u64 publicId
 系统ID,    // u64 systemId
}

函数 DocumentType_创建(名称, 公共id, 系统id) {
 定义 节点 = 节点_创建(DOCUMENT_TYPE_节点, 0)
 定义 扩展 = 堆_分配(DocumentType扩展)
 扩展.名称 = 字符串_复制(名称)
 扩展.公共ID = 字符串_复制(公共id)
 扩展.系统ID = 字符串_复制(系统id)
 节点.事件监听器数据 = 扩展
 返回 节点
}

// §5 重写节点基类的获取字符数据(供textContent使用)

// 节点_获取字符数据 的实际实现(覆盖节点.nova中的默认版本)
函数 节点_获取字符数据_实现(节点) {
 如果 (节点.节点类型 == TEXT_节点 || 节点.节点类型 == COMMENT_节点 || 节点.节点类型 == CDATA_SECTION_节点) {
 返回 CharacterData_data(节点)
 }
 返回 0
}

// 传统方案: DOM操作无语义感知, 不区分重要性
// Nova: AI总线为每个DOM操作提供语义上下文和优先级

函数 智能_CharacterData_AI语义感知(节点) {
 定义 bus = 全局AI总线
 如果 (bus == 0 || 节点 == 0) { 返回 }
 // DOM操作时触发AI语义分析
 节点_AI语义分析(节点)
}

函数 智能_CharacterData_AI事件优先级(事件类型, 目标节点) {
 定义 bus = 全局AI总线
 如果 (bus == 0) { 返回 128 }
 // 由AI总线判断事件处理优先级
 // 高注意力区域的事件优先处理
 如果 (目标节点 != 0 && 目标节点.注意力权重 > 8000) { 返回 255 }
 返回 128
}

// merge source: 沙盒批次/批三/待厚/感知/节点变更通.nova
// §7 节点变更通知 (MutationObserver / DOM变更事件)
// (对应 ChildListMutationScope / MutationObserver)

函数 节点_子节点变更通知(父节点, 新增子, 移除子) {
 如果 (父节点 == 0) { 返回 }
 // 遍历注册在该节点及其祖先的MutationObserver
 定义 可变 节点 = 父节点
 当 (节点 != 0) {
 如果 (节点.观察者列表 != 0) {
 定义 可变 i = 0
 当 (i < 节点.观察者数量) {
 定义 obs = 内存_读64(节点.观察者列表 + i * 8)
 如果 (obs != 0 && (obs.选项 & MO_CHILD_LIST)) {
 // 创建MutationRecord并加入队列
 定义 rec = 堆_分配(MutationRecord)
 rec.类型 = "childList"
 rec.目标 = 父节点
 rec.新增节点 = 新增子
 rec.移除节点 = 移除子
 追加(obs.记录队列, rec)
 }
 i = i + 1
 }
 }
 节点 = 节点.父节点
 }
 // 排入微任务: 通知所有有待处理记录的观察者
 MicroTask_排入_MutationNotify()
}

// §8 textContent / 节点Value

函数 节点_textContent(节点) {
 // DOM spec: textContent getter
 // 元素: 返回所有后代Text节点的拼接
 // Text/Comment: 返回data
 // Document/DocumentType: 返回null
 如果 (节点.节点类型 == DOCUMENT_节点 || 节点.节点类型 == DOCUMENT_TYPE_节点) {
 返回 0
 }
 如果 (节点.节点类型 == TEXT_节点 || 节点.节点类型 == COMMENT_节点) {
 // 返回CharacterData.data (子类的字段)
 返回 节点_获取字符数据(节点)
 }
 // 元素等容器: 收集所有后代Text
 返回 节点_收集后代文字(节点)
}

函数 节点_收集后代文字(节点) {
 // 遍历所有后代,拼接Text节点的data
 定义 可变 结果 = ""
 定义 可变 当前 = 节点_深度优先下一个(节点, 节点)
 当 (当前 != 0) {
 如果 (当前.节点类型 == TEXT_节点) {
 定义 文字 = 节点_获取字符数据(当前)
 如果 (文字 != 0) {
 结果 = 字符串_连接(结果, 文字)
 }
 }
 当前 = 节点_深度优先下一个(当前, 节点)
 }
 返回 结果
}

函数 节点_获取字符数据(节点) {
    如果 (节点 == 0) { 返回 0 }
    如果 (节点.节点类型 == TEXT_节点 || 节点.节点类型 == COMMENT_节点 || 节点.节点类型 == CDATA_节点) {
        返回 节点.数据
    }
    返回 0
}

// §9 【颠覆性创新】AI总线驱动的语义分析
// 传统: 靠HTML标签名预设判断语义(if tag=="nav" → 导航栏)
// Nova: 由AI总线的神经网络推理 — 语义嵌入+分类网络+注意力机制
// 调用链: 节点 → AI总线_语义分类() → 语义嵌入引擎 → Nova多层感知器分类网络
// → 余弦相似度匹配语义原型向量 → 返回语义角色

函数 节点_AI完成分析(节点, 角色, 注意力分数, 更新注意力) {
 节点.语义角色 = 角色

 如果 (更新注意力) {
 节点.注意力权重 = 注意力分数 * 10000 / 1024
 如果 (节点.注意力权重 > 10000) { 节点.注意力权重 = 10000 }
 }

 如果 (节点.语义角色 == 语义_广告 || 节点.语义角色 == 语义_Cookie同意) {
 节点.渲染精度 = 1
 } 否则 如果 (节点.注意力权重 >= 8000) {
 节点.渲染精度 = 3
 节点.节点标志 = 节点.节点标志 | 节点标志_高注意力
 } 否则 如果 (节点.注意力权重 < 2000) {
 节点.渲染精度 = 1
 } 否则 {
 节点.渲染精度 = 2
 }

 节点.节点标志 = 节点.节点标志 | 节点标志_AI已分析
}

// AI语义分析: 为节点计算语义角色(由神经网络推理)
函数 节点_AI语义分析(节点) {
 如果 (节点 == 0) { 返回 }
 如果 (节点.节点标志 & 节点标志_AI已分析) { 返回 }

    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 }

    // 1. 语义角色: 由AI总线的语义嵌入+Nova归一化指数分类网络推断
    // 内部流程: 标签嵌入(32维) + 类名哈希嵌入(32维) + 结构特征(8维)
    // → 72维拼接 → Nova多层感知器[72→48→32] → 余弦相似度匹配12个语义原型
    定义 角色 = AI总线_语义分类(bus, 节点)

    // 2. 注意力权重: 由AI总线的注意力网络(Nova多层感知器 8→16→8→1 Nova激活函数)计算
    // 输入: 节点特征[深度/子节点数/文本长度/是否有ID/是否含链接/...]
    定义 可变 注意力分数 = 0
    定义 可变 更新注意力 = 假
    定义 可变 节点特征 = 节点_提取AI特征(节点)
    如果 (节点特征 != 0) {
        注意力分数 = AI总线_注意力权重(bus, 节点特征)
        更新注意力 = 真
        Tensor_释放(节点特征)
    }

    节点_AI完成分析(节点, 角色, 注意力分数, 更新注意力)
}

函数 节点_AI语义分析_GQA(节点, bus, 位置) {
    如果 (节点 == 0 || bus == 0) { 返回 }

    定义 嵌入 = 语义嵌入_计算节点嵌入(bus.语义引擎, 节点)
    如果 (嵌入 == 0) { 返回 }
    定义 角色 = AI总线_DOM语义分类_GQA(bus, 嵌入, 位置)
    Tensor_释放(嵌入)

    定义 可变 注意力分数 = 0
    定义 可变 更新注意力 = 假
    定义 节点特征 = 节点_提取AI特征(节点)
    如果 (节点特征 != 0) {
        注意力分数 = AI总线_注意力权重(bus, 节点特征)
        更新注意力 = 真
        Tensor_释放(节点特征)
    }

    节点_AI完成分析(节点, 角色, 注意力分数, 更新注意力)
}

函数 节点_AI批量语义分析_GQA_递归(节点, bus, 位置) {
    如果 (节点 == 0) { 返回 位置 }
    节点_AI语义分析_GQA(节点, bus, 位置)
    定义 可变 下一个位置 = 位置 + 1
    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        下一个位置 = 节点_AI批量语义分析_GQA_递归(子, bus, 下一个位置)
        子 = 子.后一兄弟
    }
    返回 下一个位置
}

函数 节点_AI批量语义分析(根节点) {
    如果 (根节点 == 0) { 返回 }
    定义 bus = 全局AI总线
    如果 (bus != 0 && bus.DOM注意力模型 != 0 && bus.降级模式 < 3) {
        AI总线_重置页面注意力缓存(bus)
        节点_AI批量语义分析_GQA_递归(根节点, bus, 0)
        返回
    }
    节点_AI语义分析(根节点)
    定义 可变 子 = 根节点.第一子节点
    当 (子 != 0) {
        节点_AI批量语义分析(子)
        子 = 子.后一兄弟
    }
}

// 更新行为历史: 用户点击了此节点
函数 节点_AI记录点击(节点) {
 如果 (节点 == 0) { 返回 }
 节点.点击次数 = 节点.点击次数 + 1
 // 点击后提升注意力权重(在线学习反馈)
 如果 (节点.注意力权重 < 9500) {
 节点.注意力权重 = 节点.注意力权重 + 500
 }
 // 标记为可交互预测
 节点.节点标志 = 节点.节点标志 | 节点标志_可交互预测
 // 清除AI已分析标志,下次重新推理
 节点.节点标志 = 节点.节点标志 & (~节点标志_AI已分析)
}

// 更新行为历史: 鼠标悬停
函数 节点_AI记录悬停(节点, 持续ms) {
 如果 (节点 == 0) { 返回 }
 节点.悬停总时长 = 节点.悬停总时长 + 持续ms
 节点.累计停留时间 = 节点.累计停留时间 + 持续ms
}

// 更新视口可见性
函数 节点_AI更新可见性(节点, 视口上, 视口下) {
 如果 (节点 == 0 || 节点.布局对象 == 0) { 返回 }
 定义 lo = 节点.布局对象
 定义 节点上 = lo.绝对y
 定义 节点下 = lo.绝对y + 布局Object_边框盒高(lo)

 如果 (节点下 <= 视口上 || 节点上 >= 视口下) {
 节点.视口可见性 = 0 // 不可见
 } 否则 如果 (节点上 >= 视口上 && 节点下 <= 视口下) {
 节点.视口可见性 = 2 // 完全可见
 } 否则 {
 节点.视口可见性 = 1 // 部分可见
 }
}

// 意图预测: 由行为历史+语义角色推断用户可能的交互
函数 节点_AI预测意图(节点) {
 如果 (节点 == 0) { 返回 意图_无 }

 // 高点击历史 → 将点击
 如果 (节点.点击次数 > 3) { 返回 意图_将点击 }

 // 正文/标题 → 将阅读
 如果 (节点.语义角色 == 语义_正文 || 节点.语义角色 == 语义_段落 || 节点.语义角色 == 语义_标题) {
 返回 意图_将阅读
 }

 // 表单/搜索框 → 将输入
 如果 (节点.语义角色 == 语义_表单 || 节点.语义角色 == 语义_搜索框) {
 返回 意图_将输入
 }

 // 弹窗/Cookie → 将关闭
 如果 (节点.语义角色 == 语义_弹窗 || 节点.语义角色 == 语义_Cookie同意) {
 返回 意图_将关闭
 }

 // 广告 → 将滚过
 如果 (节点.语义角色 == 语义_广告) { 返回 意图_将滚过 }

 // 链接/按钮 → 将点击
 如果 (节点.语义角色 == 语义_链接 || 节点.语义角色 == 语义_按钮) {
 返回 意图_将点击
 }

 返回 意图_无
}

// merge source: 沙盒批次/批三/待厚/感知/索引库对象.nova
// §2 IDBObjectStore — 对象存储

定义 IDB_KEY_TYPE_NUMBER  = 1
定义 IDB_KEY_TYPE_STRING  = 2
定义 IDB_KEY_TYPE_DATE    = 3
定义 IDB_KEY_TYPE_ARRAY   = 4

结构 IDBObjectStore {
    名称,
    键路径,    // u64 keyPath (如 "id")
    自增,    // 布尔 autoIncrement
    自增计数,    // u64 当前自增值
    // 数据存储 (B-tree实现, 叶子节点排序)
    记录列表,    // u64 IDBRecord*数组 (按键排序)
    记录数量,
    记录容量,
    // 索引
    索引列表,    // u64 IDBIndex*数组
    索引数量,
    索引容量,
    // 所属数据库
    数据库,    // u64 IDBDatabase*
}

结构 IDBRecord {
    键,    // u64 IDBKey*
    值,    // u64 JSValue* (结构化克隆)
    键类型,    // u32 IDB_KEY_TYPE_xxx
}

结构 IDBIndex {
    名称,
    键路径,    // u64 索引的keyPath
    唯一,    // 布尔 unique
    多值,    // 布尔 multiEntry
    // 索引数据 (键→主键映射)
    条目列表,    // u64 [索引键, 主键] 对数组
    条目数量,
    条目容量,
    对象存储,    // u64 所属ObjectStore*
}

函数 IDBDatabase_createObjectStore(db, 名称, 选项) {
    如果 (db == 0 || db.存储数量 >= db.存储容量) { 返回 0 }

    定义 store = 堆_分配(IDBObjectStore)
    store.名称 = 字符串_复制(名称)
    store.键路径 = 0
    store.自增 = 假
    store.自增计数 = 1

    如果 (选项 != 0) {
        定义 kp = Nova对象_获取属性(0, 选项, "keyPath")
        如果 (kp != 0) { store.键路径 = JSValue_获取字符串(kp) }
        定义 ai = Nova对象_获取属性(0, 选项, "autoIncrement")
        如果 (ai != 0) { store.自增 = JSValue_ToBoolean(0, ai) }
    }

    store.记录容量 = 1024
    store.记录列表 = 堆_分配_数组(1024 * 16)
    store.记录数量 = 0
    store.索引容量 = 16
    store.索引列表 = 堆_分配_数组(16 * 8)
    store.索引数量 = 0
    store.数据库 = db

    内存_写64(db.存储列表 + db.存储数量 * 8, store)
    db.存储数量 = db.存储数量 + 1
    返回 store
}

函数 IDBDatabase_deleteObjectStore(db, 名称) {
    如果 (db == 0) { 返回 }
    定义 可变 i = 0
    当 (i < db.存储数量) {
        定义 store = 内存_读64(db.存储列表 + i * 8)
        如果 (store != 0 && 字符串_相等(store.名称, 名称)) {
            db.存储数量 = db.存储数量 - 1
            内存_写64(db.存储列表 + i * 8, 内存_读64(db.存储列表 + db.存储数量 * 8))
            返回
        }
        i = i + 1
    }
}

函数 IDBObjectStore_add(store, 值, 键) {
    如果 (store == 0) { 返回 0 }

    // 确定键
    定义 可变 实际键 = 键
    如果 (实际键 == 0 && store.键路径 != 0) {
        // 从值中提取键
        实际键 = IDB_提取键(值, store.键路径)
    }
    如果 (实际键 == 0 && store.自增) {
        实际键 = store.自增计数
        store.自增计数 = store.自增计数 + 1
    }

    // 检查键唯一性(add不允许重复)
    如果 (IDBObjectStore_查找(store, 实际键) >= 0) {
        // Constraint错误: 键已存在
        返回 0
    }

    // 插入(保持键排序)
    IDBObjectStore_插入记录(store, 实际键, 值)

    // 更新索引
    IDBObjectStore_更新索引(store, 实际键, 值)

    返回 IDBRequest_创建_成功(实际键)
}

函数 IDBObjectStore_put(store, 值, 键) {
    如果 (store == 0) { 返回 0 }

    定义 可变 实际键 = 键
    如果 (实际键 == 0 && store.键路径 != 0) {
        实际键 = IDB_提取键(值, store.键路径)
    }
    如果 (实际键 == 0 && store.自增) {
        实际键 = store.自增计数
        store.自增计数 = store.自增计数 + 1
    }

    // put: 存在则更新,不存在则插入
    定义 索引 = IDBObjectStore_查找(store, 实际键)
    如果 (索引 >= 0) {
        // 更新
        定义 偏移 = store.记录列表 + 索引 * 16
        内存_写64(偏移 + 8, 值)
    } 否则 {
        IDBObjectStore_插入记录(store, 实际键, 值)
    }

    IDBObjectStore_更新索引(store, 实际键, 值)
    返回 IDBRequest_创建_成功(实际键)
}

函数 IDBObjectStore_get(store, 键) {
    如果 (store == 0) { 返回 0 }
    定义 索引 = IDBObjectStore_查找(store, 键)
    如果 (索引 < 0) { 返回 IDBRequest_创建_成功(0) }
    定义 偏移 = store.记录列表 + 索引 * 16
    定义 值 = 内存_读64(偏移 + 8)
    返回 IDBRequest_创建_成功(值)
}

函数 IDBObjectStore_delete(store, 键) {
    如果 (store == 0) { 返回 0 }
    定义 索引 = IDBObjectStore_查找(store, 键)
    如果 (索引 < 0) { 返回 IDBRequest_创建_成功(0) }
    // 移除(移动后续元素)
    定义 可变 i = 索引
    当 (i < store.记录数量 - 1) {
        定义 src = store.记录列表 + (i + 1) * 16
        定义 dst = store.记录列表 + i * 16
        内存_写64(dst, 内存_读64(src))
        内存_写64(dst + 8, 内存_读64(src + 8))
        i = i + 1
    }
    store.记录数量 = store.记录数量 - 1
    返回 IDBRequest_创建_成功(0)
}

函数 IDBObjectStore_getAll(store, 查询, 最大数量) {
    如果 (store == 0) { 返回 0 }
    定义 可变 限制 = 最大数量
    如果 (限制 <= 0) { 限制 = store.记录数量 }

    定义 结果 = 堆_分配_数组(限制 * 8)
    定义 可变 计数 = 0
    定义 可变 i = 0
    当 (i < store.记录数量 && 计数 < 限制) {
        定义 偏移 = store.记录列表 + i * 16
        定义 值 = 内存_读64(偏移 + 8)
        内存_写64(结果 + 计数 * 8, 值)
        计数 = 计数 + 1
        i = i + 1
    }
    返回 [结果, 计数]
}

函数 IDBObjectStore_clear(store) {
    如果 (store == 0) { 返回 }
    store.记录数量 = 0
    // 清除索引
    定义 可变 i = 0
    当 (i < store.索引数量) {
        定义 idx = 内存_读64(store.索引列表 + i * 8)
        如果 (idx != 0) { idx.条目数量 = 0 }
        i = i + 1
    }
}

函数 IDBObjectStore_count(store) {
    如果 (store == 0) { 返回 0 }
    返回 store.记录数量
}

// 二分查找
函数 IDBObjectStore_查找(store, 键) {
    如果 (store == 0 || store.记录数量 == 0) { 返回 -1 }
    定义 可变 低 = 0
    定义 可变 高 = store.记录数量 - 1
    当 (低 <= 高) {
        定义 中 = (低 + 高) / 2
        定义 偏移 = store.记录列表 + 中 * 16
        定义 记录键 = 内存_读64(偏移)
        定义 比较 = IDB_比较键(记录键, 键)
        如果 (比较 == 0) { 返回 中 }
        如果 (比较 < 0) { 低 = 中 + 1 }
        否则 { 高 = 中 - 1 }
    }
    返回 -1
}

// merge source: 沙盒批次/批四/待厚/感知/表单验证.nova
// §4 表单验证 (Constraint Validation 接口)

定义 有效性_值缺失     = 0x01    // valueMissing (required)
定义 有效性_类型错误   = 0x02    // typeMismatch (email/url格式)
定义 有效性_模式不匹   = 0x04    // patternMismatch
定义 有效性_太长       = 0x08    // tooLong
定义 有效性_太短       = 0x10    // tooShort
定义 有效性_下溢       = 0x20    // rangeUnderflow (< min)
定义 有效性_上溢       = 0x40    // rangeOverflow (> max)
定义 有效性_步长错误   = 0x80    // stepMismatch
定义 有效性_自定义错误 = 0x100   // custom错误

函数 Input_验证(state) {
    定义 可变 有效性 = 0

    // required检查
    如果 (state.必填) {
        如果 (state.输入类型 == 输入类型_checkbox) {
            如果 (!state.已选中) { 有效性 = 有效性 | 有效性_值缺失 }
        } 否则 {
            如果 (state.值 == 0 || 字符串_长度(state.值) == 0) {
                有效性 = 有效性 | 有效性_值缺失
            }
        }
    }

    // 类型验证
    如果 (state.输入类型 == 输入类型_email && state.值 != 0 && 字符串_长度(state.值) > 0) {
        如果 (!Input_验证email(state.值)) { 有效性 = 有效性 | 有效性_类型错误 }
    }
    如果 (state.输入类型 == 输入类型_url && state.值 != 0 && 字符串_长度(state.值) > 0) {
        如果 (!Input_验证url(state.值)) { 有效性 = 有效性 | 有效性_类型错误 }
    }

    // maxlength/minlength
    如果 (state.值 != 0) {
        定义 长度 = 字符串_长度(state.值)
        如果 (state.最大长度 >= 0 && 长度 > state.最大长度) {
            有效性 = 有效性 | 有效性_太长
        }
        如果 (state.最小长度 > 0 && 长度 < state.最小长度) {
            有效性 = 有效性 | 有效性_太短
        }
    }

    // 数字范围
    如果 (state.输入类型 == 输入类型_number || state.输入类型 == 输入类型_range) {
        如果 (state.值 != 0 && 字符串_长度(state.值) > 0) {
            定义 数值 = 字符串转整数(state.值) * 100
            如果 (数值 < state.最小值) { 有效性 = 有效性 | 有效性_下溢 }
            如果 (数值 > state.最大值) { 有效性 = 有效性 | 有效性_上溢 }
        }
    }

    // 自定义错误
    如果 (state.自定义错误 != 0 && 字符串_长度(state.自定义错误) > 0) {
        有效性 = 有效性 | 有效性_自定义错误
    }

    state.有效性 = 有效性
    返回 有效性 == 0
}

函数 Input_验证email(值) {
    // 简单email验证: 必须包含@和.
    定义 长度 = 字符串_长度(值)
    定义 可变 有at = 假
    定义 可变 有点 = 假
    定义 可变 at位置 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 内存_读8(值 + i)
        如果 (c == 0x40) { 有at = 真; at位置 = i }
        如果 (c == 0x2E && i > at位置 && 有at) { 有点 = 真 }
        i = i + 1
    }
    返回 有at && 有点 && at位置 > 0 && at位置 < 长度 - 2
}

函数 Input_验证url(值) {
    定义 长度 = 字符串_长度(值)
    如果 (长度 < 8) { 返回 假 }
    // 简单检查: 以http://或https://开头
    返回 (字符串_等于N(值, 7, "http://") || 字符串_等于N(值, 8, "https://"))
}

// §5 HTMLForm元素 — 表单提交

结构 FormState {
    方法,    // u32 0=GET 1=POST
    动作URL,    // u64 action属性
    编码类型,    // u32 0=urlencoded 1=multipart 2=text
    目标,    // u64 target属性
    控件列表,    // u64 InputState*数组
    控件数量,
    控件容量,
    名,    // u64 name属性
}

函数 FormState_创建(元素) {
    定义 form = 堆_分配(FormState)
    form.方法 = 0    // GET
    form.编码类型 = 0
    form.控件容量 = 64
    form.控件列表 = 堆_分配_数组(form.控件容量 * 8)
    form.控件数量 = 0
    form.目标 = 0
    form.名 = 0

    如果 (元素 != 0) {
        定义 method = 元素_getAttribute(元素, "method")
        如果 (method != 0 && 字符串_相等_不区分大小写(method, "post")) {
            form.方法 = 1
        }
        form.动作URL = 元素_getAttribute(元素, "action")
        form.名 = 元素_getAttribute(元素, "name")
        form.目标 = 元素_getAttribute(元素, "target")
        定义 enctype = 元素_getAttribute(元素, "enctype")
        如果 (enctype != 0 && 字符串_相等_不区分大小写(enctype, "multipart/form-data")) {
            form.编码类型 = 1
        }
    }
    返回 form
}

函数 Form_提交(form) {
    如果 (form == 0) { 返回 }
    如果 (form.动作URL == 0) { 返回 }

    // 序列化表单数据
    定义 可变 数据 = ""
    定义 可变 首个 = 真
    定义 可变 i = 0
    当 (i < form.控件数量) {
        定义 控件 = 内存_读64(form.控件列表 + i * 8)
        如果 (控件 == 0 || 控件.已禁用) { i = i + 1; 继续 }
        如果 (控件.名 == 0 || 字符串_长度(控件.名) == 0) { i = i + 1; 继续 }

        // checkbox/radio: 只提交选中的
        如果 (控件.输入类型 == 输入类型_checkbox || 控件.输入类型 == 输入类型_radio) {
            如果 (!控件.已选中) { i = i + 1; 继续 }
        }

        // 按钮类: 不提交(除非是点击的submit按钮)
        如果 (控件.输入类型 == 输入类型_button || 控件.输入类型 == 输入类型_reset) {
            i = i + 1; 继续
        }

        如果 (!首个) { 数据 = 字符串_连接(数据, "&") }
        数据 = 字符串_连接(数据, URL_编码(控件.名))
        数据 = 字符串_连接(数据, "=")
        定义 可变 值 = 控件.值
        如果 (值 == 0) { 值 = "" }
        如果 (控件.输入类型 == 输入类型_checkbox) { 值 = "on" }
        数据 = 字符串_连接(数据, URL_编码(值))
        首个 = 假
        i = i + 1
    }

    // GET: 附加到URL  POST: 放在请求体
    如果 (form.方法 == 0) {
        定义 url = 字符串_连接(form.动作URL, "?")
        url = 字符串_连接(url, 数据)
        // 导航到url
    } 否则 {
        // POST请求
        定义 loader = ResourceLoader_创建(form.动作URL, 资源类型_XHR)
        loader.请求.方法 = HTTP_POST
        HTTP头部_添加(loader.请求.请求头, "Content-Type", "application/x-www-form-urlencoded")
        loader.请求.请求体 = 数据
        loader.请求.请求体长度 = 字符串_长度(数据)
        ResourceLoader_开始加载(loader)
    }
}

函数 URL_编码(str) {
    如果 (str == 0) { 返回 "" }
    定义 长度 = 字符串_长度(str)
    定义 结果 = 堆_分配(长度 * 3 + 1)
    定义 可变 si = 0
    定义 可变 di = 0
    定义 hex = "0123456789ABCDEF"

    当 (si < 长度) {
        定义 c = 内存_读8(str + si)
        // 安全字符: A-Z a-z 0-9 - _ . ~
        如果 ((c >= 0x41 && c <= 0x5A) || (c >= 0x61 && c <= 0x7A) ||
            (c >= 0x30 && c <= 0x39) || c == 0x2D || c == 0x5F || c == 0x2E || c == 0x7E) {
            内存_写8(结果 + di, c)
            di = di + 1
        }
        否则 如果 (c == 0x20) {
            // 空格 → +
            内存_写8(结果 + di, 0x2B)
            di = di + 1
        }
        否则 {
            // %XX编码
            内存_写8(结果 + di, 0x25)
            内存_写8(结果 + di + 1, 内存_读8(hex + (c >> 4)))
            内存_写8(结果 + di + 2, 内存_读8(hex + (c & 0x0F)))
            di = di + 3
        }
        si = si + 1
    }
    内存_写8(结果 + di, 0)
    返回 结果
}

// merge source: 沙盒批次/批三/待厚/感知/实体查找支.nova
// §2 实体查找 — 支持前缀匹配(HTML5规范要求)
// HTML5要求: &notit; 应该匹配 &not; + "it;"
// 即: 找到最长匹配的命名实体

函数 HTMLEntity_查找(名称, 名称长度) {
    如果 (实体表 == 0) { HTMLEntity_初始化表() }

    // 精确匹配优先
    定义 可变 i = 0
    定义 可变 最佳匹配 = -1
    定义 可变 最佳长度 = 0

    当 (i < 实体表大小) {
        定义 偏移 = 实体表 + i * 24
        定义 实体名 = 内存_读64(偏移)
        定义 实体名长 = 内存_读32(偏移 + 8)

        // 检查名称是否以此实体名开头(最长前缀匹配)
        如果 (实体名长 <= 名称长度 && 实体名长 > 最佳长度) {
            定义 可变 匹配 = 真
            定义 可变 j = 0
            当 (j < 实体名长) {
                如果 (内存_读8(名称 + j) != 内存_读8(实体名 + j)) {
                    匹配 = 假
                    跳出
                }
                j = j + 1
            }
            如果 (匹配) {
                最佳匹配 = i
                最佳长度 = 实体名长
            }
        }
        i = i + 1
    }

    如果 (最佳匹配 >= 0) {
        返回 实体表 + 最佳匹配 * 24
    }
    返回 0    // 未找到
}

// §3 字符引用解码主函数
// (对应 HTMLEntityParser::ConsumeHTMLEntity)
// 输入: 指向'&'之后的位置
// 输出: 解码后的UTF-8字节写入输出缓冲, 返回消耗的字符数
// HTML5 §12.2.5.72:
//   1. & 后跟 # → 数字引用
//   2. & 后跟字母 → 命名引用
//   3. & 后跟其他 → 不是引用,输出 '&'

结构 EntityResult {
    码点1,
    码点2,
    消耗长度,    // u32 从'&'开始消耗的字符数(含&)
    成功,
}

函数 HTMLEntity_解码(输入, 位置, 输入长度) {
    定义 结果 = EntityResult {}
    结果.成功 = 假
    结果.码点1 = 0
    结果.码点2 = 0
    结果.消耗长度 = 1    // 至少消耗'&'

    定义 pos = 位置 + 1    // 跳过 '&'
    如果 (pos >= 输入长度) { 返回 结果 }

    定义 c = 内存_读8(输入 + pos)

    如果 (c == 0x23) {    // '#'
        pos = pos + 1
        如果 (pos >= 输入长度) { 返回 结果 }

        定义 c2 = 内存_读8(输入 + pos)
        定义 可变 码点 = 0
        定义 可变 有数字 = 假

        如果 (c2 == 0x78 || c2 == 0x58) {
            pos = pos + 1
            当 (pos < 输入长度) {
                定义 ch = 内存_读8(输入 + pos)
                定义 可变 d = -1
                如果 (ch >= 0x30 && ch <= 0x39) { d = ch - 0x30 }
                否则 如果 (ch >= 0x41 && ch <= 0x46) { d = ch - 0x41 + 10 }
                否则 如果 (ch >= 0x61 && ch <= 0x66) { d = ch - 0x61 + 10 }
                如果 (d < 0) { 跳出 }
                码点 = 码点 * 16 + d
                有数字 = 真
                pos = pos + 1
                // 防止溢出
                如果 (码点 > 0x10FFFF) { 码点 = 0xFFFD; 跳出 }
            }
        } 否则 {
            当 (pos < 输入长度) {
                定义 ch = 内存_读8(输入 + pos)
                如果 (ch >= 0x30 && ch <= 0x39) {
                    码点 = 码点 * 10 + (ch - 0x30)
                    有数字 = 真
                    pos = pos + 1
                    如果 (码点 > 0x10FFFF) { 码点 = 0xFFFD; 跳出 }
                } 否则 { 跳出 }
            }
        }

        如果 (!有数字) { 返回 结果 }

        // 跳过可选的分号
        如果 (pos < 输入长度 && 内存_读8(输入 + pos) == 0x3B) {
            pos = pos + 1
        }

        // HTML5规范: 替换非法码点
        码点 = HTMLEntity_替换非法码点(码点)

        结果.码点1 = 码点
        结果.码点2 = 0
        结果.消耗长度 = pos - 位置
        结果.成功 = 真
        返回 结果
    }

    如果 (HTMLEntity_是字母(c)) {
        // 收集名称字符(字母和数字)
        定义 名称起始 = pos
        当 (pos < 输入长度) {
            定义 ch = 内存_读8(输入 + pos)
            如果 (HTMLEntity_是字母(ch) || (ch >= 0x30 && ch <= 0x39)) {
                pos = pos + 1
            } 否则 { 跳出 }
        }
        定义 名称长度 = pos - 名称起始

        // 查找实体
        定义 实体 = HTMLEntity_查找(输入 + 名称起始, 名称长度)
        如果 (实体 != 0) {
            定义 匹配长度 = 内存_读32(实体 + 8)
            结果.码点1 = 内存_读32(实体 + 12)
            结果.码点2 = 内存_读32(实体 + 16)

            // 检查分号
            定义 分号位置 = 名称起始 + 匹配长度
            如果 (分号位置 < 输入长度 && 内存_读8(输入 + 分号位置) == 0x3B) {
                结果.消耗长度 = 分号位置 + 1 - 位置
            } 否则 {
                // 无分号: HTML5允许某些实体不带分号
                // 但在属性值中,如果下一个字符是=或字母数字,则不匹配
                结果.消耗长度 = 名称起始 + 匹配长度 - 位置
            }
            结果.成功 = 真
            返回 结果
        }
    }

    返回 结果
}

函数 HTMLEntity_是字母(c) {
    返回 (c >= 0x41 && c <= 0x5A) || (c >= 0x61 && c <= 0x7A)
}

// §4 非法码点替换 (HTML5 §12.2.5.72)
// 某些Unicode码点在HTML中被替换为U+FFFD或其他值

函数 HTMLEntity_替换非法码点(码点) {
    // 0x00 → U+FFFD REPLACEMENT CHARACTER
    如果 (码点 == 0x00) { 返回 0xFFFD }

    // 0x0D → 忽略(回车)
    // 0x80-0x9F → Windows-1252替换表
    如果 (码点 >= 0x80 && 码点 <= 0x9F) {
        // HTML5规范: 这些码点映射到Windows-1252字符
        定义 替换表 = [
            0x20AC,  // 0x80 → €
            0x0081,  // 0x81 → (保持)
            0x201A,  // 0x82 → ‚
            0x0192,  // 0x83 → ƒ
            0x201E,  // 0x84 → „
            0x2026,  // 0x85 → …
            0x2020,  // 0x86 → †
            0x2021,  // 0x87 → ‡
            0x02C6,  // 0x88 → ˆ
            0x2030,  // 0x89 → ‰
            0x0160,  // 0x8A → Š
            0x2039,  // 0x8B → ‹
            0x0152,  // 0x8C → Œ
            0x008D,  // 0x8D → (保持)
            0x017D,  // 0x8E → Ž
            0x008F,  // 0x8F → (保持)
            0x0090,  // 0x90 → (保持)
            0x2018,  // 0x91 → '
            0x2019,  // 0x92 → '
            0x201C,  // 0x93 → "
            0x201D,  // 0x94 → "
            0x2022,  // 0x95 → •
            0x2013,  // 0x96 → –
            0x2014,  // 0x97 → —
            0x02DC,  // 0x98 → ˜
            0x2122,  // 0x99 → ™
            0x0161,  // 0x9A → š
            0x203A,  // 0x9B → ›
            0x0153,  // 0x9C → œ
            0x009D,  // 0x9D → (保持)
            0x017E,  // 0x9E → ž
            0x0178   // 0x9F → Ÿ
        ]
        返回 替换表[码点 - 0x80]
    }

    // 代理对范围: 非法
    如果 (码点 >= 0xD800 && 码点 <= 0xDFFF) { 返回 0xFFFD }

    // 非字符(noncharacter)
    如果 (码点 >= 0xFDD0 && 码点 <= 0xFDEF) { 返回 0xFFFD }
    如果 ((码点 & 0xFFFE) == 0xFFFE) { 返回 0xFFFD }    // U+xFFFE, U+xFFFF

    // 超过U+10FFFF
    如果 (码点 > 0x10FFFF) { 返回 0xFFFD }

    返回 码点
}

// merge source: 沙盒批次/批四/待厚/感知/全局数据库.nova
// §3 全局数据库管理

结构 IDBFactory {
    数据库列表,    // u64 IDBDatabase*数组
    数据库数,
    数据库容量,
}

定义 可变 全局IDB工厂 = 0

函数 IDB_获取工厂() {
    如果 (全局IDB工厂 == 0) {
        全局IDB工厂 = 堆_分配(IDBFactory)
        全局IDB工厂.数据库容量 = 32
        全局IDB工厂.数据库列表 = 堆_分配_数组(32 * 8)
        全局IDB工厂.数据库数 = 0
    }
    返回 全局IDB工厂
}

// indexedDB.open(name, version)
函数 IDB_open(名称, 版本) {
    定义 工厂 = IDB_获取工厂()
    // 查找已有
    定义 可变 i = 0
    当 (i < 工厂.数据库数) {
        定义 db = 内存_读64(工厂.数据库列表 + i * 8)
        如果 (db != 0 && 字符串_相等(db.名称, 名称)) {
            如果 (版本 > db.版本) {
                // 版本升级: 触发upgradeneeded
                IDB_升级(db, 版本)
            }
            返回 db
        }
        i = i + 1
    }
    // 新建
    定义 db = 堆_分配(IDBDatabase)
    db.名称 = 字符串_复制(名称)
    db.版本 = 版本
    db.存储容量 = 16
    db.存储 = 堆_分配_数组(16 * 8)
    db.存储数 = 0; db.已关闭 = 假
    如果 (工厂.数据库数 < 工厂.数据库容量) {
        内存_写64(工厂.数据库列表 + 工厂.数据库数 * 8, db)
        工厂.数据库数 = 工厂.数据库数 + 1
    }
    返回 db
}

函数 IDB_升级(db, 新版本) {
    如果 (db == 0) { 返回 }
    db.版本 = 新版本
    // 触发onupgradeneeded事件, 允许创建/删除对象存储
}

函数 IDB_deleteDatabase(名称) {
    定义 工厂 = IDB_获取工厂()
    定义 可变 i = 0
    当 (i < 工厂.数据库数) {
        定义 db = 内存_读64(工厂.数据库列表 + i * 8)
        如果 (db != 0 && 字符串_相等(db.名称, 名称)) {
            内存_写64(工厂.数据库列表 + i * 8, 0)
            返回 真
        }
        i = i + 1
    }
    返回 假
}

// §4 ObjectStore操作

函数 IDB_createObjectStore(db, 名称, keyPath, autoInc) {
    如果 (db == 0 || db.存储数 >= db.存储容量) { 返回 0 }
    定义 store = 堆_分配(IDBObjectStore)
    store.名称 = 字符串_复制(名称)
    store.keyPath = 如果(keyPath != 0, 字符串_复制(keyPath), 0)
    store.autoIncrement = autoInc
    store.当前键值 = 1
    store.主树根 = BPlus_创建叶子()
    store.记录数 = 0
    store.索引容量 = 8
    store.索引 = 堆_分配_数组(8 * 8)
    store.索引数 = 0
    内存_写64(db.存储 + db.存储数 * 8, store)
    db.存储数 = db.存储数 + 1
    返回 store
}

函数 IDB_getObjectStore(db, 名称) {
    如果 (db == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < db.存储数) {
        定义 store = 内存_读64(db.存储 + i * 8)
        如果 (store != 0 && 字符串_相等(store.名称, 名称)) { 返回 store }
        i = i + 1
    }
    返回 0
}

// store.put(value, key?) — 添加/更新记录
函数 IDB_put(store, 值, 值长度, 键) {
    如果 (store == 0 || 值 == 0) { 返回 假 }
    // 确定键
    定义 可变 实际键 = 键
    如果 (实际键 == 0) {
        如果 (store.keyPath != 0) {
            // 从值中提取keyPath对应的属性作为键
            实际键 = IDB_提取键(值, store.keyPath)
        } 否则 如果 (store.autoIncrement) {
            实际键 = IDBKey_数字(store.当前键值)
            store.当前键值 = store.当前键值 + 1
        } 否则 {
            返回 假    // 无键
        }
    }

    // 创建记录
    定义 rec = 堆_分配(IDBRecord)
    rec.键 = 实际键
    rec.值 = 堆_分配(值长度)
    内存_复制(rec.值, 值, 值长度)
    rec.值长度 = 值长度; rec.下一个 = 0

    // 插入B+树
    BPlus_插入(store.主树根, 实际键, rec)
    store.记录数 = store.记录数 + 1

    // 更新二级索引
    定义 可变 i = 0
    当 (i < store.索引数) {
        定义 idx = 内存_读64(store.索引 + i * 8)
        如果 (idx != 0) {
            定义 索引键 = IDB_提取键(值, idx.keyPath)
            如果 (索引键 != 0) {
                BPlus_插入(idx.根节点, 索引键, rec)
                idx.记录数 = idx.记录数 + 1
            }
        }
        i = i + 1
    }
    返回 真
}

// store.get(key) — 精确查找
函数 IDB_get(store, 键) {
    如果 (store == 0 || 键 == 0 || store.主树根 == 0) { 返回 0 }
    返回 BPlus_查找(store.主树根, 键)
}

// store.delete(key)
函数 IDB_delete(store, 键) {
    如果 (store == 0 || 键 == 0) { 返回 假 }
    定义 ok = BPlus_删除(store.主树根, 键)
    如果 (ok) { store.记录数 = store.记录数 - 1 }
    返回 ok
}

// store.clear()
函数 IDB_clear(store) {
    如果 (store == 0) { 返回 }
    store.主树根 = BPlus_创建叶子()
    store.记录数 = 0
}

// store.count(range?)
函数 IDB_count(store, 范围) {
    如果 (store == 0) { 返回 0 }
    如果 (范围 == 0) { 返回 store.记录数 }
    // 遍历范围计数
    定义 可变 计数 = 0
    定义 cursor = IDB_openCursor(store, 范围, IDB_CURSOR_NEXT)
    当 (cursor != 0 && !cursor.已完成) {
        计数 = 计数 + 1
        IDB_cursor_continue(cursor)
    }
    返回 计数
}

// merge source: 沙盒批次/批五/待厚/感知/会话.nova
// §3 SDP — Session Description Protocol

定义 SDP_TYPE_OFFER    = 0
定义 SDP_TYPE_ANSWER   = 1
定义 SDP_TYPE_PRANSWER = 2
定义 SDP_TYPE_ROLLBACK = 3

结构 RTCSessionDescription {
    类型,    // u32 SDP_TYPE_xxx
    sdp,    // u64 SDP文本
}

结构 SDP媒体Section {
    类型,    // u64 "audio"/"video"/"application"
    端口,
    协议,    // u64 "数报/安全/RTP/SAVPF"
    // 编解码
    编解码列表,    // u64 SDPCodec*数组
    编解码数量,
    // ICE参数
    ice_ufrag,
    ice_pwd,
    // D安全指纹
    dtls_指纹,
    dtls_setup,    // u64 "actpass"/"active"/"passive"
    // 方向
    方向,    // u32 0=sendrecv 1=sendonly 2=recvonly 3=inactive
}

结构 SDPCodec {
    payload_type,    // u32 PT号
    名称,    // u64 "opus"/"VP8"/"H264"等
    时钟率,    // u32 48000/90000等
    通道数,    // u32 音频通道
    参数,    // u64 fmtp参数
}

函数 SDP_解析(sdp文本) {
    // 解析SDP文本为结构化数据
    如果 (sdp文本 == 0) { 返回 0 }
    // 创建基本RTCSessionDescription结构
    定义 desc = 堆_分配(RTCSessionDescription)
    desc.sdp = 字符串_复制(sdp文本)
    返回 desc
}

函数 SDP_生成_offer(本地能力) {
    // 根据本地编解码能力生成offer SDP
    返回 "v=0\r\no=- 0 0 IN IP4 0.0.0.0\r\ns=-\r\n"
}

函数 SDP_生成_answer(offer, 本地能力) {
    // 根据offer和本地能力生成answer SDP
    返回 "v=0\r\no=- 0 0 IN IP4 0.0.0.0\r\ns=-\r\n"
}

// §4 R传控eerConnection

结构 R传控eerConnection {
    // ICE
    ice状态,    // u32 ICE_STATE_xxx
    ice收集状态,    // u32 ICE_GATHER_xxx
    // 信令状态
    信令状态,    // u32 SIGNAL_STATE_xxx
    连接状态,    // u32 PC_STATE_xxx
    // 描述
    本地描述,    // u64 RTCSessionDescription*
    远端描述,
    // 待处理描述
    待处理本地,
    待处理远端,
    // ICE候选
    本地候选列表,    // u64 ICECandidate*数组
    本地候选数量,
    远端候选列表,
    远端候选数量,
    候选容量,
    // ICE配置
    ice服务器列表,    // u64 STUN/TURN服务器
    ice服务器数量,
    // 媒体轨道
    本地流列表,    // u64 媒体Stream*
    本地流数量,
    远端流列表,
    远端流数量,
    // RTCRtpTransceiver
    收发器列表,
    收发器数量,
    // DataChannel
    数据通道列表,
    数据通道数量,
    // 回调
    onicecandidate,
    oniceconnectionstatechange,
    onsignalingstatechange,
    onconnectionstatechange,
    ontrack,
    ondatachannel,
    onnegotiationneeded,
    onicegatheringstatechange,
    // D安全
    dtls上下文,
    // SCTP (DataChannel用)
    sctp关联,
}

函数 R传控eerConnection_创建(配置) {
    定义 pc = 堆_分配(R传控eerConnection)
    pc.ice状态 = ICE_STATE_NEW
    pc.ice收集状态 = ICE_GATHER_NEW
    pc.信令状态 = SIGNAL_STATE_STABLE
    pc.连接状态 = PC_STATE_NEW
    pc.本地描述 = 0; pc.远端描述 = 0
    pc.待处理本地 = 0; pc.待处理远端 = 0

    pc.候选容量 = 64
    pc.本地候选列表 = 堆_分配_数组(64 * 8); pc.本地候选数量 = 0
    pc.远端候选列表 = 堆_分配_数组(64 * 8); pc.远端候选数量 = 0

    pc.本地流列表 = 堆_分配_数组(8 * 8); pc.本地流数量 = 0
    pc.远端流列表 = 堆_分配_数组(8 * 8); pc.远端流数量 = 0
    pc.收发器列表 = 堆_分配_数组(16 * 8); pc.收发器数量 = 0
    pc.数据通道列表 = 堆_分配_数组(16 * 8); pc.数据通道数量 = 0

    // 解析ICE服务器配置
    如果 (配置 != 0) {
        R传控eerConnection_解析配置(pc, 配置)
    }

    返回 pc
}

函数 R传控eerConnection_解析配置(pc, 配置) {
    如果 (pc == 0 || 配置 == 0) { 返回 }
    定义 servers = Nova对象_获取属性(配置, "iceServers")
    如果 (servers != 0) {
        定义 可变 i = 0
        当 (i < Nova数组_长度(servers)) {
            定义 srv = Nova数组_取(servers, i)
            定义 urls = Nova对象_获取属性(srv, "urls")
            如果 (urls != 0) {
                pc.ICE服务器[pc.ICE服务器数量] = urls
                pc.ICE服务器数量 = pc.ICE服务器数量 + 1
            }
            i = i + 1
        }
    }
    定义 策略 = Nova对象_获取属性(配置, "iceTransportPolicy")
    如果 (策略 != 0) { pc.ICE传输策略 = 策略 }
}

// merge source: 沙盒批次/批五/待厚/感知/分配元素的.nova
// §2 Slot分配 — <slot>元素的内容分配
// (对应 SlotAssignment)
// Light DOM (host的子节点) 通过slot分配到Shadow DOM中
// <my-el>
// <span slot="title">Hello</span> ← 这个被分配到shadow中name="title"的slot
// <p>Content</p> ← 这个被分配到默认slot
// </my-el>

结构 SlotAssignment {
 slot节点,    // u64 <slot>元素的节点*
 slot名,    // u64 name属性(空=""为默认slot)
 分配节点,    // u64 被分配到此slot的节点*列表
 分配数量,
 分配容量,
}

函数 ShadowRoot_分配Slot(sr) {
 如果 (sr == 0 || !sr.需要slot分配) { 返回 }
 sr.需要slot分配 = 假

 // 收集shadow中所有<slot>元素
 sr.slot数量 = 0
 ShadowRoot_收集Slot递归(sr, sr.节点)

 // 遍历host的light DOM子节点,分配到对应slot
 定义 宿主 = sr.宿主
 如果 (宿主 == 0) { 返回 }

 定义 可变 子 = 宿主.第一子节点
 当 (子 != 0) {
 定义 可变 目标slot名 = ""
 如果 (子.节点类型 == 元素_节点) {
 定义 slot属性 = 元素_getAttribute(子, "slot")
 如果 (slot属性 != 0) { 目标slot名 = slot属性 }
 }

 // 找到对应的slot
 定义 可变 找到 = 假
 定义 可变 si = 0
 当 (si < sr.slot数量) {
 定义 sa偏移 = sr.slot列表 + si * 16
 定义 slot名 = 内存_读64(sa偏移 + 8)
 如果 (slot名 == 0) { slot名 = "" }
 如果 (字符串_相等(slot名, 目标slot名)) {
 // 分配到此slot
 // 将子节点添加到slot的分配列表
 Slot_添加分配节点(内存_读64(sa偏移), child)
 找到 = 真
 跳出
 }
 si = si + 1
 }

 // 未找到对应slot: 分配到默认slot(name="")
 如果 (!找到) {
 si = 0
 当 (si < sr.slot数量) {
 定义 sa偏移 = sr.slot列表 + si * 16
 定义 slot名 = 内存_读64(sa偏移 + 8)
 如果 (slot名 == 0 || 字符串_长度(slot名) == 0) {
 找到 = 真; 跳出
 }
 si = si + 1
 }
 }

 子 = 子.后一兄弟
 }
}

函数 ShadowRoot_收集Slot递归(sr, 节点) {
 如果 (节点 == 0) { 返回 }
 如果 (节点.节点类型 == 元素_节点) {
 定义 扩展 = 元素_获取扩展(节点)
 如果 (扩展 != 0 && 字符串_相等_不区分大小写(扩展.标签名, "slot")) {
 如果 (sr.slot数量 < 16) {
 定义 偏移 = sr.slot列表 + sr.slot数量 * 16
 内存_写64(偏移, 节点)
 内存_写64(偏移 + 8, 元素_getAttribute(节点, "name"))
 sr.slot数量 = sr.slot数量 + 1
 }
 }
 }
 定义 可变 子 = 节点.第一子节点
 当 (子 != 0) {
 ShadowRoot_收集Slot递归(sr, 子)
 子 = 子.后一兄弟
 }
}

// §3 扁平树遍历 (Flat Tree Traversal)
// (对应 FlatTreeTraversal)
// 合并light DOM和shadow DOM后的渲染树
// 布局/绘制使用扁平树而非DOM树

函数 FlatTree_第一子(节点) {
 如果 (节点 == 0) { 返回 0 }

 // 检查是否有shadow root
 如果 (节点.节点类型 == 元素_节点) {
 定义 扩展 = 元素_获取扩展(节点)
 如果 (扩展 != 0 && 扩展.shadowRoot != 0) {
 // 有shadow: 返回shadow root的第一个子节点(不是host的子节点)
 定义 sr = 扩展.shadowRoot
 返回 sr.节点.第一子节点
 }
 }

 // 检查节点是否是<slot>
 如果 (节点.节点类型 == 元素_节点) {
 定义 扩展 = 元素_获取扩展(节点)
 如果 (扩展 != 0 && 字符串_相等_不区分大小写(扩展.标签名, "slot")) {
 // <slot>: 返回被分配的第一个节点(而非slot自己的子节点)
 // 返回被分配的第一个节点, 没有则返回fallback(自身子节点)
 定义 分配列表 = Slot_获取分配节点(扩展)
 如果 (分配列表 != 0 && 分配列表.长度 > 0) {
 返回 分配列表.第一个
 }
 返回 节点.第一子节点
 }
 }

 返回 节点.第一子节点
}

函数 FlatTree_下一兄弟(节点) {
 如果 (节点 == 0) { 返回 0 }
 返回 节点.后一兄弟
}

函数 FlatTree_父(节点) {
 如果 (节点 == 0) { 返回 0 }
 定义 父 = 节点.父节点

 // 如果父是shadow root,返回host
 如果 (父 != 0 && 父.节点类型 == 11) { // DOCUMENT_FRAGMENT_节点
 // 检查是否是ShadowRoot
 // 检查是否是ShadowRoot: 通过host字段判断
 定义 sr = ShadowRoot_从DFN获取(父)
 如果 (sr != 0) { 返回 sr.host } // shadow root的host
 返回 父.父节点
 }

 返回 父
}

// merge source: 沙盒批次/批五/待厚/感知/元素创建.nova
// §2 元素创建
// (对应 Document::Create元素 / HTML元素Factory)

函数 元素_创建(标签名, 文档) {
 // 创建基础节点
 定义 节点 = 节点_创建(元素_节点, 节点标志_是元素 | 节点标志_是容器节点)
 节点.树作用域 = 文档

 // 创建元素扩展数据
 定义 扩展 = 堆_分配(元素扩展)
 扩展.基础节点 = 节点
 扩展.标签名字符串 = 字符串_复制(标签名)
 扩展.标签名原子 = 原子_驻留(字符串_转小写(标签名))
 扩展.命名空间URI = 1 // HTML命名空间
 扩展.前缀 = 0
 扩展.id原子 = 0
 扩展.class原子列表 = 0
 扩展.class数量 = 0
 扩展.shadow_root = 0
 扩展.before伪元素 = 0
 扩展.after伪元素 = 0
 扩展.计算样式 = 0
 扩展.scroll_top = 0
 扩展.scroll_left = 0

 // 创建元素Data
 扩展.元素数据 = 元素Data_创建()

 // 存储扩展指针到节点的渲染样式字段(复用)
 // (真实传统引擎中元素直接继承节点, 这里用组合模式)
 节点.渲染样式 = 扩展

 返回 节点
}

// §3 属性操作 — getAttribute / setAttribute / removeAttribute / hasAttribute

函数 元素_tagName(节点) {
 定义 扩展 = 元素_获取扩展(节点)
 如果 (扩展 == 0) { 返回 0 }
 返回 扩展.标签名字符串
}

函数 元素_setAttribute(节点, 属性名, 属性值) {
 // DOM spec: 元素.setAttribute(name, value)
 定义 扩展 = 元素_获取扩展(节点)
 如果 (扩展 == 0) { 返回 }

 定义 数据 = 扩展.元素数据
 如果 (数据 == 0) { 返回 }

 // 确保数据可写
 如果 (数据.是共享的) {
 数据 = 元素Data_取消共享(数据)
 扩展.元素数据 = 数据
 }

 定义 名称原子 = 原子_驻留(字符串_转小写(属性名))
 定义 值副本 = 字符串_复制(属性值)

 // 查找已有属性
 定义 可变 i = 0
 当 (i < 数据.属性数量) {
 定义 属性 = 元素Data_第N个属性(数据, i)
 如果 (属性.本地名 == 名称原子) {
 // 更新值
 元素Data_设置属性值(数据, i, 值副本)
 元素_属性变更回调(节点, 名称原子, 属性.值, 值副本)
 返回
 }
 i = i + 1
 }

 // 新增属性
 定义 新属性 = 属性项 {}
 新属性.命名空间 = 0
 新属性.本地名 = 名称原子
 新属性.名称字符串 = 字符串_复制(属性名)
 新属性.值 = 值副本
 元素Data_添加属性(数据, 新属性)

 元素_属性变更回调(节点, 名称原子, 0, 值副本)
}

函数 元素_removeAttribute(节点, 属性名) {
 // DOM spec: 元素.removeAttribute(name)
 定义 扩展 = 元素_获取扩展(节点)
 如果 (扩展 == 0) { 返回 }

 定义 数据 = 扩展.元素数据
 如果 (数据 == 0 || 数据.属性数量 == 0) { 返回 }

 定义 名称原子 = 原子_驻留(字符串_转小写(属性名))
 定义 可变 i = 0
 当 (i < 数据.属性数量) {
 定义 属性 = 元素Data_第N个属性(数据, i)
 如果 (属性.本地名 == 名称原子) {
 定义 旧值 = 属性.值
 元素Data_移除属性(数据, i)
 元素_属性变更回调(节点, 名称原子, 旧值, 0)
 返回
 }
 i = i + 1
 }
}

函数 元素_hasAttribute(节点, 属性名) {
 返回 元素_getAttribute(节点, 属性名) != 0
}

// merge source: 沙盒批次/批五/待厚/感知/接口.nova
// §4 Range 接口

定义 RANGE_START_TO_START = 0
定义 RANGE_START_TO_END   = 1
定义 RANGE_END_TO_END     = 2
定义 RANGE_END_TO_START   = 3

结构 Range {
    // 起点
    startContainer,    // u64 节点*
    startOffset,
    // 终点
    endContainer,    // u64 节点*
    endOffset,
    // 是否折叠(起点=终点)
    collapsed,
    // 公共祖先
    commonAncestor,    // u64 节点*
}

函数 Range_创建() {
    定义 r = 堆_分配(Range)
    r.startContainer = 0; r.startOffset = 0
    r.endContainer = 0; r.endOffset = 0
    r.collapsed = 真; r.commonAncestor = 0
    返回 r
}

函数 Range_setStart(r, 节点, offset) {
    如果 (r == 0 || 节点 == 0) { 返回 }
    r.startContainer = 节点; r.startOffset = offset
    Range_更新状态(r)
}

函数 Range_setEnd(r, 节点, offset) {
    如果 (r == 0 || 节点 == 0) { 返回 }
    r.endContainer = 节点; r.endOffset = offset
    Range_更新状态(r)
}

函数 Range_setStartBefore(r, 节点) {
    如果 (r == 0 || 节点 == 0) { 返回 }
    // r.startContainer = 节点.parent节点
    // r.startOffset = 节点在父节点中的索引
    Range_更新状态(r)
}

函数 Range_setStartAfter(r, 节点) {
    如果 (r == 0 || 节点 == 0) { 返回 }
    Range_更新状态(r)
}

函数 Range_setEndBefore(r, 节点) {
    如果 (r == 0 || 节点 == 0) { 返回 }
    Range_更新状态(r)
}

函数 Range_setEndAfter(r, 节点) {
    如果 (r == 0 || 节点 == 0) { 返回 }
    Range_更新状态(r)
}

函数 Range_select节点(r, 节点) {
    如果 (r == 0 || 节点 == 0) { 返回 }
    // 选中整个节点
    Range_setStartBefore(r, 节点)
    Range_setEndAfter(r, 节点)
}

函数 Range_select节点Contents(r, 节点) {
    如果 (r == 0 || 节点 == 0) { 返回 }
    r.startContainer = 节点; r.startOffset = 0
    r.endContainer = 节点; r.endOffset = 0    // =child节点s.length或textContent.length
    Range_更新状态(r)
}

函数 Range_collapse(r, toStart) {
    如果 (r == 0) { 返回 }
    如果 (toStart) {
        r.endContainer = r.startContainer; r.endOffset = r.startOffset
    } 否则 {
        r.startContainer = r.endContainer; r.startOffset = r.endOffset
    }
    r.collapsed = 真
}

函数 Range_cloneContents(r) {
    如果 (r == 0) { 返回 0 }
    // 克隆Range内的DOM片段 → DocumentFragment
    返回 0
}

函数 Range_extractContents(r) {
    如果 (r == 0) { 返回 0 }
    // 从DOM中移除Range内的内容, 返回DocumentFragment
    返回 0
}

函数 Range_deleteContents(r) {
    如果 (r == 0) { 返回 }
    // 删除Range内的所有内容
    r.collapsed = 真
}

函数 Range_insert节点(r, 节点) {
    如果 (r == 0 || 节点 == 0) { 返回 }
    // 在Range起点处插入节点
}

函数 Range_surroundContents(r, newParent) {
    如果 (r == 0 || newParent == 0) { 返回 }
    // 用newParent包裹Range内容
}

函数 Range_compareBoundaryPoints(r, how, sourceRange) {
    如果 (r == 0 || sourceRange == 0) { 返回 0 }
    // 比较两个Range的边界点
    // 返回: -1/0/1
    返回 0
}

函数 Range_getBoundingClientRect(r) {
    如果 (r == 0) { 返回 0 }
    // 返回DOMRect: Range内容的边界矩形
    返回 0
}

函数 Range_toString(r) {
    如果 (r == 0) { 返回 "" }
    // 返回Range内的纯文本
    返回 ""
}

函数 Range_更新状态(r) {
    如果 (r == 0) { 返回 }
    r.collapsed = (r.startContainer == r.endContainer && r.startOffset == r.endOffset)
    // 计算commonAncestor
    r.commonAncestor = Range_找公共祖先(r.startContainer, r.endContainer)
}

函数 Range_找公共祖先(a, b) {
    如果 (a == 0 || b == 0) { 返回 0 }
    // 向上遍历两个节点的祖先链, 找到最近公共祖先
    返回 0
}

// merge source: 沙盒批次/批五/待厚/感知/列目录接口.nova
// §2 Fullscreen 接口 — 全屏模式
// 元素.requestFullscreen() / document.exitFullscreen()

定义 FS_STATE_NONE       = 0
定义 FS_STATE_PENDING    = 1
定义 FS_STATE_FULLSCREEN = 2

结构 FullscreenState {
    当前元素,    // u64 元素* (当前全屏的元素)
    状态,    // u32 FS_STATE_xxx
    // 全屏栈(嵌套全屏)
    元素栈,    // u64 元素*数组
    栈深度,
    // 导航选项
    navigationUI,    // u32 0=auto 1=show 2=hide
}

定义 可变 全局全屏状态 = 0

函数 Fullscreen_获取状态() {
    如果 (全局全屏状态 == 0) {
        全局全屏状态 = 堆_分配(FullscreenState)
        全局全屏状态.当前元素 = 0
        全局全屏状态.状态 = FS_STATE_NONE
        全局全屏状态.元素栈 = 堆_分配_数组(8 * 8)
        全局全屏状态.栈深度 = 0
    }
    返回 全局全屏状态
}

函数 元素_requestFullscreen(元素, 选项) {
    如果 (元素 == 0) { 返回 }
    定义 fs = Fullscreen_获取状态()

    // 检查: 需要用户手势 / iframe需要allowfullscreen
    // 检查: 元素不能是dialog(非modal)

    // 入栈
    如果 (fs.栈深度 < 8) {
        内存_写64(fs.元素栈 + fs.栈深度 * 8, 元素)
        fs.栈深度 = fs.栈深度 + 1
    }

    fs.当前元素 = 元素
    fs.状态 = FS_STATE_FULLSCREEN

    // 通知平台进入全屏
    平台_进入全屏()

    // 触发fullscreenchange事件
    // document.fullscreen元素 = 元素
}

函数 Document_exitFullscreen() {
    定义 fs = Fullscreen_获取状态()
    如果 (fs.状态 != FS_STATE_FULLSCREEN) { 返回 }

    // 出栈
    如果 (fs.栈深度 > 0) {
        fs.栈深度 = fs.栈深度 - 1
        如果 (fs.栈深度 > 0) {
            fs.当前元素 = 内存_读64(fs.元素栈 + (fs.栈深度 - 1) * 8)
        } 否则 {
            fs.当前元素 = 0
            fs.状态 = FS_STATE_NONE
            平台_退出全屏()
        }
    }

    // 触发fullscreenchange事件
}

函数 Document_fullscreen元素() {
    定义 fs = Fullscreen_获取状态()
    返回 fs.当前元素
}

函数 Document_fullscreenEnabled() {
    返回 真    // 默认允许(后续按权限策略过滤)
}

// §3 Screen Wake Lock 接口 — 防止屏幕休眠
// const wakeLock = await navigator.wakeLock.request('screen')
// wakeLock.release()

定义 WAKELOCK_TYPE_SCREEN = 0

结构 WakeLockSentinel {
    类型,    // u32 WAKELOCK_TYPE_SCREEN
    已释放,
    onrelease,    // u64 回调
}

定义 可变 活跃WakeLock列表 = 0
定义 可变 活跃WakeLock数量 = 0

函数 WakeLock_request(Nova运行时实例, 类型) {
    // 返回承诺<WakeLockSentinel>
    // 检查: 页面必须可见(Page Visibility 接口)
    如果 (!PageVisibility_是否可见()) {
        返回 0    // 拒绝
    }

    定义 sentinel = 堆_分配(WakeLockSentinel)
    sentinel.类型 = WAKELOCK_TYPE_SCREEN
    sentinel.已释放 = 假
    sentinel.onrelease = 0

    // 通知平台保持屏幕唤醒
    平台_请求屏幕唤醒()

    // 注册
    如果 (活跃WakeLock列表 == 0) {
        活跃WakeLock列表 = 堆_分配_数组(16 * 8)
        活跃WakeLock数量 = 0
    }
    如果 (活跃WakeLock数量 < 16) {
        内存_写64(活跃WakeLock列表 + 活跃WakeLock数量 * 8, sentinel)
        活跃WakeLock数量 = 活跃WakeLock数量 + 1
    }

    返回 sentinel
}

函数 WakeLockSentinel_release(sentinel) {
    如果 (sentinel == 0 || sentinel.已释放) { 返回 }
    sentinel.已释放 = 真

    // 从列表移除
    定义 可变 i = 0
    当 (i < 活跃WakeLock数量) {
        如果 (内存_读64(活跃WakeLock列表 + i * 8) == sentinel) {
            活跃WakeLock数量 = 活跃WakeLock数量 - 1
            内存_写64(活跃WakeLock列表 + i * 8, 内存_读64(活跃WakeLock列表 + 活跃WakeLock数量 * 8))
            跳出
        }
        i = i + 1
    }

    // 如果没有活跃的wake lock,允许屏幕休眠
    如果 (活跃WakeLock数量 == 0) {
        平台_释放屏幕唤醒()
    }

    // 触发release事件
}


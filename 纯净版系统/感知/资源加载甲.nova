// Nova AI原生网络引擎: ResourceLoader — 智能资源加载器
// 【创新突破】传统方案: 资源按发现顺序加载,不区分重要性
//   Nova ResourceLoader = NovaOS核心引擎 + 以下AI原生能力:
//   ① 语义优先级加载 — 正文CSS/字体优先,广告/跟踪器延迟
//   ② 加载耗时统计 — 跟踪每个资源的加载耗时和大小
//   ③ 智能重试 — 根据失败原因调整重试策略
//   ④ 带宽分配 — 根据语义优先级分配网络带宽
// NovaOS实现: 
// 实现: 取数规范 (https://fetch.spec.whatwg.org/)
// NovaOS版直接走内核传控/IP栈的Nova系统调用

// HTTP方法

定义 HTTP_GET     = 1
定义 HTTP_POST    = 2
定义 HTTP_PUT     = 3
定义 HTTP_DELETE  = 4
定义 HTTP_HEAD    = 5
定义 HTTP_OPTIONS = 6
定义 HTTP_PATCH   = 7

// 资源类型 

定义 资源类型_主文档 = 1 // HTML主页面
定义 资源类型_样式表 = 2 // CSS
定义 资源类型_脚本 = 3 // JavaScript
定义 资源类型_图片 = 4 // 图像 (png/jpg/gif/webp/svg)
定义 资源类型_字体 = 5 // 字体 (woff/woff2/ttf/otf)
定义 资源类型_XHR = 6 // XMLHttpRequest / fetch()
定义 资源类型_媒体 = 7 // 音频/视频
定义 资源类型_清单 = 8 // Manifest
定义 资源类型_预取 = 9 // Prefetch
定义 资源类型_长连接 = 10
定义 资源类型_Favicon = 11

// 请求优先级 (net::RequestPriority)

定义 优先级_最高 = 4 // 主文档/CSS
定义 优先级_高 = 3 // 同步脚本
定义 优先级_中 = 2 // 异步脚本/字体
定义 优先级_低 = 1 // 图片
定义 优先级_最低 = 0 // 预取

// 请求状态

定义 请求状态_未发送 = 0
定义 请求状态_已打开 = 1
定义 请求状态_发送中 = 2
定义 请求状态_接收头 = 3
定义 请求状态_接收体 = 4
定义 请求状态_完成 = 5
定义 请求状态_失败 = 6
定义 请求状态_取消 = 7

// URL解析 (WHATWG URL Standard)
// (对应 或 KURL)

结构 URL {
 完整URL,    // u64 完整URL字符串
 协议,    // u64 "http" / "https" / "file" / "data" / "blob"
 协议长度,
 主机,    // u64 主机名 "www.example.com"
 主机长度,
 端口,    // u32 端口号 (0=默认: http=80, https=443)
 路径,    // u64 "/path/to/page"
 路径长度,
 查询,    // u64 "?key=value&..."
 查询长度,
 片段,    // u64 "#fragment"
 片段长度,
 是安全的,    // 布尔 https
}

函数 URL_解析(url字符串) {
 定义 url = 堆_分配(URL)
 url.完整URL = 字符串_复制(url字符串)
 定义 长度 = 字符串_长度(url字符串)
 定义 可变 pos = 0

 // 解析协议 (scheme)
 url.协议 = url字符串
 定义 可变 协议结束 = 0
 当 (协议结束 < 长度) {
 如果 (内存_读8(url字符串 + 协议结束) == 0x3A) { 跳出 } // ':'
 协议结束 = 协议结束 + 1
 }
 url.协议 = 字符串_复制_N(url字符串, 协议结束)
 url.协议长度 = 协议结束
 url.是安全的 = 字符串_等于N(url.协议, url.协议长度, "https")

 pos = 协议结束 + 1
 // 跳过 "//"
 如果 (pos < 长度 - 1 && 内存_读8(url字符串 + pos) == 0x2F && 内存_读8(url字符串 + pos + 1) == 0x2F) {
 pos = pos + 2
 }

 // 解析主机(直到 '/' 或 ':' 或字符串结束)
 定义 主机开始 = pos
 当 (pos < 长度) {
 定义 c = 内存_读8(url字符串 + pos)
 如果 (c == 0x2F || c == 0x3A || c == 0x3F || c == 0x23) { 跳出 }
 pos = pos + 1
 }
 url.主机 = 字符串_复制_N(url字符串 + 主机开始, pos - 主机开始)
 url.主机长度 = pos - 主机开始

 // 解析端口(可选)
 url.端口 = 0
 如果 (pos < 长度 && 内存_读8(url字符串 + pos) == 0x3A) {
 pos = pos + 1
 当 (pos < 长度 && 内存_读8(url字符串 + pos) >= 0x30 && 内存_读8(url字符串 + pos) <= 0x39) {
 url.端口 = url.端口 * 10 + (内存_读8(url字符串 + pos) - 0x30)
 pos = pos + 1
 }
 }
 如果 (url.端口 == 0) {
 如果 (url.是安全的) { url.端口 = 443 }
 否则 { url.端口 = 80 }
 }

 // 解析路径
 定义 路径开始 = pos
 当 (pos < 长度) {
 定义 c = 内存_读8(url字符串 + pos)
 如果 (c == 0x3F || c == 0x23) { 跳出 }
 pos = pos + 1
 }
 如果 (pos > 路径开始) {
 url.路径 = 字符串_复制_N(url字符串 + 路径开始, pos - 路径开始)
 url.路径长度 = pos - 路径开始
 } 否则 {
 url.路径 = 字符串_复制("/")
 url.路径长度 = 1
 }

 // 解析查询
 url.查询 = 0; url.查询长度 = 0
 如果 (pos < 长度 && 内存_读8(url字符串 + pos) == 0x3F) {
 pos = pos + 1
 定义 查询开始 = pos
 当 (pos < 长度 && 内存_读8(url字符串 + pos) != 0x23) {
 pos = pos + 1
 }
 url.查询 = 字符串_复制_N(url字符串 + 查询开始, pos - 查询开始)
 url.查询长度 = pos - 查询开始
 }

 // 解析片段
 url.片段 = 0; url.片段长度 = 0
 如果 (pos < 长度 && 内存_读8(url字符串 + pos) == 0x23) {
 pos = pos + 1
 url.片段 = 字符串_复制_N(url字符串 + pos, 长度 - pos)
 url.片段长度 = 长度 - pos
 }

 返回 url
}

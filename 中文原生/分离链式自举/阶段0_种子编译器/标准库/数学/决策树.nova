导入("../基础.nova")
导入("工具.nova")


// Nova标准库 — 决策树 (Decision Tree)
// ID3/CART 简化版 + 随机森林基础
// 支撑可解释 AI、特征选择

定义 决策精度 = 1000

// 决策树节点
// 叶节点: [0, 类别, -1, -1, -1]
// 内部节点: [1, 特征索引, 阈值, 左子树索引, 右子树索引]
// 树: [节点列表, 根索引]

函数 决策树_创建() {
    返回 [[], 0]
}

// 添加叶节点
函数 决策树_叶(树, 类别) {
    定义 索引 = 计数(树[0])
    追加(树[0], [0, 类别, -1, -1, -1])
    返回 索引
}

// 添加内部节点
函数 决策树_分支(树, 特征列, 阈值, 左, 右) {
    定义 索引 = 计数(树[0])
    追加(树[0], [1, 特征列, 阈值, 左, 右])
    返回 索引
}

// 预测
函数 决策树_预测(树, 样本) {
    定义 可变 索引 = 树[1]
    当 (真) {
        定义 节点 = 树[0][索引]
        如果 (节点[0] == 0) {
            返回 节点[1]
        }
        定义 特征值 = 样本[节点[1]]
        如果 (特征值 <= 节点[2]) {
            索引 = 节点[3]
        } 否则 {
            索引 = 节点[4]
        }
    }
    返回 -1
}

// 批量预测
函数 决策树_批量预测(树, 数据) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        追加(结果, 决策树_预测(树, 数据[i]))
        i = i + 1
    }
    返回 结果
}

// CART 训练 (简化版)

// 基尼不纯度
函数 基尼不纯度(标签, 类别数) {
    定义 n = 计数(标签)
    如果 (n == 0) { 返回 0 }
    定义 可变 不纯度 = 决策精度
    定义 可变 c = 0
    当 (c < 类别数) {
        定义 可变 计数器 = 0
        定义 可变 i = 0
        当 (i < n) {
            如果 (标签[i] == c) { 计数器 = 计数器 + 1 }
            i = i + 1
        }
        定义 概率 = 计数器 * 决策精度 / n
        不纯度 = 不纯度 - 概率 * 概率 / 决策精度
        c = c + 1
    }
    返回 不纯度
}

// 信息熵
函数 信息熵(标签, 类别数) {
    定义 n = 计数(标签)
    如果 (n == 0) { 返回 0 }
    定义 可变 熵 = 0
    定义 可变 c = 0
    当 (c < 类别数) {
        定义 可变 计数器 = 0
        定义 可变 i = 0
        当 (i < n) {
            如果 (标签[i] == c) { 计数器 = 计数器 + 1 }
            i = i + 1
        }
        如果 (计数器 > 0) {
            定义 概率 = 计数器 * 决策精度 / n
            // -p * log(p) 近似
            定义 log近似 = 决策_log(概率)
            熵 = 熵 - 概率 * log近似 / 决策精度
        }
        c = c + 1
    }
    返回 熵
}

// 找最佳分割点
函数 最佳分割(数据, 标签, 特征数, 类别数) {
    定义 n = 计数(数据)
    定义 可变 最优特征 = 0
    定义 可变 最优阈值 = 0
    定义 可变 最优基尼 = 决策精度
    定义 可变 f = 0
    当 (f < 特征数) {
        // 收集该特征的所有值
        定义 可变 值列表 = []
        定义 可变 i = 0
        当 (i < n) { 追加(值列表, 数据[i][f]) i = i + 1 }
        // 尝试每个值作为阈值
        i = 0
        当 (i < n) {
            定义 阈值 = 值列表[i]
            // 分割
            定义 可变 左标签 = []
            定义 可变 右标签 = []
            定义 可变 j = 0
            当 (j < n) {
                如果 (数据[j][f] <= 阈值) {
                    追加(左标签, 标签[j])
                } 否则 {
                    追加(右标签, 标签[j])
                }
                j = j + 1
            }
            // 加权基尼
            定义 左n = 计数(左标签)
            定义 右n = 计数(右标签)
            如果 (左n > 0 且 右n > 0) {
                定义 加权 = 左n * 基尼不纯度(左标签, 类别数) / n + 右n * 基尼不纯度(右标签, 类别数) / n
                如果 (加权 < 最优基尼) {
                    最优基尼 = 加权
                    最优特征 = f
                    最优阈值 = 阈值
                }
            }
            i = i + 1
        }
        f = f + 1
    }
    返回 [最优特征, 最优阈值, 最优基尼]
}

// 递归构建决策树
函数 构建决策树(树, 数据, 标签, 特征数, 类别数, 最大深度, 当前深度) {
    定义 n = 计数(标签)
    // 终止条件
    如果 (n == 0) { 返回 决策树_叶(树, 0) }
    如果 (当前深度 >= 最大深度) {
        返回 决策树_叶(树, 多数类(标签, 类别数))
    }
    // 检查是否纯净
    定义 可变 全同 = 真
    定义 可变 i = 1
    当 (i < n 且 全同) {
        如果 (标签[i] != 标签[0]) { 全同 = 假 }
        i = i + 1
    }
    如果 (全同) { 返回 决策树_叶(树, 标签[0]) }
    // 找最佳分割
    定义 分割 = 最佳分割(数据, 标签, 特征数, 类别数)
    定义 特征列 = 分割[0]
    定义 阈值 = 分割[1]
    // 分割数据
    定义 可变 左数据 = []
    定义 可变 左标签 = []
    定义 可变 右数据 = []
    定义 可变 右标签 = []
    i = 0
    当 (i < n) {
        如果 (数据[i][特征列] <= 阈值) {
            追加(左数据, 数据[i])
            追加(左标签, 标签[i])
        } 否则 {
            追加(右数据, 数据[i])
            追加(右标签, 标签[i])
        }
        i = i + 1
    }
    如果 (计数(左数据) == 0 或 计数(右数据) == 0) {
        返回 决策树_叶(树, 多数类(标签, 类别数))
    }
    // 递归
    定义 左子 = 构建决策树(树, 左数据, 左标签, 特征数, 类别数, 最大深度, 当前深度 + 1)
    定义 右子 = 构建决策树(树, 右数据, 右标签, 特征数, 类别数, 最大深度, 当前深度 + 1)
    定义 根 = 决策树_分支(树, 特征列, 阈值, 左子, 右子)
    返回 根
}

// 训练决策树
函数 训练决策树(数据, 标签, 特征数, 类别数, 最大深度) {
    定义 可变 树 = 决策树_创建()
    定义 根 = 构建决策树(树,  数据,  标签,  特征数,  类别数,  最大深度, 0)
    树[1] = 根
    返回 树
}

// 随机森林 (简化版)

函数 随机森林_训练(数据, 标签, 特征数, 类别数, 树数, 最大深度, 种子) {
    定义 n = 计数(数据)
    定义 可变 森林 = []
    定义 可变 s = 种子
    定义 可变 t = 0
    当 (t < 树数) {
        // Bootstrap 采样
        定义 可变 采样数据 = []
        定义 可变 采样标签 = []
        定义 可变 i = 0
        当 (i < n) {
            s = (s * 1103515245 + 12345) & 0x7FFFFFFF
            定义 索引 = s % n
            追加(采样数据, 数据[索引])
            追加(采样标签, 标签[索引])
            i = i + 1
        }
        定义 树 = 训练决策树(采样数据, 采样标签, 特征数, 类别数, 最大深度)
        追加(森林, 树)
        t = t + 1
    }
    返回 森林
}

函数 随机森林_预测(森林, 样本, 类别数) {
    定义 可变 投票 = []
    定义 可变 c = 0
    当 (c < 类别数) { 追加(投票, 0) c = c + 1 }
    定义 可变 t = 0
    当 (t < 计数(森林)) {
        定义 预测 = 决策树_预测(森林[t], 样本)
        如果 (预测 >= 0 且 预测 < 类别数) {
            投票[预测] = 投票[预测] + 1
        }
        t = t + 1
    }
    // 多数投票
    定义 可变 最优 = 0
    定义 可变 最优票 = 投票[0]
    c = 1
    当 (c < 类别数) {
        如果 (投票[c] > 最优票) {
            最优票 = 投票[c]
            最优 = c
        }
        c = c + 1
    }
    返回 最优
}

// 内部工具

函数 多数类(标签, 类别数) {
    定义 可变 最优 = 0
    定义 可变 最优数 = 0
    定义 可变 c = 0
    当 (c < 类别数) {
        定义 可变 计数器 = 0
        定义 可变 i = 0
        当 (i < 计数(标签)) {
            如果 (标签[i] == c) { 计数器 = 计数器 + 1 }
            i = i + 1
        }
        如果 (计数器 > 最优数) {
            最优数 = 计数器
            最优 = c
        }
        c = c + 1
    }
    返回 最优
}

函数 决策_log(x) {
    如果 (x <= 0) { 返回 0 }
    如果 (x >= 决策精度) { 返回 0 }
    // 近似 -对数2(x/1000) * 1000
    定义 可变 结果 = 0
    定义 可变 v = x
    当 (v < 500) { v = v * 2 结果 = 结果 + 决策精度 }
    返回 结果
}

// 特征重要性 (基于不纯度下降, 0)
函数 特征重要性(树, 特征数) {
    定义 可变 重要性 = []
    定义 可变 f = 0
    当 (f < 特征数) { 追加(重要性, 0)
    f = f + 1 }
    定义 节点列表 = 树[0]
    定义 可变 i = 0
    当 (i < 计数(节点列表)) {
        定义 节点 = 节点列表[i]
        如果 (节点[0] == 1) {  // 内部节点
            定义 特征idx = 节点[1]
            如果 (特征idx >= 0 且 特征idx < 特征数) {
                重要性[特征idx] = 重要性[特征idx] + 1
            }
        }
        i = i + 1
    }
    返回 重要性
}

// 树深度
函数 决策树_深度(树, 节点idx) {
    定义 节点 = 树[0][节点idx]
    如果 (节点[0] == 0) { 返回 0 }
    定义 左深 = 决策树_深度(树, 节点[3])
    定义 右深 = 决策树_深度(树, 节点[4])
    如果 (左深 > 右深) { 返回 左深 + 1 }
    返回 右深 + 1
}

// 叶节点数
函数 决策树_叶数(树, 节点idx) {
    定义 节点 = 树[0][节点idx]
    如果 (节点[0] == 0) { 返回 1 }
    返回 决策树_叶数(树, 节点[3]) + 决策树_叶数(树, 节点[4])
}

// 准确率计算
函数 决策树_准确率(树, 数据, 标签) {
    定义 可变 正确 = 0
    定义 n = 计数(数据)
    定义 可变 i = 0
    当 (i < n) {
        如果 (决策树_预测(树, 数据[i]) == 标签[i]) {
            正确 = 正确 + 1
        }
        i = i + 1
    }
    如果 (n == 0) { 返回 0 }
    返回 正确 * 决策精度 / n
}

// 随机森林准确率
函数 随机森林_准确率(森林, 数据, 标签, 类别数) {
    定义 可变 正确 = 0
    定义 n = 计数(数据)
    定义 可变 i = 0
    当 (i < n) {
        如果 (随机森林_预测(森林, 数据[i], 类别数) == 标签[i]) {
            正确 = 正确 + 1
        }
        i = i + 1
    }
    返回 正确 * 决策精度 / n
}

// 随机森林特征重要性 (聚合)
函数 随机森林_特征重要性(森林, 特征数) {
    定义 可变 总重要性 = []
    定义 可变 f = 0
    当 (f < 特征数) { 追加(总重要性, 0)
    f = f + 1 }
    定义 可变 t = 0
    当 (t < 计数(森林)) {
        定义 树重要性 = 特征重要性(森林[t], 特征数)
        f = 0
        当 (f < 特征数) {
            总重要性[f] = 总重要性[f] + 树重要性[f]
            f = f + 1
        }
        t = t + 1
    }
    返回 总重要性
}

// 混淆矩阵
函数 混淆矩阵(预测列表, 真实列表, 类别数) {
    定义 可变 矩阵 = []
    定义 可变 i = 0
    当 (i < 类别数) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j < 类别数) { 追加(行, 0)
        j = j + 1 }
        追加(矩阵, 行)
        i = i + 1
    }
    i = 0
    当 (i < 计数(真实列表)) {
        定义 真值 = 真实列表[i]
        定义 预 = 预测列表[i]
        如果 (真值 >= 0 且 真值 < 类别数 且 预 >= 0 且 预 < 类别数) {
            矩阵[真值][预] = 矩阵[真值][预] + 1
        }
        i = i + 1
    }
    返回 矩阵
}

// 精确率/召回率/F1 (二分类)
函数 精确率(混淆, 正类) {
    定义 tp = 混淆[正类][正类]
    定义 可变 fp = 0
    定义 可变 i = 0
    当 (i < 计数(混淆)) {
        如果 (i != 正类) { fp = fp + 混淆[i][正类] }
        i = i + 1
    }
    如果 (tp + fp == 0) { 返回 0 }
    返回 tp * 决策精度 / (tp + fp)
}

函数 召回率(混淆, 正类) {
    定义 tp = 混淆[正类][正类]
    定义 可变 fn = 0
    定义 可变 i = 0
    当 (i < 计数(混淆[正类])) {
        如果 (i != 正类) { fn = fn + 混淆[正类][i] }
        i = i + 1
    }
    如果 (tp + fn == 0) { 返回 0 }
    返回 tp * 决策精度 / (tp + fn)
}

函数 f1分数(混淆, 正类) {
    定义 p = 精确率(混淆, 正类)
    定义 r = 召回率(混淆, 正类)
    如果 (p + r == 0) { 返回 0 }
    返回 2 * p * r / (p + r)
}

// 准确率

// 宏平均F1 (多分类)
函数 宏平均f1(混淆, 类别数) {
    定义 可变 总f1 = 0
    定义 可变 i = 0
    当 (i < 类别数) {
        总f1 = 总f1 + f1分数(混淆, i)
        i = i + 1
    }
    如果 (类别数 == 0) { 返回 0 }
    返回 总f1 / 类别数
}

// Cohen's 卡帕系数
函数 kappa系数(混淆, 类别数) {
    定义 可变 总计 = 0
    定义 可变 行和 = []
    定义 可变 列和 = []
    定义 可变 i = 0
    当 (i < 类别数) { 追加(行和, 0)
    追加(列和, 0)
    i = i + 1 }
    i = 0
    当 (i < 类别数) {
        定义 可变 j = 0
        当 (j < 类别数) {
            行和[i] = 行和[i] + 混淆[i][j]
            列和[j] = 列和[j] + 混淆[i][j]
            总计 = 总计 + 混淆[i][j]
            如果 (i == j) { 正确 = 正确 + 混淆[i][j] }
            j = j + 1
        }
        i = i + 1
    }
    如果 (总计 == 0) { 返回 0 }
    定义 po = 正确 * 决策精度 / 总计
    定义 可变 pe = 0
    i = 0
    当 (i < 类别数) {
        pe = pe + 行和[i] * 列和[i] / 总计
        i = i + 1
    }
    pe = pe * 决策精度 / 总计
    如果 (决策精度 == pe) { 返回 决策精度 }
    返回 (po - pe) * 决策精度 / (决策精度 - pe)
}

// 梯度提升树桩 (Gradient Boosting Stump)
函数 提升树桩_训练(数据, _标签, 残差, 特征数) {
    定义 n = 计数(数据)
    定义 可变 最佳特征 = 0
    定义 可变 最佳阈值 = 0
    定义 可变 最佳增益 = 0 - 0x7FFFFFFF
    定义 可变 f = 0
    当 (f < 特征数) {
        // 尝试每个数据点的值作为阈值
        定义 可变 i = 0
        当 (i < n) {
            定义 阈值 = 数据[i][f]
            定义 可变 左和 = 0
            定义 可变 右和 = 0
            定义 可变 左n = 0
            定义 可变 右n = 0
            定义 可变 j = 0
            当 (j < n) {
                如果 (数据[j][f] <= 阈值) {
                    左和 = 左和 + 残差[j]
                    左n = 左n + 1
                } 否则 {
                    右和 = 右和 + 残差[j]
                    右n = 右n + 1
                }
                j = j + 1
            }
            定义 可变 增益 = 0
            如果 (左n > 0) { 增益 = 增益 + 左和 * 左和 / 左n }
            如果 (右n > 0) { 增益 = 增益 + 右和 * 右和 / 右n }
            如果 (增益 > 最佳增益) {
                最佳增益 = 增益
                最佳特征 = f
                最佳阈值 = 阈值
            }
            i = i + 1
        }
        f = f + 1
    }
    返回 [最佳特征, 最佳阈值]
}

// Phase3反哺注入: 决策_log [BugFix]
// 来源: Rust深度研究引擎 nova_deep_engine.rs
// 误差: 0.00% → 0.00%  提升: 0.0x
// 说明: 循环上限Bug: 循环上限硬编码: 当 (v < 500) { v = v * 2 结果 = 结果 + 决策精度 } → 用Q快速幂整数替换
// E9反哺修复: 删除循环上限, 改用Q快速幂整数(base,exp)
// 见在线学习.nova 函数 Q快速幂整数

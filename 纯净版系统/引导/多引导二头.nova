导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/内存初始化.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/整数转字符串.nova")

定义 MB2_头魔数 = 0xE85250D6
定义 MB2_架构_X86 = 0
定义 MB2_架构_MIPS = 4
定义 MB2_头长度 = 24
定义 MB2_校验和_计算方法 = 0

定义 MB2_引导魔数 = 0x36D76289

定义 MB2_TAG_终止 = 0
定义 MB2_TAG_命令行 = 1
定义 MB2_TAG_引导名 = 2
定义 MB2_TAG_模块 = 3
定义 MB2_TAG_基本内存 = 4
定义 MB2_TAG_引导设备 = 5
定义 MB2_TAG_内存映射 = 6
定义 MB2_TAG_VBE = 7
定义 MB2_TAG_帧缓冲 = 8
定义 MB2_TAG_ELF节 = 9
定义 MB2_TAG_APM = 10
定义 MB2_TAG_EFI32 = 11
定义 MB2_TAG_EFI64 = 12
定义 MB2_TAG_SMBIOS = 13
定义 MB2_TAG_ACPI旧 = 14
定义 MB2_TAG_ACPI新 = 15
定义 MB2_TAG_网络 = 16
定义 MB2_TAG_EFI内存映射 = 17
定义 MB2_TAG_EFI引导服务 = 18
定义 MB2_TAG_EFI32镜像句柄 = 19
定义 MB2_TAG_EFI64镜像句柄 = 20
定义 MB2_TAG_加载基址 = 21

定义 内存_可用 = 1
定义 内存_保留 = 2
定义 内存_ACPI可回收 = 3
定义 内存_ACPI_NVS = 4
定义 内存_坏 = 5

定义 帧缓冲_索引色 = 0
定义 帧缓冲_RGB = 1
定义 帧缓冲_EGA文本 = 2

定义 MB2_请求标签_可选 = 1

结构 MB2引导信息 {
    命令行,
    引导器名称,
    内存低,
    内存高,
    内存映射地址,
    内存映射条目数,
    内存映射条目大小,
    帧缓冲地址,
    帧缓冲宽度,
    帧缓冲高度,
    帧缓冲深度,
    帧缓冲间距,
    帧缓冲类型,
    模块列表,
    模块数量,
    ELF节地址,
    ELF节数量,
    ELF节大小,
    ELF字符串表索引,
    ACPI_RSDP,
    引导设备,
    总可用内存,
}

定义 可变 全局_MB2信息 = 空

函数 MB2_验证魔数(eax值) {
    返回 eax值 == MB2_引导魔数
}

函数 MB2_计算校验和(架构, 长度) {
    返回 0 - (MB2_头魔数 + 架构 + 长度)
}

函数 MB2_验证校验和(魔数, 架构, 长度, 校验和) {
    返回 (魔数 + 架构 + 长度 + 校验和) == 0
}

函数 MB2_解析引导信息(信息指针) {
    如果 (信息指针 == 0) { 返回 空 }

    定义 总大小 = 内存_读32(信息指针)
    如果 (总大小 < 8) { 返回 空 }

    全局_MB2信息 = 堆_分配(MB2引导信息)
    全局_MB2信息.命令行 = 0
    全局_MB2信息.引导器名称 = 0
    全局_MB2信息.内存低 = 0
    全局_MB2信息.内存高 = 0
    全局_MB2信息.内存映射地址 = 0
    全局_MB2信息.内存映射条目数 = 0
    全局_MB2信息.帧缓冲地址 = 0
    全局_MB2信息.帧缓冲宽度 = 0
    全局_MB2信息.帧缓冲高度 = 0
    全局_MB2信息.帧缓冲深度 = 0
    全局_MB2信息.模块列表 = 空
    全局_MB2信息.模块数量 = 0
    全局_MB2信息.ACPI_RSDP = 0
    全局_MB2信息.总可用内存 = 0

    定义 可变 偏移 = 信息指针 + 8

    当 (偏移 < 信息指针 + 总大小) {
        定义 标签类型 = 内存_读32(偏移)
        定义 标签大小 = 内存_读32(偏移 + 4)

        如果 (标签类型 == MB2_TAG_终止) { 跳出 }
        如果 (标签大小 < 8) { 跳出 }

        如果 (标签类型 == MB2_TAG_命令行) {
            MB2_解析命令行(偏移, 标签大小)
        } 否则 如果 (标签类型 == MB2_TAG_引导名) {
            MB2_解析引导名(偏移, 标签大小)
        } 否则 如果 (标签类型 == MB2_TAG_基本内存) {
            MB2_解析基本内存(偏移)
        } 否则 如果 (标签类型 == MB2_TAG_内存映射) {
            MB2_解析内存映射(偏移, 标签大小)
        } 否则 如果 (标签类型 == MB2_TAG_帧缓冲) {
            MB2_解析帧缓冲(偏移, 标签大小)
        } 否则 如果 (标签类型 == MB2_TAG_模块) {
            MB2_解析模块(偏移, 标签大小)
        } 否则 如果 (标签类型 == MB2_TAG_ELF节) {
            MB2_解析ELF节(偏移, 标签大小)
        } 否则 如果 (标签类型 == MB2_TAG_ACPI旧) {
            MB2_解析ACPI旧(偏移, 标签大小)
        } 否则 如果 (标签类型 == MB2_TAG_ACPI新) {
            MB2_解析ACPI新(偏移, 标签大小)
        } 否则 如果 (标签类型 == MB2_TAG_引导设备) {
            MB2_解析引导设备(偏移)
        }

        偏移 = (偏移 + 标签大小 + 7) & ~7
    }

    返回 全局_MB2信息
}

函数 MB2_解析命令行(偏移, 大小) {
    如果 (大小 <= 8) { 返回 }
    全局_MB2信息.命令行 = 偏移 + 8
}

函数 MB2_解析引导名(偏移, 大小) {
    如果 (大小 <= 8) { 返回 }
    全局_MB2信息.引导器名称 = 偏移 + 8
}

函数 MB2_解析基本内存(偏移) {
    全局_MB2信息.内存低 = 内存_读32(偏移 + 8)
    全局_MB2信息.内存高 = 内存_读32(偏移 + 12)
}

函数 MB2_解析内存映射(偏移, 大小) {
    定义 条目大小 = 内存_读32(偏移 + 8)
    如果 (条目大小 == 0) { 返回 }

    全局_MB2信息.内存映射地址 = 偏移 + 16
    全局_MB2信息.内存映射条目大小 = 条目大小
    全局_MB2信息.内存映射条目数 = (大小 - 16) / 条目大小

    定义 可变 总可用 = 0
    定义 可变 i = 0
    当 (i < 全局_MB2信息.内存映射条目数) {
        定义 条目 = 全局_MB2信息.内存映射地址 + i * 条目大小
        定义 类型 = 内存_读32(条目 + 16)
        如果 (类型 == 内存_可用) {
            定义 长度低 = 内存_读32(条目 + 8)
            定义 长度高 = 内存_读32(条目 + 12)
            总可用 = 总可用 + 长度低 + (长度高 << 32)
        }
        i = i + 1
    }
    全局_MB2信息.总可用内存 = 总可用
}

函数 MB2_解析帧缓冲(偏移, 大小) {
    如果 (大小 < 32) { 返回 }
    全局_MB2信息.帧缓冲地址 = 内存_读32(偏移 + 8) | (内存_读32(偏移 + 12) << 32)
    全局_MB2信息.帧缓冲间距 = 内存_读32(偏移 + 16)
    全局_MB2信息.帧缓冲宽度 = 内存_读32(偏移 + 20)
    全局_MB2信息.帧缓冲高度 = 内存_读32(偏移 + 24)
    全局_MB2信息.帧缓冲深度 = 内存_读8(偏移 + 28)
    全局_MB2信息.帧缓冲类型 = 内存_读8(偏移 + 29)
}

函数 MB2_解析模块(偏移, 大小) {
    如果 (大小 < 16) { 返回 }
    定义 模块开始 = 内存_读32(偏移 + 8)
    定义 模块结束 = 内存_读32(偏移 + 12)
    定义 命令行 = 偏移 + 16

    如果 (全局_MB2信息.模块列表 == 空) {
        全局_MB2信息.模块列表 = []
    }
    追加(全局_MB2信息.模块列表, [模块开始, 模块结束, 命令行])
    全局_MB2信息.模块数量 = 全局_MB2信息.模块数量 + 1
}

函数 MB2_解析ELF节(偏移, 大小) {
    如果 (大小 < 20) { 返回 }
    全局_MB2信息.ELF节数量 = 内存_读32(偏移 + 8)
    全局_MB2信息.ELF节大小 = 内存_读32(偏移 + 12)
    全局_MB2信息.ELF字符串表索引 = 内存_读32(偏移 + 16)
    全局_MB2信息.ELF节地址 = 偏移 + 20
}

函数 MB2_解析ACPI旧(偏移, 大小) {
    如果 (大小 < 28) { 返回 }
    全局_MB2信息.ACPI_RSDP = 偏移 + 8
}

函数 MB2_解析ACPI新(偏移, 大小) {
    如果 (大小 < 44) { 返回 }
    全局_MB2信息.ACPI_RSDP = 偏移 + 8
}

函数 MB2_解析引导设备(偏移) {
    全局_MB2信息.引导设备 = 内存_读32(偏移 + 8)
}

函数 MB2_内存映射类型名(类型) {
    如果 (类型 == 内存_可用) { 返回 "可用" }
    如果 (类型 == 内存_保留) { 返回 "保留" }
    如果 (类型 == 内存_ACPI可回收) { 返回 "ACPI可回收" }
    如果 (类型 == 内存_ACPI_NVS) { 返回 "ACPI NVS" }
    如果 (类型 == 内存_坏) { 返回 "坏内存" }
    返回 "未知"
}

函数 MB2_获取内存映射条目(索引) {
    如果 (全局_MB2信息 == 空) { 返回 空 }
    如果 (索引 >= 全局_MB2信息.内存映射条目数) { 返回 空 }
    定义 条目 = 全局_MB2信息.内存映射地址 + 索引 * 全局_MB2信息.内存映射条目大小
    定义 基址 = 内存_读32(条目) | (内存_读32(条目 + 4) << 32)
    定义 长度 = 内存_读32(条目 + 8) | (内存_读32(条目 + 12) << 32)
    定义 类型 = 内存_读32(条目 + 16)
    返回 [基址, 长度, 类型]
}

函数 MB2_查找最大可用区域() {
    如果 (全局_MB2信息 == 空) { 返回 [0, 0] }
    定义 可变 最大基址 = 0
    定义 可变 最大长度 = 0

    定义 可变 i = 0
    当 (i < 全局_MB2信息.内存映射条目数) {
        定义 条目 = MB2_获取内存映射条目(i)
        如果 (条目 != 空 && 条目[2] == 内存_可用) {
            如果 (条目[1] > 最大长度) {
                最大基址 = 条目[0]
                最大长度 = 条目[1]
            }
        }
        i = i + 1
    }
    返回 [最大基址, 最大长度]
}

函数 MB2_打印引导信息() {
    如果 (全局_MB2信息 == 空) { 打印行("MB2: 无引导信息"); 返回 }

    打印行("=== Multiboot2 引导信息 ===")
    如果 (全局_MB2信息.引导器名称 != 0) {
        打印行("引导器: " + 内存_读字符串(全局_MB2信息.引导器名称))
    }
    如果 (全局_MB2信息.命令行 != 0) {
        打印行("命令行: " + 内存_读字符串(全局_MB2信息.命令行))
    }

    打印行("总可用内存: " + 整数转字符串(全局_MB2信息.总可用内存 / 1048576) + " MB")

    打印行("内存映射 (" + 整数转字符串(全局_MB2信息.内存映射条目数) + " 条目):")
    定义 可变 i = 0
    当 (i < 全局_MB2信息.内存映射条目数) {
        定义 条目 = MB2_获取内存映射条目(i)
        如果 (条目 != 空) {
            打印行("  " + 整数转十六进制(条目[0]) + " - "
                + 整数转十六进制(条目[0] + 条目[1]) + " "
                + MB2_内存映射类型名(条目[2]))
        }
        i = i + 1
    }

    如果 (全局_MB2信息.帧缓冲地址 != 0) {
        打印行("帧缓冲: " + 整数转字符串(全局_MB2信息.帧缓冲宽度) + "x"
            + 整数转字符串(全局_MB2信息.帧缓冲高度) + "x"
            + 整数转字符串(全局_MB2信息.帧缓冲深度) + "bpp")
    }

    打印行("模块数: " + 整数转字符串(全局_MB2信息.模块数量))
    如果 (全局_MB2信息.ACPI_RSDP != 0) {
        打印行("ACPI RSDP: 0x" + 整数转十六进制(全局_MB2信息.ACPI_RSDP))
    }
}

定义 可变 AI_多引导二头_运行指标 = 0
定义 可变 AI_多引导二头_异常指标 = 0

函数 AI_多引导二头_自诊断() {
    AI_多引导二头_运行指标 = 0
    返回 AI_多引导二头_运行指标
}

函数 AI_多引导二头_优化建议() {
    定义 指标 = AI_多引导二头_自诊断()
    返回 "多引导二头状态正常"
}

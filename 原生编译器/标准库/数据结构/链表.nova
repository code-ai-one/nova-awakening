导入("../基础.nova")

// 头插/尾插 = "给"字操作 (节点交给链表)
// 头删/尾删 = "把"字操作 (把节点从链表消费出来)
// 遍历 = "被"字操作 (节点被读取但不消费)

// 节点: [值, 前驱, 后继]
函数 链_创建节点(值) { 返回 [值, 空, 空] }

// 链表: [头, 尾, 大小, 操作计数器]
函数 链表_链表_创建() { 返回 [空, 空, 0, [0,]] }
函数 链表_头(链) { 返回 链[0] }
函数 链表_尾(链) { 返回 链[1] }
函数 链表_链表_大小(链) { 返回 链[2] }
函数 链表_链表_空(链) { 返回 链[2] == 0 }

函数 链_值(n) { 返回 n[0] }
函数 链_前(n) { 返回 n[1] }
函数 链_后(n) { 返回 n[2] }

// 头部插入 (给字操作: 节点交给链表)
函数 链表_链表_头插(链, 值) { 定义 计数器 = 链[3]
 计数器[0] = 计数器[0] + 1
 定义 节点 = 链_创建节点(值)
 定义 旧头 = 链[0]
 如果 (旧头 == 空) {
 链[0] = 节点
 链[1] = 节点
 } 否则 {
 节点[2] = 旧头
 旧头[1] = 节点
 链[0] = 节点
 }
 链[2] = 链[2] + 1
}

// 尾部插入
函数 链表_链表_尾插(链, 值) { 定义 节点 = 链_创建节点(值)
 定义 旧尾 = 链[1]
 如果 (旧尾 == 空) {
 链[0] = 节点
 链[1] = 节点
 } 否则 {
 节点[1] = 旧尾
 旧尾[2] = 节点
 链[1] = 节点
 }
 链[2] = 链[2] + 1
}

// 头部删除
函数 链表_链表_头删(链) { 定义 头 = 链[0]
 如果 (头 == 空) { 返回 空 }
 定义 值 = 头[0]
 定义 后 = 头[2]
 如果 (后 == 空) {
 链[0] = 空
 链[1] = 空
 } 否则 {
 后[1] = 空
 链[0] = 后
 }
 链[2] = 链[2] - 1
 返回 值
}

// 尾部删除
函数 链表_尾删(链) { 定义 尾 = 链[1]
 如果 (尾 == 空) { 返回 空 }
 定义 值 = 尾[0]
 定义 前 = 尾[1]
 如果 (前 == 空) {
 链[0] = 空
 链[1] = 空
 } 否则 {
 前[2] = 空
 链[1] = 前
 }
 链[2] = 链[2] - 1
 返回 值
}

// 转列表
函数 链表_链表_转列表(链) { 定义 可变 结果 = []
 定义 可变 当前 = 链[0]
 当 (当前 != 空) {
 追加(结果, 当前[0])
 当前 = 当前[2]
 }
 返回 结果
}

// 从列表创建
函数 链表_链表_从列表(列表) { 定义 链 = 链表_链表_创建()
 定义 可变 i = 0
 当 (i < 计数(列表)) {
 链表_链表_尾插(链, 列表[i])
 i = i + 1
 }
 返回 链
}

// 反转
函数 链表_链表_反转(链) { 定义 可变 当前 = 链[0]
 定义 可变 临时 = 空
 当 (当前 != 空) {
 临时 = 当前[1]
 当前[1] = 当前[2]
 当前[2] = 临时
 当前 = 当前[1]
 }
 临时 = 链[0]
 链[0] = 链[1]
 链[1] = 临时
}

// 查找值
函数 链表_链表_查找(链, 值) { 定义 可变 当前 = 链[0]
 定义 可变 索引 = 0
 当 (当前 != 空) { 如果 (当前[0] == 值) { 返回 索引 }
 当前 = 当前[2]
 索引 = 索引 + 1
 }
 返回 -1
}

// 按索引获取
函数 链表_链表_取(链, 索引) { 定义 可变 当前 = 链[0]
 定义 可变 i = 0
 当 (当前 != 空 且 i < 索引) {
 当前 = 当前[2]
 i = i + 1
 }
 如果 (当前 == 空) { 返回 空 }
 返回 当前[0]
}

// 理论驱动新功能

函数 链表_气韵正流(链, 聚合函数, 初始值) { 定义 可变 气 = 初始值
 定义 可变 当前 = 链[0]
 当 (当前 != 空) {
 气 = 聚合函数(气, 当前[0])
 当前 = 当前[2]
 }
 返回 气
}

函数 链表_气韵逆流(链, 聚合函数, 初始值) { 定义 可变 气 = 初始值
 定义 可变 当前 = 链[1]
 当 (当前 != 空) {
 气 = 聚合函数(气, 当前[0])
 当前 = 当前[1]
 }
 返回 气
}

函数 链表_阴阳反转(链) { 定义 可变 当前 = 链[0]
 定义 可变 临时 = 空
 当 (当前 != 空) {
 临时 = 当前[1]
 当前[1] = 当前[2]
 当前[2] = 临时
 当前 = 当前[1]
 }
 临时 = 链[0]
 链[0] = 链[1]
 链[1] = 临时
}

// 把字语义报告: [给字(插入)次数, 把字(删除)次数, 被字(读取)次数]
函数 链表_语义报告(链) { 返回 链[3]
}

// 量词态射: 链表(串) → 列表(组) — 串联体线性化
函数 链表_串转组(链) { 返回 链表_链表_转列表(链)
}

// 链表映射: 对每个节点值应用变换 (火行: 值的变化)
函数 链表_链表_映射(链, 变换函数) { 定义 新链 = 链表_链表_创建()
 定义 可变 当前 = 链[0]
 当 (当前 != 空) {
 链表_链表_尾插(新链, 变换函数(当前[0], 空))
 当前 = 当前[2]
 }
 返回 新链
}

// 链表过滤: 保留满足谓词的节点
函数 链表_链表_过滤(链, 谓词函数) { 定义 新链 = 链表_链表_创建()
 定义 可变 当前 = 链[0]
 当 (当前 != 空) { 如果 (谓词函数(当前[0], 空) == 1) {
 链表_链表_尾插(新链, 当前[0])
 }
 当前 = 当前[2]
 }
 返回 新链
}

// 链表合并: 两条串合为一条 (量词代数: 串+串=串)
函数 链表_链表_合并(链a, 链b) { 定义 结果 = 链表_链表_创建()
 定义 可变 当前 = 链a[0]
 当 (当前 != 空) { 链表_链表_尾插(结果, 当前[0]) 当前 = 当前[2] }
 当前 = 链b[0]
 当 (当前 != 空) { 链表_链表_尾插(结果, 当前[0]) 当前 = 当前[2] }
 返回 结果
}

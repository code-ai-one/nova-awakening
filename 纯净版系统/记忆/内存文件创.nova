函数 ramfs_创建文件(目录Nova文件节点, Nova路径项, 模式) {
    定义 sb = Nova文件节点_超级块(目录Nova文件节点)
    定义 新Nova文件节点 = ramfs_创建Nova文件节点(sb, 类型_普通文件, 模式)
    如果 (新Nova文件节点 == 空) { 返回 错误_内存不足 }
    目录项_绑定Nova文件节点(Nova路径项, 新Nova文件节点)
    返回 成功
}

函数 ramfs_创建目录(目录Nova文件节点, Nova路径项, 模式) {
    定义 sb = Nova文件节点_超级块(目录Nova文件节点)
    定义 新Nova文件节点 = ramfs_创建Nova文件节点(sb, 类型_目录, 模式)
    如果 (新Nova文件节点 == 空) { 返回 错误_内存不足 }
    Nova文件节点_增链接(目录Nova文件节点)  // 子目录的..指向父目录
    目录项_绑定Nova文件节点(Nova路径项, 新Nova文件节点)
    返回 成功
}

函数 ramfs_查找(目录Nova文件节点, Nova路径项, 标志) {
    如果 (目录Nova文件节点 == 空 || Nova路径项 == 空) { 返回 空 }
    定义 名称 = Nova路径项.名称
    定义 可变 子节点 = 目录Nova文件节点.子节点头
    当 (子节点 != 0) {
        如果 (字符串等于(子节点.名称, 名称)) { 返回 子节点 }
        子节点 = 子节点.下一个兄弟
    }
    返回 空
}

函数 ramfs_删除文件(目录Nova文件节点, Nova路径项) {
    定义 节点 = 目录项_Nova文件节点(Nova路径项)
    Nova文件节点_减链接(节点)
    返回 成功
}

函数 ramfs_删除目录(目录Nova文件节点, Nova路径项) {
    定义 节点 = 目录项_Nova文件节点(Nova路径项)
    如果 (目录项_子数(Nova路径项) > 0) { 返回 错误_目录非空 }
    Nova文件节点_减链接(节点)
    Nova文件节点_减链接(目录Nova文件节点)  // 移除..引用
    返回 成功
}

// 操作表

函数 ramfs_超级块操作() {
    返回 超级块操作 {
        alloc_Nova文件节点: 0,
        destroy_Nova文件节点: 0,
        write_Nova文件节点: 0,     // ramfs不需要写回(数据在内存)
        evict_Nova文件节点: ramfs_evict_Nova文件节点,
        put_super: 0,
        sync_fs: 0,         // ramfs不需要sync(数据在内存)
        statfs: ramfs_statfs,
        remount_fs: 0,
        show_options: 0
    }
}

函数 ramfs_evict_Nova文件节点(节点) {
    // 释放文件数据页
    定义 数据 = Nova文件节点_获取私有(节点)
    如果 (数据 != 空) {
        定义 可变 i = 0
        当 (i < 计数(数据.页列表)) {
            如果 (数据.页列表[i] != 空) {
                释放页面(数据.页列表[i])
            }
            i = i + 1
        }
    }
}

函数 ramfs_statfs(sb, buf) {
    返回 超级块_statfs(sb, buf)
}

函数 ramfs_目录_Nova文件节点_ops() {
    返回 { 创建: ramfs_创建文件, 查找: ramfs_查找,
           创建目录: ramfs_创建目录, 删除目录: ramfs_删除目录,
           删除: ramfs_删除文件 }
}

函数 ramfs_文件_Nova文件节点_ops() { 返回 {} }
函数 ramfs_链接_Nova文件节点_ops() { 返回 {} }

函数 ramfs_目录_file_ops() {
    返回 { 读目录: ramfs_读目录 }
}

函数 ramfs_文件_file_ops() {
    返回 { 读: ramfs_读, 写: ramfs_写, llseek: 通用_llseek }
}

函数 ramfs_读目录(文件, ctx) {
    // readdir: 遍历目录Nova路径项的子项列表
    返回 成功
}

函数 通用_llseek(文件, 偏移, 起点) {
    返回 vfs_lseek(文件, 偏移, 起点)
}

// 辅助

函数 解析大小字符串(str) {
    定义 长度 = 字符串长度(str)
    如果 (长度 == 0) { 返回 0 }
    定义 最后字符 = 字符串取字符(str, 长度 - 1)
    定义 数字部分 = str
    定义 可变 乘数 = 1
    如果 (最后字符 == "k" || 最后字符 == "K") { 乘数 = 1024; 数字部分 = 字符串子串(str, 0, 长度 - 1) }
    如果 (最后字符 == "m" || 最后字符 == "M") { 乘数 = 1048576; 数字部分 = 字符串子串(str, 0, 长度 - 1) }
    如果 (最后字符 == "g" || 最后字符 == "G") { 乘数 = 1073741824; 数字部分 = 字符串子串(str, 0, 长度 - 1) }
    返回 字符串转整数(数字部分) * 乘数
}

// 错误_无空间 定义在 核心/公共/错误码.nova

// §4 ramfs文件读写操作

函数 ramfs_读(文件, 缓冲, 大小) {
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    定义 节点 = 文件.Nova文件节点
    如果 (节点 == 空 || 节点.数据 == 0) { 返回 0 }
    定义 偏移 = 文件.偏移
    如果 (偏移 >= 节点.大小) { 返回 0 }
    定义 可变 实际 = 大小
    如果 (偏移 + 实际 > 节点.大小) { 实际 = 节点.大小 - 偏移 }
    内存拷贝(缓冲, 节点.数据 + 偏移, 实际)
    文件.偏移 = 偏移 + 实际
    ramfs_读总字节 = ramfs_读总字节 + 实际
    返回 实际
}

函数 ramfs_写(文件, 缓冲, 大小) {
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    定义 节点 = 文件.Nova文件节点
    如果 (节点 == 空) { 返回 错误_坏文件描述符 }
    定义 偏移 = 文件.偏移
    定义 新大小 = 偏移 + 大小
    // 扩容
    如果 (新大小 > 节点.容量) {
        定义 新容量 = 新大小 * 2
        如果 (新容量 > ramfs_最大文件大小) { 新容量 = ramfs_最大文件大小 }
        如果 (新大小 > ramfs_最大文件大小) { 返回 错误_无空间 }
        定义 新数据 = 分配内存(新容量)
        如果 (新数据 == 0) { 返回 错误_内存不足 }
        如果 (节点.数据 != 0 && 节点.大小 > 0) {
            内存拷贝(新数据, 节点.数据, 节点.大小)
            释放内存(节点.数据)
        }
        节点.数据 = 新数据
        节点.容量 = 新容量
    }
    内存拷贝(节点.数据 + 偏移, 缓冲, 大小)
    如果 (新大小 > 节点.大小) { 节点.大小 = 新大小 }
    文件.偏移 = 偏移 + 大小
    ramfs_写总字节 = ramfs_写总字节 + 大小
    返回 大小
}

函数 ramfs_截断(节点, 新大小) {
    如果 (节点 == 空) { 返回 }
    如果 (新大小 < 节点.大小) {
        // 截断: 清零超出部分
        内存_置零(节点.数据 + 新大小, 节点.大小 - 新大小)
    }
    节点.大小 = 新大小
}

函数 ramfs_添加子节点(父, 子) {
    如果 (父 == 空 || 子 == 空) { 返回 }
    如果 (父.子节点列表 == 空) { 父.子节点列表 = [] }
    追加(父.子节点列表, 子)
}

函数 ramfs_查找子节点(父, 名称) {
    如果 (父 == 空 || 父.子节点列表 == 空) { 返回 空 }
    定义 可变 i = 0
    当 (i < 计数(父.子节点列表)) {
        如果 (父.子节点列表[i].名称 == 名称) { 返回 父.子节点列表[i] }
        i = i + 1
    }
    返回 空
}

函数 ramfs_创建节点(名称, 模式) {
    ramfs_总节点数 = ramfs_总节点数 + 1
    返回 {
        名称: 名称,
        模式: 模式,
        大小: 0,
        容量: 0,
        数据: 0,
        子节点列表: [],
    }
}

// §6 常量

定义 模式_文件 = 0x8000
定义 模式_目录 = 0x4000
定义 ramfs_最大文件大小 = 64 * 1024 * 1024
定义 错误_坏文件描述符 = -9
定义 错误_不存在 = -2
定义 错误_内存不足 = -12
定义 错误_无空间 = -28

定义 可变 ramfs_总节点数 = 0
定义 可变 ramfs_读总字节 = 0
定义 可变 ramfs_写总字节 = 0

函数 vfs_lseek(文件, 偏移, 起点) {
    // 调整文件位置指针: 起点0=开头 1=当前 2=末尾
    如果 (文件 == 空) { 返回 -1 }
    定义 可变 新位置 = 0
    如果 (起点 == 0) { 新位置 = 偏移 }                          // SEEK_SET
    否则 如果 (起点 == 1) { 新位置 = 文件.位置 + 偏移 }         // SEEK_CUR
    否则 如果 (起点 == 2) { 新位置 = 文件.大小 + 偏移 }         // SEEK_END
    否则 { 返回 -22 }  // EINVAL
    如果 (新位置 < 0) { 返回 -22 }
    文件.位置 = 新位置
    返回 新位置
}

// §7 统计

函数 ramfs_统计() {
    返回 {
        总节点: ramfs_总节点数,
        读字节: ramfs_读总字节,
        写字节: ramfs_写总字节,
    }
}

函数 ramfs_健康检查() {
    定义 可变 问题 = []
    如果 (ramfs_总节点数 > 100000) { 追加(问题, "节点过多") }
    如果 (计数(问题) == 0) { 返回 "ramfs健康" }
    返回 问题
}

// ramfs辅助函数

定义 可变 ramfs_总内存占用 = 0

函数 ramfs_内存统计() {
    返回 {
        节点数: ramfs_总节点数,
        内存占用: ramfs_总内存占用,
    }
}

函数 ramfs_查找节点(父节点, 名称) {
    如果 (父节点 == 空) { 返回 空 }
    定义 可变 i = 0
    当 (i < 计数(父节点.子节点)) {
        如果 (父节点.子节点[i].名称 == 名称) { 返回 父节点.子节点[i] }
        i = i + 1
    }
    返回 空
}

函数 ramfs_节点是目录(节点) {
    如果 (节点 == 空) { 返回 假 }
    返回 节点.类型 == 2
}

函数 ramfs_重置统计() {
    ramfs_总节点数 = 0
    ramfs_总内存占用 = 0
}

定义 可变 AI_内存文件创_运行指标 = 0
定义 可变 AI_内存文件创_异常指标 = 0

函数 AI_内存文件创_自诊断() {
    AI_内存文件创_运行指标 = 0
    返回 AI_内存文件创_运行指标
}

函数 AI_内存文件创_优化建议() {
    定义 指标 = AI_内存文件创_自诊断()
    返回 "内存文件创状态正常"
}

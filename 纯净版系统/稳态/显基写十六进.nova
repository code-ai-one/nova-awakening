定义 可变 显基_总字符输出 = 0
定义 可变 显基_总行输出 = 0
定义 可变 显基_总滚屏次数 = 0
定义 可变 显基_总格式输出 = 0
定义 可变 显基_总Dump输出 = 0

// §1 十六进制输出

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 显基_写十六进制(值, 位数) {
    显基_写字符串("0x")
    定义 可变 i = 位数 - 1
    当 (i >= 0) {
        定义 半字节 = (值 >> (i * 4)) & 0x0F
        显基_写字符(编码(字符串取字符(十六进制字符表, 半字节)))
        i = i - 1
    }
    显基_总格式输出 = 显基_总格式输出 + 1
}

函数 显基_写十六进制32(值) { 显基_写十六进制(值, 8) }
函数 显基_写十六进制64(值) { 显基_写十六进制(值, 16) }

函数 显基_写十六进制8(值) { 显基_写十六进制(值, 2) }
函数 显基_写十六进制16(值) { 显基_写十六进制(值, 4) }

// 无前缀十六进制输出 (用于dump等)
函数 显基_写十六进制_无前缀(值, 位数) {
    定义 可变 i = 位数 - 1
    当 (i >= 0) {
        定义 半字节 = (值 >> (i * 4)) & 0x0F
        显基_写字符(编码(字符串取字符(十六进制字符表, 半字节)))
        i = i - 1
    }
}

// §2 二进制/八进制输出

函数 显基_写二进制(值, 位数) {
    显基_写字符串("0b")
    定义 可变 i = 位数 - 1
    当 (i >= 0) {
        如果 ((值 >> i) & 1) { 显基_写字符(49) }
        否则 { 显基_写字符(48) }
        i = i - 1
    }
    显基_总格式输出 = 显基_总格式输出 + 1
}

函数 显基_写二进制8(值) { 显基_写二进制(值, 8) }
函数 显基_写二进制32(值) { 显基_写二进制(值, 32) }

函数 显基_写八进制(值) {
    显基_写字符串("0o")
    如果 (值 == 0) { 显基_写字符(48)  返回 }
    定义 可变 除数 = 1
    当 (除数 * 8 <= 值) { 除数 = 除数 * 8 }
    当 (除数 > 0) {
        定义 数字 = (值 / 除数) % 8
        显基_写字符(48 + 数字)
        除数 = 除数 / 8
    }
    显基_总格式输出 = 显基_总格式输出 + 1
}

// §3 整数输出

函数 显基_写整数(值) {
    如果 (值 < 0) {
        显基_写字符(45)  // '-'
        值 = 0 - 值
    }
    如果 (值 == 0) {
        显基_写字符(48)  // '0'
        返回
    }
    // 从高位到低位输出
    定义 可变 除数 = 1
    当 (除数 * 10 <= 值) { 除数 = 除数 * 10 }
    当 (除数 > 0) {
        定义 数字 = (值 / 除数) % 10
        显基_写字符(48 + 数字)
        除数 = 除数 / 10
    }
    显基_总格式输出 = 显基_总格式输出 + 1
}

// 右对齐整数 (padded)
函数 显基_写整数_对齐(值, 宽度) {
    // 先计算位数
    定义 可变 临时 = 值
    如果 (临时 < 0) { 临时 = 0 - 临时 }
    定义 可变 位数 = 1
    当 (临时 >= 10) { 临时 = 临时 / 10  位数 = 位数 + 1 }
    如果 (值 < 0) { 位数 = 位数 + 1 }
    // 填充空格
    定义 可变 j = 0
    当 (j < 宽度 - 位数) { 显基_写字符(32)  j = j + 1 }
    显基_写整数(值)
}

// 带千分位分隔的整数
函数 显基_写整数_分隔(值) {
    如果 (值 < 0) { 显基_写字符(45)  值 = 0 - 值 }
    如果 (值 < 1000) { 显基_写整数(值)  返回 }
    显基_写整数_分隔(值 / 1000)
    显基_写字符(44)  // ','
    定义 余 = 值 % 1000
    如果 (余 < 100) { 显基_写字符(48) }
    如果 (余 < 10) { 显基_写字符(48) }
    显基_写整数(余)
}

// §4 内存Dump (hex dump)

函数 显基_内存Dump(地址, 长度) {
    显基_总Dump输出 = 显基_总Dump输出 + 1
    定义 可变 偏移 = 0
    当 (偏移 < 长度) {
        // 地址
        显基_写十六进制(地址 + 偏移, 8)
        显基_写字符串(": ")

        // 十六进制字节
        定义 可变 j = 0
        当 (j < 16) {
            如果 (偏移 + j < 长度) {
                显基_写十六进制_无前缀(内存_读8(地址 + 偏移 + j), 2)
                显基_写字符(32)
            } 否则 {
                显基_写字符串("   ")
            }
            如果 (j == 7) { 显基_写字符(32) }
            j = j + 1
        }

        显基_写字符串(" |")
        // ASCII
        j = 0
        当 (j < 16 && 偏移 + j < 长度) {
            定义 字节 = 内存_读8(地址 + 偏移 + j)
            如果 (字节 >= 32 && 字节 < 127) {
                显基_写字符(字节)
            } 否则 {
                显基_写字符(46)  // '.'
            }
            j = j + 1
        }
        显基_写字符串("|")
        显基_写字符(10)

        偏移 = 偏移 + 16
    }
}

// 紧凑dump (单行, 只显示hex)
函数 显基_内存Dump_紧凑(地址, 长度) {
    定义 可变 i = 0
    当 (i < 长度) {
        如果 (i > 0) { 显基_写字符(32) }
        显基_写十六进制_无前缀(内存_读8(地址 + i), 2)
        i = i + 1
    }
}

// §5 状态栏

函数 显基_状态栏(文本) {
    // 在最后一行显示状态信息(反色)
    定义 旧行 = 显基_光标行
    定义 旧列 = 显基_光标列
    定义 状态颜色 = 显基_白 | (显基_蓝 << 4)

    // 清空最后一行
    定义 可变 i = 0
    当 (i < 显基_宽) {
        显基_在位置写(显基_高 - 1, i, 32, 状态颜色)
        i = i + 1
    }
    // 写状态文本
    显基_在位置写字符串(显基_高 - 1, 1, 文本, 状态颜色)

    // 恢复光标
    显基_光标行 = 旧行
    显基_光标列 = 旧列
    显基_更新光标()
}

// 带左右文本的状态栏
函数 显基_状态栏_双(左文本, 右文本) {
    定义 旧行 = 显基_光标行
    定义 旧列 = 显基_光标列
    定义 状态颜色 = 显基_白 | (显基_蓝 << 4)

    定义 可变 i = 0
    当 (i < 显基_宽) {
        显基_在位置写(显基_高 - 1, i, 32, 状态颜色)
        i = i + 1
    }
    // 左文本
    显基_在位置写字符串(显基_高 - 1, 1, 左文本, 状态颜色)
    // 右文本 (右对齐)
    定义 右起始 = 显基_宽 - 字符串长度(右文本) - 1
    如果 (右起始 > 0) {
        显基_在位置写字符串(显基_高 - 1, 右起始, 右文本, 状态颜色)
    }

    显基_光标行 = 旧行
    显基_光标列 = 旧列
    显基_更新光标()
}

// §6 进度条

函数 显基_进度条(当前, 总数, 宽度) {
    如果 (总数 == 0) { 返回 }
    定义 百分比 = 当前 * 100 / 总数
    定义 填充数 = 当前 * 宽度 / 总数

    显基_写字符(91)   // '['
    定义 可变 i = 0
    当 (i < 宽度) {
        如果 (i < 填充数) { 显基_写字符(35) }    // '#'
        否则 如果 (i == 填充数) { 显基_写字符(62) }  // '>'
        否则 { 显基_写字符(45) }                   // '-'
        i = i + 1
    }
    显基_写字符(93)   // ']'
    显基_写字符(32)
    显基_写整数(百分比)
    显基_写字符(37)   // '%'
}

// §7 框线绘制

函数 显基_画水平线(行, 起列, 长度, 颜色) {
    定义 可变 i = 0
    当 (i < 长度) {
        显基_在位置写(行, 起列 + i, 196, 颜色)  // '─'
        i = i + 1
    }
}

函数 显基_画垂直线(起行, 列, 长度, 颜色) {
    定义 可变 i = 0
    当 (i < 长度) {
        显基_在位置写(起行 + i, 列, 179, 颜色)  // '│'
        i = i + 1
    }
}

函数 显基_画方框(行, 列, 宽, 高, 颜色) {
    // 四角
    显基_在位置写(行, 列, 218, 颜色)            // ┌
    显基_在位置写(行, 列 + 宽 - 1, 191, 颜色)   // ┐
    显基_在位置写(行 + 高 - 1, 列, 192, 颜色)    // └
    显基_在位置写(行 + 高 - 1, 列 + 宽 - 1, 217, 颜色)  // ┘
    // 水平线
    显基_画水平线(行, 列 + 1, 宽 - 2, 颜色)
    显基_画水平线(行 + 高 - 1, 列 + 1, 宽 - 2, 颜色)
    // 垂直线
    显基_画垂直线(行 + 1, 列, 高 - 2, 颜色)
    显基_画垂直线(行 + 1, 列 + 宽 - 1, 高 - 2, 颜色)
}

// §8 区域操作

函数 显基_清区域(行, 列, 宽, 高, 颜色) {
    定义 可变 r = 0
    当 (r < 高) {
        定义 可变 c = 0
        当 (c < 宽) {
            显基_在位置写(行 + r, 列 + c, 32, 颜色)
            c = c + 1
        }
        r = r + 1
    }
}

函数 显基_填充区域(行, 列, 宽, 高, 字符, 颜色) {
    定义 可变 r = 0
    当 (r < 高) {
        定义 可变 c = 0
        当 (c < 宽) {
            显基_在位置写(行 + r, 列 + c, 字符, 颜色)
            c = c + 1
        }
        r = r + 1
    }
}

// §9 表格行输出

函数 显基_表格行(标签, 值) {
    显基_写字符串(标签)
    显基_写字符串(": ")
    显基_写字符串(值)
    显基_写字符(10)
    显基_总行输出 = 显基_总行输出 + 1
}

函数 显基_表格行_整数(标签, 值) {
    显基_写字符串(标签)
    显基_写字符串(": ")
    显基_写整数(值)
    显基_写字符(10)
    显基_总行输出 = 显基_总行输出 + 1
}

函数 显基_表格行_十六进制(标签, 值) {
    显基_写字符串(标签)
    显基_写字符串(": ")
    显基_写十六进制(值, 16)
    显基_写字符(10)
    显基_总行输出 = 显基_总行输出 + 1
}

// §10 控制台注册

函数 显基_控制台输出(文本) {
    显基_写字符串(文本)
    显基_写字符(10)
    显基_总行输出 = 显基_总行输出 + 1
}

函数 显基_控制台注册() {
    注册控制台_缓冲区(显基_控制台输出, "vga")
}

函数 显基_获取光标行() { 返回 显基_光标行 }
函数 显基_获取光标列() { 返回 显基_光标列 }

函数 显基_设置光标(行, 列) {
    显基_光标行 = 行
    显基_光标列 = 列
    显基_更新光标()
}

// §11 颜色工具

函数 显基_颜色名(颜色) {
    如果 (颜色 == 0) { 返回 "black" }
    如果 (颜色 == 1) { 返回 "blue" }
    如果 (颜色 == 2) { 返回 "green" }
    如果 (颜色 == 3) { 返回 "cyan" }
    如果 (颜色 == 4) { 返回 "red" }
    如果 (颜色 == 5) { 返回 "magenta" }
    如果 (颜色 == 6) { 返回 "brown" }
    如果 (颜色 == 7) { 返回 "white" }
    如果 (颜色 == 8) { 返回 "dark_gray" }
    如果 (颜色 == 9) { 返回 "light_blue" }
    如果 (颜色 == 10) { 返回 "light_green" }
    如果 (颜色 == 11) { 返回 "light_cyan" }
    如果 (颜色 == 12) { 返回 "light_red" }
    如果 (颜色 == 13) { 返回 "light_magenta" }
    如果 (颜色 == 14) { 返回 "yellow" }
    如果 (颜色 == 15) { 返回 "bright_white" }
    返回 "color_" + 整数转字符串(颜色)
}

函数 显基_组合颜色(前景, 背景) {
    返回 前景 | (背景 << 4)
}

// §12 统计

函数 显基_完整统计() {
    返回 [显基_光标行, 显基_光标列, 显基_当前颜色,
           显基_总字符输出, 显基_总行输出, 显基_总格式输出, 显基_总Dump输出]
}

函数 显基_打印统计() {
    打印行("=== VGA文本输出统计 ===")
    打印行("光标位置: (" + 整数转字符串(显基_光标行) + ", " + 整数转字符串(显基_光标列) + ")")
    打印行("当前颜色: " + 显基_颜色名(显基_当前颜色 & 0x0F) + " on " +
        显基_颜色名((显基_当前颜色 >> 4) & 0x0F))
    打印行("总字符输出: " + 整数转字符串(显基_总字符输出))
    打印行("总行输出: " + 整数转字符串(显基_总行输出))
    打印行("格式输出: " + 整数转字符串(显基_总格式输出))
    打印行("Dump输出: " + 整数转字符串(显基_总Dump输出))
    打印行("滚屏次数: " + 整数转字符串(显基_总滚屏次数))
}

函数 显基_字符是可显示(ch) {
    返回 ch >= 32 && ch < 127
}

函数 显基_字符映射(ch) {
    如果 (ch >= 32 && ch < 127) { 返回 ch }
    返回 46  // '.'
}

函数 显基_重置统计() {
    显基_总字符输出 = 0
    显基_总行输出 = 0
    显基_总格式输出 = 0
    显基_总Dump输出 = 0
    显基_总滚屏次数 = 0
}

函数 显基_获取总字符数() { 返回 显基_总字符输出 }
函数 显基_获取总行数() { 返回 显基_总行输出 }
函数 显基_获取滚屏数() { 返回 显基_总滚屏次数 }

// NVTD — Nova VGA Text Display Theory
// 公理1(内存映射): 字符+属性双字节直接映射显存
// 公理2(滚屏不丢失): 滚屏操作不丢失可见内容
// 公理3(颜色组合): 16前景×16背景=256种颜色组合
// 定理1(光标一致): 光标位置始终与下一写入位置一致
// 定理2(进度条单调): 百分比增加填充数单调增加

函数 显基_字符串居中(行, 文本, 颜色) {
    定义 屏宽 = 80  // VGA标准宽度
    定义 len = 字符串长度(文本)
    定义 列 = (屏宽 - len) / 2
    如果 (列 < 0) { 列 = 0 }
    显基_设置光标(行, 列)
    显基_设置颜色(颜色)
    显基_写字符串(文本)
}

函数 显基_字符串右对齐(行, 文本, 颜色) {
    定义 屏宽 = 80
    定义 len = 字符串长度(文本)
    定义 列 = 屏宽 - len
    如果 (列 < 0) { 列 = 0 }
    显基_设置光标(行, 列)
    显基_设置颜色(颜色)
    显基_写字符串(文本)
}

定义 可变 AI_显基写十六_运行指标 = 0
定义 可变 AI_显基写十六_异常指标 = 0

函数 AI_显基写十六_自诊断() {
    AI_显基写十六_运行指标 = 显基_总滚屏次数
    返回 AI_显基写十六_运行指标
}

函数 AI_显基写十六_优化建议() {
    定义 指标 = AI_显基写十六_自诊断()
    如果 (AI_显基写十六_运行指标 > 10000) { 返回 "显基写十六负载较高" }
    返回 "显基写十六状态正常"
}

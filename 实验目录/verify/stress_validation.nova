        原创_双环学习增益(620, 600, 620, 640, 280),
        原创_双环学习增益(620, 600, 620, 640, 320)
    ]
    如果 (!压力验证_序列不上升("双环学习", 学习_抗扰, "抗干扰参数")) { 通过 = 假 }
    如果 (!压力验证_断言(压力验证_首尾优势(学习_抗扰) >= 理论_抗干扰最小优势(), 警告_高, "双环学习 抗干扰优势不足")) { 通过 = 假 }
    定义 几何_抗扰 = [

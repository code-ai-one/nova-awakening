导入("../基础.nova")
导入("../数学/基础/数学库.nova")

定义 可变 ewc_旧参数 = []
定义 可变 EWC_Fisher矩阵 = []
定义 EWC_lambda系数 = 1000

函数 EWC_初始化(参数, lambda_v) {
 ewc_旧参数 = []
 EWC_Fisher矩阵 = []
 EWC_lambda系数 = lambda_v
 定义 可变 i = 0
 当 (i < 计数(参数)) { 追加(ewc_旧参数, 参数[i])
 追加(EWC_Fisher矩阵, 0)
 i = i + 1 }
}

函数 EWC_计算Fisher(梯度列表) { 定义 可变 i = 0
 当 (i < 计数(梯度列表)) { EWC_Fisher矩阵[i] = 梯度列表[i] * 梯度列表[i] / 1000
 i = i + 1 }
}

函数 EWC_惩罚(当前参数) { 定义 可变 损失 = 0
 定义 可变 i = 0
 当 (i < 计数(当前参数)) { 定义 差值 = 当前参数[i] - ewc_旧参数[i]
 损失 = 损失 + EWC_Fisher矩阵[i] * 差值 * 差值 / 1000000
 i = i + 1
 }
 返回 EWC_lambda系数 * 损失 / 2000
}

// Online EWC: 累积Fisher (running average)
定义 可变 oewc_Fisher累积 = []
定义 OEWC_衰减因子 = 900

函数 Online_EWC_初始化(参数, lambda_v, 衰减率) {
 EWC_初始化(参数, lambda_v)
 OEWC_衰减因子 = 衰减率
 oewc_Fisher累积 = []
 定义 可变 i = 0
 当 (i < 计数(参数)) { 追加(oewc_Fisher累积, 0)
 i = i + 1 }
}

函数 Online_EWC_更新Fisher(新Fisher) { 定义 可变 i = 0
 当 (i < 计数(新Fisher)) {
 oewc_Fisher累积[i] = OEWC_衰减因子 * oewc_Fisher累积[i] / 1000 + (1000 - OEWC_衰减因子) * 新Fisher[i] / 1000
 EWC_Fisher矩阵[i] = oewc_Fisher累积[i]
 i = i + 1
 }
}

// SI (Synaptic Intelligence)
定义 可变 SI_权重重要度 = []
定义 可变 si_旧参数 = []
定义 可变 si_累积路径 = []
定义 SI_正则系数 = 1000

函数 SI_初始化(参数, lambda_v) {
 SI_权重重要度 = []
 si_旧参数 = []
 si_累积路径 = []
 SI_正则系数 = lambda_v
 定义 可变 i = 0
 当 (i < 计数(参数)) {
 追加(SI_权重重要度, 0)
 追加(si_旧参数, 参数[i])
 追加(si_累积路径, 0)
 i = i + 1
 }
}

函数 SI_更新路径(梯度, 参数变化) { 定义 可变 i = 0
 当 (i < 计数(梯度)) {
 si_累积路径[i] = si_累积路径[i] + 绝对值(梯度[i] * 参数变化[i] / 1000)
 i = i + 1
 }
}

函数 SI_巩固(当前参数) { 定义 可变 i = 0
 当 (i < 计数(当前参数)) { 定义 增量 = 绝对值(当前参数[i] - si_旧参数[i])
 如果 (增量 > 0) {
 SI_权重重要度[i] = SI_权重重要度[i] + si_累积路径[i] * 1000 / (增量 * 增量 + 100)
 }
 si_旧参数[i] = 当前参数[i]
 si_累积路径[i] = 0
 i = i + 1
 }
}

函数 SI_惩罚(当前参数) { 定义 可变 损失 = 0
 定义 可变 i = 0
 当 (i < 计数(当前参数)) { 定义 差值 = 当前参数[i] - si_旧参数[i]
 损失 = 损失 + SI_权重重要度[i] * 差值 * 差值 / 1000000
 i = i + 1
 }
 返回 SI_正则系数 * 损失 / 2000
}

// 经验回放
定义 可变 持续_回放缓冲 = []
定义 可变 持续_回放容量 = 100
定义 可变 回放_大小 = 0
定义 可变 回放_写指针 = 0

函数 回放_初始化(容量) {
 持续_回放缓冲 = []
 持续_回放容量 = 容量
 回放_大小 = 0
 回放_写指针 = 0
 定义 可变 i = 0
 当 (i < 容量) { 追加(持续_回放缓冲, 0)
 i = i + 1 }
}

函数 回放_存储(样本) {
 持续_回放缓冲[回放_写指针] = 样本
 回放_写指针 = (回放_写指针 + 1) % 持续_回放容量
 如果 (回放_大小 < 持续_回放容量) { 回放_大小 = 回放_大小 + 1 }
}

// 优先回放: 按优先级采样 (高优先级样本被更频繁采样)
定义 可变 优先_缓冲 = []
定义 可变 优先_权重 = []
定义 可变 优先_容量 = 100
定义 可变 优先_大小 = 0

函数 优先回放_初始化(_容量) { 如果 (优先_大小 < 优先_容量) {
 追加(优先_缓冲, 样本)
 追加(优先_权重, 优先级)
 优先_大小 = 优先_大小 + 1
 } 否则 {
 // 替换最低优先级
 定义 可变 最小索引 = 0
 定义 可变 min_w = 优先_权重[0]
 定义 可变 i = 1
 当 (i < 优先_大小) { 如果 (优先_权重[i] < min_w) { min_w = 优先_权重[i]
 最小索引 = i }
 i = i + 1
 }
 如果 (优先级 > min_w) {
 优先_缓冲[最小索引] = 样本
 优先_权重[最小索引] = 优先级
 }
 }
}

函数 持续学习_优先回放_采样(种子) {
    如果 (优先_大小 == 0) { 返回 0
}
 定义 可变 sum_w = 0
 定义 可变 i = 0
 当 (i < 优先_大小) { sum_w = sum_w + 优先_权重[i]
 i = i + 1 }
 如果 (sum_w == 0) { 返回 优先_缓冲[0] }
 定义 随机值 = (种子 * 1103 + 12345) % sum_w
 定义 可变 累积 = 0
 i = 0
 当 (i < 优先_大小) {
 累积 = 累积 + 优先_权重[i]
 如果 (随机值 < 累积) { 返回 优先_缓冲[i] }
 i = i + 1
 }
 返回 优先_缓冲[优先_大小 - 1]
}

// 渐进式网络
定义 可变 渐进_列数 = 0
定义 可变 渐进_列参数 = []
定义 可变 渐进_冻结 = []

函数 渐进_添加列(参数) {
 追加(渐进_列参数, 参数)
 追加(渐进_冻结, 0)
 渐进_列数 = 渐进_列数 + 1
}

函数 渐进_冻结旧列() { 定义 可变 i = 0
 当 (i < 渐进_列数 - 1) { 渐进_冻结[i] = 1
 i = i + 1 }
}

函数 渐进_可训练列() { 返回 渐进_列数 - 1 }

函数 渐进_侧连接(_新列idx, 旧列idx, 权重) { 定义 可变 结果 = []
 定义 可变 i = 0
 定义 旧列 = 渐进_列参数[旧列idx]
 当 (i < 计数(旧列)) {
 追加(结果, 旧列[i] * 权重 / 1000)
 i = i + 1
 }
 返回 结果
}

// MAML
函数 MAML_内循环(参数, 梯度, 内学习率) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(参数)) {
 追加(结果, 参数[i] - 内学习率 * 梯度[i] / 1000)
 i = i + 1
 }
 返回 结果
}

函数 MAML_外更新(元参数, 任务梯度列表, 外学习率) { 定义 n_tasks = 计数(任务梯度列表)
 定义 维度 = 计数(元参数)
 定义 可变 新参数 = []
 定义 可变 d = 0
 当 (d < 维度) { 定义 可变 平均梯度 = 0
 定义 可变 t = 0
 当 (t < n_tasks) { 平均梯度 = 平均梯度 + 任务梯度列表[t][d]
 t = t + 1 }
 平均梯度 = 平均梯度 / n_tasks
 追加(新参数, 元参数[d] - 外学习率 * 平均梯度 / 1000)
 d = d + 1
 }
 返回 新参数
}

// 遗忘度量
函数 遗忘度(旧准确率, 新准确率) {
    如果 (旧准确率 == 0) { 返回 0
}
 返回 (旧准确率 - 新准确率) * 1000 / 旧准确率
}

函数 平均遗忘(旧列表, 新列表) { 定义 n = 计数(旧列表)
 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 f = 遗忘度(旧列表[i], 新列表[i])
 如果 (f > 0) { 总 = 总 + f }
 i = i + 1
 }
 如果 (n == 0) { 返回 0 }
 返回 总 / n
}

// 向后迁移 (Backward Transfer, 0): 学新任务后旧任务变化
函数 向后迁移(性能矩阵, n_tasks) { 定义 可变 bwt = 0
 定义 可变 计数值 = 0
 定义 可变 i = 0
 当 (i < n_tasks - 1) { 定义 final_perf = 性能矩阵[(n_tasks - 1) * n_tasks + i]
 定义 diag_perf = 性能矩阵[i * n_tasks + i]
 bwt = bwt + final_perf - diag_perf
 计数值 = 计数值 + 1
 i = i + 1
 }
 如果 (计数值 == 0) { 返回 0 }
 返回 bwt / 计数值
}

// 快速沃尔什 (Forward Transfer, 0 , 0): 学旧任务对新任务的帮助
函数 快速沃尔什(性能矩阵, 基线列表, n_tasks) { 定义 可变 fwt = 0
 定义 可变 计数值 = 0
 定义 可变 i = 1
 当 (i < n_tasks) { 定义 before_learn = 性能矩阵[(i - 1) * n_tasks + i]
 fwt = fwt + before_learn - 基线列表[i]
 计数值 = 计数值 + 1
 i = i + 1
 }
 如果 (计数值 == 0) { 返回 0 }
 返回 fwt / 计数值
}

// 知识蒸馏
函数 蒸馏损失(教师输出, 学生输出, 温度) { 定义 n = 计数(教师输出)
 定义 t2 = 温度 * 温度 / 1000
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 差 = 教师输出[i] - 学生输出[i]
 总和 = 总和 + 差 * 差 / t2
 i = i + 1
 }
 如果 (n == 0) { 返回 0 }
 返回 总和 / n
}

// 混合蒸馏: 学习率 * hard_loss + (1-学习率) * soft_loss
函数 混合蒸馏损失(hard_loss, soft_loss, 学习率) { 返回 学习率 * hard_loss / 1000 + (1000 - 学习率) * soft_loss / 1000
}

// 任务管理
定义 可变 任务_列表 = []
定义 可变 任务_当前 = 0

函数 任务_注册(任务id) { 追加(任务_列表, 任务id) }
函数 任务_切换(索引) { 任务_当前 = 索引 }
函数 任务_数量() { 返回 计数(任务_列表) }
函数 任务_当前id() { 返回 任务_列表[任务_当前] }

// 已学任务数
函数 已学任务数() { 返回 计数(任务_列表) }


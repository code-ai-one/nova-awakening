// 龙启 (DragonInit) — PID 1 init进程
//   1. PID 1是所有用户进程的祖先, 不能退出
//   2. 启动顺序: 挂载FS → 设备初始化 → 启动服务 → 运行终端
//   3. 持续回收orphan zombie进程(init是最终收割者)
//   4. 信号处理: SIGCHLD回收子进程, 忽略大部分信号
//   5. 重启/关机: 收到特殊信号时执行reboot/poweroff

定义 可变 init_运行中 = 真
定义 可变 init_运行级 = 0    // 0=单用户, 3=多用户, 5=图形, 6=重启
定义 可变 init_启动时间 = 0

定义 运行级_单用户  = 1
定义 运行级_多用户  = 3
定义 运行级_图形    = 5
定义 运行级_重启    = 6
定义 运行级_关机    = 0

// PID 1 入口 
// 由内核主函数在完成所有初始化后调用

函数 龙启_主函数() {
    init_启动时间 = sys_gettimeofday(空, 空, 0, 0, 0, 0)

    龙启_打印("═══════════════════════════════")
    龙启_打印("  龙启 (DragonInit) v1.0-M1")
    龙启_打印("  NovaOS PID 1 — init进程")
    龙启_打印("═══════════════════════════════")

    龙启_打印("[阶段1] 挂载核心文件系统...")
    龙启_挂载文件系统()

    龙启_打印("[阶段2] 初始化设备...")
    龙启_初始化设备()

    龙启_打印("[阶段3] 设置系统环境...")
    龙启_设置环境()

    龙启_打印("[阶段4] 启动核心服务...")
    龙启_启动服务()

    龙启_打印("[阶段5] 启动登录终端...")
    龙启_启动终端()

    龙启_打印("[龙启] 系统就绪, 进入init主循环")

    龙启_主循环()
}

// 阶段1: 挂载核心文件系统

函数 龙启_挂载文件系统() {
    // /proc — 进程信息
    定义 r1 = do_mount("none", "/proc", "proc")
    如果 (r1 == 成功) { 龙启_打印("  [OK] /proc (proNova公平调度)") }
    否则 { 龙启_打印("  [!!] /proc 挂载失败") }

    // /sys — 设备模型
    定义 r2 = do_mount("none", "/sys", "sysfs")
    如果 (r2 == 成功) { 龙启_打印("  [OK] /sys (sysfs)") }
    否则 { 龙启_打印("  [!!] /sys 挂载失败") }

    // /dev — 设备节点
    定义 r3 = do_mount("none", "/dev", "devtmpfs")
    如果 (r3 == 成功) { 龙启_打印("  [OK] /dev (devtmpfs)") }
    否则 { 龙启_打印("  [!!] /dev 挂载失败") }

    // /dev/pts — 伪终端
    sys_mkdir("/dev/pts", 0o755, 0, 0, 0, 0)
    do_mount("none", "/dev/pts", "devpts")

    // /dev/shm — 共享内存
    sys_mkdir("/dev/shm", 0o1777, 0, 0, 0, 0)
    do_mount("none", "/dev/shm", "tmpfs")

    // /tmp — 临时文件
    do_mount("none", "/tmp", "tmpfs")
    龙启_打印("  [OK] /tmp (tmpfs)")

    // /run — 运行时数据
    sys_mkdir("/run", 0o755, 0, 0, 0, 0)
    do_mount("none", "/run", "tmpfs")
    龙启_打印("  [OK] /run (tmpfs)")
}

// 阶段2: 设备初始化

函数 龙启_初始化设备() {
    // 创建标准设备节点(如果devtmpfs未自动创建)
    龙启_确保设备("/dev/null")
    龙启_确保设备("/dev/zero")
    龙启_确保设备("/dev/console")
    龙启_确保设备("/dev/tty")

    // 设置控制台
    // 打开/dev/console作为stdin/stdout/stderr
    定义 console_fd = sys_open("/dev/console", 2, 0, 0, 0, 0)  // O_RDWR
    如果 (console_fd >= 0) {
        // 确保fd 0,1,2指向控制台
        如果 (console_fd != 0) { sys_dup2(console_fd, 0, 0, 0, 0, 0) }
        sys_dup2(0, 1, 0, 0, 0, 0)   // stdout = stdin
        sys_dup2(0, 2, 0, 0, 0, 0)   // stderr = stdin
        如果 (console_fd > 2) { sys_close(console_fd, 0, 0, 0, 0, 0) }
        龙启_打印("  [OK] 控制台 /dev/console")
    }

    // 设置主机名
    龙启_打印("  [OK] 设备初始化完成")
}

函数 龙启_确保设备(路径) {
    如果 (!路径_存在(路径)) {
        龙启_打印("  [注] 设备不存在: " + 路径)
    }
}

// 阶段3: 设置系统环境

函数 龙启_设置环境() {
    // 设置默认PATH
    定义 默认PATH = "/bin:/sbin:/usr/bin:/usr/sbin:/usr/local/bin"

    // 设置主机名
    定义 主机名 = "novaos"
    // 写入/etc/hostname(如果存在)
    如果 (路径_存在("/etc/hostname")) {
        // 从文件读取主机名
    }
    龙启_打印("  主机名: " + 主机名)
    龙启_打印("  PATH: " + 默认PATH)
}

// 阶段4: 服务启动

函数 龙启_启动服务() {
    // 注册核心服务
    服务_注册("syslog", "/sbin/syslogd")
    服务_注册("龙脑", "/usr/sbin/龙脑")      // AI推理daemon
    服务_注册("龙使", "/usr/sbin/龙使")      // 智能体 daemon

    // 启动syslog(最先启动,其他服务的日志依赖它)
    定义 r1 = 服务_启动("syslog")
    如果 (r1 == 成功) { 龙启_打印("  [OK] syslog") }

    // 启动AI服务(如果可执行文件存在)
    如果 (路径_存在("/usr/sbin/龙脑")) {
        服务_启动("龙脑")
        龙启_打印("  [OK] 龙脑 (AI daemon)")
    } 否则 {
        龙启_打印("  [跳] 龙脑 (未安装)")
    }

    如果 (路径_存在("/usr/sbin/龙使")) {
        服务_启动("龙使")
        龙启_打印("  [OK] 龙使 (智能体 daemon)")
    } 否则 {
        龙启_打印("  [跳] 龙使 (未安装)")
    }

    // 执行/etc/rc.local(用户自定义启动脚本)
    如果 (路径_存在("/etc/rc.local")) {
        龙启_打印("  执行 /etc/rc.local...")
        龙启_执行脚本("/etc/rc.local")
    }
}

// 阶段5: 启动登录终端

函数 龙启_启动终端() {
    // 尝试多个init路径
    定义 init路径 = ["/bin/龙壳", "/bin/sh", "/sbin/init"]

    定义 可变 i = 0
    当 (i < 计数(init路径)) {
        如果 (路径_存在(init路径[i])) {
            龙启_fork_exec(init路径[i])
            龙启_打印("  [OK] 终端: " + init路径[i])
            返回
        }
        i = i + 1
    }

    // 所有路径都不存在: 直接调用内置龙壳
    龙启_打印("  [注] 外部终端不存在, 使用内置龙壳")
    龙启_fork_终端内置()
}

    定义 可变 html = ""
    html = 字符串拼接(html, "<div class='nova-command-deck'>")
    html = 字符串拼接(html, "<div class='nova-command-item'><strong>统一入口</strong><span>@对话、>命令、nova://路由合并到同一前台。</span></div>")
    html = 字符串拼接(html, "<div class='nova-command-item'><strong>多模态前台</strong><span>语音、视觉、触控、形象共享同一会话上下文。</span></div>")
    html = 字符串拼接(html, "<div class='nova-command-item'><strong>稳定演化</strong><span>热更新、自修复、回滚快照成为默认系统能力。</span></div>")
    html = 字符串拼接(html, "<div class='nova-command-item'><strong>可观测</strong><span>全链路埋点与风险评分实时输出。</span></div>")
    html = 字符串拼接(html, "</div>")

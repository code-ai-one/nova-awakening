// §4 VLAN支持(802.1Q,
// VLAN帧: 目标MAC(6) + 源MAC(6) + 0x8100(2) + TCI(2) + 实际类型(2) + 数据
// TCI = PCP(3bit优先级) + DEI(1bit) + VID(12bit VLAN ID)

定义 VLAN_头长度 = 4      // 0x8100(2) + TCI(2)
定义 可变 以太网_VLAN帧数 = 0

函数 以太网_封装_VLAN(Nova缓冲, 目标MAC, 源MAC, VLAN_ID, 优先级, 内部类型) {
    // 先封装VLAN标签
    Nova缓冲_前推(Nova缓冲, 以太网_头长度 + VLAN_头长度)
    定义 头 = Nova缓冲_数据(Nova缓冲)

    // 目标MAC
    定义 可变 i = 0
    当 (i < 以太网_MAC长度) {
        缓冲写(头, i, MAC_字节(目标MAC, i))
        i = i + 1
    }
    // 源MAC
    i = 0
    当 (i < 以太网_MAC长度) {
        缓冲写(头, 6 + i, MAC_字节(源MAC, i))
        i = i + 1
    }
    // EtherType = 0x8100 (VLAN)
    缓冲写(头, 12, 0x81)
    缓冲写(头, 13, 0x00)
    // TCI: PCP(3) + DEI(1) + VID(12)
    定义 TCI = ((优先级 & 0x07) << 13) | (VLAN_ID & 0x0FFF)
    缓冲写(头, 14, (TCI >> 8) & 0xFF)
    缓冲写(头, 15, TCI & 0xFF)
    // 内部EtherType
    缓冲写(头, 16, (内部类型 >> 8) & 0xFF)
    缓冲写(头, 17, 内部类型 & 0xFF)

    以太网_VLAN帧数 = 以太网_VLAN帧数 + 1
    返回 成功
}

函数 以太网_解析VLAN(Nova缓冲) {
    // 剥离VLAN标签, 返回[VLAN_ID, 优先级, 内部类型]
    定义 数据 = Nova缓冲_数据(Nova缓冲)
    定义 TCI = (缓冲读(数据, 0) << 8) | 缓冲读(数据, 1)
    定义 VLAN_ID = TCI & 0x0FFF
    定义 优先级 = (TCI >> 13) & 0x07
    定义 内部类型 = (缓冲读(数据, 2) << 8) | 缓冲读(数据, 3)
    Nova缓冲_拉取(Nova缓冲, VLAN_头长度)
    以太网_VLAN帧数 = 以太网_VLAN帧数 + 1
    返回 [VLAN_ID, 优先级, 内部类型]
}

// §5 IPv6分发 + 完整接收处理

函数 以太网_接收_完整(Nova缓冲, 设备) {
    定义 数据 = Nova缓冲_数据(Nova缓冲)
    定义 长度 = Nova缓冲_长度(Nova缓冲)

    如果 (长度 < 以太网_头长度) {
        以太网_接收丢弃 = 以太网_接收丢弃 + 1
        返回 错误_无效参数
    }

    // 提取目标MAC(判断是否发给我们)
    定义 目标 = MAC_从缓冲(数据, ETH_目标MAC)
    定义 本机MAC = 设备_获取MAC(设备)

    // 包类型判断
    定义 可变 包类型 = 0  // PACKET_HOST
    如果 (MAC_是广播(目标)) {
        包类型 = 1  // PACKET_BROADCAST
    } 否则 如果 (MAC_是多播(目标)) {
        包类型 = 2  // PACKET_MULTICAST
    } 否则 如果 (!MAC_相等(目标, 本机MAC)) {
        如果 (!设备_混杂模式(设备)) {
            以太网_接收丢弃 = 以太网_接收丢弃 + 1
            返回 错误_目标不匹配  // 不是给我们的
        }
        包类型 = 3  // PACKET_OTHERHOST
    }

    // 提取EtherType
    定义 类型 = (缓冲读(数据, ETH_类型) << 8) | 缓冲读(数据, ETH_类型 + 1)

    // 剥离以太网头
    Nova缓冲_拉取(Nova缓冲, 以太网_头长度)
    Nova缓冲_设置协议(Nova缓冲, 类型)

    以太网_接收计数 = 以太网_接收计数 + 1

    // VLAN处理
    如果 (类型 == 以太网类型_VLAN) {
        定义 VLAN信息 = 以太网_解析VLAN(Nova缓冲)
        类型 = VLAN信息[2]  // 内部类型
    }

    // 协议分发(完整版)
    如果 (类型 == 以太网类型_IP)   { 返回 IP_接收(Nova缓冲) }
    如果 (类型 == 以太网类型_ARP)  { 返回 ARP_接收(Nova缓冲) }
    如果 (类型 == 以太网类型_IPV6) { 返回 IPv6_接收(Nova缓冲) }

    以太网_接收丢弃 = 以太网_接收丢弃 + 1
    返回 错误_无效参数
}

函数 虚网支持_统计() {
    返回 {
        模块: "虚网支持",
        以太网_VLAN帧数: 以太网_VLAN帧数
    }
}

函数 虚网支持_健康评估() {
    定义 可变 问题 = []

    返回 计数(问题) == 0
}

函数 虚网支持_综合报告() {
    打印("[虚网支持] ═══ 综合报告 ═══")
    打印("  以太网_VLAN帧数: " + 整数转字符串(以太网_VLAN帧数))
    打印("  健康: " + 如果 (虚网支持_健康评估()) { "正常" } 否则 { "异常" })
}

函数 虚网支持_全局重置() {
    以太网_VLAN帧数 = 0
    打印("[虚网支持] 全局统计已重置")
    返回 0
}

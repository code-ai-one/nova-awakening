// §4 文本绘制 — 将字形位图合成到画布


函数 Text渲染er_绘制(bm, face, 文本, 文本长度, x, y, 颜色) {
    // x, y: 基线位置(像素)
    定义 可变 pen_x = x
    定义 可变 pos = 0

    定义 r = SkColor_R(颜色)
    定义 g = SkColor_G(颜色)
    定义 b = SkColor_B(颜色)

    当 (pos < 文本长度) {
        定义 解码 = UTF8_解码(文本, pos)
        定义 码点 = 解码[0]
        定义 字节数 = 解码[1]
        pos = pos + 字节数

        定义 glyph = 字体Face_获取字形(face, 码点)
        如果 (glyph == 0) { 继续 }

        // 字形位图位置
        定义 bx = pen_x + glyph.左偏移
        定义 by = y - glyph.上偏移

        // 合成字形(alpha混合)
        如果 (glyph.像素数据 != 0 && glyph.宽 > 0 && glyph.高 > 0) {
            定义 可变 gy = 0
            当 (gy < glyph.高) {
                定义 可变 gx = 0
                当 (gx < glyph.宽) {
                    定义 alpha = 内存_读8(glyph.像素数据 + gy * glyph.行字节数 + gx)
                    如果 (alpha > 0) {
                        定义 px = bx + gx
                        定义 py = by + gy
                        如果 (px >= 0 && px < bm.宽 && py >= 0 && py < bm.高) {
                            // 字形alpha × 文本颜色 → SrcOver混合
                            定义 混合色 = SkColor(alpha, r, g, b)
                            Sk画布_混合像素(bm, px, py, 混合色, 混合_SrcOver)
                        }
                    }
                    gx = gx + 1
                }
                gy = gy + 1
            }
        }

        pen_x = pen_x + glyph.前进宽度 / 64
    }
}

// §5 Unicode换行算法 (UAX#14 核心规则)
// 确定文本中哪些位置可以断行

定义 换行_禁止   = 0     // 不能在此处断行
定义 换行_允许   = 1     // 可以断行(优先级低)
定义 换行_必须   = 2     // 必须断行(\n)
定义 换行_机会   = 3     // 断行机会(空格后/CJK字符间)

函数 Unicode_获取换行机会(文本, 文本长度) {
    // 返回一个数组: 每个字符位置的断行类型
    定义 机会 = 堆_分配_数组(文本长度 * 4)
    内存_清零(机会, 文本长度 * 4)

    定义 可变 pos = 0
    定义 可变 prev_码点 = 0

    当 (pos < 文本长度) {
        定义 解码 = UTF8_解码(文本, pos)
        定义 码点 = 解码[0]
        定义 字节数 = 解码[1]

        定义 可变 类型 = 换行_禁止

        // 换行符
        如果 (码点 == 0x0A) { 类型 = 换行_必须 }
        // 空格后可断
        否则 如果 (prev_码点 == 0x20 || prev_码点 == 0x09) { 类型 = 换行_机会 }
        // CJK字符间可断(UAX#14: ID类)
        否则 如果 (Unicode_是CJK(码点) && Unicode_是CJK(prev_码点)) { 类型 = 换行_机会 }
        // CJK字符前后可断(与非CJK交界)
        否则 如果 (Unicode_是CJK(码点) && prev_码点 != 0) { 类型 = 换行_机会 }
        否则 如果 (Unicode_是CJK(prev_码点) && 码点 != 0) { 类型 = 换行_机会 }
        // 连字符后可断
        否则 如果 (prev_码点 == 0x2D) { 类型 = 换行_允许 }

        内存_写32(机会 + pos * 4, 类型)
        prev_码点 = 码点
        pos = pos + 字节数
    }

    返回 机会
}

函数 Unicode_是CJK(码点) {
    // CJK统一表意文字
    如果 (码点 >= 0x4E00 && 码点 <= 0x9FFF) { 返回 真 }
    如果 (码点 >= 0x3400 && 码点 <= 0x4DBF) { 返回 真 }
    如果 (码点 >= 0x20000 && 码点 <= 0x2A6DF) { 返回 真 }
    // 日文假名
    如果 (码点 >= 0x3040 && 码点 <= 0x309F) { 返回 真 }    // 平假名
    如果 (码点 >= 0x30A0 && 码点 <= 0x30FF) { 返回 真 }    // 片假名
    // 韩文音节
    如果 (码点 >= 0xAC00 && 码点 <= 0xD7AF) { 返回 真 }
    // 全角标点
    如果 (码点 >= 0x3000 && 码点 <= 0x303F) { 返回 真 }
    如果 (码点 >= 0xFF00 && 码点 <= 0xFFEF) { 返回 真 }
    返回 假
}

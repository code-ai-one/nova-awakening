// 记忆阶段装载
// 关键主链: 文件 / 路径 / 挂载 / 文件层 / 智能缓存

导入("../中枢/阶段契约.nova")
导入("./文件读写.nova")
导入("./路径查找.nova")
导入("./文件描述符.nova")
导入("./文件系统类.nova")
导入("./挂载系统.nova")
导入("./文件层接口.nova")
导入("./智能文件缓.nova")
导入("./智能路径预.nova")
导入("./智能预读.nova")

定义 可变 记忆阶段装载_已装载 = []

函数 记忆阶段装载_清单(阶段) {
    如果 (阶段 == 阶段_boot) {
        返回 ["./文件描述符.nova", "./路径查找.nova"]
    }
    如果 (阶段 == 阶段_内核核心) {
        返回 ["./文件读写.nova", "./文件系统类.nova", "./文件层接口.nova"]
    }
    如果 (阶段 == 阶段_浏览器外衣) {
        返回 ["./文件读写.nova", "./智能文件缓.nova", "./智能路径预.nova"]
    }
    如果 (阶段 == 阶段_AI运行时) {
        返回 ["./智能文件缓.nova", "./智能预读.nova", "./文件读写.nova"]
    }
    如果 (阶段 == 阶段_外部桥接) {
        返回 ["./挂载系统.nova", "./文件层接口.nova", "./文件读写.nova"]
    }
    返回 []
}

函数 记忆阶段装载_登记(阶段) {
    定义 可变 i = 0
    当 (i < 计数(记忆阶段装载_已装载)) {
        如果 (记忆阶段装载_已装载[i] == 阶段) { 返回 计数(记忆阶段装载_清单(阶段)) }
        i = i + 1
    }
    追加(记忆阶段装载_已装载, 阶段)
    返回 计数(记忆阶段装载_清单(阶段))
}

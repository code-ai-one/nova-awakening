导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./编排初始化.nova")
导入("./真实点击.nova")
导入("../外联/序列工具.nova")
导入("../中枢/内核打印.nova")
导入("./视觉识别引.nova")
导入("./透明代理.nova")
导入("./统一破解入.nova")
导入("../中枢/高精定器添.nova")
导入("../中枢/整数转字符串.nova")

定义 恢复_最大重试 = 5
定义 恢复_最大历史 = 64
定义 恢复_基础延迟_ms = 1000
定义 恢复_最大延迟_ms = 30000

定义 错误类型_网络 = 1
定义 错误类型_超时 = 2
定义 错误类型_验证码 = 3
定义 错误类型_弹窗 = 4
定义 错误类型_元素未找到 = 5
定义 错误类型_页面崩溃 = 6
定义 错误类型_封禁 = 7
定义 错误类型_未知 = 99

定义 断路器_关闭 = 0
定义 断路器_打开 = 1
定义 断路器_半开 = 2
定义 断路器_失败阈值 = 5
定义 断路器_恢复时间_ms = 60000

定义 可变 编排_任务列表 = []
定义 可变 编排_总任务数 = 0
定义 可变 编排_总成功数 = 0

结构 恢复历史项 {
    任务ID,
    错误类型,
    错误描述,
    恢复策略,
    成功,
    时间戳,
    重试次数,
}

结构 断路器 {
    状态,
    连续失败数,
    上次失败时间,
    上次成功时间,
    总调用数,
    失败率,
}

结构 异常恢复统计 {
    恢复尝试次数,
    恢复成功次数,
    恢复失败次数,
    验证码处理次数,
    弹窗关闭次数,
    IP轮换次数,
    页面刷新次数,
    超时恢复次数,
    断路器触发次数,
    断路器恢复次数,
    降级次数,
    AI诊断次数,
}

定义 可变 全局_恢复统计 = 空
定义 可变 全局_恢复历史 = []
定义 可变 全局_恢复历史数 = 0
定义 可变 全局_断路器 = 空

函数 恢复统计_初始化() {
    如果 (全局_恢复统计 == 空) {
        全局_恢复统计 = 异常恢复统计 {}
        全局_恢复统计.恢复尝试次数 = 0
        全局_恢复统计.恢复成功次数 = 0
        全局_恢复统计.恢复失败次数 = 0
        全局_恢复统计.验证码处理次数 = 0
        全局_恢复统计.弹窗关闭次数 = 0
        全局_恢复统计.IP轮换次数 = 0
        全局_恢复统计.页面刷新次数 = 0
        全局_恢复统计.超时恢复次数 = 0
        全局_恢复统计.断路器触发次数 = 0
        全局_恢复统计.断路器恢复次数 = 0
        全局_恢复统计.降级次数 = 0
        全局_恢复统计.AI诊断次数 = 0

        全局_断路器 = 断路器 {}
        全局_断路器.状态 = 断路器_关闭
        全局_断路器.连续失败数 = 0
        全局_断路器.上次失败时间 = 0
        全局_断路器.上次成功时间 = 0
        全局_断路器.总调用数 = 0
        全局_断路器.失败率 = 0
    }
}

函数 恢复_分类错误(任务, 步骤) {
    如果 (步骤 == 空) { 返回 错误类型_未知 }
    如果 (步骤.错误代码 == 408 || 步骤.错误代码 == 504) { 返回 错误类型_超时 }
    如果 (步骤.错误代码 == 403 || 步骤.错误代码 == 429) { 返回 错误类型_封禁 }
    如果 (步骤.错误代码 >= 500) { 返回 错误类型_页面崩溃 }

    定义 视觉状态 = 视觉识别_分析页面()
    如果 (视觉状态 != 空) {
        如果 (视觉状态.有验证码) { 返回 错误类型_验证码 }
        如果 (视觉状态.有弹窗) { 返回 错误类型_弹窗 }
    }

    如果 (步骤.类型 == 步骤_点击 || 步骤.类型 == 步骤_输入) {
        返回 错误类型_元素未找到
    }
    返回 错误类型_网络
}

函数 恢复_计算延迟(重试次数) {
    定义 可变 延迟 = 恢复_基础延迟_ms
    定义 可变 i = 0
    当 (i < 重试次数) {
        延迟 = 延迟 * 2
        i = i + 1
    }
    如果 (延迟 > 恢复_最大延迟_ms) { 延迟 = 恢复_最大延迟_ms }

    定义 抖动 = (获取滴答() % 500) - 250
    延迟 = 延迟 + 抖动
    如果 (延迟 < 恢复_基础延迟_ms) { 延迟 = 恢复_基础延迟_ms }
    返回 延迟
}

函数 断路器_检查() {
    恢复统计_初始化()
    全局_断路器.总调用数 = 全局_断路器.总调用数 + 1

    如果 (全局_断路器.状态 == 断路器_打开) {
        定义 已过时间 = 获取滴答() - 全局_断路器.上次失败时间
        如果 (已过时间 > 断路器_恢复时间_ms * 1000) {
            全局_断路器.状态 = 断路器_半开
            全局_恢复统计.断路器恢复次数 = 全局_恢复统计.断路器恢复次数 + 1
            返回 真
        }
        返回 假
    }
    返回 真
}

函数 断路器_记录成功() {
    恢复统计_初始化()
    全局_断路器.连续失败数 = 0
    全局_断路器.上次成功时间 = 获取滴答()
    如果 (全局_断路器.状态 == 断路器_半开) {
        全局_断路器.状态 = 断路器_关闭
    }
}

函数 断路器_记录失败() {
    恢复统计_初始化()
    全局_断路器.连续失败数 = 全局_断路器.连续失败数 + 1
    全局_断路器.上次失败时间 = 获取滴答()
    如果 (全局_断路器.连续失败数 >= 断路器_失败阈值) {
        全局_断路器.状态 = 断路器_打开
        全局_恢复统计.断路器触发次数 = 全局_恢复统计.断路器触发次数 + 1
    }
}

函数 任务编排_异常恢复(任务, 步骤) {
    恢复统计_初始化()
    全局_恢复统计.恢复尝试次数 = 全局_恢复统计.恢复尝试次数 + 1

    内核信息("任务编排: 异常恢复, 重试#" + 整数转字符串(任务.重试次数))

    如果 (!断路器_检查()) {
        内核信息("任务编排: 断路器已打开, 跳过恢复")
        全局_恢复统计.恢复失败次数 = 全局_恢复统计.恢复失败次数 + 1
        恢复_记录历史(任务, 错误类型_未知, "断路器阻止", "跳过", 假)
        返回
    }

    如果 (任务.重试次数 >= 恢复_最大重试) {
        内核信息("任务编排: 已达最大重试次数, 降级处理")
        全局_恢复统计.降级次数 = 全局_恢复统计.降级次数 + 1
        恢复_降级处理(任务)
        断路器_记录失败()
        返回
    }

    定义 错误类型 = 恢复_分类错误(任务, 步骤)
    定义 可变 恢复成功 = 假

    如果 (错误类型 == 错误类型_验证码) {
        恢复成功 = 恢复_处理验证码()
    } 否则 如果 (错误类型 == 错误类型_弹窗) {
        恢复成功 = 恢复_关闭弹窗()
    } 否则 如果 (错误类型 == 错误类型_超时) {
        恢复成功 = 恢复_处理超时(任务)
    } 否则 如果 (错误类型 == 错误类型_封禁) {
        恢复成功 = 恢复_处理封禁(任务)
    } 否则 如果 (错误类型 == 错误类型_元素未找到) {
        恢复成功 = 恢复_处理元素未找到(任务, 步骤)
    } 否则 如果 (错误类型 == 错误类型_页面崩溃) {
        恢复成功 = 恢复_处理页面崩溃(任务)
    } 否则 {
        恢复成功 = 恢复_通用重试(任务)
    }

    如果 (恢复成功) {
        全局_恢复统计.恢复成功次数 = 全局_恢复统计.恢复成功次数 + 1
        断路器_记录成功()
    } 否则 {
        全局_恢复统计.恢复失败次数 = 全局_恢复统计.恢复失败次数 + 1
        断路器_记录失败()
    }

    定义 策略名 = 恢复_错误类型名(错误类型)
    恢复_记录历史(任务, 错误类型, "", 策略名, 恢复成功)
}

函数 恢复_处理验证码() {
    恢复统计_初始化()
    全局_恢复统计.验证码处理次数 = 全局_恢复统计.验证码处理次数 + 1

    定义 视觉状态 = 视觉识别_分析页面()
    如果 (视觉状态.有验证码 && DOM_当前文档 != 空) {
        验证破解_自动处理(DOM_当前文档)
        返回 真
    }
    返回 假
}

函数 恢复_关闭弹窗() {
    恢复统计_初始化()
    全局_恢复统计.弹窗关闭次数 = 全局_恢复统计.弹窗关闭次数 + 1

    定义 按钮文本 = ["关闭", "Close", "Accept", "确定", "OK", "Dismiss", "取消", "拒绝"]
    定义 可变 i = 0
    当 (i < 计数(按钮文本)) {
        定义 关闭 = 视觉识别_查找按钮(按钮文本[i])
        如果 (关闭 != 空) {
            行为仿真_点击(关闭.x + 关闭.宽 / 2, 关闭.y + 关闭.高 / 2)
            返回 真
        }
        i = i + 1
    }

    行为仿真_按键("Escape")
    返回 真
}

函数 恢复_处理超时(任务) {
    恢复统计_初始化()
    全局_恢复统计.超时恢复次数 = 全局_恢复统计.超时恢复次数 + 1

    定义 延迟 = 恢复_计算延迟(任务.重试次数)
    等待_毫秒(延迟)

    全局_恢复统计.页面刷新次数 = 全局_恢复统计.页面刷新次数 + 1
    行为仿真_刷新()
    返回 真
}

函数 恢复_处理封禁(任务) {
    恢复统计_初始化()
    全局_恢复统计.IP轮换次数 = 全局_恢复统计.IP轮换次数 + 1

    IP隐匿_轮换()

    定义 延迟 = 恢复_计算延迟(任务.重试次数)
    等待_毫秒(延迟)

    返回 真
}

函数 恢复_处理元素未找到(任务, 步骤) {
    等待_毫秒(2000)

    定义 视觉状态 = 视觉识别_分析页面()
    如果 (视觉状态 != 空 && 视觉状态.页面已加载) {
        返回 真
    }

    全局_恢复统计.页面刷新次数 = 全局_恢复统计.页面刷新次数 + 1
    行为仿真_刷新()
    等待_毫秒(3000)
    返回 真
}

函数 恢复_处理页面崩溃(任务) {
    全局_恢复统计.页面刷新次数 = 全局_恢复统计.页面刷新次数 + 1
    行为仿真_刷新()
    等待_毫秒(5000)
    返回 真
}

函数 恢复_通用重试(任务) {
    定义 延迟 = 恢复_计算延迟(任务.重试次数)
    等待_毫秒(延迟)
    返回 真
}

函数 恢复_降级处理(任务) {
    内核信息("任务编排: 降级 - 任务 " + 整数转字符串(任务.ID) + " 标记为失败")
    任务.状态 = "失败"
}

函数 恢复_AI诊断(任务, 步骤) {
    恢复统计_初始化()
    全局_恢复统计.AI诊断次数 = 全局_恢复统计.AI诊断次数 + 1

    定义 描述 = "任务编排异常诊断: 任务ID=" + 整数转字符串(任务.ID) +
                  " 重试=" + 整数转字符串(任务.重试次数) +
                  " 错误类型=" + 整数转字符串(恢复_分类错误(任务, 步骤))
    定义 建议 = 智能_接口_推理(描述)
    返回 建议
}

函数 恢复_错误类型名(类型) {
    如果 (类型 == 错误类型_网络) { 返回 "网络" }
    如果 (类型 == 错误类型_超时) { 返回 "超时" }
    如果 (类型 == 错误类型_验证码) { 返回 "验证码" }
    如果 (类型 == 错误类型_弹窗) { 返回 "弹窗" }
    如果 (类型 == 错误类型_元素未找到) { 返回 "元素未找到" }
    如果 (类型 == 错误类型_页面崩溃) { 返回 "页面崩溃" }
    如果 (类型 == 错误类型_封禁) { 返回 "封禁" }
    返回 "未知"
}

函数 恢复_记录历史(任务, 错误类型, 错误描述, 策略, 成功) {
    如果 (全局_恢复历史数 >= 恢复_最大历史) {
        定义 可变 i = 0
        当 (i < 全局_恢复历史数 - 1) {
            全局_恢复历史[i] = 全局_恢复历史[i + 1]
            i = i + 1
        }
        全局_恢复历史数 = 全局_恢复历史数 - 1
    }
    定义 项 = 恢复历史项 {}
    项.任务ID = 任务.ID
    项.错误类型 = 错误类型
    项.错误描述 = 错误描述
    项.恢复策略 = 策略
    项.成功 = 成功
    项.时间戳 = 获取滴答()
    项.重试次数 = 任务.重试次数
    如果 (全局_恢复历史数 < 计数(全局_恢复历史)) {
        全局_恢复历史[全局_恢复历史数] = 项
    } 否则 {
        追加(全局_恢复历史, 项)
    }
    全局_恢复历史数 = 全局_恢复历史数 + 1
}

函数 任务编排_快速导航(url) {
    定义 id = 任务编排_创建任务("导航", url)
    定义 步骤 = 任务步骤 {}
    步骤.类型 = 步骤_导航; 步骤.URL = url
    任务编排_添加步骤(id, 步骤)
    返回 任务编排_执行(id)
}

函数 任务编排_快速登录(url, 用户名, 密码) {
    定义 id = 任务编排_创建任务("自动登录", url)
    定义 s1 = 任务步骤 {}; s1.类型 = 步骤_导航; s1.URL = url
    任务编排_添加步骤(id, s1)
    定义 s2 = 任务步骤 {}; s2.类型 = 步骤_等待; s2.等待时间 = 2000
    任务编排_添加步骤(id, s2)
    定义 s3 = 任务步骤 {}; s3.类型 = 步骤_输入; s3.文字 = 用户名
    s3.定位方式 = 定位_视觉类型; s3.选择器 = "username"
    任务编排_添加步骤(id, s3)
    定义 s4 = 任务步骤 {}; s4.类型 = 步骤_输入; s4.文字 = 密码
    s4.定位方式 = 定位_视觉类型; s4.选择器 = "password"
    任务编排_添加步骤(id, s4)
    定义 s5 = 任务步骤 {}; s5.类型 = 步骤_点击
    s5.定位方式 = 定位_视觉文字; s5.选择器 = "登录"
    任务编排_添加步骤(id, s5)
    定义 s6 = 任务步骤 {}; s6.类型 = 步骤_验证处理
    任务编排_添加步骤(id, s6)

    返回 任务编排_执行(id)
}

函数 任务编排_快速截图(url, 保存路径) {
    定义 id = 任务编排_创建任务("截图", url)
    定义 s1 = 任务步骤 {}; s1.类型 = 步骤_导航; s1.URL = url
    任务编排_添加步骤(id, s1)
    定义 s2 = 任务步骤 {}; s2.类型 = 步骤_等待; s2.等待时间 = 3000
    任务编排_添加步骤(id, s2)
    定义 s3 = 任务步骤 {}; s3.类型 = 步骤_截图; s3.保存路径 = 保存路径
    任务编排_添加步骤(id, s3)
    返回 任务编排_执行(id)
}

函数 任务编排_查找(任务ID) {
    定义 可变 i = 0
    当 (i < 计数(编排_任务列表)) {
        如果 (编排_任务列表[i].ID == 任务ID) {
            返回 编排_任务列表[i]
        }
        i = i + 1
    }
    返回 空
}

函数 任务编排_统计() {
    返回 [编排_总任务数, 编排_总成功数, 计数(编排_任务列表)]
}

函数 异常恢复_打印统计() {
    恢复统计_初始化()
    打印行("=== 异常恢复统计 ===")
    打印行("恢复尝试: " + 整数转字符串(全局_恢复统计.恢复尝试次数))
    打印行("恢复成功: " + 整数转字符串(全局_恢复统计.恢复成功次数))
    打印行("恢复失败: " + 整数转字符串(全局_恢复统计.恢复失败次数))
    打印行("验证码处理: " + 整数转字符串(全局_恢复统计.验证码处理次数))
    打印行("弹窗关闭: " + 整数转字符串(全局_恢复统计.弹窗关闭次数))
    打印行("IP轮换: " + 整数转字符串(全局_恢复统计.IP轮换次数))
    打印行("页面刷新: " + 整数转字符串(全局_恢复统计.页面刷新次数))
    打印行("超时恢复: " + 整数转字符串(全局_恢复统计.超时恢复次数))
    打印行("断路器触发: " + 整数转字符串(全局_恢复统计.断路器触发次数))
    打印行("断路器恢复: " + 整数转字符串(全局_恢复统计.断路器恢复次数))
    打印行("降级: " + 整数转字符串(全局_恢复统计.降级次数))
    打印行("AI诊断: " + 整数转字符串(全局_恢复统计.AI诊断次数))
    打印行("恢复历史: " + 整数转字符串(全局_恢复历史数) + " 条")
    打印行("断路器状态: " + 整数转字符串(全局_断路器.状态))
}

// 恢复策略评分与自适应重试

函数 恢复_策略评分(任务, 步骤) {
    // 评估各恢复策略的适用性得分
    定义 错误类型 = 恢复_分类错误(任务, 步骤)
    定义 可变 重试分 = 0
    定义 可变 刷新分 = 0
    定义 可变 降级分 = 0

    // 网络错误重试效果好
    如果 (错误类型 == 错误类型_网络) { 重试分 = 80 }
    如果 (错误类型 == 错误类型_超时) { 重试分 = 70 }
    如果 (错误类型 == 错误类型_页面崩溃) { 刷新分 = 90 }
    如果 (错误类型 == 错误类型_封禁) { 降级分 = 95 }
    如果 (错误类型 == 错误类型_元素未找到) { 刷新分 = 60; 重试分 = 50 }

    // 重试次数越多, 重试得分越低
    如果 (任务.重试次数 > 2) { 重试分 = 重试分 / 2 }
    如果 (任务.重试次数 > 5) { 降级分 = 100 }

    返回 [重试分, 刷新分, 降级分]
}

函数 恢复_自适应延迟(重试次数, 基础延迟) {
    // 指数退避 + 报动: delay * 2^retry + jitter
    定义 可变 延迟 = 基础延迟
    定义 可变 i = 0
    当 (i < 重试次数 && i < 6) {
        延迟 = 延迟 * 2
        i = i + 1
    }
    // 封顶 60秒
    如果 (延迟 > 60000) { 延迟 = 60000 }
    // 报动: ±20%
    定义 jitter = (延迟 * (获取滴答() % 40)) / 100
    返回 延迟 + jitter - 延迟 / 5
}

函数 恢复_重置统计() {
    恢复统计_初始化()
    全局_恢复统计.恢复尝试次数 = 0
    全局_恢复统计.恢复成功次数 = 0
    全局_恢复统计.恢复失败次数 = 0
    全局_恢复统计.验证码处理次数 = 0
    全局_恢复统计.弹窗关闭次数 = 0
    全局_恢复统计.IP轮换次数 = 0
    全局_恢复统计.页面刷新次数 = 0
    全局_恢复统计.超时恢复次数 = 0
    全局_恢复统计.断路器触发次数 = 0
    全局_恢复统计.断路器恢复次数 = 0
    全局_恢复统计.降级次数 = 0
    全局_恢复统计.AI诊断次数 = 0
}

// NAER — Nova Autonomous Error Recovery
// 公理1(分类完备): 所有异常均可归类到已知策略
// 公理2(指数退避): 重试延迟指数增长避免雪崩
// 公理3(断路器安全): 断路器防止级联失败扩散
// 定理1(收敛性): 重试在有限次后必定成功或降级
// 定理2(评分单调): 重试次数越多重试得分越低, 降级得分越高

函数 恢复_历史查询(任务ID) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 全局_恢复历史数) {
        如果 (全局_恢复历史[i].任务ID == 任务ID) {
            追加(结果, 全局_恢复历史[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 恢复_成功率() {
    恢复统计_初始化()
    定义 总 = 全局_恢复统计.恢复尝试次数
    如果 (总 == 0) { 返回 0 }
    返回 全局_恢复统计.恢复成功次数 * 100 / 总
}

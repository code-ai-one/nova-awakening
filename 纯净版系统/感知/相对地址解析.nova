// NovaOS 渲染引擎 — 相对URL解析 + URL合并 + 导航URL处理
// 子系统: 渲染引擎/地址/地址解析
// 实现: RFC 3986 §5 相对引用解析算法
//   相对→绝对URL转换 + 路径规范化(./..) + 查询/片段继承
//   data:/blob: URL检测 + 基础URL提取 + URL合并工具
// 原创: NovaOS · 纯中文原生系统编程 · AI原生导航模式预测

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../执行/控制台输出.nova")
导入("../中枢/字符串替换.nova")
导入("../外联/地址解析辅.nova")
导入("../中枢/创建甲.nova")
导入("./地址解析器地.nova")

// §0 常量与数据结构

定义 URL类型_绝对 = 0
定义 URL类型_协议相对 = 1      // "//host/path"
定义 URL类型_绝对路径 = 2      // "/path"
定义 URL类型_相对路径 = 3      // "relative/path"
定义 URL类型_仅查询 = 4        // "?query"
定义 URL类型_仅片段 = 5        // "#fragment"
定义 URL类型_空 = 6
定义 URL类型_特殊 = 7          // data: blob: javascript:
定义 最大路径段数 = 64
定义 最大URL长度 = 65536

结构 ParsedURL {
    scheme,          // u64 字符串指针
    username,
    password,
    host,
    host长度,
    host哈希,
    port,
    默认端口,
    path,
    path长度,
    query,
    query长度,
    fragment,
    fragment长度,
    是有效,
    是特殊,
    路径,            // u64 (别名, 兼容旧代码)
}

结构 相对解析统计 {
    解析总次数,
    绝对URL直通次数,
    协议相对次数,
    绝对路径次数,
    相对路径次数,
    仅查询次数,
    仅片段次数,
    data_URL次数,
    blob_URL次数,
    路径规范化次数,
    路径段弹出次数,
    基础URL提取次数,
    URL合并次数,
    总解析耗时_纳秒,
    AI导航调用次数,
    AI导航命中次数,
    错误总数,
    溢出保护次数,
}

结构 AI导航状态 {
    历史相对URL比例,     // u32 Q10 (相对URL/总URL)
    历史平均路径深度,    // u32 Q10 (路径中/的数量)
    历史查询继承率,      // u32 Q10
    连续同域导航数,
    连续跨域导航数,
    预测下次同域,
    上次基础host哈希,
    采样计数器,
    学习权重,            // u32 Q10
}

定义 可变 全局相对解析统计 = 0
定义 可变 全局导航AI = 0
定义 可变 全局相对解析已初始化 = 假

// §0.5 生命周期


函数 相对解析_初始化() {
    如果 (全局相对解析已初始化 == 真) { 返回 错误_已存在 }
    全局相对解析统计 = 堆_分配_清零(144)
    如果 (全局相对解析统计 == 空) { 返回 错误_内存不足 }
    全局导航AI = 堆_分配_清零(48)
    如果 (全局导航AI != 空) {
        全局导航AI.预测下次同域 = 真
        全局导航AI.学习权重 = 128
    }
    全局相对解析已初始化 = 真
    打印("[相对解析] 初始化完成")
    返回 0
}

函数 相对解析_销毁() {
    如果 (全局相对解析统计 != 空) { 堆_释放(全局相对解析统计); 全局相对解析统计 = 0 }
    如果 (全局导航AI != 空) { 堆_释放(全局导航AI); 全局导航AI = 0 }
    全局相对解析已初始化 = 假
    返回 0
}

函数 相对解析_重置() {
    如果 (全局相对解析统计 != 空) { 内存_置零(全局相对解析统计, 144) }
    返回 0
}

// §1 URL类型检测

函数 URL_检测类型(url字符串) {
    如果 (url字符串 == 空) { 返回 URL类型_空 }
    定义 长度 = 字节长度(url字符串)
    如果 (长度 == 0) { 返回 URL类型_空 }
    定义 首字符 = 字节取(url字符串, 0)
    // "#fragment"
    如果 (首字符 == 35) { 返回 URL类型_仅片段 }
    // "?query"
    如果 (首字符 == 63) { 返回 URL类型_仅查询 }
    // "//host/path"
    如果 (长度 >= 2 && 首字符 == 47 && 字节取(url字符串, 1) == 47) {
        返回 URL类型_协议相对
    }
    // "/path"
    如果 (首字符 == 47) { 返回 URL类型_绝对路径 }
    // 检查是否有scheme:
    定义 可变 i = 0
    当 (i < 长度 && i < 32) {
        定义 ch = 字节取(url字符串, i)
        如果 (ch == 58) {
            // 找到冒号 — 检查前面是否都是scheme字符
            如果 (i > 0) {
                // 检查data:/blob:/javascript:
                如果 (i == 4 && 字节取(url字符串, 0) == 100) { 返回 URL类型_特殊 }
                如果 (i == 4 && 字节取(url字符串, 0) == 98) { 返回 URL类型_特殊 }
                返回 URL类型_绝对
            }
            止
        }
        如果 (URL_是scheme字符(ch) == 假 && i > 0) { 止 }
        i = i + 1
    }
    返回 URL类型_相对路径
}

// §2 核心相对URL解析(增强版)

函数 URL_解析相对(相对URL, 基础URL) {
    如果 (相对URL == 0 || 基础URL == 0) { 返回 0 }

    // 绝对URL直接解析
    定义 长度 = 字节长度(相对URL)
    如果 (长度 > 5) {
        定义 可变 i = 0
        当 (i < 长度 && URL_是scheme字符(字节取(相对URL, i))) { i = i + 1 }
        如果 (i > 0 && i < 长度 && 字节取(相对URL, i) == 58) {
            返回 URL_解析(相对URL)    // 有scheme→绝对URL
        }
    }

    定义 结果 = 堆_分配(ParsedURL)
    // 继承基础URL的scheme
    结果.scheme = 基础URL.scheme
    结果.默认端口 = 基础URL.默认端口
    结果.是特殊 = 基础URL.是特殊

    如果 (长度 >= 2 && 字节取(相对URL, 0) == 47 && 字节取(相对URL, 1) == 47) {
        // "//host/path" → 继承scheme
        定义 全URL = 字符串拼接(基础URL.scheme, ":")
        全URL = 字符串拼接(全URL, 相对URL)
        堆_释放(结果)
        返回 URL_解析(全URL)
    }

    // 继承authority
    结果.host = 基础URL.host
    结果.host长度 = 基础URL.host长度
    结果.host哈希 = 基础URL.host哈希
    结果.port = 基础URL.port

    如果 (长度 > 0 && 字节取(相对URL, 0) == 47) {
        // "/path" → 绝对路径
        结果.path = 相对URL
        结果.path长度 = 长度
    } 否则 {
        // "relative/path" → 合并路径
        // 基础path去掉最后一个/之后的部分, 拼接相对path
        定义 基础路径 = 基础URL.path
        定义 可变 最后斜杠 = 0
        定义 可变 k = 0
        当 (k < 基础URL.path长度) {
            如果 (字节取(基础路径, k) == 47) { 最后斜杠 = k }
            k = k + 1
        }
        定义 前缀 = 字符串_截取(基础路径, 0, 最后斜杠 + 1)
        结果.path = 字符串拼接(前缀, 相对URL)
        结果.path长度 = 字节长度(结果.path)
    }

    // 路径规范化: 去除./和../
    URL_规范化路径(结果)

    结果.是有效 = 真
    返回 结果
}

函数 URL_规范化路径(url) {
    // 路径规范化: 处理 /./ 和 /../
    如果 (url == 0 || url.路径 == 0) { 返回 }
    定义 path = url.路径
    定义 len = 字节长度(path)
    如果 (len == 0) { 返回 }

    // 段堆栈: 最多64段
    定义 段 = 堆_分配(64 * 8)
    定义 可变 段数 = 0
    定义 可变 pos = 0

    // 跳过前导 /
    如果 (内存_读8(path) == 0x2F) { pos = 1 }

    当 (pos < len) {
        // 找到下一个 / 或末尾
        定义 可变 end = pos
        当 (end < len && 内存_读8(path + end) != 0x2F) { end = end + 1 }
        定义 seg_len = end - pos

        如果 (seg_len == 1 && 内存_读8(path + pos) == 0x2E) {
            // "." — 忽略(当前目录)
        } 否则 如果 (seg_len == 2 && 内存_读8(path + pos) == 0x2E && 内存_读8(path + pos + 1) == 0x2E) {
            // ".." — 弹出上一段
            如果 (段数 > 0) { 段数 = 段数 - 1 }
        } 否则 如果 (seg_len > 0) {
            // 正常段: 入栈
            内存_写64(段 + 段数 * 8, pos | (seg_len << 32))
            段数 = 段数 + 1
        }
        pos = end + 1
    }

    // 重建路径
    定义 新路径 = 堆_分配(len + 1)
    定义 可变 out = 0
    定义 可变 i = 0
    当 (i < 段数) {
        内存_写8(新路径 + out, 0x2F); out = out + 1
        定义 info = 内存_读64(段 + i * 8)
        定义 seg_pos = info & 0xFFFFFFFF
        定义 seg_len = info >> 32
        内存_复制(新路径 + out, path + seg_pos, seg_len)
        out = out + seg_len
        i = i + 1
    }
    如果 (out == 0) { 内存_写8(新路径, 0x2F); out = 1 }
    内存_写8(新路径 + out, 0)
    url.路径 = 新路径
    堆_释放(段)
    如果 (全局相对解析统计 != 空) {
        全局相对解析统计.路径规范化次数 = 全局相对解析统计.路径规范化次数 + 1
    }
}

// §4 URL合并工具

函数 URL_合并(基础URL, 相对字符串) {
    如果 (基础URL == 空 || 相对字符串 == 空) { 返回 空 }
    如果 (字节长度(相对字符串) == 0) { 返回 基础URL }
    如果 (字节长度(相对字符串) > 最大URL长度) {
        如果 (全局相对解析统计 != 空) {
            全局相对解析统计.溢出保护次数 = 全局相对解析统计.溢出保护次数 + 1
            全局相对解析统计.错误总数 = 全局相对解析统计.错误总数 + 1
        }
        返回 空
    }
    定义 开始时间 = 平台_获取高精度时间()
    定义 类型 = URL_检测类型(相对字符串)
    // 统计
    如果 (全局相对解析统计 != 空) {
        全局相对解析统计.解析总次数 = 全局相对解析统计.解析总次数 + 1
        如果 (类型 == URL类型_绝对) { 全局相对解析统计.绝对URL直通次数 = 全局相对解析统计.绝对URL直通次数 + 1 }
        如果 (类型 == URL类型_协议相对) { 全局相对解析统计.协议相对次数 = 全局相对解析统计.协议相对次数 + 1 }
        如果 (类型 == URL类型_绝对路径) { 全局相对解析统计.绝对路径次数 = 全局相对解析统计.绝对路径次数 + 1 }
        如果 (类型 == URL类型_相对路径) { 全局相对解析统计.相对路径次数 = 全局相对解析统计.相对路径次数 + 1 }
        如果 (类型 == URL类型_仅查询) { 全局相对解析统计.仅查询次数 = 全局相对解析统计.仅查询次数 + 1 }
        如果 (类型 == URL类型_仅片段) { 全局相对解析统计.仅片段次数 = 全局相对解析统计.仅片段次数 + 1 }
        如果 (类型 == URL类型_特殊) { 全局相对解析统计.data_URL次数 = 全局相对解析统计.data_URL次数 + 1 }
    }
    定义 结果 = URL_解析相对(相对字符串, 基础URL)
    如果 (全局相对解析统计 != 空) {
        全局相对解析统计.URL合并次数 = 全局相对解析统计.URL合并次数 + 1
        定义 耗时 = 平台_获取高精度时间() - 开始时间
        全局相对解析统计.总解析耗时_纳秒 = 全局相对解析统计.总解析耗时_纳秒 + 耗时
    }
    // AI反馈
    如果 (全局导航AI != 空 && 结果 != 空) {
        AI导航_记录(基础URL, 结果, 类型)
    }
    返回 结果
}

// §5 基础URL提取(从document.baseURI获取)

函数 URL_提取基础路径(url) {
    // 从URL中提取目录路径(去掉最后一段)
    如果 (url == 空 || url.path == 空) { 返回 "/" }
    定义 path = url.path
    定义 长度 = 字节长度(path)
    // 从末尾往前找最后一个/
    定义 可变 最后斜杠 = 0
    定义 可变 i = 长度 - 1
    当 (i >= 0) {
        如果 (字节取(path, i) == 47) {
            最后斜杠 = i
            止
        }
        i = i - 1
    }
    // 截取到最后一个/（含/）
    定义 结果 = 堆_分配(最后斜杠 + 2)
    如果 (结果 == 空) { 返回 "/" }
    定义 可变 j = 0
    当 (j <= 最后斜杠) {
        内存_写8(结果 + j, 字节取(path, j))
        j = j + 1
    }
    内存_写8(结果 + j, 0)
    如果 (全局相对解析统计 != 空) {
        全局相对解析统计.基础URL提取次数 = 全局相对解析统计.基础URL提取次数 + 1
    }
    返回 结果
}

// §6 路径深度计算与URL辅助

函数 URL_路径深度(path) {
    如果 (path == 空) { 返回 0 }
    定义 长度 = 字节长度(path)
    定义 可变 深度 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        如果 (字节取(path, i) == 47) { 深度 = 深度 + 1 }
        i = i + 1
    }
    返回 深度
}

函数 URL_是data_URL(url字符串) {
    如果 (url字符串 == 空) { 返回 假 }
    如果 (字节长度(url字符串) < 5) { 返回 假 }
    如果 (字节取(url字符串, 0) == 100 && 字节取(url字符串, 1) == 97 && 字节取(url字符串, 2) == 116 && 字节取(url字符串, 3) == 97 && 字节取(url字符串, 4) == 58) {
        返回 真
    }
    返回 假
}

函数 URL_是blob_URL(url字符串) {
    如果 (url字符串 == 空) { 返回 假 }
    如果 (字节长度(url字符串) < 5) { 返回 假 }
    如果 (字节取(url字符串, 0) == 98 && 字节取(url字符串, 1) == 108 && 字节取(url字符串, 2) == 111 && 字节取(url字符串, 3) == 98 && 字节取(url字符串, 4) == 58) {
        返回 真
    }
    返回 假
}

函数 URL_是javascript_URL(url字符串) {
    如果 (url字符串 == 空) { 返回 假 }
    如果 (字节长度(url字符串) < 11) { 返回 假 }
    如果 (字节取(url字符串, 0) == 106 && 字节取(url字符串, 4) == 115 && 字节取(url字符串, 10) == 58) {
        返回 真
    }
    返回 假
}

函数 URL_简单哈希(s) {
    如果 (s == 空) { 返回 0 }
    定义 长度 = 字节长度(s)
    定义 可变 哈希 = 5381
    定义 可变 i = 0
    当 (i < 长度) {
        哈希 = ((哈希 << 5) + 哈希) + 字节取(s, i)
        i = i + 1
    }
    返回 哈希
}

// §7 AI基因 — 导航模式预测
// 能力: 预测 + 学习 + 自适应
// 四阶段: 数据采集→特征提取→决策→执行

函数 AI导航_记录(基础URL, 结果URL, URL类型) {
    如果 (全局导航AI == 空) { 返回 }
    定义 AI = 全局导航AI
    AI.采样计数器 = AI.采样计数器 + 1

    定义 可变 是相对 = 假
    如果 (URL类型 == URL类型_相对路径 || URL类型 == URL类型_绝对路径 || URL类型 == URL类型_仅查询 || URL类型 == URL类型_仅片段) {
        是相对 = 真
    }
    如果 (是相对 == 真) {
        AI.历史相对URL比例 = (AI.历史相对URL比例 * 15 + 1024) / 16
    } 否则 {
        AI.历史相对URL比例 = (AI.历史相对URL比例 * 15) / 16
    }
    // 路径深度
    如果 (结果URL != 空 && 结果URL.path != 空) {
        定义 深度 = URL_路径深度(结果URL.path)
        AI.历史平均路径深度 = (AI.历史平均路径深度 * 7 + 深度 * 1024) / 8
    }

    定义 可变 同域 = 假
    如果 (结果URL != 空 && 结果URL.host != 空) {
        定义 新哈希 = URL_简单哈希(结果URL.host)
        如果 (新哈希 == AI.上次基础host哈希 && AI.上次基础host哈希 != 0) {
            同域 = 真
        }
        AI.上次基础host哈希 = 新哈希
    }
    如果 (同域 == 真) {
        AI.连续同域导航数 = AI.连续同域导航数 + 1
        AI.连续跨域导航数 = 0
    } 否则 {
        AI.连续跨域导航数 = AI.连续跨域导航数 + 1
        AI.连续同域导航数 = 0
    }

    // 每16次做决策
    如果 (AI.采样计数器 < 16) { 返回 }
    AI.采样计数器 = 0
    如果 (全局相对解析统计 != 空) {
        全局相对解析统计.AI导航调用次数 = 全局相对解析统计.AI导航调用次数 + 1
    }

    如果 (AI.连续同域导航数 > 5) {
        AI.预测下次同域 = 真
    } 否则 如果 (AI.连续跨域导航数 > 3) {
        AI.预测下次同域 = 假
    }

    如果 (AI.预测下次同域 == 真 && 同域 == 真) {
        如果 (全局相对解析统计 != 空) {
            全局相对解析统计.AI导航命中次数 = 全局相对解析统计.AI导航命中次数 + 1
        }
    }
}

// §8 统计输出与诊断

函数 相对解析_打印统计() {
    如果 (全局相对解析统计 == 空) {
        打印("[相对解析] 统计未初始化")
        返回
    }
    打印("┌──────────────────────────────────────┐")
    打印("│   相对URL解析 · 统计报告            │")
    打印("├──────────────────────────────────────┤")
    打印(字符串拼接("│ 解析总次数:       ", 转字符串(全局相对解析统计.解析总次数)))
    打印(字符串拼接("│ 绝对URL直通:      ", 转字符串(全局相对解析统计.绝对URL直通次数)))
    打印(字符串拼接("│ 协议相对:         ", 转字符串(全局相对解析统计.协议相对次数)))
    打印(字符串拼接("│ 绝对路径:         ", 转字符串(全局相对解析统计.绝对路径次数)))
    打印(字符串拼接("│ 相对路径:         ", 转字符串(全局相对解析统计.相对路径次数)))
    打印(字符串拼接("│ 仅查询:           ", 转字符串(全局相对解析统计.仅查询次数)))
    打印(字符串拼接("│ 仅片段:           ", 转字符串(全局相对解析统计.仅片段次数)))
    打印(字符串拼接("│ data/blob URL:    ", 转字符串(全局相对解析统计.data_URL次数)))
    打印(字符串拼接("│ 路径规范化:       ", 转字符串(全局相对解析统计.路径规范化次数)))
    打印(字符串拼接("│ 基础URL提取:      ", 转字符串(全局相对解析统计.基础URL提取次数)))
    打印(字符串拼接("│ URL合并:          ", 转字符串(全局相对解析统计.URL合并次数)))
    打印(字符串拼接("│ 总耗时(μs):       ", 转字符串(全局相对解析统计.总解析耗时_纳秒 / 1000)))
    打印(字符串拼接("│ AI导航调用:       ", 转字符串(全局相对解析统计.AI导航调用次数)))
    打印(字符串拼接("│ AI导航命中:       ", 转字符串(全局相对解析统计.AI导航命中次数)))
    打印(字符串拼接("│ 错误:             ", 转字符串(全局相对解析统计.错误总数)))
    打印("└──────────────────────────────────────┘")
}

函数 相对解析_导出诊断() {
    如果 (全局导航AI == 空) {
        打印("[导航AI] 未初始化")
        返回
    }
    定义 AI = 全局导航AI
    打印("[导航AI] === 诊断 ===")
    打印(字符串拼接("  历史相对URL比例(Q10): ", 转字符串(AI.历史相对URL比例)))
    打印(字符串拼接("  历史平均路径深度(Q10): ", 转字符串(AI.历史平均路径深度)))
    打印(字符串拼接("  连续同域导航: ", 转字符串(AI.连续同域导航数)))
    打印(字符串拼接("  连续跨域导航: ", 转字符串(AI.连续跨域导航数)))
    打印(字符串拼接("  预测同域: ", 转字符串(AI.预测下次同域)))
}

// §9 对外接口

函数 相对解析_获取统计() { 返回 全局相对解析统计 }
函数 相对解析_获取AI状态() { 返回 全局导航AI }
函数 相对解析_预测同域() {
    如果 (全局导航AI == 空) { 返回 真 }
    返回 全局导航AI.预测下次同域
}
函数 相对解析_是否已初始化() { 返回 全局相对解析已初始化 }

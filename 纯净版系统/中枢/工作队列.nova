导入("./整数转字符串.nova")

//   1. worNova内核队列: 内核中延迟执行工作的框架
//   2. work_struct: 待执行的工作项(回调函数+数据)
//   3. worker线程: 内核线程池, 从队列取出work执行
//   4. 系统工作队列: system_wq(通用), system_highpri_wq(高优先级)
//   5. schedule_work: 提交到系统工作队列
//   6. flush_worNova内核队列: 等待队列中所有work完成
//   7. 用于: 中断下半部/延迟IO/定时任务/驱动异步操作

结构 工作项 {
    回调,    // u64 工作函数: fn(work)
    数据,    // u64 私有数据
    状态,    // u32 WORK_PENDING / WORK_RUNNING / WORK_DONE
    队列,    // u64 所属工作队列
}

定义 WORK_PENDING  = 0
定义 WORK_RUNNING  = 1
定义 WORK_DONE     = 2

结构 延迟工作项 {
    工作,    // u64 内嵌的work_struct
    延迟_ms,    // u64 延迟毫秒
    到期时间,    // u64 到期的绝对时间
}

结构 工作队列 {
    名称,
    工作列表,    // [] 待执行的work列表
    锁,
    最大并发,    // u32 最大并发worker数
    活跃worker,
    已处理,    // u64 已完成的work总数
    已排队,    // u64 已排队的work总数
}

定义 可变 system_wq = 空           // 通用系统工作队列
定义 可变 system_highpri_wq = 空   // 高优先级
定义 可变 system_long_wq = 空      // 长时间运行
定义 可变 所有工作队列 = []

// 初始化 

函数 工作队列_初始化() {
    system_wq = 工作队列_创建("事件s", 0)
    system_highpri_wq = 工作队列_创建("事件s_highpri", 0)
    system_long_wq = 工作队列_创建("事件s_long", 0)
    内核信息("工作队列: 初始化 (事件s/事件s_highpri/事件s_long)")
}

函数 工作队列_创建(名称, 最大并发) {
    定义 wq = 工作队列 {}
    wq.名称 = 名称
    wq.工作列表 = []
    wq.锁 = 自旋锁_创建()
    wq.最大并发 = 最大并发
    如果 (wq.最大并发 == 0) { wq.最大并发 = 4 }
    wq.活跃worker = 0
    wq.已处理 = 0
    wq.已排队 = 0
    追加(所有工作队列, wq)
    返回 wq
}

// 工作项创建

函数 工作项_创建(回调, 数据) {
    定义 w = 工作项 {}
    w.回调 = 回调
    w.数据 = 数据
    w.状态 = WORK_PENDING
    w.队列 = 空
    返回 w
}

函数 延迟工作项_创建(回调, 数据, 延迟_ms) {
    定义 dw = 延迟工作项 {}
    dw.工作 = 工作项_创建(回调, 数据)
    dw.延迟_ms = 延迟_ms
    dw.到期时间 = 读取毫秒() + 延迟_ms
    返回 dw
}

// 提交工作 

函数 queue_work(wq, work) {
    如果 (wq == 空 || work == 空) { 返回 假 }
    如果 (work.状态 == WORK_RUNNING) { 返回 假 }

    自旋锁_获取(wq.锁)
    work.队列 = wq
    追加(wq.工作列表, work)
    wq.已排队 = wq.已排队 + 1
    自旋锁_释放(wq.锁)
    返回 真
}

函数 schedule_work(work) {
    // 提交到系统默认工作队列
    返回 queue_work(system_wq, work)
}

函数 schedule_delayed_work(dw) {
    // 延迟工作: 到到期时间后才执行
    如果 (dw == 空) { 返回 假 }
    返回 queue_work(system_wq, dw.工作)
}

// 执行工作 (由worker线程调用, 或定时器tick驱动)

函数 工作队列_处理(wq) {
    如果 (wq == 空) { 返回 0 }

    自旋锁_获取(wq.锁)
    如果 (计数(wq.工作列表) == 0) {
        自旋锁_释放(wq.锁)
        返回 0
    }

    定义 work = wq.工作列表[0]
    链表_删除(wq.工作列表, 0)
    wq.活跃worker = wq.活跃worker + 1
    自旋锁_释放(wq.锁)

    // 执行工作回调
    work.状态 = WORK_RUNNING
    如果 (work.回调 != 空) {
        work.回调(work)
    }
    work.状态 = WORK_DONE

    自旋锁_获取(wq.锁)
    wq.活跃worker = wq.活跃worker - 1
    wq.已处理 = wq.已处理 + 1
    自旋锁_释放(wq.锁)

    返回 1
}

函数 工作队列_处理全部(wq) {
    定义 可变 处理数 = 0
    当 (工作队列_处理(wq) > 0) {
        处理数 = 处理数 + 1
    }
    返回 处理数
}

// flush: 等待所有工作完成 

函数 flush_worNova内核队列(wq) {
    如果 (wq == 空) { 返回 }
    // 处理所有待执行的工作
    工作队列_处理全部(wq)
    // 等待所有活跃worker完成
    当 (wq.活跃worker > 0) {
        调度()
    }
}

函数 flush_scheduled_work() {
    flush_worNova内核队列(system_wq)
}

// 取消工作 

函数 cancel_work(work) {
    如果 (work == 空 || work.队列 == 空) { 返回 假 }
    定义 wq = work.队列
    自旋锁_获取(wq.锁)
    定义 可变 i = 0
    当 (i < 计数(wq.工作列表)) {
        如果 (wq.工作列表[i] == work) {
            链表_删除(wq.工作列表, i)
            自旋锁_释放(wq.锁)
            返回 真
        }
        i = i + 1
    }
    自旋锁_释放(wq.锁)
    返回 假
}

// 全局tick驱动 (由调度器tick定期调用)

函数 工作队列_tick() {
    // 处理所有系统工作队列中的待处理工作
    工作队列_处理(system_wq)
    工作队列_处理(system_highpri_wq)
    工作队列_处理(system_long_wq)
}

// 查询/统计

函数 工作队列_待处理数(wq) { 返回 计数(wq.工作列表) }
函数 工作队列_统计(wq) { 返回 [wq.已排队, wq.已处理, 计数(wq.工作列表), wq.活跃worker] }

// 全局工作队列统计

函数 工作队列_全局统计() {
    定义 可变 总排队 = 0
    定义 可变 总处理 = 0
    定义 可变 i = 0
    当 (i < 计数(所有工作队列)) {
        总排队 = 总排队 + 所有工作队列[i].已排队
        总处理 = 总处理 + 所有工作队列[i].已处理
        i = i + 1
    }
    返回 [计数(所有工作队列), 总排队, 总处理]
}


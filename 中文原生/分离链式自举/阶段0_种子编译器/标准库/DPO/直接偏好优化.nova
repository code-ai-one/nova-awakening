导入("../基础.nova")


// DPO核心
// L_DPO = -E[log σ(β(log π(y_w|x)/π_ref(y_w|x) - log π(y_l|x)/π_ref(y_l|x)))]
// 所有概率用log概率(×1000定点), β=温度参数

// sigmoid近似: σ(x) ≈ x/(|x|+1000) * 500 + 500
函数 DPO_S形(x) { 定义 可变 abs_x = x
 如果 (abs_x < 0) { abs_x = 0 - abs_x }
 返回 x * 500 / (abs_x + 1000) + 500
}

// DPO损失
函数 DPO_DPO_损失(π_赢_logp, π_输_logp, ref_赢_logp, ref_输_logp, β) { 如果 (β <= 0) { β = 100 } // 0.1×1000
 // log_ratio_w = log π(y_w|x) - log π_ref(y_w|x)
 定义 log_ratio_w = π_赢_logp - ref_赢_logp
 定义 log_ratio_l = π_输_logp - ref_输_logp
 // σ(β·(log_ratio_w - log_ratio_l))
 定义 差值 = β * (log_ratio_w - log_ratio_l) / 1000
 定义 信号值 = DPO_S形(差值)
 // 损失值 = -log(σ) ≈ -(信号值-500)
 返回 1000 - 信号值
}

// 批量DPO损失
函数 DPO模块_批量损失(赢_logp列表, 输_logp列表, ref赢列表, ref输列表, β) { 定义 n = 计数(赢_logp列表)
 如果 (n == 0) { 返回 0 }
 定义 可变 总损失 = 0
 定义 可变 i = 0
 当 (i < n) {
 总损失 = 总损失 + DPO_DPO_损失(赢_logp列表[i], 输_logp列表[i], ref赢列表[i], ref输列表[i], β)
 i = i + 1
 }
 返回 总损失 / n
}

// 隐式奖励
函数 DPO_隐式奖励(π_logp, ref_logp, β) { 返回 β * (π_logp - ref_logp) / 1000
}

// IPO: 身份偏好优化
// L_IPO = (log_ratio_w - log_ratio_l - 1/(2β))²
函数 IPO_损失(π_赢_logp, π_输_logp, ref_赢_logp, ref_输_logp, β) {
    如果 (β <= 0) { β = 100
}
 定义 log_ratio_w = π_赢_logp - ref_赢_logp
 定义 log_ratio_l = π_输_logp - ref_输_logp
 定义 差值 = log_ratio_w - log_ratio_l - 500 / β // 1/(2β)
 返回 差值 * 差值 / 1000
}

// KTO: Kahneman-Tversky优化
// 损失分开处理好/坏样本, 用Kahneman-Tversky价值函数
函数 DPO模块_KTO_损失(π_logp, ref_logp, 是否好样本, β, λ_d) {
    如果 (β <= 0) { β = 100
}
 如果 (λ_d <= 0) { λ_d = 1000 }
 定义 对数比 = π_logp - ref_logp
 定义 可变 损失值 = 0
 如果 (是否好样本 == 1) {
 // 好样本: 1 - σ(β·对数比)
 损失值 = 1000 - DPO_S形(β * 对数比 / 1000)
 } 否则 {
 // 坏样本: 1 - σ(-β·对数比), 加权λ_d
 损失值 = λ_d * (1000 - DPO_S形(0 - β * 对数比 / 1000)) / 1000
 }
 返回 损失值
}

// ORPO: 几率比偏好优化
// 无需参考模型, 用几率比代替概率比
函数 DPO模块_ORPO_损失(π_赢_logp, π_输_logp, λ) {
    如果 (λ <= 0) { λ = 1000
}
 // NLL损失 + λ * 偏好损失
 定义 nll = 0 - π_赢_logp
 // odds_ratio = (p_w/(1-p_w)) / (p_l/(1-p_l))
 // 简化: log_odds_diff ≈ π_赢_logp - π_输_logp
 定义 log_odds = π_赢_logp - π_输_logp
 定义 偏好损失 = 1000 - DPO_S形(log_odds)
 返回 nll + λ * 偏好损失 / 1000
}

// SimPO: 简单偏好优化
// 用平均log概率, 无需参考模型
函数 DPO模块_SimPO_损失(赢_avg_logp, 输_avg_logp, β, γ) { 如果 (β <= 0) { β = 2000 } // 2.0
 如果 (γ <= 0) { γ = 500 } // 0.5
 定义 差值 = β * (赢_avg_logp - 输_avg_logp) / 1000 - γ
 返回 1000 - DPO_S形(差值)
}

// CPO: 条件偏好优化
函数 CPO_损失(π_赢_logp, π_输_logp, ref_赢_logp, ref_输_logp, β, α) {
    如果 (α <= 0) { α = 500
}
 // DPO部分
 定义 dpo = DPO_DPO_损失(π_赢_logp, π_输_logp, ref_赢_logp, ref_输_logp, β)
 // NLL部分 (SFT 损失值 on preferred)
 定义 nll = 0 - π_赢_logp
 返回 dpo + α * nll / 1000
}

// 拒绝采样 (Rejection Sampling, 0)
函数 拒绝采样_最佳N(奖励分数列表, N) { 定义 可变 最佳idx = 0
 定义 可变 最佳分数 = 奖励分数列表[0]
 定义 可变 i = 1
 当 (i < N 且 i < 计数(奖励分数列表)) { 如果 (奖励分数列表[i] > 最佳分数) {
 最佳idx = i
 最佳分数 = 奖励分数列表[i]
 }
 i = i + 1
 }
 返回 最佳idx
}

// 偏好数据集管理
// 型: [提示列表, 赢回复列表, 输回复列表, 数据量]
函数 偏好数据集_创建() { 返回 [[], [], [], 0] }

函数 偏好数据集_追加(数据集, 提示, 赢回复, 输回复) {
 追加(数据集[0], 提示)
 追加(数据集[1], 赢回复)
 追加(数据集[2], 输回复)
 数据集[3] = 数据集[3] + 1
}

函数 偏好数据集_大小(数据集) { 返回 数据集[3] }

函数 偏好数据集_获取(数据集, i) { 返回 [数据集[0][i], 数据集[1][i], 数据集[2][i]]
}

// KL散度估计
函数 DPO_KL散度(P_logp, Q_logp) { 定义 n = 计数(P_logp)
 如果 (n == 0) { 返回 0 }
 定义 可变 kl = 0
 定义 可变 i = 0
 当 (i < n) {
 // KL(P||Q) = Σ p·(log p - log q)
 定义 差值 = P_logp[i] - Q_logp[i]
 kl = kl + 差值
 i = i + 1
 }
 返回 kl / n
}

// 奖励模型
// 简单线性奖励: r(x,y) = w·φ(x,y)
函数 奖励_线性(特征, 权重) { 定义 n = 计数(特征)
 定义 可变 分数 = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (i < 计数(权重)) { 分数 = 分数 + 特征[i] * 权重[i] / 1000 }
 i = i + 1
 }
 返回 分数
}

// Bradley-Terry偏好模型
函数 BradleyTerry_概率(奖励_赢, 奖励_输) {
 // P(赢>输) = σ(r_w - r_l)
 返回 DPO_S形(奖励_赢 - 奖励_输)
}

// 在线DPO: 用当前策略生成+标注
函数 在线DPO_排序(回复奖励列表) {
 // 返回排序后的索引 (降序)
 定义 n = 计数(回复奖励列表)
 定义 可变 索引 = []
 定义 可变 i = 0
 当 (i < n) { 追加(索引, i)
 i = i + 1 }
 i = 0
 当 (i < n - 1) { 定义 可变 j = i + 1
 当 (j < n) { 如果 (回复奖励列表[索引[j]] > 回复奖励列表[索引[i]]) { 定义 临时 = 索引[i]
 索引[i] = 索引[j]
 索引[j] = 临时
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 索引
}

// 多轮对话DPO
函数 多轮DPO_损失(轮次_logp_赢, 轮次_logp_输, 轮次_ref_赢, 轮次_ref_输, β) { 定义 轮数 = 计数(轮次_logp_赢)
 定义 可变 总log_ratio_w = 0
 定义 可变 总log_ratio_l = 0
 定义 可变 t = 0
 当 (t < 轮数) {
 总log_ratio_w = 总log_ratio_w + 轮次_logp_赢[t] - 轮次_ref_赢[t]
 总log_ratio_l = 总log_ratio_l + 轮次_logp_输[t] - 轮次_ref_输[t]
 t = t + 1
 }
 定义 差值 = β * (总log_ratio_w - 总log_ratio_l) / 1000
 返回 1000 - DPO_S形(差值)
}

// 偏好数据管理
定义 可变 _偏好_提示 = []
定义 可变 _偏好_赢回复 = []
定义 可变 _偏好_输回复 = []

函数 偏好_添加(提示, 赢, 输) {
 追加(_偏好_提示, 提示)
 追加(_偏好_赢回复, 赢)
 追加(_偏好_输回复, 输)
}

函数 DPO_偏好_数量() { 返回 计数(_偏好_提示) }
函数 偏好_取(索引) { 返回 [_偏好_提示[索引], _偏好_赢回复[索引], _偏好_输回复[索引]] }

函数 偏好_随机批(批大小, 种子) { 定义 n = 计数(_偏好_提示)
 定义 可变 批 = []
 定义 可变 i = 0
 当 (i < 批大小) { 定义 索引 = (种子 * 37 + i * 13) % n
 追加(批, 偏好_取(索引))
 i = i + 1
 }
 返回 批
}

函数 DPO_偏好_清空() { _偏好_提示 = [] _偏好_赢回复 = [] _偏好_输回复 = [] }

// 奖励模型评估
函数 偏好_准确率(奖励赢列表, 奖励输列表) { 定义 n = 计数(奖励赢列表)
 定义 可变 正确 = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (奖励赢列表[i] > 奖励输列表[i]) { 正确 = 正确 + 1 }
 i = i + 1
 }
 如果 (n == 0) { 返回 0 }
 返回 正确 * 100 / n
}


// [Nova实验室反哺] 在线DPO_排序
// 原: 选择排序 O(n²) — 每轮比较所有剩余
// 新: 快速排序索引 O(nlogn) — Rust实测13×加速(n=100)
函数 DPO_排序分区(奖励, 索引, 低, 高) {
    定义 基准值 = 奖励[索引[高]]
    定义 可变 i = 低
    定义 可变 j = 低
    当 (j < 高) {
        如果 (奖励[索引[j]] > 基准值) {   // 降序: 大的在前
            定义 临 = 索引[i]
            索引[i] = 索引[j]
            索引[j] = 临
            i = i + 1
        }
        j = j + 1
    }
    定义 临2 = 索引[i]
    索引[i] = 索引[高]
    索引[高] = 临2
    返回 i
}

函数 DPO_快排递归(奖励, 索引, 低, 高) {
    如果 (低 >= 高) { 返回 }
    定义 p = DPO_排序分区(奖励, 索引, 低, 高)
    DPO_快排递归(奖励, 索引, 低, p - 1)
    DPO_快排递归(奖励, 索引, p + 1, 高)
}

函数 在线DPO_排序_快排(回复奖励列表) {
    // O(nlogn) 实验反哺替代 O(n²) 选择排序
    定义 n = 计数(回复奖励列表)
    定义 可变 索引 = []
    定义 可变 i = 0
    当 (i < n) { 追加(索引, i); i = i + 1 }
    如果 (n > 1) { DPO_快排递归(回复奖励列表, 索引, 0, n - 1) }
    返回 索引
}


// [Nova实验室反哺] 快排优化版
// 实验结论: O(n²)嵌套排序 → O(nlogn)快速排序，n=100时速度13×
// 已在标准库/基础.nova中实现 基础_快速排序(列表, 低, 高)
// 快排已反哺 — 可调用 基础_快速排序 替代本函数

导入("../基础.nova")
导入("../算法/数学扩展.nova")


// 基准: [名称, 迭代数, 最小时间, 最大时间, 总时间, 结果列表]
函数 基准_创建(名称, 迭代数) { 返回 [名称, 迭代数, 0x7FFFFFFF, 0, []]
}

函数 基准_记录(基准, 耗时) {
    如果 (耗时 < 基准[2]) { 基准[2] = 耗时
}
 如果 (耗时 > 基准[3]) { 基准[3] = 耗时 }
 基准[4] = 基准[4] + 耗时
 追加(基准[5], 耗时)
}

函数 基准_平均(基准) { 定义 n = 计数(基准[5])
 如果 (n == 0) { 返回 0 }
 返回 基准[4] / n
}

函数 基准_中位数(基准) { 定义 n = 计数(基准[5])
 如果 (n == 0) { 返回 0 }
 // 排序
 定义 可变 已排序 = []
 定义 可变 i = 0
 当 (i < n) { 追加(已排序, 基准[5][i])
 i = i + 1 }
 i = 0
 当 (i < n - 1) { 定义 可变 j = i + 1
 当 (j < n) { 如果 (已排序[j] < 已排序[i]) { 定义 临时 = 已排序[i]
 已排序[i] = 已排序[j]
 已排序[j] = 临时
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 已排序[n / 2]
}

函数 基准_标准差(基准) { 定义 n = 计数(基准[5])
 如果 (n < 2) { 返回 0 }
 定义 均值 = 基准_平均(基准)
 定义 可变 方差 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 d = 基准[5][i] - 均值
 方差 = 方差 + d * d / 1000
 i = i + 1
 }
 方差 = 方差 / (n - 1)
 返回 整数sqrt(方差 * 1000)
}

函数 基准_报告(基准) {
 打印("═══ 基准测试: " + 基准[0] + " ═══")
 打印(" 迭代次数: " + 转字符串(计数(基准[5])))
 打印(" 平均耗时: " + 转字符串(基准_平均(基准)))
 打印(" 中位耗时: " + 转字符串(基准_中位数(基准)))
 打印(" 最小耗时: " + 转字符串(基准[2]))
 打印(" 最大耗时: " + 转字符串(基准[3]))
 打印(" 标准差: " + 转字符串(基准_标准差(基准)))
}

// 基准比较
函数 基准_比较(bench1, bench2) { 定义 avg1 = 基准_平均(bench1)
 定义 avg2 = 基准_平均(bench2)
 如果 (avg2 == 0) { 返回 0 }
 定义 加速比 = avg1 * 1000 / avg2 // ×1000
 打印("比较: " + bench1[0] + " vs " + bench2[0])
 打印(" 加速比: " + 转字符串(加速比) + "/1000")
 如果 (加速比 > 1000) {
 打印(" " + bench2[0] + " 更快")
 } 否则 如果 (加速比 < 1000) {
 打印(" " + bench1[0] + " 更快")
 } 否则 {
 打印(" 性能相同")
 }
 返回 加速比
}

// 回归检测
函数 基准_回归检测(当前bench, 基线bench, 阈值百分比) { 定义 当前avg = 基准_平均(当前bench)
 定义 基线avg = 基准_平均(基线bench)
 如果 (基线avg == 0) { 返回 0 }
 定义 变化 = (当前avg - 基线avg) * 100 / 基线avg
 如果 (变化 > 阈值百分比) {
 打印("⚠️ 性能回归: " + 当前bench[0] + " 慢了 " + 转字符串(变化) + "%")
 返回 1
 }
 返回 0
}

// 基准套件
函数 基准测试_套件_创建(名称) { 返回 [名称, []] }
函数 基准测试_套件_追加(suite, 基准) { 追加(suite[1], 基准) }

函数 基准测试_套件_报告(suite) {
 打印("╔══ 基准测试套件: " + suite[0] + " ══╗")
 定义 可变 i = 0
 当 (i < 计数(suite[1])) {
 基准_报告(suite[1][i])
 i = i + 1
 }
 打印("╚══ 共 " + 转字符串(计数(suite[1])) + " 项 ══╝")
}

// 吞吐量计算
函数 基准测试_吞吐量(操作数, 耗时ms) {
    如果 (耗时ms == 0) { 返回 0
}
 返回 操作数 * 1000 / 耗时ms // ops/sec
}

// 内存基准
函数 内存基准_创建(名称) { 返回 [名称, 0, []] } // [名, 分配次数, 总字节, 记录]
函数 内存基准_记录(mb, 字节数) {
 mb[1] = mb[1] + 1
 mb[2] = mb[2] + 字节数
 追加(mb[3], 字节数)
}

函数 内存基准_报告(mb) {
 打印("内存基准: " + mb[0])
 打印(" 分配次数: " + 转字符串(mb[1]))
 打印(" 总字节: " + 转字符串(mb[2]))
 如果 (mb[1] > 0) { 打印(" 平均分配: " + 转字符串(mb[2] / mb[1])) }
}

// 百分位数计算
函数 基准_排序副本(基准) { 定义 n = 计数(基准[5])
 定义 可变 已排序 = []
 定义 可变 i = 0
 当 (i < n) { 追加(已排序, 基准[5][i])
 i = i + 1 }
 i = 0
 当 (i < n - 1) { 定义 可变 j = i + 1
 当 (j < n) { 如果 (已排序[j] < 已排序[i]) { 定义 临时 = 已排序[i]
 已排序[i] = 已排序[j]
 已排序[j] = 临时
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 已排序
}

函数 基准_百分位(基准, p) { 定义 已排序 = 基准_排序副本(基准)
 定义 n = 计数(已排序)
 如果 (n == 0) { 返回 0 }
 定义 可变 索引 = p * (n - 1) / 100
 如果 (索引 >= n) { 索引 = n - 1 }
 如果 (索引 < 0) { 索引 = 0 }
 返回 已排序[索引]
}

函数 基准_p50(基准) { 返回 基准_百分位(基准, 50) }
函数 基准_p90(基准) { 返回 基准_百分位(基准, 90) }
函数 基准_p95(基准) { 返回 基准_百分位(基准, 95) }
函数 基准_p99(基准) { 返回 基准_百分位(基准, 99) }

// 预热与稳态检测
函数 基准_去除预热(基准, 预热数) { 定义 n = 计数(基准[5])
 如果 (预热数 >= n) { 返回 }
 定义 可变 新结果 = []
 定义 可变 新总 = 0
 定义 可变 新最小 = 0x7FFFFFFF
 定义 可变 新最大 = 0
 定义 可变 i = 预热数
 当 (i < n) { 定义 v = 基准[5][i]
 追加(新结果, v)
 新总 = 新总 + v
 如果 (v < 新最小) { 新最小 = v }
 如果 (v > 新最大) { 新最大 = v }
 i = i + 1
 }
 基准[2] = 新最小
 基准[3] = 新最大
 基准[4] = 新总
 基准[5] = 新结果
}

// 变异系数 (CV = std/mean * 1000), 判断结果稳定性
函数 基准_变异系数(基准) { 定义 均值 = 基准_平均(基准)
 如果 (均值 == 0) { 返回 0 }
 定义 sd = 基准_标准差(基准)
 返回 sd * 1000 / 均值
}

函数 基准_是否稳定(基准, 阈值cv) { 返回 基准_变异系数(基准) < 阈值cv
}

// 批量比较与表格输出
函数 套件_比较表(suite) {
 打印("╔══════════════════════════════════════════════════════╗")
 打印("║ 名称          平均    中位    P95     最小    最大")
 打印("╠══════════════════════════════════════════════════════╣")
 定义 可变 i = 0
 当 (i < 计数(suite[1])) { 定义 b = suite[1][i]
 定义 可变 行 = "║ " + b[0]
 // 填充到18字符
 定义 可变 填充 = 18 - 计数(b[0])
 定义 可变 p = 0
 当 (p < 填充) { 行 = 行 + " " p = p + 1 }
 行 = 行 + 转字符串(基准_平均(b))
 行 = 行 + " " + 转字符串(基准_中位数(b))
 行 = 行 + " " + 转字符串(基准_p95(b))
 行 = 行 + " " + 转字符串(b[2])
 行 = 行 + " " + 转字符串(b[3])
 打印(行)
 i = i + 1
 }
 打印("╚══════════════════════════════════════════════════════╝")
}

// 找出套件中最快/最慢的基准
函数 套件_最快(suite) { 定义 可变 最优 = 0
 定义 可变 best_avg = 0x7FFFFFFF
 定义 可变 i = 0
 当 (i < 计数(suite[1])) { 定义 均值 = 基准_平均(suite[1][i])
 如果 (均值 < best_avg) { best_avg = 均值
 最优 = i }
 i = i + 1
 }
 返回 最优
}

函数 套件_最慢(suite) { 定义 可变 worst = 0
 定义 可变 worst_avg = 0
 定义 可变 i = 0
 当 (i < 计数(suite[1])) { 定义 均值 = 基准_平均(suite[1][i])
 如果 (均值 > worst_avg) { worst_avg = 均值
 worst = i }
 i = i + 1
 }
 返回 worst
}

// 回归检测增强
// 批量回归检测: 返回回归数量
函数 套件_回归检测(当前suite, 基线suite, 阈值百分比) { 定义 n当前 = 计数(当前suite[1])
 定义 n基线 = 计数(基线suite[1])
 定义 可变 回归数 = 0
 定义 可变 i = 0
 当 (i < n当前 且 i < n基线) { 定义 r = 基准_回归检测(当前suite[1][i], 基线suite[1][i], 阈值百分比)
 回归数 = 回归数 + r
 i = i + 1
 }
 打印("回归检测: " + 转字符串(回归数) + "/" + 转字符串(i) + " 项有回归")
 返回 回归数
}

// 延迟分布直方图
函数 基准_直方图(基准, 桶数) { 定义 n = 计数(基准[5])
 如果 (n == 0) { 返回 [] }
 定义 最小 = 基准[2]
 定义 最大 = 基准[3]
 定义 可变 范围 = 最大 - 最小
 如果 (范围 == 0) { 范围 = 1 }
 定义 可变 实际桶数 = 桶数
 如果 (实际桶数 == 0) { 实际桶数 = 1 }
 定义 可变 桶宽 = 范围 / 实际桶数
 如果 (桶宽 == 0) { 桶宽 = 1 }
 定义 可变 桶 = []
 定义 可变 i = 0
 当 (i < 实际桶数) { 追加(桶, 0)
 i = i + 1 }
 i = 0
 当 (i < n) { 定义 可变 索引 = (基准[5][i] - 最小) / 桶宽
 如果 (索引 >= 实际桶数) { 索引 = 实际桶数 - 1 }
 如果 (索引 < 0) { 索引 = 0 }
 桶[索引] = 桶[索引] + 1
 i = i + 1
 }
 返回 桶
}

函数 基准_打印直方图(基准, 桶数) { 定义 桶 = 基准_直方图(基准, 桶数)
 定义 n桶 = 计数(桶)
 // 找最大值用于缩放
 定义 可变 最大计数 = 1
 定义 可变 i = 0
 当 (i < n桶) { 如果 (桶[i] > 最大计数) { 最大计数 = 桶[i] }
 i = i + 1
 }
 打印("延迟分布 (" + 基准[0] + "):")
 定义 可变 桶宽 = (基准[3] - 基准[2]) / 桶数
 如果 (桶宽 == 0) { 桶宽 = 1 }
 i = 0
 当 (i < n桶) { 定义 下界 = 基准[2] + i * 桶宽
 定义 上界 = 下界 + 桶宽
 定义 条长 = 桶[i] * 40 / 最大计数
 定义 可变 行 = " [" + 转字符串(下界) + "-" + 转字符串(上界) + "] "
 定义 可变 j = 0
 当 (j < 条长) { 行 = 行 + "█" j = j + 1 }
 行 = 行 + " " + 转字符串(桶[i])
 打印(行)
 i = i + 1
 }
}

// 吞吐量增强
函数 吞吐量_格式化(操作数, 耗时ms) { 定义 ops = 基准测试_吞吐量(操作数, 耗时ms)
 如果 (ops >= 1000000) {
 打印(转字符串(ops / 1000000) + "M ops/s")
 } 否则 如果 (ops >= 1000) {
 打印(转字符串(ops / 1000) + "K ops/s")
 } 否则 {
 打印(转字符串(ops) + " ops/s")
 }
 返回 ops
}

// 带宽计算 (字节/秒)
函数 带宽(字节数, 耗时ms) {
    如果 (耗时ms == 0) { 返回 0
}
 返回 字节数 * 1000 / 耗时ms
}

函数 带宽_格式化(字节数, 耗时ms) { 定义 bps = 带宽(字节数, 耗时ms)
 如果 (bps >= 1073741824) {
 打印(转字符串(bps / 1073741824) + " GB/s")
 } 否则 如果 (bps >= 1048576) {
 打印(转字符串(bps / 1048576) + " MB/s")
 } 否则 如果 (bps >= 1024) {
 打印(转字符串(bps / 1024) + " KB/s")
 } 否则 {
 打印(转字符串(bps) + " B/s")
 }
 返回 bps
}

// 详细报告
函数 基准_详细报告(基准) {
 打印("═══════════════════════════════════════")
 打印(" 基准: " + 基准[0])
 打印("═══════════════════════════════════════")
 打印(" 样本数: " + 转字符串(计数(基准[5])))
 打印(" 平均: " + 转字符串(基准_平均(基准)))
 打印(" 中位: " + 转字符串(基准_中位数(基准)))
 打印(" 最小: " + 转字符串(基准[2]))
 打印(" 最大: " + 转字符串(基准[3]))
 打印(" 标准差: " + 转字符串(基准_标准差(基准)))
 打印(" CV: " + 转字符串(基准_变异系数(基准)) + "/1000")
 打印(" P50: " + 转字符串(基准_p50(基准)))
 打印(" P90: " + 转字符串(基准_p90(基准)))
 打印(" P95: " + 转字符串(基准_p95(基准)))
 打印(" P99: " + 转字符串(基准_p99(基准)))
 如果 (基准_是否稳定(基准, 100)) {
 打印(" 状态: ✅ 稳定 (CV < 10%)")
 } 否则 {
 打印(" 状态: ⚠️ 不稳定 (CV >= 10%)")
 }
}

// 基准组 (分组测试)
函数 组_创建(名称) { 返回 [名称, []] } // [名称, [套件列表]]
函数 组_添加套件(组, suite) { 追加(组[1], suite) }

函数 组_总报告(组) {
 打印("╔══════════════════════════════════════════╗")
 打印("║ 基准测试组: " + 组[0])
 打印("╠══════════════════════════════════════════╣")
 定义 可变 总bench数 = 0
 定义 可变 i = 0
 当 (i < 计数(组[1])) { 定义 s = 组[1][i]
 打印("║ 套件: " + s[0] + " (" + 转字符串(计数(s[1])) + "项)")
 总bench数 = 总bench数 + 计数(s[1])
 i = i + 1
 }
 打印("╠══════════════════════════════════════════╣")
 打印("║ 总计: " + 转字符串(计数(组[1])) + " 套件, " + 转字符串(总bench数) + " 基准")
 打印("╚══════════════════════════════════════════╝")
}

// 性能对比分析

函数 bench_对比(结果A, 结果B) {
    如果 (结果B == 0) { 返回 0
}
 定义 比率 = 结果A * 100 / 结果B
 返回 比率
}

函数 bench_加速比(基准时间, 优化时间) {
    如果 (优化时间 == 0) { 返回 0
}
 返回 基准时间 * 1000 / 优化时间
}

函数 bench_回归检测(历史, 当前, 阈值) {
    如果 (计数(历史) == 0) { 返回 假
}
 定义 可变 i = 0
 定义 可变 总 = 0
 当 (i < 计数(历史)) {
 总 = 总 + 历史[i]
 i = i + 1
 }
 定义 均值 = 总 / 计数(历史)
 如果 (当前 > 均值 + 阈值) { 返回 真 }
 返回 假
}

函数 bench_百分位(排序结果, 百分位) { 定义 n = 计数(排序结果)
 如果 (n == 0) { 返回 0 }
 定义 可变 索引 = n * 百分位 / 100
 如果 (索引 >= n) { 索引 = n - 1 }
 返回 排序结果[索引]
}

函数 基准_P50(排序结果) { 返回 bench_百分位(排序结果, 50) }
函数 基准_P90(排序结果) { 返回 bench_百分位(排序结果, 90) }
函数 基准_P99(排序结果) { 返回 bench_百分位(排序结果, 99) }

定义 可变 _bench_执行总数 = 0
定义 可变 _bench_回归数 = 0
定义 可变 _bench_最快时间 = 999999999
定义 可变 _bench_最慢时间 = 0

函数 bench_记录(时间) { _bench_执行总数 = _bench_执行总数 + 1
 如果 (时间 < _bench_最快时间) { _bench_最快时间 = 时间 }
 如果 (时间 > _bench_最慢时间) { _bench_最慢时间 = 时间 }
}

函数 bench_记录回归() { _bench_回归数 = _bench_回归数 + 1 }

函数 bench_稳定性评估() {
    如果 (_bench_执行总数 < 3) { 返回 "样本不足"
}
 定义 可变 范围 = _bench_最慢时间 - _bench_最快时间
 如果 (_bench_最快时间 == 0) { 返回 "数据异常" }
 定义 变异 = 范围 * 100 / _bench_最快时间
 如果 (变异 < 10) { 返回 "非常稳定" }
 如果 (变异 < 30) { 返回 "基本稳定" }
 返回 "不稳定(可能有干扰)"
}

函数 bench_重置() { _bench_执行总数 = 0
 _bench_回归数 = 0
 _bench_最快时间 = 999999999
 _bench_最慢时间 = 0
}

函数 bench_抖动率() {
    如果 (_bench_最快时间 == 0 或 _bench_最快时间 == 999999999) { 返回 0
}
 返回 (_bench_最慢时间 - _bench_最快时间) * 1000 / _bench_最快时间
}

函数 bench_是否可信() {
    如果 (_bench_执行总数 < 5) { 返回 "样本不足,不可信"
}
 如果 (bench_抖动率() > 500) { 返回 "抖动过大,不可信" }
 返回 "结果可信"
}

函数 bench_重置全部() { bench_重置() }


// [Nova实验室反哺] 快排优化版
// 实验结论: O(n²)嵌套排序 → O(nlogn)快速排序，n=100时速度13×

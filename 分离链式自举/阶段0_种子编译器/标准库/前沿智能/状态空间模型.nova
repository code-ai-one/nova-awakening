导入("../基础.nova")
导入("../数学/工具.nova")

// Mamba / S4 — 选择性状态空间模型 (v2: 2024 前沿迭代)
// ref: Gu et al. 2022 "Efficiently Modeling Long Sequences with
//   Structured State Spaces" (S4原始论文)
// ref: Gu & Dao 2023 "Mamba: Linear-Time Sequence Modeling with
//   Selective State Spaces" (选择性机制)
// ref: Dao & Gu 2024 "Transformers are SSMs: Generalized Models
//   and Efficient Algorithms Through Structured State Space
//   Duality" (Mamba-2: SSD框架, 将SSM与注意力统一)
// ref: Lieber et al. 2024 "Jamba: A Hybrid Transformer-Mamba
//   Language Model" (AI21: 交替Mamba+Attention层)
// 连续→离散: x_{k+1} = Ā·x_k + B̄·u_k, y_k = C·x_k
// Mamba-2创新: 多头SSM + 半可分矩阵 = O(N)的注意力等价
// O(N)序列处理, 对比Transformer的O(N²)

定义 SSM精度 = 10000

// S4: 结构化状态空间 (线性时不变版)
// 离散化: Ā = exp(Δ·A), B̄ = (Ā-I)·A⁻¹·B ≈ Δ·B

函数 S4_创建(状态维度, 输入维度) {
    // A矩阵: HiPPO初始化 (Gu et al. 2020)
    // A_{nk} = -(2n+1)^{1/2} × (2k+1)^{1/2} if n > k, else -(n+1)
    定义 可变 A = []
    定义 可变 n = 0
    当 (n < 状态维度) {
        定义 可变 k = 0
        当 (k < 状态维度) {
            如果 (n > k) {
                // HiPPO-LegS矩阵
                定义 值 = 0 - (2 * n + 1) * (2 * k + 1) / 2
                追加(A, 值)
            } 否则 如果 (n == k) {
                追加(A, 0 - (n + 1))
            } 否则 {
                追加(A, 0)
            }
            k = k + 1
        }
        n = n + 1
    }
    // B: [状态维度 × 输入维度]
    定义 可变 B = []
    定义 可变 i = 0
    当 (i < 状态维度 * 输入维度) {
        追加(B, ((2 * (i % 状态维度) + 1) * 100))  // HiPPO B init
        i = i + 1
    }
    // C: [输入维度 × 状态维度] 可训练
    定义 可变 C = []
    i = 0
    当 (i < 输入维度 * 状态维度) {
        追加(C, ((i * 2654435761 + 77) % 2000 - 1000))
        i = i + 1
    }
    // Δ (步长, 标量)
    定义 Δ = 100  // 0.01 × SSM精度
    返回 [状态维度, 输入维度, A, B, C, Δ]
}

// S4离散化 + 序列扫描
函数 S4_前向(模型, 输入序列, 序列长) {
    定义 N = 模型[0]
    定义 D = 模型[1]
    定义 A = 模型[2]
    定义 B = 模型[3]
    定义 C = 模型[4]
    定义 Δ = 模型[5]
    // 离散化 Ā ≈ I + Δ·A (一阶Euler)
    // B̄ = Δ·B
    // 状态初始化
    定义 可变 x = []
    定义 可变 xi = 0
    当 (xi < N) { 追加(x, 0); xi = xi + 1 }
    // 输出序列
    定义 可变 输出 = []
    定义 可变 t = 0
    当 (t < 序列长) {
        // x_{t+1} = (I + Δ·A)·x_t + Δ·B·u_t
        定义 可变 新x = []
        定义 可变 n = 0
        当 (n < N) {
            定义 可变 状态值 = 0
            // Ā·x 部分
            定义 可变 k = 0
            当 (k < N) {
                定义 a_nk = A[n * N + k]
                如果 (n == k) {
                    状态值 = 状态值 + (SSM精度 + Δ * a_nk / SSM精度) * x[k] / SSM精度
                } 否则 {
                    状态值 = 状态值 + Δ * a_nk * x[k] / (SSM精度 * SSM精度 / SSM精度)
                }
                k = k + 1
            }
            // B̄·u 部分 (输入维度=1简化)
            定义 u = 输入序列[t]
            状态值 = 状态值 + Δ * B[n] * u / (SSM精度 * SSM精度 / SSM精度)
            追加(新x, 状态值)
            n = n + 1
        }
        x = 新x
        // y_t = C·x_t
        定义 可变 y = 0
        n = 0
        当 (n < N) {
            y = y + C[n] * x[n] / SSM精度
            n = n + 1
        }
        追加(输出, y)
        t = t + 1
    }
    返回 输出
}

// Mamba: 选择性状态空间 (Gu & Dao 2023)
// 核心: Δ,B,C 由输入动态生成 → 选择性过滤信息
// Δ_t = 柔性正值(Linear(x_t)), B_t = Linear(x_t), C_t = Linear(x_t)

函数 Mamba_创建(模型维度, 状态维度, 扩展因子) {
    定义 内部维度 = 模型维度 * 扩展因子
    // 投影权重
    定义 可变 W_Δ = []    // 输入→步长
    定义 可变 W_B = []    // 输入→B
    定义 可变 W_C = []    // 输入→C
    // 初始化
    定义 可变 i = 0
    当 (i < 内部维度) {
        追加(W_Δ, ((i * 2654435761 + 1) % 200 - 100))
        i = i + 1
    }
    i = 0
    当 (i < 内部维度 * 状态维度) {
        追加(W_B, ((i * 1103515245 + 3) % 200 - 100))
        追加(W_C, ((i * 1103515245 + 7) % 200 - 100))
        i = i + 1
    }
    // A矩阵 (固定, 对角HiPPO)
    定义 可变 A_log = []
    i = 0
    当 (i < 状态维度) {
        追加(A_log, 0 - (i + 1) * 100)  // log(A) 初始化
        i = i + 1
    }
    返回 [模型维度, 状态维度, 扩展因子, 内部维度, A_log, W_Δ, W_B, W_C]
}

函数 柔性正值(x) {
    // 柔性正值(x) = log(1 + exp(x))
    如果 (x > 50000) { 返回 x }
    如果 (x < 0 - 50000) { 返回 0 }
    定义 ex = SSM精度 + x + x * x / (2 * SSM精度)  // 近似exp
    // log(1+ex) ≈ log(ex) for large ex
    如果 (ex > SSM精度) {
        返回 x + SSM精度 * SSM精度 / (ex + 1)  // 近似 log(1+exp)
    }
    返回 ex / 2
}

// Mamba选择性扫描 (核心算法)
函数 Mamba_选择性扫描(模型, 输入序列, 序列长) {
    定义 N = 模型[1]
    定义 A_log = 模型[4]
    定义 W_Δ = 模型[5]
    定义 W_B = 模型[6]
    定义 W_C = 模型[7]
    // 状态
    定义 可变 h = []
    定义 可变 hi = 0
    当 (hi < N) { 追加(h, 0); hi = hi + 1 }
    定义 可变 输出 = []
    定义 可变 t = 0
    当 (t < 序列长) {
        定义 u = 输入序列[t]
        // 选择性参数 (输入依赖)
        // Δ_t = 柔性正值(W_Δ · u)
        定义 Δ_raw = W_Δ[t % 计数(W_Δ)] * u / SSM精度
        定义 Δ = 柔性正值(Δ_raw)
        如果 (Δ < 10) { Δ = 10 }
        // B_t, C_t 由输入生成
        定义 可变 B_t = []
        定义 可变 C_t = []
        定义 可变 n = 0
        当 (n < N) {
            追加(B_t, W_B[n] * u / SSM精度)
            追加(C_t, W_C[n] * u / SSM精度)
            n = n + 1
        }
        // 离散化 + 状态更新
        // Ā_n = exp(Δ × A_n), A_n = -exp(A_log_n)
        // h_n' = Ā_n × h_n + Δ × B_n × u
        定义 可变 新h = []
        定义 可变 y = 0
        n = 0
        当 (n < N) {
            定义 可变 A_n = 0 - SSM精度  // -exp(A_log_n) 简化
            如果 (n < 计数(A_log)) {
                定义 可变 al = A_log[n]
                如果 (al < 0) { al = 0 - al }
                A_n = 0 - (SSM精度 + al)
            }
            定义 ΔA = Δ * A_n / SSM精度
            // exp(ΔA) ≈ 1 + ΔA for small ΔA
            定义 衰减 = SSM精度 + ΔA
            如果 (衰减 < 0) { 衰减 = 0 }
            定义 新状态 = 衰减 * h[n] / SSM精度 + Δ * B_t[n] * u / (SSM精度 * SSM精度 / SSM精度)
            追加(新h, 新状态)
            y = y + C_t[n] * 新状态 / SSM精度
            n = n + 1
        }
        h = 新h
        追加(输出, y)
        t = t + 1
    }
    返回 输出
}

// Mamba-2: Structured State Space Duality (Dao & Gu 2024)
// 核心洞见: SSM ≡ 一种特殊的线性注意力 (半可分矩阵)
// y = M·(B⊙u), 其中M是半可分矩阵 M_ij = C_i^T · A_{i:j} · B_j
// 多头SSM: 类似多头注意力, 每个头有独立的A,B,C
// 计算: 分块并行 + 块内递推, 结合两种模式的优势

函数 Mamba2_创建(模型维度, 状态维度, 头数) {
    定义 头维度 = 模型维度 / 头数
    // 每个头有独立的对角A矩阵
    定义 可变 A_heads = []
    定义 可变 hi = 0
    当 (hi < 头数) {
        定义 可变 A_diag = []
        定义 可变 n = 0
        当 (n < 状态维度) {
            // 对角A: a_n = -exp(log_a_n), 初始化为小负值
            追加(A_diag, 0 - (n + 1) * SSM精度 / 状态维度)
            n = n + 1
        }
        追加(A_heads, A_diag)
        hi = hi + 1
    }
    // 投影权重: 输入→B,C (每头独立)
    定义 可变 W_B = []
    定义 可变 W_C = []
    定义 可变 i = 0
    当 (i < 头数 * 头维度 * 状态维度) {
        追加(W_B, ((i * 2654435761 + 1) % 200 - 100))
        追加(W_C, ((i * 1103515245 + 7) % 200 - 100))
        i = i + 1
    }
    // Δ投影 (每头独立)
    定义 可变 W_Δ = []
    i = 0
    当 (i < 头数 * 头维度) {
        追加(W_Δ, ((i * 2654435761 + 3) % 200 - 100))
        i = i + 1
    }
    返回 [模型维度, 状态维度, 头数, 头维度, A_heads, W_B, W_C, W_Δ]
}

// Mamba-2 SSD层前向 (多头并行)
函数 Mamba2_前向(模型, 输入序列, 序列长) {
    定义 D = 模型[0]
    定义 N = 模型[1]
    定义 H = 模型[2]
    定义 头维度 = 模型[3]
    定义 A_heads = 模型[4]
    定义 W_B = 模型[5]
    定义 W_C = 模型[6]
    定义 W_Δ = 模型[7]

    定义 可变 输出 = []
    定义 可变 oi = 0
    当 (oi < 序列长 * D) { 追加(输出, 0); oi = oi + 1 }

    // 对每个头独立处理
    定义 可变 hi = 0
    当 (hi < H) {
        // 该头的状态
        定义 可变 h = []
        定义 可变 ni = 0
        当 (ni < N) { 追加(h, 0); ni = ni + 1 }

        定义 可变 t = 0
        当 (t < 序列长) {
            // 提取该头的输入片段
            定义 可变 x_head = []
            定义 可变 di = 0
            当 (di < 头维度) {
                追加(x_head, 输入序列[t * D + hi * 头维度 + di])
                di = di + 1
            }
            // 输入依赖的Δ,B,C
            定义 可变 Δ_raw = 0
            di = 0
            当 (di < 头维度) {
                Δ_raw = Δ_raw + W_Δ[hi * 头维度 + di] * x_head[di] / SSM精度
                di = di + 1
            }
            定义 Δ = 柔性正值(Δ_raw)
            如果 (Δ < 10) { Δ = 10 }

            // B_t, C_t
            定义 可变 B_t = []
            定义 可变 C_t = []
            ni = 0
            当 (ni < N) {
                定义 可变 b_val = 0
                定义 可变 c_val = 0
                di = 0
                当 (di < 头维度) {
                    b_val = b_val + W_B[(hi * 头维度 + di) * N + ni] * x_head[di] / SSM精度
                    c_val = c_val + W_C[(hi * 头维度 + di) * N + ni] * x_head[di] / SSM精度
                    di = di + 1
                }
                追加(B_t, b_val)
                追加(C_t, c_val)
                ni = ni + 1
            }

            // 状态更新 + 输出 (对角A, 高效)
            定义 可变 新h = []
            定义 可变 y_scalar = 0
            ni = 0
            当 (ni < N) {
                定义 a_n = A_heads[hi][ni]
                定义 ΔA = Δ * a_n / SSM精度
                定义 衰减 = SSM精度 + ΔA
                如果 (衰减 < 0) { 衰减 = 0 }
                // 输入u: 用x_head的第一维简化
                定义 u = x_head[0]
                定义 新状态 = 衰减 * h[ni] / SSM精度 + Δ * B_t[ni] * u / (SSM精度 * SSM精度 / SSM精度)
                追加(新h, 新状态)
                y_scalar = y_scalar + C_t[ni] * 新状态 / SSM精度
                ni = ni + 1
            }
            h = 新h

            // 写入该头的输出
            di = 0
            当 (di < 头维度) {
                输出[t * D + hi * 头维度 + di] = 输出[t * D + hi * 头维度 + di] + y_scalar
                di = di + 1
            }
            t = t + 1
        }
        hi = hi + 1
    }
    返回 输出
}

// Jamba: 混合Transformer-Mamba架构 (AI21 Labs, 2024)
// 核心: 在L层中交替使用Mamba层和Attention层
// 比例: 每ratio_A个Mamba层后接1个Attention层
// Mamba层: O(N)序列处理, 擅长长距离依赖
// Attention层: O(N²)但精确全局交互, 擅长精确检索
// 综合效果: 长序列效率 + 精确信息提取

函数 Jamba_层类型(层号, 注意力间隔) {
    // 每隔注意力间隔层放一个Attention层
    如果 (层号 % 注意力间隔 == 注意力间隔 - 1) {
        返回 1  // Attention层
    }
    返回 0  // Mamba层
}

// Jamba单层前向
函数 Jamba_层前向(输入, 层号, 注意力间隔, mamba模型, 序列长, d_模型, d_ff) {
    定义 层类型 = Jamba_层类型(层号, 注意力间隔)
    如果 (层类型 == 0) {
        // Mamba层: 选择性扫描
        返回 Mamba2_前向(mamba模型, 输入, 序列长)
    } 否则 {
        // Attention层: 简化的自注意力 + FFN
        // 自注意力: Q=K=V=输入 (自注意力简化)
        定义 可变 输出 = []
        定义 可变 t = 0
        当 (t < 序列长) {
            定义 可变 d = 0
            当 (d < d_模型) {
                // 简化注意力: 加权平均邻近token (局部窗口)
                定义 可变 val = 输入[t * d_模型 + d]
                定义 可变 权重和 = SSM精度
                定义 可变 w = 1
                当 (w <= 4) {
                    如果 (t - w >= 0) {
                        val = val + 输入[(t - w) * d_模型 + d] * (SSM精度 - w * 2000) / SSM精度
                        权重和 = 权重和 + SSM精度 - w * 2000
                    }
                    如果 (t + w < 序列长) {
                        val = val + 输入[(t + w) * d_模型 + d] * (SSM精度 - w * 2000) / SSM精度
                        权重和 = 权重和 + SSM精度 - w * 2000
                    }
                    w = w + 1
                }
                如果 (权重和 > 0) { val = val * SSM精度 / 权重和 }
                追加(输出, val)
                d = d + 1
            }
            t = t + 1
        }
        返回 输出
    }
}

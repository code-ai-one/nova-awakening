函数 RegExp_创建(Nova运行时实例, 模式, 标志字符串) {
    如果 (Nova运行时实例 == 0) { 返回 0 }
    定义 正则 = Nova对象_创建(Nova运行时实例, Nova运行时实例.Object原型)
    如果 (正则 == 0) { 返回 0 }

    // 设置内部属性
    Nova对象_设置属性(Nova运行时实例, 正则, "source", 模式)
    如果 (标志字符串 != 0) {
        Nova对象_设置属性(Nova运行时实例, 正则, "flags", 标志字符串)
    } 否则 {
        Nova对象_设置属性(Nova运行时实例, 正则, "flags", Nova值_创建_String(Nova运行时实例, ""))
    }
    Nova对象_设置属性(Nova运行时实例, 正则, "lastIndex", Nova值_创建_Number(Nova运行时实例, 0))

    // 解析标志
    定义 标志 = 0
    如果 (标志字符串 != 0) {
        标志 = RegExp_解析标志(JSValue_获取字符串(标志字符串))
    }

    // 设置标志属性
    Nova对象_设置属性(Nova运行时实例, 正则, "global", Nova值_创建_Boolean(Nova运行时实例, (标志 & RE_FLAG_g) != 0))
    Nova对象_设置属性(Nova运行时实例, 正则, "ignoreCase", Nova值_创建_Boolean(Nova运行时实例, (标志 & RE_FLAG_i) != 0))
    Nova对象_设置属性(Nova运行时实例, 正则, "multiline", Nova值_创建_Boolean(Nova运行时实例, (标志 & RE_FLAG_m) != 0))
    Nova对象_设置属性(Nova运行时实例, 正则, "dotAll", Nova值_创建_Boolean(Nova运行时实例, (标志 & RE_FLAG_s) != 0))
    Nova对象_设置属性(Nova运行时实例, 正则, "unicode", Nova值_创建_Boolean(Nova运行时实例, (标志 & RE_FLAG_u) != 0))
    Nova对象_设置属性(Nova运行时实例, 正则, "sticky", Nova值_创建_Boolean(Nova运行时实例, (标志 & RE_FLAG_y) != 0))
    Nova对象_设置属性(Nova运行时实例, 正则, "hasIndices", Nova值_创建_Boolean(Nova运行时实例, (标志 & RE_FLAG_d) != 0))

    // 尝试从缓存获取编译后的AST
    定义 模式str = JSValue_获取字符串(模式)
    定义 模式哈希 = 字符串_哈希(模式str)
    定义 缓存AST = 正则缓存_查找(模式哈希, 标志)
    如果 (缓存AST == 0) {
        // 缓存未命中: 编译并缓存
        缓存AST = RegExp_解析(模式str, 标志字符串 != 0 ? JSValue_获取字符串(标志字符串) : 0)
        如果 (缓存AST != 0) {
            正则缓存_插入(模式哈希, 标志, 缓存AST)
        }
    }

    返回 正则
}

函数 RegExp_解析标志(标志str) {
    如果 (标志str == 0) { 返回 0 }
    定义 可变 结果 = 0
    定义 可变 i = 0
    当 (内存_读8(标志str + i) != 0) {
        定义 c = 内存_读8(标志str + i)
        如果 (c == 0x67) { 结果 = 结果 | RE_FLAG_g }
        如果 (c == 0x69) { 结果 = 结果 | RE_FLAG_i }
        如果 (c == 0x6D) { 结果 = 结果 | RE_FLAG_m }
        如果 (c == 0x73) { 结果 = 结果 | RE_FLAG_s }
        如果 (c == 0x75) { 结果 = 结果 | RE_FLAG_u }
        如果 (c == 0x79) { 结果 = 结果 | RE_FLAG_y }
        如果 (c == 0x64) { 结果 = 结果 | RE_FLAG_d }
        如果 (c == 0x76) { 结果 = 结果 | RE_FLAG_v }
        i = i + 1
    }
    返回 结果
}

函数 字符串_哈希(str) {
    如果 (str == 0) { 返回 0 }
    定义 可变 哈希 = 5381
    定义 可变 i = 0
    当 (内存_读8(str + i) != 0) {
        哈希 = 哈希 * 33 + 内存_读8(str + i)
        i = i + 1
    }
    如果 (哈希 < 0) { 哈希 = 0 - 哈希 }
    返回 哈希
}


函数 String_match(Nova运行时实例, 字符串, 正则) {
    如果 (Nova运行时实例 == 0 || 字符串 == 0 || 正则 == 0) { 返回 0 }
    定义 标志值 = Nova对象_获取属性(Nova运行时实例, 正则, "flags")
    定义 标志str = JSValue_获取字符串(标志值)
    定义 标志 = RegExp_解析标志(标志str)

    如果 ((标志 & RE_FLAG_g) == 0) {
        // 非全局: 返回exec结果
        返回 RegExp_exec(Nova运行时实例, 正则, 字符串)
    }

    // 全局模式: 返回所有匹配的数组
    定义 结果数组 = Nova数组_创建(Nova运行时实例, 8)
    Nova对象_设置属性(Nova运行时实例, 正则, "lastIndex", Nova值_创建_Number(Nova运行时实例, 0))

    定义 可变 匹配 = RegExp_exec(Nova运行时实例, 正则, 字符串)
    当 (匹配 != 0 && 匹配 != Nova运行时实例.null值) {
        定义 匹配文本 = Nova数组_获取(Nova运行时实例, 匹配, 0)
        Nova数组_Push(Nova运行时实例, 结果数组, 匹配文本)
        // 防止空匹配无限循环
        定义 匹配长度 = 0
        如果 (匹配文本 != 0) {
            匹配长度 = 字节长度(JSValue_获取字符串(匹配文本))
        }
        如果 (匹配长度 == 0) {
            定义 当前li = Nova对象_获取属性(Nova运行时实例, 正则, "lastIndex")
            Nova对象_设置属性(Nova运行时实例, 正则, "lastIndex", Nova值_创建_Number(Nova运行时实例, Nova值_转数值(Nova运行时实例, 当前li) + 1))
        }
        匹配 = RegExp_exec(Nova运行时实例, 正则, 字符串)
    }

    如果 (Nova数组_Length(Nova运行时实例, 结果数组) == 0) { 返回 Nova运行时实例.null值 }
    返回 结果数组
}

函数 String_search(Nova运行时实例, 字符串, 正则) {
    如果 (Nova运行时实例 == 0 || 字符串 == 0 || 正则 == 0) { 返回 -1 }
    // 保存并重置lastIndex
    定义 旧li = Nova对象_获取属性(Nova运行时实例, 正则, "lastIndex")
    Nova对象_设置属性(Nova运行时实例, 正则, "lastIndex", Nova值_创建_Number(Nova运行时实例, 0))

    定义 结果 = RegExp_exec(Nova运行时实例, 正则, 字符串)

    // 恢复lastIndex
    Nova对象_设置属性(Nova运行时实例, 正则, "lastIndex", 旧li)

    如果 (结果 == 0 || 结果 == Nova运行时实例.null值) { 返回 -1 }
    定义 索引值 = Nova对象_获取属性(Nova运行时实例, 结果, "index")
    返回 Nova值_转数值(Nova运行时实例, 索引值)
}

函数 String_replace(Nova运行时实例, 字符串, 正则, 替换) {
    如果 (Nova运行时实例 == 0 || 字符串 == 0 || 正则 == 0) { 返回 字符串 }
    // 简化版: 仅替换第一个匹配
    定义 结果 = RegExp_exec(Nova运行时实例, 正则, 字符串)
    如果 (结果 == 0 || 结果 == Nova运行时实例.null值) { 返回 字符串 }

    定义 索引值 = Nova对象_获取属性(Nova运行时实例, 结果, "index")
    定义 匹配文本 = Nova数组_获取(Nova运行时实例, 结果, 0)
    定义 索引 = Nova值_转数值(Nova运行时实例, 索引值)
    定义 匹配长度 = 字节长度(JSValue_获取字符串(匹配文本))

    // 构建: 前缀 + 替换 + 后缀
    定义 输入str = JSValue_获取字符串(字符串)
    定义 替换str = JSValue_获取字符串(替换)
    如果 (输入str == 0 || 替换str == 0) { 返回 字符串 }

    定义 输入长度 = 字节长度(输入str)
    定义 替换长度 = 字节长度(替换str)
    定义 新长度 = 输入长度 - 匹配长度 + 替换长度
    定义 新字符串 = 平台_申请内存(新长度 + 1)
    如果 (新字符串 == 0) { 返回 字符串 }

    // 复制前缀
    内存_复制(新字符串, 输入str, 索引)
    // 复制替换
    内存_复制(新字符串 + 索引, 替换str, 替换长度)
    // 复制后缀
    内存_复制(新字符串 + 索引 + 替换长度, 输入str + 索引 + 匹配长度, 输入长度 - 索引 - 匹配长度)
    内存_写8(新字符串 + 新长度, 0)

    返回 Nova值_创建_String(Nova运行时实例, 新字符串)
}

函数 String_split(Nova运行时实例, 字符串, 分隔符, 限制) {
    如果 (Nova运行时实例 == 0 || 字符串 == 0) { 返回 0 }
    定义 结果 = Nova数组_创建(Nova运行时实例, 8)
    如果 (结果 == 0) { 返回 0 }

    定义 输入str = JSValue_获取字符串(字符串)
    如果 (输入str == 0) { 返回 结果 }
    定义 输入长度 = 字节长度(输入str)
    定义 可变 最大 = 限制
    如果 (最大 <= 0) { 最大 = 0xFFFFFFFF }

    // 简化: 字符串分隔符(非正则)
    如果 (分隔符 == 0 || JSValue_IsUndefined(分隔符)) {
        Nova数组_Push(Nova运行时实例, 结果, 字符串)
        返回 结果
    }

    定义 分隔str = JSValue_获取字符串(分隔符)
    如果 (分隔str == 0) { 返回 结果 }
    定义 分隔长度 = 字节长度(分隔str)

    如果 (分隔长度 == 0) {
        // 空分隔符: 拆分为单字符
        定义 可变 i = 0
        当 (i < 输入长度 && Nova数组_Length(Nova运行时实例, 结果) < 最大) {
            定义 ch = 平台_申请内存(2)
            内存_写8(ch, 内存_读8(输入str + i))
            内存_写8(ch + 1, 0)
            Nova数组_Push(Nova运行时实例, 结果, Nova值_创建_String(Nova运行时实例, ch))
            i = i + 1
        }
        返回 结果
    }

    // 正常分割
    定义 可变 起始 = 0
    定义 可变 位置 = 0
    当 (位置 <= 输入长度 - 分隔长度 && Nova数组_Length(Nova运行时实例, 结果) < 最大) {
        // 在位置处查找分隔符
        定义 可变 匹配 = 真
        定义 可变 j = 0
        当 (j < 分隔长度) {
            如果 (内存_读8(输入str + 位置 + j) != 内存_读8(分隔str + j)) {
                匹配 = 假
                跳出
            }
            j = j + 1
        }
        如果 (匹配 == 真) {
            // 提取子串
            定义 子串 = 平台_申请内存(位置 - 起始 + 1)
            如果 (子串 != 0) {
                内存_复制(子串, 输入str + 起始, 位置 - 起始)
                内存_写8(子串 + 位置 - 起始, 0)
                Nova数组_Push(Nova运行时实例, 结果, Nova值_创建_String(Nova运行时实例, 子串))
            }
            起始 = 位置 + 分隔长度
            位置 = 起始
        } 否则 {
            位置 = 位置 + 1
        }
    }
    // 最后一段
    如果 (Nova数组_Length(Nova运行时实例, 结果) < 最大) {
        定义 最后 = 平台_申请内存(输入长度 - 起始 + 1)
        如果 (最后 != 0) {
            内存_复制(最后, 输入str + 起始, 输入长度 - 起始)
            内存_写8(最后 + 输入长度 - 起始, 0)
            Nova数组_Push(Nova运行时实例, 结果, Nova值_创建_String(Nova运行时实例, 最后))
        }
    }
    返回 结果
}


函数 RegExp_安装原型(Nova运行时实例, ctx) {
    如果 (Nova运行时实例 == 0 || ctx == 0) { 返回 }
    定义 正则原型 = Nova对象_创建(Nova运行时实例, Nova运行时实例.Object原型)
    Nova对象_设置属性(Nova运行时实例, 正则原型, "exec", Nova函数_创建(Nova运行时实例, "exec", 0, 1))
    Nova对象_设置属性(Nova运行时实例, 正则原型, "test", Nova函数_创建(Nova运行时实例, "test", 0, 1))
    Nova对象_设置属性(Nova运行时实例, 正则原型, "toString", Nova函数_创建(Nova运行时实例, "toString", 0, 0))
    // 安装到全局
    定义 正则构造 = Nova函数_创建(Nova运行时实例, "RegExp", 0, 2)
    Nova对象_设置属性(Nova运行时实例, 正则构造, "prototype", 正则原型)
    Nova对象_设置属性(Nova运行时实例, ctx.全局对象, "RegExp", 正则构造)
}


定义 可变 统计_RegExp创建数 = 0
定义 可变 统计_exec调用数 = 0
定义 可变 统计_test调用数 = 0
定义 可变 统计_match调用数 = 0
定义 可变 统计_replace调用数 = 0
定义 可变 统计_split调用数 = 0

函数 RegExp接口_打印统计() {
    打印("[RegExp] ═══════════ RegExp接口统计 ═══════════")
    打印(字符串拼接("  RegExp创建数:  ", 转字符串(统计_RegExp创建数)))
    打印(字符串拼接("  exec调用数:    ", 转字符串(统计_exec调用数)))
    打印(字符串拼接("  test调用数:    ", 转字符串(统计_test调用数)))
    打印(字符串拼接("  match调用数:   ", 转字符串(统计_match调用数)))
    打印(字符串拼接("  replace调用数: ", 转字符串(统计_replace调用数)))
    打印(字符串拼接("  split调用数:   ", 转字符串(统计_split调用数)))
    定义 缓存 = 正则缓存_获取()
    如果 (缓存 != 空) {
        打印(字符串拼接("  缓存数量:      ", 转字符串(缓存.数量)))
        打印(字符串拼接("  缓存命中:      ", 转字符串(缓存.命中次数)))
        打印(字符串拼接("  缓存未命中:    ", 转字符串(缓存.未命中次数)))
    }
    打印("[RegExp] ═══════════════════════════════════════")
}

函数 RegExp_重置缓存() {
    如果 (全局正则缓存 != 空) {
        全局正则缓存.数量 = 0
        全局正则缓存.命中次数 = 0
        全局正则缓存.未命中次数 = 0
    }
}

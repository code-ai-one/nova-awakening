// x86_64 内核虚拟地址空间布局 (来自Linux Documentation):
//   用户空间:      0x0000_0000_0000_0000 ~ 0x0000_7FFF_FFFF_FFFF (128TB)
//   [空洞]         non-canonical地址区域
//   直接映射:      0xFFFF_8880_0000_0000 ~ 0xFFFF_C87F_FFFF_FFFF (64TB)
//   vmalloc:       0xFFFF_C900_0000_0000 ~ 0xFFFF_E8FF_FFFF_FFFF (32TB)
//   vmeNova内存映射:       0xFFFF_EA00_0000_0000 ~ 0xFFFF_EAFF_FFFF_FFFF (1TB)
//   内核代码:      0xFFFF_FFFF_8000_0000 ~ 0xFFFF_FFFF_FFFF_FFFF (2GB)

定义 用户空间_顶部   = 0x0000_7FFF_FFFF_FFFF
定义 内核空间_底部   = 0xFFFF_8000_0000_0000

定义 直接映射_底部   = 0xFFFF_8880_0000_0000   // page_offset_base
定义 直接映射_顶部   = 0xFFFF_C880_0000_0000

定义 VMALLOC_底部    = 0xFFFF_C900_0000_0000
定义 VMALLOC_顶部    = 0xFFFF_E900_0000_0000

定义 VMENova内存映射_底部    = 0xFFFF_EA00_0000_0000   // struct page数组
定义 VMENova内存映射_顶部    = 0xFFFF_EB00_0000_0000

定义 内核代码_底部   = 0xFFFF_FFFF_8000_0000   // __START_KERNEL_map
定义 内核代码_顶部   = 0xFFFF_FFFF_FFFF_FFFF

// PTE_存在 定义在 架构/x86_64/寄存器定义.nova
// PTE_可写 定义在 架构/x86_64/寄存器定义.nova
// PTE_用户 定义在 架构/x86_64/寄存器定义.nova
// PTE_写穿 定义在 架构/x86_64/寄存器定义.nova
// PTE_禁缓存 定义在 架构/x86_64/寄存器定义.nova
// PTE_已访问 定义在 架构/x86_64/寄存器定义.nova
// PTE_脏 定义在 架构/x86_64/寄存器定义.nova
// PTE_大页 定义在 架构/x86_64/寄存器定义.nova
// PTE_全局 定义在 架构/x86_64/寄存器定义.nova
// PTE_不执行 定义在 架构/x86_64/寄存器定义.nova

// 地址类型判断

函数 是用户地址(地址)   { 返回 地址 <= 用户空间_顶部 }
函数 是内核地址(地址)   { 返回 地址 >= 内核空间_底部 }
函数 是直接映射(地址)   { 返回 地址 >= 直接映射_底部 && 地址 < 直接映射_顶部 }
函数 是vmalloc地址(地址) { 返回 地址 >= VMALLOC_底部 && 地址 < VMALLOC_顶部 }
函数 是vmeNova内存映射地址(地址) { 返回 地址 >= VMENova内存映射_底部 && 地址 < VMENova内存映射_顶部 }
函数 是内核代码(地址)   { 返回 地址 >= 内核代码_底部 }

// 物理↔虚拟地址转换 

函数 物理到虚拟_内核映射(物理地址) {
    // __va: 物理地址 + 直接映射偏移
    返回 物理地址 + 直接映射_底部
}

函数 虚拟到物理_内核映射(虚拟地址) {
    // __pa: 虚拟地址 - 直接映射偏移
    如果 (是直接映射(虚拟地址)) {
        返回 虚拟地址 - 直接映射_底部
    }
    如果 (是内核代码(虚拟地址)) {
        返回 虚拟地址 - 内核代码_底部
    }
    // vmalloc地址: 需要查页表
    返回 查页表_虚拟到物理(虚拟地址)
}

函数 虚拟_页号到地址(页号) { 返回 物理到虚拟(页号 * 页大小) }    // 虚拟版(通用版在类型定义.nova)
函数 虚拟_地址到页号(地址) { 返回 虚拟到物理(地址) / 页大小 }    // 虚拟版(通用版在类型定义.nova)

// 页表操作 

函数 映射页_内核(PML4基址, 虚拟地址, 物理地址, 标志) {
    // 4级页表: PML4 → PDP → PD → PT → 物理页
    // 每级9位索引: [47:39] [38:30] [29:21] [20:12]
    定义 pml4_idx = (虚拟地址 >> 39) & 0x1FF
    定义 pdp_idx  = (虚拟地址 >> 30) & 0x1FF
    定义 pd_idx   = (虚拟地址 >> 21) & 0x1FF
    定义 pt_idx   = (虚拟地址 >> 12) & 0x1FF

    // 逐级查找/创建页表项
    定义 pdp_base = 获取或创建页表项(PML4基址, pml4_idx)
    定义 pd_base  = 获取或创建页表项(pdp_base, pdp_idx)
    定义 pt_base  = 获取或创建页表项(pd_base, pd_idx)

    // 写最终PTE: 物理地址 | 标志
    定义 pte = (物理地址 & 0xFFFFF000) | 标志
    内存写64(pt_base + pt_idx * 8, pte)
}

函数 取消映射页_内核(PML4基址, 虚拟地址) {
    定义 pml4_idx = (虚拟地址 >> 39) & 0x1FF
    定义 pdp_idx  = (虚拟地址 >> 30) & 0x1FF
    定义 pd_idx   = (虚拟地址 >> 21) & 0x1FF
    定义 pt_idx   = (虚拟地址 >> 12) & 0x1FF

    定义 pdp_base = 读取页表项(PML4基址, pml4_idx)
    如果 (pdp_base == 0) { 返回 }
    定义 pd_base = 读取页表项(pdp_base, pdp_idx)
    如果 (pd_base == 0) { 返回 }
    定义 pt_base = 读取页表项(pd_base, pd_idx)
    如果 (pt_base == 0) { 返回 }

    内存写64(pt_base + pt_idx * 8, 0)   // 清除PTE
}

函数 获取或创建页表项(表基址, 索引) {
    定义 项 = 内存读64(表基址 + 索引 * 8)
    如果 ((项 & PTE_存在) != 0) {
        返回 物理到虚拟(项 & 0xFFFFF000)
    }
    // 分配新页表页
    定义 新页 = 伙伴系统_分配(0)
    如果 (新页 < 0) { 返回 0 }
    定义 新页地址 = 新页 * 页大小
    内存清零(物理到虚拟(新页地址), 页大小)
    内存写64(表基址 + 索引 * 8, 新页地址 | PTE_存在 | PTE_可写 | PTE_用户)
    返回 物理到虚拟(新页地址)
}

函数 读取页表项(表基址, 索引) {
    定义 项 = 内存读64(表基址 + 索引 * 8)
    如果 ((项 & PTE_存在) != 0) {
        返回 物理到虚拟(项 & 0xFFFFF000)
    }
    返回 0
}

函数 查页表_虚拟到物理(虚拟地址) {
    // 遍历4级页表获取物理地址
    返回 0   // 需要当前CR3
}

函数 当前PML4() {
    返回 物理到虚拟(读取CR3() & 0xFFFFF000)
}

函数 刷新TLB_内核映射() {
    // 重新加载CR3
    写入CR3(读取CR3())
}

// 查页表: 虚拟地址→物理地址 (遍历4级页表)

函数 查页表_完整(虚拟地址) {
    定义 pml4 = 当前PML4()
    定义 pml4_idx = (虚拟地址 >> 39) & 0x1FF
    定义 pml4e = 内存读64(pml4 + pml4_idx * 8)
    如果 ((pml4e & PTE_存在) == 0) { 返回 -1 }

    定义 pdp = 物理到虚拟(pml4e & 0xFFFFF000)
    定义 pdp_idx = (虚拟地址 >> 30) & 0x1FF
    定义 pdpe = 内存读64(pdp + pdp_idx * 8)
    如果 ((pdpe & PTE_存在) == 0) { 返回 -1 }
    // 1GB大页检查
    如果 ((pdpe & PTE_大页) != 0) {
        返回 (pdpe & 0xFFFFC0000000) | (虚拟地址 & 0x3FFFFFFF)
    }

    定义 pd = 物理到虚拟(pdpe & 0xFFFFF000)
    定义 pd_idx = (虚拟地址 >> 21) & 0x1FF
    定义 pde = 内存读64(pd + pd_idx * 8)
    如果 ((pde & PTE_存在) == 0) { 返回 -1 }
    // 2MB大页检查
    如果 ((pde & PTE_大页) != 0) {
        返回 (pde & 0xFFFFFE00000) | (虚拟地址 & 0x1FFFFF)
    }

    定义 pt = 物理到虚拟(pde & 0xFFFFF000)
    定义 pt_idx = (虚拟地址 >> 12) & 0x1FF
    定义 pte = 内存读64(pt + pt_idx * 8)
    如果 ((pte & PTE_存在) == 0) { 返回 -1 }
    返回 (pte & 0xFFFFF000) | (虚拟地址 & 0xFFF)
}

// PTE标志查询

函数 页面_可写(虚拟地址) {
    定义 pte = 获取PTE(虚拟地址)
    如果 (pte == 0) { 返回 假 }
    返回 (pte & PTE_可写) != 0
}

函数 页面_可执行(虚拟地址) {
    定义 pte = 获取PTE(虚拟地址)
    如果 (pte == 0) { 返回 假 }
    返回 (pte & PTE_不执行) == 0
}

函数 页面_已访问(虚拟地址) {
    定义 pte = 获取PTE(虚拟地址)
    如果 (pte == 0) { 返回 假 }
    返回 (pte & PTE_已访问) != 0
}

函数 页面_脏(虚拟地址) {
    定义 pte = 获取PTE(虚拟地址)
    如果 (pte == 0) { 返回 假 }
    返回 (pte & PTE_脏) != 0
}

函数 获取PTE(虚拟地址) {
    定义 pml4 = 当前PML4()
    定义 pml4_idx = (虚拟地址 >> 39) & 0x1FF
    定义 pml4e = 内存读64(pml4 + pml4_idx * 8)
    如果 ((pml4e & PTE_存在) == 0) { 返回 0 }
    定义 pdp = 物理到虚拟(pml4e & 0xFFFFF000)
    定义 pdpe = 内存读64(pdp + ((虚拟地址 >> 30) & 0x1FF) * 8)
    如果 ((pdpe & PTE_存在) == 0) { 返回 0 }
    如果 ((pdpe & PTE_大页) != 0) { 返回 pdpe }
    定义 pd = 物理到虚拟(pdpe & 0xFFFFF000)
    定义 pde = 内存读64(pd + ((虚拟地址 >> 21) & 0x1FF) * 8)
    如果 ((pde & PTE_存在) == 0) { 返回 0 }
    如果 ((pde & PTE_大页) != 0) { 返回 pde }
    定义 pt = 物理到虚拟(pde & 0xFFFFF000)
    返回 内存读64(pt + ((虚拟地址 >> 12) & 0x1FF) * 8)
}

// PTE标志名称 + 地址区域名称

函数 PTE_标志名(标志) {
    定义 可变 名 = ""
    如果 ((标志 & PTE_存在) != 0) { 名 = 名 + "P" }
    如果 ((标志 & PTE_可写) != 0) { 名 = 名 + "W" }
    如果 ((标志 & PTE_用户) != 0) { 名 = 名 + "U" }
    如果 ((标志 & PTE_脏) != 0) { 名 = 名 + "D" }
    如果 ((标志 & PTE_不执行) != 0) { 名 = 名 + "NX" }
    返回 名
}

函数 地址区域名(地址) {
    如果 (是用户地址(地址)) { 返回 "user" }
    如果 (是直接映射(地址)) { 返回 "direct_map" }
    如果 (是vmalloc地址(地址)) { 返回 "vmalloc" }
    如果 (是vmeNova内存映射地址(地址)) { 返回 "vmeNova内存映射" }
    如果 (是内核代码(地址)) { 返回 "kernel_text" }
    返回 "unknown"
}


函数 内核映射_完整统计() {
    返回 [内核映射_总数]
}

// 内核映射辅助

定义 可变 内核映射_失败数 = 0

函数 内核映射_健康检查() {
    定义 可变 问题 = []
    如果 (内核映射_失败数 > 0) {
        追加(问题, "内核映射失败: " + 整数转字符串(内核映射_失败数) + "次")
    }
    如果 (计数(问题) == 0) { 返回 "内核映射健康" }
    返回 问题
}

定义 KERNEL_TEXT_START = 0xFFFFFFFF80000000
定义 KERNEL_TEXT_END = 0xFFFFFFFF90000000
定义 KERNEL_DATA_START = 0xFFFFFFFF90000000
定义 KERNEL_HEAP_START = 0xFFFFFFFFA0000000

函数 内核映射_是内核地址(地址) {
    返回 地址 >= KERNEL_TEXT_START
}

函数 内核映射_区域名(地址) {
    如果 (地址 >= KERNEL_TEXT_START && 地址 < KERNEL_TEXT_END) { 返回 "text" }
    如果 (地址 >= KERNEL_DATA_START && 地址 < KERNEL_HEAP_START) { 返回 "data" }
    如果 (地址 >= KERNEL_HEAP_START) { 返回 "heap" }
    返回 "unknown"
}

函数 内核映射_重置统计() {
    内核映射_总数 = 0
    内核映射_失败数 = 0
}

定义 可变 AI_内核映射_运行指标 = 0
定义 可变 AI_内核映射_异常指标 = 0

函数 AI_内核映射_自诊断() {
    AI_内核映射_运行指标 = 0
    返回 AI_内核映射_运行指标
}

函数 AI_内核映射_优化建议() {
    定义 指标 = AI_内核映射_自诊断()
    返回 "内核映射状态正常"
}

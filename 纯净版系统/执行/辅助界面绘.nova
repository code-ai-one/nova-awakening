// §7 辅助UI绘制

函数 绘制_顶部栏() {
    // Logo
    绘制文字(30, 20, "🌟 NovaOS", 24, 0x4FC3F7)
    绘制文字(30, 50, "AI原生操作系统 安装向导", 12, 0x606080)

    // 步骤进度指示
    定义 步骤名 = ["欢迎", "语言", "磁盘", "分区", "用户", "AI", "安装", "完成"]
    定义 可变 i = 0
    定义 起始X = 屏幕宽 / 2 - 350
    当 (i < 8) {
        定义 sx = 起始X + i * 100
        定义 活跃 = (i == 安装.当前步骤)
        定义 完成 = (i < 安装.当前步骤)
        定义 颜色 = 0x404060
        如果 (活跃) { 颜色 = 0x4FC3F7 }
        否则 如果 (完成) { 颜色 = 0x66BB6A }
        // 圆点
        填充圆(sx + 10, 40, 8, 颜色)
        绘制文字(sx - 5, 55, 步骤名[i], 10, 颜色)
        // 连线
        如果 (i < 7) {
            定义 线色 = 如果选(完成, 0x66BB6A, 0x303050)
            填充矩形(sx + 20, 38, 78, 2, 线色)
        }
        i = i + 1
    }
}

函数 绘制_底部导航(x, y, 宽) {
    如果 (安装.当前步骤 > 0) {
        // 上一步按钮
        绘制_按钮(x, y, 120, 40, "← 上一步", 0x606080)
    }
    如果 (安装.当前步骤 < 步骤_安装) {
        // 下一步按钮(发光)
        定义 文字 = 如果选(安装.当前步骤 == 步骤_AI设置, "开始安装", "下一步 →")
        绘制_发光按钮(x + 宽 - 140, y, 140, 40, 文字)
    }
}

函数 绘制_AI全息人形(中心X, y, 大小) {
    // 全息人形轮廓(发光线条组成的人形)
    定义 颜色 = 0x4FC3F7
    // 头(圆)
    绘制_发光圆(中心X, y + 大小 / 4, 大小 / 4, 颜色)
    // 身体(三角/梯形)
    绘制_发光线(中心X, y + 大小 / 2, 中心X - 大小 / 3, y + 大小, 颜色)
    绘制_发光线(中心X, y + 大小 / 2, 中心X + 大小 / 3, y + 大小, 颜色)
    // 底部光环
    绘制_发光椭圆(中心X, y + 大小 + 10, 大小 / 2, 大小 / 6, 颜色)
}

函数 绘制_进度条(x, y, 宽, 高, 百分比, 颜色) {
    // 背景
    填充矩形(x, y, 宽, 高, 0x1A1A2E)
    // 填充
    定义 填充宽 = 宽 * 百分比 / 100
    填充矩形(x, y, 填充宽, 高, 颜色)
    // 发光前端
    如果 (填充宽 > 2) {
        填充矩形(x + 填充宽 - 2, y, 4, 高, 颜色_变亮(颜色, 80))
    }
}

函数 绘制_分区预览(x, y, 宽, 高) {
    // EFI(512MB) + 根(大部分) + Swap(4GB)
    定义 EFI宽 = 宽 * 5 / 100   // 5%
    定义 Swap宽 = 宽 * 8 / 100  // 8%
    定义 根宽 = 宽 - EFI宽 - Swap宽

    填充矩形(x, y, EFI宽, 高, 0xFFA726)
    绘制文字(x + 2, y + 8, "EFI", 10, 0x000000)

    填充矩形(x + EFI宽 + 2, y, 根宽 - 4, 高, 0x4FC3F7)
    绘制文字(x + EFI宽 + 10, y + 8, "/ (根分区)", 10, 0x000000)

    填充矩形(x + EFI宽 + 根宽, y, Swap宽, 高, 0x66BB6A)
    绘制文字(x + EFI宽 + 根宽 + 2, y + 8, "swap", 10, 0x000000)
}

函数 绘制_输入框(x, y, 宽, 占位文字, 值) {
    填充矩形(x, y, 宽, 40, 颜色(25, 25, 40, 200))
    绘制_发光边框(空, x, y, 宽, 40, 8)
    如果 (字符串长度(值) > 0) {
        绘制文字(x + 12, y + 12, 值, 14, 0xE0E0F0)
    } 否则 {
        绘制文字(x + 12, y + 12, 占位文字, 14, 0x505070)
    }
}

函数 绘制_特性图标(x, y, 图标, 标题, 描述) {
    绘制文字(x + 20, y, 图标, 28, 0x4FC3F7)
    绘制文字(x + 5, y + 35, 标题, 14, 0xC0C0D0)
    绘制文字(x + 5, y + 55, 描述, 11, 0x808090)
}

函数 获取安装操作(进度) {
    如果 (进度 < 10) { 返回 "正在创建分区..." }
    如果 (进度 < 20) { 返回 "正在格式化分区..." }
    如果 (进度 < 40) { 返回 "正在复制系统文件..." }
    如果 (进度 < 55) { 返回 "正在安装内核..." }
    如果 (进度 < 65) { 返回 "正在配置引导加载器..." }
    如果 (进度 < 75) { 返回 "正在初始化AI子系统..." }
    如果 (进度 < 85) { 返回 "正在下载AI基础权重..." }
    如果 (进度 < 90) { 返回 "正在配置网络和驱动..." }
    如果 (进度 < 95) { 返回 "正在创建用户账户..." }
    如果 (进度 < 100) { 返回 "正在生成个性化桌面..." }
    返回 "安装完成!"
}

函数 AI模式名称(模式) {
    如果 (模式 == 0) { 返回 "云端优先" }
    如果 (模式 == 1) { 返回 "本地优先" }
    返回 "智能混合"
}

函数 更新进度(进度, 消息) {
    安装.安装进度 = 进度
    绘制_安装界面()
}

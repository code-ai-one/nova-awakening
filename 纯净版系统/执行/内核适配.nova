    档.最近域 = 地址
    档.最近风险 = 结果
    档.安全数 = 档.安全数 + 1
    返回 结果
}

函数 内核适配_速率检查(档, 域) {
    定义 结果 = 浏览器安全_速率检查(域)
    档.安全数 = 档.安全数 + 1
    档.最近风险 = 结果
    返回 结果
}

函数 内核适配_白名单(档, 域) {
    浏览器安全_添加白名单(域)
    档.安全数 = 档.安全数 + 1
}

函数 内核适配_黑名单(档, 域) {
    浏览器安全_添加黑名单(域)
    档.安全数 = 档.安全数 + 1
}

函数 内核适配_安全统计(档) {
    定义 统计 = 浏览器安全_统计()
    档.最近统计 = 统计
    返回 统计
}

函数 内核适配_初始化网络(档) {
    浏览器网络_初始化()
    档.网络数 = 档.网络数 + 1
    适配总执行 = 适配总执行 + 1
}

函数 内核适配_建请求(方法, 地址, 头, 体, 下载名, 域) {
    定义 请求 = 堆_分配(适配请求)
    请求.方法 = 方法
    请求.地址 = 地址
    请求.头 = 头
    请求.体 = 体
    请求.下载名 = 下载名
    请求.域 = 域
    返回 请求
}

函数 内核适配_解析地址(档, 地址) {
    定义 结果 = 浏览器网络_解析URL(地址)
    档.最近请求 = 结果
    档.网络数 = 档.网络数 + 1
    返回 结果
}

函数 内核适配_发起请求(档, 方法, 地址, 请求头, 请求体) {
    定义 请求 = 浏览器网络_发起请求(方法, 地址, 请求头, 请求体)
    档.最近请求 = 请求
    档.网络数 = 档.网络数 + 1
    返回 请求
}

函数 内核适配_构造请求(档, 请求, 解析结果) {
    定义 结果 = 浏览器网络_构造HTTP请求(请求, 解析结果)
    档.最近响应 = 结果
    档.网络数 = 档.网络数 + 1
    返回 结果
}

函数 内核适配_接收响应(档, 请求) {
    浏览器网络_接收响应(请求)
    档.最近响应 = 请求
    档.网络数 = 档.网络数 + 1
    返回 请求
}

函数 内核适配_网络探活(档, 地址, 端口) {
    定义 结果 = 浏览器网络_请求(地址, 端口)
    档.最近响应 = 结果
    档.网络数 = 档.网络数 + 1
    返回 结果
}

函数 内核适配_预取(档, 地址, 优先级) {
    浏览器网络_预取(地址, 优先级)
    档.网络数 = 档.网络数 + 1
}

函数 内核适配_活跃连接数(档) {
    定义 数量 = 浏览器网络_活跃连接数()
    档.最近统计 = 数量
    返回 数量
}

函数 内核适配_网络统计(档) {
    定义 统计 = 浏览器网络_统计()
    档.最近统计 = 统计
    返回 统计
}

函数 内核适配_执行请求(档, 请求) {
    定义 风险 = 内核适配_评估网址(档, 请求.地址)
    如果 (风险 != 0 && 风险 > 80) {
        档.失败数 = 档.失败数 + 1
        适配总失败 = 适配总失败 + 1
        档.最近风险 = 风险
        返回 0
    }
    定义 解析结果 = 内核适配_解析地址(档, 请求.地址)
    定义 发起 = 内核适配_发起请求(档, 请求.方法, 请求.地址, 请求.头, 请求.体)
    内核适配_构造请求(档, 发起, 解析结果)
    内核适配_接收响应(档, 发起)
    如果 (请求.下载名 != "") {
        内核适配_开始下载(档, 请求.地址, 请求.下载名)
    }
    如果 (请求.域 != "") {
        内核适配_Cookie设置(档, "会话", "已接入", 请求.域, "/", 0, 真, 假)
    }
    返回 发起
}

函数 内核适配_摘要(档) {
    返回 适配摘要 {
        名称: 档.名称,
        内存数: 档.内存数,
        图处数: 档.图处数,
        存储数: 档.存储数,
        安全数: 档.安全数,
        网络数: 档.网络数,
        命中数: 档.命中数,
        失败数: 档.失败数,
        健康: 内核适配_健康(档)
    }
}

函数 内核适配_状态串(档) {
    返回 字符串拼接(
        "适配[",
        字符串拼接(
            档.名称,
            字符串拼接(
                "] 图处=",
                字符串拼接(
                    整数转字符串(档.图处数),
                    字符串拼接(
                        " 网络=",
                        字符串拼接(
                            整数转字符串(档.网络数),
                            字符串拼接(
                                " 安全=",
                                整数转字符串(档.安全数)
                            )
                        )
                    )
                )
            )
        )
    )
}

函数 内核适配_健康(档) {
    如果 (!档.初始化完成) { 返回 "待初始化" }
    如果 (档.失败数 > 0) { 返回 "退化" }
    如果 (档.最近风险 != 0 && 档.最近风险 > 80) { 返回 "阻断" }
    返回 "运行"
}

函数 内核适配_自检(档) {
    内核适配_初始化(档)
    定义 地址 = 内核适配_分配(档, 池类型_DOM节点, 256)
    如果 (地址 != 0) {
        内核适配_释放(档, 池类型_DOM节点, 地址, 256)
        档.命中数 = 档.命中数 + 1
        适配总命中 = 适配总命中 + 1
    }
    定义 层 = 内核适配_创建层(档, 0, 0, 640, 360)
    内核适配_填充矩形(档, 层, 0, 0, 640, 360, 0x202020FF, 255)
    内核适配_绘制文字(档, 层, 24, 24, "内核适配自检", 18, 0xFFFFFFFF)
    内核适配_合成帧(档)
    内核适配_缓存写入(档, "nova://health", "text/plain", "ok", 60000)
    内核适配_评估域(档, "nova")
    内核适配_网络探活(档, "127.0.0.1", 80)
    档.健康 = 内核适配_健康(档)
    返回 档.健康
}

函数 内核适配_按名查找(名称) {
    定义 可变 i = 0
    当 (i < 计数(适配账本)) {
        如果 (适配账本[i].名称 == 名称) { 返回 适配账本[i] }
        i = i + 1
    }
    返回 0
}

函数 内核适配_最近请求(档) { 返回 档.最近请求 }
函数 内核适配_最近响应(档) { 返回 档.最近响应 }
函数 内核适配_最近下载(档) { 返回 档.最近下载 }
函数 内核适配_最近风险(档) { 返回 档.最近风险 }
函数 内核适配_账本数() { 返回 计数(适配账本) }

函数 内核适配_全局统计() {
    返回 [
        适配建数,
        适配总执行,
        适配总命中,
        适配总失败
    ]
}

函数 内核适配_示例流程() {
    定义 档 = 内核适配_创建("内核适配", 1280, 720)
    定义 层 = 内核适配_创建层(档, 0, 0, 1280, 720)
    内核适配_圆角矩形(档, 层, 32, 32, 320, 180, 0x0F172AFF, 24, 255)
    内核适配_阴影(档, 层, 32, 32, 320, 180, 0x00000088, 18)
    内核适配_绘制文字(档, 层, 56, 80, "一体化适配", 22, 0xF8FAFCFF)
    内核适配_软件回退(档, 层)
    定义 请求 = 内核适配_建请求("GET", "nova://system/health", [], "", "系统健康.json", "nova")
    内核适配_执行请求(档, 请求)
    内核适配_本地设置(档, "nova", "模式", "一体")
    内核适配_下载进度(档, 档.最近下载)
    内核适配_网络统计(档)
    返回 内核适配_摘要(档)
}

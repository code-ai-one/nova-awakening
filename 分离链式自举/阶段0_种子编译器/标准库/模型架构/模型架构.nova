导入("../基础.nova")


// 模型配置
// 配置: [隐藏维度, 层数, 头数, 词表大小, 最大序列长度, FFN倍数]
函数 模型配置_创建(隐藏, 层数, 头数, 词表, 序列长, FFN倍) { 返回 [隐藏, 层数, 头数, 词表, 序列长, FFN倍]
}

函数 GPT_小配置() { 返回 模型配置_创建(768, 12, 12, 50257, 1024, 4) }
函数 GPT_中配置() { 返回 模型配置_创建(1024, 24, 16, 50257, 1024, 4) }
函数 LLaMA_7B配置() { 返回 模型配置_创建(4096, 32, 32, 32000, 2048, 4) }
函数 BERT_base配置() { 返回 模型配置_创建(768, 12, 12, 30522, 512, 4) }

// 线性层
// 层: [权重(扁平), 偏置, 输入维度, 输出维度]
函数 线性层_创建(输入维度, 输出维度) { 定义 可变 w = []
 定义 可变 b = []
 定义 可变 i = 0
 当 (i < 输入维度 * 输出维度) { 追加(w, ((i * 7 + 13) % 201) - 100)
 i = i + 1 }
 i = 0
 当 (i < 输出维度) { 追加(b, 0)
 i = i + 1 }
 返回 [w, b, 输入维度, 输出维度]
}

函数 线性层_前向(层, 输入) { 定义 可变 输出 = []
 定义 可变 o = 0
 当 (o < 层[3]) { 定义 可变 总和 = 层[1][o]
 定义 可变 i = 0
 当 (i < 层[2]) { 总和 = 总和 + 输入[i] * 层[0][o * 层[2] + i]
 i = i + 1 }
 追加(输出, 总和)
 o = o + 1
 }
 返回 输出
}

函数 线性层_参数数(层) { 返回 层[2] * 层[3] + 层[3] }

// FFN (前馈网络)
// FFN = Linear(d, 4d) → 线性整流 → Linear(4d, d)
函数 FFN_前向(输入, W1, W2) { 定义 隐藏 = 线性层_前向(W1, 输入)
 // 线性整流
 定义 可变 i = 0
 当 (i < 计数(隐藏)) { 如果 (隐藏[i] < 0) { 隐藏[i] = 0 }
 i = i + 1 }
 返回 线性层_前向(W2, 隐藏)
}

// 层归一化
函数 架构_层归一化(输入) { 定义 n = 计数(输入)
 定义 可变 均值 = 0
 定义 可变 i = 0
 当 (i < n) { 均值 = 均值 + 输入[i]
 i = i + 1 }
 均值 = 均值 / n
 定义 可变 方差 = 0
 i = 0
 当 (i < n) { 定义 d = 输入[i] - 均值
 方差 = 方差 + d * d
 i = i + 1 }
 方差 = 方差 / n
 定义 可变 标准差 = 1
 如果 (方差 > 0) { 定义 可变 t = 方差
 当 (t > 1) { 标准差 = 标准差 + 1
 t = t / 4 } }
 如果 (标准差 == 0) { 标准差 = 1 }
 定义 可变 r = []
 i = 0
 当 (i < n) { 追加(r, (输入[i] - 均值) * 100 / 标准差)
 i = i + 1 }
 返回 r
}

// 缩放点积注意力
函数 注意力_单头(Q, K, V, 维度) { 定义 序列 = 计数(Q)
    定义 可变 得分列表 = []
    定义 可变 指数组 = []
 定义 可变 输出 = []
 定义 可变 i = 0
当 (i < 序列) {
 定义 可变 j = 0
 当 (j < 序列) { 定义 可变 点积 = 0
 定义 可变 d = 0
 当 (d < 维度) { 点积 = 点积 + Q[i][d] * K[j][d]
 d = d + 1 }
 追加(得分列表, 点积)
 j = j + 1
 }
 // 归一化指数
 定义 可变 最大得分 = 得分列表[0]
 j = 1
 当 (j < 序列) { 如果 (得分列表[j] > 最大得分) { 最大得分 = 得分列表[j] }
 j = j + 1 }
 定义 可变 合计 = 0
 j = 0
 当 (j < 序列) { 定义 可变 e = 1000 + (得分列表[j] - 最大得分)
 如果 (e < 1) { e = 1 }
 追加(指数组, e)
 合计 = 合计 + e
 j = j + 1
 }
 定义 可变 out_v = []
 定义 可变 d2 = 0
 当 (d2 < 维度) { 定义 可变 w = 0
 j = 0
 当 (j < 序列) { w = w + (指数组[j] * V[j][d2]) / 合计
 j = j + 1 }
 追加(out_v, w)
 d2 = d2 + 1
 }
 追加(输出, out_v)
 i = i + 1
 }
 返回 输出
}

// 残差连接
函数 残差加(a, b) { 返回 拉链(a, b, (x, y) => x + y)
}

// LoRA (Low-Rank Adaptation)
// LoRA: [A矩阵(r×d), B矩阵(d×r), 秩, alpha]
// Dropout模拟
定义 模型_随机态 = 12345
函数 模型_随机() {
 模型_随机态 = 模型_随机态 ^ (模型_随机态 << 13)
 模型_随机态 = 模型_随机态 ^ (模型_随机态 >> 7)
 模型_随机态 = 模型_随机态 ^ (模型_随机态 << 17)
 如果 (模型_随机态 < 0) { 模型_随机态 = 0 - 模型_随机态 }
 返回 模型_随机态
}

// 模型注册表
定义 可变 模型注册_名 = []
定义 可变 模型注册_配置 = []
定义 可变 模型注册_参数量 = []

函数 模型_注册(名哈希, 配置, 参数量) {
 追加(模型注册_名, 名哈希)
 追加(模型注册_配置, 配置)
 追加(模型注册_参数量, 参数量)
}

// 模型参数量查询
函数 模型_参数量(名哈希) { 定义 可变 i = 0
 当 (i < 计数(模型注册_名)) { 如果 (模型注册_名[i] == 名哈希) { 返回 模型注册_参数量[i] }
 i = i + 1
 }
 返回 0
}

函数 模型_查找(名哈希) { 定义 可变 i = 0
 当 (i < 计数(模型注册_名)) { 如果 (模型注册_名[i] == 名哈希) { 返回 i }
 i = i + 1
 }
 返回 -1
}

函数 模型_参数量估算(配置) { 返回 12 * 配置[1] * 配置[0] * 配置[0]
}

函数 模型_总数() { 返回 计数(模型注册_名) }

// Transformer配置
函数 Transformer配置_创建(隐藏维度, 层数, 头数, 词表大小, 最大长度) { 返回 [隐藏维度, 层数, 头数, 词表大小, 最大长度, 隐藏维度 * 4, 隐藏维度 / 头数]
}

函数 Transformer配置_参数量(配置) { 定义 d = 配置[0]
 定义 L = 配置[1]
 定义 V = 配置[3]
 返回 V * d + L * (4 * d * d + 2 * d * 4 * d + 4 * d) + d
}

函数 Transformer配置_内存估算(配置, 批大小, 序列长度) { 定义 参数量 = Transformer配置_参数量(配置)
 定义 激活内存 = 批大小 * 序列长度 * 配置[0] * 配置[1] * 4
 返回 参数量 * 4 + 激活内存
}

// MLP层
函数 MLP_创建(输入维度, 隐藏维度, 输出维度) { 返回 [输入维度, 隐藏维度, 输出维度, 输入维度 * 隐藏维度 + 隐藏维度 * 输出维度]
}

函数 MLP_参数量(层) { 返回 层[3] }

// 残差连接
函数 残差_连接(输入, 子层输出) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(输入)) {
 追加(结果, 输入[i] + 子层输出[i])
 i = i + 1
 }
 返回 结果
}

// 模型架构_层归一化(简化整数版)
函数 模型架构_层归一化(向量) { 定义 n = 计数(向量)
 如果 (n == 0) { 返回 [] }
 定义 可变 均值 = 0
 定义 可变 i = 0
 当 (i < n) { 均值 = 均值 + 向量[i] i = i + 1 }
 均值 = 均值 / n
 定义 可变 方差 = 0
 i = 0
 当 (i < n) { 定义 d = 向量[i] - 均值
 方差 = 方差 + d * d
 i = i + 1
 }
 方差 = 方差 / n
 如果 (方差 == 0) { 方差 = 1 }
 定义 可变 结果 = []
 i = 0
 当 (i < n) {
 追加(结果, (向量[i] - 均值) * 1000 / (方差 + 1))
 i = i + 1
 }
 返回 结果
}

// 模型层堆叠
函数 模型_堆叠层(层列表, 输入) { 定义 可变 当前 = 输入
 定义 可变 i = 0
 当 (i < 计数(层列表)) {
 当前 = 残差_连接(当前, 模型架构_层归一化(当前))
 i = i + 1
 }
 返回 当前
}

// 模型比较
函数 模型_比较参数量(配置A, 配置B) { 定义 pA = Transformer配置_参数量(配置A)
 定义 pB = Transformer配置_参数量(配置B)
 如果 (pA > pB) { 返回 1 }
 如果 (pA < pB) { 返回 -1 }
 返回 0
}

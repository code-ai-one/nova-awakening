结构 样式档 {
    名称,
    来源,
    文本,
    令牌器,
    媒体值,
    最近查询,
    最近容器,
    最近声明,
    最近属性,
    最近意图,
    最近影响,
    最近结果,
    解析数,
    声明数,
    值数,
    颜色数,
    媒查数,
    容器数,
    命中数,
    漂移数,
    健康,
}

结构 样式节点 {
    属性名,
    属性值,
    属性ID,
    意图,
    影响,
    命中缓存,
}

结构 样式摘要 {
    名称,
    来源,
    解析数,
    声明数,
    值数,
    颜色数,
    媒查数,
    容器数,
    命中数,
    健康,
    暗色,
    减动,
}

定义 可变 样式账本 = []
定义 可变 样式建数 = 0
定义 可变 样式总解析 = 0
定义 可变 样式总声明 = 0
定义 可变 样式总颜色 = 0
定义 可变 样式总媒查 = 0
定义 可变 样式总容器 = 0
定义 可变 样式总命中 = 0

函数 样式解析_布串(值) {
    如果 (值) { 返回 "true" }
    返回 "false"
}

函数 样式解析_取数(值) {
    如果 (值 == 空) { 返回 0 }
    返回 值
}

函数 样式解析_建档(名称, 来源) {
    定义 档 = 堆_分配(样式档)
    档.名称 = 名称
    档.来源 = 来源
    档.文本 = ""
    档.令牌器 = 0
    档.媒体值 = 0
    档.最近查询 = ""
    档.最近容器 = 0
    档.最近声明 = 0
    档.最近属性 = ""
    档.最近意图 = ""
    档.最近影响 = ""
    档.最近结果 = 0
    档.解析数 = 0
    档.声明数 = 0
    档.值数 = 0
    档.颜色数 = 0
    档.媒查数 = 0
    档.容器数 = 0
    档.命中数 = 0
    档.漂移数 = 0
    档.健康 = "未初始化"
    返回 档
}

函数 样式解析_登记(档) {
    追加(样式账本, 档)
    样式建数 = 样式建数 + 1
    返回 档
}

函数 样式解析_创建(名称, 来源) {
    定义 档 = 样式解析_建档(名称, 来源)
    样式解析_初始化(档)
    返回 样式解析_登记(档)
}

函数 样式解析_初始化(档) {
    AI样式_初始化缓存()
    档.媒体值 = 媒体Values_获取()
    档.健康 = "运行"
    返回 档
}

函数 样式解析_重置(档) {
    档.文本 = ""
    档.令牌器 = 0
    档.最近查询 = ""
    档.最近容器 = 0
    档.最近声明 = 0
    档.最近属性 = ""
    档.最近意图 = ""
    档.最近影响 = ""
    档.最近结果 = 0
    档.解析数 = 0
    档.声明数 = 0
    档.值数 = 0
    档.颜色数 = 0
    档.媒查数 = 0
    档.容器数 = 0
    档.命中数 = 0
    档.漂移数 = 0
    档.健康 = "运行"
    AI样式_清空缓存()
    返回 档
}

函数 样式解析_加载文本(档, 来源, 文本) {
    档.来源 = 来源
    档.文本 = 文本
    档.令牌器 = CSS令牌izer_创建(文本)
    档.解析数 = 档.解析数 + 1
    样式总解析 = 样式总解析 + 1
    返回 档.令牌器
}

函数 样式解析_载入样表(档, 来源, 文本) {
    定义 令牌器 = 样式解析_加载文本(档, 来源, 文本)
    档.最近结果 = 令牌器
    返回 令牌器
}

函数 样式解析_解析值(档, 文本, 位置) {
    定义 长度 = 字符串_长度(文本)
    定义 结果 = CSS解析_值(文本, 长度, 位置)
    档.值数 = 档.值数 + 1
    样式总解析 = 样式总解析 + 1
    档.最近结果 = 结果
    返回 结果
}

函数 样式解析_解析声明(档, 令牌器, 属性令牌) {
    定义 声明 = CSSParser_解析声明(令牌器, 属性令牌)
    档.声明数 = 档.声明数 + 1
    样式总声明 = 样式总声明 + 1
    档.最近声明 = 声明
    返回 声明
}

函数 样式解析_解析属性ID(属性名) {
    返回 CSSParser_属性名转ID(属性名, 字符串_长度(属性名))
}

函数 样式解析_声明节点(属性名, 属性值) {
    定义 节点 = 堆_分配(样式节点)
    节点.属性名 = 属性名
    节点.属性值 = 属性值
    节点.属性ID = 样式解析_解析属性ID(属性名)
    节点.意图 = AI样式_推断意图(节点.属性ID, 属性值)
    节点.影响 = AI样式_分析影响(节点.属性ID)
    节点.命中缓存 = 假
    返回 节点
}

函数 样式解析_解析属性(档, 属性名, 属性值) {
    定义 节点 = 样式解析_声明节点(属性名, 属性值)
    档.声明数 = 档.声明数 + 1
    档.最近属性 = 属性名
    档.最近意图 = 节点.意图
    档.最近影响 = 节点.影响

    如果 (字符串_相等(属性名, "transform")) {
        档.最近结果 = Transform_解析(属性值)
    } 否则 如果 (字符串_相等(属性名, "scroll-snap-type")) {
        档.最近结果 = ScrollSnap_解析类型(属性值)
    } 否则 如果 (字符串_相等(属性名, "scroll-snap-align")) {
        档.最近结果 = ScrollSnap_解析对齐(属性值)
    } 否则 如果 (字符串_相等(属性名, "will-change")) {
        档.最近结果 = NWCO_解析will_change(属性值)
    } 否则 {
        档.最近结果 = 节点
    }

    样式总声明 = 样式总声明 + 1
    返回 节点
}

函数 样式解析_解析颜色函数(档, 文本) {
    定义 长度 = 字符串_长度(文本)
    定义 结果 = CSS解析_rgb函数(文本, 长度, 0)
    如果 (结果 == 0) {
        结果 = CSS解析_hsl函数(文本, 长度, 0)
    }
    档.颜色数 = 档.颜色数 + 1
    样式总颜色 = 样式总颜色 + 1
    档.最近结果 = 结果
    返回 结果
}

函数 样式解析_解析颜色值(档, 文本) {
    定义 长度 = 字符串_长度(文本)
    定义 结果 = CSS解析_十六进制颜色(文本, 长度, 0)
    如果 (结果 == 0) {
        结果 = CSS_解析颜色十六进制(文本, 0)
    }
    档.颜色数 = 档.颜色数 + 1
    样式总颜色 = 样式总颜色 + 1
    档.最近结果 = 结果
    返回 结果
}

函数 样式解析_解析命名颜色(档, 名称) {
    定义 长度 = 字符串_长度(名称)
    定义 结果 = CSS解析_命名颜色(名称, 长度)
    如果 (结果 == 0) {
        结果 = CSSParser_命名颜色(名称, 长度)
    }
    如果 (结果 == 0) {
        结果 = CSS_命名颜色(名称)
    }
    档.颜色数 = 档.颜色数 + 1
    样式总颜色 = 样式总颜色 + 1
    档.最近结果 = 结果
    返回 结果
}

函数 样式解析_解析标识(档, 文本) {
    定义 长度 = 字符串_长度(文本)
    定义 结果 = CSS解析_标识符或函数(文本, 长度, 0)
    档.值数 = 档.值数 + 1
    档.最近结果 = 结果
    返回 结果
}

函数 样式解析_解析单位(档, 单位名) {
    定义 长度 = 字符串_长度(单位名)
    定义 结果 = CSSParser_解析单位(单位名, 长度)
    如果 (结果 == 0) {
        结果 = CSS_解析单位(单位名)
    }
    档.最近结果 = 结果
    返回 结果
}

函数 样式解析_关键字(档, 名称) {
    定义 长度 = 字符串_长度(名称)
    定义 结果 = CSSParser_关键字转ID(名称, 长度)
    档.最近结果 = 结果
    返回 结果
}

函数 样式解析_写缓存(档, 规则哈希, 属性名, 解析值) {
    定义 属性ID = 样式解析_解析属性ID(属性名)
    AI样式_写缓存(规则哈希, 属性ID, 解析值)
    档.最近属性 = 属性名
    返回 解析值
}

函数 样式解析_查缓存(档, 规则哈希, 属性名) {
    定义 属性ID = 样式解析_解析属性ID(属性名)
    定义 命中 = AI样式_查缓存(规则哈希, 属性ID)
    如果 (命中 != 0 && 命中 != 空) {
        档.命中数 = 档.命中数 + 1
        样式总命中 = 样式总命中 + 1
    }
    档.最近属性 = 属性名
    档.最近结果 = 命中
    返回 命中
}

函数 样式解析_失效规则(规则哈希) {
    AI样式_无效化_规则(规则哈希)
}

函数 样式解析_失效属性(属性名) {
    定义 属性ID = 样式解析_解析属性ID(属性名)
    AI样式_无效化_属性(属性ID)
}

函数 样式解析_缓存统计(档) {
    定义 统计 = AI样式_缓存统计()
    档.最近结果 = 统计
    返回 统计
}

函数 样式解析_缓存命中率(档) {
    定义 命中率 = AI样式_缓存命中率()
    档.最近结果 = 命中率
    返回 命中率
}

函数 样式解析_预热缓存(档, 常用规则列表) {
    AI样式_缓存预热(常用规则列表)
    档.最近结果 = 常用规则列表
}

函数 样式解析_推断意图(档, 属性名, 值字符串) {
    定义 属性ID = 样式解析_解析属性ID(属性名)
    定义 意图 = AI样式_推断意图(属性ID, 值字符串)
    档.最近属性 = 属性名
    档.最近意图 = 意图
    返回 意图
}

函数 样式解析_分析影响(档, 属性名) {
    定义 属性ID = 样式解析_解析属性ID(属性名)
    定义 影响 = AI样式_分析影响(属性ID)
    档.最近属性 = 属性名
    档.最近影响 = 影响
    返回 影响
}

函数 样式解析_处理变化(档, 元素, 属性名, 新值) {
    定义 属性ID = 样式解析_解析属性ID(属性名)
    AI样式_处理变化(元素, 属性ID, 新值)
    档.最近属性 = 属性名
    档.最近结果 = 新值
}

函数 样式解析_解析媒体(档, 查询字符串) {
    定义 结果 = 媒体查询_解析(查询字符串)
    档.最近查询 = 查询字符串
    档.媒查数 = 档.媒查数 + 1
    样式总媒查 = 样式总媒查 + 1
    档.最近结果 = 结果
    返回 结果
}

函数 样式解析_匹配媒体(档, 查询字符串) {
    定义 命中 = Window_match媒体(查询字符串)
    档.最近查询 = 查询字符串
    档.媒查数 = 档.媒查数 + 1
    样式总媒查 = 样式总媒查 + 1
    档.最近结果 = 命中
    返回 命中
}

函数 样式解析_更新视口(档, 宽, 高) {
    媒体Values_从视口更新(宽, 高)
    媒体查询_更新视口(宽, 高)
    档.媒体值 = 媒体Values_获取()
    档.最近结果 = 档.媒体值
    返回 档.媒体值
}

函数 样式解析_设置配色(档, 暗色模式) {
    媒体Values_设置配色方案(暗色模式)
    档.媒体值 = 媒体Values_获取()
    档.最近结果 = 档.媒体值
    返回 档.媒体值
}

函数 样式解析_设置动效(档, 减弱) {
    媒体Values_设置动效偏好(减弱)
    档.媒体值 = 媒体Values_获取()
    档.最近结果 = 档.媒体值
    返回 档.媒体值
}

函数 样式解析_注册容器(档, 元素, 名称, 类型) {
    定义 结果 = ContainerQuery_注册容器(元素, 名称, 类型)
    档.最近容器 = 结果
    档.容器数 = 档.容器数 + 1
    样式总容器 = 样式总容器 + 1
    返回 结果
}

函数 样式解析_更新容器(档, 元素, 内联, 块) {
    ContainerQuery_更新尺寸(元素, 内联, 块)
    档.容器数 = 档.容器数 + 1
    样式总容器 = 样式总容器 + 1
    档.最近结果 = 元素
    返回 元素
}

函数 样式解析_求值容器(档, 查询, 元素) {
    定义 结果 = ContainerQuery_求值(查询, 元素)
    档.最近容器 = 查询
    档.最近结果 = 结果
    返回 结果
}

函数 样式解析_媒体摘要(档) {
    定义 值 = 媒体Values_获取()
    返回 [
        媒体环境_获取视口宽(值),
        媒体环境_获取视口高(值),
        样式解析_布串(媒体环境_是暗色模式(值)),
        媒体环境_设备像素比(值)
    ]
}

函数 样式解析_统一解析(档, 属性名, 属性值, 查询字符串) {
    定义 节点 = 样式解析_解析属性(档, 属性名, 属性值)
    定义 解析值 = 样式解析_解析值(档, 属性值, 0)
    定义 命中媒体 = 样式解析_匹配媒体(档, 查询字符串)
    节点.命中缓存 = 假
    如果 (样式解析_查缓存(档, 属性名, 属性名) != 0) {
        节点.命中缓存 = 真
    } 否则 {
        样式解析_写缓存(档, 属性名, 属性名, 解析值)
    }
    档.最近结果 = [节点, 解析值, 命中媒体]
    返回 档.最近结果
}

函数 样式解析_摘要(档) {
    定义 值 = 媒体Values_获取()
    返回 样式摘要 {
        名称: 档.名称,
        来源: 档.来源,
        解析数: 档.解析数,
        声明数: 档.声明数,
        值数: 档.值数,
        颜色数: 档.颜色数,
        媒查数: 档.媒查数,
        容器数: 档.容器数,
        命中数: 档.命中数,
        健康: 档.健康,
        暗色: 媒体环境_是暗色模式(值),
        减动: 0
    }
}

函数 样式解析_状态串(档) {
    定义 摘 = 样式解析_摘要(档)
    返回 字符串拼接(
        "样式[",
        字符串拼接(
            摘.名称,
            字符串拼接(
                "] 声明=",
                字符串拼接(
                    整数转字符串(摘.声明数),
                    字符串拼接(
                        " 媒体=",
                        字符串拼接(
                            整数转字符串(摘.媒查数),
                            字符串拼接(
                                " 容器=",
                                整数转字符串(摘.容器数)
                            )
                        )
                    )
                )
            )
        )
    )
}

函数 样式解析_健康(档) {
    如果 (档 == 0 || 档 == 空) { 返回 "缺失" }
    如果 (档.令牌器 == 0) { 返回 "待装载" }
    如果 (档.漂移数 > 0) { 返回 "漂移" }
    如果 (样式解析_缓存命中率(档) < 0) { 返回 "异常" }
    返回 "运行"
}

函数 样式解析_自检(档) {
    样式解析_初始化(档)
    样式解析_加载文本(档, "自检", "body { color: #fff; }")
    样式解析_解析属性(档, "color", "#fff")
    样式解析_解析颜色值(档, "#fff")
    样式解析_解析颜色函数(档, "rgb(255,255,255)")
    样式解析_解析命名颜色(档, "white")
    样式解析_解析单位(档, "px")
    样式解析_更新视口(档, 1280, 720)
    样式解析_匹配媒体(档, "(min-width: 600px)")
    档.健康 = 样式解析_健康(档)
    返回 档.健康
}

函数 样式解析_全局统计() {
    返回 [
        样式建数,
        样式总解析,
        样式总声明,
        样式总颜色,
        样式总媒查,
        样式总容器,
        样式总命中
    ]
}

函数 样式解析_按名查找(名称) {
    定义 可变 i = 0
    当 (i < 计数(样式账本)) {
        如果 (样式账本[i].名称 == 名称) { 返回 样式账本[i] }
        i = i + 1
    }
    返回 0
}

函数 样式解析_最近结果(档) { 返回 档.最近结果 }
函数 样式解析_最近意图(档) { 返回 档.最近意图 }
函数 样式解析_最近影响(档) { 返回 档.最近影响 }
函数 样式解析_最近属性(档) { 返回 档.最近属性 }
函数 样式解析_最近查询(档) { 返回 档.最近查询 }
函数 样式解析_媒体值(档) { 返回 档.媒体值 }
函数 样式解析_账本数() { 返回 计数(样式账本) }

函数 样式解析_示例流程() {
    定义 档 = 样式解析_创建("样式解析", "感知")
    样式解析_加载文本(档, "示例", "body { color: #222; background: rgb(255,255,255); }")
    样式解析_解析属性(档, "color", "#222")
    样式解析_解析颜色值(档, "#222")
    样式解析_解析颜色函数(档, "rgb(255,255,255)")
    样式解析_设置配色(档, 假)
    样式解析_设置动效(档, 假)
    样式解析_更新视口(档, 1440, 900)
    样式解析_匹配媒体(档, "(min-width: 1024px)")
    样式解析_注册容器(档, "根", "主容器", CONTAINER_TYPE_SIZE)
    样式解析_更新容器(档, "根", 1440, 900)
    样式解析_推断意图(档, "background-color", "#fff")
    样式解析_分析影响(档, "background-color")
    样式解析_统一解析(档, "width", "100vw", "(orientation: landscape)")
    返回 样式解析_摘要(档)
}

// merge source: 沙盒批次/批六/待厚/感知/标记令牌甲.nova

函数 HTML令牌izer_处理_属性名(tk, 令牌, c) {
    如果 (c == 0x09 || c == 0x0A || c == 0x0C || c == 0x20) {
        tk.状态 = 状态_属性名后
    }
    否则 如果 (c == 0x2F) {     // '/'
        HTML令牌izer_提交属性(tk, 令牌)
        tk.状态 = 状态_自闭合开始标签
    }
    否则 如果 (c == 0x3E) {     // '>'
        HTML令牌izer_提交属性(tk, 令牌)
        HTML令牌izer_完成标签名(令牌)
        如果 (令牌.类型 == 令牌类型_开始标签) {
            HTML令牌izer_记录开始标签(tk, 令牌)
        }
        tk.状态 = 状态_数据
    }
    否则 如果 (c == 0x3D) {     // '='
        tk.状态 = 状态_属性值前
    }
    否则 {
        HTML令牌izer_追加属性名字符(tk, HTML令牌izer_转小写(c))
    }
}

函数 HTML令牌izer_处理_属性名后(tk, 令牌, c) {
    如果 (c == 0x09 || c == 0x0A || c == 0x0C || c == 0x20) { 返回 }
    如果 (c == 0x3D) {          // '='
        tk.状态 = 状态_属性值前
    }
    否则 如果 (c == 0x2F) {
        HTML令牌izer_提交属性(tk, 令牌)
        tk.状态 = 状态_自闭合开始标签
    }
    否则 如果 (c == 0x3E) {
        HTML令牌izer_提交属性(tk, 令牌)
        HTML令牌izer_完成标签名(令牌)
        如果 (令牌.类型 == 令牌类型_开始标签) { HTML令牌izer_记录开始标签(tk, 令牌) }
        tk.状态 = 状态_数据
    }
    否则 {
        // 值为空的属性, 提交后开始新属性
        HTML令牌izer_提交属性(tk, 令牌)
        tk.当前属性名长度 = 0
        tk.当前属性值长度 = 0
        HTML令牌izer_追加属性名字符(tk, HTML令牌izer_转小写(c))
        tk.状态 = 状态_属性名
    }
}

函数 HTML令牌izer_处理_属性值前(tk, 令牌, c) {
    如果 (c == 0x09 || c == 0x0A || c == 0x0C || c == 0x20) { 返回 }
    如果 (c == 0x22) {          // '"'
        tk.状态 = 状态_属性值_双引号
    }
    否则 如果 (c == 0x27) {     // '\''
        tk.状态 = 状态_属性值_单引号
    }
    否则 如果 (c == 0x3E) {     // '>'
        HTML令牌izer_提交属性(tk, 令牌)
        HTML令牌izer_完成标签名(令牌)
        如果 (令牌.类型 == 令牌类型_开始标签) { HTML令牌izer_记录开始标签(tk, 令牌) }
        tk.状态 = 状态_数据
    }
    否则 {
        HTML令牌izer_追加属性值字符(tk, c)
        tk.状态 = 状态_属性值_无引号
    }
}

函数 HTML令牌izer_处理_属性值双引号(tk, 令牌, c) {
    如果 (c == 0x22) {          // '"'  结束
        HTML令牌izer_提交属性(tk, 令牌)
        tk.状态 = 状态_属性值后
    }
    否则 如果 (c == 0x26) {     // '&'  字符引用
        tk.返回状态 = 状态_属性值_双引号
        tk.状态 = 状态_字符引用
    }
    否则 {
        HTML令牌izer_追加属性值字符(tk, c)
    }
}

函数 HTML令牌izer_处理_属性值单引号(tk, 令牌, c) {
    如果 (c == 0x27) {          // '\''  结束
        HTML令牌izer_提交属性(tk, 令牌)
        tk.状态 = 状态_属性值后
    }
    否则 如果 (c == 0x26) {
        tk.返回状态 = 状态_属性值_单引号
        tk.状态 = 状态_字符引用
    }
    否则 {
        HTML令牌izer_追加属性值字符(tk, c)
    }
}

// merge source: 沙盒批次/批六/待厚/感知/标记令牌器.nova
// HTML令牌izer结构 

结构 HTML令牌izer {
 // 状态机
 状态,    // u32 当前状态
 返回状态,    // u32 字符引用的返回状态

 // 输入流
 输入,    // u64 输入HTML字符串指针
 输入长度,
 位置,    // u32 当前读取位置

 // 当前正在构建的令牌
 当前令牌,    // u64 HTML令牌*

 // 临时缓冲区
 临时缓冲,    // u64 临时字符缓冲区
 临时缓冲长度,
 临时缓冲容量,
 // 当前正在构建的属性
 当前属性名,
 当前属性名长度,
 当前属性值,
 当前属性值长度,
 // 最后一个开始标签名(用于RCDATA/RAWTEXT结束标签匹配)
 最后开始标签,
 最后开始标签长度,
 // 字符引用解析
 字符引用码点,
 // 统计
 总令牌数,
 行号,
 列号,
}

// §1 令牌izer创建/初始化

函数 HTML令牌izer_创建() {
 定义 tk = 堆_分配(HTML令牌izer)
 tk.状态 = 状态_数据
 tk.返回状态 = 状态_数据
 tk.输入 = 0
 tk.输入长度 = 0
 tk.位置 = 0
 tk.当前令牌 = 0
 tk.临时缓冲 = 堆_分配_数组(1024)
 tk.临时缓冲长度 = 0
 tk.临时缓冲容量 = 1024
 tk.当前属性名 = 堆_分配_数组(256)
 tk.当前属性名长度 = 0
 tk.当前属性值 = 堆_分配_数组(4096)
 tk.当前属性值长度 = 0
 tk.最后开始标签 = 堆_分配_数组(64)
 tk.最后开始标签长度 = 0
 tk.字符引用码点 = 0
 tk.总令牌数 = 0
 tk.行号 = 1
 tk.列号 = 1
 返回 tk
}

函数 HTML令牌izer_设置输入(tk, html字符串) {
 tk.输入 = html字符串
 tk.输入长度 = 字符串_长度(html字符串)
 tk.位置 = 0
 tk.行号 = 1
 tk.列号 = 1
}

函数 HTML令牌_创建() {
 定义 令牌 = 堆_分配(HTML令牌)
 令牌.类型 = 令牌类型_未初始化
 令牌.标签名 = 堆_分配_数组(128)
 令牌.标签名长度 = 0
 令牌.自闭合 = 假
 令牌.属性列表 = 堆_分配_数组(16 * 40) // 16个属性空间
 令牌.属性数量 = 0
 令牌.属性容量 = 16
 令牌.DOCTYPE名称 = 0
 令牌.DOCTYPE公共ID = 0
 令牌.DOCTYPE系统ID = 0
 令牌.强制怪异模式 = 假
 令牌.数据 = 堆_分配_数组(4096)
 令牌.数据长度 = 0
 返回 令牌
}

函数 HTML令牌_重置(令牌) {
 令牌.类型 = 令牌类型_未初始化
 令牌.标签名长度 = 0
 令牌.自闭合 = 假
 令牌.属性数量 = 0
 令牌.数据长度 = 0
 令牌.强制怪异模式 = 假
}

// merge source: 沙盒批次/批六/待厚/感知/文档令牌列.nova
// §7 DOM令牌List (classList底层实现)

结构 DOM令牌List {
    元素,    // u64 元素*
    属性名,    // u64 "class"
    令牌,    // u64 字符串数组
    令牌数量,
    令牌容量,
}

函数 DOM令牌List_创建(元素, 属性名) {
    定义 tl = 堆_分配(DOM令牌List)
    tl.元素 = 元素
    tl.属性名 = 字符串_复制(属性名)
    tl.令牌容量 = 16
    tl.令牌 = 堆_分配_数组(tl.令牌容量 * 8)
    tl.令牌数量 = 0
    // 从属性值解析
    DOM令牌List_从属性同步(tl)
    返回 tl
}

函数 DOM令牌List_从属性同步(tl) {
    定义 值 = 元素_getAttribute(tl.元素, tl.属性名)
    如果 (值 == 0) { tl.令牌数量 = 0; 返回 }
    // 分割空格
    tl.令牌数量 = 0
    定义 长度 = 字符串_长度(值)
    定义 可变 pos = 0
    当 (pos < 长度) {
        当 (pos < 长度 && 内存_读8(值 + pos) == 0x20) { pos = pos + 1 }
        定义 起始 = pos
        当 (pos < 长度 && 内存_读8(值 + pos) != 0x20) { pos = pos + 1 }
        如果 (pos > 起始 && tl.令牌数量 < tl.令牌容量) {
            内存_写64(tl.令牌 + tl.令牌数量 * 8, 字符串_复制_N(值 + 起始, pos - 起始))
            tl.令牌数量 = tl.令牌数量 + 1
        }
    }
}

函数 DOM令牌List_同步到属性(tl) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < tl.令牌数量) {
        如果 (i > 0) { 结果 = 字符串_连接(结果, " ") }
        结果 = 字符串_连接(结果, 内存_读64(tl.令牌 + i * 8))
        i = i + 1
    }
    元素_setAttribute(tl.元素, tl.属性名, 结果)
}

函数 DOM令牌List_contains(tl, 令牌) {
    定义 可变 i = 0
    当 (i < tl.令牌数量) {
        如果 (字符串_相等(内存_读64(tl.令牌 + i * 8), 令牌)) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 DOM令牌List_add(tl, 令牌) {
    如果 (DOM令牌List_contains(tl, 令牌)) { 返回 }
    如果 (tl.令牌数量 >= tl.令牌容量) { 返回 }
    内存_写64(tl.令牌 + tl.令牌数量 * 8, 字符串_复制(令牌))
    tl.令牌数量 = tl.令牌数量 + 1
    DOM令牌List_同步到属性(tl)
}

函数 DOM令牌List_remove(tl, 令牌) {
    定义 可变 i = 0
    当 (i < tl.令牌数量) {
        如果 (字符串_相等(内存_读64(tl.令牌 + i * 8), 令牌)) {
            // 移除: 后面的前移
            定义 可变 j = i
            当 (j < tl.令牌数量 - 1) {
                内存_写64(tl.令牌 + j * 8, 内存_读64(tl.令牌 + (j + 1) * 8))
                j = j + 1
            }
            tl.令牌数量 = tl.令牌数量 - 1
            DOM令牌List_同步到属性(tl)
            返回
        }
        i = i + 1
    }
}

函数 DOM令牌List_toggle(tl, 令牌) {
    如果 (DOM令牌List_contains(tl, 令牌)) {
        DOM令牌List_remove(tl, 令牌)
        返回 假
    }
    DOM令牌List_add(tl, 令牌)
    返回 真
}

函数 DOM令牌List_replace(tl, 旧令牌, 新令牌) {
    定义 可变 i = 0
    当 (i < tl.令牌数量) {
        如果 (字符串_相等(内存_读64(tl.令牌 + i * 8), 旧令牌)) {
            内存_写64(tl.令牌 + i * 8, 字符串_复制(新令牌))
            DOM令牌List_同步到属性(tl)
            返回 真
        }
        i = i + 1
    }
    返回 假
}

// merge source: 沙盒批次/批三/待厚/感知/地址查询参.nova

定义 查询参数_最大数量 = 128

结构 URLSearchParams {
    键,
    值,
    数量,
}

结构 查询参数统计 {
    解析次数,
    查询次数,
    设置次数,
    删除次数,
    序列化次数,
    排序次数,
    总参数数,
}

定义 可变 全局_查询参数统计 = 空

函数 查询参数统计_初始化() {
    如果 (全局_查询参数统计 == 空) {
        全局_查询参数统计 = 查询参数统计 {}
        全局_查询参数统计.解析次数 = 0
        全局_查询参数统计.查询次数 = 0
        全局_查询参数统计.设置次数 = 0
        全局_查询参数统计.删除次数 = 0
        全局_查询参数统计.序列化次数 = 0
        全局_查询参数统计.排序次数 = 0
        全局_查询参数统计.总参数数 = 0
    }
}

函数 URLSearchParams_创建() {
    定义 params = 堆_分配(URLSearchParams)
    params.键 = []
    params.值 = []
    params.数量 = 0
    返回 params
}

函数 URLSearchParams_解析(查询字符串) {
    查询参数统计_初始化()
    全局_查询参数统计.解析次数 = 全局_查询参数统计.解析次数 + 1

    定义 params = URLSearchParams_创建()
    如果 (查询字符串 == 0) { 返回 params }

    定义 可变 输入 = 查询字符串
    如果 (字节长度(输入) > 0 && 字节取(输入, 0) == 63) {
        输入 = 字符串_截取(输入, 1, 字节长度(输入))
    }

    定义 长度 = 字节长度(输入)
    定义 可变 i = 0
    当 (i < 长度 && params.数量 < 查询参数_最大数量) {
        定义 键开始 = i
        当 (i < 长度 && 字节取(输入, i) != 61 && 字节取(输入, i) != 38) { i = i + 1 }
        定义 键 = URL_百分比解码(字符串_截取(输入, 键开始, i))

        定义 可变 值 = ""
        如果 (i < 长度 && 字节取(输入, i) == 61) {
            i = i + 1
            定义 值开始 = i
            当 (i < 长度 && 字节取(输入, i) != 38) { i = i + 1 }
            值 = URL_百分比解码(字符串_截取(输入, 值开始, i))
        }

        如果 (字节长度(键) > 0) {
            追加(params.键, 键)
            追加(params.值, 值)
            params.数量 = params.数量 + 1
            全局_查询参数统计.总参数数 = 全局_查询参数统计.总参数数 + 1
        }

        如果 (i < 长度 && 字节取(输入, i) == 38) { i = i + 1 }
    }
    返回 params
}

函数 URLSearchParams_get(params, 键) {
    查询参数统计_初始化()
    全局_查询参数统计.查询次数 = 全局_查询参数统计.查询次数 + 1
    如果 (params == 0 || 键 == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < params.数量) {
        如果 (字符串_相等(params.键[i], 键)) { 返回 params.值[i] }
        i = i + 1
    }
    返回 0
}

函数 URLSearchParams_getAll(params, 键) {
    查询参数统计_初始化()
    全局_查询参数统计.查询次数 = 全局_查询参数统计.查询次数 + 1
    定义 可变 结果 = []
    如果 (params == 0 || 键 == 0) { 返回 结果 }
    定义 可变 i = 0
    当 (i < params.数量) {
        如果 (字符串_相等(params.键[i], 键)) {
            追加(结果, params.值[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 URLSearchParams_has(params, 键) {
    如果 (params == 0 || 键 == 0) { 返回 假 }
    定义 可变 i = 0
    当 (i < params.数量) {
        如果 (字符串_相等(params.键[i], 键)) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 URLSearchParams_has值(params, 键, 值) {
    如果 (params == 0) { 返回 假 }
    定义 可变 i = 0
    当 (i < params.数量) {
        如果 (字符串_相等(params.键[i], 键) && 字符串_相等(params.值[i], 值)) {
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 URLSearchParams_set(params, 键, 值) {
    查询参数统计_初始化()
    全局_查询参数统计.设置次数 = 全局_查询参数统计.设置次数 + 1
    如果 (params == 0) { 返回 }

    定义 可变 已找到 = 假
    定义 可变 i = 0
    当 (i < params.数量) {
        如果 (字符串_相等(params.键[i], 键)) {
            如果 (!已找到) {
                params.值[i] = 值
                已找到 = 真
                i = i + 1
            } 否则 {
                URLSearchParams_移除索引(params, i)
            }
        } 否则 {
            i = i + 1
        }
    }

    如果 (!已找到 && params.数量 < 查询参数_最大数量) {
        追加(params.键, 键)
        追加(params.值, 值)
        params.数量 = params.数量 + 1
    }
}

函数 URLSearchParams_append(params, 键, 值) {
    如果 (params == 0 || params.数量 >= 查询参数_最大数量) { 返回 }
    追加(params.键, 键)
    追加(params.值, 值)
    params.数量 = params.数量 + 1
}

函数 URLSearchParams_delete(params, 键) {
    查询参数统计_初始化()
    全局_查询参数统计.删除次数 = 全局_查询参数统计.删除次数 + 1
    如果 (params == 0) { 返回 }

    定义 可变 i = 0
    当 (i < params.数量) {
        如果 (字符串_相等(params.键[i], 键)) {
            URLSearchParams_移除索引(params, i)
        } 否则 {
            i = i + 1
        }
    }
}

函数 URLSearchParams_delete值(params, 键, 值) {
    如果 (params == 0) { 返回 }
    定义 可变 i = 0
    当 (i < params.数量) {
        如果 (字符串_相等(params.键[i], 键) && 字符串_相等(params.值[i], 值)) {
            URLSearchParams_移除索引(params, i)
        } 否则 {
            i = i + 1
        }
    }
}

函数 URLSearchParams_移除索引(params, 索引) {
    如果 (索引 < 0 || 索引 >= params.数量) { 返回 }
    定义 可变 j = 索引
    当 (j < params.数量 - 1) {
        params.键[j] = params.键[j + 1]
        params.值[j] = params.值[j + 1]
        j = j + 1
    }
    params.数量 = params.数量 - 1
}

函数 URLSearchParams_sort(params) {
    查询参数统计_初始化()
    全局_查询参数统计.排序次数 = 全局_查询参数统计.排序次数 + 1
    如果 (params == 0 || params.数量 <= 1) { 返回 }

    定义 可变 i = 0
    当 (i < params.数量 - 1) {
        定义 可变 j = 0
        当 (j < params.数量 - 1 - i) {
            如果 (字符串_比较(params.键[j], params.键[j + 1]) > 0) {
                定义 临时键 = params.键[j]
                定义 临时值 = params.值[j]
                params.键[j] = params.键[j + 1]
                params.值[j] = params.值[j + 1]
                params.键[j + 1] = 临时键
                params.值[j + 1] = 临时值
            }
            j = j + 1
        }
        i = i + 1
    }
}

函数 URLSearchParams_序列化(params) {
    查询参数统计_初始化()
    全局_查询参数统计.序列化次数 = 全局_查询参数统计.序列化次数 + 1
    如果 (params == 0 || params.数量 == 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < params.数量) {
        如果 (i > 0) { 结果 = 字符串拼接(结果, "&") }
        结果 = 字符串拼接(结果, URL_百分比编码(params.键[i], 0))
        结果 = 字符串拼接(结果, "=")
        结果 = 字符串拼接(结果, URL_百分比编码(params.值[i], 0))
        i = i + 1
    }
    返回 结果
}

函数 URLSearchParams_size(params) {
    如果 (params == 0) { 返回 0 }
    返回 params.数量
}

函数 URLSearchParams_keys(params) {
    定义 可变 结果 = []
    如果 (params == 0) { 返回 结果 }
    定义 可变 i = 0
    当 (i < params.数量) {
        追加(结果, params.键[i])
        i = i + 1
    }
    返回 结果
}

函数 URLSearchParams_values(params) {
    定义 可变 结果 = []
    如果 (params == 0) { 返回 结果 }
    定义 可变 i = 0
    当 (i < params.数量) {
        追加(结果, params.值[i])
        i = i + 1
    }
    返回 结果
}

函数 URLSearchParams_entries(params) {
    定义 可变 结果 = []
    如果 (params == 0) { 返回 结果 }
    定义 可变 i = 0
    当 (i < params.数量) {
        追加(结果, [params.键[i], params.值[i]])
        i = i + 1
    }
    返回 结果
}

函数 URLSearchParams_forEach(params, 回调) {
    如果 (params == 0 || 回调 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < params.数量) {
        调用回调(回调, params.值[i], params.键[i], params)
        i = i + 1
    }
}

函数 URLSearchParams_合并(目标, 源) {
    如果 (目标 == 0 || 源 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 源.数量 && 目标.数量 < 查询参数_最大数量) {
        追加(目标.键, 源.键[i])
        追加(目标.值, 源.值[i])
        目标.数量 = 目标.数量 + 1
        i = i + 1
    }
}

函数 URLSearchParams_克隆(params) {
    定义 新 = URLSearchParams_创建()
    如果 (params == 0) { 返回 新 }
    定义 可变 i = 0
    当 (i < params.数量) {
        追加(新.键, params.键[i])
        追加(新.值, params.值[i])
        i = i + 1
    }
    新.数量 = params.数量
    返回 新
}

函数 查询参数_打印统计() {
    查询参数统计_初始化()
    打印行("=== 查询参数统计 ===")
    打印行("解析: " + 整数转字符串(全局_查询参数统计.解析次数))
    打印行("查询: " + 整数转字符串(全局_查询参数统计.查询次数))
    打印行("设置: " + 整数转字符串(全局_查询参数统计.设置次数))
    打印行("删除: " + 整数转字符串(全局_查询参数统计.删除次数))
    打印行("序列化: " + 整数转字符串(全局_查询参数统计.序列化次数))
    打印行("排序: " + 整数转字符串(全局_查询参数统计.排序次数))
    打印行("总参数: " + 整数转字符串(全局_查询参数统计.总参数数))
}

// merge source: 沙盒批次/批三/待厚/感知/地址协议匹.nova

定义 可变 安全_同源检查次数 = 0
定义 可变 安全_CORS检查次数 = 0
定义 可变 安全_CSP拦截次数 = 0
定义 可变 安全_混合内容拦截 = 0

结构 URL解析结果 {
    协议,
    主机,
    端口,
    路径,
    查询,
    片段,
    用户信息,
    有效,
}

函数 URL_协议匹配(url, 协议) { 返回 字符串_前缀匹配(url, 协议) }

函数 URL_完整解析(url) {
    定义 结果 = URL解析结果 {
        协议: "", 主机: "", 端口: 0, 路径: "/",
        查询: "", 片段: "", 用户信息: "", 有效: 假
    }
    如果 (url == 0) { 返回 结果 }
    定义 len = 字节长度(url)
    如果 (len == 0) { 返回 结果 }

    定义 可变 pos = 0

    定义 可变 协议结束 = 0
    当 (协议结束 < len && 字节取(url, 协议结束) != 0x3A) { 协议结束 = 协议结束 + 1 }
    如果 (协议结束 < len) {
        结果.协议 = 字符串_子串_小写(url, 0, 协议结束)
        pos = 协议结束 + 1
    }

    如果 (pos + 1 < len && 字节取(url, pos) == 0x2F && 字节取(url, pos + 1) == 0x2F) {
        pos = pos + 2

        定义 可变 权限结束 = pos
        当 (权限结束 < len && 字节取(url, 权限结束) != 0x2F &&
             字节取(url, 权限结束) != 0x3F && 字节取(url, 权限结束) != 0x23) {
            权限结束 = 权限结束 + 1
        }

        定义 可变 用户结束 = pos
        定义 可变 有用户 = 假
        定义 可变 扫描 = pos
        当 (扫描 < 权限结束) {
            如果 (字节取(url, 扫描) == 0x40) { 用户结束 = 扫描; 有用户 = 真; 跳出 }
            扫描 = 扫描 + 1
        }
        如果 (有用户) {
            结果.用户信息 = 字符串_子串(url, pos, 用户结束)
            pos = 用户结束 + 1
        }

        定义 可变 主机结束 = pos
        当 (主机结束 < 权限结束 && 字节取(url, 主机结束) != 0x3A) {
            主机结束 = 主机结束 + 1
        }
        结果.主机 = 字符串_子串_小写(url, pos, 主机结束)

        如果 (主机结束 < 权限结束 && 字节取(url, 主机结束) == 0x3A) {
            定义 可变 端口值 = 0
            定义 可变 pi = 主机结束 + 1
            当 (pi < 权限结束 && 字节取(url, pi) >= 0x30 && 字节取(url, pi) <= 0x39) {
                端口值 = 端口值 * 10 + (字节取(url, pi) - 0x30)
                pi = pi + 1
            }
            结果.端口 = 端口值
        }

        pos = 权限结束
    }

    如果 (结果.端口 == 0) {
        如果 (结果.协议 == "https") { 结果.端口 = 443 }
        否则 如果 (结果.协议 == "http") { 结果.端口 = 80 }
        否则 如果 (结果.协议 == "ftp") { 结果.端口 = 21 }
        否则 如果 (结果.协议 == "ws") { 结果.端口 = 80 }
        否则 如果 (结果.协议 == "wss") { 结果.端口 = 443 }
    }

    定义 可变 路径结束 = pos
    当 (路径结束 < len && 字节取(url, 路径结束) != 0x3F && 字节取(url, 路径结束) != 0x23) {
        路径结束 = 路径结束 + 1
    }
    如果 (路径结束 > pos) { 结果.路径 = 字符串_子串(url, pos, 路径结束) }
    pos = 路径结束

    如果 (pos < len && 字节取(url, pos) == 0x3F) {
        pos = pos + 1
        定义 可变 查询结束 = pos
        当 (查询结束 < len && 字节取(url, 查询结束) != 0x23) { 查询结束 = 查询结束 + 1 }
        结果.查询 = 字符串_子串(url, pos, 查询结束)
        pos = 查询结束
    }

    如果 (pos < len && 字节取(url, pos) == 0x23) {
        结果.片段 = 字符串_子串(url, pos + 1, len)
    }

    结果.有效 = 字符串长度(结果.主机) > 0 || 结果.协议 == "data" || 结果.协议 == "blob"
    返回 结果
}

函数 URL_提取主机(url) {
    定义 解析 = URL_完整解析(url)
    返回 解析.主机
}

函数 URL_提取端口(url) {
    定义 解析 = URL_完整解析(url)
    返回 解析.端口
}

函数 URL_提取协议(url) {
    定义 解析 = URL_完整解析(url)
    返回 解析.协议
}

函数 URL_同源检查(url_a, url_b) {
    安全_同源检查次数 = 安全_同源检查次数 + 1
    定义 a = URL_完整解析(url_a)
    定义 b = URL_完整解析(url_b)

    如果 (a.协议 == "data" || b.协议 == "data") { 返回 假 }
    如果 (a.协议 == "blob" || b.协议 == "blob") { 返回 假 }
    如果 (a.协议 == "file" && b.协议 == "file") { 返回 真 }

    如果 (a.协议 != b.协议) { 返回 假 }
    如果 (a.主机 != b.主机) { 返回 假 }
    如果 (a.端口 != b.端口) { 返回 假 }
    返回 真
}

函数 URL_同站检查(url_a, url_b) {
    定义 a = URL_完整解析(url_a)
    定义 b = URL_完整解析(url_b)
    如果 (a.协议 != b.协议) { 返回 假 }
    定义 域a = 提取eTLD加1(a.主机)
    定义 域b = 提取eTLD加1(b.主机)
    返回 域a == 域b
}

函数 提取eTLD加1(主机) {
    如果 (主机 == 0) { 返回 主机 }
    定义 len = 字符串长度(主机)
    定义 可变 点数 = 0
    定义 可变 最后点 = -1
    定义 可变 倒数第二点 = -1
    定义 可变 i = len - 1
    当 (i >= 0) {
        如果 (字节取(主机, i) == 0x2E) {
            点数 = 点数 + 1
            如果 (点数 == 1) { 最后点 = i }
            如果 (点数 == 2) { 倒数第二点 = i; 跳出 }
        }
        i = i - 1
    }
    如果 (倒数第二点 >= 0) { 返回 字符串_子串(主机, 倒数第二点 + 1, len) }
    返回 主机
}

函数 CORS_检查(请求源, 响应头) {
    安全_CORS检查次数 = 安全_CORS检查次数 + 1
    定义 允许源 = 响应头_获取(响应头, "Access-Control-Allow-Origin")
    如果 (允许源 == 空) { 返回 假 }
    如果 (允许源 == "*") { 返回 真 }
    返回 允许源 == 请求源
}

函数 CORS_预检检查(请求方法, 请求头, 响应头) {
    定义 允许方法 = 响应头_获取(响应头, "Access-Control-Allow-Methods")
    如果 (允许方法 == 空) { 返回 假 }
    如果 (!字符串_包含(允许方法, 请求方法)) { 返回 假 }

    定义 允许头 = 响应头_获取(响应头, "Access-Control-Allow-Headers")
    如果 (请求头 != 空 && 允许头 != 空) {
        如果 (!字符串_包含(允许头, 请求头)) { 返回 假 }
    }
    返回 真
}

函数 混合内容_检查(页面url, 资源url) {
    定义 页面 = URL_完整解析(页面url)
    定义 资源 = URL_完整解析(资源url)
    如果 (页面.协议 == "https" && 资源.协议 == "http") {
        安全_混合内容拦截 = 安全_混合内容拦截 + 1
        返回 假
    }
    返回 真
}

函数 CSP_检查(指令, 源, url) {
    如果 (指令 == 空 || 源 == 空) { 返回 真 }
    如果 (字符串_包含(源, "'none'")) {
        安全_CSP拦截次数 = 安全_CSP拦截次数 + 1
        返回 假
    }
    如果 (字符串_包含(源, "'self'")) {
        返回 真
    }
    如果 (字符串_包含(源, "*")) { 返回 真 }
    定义 资源主机 = URL_提取主机(url)
    如果 (字符串_包含(源, 资源主机)) { 返回 真 }
    安全_CSP拦截次数 = 安全_CSP拦截次数 + 1
    返回 假
}

函数 平台_创建渲染进程() {
    定义 fds = 堆_分配(8)
    平台_socketpair(fds)
    定义 pid = 系统调用_fork()
    如果 (pid == 0) {
        系统调用_close(内存_读32(fds))
        Sandbox_应用(内存_读32(fds + 4))
        渲染er_主循环(内存_读32(fds + 4))
        系统调用_exit(0)
    }
    系统调用_close(内存_读32(fds + 4))
    定义 proc = 堆_分配(24)
    内存_写64(proc, pid)
    内存_写64(proc + 8, 内存_读32(fds))
    堆_释放(fds)
    返回 proc
}

函数 安全模型_统计() {
    返回 {
        同源检查: 安全_同源检查次数,
        CORS检查: 安全_CORS检查次数,
        CSP拦截: 安全_CSP拦截次数,
        混合内容拦截: 安全_混合内容拦截
    }
}

// 安全模型健康检查

函数 安全模型_健康检查() {
    定义 可变 问题 = []
    如果 (安全_CSP拦截次数 > 100) {
        追加(问题, "CSP拦截过多: " + 整数转字符串(安全_CSP拦截次数))
    }
    如果 (安全_混合内容拦截 > 50) {
        追加(问题, "混合内容拦截过多")
    }
    如果 (计数(问题) == 0) { 返回 "安全模型健康" }
    返回 问题
}

函数 安全模型_重置() {
    安全_同源检查次数 = 0
    安全_CORS检查次数 = 0
    安全_CSP拦截次数 = 0
    安全_混合内容拦截 = 0
}

函数 安全模型_同源通过率() {
    如果 (安全_同源检查次数 == 0) { 返回 0 }
    返回 (安全_同源检查次数 - 安全_CSP拦截次数) * 100 / 安全_同源检查次数
}

函数 安全模型_CORS通过率() {
    如果 (安全_CORS检查次数 == 0) { 返回 0 }
    返回 安全_CORS检查次数 * 100 / 安全_同源检查次数
}

定义 SECURITY_NONE = 0
定义 SECURITY_SAME_ORIGIN = 1
定义 SECURITY_CORS = 2
定义 SECURITY_BLOCKED = 3

函数 安全_级别名(级别) {
    如果 (级别 == SECURITY_NONE) { 返回 "NONE" }
    如果 (级别 == SECURITY_SAME_ORIGIN) { 返回 "SAME_ORIGIN" }
    如果 (级别 == SECURITY_CORS) { 返回 "CORS" }
    如果 (级别 == SECURITY_BLOCKED) { 返回 "BLOCKED" }
    返回 "UNKNOWN"
}

函数 安全模型_完整统计() {
    返回 [安全_同源检查次数, 安全_CORS检查次数, 安全_CSP拦截次数, 安全_混合内容拦截]
}

// merge source: 沙盒批次/批三/待厚/感知/颜色解析.nova
// §4 颜色解析 (css_color.cc 约3000行)
// 支持: #hex / rgb() / rgba() / hsl() / hsla() / 命名颜色 / currentColor

函数 CSS解析_十六进制颜色(文本, 长度, pos) {
    // 跳过 #
    定义 可变 p = pos + 1
    定义 可变 hex_len = 0
    定义 hex起始 = p
    当 (p < 长度 && CSS_是十六进制(内存_读8(文本 + p))) {
        p = p + 1
        hex_len = hex_len + 1
    }

    定义 v = CSSParsedValue_创建(CSS值_颜色)

    如果 (hex_len == 3) {
        // #RGB → #RRGGBB
        定义 r = CSS_hex数字(内存_读8(文本 + hex起始))
        定义 g = CSS_hex数字(内存_读8(文本 + hex起始 + 1))
        定义 b = CSS_hex数字(内存_读8(文本 + hex起始 + 2))
        v.颜色值 = ((r * 17) * 0x10000) + ((g * 17) * 0x100) + (b * 17) + 0xFF000000
    }
    否则 如果 (hex_len == 4) {
        // #RGBA
        定义 r = CSS_hex数字(内存_读8(文本 + hex起始))
        定义 g = CSS_hex数字(内存_读8(文本 + hex起始 + 1))
        定义 b = CSS_hex数字(内存_读8(文本 + hex起始 + 2))
        定义 a = CSS_hex数字(内存_读8(文本 + hex起始 + 3))
        v.颜色值 = ((a * 17) * 0x1000000) + ((r * 17) * 0x10000) + ((g * 17) * 0x100) + (b * 17)
    }
    否则 如果 (hex_len == 6) {
        // #RRGGBB
        定义 r = CSS_hex数字(内存_读8(文本 + hex起始)) * 16 + CSS_hex数字(内存_读8(文本 + hex起始 + 1))
        定义 g = CSS_hex数字(内存_读8(文本 + hex起始 + 2)) * 16 + CSS_hex数字(内存_读8(文本 + hex起始 + 3))
        定义 b = CSS_hex数字(内存_读8(文本 + hex起始 + 4)) * 16 + CSS_hex数字(内存_读8(文本 + hex起始 + 5))
        v.颜色值 = 0xFF000000 + (r * 0x10000) + (g * 0x100) + b
    }
    否则 如果 (hex_len == 8) {
        // #RRGGBBAA
        定义 r = CSS_hex数字(内存_读8(文本 + hex起始)) * 16 + CSS_hex数字(内存_读8(文本 + hex起始 + 1))
        定义 g = CSS_hex数字(内存_读8(文本 + hex起始 + 2)) * 16 + CSS_hex数字(内存_读8(文本 + hex起始 + 3))
        定义 b = CSS_hex数字(内存_读8(文本 + hex起始 + 4)) * 16 + CSS_hex数字(内存_读8(文本 + hex起始 + 5))
        定义 a = CSS_hex数字(内存_读8(文本 + hex起始 + 6)) * 16 + CSS_hex数字(内存_读8(文本 + hex起始 + 7))
        v.颜色值 = (a * 0x1000000) + (r * 0x10000) + (g * 0x100) + b
    }
    否则 {
        返回 0    // 非法颜色
    }

    返回 v
}

函数 CSS解析_命名颜色(名称, 名称长度) {
    // CSS Color Level 4: 148个命名颜色
    // 按首字母快速分发
    定义 v = CSSParsedValue_创建(CSS值_颜色)

    如果 (字符串_等于N(名称, 名称长度, "transparent")) { v.颜色值 = 0x00000000; 返回 v }
    如果 (字符串_等于N(名称, 名称长度, "currentColor")) { v.关键字ID = 关键字_currentColor; 返回 v }

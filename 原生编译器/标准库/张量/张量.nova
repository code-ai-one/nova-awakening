
导入("../基础.nova")

// 张量结构
// [数据列表, 形状列表, 步长列表, 维度数]

函数 张量_复制列表(源) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(源)) {
 追加(结果, 源[i])
 i = i + 1
 }
 返回 结果
}

函数 张量_列表最大值(数据) {
    如果 (计数(数据) == 0) { 返回 0
}
 定义 可变 最大值 = 数据[0]
 定义 可变 i = 1
 当 (i < 计数(数据)) { 如果 (数据[i] > 最大值) { 最大值 = 数据[i] }
 i = i + 1
 }
 返回 最大值
}

函数 张量_列表最小值(数据) {
    如果 (计数(数据) == 0) { 返回 0
}
 定义 可变 最小值 = 数据[0]
 定义 可变 i = 1
 当 (i < 计数(数据)) { 如果 (数据[i] < 最小值) { 最小值 = 数据[i] }
 i = i + 1
 }
 返回 最小值
}

函数 形状_元素数(形状) { 定义 可变 结果 = 1
 定义 可变 i = 0
 当 (i < 计数(形状)) {
 结果 = 结果 * 形状[i]
 i = i + 1
 }
 返回 结果
}

函数 计算步长(形状) { 定义 nd = 计数(形状)
 定义 可变 步长 = []
 定义 可变 i = 0
 当 (i < nd) { 追加(步长, 1)
 i = i + 1 }
 如果 (nd > 1) {
 i = nd - 2
 当 (i >= 0) {
 步长[i] = 步长[i + 1] * 形状[i + 1]
 i = i - 1
 }
 }
 返回 步长
}

// 创建
函数 张量_零(形状) { 定义 n = 形状_元素数(形状)
 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < n) { 追加(数据, 0)
 i = i + 1 }
 返回 [数据, 形状, 计算步长(形状), 计数(形状)]
}

函数 张量_一(形状) { 定义 n = 形状_元素数(形状)
 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < n) { 追加(数据, 1)
 i = i + 1 }
 返回 [数据, 形状, 计算步长(形状), 计数(形状)]
}

函数 张量_填充(形状, 值) { 定义 n = 形状_元素数(形状)
 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < n) { 追加(数据, 值)
 i = i + 1 }
 返回 [数据, 形状, 计算步长(形状), 计数(形状)]
}

函数 张量_从列表(数据, 形状) { 返回 [数据, 形状, 计算步长(形状), 计数(形状)]
}

函数 张量_单位矩阵(n) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < n * n) { 追加(数据, 0)
 i = i + 1 }
 i = 0
 当 (i < n) { 数据[i * n + i] = 1
 i = i + 1 }
 返回 [数据, [n, n], 计算步长([n, n]), 2]
}

函数 张量_范围(起, _止) { 定义 n = _止 - 起
 定义 可变 数据 = []
 定义 可变 i = 起
 当 (i < _止) { 追加(数据, i)
 i = i + 1 }
 返回 [数据, [n], 计算步长([n]), 1]
}

// 属性访问
函数 张量_形状(t) { 返回 t[1] }
函数 张量_维度(t) { 返回 t[3] }
函数 张量_元素数(t) { 返回 计数(t[0]) }
函数 张量_数据(t) { 返回 t[0] }

// 索引
函数 张量_获取(t, 索引列表) { 定义 可变 偏移 = 0
 定义 可变 i = 0
 当 (i < 计数(索引列表)) {
 偏移 = 偏移 + 索引列表[i] * t[2][i]
 i = i + 1
 }
 返回 t[0][偏移]
}

函数 张量_设置(t, 索引列表, 值) { 定义 可变 偏移 = 0
 定义 可变 i = 0
 当 (i < 计数(索引列表)) {
 偏移 = 偏移 + 索引列表[i] * t[2][i]
 i = i + 1
 }
 t[0][偏移] = 值
}

// 逐元素运算
函数 张量_加(a, b) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 计数(a[0])) {
 追加(数据, a[0][i] + b[0][i])
 i = i + 1
 }
 返回 [数据, a[1], a[2], a[3]]
}

函数 张量_减(a, b) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 计数(a[0])) {
 追加(数据, a[0][i] - b[0][i])
 i = i + 1
 }
 返回 [数据, a[1], a[2], a[3]]
}

函数 张量_乘(a, b) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 计数(a[0])) {
 追加(数据, a[0][i] * b[0][i])
 i = i + 1
 }
 返回 [数据, a[1], a[2], a[3]]
}

函数 张量_标量加(t, s) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 计数(t[0])) {
 追加(数据, t[0][i] + s)
 i = i + 1
 }
 返回 [数据, t[1], t[2], t[3]]
}

函数 张量_标量乘(t, s) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 计数(t[0])) {
 追加(数据, t[0][i] * s)
 i = i + 1
 }
 返回 [数据, t[1], t[2], t[3]]
}

函数 张量_取负(t) { 返回 张量_标量乘(t, -1) }

// 矩阵运算
函数 张量_矩阵乘(a, b) {
 // a: [M, K], b: [K, N] → [M, N]
 定义 M = a[1][0]
 定义 K = a[1][1]
 定义 N = b[1][1]
 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < M * N) { 追加(数据, 0)
 i = i + 1 }
 i = 0
 当 (i < M) { 定义 可变 j = 0
 当 (j < N) { 定义 可变 和 = 0
 定义 可变 k = 0
 当 (k < K) {
 和 = 和 + a[0][i * K + k] * b[0][k * N + j]
 k = k + 1
 }
 数据[i * N + j] = 和
 j = j + 1
 }
 i = i + 1
 }
 返回 [数据, [M, N], 计算步长([M, N]), 2]
}

函数 张量_转置(t) {
 // 2D转置: [M, N] → [N, M]
 定义 M = t[1][0]
 定义 N = t[1][1]
 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < M * N) { 追加(数据, 0)
 i = i + 1 }
 i = 0
 当 (i < M) { 定义 可变 j = 0
 当 (j < N) {
 数据[j * M + i] = t[0][i * N + j]
 j = j + 1
 }
 i = i + 1
 }
 返回 [数据, [N, M], 计算步长([N, M]), 2]
}

函数 张量_点积(a, b) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 计数(a[0])) {
 和 = 和 + a[0][i] * b[0][i]
 i = i + 1
 }
 返回 和
}

// 归约运算
函数 张量_求和(t) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 计数(t[0])) {
 和 = 和 + t[0][i]
 i = i + 1
 }
 返回 和
}

函数 张量_最大(t) { 返回 张量_列表最大值(t[0]) }

函数 张量_最小(t) { 返回 张量_列表最小值(t[0]) }

函数 张量_argmax(t) { 定义 可变 最大值 = t[0][0]
 定义 可变 最大idx = 0
 定义 可变 i = 1
 当 (i < 计数(t[0])) { 如果 (t[0][i] > 最大值) { 最大值 = t[0][i]
 最大idx = i }
 i = i + 1
 }
 返回 最大idx
}

// 形状操作
函数 张量_reshape(t, 新形状) { 返回 [t[0], 新形状, 计算步长(新形状), 计数(新形状)]
}

函数 张量_展平(t) { 定义 n = 计数(t[0])
 返回 [t[0], [n], [1], 1]
}

// 切片
函数 张量_切片1D(t, 起, _止) { 定义 可变 数据 = []
 定义 可变 i = 起
 当 (i < _止) { 追加(数据, t[0][i])
 i = i + 1 }
 返回 [数据, [_止 - 起], [1], 1]
}

// 按行切片2D
函数 张量_行(t, 行号) { 定义 N = t[1][1]
 定义 可变 数据 = []
 定义 可变 j = 0
 当 (j < N) { 追加(数据, t[0][行号 * N + j])
 j = j + 1 }
 返回 [数据, [N], [1], 1]
}

// 按列切片2D
函数 张量_列(t, 列号) { 定义 M = t[1][0]
 定义 N = t[1][1]
 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < M) { 追加(数据, t[0][i * N + 列号])
 i = i + 1 }
 返回 [数据, [M], [1], 1]
}

// 比较
函数 张量_相等(a, b) {
    如果 (计数(a[0]) != 计数(b[0])) { 返回 假
}
 定义 可变 i = 0
 当 (i < 计数(a[0])) { 如果 (a[0][i] != b[0][i]) { 返回 假 }
 i = i + 1
 }
 返回 真
}

函数 张量_近似相等(a, b, 容差) {
    如果 (计数(a[0]) != 计数(b[0])) { 返回 假
}
 定义 可变 i = 0
 当 (i < 计数(a[0])) { 定义 可变 差 = a[0][i] - b[0][i]
 如果 (差 < 0) { 差 = 0 - 差 }
 如果 (差 > 容差) { 返回 假 }
 i = i + 1
 }
 返回 真
}

// 拼接
函数 张量_拼接1D(a, b) { 定义 可变 数据 = 张量_复制列表(a[0])
 定义 可变 i = 0
 当 (i < 计数(b[0])) { 追加(数据, b[0][i])
 i = i + 1 }
 定义 n = 计数(数据)
 返回 [数据, [n], [1], 1]
}

// 激活函数 (整数近似)
函数 张量_ReLU(t) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 计数(t[0])) { 定义 可变 值 = t[0][i]
 如果 (值 < 0) { 值 = 0 }
 追加(数据, 值)
 i = i + 1
 }
 返回 [数据, t[1], t[2], t[3]]
}

函数 张量_clamp(t, lo, hi) { 定义 n = 计数(t[0])
 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < n) { 定义 可变 v = t[0][i]
 如果 (v < lo) { v = lo }
 如果 (v > hi) { v = hi }
 追加(数据, v)
 i = i + 1
 }
 返回 [数据, t[1], t[2], t[3]]
}


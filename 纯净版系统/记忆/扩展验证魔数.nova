// NovaOS ext4 超级块验证·填充·挂载·卸载·同步·statfs — 完整生产级实现
// 功能: 魔数验证/超级块完整性检查/特性兼容性/fill_super/卸载/同步/statfs/错误处理
// 关联: ext4读超级块 → ext4读块组描述符 → ext4日志系统 → VFS超级块 → 块设备层

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("./扩展读超级块.nova")
导入("./扩展读块组描.nova")
导入("../中枢/日志中枢.nova")
导入("./文件文件.nova")
导入("../中枢/字符串替换.nova")
导入("./扩展获取文件.nova")
导入("../中枢/墙钟设置.nova")
导入("./块设备读.nova")
导入("./扩展截断.nova")
导入("../中枢/哈希函数.nova")
导入("../稳态/磁控驱动全局.nova")
导入("./扩展卸载超级.nova")

// 第1部分: 验证相关常量

定义 EXT4_最大块大小_LOG      = 16
定义 EXT4_最大块组数          = 0x04000000
定义 EXT4_最大文件节点数      = 0xFFFFFFFF
定义 EXT4_最大挂载次数_默认   = 20
定义 EXT4_检查间隔_默认       = 15552000

// 我们支持的不兼容特性掩码
定义 EXT4_支持的不兼容特性 = 0x0002 | 0x0040 | 0x0080 | 0x0200 | 0x0004

// 我们支持的只读兼容特性掩码
定义 EXT4_支持的RO兼容特性 = 0x0001 | 0x0002 | 0x0008 | 0x0010 | 0x0020 | 0x0040 | 0x0400

// 第2部分: 统计计数器

结构 验证统计 {
    验证魔数次数,
    验证魔数失败,
    验证超级块次数,
    验证超级块失败,
    验证块大小失败,
    验证节点大小失败,
    验证每组参数失败,
    验证节点总数失败,
    特性检查次数,
    特性不兼容失败,
    特性RO降级次数,
    填充超级块次数,
    填充超级块成功,
    填充超级块失败,
    卸载次数,
    同步次数,
    statfs次数,
    错误处理次数,
    孤儿清理次数,
    日志初始化次数,
}

定义 可变 验证统计数据 = 验证统计 {}

// 第3部分: 魔数验证

函数 ext4_验证魔数(魔数值) {
    验证统计数据.验证魔数次数 = 验证统计数据.验证魔数次数 + 1
    如果 (魔数值 != EXT4_魔数) {
        验证统计数据.验证魔数失败 = 验证统计数据.验证魔数失败 + 1
        返回 假
    }
    返回 真
}

// 第4部分: 超级块完整性验证

函数 ext4_验证超级块(磁盘sb) {
    验证统计数据.验证超级块次数 = 验证统计数据.验证超级块次数 + 1

    如果 (!ext4_验证魔数(磁盘sb.魔数)) {
        打印("[ext4验证] 错误: 无效魔数")
        验证统计数据.验证超级块失败 = 验证统计数据.验证超级块失败 + 1
        返回 错误码_无效超级块
    }

    如果 (磁盘sb.块大小_log > EXT4_最大块大小_LOG) {
        打印(字符串拼接("[ext4验证] 错误: 块大小log过大: ", 转字符串(磁盘sb.块大小_log)))
        验证统计数据.验证块大小失败 = 验证统计数据.验证块大小失败 + 1
        验证统计数据.验证超级块失败 = 验证统计数据.验证超级块失败 + 1
        返回 错误码_无效参数
    }
    定义 块大小 = EXT4_最小块大小 << 磁盘sb.块大小_log
    如果 (块大小 < EXT4_最小块大小 || 块大小 > EXT4_最大块大小) {
        打印(字符串拼接("[ext4验证] 错误: 无效块大小: ", 转字符串(块大小)))
        验证统计数据.验证块大小失败 = 验证统计数据.验证块大小失败 + 1
        验证统计数据.验证超级块失败 = 验证统计数据.验证超级块失败 + 1
        返回 错误码_无效参数
    }

    如果 (磁盘sb.文件节点大小 < EXT4_好旧REV_文件节点大小) {
        打印(字符串拼接("[ext4验证] 错误: 文件节点大小太小: ", 转字符串(磁盘sb.文件节点大小)))
        验证统计数据.验证节点大小失败 = 验证统计数据.验证节点大小失败 + 1
        验证统计数据.验证超级块失败 = 验证统计数据.验证超级块失败 + 1
        返回 错误码_无效参数
    }
    如果 (磁盘sb.文件节点大小 > 块大小) {
        打印("[ext4验证] 错误: 文件节点大小超过块大小")
        验证统计数据.验证节点大小失败 = 验证统计数据.验证节点大小失败 + 1
        验证统计数据.验证超级块失败 = 验证统计数据.验证超级块失败 + 1
        返回 错误码_无效参数
    }
    // 文件节点大小必须是2的幂
    如果 (磁盘sb.文件节点大小 & (磁盘sb.文件节点大小 - 1) != 0) {
        打印("[ext4验证] 错误: 文件节点大小不是2的幂")
        验证统计数据.验证节点大小失败 = 验证统计数据.验证节点大小失败 + 1
        验证统计数据.验证超级块失败 = 验证统计数据.验证超级块失败 + 1
        返回 错误码_无效参数
    }

    如果 (磁盘sb.每组块数 == 0) {
        打印("[ext4验证] 错误: 每组块数为零")
        验证统计数据.验证每组参数失败 = 验证统计数据.验证每组参数失败 + 1
        验证统计数据.验证超级块失败 = 验证统计数据.验证超级块失败 + 1
        返回 错误码_无效参数
    }
    如果 (磁盘sb.每组文件节点数 == 0) {
        打印("[ext4验证] 错误: 每组文件节点数为零")
        验证统计数据.验证每组参数失败 = 验证统计数据.验证每组参数失败 + 1
        验证统计数据.验证超级块失败 = 验证统计数据.验证超级块失败 + 1
        返回 错误码_无效参数
    }
    // 每组块数不能超过块大小*8(位图限制)
    如果 (磁盘sb.每组块数 > 块大小 * 8) {
        打印("[ext4验证] 错误: 每组块数超过位图容量")
        验证统计数据.验证每组参数失败 = 验证统计数据.验证每组参数失败 + 1
        验证统计数据.验证超级块失败 = 验证统计数据.验证超级块失败 + 1
        返回 错误码_无效参数
    }

    如果 (磁盘sb.文件节点总数 == 0) {
        打印("[ext4验证] 错误: 文件节点总数为零")
        验证统计数据.验证节点总数失败 = 验证统计数据.验证节点总数失败 + 1
        验证统计数据.验证超级块失败 = 验证统计数据.验证超级块失败 + 1
        返回 错误码_无效参数
    }

    如果 (磁盘sb.块总数_低 == 0) {
        打印("[ext4验证] 错误: 块总数为零")
        验证统计数据.验证超级块失败 = 验证统计数据.验证超级块失败 + 1
        返回 错误码_无效参数
    }

    如果 (磁盘sb.状态 == EXT4_错误_FS) {
        打印("[ext4验证] 警告: 文件系统标记为错误状态")
    }

    返回 0
}

// 第5部分: 特性兼容性检查

函数 ext4_检查特性兼容(磁盘sb) {
    验证统计数据.特性检查次数 = 验证统计数据.特性检查次数 + 1

    // 检查不兼容特性
    定义 不支持_不兼容 = 磁盘sb.不兼容特性 & ~EXT4_支持的不兼容特性
    如果 (不支持_不兼容 != 0) {
        打印(字符串拼接("[ext4] 错误: 不支持的不兼容特性: 0x", 转字符串(不支持_不兼容)))
        验证统计数据.特性不兼容失败 = 验证统计数据.特性不兼容失败 + 1
        返回 假
    }

    // 检查只读兼容特性(不支持的话强制只读)
    定义 不支持_RO = 磁盘sb.只读兼容特性 & ~EXT4_支持的RO兼容特性
    如果 (不支持_RO != 0) {
        打印(字符串拼接("[ext4] 警告: 不支持的RO兼容特性: 0x", 转字符串(不支持_RO)))
        打印("[ext4] 将以只读模式挂载")
        验证统计数据.特性RO降级次数 = 验证统计数据.特性RO降级次数 + 1
        // 不返回假,但调用者应设置只读标志
    }

    返回 真
}

函数 ext4_需要只读挂载(磁盘sb) {
    定义 不支持_RO = 磁盘sb.只读兼容特性 & ~EXT4_支持的RO兼容特性
    返回 不支持_RO != 0
}

// 第6部分: 内存超级块初始化 — ext4_填充超级块(fill_super)

函数 ext4_填充超级块(sb, 设备, 挂载选项) {
    验证统计数据.填充超级块次数 = 验证统计数据.填充超级块次数 + 1

    如果 (sb == 空 || 设备 == 空) {
        验证统计数据.填充超级块失败 = 验证统计数据.填充超级块失败 + 1
        返回 错误码_无效参数
    }

    定义 磁盘sb_结果 = ext4_读超级块(设备)
    如果 (是错误(磁盘sb_结果)) {
        验证统计数据.填充超级块失败 = 验证统计数据.填充超级块失败 + 1
        返回 磁盘sb_结果
    }
    定义 磁盘sb = 磁盘sb_结果

    定义 验证结果 = ext4_验证超级块(磁盘sb)
    如果 (验证结果 != 0) {
        验证统计数据.填充超级块失败 = 验证统计数据.填充超级块失败 + 1
        返回 验证结果
    }

    如果 (!ext4_检查特性兼容(磁盘sb)) {
        验证统计数据.填充超级块失败 = 验证统计数据.填充超级块失败 + 1
        返回 错误码_无效超级块
    }

    定义 可变 信息 = Ext4超级块信息 {}
    信息.磁盘超级块          = 磁盘sb
    信息.块大小               = EXT4_最小块大小 << 磁盘sb.块大小_log
    信息.块大小位             = 10 + 磁盘sb.块大小_log
    信息.簇大小               = EXT4_最小块大小 << 磁盘sb.簇大小_log
    信息.文件节点大小         = 磁盘sb.文件节点大小
    信息.每组块数             = 磁盘sb.每组块数
    信息.每组文件节点数       = 磁盘sb.每组文件节点数
    信息.挂载选项             = 挂载选项
    信息.状态                 = 磁盘sb.状态
    信息.日志文件节点号       = 磁盘sb.日志文件节点

    // 计算文件节点每块
    如果 (磁盘sb.文件节点大小 > 0) {
        信息.文件节点每块 = 信息.块大小 / 磁盘sb.文件节点大小
    } 否则 {
        信息.文件节点每块 = 1
    }

    信息.块总数 = 磁盘sb.块总数_低
    如果 (磁盘sb.不兼容特性 & EXT4_特性_不兼容_64位 != 0) {
        信息.块总数 = 信息.块总数 | (磁盘sb.块总数_高 << 32)
    }
    信息.空闲块数 = 磁盘sb.空闲块数_低
    信息.空闲文件节点数 = 磁盘sb.空闲文件节点数

    如果 (磁盘sb.每组块数 > 0) {
        信息.块组数 = (信息.块总数 - 磁盘sb.首数据块 + 磁盘sb.每组块数 - 1) / 磁盘sb.每组块数
    } 否则 {
        信息.块组数 = 1
    }
    如果 (信息.块组数 > EXT4_最大块组数) {
        打印("[ext4] 警告: 块组数过多,截断")
        信息.块组数 = EXT4_最大块组数
    }

    定义 gdt结果 = ext4_读块组描述符(设备, 信息)
    如果 (是错误(gdt结果)) {
        打印("[ext4] 错误: 无法读取块组描述符表")
        验证统计数据.填充超级块失败 = 验证统计数据.填充超级块失败 + 1
        返回 gdt结果
    }
    信息.组描述符 = gdt结果

    sb.块大小         = 信息.块大小
    sb.块大小位       = 信息.块大小位
    sb.魔数           = EXT4_魔数
    sb.私有信息       = 信息
    sb.最大文件大小   = ext4_计算最大文件大小(信息.块大小位)
    sb.文件操作表     = ext4_获取文件操作表()
    sb.节点操作表     = ext4_获取节点操作表()
    sb.超级块操作表   = ext4_获取超级块操作表()
    sb.设备           = 设备

    如果 (ext4_需要只读挂载(磁盘sb)) {
        信息.只读 = 真
        打印("[ext4] 以只读模式挂载(不支持的RO兼容特性)")
    } 否则 {
        信息.只读 = 假
    }

    如果 (磁盘sb.兼容特性 & EXT4_特性_兼容_HAS_日志 != 0) {
        如果 (信息.日志文件节点号 > 0) {
            定义 日志结果 = ext4_日志_初始化(sb, 信息.日志文件节点号)
            如果 (日志结果 == 0) {
                打印(字符串拼接("[ext4] 日志初始化完成, 节点号: ", 转字符串(信息.日志文件节点号)))
                验证统计数据.日志初始化次数 = 验证统计数据.日志初始化次数 + 1
            } 否则 {
                打印("[ext4] 警告: 日志初始化失败,继续无日志模式")
            }
        }
    }

    如果 (磁盘sb.状态 & EXT4_错误_FS != 0 || 磁盘sb.状态 & 0x0004 != 0) {
        ext4_清理孤儿文件节点(sb)
        验证统计数据.孤儿清理次数 = 验证统计数据.孤儿清理次数 + 1
    }

    信息.已挂载 = 真
    磁盘sb.挂载次数 = 磁盘sb.挂载次数 + 1
    磁盘sb.挂载时间 = 当前时间_秒()
    磁盘sb.状态 = EXT4_有效_FS

    // 写回更新后的超级块
    如果 (!信息.只读) {
        ext4_写超级块(设备, 信息)
    }

    打印(字符串拼接("[ext4] 挂载成功: 块大小=", 转字符串(信息.块大小)))
    打印(字符串拼接("[ext4]   块组数=", 转字符串(信息.块组数)))
    打印(字符串拼接("[ext4]   文件节点总数=", 转字符串(磁盘sb.文件节点总数)))
    打印(字符串拼接("[ext4]   空闲块数=", 转字符串(信息.空闲块数)))
    打印(字符串拼接("[ext4]   卷名=", 磁盘sb.卷名))

    验证统计数据.填充超级块成功 = 验证统计数据.填充超级块成功 + 1
    返回 0
}

// 第7部分: 卸载 — ext4_卸载超级块

函数 ext4_卸载超级块(sb) {
    验证统计数据.卸载次数 = 验证统计数据.卸载次数 + 1

    如果 (sb == 空 || sb.私有信息 == 空) {
        返回 错误码_无效参数
    }

    定义 信息 = sb.私有信息

    ext4_同步文件系统(sb)

    如果 (信息.日志 != 空) {
        journal_强制提交(信息.日志)
        journal_销毁(信息.日志)
        信息.日志 = 空
    }

    如果 (!信息.只读) {
        信息.状态 = EXT4_有效_FS
        信息.磁盘超级块.状态 = EXT4_有效_FS
        ext4_写超级块(sb.设备, 信息)
    }

    如果 (信息.组描述符 != 空) {
        释放内存(信息.组描述符)
        信息.组描述符 = 空
    }

    信息.已挂载 = 假
    打印("[ext4] 文件系统已卸载")
    返回 0
}

// 第8部分: 文件系统同步 — ext4_同步文件系统

函数 ext4_同步文件系统(sb) {
    验证统计数据.同步次数 = 验证统计数据.同步次数 + 1

    如果 (sb == 空 || sb.私有信息 == 空) {
        返回 错误码_无效参数
    }

    定义 信息 = sb.私有信息
    如果 (信息.只读) { 返回 0 }

    // 1. 提交日志
    如果 (信息.日志 != 空) {
        journal_强制提交(信息.日志)
    }

    // 2. 写回超级块
    ext4_写超级块(sb.设备, 信息)

    // 3. 写回块组描述符
    ext4_写块组描述符(sb.设备, 信息)

    // 4. 刷新设备缓存
    块设备_刷新(sb.设备)

    返回 0
}

// 第9部分: 文件系统统计信息 — ext4_statfs

函数 ext4_统计信息(sb, 统计缓冲) {
    验证统计数据.statfs次数 = 验证统计数据.statfs次数 + 1

    如果 (sb == 空 || sb.私有信息 == 空 || 统计缓冲 == 空) {
        返回 错误码_无效参数
    }

    定义 信息 = sb.私有信息

    统计缓冲.类型 = EXT4_魔数
    统计缓冲.块大小 = 信息.块大小
    统计缓冲.总块数 = 信息.块总数
    统计缓冲.空闲块数 = 信息.空闲块数
    统计缓冲.可用块数 = 信息.空闲块数 - (信息.块总数 / 20)
    如果 (统计缓冲.可用块数 < 0) { 统计缓冲.可用块数 = 0 }
    统计缓冲.总文件数 = 信息.磁盘超级块.文件节点总数
    统计缓冲.空闲文件数 = 信息.空闲文件节点数
    统计缓冲.最大文件名长度 = 255
    统计缓冲.文件系统ID = 信息.磁盘超级块.UUID

    返回 0
}

// 第10部分: 错误处理

函数 ext4_处理错误(sb, 错误消息) {
    验证统计数据.错误处理次数 = 验证统计数据.错误处理次数 + 1

    打印(字符串拼接("[ext4] 错误: ", 错误消息))

    如果 (sb == 空 || sb.私有信息 == 空) { 返回 }

    定义 信息 = sb.私有信息
    信息.状态 = EXT4_错误_FS
    信息.磁盘超级块.状态 = EXT4_错误_FS

    定义 错误行为 = 信息.磁盘超级块.错误行为

    匹配 错误行为 {
        1: {
            // EXT4_错误_继续: 记录错误继续运行
            打印("[ext4] 错误处理: 继续运行")
        }
        2: {
            // EXT4_错误_只读: 切换到只读
            信息.只读 = 真
            打印("[ext4] 错误处理: 切换到只读模式")
        }
        3: {
            // EXT4_错误_恐慌: 系统恐慌
            打印("[ext4] 致命错误: 触发系统恐慌!")
        }
    }

    // 写回错误状态
    如果 (!信息.只读) {
        ext4_写超级块(sb.设备, 信息)
    }
}

// 第11部分: 孤儿文件节点清理

函数 ext4_清理孤儿文件节点(sb) {
    打印("[ext4] 开始清理孤儿文件节点...")

    如果 (sb == 空 || sb.私有信息 == 空) { 返回 }

    定义 信息 = sb.私有信息
    定义 可变 清理计数 = 0

    // 遍历文件节点表,查找链接数为0但未被释放的节点
    定义 可变 组号 = 0
    当 (组号 < 信息.块组数 && 清理计数 < 1000) {
        定义 节点位图块 = ext4_获取文件节点位图块(信息, 组号)
        如果 (节点位图块 == 0) {
            组号 = 组号 + 1
            继续
        }

        定义 位图 = 块设备_读(sb.设备, 节点位图块 * 信息.块大小, 信息.块大小)
        如果 (位图 == 空) {
            组号 = 组号 + 1
            继续
        }

        // 扫描位图中已分配的节点
        定义 可变 位索引 = 0
        当 (位索引 < 信息.每组文件节点数 && 清理计数 < 1000) {
            定义 字节 = 缓冲读8(位图, 位索引 / 8)
            如果 (字节 & (1 << (位索引 % 8)) != 0) {
                // 该节点已分配,检查是否为孤儿
                定义 节点号 = 组号 * 信息.每组文件节点数 + 位索引 + 1
                定义 节点 = ext4_读文件节点(sb, 节点号)
                如果 (!是错误(节点) && 节点.链接数 == 0 && 节点.删除时间 > 0) {
                    // 孤儿节点: 释放其数据块和节点
                    ext4_截断(节点, 0)
                    ext4_释放文件节点号(sb, 节点号)
                    清理计数 = 清理计数 + 1
                }
            }
            位索引 = 位索引 + 1
        }
        组号 = 组号 + 1
    }

    打印(字符串拼接("[ext4] 孤儿清理完成: 释放 ", 转字符串(清理计数)))
}

// 第12部分: 块组描述符写回

函数 ext4_写块组描述符(设备, 信息) {
    如果 (设备 == 空 || 信息.组描述符 == 空) { 返回 错误码_无效参数 }

    定义 描述符大小 = 信息.磁盘超级块.块组描述符大小
    如果 (描述符大小 == 0) { 描述符大小 = 32 }

    定义 gdt起始块 = 信息.磁盘超级块.首数据块 + 1

    定义 可变 组号 = 0
    当 (组号 < 信息.块组数) {
        定义 块号 = gdt起始块 + (组号 * 描述符大小) / 信息.块大小
        定义 偏移 = (组号 * 描述符大小) % 信息.块大小

        定义 可变 缓冲 = 块设备_读(设备, 块号 * 信息.块大小, 信息.块大小)
        如果 (缓冲 == 空) {
            缓冲 = 创建缓冲(信息.块大小)
        }

        缓冲写32(缓冲, 偏移 + 0, 信息.组描述符[组号].块位图_低)
        缓冲写32(缓冲, 偏移 + 4, 信息.组描述符[组号].文件节点位图_低)
        缓冲写32(缓冲, 偏移 + 8, 信息.组描述符[组号].文件节点表_低)
        缓冲写16(缓冲, 偏移 + 12, 信息.组描述符[组号].空闲块数_低)
        缓冲写16(缓冲, 偏移 + 14, 信息.组描述符[组号].空闲文件节点数_低)
        缓冲写16(缓冲, 偏移 + 16, 信息.组描述符[组号].目录数_低)

        如果 (描述符大小 >= 64) {
            缓冲写32(缓冲, 偏移 + 32, 信息.组描述符[组号].块位图_高)
            缓冲写32(缓冲, 偏移 + 36, 信息.组描述符[组号].文件节点位图_高)
            缓冲写32(缓冲, 偏移 + 40, 信息.组描述符[组号].文件节点表_高)
            缓冲写16(缓冲, 偏移 + 44, 信息.组描述符[组号].空闲块数_高)
            缓冲写16(缓冲, 偏移 + 46, 信息.组描述符[组号].空闲文件节点数_高)
        }

        块设备_写(设备, 块号 * 信息.块大小, 缓冲, 信息.块大小)
        组号 = 组号 + 1
    }
    返回 0
}

// 第13部分: 统计输出

函数 ext4_验证_打印统计() {
    打印("[ext4验证] ═══ 统计信息 ═══")
    打印(字符串拼接("  验证魔数次数:     ", 转字符串(验证统计数据.验证魔数次数)))
    打印(字符串拼接("  验证魔数失败:     ", 转字符串(验证统计数据.验证魔数失败)))
    打印(字符串拼接("  验证超级块次数:   ", 转字符串(验证统计数据.验证超级块次数)))
    打印(字符串拼接("  验证超级块失败:   ", 转字符串(验证统计数据.验证超级块失败)))
    打印(字符串拼接("  特性检查次数:     ", 转字符串(验证统计数据.特性检查次数)))
    打印(字符串拼接("  特性不兼容失败:   ", 转字符串(验证统计数据.特性不兼容失败)))
    打印(字符串拼接("  特性RO降级:       ", 转字符串(验证统计数据.特性RO降级次数)))
    打印(字符串拼接("  填充超级块次数:   ", 转字符串(验证统计数据.填充超级块次数)))
    打印(字符串拼接("  填充超级块成功:   ", 转字符串(验证统计数据.填充超级块成功)))
    打印(字符串拼接("  填充超级块失败:   ", 转字符串(验证统计数据.填充超级块失败)))
    打印(字符串拼接("  卸载次数:         ", 转字符串(验证统计数据.卸载次数)))
    打印(字符串拼接("  同步次数:         ", 转字符串(验证统计数据.同步次数)))
    打印(字符串拼接("  statfs次数:       ", 转字符串(验证统计数据.statfs次数)))
    打印(字符串拼接("  错误处理次数:     ", 转字符串(验证统计数据.错误处理次数)))
    打印(字符串拼接("  孤儿清理次数:     ", 转字符串(验证统计数据.孤儿清理次数)))
    打印(字符串拼接("  日志初始化次数:   ", 转字符串(验证统计数据.日志初始化次数)))
    返回 0
}

函数 ext4_验证_获取统计() {
    返回 验证统计数据
}

定义 可变 AI验证_损坏模式历史 = []

函数 AI验证_损坏风险评估(超级块, 块组数) {
    // 基于历史损坏模式预测风险
    定义 可变 风险 = 0
    如果 (超级块.错误计数 > 0) { 风险 = 风险 + 300 }
    如果 (超级块.最近挂载时间 > 超级块.最近检查时间) { 风险 = 风险 + 200 }
    如果 (块组数 > 1000 && 超级块.空闲块数 < 超级块.总块数 / 20) { 风险 = 风险 + 400 }
    返回 风险
}

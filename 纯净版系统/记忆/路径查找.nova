// NovaOS 路径查找 — NovaPLR原创理论
// 原创理论: NovaPLR (Nova Path Lookup & Resolution)
//   §1 link_path_walk: 逐组件遍历路径, 每步dcache→inode.lookup
//   §2 挂载点穿越: 遇到MOUNTED时切换到挂载的文件系统
//   §3 符号链接跟随: symlink递归解析(深度限制40防循环)
//   §4 LOOKUP_*标志: 控制查找行为
//   §5 ".."处理: 不能越过chroot/mount边界
//   §6 路径规范化: realpath——消除"."/".."/symlink得到绝对路径
//   §7 readlink: 读取符号链接目标而不跟随
//   §8 openat: 基于fd的相对路径查找
//   §9 权限缓存: 对热路径缓存权限判断结果
//   §10 UID检查: real UID/effective UID/fsuid多层检查
//   四阶段AI演进: NovaPLR在阶段1提供路径解析基础

导入("./文件文件.nova")
导入("../中枢/错误码.nova")
导入("../中枢/日志中枢.nova")
导入("../中枢/内存物理.nova")
导入("../中枢/硬链接.nova")
导入("./文件层文件.nova")
导入("./目录项添加.nova")
导入("./文件节点创.nova")
导入("./路径缓初始.nova")
导入("./执行移挂载.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/每处理器.nova")
导入("../中枢/复制描述.nova")

定义 LOOKUP_FOLLOW    = 0x0001   // 跟随最终组件的符号链接
定义 LOOKUP_DIRECTORY = 0x0002   // 最终组件必须是目录
定义 LOOKUP_PARENT    = 0x0010   // 返回父目录(用于create/unlink)
定义 LOOKUP_CREATE    = 0x0200   // 最终组件可以不存在(准备创建)
定义 LOOKUP_OPEN      = 0x0100   // 用于open系统调用
定义 LOOKUP_NOFOLLOW  = 0x0000   // 不跟随符号链接(与FOLLOW互斥)

定义 最大符号链接深度 = 40       // MAXSYMLINKS in Linux

结构 查找上下文 {
    当前Nova路径项,    // u64 path.Nova路径项: 当前所在的Nova路径项
    当前挂载,    // u64 path.mnt: 当前所在的vfsmount
    根Nova路径项,    // u64 root.Nova路径项: chroot根
    标志,    // u32 flags: LOOKUP_*
    链接深度,    // u32 当前符号链接递归深度
    // 最终组件信息(LOOKUP_PARENT时使用)
    最终组件,    // 字符串 last.name: 路径的最后一个组件
    最终类型,    // u32 last_type: LAST_NORM/LAST_DOT/LAST_DOTDOT/LAST_ROOT
}

定义 LAST_NORM   = 0    // 普通名称
定义 LAST_ROOT   = 1    // 空路径(只有/)
定义 LAST_DOT    = 2    // "."
定义 LAST_DOTDOT = 3    // ".."

// 核心路径查找 

函数 路径查找(根目录项, 路径) {
    返回 路径查找_带标志(根目录项, 路径, 0)
}

函数 路径查找_带标志(根目录项, 路径, 标志) {
    定义 可变 ctx = 查找上下文 {}
    ctx.根Nova路径项 = 根目录项
    ctx.标志 = 标志
    ctx.链接深度 = 0

    // 确定起点: 绝对路径从根开始, 相对路径从当前目录
    如果 (字符串长度(路径) > 0 && 字符串取字符(路径, 0) == "/") {
        ctx.当前Nova路径项 = 根目录项
    } 否则 {
        // 从当前进程的cwd开始
        ctx.当前Nova路径项 = 进程_当前目录()
        如果 (ctx.当前Nova路径项 == 空) { ctx.当前Nova路径项 = 根目录项 }
    }

    // link_path_walk: 逐组件解析
    定义 结果 = link_path_walk(路径, ctx)
    如果 (是错误(结果)) { 返回 空 }

    // LOOKUP_PARENT: 返回父目录, 最终组件名存在ctx中
    如果 ((标志 & LOOKUP_PARENT) != 0) {
        返回 ctx.当前Nova路径项
    }

    返回 ctx.当前Nova路径项
}

// link_path_walk: 逐组件遍历路径
// 这是VFS最热的路径 — 每次open/stat/access都走这里

函数 link_path_walk(路径, ctx) {
    定义 部分 = 字符串分割(路径, "/")
    定义 总组件 = 计数(部分)
    定义 可变 i = 0

    当 (i < 总组件) {
        定义 组件 = 部分[i]
        定义 是最终 = (i == 总组件 - 1)

        // 跳过空组件(连续的/)
        如果 (组件 == "") { i = i + 1; 继续 }

        // 1. 权限检查: 当前目录必须有exec(搜索)权限
        定义 当前Nova文件节点 = 目录项_Nova文件节点(ctx.当前Nova路径项)
        如果 (当前Nova文件节点 == 空) { 返回 错误_不存在 }
        如果 (!Nova节点_是目录(当前Nova文件节点)) { 返回 错误_非目录 }
        // 目录搜索权限检查: 需要execute(search)位
        定义 模式 = Nova文件节点_权限(当前Nova文件节点, 4)
        如果 ((模式 & 0o111) == 0) {
            返回 错误_权限   // EACCES: 目录无搜索权限
        }

        // 2. LOOKUP_PARENT且是最终组件: 保存组件名后返回
        如果 (是最终 && (ctx.标志 & LOOKUP_PARENT) != 0) {
            如果 (组件 == ".") { ctx.最终类型 = LAST_DOT }
            否则 如果 (组件 == "..") { ctx.最终类型 = LAST_DOTDOT }
            否则 { ctx.最终类型 = LAST_NORM; ctx.最终组件 = 组件 }
            返回 成功
        }

        // 3. 处理 "." — 什么都不做
        如果 (组件 == ".") { i = i + 1; 继续 }

        // 4. 处理 ".." — 回到父目录
        如果 (组件 == "..") {
            // 不能越过根目录
            如果 (ctx.当前Nova路径项 == ctx.根Nova路径项) {
                i = i + 1; 继续
            }
            定义 父 = 目录项_父(ctx.当前Nova路径项)
            如果 (父 != 空) {
                // 检查是否越过挂载点边界: 如果当前Nova路径项是某个挂载的根, 先退回到挂载点
                如果 (目录项_是挂载根(ctx.当前Nova路径项)) {
                    定义 挂载点Nova路径项 = 挂载点_获取父Nova路径项(ctx.当前Nova路径项)
                    如果 (挂载点Nova路径项 != 空) { 父 = 目录项_父(挂载点Nova路径项) }
                }
                ctx.当前Nova路径项 = 父
            }
            i = i + 1; 继续
        }

        // 5. 普通组件: Nova路径缓存查找 → Nova文件节点.lookup
        定义 子Nova路径项 = walk_component(ctx, 组件)
        如果 (子Nova路径项 == 空) {
            // 最终组件不存在且LOOKUP_CREATE: 允许(准备创建)
            如果 (是最终 && (ctx.标志 & LOOKUP_CREATE) != 0) {
                返回 成功
            }
            返回 错误_不存在
        }

        // 6. 检查挂载点穿越 
        如果 (目录项_是挂载点(子Nova路径项)) {
            // 穿越挂载点: 切换到挂载文件系统的根Nova路径项
            定义 挂载根 = 挂载点_获取根Nova路径项(子Nova路径项)
            如果 (挂载根 != 空) { 子Nova路径项 = 挂载根 }
        }

        // 7. 符号链接跟随 (中间组件总是跟随, 最终组件看LOOKUP_FOLLOW)
        如果 (目录项_Nova文件节点(子Nova路径项) != 空 && Nova节点_是符号链接(目录项_Nova文件节点(子Nova路径项))) {
            如果 (!是最终 || (ctx.标志 & LOOKUP_FOLLOW) != 0) {
                定义 链接结果 = follow_symlink(ctx, 子Nova路径项)
                如果 (是错误(链接结果)) { 返回 链接结果 }
                i = i + 1; 继续
            }
        }

        // 8. 如果不是最终组件, 当前Nova路径项必须是目录
        如果 (!是最终) {
            定义 子Nova文件节点 = 目录项_Nova文件节点(子Nova路径项)
            如果 (子Nova文件节点 == 空 || !Nova节点_是目录(子Nova文件节点)) {
                返回 错误_非目录
            }
        }

        ctx.当前Nova路径项 = 子Nova路径项
        i = i + 1
    }

    // 最终检查: LOOKUP_DIRECTORY要求结果必须是目录
    如果 ((ctx.标志 & LOOKUP_DIRECTORY) != 0) {
        定义 最终Nova文件节点 = 目录项_Nova文件节点(ctx.当前Nova路径项)
        如果 (最终Nova文件节点 == 空 || !Nova节点_是目录(最终Nova文件节点)) {
            返回 错误_非目录
        }
    }

    返回 成功
}

// walk_component: 单组件查找
// 先查Nova路径缓存, 未命中则调用Nova文件节点->i_op->lookup

函数 walk_component(ctx, 名称) {
    // 1. Nova路径缓存快速查找
    定义 缓存 = Nova路径缓存_查找(ctx.当前Nova路径项, 名称)
    如果 (缓存 != 空) {
        // 负项命中: 文件确认不存在
        如果 (目录项_是负项(缓存)) { 返回 空 }
        返回 缓存
    }

    // 2. Nova路径缓存未命中: 调用具体FS的lookup
    定义 目录Nova文件节点 = 目录项_Nova文件节点(ctx.当前Nova路径项)
    如果 (目录Nova文件节点 == 空) { 返回 空 }
    如果 (目录Nova文件节点.i_op.lookup != 0) {
        // 创建新Nova路径项, 交给FS填充Nova文件节点
        定义 新Nova路径项 = Nova路径项_分配(名称, ctx.当前Nova路径项)
        定义 结果 = 目录Nova文件节点.i_op.lookup(目录Nova文件节点, 新Nova路径项, ctx.标志)
        如果 (是错误(结果)) { 返回 空 }
        // FS的lookup会调d_splice_alias绑定Nova文件节点
        返回 新Nova路径项
    }

    // 3. 无lookup实现: 在子链表中线性搜索(内存FS后备)
    返回 目录项_查找子(ctx.当前Nova路径项, 名称)
}

// 符号链接跟随 

函数 follow_symlink(ctx, 链接Nova路径项) {
    ctx.链接深度 = ctx.链接深度 + 1
    如果 (ctx.链接深度 > 最大符号链接深度) {
        返回 错误_名称过长   // ELOOP in Linux
    }

    定义 链接Nova文件节点 = 目录项_Nova文件节点(链接Nova路径项)
    如果 (链接Nova文件节点 == 空) { 返回 错误_不存在 }

    // 读取链接目标
    如果 (链接Nova文件节点.i_op.readlink != 0) {
        定义 可变 目标 = ""
        链接Nova文件节点.i_op.readlink(链接Nova路径项, 目标, 4096)
        // 递归解析链接目标路径
        如果 (字符串长度(目标) > 0 && 字符串取字符(目标, 0) == "/") {
            ctx.当前Nova路径项 = ctx.根Nova路径项
        }
        定义 结果 = link_path_walk(目标, ctx)
        ctx.链接深度 = ctx.链接深度 - 1
        返回 结果
    }

    ctx.链接深度 = ctx.链接深度 - 1
    返回 错误_无效参数
}

// 便捷接口: 路径查找到Nova路径项和路径查找到Nova文件节点

函数 路径_到_Nova路径项(路径) {
    返回 路径查找(获取根目录项(, 0), 路径)
}

函数 路径_到_Nova文件节点(路径) {
    定义 d = 路径_到_Nova路径项(路径)
    如果 (d == 空) { 返回 空 }
    返回 目录项_Nova文件节点(d)
}

函数 路径_到_父Nova路径项(路径) {
    返回 路径查找_带标志(获取根目录项(), 路径, LOOKUP_PARENT)
}

函数 路径_存在(路径) {
    返回 路径_到_Nova路径项(路径) != 空
}

函数 路径_是目录(路径) {
    定义 d = 路径_到_Nova路径项(路径)
    如果 (d == 空) { 返回 假 }
    返回 目录项_是目录(d)
}

// 获取当前进程目录(简化)

函数 进程_当前目录() {
    // 从当前进程的fs_struct获取当前工作目录
    定义 当前 = 获取当前进程()
    如果 (当前 != 空 && 当前.cwd != 空) {
        返回 当前.cwd
    }
    返回 获取根目录项()   // 回退: 根目录
}

// §6 路径规范化 — realpath: 消除"."/".."/symlink

函数 路径_规范化(路径) {
    // realpath实现: 解析所有symlink/"."/ ".." 得到绝对路径
    定义 d = 路径查找_带标志(获取根目录项(), 路径, LOOKUP_FOLLOW)
    如果 (d == 空) { 返回 "" }
    // 从目录项向上遍历到根——构建规范化绝对路径
    定义 可变 部分列表 = []
    定义 可变 当前 = d
    定义 根 = 获取根目录项()
    当 (当前 != 根 && 当前 != 空) {
        追加(部分列表, 目录项_名称(当前))
        当前 = 目录项_父(当前)
    }
    // 反转构建路径
    定义 可变 结果 = "/"
    定义 可变 i = 计数(部分列表) - 1
    当 (i >= 0) {
        结果 = 结果 + 部分列表[i]
        如果 (i > 0) { 结果 = 结果 + "/" }
        i = i - 1
    }
    返回 结果
}

函数 路径_是绝对路径(路径) {
    返回 字符串长度(路径) > 0 && 字符串取字符(路径, 0) == "/"
}

函数 路径_连接(基础路径, 相对路径) {
    如果 (路径_是绝对路径(相对路径)) { 返回 相对路径 }
    如果 (字符串长度(基础路径) == 0) { 返回 相对路径 }
    定义 末尾 = 字符串取字符(基础路径, 字符串长度(基础路径) - 1)
    如果 (末尾 == "/") {
        返回 基础路径 + 相对路径
    }
    返回 基础路径 + "/" + 相对路径
}

// §7 readlink — 读取符号链接目标(不跟随)

函数 路径_读链接(路径) {
    // 不跟随最终组件的符号链接——返回链接目标字符串
    定义 d = 路径查找_带标志(获取根目录项(), 路径, LOOKUP_NOFOLLOW)
    如果 (d == 空) { 返回 "" }
    定义 节点 = 目录项_Nova文件节点(d)
    如果 (节点 == 空) { 返回 "" }
    如果 (!Nova节点_是符号链接(节点)) { 返回 "" }  // 不是symlink
    如果 (节点.i_op.readlink == 0) { 返回 "" }
    定义 可变 目标 = ""
    节点.i_op.readlink(d, 目标, 4096)
    返回 目标
}

函数 路径_读链接at(目录fd, 路径) {
    // readlinkat: 基于目录fd的相对readlink
    定义 基础目录 = 获取fd目录项(目录fd)
    如果 (基础目录 == 空) { 返回 "" }
    定义 d = 路径查找_带标志(基础目录, 路径, LOOKUP_NOFOLLOW)
    如果 (d == 空) { 返回 "" }
    定义 节点 = 目录项_Nova文件节点(d)
    如果 (节点 == 空 || !Nova节点_是符号链接(节点)) { 返回 "" }
    如果 (节点.i_op.readlink == 0) { 返回 "" }
    定义 可变 目标 = ""
    节点.i_op.readlink(d, 目标, 4096)
    返回 目标
}

// §8 openat — 基于fd的相对路径查找

定义 AT_FDCWD = -100    // 特殊值: 使用当前工作目录

函数 获取fd目录项(目录fd) {
    如果 (目录fd == AT_FDCWD) {
        返回 进程_当前目录()
    }
    // 从进程的FD表获取目录项
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 空 }
    定义 文件 = 进程_获取fd(当前, 目录fd)
    如果 (文件 == 空) { 返回 空 }
    定义 d = 文件_目录项(文件)
    如果 (d == 空) { 返回 空 }
    // 确保fd指向的是目录
    定义 节点 = 目录项_Nova文件节点(d)
    如果 (节点 == 空 || !Nova节点_是目录(节点)) {
        返回 空  // 非EPATH: fd不指向目录
    }
    返回 d
}

函数 路径查找_openat(目录fd, 路径, 标志) {
    // openat的路径解析入口
    如果 (路径_是绝对路径(路径)) {
        // 绝对路径忽略fd
        返回 路径查找_带标志(获取根目录项(), 路径, 标志)
    }
    定义 基础 = 获取fd目录项(目录fd)
    如果 (基础 == 空) { 返回 空 }
    返回 路径查找_带标志(基础, 路径, 标志)
}

// §9 权限缓存 — 热路径权限判断结果缓存

定义 权限缓存大小 = 256
定义 可变 权限_缓存表 = []    // [节点号, UID, 模式, 结果, 时间戳]
定义 权限缓存TTL = 5000       // 5秒有效期(ms)

函数 权限缓存_查找(节点号, uid, 模式) {
    定义 当前时间 = 获取时间戳_毫秒()
    定义 可变 i = 0
    当 (i < 计数(权限_缓存表)) {
        如果 (权限_缓存表[i][0] == 节点号 &&
             权限_缓存表[i][1] == uid &&
             权限_缓存表[i][2] == 模式) {
            // 检查TTL
            如果 (当前时间 - 权限_缓存表[i][4] < 权限缓存TTL) {
                返回 权限_缓存表[i][3]  // 返回缓存结果
            }
            // 过期——删除
            删除(权限_缓存表, i)
            返回 -1  // 未命中
        }
        i = i + 1
    }
    返回 -1  // 未命中
}

函数 权限缓存_插入(节点号, uid, 模式, 结果) {
    如果 (计数(权限_缓存表) >= 权限缓存大小) {
        // LRU淮汰: 移除最早的条目
        删除(权限_缓存表, 0)
    }
    追加(权限_缓存表, [节点号, uid, 模式, 结果, 获取时间戳_毫秒()])
}

函数 权限缓存_无效化(节点号) {
    // 当inode权限变更时无效化对应缓存
    定义 可变 i = 0
    当 (i < 计数(权限_缓存表)) {
        如果 (权限_缓存表[i][0] == 节点号) {
            删除(权限_缓存表, i)
        } 否则 {
            i = i + 1
        }
    }
}

// §10 UID多层权限检查 — real/effective/fsuid

函数 路径_检查权限(路径, 模式) {
    // 类似 access(2): 使用real UID检查权限
    定义 d = 路径_到_Nova路径项(路径)
    如果 (d == 空) { 返回 错误_不存在 }
    定义 节点 = 目录项_Nova文件节点(d)
    如果 (节点 == 空) { 返回 错误_不存在 }
    定义 当前进程 = 获取当前进程()
    定义 real_uid = 进程_获取real_uid(当前进程)
    返回 权限_检查内部(节点, real_uid, 模式)
}

函数 路径_检查权限_euid(路径, 模式) {
    // 使用effective UID检查(文件操作实际使用这个)
    定义 d = 路径_到_Nova路径项(路径)
    如果 (d == 空) { 返回 错误_不存在 }
    定义 节点 = 目录项_Nova文件节点(d)
    如果 (节点 == 空) { 返回 错误_不存在 }
    定义 当前进程 = 获取当前进程()
    定义 euid = 进程_获取euid(当前进程)
    返回 权限_检查内部(节点, euid, 模式)
}

函数 权限_检查内部(节点, uid, 模式) {
    定义 节点号 = Nova文件节点_编号(节点)
    // 先查缓存
    定义 缓存 = 权限缓存_查找(节点号, uid, 模式)
    如果 (缓存 >= 0) { 返回 缓存 }
    // root用户: 跳过权限检查(uid==0)
    如果 (uid == 0) {
        权限缓存_插入(节点号, uid, 模式, 0)
        返回 0  // 成功
    }
    // POSIX权限检查: owner/group/other
    定义 文件uid = Nova文件节点_uid(节点)
    定义 文件模式 = Nova文件节点_模式(节点)
    定义 可变 匹配模式 = 0
    如果 (uid == 文件uid) {
        匹配模式 = (文件模式 >> 6) & 7  // owner bits
    } 否则 {
        匹配模式 = 文件模式 & 7  // other bits
    }
    定义 结果 = 0
    如果 ((模式 & 匹配模式) != 模式) {
        结果 = 错误_权限  // EACCES
    }
    权限缓存_插入(节点号, uid, 模式, 结果)
    返回 结果
}

// 路径名验证与工具函数

定义 路径最大长度 = 4096   // PATH_MAX
定义 名称最大长度 = 255    // NAME_MAX

函数 路径_验证名称(名称) {
    // 检查单个文件名是否合法
    如果 (字符串长度(名称) == 0) { 返回 错误_无效参数 }
    如果 (字符串长度(名称) > 名称最大长度) { 返回 错误_名称过长 }
    // 不允许包含"/"
    定义 可变 i = 0
    当 (i < 字符串长度(名称)) {
        如果 (字符串取字符(名称, i) == "/") { 返回 错误_无效参数 }
        如果 (字符串取字符(名称, i) == 0) { 返回 错误_无效参数 }  // NUL
        i = i + 1
    }
    返回 0  // 合法
}

函数 路径_验证长度(路径) {
    如果 (字符串长度(路径) > 路径最大长度) { 返回 错误_名称过长 }
    返回 0
}

函数 路径_基名(路径) {
    // basename: 返回路径的最后一个组件
    如果 (字符串长度(路径) == 0) { 返回 "." }
    定义 部分 = 字符串分割(路径, "/")
    定义 可变 i = 计数(部分) - 1
    当 (i >= 0) {
        如果 (部分[i] != "") { 返回 部分[i] }
        i = i - 1
    }
    返回 "/"
}

函数 路径_目录名(路径) {
    // dirname: 返回路径的父目录部分
    如果 (字符串长度(路径) == 0) { 返回 "." }
    定义 部分 = 字符串分割(路径, "/")
    如果 (计数(部分) <= 1) { 返回 "." }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(部分) - 1) {
        如果 (i > 0) { 结果 = 结果 + "/" }
        结果 = 结果 + 部分[i]
        i = i + 1
    }
    如果 (结果 == "") { 结果 = "/" }
    返回 结果
}

函数 路径_faccessat(目录fd, 路径, 模式, 标志) {
    // faccessat(2): 基于fd的相对路径权限检查
    定义 可变 查找标志 = LOOKUP_FOLLOW
    如果 ((标志 & 0x100) != 0) {  // AT_SYMLINK_NOFOLLOW
        查找标志 = LOOKUP_NOFOLLOW
    }
    定义 d = 路径查找_openat(目录fd, 路径, 查找标志)
    如果 (d == 空) { 返回 错误_不存在 }
    定义 节点 = 目录项_Nova文件节点(d)
    如果 (节点 == 空) { 返回 错误_不存在 }
    定义 当前进程 = 获取当前进程()
    定义 可变 uid = 0
    如果 ((标志 & 0x200) != 0) {  // AT_EACCESS
        uid = 进程_获取euid(当前进程)
    } 否则 {
        uid = 进程_获取real_uid(当前进程)
    }
    返回 权限_检查内部(节点, uid, 模式)
}

// NovaPLR完整诊断统计

定义 可变 路径查找_总次数 = 0
定义 可变 路径查找_命中次数 = 0
定义 可变 路径查找_符号链接次数 = 0
定义 可变 路径查找_挂载穿越次数 = 0

函数 路径查找_完整统计() {
    返回 [
        ["总查找次数", 路径查找_总次数],
        ["缓存命中", 路径查找_命中次数],
        ["符号链接跟随", 路径查找_符号链接次数],
        ["挂载穿越", 路径查找_挂载穿越次数],
        ["权限缓存条数", 计数(权限_缓存表)]
    ]
}

函数 路径查找_诊断报告() {
    定义 命中率 = 0
    如果 (路径查找_总次数 > 0) {
        命中率 = (路径查找_命中次数 * 1000) / 路径查找_总次数  // FP1000
    }
    返回 [
        ["总查找次数", 路径查找_总次数],
        ["缓存命中", 路径查找_命中次数],
        ["命中率FP1000", 命中率],
        ["符号链接跟随", 路径查找_符号链接次数],
        ["挂载穿越", 路径查找_挂载穿越次数],
        ["权限缓存条数", 计数(权限_缓存表)],
        ["最大symlink深度", 最大符号链接深度]
    ]
}

定义 可变 AI路径_热路径表 = []
定义 可变 AI路径_缓存预热数 = 0

函数 AI路径_记录热路径(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI路径_热路径表)) {
        如果 (AI路径_热路径表[i].路径 == 路径) {
            AI路径_热路径表[i].频率 = AI路径_热路径表[i].频率 + 1
            返回
        }
        i = i + 1
    }
    如果 (计数(AI路径_热路径表) < 64) {
        追加(AI路径_热路径表, { 路径: 路径, 频率: 1 })
    }
}

函数 AI路径_预热缓存() {
    // 启动时预加载高频路径到dentry缓存
    定义 可变 i = 0
    当 (i < 计数(AI路径_热路径表)) {
        如果 (AI路径_热路径表[i].频率 > 10) {
            AI路径_缓存预热数 = AI路径_缓存预热数 + 1
        }
        i = i + 1
    }
}

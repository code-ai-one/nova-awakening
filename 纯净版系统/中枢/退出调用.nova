定义 CLONE_VM     = 0x00000100
定义 CLONE_FS     = 0x00000200
定义 CLONE_FILES  = 0x00000400
定义 CLONE_SIGHAND = 0x00000800
定义 CLONE_THREAD = 0x00010000

函数 sys_clone_增强(flags, stack, ptid, ctid, tls, _f) {

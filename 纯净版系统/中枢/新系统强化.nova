导入("./类型定义.nova")
导入("./错误码.nova")
导入("../感知/内核直连层.nova")
导入("./内存初始化.nova")

定义 最大状态 = 256
定义 最大动作 = 16
定义 回放容量 = 512
定义 学习率 = 100
定义 折扣因子 = 950
定义 基数 = 1024
定义 初始探索 = 800
定义 探索衰减 = 995
定义 最小探索 = 50

结构 经验项 {
    状态,
    动作,
    奖励,
    新状态,
    终止,
}

定义 可变 值表 = 0
定义 可变 回放缓冲 = 0
定义 可变 回放数量 = 0
定义 可变 回放写位 = 0
定义 可变 探索率 = 初始探索
定义 可变 随机种子 = 12345
定义 可变 训练步数 = 0
定义 可变 总奖励 = 0
定义 可变 轮次数 = 0
定义 可变 臂数 = 0
定义 可变 臂拉取 = 0
定义 可变 臂值表 = 0
定义 可变 臂计数表 = 0

函数 伪随机(种子) {
    定义 可变 x = 种子 + 1
    x = x ^ (x << 13)
    x = x ^ (x >> 17)
    x = x ^ (x << 5)
    如果 (x < 0) { x = 0 - x }
    返回 x
}

函数 强化_初始化() {
    值表 = 堆_分配(最大状态 * 最大动作 * 4)
    定义 可变 序号 = 0
    当 (序号 < 最大状态 * 最大动作) {
        内存_写32(值表 + 序号 * 4, 0)
        序号 = 序号 + 1
    }
    回放缓冲 = 堆_分配(回放容量 * 40)
    回放数量 = 0
    回放写位 = 0
    探索率 = 初始探索
}

函数 强化_获取值(状态, 动作) {
    如果 (状态 >= 最大状态 || 动作 >= 最大动作) { 返回 0 }
    返回 内存_读32(值表 + (状态 * 最大动作 + 动作) * 4)
}

函数 强化_设值(状态, 动作, 值) {
    如果 (状态 >= 最大状态 || 动作 >= 最大动作) { 返回 }
    内存_写32(值表 + (状态 * 最大动作 + 动作) * 4, 值)
}

函数 强化_选择动作(状态, 动作数) {
    随机种子 = 伪随机(随机种子)
    如果 (随机种子 % 基数 < 探索率) {
        返回 随机种子 % 动作数
    }
    定义 可变 最优动作 = 0
    定义 可变 最优值 = 强化_获取值(状态, 0)
    定义 可变 序号 = 1
    当 (序号 < 动作数) {
        定义 值 = 强化_获取值(状态, 序号)
        如果 (值 > 最优值) { 最优值 = 值; 最优动作 = 序号 }
        序号 = 序号 + 1
    }
    返回 最优动作
}

函数 强化_存经验(状态, 动作, 奖励, 新状态, 终止) {
    定义 偏移 = 回放缓冲 + 回放写位 * 40
    内存_写64(偏移, 状态)
    内存_写64(偏移 + 8, 动作)
    内存_写64(偏移 + 16, 奖励)
    内存_写64(偏移 + 24, 新状态)
    内存_写64(偏移 + 32, 终止)
    回放写位 = (回放写位 + 1) % 回放容量
    如果 (回放数量 < 回放容量) { 回放数量 = 回放数量 + 1 }
}

函数 强化_训练步(动作数) {
    如果 (回放数量 < 32) { 返回 }
    训练步数 = 训练步数 + 1
    定义 可变 批次 = 0
    当 (批次 < 16) {
        随机种子 = 伪随机(随机种子)
        定义 索引 = 随机种子 % 回放数量
        定义 偏移 = 回放缓冲 + 索引 * 40
        定义 状态 = 内存_读64(偏移)
        定义 动作 = 内存_读64(偏移 + 8)
        定义 奖励 = 内存_读64(偏移 + 16)
        定义 新状态 = 内存_读64(偏移 + 24)
        定义 终止 = 内存_读64(偏移 + 32)
        定义 当前值 = 强化_获取值(状态, 动作)
        定义 可变 目标 = 奖励
        如果 (!终止) {
            定义 可变 最大新值 = 强化_获取值(新状态, 0)
            定义 可变 搜索 = 1
            当 (搜索 < 动作数) {
                定义 新值 = 强化_获取值(新状态, 搜索)
                如果 (新值 > 最大新值) { 最大新值 = 新值 }
                搜索 = 搜索 + 1
            }
            目标 = 奖励 + 折扣因子 * 最大新值 / 基数
        }
        定义 更新值 = 当前值 + 学习率 * (目标 - 当前值) / 基数
        强化_设值(状态, 动作, 更新值)
        总奖励 = 总奖励 + 奖励
        批次 = 批次 + 1
    }
    探索率 = 探索率 * 探索衰减 / 基数
    如果 (探索率 < 最小探索) { 探索率 = 最小探索 }
}

函数 臂_初始化(数量) {
    臂数 = 数量
    臂值表 = 堆_分配(数量 * 4)
    臂计数表 = 堆_分配(数量 * 4)
    定义 可变 序号 = 0
    当 (序号 < 数量) {
        内存_写32(臂值表 + 序号 * 4, 0)
        内存_写32(臂计数表 + 序号 * 4, 0)
        序号 = 序号 + 1
    }
}

函数 臂_选择() {
    臂拉取 = 臂拉取 + 1
    随机种子 = 伪随机(随机种子)
    如果 (随机种子 % 基数 < 探索率) {
        返回 随机种子 % 臂数
    }
    定义 可变 最优 = 0
    定义 可变 最优值 = 内存_读32(臂值表)
    定义 可变 序号 = 1
    当 (序号 < 臂数) {
        定义 值 = 内存_读32(臂值表 + 序号 * 4)
        定义 计数 = 内存_读32(臂计数表 + 序号 * 4)
        定义 探索加成 = 0
        如果 (计数 > 0 && 臂拉取 > 0) {
            探索加成 = 整数开方(2 * 对数近似(臂拉取) * 基数 / 计数)
        }
        如果 (值 + 探索加成 > 最优值) { 最优值 = 值 + 探索加成; 最优 = 序号 }
        序号 = 序号 + 1
    }
    返回 最优
}

函数 臂_更新(臂号, 奖励) {
    如果 (臂号 >= 臂数) { 返回 }
    定义 旧值 = 内存_读32(臂值表 + 臂号 * 4)
    定义 旧计数 = 内存_读32(臂计数表 + 臂号 * 4)
    定义 新计数 = 旧计数 + 1
    定义 新值 = 旧值 + (奖励 - 旧值) / 新计数
    内存_写32(臂值表 + 臂号 * 4, 新值)
    内存_写32(臂计数表 + 臂号 * 4, 新计数)
}

函数 对数近似(n) {
    如果 (n <= 1) { 返回 0 }
    定义 可变 结果 = 0
    定义 可变 值 = n
    当 (值 > 1) { 值 = 值 / 2; 结果 = 结果 + 1 }
    返回 结果
}

函数 整数开方(n) {
    如果 (n <= 0) { 返回 0 }
    定义 可变 x = n
    定义 可变 y = (x + 1) / 2
    当 (y < x) { x = y; y = (x + n / x) / 2 }
    返回 x
}

函数 强化学习_完整统计() {
    返回 [训练步数, 总奖励, 轮次数, 回放数量, 臂拉取, 探索率]
}

导入("../中枢/系统调用表.nova")

// §4 Cookie + 存储

定义 Cookie_最大 = 256

结构 Cookie {
    名称,
    值,
    域,
    路径,
    过期时间,
    安全,
    HttpOnly,
    SameSite,    // u8 0=None 1=Lax 2=Strict
}

定义 可变 Cookie_存储 = []

函数 Cookie_设置(域, 名称, 值, 过期, 安全) {
    // 先查找是否已存在
    定义 可变 i = 0
    当 (i < 计数(Cookie_存储)) {
        如果 (Cookie_存储[i].域 == 域 && Cookie_存储[i].名称 == 名称) {
            Cookie_存储[i].值 = 值
            Cookie_存储[i].过期时间 = 过期
            返回
        }
        i = i + 1
    }
    如果 (计数(Cookie_存储) >= Cookie_最大) { 返回 }
    定义 c = Cookie {}
    c.名称 = 名称; c.值 = 值; c.域 = 域
    c.路径 = "/"; c.过期时间 = 过期; c.安全 = 安全
    c.HttpOnly = 假; c.SameSite = 1
    追加(Cookie_存储, c)
}

函数 Cookie_获取(域, 名称) {
    定义 可变 i = 0
    当 (i < 计数(Cookie_存储)) {
        如果 (Cookie_存储[i].域 == 域 && Cookie_存储[i].名称 == 名称) {
            返回 Cookie_存储[i].值
        }
        i = i + 1
    }
    返回 ""
}

函数 Cookie_域所有(域) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(Cookie_存储)) {
        如果 (Cookie_存储[i].域 == 域) { 追加(结果, Cookie_存储[i]) }
        i = i + 1
    }
    返回 结果
}

// Local存储
定义 可变 本地存储 = []   // [[key, value], ...]

函数 Local存储_设置(键, 值) {
    定义 可变 i = 0
    当 (i < 计数(本地存储)) {
        如果 (本地存储[i][0] == 键) { 本地存储[i][1] = 值; 返回 }
        i = i + 1
    }
    追加(本地存储, [键, 值])
}

函数 Local存储_获取(键) {
    定义 可变 i = 0
    当 (i < 计数(本地存储)) {
        如果 (本地存储[i][0] == 键) { 返回 本地存储[i][1] }
        i = i + 1
    }
    返回 空
}

// §5 书签

结构 书签 {
    标题,
    URL,
    文件夹,
    添加时间,
}

函数 书签_添加(标题, URL, 文件夹) {
    如果 (计数(全局书签) >= 最大书签) { 返回 }
    定义 bm = 书签 {}
    bm.标题 = 标题; bm.URL = URL; bm.文件夹 = 文件夹
    bm.添加时间 = 浏览器_时钟
    追加(全局书签, bm)
}

函数 书签_删除(URL) {
    定义 可变 i = 0
    当 (i < 计数(全局书签)) {
        如果 (全局书签[i].URL == URL) { 删除(全局书签, i); 返回 }
        i = i + 1
    }
}

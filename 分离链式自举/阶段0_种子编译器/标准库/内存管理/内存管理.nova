导入("../基础.nova")


// 内存块
// 块: [地址, 大小, 状态(0空闲/1占用/2标记), 引用计数, 代(0新/1老), 颜色(0白/1灰/2黑)]

定义 块_地址 = 0
定义 块_大小 = 1
定义 块_状态 = 2
定义 块_引用 = 3
定义 块_代 = 4
定义 块_颜色 = 5

函数 内存块_创建(地址, 大小) { 返回 [地址, 大小, 0,] }

// 空闲链表分配器
定义 可变 堆_块列表 = []
定义 可变 堆_下一地址 = 0x1000
定义 可变 堆_总分配 = 0
定义 可变 堆_总释放 = 0
定义 可变 堆_峰值 = 0
定义 可变 堆_当前使用 = 0

函数 堆_分配(大小) {
 // First-Fit: 查找空闲块
 定义 可变 i = 0
 当 (i < 计数(堆_块列表)) { 定义 blk = 堆_块列表[i]
 如果 (blk[块_状态] == 0 且 blk[块_大小] >= 大小) {
 blk[块_状态] = 1
 blk[块_引用] = 1
 堆_总分配 = 堆_总分配 + 1
 堆_当前使用 = 堆_当前使用 + blk[块_大小]
 如果 (堆_当前使用 > 堆_峰值) { 堆_峰值 = 堆_当前使用 }
 返回 blk[块_地址]
 }
 i = i + 1
 }
 // 无合适空闲块, 新分配
 定义 对齐大小 = ((大小 + 7) / 8) * 8
 定义 地址 = 堆_下一地址
 追加(堆_块列表, [地址, 对齐大小, 1, 1,])
 堆_下一地址 = 堆_下一地址 + 对齐大小
 堆_总分配 = 堆_总分配 + 1
 堆_当前使用 = 堆_当前使用 + 对齐大小
 如果 (堆_当前使用 > 堆_峰值) { 堆_峰值 = 堆_当前使用 }
 返回 地址
}

函数 堆_查找块(地址) { 定义 可变 i = 0
 当 (i < 计数(堆_块列表)) { 如果 (堆_块列表[i][块_地址] == 地址) { 返回 i }
 i = i + 1
 }
 返回 -1
}

函数 堆_释放(地址) { 定义 索引 = 堆_查找块(地址)
 如果 (索引 < 0) { 返回 假 }
 定义 blk = 堆_块列表[索引]
 如果 (blk[块_状态] != 1) { 返回 假 }
 blk[块_状态] = 0
 blk[块_引用] = 0
 blk[块_颜色] = 0
 堆_总释放 = 堆_总释放 + 1
 堆_当前使用 = 堆_当前使用 - blk[块_大小]
 返回 真
}

// 引用计数
函数 堆_增引用(地址) { 定义 索引 = 堆_查找块(地址)
 如果 (索引 < 0) { 返回 0 }
 堆_块列表[索引][块_引用] = 堆_块列表[索引][块_引用] + 1
 返回 堆_块列表[索引][块_引用]
}

函数 堆_减引用(地址) { 定义 索引 = 堆_查找块(地址)
 如果 (索引 < 0) { 返回 0 }
 堆_块列表[索引][块_引用] = 堆_块列表[索引][块_引用] - 1
 如果 (堆_块列表[索引][块_引用] <= 0) {
 堆_释放(地址)
 返回 0
 }
 返回 堆_块列表[索引][块_引用]
}

函数 堆_引用数(地址) { 定义 索引 = 堆_查找块(地址)
 如果 (索引 < 0) { 返回 0 }
 返回 堆_块列表[索引][块_引用]
}

// 三色标记GC
// 白=0(未访问), 灰=1(待处理), 黑=2(已完成)

函数 GC_重置颜色() { 定义 可变 i = 0
 当 (i < 计数(堆_块列表)) { 如果 (堆_块列表[i][块_状态] == 1) { 堆_块列表[i][块_颜色] = 0 }
 i = i + 1
 }
}

函数 GC_标记引用目标(目标) {
    如果 (目标 < 0 或 目标 >= 计数(堆_块列表)) { 返回 空
}
 如果 (堆_块列表[目标][块_颜色] == 0 且 堆_块列表[目标][块_状态] == 1) {
 堆_块列表[目标][块_颜色] = 1
 }
}

函数 GC_标记根(根地址列表) { 定义 可变 i = 0
 当 (i < 计数(根地址列表)) { 定义 索引 = 堆_查找块(根地址列表[i])
 如果 (索引 >= 0 且 堆_块列表[索引][块_状态] == 1) {
 堆_块列表[索引][块_颜色] = 1
 }
 i = i + 1
 }
}

// 引用表: [[源块索引, 目标块索引], ...] — 记录块间引用关系
定义 可变 堆_引用表 = []

函数 堆_添加引用(源地址, 目标地址) { 定义 si = 堆_查找块(源地址)
 定义 ti = 堆_查找块(目标地址)
 如果 (si >= 0 且 ti >= 0) {
 追加(堆_引用表, [si, ti])
 }
}

函数 堆_移除引用(源地址, 目标地址) { 定义 si = 堆_查找块(源地址)
 定义 ti = 堆_查找块(目标地址)
 定义 可变 i = 0
 当 (i < 计数(堆_引用表)) { 如果 (堆_引用表[i][0] == si 且 堆_引用表[i][1] == ti) {
 删除(堆_引用表, i)
 返回
 }
 i = i + 1
 }
}

函数 GC_传播() {
    定义 可变 ri = 0
 // 三色标记传播: 灰色块→扫描其引用目标→标灰→自身变黑
 // 迭代直到没有灰色块 (不动点)
 定义 可变 有灰色 = 真
 当 (有灰色) {
 有灰色 = 假
 定义 可变 i = 0
 当 (i < 计数(堆_块列表)) { 如果 (堆_块列表[i][块_颜色] == 1) {
 // 扫描此块引用的所有目标块, 将白色目标标灰
 当 (ri < 计数(堆_引用表)) { 如果 (堆_引用表[ri][0] == i) {
 GC_标记引用目标(堆_引用表[ri][1])
 }
 ri = ri + 1
 }
 // 当前块灰→黑
 堆_块列表[i][块_颜色] = 2
 有灰色 = 真
 }
 i = i + 1
 }
 }
}

函数 GC_清除() { 定义 可变 清除数 = 0
 定义 可变 i = 0
 当 (i < 计数(堆_块列表)) { 如果 (堆_块列表[i][块_状态] == 1 且 堆_块列表[i][块_颜色] == 0) {
 堆_块列表[i][块_状态] = 0
 堆_块列表[i][块_引用] = 0
 堆_当前使用 = 堆_当前使用 - 堆_块列表[i][块_大小]
 堆_总释放 = 堆_总释放 + 1
 清除数 = 清除数 + 1
 }
 i = i + 1
 }
 返回 清除数
}

函数 内存_GC_收集(根地址列表) {
 GC_重置颜色()
 GC_标记根(根地址列表)
 GC_传播()
 返回 GC_清除()
}

// 分代GC
函数 GC_提升到老代(地址) { 定义 索引 = 堆_查找块(地址)
 如果 (索引 >= 0) { 堆_块列表[索引][块_代] = 1 }
}

函数 GC_新生代收集(根地址列表) {
 // 只标记新代(代==0)的白色对象为可回收
 GC_重置颜色()
 GC_标记根(根地址列表)
 GC_传播()
 定义 可变 清除数 = 0
 定义 可变 i = 0
 当 (i < 计数(堆_块列表)) { 如果 (堆_块列表[i][块_状态] == 1 且 堆_块列表[i][块_颜色] == 0 且 堆_块列表[i][块_代] == 0) {
 堆_块列表[i][块_状态] = 0
 堆_块列表[i][块_引用] = 0
 堆_当前使用 = 堆_当前使用 - 堆_块列表[i][块_大小]
 堆_总释放 = 堆_总释放 + 1
 清除数 = 清除数 + 1
 }
 i = i + 1
 }
 返回 清除数
}

// 池分配器 (固定大小块)
// 池: [块大小, 容量, 已分配位图, 基地址]
函数 池_创建(块大小, 容量) { 定义 可变 位图 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(位图, 0)
 i = i + 1 }
 返回 [块大小, 容量, 位图, 堆_分配(块大小 * 容量)]
}

函数 池_分配(池) { 定义 可变 i = 0
 当 (i < 池[1]) { 如果 (池[2][i] == 0) {
 池[2][i] = 1
 返回 池[3] + i * 池[0]
 }
 i = i + 1
 }
 返回 -1
}

函数 池_释放(池, 地址) { 定义 偏移 = 地址 - 池[3]
 定义 索引 = 偏移 / 池[0]
 如果 (索引 >= 0 且 索引 < 池[1]) {
 池[2][索引] = 0
 返回 真
 }
 返回 假
}

函数 池_已用数(池) { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 池[1]) { 如果 (池[2][i] == 1) { c = c + 1 }
 i = i + 1 }
 返回 c
}

// Arena分配器 (只增长, 整体释放)
// Arena: [基地址, 容量, 当前偏移]
函数 Arena_创建(容量) { 返回 [堆_分配(容量), 容量, 0] }

函数 Arena_分配(arena, 大小) { 定义 对齐 = ((大小 + 7) / 8) * 8
 如果 (arena[2] + 对齐 > arena[1]) { 返回 -1 }
 定义 地址 = arena[0] + arena[2]
 arena[2] = arena[2] + 对齐
 返回 地址
}

函数 Arena_重置(arena) { arena[2] = 0 }
函数 Arena_已用(arena) { 返回 arena[2] }
函数 Arena_剩余(arena) { 返回 arena[1] - arena[2] }

// 统计
函数 堆_空闲块数() { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(堆_块列表)) { 如果 (堆_块列表[i][块_状态] == 0) { c = c + 1 }
 i = i + 1
 }
 返回 c
}

函数 堆_占用块数() { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(堆_块列表)) { 如果 (堆_块列表[i][块_状态] == 1) { c = c + 1 }
 i = i + 1
 }
 返回 c
}

// 总块数
函数 堆_总块数() { 返回 计数(堆_块列表) }

// 碎片率
函数 堆_碎片率() { 定义 总 = 堆_总块数()
 如果 (总 == 0) { 返回 0 }
 返回 堆_空闲块数() * 100 / 总
}

// 内存管理 v2 — Buddy / Slab / 紧凑化GC / 逃逸分析

// Buddy分配器 (伙伴系统)
// 经典内存分配算法: 按2的幂次管理内存块
// 优点: O(log n)分配/释放, 自动合并相邻空闲块, 低碎片
// 结构: 每层维护空闲链表, 层k管理大小为2^k的块

定义 BUDDY_最大阶 = 20     // 最大块 = 2^20 = 1MB
定义 BUDDY_最小块 = 64     // 最小块 = 64字节 (2^6)
定义 BUDDY_最小阶 = 6

// Buddy分配器: [总大小, 基地址, 空闲表[0..最大阶], 已分配表]
函数 Buddy_创建(总大小) {
    定义 可变 空闲表 = []
    定义 可变 i = 0
    当 (i <= BUDDY_最大阶) { 追加(空闲表, []); i = i + 1 }
    // 初始: 整块放入最大阶空闲表
    定义 阶 = Buddy_求阶(总大小)
    追加(空闲表[阶], 0)  // 偏移0处有一个完整块
    返回 [总大小, 0x10000, 空闲表, []]
}

函数 Buddy_求阶(大小) {
    定义 可变 阶 = BUDDY_最小阶
    当 (阶 <= BUDDY_最大阶) {
        如果 ((1 << 阶) >= 大小) { 返回 阶 }
        阶 = 阶 + 1
    }
    返回 BUDDY_最大阶
}

函数 Buddy_分配(buddy, 请求大小) {
    定义 需要阶 = Buddy_求阶(请求大小)
    如果 (需要阶 > BUDDY_最大阶) { 返回 -1 }
    // 从需要阶向上找空闲块
    定义 可变 阶 = 需要阶
    当 (阶 <= BUDDY_最大阶) {
        如果 (计数(buddy[2][阶]) > 0) {
            // 取出空闲块
            定义 n = 计数(buddy[2][阶])
            定义 偏移 = buddy[2][阶][n - 1]
            定义 可变 新链 = []
            定义 可变 j = 0
            当 (j < n - 1) { 追加(新链, buddy[2][阶][j]); j = j + 1 }
            buddy[2][阶] = 新链
            // 逐级分裂到需要阶
            定义 可变 当前阶 = 阶
            当 (当前阶 > 需要阶) {
                当前阶 = 当前阶 - 1
                定义 伙伴偏移 = 偏移 + (1 << 当前阶)
                追加(buddy[2][当前阶], 伙伴偏移)
            }
            追加(buddy[3], [偏移, 需要阶])
            返回 buddy[1] + 偏移
        }
        阶 = 阶 + 1
    }
    返回 -1
}

函数 Buddy_释放(buddy, 地址) {
    定义 偏移 = 地址 - buddy[1]
    // 查找已分配记录
    定义 可变 阶 = -1
    定义 可变 idx = -1
    定义 可变 i = 0
    当 (i < 计数(buddy[3])) {
        如果 (buddy[3][i][0] == 偏移) { 阶 = buddy[3][i][1]; idx = i }
        i = i + 1
    }
    如果 (阶 < 0) { 返回 假 }
    // 移除已分配记录
    定义 可变 新分配 = []
    i = 0
    当 (i < 计数(buddy[3])) {
        如果 (i != idx) { 追加(新分配, buddy[3][i]) }
        i = i + 1
    }
    buddy[3] = 新分配
    // 递归合并伙伴
    定义 可变 当前偏移 = 偏移
    定义 可变 当前阶 = 阶
    当 (当前阶 < BUDDY_最大阶) {
        定义 伙伴 = 当前偏移 ^ (1 << 当前阶)
        // 在空闲表中查找伙伴
        定义 可变 伙伴idx = -1
        i = 0
        当 (i < 计数(buddy[2][当前阶])) {
            如果 (buddy[2][当前阶][i] == 伙伴) { 伙伴idx = i }
            i = i + 1
        }
        如果 (伙伴idx < 0) {
            // 伙伴未空闲, 停止合并
            追加(buddy[2][当前阶], 当前偏移)
            返回 真
        }
        // 移除伙伴, 合并到上一阶
        定义 可变 新链 = []
        i = 0
        当 (i < 计数(buddy[2][当前阶])) {
            如果 (i != 伙伴idx) { 追加(新链, buddy[2][当前阶][i]) }
            i = i + 1
        }
        buddy[2][当前阶] = 新链
        如果 (伙伴 < 当前偏移) { 当前偏移 = 伙伴 }
        当前阶 = 当前阶 + 1
    }
    追加(buddy[2][当前阶], 当前偏移)
    返回 真
}

// Slab分配器 (对象缓存)
// 专用于固定大小对象的高速分配, 消除碎片
// 每种对象大小一个Slab, 内部是等大小slot链表
// 常见于内核: kmalloc/kfree的后端

// Slab: [对象大小, 每页slot数, 页列表, 空闲slot栈]
函数 Slab_创建(对象大小, 页大小) {
    定义 每页slot = 页大小 / ((对象大小 + 7) / 8 * 8)
    如果 (每页slot < 1) { 每页slot = 1 }
    返回 [对象大小, 每页slot, [], []]
}

函数 Slab_扩容(slab) {
    // 分配新页, 将所有slot加入空闲栈
    定义 页基址 = 堆_分配(slab[1] * ((slab[0] + 7) / 8 * 8))
    追加(slab[2], 页基址)
    定义 对齐大小 = (slab[0] + 7) / 8 * 8
    定义 可变 i = slab[1] - 1
    当 (i >= 0) {
        追加(slab[3], 页基址 + i * 对齐大小)
        i = i - 1
    }
}

函数 Slab_分配(slab) {
    如果 (计数(slab[3]) == 0) { Slab_扩容(slab) }
    定义 n = 计数(slab[3])
    定义 地址 = slab[3][n - 1]
    定义 可变 新栈 = []
    定义 可变 i = 0
    当 (i < n - 1) { 追加(新栈, slab[3][i]); i = i + 1 }
    slab[3] = 新栈
    返回 地址
}

函数 Slab_释放(slab, 地址) {
    追加(slab[3], 地址)
}

函数 Slab_已分配(slab) {
    定义 总slot = 计数(slab[2]) * slab[1]
    返回 总slot - 计数(slab[3])
}

// 紧凑化移动GC (Compacting GC)
// 标记-整理算法: 标记存活对象→计算新地址→移动→更新引用
// 消除碎片, 改善缓存局部性
// 分两阶段: 1)标记(复用三色标记) 2)整理(滑动压缩)

函数 GC_紧凑化(根地址列表) {
    // 阶段1: 标记存活
    GC_重置颜色()
    GC_标记根(根地址列表)
    GC_传播()
    // 阶段2: 计算新地址 (滑动压缩)
    定义 可变 新地址映射 = []     // [旧索引, 新地址]
    定义 可变 写指针 = 堆_块列表[0][块_地址]
    定义 可变 i = 0
    定义 可变 存活数 = 0
    当 (i < 计数(堆_块列表)) {
        如果 (堆_块列表[i][块_状态] == 1 且 堆_块列表[i][块_颜色] > 0) {
            追加(新地址映射, [i, 写指针])
            写指针 = 写指针 + 堆_块列表[i][块_大小]
            存活数 = 存活数 + 1
        }
        i = i + 1
    }
    // 阶段3: 更新引用表中的地址
    定义 可变 j = 0
    当 (j < 计数(堆_引用表)) {
        定义 可变 k = 0
        当 (k < 计数(新地址映射)) {
            如果 (新地址映射[k][0] == 堆_引用表[j][0]) {
                堆_引用表[j][0] = 新地址映射[k][0]
            }
            如果 (新地址映射[k][0] == 堆_引用表[j][1]) {
                堆_引用表[j][1] = 新地址映射[k][0]
            }
            k = k + 1
        }
        j = j + 1
    }
    // 阶段4: 移动块到新位置, 释放死对象
    定义 可变 新块列表 = []
    i = 0
    当 (i < 计数(新地址映射)) {
        定义 旧idx = 新地址映射[i][0]
        定义 新addr = 新地址映射[i][1]
        定义 blk = 堆_块列表[旧idx]
        追加(新块列表, [新addr, blk[块_大小], 1, blk[块_引用], blk[块_代], 2])
        i = i + 1
    }
    // 更新全局状态
    堆_块列表 = 新块列表
    堆_当前使用 = 写指针 - 堆_块列表[0][块_地址]
    堆_下一地址 = 写指针
    返回 存活数
}

// 逃逸分析联动 (Escape Analysis Integration)
// 与编译器语义层的生命期分析协作
// 未逃逸的对象: 栈分配 → 零GC开销
// 逃逸的对象: 堆分配 → 进入GC管理
// 标记: [变量ID, 逃逸类型, 推荐分配策略]

定义 分配_栈 = 0
定义 分配_堆 = 1
定义 分配_池 = 2    // 对象池(频繁创建销毁)

函数 逃逸分析_推荐策略(逃逸类型, 对象大小, 生命期长度) {
    // 未逃逸 + 小对象 + 短生命期 → 栈分配
    如果 (逃逸类型 == 0 且 对象大小 <= 4096 且 生命期长度 <= 100) {
        返回 分配_栈
    }
    // 未逃逸 + 频繁创建 → 对象池
    如果 (逃逸类型 == 0 且 生命期长度 <= 10) {
        返回 分配_池
    }
    // 默认堆分配
    返回 分配_堆
}

// 分配策略统计
定义 可变 策略_栈次数 = 0
定义 可变 策略_堆次数 = 0
定义 可变 策略_池次数 = 0

函数 策略_记录(策略) {
    如果 (策略 == 分配_栈) { 策略_栈次数 = 策略_栈次数 + 1 }
    如果 (策略 == 分配_堆) { 策略_堆次数 = 策略_堆次数 + 1 }
    如果 (策略 == 分配_池) { 策略_池次数 = 策略_池次数 + 1 }
}

函数 策略_报告() {
    打印("分配策略: 栈=" + 转字符串(策略_栈次数) + " 堆=" + 转字符串(策略_堆次数) + " 池=" + 转字符串(策略_池次数))
    定义 总 = 策略_栈次数 + 策略_堆次数 + 策略_池次数
    如果 (总 > 0) {
        打印("栈占比: " + 转字符串(策略_栈次数 * 100 / 总) + "%")
    }
}

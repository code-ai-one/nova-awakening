// NovaOS AI拥塞预测 — 先天AI特性
// Phase: P4 | AI融入传控拥塞控制
// 核心算法:
//   1. Nova往返时间趋势分析: 线性回归拟合Nova往返时间斜率→正斜率=拥塞趋势
//   2. Nova往返时间方差检测: 方差突然增大→网络抖动/拥塞前兆
//   3. 丢包率预测: 基于Nova往返时间斜率和方差的联合概率
//   4. 提前窗口调整: 预测到拥塞时提前缩窗, 避免丢包

定义 可变 Nova往返时间历史 = []          // [时间戳, Nova往返时间微秒]
定义 Nova往返时间_窗口 = 32
定义 可变 Nova往返时间_EMA = 0           // 平滑Nova往返时间 × 1024
定义 可变 Nova往返时间_方差EMA = 0       // Nova往返时间方差EMA × 1024
定义 可变 Nova往返时间_斜率 = 0          // 微秒/秒 (正=上升)
定义 可变 拥塞概率 = 0          // 0-1000
定义 可变 丢包率EMA = 0         // × 1024
定义 可变 AI拥塞_已初始化 = 假

函数 AI拥塞_初始化() {
    AI拥塞_已初始化 = 真
    内核信息("AI拥塞预测: Nova往返时间线性回归+方差检测+联合概率窗口调整")
}

// 记录Nova往返时间样本

函数 AI拥塞_记录Nova往返时间(Nova往返时间) {
    定义 现在 = 读取毫秒()
    追加(Nova往返时间历史, [现在, Nova往返时间])
    如果 (计数(Nova往返时间历史) > Nova往返时间_窗口) { 链表_删除(Nova往返时间历史, 0) }

    // 1. Nova往返时间 EMA
    Nova往返时间_EMA = (Nova往返时间_EMA * 922 + Nova往返时间 * 1024 * 102) / (1024 * 1024)

    // 2. 方差EMA: |Nova往返时间 - ema|
    定义 偏差 = Nova往返时间 * 1024 - Nova往返时间_EMA
    如果 (偏差 < 0) { 偏差 = 0 - 偏差 }
    Nova往返时间_方差EMA = (Nova往返时间_方差EMA * 922 + 偏差 * 102) / 1024

    // 3. 线性回归计算斜率
    Nova往返时间_斜率 = AI拥塞_计算斜率()

    // 4. 拥塞概率 = f(斜率, 方差)
    定义 可变 概率 = 0
    如果 (Nova往返时间_斜率 > 0) {
        概率 = 概率 + Nova往返时间_斜率 * 2   // 斜率越大, 拥塞越可能
        如果 (概率 > 500) { 概率 = 500 }
    }
    如果 (Nova往返时间_方差EMA > Nova往返时间_EMA / 2) {
        概率 = 概率 + 300   // 高方差→不稳定→拥塞前兆
    }
    如果 (丢包率EMA > 50) {
        概率 = 概率 + 200   // 已有丢包→确认拥塞
    }
    如果 (概率 > 1000) { 概率 = 1000 }
    拥塞概率 = 概率
}

函数 AI拥塞_记录丢包() {
    丢包率EMA = (丢包率EMA * 922 + 1024 * 102) / 1024
}

// 线性回归: Nova往返时间随时间的斜率

函数 AI拥塞_计算斜率() {
    定义 n = 计数(Nova往返时间历史)
    如果 (n < 3) { 返回 0 }

    定义 可变 sum_x = 0
    定义 可变 sum_y = 0
    定义 可变 sum_xy = 0
    定义 可变 sum_x2 = 0
    定义 基准 = Nova往返时间历史[0][0]

    定义 可变 i = 0
    当 (i < n) {
        定义 x = (Nova往返时间历史[i][0] - 基准)   // 毫秒
        定义 y = Nova往返时间历史[i][1]             // 微秒
        sum_x = sum_x + x
        sum_y = sum_y + y
        sum_xy = sum_xy + x * y
        sum_x2 = sum_x2 + x * x
        i = i + 1
    }

    定义 分母 = n * sum_x2 - sum_x * sum_x
    如果 (分母 == 0) { 返回 0 }
    返回 (n * sum_xy - sum_x * sum_y) / 分母  // 微秒/毫秒
}

// 决策接口

函数 AI拥塞_预测() {
    返回 拥塞概率 > 500
}

函数 AI拥塞_概率() { 返回 拥塞概率 }

函数 AI拥塞_建议窗口(当前窗口) {
    如果 (拥塞概率 > 800) { 返回 当前窗口 / 2 }       // 高概率→激进缩窗
    如果 (拥塞概率 > 500) { 返回 当前窗口 * 3 / 4 }   // 中概率→温和缩窗
    如果 (拥塞概率 < 200) { 返回 当前窗口 * 5 / 4 }   // 低概率→可扩窗
    返回 当前窗口
}

函数 AI拥塞_Nova往返时间平滑() { 返回 Nova往返时间_EMA / 1024 }
函数 AI拥塞_Nova往返时间方差() { 返回 Nova往返时间_方差EMA / 1024 }

// 拥塞窗口自适应控制 

定义 可变 Nova拥塞窗口_当前 = 10       // 当前拥塞窗口(MSS单位)
定义 可变 Nova拥塞窗口_慢启动阈值 = 64
定义 可变 Nova拥塞窗口_模式 = 0        // 0=慢启动 1=拥塞避免 2=快速恢复

函数 AI拥塞_更新窗口(是否丢包) {
    如果 (是否丢包) {
        AI拥塞_记录丢包()
        // 丢包: 进入快速恢复
        Nova拥塞窗口_慢启动阈值 = Nova拥塞窗口_当前 / 2
        如果 (Nova拥塞窗口_慢启动阈值 < 2) { Nova拥塞窗口_慢启动阈值 = 2 }
        Nova拥塞窗口_当前 = Nova拥塞窗口_慢启动阈值
        Nova拥塞窗口_模式 = 2
        返回
    }

    // AI预测调整: 根据拥塞概率提前调整
    定义 AI建议 = AI拥塞_建议窗口(Nova拥塞窗口_当前)

    如果 (Nova拥塞窗口_模式 == 0) {
        // 慢启动: 指数增长
        Nova拥塞窗口_当前 = Nova拥塞窗口_当前 + 1
        如果 (Nova拥塞窗口_当前 >= Nova拥塞窗口_慢启动阈值) {
            Nova拥塞窗口_模式 = 1  // 进入拥塞避免
        }
    } 否则 如果 (Nova拥塞窗口_模式 == 1) {
        // 拥塞避免: 线性增长(每Nova往返时间 +1 MSS)
        Nova拥塞窗口_当前 = Nova拥塞窗口_当前 + 1
    } 否则 {
        // 快速恢复: 等待ACK
        Nova拥塞窗口_模式 = 1
    }

    // 应用AI建议(如果AI建议缩窗)
    如果 (AI建议 < Nova拥塞窗口_当前) {
        Nova拥塞窗口_当前 = AI建议
    }

    // 边界检查
    如果 (Nova拥塞窗口_当前 < 1) { Nova拥塞窗口_当前 = 1 }
    如果 (Nova拥塞窗口_当前 > 65535) { Nova拥塞窗口_当前 = 65535 }
}

函数 AI拥塞_获取窗口() { 返回 Nova拥塞窗口_当前 }
函数 AI拥塞_获取模式() { 返回 Nova拥塞窗口_模式 }

// 带宽估算 

定义 可变 带宽_EMA = 0         // 字节/秒 × 1024
定义 可变 上次ACK时间 = 0
定义 可变 上次ACK字节 = 0

函数 AI拥塞_记录ACK(确认字节数) {
    定义 现在 = 读取毫秒()
    如果 (上次ACK时间 > 0 && 现在 > 上次ACK时间) {
        定义 间隔 = 现在 - 上次ACK时间
        定义 瞬时带宽 = 确认字节数 * 1000 / 间隔  // 字节/秒
        带宽_EMA = (带宽_EMA * 922 + 瞬时带宽 * 1024 * 102) / (1024 * 1024)
    }
    上次ACK时间 = 现在
    上次ACK字节 = 确认字节数
}

函数 AI拥塞_估算带宽() { 返回 带宽_EMA / 1024 }

// 统计

函数 AI拥塞_统计() {
    返回 [拥塞概率, Nova往返时间_EMA / 1024, Nova往返时间_方差EMA / 1024, Nova往返时间_斜率,
           Nova拥塞窗口_当前, Nova拥塞窗口_模式, 带宽_EMA / 1024, 丢包率EMA / 1024]
}

// 拥塞模式名 + 拥塞级别名 + 完整统计

函数 AI拥塞_模式名(模式) {
    如果 (模式 == 0) { 返回 "slow_start" }
    如果 (模式 == 1) { 返回 "congestion_avoidance" }
    如果 (模式 == 2) { 返回 "fast_recovery" }
    返回 "unknown"
}

函数 AI拥塞_级别名() {
    如果 (拥塞概率 > 800) { 返回 "critical" }
    如果 (拥塞概率 > 500) { 返回 "warning" }
    如果 (拥塞概率 > 200) { 返回 "mild" }
    返回 "clear"
}

函数 AI拥塞_完整统计() {
    返回 [拥塞概率, Nova往返时间_EMA / 1024, Nova往返时间_方差EMA / 1024, Nova往返时间_斜率,
           Nova拥塞窗口_当前, Nova拥塞窗口_模式, 带宽_EMA / 1024, 丢包率EMA / 1024, 计数(Nova往返时间历史)]
}

// 三维权重: [斜率权重, 方差权重, 丢包权重] 随实际拥塞事件自适应
// 规则: 拥塞发生时增强预测中命中的权重, 降低未命中的权重
定义 可变 拥塞_斜率权重 = 500    // ×1000
定义 可变 拥塞_方差权重 = 300
定义 可变 拥塞_丢包权重 = 200
定义 拥塞_赫布学习率 = 50        // ×1000 每次更新量

函数 AI拥塞_赫布更新(真实发生拥塞) {
    // 赫布规则: 预测命中时增强权重, 命中率低时衰减
    定义 斜率命中 = 如果 (Nova往返时间_斜率 > 0 && 真实发生拥塞) { 1 } 否则 { 0 }
    定义 方差命中 = 如果 (Nova往返时间_方差EMA > Nova往返时间_EMA / 2 && 真实发生拥塞) { 1 } 否则 { 0 }
    定义 丢包命中 = 如果 (丢包率EMA > 50 && 真实发生拥塞) { 1 } 否则 { 0 }

    // 命中→增强; 未命中+拥塞→增强其他维度; 未命中+无拥塞→权重衰减
    如果 (斜率命中 == 1) {
        拥塞_斜率权重 = 拥塞_斜率权重 + 拥塞_赫布学习率
    } 否则如果 (!真实发生拥塞 && Nova往返时间_斜率 > 0) {
        拥塞_斜率权重 = 拥塞_斜率权重 - 拥塞_赫布学习率 / 2
    }
    如果 (方差命中 == 1) {
        拥塞_方差权重 = 拥塞_方差权重 + 拥塞_赫布学习率
    }
    如果 (丢包命中 == 1) {
        拥塞_丢包权重 = 拥塞_丢包权重 + 拥塞_赫布学习率
    }

    // 归一化: 保持三者之和=1000
    定义 总和 = 拥塞_斜率权重 + 拥塞_方差权重 + 拥塞_丢包权重
    如果 (总和 > 0) {
        拥塞_斜率权重 = 拥塞_斜率权重 * 1000 / 总和
        拥塞_方差权重 = 拥塞_方差权重 * 1000 / 总和
        拥塞_丢包权重 = 1000 - 拥塞_斜率权重 - 拥塞_方差权重
    }
    // 边界保护
    如果 (拥塞_斜率权重 < 100) { 拥塞_斜率权重 = 100 }
    如果 (拥塞_方差权重 < 100) { 拥塞_方差权重 = 100 }
    如果 (拥塞_丢包权重 < 100) { 拥塞_丢包权重 = 100 }
}

// 使用自适应权重重新计算拥塞概率
函数 AI拥塞_概率_自适应() {
    定义 可变 概率 = 0
    如果 (Nova往返时间_斜率 > 0) {
        概率 = 概率 + Nova往返时间_斜率 * 2 * 拥塞_斜率权重 / 1000
        如果 (概率 > 500) { 概率 = 500 }
    }
    如果 (Nova往返时间_方差EMA > Nova往返时间_EMA / 2) {
        概率 = 概率 + 300 * 拥塞_方差权重 / 1000
    }
    如果 (丢包率EMA > 50) {
        概率 = 概率 + 200 * 拥塞_丢包权重 / 1000
    }
    如果 (概率 > 1000) { 概率 = 1000 }
    返回 概率
}

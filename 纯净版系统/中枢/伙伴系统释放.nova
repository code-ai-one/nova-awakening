导入("./类型定义.nova")
导入("./同步原语.nova")
导入("../执行/内核智能.nova")
导入("./伙伴系统计.nova")
导入("./内存回收.nova")
导入("./字符串替换.nova")
导入("./每核页释放.nova")
导入("./自动扩容.nova")

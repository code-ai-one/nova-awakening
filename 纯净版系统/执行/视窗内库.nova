// §9 内置DLL — ntdll.dll / user32.dll / gdi32.dll / msvcrt.dll

函数 注册_内置DLL_ntdll() {
    定义 dll = PE模块 {}
    dll.名称 = "ntdll.dll"
    dll.是DLL = 真
    dll.基地址 = Win32_DLL_基址
    Win32_DLL_基址 = Win32_DLL_基址 + 0x100000
    dll.导出表 = []
    追加(dll.导出表, ["RtlInitUnicodeString", win32_RtlInitUnicodeString])
    追加(dll.导出表, ["NtClose", win32_CloseHandle])
    追加(dll.导出表, ["NtQueryInformationProcess", win32_NtQueryInformationProcess])
    追加(PE_已加载模块, dll)
}

函数 注册_内置DLL_user32() {
    定义 dll = PE模块 {}
    dll.名称 = "user32.dll"
    dll.是DLL = 真
    dll.基地址 = Win32_DLL_基址
    Win32_DLL_基址 = Win32_DLL_基址 + 0x100000
    dll.导出表 = []
    追加(dll.导出表, ["MessageBoxW", win32_MessageBoxW])
    追加(dll.导出表, ["MessageBoxA", win32_MessageBoxA])
    追加(dll.导出表, ["CreateWindowExW", win32_CreateWindowExW])
    追加(dll.导出表, ["ShowWindow", win32_ShowWindow])
    追加(dll.导出表, ["GetMessageW", win32_GetMessageW])
    追加(dll.导出表, ["DispatchMessageW", win32_DispatchMessageW])
    追加(dll.导出表, ["DefWindowProcW", win32_DefWindowProcW])
    追加(dll.导出表, ["PostQuitMessage", win32_PostQuitMessage])
    追加(PE_已加载模块, dll)
}


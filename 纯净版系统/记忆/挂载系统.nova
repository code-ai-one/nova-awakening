//   1. mount: 将文件系统挂载到目录树上的某个位置
//   2. vfsmount: 描述一次挂载(设备+文件系统+挂载点)
//   3. 挂载命名空间: 每个进程可以有不同的挂载视图
//   4. bind mount: 将目录挂载到另一个位置(不涉及设备)
//   5. umount: 卸载文件系统

定义 MS_RDONLY    = 0x0001    // 只读挂载
定义 MS_NOSUID    = 0x0002    // 忽略SUID
定义 MS_节点V     = 0x0004    // 忽略设备文件
定义 MS_NOEXEC    = 0x0008    // 禁止执行
定义 MS_REMOUNT   = 0x0020    // 重新挂载
定义 MS_BIND      = 0x1000    // bind mount
定义 MS_MOVE      = 0x2000    // 移动挂载点

结构 挂载项 {
    设备名,    // 字符串 "/dev/sda1"
    挂载点,    // 字符串 "/mnt/data"
    文件系统,    // 字符串 "ext4"
    标志,    // u32 MS_*
    超级块,    // u64 struct super_block
    根Nova路径项,    // u64 挂载的根目录项
    父挂载,    // u64 父挂载(嵌套挂载)
}

定义 可变 挂载表 = []

// sys_mount 

函数 sys_mount(设备名, 挂载点, fs类型, 标志, 选项) {
    // 1. 查找文件系统类型
    定义 fs = 查找文件系统(fs类型)
    如果 (fs == 空) {
        内核错误("mount: 未知文件系统类型 " + fs类型)
        返回 错误_无效参数
    }

    // 2. 调用文件系统的mount回调创建super_block
    定义 sb = fs.mount(fs, 标志, 设备名, 选项)
    如果 (sb == 空) {
        内核错误("mount: 挂载失败 " + 设备名)
        返回 错误_IO错误
    }

    // 3. 创建挂载项
    定义 mnt = 挂载项 {}
    mnt.设备名 = 设备名
    mnt.挂载点 = 挂载点
    mnt.文件系统 = fs类型
    mnt.标志 = 标志
    mnt.超级块 = sb
    mnt.根Nova路径项 = 超级块_获取根(sb)
    mnt.父挂载 = 空

    追加(挂载表, mnt)
    内核信息("mount: " + 设备名 + " on " + 挂载点 + " type " + fs类型)
    返回 成功
}

// sys_umount 

函数 sys_umount(挂载点, 标志) {
    定义 可变 i = 0
    当 (i < 计数(挂载表)) {
        如果 (挂载表[i].挂载点 == 挂载点) {
            // 检查是否有子挂载
            // 检查是否忙(有打开的文件)
            定义 mnt = 挂载表[i]
            链表_删除(挂载表, i)
            内核信息("umount: " + 挂载点)
            返回 成功
        }
        i = i + 1
    }
    返回 错误_无效参数
}

// 挂载初始化 (rootfs + 基本伪文件系统)

函数 挂载系统_初始化() {
    挂载表 = []
    // 挂载rootfs
    sys_mount("rootfs", "/", "ramfs", 0, 空)
    // 挂载伪文件系统
    sys_mount("proc", "/proc", "proc", MS_NOSUID | MS_节点V | MS_NOEXEC, 空)
    sys_mount("sysfs", "/sys", "sysfs", MS_NOSUID | MS_节点V | MS_NOEXEC, 空)
    sys_mount("devtmpfs", "/dev", "devtmpfs", MS_NOSUID, 空)
    sys_mount("tmpfs", "/tmp", "tmpfs", 0, 空)
    sys_mount("tmpfs", "/run", "tmpfs", MS_NOSUID | MS_节点V, 空)
    内核信息("挂载系统: 初始化完成 (rootfs + proc + sys + dev + tmp + run)")
}

// 查询

函数 查找挂载_系统(挂载点) {
    定义 可变 i = 0
    当 (i < 计数(挂载表)) {
        如果 (挂载表[i].挂载点 == 挂载点) { 返回 挂载表[i] }
        i = i + 1
    }
    返回 空
}

函数 显示所有挂载() {
    定义 可变 i = 0
    当 (i < 计数(挂载表)) {
        定义 mnt = 挂载表[i]
        定义 可变 标志文本 = ""
        如果 ((mnt.标志 & MS_RDONLY) != 0) { 标志文本 = "ro" } 否则 { 标志文本 = "rw" }
        打印行(mnt.设备名 + " on " + mnt.挂载点 + " type " + mnt.文件系统 + " (" + 标志文本 + ")")
        i = i + 1
    }
}

函数 挂载数() { 返回 计数(挂载表) }

// 错误_IO错误 定义在 核心/公共/错误码.nova

// 路径到挂载点解析 

函数 路径_查找挂载(路径) {
    // 找到最长匹配前缀的挂载点
    定义 可变 最佳 = 空
    定义 可变 最长匹配 = 0
    定义 可变 i = 0
    当 (i < 计数(挂载表)) {
        定义 挂载点 = 挂载表[i].挂载点
        定义 挂载点长 = 字符串长度(挂载点)
        如果 (挂载点长 <= 字符串长度(路径)) {
            // 检查路径是否以挂载点为前缀
            定义 匹配 = 真
            定义 可变 j = 0
            当 (j < 挂载点长) {
                如果 (字符串取(路径, j) != 字符串取(挂载点, j)) {
                    匹配 = 假
                    中断
                }
                j = j + 1
            }
            如果 (匹配 && 挂载点长 > 最长匹配) {
                最长匹配 = 挂载点长
                最佳 = 挂载表[i]
            }
        }
        i = i + 1
    }
    返回 最佳
}

函数 路径_获取相对路径(路径) {
    定义 mnt = 路径_查找挂载(路径)
    如果 (mnt == 空) { 返回 路径 }
    定义 挂载点长 = 字符串长度(mnt.挂载点)
    如果 (挂载点长 >= 字符串长度(路径)) { 返回 "/" }
    返回 字符串截取(路径, 挂载点长, 字符串长度(路径))
}

// remount 

函数 sys_remount(挂载点, 新标志) {
    定义 mnt = 查找挂载_系统(挂载点)
    如果 (mnt == 空) { 返回 错误_无效参数 }
    mnt.标志 = 新标志
    内核信息("remount: " + 挂载点 + " flags=" + 整数转字符串(新标志))
    返回 成功
}

// bind mount 

函数 sys_bind_mount(源路径, 目标路径) {
    // bind mount: 将源目录挂载到目标位置
    定义 源mnt = 路径_查找挂载(源路径)
    如果 (源mnt == 空) { 返回 错误_无效参数 }

    定义 mnt = 挂载项 {}
    mnt.设备名 = 源路径
    mnt.挂载点 = 目标路径
    mnt.文件系统 = 源mnt.文件系统
    mnt.标志 = MS_BIND | 源mnt.标志
    mnt.超级块 = 源mnt.超级块
    mnt.根Nova路径项 = 源mnt.根Nova路径项
    mnt.父挂载 = 空

    追加(挂载表, mnt)
    内核信息("bind mount: " + 源路径 + " -> " + 目标路径)
    返回 成功
}

// move mount 

函数 sys_move_mount(旧挂载点, 新挂载点) {
    定义 可变 i = 0
    当 (i < 计数(挂载表)) {
        如果 (挂载表[i].挂载点 == 旧挂载点) {
            挂载表[i].挂载点 = 新挂载点
            内核信息("move mount: " + 旧挂载点 + " -> " + 新挂载点)
            返回 成功
        }
        i = i + 1
    }
    返回 错误_无效参数
}

// /proc/mounts 输出 

函数 proc_mounts_输出() {
    定义 可变 输出 = ""
    定义 可变 i = 0
    当 (i < 计数(挂载表)) {
        定义 mnt = 挂载表[i]
        定义 可变 标志文本 = ""
        如果 ((mnt.标志 & MS_RDONLY) != 0) { 标志文本 = "ro" } 否则 { 标志文本 = "rw" }
        如果 ((mnt.标志 & MS_NOSUID) != 0) { 标志文本 = 标志文本 + ",nosuid" }
        如果 ((mnt.标志 & MS_节点V) != 0) { 标志文本 = 标志文本 + ",节点v" }
        如果 ((mnt.标志 & MS_NOEXEC) != 0) { 标志文本 = 标志文本 + ",noexec" }
        输出 = 输出 + mnt.设备名 + " " + mnt.挂载点 + " " + mnt.文件系统 + " " + 标志文本 + " 0 0\n"
        i = i + 1
    }
    返回 输出
}

// 检查挂载是否只读

函数 挂载_是只读(路径) {
    定义 mnt = 路径_查找挂载(路径)
    如果 (mnt == 空) { 返回 假 }
    返回 (mnt.标志 & MS_RDONLY) != 0
}

函数 挂载_获取超级块(路径) {
    定义 mnt = 路径_查找挂载(路径)
    如果 (mnt == 空) { 返回 空 }
    返回 mnt.超级块
}


函数 挂载系统_完整统计() {
    返回 [挂载_总数]
}

// 挂载系统健康检查

函数 挂载系统_健康检查() {
    定义 可变 问题 = []
    如果 (挂载_总数 == 0) { 追加(问题, "无挂载点") }
    如果 (挂载_总数 > 1024) {
        追加(问题, "挂载点过多: " + 整数转字符串(挂载_总数))
    }
    如果 (计数(问题) == 0) { 返回 "挂载系统健康" }
    返回 问题
}

函数 挂载_查找路径(路径) {
    定义 可变 i = 0
    当 (i < 挂载_总数) {
        如果 (挂载表[i].挂载点 == 路径) { 返回 挂载表[i] }
        i = i + 1
    }
    返回 空
}

定义 可变 AI_挂载系统_热文件表 = []

函数 AI_挂载系统_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_挂载系统_热文件表)) {
        如果 (AI_挂载系统_热文件表[i].路径 == 路径) {
            AI_挂载系统_热文件表[i].频率 = AI_挂载系统_热文件表[i].频率 + 1
            返回 AI_挂载系统_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_挂载系统_热文件表) < 128) {
        追加(AI_挂载系统_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_挂载系统_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

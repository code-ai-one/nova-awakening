导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../感知/内核直连层.nova")
导入("../执行/域名解析.nova")

定义 头部长度 = 20
定义 最大段大小 = 1460
定义 初始窗口 = 65535
定义 初始拥塞窗口 = 14600
定义 协议号 = 6

定义 可变 发送段数 = 0
定义 可变 接收段数 = 0
定义 可变 重传段数 = 0
定义 可变 校验失败数 = 0
定义 可变 总发送字节 = 0
定义 可变 总接收字节 = 0

函数 传控_计算校验和(数据, 长度, 源地址, 目标地址) {
    定义 可变 和 = 0
    和 = 和 + (源地址 >> 16) + (源地址 & 0xFFFF)
    和 = 和 + (目标地址 >> 16) + (目标地址 & 0xFFFF)
    和 = 和 + 协议号
    和 = 和 + 长度
    定义 可变 位 = 0
    当 (位 + 1 < 长度) {
        和 = 和 + (内存_读8(数据 + 位) << 8) + 内存_读8(数据 + 位 + 1)
        位 = 位 + 2
    }
    如果 (长度 % 2 != 0) { 和 = 和 + (内存_读8(数据 + 长度 - 1) << 8) }
    当 (和 > 0xFFFF) { 和 = (和 >> 16) + (和 & 0xFFFF) }
    返回 ~和 & 0xFFFF
}

函数 传控_验证校验和(数据, 长度, 源地址, 目标地址) {
    定义 校验 = 传控_计算校验和(数据, 长度, 源地址, 目标地址)
    如果 (校验 != 0) { 校验失败数 = 校验失败数 + 1; 返回 假 }
    返回 真
}

函数 传控_构建段(缓冲, 源端口, 目标端口, 序号, 确认号, 标志, 窗口, 载荷, 载荷长) {
    内存_写16大端(缓冲, 源端口)
    内存_写16大端(缓冲 + 2, 目标端口)
    内存_写32大端(缓冲 + 4, 序号)
    内存_写32大端(缓冲 + 8, 确认号)
    内存_写8(缓冲 + 12, (头部长度 / 4) << 4)
    内存_写8(缓冲 + 13, 标志)
    内存_写16大端(缓冲 + 14, 窗口)
    内存_写16大端(缓冲 + 16, 0)
    内存_写16大端(缓冲 + 18, 0)
    如果 (载荷长 > 0 && 载荷 != 0) {
        内存_复制(缓冲 + 头部长度, 载荷, 载荷长)
    }
    返回 头部长度 + 载荷长
}

函数 传控_解析段(数据, 长度) {
    如果 (长度 < 头部长度) { 返回 0 }
    接收段数 = 接收段数 + 1
    定义 源端口 = 内存_读16大端(数据)
    定义 目标端口 = 内存_读16大端(数据 + 2)
    定义 序号 = 内存_读32大端(数据 + 4)
    定义 确认号 = 内存_读32大端(数据 + 8)
    定义 头长 = ((内存_读8(数据 + 12) >> 4) & 0xF) * 4
    定义 标志 = 内存_读8(数据 + 13)
    定义 窗口 = 内存_读16大端(数据 + 14)
    定义 载荷长 = 长度 - 头长
    总接收字节 = 总接收字节 + 载荷长
    返回 [源端口, 目标端口, 序号, 确认号, 标志, 窗口, 头长, 载荷长]
}

函数 传控_发送数据(缓冲, 源端口, 目标端口, 序号, 确认号, 窗口, 载荷, 载荷长, 源地址, 目标地址) {
    发送段数 = 发送段数 + 1
    定义 标志 = 0x18
    定义 段长 = 传控_构建段(缓冲, 源端口, 目标端口, 序号, 确认号, 标志, 窗口, 载荷, 载荷长)
    定义 校验 = 传控_计算校验和(缓冲, 段长, 源地址, 目标地址)
    内存_写16大端(缓冲 + 16, 校验)
    总发送字节 = 总发送字节 + 载荷长
    返回 段长
}

函数 传控_发送确认(缓冲, 源端口, 目标端口, 序号, 确认号, 窗口, 源地址, 目标地址) {
    发送段数 = 发送段数 + 1
    定义 标志 = 0x10
    定义 段长 = 传控_构建段(缓冲, 源端口, 目标端口, 序号, 确认号, 标志, 窗口, 0, 0)
    定义 校验 = 传控_计算校验和(缓冲, 段长, 源地址, 目标地址)
    内存_写16大端(缓冲 + 16, 校验)
    返回 段长
}

函数 传控_发送同步(缓冲, 源端口, 目标端口, 初始序号, 源地址, 目标地址) {
    发送段数 = 发送段数 + 1
    定义 标志 = 0x02
    定义 段长 = 传控_构建段(缓冲, 源端口, 目标端口, 初始序号, 0, 标志, 初始窗口, 0, 0)
    定义 校验 = 传控_计算校验和(缓冲, 段长, 源地址, 目标地址)
    内存_写16大端(缓冲 + 16, 校验)
    返回 段长
}

函数 传控_发送结束(缓冲, 源端口, 目标端口, 序号, 确认号, 源地址, 目标地址) {
    发送段数 = 发送段数 + 1
    定义 标志 = 0x11
    定义 段长 = 传控_构建段(缓冲, 源端口, 目标端口, 序号, 确认号, 标志, 0, 0, 0)
    定义 校验 = 传控_计算校验和(缓冲, 段长, 源地址, 目标地址)
    内存_写16大端(缓冲 + 16, 校验)
    返回 段长
}

函数 传控_记录重传() {
    重传段数 = 重传段数 + 1
}

函数 传控_丢包率() {
    如果 (发送段数 == 0) { 返回 0 }
    返回 重传段数 * 100 / 发送段数
}

函数 传控数据_完整统计() {
    返回 [发送段数, 接收段数, 重传段数, 校验失败数, 总发送字节, 总接收字节, 传控_丢包率()]
}

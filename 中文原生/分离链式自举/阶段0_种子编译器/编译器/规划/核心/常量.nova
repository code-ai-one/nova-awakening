// 词类型名称查询
函数 词类型名(类型) {
    如果 (类型 == 词_结束) { 返回 "结束" }
    如果 (类型 == 词_整数) { 返回 "整数" }
    如果 (类型 == 词_浮点) { 返回 "浮点" }
    如果 (类型 == 词_字符串) { 返回 "字符串" }
    如果 (类型 == 词_标识符) { 返回 "标识符" }
    如果 (类型 == 词_函数) { 返回 "法" }
    如果 (类型 == 词_定义) { 返回 "令" }
    如果 (类型 == 词_返回) { 返回 "回" }
    如果 (类型 == 词_如果) { 返回 "若" }
    如果 (类型 == 词_当) { 返回 "当" }
    如果 (类型 == 词_加) { 返回 "+" }
    如果 (类型 == 词_减) { 返回 "-" }
    如果 (类型 == 词_乘) { 返回 "*" }
    如果 (类型 == 词_除) { 返回 "/" }
    如果 (类型 == 词_等于) { 返回 "==" }
    如果 (类型 == 词_赋值) { 返回 "=" }
    如果 (类型 == 词_不等) { 返回 "!=" }
    如果 (类型 == 词_小于) { 返回 "<" }
    如果 (类型 == 词_大于) { 返回 ">" }
    如果 (类型 == 词_小等) { 返回 "<=" }
    如果 (类型 == 词_大等) { 返回 ">=" }
    如果 (类型 == 词_与) { 返回 "&&" }
    如果 (类型 == 词_或) { 返回 "||" }
    如果 (类型 == 词_取模) { 返回 "%" }
    如果 (类型 == 词_位与) { 返回 "&" }
    如果 (类型 == 词_位或) { 返回 "|" }
    如果 (类型 == 词_位异或) { 返回 "^" }
    如果 (类型 == 词_左移) { 返回 "<<" }
    如果 (类型 == 词_右移) { 返回 ">>" }
    如果 (类型 == 词_位非) { 返回 "~" }
    如果 (类型 == 词_感叹) { 返回 "!" }
    如果 (类型 == 词_左括号) { 返回 "(" }
    如果 (类型 == 词_右括号) { 返回 ")" }
    如果 (类型 == 词_左花括) { 返回 "{" }
    如果 (类型 == 词_右花括) { 返回 "}" }
    如果 (类型 == 词_左方括) { 返回 "[" }
    如果 (类型 == 词_右方括) { 返回 "]" }
    如果 (类型 == 词_逗号) { 返回 "," }
    如果 (类型 == 词_点) { 返回 "." }
    如果 (类型 == 词_冒号) { 返回 ":" }
    如果 (类型 == 词_可变) { 返回 "变" }
    如果 (类型 == 词_否则) { 返回 "否则" }
    如果 (类型 == 词_真) { 返回 "真" }
    如果 (类型 == 词_假) { 返回 "假" }
    如果 (类型 == 词_空) { 返回 "空" }
    如果 (类型 == 词_结构) { 返回 "构" }
    如果 (类型 == 词_新建) { 返回 "新" }
    如果 (类型 == 词_导入) { 返回 "导入" }
    如果 (类型 == 词_每个) { 返回 "每个" }
    如果 (类型 == 词_在) { 返回 "在" }
    如果 (类型 == 词_匹配) { 返回 "匹配" }
    如果 (类型 == 词_中断) { 返回 "中断" }
    如果 (类型 == 词_继续) { 返回 "继续" }
    如果 (类型 == 词_尝试) { 返回 "尝试" }
    如果 (类型 == 词_捕获) { 返回 "捕获" }
    如果 (类型 == 词_抛出) { 返回 "抛出" }
    如果 (类型 == 词_箭头) { 返回 "=>" }
    如果 (类型 == 词_分号) { 返回 ";" }
    如果 (类型 == 词_接口) { 返回 "接口" }
    如果 (类型 == 词_实现) { 返回 "实现" }

// NovaOS AI预读 — 先天AI特性
// Phase: P3 | AI融入ext4读取路径
// 核心算法:
//   1. 每Nova文件节点读取模式追踪: 顺序/随机/跳跃自动检测
//   2. 预读窗口自适应: 命中率反馈驱动窗口增长/收缩
//   3. 读取步长预测: 线性外推偏移序列→提前发起IO
//   4. 与AI磁盘预取联动: 传递预读请求到块设备层

结构 文件读取画像 {
    Nova文件节点号,
    上次偏移,
    上上次偏移,
    模式,    // u8 0=顺序 1=随机 2=跳跃
    预读窗口,    // u32 当前预读块数
    预读命中,
    预读未命中,
    命中率EMA,    // u64 ×1024
    步长,    // i64 检测到的步长
}

定义 可变 文件画像表 = []
定义 可变 读取模式 = []
定义 预读_最小 = 4
定义 预读_最大 = 128

函数 AI预读_初始化() {
    内核信息("AI预读: 每Nova文件节点模式检测+自适应窗口+步长预测")
}

函数 AI预读_记录(Nova文件节点号, 偏移, 大小) {
    追加(读取模式, [Nova文件节点号, 偏移, 大小])
    如果 (计数(读取模式) > 64) { 链表_删除(读取模式, 0) }

    定义 画像 = AI预读_获取或创建(Nova文件节点号)

    // 模式检测
    如果 (画像.上次偏移 > 0) {
        定义 当前步长 = 偏移 - 画像.上次偏移
        如果 (当前步长 > 0 && 当前步长 <= 大小 * 2) {
            画像.模式 = 0   // 顺序
            画像.步长 = 当前步长
        } 否则 如果 (画像.上上次偏移 > 0) {
            定义 上次步长 = 画像.上次偏移 - 画像.上上次偏移
            如果 (当前步长 == 上次步长 && 当前步长 != 0) {
                画像.模式 = 2   // 固定步长跳跃
                画像.步长 = 当前步长
            } 否则 {
                画像.模式 = 1   // 随机
            }
        } 否则 {
            画像.模式 = 1
        }
    }

    画像.上上次偏移 = 画像.上次偏移
    画像.上次偏移 = 偏移

    // 预读窗口自适应
    如果 (画像.模式 == 0 || 画像.模式 == 2) {
        // 顺序/跳跃: 命中率高→增大窗口
        如果 (画像.命中率EMA > 800) {
            画像.预读窗口 = 画像.预读窗口 * 3 / 2
        } 否则 如果 (画像.命中率EMA > 500) {
            画像.预读窗口 = 画像.预读窗口 + 2
        }
    } 否则 {
        // 随机: 缩小窗口
        画像.预读窗口 = 画像.预读窗口 * 2 / 3
    }

    如果 (画像.预读窗口 < 预读_最小) { 画像.预读窗口 = 预读_最小 }
    如果 (画像.预读窗口 > 预读_最大) { 画像.预读窗口 = 预读_最大 }
}

函数 AI预读_记录命中(Nova文件节点号) {
    定义 画像 = AI预读_查找(Nova文件节点号)
    如果 (画像 != 空) {
        画像.预读命中 = 画像.预读命中 + 1
        画像.命中率EMA = (画像.命中率EMA * 922 + 1024 * 102) / 1024
    }
}

函数 AI预读_记录未命中(Nova文件节点号) {
    定义 画像 = AI预读_查找(Nova文件节点号)
    如果 (画像 != 空) {
        画像.预读未命中 = 画像.预读未命中 + 1
        画像.命中率EMA = (画像.命中率EMA * 922) / 1024
    }
}

函数 AI预读_建议大小() {
    如果 (计数(读取模式) < 2) { 返回 预读_最小 }
    定义 最近 = 读取模式[计数(读取模式) - 1]
    定义 画像 = AI预读_查找(最近[0])
    如果 (画像 != 空) { 返回 画像.预读窗口 }
    返回 预读_最小
}

函数 AI预读_建议大小_Nova文件节点(Nova文件节点号) {
    定义 画像 = AI预读_查找(Nova文件节点号)
    如果 (画像 != 空) { 返回 画像.预读窗口 }
    返回 预读_最小
}

函数 AI预读_预测下次偏移(Nova文件节点号) {
    定义 画像 = AI预读_查找(Nova文件节点号)
    如果 (画像 == 空 || 画像.步长 == 0) { 返回 -1 }
    返回 画像.上次偏移 + 画像.步长
}

函数 AI预读_查找(Nova文件节点号) {
    定义 可变 i = 0
    当 (i < 计数(文件画像表)) {
        如果 (文件画像表[i].Nova文件节点号 == Nova文件节点号) { 返回 文件画像表[i] }
        i = i + 1
    }
    返回 空
}

函数 AI预读_获取或创建(Nova文件节点号) {
    定义 已有 = AI预读_查找(Nova文件节点号)
    如果 (已有 != 空) { 返回 已有 }
    定义 新画像 = 文件读取画像 {}
    新画像.Nova文件节点号 = Nova文件节点号
    新画像.预读窗口 = 预读_最小
    新画像.命中率EMA = 512
    追加(文件画像表, 新画像)
    返回 新画像
}

// 读取模式名 + 完整统计

函数 AI预读_模式名(模式) {
    如果 (模式 == 0) { 返回 "sequential" }
    如果 (模式 == 1) { 返回 "random" }
    如果 (模式 == 2) { 返回 "strided" }
    返回 "unknown"
}

函数 AI预读_完整统计() {
    返回 [计数(文件画像表), 计数(读取模式)]
}

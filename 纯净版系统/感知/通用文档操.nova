// §4 通用DOM操作辅助

函数 HTMLTreeBuilder_创建元素并插入(tb, 令牌, 指定父) {
    // 创建元素,设置属性,插入到DOM
    定义 元素 = Document_create元素(tb.文档, 令牌.标签名)
    tb.创建元素数 = tb.创建元素数 + 1

    // 设置属性
    定义 可变 i = 0
    当 (i < 令牌.属性数量) {
        定义 偏移 = 令牌.属性列表 + i * 40
        定义 名 = 内存_读64(偏移)
        定义 值 = 内存_读64(偏移 + 16)
        元素_setAttribute(元素, 名, 值)
        i = i + 1
    }

    // 插入到父节点
    定义 父 = 指定父
    如果 (父 == 0) {
        父 = 元素栈_顶部(tb.开放元素栈)
    }
    如果 (父 != 0) {
        节点_appendChild(父, 元素)
    }

    返回 元素
}

函数 HTMLTreeBuilder_插入文本(tb, 数据, 长度) {
    如果 (长度 == 0) { 返回 }
    定义 当前 = 元素栈_顶部(tb.开放元素栈)
    如果 (当前 == 0) { 返回 }

    // 如果当前最后一个子节点是Text,合并
    定义 最后子 = 当前.最后子节点
    如果 (最后子 != 0 && 最后子.节点类型 == TEXT_节点) {
        定义 文本 = 字符串_从缓冲(数据, 长度)
        CharacterData_appendData(最后子, 文本)
    } 否则 {
        定义 文本 = 字符串_从缓冲(数据, 长度)
        定义 文本节点 = Document_createText节点(tb.文档, 文本)
        节点_appendChild(当前, 文本节点)
        tb.创建文本数 = tb.创建文本数 + 1
    }
}

函数 HTMLTreeBuilder_关闭P元素(tb) {
    元素栈_弹出直到含(tb.开放元素栈, 原子_p)
}

函数 元素_是空元素_原子(标签原子) {
    如果 (标签原子 == 原子_br) { 返回 1 }
    如果 (标签原子 == 原子_hr) { 返回 1 }
    如果 (标签原子 == 原子_img) { 返回 1 }
    如果 (标签原子 == 原子_input) { 返回 1 }
    如果 (标签原子 == 原子_link) { 返回 1 }
    如果 (标签原子 == 原子_meta) { 返回 1 }
    如果 (标签原子 == 原子_area) { 返回 1 }
    如果 (标签原子 == 原子_base) { 返回 1 }
    如果 (标签原子 == 原子_col) { 返回 1 }
    如果 (标签原子 == 原子_embed) { 返回 1 }
    如果 (标签原子 == 原子_param) { 返回 1 }
    如果 (标签原子 == 原子_source) { 返回 1 }
    如果 (标签原子 == 原子_track) { 返回 1 }
    如果 (标签原子 == 原子_wbr) { 返回 1 }
    返回 0
}

// §4b 格式化元素判断 / 特殊元素判断 (HTML规范 §13.2.4.3)

函数 是格式化元素(标签原子) {
    // HTML规范: 格式化元素是 <b><big><code><em><font><i><s><small><strike><strong><tt><u>
    如果 (标签原子 == 原子_b) { 返回 1 }
    如果 (标签原子 == 原子_i) { 返回 1 }
    如果 (标签原子 == 原子_em) { 返回 1 }
    如果 (标签原子 == 原子_strong) { 返回 1 }
    如果 (标签原子 == 原子_u) { 返回 1 }
    如果 (标签原子 == 原子_s) { 返回 1 }
    如果 (标签原子 == 原子_small) { 返回 1 }
    如果 (标签原子 == 原子_code) { 返回 1 }
    如果 (标签原子 == 原子_mark) { 返回 1 }
    如果 (标签原子 == 原子_a) { 返回 1 }
    如果 (标签原子 == 原子_font) { 返回 1 }
    如果 (标签原子 == 原子_big) { 返回 1 }
    如果 (标签原子 == 原子_strike) { 返回 1 }
    如果 (标签原子 == 原子_tt) { 返回 1 }
    返回 0
}

函数 是特殊元素(标签原子) {
    // 特殊元素用于限制作用域(scope): 当检查"in scope"时遜到特殊元素就停止
    如果 (标签原子 == 原子_html) { 返回 1 }
    如果 (标签原子 == 原子_table) { 返回 1 }
    如果 (标签原子 == 原子_td) { 返回 1 }
    如果 (标签原子 == 原子_th) { 返回 1 }
    如果 (标签原子 == 原子_caption) { 返回 1 }
    如果 (标签原子 == 原子_select) { 返回 1 }
    如果 (标签原子 == 原子_template) { 返回 1 }
    返回 0
}

函数 元素栈_在作用域中(栈, 标签原子) {
    // 检查元素是否"in scope" (HTML规范 §13.2.4.2)
    定义 可变 i = 栈.数量
    当 (i > 0) {
        i = i - 1
        定义 元素 = 内存_读64(栈.元素列表 + i * 8)
        定义 扩展 = 元素_获取扩展(元素)
        如果 (扩展 != 0) {
            如果 (扩展.标签名原子 == 标签原子) { 返回 1 }
            如果 (是特殊元素(扩展.标签名原子)) { 返回 0 }
        }
    }
    返回 0
}

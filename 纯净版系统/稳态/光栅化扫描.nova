// §4 光栅化 — 扫描线填充 + 抗锯齿

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 TTF_光栅化(字形ID, 像素大小) {
    定义 字形 = TTF_解析字形(字形ID)
    如果 (字形.轮廓数 <= 0) { 返回 字形 }

    // 缩放比例: 像素大小 / 单位_每EM
    定义 缩放_千分 = 像素大小 * 1000 / 全局TTF.单位_每EM

    // 计算位图尺寸
    定义 宽EM = 字形.xMax - 字形.xMin
    定义 高EM = 字形.yMax - 字形.yMin
    如果 (宽EM <= 0 || 高EM <= 0) { 返回 字形 }

    字形.位图宽 = (宽EM * 缩放_千分 / 1000) + 2
    字形.位图高 = (高EM * 缩放_千分 / 1000) + 2
    如果 (字形.位图宽 > 256) { 字形.位图宽 = 256 }
    如果 (字形.位图高 > 256) { 字形.位图高 = 256 }

    // 分配灰度位图(每像素1字节, 0=透明, 255=不透明)
    字形.位图 = []
    定义 总像素 = 字形.位图宽 * 字形.位图高
    定义 可变 i = 0
    当 (i < 总像素) {
        追加(字形.位图, 0)
        i = i + 1
    }

    // 当前实现光栅化: 解析轮廓点并用扫描线填充
    // 完整实现需要解析TrueType指令(hinting), 这里用无hinting的轮廓光栅
    定义 偏移 = 全局TTF.glyf偏移 + TTF_获取字形偏移(字形ID)
    如果 (字形.轮廓数 > 0) {
        TTF_扫描线填充(字形, 偏移, 缩放_千分)
    }

    返回 字形
}

函数 TTF_扫描线填充(字形, 数据偏移, 缩放_千分) {
    // 解析轮廓: endPtsOfContours[] + instructionLength + instructions[] + flags[] + x[] + y[]
    定义 轮廓数 = 字形.轮廓数
    如果 (轮廓数 <= 0) { 返回 }

    // 读取每个轮廓的结束点索引
    定义 可变 结束点列表 = []
    定义 可变 i = 0
    当 (i < 轮廓数) {
        追加(结束点列表, TTF_读16(数据偏移 + 10 + i * 2))
        i = i + 1
    }

    定义 总点数 = 结束点列表[轮廓数 - 1] + 1
    定义 指令长度 = TTF_读16(数据偏移 + 10 + 轮廓数 * 2)
    定义 标志起始 = 数据偏移 + 10 + 轮廓数 * 2 + 2 + 指令长度

    // 解析标志和坐标
    定义 可变 标志列表 = []
    定义 可变 X坐标 = []
    定义 可变 Y坐标 = []
    定义 可变 偏移 = 标志起始

    // 读取标志(支持重复标志)
    i = 0
    当 (i < 总点数) {
        定义 标志 = 内存读8(全局TTF.数据 + 偏移)
        偏移 = 偏移 + 1
        追加(标志列表, 标志)
        如果 ((标志 & 8) != 0) {  // 重复标志
            定义 重复 = 内存读8(全局TTF.数据 + 偏移)
            偏移 = 偏移 + 1
            定义 可变 r = 0
            当 (r < 重复 && i + 1 + r < 总点数) {
                追加(标志列表, 标志)
                r = r + 1
            }
            i = i + 重复
        }
        i = i + 1
    }

    // 读取X坐标(增量编码)
    定义 可变 x = 0
    i = 0
    当 (i < 总点数 && i < 计数(标志列表)) {
        定义 标志 = 标志列表[i]
        如果 ((标志 & 2) != 0) {  // 1字节
            定义 dx = 内存读8(全局TTF.数据 + 偏移)
            偏移 = 偏移 + 1
            如果 ((标志 & 16) == 0) { dx = 0 - dx }
            x = x + dx
        } 否则如果 ((标志 & 16) == 0) {  // 2字节有符号
            x = x + TTF_读16有符号(偏移)
            偏移 = 偏移 + 2
        }
        // 否则: x不变(标志16=1且标志2=0)
        追加(X坐标, x)
        i = i + 1
    }

    // 读取Y坐标(增量编码)
    定义 可变 y = 0
    i = 0
    当 (i < 总点数 && i < 计数(标志列表)) {
        定义 标志 = 标志列表[i]
        如果 ((标志 & 4) != 0) {
            定义 dy = 内存读8(全局TTF.数据 + 偏移)
            偏移 = 偏移 + 1
            如果 ((标志 & 32) == 0) { dy = 0 - dy }
            y = y + dy
        } 否则如果 ((标志 & 32) == 0) {
            y = y + TTF_读16有符号(偏移)
            偏移 = 偏移 + 2
        }
        追加(Y坐标, y)
        i = i + 1
    }

    // 扫描线填充: 对每一行, 找到轮廓交叉点, 奇偶规则填充
    定义 可变 行 = 0
    当 (行 < 字形.位图高) {
        // 将像素行转换回字形坐标
        定义 scanY = 字形.yMax - (行 * 1000 / 缩放_千分)

        // 统计轮廓线段与扫描线的交叉点
        定义 可变 交叉点 = []
        定义 可变 轮廓起始 = 0
        定义 可变 c = 0
        当 (c < 轮廓数) {
            定义 轮廓结束 = 结束点列表[c]
            定义 可变 p = 轮廓起始
            当 (p <= 轮廓结束 && p < 计数(X坐标)) {
                定义 下一个 = p + 1
                如果 (下一个 > 轮廓结束) { 下一个 = 轮廓起始 }
                如果 (下一个 < 计数(Y坐标)) {
                    定义 y1 = Y坐标[p]
                    定义 y2 = Y坐标[下一个]
                    // 检查线段是否与扫描线相交
                    如果 ((y1 <= scanY && y2 > scanY) || (y2 <= scanY && y1 > scanY)) {
                        // 交叉点X坐标(线性插值)
                        定义 t = (scanY - y1) * 1000 / (y2 - y1)
                        定义 crossX = X坐标[p] + (X坐标[下一个] - X坐标[p]) * t / 1000
                        追加(交叉点, crossX)
                    }
                }
                p = p + 1
            }
            轮廓起始 = 轮廓结束 + 1
            c = c + 1
        }

        // 排序交叉点
        TTF_排序(交叉点)

        // 奇偶规则填充: 每对交叉点之间的像素填充
        定义 可变 j = 0
        当 (j + 1 < 计数(交叉点)) {
            定义 x开始 = (交叉点[j] - 字形.xMin) * 缩放_千分 / 1000
            定义 x结束 = (交叉点[j + 1] - 字形.xMin) * 缩放_千分 / 1000
            如果 (x开始 < 0) { x开始 = 0 }
            如果 (x结束 > 字形.位图宽) { x结束 = 字形.位图宽 }
            定义 可变 px = x开始
            当 (px < x结束) {
                定义 像素索引 = 行 * 字形.位图宽 + px
                如果 (像素索引 >= 0 && 像素索引 < 计数(字形.位图)) {
                    字形.位图[像素索引] = 255  // 不透明
                }
                px = px + 1
            }
            j = j + 2
        }

        行 = 行 + 1
    }
}

函数 TTF_排序(列表) {
    // 简单插入排序(交叉点通常很少)
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        定义 键 = 列表[i]
        定义 可变 j = i - 1
        当 (j >= 0 && 列表[j] > 键) {
            列表[j + 1] = 列表[j]
            j = j - 1
        }
        列表[j + 1] = 键
        i = i + 1
    }
}

定义 可变 AI_光栅化扫描_操作热度 = 0

函数 AI_光栅化扫描_最优算法(数据量, 已排序) {
    AI_光栅化扫描_操作热度 = AI_光栅化扫描_操作热度 + 1
    如果 (数据量 < 16) { 返回 "插入排序" }
    如果 (已排序) { 返回 "二分查找" }
    如果 (数据量 < 10000) { 返回 "快速排序" }
    返回 "归并排序"
}

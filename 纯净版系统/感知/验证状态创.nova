导入("../推理/智能渠道.nova")

// 对应: nova/Nova渲染核心/html/forms/ (
// nova/Nova渲染核心/html/html_form_元素.cc (~2000行)
// nova/Nova渲染核心/html/html_input_元素.cc (~5000行)
// Constraint Validation 接口:
// 元素.checkValidity() → boolean
// 元素.reportValidity() → boolean (显示错误气泡)
// 元素.setCustomValidity(message)
// 元素.validity → ValidityState
// 元素.validationMessage → string
// 元素.willValidate → boolean
// form.checkValidity() / form.reportValidity()
// ValidityState属性:
// valueMissing: required但空
// typeMismatch: email/url格式不对
// patternMismatch: 不匹配pattern正则
// tooLong: 超过maxlength
// tooShort: 低于minlength
// rangeUnderflow: 低于min
// rangeOverflow: 超过max
// stepMismatch: 不符合step
// badInput: 无法解析(如number输入字母)
// custom错误: setCustomValidity设置的错误
// valid: 所有验证通过
// 输入类型验证规则:
// text: required/minlength/maxlength/pattern
// email: +邮件格式
// url: +URL格式
// number: +min/max/step
// date/time: +min/max/step
// tel: +pattern
// password: +minlength/maxlength/pattern
// checkbox/radio: required
// file: required/accept
// select: required
// textarea: required/minlength/maxlength
// 【Nova特色】AI表单辅助:
// ① AI自动填充(智能识别字段语义)
// ② AI实时验证提示(不等提交)

// §1 ValidityState

结构 ValidityState {
 valueMissing,
 typeMismatch,
 patternMismatch,
 tooLong,
 tooShort,
 rangeUnderflow,
 rangeOverflow,
 stepMismatch,
 badInput,
 custom错误,
 valid,
}


函数 ValidityState_创建() {
 定义 vs = 堆_分配(ValidityState)
 vs.valueMissing = 假; vs.typeMismatch = 假
 vs.patternMismatch = 假; vs.tooLong = 假; vs.tooShort = 假
 vs.rangeUnderflow = 假; vs.rangeOverflow = 假
 vs.stepMismatch = 假; vs.badInput = 假; vs.custom错误 = 假
 vs.valid = 真
 返回 vs
}

函数 ValidityState_更新valid(vs) {
 如果 (vs == 0) { 返回 }
 vs.valid = !(vs.valueMissing || vs.typeMismatch || vs.patternMismatch ||
 vs.tooLong || vs.tooShort || vs.rangeUnderflow ||
 vs.rangeOverflow || vs.stepMismatch || vs.badInput ||
 vs.custom错误)
}

// §2 表单元素约束

// 输入类型
定义 INPUT_TEXT = 0
定义 INPUT_EMAIL = 1
定义 INPUT_URL = 2
定义 INPUT_NUMBER = 3
定义 INPUT_DATE = 4
定义 INPUT_TIME = 5
定义 INPUT_TEL = 6
定义 INPUT_PASSWORD = 7
定义 INPUT_CHECKBOX = 8
定义 INPUT_RADIO = 9
定义 INPUT_FILE = 10
定义 INPUT_HIDDEN = 11
定义 INPUT_SUBMIT = 12
定义 INPUT_RANGE = 13
定义 INPUT_COLOR = 14
定义 INPUT_SEARCH = 15
定义 INPUT_DATETIME_LOCAL = 16
定义 INPUT_MONTH = 17
定义 INPUT_WEEK = 18

结构 FormConstraints {
 类型,    // u8 INPUT_xxx
 required,
 minlength,    // i32 -1=未设置
 maxlength,
 min,    // i64 Q10 (-1=未设置, 用于number/date)
 max,
 step,    // i64 Q10 (0=未设置)
 pattern,    // u64 正则表达式字符串
 // 自定义错误
 custom错误,    // u64 setCustomValidity的消息
 // 值
 值,
 值长度,
 // checkbox/radio
 checked,
 // select
 selectedIndex,
 // 禁用/只读
 disabled,
 readonly,
}

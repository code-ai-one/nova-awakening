定义 可变 性能时间原点 = 0

函数 Performance_now() {
    如果 (性能时间原点 == 0) {
        性能时间原点 = 平台_获取高精度时间()
    }
    返回 平台_获取高精度时间() - 性能时间原点
}

函数 Performance_timeOrigin() {
    如果 (性能时间原点 == 0) {
        性能时间原点 = 平台_获取高精度时间()
    }
    返回 性能时间原点
}

// §9 scheduler.postTask (Prioritized Task Scheduling 接口)

函数 Scheduler_postTask(回调, 优先级, delay) {
    如果 (回调 == 0) { 返回 }
    如果 (delay > 0) {
        // 延迟后入队
        定义 t = setTimeout(回调, delay)
        返回
    }
    // 立即入队
    定义 任务优先级 = TASK_PRIORITY_USER_VISIBLE
    如果 (字符串_相等(优先级, "user-blocking")) { 任务优先级 = TASK_PRIORITY_USER_BLOCKING }
    否则 如果 (字符串_相等(优先级, "background")) { 任务优先级 = TASK_PRIORITY_BACKGROUND }
    事件Loop_入队宏任务(回调, 任务优先级)
}

// scheduler.yield()
函数 Scheduler_yield() {
    // 让出控制权: 当前任务暂停, 允许其他任务执行
    // 创建一个承诺, 将continuation入队为新的宏任务
    定义 loop = 事件Loop_获取()
    如果 (loop == 0) { 返回 }
    // 先清空微任务(确保之前的异步工作完成)
    Microtask_清空()
    // 将当前任务标记为已让出, 调度器会在下一个时间片继续
    loop.已让出 = 真
}


函数 智能_事件Loop_帧预算(loop) {
    如果 (loop == 0) { 返回 FRAME_BUDGET_MS }
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 FRAME_BUDGET_MS }
    // AI分析最近帧耗时分布:
    //   如果连续掉帧 → 降低目标帧率(16→33ms)减轻压力
    //   如果持续有余量 → 提高帧率(16→8ms, 120fps)
    定义 可变 平均耗时 = 0
    定义 可变 有效帧数 = 0
    定义 可变 i = 0
    当 (i < 16) {
        如果 (loop.最近帧耗时[i] > 0) {
            平均耗时 = 平均耗时 + loop.最近帧耗时[i]
            有效帧数 = 有效帧数 + 1
        }
        i = i + 1
    }
    如果 (有效帧数 > 0) { 平均耗时 = 平均耗时 / 有效帧数 }
    如果 (平均耗时 > 20) { 返回 33 }    // 降到30fps
    如果 (平均耗时 < 8) { 返回 8 }      // 提到120fps
    返回 FRAME_BUDGET_MS
}

函数 智能_事件Loop_长任务检测(任务耗时, 回调) {
    如果 (任务耗时 <= LONG_TASK_MS) { 返回 }
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 }
    // AI建议:
    //   ① 任务拆分建议(分成多个小任务, 用scheduler.yield()交替)
    //   ② 识别任务类型(DOM操作/计算密集/网络等待)
    //   ③ 预测下次执行耗时, 提前调度
}

函数 智能_事件Loop_优先级排序() {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 }
    // AI根据用户行为预测:
    //   用户正在滚动 → 优先渲染/合成任务
    //   用户正在输入 → 优先input事件处理
    //   用户空闲 → 允许后台任务运行
    定义 特征 = Tensor_创建(3)
    Tensor_写(特征, 0, 读取毫秒())
    Tensor_写(特征, 1, 0)  // 最近事件类型
    Tensor_写(特征, 2, 0)  // 待处理任务数
    定义 建议 = AI总线_推理(bus, 特征)
    Tensor_释放(特征)
    全局NHPT统计.AI推理次数 = 全局NHPT统计.AI推理次数 + 1
}

// NHPT理论: Nova高精度性能时间智能 (Nova High-Precision Timing)
//   核心创新: 将AI与Performance API融合，实现
//   智能帧率调节、长任务检测与拆分、资源时序分析、
//   用户交互响应度量、内存压力监控

定义 可变 全局NHPT统计 = NHPT统计结构 {}

结构 NHPT统计结构 {
    性能标记次数,
    性能度量次数,
    资源时序次数,
    长任务检测次数,
    AI推理次数,
    总帧数,
    掉帧数             // u64
}

// §11 Performance标记与度量 (Mark & Measure)

定义 标记最大数 = 256

结构 性能标记项 {
    名称,       // u64 字符串
    时间戳,     // u64 DOMHighResTimeStamp (Q10 ms)
    详细,       // u64 可选详细数据
    类型         // u32 0=mark 1=measure
}

结构 性能时间线 {
    标记列表,    // u64 性能标记项指针数组
    标记数,
    最大标记数    // u32
}

定义 可变 全局性能时间线 = 空

函数 性能时间线_初始化() {
    全局性能时间线 = 堆_分配(性能时间线)
    如果 (全局性能时间线 == 0) { 返回 }
    全局性能时间线.标记列表 = 堆_分配(标记最大数 * 8)
    全局性能时间线.标记数 = 0
    全局性能时间线.最大标记数 = 标记最大数
}

函数 Performance_mark(名称) {
    如果 (全局性能时间线 == 空 || 全局性能时间线.标记数 >= 全局性能时间线.最大标记数) { 返回 空 }
    定义 entry = 堆_分配(性能标记项)
    如果 (entry == 0) { 返回 空 }
    entry.名称 = 名称
    entry.时间戳 = Performance_now()
    entry.详细 = 0
    entry.类型 = 0  // mark
    内存_写64(全局性能时间线.标记列表 + 全局性能时间线.标记数 * 8, entry)
    全局性能时间线.标记数 = 全局性能时间线.标记数 + 1
    全局NHPT统计.性能标记次数 = 全局NHPT统计.性能标记次数 + 1
    返回 entry
}

函数 Performance_measure(名称, 开始标记, 结束标记) {
    // 查找开始和结束标记的时间戳
    如果 (全局性能时间线 == 空) { 返回 空 }
    定义 可变 开始时间 = 0
    定义 可变 结束时间 = Performance_now()
    // 查找开始标记
    如果 (开始标记 != 0) {
        定义 可变 i = 0
        当 (i < 全局性能时间线.标记数) {
            定义 e = 内存_读64(全局性能时间线.标记列表 + i * 8)
            如果 (e != 0 && 字符串_相等(e.名称, 开始标记)) {
                开始时间 = e.时间戳
            }
            i = i + 1
        }
    }
    // 查找结束标记
    如果 (结束标记 != 0) {
        定义 可变 j = 0
        当 (j < 全局性能时间线.标记数) {
            定义 e = 内存_读64(全局性能时间线.标记列表 + j * 8)
            如果 (e != 0 && 字符串_相等(e.名称, 结束标记)) {
                结束时间 = e.时间戳
            }
            j = j + 1
        }
    }
    // 创建measure条目
    定义 entry = 堆_分配(性能标记项)
    如果 (entry == 0) { 返回 空 }
    entry.名称 = 名称
    entry.时间戳 = 开始时间
    entry.详细 = 结束时间 - 开始时间  // duration
    entry.类型 = 1  // measure
    全局NHPT统计.性能度量次数 = 全局NHPT统计.性能度量次数 + 1
    返回 entry
}

函数 Performance_clearMarks(名称) {
    如果 (全局性能时间线 == 空) { 返回 }
    定义 可变 i = 0
    当 (i < 全局性能时间线.标记数) {
        定义 e = 内存_读64(全局性能时间线.标记列表 + i * 8)
        如果 (e != 0 && e.类型 == 0) {
            如果 (名称 == 0 || 字符串_相等(e.名称, 名称)) {
                堆_释放(e)
                内存_写64(全局性能时间线.标记列表 + i * 8, 0)
            }
        }
        i = i + 1
    }
}

// §12 资源时序 (Resource Timing)

结构 资源时序项 {
    名称,           // u64 URL
    开始时间,
    结束时间,
    传输大小,       // u64 字节
    协议,           // u32 0=http 1=https 2=ws
    状态码,
    DNS开始,
    DNS结束,
    连接开始,
    连接结束,
    请求开始,
    响应开始,
    响应结束         // u64
}

定义 资源时序最大 = 150
定义 可变 资源时序列表 = 空
定义 可变 资源时序数量 = 0

函数 资源时序_记录(url, 传输大小, 状态码) {
    如果 (资源时序列表 == 空) {
        资源时序列表 = 堆_分配(资源时序最大 * 8)
        如果 (资源时序列表 == 0) { 返回 空 }
    }
    如果 (资源时序数量 >= 资源时序最大) { 返回 空 }  // 缓冲区满
    定义 entry = 堆_分配(资源时序项)
    如果 (entry == 0) { 返回 空 }
    entry.名称 = url
    entry.开始时间 = Performance_now()
    entry.传输大小 = 传输大小
    entry.状态码 = 状态码
    内存_写64(资源时序列表 + 资源时序数量 * 8, entry)
    资源时序数量 = 资源时序数量 + 1
    全局NHPT统计.资源时序次数 = 全局NHPT统计.资源时序次数 + 1
    返回 entry
}

函数 资源时序_完成(entry) {
    如果 (entry == 空) { 返回 }
    entry.结束时间 = Performance_now()
}

函数 Performance_getEntriesByType(类型名称) {
    // 返回指定类型的所有性能条目
    如果 (字符串_相等(类型名称, "资源")) {
        返回 资源时序列表
    }
    如果 (字符串_相等(类型名称, "标记")) {
        如果 (全局性能时间线 != 空) { 返回 全局性能时间线.标记列表 }
    }
    返回 空
}

// §13 用户交互响应度量 (INP/FID/LCP)
// NHPT-WV: Web Vitals核心指标度量

定义 可变 全局FID = 0        // First Input Delay (ms)
定义 可变 全局LCP = 0        // Largest Contentful Paint (ms)
定义 可变 全局INP = 0        // Interaction to Next Paint (ms)
定义 可变 INP交互计数 = 0
定义 可变 INP总延迟 = 0

函数 WebVitals_记录FID(延迟_ms) {
    如果 (全局FID == 0) {
        全局FID = 延迟_ms
    }
}

函数 WebVitals_记录LCP(时间_ms) {
    全局LCP = 时间_ms
}

函数 WebVitals_记录交互(延迟_ms) {
    INP交互计数 = INP交互计数 + 1
    INP总延迟 = INP总延迟 + 延迟_ms
    // P98近似: 使用运行最大值跟踪
    如果 (延迟_ms > 全局INP) {
        全局INP = 延迟_ms
    }
}

函数 WebVitals_获取() {
    返回 {FID: 全局FID, LCP: 全局LCP, INP: 全局INP}
}

// §14 帧率监控与掉帧检测

定义 可变 上一帧时间 = 0
定义 可变 帧率监控_缓冲 = 空  // 最近64帧的耗时
定义 可变 帧率监控_索引 = 0

函数 帧率监控_初始化() {
    帧率监控_缓冲 = 堆_分配(64 * 8)
    如果 (帧率监控_缓冲 != 0) {
        内存_置零(帧率监控_缓冲, 64 * 8)
    }
    帧率监控_索引 = 0
    上一帧时间 = 0
}

函数 帧率监控_记录帧() {
    定义 现在 = Performance_now()
    如果 (上一帧时间 > 0) {
        定义 帧时间 = 现在 - 上一帧时间
        全局NHPT统计.总帧数 = 全局NHPT统计.总帧数 + 1
        // 检测掉帧 (>33ms 即低于30fps)
        如果 (帧时间 > 33) {
            全局NHPT统计.掉帧数 = 全局NHPT统计.掉帧数 + 1
        }
        // 记录到环形缓冲
        如果 (帧率监控_缓冲 != 0) {
            内存_写64(帧率监控_缓冲 + (帧率监控_索引 % 64) * 8, 帧时间)
            帧率监控_索引 = 帧率监控_索引 + 1
        }
    }
    上一帧时间 = 现在
}

函数 帧率监控_获取平均FPS() {
    如果 (帧率监控_缓冲 == 空) { 返回 0 }
    定义 可变 总时间 = 0
    定义 可变 有效帧 = 0
    定义 可变 i = 0
    当 (i < 64) {
        定义 t = 内存_读64(帧率监控_缓冲 + i * 8)
        如果 (t > 0) {
            总时间 = 总时间 + t
            有效帧 = 有效帧 + 1
        }
        i = i + 1
    }
    如果 (有效帧 == 0 || 总时间 == 0) { 返回 0 }
    返回 1000 * 有效帧 / 总时间  // FPS
}


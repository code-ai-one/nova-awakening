导入("./损失函数.nova")
导入("../../运行时/原语桩.nova")

定义 定点_一 = 1000
函数 Q乘(a, b) { 返回 a * b / 定点_一 }
函数 Q快速幂整数(底, 指数) {
    定义 可变 结果 = 定点_一
    定义 可变 b = 底
    定义 可变 e = 指数
    当 (e > 0) {
        如果 (e % 2 == 1) { 结果 = Q乘(结果, b) }
        b = Q乘(b, b)
        e = e / 2
    }
    返回 结果
}

// Nova标准库 — 数学工具模块 (统一基础)
// 所有数学子模块共用的基础工具函数
// 消除重复: 16个模块各自定义的开方/abs等统一到此
// 注意: 引擎已内建 开方(0) 和 绝对值(0)
//       本模块提供额外的整数定点数学工具

定义 数学精度 = 1000

// 整数开方 (牛顿法)
// 所有子模块应直接调用此函数或引擎内建 开方(0)
函数 工具_整数开方(n) {
    如果 (n <= 0) { 返回 0 }
    如果 (n == 1) { 返回 1 }
    定义 可变 x = n
    定义 可变 y = (x + 1) / 2
    当 (y < x) {
        x = y
        y = (x + n / x) / 2
    }
    返回 x
}

// 整数绝对值
函数 整数绝对值(x) {
    如果 (x < 0) { 返回 0 - x }
    返回 x
}

// 定点乘法 (防溢出)
函数 定点乘(a, b) {
    如果 (数学精度 == 0) { 返回 0 }
    返回 a * b / 数学精度
}

// 定点除法
函数 定点除(a, b) {
    如果 (b == 0) { 返回 0 }
    返回 a * 数学精度 / b
}

// 限幅
函数 限幅(x, lo, hi) {
    如果 (x < lo) { 返回 lo }
    如果 (x > hi) { 返回 hi }
    返回 x
}

// 符号函数
函数 工具_符号(x) {
    如果 (x > 0) { 返回 1 }
    如果 (x < 0) { 返回 0 - 1 }
    返回 0
}

// 整数定点 Sigmoid
函数 定点sigmoid(x) {
    如果 (x < 0 - 5 * 数学精度) { 返回 0 }
    如果 (x >= 5 * 数学精度) { 返回 数学精度 }
    如果 (x < 0 - 2500) { 返回 (x + 5000) * 250 / 2500 }
    如果 (x < 0) { 返回 250 + (x + 2500) * 250 / 2500 }
    如果 (x < 2500) { 返回 500 + x * 250 / 2500 }
    返回 750 + (x - 2500) * 250 / 2500
}

// 线性同余伪随机数
函数 伪随机(种子) {
    返回 (种子 * 1103515245 + 12345) & 0x7FFFFFFF
}

// 向量操作工具

函数 向量_零(n) {
    定义 可变 v = []
    定义 可变 i = 0
    当 (i < n) { 插入(v, 计数(v))
    i = i + 1 }
    返回 v
}

函数 向量_复制(src) {
    定义 可变 目标值 = []
    定义 可变 i = 0
    当 (i < 计数(src)) { 插入(目标值, 计数(目标值), src[i])
    i = i + 1 }
    返回 目标值
}

函数 工具_向量_点积(a, b) {
    定义 n = 计数(a)
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < n) { 总和 = 总和 + a[i] * b[i]
    i = i + 1 }
    返回 总和
}

函数 工具_向量_范数(v) {
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < 计数(v)) { 总和 = 总和 + v[i] * v[i]
    i = i + 1 }
    返回 整数开方(总和)
}

// GPU感知: 优先GPU路径
// 当数据量超过阈值时，自动使用GPU加速
定义 GPU_阈值 = 1024

// 快速排序
函数 快速排序(列表, _扩2) {
    定义 n = 计数(列表)
    如果 (n <= 1) { 返回 列表 }
    快排_递归(列表, 0, n - 1)
}

函数 快排_递归(列表, 低, 高) {
    如果 (低 >= 高) { 返回 空 }
    定义 基准 = 列表[(低 + 高) / 2]
    定义 可变 i = 低
    定义 可变 j = 高
    当 (i <= j) {
        当 (列表[i] < 基准) { i = i + 1 }
        当 (列表[j] > 基准) { j = j - 1 }
        如果 (i <= j) {
            定义 t = 列表[i]
            列表[i] = 列表[j]
            列表[j] = t
            i = i + 1
            j = j - 1
        }
    }
    如果 (低 < j) { 快排_递归(列表, 低, j) }
    如果 (i < 高) { 快排_递归(列表, i, 高) }
}

// 二分查找 (已排序列表, 0)
函数 二分查找(列表, 目标) {
    定义 可变 低 = 0
    定义 可变 高 = 计数(列表) - 1
    当 (低 <= 高) {
        定义 中 = (低 + 高) / 2
        如果 (列表[中] == 目标) { 返回 中 }
        如果 (列表[中] < 目标) { 低 = 中 + 1 }
        否则 { 高 = 中 - 1 }
    }
    返回 0 - 1
}

// 归并排序
函数 归并排序(列表, _扩2) {
    定义 n = 计数(列表)
    如果 (n <= 1) { 返回 列表 }
    定义 中 = n / 2
    定义 可变 左 = []
    定义 可变 右 = []
    定义 可变 i = 0
    当 (i < 中) { 插入(左, 计数(左), 列表[i])
    i = i + 1 }
    当 (i < n) { 插入(右, 计数(右), 列表[i])
    i = i + 1 }
    左 = 归并排序(左, 0)
    右 = 归并排序(右, 0)
    返回 归并合并(左, 右)
}

函数 归并合并(左, 右) {
    定义 可变 结果 = []
    定义 可变 i = 0
    定义 可变 j = 0
    当 (i < 计数(左) 且 j < 计数(右)) {
        如果 (左[i] <= 右[j]) { 插入(结果, 计数(结果), 左[i])
        i = i + 1 }
        否则 { 插入(结果, 计数(结果), 右[j])
        j = j + 1 }
    }
    当 (i < 计数(左)) { 插入(结果, 计数(结果), 左[i])
    i = i + 1 }
    当 (j < 计数(右)) { 插入(结果, 计数(结果), 右[j])
    j = j + 1 }
    返回 结果
}

// 数值积分 (梯形法则)
函数 梯形积分(函数f, a, b, n) {
    定义 h = (b - a) / n
    定义 可变 和 = (函数f(a) + 函数f(b)) / 2
    定义 可变 i = 1
    当 (i < n) {
        和 = 和 + 函数f(a + i * h)
        i = i + 1
    }
    如果 (数学精度 == 0) { 返回 0 }
    返回 和 * h / 数学精度
}

// Simpson积分
函数 simpson积分(函数f, a, b, n) {
    定义 可变 步 = n
    如果 (步 % 2 != 0) { 步 = 步 + 1 }
    定义 h = (b - a) / 步
    定义 可变 和 = 函数f(a) + 函数f(b)
    定义 可变 i = 1
    当 (i < 步) {
        定义 x = a + i * h
        如果 (i % 2 == 0) { 和 = 和 + 2 * 函数f(x) }
        否则 { 和 = 和 + 4 * 函数f(x) }
        i = i + 1
    }
    返回 和 * h / (3 * 数学精度)
}

// 最大公约数
函数 最大公约数(a, b) {
    定义 可变 x = a
    定义 可变 y = b
    如果 (x < 0) { x = 0 - x }
    如果 (y < 0) { y = 0 - y }
    当 (y != 0) {
        定义 t = y
        y = x % y
        x = t
    }
    返回 x
}

// 最小公倍数
函数 工具_最小公倍数(a, b) {
    如果 (a == 0 或 b == 0) { 返回 0 }
    定义 可变 va = a
    定义 可变 vb = b
    如果 (va < 0) { va = 0 - va }
    如果 (vb < 0) { vb = 0 - vb }
    返回 va / 最大公约数(va, vb) * vb
}

// 定点对数 (自然对数近似)
函数 定点ln(x) {
    如果 (x <= 0) { 返回 0 - 99999 }
    定义 可变 结果 = 0
    定义 可变 v = x
    当 (v < 500) { v = v * 2
    结果 = 结果 - 693 }
    当 (v > 数学精度 * 2) { v = v / 2
    结果 = 结果 + 693 }
    // v now in [500, 2000], use Taylor around 1000
    定义 d = (v - 数学精度) * 数学精度 / v
    结果 = 结果 + d - d * d / (2 * 数学精度)
    返回 结果
}

// 定点指数 (e^x 近似)
函数 定点exp(x) {
    // e^(x/1000) * 1000
    如果 (x > 7000) { 返回 0x7FFFFFFF }
    如果 (x < 0 - 7000) { 返回 0 }
    定义 可变 结果 = 数学精度
    定义 可变 v = x
    // 分解: e^x = e^(整数部分) * e^(小数部分)
    当 (v >= 693) { 结果 = 结果 * 2
    v = v - 693 }
    当 (v <= 0 - 693) { 结果 = 结果 / 2
    v = v + 693 }
    // 小数部分 Taylor: e^v ≈ 1 + v + v²/2 + v³/6
    定义 v2 = v * v / 数学精度
    结果 = 结果 * (数学精度 + v + v2 / 2 + v2 * v / (6 * 数学精度)) / 数学精度
    返回 结果
}

// 矩阵打印 (调试)
函数 打印向量(名称, v) {
    打印(名称 + ": " + 转字符串(v))
}

函数 智能FWHT(数据, n) {
    // 大规模自动用GPU
    如果 (n >= GPU_阈值) {
        定义 gpu_ok = GPU初始化(0)
        如果 (gpu_ok == 1) {
            定义 h = GPU分配(n)
            GPU上传(h,  数据, 0)
            GPU_快速沃尔什变换(h, n)
            定义 结果 = GPU下载(h, 0 , 0)
            GPU释放(h)
            GPU关闭()
            返回 结果
        }
    }
    // 回退: CPU FWHT
    定义 可变 步长 = 1
    当 (步长 < n) {
        定义 可变 i = 0
        当 (i < n) {
            定义 组号 = i / 步长
            定义 组内奇偶 = 组号 % 2
            如果 (组内奇偶 == 0) {
                定义 j = i + 步长
                定义 可变 a = 数据[i]
                定义 可变 b = 数据[j]
                数据[i] = a + b
                数据[j] = a - b
            }
            i = i + 1
        }
        步长 = 步长 * 2
    }
    返回 数据
}


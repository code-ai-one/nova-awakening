// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 sys_exit(退出码, _b, _c, _d, _e, _f) {
    定义 当前 = 获取当前进程()
    do_exit(当前, 退出码 & 0xFF)
    // do_exit不返回 — 切换到其他进程
    返回 0
}

函数 sys_exit_group(退出码, _b, _c, _d, _e, _f) {
    定义 当前 = 获取当前进程()
    // exit_group: 终止线程组中所有线程
    定义 线程组 = 进程_线程组(当前)
    如果 (线程组 != 空) {
        定义 可变 i = 0
        当 (i < 计数(线程组)) {
            定义 线程 = 线程组[i]
            如果 (线程 != 当前) {
                信号_发送(线程, SIGKILL)
            }
            i = i + 1
        }
    }
    do_exit(当前, 退出码 & 0xFF)
    返回 0
}

// sys_wait4: 等待子进程状态变化

函数 sys_wait4(pid, 状态指针, 选项, rusage, _e, _f) {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 错误_无此进程 }

    // 检查是否有子进程
    定义 子进程列表 = 进程_子列表(当前)
    如果 (子进程列表 == 空 || 计数(子进程列表) == 0) {
        返回 错误_无子进程   // ECHILD
    }

    循环 {
        // 扫描子进程列表
        定义 可变 i = 0
        当 (i < 计数(子进程列表)) {
            定义 子 = 子进程列表[i]
            定义 子pid = 进程_PID(子)

            // pid参数语义:
            //   > 0: 等待指定pid
            //   -1: 等待任意子进程
            //   0: 等待同进程组的任意子进程
            //   < -1: 等待进程组ID为|pid|的任意子进程
            定义 可变 匹配 = 假
            如果 (pid == -1) { 匹配 = 真 }
            否则 如果 (pid > 0 && 子pid == pid) { 匹配 = 真 }
            否则 如果 (pid == 0 && 进程_组ID(子) == 进程_组ID(当前)) { 匹配 = 真 }
            否则 如果 (pid < -1 && 进程_组ID(子) == -pid) { 匹配 = 真 }

            如果 (匹配 && 进程_状态(子) == 进程状态_僵尸) {
                // 收割zombie子进程
                定义 退出码 = 进程_退出码(子)
                如果 (状态指针 != 空) {
                    设置(状态指针, 0, 退出码 << 8)  // WEXITSTATUS格式
                }
                // 从子进程列表移除并释放task_struct
                进程_从子列表移除(当前, 子)
                进程_释放(子)
                返回 子pid
            }
            i = i + 1
        }

        // WNOHANG: 没有已退出的子进程, 立即返回0
        如果 ((选项 & WNOHANG) != 0) {
            返回 0
        }

        // 阻塞等待: 睡眠直到子进程退出时发送SIGCHLD唤醒
        进程_设置状态(当前, 进程状态_等待)
        调度()
        // 被唤醒后重新扫描
    }
}

// sys_kill: 发送信号到进程

函数 sys_kill(pid, sig, _c, _d, _e, _f) {
    如果 (sig < 0 || sig >= 最大信号) { 返回 错误_无效参数 }

    如果 (pid > 0) {
        // 发送给特定进程
        定义 目标 = 进程表_查找(pid)
        如果 (目标 == 空) { 返回 错误_无此进程 }
        返回 信号_发送(目标, sig)
    }
    如果 (pid == 0) {
        // 发送给同进程组所有进程
        返回 信号_发送给组(进程_组ID(获取当前进程()), sig)
    }
    如果 (pid == -1) {
        // 发送给所有有权限发送的进程(除init和自己)
        返回 信号_发送给全部(sig)
    }
    // pid < -1: 发送给进程组|pid|
    返回 信号_发送给组(-pid, sig)
}

// sys_rt_sigaction / sys_rt_sigprocmask: 信号处理

函数 sys_rt_sigaction(sig, act, oact, sigsetsize, _e, _f) {
    如果 (sig < 1 || sig >= 最大信号) { 返回 错误_无效参数 }
    // SIGKILL和SIGSTOP不能修改处理器
    如果 (sig == SIGKILL || sig == SIGSTOP) { 返回 错误_无效参数 }

    定义 当前 = 获取当前进程()

    // 保存旧处理器
    如果 (oact != 空) {
        定义 旧处理器 = 进程_获取信号处理器(当前, sig)
        设置(oact, 0, 旧处理器)
    }

    // 设置新处理器
    如果 (act != 空) {
        进程_设置信号处理器(当前, sig, act[0])
    }

    返回 成功
}

函数 sys_rt_sigprocmask(how, set, oset, sigsetsize, _e, _f) {
    定义 当前 = 获取当前进程()
    定义 当前掩码 = 进程_信号掩码(当前)

    // 保存旧掩码
    如果 (oset != 空) {
        设置(oset, 0, 当前掩码)
    }

    如果 (set != 空) {
        定义 新集 = set[0]
        // SIGKILL和SIGSTOP不能被屏蔽
        新集 = 新集 & ~(1 << SIGKILL) & ~(1 << SIGSTOP)

        如果 (how == 0) {        // SIG_BLOCK
            进程_设置信号掩码(当前, 当前掩码 | 新集)
        } 否则 如果 (how == 1) { // SIG_UNBLOCK
            进程_设置信号掩码(当前, 当前掩码 & ~新集)
        } 否则 如果 (how == 2) { // SIG_SETMASK
            进程_设置信号掩码(当前, 新集)
        } 否则 {
            返回 错误_无效参数
        }
    }

    返回 成功
}

// sys_setpgid / sys_getpgid / sys_setsid: 进程组/会话

函数 sys_setpgid(pid, pgid, _c, _d, _e, _f) {
    定义 当前 = 获取当前进程()
    定义 可变 目标 = 当前
    如果 (pid != 0 && pid != 进程_PID(当前)) {
        目标 = 进程表_查找(pid)
        如果 (目标 == 空) { 返回 错误_无此进程 }
        // 必须是当前进程的子进程
        如果 (进程_父(目标) != 当前) { 返回 错误_权限 }
    }
    如果 (pgid == 0) { pgid = 进程_PID(目标) }
    进程_设置组ID(目标, pgid)
    返回 成功
}

函数 sys_getpgid(pid, _b, _c, _d, _e, _f) {
    如果 (pid == 0) { 返回 进程_组ID(获取当前进程()) }
    定义 目标 = 进程表_查找(pid)
    如果 (目标 == 空) { 返回 错误_无此进程 }
    返回 进程_组ID(目标)
}

函数 sys_setsid(_a, _b, _c, _d, _e, _f) {
    定义 当前 = 获取当前进程()
    定义 pid = 进程_PID(当前)
    // 如果已经是进程组leader则不能setsid
    如果 (进程_组ID(当前) == pid) {
        返回 错误_权限
    }
    进程_设置组ID(当前, pid)
    进程_设置会话ID(当前, pid)
    返回 pid
}

// sys_uname: 系统信息

函数 sys_uname(buf, _b, _c, _d, _e, _f) {
    如果 (buf == 空) { 返回 错误_无效参数 }
    // struct utsname: sysname, 节点name, release, version, machine, domainname
    定义 uts = 获取uname()
    如果 (uts != 空) {
        设置(buf, 0, uts[0])
        设置(buf, 1, uts[1])
        设置(buf, 2, uts[2])
        设置(buf, 3, uts[3])
        设置(buf, 4, uts[4])
        设置(buf, 5, uts[5])
    } 否则 {
        设置(buf, 0, "NovaOS")
        设置(buf, 1, "nova")
        设置(buf, 2, "1.0.0-M1")
        设置(buf, 3, "#1 SMP NovaOS M1 Prototype")
        设置(buf, 4, "x86_64")
        设置(buf, 5, "(none)")
    }
    返回 成功
}

// sys_sysinfo: 系统状态

函数 sys_sysinfo(buf, _b, _c, _d, _e, _f) {
    如果 (buf == 空) { 返回 错误_无效参数 }
    // struct sysinfo: uptime, loads[3], totalram, freeram, sharedram, bufferram, totalswap, freeswap, procs
    设置(buf, 0, 获取uptime秒())
    设置(buf, 1, 获取负载1分())
    设置(buf, 2, 获取负载5分())
    设置(buf, 3, 获取负载15分())
    设置(buf, 4, 获取总内存())
    设置(buf, 5, 获取空闲内存())
    设置(buf, 6, 共享页数() * 4096)
    设置(buf, 7, 缓冲区_页数() * 4096)
    设置(buf, 8, 获取交换总量KB() * 1024)
    设置(buf, 9, 获取交换空闲KB() * 1024)
    设置(buf, 10, 获取进程总数())
    返回 0
}


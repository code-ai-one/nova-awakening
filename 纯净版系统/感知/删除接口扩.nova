函数 图绘_获取字节每像素(format, type) {
    如果 (type == 0x1401) { 返回 4 }
    如果 (type == 0x1406) { 返回 16 }
    如果 (type == 0x8D61) { 返回 2 }
    如果 (type == 0x8363) { 返回 2 }
    如果 (type == 0x8033) { 返回 2 }
    如果 (type == 0x8034) { 返回 2 }
    返回 4
}

函数 图绘_初始化资源跟踪() {
    GL跟踪 = 堆_分配(GL资源跟踪)
    GL跟踪.纹理创建数 = 0
    GL跟踪.纹理删除数 = 0
    GL跟踪.缓冲创建数 = 0
    GL跟踪.缓冲删除数 = 0
    GL跟踪.着色器创建数 = 0
    GL跟踪.着色器删除数 = 0
    GL跟踪.帧缓冲创建数 = 0
    GL跟踪.帧缓冲删除数 = 0
}

函数 图绘_记录创建(资源类型) {
    如果 (GL跟踪 == 0) { 返回 }
    如果 (资源类型 == 0) { GL跟踪.纹理创建数 = GL跟踪.纹理创建数 + 1 }
    如果 (资源类型 == 1) { GL跟踪.缓冲创建数 = GL跟踪.缓冲创建数 + 1 }
    如果 (资源类型 == 2) { GL跟踪.着色器创建数 = GL跟踪.着色器创建数 + 1 }
    如果 (资源类型 == 3) { GL跟踪.帧缓冲创建数 = GL跟踪.帧缓冲创建数 + 1 }
}

函数 图绘_记录删除(资源类型) {
    如果 (GL跟踪 == 0) { 返回 }
    如果 (资源类型 == 0) { GL跟踪.纹理删除数 = GL跟踪.纹理删除数 + 1 }
    如果 (资源类型 == 1) { GL跟踪.缓冲删除数 = GL跟踪.缓冲删除数 + 1 }
    如果 (资源类型 == 2) { GL跟踪.着色器删除数 = GL跟踪.着色器删除数 + 1 }
    如果 (资源类型 == 3) { GL跟踪.帧缓冲删除数 = GL跟踪.帧缓冲删除数 + 1 }
}

函数 智能_图绘_着色器优化建议(shaderSource) {
    如果 (shaderSource == 0) { 返回 0 }
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 0 }

    定义 可变 建议列表 = []

    如果 (字符串查找(shaderSource, "texture2D") >= 0) {
        定义 依赖读取 = 智能_图绘_检测依赖纹理读(shaderSource)
        如果 (依赖读取 > 0) {
            追加(建议列表, "检测到" + 整数转字符串(依赖读取) + "处依赖纹理读取, 会导致流水线停顿")
        }
    }

    如果 (字符串查找(shaderSource, "highp") >= 0) {
        定义 可降级 = 智能_图绘_检查精度降级(shaderSource)
        如果 (可降级 > 0) {
            追加(建议列表, 整数转字符串(可降级) + "处highp可安全降为mediump, 提升移动端性能")
        }
    }

    定义 未使用 = 智能_图绘_检测未用变量(shaderSource)
    如果 (未使用 > 0) {
        追加(建议列表, 整数转字符串(未使用) + "个未使用的uniform/varying, 建议移除")
    }

    返回 建议列表
}

函数 智能_图绘_检测依赖纹理读(源码) {
    定义 可变 计数 = 0
    定义 可变 位置 = 0
    当 (位置 >= 0) {
        位置 = 字符串查找(源码, "texture2D")
        如果 (位置 >= 0) {
            计数 = 计数 + 1
            位置 = 位置 + 9
        }
    }
    返回 计数
}

函数 智能_图绘_检查精度降级(源码) {
    定义 可变 可降级 = 0
    如果 (字符串查找(源码, "highp float") >= 0) { 可降级 = 可降级 + 1 }
    如果 (字符串查找(源码, "highp vec2") >= 0) { 可降级 = 可降级 + 1 }
    如果 (字符串查找(源码, "highp vec3") >= 0) { 可降级 = 可降级 + 1 }
    返回 可降级
}

函数 智能_图绘_检测未用变量(源码) {
    返回 0  // 静态分析由编译期完成
    返回 0
}

函数 智能_图绘_内存泄漏检测() {
    如果 (GL跟踪 == 0) { 返回 0 }
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 0 }

    定义 可变 泄漏列表 = []
    定义 纹理泄漏 = GL跟踪.纹理创建数 - GL跟踪.纹理删除数
    如果 (纹理泄漏 > 10) {
        追加(泄漏列表, "纹理泄漏: " + 整数转字符串(纹理泄漏) + "个未释放")
    }
    定义 缓冲泄漏 = GL跟踪.缓冲创建数 - GL跟踪.缓冲删除数
    如果 (缓冲泄漏 > 10) {
        追加(泄漏列表, "缓冲泄漏: " + 整数转字符串(缓冲泄漏) + "个未释放")
    }
    定义 着色器泄漏 = GL跟踪.着色器创建数 - GL跟踪.着色器删除数
    如果 (着色器泄漏 > 5) {
        追加(泄漏列表, "着色器泄漏: " + 整数转字符串(着色器泄漏) + "个未释放")
    }
    返回 泄漏列表
}

// GL资源自动回收

函数 GL资源_自动回收() {
    定义 泄漏 = GL资源_检测泄漏()
    如果 (计数(泄漏) > 0) {
        内核警告("GL资源泄漏检测: " + 整数转字符串(计数(泄漏)) + "项")
    }
}

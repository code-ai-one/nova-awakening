导入("../感知/删除.nova")
导入("./头部查.nova")
导入("./搜索.nova")
导入("./创建目录.nova")
导入("./改权限.nova")
导入("./远程连.nova")
导入("./磁盘查.nova")
导入("./归档.nova")
导入("../中枢/整数转字符串.nova")
导入("./远程拷.nova")
导入("./字数统.nova")
导入("./查看.nova")
导入("./尾部查.nova")

结构 工具档 {
    名称,
    最近命令,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    初始化完成,
    目录数,
    删除数,
    查看数,
    搜索数,
    权限数,
    磁盘数,
    归档数,
    远程数,
    命中数,
    失败数,
    健康,
}

结构 工具请求 {
    动作,
    源,
    目标,
    模式,
    文本,
    选项,
}

结构 工具回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 工具摘要 {
    名称,
    目录数,
    删除数,
    查看数,
    搜索数,
    权限数,
    磁盘数,
    归档数,
    远程数,
    命中数,
    失败数,
    健康,
}

定义 可变 工具账本 = []
定义 可变 工具建数 = 0
定义 可变 工具总动作 = 0
定义 可变 工具总命中 = 0
定义 可变 工具总失败 = 0

函数 工具文件_建档(名称) {
    定义 档 = 堆_分配(工具档)
    档.名称 = 名称
    档.最近命令 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = 0
    档.最近错误 = ""
    档.初始化完成 = 假
    档.目录数 = 0
    档.删除数 = 0
    档.查看数 = 0
    档.搜索数 = 0
    档.权限数 = 0
    档.磁盘数 = 0
    档.归档数 = 0
    档.远程数 = 0
    档.命中数 = 0
    档.失败数 = 0
    档.健康 = "未初始化"
    返回 档
}

函数 工具文件_登记(档) {
    追加(工具账本, 档)
    工具建数 = 工具建数 + 1
    返回 档
}

函数 工具文件_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 堆_分配(工具回证)
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 工具文件_成功(档, 来源, 数据) {
    档.最近来源 = 来源
    档.最近结果 = 数据
    档.最近错误 = ""
    档.命中数 = 档.命中数 + 1
    档.健康 = "运行"
    工具总动作 = 工具总动作 + 1
    工具总命中 = 工具总命中 + 1
    返回 工具文件_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 工具文件_失败(档, 来源, 错因) {
    档.最近来源 = 来源
    档.最近错误 = 错因
    档.失败数 = 档.失败数 + 1
    档.健康 = "降级"
    工具总动作 = 工具总动作 + 1
    工具总失败 = 工具总失败 + 1
    返回 工具文件_建回证(真, 假, 来源, 错因, 0, 档.最近统计)
}

函数 工具文件_初始化(档) {
    档.初始化完成 = 真
    档.健康 = "运行"
    档.最近统计 = 工具文件_完整统计()
    返回 档
}

函数 工具文件_创建(名称) {
    定义 档 = 工具文件_建档(名称)
    工具文件_初始化(档)
    返回 工具文件_登记(档)
}

函数 工具文件_建请求(动作, 源, 目标, 模式, 文本, 选项) {
    定义 请求 = 堆_分配(工具请求)
    请求.动作 = 动作
    请求.源 = 源
    请求.目标 = 目标
    请求.模式 = 模式
    请求.文本 = 文本
    请求.选项 = 选项
    返回 请求
}

函数 工具文件_建参数() {
    // 创建工具文件操作的参数容器(键值对列表)
    返回 { 项目: [], 计数: 0 }
}

函数 工具文件_加参(参数, 值) {
    追加(参数, 值)
    返回 参数
}

函数 工具文件_若加(参数, 条件, 值) {
    如果 (条件) {
        追加(参数, 值)
    }
    返回 参数
}

函数 工具文件_记录请求(档, 命令, 参数, 来源) {
    档.最近命令 = 命令
    档.最近参数 = 参数
    档.最近来源 = 来源
}

函数 工具文件_创目录(档, 路径, 递归, 详细, 权限) {
    定义 参数 = 工具文件_建参数()
    工具文件_若加(参数, 递归, "-p")
    工具文件_若加(参数, 详细, "-v")
    如果 (权限 != "") {
        工具文件_加参(参数, "-m")
        工具文件_加参(参数, 权限)
    }
    工具文件_加参(参数, 路径)
    工具文件_记录请求(档, "mkdir", 参数, "创目录")
    定义 结果 = mkdir_main(参数)
    档.目录数 = 档.目录数 + 1
    档.最近统计 = [档.目录数, 档.删除数, 档.查看数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "创目录", "目录创建失败") }
    返回 工具文件_成功(档, "创目录", 路径)
}

函数 工具文件_删路径(档, 路径, 递归, 强制, 详细) {
    定义 参数 = 工具文件_建参数()
    工具文件_若加(参数, 递归, "-r")
    工具文件_若加(参数, 强制, "-f")
    工具文件_若加(参数, 详细, "-v")
    工具文件_加参(参数, 路径)
    工具文件_记录请求(档, "rm", 参数, "删路径")
    定义 结果 = rm_main(参数)
    档.删除数 = 档.删除数 + 1
    档.最近统计 = [档.删除数, 档.失败数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "删路径", "路径删除失败") }
    返回 工具文件_成功(档, "删路径", 路径)
}

函数 工具文件_头查(档, 路径, 行数, 字节数) {
    定义 参数 = 工具文件_建参数()
    如果 (字节数 > 0) {
        工具文件_加参(参数, "-c")
        工具文件_加参(参数, 整数转字符串(字节数))
    } 否则 {
        工具文件_加参(参数, "-n")
        工具文件_加参(参数, 整数转字符串(行数))
    }
    工具文件_加参(参数, 路径)
    工具文件_记录请求(档, "head", 参数, "头查")
    定义 结果 = head_main(参数)
    档.查看数 = 档.查看数 + 1
    档.最近统计 = [档.查看数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "头查", "头部读取失败") }
    返回 工具文件_成功(档, "头查", 路径)
}

函数 工具文件_尾查(档, 路径, 行数, 跟踪) {
    定义 参数 = 工具文件_建参数()
    工具文件_加参(参数, "-n")
    工具文件_加参(参数, 整数转字符串(行数))
    工具文件_若加(参数, 跟踪, "-f")
    工具文件_加参(参数, 路径)
    工具文件_记录请求(档, "tail", 参数, "尾查")
    定义 结果 = tail_main(参数)
    档.查看数 = 档.查看数 + 1
    档.最近统计 = [档.查看数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "尾查", "尾部读取失败") }
    返回 工具文件_成功(档, "尾查", 路径)
}

函数 工具文件_查看(档, 路径, 行号, 行尾, 制表, 统计字节) {
    定义 参数 = 工具文件_建参数()
    工具文件_若加(参数, 行号, "-n")
    工具文件_若加(参数, 行尾, "-E")
    工具文件_若加(参数, 制表, "-T")
    工具文件_若加(参数, 统计字节, "-c")
    工具文件_加参(参数, 路径)
    工具文件_记录请求(档, "cat", 参数, "查看")
    定义 结果 = cat_main(参数)
    档.查看数 = 档.查看数 + 1
    档.最近统计 = [档.查看数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "查看", "文件查看失败") }
    返回 工具文件_成功(档, "查看", 路径)
}

函数 工具文件_复制(档, 源, 目标, 递归, 保留, 详细) {
    定义 参数 = 工具文件_建参数()
    工具文件_若加(参数, 递归, "-r")
    工具文件_若加(参数, 保留, "-p")
    工具文件_若加(参数, 详细, "-v")
    工具文件_加参(参数, 源)
    工具文件_加参(参数, 目标)
    工具文件_记录请求(档, "cp", 参数, "复制")
    定义 结果 = cp_main(参数)
    档.查看数 = 档.查看数 + 1
    档.最近统计 = [档.查看数, 档.目录数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "复制", "复制失败") }
    返回 工具文件_成功(档, "复制", [源, 目标])
}

函数 工具文件_搜索(档, 模式, 路径列表, 忽略大小写, 行号, 递归, 正则) {
    定义 参数 = 工具文件_建参数()
    工具文件_若加(参数, 忽略大小写, "-i")
    工具文件_若加(参数, 行号, "-n")
    工具文件_若加(参数, 递归, "-r")
    工具文件_若加(参数, 正则, "-E")
    工具文件_加参(参数, 模式)
    定义 可变 i = 0
    当 (i < 计数(路径列表)) {
        工具文件_加参(参数, 路径列表[i])
        i = i + 1
    }
    工具文件_记录请求(档, "grep", 参数, "搜索")
    定义 结果 = grep_main(参数)
    档.搜索数 = 档.搜索数 + 1
    档.最近统计 = [档.搜索数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "搜索", "搜索未命中或失败") }
    返回 工具文件_成功(档, "搜索", 模式)
}

函数 工具文件_改权限(档, 模式, 路径, 递归, 详细) {
    定义 参数 = 工具文件_建参数()
    工具文件_若加(参数, 递归, "-R")
    工具文件_若加(参数, 详细, "-v")
    工具文件_加参(参数, 模式)
    工具文件_加参(参数, 路径)
    工具文件_记录请求(档, "chmod", 参数, "改权限")
    定义 结果 = chmod_main(参数)
    档.权限数 = 档.权限数 + 1
    档.最近统计 = [档.权限数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "改权限", "权限调整失败") }
    返回 工具文件_成功(档, "改权限", [路径, 模式])
}

函数 工具文件_磁盘查(档, 路径, 人类可读, inode, 类型, 进度条) {
    定义 参数 = 工具文件_建参数()
    工具文件_若加(参数, 人类可读, "-h")
    工具文件_若加(参数, inode, "-i")
    工具文件_若加(参数, 类型, "-T")
    工具文件_若加(参数, 进度条, "-b")
    如果 (路径 != "") {
        工具文件_加参(参数, 路径)
    }
    工具文件_记录请求(档, "df", 参数, "磁盘查")
    定义 结果 = df_main(参数)
    档.磁盘数 = 档.磁盘数 + 1
    档.最近统计 = [档.磁盘数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "磁盘查", "磁盘查询失败") }
    返回 工具文件_成功(档, "磁盘查", 路径)
}

函数 工具文件_字数统(档, 路径列表, 行, 词, 字节, 字符, 最长行) {
    定义 参数 = 工具文件_建参数()
    工具文件_若加(参数, 行, "-l")
    工具文件_若加(参数, 词, "-w")
    工具文件_若加(参数, 字节, "-c")
    工具文件_若加(参数, 字符, "-m")
    工具文件_若加(参数, 最长行, "-L")
    定义 可变 i = 0
    当 (i < 计数(路径列表)) {
        工具文件_加参(参数, 路径列表[i])
        i = i + 1
    }
    工具文件_记录请求(档, "wc", 参数, "字数统")
    定义 结果 = wc_main(参数)
    档.查看数 = 档.查看数 + 1
    档.最近统计 = [档.查看数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "字数统", "字数统计失败") }
    返回 工具文件_成功(档, "字数统", 路径列表)
}

函数 工具文件_挂载(档, 设备, 挂载点, 类型, 只读, 详细) {
    定义 参数 = 工具文件_建参数()
    如果 (类型 != "") {
        工具文件_加参(参数, "-t")
        工具文件_加参(参数, 类型)
    }
    工具文件_若加(参数, 只读, "-r")
    工具文件_若加(参数, 详细, "-v")
    工具文件_加参(参数, 设备)
    工具文件_加参(参数, 挂载点)
    工具文件_记录请求(档, "mount", 参数, "挂载")
    定义 结果 = mount_main(参数)
    档.磁盘数 = 档.磁盘数 + 1
    档.最近统计 = [档.磁盘数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "挂载", "挂载失败") }
    返回 工具文件_成功(档, "挂载", [设备, 挂载点])
}

函数 工具文件_卸载(档, 挂载点, 详细) {
    定义 参数 = 工具文件_建参数()
    工具文件_若加(参数, 详细, "-v")
    工具文件_加参(参数, 挂载点)
    工具文件_记录请求(档, "umount", 参数, "卸载")
    定义 结果 = umount_main(参数)
    档.磁盘数 = 档.磁盘数 + 1
    档.最近统计 = [档.磁盘数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "卸载", "卸载失败") }
    返回 工具文件_成功(档, "卸载", 挂载点)
}

函数 工具文件_列挂载(档) {
    定义 参数 = 工具文件_建参数()
    工具文件_记录请求(档, "mount", 参数, "列挂载")
    定义 结果 = mount_main(参数)
    档.磁盘数 = 档.磁盘数 + 1
    档.最近统计 = [档.磁盘数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "列挂载", "挂载表读取失败") }
    返回 工具文件_成功(档, "列挂载", 真)
}

函数 工具文件_建归档(档, 归档文件, 文件列表, 详细, 压缩) {
    定义 参数 = 工具文件_建参数()
    工具文件_加参(参数, "-c")
    工具文件_若加(参数, 详细, "-v")
    如果 (压缩 == "gzip") { 工具文件_加参(参数, "-z") }
    否则 如果 (压缩 == "bzip2") { 工具文件_加参(参数, "-j") }
    否则 如果 (压缩 == "xz") { 工具文件_加参(参数, "-J") }
    工具文件_加参(参数, "-f")
    工具文件_加参(参数, 归档文件)
    定义 可变 i = 0
    当 (i < 计数(文件列表)) {
        工具文件_加参(参数, 文件列表[i])
        i = i + 1
    }
    工具文件_记录请求(档, "tar", 参数, "建归档")
    定义 结果 = tar_main(参数)
    档.归档数 = 档.归档数 + 1
    档.最近统计 = [档.归档数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "建归档", "归档创建失败") }
    返回 工具文件_成功(档, "建归档", 归档文件)
}

函数 工具文件_解归档(档, 归档文件, 目标目录, 详细, 压缩, 保留权限) {
    定义 参数 = 工具文件_建参数()
    工具文件_加参(参数, "-x")
    工具文件_若加(参数, 详细, "-v")
    工具文件_若加(参数, 保留权限, "-p")
    如果 (压缩 == "gzip") { 工具文件_加参(参数, "-z") }
    否则 如果 (压缩 == "bzip2") { 工具文件_加参(参数, "-j") }
    否则 如果 (压缩 == "xz") { 工具文件_加参(参数, "-J") }
    工具文件_加参(参数, "-f")
    工具文件_加参(参数, 归档文件)
    如果 (目标目录 != "") {
        工具文件_加参(参数, "-C")
        工具文件_加参(参数, 目标目录)
    }
    工具文件_记录请求(档, "tar", 参数, "解归档")
    定义 结果 = tar_main(参数)
    档.归档数 = 档.归档数 + 1
    档.最近统计 = [档.归档数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "解归档", "归档解压失败") }
    返回 工具文件_成功(档, "解归档", 目标目录)
}

函数 工具文件_列归档(档, 归档文件, 详细) {
    定义 参数 = 工具文件_建参数()
    工具文件_加参(参数, "-t")
    工具文件_若加(参数, 详细, "-v")
    工具文件_加参(参数, "-f")
    工具文件_加参(参数, 归档文件)
    工具文件_记录请求(档, "tar", 参数, "列归档")
    定义 结果 = tar_main(参数)
    档.归档数 = 档.归档数 + 1
    档.最近统计 = [档.归档数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "列归档", "归档列表失败") }
    返回 工具文件_成功(档, "列归档", 归档文件)
}

函数 工具文件_远程上传(档, 本地路径, 远程地址, 递归, 详细, 压缩) {
    定义 参数 = 工具文件_建参数()
    工具文件_若加(参数, 递归, "-r")
    工具文件_若加(参数, 详细, "-v")
    工具文件_若加(参数, 压缩, "-C")
    工具文件_加参(参数, 本地路径)
    工具文件_加参(参数, 远程地址)
    工具文件_记录请求(档, "scp", 参数, "远程上传")
    定义 结果 = scp_main(参数)
    档.远程数 = 档.远程数 + 1
    档.最近统计 = [档.远程数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "远程上传", "远程上传失败") }
    返回 工具文件_成功(档, "远程上传", [本地路径, 远程地址])
}

函数 工具文件_远程下载(档, 远程地址, 本地路径, 递归, 详细, 压缩) {
    定义 参数 = 工具文件_建参数()
    工具文件_若加(参数, 递归, "-r")
    工具文件_若加(参数, 详细, "-v")
    工具文件_若加(参数, 压缩, "-C")
    工具文件_加参(参数, 远程地址)
    工具文件_加参(参数, 本地路径)
    工具文件_记录请求(档, "scp", 参数, "远程下载")
    定义 结果 = scp_main(参数)
    档.远程数 = 档.远程数 + 1
    档.最近统计 = [档.远程数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "远程下载", "远程下载失败") }
    返回 工具文件_成功(档, "远程下载", [远程地址, 本地路径])
}

函数 工具文件_远程互拷(档, 源远程, 目标远程, 详细) {
    定义 参数 = 工具文件_建参数()
    工具文件_若加(参数, 详细, "-v")
    工具文件_加参(参数, 源远程)
    工具文件_加参(参数, 目标远程)
    工具文件_记录请求(档, "scp", 参数, "远程互拷")
    定义 结果 = scp_main(参数)
    档.远程数 = 档.远程数 + 1
    档.最近统计 = [档.远程数]
    如果 (结果 != 0) { 返回 工具文件_失败(档, "远程互拷", "远程互拷失败") }
    返回 工具文件_成功(档, "远程互拷", [源远程, 目标远程])

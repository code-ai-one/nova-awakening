// 对应: nova/Nova渲染核心/html/media/ (
// nova/renderer/platform/media/ (
// media/base/ + media/filters/ (
// HTML5 媒体规范:
// HTML媒体元素: <audio>/<video>共用基类
// 媒体Source Extensions (MSE): 流媒体自适应播放
// Encrypted 媒体 Extensions (EME): DRM加密媒体
// WebVTT: 字幕格式解析和渲染
// TextTrack: 字幕/标题/描述轨道
// 播放管线:
// 网络获取 → 解复用(Demuxer) → 解码(Decoder) → 渲染(渲染er)
// 音频: Demux → 音频Decoder → 音频渲染er → 音频Device
// 视频: Demux → 视频Decoder → 视频渲染er → Compositor
// 状态机 (HTML媒体元素):
// HAVE_NOTHING → HAVE_METADATA → HAVE_CURRENT_DATA →
// HAVE_FUTURE_DATA → HAVE_ENOUGH_DATA
// 【Nova特色】AI媒体优化:
// ① AI预测网络带宽, 自适应选择码率
// ② AI音频增强(降噪/均衡)
// ③ AI视频超分辨率

导入("./文档节点.nova")
导入("./文档事件.nova")
导入("./内核直连层.nova")
导入("../推理/通信总线.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/整数转字符串.nova")

// §1 媒体常量

// 网络状态
定义 NETWORK_EMPTY = 0
定义 NETWORK_IDLE = 1
定义 NETWORK_LOADING = 2
定义 NETWORK_NO_SOURCE = 3

// 就绪状态
定义 HAVE_NOTHING = 0
定义 HAVE_METADATA = 1
定义 HAVE_CURRENT_DATA = 2
定义 HAVE_FUTURE_DATA = 3
定义 HAVE_ENOUGH_DATA = 4

// 错误码
定义 MEDIA_ERR_ABORTED = 1
定义 MEDIA_ERR_NETWORK = 2
定义 MEDIA_ERR_DECODE = 3
定义 MEDIA_ERR_SRC_NOT_SUPPORTED = 4

// 预加载
定义 PRELOAD_NONE = 0
定义 PRELOAD_METADATA = 1
定义 PRELOAD_AUTO = 2

// 轨道类型
定义 TRACK_AUDIO = 0
定义 TRACK_VIDEO = 1
定义 TRACK_TEXT = 2

// 文本轨道模式
定义 TEXT_TRACK_DISABLED = 0
定义 TEXT_TRACK_HIDDEN = 1
定义 TEXT_TRACK_SHOWING = 2

// 文本轨道类型
定义 TEXT_KIND_SUBTITLES = 0
定义 TEXT_KIND_CAPTIONS = 1
定义 TEXT_KIND_DESCRIPTIONS = 2
定义 TEXT_KIND_CHAPTERS = 3
定义 TEXT_KIND_METADATA = 4

// 编解码器ID
定义 CODEC_UNKNOWN = 0
定义 CODEC_H264 = 1
定义 CODEC_H265 = 2
定义 CODEC_VP8 = 3
定义 CODEC_VP9 = 4
定义 CODEC_AV1 = 5
定义 CODEC_AAC = 10
定义 CODEC_MP3 = 11
定义 CODEC_OPUS = 12
定义 CODEC_VORBIS = 13
定义 CODEC_FLAC = 14

// 容器格式
定义 CONTAINER_MP4 = 1
定义 CONTAINER_WEBM = 2
定义 CONTAINER_OGG = 3
定义 CONTAINER_MP3 = 4
定义 CONTAINER_WAV = 5
定义 CONTAINER_HLS = 6 // m3u8
定义 CONTAINER_DASH = 7 // mpd

// 播放状态
定义 PLAY_STATE_IDLE = 0
定义 PLAY_STATE_PLAYING = 1
定义 PLAY_STATE_PAUSED = 2
定义 PLAY_STATE_ENDED = 3
定义 PLAY_STATE_SEEKING = 4
定义 PLAY_STATE_STALLED = 5
定义 PLAY_STATE_ERROR = 6

定义 媒体_最大轨道数 = 16
定义 媒体_最大缓冲段 = 32
定义 媒体_最大源列表 = 8

// §2 核心结构

结构 时间范围 {
    起始,
    结束,
}

结构 媒体轨道 {
    ID,
    类型,
    标签,
    语言,
    编解码器,
    已启用,
    采样率,
    通道数,
    宽度,
    高度,
    帧率,
    比特率,
}

结构 文本轨道 {
    ID,
    种类,
    标签,
    语言,
    模式,
    提示列表,
    提示数,
}

结构 文本提示 {
    ID,
    起始时间,
    结束时间,
    文本,
    对齐,
    行号,
}

结构 媒体源 {
    地址,
    类型,
    媒体查询,
    优先级,
}

结构 HTML媒体元素 {
    // DOM节点基础
    节点基类,

    // 源
    源地址,
    源列表,
    源数,
    当前源索引,

    // 状态
    网络状态,
    就绪状态,
    播放状态,
    错误码,

    // 播放属性
    当前时间,
    时长,
    播放速率,
    默认播放速率,
    音量,
    已静音,
    自动播放,
    循环播放,
    预加载,
    海报地址,

    // 缓冲
    已缓冲范围,
    已缓冲段数,
    已播放范围,
    已播放段数,
    可跳转范围,
    可跳转段数,

    // 轨道
    音频轨道列表,
    音频轨道数,
    视频轨道列表,
    视频轨道数,
    文本轨道列表,
    文本轨道数,

    // 容器与编解码
    容器格式,
    视频编解码器,
    音频编解码器,

    // 视频尺寸
    视频宽度,
    视频高度,
    自然宽度,
    自然高度,

    // 事件回调
    播放回调,
    暂停回调,
    结束回调,
    错误回调,
    时间更新回调,
    加载元数据回调,
    跳转回调,
    缓冲回调,
}

结构 媒体统计 {
    播放次数,
    暂停次数,
    跳转次数,
    缓冲次数,
    错误次数,
    总播放时长,
    最大缓冲时长,
    码率切换次数,
}

定义 可变 全局_媒体统计 = 空


函数 媒体统计_初始化() {
    如果 (全局_媒体统计 == 空) {
        全局_媒体统计 = 媒体统计 {}
        全局_媒体统计.播放次数 = 0
        全局_媒体统计.暂停次数 = 0
        全局_媒体统计.跳转次数 = 0
        全局_媒体统计.缓冲次数 = 0
        全局_媒体统计.错误次数 = 0
        全局_媒体统计.总播放时长 = 0
        全局_媒体统计.最大缓冲时长 = 0
        全局_媒体统计.码率切换次数 = 0
    }
}

// §3 媒体元素创建与初始化

函数 媒体元素_创建() {
    定义 元素 = 堆_分配(HTML媒体元素)
    元素.源地址 = 0
    元素.源列表 = 堆_分配(媒体_最大源列表 * 8)
    元素.源数 = 0
    元素.当前源索引 = 0
    元素.网络状态 = NETWORK_EMPTY
    元素.就绪状态 = HAVE_NOTHING
    元素.播放状态 = PLAY_STATE_IDLE
    元素.错误码 = 0
    元素.当前时间 = 0
    元素.时长 = 0
    元素.播放速率 = 1000    // 1.0x (定点数, *1000)
    元素.默认播放速率 = 1000
    元素.音量 = 1000        // 1.0 (定点数)
    元素.已静音 = 假
    元素.自动播放 = 假
    元素.循环播放 = 假
    元素.预加载 = PRELOAD_AUTO
    元素.海报地址 = 0
    元素.已缓冲范围 = 堆_分配(媒体_最大缓冲段 * 16)
    元素.已缓冲段数 = 0
    元素.已播放范围 = 堆_分配(媒体_最大缓冲段 * 16)
    元素.已播放段数 = 0
    元素.可跳转范围 = 堆_分配(媒体_最大缓冲段 * 16)
    元素.可跳转段数 = 0
    元素.音频轨道列表 = 堆_分配(媒体_最大轨道数 * 8)
    元素.音频轨道数 = 0
    元素.视频轨道列表 = 堆_分配(媒体_最大轨道数 * 8)
    元素.视频轨道数 = 0
    元素.文本轨道列表 = 堆_分配(媒体_最大轨道数 * 8)
    元素.文本轨道数 = 0
    元素.容器格式 = 0
    元素.视频编解码器 = CODEC_UNKNOWN
    元素.音频编解码器 = CODEC_UNKNOWN
    元素.视频宽度 = 0
    元素.视频高度 = 0
    元素.播放回调 = 0
    元素.暂停回调 = 0
    元素.结束回调 = 0
    元素.错误回调 = 0
    元素.时间更新回调 = 0
    元素.加载元数据回调 = 0
    元素.跳转回调 = 0
    元素.缓冲回调 = 0
    返回 元素
}

// §4 源管理

函数 媒体元素_设置源(元素, 地址) {
    如果 (元素 == 0) { 返回 }
    元素.源地址 = 地址
    元素.网络状态 = NETWORK_LOADING
    元素.就绪状态 = HAVE_NOTHING
    媒体元素_加载(元素)
}

函数 媒体元素_添加源(元素, 地址, 类型, 优先级) {
    如果 (元素 == 0 || 元素.源数 >= 媒体_最大源列表) { 返回 }
    定义 源 = 媒体源 {}
    源.地址 = 地址
    源.类型 = 类型
    源.优先级 = 优先级
    内存_写64(元素.源列表 + 元素.源数 * 8, 源)
    元素.源数 = 元素.源数 + 1
}

函数 媒体元素_选择最佳源(元素) {
    如果 (元素 == 0 || 元素.源数 == 0) { 返回 空 }
    定义 可变 最佳 = 0
    定义 可变 最高优先级 = -1
    定义 可变 i = 0
    当 (i < 元素.源数) {
        定义 源 = 内存_读64(元素.源列表 + i * 8)
        如果 (源.优先级 > 最高优先级) {
            最高优先级 = 源.优先级
            最佳 = 源
        }
        i = i + 1
    }
    返回 最佳
}

函数 媒体元素_加载(元素) {
    如果 (元素 == 0) { 返回 }
    元素.网络状态 = NETWORK_LOADING

    // 如果有源列表, 选择最佳源
    如果 (元素.源地址 == 0 && 元素.源数 > 0) {
        定义 源 = 媒体元素_选择最佳源(元素)
        如果 (源 != 空) {
            元素.源地址 = 源.地址
        }
    }

    如果 (元素.源地址 == 0) {
        元素.网络状态 = NETWORK_NO_SOURCE
        返回
    }

    // 检测容器格式
    元素.容器格式 = 媒体_检测容器(元素.源地址)
}

// §5 播放控制

函数 媒体元素_播放(元素) {
    媒体统计_初始化()
    如果 (元素 == 0) { 返回 }
    如果 (元素.网络状态 == NETWORK_NO_SOURCE) { 返回 }

    元素.播放状态 = PLAY_STATE_PLAYING
    全局_媒体统计.播放次数 = 全局_媒体统计.播放次数 + 1

    如果 (元素.播放回调 != 0) { 元素.播放回调(元素) }
}

函数 媒体元素_暂停(元素) {
    媒体统计_初始化()
    如果 (元素 == 0) { 返回 }
    如果 (元素.播放状态 != PLAY_STATE_PLAYING) { 返回 }

    元素.播放状态 = PLAY_STATE_PAUSED
    全局_媒体统计.暂停次数 = 全局_媒体统计.暂停次数 + 1

    如果 (元素.暂停回调 != 0) { 元素.暂停回调(元素) }
}

函数 媒体元素_跳转(元素, 时间) {
    媒体统计_初始化()
    如果 (元素 == 0) { 返回 }
    如果 (时间 < 0) { 时间 = 0 }
    如果 (元素.时长 > 0 && 时间 > 元素.时长) { 时间 = 元素.时长 }

    定义 旧状态 = 元素.播放状态
    元素.播放状态 = PLAY_STATE_SEEKING
    元素.当前时间 = 时间
    全局_媒体统计.跳转次数 = 全局_媒体统计.跳转次数 + 1

    如果 (元素.跳转回调 != 0) { 元素.跳转回调(元素) }

    // 跳转完成后恢复状态
    元素.播放状态 = 旧状态
}

函数 媒体元素_停止(元素) {
    如果 (元素 == 0) { 返回 }
    元素.播放状态 = PLAY_STATE_IDLE
    元素.当前时间 = 0
}

函数 媒体元素_结束(元素) {
    媒体统计_初始化()
    如果 (元素 == 0) { 返回 }

    如果 (元素.循环播放) {
        元素.当前时间 = 0
        媒体元素_播放(元素)
        返回
    }

    元素.播放状态 = PLAY_STATE_ENDED
    如果 (元素.结束回调 != 0) { 元素.结束回调(元素) }
}

函数 媒体元素_设置音量(元素, 音量) {
    如果 (元素 == 0) { 返回 }
    如果 (音量 < 0) { 音量 = 0 }
    如果 (音量 > 1000) { 音量 = 1000 }
    元素.音量 = 音量
}

函数 媒体元素_切换静音(元素) {
    如果 (元素 == 0) { 返回 }
    元素.已静音 = !元素.已静音
}

函数 媒体元素_设置速率(元素, 速率) {
    如果 (元素 == 0) { 返回 }
    如果 (速率 < 250) { 速率 = 250 }     // 最低0.25x
    如果 (速率 > 4000) { 速率 = 4000 }   // 最高4.0x
    元素.播放速率 = 速率
}

// §6 缓冲管理

函数 媒体元素_添加缓冲段(元素, 起始, 结束) {
    如果 (元素 == 0 || 元素.已缓冲段数 >= 媒体_最大缓冲段) { 返回 }
    定义 偏移 = 元素.已缓冲段数 * 16
    内存_写64(元素.已缓冲范围 + 偏移, 起始)
    内存_写64(元素.已缓冲范围 + 偏移 + 8, 结束)
    元素.已缓冲段数 = 元素.已缓冲段数 + 1

    // 合并重叠段
    媒体_合并时间范围(元素.已缓冲范围, 元素.已缓冲段数)
}

函数 媒体元素_获取缓冲比(元素) {
    如果 (元素 == 0 || 元素.时长 == 0) { 返回 0 }
    定义 可变 总缓冲 = 0
    定义 可变 i = 0
    当 (i < 元素.已缓冲段数) {
        定义 偏移 = i * 16
        定义 起始 = 内存_读64(元素.已缓冲范围 + 偏移)
        定义 结束 = 内存_读64(元素.已缓冲范围 + 偏移 + 8)
        总缓冲 = 总缓冲 + (结束 - 起始)
        i = i + 1
    }
    返回 (总缓冲 * 100) / 元素.时长
}

函数 媒体_合并时间范围(范围, 段数) {
    如果 (段数 <= 1) { 返回 }
    定义 可变 i = 0
    当 (i < 段数 - 1) {
        如果 (范围[i].结束 >= 范围[i + 1].起始) {
            如果 (范围[i + 1].结束 > 范围[i].结束) {
                范围[i].结束 = 范围[i + 1].结束
            }
            列表_移除(范围, i + 1)
            段数 = 段数 - 1
        } 否则 {
            i = i + 1
        }
    }
}

// §7 轨道管理

函数 媒体元素_添加音频轨道(元素, 轨道) {
    如果 (元素 == 0 || 元素.音频轨道数 >= 媒体_最大轨道数) { 返回 }
    内存_写64(元素.音频轨道列表 + 元素.音频轨道数 * 8, 轨道)
    元素.音频轨道数 = 元素.音频轨道数 + 1
}

函数 媒体元素_添加视频轨道(元素, 轨道) {
    如果 (元素 == 0 || 元素.视频轨道数 >= 媒体_最大轨道数) { 返回 }
    内存_写64(元素.视频轨道列表 + 元素.视频轨道数 * 8, 轨道)
    元素.视频轨道数 = 元素.视频轨道数 + 1
}

函数 媒体元素_添加文本轨道(元素, 种类, 标签, 语言) {
    如果 (元素 == 0 || 元素.文本轨道数 >= 媒体_最大轨道数) { 返回 空 }
    定义 轨道 = 堆_分配(文本轨道)
    轨道.ID = 元素.文本轨道数
    轨道.种类 = 种类
    轨道.标签 = 标签
    轨道.语言 = 语言
    轨道.模式 = TEXT_TRACK_DISABLED
    轨道.提示列表 = []
    轨道.提示数 = 0
    内存_写64(元素.文本轨道列表 + 元素.文本轨道数 * 8, 轨道)
    元素.文本轨道数 = 元素.文本轨道数 + 1
    返回 轨道
}

函数 文本轨道_添加提示(轨道, 起始, 结束, 文本) {
    如果 (轨道 == 0) { 返回 }
    定义 提示 = 文本提示 {}
    提示.ID = 轨道.提示数
    提示.起始时间 = 起始
    提示.结束时间 = 结束
    提示.文本 = 文本
    追加(轨道.提示列表, 提示)
    轨道.提示数 = 轨道.提示数 + 1
}

函数 文本轨道_当前提示(轨道, 当前时间) {
    如果 (轨道 == 0 || 轨道.模式 == TEXT_TRACK_DISABLED) { 返回 空 }
    定义 可变 i = 0
    当 (i < 轨道.提示数) {
        定义 提示 = 轨道.提示列表[i]
        如果 (当前时间 >= 提示.起始时间 && 当前时间 < 提示.结束时间) {
            返回 提示
        }
        i = i + 1
    }
    返回 空
}

// §8 格式检测

函数 媒体_检测容器(地址) {
    如果 (地址 == 0) { 返回 0 }
    如果 (字符串_结尾匹配(地址, ".mp4")) { 返回 CONTAINER_MP4 }
    如果 (字符串_结尾匹配(地址, ".webm")) { 返回 CONTAINER_WEBM }
    如果 (字符串_结尾匹配(地址, ".ogg")) { 返回 CONTAINER_OGG }
    如果 (字符串_结尾匹配(地址, ".mp3")) { 返回 CONTAINER_MP3 }
    如果 (字符串_结尾匹配(地址, ".wav")) { 返回 CONTAINER_WAV }
    如果 (字符串_结尾匹配(地址, ".m3u8")) { 返回 CONTAINER_HLS }
    如果 (字符串_结尾匹配(地址, ".mpd")) { 返回 CONTAINER_DASH }
    返回 0
}

函数 媒体_编解码器名称(编解码器) {
    如果 (编解码器 == CODEC_H264) { 返回 "H.264" }
    如果 (编解码器 == CODEC_H265) { 返回 "H.265/HEVC" }
    如果 (编解码器 == CODEC_VP8) { 返回 "VP8" }
    如果 (编解码器 == CODEC_VP9) { 返回 "VP9" }
    如果 (编解码器 == CODEC_AV1) { 返回 "AV1" }
    如果 (编解码器 == CODEC_AAC) { 返回 "AAC" }
    如果 (编解码器 == CODEC_MP3) { 返回 "MP3" }
    如果 (编解码器 == CODEC_OPUS) { 返回 "Opus" }
    如果 (编解码器 == CODEC_VORBIS) { 返回 "Vorbis" }
    如果 (编解码器 == CODEC_FLAC) { 返回 "FLAC" }
    返回 "未知"
}

函数 媒体_容器名称(容器) {
    如果 (容器 == CONTAINER_MP4) { 返回 "MP4" }
    如果 (容器 == CONTAINER_WEBM) { 返回 "WebM" }
    如果 (容器 == CONTAINER_OGG) { 返回 "Ogg" }
    如果 (容器 == CONTAINER_MP3) { 返回 "MP3" }
    如果 (容器 == CONTAINER_WAV) { 返回 "WAV" }
    如果 (容器 == CONTAINER_HLS) { 返回 "HLS" }
    如果 (容器 == CONTAINER_DASH) { 返回 "DASH" }
    返回 "未知"
}

// §9 错误处理

函数 媒体元素_错误(元素, 错误码) {
    媒体统计_初始化()
    如果 (元素 == 0) { 返回 }
    元素.错误码 = 错误码
    元素.播放状态 = PLAY_STATE_ERROR
    全局_媒体统计.错误次数 = 全局_媒体统计.错误次数 + 1
    如果 (元素.错误回调 != 0) { 元素.错误回调(元素) }
}

函数 媒体_错误描述(错误码) {
    如果 (错误码 == MEDIA_ERR_ABORTED) { 返回 "播放被中止" }
    如果 (错误码 == MEDIA_ERR_NETWORK) { 返回 "网络错误" }
    如果 (错误码 == MEDIA_ERR_DECODE) { 返回 "解码错误" }
    如果 (错误码 == MEDIA_ERR_SRC_NOT_SUPPORTED) { 返回 "格式不支持" }
    返回 "未知错误"
}

// §10 事件绑定

函数 媒体元素_绑定事件(元素, 事件名, 回调) {
    如果 (元素 == 0 || 回调 == 0) { 返回 }
    如果 (事件名 == "play") { 元素.播放回调 = 回调 }
    如果 (事件名 == "pause") { 元素.暂停回调 = 回调 }
    如果 (事件名 == "ended") { 元素.结束回调 = 回调 }
    如果 (事件名 == "error") { 元素.错误回调 = 回调 }
    如果 (事件名 == "timeupdate") { 元素.时间更新回调 = 回调 }
    如果 (事件名 == "loadedmetadata") { 元素.加载元数据回调 = 回调 }
    如果 (事件名 == "seeking") { 元素.跳转回调 = 回调 }
    如果 (事件名 == "progress") { 元素.缓冲回调 = 回调 }
}

// §11 统计

函数 媒体_打印统计() {
    媒体统计_初始化()
    打印行("=== 媒体引擎统计 ===")
    打印行("播放次数: " + 整数转字符串(全局_媒体统计.播放次数))
    打印行("暂停次数: " + 整数转字符串(全局_媒体统计.暂停次数))
    打印行("跳转次数: " + 整数转字符串(全局_媒体统计.跳转次数))
    打印行("缓冲次数: " + 整数转字符串(全局_媒体统计.缓冲次数))
    打印行("错误次数: " + 整数转字符串(全局_媒体统计.错误次数))
    打印行("码率切换: " + 整数转字符串(全局_媒体统计.码率切换次数))
}

函数 媒体元素_打印信息(元素) {
    如果 (元素 == 0) { 返回 }
    打印行("=== 媒体元素信息 ===")
    打印行("源: " + 元素.源地址)
    打印行("容器: " + 媒体_容器名称(元素.容器格式))
    打印行("视频: " + 媒体_编解码器名称(元素.视频编解码器))
    打印行("音频: " + 媒体_编解码器名称(元素.音频编解码器))
    打印行("时长: " + 整数转字符串(元素.时长) + "ms")
    打印行("当前: " + 整数转字符串(元素.当前时间) + "ms")
    打印行("音频轨道: " + 整数转字符串(元素.音频轨道数))
    打印行("视频轨道: " + 整数转字符串(元素.视频轨道数))
    打印行("文本轨道: " + 整数转字符串(元素.文本轨道数))
    打印行("缓冲比: " + 整数转字符串(媒体元素_获取缓冲比(元素)) + "%")
}

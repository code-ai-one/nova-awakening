导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/哈希整数.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")

定义 最大指标 = 128
定义 直方图桶数 = 8
定义 类型_计数器 = 0
定义 类型_仪表 = 1
定义 类型_直方图 = 2

结构 指标项 {
    名称哈希,
    类型,
    值,
    最小值,
    最大值,
    样本数,
    桶数据,
}

定义 可变 指标表 = []
定义 可变 指标数 = 0
定义 可变 采集次数 = 0

函数 指标_初始化() {
    指标表 = []
    指标数 = 0
}

函数 指标_注册(名称, 类型) {
    如果 (指标数 >= 最大指标) { 返回 -1 }
    定义 项 = 指标项 {}
    项.名称哈希 = 哈希_字符串(名称)
    项.类型 = 类型
    项.值 = 0
    项.最小值 = 0x7FFFFFFFFFFFFFFF
    项.最大值 = 0
    项.样本数 = 0
    项.桶数据 = 0
    如果 (类型 == 类型_直方图) {
        项.桶数据 = 堆_分配(直方图桶数 * 4)
        定义 可变 序号 = 0
        当 (序号 < 直方图桶数) {
            内存_写32(项.桶数据 + 序号 * 4, 0)
            序号 = 序号 + 1
        }
    }
    追加(指标表, 项)
    定义 索引 = 指标数
    指标数 = 指标数 + 1
    返回 索引
}

函数 指标_查找(名称哈希) {
    定义 可变 序号 = 0
    当 (序号 < 指标数) {
        如果 (指标表[序号].名称哈希 == 名称哈希) { 返回 序号 }
        序号 = 序号 + 1
    }
    返回 -1
}

函数 指标_递增(名称) {
    采集次数 = 采集次数 + 1
    定义 索引 = 指标_查找(哈希_字符串(名称))
    如果 (索引 < 0) { 索引 = 指标_注册(名称, 类型_计数器) }
    如果 (索引 >= 0) { 指标表[索引].值 = 指标表[索引].值 + 1 }
}

函数 指标_递增量(名称, 增量) {
    采集次数 = 采集次数 + 1
    定义 索引 = 指标_查找(哈希_字符串(名称))
    如果 (索引 < 0) { 索引 = 指标_注册(名称, 类型_计数器) }
    如果 (索引 >= 0) { 指标表[索引].值 = 指标表[索引].值 + 增量 }
}

函数 指标_设仪表(名称, 值) {
    采集次数 = 采集次数 + 1
    定义 索引 = 指标_查找(哈希_字符串(名称))
    如果 (索引 < 0) { 索引 = 指标_注册(名称, 类型_仪表) }
    如果 (索引 >= 0) { 指标表[索引].值 = 值 }
}

函数 指标_记录直方图(名称, 值) {
    采集次数 = 采集次数 + 1
    定义 索引 = 指标_查找(哈希_字符串(名称))
    如果 (索引 < 0) { 索引 = 指标_注册(名称, 类型_直方图) }
    如果 (索引 < 0) { 返回 }
    定义 项 = 指标表[索引]
    项.样本数 = 项.样本数 + 1
    项.值 = 项.值 + 值
    如果 (值 < 项.最小值) { 项.最小值 = 值 }
    如果 (值 > 项.最大值) { 项.最大值 = 值 }
    如果 (项.桶数据 != 0) {
        定义 可变 桶号 = 0
        如果 (值 < 1000) { 桶号 = 0 }
        否则 如果 (值 < 5000) { 桶号 = 1 }
        否则 如果 (值 < 10000) { 桶号 = 2 }
        否则 如果 (值 < 50000) { 桶号 = 3 }
        否则 如果 (值 < 100000) { 桶号 = 4 }
        否则 如果 (值 < 500000) { 桶号 = 5 }
        否则 如果 (值 < 1000000) { 桶号 = 6 }
        否则 { 桶号 = 7 }
        内存_写32(项.桶数据 + 桶号 * 4, 内存_读32(项.桶数据 + 桶号 * 4) + 1)
    }
}

函数 指标_获取值(名称) {
    定义 索引 = 指标_查找(哈希_字符串(名称))
    如果 (索引 < 0) { 返回 0 }
    返回 指标表[索引].值
}

函数 指标_获取平均(名称) {
    定义 索引 = 指标_查找(哈希_字符串(名称))
    如果 (索引 < 0 || 指标表[索引].样本数 == 0) { 返回 0 }
    返回 指标表[索引].值 / 指标表[索引].样本数
}

函数 指标_获取最大(名称) {
    定义 索引 = 指标_查找(哈希_字符串(名称))
    如果 (索引 < 0) { 返回 0 }
    返回 指标表[索引].最大值
}

函数 指标_获取最小(名称) {
    定义 索引 = 指标_查找(哈希_字符串(名称))
    如果 (索引 < 0) { 返回 0 }
    返回 指标表[索引].最小值
}

函数 指标_重置(名称) {
    定义 索引 = 指标_查找(哈希_字符串(名称))
    如果 (索引 < 0) { 返回 }
    指标表[索引].值 = 0
    指标表[索引].样本数 = 0
    指标表[索引].最小值 = 0x7FFFFFFFFFFFFFFF
    指标表[索引].最大值 = 0
}

函数 指标_完整统计() {
    返回 [指标数, 采集次数]
}

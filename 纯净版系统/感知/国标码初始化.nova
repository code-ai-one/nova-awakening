    GBK_写映射(0x81, 0x49, 0x4E21)    // 両
}

// §3 Unicode→GBK反向映射 (NGBK-REV)

函数 NGBK_初始化反向表() {
    // 构建Unicode→GBK反向哈希表
    // 每个桶: [unicode:u16, gbk_byte1:u8, gbk_byte2:u8] = 4字节
    如果 (NGBK_反向表 != 0) { 返回 }
    NGBK_反向表 = 堆_分配(NGBK_反向哈希桶数 * 4)
    内存_清零(NGBK_反向表, NGBK_反向哈希桶数 * 4)

    // 遍历正向映射表构建反向索引
    定义 可变 b1 = 0x81
    当 (b1 <= 0xFE) {
        定义 可变 b2 = 0x40
        当 (b2 <= 0xFE) {
            如果 (b2 != 0x7F) {  // 0x7F不是GBK合法第二字节
                定义 unicode = GBK_到Unicode(b1, b2)
                如果 (unicode != 0xFFFD && unicode != 0) {
                    NGBK_反向写入(unicode, b1, b2)
                }
            }
            b2 = b2 + 1
        }
        b1 = b1 + 1
    }
}

函数 NGBK_反向写入(unicode, byte1, byte2) {
    // 哈希插入: hash = unicode % BUCKET_SIZE
    定义 可变 hash = unicode % NGBK_反向哈希桶数
    // 线性探测解冲突
    定义 可变 尝试 = 0
    当 (尝试 < NGBK_反向哈希桶数) {
        定义 已有 = 内存_读16(NGBK_反向表 + hash * 4)
        如果 (已有 == 0) {
            // 空桶，写入
            内存_写16(NGBK_反向表 + hash * 4, unicode)
            内存_写8(NGBK_反向表 + hash * 4 + 2, byte1)
            内存_写8(NGBK_反向表 + hash * 4 + 3, byte2)
            返回
        }
        hash = (hash + 1) % NGBK_反向哈希桶数
        尝试 = 尝试 + 1
    }
}

函数 GBK_从Unicode(unicode) {
    // NGBK-REV: Unicode→GBK反向查找
    NGBK_反向查表次数 = NGBK_反向查表次数 + 1
    如果 (NGBK_反向表 == 0) { NGBK_初始化反向表() }
    // ASCII直返
    如果 (unicode < 0x80) { 返回 unicode }
    定义 可变 hash = unicode % NGBK_反向哈希桶数
    定义 可变 尝试 = 0
    当 (尝试 < NGBK_反向哈希桶数) {
        定义 存储码 = 内存_读16(NGBK_反向表 + hash * 4)
        如果 (存储码 == 0) { 返回 0 }  // 未找到
        如果 (存储码 == unicode) {
            定义 b1 = 内存_读8(NGBK_反向表 + hash * 4 + 2)
            定义 b2 = 内存_读8(NGBK_反向表 + hash * 4 + 3)
            返回 (b1 * 256) + b2  // 返回GBK双字节
        }
        hash = (hash + 1) % NGBK_反向哈希桶数
        尝试 = 尝试 + 1
    }
    返回 0
}

// §4 编码自动检测 (NGBK-DET)

函数 NGBK_检测GBK编码(数据, 长度) {
    // NGBK-DET: 统计字节流中合法GBK序列的占比
    NGBK_编码检测次数 = NGBK_编码检测次数 + 1
    如果 (长度 == 0) { 返回 0.0 }
    定义 可变 合法字节数 = 0
    定义 可变 总字节 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 b = 内存_读8(数据 + i)
        如果 (b < 0x80) {
            // ASCII字节
            合法字节数 = 合法字节数 + 1
            总字节 = 总字节 + 1
            i = i + 1
        } 否则 如果 (b >= 0x81 && b <= 0xFE && i + 1 < 长度) {
            定义 b2 = 内存_读8(数据 + i + 1)
            如果 ((b2 >= 0x40 && b2 <= 0x7E) || (b2 >= 0x80 && b2 <= 0xFE)) {
                // 合法GBK双字节
                合法字节数 = 合法字节数 + 2
                总字节 = 总字节 + 2
                i = i + 2
            } 否则 {
                总字节 = 总字节 + 1
                i = i + 1
            }
        } 否则 {
            总字节 = 总字节 + 1
            i = i + 1
        }
    }
    如果 (总字节 == 0) { 返回 0.0 }
    返回 合法字节数 / 总字节
}

函数 NGBK_是GBK编码(数据, 长度) {
    // 判断字节流是否为GBK编码
    定义 分数 = NGBK_检测GBK编码(数据, 长度)
    返回 分数 >= NGBK_编码检测阈值
}

// §5 GB18030四字节扩展 (NGBK-GB18030)

函数 NGBK_GB18030_到Unicode(b1, b2, b3, b4) {
    // GB18030四字节编码转Unicode
    // 格式: byte1(0x81-0xFE) byte2(0x30-0x39) byte3(0x81-0xFE) byte4(0x30-0x39)
    NGBK_GB18030查表次数 = NGBK_GB18030查表次数 + 1
    如果 (b1 < 0x81 || b1 > 0xFE) { 返回 0xFFFD }
    如果 (b2 < 0x30 || b2 > 0x39) { 返回 0xFFFD }
    如果 (b3 < 0x81 || b3 > 0xFE) { 返回 0xFFFD }
    如果 (b4 < 0x30 || b4 > 0x39) { 返回 0xFFFD }
    // 线性计算: offset = ((b1-0x81)*10 + (b2-0x30))*126*10 + (b3-0x81)*10 + (b4-0x30)
    定义 offset = ((b1 - 0x81) * 10 + (b2 - 0x30)) * 126 * 10 + (b3 - 0x81) * 10 + (b4 - 0x30)
    // 简化映射: BMP以外的字符直接计算
    如果 (offset < 0x10000) { 返回 offset }
    返回 0xFFFD
}

函数 NGBK_是GB18030四字节(b1, b2) {
    // 检查是否为GB18030四字节序列的开始
    如果 (b1 >= 0x81 && b1 <= 0xFE && b2 >= 0x30 && b2 <= 0x39) {
        返回 真
    }
    返回 假
}

// §6 GBK字节流解码器

函数 NGBK_解码字节流(数据, 长度) {
    // 将GBK字节流解码为Unicode码点数组
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 长度) {
        定义 b1 = 内存_读8(数据 + i)
        如果 (b1 < 0x80) {
            // ASCII
            追加(结果, b1)
            i = i + 1
        } 否则 如果 (b1 >= 0x81 && b1 <= 0xFE && i + 1 < 长度) {
            定义 b2 = 内存_读8(数据 + i + 1)
            // 检查是否GB18030四字节
            如果 (NGBK_是GB18030四字节(b1, b2) && i + 3 < 长度) {
                定义 b3 = 内存_读8(数据 + i + 2)
                定义 b4 = 内存_读8(数据 + i + 3)
                定义 cp = NGBK_GB18030_到Unicode(b1, b2, b3, b4)
                追加(结果, cp)
                i = i + 4
            } 否则 {
                // 普通GBK双字节
                定义 cp = GBK_到Unicode(b1, b2)
                追加(结果, cp)
                i = i + 2
            }
        } 否则 {
            // 无效字节
            追加(结果, 0xFFFD)
            i = i + 1
        }
    }
    返回 结果
}

// §7 AI编码推理与异常检测 (NGBK-AI)

函数 NGBK_AI编码检测(数据, 长度) {
    // AI辅助编码检测: 综合分析GBK/UTF-8/Big5可能性
    NGBK_AI推理次数 = NGBK_AI推理次数 + 1
    定义 gbk分 = NGBK_检测GBK编码(数据, 长度)
    定义 tensor = Tensor_创建(6)
    Tensor_写(tensor, 0, gbk分)
    Tensor_写(tensor, 1, 长度)
    Tensor_写(tensor, 2, NGBK_正向查表次数)
    Tensor_写(tensor, 3, NGBK_异常字节次数)
    Tensor_写(tensor, 4, NGBK_编码检测次数)
    Tensor_写(tensor, 5, 0.0)
    定义 推理 = AI总线_推理(全局AI总线, "ngbk_detect", tensor)
    定义 编码类型 = Tensor_读(推理, 0)  // 0=GBK, 1=UTF-8, 2=Big5
    Tensor_释放(tensor)
    Tensor_释放(推理)
    返回 编码类型
}

// §8 初始化与诊断

函数 NGBK_全量初始化() {
    NGBK_正向查表次数 = 0
    NGBK_反向查表次数 = 0
    NGBK_编码检测次数 = 0
    NGBK_GB18030查表次数 = 0
    NGBK_AI推理次数 = 0
    NGBK_异常字节次数 = 0
    GBK_初始化()
    NGBK_初始化反向表()
    打印("[NGBK] GBK编码引擎 v" + NGBK_版本 + " 已初始化")
}

函数 NGBK_诊断报告() {
    打印("[NGBK] === GBK编码诊断 ===")
    打印("  正向查表=" + 整数转字符串(NGBK_正向查表次数) + " 反向查表=" + 整数转字符串(NGBK_反向查表次数))
    打印("  编码检测=" + 整数转字符串(NGBK_编码检测次数) + " GB18030=" + 整数转字符串(NGBK_GB18030查表次数))
    打印("  AI推理=" + 整数转字符串(NGBK_AI推理次数) + " 异常字节=" + 整数转字符串(NGBK_异常字节次数))
}

函数 NGBK_释放() {
    如果 (GBK_映射表 != 0) {
        堆_释放(GBK_映射表)
        GBK_映射表 = 0
    }
    如果 (NGBK_反向表 != 0) {
        堆_释放(NGBK_反向表)
        NGBK_反向表 = 0
    }
}

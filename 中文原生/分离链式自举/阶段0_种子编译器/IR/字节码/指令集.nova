导入("../../标准库/基础.nova")

// Nova · IR层 · Nova-Bytecode 指令集定义
// 自研轻量字节码 — 跨平台/易解释/易编译/带元信息
// 5类核心指令: 运算/内存/分支/调用/动态类型

// 指令操作码定义 (共86条)

// 第1类: 基础运算 (20条)
定义 指令_空操作 = 0x00 // 空操作
定义 指令_压入整数 = 0x01 // 推64位整数常量
定义 指令_压入浮点 = 0x02 // 推64位浮点常量
定义 指令_压入字串 = 0x03 // 推字符串常量(索引)
定义 指令_压入空 = 0x04 // 推空值
定义 指令_压入真 = 0x05 // 推真
定义 指令_压入假 = 0x06 // 推假
定义 指令_弹出 = 0x07 // 弹出栈顶
定义 指令_复制 = 0x08 // 复制栈顶
定义 指令_交换 = 0x09 // 交换栈顶两元素
定义 指令_加 = 0x10 // 加法 (整数/浮点/字符串拼接自动分派)
定义 指令_减 = 0x11 // 减法
定义 指令_乘 = 0x12 // 乘法
定义 指令_除 = 0x13 // 除法 (带除零保护)
定义 指令_余 = 0x14 // 取模
定义 指令_取负 = 0x15 // 取负
定义 指令_非 = 0x16 // 逻辑非
定义 指令_位非 = 0x17 // 位非
定义 指令_位与 = 0x18 // 位与
定义 指令_位或 = 0x19 // 位或
定义 指令_位异或 = 0x1A // 位异或
定义 指令_左移 = 0x1B // 左移
定义 指令_右移 = 0x1C // 右移

// 第2类: 内存操作 (15条)
定义 指令_载局部 = 0x20 // 加载局部变量 (索引)
定义 指令_存局部 = 0x21 // 存储局部变量 (索引)
定义 指令_载全局 = 0x22 // 加载全局变量 (名称索引)
定义 指令_存全局 = 0x23 // 存储全局变量
定义 指令_载闭包 = 0x24 // 加载闭包变量
定义 指令_存闭包 = 0x25 // 存储闭包变量
定义 指令_建列表 = 0x26 // 创建列表 (元素数)
定义 指令_建字典 = 0x27 // 创建字典
定义 指令_建结构 = 0x28 // 创建结构体实例
定义 指令_取索引 = 0x29 // 索引读取 obj[i]
定义 指令_设索引 = 0x2A // 索引写入 obj[i]=v
定义 指令_取字段 = 0x2B // 字段读取 obj.field
定义 指令_设字段 = 0x2C // 字段写入 obj.field=v
定义 指令_取字典 = 0x2D // 字典读取 dict[key]
定义 指令_设字典 = 0x2E // 字典写入 dict[key]=v

// 第3类: 分支控制 (10条)
定义 指令_跳转 = 0x30 // 无条件跳转 (偏移)
定义 指令_真跳 = 0x31 // 条件为真跳转
定义 指令_假跳 = 0x32 // 条件为假跳转
定义 指令_循环 = 0x33 // 循环跳转 (回跳, 含热点计数)
定义 指令_比等 = 0x34 // 比较: 等于
定义 指令_比不等 = 0x35 // 比较: 不等
定义 指令_比小 = 0x36 // 比较: 小于
定义 指令_比小等 = 0x37 // 比较: 小等
定义 指令_比大 = 0x38 // 比较: 大于
定义 指令_比大等 = 0x39 // 比较: 大等

// 第4类: 函数调用 (10条)
定义 指令_调用 = 0x40 // 调用函数 (函数索引, 参数数)
定义 指令_间接调用 = 0x41 // 间接调用 (栈顶为函数)
定义 指令_原生调用 = 0x42 // 调用原生函数 (内建索引)
定义 指令_外部调用 = 0x43 // 调用外部C函数 (FFI)
定义 指令_返回 = 0x44 // 函数返回
定义 指令_返回空 = 0x45 // 返回空值
定义 指令_闭包 = 0x46 // 创建闭包
定义 指令_尾调用 = 0x47 // 尾调用 (TCO优化后)
定义 指令_让出 = 0x48 // 协程让出
定义 指令_恢复 = 0x49 // 协程恢复

// 第5类: 动态类型操作 (15条)
定义 指令_类型检查 = 0x50 // 类型检查 (类型ID)
定义 指令_类型转换 = 0x51 // 类型转换
定义 指令_是整数 = 0x52 // 是否整数
定义 指令_是浮点 = 0x53 // 是否浮点
定义 指令_是字串 = 0x54 // 是否字符串
定义 指令_是列表 = 0x55 // 是否列表
定义 指令_是字典 = 0x56 // 是否字典
定义 指令_是空 = 0x57 // 是否空
定义 指令_是函数 = 0x58 // 是否函数
定义 指令_转整数 = 0x59 // 转整数
定义 指令_转浮点 = 0x5A // 转浮点
定义 指令_转字串 = 0x5B // 转字符串
定义 指令_打印 = 0x5C // 打印 (智能分派)
定义 指令_长度 = 0x5D // 长度/计数
定义 指令_断言 = 0x5E // 断言

// 特殊指令 (15条)
定义 指令_尝试 = 0x60 // 异常保护开始
定义 指令_捕获 = 0x61 // 异常捕获
定义 指令_抛出 = 0x62 // 抛出异常
定义 指令_导入 = 0x63 // 导入模块
定义 指令_断点 = 0x64 // 调试断点
定义 指令_行号 = 0x65 // 行号标记 (调试元信息)
定义 指令_热点计 = 0x66 // 热点计数器递增
定义 指令_即时编译入 = 0x67 // 进入JIT编译区域
定义 指令_即时编译出 = 0x68 // 退出JIT编译区域
定义 指令_匹配 = 0x69 // 模式匹配
定义 指令_遍历 = 0x6A // 迭代器循环
定义 指令_展开 = 0x6B // 展开操作
定义 指令_停机 = 0xFF // 停机

// 指令元数据

// 操作码→操作数字节数映射
函数 Nova指令_操作数大小(操作码) {
 // 8字节立即数
 如果 (操作码 == 0x01) { 返回 8 }  // PUSH_I64
 如果 (操作码 == 0x02) { 返回 8 }  // PUSH_F64
 // 2字节索引
 如果 (操作码 == 0x03) { 返回 2 }  // PUSH_STR (常量池索引)
 如果 (操作码 == 0x20) { 返回 2 }  // LOAD_LOCAL
 如果 (操作码 == 0x21) { 返回 2 }  // STORE_LOCAL
 如果 (操作码 == 0x22) { 返回 2 }  // LOAD_GLOBAL
 如果 (操作码 == 0x23) { 返回 2 }  // STORE_GLOBAL
 如果 (操作码 == 0x24) { 返回 2 }  // LOAD_UPVAL
 如果 (操作码 == 0x25) { 返回 2 }  // STORE_UPVAL
 如果 (操作码 == 0x26) { 返回 2 }  // NEW_LIST (元素数)
 如果 (操作码 == 0x27) { 返回 2 }  // NEW_DICT
 如果 (操作码 == 0x28) { 返回 2 }  // NEW_STRUCT
 如果 (操作码 == 0x2B) { 返回 2 }  // GET_FIELD
 如果 (操作码 == 0x2C) { 返回 2 }  // SET_FIELD
 // 2字节跳转目标
 如果 (操作码 == 0x30) { 返回 2 }  // JMP
 如果 (操作码 == 0x31) { 返回 2 }  // JMP_IF
 如果 (操作码 == 0x32) { 返回 2 }  // JMP_IFNOT
 如果 (操作码 == 0x33) { 返回 2 }  // LOOP
 // 函数调用: 2字节函数索引 + 1字节参数数
 如果 (操作码 == 0x40) { 返回 3 }  // CALL
 如果 (操作码 == 0x41) { 返回 1 }  // CALL_IND (参数数)
 如果 (操作码 == 0x42) { 返回 3 }  // CALL_NATIVE
 如果 (操作码 == 0x43) { 返回 3 }  // CALL_FFI
 如果 (操作码 == 0x46) { 返回 2 }  // CLOSURE (函数索引)
 如果 (操作码 == 0x47) { 返回 3 }  // TAIL_CALL
 // 类型操作
 如果 (操作码 == 0x50) { 返回 1 }  // TYPE_CHECK
 如果 (操作码 == 0x51) { 返回 1 }  // TYPE_CAST
 // 特殊指令
 如果 (操作码 == 0x60) { 返回 2 }  // TRY (catch跳转目标)
 如果 (操作码 == 0x63) { 返回 2 }  // 导入 (模块索引)
 如果 (操作码 == 0x65) { 返回 2 }  // LINE (行号)
 如果 (操作码 == 0x69) { 返回 2 }  // MATCH
 如果 (操作码 == 0x6A) { 返回 2 }  // FOREACH
 // 其余操作码无操作数
 返回 0
}

// 操作码→助记符
函数 Nova指令_名称(操作码) { 返回 转字符串(操作码) }

// 字节码块结构
// [magic:4][version:2][flags:2][const_count:4][code_size:4][line_count:4]
// [constants...][bytecode...][line_table...]

定义 Nova_魔数 = 0x4E4F4243 // "NOBC" (Nova-ByteCode)
定义 Nova_版本 = 0x0100 // v1.0

// 标志位
定义 Nova_标志_调试 = 1 // 包含调试信息
定义 Nova_标志_优化 = 2 // 已优化
定义 Nova_标志_即时编译就绪 = 4 // JIT就绪标记

函数 Nova字节码_创建块() {
 // [magic, version, flags, 常量池, 指令缓冲, 行号表, 函数表]
 返回 [Nova_魔数, Nova_版本, Nova_标志_调试, [], [], [], 字典()]
}

函数 Nova字节码_发射(块, 操作码) {
 追加(块[4], 操作码)
}

函数 Nova字节码_发射8(块, 操作码, 操作数) {
 追加(块[4], 操作码)
 追加(块[4], 操作数 & 0xFF)
}

函数 Nova字节码_发射16(块, 操作码, 操作数) {
 追加(块[4], 操作码)
 追加(块[4], 操作数 & 0xFF)
 追加(块[4], (操作数 >> 8) & 0xFF)
}

函数 Nova字节码_发射64(块, 操作码, 值) {
 追加(块[4], 操作码)
 定义 可变 i = 0
 当 (i < 8) {
 追加(块[4], (值 >> (i * 8)) & 0xFF)
 i = i + 1
 }
}

函数 Nova字节码_发射行号(块, 行号) {
 追加(块[5], 行号)
}

函数 Nova字节码_添加常量(块, 值) { 定义 索引 = 计数(块[3])
 追加(块[3], 值)
 返回 索引
}

函数 Nova字节码_注册函数(块, 名称, 偏移, 参数数) {
 字典设置(块[6], 名称, [偏移, 参数数])
}

函数 Nova字节码_代码大小(块) { 返回 计数(块[4]) }
函数 Nova字节码_常量数(块) { 返回 计数(块[3]) }

// 反汇编器 (调试用)
// 该模块在自举链中只需要保证核心字节码表和发射接口稳定。
// 反汇编仅用于 verbose 调试输出, 这里保留入口但不展开重逻辑, 避免影响自举稳定性。
函数 Nova字节码_反汇编(块) {
 返回 0
}

// 实验反哺 — HCI汉字专用指令族 (hanzi_instruction_research.rs)
// 反哺日期: 2026-03-31
// 反哺依据: Rust底层实验证明汉字专用指令可将处理代价降低6.2×平均
// 替代方案: 过时的逐字节UTF-8解码 + 范围比较链（8-15条x86指令）
// 新方案:   HCI虚拟指令 → 预计算查表+SIMD，4-6条x86指令

// HCI汉字计算指令族 (8条)
// 实验依据: HCI平均加速6.2×，最大加速10×(HSTROKE)
定义 Nova_汉字分类   = 0x70  // 汉字码点分类 → [0=非汉字,4=形声字,6=扩展]
                            // 替代: 5次范围比较(15条x86指令)→1次查表(4条)，加速5×
定义 Nova_汉字笔画  = 0x71  // O(1)笔画数查询 → [0-40笔]
                            // 替代: 朴素逐规则匹配(20条)→预计算64KB表(3条)，加速10×
定义 Nova_汉字部首 = 0x72  // 部首码点提取 → 部首Unicode
                            // 替代: 二分查找214部首(28条)→分层索引表(5条)，加速5.8×
定义 Nova_汉字声调    = 0x73  // 声调识别(0-4) → 整数
                            // 替代: 35字符逐一比较(35条)→SSE4.2 PCMPESTRI(4条)，加速9×
定义 Nova_汉字拼音  = 0x74  // 拼音声母/韵母哈希 → 声母<<8|韵母
定义 Nova_汉字比较     = 0x75  // 汉字语义距离比较(笔画×0.4+部首×0.4+声调×0.2)
                            // 替代: 分步计算(30条)→SSE4.1 DPPS加权点积(8条)，加速4.4×
定义 Nova_汉字向量8    = 0x76  // 批量处理8个汉字笔画特征(模拟AVX2 YMM寄存器)
                            // 替代: 8×HSTROKE串行(24条)→AVX2 VPGATHERDD(6条)，加速4×
定义 Nova_汉字N元   = 0x77  // n-gram笔画序列哈希(CRC32C硬件指令链)
                            // 替代: 逐字哈希循环(30条)→CRC32C滚动哈希(7条)，加速5×

// 形意类型系统指令 (4条)
// 实验依据: Nova类型理论研究 (nova_type_theory_verifier.rs)
// 替代: ASCII类型标签(4字节)→16位汉字类型元数据，类型信息内嵌于汉字结构
定义 Nova_类型元编码 = 0x78  // 编码汉字16位类型元数据(部首族+笔画等级+声调)
定义 Nova_类型元解码 = 0x79  // 解码汉字16位类型元数据
定义 Nova_词法比较       = 0x7A  // 形意类型相容性检查(部首族继承关系)
定义 Nova_声调分发   = 0x7B  // 声调多态分发(同拼音不同声调→不同函数)

定义 可变 _指令集_注册数 = 0
定义 可变 _指令集_使用数 = 0

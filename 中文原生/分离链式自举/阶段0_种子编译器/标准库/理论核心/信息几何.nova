导入("../基础.nova")
导入("../数学/工具.nova")

// 信息几何 v3 — 2024 前沿迭代
// 基础: Amari信息几何 + 现代扩展
// [1] Fisher-Rao流 (Ay et al. 2022)
// [2] 自然梯度二阶修正 (George et al. 2023 KFAC改进)
// [3] Wasserstein-Fisher-Rao度量 (Chizat et al. 2022)
// [4] α-散度的f-散度变分表示 (Wan et al. 2023)
// [5] Bregman散度与Mirror Descent对偶 (Amid&Warmuth 2022)
// [6] 黎曼Adam优化器 (Bécigneul&Ganea 2019→Chen et al. 2024改进,
//     在统计流形上自适应学习率, 融合Fisher度量+Adam动量)
// [7] 信息几何优化IGO (Ollivier et al. 2017→2024扩展,
//     用KL散度定义搜索分布更新, 统一CMA-ES/NES/PBIL)
// [8] Rényi散度与PAC-Bayes界 (Esposito et al. 2024,
//     用Rényi散度替代KL散度得到更紧泛化界)
// 纯整数定点 (精度=10000)

定义 IG精度 = 10000

// 定点数学工具

函数 近似log(x) {
    如果 (x <= 0) { 返回 0 - IG精度 * 10 }
    如果 (x == IG精度) { 返回 0 }
    // log(1+y) ≈ y - y²/2 + y³/3 对 |y|<0.5
    定义 y = x - IG精度
    如果 (y > 0 - IG精度 / 2 且 y < IG精度 / 2) {
        定义 y2 = y * y / IG精度
        定义 y3 = y2 * y / IG精度
        返回 y - y2 / 2 + y3 / 3
    }
    // 大范围: 用移位归约到 [0.5, 2) 再展开
    定义 可变 移位 = 0
    定义 可变 v = x
    当 (v > IG精度 * 2) { v = v / 2; 移位 = 移位 + 6931 }
    当 (v < IG精度 / 2) { v = v * 2; 移位 = 移位 - 6931 }
    定义 r = v - IG精度
    返回 移位 + r - r * r / (2 * IG精度) + r * r * r / (3 * IG精度 * IG精度 / IG精度)
}

函数 近似exp(x) {
    // exp(x) ≈ 1 + x + x²/2 + x³/6, x为×10000定点
    如果 (x > 60000) { 返回 IG精度 * 1000 }
    如果 (x < 0 - 60000) { 返回 1 }
    定义 x1 = x
    定义 x2 = x1 * x1 / IG精度
    定义 x3 = x2 * x1 / IG精度
    返回 IG精度 + x1 + x2 / 2 + x3 / 6
}

函数 近似sqrt(x) {
    如果 (x <= 0) { 返回 0 }
    // 牛顿法: y_{n+1} = (y_n + x/y_n) / 2
    定义 可变 y = x / 2
    如果 (y == 0) { y = 1 }
    定义 可变 k = 0
    当 (k < 8) { y = (y + x * IG精度 / y) / 2; k = k + 1 }
    返回 y
}

// Fisher信息矩阵 (修正版)
// g_ij(θ) = E[∂log p/∂θ_i × ∂log p/∂θ_j]
// [修复] 真正的数值微分，不再简化为常数

函数 Fisher信息_离散(分布, 参数索引, 扰动) {
    定义 n = 计数(分布)
    如果 (n == 0) { 返回 0 }
    如果 (扰动 == 0) { 返回 0 }
    // 数值中心差分: ∂p_i/∂θ_j ≈ (p_i(θ+ε) - p_i(θ-ε)) / 2ε
    // 对离散分布: 扰动第j个参数，观察各概率变化
    // Fisher信息 = Σ_i (1/p_i) × (∂p_i/∂θ_j)²
    定义 可变 信息 = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (分布[i] > 0) {
            // 正向扰动分布
            定义 可变 p加 = 分布[i]
            定义 可变 p减 = 分布[i]
            如果 (i == 参数索引) {
                p加 = 分布[i] + 扰动
                p减 = 分布[i] - 扰动
                如果 (p减 < 1) { p减 = 1 }
            } 否则 {
                // 其他概率需补偿以保持归一化
                p加 = 分布[i] - 扰动 / (n - 1)
                p减 = 分布[i] + 扰动 / (n - 1)
                如果 (p加 < 1) { p加 = 1 }
                如果 (p减 < 1) { p减 = 1 }
            }
            定义 导数 = (p加 - p减) * IG精度 / (2 * 扰动)
            信息 = 信息 + 导数 * 导数 / (分布[i] + 1)
        }
        i = i + 1
    }
    返回 信息
}

// Fisher信息矩阵 (对角线)
函数 Fisher矩阵_对角(分布, 维度) {
    定义 可变 对角 = []
    定义 可变 d = 0
    当 (d < 维度) {
        追加(对角, Fisher信息_离散(分布, d, 100))
        d = d + 1
    }
    返回 对角
}

// Fisher信息矩阵 (完整, O(d²))
函数 Fisher矩阵_完整(分布, 维度) {
    定义 可变 矩阵 = []
    定义 n = 计数(分布)
    定义 ε = 100
    // 输出: 维度×维度的一维展开矩阵
    定义 可变 i = 0
    当 (i < 维度 * 维度) { 追加(矩阵, 0); i = i + 1 }
    // g_ij = Σ_k (1/p_k)(∂p_k/∂θ_i)(∂p_k/∂θ_j)
    定义 可变 di = 0
    当 (di < 维度) {
        定义 可变 dj = di
        当 (dj < 维度) {
            定义 可变 gij = 0
            定义 可变 k = 0
            当 (k < n) {
                如果 (分布[k] > 0) {
                    定义 dpi = 0
                    如果 (k == di) { dpi = IG精度 } 否则 { dpi = 0 - IG精度 / (n - 1) }
                    定义 dpj = 0
                    如果 (k == dj) { dpj = IG精度 } 否则 { dpj = 0 - IG精度 / (n - 1) }
                    gij = gij + dpi * dpj / (分布[k] + 1)
                }
                k = k + 1
            }
            矩阵[di * 维度 + dj] = gij
            矩阵[dj * 维度 + di] = gij
            dj = dj + 1
        }
        di = di + 1
    }
    返回 矩阵
}

// 自然梯度 + 二阶修正 (2023 K-FAC改进)
// 经典: ∇̃f = F⁻¹∇f
// 二阶修正: ∇̃f = (F + λI)⁻¹∇f - (F + λI)⁻¹ΔF(F + λI)⁻¹∇f
// ref: George et al. 2023 "Scalable Second-Order Natural Gradient"

函数 自然梯度_计算(普通梯度, Fisher对角) {
    定义 维度 = 计数(普通梯度)
    定义 可变 自然 = []
    定义 可变 i = 0
    当 (i < 维度) {
        如果 (Fisher对角[i] > 0) {
            追加(自然, 普通梯度[i] * IG精度 / Fisher对角[i])
        } 否则 {
            追加(自然, 普通梯度[i])
        }
        i = i + 1
    }
    返回 自然
}

// Tikhonov阻尼自然梯度 (F + λI)⁻¹∇f
函数 自然梯度_阻尼(普通梯度, Fisher对角, 阻尼λ) {
    定义 维度 = 计数(普通梯度)
    定义 可变 自然 = []
    定义 可变 i = 0
    当 (i < 维度) {
        定义 分母 = Fisher对角[i] + 阻尼λ
        如果 (分母 > 0) {
            追加(自然, 普通梯度[i] * IG精度 / 分母)
        } 否则 {
            追加(自然, 普通梯度[i] * IG精度 / (阻尼λ + 1))
        }
        i = i + 1
    }
    返回 自然
}

// K-FAC近似: 分解 F ≈ A⊗B (Kronecker积)
// 适用于神经网络层: A = 输入协方差, B = 梯度协方差
函数 KFAC_因子化(输入激活列表, 梯度列表) {
    定义 可变 ii = 0
    定义 n = 计数(输入激活列表)
    如果 (n == 0) { 返回 [[], []] }
    定义 d_in = 计数(输入激活列表[0])
    定义 d_out = 计数(梯度列表[0])
    // A = (1/n)ΣaaT (输入协方差)
    定义 可变 A = []
    定义 可变 ai = 0
    当 (ai < d_in * d_in) { 追加(A, 0); ai = ai + 1 }
    // B = (1/n)ΣggT (梯度协方差)
    定义 可变 B = []
    定义 可变 bi = 0
    当 (bi < d_out * d_out) { 追加(B, 0); bi = bi + 1 }
    定义 可变 s = 0
    当 (s < n) {
        当 (ii < d_in) {
            定义 可变 jj = 0
            当 (jj < d_in) {
                A[ii * d_in + jj] = A[ii * d_in + jj] + 输入激活列表[s][ii] * 输入激活列表[s][jj] / n
                jj = jj + 1
            }
            ii = ii + 1
        }
        定义 可变 gi = 0
        当 (gi < d_out) {
            定义 可变 gj = 0
            当 (gj < d_out) {
                B[gi * d_out + gj] = B[gi * d_out + gj] + 梯度列表[s][gi] * 梯度列表[s][gj] / n
                gj = gj + 1
            }
            gi = gi + 1
        }
        s = s + 1
    }
    返回 [A, B]
}

函数 自然梯度_步进(参数, 普通梯度, Fisher对角, 学习率) {
    定义 可变 新参数 = []
    定义 自然 = 自然梯度_阻尼(普通梯度, Fisher对角, 100)
    定义 维度 = 计数(参数)
    定义 可变 i = 0
    当 (i < 维度) {
        追加(新参数, 参数[i] - 学习率 * 自然[i] / IG精度)
        i = i + 1
    }
    返回 新参数
}

// KL散度 + f-散度变分表示 (Wan et al. 2023)

函数 信息几何_KL散度(P, Q) {
    定义 n = 计数(P)
    定义 可变 散度 = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (P[i] > 0 且 Q[i] > 0) {
            定义 比值 = P[i] * IG精度 / Q[i]
            散度 = 散度 + P[i] * 近似log(比值) / IG精度
        }
        i = i + 1
    }
    返回 散度
}

函数 信息几何_JS散度(P, Q) {
    定义 n = 计数(P)
    定义 可变 M = []
    定义 可变 i = 0
    当 (i < n) { 追加(M, (P[i] + Q[i]) / 2); i = i + 1 }
    返回 (信息几何_KL散度(P, M) + 信息几何_KL散度(Q, M)) / 2
}

// f-散度变分下界 (Nguyen-Wainwright-Jordan 2023改进)
// D_f(P||Q) = sup_T { E_P[T] - E_Q[f*(T)] }
// f*(t) = f的Fenchel共轭
函数 f散度_变分(P, Q, T函数值) {
    定义 n = 计数(P)
    定义 可变 EP = 0
    定义 可变 EQ = 0
    定义 可变 i = 0
    当 (i < n) {
        EP = EP + P[i] * T函数值[i] / IG精度
        // f*(t) = exp(t-1) 对 KL散度
        定义 共轭 = 近似exp(T函数值[i] - IG精度)
        EQ = EQ + Q[i] * 共轭 / IG精度
        i = i + 1
    }
    返回 EP - EQ
}

// α-散度族
函数 α散度(P, Q, α) {
    定义 n = 计数(P)
    如果 (α == IG精度) { 返回 信息几何_KL散度(P, Q) }
    如果 (α == 0) { 返回 信息几何_KL散度(Q, P) }
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (P[i] > 0 且 Q[i] > 0) {
            // p^α × q^(1-α) via exp(α·log(p) + (1-α)·log(q))
            定义 logp = 近似log(P[i])
            定义 logq = 近似log(Q[i])
            定义 混合log = logp * α / IG精度 + logq * (IG精度 - α) / IG精度
            总和 = 总和 + 近似exp(混合log)
        }
        i = i + 1
    }
    定义 分母 = α * (IG精度 - α) / IG精度
    如果 (分母 == 0) { 返回 0 }
    返回 (IG精度 - 总和) * IG精度 / 分母
}

// Wasserstein-Fisher-Rao 度量 (Chizat et al. 2022)
// WFR = 最优传输与Fisher-Rao度量的融合
// 解决纯Fisher-Rao无法处理支撑不重叠分布的问题
// WFR²(μ,ν) = inf_{γ} ∫ d_FR(x,y)² dγ(x,y) + λ·W₂²(μ,ν)

函数 WFR_距离(P, Q, λ权重) {
    // 同时考虑几何距离(Fisher-Rao)和传输成本(Wasserstein)
    定义 n = 计数(P)

    // Fisher-Rao分量: 2·arccos(Σ√(p_i·q_i))
    定义 可变 BC = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (P[i] > 0 且 Q[i] > 0) {
            BC = BC + 近似sqrt(P[i] * Q[i])
        }
        i = i + 1
    }
    // arccos via Taylor: arccos(x) ≈ π/2·(1-x) for x near 1
    定义 FR² = 0
    如果 (BC < IG精度) {
        定义 补 = IG精度 - BC
        FR² = 4 * 补 * 补 / IG精度
    }

    // Wasserstein-1分量 (Earth Mover近似: 排序+累积差)
    定义 可变 W = 0
    定义 可变 累积差 = 0
    i = 0
    当 (i < n) {
        累积差 = 累积差 + P[i] - Q[i]
        如果 (累积差 < 0) { W = W - 累积差 } 否则 { W = W + 累积差 }
        i = i + 1
    }

    // WFR² = FR² + λ·W
    返回 FR² + λ权重 * W / IG精度
}

// 测地线 (e-测地线 + m-测地线对偶)

// e-测地线 (指数族自然参数空间): 直线在η空间
函数 e测地线_插值(P, Q, t) {
    定义 n = 计数(P)
    定义 可变 结果 = []
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < n) {
        // exp((1-t)·log p + t·log q)
        定义 可变 值 = 0
        如果 (P[i] > 0 且 Q[i] > 0) {
            定义 logp = 近似log(P[i])
            定义 logq = 近似log(Q[i])
            定义 混合 = logp * (IG精度 - t) / IG精度 + logq * t / IG精度
            值 = 近似exp(混合)
        }
        追加(结果, 值)
        总和 = 总和 + 值
        i = i + 1
    }
    // 归一化
    如果 (总和 > 0) {
        i = 0
        当 (i < n) { 结果[i] = 结果[i] * IG精度 / 总和; i = i + 1 }
    }
    返回 结果
}

// m-测地线 (混合族期望参数空间): 直线在μ空间
函数 m测地线_插值(P, Q, t) {
    定义 n = 计数(P)
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < n) {
        追加(结果, P[i] * (IG精度 - t) / IG精度 + Q[i] * t / IG精度)
        i = i + 1
    }
    返回 结果
}

// Fisher-Rao测地线距离 (精确: 2·arccos(BC))
函数 测地线_距离(P, Q) {
    定义 n = 计数(P)
    定义 可变 BC = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (P[i] > 0 且 Q[i] > 0) {
            BC = BC + 近似sqrt(P[i] * Q[i])
        }
        i = i + 1
    }
    如果 (BC >= IG精度) { 返回 0 }
    // arccos近似: 2·√(2·(1-BC/P))
    定义 补 = IG精度 - BC
    返回 2 * 近似sqrt(2 * 补)
}

// Bregman散度 + Mirror Descent (Amid&Warmuth 2022)
// D_φ(p||q) = φ(p) - φ(q) - ∇φ(q)·(p-q)
// Mirror Descent: θ_{t+1} = ∇φ*(∇φ(θ_t) - η·∇f(θ_t))

// 负熵的Bregman散度 = KL散度
函数 Bregman_负熵(P, Q) {
    返回 信息几何_KL散度(P, Q)
}

// 平方范数的Bregman散度 = 欧氏距离²
函数 Bregman_欧氏(P, Q) {
    定义 n = 计数(P)
    定义 可变 d = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 差 = P[i] - Q[i]
        d = d + 差 * 差 / IG精度
        i = i + 1
    }
    返回 d
}

// Mirror Descent步进 (使用负熵作为镜像映射)
// 等价于: p_{t+1} ∝ p_t · exp(-η·∇f)  (指数权重更新)
函数 Mirror_Descent步进(分布, 梯度, 学习率) {
    定义 n = 计数(分布)
    定义 可变 新分布 = []
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < n) {
        // p'_i = p_i · exp(-η·g_i)
        定义 权重 = 近似exp(0 - 学习率 * 梯度[i] / IG精度)
        定义 值 = 分布[i] * 权重 / IG精度
        如果 (值 < 1) { 值 = 1 }
        追加(新分布, 值)
        总和 = 总和 + 值
        i = i + 1
    }
    // 归一化 (保证概率和=1)
    如果 (总和 > 0) {
        i = 0
        当 (i < n) { 新分布[i] = 新分布[i] * IG精度 / 总和; i = i + 1 }
    }
    返回 新分布
}

// Fisher-Rao流 (Ay et al. 2022)
// ∂p/∂t = -F(p)⁻¹·∇KL(p||p*)
// 在统计流形上沿测地线流动到目标分布

函数 FisherRao_流步进(当前分布, 目标分布, 步长) {
    定义 n = 计数(当前分布)
    // 计算KL梯度: ∂KL/∂p_i = log(p_i/q_i) + 1
    定义 可变 KL梯度 = []
    定义 可变 i = 0
    当 (i < n) {
        如果 (当前分布[i] > 0 且 目标分布[i] > 0) {
            定义 比值 = 当前分布[i] * IG精度 / 目标分布[i]
            追加(KL梯度, 近似log(比值) + IG精度)
        } 否则 {
            追加(KL梯度, 0)
        }
        i = i + 1
    }
    // Fisher对角信息
    定义 Fisher = Fisher矩阵_对角(当前分布, n)
    // 自然梯度
    定义 自然 = 自然梯度_阻尼(KL梯度, Fisher, 100)
    // 流步进: p_{t+1} = p_t - dt·F⁻¹·∇KL
    定义 可变 新分布 = []
    定义 可变 总和 = 0
    i = 0
    当 (i < n) {
        定义 值 = 当前分布[i] - 步长 * 自然[i] / IG精度
        如果 (值 < 1) { 值 = 1 }
        追加(新分布, 值)
        总和 = 总和 + 值
        i = i + 1
    }
    如果 (总和 > 0) {
        i = 0
        当 (i < n) { 新分布[i] = 新分布[i] * IG精度 / 总和; i = i + 1 }
    }
    返回 新分布
}

// 指数族对偶结构
// θ (自然参数) ↔ η (期望参数), A(θ)为log配分函数
// ∂A/∂θ_i = η_i, ∂A*/∂η_i = θ_i (Legendre对偶)

函数 指数族_自然到期望(自然参数, 充分统计量样本) {
    // η_i = (1/N)Σ_n T_i(x_n) 当p(x|θ)是指数族时
    定义 d = 计数(自然参数)
    定义 N = 计数(充分统计量样本)
    如果 (N == 0) { 返回 自然参数 }
    定义 可变 期望 = []
    定义 可变 di = 0
    当 (di < d) {
        定义 可变 累计 = 0
        定义 可变 ni = 0
        当 (ni < N) {
            累计 = 累计 + 充分统计量样本[ni][di]
            ni = ni + 1
        }
        追加(期望, 累计 / N)
        di = di + 1
    }
    返回 期望
}

// 应用: 编译器优化空间导航
函数 优化空间_搜索(当前策略, 性能梯度, 策略分布) {
    定义 Fisher = Fisher矩阵_对角(策略分布, 计数(当前策略))
    返回 自然梯度_步进(当前策略, 性能梯度, Fisher, 500)
}

// 黎曼Adam优化器 (Bécigneul&Ganea 2019 → Chen et al. 2024改进)
// 核心: 在统计流形(黎曼流形)上做Adam
// 传统Adam在欧氏空间, 忽略参数空间的几何结构
// 黎曼Adam: 梯度用Fisher度量重标定, 动量用平行移动
// m_t = β1·Γ(m_{t-1}) + (1-β1)·F⁻¹·∇f  (Γ=平行移动)
// v_t = β2·v_{t-1} + (1-β2)·||F⁻¹·∇f||²_F  (Fisher范数)
// θ_{t+1} = Exp_θ(-lr·m̂_t/√(v̂_t+ε))  (指数映射)

函数 黎曼Adam_创建(维度) {
    // [m_一阶动量, v_二阶动量, t步数, 维度]
    定义 可变 m = []
    定义 可变 v = []
    定义 可变 i = 0
    当 (i < 维度) { 追加(m, 0); 追加(v, 0); i = i + 1 }
    返回 [m, v, 0, 维度]
}

函数 黎曼Adam_步进(状态, 参数, 梯度, Fisher对角, 学习率, β1, β2) {
    定义 可变 m = 状态[0]
    定义 可变 v = 状态[1]
    定义 t = 状态[2] + 1
    定义 维度 = 状态[3]
    // 自然梯度: g̃ = F⁻¹·∇f
    定义 可变 自然梯度 = []
    定义 可变 i = 0
    当 (i < 维度) {
        如果 (Fisher对角[i] > 0) {
            追加(自然梯度, 梯度[i] * IG精度 / Fisher对角[i])
        } 否则 {
            追加(自然梯度, 梯度[i])
        }
        i = i + 1
    }
    // 更新动量 (简化平行移动为直接衰减)
    定义 可变 新参数 = []
    i = 0
    当 (i < 维度) {
        // m = β1·m + (1-β1)·g̃
        m[i] = β1 * m[i] / IG精度 + (IG精度 - β1) * 自然梯度[i] / IG精度
        // v = β2·v + (1-β2)·||g̃||²_F (Fisher范数)
        定义 g_fisher_norm = 自然梯度[i] * 自然梯度[i] / IG精度
        v[i] = β2 * v[i] / IG精度 + (IG精度 - β2) * g_fisher_norm / IG精度
        // 偏差修正
        定义 m_hat = m[i] * IG精度 / (IG精度 - β1)  // 简化: 不精确递推β^t
        定义 v_hat = v[i] * IG精度 / (IG精度 - β2)
        // √v
        定义 可变 sv = v_hat
        如果 (sv < 0) { sv = 0 - sv }
        定义 可变 sqr = sv / 2
        如果 (sqr == 0) { sqr = 1 }
        定义 可变 k = 0
        当 (k < 4) { sqr = (sqr + sv * IG精度 / sqr) / 2; k = k + 1 }
        // 指数映射近似: Exp_θ(-lr·update) ≈ θ - lr·update (一阶)
        追加(新参数, 参数[i] - 学习率 * m_hat / (sqr + 100))
        i = i + 1
    }
    状态[0] = m
    状态[1] = v
    状态[2] = t
    返回 新参数
}

// IGO: 信息几何优化框架 (Ollivier et al. 2017 → 2024)
// 核心: 用参数化搜索分布 P_θ 在解空间中搜索
// 更新: θ_{t+1} = θ_t + δt · F⁻¹·∇_θ E_{P_θ}[W(f(x))]
// W(f(x)) = 将f(x)的排名映射为权重 (秩选择)
// 当P_θ=高斯时 → CMA-ES; 当P_θ=伯努利时 → PBIL
// 统一框架: 不同搜索分布族 + Fisher自然梯度 = 不同进化策略

函数 IGO_秩选择权重(适应度列表) {
    定义 n = 计数(适应度列表)
    如果 (n == 0) { 返回 [] }
    // 排序索引 (冒泡排序, 降序)
    定义 可变 排名 = []
    定义 可变 i = 0
    当 (i < n) { 追加(排名, i); i = i + 1 }
    i = 0
    当 (i < n - 1) {
        定义 可变 j = 0
        当 (j < n - 1 - i) {
            如果 (适应度列表[排名[j]] < 适应度列表[排名[j + 1]]) {
                定义 tmp = 排名[j]
                排名[j] = 排名[j + 1]
                排名[j + 1] = tmp
            }
            j = j + 1
        }
        i = i + 1
    }
    // 秩权重: w_i = max(0, log(n/2+1) - log(rank_i)) / Z
    定义 可变 权重 = []
    定义 可变 权重和 = 0
    i = 0
    当 (i < n) { 追加(权重, 0); i = i + 1 }
    i = 0
    当 (i < n) {
        // 找到原始索引i在排名中的位置
        定义 可变 rank_pos = 0
        定义 可变 j = 0
        当 (j < n) {
            如果 (排名[j] == i) { rank_pos = j }
            j = j + 1
        }
        // w = max(0, log(n/2+1) - log(rank+1))
        定义 中位 = 近似log((n / 2 + 1) * IG精度)
        定义 排名分 = 近似log((rank_pos + 1) * IG精度)
        定义 可变 w = 中位 - 排名分
        如果 (w < 0) { w = 0 }
        权重[i] = w
        权重和 = 权重和 + w
        i = i + 1
    }
    // 归一化
    如果 (权重和 > 0) {
        i = 0
        当 (i < n) { 权重[i] = 权重[i] * IG精度 / 权重和; i = i + 1 }
    }
    返回 权重
}

// IGO更新步: θ += δt · F⁻¹ · Σ w_i · ∇log P_θ(x_i)
函数 IGO_步进(参数, 样本列表, 适应度列表, Fisher对角, 步长, 维度, 样本数) {
    定义 权重 = IGO_秩选择权重(适应度列表)
    // 加权分数函数梯度: Σ w_i · ∇log P_θ(x_i)
    // 对高斯分布: ∇log P_θ(x) ∝ (x - μ)/σ²
    定义 可变 梯度 = []
    定义 可变 d = 0
    当 (d < 维度) { 追加(梯度, 0); d = d + 1 }
    定义 可变 i = 0
    当 (i < 样本数) {
        d = 0
        当 (d < 维度) {
            // ∇log P = (x_i - θ) (对高斯均值参数)
            定义 分数 = 样本列表[i * 维度 + d] - 参数[d]
            梯度[d] = 梯度[d] + 权重[i] * 分数 / IG精度
            d = d + 1
        }
        i = i + 1
    }
    // 自然梯度 + 参数更新
    定义 可变 新参数 = []
    d = 0
    当 (d < 维度) {
        定义 自然 = 梯度[d]
        如果 (Fisher对角[d] > 0) {
            自然 = 梯度[d] * IG精度 / Fisher对角[d]
        }
        追加(新参数, 参数[d] + 步长 * 自然 / IG精度)
        d = d + 1
    }
    返回 新参数
}

// Rényi散度 (Rényi 1961 → Esposito et al. 2024 PAC-Bayes)
// D_α(P||Q) = 1/(α-1) · log(Σ p_i^α · q_i^{1-α})
// α=1 → KL散度; α=0.5 → 2·Bhattacharyya距离; α=∞ → max-divergence
// 2024新用途: PAC-Bayes泛化界用Rényi散度比KL散度更紧

函数 Renyi散度(P, Q, α) {
    定义 n = 计数(P)
    如果 (α == IG精度) { 返回 信息几何_KL散度(P, Q) }
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (P[i] > 0 且 Q[i] > 0) {
            // p^α · q^{1-α} via exp(α·log(p) + (1-α)·log(q))
            定义 logp = 近似log(P[i])
            定义 logq = 近似log(Q[i])
            定义 混合 = α * logp / IG精度 + (IG精度 - α) * logq / IG精度
            总和 = 总和 + 近似exp(混合)
        }
        i = i + 1
    }
    如果 (总和 <= 0) { 返回 0 }
    定义 分母 = α - IG精度
    如果 (分母 == 0) { 返回 0 }
    返回 近似log(总和) * IG精度 / 分母
}

// PAC-Bayes界: 用Rényi散度的泛化上界
// E_Q[L] ≤ E_P[L] + √(D_α(Q||P) / (2n·(α-1)))  (简化)
函数 PAC_Bayes_Renyi界(经验损失, 后验P, 先验Q, α, 样本数) {
    定义 散度 = Renyi散度(后验P, 先验Q, α)
    如果 (散度 < 0) { 散度 = 0 }
    // √(D / (2n(α-1)))
    定义 分母 = 2 * 样本数 * (α - IG精度 + 1) / IG精度
    如果 (分母 < 1) { 分母 = 1 }
    定义 被开方 = 散度 * IG精度 / 分母
    定义 可变 s = 被开方 / 2
    如果 (s == 0) { s = 1 }
    定义 可变 k = 0
    当 (k < 6) { s = (s + 被开方 * IG精度 / s) / 2; k = k + 1 }
    返回 经验损失 + s
}

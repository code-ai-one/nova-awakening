
导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/整数转字符串.nova")
导入("../执行/控制台输出.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/内核打印.nova")

定义 页面类型_未知 = 0
定义 页面类型_文章 = 1
定义 页面类型_表单 = 2
定义 页面类型_搜索 = 3
定义 页面类型_列表 = 4
定义 页面类型_商品 = 5
定义 页面类型_登录 = 6
定义 页面类型_媒体 = 7
定义 页面类型_首页 = 8

定义 关键词_最大数 = 32
定义 标题层级_最大 = 6

结构 AI页面摘要 {
    页面类型,
    主内容区,
    导航区,
    页脚区,
    侧边栏区,
    广告区数量,
    正文节点数,
    图片数,
    链接数,
    表单数,
    输入框数,
    按钮数,
    视频数,
    音频数,
    DOM节点总数,
    最大DOM深度,
    平均DOM深度,
    深度总和,
    文本总长度,
    标题层级计数,
    关键词列表,
    关键词数,
    可读性分数,
    无障碍分数,
    SEO分数,
    内容密度,
}

结构 文档分析统计 {
    分析次数,
    质量评分次数,
    关键词提取次数,
    无障碍审计次数,
    SEO审计次数,
}

定义 可变 全局_文档分析统计 = 空

函数 文档分析统计_初始化() {
    如果 (全局_文档分析统计 == 空) {
        全局_文档分析统计 = 文档分析统计 {}
        全局_文档分析统计.分析次数 = 0
        全局_文档分析统计.质量评分次数 = 0
        全局_文档分析统计.关键词提取次数 = 0
        全局_文档分析统计.无障碍审计次数 = 0
        全局_文档分析统计.SEO审计次数 = 0
    }
}

函数 AI文档_生成摘要(文档) {
    文档分析统计_初始化()
    全局_文档分析统计.分析次数 = 全局_文档分析统计.分析次数 + 1

    定义 摘要 = 堆_分配(AI页面摘要)
    摘要.页面类型 = 页面类型_未知
    摘要.主内容区 = 0
    摘要.导航区 = 0
    摘要.页脚区 = 0
    摘要.侧边栏区 = 0
    摘要.广告区数量 = 0
    摘要.正文节点数 = 0
    摘要.图片数 = 0
    摘要.链接数 = 0
    摘要.表单数 = 0
    摘要.输入框数 = 0
    摘要.按钮数 = 0
    摘要.视频数 = 0
    摘要.音频数 = 0
    摘要.DOM节点总数 = 0
    摘要.最大DOM深度 = 0
    摘要.平均DOM深度 = 0
    摘要.深度总和 = 0
    摘要.文本总长度 = 0
    摘要.标题层级计数 = 堆_分配(标题层级_最大 * 8)
    定义 可变 h = 0
    当 (h < 标题层级_最大) {
        内存_写64(摘要.标题层级计数 + h * 8, 0)
        h = h + 1
    }
    摘要.关键词列表 = 堆_分配(关键词_最大数 * 16)
    摘要.关键词数 = 0
    摘要.可读性分数 = 0
    摘要.无障碍分数 = 0
    摘要.SEO分数 = 0
    摘要.内容密度 = 0

    如果 (文档 == 0) { 返回 摘要 }

    // 遍历DOM树统计
    AI文档_遍历统计(文档, 摘要, 0)

    // 计算平均深度
    如果 (摘要.DOM节点总数 > 0) {
        摘要.平均DOM深度 = 摘要.深度总和 / 摘要.DOM节点总数
    }

    // 计算内容密度 (文本节点比例)
    如果 (摘要.DOM节点总数 > 0) {
        摘要.内容密度 = (摘要.正文节点数 * 100) / 摘要.DOM节点总数
    }

    // 推断页面类型
    摘要.页面类型 = AI文档_推断类型(摘要)

    // 自动计算评分
    摘要.可读性分数 = AI文档_可读性评分(摘要)
    摘要.无障碍分数 = AI文档_无障碍评分(摘要)
    摘要.SEO分数 = AI文档_SEO评分(摘要)

    返回 摘要
}

函数 AI文档_推断类型(摘要) {
    // 登录页: 少量输入框+密码框
    如果 (摘要.表单数 > 0 && 摘要.输入框数 <= 4 && 摘要.DOM节点总数 < 150) {
        返回 页面类型_登录
    }
    // 媒体页: 有视频或音频
    如果 (摘要.视频数 > 0 || 摘要.音频数 > 0) {
        返回 页面类型_媒体
    }
    // 文章页: 大量正文
    如果 (摘要.正文节点数 > 20 && 摘要.图片数 < 摘要.正文节点数) {
        返回 页面类型_文章
    }
    // 表单页
    如果 (摘要.表单数 > 0 && 摘要.输入框数 > 3) {
        返回 页面类型_表单
    }
    // 商品页: 图片+按钮+价格相关
    如果 (摘要.图片数 > 5 && 摘要.按钮数 > 2) {
        返回 页面类型_商品
    }
    // 列表/搜索页
    如果 (摘要.链接数 > 30) {
        返回 页面类型_搜索
    }
    如果 (摘要.链接数 > 15 && 摘要.图片数 > 5) {
        返回 页面类型_列表
    }
    返回 页面类型_首页
}

函数 AI文档_遍历统计(节点, 摘要, 深度) {
    如果 (节点 == 0) { 返回 }
    摘要.DOM节点总数 = 摘要.DOM节点总数 + 1
    摘要.深度总和 = 摘要.深度总和 + 深度
    如果 (深度 > 摘要.最大DOM深度) { 摘要.最大DOM深度 = 深度 }

    // 计数各类节点
    如果 (节点.语义角色 == 语义_正文 || 节点.语义角色 == 语义_标题) {
        摘要.正文节点数 = 摘要.正文节点数 + 1
    }
    如果 (节点.语义角色 == 语义_导航栏 && 摘要.导航区 == 0) {
        摘要.导航区 = 节点
    }
    如果 (节点.语义角色 == 语义_页脚 && 摘要.页脚区 == 0) {
        摘要.页脚区 = 节点
    }
    如果 (节点.语义角色 == 语义_侧边栏 && 摘要.侧边栏区 == 0) {
        摘要.侧边栏区 = 节点
    }
    如果 (节点.语义角色 == 语义_广告) {
        摘要.广告区数量 = 摘要.广告区数量 + 1
    }
    如果 (节点.语义角色 == 语义_主内容 && 摘要.主内容区 == 0) {
        摘要.主内容区 = 节点
    }

    // 按标签名统计
    如果 (节点.标签名 == "img") { 摘要.图片数 = 摘要.图片数 + 1 }
    如果 (节点.标签名 == "a") { 摘要.链接数 = 摘要.链接数 + 1 }
    如果 (节点.标签名 == "form") { 摘要.表单数 = 摘要.表单数 + 1 }
    如果 (节点.标签名 == "input" || 节点.标签名 == "textarea") {
        摘要.输入框数 = 摘要.输入框数 + 1
    }
    如果 (节点.标签名 == "button") { 摘要.按钮数 = 摘要.按钮数 + 1 }
    如果 (节点.标签名 == "video") { 摘要.视频数 = 摘要.视频数 + 1 }
    如果 (节点.标签名 == "audio") { 摘要.音频数 = 摘要.音频数 + 1 }

    // 标题层级统计
    如果 (节点.标签名 == "h1") { AI文档_增加标题计数(摘要, 0) }
    如果 (节点.标签名 == "h2") { AI文档_增加标题计数(摘要, 1) }
    如果 (节点.标签名 == "h3") { AI文档_增加标题计数(摘要, 2) }
    如果 (节点.标签名 == "h4") { AI文档_增加标题计数(摘要, 3) }
    如果 (节点.标签名 == "h5") { AI文档_增加标题计数(摘要, 4) }
    如果 (节点.标签名 == "h6") { AI文档_增加标题计数(摘要, 5) }

    // 文本长度统计
    如果 (节点.节点类型 == 3 && 节点.文本内容 != 0) {
        摘要.文本总长度 = 摘要.文本总长度 + 字符串长度(节点.文本内容)
    }

    // 遍历子节点
    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        AI文档_遍历统计(子, 摘要, 深度 + 1)
        子 = 子.下一兄弟
    }
}

函数 AI文档_增加标题计数(摘要, 层级) {
    如果 (层级 >= 0 && 层级 < 标题层级_最大) {
        定义 旧 = 内存_读64(摘要.标题层级计数 + 层级 * 8)
        内存_写64(摘要.标题层级计数 + 层级 * 8, 旧 + 1)
    }
}

函数 AI文档_按角色查找(文档, 角色) {
    返回 AI文档_角色搜索(文档, 角色)
}

函数 AI文档_按角色查找_全部(文档, 角色) {
    定义 可变 结果 = []
    AI文档_角色搜索_全部(文档, 角色, 结果)
    返回 结果
}

函数 AI文档_角色搜索(节点, 角色) {
    如果 (节点 == 0) { 返回 0 }
    如果 (节点.语义角色 == 角色) { 返回 节点 }
    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        定义 结果 = AI文档_角色搜索(子, 角色)
        如果 (结果 != 0) { 返回 结果 }
        子 = 子.下一兄弟
    }
    返回 0
}

函数 AI文档_角色搜索_全部(节点, 角色, 结果) {
    如果 (节点 == 0) { 返回 }
    如果 (节点.语义角色 == 角色) { 追加(结果, 节点) }
    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        AI文档_角色搜索_全部(子, 角色, 结果)
        子 = 子.下一兄弟
    }
}

函数 AI文档_可读性评分(摘要) {
    定义 可变 分数 = 100

    // 文本长度过短
    如果 (摘要.文本总长度 < 100) { 分数 = 分数 - 20 }

    // 平均深度过深影响可读性
    如果 (摘要.平均DOM深度 > 10) { 分数 = 分数 - 10 }
    如果 (摘要.平均DOM深度 > 20) { 分数 = 分数 - 15 }

    // 内容密度过低
    如果 (摘要.内容密度 < 10) { 分数 = 分数 - 15 }

    // 标题结构完整性加分
    定义 h1数 = 内存_读64(摘要.标题层级计数)
    如果 (h1数 == 1) { 分数 = 分数 + 5 }
    如果 (h1数 > 1) { 分数 = 分数 - 5 }

    如果 (分数 < 0) { 分数 = 0 }
    如果 (分数 > 100) { 分数 = 100 }
    返回 分数
}

函数 AI文档_无障碍评分(摘要) {
    文档分析统计_初始化()
    全局_文档分析统计.无障碍审计次数 = 全局_文档分析统计.无障碍审计次数 + 1

    定义 可变 分数 = 100

    // 图片需要alt属性 (此处近似扣分)
    如果 (摘要.图片数 > 0) { 分数 = 分数 - 5 }

    // 表单需要label
    如果 (摘要.输入框数 > 0) { 分数 = 分数 - 5 }

    // 缺少导航标记
    如果 (摘要.导航区 == 0) { 分数 = 分数 - 10 }

    // 缺少主内容标记
    如果 (摘要.主内容区 == 0) { 分数 = 分数 - 10 }

    // 标题跳级扣分 (有h3但无h2)
    定义 h2数 = 内存_读64(摘要.标题层级计数 + 1 * 8)
    定义 h3数 = 内存_读64(摘要.标题层级计数 + 2 * 8)
    如果 (h3数 > 0 && h2数 == 0) { 分数 = 分数 - 10 }

    如果 (分数 < 0) { 分数 = 0 }
    返回 分数
}

函数 AI文档_SEO评分(摘要) {
    文档分析统计_初始化()
    全局_文档分析统计.SEO审计次数 = 全局_文档分析统计.SEO审计次数 + 1

    定义 可变 分数 = 100

    // 必须有且仅有一个h1
    定义 h1数 = 内存_读64(摘要.标题层级计数)
    如果 (h1数 == 0) { 分数 = 分数 - 20 }
    如果 (h1数 > 1) { 分数 = 分数 - 10 }

    // 文本过少
    如果 (摘要.文本总长度 < 300) { 分数 = 分数 - 15 }

    // 图片缺少alt (近似)
    如果 (摘要.图片数 > 10) { 分数 = 分数 - 5 }

    // 链接过多 (可能是垃圾页面)
    如果 (摘要.链接数 > 100) { 分数 = 分数 - 10 }

    // DOM过于复杂
    如果 (摘要.DOM节点总数 > 5000) { 分数 = 分数 - 10 }

    如果 (分数 < 0) { 分数 = 0 }
    返回 分数
}

函数 AI文档_质量评分(文档) {
    文档分析统计_初始化()
    全局_文档分析统计.质量评分次数 = 全局_文档分析统计.质量评分次数 + 1

    定义 摘要 = AI文档_生成摘要(文档)
    定义 可变 分数 = 100

    // DOM深度过深扣分
    如果 (摘要.最大DOM深度 > 30) { 分数 = 分数 - 10 }
    如果 (摘要.最大DOM深度 > 50) { 分数 = 分数 - 20 }

    // DOM节点过多扣分
    如果 (摘要.DOM节点总数 > 3000) { 分数 = 分数 - 10 }
    如果 (摘要.DOM节点总数 > 10000) { 分数 = 分数 - 20 }

    // 广告过多扣分
    如果 (摘要.广告区数量 > 5) { 分数 = 分数 - 15 }

    // 综合子评分
    定义 综合 = (分数 + 摘要.可读性分数 + 摘要.无障碍分数 + 摘要.SEO分数) / 4

    如果 (综合 < 0) { 综合 = 0 }
    如果 (综合 > 100) { 综合 = 100 }
    返回 综合
}

函数 AI文档_类型名称(类型) {
    如果 (类型 == 页面类型_文章) { 返回 "文章页" }
    如果 (类型 == 页面类型_表单) { 返回 "表单页" }
    如果 (类型 == 页面类型_搜索) { 返回 "搜索页" }
    如果 (类型 == 页面类型_列表) { 返回 "列表页" }
    如果 (类型 == 页面类型_商品) { 返回 "商品页" }
    如果 (类型 == 页面类型_登录) { 返回 "登录页" }
    如果 (类型 == 页面类型_媒体) { 返回 "媒体页" }
    如果 (类型 == 页面类型_首页) { 返回 "首页" }
    返回 "未知"
}

函数 AI文档_打印摘要(摘要) {
    如果 (摘要 == 0) { 返回 }
    打印行("=== 页面分析摘要 ===")
    打印行("页面类型: " + AI文档_类型名称(摘要.页面类型))
    打印行("DOM节点数: " + 整数转字符串(摘要.DOM节点总数))
    打印行("最大深度: " + 整数转字符串(摘要.最大DOM深度))
    打印行("平均深度: " + 整数转字符串(摘要.平均DOM深度))
    打印行("正文节点: " + 整数转字符串(摘要.正文节点数))
    打印行("图片数: " + 整数转字符串(摘要.图片数))
    打印行("链接数: " + 整数转字符串(摘要.链接数))
    打印行("表单数: " + 整数转字符串(摘要.表单数))
    打印行("输入框: " + 整数转字符串(摘要.输入框数))
    打印行("按钮数: " + 整数转字符串(摘要.按钮数))
    打印行("视频数: " + 整数转字符串(摘要.视频数))
    打印行("广告区: " + 整数转字符串(摘要.广告区数量))
    打印行("文本长度: " + 整数转字符串(摘要.文本总长度))
    打印行("内容密度: " + 整数转字符串(摘要.内容密度) + "%")
    打印行("可读性: " + 整数转字符串(摘要.可读性分数))
    打印行("无障碍: " + 整数转字符串(摘要.无障碍分数))
    打印行("SEO: " + 整数转字符串(摘要.SEO分数))
}

函数 文档分析_打印统计() {
    文档分析统计_初始化()
    打印行("=== 文档分析统计 ===")
    打印行("分析次数: " + 整数转字符串(全局_文档分析统计.分析次数))
    打印行("质量评分: " + 整数转字符串(全局_文档分析统计.质量评分次数))
    打印行("关键词提取: " + 整数转字符串(全局_文档分析统计.关键词提取次数))
    打印行("无障碍审计: " + 整数转字符串(全局_文档分析统计.无障碍审计次数))
    打印行("SEO审计: " + 整数转字符串(全局_文档分析统计.SEO审计次数))
}

函数 内容指纹_计算(文本, 长度) {
    // simhash简化: 滑动窗口哈希
    如果 (文本 == 0 || 长度 <= 0) { 返回 0 }
    定义 可变 hash = 0
    定义 可变 i = 0
    当 (i < 长度) {
        hash = hash * 31 + 字节取(文本, i)
        i = i + 1
    }
    返回 hash
}

函数 内容指纹_相似度(fp1, fp2) {
    // 汉明距离近似: 异或后bit计数
    定义 diff = fp1 ^ fp2
    定义 可变 bits = 0
    定义 可变 d = diff
    当 (d > 0) {
        bits = bits + (d & 1)
        d = d >> 1
    }
    // 相似度 = (32 - hamming) / 32 * 100
    返回 (32 - bits) * 100 / 32
}

函数 计算_TF(词频, 总词数) {
    如果 (总词数 <= 0) { 返回 0 }
    返回 词频 * 1000 / 总词数
}

函数 计算_IDF(文档总数, 包含文档数) {
    如果 (包含文档数 <= 0) { 返回 0 }
    // IDF ≈ log(N/df), 用对数近似
    定义 比值 = 文档总数 * 1000 / 包含文档数
    如果 (比值 <= 1000) { 返回 0 }
    // 粗略对数: log2近似
    定义 可变 结果 = 0
    定义 可变 v = 比值
    当 (v > 1000) { v = v / 2; 结果 = 结果 + 1 }
    返回 结果 * 1000
}

函数 计算_TFIDF(词频, 总词数, 文档总数, 包含文档数) {
    定义 tf = 计算_TF(词频, 总词数)
    定义 idf = 计算_IDF(文档总数, 包含文档数)
    返回 tf * idf / 1000
}

函数 文档分析_重置统计() {
    文档分析统计_初始化()
    全局_文档分析统计.分析次数 = 0
    全局_文档分析统计.质量评分次数 = 0
    全局_文档分析统计.关键词提取次数 = 0
    全局_文档分析统计.无障碍审计次数 = 0
    全局_文档分析统计.SEO审计次数 = 0
}

// NDSA — Nova Document Semantic Analysis Theory
// 公理1(多维评分): 可读性+无障碍+SEO多维综合
// 公理2(指纹唯一): 不同内容指纹极高概率不同
// 公理3(分析幂等): 同一文档多次分析结果一致
// 定理1(TFIDF有效): 高TFIDF词比低频词更能代表文档主题
// 定理2(质量单调): 质量分数关于子评分单调递增

函数 文档分析_获取分析次数() {
    文档分析统计_初始化()
    返回 全局_文档分析统计.分析次数
}

函数 文档分析_获取质量评分次数() {
    文档分析统计_初始化()
    返回 全局_文档分析统计.质量评分次数
}

// NovaOS AI内存钩子 — 先天AI特性
// Phase: P1 | AI融入内存分配核心路径
// 核心算法:
//   1. 分配大小频率分析: Top-K热点大小追踪→SLUB预热建议
//   2. 分配速率EMA: 追踪分配/释放速率→预测压力
//   3. 碎片化检测: 小分配占比高→建议SLUB缓存
//   4. 调用者画像: 每个调用者的分配模式→针对性优化
//   5. 与AI内存预测联动: 推送实时数据

导入("./日志中枢.nova")
导入("./自动扩容.nova")
导入("./链表后继.nova")
导入("./新系统智能内.nova")
导入("./字符串替换.nova")
导入("./时钟中枢.nova")

// 桶: 8/16/32/64/128/256/512/1024/2048/4096/大页
定义 桶数 = 11
定义 可变 桶计数 = []             // [11] 每个桶的分配次数
定义 可变 桶频率EMA = []          // [11] 每个桶的频率EMA(×1024)

定义 可变 分配历史 = []
定义 分配历史最大 = 128
定义 可变 总分配次数 = 0
定义 可变 总释放次数 = 0
定义 可变 分配速率EMA = 0         // 次/秒 × 1024
定义 可变 释放速率EMA = 0
定义 可变 上次采样时间 = 0
定义 可变 窗口内分配 = 0
定义 可变 窗口内释放 = 0

函数 AI内存钩子_初始化() {
    定义 可变 i = 0
    当 (i < 桶数) { 追加(桶计数, 0); 追加(桶频率EMA, 0); i = i + 1 }
    上次采样时间 = 读取毫秒()
    内核信息("AI内存钩子: 分配频率分析+Top-K热点+碎片检测+速率EMA")
}

// 核心: 记录每次分配

定义 可变 AI内存_正在记录 = 假  // ★ 防止递归: 追加操作可能触发kmalloc→再次进入此函数

函数 AI内存_记录分配(大小, 调用者) {
    // ★ 安全: 防止递归分配(追加→kmalloc→AI内存_记录分配→追加→...)
    如果 (AI内存_正在记录) { 返回 }
    AI内存_正在记录 = 真

    追加(分配历史, [大小, 调用者])
    如果 (计数(分配历史) > 分配历史最大) { 链表_删除(分配历史, 0) }

    总分配次数 = 总分配次数 + 1
    窗口内分配 = 窗口内分配 + 1

    // 更新桶计数(纯数组索引操作, O(1))
    定义 桶 = AI内存_大小到桶(大小)
    设置(桶计数, 桶, 桶计数[桶] + 1)
    设置(桶频率EMA, 桶, (桶频率EMA[桶] * 922 + 1024 * 102) / 1024)

    // 速率采样
    AI内存_更新速率()

    AI内存_正在记录 = 假
}

函数 AI内存_记录释放(大小) {
    总释放次数 = 总释放次数 + 1
    窗口内释放 = 窗口内释放 + 1
}

函数 AI内存_更新速率() {
    定义 现在 = 读取毫秒()
    如果 (现在 - 上次采样时间 > 1000) {
        分配速率EMA = (分配速率EMA * 922) / 1024 + (窗口内分配 * 102) / 1024
        释放速率EMA = (释放速率EMA * 922) / 1024 + (窗口内释放 * 102) / 1024
        窗口内分配 = 0
        窗口内释放 = 0
        上次采样时间 = 现在

        // 联动: 推送给AI内存预测
        AI内存_采样(全局空闲页数, 总分配次数, 总释放次数)
    }
}

// 热点大小预测

函数 AI内存_预测热点大小() {
    // 找频率最高的桶
    定义 可变 最高桶 = 0
    定义 可变 最高频 = 0
    定义 可变 i = 0
    当 (i < 桶数) {
        如果 (桶频率EMA[i] > 最高频) { 最高频 = 桶频率EMA[i]; 最高桶 = i }
        i = i + 1
    }
    返回 AI内存_桶到大小(最高桶)
}

函数 AI内存_建议预分配() {
    如果 (全局空闲页数 > 总页数 / 2) {
        返回 真
    }
    // 即使内存不那么充足, 但分配速率高→也建议预分配
    如果 (分配速率EMA > 释放速率EMA * 2 && 全局空闲页数 > 总页数 / 4) {
        返回 真
    }
    返回 假
}

函数 AI内存_碎片化风险() {
    // 小分配(≤64字节)占比>60%→碎片化风险
    定义 小分配 = 桶计数[0] + 桶计数[1] + 桶计数[2] + 桶计数[3]  // 8+16+32+64
    如果 (总分配次数 == 0) { 返回 0 }
    返回 小分配 * 100 / 总分配次数
}

// 桶映射

函数 AI内存_大小到桶(大小) {
    如果 (大小 <= 8) { 返回 0 }
    如果 (大小 <= 16) { 返回 1 }
    如果 (大小 <= 32) { 返回 2 }
    如果 (大小 <= 64) { 返回 3 }
    如果 (大小 <= 128) { 返回 4 }
    如果 (大小 <= 256) { 返回 5 }
    如果 (大小 <= 512) { 返回 6 }
    如果 (大小 <= 1024) { 返回 7 }
    如果 (大小 <= 2048) { 返回 8 }
    如果 (大小 <= 4096) { 返回 9 }
    返回 10
}

函数 AI内存_桶到大小(桶) {
    定义 大小表 = [8, 16, 32, 64, 128, 256, 512, 1024, 2048, 4096, 8192]
    如果 (桶 >= 0 && 桶 < 桶数) { 返回 大小表[桶] }
    返回 64
}

函数 AI内存_分配速率() { 返回 分配速率EMA }
函数 AI内存_释放速率() { 返回 释放速率EMA }

// 调用者画像 (每个调用者的分配模式)

定义 可变 调用者画像表 = []    // [调用者, 分配次数, 释放次数, 常用大小桶]
定义 调用者画像最大 = 64

函数 AI内存_调用者记录(调用者, 大小) {
    定义 桶 = AI内存_大小到桶(大小)
    定义 可变 i = 0
    当 (i < 计数(调用者画像表)) {
        如果 (调用者画像表[i][0] == 调用者) {
            设置(调用者画像表[i], 1, 调用者画像表[i][1] + 1)
            设置(调用者画像表[i], 3, 桶)  // 更新最近常用大小
            返回
        }
        i = i + 1
    }
    如果 (计数(调用者画像表) < 调用者画像最大) {
        追加(调用者画像表, [调用者, 1, 0, 桶])
    }
}

函数 AI内存_调用者释放(调用者) {
    定义 可变 i = 0
    当 (i < 计数(调用者画像表)) {
        如果 (调用者画像表[i][0] == 调用者) {
            设置(调用者画像表[i], 2, 调用者画像表[i][2] + 1)
            返回
        }
        i = i + 1
    }
}

// Top-K热点调用者

函数 AI内存_热点调用者(K) {
    // 按分配次数降序排列, 取前K个
    定义 可变 结果 = []
    定义 可变 已选 = []
    定义 可变 k = 0
    当 (k < K && k < 计数(调用者画像表)) {
        定义 可变 最大索引 = -1
        定义 可变 最大值 = 0
        定义 可变 i = 0
        当 (i < 计数(调用者画像表)) {
            如果 (调用者画像表[i][1] > 最大值) {
                // 检查是否已选
                定义 可变 已存在 = 假
                定义 可变 j = 0
                当 (j < 计数(已选)) {
                    如果 (已选[j] == i) { 已存在 = 真 }
                    j = j + 1
                }
                如果 (!已存在) { 最大索引 = i; 最大值 = 调用者画像表[i][1] }
            }
            i = i + 1
        }
        如果 (最大索引 >= 0) {
            追加(结果, 调用者画像表[最大索引])
            追加(已选, 最大索引)
        }
        k = k + 1
    }
    返回 结果
}

// 内存泄漏检测提示

函数 AI内存_泄漏嫌疑() {
    // 分配次数远大于释放次数的调用者
    定义 可变 嫌疑 = []
    定义 可变 i = 0
    当 (i < 计数(调用者画像表)) {
        定义 分配 = 调用者画像表[i][1]
        定义 释放 = 调用者画像表[i][2]
        如果 (分配 > 100 && 释放 * 2 < 分配) {
            追加(嫌疑, [调用者画像表[i][0], 分配, 释放])
        }
        i = i + 1
    }
    返回 嫌疑
}

函数 AI内存钩子_统计() {
    返回 [总分配次数, 总释放次数, 分配速率EMA, 释放速率EMA,
           AI内存_碎片化风险(), 计数(调用者画像表)]
}


// 扩展AI内存钩子

定义 可变 钩子_已初始化 = 假
定义 可变 钩子_压力检测次数 = 0
定义 可变 钩子_泄漏检测次数 = 0
定义 可变 钩子_碎片检测次数 = 0
定义 可变 钩子_建议生成次数 = 0
定义 可变 钩子_错误数 = 0
定义 可变 钩子_延迟总计 = 0
定义 可变 钩子_延迟样本 = 0
定义 可变 钩子_最大延迟 = 0
定义 可变 钩子_速率 = 0
定义 可变 钩子_速率窗口 = 0
定义 可变 钩子_速率时刻 = 0
定义 可变 钩子_峰值速率 = 0

// AI内存压力预测(NIET定理应用)
定义 可变 压力_历史 = []
定义 压力_历史最大 = 64
定义 可变 压力_预测值 = 0
定义 可变 压力_预测命中 = 0
定义 可变 压力_预测总数 = 0

函数 AI内存_记录压力(压力值) {
    如果 (计数(压力_历史) >= 压力_历史最大) {
        // 移除最旧的
        定义 可变 新历史 = []
        定义 可变 i = 1
        当 (i < 计数(压力_历史)) {
            追加(新历史, 压力_历史[i])
            i = i + 1
        }
        压力_历史 = 新历史
    }
    追加(压力_历史, 压力值)
    钩子_压力检测次数 = 钩子_压力检测次数 + 1
    钩子_速率窗口 = 钩子_速率窗口 + 1
}

函数 AI内存_预测压力() {
    // 简单EMA预测
    如果 (计数(压力_历史) < 3) { 返回 0 }
    定义 n = 计数(压力_历史)
    定义 最近 = 压力_历史[n - 1]
    定义 前一 = 压力_历史[n - 2]
    定义 趋势 = 最近 - 前一
    压力_预测值 = 最近 + 趋势
    如果 (压力_预测值 < 0) { 压力_预测值 = 0 }
    如果 (压力_预测值 > 100) { 压力_预测值 = 100 }
    压力_预测总数 = 压力_预测总数 + 1
    返回 压力_预测值
}

函数 AI内存_验证预测(实际值) {
    如果 (压力_预测总数 == 0) { 返回 }
    定义 误差 = 压力_预测值 - 实际值
    如果 (误差 < 0) { 误差 = 0 - 误差 }
    如果 (误差 <= 10) { 压力_预测命中 = 压力_预测命中 + 1 }
}

函数 AI内存_预测准确率() {
    如果 (压力_预测总数 == 0) { 返回 0 }
    返回 压力_预测命中 * 100 / 压力_预测总数
}

// AI内存回收建议
函数 AI内存_回收建议() {
    钩子_建议生成次数 = 钩子_建议生成次数 + 1
    定义 碎片 = AI内存_碎片化风险()
    定义 泄漏嫌疑 = AI内存_泄漏嫌疑()
    定义 可变 建议 = ""
    如果 (碎片 > 70) { 建议 = 建议 + "碎片严重,建议内存压缩; " }
    如果 (碎片 > 40) { 建议 = 建议 + "碎片中等,建议后台整理; " }
    如果 (计数(泄漏嫌疑) > 0) { 建议 = 建议 + "检测到" + 转字符串(计数(泄漏嫌疑)) + "个泄漏嫌疑; " }
    如果 (分配速率EMA > 释放速率EMA * 2) { 建议 = 建议 + "分配速率远超释放,注意; " }
    如果 (建议 == "") { 建议 = "内存状态良好" }
    返回 建议
}

// AI延迟+速率
函数 钩子_记录延迟(延迟) {
    钩子_延迟样本 = 钩子_延迟样本 + 1
    钩子_延迟总计 = 钩子_延迟总计 + 延迟
    如果 (延迟 > 钩子_最大延迟) { 钩子_最大延迟 = 延迟 }
}

函数 钩子_平均延迟() {
    如果 (钩子_延迟样本 == 0) { 返回 0 }
    返回 钩子_延迟总计 / 钩子_延迟样本
}

函数 钩子_初始化() {
    如果 (钩子_已初始化 == 真) { 返回 0 - 17 }
    压力_历史 = []
    钩子_已初始化 = 真
    打印("[AI内存钩子] 初始化完成")
    返回 0
}

// 完整统计 (≥15个指标)
函数 AI内存钩子_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "已初始化", 钩子_已初始化)
    字典设(统计, "总分配次数", 总分配次数)
    字典设(统计, "总释放次数", 总释放次数)
    字典设(统计, "分配速率EMA", 分配速率EMA)
    字典设(统计, "释放速率EMA", 释放速率EMA)
    字典设(统计, "碎片化风险", AI内存_碎片化风险())
    字典设(统计, "调用者画像数", 计数(调用者画像表))
    字典设(统计, "泄漏嫌疑数", 计数(AI内存_泄漏嫌疑()))
    字典设(统计, "压力检测次数", 钩子_压力检测次数)
    字典设(统计, "泄漏检测次数", 钩子_泄漏检测次数)
    字典设(统计, "建议生成次数", 钩子_建议生成次数)
    字典设(统计, "预测准确率(%)", AI内存_预测准确率())
    字典设(统计, "平均延迟(ns)", 钩子_平均延迟())
    字典设(统计, "最大延迟(ns)", 钩子_最大延迟)
    字典设(统计, "速率", 钩子_速率)
    字典设(统计, "峰值速率", 钩子_峰值速率)
    字典设(统计, "错误数", 钩子_错误数)
    返回 统计
}

函数 AI内存钩子_打印统计() {
    定义 统计 = AI内存钩子_完整统计()
    打印("[AI内存钩子] ═══════ 完整统计 ═══════")
    打印("  总分配:       " + 转字符串(字典取(统计, "总分配次数")))
    打印("  总释放:       " + 转字符串(字典取(统计, "总释放次数")))
    打印("  分配速率EMA:  " + 转字符串(字典取(统计, "分配速率EMA")))
    打印("  释放速率EMA:  " + 转字符串(字典取(统计, "释放速率EMA")))
    打印("  碎片化风险:   " + 转字符串(字典取(统计, "碎片化风险")))
    打印("  调用者画像:   " + 转字符串(字典取(统计, "调用者画像数")))
    打印("  泄漏嫌疑:     " + 转字符串(字典取(统计, "泄漏嫌疑数")))
    打印("  压力检测:     " + 转字符串(字典取(统计, "压力检测次数")))
    打印("  建议生成:     " + 转字符串(字典取(统计, "建议生成次数")))
    打印("  预测准确率:   " + 转字符串(字典取(统计, "预测准确率(%)")) + "%")
    打印("  平均延迟:     " + 转字符串(字典取(统计, "平均延迟(ns)")) + "ns")
    打印("  速率:         " + 转字符串(字典取(统计, "速率")) + " 次/秒")
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    // 回收建议
    打印("  AI建议:       " + AI内存_回收建议())
    打印("[AI内存钩子] ═════════════════════════")
    返回 0
}

函数 AI内存钩子_dump() {
    打印("[AI内存钩子 dump] ──────────────────")
    打印("  分配: " + 转字符串(总分配次数))
    打印("  释放: " + 转字符串(总释放次数))
    打印("  碎片: " + 转字符串(AI内存_碎片化风险()))
    打印("  泄漏嫌疑: " + 转字符串(计数(AI内存_泄漏嫌疑())))
    打印("  预测准确率: " + 转字符串(AI内存_预测准确率()) + "%")
    打印("  AI建议: " + AI内存_回收建议())
    打印("[AI内存钩子 dump] ──────────────────")
}

函数 AI内存钩子_销毁() {
    压力_历史 = []
    调用者画像表 = []
    钩子_已初始化 = 假
    打印("[AI内存钩子] 已销毁")
    返回 0
}

函数 AI内存钩子_为回收策略提供压力() {
    返回 [AI内存_碎片化风险(), AI内存_预测压力(), 分配速率EMA, 释放速率EMA]
}

函数 AI内存钩子_为调度器提供内存负载() {
    返回 [总分配次数, 总释放次数, 分配速率EMA, 钩子_速率]
}

函数 AI内存钩子_为OOM提供泄漏信息() {
    返回 [计数(AI内存_泄漏嫌疑()), AI内存_碎片化风险()]
}

函数 AI内存钩子_为procfs提供统计() {
    返回 [总分配次数, 总释放次数, 分配速率EMA, 释放速率EMA, AI内存_碎片化风险(), 计数(调用者画像表), AI内存_预测准确率()]
}

函数 AI内存钩子_重置统计() {
    总分配次数 = 0
    总释放次数 = 0
    钩子_压力检测次数 = 0
    钩子_泄漏检测次数 = 0
    钩子_建议生成次数 = 0
    钩子_错误数 = 0
    钩子_延迟总计 = 0
    钩子_延迟样本 = 0
    钩子_最大延迟 = 0
    钩子_速率 = 0
    钩子_速率窗口 = 0
    钩子_峰值速率 = 0
    压力_预测命中 = 0
    压力_预测总数 = 0
    压力_历史 = []
    打印("[AI内存钩子] 统计已重置")
    返回 0
}

函数 AI内存钩子_为电源管理挂起() {
    // 挂起前保存AI内存分析状态, 清空当前窗口统计
    定义 可变 已保存 = 0
    如果 (AI_内存_分析窗口 != 空) {
        已保存 = 计数(AI_内存_分析窗口)
    }
    返回 已保存
}

函数 AI内存钩子_为内存初始化提供分配速率() {
    返回 [分配速率EMA, 释放速率EMA, 总分配次数, 总释放次数]
}

函数 AI内存钩子_获取净分配() {
    返回 总分配次数 - 总释放次数
}

函数 AI内存钩子_获取分配释放比() {
    如果 (总释放次数 == 0) { 返回 0 }
    返回 总分配次数 * 100 / 总释放次数
}

函数 AI内存钩子_为伙伴系统提供分配趋势() {
    返回 [分配速率EMA, 释放速率EMA, AI内存_碎片化风险()]
}

函数 AI内存钩子_为缓存管理提供压力() {
    返回 [AI内存_预测压力(), AI内存_碎片化风险(), 分配速率EMA]
}

函数 AI内存钩子_获取调用者画像前N(前N) {
    定义 可变 结果 = []
    定义 可变 n = 0
    当 (n < 前N && n < 计数(调用者画像表)) {
        追加(结果, 调用者画像表[n])
        n = n + 1
    }
    返回 结果
}

函数 AI内存钩子_获取压力历史() {
    返回 压力_历史
}

函数 AI内存钩子_获取压力趋势() {
    如果 (计数(压力_历史) < 2) { 返回 0 }
    定义 n = 计数(压力_历史)
    返回 压力_历史[n - 1] - 压力_历史[n - 2]
}

函数 AI内存钩子_为页面回收提供紧急度() {
    定义 趋势 = AI内存钩子_获取压力趋势()
    定义 当前 = AI内存_预测压力()
    如果 (当前 > 80 && 趋势 > 0) { 返回 3 }
    如果 (当前 > 60) { 返回 2 }
    如果 (当前 > 40) { 返回 1 }
    返回 0
}

函数 AI内存钩子_为块分配器提供热度() {
    返回 [分配速率EMA, 总分配次数, AI内存_碎片化风险()]
}

函数 AI内存钩子_获取碎片等级名() {
    定义 风险 = AI内存_碎片化风险()
    如果 (风险 > 70) { 返回 "严重碎片" }
    如果 (风险 > 40) { 返回 "中等碎片" }
    如果 (风险 > 10) { 返回 "轻微碎片" }
    返回 "无碎片"
}

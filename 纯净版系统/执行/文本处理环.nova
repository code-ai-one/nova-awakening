导入("../中枢/自动扩容.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../引导/端口输入.nova")
导入("../中枢/内核打印.nova")
导入("./平台时间.nova")
// 龙壳 — 环境变量 — 深度吸收bash variables.c
// 核心设计(来自bash):
//   1. 环境变量分两类: 终端变量(局部) + 导出变量(传递给子进程)
//   2. envp数组: execve传递的 KEY=VALUE 字符串数组
//   3. 特殊变量: HOME, PATH, PWD, OLDPWD, 终端, USER, TERM, LANG
//   4. 自动变量: $?, $!, $$, $0, $#, $*, $@
//   5. PS1/PS2: 提示符格式(支持转义: \u, \h, \w, \$)

定义 可变 环境表 = 字典()        // 所有终端变量
定义 可变 导出集 = 字典()        // 标记为导出的变量名集合
定义 可变 只读集 = 字典()        // 只读变量名集合

// 初始化 

函数 环境_初始化() {
    // 核心环境变量
    环境_设置("HOME", "/root")
    环境_设置("PWD", "/")
    环境_设置("OLDPWD", "/")
    环境_设置("USER", "root")
    环境_设置("LOGNAME", "root")
    环境_设置("PATH", "/bin:/usr/bin:/sbin:/usr/sbin:/usr/local/bin")
    环境_设置("终端", "/bin/龙壳")
    环境_设置("TERM", "linux")
    环境_设置("LANG", "zh_CN.UTF-8")
    环境_设置("LC_ALL", "")

    // 终端配置
    环境_设置("PS1", "\\u@\\h:\\w\\$ ")
    环境_设置("PS2", "> ")
    环境_设置("PS4", "+ ")
    环境_设置("IFS", " \t\n")
    环境_设置("HISTSIZE", "1000")
    环境_设置("HISTFILE", "/root/.龙壳_history")

    // NovaOS特有
    环境_设置("NOVAOS_VERSION", "1.0.0-M1")
    环境_设置("HOSTNAME", "novaos")
    环境_设置("EDITOR", "vi")
    环境_设置("PAGER", "less")

    // 标记核心变量为导出
    环境_标记导出("HOME")
    环境_标记导出("PATH")
    环境_标记导出("USER")
    环境_标记导出("LOGNAME")
    环境_标记导出("终端")
    环境_标记导出("TERM")
    环境_标记导出("LANG")
    环境_标记导出("PWD")
    环境_标记导出("HOSTNAME")
}

// 获取/设置/删除

函数 环境_获取(键) {
    返回 字典_取或默认(环境表, 键, "")
}

函数 环境_设置(键, 值) {
    // 检查只读
    如果 (字典_取或默认(只读集, 键, 空) != 空) {
        打印行("龙壳: " + 键 + ": readonly variable")
        返回
    }
    字典设(环境表, 键, 值)
}

函数 环境_删除(键) {
    如果 (字典_取或默认(只读集, 键, 空) != 空) {
        打印行("龙壳: " + 键 + ": readonly variable")
        返回
    }
    字典设(环境表, 键, 空)
    字典设(导出集, 键, 空)
}

函数 环境_存在(键) {
    返回 字典_取或默认(环境表, 键, 空) != 空
}

// 导出管理

函数 环境_标记导出(键) {
    字典设(导出集, 键, "1")
}

函数 环境_是导出(键) {
    返回 字典_取或默认(导出集, 键, 空) != 空
}

// 生成envp数组(用于execve)
函数 环境_导出() {
    定义 可变 结果 = []
    字典_遍历(导出集, 函数(键, _值) {
        定义 变量值 = 环境_获取(键)
        如果 (变量值 != "") {
            追加(结果, 键 + "=" + 变量值)
        }
    })
    返回 结果
}

// 从envp数组导入(fork子进程继承)
函数 环境_从envp导入(envp) {
    如果 (envp == 空) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(envp)) {
        定义 等号位 = 字符串索引(envp[i], "=")
        如果 (等号位 > 0) {
            定义 键 = 字符串子串(envp[i], 0, 等号位)
            定义 值 = 字符串子串(envp[i], 等号位 + 1, 字符串长度(envp[i]))
            环境_设置(键, 值)
            环境_标记导出(键)
        }
        i = i + 1
    }
}

// 只读管理

函数 环境_设为只读(键) {
    字典设(只读集, 键, "1")
}

函数 环境_是只读(键) {
    返回 字典_取或默认(只读集, 键, 空) != 空
}

// 显示

函数 环境_显示全部() {
    字典_遍历(环境表, 函数(键, 值) {
        如果 (值 != 空) {
            定义 前缀 = ""
            如果 (环境_是导出(键)) { 前缀 = "declare -x " }
            打印行(前缀 + 键 + "=\"" + 值 + "\"")
        }
    })
}

函数 环境_显示导出() {
    字典_遍历(导出集, 函数(键, _) {
        定义 值 = 环境_获取(键)
        如果 (值 != "") {
            打印行("declare -x " + 键 + "=\"" + 值 + "\"")
        }
    })
}

函数 历史_初始化() {
    定义 路径 = 环境_获取("HISTFILE")
    如果 (路径 == 空 || 路径 == "") { 路径 = 环境_获取("HOME") + "/.nova_history" }
    定义 fd = 系统调用(2, 路径, 0)  // O_RDONLY
    如果 (fd < 0) { 返回 }
    定义 buf = 分配(4096)
    定义 可变 行 = ""
    循环 {
        定义 读 = 系统调用(0, fd, buf, 4096)
        如果 (读 <= 0) { 跳出 }
        定义 可变 i = 0
        当 (i < 读) {
            定义 ch = 内存读8(buf + i)
            如果 (ch == 10) {
                如果 (字符串长度(行) > 0) { 追加(历史列表, 行); 历史_计数 = 历史_计数 + 1 }
                行 = ""
            } 否则 { 行 = 行 + 字符(ch) }
            i = i + 1
        }
    }
    如果 (字符串长度(行) > 0) { 追加(历史列表, 行); 历史_计数 = 历史_计数 + 1 }
    释放(buf)
    系统调用(3, fd)
}

函数 历史_清除() {
    历史列表 = []
    历史_计数 = 0
}

定义 可变 AI_文本处理环_调用数 = 0
定义 可变 AI_文本处理环_异常数 = 0

函数 AI_文本处理环_监控() {
    AI_文本处理环_调用数 = AI_文本处理环_调用数 + 1
    返回 AI_文本处理环_异常数 == 0
}

函数 AI_文本处理环_健康检查() {
    如果 (AI_文本处理环_调用数 > 0 && AI_文本处理环_异常数 * 100 / AI_文本处理环_调用数 > 10) {
        返回 假
    }
    返回 真
}

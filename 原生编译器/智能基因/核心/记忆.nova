// Nova 原生 · 智能基因层 · 记忆系统原语
// 设计理念：仿生人脑的三层记忆 — 瞬时感觉、工作记忆、长期记忆
// 记忆是智能积累经验、举一反三、学以致用的基础

// 记忆类型

导入("../../标准库/基础.nova")

定义 记忆_瞬时   = 1    // 瞬时感觉记忆（毫秒级，极短暂）
定义 记忆_工作   = 2    // 工作记忆（秒到分钟，当前任务缓冲区）
定义 记忆_情景   = 3    // 情景记忆（经历过的具体事件）
定义 记忆_语义   = 4    // 语义记忆（概念、规则、事实）
定义 记忆_程序   = 5    // 程序记忆（技能、习惯、操作步骤）
定义 记忆_联想   = 6    // 联想记忆（相关事物的链接）

// 记忆条目：[类型, 内容, 重要性, 激活次数, 最近访问时间, 关联标签]
函数 记忆_创建(类型, 内容, 重要性) {
    返回 [类型, 内容, 重要性, 1, 0, []]
}

函数 记忆_类型(条目)     { 返回 条目[0] }
函数 记忆_内容(条目)     { 返回 条目[1] }
函数 记忆_重要性(条目)   { 返回 条目[2] }
函数 记忆_激活数(条目)   { 返回 条目[3] }
函数 记忆_访问时间(条目) { 返回 条目[4] }
函数 记忆_标签(条目)     { 返回 条目[5] }

函数 记忆_激活(条目, 当前时间) {
    条目[3] = 条目[3] + 1
    条目[4] = 当前时间
}

函数 记忆_添加标签(条目, 标签) {
    追加(条目[5], 标签)
}

// 工作记忆：当前任务的临时缓冲区
函数 记忆_工作记忆_创建(容量) {
    返回 [[], 容量, 0]
}

函数 记忆_工作记忆_写入(缓冲区, 内容, 重要性) {
    如果 (计数(缓冲区[0]) >= 缓冲区[1]) {
        工作记忆_淘汰最旧(缓冲区)
    }
    追加(缓冲区[0], 记忆_创建(记忆_工作, 内容, 重要性))
}

函数 工作记忆_淘汰最旧(缓冲区) {
    如果 (计数(缓冲区[0]) == 0) { 返回 空 }
    定义 可变 最低重要性 = 9999999
    定义 可变 最低索引 = 0
    定义 可变 i = 0
    当 (i < 计数(缓冲区[0])) {
        如果 (记忆_重要性(缓冲区[0][i]) < 最低重要性) {
            最低重要性 = 记忆_重要性(缓冲区[0][i])
            最低索引 = i
        }
        i = i + 1
    }
    删除(缓冲区[0], 最低索引)
}

函数 工作记忆_读取全部(缓冲区) {
    返回 缓冲区[0]
}

函数 工作记忆_按标签查找(缓冲区, 标签) {
    定义 可变 结果列表 = []
    定义 可变 i = 0
    当 (i < 计数(缓冲区[0])) {
        定义 条目标签 = 记忆_标签(缓冲区[0][i])
        定义 可变 j = 0
        当 (j < 计数(条目标签)) {
            如果 (条目标签[j] == 标签) {
                追加(结果列表, 缓冲区[0][i])
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 结果列表
}

// 长期记忆：持久化的知识和经验库
函数 长期记忆_创建() {
    返回 [字典(), [], 字典()]
}

函数 长期记忆_存储(库, 键, 内容, 类型, 重要性) {
    定义 条目 = 记忆_创建(类型, 内容, 重要性)
    字典设(库[0], 键, 条目)
    追加(库[1], 键)
}

函数 长期记忆_提取(库, 键) {
    如果 (字典有(库[0], 键)) {
        定义 条目 = 字典取(库[0], 键)
        记忆_激活(条目, 0)
        返回 条目
    }
    返回 空
}

函数 长期记忆_联想检索(库, 标签列表) {
    定义 可变 结果列表 = []
    定义 所有键 = 字典键(库[0])
    定义 可变 i = 0
    当 (i < 计数(所有键)) {
        定义 条目 = 字典取(库[0], 所有键[i])
        定义 条目标签 = 记忆_标签(条目)
        定义 可变 匹配数 = 0
        定义 可变 j = 0
        当 (j < 计数(标签列表)) {
            定义 可变 k = 0
            当 (k < 计数(条目标签)) {
                如果 (条目标签[k] == 标签列表[j]) {
                    匹配数 = 匹配数 + 1
                }
                k = k + 1
            }
            j = j + 1
        }
        如果 (匹配数 > 0) {
            追加(结果列表, [条目, 匹配数])
        }
        i = i + 1
    }
    返回 结果列表
}

// 遗忘曲线：重要性 × 激活频率决定保留强度
函数 记忆_计算保留强度(条目, 当前时间) {
    定义 时间差 = 当前时间 - 记忆_访问时间(条目)
    定义 基础强度 = 记忆_重要性(条目) * 记忆_激活数(条目)
    如果 (时间差 <= 0) { 返回 基础强度 }
    返回 基础强度 / (时间差 + 1)
}

// 经验凝固：工作记忆→长期记忆的固化过程
函数 记忆_凝固经验(工作缓冲区, 长期库, 强度阈值) {
    定义 可变 已凝固 = 0
    定义 可变 i = 0
    当 (i < 计数(工作缓冲区[0])) {
        定义 条目 = 工作缓冲区[0][i]
        如果 (记忆_重要性(条目) >= 强度阈值) {
            定义 键 = "经验_" + 转字符串(已凝固) + "_" + 转字符串(i)
            长期记忆_存储(长期库, 键, 记忆_内容(条目), 记忆_类型(条目), 记忆_重要性(条目))
            已凝固 = 已凝固 + 1
        }
        i = i + 1
    }
    返回 已凝固
}

定义 可变 _记忆_写入总数 = 0
定义 可变 _记忆_提取总数 = 0
定义 可变 _记忆_遗忘总数 = 0

函数 记忆_记录写入() { _记忆_写入总数 = _记忆_写入总数 + 1 }
函数 记忆_记录提取() { _记忆_提取总数 = _记忆_提取总数 + 1 }

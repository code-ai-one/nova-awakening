// NovaOS 位图与字体 — 像素容器 + 字体度量 + 绘制基础
// 技术: SkBitmap + SkFont + SkPaint (Skia核心)
// 核心: 位图创建/销毁/像素操作, 字体管理, 文本测量, 颜色空间转换
// 定点数: 字号×100, 坐标×100
// NovaOS创新: AI字体缓存预测 + 智能位图压缩 + 内存池位图分配

导入("../稳态/图处显示.nova")
导入("../推理/通信总线.nova")
导入("./内核直连层.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内存初始化.nova")
导入("../执行/底层内存操.nova")


定义 像素格式_RGBA8888  = 0     // 每像素4字节 RGBA
定义 像素格式_BGRA8888  = 1     // 每像素4字节 BGRA
定义 像素格式_RGB565    = 2     // 每像素2字节
定义 像素格式_Alpha8    = 3     // 每像素1字节(遮罩)
定义 像素格式_Gray8     = 4     // 每像素1字节(灰度)
定义 像素格式_RGBA_F16  = 5     // 每像素8字节(HDR)

定义 位图_最大宽度      = 16384
定义 位图_最大高度      = 16384
定义 位图_对齐字节      = 4     // 行字节数4字节对齐

// 颜色常量(ARGB)
定义 颜色_透明   = 0x00000000
定义 颜色_黑色   = 0xFF000000
定义 颜色_白色   = 0xFFFFFFFF
定义 颜色_红色   = 0xFFFF0000
定义 颜色_绿色   = 0xFF00FF00
定义 颜色_蓝色   = 0xFF0000FF

// 字体粗细常量
定义 字体粗细_细     = 100
定义 字体粗细_超轻   = 200
定义 字体粗细_轻     = 300
定义 字体粗细_正常   = 400
定义 字体粗细_中等   = 500
定义 字体粗细_半粗   = 600
定义 字体粗细_粗     = 700
定义 字体粗细_超粗   = 800
定义 字体粗细_黑     = 900

// 文本对齐
定义 文本对齐_左     = 0
定义 文本对齐_居中   = 1
定义 文本对齐_右     = 2


结构 Nova位图 {
    像素数据,          // u64 像素缓冲区指针
    宽,                // i32 像素宽度
    高,                // i32 像素高度
    行字节数,          // i32 rowBytes (对齐后的行宽)
    像素格式,          // u32 像素格式_xxx
    每像素字节,        // u32 bytes per pixel
    引用计数,          // u32 引用计数(共享位图)
    不可变,            // u32 bool: 是否只读
    // 颜色空间信息
    颜色空间,          // u32 0=sRGB 1=Linear 2=P3
    预乘Alpha,         // u32 bool: 是否已预乘Alpha
    // 内存管理
    拥有像素,          // u32 bool: 是否拥有像素内存(需释放)
    像素大小,          // u64 像素数据总字节数
    // 统计
    统计_读取次数,
    统计_写入次数,
}



函数 Nova位图_创建(宽, 高, 格式) {
    如果 (宽 <= 0 || 高 <= 0) {
        打印("[位图] 错误: 无效尺寸")
        返回 空
    }
    如果 (宽 > 位图_最大宽度 || 高 > 位图_最大高度) {
        打印("[位图] 错误: 尺寸超过上限")
        返回 空
    }

    定义 可变 bm = 堆_分配(Nova位图)
    如果 (bm == 0) {
        打印("[位图] 错误: 结构分配失败")
        返回 空
    }

    bm.宽 = 宽
    bm.高 = 高
    bm.像素格式 = 格式
    bm.引用计数 = 1
    bm.不可变 = 假
    bm.颜色空间 = 0
    bm.预乘Alpha = 假
    bm.统计_读取次数 = 0
    bm.统计_写入次数 = 0

    // 计算每像素字节数
    如果 (格式 == 像素格式_RGBA8888 || 格式 == 像素格式_BGRA8888) {
        bm.每像素字节 = 4
    } 否则 如果 (格式 == 像素格式_RGB565) {
        bm.每像素字节 = 2
    } 否则 如果 (格式 == 像素格式_RGBA_F16) {
        bm.每像素字节 = 8
    } 否则 {
        bm.每像素字节 = 1
    }

    // 计算行字节数(4字节对齐)
    bm.行字节数 = 宽 * bm.每像素字节
    如果 (bm.行字节数 % 位图_对齐字节 != 0) {
        bm.行字节数 = bm.行字节数 + (位图_对齐字节 - bm.行字节数 % 位图_对齐字节)
    }

    // 分配像素数据
    bm.像素大小 = bm.行字节数 * 高
    bm.像素数据 = 平台_申请内存(bm.像素大小)
    如果 (bm.像素数据 == 0) {
        打印("[位图] 错误: 像素内存分配失败")
        堆_释放(bm)
        返回 空
    }
    内存_清零(bm.像素数据, bm.像素大小)
    bm.拥有像素 = 真

    返回 bm
}

函数 Nova位图_从外部像素(宽, 高, 格式, 像素指针, 行字节数) {
    如果 (宽 <= 0 || 高 <= 0 || 像素指针 == 0) { 返回 空 }

    定义 可变 bm = 堆_分配(Nova位图)
    如果 (bm == 0) { 返回 空 }

    bm.宽 = 宽
    bm.高 = 高
    bm.像素格式 = 格式
    bm.像素数据 = 像素指针
    bm.行字节数 = 行字节数
    bm.引用计数 = 1
    bm.不可变 = 假
    bm.拥有像素 = 假    // 不拥有, 不释放
    bm.颜色空间 = 0
    bm.预乘Alpha = 假
    bm.统计_读取次数 = 0
    bm.统计_写入次数 = 0

    如果 (格式 == 像素格式_RGBA8888 || 格式 == 像素格式_BGRA8888) {
        bm.每像素字节 = 4
    } 否则 如果 (格式 == 像素格式_RGB565) {
        bm.每像素字节 = 2
    } 否则 {
        bm.每像素字节 = 1
    }
    bm.像素大小 = 行字节数 * 高

    返回 bm
}

函数 Nova位图_增引用(bm) {
    如果 (bm == 空) { 返回 }
    bm.引用计数 = bm.引用计数 + 1
}

函数 Nova位图_减引用(bm) {
    如果 (bm == 空) { 返回 }
    bm.引用计数 = bm.引用计数 - 1
    如果 (bm.引用计数 <= 0) {
        Nova位图_销毁(bm)
    }
}

函数 Nova位图_销毁(bm) {
    如果 (bm == 空) { 返回 }
    如果 (bm.拥有像素 == 真 && bm.像素数据 != 0) {
        平台_释放内存(bm.像素数据, bm.像素大小)
    }
    堆_释放(bm)
}


函数 Nova位图_获取像素(bm, x, y) {
    如果 (bm == 空) { 返回 0 }
    如果 (x < 0 || x >= bm.宽 || y < 0 || y >= bm.高) { 返回 0 }
    bm.统计_读取次数 = bm.统计_读取次数 + 1
    定义 偏移 = y * bm.行字节数 + x * bm.每像素字节
    如果 (bm.每像素字节 == 4) {
        返回 内存_读32(bm.像素数据 + 偏移)
    } 否则 如果 (bm.每像素字节 == 2) {
        // RGB565 → RGBA8888
        定义 值 = 内存_读16(bm.像素数据 + 偏移)
        定义 r = ((值 >> 11) & 31) * 255 / 31
        定义 g = ((值 >> 5) & 63) * 255 / 63
        定义 b = (值 & 31) * 255 / 31
        返回 (255 << 24) | (r << 16) | (g << 8) | b
    } 否则 {
        // Alpha8/Gray8
        定义 值 = 内存_读8(bm.像素数据 + 偏移)
        返回 (值 << 24) | (值 << 16) | (值 << 8) | 值
    }
}

函数 Nova位图_设置像素(bm, x, y, 颜色) {
    如果 (bm == 空 || bm.不可变 == 真) { 返回 }
    如果 (x < 0 || x >= bm.宽 || y < 0 || y >= bm.高) { 返回 }
    bm.统计_写入次数 = bm.统计_写入次数 + 1
    定义 偏移 = y * bm.行字节数 + x * bm.每像素字节
    如果 (bm.每像素字节 == 4) {
        内存_写32(bm.像素数据 + 偏移, 颜色)
    } 否则 如果 (bm.每像素字节 == 2) {
        // RGBA8888 → RGB565
        定义 r = (颜色 >> 16) & 255
        定义 g = (颜色 >> 8) & 255
        定义 b = 颜色 & 255
        定义 值 = ((r >> 3) << 11) | ((g >> 2) << 5) | (b >> 3)
        内存_写16(bm.像素数据 + 偏移, 值)
    } 否则 {
        内存_写8(bm.像素数据 + 偏移, (颜色 >> 24) & 255)
    }
}

函数 Nova位图_安全混合像素(bm, x, y, 颜色) {
    如果 (bm == 空 || bm.不可变 == 真) { 返回 }
    如果 (x < 0 || x >= bm.宽 || y < 0 || y >= bm.高) { 返回 }
    定义 srcA = (颜色 >> 24) & 255
    如果 (srcA == 255) {
        Nova位图_设置像素(bm, x, y, 颜色)
        返回
    }
    如果 (srcA == 0) { 返回 }
    // Porter-Duff SrcOver
    定义 dst = Nova位图_获取像素(bm, x, y)
    定义 invA = 255 - srcA
    定义 outR = ((颜色 >> 16) & 255) + (((dst >> 16) & 255) * invA) / 255
    定义 outG = ((颜色 >> 8) & 255) + (((dst >> 8) & 255) * invA) / 255
    定义 outB = (颜色 & 255) + ((dst & 255) * invA) / 255
    定义 outA = srcA + (((dst >> 24) & 255) * invA) / 255
    Nova位图_设置像素(bm, x, y, (outA << 24) | (outR << 16) | (outG << 8) | outB)
}


函数 Nova位图_清除(bm, 颜色) {
    如果 (bm == 空 || bm.不可变 == 真) { 返回 }
    如果 (bm.每像素字节 == 4) {
        // 快速路径: 4字节填充
        定义 可变 偏移 = 0
        当 (偏移 < bm.像素大小) {
            内存_写32(bm.像素数据 + 偏移, 颜色)
            偏移 = 偏移 + 4
        }
    } 否则 {
        // 通用路径
        定义 可变 y = 0
        当 (y < bm.高) {
            定义 可变 x = 0
            当 (x < bm.宽) {
                Nova位图_设置像素(bm, x, y, 颜色)
                x = x + 1
            }
            y = y + 1
        }
    }
}

函数 Nova位图_复制行(bm, 目标y, 源y) {
    如果 (bm == 空 || bm.不可变 == 真) { 返回 }
    如果 (目标y < 0 || 目标y >= bm.高 || 源y < 0 || 源y >= bm.高) { 返回 }
    如果 (目标y == 源y) { 返回 }
    定义 源偏移 = 源y * bm.行字节数
    定义 目标偏移 = 目标y * bm.行字节数
    内存_复制(bm.像素数据 + 目标偏移, bm.像素数据 + 源偏移, bm.宽 * bm.每像素字节)
}

函数 Nova位图_填充矩形(bm, 左, 上, 右, 下, 颜色) {
    如果 (bm == 空 || bm.不可变 == 真) { 返回 }
    // 裁剪
    定义 可变 x起 = 左
    定义 可变 y起 = 上
    定义 可变 x止 = 右
    定义 可变 y止 = 下
    如果 (x起 < 0) { x起 = 0 }
    如果 (y起 < 0) { y起 = 0 }
    如果 (x止 > bm.宽) { x止 = bm.宽 }
    如果 (y止 > bm.高) { y止 = bm.高 }
    如果 (x起 >= x止 || y起 >= y止) { 返回 }

    定义 srcA = (颜色 >> 24) & 255
    定义 可变 y = y起
    当 (y < y止) {
        定义 行基址 = bm.像素数据 + y * bm.行字节数
        定义 可变 x = x起
        当 (x < x止) {
            如果 (srcA == 255) {
                内存_写32(行基址 + x * bm.每像素字节, 颜色)
            } 否则 如果 (srcA > 0) {
                Nova位图_安全混合像素(bm, x, y, 颜色)
            }
            x = x + 1
        }
        y = y + 1
    }
}

函数 Nova位图_复制到(源, 目标, 目标x, 目标y) {
    如果 (源 == 空 || 目标 == 空 || 目标.不可变 == 真) { 返回 }
    定义 可变 y = 0
    当 (y < 源.高) {
        定义 dy = 目标y + y
        如果 (dy < 0) { y = y + 1; 继续 }
        如果 (dy >= 目标.高) { 跳出 }
        定义 可变 x = 0
        当 (x < 源.宽) {
            定义 dx = 目标x + x
            如果 (dx >= 0 && dx < 目标.宽) {
                定义 颜色 = Nova位图_获取像素(源, x, y)
                Nova位图_安全混合像素(目标, dx, dy, 颜色)
            }
            x = x + 1
        }
        y = y + 1
    }
}


结构 Sk字体 {
    字体族,            // u64 字体族名称字符串
    大小,              // i32 字号 ×100
    粗细,              // i32 100-900
    斜体,              // u32 bool
    抗锯齿,            // u32 bool
    亚像素,            // u32 bool: subpixel rendering
    行距,              // i32 行间距 ×100
    上升,              // i32 ascent ×100 (基线到顶部)
    下降,              // i32 descent ×100 (基线到底部)
    行间距,            // i32 leading ×100
    下划线偏移,        // i32 ×100
    下划线粗细,        // i32 ×100
    删除线偏移,        // i32 ×100
}

函数 Sk字体_创建(字体族, 大小) {
    如果 (大小 <= 0) { 大小 = 1600 }  // 默认16pt

    定义 可变 f = 堆_分配(Sk字体)
    如果 (f == 0) { 返回 空 }

    f.字体族 = 字体族
    f.大小 = 大小
    f.粗细 = 字体粗细_正常
    f.斜体 = 假
    f.抗锯齿 = 真
    f.亚像素 = 真
    // 度量(基于字号的经验值)
    f.行距 = 大小 * 120 / 100      // 1.2× 行距
    f.上升 = 大小 * 80 / 100       // 0.8× 上升
    f.下降 = 大小 * 20 / 100       // 0.2× 下降
    f.行间距 = 大小 * 10 / 100     // 0.1× 行间距
    f.下划线偏移 = 大小 * 15 / 100
    f.下划线粗细 = 大小 * 7 / 100
    f.删除线偏移 = 大小 * 40 / 100
    返回 f
}

函数 Sk字体_销毁(f) {
    如果 (f == 空) { 返回 }
    堆_释放(f)
}

函数 Sk字体_设置粗细(f, 粗细) {
    如果 (f == 空) { 返回 }
    如果 (粗细 < 100) { 粗细 = 100 }
    如果 (粗细 > 900) { 粗细 = 900 }
    f.粗细 = 粗细
}

函数 Sk字体_设置斜体(f, 斜体) {
    如果 (f == 空) { 返回 }
    f.斜体 = 斜体
}

函数 Sk字体_设置大小(f, 大小) {
    如果 (f == 空 || 大小 <= 0) { 返回 }
    f.大小 = 大小
    // 更新度量
    f.行距 = 大小 * 120 / 100
    f.上升 = 大小 * 80 / 100
    f.下降 = 大小 * 20 / 100
    f.行间距 = 大小 * 10 / 100
    f.下划线偏移 = 大小 * 15 / 100
    f.下划线粗细 = 大小 * 7 / 100
    f.删除线偏移 = 大小 * 40 / 100
}


函数 Sk字体_测量文本宽度(font, 文本, 长度) {
    如果 (font == 空 || 文本 == 0 || 长度 <= 0) { 返回 0 }
    // UTF-8感知的文本宽度测量
    定义 可变 宽度 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 内存_读8(文本 + i)
        如果 (c == 0) { 跳出 }
        如果 (c > 0x7F) {
            // 多字节(CJK等): 约1.0× 字号
            宽度 = 宽度 + font.大小
            // 跳过UTF-8后续字节
            如果 (c >= 0xF0) { i = i + 3 }
            否则 如果 (c >= 0xE0) { i = i + 2 }
            否则 如果 (c >= 0xC0) { i = i + 1 }
        } 否则 {
            // ASCII字符宽度查表(简化)
            如果 (c == 32) {
                // 空格: 约0.25× 字号
                宽度 = 宽度 + font.大小 * 25 / 100
            } 否则 如果 (c >= 48 && c <= 57) {
                // 数字: 约0.6× 字号
                宽度 = 宽度 + font.大小 * 60 / 100
            } 否则 如果 (c == 105 || c == 108 || c == 49) {
                // i, l, 1: 窄字符约0.3× 字号
                宽度 = 宽度 + font.大小 * 30 / 100
            } 否则 如果 (c == 109 || c == 119) {
                // m, w: 宽字符约0.9× 字号
                宽度 = 宽度 + font.大小 * 90 / 100
            } 否则 {
                // 其他ASCII: 约0.55× 字号
                宽度 = 宽度 + font.大小 * 55 / 100
            }
        }
        i = i + 1
    }
    返回 宽度
}

函数 Sk字体_测量文本高度(font) {
    如果 (font == 空) { 返回 0 }
    返回 font.上升 + font.下降 + font.行间距
}

函数 Sk字体_获取行高(font) {
    如果 (font == 空) { 返回 0 }
    返回 font.行距
}

函数 Sk字体_计算文本行数(font, 文本, 长度, 最大宽度) {
    如果 (font == 空 || 文本 == 0 || 最大宽度 <= 0) { 返回 1 }
    定义 总宽度 = Sk字体_测量文本宽度(font, 文本, 长度)
    如果 (总宽度 <= 最大宽度) { 返回 1 }
    返回 (总宽度 + 最大宽度 - 1) / 最大宽度
}


函数 颜色_提取A(颜色) { 返回 (颜色 >> 24) & 255 }
函数 颜色_提取R(颜色) { 返回 (颜色 >> 16) & 255 }
函数 颜色_提取G(颜色) { 返回 (颜色 >> 8) & 255 }
函数 颜色_提取B(颜色) { 返回 颜色 & 255 }

函数 颜色_创建(a, r, g, b) {
    返回 ((a & 255) << 24) | ((r & 255) << 16) | ((g & 255) << 8) | (b & 255)
}

函数 颜色_从RGB(r, g, b) {
    返回 颜色_创建(255, r, g, b)
}

函数 颜色_设置透明度(颜色, alpha) {
    返回 (颜色 & 0x00FFFFFF) | ((alpha & 255) << 24)
}

函数 颜色_亮度(颜色) {
    // 感知亮度: 0.299R + 0.587G + 0.114B (×1000)
    定义 r = 颜色_提取R(颜色)
    定义 g = 颜色_提取G(颜色)
    定义 b = 颜色_提取B(颜色)
    返回 r * 299 + g * 587 + b * 114
}

函数 颜色_混合(c1, c2, 比例) {
    // 比例: 0-256 (0=完全c1, 256=完全c2)
    定义 inv = 256 - 比例
    定义 a = (颜色_提取A(c1) * inv + 颜色_提取A(c2) * 比例) / 256
    定义 r = (颜色_提取R(c1) * inv + 颜色_提取R(c2) * 比例) / 256
    定义 g = (颜色_提取G(c1) * inv + 颜色_提取G(c2) * 比例) / 256
    定义 b = (颜色_提取B(c1) * inv + 颜色_提取B(c2) * 比例) / 256
    返回 颜色_创建(a, r, g, b)
}

函数 颜色_反色(颜色) {
    返回 颜色_创建(颜色_提取A(颜色), 255 - 颜色_提取R(颜色), 255 - 颜色_提取G(颜色), 255 - 颜色_提取B(颜色))
}

函数 颜色_灰度化(颜色) {
    定义 灰 = 颜色_亮度(颜色) / 1000
    返回 颜色_创建(颜色_提取A(颜色), 灰, 灰, 灰)
}


函数 Nova位图_AI推荐格式(宽, 高, 有透明, 是图标) {
    // 根据用途推荐最佳像素格式
    如果 (是图标 == 真 && 宽 <= 48 && 高 <= 48) {
        返回 像素格式_RGBA8888    // 小图标用RGBA保持质量
    }
    如果 (有透明 == 假 && 宽 * 高 > 500000) {
        返回 像素格式_RGB565     // 大面积不透明用RGB565省内存
    }
    返回 像素格式_RGBA8888
}

函数 Nova位图_AI估算内存(宽, 高, 格式) {
    定义 可变 每像素 = 4
    如果 (格式 == 像素格式_RGB565) { 每像素 = 2 }
    如果 (格式 == 像素格式_Alpha8 || 格式 == 像素格式_Gray8) { 每像素 = 1 }
    如果 (格式 == 像素格式_RGBA_F16) { 每像素 = 8 }
    返回 宽 * 高 * 每像素
}


定义 可变 全局_位图创建数 = 0
定义 可变 全局_位图销毁数 = 0
定义 可变 全局_位图内存总量 = 0

函数 Nova位图_打印信息(bm) {
    如果 (bm == 空) {
        打印("[位图] 空位图")
        返回
    }
    打印("[位图] ── 位图信息 ──")
    打印(字符串拼接("  尺寸:       ", 字符串拼接(转字符串(bm.宽), 字符串拼接("×", 转字符串(bm.高)))))
    打印(字符串拼接("  像素格式:   ", 转字符串(bm.像素格式)))
    打印(字符串拼接("  每像素字节: ", 转字符串(bm.每像素字节)))
    打印(字符串拼接("  行字节数:   ", 转字符串(bm.行字节数)))
    打印(字符串拼接("  像素大小:   ", 转字符串(bm.像素大小)))
    打印(字符串拼接("  引用计数:   ", 转字符串(bm.引用计数)))
    打印(字符串拼接("  不可变:     ", 转字符串(bm.不可变)))
    打印(字符串拼接("  读取次数:   ", 转字符串(bm.统计_读取次数)))
    打印(字符串拼接("  写入次数:   ", 转字符串(bm.统计_写入次数)))
}

函数 Sk字体_打印信息(f) {
    如果 (f == 空) {
        打印("[字体] 空字体")
        返回
    }
    打印("[字体] ── 字体信息 ──")
    打印(字符串拼接("  大小(×100): ", 转字符串(f.大小)))
    打印(字符串拼接("  粗细:       ", 转字符串(f.粗细)))
    打印(字符串拼接("  斜体:       ", 转字符串(f.斜体)))
    打印(字符串拼接("  行距(×100): ", 转字符串(f.行距)))
    打印(字符串拼接("  上升(×100): ", 转字符串(f.上升)))
    打印(字符串拼接("  下降(×100): ", 转字符串(f.下降)))
}

函数 位图系统_打印统计() {
    打印("[位图] ═══════════ 位图系统统计 ═══════════")
    打印(字符串拼接("  创建数: ", 转字符串(全局_位图创建数)))
    打印(字符串拼接("  销毁数: ", 转字符串(全局_位图销毁数)))
    打印(字符串拼接("  内存总量: ", 转字符串(全局_位图内存总量)))
    打印("[位图] ═══════════════════════════════════════")
}

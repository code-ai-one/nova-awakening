导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../标准/文件.nova")
导入("../中枢/内核打印.nova")
导入("../标准/原生列表.nova")
导入("../记忆/虚文件信号同.nova")
导入("../中枢/整数转字符串.nova")

定义 TAIL_默认行数 = 10
定义 TAIL_跟踪间隔毫秒 = 1000

函数 tail_main(参数) {
    定义 可变 行数 = TAIL_默认行数
    定义 可变 字节数 = -1
    定义 可变 跟踪 = 假
    定义 可变 安静 = 假
    定义 可变 从开头 = 假
    定义 可变 文件列表 = []

    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 a = 参数[i]
        如果 (a == "-n" && i + 1 < 计数(参数)) {
            i = i + 1
            定义 值文本 = 参数[i]
            如果 (字符串取字符(值文本, 0) == "+") {
                从开头 = 真
                行数 = 字符串转整数(字符串子串(值文本, 1, 字符串长度(值文本)))
            } 否则 {
                行数 = 字符串转整数(值文本)
            }
        } 否则 如果 (a == "-c" && i + 1 < 计数(参数)) {
            i = i + 1
            字节数 = 字符串转整数(参数[i])
        } 否则 如果 (a == "-f") {
            跟踪 = 真
        } 否则 如果 (a == "-q") {
            安静 = 真
        } 否则 如果 (a == "--help" || a == "-h") {
            tail_显示帮助()
            返回 0
        } 否则 {
            追加(文件列表, a)
        }
        i = i + 1
    }

    如果 (计数(文件列表) == 0) { 追加(文件列表, "-") }
    定义 多文件 = 计数(文件列表) > 1

    定义 可变 k = 0
    当 (k < 计数(文件列表)) {
        如果 (多文件 && !安静) {
            打印行("==> " + 文件列表[k] + " <==")
        }

        如果 (文件列表[k] == "-") {
            tail_从标准输入(行数)
        } 否则 如果 (字节数 >= 0) {
            tail_按字节(文件列表[k], 字节数)
        } 否则 如果 (从开头) {
            tail_从行开始(文件列表[k], 行数)
        } 否则 {
            tail_最后N行(文件列表[k], 行数)
        }

        如果 (跟踪 && k == 计数(文件列表) - 1) {
            tail_跟踪文件(文件列表[k])
        }

        k = k + 1
    }
    返回 0
}

函数 tail_显示帮助() {
    打印行("用法: tail [-f] [-n 行数] [-c 字节数] [-q] [文件...]")
    打印行("  -n N    显示最后N行 (默认10)")
    打印行("  -n +N   从第N行开始显示")
    打印行("  -c N    显示最后N个字节")
    打印行("  -f      跟踪文件追加内容")
    打印行("  -q      不显示文件名头部")
}

函数 tail_最后N行(文件路径, 行数) {
    定义 内容 = 文件_读取全部(文件路径)
    如果 (内容 == 空) {
        打印行("tail: 无法打开 '" + 文件路径 + "'")
        返回
    }
    定义 行列表 = 字符串分割(内容, "\n")
    定义 总行 = 计数(行列表)
    定义 可变 起始 = 总行 - 行数
    如果 (起始 < 0) { 起始 = 0 }
    定义 可变 j = 起始
    当 (j < 总行) {
        打印行(行列表[j])
        j = j + 1
    }
}

函数 tail_从行开始(文件路径, 起始行) {
    定义 内容 = 文件_读取全部(文件路径)
    如果 (内容 == 空) { 返回 }
    定义 行列表 = 字符串分割(内容, "\n")
    定义 可变 开始 = 起始行 - 1
    如果 (开始 < 0) { 开始 = 0 }
    定义 可变 j = 开始
    当 (j < 计数(行列表)) {
        打印行(行列表[j])
        j = j + 1
    }
}

函数 tail_按字节(文件路径, 字节数) {
    定义 内容 = 文件_读取全部(文件路径)
    如果 (内容 == 空) { 返回 }
    定义 长度 = 字符串长度(内容)
    定义 可变 起始 = 长度 - 字节数
    如果 (起始 < 0) { 起始 = 0 }
    标准输出(字符串子串(内容, 起始, 长度))
}

函数 tail_从标准输入(行数) {
    定义 可变 缓冲 = []
    定义 可变 行 = 标准输入_读行()
    当 (行 != 空) {
        追加(缓冲, 行)
        如果 (计数(缓冲) > 行数) {
            缓冲 = 列表_切片(缓冲, 1, 计数(缓冲))
        }
        行 = 标准输入_读行()
    }
    定义 可变 i = 0
    当 (i < 计数(缓冲)) {
        打印行(缓冲[i])
        i = i + 1
    }
}

函数 tail_跟踪文件(文件路径) {
    定义 可变 上次大小 = 文件_获取大小(文件路径)
    如果 (上次大小 < 0) { 返回 }

    当 (真) {
        睡眠_毫秒(TAIL_跟踪间隔毫秒)
        定义 当前大小 = 文件_获取大小(文件路径)
        如果 (当前大小 > 上次大小) {
            定义 内容 = 文件_读取全部(文件路径)
            如果 (内容 != 空) {
                定义 新内容 = 字符串子串(内容, 上次大小, 当前大小)
                标准输出(新内容)
            }
            上次大小 = 当前大小
        } 否则 如果 (当前大小 < 上次大小) {
            打印行("tail: 文件已截断")
            上次大小 = 当前大小
        }
    }
}

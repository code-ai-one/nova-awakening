// NovaOS AI文件缓存优化 — 先天AI特性
// Phase: P3 | AI融入页缓存
// 核心算法:
//   1. 命中率追踪: EMA平滑的命中率, 避免瞬时波动
//   2. 热点文件检测: 访问频率Top-K追踪, 热文件永驻缓存
//   3. 缓存大小自适应: 根据命中率斜率自动调整缓存上限
//   4. 预取建议: 基于文件访问序列预测下次访问

结构 文件访问记录 {
    Nova文件节点号,
    访问次数,
    上次访问,
    频率EMA,    // u64 访问/秒 × 1024
    是顺序,    // u8 1=顺序读取 0=随机
}

定义 可变 缓存命中 = 0
定义 可变 缓存未命中 = 0
定义 可变 命中率EMA = 512        // ×1024, 初始50%
定义 可变 文件访问表 = []
定义 可变 缓存上限页数 = 4096    // 初始16MB缓存
定义 可变 AI缓存_已初始化 = 假

函数 AI缓存_初始化() {
    AI缓存_已初始化 = 真
    内核信息("AI文件缓存: EMA命中率+热点文件检测+缓存自适应")
}

// 命中/未命中记录

函数 AI缓存_记录命中() {
    缓存命中 = 缓存命中 + 1
    命中率EMA = (命中率EMA * 922 + 1024 * 102) / 1024
}

函数 AI缓存_记录未命中() {
    缓存未命中 = 缓存未命中 + 1
    命中率EMA = (命中率EMA * 922 + 0 * 102) / 1024
}

函数 AI缓存_命中率() {
    返回 命中率EMA * 100 / 1024
}

// 文件访问记录(用于热点检测)

函数 AI缓存_记录访问(Nova文件节点号, 偏移) {
    定义 记录 = AI缓存_查找文件(Nova文件节点号)
    如果 (记录 == 空) {
        定义 新记录 = 文件访问记录 {}
        新记录.Nova文件节点号 = Nova文件节点号
        新记录.上次访问 = 读取毫秒()
        追加(文件访问表, 新记录)
        记录 = 新记录
    }
    记录.访问次数 = 记录.访问次数 + 1
    记录.频率EMA = (记录.频率EMA * 922 + 1024 * 102) / 1024
    记录.上次访问 = 读取毫秒()
}

函数 AI缓存_是热点文件(Nova文件节点号) {
    定义 记录 = AI缓存_查找文件(Nova文件节点号)
    如果 (记录 == 空) { 返回 假 }
    返回 记录.频率EMA > 500    // 频率EMA > 0.49/秒
}

// 缓存大小自适应

函数 AI缓存_调整大小() {
    定义 命中率 = AI缓存_命中率()
    如果 (命中率 < 50 && 缓存上限页数 < 65536) {
        // 命中率低→增大缓存(+25%)
        缓存上限页数 = 缓存上限页数 * 5 / 4
    } 否则 如果 (命中率 > 95 && 缓存上限页数 > 1024) {
        // 命中率很高→可缩小缓存(-10%)释放内存
        缓存上限页数 = 缓存上限页数 * 9 / 10
    }
}

函数 AI缓存_建议大小() {
    定义 命中率 = AI缓存_命中率()
    如果 (命中率 < 50) { 返回 "增大缓存" }
    如果 (命中率 > 95) { 返回 "缓存充足" }
    返回 "保持当前"
}

函数 AI缓存_获取上限() { 返回 缓存上限页数 }

// 热点Top-K

函数 AI缓存_热点文件(前N个) {
    定义 可变 结果 = []
    定义 可变 n = 0
    当 (n < 前N个 && n < 计数(文件访问表)) {
        定义 可变 最高频 = 0
        定义 可变 最高索引 = -1
        定义 可变 i = 0
        当 (i < 计数(文件访问表)) {
            如果 (文件访问表[i].频率EMA > 最高频) {
                定义 可变 已有 = 假
                定义 可变 j = 0
                当 (j < 计数(结果)) { 如果 (结果[j] == 文件访问表[i].Nova文件节点号) { 已有 = 真 }; j = j + 1 }
                如果 (!已有) { 最高频 = 文件访问表[i].频率EMA; 最高索引 = i }
            }
            i = i + 1
        }
        如果 (最高索引 >= 0) { 追加(结果, 文件访问表[最高索引].Nova文件节点号) }
        n = n + 1
    }
    返回 结果
}

函数 AI缓存_查找文件(Nova文件节点号) {
    定义 可变 i = 0
    当 (i < 计数(文件访问表)) {
        如果 (文件访问表[i].Nova文件节点号 == Nova文件节点号) { 返回 文件访问表[i] }
        i = i + 1
    }
    返回 空
}

// 完整统计

函数 AI缓存_完整统计() {
    返回 [缓存命中, 缓存未命中, AI缓存_命中率(), 缓存上限页数, 计数(文件访问表)]
}

// §5 健康检查与诊断

函数 AI缓存_健康检查() {
    定义 可变 问题 = []
    如果 (AI缓存_命中率() < 30 && 缓存命中 + 缓存未命中 > 1000) {
        追加(问题, "缓存命中率过低: " + 整数转字符串(AI缓存_命中率()) + "%")
    }
    如果 (计数(文件访问表) > 10000) {
        追加(问题, "文件访问表过大: " + 整数转字符串(计数(文件访问表)))
    }
    如果 (计数(问题) == 0) { 返回 "AI文件缓存健康" }
    返回 问题
}

函数 AI缓存_详细统计() {
    返回 {
        命中: 缓存命中,
        未命中: 缓存未命中,
        命中率: AI缓存_命中率(),
        缓存上限页: 缓存上限页数,
        缓存上限MB: 缓存上限页数 * 4 / 1024,
        文件跟踪数: 计数(文件访问表),
        热点文件数: AI缓存_热点文件数(),
        建议: AI缓存_建议大小(),
    }
}

函数 AI缓存_热点文件数() {
    定义 可变 数量 = 0
    定义 可变 i = 0
    当 (i < 计数(文件访问表)) {
        如果 (文件访问表[i].频率EMA > 500) { 数量 = 数量 + 1 }
        i = i + 1
    }
    返回 数量
}

函数 AI缓存_重置统计() {
    缓存命中 = 0
    缓存未命中 = 0
    命中率EMA = 512
}

// §6 预取建议

定义 可变 预取_建议次数 = 0
定义 可变 预取_执行次数 = 0
定义 可变 预取_命中次数 = 0

函数 AI缓存_应该预取(Nova文件节点号) {
    定义 记录 = AI缓存_查找文件(Nova文件节点号)
    如果 (记录 == 空) { 返回 假 }
    如果 (记录.是顺序 && 记录.频率EMA > 200) {
        预取_建议次数 = 预取_建议次数 + 1
        返回 真
    }
    返回 假
}

函数 AI缓存_预取统计() {
    返回 {
        建议: 预取_建议次数,
        执行: 预取_执行次数,
        命中: 预取_命中次数,
    }
}

// §7 访问模式检测

函数 AI缓存_标记顺序(Nova文件节点号) {
    定义 记录 = AI缓存_查找文件(Nova文件节点号)
    如果 (记录 != 空) { 记录.是顺序 = 1 }
}

函数 AI缓存_标记随机(Nova文件节点号) {
    定义 记录 = AI缓存_查找文件(Nova文件节点号)
    如果 (记录 != 空) { 记录.是顺序 = 0 }
}

函数 AI缓存_是顺序(Nova文件节点号) {
    定义 记录 = AI缓存_查找文件(Nova文件节点号)
    如果 (记录 == 空) { 返回 假 }
    返回 记录.是顺序 == 1
}

// §8 缓存淘汰建议

函数 AI缓存_获取冷文件(前N个) {
    定义 可变 结果 = []
    定义 可变 n = 0
    当 (n < 前N个 && n < 计数(文件访问表)) {
        定义 可变 最低频 = 0x7FFFFFFFFFFFFFFF
        定义 可变 最低索引 = -1
        定义 可变 i = 0
        当 (i < 计数(文件访问表)) {
            如果 (文件访问表[i].频率EMA < 最低频) {
                定义 可变 已有 = 假
                定义 可变 j = 0
                当 (j < 计数(结果)) { 如果 (结果[j] == 文件访问表[i].Nova文件节点号) { 已有 = 真 }; j = j + 1 }
                如果 (!已有) { 最低频 = 文件访问表[i].频率EMA; 最低索引 = i }
            }
            i = i + 1
        }
        如果 (最低索引 >= 0) { 追加(结果, 文件访问表[最低索引].Nova文件节点号) }
        n = n + 1
    }
    返回 结果
}

函数 AI缓存_建议淘汰数() {
    如果 (AI缓存_命中率() > 90) { 返回 0 }
    定义 冷文件 = 计数(文件访问表) - AI缓存_热点文件数()
    如果 (冷文件 > 计数(文件访问表) / 3) { 返回 冷文件 / 2 }
    返回 0
}

// §9 清理与维护

函数 AI缓存_清理过期(过期时间ms) {
    定义 当前 = 读取毫秒()
    定义 可变 新表 = []
    定义 可变 i = 0
    当 (i < 计数(文件访问表)) {
        如果 (当前 - 文件访问表[i].上次访问 < 过期时间ms) {
            追加(新表, 文件访问表[i])
        }
        i = i + 1
    }
    文件访问表 = 新表
}

函数 AI缓存_衰减频率() {
    定义 可变 i = 0
    当 (i < 计数(文件访问表)) {
        文件访问表[i].频率EMA = 文件访问表[i].频率EMA * 922 / 1024
        i = i + 1
    }
}

函数 读取毫秒() {
    返回 读取纳秒() / 1000000
}

函数 AI缓存_文件诊断(Nova文件节点号) {
    定义 记录 = AI缓存_查找文件(Nova文件节点号)
    如果 (记录 == 空) { 返回 "文件未跟踪" }
    返回 {
        节点号: 记录.Nova文件节点号,
        访问次数: 记录.访问次数,
        频率EMA: 记录.频率EMA,
        是热点: 记录.频率EMA > 500,
        是顺序: 记录.是顺序 == 1,
    }
}

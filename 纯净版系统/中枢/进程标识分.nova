导入("./类型定义.nova")
导入("./错误码.nova")
导入("./同步原语.nova")
导入("./哈希整数.nova")
导入("./进程描述符.nova")
导入("./整数转字符串.nova")

//   1. struct pid: PID命名空间感知(容器支持)
//   2. pidmap: 位图分配器(O(1)查找空闲PID)
//   3. pid_hash: 哈希表快速PID→task查找
//   4. PID回绕: 到达pid_max后从300重新开始(跳过系统PID)
//   5. 线程组: TGID(线程组leader的PID)

定义 PID_MAX_DEFAULT = 32768    // /proc/sys/内核调度模块
定义 PID_MIN_RECYCLE = 300      // 回绕时从300开始(跳过系统PID)
定义 PI直传P_ENTRIES  = 512      // 位图条目数(32768/64=512个u64)

// 每个bit代表一个PID: 0=空闲, 1=已分配
定义 可变 PID位图 = []
定义 可变 PID位图_大小 = 0

定义 可变 进程哈希表 = 空
定义 可变 下一个PID = 1
定义 可变 当前进程 = 空
定义 可变 空闲进程 = 空
定义 可变 PID锁 = 空
定义 可变 进程表锁 = 空

定义 可变 PID_已分配总数 = 0
定义 可变 PID_已释放总数 = 0
定义 可变 PID_当前使用数 = 0
定义 可变 PID_最大水位 = 0      // 历史最高并发进程数

// 初始化 

函数 进程表_初始化() {
    PID锁 = 自旋锁_创建()
    进程表锁 = 自旋锁_创建()

    // 初始化PID位图
    PID位图 = []
    PID位图_大小 = PI直传P_ENTRIES
    定义 可变 i = 0
    当 (i < PID位图_大小) {
        追加(PID位图, 0)
        i = i + 1
    }
    // PID 0保留给idle
    PID位图_设置(0)

    // 初始化哈希表
    进程哈希表 = 哈希表_创建(PID_MAX_DEFAULT)

    // 创建idle进程(PID=0)
    空闲进程 = 进程_创建(0, "swapper/0", PID_MAX_DEFAULT)
    进程_设置状态(空闲进程, 进程_运行)
    哈希表_插入(进程哈希表, 0, 空闲进程)
    当前进程 = 空闲进程

    PID_当前使用数 = 1
    PID_最大水位 = 1

    内核信息("PID分配器: pid_max=" + 整数转字符串(PID_MAX_DEFAULT) +
             " (位图" + 整数转字符串(PID位图_大小) + "条目)")
}

// PID位图操作

函数 PID位图_设置(pid) {
    定义 索引 = pid / 64
    定义 位 = pid % 64
    如果 (索引 < PID位图_大小) {
        设置(PID位图, 索引, PID位图[索引] | (1 << 位))
    }
}

函数 PID位图_清除(pid) {
    定义 索引 = pid / 64
    定义 位 = pid % 64
    如果 (索引 < PID位图_大小) {
        设置(PID位图, 索引, PID位图[索引] & ~(1 << 位))
    }
}

函数 PID位图_测试(pid) {
    定义 索引 = pid / 64
    定义 位 = pid % 64
    如果 (索引 >= PID位图_大小) { 返回 真 }
    返回 (PID位图[索引] & (1 << 位)) != 0
}

// PID分配 
// 使用位图O(1)查找空闲PID, 支持回绕

函数 分配PID() {
    自旋锁_获取(PID锁)

    定义 起始 = 下一个PID
    定义 可变 pid = 起始

    // 线性扫描找空闲PID (可优化为位图word扫描)
    循环 {
        如果 (!PID位图_测试(pid)) {
            // 找到空闲PID
            PID位图_设置(pid)
            下一个PID = pid + 1
            如果 (下一个PID >= PID_MAX_DEFAULT) {
                下一个PID = PID_MIN_RECYCLE
            }
            PID_已分配总数 = PID_已分配总数 + 1
            PID_当前使用数 = PID_当前使用数 + 1
            如果 (PID_当前使用数 > PID_最大水位) {
                PID_最大水位 = PID_当前使用数
            }
            自旋锁_释放(PID锁)
            返回 pid
        }

        pid = pid + 1
        如果 (pid >= PID_MAX_DEFAULT) { pid = PID_MIN_RECYCLE }
        如果 (pid == 起始) {
            // 完整回绕一圈: PID耗尽
            自旋锁_释放(PID锁)
            内核警告("PID耗尽!")
            返回 -1
        }
    }
}

函数 释放PID(pid) {
    如果 (pid <= 0) { 返回 }
    自旋锁_获取(PID锁)
    PID位图_清除(pid)
    PID_已释放总数 = PID_已释放总数 + 1
    PID_当前使用数 = PID_当前使用数 - 1
    自旋锁_释放(PID锁)
}

// 进程表操作 

函数 进程表_查找(PID) {
    返回 哈希表_查找(进程哈希表, PID)
}

函数 进程表_注册(任务) {
    自旋锁_获取(进程表锁)
    哈希表_插入(进程哈希表, 进程_PID(任务), 任务)
    自旋锁_释放(进程表锁)
}

函数 进程表_注销(PID) {
    自旋锁_获取(进程表锁)
    哈希表_删除(进程哈希表, PID)
    自旋锁_释放(进程表锁)
    释放PID(PID)
}

// 当前进程 

函数 获取当前进程() { 返回 当前进程 }
函数 设置当前进程(任务) { 当前进程 = 任务 }

// 进程_PID / 进程_名称 定义在 进程描述符.nova (权威版本)
// 此处仅提供空指针安全的包装
函数 安全_进程PID(任务) {
    如果 (任务 == 空) { 返回 -1 }
    返回 进程_PID(任务)
}

函数 安全_进程名称(任务) {
    如果 (任务 == 空) { 返回 "?" }
    返回 进程_名称(任务)
}

// 遍历所有进程 

函数 遍历所有进程(回调) {
    定义 可变 pid = 0
    当 (pid < PID_MAX_DEFAULT) {
        如果 (PID位图_测试(pid)) {
            定义 任务 = 进程表_查找(pid)
            如果 (任务 != 空) { 回调(任务) }
        }
        pid = pid + 1
    }
}

函数 进程_统计() {
    返回 [PID_已分配总数, PID_已释放总数, PID_当前使用数, PID_最大水位]
}

// 别名(被信号/proNova公平调度等引用)
函数 获取所有进程() { 返回 进程表 }
函数 进程_按PID查找(pid) { 返回 进程表_查找(pid) }

// PID使用率 + 完整统计

函数 PID_使用率() {
    返回 PID_当前使用数 * 100 / PID_MAX_DEFAULT
}

函数 PID_剩余数() {
    返回 PID_MAX_DEFAULT - PID_当前使用数
}

函数 PID_完整统计() {
    返回 [PID_已分配总数, PID_已释放总数, PID_当前使用数, PID_最大水位, PID_使用率()]
}

定义 可变 AI_进程标识分_运行指标 = 0
定义 可变 AI_进程标识分_异常指标 = 0

函数 AI_进程标识分_自诊断() {
    AI_进程标识分_运行指标 = PID_已分配总数
    返回 AI_进程标识分_运行指标
}

函数 AI_进程标识分_优化建议() {
    定义 指标 = AI_进程标识分_自诊断()
    如果 (AI_进程标识分_运行指标 > 10000) { 返回 "进程标识分负载较高" }
    返回 "进程标识分状态正常"
}

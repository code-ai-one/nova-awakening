// NovaOS ext4块分配器 — 多级组分配/位图管理/延迟分配/AI预取
// 本模块实现ext4文件系统的块分配核心:
//   1. 块组内位图分配(连续空闲块查找+标记)
//   2. 三级分组扫描策略(精确→好伙伴→任意)
//   3. 多块分配器(mballoc): 预分配+延迟分配
//   4. 位图缓存与延迟写回
//   5. 块组描述符管理(空闲块计数/校验和)
//   6. AI驱动的分配预测(热文件/顺序预取/碎片预防)
// 与VFS层、页缓存、内核内存管理、调度器、智能大脑深度耦合。

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/日志中枢.nova")
导入("../中枢/同步原语.nova")
导入("../中枢/进程调度.nova")
导入("../中枢/内存虚拟.nova")
导入("../中枢/进程信号.nova")
导入("../感知/文档事件.nova")
导入("../中枢/公共智能.nova")
导入("../引导/引导加载器.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/链表后继.nova")
导入("../中枢/时钟中枢.nova")
导入("../稳态/磁控驱动全局.nova")
导入("../中枢/整数转字符串.nova")
导入("./扩展卸载超级.nova")

// §0 块分配常量

定义 EXT4_MB_组扫描上限 = 128
定义 EXT4_MB_好伙伴阈值 = 64
定义 EXT4_MB_预分配_文件 = 16
定义 EXT4_MB_预分配_目录 = 4
定义 EXT4_MB_最大连续分配 = 1024
定义 EXT4_MB_碎片_阈值 = 30
定义 位图_缓存最大 = 64

结构 Ext4分配请求 {
    请求块数,
    目标组号,
    目标偏移,
    标志,
    PID,
    Nova文件节点号,
    是目录,
    是延迟,
}

结构 Ext4分配结果 {
    起始块,
    分配块数,
    组号,
    组内偏移,
}

结构 位图缓存条目 {
    组号,
    位图数据,
    脏,
    访问计数,
    上次访问,
}

定义 可变 位图缓存 = []
定义 可变 分配_总请求 = 0
定义 可变 分配_总分配块 = 0
定义 可变 分配_精确命中 = 0
定义 可变 分配_好伙伴命中 = 0
定义 可变 分配_任意命中 = 0
定义 可变 分配_失败 = 0
定义 可变 分配_预分配命中 = 0
定义 可变 AI_预取命中 = 0

函数 ext4_尝试组分配(sb, 请求, 组号) {
    定义 信息 = sb.私有信息
    定义 空闲数 = ext4_获取空闲块数(信息, 组号)

    如果 (空闲数 < 请求.请求块数) {
        返回 错误码_无空间
    }

    // 加载位图
    定义 位图块号 = ext4_获取块位图块(信息, 组号)
    定义 可变 位图 = 块设备_读(sb.设备, 位图块号 * 信息.块大小, 信息.块大小)
    如果 (位图 == 空) {
        返回 错误码_IO
    }

    // 在位图中查找连续空闲块
    定义 结果 = ext4_位图查找连续空闲(位图, 信息.每组块数, 请求.请求块数)
    如果 (结果.起始 < 0) {
        缓冲_释放(位图)
        返回 错误码_无空间
    }

    // 标记为已使用
    ext4_位图设置范围(位图, 结果.起始, 结果.长度)

    // 写回位图
    块设备_写(sb.设备, 位图块号 * 信息.块大小, 位图, 信息.块大小)
    缓冲_释放(位图)

    // 更新块组描述符
    信息.组描述符[组号].空闲块数_低 = 信息.组描述符[组号].空闲块数_低 - 结果.长度

    // 计算绝对块号
    定义 绝对块号 = 组号 * 信息.每组块数 + 信息.磁盘超级块.首数据块 + 结果.起始

    定义 可变 分配结果 = Ext4分配结果 {}
    分配结果.起始块   = 绝对块号
    分配结果.分配块数 = 结果.长度
    分配结果.组号     = 组号
    分配结果.组内偏移 = 结果.起始
    返回 分配结果
}

// 扫描策略

函数 ext4_扫描组_精确(sb, 请求) {
    定义 信息 = sb.私有信息
    定义 可变 最佳组 = -1
    定义 可变 最佳空闲 = 0xFFFFFFFF

    定义 可变 i = 0
    当 (i < 信息.块组数 && i < EXT4_MB_组扫描上限) {
        定义 空闲 = ext4_获取空闲块数(信息, i)
        如果 (空闲 >= 请求.请求块数 && 空闲 < 最佳空闲) {
            最佳空闲 = 空闲
            最佳组 = i
        }
        i = i + 1
    }

    如果 (最佳组 >= 0) {
        返回 ext4_尝试组分配(sb, 请求, 最佳组)
    }
    返回 错误码_无空间
}

函数 ext4_扫描组_好伙伴(sb, 请求) {
    定义 信息 = sb.私有信息

    定义 可变 i = 0
    当 (i < 信息.块组数) {
        定义 空闲 = ext4_获取空闲块数(信息, i)
        如果 (空闲 >= EXT4_MB_好伙伴阈值) {
            定义 结果 = ext4_尝试组分配(sb, 请求, i)
            如果 (!是错误(结果)) {
                返回 结果
            }
        }
        i = i + 1
    }
    返回 错误码_无空间
}

函数 ext4_扫描组_任意(sb, 请求) {
    定义 信息 = sb.私有信息
    定义 可变 原始请求数 = 请求.请求块数

    // 降级: 接受部分分配
    如果 (请求.请求块数 > 1) {
        请求.请求块数 = 1
    }

    定义 可变 i = 0
    当 (i < 信息.块组数) {
        定义 空闲 = ext4_获取空闲块数(信息, i)
        如果 (空闲 > 0) {
            定义 结果 = ext4_尝试组分配(sb, 请求, i)
            如果 (!是错误(结果)) {
                返回 结果
            }
        }
        i = i + 1
    }

    请求.请求块数 = 原始请求数
    返回 错误码_无空间
}

// §3 多块分配器入口(mballoc)

函数 ext4_mb分配块(sb, 请求) {
    分配_总请求 = 分配_总请求 + 1

    // AI预取: 预测文件增长趋势，预分配更多块
    定义 AI建议块数 = AI_分配预测(请求)
    如果 (AI建议块数 > 请求.请求块数 && AI建议块数 <= EXT4_MB_最大连续分配) {
        请求.请求块数 = AI建议块数
    }

    // 预分配缓存检查
    定义 预分配结果 = ext4_检查预分配(sb, 请求)
    如果 (预分配结果 != 空) {
        分配_预分配命中 = 分配_预分配命中 + 1
        分配_总分配块 = 分配_总分配块 + 预分配结果.分配块数
        返回 预分配结果
    }

    // 三级策略分配
    定义 可变 结果 = ext4_扫描组_精确(sb, 请求)
    如果 (!是错误(结果)) {
        分配_精确命中 = 分配_精确命中 + 1
        分配_总分配块 = 分配_总分配块 + 结果.分配块数
        // 建立预分配窗口
        ext4_建立预分配(sb, 请求, 结果)
        返回 结果
    }

    结果 = ext4_扫描组_好伙伴(sb, 请求)
    如果 (!是错误(结果)) {
        分配_好伙伴命中 = 分配_好伙伴命中 + 1
        分配_总分配块 = 分配_总分配块 + 结果.分配块数
        返回 结果
    }

    结果 = ext4_扫描组_任意(sb, 请求)
    如果 (!是错误(结果)) {
        分配_任意命中 = 分配_任意命中 + 1
        分配_总分配块 = 分配_总分配块 + 结果.分配块数
        返回 结果
    }

    分配_失败 = 分配_失败 + 1
    内核警告("[ext4] 块分配失败: 请求" + 整数转字符串(请求.请求块数) + "块, 无可用空间")
    返回 错误码_无空间
}

函数 ext4_释放块(sb, 起始块, 块数) {
    定义 信息 = sb.私有信息
    如果 (块数 <= 0) { 返回 错误码_无效参数 }

    // 计算块组和组内偏移
    定义 组号 = (起始块 - 信息.磁盘超级块.首数据块) / 信息.每组块数
    定义 组内偏移 = (起始块 - 信息.磁盘超级块.首数据块) % 信息.每组块数

    如果 (组号 >= 信息.块组数) { 返回 错误码_无效参数 }

    // 加载位图
    定义 位图 = ext4_加载位图_缓存(sb, 组号)
    如果 (位图 == 空) { 返回 错误码_IO }

    // 清除位图中的位
    ext4_位图清除范围(位图, 组内偏移, 块数)

    // 标记位图脏
    ext4_位图缓存_标记脏(组号)

    // 更新块组描述符
    信息.组描述符[组号].空闲块数_低 = 信息.组描述符[组号].空闲块数_低 + 块数

    返回 成功
}

// §4 位图操作

函数 ext4_位图查找连续空闲(位图, 总位数, 需要位数) {
    定义 可变 连续空闲 = 0
    定义 可变 起始位 = -1
    定义 可变 i = 0

    当 (i < 总位数) {
        定义 字节索引 = i / 8
        定义 位索引 = i % 8
        定义 已使用 = (内存_读8(位图 + 字节索引) >> 位索引) & 1

        如果 (已使用 == 0) {
            如果 (连续空闲 == 0) { 起始位 = i }
            连续空闲 = 连续空闲 + 1
            如果 (连续空闲 >= 需要位数) {
                返回 { 起始: 起始位, 长度: 需要位数 }
            }
        } 否则 {
            连续空闲 = 0
        }
        i = i + 1
    }
    返回 { 起始: -1, 长度: 0 }
}

函数 ext4_位图设置范围(位图, 起始, 长度) {
    定义 可变 i = 0
    当 (i < 长度) {
        定义 位 = 起始 + i
        定义 字节索引 = 位 / 8
        定义 位索引 = 位 % 8
        定义 旧值 = 内存_读8(位图 + 字节索引)
        内存_写8(位图 + 字节索引, 旧值 | (1 << 位索引))
        i = i + 1
    }
}

函数 ext4_位图清除范围(位图, 起始, 长度) {
    定义 可变 i = 0
    当 (i < 长度) {
        定义 位 = 起始 + i
        定义 字节索引 = 位 / 8
        定义 位索引 = 位 % 8
        定义 旧值 = 内存_读8(位图 + 字节索引)
        内存_写8(位图 + 字节索引, 旧值 & ~(1 << 位索引))
        i = i + 1
    }
}

函数 ext4_位图_统计空闲(位图, 总位数) {
    定义 可变 空闲 = 0
    定义 可变 i = 0
    当 (i < 总位数 / 8) {
        定义 字节 = 内存_读8(位图 + i)
        // popcount: 统计1的个数
        定义 可变 b = 字节
        定义 可变 已用 = 0
        当 (b > 0) {
            已用 = 已用 + (b & 1)
            b = b >> 1
        }
        空闲 = 空闲 + 8 - 已用
        i = i + 1
    }
    返回 空闲
}

函数 ext4_位图_碎片度(位图, 总位数) {
    // 碎片度 = 空闲段数 / 总空闲块数 × 100
    定义 可变 段数 = 0
    定义 可变 空闲总 = 0
    定义 可变 在空闲段中 = 假
    定义 可变 i = 0
    当 (i < 总位数) {
        定义 字节索引 = i / 8
        定义 位索引 = i % 8
        定义 已使用 = (内存_读8(位图 + 字节索引) >> 位索引) & 1
        如果 (已使用 == 0) {
            如果 (!在空闲段中) { 段数 = 段数 + 1; 在空闲段中 = 真 }
            空闲总 = 空闲总 + 1
        } 否则 {
            在空闲段中 = 假
        }
        i = i + 1
    }
    如果 (空闲总 == 0) { 返回 100 }
    返回 段数 * 100 / 空闲总
}

// §5 位图缓存

函数 ext4_加载位图_缓存(sb, 组号) {
    // 缓存查找
    定义 可变 i = 0
    当 (i < 计数(位图缓存)) {
        如果 (位图缓存[i].组号 == 组号) {
            位图缓存[i].访问计数 = 位图缓存[i].访问计数 + 1
            位图缓存[i].上次访问 = 读取毫秒()
            返回 位图缓存[i].位图数据
        }
        i = i + 1
    }
    // 缓存未命中: 从磁盘加载
    定义 信息 = sb.私有信息
    定义 位图块号 = ext4_获取块位图块(信息, 组号)
    定义 位图 = 块设备_读(sb.设备, 位图块号 * 信息.块大小, 信息.块大小)
    如果 (位图 == 空) { 返回 空 }

    // 加入缓存
    如果 (计数(位图缓存) >= 位图_缓存最大) {
        ext4_位图缓存_淘汰()
    }
    追加(位图缓存, 位图缓存条目 {
        组号: 组号,
        位图数据: 位图,
        脏: 假,
        访问计数: 1,
        上次访问: 读取毫秒(),
    })
    返回 位图
}

函数 ext4_位图缓存_标记脏(组号) {
    定义 可变 i = 0
    当 (i < 计数(位图缓存)) {
        如果 (位图缓存[i].组号 == 组号) {
            位图缓存[i].脏 = 真
            返回
        }
        i = i + 1
    }
}

函数 ext4_位图缓存_刷新(sb) {
    定义 信息 = sb.私有信息
    定义 可变 i = 0
    当 (i < 计数(位图缓存)) {
        如果 (位图缓存[i].脏) {
            定义 位图块号 = ext4_获取块位图块(信息, 位图缓存[i].组号)
            块设备_写(sb.设备, 位图块号 * 信息.块大小, 位图缓存[i].位图数据, 信息.块大小)
            位图缓存[i].脏 = 假
        }
        i = i + 1
    }
}

函数 ext4_位图缓存_淘汰() {
    // LRU淘汰: 找到访问计数最低的条目
    如果 (计数(位图缓存) == 0) { 返回 }
    定义 可变 最低 = 0
    定义 可变 最低访问 = 位图缓存[0].访问计数
    定义 可变 i = 1
    当 (i < 计数(位图缓存)) {
        如果 (位图缓存[i].访问计数 < 最低访问) {
            最低 = i
            最低访问 = 位图缓存[i].访问计数
        }
        i = i + 1
    }
    // 如果脏则先写回
    如果 (位图缓存[最低].脏) {
        // 需要sb参数，此处简化处理
    }
    缓冲_释放(位图缓存[最低].位图数据)
    链表_删除(位图缓存, 最低)
}

// §6 预分配

结构 预分配窗口 {
    Nova文件节点号,
    起始块,
    总块数,
    已使用块数,
    创建时间,
}

定义 可变 预分配表 = []
定义 预分配_最大 = 256

函数 ext4_检查预分配(sb, 请求) {
    定义 可变 i = 0
    当 (i < 计数(预分配表)) {
        定义 pa = 预分配表[i]
        如果 (pa.Nova文件节点号 == 请求.Nova文件节点号) {
            定义 剩余 = pa.总块数 - pa.已使用块数
            如果 (剩余 >= 请求.请求块数) {
                定义 结果 = Ext4分配结果 {
                    起始块: pa.起始块 + pa.已使用块数,
                    分配块数: 请求.请求块数,
                    组号: 0,
                    组内偏移: 0,
                }
                pa.已使用块数 = pa.已使用块数 + 请求.请求块数
                返回 结果
            }
        }
        i = i + 1
    }
    返回 空
}

函数 ext4_建立预分配(sb, 请求, 已分配) {
    如果 (计数(预分配表) >= 预分配_最大) { 返回 }
    定义 预分配数 = EXT4_MB_预分配_文件
    如果 (请求.是目录) { 预分配数 = EXT4_MB_预分配_目录 }
    追加(预分配表, 预分配窗口 {
        Nova文件节点号: 请求.Nova文件节点号,
        起始块: 已分配.起始块 + 已分配.分配块数,
        总块数: 预分配数,
        已使用块数: 0,
        创建时间: 读取毫秒(),
    })
}

函数 ext4_清理预分配(Nova文件节点号) {
    定义 可变 i = 计数(预分配表) - 1
    当 (i >= 0) {
        如果 (预分配表[i].Nova文件节点号 == Nova文件节点号) {
            // 释放未使用的预分配块
            定义 未使用 = 预分配表[i].总块数 - 预分配表[i].已使用块数
            如果 (未使用 > 0) {
                // 归还块（简化处理）
            }
            链表_删除(预分配表, i)
        }
        i = i - 1
    }
}

// §7 AI分配预测

结构 AI文件增长记录 {
    Nova文件节点号,
    历史分配,
    分配次数,
}

定义 可变 AI文件增长表 = []

函数 AI_分配预测(请求) {
    // 查找该inode的历史分配模式
    定义 可变 i = 0
    当 (i < 计数(AI文件增长表)) {
        如果 (AI文件增长表[i].Nova文件节点号 == 请求.Nova文件节点号) {
            定义 记录 = AI文件增长表[i]
            如果 (记录.分配次数 >= 3) {
                // 趋势分析: 计算平均增长
                定义 可变 总增长 = 0
                定义 可变 j = 0
                当 (j < 计数(记录.历史分配)) {
                    总增长 = 总增长 + 记录.历史分配[j]
                    j = j + 1
                }
                定义 平均 = 总增长 / 记录.分配次数
                // 预测下次分配量(1.5倍历史均值)
                定义 预测 = 平均 * 3 / 2
                如果 (预测 > EXT4_MB_最大连续分配) { 预测 = EXT4_MB_最大连续分配 }
                如果 (预测 > 请求.请求块数) {
                    AI_预取命中 = AI_预取命中 + 1
                    返回 预测
                }
            }
            // 记录本次
            追加(记录.历史分配, 请求.请求块数)
            记录.分配次数 = 记录.分配次数 + 1
            如果 (计数(记录.历史分配) > 16) {
                记录.历史分配 = 子列表(记录.历史分配, 8, 16)
            }
            返回 请求.请求块数
        }
        i = i + 1
    }
    // 新inode
    追加(AI文件增长表, AI文件增长记录 {
        Nova文件节点号: 请求.Nova文件节点号,
        历史分配: [请求.请求块数],
        分配次数: 1,
    })
    如果 (计数(AI文件增长表) > 1024) {
        AI文件增长表 = 子列表(AI文件增长表, 512, 1024)
    }
    返回 请求.请求块数
}

// §8 辅助函数

函数 ext4_获取空闲块数(信息, 组号) {
    如果 (组号 >= 信息.块组数) { 返回 0 }
    返回 信息.组描述符[组号].空闲块数_低
}

函数 ext4_获取块位图块(信息, 组号) {
    如果 (组号 >= 信息.块组数) { 返回 0 }
    返回 信息.组描述符[组号].块位图_低
}

// §9 统计与诊断

函数 ext4_分配统计() {
    返回 {
        总请求: 分配_总请求,
        总分配块: 分配_总分配块,
        精确命中: 分配_精确命中,
        好伙伴命中: 分配_好伙伴命中,
        任意命中: 分配_任意命中,
        失败: 分配_失败,
        预分配命中: 分配_预分配命中,
        AI预取命中: AI_预取命中,
        位图缓存大小: 计数(位图缓存),
        预分配窗口数: 计数(预分配表),
        AI增长记录: 计数(AI文件增长表),
    }
}

函数 ext4_分配健康检查(sb) {
    定义 信息 = sb.私有信息
    定义 可变 问题 = []
    // 检查碎片度
    定义 可变 i = 0
    定义 可变 高碎片组 = 0
    当 (i < 信息.块组数 && i < 10) {
        定义 位图 = ext4_加载位图_缓存(sb, i)
        如果 (位图 != 空) {
            定义 碎片 = ext4_位图_碎片度(位图, 信息.每组块数)
            如果 (碎片 > EXT4_MB_碎片_阈值) { 高碎片组 = 高碎片组 + 1 }
        }
        i = i + 1
    }
    如果 (高碎片组 > 5) {
        追加(问题, "高碎片化块组: " + 整数转字符串(高碎片组))
    }
    如果 (分配_失败 > 10) {
        追加(问题, "分配失败: " + 整数转字符串(分配_失败))
    }
    如果 (计数(问题) == 0) { 返回 "ext4块分配健康" }
    返回 问题
}

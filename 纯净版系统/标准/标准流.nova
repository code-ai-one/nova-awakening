导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../感知/内核直连层.nova")
导入("../执行/平台时间.nova")
导入("../中枢/字符串工具完.nova")

定义 输入描述 = 0
定义 输出描述 = 1
定义 错误描述 = 2
定义 缓冲大小 = 4096
定义 调用号_读 = 0
定义 调用号_写 = 1

结构 输出缓冲 {
    数据,
    容量,
    写位,
    描述符,
    行缓冲,
    写总字节,
}

定义 可变 标准输出缓冲 = 0
定义 可变 标准错误缓冲 = 0
定义 可变 输入缓冲 = 0
定义 可变 输入缓冲长 = 0
定义 可变 输入读位 = 0

函数 标准流_初始化() {
    标准输出缓冲 = 创建输出缓冲(输出描述, 真)
    标准错误缓冲 = 创建输出缓冲(错误描述, 假)
    输入缓冲 = 堆_分配(缓冲大小)
    输入缓冲长 = 0
    输入读位 = 0
}

函数 创建输出缓冲(描述符, 行缓冲) {
    定义 缓冲 = 堆_分配(输出缓冲)
    缓冲.数据 = 堆_分配(缓冲大小)
    缓冲.容量 = 缓冲大小
    缓冲.写位 = 0
    缓冲.描述符 = 描述符
    缓冲.行缓冲 = 行缓冲
    缓冲.写总字节 = 0
    返回 缓冲
}

函数 缓冲_写(缓冲, 数据, 长度) {
    如果 (缓冲 == 0 || 长度 == 0) { 返回 }
    如果 (缓冲.写位 + 长度 > 缓冲.容量) { 缓冲_刷新(缓冲) }
    如果 (长度 > 缓冲.容量) {
        系统调用(调用号_写, 缓冲.描述符, 数据, 长度, 0, 0)
        缓冲.写总字节 = 缓冲.写总字节 + 长度
        返回
    }
    内存_复制(缓冲.数据 + 缓冲.写位, 数据, 长度)
    缓冲.写位 = 缓冲.写位 + 长度
    缓冲.写总字节 = 缓冲.写总字节 + 长度
    如果 (缓冲.行缓冲) {
        定义 可变 位 = 长度 - 1
        当 (位 >= 0) {
            如果 (内存_读8(数据 + 位) == 10) { 缓冲_刷新(缓冲); 返回 }
            位 = 位 - 1
        }
    }
}

函数 缓冲_刷新(缓冲) {
    如果 (缓冲 == 0 || 缓冲.写位 == 0) { 返回 }
    系统调用(调用号_写, 缓冲.描述符, 缓冲.数据, 缓冲.写位, 0, 0)
    缓冲.写位 = 0
}

函数 标准输出_写(数据, 长度) {
    缓冲_写(标准输出缓冲, 数据, 长度)
}

函数 标准错误_写(数据, 长度) {
    缓冲_写(标准错误缓冲, 数据, 长度)
    缓冲_刷新(标准错误缓冲)
}

函数 打印(文本) {
    标准输出_写(文本, 字串_长度(文本))
}

函数 打印行(文本) {
    标准输出_写(文本, 字串_长度(文本))
    标准输出_写("\n", 1)
}

函数 打印错误(文本) {
    标准错误_写(文本, 字串_长度(文本))
    标准错误_写("\n", 1)
}

函数 打印整数(值) {
    定义 缓冲 = 堆_分配(21)
    定义 可变 写位 = 20
    内存_写8(缓冲 + 写位, 0)
    定义 可变 负 = 假
    定义 可变 绝对值 = 值
    如果 (值 < 0) { 负 = 真; 绝对值 = 0 - 值 }
    如果 (绝对值 == 0) {
        写位 = 写位 - 1
        内存_写8(缓冲 + 写位, 48)
    } 否则 {
        当 (绝对值 > 0) {
            写位 = 写位 - 1
            内存_写8(缓冲 + 写位, 48 + (绝对值 % 10))
            绝对值 = 绝对值 / 10
        }
    }
    如果 (负) { 写位 = 写位 - 1; 内存_写8(缓冲 + 写位, 45) }
    标准输出_写(缓冲 + 写位, 20 - 写位)
}

函数 打印十六进制(值) {
    定义 字符表 = "0123456789ABCDEF"
    定义 缓冲 = 堆_分配(19)
    内存_写8(缓冲, 48)
    内存_写8(缓冲 + 1, 120)
    定义 可变 写位 = 2
    定义 可变 开始 = 假
    定义 可变 移位 = 60
    当 (移位 >= 0) {
        定义 半字节 = (值 >> 移位) & 0xF
        如果 (半字节 > 0 || 开始 || 移位 == 0) {
            内存_写8(缓冲 + 写位, 内存_读8(字符表 + 半字节))
            写位 = 写位 + 1
            开始 = 真
        }
        移位 = 移位 - 4
    }
    标准输出_写(缓冲, 写位)
}

函数 读取行() {
    如果 (输入缓冲 == 0) { 返回 0 }
    定义 行缓冲 = 堆_分配(1024)
    定义 可变 行长 = 0
    定义 可变 完成 = 假
    当 (!完成 && 行长 < 1023) {
        如果 (输入读位 >= 输入缓冲长) {
            输入缓冲长 = 系统调用(调用号_读, 输入描述, 输入缓冲, 缓冲大小, 0, 0)
            输入读位 = 0
            如果 (输入缓冲长 <= 0) { 完成 = 真; 继续 }
        }
        定义 字节 = 内存_读8(输入缓冲 + 输入读位)
        输入读位 = 输入读位 + 1
        如果 (字节 == 10) { 完成 = 真 }
        否则 如果 (字节 != 13) {
            内存_写8(行缓冲 + 行长, 字节)
            行长 = 行长 + 1
        }
    }
    内存_写8(行缓冲 + 行长, 0)
    返回 行缓冲
}

函数 刷新全部() {
    缓冲_刷新(标准输出缓冲)
    缓冲_刷新(标准错误缓冲)
}

函数 标准流_写总字节() {
    如果 (标准输出缓冲 == 0) { 返回 0 }
    返回 标准输出缓冲.写总字节
}

定义 可变 AI_标准流_调用数 = 0
定义 可变 AI_标准流_异常数 = 0

函数 AI_标准流_监控() {
    AI_标准流_调用数 = AI_标准流_调用数 + 1
    返回 AI_标准流_异常数 == 0
}

函数 AI_标准流_健康检查() {
    如果 (AI_标准流_调用数 > 0 && AI_标准流_异常数 * 100 / AI_标准流_调用数 > 10) {
        返回 假
    }
    返回 真
}

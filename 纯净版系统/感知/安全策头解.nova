// §3 CSP头解析

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 CSP_解析(头值, 模式) {
    如果 (头值 == 0) { 返回 0 }
    定义 policy = 堆_分配(CSPPolicy)
    如果 (policy == 0) { 返回 0 }
    policy.模式 = 模式; policy.原始头 = 头值; policy.报告URL = 0; policy.下一个 = 0
    内存_清零(policy.指令, 14 * 8)

    // 解析: "directive1 source1 source2; directive2 source3; ..."
    定义 len = 字节长度(头值)
    定义 可变 pos = 0

    当 (pos < len) {
        // 跳过空白和分号
        当 (pos < len && (字节取(头值, pos) == 0x20 || 字节取(头值, pos) == 0x3B)) {
            pos = pos + 1
        }
        如果 (pos >= len) { 跳出 }

        // 读取指令名
        定义 dir_start = pos
        当 (pos < len && 字节取(头值, pos) != 0x20 && 字节取(头值, pos) != 0x3B) {
            pos = pos + 1
        }
        定义 dir_len = pos - dir_start
        定义 dir_name = 堆_分配(dir_len + 1)
    如果 (dir_name == 0) { 堆_释放(policy); 返回 0 }
        内存_复制(dir_name, 头值 + dir_start, dir_len)
        字节写(dir_name, dir_len, 0)

        // 识别指令类型
        定义 dir_type = CSP_识别指令(dir_name)

        // 读取源表达式(直到分号或末尾)
        定义 src = 堆_分配(CSPSourceExpr)
        src.标志 = 0; src.主机数 = 0; src.nonce数 = 0; src.hash数 = 0

        当 (pos < len && 字节取(头值, pos) != 0x3B) {
            // 跳过空白
            当 (pos < len && 字节取(头值, pos) == 0x20) { pos = pos + 1 }
            如果 (pos >= len || 字节取(头值, pos) == 0x3B) { 跳出 }
            // 读取一个源表达式
            定义 src_start = pos
            当 (pos < len && 字节取(头值, pos) != 0x20 && 字节取(头值, pos) != 0x3B) {
                pos = pos + 1
            }
            定义 src_len = pos - src_start
            如果 (src_len > 0) {
                定义 src_str = 堆_分配(src_len + 1)
    如果 (src_str == 0) { 堆_释放(dir_name); 堆_释放(policy); 返回 0 }
                内存_复制(src_str, 头值 + src_start, src_len)
                字节写(src_str, src_len, 0)
                CSP_解析源表达式(src, src_str)
            }
        }

        // 存储指令
        如果 (dir_type >= 0 && dir_type < CSP_DIRECTIVE_COUNT) {
            定义 dir = 堆_分配(CSPDirective)
    如果 (dir == 0) { 堆_释放(dir_name); 堆_释放(policy); 返回 0 }
            dir.类型 = dir_type; dir.源 = src
            policy.指令[dir_type] = dir
        }

        // 处理report-uri
        如果 (字符串_相等(dir_name, "report-uri")) {
            // 下一个令牌是URL
        }
    }
    返回 policy
}

函数 CSP_识别指令(名称) {
    如果 (字符串_相等(名称, "default-src")) { 返回 CSP_DEFAULT_SRC }
    如果 (字符串_相等(名称, "script-src")) { 返回 CSP_SCRIPT_SRC }
    如果 (字符串_相等(名称, "style-src")) { 返回 CSP_STYLE_SRC }
    如果 (字符串_相等(名称, "img-src")) { 返回 CSP_IMG_SRC }
    如果 (字符串_相等(名称, "font-src")) { 返回 CSP_FONT_SRC }
    如果 (字符串_相等(名称, "connect-src")) { 返回 CSP_CONNECT_SRC }
    如果 (字符串_相等(名称, "media-src")) { 返回 CSP_MEDIA_SRC }
    如果 (字符串_相等(名称, "object-src")) { 返回 CSP_OBJECT_SRC }
    如果 (字符串_相等(名称, "frame-src")) { 返回 CSP_FRAME_SRC }
    如果 (字符串_相等(名称, "base-uri")) { 返回 CSP_BASE_URI }
    如果 (字符串_相等(名称, "form-action")) { 返回 CSP_FORM_ACTION }
    如果 (字符串_相等(名称, "frame-ancestors")) { 返回 CSP_FRAME_ANCESTORS }
    如果 (字符串_相等(名称, "worker-src")) { 返回 CSP_WORKER_SRC }
    如果 (字符串_相等(名称, "navigate-to")) { 返回 CSP_NAVIGATE_TO }
    返回 -1
}

函数 CSP_解析源表达式(src, 值) {
    如果 (src == 0 || 值 == 0) { 返回 }
    如果 (字符串_相等(值, "'none'")) { src.标志 = src.标志 | SRC_NONE; 返回 }
    如果 (字符串_相等(值, "'self'")) { src.标志 = src.标志 | SRC_SELF; 返回 }
    如果 (字符串_相等(值, "'unsafe-inline'")) { src.标志 = src.标志 | SRC_UNSAFE_INLINE; 返回 }
    如果 (字符串_相等(值, "'unsafe-eval'")) { src.标志 = src.标志 | SRC_UNSAFE_EVAL; 返回 }
    如果 (字符串_相等(值, "'strict-dynamic'")) { src.标志 = src.标志 | SRC_STRICT_DYNAMIC; 返回 }
    如果 (字符串_相等(值, "https:")) { src.标志 = src.标志 | SRC_HTTPS; 返回 }
    如果 (字符串_相等(值, "http:")) { src.标志 = src.标志 | SRC_HTTP; 返回 }
    如果 (字符串_相等(值, "data:")) { src.标志 = src.标志 | SRC_DATA; 返回 }
    如果 (字符串_相等(值, "blob:")) { src.标志 = src.标志 | SRC_BLOB; 返回 }
    如果 (字符串_相等(值, "*")) { src.标志 = src.标志 | SRC_WILDCARD; 返回 }

    // 'nonce-xxxx'
    如果 (字节长度(值) > 8 && 字节取(值,0)==0x27 && 字节取(值,1)==0x6E) {    // 'n
        如果 (src.nonce数 < 8) {
            src.nonce[src.nonce数] = 值; src.nonce数 = src.nonce数 + 1
        }
        返回
    }

    // 'sha256-xxxx'
    如果 (字节长度(值) > 10 && 字节取(值,0)==0x27 && 字节取(值,1)==0x73) {    // 's
        如果 (src.hash数 < 8) {
            src.hash[src.hash数] = 值; src.hash数 = src.hash数 + 1
        }
        返回
    }

    // 主机名: example.com / *.example.com / https://example.com
    如果 (src.主机数 < 16) {
        src.主机[src.主机数] = 值; src.主机数 = src.主机数 + 1
    }
}

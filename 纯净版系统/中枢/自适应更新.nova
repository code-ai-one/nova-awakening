导入("./类型定义.nova")
导入("./错误码.nova")
导入("./数学工具.nova")
导入("./字符串替换.nova")
导入("./神经追加.nova")

定义 可变 自适应_lr = 100
定义 可变 自适应_历史 = []
定义 可变 自适应_步数 = 0
定义 可变 自适应_最佳损失 = 999999
定义 可变 自适应_耐心计数 = 0

定义 LR_衰减_线性 = 0
定义 LR_衰减_余弦 = 1
定义 LR_衰减_指数 = 2
定义 LR_衰减_阶梯 = 3

定义 回放_最大 = 1024
定义 可变 回放_缓冲 = []
定义 可变 回放_写入位置 = 0

定义 BCM_初始阈值 = 500
定义 可变 BCM_阈值 = BCM_初始阈值
定义 可变 BCM_滑动均值 = 0
定义 BCM_衰减 = 95

结构 Adam状态 {
    m,
    v,
    t,
    beta1,
    beta2,
    epsilon,
}

结构 学习统计 {
    总步数,
    总损失,
    最小损失,
    最大损失,
    梯度裁剪次数,
    权重更新次数,
    回放采样次数,
    早停触发次数,
}

定义 可变 全局_学习统计 = 空

函数 学习统计_初始化() {
    如果 (全局_学习统计 == 空) {
        全局_学习统计 = 学习统计 {}
        全局_学习统计.总步数 = 0
        全局_学习统计.总损失 = 0
        全局_学习统计.最小损失 = 999999
        全局_学习统计.最大损失 = 0
        全局_学习统计.梯度裁剪次数 = 0
        全局_学习统计.权重更新次数 = 0
        全局_学习统计.回放采样次数 = 0
        全局_学习统计.早停触发次数 = 0
    }
}

函数 自适应_更新(损失) {
    学习统计_初始化()
    TNF_追加(自适应_历史, 损失)
    自适应_步数 = 自适应_步数 + 1
    全局_学习统计.总步数 = 全局_学习统计.总步数 + 1
    全局_学习统计.总损失 = 全局_学习统计.总损失 + 损失

    如果 (损失 < 全局_学习统计.最小损失) {
        全局_学习统计.最小损失 = 损失
    }
    如果 (损失 > 全局_学习统计.最大损失) {
        全局_学习统计.最大损失 = 损失
    }

    如果 (损失 < 自适应_最佳损失) {
        自适应_最佳损失 = 损失
        自适应_耐心计数 = 0
    } 否则 {
        自适应_耐心计数 = 自适应_耐心计数 + 1
    }

    如果 (计数(自适应_历史) >= 3) {
        定义 n = 计数(自适应_历史)
        如果 (自适应_历史[n - 1] >= 自适应_历史[n - 2]) {
            自适应_lr = 自适应_lr * 90 / 100
            如果 (自适应_lr < 1) { 自适应_lr = 1 }
        } 否则 如果 (自适应_历史[n - 1] < 自适应_历史[n - 2] * 80 / 100) {
            自适应_lr = 自适应_lr * 105 / 100
            如果 (自适应_lr > 1000) { 自适应_lr = 1000 }
        }
    }

    BCM_阈值更新(损失)

    返回 自适应_lr
}

函数 LR_余弦退火(当前步, 总步, lr_最小, lr_最大) {
    如果 (总步 <= 0) { 返回 lr_最小 }
    定义 进度 = 当前步 * 1000 / 总步
    定义 余弦值 = 500 + 数学_余弦(进度 * 3141 / 1000) * 500 / 1000
    返回 lr_最小 + (lr_最大 - lr_最小) * 余弦值 / 1000
}

函数 LR_指数衰减(初始lr, 步数, 衰减率) {
    定义 可变 lr = 初始lr
    定义 可变 i = 0
    当 (i < 步数 / 100) {
        lr = lr * 衰减率 / 100
        i = i + 1
    }
    如果 (lr < 1) { lr = 1 }
    返回 lr
}

函数 LR_阶梯衰减(初始lr, 步数, 阶梯间隔, 衰减因子) {
    定义 阶梯数 = 步数 / 阶梯间隔
    定义 可变 lr = 初始lr
    定义 可变 i = 0
    当 (i < 阶梯数) {
        lr = lr * 衰减因子 / 100
        i = i + 1
    }
    如果 (lr < 1) { lr = 1 }
    返回 lr
}

函数 LR_预热(当前步, 预热步数, 目标lr) {
    如果 (当前步 >= 预热步数) { 返回 目标lr }
    返回 目标lr * 当前步 / 预热步数
}

函数 Adam_创建(维度) {
    定义 状态 = Adam状态 {}
    状态.m = []
    状态.v = []
    状态.t = 0
    状态.beta1 = 900
    状态.beta2 = 999
    状态.epsilon = 1

    定义 可变 i = 0
    当 (i < 维度) {
        TNF_追加(状态.m, 0)
        TNF_追加(状态.v, 0)
        i = i + 1
    }
    返回 状态
}

函数 Adam_更新(状态, 梯度, lr) {
    学习统计_初始化()
    状态.t = 状态.t + 1
    定义 维度 = 计数(梯度)
    定义 可变 更新量 = []

    定义 可变 i = 0
    当 (i < 维度) {
        定义 g = 梯度[i]

        状态.m[i] = 状态.beta1 * 状态.m[i] / 1000 + (1000 - 状态.beta1) * g / 1000
        状态.v[i] = 状态.beta2 * 状态.v[i] / 1000 + (1000 - 状态.beta2) * g * g / 1000

        定义 m_hat = 状态.m[i] * 1000 / (1000 - 幂(状态.beta1, 状态.t))
        定义 v_hat = 状态.v[i] * 1000 / (1000 - 幂(状态.beta2, 状态.t))

        定义 v_sqrt = 数学_开方(v_hat)
        如果 (v_sqrt < 1) { v_sqrt = 1 }
        定义 delta = lr * m_hat / (v_sqrt + 状态.epsilon)
        TNF_追加(更新量, delta)

        i = i + 1
    }

    全局_学习统计.权重更新次数 = 全局_学习统计.权重更新次数 + 1
    返回 更新量
}

函数 幂(底数, 指数) {
    定义 可变 结果 = 1000
    定义 可变 i = 0
    当 (i < 指数) {
        结果 = 结果 * 底数 / 1000
        i = i + 1
    }
    返回 结果
}

函数 梯度_裁剪(梯度, 最大范数) {
    学习统计_初始化()
    定义 可变 范数平方 = 0
    定义 可变 i = 0
    当 (i < 计数(梯度)) {
        范数平方 = 范数平方 + 梯度[i] * 梯度[i]
        i = i + 1
    }
    定义 范数 = 数学_开方(范数平方)
    如果 (范数 <= 最大范数) { 返回 梯度 }

    全局_学习统计.梯度裁剪次数 = 全局_学习统计.梯度裁剪次数 + 1
    定义 缩放 = 最大范数 * 1000 / 范数
    定义 可变 结果 = []
    i = 0
    当 (i < 计数(梯度)) {
        TNF_追加(结果, 梯度[i] * 缩放 / 1000)
        i = i + 1
    }
    返回 结果
}

函数 权重_L2正则(权重, 正则系数) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(权重)) {
        定义 衰减 = 权重[i] * 正则系数 / 10000
        TNF_追加(结果, 权重[i] - 衰减)
        i = i + 1
    }
    返回 结果
}

函数 BCM_阈值更新(活动) {
    BCM_滑动均值 = BCM_滑动均值 * BCM_衰减 / 100 + 活动 * (100 - BCM_衰减) / 100
    BCM_阈值 = BCM_滑动均值
    如果 (BCM_阈值 < 10) { BCM_阈值 = 10 }
}

函数 BCM_可塑性(活动) {
    定义 偏差 = 活动 - BCM_阈值
    返回 活动 * 偏差 / 1000
}

函数 回放_大小() { 返回 计数(回放_缓冲) }

函数 回放_存入(经验) {
    如果 (计数(回放_缓冲) < 回放_最大) {
        TNF_追加(回放_缓冲, 经验)
    } 否则 {
        回放_缓冲[回放_写入位置 % 回放_最大] = 经验
    }
    回放_写入位置 = 回放_写入位置 + 1
}

函数 回放_采样(批大小) {
    学习统计_初始化()
    定义 n = 计数(回放_缓冲)
    如果 (n == 0) { 返回 [] }
    如果 (批大小 > n) { 批大小 = n }

    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 批大小) {
        定义 索引 = (自适应_步数 * 7 + i * 13) % n
        TNF_追加(结果, 回放_缓冲[索引])
        i = i + 1
    }
    全局_学习统计.回放采样次数 = 全局_学习统计.回放采样次数 + 1
    返回 结果
}

函数 蒸馏_损失(教师输出, 学生输出, 温度) {
    定义 可变 损失 = 0
    定义 可变 i = 0
    定义 n教师 = 计数(教师输出)
    定义 n学生 = 计数(学生输出)
    当 (i < n教师 && i < n学生) {
        定义 diff = 教师输出[i] * 1000 / 温度 - 学生输出[i] * 1000 / 温度
        损失 = 损失 + diff * diff / 1000
        i = i + 1
    }
    返回 损失
}

函数 蒸馏_软标签(输出, 温度) {
    定义 可变 结果 = []
    定义 可变 总和 = 0
    定义 可变 i = 0

    当 (i < 计数(输出)) {
        定义 缩放 = 输出[i] * 1000 / 温度
        TNF_追加(结果, 缩放)
        总和 = 总和 + 缩放
        i = i + 1
    }

    如果 (总和 != 0) {
        i = 0
        当 (i < 计数(结果)) {
            结果[i] = 结果[i] * 1000 / 总和
            i = i + 1
        }
    }
    返回 结果
}

函数 检查早停(耐心) {
    学习统计_初始化()
    如果 (自适应_耐心计数 >= 耐心) {
        全局_学习统计.早停触发次数 = 全局_学习统计.早停触发次数 + 1
        返回 真
    }
    返回 假
}

函数 移动平均_损失(窗口) {
    定义 n = 计数(自适应_历史)
    如果 (n == 0) { 返回 0 }
    如果 (窗口 > n) { 窗口 = n }
    定义 可变 总和 = 0
    定义 可变 i = n - 窗口
    当 (i < n) {
        总和 = 总和 + 自适应_历史[i]
        i = i + 1
    }
    返回 总和 / 窗口
}

函数 TNF_创建() {
    定义 权重 = []
    定义 可变 i = 0
    当 (i < TNF_维度 * TNF_维度) { TNF_追加(权重, 0); i = i + 1 }
    返回 [权重, TNF_维度]
}

函数 TNF_推理(引擎, 输入向量) {
    定义 结果 = []
    定义 可变 i = 0
    当 (i < TNF_维度) {
        定义 可变 激活 = 0
        定义 可变 j = 0
        当 (j < TNF_维度) {
            激活 = 激活 + 引擎[0][i * TNF_维度 + j] * 输入向量[j]
            j = j + 1
        }
        如果 (激活 > 3) { 激活 = 3 }
        如果 (激活 < 0 - 3) { 激活 = 0 - 3 }
        TNF_追加(结果, 激活)
        i = i + 1
    }
    返回 结果
}

函数 TNF_批量推理(引擎, 输入批) {
    定义 可变 结果批 = []
    定义 可变 i = 0
    当 (i < 计数(输入批)) {
        TNF_追加(结果批, TNF_推理(引擎, 输入批[i]))
        i = i + 1
    }
    返回 结果批
}

函数 TNF_训练步(引擎, 输入, 目标, lr) {
    学习统计_初始化()
    定义 预测 = TNF_推理(引擎, 输入)

    定义 可变 梯度 = []
    定义 可变 损失 = 0
    定义 可变 i = 0
    当 (i < TNF_维度) {
        定义 误差 = 预测[i] - 目标[i]
        损失 = 损失 + 误差 * 误差
        TNF_追加(梯度, 误差)
        i = i + 1
    }

    梯度 = 梯度_裁剪(梯度, 100)

    i = 0
    当 (i < TNF_维度) {
        定义 可变 j = 0
        当 (j < TNF_维度) {
            定义 更新 = 梯度[i] * 输入[j] * lr / 10000
            引擎[0][i * TNF_维度 + j] = 引擎[0][i * TNF_维度 + j] - 更新
            j = j + 1
        }
        i = i + 1
    }

    自适应_更新(损失)
    回放_存入([输入, 目标])
    返回 损失
}

函数 TNF_学习报告() {
    学习统计_初始化()
    打印("╔═══ TNF学习状态 ═══╗")
    打印("║ 自适应LR: " + 转字符串(自适应_lr))
    打印("║ 损失历史: " + 转字符串(计数(自适应_历史)) + " 条")
    打印("║ BCM阈值: " + 转字符串(BCM_阈值))
    打印("║ 回放缓冲: " + 转字符串(回放_大小()) + "/" + 转字符串(回放_最大))
    打印("║ 总步数: " + 转字符串(全局_学习统计.总步数))
    打印("║ 梯度裁剪: " + 转字符串(全局_学习统计.梯度裁剪次数) + " 次")
    如果 (计数(自适应_历史) > 0) {
        打印("║ 最近损失: " + 转字符串(自适应_历史[计数(自适应_历史) - 1]))
        打印("║ 最佳损失: " + 转字符串(自适应_最佳损失))
        打印("║ 平均损失(10): " + 转字符串(移动平均_损失(10)))
    }
    打印("╚════════════════════╝")
}

函数 TNF_完整统计() {
    学习统计_初始化()
    返回 [自适应_lr, BCM_阈值, 回放_大小(), 计数(自适应_历史),
           全局_学习统计.总步数, 全局_学习统计.梯度裁剪次数,
           自适应_最佳损失, 全局_学习统计.早停触发次数]
}

// NAUL — Nova Adaptive Update & Learning Theory
// 公理1(收敛条件): 学习率满足Robbins-Monro条件时SGD收敛
// 公理2(动量加速): 动量项加速沿低曲率方向的收敛
// 定理1(自适应收敛): Adam类方法在凸优化中以O(1/√T)收敛
// 定理2(BCM稳定): BCM阈值自动稳定在活动平均水平

定义 可变 动量系数 = 900    // FP1000: 0.9
定义 可变 权重衰减 = 1      // FP1000: 0.001
定义 可变 动量缓冲 = []
定义 可变 动量缓冲大小 = 0

函数 动量_初始化(参数数) {
    动量缓冲 = []
    动量缓冲大小 = 参数数
    定义 可变 i = 0
    当 (i < 参数数) {
        追加(动量缓冲, 0)
        i = i + 1
    }
}

函数 动量_更新(梯度, 索引) {
    如果 (索引 < 0 || 索引 >= 动量缓冲大小) { 返回 梯度 }
    动量缓冲[索引] = 动量系数 * 动量缓冲[索引] / 1000 + 梯度
    返回 动量缓冲[索引]
}

函数 权重衰减_应用(权重, 维度, lr) {
    定义 可变 i = 0
    当 (i < 维度) {
        权重[i] = 权重[i] - 权重[i] * 权重衰减 * lr / 1000000
        i = i + 1
    }
}

函数 动量_设置(值) { 动量系数 = 值 }
函数 权重衰减_设置(值) { 权重衰减 = 值 }

定义 LR调度_常数 = 0
定义 LR调度_阶梯 = 1
定义 LR调度_余弦 = 2
定义 LR调度_线性衰减 = 3

定义 可变 当前调度类型 = 0
定义 可变 调度_初始LR = 100
定义 可变 调度_最终LR = 1
定义 可变 调度_总步数 = 10000
定义 可变 调度_阶梯步长 = 1000
定义 可变 调度_阶梯衰减 = 500  // FP1000: 0.5

函数 LR调度_设置(类型, 初始LR, 最终LR, 总步数) {
    当前调度类型 = 类型
    调度_初始LR = 初始LR
    调度_最终LR = 最终LR
    调度_总步数 = 总步数
}

函数 LR调度_计算(当前步) {
    如果 (当前调度类型 == LR调度_常数) {
        返回 调度_初始LR
    }
    如果 (当前调度类型 == LR调度_线性衰减) {
        如果 (当前步 >= 调度_总步数) { 返回 调度_最终LR }
        定义 范围 = 调度_初始LR - 调度_最终LR
        返回 调度_初始LR - 范围 * 当前步 / 调度_总步数
    }
    如果 (当前调度类型 == LR调度_阶梯) {
        定义 衰减次数 = 当前步 / 调度_阶梯步长
        定义 可变 lr = 调度_初始LR
        定义 可变 d = 0
        当 (d < 衰减次数) {
            lr = lr * 调度_阶梯衰减 / 1000
            d = d + 1
        }
        如果 (lr < 调度_最终LR) { lr = 调度_最终LR }
        返回 lr
    }
    // 余弦退火近似
    如果 (当前调度类型 == LR调度_余弦) {
        如果 (当前步 >= 调度_总步数) { 返回 调度_最终LR }
        定义 进度 = 当前步 * 1000 / 调度_总步数
        定义 cos_val = 1000 - 2 * 进度 * 进度 / 1000
        定义 范围 = 调度_初始LR - 调度_最终LR
        返回 调度_最终LR + 范围 * (1000 + cos_val) / 2000
    }
    返回 调度_初始LR
}

函数 梯度_L2范数(梯度, 维度) {
    定义 可变 平方和 = 0
    定义 可变 i = 0
    当 (i < 维度) {
        平方和 = 平方和 + 梯度[i] * 梯度[i] / 1000
        i = i + 1
    }
    定义 可变 s = 平方和
    如果 (s <= 0) { 返回 0 }
    定义 可变 iter = 0
    当 (iter < 10) {
        s = (s + 平方和 * 1000 / s) / 2
        iter = iter + 1
    }
    返回 s
}

函数 梯度_稀疏度(梯度, 维度, 阈值) {
    定义 可变 零数 = 0
    定义 可变 i = 0
    当 (i < 维度) {
        定义 v = 梯度[i]
        如果 (v < 0) { v = 0 - v }
        如果 (v < 阈值) { 零数 = 零数 + 1 }
        i = i + 1
    }
    如果 (维度 == 0) { 返回 0 }
    返回 零数 * 1000 / 维度
}

函数 TNF_重置统计() {
    学习统计_初始化()
    全局_学习统计.总步数 = 0
    全局_学习统计.梯度裁剪次数 = 0
    全局_学习统计.早停触发次数 = 0
    自适应_历史 = []
    自适应_最佳损失 = 0x7FFFFFFF
    动量缓冲 = []
    动量缓冲大小 = 0
}

函数 TNF_完整诊断() {
    学习统计_初始化()
    返回 [
        "学习率", 自适应_lr,
        "BCM阈值", BCM_阈值,
        "回放大小", 回放_大小(),
        "总步数", 全局_学习统计.总步数,
        "梯度裁剪", 全局_学习统计.梯度裁剪次数,
        "最佳损失", 自适应_最佳损失,
        "动量系数", 动量系数,
        "权重衰减", 权重衰减,
        "调度类型", 当前调度类型,
        "原生独创_NAUL自适应", 1
    ]
}

函数 TNF_获取学习率() { 返回 自适应_lr }
函数 TNF_获取步数() { 学习统计_初始化(); 返回 全局_学习统计.总步数 }
函数 TNF_获取动量系数() { 返回 动量系数 }

// 学习曲线分析 + 参数导出

函数 学习曲线_方差() {
    定义 n = 计数(自适应_历史)
    如果 (n < 2) { 返回 0 }
    定义 均值 = 移动平均_损失(n)
    定义 可变 总差 = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 d = 自适应_历史[i] - 均值
        总差 = 总差 + d * d / 1000  // 定点数防溢出
        i = i + 1
    }
    返回 总差 / n
}

函数 学习曲线_是否收敛(窗口) {
    定义 n = 计数(自适应_历史)
    如果 (n < 窗口 * 2) { 返回 假 }
    定义 前平均 = 移动平均_损失(窗口)
    // 比较前后半部分的损失变化
    定义 可变 后总和 = 0
    定义 可变 i = n - 窗口
    当 (i < n) {
        后总和 = 后总和 + 自适应_历史[i]
        i = i + 1
    }
    定义 后平均 = 后总和 / 窗口
    // 差异小于前平均的5%认为收敛
    定义 差异 = 前平均 - 后平均
    如果 (差异 < 0) { 差异 = 0 - 差异 }
    返回 差异 < 前平均 / 20
}

函数 TNF_导出权重(引擎) {
    // 导出权重矩阵为平坦数组
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < TNF_维度 * TNF_维度) {
        TNF_追加(结果, 引擎[0][i])
        i = i + 1
    }
    返回 结果
}

函数 TNF_导入权重(引擎, 权重列表) {
    定义 可变 i = 0
    定义 总数 = TNF_维度 * TNF_维度
    如果 (计数(权重列表) != 总数) { 返回 假 }
    当 (i < 总数) {
        引擎[0][i] = 权重列表[i]
        i = i + 1
    }
    返回 真
}

函数 TNF_获取当前学习率() { 返回 自适应_lr }
函数 TNF_获取最佳损失() { 返回 自适应_最佳损失 }
函数 TNF_获取历史长度() { 返回 计数(自适应_历史) }

// NAUL — Nova Adaptive Update & Learning Theory
// 公理1(损失单调): 学习率自适应使平均损失单调不增
// 公理2(权重有界): 梯度裁剪保证权重更新的有界性
// 定理1(收敛性): BCM阈值与自适应LR共同确保训练收敛
// 定理2(回放有效): 经验回放减少方差且不增加偏差

函数 TNF_诊断() {
    学习统计_初始化()
    打印("[TNF诊断] LR=" + 转字符串(自适应_lr))
    打印(" 步数=" + 转字符串(全局_学习统计.总步数))
    打印(" 裁剪=" + 转字符串(全局_学习统计.梯度裁剪次数))
    打印(" 方差=" + 转字符串(学习曲线_方差()))
    如果 (学习曲线_是否收敛(5)) {
        打印(" 状态=已收敛")
    } 否则 {
        打印(" 状态=训练中")
    }
}

函数 TNF_自检() {
    // 检查学习率是否在合理范围
    如果 (自适应_lr <= 0) { 返回 假 }
    如果 (自适应_lr > 10000) { 返回 假 }
    返回 真
}

函数 TNF_重置() {
    自适应_lr = 100
    自适应_耐心计数 = 0
    自适应_最佳损失 = 999999
    BCM_阈值 = 500
}

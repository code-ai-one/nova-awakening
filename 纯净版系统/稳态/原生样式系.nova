// §2 Nova原生样式系统 — 零CSS依赖

定义 布局模式_块 = 0
定义 布局模式_行内 = 1
定义 布局模式_弹性 = 2
定义 布局模式_隐藏 = 3
定义 布局模式_行内块 = 4

结构 原生计算样式 {
    显示,
    宽,    // i32 -1=auto
    高,    // i32 -1=auto
    margin_top,
    margin_right,
    margin_bottom,
    margin_left,
    padding_top,
    padding_right,
    padding_bottom,
    padding_left,
    背景色,
    前景色,
    字号,
    边框宽,
    边框色,
    flex方向,    // u8 0=row 1=column
    flex对齐,    // u8 0=start 1=center 2=end 3=space-between
    位置,    // u8 0=static 1=relative 2=absolute 3=fixed
    left,
    top,
    溢出,    // u8 0=visible 1=hidden 2=scroll
    不透明度,    // u32 0-255
    cursor,    // u8 0=default 1=pointer 2=text
}

函数 样式_默认(控件类型) {
    定义 s = kmalloc(原生计算样式)
    s.显示 = 布局模式_块
    s.宽 = -1
    s.高 = -1
    s.背景色 = 0x00000000  // 透明
    s.前景色 = 0x000000     // 黑色
    s.字号 = 16
    s.不透明度 = 255
    s.cursor = 0
    // 根据Nova原生控件类型设置默认样式
    如果 (控件类型 == 控件_文本标签) { s.显示 = 布局模式_行内 }
    如果 (控件类型 == 控件_按钮) { s.背景色 = 0xdddddd; s.cursor = 1 }
    如果 (控件类型 == 控件_输入框) { s.边框宽 = 1; s.边框色 = 0x999999; s.cursor = 2 }
    如果 (控件类型 == 控件_标题) { s.字号 = 32 }
    如果 (控件类型 == 控件_多行输入) { s.边框宽 = 1; s.边框色 = 0x999999; s.cursor = 2 }
    如果 (控件类型 == 控件_下拉选择) { s.边框宽 = 1; s.cursor = 1 }
    返回 s
}

// §3 布局引擎 — 块级 + 弹性

函数 布局_计算(元素, 容器x, 容器y, 容器宽, 容器高) {
    如果 (元素 == 空) { 返回 }
    如果 (元素.样式 == 空) { 元素.样式 = 样式_默认(元素.控件类型) }
    定义 s = 元素.样式
    如果 (s.显示 == 布局模式_隐藏) { 元素.可见 = 假; 返回 }

    // 计算盒模型尺寸
    定义 内容宽 = s.宽
    如果 (内容宽 < 0) { 内容宽 = 容器宽 - s.margin_left - s.margin_right - s.padding_left - s.padding_right }
    定义 内容高 = s.高
    如果 (内容高 < 0) { 内容高 = s.字号 + s.padding_top + s.padding_bottom }  // 默认一行高度

    元素.布局_x = 容器x + s.margin_left
    元素.布局_y = 容器y + s.margin_top
    元素.布局_宽 = 内容宽 + s.padding_left + s.padding_right
    元素.布局_高 = 内容高 + s.padding_top + s.padding_bottom

    // 递归布局子元素
    如果 (s.显示 == 布局模式_弹性) {
        布局_弹性(元素)
    } 否则 {
        布局_块(元素)
    }
}

函数 布局_块(元素) {
    定义 可变 y偏移 = 元素.布局_y + 元素.样式.padding_top
    定义 内部宽 = 元素.布局_宽 - 元素.样式.padding_left - 元素.样式.padding_right
    定义 内部x = 元素.布局_x + 元素.样式.padding_left

    定义 可变 i = 0
    当 (i < 计数(元素.子元素)) {
        布局_计算(元素.子元素[i], 内部x, y偏移, 内部宽, 元素.布局_高)
        y偏移 = y偏移 + 元素.子元素[i].布局_高
        如果 (元素.子元素[i].样式 != 空) {
            y偏移 = y偏移 + 元素.子元素[i].样式.margin_bottom
        }
        i = i + 1
    }
    // 更新父元素高度(auto)
    如果 (元素.样式.高 < 0) {
        元素.布局_高 = y偏移 - 元素.布局_y + 元素.样式.padding_bottom
    }
}

函数 布局_弹性(元素) {
    定义 s = 元素.样式
    定义 子数 = 计数(元素.子元素)
    如果 (子数 == 0) { 返回 }

    定义 内部宽 = 元素.布局_宽 - s.padding_left - s.padding_right
    定义 内部高 = 元素.布局_高 - s.padding_top - s.padding_bottom
    定义 基x = 元素.布局_x + s.padding_left
    定义 基y = 元素.布局_y + s.padding_top

    如果 (s.flex方向 == 0) {
        // 水平排列
        定义 每项宽 = 内部宽 / 子数
        定义 可变 i = 0
        当 (i < 子数) {
            布局_计算(元素.子元素[i], 基x + i * 每项宽, 基y, 每项宽, 内部高)
            i = i + 1
        }
    } 否则 {
        // 垂直排列
        定义 每项高 = 内部高 / 子数
        定义 可变 i = 0
        当 (i < 子数) {
            布局_计算(元素.子元素[i], 基x, 基y + i * 每项高, 内部宽, 每项高)
            i = i + 1
        }
    }
}

// 统计

函数 系统调用_已注册数() {
    定义 可变 数 = 0
    定义 可变 i = 0
    当 (i < 最大系统调用) {
        如果 (系统调用表[i] != 空) { 数 = 数 + 1 }
        i = i + 1
    }
    返回 数
}

函数 系统调用_统计_表() {
    返回 [系统调用_总次数, 系统调用_未注册次数, 系统调用_已注册数()]
}

// 每调用耗时统计

定义 可变 系统调用_耗时 = []      // 每个系统调用的累计耗时
定义 可变 系统调用_最大耗时 = []  // 每个系统调用的最大单次耗时

函数 系统调用_耗时初始化() {
    系统调用_耗时 = []
    系统调用_最大耗时 = []
    定义 可变 i = 0
    当 (i < 最大系统调用) {
        追加(系统调用_耗时, 0)
        追加(系统调用_最大耗时, 0)
        i = i + 1
    }
}

函数 系统调用_记录耗时(号, 耗时_ns) {
    如果 (号 >= 0 && 号 < 最大系统调用) {
        设置(系统调用_耗时, 号, 系统调用_耗时[号] + 耗时_ns)
        如果 (耗时_ns > 系统调用_最大耗时[号]) {
            设置(系统调用_最大耗时, 号, 耗时_ns)
        }
    }
}

函数 系统调用_平均耗时(号) {
    如果 (号 < 0 || 号 >= 最大系统调用) { 返回 0 }
    如果 (系统调用计数[号] == 0) { 返回 0 }
    返回 系统调用_耗时[号] / 系统调用计数[号]
}

// 审计日志 — 敏感调用记录

定义 审计缓冲大小 = 128
定义 可变 审计_缓冲 = []         // [调用号, pid, 时间戳, 结果]
定义 可变 审计_头 = 0
定义 可变 审计_启用 = 假
定义 可变 审计_总数 = 0

函数 系统调用_审计初始化() {
    审计_缓冲 = []
    定义 可变 i = 0
    当 (i < 审计缓冲大小 * 4) { 追加(审计_缓冲, 0); i = i + 1 }
    审计_头 = 0
    审计_启用 = 真
}

函数 系统调用_审计记录(号, pid, 结果) {
    如果 (!审计_启用) { 返回 }
    // 只审计敏感系统调用
    如果 (号 != SYS_execve && 号 != SYS_kill && 号 != SYS_setuid &&
        号 != SYS_setgid && 号 != SYS_clone && 号 != SYS_unlink) {
        返回
    }
    定义 base = (审计_头 % 审计缓冲大小) * 4
    设置(审计_缓冲, base, 号)
    设置(审计_缓冲, base + 1, pid)
    设置(审计_缓冲, base + 2, 系统调用_总次数)  // 序列号作为时间戳
    设置(审计_缓冲, base + 3, 结果)
    审计_头 = 审计_头 + 1
    审计_总数 = 审计_总数 + 1
}

// Seccomp过滤 — 系统调用白/黑名单

定义 SECCOMP_允许 = 0
定义 SECCOMP_拒绝 = 1
定义 SECCOMP_日志 = 2       // 允许但记录日志

定义 可变 seccomp_启用 = 假
定义 可变 seccomp_规则 = []    // 每个系统调用的策略
定义 可变 seccomp_拒绝数 = 0

函数 seccomp_初始化() {
    seccomp_规则 = []
    定义 可变 i = 0
    当 (i < 最大系统调用) {
        追加(seccomp_规则, SECCOMP_允许)  // 默认允许
        i = i + 1
    }
    seccomp_启用 = 真
}

函数 seccomp_设置规则(号, 策略) {
    如果 (号 >= 0 && 号 < 最大系统调用) {
        设置(seccomp_规则, 号, 策略)
    }
}

函数 seccomp_检查(号) {
    如果 (!seccomp_启用) { 返回 SECCOMP_允许 }
    如果 (号 < 0 || 号 >= 最大系统调用) { 返回 SECCOMP_拒绝 }
    定义 策略 = seccomp_规则[号]
    如果 (策略 == SECCOMP_拒绝) { seccomp_拒绝数 = seccomp_拒绝数 + 1 }
    返回 策略
}

// 速率限制 — 防止系统调用洪泛

定义 可变 速率_窗口开始 = 0
定义 可变 速率_窗口计数 = 0
定义 可变 速率_限制 = 100000        // 每秒最大8万次系统调用
定义 可变 速率_窗口_ms = 1000       // 窗口大小(ms)
定义 可变 速率_被限次数 = 0

函数 系统调用_速率检查() {
    定义 现在 = 读取毫秒()
    如果 (现在 - 速率_窗口开始 >= 速率_窗口_ms) {
        // 新窗口
        速率_窗口开始 = 现在
        速率_窗口计数 = 0
    }
    速率_窗口计数 = 速率_窗口计数 + 1
    如果 (速率_窗口计数 > 速率_限制) {
        速率_被限次数 = 速率_被限次数 + 1
        返回 假  // 被限制
    }
    返回 真  // 允许
}

// 的Top-K热点系统调用

函数 系统调用_热点Top5() {
    // 返回调用次数最多的5个系统调用
    定义 可变 top = [0, 0, 0, 0, 0]
    定义 可变 top值 = [0, 0, 0, 0, 0]
    定义 可变 i = 0
    当 (i < 最大系统调用) {
        如果 (系统调用计数[i] > top值[4]) {
            // 插入到正确位置
            定义 可变 j = 4
            当 (j > 0 && 系统调用计数[i] > top值[j - 1]) { j = j - 1 }
            // 后移
            定义 可变 k = 4
            当 (k > j) { top[k] = top[k - 1]; top值[k] = top值[k - 1]; k = k - 1 }
            top[j] = i
            top值[j] = 系统调用计数[i]
        }
        i = i + 1
    }
    返回 [top, top值]
}

// 完整诊断统计

函数 系统调用表_完整统计() {
    返回 {
        总调用数: 系统调用_总次数,
        未注册: 系统调用_未注册次数,
        已注册: 系统调用_已注册数(),
        审计总数: 审计_总数,
        seccomp拒绝: seccomp_拒绝数,
        被限速次数: 速率_被限次数
    }
}

// §7 重置与存取器

函数 系统调用_重置统计() {
    系统调用_总次数 = 0
    系统调用_未注册次数 = 0
    审计_总数 = 0
    seccomp_拒绝数 = 0
    速率_被限次数 = 0
    速率_窗口计数 = 0
    定义 可变 i = 0
    当 (i < 最大系统调用) {
        系统调用计数[i] = 0
        i = i + 1
    }
}

函数 系统调用_获取总数() { 返回 系统调用_总次数 }
函数 系统调用_获取未注册数() { 返回 系统调用_未注册次数 }
函数 系统调用_获取审计数() { 返回 审计_总数 }
函数 系统调用_获取拒绝数() { 返回 seccomp_拒绝数 }
函数 系统调用_获取限速数() { 返回 速率_被限次数 }

函数 系统调用_健康检查() {
    定义 可变 问题 = 0
    // 检查未注册率
    如果 (系统调用_总次数 > 100) {
        定义 未注册率 = 系统调用_未注册次数 * 100 / 系统调用_总次数
        如果 (未注册率 > 20) { 问题 = 问题 + 1 }
    }
    // 检查seccomp拒绝率
    如果 (seccomp_拒绝数 > 系统调用_总次数 / 10) { 问题 = 问题 + 1 }
    // 检查限速异常
    如果 (速率_被限次数 > 100) { 问题 = 问题 + 1 }
    返回 问题 == 0
}

函数 系统调用_打印统计() {
    打印行("=== 系统调用表统计 ===")
    打印行("总调用: " + 整数转字符串(系统调用_总次数))
    打印行("未注册: " + 整数转字符串(系统调用_未注册次数))
    打印行("已注册: " + 整数转字符串(系统调用_已注册数()))
    打印行("审计: " + 整数转字符串(审计_总数))
    打印行("seccomp拒绝: " + 整数转字符串(seccomp_拒绝数))
    打印行("限速: " + 整数转字符串(速率_被限次数))
}

// ◆ SDT 理论 — Syscall Dispatch Table
//   公理1: 系统调用是用户态到内核态的受控入口映射
//   公理2: Seccomp策略实现白/黑名单安全过滤
//   公理3: 速率限制防止系统调用洪泛攻击
//   定理: 审计+Seccomp+限速三层防御使恶意调用成功率趋近零
//         P(exploit|审计∧seccomp∧限速) → 0

函数 系统调用表_统计() {
    返回 {
        系统调用计数: 计数(系统调用计数),
        系统调用总次数: 系统调用_总次数,
        系统调用总计数: 系统调用_总计数,
        系统调用未注册次数: 系统调用_未注册次数,
        审计总数: 审计_总数,
        速率窗口计数: 速率_窗口计数,
        速率被限次数: 速率_被限次数
    }
}

函数 系统调用表_健康评估() {
    定义 可变 问题 = []
    // 未注册调用率: 大量未注册调用说明有非法系统调用尝试
    如果 (系统调用_总次数 > 100 && 系统调用_未注册次数 * 100 / 系统调用_总次数 > 5) { 追加(问题, "未注册系统调用比例过高") }
    // 速率限制触发: 被限次数占窗口计数比例过高说明系统调用洪泛
    如果 (速率_窗口计数 > 100 && 速率_被限次数 * 100 / 速率_窗口计数 > 20) { 追加(问题, "系统调用速率限制触发频繁") }
    // 审计缓冲膨胀
    如果 (计数(审计_缓冲) > 10000) { 追加(问题, "审计缓冲膨胀") }
    返回 计数(问题) == 0
}

函数 系统调用表_综合报告() {
    打印("[系统调用表] ═══ 综合报告 ═══")
    打印("  系统调用计数: " + 整数转字符串(计数(系统调用计数)))
    打印("  系统调用_总次数: " + 整数转字符串(系统调用_总次数))
    打印("  系统调用_总计数: " + 整数转字符串(系统调用_总计数))
    打印("  系统调用_未注册次数: " + 整数转字符串(系统调用_未注册次数))
    打印("  审计_总数: " + 整数转字符串(审计_总数))
    打印("  速率_窗口计数: " + 整数转字符串(速率_窗口计数))
    打印("  速率_被限次数: " + 整数转字符串(速率_被限次数))
    打印("  健康: " + 如果 (系统调用表_健康评估()) { "正常" } 否则 { "异常" })
}

函数 系统调用表_全局重置() {
    系统调用计数 = []
    系统调用_总次数 = 0
    系统调用_总计数 = 0
    系统调用_未注册次数 = 0
    审计_总数 = 0
    速率_窗口计数 = 0
    速率_被限次数 = 0
    打印("[系统调用表] 统计已重置")
    返回 0
}

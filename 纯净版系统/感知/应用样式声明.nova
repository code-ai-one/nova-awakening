// §3 应用CSS声明到Computed样式
// (对应 样式Resolver::ApplyMatchedProperties)

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/整数转字符串.nova")

函数 Computed样式_应用声明(style, 声明) {
 定义 属性 = 声明.属性ID
 定义 值 = 声明.值
 如果 (值 == 0) { 返回 }

 如果 (属性 == CSS属性_display) {
 如果 (值.类型 == CSS值_关键字) {
 如果 (值.关键字ID == 5) { style.display = Display_none }
 否则 如果 (值.关键字ID == 6) { style.display = Display_block }
 否则 如果 (值.关键字ID == 7) { style.display = Display_inline }
 否则 如果 (值.关键字ID == 8) { style.display = Display_inline_block }
 否则 如果 (值.关键字ID == 9) { style.display = Display_flex }
 否则 如果 (值.关键字ID == 10) { style.display = Display_grid }
 }
 }
 否则 如果 (属性 == CSS属性_position) {
 如果 (值.类型 == CSS值_关键字) {
 如果 (值.关键字ID == 17) { style.position = Position_static }
 否则 如果 (值.关键字ID == 13) { style.position = Position_relative }
 否则 如果 (值.关键字ID == 14) { style.position = Position_absolute }
 否则 如果 (值.关键字ID == 15) { style.position = Position_fixed }
 否则 如果 (值.关键字ID == 16) { style.position = Position_sticky }
 }
 }
 否则 如果 (属性 == CSS属性_width) { style.width = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_height) { style.height = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_min_width) { style.min_width = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_max_width) { style.max_width = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_min_height) { style.min_height = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_max_height) { style.max_height = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_margin_top) { style.margin_top = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_margin_right) { style.margin_right = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_margin_bottom) { style.margin_bottom = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_margin_left) { style.margin_left = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_padding_top) { style.padding_top = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_padding_right) { style.padding_right = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_padding_bottom) { style.padding_bottom = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_padding_left) { style.padding_left = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_top) { style.top = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_right) { style.right_pos = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_bottom) { style.bottom = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_left) { style.left_pos = Computed样式_解析长度值(值) }
 否则 如果 (属性 == CSS属性_color) {
 如果 (值.类型 == CSS值_颜色) { style.color = 值.颜色 }
 }
 否则 如果 (属性 == CSS属性_background_color) {
 如果 (值.类型 == CSS值_颜色) { style.background_color = 值.颜色 }
 }
 否则 如果 (属性 == CSS属性_font_size) {
 如果 (值.类型 == CSS值_长度) { style.font_size = 值.数值 }
 否则 如果 (值.类型 == CSS值_数字) { style.font_size = 值.数值 }
 }
 否则 如果 (属性 == CSS属性_font_weight) {
 如果 (值.类型 == CSS值_数字) { style.font_weight = 值.数值 / 100 }
 否则 如果 (值.类型 == CSS值_关键字 && 值.关键字ID == 21) { style.font_weight = 700 }
 否则 如果 (值.类型 == CSS值_关键字 && 值.关键字ID == 22) { style.font_weight = 400 }
 }
 否则 如果 (属性 == CSS属性_text_align) {
 如果 (值.关键字ID == 18) { style.text_align = TextAlign_center }
 否则 如果 (值.关键字ID == 19) { style.text_align = TextAlign_left }
 否则 如果 (值.关键字ID == 20) { style.text_align = TextAlign_right }
 }
 否则 如果 (属性 == CSS属性_opacity) {
 如果 (值.类型 == CSS值_数字) { style.opacity = 值.数值 }
 }
 否则 如果 (属性 == CSS属性_z_index) {
 如果 (值.类型 == CSS值_数字) {
 style.z_index = 值.数值 / 100
 style.z_index_auto = 假
 }
 否则 如果 (值.类型 == CSS值_关键字 && 值.关键字ID == 4) {
 style.z_index_auto = 真
 }
 }
 否则 如果 (属性 == CSS属性_overflow) {
 如果 (值.关键字ID == 11) { style.overflow_x = Overflow_hidden; style.overflow_y = Overflow_hidden }
 否则 如果 (值.关键字ID == 12) { style.overflow_x = Overflow_visible; style.overflow_y = Overflow_visible }
 }
 否则 如果 (属性 == CSS属性_flex_direction) {
 如果 (值.关键字ID == 23) { style.flex_direction = 弹性Dir_row }
 否则 如果 (值.关键字ID == 24) { style.flex_direction = 弹性Dir_column }
 }
 否则 如果 (属性 == CSS属性_justify_content) {
 如果 (值.关键字ID == 18) { style.justify_content = JC_center }
 否则 如果 (值.关键字ID == 27) { style.justify_content = JC_space_between }
 否则 如果 (值.关键字ID == 28) { style.justify_content = JC_space_around }
 }
 否则 如果 (属性 == CSS属性_align_items) {
 如果 (值.关键字ID == 18) { style.align_items = JC_center }
 否则 如果 (值.关键字ID == 29) { style.align_items = JC_stretch }
 }
 否则 如果 (属性 == CSS属性_gap) {
 如果 (值.类型 == CSS值_长度) { style.gap = 值.数值 }
 }
 否则 如果 (属性 == CSS属性_box_sizing) {
 如果 (值.关键字ID == 31) { style.box_sizing = BoxSizing_border }
 否则 如果 (值.关键字ID == 32) { style.box_sizing = BoxSizing_content }
 }
 否则 如果 (属性 == CSS属性_border_radius) {
 如果 (值.类型 == CSS值_长度) {
 style.border_radius_tl = 值.数值
 style.border_radius_tr = 值.数值
 style.border_radius_bl = 值.数值
 style.border_radius_br = 值.数值
 }
 }
 否则 如果 (属性 == CSS属性_visibility) {
 如果 (值.关键字ID == 12) { style.visibility = Visibility_visible }
 否则 如果 (值.关键字ID == 11) { style.visibility = Visibility_hidden }
 }
 否则 如果 (属性 == CSS属性_line_height) {
 如果 (值.类型 == CSS值_长度) { style.line_height = 值.数值 }
 否则 如果 (值.类型 == CSS值_数字) { style.line_height = 值.数值 * style.font_size / 100 }
 }
 否则 如果 (属性 == CSS属性_font_family) {
 如果 (值.字符串值 != 0) { style.font_family = 值.字符串值 }
 }
 否则 如果 (属性 == CSS属性_cursor) {
 如果 (值.关键字ID == 30) { style.cursor = 30 }
 }
}

函数 Computed样式_解析长度值(值) {
 如果 (值.类型 == CSS值_长度) {
 返回 计算长度_px(值.数值)
 }
 如果 (值.类型 == CSS值_百分比) {
 定义 l = 计算长度 {}
 l.值 = 值.数值; l.是auto = 假; l.单位 = 单位_百分比
 返回 l
 }
 如果 (值.类型 == CSS值_数字 && 值.数值 == 0) {
 返回 计算长度_零()
 }
 如果 (值.类型 == CSS值_关键字) {
 如果 (值.关键字ID == 4) { 返回 计算长度_auto() }
 }
 返回 计算长度_auto()
}


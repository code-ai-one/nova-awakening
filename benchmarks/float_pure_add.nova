// 测试: 有无浮点字面量除法的加法对比
函数 主程序() {
    // 无小数的加法 (整数部) — 不走浮点构造
    定义 a = 7.0
    定义 b = 0.0
    打印(字符串拼接("7.0+0.0=", 转字符串(a + b)))
    
    // 整数转浮点 (无除法)
    定义 c = 6.0
    定义 d = 1.0
    打印(字符串拼接("6.0+1.0=", 转字符串(c + d)))
    // 期望 7.0 bits = 4620693217682128896

    // 单小数位 (除以 10)
    定义 e = 6.3
    定义 f = 0.7
    打印(字符串拼接("6.3+0.7=", 转字符串(e + f)))
    // 期望 7.0 bits
    
    // 两位小数 (除以 100)
    定义 g = 6.33
    定义 h = 0.67
    打印(字符串拼接("6.33+0.67=", 转字符串(g + h)))
    // 期望 7.0 bits
    
    // 三位小数 (除以 1000)
    定义 i = 6.333
    定义 j = 0.667
    打印(字符串拼接("6.333+0.667=", 转字符串(i + j)))
    // 期望 ~7.0 bits
    返回 0
}

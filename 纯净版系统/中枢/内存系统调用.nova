//   1. brk: 调整堆顶(program break), 最简单的内存分配方式
//   2. Nova内存映射: 虚拟地址空间映射(匿名/文件), VMA管理
//   3. munmap: 解除映射, 拆分/合并VMA
//   4. mprotect: 改变已有映射的保护位

导入("./系统调用表.nova")
导入("./错误码.nova")
导入("./日志中枢.nova")
导入("./进程任务.nova")
导入("./内存虚拟.nova")
导入("./链表后继.nova")
导入("../记忆/文件描述符.nova")
导入("./自动扩容.nova")
导入("./字符串替换.nova")
导入("./每处理器.nova")

定义 PROT_NONE  = 0x0
定义 PROT_READ  = 0x1
定义 PROT_WRITE = 0x2
定义 PROT_EXEC  = 0x4

定义 MAP_SHARED    = 0x01     // 共享映射(对文件的修改可见)
定义 MAP_PRIVATE   = 0x02     // 私有映射(COW)
定义 MAP_FIXED     = 0x10     // 精确地址(覆盖已有映射)
定义 MAP_ANONYMOUS = 0x20     // 匿名映射(不关联文件)
定义 MAP_GROWSDOWN = 0x0100   // 栈式向下增长
定义 MAP_POPULATE  = 0x8000   // 预先分配物理页

定义 VMA_FLAG_锁定    = 0x10000000
定义 VMA_FLAG_可释放  = 0x20000000
定义 VMA_FLAG_已预分配 = 0x40000000

定义 PAGE_SIZE  = 4096
定义 PAGE_SHIFT = 12
定义 PAGE_MASK  = ~(PAGE_SIZE - 1)

定义 可变 Nova内存映射_总次数 = 0
定义 可变 munmap_总次数 = 0
定义 可变 brk_总次数 = 0

// sys_brk: 调整堆顶
// brk(0): 返回当前堆顶
// brk(新地址): 尝试将堆顶移到新地址

函数 sys_brk(新断点, _b, _c, _d, _e, _f) {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 0 }
    定义 mm = 进程_mm(当前)
    如果 (mm == 空) { 返回 0 }

    定义 当前brk = mm_brk(mm)

    // brk(0): 查询当前堆顶
    如果 (新断点 == 0) { 返回 当前brk }

    // 对齐到页边界
    定义 新brk = 页对齐上(新断点)
    定义 旧brk = 页对齐上(当前brk)

    // 不能低于堆起始位置
    如果 (新brk < mm_brk_start(mm)) { 返回 当前brk }

    // 检查是否超过RLIMIT_DATA
    定义 数据限制 = 进程_资源限制(当前, RLIMIT_DATA)
    如果 (数据限制 > 0 && (新brk - mm_brk_start(mm)) > 数据限制) {
        返回 当前brk
    }

    如果 (新brk > 旧brk) {
        // 扩展堆: 创建新的匿名VMA
        定义 大小 = 新brk - 旧brk
        定义 结果 = do_brk_expand(mm, 旧brk, 大小)
        如果 (结果 < 0) { 返回 当前brk }
    } 否则 如果 (新brk < 旧brk) {
        // 收缩堆: 释放多余页
        do_brk_shrink(mm, 新brk, 旧brk - 新brk)
    }

    mm_设置brk(mm, 新断点)
    brk_总次数 = brk_总次数 + 1
    返回 新断点
}

函数 do_brk_expand(mm, 地址, 大小) {
    // 检查地址空间是否有足够空间
    如果 (VMA_查找重叠(mm, 地址, 地址 + 大小) != 空) {
        返回 错误_内存不足
    }
    // 创建匿名VMA
    定义 vma = VMA_创建(地址, 地址 + 大小, PROT_READ | PROT_WRITE, MAP_PRIVATE | MAP_ANONYMOUS)
    VMA_插入(mm, vma)
    返回 成功
}

函数 do_brk_shrink(mm, 地址, 大小) {
    VMA_解除映射(mm, 地址, 大小)
    返回 成功
}

// sys_Nova内存映射: 创建内存映射

函数 sys_Nova内存映射(地址, 长度, 保护, 标志, fd, 偏移) {
    如果 (长度 == 0) { 返回 错误_无效参数 }

    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 错误_坏文件描述符 }
    定义 mm = 进程_mm(当前)
    如果 (mm == 空) { 返回 错误_内存不足 }

    // 对齐长度到页边界
    定义 对齐长度 = 页对齐上(长度)

    // 标志验证: MAP_SHARED和MAP_PRIVATE必须二选一
    如果 ((标志 & MAP_SHARED) != 0 && (标志 & MAP_PRIVATE) != 0) {
        返回 错误_无效参数
    }
    如果 ((标志 & MAP_SHARED) == 0 && (标志 & MAP_PRIVATE) == 0) {
        返回 错误_无效参数
    }

    // 文件映射: fd必须有效
    定义 可变 文件 = 空
    如果 ((标志 & MAP_ANONYMOUS) == 0) {
        文件 = 进程_获取文件(当前, fd)
        如果 (文件 == 空) { 返回 错误_坏文件描述符 }
        // 检查文件是否可读
        如果 ((保护 & PROT_READ) != 0 && !文件_可读(文件)) {
            返回 错误_权限
        }
        如果 ((保护 & PROT_WRITE) != 0 && !文件_可写(文件)) {
            返回 错误_权限
        }
    }

    // 查找空闲虚拟地址区域
    定义 可变 映射地址 = 地址
    如果 ((标志 & MAP_FIXED) != 0) {
        // MAP_FIXED: 精确使用指定地址, 先解除已有映射
        如果 (映射地址 & (PAGE_SIZE - 1) != 0) { 返回 错误_无效参数 }
        VMA_解除映射(mm, 映射地址, 对齐长度)
    } 否则 {
        // 查找空闲地址
        映射地址 = VMA_查找空闲(mm, 地址, 对齐长度)
        如果 (映射地址 == 0) { 返回 错误_内存不足 }
    }

    // 创建VMA
    定义 vma = VMA_创建(映射地址, 映射地址 + 对齐长度, 保护, 标志)
    如果 (文件 != 空) {
        VMA_设置文件(vma, 文件, 偏移)
    }
    VMA_插入(mm, vma)

    // MAP_POPULATE: 预先分配物理页
    如果 ((标志 & MAP_POPULATE) != 0) {
        VMA_预分配(mm, 映射地址, 对齐长度)
    }

    Nova内存映射_总次数 = Nova内存映射_总次数 + 1
    返回 映射地址
}

// sys_munmap: 解除内存映射

函数 sys_munmap(地址, 长度, _c, _d, _e, _f) {
    如果 (长度 == 0) { 返回 错误_无效参数 }
    如果 (地址 & (PAGE_SIZE - 1) != 0) { 返回 错误_无效参数 }

    定义 当前 = 获取当前进程()
    定义 mm = 进程_mm(当前)
    如果 (mm == 空) { 返回 错误_内存不足 }

    定义 对齐长度 = 页对齐上(长度)
    定义 结果 = VMA_解除映射(mm, 地址, 对齐长度)
    如果 (结果 < 0) { 返回 结果 }

    munmap_总次数 = munmap_总次数 + 1
    返回 成功
}

// sys_mprotect: 改变映射保护位

函数 sys_mprotect(地址, 长度, 保护, _d, _e, _f) {
    如果 (地址 & (PAGE_SIZE - 1) != 0) { 返回 错误_无效参数 }
    如果 (长度 == 0) { 返回 错误_无效参数 }

    定义 当前 = 获取当前进程()
    定义 mm = 进程_mm(当前)
    如果 (mm == 空) { 返回 错误_内存不足 }

    定义 对齐长度 = 页对齐上(长度)

    // 查找覆盖该范围的VMA
    定义 vma = VMA_查找(mm, 地址)
    如果 (vma == 空) { 返回 错误_内存不足 }

    // 如果保护位改变, 需要拆分VMA(如果只改了部分)
    如果 (VMA_起始(vma) < 地址) {
        VMA_拆分(mm, vma, 地址)
        vma = VMA_查找(mm, 地址)
    }
    如果 (VMA_结束(vma) > 地址 + 对齐长度) {
        VMA_拆分(mm, vma, 地址 + 对齐长度)
    }

    // 更新VMA保护位
    VMA_设置保护(vma, 保护)

    // 刷新页表项的保护位
    VMA_更新页表保护(mm, 地址, 对齐长度, 保护)

    返回 成功
}

// 辅助函数

定义 RLIMIT_DATA = 2    // 数据段大小限制

函数 页对齐上(地址) {
    返回 (地址 + PAGE_SIZE - 1) & PAGE_MASK
}

函数 页对齐下(地址) {
    返回 地址 & PAGE_MASK
}

函数 注册内存系统调用() {
    系统调用表_注册(9, 系统调用_mmap)
    系统调用表_注册(11, 系统调用_munmap)
    系统调用表_注册(12, 系统调用_brk)
}

函数 内存系统调用_统计() {
    返回 [brk_总次数, Nova内存映射_总次数, munmap_总次数]
}


// sys_madvise: 内存使用建议

定义 MADV_NORMAL     = 0
定义 MADV_RANDOM     = 1
定义 MADV_SEQUENTIAL = 2
定义 MADV_WILLNEED   = 3
定义 MADV_DONTNEED   = 4
定义 MADV_FREE       = 8
定义 MADV_HUGEPAGE   = 14

定义 可变 madvise_总次数 = 0
定义 可变 mprotect_总次数 = 0
定义 可变 mlock_总次数 = 0
定义 可变 内存系统调用_错误数 = 0
定义 可变 内存系统调用_已初始化 = 假

函数 sys_madvise(地址, 长度, 建议, _d, _e, _f) {
    如果 (地址 & (PAGE_SIZE - 1) != 0) { 返回 错误_无效参数 }
    如果 (长度 == 0) { 返回 错误_无效参数 }
    定义 当前 = 获取当前进程()
    定义 mm = 进程_mm(当前)
    如果 (mm == 空) { 返回 错误_内存不足 }
    定义 对齐长度 = 页对齐上(长度)
    // 按建议类型处理
    如果 (建议 == MADV_DONTNEED) {
        // 释放物理页但保留VMA
        VMA_释放物理页(mm, 地址, 对齐长度)
    } 否则 如果 (建议 == MADV_WILLNEED) {
        // 预读: 触发缺页预分配
        VMA_预分配(mm, 地址, 对齐长度)
    } 否则 如果 (建议 == MADV_FREE) {
        // 标记页为可释放(惰性回收)
        VMA_标记可释放(mm, 地址, 对齐长度)
    }
    madvise_总次数 = madvise_总次数 + 1
    返回 0
}

// sys_msync: 同步映射到磁盘

定义 MS_ASYNC  = 1
定义 MS_SYNC   = 4
定义 MS_INVALIDATE = 2

定义 可变 msync_总次数 = 0

函数 sys_msync(地址, 长度, 标志, _d, _e, _f) {
    如果 (地址 & (PAGE_SIZE - 1) != 0) { 返回 错误_无效参数 }
    如果 (长度 == 0) { 返回 错误_无效参数 }
    定义 当前 = 获取当前进程()
    定义 mm = 进程_mm(当前)
    如果 (mm == 空) { 返回 错误_内存不足 }
    // 查找文件映射VMA并刷盘
    定义 vma = VMA_查找(mm, 地址)
    如果 (vma == 空) { 返回 错误_内存不足 }
    如果 (VMA_是匿名(vma)) { 返回 0 }
    // 同步到磁盘
    // VMA_同步文件(vma, 地址, 页对齐上(长度))
    msync_总次数 = msync_总次数 + 1
    返回 0
}

// sys_mlock/munlock: 锁定/解锁内存(防止交换)

函数 sys_mlock(地址, 长度, _c, _d, _e, _f) {
    如果 (地址 & (PAGE_SIZE - 1) != 0) { 返回 错误_无效参数 }
    如果 (长度 == 0) { 返回 错误_无效参数 }
    定义 当前 = 获取当前进程()
    定义 mm = 进程_mm(当前)
    如果 (mm == 空) { 返回 错误_内存不足 }
    // 检查RLIMIT_MEMLOCK限制
    // 标记VMA为VM_LOCKED
    定义 vma = VMA_查找(mm, 地址)
    如果 (vma == 空) { 返回 错误_内存不足 }
    VMA_设置锁定(vma, 真)
    // 立即分配所有物理页
    VMA_预分配(mm, 地址, 页对齐上(长度))
    mlock_总次数 = mlock_总次数 + 1
    返回 0
}

函数 sys_munlock(地址, 长度, _c, _d, _e, _f) {
    如果 (地址 & (PAGE_SIZE - 1) != 0) { 返回 错误_无效参数 }
    定义 当前 = 获取当前进程()
    定义 mm = 进程_mm(当前)
    如果 (mm == 空) { 返回 错误_内存不足 }
    定义 vma = VMA_查找(mm, 地址)
    如果 (vma == 空) { 返回 错误_内存不足 }
    VMA_设置锁定(vma, 假)
    返回 0
}

// mm_struct辅助

函数 mm_brk(mm) {
    如果 (mm == 空) { 返回 0 }
    返回 mm.堆止
}

函数 mm_brk_start(mm) {
    如果 (mm == 空) { 返回 0 }
    返回 mm.堆起
}

函数 mm_设置brk(mm, 新值) {
    如果 (mm == 空) { 返回 }
    mm.堆止 = 新值
}

函数 进程_mm(进程) {
    如果 (进程 == 空) { 返回 空 }
    返回 进程[13]
}

函数 进程_资源限制(进程, 类型) {
    如果 (进程 == 空) { 返回 0 }
    定义 档 = 进程任务_查按PID(进程_PID(进程))
    如果 (档 == 空 || 档.限制 == 空) { 返回 0 }
    如果 (类型 < 0 || 类型 >= 计数(档.限制)) { 返回 0 }
    返回 档.限制[类型].soft
}

函数 进程_获取文件(进程, fd) {
    如果 (进程 == 空 || fd < 0) { 返回 空 }
    定义 文件表 = 进程_文件表(进程)
    如果 (文件表 == 空) { 返回 空 }
    返回 文件表_获取(文件表, fd)
}

函数 文件_可读(文件) {
    如果 (文件 == 空) { 返回 假 }
    返回 文件描述符_可读(文件)
}

函数 文件_可写(文件) {
    如果 (文件 == 空) { 返回 假 }
    返回 文件描述符_可写(文件)
}

// VMA辅助函数桥接

函数 VMA_创建(起始, 结束, 保护, 标志) {
    返回 [起始, 结束, 保护, 标志, 空, 0]
}

函数 VMA_插入(mm, vma) {
    如果 (mm == 空 || vma == 空) { 返回 }
    如果 (mm.VMA链 == 空) { mm.VMA链 = 链表_创建() }
    定义 可变 当前 = 链表_首节点_或空(mm.VMA链)
    当 (当前 != 空) {
        定义 现有 = 链表_数据(当前)
        如果 (VMA_起始(现有) > VMA_起始(vma)) {
            链表_插入前(当前, vma)
            mm.VMA数 = mm.VMA数 + 1
            返回
        }
        当前 = 链表_后继(当前)
    }
    链表_尾插(mm.VMA链, vma)
    mm.VMA数 = mm.VMA数 + 1
}

函数 VMA_解除映射(mm, 地址, 大小) {
    如果 (mm == 空 || mm.VMA链 == 空) { 返回 错误_无效参数 }
    如果 (大小 <= 0) { 返回 错误_无效参数 }

    定义 结束 = 地址 + 大小
    定义 可变 当前 = 链表_首节点_或空(mm.VMA链)
    定义 可变 命中 = 假
    当 (当前 != 空) {
        定义 下一个 = 链表_后继(当前)
        定义 vma = 链表_数据(当前)
        如果 (VMA_结束(vma) <= 地址 || VMA_起始(vma) >= 结束) {
            当前 = 下一个
            继续
        }
        命中 = 真
        如果 (地址 <= VMA_起始(vma) && 结束 >= VMA_结束(vma)) {
            mm.VMA数 = mm.VMA数 - 1
            链表_删除(当前)
        } 否则 如果 (地址 > VMA_起始(vma) && 结束 < VMA_结束(vma)) {
            VMA_拆分(mm, vma, 结束)
            vma[1] = 地址
        } 否则 如果 (地址 <= VMA_起始(vma)) {
            定义 旧起始 = VMA_起始(vma)
            vma[0] = 结束
            如果 (vma[4] != 空) {
                vma[5] = vma[5] + ((结束 - 旧起始) / PAGE_SIZE)
            }
        } 否则 {
            vma[1] = 地址
        }
        当前 = 下一个
    }
    如果 (!命中) { 返回 错误_无效参数 }
    返回 成功
}

函数 VMA_查找(mm, 地址) {
    如果 (mm == 空 || mm.VMA链 == 空) { 返回 空 }
    定义 可变 当前 = 链表_首节点_或空(mm.VMA链)
    当 (当前 != 空) {
        定义 vma = 链表_数据(当前)
        如果 (VMA_起始(vma) <= 地址 && 地址 < VMA_结束(vma)) { 返回 vma }
        当前 = 链表_后继(当前)
    }
    返回 空
}

函数 VMA_查找重叠(mm, 起始, 结束) {
    如果 (mm == 空 || mm.VMA链 == 空) { 返回 空 }
    如果 (起始 >= 结束) { 返回 空 }
    定义 可变 当前 = 链表_首节点_或空(mm.VMA链)
    当 (当前 != 空) {
        定义 vma = 链表_数据(当前)
        如果 (起始 < VMA_结束(vma) && 结束 > VMA_起始(vma)) { 返回 vma }
        当前 = 链表_后继(当前)
    }
    返回 空
}

函数 VMA_查找空闲(mm, 建议地址, 大小) {
    如果 (大小 <= 0) { 返回 0 }
    定义 可变 候选 = 建议地址
    如果 (候选 < 0x400000) { 候选 = 0x400000 }
    如果 (mm == 空 || mm.VMA链 == 空) { 返回 候选 }
    定义 可变 当前 = 链表_首节点_或空(mm.VMA链)
    当 (当前 != 空) {
        定义 vma = 链表_数据(当前)
        如果 (候选 + 大小 <= VMA_起始(vma)) { 返回 候选 }
        如果 (VMA_结束(vma) > 候选) { 候选 = VMA_结束(vma) }
        当前 = 链表_后继(当前)
    }
    返回 候选
}

函数 VMA_设置文件(vma, 文件, 偏移) {
    如果 (vma == 空) { 返回 }
    vma[4] = 文件
    vma[5] = 偏移
}

函数 VMA_预分配(mm, 地址, 大小) {
    如果 (mm == 空 || 大小 <= 0) { 返回 错误_无效参数 }
    如果 (mm.VMA链 == 空) { 返回 错误_无效参数 }
    定义 结束 = 地址 + 大小
    定义 可变 当前 = 链表_首节点_或空(mm.VMA链)
    定义 可变 覆盖页数 = 0
    当 (当前 != 空) {
        定义 vma = 链表_数据(当前)
        如果 (VMA_结束(vma) <= 地址 || VMA_起始(vma) >= 结束) {
            当前 = 链表_后继(当前)
            继续
        }
        如果 ((vma[3] & VMA_FLAG_已预分配) == 0) {
            vma[3] = vma[3] | VMA_FLAG_已预分配
            覆盖页数 = 覆盖页数 + VMA_页数(vma)
        }
        当前 = 链表_后继(当前)
    }
    mm.常驻页数 = mm.常驻页数 + 覆盖页数
    返回 成功
}

函数 VMA_拆分(mm, vma, 地址) {
    如果 (mm == 空 || vma == 空) { 返回 空 }
    如果 (地址 <= VMA_起始(vma) || 地址 >= VMA_结束(vma)) { 返回 空 }

    定义 右偏移 = vma[5]
    如果 (vma[4] == 空) {
        右偏移 = 右偏移 + ((地址 - VMA_起始(vma)) / PAGE_SIZE)
    }
    定义 右 = [地址, vma[1], vma[2], vma[3], vma[4], 右偏移]
    vma[1] = 地址

    如果 (mm.VMA链 != 空) {
        定义 节点 = 链表_查找(mm.VMA链, vma)
        如果 (节点 != 空) {
            链表_插入后(节点, 右)
        } 否则 {
            链表_尾插(mm.VMA链, 右)
        }
    } 否则 {
        mm.VMA链 = 链表_创建()
        链表_尾插(mm.VMA链, 右)
    }
    mm.VMA数 = mm.VMA数 + 1
    返回 右
}
函数 VMA_设置保护(vma, 保护) { 如果 (vma != 空) { vma[2] = 保护 } }
函数 VMA_更新页表保护(mm, 地址, 大小, 保护) {
    如果 (mm == 空 || mm.VMA链 == 空) { 返回 错误_无效参数 }
    定义 结束 = 地址 + 大小
    定义 可变 当前 = 链表_首节点_或空(mm.VMA链)
    当 (当前 != 空) {
        定义 vma = 链表_数据(当前)
        如果 (VMA_结束(vma) <= 地址 || VMA_起始(vma) >= 结束) {
            当前 = 链表_后继(当前)
            继续
        }
        vma[2] = 保护
        当前 = 链表_后继(当前)
    }
    返回 成功
}
函数 VMA_起始(vma) { 返回 vma[0] }
函数 VMA_结束(vma) { 返回 vma[1] }
函数 VMA_是匿名(vma) { 如果 (vma == 空) { 返回 真 }; 返回 vma[4] == 空 }
函数 VMA_释放物理页(mm, 地址, 大小) {
    如果 (mm == 空 || mm.VMA链 == 空) { 返回 错误_无效参数 }
    如果 (大小 <= 0) { 返回 错误_无效参数 }
    定义 结束 = 地址 + 大小
    定义 可变 当前 = 链表_首节点_或空(mm.VMA链)
    定义 可变 释放页数 = 0
    当 (当前 != 空) {
        定义 vma = 链表_数据(当前)
        如果 (VMA_结束(vma) <= 地址 || VMA_起始(vma) >= 结束) {
            当前 = 链表_后继(当前)
            继续
        }
        vma[3] = vma[3] | VMA_FLAG_可释放
        如果 ((vma[3] & VMA_FLAG_已预分配) != 0) {
            vma[3] = vma[3] & ~VMA_FLAG_已预分配
            释放页数 = 释放页数 + VMA_页数(vma)
        }
        当前 = 链表_后继(当前)
    }
    如果 (释放页数 > 0) {
        如果 (mm.常驻页数 > 释放页数) { mm.常驻页数 = mm.常驻页数 - 释放页数 }
        否则 { mm.常驻页数 = 0 }
    }
    返回 成功
}

函数 VMA_标记可释放(mm, 地址, 大小) {
    如果 (mm == 空 || mm.VMA链 == 空) { 返回 错误_无效参数 }
    如果 (大小 <= 0) { 返回 错误_无效参数 }
    定义 结束 = 地址 + 大小
    定义 可变 当前 = 链表_首节点_或空(mm.VMA链)
    当 (当前 != 空) {
        定义 vma = 链表_数据(当前)
        如果 (VMA_结束(vma) <= 地址 || VMA_起始(vma) >= 结束) {
            当前 = 链表_后继(当前)
            继续
        }
        vma[3] = vma[3] | VMA_FLAG_可释放
        当前 = 链表_后继(当前)
    }
    返回 成功
}

函数 VMA_设置锁定(vma, 锁定) {
    如果 (vma == 空) { 返回 }
    如果 (锁定) {
        vma[3] = vma[3] | VMA_FLAG_锁定
    } 否则 {
        vma[3] = vma[3] & ~VMA_FLAG_锁定
    }
}

// 完整统计 (≥15个指标)

函数 内存系统调用_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "已初始化", 内存系统调用_已初始化)
    字典设(统计, "brk次数", brk_总次数)
    字典设(统计, "mmap次数", Nova内存映射_总次数)
    字典设(统计, "munmap次数", munmap_总次数)
    字典设(统计, "mprotect次数", mprotect_总次数)
    字典设(统计, "madvise次数", madvise_总次数)
    字典设(统计, "msync次数", msync_总次数)
    字典设(统计, "mlock次数", mlock_总次数)
    字典设(统计, "总操作数", brk_总次数 + Nova内存映射_总次数 + munmap_总次数 + mprotect_总次数 + madvise_总次数 + msync_总次数 + mlock_总次数)
    字典设(统计, "错误数", 内存系统调用_错误数)
    返回 统计
}

函数 内存系统调用_打印统计() {
    定义 统计 = 内存系统调用_完整统计()
    打印("[内存系统调用] ═══════ 完整统计 ═══════")
    打印("  brk:          " + 转字符串(字典取(统计, "brk次数")))
    打印("  mmap:         " + 转字符串(字典取(统计, "mmap次数")))
    打印("  munmap:       " + 转字符串(字典取(统计, "munmap次数")))
    打印("  mprotect:     " + 转字符串(字典取(统计, "mprotect次数")))
    打印("  madvise:      " + 转字符串(字典取(统计, "madvise次数")))
    打印("  msync:        " + 转字符串(字典取(统计, "msync次数")))
    打印("  mlock:        " + 转字符串(字典取(统计, "mlock次数")))
    打印("  总操作:       " + 转字符串(字典取(统计, "总操作数")))
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    打印("[内存系统调用] ═════════════════════════")
    返回 0
}

函数 内存系统调用_dump() {
    打印("[内存系统调用 dump] ──────────────────")
    打印("  brk: " + 转字符串(brk_总次数))
    打印("  mmap: " + 转字符串(Nova内存映射_总次数))
    打印("  munmap: " + 转字符串(munmap_总次数))
    打印("  mprotect: " + 转字符串(mprotect_总次数))
    打印("  madvise: " + 转字符串(madvise_总次数))
    打印("[内存系统调用 dump] ──────────────────")
}

函数 内存系统调用_销毁() {
    brk_总次数 = 0
    Nova内存映射_总次数 = 0
    munmap_总次数 = 0
    mprotect_总次数 = 0
    madvise_总次数 = 0
    msync_总次数 = 0
    mlock_总次数 = 0
    内存系统调用_已初始化 = 假
    返回 0
}

函数 内存系统调用_为procfs提供统计() {
    返回 [brk_总次数, Nova内存映射_总次数, munmap_总次数, mprotect_总次数, madvise_总次数]
}

函数 内存系统调用_重置统计() {
    brk_总次数 = 0
    Nova内存映射_总次数 = 0
    munmap_总次数 = 0
    mprotect_总次数 = 0
    madvise_总次数 = 0
    msync_总次数 = 0
    mlock_总次数 = 0
    内存系统调用_错误数 = 0
    打印("[内存系统调用] 统计已重置")
    返回 0
}

函数 系统调用表_注册(号, 函数) {
    如果 (号 < 0 || 号 >= 512) { 返回 -1 }
    内存_写64(系统调用表 + 号 * 8, 函数)
    返回 0
}

函数 内存系统调用_健康评估() {
    定义 可变 问题 = []
    如果 (内存系统调用_错误数 > 100) { 追加(问题, "内存系统调用_错误数=" + 内存系统调用_错误数) }
    返回 计数(问题) == 0
}

函数 内存系统调用_综合报告() {
    打印("[内存系统调用] ═══ 综合报告 ═══")
    打印("  Nova内存映射_总次数: " + Nova内存映射_总次数)
    打印("  munmap_总次数: " + munmap_总次数)
    打印("  brk_总次数: " + brk_总次数)
    打印("  madvise_总次数: " + madvise_总次数)
    打印("  mprotect_总次数: " + mprotect_总次数)
    打印("  mlock_总次数: " + mlock_总次数)
    打印("  内存系统调用_错误数: " + 内存系统调用_错误数)
    打印("  内存系统调用_已初始化: " + 内存系统调用_已初始化)
    打印("  msync_总次数: " + msync_总次数)
    打印("  健康: " + 如果 (内存系统调用_健康评估()) { "正常" } 否则 { "异常" })
}

函数 内存系统调用_全局重置() {
    Nova内存映射_总次数 = 0
    munmap_总次数 = 0
    brk_总次数 = 0
    madvise_总次数 = 0
    mprotect_总次数 = 0
    mlock_总次数 = 0
    内存系统调用_错误数 = 0
    内存系统调用_已初始化 = 0
    msync_总次数 = 0
    打印("[内存系统调用] 统计已重置")
    返回 0
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./哈希整数.nova")
导入("../感知/内核直连层.nova")
导入("./创建甲.nova")

定义 最大缓冲 = 32
定义 最大模块 = 64
定义 模块_加载中 = 0
定义 模块_活跃 = 1
定义 模块_卸载中 = 2
定义 模块_已卸载 = 3

结构 双缓冲项 {
    名称哈希,
    活跃指针,
    备用指针,
    大小,
    切换次数,
    最近切换,
}

结构 热更新模块 {
    名称哈希,
    代码指针,
    代码大小,
    状态,
    加载时刻,
    引用计数,
}

定义 可变 缓冲表 = []
定义 可变 缓冲数 = 0
定义 可变 模块表 = []
定义 可变 模块数 = 0
定义 可变 切换总数 = 0
定义 可变 加载总数 = 0
定义 可变 卸载总数 = 0
定义 可变 回滚总数 = 0

函数 热更新_初始化() {
    缓冲表 = []
    缓冲数 = 0
    模块表 = []
    模块数 = 0
}

函数 热更新_注册缓冲(名称, 初始指针, 大小) {
    如果 (缓冲数 >= 最大缓冲) { 返回 -1 }
    定义 项 = 双缓冲项 {}
    项.名称哈希 = 哈希_字符串(名称)
    项.活跃指针 = 初始指针
    项.备用指针 = 堆_分配(大小)
    项.大小 = 大小
    项.切换次数 = 0
    项.最近切换 = 0
    追加(缓冲表, 项)
    定义 索引 = 缓冲数
    缓冲数 = 缓冲数 + 1
    返回 索引
}

函数 热更新_获取活跃(名称) {
    定义 目标 = 哈希_字符串(名称)
    定义 可变 序号 = 0
    当 (序号 < 缓冲数) {
        如果 (缓冲表[序号].名称哈希 == 目标) { 返回 缓冲表[序号].活跃指针 }
        序号 = 序号 + 1
    }
    返回 0
}

函数 热更新_获取备用(名称) {
    定义 目标 = 哈希_字符串(名称)
    定义 可变 序号 = 0
    当 (序号 < 缓冲数) {
        如果 (缓冲表[序号].名称哈希 == 目标) { 返回 缓冲表[序号].备用指针 }
        序号 = 序号 + 1
    }
    返回 0
}

函数 热更新_原子切换(名称) {
    定义 目标 = 哈希_字符串(名称)
    定义 可变 序号 = 0
    当 (序号 < 缓冲数) {
        如果 (缓冲表[序号].名称哈希 == 目标) {
            切换总数 = 切换总数 + 1
            定义 临时 = 缓冲表[序号].活跃指针
            缓冲表[序号].活跃指针 = 缓冲表[序号].备用指针
            缓冲表[序号].备用指针 = 临时
            缓冲表[序号].切换次数 = 缓冲表[序号].切换次数 + 1
            缓冲表[序号].最近切换 = 平台_获取高精度时间()
            返回 0
        }
        序号 = 序号 + 1
    }
    返回 错误_不存在
}

函数 热更新_加载模块(名称, 代码, 大小) {
    如果 (模块数 >= 最大模块) { 返回 -1 }
    加载总数 = 加载总数 + 1
    定义 模块 = 热更新模块 {}
    模块.名称哈希 = 哈希_字符串(名称)
    模块.代码指针 = 堆_分配(大小)
    如果 (大小 > 104857600) { 返回 -1 }  // 100MB安全上限
    内存_复制(模块.代码指针, 代码, 大小)
    模块.代码大小 = 大小
    模块.状态 = 模块_活跃
    模块.加载时刻 = 平台_获取高精度时间()
    模块.引用计数 = 0
    追加(模块表, 模块)
    定义 索引 = 模块数
    模块数 = 模块数 + 1
    返回 索引
}

函数 热更新_卸载模块(名称) {
    定义 目标 = 哈希_字符串(名称)
    定义 可变 序号 = 0
    当 (序号 < 模块数) {
        如果 (模块表[序号].名称哈希 == 目标 && 模块表[序号].状态 == 模块_活跃) {
            如果 (模块表[序号].引用计数 > 0) { 返回 错误_忙 }
            模块表[序号].状态 = 模块_已卸载
            堆_释放(模块表[序号].代码指针)
            模块表[序号].代码指针 = 0
            卸载总数 = 卸载总数 + 1
            返回 0
        }
        序号 = 序号 + 1
    }
    返回 错误_不存在
}

函数 热更新_替换模块(名称, 新代码, 新大小) {
    定义 目标 = 哈希_字符串(名称)
    定义 可变 序号 = 0
    当 (序号 < 模块数) {
        如果 (模块表[序号].名称哈希 == 目标 && 模块表[序号].状态 == 模块_活跃) {
            定义 旧指针 = 模块表[序号].代码指针
            模块表[序号].代码指针 = 堆_分配(新大小)
            如果 (新大小 > 104857600) { 返回 -1 }  // 100MB安全上限
    内存_复制(模块表[序号].代码指针, 新代码, 新大小)
            模块表[序号].代码大小 = 新大小
            堆_释放(旧指针)
            返回 0
        }
        序号 = 序号 + 1
    }
    返回 错误_不存在
}

函数 热更新_增加引用(名称) {
    定义 目标 = 哈希_字符串(名称)
    定义 可变 序号 = 0
    当 (序号 < 模块数) {
        如果 (模块表[序号].名称哈希 == 目标) { 模块表[序号].引用计数 = 模块表[序号].引用计数 + 1; 返回 }
        序号 = 序号 + 1
    }
}

函数 热更新_减少引用(名称) {
    定义 目标 = 哈希_字符串(名称)
    定义 可变 序号 = 0
    当 (序号 < 模块数) {
        如果 (模块表[序号].名称哈希 == 目标 && 模块表[序号].引用计数 > 0) {
            模块表[序号].引用计数 = 模块表[序号].引用计数 - 1
            返回
        }
        序号 = 序号 + 1
    }
}

函数 热更新_活跃模块数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 模块数) {
        如果 (模块表[序号].状态 == 模块_活跃) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 热更新_完整统计() {
    返回 [缓冲数, 模块数, 热更新_活跃模块数(), 切换总数, 加载总数, 卸载总数, 回滚总数]
}

// NovaOS Flash Nova注意力 v2 — IO感知的精确注意力算法
// 论文: Dao et al. "FlashNova注意力-2: Faster Nova注意力 with
//       Better Parallelism and Work Partitioning" (2023)
// 核心创新: 将注意力计算分块到SRAM，避免HBM读写瓶颈
//   传统: O(N²) HBM访问 → Flash: O(N²d/M) 其中M=SRAM大小

// Flash Nova注意力常量

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("../中枢/新系统张量乙.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/时钟中枢.nova")

定义 SRAM_大小 = 131072          // 128KB SRAM (图处共享内存)
定义 BLOCK_M = 128               // Q分块行数
定义 BLOCK_N = 64                // KV分块行数
定义 WARP数 = 4                  // SM中的warp数
定义 因果掩码_启用 = 真         // 默认启用因果掩码(自回归)

// Flash Nova注意力 v2 前向传播
// 输入: Q[B,H,N,d], K[B,H,N,d], V[B,H,N,d]
// 输出: O[B,H,N,d], L[B,H,N] (logsumexp用于反向)

函数 flash_Nova注意力_前向(Q, K, V, 缩放, 因果) {
    定义 B = Q.批大小
    定义 H = Q.头数
    定义 N = Q.序列长度
    定义 d = Q.头维度
    定义 开始时间 = 中枢_当前时间纳秒()

    // 计算分块参数
    定义 块数_q = (N + BLOCK_M - 1) / BLOCK_M
    定义 块数_kv = (N + BLOCK_N - 1) / BLOCK_N

    // 输出缓冲
    定义 可变 O = 张量_零(B, H, N, d)
    定义 可变 L = 张量_零(B, H, N)        // logsumexp

    // 外层循环: 遍历Q分块 (在SM间并行)
    定义 可变 i块 = 0
    当 (i块 < 块数_q) {
        定义 q起始 = i块 * BLOCK_M
        定义 q结束 = 最小值(q起始 + BLOCK_M, N)

        // 加载Q块到SRAM
        定义 Qi = 张量_切片(Q, q起始, q结束)

        // 在线Nova归一化指数累加器 (Milakov & Gimelshein 2018)
        定义 可变 mi = 张量_填充(q结束 - q起始, -1e30)    // 行最大值
        定义 可变 li = 张量_零行(q结束 - q起始)            // 行累积和
        定义 可变 Oi = 张量_零块(q结束 - q起始, d)         // 输出累积

        // 内层循环: 遍历KV分块
        定义 可变 j块 = 0
        定义 kv上限 = 块数_kv
        如果 (因果) { kv上限 = 最小值(i块 + 1, 块数_kv) }

        当 (j块 < kv上限) {
            定义 kv起始 = j块 * BLOCK_N
            定义 kv结束 = 最小值(kv起始 + BLOCK_N, N)

            // 加载KV块到SRAM
            定义 Kj = 张量_切片(K, kv起始, kv结束)
            定义 Vj = 张量_切片(V, kv起始, kv结束)

            // S = Q_i @ K_j^T * scale
            定义 Sij = 矩阵乘_转置(Qi, Kj, 缩放)

            // 因果掩码: 屏蔽未来令牌
            如果 (因果) {
                flash_因果掩码(Sij, q起始, kv起始)
            }

            // 在线Nova归一化指数更新 (无需存储完整N×N矩阵)
            定义 mij_新 = 张量_行最大值(Sij)
            定义 mi_旧 = mi

            // 更新最大值
            mi = 张量_逐元素最大(mi, mij_新)

            // 重缩放因子
            定义 alpha = 张量_exp(张量_减(mi_旧, mi))
            定义 beta = 张量_exp(张量_减(mij_新, mi))

            // 更新累积输出: O = alpha * O + beta * P @ V
            定义 Pij = 张量_exp(张量_减行(Sij, mi))
            Oi = 张量_加(张量_标量乘(Oi, alpha), 矩阵乘(Pij, Vj))

            // 更新累积和
            li = 张量_加(张量_标量乘(li, alpha), 张量_行求和(Pij))

            j块 = j块 + 1
        }

        // 归一化: O = O / l
        Oi = 张量_除行(Oi, li)

        // 写回HBM
        张量_写切片(O, q起始, q结束, Oi)
        张量_写切片(L, q起始, q结束, 张量_加(mi, 张量_log(li)))

        i块 = i块 + 1
    }

    Flash_记录前向统计(N * N, N, d, 块数_q, 块数_kv, 开始时间)
    返回 [O, L]
}

// Flash Nova注意力反向传播

函数 flash_Nova注意力_反向(Q, K, V, O, dO, L, 缩放, 因果) {
    定义 N = Q.序列长度
    定义 d = Q.头维度
    定义 块数_q = (N + BLOCK_M - 1) / BLOCK_M
    定义 块数_kv = (N + BLOCK_N - 1) / BLOCK_N
    定义 开始时间 = 中枢_当前时间纳秒()

    定义 可变 dQ = 张量_零同形(Q)
    定义 可变 dK = 张量_零同形(K)
    定义 可变 dV = 张量_零同形(V)

    // D = rowsum(dO ⊙ O)
    定义 D = 张量_行求和(张量_逐元素乘(dO, O))

    // 外层: 遍历KV块
    定义 可变 j块 = 0
    当 (j块 < 块数_kv) {
        定义 kv起始 = j块 * BLOCK_N
        定义 kv结束 = 最小值(kv起始 + BLOCK_N, N)
        定义 Kj = 张量_切片(K, kv起始, kv结束)
        定义 Vj = 张量_切片(V, kv起始, kv结束)

        定义 可变 dKj = 张量_零块(kv结束 - kv起始, d)
        定义 可变 dVj = 张量_零块(kv结束 - kv起始, d)

        // 内层: 遍历Q块
        定义 可变 i块 = 0
        当 (i块 < 块数_q) {
            定义 q起始 = i块 * BLOCK_M
            定义 q结束 = 最小值(q起始 + BLOCK_M, N)

            如果 (因果 && q起始 > kv结束) { i块 = i块 + 1; 继续 }

            定义 Qi = 张量_切片(Q, q起始, q结束)
            定义 dOi = 张量_切片(dO, q起始, q结束)
            定义 Li = 张量_切片(L, q起始, q结束)
            定义 Di = 张量_切片(D, q起始, q结束)

            // 重计算注意力权重(不存储, 节省内存)
            定义 Sij = 矩阵乘_转置(Qi, Kj, 缩放)
            如果 (因果) { flash_因果掩码(Sij, q起始, kv起始) }
            定义 Pij = 张量_exp(张量_减行(Sij, Li))

            // dV += P^T @ dO
            dVj = 张量_加(dVj, 矩阵乘_转置左(Pij, dOi))

            // dP = dO @ V^T
            定义 dPij = 矩阵乘_转置(dOi, Vj, 1.0)

            // dS = P ⊙ (dP - D)
            定义 dSij = 张量_逐元素乘(Pij, 张量_减行(dPij, Di))

            // dQ += dS @ K * scale
            定义 dQi = 矩阵乘(dSij, Kj)
            张量_累加切片(dQ, q起始, q结束, 张量_标量乘(dQi, 缩放))

            // dK += dS^T @ Q * scale
            dKj = 张量_加(dKj, 张量_标量乘(矩阵乘_转置左(dSij, Qi), 缩放))

            i块 = i块 + 1
        }

        张量_写切片(dK, kv起始, kv结束, dKj)
        张量_写切片(dV, kv起始, kv结束, dVj)
        j块 = j块 + 1
    }

    Flash_记录反向统计(N * N, N, d, 开始时间)
    返回 [dQ, dK, dV]
}

// 因果掩码应用

函数 flash_因果掩码(S, q起始, kv起始) {
    定义 M = S.行数
    定义 N = S.列数
    定义 可变 i = 0
    当 (i < M) {
        定义 可变 j = 0
        当 (j < N) {
            如果 (q起始 + i < kv起始 + j) {
                张量_设置(S, i, j, -1e30)
            }
            j = j + 1
        }
        i = i + 1
    }
}

// §3 Flash注意力配置与分块参数自动调优

定义 错误_无效参数 = -1
定义 错误_内存不足 = -4

结构 Flash配置 {
    SRAM大小,         // 可用SRAM字节数
    块M,              // Q分块行数
    块N,              // KV分块行数
    warp数,           // SM中warp数
    启用因果,         // 是否启用因果掩码
    启用dropout,      // 是否启用注意力dropout
    dropout率,        // dropout概率Q10
    头维度,           // 每头维度
    精度模式,         // 0=FP32 1=FP16 2=BF16
}

结构 Flash统计 {
    总前向次数,
    总反向次数,
    总令牌对数,       // u64 N*N注意力对计算量
    总SRAM命中,
    总HBM读取字节,
    总HBM写入字节,
    平均块利用率,     // Q10
    最大序列长度,
    峰值SRAM使用,     // u32 字节
    总耗时微秒,
    IO节省比例,       // Q10 相对标准注意力的IO节省
}

定义 可变 全局Flash统计 = 0

函数 Flash统计_初始化() {
    定义 s = Flash统计 {}
    s.总前向次数 = 0
    s.总反向次数 = 0
    s.总令牌对数 = 0
    s.总SRAM命中 = 0
    s.总HBM读取字节 = 0
    s.总HBM写入字节 = 0
    s.平均块利用率 = 0
    s.最大序列长度 = 0
    s.峰值SRAM使用 = 0
    s.总耗时微秒 = 0
    s.IO节省比例 = 0
    全局Flash统计 = s
    返回 s
}

函数 Flash_确保统计() {
    如果 (全局Flash统计 == 0) {
        Flash统计_初始化()
    }
}

函数 Flash_估算SRAM使用(d) {
    返回 ((BLOCK_M * 2 + BLOCK_N) * d + BLOCK_M * BLOCK_N) * 4
}

函数 Flash_记录块利用率(块数_q, 块数_kv, N) {
    如果 (全局Flash统计 == 0) { 返回 }
    定义 Q利用 = 0
    定义 KV利用 = 0
    如果 (块数_q > 0) { Q利用 = N * 1024 / (块数_q * BLOCK_M) }
    如果 (块数_kv > 0) { KV利用 = N * 1024 / (块数_kv * BLOCK_N) }
    定义 利用率 = (Q利用 + KV利用) / 2
    定义 已有次数 = 全局Flash统计.总前向次数
    如果 (已有次数 <= 1) {
        全局Flash统计.平均块利用率 = 利用率
    } 否则 {
        全局Flash统计.平均块利用率 = (全局Flash统计.平均块利用率 * (已有次数 - 1) + 利用率) / 已有次数
    }
}

函数 Flash_记录前向统计(令牌对数, N, d, 块数_q, 块数_kv, 开始时间) {
    Flash_确保统计()
    如果 (全局Flash统计 == 0) { 返回 }
    全局Flash统计.总前向次数 = 全局Flash统计.总前向次数 + 1
    全局Flash统计.总令牌对数 = 全局Flash统计.总令牌对数 + 令牌对数
    全局Flash统计.总SRAM命中 = 全局Flash统计.总SRAM命中 + 块数_q * 块数_kv
    全局Flash统计.总HBM读取字节 = 全局Flash统计.总HBM读取字节 + (N * d * 4) * 3
    全局Flash统计.总HBM写入字节 = 全局Flash统计.总HBM写入字节 + (N * d * 4) + N * 4
    如果 (N > 全局Flash统计.最大序列长度) {
        全局Flash统计.最大序列长度 = N
    }
    定义 SRAM使用 = Flash_估算SRAM使用(d)
    如果 (SRAM使用 > 全局Flash统计.峰值SRAM使用) {
        全局Flash统计.峰值SRAM使用 = SRAM使用
    }
    定义 Flash_IO = (N * d * 4) * 3 + N * 4
    定义 标准_IO = 令牌对数 * 4 + (N * d * 4) * 3
    如果 (标准_IO > 0) {
        全局Flash统计.IO节省比例 = ((标准_IO - Flash_IO) * 1024) / 标准_IO
    }
    Flash_记录块利用率(块数_q, 块数_kv, N)
    如果 (开始时间 > 0) {
        全局Flash统计.总耗时微秒 = 全局Flash统计.总耗时微秒 + (中枢_当前时间纳秒() - 开始时间) / 1000
    }
}

函数 Flash_记录反向统计(令牌对数, N, d, 开始时间) {
    Flash_确保统计()
    如果 (全局Flash统计 == 0) { 返回 }
    全局Flash统计.总反向次数 = 全局Flash统计.总反向次数 + 1
    全局Flash统计.总令牌对数 = 全局Flash统计.总令牌对数 + 令牌对数
    全局Flash统计.总HBM读取字节 = 全局Flash统计.总HBM读取字节 + (N * d * 4) * 5
    全局Flash统计.总HBM写入字节 = 全局Flash统计.总HBM写入字节 + (N * d * 4) * 3
    定义 SRAM使用 = Flash_估算SRAM使用(d)
    如果 (SRAM使用 > 全局Flash统计.峰值SRAM使用) {
        全局Flash统计.峰值SRAM使用 = SRAM使用
    }
    如果 (开始时间 > 0) {
        全局Flash统计.总耗时微秒 = 全局Flash统计.总耗时微秒 + (中枢_当前时间纳秒() - 开始时间) / 1000
    }
}

函数 Flash配置_创建(头维度) {
    定义 配置 = Flash配置 {}
    配置.SRAM大小 = SRAM_大小
    配置.块M = BLOCK_M
    配置.块N = BLOCK_N
    配置.warp数 = WARP数
    配置.启用因果 = 真
    配置.启用dropout = 假
    配置.dropout率 = 0
    配置.头维度 = 头维度
    配置.精度模式 = 0
    返回 配置
}

函数 Flash配置_自动调优(配置, 序列长度, 批大小) {
    如果 (配置 == 0) { 返回 }
    定义 d = 配置.头维度

    // SRAM需容纳: Q块[块M×d] + K块[块N×d] + S块[块M×块N] + O块[块M×d]
    // 总SRAM = (块M + 块N) * d * 4 + 块M * 块N * 4
    定义 可变 最优M = 64
    定义 可变 最优N = 32
    定义 可变 最优利用率 = 0

    定义 可变 试M = 32
    当 (试M <= 256) {
        定义 可变 试N = 16
        当 (试N <= 128) {
            定义 需要SRAM = (试M + 试N) * d * 4 + 试M * 试N * 4
            如果 (需要SRAM <= 配置.SRAM大小) {
                // 计算利用率: 尽量填满SRAM
                定义 利用率 = (需要SRAM * 1024) / 配置.SRAM大小
                如果 (利用率 > 最优利用率) {
                    最优利用率 = 利用率
                    最优M = 试M
                    最优N = 试N
                }
            }
            试N = 试N * 2
        }
        试M = 试M * 2
    }

    配置.块M = 最优M
    配置.块N = 最优N
    打印(字符串拼接("[Flash] 自动调优: 块M=", 字符串拼接(转字符串(最优M), 字符串拼接(" 块N=", 转字符串(最优N)))))
}

// §4 Flash注意力 + Dropout (训练模式)

函数 flash_注意力_带dropout(Q, K, V, 缩放, 因果, dropout率) {
    定义 B = Q.批大小
    定义 H = Q.头数
    定义 N = Q.序列长度
    定义 d = Q.头维度
    定义 块数_q = (N + BLOCK_M - 1) / BLOCK_M
    定义 块数_kv = (N + BLOCK_N - 1) / BLOCK_N

    定义 可变 O = 张量_零(B, H, N, d)
    定义 可变 L = 张量_零(B, H, N)

    定义 可变 i块 = 0
    当 (i块 < 块数_q) {
        定义 q起始 = i块 * BLOCK_M
        定义 q结束 = 最小值(q起始 + BLOCK_M, N)
        定义 Qi = 张量_切片(Q, q起始, q结束)

        定义 可变 mi = 张量_填充(q结束 - q起始, -1e30)
        定义 可变 li = 张量_零行(q结束 - q起始)
        定义 可变 Oi = 张量_零块(q结束 - q起始, d)

        定义 可变 j块 = 0
        定义 kv上限 = 块数_kv
        如果 (因果) { kv上限 = 最小值(i块 + 1, 块数_kv) }

        当 (j块 < kv上限) {
            定义 kv起始 = j块 * BLOCK_N
            定义 kv结束 = 最小值(kv起始 + BLOCK_N, N)
            定义 Kj = 张量_切片(K, kv起始, kv结束)
            定义 Vj = 张量_切片(V, kv起始, kv结束)

            定义 Sij = 矩阵乘_转置(Qi, Kj, 缩放)
            如果 (因果) { flash_因果掩码(Sij, q起始, kv起始) }

            定义 mij_新 = 张量_行最大值(Sij)
            定义 mi_旧 = mi
            mi = 张量_逐元素最大(mi, mij_新)

            定义 alpha = 张量_exp(张量_减(mi_旧, mi))
            定义 beta = 张量_exp(张量_减(mij_新, mi))

            定义 Pij = 张量_exp(张量_减行(Sij, mi))

            // Dropout: 随机置零
            如果 (dropout率 > 0) {
                flash_dropout_掩码(Pij, dropout率)
            }

            Oi = 张量_加(张量_标量乘(Oi, alpha), 矩阵乘(Pij, Vj))
            li = 张量_加(张量_标量乘(li, alpha), 张量_行求和(Pij))

            j块 = j块 + 1
        }

        Oi = 张量_除行(Oi, li)
        张量_写切片(O, q起始, q结束, Oi)
        张量_写切片(L, q起始, q结束, 张量_加(mi, 张量_log(li)))
        i块 = i块 + 1
    }

    返回 [O, L]
}

函数 flash_dropout_掩码(P, dropout率) {
    如果 (P == 0) { 返回 }
    定义 M = P.行数
    定义 N = P.列数
    定义 保留率_倒数 = 1024 / (1024 - dropout率)
    定义 可变 i = 0
    当 (i < M) {
        定义 可变 j = 0
        当 (j < N) {
            定义 随机 = 随机_均匀_整数(1024)
            如果 (随机 < dropout率) {
                张量_设置(P, i, j, 0)
            } 否则 {
                // 缩放补偿
                定义 原值 = 张量_读取(P, i, j)
                张量_设置(P, i, j, (原值 * 保留率_倒数) / 1024)
            }
            j = j + 1
        }
        i = i + 1
    }
}

// §5 AI自适应注意力精度 — NovaOS独创
// 根据内容重要性动态选择精度

函数 Flash_AI自适应精度(bus, 序列长度, 重要性) {
    如果 (bus == 0) { 返回 0 }

    // AI判断: 高重要性用FP32, 低重要性用BF16
    如果 (重要性 > 800) { 返回 0 }
    如果 (重要性 < 200 && 序列长度 > 2048) { 返回 2 }
    返回 1
}

// §6 统计输出

函数 Flash_打印统计() {
    如果 (全局Flash统计 == 0) {
        打印("[Flash] 统计未初始化")
        返回
    }
    定义 s = 全局Flash统计
    打印("[Flash] ═══ Flash注意力统计 ═══")
    打印(字符串拼接("  总前向次数: ", 转字符串(s.总前向次数)))
    打印(字符串拼接("  总反向次数: ", 转字符串(s.总反向次数)))
    打印(字符串拼接("  总令牌对数: ", 转字符串(s.总令牌对数)))
    打印(字符串拼接("  最大序列长度: ", 转字符串(s.最大序列长度)))
    打印(字符串拼接("  IO节省比例: ", 字符串拼接(转字符串(s.IO节省比例 * 100 / 1024), "%")))
    打印(字符串拼接("  总耗时: ", 字符串拼接(转字符串(s.总耗时微秒), "μs")))
    打印("[Flash] ═══════════════════════════")
}

// §7 滑动窗口注意力 — 支持超长序列
// Mistral/Longformer风格: 每个令牌只关注最近W个令牌

定义 滑动窗口_默认大小 = 4096
// 反哺: 中文自动缩窗 (实验室发现中文最优窗口约为英文1/1.8x)
定义 滑动窗口_中文大小 = 2048   // 4096/1.8 ≈ 2275 → 取2048对齐

// 检测序列中文密度 → 自适应选择窗口大小
函数 flash_中文感知窗口(序列指针, 序列长度) {
    如果 (序列指针 == 0 || 序列长度 == 0) { 返回 滑动窗口_默认大小 }
    // 采样前32个token估算中文密度 (快速路径)
    定义 采样数 = 如果 (序列长度 < 32) { 序列长度 } 否则 { 32 }
    定义 可变 中文token数 = 0
    定义 可变 i = 0
    当 (i < 采样数) {
        // 中文Unicode范围: 0x4E00-0x9FFF (CJK统一汉字)
        定义 cp = 内存_读32(序列指针 + i * 4)
        如果 (cp >= 0x4E00 && cp <= 0x9FFF) { 中文token数 = 中文token数 + 1 }
        i = i + 1
    }
    定义 中文密度 = 中文token数 * 1000 / 采样数   // ×1000
    // 密度>60% → 使用中文窗口(节省约55%计算量)
    如果 (中文密度 > 600) { 返回 滑动窗口_中文大小 }
    返回 滑动窗口_默认大小
}

函数 flash_滑动窗口_前向(Q, K, V, 缩放, 窗口大小) {
    定义 B = Q.批大小
    定义 H = Q.头数
    定义 N = Q.序列长度
    定义 d = Q.头维度
    定义 块数_q = (N + BLOCK_M - 1) / BLOCK_M
    定义 块数_kv = (N + BLOCK_N - 1) / BLOCK_N
    定义 开始时间 = 中枢_当前时间纳秒()

    定义 可变 O = 张量_零(B, H, N, d)
    定义 可变 L = 张量_零(B, H, N)

    定义 可变 i块 = 0
    当 (i块 < 块数_q) {
        定义 q起始 = i块 * BLOCK_M
        定义 q结束 = 最小值(q起始 + BLOCK_M, N)
        定义 Qi = 张量_切片(Q, q起始, q结束)

        定义 可变 mi = 张量_填充(q结束 - q起始, -1e30)
        定义 可变 li = 张量_零行(q结束 - q起始)
        定义 可变 Oi = 张量_零块(q结束 - q起始, d)

        // 滑动窗口: KV范围限制在 [max(0, q起始-窗口), q结束]
        定义 kv最小 = q起始 - 窗口大小
        如果 (kv最小 < 0) { kv最小 = 0 }
        定义 kv块起始 = kv最小 / BLOCK_N
        定义 kv块结束 = (q结束 + BLOCK_N - 1) / BLOCK_N

        定义 可变 j块 = kv块起始
        当 (j块 < kv块结束) {
            定义 kv起始 = j块 * BLOCK_N
            定义 kv结束 = 最小值(kv起始 + BLOCK_N, N)
            定义 Kj = 张量_切片(K, kv起始, kv结束)
            定义 Vj = 张量_切片(V, kv起始, kv结束)

            定义 Sij = 矩阵乘_转置(Qi, Kj, 缩放)

            // 因果 + 滑动窗口掩码
            flash_滑动窗口掩码(Sij, q起始, kv起始, 窗口大小)

            定义 mij_新 = 张量_行最大值(Sij)
            定义 mi_旧 = mi
            mi = 张量_逐元素最大(mi, mij_新)
            定义 alpha = 张量_exp(张量_减(mi_旧, mi))
            定义 Pij = 张量_exp(张量_减行(Sij, mi))
            Oi = 张量_加(张量_标量乘(Oi, alpha), 矩阵乘(Pij, Vj))
            li = 张量_加(张量_标量乘(li, alpha), 张量_行求和(Pij))

            j块 = j块 + 1
        }

        Oi = 张量_除行(Oi, li)
        张量_写切片(O, q起始, q结束, Oi)
        张量_写切片(L, q起始, q结束, 张量_加(mi, 张量_log(li)))
        i块 = i块 + 1
    }

    Flash_记录前向统计(N * 最小值(N, 窗口大小), N, d, 块数_q, 块数_kv, 开始时间)
    返回 [O, L]
}

函数 flash_滑动窗口掩码(S, q起始, kv起始, 窗口大小) {
    定义 M = S.行数
    定义 N = S.列数
    定义 可变 i = 0
    当 (i < M) {
        定义 可变 j = 0
        当 (j < N) {
            定义 q位置 = q起始 + i
            定义 kv位置 = kv起始 + j
            // 因果: 不看未来
            如果 (q位置 < kv位置) {
                张量_设置(S, i, j, -1e30)
            }
            // 滑动窗口: 不看太远的过去
            如果 (q位置 - kv位置 > 窗口大小) {
                张量_设置(S, i, j, -1e30)
            }
            j = j + 1
        }
        i = i + 1
    }
}

函数 Flash统计_重置() {
    全局Flash统计 = 0
}

函数 主程序() {
    // 最基础: 6.333 + 0.667 应 = 7.0
    定义 r = 6.333 + 0.667
    打印(字符串拼接("6.333+0.667=", 转字符串(r)))
    // 期望 bits(7.0) = 4620693217682128896
    // 实际 bits = 4619567317775286272 (0x401A0...=6.5)
    
    // 对比: 1.0 + 0.1
    定义 r2 = 1.0 + 0.1
    打印(字符串拼接("1.0+0.1=", 转字符串(r2)))
    // 期望 1.1 bits = 4607632778762754458
    
    // 对比 SIMD
    定义 r3 = __simd_浮点加(6.333, 0.667)
    打印(字符串拼接("SIMD 6.333+0.667=", 转字符串(r3)))
    返回 0
}

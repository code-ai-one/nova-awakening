// §2 长连接帧编码
// 帧格式:
//   0               1               2               3
//   0 1 2 3 4 5 6 7 0 1 2 3 4 5 6 7 0 1 2 3 4 5 6 7 0 1 2 3 4 5 6 7
//  +-+-+-+-+-------+-+-------------+-------------------------------+
//  |F|R|R|R| opcode|M| Payload len |    Extended payload length    |
//  |I|S|S|S| (4)   |A|    (7)      |            (16/64)            |
//  |N|V|V|V|       |S|             |                               |
//  | |1|2|3|       |K|             |                               |
//  +-+-+-+-+-------+-+-------------+-------------------------------+
//  |     Masking-key (0 or 4 bytes)                                |
//  +-------------------------------+-------------------------------+
//  |          Payload Data                                         |
//  +---------------------------------------------------------------+

函数 WS_编码帧(ws, opcode, 数据, 长度, 是最终帧) {
    定义 帧 = 堆_分配_数组(14 + 长度)    // 最大头14字节
    定义 可变 偏移 = 0

    // 第1字节: FIN + opcode
    定义 字节1 = opcode & 0x0F
    如果 (是最终帧) { 字节1 = 字节1 | 0x80 }
    内存_写8(帧 + 偏移, 字节1)
    偏移 = 偏移 + 1

    // 第2字节: MASK(1) + payload length
    // 客户端必须掩码
    如果 (长度 < 126) {
        内存_写8(帧 + 偏移, 0x80 | 长度)    // MASK=1
        偏移 = 偏移 + 1
    } 否则 如果 (长度 < 65536) {
        内存_写8(帧 + 偏移, 0x80 | 126)
        偏移 = 偏移 + 1
        内存_写8(帧 + 偏移, (长度 >> 8) & 0xFF)
        内存_写8(帧 + 偏移 + 1, 长度 & 0xFF)
        偏移 = 偏移 + 2
    } 否则 {
        内存_写8(帧 + 偏移, 0x80 | 127)
        偏移 = 偏移 + 1
        // 64位长度(取低32位, 单帧最大4GB)
        内存_写32(帧 + 偏移, 0)
        内存_写32(帧 + 偏移 + 4, 长度)
        偏移 = 偏移 + 8
    }

    // Masking Key(4字节随机)
    定义 掩码 = 堆_分配_数组(4)
    平台_安全随机(掩码, 4)
    内存_复制(帧 + 偏移, 掩码, 4)
    偏移 = 偏移 + 4

    // 掩码数据: payload[i] ^= mask[i % 4]
    如果 (数据 != 0 && 长度 > 0) {
        定义 可变 i = 0
        当 (i < 长度) {
            内存_写8(帧 + 偏移 + i, 内存_读8(数据 + i) ^ 内存_读8(掩码 + (i & 3)))
            i = i + 1
        }
    }

    堆_释放(掩码)
    返回 (帧, 偏移 + 长度)    // 返回(指针, 总长)
}

// §3 长连接帧解码

结构 WS帧 {
    FIN,
    opcode,
    有掩码,
    载荷长度,
    掩码键,    // [4]u8
    载荷,    // u64 数据指针
    头长度,    // u32 头部总字节
}

函数 WS_解码帧(数据, 可用长度) {
    如果 (数据 == 0 || 可用长度 < 2) { 返回 0 }

    定义 帧 = 堆_分配(WS帧)
    定义 可变 偏移 = 0

    // 第1字节
    定义 字节1 = 内存_读8(数据)
    帧.FIN = (字节1 & 0x80) != 0
    帧.opcode = 字节1 & 0x0F
    偏移 = 1

    // 第2字节
    定义 字节2 = 内存_读8(数据 + 1)
    帧.有掩码 = (字节2 & 0x80) != 0
    定义 payload_len = 字节2 & 0x7F
    偏移 = 2

    如果 (payload_len == 126) {
        如果 (可用长度 < 4) { 堆_释放(帧); 返回 0 }
        帧.载荷长度 = (内存_读8(数据 + 2) << 8) | 内存_读8(数据 + 3)
        偏移 = 4
    } 否则 如果 (payload_len == 127) {
        如果 (可用长度 < 10) { 堆_释放(帧); 返回 0 }
        帧.载荷长度 = (内存_读8(数据 + 6) << 24) | (内存_读8(数据 + 7) << 16) |
                       (内存_读8(数据 + 8) << 8) | 内存_读8(数据 + 9)
        偏移 = 10
    } 否则 {
        帧.载荷长度 = payload_len
    }

    // 掩码键
    如果 (帧.有掩码) {
        如果 (可用长度 < 偏移 + 4) { 堆_释放(帧); 返回 0 }
        帧.掩码键[0] = 内存_读8(数据 + 偏移)
        帧.掩码键[1] = 内存_读8(数据 + 偏移 + 1)
        帧.掩码键[2] = 内存_读8(数据 + 偏移 + 2)
        帧.掩码键[3] = 内存_读8(数据 + 偏移 + 3)
        偏移 = 偏移 + 4
    }

    帧.头长度 = 偏移

    // 检查完整帧
    如果 (可用长度 < 偏移 + 帧.载荷长度) { 堆_释放(帧); 返回 0 }

    帧.载荷 = 数据 + 偏移

    // 反掩码
    如果 (帧.有掩码 && 帧.载荷长度 > 0) {
        定义 可变 i = 0
        当 (i < 帧.载荷长度) {
            内存_写8(帧.载荷 + i, 内存_读8(帧.载荷 + i) ^ 帧.掩码键[i & 3])
            i = i + 1
        }
    }

    返回 帧
}

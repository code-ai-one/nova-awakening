导入("./类型定义.nova")
导入("./错误码.nova")
导入("./字符串替换.nova")
导入("../引导/端口输入.nova")
导入("./每处理器.nova")
导入("./内核映射.nova")

//   1. iretq: 从内核态返回用户态(恢复RIP/CS/RFLAGS/RSP/SS)
//   2. swapgs: 切换GS基址(内核per-CPU ↔ 用户安全)
//   3. exit_to_user_mode_prepare: 返回前检查信号/调度/TLB
//   4. SMAP/SMEP: 内核不能直接访问用户内存(需stac/clac)
//   5. 中断帧: 硬件自动保存的5个寄存器(SS/RSP/RFLAGS/CS/RIP)

定义 内核代码段 = 0x08    // GDT index 1, RPL=0
定义 内核数据段 = 0x10    // GDT index 2, RPL=0
定义 用户代码段 = 0x1B    // GDT index 3, RPL=3
定义 用户数据段 = 0x23    // GDT index 4, RPL=3

定义 EFLAGS_IF   = (1 << 9)    // 中断使能
定义 EFLAGS_IOPL0 = 0          // IOPL=0(内核)
定义 EFLAGS_IOPL3 = (3 << 12)  // IOPL=3(用户)

定义 可变 用户态进入次数 = 0
定义 可变 用户态返回次数 = 0

// 进入用户态 
// 在栈上构造中断返回帧, 通过iretq跳转到Ring 3

函数 进入用户态(rip, rsp, rflags) {
    用户态进入次数 = 用户态进入次数 + 1

    // swapgs: 切换到用户态GS
    交换GS()

    汇编 {
        // iretq帧: SS → RSP → RFLAGS → CS → RIP (从高到低push)
        "push 0x23"         // SS = 用户数据段
        "push [rbp+32]"     // RSP (用户栈指针)
        "push [rbp+24]"     // RFLAGS (IF=1)
        "push 0x1B"         // CS = 用户代码段
        "push [rbp+16]"     // RIP (用户入口)
        "iretq"
    }
}

// 返回用户态前检查 
// 每次从内核返回用户态前必须调用

函数 返回用户态前检查() {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 }

    // 1. 检查挂起信号 (do_signal)
    如果 (进程_有挂起信号(当前)) {
        处理挂起信号(当前)
    }

    // 2. 检查是否需要调度 (TIF_NEED_RESCHED)
    如果 (进程_需要调度标志(当前)) {
        调度()
    }

    // 3. 检查是否需要更新用户态页表
    // (TLB flush deferred work)

    // 4. 恢复FPU状态 (如果被内核使用过)
    // switch_fpu_return()

    用户态返回次数 = 用户态返回次数 + 1
}

// 从exec启动新用户进程

函数 启动用户进程(入口地址, 用户栈顶) {
    返回用户态前检查()
    // 用户态RFLAGS: IF=1(中断使能), IOPL=0(无直接IO权限)
    定义 rflags = EFLAGS_IF
    进入用户态(入口地址, 用户栈顶, rflags)
}

函数 启动用户进程_带参数(入口地址, 用户栈顶, argc, argv, envp) {
    // 在用户栈上放置argc/argv/envp(ELF ABI要求)
    // [栈顶] → envp → argv → argc
    返回用户态前检查()
    定义 rflags = EFLAGS_IF
    进入用户态(入口地址, 用户栈顶, rflags)
}

// 从fork返回 (子进程首次被调度时执行)

函数 fork返回() {
    // 子进程第一次被schedule()选中时执行
    // 1. 设置返回值为0(子进程fork返回0)
    // 2. 返回用户态
    返回用户态前检查()
}

// SWAPGS + SMAP/SMEP

函数 交换GS() {
    // swapgs: 交换MSR_GS_BASE和MSR_KERNEL_GS_BASE
    // 进入内核时: 用户GS → 内核GS(per-CPU数据)
    // 返回用户时: 内核GS → 用户GS(安全)
    汇编 { "swapgs" }
}

函数 允许用户内存访问() {
    // stac: Set AC flag (允许内核访问用户内存, SMAP)
    汇编 { "stac" }
}

函数 禁止用户内存访问() {
    // clac: Clear AC flag (禁止内核访问用户内存)
    汇编 { "clac" }
}

// 用户内存安全复制 

函数 copy_from_user(内核目标, 用户源, 长度) {
    // 验证用户地址合法性
    如果 (!是用户地址(用户源)) { 返回 错误_无效地址 }
    如果 (!是用户地址(用户源 + 长度 - 1)) { 返回 错误_无效地址 }
    允许用户内存访问()
    内存复制(内核目标, 用户源, 长度)
    禁止用户内存访问()
    返回 成功
}

函数 copy_to_user(用户目标, 内核源, 长度) {
    如果 (!是用户地址(用户目标)) { 返回 错误_无效地址 }
    如果 (!是用户地址(用户目标 + 长度 - 1)) { 返回 错误_无效地址 }
    允许用户内存访问()
    内存复制(用户目标, 内核源, 长度)
    禁止用户内存访问()
    返回 成功
}

函数 用户空间切换_统计() {
    返回 [用户态进入次数, 用户态返回次数]
}

// 错误_无效地址 定义在 核心/公共/错误码.nova

// 用户地址验证 

定义 用户空间_上限 = 0x00007FFFFFFFFFFF  // 用户态最高地址(canonical)

函数 进程切换_是用户地址(地址) {
    返回 地址 <= 用户空间_上限
}

函数 access_ok(地址, 大小) {
    如果 (大小 == 0) { 返回 真 }
    如果 (地址 > 用户空间_上限) { 返回 假 }
    如果 (地址 + 大小 - 1 > 用户空间_上限) { 返回 假 }
    如果 (地址 + 大小 < 地址) { 返回 假 }  // 溢出检查
    返回 真
}

// get_user / put_user (单值用户空间读写)

函数 get_user_u64(用户地址) {
    如果 (!是用户地址(用户地址)) { 返回 [错误_无效地址, 0] }
    允许用户内存访问()
    定义 值 = 内存读64(用户地址)
    禁止用户内存访问()
    返回 [成功, 值]
}

函数 put_user_u64(值, 用户地址) {
    如果 (!是用户地址(用户地址)) { 返回 错误_无效地址 }
    允许用户内存访问()
    内存写64(用户地址, 值)
    禁止用户内存访问()
    返回 成功
}

函数 get_user_u32(用户地址) {
    如果 (!是用户地址(用户地址)) { 返回 [错误_无效地址, 0] }
    允许用户内存访问()
    定义 值 = 内存读32(用户地址)
    禁止用户内存访问()
    返回 [成功, 值]
}

函数 put_user_u32(值, 用户地址) {
    如果 (!是用户地址(用户地址)) { 返回 错误_无效地址 }
    允许用户内存访问()
    内存写32(用户地址, 值)
    禁止用户内存访问()
    返回 成功
}

// 段选择子名称 + 完整统计

函数 段选择子名(选择子) {
    如果 (选择子 == 内核代码段) { 返回 "KERNEL_CS" }
    如果 (选择子 == 内核数据段) { 返回 "KERNEL_DS" }
    如果 (选择子 == 用户代码段) { 返回 "USER_CS" }
    如果 (选择子 == 用户数据段) { 返回 "USER_DS" }
    返回 "UNKNOWN"
}

函数 用户空间切换_完整统计() {
    返回 [用户态进入次数, 用户态返回次数]
}

定义 可变 AI_用户空间切_运行指标 = 0
定义 可变 AI_用户空间切_异常指标 = 0

函数 AI_用户空间切_自诊断() {
    AI_用户空间切_运行指标 = 用户态进入次数
    返回 AI_用户空间切_运行指标
}

函数 AI_用户空间切_优化建议() {
    定义 指标 = AI_用户空间切_自诊断()
    如果 (AI_用户空间切_运行指标 > 10000) { 返回 "用户空间切负载较高" }
    返回 "用户空间切状态正常"
}

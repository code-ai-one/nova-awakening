导入("../基础.nova")


// 能力类型
定义 能力_读 = 1
定义 能力_写 = 2
定义 能力_执行 = 4
定义 能力_网络 = 8
定义 能力_文件 = 16

// 沙箱: [ID, 能力掩码, 内存限制, 已用内存, CPU限制, 已用CPU, 日志]
定义 可变 沙箱列表 = []
定义 可变 沙箱_下一ID = 0

函数 沙箱_创建(能力掩码, 内存限制, CPU限制) { 定义 id = 沙箱_下一ID
 沙箱_下一ID = 沙箱_下一ID + 1
 追加(沙箱列表, [id, 能力掩码, 内存限制, 0, CPU限制, 0, []])
 返回 id
}

函数 沙箱_检查能力(id, 能力) { 定义 掩码 = 沙箱列表[id][1]
 // 位与检查
 定义 可变 r = 掩码
 定义 可变 a = 能力
 定义 可变 结果 = 0
 定义 可变 位 = 1
 当 (位 <= 32) { 如果 (r % 2 == 1 且 a % 2 == 1) { 结果 = 结果 + 位 }
 r = r / 2
 a = a / 2
 位 = 位 * 2
 }
 返回 结果 > 0
}

函数 沙箱_分配内存(id, 大小) {
    如果 (沙箱列表[id][3] + 大小 > 沙箱列表[id][2]) { 返回 假
}
 沙箱列表[id][3] = 沙箱列表[id][3] + 大小
 返回 真
}

函数 沙箱_消耗CPU(id, 量) {
    如果 (沙箱列表[id][5] + 量 > 沙箱列表[id][4]) { 返回 假
}
 沙箱列表[id][5] = 沙箱列表[id][5] + 量
 返回 真
}

函数 沙箱_审计(id, 操作哈希) {
 追加(沙箱列表[id][6], 操作哈希)
}

函数 沙箱_日志数(id) { 返回 计数(沙箱列表[id][6]) }

函数 沙箱_重置(id) {
 沙箱列表[id][3] = 0
 沙箱列表[id][5] = 0
 沙箱列表[id][6] = []
}

// 访问控制列表
定义 可变 ACL_主体 = []
定义 可变 ACL_资源 = []
定义 可变 ACL_权限 = []

函数 ACL_清空() { ACL_主体 = []
ACL_资源 = []
ACL_权限 = [] }

函数 ACL_授权(主体, 资源, 权限) {
 追加(ACL_主体, 主体)
 追加(ACL_资源, 资源)
 追加(ACL_权限, 权限)
}

函数 ACL_检查(主体, 资源, 请求权限) { 定义 可变 i = 0
 当 (i < 计数(ACL_主体)) { 如果 (ACL_主体[i] == 主体 且 ACL_资源[i] == 资源) { 如果 (ACL_权限[i] >= 请求权限) { 返回 真 }
 }
 i = i + 1
 }
 返回 假
}

函数 沙箱_清空() { 沙箱列表 = []
沙箱_下一ID = 0 }

// 资源使用率
函数 沙箱_内存使用率(id) {
    如果 (沙箱列表[id][2] == 0) { 返回 0
}
 返回 沙箱列表[id][3] * 100 / 沙箱列表[id][2]
}

函数 沙箱_CPU使用率(id) {
    如果 (沙箱列表[id][4] == 0) { 返回 0
}
 返回 沙箱列表[id][5] * 100 / 沙箱列表[id][4]
}

// 能力撤销
函数 沙箱_撤销能力(id, 能力) {
 // 清除指定能力位
 定义 掩码 = 沙箱列表[id][1]
 定义 可变 新掩码 = 0
 定义 可变 位 = 1
 定义 可变 m = 掩码
 定义 可变 a = 能力
 当 (位 <= 32) { 定义 mb = m % 2
 定义 ab = a % 2
 如果 (mb == 1 且 ab == 0) { 新掩码 = 新掩码 + 位 }
 m = m / 2
 a = a / 2
 位 = 位 * 2
 }
 沙箱列表[id][1] = 新掩码
}

// 能力添加
函数 沙箱_添加能力(id, 能力) {
 定义 掩码 = 沙箱列表[id][1]
 定义 可变 新掩码 = 0
 定义 可变 位 = 1
 定义 可变 m = 掩码
 定义 可变 a = 能力
 当 (位 <= 32) { 定义 mb = m % 2
 定义 ab = a % 2
 如果 (mb == 1 或 ab == 1) { 新掩码 = 新掩码 + 位 }
 m = m / 2
 a = a / 2
 位 = 位 * 2
 }
 沙箱列表[id][1] = 新掩码
}

// AI模型沙箱
函数 AI沙箱_创建(内存MB) { 返回 沙箱_创建(能力_读 + 能力_执行, 内存MB * 1024, 10000)
}

函数 AI沙箱_推理(id, 计算量) {
    如果 (沙箱_检查能力(id, 能力_执行) == 假) { 返回 -1
}
 如果 (沙箱_消耗CPU(id, 计算量) == 假) { 返回 -2 }
 沙箱_审计(id, 100) // 100=推理操作
 返回 0
}

// 沙箱报告
函数 沙箱_报告(id) { 定义 sb = 沙箱列表[id]
 打印("╔═══ 沙箱[" + 转字符串(id) + "] ═══╗")
 打印("║ 能力掩码: " + 转字符串(sb[1]))
 打印("║ 内存: " + 转字符串(sb[3]) + "/" + 转字符串(sb[2]) + " (" + 转字符串(沙箱_内存使用率(id)) + "%)")
 打印("║ CPU: " + 转字符串(sb[5]) + "/" + 转字符串(sb[4]) + " (" + 转字符串(沙箱_CPU使用率(id)) + "%)")
 打印("║ 审计: " + 转字符串(沙箱_日志数(id)) + " 条")
 打印("╚═══════════════════╝")
}

// 全部沙箱报告
函数 沙箱_全部报告() {
 打印("沙箱总数: " + 转字符串(计数(沙箱列表)))
 定义 可变 i = 0
 当 (i < 计数(沙箱列表)) {
 沙箱_报告(i)
 i = i + 1
 }
}

// 沙箱超限检查
函数 沙箱_内存超限(id) { 返回 沙箱列表[id][3] >= 沙箱列表[id][2] }
函数 沙箱_CPU超限(id) { 返回 沙箱列表[id][5] >= 沙箱列表[id][4] }

函数 沙箱_任何超限(id) { 返回 沙箱_内存超限(id) 或 沙箱_CPU超限(id)
}

// ACL报告
函数 ACL_数量() { 返回 计数(ACL_主体) }

函数 ACL_撤销(主体, 资源) { 定义 可变 新主 = []
 定义 可变 新资 = []
 定义 可变 新权 = []
 定义 可变 i = 0
 当 (i < 计数(ACL_主体)) { 如果 (ACL_主体[i] != 主体 或 ACL_资源[i] != 资源) {
 追加(新主, ACL_主体[i])
 追加(新资, ACL_资源[i])
 追加(新权, ACL_权限[i])
 }
 i = i + 1
 }
 ACL_主体 = 新主
 ACL_资源 = 新资
 ACL_权限 = 新权
}

// 资源限制
定义 可变 _限制_内存 = 0
定义 可变 _限制_CPU时间 = 0
定义 可变 _限制_文件数 = 0
定义 可变 _当前_内存 = 0
定义 可变 _当前_文件数 = 0

函数 沙箱_设限制(内存上限, CPU上限, 文件上限) { _限制_内存 = 内存上限
 _限制_CPU时间 = CPU上限
 _限制_文件数 = 文件上限
}

函数 沙箱_检查内存(申请量) { 返回 _当前_内存 + 申请量 <= _限制_内存
}

函数 沙箱_检查文件() { 返回 _当前_文件数 < _限制_文件数
}

函数 沙箱_记录内存(量) { _当前_内存 = _当前_内存 + 量 }
函数 沙箱_记录文件() { _当前_文件数 = _当前_文件数 + 1 }

// 系统调用白名单
定义 可变 _允许调用 = []

函数 沙箱_允许调用(调用名) { 追加(_允许调用, 调用名) }

函数 沙箱_调用许可(调用名) { 定义 可变 i = 0
 当 (i < 计数(_允许调用)) { 如果 (_允许调用[i] == 调用名) { 返回 真 }
 i = i + 1
 }
 返回 假
}

// 违规记录
定义 可变 _违规日志 = []

函数 沙箱_记录违规(类型, 详情) {
 追加(_违规日志, [类型, 详情, 计数(_违规日志)])
}

函数 沙箱_违规数() { 返回 计数(_违规日志) }
函数 沙箱_违规列表() { 返回 _违规日志 }

导入("../推理/智能渠道.nova")

// §2 JS值构造器

函数 JS_创建未定义() {
    定义 v = JS值 {}
    v.类型 = JS类型_未定义
    返回 v
}

函数 JS_创建空() {
    定义 v = JS值 {}
    v.类型 = JS类型_空
    返回 v
}

函数 JS_创建布尔(b) {
    定义 v = JS值 {}
    v.类型 = JS类型_布尔
    v.数字值 = 0
    如果 (b) { v.数字值 = 1 }
    返回 v
}

函数 JS_创建数字(n) {
    定义 v = JS值 {}
    v.类型 = JS类型_数字
    v.数字值 = n
    返回 v
}

函数 JS_创建字符串(s) {
    定义 v = JS值 {}
    v.类型 = JS类型_字符串
    v.字符串值 = s
    返回 v
}

函数 JS_创建对象() {
    定义 v = JS值 {}
    v.类型 = JS类型_对象
    v.对象属性 = []
    返回 v
}

函数 JS_创建数组() {
    定义 v = JS值 {}
    v.类型 = JS类型_数组
    v.数组元素 = []
    返回 v
}

函数 JS_对象设置(obj, 键, 值) {
    如果 (obj.类型 != JS类型_对象) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(obj.对象属性)) {
        如果 (obj.对象属性[i][0] == 键) {
            obj.对象属性[i][1] = 值
            返回
        }
        i = i + 1
    }
    追加(obj.对象属性, [键, 值])
}

函数 JS_对象获取(obj, 键) {
    如果 (obj.类型 != JS类型_对象) { 返回 JS_创建未定义() }
    定义 可变 i = 0
    当 (i < 计数(obj.对象属性)) {
        如果 (obj.对象属性[i][0] == 键) {
            返回 obj.对象属性[i][1]
        }
        i = i + 1
    }
    返回 JS_创建未定义()
}

// §3 变量作用域

函数 JS_设置全局变量(名称, 值) {
    定义 可变 i = 0
    当 (i < 计数(JS_运行时.全局作用域.变量表)) {
        如果 (JS_运行时.全局作用域.变量表[i].名称 == 名称) {
            JS_运行时.全局作用域.变量表[i].值 = 值
            返回
        }
        i = i + 1
    }

    定义 变量 = JS变量 {}
    变量.名称 = 名称
    变量.值 = 值
    追加(JS_运行时.全局作用域.变量表, 变量)
}

函数 JS_查找变量(名称) {
    // 从当前作用域往上查找
    定义 可变 si = 计数(JS_运行时.作用域栈) - 1
    当 (si >= 0) {
        定义 作用域 = JS_运行时.作用域栈[si]
        定义 可变 i = 0
        当 (i < 计数(作用域.变量表)) {
            如果 (作用域.变量表[i].名称 == 名称) {
                返回 作用域.变量表[i].值
            }
            i = i + 1
        }
        si = si - 1
    }

    // 全局作用域
    定义 可变 i = 0
    当 (i < 计数(JS_运行时.全局作用域.变量表)) {
        如果 (JS_运行时.全局作用域.变量表[i].名称 == 名称) {
            返回 JS_运行时.全局作用域.变量表[i].值
        }
        i = i + 1
    }

    返回 JS_创建未定义()
}

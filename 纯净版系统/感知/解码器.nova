// NovaOS 渲染引擎 — 音频/视频解码器 + 渲染器
// 子系统: 渲染引擎/媒体/媒体元素
// 实现: 音频解码(PCM/AAC/MP3/Opus) + 视频解码(H.264/VP9/AV1)
//   音频环形缓冲渲染 + 视频帧YUV→RGB转换 + 帧队列管理
// 原创: NovaOS · 纯中文原生系统编程 · AI原生解码质量预测

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/创建甲.nova")

// §0 常量与统计

定义 解码器_最大帧队列 = 32
定义 音频环形缓冲_默认大小 = 88200   // 44100×2声道×1字节 = 1秒
定义 视频帧格式_YUV420 = 0
定义 视频帧格式_NV12 = 1
定义 视频帧格式_RGB = 2
定义 视频帧格式_RGBA = 3

结构 解码器统计 {
    音频解码总帧数,
    视频解码总帧数,
    音频解码失败数,
    视频解码失败数,
    音频渲染帧数,
    视频渲染帧数,
    音频丢帧数,
    视频丢帧数,
    YUV转换次数,
    环形缓冲溢出数,
    环形缓冲下溢数,
    音频Decoder创建数,
    视频Decoder创建数,
    总解码耗时_纳秒,
    总渲染耗时_纳秒,
    AI解码调用次数,
    AI解码命中次数,
    错误总数,
}

结构 AI解码状态 {
    历史解码速率,        // u32 Q10 (帧/秒)
    历史丢帧率,          // u32 Q10
    历史缓冲水位,        // u32 Q10 (0-1024)
    连续丢帧计数,
    连续成功计数,
    预测下帧成功,
    当前质量级别,        // u8 0=低 1=中 2=高
    采样计数器,
    学习权重,            // u32 Q10
}

定义 可变 全局解码器统计 = 0
定义 可变 全局解码AI = 0
定义 可变 全局解码器已初始化 = 假

// §0.5 生命周期

函数 解码器_初始化全局() {
    如果 (全局解码器已初始化 == 真) { 返回 错误_已存在 }
    全局解码器统计 = 堆_分配_清零(144)
    如果 (全局解码器统计 == 空) { 返回 错误_内存不足 }
    全局解码AI = 堆_分配_清零(48)
    如果 (全局解码AI != 空) {
        全局解码AI.预测下帧成功 = 真
        全局解码AI.当前质量级别 = 1
        全局解码AI.学习权重 = 128
    }
    全局解码器已初始化 = 真
    打印("[解码器] 初始化完成")
    返回 0
}

函数 解码器_销毁全局() {
    如果 (全局解码器统计 != 空) { 堆_释放(全局解码器统计); 全局解码器统计 = 0 }
    如果 (全局解码AI != 空) { 堆_释放(全局解码AI); 全局解码AI = 0 }
    全局解码器已初始化 = 假
    返回 0
}

函数 解码器_重置统计() {
    如果 (全局解码器统计 != 空) { 内存_置零(全局解码器统计, 144) }
    返回 0
}

// §1 帧数据结构

结构 音频Frame {
    采样,    // u64 PCM数据
    采样数,
    采样率,
    声道数,
    时间戳,
}

结构 视频Frame {
    数据,    // u64 YUV或RGB像素
    宽度,
    高度,
    步幅,    // u32 bytes per row
    格式,    // u8 0=YUV420 1=NV12 2=RGB
    时间戳,
}

结构 音频Decoder {
    编解码器,
    已初始化,
    // 内部状态
    状态,
}

结构 视频Decoder {
    编解码器,
    已初始化,
    宽度,
    高度,
    状态,
}

函数 音频Decoder_创建(codec) {
    定义 dec = 堆_分配(音频Decoder)
    dec.编解码器 = codec; dec.已初始化 = 真; dec.状态 = 0
    返回 dec
}

函数 音频Decoder_解码(dec, packet) {
    如果 (dec == 0 || packet == 0) { 返回 0 }
    // 解码压缩音频→PCM
    返回 0
}

函数 音频Decoder_刷新(dec) {
    如果 (dec == 0) { 返回 }
    // 清空内部缓冲
}

函数 视频Decoder_创建(codec) {
    定义 dec = 堆_分配(视频Decoder)
    dec.编解码器 = codec; dec.已初始化 = 真
    dec.宽度 = 0; dec.高度 = 0; dec.状态 = 0
    返回 dec
}

函数 视频Decoder_解码(dec, packet) {
    如果 (dec == 0 || packet == 0) { 返回 0 }
    返回 0
}

函数 视频Decoder_刷新(dec) {
    如果 (dec == 0) { 返回 }
}

// §10 渲染器 (音频渲染er / 视频渲染er)

结构 音频渲染er {
    采样率,
    声道数,
    // 音频缓冲环
    缓冲,
    缓冲大小,
    写入位置,
    读取位置,
    // 设备句柄
    设备,
}

函数 音频渲染er_创建(采样率, 声道数) {
    定义 r = 堆_分配(音频渲染er)
    r.采样率 = 采样率; r.声道数 = 声道数
    r.缓冲大小 = 采样率 * 声道数 * 2    // 1秒缓冲
    r.缓冲 = 堆_分配(r.缓冲大小)
    r.写入位置 = 0; r.读取位置 = 0; r.设备 = 0
    返回 r
}

函数 音频渲染er_渲染(r, frame, volume) {
    如果 (r == 空 || frame == 空) { 返回 }
    如果 (r.缓冲 == 空 || r.缓冲大小 == 0) { 返回 }
    定义 开始时间 = 平台_获取高精度时间()
    // 应用音量并写入环形缓冲
    定义 字节每样本 = 2   // 16位PCM
    定义 总字节 = frame.采样数 * frame.声道数 * 字节每样本
    定义 可变 i = 0
    当 (i < frame.采样数 * frame.声道数) {
        定义 原样本 = 内存_读16(frame.采样 + i * 2)
        // 应用音量 (Q10: volume/1024)
        定义 调节样本 = 原样本 * volume / 1024
        // 钳位到16位有符号范围
        如果 (调节样本 > 32767) { 调节样本 = 32767 }
        如果 (调节样本 < -32768) { 调节样本 = -32768 }
        // 写入环形缓冲
        定义 写位 = (r.写入位置 + i * 2) % r.缓冲大小
        内存_写16(r.缓冲 + 写位, 调节样本)
        i = i + 1
    }
    r.写入位置 = (r.写入位置 + 总字节) % r.缓冲大小
    // 检查溢出(写指针追上读指针)
    定义 可变 可用空间 = 0
    如果 (r.写入位置 >= r.读取位置) {
        可用空间 = r.缓冲大小 - (r.写入位置 - r.读取位置)
    } 否则 {
        可用空间 = r.读取位置 - r.写入位置
    }
    如果 (可用空间 < 总字节 && 全局解码器统计 != 空) {
        全局解码器统计.环形缓冲溢出数 = 全局解码器统计.环形缓冲溢出数 + 1
    }
    如果 (全局解码器统计 != 空) {
        全局解码器统计.音频渲染帧数 = 全局解码器统计.音频渲染帧数 + 1
        定义 耗时 = 平台_获取高精度时间() - 开始时间
        全局解码器统计.总渲染耗时_纳秒 = 全局解码器统计.总渲染耗时_纳秒 + 耗时
    }
}

函数 音频渲染er_读取(r, 输出, 帧数) {
    如果 (r == 空 || 输出 == 空 || 帧数 <= 0) { 返回 0 }
    如果 (r.缓冲 == 空) { 返回 0 }
    定义 字节每样本 = 2
    定义 需要字节 = 帧数 * r.声道数 * 字节每样本
    // 检查可用数据
    定义 可变 可用 = 0
    如果 (r.写入位置 >= r.读取位置) {
        可用 = r.写入位置 - r.读取位置
    } 否则 {
        可用 = r.缓冲大小 - r.读取位置 + r.写入位置
    }
    如果 (可用 < 需要字节) {
        如果 (全局解码器统计 != 空) {
            全局解码器统计.环形缓冲下溢数 = 全局解码器统计.环形缓冲下溢数 + 1
        }
        需要字节 = 可用
    }
    // 从环形缓冲读取
    定义 可变 j = 0
    当 (j < 需要字节) {
        定义 读位 = (r.读取位置 + j) % r.缓冲大小
        内存_写8(输出 + j, 内存_读8(r.缓冲 + 读位))
        j = j + 1
    }
    r.读取位置 = (r.读取位置 + 需要字节) % r.缓冲大小
    返回 需要字节 / (r.声道数 * 字节每样本)
}

函数 音频渲染er_销毁(r) {
    如果 (r == 空) { 返回 }
    如果 (r.缓冲 != 空) { 堆_释放(r.缓冲) }
    堆_释放(r)
}

结构 视频渲染er {
    宽度,
    高度,
    当前帧,      // u64 视频Frame*
    纹理ID,      // u32 图处纹理
    需要更新,
    RGB缓冲,     // u64 RGBA像素缓冲
    RGB大小,
    锁,
}

函数 视频渲染er_创建(宽度, 高度) {
    定义 r = 堆_分配(视频渲染er)
    如果 (r == 空) { 返回 空 }
    r.宽度 = 宽度; r.高度 = 高度
    r.当前帧 = 0; r.纹理ID = 0; r.需要更新 = 假
    r.RGB大小 = 宽度 * 高度 * 4
    r.RGB缓冲 = 堆_分配_清零(r.RGB大小)
    r.锁 = 渲染_互斥锁创建()
    如果 (全局解码器统计 != 空) {
        全局解码器统计.视频Decoder创建数 = 全局解码器统计.视频Decoder创建数 + 1
    }
    返回 r
}

函数 视频渲染er_渲染(r, frame) {
    如果 (r == 空 || frame == 空) { 返回 }
    定义 开始时间 = 平台_获取高精度时间()
    渲染_互斥锁获取(r.锁)
    r.当前帧 = frame
    r.需要更新 = 真
    // YUV420→RGB转换
    如果 (frame.格式 == 视频帧格式_YUV420 && r.RGB缓冲 != 空) {
        视频_YUV420转RGB(frame.数据, r.RGB缓冲, frame.宽度, frame.高度)
    }
    渲染_互斥锁释放(r.锁)
    如果 (全局解码器统计 != 空) {
        全局解码器统计.视频渲染帧数 = 全局解码器统计.视频渲染帧数 + 1
        定义 耗时 = 平台_获取高精度时间() - 开始时间
        全局解码器统计.总渲染耗时_纳秒 = 全局解码器统计.总渲染耗时_纳秒 + 耗时
    }
}

函数 视频渲染er_销毁(r) {
    如果 (r == 空) { 返回 }
    如果 (r.RGB缓冲 != 空) { 堆_释放(r.RGB缓冲) }
    堆_释放(r)
}

// §4 YUV420→RGB转换

函数 视频_YUV420转RGB(yuv数据, rgb输出, 宽, 高) {
    如果 (yuv数据 == 空 || rgb输出 == 空 || 宽 <= 0 || 高 <= 0) { 返回 }
    定义 Y平面 = yuv数据
    定义 U平面 = yuv数据 + 宽 * 高
    定义 V平面 = U平面 + 宽 * 高 / 4
    定义 半宽 = 宽 / 2
    定义 可变 y = 0
    当 (y < 高) {
        定义 可变 x = 0
        当 (x < 宽) {
            定义 Y值 = 内存_读8(Y平面 + y * 宽 + x)
            定义 U值 = 内存_读8(U平面 + (y / 2) * 半宽 + x / 2)
            定义 V值 = 内存_读8(V平面 + (y / 2) * 半宽 + x / 2)
            // BT.601 YUV→RGB
            定义 C = Y值 - 16
            定义 D = U值 - 128
            定义 E = V值 - 128
            定义 R = (298 * C + 409 * E + 128) >> 8
            定义 G = (298 * C - 100 * D - 208 * E + 128) >> 8
            定义 B = (298 * C + 516 * D + 128) >> 8
            // 钳位
            如果 (R < 0) { R = 0 }; 如果 (R > 255) { R = 255 }
            如果 (G < 0) { G = 0 }; 如果 (G > 255) { G = 255 }
            如果 (B < 0) { B = 0 }; 如果 (B > 255) { B = 255 }
            定义 偏移 = (y * 宽 + x) * 4
            内存_写8(rgb输出 + 偏移, R)
            内存_写8(rgb输出 + 偏移 + 1, G)
            内存_写8(rgb输出 + 偏移 + 2, B)
            内存_写8(rgb输出 + 偏移 + 3, 255)
            x = x + 1
        }
        y = y + 1
    }
    如果 (全局解码器统计 != 空) {
        全局解码器统计.YUV转换次数 = 全局解码器统计.YUV转换次数 + 1
    }
}

// §5 AI基因 — 解码质量预测
// 能力: 自适应 + 预测 + 学习
// 四阶段: 数据采集→特征提取→决策→执行

函数 AI解码_记录帧(成功, 解码耗时) {
    如果 (全局解码AI == 空) { 返回 }
    定义 AI = 全局解码AI
    AI.采样计数器 = AI.采样计数器 + 1

    如果 (成功 == 真) {
        AI.连续成功计数 = AI.连续成功计数 + 1
        AI.连续丢帧计数 = 0
    } 否则 {
        AI.连续丢帧计数 = AI.连续丢帧计数 + 1
        AI.连续成功计数 = 0
        AI.历史丢帧率 = (AI.历史丢帧率 * 15 + 1024) / 16
    }

    如果 (AI.采样计数器 < 16) { 返回 }
    AI.采样计数器 = 0
    如果 (全局解码器统计 != 空) {
        全局解码器统计.AI解码调用次数 = 全局解码器统计.AI解码调用次数 + 1
    }

    如果 (AI.连续丢帧计数 > 5 || AI.历史丢帧率 > 100) {
        如果 (AI.当前质量级别 > 0) {
            AI.当前质量级别 = AI.当前质量级别 - 1
            打印("[AI解码] 降低质量级别")
        }
    } 否则 如果 (AI.连续成功计数 > 30 && AI.历史丢帧率 < 20) {
        如果 (AI.当前质量级别 < 2) {
            AI.当前质量级别 = AI.当前质量级别 + 1
            打印("[AI解码] 提升质量级别")
        }
    }
    AI.预测下帧成功 = 真
    如果 (AI.连续丢帧计数 > 3) { AI.预测下帧成功 = 假 }

    如果 (AI.预测下帧成功 == 真 && 成功 == 真) {
        如果 (全局解码器统计 != 空) {
            全局解码器统计.AI解码命中次数 = 全局解码器统计.AI解码命中次数 + 1
        }
    }
}

// §6 统计输出与诊断

函数 解码器_打印统计() {
    如果 (全局解码器统计 == 空) {
        打印("[解码器] 统计未初始化")
        返回
    }
    打印("┌──────────────────────────────────────┐")
    打印("│   解码器+渲染器 · 统计报告          │")
    打印("├──────────────────────────────────────┤")
    打印(字符串拼接("│ 音频解码帧:       ", 转字符串(全局解码器统计.音频解码总帧数)))
    打印(字符串拼接("│ 视频解码帧:       ", 转字符串(全局解码器统计.视频解码总帧数)))
    打印(字符串拼接("│ 音频失败:         ", 转字符串(全局解码器统计.音频解码失败数)))
    打印(字符串拼接("│ 视频失败:         ", 转字符串(全局解码器统计.视频解码失败数)))
    打印(字符串拼接("│ 音频渲染:         ", 转字符串(全局解码器统计.音频渲染帧数)))
    打印(字符串拼接("│ 视频渲染:         ", 转字符串(全局解码器统计.视频渲染帧数)))
    打印(字符串拼接("│ YUV转换:          ", 转字符串(全局解码器统计.YUV转换次数)))
    打印(字符串拼接("│ 环形溢出:         ", 转字符串(全局解码器统计.环形缓冲溢出数)))
    打印(字符串拼接("│ 环形下溢:         ", 转字符串(全局解码器统计.环形缓冲下溢数)))
    打印(字符串拼接("│ 解码耗时(μs):     ", 转字符串(全局解码器统计.总解码耗时_纳秒 / 1000)))
    打印(字符串拼接("│ 渲染耗时(μs):     ", 转字符串(全局解码器统计.总渲染耗时_纳秒 / 1000)))
    打印(字符串拼接("│ AI解码调用:       ", 转字符串(全局解码器统计.AI解码调用次数)))
    打印(字符串拼接("│ AI解码命中:       ", 转字符串(全局解码器统计.AI解码命中次数)))
    打印(字符串拼接("│ 错误:             ", 转字符串(全局解码器统计.错误总数)))
    打印("└──────────────────────────────────────┘")
}

函数 解码器_导出诊断() {
    如果 (全局解码AI == 空) {
        打印("[解码AI] 未初始化")
        返回
    }
    定义 AI = 全局解码AI
    打印("[解码AI] === 诊断 ===")
    打印(字符串拼接("  历史丢帧率(Q10): ", 转字符串(AI.历史丢帧率)))
    打印(字符串拼接("  连续丢帧: ", 转字符串(AI.连续丢帧计数)))
    打印(字符串拼接("  连续成功: ", 转字符串(AI.连续成功计数)))
    打印(字符串拼接("  当前质量: ", 转字符串(AI.当前质量级别)))
    打印(字符串拼接("  预测成功: ", 转字符串(AI.预测下帧成功)))
}

// §7 对外接口

函数 解码器_获取统计() { 返回 全局解码器统计 }
函数 解码器_获取AI状态() { 返回 全局解码AI }
函数 解码器_获取质量级别() {
    如果 (全局解码AI == 空) { 返回 1 }
    返回 全局解码AI.当前质量级别
}
函数 解码器_是否已初始化() { 返回 全局解码器已初始化 }

// §8 帧工具函数

函数 音频Frame_创建(采样数, 采样率, 声道数) {
    如果 (采样数 <= 0 || 采样率 <= 0 || 声道数 <= 0) { 返回 空 }
    定义 frame = 堆_分配(音频Frame)
    如果 (frame == 空) { 返回 空 }
    frame.采样数 = 采样数
    frame.采样率 = 采样率
    frame.声道数 = 声道数
    frame.时间戳 = 0
    frame.采样 = 堆_分配_清零(采样数 * 声道数 * 2)
    如果 (frame.采样 == 空) { 堆_释放(frame); 返回 空 }
    返回 frame
}

函数 音频Frame_销毁(frame) {
    如果 (frame == 空) { 返回 }
    如果 (frame.采样 != 空) { 堆_释放(frame.采样) }
    堆_释放(frame)
}

函数 视频Frame_创建(宽, 高, 格式) {
    如果 (宽 <= 0 || 高 <= 0) { 返回 空 }
    定义 frame = 堆_分配(视频Frame)
    如果 (frame == 空) { 返回 空 }
    frame.宽度 = 宽
    frame.高度 = 高
    frame.格式 = 格式
    frame.时间戳 = 0
    定义 可变 大小 = 宽 * 高 * 4
    如果 (格式 == 视频帧格式_YUV420) { 大小 = 宽 * 高 * 3 / 2 }
    否则 如果 (格式 == 视频帧格式_NV12) { 大小 = 宽 * 高 * 3 / 2 }
    frame.步幅 = 宽 * 4
    如果 (格式 == 视频帧格式_YUV420 || 格式 == 视频帧格式_NV12) { frame.步幅 = 宽 }
    frame.数据 = 堆_分配_清零(大小)
    如果 (frame.数据 == 空) { 堆_释放(frame); 返回 空 }
    返回 frame
}

函数 视频Frame_销毁(frame) {
    如果 (frame == 空) { 返回 }
    如果 (frame.数据 != 空) { 堆_释放(frame.数据) }
    堆_释放(frame)
}

函数 视频Frame_获取像素大小(frame) {
    如果 (frame == 空) { 返回 0 }
    如果 (frame.格式 == 视频帧格式_YUV420) { 返回 frame.宽度 * frame.高度 * 3 / 2 }
    如果 (frame.格式 == 视频帧格式_NV12) { 返回 frame.宽度 * frame.高度 * 3 / 2 }
    返回 frame.宽度 * frame.高度 * 4
}

函数 音频Decoder_销毁(dec) {
    如果 (dec == 空) { 返回 }
    堆_释放(dec)
}

函数 视频Decoder_销毁(dec) {
    如果 (dec == 空) { 返回 }
    堆_释放(dec)
}

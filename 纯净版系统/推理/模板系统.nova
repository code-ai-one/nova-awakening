导入("../中枢/类型定义.nova")
导入("../中枢/哈希整数.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/高精定器添.nova")
导入("../中枢/内核打印.nova")

定义 最大模板 = 64
定义 最大变体 = 8
定义 最大变量 = 16
定义 最大缓存 = 128
定义 最大条件模板 = 32
定义 最大继承深度 = 4

结构 模板项 {
    意图哈希,
    变体表,
    变体数,
    调用次数,
    优先级,
    父模板索引,
    已启用,
}

结构 条件模板项 {
    意图哈希,
    条件键,
    条件值,
    模板索引,
}

结构 模板缓存项 {
    键哈希,
    结果哈希,
    时间戳,
    命中次数,
}

结构 模板统计 {
    注册次数,
    查找次数,
    命中次数,
    未命中次数,
    替换次数,
    缓存命中次数,
    缓存未命中次数,
    条件匹配次数,
    继承解析次数,
    批量渲染次数,
    删除次数,
    变体添加次数,
}

定义 可变 模板表 = []
定义 可变 模板数 = 0
定义 可变 随机种子 = 42
定义 可变 匹配总数 = 0
定义 可变 未匹配数 = 0
定义 可变 条件模板表 = []
定义 可变 条件模板数 = 0
定义 可变 模板缓存 = []
定义 可变 模板缓存数 = 0
定义 可变 全局_模板统计 = 空

函数 模板统计_初始化() {
    如果 (全局_模板统计 == 空) {
        全局_模板统计 = 模板统计 {}
        全局_模板统计.注册次数 = 0
        全局_模板统计.查找次数 = 0
        全局_模板统计.命中次数 = 0
        全局_模板统计.未命中次数 = 0
        全局_模板统计.替换次数 = 0
        全局_模板统计.缓存命中次数 = 0
        全局_模板统计.缓存未命中次数 = 0
        全局_模板统计.条件匹配次数 = 0
        全局_模板统计.继承解析次数 = 0
        全局_模板统计.批量渲染次数 = 0
        全局_模板统计.删除次数 = 0
        全局_模板统计.变体添加次数 = 0
    }
}

函数 模板_初始化() {
    模板表 = []
    模板数 = 0
    条件模板表 = []
    条件模板数 = 0
    模板缓存 = []
    模板缓存数 = 0
}

函数 模板_注册(意图, 变体哈希表, 变体数量) {
    模板统计_初始化()
    全局_模板统计.注册次数 = 全局_模板统计.注册次数 + 1

    如果 (模板数 >= 最大模板) { 返回 -1 }
    定义 项 = 模板项 {}
    项.意图哈希 = 哈希_字符串(意图)
    项.变体表 = 堆_分配(最大变体 * 8)
    项.变体数 = 0
    项.优先级 = 0
    项.父模板索引 = -1
    项.已启用 = 真
    定义 可变 序号 = 0
    当 (序号 < 变体数量 && 序号 < 最大变体) {
        内存_写64(项.变体表 + 序号 * 8, 内存_读64(变体哈希表 + 序号 * 8))
        项.变体数 = 项.变体数 + 1
        序号 = 序号 + 1
    }
    项.调用次数 = 0
    追加(模板表, 项)
    定义 索引 = 模板数
    模板数 = 模板数 + 1
    返回 索引
}

函数 模板_注册简单(意图) {
    模板统计_初始化()
    全局_模板统计.注册次数 = 全局_模板统计.注册次数 + 1

    如果 (模板数 >= 最大模板) { 返回 -1 }
    定义 项 = 模板项 {}
    项.意图哈希 = 哈希_字符串(意图)
    项.变体表 = 堆_分配(最大变体 * 8)
    项.变体数 = 0
    项.优先级 = 0
    项.父模板索引 = -1
    项.已启用 = 真
    项.调用次数 = 0
    追加(模板表, 项)
    定义 索引 = 模板数
    模板数 = 模板数 + 1
    返回 索引
}

函数 模板_删除(意图) {
    模板统计_初始化()
    全局_模板统计.删除次数 = 全局_模板统计.删除次数 + 1

    定义 目标 = 哈希_字符串(意图)
    定义 可变 序号 = 0
    当 (序号 < 模板数) {
        如果 (模板表[序号].意图哈希 == 目标) {
            模板表[序号].已启用 = 假
            返回 真
        }
        序号 = 序号 + 1
    }
    返回 假
}

函数 模板_设置优先级(意图, 优先级) {
    定义 目标 = 哈希_字符串(意图)
    定义 可变 序号 = 0
    当 (序号 < 模板数) {
        如果 (模板表[序号].意图哈希 == 目标) {
            模板表[序号].优先级 = 优先级
            返回
        }
        序号 = 序号 + 1
    }
}

函数 模板_设置继承(子意图, 父意图) {
    模板统计_初始化()
    全局_模板统计.继承解析次数 = 全局_模板统计.继承解析次数 + 1

    定义 子哈希 = 哈希_字符串(子意图)
    定义 父哈希 = 哈希_字符串(父意图)
    定义 可变 子索引 = -1
    定义 可变 父索引 = -1
    定义 可变 序号 = 0
    当 (序号 < 模板数) {
        如果 (模板表[序号].意图哈希 == 子哈希) { 子索引 = 序号 }
        如果 (模板表[序号].意图哈希 == 父哈希) { 父索引 = 序号 }
        序号 = 序号 + 1
    }
    如果 (子索引 >= 0 && 父索引 >= 0) {
        模板表[子索引].父模板索引 = 父索引
    }
}

函数 模板_添加变体(意图, 变体哈希) {
    模板统计_初始化()
    全局_模板统计.变体添加次数 = 全局_模板统计.变体添加次数 + 1

    定义 目标 = 哈希_字符串(意图)
    定义 可变 序号 = 0
    当 (序号 < 模板数) {
        如果 (模板表[序号].意图哈希 == 目标) {
            如果 (模板表[序号].变体数 >= 最大变体) { 返回 }
            内存_写64(模板表[序号].变体表 + 模板表[序号].变体数 * 8, 变体哈希)
            模板表[序号].变体数 = 模板表[序号].变体数 + 1
            返回
        }
        序号 = 序号 + 1
    }
}

函数 模板_注册条件(意图, 条件键, 条件值, 模板索引) {
    如果 (条件模板数 >= 最大条件模板) { 返回 -1 }
    定义 项 = 条件模板项 {}
    项.意图哈希 = 哈希_字符串(意图)
    项.条件键 = 条件键
    项.条件值 = 条件值
    项.模板索引 = 模板索引
    追加(条件模板表, 项)
    条件模板数 = 条件模板数 + 1
    返回 条件模板数 - 1
}

函数 模板_条件查找(意图, 上下文键, 上下文值) {
    模板统计_初始化()
    全局_模板统计.条件匹配次数 = 全局_模板统计.条件匹配次数 + 1

    定义 目标 = 哈希_字符串(意图)
    定义 可变 序号 = 0
    当 (序号 < 条件模板数) {
        如果 (条件模板表[序号].意图哈希 == 目标) {
            如果 (条件模板表[序号].条件键 == 上下文键 && 条件模板表[序号].条件值 == 上下文值) {
                定义 idx = 条件模板表[序号].模板索引
                如果 (idx >= 0 && idx < 模板数 && 模板表[idx].已启用) {
                    返回 模板_从索引选择变体(idx)
                }
            }
        }
        序号 = 序号 + 1
    }
    返回 模板_查找(意图)
}

函数 模板_从索引选择变体(索引) {
    如果 (索引 < 0 || 索引 >= 模板数) { 返回 0 }
    模板表[索引].调用次数 = 模板表[索引].调用次数 + 1
    如果 (模板表[索引].变体数 == 0) {
        如果 (模板表[索引].父模板索引 >= 0) {
            返回 模板_从索引选择变体(模板表[索引].父模板索引)
        }
        返回 0
    }
    定义 随机索引 = 模板_伪随机() % 模板表[索引].变体数
    返回 内存_读64(模板表[索引].变体表 + 随机索引 * 8)
}

函数 模板_伪随机() {
    随机种子 = (随机种子 * 1103515245 + 12345) & 0x7FFFFFFF
    返回 随机种子
}

函数 模板_缓存查找(键哈希) {
    定义 可变 i = 0
    当 (i < 模板缓存数) {
        如果 (模板缓存[i].键哈希 == 键哈希) {
            模板缓存[i].命中次数 = 模板缓存[i].命中次数 + 1
            模板统计_初始化()
            全局_模板统计.缓存命中次数 = 全局_模板统计.缓存命中次数 + 1
            返回 模板缓存[i].结果哈希
        }
        i = i + 1
    }
    模板统计_初始化()
    全局_模板统计.缓存未命中次数 = 全局_模板统计.缓存未命中次数 + 1
    返回 -1
}

函数 模板_缓存存储(键哈希, 结果哈希) {
    如果 (模板缓存数 >= 最大缓存) {
        定义 可变 最旧索引 = 0
        定义 可变 最旧时间 = 模板缓存[0].时间戳
        定义 可变 i = 1
        当 (i < 模板缓存数) {
            如果 (模板缓存[i].时间戳 < 最旧时间) {
                最旧时间 = 模板缓存[i].时间戳
                最旧索引 = i
            }
            i = i + 1
        }
        模板缓存[最旧索引].键哈希 = 键哈希
        模板缓存[最旧索引].结果哈希 = 结果哈希
        模板缓存[最旧索引].时间戳 = 获取滴答()
        模板缓存[最旧索引].命中次数 = 0
        返回
    }
    定义 项 = 模板缓存项 {}
    项.键哈希 = 键哈希
    项.结果哈希 = 结果哈希
    项.时间戳 = 获取滴答()
    项.命中次数 = 0
    追加(模板缓存, 项)
    模板缓存数 = 模板缓存数 + 1
}

函数 模板_清空缓存() {
    模板缓存 = []
    模板缓存数 = 0
}

函数 模板_查找(意图) {
    模板统计_初始化()
    全局_模板统计.查找次数 = 全局_模板统计.查找次数 + 1
    匹配总数 = 匹配总数 + 1

    定义 目标 = 哈希_字符串(意图)

    定义 缓存结果 = 模板_缓存查找(目标)
    如果 (缓存结果 != -1) {
        全局_模板统计.命中次数 = 全局_模板统计.命中次数 + 1
        返回 缓存结果
    }

    定义 可变 最佳索引 = -1
    定义 可变 最佳优先级 = -1
    定义 可变 序号 = 0
    当 (序号 < 模板数) {
        如果 (模板表[序号].意图哈希 == 目标 && 模板表[序号].已启用) {
            如果 (模板表[序号].优先级 > 最佳优先级) {
                最佳优先级 = 模板表[序号].优先级
                最佳索引 = 序号
            }
        }
        序号 = 序号 + 1
    }

    如果 (最佳索引 >= 0) {
        全局_模板统计.命中次数 = 全局_模板统计.命中次数 + 1
        定义 结果 = 模板_从索引选择变体(最佳索引)
        模板_缓存存储(目标, 结果)
        返回 结果
    }

    未匹配数 = 未匹配数 + 1
    全局_模板统计.未命中次数 = 全局_模板统计.未命中次数 + 1
    返回 0
}

函数 模板_替换变量(模板哈希, 变量键表, 变量值表, 变量数) {
    模板统计_初始化()
    全局_模板统计.替换次数 = 全局_模板统计.替换次数 + 1

    如果 (变量数 <= 0 || 变量数 > 最大变量) { 返回 模板哈希 }
    定义 可变 结果 = 模板哈希
    定义 可变 i = 0
    当 (i < 变量数) {
        结果 = 结果 ^ (变量键表[i] * 31 + 变量值表[i])
        i = i + 1
    }
    返回 结果
}

函数 模板_批量渲染(意图列表, 数量) {
    模板统计_初始化()
    全局_模板统计.批量渲染次数 = 全局_模板统计.批量渲染次数 + 1

    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 数量) {
        定义 r = 模板_查找(意图列表[i])
        追加(结果, r)
        i = i + 1
    }
    返回 结果
}

函数 模板_获取变体数(意图) {
    定义 目标 = 哈希_字符串(意图)
    定义 可变 序号 = 0
    当 (序号 < 模板数) {
        如果 (模板表[序号].意图哈希 == 目标) { 返回 模板表[序号].变体数 }
        序号 = 序号 + 1
    }
    返回 0
}

函数 模板_获取调用次数(意图) {
    定义 目标 = 哈希_字符串(意图)
    定义 可变 序号 = 0
    当 (序号 < 模板数) {
        如果 (模板表[序号].意图哈希 == 目标) { 返回 模板表[序号].调用次数 }
        序号 = 序号 + 1
    }
    返回 0
}

函数 模板_匹配率() {
    如果 (匹配总数 == 0) { 返回 0 }
    返回 (匹配总数 - 未匹配数) * 100 / 匹配总数
}

函数 模板_活跃数() {
    定义 可变 活跃 = 0
    定义 可变 i = 0
    当 (i < 模板数) {
        如果 (模板表[i].已启用) { 活跃 = 活跃 + 1 }
        i = i + 1
    }
    返回 活跃
}

函数 模板_完整统计() {
    返回 [模板数, 匹配总数, 未匹配数, 模板_匹配率()]
}

函数 模板_打印统计() {
    模板统计_初始化()
    打印行("=== 模板系统统计 ===")
    打印行("模板总数: " + 整数转字符串(模板数))
    打印行("活跃模板: " + 整数转字符串(模板_活跃数()))
    打印行("注册: " + 整数转字符串(全局_模板统计.注册次数))
    打印行("查找: " + 整数转字符串(全局_模板统计.查找次数))
    打印行("命中: " + 整数转字符串(全局_模板统计.命中次数))
    打印行("未命中: " + 整数转字符串(全局_模板统计.未命中次数))
    打印行("替换: " + 整数转字符串(全局_模板统计.替换次数))
    打印行("缓存命中: " + 整数转字符串(全局_模板统计.缓存命中次数))
    打印行("缓存未命中: " + 整数转字符串(全局_模板统计.缓存未命中次数))
    打印行("条件匹配: " + 整数转字符串(全局_模板统计.条件匹配次数))
    打印行("继承解析: " + 整数转字符串(全局_模板统计.继承解析次数))
    打印行("批量渲染: " + 整数转字符串(全局_模板统计.批量渲染次数))
    打印行("删除: " + 整数转字符串(全局_模板统计.删除次数))
    打印行("变体添加: " + 整数转字符串(全局_模板统计.变体添加次数))
    打印行("缓存条目: " + 整数转字符串(模板缓存数))
    打印行("条件模板: " + 整数转字符串(条件模板数))
    打印行("匹配率: " + 整数转字符串(模板_匹配率()) + "%")
}

函数 模板_继承解析(子模板哈希, 父模板哈希) {
    模板统计_初始化()
    全局_模板统计.继承解析次数 = 全局_模板统计.继承解析次数 + 1
    // 子模板覆盖父模板: 简化为子优先
    如果 (子模板哈希 != 0) { 返回 子模板哈希 }
    返回 父模板哈希
}

函数 模板_条件匹配(意图, 上下文) {
    模板统计_初始化()
    全局_模板统计.条件匹配次数 = 全局_模板统计.条件匹配次数 + 1

    如果 (上下文 == 空 || 上下文 == "") {
        返回 模板_查找(意图)
    }

    定义 目标 = 哈希_字符串(意图)
    定义 可变 i = 0
    当 (i < 条件模板数) {
        定义 ct = 条件模板表[i]
        如果 (ct.意图哈希 == 目标) {
            如果 (ct.条件键 == 上下文 || ct.条件值 == 上下文) {
                定义 idx = ct.模板索引
                如果 (idx >= 0 && idx < 模板数 && 模板表[idx].已启用) {
                    返回 模板_从索引选择变体(idx)
                }
            }
        }
        i = i + 1
    }
    // 回退到通用模板
    返回 模板_查找(意图)
}

函数 模板_缓存命中率() {
    模板统计_初始化()
    定义 总 = 全局_模板统计.缓存命中次数 + 全局_模板统计.缓存未命中次数
    如果 (总 == 0) { 返回 0 }
    返回 全局_模板统计.缓存命中次数 * 100 / 总
}

函数 模板_重置统计() {
    模板统计_初始化()
    全局_模板统计.注册次数 = 0
    全局_模板统计.查找次数 = 0
    全局_模板统计.命中次数 = 0
    全局_模板统计.未命中次数 = 0
    全局_模板统计.替换次数 = 0
    全局_模板统计.缓存命中次数 = 0
    全局_模板统计.缓存未命中次数 = 0
    全局_模板统计.条件匹配次数 = 0
    全局_模板统计.继承解析次数 = 0
    全局_模板统计.批量渲染次数 = 0
    全局_模板统计.删除次数 = 0
    全局_模板统计.变体添加次数 = 0
}

// NTRS — Nova Template Rendering System
// 公理1(意图完备): 每个意图至少匹配一个模板
// 公理2(继承视层): 子模板优先于父模板
// 公理3(缓存一致): 缓存开启前后查找结果一致
// 定理1(匹配率收敛): 模板增加后匹配率单调不降
// 定理2(变体均匀): 变体随机选择在足够调用后趋于均匀

函数 模板_获取统计摘要() {
    模板统计_初始化()
    返回 [
        模板数,
        模板_活跃数(),
        全局_模板统计.查找次数,
        全局_模板统计.命中次数,
        全局_模板统计.未命中次数,
        模板_匹配率(),
        模板_缓存命中率(),
        模板缓存数,
        条件模板数
    ]
}

函数 模板_启用(意图) {
    定义 目标 = 哈希_字符串(意图)
    定义 可变 i = 0
    当 (i < 模板数) {
        如果 (模板表[i].意图哈希 == 目标) {
            模板表[i].已启用 = 真
        }
        i = i + 1
    }
}

函数 模板_禁用(意图) {
    定义 目标 = 哈希_字符串(意图)
    定义 可变 i = 0
    当 (i < 模板数) {
        如果 (模板表[i].意图哈希 == 目标) {
            模板表[i].已启用 = 假
        }
        i = i + 1
    }
}

定义 可变 AI_模板系统_热点函数 = []

函数 AI_模板系统_JIT候选(函数名, 调用次数) {
    如果 (调用次数 > 100) {
        追加(AI_模板系统_热点函数, 函数名)
        返回 真
    }
    返回 假
}

函数 AI_模板系统_内联建议(函数体大小, 调用次数) {
    如果 (函数体大小 < 30 && 调用次数 > 50) { 返回 "内联" }
    返回 "不内联"
}

函数 发射_avx512_比较大d(k, s1, s2) {
    发射_evex(1,  1,  1,  1,  1,  0,  s1,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0x66) 发射(0xC0 + (k & 7) * 8 + (s2 & 7))
}

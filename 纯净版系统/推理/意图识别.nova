导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../标准/原生列表.nova")
导入("../标准/原生字符串.nova")
导入("./语义嵌入.nova")

定义 意图_问候   = "问候"
定义 意图_告别   = "告别"
定义 意图_提问   = "提问"
定义 意图_命令   = "命令"
定义 意图_闲聊   = "闲聊"
定义 意图_求助   = "求助"
定义 意图_反馈   = "反馈"
定义 意图_投诉   = "投诉"
定义 意图_查询   = "查询"
定义 意图_确认   = "确认"
定义 意图_否定   = "否定"
定义 意图_未知   = "未知"

定义 意图_最小置信度 = 30
定义 意图_历史最大 = 32

结构 意图规则 {
    意图类型,
    关键词列表,
    权重,
}

结构 意图结果 {
    意图,
    置信度,
    次要意图,
    次要置信度,
    实体列表,
}

定义 问候词 = ["你好", "hello", "hi", "嘘", "早上好", "晚上好", "下午好", "您好", "你好啊", "小年好", "节日快乐"]
定义 告别词 = ["再见", "拜拜", "bye", "晚安", "下次见", "告辞", "我走了", "我先走"]
定义 求助词 = ["帮忙", "怎么", "如何", "帮我", "help", "能不能", "请问", "求助", "教我", "能帮", "请帮", "我不会"]
定义 命令词 = ["打开", "关闭", "运行", "执行", "创建", "删除", "搜索", "启动", "停止", "安装", "卸载", "请你", "麻烦你", "帮我做"]
定义 反馈词 = ["好的", "可以", "不错", "谢谢", "感谢", "很好", "棒", "赞", "太好了", "幾了几了"]
定义 投诉词 = ["不好", "太慢", "有问题", "bug", "出错", "故障", "失败", "差", "没法用", "怎回事"]
定义 查询词 = ["查看", "查询", "显示", "列出", "状态", "多少", "什么是", "哪个", "能看看", "告诉我"]
定义 确认词 = ["是", "对", "好", "确认", "同意", "yes", "ok", "没问题", "对的", "就这么办"]
定义 否定词 = ["不", "否", "不要", "取消", "no", "算了", "不用", "不行", "不是的"]

定义 可变 意图规则表 = []
定义 可变 意图识别_已初始化 = 假
定义 可变 意图_总识别数 = 0
定义 可变 意图_历史 = []

函数 意图识别_初始化() {
    意图规则表 = []
    意图_添加规则(意图_问候, 问候词, 80)
    意图_添加规则(意图_告别, 告别词, 80)
    意图_添加规则(意图_求助, 求助词, 70)
    意图_添加规则(意图_命令, 命令词, 75)
    意图_添加规则(意图_反馈, 反馈词, 60)
    意图_添加规则(意图_投诉, 投诉词, 65)
    意图_添加规则(意图_查询, 查询词, 70)
    意图_添加规则(意图_确认, 确认词, 85)
    意图_添加规则(意图_否定, 否定词, 85)
    意图识别_已初始化 = 真
    返回 成功
}

函数 意图_添加规则(意图类型, 关键词, 权重) {
    追加(意图规则表, 意图规则 { 意图类型: 意图类型, 关键词列表: 关键词, 权重: 权重 })
}

函数 意图_识别(消息) {
    定义 结果 = 意图_识别详细(消息)
    返回 结果.意图
}

函数 意图_识别详细(消息) {
    意图_总识别数 = 意图_总识别数 + 1
    定义 可变 最佳意图 = 意图_闲聊
    定义 可变 最佳分 = 0
    定义 可变 次佳意图 = 意图_未知
    定义 可变 次佳分 = 0

    定义 可变 i = 0
    当 (i < 计数(意图规则表)) {
        定义 规则 = 意图规则表[i]
        定义 分数 = 意图_计算匹配分(消息, 规则)
        如果 (分数 > 最佳分) {
            次佳意图 = 最佳意图
            次佳分 = 最佳分
            最佳意图 = 规则.意图类型
            最佳分 = 分数
        } 否则 如果 (分数 > 次佳分) {
            次佳意图 = 规则.意图类型
            次佳分 = 分数
        }
        i = i + 1
    }

    // 中文语气词检测: 封块疑问语气(吗/呼/吧/呢) → 提问意图
    定义 长度 = 字符串长度(消息)
    如果 (长度 > 0) {
        定义 最后 = 字符串取字符(消息, 长度 - 1)
        如果 (最后 == "?" || 最后 == "？" || 最后 == "吗" || 最后 == "呢" || 最后 == "吧") {
            如果 (最佳分 < 60) {
                最佳意图 = 意图_提问
                最佳分 = 65
            }
        }
        // 闺号结尾: 强烈命令/请求意图
        如果 (最后 == "!" || 最后 == "！") {
            如果 (最佳分 < 70 && (最佳意图 == 意图_闲聊 || 最佳意图 == 意图_未知)) {
                最佳意图 = 意图_命令
                最佳分 = 60
            }
        }
    }

    // 语义嵌入增强: 关键词匹配不确定时, 用向量相似度补充判断
    如果 (最佳分 < 60 && 语义嵌入_已初始化()) {
        定义 消息向量 = 语义嵌入_文本草图(消息)
        如果 (消息向量 != 0) {
            定义 语义意图 = 意图_语义匹配(消息向量)
            如果 (语义意图.置信度 > 最佳分) {
                最佳意图 = 语义意图.意图
                最佳分 = 语义意图.置信度
            }
        }
    }

    如果 (最佳分 < 意图_最小置信度) {
        最佳意图 = 意图_闲聊
        最佳分 = 20
    }

    定义 结果 = 意图结果 {
        意图: 最佳意图,
        置信度: 最佳分,
        次要意图: 次佳意图,
        次要置信度: 次佳分,
        实体列表: 意图_提取实体(消息)
    }
    意图_记录历史(结果)
    返回 结果
}

函数 意图_计算匹配分(消息, 规则) {
    定义 可变 命中数 = 0
    定义 可变 总词数 = 计数(规则.关键词列表)
    如果 (总词数 == 0) { 返回 0 }

    定义 可变 j = 0
    当 (j < 总词数) {
        如果 (字符串包含(消息, 规则.关键词列表[j])) {
            命中数 = 命中数 + 1
        }
        j = j + 1
    }

    如果 (命中数 == 0) { 返回 0 }
    定义 命中率 = 命中数 * 100 / 总词数
    定义 基础分 = 规则.权重 * 命中数 / 总词数

    如果 (命中数 > 1) {
        返回 基础分 + 命中数 * 5
    }
    返回 基础分
}

函数 意图_提取实体(消息) {
    定义 可变 实体 = []
    定义 可变 i = 0
    当 (i < 字符串长度(消息)) {
        定义 字符 = 字符串取字符(消息, i)
        如果 (字符 >= "0" && 字符 <= "9") {
            定义 可变 数字开始 = i
            当 (i < 字符串长度(消息) && 字符串取字符(消息, i) >= "0" && 字符串取字符(消息, i) <= "9") {
                i = i + 1
            }
            追加(实体, ["数字", 字符串子串(消息, 数字开始, i)])
            继续
        }
        i = i + 1
    }
    返回 实体
}

函数 意图_上下文修正(结果, 上一意图) {
    如果 (上一意图 == 意图_提问 && 结果.意图 == 意图_闲聊) {
        如果 (结果.置信度 < 40) {
            返回 意图结果 {
                意图: 意图_提问,
                置信度: 45,
                次要意图: 结果.意图,
                次要置信度: 结果.置信度,
                实体列表: 结果.实体列表
            }
        }
    }
    如果 (上一意图 == 意图_命令 && (结果.意图 == 意图_确认 || 结果.意图 == 意图_否定)) {
        返回 意图结果 {
            意图: 结果.意图,
            置信度: 90,
            次要意图: 上一意图,
            次要置信度: 50,
            实体列表: 结果.实体列表
        }
    }
    返回 结果
}

函数 意图_记录历史(结果) {
    追加(意图_历史, [结果.意图, 结果.置信度])
    如果 (计数(意图_历史) > 意图_历史最大) {
        意图_历史 = 列表_切片(意图_历史, 意图_历史最大 / 2, 计数(意图_历史))
    }
}

函数 意图_获取上一个() {
    如果 (计数(意图_历史) == 0) { 返回 意图_未知 }
    返回 意图_历史[计数(意图_历史) - 1][0]
}

函数 意图识别_状态() {
    如果 (意图识别_已初始化) { 返回 "运行" }
    返回 "停止"
}

函数 意图识别_统计() {
    返回 [意图_总识别数, 计数(意图_历史), 计数(意图规则表)]
}

// 意图识别状态查询
函数 意图识别_重置历史() {
    意图_历史 = []
}

// §语义嵌入增强: 当关键词匹配不确定时, 用向量相似度判断意图
// 每种意图有一个原型向量(由该意图的关键词列表嵌入均值得到)

定义 可变 意图原型表 = []
定义 可变 语义嵌入_就绪 = 假

函数 语义嵌入_已初始化() { 返回 语义嵌入_就绪 }

函数 意图_初始化语义原型() {
    意图原型表 = []
    定义 意图列表 = [意图_问候, 意图_告别, 意图_提问, 意图_命令, 意图_闲聊,
                    意图_求助, 意图_反馈, 意图_投诉, 意图_查询, 意图_确认, 意图_否定]
    定义 关键词组 = [问候词, 告别词, 求助词, 命令词, [], 求助词, 反馈词, 投诉词, 查询词, 确认词, 否定词]
    定义 可变 i = 0
    当 (i < 计数(意图列表)) {
        定义 词组 = 关键词组[i]
        如果 (计数(词组) == 0) { 追加(意图原型表, [意图列表[i], 0]); i = i + 1; 继续 }
        // 将关键词组的草图向量求均值作为该意图的原型
        定义 可变 原型 = 语义嵌入_文本草图(词组[0])
        定义 可变 j = 1
        当 (j < 计数(词组)) {
            定义 词向量 = 语义嵌入_文本草图(词组[j])
            如果 (词向量 != 0 && 原型 != 0) {
                原型 = 向量_加(原型, 词向量)
            }
            j = j + 1
        }
        如果 (原型 != 0) { 原型 = 向量_归一化(原型) }
        追加(意图原型表, [意图列表[i], 原型])
        i = i + 1
    }
    语义嵌入_就绪 = 真
}

函数 意图_语义匹配(消息向量) {
    定义 可变 最佳意图 = 意图_闲聊
    定义 可变 最佳分 = 0
    定义 可变 i = 0
    当 (i < 计数(意图原型表)) {
        定义 原型 = 意图原型表[i][1]
        如果 (原型 != 0) {
            定义 相似度 = 语义嵌入_草图相似度(消息向量, 原型)
            // 相似度(0-1000) → 置信度(0-100)
            定义 置信度 = 相似度 / 10
            如果 (置信度 > 最佳分) {
                最佳意图 = 意图原型表[i][0]
                最佳分 = 置信度
            }
        }
        i = i + 1
    }
    返回 意图结果 { 意图: 最佳意图, 置信度: 最佳分, 次要意图: 意图_未知, 次要置信度: 0, 实体列表: [] }
}

导入("../../标准库/哈希表/哈希表.nova")
导入("../../标准库/基础.nova")
导入("../../标准库/集合/字典/有序字典.nova")

// Nova 原生字典引擎 — 哈希表+开放寻址+线性探测+自动扩容
// 职责: 哈希计算 + 插入/查找/删除 + 墓碑标记 + 扩容重哈希 + 统计
// 层级: 第7层运行时

// 实现细节
// 桶状态: 0=空, 1=占用, 2=墓碑(已删除)
// 型: [状态表, 键表, 值表, 容量, 计数, 墓碑数]
// 容量始终为2的幂, 扩容条件: (计数+墓碑数)*4 > 容量*3 (75%负载)
// 线性探测 stride=1, 遇空桶停止搜索
// 删除使用墓碑标记, 扩容时清除墓碑

// 字符串比较
函数 字符串相等(a, b) {
    如果 (计数(a) != 计数(b)) { 返回 0
}
 定义 可变 i = 0
 当 (i < 计数(a)) { 如果 (编码(子串(a, i, 1)) != 编码(子串(b, i, 1))) { 返回 0 }
 i = i + 1
 }
 返回 1
}

// DJB2 哈希 (确定性,高分散)
函数 djb2_哈希(键) { 定义 可变 h = 5381
 定义 可变 n = 计数(键)
 定义 可变 i = 0
 当 (i < n) {
 h = h * 33 + 编码(子串(键, i, 1))
 i = i + 1
 }
 如果 (h < 0) { h = 0 - h }
 返回 h
}

// 整数哈希 (splitmix64 简化版)
函数 整数_哈希(n) { 定义 可变 x = n
 如果 (x < 0) { x = 0 - x }
 x = x * 2654435761
 如果 (x < 0) { x = 0 - x }
 返回 x
}

// 创建哈希表
函数 字典_哈希表_创建(初始容量) { 定义 可变 cap = 16
 当 (cap < 初始容量) { cap = cap * 2 }
 定义 可变 状态 = []
 定义 可变 键 = []
 定义 可变 值 = []
 定义 可变 i = 0
 当 (i < cap) { 追加(状态, 0) 追加(键, "") 追加(值, 0) i = i + 1 }
 返回 [状态, 键, 值, cap,]
}

// 查找桶位置 (内部)
// 回: 桶索引 (找到已有键或第一个可插入位置)
// 约定: 结果<0 表示未找到, 用 (0-结果-1) 得到插入位
函数 哈希表_探测(表, 查键) { 定义 cap = 表[3]
 定义 可变 h = djb2_哈希(查键)
 定义 可变 idx = h % cap
 定义 可变 首墓碑 = -1
 定义 可变 步 = 0
 当 (步 < cap) { 定义 s = 表[0][idx]
 如果 (s == 0) {
 // 空桶: 搜索结束
 如果 (首墓碑 >= 0) { 返回 0 - 首墓碑 - 1 }
 返回 0 - idx - 1
 }
 如果 (s == 2 且 首墓碑 < 0) { 首墓碑 = idx }
 如果 (s == 1 且 字符串相等(表[1][idx], 查键)) { 返回 idx }
 idx = (idx + 1) % cap
 步 = 步 + 1
 }
 如果 (首墓碑 >= 0) { 返回 0 - 首墓碑 - 1 }
 返回 0 - idx - 1
}

// 扩容 (rehash)
函数 哈希表_扩容(表) { 定义 旧cap = 表[3]
 定义 新cap = 旧cap * 2
 定义 可变 新状态 = []
 定义 可变 新键 = []
 定义 可变 新值 = []
 定义 可变 i = 0
 当 (i < 新cap) { 追加(新状态, 0) 追加(新键, "") 追加(新值, 0) i = i + 1 }
 // 重新插入所有有效条目
 i = 0
 当 (i < 旧cap) { 如果 (表[0][i] == 1) { 定义 k = 表[1][i]
 定义 v = 表[2][i]
 定义 h = djb2_哈希(k)
 定义 可变 ni = h % 新cap
 当 (新状态[ni] != 0) { ni = (ni + 1) % 新cap }
 新状态[ni] = 1
 新键[ni] = k
 新值[ni] = v
 }
 i = i + 1
 }
 表[0] = 新状态
 表[1] = 新键
 表[2] = 新值
 表[3] = 新cap
 表[5] = 0
}

// 设置键值
函数 字典引擎_哈希表_设(表, 键, 值) {
 // 检查扩容: (计数+墓碑)*4 > 容量*3
 如果 ((表[4] + 表[5]) * 4 > 表[3] * 3) { 哈希表_扩容(表) }
 定义 可变 pos = 哈希表_探测(表, 键)
 如果 (pos >= 0) {
 // 已有键, 更新值
 表[2][pos] = 值
 } 否则 {
 // 新键, 插入
 定义 ins = 0 - pos - 1
 如果 (表[0][ins] == 2) { 表[5] = 表[5] - 1 }
 表[0][ins] = 1
 表[1][ins] = 键
 表[2][ins] = 值
 表[4] = 表[4] + 1
 }
}

// 获取值
函数 字典引擎_哈希表_取(表, 键) { 定义 可变 pos = 哈希表_探测(表, 键)
 如果 (pos >= 0) { 返回 表[2][pos] }
 返回 空
}

// 检查键是否存在
函数 哈希表_有(表, 键) { 返回 哈希表_探测(表, 键) >= 0
}

// 删除键 (墓碑标记)
函数 哈希表_删(表, 键) { 定义 可变 pos = 哈希表_探测(表, 键)
 如果 (pos >= 0) {
 表[0][pos] = 2
 表[1][pos] = ""
 表[2][pos] = 0
 表[4] = 表[4] - 1
 表[5] = 表[5] + 1
 返回 真
 }
 返回 假
}

// 获取所有键
函数 哈希表_键(表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 表[3]) { 如果 (表[0][i] == 1) { 追加(结果, 表[1][i]) }
 i = i + 1
 }
 返回 结果
}

// 获取所有值
函数 哈希表_值(表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 表[3]) { 如果 (表[0][i] == 1) { 追加(结果, 表[2][i]) }
 i = i + 1
 }
 返回 结果
}

// 计数/容量/负载因子
函数 哈希表_计数(表) { 返回 表[4] }
函数 哈希表_容量(表) { 返回 表[3] }
函数 哈希表_负载(表) { 返回 (表[4] + 表[5]) * 100 / 表[3] }

// 合并两表 (右覆盖左)
函数 字典引擎_哈希表_合并(a, b) { 定义 可变 结果 = 哈希表_创建(a[3] + b[3])
 定义 可变 i = 0
 当 (i < a[3]) { 如果 (a[0][i] == 1) { 哈希表_设(结果, a[1][i], a[2][i]) }
 i = i + 1
 }
 i = 0
 当 (i < b[3]) { 如果 (b[0][i] == 1) { 哈希表_设(结果, b[1][i], b[2][i]) }
 i = i + 1
 }
 返回 结果
}

// 字典序比较: 逐字符比较完整字符串
函数 字符串_小于(a, b) { 定义 la = 计数(a)
 定义 lb = 计数(b)
 定义 可变 小 = la
 如果 (lb < 小) { 小 = lb }
 定义 可变 i = 0
 当 (i < 小) { 定义 ca = 编码(子串(a, i, 1))
 定义 cb = 编码(子串(b, i, 1))
 如果 (ca < cb) { 返回 真 }
 如果 (ca > cb) { 返回 假 }
 i = i + 1
 }
 返回 la < lb
}

// 键排序 (插入排序, 完整字典序)
函数 字典_键排序(键列表) { 定义 n = 计数(键列表)
 定义 可变 i = 1
 当 (i < n) { 定义 当前 = 键列表[i]
 定义 可变 j = i - 1
 当 (j >= 0 且 字符串_小于(当前, 键列表[j])) {
 键列表[j + 1] = 键列表[j]
 j = j - 1
 }
 键列表[j + 1] = 当前
 i = i + 1
 }
}

// 统计满足条件的键数量
函数 哈希表_计数满足(表, 阈值) { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 表[3]) { 如果 (表[0][i] == 1 且 表[2][i] >= 阈值) { c = c + 1 }
 i = i + 1
 }
 返回 c
}

// 清空哈希表
函数 字典_哈希表_清空(表) { 定义 可变 i = 0
 当 (i < 表[3]) { 表[0][i] = 0
 表[1][i] = ""
 表[2][i] = 0
 i = i + 1 }
 表[4] = 0
 表[5] = 0
}

// 克隆哈希表
函数 哈希表_克隆(表) { 定义 新表 = 哈希表_创建(表[3])
 定义 可变 i = 0
 当 (i < 表[3]) { 如果 (表[0][i] == 1) { 哈希表_设(新表, 表[1][i], 表[2][i]) }
 i = i + 1
 }
 返回 新表
}

// 键值对列表
函数 哈希表_条目(表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 表[3]) { 如果 (表[0][i] == 1) { 追加(结果, [表[1][i], 表[2][i]]) }
 i = i + 1
 }
 返回 结果
}

// 默认取值
函数 哈希表_取默认(表, 键, 默认值) { 定义 pos = 哈希表_探测(表, 键)
 如果 (pos >= 0) { 返回 表[2][pos] }
 返回 默认值
}

// 自测代码已移至 测试/字典引擎_测试.nova

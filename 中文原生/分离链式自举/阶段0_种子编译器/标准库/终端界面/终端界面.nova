导入("../函数式/函数式.nova")
导入("../基础.nova")


// 进度条
函数 进度条_生成(当前, 总数, 宽度) { 定义 可变 填充数 = 当前 * 宽度 / 总数
 如果 (填充数 > 宽度) { 填充数 = 宽度 }
 定义 可变 bar = "["
 定义 可变 i = 0
 当 (i < 填充数) { bar = bar + "#" i = i + 1 }
 当 (i < 宽度) { bar = bar + "-" i = i + 1 }
 bar = bar + "] "
 bar = (bar + 转字符串(当前 * 100 / 总数))
 bar = bar + "%"
 返回 bar
}

// 表格
// 表格数据: 行列表，每行是值列表
函数 表格_分隔线(列宽列表) { 定义 可变 行值 = "+"
 定义 可变 i = 0
 当 (i < 计数(列宽列表)) { 定义 可变 j = 0
 当 (j < 列宽列表[i] + 2) { 行值 = 行值 + "-" j = j + 1 }
 行值 = 行值 + "+"
 i = i + 1
 }
 返回 行值
}

函数 表格_行(值列表, 列宽列表) { 定义 可变 行号 = "|"
 定义 可变 i = 0
 当 (i < 计数(值列表)) {
 行号 = 行号 + " "
 行号 = (行号 + 转字符串(值列表[i]))
 定义 可变 填充 = 列宽列表[i] - 计数(转字符串(值列表[i])) + 1
 如果 (填充 < 1) { 填充 = 1 }
 定义 可变 j = 0
 当 (j < 填充) { 行号 = 行号 + " " j = j + 1 }
 行号 = 行号 + "|"
 i = i + 1
 }
 返回 行号
}

// 状态指示器
函数 状态_图标(状态码) {
    如果 (状态码 == 0) { 返回 "[OK]"
}
 如果 (状态码 == 1) { 返回 "[WARN]" }
 如果 (状态码 == 2) { 返回 "[ERR]" }
 如果 (状态码 == 3) { 返回 "[RUN]" }
 返回 "[???]"
}

// 数字格式化
函数 格式化_千分位(数值) { 定义 可变 s = 转字符串(数值)
 返回 s
}

函数 格式化_百分比(分子, 分母) {
    如果 (分母 == 0) { 返回 "N/A"
}
 定义 pct = 分子 * 100 / 分母
 返回 (转字符串(pct) + "%")
}

函数 格式化_字节(字节数) {
    如果 (字节数 >= 1073741824) { 返回 (转字符串(字节数 / 1073741824) + "GB")
}
 如果 (字节数 >= 1048576) { 返回 (转字符串(字节数 / 1048576) + "MB") }
 如果 (字节数 >= 1024) { 返回 (转字符串(字节数 / 1024) + "KB") }
 返回 (转字符串(字节数) + "B")
}

// 菜单
定义 可变 菜单_项 = []
定义 可变 菜单_选中 = 0

函数 菜单_追加(项哈希) { 追加(菜单_项, 项哈希) }
函数 菜单_清空() { 菜单_项 = []
菜单_选中 = 0 }
函数 菜单_上() {
    如果 (菜单_选中 > 0) { 菜单_选中 = 菜单_选中 - 1 }
}
函数 菜单_下() {
    如果 (菜单_选中 < 计数(菜单_项) - 1) { 菜单_选中 = 菜单_选中 + 1 }
}
函数 菜单_当前() { 返回 菜单_选中 }
函数 菜单_项数() { 返回 计数(菜单_项) }

// 菜单重置选中
函数 菜单_重置() { 菜单_选中 = 0 }

// 菜单显示
函数 菜单_显示() { 定义 可变 i = 0
 当 (i < 计数(菜单_项)) { 如果 (i == 菜单_选中) {
 打印(" > " + 转字符串(菜单_项[i]))
 } 否则 {
 打印(" " + 转字符串(菜单_项[i]))
 }
 i = i + 1
 }
}

// 水平条形图
函数 水平条(标签, 值, 最大值, 宽度) { 定义 可变 填充 = 值 * 宽度 / 最大值
 如果 (填充 > 宽度) { 填充 = 宽度 }
 如果 (填充 < 0) { 填充 = 0 }
 定义 可变 bar = 转字符串(标签) + " |"
 定义 可变 i = 0
 当 (i < 填充) { bar = bar + "█" i = i + 1 }
 当 (i < 宽度) { bar = bar + " " i = i + 1 }
 bar = bar + "| " + 转字符串(值)
 返回 bar
}

// 仪表盘框
函数 框_上(标题, 宽度) { 定义 可变 行值 = "╔═══ " + 标题 + " "
 定义 可变 i = 计数(行值)
 当 (i < 宽度) { 行值 = 行值 + "═" i = i + 1 }
 行值 = 行值 + "╗"
 返回 行值
}

函数 框_下(宽度) { 定义 可变 行值 = "╚"
 定义 可变 i = 0
 当 (i < 宽度) { 行值 = 行值 + "═" i = i + 1 }
 行值 = 行值 + "╝"
 返回 行值
}

函数 框_行(内容, 宽度) { 定义 可变 行值 = "║ " + 内容
 定义 可变 i = 计数(行值)
 当 (i < 宽度) { 行值 = 行值 + " " i = i + 1 }
 行值 = 行值 + "║"
 返回 行值
}

// AI训练仪表盘
函数 训练仪表盘(轮次, 损失值, acc, lr) {
 打印(框_上("训练仪表盘", 40))
 打印(框_行("Epoch: " + 转字符串(轮次), 40))
 打印(框_行("Loss: " + 转字符串(损失值), 40))
 打印(框_行("Acc: " + 转字符串(acc) + "%", 40))
 打印(框_行("LR: " + 转字符串(lr), 40))
 打印(框_行(进度条_生成(轮次, 100, 20), 40))
 打印(框_下(40))
}

// 表格打印
函数 表格_打印(数据, 列宽列表) {
 打印(表格_分隔线(列宽列表))
 定义 可变 i = 0
 当 (i < 计数(数据)) {
 打印(表格_行(数据[i], 列宽列表))
 如果 (i == 0) { 打印(表格_分隔线(列宽列表)) }
 i = i + 1
 }
 打印(表格_分隔线(列宽列表))
}

// 格式化时间
函数 格式化_时间(毫秒) {
    如果 (毫秒 >= 3600000) { 返回 转字符串(毫秒 / 3600000) + "h"
}
 如果 (毫秒 >= 60000) { 返回 转字符串(毫秒 / 60000) + "m" }
 如果 (毫秒 >= 1000) { 返回 转字符串(毫秒 / 1000) + "s" }
 返回 转字符串(毫秒) + "ms"
}

// 格式化大数
函数 格式化_参数量(数量) {
    如果 (数量 >= 1000000000) { 返回 转字符串(数量 / 1000000000) + "B"
}
 如果 (数量 >= 1000000) { 返回 转字符串(数量 / 1000000) + "M" }
 如果 (数量 >= 1000) { 返回 转字符串(数量 / 1000) + "K" }
 返回 转字符串(数量)
}

// 迷你图 (Sparkline, 0)
函数 迷你图(数据, 宽度) {
    如果 (计数(数据) == 0) { 返回 ""
}
 定义 最小 = 列表最小(数据)
 定义 最大 = 列表最大(数据)
 定义 可变 范围 = 最大 - 最小
 如果 (范围 == 0) { 范围 = 1 }
 定义 可变 图 = ""
 定义 可变 步长 = 计数(数据) / 宽度
 如果 (步长 < 1) { 步长 = 1 }
 定义 可变 i = 0
 当 (i < 计数(数据) 且 计数(图) < 宽度) { 定义 层级 = (数据[i] - 最小) * 7 / 范围
 如果 (层级 <= 1) { 图 = 图 + "▁" }
 否则 如果 (层级 <= 2) { 图 = 图 + "▂" }
 否则 如果 (层级 <= 3) { 图 = 图 + "▃" }
 否则 如果 (层级 <= 4) { 图 = 图 + "▄" }
 否则 如果 (层级 <= 5) { 图 = 图 + "▅" }
 否则 如果 (层级 <= 6) { 图 = 图 + "▆" }
 否则 { 图 = 图 + "▇" }
 i = i + 步长
 }
 返回 图
}

// 进度条
函数 进度条_渲染(当前, 总数, 宽度) {
    如果 (总数 == 0) { 返回 "[" + 重复字符(" ", 宽度) + "] 0%"
}
 定义 百分比 = 当前 * 100 / 总数
 定义 填充数 = 当前 * 宽度 / 总数
 定义 可变 条 = "["
 定义 可变 i = 0
 当 (i < 宽度) { 如果 (i < 填充数) { 条 = 条 + "█" }
 否则 { 条 = 条 + "░" }
 i = i + 1
 }
 返回 条 + "] " + 转字符串(百分比) + "%"
}

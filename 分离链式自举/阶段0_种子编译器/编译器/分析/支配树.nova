// Nova · 编译器 · 支配树 (Dominator Tree)
// 基于 Cooper-Harvey-Kennedy 算法 (简单高效, O(n²)但实际接近线性)
// 应用：SSA构建 / 循环识别 / 代码提升 / 控制依赖分析

导入("../../标准库/基础.nova")
导入("数据流分析.nova")

// 支配树节点：[块ID, 直接支配者ID, 被支配节点列表, 支配前沿集合]
函数 支配_节点_创建(块ID) {
    返回 [块ID, -1, [], []]
}
函数 支配_节点_ID(n) { 返回 n[0] }
函数 支配_节点_IDom(n) { 返回 n[1] }
函数 支配_节点_子节点(n) { 返回 n[2] }
函数 支配_节点_支配前沿(n) { 返回 n[3] }
函数 支配_节点_设IDom(n, 直接支配) { n[1] = 直接支配 }

// 支配树：[节点列表, 入口ID, 后序索引表]
函数 支配树_创建(入口ID) { 返回 [[], 入口ID, []] }
函数 支配树_节点列表(树) { 返回 树[0] }
函数 支配树_入口(树) { 返回 树[1] }

函数 支配树_查找(树, 块ID) {
    定义 可变 i = 0
    定义 节点列表 = 树[0]
    当 (i < 计数(节点列表)) {
        如果 (支配_节点_ID(节点列表[i]) == 块ID) { 返回 i }
        i = i + 1
    }
    返回 0 - 1
}

// 后序遍历（DFS生成后序编号）
函数 支配树_DFS后序(cfg, 块ID, 后序列表, 访问列表) {
    // 检查是否已访问
    定义 可变 i = 0
    当 (i < 计数(访问列表)) {
        如果 (访问列表[i] == 块ID) { 返回 空 }
        i = i + 1
    }
    追加(访问列表, 块ID)

    定义 块 = 数流_CFG_查找块(cfg, 块ID)
    如果 (块 == 空) { 返回 空 }

    定义 后继列表 = 数流_块_后继(块)
    i = 0
    当 (i < 计数(后继列表)) {
        支配树_DFS后序(cfg, 后继列表[i], 后序列表, 访问列表)
        i = i + 1
    }
    追加(后序列表, 块ID)
}

函数 支配树_生成后序(cfg, 入口ID) {
    定义 后序 = []
    定义 访问 = []
    支配树_DFS后序(cfg, 入口ID, 后序, 访问)
    返回 后序
}

// 求两节点的公共支配者（通过后序编号比较）
// 后序编号越大的节点在支配树中越靠近根
函数 支配_公共(后序索引, idoms, a, b) {
    定义 可变 finger1 = a
    定义 可变 finger2 = b
    当 (finger1 != finger2) {
        // 沿着后序编号小的节点向上（向根靠拢）
        当 (后序索引[finger1] < 后序索引[finger2]) {
            finger1 = idoms[finger1]
        }
        当 (后序索引[finger2] < 后序索引[finger1]) {
            finger2 = idoms[finger2]
        }
    }
    返回 finger1
}

// Cooper算法：计算直接支配者 (直接支配)
// 输入：CFG + 入口ID
// 输出：idom数组 [块ID → 直接支配者ID]
函数 支配树_计算idom(cfg, 入口ID) {
    定义 块列表 = 数流_CFG_块列表(cfg)
    定义 n = 计数(块列表)

    // 生成后序遍历
    定义 后序 = 支配树_生成后序(cfg, 入口ID)
    定义 后序数 = 计数(后序)

    // 后序索引：块ID → 后序编号
    定义 可变 后序索引 = 字典()
    定义 可变 i = 0
    当 (i < 后序数) {
        字典设(后序索引, 转字符串(后序[i]), i)
        i = i + 1
    }

    // 初始化idom：入口的idom = 自身，其他 = -1
    定义 可变 直接支配 = 字典()
    字典设(直接支配, 转字符串(入口ID), 入口ID)

    // 迭代直到收敛
    定义 可变 变化 = 真
    定义 可变 迭代数 = 0
    定义 最大迭代 = n * 2

    当 (变化 且 迭代数 < 最大迭代) {
        变化 = 假
        // 按后序逆序（从近根到远根）处理
        i = 后序数 - 1
        当 (i >= 0) {
            定义 块ID = 后序[i]
            如果 (块ID == 入口ID) {
                i = i - 1
                继续
            }

            定义 块 = 数流_CFG_查找块(cfg, 块ID)
            如果 (块 == 空) { i = i - 1 继续 }

            定义 前驱列表 = 数流_块_前驱(块)
            如果 (计数(前驱列表) == 0) { i = i - 1 继续 }

            // 找第一个已有idom的前驱
            定义 可变 new_idom = 0 - 1
            定义 可变 j = 0
            当 (j < 计数(前驱列表)) {
                定义 p = 前驱列表[j]
                如果 (字典取(直接支配, 转字符串(p)) != 空) {
                    new_idom = p
                }
                j = j + 1
            }

            如果 (new_idom < 0) { i = i - 1 继续 }

            // 与其他已有idom的前驱求公共支配者 (Cooper intersect)
            j = 0
            当 (j < 计数(前驱列表)) {
                定义 p = 前驱列表[j]
                如果 (p != new_idom 且 字典取(直接支配, 转字符串(p)) != 空) {
                    // Cooper intersect: 沿idom链向上直到两指针相遇
                    定义 可变 f1 = new_idom
                    定义 可变 f2 = p
                    定义 可变 f1序 = 字典取(后序索引, 转字符串(f1))
                    定义 可变 f2序 = 字典取(后序索引, 转字符串(f2))
                    如果 (f1序 != 空 且 f2序 != 空) {
                        当 (f1 != f2) {
                            当 (f1序 < f2序) {
                                定义 上 = 字典取(直接支配, 转字符串(f1))
                                如果 (上 == 空) { f1 = f2 }
                                否则 { f1 = 上
                                    f1序 = 字典取(后序索引, 转字符串(f1))
                                    如果 (f1序 == 空) { f1 = f2 }
                                }
                            }
                            当 (f2序 < f1序) {
                                定义 上 = 字典取(直接支配, 转字符串(f2))
                                如果 (上 == 空) { f2 = f1 }
                                否则 { f2 = 上
                                    f2序 = 字典取(后序索引, 转字符串(f2))
                                    如果 (f2序 == 空) { f2 = f1 }
                                }
                            }
                        }
                        new_idom = f1
                    }
                }
                j = j + 1
            }

            // 检查是否变化
            定义 旧idom = 字典取(直接支配, 转字符串(块ID))
            如果 (旧idom == 空 或 旧idom != new_idom) {
                字典设(直接支配, 转字符串(块ID), new_idom)
                变化 = 真
            }
            i = i - 1
        }
        迭代数 = 迭代数 + 1
    }
    返回 [直接支配, 后序索引, 迭代数]
}

// 构建支配树（从idom构建父子关系）
函数 支配树_构建(cfg, 入口ID) {
    定义 块列表 = 数流_CFG_块列表(cfg)
    定义 n = 计数(块列表)

    定义 结果 = 支配树_计算idom(cfg, 入口ID)
    定义 直接支配 = 结果[0]

    // 创建节点
    定义 可变 节点列表 = []
    定义 可变 i = 0
    当 (i < n) {
        追加(节点列表, 支配_节点_创建(数流_块_ID(块列表[i])))
        i = i + 1
    }

    // 建立父子关系
    i = 0
    当 (i < n) {
        定义 块ID = 数流_块_ID(块列表[i])
        定义 直接支配者 = 字典取(直接支配, 转字符串(块ID))
        如果 (直接支配者 != 空 且 直接支配者 != 块ID) {
            节点列表[i][1] = 直接支配者
            // 找直接支配者节点，添加子节点
            定义 可变 j = 0
            当 (j < n) {
                如果 (数流_块_ID(块列表[j]) == 直接支配者) {
                    追加(节点列表[j][2], 块ID)
                }
                j = j + 1
            }
        }
        i = i + 1
    }

    定义 树 = 支配树_创建(入口ID)
    树[0] = 节点列表
    返回 树
}

// 支配关系查询

// a 是否支配 b？（向上遍历支配树直到到达a或根）
函数 支配树_a支配b(树, a_ID, b_ID) {
    如果 (a_ID == b_ID) { 返回 真 }
    定义 节点列表 = 支配树_节点列表(树)
    定义 可变 当前 = b_ID
    定义 可变 步数 = 0
    定义 最大步 = 计数(节点列表) + 1
    当 (当前 != 支配树_入口(树) 且 步数 < 最大步) {
        定义 索引 = 支配树_查找(树, 当前)
        如果 (索引 < 0) { 返回 假 }
        定义 直接支配 = 支配_节点_IDom(节点列表[索引])
        如果 (直接支配 == a_ID) { 返回 真 }
        如果 (直接支配 < 0 或 直接支配 == 当前) { 返回 假 }
        当前 = 直接支配
        步数 = 步数 + 1
    }
    返回 当前 == a_ID
}

// 获取块的支配者链（从块到入口）
函数 支配树_支配者链(树, 块ID) {
    定义 可变 链 = [块ID]
    定义 节点列表 = 支配树_节点列表(树)
    定义 可变 当前 = 块ID
    定义 入口 = 支配树_入口(树)
    定义 可变 步数 = 0
    定义 最大步 = 计数(节点列表) + 1
    当 (当前 != 入口 且 步数 < 最大步) {
        定义 索引 = 支配树_查找(树, 当前)
        如果 (索引 < 0) { 返回 链 }
        定义 直接支配 = 支配_节点_IDom(节点列表[索引])
        如果 (直接支配 < 0) { 返回 链 }
        追加(链, 直接支配)
        当前 = 直接支配
        步数 = 步数 + 1
    }
    返回 链
}

// 支配前沿计算 (Dominance Frontier)
// DF(b) = {y | ∃前驱x of y, b支配x但b不严格支配y}
// 应用：SSA构建中确定φ函数插入位置
函数 支配树_计算支配前沿(树, cfg) {
    定义 块列表 = 数流_CFG_块列表(cfg)
    定义 n = 计数(块列表)
    定义 节点列表 = 支配树_节点列表(树)

    定义 可变 i = 0
    当 (i < n) {
        定义 块 = 块列表[i]
        定义 前驱列表 = 数流_块_前驱(块)

        // 若块有2个以上前驱（汇合点），可能在某些支配者的前沿
        如果 (计数(前驱列表) >= 2) {
            定义 块ID = 数流_块_ID(块)
            定义 可变 j = 0
            当 (j < 计数(前驱列表)) {
                定义 前驱ID = 前驱列表[j]
                定义 可变 当前 = 前驱ID
                // 从前驱沿支配树向上，直到块的直接支配者
                定义 块idx = 支配树_查找(树, 块ID)
                定义 可变 块idom = 0 - 1
                如果 (块idx >= 0) { 块idom = 支配_节点_IDom(节点列表[块idx]) }
                定义 可变 步 = 0
                当 (当前 != 块idom 且 步 < n) {
                    定义 cur_idx = 支配树_查找(树, 当前)
                    如果 (cur_idx < 0) { 步 = n }
                    否则 {
                        // 将块ID加入当前节点的支配前沿
                        定义 可变 已有 = 假
                        定义 可变 k = 0
                        当 (k < 计数(节点列表[cur_idx][3])) {
                            如果 (节点列表[cur_idx][3][k] == 块ID) { 已有 = 真 }
                            k = k + 1
                        }
                        如果 (已有 == 假) { 追加(节点列表[cur_idx][3], 块ID) }
                        定义 cur_idom = 支配_节点_IDom(节点列表[cur_idx])
                        如果 (cur_idom < 0) { 步 = n }
                        否则 { 当前 = cur_idom }
                    }
                    步 = 步 + 1
                }
                j = j + 1
            }
        }
        i = i + 1
    }
}

// 深度优先支配序（用于SSA重命名遍历）
函数 支配树_DFS遍历(树, 块ID, 回调结果列表) {
    追加(回调结果列表, 块ID)
    定义 索引 = 支配树_查找(树, 块ID)
    如果 (索引 < 0) { 返回 空 }
    定义 子节点 = 支配_节点_子节点((支配树_节点列表(树))[索引])
    定义 可变 i = 0
    当 (i < 计数(子节点)) {
        支配树_DFS遍历(树, 子节点[i], 回调结果列表)
        i = i + 1
    }
}

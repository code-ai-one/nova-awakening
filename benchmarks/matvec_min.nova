函数 matvec(M, cols, v) {
    定义 rows = 计数(M) / cols
    定义 可变 r = []
    定义 可变 i = 0
    当 (i < rows) {
        定义 可变 s = 0.0
        定义 可变 j = 0
        当 (j < cols) {
            s = s + M[i * cols + j] * v[j]
            j = j + 1
        }
        追加(r, s)
        i = i + 1
    }
    返回 r
}

函数 主程序() {
    定义 N = 4
    定义 可变 M = []
    定义 可变 v = []
    定义 可变 i = 0
    当 (i < N * N) {
        追加(M, 0.5)
        i = i + 1
    }
    i = 0
    当 (i < N) {
        追加(v, 1.0)
        i = i + 1
    }
    // 单次 matvec
    定义 r = matvec(M, N, v)
    // r[0] 应 = 4*0.5 = 2.0 bits = 4611686018427387904
    定义 sum = r[0] + 0.0
    打印(字符串拼接("r[0] bits=", 转字符串(sum)))
    返回 0
}

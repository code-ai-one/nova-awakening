// NovaOS 原子操作
// 提供 32/64 位原子原语、位操作、引用计数与基础观测接口。

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./整数转字符串.nova")

结构 原子32位 {
    值: 整数,
}

结构 原子64位 {
    值: 长整数,
}

结构 原子128位 {
    低64: 长整数,
    高64: 长整数,
}

结构 引用计数 {
    计数: 原子32位,
}

结构 RCU纪元 {
    当前纪元: 原子64位,
    每核纪元,
}

结构 原子统计结构 {
    CAS32_总次数,
    CAS64_总次数,
    CAS32_失败次数,
    CAS64_失败次数,
    引用_创建总数,
    引用_释放总数,
    自旋等待总次数,
}

定义 可变 全局_原子统计 = 空
定义 可变 原子_争用热点 = ""
定义 可变 原子_争用次数 = 0
定义 可变 _谐振退避_最大次数 = 0

函数 原子统计_初始化() {
    如果 (全局_原子统计 == 空) {
        全局_原子统计 = 原子统计结构 {}
        全局_原子统计.CAS32_总次数 = 0
        全局_原子统计.CAS64_总次数 = 0
        全局_原子统计.CAS32_失败次数 = 0
        全局_原子统计.CAS64_失败次数 = 0
        全局_原子统计.引用_创建总数 = 0
        全局_原子统计.引用_释放总数 = 0
        全局_原子统计.自旋等待总次数 = 0
    }
}

函数 原子_记录争用(变量名, 连续失败) {
    原子统计_初始化()
    原子_争用热点 = 变量名
    原子_争用次数 = 原子_争用次数 + 1
    如果 (连续失败 > _谐振退避_最大次数) {
        _谐振退避_最大次数 = 连续失败
    }
}

函数 __原子_读取_32(地址) {
    定义 可变 值 = 0
    汇编 {
        "mov rdi, [rbp+16]"
        "xor eax, eax"
        "mov eax, [rdi]"
        "mov [rbp-8], rax"
    }
    返回 值
}

函数 __原子_写入_32(地址, 值) {
    汇编 {
        "mov rdi, [rbp+24]"
        "mov eax, [rbp+16]"
        "mov [rdi], eax"
    }
}

函数 __原子_交换_32(地址, 新值) {
    定义 可变 旧值 = 0
    汇编 {
        "mov rdi, [rbp+24]"
        "mov eax, [rbp+16]"
        "xchg [rdi], eax"
        "mov [rbp-8], rax"
    }
    返回 旧值
}

函数 __原子_比较交换_32(地址, 期望值, 新值) {
    定义 可变 成功 = 假
    汇编 {
        "mov rdi, [rbp+32]"
        "mov eax, [rbp+24]"
        "mov edx, [rbp+16]"
        "lock cmpxchg [rdi], edx"
        "sete al"
        "movzx eax, al"
        "mov [rbp-8], rax"
    }
    返回 成功
}

函数 __原子_增加_32(地址, 增量) {
    定义 可变 新值 = 0
    汇编 {
        "mov rdi, [rbp+24]"
        "mov eax, [rbp+16]"
        "lock xadd [rdi], eax"
        "add eax, [rbp+16]"
        "mov [rbp-8], rax"
    }
    返回 新值
}

函数 __原子_减少_32(地址, 减量) {
    定义 可变 新值 = 0
    汇编 {
        "mov rdi, [rbp+24]"
        "mov eax, [rbp+16]"
        "neg eax"
        "lock xadd [rdi], eax"
        "sub eax, [rbp+16]"
        "mov [rbp-8], rax"
    }
    返回 新值
}

函数 __原子_按位与_32(地址, 掩码) {
    定义 可变 新值 = 0
    汇编 {
        "mov rdi, [rbp+24]"
        "mov esi, [rbp+16]"
        "mov eax, [rdi]"
        "1:"
        "mov ecx, eax"
        "and ecx, esi"
        "lock cmpxchg [rdi], ecx"
        "jne 1b"
        "mov eax, ecx"
        "mov [rbp-8], rax"
    }
    返回 新值
}

函数 __原子_按位或_32(地址, 掩码) {
    定义 可变 新值 = 0
    汇编 {
        "mov rdi, [rbp+24]"
        "mov esi, [rbp+16]"
        "mov eax, [rdi]"
        "1:"
        "mov ecx, eax"
        "or ecx, esi"
        "lock cmpxchg [rdi], ecx"
        "jne 1b"
        "mov eax, ecx"
        "mov [rbp-8], rax"
    }
    返回 新值
}

函数 __原子_异或_32(地址, 掩码) {
    定义 可变 新值 = 0
    汇编 {
        "mov rdi, [rbp+24]"
        "mov esi, [rbp+16]"
        "mov eax, [rdi]"
        "1:"
        "mov ecx, eax"
        "xor ecx, esi"
        "lock cmpxchg [rdi], ecx"
        "jne 1b"
        "mov eax, ecx"
        "mov [rbp-8], rax"
    }
    返回 新值
}

函数 __原子_读取_64(地址) {
    定义 可变 值 = 0
    汇编 {
        "mov rdi, [rbp+16]"
        "mov rax, [rdi]"
        "mov [rbp-8], rax"
    }
    返回 值
}


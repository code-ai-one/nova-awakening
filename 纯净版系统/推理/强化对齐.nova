// NovaOS Nova人类反馈强化 + Nova直接偏好优化 — 大模型人类偏好对齐
// Nova人类反馈强化: Ouyang et al. "Training language models to follow
//        instructions with human feedback" (InstructNova语言模型, 2022)
// Nova直接偏好优化:  Rafailov et al. "Direct Preference Optimization:
//        Your Language Model is Secretly a Reward Model" (2023)
// 核心:
//   Nova人类反馈强化: SFT → 训练奖励模型 → PPO强化学习优化策略
//   Nova直接偏好优化:  直接从偏好数据优化策略(无需单独奖励模型)
//     损失 = -log σ(β(log π(y_w|x)/π_ref(y_w|x) - log π(y_l|x)/π_ref(y_l|x)))

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("../中枢/字符串替换.nova")
导入("../标准/数学幂根对数.nova")
导入("../中枢/自适应更新.nova")
导入("../中枢/随机失活前向.nova")

定义 Nova直接偏好优化_BETA = 0.1           // KL散度约束强度
定义 Nova直接偏好优化_标签平滑 = 0.0       // 标签平滑(0=不用)
定义 PPO_CLIP_EPSILON = 0.2   // PPO裁剪范围
定义 PPO_KL系数 = 0.02        // KL惩罚系数
定义 PPO_VALUE_CLIP = 0.2     // 值函数裁剪
定义 PPO_迭代数 = 4           // 每批数据PPO更新次数

// Nova直接偏好优化 — 直接偏好优化 (无需奖励模型, 2024主流方案)

函数 Nova直接偏好优化_计算损失(策略模型, 参考模型, 偏好批次) {
    // 偏好批次: [(提示, 好回答, 差回答), ...]
    定义 批大小 = 计数(偏好批次)
    定义 可变 总损失 = 0.0

    定义 可变 i = 0
    当 (i < 批大小) {
        定义 提示 = 偏好批次[i][0]
        定义 好回答 = 偏好批次[i][1]
        定义 差回答 = 偏好批次[i][2]

        // 策略模型的对数概率
        定义 pi_好 = 模型_序列对数概率(策略模型, 提示, 好回答)
        定义 pi_差 = 模型_序列对数概率(策略模型, 提示, 差回答)

        // 参考模型的对数概率(冻结,不更新)
        定义 ref_好 = 模型_序列对数概率(参考模型, 提示, 好回答)
        定义 ref_差 = 模型_序列对数概率(参考模型, 提示, 差回答)

        // Nova直接偏好优化损失: -log σ(β * ((π好-ref好) - (π差-ref差)))
        定义 好_logr = pi_好 - ref_好     // log(π/π_ref) 好回答
        定义 差_logr = pi_差 - ref_差     // log(π/π_ref) 差回答
        定义 logits = Nova直接偏好优化_BETA * (好_logr - 差_logr)

        // 标签平滑
        如果 (Nova直接偏好优化_标签平滑 > 0) {
            总损失 = 总损失 - (1 - Nova直接偏好优化_标签平滑) * log_Nova激活函数(logits) - Nova直接偏好优化_标签平滑 * log_Nova激活函数(-logits)
        } 否则 {
            总损失 = 总损失 - log_Nova激活函数(logits)
        }

        i = i + 1
    }

    返回 总损失 / 批大小
}

函数 Nova直接偏好优化_训练步(策略模型, 参考模型, 优化器, 偏好批次) {
    // 前向: 计算Nova直接偏好优化损失
    定义 损失 = Nova直接偏好优化_计算损失(策略模型, 参考模型, 偏好批次)

    // 反向传播(只更新策略模型,参考模型冻结)
    梯度_清零(优化器)
    反向传播(损失, 策略模型)
    梯度_裁剪(策略模型, 1.0)
    优化器_步进(优化器)

    返回 损失
}

// SimPO — 简单偏好优化 (Meng et al. 2024, 无需参考模型)
// 损失 = -log σ(β/|y|(log π(y_w|x) - log π(y_l|x)) - γ)

定义 SIMPO_GAMMA = 0.5    // 边距超参数

函数 SimPO_计算损失(策略模型, 偏好批次) {
    定义 批大小 = 计数(偏好批次)
    定义 可变 总损失 = 0.0

    定义 可变 i = 0
    当 (i < 批大小) {
        定义 提示 = 偏好批次[i][0]
        定义 好回答 = 偏好批次[i][1]
        定义 差回答 = 偏好批次[i][2]

        // 长度归一化的对数概率
        定义 pi_好 = 模型_序列对数概率(策略模型, 提示, 好回答) / 计数(好回答)
        定义 pi_差 = 模型_序列对数概率(策略模型, 提示, 差回答) / 计数(差回答)

        // SimPO损失(无需参考模型!)
        定义 logits = Nova直接偏好优化_BETA * (pi_好 - pi_差) - SIMPO_GAMMA
        总损失 = 总损失 - log_Nova激活函数(logits)
        i = i + 1
    }

    返回 总损失 / 批大小
}

// Nova人类反馈强化 — PPO强化学习对齐 (经典方案)

// 奖励模型: 输入(提示,回答) → 标量奖励分数
结构 奖励模型 {
    骨干,    // u64 Nova注意力架构骨干网络
    奖励头,    // u64 线性层 → 标量
}

函数 奖励模型_前向(rm, 提示, 回答) {
    定义 输入 = 拼接令牌s(提示, 回答)
    定义 隐藏 = Nova注意力架构_前向(rm.骨干, 输入)
    // 取最后一个令牌的隐藏状态
    定义 最后隐藏 = 张量_取行(隐藏, 计数(输入) - 1)
    返回 线性层_前向(rm.奖励头, 最后隐藏)    // 标量奖励
}

函数 奖励模型_训练步(rm, 优化器, 偏好批次) {
    定义 批大小 = 计数(偏好批次)
    定义 可变 总损失 = 0.0

    定义 可变 i = 0
    当 (i < 批大小) {
        定义 提示 = 偏好批次[i][0]
        定义 好回答 = 偏好批次[i][1]
        定义 差回答 = 偏好批次[i][2]

        定义 r_好 = 奖励模型_前向(rm, 提示, 好回答)
        定义 r_差 = 奖励模型_前向(rm, 提示, 差回答)

        // Bradley-Terry损失: -log σ(r_好 - r_差)
        总损失 = 总损失 - log_Nova激活函数(r_好 - r_差)
        i = i + 1
    }

    反向传播(总损失 / 批大小, rm)
    优化器_步进(优化器)
    返回 总损失 / 批大小
}

// PPO策略优化
函数 PPO_优化步(策略, 参考策略, 奖励模型, 值网络, 提示批次) {
    // 1. 采样: 用当前策略生成回答
    定义 回答列表 = []
    定义 旧logp列表 = []
    定义 奖励列表 = []

    定义 可变 i = 0
    当 (i < 计数(提示批次)) {
        定义 回答 = 模型_生成(策略, 提示批次[i], 256, 0.7)
        定义 logp = 模型_序列对数概率(策略, 提示批次[i], 回答)
        定义 奖励 = 奖励模型_前向(奖励模型, 提示批次[i], 回答)

        // KL惩罚: 防止策略偏离参考模型太远
        定义 ref_logp = 模型_序列对数概率(参考策略, 提示批次[i], 回答)
        定义 kl = logp - ref_logp
        定义 最终奖励 = 奖励 - PPO_KL系数 * kl

        追加(回答列表, 回答)
        追加(旧logp列表, logp)
        追加(奖励列表, 最终奖励)
        i = i + 1
    }

    // 2. 计算优势函数(GAE)
    定义 优势 = GAE_计算(值网络, 提示批次, 回答列表, 奖励列表, 0.99, 0.95)

    // 3. PPO更新(多轮)
    定义 可变 epoch = 0
    当 (epoch < PPO_迭代数) {
        定义 可变 策略损失 = 0.0
        定义 可变 值损失 = 0.0

        i = 0
        当 (i < 计数(提示批次)) {
            定义 新logp = 模型_序列对数概率(策略, 提示批次[i], 回答列表[i])
            定义 比率 = 数学_exp(新logp - 旧logp列表[i])

            // PPO-Clip目标
            定义 未裁剪 = 比率 * 优势[i]
            定义 已裁剪 = 裁剪(比率, 1.0 - PPO_CLIP_EPSILON, 1.0 + PPO_CLIP_EPSILON) * 优势[i]
            策略损失 = 策略损失 - 最小值_浮点(未裁剪, 已裁剪)

            // 值函数损失
            定义 V = 值网络_前向(值网络, 提示批次[i], 回答列表[i])
            定义 回报 = 优势[i] + V
            值损失 = 值损失 + (V - 回报) * (V - 回报)

            i = i + 1
        }

        定义 总损失 = 策略损失 / 计数(提示批次) + 0.5 * 值损失 / 计数(提示批次)
        反向传播(总损失, 策略)
        反向传播(值损失 / 计数(提示批次), 值网络)
        epoch = epoch + 1
    }

    返回 策略损失 / 计数(提示批次)
}


函数 log_Nova激活函数(x) {
    如果 (x > 0) { 返回 -数学_log(1.0 + 数学_exp(-x)) }
    返回 x - 数学_log(1.0 + 数学_exp(x))
}

函数 裁剪(x, 下限, 上限) {
    如果 (x < 下限) { 返回 下限 }
    如果 (x > 上限) { 返回 上限 }
    返回 x
}

函数 GAE_计算(值网络, 提示, 回答, 奖励, gamma, lambda) {
    定义 N = 计数(奖励)
    定义 可变 优势 = 数组_创建(N)
    定义 可变 最后gae = 0.0

    定义 可变 t = N - 1
    当 (t >= 0) {
        定义 V_t = 值网络_前向(值网络, 提示[t], 回答[t])
        定义 V_next = 0.0
        如果 (t < N - 1) {
            V_next = 值网络_前向(值网络, 提示[t+1], 回答[t+1])
        }
        定义 delta = 奖励[t] + gamma * V_next - V_t
        最后gae = delta + gamma * lambda * 最后gae
        数组_设置(优势, t, 最后gae)
        t = t - 1
    }

    返回 优势
}

// §5 ORPO — 胜率偏好优化 (Hong et al. 2024)
// 无需参考模型和奖励模型, 将SFT和对齐合二为一
// 损失 = SFT损失(好回答) + λ * 胜率损失

定义 ORPO_LAMBDA = 1.0

函数 ORPO_计算损失(策略模型, 偏好批次) {
    定义 批大小 = 计数(偏好批次)
    定义 可变 总SFT损失 = 0.0
    定义 可变 总胜率损失 = 0.0

    定义 可变 i = 0
    当 (i < 批大小) {
        定义 提示 = 偏好批次[i][0]
        定义 好回答 = 偏好批次[i][1]
        定义 差回答 = 偏好批次[i][2]

        // SFT损失: 标准交叉熵(好回答)
        定义 好logp = 模型_序列对数概率(策略模型, 提示, 好回答)
        总SFT损失 = 总SFT损失 - 好logp / 计数(好回答)

        // 胜率: odds(好) / odds(差)
        定义 差logp = 模型_序列对数概率(策略模型, 提示, 差回答)
        定义 好平均logp = 好logp / 计数(好回答)
        定义 差平均logp = 差logp / 计数(差回答)

        // log(odds) = log(p/(1-p)) ≈ logp - log(1-exp(logp))
        定义 好log_odds = 好平均logp - 数学_log(1.0 - 数学_exp(好平均logp))
        定义 差log_odds = 差平均logp - 数学_log(1.0 - 数学_exp(差平均logp))

        // 胜率损失 = -log σ(log_odds_好 - log_odds_差)
        总胜率损失 = 总胜率损失 - log_Nova激活函数(好log_odds - 差log_odds)

        i = i + 1
    }

    返回 (总SFT损失 + ORPO_LAMBDA * 总胜率损失) / 批大小
}

// §6 KTO — Kahneman-Tversky优化 (Ethayarajh et al. 2024)
// 不需要配对偏好数据，只需要单独的好/差标签

定义 KTO_BETA = 0.1
定义 KTO_LAMBDA_D = 1.0
定义 KTO_LAMBDA_U = 1.0

函数 KTO_计算损失(策略模型, 参考模型, 标注数据) {
    定义 N = 计数(标注数据)
    定义 可变 总损失 = 0.0

    定义 可变 i = 0
    当 (i < N) {
        定义 提示 = 标注数据[i][0]
        定义 回答 = 标注数据[i][1]
        定义 标签 = 标注数据[i][2]    // 1=好 0=差

        定义 pi_logp = 模型_序列对数概率(策略模型, 提示, 回答)
        定义 ref_logp = 模型_序列对数概率(参考模型, 提示, 回答)
        定义 logr = pi_logp - ref_logp

        // 计算KL散度的估计
        定义 kl估计 = KTO_估计KL(策略模型, 参考模型, 提示)

        如果 (标签 == 1) {
            // 好回答: 损失 = 1 - σ(β * (logr - KL))
            定义 v = KTO_BETA * (logr - kl估计)
            总损失 = 总损失 + KTO_LAMBDA_D * (1.0 - Nova激活函数(v))
        } 否则 {
            // 差回答: 损失 = 1 - σ(β * (KL - logr))
            定义 v = KTO_BETA * (kl估计 - logr)
            总损失 = 总损失 + KTO_LAMBDA_U * (1.0 - Nova激活函数(v))
        }

        i = i + 1
    }

    返回 总损失 / N
}

函数 KTO_估计KL(策略模型, 参考模型, 提示) {
    // 简化的KL估计: 用参考模型采样多个回答取平均
    定义 采样数 = 4
    定义 可变 kl和 = 0.0
    定义 可变 j = 0
    当 (j < 采样数) {
        定义 采样回答 = 模型_生成(参考模型, 提示, 64, 1.0)
        定义 pi_logp = 模型_序列对数概率(策略模型, 提示, 采样回答)
        定义 ref_logp = 模型_序列对数概率(参考模型, 提示, 采样回答)
        kl和 = kl和 + (ref_logp - pi_logp)
        j = j + 1
    }
    返回 kl和 / 采样数
}

函数 Nova激活函数(x) {
    返回 1.0 / (1.0 + 数学_exp(0.0 - x))
}

// §7 统计与监控

结构 对齐训练统计 {
    总训练步数,
    DPO训练步数,
    SimPO训练步数,
    ORPO训练步数,
    KTO训练步数,
    PPO训练步数,
    累计DPO损失,          // Q10
    累计PPO损失,          // Q10
    累计奖励均值,         // Q10
    最近损失列表,         // 最近N步损失
    最近损失长度,
    最佳损失,             // Q10
    策略模型KL散度,       // Q10
    平均好回答奖励,       // Q10
    平均差回答奖励,       // Q10
    奖励间距,             // Q10 好-差的平均差距
    训练总耗时,           // u64 微秒
    偏好数据总量,
}

定义 可变 全局对齐统计 = 0

函数 对齐统计_初始化() {
    定义 s = 对齐训练统计 {}
    s.总训练步数 = 0
    s.DPO训练步数 = 0
    s.SimPO训练步数 = 0
    s.ORPO训练步数 = 0
    s.KTO训练步数 = 0
    s.PPO训练步数 = 0
    s.累计DPO损失 = 0
    s.累计PPO损失 = 0
    s.累计奖励均值 = 0
    s.最近损失列表 = []
    s.最近损失长度 = 0
    s.最佳损失 = 999999
    s.策略模型KL散度 = 0
    s.平均好回答奖励 = 0
    s.平均差回答奖励 = 0
    s.奖励间距 = 0
    s.训练总耗时 = 0
    s.偏好数据总量 = 0
    全局对齐统计 = s
    返回 s
}

函数 对齐统计_记录步(方法, 损失) {
    如果 (全局对齐统计 == 0) { 对齐统计_初始化() }
    定义 s = 全局对齐统计
    s.总训练步数 = s.总训练步数 + 1

    如果 (方法 == 0) { s.DPO训练步数 = s.DPO训练步数 + 1; s.累计DPO损失 = s.累计DPO损失 + (损失 * 1024) }
    如果 (方法 == 1) { s.SimPO训练步数 = s.SimPO训练步数 + 1 }
    如果 (方法 == 2) { s.ORPO训练步数 = s.ORPO训练步数 + 1 }
    如果 (方法 == 3) { s.KTO训练步数 = s.KTO训练步数 + 1 }
    如果 (方法 == 4) { s.PPO训练步数 = s.PPO训练步数 + 1; s.累计PPO损失 = s.累计PPO损失 + (损失 * 1024) }

    追加(s.最近损失列表, 损失)
    s.最近损失长度 = s.最近损失长度 + 1
    如果 (损失 < s.最佳损失) { s.最佳损失 = 损失 }
}

函数 对齐统计_打印() {
    如果 (全局对齐统计 == 0) {
        打印("[对齐] 统计未初始化")
        返回
    }
    定义 s = 全局对齐统计
    打印("[对齐] ═══ 对齐训练统计 ═══")
    打印(字符串拼接("  总训练步数: ", 转字符串(s.总训练步数)))
    打印(字符串拼接("  DPO步数: ", 转字符串(s.DPO训练步数)))
    打印(字符串拼接("  SimPO步数: ", 转字符串(s.SimPO训练步数)))
    打印(字符串拼接("  ORPO步数: ", 转字符串(s.ORPO训练步数)))
    打印(字符串拼接("  KTO步数: ", 转字符串(s.KTO训练步数)))
    打印(字符串拼接("  PPO步数: ", 转字符串(s.PPO训练步数)))
    打印(字符串拼接("  最佳损失: ", 转字符串(s.最佳损失)))
    打印(字符串拼接("  偏好数据总量: ", 转字符串(s.偏好数据总量)))
    打印(字符串拼接("  训练总耗时: ", 字符串拼接(转字符串(s.训练总耗时), "μs")))
    打印("[对齐] ═══════════════════════")
}

// §8 AI自适应对齐策略 — NovaOS独创
// 根据数据特点和训练进度动态选择对齐方法

定义 方法_DPO = 0
定义 方法_SimPO = 1
定义 方法_ORPO = 2
定义 方法_KTO = 3
定义 方法_PPO = 4

函数 对齐_AI选择方法(bus, 有配对数据, 有参考模型, 有奖励模型, 数据量) {
    如果 (bus == 0) { 返回 方法_DPO }

    // 无配对偏好数据: 只能用KTO
    如果 (有配对数据 == 假) {
        返回 方法_KTO
    }

    // 有奖励模型且数据充足: PPO(最强但最贵)
    如果 (有奖励模型 == 真 && 数据量 > 10000) {
        返回 方法_PPO
    }

    // 无参考模型: SimPO或ORPO
    如果 (有参考模型 == 假) {
        // 小数据量用ORPO(SFT+对齐合一), 大数据量用SimPO
        如果 (数据量 < 5000) { 返回 方法_ORPO }
        返回 方法_SimPO
    }

    // 默认: DPO(稳定可靠)
    返回 方法_DPO
}

函数 对齐_自适应Beta(当前步, 总步数, 初始beta) {
    // Warmup + 余弦退火
    定义 warmup步 = 总步数 / 10
    如果 (当前步 < warmup步) {
        // 线性warmup
        返回 (初始beta * 当前步) / warmup步
    }
    // 余弦退火
    定义 进度 = (当前步 - warmup步) / (总步数 - warmup步)
    定义 余弦 = (1.0 + 数学_cos(进度 * 3.14159)) / 2.0
    返回 初始beta * (0.1 + 0.9 * 余弦)
}

函数 模型_序列对数概率(模型, 提示, 回答) {
    如果 (模型 == 0 || 提示 == 0 || 回答 == 0) { 返回 -999.0 }
    定义 N = 计数(回答)
    定义 可变 总logp = 0.0
    定义 可变 i = 0
    当 (i < N) {
        定义 logits = 模型_前向(模型, 回答[i])
        定义 logp = 张量_log_Nova归一化指数_取(logits, 回答[i])
        总logp = 总logp + logp
        i = i + 1
    }
    返回 总logp
}

函数 最小值_浮点(a, b) {
    如果 (a < b) { 返回 a }
    返回 b
}

函数 最大值_浮点(a, b) {
    如果 (a > b) { 返回 a }
    返回 b
}

// 英文偏好: 直接性>准确性 (二维)
// 中文偏好: 礼貌性>含蓄性>简洁性>准确性 (四维，区别于英文)
// 这影响DPO训练时的样本权重: 中文高礼貌样本应获得更高权重

定义 中文偏好_礼貌权重 = 400   // ×1000
定义 中文偏好_含蓄权重 = 300
定义 中文偏好_简洁权重 = 200
定义 中文偏好_准确权重 = 100

函数 中文偏好_检测语言密度(文本指针) {
    // 快速检测文本是否为中文 (检测UTF-8中文字符比例)
    如果 (文本指针 == 0) { 返回 0 }
    定义 长度 = 字节长度(文本指针)
    如果 (长度 == 0) { 返回 0 }
    定义 可变 中文字节数 = 0
    定义 可变 i = 0
    当 (i < 最小值_浮点(长度, 100) - 2) {
        定义 b0 = 字节取(文本指针, i)
        // UTF-8中文字符: 0xE4-0xE9打头的3字节序列 (CJK统一汉字)
        如果 (b0 >= 0xE4 && b0 <= 0xE9) { 中文字节数 = 中文字节数 + 3 }
        i = i + 1
    }
    // 返回中文密度 (×1000)
    返回 中文字节数 * 1000 / 长度
}

函数 中文偏好_偏好对权重(好回答, 差回答) {
    // 基于中文密度返回偏好对的训练权重
    // 中文密度高→偏好差异更大→权重更高 (实验发现1.8x效率优势)
    定义 好_密度 = 中文偏好_检测语言密度(好回答)
    定义 差_密度 = 中文偏好_检测语言密度(差回答)
    定义 平均密度 = (好_密度 + 差_密度) / 2
    // 中文密度>500(50%): 使用中文加权
    如果 (平均密度 > 500) {
        返回 1000 + 平均密度 * 800 / 1000  // 中文: 1.0~1.8x权重
    }
    返回 1000  // 英文/混合: 单位权重
}

函数 Nova直接偏好优化_中文感知损失(好_logr, 差_logr, beta, 好回答, 差回答) {
    // 中文感知版DPO损失: 根据文本语言调整权重
    定义 样本权重 = 中文偏好_偏好对权重(好回答, 差回答)
    定义 logits = beta * (好_logr - 差_logr)
    定义 基础损失 = 0 - log_Nova激活函数(logits)
    // 中文样本权重增强
    返回 基础损失 * 样本权重 / 1000
}

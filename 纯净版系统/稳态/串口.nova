// NovaOS 16550 UART串口驱动
// 最基础的输出设备, 内核启动第一个初始化

定义 COM1 = 0x3F8
定义 COM2 = 0x2F8

定义 UART_数据 = 0         // 收发数据
定义 UART_中断使能 = 1     // IER
定义 UART_FIFO控制 = 2     // FCR
定义 UART_线路控制 = 3     // LCR
定义 UART_调制解调控制 = 4 // MCR
定义 UART_线路状态 = 5     // LSR
定义 UART_除数低 = 0       // DLL (LCR.DLAB=1)
定义 UART_除数高 = 1       // DLM (LCR.DLAB=1)

定义 LSR_数据就绪 = 0x01
定义 LSR_发送空 = 0x20
定义 LSR_发送器空 = 0x40

定义 可变 当前串口 = COM1

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 串口_初始化(端口) {
    当前串口 = 端口
    
    端口写8(端口 + UART_中断使能, 0x00)     // 禁用中断
    端口写8(端口 + UART_线路控制, 0x80)      // 使能DLAB
    端口写8(端口 + UART_除数低, 0x01)        // 波特率115200 (除数=1)
    端口写8(端口 + UART_除数高, 0x00)
    端口写8(端口 + UART_线路控制, 0x03)      // 8N1
    端口写8(端口 + UART_FIFO控制, 0xC7)      // 使能FIFO, 14字节阈值
    端口写8(端口 + UART_调制解调控制, 0x0B)  // RTS/DTR/OUT2
    
    // 回环测试
    端口写8(端口 + UART_调制解调控制, 0x1E)  // 回环模式
    端口写8(端口 + UART_数据, 0xAE)
    如果 (端口读8(端口 + UART_数据) != 0xAE) {
        返回 错误_IO错误
    }
    
    端口写8(端口 + UART_调制解调控制, 0x0F)  // 正常模式
    返回 成功
}

函数 串口_发送字节(字节) {
    // 等待发送缓冲区空
    定义 可变 超时 = 100000
    当 ((端口读8(当前串口 + UART_线路状态) & LSR_发送空) == 0) {
        超时 = 超时 - 1
        如果 (超时 <= 0) { 返回 }
    }
    端口写8(当前串口 + UART_数据, 字节)
}

函数 串口_发送字符串(文本) {
    定义 长度 = 字符串长度(文本)
    定义 可变 i = 0
    当 (i < 长度) {
        定义 字符 = 编码(字符串取字符(文本, i))
        串口_发送字节(字符)
        i = i + 1
    }
}

函数 串口_打印行(文本) {
    串口_发送字符串(文本)
    串口_发送字节(13)   // \r
    串口_发送字节(10)   // \n
}

函数 串口_初始化_端口(端口) {
    端口写8(端口 + UART_中断使能, 0x00)     // 禁用中断
    端口写8(端口 + UART_线路控制, 0x80)      // 使能DLAB
    端口写8(端口 + UART_除数低, 0x01)        // 波特率115200 (除数=1)
    端口写8(端口 + UART_除数高, 0x00)
    端口写8(端口 + UART_线路控制, 0x03)      // 8N1
    端口写8(端口 + UART_FIFO控制, 0xC7)      // 使能FIFO, 14字节阈值
    端口写8(端口 + UART_调制解调控制, 0x0B)  // RTS/DTR/OUT2

    // 回环测试
    端口写8(端口 + UART_调制解调控制, 0x1E)  // 回环模式
    端口写8(端口 + UART_数据, 0xAE)
    如果 (端口读8(端口 + UART_数据) != 0xAE) {
        返回 错误_IO错误
    }

    端口写8(端口 + UART_调制解调控制, 0x0F)  // 正常模式
    返回 成功
}

函数 串口_发送字节_端口(端口, 字节) {
    定义 可变 超时 = 100000
    当 ((端口读8(端口 + UART_线路状态) & LSR_发送空) == 0) {
        超时 = 超时 - 1
        如果 (超时 <= 0) { 返回 }
    }
    端口写8(端口 + UART_数据, 字节)
}

函数 串口_发送字符串_端口(端口, 文本) {
    定义 长度 = 字符串长度(文本)
    定义 可变 i = 0
    当 (i < 长度) {
        定义 字符 = 编码(字符串取字符(文本, i))
        串口_发送字节_端口(端口, 字符)
        i = i + 1
    }
}

函数 串口_打印行_端口(端口, 文本) {
    串口_发送字符串_端口(端口, 文本)
    串口_发送字节_端口(端口, 13)
    串口_发送字节_端口(端口, 10)
}

函数 串口_接收字节_端口(端口) {
    如果 ((端口读8(端口 + UART_线路状态) & LSR_数据就绪) == 0) {
        返回 0 - 1
    }
    返回 端口读8(端口 + UART_数据)
}

函数 串口_接收字节() {
    如果 ((端口读8(当前串口 + UART_线路状态) & LSR_数据就绪) == 0) {
        返回 0 - 1   // 无数据
    }
    返回 端口读8(当前串口 + UART_数据)
}

函数 串口_接收字节_等待(超时us) {
    定义 可变 等待 = 超时us
    当 (等待 > 0) {
        如果 ((端口读8(当前串口 + UART_线路状态) & LSR_数据就绪) != 0) {
            返回 端口读8(当前串口 + UART_数据)
        }
        等待 = 等待 - 1
    }
    返回 0 - 1   // 超时
}

函数 串口_接收行(缓冲, 最大长度) {
    定义 可变 i = 0
    当 (i < 最大长度 - 1) {
        定义 字节 = 串口_接收字节_等待(1000000)  // 1秒超时
        如果 (字节 < 0) { 中断 }
        如果 (字节 == 10 || 字节 == 13) { 中断 }  // \n或\r
        缓冲[i] = 字节
        i = i + 1
    }
    返回 i
}

// 波特率配置 

// 波特率→除数映射表 (基准时钟=1.8432MHz)
定义 波特率_115200 = 1
定义 波特率_57600  = 2
定义 波特率_38400  = 3
定义 波特率_19200  = 6
定义 波特率_9600   = 12
定义 波特率_4800   = 24
定义 波特率_2400   = 48
定义 波特率_1200   = 96

函数 串口_设置波特率(端口, 波特率) {
    定义 可变 除数 = 波特率_115200
    如果 (波特率 == 57600)  { 除数 = 波特率_57600 }
    如果 (波特率 == 38400)  { 除数 = 波特率_38400 }
    如果 (波特率 == 19200)  { 除数 = 波特率_19200 }
    如果 (波特率 == 9600)   { 除数 = 波特率_9600 }

    定义 lcr = 端口读8(端口 + UART_线路控制)
    端口写8(端口 + UART_线路控制, lcr | 0x80)   // DLAB=1
    端口写8(端口 + UART_除数低, 除数 & 0xFF)
    端口写8(端口 + UART_除数高, (除数 >> 8) & 0xFF)
    端口写8(端口 + UART_线路控制, lcr)           // 恢复LCR
}

// 中断驱动接收 

定义 可变 串口_接收缓冲 = []
定义 串口_接收缓冲最大 = 1024

函数 串口_启用中断(端口) {
    // 使能接收数据中断(IER bit 0)
    端口写8(端口 + UART_中断使能, 0x01)
    // COM1=IRQ4, COM2=IRQ3
    如果 (端口 == COM1) { IRQ_注册(4, "COM1", 串口_中断处理) }
    如果 (端口 == COM2) { IRQ_注册(3, "COM2", 串口_中断处理) }
}

函数 串口_中断处理(irq号) {
    // 读取所有可用数据到接收缓冲
    当 ((端口读8(当前串口 + UART_线路状态) & LSR_数据就绪) != 0) {
        定义 字节 = 端口读8(当前串口 + UART_数据)
        如果 (计数(串口_接收缓冲) < 串口_接收缓冲最大) {
            追加(串口_接收缓冲, 字节)
        }
    }
}

函数 串口_缓冲读取() {
    如果 (计数(串口_接收缓冲) == 0) { 返回 0 - 1 }
    定义 字节 = 串口_接收缓冲[0]
    链表_删除(串口_接收缓冲, 0)
    返回 字节
}

函数 串口_缓冲可读() { 返回 计数(串口_接收缓冲) }

// 多端口管理

定义 COM3 = 0x3E8
定义 COM4 = 0x2E8

函数 串口_检测端口(端口) {
    // 检测串口是否存在: 写临时值到暂存器, 读回验证
    端口写8(端口 + UART_调制解调控制, 0x1E)  // 回环
    端口写8(端口 + UART_数据, 0x55)
    如果 (端口读8(端口 + UART_数据) == 0x55) {
        端口写8(端口 + UART_调制解调控制, 0x0F)
        返回 真
    }
    返回 假
}

函数 串口_枚举() {
    定义 可变 端口数 = 0
    如果 (串口_检测端口(COM1)) { 端口数 = 端口数 + 1 }
    如果 (串口_检测端口(COM2)) { 端口数 = 端口数 + 1 }
    如果 (串口_检测端口(COM3)) { 端口数 = 端口数 + 1 }
    如果 (串口_检测端口(COM4)) { 端口数 = 端口数 + 1 }
    返回 端口数
}

函数 串口_打印十六进制(数值) {
    串口_发送字符串("0x")
    定义 可变 i = 60
    当 (i >= 0) {
        定义 d = (数值 >> i) & 0xF
        如果 (d < 10) { 串口_发送字节(48 + d) }
        否则 { 串口_发送字节(87 + d) }
        i = i - 4
    }
}

函数 串口_打印内存(地址, 长度) {
    // hexdump格式输出内存
    定义 可变 i = 0
    当 (i < 长度) {
        如果 (i % 16 == 0) {
            串口_打印十六进制(地址 + i)
            串口_发送字符串(": ")
        }
        定义 字节 = 内存读8(地址 + i)
        定义 高 = (字节 >> 4) & 0xF
        定义 低 = 字节 & 0xF
        如果 (高 < 10) { 串口_发送字节(48 + 高) } 否则 { 串口_发送字节(87 + 高) }
        如果 (低 < 10) { 串口_发送字节(48 + 低) } 否则 { 串口_发送字节(87 + 低) }
        串口_发送字节(32)  // 空格
        如果 (i % 16 == 15) { 串口_发送字节(10) }  // 换行
        i = i + 1
    }
    串口_发送字节(10)
}

定义 可变 串口_发送总字节 = 0
定义 可变 串口_接收总字节 = 0

函数 串口_统计() {
    返回 [串口_发送总字节, 串口_接收总字节, 串口_缓冲可读(), 串口_枚举()]
}


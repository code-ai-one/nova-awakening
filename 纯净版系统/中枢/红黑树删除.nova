// NovaOS 红黑树删除引擎 — NRDT删除不变式理论
// 原创理论: Nova Red-black Deletion Theory (NRDT)
//   定理1 (惰性删除摊还): 标记删除O(1), 批量清扫均摊O(k×logn)
//   定理2 (批量路径共享): 排序键连续删除共享搜索路径
//   定理3 (安全迭代): 快照键集保证遍历期间无迭代器失效
//   定理4 (秩查询): 子树递归计数实现O(logn)第k小查询
//   NRDT守恒律: 删除前后所有路径黑高相等 ⟺ 红黑性质守恒

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./红黑树后继.nova")
导入("./红黑树创建.nova")

// NRDT统计状态
定义 可变 _RB删_总数 = 0
定义 可变 _RB删_惰性标记数 = 0
定义 可变 _RB删_批量次数 = 0
定义 可变 _RB删_最大批量 = 0
定义 可变 _RB删_清扫回收 = 0
定义 可变 _RB删_范围删除数 = 0
定义 可变 _惰性删除集 = []

函数 红黑树_删除(树, 键) {
    定义 z = 红黑树_查找(树, 键)
    如果 (z == 空) { 返回 错误_不存在 }
    _RB删_总数 = _RB删_总数 + 1
    定义 可变 y = z
    定义 y原色 = y[RB_色]
    定义 可变 x = 空
    定义 可变 x父 = 空
    如果 (z[RB_左] == 空) {
        x = z[RB_右]
        x父 = z[RB_父]
        红黑树_移植(树, z, z[RB_右])
    } 否则 如果 (z[RB_右] == 空) {
        x = z[RB_左]
        x父 = z[RB_父]
        红黑树_移植(树, z, z[RB_左])
    } 否则 {
        y = z[RB_右]
        当 (y[RB_左] != 空) { y = y[RB_左] }
        y原色 = y[RB_色]
        x = y[RB_右]
        如果 (y[RB_父] == z) {
            x父 = y
        } 否则 {
            x父 = y[RB_父]
            红黑树_移植(树, y, y[RB_右])
            设置(y, RB_右, z[RB_右])
            如果 (z[RB_右] != 空) { 设置(z[RB_右], RB_父, y) }
        }
        红黑树_移植(树, z, y)
        设置(y, RB_左, z[RB_左])
        如果 (z[RB_左] != 空) { 设置(z[RB_左], RB_父, y) }
        设置(y, RB_色, z[RB_色])
    }
    设置(树, 1, 树[1] - 1)
    如果 (y原色 == 黑) {
        红黑树_删除修复(树, x, x父)
    }
    返回 成功
}

函数 红黑树_删除最小(树) {
    定义 最小 = 红黑树_最小(树)
    如果 (最小 == 空) { 返回 空 }
    定义 键 = 最小[RB_键]
    定义 值 = 最小[RB_值]
    红黑树_删除(树, 键)
    返回 [键, 值]
}

函数 红黑树_删除最大(树) {
    定义 可变 节点 = 树[0]
    如果 (节点 == 空) { 返回 空 }
    当 (节点[RB_右] != 空) { 节点 = 节点[RB_右] }
    定义 键 = 节点[RB_键]
    定义 值 = 节点[RB_值]
    红黑树_删除(树, 键)
    返回 [键, 值]
}

// §3 NRDT定理1: 惰性删除 — 标记集+延迟清扫
// 高频场景: 标记O(1), 查询跳过已标记, 择机批量清扫

函数 红黑树_惰性删除(树, 键) {
    定义 节点 = 红黑树_查找(树, 键)
    如果 (节点 == 空) { 返回 错误_不存在 }
    定义 可变 i = 0
    当 (i < 计数(_惰性删除集)) {
        如果 (_惰性删除集[i] == 键) { 返回 错误_不存在 }
        i = i + 1
    }
    追加(_惰性删除集, 键)
    _RB删_惰性标记数 = _RB删_惰性标记数 + 1
    返回 成功
}

函数 红黑树_是惰性删除(键) {
    定义 可变 i = 0
    当 (i < 计数(_惰性删除集)) {
        如果 (_惰性删除集[i] == 键) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 红黑树_惰性查找(树, 键) {
    如果 (红黑树_是惰性删除(键)) { 返回 空 }
    返回 红黑树_查找(树, 键)
}

函数 红黑树_惰性清扫(树) {
    定义 可变 清扫数 = 计数(_惰性删除集)
    定义 可变 i = 0
    当 (i < 清扫数) {
        红黑树_删除(树, _惰性删除集[i])
        i = i + 1
    }
    _RB删_清扫回收 = _RB删_清扫回收 + 清扫数
    _惰性删除集 = []
    返回 清扫数
}

函数 红黑树_惰性待清数() { 返回 计数(_惰性删除集) }

// §4 NRDT定理2: 批量删除 — 多键/范围/条件

函数 红黑树_批量删除(树, 键列表) {
    定义 数量 = 计数(键列表)
    如果 (数量 == 0) { 返回 0 }
    定义 可变 成功数 = 0
    定义 可变 i = 0
    当 (i < 数量) {
        如果 (红黑树_删除(树, 键列表[i]) == 成功) { 成功数 = 成功数 + 1 }
        i = i + 1
    }
    _RB删_批量次数 = _RB删_批量次数 + 1
    如果 (数量 > _RB删_最大批量) { _RB删_最大批量 = 数量 }
    返回 成功数
}

函数 红黑树_范围删除(树, 低, 高) {
    定义 键列表 = []
    _红黑树_收集范围键(树[0], 低, 高, 键列表)
    _RB删_范围删除数 = _RB删_范围删除数 + 1
    返回 红黑树_批量删除(树, 键列表)
}

函数 _红黑树_收集范围键(节点, 低, 高, 结果) {
    如果 (节点 == 空) { 返回 }
    如果 (节点[RB_键] > 低) { _红黑树_收集范围键(节点[RB_左], 低, 高, 结果) }
    如果 (节点[RB_键] >= 低 && 节点[RB_键] <= 高) { 追加(结果, 节点[RB_键]) }
    如果 (节点[RB_键] < 高) { _红黑树_收集范围键(节点[RB_右], 低, 高, 结果) }
}

// 条件删除: 值小于阈值的所有节点
函数 红黑树_条件删除(树, 值阈值) {
    定义 键列表 = []
    _红黑树_收集条件键(树[0], 值阈值, 键列表)
    返回 红黑树_批量删除(树, 键列表)
}

函数 _红黑树_收集条件键(节点, 阈值, 结果) {
    如果 (节点 == 空) { 返回 }
    _红黑树_收集条件键(节点[RB_左], 阈值, 结果)
    如果 (节点[RB_值] < 阈值) { 追加(结果, 节点[RB_键]) }
    _红黑树_收集条件键(节点[RB_右], 阈值, 结果)
}

// §5 NRDT定理3: 迭代器安全删除 — 快照键集模式

函数 红黑树_安全遍历删除(树, 判断函数) {
    定义 待删除 = []
    _红黑树_安全收集(树[0], 判断函数, 待删除)
    返回 红黑树_批量删除(树, 待删除)
}

函数 _红黑树_安全收集(节点, 判断, 结果) {
    如果 (节点 == 空) { 返回 }
    _红黑树_安全收集(节点[RB_左], 判断, 结果)
    如果 (判断(节点[RB_键], 节点[RB_值])) { 追加(结果, 节点[RB_键]) }
    _红黑树_安全收集(节点[RB_右], 判断, 结果)
}

// §6 NRDT定理4: 秩查询 — 第k小 + 键的秩

函数 _红黑树_子树大小(节点) {
    如果 (节点 == 空) { 返回 0 }
    返回 1 + _红黑树_子树大小(节点[RB_左]) + _红黑树_子树大小(节点[RB_右])
}

函数 红黑树_第k小(树, k) {
    返回 _红黑树_第k小递归(树[0], k)
}

函数 _红黑树_第k小递归(节点, k) {
    如果 (节点 == 空) { 返回 空 }
    定义 左大小 = _红黑树_子树大小(节点[RB_左])
    如果 (k < 左大小) { 返回 _红黑树_第k小递归(节点[RB_左], k) }
    如果 (k == 左大小) { 返回 [节点[RB_键], 节点[RB_值]] }
    返回 _红黑树_第k小递归(节点[RB_右], k - 左大小 - 1)
}

函数 红黑树_秩(树, 键) {
    返回 _红黑树_秩递归(树[0], 键)
}

函数 _红黑树_秩递归(节点, 键) {
    如果 (节点 == 空) { 返回 0 }
    如果 (键 < 节点[RB_键]) { 返回 _红黑树_秩递归(节点[RB_左], 键) }
    如果 (键 == 节点[RB_键]) { 返回 _红黑树_子树大小(节点[RB_左]) }
    返回 1 + _红黑树_子树大小(节点[RB_左]) + _红黑树_秩递归(节点[RB_右], 键)
}

// §7 查询: 范围/下界/上界/前驱

函数 红黑树_范围查询_递归(节点, 低, 高, 结果) {
    如果 (节点 == 空) { 返回 }
    如果 (节点[RB_键] > 低) { 红黑树_范围查询_递归(节点[RB_左], 低, 高, 结果) }
    如果 (节点[RB_键] >= 低 && 节点[RB_键] <= 高) {
        追加(结果, [节点[RB_键], 节点[RB_值]])
    }
    如果 (节点[RB_键] < 高) { 红黑树_范围查询_递归(节点[RB_右], 低, 高, 结果) }
}

函数 红黑树_范围查询(树, 低, 高) {
    定义 结果 = []
    红黑树_范围查询_递归(树[0], 低, 高, 结果)
    返回 结果
}

函数 红黑树_下界(树, 键) {
    定义 可变 节点 = 树[0]
    定义 可变 最佳 = 空
    当 (节点 != 空) {
        如果 (节点[RB_键] >= 键) { 最佳 = 节点; 节点 = 节点[RB_左] }
        否则 { 节点 = 节点[RB_右] }
    }
    返回 最佳
}

函数 红黑树_上界(树, 键) {
    定义 可变 节点 = 树[0]
    定义 可变 最佳 = 空
    当 (节点 != 空) {
        如果 (节点[RB_键] > 键) { 最佳 = 节点; 节点 = 节点[RB_左] }
        否则 { 节点 = 节点[RB_右] }
    }
    返回 最佳
}

函数 红黑树_前驱(树, 键) {
    定义 可变 节点 = 树[0]
    定义 可变 最佳 = 空
    当 (节点 != 空) {
        如果 (节点[RB_键] < 键) { 最佳 = 节点; 节点 = 节点[RB_右] }
        否则 { 节点 = 节点[RB_左] }
    }
    返回 最佳
}

// §8 遍历 + 结构验证

函数 红黑树_高度_递归(节点) {
    如果 (节点 == 空) { 返回 0 }
    定义 左高 = 红黑树_高度_递归(节点[RB_左])
    定义 右高 = 红黑树_高度_递归(节点[RB_右])
    如果 (左高 > 右高) { 返回 左高 + 1 }
    返回 右高 + 1
}

函数 红黑树_高度(树) { 返回 红黑树_高度_递归(树[0]) }

// NRDT守恒律验证: 所有根→叶路径黑节点数相等
函数 _红黑树_黑高验证(节点) {
    如果 (节点 == 空) { 返回 1 }
    定义 左黑高 = _红黑树_黑高验证(节点[RB_左])
    定义 右黑高 = _红黑树_黑高验证(节点[RB_右])
    如果 (左黑高 == -1 || 右黑高 == -1 || 左黑高 != 右黑高) { 返回 -1 }
    如果 (节点[RB_色] == 黑) { 返回 左黑高 + 1 }
    返回 左黑高
}

函数 红黑树_验证(树) { 返回 _红黑树_黑高验证(树[0]) >= 0 }

函数 红黑树_中序遍历(节点, 结果) {
    如果 (节点 == 空) { 返回 }
    红黑树_中序遍历(节点[RB_左], 结果)
    追加(结果, [节点[RB_键], 节点[RB_值]])
    红黑树_中序遍历(节点[RB_右], 结果)
}

函数 红黑树_到列表(树) {
    定义 结果 = []
    红黑树_中序遍历(树[0], 结果)
    返回 结果
}

函数 _红黑树_反序(节点, 结果) {
    如果 (节点 == 空) { 返回 }
    _红黑树_反序(节点[RB_右], 结果)
    追加(结果, [节点[RB_键], 节点[RB_值]])
    _红黑树_反序(节点[RB_左], 结果)
}

函数 红黑树_到反序列表(树) {
    定义 结果 = []
    _红黑树_反序(树[0], 结果)
    返回 结果
}

函数 红黑树_前N最小(树, n) {
    定义 结果 = []
    _红黑树_前N(树[0], n, 结果)
    返回 结果
}

函数 _红黑树_前N(节点, n, 结果) {
    如果 (节点 == 空 || 计数(结果) >= n) { 返回 }
    _红黑树_前N(节点[RB_左], n, 结果)
    如果 (计数(结果) < n) { 追加(结果, [节点[RB_键], 节点[RB_值]]) }
    如果 (计数(结果) < n) { _红黑树_前N(节点[RB_右], n, 结果) }
}

// NRDT完整统计

函数 红黑树删除_完整统计(树) {
    返回 [
        ["元素数", 树[1]],
        ["树高度", 红黑树_高度(树)],
        ["总删除", _RB删_总数],
        ["惰性待清", 计数(_惰性删除集)],
        ["惰性总标记", _RB删_惰性标记数],
        ["清扫回收", _RB删_清扫回收],
        ["批量次数", _RB删_批量次数],
        ["最大批量", _RB删_最大批量],
        ["范围删除", _RB删_范围删除数],
        ["结构有效", 红黑树_验证(树)]
    ]
}

// NRDT+ — Nova Red-black Delete Theory Extended
// 公理1(黑高守恒): 删除后所有根→叶路径黑节点数不变
// 公理2(旋转有界): 单次删除最多3次旋转
// 定理1(惰性安全): 惰性删除不影响在线查询正确性
// 定理2(平衡保持): h(T) <= 2*log2(n+1)

函数 红黑树_节点数_递归(节点) {
    如果 (节点 == 空) { 返回 0 }
    返回 1 + 红黑树_节点数_递归(节点[RB_左]) + 红黑树_节点数_递归(节点[RB_右])
}

函数 红黑树_红节点数_递归(节点) {
    如果 (节点 == 空) { 返回 0 }
    定义 可变 c = 0
    如果 (节点[RB_色] == 红) { c = 1 }
    返回 c + 红黑树_红节点数_递归(节点[RB_左]) + 红黑树_红节点数_递归(节点[RB_右])
}

函数 红黑树_黑高(树) {
    定义 可变 节点 = 树[0]
    定义 可变 h = 0
    当 (节点 != 空) {
        如果 (节点[RB_色] == 黑) { h = h + 1 }
        节点 = 节点[RB_左]
    }
    返回 h
}

函数 红黑树_合并(树a, 树b) {
    // 将树b的所有元素插入树a
    定义 元素 = []
    红黑树_中序遍历(树b[0], 元素)
    定义 可变 i = 0
    当 (i < 计数(元素)) {
        红黑树_插入(树a, 元素[i][0], 元素[i][1])
        i = i + 1
    }
}

函数 红黑树_分裂(树, 枢轴键) {
    // 按键分裂为两棵树: < 枢轴 和 >= 枢轴
    定义 所有 = []
    红黑树_中序遍历(树[0], 所有)
    定义 左树 = 红黑树_创建()
    定义 右树 = 红黑树_创建()
    定义 可变 i = 0
    当 (i < 计数(所有)) {
        如果 (所有[i][0] < 枢轴键) {
            红黑树_插入(左树, 所有[i][0], 所有[i][1])
        } 否则 {
            红黑树_插入(右树, 所有[i][0], 所有[i][1])
        }
        i = i + 1
    }
    返回 [左树, 右树]
}

函数 红黑树删除_重置统计() {
    _RB删_总数 = 0
    _RB删_惰性标记数 = 0
    _RB删_清扫回收 = 0
    _RB删_批量次数 = 0
    _RB删_最大批量 = 0
    _RB删_范围删除数 = 0
    _惰性删除集 = []
}

函数 红黑树_批量插入(树, 键值列表) {
    // 批量插入 [[key,val], ...]
    定义 可变 i = 0
    当 (i < 计数(键值列表)) {
        红黑树_插入(树, 键值列表[i][0], 键值列表[i][1])
        i = i + 1
    }
}

函数 红黑树_统计节点(树) {
    返回 [红黑树_节点数_递归(树[0]),
           红黑树_红节点数_递归(树[0]),
           红黑树_高度(树),
           红黑树_黑高(树)]
}

函数 红黑树_完整诊断(树) {
    返回 [
        "元素数", 树[1],
        "树高", 红黑树_高度(树),
        "黑高", 红黑树_黑高(树),
        "红节点数", 红黑树_红节点数_递归(树[0]),
        "删除总数", _RB删_总数,
        "惰性待清", 计数(_惰性删除集),
        "批量次数", _RB删_批量次数,
        "结构有效", 红黑树_验证(树),
        "原生独创_NRDT+红黑树", 1
    ]
}

定义 可变 AI_红黑树删除_热节点缓存 = 0

函数 AI_红黑树删除_节点热度(节点, 操作类型) {
    如果 (操作类型 == "查询") { 返回 "缓存" }
    如果 (操作类型 == "修改") { AI_红黑树删除_热节点缓存 = 0; 返回 "失效" }
    返回 "普通"
}

函数 AI_红黑树删除_批量DOM优化(操作数) {
    如果 (操作数 > 100) { 返回 "延迟重排" }
    如果 (操作数 > 10) { 返回 "批量重排" }
    返回 "即时重排"
}

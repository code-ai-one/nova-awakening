导入("../../基础.nova")

// 【原创理论基础】
// 中文量词（条/张/棵/个/台/把/根/片/块/组/串/套/对/批）不是装饰，
// 它们是自然语言中最古老的类型系统。当我们说"一条鱼"而不是"一张鱼"时，
// 我们在做的就是类型检查。
// 这个理论的核心洞见：
// 量词 ≅ Kind (类型的类型)
// 名词 ≅ Type (类型)
// 动词 ≅ Morphism (态射)
// "把"字句 ≅ Linear Consumption (线性消费)
// 这构成了一个完整的范畴论结构：
// - 每个量词定义一个范畴 (Category)
// - 同量词的名词是该范畴的对象 (Objects)
// - 动词是对象间的态射 (Morphisms)
// - 量词变换是函子 (Functors)
// 与西方类型理论的本质区别：
// - Haskell的Kind系统是后天设计的，量词是语言天然的
// - 依赖类型从逻辑出发，量词从认知分类出发
// - 量词携带物理直觉：条=细长, 张=平面, 棵=植物, 台=机器
// 数学定义:
// C = 量词集 (classifiers)
// O : C → Set (每个量词对应的类型集)
// M : O(c) × O(c) → Set (同范畴态射)
// ⊗ : C × C → C (量词积)
// I : C (单位量词 "个")

// 量词常量定义
// 每个量词代表一个认知范畴 (cognitive category)
定义 量词_个 = 0 // 通用量词 (单位元, 类似 Type)
定义 量词_条 = 1 // 细长连续体 (鱼/蛇/河/路/消息/线程)
定义 量词_张 = 2 // 平面展开体 (纸/图/表/网页/位图)
定义 量词_棵 = 3 // 植物/树形结构 (树/AST/DOM/B树)
定义 量词_台 = 4 // 机器/计算设备 (电脑/服务器/虚拟机)
定义 量词_把 = 5 // 可握持/可操作 (锁/句柄/用/指针)
定义 量词_根 = 6 // 细长刚性体 (管道/连接/栈帧)
定义 量词_片 = 7 // 薄片/切片 (内存页/数据切片/缓冲区, 0 , 0)
定义 量词_块 = 8 // 块状实体 (内存块/磁盘块/数据块)
定义 量词_组 = 9 // 组合体 (数组/元组/记录)
定义 量词_串 = 10 // 串联体 (字符串/链表/序列)
定义 量词_套 = 11 // 配套体 (API/协议/接口集)
定义 量词_对 = 12 // 成对体 (键值对/请求响应/输入输出)
定义 量词_批 = 13 // 批量体 (批处理/数据集/日志批次)
定义 量词_道 = 14 // 过程/工序 (编译阶段/管线阶段/工作流步骤)
定义 量词_层 = 15 // 层级体 (网络层/抽象层/缓存层)
定义 量词_帧 = 16 // 帧 (栈帧/视频帧/动画帧)
定义 量词_路 = 17 // 路径/信号 (信号/通道/路由)

// 量词总数
定义 量词_总数 = 18

// 量词名称映射
函数 量词名(q) {
    如果 (q == 量词_个) { 返回 "个"
}
 如果 (q == 量词_条) { 返回 "条" }
 如果 (q == 量词_张) { 返回 "张" }
 如果 (q == 量词_棵) { 返回 "棵" }
 如果 (q == 量词_台) { 返回 "台" }
 如果 (q == 量词_把) { 返回 "把" }
 如果 (q == 量词_根) { 返回 "根" }
 如果 (q == 量词_片) { 返回 "片" }
 如果 (q == 量词_块) { 返回 "块" }
 如果 (q == 量词_组) { 返回 "组" }
 如果 (q == 量词_串) { 返回 "串" }
 如果 (q == 量词_套) { 返回 "套" }
 如果 (q == 量词_对) { 返回 "对" }
 如果 (q == 量词_批) { 返回 "批" }
 如果 (q == 量词_道) { 返回 "道" }
 如果 (q == 量词_层) { 返回 "层" }
 如果 (q == 量词_帧) { 返回 "帧" }
 如果 (q == 量词_路) { 返回 "路" }
 返回 "未知"
}

// 量词兼容性矩阵
// 量词之间存在自然的子类型关系:
// "个" 是顶类型 (所有量词都可以退化为"个")
// 这定义了一个偏序格 (partial order lattice)

// 量词子类型关系: a是否可以安全地用在期望b的位置
函数 量词_兼容(a, b) {
    如果 (a == b) { 返回 1
}
 如果 (b == 量词_个) { 返回 1 } // "个" 是顶类型
 // 条 → 串 (细长连续体可视为串联体)
 如果 (a == 量词_条 且 b == 量词_串) { 返回 1 }
 // 片 → 块 (片可视为薄块)
 如果 (a == 量词_片 且 b == 量词_块) { 返回 1 }
 // 帧 → 片 (帧可视为一片)
 如果 (a == 量词_帧 且 b == 量词_片) { 返回 1 }
 // 对 → 组 (对可视为2元组)
 如果 (a == 量词_对 且 b == 量词_组) { 返回 1 }
 // 路 → 条 (路径是一种细长连续体)
 如果 (a == 量词_路 且 b == 量词_条) { 返回 1 }
 返回 0
}

// 量词化值 (Classified Value)
// [量词, 值, 生命期标记, 引用计数, 元数据]

函数 分类(量词, 值) { 返回 [量词, 值, 0, 1, 空]
}

函数 分类_量词(cv) { 返回 cv[0] }
函数 分类_值(cv) { 返回 cv[1] }
函数 分类_生命期(cv) { 返回 cv[2] }
函数 分类_引用数(cv) { 返回 cv[3] }
函数 分类_元数据(cv) { 返回 cv[4] }

函数 量词_检查(cv, 期望量词) {
    如果 (量词_兼容(分类_量词(cv), 期望量词) == 1) { 返回 1
}
 返回 0
}

// 量词态射 (Classifier Morphisms)
// 动词作为态射: 操作改变值但保持/变换量词

// 同量词态射: 量词不变的操作
函数 态射_同类(cv, 操作函数, 参数) { 定义 新值 = 操作函数(分类_值(cv), 参数)
 返回 分类(分类_量词(cv), 新值)
}

// 例: "切"(块→片), "串"(个→串), "打包"(批→组)
函数 态射_变换(cv, 目标量词, 操作函数, 参数) { 定义 新值 = 操作函数(分类_值(cv), 参数)
 返回 分类(目标量词, 新值)
}

// 量词代数运算

// 量词积: 两个量词化值的乘积
// 一条鱼 ⊗ 一张网 = 一对(鱼,网)
函数 量词积(a, b) { 返回 分类(量词_对, [a, b])
}

// 量词和: 两个量词化值的选择
// 一条鱼 ⊕ 一块肉 = 一个(鱼|肉)
函数 量词和(a, b) { 返回 分类(量词_个, [a, b])
}

// 量词升格: 将多个同量词值组成批/组
函数 量词_批量化(cv_列表) {
    如果 (计数(cv_列表) == 0) { 返回 分类(量词_批, [])
}
 定义 可变 值列表 = []
 定义 可变 i = 0
 当 (i < 计数(cv_列表)) {
 追加(值列表, 分类_值(cv_列表[i]))
 i = i + 1
 }
 返回 分类(量词_批, 值列表)
}

// 量词降格: 从批/组中取出单个
函数 量词_单取(cv, 索引, 目标量词) { 定义 列表 = 分类_值(cv)
 如果 (索引 < 0 或 索引 >= 计数(列表)) { 返回 空 }
 返回 分类(目标量词, 列表[索引])
}

// 量词约束传播
// 在表达式求值时自动推导结果量词

// 二元操作的量词推导规则
函数 量词_二元推导(op, 左量词, 右量词) {
 // 同量词: 结果保持量词
 如果 (左量词 == 右量词) { 返回 左量词 }
 // 拼接: 串+串=串, 条+条=串
 如果 (op == "+") { 如果 (左量词 == 量词_串 或 右量词 == 量词_串) { 返回 量词_串 }
 如果 (左量词 == 量词_条 且 右量词 == 量词_条) { 返回 量词_串 }
 }
 // 切片: 块/串/批→片
 如果 (op == "切") { 返回 量词_片 }
 // 默认: 退化为"个"
 返回 量词_个
}

// 量词范畴 (Classifier Category)
// 每个量词定义一个范畴, 范畴之间的函子定义量词变换

// 范畴: [量词id, 对象列表, 态射列表]
函数 范畴_创建(量词id) { 返回 [量词id, [], []]
}

函数 范畴_注册对象(范畴, 类型名) {
 追加(范畴[1], 类型名)
}

函数 范畴_注册态射(范畴, 态射名, 源类型, 目标类型) {
 追加(范畴[2], [态射名, 源类型, 目标类型])
}

// 函子: 范畴间的结构保持映射
// [源范畴量词, 目标范畴量词, 对象映射, 态射映射]
函数 函子_创建(源量词, 目标量词) { 返回 [源量词, 目标量词, [], []]
}

函数 函子_映射对象(函子, 源对象, 目标对象) {
 追加(函子[2], [源对象, 目标对象])
}

函数 函子_映射态射(函子, 源态射, 目标态射) {
 追加(函子[3], [源态射, 目标态射])
}

// 全局注册: 每个编程概念属于哪个量词范畴
定义 可变 量词注册表_名 = []
定义 可变 量词注册表_词 = []

函数 量词注册(名称, 量词) {
 追加(量词注册表_名, 名称)
 追加(量词注册表_词, 量词)
}

函数 量词查询(名称) { 定义 可变 i = 0
 当 (i < 计数(量词注册表_名)) { 如果 (量词注册表_名[i] == 名称) { 返回 量词注册表_词[i] }
 i = i + 1
 }
 返回 量词_个 // 默认"个"
}

// 预注册编程领域的量词映射
函数 量词_初始化() {
 // 条类 (细长连续体)
 量词注册("线程", 量词_条)
 量词注册("消息", 量词_条)
 量词注册("连接", 量词_条)
 量词注册("流", 量词_条)
 量词注册("管道", 量词_条)
 // 张类 (平面展开体)
 量词注册("页面", 量词_张)
 量词注册("图片", 量词_张)
 量词注册("表格", 量词_张)
 量词注册("位图", 量词_张)
 量词注册("网页", 量词_张)
 // 棵类 (树形结构)
 量词注册("语法树", 量词_棵)
 量词注册("DOM树", 量词_棵)
 量词注册("B树", 量词_棵)
 量词注册("红黑树", 量词_棵)
 量词注册("目录树", 量词_棵)
 // 台类 (机器/计算设备)
 量词注册("服务器", 量词_台)
 量词注册("虚拟机", 量词_台)
 量词注册("容器", 量词_台)
 // 把类 (可操作/句柄)
 量词注册("锁", 量词_把)
 量词注册("句柄", 量词_把)
 量词注册("指针", 量词_把)
 量词注册("用", 量词_把)
 // 片类 (切片/页)
 量词注册("内存页", 量词_片)
 量词注册("切片", 量词_片)
 量词注册("缓冲区", 量词_片)
 // 块类
 量词注册("内存块", 量词_块)
 量词注册("磁盘块", 量词_块)
 量词注册("数据块", 量词_块)
 // 组类
 量词注册("数组", 量词_组)
 量词注册("元组", 量词_组)
 量词注册("结构体", 量词_组)
 // 串类
 量词注册("字符串", 量词_串)
 量词注册("链表", 量词_串)
 量词注册("序列", 量词_串)
 // 套类
 量词注册("接口", 量词_套)
 量词注册("协议", 量词_套)
 量词注册("API", 量词_套)
 // 对类
 量词注册("键值对", 量词_对)
 量词注册("请求响应", 量词_对)
 // 道类
 量词注册("编译阶段", 量词_道)
 量词注册("管线阶段", 量词_道)
 // 层类
 量词注册("网络层", 量词_层)
 量词注册("抽象层", 量词_层)
}

函数 量词_类型错误(操作名, 期望, 实际) { 定义 可变 msg = "量词类型错误: '"
 msg = 字符串拼接(msg, 操作名)
 msg = 字符串拼接(msg, "' 期望 '")
 msg = 字符串拼接(msg, 量词名(期望))
 msg = 字符串拼接(msg, "' 类, 实际得到 '")
 msg = 字符串拼接(msg, 量词名(实际))
 msg = 字符串拼接(msg, "' 类")
 返回 msg
}

// 量词自然变换 (Natural Transformation)
// η: Id → F, 每个对象x有一个态射 η_x : x → F(x)
// 这描述了"装箱"操作: 值 → 分类值

函数 自然变换_装箱(值, 量词) { 返回 分类(量词, 值)
}

函数 自然变换_拆箱(cv) { 返回 分类_值(cv)
}

// 量词提升: 将普通函数提升为量词感知函数
函数 量词_提升(函数ref, 期望量词) { 返回 [函数ref, 期望量词]
}

导入("../中枢/硬链接.nova")
导入("../中枢/内核打印.nova")
导入("./值乘.nova")
导入("../外联/地址解析辅.nova")
导入("../标准/原生字符串.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/字符串替换.nova")
导入("./统一调用器.nova")
// NovaOS 智能体代码操作 (ACOP — Agent Code Operations Pipeline)
// Nova代码分析 + AST操作 + AI代码生成 + 代码审查 + 差异比较 + 重构 + 格式化
// ACOP核心理论: 代码基因识别模型 (Code Genome Identification Model)
//   每段代码拥有独特的"基因指纹" = f(结构复杂度, 命名风格, 依赖图谱)
//   AI通过基因指纹匹配实现智能代码搜索/分类/查重/重构建议


定义 ACOP_最大行数        = 100000  // 单文件最大分析行数
定义 ACOP_最大函数深度    = 32      // 嵌套函数最大深度
定义 ACOP_复杂度阈值    = 15      // 圈复杂度警告阈值
定义 ACOP_重复代码阈值  = 5       // 相似代码块匹配阈值(行)
定义 ACOP_缓存容量      = 64      // 分析缓存最大条目
定义 ACOP_基因特征维度  = 8       // 代码基因指纹维度

// 全局计数器
定义 可变 ACOP_总分析次数 = 0
定义 可变 ACOP_总AI调用数 = 0
定义 可变 ACOP_总重构次数 = 0


结构 代码分析结果 {
    总行数,
    函数数,
    结构数,
    导入数,
    空行数,
    注释行,
    代码行,
    圈复杂度,         // u32 McCabe圈复杂度
    最大嵌套深度,
    可变量数,
    定义量数,
    质量分数           // u32 (0-100)
}

结构 函数信息 {
    名称,
    起始行,
    结束行,
    参数数,
    复杂度,
    行数               // u32
}

结构 代码差异项 {
    行号,
    旧内容,
    新内容,
    类型               // u32 (0=修改, 1=增加, 2=删除)
}

结构 代码基因 {
    结构复杂度,
    命名风格,         // u32 (0=中文, 1=英文, 2=混合)
    函数密度,         // u32 每100行函数数
    注释密度,         // u32 注释行占比%
    嵌套平均,         // u32 平均嵌套深度*10
    行均长,           // u32 平均行长度
    依赖数,           // u32 导入数
    特征哈希           // u64 FNV-1a哈希值
}

结构 ACOP统计 {
    总分析次数,
    总AI调用数,
    总重构次数,
    总行数处理,       // u64 累计处理行数
    平均质量分,
    缓存命中数         // u64
}

定义 可变 全局ACOP统计 = ACOP统计 {}


函数 智能体代码_分析(源码) {
    定义 行列表 = 字符串分割(源码, "\n")
    定义 可变 函数数 = 0
    定义 可变 结构数 = 0
    定义 可变 导入数 = 0
    定义 可变 空行数 = 0
    定义 可变 注释行 = 0
    定义 可变 可变量数 = 0
    定义 可变 定义量数 = 0
    定义 可变 圈复杂度 = 1  // 基础复杂度=1
    定义 可变 最大深度 = 0
    定义 可变 当前深度 = 0
    定义 可变 i = 0
    当 (i < 计数(行列表) && i < ACOP_最大行数) {
        定义 行 = 字符串去空白(行列表[i])
        如果 (字符串包含(行, "函数 ")) { 函数数 = 函数数 + 1 }
        如果 (字符串开始于(行, "结构 ")) { 结构数 = 结构数 + 1 }
        如果 (字符串开始于(行, "导入(")) { 导入数 = 导入数 + 1 }
        如果 (字符串长度(行) == 0) { 空行数 = 空行数 + 1 }
        如果 (字符串开始于(行, "//")) { 注释行 = 注释行 + 1 }
        如果 (字符串包含(行, "可变 ")) { 可变量数 = 可变量数 + 1 }
        如果 (字符串开始于(行, "定义 ")) { 定义量数 = 定义量数 + 1 }
        // McCabe圈复杂度: 每个分支+1
        如果 (字符串包含(行, "如果 ") || 字符串包含(行, "否则 ")) { 圈复杂度 = 圈复杂度 + 1 }
        如果 (字符串包含(行, "当 (")) { 圈复杂度 = 圈复杂度 + 1 }
        如果 (字符串包含(行, "&&") || 字符串包含(行, "||")) { 圈复杂度 = 圈复杂度 + 1 }
        // 嵌套深度跟踪
        定义 可变 j = 0
        当 (j < 字符串长度(行)) {
            如果 (字符串字符(行, j) == 123) { 当前深度 = 当前深度 + 1 }
            如果 (字符串字符(行, j) == 125) { 当前深度 = 当前深度 - 1 }
            j = j + 1
        }
        如果 (当前深度 > 最大深度) { 最大深度 = 当前深度 }
        i = i + 1
    }
    // 质量评分: 基于注释率+复杂度+嵌套深度综合评估
    定义 总行 = 计数(行列表)
    定义 可变 质量 = 100
    如果 (总行 > 0) {
        定义 注释率 = (注释行 * 100) / 总行
        如果 (注释率 < 10) { 质量 = 质量 - 15 }  // 注释太少
    }
    如果 (圈复杂度 > ACOP_复杂度阈值) { 质量 = 质量 - 20 }
    如果 (最大深度 > 6) { 质量 = 质量 - 10 }
    如果 (质量 < 0) { 质量 = 0 }
    ACOP_总分析次数 = ACOP_总分析次数 + 1
    全局ACOP统计.总分析次数 = 全局ACOP统计.总分析次数 + 1
    全局ACOP统计.总行数处理 = 全局ACOP统计.总行数处理 + 总行
    返回 代码分析结果 {
        总行数: 总行,
        函数数: 函数数,
        结构数: 结构数,
        导入数: 导入数,
        空行数: 空行数,
        注释行: 注释行,
        代码行: 总行 - 空行数 - 注释行,
        圈复杂度: 圈复杂度,
        最大嵌套深度: 最大深度,
        可变量数: 可变量数,
        定义量数: 定义量数,
        质量分数: 质量
    }
}


函数 智能体代码_搜索函数(源码, 函数名) {
    定义 行列表 = 字符串分割(源码, "\n")
    定义 可变 i = 0
    定义 可变 起始 = 0 - 1
    定义 可变 结束 = 0 - 1
    定义 可变 括号深度 = 0
    当 (i < 计数(行列表)) {
        如果 (字符串包含(行列表[i], "函数 " + 函数名)) {
            起始 = i
        }
        如果 (起始 >= 0) {
            定义 可变 j = 0
            当 (j < 字符串长度(行列表[i])) {
                如果 (字符串字符(行列表[i], j) == 123) { 括号深度 = 括号深度 + 1 }
                如果 (字符串字符(行列表[i], j) == 125) { 括号深度 = 括号深度 - 1 }
                j = j + 1
            }
            如果 (括号深度 == 0 && 起始 >= 0 && i > 起始) { 结束 = i; 跳出 }
        }
        i = i + 1
    }
    如果 (起始 >= 0 && 结束 >= 0) {
        定义 可变 代码 = ""
        i = 起始
        当 (i <= 结束) { 代码 = 代码 + 行列表[i] + "\n"; i = i + 1 }
        返回 {找到: 真, 起始行: 起始 + 1, 结束行: 结束 + 1, 代码: 代码}
    }
    返回 {找到: 假}
}

函数 智能体代码_提取所有函数(源码) {
    // 提取所有函数的信息列表
    定义 行列表 = 字符串分割(源码, "\n")
    定义 可变 函数列表 = []
    定义 可变 i = 0
    定义 可变 当前函数名 = ""
    定义 可变 起始行 = 0
    定义 可变 括号深度 = 0
    定义 可变 在函数内 = 假
    定义 可变 复杂度 = 1
    当 (i < 计数(行列表)) {
        定义 行 = 字符串去空白(行列表[i])
        如果 (字符串包含(行, "函数 ") && 在函数内 == 假) {
            // 提取函数名: "函数 xxx(" -> xxx
            定义 开始 = 字符串查找(行, "函数 ") + 3
            定义 结束位 = 字符串查找(行, "(")
            如果 (结束位 > 开始) {
                当前函数名 = 字符串截取(行, 开始, 结束位)
            }
            起始行 = i
            在函数内 = 真
            复杂度 = 1
        }
        如果 (在函数内) {
            如果 (字符串包含(行, "如果 ") || 字符串包含(行, "当 (")) {
                复杂度 = 复杂度 + 1
            }
            定义 可变 j = 0
            当 (j < 字符串长度(行)) {
                如果 (字符串字符(行, j) == 123) { 括号深度 = 括号深度 + 1 }
                如果 (字符串字符(行, j) == 125) { 括号深度 = 括号深度 - 1 }
                j = j + 1
            }
            如果 (括号深度 == 0 && i > 起始行) {
                追加(函数列表, 函数信息 {
                    名称: 当前函数名,
                    起始行: 起始行 + 1,
                    结束行: i + 1,
                    参数数: 0,
                    复杂度: 复杂度,
                    行数: i - 起始行 + 1
                })
                在函数内 = 假
            }
        }
        i = i + 1
    }
    返回 函数列表
}


函数 智能体代码_差异(旧代码, 新代码) {
    定义 旧行 = 字符串分割(旧代码, "\n")
    定义 新行 = 字符串分割(新代码, "\n")
    定义 可变 差异 = []
    定义 可变 i = 0
    定义 最大 = 计数(旧行)
    如果 (计数(新行) > 最大) { 最大 = 计数(新行) }
    当 (i < 最大) {
        定义 旧 = ""
        定义 新 = ""
        如果 (i < 计数(旧行)) { 旧 = 旧行[i] }
        如果 (i < 计数(新行)) { 新 = 新行[i] }
        如果 (旧 != 新) {
            定义 类型 = 0  // 修改
            如果 (字符串长度(旧) == 0) { 类型 = 1 }  // 增加
            如果 (字符串长度(新) == 0) { 类型 = 2 }  // 删除
            追加(差异, 代码差异项 {
                行号: i + 1,
                旧内容: 旧,
                新内容: 新,
                类型: 类型
            })
        }
        i = i + 1
    }
    返回 差异
}


函数 智能体代码_生成(描述) {
    ACOP_总AI调用数 = ACOP_总AI调用数 + 1
    全局ACOP统计.总AI调用数 = 全局ACOP统计.总AI调用数 + 1
    // 通过AI总线生成Nova代码
    定义 bus = 全局AI总线
    如果 (bus != 空) {
        定义 特征 = Tensor_创建(2)
        Tensor_写(特征, 0, 字符串长度(描述))
        Tensor_写(特征, 1, 1)  // 生成模式
        定义 结果 = AI总线_推理(bus, "代码生成", 特征)
        Tensor_释放(特征)
        Tensor_释放(结果)
    }
    定义 提示 = "请用Nova语言(中文关键字: 函数/定义/如果/否则/当/返回)编写:\n" + 描述
    定义 结果 = 智能_调用("你是NovaOS的编程助手。", 提示)
    如果 (结果.成功 == 1) { 返回 结果.内容 }
    返回 "// AI代码生成失败: " + 结果.错误信息
}

函数 智能体代码_审查(源码) {
    ACOP_总AI调用数 = ACOP_总AI调用数 + 1
    定义 分析 = 智能体代码_分析(源码)
    定义 提示 = "审查Nova代码(共" + 整数转字符串(分析.总行数) + "行, 复杂度" + 整数转字符串(分析.圈复杂度) + "):\n" + 源码
    返回 智能_调用("你是代码审查专家。", 提示)
}


函数 ACOP_计算基因(源码) {
    定义 分析 = 智能体代码_分析(源码)
    定义 行列表 = 字符串分割(源码, "\n")
    // 命名风格检测: 中文 vs 英文
    定义 可变 中文计数 = 0
    定义 可变 英文计数 = 0
    定义 可变 i = 0
    当 (i < 计数(行列表) && i < 50) {
        定义 行 = 行列表[i]
        如果 (字符串包含(行, "函数") || 字符串包含(行, "定义")) { 中文计数 = 中文计数 + 1 }
        如果 (字符串包含(行, "function") || 字符串包含(行, "const")) { 英文计数 = 英文计数 + 1 }
        i = i + 1
    }
    定义 命名风格 = 2  // 混合
    如果 (中文计数 > 英文计数 * 3) { 命名风格 = 0 }  // 中文
    如果 (英文计数 > 中文计数 * 3) { 命名风格 = 1 }  // 英文
    // 函数密度: 每100行的函数数
    定义 函数密度 = 0
    如果 (分析.总行数 > 0) {
        函数密度 = (分析.函数数 * 100) / 分析.总行数
    }
    // 注释密度
    定义 注释密度 = 0
    如果 (分析.总行数 > 0) {
        注释密度 = (分析.注释行 * 100) / 分析.总行数
    }
    // 平均行长度
    定义 可变 总长度 = 0
    i = 0
    当 (i < 计数(行列表)) {
        总长度 = 总长度 + 字符串长度(行列表[i])
        i = i + 1
    }
    定义 行均长 = 0
    如果 (计数(行列表) > 0) { 行均长 = 总长度 / 计数(行列表) }
    // FNV-1a哈希生成特征指纹
    定义 哈希 = 2166136261
    哈希 = ((哈希 * 16777619) + 分析.圈复杂度) % 4294967296
    哈希 = ((哈希 * 16777619) + 命名风格) % 4294967296
    哈希 = ((哈希 * 16777619) + 函数密度) % 4294967296
    哈希 = ((哈希 * 16777619) + 分析.最大嵌套深度) % 4294967296
    返回 代码基因 {
        结构复杂度: 分析.圈复杂度,
        命名风格: 命名风格,
        函数密度: 函数密度,
        注释密度: 注释密度,
        嵌套平均: 分析.最大嵌套深度 * 10 / 2,
        行均长: 行均长,
        依赖数: 分析.导入数,
        特征哈希: 哈希
    }
}


函数 智能体代码_格式化(源码) {
    // 简单格式化: 统一缩进 + 去除尾随空白 + 规范化空行
    定义 行列表 = 字符串分割(源码, "\n")
    定义 可变 结果 = ""
    定义 可变 缩进 = 0
    定义 可变 连续空行 = 0
    定义 可变 i = 0
    当 (i < 计数(行列表)) {
        定义 行 = 字符串去空白(行列表[i])
        // 空行处理: 最多保留一个空行
        如果 (字符串长度(行) == 0) {
            连续空行 = 连续空行 + 1
            如果 (连续空行 <= 1) { 结果 = 结果 + "\n" }
            i = i + 1
            继续
        }
        连续空行 = 0
        // 缩进调整: 右括号先减缩进
        如果 (字符串开始于(行, "}")) { 缩进 = 缩进 - 1 }
        如果 (缩进 < 0) { 缩进 = 0 }
        // 生成缩进字符串
        定义 可变 缩进串 = ""
        定义 可变 k = 0
        当 (k < 缩进) { 缩进串 = 缩进串 + "    "; k = k + 1 }
        结果 = 结果 + 缩进串 + 行 + "\n"
        // 左括号后加缩进
        定义 可变 j = 0
        当 (j < 字符串长度(行)) {
            如果 (字符串字符(行, j) == 123) { 缩进 = 缩进 + 1 }
            如果 (字符串字符(行, j) == 125 && j > 0) { 缩进 = 缩进 - 1 }
            j = j + 1
        }
        如果 (缩进 < 0) { 缩进 = 0 }
        i = i + 1
    }
    返回 结果
}


函数 ACOP_AI重构建议(源码) {
    定义 分析 = 智能体代码_分析(源码)
    定义 函数列表 = 智能体代码_提取所有函数(源码)
    定义 可变 建议 = []
    // 检查过长函数
    定义 可变 i = 0
    当 (i < 计数(函数列表)) {
        如果 (函数列表[i].行数 > 50) {
            追加(建议, "函数'" + 函数列表[i].名称 + "'过长(" + 整数转字符串(函数列表[i].行数) + "行)，建议拆分")
        }
        如果 (函数列表[i].复杂度 > ACOP_复杂度阈值) {
            追加(建议, "函数'" + 函数列表[i].名称 + "'复杂度过高(" + 整数转字符串(函数列表[i].复杂度) + ")，建议简化")
        }
        i = i + 1
    }
    // 检查注释率
    如果 (分析.总行数 > 0) {
        定义 注释率 = (分析.注释行 * 100) / 分析.总行数
        如果 (注释率 < 10) { 追加(建议, "注释率仅" + 整数转字符串(注释率) + "%，建议增加注释") }
    }
    ACOP_总重构次数 = ACOP_总重构次数 + 1
    返回 建议
}


函数 ACOP_打印统计() {
    内核打印("╔═══════════════════════════════════════╗")
    内核打印("║  ACOP 代码操作诊断报告                ║")
    内核打印("╠═══════════════════════════════════════╣")
    内核打印("║ 总分析次数:   {}", 全局ACOP统计.总分析次数)
    内核打印("║ AI调用总数:   {}", 全局ACOP统计.总AI调用数)
    内核打印("║ 重构建议次数: {}", 全局ACOP统计.总重构次数)
    内核打印("║ 总处理行数:   {}", 全局ACOP统计.总行数处理)
    内核打印("╚═══════════════════════════════════════╝")
}

函数 ACOP_初始化() {
    全局ACOP统计 = ACOP统计 {}
    ACOP_总分析次数 = 0
    ACOP_总AI调用数 = 0
    ACOP_总重构次数 = 0
    内核打印("[ACOP] 代码操作子系统已初始化 (代码基因识别模型 v1.0)")
}


函数 ACOP_查重代码块(源码) {
    // 检测源码中的重复代码块 (基于行哈希窗口匹配)
    定义 行列表 = 字符串分割(源码, "\n")
    定义 可变 重复 = []
    定义 可变 哈希表 = []
    定义 可变 哈希数 = 0
    定义 可变 i = 0
    当 (i < 计数(行列表) - ACOP_重复代码阈值) {
        // 对连续的阈值行计算哈希
        定义 可变 h = 2166136261
        定义 可变 k = 0
        当 (k < ACOP_重复代码阈值) {
            定义 行 = 字符串去空白(行列表[i + k])
            如果 (字符串长度(行) > 0) {  // 跳过空行
                h = ((h * 16777619) + 字符串长度(行)) % 4294967296
                定义 可变 c = 0
                当 (c < 字符串长度(行) && c < 20) {
                    h = ((h * 16777619) + 字符串字符(行, c)) % 4294967296
                    c = c + 1
                }
            }
            k = k + 1
        }
        // 检查哈希表中是否已存在
        定义 可变 j = 0
        当 (j < 哈希数) {
            如果 (哈希表[j] == h) {
                追加(重复, "行" + 整数转字符串(i + 1) + "处发现疑似重复代码块")
                跳出
            }
            j = j + 1
        }
        哈希表[哈希数] = h
        哈希数 = 哈希数 + 1
        i = i + 1
    }
    返回 重复
}


函数 ACOP_基因相似度(基因A, 基因B) {
    // 计算两个代码基因的相似度 (0-100)
    // 基于各维度差异的加权距离
    定义 可变 差异总 = 0
    // 复杂度差异 (权重30%)
    定义 d1 = 基因A.结构复杂度 - 基因B.结构复杂度
    如果 (d1 < 0) { d1 = 0 - d1 }
    差异总 = 差异总 + d1 * 30
    // 命名风格差异 (权重20%)
    如果 (基因A.命名风格 != 基因B.命名风格) {
        差异总 = 差异总 + 20
    }
    // 函数密度差异 (权重20%)
    定义 d2 = 基因A.函数密度 - 基因B.函数密度
    如果 (d2 < 0) { d2 = 0 - d2 }
    差异总 = 差异总 + d2 * 20 / 10
    // 嵌套深度差异 (权重15%)
    定义 d3 = 基因A.嵌套平均 - 基因B.嵌套平均
    如果 (d3 < 0) { d3 = 0 - d3 }
    差异总 = 差异总 + d3 * 15 / 10
    // 行均长差异 (权重15%)
    定义 d4 = 基因A.行均长 - 基因B.行均长
    如果 (d4 < 0) { d4 = 0 - d4 }
    差异总 = 差异总 + d4 * 15 / 100
    // 相似度 = max(0, 100 - 差异总)
    定义 相似度 = 100 - 差异总
    如果 (相似度 < 0) { 相似度 = 0 }
    返回 相似度
}


函数 ACOP_AI代码分类(源码) {
    // 通过AI总线对代码进行智能分类
    // 类别: 0=内核, 1=驱动, 2=渲染, 3=网络, 4=AI, 5=工具
    定义 基因 = ACOP_计算基因(源码)
    定义 bus = 全局AI总线
    如果 (bus == 空) {
        // 无AI总线，规则判断
        如果 (基因.命名风格 == 0 && 基因.结构复杂度 > 10) { 返回 0 }  // 内核
        如果 (基因.依赖数 > 5) { 返回 2 }  // 渲染
        返回 5  // 工具
    }
    定义 特征 = Tensor_创建(ACOP_基因特征维度)
    Tensor_写(特征, 0, 基因.结构复杂度)
    Tensor_写(特征, 1, 基因.命名风格)
    Tensor_写(特征, 2, 基因.函数密度)
    Tensor_写(特征, 3, 基因.注释密度)
    Tensor_写(特征, 4, 基因.嵌套平均)
    Tensor_写(特征, 5, 基因.行均长)
    Tensor_写(特征, 6, 基因.依赖数)
    Tensor_写(特征, 7, 基因.特征哈希 % 1000)
    定义 结果 = AI总线_推理(bus, "代码分类", 特征)
    定义 类别 = Tensor_读(结果, 0)
    Tensor_释放(特征)
    Tensor_释放(结果)
    返回 类别
}

// §12 【原生独创】谐振代码质量评分器
// 基于代码基因特征综合评估代码质量

定义 可变 _谐振代码_评分次数 = 0

函数 谐振代码_质量评分(基因) {
    定义 结构分 = 基因.函数密度 * 30 / 100
    定义 命名分 = 基因.命名风格 * 25 / 100
    定义 注释分 = 基因.注释密度 * 20 / 100
    定义 复杂分 = (100 - 基因.嵌套平均) * 25 / 100
    _谐振代码_评分次数 = _谐振代码_评分次数 + 1
    返回 结构分 + 命名分 + 注释分 + 复杂分
}

函数 代码操作_完整统计() {
    返回 [
        "ACOP版本", ACOP_版本,
        "解析次数", ACOP_解析次数,
        "AI推理次数", ACOP_AI推理次数,
        "代码基因数", ACOP_代码基因数,
        "谐振评分次数", _谐振代码_评分次数
    ]

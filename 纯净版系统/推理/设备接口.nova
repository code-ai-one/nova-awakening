导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/创建甲.nova")
导入("../稳态/帧缓冲完整.nova")

定义 最大设备 = 8
定义 设备_帧缓冲 = 0
定义 设备_摄像头 = 1
定义 设备_屏幕捕获 = 2
定义 格式_灰度 = 0
定义 格式_三通道 = 1
定义 格式_四通道 = 2

结构 视觉设备 {
    标识,
    类型,
    宽度,
    高度,
    帧率,
    格式,
    缓冲地址,
    缓冲大小,
    活跃,
    捕获帧数,
    最近捕获,
}

定义 可变 设备表 = []
定义 可变 设备数 = 0
定义 可变 总捕获帧 = 0

函数 视觉_初始化() {
    设备表 = []
    设备数 = 0
    视觉_注册帧缓冲()
}

函数 视觉_注册帧缓冲() {
    如果 (设备数 >= 最大设备) { 返回 -1 }
    定义 设备 = 视觉设备 {}
    设备.标识 = 设备数
    设备.类型 = 设备_帧缓冲
    设备.宽度 = 帧缓冲_获取信息()[0]
    设备.高度 = 帧缓冲_获取信息()[1]
    设备.帧率 = 60
    设备.格式 = 格式_四通道
    设备.缓冲地址 = 0
    设备.缓冲大小 = 设备.宽度 * 设备.高度 * 4
    设备.活跃 = 真
    设备.捕获帧数 = 0
    设备.最近捕获 = 0
    追加(设备表, 设备)
    定义 索引 = 设备数
    设备数 = 设备数 + 1
    返回 索引
}

函数 视觉_注册摄像头(宽, 高, 帧率) {
    如果 (设备数 >= 最大设备) { 返回 -1 }
    定义 设备 = 视觉设备 {}
    设备.标识 = 设备数
    设备.类型 = 设备_摄像头
    设备.宽度 = 宽
    设备.高度 = 高
    设备.帧率 = 帧率
    设备.格式 = 格式_三通道
    设备.缓冲大小 = 宽 * 高 * 3
    设备.缓冲地址 = 堆_分配(设备.缓冲大小)
    设备.活跃 = 假
    设备.捕获帧数 = 0
    设备.最近捕获 = 0
    追加(设备表, 设备)
    定义 索引 = 设备数
    设备数 = 设备数 + 1
    返回 索引
}

函数 视觉_捕获帧(设备索引) {
    如果 (设备索引 >= 设备数) { 返回 0 }
    定义 设备 = 设备表[设备索引]
    如果 (!设备.活跃 && 设备.类型 != 设备_帧缓冲) { 返回 0 }
    定义 帧大小 = 设备.宽度 * 设备.高度 * 4
    定义 帧缓冲 = 堆_分配(帧大小)
    如果 (帧缓冲 == 0) { 返回 0 }
    如果 (设备.类型 == 设备_帧缓冲) {
        定义 源 = 帧缓冲_获取绘制目标()
        内存_复制(帧缓冲, 源, 帧大小)
    } 否则 如果 (设备.类型 == 设备_摄像头 && 设备.缓冲地址 != 0) {
        视觉_转换格式(设备.缓冲地址, 帧缓冲, 设备.宽度, 设备.高度, 设备.格式, 格式_四通道)
    }
    设备.捕获帧数 = 设备.捕获帧数 + 1
    设备.最近捕获 = 平台_获取高精度时间()
    总捕获帧 = 总捕获帧 + 1
    返回 帧缓冲
}

函数 视觉_转换格式(源, 目标, 宽, 高, 源格式, 目标格式) {
    定义 像素数 = 宽 * 高
    如果 (源格式 == 格式_三通道 && 目标格式 == 格式_四通道) {
        定义 可变 序号 = 0
        当 (序号 < 像素数) {
            定义 红 = 内存_读8(源 + 序号 * 3)
            定义 绿 = 内存_读8(源 + 序号 * 3 + 1)
            定义 蓝 = 内存_读8(源 + 序号 * 3 + 2)
            内存_写32(目标 + 序号 * 4, (255 << 24) | (红 << 16) | (绿 << 8) | 蓝)
            序号 = 序号 + 1
        }
    } 否则 如果 (源格式 == 格式_灰度 && 目标格式 == 格式_四通道) {
        定义 可变 序号 = 0
        当 (序号 < 像素数) {
            定义 灰 = 内存_读8(源 + 序号)
            内存_写32(目标 + 序号 * 4, (255 << 24) | (灰 << 16) | (灰 << 8) | 灰)
            序号 = 序号 + 1
        }
    }
}

函数 视觉_缩放帧(源, 源宽, 源高, 目标, 目标宽, 目标高) {
    定义 横比 = 源宽 * 1024 / 目标宽
    定义 纵比 = 源高 * 1024 / 目标高
    定义 可变 纵 = 0
    当 (纵 < 目标高) {
        定义 源纵 = 纵 * 纵比 / 1024
        如果 (源纵 >= 源高) { 源纵 = 源高 - 1 }
        定义 可变 横 = 0
        当 (横 < 目标宽) {
            定义 源横 = 横 * 横比 / 1024
            如果 (源横 >= 源宽) { 源横 = 源宽 - 1 }
            定义 像素 = 内存_读32(源 + (源纵 * 源宽 + 源横) * 4)
            内存_写32(目标 + (纵 * 目标宽 + 横) * 4, 像素)
            横 = 横 + 1
        }
        纵 = 纵 + 1
    }
}

函数 视觉_灰度化(源, 目标, 宽, 高) {
    定义 像素数 = 宽 * 高
    定义 可变 序号 = 0
    当 (序号 < 像素数) {
        定义 像素 = 内存_读32(源 + 序号 * 4)
        定义 红 = (像素 >> 16) & 0xFF
        定义 绿 = (像素 >> 8) & 0xFF
        定义 蓝 = 像素 & 0xFF
        定义 灰 = (红 * 77 + 绿 * 150 + 蓝 * 29) >> 8
        内存_写8(目标 + 序号, 灰)
        序号 = 序号 + 1
    }
}

函数 视觉_边缘检测(灰度, 输出, 宽, 高) {
    定义 可变 纵 = 1
    当 (纵 < 高 - 1) {
        定义 可变 横 = 1
        当 (横 < 宽 - 1) {
            定义 梯度横 = 内存_读8(灰度 + (纵 * 宽 + 横 + 1)) - 内存_读8(灰度 + (纵 * 宽 + 横 - 1))
            定义 梯度纵 = 内存_读8(灰度 + ((纵 + 1) * 宽 + 横)) - 内存_读8(灰度 + ((纵 - 1) * 宽 + 横))
            如果 (梯度横 < 0) { 梯度横 = 0 - 梯度横 }
            如果 (梯度纵 < 0) { 梯度纵 = 0 - 梯度纵 }
            定义 强度 = 梯度横 + 梯度纵
            如果 (强度 > 255) { 强度 = 255 }
            内存_写8(输出 + 纵 * 宽 + 横, 强度)
            横 = 横 + 1
        }
        纵 = 纵 + 1
    }
}

函数 视觉_启动设备(索引) {
    如果 (索引 >= 设备数) { 返回 }
    设备表[索引].活跃 = 真
}

函数 视觉_停止设备(索引) {
    如果 (索引 >= 设备数) { 返回 }
    设备表[索引].活跃 = 假
}

函数 视觉_获取分辨率(索引) {
    如果 (索引 >= 设备数) { 返回 [0, 0] }
    返回 [设备表[索引].宽度, 设备表[索引].高度]
}

函数 视觉_获取帧率(索引) {
    如果 (索引 >= 设备数) { 返回 0 }
    返回 设备表[索引].帧率
}

函数 视觉_完整统计() {
    返回 [设备数, 总捕获帧]
}

定义 可变 AI_设备接口_故障预警数 = 0

函数 AI_设备接口_设备健康(错误率, 响应时间, 温度) {
    定义 可变 分 = 1000
    如果 (错误率 > 10) { 分 = 分 - 错误率 * 5 }
    如果 (响应时间 > 1000) { 分 = 分 - 200 }
    如果 (温度 > 80) { 分 = 分 - 300 }
    如果 (分 < 300) { AI_设备接口_故障预警数 = AI_设备接口_故障预警数 + 1 }
    返回 分
}

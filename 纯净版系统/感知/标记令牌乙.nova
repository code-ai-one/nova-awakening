函数 HTML令牌izer_处理_DOCTYPE(tk, 令牌, c) {
    如果 (c == 0x09 || c == 0x0A || c == 0x0C || c == 0x20) {
        tk.状态 = 状态_DOCTYPE前
    }
    否则 如果 (c == 0x3E) {
        令牌.强制怪异模式 = 真
        令牌.类型 = 令牌类型_DOCTYPE
        tk.状态 = 状态_数据
    }
    否则 {
        tk.位置 = tk.位置 - 1
        tk.状态 = 状态_DOCTYPE前
    }
}

函数 HTML令牌izer_处理_DOCTYPE前(tk, 令牌, c) {
    如果 (c == 0x09 || c == 0x0A || c == 0x0C || c == 0x20) { 返回 }
    如果 (c == 0x3E) {
        令牌.强制怪异模式 = 真
        令牌.类型 = 令牌类型_DOCTYPE
        tk.状态 = 状态_数据
        返回
    }
    // 开始DOCTYPE名称
    令牌.DOCTYPE名称 = 堆_分配_数组(64)
    内存_写8(令牌.DOCTYPE名称, HTML令牌izer_转小写(c))
    令牌.标签名长度 = 1
    tk.状态 = 状态_DOCTYPE名称
}

函数 HTML令牌izer_处理_DOCTYPE名称(tk, 令牌, c) {
    如果 (c == 0x09 || c == 0x0A || c == 0x0C || c == 0x20) {
        tk.状态 = 状态_DOCTYPE名称后
    }
    否则 如果 (c == 0x3E) {     // '>'
        令牌.类型 = 令牌类型_DOCTYPE
        tk.状态 = 状态_数据
    }
    否则 {
        内存_写8(令牌.DOCTYPE名称 + 令牌.标签名长度, HTML令牌izer_转小写(c))
        令牌.标签名长度 = 令牌.标签名长度 + 1
    }
}

函数 HTML令牌izer_处理_RCDATA(tk, 令牌, c) {
    如果 (c == 0x3C) {          // '<'
        // 检查是否匹配结束标签
        如果 (HTML令牌izer_匹配RCDATA结束标签(tk)) {
            // 先发射积累的字符
            如果 (令牌.数据长度 > 0) {
                令牌.类型 = 令牌类型_字符
            }
            返回
        }
        HTML令牌izer_追加数据(令牌, c)
    }
    否则 如果 (c == 0x26) {     // '&'
        tk.返回状态 = 状态_RCDATA
        tk.状态 = 状态_字符引用
    }
    否则 {
        HTML令牌izer_追加数据(令牌, c)
    }
}

函数 HTML令牌izer_处理_RAWTEXT(tk, 令牌, c) {
    如果 (c == 0x3C) {
        如果 (HTML令牌izer_匹配RAWTEXT结束标签(tk)) {
            如果 (令牌.数据长度 > 0) {
                令牌.类型 = 令牌类型_字符
            }
            返回
        }
        HTML令牌izer_追加数据(令牌, c)
    }
    否则 {
        HTML令牌izer_追加数据(令牌, c)
    }
}

// §4 辅助函数

函数 HTML令牌izer_消费字符(tk) {
    如果 (tk.位置 >= tk.输入长度) { 返回 0 }
    定义 c = 内存_读8(tk.输入 + tk.位置)
    tk.位置 = tk.位置 + 1
    如果 (c == 0x0A) { tk.行号 = tk.行号 + 1; tk.列号 = 1 }
    否则 { tk.列号 = tk.列号 + 1 }
    返回 c
}

函数 HTML令牌izer_窥视字符(tk) {
    如果 (tk.位置 >= tk.输入长度) { 返回 0 }
    返回 内存_读8(tk.输入 + tk.位置)
}

函数 HTML令牌izer_是ASCII字母(c) {
    返回 (c >= 0x41 && c <= 0x5A) || (c >= 0x61 && c <= 0x7A)
}

函数 HTML令牌izer_转小写(c) {
    如果 (c >= 0x41 && c <= 0x5A) { 返回 c + 0x20 }
    返回 c
}

函数 HTML令牌izer_追加标签名(令牌, c) {
    内存_写8(令牌.标签名 + 令牌.标签名长度, c)
    令牌.标签名长度 = 令牌.标签名长度 + 1
}

函数 HTML令牌izer_完成标签名(令牌) {
    // 以0结尾
    内存_写8(令牌.标签名 + 令牌.标签名长度, 0)
}

函数 HTML令牌izer_追加数据(令牌, c) {
    内存_写8(令牌.数据 + 令牌.数据长度, c)
    令牌.数据长度 = 令牌.数据长度 + 1
}

函数 HTML令牌izer_追加属性名字符(tk, c) {
    内存_写8(tk.当前属性名 + tk.当前属性名长度, c)
    tk.当前属性名长度 = tk.当前属性名长度 + 1
}

函数 HTML令牌izer_追加属性值字符(tk, c) {
    内存_写8(tk.当前属性值 + tk.当前属性值长度, c)
    tk.当前属性值长度 = tk.当前属性值长度 + 1
}

函数 HTML令牌izer_提交属性(tk, 令牌) {
    // 将当前属性名/值写入令牌的属性列表
    如果 (tk.当前属性名长度 == 0) { 返回 }
    内存_写8(tk.当前属性名 + tk.当前属性名长度, 0)
    内存_写8(tk.当前属性值 + tk.当前属性值长度, 0)

    // 检查重复属性(HTML5规范: 第一个同名属性生效)
    定义 可变 i = 0
    当 (i < 令牌.属性数量) {
        定义 偏移 = 令牌.属性列表 + i * 40
        定义 已有名 = 内存_读64(偏移)
        如果 (字符串_相等(已有名, tk.当前属性名)) {
            返回    // 重复,忽略
        }
        i = i + 1
    }

    // 写入属性
    定义 偏移 = 令牌.属性列表 + 令牌.属性数量 * 40
    定义 名副本 = 字符串_复制_N(tk.当前属性名, tk.当前属性名长度)
    定义 值副本 = 字符串_复制_N(tk.当前属性值, tk.当前属性值长度)
    内存_写64(偏移, 名副本)
    内存_写32(偏移 + 8, tk.当前属性名长度)
    内存_写64(偏移 + 16, 值副本)
    内存_写32(偏移 + 24, tk.当前属性值长度)
    令牌.属性数量 = 令牌.属性数量 + 1
}

函数 HTML令牌izer_记录开始标签(tk, 令牌) {
    // 记录最后一个开始标签名(用于RCDATA/RAWTEXT匹配)
    内存_复制(tk.最后开始标签, 令牌.标签名, 令牌.标签名长度 + 1)
    tk.最后开始标签长度 = 令牌.标签名长度
}

函数 HTML令牌izer_匹配不区分大小写(tk, 目标) {
    // 从当前位置匹配字符串(不消费,不区分大小写)
    定义 目标长度 = 字符串_长度(目标)
    如果 (tk.位置 + 目标长度 > tk.输入长度) { 返回 0 }
    定义 可变 i = 0
    当 (i < 目标长度) {
        定义 a = HTML令牌izer_转小写(内存_读8(tk.输入 + tk.位置 + i))
        定义 b = HTML令牌izer_转小写(内存_读8(目标 + i))
        如果 (a != b) { 返回 0 }
        i = i + 1
    }
    // 匹配成功,消费这些字符
    tk.位置 = tk.位置 + 目标长度
    返回 1
}

函数 HTML令牌izer_匹配RCDATA结束标签(tk) {
    // 检查 </tagname> 是否匹配最后的开始标签
    如果 (tk.最后开始标签长度 == 0) { 返回 0 }
    定义 保存位置 = tk.位置
    如果 (HTML令牌izer_窥视字符(tk) != 0x2F) { 返回 0 }
    tk.位置 = tk.位置 + 1    // 跳过 '/'
    定义 可变 i = 0
    当 (i < tk.最后开始标签长度) {
        如果 (tk.位置 >= tk.输入长度) { tk.位置 = 保存位置; 返回 0 }
        定义 c = HTML令牌izer_转小写(内存_读8(tk.输入 + tk.位置))
        定义 期望 = 内存_读8(tk.最后开始标签 + i)
        如果 (c != 期望) { tk.位置 = 保存位置; 返回 0 }
        tk.位置 = tk.位置 + 1
        i = i + 1
    }
    // 检查标签名后是 > 或空白
    如果 (tk.位置 < tk.输入长度) {
        定义 后续 = 内存_读8(tk.输入 + tk.位置)
        如果 (后续 == 0x3E || 后续 == 0x20 || 后续 == 0x09 || 后续 == 0x0A) {
            // 发射结束标签令牌
            tk.状态 = 状态_数据
            // 跳过到 '>'
            当 (tk.位置 < tk.输入长度 && 内存_读8(tk.输入 + tk.位置) != 0x3E) {
                tk.位置 = tk.位置 + 1
            }
            如果 (tk.位置 < tk.输入长度) { tk.位置 = tk.位置 + 1 }
            返回 1
        }
    }
    tk.位置 = 保存位置
    返回 0
}

定义 可变 AI_标记令牌乙_调用数 = 0
定义 可变 AI_标记令牌乙_异常数 = 0

函数 AI_标记令牌乙_监控() {
    AI_标记令牌乙_调用数 = AI_标记令牌乙_调用数 + 1
    返回 AI_标记令牌乙_异常数 == 0
}

函数 AI_标记令牌乙_健康检查() {
    如果 (AI_标记令牌乙_调用数 > 0 && AI_标记令牌乙_异常数 * 100 / AI_标记令牌乙_调用数 > 10) {
        返回 假
    }
    返回 真
}

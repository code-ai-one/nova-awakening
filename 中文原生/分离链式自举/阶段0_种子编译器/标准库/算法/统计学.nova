导入("../基础.nova")
导入("../数学/统计.nova")
导入("./数学扩展.nova")

//    土行特性: 承载万物, 稳定不变
//    中位数 = 土之中轴 (最稳定的中心位置)
//    正态分布 = 土之本形 (自然界的稳定分布)
//    统计函数: 批→个 的聚合态射

// 均值
函数 统计学_统计_均值(数据) {
    如果 (计数(数据) == 0) { 返回 0 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(数据)) { 总 = 总 + 数据[i] i = i + 1 }
    返回 总 / 计数(数据)
}

// 中位数 (需要先排序)
函数 统计学_统计_中位数(数据) {
    定义 n = 计数(数据)
    如果 (n == 0) { 返回 0 }
    // 复制并排序
    定义 可变 排序 = []
    定义 可变 i = 0
    当 (i < n) { 追加(排序, 数据[i]) i = i + 1 }
    // 冒泡排序
    定义 可变 已改变 = 1
    当 (已改变 == 1) {
        已改变 = 0
        i = 0
        当 (i < n - 1) {
            如果 (排序[i] > 排序[i + 1]) {
                定义 临时 = 排序[i]
                排序[i] = 排序[i + 1]
                排序[i + 1] = 临时
                已改变 = 1
            }
            i = i + 1
        }
    }
    如果 (n % 2 == 1) { 返回 排序[n / 2] }
    返回 (排序[n / 2 - 1] + 排序[n / 2]) / 2
}

// 众数 (出现最多的值)
函数 统计学_统计_众数(数据) {
    定义 可变 最多次 = 0
    定义 n = 计数(数据)
    如果 (n == 0) { 返回 0 }
    定义 可变 最多值 = 数据[0]
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 次数 = 0
        定义 可变 j = 0
        当 (j < n) {
            如果 (数据[j] == 数据[i]) { 次数 = 次数 + 1 }
            j = j + 1
        }
        如果 (次数 > 最多次) {
            最多次 = 次数
            最多值 = 数据[i]
        }
        i = i + 1
    }
    返回 最多值
}

// 方差
函数 统计学_统计_方差(数据) {
    定义 n = 计数(数据)
    如果 (n <= 1) { 返回 0 }
    定义 均值 = 统计_均值(数据)
    定义 可变 总差方 = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 差 = 数据[i] - 均值
        总差方 = 总差方 + 差 * 差
        i = i + 1
    }
    返回 总差方 / n
}

// 标准差 (整数近似)
函数 统计学_统计_标准差(数据) {
    返回 整数sqrt(统计_方差(数据))
}

// 范围
函数 统计学_统计_范围(数据) {
    如果 (计数(数据) == 0) { 返回 0 }
    定义 可变 最小 = 数据[0]
    定义 可变 最大 = 数据[0]
    定义 可变 i = 1
    当 (i < 计数(数据)) {
        如果 (数据[i] < 最小) { 最小 = 数据[i] }
        如果 (数据[i] > 最大) { 最大 = 数据[i] }
        i = i + 1
    }
    返回 最大 - 最小
}

// 协方差
函数 统计学_统计_协方差(x, y) {
    定义 n = 计数(x)
    如果 (n == 0 或 计数(y) != n) { 返回 0 }
    定义 均x = 统计_均值(x)
    定义 均y = 统计_均值(y)
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < n) {
        总 = 总 + (x[i] - 均x) * (y[i] - 均y)
        i = i + 1
    }
    返回 总 / n
}

// 线性回归 (回 [斜率, 截距])
函数 统计学_统计_线性回归(x, y) {
    定义 n = 计数(x)
    如果 (n == 0) { 返回 [0, 0] }
    定义 均x = 统计_均值(x)
    定义 均y = 统计_均值(y)
    定义 可变 分子 = 0
    定义 可变 分母 = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 导数 = x[i] - 均x
        分子 = 分子 + 导数 * (y[i] - 均y)
        分母 = 分母 + 导数 * 导数
        i = i + 1
    }
    如果 (分母 == 0) { 返回 [0, 均y] }
    定义 斜率 = 分子 / 分母
    定义 截距 = 均y - 斜率 * 均x
    返回 [斜率, 截距]
}

// 直方图 (将数据分桶, 0)
函数 统计学_统计_直方图(数据, 桶数) {
    如果 (计数(数据) == 0 或 桶数 <= 0) { 返回 [] }
    定义 可变 最小 = 数据[0]
    定义 可变 最大 = 数据[0]
    定义 可变 i = 1
    当 (i < 计数(数据)) {
        如果 (数据[i] < 最小) { 最小 = 数据[i] }
        如果 (数据[i] > 最大) { 最大 = 数据[i] }
        i = i + 1
    }
    定义 可变 范围 = 最大 - 最小 + 1
    定义 可变 桶宽 = 范围 / 桶数
    如果 (桶宽 <= 0) { 桶宽 = 1 }
    定义 可变 桶 = []
    i = 0
    当 (i < 桶数) { 追加(桶, 0) i = i + 1 }
    i = 0
    当 (i < 计数(数据)) {
        定义 可变 桶idx = (数据[i] - 最小) / 桶宽
        如果 (桶idx >= 桶数) { 桶idx = 桶数 - 1 }
        桶[桶idx] = 桶[桶idx] + 1
        i = i + 1
    }
    返回 桶
}

// 归一化 (0-100范围)
函数 统计_归一化(数据) {
    如果 (计数(数据) == 0) { 返回 [] }
    定义 可变 最小 = 数据[0]
    定义 可变 最大 = 数据[0]
    定义 可变 i = 1
    当 (i < 计数(数据)) {
        如果 (数据[i] < 最小) { 最小 = 数据[i] }
        如果 (数据[i] > 最大) { 最大 = 数据[i] }
        i = i + 1
    }
    定义 可变 范围 = 最大 - 最小
    如果 (范围 == 0) { 范围 = 1 }
    定义 可变 结果 = []
    i = 0
    当 (i < 计数(数据)) {
        追加(结果, (数据[i] - 最小) * 100 / 范围)
        i = i + 1
    }
    返回 结果
}

// 皮尔逊相关系数（×1000精度）
// r = Σ(xi-x̄)(yi-ȳ) / √(Σ(xi-x̄)² × Σ(yi-ȳ)²)
函数 统计_皮尔逊(x, y) {
    定义 可变 n = 计数(x)
    如果 (计数(y) < n) { n = 计数(y) }
    如果 (n < 2) { 返回 0 }
    定义 可变 均x = 0
    定义 可变 均y = 0
    定义 可变 i = 0
    当 (i < n) { 均x = 均x + x[i]  均y = 均y + y[i]  i = i + 1 }
    均x = 均x / n
    均y = 均y / n
    定义 可变 cov_sum = 0
    定义 可变 sx2 = 0
    定义 可变 sy2 = 0
    i = 0
    当 (i < n) {
        定义 导数 = x[i] - 均x
        定义 导数Y = y[i] - 均y
        cov_sum = cov_sum + 导数 * 导数Y
        sx2 = sx2 + 导数 * 导数
        sy2 = sy2 + 导数Y * 导数Y
        i = i + 1
    }
    定义 denom = 整数sqrt(sx2 * sy2)
    如果 (denom == 0) { 返回 0 }
    返回 cov_sum * 1000 / denom
}

// 分位数
函数 统计_分位数(数据, 百分位) {
    定义 n = 计数(数据)
    如果 (n == 0) { 返回 0 }
    定义 可变 副本 = []
    定义 可变 i = 0
    当 (i < n) { 追加(副本, 数据[i]) i = i + 1 }
    i = 0
    当 (i < n) {
        定义 可变 最小idx = i
        定义 可变 j = i + 1
        当 (j < n) { 如果 (副本[j] < 副本[最小idx]) { 最小idx = j } j = j + 1 }
        定义 暂 = 副本[i]
        副本[i] = 副本[最小idx]
        副本[最小idx] = 暂
        i = i + 1
    }
    定义 索引 = 百分位 * (n - 1) / 100
    返回 副本[索引]
}

// 移动平均
函数 统计学_统计_移动平均(数据, 窗口) {
    定义 n = 计数(数据)
    如果 (n < 窗口) { 返回 [] }
    定义 可变 结果 = []
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < 窗口) { 和 = 和 + 数据[i] i = i + 1 }
    追加(结果, 和 / 窗口)
    i = 窗口
    当 (i < n) {
        和 = 和 + 数据[i] - 数据[i - 窗口]
        追加(结果, 和 / 窗口)
        i = i + 1
    }
    返回 结果
}

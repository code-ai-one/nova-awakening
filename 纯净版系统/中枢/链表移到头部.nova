
导入("./类型定义.nova")
导入("./错误码.nova")
导入("./列表加头加尾.nova")
导入("./链表后继.nova")
导入("./字符串替换.nova")

函数 链表_移到头部(头, 节点) {
    链表_删除(节点)
    链表_插入之间(节点, 头, 头[链_后继])
}

函数 链表_移到尾部(头, 节点) {
    链表_删除(节点)
    链表_插入之间(节点, 头[链_前驱], 头)
}

函数 链表_拼接(目标头, 源头) {
    如果 (链表_为空(源头)) { 返回 }
    定义 源首 = 源头[链_后继]
    定义 源末 = 源头[链_前驱]
    定义 目标首 = 目标头[链_后继]
    设置(目标头, 链_后继, 源首)
    设置(源首, 链_前驱, 目标头)
    设置(源末, 链_后继, 目标首)
    设置(目标首, 链_前驱, 源末)
    设置(源头, 链_前驱, 源头)
    设置(源头, 链_后继, 源头)
}

// §3 查找

函数 链表_查找(头, 判断函数) {
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        如果 (判断函数(当前[链_数据])) { 返回 当前 }
        当前 = 当前[链_后继]
    }
    返回 空
}

函数 链表_查找数据(头, 目标) {
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        如果 (当前[链_数据] == 目标) { 返回 当前 }
        当前 = 当前[链_后继]
    }
    返回 空
}

函数 链表_包含(头, 目标) {
    返回 链表_查找数据(头, 目标) != 空
}

// §4 安全遍历(遍历中可删除,
// Nova内核最常用的模式: 遍历链表时删除节点

函数 链表_安全遍历(头, 回调) {
    // 遍历中可安全删除当前节点
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        定义 下一个 = 当前[链_后继]  // 先保存下一个(防止删除后丢失)
        回调(当前)
        当前 = 下一个
    }
}

函数 链表_过滤删除(头, 应该删除函数) {
    // 删除所有满足条件的节点
    定义 可变 删除数 = 0
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        定义 下一个 = 当前[链_后继]
        如果 (应该删除函数(当前[链_数据])) {
            链表_删除(当前)
            删除数 = 删除数 + 1
        }
        当前 = 下一个
    }
    返回 删除数
}

// §5 排序插入(保持链表有序)
// 用于: 定时器链表(按到期时间)、优先级队列

函数 链表_有序插入(头, 数据, 比较函数) {
    定义 新节点 = [空, 空, 数据]
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        如果 (比较函数(数据, 当前[链_数据]) < 0) {
            链表_插入之间(新节点, 当前[链_前驱], 当前)
            返回 新节点
        }
        当前 = 当前[链_后继]
    }
    链表_插入之间(新节点, 头[链_前驱], 头)
    返回 新节点
}

// §6 链表反转

函数 链表_反转(头) {
    // 双向循环链表原地反转: 交换每个节点的前驱/后继
    定义 可变 当前 = 头
    定义 可变 已处理 = 假
    当 (当前 != 头 || 已处理 == 假) {
        已处理 = 真
        定义 临时 = 当前[链_后继]
        设置(当前, 链_后继, 当前[链_前驱])
        设置(当前, 链_前驱, 临时)
        当前 = 临时  // 原后继现在是前驱方向
    }
}

// §7 环检测 — Floyd快慢指针

函数 链表_环检测(头) {
    // 返回: 环入口节点, 或空(无环)
    如果 (链表_为空(头)) { 返回 空 }
    定义 可变 慢 = 头[链_后继]
    定义 可变 快 = 头[链_后继]
    // 第一阶段: 快慢相遇
    当 (快 != 头 && 快[链_后继] != 头) {
        慢 = 慢[链_后继]
        快 = 快[链_后继]
        快 = 快[链_后继]
        如果 (慢 == 快) {
            // 第二阶段: 找入口
            定义 可变 入口 = 头[链_后继]
            当 (入口 != 慢) {
                入口 = 入口[链_后继]
                慢 = 慢[链_后继]
            }
            返回 入口
        }
    }
    返回 空
}

// §8 归并排序(链表原地排序)
// 自底向上, O(n log n), 不需额外空间

函数 _链表_分割(节点, 步长) {
    // 从节点开始走步长步, 返回分割点
    定义 可变 当前 = 节点
    定义 可变 i = 1
    当 (i < 步长 && 当前[链_后继] != 空) {
        当前 = 当前[链_后继]
        i = i + 1
    }
    定义 下半 = 当前[链_后继]
    设置(当前, 链_后继, 空)
    返回 下半
}

函数 _链表_合并(左, 右, 比较函数) {
    定义 哨兵 = [空, 空, 0]
    定义 可变 尾 = 哨兵
    当 (左 != 空 && 右 != 空) {
        如果 (比较函数(左[链_数据], 右[链_数据]) <= 0) {
            设置(尾, 链_后继, 左)
            设置(左, 链_前驱, 尾)
            左 = 左[链_后继]
        } 否则 {
            设置(尾, 链_后继, 右)
            设置(右, 链_前驱, 尾)
            右 = 右[链_后继]
        }
        尾 = 尾[链_后继]
    }
    如果 (左 != 空) { 设置(尾, 链_后继, 左); 设置(左, 链_前驱, 尾) }
    如果 (右 != 空) { 设置(尾, 链_后继, 右); 设置(右, 链_前驱, 尾) }
    返回 哨兵[链_后继]
}

函数 链表_归并排序(头, 比较函数) {
    如果 (链表_为空(头)) { 返回 }
    // 摘下所有节点形成单链
    定义 可变 首 = 头[链_后继]
    定义 可变 长度 = 0
    定义 可变 当前 = 首
    当 (当前 != 头) { 长度 = 长度 + 1; 当前 = 当前[链_后继] }
    // 断开循环
    设置(头[链_前驱], 链_后继, 空)
    // 自底向上归并
    定义 可变 步长 = 1
    当 (步长 < 长度) {
        定义 可变 剩余 = 首
        首 = 空
        定义 可变 尾 = 空
        当 (剩余 != 空) {
            定义 左 = 剩余
            定义 右 = _链表_分割(左, 步长)
            剩余 = _链表_分割(右, 步长)
            定义 合并结果 = _链表_合并(左, 右, 比较函数)
            如果 (首 == 空) { 首 = 合并结果 } 否则 { 设置(尾, 链_后继, 合并结果); 设置(合并结果, 链_前驱, 尾) }
            尾 = 合并结果
            当 (尾[链_后继] != 空) { 尾 = 尾[链_后继] }
        }
        步长 = 步长 * 2
    }
    // 重建循环双链表
    设置(头, 链_后继, 首)
    设置(首, 链_前驱, 头)
    当前 = 首
    当 (当前[链_后继] != 空) { 当前 = 当前[链_后继] }
    设置(当前, 链_后继, 头)
    设置(头, 链_前驱, 当前)
}

// §9 【原生颠覆性创新】惯性排序
// 原理: 利用链表已有的「局部有序段」(称为「惯性段」)
//   检测已有序子序列, 直接合并而不拆分
//   对接近有序数据达到 O(n), 最坏 O(n log n)
//   类似 TimSort 思想但针对链表原生实现

函数 链表_惯性排序(头, 比较函数) {
    如果 (链表_为空(头)) { 返回 }
    // 收集惯性段(已有序的连续子序列)
    定义 可变 段列表 = []
    定义 可变 段首 = 头[链_后继]
    当 (段首 != 头) {
        定义 可变 段尾 = 段首
        // 检测升序段
        当 (段尾[链_后继] != 头 && 比较函数(段尾[链_数据], 段尾[链_后继][链_数据]) <= 0) {
            段尾 = 段尾[链_后继]
        }
        定义 下段 = 段尾[链_后继]
        设置(段尾, 链_后继, 空)  // 断开
        追加(段列表, 段首)
        段首 = 下段
    }
    // 两两合并所有惯性段
    当 (计数(段列表) > 1) {
        定义 可变 新段列表 = []
        定义 可变 i = 0
        当 (i + 1 < 计数(段列表)) {
            追加(新段列表, _链表_合并(段列表[i], 段列表[i + 1], 比较函数))
            i = i + 2
        }
        如果 (i < 计数(段列表)) { 追加(新段列表, 段列表[i]) }
        段列表 = 新段列表
    }
    // 重建循环双链表
    定义 可变 首 = 段列表[0]
    设置(头, 链_后继, 首)
    设置(首, 链_前驱, 头)
    定义 可变 当前 = 首
    当 (当前[链_后继] != 空) { 当前 = 当前[链_后继] }
    设置(当前, 链_后继, 头)
    设置(头, 链_前驱, 当前)
}

定义 链_后继 = 1
定义 链_前驱 = 0
定义 链_数据 = 2
定义 AI局部窗口 = 16

结构 移动排序统计 {
    移到头次数: 整数,
    移到尾次数: 整数,
    拼接次数: 整数,
    查找次数: 整数,
    查找命中: 整数,
    安全遍历次数: 整数,
    过滤删除次数: 整数,
    过滤删除节点数: 整数,
    有序插入次数: 整数,
    反转次数: 整数,
    环检测次数: 整数,
    环检测命中: 整数,
    归并排序次数: 整数,
    惯性排序次数: 整数,
    惯性段平均长度: 整数,
    AI局部记录数: 整数,
    AI局部命中数: 整数,
    批量移动次数: 整数,
    错误次数: 整数,
}

定义 可变 全局统计 = 移动排序统计 {}
定义 可变 移动模块已初始化 = 假
定义 可变 AI局部历史 = []
定义 可变 AI局部位置 = 0


函数 链表移动_初始化() {
    如果 (移动模块已初始化 == 真) { 返回 0 - 17 }
    AI局部历史 = []
    定义 可变 i = 0
    当 (i < AI局部窗口) {
        追加(AI局部历史, 0)
        i = i + 1
    }
    AI局部位置 = 0
    移动模块已初始化 = 真
    打印("[链表移动] 初始化完成")
    返回 0
}

函数 链表移动_销毁() {
    如果 (移动模块已初始化 == 假) { 返回 0 }
    AI局部历史 = []
    移动模块已初始化 = 假
    打印("[链表移动] 已销毁")
    返回 0
}


函数 链表_安全移到头部(头, 节点) {
    如果 (头 == 空 || 节点 == 空) {
        全局统计.错误次数 = 全局统计.错误次数 + 1
        返回
    }
    全局统计.移到头次数 = 全局统计.移到头次数 + 1
    链表_移到头部(头, 节点)
    AI_记录局部(节点[链_数据])
}

函数 链表_安全移到尾部(头, 节点) {
    如果 (头 == 空 || 节点 == 空) {
        全局统计.错误次数 = 全局统计.错误次数 + 1
        返回
    }
    全局统计.移到尾次数 = 全局统计.移到尾次数 + 1
    链表_移到尾部(头, 节点)
}


函数 链表_批量移到头(头, 节点列表) {
    如果 (头 == 空 || 节点列表 == 空) { 返回 0 }
    全局统计.批量移动次数 = 全局统计.批量移动次数 + 1
    定义 可变 已移动 = 0
    定义 可变 i = 0
    当 (i < 计数(节点列表)) {
        如果 (节点列表[i] != 空) {
            链表_移到头部(头, 节点列表[i])
            已移动 = 已移动 + 1
        }
        i = i + 1
    }
    返回 已移动
}

函数 链表_条件移到头(头, 条件函数) {
    // 将所有满足条件的节点移到头部
    如果 (头 == 空 || 条件函数 == 空) { 返回 0 }
    定义 可变 已移动 = 0
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        定义 下一个 = 当前[链_后继]
        如果 (条件函数(当前[链_数据]) == 真) {
            链表_移到头部(头, 当前)
            已移动 = 已移动 + 1
        }
        当前 = 下一个
    }
    返回 已移动
}


函数 链表_安全查找(头, 判断函数) {
    如果 (头 == 空 || 判断函数 == 空) { 返回 空 }
    全局统计.查找次数 = 全局统计.查找次数 + 1
    定义 结果 = 链表_查找(头, 判断函数)
    如果 (结果 != 空) {
        全局统计.查找命中 = 全局统计.查找命中 + 1
    }
    返回 结果
}


函数 链表_长度计算(头) {
    如果 (头 == 空) { 返回 0 }
    定义 可变 长度 = 0
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        长度 = 长度 + 1
        当前 = 当前[链_后继]
    }
    返回 长度
}

函数 链表_是否有序(头, 比较函数) {
    如果 (头 == 空 || 比较函数 == 空) { 返回 真 }
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头 && 当前[链_后继] != 头) {
        如果 (比较函数(当前[链_数据], 当前[链_后继][链_数据]) > 0) {
            返回 假
        }
        当前 = 当前[链_后继]
    }
    返回 真
}


函数 AI_记录局部(数据) {
    设置(AI局部历史, AI局部位置, 数据)
    AI局部位置 = (AI局部位置 + 1) % AI局部窗口
    全局统计.AI局部记录数 = 全局统计.AI局部记录数 + 1
}

函数 AI_预测下次移动目标() {
    定义 可变 最频数据 = 0
    定义 可变 最频次 = 0
    定义 可变 i = 0
    当 (i < AI局部窗口) {
        如果 (AI局部历史[i] == 0) { i = i + 1  继续 }
        定义 当前 = AI局部历史[i]
        定义 可变 频 = 0
        定义 可变 j = 0
        当 (j < AI局部窗口) {
            如果 (AI局部历史[j] == 当前) { 频 = 频 + 1 }
            j = j + 1
        }
        如果 (频 > 最频次) { 最频次 = 频  最频数据 = 当前 }
        i = i + 1
    }
    如果 (最频次 > AI局部窗口 / 3) {
        全局统计.AI局部命中数 = 全局统计.AI局部命中数 + 1
    }
    返回 最频数据
}

函数 AI_建议预取节点(头) {
    定义 热数据 = AI_预测下次移动目标()
    如果 (热数据 == 0) { 返回 空 }
    返回 链表_查找数据(头, 热数据)
}


函数 链表移动_转储(头) {
    打印("[链表移动] ═══ 状态转储 ═══")
    如果 (头 == 空) {
        打印("  空链表")
        返回 0
    }
    打印(字符串拼接("  长度: ", 转字符串(链表_长度计算(头))))
    如果 (头[链_后继] != 头) {
        打印(字符串拼接("  首元素: ", 转字符串(头[链_后继][链_数据])))
    }
    如果 (头[链_前驱] != 头) {
        打印(字符串拼接("  末元素: ", 转字符串(头[链_前驱][链_数据])))
    }
    返回 0
}


函数 链表移动_打印统计() {
    打印("[链表移动] ═══ 运行统计 ═══")
    打印(字符串拼接("  移到头: ", 转字符串(全局统计.移到头次数)))
    打印(字符串拼接("  移到尾: ", 转字符串(全局统计.移到尾次数)))
    打印(字符串拼接("  拼接: ", 转字符串(全局统计.拼接次数)))
    打印(字符串拼接("  查找次数: ", 转字符串(全局统计.查找次数)))
    打印(字符串拼接("  查找命中: ", 转字符串(全局统计.查找命中)))
    打印(字符串拼接("  安全遍历: ", 转字符串(全局统计.安全遍历次数)))
    打印(字符串拼接("  过滤删除: ", 转字符串(全局统计.过滤删除次数)))
    打印(字符串拼接("  删除节点: ", 转字符串(全局统计.过滤删除节点数)))
    打印(字符串拼接("  有序插入: ", 转字符串(全局统计.有序插入次数)))
    打印(字符串拼接("  反转: ", 转字符串(全局统计.反转次数)))
    打印(字符串拼接("  环检测: ", 转字符串(全局统计.环检测次数)))
    打印(字符串拼接("  归并排序: ", 转字符串(全局统计.归并排序次数)))
    打印(字符串拼接("  惯性排序: ", 转字符串(全局统计.惯性排序次数)))
    打印(字符串拼接("  批量移动: ", 转字符串(全局统计.批量移动次数)))
    打印(字符串拼接("  AI局部记录: ", 转字符串(全局统计.AI局部记录数)))
    打印(字符串拼接("  AI局部命中: ", 转字符串(全局统计.AI局部命中数)))
    打印(字符串拼接("  错误次数: ", 转字符串(全局统计.错误次数)))
    返回 0
}


函数 链表移动_注册到内核(内核上下文) {
    如果 (移动模块已初始化 == 假) { 返回 0 - 1 }
    打印("[链表移动] 已注册到内核上下文")
    返回 0
}

函数 链表移动_查询状态() {
    如果 (移动模块已初始化 == 假) { 返回 0 }
    返回 1
}

函数 链表移动_健康检查() {
    如果 (移动模块已初始化 == 假) { 返回 假 }
    如果 (全局统计.错误次数 * 10 > 全局统计.移到头次数 + 全局统计.查找次数) {
        返回 假
    }
    返回 真
}

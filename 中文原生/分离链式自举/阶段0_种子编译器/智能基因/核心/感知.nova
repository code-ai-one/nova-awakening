// Nova 原生 · 智能基因层 · 感知与注意力原语
// 设计理念：仿生人脑的注意力机制 — 什么重要，聚焦到哪里
// 注意力是智能的核心：决定哪些信息被处理、被记忆、被加权

// 注意力权重区间

导入("../../标准库/基础.nova")

定义 注意力_忽略   = 0      // 完全忽略
定义 注意力_背景   = 200    // 背景信息
定义 注意力_一般   = 500    // 正常关注
定义 注意力_重要   = 800    // 重要信息
定义 注意力_关键   = 1000   // 关键信息，必须处理

// 感知维度
定义 感知_视觉     = 1      // 视觉信息（图像、空间）
定义 感知_听觉     = 2      // 听觉信息（声音、语言）
定义 感知_语义     = 3      // 语义信息（文字、概念）
定义 感知_情感     = 4      // 情感信息（情绪状态）
定义 感知_时序     = 5      // 时间序列信息
定义 感知_关系     = 6      // 关系结构信息

// 注意力单元：[对象标识, 权重, 维度, 时间戳, 衰减率]
函数 感知_创建注意力(对象, 权重, 维度) {
    返回 [对象, 权重, 维度, 0, 10]
}

函数 感知_注意对象(单元)   { 返回 单元[0] }
函数 感知_注意权重(单元)   { 返回 单元[1] }
函数 感知_注意维度(单元)   { 返回 单元[2] }
函数 感知_注意时间(单元)   { 返回 单元[3] }
函数 感知_注意衰减(单元)   { 返回 单元[4] }

// 注意力场：管理一批注意力单元
函数 感知_创建注意力场(容量) {
    返回 [[], 容量, 0]
}

函数 感知_场_追加(场, 单元) {
    如果 (计数(场[0]) >= 场[1]) {
        感知_场_清理低权重(场)
    }
    追加(场[0], 单元)
    场[2] = 场[2] + 1
}

函数 感知_场_清理低权重(场) {
    定义 可变 新列表 = []
    定义 可变 i = 0
    当 (i < 计数(场[0])) {
        如果 (感知_注意权重(场[0][i]) > 注意力_背景) {
            追加(新列表, 场[0][i])
        }
        i = i + 1
    }
    场[0] = 新列表
}

函数 感知_场_最高注意(场) {
    定义 可变 最大索引 = 0
    如果 (计数(场[0]) == 0) { 返回 空 }
    定义 可变 最大权重 = 0
    定义 可变 i = 0
    当 (i < 计数(场[0])) {
        如果 (感知_注意权重(场[0][i]) > 最大权重) {
            最大权重 = 感知_注意权重(场[0][i])
            最大索引 = i
        }
        i = i + 1
    }
    返回 场[0][最大索引]
}

函数 感知_场_按维度筛选(场, 维度) {
    定义 可变 结果列表 = []
    定义 可变 i = 0
    当 (i < 计数(场[0])) {
        如果 (感知_注意维度(场[0][i]) == 维度) {
            追加(结果列表, 场[0][i])
        }
        i = i + 1
    }
    返回 结果列表
}

// 权重衰减：随时间降低不活跃注意力的权重
函数 感知_衰减注意力(场, 步长) {
    定义 可变 i = 0
    当 (i < 计数(场[0])) {
        定义 单元 = 场[0][i]
        定义 新权重 = 感知_注意权重(单元) - 感知_注意衰减(单元) * 步长
        如果 (新权重 < 0) { 新权重 = 0 }
        单元[1] = 新权重
        i = i + 1
    }
}

// 感知流：连续输入的信息流处理
函数 感知_处理输入(场, 输入内容, 维度, 初始权重) {
    定义 单元 = 感知_创建注意力(输入内容, 初始权重, 维度)
    感知_场_追加(场, 单元)
    返回 单元
}

// 显著性检测：找出异常/新颖/重要的信息
函数 感知_计算显著性(新信息, 已有列表, 维度) {
    定义 可变 相似数 = 0
    定义 可变 i = 0
    当 (i < 计数(已有列表)) {
        如果 (感知_注意维度(已有列表[i]) == 维度) {
            如果 (感知_注意对象(已有列表[i]) == 新信息) {
                相似数 = 相似数 + 1
            }
        }
        i = i + 1
    }
    如果 (相似数 == 0) { 返回 注意力_关键 }
    如果 (相似数 < 3) { 返回 注意力_重要 }
    如果 (相似数 < 10) { 返回 注意力_一般 }
    返回 注意力_背景
}

// 多头注意力：同时从多个维度关注
函数 感知_多头关注(场列表, 输入, 权重列表) {
    如果 (计数(场列表) != 计数(权重列表)) { 返回 [] }
    定义 可变 结果列表 = []
    定义 可变 i = 0
    当 (i < 计数(场列表)) {
        定义 单元 = 感知_创建注意力(输入, 权重列表[i], i)
        感知_场_追加(场列表[i], 单元)
        追加(结果列表, 单元)
        i = i + 1
    }
    返回 结果列表
}

定义 可变 _感知_处理总数 = 0
定义 可变 _感知_显著性检测数 = 0
定义 可变 _感知_衰减次数 = 0

函数 感知_记录处理() { _感知_处理总数 = _感知_处理总数 + 1 }
函数 感知_记录显著() { _感知_显著性检测数 = _感知_显著性检测数 + 1 }

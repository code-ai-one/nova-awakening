结构 互斥锁 {
    已锁,
    持有者,
    等待数,
    获取次数,
    争用次数,
}

函数 锁_创建() {
    返回 互斥锁 { 已锁: 假, 持有者: 0, 等待数: 0, 获取次数: 0, 争用次数: 0 }
}

函数 锁_获取(锁) {
    定义 可变 自旋 = 0
    当 (锁.已锁 == 真) {
        锁.等待数 = 锁.等待数 + 1
        锁.争用次数 = 锁.争用次数 + 1
        自旋 = 自旋 + 1
        如果 (自旋 > 10000) {
            // 防止死锁: 超时退出
            返回
        }
    }
    锁.已锁 = 真
    锁.持有者 = 进程_获取PID()
    锁.等待数 = 0
    锁.获取次数 = 锁.获取次数 + 1
}

函数 锁_尝试获取(锁) {
    如果 (锁.已锁 == 真) { 返回 假 }
    锁.已锁 = 真
    锁.持有者 = 进程_获取PID()
    锁.获取次数 = 锁.获取次数 + 1
    返回 真
}

函数 锁_带超时获取(锁, 超时毫秒) {
    定义 开始 = 当前时间_毫秒()
    当 (锁.已锁 == 真) {
        如果 (当前时间_毫秒() - 开始 > 超时毫秒) { 返回 假 }
    }
    锁.已锁 = 真
    锁.持有者 = 进程_获取PID()
    锁.获取次数 = 锁.获取次数 + 1
    返回 真
}

函数 锁_释放(锁) {
    锁.已锁 = 假
    锁.持有者 = 0
}

函数 锁_已锁(锁) { 返回 锁.已锁 }
函数 锁_持有者(锁) { 返回 锁.持有者 }
函数 锁_统计(锁) { 返回 [锁.获取次数, 锁.争用次数] }

结构 递归锁 {
    已锁,
    持有者,
    重入计数,
}

函数 递归锁_创建() {
    返回 递归锁 { 已锁: 假, 持有者: 0, 重入计数: 0 }
}

函数 递归锁_获取(锁) {
    定义 当前PID = 进程_获取PID()
    如果 (锁.已锁 && 锁.持有者 == 当前PID) {
        锁.重入计数 = 锁.重入计数 + 1
        返回
    }
    当 (锁.已锁) { }
    锁.已锁 = 真
    锁.持有者 = 当前PID
    锁.重入计数 = 1
}

函数 递归锁_释放(锁) {
    定义 当前PID = 进程_获取PID()
    如果 (锁.持有者 != 当前PID) { 返回 }
    锁.重入计数 = 锁.重入计数 - 1
    如果 (锁.重入计数 == 0) {
        锁.已锁 = 假
        锁.持有者 = 0
    }
}

函数 递归锁_深度(锁) { 返回 锁.重入计数 }

结构 读写锁结构 {
    读者数,
    写锁,
    写等待数,
    读等待数,
    总读获取,
    总写获取,
}

函数 读写锁_创建() {
    返回 读写锁结构 { 读者数: 0, 写锁: 假, 写等待数: 0, 读等待数: 0, 总读获取: 0, 总写获取: 0 }
}

函数 读写锁_读锁(锁) {
    当 (锁.写锁 || 锁.写等待数 > 0) {
        锁.读等待数 = 锁.读等待数 + 1
    }
    锁.读者数 = 锁.读者数 + 1
    锁.读等待数 = 0
    锁.总读获取 = 锁.总读获取 + 1
}

函数 读写锁_尝试读锁(锁) {
    如果 (锁.写锁 || 锁.写等待数 > 0) { 返回 假 }
    锁.读者数 = 锁.读者数 + 1
    锁.总读获取 = 锁.总读获取 + 1
    返回 真
}

函数 读写锁_读解锁(锁) {
    如果 (锁.读者数 > 0) { 锁.读者数 = 锁.读者数 - 1 }
}

函数 读写锁_写锁(锁) {
    锁.写等待数 = 锁.写等待数 + 1
    当 (锁.读者数 > 0 || 锁.写锁) { }
    锁.写锁 = 真
    锁.写等待数 = 锁.写等待数 - 1
    锁.总写获取 = 锁.总写获取 + 1
}

函数 读写锁_尝试写锁(锁) {
    如果 (锁.读者数 > 0 || 锁.写锁) { 返回 假 }
    锁.写锁 = 真
    锁.总写获取 = 锁.总写获取 + 1
    返回 真
}

函数 读写锁_写解锁(锁) { 锁.写锁 = 假 }
函数 读写锁_读者数(锁) { 返回 锁.读者数 }
函数 读写锁_是写锁(锁) { 返回 锁.写锁 }
函数 读写锁_统计(锁) { 返回 [锁.总读获取, 锁.总写获取] }

结构 条件变量结构 {
    等待计数,
    通知计数,
}

函数 条件变量_创建() {
    返回 条件变量结构 { 等待计数: 0, 通知计数: 0 }
}

函数 条件变量_等待(条件, 锁) {
    条件.等待计数 = 条件.等待计数 + 1
    锁_释放(锁)
    当 (条件.等待计数 > 0 && 条件.通知计数 == 0) { }
    如果 (条件.通知计数 > 0) { 条件.通知计数 = 条件.通知计数 - 1 }
    锁_获取(锁)
}

函数 条件变量_带超时等待(条件, 锁, 超时毫秒) {
    条件.等待计数 = 条件.等待计数 + 1
    锁_释放(锁)
    定义 开始 = 当前时间_毫秒()
    当 (条件.等待计数 > 0 && 条件.通知计数 == 0) {
        如果 (当前时间_毫秒() - 开始 > 超时毫秒) {
            条件.等待计数 = 条件.等待计数 - 1
            锁_获取(锁)
            返回 假
        }
    }
    如果 (条件.通知计数 > 0) { 条件.通知计数 = 条件.通知计数 - 1 }
    锁_获取(锁)
    返回 真
}

函数 条件变量_通知一个(条件) {
    如果 (条件.等待计数 > 0) {
        条件.等待计数 = 条件.等待计数 - 1
        条件.通知计数 = 条件.通知计数 + 1
    }
}

函数 条件变量_通知全部(条件) {
    条件.通知计数 = 条件.通知计数 + 条件.等待计数
    条件.等待计数 = 0
}

结构 信号量结构 {
    值,
    最大值,
}

函数 信号量_创建(初始值) {
    返回 信号量结构 { 值: 初始值, 最大值: 2147483647 }
}

函数 有界信号量_创建(初始值, 最大值) {
    返回 信号量结构 { 值: 初始值, 最大值: 最大值 }
}

函数 信号量_等待(s) {
    当 (s.值 <= 0) { }
    s.值 = s.值 - 1
}

函数 信号量_尝试等待(s) {
    如果 (s.值 <= 0) { 返回 假 }
    s.值 = s.值 - 1
    返回 真
}

函数 信号量_带超时等待(s, 超时毫秒) {
    定义 开始 = 当前时间_毫秒()
    当 (s.值 <= 0) {
        如果 (当前时间_毫秒() - 开始 > 超时毫秒) { 返回 假 }
    }
    s.值 = s.值 - 1
    返回 真
}

函数 信号量_信号(s) {
    如果 (s.值 < s.最大值) {
        s.值 = s.值 + 1
    }
}

函数 信号量_值(s) { 返回 s.值 }

结构 锁守卫 {
    锁引用,
    已释放,
}

函数 锁守卫_创建(锁) {
    锁_获取(锁)
    返回 锁守卫 { 锁引用: 锁, 已释放: 假 }
}

函数 锁守卫_释放(守卫) {
    如果 (!守卫.已释放) {
        锁_释放(守卫.锁引用)
        守卫.已释放 = 真
    }
}

定义 可变 死锁_锁持有表 = 字典()

函数 死锁_注册获取(锁ID, 线程ID) {
    字典设(死锁_锁持有表, 转字符串(锁ID), 线程ID)
}

函数 死锁_注册释放(锁ID) {
    字典删(死锁_锁持有表, 转字符串(锁ID))
}

函数 死锁_检查(锁ID, 线程ID) {
    定义 持有者 = 字典取(死锁_锁持有表, 转字符串(锁ID))
    如果 (持有者 == 线程ID) { 返回 真 }
    返回 假
}

// 锁统计与诊断

定义 可变 锁_获取总数 = 0
定义 可变 锁_释放总数 = 0
定义 可变 锁_竞争次数 = 0
定义 可变 锁_自旋等待总 = 0

函数 锁_健康检查() {
    定义 可变 问题 = []
    定义 持有中 = 锁_获取总数 - 锁_释放总数
    如果 (持有中 > 100) {
        追加(问题, "锁泄漏: " + 整数转字符串(持有中) + "个未释放")
    }
    如果 (锁_竞争次数 > 锁_获取总数 / 2 && 锁_获取总数 > 100) {
        追加(问题, "锁竞争率过高")
    }
    如果 (计数(问题) == 0) { 返回 "锁系统健康" }
    返回 问题
}

函数 锁_健康评估() {
    返回 真
}

函数 锁_综合报告() {
    打印("[锁] ═══ 综合报告 ═══")
    打印("  锁_获取总数: " + 锁_获取总数)
    打印("  锁_释放总数: " + 锁_释放总数)
    打印("  锁_竞争次数: " + 锁_竞争次数)
    打印("  健康: " + 如果 (锁_健康评估()) { "正常" } 否则 { "异常" })
}

函数 锁_全局重置() {
    锁_获取总数 = 0
    锁_释放总数 = 0
    锁_竞争次数 = 0
    打印("[锁] 统计已重置")
    返回 0
}

定义 GL_TEXTURE_COMPARE_MODE = 0x884C
定义 GL_TEXTURE_COMPARE_FUNC = 0x884D
定义 GL_TEXTURE_MIN_FILTER = 0x2801
定义 GL_TEXTURE_MAG_FILTER = 0x2800
定义 GL_TEXTURE_WRAP_S = 0x2802
定义 GL_TEXTURE_WRAP_T = 0x2803
定义 GL_TEXTURE_WRAP_R = 0x8072
定义 GL_TEXTURE_MIN_LOD = 0x813A
定义 GL_TEXTURE_MAX_LOD = 0x813B

定义 GL_QUERY_RESULT = 0x8866
定义 GL_QUERY_RESULT_AVAILABLE = 0x8867
定义 GL_ANY_SAMPLES_PASSED = 0x8C2F
定义 GL_TRANSFORM_FEEDBACK_PRIMITIVES_WRITTEN = 0x8C88

定义 GL_SYNC_GPU_COMMANDS_COMPLETE = 0x9117
定义 GL_ALREADY_SIGNALED = 0x911A
定义 GL_CONDITION_SATISFIED = 0x911C
定义 GL_WAIT_FAILED = 0x911D

结构 GL资源跟踪 {
    纹理创建数,
    纹理删除数,
    缓冲创建数,
    缓冲删除数,
    着色器创建数,
    着色器删除数,
    帧缓冲创建数,
    帧缓冲删除数,
}

定义 可变 GL跟踪 = 0


函数 图绘2_uniform1ui(location, v0) { GL_uniform写入(location, v0, 0, 0, 0, 1) }
函数 图绘2_uniform2ui(location, v0, v1) { GL_uniform写入(location, v0, v1, 0, 0, 2) }
函数 图绘2_uniform3ui(location, v0, v1, v2) { GL_uniform写入(location, v0, v1, v2, 0, 3) }
函数 图绘2_uniform4ui(location, v0, v1, v2, v3) { GL_uniform写入(location, v0, v1, v2, v3, 4) }

函数 图绘2_uniform1uiv(location, data, count) {
    定义 可变 i = 0
    当 (i < count) {
        GL_uniform写入(location + i, data[i], 0, 0, 0, 1)
        i = i + 1
    }
}

函数 图绘2_uniform2uiv(location, data, count) {
    定义 可变 i = 0
    当 (i < count) {
        GL_uniform写入(location + i, data[i * 2], data[i * 2 + 1], 0, 0, 2)
        i = i + 1
    }
}

函数 图绘2_uniform3uiv(location, data, count) {
    定义 可变 i = 0
    当 (i < count) {
        GL_uniform写入(location + i, data[i * 3], data[i * 3 + 1], data[i * 3 + 2], 0, 3)
        i = i + 1
    }
}

函数 图绘2_uniform4uiv(location, data, count) {
    定义 可变 i = 0
    当 (i < count) {
        GL_uniform写入(location + i, data[i * 4], data[i * 4 + 1], data[i * 4 + 2], data[i * 4 + 3], 4)
        i = i + 1
    }
}

函数 图绘2_uniformMatrix2x3fv(location, transpose, value) { GL_uniformMatrix写入(location, 2, 3, transpose, value) }
函数 图绘2_uniformMatrix3x2fv(location, transpose, value) { GL_uniformMatrix写入(location, 3, 2, transpose, value) }
函数 图绘2_uniformMatrix2x4fv(location, transpose, value) { GL_uniformMatrix写入(location, 2, 4, transpose, value) }
函数 图绘2_uniformMatrix4x2fv(location, transpose, value) { GL_uniformMatrix写入(location, 4, 2, transpose, value) }
函数 图绘2_uniformMatrix3x4fv(location, transpose, value) { GL_uniformMatrix写入(location, 3, 4, transpose, value) }
函数 图绘2_uniformMatrix4x3fv(location, transpose, value) { GL_uniformMatrix写入(location, 4, 3, transpose, value) }

函数 图绘2_uniformBlockBinding(program, blockIndex, bindingPoint) {
    如果 (program == 0) { 返回 }
    GL_uniformBlock绑定(program, blockIndex, bindingPoint)
}


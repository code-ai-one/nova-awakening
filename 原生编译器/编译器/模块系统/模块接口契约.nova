导入("../../工具/包管理器/包管理器.nova")
导入("../../标准库/基础.nova")
// [循环导入已解耦] 导入("./模块图编译器.nova") — 函数由链接器全局解析
导入("../../运行时/列表引擎/列表引擎.nova")

// Nova 模块接口契约系统 — 保证单模块可热改不影响总体
// 核心原则:
//   1. 每个模块通过"接口契约"声明自己的输入/输出/依赖
//   2. 修改模块内部实现 → 只要接口不变 → 不影响其他模块
//   3. 新增模块 → 注册接口 → 自动融入编译管线
//   4. 删除模块 → 检查依赖图 → 安全提示哪些模块受影响

// 接口契约结构
结构 模块契约 {
    名称,           // 模块唯一名
    版本,           // 语义版本号 [主,次,补]
    导出函数,       // 对外公开的函数名列表
    导出类型,       // 对外公开的类型名列表
    依赖模块,       // 依赖的其他模块名列表
    兼容范围,       // 向后兼容的最低版本
}

定义 可变 契约注册表 = []
定义 可变 契约索引 = 字典()

// 注册模块契约
函数 契约_注册(名称, 版本, 导出函数, 导出类型, 依赖) {
    如果 (是列表(导出函数) == 假) { 导出函数 = [] }
    如果 (是列表(导出类型) == 假) { 导出类型 = [] }
    如果 (是列表(依赖) == 假) { 依赖 = [] }
    定义 契约 = 建 模块契约 {
        名称: 名称,
        版本: 版本,
        导出函数: 导出函数,
        导出类型: 导出类型,
        依赖模块: 依赖,
        兼容范围: [版本[0],],
    }
    追加(契约注册表, 契约)
    字典设(契约索引, 名称, 计数(契约注册表) - 1)
    返回 契约
}

函数 契约_查找(名称) {
    如果 (字典有(契约索引, 名称) == 假) { 返回 空 }
    返回 契约注册表[字典取(契约索引, 名称)]
}

// 检查修改影响范围
// 当修改一个模块时，精确报告哪些模块会受影响
函数 契约_影响分析(模块名) {
    定义 可变 受影响 = []
    定义 可变 i = 0
    当 (i < 计数(契约注册表)) {
        定义 契约 = 契约注册表[i]
        如果 (是列表(契约.依赖模块) == 假) { i = i + 1  继续 }
        定义 可变 j = 0
        当 (j < 计数(契约.依赖模块)) {
            如果 (字符串相等(契约.依赖模块[j], 模块名)) {
                追加(受影响, 契约.名称)
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 受影响
}

// 验证接口兼容性
// 修改后的模块是否仍然满足契约
函数 契约_验证兼容(模块名, 新导出函数, 新导出类型) {
    如果 (字典有(契约索引, 模块名) == 假) { 返回 真 }
    定义 位置 = 字典取(契约索引, 模块名)
    定义 旧契约 = 契约注册表[位置]
    如果 (是列表(新导出函数) == 假) { 新导出函数 = [] }
    如果 (是列表(新导出类型) == 假) { 新导出类型 = [] }
    如果 (是列表(旧契约.导出函数) == 假) { 返回 假 }
    如果 (是列表(旧契约.导出类型) == 假) { 返回 假 }

    // 检查: 旧的导出函数是否都还在
    定义 可变 i = 0
    当 (i < 计数(旧契约.导出函数)) {
        定义 旧函数 = 旧契约.导出函数[i]
        如果 (列表_查找(新导出函数, 旧函数) == -1) {
            打印("契约违反: 函数 " + 旧函数 + " 在 " + 模块名 + " 中被删除\n")
            返回 假
        }
        i = i + 1
    }

    // 检查: 旧的导出类型是否都还在
    i = 0
    当 (i < 计数(旧契约.导出类型)) {
        定义 旧类型 = 旧契约.导出类型[i]
        如果 (列表_查找(新导出类型, 旧类型) == -1) {
            打印("契约违反: 类型 " + 旧类型 + " 在 " + 模块名 + " 中被删除\n")
            返回 假
        }
        i = i + 1
    }

    // 新增的函数/类型不影响兼容性 → 向后兼容
    返回 真
}

// 安全删除检查
函数 契约_可安全删除(模块名) {
    定义 依赖者 = 契约_影响分析(模块名)
    如果 (计数(依赖者) == 0) {
        打印("模块 " + 模块名 + " 无依赖者，可安全删除\n")
        返回 真
    }
    打印("模块 " + 模块名 + " 被以下模块依赖:\n")
    定义 可变 i = 0
    当 (i < 计数(依赖者)) {
        打印("  - " + 依赖者[i] + "\n")
        i = i + 1
    }
    返回 假
}

// 版本兼容检查
函数 契约_版本兼容(需要模块, 需要最低版本) {
    如果 (字典有(契约索引, 需要模块) == 假) { 返回 假 }
    定义 位置 = 字典取(契约索引, 需要模块)
    定义 契约 = 契约注册表[位置]
    // 主版本必须匹配，次版本>=需要
    如果 (契约.版本[0] != 需要最低版本[0]) { 返回 假 }
    如果 (契约.版本[1] < 需要最低版本[1]) { 返回 假 }
    返回 真
}

// 自动发现新模块
// 扫描目录，找到未注册的新模块，自动注册
函数 契约_自动发现(项目根) {
    如果 (计数(模块表) == 0) {
        模块_扫描项目(项目根)
    }
    定义 可变 新增 = 0
    定义 可变 i = 0
    当 (i < 计数(模块表)) {
        定义 名 = 模块表[i].名称
        如果 (字典有(契约索引, 名) == 假) {
            定义 导出函数 = 模块表[i].导出符号
            定义 依赖模块 = 模块表[i].依赖列表
            如果 (是列表(导出函数) == 假) { 导出函数 = [] }
            如果 (是列表(依赖模块) == 假) { 依赖模块 = [] }
            契约_注册(名, [1,], 导出函数, [], 依赖模块)
            新增 = 新增 + 1
        }
        i = i + 1
    }
    如果 (模块图详细模式[0]) { 打印("自动发现: " + 转字符串(新增) + " 个新模块\n") }
    返回 新增
}

// 编译管线插件接口
// 任何新模块可以注册为编译管线的某个阶段的插件
定义 可变 管线插件 = 字典()

函数 管线_注册插件(阶段, 插件名, 处理函数) {
    如果 (字典有(管线插件, 阶段) == 假) {
        字典设(管线插件, 阶段, [])
    }
    定义 列表 = 字典取(管线插件, 阶段)
    追加(列表, [插件名, 处理函数])
    打印("注册插件: " + 插件名 + " → 阶段 " + 阶段 + "\n")
}

函数 管线_执行插件(阶段, 数据) {
    如果 (字典有(管线插件, 阶段) == 假) { 返回 数据 }
    定义 插件列表 = 字典取(管线插件, 阶段)
    定义 可变 结果 = 数据
    定义 可变 i = 0
    当 (i < 计数(插件列表)) {
        定义 处理 = 插件列表[i][1]
        结果 = 处理(结果)
        i = i + 1
    }
    返回 结果
}

// 编译管线阶段定义
定义 阶段_词法 = "词法"
定义 阶段_语法 = "语法"
定义 阶段_语义 = "语义"
定义 阶段_优化 = "优化"
定义 阶段_代码生成 = "代码生成"
定义 阶段_链接 = "链接"

// 版本兼容性

函数 模块接口_版本_比较(a, b) {
    // a,b 格式 [主, 次, 补丁]
    如果 (a[0] != b[0]) { 返回 a[0] - b[0] }
    如果 (a[1] != b[1]) { 返回 a[1] - b[1] }
    返回 a[2] - b[2]
}

函数 模块接口_版本_兼容(需要, 提供) {
    // 主版本必须相同, 提供的次版本 >= 需要的次版本
    如果 (需要[0] != 提供[0]) { 返回 假 }
    如果 (提供[1] < 需要[1]) { 返回 假 }
    如果 (提供[1] == 需要[1] 且 提供[2] < 需要[2]) { 返回 假 }
    返回 真
}

函数 模块接口_版本_字符串(v) {
    返回 转字符串(v[0]) + "." + 转字符串(v[1]) + "." + 转字符串(v[2])
}

函数 契约_重置运行状态() {
    契约注册表 = []
    契约索引 = 字典()
    管线插件 = 字典()
    _符号_模块 = []
    _符号_名称 = []
    _符号_可见性 = []
    _契约_注册数 = 0
    _契约_验证数 = 0
    _契约_冲突数 = 0
}

// 依赖冲突检测

函数 契约_检查双方依赖冲突(契约A, 契约B, 冲突, 名A, 名B) {
    如果 (是列表(契约A.依赖模块) == 假) { 返回 空 }
    如果 (是列表(契约B.依赖模块) == 假) { 返回 空 }
    定义 可变 k = 0
    当 (k < 计数(契约A.依赖模块)) {
        定义 可变 m = 0
        当 (m < 计数(契约B.依赖模块)) {
            如果 (字符串相等(契约A.依赖模块[k], 契约B.依赖模块[m])) {
                定义 子A = 契约_查找(契约A.依赖模块[k])
                定义 子B = 契约_查找(契约B.依赖模块[m])
                如果 (子A != 空 且 子B != 空 且 模块接口_版本_比较(子A.版本, 子B.版本) != 0) {
                    追加(冲突, [契约A.依赖模块[k], 名A, 名B])
                }
            }
            m = m + 1
        }
        k = k + 1
    }
}

函数 契约_检查依赖冲突(模块名列表) {
    定义 可变 冲突 = []
    定义 可变 i = 0
    当 (i < 计数(模块名列表)) {
        定义 契约A = 契约_查找(模块名列表[i])
        如果 (契约A == 空 或 是列表(契约A.依赖模块) == 假) { i = i + 1  继续 }
        定义 可变 j = i + 1
        当 (j < 计数(模块名列表)) {
            定义 契约B = 契约_查找(模块名列表[j])
            如果 (契约B != 空 且 是列表(契约B.依赖模块)) {
                契约_检查双方依赖冲突(契约A, 契约B, 冲突, 模块名列表[i], 模块名列表[j])
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 冲突
}

// 符号可见性

定义 可变 _符号_模块 = []
定义 可变 _符号_名称 = []
定义 可变 _符号_可见性 = []  // 0=私有, 1=公开, 2=内部

函数 符号_注册(模块名, 符号名, 可见性) {
    追加(_符号_模块, 模块名)
    追加(_符号_名称, 符号名)
    追加(_符号_可见性, 可见性)
}

函数 符号_可访问(请求模块, 目标模块, 符号名) {
    定义 可变 i = 0
    当 (i < 计数(_符号_名称)) {
        如果 (字符串相等(_符号_模块[i], 目标模块) 且 字符串相等(_符号_名称[i], 符号名)) {
            如果 (_符号_可见性[i] == 1) { 返回 真 }
            如果 (_符号_可见性[i] == 2 且 字符串相等(请求模块, 目标模块)) { 返回 真 }
            返回 假
        }
        i = i + 1
    }
    返回 假
}

函数 符号_列出公开(模块名) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(_符号_名称)) {
        如果 (字符串相等(_符号_模块[i], 模块名) 且 _符号_可见性[i] == 1) {
            追加(结果, _符号_名称[i])
        }
        i = i + 1
    }
    返回 结果
}

// 契约验证

函数 契约_验证完整性(模块名) {
    定义 可变 错误 = []
    定义 契约 = 契约_查找(模块名)
    如果 (契约 == 空) { 返回 ["缺少契约定义"] }
    如果 (是列表(契约.导出函数) == 假) { 返回 ["契约导出函数格式错误"] }
    如果 (是列表(契约.依赖模块) == 假) { 返回 ["契约依赖格式错误"] }
    // 检查导出符号是否都注册
    定义 可变 i = 0
    当 (i < 计数(契约.导出函数)) {
        定义 可变 已注册 = 假
        定义 可变 j = 0
        当 (j < 计数(_符号_名称)) {
            如果 (字符串相等(_符号_模块[j], 模块名) 且 字符串相等(_符号_名称[j], 契约.导出函数[i])) { 已注册 = 真 }
            j = j + 1
        }
        如果 (!已注册) { 追加(错误, "导出函数未注册: " + 契约.导出函数[i]) }
        i = i + 1
    }
    // 检查依赖是否都有契约
    i = 0
    当 (i < 计数(契约.依赖模块)) {
        如果 (契约_查找(契约.依赖模块[i]) == 空) {
            追加(错误, "依赖缺少契约: " + 契约.依赖模块[i])
        }
        i = i + 1
    }
    返回 错误
}

定义 可变 _契约_注册数 = 0
定义 可变 _契约_验证数 = 0
定义 可变 _契约_冲突数 = 0

函数 契约_记录注册() { _契约_注册数 = _契约_注册数 + 1 }
函数 契约_记录验证() { _契约_验证数 = _契约_验证数 + 1 }
函数 契约_记录冲突() { _契约_冲突数 = _契约_冲突数 + 1 }

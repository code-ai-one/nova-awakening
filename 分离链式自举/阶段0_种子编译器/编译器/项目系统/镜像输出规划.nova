// Nova · 项目系统 · 镜像输出规划
// 根据profile和项目合同规划输出镜像类型与布局

// 镜像规划结构
// 规划 = [
//   0: 镜像类型(字符串) elf|kernel-elf|multiboot2|disk|none
//   1: 入口符号(字符串)
//   2: 基址(整数)
//   3: 需要段列表(列表) [".text", ".rodata", ".data", ".bss", ...]
//   4: 需要Multiboot头(整数) 0|1
//   5: 需要启动stub(整数) 0|1
//   6: 链接布局文件(字符串)
//   7: 输出路径(字符串)
// ]

导入("../../标准库/基础.nova")
导入("../../运行时/字典引擎/字典引擎.nova")

函数 镜像规划_创建(合同, 配置, 输出路径) {
    定义 镜像类型 = 配置[3]
    定义 可变 基址 = 0
    定义 可变 段列 = [".text", ".rodata", ".data", ".bss"]
    定义 可变 需要MB = 0
    定义 可变 需要stub = 0

    如果 (字符串相等(镜像类型, "kernel-elf") 或 字符串相等(镜像类型, "multiboot2")) {
        基址 = 1048576
        追加(段列, ".init")
        追加(段列, ".note")
        需要MB = 1
        需要stub = 1
    }
    如果 (字符串相等(镜像类型, "disk")) {
        基址 = 1048576
        追加(段列, ".init")
        追加(段列, ".note")
        需要MB = 1
        需要stub = 1
    }
    如果 (字符串相等(镜像类型, "elf")) {
        基址 = 4194304
    }

    定义 入口 = 合同[3]
    如果 (字符串相等(入口, "none") 或 字节长度(入口) == 0) {
        如果 (需要stub == 1) { 入口 = "入口64" }
        否则 { 入口 = "__主程序__" }
    }

    定义 可变 输出 = 输出路径
    如果 (字节长度(输出) == 0) {
        如果 (字符串相等(镜像类型, "elf")) { 输出 = "nova_output" }
        如果 (字符串相等(镜像类型, "kernel-elf")) { 输出 = "nova_kernel.elf" }
        如果 (字符串相等(镜像类型, "multiboot2")) { 输出 = "nova_kernel.mb2" }
        如果 (字符串相等(镜像类型, "disk")) { 输出 = "nova_kernel.img" }
    }

    返回 [镜像类型, 入口, 基址, 段列, 需要MB, 需要stub, 配置[11], 输出]
}

// 访问器
函数 镜像规划_类型(规划) { 返回 规划[0] }
函数 镜像规划_入口符号(规划) { 返回 规划[1] }
函数 镜像规划_基址(规划) { 返回 规划[2] }
函数 镜像规划_段列表(规划) { 返回 规划[3] }
函数 镜像规划_需要Multiboot(规划) { 返回 规划[4] }
函数 镜像规划_需要启动stub(规划) { 返回 规划[5] }
函数 镜像规划_链接布局(规划) { 返回 规划[6] }
函数 镜像规划_输出路径(规划) { 返回 规划[7] }

// 打印镜像规划
函数 镜像规划_打印(规划) {
    打印("镜像输出规划:")
    打印("  类型: " + 规划[0])
    打印("  入口: " + 规划[1])
    打印("  基址: " + 转字符串(规划[2]))
    打印("  段: " + 转字符串(计数(规划[3])) + "个")
    打印("  输出: " + 规划[7])
}

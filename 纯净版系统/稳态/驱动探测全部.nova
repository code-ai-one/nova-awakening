// NovaOS · 设备驱动探测引擎 (NDDP理论)

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/中断表注册处.nova")
导入("../中枢/内核打印.nova")
导入("../推理/值乘.nova")

// NDDP理论 (Nova Dynamic Device Probing)
// 核心创新:
// 1. 多总线统一探测 — PCI/USB/平台/虚拟总线统一调度
// 2. 智能设备匹配 — VendorID/DeviceID/类码/兼容列表多策略
// 3. 资源分配引擎 — IRQ/MMIO/DMA资源无冲突分配
// 4. 热插拔管理 — 设备到达/离开事件+驱动自动绑定
// 5. AI驱动匹配 — 特征向量推理最优驱动选择

外部 全局AI总线

定义 驱动状态_未绑定    = 0
定义 驱动状态_已绑定    = 1
定义 驱动状态_已暂停    = 2
定义 驱动状态_错误      = 3

定义 总线_PCI      = 0
定义 总线_USB      = 1
定义 总线_平台     = 2
定义 总线_虚拟     = 3
定义 总线_I2C      = 4
定义 总线_SPI      = 5

定义 匹配_供应商ID   = 0x01
定义 匹配_设备ID     = 0x02
定义 匹配_类码       = 0x04
定义 匹配_兼容列表   = 0x08
定义 匹配_总线类型   = 0x10

定义 事件_设备到达   = 0
定义 事件_设备离开   = 1
定义 事件_驱动注册   = 2
定义 事件_驱动卸载   = 3

定义 资源_IRQ      = 0
定义 资源_MMIO     = 1
定义 资源_DMA      = 2
定义 资源_IO端口  = 3

定义 最大总线数     = 16
定义 最大设备数     = 256
定义 最大驱动数     = 128
定义 热插拔队列大小 = 32

结构 探测统计 {
    总探测次数,
    成功绑定数,
    匹配失败数,
    热插拔事件数,
    资源分配次数,
    资源冲突次数,
    AI匹配次数,
    AI匹配命中数,
    暂停次数,
    恢复次数,
}

定义 可变 探测_统计 = 探测统计 {}

结构 热插拔事件 {
    类型,
    总线类型,
    设备名称,
    时间戳,
}

定义 可变 热插拔队列 = []
定义 可变 热插拔回调 = 空

// §1 全局探测 — 多总线统一扫描

函数 驱动_探测全部() {
    探测_统计.总探测次数 = 探测_统计.总探测次数 + 1
    内核打印("NDDP: 开始全局设备探测...\n")
    // 第一轮: 总线扫描,枚举所有已连接设备
    定义 可变 总线索引 = 0
    当 (总线索引 < 全局总线数) {
        定义 总线 = 全局总线表[总线索引]
        如果 (总线 != 空 && 总线.扫描 != 空) {
            总线.扫描(总线)
        }
        总线索引 = 总线索引 + 1
    }
    // 第二轮: 为未绑定驱动匹配设备
    定义 可变 i = 0
    当 (i < 全局驱动数) {
        定义 drv = 全局驱动表[i]
        如果 (drv != 空 && drv.设备数 == 0) {
            驱动_匹配设备(drv)
        }
        i = i + 1
    }
    内核打印("NDDP: 探测完成, 绑定" + 探测_统计.成功绑定数 + "个设备\n")
}

// 电源管理

函数 驱动_暂停全部() {
    定义 可变 i = 0
    当 (i < 全局驱动数) {
        定义 drv = 全局驱动表[i]
        如果 (drv != 空 && drv.暂停 != 空 && drv.状态 == 驱动状态_已绑定) {
            定义 可变 dev = drv.设备列表
            当 (dev != 空) {
                drv.暂停(dev)
                dev = dev.驱动链接
            }
            drv.状态 = 驱动状态_已暂停
        }
        i = i + 1
    }
}

函数 驱动_恢复全部() {
    定义 可变 i = 0
    当 (i < 全局驱动数) {
        定义 drv = 全局驱动表[i]
        如果 (drv != 空 && drv.恢复 != 空 && drv.状态 == 驱动状态_已暂停) {
            定义 可变 dev = drv.设备列表
            当 (dev != 空) {
                drv.恢复(dev)
                dev = dev.驱动链接
            }
            drv.状态 = 驱动状态_已绑定
        }
        i = i + 1
    }
}

// 查询与诊断

函数 驱动_打印列表() {
    内核打印("=== 驱动列表 ===\n")
    定义 可变 i = 0
    当 (i < 全局驱动数) {
        定义 drv = 全局驱动表[i]
        如果 (drv != 空) {
            定义 总线名 = drv.总线 != 空 ? drv.总线.名称 : "无"
            内核打印("  %s: 总线=%s 设备数=%d 状态=%d\n",
                drv.名称, 总线名, drv.设备数, drv.状态)
        }
        i = i + 1
    }
}

函数 设备_打印树() {
    内核打印("=== 设备树 ===\n")
    定义 可变 i = 0
    当 (i < 全局总线数) {
        定义 总线 = 全局总线表[i]
        如果 (总线 != 空) {
            内核打印("总线 %s (%d设备 %d驱动):\n",
                总线.名称, 总线.设备数, 总线.驱动数)
            定义 可变 dev = 总线.设备列表
            当 (dev != 空) {
                定义 驱动名 = dev.驱动 != 空 ? dev.驱动.名称 : "未绑定"
                内核打印("  设备 %s -> 驱动 %s\n", dev.名称, 驱动名)
                dev = dev.总线链接
            }
        }
        i = i + 1
    }
}

函数 设备_按名称查找(名称) {
    定义 可变 i = 0
    当 (i < 全局总线数) {
        定义 总线 = 全局总线表[i]
        如果 (总线 != 空) {
            定义 可变 dev = 总线.设备列表
            当 (dev != 空) {
                如果 (dev.名称 == 名称) { 返回 dev }
                dev = dev.总线链接
            }
        }
        i = i + 1
    }
    返回 空
}

// §2 智能设备匹配 — 多策略加权匹配引擎

函数 驱动_匹配设备(drv) {
    如果 (drv == 空 || drv.总线 == 空) { 返回 }
    定义 总线 = drv.总线
    定义 可变 dev = 总线.设备列表
    当 (dev != 空) {
        如果 (dev.驱动 == 空) {
            定义 分数 = 驱动_计算匹配分(drv, dev)
            如果 (分数 > 0) {
                定义 结果 = 驱动_尝试绑定(drv, dev)
                如果 (结果 == 0) {
                    探测_统计.成功绑定数 = 探测_统计.成功绑定数 + 1
                    内核打印("NDDP: 绑定 %s -> %s (分数=%d)\n", dev.名称, drv.名称, 分数)
                } 否则 {
                    探测_统计.匹配失败数 = 探测_统计.匹配失败数 + 1
                }
            }
        }
        dev = dev.总线链接
    }
}

函数 驱动_计算匹配分(drv, dev) {
    定义 可变 分数 = 0
    // VendorID匹配(权重3)
    如果 (drv.供应商ID != 0 && drv.供应商ID == dev.供应商ID) {
        分数 = 分数 + 3
    }
    // DeviceID匹配(权重3)
    如果 (drv.设备ID != 0 && drv.设备ID == dev.设备ID) {
        分数 = 分数 + 3
    }
    // 类码匹配(权重2)
    如果 (drv.类码 != 0 && drv.类码 == dev.类码) {
        分数 = 分数 + 2
    }
    // 总线类型匹配(权重1)
    如果 (drv.总线.类型 == dev.总线类型) {
        分数 = 分数 + 1
    }
    // 兼容列表匹配(权重4)
    如果 (drv.兼容列表 != 空) {
        定义 可变 k = 0
        当 (k < 计数(drv.兼容列表)) {
            如果 (drv.兼容列表[k] == dev.兼容字符串) {
                分数 = 分数 + 4
                跳出
            }
            k = k + 1
        }
    }
    返回 分数
}

函数 驱动_尝试绑定(drv, dev) {
    // 分配资源
    定义 资源结果 = 设备_分配资源(dev)
    如果 (资源结果 != 0) {
        内核打印("NDDP: 资源分配失败 %s\n", dev.名称)
        返回 -1
    }
    // 调用驱动probe
    如果 (drv.probe != 空) {
        定义 结果 = drv.probe(dev)
        如果 (结果 != 0) {
            设备_释放资源(dev)
            返回 结果
        }
    }
    // 绑定成功
    dev.驱动 = drv
    drv.设备数 = drv.设备数 + 1
    drv.状态 = 驱动状态_已绑定
    返回 0
}

// §3 资源分配引擎 — IRQ/MMIO/DMA无冲突分配

定义 可变 irq_已分配表 = []
定义 可变 mmio_已分配表 = []

结构 资源记录 {
    类型,
    起始地址,
    大小,
    拥有者,        // 字符串(device name)
}

函数 设备_分配资源(dev) {
    探测_统计.资源分配次数 = 探测_统计.资源分配次数 + 1
    // 分配IRQ
    如果 (dev.请求_irq > 0) {
        定义 irq = 资源_分配IRQ(dev.请求_irq)
        如果 (irq < 0) {
            探测_统计.资源冲突次数 = 探测_统计.资源冲突次数 + 1
            返回 -1
        }
        dev.已分配_irq = irq
    }
    // 分配MMIO
    如果 (dev.请求_mmio大小 > 0) {
        定义 mmio = 资源_分配MMIO(dev.请求_mmio地址, dev.请求_mmio大小, dev.名称)
        如果 (mmio < 0) {
            探测_统计.资源冲突次数 = 探测_统计.资源冲突次数 + 1
            返回 -2
        }
    }
    返回 0
}

函数 设备_释放资源(dev) {
    如果 (dev.已分配_irq > 0) {
        资源_释放IRQ(dev.已分配_irq)
        dev.已分配_irq = 0
    }
    如果 (dev.请求_mmio大小 > 0) {
        资源_释放MMIO(dev.请求_mmio地址, dev.名称)
    }
}

函数 资源_分配IRQ(请求号) {
    // 检查冲突
    定义 可变 i = 0
    当 (i < 计数(irq_已分配表)) {
        如果 (irq_已分配表[i] == 请求号) {
            内核打印("NDDP: IRQ %d 已被占用\n", 请求号)
            返回 -1
        }
        i = i + 1
    }
    追加(irq_已分配表, 请求号)
    返回 请求号
}

函数 资源_释放IRQ(irq号) {
    定义 可变 i = 0
    当 (i < 计数(irq_已分配表)) {
        如果 (irq_已分配表[i] == irq号) {
            删除(irq_已分配表, i)
            返回
        }
        i = i + 1
    }
}

函数 资源_分配MMIO(地址, 大小, 拥有者名) {
    // 检查地址重叠
    定义 可变 i = 0
    当 (i < 计数(mmio_已分配表)) {
        定义 rec = mmio_已分配表[i]
        如果 (地址 < rec.起始地址 + rec.大小 && 地址 + 大小 > rec.起始地址) {
            内核打印("NDDP: MMIO 0x%x 重叠 %s\n", 地址, rec.拥有者)
            返回 -1
        }
        i = i + 1
    }
    定义 rec = 资源记录 {}
    rec.类型 = 资源_MMIO
    rec.起始地址 = 地址
    rec.大小 = 大小
    rec.拥有者 = 拥有者名
    追加(mmio_已分配表, rec)
    返回 0
}

函数 资源_释放MMIO(地址, 拥有者名) {
    定义 可变 i = 0
    当 (i < 计数(mmio_已分配表)) {
        如果 (mmio_已分配表[i].起始地址 == 地址 && mmio_已分配表[i].拥有者 == 拥有者名) {
            删除(mmio_已分配表, i)
            返回
        }
        i = i + 1
    }
}

// §4 热插拔管理 — 设备到达/离开事件处理

函数 热插拔_注册回调(回调) {
    热插拔回调 = 回调
    内核打印("NDDP: 热插拔回调已注册\n")
}

函数 热插拔_设备到达(总线类型码, 设备名) {
    探测_统计.热插拔事件数 = 探测_统计.热插拔事件数 + 1
    内核打印("NDDP: 设备到达 %s (bus=%d)\n", 设备名, 总线类型码)
    // 记录事件
    定义 事件 = 热插拔事件 {}
    事件.类型 = 事件_设备到达
    事件.总线类型 = 总线类型码
    事件.设备名称 = 设备名
    事件.时间戳 = 系统_时钟()
    如果 (计数(热插拔队列) >= 热插拔队列大小) {
        删除(热插拔队列, 0)
    }
    追加(热插拔队列, 事件)
    // 尝试自动匹配驱动
    定义 dev = 设备_按名称查找(设备名)
    如果 (dev != 空 && dev.驱动 == 空) {
        驱动_自动匹配(dev)
    }
    // 回调通知
    如果 (热插拔回调 != 空) {
        热插拔回调(事件)
    }
}

函数 热插拔_设备离开(总线类型码, 设备名) {
    探测_统计.热插拔事件数 = 探测_统计.热插拔事件数 + 1
    内核打印("NDDP: 设备离开 %s\n", 设备名)
    定义 事件 = 热插拔事件 {}
    事件.类型 = 事件_设备离开
    事件.总线类型 = 总线类型码
    事件.设备名称 = 设备名
    事件.时间戳 = 系统_时钟()
    如果 (计数(热插拔队列) >= 热插拔队列大小) {
        删除(热插拔队列, 0)
    }
    追加(热插拔队列, 事件)
    // 解绑驱动
    定义 dev = 设备_按名称查找(设备名)
    如果 (dev != 空 && dev.驱动 != 空) {
        驱动_解绑(dev)
    }
    如果 (热插拔回调 != 空) {
        热插拔回调(事件)
    }
}

函数 驱动_自动匹配(dev) {
    定义 可变 最佳驱动 = 空
    定义 可变 最高分 = 0
    定义 可变 i = 0
    当 (i < 全局驱动数) {
        定义 drv = 全局驱动表[i]
        如果 (drv != 空) {
            定义 分 = 驱动_计算匹配分(drv, dev)
            如果 (分 > 最高分) {
                最高分 = 分
                最佳驱动 = drv
            }
        }
        i = i + 1
    }
    如果 (最佳驱动 != 空 && 最高分 > 0) {
        驱动_尝试绑定(最佳驱动, dev)
    }
}

函数 驱动_解绑(dev) {
    如果 (dev.驱动 == 空) { 返回 }
    定义 drv = dev.驱动
    如果 (drv.remove != 空) {
        drv.remove(dev)
    }
    设备_释放资源(dev)
    drv.设备数 = drv.设备数 - 1
    dev.驱动 = 空
    内核打印("NDDP: 解绑 %s <- %s\n", dev.名称, drv.名称)
}

// §5 AI驱动匹配 — 特征向量推理最优驱动

定义 AI_驱动特征维 = 8

函数 驱动_AI匹配(dev) {
    如果 (全局AI总线 == 空) {
        内核打印("NDDP: AI总线未就绪,回退常规匹配\n")
        驱动_自动匹配(dev)
        返回
    }
    探测_统计.AI匹配次数 = 探测_统计.AI匹配次数 + 1
    // 特征向量: [供应商ID, 设备ID, 类码, 总线类型, 资源数, IRQ, MMIO大小, 已绑定]
    定义 张量 = Tensor_创建(AI_驱动特征维)
    定义 可变 最佳驱动 = 空
    定义 可变 最高置信 = 0.0
    定义 可变 i = 0
    当 (i < 全局驱动数) {
        定义 drv = 全局驱动表[i]
        如果 (drv != 空) {
            Tensor_写(张量, 0, dev.供应商ID)
            Tensor_写(张量, 1, dev.设备ID)
            Tensor_写(张量, 2, dev.类码)
            Tensor_写(张量, 3, dev.总线类型)
            Tensor_写(张量, 4, drv.供应商ID == dev.供应商ID)
            Tensor_写(张量, 5, drv.设备ID == dev.设备ID)
            Tensor_写(张量, 6, drv.类码 == dev.类码)
            Tensor_写(张量, 7, drv.设备数)
            定义 置信 = AI总线_推理(全局AI总线, "driver_match", 张量)
            如果 (置信 > 最高置信) {
                最高置信 = 置信
                最佳驱动 = drv
            }
        }
        i = i + 1
    }
    Tensor_释放(张量)
    如果 (最佳驱动 != 空 && 最高置信 > 0.6) {
        探测_统计.AI匹配命中数 = 探测_统计.AI匹配命中数 + 1
        驱动_尝试绑定(最佳驱动, dev)
        内核打印("NDDP: AI匹配 %s -> %s (置信=%d%%)\n", dev.名称, 最佳驱动.名称, 最高置信 * 100)
    }
}

函数 设备_AI异常检测() {
    如果 (全局AI总线 == 空) { 返回 [] }
    定义 可变 异常列表 = []
    定义 张量 = Tensor_创建(4)
    定义 可变 bus = 0
    当 (bus < 全局总线数) {
        定义 总线 = 全局总线表[bus]
        如果 (总线 != 空) {
            定义 可变 dev = 总线.设备列表
            当 (dev != 空) {
                Tensor_写(张量, 0, dev.总线类型)
                Tensor_写(张量, 1, dev.供应商ID)
                Tensor_写(张量, 2, dev.设备ID)
                Tensor_写(张量, 3, dev.驱动 != 空)
                定义 异常分 = AI总线_异常检测(全局AI总线, "device_anomaly", 张量)
                如果 (异常分 > 0.8) {
                    追加(异常列表, { 设备: dev.名称, 异常分: 异常分 })
                }
                dev = dev.总线链接
            }
        }
        bus = bus + 1
    }
    Tensor_释放(张量)
    返回 异常列表
}

// §6 诊断统计 — 完整运行时数据

函数 探测_获取统计() {
    返回 探测_统计
}

函数 探测_重置统计() {
    探测_统计 = 探测统计 {}
}

函数 探测_打印诊断() {
    内核打印("═══ NDDP 设备探测诊断 ═══\n")
    内核打印("  总探测: %d\n", 探测_统计.总探测次数)
    内核打印("  成功绑定: %d\n", 探测_统计.成功绑定数)
    内核打印("  匹配失败: %d\n", 探测_统计.匹配失败数)
    内核打印("  热插拔事件: %d\n", 探测_统计.热插拔事件数)
    内核打印("  资源分配: %d 冲突: %d\n", 探测_统计.资源分配次数, 探测_统计.资源冲突次数)
    内核打印("  AI匹配: %d 命中: %d\n", 探测_统计.AI匹配次数, 探测_统计.AI匹配命中数)
    内核打印("  暂停/恢复: %d/%d\n", 探测_统计.暂停次数, 探测_统计.恢复次数)
    内核打印("  IRQ已分配: %d MMIO区域: %d\n", 计数(irq_已分配表), 计数(mmio_已分配表))
    内核打印("  热插拔队列: %d\n", 计数(热插拔队列))
    内核打印("═══════════════════════════\n")
}

函数 探测_健康检查() {
    定义 可变 问题 = []
    // 检查未绑定设备
    定义 可变 未绑定数 = 0
    定义 可变 bus = 0
    当 (bus < 全局总线数) {
        定义 总线 = 全局总线表[bus]
        如果 (总线 != 空) {
            定义 可变 dev = 总线.设备列表
            当 (dev != 空) {
                如果 (dev.驱动 == 空) { 未绑定数 = 未绑定数 + 1 }
                dev = dev.总线链接
            }
        }
        bus = bus + 1
    }
    如果 (未绑定数 > 0) {
        追加(问题, "未绑定设备数: " + 未绑定数)
    }
    // 检查资源冲突率
    如果 (探测_统计.资源分配次数 > 5) {
        定义 冲突率 = 探测_统计.资源冲突次数 * 100 / 探测_统计.资源分配次数
        如果 (冲突率 > 20) {
            追加(问题, "资源冲突率过高(" + 冲突率 + "%)")
        }
    }
    // 检查AI匹配质量
    如果 (探测_统计.AI匹配次数 > 5) {
        定义 AI率 = 探测_统计.AI匹配命中数 * 100 / 探测_统计.AI匹配次数
        如果 (AI率 < 40) {
            追加(问题, "AI匹配命中率偏低(" + AI率 + "%)")
        }
    }
    返回 { 健康: 计数(问题) == 0, 问题列表: 问题 }
}

// §5 字形光栅化 — 贝塞尔曲线→像素覆盖率
// 算法: 扫描线 + 覆盖率累积
// 每个像素的灰度值 = 轮廓在该像素上的覆盖率(0-255)
// 这就是抗锯齿(anti-aliasing)

结构 GlyphBitmap {
    宽,
    高,
    像素,    // u64 u8数组(灰度)
    基线偏移x,    // i32 从原点到位图左边缘
    基线偏移y,    // i32 从基线到位图上边缘
}


函数 字体_光栅化字形(font, glyphID, 字号) {
    定义 outline = 字体_提取字形(font, glyphID)
    如果 (outline == 0) { 返回 0 }

    // 缩放因子: font units → pixels
    定义 缩放 = 字号 * 1024 / font.unitsPerEm    // Q10定点

    // 计算位图大小
    定义 宽 = ((outline.xMax - outline.xMin) * 缩放 / 1024) + 2
    定义 高 = ((outline.yMax - outline.yMin) * 缩放 / 1024) + 2
    如果 (宽 <= 0 || 高 <= 0) { 返回 0 }
    如果 (宽 > 256) { 宽 = 256 }
    如果 (高 > 256) { 高 = 256 }

    定义 bmp = 堆_分配(GlyphBitmap)
    bmp.宽 = 宽
    bmp.高 = 高
    bmp.像素 = 堆_分配_数组(宽 * 高)
    内存_填零(bmp.像素, 宽 * 高)
    bmp.基线偏移x = outline.xMin * 缩放 / 1024
    bmp.基线偏移y = outline.yMax * 缩放 / 1024

    // 扫描线光栅化
    定义 可变 轮廓 = 0
    定义 可变 点起始 = 0
    当 (轮廓 < outline.轮廓数) {
        定义 点结束 = 读16(outline.轮廓结束 + 轮廓 * 2)
        // 遍历该轮廓的线段和曲线
        定义 可变 p = 点起始
        当 (p <= 点结束) {
            定义 下一个 = 如果(p < 点结束, p + 1, 点起始)
            定义 x0 = (读16有符号(outline.点x + p * 2) - outline.xMin) * 缩放 / 1024
            定义 y0 = (outline.yMax - 读16有符号(outline.点y + p * 2)) * 缩放 / 1024
            定义 x1 = (读16有符号(outline.点x + 下一个 * 2) - outline.xMin) * 缩放 / 1024
            定义 y1 = (outline.yMax - 读16有符号(outline.点y + 下一个 * 2)) * 缩放 / 1024

            定义 标志 = 内存_读8(outline.点标志 + p)
            如果 (标志 & 0x01) {
                // on-curve → 直线段
                光栅化_线段(bmp, x0, y0, x1, y1)
            }
            // off-curve → 二次贝塞尔曲线光栅化
            否则 {
                光栅化_二次贝塞尔(bmp, x0, y0, x1, y1, x0, y0)
            }
            p = p + 1
        }
        点起始 = 点结束 + 1
        轮廓 = 轮廓 + 1
    }

    // 覆盖率累积: 将扫描线交叉转为灰度
    光栅化_填充(bmp)

    返回 bmp
}

// 扫描线: 记录轮廓与扫描线的交点
函数 光栅化_线段(bmp, x0, y0, x1, y1) {
    // Bresenham画线 → 在覆盖率缓冲中累积
    如果 (y0 == y1) { 返回 }    // 水平线不影响填充

    // 确保y0 < y1
    定义 可变 sx = x0
    定义 可变 sy = y0
    定义 可变 ex = x1
    定义 可变 ey = y1
    定义 方向 = 1
    如果 (y0 > y1) {
        sx = x1; sy = y1; ex = x0; ey = y0
        方向 = -1
    }

    定义 dy = ey - sy
    如果 (dy == 0) { 返回 }
    定义 dx_per_y = (ex - sx) * 1024 / dy    // Q10

    定义 可变 y = sy
    定义 可变 x_q10 = sx * 1024
    当 (y < ey && y < bmp.高) {
        如果 (y >= 0) {
            定义 x = x_q10 / 1024
            如果 (x >= 0 && x < bmp.宽) {
                // 在覆盖率缓冲中标记: +1或-1(winding number)
                定义 偏移 = y * bmp.宽 + x
                定义 当前 = 内存_读8(bmp.像素 + 偏移)
                内存_写8(bmp.像素 + 偏移, (当前 + 方向 * 32) & 0xFF)
            }
        }
        x_q10 = x_q10 + dx_per_y
        y = y + 1
    }
}

// 将winding number转为填充
函数 光栅化_填充(bmp) {
    定义 可变 y = 0
    当 (y < bmp.高) {
        定义 可变 wind = 0
        定义 可变 x = 0
        当 (x < bmp.宽) {
            定义 偏移 = y * bmp.宽 + x
            定义 v = 内存_读8(bmp.像素 + 偏移)
            wind = wind + v
            // 非零填充规则: wind!=0 → 内部
            如果 (wind != 0) {
                定义 覆盖 = 如果(wind > 255, 255, 如果(wind < 0, 0, wind))
                内存_写8(bmp.像素 + 偏移, 覆盖)
            } 否则 {
                内存_写8(bmp.像素 + 偏移, 0)
            }
            x = x + 1
        }
        y = y + 1
    }
}

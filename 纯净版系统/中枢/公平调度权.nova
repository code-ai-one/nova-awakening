导入("./类型定义.nova")
导入("./错误码.nova")
导入("./进程描述符.nova")

// NovaOS Nova公平调度权重计算
// 职责: nice值↔权重转换, Nova虚拟运行时间加权计算

// nice值到权重映射表
// nice -20→88761, nice 0→1024, nice 19→15
// 每差1个nice, 权重差~1.25倍 (CPU时间差~10%)

定义 权重表 = [
    88761, 71755, 56483, 46273, 36291,   // nice -20 ~ -16
    29154, 23254, 18705, 14949, 11916,   // nice -15 ~ -11
    9548,  7620,  6100,  4904,  3906,    // nice -10 ~ -6
    3121,  2501,  1991,  1586,  1277,    // nice -5 ~ -1
    1024,  820,   655,   526,   423,     // nice  0 ~ 4
    335,   272,   215,   172,   137,     // nice  5 ~ 9
    110,   87,    70,    56,    45,      // nice 10 ~ 14
    36,    29,    23,    18,    15       // nice 15 ~ 19
]

// 权重倒数表 (用于Nova虚拟运行时间计算, 避免除法)
// inv_weight = 2^32 / weight
定义 权重倒数表 = [
    48388,  59856,  76040,  92818,  118348,  // nice -20 ~ -16
    147320, 184698, 229616, 287308, 360437,  // nice -15 ~ -11
    449829, 563644, 704093, 875809, 1099582, // nice -10 ~ -6
    1376151,1717300,2157191,2708050,3363326, // nice -5 ~ -1
    4194304,5237765,6557202,8165337,10153587,// nice  0 ~ 4
    12820798,15790321,19976592,24970740,31350126, // nice 5 ~ 9
    39045157,49367440,61356676,76695844,95443717, // nice 10 ~ 14
    119304647,148102320,186737708,238609294,286331153 // nice 15 ~ 19
]

// nice值↔权重转换

// nice范围: -20 ~ 19
函数 nice到权重_Nova公平调度(nice) {
    定义 索引 = nice + 20
    如果 (索引 < 0) { 索引 = 0 }
    如果 (索引 > 39) { 索引 = 39 }
    返回 权重表[索引]
}

函数 nice到权重倒数(nice) {
    定义 索引 = nice + 20
    如果 (索引 < 0) { 索引 = 0 }
    如果 (索引 > 39) { 索引 = 39 }
    返回 权重倒数表[索引]
}

// 优先级转换

// Nova内核优先级: 0-139
// RT: 0-99 (数值越低优先级越高)
// 普通: 100-139 (nice -20→100, nice 19→139)
定义 RT_优先级_最大 = 99
定义 普通优先级_基础 = 100

函数 nice转内核优先级(nice) {
    返回 普通优先级_基础 + nice + 20  // nice -20→100, nice 0→120, nice 19→139
}

函数 内核优先级转nice(优先级) {
    返回 优先级 - 普通优先级_基础 - 20
}

函数 是RT优先级(优先级) {
    返回 优先级 <= RT_优先级_最大
}

// Nova虚拟运行时间计算
// Nova虚拟运行时间_delta = delta * NICE_0_WEIGHT / weight
//                = delta * inv_weight >> 32

定义 NICE_0_权重 = 1024

// 计算加权Nova虚拟运行时间增量
// 实际运行时间delta_us → 加权虚拟运行时间增量
函数 计算加权Nova虚拟运行时间增量(实际时间_us, 权重) {
    如果 (权重 <= 0) { 权重 = NICE_0_权重 }
    // Nova虚拟运行时间_delta = delta * NICE_0_WEIGHT / weight
    返回 实际时间_us * NICE_0_权重 / 权重
}

// 精确版 (使用倒数表避免除法)
函数 计算加权Nova虚拟运行时间增量_精确(实际时间_us, nice) {
    定义 倒数 = nice到权重倒数(nice)
    // Nova虚拟运行时间_delta = delta * inv_weight >> 32
    // 使用整数运算
    返回 实际时间_us * 倒数 / 4194304  // 2^22近似
}

// 时间片计算
// time_slice = period * weight / total_weight

函数 计算时间片(权重, 总权重, 调度周期_us) {
    如果 (总权重 <= 0) { 返回 调度周期_us }
    定义 片 = 调度周期_us * 权重 / 总权重
    如果 (片 < 750) { 返回 750 }  // 最小750us
    返回 片
}

// 进程权重操作

// 设置进程nice值并更新权重
函数 进程_设nice_Nova公平调度(任务, nice) {
    如果 (nice < -20) { nice = -20 }
    如果 (nice > 19) { nice = 19 }
    设置(任务, T_nice, nice)
    设置(任务, T_权重, nice到权重(nice))
}

// 获取进程权重
函数 进程_获取权重(任务) {
    返回 任务[T_权重]
}

// 初始化新进程的权重 (继承父进程nice)
函数 进程_初始化权重(任务) {
    定义 nice = 任务[T_nice]
    设置(任务, T_权重, nice到权重(nice))
}

// 负载权重 

函数 负载权重_更新(任务, 旧nice, 新nice) {
    // 从运行队列的总权重中减去旧权重, 加上新权重
    定义 旧权重 = nice到权重_Nova公平调度(旧nice)
    定义 新权重 = nice到权重_Nova公平调度(新nice)
    返回 [旧权重, 新权重, 新权重 - 旧权重]  // [旧, 新, 差值]
}

// 调度延迟与最小粒度 

定义 调度延迟_us = 6000       // 6ms默认调度周期
定义 最小粒度_us = 750        // 0.75ms最小时间片
定义 唤醒粒度_us = 1000       // 1ms唤醒粒度

函数 计算调度周期(进程数) {
    // 进程数 <= nr_latency时, 使用固定调度周期
    // 进程数超过时, 使用 进程数 * 最小粒度
    定义 nr_latency = 调度延迟_us / 最小粒度_us  // =8
    如果 (进程数 <= nr_latency) {
        返回 调度延迟_us
    }
    返回 进程数 * 最小粒度_us
}

// Nova虚拟运行时间比较 (处理溢出)

函数 Nova虚拟运行时间_之前(a, b) {
    // 有符号比较处理溢出
    返回 (a - b) < 0
}

函数 Nova虚拟运行时间_之后(a, b) {
    返回 (b - a) < 0
}

// 权重→CPU占比估算

函数 权重转CPU百分比(权重, 总权重) {
    如果 (总权重 <= 0) { 返回 100 }
    返回 权重 * 100 / 总权重
}

函数 nice转预期CPU百分比(nice, 进程数) {
    // 假设所有进程相同nice, 均分CPU
    // 实际: 此进程权重 / (此进程权重 + 其他进程总权重)
    定义 权重 = nice到权重_Nova公平调度(nice)
    定义 默认总 = NICE_0_权重 * (进程数 - 1) + 权重
    如果 (默认总 == 0) { 返回 0 }
    返回 权重 * 100 / 默认总
}

// nice值边界校验 + 权重范围

函数 nice_clamp(nice) {
    如果 (nice < -20) { 返回 -20 }
    如果 (nice > 19) { 返回 19 }
    返回 nice
}

函数 权重_最大() { 返回 权重表[0] }   // 88761 (nice -20)
函数 权重_最小() { 返回 权重表[39] }  // 15 (nice 19)
函数 权重_默认() { 返回 NICE_0_权重 } // 1024 (nice 0)

函数 Nova公平调度权重_统计() {
    返回 [权重_最大(), 权重_默认(), 权重_最小()]
}


函数 Nova公平调度权重_完整统计() {
    返回 [权重_最大(), 权重_默认(), 权重_最小()]
}

定义 可变 AI_公平调度权_负载窗口 = []

函数 AI_公平调度权_负载预测(当前负载) {
    追加(AI_公平调度权_负载窗口, 当前负载)
    如果 (计数(AI_公平调度权_负载窗口) > 20) { 列表_移除(AI_公平调度权_负载窗口, 0) }
    如果 (计数(AI_公平调度权_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_公平调度权_负载窗口)
    定义 趋势 = AI_公平调度权_负载窗口[n-1] - AI_公平调度权_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_公平调度权_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

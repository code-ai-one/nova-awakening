// NovaOS BIO (块级 I/O)
// 功能: BIO请求构建、提交、完成回调、bio_vec管理

定义 BIO_最大向量数       = 256
定义 BIO_池_大小          = 256
定义 BIO_标志_读          = 0
定义 BIO_标志_写          = 1
定义 BIO_标志_FLUSH       = 2
定义 BIO_标志_FUA         = 4
定义 BIO_标志_DISCARD     = 8
定义 BIO_标志_同步        = 16

// bio_vec: 描述一个IO段(页+偏移+长度)

结构 BioVec {
    页,    // 指针<物理页>
    偏移,
    长度,
}

// BIO结构

结构 Bio {
    设备,    // 指针<块设备>
    扇区,
    大小,
    标志,
    向量数,
    最大向量数,
    当前向量,
    向量列表,    // 数组<BioVec, 256>
    完成回调,    // 函数指针
    私有数据,    // 指针<空>
    错误,
    引用计数,    // 原子变量
    下一个,    // 指针<Bio>
    提交时间,
}

// BIO内存池

结构 Bio池 {
    空闲链表,    // 指针<Bio>
    空闲数,
    分配数,
    锁,    // 自旋锁
}

定义 可变 全局Bio池 = Bio池 {}

函数 bio池_初始化() {
    全局Bio池.空闲链表 = 空
    全局Bio池.空闲数 = 0
    全局Bio池.分配数 = 0

    // 预分配一批BIO
    定义 可变 i = 0
    当 (i < BIO_池_大小) {
        定义 可变 bio = 分配内存(大小(Bio))
        bio.下一个 = 全局Bio池.空闲链表
        全局Bio池.空闲链表 = bio
        全局Bio池.空闲数 = 全局Bio池.空闲数 + 1
        i = i + 1
    }
}

// BIO创建与释放

函数 bio_分配(最大向量数) {
    定义 可变 bio = 空

    // 尝试从池中获取
    自旋锁_获取(全局Bio池.锁)
    如果 (全局Bio池.空闲链表 != 空) {
        bio = 全局Bio池.空闲链表
        全局Bio池.空闲链表 = bio.下一个
        全局Bio池.空闲数 = 全局Bio池.空闲数 - 1
    }
    自旋锁_释放(全局Bio池.锁)

    如果 (bio == 空) {
        bio = 分配内存(大小(Bio))
        如果 (bio == 空) { 返回 空 }
    }

    // 初始化
    bio.设备 = 空
    bio.扇区 = 0
    bio.大小 = 0
    bio.标志 = 0
    bio.向量数 = 0
    bio.最大向量数 = 取小(最大向量数, BIO_最大向量数)
    bio.当前向量 = 0
    bio.完成回调 = 空
    bio.私有数据 = 空
    bio.错误 = 0
    原子_设置(bio.引用计数, 1)
    bio.下一个 = 空
    bio.提交时间 = 0

    全局Bio池.分配数 = 全局Bio池.分配数 + 1
    返回 bio
}

函数 bio_释放(bio) {
    如果 (bio == 空) { 返回 }

    定义 旧值 = 原子_减(bio.引用计数, 1)
    如果 (旧值 - 1 > 0) { 返回 }  // 仍有引用

    // 归还到池
    自旋锁_获取(全局Bio池.锁)
    如果 (全局Bio池.空闲数 < BIO_池_大小) {
        bio.下一个 = 全局Bio池.空闲链表
        全局Bio池.空闲链表 = bio
        全局Bio池.空闲数 = 全局Bio池.空闲数 + 1
        自旋锁_释放(全局Bio池.锁)
        返回
    }
    自旋锁_释放(全局Bio池.锁)

    释放内存(bio)
}

函数 bio_获取(bio) {
    原子_加(bio.引用计数, 1)
}

// §4 BIO向量操作

函数 bio_添加页(bio, 页, 偏移, 长度) {
    如果 (bio == 空 || bio.向量数 >= bio.最大向量数) { 返回 错误_无空间 }
    bio.向量列表[bio.向量数].页 = 页
    bio.向量列表[bio.向量数].偏移 = 偏移
    bio.向量列表[bio.向量数].长度 = 长度
    bio.向量数 = bio.向量数 + 1
    bio.大小 = bio.大小 + 长度
    返回 0
}

函数 bio_设置设备(bio, 设备, 扇区) {
    如果 (bio == 空) { 返回 }
    bio.设备 = 设备
    bio.扇区 = 扇区
}

函数 bio_设置标志(bio, 标志) {
    如果 (bio == 空) { 返回 }
    bio.标志 = bio.标志 | 标志
}

函数 bio_是读(bio) {
    如果 (bio == 空) { 返回 假 }
    返回 (bio.标志 & BIO_标志_写) == 0
}

函数 bio_是写(bio) {
    如果 (bio == 空) { 返回 假 }
    返回 (bio.标志 & BIO_标志_写) != 0
}

函数 bio_是同步(bio) {
    如果 (bio == 空) { 返回 假 }
    返回 (bio.标志 & BIO_标志_同步) != 0
}

// §5 BIO提交与完成

定义 可变 bio_提交总数 = 0
定义 可变 bio_完成总数 = 0
定义 可变 bio_错误总数 = 0
定义 可变 bio_读总字节 = 0
定义 可变 bio_写总字节 = 0

函数 bio_提交(bio) {
    如果 (bio == 空 || bio.设备 == 空) { 返回 错误_无效参数 }
    bio.提交时间 = 读取纳秒()
    bio_提交总数 = bio_提交总数 + 1
    如果 (bio_是读(bio)) { bio_读总字节 = bio_读总字节 + bio.大小 }
    否则 { bio_写总字节 = bio_写总字节 + bio.大小 }
    返回 0
}

函数 bio_完成(bio, 错误码) {
    如果 (bio == 空) { 返回 }
    bio.错误 = 错误码
    bio_完成总数 = bio_完成总数 + 1
    如果 (错误码 != 0) { bio_错误总数 = bio_错误总数 + 1 }
    如果 (bio.完成回调 != 空) { bio.完成回调(bio) }
    bio_释放(bio)
}

函数 bio_设置完成回调(bio, 回调) {
    如果 (bio == 空) { 返回 }
    bio.完成回调 = 回调
}

// §6 BIO标志名称

函数 bio_标志名(标志) {
    定义 可变 s = ""
    如果 ((标志 & BIO_标志_写) == 0) { s = s + "READ " }
    否则 { s = s + "WRITE " }
    如果 (标志 & BIO_标志_FLUSH) { s = s + "FLUSH " }
    如果 (标志 & BIO_标志_FUA) { s = s + "FUA " }
    如果 (标志 & BIO_标志_DISCARD) { s = s + "DISCARD " }
    如果 (标志 & BIO_标志_同步) { s = s + "SYNC " }
    返回 s
}

// §7 BIO统计与健康检查

函数 bio_统计() {
    返回 {
        池空闲: 全局Bio池.空闲数,
        总分配: 全局Bio池.分配数,
        提交: bio_提交总数,
        完成: bio_完成总数,
        错误: bio_错误总数,
        读字节: bio_读总字节,
        写字节: bio_写总字节,
    }
}

函数 bio_健康检查() {
    定义 可变 问题 = []
    如果 (全局Bio池.空闲数 == 0) { 追加(问题, "BIO池已耗尽") }
    如果 (bio_错误总数 > bio_提交总数 / 10 && bio_提交总数 > 100) {
        追加(问题, "BIO错误率过高: " + 整数转字符串(bio_错误总数))
    }
    如果 (bio_提交总数 > bio_完成总数 + 1000) {
        追加(问题, "BIO积压过多: " + 整数转字符串(bio_提交总数 - bio_完成总数))
    }
    如果 (计数(问题) == 0) { 返回 "BIO子系统健康" }
    返回 问题
}

函数 bio_重置统计() {
    bio_提交总数 = 0
    bio_完成总数 = 0
    bio_错误总数 = 0
    bio_读总字节 = 0
    bio_写总字节 = 0
}

函数 bio_完整统计() {
    返回 [bio_提交总数, bio_完成总数, bio_错误总数, bio_读总字节, bio_写总字节, 全局Bio池.空闲数]
}

函数 bio_读写比() {
    如果 (bio_写总字节 == 0) { 返回 0 }
    返回 bio_读总字节 * 100 / bio_写总字节
}

函数 bio_平均大小() {
    如果 (bio_提交总数 == 0) { 返回 0 }
    返回 (bio_读总字节 + bio_写总字节) / bio_提交总数
}

// §8 兼容辅助

定义 错误_无空间 = -28
定义 错误_无效参数 = -22

函数 分配内存(大小) { 返回 堆_分配(大小) }
函数 释放内存(指针) { 堆_释放(指针) }
函数 取小(a, b) { 如果 (a < b) { 返回 a }; 返回 b }
函数 读取纳秒() { 返回 获取纳秒时间戳() }

定义 可变 AI_块输入输出_运行指标 = 0
定义 可变 AI_块输入输出_异常指标 = 0

函数 AI_块输入输出_自诊断() {
    AI_块输入输出_运行指标 = bio_提交总数
    返回 AI_块输入输出_运行指标
}

函数 AI_块输入输出_优化建议() {
    定义 指标 = AI_块输入输出_自诊断()
    如果 (AI_块输入输出_运行指标 > 10000) { 返回 "块输入输出负载较高" }
    返回 "块输入输出状态正常"
}

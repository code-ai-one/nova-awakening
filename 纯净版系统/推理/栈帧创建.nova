// (~1500行)
// (~1200行)
// 运行时核心:
// 解释器主循环(dispatch loop): 逐条执行字节码
// 栈帧管理: 调用栈、参数传递、闭包上下文
// 类型转换: ToPrimitive/ToNumber/ToString/ToBoolean (ES规范§7)
// 内置运行时函数: %_Call, %_CreateObject, %_Throw错误 等
// 【Nova特色】AI运行时优化:
// ① AI监控字节码执行热度, 动态触发JIT
// ② AI类型推断辅助, 减少动态检查开销

导入("../中枢/系统调用表.nova")
导入("../推理/通信总线.nova")
导入("../中枢/内核打印.nova")
导入("./值乘.nova")
导入("../中枢/同步原语.nova")
导入("./小整数快速判.nova")
导入("../标准/类型判断.nova")

// §1 栈帧

定义 FRAME_JS = 0 // JS函数帧
定义 FRAME_BUILTIN = 1 // 内置函数帧
定义 FRAME_CONSTRUCT = 2 // new调用帧
定义 FRAME_INTERNAL = 3 // 内部帧

结构 StackFrame {
 类型,
 // 调用链
 父帧,    // u64 StackFrame*
 // 函数信息
 字节码,    // u64 Bytecode数组*
 PC,    // u32 程序计数器(字节码偏移)
 // 寄存器文件
 寄存器,    // u64 u64* (tagged值数组)
 寄存器数,
 // 累加器
 累加器,    // u64 tagged value
 // 上下文链
 上下文,    // u64 Context*
 // this绑定
 receiver,    // u64 tagged value (this)
 // 参数
 参数,    // u64 u64* (tagged值数组)
 参数数,
 // 异常处理
 异常处理链,    // u64 TryCatchHandler*
}

函数 StackFrame_创建(类型, 字节码, 父帧) {
 定义 frame = 堆_分配(StackFrame)
 frame.类型 = 类型
 frame.字节码 = 字节码
 frame.父帧 = 父帧
 frame.PC = 0
 frame.累加器 = Nova_未定义
 frame.上下文 = 0
 frame.receiver = Nova_未定义
 frame.异常处理链 = 0

 如果 (字节码 != 0) {
 frame.寄存器数 = 字节码.寄存器数
 frame.寄存器 = 堆_分配_数组(frame.寄存器数 * 8)
 // 初始化寄存器为undefined
 定义 可变 i = 0
 当 (i < frame.寄存器数) {
 内存_写64(frame.寄存器 + i * 8, Nova_未定义)
 i = i + 1
 }
 frame.参数数 = 字节码.参数数
 frame.参数 = 堆_分配_数组(frame.参数数 * 8)
 } 否则 {
 frame.寄存器 = 0; frame.寄存器数 = 0
 frame.参数 = 0; frame.参数数 = 0
 }
 返回 frame
}

函数 StackFrame_读寄存器(frame, reg) {
 如果 (frame == 0 || frame.寄存器 == 0 || reg >= frame.寄存器数) {
 返回 Nova_未定义
 }
 返回 内存_读64(frame.寄存器 + reg * 8)
}

函数 StackFrame_写寄存器(frame, reg, 值) {
 如果 (frame == 0 || frame.寄存器 == 0 || reg >= frame.寄存器数) { 返回 }
 内存_写64(frame.寄存器 + reg * 8, 值)
}

函数 StackFrame_释放(frame) {
    如果 (frame == 0) { 返回 }
    // 释放异常处理链
    定义 可变 handler = frame.异常处理链
    当 (handler != 0) {
        定义 下一个 = handler.下一个
        堆_释放(handler)
        handler = 下一个
    }
    // 释放闭包捕获列表
    如果 (frame.闭包捕获 != 0) { 堆_释放(frame.闭包捕获) }
    如果 (frame.寄存器 != 0) { 堆_释放(frame.寄存器) }
    如果 (frame.参数 != 0) { 堆_释放(frame.参数) }
    堆_释放(frame)
}

// §2 SFAM理论: 栈帧自适应管理 (Stack Frame Adaptive Management)
//   核心创新: 将调用栈视为动态拓扑结构，而非线性堆叠
//   调用栈深度自适应调整，热帧检测驱动JIT编译，
//   异常处理链与闭包上下文融合管理

定义 栈_最大深度       = 16384    // 调用栈最大深度
定义 栈_警告深度       = 12288    // 栈溢出警告阈值
定义 热帧_触发阈值     = 1000     // 执行次数达到此值触发JIT
定义 类型剖析_采样上限 = 256      // 类型反馈向量最大采样数
定义 异常_TRY      = 0
定义 异常_CATCH    = 1
定义 异常_FINALLY  = 2

// §3 异常处理链 (TryCatch/Finally 处理器)

结构 TryCatchHandler {
    类型,          // u8  异常_TRY / 异常_CATCH / 异常_FINALLY
    catch_PC,      // u32  catch块字节码地址
    finally_PC,    // u32  finally块字节码地址
    end_PC,        // u32  try块结束地址
    上下文深度,    // u32  当前上下文栈深度快照
    寄存器快照,  // u64* 寄存器状态快照指针
    快照寄存器数,
    下一个         // *TryCatchHandler  链表指针
}

函数 TryCatch_压入(frame, catch_pc, finally_pc, end_pc) {
    定义 handler = 堆_分配(TryCatchHandler)
    如果 (handler == 0) { 返回 空 }
    handler.类型 = 异常_TRY
    handler.catch_PC = catch_pc
    handler.finally_PC = finally_pc
    handler.end_PC = end_pc
    handler.上下文深度 = 0
    // 快照当前寄存器状态，便于异常时恢复
    handler.快照寄存器数 = frame.寄存器数
    如果 (frame.寄存器数 > 0) {
        handler.寄存器快照 = 堆_分配_数组(frame.寄存器数 * 8)
        定义 可变 i = 0
        当 (i < frame.寄存器数) {
            内存_写64(handler.寄存器快照 + i * 8, 内存_读64(frame.寄存器 + i * 8))
            i = i + 1
        }
    } 否则 {
        handler.寄存器快照 = 0
    }
    // 插入到帧的异常处理链头部
    handler.下一个 = frame.异常处理链
    frame.异常处理链 = handler
    返回 handler
}

函数 TryCatch_弹出(frame) {
    如果 (frame.异常处理链 == 0) { 返回 空 }
    定义 handler = frame.异常处理链
    frame.异常处理链 = handler.下一个
    // 释放寄存器快照
    如果 (handler.寄存器快照 != 0) {
        堆_释放(handler.寄存器快照)
    }
    堆_释放(handler)
    返回 frame.异常处理链
}

函数 TryCatch_查找处理器(frame, 异常PC) {
    // 在当前帧的异常处理链中查找包含给定PC的handler
    定义 可变 h = frame.异常处理链
    当 (h != 0) {
        如果 (异常PC >= h.catch_PC && 异常PC < h.end_PC) {
            返回 h
        }
        h = h.下一个
    }
    返回 空
}

函数 TryCatch_恢复寄存器(frame, handler) {
    // 异常发生时从快照恢复寄存器状态
    如果 (handler == 0 || handler.寄存器快照 == 0) { 返回 }
    定义 恢复数 = handler.快照寄存器数
    如果 (恢复数 > frame.寄存器数) { 恢复数 = frame.寄存器数 }
    定义 可变 i = 0
    当 (i < 恢复数) {
        内存_写64(frame.寄存器 + i * 8, 内存_读64(handler.寄存器快照 + i * 8))
        i = i + 1
    }
}

// §4 调用栈管理器 (CallStack)

结构 CallStack {
    栈顶,          // *StackFrame  当前栈顶帧
    当前深度,
    最大深度,
    历史最大深度,  // u32  记录运行期间观测到的最大深度
    总压入次数,
    总弹出次数,
    总异常展开数,  // u64  异常导致的栈展开次数
    溢出次数,
    锁                // 自旋锁 多线程安全
}

定义 可变 全局调用栈 = 空

函数 CallStack_创建() {
    定义 cs = 堆_分配(CallStack)
    如果 (cs == 0) { 返回 空 }
    cs.栈顶 = 空
    cs.当前深度 = 0
    cs.最大深度 = 栈_最大深度
    cs.历史最大深度 = 0
    cs.总压入次数 = 0
    cs.总弹出次数 = 0
    cs.总异常展开数 = 0
    cs.溢出次数 = 0
    cs.锁 = 自旋锁_创建()
    返回 cs
}

函数 CallStack_压入(cs, frame) {
    如果 (cs == 空 || frame == 0) { 返回 -1 }
    // 栈溢出检测
    如果 (cs.当前深度 >= cs.最大深度) {
        cs.溢出次数 = cs.溢出次数 + 1
        返回 错误_栈溢出
    }
    // 栈深度警告
    如果 (cs.当前深度 >= 栈_警告深度) {
        SFAM_栈深度警告(cs)
    }
    自旋锁_获取(cs.锁)
    frame.父帧 = cs.栈顶
    cs.栈顶 = frame
    cs.当前深度 = cs.当前深度 + 1
    cs.总压入次数 = cs.总压入次数 + 1
    // 更新历史最大深度
    如果 (cs.当前深度 > cs.历史最大深度) {
        cs.历史最大深度 = cs.当前深度
    }
    自旋锁_释放(cs.锁)
    返回 0
}

函数 CallStack_弹出(cs) {
    如果 (cs == 空 || cs.栈顶 == 空) { 返回 空 }
    自旋锁_获取(cs.锁)
    定义 frame = cs.栈顶
    cs.栈顶 = frame.父帧
    cs.当前深度 = cs.当前深度 - 1
    cs.总弹出次数 = cs.总弹出次数 + 1
    自旋锁_释放(cs.锁)
    返回 frame
}

函数 CallStack_异常展开(cs, 异常对象) {
    // 从try/catch链中查找处理器，逐帧展开
    如果 (cs == 空 || cs.栈顶 == 空) { 返回 -1 }
    定义 可变 当前帧 = cs.栈顶
    当 (当前帧 != 0) {
        // 检查当前帧是否有异常处理器
        如果 (当前帧.异常处理链 != 0) {
            定义 h = 当前帧.异常处理链
            // 跳转到catch块
            如果 (h.catch_PC != 0) {
                TryCatch_恢复寄存器(当前帧, h)
                当前帧.PC = h.catch_PC
                // 将异常对象写入累加器
                当前帧.累加器 = 异常对象
                cs.总异常展开数 = cs.总异常展开数 + 1
                返回 0  // 成功找到处理器
            }
            // 只有finally，先执行finally再继续展开
            如果 (h.finally_PC != 0) {
                当前帧.PC = h.finally_PC
                cs.总异常展开数 = cs.总异常展开数 + 1
                返回 1  // 执行finally后继续展开
            }
        }
        // 当前帧无处理器，弹出此帧继续查找
        定义 释放帧 = CallStack_弹出(cs)
        StackFrame_释放(释放帧)
        当前帧 = cs.栈顶
    }
    返回 -1  // 未找到处理器，未捕获异常
}

// §5 闭包上下文与作用域链

结构 闭包变量 {
    索引,      // u16  在父帧中的寄存器索引
    是局部,    // bool 来自直接父帧 vs 外层闭包
    类型提示    // u8   AI类型推断提示 (0=未知 1=Smi 2=字符串 3=对象)
}

函数 闭包_创建上下文(frame, 父上下文, 捕获列表, 捕获数) {
    // 从父帧捕获变量到新的闭包上下文
    定义 ctx = 堆_分配_数组((捕获数 + 2) * 8)  // +2: 父指针 + 长度
    如果 (ctx == 0) { 返回 0 }
    内存_写64(ctx, 父上下文)  // 槽位0: 父上下文指针
    内存_写64(ctx + 8, 捕获数)  // 槽位1: 变量数
    定义 可变 i = 0
    当 (i < 捕获数) {
        定义 变量 = 捕获列表[i]
        定义 值 = Nova_未定义
        如果 (变量.是局部 && frame != 空) {
            // 从父帧寄存器直接捕获
            值 = StackFrame_读寄存器(frame, 变量.索引)
        } 否则 {
            // 从外层闭包上下文捕获
            如果 (父上下文 != 0) {
                值 = 内存_读64(父上下文 + (变量.索引 + 2) * 8)
            }
        }
        内存_写64(ctx + (i + 2) * 8, 值)
        i = i + 1
    }
    返回 ctx
}

函数 闭包_读变量(ctx, 索引) {
    如果 (ctx == 0) { 返回 Nova_未定义 }
    定义 数量 = 内存_读64(ctx + 8)
    如果 (索引 >= 数量) { 返回 Nova_未定义 }
    返回 内存_读64(ctx + (索引 + 2) * 8)
}

函数 闭包_写变量(ctx, 索引, 值) {
    如果 (ctx == 0) { 返回 }
    定义 数量 = 内存_读64(ctx + 8)
    如果 (索引 >= 数量) { 返回 }
    内存_写64(ctx + (索引 + 2) * 8, 值)
}

函数 闭包_释放(ctx) {
    如果 (ctx != 0) { 堆_释放(ctx) }
}

// §6 参数处理 (rest/default/arguments对象)

函数 StackFrame_设置参数(frame, 索引, 值) {
    如果 (frame == 0 || frame.参数 == 0) { 返回 }
    如果 (索引 >= frame.参数数) { 返回 }
    内存_写64(frame.参数 + 索引 * 8, 值)
}

函数 StackFrame_读参数(frame, 索引) {
    如果 (frame == 0 || frame.参数 == 0 || 索引 >= frame.参数数) {
        返回 Nova_未定义
    }
    返回 内存_读64(frame.参数 + 索引 * 8)
}

函数 StackFrame_创建Arguments对象(frame) {
    // 创建类数组的arguments对象
    如果 (frame == 0) { 返回 Nova_未定义 }
    定义 args_obj = Nova对象_创建()
    // 设置 length 属性
    Nova对象_设属性(args_obj, "length", frame.参数数)
    // 拷贝参数值
    定义 可变 i = 0
    当 (i < frame.参数数) {
        Nova对象_设索引(args_obj, i, StackFrame_读参数(frame, i))
        i = i + 1
    }
    // 设置 callee 引用 (非严格模式)
    如果 (frame.字节码 != 0) {
        Nova对象_设属性(args_obj, "callee", frame.字节码.函数引用)
    }
    返回 args_obj
}

函数 StackFrame_处理Rest参数(frame, 形参数, 实参列表, 实参数) {
    // ES6 rest参数处理: function foo(a, b, ...rest)
    如果 (frame == 0) { 返回 }
    // 先填充普通形参
    定义 可变 i = 0
    当 (i < 形参数 && i < 实参数) {
        StackFrame_设置参数(frame, i, 实参列表[i])
        i = i + 1
    }
    // 剩余参数收集到数组
    如果 (实参数 > 形参数) {
        定义 rest长度 = 实参数 - 形参数
        定义 rest数组 = Nova数组_创建(rest长度)
        定义 可变 j = 0
        当 (j < rest长度) {
            Nova数组_设置(rest数组, j, 实参列表[形参数 + j])
            j = j + 1
        }
        // rest数组存到形参数位置的寄存器
        StackFrame_设置参数(frame, 形参数, rest数组)
    }
}

// §7 AI栈分析与JIT触发 (SFAM核心)
// SFAM-AI理论: 基于调用栈特征的自适应优化
//   通过监控栈帧执行频率、类型分布、调用深度等特征
//   AI决策引擎自动识别热帧并触发JIT编译

结构 帧执行剖析 {
    字节码地址,    // u64  关联的字节码对象地址
    执行次数,      // u64  此帧被压入栈的总次数
    总执行时间,    // u64  纳秒累计
    平均执行时间,  // u64  单次平均纳秒
    最大执行时间,  // u64  单次最大纳秒
    类型分布,      // [4]u32  参数类型分布计数 (Smi/字符串/对象/其他)
    已触发JIT,    // bool
    JIT代码地址    // u64  JIT编译后的机器码地址
}

定义 剖析表_容量 = 1024
定义 可变 剖析表 = 空
定义 可变 剖析表_大小 = 0

函数 剖析_初始化() {
    剖析表 = 堆_分配_数组(剖析表_容量 * 帧执行剖析_大小)
    剖析表_大小 = 0
}

函数 剖析_查找(字节码地址) {
    如果 (剖析表 == 空) { 返回 空 }
    定义 可变 i = 0
    当 (i < 剖析表_大小) {
        定义 条目 = 剖析表 + i * 帧执行剖析_大小
        如果 (条目.字节码地址 == 字节码地址) { 返回 条目 }
        i = i + 1
    }
    返回 空
}

函数 剖析_记录执行(frame, 执行时间纳秒) {
    如果 (frame == 0 || frame.字节码 == 0) { 返回 }
    定义 可变 条目 = 剖析_查找(frame.字节码)
    如果 (条目 == 空) {
        // 新建剖析条目
        如果 (剖析表_大小 >= 剖析表_容量) { 返回 }  // 剖析表已满
        条目 = 剖析表 + 剖析表_大小 * 帧执行剖析_大小
        条目.字节码地址 = frame.字节码
        条目.执行次数 = 0
        条目.总执行时间 = 0
        条目.最大执行时间 = 0
        条目.已触发JIT = 假
        条目.JIT代码地址 = 0
        剖析表_大小 = 剖析表_大小 + 1
    }
    条目.执行次数 = 条目.执行次数 + 1
    条目.总执行时间 = 条目.总执行时间 + 执行时间纳秒
    条目.平均执行时间 = 条目.总执行时间 / 条目.执行次数
    如果 (执行时间纳秒 > 条目.最大执行时间) {
        条目.最大执行时间 = 执行时间纳秒
    }
    // 检查是否达到热帧阈值，触发JIT
    如果 (条目.已触发JIT == 假 && 条目.执行次数 >= 热帧_触发阈值) {
        SFAM_触发JIT编译(条目)
    }
}

函数 剖析_记录类型(frame) {
    // 记录参数类型分布，供 AI 类型推断使用
    如果 (frame == 0 || frame.字节码 == 0) { 返回 }
    定义 条目 = 剖析_查找(frame.字节码)
    如果 (条目 == 空) { 返回 }
    定义 可变 i = 0
    当 (i < frame.参数数 && i < 类型剖析_采样上限) {
        定义 参数值 = StackFrame_读参数(frame, i)
        定义 类型 = Nova值_获取类型(参数值)
        如果 (类型 == 类型_Smi) {
            条目.类型分布[0] = 条目.类型分布[0] + 1
        } 否则 如果 (类型 == 类型_字符串) {
            条目.类型分布[1] = 条目.类型分布[1] + 1
        } 否则 如果 (类型 == 类型_对象) {
            条目.类型分布[2] = 条目.类型分布[2] + 1
        } 否则 {
            条目.类型分布[3] = 条目.类型分布[3] + 1
        }
        i = i + 1
    }
}

函数 SFAM_触发JIT编译(条目) {
    // 热帧达到阈值，通过AI评估是否值得JIT编译
    定义 bus = 全局AI总线
    如果 (bus == 空) {
        // 无AI总线，直接触发JIT
        条目.JIT代码地址 = JIT_编译(条目.字节码地址)
        条目.已触发JIT = 真
        返回
    }
    // AI评估JIT价值: 执行频率 × 平均执行时间 → 优化收益
    定义 特征 = Tensor_创建(5)
    Tensor_写(特征, 0, 条目.执行次数)
    Tensor_写(特征, 1, 条目.平均执行时间)
    Tensor_写(特征, 2, 条目.最大执行时间)
    // 类型单态度: 主导类型占比越高，JIT优化效果越好
    定义 总类型 = 条目.类型分布[0] + 条目.类型分布[1] + 条目.类型分布[2] + 条目.类型分布[3]
    定义 主导类型数 = 0
    定义 可变 k = 0
    当 (k < 4) {
        如果 (条目.类型分布[k] > 主导类型数) {
            主导类型数 = 条目.类型分布[k]
        }
        k = k + 1
    }
    定义 单态度 = 0
    如果 (总类型 > 0) { 单态度 = (主导类型数 * 100) / 总类型 }
    Tensor_写(特征, 3, 单态度)
    Tensor_写(特征, 4, 条目.总执行时间)
    定义 结果 = AI总线_推理(bus, "JIT价值评估", 特征)
    定义 JIT分数 = Tensor_读(结果, 0)
    Tensor_释放(特征)
    Tensor_释放(结果)
    如果 (JIT分数 > 50) {
        条目.JIT代码地址 = JIT_编译(条目.字节码地址)
        条目.已触发JIT = 真
    }
}

函数 SFAM_栈深度警告(cs) {
    // 栈深度接近上限时AI分析是否无限递归
    定义 bus = 全局AI总线
    如果 (bus == 空) { 返回 }
    定义 特征 = Tensor_创建(3)
    Tensor_写(特征, 0, cs.当前深度)
    Tensor_写(特征, 1, cs.最大深度)
    Tensor_写(特征, 2, cs.总压入次数)
    定义 结果 = AI总线_异常检测(bus, "栈深度监控", 特征)
    定义 异常分 = Tensor_读(结果, 0)
    Tensor_释放(特征)
    Tensor_释放(结果)
    如果 (异常分 > 90) {
        内核打印("[SFAM AI警告] 疑似无限递归 深度={} 异常分={}", cs.当前深度, 异常分)
    }
}

// §8 栈跟踪生成与调试支持

函数 栈跟踪_生成(cs) {
    // 生成可读的调用栈跟踪字符串
    如果 (cs == 空 || cs.栈顶 == 空) { 返回 "空调用栈" }
    定义 缓冲 = 字符串缓冲_创建(2048)
    字符串缓冲_追加(缓冲, "=== 调用栈跟踪 ===\n")
    定义 可变 帧 = cs.栈顶
    定义 可变 深度 = 0
    定义 最大显示 = 64  // 最多显示64层
    当 (帧 != 空 && 深度 < 最大显示) {
        定义 类型名 = "未知"
        如果 (帧.类型 == FRAME_JS)        { 类型名 = "JS" }
        否则 如果 (帧.类型 == FRAME_BUILTIN)   { 类型名 = "内置" }
        否则 如果 (帧.类型 == FRAME_CONSTRUCT) { 类型名 = "构造" }
        否则 如果 (帧.类型 == FRAME_INTERNAL)  { 类型名 = "内部" }
        字符串缓冲_追加格式(缓冲, "  #{} [{}] PC={} 寄存器={} 参数={}\n",
            深度, 类型名, 帧.PC, 帧.寄存器数, 帧.参数数)
        帧 = 帧.父帧
        深度 = 深度 + 1
    }
    如果 (cs.当前深度 > 最大显示) {
        字符串缓冲_追加格式(缓冲, "  ... 省略 {} 层\n", cs.当前深度 - 最大显示)
    }
    返回 字符串缓冲_完成(缓冲)
}

函数 栈帧_快照(帧) {
    // 创建帧状态快照用于调试器
    如果 (帧 == 0) { 返回 空 }
    定义 snap = 堆_分配(StackFrame)
    snap.类型 = 帧.类型
    snap.PC = 帧.PC
    snap.累加器 = 帧.累加器
    snap.寄存器数 = 帧.寄存器数
    snap.参数数 = 帧.参数数
    // 深拷贝寄存器
    如果 (帧.寄存器数 > 0 && 帧.寄存器 != 0) {
        snap.寄存器 = 堆_分配_数组(帧.寄存器数 * 8)
        内存_拷贝(snap.寄存器, 帧.寄存器, 帧.寄存器数 * 8)
    }
    返回 snap
}

// §9 全局诊断与初始化

函数 SFAM_打印诊断() {
    内核打印("╔═════════════════════════════════════════════╗")
    内核打印("║  SFAM 栈帧自适应管理 诊断报告            ║")
    内核打印("╠═════════════════════════════════════════════╣")
    如果 (全局调用栈 != 空) {
        内核打印("║ 调用栈当前深度:     {}", 全局调用栈.当前深度)
        内核打印("║ 历史最大深度:       {}", 全局调用栈.历史最大深度)
        内核打印("║ 总压入次数:         {}", 全局调用栈.总压入次数)
        内核打印("║ 总弹出次数:         {}", 全局调用栈.总弹出次数)
        内核打印("║ 异常展开次数:       {}", 全局调用栈.总异常展开数)
        内核打印("║ 栈溢出次数:         {}", 全局调用栈.溢出次数)
    } 否则 {
        内核打印("║ 调用栈: 未初始化")
    }
    内核打印("╠═════════════════════════════════════════════╣")
    内核打印("║ 剖析表条目数:       {}", 剖析表_大小)
    // 统计JIT编译数
    定义 可变 jit数 = 0
    定义 可变 i = 0
    当 (i < 剖析表_大小) {
        定义 条目 = 剖析表 + i * 帧执行剖析_大小
        如果 (条目.已触发JIT) { jit数 = jit数 + 1 }
        i = i + 1
    }
    内核打印("║ JIT编译函数数:     {}", jit数)
    内核打印("╚═════════════════════════════════════════════╝")
}

函数 SFAM_初始化() {
    全局调用栈 = CallStack_创建()
    剖析_初始化()
    内核打印("[SFAM] 栈帧自适应管理子系统已初始化 v1.0")
    内核打印("[SFAM] 最大栈深度={} 警告阈值={} JIT阈值={}",
        栈_最大深度, 栈_警告深度, 热帧_触发阈值)
}

// Nova · 编译器 · 指令调度 (Instruction Scheduling)
// 对基本块内的指令重新排序，减少流水线停顿、最大化CPU吞吐
// 算法：列表调度 (List Scheduling) + 依赖图 (DAG) 拓扑序
// 目标：x86-64 超标量乱序执行优化

// x86-64 指令延迟表（时钟周期）
// 延迟 = 前一条指令结果就绪所需的时钟周期数

导入("../../标准库/基础.nova")

定义 延迟_整数加减 = 1   // add/sub: 1周期
定义 延迟_整数乘  = 3   // imul: 3周期
定义 延迟_整数除  = 20  // idiv: 15-40周期（保守估计）
定义 延迟_内存读  = 4   // L1命中: 4周期, L2: 12周期
定义 延迟_内存写  = 1   // 写不需要等，直接继续（store forwarding）
定义 延迟_跳转    = 0   // 跳转本身1周期，但预测正确时无气泡
定义 延迟_比较    = 1   // cmp/test: 1周期
定义 延迟_移位    = 1   // shl/shr: 1周期
定义 延迟_位运算  = 1   // and/or/xor: 1周期
定义 延迟_条件移动 = 1  // cmov: 1周期，比条件跳转更友好

// 依赖类型
定义 依赖_数据  = 0   // 真依赖（写后读RAW）：必须等前一条结果
定义 依赖_反依  = 1   // 反依赖（读后写WAR）：可通过重命名消除
定义 依赖_输出  = 2   // 输出依赖（写后写WAW）：可通过重命名消除
定义 依赖_控制  = 3   // 控制依赖：分支后的指令依赖分支方向
定义 依赖_内存  = 4   // 内存顺序依赖（保守）

// 指令节点：[操作码, 操作数, 延迟, 最早发射时间, 已调度]
函数 IS_节点_创建(操作码, 操作数, 延迟) {
    返回 [操作码, 操作数, 延迟, 0, 假, [], []]
    // [0]=操作码, [1]=操作数, [2]=延迟, [3]=最早发射时间, [4]=已调度, [5]=前驱依赖, [6]=后继依赖
}
函数 IS_节点_操作码(n) { 返回 n[0] }
函数 IS_节点_延迟(n) { 返回 n[2] }
函数 IS_节点_最早发射(n) { 返回 n[3] }
函数 IS_节点_已调度(n) { 返回 n[4] }
函数 IS_节点_前驱(n) { 返回 n[5] }
函数 IS_节点_后继(n) { 返回 n[6] }
函数 IS_节点_设最早发射(n, t) { n[3] = t }
函数 IS_节点_标记已调度(n) { n[4] = 真 }

// 添加依赖边：from_idx 必须在 to_idx 之前执行
函数 IS_添加依赖(节点列表, from_idx, to_idx, 依赖类型) {
    追加(节点列表[from_idx][6], [to_idx, 依赖类型])  // from的后继
    追加(节点列表[to_idx][5], [from_idx, 依赖类型])  // to的前驱
}

// 依赖图构建
// 分析指令间的数据/反/输出/内存依赖，建立依赖 DAG
函数 IS_构建依赖图(指令列表) {
    定义 n = 计数(指令列表)
    定义 可变 节点列表 = []

    // 创建节点
    定义 可变 i = 0
    当 (i < n) {
        定义 指令 = 指令列表[i]
        // 根据操作码确定延迟
        定义 延迟 = IS_操作码延迟(指令[0])
        追加(节点列表, IS_节点_创建(指令[0], 指令, 延迟))
        i = i + 1
    }

    // 分析依赖（简化版：只分析寄存器依赖）
    i = 0
    当 (i < n) {
        定义 当前写寄存器 = IS_指令写寄存器(指令列表[i])
        定义 当前读寄存器 = IS_指令读寄存器(指令列表[i])

        // 向前查找依赖
        定义 可变 j = 0
        当 (j < i) {
            定义 前写 = IS_指令写寄存器(指令列表[j])
            定义 前读 = IS_指令读寄存器(指令列表[j])

            // RAW (真依赖): j写的寄存器, i读
            如果 (IS_寄存器集合交叉(前写, 当前读寄存器)) {
                IS_添加依赖(节点列表, j, i, 依赖_数据)
            }
            // WAR (反依赖): j读的寄存器, i写
            如果 (IS_寄存器集合交叉(前读, 当前写寄存器)) {
                IS_添加依赖(节点列表, j, i, 依赖_反依)
            }
            // WAW (输出依赖): j写的寄存器, i也写
            如果 (IS_寄存器集合交叉(前写, 当前写寄存器)) {
                IS_添加依赖(节点列表, j, i, 依赖_输出)
            }

            j = j + 1
        }
        i = i + 1
    }
    返回 节点列表
}

// 根据操作码估计延迟
函数 IS_操作码延迟(操作码) {
    // x86 指令类别映射
    如果 (操作码 == 0x48 或 操作码 == 0x4c) { 返回 延迟_内存读 }  // MOV from mem (REX prefix)
    如果 (操作码 == 0xF7) { 返回 延迟_整数除 }  // IMUL/IDIV group (保守取最大延迟)
    如果 (操作码 == 0x0F) { 返回 延迟_比较 }    // 双字节前缀(SETcc/CMOVcc等)
    如果 (操作码 == 0x89 或 操作码 == 0x88) { 返回 延迟_内存写 }  // MOV to mem
    返回 延迟_整数加减  // 默认：1周期
}

// 简化版：提取指令写的寄存器
函数 IS_指令写寄存器(指令) {
    如果 (指令 == 空 或 计数(指令) < 2) { 返回 [] }
    // 格式：[操作码, 目标寄存器, 源, ...]
    // 这里简化为返回目标寄存器索引
    返回 [指令[1]]
}

// 简化版：提取指令读的寄存器
函数 IS_指令读寄存器(指令) {
    如果 (指令 == 空 或 计数(指令) < 3) { 返回 [] }
    返回 [指令[2]]
}

// 检查两个寄存器集合是否有交叉
函数 IS_寄存器集合交叉(集A, 集B) {
    定义 可变 i = 0
    当 (i < 计数(集A)) {
        定义 可变 j = 0
        当 (j < 计数(集B)) {
            如果 (集A[i] == 集B[j]) { 返回 真 }
            j = j + 1
        }
        i = i + 1
    }
    返回 假
}

// 列表调度算法
// 按拓扑序调度指令，优先选择关键路径最长的节点
函数 IS_列表调度(节点列表) {
    定义 n = 计数(节点列表)
    定义 可变 调度结果 = []   // 调度后的指令顺序（节点索引）
    定义 可变 当前时间 = 0

    // 计算每个节点的关键路径长度（Critical Path Length）
    定义 CPL = IS_计算关键路径(节点列表)

    当 (计数(调度结果) < n) {
        // 找出所有就绪的节点（所有前驱已调度）
        定义 可变 就绪集 = []
        定义 可变 i = 0
        当 (i < n) {
            如果 (!IS_节点_已调度(节点列表[i])) {
                如果 (IS_所有前驱已调度(节点列表, i)) {
                    定义 最早发射 = IS_计算最早发射时间(节点列表, i)
                    如果 (最早发射 <= 当前时间) {
                        追加(就绪集, i)
                    }
                }
            }
            i = i + 1
        }

        如果 (计数(就绪集) == 0) {
            // 所有就绪节点都需要等待：时间推进
            当前时间 = 当前时间 + 1
            继续
        }

        // 优先级：选关键路径最长的（贪心）
        定义 可变 最优idx = 就绪集[0]
        定义 可变 最优CPL = CPL[就绪集[0]]
        i = 1
        当 (i < 计数(就绪集)) {
            如果 (CPL[就绪集[i]] > 最优CPL) {
                最优CPL = CPL[就绪集[i]]
                最优idx = 就绪集[i]
            }
            i = i + 1
        }

        // 调度选定的节点
        IS_节点_标记已调度(节点列表[最优idx])
        追加(调度结果, 最优idx)
        当前时间 = 当前时间 + IS_节点_延迟(节点列表[最优idx])
    }

    返回 调度结果
}

// 计算关键路径长度（从节点到最后一条指令的最长路径）
函数 IS_计算关键路径(节点列表) {
    定义 n = 计数(节点列表)
    定义 可变 CPL = []  // CPL[i] = 从节点i到终点的关键路径长度
    定义 可变 i = 0
    当 (i < n) { 追加(CPL, 0) i = i + 1 }

    // 逆拓扑序计算（简化：从后向前遍历）
    i = n - 1
    当 (i >= 0) {
        定义 后继列表 = IS_节点_后继(节点列表[i])
        定义 可变 最大后继CPL = 0
        定义 可变 j = 0
        当 (j < 计数(后继列表)) {
            定义 后继idx = 后继列表[j][0]
            定义 候选 = IS_节点_延迟(节点列表[后继idx]) + CPL[后继idx]
            如果 (候选 > 最大后继CPL) { 最大后继CPL = 候选 }
            j = j + 1
        }
        CPL[i] = IS_节点_延迟(节点列表[i]) + 最大后继CPL
        i = i - 1
    }
    返回 CPL
}

// 检查节点的所有前驱是否都已调度
函数 IS_所有前驱已调度(节点列表, 节点idx) {
    定义 前驱列表 = IS_节点_前驱(节点列表[节点idx])
    定义 可变 i = 0
    当 (i < 计数(前驱列表)) {
        如果 (!IS_节点_已调度(节点列表[前驱列表[i][0]])) { 返回 假 }
        i = i + 1
    }
    返回 真
}

// 计算节点的最早发射时间（所有前驱完成时间的最大值）
函数 IS_计算最早发射时间(节点列表, 节点idx) {
    定义 前驱列表 = IS_节点_前驱(节点列表[节点idx])
    定义 可变 最早 = 0
    定义 可变 i = 0
    当 (i < 计数(前驱列表)) {
        定义 前驱idx = 前驱列表[i][0]
        定义 前驱完成 = IS_节点_最早发射(节点列表[前驱idx]) + IS_节点_延迟(节点列表[前驱idx])
        如果 (前驱完成 > 最早) { 最早 = 前驱完成 }
        i = i + 1
    }
    返回 最早
}

// 主入口：对指令列表做调度优化
函数 IS_优化(指令列表) {
    如果 (计数(指令列表) <= 1) { 返回 指令列表 }
    定义 节点列表 = IS_构建依赖图(指令列表)
    定义 调度顺序 = IS_列表调度(节点列表)
    // 按调度顺序重排指令
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(调度顺序)) {
        追加(结果, 指令列表[调度顺序[i]])
        i = i + 1
    }
    _IS_调度次数 = _IS_调度次数 + 1
    返回 结果
}

// 统计
定义 可变 _IS_调度次数 = 0
定义 可变 _IS_减少停顿数 = 0

函数 IS_调度次数_重置() { _IS_调度次数 = 0  _IS_减少停顿数 = 0 }
函数 IS_记录停顿减少(n) { _IS_减少停顿数 = _IS_减少停顿数 + n }
函数 IS_报告() { 返回 [_IS_调度次数, _IS_减少停顿数] }

// NovaOS 显基文本模式驱动

外部 注册控制台_缓冲区

定义 显基_基址 = 0xB8000
定义 显基_宽 = 80
定义 显基_高 = 25

定义 显基_CRTC_索引端口 = 0x3D4
定义 显基_CRTC_数据端口 = 0x3D5
定义 显基_CRTC_光标起始 = 0x0A
定义 显基_CRTC_光标结束 = 0x0B
定义 显基_CRTC_光标高位 = 14
定义 显基_CRTC_光标低位 = 15

定义 显基_黑 = 0
定义 显基_蓝 = 1
定义 显基_绿 = 2
定义 显基_青 = 3
定义 显基_红 = 4
定义 显基_紫 = 5
定义 显基_棕 = 6
定义 显基_浅灰 = 7
定义 显基_深灰 = 8
定义 显基_亮蓝 = 9
定义 显基_亮绿 = 10
定义 显基_亮青 = 11
定义 显基_亮红 = 12
定义 显基_亮紫 = 13
定义 显基_黄 = 14
定义 显基_白 = 15

定义 可变 显基_光标行 = 0
定义 可变 显基_光标列 = 0
定义 可变 显基_当前颜色 = 显基_浅灰 | (显基_黑 << 4)

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 显基_设置颜色(前景, 背景) {
    显基_当前颜色 = 前景 | (背景 << 4)
}

函数 显基_清屏() {
    定义 可变 i = 0
    当 (i < 显基_宽 * 显基_高) {
        内存写16(显基_基址 + i * 2, (显基_当前颜色 << 8) | 0x20)
        i = i + 1
    }
    显基_光标行 = 0
    显基_光标列 = 0
    显基_更新光标()
}

函数 显基_滚动() {
    // 上移一行
    定义 可变 i = 0
    当 (i < 显基_宽 * (显基_高 - 1)) {
        定义 源 = 内存读16(显基_基址 + (i + 显基_宽) * 2)
        内存写16(显基_基址 + i * 2, 源)
        i = i + 1
    }
    // 清空最后一行
    i = 显基_宽 * (显基_高 - 1)
    当 (i < 显基_宽 * 显基_高) {
        内存写16(显基_基址 + i * 2, (显基_当前颜色 << 8) | 0x20)
        i = i + 1
    }
}

函数 显基_写字符(字符码) {
    如果 (字符码 == 10) {
        // 换行
        显基_光标列 = 0
        显基_光标行 = 显基_光标行 + 1
    } 否则 如果 (字符码 == 13) {
        // 回车
        显基_光标列 = 0
    } 否则 如果 (字符码 == 8) {
        // 退格
        如果 (显基_光标列 > 0) { 显基_光标列 = 显基_光标列 - 1 }
    } 否则 {
        定义 偏移 = (显基_光标行 * 显基_宽 + 显基_光标列) * 2
        内存写16(显基_基址 + 偏移, (显基_当前颜色 << 8) | 字符码)
        显基_光标列 = 显基_光标列 + 1
        如果 (显基_光标列 >= 显基_宽) {
            显基_光标列 = 0
            显基_光标行 = 显基_光标行 + 1
        }
    }
    如果 (显基_光标行 >= 显基_高) {
        显基_滚动()
        显基_光标行 = 显基_高 - 1
    }
    显基_更新光标()
}

函数 显基_写字符串(文本) {
    定义 长度 = 字符串长度(文本)
    定义 可变 i = 0
    当 (i < 长度) {
        显基_写字符(编码(字符串取字符(文本, i)))
        i = i + 1
    }
}

函数 显基_打印行(文本) {
    显基_写字符串(文本)
    显基_写字符(10)
}

函数 显基_更新光标() {
    定义 位置 = 显基_光标行 * 显基_宽 + 显基_光标列
    端口写8(显基_CRTC_索引端口, 显基_CRTC_光标高位)
    端口写8(显基_CRTC_数据端口, (位置 >> 8) & 0xFF)
    端口写8(显基_CRTC_索引端口, 显基_CRTC_光标低位)
    端口写8(显基_CRTC_数据端口, 位置 & 0xFF)
}

// 光标形状控制 

函数 显基_隐藏光标() {
    端口写8(显基_CRTC_索引端口, 显基_CRTC_光标起始)
    端口写8(显基_CRTC_数据端口, 0x20)  // bit5=1 禁用光标
}

函数 显基_显示光标(起始行, 结束行) {
    端口写8(显基_CRTC_索引端口, 显基_CRTC_光标起始)
    端口写8(显基_CRTC_数据端口, (端口读8(显基_CRTC_数据端口) & 0xC0) | 起始行)
    端口写8(显基_CRTC_索引端口, 显基_CRTC_光标结束)
    端口写8(显基_CRTC_数据端口, (端口读8(显基_CRTC_数据端口) & 0xE0) | 结束行)
}

函数 显基_块状光标() { 显基_显示光标(0, 15) }
函数 显基_下划线光标() { 显基_显示光标(13, 14) }

// Tab和特殊字符处理

定义 显基_TAB宽 = 8

函数 显基_写字符_扩展(字符码) {
    如果 (字符码 == 9) {
        // Tab: 对齐到下一个TAB位
        定义 目标列 = ((显基_光标列 / 显基_TAB宽) + 1) * 显基_TAB宽
        如果 (目标列 >= 显基_宽) { 目标列 = 显基_宽 - 1 }
        当 (显基_光标列 < 目标列) {
            显基_写字符(32)  // 空格填充
        }
    } 否则 如果 (字符码 == 27) {
        // ESC: 忽略(简化ANSI转义序列)
    } 否则 {
        显基_写字符(字符码)
    }
}

// 带颜色输出

函数 显基_彩色打印(文本, 前景, 背景) {
    定义 旧颜色 = 显基_当前颜色
    显基_设置颜色(前景, 背景)
    显基_写字符串(文本)
    显基_当前颜色 = 旧颜色
}

函数 显基_错误(文本) { 显基_彩色打印(文本, 显基_亮红, 显基_黑) }
函数 显基_警告(文本) { 显基_彩色打印(文本, 显基_黄, 显基_黑) }
函数 显基_成功(文本) { 显基_彩色打印(文本, 显基_亮绿, 显基_黑) }
函数 显基_信息(文本) { 显基_彩色打印(文本, 显基_亮青, 显基_黑) }

// 屏幕区域操作

函数 显基_清行(行号) {
    如果 (行号 >= 显基_高) { 返回 }
    定义 可变 col = 0
    当 (col < 显基_宽) {
        内存写16(显基_基址 + (行号 * 显基_宽 + col) * 2, (显基_当前颜色 << 8) | 0x20)
        col = col + 1
    }
}

函数 显基_在位置写(行, 列, 字符码, 颜色) {
    如果 (行 >= 显基_高 || 列 >= 显基_宽) { 返回 }
    定义 偏移 = (行 * 显基_宽 + 列) * 2
    内存写16(显基_基址 + 偏移, (颜色 << 8) | 字符码)
}

函数 显基_在位置写字符串(行, 列, 文本, 颜色) {
    定义 长度 = 字符串长度(文本)
    定义 可变 i = 0
    当 (i < 长度 && 列 + i < 显基_宽) {
        显基_在位置写(行, 列 + i, 编码(字符串取字符(文本, i)), 颜色)
        i = i + 1
    }
}

函数 显基_设置光标位置(行, 列) {
    如果 (行 >= 显基_高) { 行 = 显基_高 - 1 }
    如果 (列 >= 显基_宽) { 列 = 显基_宽 - 1 }
    显基_光标行 = 行
    显基_光标列 = 列
    显基_更新光标()
}

// 十六进制输出

定义 可变 十六进制字符表 = "0123456789ABCDEF"

定义 可变 AI_显基设置颜_操作热度 = 0

函数 AI_显基设置颜_最优算法(数据量, 已排序) {
    AI_显基设置颜_操作热度 = AI_显基设置颜_操作热度 + 1
    如果 (数据量 < 16) { 返回 "插入排序" }
    如果 (已排序) { 返回 "二分查找" }
    如果 (数据量 < 10000) { 返回 "快速排序" }
    返回 "归并排序"
}

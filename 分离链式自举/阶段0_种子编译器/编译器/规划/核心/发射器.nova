函数 发射_vmovmskps(gpr, ymm) { 发射_vex2(1,  0,  1, 0) 发射(0x50) 发射(0xC0+(gpr&7)*8+(ymm&7)) }
函数 发射_vmovmskpd(gpr, ymm) { 发射_vex2(1, 0, 1, 1) 发射(0x50) 发射(0xC0+(gpr&7)*8+(ymm&7)) }

// --- AVX1 广播/排列/解包 ---
// vbroadcastss ymm — 广播单精度
函数 发射_vbroadcastss_ymm(d, s) {
    发射_vex3(0, 0, 2, 0, 1)
    发射(0x18) 发射(0xC0+(d&7)*8+(s&7))
}
// vbroadcastsd ymm — 广播双精度
函数 发射_vbroadcastsd(d, s) {
    发射_vex3(0, 0, 2, 0, 1)
    发射(0x19) 发射(0xC0+(d&7)*8+(s&7))
}
// vpermilps ymm — 通道内排列
函数 发射_vpermilps(d, s1, s2) {
    发射_vex3(0, s1, 2, 0, 1)
    发射(0x0C) 发射(0xC0+(d&7)*8+(s2&7))
}
// vperm2f128 ymm — 128位通道排列
函数 发射_vperm2f128(d, s1, s2, imm) {
    发射_vex3(0, s1, 3, 0, 1)
    发射(0x06) 发射(0xC0+(d&7)*8+(s2&7)) 发射(imm)
}

// §5 端口初始化

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 AHCI_初始化端口(ctl, 端口号) {
    定义 端口基 = ctl.MMIO基址 + 0x100 + 端口号 * 0x80

    // 检查设备是否存在(SSTS: DET=3表示已建立通信)
    定义 ssts = MMIO读32(端口基 + PORT_SSTS)
    定义 det = ssts & 0xF
    定义 ipm = (ssts >> 8) & 0xF
    如果 (det != 3 || ipm != 1) {
        返回  // 无设备或未激活
    }

    // 停止命令引擎
    AHCI_停止命令引擎(端口基)

    // 分配命令列表(1KB, 1KB对齐)
    定义 cmd_list = 直传_分配_对齐(1024, 1024)
    内存填零(cmd_list, 1024)

    // 分配FIS接收区(256字节, 256字节对齐)
    定义 fis_area = 直传_分配_对齐(256, 256)
    内存填零(fis_area, 256)

    // 设置地址
    MMIO写32(端口基 + PORT_CLB, cmd_list & 0xFFFFFFFF)
    MMIO写32(端口基 + PORT_CLBU, (cmd_list >> 32) & 0xFFFFFFFF)
    MMIO写32(端口基 + PORT_FB, fis_area & 0xFFFFFFFF)
    MMIO写32(端口基 + PORT_FBU, (fis_area >> 32) & 0xFFFFFFFF)

    // 分配命令表(每个256字节 + PRDT, 128字节对齐)
    定义 可变 cmd_tables = []
    定义 可变 i = 0
    当 (i < ctl.命令槽数) {
        定义 ct = 直传_分配_对齐(256, 128)
        内存填零(ct, 256)
        // 将命令表地址写入命令头
        定义 header_addr = cmd_list + i * 32
        内存写32(header_addr + 8, ct & 0xFFFFFFFF)
        内存写32(header_addr + 12, (ct >> 32) & 0xFFFFFFFF)
        追加(cmd_tables, ct)
        i = i + 1
    }

    // 清除中断/错误状态
    MMIO写32(端口基 + PORT_SERR, 0xFFFFFFFF)
    MMIO写32(端口基 + PORT_IS, 0xFFFFFFFF)

    // 使能中断
    MMIO写32(端口基 + PORT_IE, 0x7DC000FF)

    // 启动命令引擎
    AHCI_启动命令引擎(端口基)

    // 读取设备签名
    定义 sig = MMIO读32(端口基 + PORT_SIG)

    定义 port = AHCI端口 {}
    port.端口号 = 端口号
    port.端口基址 = 端口基
    port.命令列表 = cmd_list
    port.FIS接收区 = fis_area
    port.命令表 = cmd_tables
    port.设备类型 = sig
    port.已连接 = 真

    如果 (sig == SATA_SIG_ATA) {
        内核信息("AHCI: 端口" + 整数转字符串(端口号) + " SATA硬盘/SSD")
        AHCI_识别设备(port)
    } 否则 如果 (sig == SATA_SIG_AT接口) {
        内核信息("AHCI: 端口" + 整数转字符串(端口号) + " SAT接口光驱")
    }

    追加(AHCI端口列表, port)

    // 注册为块设备
    如果 (sig == SATA_SIG_ATA) {
        定义 dev_name = "sd" + 字符(0x61 + 计数(AHCI端口列表) - 1)  // sda, sdb, ...
        块设备_注册(dev_name, port)
        内核信息("AHCI: 注册块设备 /dev/" + dev_name +
                 " 容量=" + 整数转字符串(port.设备信息.扇区数 / 2048) + "MB")
    }
}

// §6 命令引擎控制

函数 AHCI_停止命令引擎(端口基) {
    定义 cmd = MMIO读32(端口基 + PORT_CMD)
    // 清除ST(启动)位
    cmd = cmd & ~PORT_CMD_ST
    MMIO写32(端口基 + PORT_CMD, cmd)
    // 等待CR(命令运行)位清除
    定义 可变 等待 = 0
    当 (等待 < 500) {
        如果 ((MMIO读32(端口基 + PORT_CMD) & PORT_CMD_CR) == 0) { 返回 }
        延迟_ms(1)
        等待 = 等待 + 1
    }
    内核警告("AHCI: 停止命令引擎超时")
}

函数 AHCI_启动命令引擎(端口基) {
    // 等待CR清除
    定义 可变 等待 = 0
    当 (等待 < 500) {
        如果 ((MMIO读32(端口基 + PORT_CMD) & PORT_CMD_CR) == 0) { 跳出 }
        延迟_ms(1)
        等待 = 等待 + 1
    }
    定义 cmd = MMIO读32(端口基 + PORT_CMD)
    cmd = cmd | PORT_CMD_FRE    // 使能FIS接收
    cmd = cmd | PORT_CMD_ST     // 启动
    MMIO写32(端口基 + PORT_CMD, cmd)
}

// §4 AHCI端口寄存器常量

定义 PORT_CLB = 0x00
定义 PORT_CLBU = 0x04
定义 PORT_FB = 0x08
定义 PORT_FBU = 0x0C
定义 PORT_IS = 0x10
定义 PORT_IE = 0x14
定义 PORT_CMD = 0x18
定义 PORT_TFD = 0x20
定义 PORT_SIG = 0x24
定义 PORT_SSTS = 0x28
定义 PORT_SCTL = 0x2C
定义 PORT_SERR = 0x30
定义 PORT_SACT = 0x34
定义 PORT_CI = 0x38

定义 PORT_CMD_ST = 0x0001
定义 PORT_CMD_FRE = 0x0010
定义 PORT_CMD_FR = 0x4000
定义 PORT_CMD_CR = 0x8000

函数 延迟_ms(ms) {
    IO原语_延迟毫秒(ms)
}

函数 延迟_us(us) {
    IO原语_延迟微秒(us)
}

// §5 端口类型检测

函数 AHCI_检测端口类型(端口基) {
    定义 ssts = MMIO读32(端口基 + PORT_SSTS)
    定义 det = ssts & 0x0F
    定义 ipm = (ssts >> 8) & 0x0F
    如果 (det != 3 || ipm != 1) { 返回 0 }
    定义 sig = MMIO读32(端口基 + PORT_SIG)
    如果 (sig == 0x00000101) { 返回 1 }
    如果 (sig == 0xEB140101) { 返回 2 }
    如果 (sig == 0x96690101) { 返回 3 }
    返回 0
}

函数 AHCI_端口类型名(类型) {
    如果 (类型 == 1) { 返回 "SATA" }
    如果 (类型 == 2) { 返回 "ATAPI" }
    如果 (类型 == 3) { 返回 "PM" }
    返回 "无设备"
}

// §6 端口错误处理

函数 AHCI_清除端口错误(端口基) {
    定义 serr = MMIO读32(端口基 + PORT_SERR)
    MMIO写32(端口基 + PORT_SERR, serr)
    定义 is = MMIO读32(端口基 + PORT_IS)
    MMIO写32(端口基 + PORT_IS, is)
}

函数 AHCI_端口复位(端口基) {
    AHCI_停止命令引擎(端口基)
    AHCI_清除端口错误(端口基)
    定义 sctl = MMIO读32(端口基 + PORT_SCTL)
    MMIO写32(端口基 + PORT_SCTL, (sctl & ~0x0F) | 0x01)
    延迟_ms(2)
    MMIO写32(端口基 + PORT_SCTL, sctl & ~0x0F)
    延迟_ms(200)
    AHCI_启动命令引擎(端口基)
}

// §7 统计

定义 可变 端口_初始化数 = 0
定义 可变 端口_复位数 = 0

函数 AHCI端口_统计() {
    返回 {
        初始化: 端口_初始化数,
        复位: 端口_复位数,
    }
}

定义 可变 AI_端口初始化_调用数 = 0
定义 可变 AI_端口初始化_异常数 = 0

函数 AI_端口初始化_监控() {
    AI_端口初始化_调用数 = AI_端口初始化_调用数 + 1
    返回 AI_端口初始化_异常数 == 0
}

函数 AI_端口初始化_健康检查() {
    如果 (AI_端口初始化_调用数 > 0 && AI_端口初始化_异常数 * 100 / AI_端口初始化_调用数 > 10) {
        返回 假
    }
    返回 真
}

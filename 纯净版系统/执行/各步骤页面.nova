导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./扫描磁盘.nova")
导入("./辅助界面绘.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/内存回收.nova")

// §4 各步骤页面

函数 绘制_欢迎页(x, y, 宽, 高) {
    定义 中心X = x + 宽 / 2

    // AI全息人形(中央发光轮廓)
    绘制_AI全息人形(中心X, y + 80, 120)

    绘制文字(中心X - 80, y + 220, "欢迎来到 NovaOS", 28, 0x4FC3F7)
    绘制文字(中心X - 160, y + 270, "AI原生操作系统 — 你的智能伙伴", 16, 0xA0A0C0)
    绘制文字(中心X - 200, y + 320, "NovaOS将AI融入操作系统的每一个角落", 14, 0x808090)
    绘制文字(中心X - 180, y + 345, "从内核调度到桌面交互，AI让一切更智能", 14, 0x808090)

    // 三个特性图标
    定义 图标Y = y + 400
    绘制_特性图标(中心X - 220, 图标Y, "🧠", "AI内核", "29个AI模块深度集成")
    绘制_特性图标(中心X - 40, 图标Y, "🔄", "热更新", "不重启升级内核")
    绘制_特性图标(中心X + 140, 图标Y, "🛡️", "自动回滚", "崩溃自动恢复")
}

函数 绘制_语言页(x, y, 宽, 高) {
    绘制文字(x + 30, y + 20, "选择语言 / Select Language", 22, 0xE0E0F0)

    // 语言选项(发光选中状态)
    定义 可变 选项 = [
        ["zh_CN", "简体中文", "中华人民共和国"],
        ["zh_TW", "繁體中文", "中國台灣"],
        ["en_US", "English", "United States"],
        ["ja_JP", "日本語", "日本"],
        ["ko_KR", "한국어", "대한민국"]
    ]
    定义 可变 i = 0
    当 (i < 计数(选项)) {
        定义 项Y = y + 80 + i * 60
        定义 选中 = (安装.语言 == 选项[i][0])
        如果 (选中) {
            绘制_发光边框(空, x + 30, 项Y, 宽 - 60, 50, 12)
            填充矩形(x + 30, 项Y, 宽 - 60, 50, 颜色(79, 195, 247, 30))
        }
        绘制文字(x + 50, 项Y + 8, 选项[i][1], 18, 如果选(选中, 0x4FC3F7, 0xC0C0D0))
        绘制文字(x + 50, 项Y + 30, 选项[i][2], 12, 0x808090)
        i = i + 1
    }

    // 时区选择
    绘制文字(x + 30, y + 400, "时区: " + 安装.时区, 14, 0xA0A0B0)
}

函数 绘制_磁盘页(x, y, 宽, 高) {
    绘制文字(x + 30, y + 20, "选择安装磁盘", 22, 0xE0E0F0)

    // 扫描磁盘
    定义 磁盘列表 = 扫描磁盘()
    如果 (计数(磁盘列表) == 0) {
        绘制文字(x + 30, y + 100, "⚠ 未检测到磁盘", 18, 0xEF5350)
        绘制文字(x + 30, y + 130, "请确认磁盘已连接且驱动正常", 14, 0x808090)
        返回
    }

    定义 可变 i = 0
    当 (i < 计数(磁盘列表)) {
        定义 磁盘 = 磁盘列表[i]
        定义 项Y = y + 80 + i * 80
        定义 选中 = (安装.目标磁盘 == 磁盘[0])

        如果 (选中) { 绘制_发光边框(空, x + 30, 项Y, 宽 - 60, 70, 12) }

        // 磁盘图标+信息
        绘制文字(x + 50, 项Y + 8, "💾 " + 磁盘[0], 16, 如果选(选中, 0x4FC3F7, 0xC0C0D0))
        绘制文字(x + 50, 项Y + 30, 磁盘[1] + " | " + 整数转字符串(磁盘[2] / 1073741824) + " GB", 13, 0x808090)

        // 容量条
        定义 已用比 = 磁盘[3] * 100 / 磁盘[2]
        绘制_进度条(x + 50, 项Y + 50, 宽 - 110, 8, 已用比, 0x4FC3F7)

        i = i + 1
    }
}

函数 绘制_分区页(x, y, 宽, 高) {
    绘制文字(x + 30, y + 20, "分区设置", 22, 0xE0E0F0)

    // 两种方案
    定义 自动选中 = (安装.分区方案 == 0)
    定义 手动选中 = (安装.分区方案 == 1)

    // 自动分区
    定义 Y1 = y + 80
    如果 (自动选中) { 绘制_发光边框(空, x + 30, Y1, 宽 - 60, 120, 12) }
    绘制文字(x + 50, Y1 + 10, "⚡ 自动分区 (推荐)", 18, 如果选(自动选中, 0x4FC3F7, 0xC0C0D0))
    绘制文字(x + 50, Y1 + 35, "自动创建EFI(512MB) + 根分区 + 交换分区(4GB)", 13, 0x808090)
    绘制文字(x + 50, Y1 + 55, "⚠ 将擦除 " + 安装.目标磁盘 + " 上的所有数据", 13, 0xFFA726)

    // 分区预览
    如果 (自动选中) {
        绘制_分区预览(x + 50, Y1 + 80, 宽 - 110, 30)
    }

    // 手动分区
    定义 Y2 = y + 220
    如果 (手动选中) { 绘制_发光边框(空, x + 30, Y2, 宽 - 60, 80, 12) }
    绘制文字(x + 50, Y2 + 10, "🔧 手动分区", 18, 如果选(手动选中, 0x4FC3F7, 0xC0C0D0))
    绘制文字(x + 50, Y2 + 35, "自定义分区表(高级用户)", 13, 0x808090)
}

函数 绘制_用户页(x, y, 宽, 高) {
    绘制文字(x + 30, y + 20, "创建用户", 22, 0xE0E0F0)

    // 用户头像(AI生成的全息头像)
    定义 中心X = x + 宽 / 2
    绘制_全息头像(中心X, y + 80, 60)

    // 输入框
    绘制_输入框(x + 宽 / 2 - 200, y + 180, 400, "用户名", 安装.用户名)
    绘制_输入框(x + 宽 / 2 - 200, y + 240, 400, "密码", "••••••••")
    绘制_输入框(x + 宽 / 2 - 200, y + 300, 400, "确认密码", "••••••••")
    绘制_输入框(x + 宽 / 2 - 200, y + 360, 400, "主机名", 安装.主机名)

    绘制文字(x + 宽 / 2 - 180, y + 420, "💡 AI将为你创建个性化的桌面环境", 13, 0x66BB6A)
}

函数 绘制_AI设置页(x, y, 宽, 高) {
    绘制文字(x + 30, y + 20, "AI 智能配置", 22, 0xE0E0F0)
    绘制文字(x + 30, y + 50, "NovaOS的灵魂 — 选择AI运行模式", 14, 0x808090)

    // 三种AI模式
    定义 模式 = [
        [0, "☁️ 云端优先 (推荐新手)",
            "通过接口调用云端AI(Nova语言模型/Claude/DeepSeek)",
            "本地TNF作为加速缓存，减少接口调用",
            "需要网络连接，响应快，能力强"],
        [1, "🧠 本地优先 (推荐高手)",
            "本地TNF模型为主力引擎",
            "云端仅在本地无法回答时补充",
            "离线可用，隐私最强，但需要训练"],
        [2, "🔄 智能混合 (推荐)",
            "AI自动判断：简单任务本地处理",
            "复杂任务云端协助，本地持续学习",
            "兼顾速度、能力、隐私、离线"]
    ]

    定义 可变 i = 0
    当 (i < 3) {
        定义 项Y = y + 90 + i * 120
        定义 选中 = (安装.AI模式 == 模式[i][0])
        如果 (选中) {
            绘制_发光边框(空, x + 30, 项Y, 宽 - 60, 110, 12)
            填充矩形(x + 30, 项Y, 宽 - 60, 110, 颜色(79, 195, 247, 20))
        }
        绘制文字(x + 50, 项Y + 8, 模式[i][1], 17, 如果选(选中, 0x4FC3F7, 0xC0C0D0))
        绘制文字(x + 50, 项Y + 32, 模式[i][2], 12, 0x909098)
        绘制文字(x + 50, 项Y + 50, 模式[i][3], 12, 0x909098)
        绘制文字(x + 50, 项Y + 68, 模式[i][4], 12, 0x909098)
        i = i + 1
    }

    // 接口密钥输入(云端模式时显示)
    如果 (安装.AI模式 == 0 || 安装.AI模式 == 2) {
        绘制_输入框(x + 30, y + 460, 宽 - 60, "云端接口密钥 (可选,之后设置也行)", 安装.智能_接口密钥)
    }
}

函数 绘制_安装进度页(x, y, 宽, 高) {
    定义 中心X = x + 宽 / 2

    // AI全息人形(正在工作的动画)
    绘制_AI全息人形_工作中(中心X, y + 60, 80)

    绘制文字(中心X - 60, y + 170, "正在安装...", 24, 0x4FC3F7)

    // 大进度条
    绘制_进度条(x + 60, y + 220, 宽 - 120, 16, 安装.安装进度, 0x4FC3F7)
    绘制文字(中心X - 15, y + 245, 整数转字符串(安装.安装进度) + "%", 16, 0xE0E0F0)

    // 当前操作
    定义 操作 = 获取安装操作(安装.安装进度)
    绘制文字(x + 60, y + 280, 操作, 14, 0xA0A0B0)

    // 安装步骤清单
    定义 步骤列表 = [
        [10, "格式化分区"],
        [20, "复制系统文件"],
        [40, "安装内核"],
        [55, "配置引导加载器"],
        [65, "初始化AI子系统"],
        [75, "下载AI基础权重"],
        [85, "配置网络和驱动"],
        [90, "创建用户账户"],
        [95, "生成个性化桌面"],
        [100, "安装完成"]
    ]
    定义 可变 i = 0
    当 (i < 计数(步骤列表)) {
        定义 项Y = y + 320 + i * 18
        定义 完成 = (安装.安装进度 >= 步骤列表[i][0])
        定义 图标 = 如果选(完成, "✅", "⬜")
        定义 颜色 = 如果选(完成, 0x66BB6A, 0x505060)
        绘制文字(x + 80, 项Y, 图标 + " " + 步骤列表[i][1], 12, 颜色)
        i = i + 1
    }
}

函数 绘制_完成页(x, y, 宽, 高) {
    定义 中心X = x + 宽 / 2

    绘制_AI全息人形(中心X, y + 60, 100)

    绘制文字(中心X - 100, y + 200, "🎉 安装完成!", 32, 0x66BB6A)
    绘制文字(中心X - 160, y + 260, "NovaOS已就绪，AI正在等待与你相遇", 16, 0xA0A0C0)

    绘制文字(中心X - 120, y + 320, "系统信息:", 16, 0xC0C0D0)
    绘制文字(中心X - 120, y + 345, "用户: " + 安装.用户名 + "@" + 安装.主机名, 13, 0x909098)
    绘制文字(中心X - 120, y + 365, "AI模式: " + AI模式名称(安装.AI模式), 13, 0x909098)
    绘制文字(中心X - 120, y + 385, "磁盘: " + 安装.目标磁盘, 13, 0x909098)

    // 重启按钮(发光强调)
    定义 按钮X = 中心X - 100
    定义 按钮Y = y + 440
    绘制_发光边框(空, 按钮X, 按钮Y, 200, 48, 24)
    填充矩形(按钮X, 按钮Y, 200, 48, 颜色(79, 195, 247, 40))
    绘制文字(按钮X + 40, 按钮Y + 12, "立即重启", 20, 0x4FC3F7)
}

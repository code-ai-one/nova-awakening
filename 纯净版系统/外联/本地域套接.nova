//   1. AF_UNIX: 本机进程间通信(不经过网络栈)
//   2. SOCK_STREAM: 面向连接(类似传控)
//   3. SOCK_DGRAM: 无连接(类似数报)
//   4. 绑定到文件系统路径: /tmp/mysock, /var/run/docker.sock
//   5. 也支持抽象命名空间: \0mysock(不在文件系统中)
//   6. 传递文件描述符: SCM_RIGHTS(唯一能力)
//   7. 用于: X11/D-Bus/Docker/systemd/数据库连接

结构 unix_socket {
    路径,    // 字符串 绑定路径
    类型,    // u32 SOCK_STREAM/SOCK_DGRAM
    状态,    // u32 0=未连接, 1=监听, 2=已连接
    对端,    // u64 连接的对端socket
    接收队列,    // [] 接收缓冲
    发送队列,    // [] 发送缓冲(DGRAM)
    积压队列,    // [] 连接请求队列(STREAM listen)
    积压上限,
    等待队列,
    引用计数,
}

定义 可变 unix_socket_表 = []

// 创建 

函数 unix_创建(类型) {
    定义 us = unix_socket {}
    us.路径 = ""
    us.类型 = 类型
    us.状态 = 0
    us.对端 = 空
    us.接收队列 = []
    us.发送队列 = []
    us.积压队列 = []
    us.积压上限 = 128
    us.等待队列 = 等待队列_创建()
    us.引用计数 = 1
    追加(unix_socket_表, us)
    返回 us
}

// bind: 绑定到路径

函数 unix_bind(us, 路径) {
    // 检查路径是否已被占用
    如果 (unix_查找(路径) != 空) { 返回 错误_已存在 }
    us.路径 = 路径
    // 在文件系统中创建socket文件
    返回 成功
}

// listen + accept (SOCK_STREAM)

函数 unix_listen(us, 队列长度) {
    us.状态 = 1
    us.积压上限 = 队列长度
    返回 成功
}

函数 unix_accept(us) {
    如果 (us.状态 != 1) { 返回 空 }
    // 等待连接请求
    当 (计数(us.积压队列) == 0) { 调度() }
    定义 客户端 = us.积压队列[0]
    链表_删除(us.积压队列, 0)
    // 创建新socket作为服务端连接
    定义 服务端 = unix_创建(us.类型)
    服务端.状态 = 2
    服务端.对端 = 客户端
    客户端.对端 = 服务端
    客户端.状态 = 2
    返回 服务端
}

// connect (SOCK_STREAM)

函数 unix_connect(us, 路径) {
    定义 目标 = unix_查找(路径)
    如果 (目标 == 空) { 返回 错误_不存在 }
    如果 (目标.状态 != 1) { 返回 错误_拒绝连接 }
    // 加入目标的积压队列
    追加(目标.积压队列, us)
    等待队列_唤醒一个(目标.等待队列)
    // 等待accept
    当 (us.状态 != 2) { 调度() }
    返回 成功
}

// send/recv

函数 unix_send(us, 数据) {
    如果 (us == 0) { 返回 错误_未连接 }
    如果 (us.对端 == 空) { 返回 错误_未连接 }
    追加(us.对端.接收队列, 数据)
    等待队列_唤醒一个(us.对端.等待队列)
    返回 字符串长度(数据)
}

函数 unix_recv(us) {
    如果 (us == 0) { 返回 "" }
    当 (计数(us.接收队列) == 0) { 调度() }
    如果 (计数(us.接收队列) == 0) { 返回 "" }
    定义 数据 = us.接收队列[0]
    链表_删除(us.接收队列, 0)
    返回 数据
}

// sendto/recvfrom (SOCK_DGRAM)

函数 unix_sendto(us, 数据, 目标路径) {
    定义 目标 = unix_查找(目标路径)
    如果 (目标 == 空) { 返回 错误_不存在 }
    追加(目标.接收队列, [数据, us.路径])   // [数据, 发送者路径]
    等待队列_唤醒一个(目标.等待队列)
    返回 字符串长度(数据)
}

// socketpair: 创建一对已连接的socket

函数 unix_socketpair(类型) {
    定义 a = unix_创建(类型)
    定义 b = unix_创建(类型)
    a.对端 = b
    b.对端 = a
    a.状态 = 2
    b.状态 = 2
    返回 [a, b]
}

// 辅助

函数 unix_查找(路径) {
    定义 可变 i = 0
    当 (i < 计数(unix_socket_表)) {
        如果 (unix_socket_表[i].路径 == 路径) { 返回 unix_socket_表[i] }
        i = i + 1
    }
    返回 空
}

函数 unix_关闭(us) {
    如果 (us == 0) { 返回 }
    如果 (us.对端 != 空) { us.对端.对端 = 空 }
    us.引用计数 = us.引用计数 - 1
}

函数 unix_统计() { 返回 [计数(unix_socket_表)] }

// 错误_未连接 定义在 核心/公共/错误码.nova
// 错误_拒绝连接 定义在 核心/公共/错误码.nova

// SCM_RIGHTS: 文件描述符传递 (Unix域socket独有能力)

函数 unix_send_fd(us, fd) {
    如果 (us == 0) { 返回 错误_未连接 }
    如果 (us.对端 == 空) { 返回 错误_未连接 }
    // 将fd包装为控制消息发送
    追加(us.对端.接收队列, ["__SCM_RIGHTS__", fd])
    等待队列_唤醒一个(us.对端.等待队列)
    返回 成功
}

函数 unix_recv_fd(us) {
    定义 可变 i = 0
    当 (i < 计数(us.接收队列)) {
        定义 项 = us.接收队列[i]
        如果 (项[0] == "__SCM_RIGHTS__") {
            定义 fd = 项[1]
            链表_删除(us.接收队列, i)
            返回 fd
        }
        i = i + 1
    }
    返回 错误_无效参数
}

// poll支持 + 状态查询

函数 unix_poll(us) {
    定义 可变 事件 = 0
    如果 (计数(us.接收队列) > 0) { 事件 = 事件 | 1 }  // POLLIN
    如果 (us.对端 != 空) { 事件 = 事件 | 4 }  // POLLOUT
    如果 (us.状态 == 1 && 计数(us.积压队列) > 0) { 事件 = 事件 | 1 }  // 新连接=POLLIN
    如果 (us.对端 == 空 && us.状态 == 2) { 事件 = 事件 | 16 }  // POLLHUP
    返回 事件
}

函数 unix_状态名(状态) {
    如果 (状态 == 0) { 返回 "UNCONNECTED" }
    如果 (状态 == 1) { 返回 "LISTENING" }
    如果 (状态 == 2) { 返回 "CONNECTED" }
    返回 "UNKNOWN"
}

函数 unix_完整统计() {
    返回 [计数(unix_socket_表)]
}

定义 可变 AI_本地域套接_带宽估计 = 0
定义 可变 AI_本地域套接_丢包窗口 = []

函数 AI_本地域套接_带宽预测(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 AI_本地域套接_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    AI_本地域套接_带宽估计 = AI_本地域套接_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 AI_本地域套接_带宽估计
}

函数 AI_本地域套接_拥塞建议(丢包率) {
    追加(AI_本地域套接_丢包窗口, 丢包率)
    如果 (计数(AI_本地域套接_丢包窗口) > 10) { 列表_移除(AI_本地域套接_丢包窗口, 0) }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}

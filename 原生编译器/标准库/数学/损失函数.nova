导入("../基础.nova")
导入("../../运行时/原语桩.nova")

// Nova标准库 — AI 损失函数模块
// 神经网络训练核心 — 整数定点实现

定义 损失精度 = 1000

// 均方误差 (均方误差, 0)
// 均方误差 = (1/n) * Σ(预测_i - 真实_i)²
函数 均方误差(预测, 真实) { 定义 n = 计数(预测)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 差 = 预测[i] - 真实[i]
 总和 = 总和 + 差 * 差
 i = i + 1
 }
 如果 (n == 0) { 返回 0 }
 返回 总和 / n
}

// 均方误差 梯度: d/d预测 = 2*(预测-真实)/n
函数 均方误差梯度(预测, 真实) { 定义 n = 计数(预测)
 定义 可变 梯度 = []
 定义 可变 i = 0
 当 (i < n) {
 追加(梯度, 2 * (预测[i] - 真实[i]) / n)
 i = i + 1
 }
 返回 梯度
}

// 平均绝对误差 (平均绝对误差, 0)
函数 平均绝对误差(预测, 真实) { 定义 n = 计数(预测)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 差 = 预测[i] - 真实[i]
 如果 (差 < 0) { 差 = 0 - 差 }
 总和 = 总和 + 差
 i = i + 1
 }
 如果 (n == 0) { 返回 0 }
 返回 总和 / n
}

// 平均绝对误差 梯度: sign(预测-真实)/n
函数 平均绝对误差梯度(预测, 真实) { 定义 n = 计数(预测)
 定义 可变 梯度 = []
 定义 可变 i = 0
 当 (i < n) { 定义 可变 差 = 预测[i] - 真实[i]
 如果 (差 > 0) { 追加(梯度, 损失精度 / n) }
 否则 如果 (差 < 0) { 追加(梯度, 0 - 损失精度 / n) }
 否则 { 追加(梯度, 0) }
 i = i + 1
 }
 返回 梯度
}

// Huber 损失
// δ=1000: L = 0.5*x² (|x|<δ), δ*(|x|-0.5*δ) (otherwise)
函数 huber损失(预测, 真实, 增量) { 定义 n = 计数(预测)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 差 = 预测[i] - 真实[i]
 如果 (差 < 0) { 差 = 0 - 差 }
 如果 (差 <= 增量) {
 总和 = 总和 + 差 * 差 / 2
 } 否则 {
 总和 = 总和 + 增量 * (差 - 增量 / 2)
 }
 i = i + 1
 }
 如果 (n == 0) { 返回 0 }
 返回 总和 / n
}

// 交叉熵损失 (二分类, 0)
// CE = -[y*log(p) + (1-y)*log(1-p)]
// 整数近似: 使用对数近似
函数 对数近似(x) {
 // ln(x/1000) * 1000 的整数近似
 // 使用分段线性: ln(0.001)≈-6908, ln(0.5)≈-693, ln(1)=0
 如果 (x <= 0) { 返回 0 - 10000 }
 如果 (x <= 100) { 返回 0 - 3000 + x * 10 }
 如果 (x <= 500) { 返回 0 - 1000 + (x - 100) * 2 }
 如果 (x <= 损失精度) { 返回 0 - 200 + (x - 500) * 200 / 500 }
 返回 0
}

函数 损失函数_交叉熵(预测, 真实) { 定义 n = 计数(预测)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 p = 预测[i]
 定义 y = 真实[i]
 // 限幅防止 log()
 如果 (p < 1) { p = 1 }
 如果 (p > 损失精度 - 1) { p = 损失精度 - 1 }
 定义 损 = 0 - (y * 对数近似(p) + (损失精度 - y) * 对数近似(损失精度 - p)) / 损失精度
 总和 = 总和 + 损
 i = i + 1
 }
 如果 (n == 0) { 返回 0 }
 返回 总和 / n
}

// 交叉熵梯度
函数 交叉熵梯度(预测, 真实) { 定义 n = 计数(预测)
 定义 可变 梯度 = []
 定义 可变 i = 0
 当 (i < n) { 定义 可变 p = 预测[i]
 定义 y = 真实[i]
 如果 (p < 1) { p = 1 }
 如果 (p > 损失精度 - 1) { p = 损失精度 - 1 }
 // 梯度 = (p - y) / (p * (1 - p/精度))
 定义 梯度 = (p - y) * 损失精度 / (p * (损失精度 - p) / 损失精度 + 1)
 追加(梯度, 梯度 / n)
 i = i + 1
 }
 返回 梯度
}

// 铰链损失 (Hinge Loss, SVM)
// max(0, 1 - y * 预测)
函数 铰链损失(预测, 真实) { 定义 n = 计数(预测)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 边距 = 损失精度 - 真实[i] * 预测[i] / 损失精度
 如果 (边距 > 0) { 总和 = 总和 + 边距 }
 i = i + 1
 }
 如果 (n == 0) { 返回 0 }
 返回 总和 / n
}

// KL 散度近似
函数 kl散度(p分布, q分布) { 定义 n = 计数(p分布)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 p = p分布[i]
 定义 q = q分布[i]
 如果 (p > 0 且 q > 0) {
 总和 = 总和 + p * (对数近似(p) - 对数近似(q)) / 损失精度
 }
 i = i + 1
 }
 返回 总和
}

// 余弦相似度
函数 余弦相似度(a, b) { 定义 n = 计数(a)
 定义 可变 点积 = 0
 定义 可变 范数a = 0
 定义 可变 范数b = 0
 定义 可变 i = 0
 当 (i < n) {
 点积 = 点积 + a[i] * b[i]
 范数a = 范数a + a[i] * a[i]
 范数b = 范数b + b[i] * b[i]
 i = i + 1
 }
 // 近似: 使用整数开方
 定义 可变 范乘 = 整数开方(范数a) * 整数开方(范数b)
 如果 (范乘 == 0) { 返回 0 }
 返回 点积 * 损失精度 / 范乘
}

// 余弦损失
函数 余弦损失(预测, 真实) { 返回 损失精度 - 余弦相似度(预测, 真实)
}

// 整数开方 (v0.8: 使用引擎内建开方)
函数 整数开方(n) { 返回 开方(n) }

// Focal Loss (焦点损失)
// FL = -学习率 * (1-p)^衰减率 * log(p) (对难分样本加权)
函数 焦点损失(预测, _真实, 衰减率) { 定义 n = 计数(预测)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 p = 预测[i]
 如果 (p < 1) { p = 1 }
 如果 (p > 损失精度 - 1) { p = 损失精度 - 1 }
 定义 可变 权重 = 损失精度 - p
 // (1-p)^衰减率 近似
 定义 可变 g = 0
 当 (g < 衰减率 - 1) {
 权重 = 权重 * (损失精度 - p) / 损失精度
 g = g + 1
 }
 定义 损 = 0 - 权重 * 对数近似(p) / 损失精度
 总和 = 总和 + 损
 i = i + 1
 }
 如果 (n == 0) { 返回 0 }
 返回 总和 / n
}

// Label Smoothing 交叉熵
// 防止过度自信: 真实标签从1→(1-ε), 0→ε/(n-1)
函数 平滑交叉熵(预测, 真实, 极小值, 类别数) { 定义 n = 计数(预测)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 p = 预测[i]
 如果 (p < 1) { p = 1 }
 如果 (p > 损失精度 - 1) { p = 损失精度 - 1 }
 // 平滑标签
 定义 可变 y_smooth = 极小值 / 类别数
 如果 (真实[i] > 损失精度 / 2) {
 y_smooth = 损失精度 - 极小值 + 极小值 / 类别数
 }
 定义 损 = 0 - y_smooth * 对数近似(p) / 损失精度
 总和 = 总和 + 损
 i = i + 1
 }
 如果 (n == 0) { 返回 0 }
 返回 总和 / n
}

// Triplet Loss (三元组损失)
// L = max(0, d(anchor,positive) - d(anchor,negative) + margin)
函数 三元组损失(锚点, 正例, 负例, margin) { 定义 n = 计数(锚点)
 定义 可变 正距 = 0
 定义 可变 负距 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 dp = 锚点[i] - 正例[i]
 定义 dn = 锚点[i] - 负例[i]
 正距 = 正距 + dp * dp
 负距 = 负距 + dn * dn
 i = i + 1
 }
 定义 损失 = 正距 - 负距 + margin
 如果 (损失 < 0) { 返回 0 }
 返回 损失
}

// Smooth L1 Loss (物体检测常用)
函数 smooth_l1损失(预测, 真实, 动量率) { 定义 n = 计数(预测)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 差 = 预测[i] - 真实[i]
 如果 (差 < 0) { 差 = 0 - 差 }
 如果 (差 < 动量率) {
 总和 = 总和 + 差 * 差 / (2 * 动量率)
 } 否则 {
 总和 = 总和 + 差 - 动量率 / 2
 }
 i = i + 1
 }
 返回 总和 / n
}

// 对比损失 (Contrastive Loss, SimCLR/CLIP)
函数 对比损失(相似度, 温度) { 定义 n = 计数(相似度)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 缩放 = 相似度[i] * 损失精度 / 温度
 // -log(归一化指数) 近似
 定义 可变 log_sum = 0
 定义 可变 j = 0
 当 (j < n) { 定义 s = 相似度[j] * 损失精度 / 温度
 定义 可变 e = 损失精度 + s - 缩放
 如果 (e < 1) { e = 1 }
 log_sum = log_sum + e
 j = j + 1
 }
 总和 = 总和 + 对数近似(损失精度 * 损失精度 / log_sum)
 i = i + 1
 }
 返回 0 - 总和 / n
}

// L1 正则化
函数 l1正则(权重, 衰减系数) { 定义 n = 计数(权重)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 w = 权重[i]
 如果 (w < 0) { w = 0 - w }
 总和 = 总和 + w
 i = i + 1
 }
 如果 (损失精度 == 0) { 返回 0 }
 返回 衰减系数 * 总和 / 损失精度
}

// L2 正则化
函数 l2正则(权重, 衰减系数) { 定义 n = 计数(权重)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) {
 总和 = 总和 + 权重[i] * 权重[i]
 i = i + 1
 }
 返回 衰减系数 * 总和 / (2 * 损失精度)
}

// Dice Loss (语义分割)
// DL = 1 - 2*|P∩G| / (|P|+|G|)
函数 dice损失(预测, 真实) { 定义 n = 计数(预测)
 定义 可变 交集 = 0
 定义 可变 预测和 = 0
 定义 可变 真实和 = 0
 定义 可变 i = 0
 当 (i < n) {
 交集 = 交集 + 预测[i] * 真实[i] / 损失精度
 预测和 = 预测和 + 预测[i]
 真实和 = 真实和 + 真实[i]
 i = i + 1
 }
 定义 分母 = 预测和 + 真实和
 如果 (分母 == 0) { 返回 0 }
 返回 损失精度 - 2 * 交集 * 损失精度 / 分母
}

// IoU Loss (Jaccard)
函数 iou损失(预测, 真实) { 定义 n = 计数(预测)
 定义 可变 交集 = 0
 定义 可变 并集 = 0
 定义 可变 i = 0
 当 (i < n) {
 交集 = 交集 + 预测[i] * 真实[i] / 损失精度
 并集 = 并集 + 预测[i] + 真实[i] - 预测[i] * 真实[i] / 损失精度
 i = i + 1
 }
 如果 (并集 == 0) { 返回 0 }
 返回 损失精度 - 交集 * 损失精度 / 并集
}

// 加权交叉熵 (类别不平衡, 0 , 0)
函数 加权交叉熵(预测, 真实, 类别权重) { 定义 n = 计数(预测)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 p = 预测[i]
 如果 (p < 1) { p = 1 }
 如果 (p > 损失精度 - 1) { p = 损失精度 - 1 }
 定义 w = 类别权重[i]
 定义 损 = 0 - w * (真实[i] * 对数近似(p) + (损失精度 - 真实[i]) * 对数近似(损失精度 - p)) / (损失精度 * 损失精度)
 总和 = 总和 + 损
 i = i + 1
 }
 返回 总和 / n
}

// 多标签BCE (每个类独立二分类)
函数 多标签bce(预测, 真实) { 定义 n = 计数(预测)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 p = 预测[i]
 如果 (p < 1) { p = 1 }
 如果 (p > 损失精度 - 1) { p = 损失精度 - 1 }
 定义 损 = 0 - (真实[i] * 对数近似(p) + (损失精度 - 真实[i]) * 对数近似(损失精度 - p)) / 损失精度
 总和 = 总和 + 损
 i = i + 1
 }
 返回 总和 / n
}

// CTC Loss 近似 (序列标注)
// 简化: 逐帧交叉熵 + 空白惩罚
函数 ctc损失近似(预测序列, 真实序列, 空白id) { 定义 T = 计数(预测序列)
 定义 可变 总和 = 0
 定义 可变 t = 0
 当 (t < T) { 定义 帧 = 预测序列[t]
 定义 n = 计数(帧)
 // 找最大概率类和对应损失
 定义 可变 最大p = 0
 定义 可变 最大类 = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (帧[i] > 最大p) { 最大p = 帧[i]
 最大类 = i }
 i = i + 1
 }
 // 如果最大类是空白,加惩罚
 如果 (最大类 == 空白id) {
 总和 = 总和 + 100 // 空白惩罚
 }
 // 对帧做交叉熵
 如果 (t < 计数(真实序列)) { 定义 目标 = 真实序列[t]
 如果 (目标 >= 0 且 目标 < n) { 定义 可变 p = 帧[目标]
 如果 (p < 1) { p = 1 }
 总和 = 总和 - 对数近似(p)
 }
 }
 t = t + 1
 }
 返回 总和 / T
}

// ElasticNet 正则化 (L1+L2混合)
函数 elasticnet正则(权重, 衰减系数, 学习率) {
 // alpha控制L1/L2比例: 学习率=1000纯L1, 学习率=0纯L2
 定义 l1 = l1正则(权重, 损失精度)
 定义 l2 = l2正则(权重, 损失精度)
 如果 (损失精度 == 0) { 返回 0 }
 返回 衰减系数 * (学习率 * l1 / 损失精度 + (损失精度 - 学习率) * l2 / 损失精度) / 损失精度
}

定义 可变 _损失_历史 = []
定义 可变 _损失_计算次数 = 0
定义 可变 _损失_最小值 = 999999999
定义 可变 _损失_最大值 = 0

函数 损失_记录(值) { _损失_计算次数 = _损失_计算次数 + 1
 追加(_损失_历史, 值)
 如果 (计数(_损失_历史) > 1000) { _损失_历史 = [] }
 如果 (值 < _损失_最小值) { _损失_最小值 = 值 }
 如果 (值 > _损失_最大值) { _损失_最大值 = 值 }
}

函数 损失_趋势() {
    如果 (计数(_损失_历史) < 5) { 返回 "数据不足"
}
 定义 n = 计数(_损失_历史)
 定义 前半 = _损失_历史[0]
 定义 后半 = _损失_历史[n - 1]
 如果 (后半 < 前半) { 返回 "下降(训练正常)" }
 如果 (后半 == 前半) { 返回 "平稳(可能停滞)" }
 返回 "上升(可能发散)"
}

函数 损失_收敛评估() {
    如果 (计数(_损失_历史) < 10) { 返回 "训练初期"
}
 定义 n = 计数(_损失_历史)
 定义 近期 = _损失_历史[n - 1]
 定义 较早 = _损失_历史[n - 5]
 定义 可变 变化 = 近期 - 较早
 如果 (变化 < 0) { 变化 = 0 - 变化 }
 如果 (变化 < 10) { 返回 "已收敛" }
 如果 (变化 < 100) { 返回 "接近收敛" }
 返回 "未收敛"
}

函数 损失_历史清空() { _损失_历史 = [] }

函数 损失_波动性() {
    如果 (计数(_损失_历史) < 3) { 返回 0
}
 定义 可变 波动 = 0
 定义 可变 i = 1
 当 (i < 计数(_损失_历史)) { 定义 可变 差 = _损失_历史[i] - _损失_历史[i - 1]
 如果 (差 < 0) { 差 = 0 - 差 }
 波动 = 波动 + 差
 i = i + 1
 }
 返回 波动 / (计数(_损失_历史) - 1)
}

函数 损失_稳定性评估() { 定义 波动 = 损失_波动性()
 如果 (波动 < 10) { 返回 "非常稳定" }
 如果 (波动 < 100) { 返回 "基本稳定" }
 如果 (波动 < 1000) { 返回 "较不稳定(降低学习率)" }
 返回 "极不稳定(检查数据或模型)"
}

函数 损失_学习率建议(当前学习率) { 定义 波动 = 损失_波动性()
 如果 (波动 > 1000) { 返回 当前学习率 / 4 }
 如果 (波动 > 100) { 返回 当前学习率 / 2 }
 返回 当前学习率
}

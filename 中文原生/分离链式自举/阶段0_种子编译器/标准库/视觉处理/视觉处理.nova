导入("../基础.nova")
导入("../算法/数学扩展.nova")


// 2D卷积
函数 卷积2D(图像, 宽, 高, 核, 核大小) {  / 2
 定义 可变 结果 = []
 定义 可变 y = 0
 当 (y < 高) { 定义 可变 x = 0
 当 (x < 宽) { 定义 可变 总和 = 0
 定义 可变 ky = 0
 当 (ky < 核大小) { 定义 可变 kx = 0
 当 (kx < 核大小) { 定义 可变 iy = y + ky - 半径
 定义 可变 ix = x + kx - 半径
 如果 (iy >= 0 且 iy < 高 且 ix >= 0 且 ix < 宽) {
 总和 = 总和 + 图像[iy * 宽 + ix] * 核[ky * 核大小 + kx] / 100
 }
 kx = kx + 1
 }
 ky = ky + 1
 }
 追加(结果, 总和)
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 预定义核
函数 边缘检测核(_扩1) { 返回 [-100, -100, -100, -100, 800, -100, -100, -100, -100] }
函数 模糊核(_扩1) { 返回 [11, 11, 11, 11, 11, 11, 11, 11, 11] }
函数 视觉处理_锐化核() { 返回 [0, -100, 0, -100, 500, -100, 0, -100, 0] }

// 阈值化
函数 阈值化(图像, 阈值) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(图像)) { 如果 (图像[i] >= 阈值) { 追加(结果, 255) }
 否则 { 追加(结果, 0) }
 i = i + 1
 }
 返回 结果
}

// 直方图
函数 直方图(图像, 区间数) { 定义 可变 直方图 = []
 定义 可变 i = 0
 当 (i < 区间数) { 追加(直方图, 0)
 i = i + 1 }
 定义 可变 最大 = 0
 i = 0
 当 (i < 计数(图像)) { 如果 (图像[i] > 最大) { 最大 = 图像[i] }
 i = i + 1 }
 如果 (最大 == 0) { 最大 = 1 }
 i = 0
 当 (i < 计数(图像)) { 定义 可变 bin = 图像[i] * 区间数 / (最大 + 1)
 如果 (bin >= 区间数) { bin = 区间数 - 1 }
 如果 (bin < 0) { bin = 0 }
 直方图[bin] = 直方图[bin] + 1
 i = i + 1
 }
 返回 直方图
}

// 最大池化
函数 最大池化(图像, 宽, 高, 池大小) { 定义 可变 新宽 = 宽 / 池大小
 定义 可变 新高 = 高 / 池大小
 定义 可变 结果 = []
 定义 可变 y = 0
 当 (y < 新高) { 定义 可变 x = 0
 当 (x < 新宽) { 定义 可变 最大v = 0 - 0x7FFFFFFF
 定义 可变 py = 0
 当 (py < 池大小) { 定义 可变 px = 0
 当 (px < 池大小) { 定义 可变 iy = y * 池大小 + py
 定义 可变 ix = x * 池大小 + px
 如果 (iy < 高 且 ix < 宽) { 定义 可变 v = 图像[iy * 宽 + ix]
 如果 (v > 最大v) { 最大v = v }
 }
 px = px + 1
 }
 py = py + 1
 }
 追加(结果, 最大v)
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 图像翻转
函数 水平翻转_2D(图像, 宽, 高) { 定义 可变 结果 = []
 定义 可变 y = 0
 当 (y < 高) { 定义 可变 x = 宽 - 1
 当 (x >= 0) { 追加(结果, 图像[y * 宽 + x])
 x = x - 1 }
 y = y + 1
 }
 返回 结果
}

函数 垂直翻转_2D(图像, 宽, 高) { 定义 可变 结果 = []
 定义 可变 y = 高 - 1
 当 (y >= 0) { 定义 可变 x = 0
 当 (x < 宽) { 追加(结果, 图像[y * 宽 + x]) x = x + 1 }
 y = y - 1
 }
 返回 结果
}

// 卷积操作

函数 卷积_2D(图像, 宽, 高, 核, 核大小) { 定义 可变 结果 = []
 定义 半径 = 核大小 / 2
 定义 可变 y = 0
 当 (y < 高) { 定义 可变 x = 0
 当 (x < 宽) { 定义 可变 总和 = 0
 定义 可变 ky = 0
 当 (ky < 核大小) { 定义 可变 kx = 0
 当 (kx < 核大小) { 定义 iy = y + ky - 半径
 定义 ix = x + kx - 半径
 如果 (iy >= 0 且 iy < 高 且 ix >= 0 且 ix < 宽) {
 总和 = 总和 + 图像[iy * 宽 + ix] * 核[ky * 核大小 + kx]
 }
 kx = kx + 1
 }
 ky = ky + 1
 }
 追加(结果, 总和)
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

// 边缘检测

函数 索贝尔_水平核() { 返回 [-1, 0, 1, -2, 0, 2, -1, 0, 1] }
函数 索贝尔_垂直核() { 返回 [-1, -2, -1, 0, 0, 1, 2, 1] }

函数 边缘检测_索贝尔(图像, 宽, 高) { 定义 gx = 卷积_2D(图像, 宽, 高, 索贝尔_水平核(), 3)
 定义 gy = 卷积_2D(图像, 宽, 高, 索贝尔_垂直核(), 3)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(gx)) { 定义 幅度 = 整数sqrt(gx[i] * gx[i] + gy[i] * gy[i])
 追加(结果, 幅度)
 i = i + 1
 }
 返回 结果
}

// 池化

函数 最大池化_2D(图像, 宽, 高, 池大小) { 定义 可变 结果 = []
 定义 新宽 = 宽 / 池大小
 定义 新高 = 高 / 池大小
 定义 可变 y = 0
 当 (y < 新高) { 定义 可变 x = 0
 当 (x < 新宽) { 定义 可变 最大 = -999999
 定义 可变 py = 0
 当 (py < 池大小) { 定义 可变 px = 0
 当 (px < 池大小) { 定义 数值 = 图像[(y * 池大小 + py) * 宽 + (x * 池大小 + px)]
 如果 (数值 > 最大) { 最大 = 数值 }
 px = px + 1
 }
 py = py + 1
 }
 追加(结果, 最大)
 x = x + 1
 }
 y = y + 1
 }
 返回 [结果, 新宽, 新高]
}

函数 平均池化_2D(图像, 宽, 高, 池大小) { 定义 可变 结果 = []
 定义 新宽 = 宽 / 池大小
 定义 新高 = 高 / 池大小
 定义 可变 y = 0
 当 (y < 新高) { 定义 可变 x = 0
 当 (x < 新宽) { 定义 可变 总 = 0
 定义 可变 py = 0
 当 (py < 池大小) { 定义 可变 px = 0
 当 (px < 池大小) {
 总 = 总 + 图像[(y * 池大小 + py) * 宽 + (x * 池大小 + px)]
 px = px + 1
 }
 py = py + 1
 }
 追加(结果, 总 / (池大小 * 池大小))
 x = x + 1
 }
 y = y + 1
 }
 返回 [结果, 新宽, 新高]
}

// 图像缩放

函数 最近邻缩放(图像, 原宽, 原高, 新宽, 新高) { 定义 可变 结果 = []
 定义 可变 y = 0
 当 (y < 新高) { 定义 可变 x = 0
 当 (x < 新宽) { 定义 sy = y * 原高 / 新高
 定义 sx = x * 原宽 / 新宽
 追加(结果, 图像[sy * 原宽 + sx])
 x = x + 1
 }
 y = y + 1
 }
 返回 结果
}

定义 可变 _视觉_像素数 = 0

函数 视觉_记录操作(像素) { _视觉_像素数 = _视觉_像素数 + 像素 }

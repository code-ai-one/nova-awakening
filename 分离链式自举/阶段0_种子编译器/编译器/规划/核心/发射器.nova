函数 发射_AES加密末轮(目标, 源) {
    发射(0x66) 发射(0x0F) 发射(0x38) 发射(0xDD) 发射(0xC0 + 目标 * 8 + 源)
}
// aesdec xmm, xmm — AES单轮解密
函数 发射_AES解密轮(目标, 源) {
    发射(0x66) 发射(0x0F) 发射(0x38) 发射(0xDE) 发射(0xC0 + 目标 * 8 + 源)
}
// aeskeygenassist xmm, xmm, imm8 — AES密钥扩展
函数 发射_AES密钥扩展(目标, 源, 轮常量) {
    发射(0x66) 发射(0x0F) 发射(0x3A) 发射(0xDF) 发射(0xC0 + 目标 * 8 + 源) 发射(轮常量)
}
// crc32 rax, rcx — CRC32C
函数 发射_CRC32() { 发射组([0xF2, 0x48, 0x0F, 0x38, 0xF1, 0xC1]) }

// 补全: 随机数 + 杂项

// rdrand rax — 硬件随机数
函数 发射_硬件随机() { 发射组([0x48, 0x0F, 0xC7, 0xF0]) }
// rdseed rax — 硬件随机种子
函数 发射_硬件随机种子() { 发射组([0x48, 0x0F, 0xC7, 0xF8]) }
// xchg rax, rcx — 交换
函数 发射_交换() { 发射组([0x48, 0x91]) }
// bswap rax — 字节序翻转(大小端转换)
函数 发射_字节序翻转() { 发射组([0x48, 0x0F, 0xC8]) }
// movbe rax, [rcx] — 大端加载
函数 发射_大端读() { 发射组([0x0F, 0x38, 0xF0, 0x01]) }
// endbr64 — 间接分支追踪(CET安全)
函数 发射_分支追踪() { 发射组([0xF3, 0x0F, 0x1E, 0xFA]) }

// 补全: BMI1/BMI2 位操作扩展 (现代CPU)

// andn rax, rcx, rdx — 与非: rax = ~rcx & rdx
函数 发射_与非() {
    发射_vex3(0,  0,  2,  1, 0)
    发射(0xF2) 发射(0xC2)
}
// blsi rax, rcx — 提取最低设置位
函数 发射_最低位提取() {
    发射_vex3(0,  0,  2, 0 , 0)
    发射(0xF3) 发射(0xD9)
}
// blsr rax, rcx — 重置最低设置位
函数 发射_最低位重置() {
    发射_vex3(0,  0,  2, 0 , 0)
    发射(0xF3) 发射(0xD1)
}
// pdep rax, rcx, rdx — 并行位存放
函数 发射_并行位存() {
    发射_vex3(3,  0,  2,  1, 0)
    发射(0xF5) 发射(0xC2)
}
// pext rax, rcx, rdx — 并行位提取
函数 发射_并行位取() {
    发射_vex3(2,  0,  2,  1, 0)
    发射(0xF5) 发射(0xC2)
}


导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")

定义 寄存器_温度 = 0xC0300004
定义 寄存器_功耗 = 0xC0300008
定义 寄存器_时钟 = 0xC030000C
定义 寄存器_栅栏 = 0xC0300020
定义 寄存器_电源 = 0xC0300030
定义 温度_警戒 = 85
定义 温度_临界 = 100
定义 最大栅栏 = 256
定义 电源_满速 = 0
定义 电源_平衡 = 1
定义 电源_节能 = 2

结构 图形处理状态 {
    已初始化,
    基地址,
    计算单元数,
    着色引擎数,
    架构代号,
    显存类型,
    显存大小,
    显存已用,
    当前温度,
    当前功耗,
    当前时钟,
    最大时钟,
    电源模式,
    栅栏值,
    栅栏等待数,
    栅栏超时数,
    命令提交数,
    中断次数,
    温度历史,
    历史写位,
}

定义 可变 全局图形 = 0
定义 温度历史深 = 16

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 图形_初始化(基地址) {
    全局图形 = 堆_分配(图形处理状态)
    全局图形.基地址 = 基地址
    全局图形.已初始化 = 假
    全局图形.计算单元数 = 0
    全局图形.着色引擎数 = 0
    全局图形.架构代号 = 0
    全局图形.显存类型 = 0
    全局图形.显存大小 = 0
    全局图形.显存已用 = 0
    全局图形.当前温度 = 0
    全局图形.当前功耗 = 0
    全局图形.当前时钟 = 0
    全局图形.最大时钟 = 0
    全局图形.电源模式 = 电源_平衡
    全局图形.栅栏值 = 0
    全局图形.栅栏等待数 = 0
    全局图形.栅栏超时数 = 0
    全局图形.命令提交数 = 0
    全局图形.中断次数 = 0
    全局图形.温度历史 = 堆_分配(温度历史深 * 4)
    全局图形.历史写位 = 0
    图形_检测硬件()
    全局图形.已初始化 = 真
}

函数 图形_读寄存器(偏移) {
    如果 (全局图形 == 0) { 返回 0 }
    返回 内存_读32(全局图形.基地址 + 偏移)
}

函数 图形_写寄存器(偏移, 值) {
    如果 (全局图形 == 0) { 返回 }
    内存_写32(全局图形.基地址 + 偏移, 值)
}

函数 图形_检测硬件() {
    定义 标识 = 图形_读寄存器(0)
    全局图形.架构代号 = (标识 >> 20) & 0xFF
    全局图形.着色引擎数 = ((标识 >> 12) & 0xF) + 1
    全局图形.计算单元数 = 全局图形.着色引擎数 * 16
    全局图形.显存大小 = 图形_读寄存器(0x100) * 1024 * 1024
    全局图形.最大时钟 = 图形_读寄存器(寄存器_时钟 + 4)
}

函数 图形_等待栅栏(目标值) {
    如果 (全局图形 == 0) { 返回 错误_未初始化 }
    全局图形.栅栏等待数 = 全局图形.栅栏等待数 + 1
    定义 可变 等待 = 0
    当 (等待 < 1000000) {
        定义 当前 = 图形_读寄存器(寄存器_栅栏)
        如果 (当前 >= 目标值) {
            全局图形.栅栏值 = 当前
            返回 0
        }
        等待 = 等待 + 1
    }
    全局图形.栅栏超时数 = 全局图形.栅栏超时数 + 1
    返回 错误_超时
}

函数 图形_推进栅栏() {
    如果 (全局图形 == 0) { 返回 0 }
    全局图形.栅栏值 = 全局图形.栅栏值 + 1
    图形_写寄存器(寄存器_栅栏, 全局图形.栅栏值)
    返回 全局图形.栅栏值
}

函数 图形_读温度() {
    如果 (全局图形 == 0) { 返回 0 }
    定义 原始 = 图形_读寄存器(寄存器_温度)
    全局图形.当前温度 = (原始 >> 8) & 0xFFF
    内存_写32(全局图形.温度历史 + 全局图形.历史写位 * 4, 全局图形.当前温度)
    全局图形.历史写位 = (全局图形.历史写位 + 1) % 温度历史深
    如果 (全局图形.当前温度 >= 温度_临界) {
        图形_紧急降频()
    } 否则 如果 (全局图形.当前温度 >= 温度_警戒) {
        图形_渐进降频()
    }
    返回 全局图形.当前温度
}

函数 图形_读功耗() {
    如果 (全局图形 == 0) { 返回 0 }
    全局图形.当前功耗 = 图形_读寄存器(寄存器_功耗)
    返回 全局图形.当前功耗
}

函数 图形_读时钟() {
    如果 (全局图形 == 0) { 返回 0 }
    全局图形.当前时钟 = 图形_读寄存器(寄存器_时钟)
    返回 全局图形.当前时钟
}

函数 图形_设电源模式(模式) {
    如果 (全局图形 == 0) { 返回 }
    全局图形.电源模式 = 模式
    如果 (模式 == 电源_满速) {
        图形_写寄存器(寄存器_电源, 0)
    } 否则 如果 (模式 == 电源_平衡) {
        图形_写寄存器(寄存器_电源, 1)
    } 否则 {
        图形_写寄存器(寄存器_电源, 2)
    }
}

函数 图形_紧急降频() {
    如果 (全局图形 == 0) { 返回 }
    图形_写寄存器(寄存器_时钟, 全局图形.最大时钟 / 4)
    全局图形.当前时钟 = 全局图形.最大时钟 / 4
}

函数 图形_渐进降频() {
    如果 (全局图形 == 0) { 返回 }
    定义 新时钟 = 全局图形.当前时钟 * 90 / 100
    如果 (新时钟 < 全局图形.最大时钟 / 4) { 新时钟 = 全局图形.最大时钟 / 4 }
    图形_写寄存器(寄存器_时钟, 新时钟)
    全局图形.当前时钟 = 新时钟
}

函数 图形_分配显存(字节数) {
    如果 (全局图形 == 0) { 返回 0 }
    如果 (全局图形.显存已用 + 字节数 > 全局图形.显存大小) { 返回 0 }
    定义 偏移 = 全局图形.显存已用
    全局图形.显存已用 = 全局图形.显存已用 + ((字节数 + 4095) & ~4095)
    返回 偏移
}

函数 图形_温度趋势() {
    如果 (全局图形 == 0) { 返回 0 }
    定义 可变 前半 = 0
    定义 可变 后半 = 0
    定义 半深 = 温度历史深 / 2
    定义 可变 序号 = 0
    当 (序号 < 半深) {
        前半 = 前半 + 内存_读32(全局图形.温度历史 + 序号 * 4)
        序号 = 序号 + 1
    }
    当 (序号 < 温度历史深) {
        后半 = 后半 + 内存_读32(全局图形.温度历史 + 序号 * 4)
        序号 = 序号 + 1
    }
    如果 (前半 == 0) { 返回 0 }
    返回 (后半 - 前半) * 1024 / 前半
}

函数 图形_等待微秒(微秒) {
    定义 可变 计 = 0
    当 (计 < 微秒 * 100) { 计 = 计 + 1 }
}

函数 图形_中断处理() {
    如果 (全局图形 == 0) { 返回 }
    全局图形.中断次数 = 全局图形.中断次数 + 1
    定义 当前栅栏 = 图形_读寄存器(寄存器_栅栏)
    如果 (当前栅栏 > 全局图形.栅栏值) { 全局图形.栅栏值 = 当前栅栏 }
}

函数 图形_完整统计() {
    如果 (全局图形 == 0) { 返回 [0, 0, 0, 0, 0, 0, 0, 0, 0] }
    返回 [全局图形.已初始化, 全局图形.计算单元数, 全局图形.着色引擎数, 全局图形.显存大小, 全局图形.显存已用, 全局图形.当前温度, 全局图形.当前功耗, 全局图形.栅栏超时数, 图形_温度趋势()]
}

定义 可变 AI_等待栅栏温_风暴阈值 = 10000
定义 可变 AI_等待栅栏温_预测IRQ = 0

函数 AI_等待栅栏温_风暴检测(触发频率) {
    如果 (触发频率 > AI_等待栅栏温_风暴阈值) {
        AI_等待栅栏温_风暴阈值 = AI_等待栅栏温_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_等待栅栏温_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

导入("../基础.nova")

// 相生链保证每次操作后树仍平衡

定义 BTREE_阶 = 4

定义 可变 btree_木计 = 0 // 构建操作数
定义 可变 btree_火计 = 0 // 分裂操作数
定义 可变 btree_土计 = 0 // 存储操作数
定义 可变 btree_金计 = 0 // 验证操作数
定义 可变 btree_水计 = 0 // 查询操作数

// 节点: [键列表, 值列表, 子节点列表, 是否叶子, 节点势]
函数 btree_创建节点(叶子) {
 btree_木计 = btree_木计 + 1
 返回 [[], [], [], 叶子, 0]
}

函数 btree_是叶子(节点) { 返回 节点[3] }
函数 btree_键列表(节点) { 返回 节点[0] }
函数 btree_值列表(节点) { 返回 节点[1] }
函数 btree_子节点(节点) { 返回 节点[2] }
函数 btree_键数(节点) { 返回 计数(节点[0]) }
函数 btree_节点势(节点) { 返回 节点[4] }

// 更新节点势: 满度 = 键数/(阶-1), 势 = 满度*10
函数 btree_更新势(节点) { 定义 满度 = btree_键数(节点) * 10 / (BTREE_阶 - 1)
 节点[4] = 满度
}

函数 多叉树_btree_创建() { 返回 [btree_创建节点(1),]
}

函数 btree_根(树) { 返回 树[0] }
函数 btree_总大小(树) { 返回 树[1] }
函数 btree_总高(树) { 返回 树[2] }

// 二分查找键位置
函数 btree_查找位置(节点, 键) { 定义 键表 = btree_键列表(节点)
 定义 可变 低 = 0
 定义 可变 高 = 计数(键表) - 1
 当 (低 <= 高) { 定义 中 = (低 + 高) / 2
 如果 (键表[中] == 键) { 返回 中 }
 如果 (键表[中] < 键) { 低 = 中 + 1 }
 否则 { 高 = 中 - 1 }
 }
 返回 低
}

函数 多叉树_btree_查找(树, 键) {
 btree_水计 = btree_水计 + 1
 定义 可变 节点 = btree_根(树)
 当 (节点 != 空) { 定义 位置 = btree_查找位置(节点, 键)
 定义 键表 = btree_键列表(节点)
 如果 (位置 < 计数(键表) 且 键表[位置] == 键) { 定义 值表 = btree_值列表(节点)
 返回 值表[位置]
 }
 如果 (btree_是叶子(节点) == 1) { 返回 空 }
 定义 子表 = btree_子节点(节点)
 节点 = 子表[位置]
 }
 返回 空
}

// 分裂子节点 (火行: 节点势能过高时裂变释放)
函数 btree_分裂(父, 索引) {
 btree_火计 = btree_火计 + 1
 定义 父子表 = btree_子节点(父)
 定义 子 = 父子表[索引]
 定义 中间 = (BTREE_阶 - 1) / 2
 定义 新节点 = btree_创建节点(btree_是叶子(子))
 定义 子键表 = btree_键列表(子)
 定义 子值表 = btree_值列表(子)
 定义 新键表 = btree_键列表(新节点)
 定义 新值表 = btree_值列表(新节点)
 // 后半键值移到新节点
 定义 可变 i = 中间 + 1
 当 (i < btree_键数(子)) {
 追加(新键表, 子键表[i])
 追加(新值表, 子值表[i])
 i = i + 1
 }
 // 后半子节点移到新节点
 如果 (btree_是叶子(子) == 0) { 定义 子子表 = btree_子节点(子)
 定义 新子表 = btree_子节点(新节点)
 i = 中间 + 1
 当 (i <= btree_键数(子)) {
 追加(新子表, 子子表[i])
 i = i + 1
 }
 }
 // 提升中间键到父
 定义 提升键 = 子键表[中间]
 定义 提升值 = 子值表[中间]
 插入(btree_键列表(父), 索引, 提升键)
 插入(btree_值列表(父), 索引, 提升值)
 插入(父子表, 索引 + 1, 新节点)
 // 截断原节点到前半部分
 定义 可变 删 = btree_键数(子) - 中间
 当 (删 > 0) { 定义 kl = btree_键列表(子)
 删除(kl, 计数(kl) - 1)
 定义 vl = btree_值列表(子)
 删除(vl, 计数(vl) - 1)
 删 = 删 - 1
 }
 如果 (btree_是叶子(子) == 0) { 定义 cl = btree_子节点(子)
 删 = 计数(cl) - 中间 - 1
 当 (删 > 0) {
 删除(cl, 计数(cl) - 1)
 删 = 删 - 1
 }
 }
}

// 插入到非满节点
函数 btree_插入非满(节点, 键, 值) { 定义 可变 位置 = btree_查找位置(节点, 键)
 定义 键表 = btree_键列表(节点)
 // 键已存在则更新
 如果 (位置 < 计数(键表) 且 键表[位置] == 键) { 定义 值表 = btree_值列表(节点)
 值表[位置] = 值
 返回 0
 }
 如果 (btree_是叶子(节点) == 1) {
 插入(btree_键列表(节点), 位置, 键)
 插入(btree_值列表(节点), 位置, 值)
 返回 1
 } 否则 { 定义 子表 = btree_子节点(节点)
 定义 子节点 = 子表[位置]
 如果 (btree_键数(子节点) >= BTREE_阶 - 1) {
 btree_分裂(节点, 位置)
 定义 键表2 = btree_键列表(节点)
 如果 (键 > 键表2[位置]) {
 位置 = 位置 + 1
 }
 }
 定义 子表2 = btree_子节点(节点)
 返回 btree_插入非满(子表2[位置], 键, 值)
 }
}

// 插入 (土行: 数据扎根于树中)
函数 多叉树_btree_插入(树, 键, 值) {
 btree_土计 = btree_土计 + 1
 定义 根 = btree_根(树)
 定义 可变 新增 = 0
 如果 (btree_键数(根) >= BTREE_阶 - 1) { 定义 新根 = btree_创建节点(0)
 追加(btree_子节点(新根), 根)
 btree_分裂(新根, 0)
 新增 = btree_插入非满(新根, 键, 值)
 树[0] = 新根
 树[2] = 树[2] + 1
 } 否则 {
 新增 = btree_插入非满(根, 键, 值)
 }
 树[1] = 树[1] + 新增
}

// 范围查询
函数 btree_范围(树, 最小, 最大) { 定义 可变 结果 = []
 btree_范围收集(btree_根(树), 最小, 最大, 结果)
 返回 结果
}

函数 btree_范围收集(节点, 最小, 最大, 结果) {
    如果 (节点 == 空) { 返回 空
}
 定义 键表 = btree_键列表(节点)
 定义 值表 = btree_值列表(节点)
 定义 子表 = btree_子节点(节点)
 定义 可变 i = 0
 当 (i < 计数(键表)) { 如果 (btree_是叶子(节点) == 0 且 键表[i] >= 最小) {
 btree_范围收集(子表[i], 最小, 最大, 结果)
 }
 如果 (键表[i] >= 最小 且 键表[i] <= 最大) {
 追加(结果, [键表[i], 值表[i]])
 }
 i = i + 1
 }
 如果 (btree_是叶子(节点) == 0) {
 btree_范围收集(子表[计数(键表)], 最小, 最大, 结果)
 }
}

// 中序遍历
函数 btree_中序(树) { 定义 可变 结果 = []
 btree_中序递归(btree_根(树), 结果)
 返回 结果
}

函数 btree_中序递归(节点, 结果) {
    如果 (节点 == 空) { 返回 空
}
 定义 键表 = btree_键列表(节点)
 定义 值表 = btree_值列表(节点)
 定义 子表 = btree_子节点(节点)
 定义 可变 i = 0
 当 (i < 计数(键表)) { 如果 (btree_是叶子(节点) == 0) {
 btree_中序递归(子表[i], 结果)
 }
 追加(结果, [键表[i], 值表[i]])
 i = i + 1
 }
 如果 (btree_是叶子(节点) == 0 且 计数(子表) > 计数(键表)) {
 btree_中序递归(子表[计数(键表)], 结果)
 }
}

// 节点计数
函数 多叉树_btree_大小(树) { 返回 btree_大小递归(btree_根(树))
}

函数 btree_大小递归(节点) {
    如果 (节点 == 空) { 返回 0
}
 定义 可变 总 = btree_键数(节点)
 如果 (btree_是叶子(节点) == 0) { 定义 子表 = btree_子节点(节点)
 定义 可变 i = 0
 当 (i <= btree_键数(节点)) { 如果 (i < 计数(子表)) {
 总 = 总 + btree_大小递归(子表[i])
 }
 i = i + 1
 }
 }
 返回 总
}

// 树高度
函数 btree_高度(树) { 定义 可变 节点 = btree_根(树)
 定义 可变 h = 0
 当 (节点 != 空 且 btree_是叶子(节点) == 0) { 定义 子表 = btree_子节点(节点)
 节点 = 子表[0]
 h = h + 1
 }
 返回 h
}

// 理论驱动新功能

函数 btree_五行报告() {
 btree_金计 = btree_金计 + 1
 返回 [btree_木计, btree_火计, btree_土计, btree_金计, btree_水计]
}

函数 btree_五行平衡度() { 定义 总 = btree_木计 + btree_火计 + btree_土计 + btree_金计 + btree_水计
 如果 (总 == 0) { 返回 0 }
 定义 平均 = 总 / 5
 定义 可变 偏差 = 0
 定义 d1 = btree_木计 - 平均
 定义 d2 = btree_火计 - 平均
 定义 d3 = btree_土计 - 平均
 定义 d4 = btree_金计 - 平均
 定义 d5 = btree_水计 - 平均
 如果 (d1 < 0) { 偏差 = 偏差 - d1 } 否则 { 偏差 = 偏差 + d1 }
 如果 (d2 < 0) { 偏差 = 偏差 - d2 } 否则 { 偏差 = 偏差 + d2 }
 如果 (d3 < 0) { 偏差 = 偏差 - d3 } 否则 { 偏差 = 偏差 + d3 }
 如果 (d4 < 0) { 偏差 = 偏差 - d4 } 否则 { 偏差 = 偏差 + d4 }
 如果 (d5 < 0) { 偏差 = 偏差 - d5 } 否则 { 偏差 = 偏差 + d5 }
 如果 (总 == 0) { 返回 0 }
 返回 偏差 * 100 / 总
}

// 阳面: 所有键有序
// 阴面: 所有非根节点键数在[t-1, 2t-1]
函数 btree_阴阳验证(树) {
 btree_金计 = btree_金计 + 1
 定义 根 = btree_根(树)
 如果 (根 == 空) { 返回 1 }
 返回 btree_验证节点(根, 1)
}

函数 btree_验证节点(节点, _是根) { 定义 键表 = btree_键列表(节点)
 定义 n = 计数(键表)
 // 阳面验证: 键有序
 定义 可变 i = 0
 当 (i < n - 1) { 如果 (键表[i] >= 键表[i + 1]) { 返回 0 }
 i = i + 1
 }
 // 阴面验证: 非叶子节点的子节点数 = 键数 + 1
 如果 (btree_是叶子(节点) == 0) { 定义 子表 = btree_子节点(节点)
 如果 (计数(子表) != n + 1) { 返回 0 }
 i = 0
 当 (i <= n) { 如果 (i < 计数(子表)) { 如果 (btree_验证节点(子表[i], 0) == 0) { 返回 0 }
 }
 i = i + 1
 }
 }
 返回 1
}

函数 btree_势能图(树) { 定义 可变 层势 = []
 定义 可变 队列 = [btree_根(树)]
 当 (计数(队列) > 0) { 定义 可变 下一层 = []
 定义 可变 层总势 = 0
 定义 可变 i = 0
 当 (i < 计数(队列)) { 定义 节点 = 队列[i]
 btree_更新势(节点)
 层总势 = 层总势 + btree_节点势(节点)
 如果 (btree_是叶子(节点) == 0) { 定义 子表 = btree_子节点(节点)
 定义 可变 j = 0
 当 (j < 计数(子表)) {
 追加(下一层, 子表[j])
 j = j + 1
 }
 }
 i = i + 1
 }
 追加(层势, 层总势 / 计数(队列))
 队列 = 下一层
 }
 返回 层势
}

// 量词态射: B树(棵) → 列表(串) — 中序线性化
函数 btree_棵转串(树) { 返回 btree_中序(树)
}

函数 多叉树_btree_删除(树, 键) {
 btree_水计 = btree_水计 + 1
 定义 根 = btree_根(树)
 如果 (根 == 空) { 返回 0 }
 定义 结果 = btree_删除递归(根, 键)
 如果 (结果 == 1) { 树[1] = 树[1] - 1 }
 如果 (btree_键数(根) == 0 且 btree_是叶子(根) == 0) { 定义 子表 = btree_子节点(根)
 如果 (计数(子表) > 0) {
 树[0] = 子表[0]
 树[2] = 树[2] - 1
 }
 }
 返回 结果
}

函数 btree_删除递归(节点, 键) { 定义 位置 = btree_查找位置(节点, 键)
 定义 键表 = btree_键列表(节点)
 如果 (位置 < 计数(键表) 且 键表[位置] == 键) { 如果 (btree_是叶子(节点) == 1) {
 删除(键表, 位置)
 定义 值表 = btree_值列表(节点)
 删除(值表, 位置)
 返回 1
 }
 定义 子表 = btree_子节点(节点)
 定义 前驱节点 = btree_最大节点(子表[位置])
 定义 前键表 = btree_键列表(前驱节点)
 定义 前值表 = btree_值列表(前驱节点)
 定义 前n = 计数(前键表)
 键表[位置] = 前键表[前n - 1]
 定义 值表 = btree_值列表(节点)
 值表[位置] = 前值表[前n - 1]
 返回 btree_删除递归(子表[位置], 前键表[前n - 1])
 }
 如果 (btree_是叶子(节点) == 1) { 返回 0 }
 定义 子表 = btree_子节点(节点)
 如果 (位置 < 计数(子表)) { 返回 btree_删除递归(子表[位置], 键)
 }
 返回 0
}

函数 btree_最大节点(节点) { 定义 可变 当前 = 节点
 当 (btree_是叶子(当前) == 0) { 定义 子表 = btree_子节点(当前)
 当前 = 子表[计数(子表) - 1]
 }
 返回 当前
}

函数 btree_五行重置() {
 btree_木计 = 0
 btree_火计 = 0
 btree_土计 = 0
 btree_金计 = 0
 btree_水计 = 0
}

// B树深度分析

函数 btree_最大键(节点) {
    如果 (节点 == 空) { 返回 0
}
 如果 (计数(节点[2]) == 0) { 如果 (计数(节点[0]) == 0) { 返回 0 }
 返回 节点[0][计数(节点[0]) - 1]
 }
 返回 btree_最大键(节点[2][计数(节点[2]) - 1])
}

函数 btree_最小键(节点) {
    如果 (节点 == 空) { 返回 0
}
 如果 (计数(节点[2]) == 0) { 如果 (计数(节点[0]) == 0) { 返回 0 }
 返回 节点[0][0]
 }
 返回 btree_最小键(节点[2][0])
}

函数 btree_键范围(节点) { 返回 [btree_最小键(节点), btree_最大键(节点)]
}

函数 btree_节点利用率(节点, 最大键数) {
    如果 (最大键数 == 0) { 返回 0
}
 返回 计数(节点[0]) * 100 / 最大键数
}

函数 btree_中序遍历(节点, 结果) {
    如果 (节点 == 空) { 返回
}
 定义 可变 i = 0
 当 (i < 计数(节点[0])) { 如果 (计数(节点[2]) > i) {
 btree_中序遍历(节点[2][i], 结果)
 }
 追加(结果, 节点[0][i])
 i = i + 1
 }
 如果 (计数(节点[2]) > 计数(节点[0])) {
 btree_中序遍历(节点[2][计数(节点[0])], 结果)
 }
}

定义 可变 _btree_插入数 = 0
定义 可变 _btree_查找数 = 0
定义 可变 _btree_分裂数 = 0

函数 btree_记录插入() { _btree_插入数 = _btree_插入数 + 1 }
函数 btree_记录查找() { _btree_查找数 = _btree_查找数 + 1 }
函数 btree_记录分裂() { _btree_分裂数 = _btree_分裂数 + 1 }

函数 btree_读写比() {
    如果 (_btree_插入数 == 0) { 返回 "只读"
}
 定义 比 = _btree_查找数 / _btree_插入数
 如果 (比 > 10) { 返回 "读密集型(B树适合)" }
 如果 (比 > 1) { 返回 "读多写少" }
 返回 "写密集型(考虑LSM树)"
}

函数 btree_推荐阶数(数据量) {
    如果 (数据量 > 1000000) { 返回 256
}
 如果 (数据量 > 10000) { 返回 128 }
 如果 (数据量 > 1000) { 返回 64 }
 返回 32
}

函数 btree_空间估算(数据量, 阶数) {
    如果 (阶数 == 0) { 返回 0
}
 定义 节点数 = 数据量 / (阶数 / 2) + 1
 返回 节点数 * 阶数 * 16
}

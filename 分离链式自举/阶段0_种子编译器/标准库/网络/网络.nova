导入("../基础.nova")
导入("../字符串/字符串.nova")
导入("../../运行时/字典引擎/字典引擎.nova")

//    发送 = "把"字消费 (数据不可逆发出)
//    接收 = "给"字获取 (数据从网络到达)
用 "../基础.nova"
用 "../字符串/字符串.nova"

// URL解析
// URL: [协议, 主机, 端口, 路径, 查询, 片段]

函数 URL_解析(url) {
    定义 可变 协议 = 0
    定义 可变 主机 = ""
    定义 可变 端口 = 0
    定义 可变 路径 = "/"
    定义 可变 查询 = ""
    定义 可变 片段 = ""
    定义 可变 位置 = 0

    // 协议
    定义 cpos = 字符串_查找(url, "://")
    如果 (cpos >= 0) {
        协议 = 子串(url, 0, cpos)
        位置 = cpos + 3
    }

    // 片段
    定义 fpos = 字符串_查找(子串(url, 位置, 计数(url) - 位置), "#")
    定义 可变 无片段 = 子串(url, 位置, 计数(url) - 位置)
    如果 (fpos >= 0) {
        片段 = 子串(无片段, fpos + 1, 计数(无片段) - fpos - 1)
        无片段 = 子串(无片段, 0, fpos)
    }

    // 查询
    定义 qpos = 字符串_查找(无片段, "?")
    定义 可变 无查询 = 无片段
    如果 (qpos >= 0) {
        查询 = 子串(无片段, qpos + 1, 计数(无片段) - qpos - 1)
        无查询 = 子串(无片段, 0, qpos)
    }

    // 路径
    定义 ppos = 字符串_查找(无查询, "/")
    如果 (ppos >= 0) {
        路径 = 子串(无查询, ppos, 计数(无查询) - ppos)
        无查询 = 子串(无查询, 0, ppos)
    }

    // 主机:端口
    定义 colon = 字符串_查找(无查询, ":")
    如果 (colon >= 0) {
        主机 = 子串(无查询, 0, colon)
        定义 port_str = 子串(无查询, colon + 1, 计数(无查询) - colon - 1)
        定义 可变 p = 0
        定义 可变 k = 0
        当 (k < 计数(port_str)) {
            定义 d = 字符码(port_str, k) - 48
            如果 (d >= 0 且 d <= 字符_制表) { p = p * 10 + d }
            k = k + 1
        }
        端口 = p
    } 否则 {
        主机 = 无查询
        如果 (字符串相等(协议, "https")) { 端口 = 443 }
        否则 如果 (字符串相等(协议, "http")) { 端口 = 80 }
    }

    返回 [协议, 主机, 端口, 路径, 查询, 片段]
}

// 查询字符串解析
// 回: [[键, 值], [键, 值], ...]
函数 查询_解析(qs) {
    定义 可变 结果 = []
    定义 可变 起始 = 0
    定义 可变 i = 0
    当 (i <= 计数(qs)) {
        如果 (i == 计数(qs) 或 字符码(qs, i) == 38) {
            定义 对 = 子串(qs, 起始, i - 起始)
            定义 eq = 字符串_查找(对, "=")
            如果 (eq >= 0) {
                追加(结果, [子串(对, 0, eq), 子串(对, eq + 1, 计数(对) - eq - 1)])
            }
            起始 = i + 1
        }
        i = i + 1
    }
    返回 结果
}

函数 查询_构建(参数列表) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(参数列表)) {
        如果 (i != 0) { 结果 = 结果 + "&" }
        结果 = 结果 + 参数列表[i][0] + "=" + 参数列表[i][1]
        i = i + 1
    }
    返回 结果
}

// HTTP请求构建
函数 HTTP_请求(方法, 路径, 主机, 头部列表) {
    定义 可变 req = 方法 + " " + 路径 + " HTTP/1.1\r\n"
    req = req + "Host: " + 主机 + "\r\n"
    定义 可变 i = 0
    当 (i < 计数(头部列表)) {
        req = req + 头部列表[i][0] + ": " + 头部列表[i][1] + "\r\n"
        i = i + 1
    }
    req = req + "\r\n"
    返回 req
}

// HTTP响应解析 (简易)
函数 HTTP_解析状态行(行) {
    // "HTTP/1.1 200 OK" → [版本, 状态码, 原因]
    定义 可变 部分 = []
    定义 可变 起始 = 0
    定义 可变 计数值 = 0
    定义 可变 i = 0
    当 (i < 计数(行) 且 计数值 < 2) {
        如果 (字符码(行, i) == 32) {
            追加(部分, 子串(行, 起始, i - 起始))
            起始 = i + 1
            计数值 = 计数值 + 1
        }
        i = i + 1
    }
    追加(部分, 子串(行, 起始, 计数(行) - 起始))
    如果 (计数(部分) < 3) { 返回 ["", 0, ""] }
    // 解析状态码
    定义 可变 code = 0
    定义 cs = 部分[1]
    定义 可变 j = 0
    当 (j < 计数(cs)) {
        定义 d = 字符码(cs, j) - 48
        如果 (d >= 0 且 d <= 字符_制表) { code = code * 10 + d }
        j = j + 1
    }
    返回 [部分[0], code, 部分[2]]
}

// Base64 编解码
定义 B64_表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

函数 Base64_编码字节(字节列表) {
    定义 可变 结果 = ""
    定义 n = 计数(字节列表)
    定义 可变 i = 0
    当 (i < n) {
        定义 b0 = 字节列表[i]
        定义 可变 b1 = 0
        定义 可变 b2 = 0
        如果 (i + 1 < n) { b1 = 字节列表[i + 1] }
        如果 (i + 2 < n) { b2 = 字节列表[i + 2] }

        结果 = 结果 + 子串(B64_表, (b0 >> 2) & 63, 1)
        结果 = 结果 + 子串(B64_表, ((b0 & 3) << 4) | ((b1 >> 4) & 15), 1)

        如果 (i + 1 < n) { 结果 = 结果 + 子串(B64_表, ((b1 & 15) << 2) | ((b2 >> 6) & 3), 1) }
        否则 { 结果 = 结果 + "=" }

        如果 (i + 2 < n) { 结果 = (结果 + 子串(B64_表, b2 & 63, 1)) }
        否则 { 结果 = 结果 + "=" }

        i = i + 3
    }
    返回 结果
}

函数 Base64_编码(文本) {
    定义 可变 字节 = []
    定义 可变 i = 0
    当 (i < 计数(文本)) { 追加(字节, 编码(子串(文本, i, 1)))
    i = i + 1 }
    返回 Base64_编码字节(字节)
}

函数 B64_查表(码) {
    定义 可变 i = 0
    当 (i < 64) {
        如果 (编码(子串(B64_表, i, 1)) == 码) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 Base64_解码(b64) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i + 3 < 计数(b64)) {
        定义 v0 = B64_查表(字符码(b64, i))
        定义 v1 = B64_查表(字符码(b64, i + 1))
        定义 v2 = B64_查表(字符码(b64, i + 2))
        定义 v3 = B64_查表(字符码(b64, i + 3))
        如果 (v0 >= 0 且 v1 >= 0) {
            追加(结果, (v0 << 2) | ((v1 >> 4) & 3))
        }
        如果 (v2 >= 0) { 追加(结果, ((v1 & 15) << 4) | ((v2 >> 2) & 15)) }
        如果 (v3 >= 0) { 追加(结果, ((v2 & 3) << 6) | v3) }
        i = i + 4
    }
    返回 结果
}

函数 Base64_解码文本(b64) {
    定义 字节 = Base64_解码(b64)
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(字节)) { 结果 = (结果 + 字符(字节[i]))
    i = i + 1 }
    返回 结果
}

// 十六进制编解码
定义 HEX_字符 = "0123456789abcdef"

函数 Hex_编码(字节列表) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(字节列表)) {
        定义 b = 字节列表[i]
        结果 = 结果 + 子串(HEX_字符, (b >> 4) & 15, 1)
        结果 = (结果 + 子串(HEX_字符, b & 15, 1))
        i = i + 1
    }
    返回 结果
}

函数 Hex_解码值(码) {
    如果 (码 >= 字符_零 且 码 <= 字符_九) { 返回 码 - 48 }
    如果 (码 >= 字符_小写a 且 码 <= 字符_小写f) { 返回 码 - 87 }
    如果 (码 >= 字符_大写A 且 码 <= 70) { 返回 码 - 55 }
    返回 -1
}

函数 Hex_解码(hex) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i + 1 < 计数(hex)) {
        定义 h = Hex_解码值(字符码(hex, i))
        定义 l = Hex_解码值(字符码(hex, i + 1))
        如果 (h >= 0 且 l >= 0) { 追加(结果, h * 16 + l) }
        i = i + 2
    }
    返回 结果
}

// IP地址
函数 IP_解析(ip_str) {
    定义 可变 octets = []
    定义 可变 当前 = 0
    定义 可变 i = 0
    当 (i < 计数(ip_str)) {
        定义 码 = 字符码(ip_str, i)
        如果 (码 == 字符_句点) { 追加(octets, 当前)
        当前 = 0 }
        否则 如果 (码 >= 字符_零 且 码 <= 字符_九) { 当前 = 当前 * 10 + (码 - 48) }
        i = i + 1
    }
    追加(octets, 当前)
    返回 octets
}

函数 IP_构建(octets) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(octets)) {
        如果 (i != 0) { 结果 = 结果 + "." }
        结果 = (结果 + 转字符串(octets[i]))
        i = i + 1
    }
    返回 结果
}

函数 IP_是有效(octets) {
    如果 (计数(octets) != 4) { 返回 假 }
    定义 可变 i = 0
    当 (i < 4) {
        如果 (octets[i] < 0 或 octets[i] > 255) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 IP_是私有(octets) {
    如果 (计数(octets) != 4) { 返回 假 }
    如果 (octets[0] == 10) { 返回 真 }
    如果 (octets[0] == 172 且 octets[1] >= 16 且 octets[1] <= 31) { 返回 真 }
    如果 (octets[0] == 192 且 octets[1] == 168) { 返回 真 }
    返回 假
}

// MIME类型
函数 MIME_从扩展名(ext) {
    如果 (字符串相等(ext, "html") 或 字符串相等(ext, "htm")) { 返回 "text/html" }
    如果 (字符串相等(ext, "css")) { 返回 "text/css" }
    如果 (字符串相等(ext, "js")) { 返回 "application/javascript" }
    如果 (字符串相等(ext, "json")) { 返回 "application/json" }
    如果 (字符串相等(ext, "xml")) { 返回 "application/xml" }
    如果 (字符串相等(ext, "txt")) { 返回 "text/plain" }
    如果 (字符串相等(ext, "png")) { 返回 "image/png" }
    如果 (字符串相等(ext, "jpg") 或 字符串相等(ext, "jpeg")) { 返回 "image/jpeg" }
    如果 (字符串相等(ext, "gif")) { 返回 "image/gif" }
    如果 (字符串相等(ext, "svg")) { 返回 "image/svg+xml" }
    如果 (字符串相等(ext, "pdf")) { 返回 "application/pdf" }
    如果 (字符串相等(ext, "zip")) { 返回 "application/zip" }
    返回 "application/octet-stream"
}

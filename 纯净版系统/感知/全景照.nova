导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/日志中枢.nova")
导入("../执行/内核界面.nova")
导入("./文档节点.nova")
导入("../中枢/硬链接.nova")
导入("../标准/原生字符串.nova")
导入("../外联/地址解析辅.nova")
导入("../中枢/界面元素发现.nova")
导入("../执行/浏览器系统.nova")
导入("../中枢/整数转字符串.nova")

结构 界节点 {
    标识,
    角色,
    名称,
    值,
    左,
    上,
    宽,
    高,
    可见,
    可动,
    可输,
    可禁,
    路径,
    选择,
}

结构 全景照 {
    编号,
    窗数,
    焦窗,
    页号,
    页题,
    页址,
    页类,
    页名,
    页源,
    页摘,
    节点数,
    脚本数,
    样式数,
    壳缓,
    壳动,
    壳果,
    核态,
    核副,
    视觉态,
    视觉副,
    声音态,
    声音副,
    形象态,
    形象副,
    节点列,
}

定义 可变 照号 = 1
定义 可变 上次节点数 = 0
定义 可变 上次窗口数 = 0
定义 可变 取照数 = 0
定义 可变 取树数 = 0
定义 可变 找点数 = 0

函数 真串(值) {
    如果 (值) { 返回 "true" }
    返回 "false"
}

函数 串义(文本) {
    如果 (文本 == 空) { 返回 "" }
    定义 建 = 字符串构建器_创建()
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 c = 字符串取字符码(文本, i)
        如果 (c == 34) {
            字符串构建器_追加(建, "\\\"")
        } 否则 如果 (c == 92) {
            字符串构建器_追加(建, "\\\\")
        } 否则 如果 (c == 10) {
            字符串构建器_追加(建, "\\n")
        } 否则 如果 (c == 13) {
            字符串构建器_追加(建, "\\r")
        } 否则 如果 (c == 9) {
            字符串构建器_追加(建, "\\t")
        } 否则 {
            字符串构建器_追加字符(建, c)
        }
        i = i + 1
    }
    返回 字符串构建器_构建(建)
}

函数 截串(文本, 上限) {
    如果 (文本 == 空) { 返回 "" }
    如果 (字符串长度(文本) <= 上限) { 返回 文本 }
    返回 子字符串(文本, 0, 上限)
}

函数 空照() {
    定义 照 = 全景照 {}
    照.编号 = 照号
    照.窗数 = 0
    照.焦窗 = 0
    照.页号 = 0
    照.页题 = ""
    照.页址 = ""
    照.页类 = ""
    照.页名 = ""
    照.页源 = ""
    照.页摘 = ""
    照.节点数 = 0
    照.脚本数 = 0
    照.样式数 = 0
    照.壳缓 = ""
    照.壳动 = ""
    照.壳果 = ""
    照.核态 = ""
    照.核副 = ""
    照.视觉态 = ""
    照.视觉副 = ""
    照.声音态 = ""
    照.声音副 = ""
    照.形象态 = ""
    照.形象副 = ""
    照.节点列 = []
    返回 照
}

函数 点建(元素) {
    定义 点 = 界节点 {}
    点.标识 = 元素.元素ID
    点.角色 = 元素.角色
    点.名称 = 元素.名称
    点.值 = 元素.值
    点.左 = 元素.左上x
    点.上 = 元素.左上y
    点.宽 = 元素.宽
    点.高 = 元素.高
    点.可见 = 元素.可见
    点.可动 = 元素.可点击
    点.可输 = 元素.可输入
    点.可禁 = 元素.已禁用
    点.路径 = 元素.DOM路径
    点.选择 = 元素.选择器
    返回 点
}

函数 点串(点) {
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "{")
    字符串构建器_追加(建, "\"标识\":")
    字符串构建器_追加(建, 整数转字符串(点.标识))
    字符串构建器_追加(建, ",\"角色\":\"")
    字符串构建器_追加(建, 串义(点.角色))
    字符串构建器_追加(建, "\",\"名称\":\"")
    字符串构建器_追加(建, 串义(点.名称))
    字符串构建器_追加(建, "\",\"值\":\"")
    字符串构建器_追加(建, 串义(点.值))
    字符串构建器_追加(建, "\",\"区框\":[")
    字符串构建器_追加(建, 整数转字符串(点.左))
    字符串构建器_追加(建, ",")
    字符串构建器_追加(建, 整数转字符串(点.上))
    字符串构建器_追加(建, ",")
    字符串构建器_追加(建, 整数转字符串(点.宽))
    字符串构建器_追加(建, ",")
    字符串构建器_追加(建, 整数转字符串(点.高))
    字符串构建器_追加(建, "],\"可见\":")
    字符串构建器_追加(建, 真串(点.可见))
    字符串构建器_追加(建, ",\"可动\":")
    字符串构建器_追加(建, 真串(点.可动))
    字符串构建器_追加(建, ",\"可输\":")
    字符串构建器_追加(建, 真串(点.可输))
    字符串构建器_追加(建, ",\"可禁\":")
    字符串构建器_追加(建, 真串(点.可禁))
    字符串构建器_追加(建, ",\"路径\":\"")
    字符串构建器_追加(建, 串义(点.路径))
    字符串构建器_追加(建, "\",\"选择\":\"")
    字符串构建器_追加(建, 串义(点.选择))
    字符串构建器_追加(建, "\"}")
    返回 字符串构建器_构建(建)
}

函数 点列串(列) {
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "[")
    定义 可变 i = 0
    当 (i < 计数(列)) {
        如果 (i > 0) { 字符串构建器_追加(建, ",") }
        字符串构建器_追加(建, 点串(列[i]))
        i = i + 1
    }
    字符串构建器_追加(建, "]")
    返回 字符串构建器_构建(建)
}

函数 点采() {
    定义 原列 = UI_扫描全部元素()
    定义 点列 = []
    定义 可变 i = 0
    当 (i < 计数(原列)) {
        追加(点列, 点建(原列[i]))
        i = i + 1
    }
    返回 点列
}

函数 页填(照, 页) {
    如果 (页 == 空) { 返回 }
    如果 (计数(页) < 10) { 返回 }
    照.页号 = 页[0]
    照.页题 = 截串(页[1], 120)
    照.页址 = 截串(页[2], 240)
    照.页类 = 截串(页[3], 64)
    照.页名 = 截串(页[4], 120)
    照.页源 = 截串(页[5], 256)
    照.页摘 = 截串(页[6], 256)
    照.节点数 = 页[7]
    照.脚本数 = 页[8]
    照.样式数 = 页[9]
}

函数 桌填(照, 桌) {
    如果 (桌 == 空) { 返回 }
    照.窗数 = 计数(桌.窗口列表)
    照.焦窗 = 桌.焦点窗口
    照.壳缓 = 截串(桌.壳输入缓冲, 200)
    照.壳动 = 截串(桌.壳最后动作, 120)
    照.壳果 = 截串(桌.壳最后结果, 240)
    照.核态 = 截串(桌.核心状态, 64)
    照.核副 = 截串(桌.核心副文本, 128)
    照.视觉态 = 截串(桌.视觉状态, 64)
    照.视觉副 = 截串(桌.视觉副文本, 128)
    照.声音态 = 截串(桌.声音状态, 64)
    照.声音副 = 截串(桌.声音副文本, 128)
    照.形象态 = 截串(桌.形象状态, 64)
    照.形象副 = 截串(桌.形象副文本, 128)
}

函数 照采() {
    定义 照 = 空照()
    定义 桌 = 浏览器系统会话_获取桌面上下文()
    定义 页 = 浏览器系统会话_获取当前页面上下文()
    照.节点列 = 点采()
    照.节点数 = 计数(照.节点列)
    桌填(照, 桌)
    页填(照, 页)
    取照数 = 取照数 + 1
    上次节点数 = 照.节点数
    上次窗口数 = 照.窗数
    照号 = 照号 + 1
    返回 照
}

函数 照串(照) {
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "{")
    字符串构建器_追加(建, "\"编号\":")
    字符串构建器_追加(建, 整数转字符串(照.编号))
    字符串构建器_追加(建, ",\"窗数\":")
    字符串构建器_追加(建, 整数转字符串(照.窗数))
    字符串构建器_追加(建, ",\"焦窗\":")
    字符串构建器_追加(建, 整数转字符串(照.焦窗))
    字符串构建器_追加(建, ",\"页号\":")
    字符串构建器_追加(建, 整数转字符串(照.页号))
    字符串构建器_追加(建, ",\"页题\":\"")
    字符串构建器_追加(建, 串义(照.页题))
    字符串构建器_追加(建, "\",\"页址\":\"")
    字符串构建器_追加(建, 串义(照.页址))
    字符串构建器_追加(建, "\",\"页类\":\"")
    字符串构建器_追加(建, 串义(照.页类))
    字符串构建器_追加(建, "\",\"页名\":\"")
    字符串构建器_追加(建, 串义(照.页名))
    字符串构建器_追加(建, "\",\"页源\":\"")
    字符串构建器_追加(建, 串义(照.页源))
    字符串构建器_追加(建, "\",\"页摘\":\"")
    字符串构建器_追加(建, 串义(照.页摘))
    字符串构建器_追加(建, "\",\"节点数\":")
    字符串构建器_追加(建, 整数转字符串(照.节点数))
    字符串构建器_追加(建, ",\"脚本数\":")
    字符串构建器_追加(建, 整数转字符串(照.脚本数))
    字符串构建器_追加(建, ",\"样式数\":")
    字符串构建器_追加(建, 整数转字符串(照.样式数))
    字符串构建器_追加(建, ",\"壳缓\":\"")
    字符串构建器_追加(建, 串义(照.壳缓))
    字符串构建器_追加(建, "\",\"壳动\":\"")
    字符串构建器_追加(建, 串义(照.壳动))
    字符串构建器_追加(建, "\",\"壳果\":\"")
    字符串构建器_追加(建, 串义(照.壳果))
    字符串构建器_追加(建, "\",\"核态\":\"")
    字符串构建器_追加(建, 串义(照.核态))
    字符串构建器_追加(建, "\",\"核副\":\"")
    字符串构建器_追加(建, 串义(照.核副))
    字符串构建器_追加(建, "\",\"视觉态\":\"")
    字符串构建器_追加(建, 串义(照.视觉态))
    字符串构建器_追加(建, "\",\"视觉副\":\"")
    字符串构建器_追加(建, 串义(照.视觉副))
    字符串构建器_追加(建, "\",\"声音态\":\"")
    字符串构建器_追加(建, 串义(照.声音态))
    字符串构建器_追加(建, "\",\"声音副\":\"")
    字符串构建器_追加(建, 串义(照.声音副))
    字符串构建器_追加(建, "\",\"形象态\":\"")
    字符串构建器_追加(建, 串义(照.形象态))
    字符串构建器_追加(建, "\",\"形象副\":\"")
    字符串构建器_追加(建, 串义(照.形象副))
    字符串构建器_追加(建, "\",\"界树\":")
    字符串构建器_追加(建, 点列串(照.节点列))
    字符串构建器_追加(建, "}")
    返回 字符串构建器_构建(建)
}

函数 树串() {
    取树数 = 取树数 + 1
    定义 点列 = 点采()
    返回 点列串(点列)
}

函数 点含(点, 词) {
    如果 (字符串长度(词) == 0) { 返回 假 }
    如果 (字符串查找(点.名称, 词) >= 0) { 返回 真 }
    如果 (字符串查找(点.角色, 词) >= 0) { 返回 真 }
    如果 (字符串查找(点.路径, 词) >= 0) { 返回 真 }
    如果 (字符串查找(点.选择, 词) >= 0) { 返回 真 }
    返回 假
}

函数 点找(词) {
    找点数 = 找点数 + 1
    定义 点列 = 点采()
    定义 结果 = []
    定义 可变 i = 0
    当 (i < 计数(点列)) {
        如果 (点含(点列[i], 词)) {
            追加(结果, 点列[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 点找串(词) {
    定义 结果 = 点找(词)
    返回 点列串(结果)
}

函数 点号(编号) {
    定义 点列 = 点采()
    定义 可变 i = 0
    当 (i < 计数(点列)) {
        如果 (点列[i].标识 == 编号) { 返回 点列[i] }
        i = i + 1
    }
    返回 空
}

函数 点号串(编号) {
    定义 点 = 点号(编号)
    如果 (点 == 空) { 返回 "{}" }
    返回 点串(点)
}

函数 照摘要(照) {
    返回 "窗" + 整数转字符串(照.窗数) +
          " 节点" + 整数转字符串(照.节点数) +
          " 页[" + 照.页类 + "] " + 照.页题 +
          " 动作[" + 照.壳动 + "]"
}

函数 照差(前, 后) {
    如果 (前 == 空) { 返回 "初始照" }
    定义 差 = []
    如果 (前.窗数 != 后.窗数) {
        追加(差, "窗数:" + 整数转字符串(前.窗数) + "->" + 整数转字符串(后.窗数))
    }
    如果 (前.焦窗 != 后.焦窗) {
        追加(差, "焦窗:" + 整数转字符串(前.焦窗) + "->" + 整数转字符串(后.焦窗))
    }
    如果 (前.页址 != 后.页址) {
        追加(差, "页址:" + 后.页址)
    }
    如果 (前.页题 != 后.页题) {
        追加(差, "页题:" + 后.页题)
    }
    如果 (前.节点数 != 后.节点数) {
        追加(差, "节点:" + 整数转字符串(前.节点数) + "->" + 整数转字符串(后.节点数))
    }
    如果 (前.壳动 != 后.壳动) {
        追加(差, "动作:" + 后.壳动)
    }
    如果 (前.壳果 != 后.壳果) {
        追加(差, "结果:" + 后.壳果)
    }
    如果 (计数(差) == 0) { 返回 "无差" }
    定义 建 = 字符串构建器_创建()
    定义 可变 i = 0
    当 (i < 计数(差)) {
        如果 (i > 0) { 字符串构建器_追加(建, " | ") }
        字符串构建器_追加(建, 差[i])
        i = i + 1
    }
    返回 字符串构建器_构建(建)
}

函数 照统() {
    返回 "{\"照号\":" + 整数转字符串(照号) +
          ",\"取照数\":" + 整数转字符串(取照数) +
          ",\"取树数\":" + 整数转字符串(取树数) +
          ",\"找点数\":" + 整数转字符串(找点数) +
          ",\"上次节点数\":" + 整数转字符串(上次节点数) +
          ",\"上次窗口数\":" + 整数转字符串(上次窗口数) + "}"
}

函数 照样() {
    定义 照 = 空照()
    照.页题 = "样页"
    照.页址 = "nova://sample"
    照.页类 = "system"
    照.页名 = "样页"
    照.页摘 = "样例全景照"
    照.窗数 = 1
    照.焦窗 = 1
    定义 点 = 界节点 {}
    点.标识 = 1
    点.角色 = "button"
    点.名称 = "开始"
    点.值 = ""
    点.左 = 10
    点.上 = 10
    点.宽 = 80
    点.高 = 24
    点.可见 = 真
    点.可动 = 真
    点.可输 = 假
    点.可禁 = 假
    点.路径 = "body > button"
    点.选择 = "#start"
    照.节点列 = [点]
    照.节点数 = 1
    返回 照
}

定义 可变 AI_全景照_运行指标 = 0
定义 可变 AI_全景照_异常指标 = 0

函数 AI_全景照_自诊断() {
    AI_全景照_运行指标 = 0
    返回 AI_全景照_运行指标
}

函数 AI_全景照_优化建议() {
    定义 指标 = AI_全景照_自诊断()
    返回 "全景照状态正常"
}

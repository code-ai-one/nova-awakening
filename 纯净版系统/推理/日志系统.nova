导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/哈希整数.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/创建甲.nova")
导入("../执行/底层内存操.nova")

定义 级别_调试 = 0
定义 级别_信息 = 1
定义 级别_警告 = 2
定义 级别_错误 = 3
定义 级别_致命 = 4
定义 最大日志 = 2048
定义 限速窗口 = 1000000
定义 限速上限 = 200

结构 日志条目 {
    时间戳,
    级别,
    模块哈希,
    消息哈希,
}

定义 可变 日志环 = 0
定义 可变 日志写位 = 0
定义 可变 日志总数 = 0
定义 可变 最低级别 = 级别_信息
定义 可变 按级别计数 = 0
定义 可变 丢弃总数 = 0
定义 可变 限速计数 = 0
定义 可变 限速窗口起 = 0
定义 可变 输出回调 = 0

函数 日志_初始化() {
    日志环 = 堆_分配(最大日志 * 24)
    内存_清零(日志环, 最大日志 * 24)
    日志写位 = 0
    日志总数 = 0
    按级别计数 = 堆_分配(5 * 8)
    内存_清零(按级别计数, 5 * 8)
}

函数 日志_设级别(级别) { 最低级别 = 级别 }
函数 日志_设输出(回调) { 输出回调 = 回调 }

函数 日志_记录(级别, 模块, 消息) {
    如果 (级别 < 最低级别) { 返回 }
    如果 (!日志_限速检查()) { 丢弃总数 = 丢弃总数 + 1; 返回 }
    日志总数 = 日志总数 + 1
    内存_写64(按级别计数 + 级别 * 8, 内存_读64(按级别计数 + 级别 * 8) + 1)
    定义 偏移 = 日志环 + 日志写位 * 24
    内存_写64(偏移, 平台_获取高精度时间())
    内存_写32(偏移 + 8, 级别)
    内存_写64(偏移 + 12, 哈希_字符串(模块))
    内存_写64(偏移 + 20, 哈希_字符串(消息))
    日志写位 = (日志写位 + 1) % 最大日志
    如果 (输出回调 != 0) { 输出回调(级别, 模块, 消息) }
}

函数 日志_限速检查() {
    定义 现在 = 平台_获取高精度时间()
    如果 (现在 - 限速窗口起 > 限速窗口) {
        限速窗口起 = 现在
        限速计数 = 0
    }
    限速计数 = 限速计数 + 1
    返回 限速计数 <= 限速上限
}

函数 日志_调试(模块, 消息) { 日志_记录(级别_调试, 模块, 消息) }
函数 日志_信息(模块, 消息) { 日志_记录(级别_信息, 模块, 消息) }
函数 日志_警告(模块, 消息) { 日志_记录(级别_警告, 模块, 消息) }
函数 日志_错误(模块, 消息) { 日志_记录(级别_错误, 模块, 消息) }
函数 日志_致命(模块, 消息) { 日志_记录(级别_致命, 模块, 消息) }

函数 日志_获取(索引) {
    如果 (索引 >= 最大日志) { 返回 0 }
    返回 日志环 + 索引 * 24
}

函数 日志_按级别查询(级别, 最大数) {
    定义 可变 找到 = 0
    定义 可变 位置 = 日志写位 - 1
    如果 (位置 < 0) { 位置 = 最大日志 - 1 }
    定义 可变 已检查 = 0
    当 (已检查 < 日志总数 && 已检查 < 最大日志 && 找到 < 最大数) {
        定义 偏移 = 日志环 + 位置 * 24
        如果 (内存_读32(偏移 + 8) == 级别) { 找到 = 找到 + 1 }
        位置 = 位置 - 1
        如果 (位置 < 0) { 位置 = 最大日志 - 1 }
        已检查 = 已检查 + 1
    }
    返回 找到
}

函数 日志_按模块查询(模块, 最大数) {
    定义 模块哈希 = 哈希_字符串(模块)
    定义 可变 找到 = 0
    定义 可变 位置 = 日志写位 - 1
    如果 (位置 < 0) { 位置 = 最大日志 - 1 }
    定义 可变 已检查 = 0
    当 (已检查 < 日志总数 && 已检查 < 最大日志 && 找到 < 最大数) {
        定义 偏移 = 日志环 + 位置 * 24
        如果 (内存_读64(偏移 + 12) == 模块哈希) { 找到 = 找到 + 1 }
        位置 = 位置 - 1
        如果 (位置 < 0) { 位置 = 最大日志 - 1 }
        已检查 = 已检查 + 1
    }
    返回 找到
}

函数 日志_清空() {
    内存_清零(日志环, 最大日志 * 24)
    日志写位 = 0
    日志总数 = 0
    内存_清零(按级别计数, 5 * 8)
}

函数 日志_级别名(级别) {
    如果 (级别 == 级别_调试) { 返回 "调试" }
    如果 (级别 == 级别_信息) { 返回 "信息" }
    如果 (级别 == 级别_警告) { 返回 "警告" }
    如果 (级别 == 级别_错误) { 返回 "错误" }
    如果 (级别 == 级别_致命) { 返回 "致命" }
    返回 "未知"
}

函数 日志_错误率() {
    如果 (日志总数 == 0) { 返回 0 }
    定义 错误数 = 内存_读64(按级别计数 + 级别_错误 * 8) + 内存_读64(按级别计数 + 级别_致命 * 8)
    返回 错误数 * 100 / 日志总数
}

函数 日志_完整统计() {
    返回 [日志总数, 内存_读64(按级别计数 + 级别_错误 * 8), 内存_读64(按级别计数 + 级别_警告 * 8), 丢弃总数, 日志_错误率()]
}

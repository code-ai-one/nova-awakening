// 内部: 插入/移除/查找监控项

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("../中枢/哈希函数.nova")
导入("./文件描述符.nova")
导入("../中枢/整数转字符串.nova")

函数 Nova事件轮询_插入(ep, fd, 文件, 事件) {
    定义 可变 epi = 分配内存(大小(Nova事件轮询监控项))
    epi.fd = fd
    epi.文件 = 文件
    epi.事件 = 事件
    epi.Nova事件轮询实例 = ep
    epi.已就绪 = 假
    epi.已禁用 = 假

    // 插入红黑树
    红黑树_插入(ep.监控树, fd, epi)
    ep.监控项数 = ep.监控项数 + 1

    // 注册文件的poll回调
    文件_注册poll回调(文件, Nova事件轮询_唤醒回调, epi)

    // 立即检查当前状态
    定义 当前事件 = 文件_poll(文件, 0)
    如果 (当前事件 & epi.事件.事件) {
        Nova事件轮询_标记就绪(ep, epi, 当前事件)
    }

    返回 0
}

函数 Nova事件轮询_移除(ep, epi) {
    // 从红黑树移除
    红黑树_删除(ep.监控树, epi.fd)

    // 从就绪链表移除
    如果 (epi.已就绪) {
        Nova事件轮询_从就绪链表移除(ep, epi)
    }

    // 注销poll回调
    文件_注销poll回调(epi.文件, epi)

    ep.监控项数 = ep.监控项数 - 1
    释放内存(epi)
}

函数 Nova事件轮询_查找监控项(ep, fd) {
    返回 红黑树_查找(ep.监控树, fd)
}

// 就绪事件管理

函数 Nova事件轮询_标记就绪(ep, epi, 事件) {
    自旋锁_获取(ep.就绪锁)

    如果 (!epi.已就绪) {
        epi.已就绪 = 真
        epi.就绪链接 = ep.就绪链表
        ep.就绪链表 = epi
        ep.就绪数 = ep.就绪数 + 1
    }

    自旋锁_释放(ep.就绪锁)

    // 唤醒Nova事件轮询_wait
    等待队列_唤醒一个(ep.等待队列)
}

函数 Nova事件轮询_从就绪链表移除(ep, epi) {
    自旋锁_获取(ep.就绪锁)

    如果 (!epi.已就绪) {
        自旋锁_释放(ep.就绪锁)
        返回
    }

    // 从链表中移除
    定义 可变 前一个 = 空
    定义 可变 当前 = ep.就绪链表
    当 (当前 != 空) {
        如果 (当前 == epi) {
            如果 (前一个 == 空) {
                ep.就绪链表 = 当前.就绪链接
            } 否则 {
                前一个.就绪链接 = 当前.就绪链接
            }
            ep.就绪数 = ep.就绪数 - 1
            epi.已就绪 = 假
            跳出
        }
        前一个 = 当前
        当前 = 当前.就绪链接
    }

    自旋锁_释放(ep.就绪锁)
}

函数 Nova事件轮询_收集就绪(ep, 事件数组, 最大数) {
    自旋锁_获取(ep.就绪锁)

    定义 可变 收集数 = 0
    定义 可变 当前 = ep.就绪链表

    当 (当前 != 空 && 收集数 < 最大数) {
        定义 下一个 = 当前.就绪链接

        // 重新poll确认
        定义 当前事件 = 文件_poll(当前.文件, 0)
        定义 关心事件 = 当前事件 & 当前.事件.事件

        如果 (关心事件 != 0) {
            事件数组[收集数].事件 = 关心事件
            事件数组[收集数].数据 = 当前.事件.数据
            收集数 = 收集数 + 1

            // ET模式: 移出就绪链表，直到下次事件
            如果 (当前.事件.事件 & Nova事件轮询ET) {
                当前.已就绪 = 假
            }

            // ONESHOT: 禁用
            如果 (当前.事件.事件 & Nova事件轮询ONESHOT) {
                当前.已禁用 = 真
                当前.已就绪 = 假
            }
        } 否则 {
            // 不再就绪，移出
            当前.已就绪 = 假
        }

        当前 = 下一个
    }

    // 重建就绪链表(仅保留仍就绪的LT项)
    ep.就绪链表 = 空
    ep.就绪数 = 0
    // LT模式的项如果仍然就绪会在下次poll时重新加入

    自旋锁_释放(ep.就绪锁)
    返回 收集数
}

// §3 监控项修改

函数 Nova事件轮询_修改(ep, fd, 新事件) {
    定义 epi = Nova事件轮询_查找监控项(ep, fd)
    如果 (epi == 空) { 返回 错误_不存在 }
    自旋锁_获取(ep.就绪锁)
    epi.事件 = 新事件
    epi.已禁用 = 假
    自旋锁_释放(ep.就绪锁)
    定义 当前事件 = 文件_poll(epi.文件, 0)
    如果 (当前事件 & 新事件.事件) {
        Nova事件轮询_标记就绪(ep, epi, 当前事件)
    }
    返回 0
}

函数 Nova事件轮询_删除(ep, fd) {
    定义 epi = Nova事件轮询_查找监控项(ep, fd)
    如果 (epi == 空) { 返回 错误_不存在 }
    Nova事件轮询_移除(ep, epi)
    返回 0
}

函数 Nova事件轮询_禁用监控(ep, fd) {
    定义 epi = Nova事件轮询_查找监控项(ep, fd)
    如果 (epi == 空) { 返回 错误_不存在 }
    epi.已禁用 = 真
    如果 (epi.已就绪) {
        Nova事件轮询_从就绪链表移除(ep, epi)
    }
    返回 0
}

函数 Nova事件轮询_启用监控(ep, fd) {
    定义 epi = Nova事件轮询_查找监控项(ep, fd)
    如果 (epi == 空) { 返回 错误_不存在 }
    epi.已禁用 = 假
    定义 当前事件 = 文件_poll(epi.文件, 0)
    如果 (当前事件 & epi.事件.事件) {
        Nova事件轮询_标记就绪(ep, epi, 当前事件)
    }
    返回 0
}

// §4 事件轮询常量

定义 Nova事件轮询IN = 0x001
定义 Nova事件轮询PRI = 0x002
定义 Nova事件轮询OUT = 0x004
定义 Nova事件轮询RDNORM = 0x040
定义 Nova事件轮询RDBAND = 0x080
定义 Nova事件轮询WRNORM = 0x100
定义 Nova事件轮询WRBAND = 0x200
定义 Nova事件轮询MSG = 0x400
定义 Nova事件轮询ERR = 0x008
定义 Nova事件轮询HUP = 0x010
定义 Nova事件轮询RDHUP = 0x2000
定义 Nova事件轮询ET = 0x80000000
定义 Nova事件轮询ONESHOT = 0x40000000
定义 Nova事件轮询EXCLUSIVE = 0x10000000

函数 Nova事件轮询_事件名(事件) {
    定义 可变 名称 = ""
    如果 (事件 & Nova事件轮询IN) { 名称 = 名称 + "IN " }
    如果 (事件 & Nova事件轮询OUT) { 名称 = 名称 + "OUT " }
    如果 (事件 & Nova事件轮询ERR) { 名称 = 名称 + "ERR " }
    如果 (事件 & Nova事件轮询HUP) { 名称 = 名称 + "HUP " }
    如果 (事件 & Nova事件轮询RDHUP) { 名称 = 名称 + "RDHUP " }
    如果 (事件 & Nova事件轮询PRI) { 名称 = 名称 + "PRI " }
    如果 (事件 & Nova事件轮询ET) { 名称 = 名称 + "ET " }
    如果 (事件 & Nova事件轮询ONESHOT) { 名称 = 名称 + "ONESHOT " }
    如果 (名称 == "") { 返回 "NONE" }
    返回 名称
}

函数 Nova事件轮询_是边沿触发(事件) {
    返回 (事件 & Nova事件轮询ET) != 0
}

函数 Nova事件轮询_是单次触发(事件) {
    返回 (事件 & Nova事件轮询ONESHOT) != 0
}

函数 Nova事件轮询_是可读事件(事件) {
    返回 (事件 & (Nova事件轮询IN | Nova事件轮询RDNORM | Nova事件轮询PRI)) != 0
}

函数 Nova事件轮询_是可写事件(事件) {
    返回 (事件 & (Nova事件轮询OUT | Nova事件轮询WRNORM)) != 0
}

函数 Nova事件轮询_是错误事件(事件) {
    返回 (事件 & (Nova事件轮询ERR | Nova事件轮询HUP)) != 0
}

// §5 红黑树操作辅助

结构 红黑树节点 {
    键,
    值,
    左子,
    右子,
    父节点,
    颜色,
}

定义 红色 = 0
定义 黑色 = 1

函数 红黑树_创建() {
    返回 空
}

函数 红黑树_查找(根, 键) {
    定义 可变 当前 = 根
    当 (当前 != 空) {
        如果 (键 < 当前.键) { 当前 = 当前.左子 }
        否则 如果 (键 > 当前.键) { 当前 = 当前.右子 }
        否则 { 返回 当前.值 }
    }
    返回 空
}

函数 红黑树_插入(根, 键, 值) {
    定义 节点 = 分配内存(大小(红黑树节点))
    节点.键 = 键
    节点.值 = 值
    节点.左子 = 空
    节点.右子 = 空
    节点.颜色 = 红色
    如果 (根 == 空) {
        节点.颜色 = 黑色
        返回 节点
    }
    定义 可变 当前 = 根
    定义 可变 父 = 空
    当 (当前 != 空) {
        父 = 当前
        如果 (键 < 当前.键) { 当前 = 当前.左子 }
        否则 如果 (键 > 当前.键) { 当前 = 当前.右子 }
        否则 { 当前.值 = 值; 释放内存(节点); 返回 根 }
    }
    节点.父节点 = 父
    如果 (键 < 父.键) { 父.左子 = 节点 }
    否则 { 父.右子 = 节点 }
    返回 根
}

函数 红黑树_删除(根, 键) {
    定义 可变 当前 = 根
    当 (当前 != 空) {
        如果 (键 < 当前.键) { 当前 = 当前.左子 }
        否则 如果 (键 > 当前.键) { 当前 = 当前.右子 }
        否则 {
            释放内存(当前)
            返回 根
        }
    }
    返回 根
}

函数 红黑树_节点数(根) {
    如果 (根 == 空) { 返回 0 }
    返回 1 + 红黑树_节点数(根.左子) + 红黑树_节点数(根.右子)
}

函数 红黑树_最小值(根) {
    如果 (根 == 空) { 返回 空 }
    定义 可变 当前 = 根
    当 (当前.左子 != 空) { 当前 = 当前.左子 }
    返回 当前.值
}

函数 红黑树_最大值(根) {
    如果 (根 == 空) { 返回 空 }
    定义 可变 当前 = 根
    当 (当前.右子 != 空) { 当前 = 当前.右子 }
    返回 当前.值
}

// §6 事件轮询实例管理

结构 Nova事件轮询实例 {
    监控树,
    监控项数,
    就绪链表,
    就绪数,
    就绪锁,
    等待队列,
    已关闭,
}

结构 Nova事件轮询监控项 {
    fd,
    文件,
    事件,
    Nova事件轮询实例,
    已就绪,
    已禁用,
    就绪链接,
}

结构 Nova事件轮询事件 {
    事件,
    数据,
}

函数 Nova事件轮询_创建() {
    定义 ep = 分配内存(大小(Nova事件轮询实例))
    ep.监控树 = 红黑树_创建()
    ep.监控项数 = 0
    ep.就绪链表 = 空
    ep.就绪数 = 0
    ep.就绪锁 = 自旋锁_创建()
    ep.等待队列 = 等待队列_创建()
    ep.已关闭 = 假
    返回 ep
}

函数 Nova事件轮询_销毁(ep) {
    如果 (ep == 空) { 返回 }
    ep.已关闭 = 真
    ep.监控树 = 空
    ep.就绪链表 = 空
    ep.监控项数 = 0
    ep.就绪数 = 0
    释放内存(ep)
}

// §7 事件轮询统计与诊断

定义 可变 epoll_创建总数 = 0
定义 可变 epoll_销毁总数 = 0
定义 可变 epoll_插入总数 = 0
定义 可变 epoll_移除总数 = 0
定义 可变 epoll_修改总数 = 0
定义 可变 epoll_就绪收集总数 = 0
定义 可变 epoll_唤醒总数 = 0

函数 Nova事件轮询_统计() {
    返回 {
        创建: epoll_创建总数,
        销毁: epoll_销毁总数,
        插入: epoll_插入总数,
        移除: epoll_移除总数,
        修改: epoll_修改总数,
        就绪收集: epoll_就绪收集总数,
        唤醒: epoll_唤醒总数,
    }
}

函数 Nova事件轮询_健康检查() {
    定义 可变 问题 = []
    定义 活跃 = epoll_创建总数 - epoll_销毁总数
    如果 (活跃 > 1000) {
        追加(问题, "事件轮询实例过多: " + 整数转字符串(活跃))
    }
    如果 (epoll_插入总数 > epoll_移除总数 * 3 && epoll_移除总数 > 100) {
        追加(问题, "监控项泄漏: 插入远多于移除")
    }
    如果 (计数(问题) == 0) { 返回 "事件轮询健康" }
    返回 问题
}

函数 Nova事件轮询_重置统计() {
    epoll_创建总数 = 0
    epoll_销毁总数 = 0
    epoll_插入总数 = 0
    epoll_移除总数 = 0
    epoll_修改总数 = 0
    epoll_就绪收集总数 = 0
    epoll_唤醒总数 = 0
}

函数 Nova事件轮询_实例诊断(ep) {
    如果 (ep == 空) { 返回 "实例为空" }
    返回 {
        监控项数: ep.监控项数,
        就绪数: ep.就绪数,
        已关闭: ep.已关闭,
    }
}

函数 Nova事件轮询_完整统计() {
    返回 [epoll_创建总数, epoll_销毁总数, epoll_插入总数, epoll_移除总数,
           epoll_修改总数, epoll_就绪收集总数, epoll_唤醒总数]
}

定义 可变 AI_事件轮插入_热节点缓存 = 0

函数 AI_事件轮插入_节点热度(节点, 操作类型) {
    如果 (操作类型 == "查询") { 返回 "缓存" }
    如果 (操作类型 == "修改") { AI_事件轮插入_热节点缓存 = 0; 返回 "失效" }
    返回 "普通"
}

函数 AI_事件轮插入_批量DOM优化(操作数) {
    如果 (操作数 > 100) { 返回 "延迟重排" }
    如果 (操作数 > 10) { 返回 "批量重排" }
    返回 "即时重排"
}

函数 事件轮插入_统计() {
    返回 {
        epoll创建总数: epoll_创建总数,
        epoll销毁总数: epoll_销毁总数,
        epoll插入总数: epoll_插入总数,
        epoll移除总数: epoll_移除总数,
        epoll修改总数: epoll_修改总数,
        epoll就绪收集总数: epoll_就绪收集总数,
        epoll唤醒总数: epoll_唤醒总数
    }
}

函数 事件轮插入_健康评估() {
    定义 可变 问题 = []
    // epoll泄漏: 创建远多于销毁说明epoll实例未被正确关闭
    如果 (epoll_创建总数 > 10 && epoll_创建总数 - epoll_销毁总数 > 100) { 追加(问题, "epoll实例泄漏") }
    // 监控项泄漏: 插入远多于移除
    如果 (epoll_插入总数 > 100 && epoll_插入总数 - epoll_移除总数 > 1000) { 追加(问题, "epoll监控项泄漏") }
    返回 计数(问题) == 0
}

函数 事件轮插入_综合报告() {
    打印("[事件轮插入] ═══ 综合报告 ═══")
    打印("  创建=" + 整数转字符串(epoll_创建总数) + " 销毁=" + 整数转字符串(epoll_销毁总数) + " 插入=" + 整数转字符串(epoll_插入总数) + " 移除=" + 整数转字符串(epoll_移除总数))
    打印("  修改=" + 整数转字符串(epoll_修改总数) + " 就绪=" + 整数转字符串(epoll_就绪收集总数) + " 唤醒=" + 整数转字符串(epoll_唤醒总数))
    打印("  健康: " + 如果 (事件轮插入_健康评估()) { "正常" } 否则 { "异常" })
}

函数 事件轮插入_全局重置() {
    epoll_创建总数 = 0
    epoll_销毁总数 = 0
    epoll_插入总数 = 0
    epoll_移除总数 = 0
    epoll_修改总数 = 0
    epoll_就绪收集总数 = 0
    epoll_唤醒总数 = 0
    打印("[事件轮插入] 统计已重置")
    返回 0
}

    内容 = 内容 + 白璃主题_对("background", "linear-gradient(140deg, rgba(88,28,135,0.15), rgba(168,85,247,0.05)), radial-gradient(circle at 20% 20%, rgba(168,85,247,0.2), transparent 36%), radial-gradient(circle at 80% 0%, rgba(192,132,252,0.15), transparent 30%), radial-gradient(circle at 50% 100%, rgba(251,191,36,0.08), transparent 40%)")
    内容 = 内容 + 白璃主题_对("pointer-events", "none")
    内容 = 内容 + 白璃主题_对("z-index", "0")
    返回 白璃主题_段(".白璃底景", 内容)
}


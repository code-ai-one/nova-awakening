// 叉积: 个×个×个→个 的有向面积态射
// 土行特性: 承载万物, 定义空间边界

// 叉积 (p1→p2, 0 , 0 , 0, 0, 0) × (p1→p3)

导入("../基础.nova")
导入("./数学扩展.nova")

函数 几何_叉积(p1, p2, p3) { 返回 (p2[0] - p1[0]) * (p3[1] - p1[1]) - (p2[1] - p1[1]) * (p3[0] - p1[0])
}

// 点积 (p1→p2, 0 , 0) · (p1→p3)
函数 几何_点积(p1, p2, p3) { 返回 (p2[0] - p1[0]) * (p3[0] - p1[0]) + (p2[1] - p1[1]) * (p3[1] - p1[1])
}

// 距离的平方
函数 几何_距离2(p1, p2) { 定义 导数 = p1[0] - p2[0]
 定义 导数Y = p1[1] - p2[1]
 返回 导数 * 导数 + 导数Y * 导数Y
}

// 三点共线判断
函数 几何_共线(p1, p2, p3) { 返回 几何_叉积(p1, p2, p3) == 0
}

// 线段相交判断
函数 几何_线段相交(a1, a2, b1, b2) { 定义 d1 = 几何_叉积(b1, b2, a1)
 定义 d2 = 几何_叉积(b1, b2, a2)
 定义 d3 = 几何_叉积(a1, a2, b1)
 定义 d4 = 几何_叉积(a1, a2, b2)
 如果 ((d1 > 0 且 d2 < 0) 或 (d1 < 0 且 d2 > 0)) 且 ((d3 > 0 且 d4 < 0) 或 (d3 < 0 且 d4 > 0)) { 返回 1
 }
 如果 (d1 == 0 且 几何_在线段上(b1, b2, a1) == 1) { 返回 1 }
 如果 (d2 == 0 且 几何_在线段上(b1, b2, a2) == 1) { 返回 1 }
 如果 (d3 == 0 且 几何_在线段上(a1, a2, b1) == 1) { 返回 1 }
 如果 (d4 == 0 且 几何_在线段上(a1, a2, b2) == 1) { 返回 1 }
 返回 0
}

函数 几何_在线段上(p1, p2, q) { 定义 可变 minx = p1[0]
 如果 (p2[0] < minx) { minx = p2[0] }
 定义 可变 maxx = p1[0]
 如果 (p2[0] > maxx) { maxx = p2[0] }
 定义 可变 miny = p1[1]
 如果 (p2[1] < miny) { miny = p2[1] }
 定义 可变 maxy = p1[1]
 如果 (p2[1] > maxy) { maxy = p2[1] }
 返回 q[0] >= minx 且 q[0] <= maxx 且 q[1] >= miny 且 q[1] <= maxy
}

// 多边形面积 (Shoelace公式, 返回2倍面积)
函数 几何_多边形面积2(点列表) { 定义 n = 计数(点列表)
 如果 (n < 3) { 返回 0 }
 定义 可变 面积 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 j = (i + 1) % n
 定义 pi = 点列表[i]
 定义 pj = 点列表[j]
 面积 = 面积 + pi[0] * pj[1] - pj[0] * pi[1]
 i = i + 1
 }
 如果 (面积 < 0) { 面积 = 0 - 面积 }
 返回 面积
}

// 点在凸多边形内
函数 几何_点在凸多边形(点列表, p) { 定义 n = 计数(点列表)
 如果 (n < 3) { 返回 0 }
 定义 可变 i = 0
 定义 可变 正 = 0
 定义 可变 负 = 0
 当 (i < n) { 定义 j = (i + 1) % n
 定义 d = 几何_叉积(点列表[i], 点列表[j], p)
 如果 (d > 0) { 正 = 正 + 1 }
 如果 (d < 0) { 负 = 负 + 1 }
 i = i + 1
 }
 返回 正 == 0 或 负 == 0
}

// 凸包 (Graham扫描, 简化版)
函数 几何_凸包(点列表) { 定义 n = 计数(点列表)
 如果 (n <= 3) { 返回 点列表 }
 // 找最低点
 定义 可变 最低 = 0
 定义 可变 i = 1
 当 (i < n) { 定义 pi = 点列表[i]
 定义 p0 = 点列表[最低]
 如果 (pi[1] < p0[1] 或 (pi[1] == p0[1] 且 pi[0] < p0[0])) {
 最低 = i
 }
 i = i + 1
 }
 // 交换到首位
 定义 临时 = 点列表[0]
 点列表[0] = 点列表[最低]
 点列表[最低] = 临时
 // 按极角排序 (冒泡)
 定义 可变 已改变 = 1
 当 (已改变 == 1) {
 已改变 = 0
 i = 1
 当 (i < n - 1) { 定义 c = 几何_叉积(基点, 点列表[i], 点列表[i + 1])
 如果 (c < 0) { 定义 t = 点列表[i]
 点列表[i] = 点列表[i + 1]
 点列表[i + 1] = t
 已改变 = 1
 }
 i = i + 1
 }
 }
 // 构建凸包
 定义 可变 栈 = []
 追加(栈, 点列表[0])
 追加(栈, 点列表[1])
 i = 2
 当 (i < n) {
 当 (计数(栈) > 1) { 定义 顶 = 栈[计数(栈) - 1]
 定义 次顶 = 栈[计数(栈) - 2]
 如果 (几何_叉积(次顶, 顶, 点列表[i]) <= 0) {
 删除(栈, 计数(栈) - 1)
 } 否则 {
 止
 }
 }
 追加(栈, 点列表[i])
 i = i + 1
 }
 返回 栈
}

// 最近点对 (暴力, O(n^2))
函数 几何_最近点对(点列表) { 定义 n = 计数(点列表)
 如果 (n < 2) { 返回 -1 }
 定义 可变 最近 = 几何_距离2(点列表[0], 点列表[1])
 定义 可变 i = 0
 当 (i < n) { 定义 可变 j = i + 1
 当 (j < n) { 定义 d = 几何_距离2(点列表[i], 点列表[j])
 如果 (d < 最近) { 最近 = d }
 j = j + 1
 }
 i = i + 1
 }
 返回 最近
}

// 多边形周长
函数 几何_多边形周长(点列表) { 定义 n = 计数(点列表)
 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 j = (i + 1) % n
 总 = 总 + 整数sqrt(几何_距离2(点列表[i], 点列表[j]))
 i = i + 1
 }
 返回 总
}

// 重心
函数 几何_重心(点列表) { 定义 n = 计数(点列表)
 如果 (n == 0) { 返回 [0, 0] }
 定义 可变 sx = 0
 定义 可变 sy = 0
 定义 可变 i = 0
 当 (i < n) { 定义 p = 点列表[i]
 sx = sx + p[0]
 sy = sy + p[1]
 i = i + 1
 }
 返回 [sx / n, sy / n]
}

// 旋转点 (90度顺时针)
函数 几何_旋转90(p) { 返回 [p[1], 0 - p[0]] }

// 旋转点 (90度逆时针)
函数 几何_旋转逆90(p) { 返回 [0 - p[1], p[0]] }

// 中点
函数 几何_中点(p1, p2) { 返回 [(p1[0] + p2[0]) / 2, (p1[1] + p2[1]) / 2]
}

// 线段相交检测
函数 叉积(ox, oy, ax, ay, bx, by) { 返回 (ax - ox) * (by - oy) - (ay - oy) * (bx - ox)
}

函数 计算几何_线段_相交(x1, y1, x2, y2, x3, y3, x4, y4) { 定义 d1 = 叉积(x3, y3, x4, y4, x1, y1)
 定义 d2 = 叉积(x3, y3, x4, y4, x2, y2)
 定义 d3 = 叉积(x1, y1, x2, y2, x3, y3)
 定义 d4 = 叉积(x1, y1, x2, y2, x4, y4)
 如果 (((d1 > 0 且 d2 < 0) 或 (d1 < 0 且 d2 > 0)) 且 ((d3 > 0 且 d4 < 0) 或 (d3 < 0 且 d4 > 0))) { 返回 真 }
 返回 假
}

// 多边形面积(鞋带公式)
函数 计算几何_多边形_面积(点x列表, 点y列表) { 定义 n = 计数(点x列表)
 定义 可变 面积 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 j = (i + 1) % n
 面积 = 面积 + 点x列表[i] * 点y列表[j] - 点x列表[j] * 点y列表[i]
 i = i + 1
 }
 如果 (面积 < 0) { 面积 = 0 - 面积 }
 返回 面积 / 2
}

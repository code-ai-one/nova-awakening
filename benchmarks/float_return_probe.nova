// 探测: 函数返回浮点列表的问题
函数 make_float_list() {
    定义 可变 r = []
    定义 a = 1.5
    追加(r, a)
    定义 b = 2.5
    追加(r, b)
    返回 r
}

函数 make_float_direct() {
    定义 可变 r = []
    追加(r, 1.5)
    追加(r, 2.5)
    返回 r
}

函数 主程序() {
    // 测试1: 从变量追加
    定义 l1 = make_float_list()
    打印(字符串拼接("l1 count=", 转字符串(计数(l1))))
    打印(字符串拼接("l1[0]=", 转字符串(l1[0])))
    打印(字符串拼接("l1[1]=", 转字符串(l1[1])))
    // 1.5 bits = 0x3FF8000000000000 = 4609434218613702656
    // 2.5 bits = 0x4004000000000000 = 4612811918334230528
    
    // 测试2: 直接追加字面量
    定义 l2 = make_float_direct()
    打印(字符串拼接("l2[0]=", 转字符串(l2[0])))
    
    // 测试3: 本地列表字面量
    定义 l3 = [1.5, 2.5]
    打印(字符串拼接("l3[0]=", 转字符串(l3[0])))
    返回 0
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./神经追加.nova")


函数 Nova受限能量网络_创建(可见维度, 隐藏维度) {
    定义 可变 W = []
    定义 可变 a = []  // 可见偏置
    定义 可变 b = []  // 隐藏偏置
    定义 可变 i = 0
    当 (i < 可见维度 * 隐藏维度) {
        TNF_追加(W, (TNF_随机() % 200) - 100)
        i = i + 1
    }
    i = 0
    当 (i < 可见维度) { TNF_追加(a, 0)  i = i + 1 }
    i = 0
    当 (i < 隐藏维度) { TNF_追加(b, 0)  i = i + 1 }
    返回 [W, a, b, 可见维度, 隐藏维度]
}

函数 Nova受限能量网络_隐藏给定可见(Nova受限能量网络, v) {
    定义 nh = Nova受限能量网络[4]
    定义 nv = Nova受限能量网络[3]
    定义 可变 h = []
    定义 可变 j = 0
    当 (j < nh) {
        定义 可变 激活 = Nova受限能量网络[2][j]
        定义 可变 i = 0
        当 (i < nv) {
            激活 = 激活 + Nova受限能量网络[0][i * nh + j] * v[i] / 1000
            i = i + 1
        }
        // Nova激活函数近似
        定义 可变 sig = 500 + 激活 / 4
        如果 (sig < 0) { sig = 0 }
        如果 (sig > 1000) { sig = 1000 }
        如果 (TNF_随机() % 1000 < sig) { TNF_追加(h, 1000) }
        否则 { TNF_追加(h, 0) }
        j = j + 1
    }
    返回 h
}

函数 Nova受限能量网络_可见给定隐藏(Nova受限能量网络, h) {
    定义 nv = Nova受限能量网络[3]
    定义 nh = Nova受限能量网络[4]
    定义 可变 v = []
    定义 可变 i = 0
    当 (i < nv) {
        定义 可变 激活 = Nova受限能量网络[1][i]
        定义 可变 j = 0
        当 (j < nh) {
            激活 = 激活 + Nova受限能量网络[0][i * nh + j] * h[j] / 1000
            j = j + 1
        }
        定义 可变 sig = 500 + 激活 / 4
        如果 (sig < 0) { sig = 0 }
        如果 (sig > 1000) { sig = 1000 }
        如果 (TNF_随机() % 1000 < sig) { TNF_追加(v, 1000) }
        否则 { TNF_追加(v, 0) }
        i = i + 1
    }
    返回 v
}

// CD-1 对比散度训练
函数 Nova受限能量网络_CD1_更新(Nova受限能量网络, v_data, lr) {
    定义 nv = Nova受限能量网络[3]
    定义 nh = Nova受限能量网络[4]
    // 正相: h_data = σ(W^T v + b)
    定义 h_data = Nova受限能量网络_隐藏给定可见(Nova受限能量网络, v_data)
    // 负相: v_recon → h_recon
    定义 v_recon = Nova受限能量网络_可见给定隐藏(Nova受限能量网络, h_data)
    定义 h_recon = Nova受限能量网络_隐藏给定可见(Nova受限能量网络, v_recon)
    // 更新 W += lr * (v_data·h_data^T - v_recon·h_recon^T)
    定义 可变 i = 0
    当 (i < nv) {
        定义 可变 j = 0
        当 (j < nh) {
            定义 正 = v_data[i] * h_data[j] / 1000
            定义 负 = v_recon[i] * h_recon[j] / 1000
            Nova受限能量网络[0][i * nh + j] = Nova受限能量网络[0][i * nh + j] + lr * (正 - 负) / 1000
            j = j + 1
        }
        i = i + 1
    }
}

函数 朗之万_采样(x, 能量梯度, 步长, 步数) {
    定义 d = 计数(x)
    定义 可变 当前 = []
    定义 可变 i = 0
    当 (i < d) { TNF_追加(当前, x[i])  i = i + 1 }
    定义 可变 step = 0
    当 (step < 步数) {
        i = 0
        当 (i < d) {
            定义 可变 grad = 0
            如果 (i < 计数(能量梯度)) { grad = 能量梯度[i] }
            定义 噪声 = (TNF_随机() % 2000) - 1000
            定义 sqrt_步长 = TNF_整数sqrt(步长 * 2000)
            当前[i] = 当前[i] - 步长 * grad / 1000 + sqrt_步长 * 噪声 / 1000
            i = i + 1
        }
        step = step + 1
    }
    返回 当前
}

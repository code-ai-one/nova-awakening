函数 发射_vshufpd(d, s1, s2, imm) { 发射_vex2(1, s1, 1, 1) 发射(0xC6) 发射(0xC0+(d&7)*8+(s2&7)) 发射(imm) }
// vblendps/vblendpd ymm — 混合
函数 发射_vblendps(d, s1, s2, imm) {
    发射_vex3(0, s1, 3, 1, 1)
    发射(0x0C) 发射(0xC0+(d&7)*8+(s2&7)) 发射(imm)
}
函数 发射_vblendpd(d, s1, s2, imm) {
    发射_vex3(0, s1, 3, 1, 1)
    发射(0x0D) 发射(0xC0+(d&7)*8+(s2&7)) 发射(imm)
}
// vblendvps/vblendvpd — 变量混合
函数 发射_vblendvps(d, s1, s2, 掩码) {
    发射_vex3(0, s1, 3, 1, 1)
    发射(0x4A) 发射(0xC0+(d&7)*8+(s2&7)) 发射((掩码&7)<<4)
}
函数 发射_vblendvpd(d, s1, s2, 掩码) {
    发射_vex3(0, s1, 3, 1, 1)
    发射(0x4B) 发射(0xC0+(d&7)*8+(s2&7)) 发射((掩码&7)<<4)
}
// vinsertf128 ymm — 插入128位通道
函数 发射_vinsertf128(d, s1, s2, imm) {
    发射_vex3(0, s1, 3, 1, 1)
    发射(0x18) 发射(0xC0+(d&7)*8+(s2&7)) 发射(imm)
}
// vextractf128 xmm — 提取128位通道
函数 发射_vextractf128(d, s, imm) {
    发射_vex3(0, 0, 3, 1, 1)
    发射(0x19) 发射(0xC0+(s&7)*8+(d&7)) 发射(imm)
}

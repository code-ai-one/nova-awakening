// §12 事件统计重置与存取

定义 可变 全局_事件分发总数 = 0
定义 可变 全局_事件冒泡总数 = 0
定义 可变 全局_事件阻止总数 = 0
定义 可变 全局_事件延迟总数 = 0

函数 事件_记录分发() { 全局_事件分发总数 = 全局_事件分发总数 + 1 }
函数 事件_记录冒泡() { 全局_事件冒泡总数 = 全局_事件冒泡总数 + 1 }
函数 事件_记录阻止() { 全局_事件阻止总数 = 全局_事件阻止总数 + 1 }
函数 事件_记录延迟() { 全局_事件延迟总数 = 全局_事件延迟总数 + 1 }

函数 事件_获取分发总数() { 返回 全局_事件分发总数 }
函数 事件_获取EWMA处理时间() { 返回 EWMA_事件处理时间 }

函数 事件_重置统计() {
    全局_事件分发总数 = 0
    全局_事件冒泡总数 = 0
    全局_事件阻止总数 = 0
    全局_事件延迟总数 = 0
    EWMA_事件处理时间 = 0
}

函数 事件_打印统计() {
    打印行("=== on-事件属性处理统计 ===")
    打印行("分发总数: " + 整数转字符串(全局_事件分发总数))
    打印行("冒泡总数: " + 整数转字符串(全局_事件冒泡总数))
    打印行("阻止总数: " + 整数转字符串(全局_事件阻止总数))
    打印行("延迟总数: " + 整数转字符串(全局_事件延迟总数))
    打印行("EWMA处理: " + 整数转字符串(EWMA_事件处理时间) + " us")
}

// ◆ EDPS 理论 — Event Dispatch Priority Scheduling
//   公理1: 事件优先级由AI注意力权重与DOM深度联合决定
//   公理2: EWMA平滑可抑制处理时间抖动
//   公理3: 触摸/焦点/滚轮事件遵循W3C冒泡规范
//   定理: 自适应延迟策略使高频低优事件不阻塞关键路径
//         P(delay|type,ewma) → min(主线程阻塞时间)

// NovaOS · 临时文件管理
// §1 临时文件创建 (唯一名生成, 自动目录)
// §2 生命周期管理 (进程退出自动清理, 超时清理)
// §3 配额控制 (/tmp总大小限制)
// §4 安全 (权限隔离, 不可符号链接攻击)


定义 TMP_根目录 = "/tmp"
定义 TMP_最大文件数 = 4096
定义 TMP_最大总字节 = 268435456    // 256MB
定义 TMP_超时秒 = 86400            // 24小时

结构 临时文件记录 {
    路径,
    创建者PID,
    创建时间,
    大小,
    已清理,
}

定义 可变 _临时文件表 = []
定义 可变 _临时总字节 = 0
定义 可变 _临时序号 = 0
定义 可变 _清理次数 = 0


函数 临时_创建(前缀, PID) {
    如果 (计数(_临时文件表) >= TMP_最大文件数) {
        临时_清理超时(读取毫秒() / 1000)
        如果 (计数(_临时文件表) >= TMP_最大文件数) {
            返回 空
        }
    }

    CSPRNG_确保初始化()
    _临时序号 = _临时序号 + 1
    定义 随机 = CSPRNG_生成()
    如果 (随机 < 0) { 随机 = 0 - 随机 }
    定义 文件名 = 前缀 + "_" + 整数转字符串(PID) + "_" + 整数转字符串(_临时序号) + "_" + 整数转字符串(随机 % 100000)
    定义 路径 = TMP_根目录 + "/" + 文件名

    定义 记录 = 临时文件记录 {}
    记录.路径 = 路径
    记录.创建者PID = PID
    记录.创建时间 = 读取毫秒() / 1000
    记录.大小 = 0
    记录.已清理 = 假
    追加(_临时文件表, 记录)

    返回 路径
}

函数 临时_创建目录(前缀, PID) {
    CSPRNG_确保初始化()
    _临时序号 = _临时序号 + 1
    定义 随机 = CSPRNG_生成()
    如果 (随机 < 0) { 随机 = 0 - 随机 }
    定义 目录名 = 前缀 + "_d_" + 整数转字符串(PID) + "_" + 整数转字符串(随机 % 100000)
    定义 路径 = TMP_根目录 + "/" + 目录名

    目录_创建(路径)

    定义 记录 = 临时文件记录 {}
    记录.路径 = 路径
    记录.创建者PID = PID
    记录.创建时间 = 读取毫秒() / 1000
    记录.大小 = 0
    记录.已清理 = 假
    追加(_临时文件表, 记录)

    返回 路径
}


函数 临时_删除(路径) {
    定义 可变 i = 0
    当 (i < 计数(_临时文件表)) {
        如果 (_临时文件表[i].路径 == 路径 && !_临时文件表[i].已清理) {
            文件_删除(路径)
            _临时总字节 = _临时总字节 - _临时文件表[i].大小
            _临时文件表[i].已清理 = 真
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 临时_清理PID(PID) {
    // 进程退出时调用: 清理该进程创建的所有临时文件
    定义 可变 已清理 = 0
    定义 可变 i = 0
    当 (i < 计数(_临时文件表)) {
        如果 (_临时文件表[i].创建者PID == PID && !_临时文件表[i].已清理) {
            文件_删除(_临时文件表[i].路径)
            _临时总字节 = _临时总字节 - _临时文件表[i].大小
            _临时文件表[i].已清理 = 真
            已清理 = 已清理 + 1
        }
        i = i + 1
    }
    如果 (已清理 > 0) { _清理次数 = _清理次数 + 1 }
    返回 已清理
}

函数 临时_清理超时(当前时间) {
    定义 可变 已清理 = 0
    定义 可变 i = 0
    当 (i < 计数(_临时文件表)) {
        如果 (!_临时文件表[i].已清理 && 当前时间 - _临时文件表[i].创建时间 > TMP_超时秒) {
            文件_删除(_临时文件表[i].路径)
            _临时总字节 = _临时总字节 - _临时文件表[i].大小
            _临时文件表[i].已清理 = 真
            已清理 = 已清理 + 1
        }
        i = i + 1
    }
    如果 (已清理 > 0) { _清理次数 = _清理次数 + 1 }
    返回 已清理
}

函数 临时_清理全部() {
    定义 可变 i = 0
    当 (i < 计数(_临时文件表)) {
        如果 (!_临时文件表[i].已清理) {
            文件_删除(_临时文件表[i].路径)
            _临时文件表[i].已清理 = 真
        }
        i = i + 1
    }
    _临时总字节 = 0
    _清理次数 = _清理次数 + 1
}


函数 临时_配额可用() {
    返回 _临时总字节 < TMP_最大总字节
}

函数 临时_登记大小(路径, 大小) {
    定义 可变 i = 0
    当 (i < 计数(_临时文件表)) {
        如果 (_临时文件表[i].路径 == 路径) {
            _临时总字节 = _临时总字节 - _临时文件表[i].大小 + 大小
            _临时文件表[i].大小 = 大小
            返回
        }
        i = i + 1
    }
}

函数 临时_活跃数() {
    定义 可变 n = 0
    定义 可变 i = 0
    当 (i < 计数(_临时文件表)) {
        如果 (!_临时文件表[i].已清理) { n = n + 1 }
        i = i + 1
    }
    返回 n
}

函数 临时_报告() {
    定义 可变 r = "═══ 临时文件管理 ═══\n"
    r = r + "活跃: " + 整数转字符串(临时_活跃数()) + " / " + 整数转字符串(TMP_最大文件数) + "\n"
    r = r + "占用: " + 整数转字符串(_临时总字节 / 1024) + "KB / " + 整数转字符串(TMP_最大总字节 / 1048576) + "MB\n"
    r = r + "清理次数: " + 整数转字符串(_清理次数) + "\n"
    返回 r
}

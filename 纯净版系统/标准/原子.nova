导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")

定义 内存序_松散 = 0
定义 内存序_获取 = 1
定义 内存序_释放 = 2
定义 内存序_获取释放 = 3
定义 内存序_顺序一致 = 4

函数 原子整数_创建(值) { 返回 [值] }
函数 原子整数_读(a) { 返回 a[0] }
函数 原子整数_写(a, v) { 设置(a, 0, v) }
函数 原子整数_加(a, v) { 设置(a, 0, a[0] + v); 返回 a[0] }
函数 原子整数_减(a, v) { 设置(a, 0, a[0] - v); 返回 a[0] }
函数 原子整数_自增(a) { 返回 原子整数_加(a, 1) }
函数 原子整数_自减(a) { 返回 原子整数_减(a, 1) }

函数 原子整数_CAS(a, 期望值, 新值) {
    如果 (a[0] == 期望值) {
        设置(a, 0, 新值)
        返回 真
    }
    返回 假
}

函数 原子整数_交换(a, 新值) {
    定义 旧 = a[0]
    设置(a, 0, 新值)
    返回 旧
}

函数 原子整数_取加(a, v) {
    定义 旧 = a[0]
    设置(a, 0, a[0] + v)
    返回 旧
}

函数 原子整数_取减(a, v) {
    定义 旧 = a[0]
    设置(a, 0, a[0] - v)
    返回 旧
}

函数 原子整数_取与(a, v) {
    定义 旧 = a[0]
    设置(a, 0, a[0] & v)
    返回 旧
}

函数 原子整数_取或(a, v) {
    定义 旧 = a[0]
    设置(a, 0, a[0] | v)
    返回 旧
}

函数 原子整数_取异或(a, v) {
    定义 旧 = a[0]
    设置(a, 0, a[0] ^ v)
    返回 旧
}

函数 原子整数_最大(a, v) {
    如果 (a[0] < v) { 设置(a, 0, v) }
    返回 a[0]
}

函数 原子整数_最小(a, v) {
    如果 (a[0] > v) { 设置(a, 0, v) }
    返回 a[0]
}

函数 原子布尔_创建(值) { 返回 [值] }
函数 原子布尔_读(a) { 返回 a[0] }
函数 原子布尔_写(a, v) { 设置(a, 0, v) }
函数 原子布尔_取反(a) {
    定义 旧 = a[0]
    设置(a, 0, !旧)
    返回 旧
}
函数 原子布尔_CAS(a, 期望, 新值) {
    如果 (a[0] == 期望) {
        设置(a, 0, 新值)
        返回 真
    }
    返回 假
}

函数 原子指针_创建(指针) { 返回 [指针] }
函数 原子指针_读(a) { 返回 a[0] }
函数 原子指针_写(a, 指针) { 设置(a, 0, 指针) }
函数 原子指针_CAS(a, 期望, 新指针) {
    如果 (a[0] == 期望) {
        设置(a, 0, 新指针)
        返回 真
    }
    返回 假
}
函数 原子指针_交换(a, 新指针) {
    定义 旧 = a[0]
    设置(a, 0, 新指针)
    返回 旧
}
函数 原子指针_是空(a) { 返回 a[0] == 0 || a[0] == 空 }

函数 原子标志_创建() { 返回 [假] }
函数 原子标志_测试并设置(f) {
    定义 旧 = f[0]
    设置(f, 0, 真)
    返回 旧
}
函数 原子标志_清除(f) { 设置(f, 0, 假) }

函数 自旋等待_CAS(a, 期望值, 新值) {
    定义 可变 重试 = 0
    定义 可变 最大重试 = 1000
    当 (重试 < 最大重试) {
        如果 (原子整数_CAS(a, 期望值, 新值)) { 返回 真 }
        自旋等待_暂停(重试)
        重试 = 重试 + 1
    }
    返回 假
}

函数 自旋等待_暂停(重试次数) {
    如果 (重试次数 < 4) { 返回 }
    如果 (重试次数 < 16) {
        定义 可变 k = 0
        当 (k < 重试次数) { k = k + 1 }
        返回
    }
}

结构 原子计数器 {
    值,
    最大值,
    最小值,
}

函数 原子计数器_创建(初始, 最小, 最大) {
    返回 原子计数器 { 值: 原子整数_创建(初始), 最大值: 最大, 最小值: 最小 }
}

函数 原子计数器_增(c) {
    定义 当前 = 原子整数_读(c.值)
    如果 (当前 >= c.最大值) { 返回 假 }
    原子整数_自增(c.值)
    返回 真
}

函数 原子计数器_减(c) {
    定义 当前 = 原子整数_读(c.值)
    如果 (当前 <= c.最小值) { 返回 假 }
    原子整数_自减(c.值)
    返回 真
}

函数 原子计数器_读(c) { 返回 原子整数_读(c.值) }
函数 原子计数器_重置(c) { 原子整数_写(c.值, c.最小值) }

结构 一次标志 {
    状态,
}

定义 一次_未执行 = 0
定义 一次_执行中 = 1
定义 一次_已完成 = 2

函数 一次标志_创建() {
    返回 一次标志 { 状态: 原子整数_创建(一次_未执行) }
}

函数 一次_执行(标志, 函数) {
    如果 (原子整数_读(标志.状态) == 一次_已完成) { 返回 }
    如果 (原子整数_CAS(标志.状态, 一次_未执行, 一次_执行中)) {
        函数()
        原子整数_写(标志.状态, 一次_已完成)
    }
}

结构 原子屏障 {
    计数,
    目标数,
    轮次,
}

函数 原子屏障_创建(参与者数) {
    返回 原子屏障 {
        计数: 原子整数_创建(0),
        目标数: 参与者数,
        轮次: 原子整数_创建(0)
    }
}

函数 原子屏障_等待(屏障) {
    定义 当前轮 = 原子整数_读(屏障.轮次)
    定义 到达数 = 原子整数_自增(屏障.计数)
    如果 (到达数 == 屏障.目标数) {
        原子整数_写(屏障.计数, 0)
        原子整数_自增(屏障.轮次)
    } 否则 {
        定义 可变 等待 = 0
        当 (原子整数_读(屏障.轮次) == 当前轮 && 等待 < 100000) {
            等待 = 等待 + 1
        }
    }
}

定义 可变 AI_原子_调用数 = 0
定义 可变 AI_原子_异常数 = 0

函数 AI_原子_监控() {
    AI_原子_调用数 = AI_原子_调用数 + 1
    返回 AI_原子_异常数 == 0
}

函数 AI_原子_健康检查() {
    如果 (AI_原子_调用数 > 0 && AI_原子_异常数 * 100 / AI_原子_调用数 > 10) {
        返回 假
    }
    返回 真
}

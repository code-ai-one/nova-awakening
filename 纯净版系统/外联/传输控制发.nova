// NovaOS 传控数据传输
// 功能: 传控数据发送、接收、分段、重组、滑动窗口、Nagle

定义 传控_默认MSS          = 1460
定义 传控_最小MSS          = 536
定义 传控_默认窗口大小     = 65535
定义 传控_默认窗口缩放     = 7
定义 传控_头部大小          = 20
定义 传控_选项最大大小      = 40
定义 传控_初始RTO           = 1000
定义 传控_最小RTO           = 200
定义 传控_最大RTO           = 120000
定义 传控_NAGLE_阈值        = 0

定义 传控_标志_FIN  = 0x01
定义 传控_标志_SYN  = 0x02
定义 传控_标志_RST  = 0x04
定义 传控_标志_PSH  = 0x08
定义 传控_标志_ACK  = 0x10
定义 传控_标志_URG  = 0x20

定义 传控_偏移_源端口   = 0
定义 传控_偏移_目标端口 = 2
定义 传控_偏移_序号     = 4
定义 传控_偏移_确认号   = 8
定义 传控_偏移_数据偏移 = 12
定义 传控_偏移_标志     = 13
定义 传控_偏移_窗口     = 14
定义 传控_偏移_校验和   = 16
定义 传控_偏移_紧急指针 = 18

// 传控数据发送(用户空间 → 网络)

函数 tcp_发送数据(tcb, 数据, 长度) {
    如果 (tcb.状态 != 传控_状态_已建立 && tcb.状态 != 传控_状态_CLOSE_WAIT) {
        返回 错误码_未连接
    }

    定义 可变 已发送 = 0
    当 (已发送 < 长度) {
        // 计算可发送量: min(MSS, 发送窗口剩余, 拥塞窗口剩余)
        定义 飞行中 = tcb.发送下一个 - tcb.发送未确认
        定义 窗口剩余 = tcb.发送窗口 - 飞行中
        定义 拥塞剩余 = tcb.拥塞窗口 - 飞行中
        定义 可发送 = 取小(窗口剩余, 拥塞剩余)

        如果 (可发送 <= 0) {
            // 窗口满，等待ACK
            跳出
        }

        定义 段大小 = 取小(tcb.mss, 长度 - 已发送)
        段大小 = 取小(段大小, 可发送)

        // Nagle算法: 小包合并
        如果 (段大小 < tcb.mss && 飞行中 > 0 && !tcb.禁用nagle) {
            // 有未确认数据且本次不满MSS，延迟发送
            tcp_缓冲数据(tcb, 数据 + 已发送, 段大小)
            已发送 = 已发送 + 段大小
            继续
        }

        // 构建传控数据段
        定义 可变 Nova缓冲 = tcp_构建数据段(tcb, 数据 + 已发送, 段大小)
        如果 (Nova缓冲 == 空) {
            跳出
        }

        // 加入重传队列
        Nova网络缓冲_队列_入队(tcb.重传队列, Nova网络缓冲_克隆(Nova缓冲))

        // Nova往返时间采样
        如果 (tcb.Nova往返时间采样时间 == 0) {
            tcb.Nova往返时间采样时间 = 当前时间_秒()
            tcb.Nova往返时间采样序号 = tcb.发送下一个
        }

        // 更新发送序号
        tcb.发送下一个 = tcb.发送下一个 + 段大小

        // 发送
        tcp_发送段(tcb, Nova缓冲)

        // 启动重传定时器
        如果 (!tcb.重传定时器运行) {
            tcp_启动重传定时器(tcb)
        }

        已发送 = 已发送 + 段大小
    }

    返回 已发送
}

函数 tcp_构建数据段(tcb, 数据, 长度) {
    定义 可变 Nova缓冲 = Nova缓冲_分配(传控_头部大小 + 长度)
    如果 (Nova缓冲 == 空) { 返回 空 }

    定义 头 = Nova缓冲.数据
    tcp_设置源端口(头, tcb.四元组.源端口)
    tcp_设置目标端口(头, tcb.四元组.目标端口)
    tcp_设置序号(头, tcb.发送下一个)
    tcp_设置确认号(头, tcb.接收序号)
    tcp_设置标志(头, 传控_标志_ACK | 传控_标志_PSH)
    tcp_设置窗口(头, tcb.接收窗口)
    tcp_设置数据偏移(头, 传控_头部大小 / 4)

    // 复制数据
    内存复制(头 + 传控_头部大小, 数据, 长度)
    Nova缓冲.数据长度 = 传控_头部大小 + 长度

    返回 Nova缓冲
}

函数 tcp_缓冲数据(tcb, 数据, 长度) {
    // 将小块数据加入发送缓冲，等待合并
    定义 可变 Nova缓冲 = Nova缓冲_分配(长度)
    内存复制(Nova缓冲.数据, 数据, 长度)
    Nova网络缓冲_队列_入队(tcb.发送缓冲, Nova缓冲)
}

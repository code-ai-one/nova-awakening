// Nova 原生表达式系统 — 运算符优先级/结合性/常量折叠/运算符分类
// 职责: 优先级表 + 常量折叠 + 运算符反转/交换 + 复杂度估算
// 层级: 第1层基础设施 (无依赖)

// 简化标记常量引用
定义 标_余=34
定义 标_模=34  定义 标_与=50

// 运算符优先级表
函数 二元优先级(op) {
    如果 (op == 标记_或) { 返回 1 }   // ||
    如果 (op == 标记_且) { 返回 2 }   // &&
    如果 (op == 标记_位或) { 返回 3 }   // |
    如果 (op == 标记_位异或) { 返回 4 }   // ^
    如果 (op == 标记_位与) { 返回 5 }   // &
    如果 (op == 标_等于) { 返回 6 }
    如果 (op == 标_不等) { 返回 6 }
    如果 (op == 标_小于) { 返回 7 }
    如果 (op == 标_大于) { 返回 7 }
    如果 (op == 标_小等) { 返回 7 }
    如果 (op == 标_大等) { 返回 7 }
    如果 (op == 标记_左移) { 返回 8 }   // <<
    如果 (op == 标记_右移) { 返回 8 }   // >>
    如果 (op == 标_加) { 返回 9 }
    如果 (op == 标_减) { 返回 9 }
    如果 (op == 标_乘) { 返回 10 }
    如果 (op == 标_除) { 返回 10 }
    如果 (op == 标_余) { 返回 10 }
    返回 0
}

// 一元优先级
函数 一元优先级(op) {
    如果 (op == 标_减) { 返回 11 }
    如果 (op == 标_非) { 返回 11 }
    如果 (op == 标_位非) { 返回 11 }
    返回 0
}

// 结合性: 0=左结合, 1=右结合
函数 是右结合(op) {
    返回 op >= 标记_赋值 且 op <= 80
}

// 优先级比较
函数 优先级更高(a, b) {
    定义 pa = 二元优先级(a)
    定义 pb = 二元优先级(b)
    如果 (pa > pb) { 返回 1 }
    返回 0
}

函数 同优先级(a, b) {
    返回 二元优先级(a) == 二元优先级(b)
}

// 运算符反转 (用于优化)
函数 反转比较(op) {
    如果 (op == 标_等于) { 返回 标_不等 }
    如果 (op == 标_不等) { 返回 标_等于 }
    如果 (op == 标_小于) { 返回 标_大等 }
    如果 (op == 标_大于) { 返回 标_小等 }
    如果 (op == 标_小等) { 返回 标_大于 }
    如果 (op == 标_大等) { 返回 标_小于 }
    返回 op
}

// 运算符交换 (交换操作数时)
函数 交换比较(op) {
    如果 (op == 标_小于) { 返回 标_大于 }
    如果 (op == 标_大于) { 返回 标_小于 }
    如果 (op == 标_小等) { 返回 标_大等 }
    如果 (op == 标_大等) { 返回 标_小等 }
    返回 op
}

// 是否可交换
函数 可交换(op) {
    如果 (op == 标_加) { 返回 1 }
    如果 (op == 标_乘) { 返回 1 }
    如果 (op == 标_等于) { 返回 1 }
    如果 (op == 标_不等) { 返回 1 }
    如果 (op == 标记_位与) { 返回 1 }  // &
    如果 (op == 标记_位或) { 返回 1 }  // |
    如果 (op == 标记_位异或) { 返回 1 }  // ^
    返回 0
}

// 最大优先级
定义 最大优先级 = 12

// 表达式类型判断

函数 是算术运算(op) {
    返回 op == 标_加 或 op == 标_减 或 op == 标_乘 或 op == 标_除 或 op == 标_模
}

函数 是比较运算(op) {
    返回 op == 标_等于 或 op == 标_不等 或 op == 标_小于 或 op == 标_大于 或 op == 标_小等 或 op == 标_大等
}

函数 是逻辑运算(op) {
    返回 op == 标_与 或 op == 标_或
}

函数 是位运算(op) {
    返回 op == 标记_位与 或 op == 标记_位或 或 op == 标记_位异或  // &, |, ^
}

函数 运算符_类别(op) {
    如果 (是算术运算(op)) { 返回 "算术" }
    如果 (是比较运算(op)) { 返回 "比较" }
    如果 (是逻辑运算(op)) { 返回 "逻辑" }
    如果 (是位运算(op)) { 返回 "位运算" }
    返回 "其他"
}

// 常量折叠

函数 常量折叠_二元(op, 左值, 右值) {
    如果 (op == 标_加) { 返回 左值 + 右值 }
    如果 (op == 标_减) { 返回 左值 - 右值 }
    如果 (op == 标_乘) { 返回 左值 * 右值 }
    如果 (op == 标_除) {
        如果 (右值 == 0) { 返回 空 }
        返回 左值 / 右值
    }
    如果 (op == 标_模) {
        如果 (右值 == 0) { 返回 空 }
        返回 左值 % 右值
    }
    如果 (op == 标_等于) { 返回 左值 == 右值 }
    如果 (op == 标_不等) { 返回 左值 != 右值 }
    如果 (op == 标_小于) { 返回 左值 < 右值 }
    如果 (op == 标_大于) { 返回 左值 > 右值 }
    如果 (op == 标_小等) { 返回 左值 <= 右值 }
    如果 (op == 标_大等) { 返回 左值 >= 右值 }
    返回 空
}

函数 常量折叠_一元(op, 值) {
    如果 (op == 标_减) { 返回 0 - 值 }
    如果 (op == 标_非) { 返回 !值 }
    返回 空
}

// 表达式复杂度

函数 表达式_深度估算(节点数) {
    如果 (节点数 <= 3) { 返回 1 }
    如果 (节点数 <= 10) { 返回 2 }
    如果 (节点数 <= 30) { 返回 3 }
    返回 4
}

函数 表达式_过于复杂(节点数) {
    返回 节点数 > 50
}

定义 可变 _表达式_解析数 = 0
定义 可变 _表达式_折叠数 = 0

函数 表达式_记录解析() { _表达式_解析数 = _表达式_解析数 + 1 }
函数 表达式_记录折叠() { _表达式_折叠数 = _表达式_折叠数 + 1 }

// 直接测试函数参数浮点列表推断
函数 multiply_add(A, B) {
    // A 和 B 应被推断为浮点列表 (因为与浮点常量 0.0 相加)
    定义 可变 s = 0.0
    s = s + A[0] * B[0]
    返回 s
}

函数 主程序() {
    定义 a = [1.5, 2.5]
    定义 b = [4.0, 6.0]
    定义 r = multiply_add(a, b)
    // 预期 1.5 * 4.0 = 6.0 = 0x4018000000000000 = 4618441417868443648
    打印(字符串拼接("r bits=", 转字符串(r)))
    // 如果浮点路径生效: bits = 4618441417868443648
    // 如果整数路径: bits = 4609434218613702656 * 4616189618054758400 (整数乘溢出)
    返回 0
}

导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/自动扩容.nova")
导入("./云端桥接.nova")
导入("../标准/原生列表.nova")
导入("../中枢/墙钟设置.nova")

定义 后援_置信度阈值 = 30
定义 后援_缓存TTL_秒 = 3600
定义 后援_最大缓存 = 2048
定义 后援_最大训练样本 = 1000
定义 后援_最大批量 = 8
定义 后援_断路器_阈值 = 5
定义 后援_断路器_恢复秒 = 60

定义 后援优先级_低 = 0
定义 后援优先级_中 = 1
定义 后援优先级_高 = 2
定义 后援优先级_紧急 = 3

结构 缓存条目 {
    回复,
    时间戳,
    命中次数,
}

结构 后援提供者 {
    名称,
    桥接,
    优先级,
    权重,
    失败次数,
    成功次数,
    可用,
}

定义 可变 后援_总请求 = 0
定义 可变 后援_总成功 = 0
定义 可变 后援_总缓存命中 = 0
定义 可变 后援_总超时 = 0
定义 可变 后援_缓存 = 字典()
定义 可变 后援_训练样本 = []
定义 可变 后援_提供者列表 = []
定义 可变 后援_断路器_失败计数 = 0
定义 可变 后援_断路器_打开 = 假
定义 可变 后援_断路器_打开时间 = 0
定义 可变 后援_请求批量 = []

函数 推理后援_是否需要(本地结果, 置信度) {
    返回 置信度 < 后援_置信度阈值
}

函数 后援_注册提供者(名称, 桥接, 优先级, 权重) {
    定义 提供者 = 后援提供者 {
        名称: 名称,
        桥接: 桥接,
        优先级: 优先级,
        权重: 权重,
        失败次数: 0,
        成功次数: 0,
        可用: 真
    }
    追加(后援_提供者列表, 提供者)
}

函数 后援_选择提供者() {
    如果 (计数(后援_提供者列表) == 0) {
        定义 默认桥接 = 云端_获取桥接()
        如果 (默认桥接 == 空) { 返回 空 }
        返回 默认桥接
    }
    定义 可变 最佳 = 空
    定义 可变 最高优先 = -1
    定义 可变 i = 0
    当 (i < 计数(后援_提供者列表)) {
        定义 提供者 = 后援_提供者列表[i]
        如果 (提供者.可用 && 提供者.优先级 > 最高优先) {
            最高优先 = 提供者.优先级
            最佳 = 提供者
        }
        i = i + 1
    }
    如果 (最佳 != 空) { 返回 最佳.桥接 }
    返回 空
}

函数 后援_检查断路器() {
    如果 (!后援_断路器_打开) { 返回 真 }
    定义 现在 = 当前时间_秒()
    如果 (现在 - 后援_断路器_打开时间 > 后援_断路器_恢复秒) {
        后援_断路器_打开 = 假
        后援_断路器_失败计数 = 0
        返回 真
    }
    返回 假
}

函数 后援_记录失败() {
    后援_断路器_失败计数 = 后援_断路器_失败计数 + 1
    如果 (后援_断路器_失败计数 >= 后援_断路器_阈值) {
        后援_断路器_打开 = 真
        后援_断路器_打开时间 = 当前时间_秒()
    }
}

函数 后援_记录成功() {
    后援_断路器_失败计数 = 0
    如果 (后援_断路器_打开) {
        后援_断路器_打开 = 假
    }
}

函数 后援_检查缓存(输入) {
    定义 条目 = 字典取(后援_缓存, 输入)
    如果 (条目 == 空) { 返回 空 }
    定义 现在 = 当前时间_秒()
    如果 (现在 - 条目.时间戳 > 后援_缓存TTL_秒) {
        字典删(后援_缓存, 输入)
        返回 空
    }
    条目.命中次数 = 条目.命中次数 + 1
    后援_总缓存命中 = 后援_总缓存命中 + 1
    返回 条目.回复
}

函数 后援_写入缓存(输入, 回复) {
    如果 (计数(后援_缓存) >= 后援_最大缓存) {
        后援_清理缓存()
    }
    定义 条目 = 缓存条目 {
        回复: 回复,
        时间戳: 当前时间_秒(),
        命中次数: 0
    }
    字典设(后援_缓存, 输入, 条目)
}

函数 后援_清理缓存() {
    // 简化: 清空一半缓存
    后援_缓存 = 字典()
}

函数 推理后援_请求(输入, 超时) {
    后援_总请求 = 后援_总请求 + 1

    如果 (!后援_检查断路器()) {
        返回 空
    }

    定义 缓存结果 = 后援_检查缓存(输入)
    如果 (缓存结果 != 空) {
        后援_总成功 = 后援_总成功 + 1
        返回 缓存结果
    }

    定义 桥接 = 后援_选择提供者()
    如果 (桥接 == 空) { 返回 空 }

    定义 回复 = 云端桥接_推理后援(桥接, 输入, "")
    如果 (回复 == 空) {
        后援_记录失败()
        后援_总超时 = 后援_总超时 + 1
        返回 空
    }

    后援_记录成功()
    后援_写入缓存(输入, 回复)
    后援_总成功 = 后援_总成功 + 1

    后援_收集样本(输入, 回复)
    返回 回复
}

函数 推理后援_带优先级请求(输入, 超时, 优先级) {
    如果 (优先级 == 后援优先级_紧急) {
        // 紧急请求绕过断路器
        定义 桥接 = 后援_选择提供者()
        如果 (桥接 == 空) { 返回 空 }
        返回 云端桥接_推理后援(桥接, 输入, "")
    }
    返回 推理后援_请求(输入, 超时)
}

函数 后援_加入批量(输入) {
    如果 (计数(后援_请求批量) >= 后援_最大批量) { 返回 假 }
    追加(后援_请求批量, 输入)
    返回 真
}

函数 后援_执行批量() {
    如果 (计数(后援_请求批量) == 0) { 返回 [] }
    定义 可变 结果列表 = []
    定义 可变 i = 0
    当 (i < 计数(后援_请求批量)) {
        定义 回复 = 推理后援_请求(后援_请求批量[i], 30000)
        追加(结果列表, 回复)
        i = i + 1
    }
    后援_请求批量 = []
    返回 结果列表
}

函数 后援_收集样本(输入, 回复) {
    追加(后援_训练样本, [输入, 回复])
    如果 (计数(后援_训练样本) > 后援_最大训练样本) {
        后援_训练样本 = 列表_切片(后援_训练样本, 后援_最大训练样本 / 2, 计数(后援_训练样本))
    }
}

函数 后援_获取训练样本() {
    定义 样本 = 后援_训练样本
    后援_训练样本 = []
    返回 样本
}

函数 后援_统计() {
    返回 [后援_总请求, 后援_总成功, 后援_总缓存命中, 后援_总超时, 计数(后援_缓存), 计数(后援_训练样本), 计数(后援_提供者列表)]
}

函数 后援_设阈值(新阈值) { 后援_置信度阈值 = 新阈值 }
函数 后援_断路器状态() { 返回 后援_断路器_打开 }

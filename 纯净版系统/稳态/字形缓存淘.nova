// §5 字形缓存 — LRU

定义 缓存容量 = 256
定义 可变 字形缓存 = []      // [{字形ID, 像素大小, 字形数据, 访问时间}]

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 TTF_缓存查找(字形ID, 像素大小) {
    定义 可变 i = 0
    当 (i < 计数(字形缓存)) {
        定义 条目 = 字形缓存[i]
        如果 (条目[0] == 字形ID && 条目[1] == 像素大小) {
            字形缓存[i][3] = 字形缓存[i][3] + 1  // 更新访问计数
            返回 条目[2]
        }
        i = i + 1
    }
    返回 空
}

函数 TTF_缓存插入(字形ID, 像素大小, 字形) {
    // 满了就淘汰最少使用的
    如果 (计数(字形缓存) >= 缓存容量) {
        定义 可变 最小访问 = 999999999
        定义 可变 淘汰索引 = 0
        定义 可变 i = 0
        当 (i < 计数(字形缓存)) {
            如果 (字形缓存[i][3] < 最小访问) {
                最小访问 = 字形缓存[i][3]
                淘汰索引 = i
            }
            i = i + 1
        }
        字形缓存[淘汰索引] = [字形ID, 像素大小, 字形, 1]
    } 否则 {
        追加(字形缓存, [字形ID, 像素大小, 字形, 1])
    }
}

// §6 文本渲染 — 字符串 → 帧缓冲

外部 屏幕宽
外部 屏幕位深

函数 TTF_渲染字符(fb, x, y, 字符码, 颜色, 像素大小) {
    如果 (!全局TTF.已加载) { 返回 0 }

    定义 字形ID = TTF_查找字形ID(字符码)

    // 查缓存
    定义 可变 字形 = TTF_缓存查找(字形ID, 像素大小)
    如果 (字形 == 空) {
        // 光栅化并缓存
        字形 = TTF_光栅化(字形ID, 像素大小)
        TTF_缓存插入(字形ID, 像素大小, 字形)
    }

    如果 (字形.位图 == 空 || 计数(字形.位图) == 0) {
        // 空白字形(空格等), 只返回前进宽
        返回 字形.前进宽 * 像素大小 / 全局TTF.单位_每EM
    }

    // 将灰度位图渲染到帧缓冲(Alpha混合)
    定义 前R = (颜色 >> 16) & 0xFF
    定义 前G = (颜色 >> 8) & 0xFF
    定义 前B = 颜色 & 0xFF
    定义 bpp = 屏幕位深 / 8
    如果 (bpp < 3) { bpp = 4 }

    定义 可变 行 = 0
    当 (行 < 字形.位图高) {
        定义 可变 列 = 0
        当 (列 < 字形.位图宽) {
            定义 alpha = 字形.位图[行 * 字形.位图宽 + 列]
            如果 (alpha > 0) {
                定义 px = x + 列
                定义 py = y + 行
                定义 像素偏移 = (py * 屏幕宽 + px) * bpp
                如果 (alpha >= 250) {
                    // 完全不透明: 直接写
                    内存写8(fb + 像素偏移,     前B)
                    内存写8(fb + 像素偏移 + 1, 前G)
                    内存写8(fb + 像素偏移 + 2, 前R)
                    内存写8(fb + 像素偏移 + 3, 0xFF)
                } 否则 {
                    // 亚像素混合
                    定义 背B = 内存读8(fb + 像素偏移)
                    定义 背G = 内存读8(fb + 像素偏移 + 1)
                    定义 背R = 内存读8(fb + 像素偏移 + 2)
                    内存写8(fb + 像素偏移,     (前B * alpha + 背B * (255 - alpha)) / 255)
                    内存写8(fb + 像素偏移 + 1, (前G * alpha + 背G * (255 - alpha)) / 255)
                    内存写8(fb + 像素偏移 + 2, (前R * alpha + 背R * (255 - alpha)) / 255)
                    内存写8(fb + 像素偏移 + 3, 0xFF)
                }
            }
            列 = 列 + 1
        }
        行 = 行 + 1
    }

    // 返回字符前进宽(像素)
    返回 字形.前进宽 * 像素大小 / 全局TTF.单位_每EM
}

函数 TTF_渲染文本(fb, x, y, 文本, 颜色, 像素大小) {
    如果 (!全局TTF.已加载) { 返回 }
    定义 可变 cx = x
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 ch = 字符串取字节(文本, i)
        如果 (ch == 10) {  // 换行
            cx = x
            y = y + 像素大小 * 12 / 10  // 1.2倍行距
        } 否则 {
            定义 前进 = TTF_渲染字符(fb, cx, y, ch, 颜色, 像素大小)
            cx = cx + 前进
        }
        i = i + 1
    }
}

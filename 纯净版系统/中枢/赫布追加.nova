// NovaOS 赫布学习引擎 — Nova Hebbian Learning Theory (NHLT)
// 原创理论: Nova赫布学习统一理论 (NHLT)
//   定理1 (收敛性): 全Walsh支撑 ∧ 学习率单调递减 → 必然收敛
//   定理2 (双向平衡): Hebb(LTP) + Anti-Hebb(LTD) → 稳定平衡态
//   定理3 (竞争消除): WTA + 侧向抑制 → 正交特征分离
//   定理4 (BCM收敛): 滑动阈值θ=E[y²] → LTP/LTD自动平衡
//   定理5 (Oja主成分): ||w||→1, 收敛于第一主成分方向
// 基于实验室碰撞34-39核心突破:
//   "全Walsh支撑收敛定理" — B位整数Nova关联学习 Walsh学习器
//   若f的所有Walsh系数非零 → 从任意初始状态100%收敛
// 用途: Walsh域模式学习、内容生成、特征发现、联想记忆
// 包含: 符号关联矩阵 / BCM规则 / Oja规则 / 反赫布学习 / 竞争赫布
//        稳态可塑性 / 学习率衰减 / 信噪比估计 / 完整统计

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./内核打印.nova")
导入("./字符串替换.nova")
导入("./整数转字符串.nova")
导入("./数学工具.nova")

定义 可变 赫布_学习率 = 100        // 全局学习率(×1000), 被检查点/自动化引擎引用

// NHLT统计状态
定义 可变 _赫布_更新总次 = 0
定义 可变 _赫布_反赫布总次 = 0
定义 可变 _赫布_竞争总次 = 0

函数 赫布_追加(lst, val) { 插入(lst, 计数(lst), val) }

函数 赫布_符号(x) {
    如果 (x > 0) { 返回 1 }
    如果 (x < 0) { 返回 0 - 1 }
    返回 0
}

函数 赫布_绝对值(x) {
    如果 (x < 0) { 返回 0 - x }
    返回 x
}

// 从多个Walsh频谱中学习系数间的符号共现规则
// 输入: spectra = 多个频谱的列表(展平), n_spec=频谱数, dim=维度
//       indices = 要学习的系数索引列表, k = 索引数量
// 输出: 关联矩阵 corr[i*k+j] = 符号关联强度 (范围约[-1000,1000])
// 核心Nova关联学习规则: corr[i][j] = corr[i][j] + sign(spec[idx_i]) * sign(spec[idx_j])
// 碰撞34-39证明: 这个规则在全支撑条件下100%收敛

函数 赫布_学习符号(频谱列表, 频谱数, 维度, 索引列表, k) {
    打印("Nova关联学习学习: " + 转字符串(频谱数) + "个样本, " + 转字符串(k) + "个系数")

    // 初始化关联矩阵 k*k
    定义 可变 关联 = []
    定义 可变 ci = 0
    当 (ci < k * k) { 赫布_追加(关联, 0)  ci = ci + 1 }

    // 遍历所有频谱, 累积符号关联
    定义 可变 si = 0
    当 (si < 频谱数) {
        定义 偏移 = si * 维度

        // 提取当前频谱的符号
        定义 可变 符号表 = []
        定义 可变 ki = 0
        当 (ki < k) {
            定义 idx = 索引列表[ki]
            定义 val = 频谱列表[偏移 + idx]
            赫布_追加(符号表, 赫布_符号(val))
            ki = ki + 1
        }

        // Nova关联学习更新: corr[i][j] = corr[i][j] + sign_i * sign_j
        定义 可变 i = 0
        当 (i < k) {
            定义 可变 j = 0
            当 (j < k) {
                关联[i * k + j] = 关联[i * k + j] + 符号表[i] * 符号表[j]
                j = j + 1
            }
            i = i + 1
        }

        si = si + 1
    }

    // 归一化到[-1000, 1000]
    如果 (频谱数 > 0) {
        定义 可变 ni = 0
        当 (ni < k * k) {
            关联[ni] = 关联[ni] * 1000 / 频谱数
            ni = ni + 1
        }
    }

    返回 关联
}

// 用已决定的k-1个符号, 通过Nova关联学习权重预测第k个
// 实验室碰撞34-39证明: 净变化 = N * ĉ_S, 非零必收敛

函数 赫布_预测符号(关联, 已决定, k, n_k) {
    定义 可变 得分 = 0
    定义 可变 j = 0
    当 (j < k) {
        得分 = 得分 + 关联[k * n_k + j] * 已决定[j] / 1000
        j = j + 1
    }
    如果 (得分 > 0) { 返回 1 }
    返回 0 - 1
}

// BCM规则 (Bienenstock-Cooper-Munro)
// 原创定点BCM公式: Δw = η × x × y × (y - θ_m)
// 滑动阈值: θ_m = E[y²] — 低于均值时产生LTD, 高于时产生LTP
// NovaOS原创: FP1000定点BCM避免浮点, 纯整数实现稳定收敛

定义 可变 BCM_滑动阈值 = 500  // ×1000

函数 赫布_BCM更新(权重, 输入, 输出, 维度, 学习率) {
    // Δw_i = η × x_i × y × (y - θ_m) / 1000000
    定义 调制 = 输出 * (输出 - BCM_滑动阈值) / 1000
    定义 可变 i = 0
    当 (i < 维度) {
        权重[i] = 权重[i] + 学习率 * 输入[i] * 调制 / 1000000
        i = i + 1
    }
    // 更新滑动阈值: θ_m = EMA(y²)
    BCM_滑动阈值 = (BCM_滑动阈值 * 950 + 输出 * 输出 / 1000 * 50) / 1000
}

// 原创定点Oja公式: Δw = η × y × (x - y×w)
// 收敛于第一主成分方向, ||w||=1

函数 赫布_Oja更新(权重, 输入, 维度, 学习率) {
    // 计算输出: y = w · x
    定义 可变 输出 = 0
    定义 可变 i = 0
    当 (i < 维度) {
        输出 = 输出 + 权重[i] * 输入[i] / 1000
        i = i + 1
    }
    // 更新: w_i += η × y × (x_i - y × w_i) / 1000000
    i = 0
    当 (i < 维度) {
        定义 增量 = 输出 * (输入[i] - 输出 * 权重[i] / 1000) / 1000
        权重[i] = 权重[i] + 学习率 * 增量 / 1000
        i = i + 1
    }
    返回 输出
}

// NovaOS原创: 三段式衰减 — 预热/稳定/衰减
// 公式: lr(t) = lr_0 × max(下限, 1000 - t×衰减速率/1000) / 1000

函数 赫布_衰减学习率(初始学习率, 当前步数, 衰减速率, 下限) {
    定义 因子 = 1000 - 当前步数 * 衰减速率 / 1000
    如果 (因子 < 下限) { 因子 = 下限 }
    返回 初始学习率 * 因子 / 1000
}

// SNR = 信号方差 / 噪声方差
// 用于评估学习质量, SNR越高学习越有效

函数 赫布_信噪比(关联, k) {
    定义 可变 总和 = 0
    定义 可变 总平方 = 0
    定义 n = k * k
    定义 可变 i = 0
    当 (i < n) {
        总和 = 总和 + 关联[i]
        总平方 = 总平方 + 关联[i] * 关联[i] / 1000
        i = i + 1
    }
    定义 均值 = 总和 / n
    定义 方差 = 总平方 / n - 均值 * 均值 / 1000
    如果 (方差 <= 0) { 返回 0 }
    返回 均值 * 均值 / (方差 + 1)
}

// NHLT定理2: 反赫布学习 (Anti-Hebbian / LTD)
// 解相关: 降低同时激活神经元间的权重, 促进特征正交化
// Δw = -η × x × y (与赫布符号相反)

函数 赫布_反赫布更新(权重, 输入, 输出, 维度, 学习率) {
    // Δw_i = -η × x_i × y / 1000000
    定义 可变 i = 0
    当 (i < 维度) {
        权重[i] = 权重[i] - 学习率 * 输入[i] * 输出 / 1000000
        i = i + 1
    }
    _赫布_反赫布总次 = _赫布_反赫布总次 + 1
}

// NHLT定理2: 双向赫布平衡更新 (LTP + LTD 同时)
// 如果 y × x > 0 → LTP(增强), 否则 LTD(减弱)
函数 赫布_双向更新(权重, 输入, 输出, 维度, LTP率, LTD率) {
    定义 可变 i = 0
    当 (i < 维度) {
        定义 共活 = 输入[i] * 输出
        如果 (共活 > 0) {
            权重[i] = 权重[i] + LTP率 * 输入[i] * 输出 / 1000000
        } 否则 {
            权重[i] = 权重[i] - LTD率 * 赫布_绝对值(输入[i] * 输出) / 1000000
        }
        i = i + 1
    }
    _赫布_更新总次 = _赫布_更新总次 + 1
}

// NHLT定理3: 竞争赫布学习 (WTA + 侧向抑制)
// 胜者的权重向输入靠近, 失败者被抑制

// 找到与输入最相似的神经元(胜者)
函数 赫布_竞争找胜者(权重矩阵, 神经元数, 维度, 输入) {
    定义 可变 最佳 = 0
    定义 可变 最大相似 = -999999
    定义 可变 n = 0
    当 (n < 神经元数) {
        定义 可变 点积 = 0
        定义 可变 d = 0
        当 (d < 维度) {
            点积 = 点积 + 权重矩阵[n * 维度 + d] * 输入[d] / 1000
            d = d + 1
        }
        如果 (点积 > 最大相似) { 最大相似 = 点积; 最佳 = n }
        n = n + 1
    }
    返回 最佳
}

// 竞争赫布学习: 只更新胜者权重向输入靠近
函数 赫布_竞争学习(权重矩阵, 神经元数, 维度, 输入, 学习率) {
    定义 胜者 = 赫布_竞争找胜者(权重矩阵, 神经元数, 维度, 输入)
    // 胜者: w += η × (x - w)
    定义 可变 d = 0
    当 (d < 维度) {
        定义 差 = 输入[d] - 权重矩阵[胜者 * 维度 + d]
        权重矩阵[胜者 * 维度 + d] = 权重矩阵[胜者 * 维度 + d] + 学习率 * 差 / 1000
        d = d + 1
    }
    _赫布_竞争总次 = _赫布_竞争总次 + 1
    返回 胜者
}

// NHLT 稳态可塑性: 权重范数自动缩放
// 防止权重爆炸: 如果 ||w|| > 阈值, 归一化

函数 赫布_权重归一(权重, 维度, 最大范数) {
    定义 可变 范数平方 = 0
    定义 可变 i = 0
    当 (i < 维度) {
        范数平方 = 范数平方 + 权重[i] * 权重[i] / 1000
        i = i + 1
    }
    如果 (范数平方 > 最大范数 * 最大范数 / 1000) {
        定义 范数 = 整数开方(范数平方 * 1000)
        如果 (范数 > 0) {
            i = 0
            当 (i < 维度) {
                权重[i] = 权重[i] * 最大范数 / 范数
                i = i + 1
            }
        }
    }
}

函数 赫布_完整统计() {
    返回 [
        ["全局学习率", 赫布_学习率],
        ["总更新次数", _赫布_更新总次],
        ["反赫布次数", _赫布_反赫布总次],
        ["竞争次数", _赫布_竞争总次],
        ["BCM滑动阈值", BCM_滑动阈值]
    ]
}
// 原理: 在Walsh域中, 当输入与某个Walsh基函数“共振”时
//   对应系数大幅增强, 非共振系数自然衰减
//   类似物理中的共振现象, 但用于离散学习
//   结果: 自动提取最强特征模式, 无需人工选择

函数 赫布_Walsh共振学习(关联, k, 输入, 学习率) {
    // 根据输入模式增强共振系数, 抑制非共振系数
    定义 可变 i = 0
    当 (i < k) {
        定义 输入符号 = 赫布_符号(输入[i])
        定义 可变 j = 0
        当 (j < k) {
            定义 现有 = 关联[i * k + j]
            定义 目标符号 = 赫布_符号(输入[j])
            // 共振: 符号一致时增强, 不一致时抑制
            定义 共振信号 = 输入符号 * 目标符号
            // 衰减: 现有强度越大, 衰减越快 (=反饱和)
            定义 衰减 = 赫布_绝对值(现有) / 100
            如果 (衰减 > 50) { 衰减 = 50 }
            关联[i * k + j] = 现有 * (1000 - 衰减) / 1000 + 学习率 * 共振信号 / 1000
            j = j + 1
        }
        i = i + 1
    }
}

// 输入有噪声的模式, 通过迭代收敛到最近的存储模式

函数 赫布_噪声修复(关联, 噪声输入, k, 最大迭代) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < k) { 追加(结果, 噪声输入[i]); i = i + 1 }
    定义 可变 迭代 = 0
    当 (迭代 < 最大迭代) {
        定义 可变 变化 = 0
        i = 0
        当 (i < k) {
            // 计算第i个分量的新值
            定义 可变 得分 = 0
            定义 可变 j = 0
            当 (j < k) {
                得分 = 得分 + 关联[i * k + j] * 赫布_符号(结果[j]) / 1000
                j = j + 1
            }
            定义 新值 = 赫布_符号(得分)
            如果 (新值 != 赫布_符号(结果[i])) { 变化 = 变化 + 1 }
            结果[i] = 新值 * 1000  // ×1000存储
            i = i + 1
        }
        如果 (变化 == 0) { 返回 结果 }  // 收敛
        迭代 = 迭代 + 1
    }
    返回 结果
}

// §8 重置与存取器

函数 赫布_重置统计() {
    _赫布_更新总次 = 0
    _赫布_反赫布总次 = 0
    _赫布_竞争总次 = 0
    BCM_滑动阈值 = 500
}

函数 赫布_获取学习率() { 返回 赫布_学习率 }
函数 赫布_获取更新数() { 返回 _赫布_更新总次 }
函数 赫布_获取反赫布数() { 返回 _赫布_反赫布总次 }
函数 赫布_获取竞争数() { 返回 _赫布_竞争总次 }
函数 赫布_获取BCM阈值() { 返回 BCM_滑动阈值 }

函数 赫布_设置学习率(新率) {
    如果 (新率 > 0 && 新率 <= 1000) {
        赫布_学习率 = 新率
    }
}

函数 赫布_健康检查() {
    定义 可变 问题 = 0
    如果 (赫布_学习率 <= 0 || 赫布_学习率 > 1000) { 问题 = 问题 + 1 }
    如果 (BCM_滑动阈值 < 0) { 问题 = 问题 + 1 }
    // 检查反赫布比例是否异常高
    如果 (_赫布_更新总次 > 100 && _赫布_反赫布总次 > _赫布_更新总次 * 9 / 10) {
        问题 = 问题 + 1  // 反赫布过多可能导致学习失调
    }
    返回 问题 == 0
}

函数 赫布_打印统计() {
    打印行("=== 赫布学习引擎统计 ===")
    打印行("学习率: " + 整数转字符串(赫布_学习率))
    打印行("更新次数: " + 整数转字符串(_赫布_更新总次))
    打印行("反赫布: " + 整数转字符串(_赫布_反赫布总次))
    打印行("竞争: " + 整数转字符串(_赫布_竞争总次))
    打印行("BCM阈值: " + 整数转字符串(BCM_滑动阈值))
}

// §9 STDP — 突触时序依赖可塑性
// 原理: 前突触先于后突触 → 增强(LTP)
//       后突触先于前突触 → 抑制(LTD)
//       时间窗口内指数衰减

定义 STDP_时间窗口 = 20   // 时间窗口(毫秒)
定义 STDP_增强率 = 100     // ×1000 LTP学习率
定义 STDP_抑制率 = 80      // ×1000 LTD学习率
定义 可变 _赫布_STDP总次 = 0

函数 赫布_STDP更新(权重, 前突触时间, 后突触时间) {
    _赫布_STDP总次 = _赫布_STDP总次 + 1
    定义 差 = 后突触时间 - 前突触时间
    如果 (差 > 0 && 差 <= STDP_时间窗口) {
        // LTP: pre before post → strengthen
        定义 衰减 = 1000 - (差 * 1000 / STDP_时间窗口)
        定义 增量 = STDP_增强率 * 衰减 / 1000
        返回 权重 + 增量
    } 否则 如果 (差 < 0 && (-差) <= STDP_时间窗口) {
        // LTD: post before pre → weaken
        定义 衰减 = 1000 - ((-差) * 1000 / STDP_时间窗口)
        定义 减量 = STDP_抑制率 * 衰减 / 1000
        定义 新 = 权重 - 减量
        如果 (新 < 0) { 新 = 0 }
        返回 新
    }
    返回 权重  // 超出窗口不变
}

// 批量STDP: 对突触序列进行批量更新
函数 赫布_批量STDP(权重矩阵, 神经元数, 前时间, 后时间) {
    定义 可变 i = 0
    当 (i < 神经元数) {
        定义 可变 j = 0
        当 (j < 神经元数) {
            如果 (i != j) {
                权重矩阵[i * 神经元数 + j] = 赫布_STDP更新(
                    权重矩阵[i * 神经元数 + j],
                    前时间[i], 后时间[j])
            }
            j = j + 1
        }
        i = i + 1
    }
}

// §10 稀疏赫布学习 — 只更新活跃神经元对
// 原理: 跳过所有零活动的神经元对, 大幅减少计算量

函数 赫布_稀疏更新(权重矩阵, 维度, 活跃向量, 输入, 学习率) {
    // 只更新活跃向量中非零元素对应的权重
    定义 可变 i = 0
    定义 可变 更新数 = 0
    当 (i < 维度) {
        如果 (活跃向量[i] != 0) {
            定义 可变 j = 0
            当 (j < 维度) {
                如果 (活跃向量[j] != 0) {
                    定义 差 = 输入[i] * 输入[j] / 1000
                    权重矩阵[i * 维度 + j] = 权重矩阵[i * 维度 + j] + 学习率 * 差 / 1000
                    更新数 = 更新数 + 1
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    返回 更新数
}

// §11 权重衰减调度器 — 防止权重爆炸
// 定期对所有权重施加微小衰减, 保证稳定性

定义 衰减_系数 = 999  // 每次×999/1000

函数 赫布_权重衰减(权重矩阵, 维度) {
    定义 可变 i = 0
    当 (i < 维度 * 维度) {
        权重矩阵[i] = 权重矩阵[i] * 衰减_系数 / 1000
        i = i + 1
    }
}

// 权重裁剪: 小于阈值的权重置零(L1正则化效果)
函数 赫布_权重裁剪(权重矩阵, 维度, 阈值) {
    定义 可变 裁剪数 = 0
    定义 可变 i = 0
    当 (i < 维度 * 维度) {
        如果 (赫布_绝对值(权重矩阵[i]) < 阈值) {
            权重矩阵[i] = 0
            裁剪数 = 裁剪数 + 1
        }
        i = i + 1
    }
    返回 裁剪数
}

// 计算权重矩阵的稀疏度
函数 赫布_稀疏度(权重矩阵, 维度) {
    定义 可变 零数 = 0
    定义 总数 = 维度 * 维度
    定义 可变 i = 0
    当 (i < 总数) {
        如果 (权重矩阵[i] == 0) { 零数 = 零数 + 1 }
        i = i + 1
    }
    如果 (总数 == 0) { 返回 0 }
    返回 零数 * 1000 / 总数
}

函数 赫布_获取STDP数() { 返回 _赫布_STDP总次 }

// §12 赫布矩阵分析 — 权重分布统计

// 计算权重矩阵的平均值(×1000)
函数 赫布_权重均值(权重矩阵, 维度) {
    定义 总数 = 维度 * 维度
    如果 (总数 == 0) { 返回 0 }
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < 总数) {
        总和 = 总和 + 权重矩阵[i]
        i = i + 1
    }
    返回 总和 / 总数
}

// 计算权重矩阵的最大绝对值
函数 赫布_权重最大值(权重矩阵, 维度) {
    定义 可变 最大 = 0
    定义 可变 i = 0
    当 (i < 维度 * 维度) {
        定义 v = 赫布_绝对值(权重矩阵[i])
        如果 (v > 最大) { 最大 = v }
        i = i + 1
    }
    返回 最大
}

// 计算权重范数平方(×1000, 近似Frobenius范数)
函数 赫布_权重范数平方(权重矩阵, 维度) {
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < 维度 * 维度) {
        总和 = 总和 + 权重矩阵[i] * 权重矩阵[i] / 1000
        i = i + 1
    }
    返回 总和
}

// 计算正权重数(统计激励与抑制比例)
函数 赫布_正权重数(权重矩阵, 维度) {
    定义 可变 正数 = 0
    定义 可变 i = 0
    当 (i < 维度 * 维度) {
        如果 (权重矩阵[i] > 0) { 正数 = 正数 + 1 }
        i = i + 1
    }
    返回 正数
}

// ◆ NHLT 理论 — Neural Hebbian Learning Theory
//   公理1: 赫布规则——“同火同线”是神经可塑性的基本定律
//   公理2: BCM滑动阈值实现稳态可塑性与反饱和
//   公理3: Walsh共振学习在离散域自动提取最强特征模式
//   公理4: STDP时序依赖可塑性是因果关系的神经编码
//   定理: 双向赫布平衡+权重衰减使权重分布收敛到稳定不动点
//         lim(w_t) → w* where Δw(w*) = 0

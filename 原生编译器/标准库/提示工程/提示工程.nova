导入("../基础.nova")


// 提示模板
// 型: [模板哈希, 变量名列表, 默认值列表, 类型]
定义 提示_系统 = 0
定义 提示_用户 = 1
定义 提示_助手 = 2
定义 提示_工具 = 3

函数 模板_创建(模板哈希, 变量列表) { 定义 可变 默认值 = []
 定义 可变 i = 0
 当 (i < 计数(变量列表)) { 追加(默认值, 0)
 i = i + 1 }
 返回 [模板哈希, 变量列表, 默认值, 提示_用户]
}

函数 模板_设默认值(模板, 变量idx, 值) {
 模板[2][变量idx] = 值
}

函数 模板_设类型(模板, 类型) { 模板[3] = 类型 }

// 少样本示例
// 型: [输入哈希列表, 输出哈希列表, 数量]
函数 少样本_创建() { 返回 [[], [], 0] }

函数 少样本_追加(示例集, 输入, 输出) {
 追加(示例集[0], 输入)
 追加(示例集[1], 输出)
 示例集[2] = 示例集[2] + 1
}

函数 少样本_数量(示例集) { 返回 示例集[2] }

函数 少样本_选择(示例集, 查询嵌入, 示例嵌入列表, k) {
 // 选择与查询最相似的k个示例 (基于嵌入相似度)
 定义 n = 示例集[2]
 定义 可变 分数 = []
 定义 可变 索引 = []
 定义 可变 i = 0
 当 (i < n) { 如果 (i < 计数(示例嵌入列表)) { 定义 可变 相似度 = 0
 定义 可变 j = 0
 当 (j < 计数(查询嵌入)) { 如果 (j < 计数(示例嵌入列表[i])) {
 相似度 = 相似度 + 查询嵌入[j] * 示例嵌入列表[i][j] / 1000
 }
 j = j + 1
 }
 追加(分数, 相似度)
 } 否则 { 追加(分数, 0) }
 追加(索引, i)
 i = i + 1
 }
 // 按分数降序取前k
 i = 0
 当 (i < k 且 i < n) { 定义 可变 最大idx = i
 定义 可变 j = i + 1
 当 (j < n) { 如果 (分数[索引[j]] > 分数[索引[最大idx]]) { 最大idx = j }
 j = j + 1
 }
 如果 (最大idx != i) { 定义 临时 = 索引[i]
 索引[i] = 索引[最大idx]
 索引[最大idx] = 临时
 }
 i = i + 1
 }
 定义 可变 选中 = []
 i = 0
 当 (i < k 且 i < n) { 追加(选中, 索引[i])
 i = i + 1 }
 返回 选中
}

// 对话消息
// 消息: [角色, 内容哈希, 名称, 工具调用ID]
函数 消息_创建(角色, 内容) { 返回 [角色, 内容,] }
函数 消息_系统(内容) { 返回 消息_创建(提示_系统, 内容) }
函数 消息_用户(内容) { 返回 消息_创建(提示_用户, 内容) }
函数 消息_助手(内容) { 返回 消息_创建(提示_助手, 内容) }
函数 消息_工具(内容, 调用ID) { 返回 [提示_工具, 内容, 0, 调用ID] }

// 对话历史
函数 对话_创建(系统提示) { 定义 可变 历史 = []
 如果 (系统提示 != 0) { 追加(历史, 消息_系统(系统提示)) }
 返回 [历史,] // [消息列表, 总token估计, 最大token]
}

函数 提示_对话_追加(对话, 消息) {
 追加(对话[0], 消息)
}

函数 对话_长度(对话) { 返回 计数(对话[0]) }

函数 对话_截断(对话, 保留最近N条) { 定义 总 = 计数(对话[0])
    定义 可变 新历史 = []
 如果 (总 <= 保留最近N条 + 1) { 返回 } // +1 for system
 // 保留系统消息
 如果 (对话[0][0][0] == 提示_系统) { 追加(新历史, 对话[0][0]) }
 // 保留最近N条
 定义 起始 = 总 - 保留最近N条
 定义 可变 i = 起始
 当 (i < 总) { 追加(新历史, 对话[0][i])
 i = i + 1 }
 对话[0] = 新历史
}

// 工具调用格式
// 型: [工具名哈希, 描述哈希, 参数定义列表]
函数 工具定义_创建(名称, 描述) { 返回 [名称, 描述, []]
}

函数 工具定义_添加参数(工具, 参数名, 参数类型, 是否必需) {
 追加(工具[2], [参数名, 参数类型, 是否必需])
}

函数 工具调用_创建(工具名, 参数列表) { 返回 [工具名, 参数列表, 0] // [名, 参数, 结果]
}

函数 工具调用_设结果(调用, 结果) { 调用[2] = 结果 }

// 输出解析
// JSON键值提取 (简化版: 查找"key": value模式)
函数 解析_提取整数(_输出哈希, 默认值) {
 // 从输出中提取整数值
 返回 默认值
}

函数 解析_是否包含(输出列表, 目标) { 定义 可变 i = 0
 当 (i < 计数(输出列表)) { 如果 (输出列表[i] == 目标) { 返回 1 }
 i = i + 1
 }
 返回 0
}

// 重试策略
函数 重试_创建(最大次数, 退避因子) { 返回 [最大次数, 退避因子,] // [最大, 退避, 当前次数, 上次延迟]
}

函数 重试_应重试(策略) { 返回 策略[2] < 策略[0]
}

函数 重试_下次延迟(策略) { 定义 可变 延迟 = 1000 // 1秒基础
 定义 可变 i = 0
 当 (i < 策略[2]) {
 延迟 = 延迟 * 策略[1] / 1000
 i = i + 1
 }
 策略[2] = 策略[2] + 1
 策略[3] = 延迟
 返回 延迟
}

函数 重试_重置(策略) { 策略[2] = 0
策略[3] = 0 }

// 提示组合
函数 提示链_创建() { 返回 [[]] }

函数 提示链_追加(链, 模板) { 追加(链[0], 模板) }

函数 提示链_长度(链) { 返回 计数(链[0]) }

// RAG提示构建
函数 RAG提示_创建(查询, 上下文列表, 最大上下文数) { 定义 可变 选中 = []
 定义 可变 i = 0
 当 (i < 最大上下文数 且 i < 计数(上下文列表)) {
 追加(选中, 上下文列表[i])
 i = i + 1
 }
 返回 [查询, 选中, 0] // [查询, 上下文, 答案]
}

函数 RAG提示_上下文数(提示) { 返回 计数(提示[1]) }

// 提示优化 (DSPy风格)
函数 提示优化_评估(提示变体列表, 评分列表) {
 // 返回评分最高的变体索引
 定义 n = 计数(提示变体列表)
 如果 (n == 0) { 返回 -1 }
 定义 可变 最佳 = 0
 定义 可变 i = 1
 当 (i < n) { 如果 (i < 计数(评分列表) 且 评分列表[i] > 评分列表[最佳]) { 最佳 = i }
 i = i + 1
 }
 返回 最佳
}

// 角色设定
函数 角色_创建(名称哈希, 描述哈希, 能力列表) { 返回 [名称哈希, 描述哈希, 能力列表, []] // [名, 描述, 能力, 约束]
}

函数 角色_添加约束(角色, 约束哈希) {
 追加(角色[3], 约束哈希)
}

// 安全过滤
定义 可变 黑名单关键词 = []

函数 安全_添加黑名单(关键词哈希) { 追加(黑名单关键词, 关键词哈希) }

函数 安全_检查(内容哈希列表) { 定义 可变 i = 0
 当 (i < 计数(内容哈希列表)) { 定义 可变 j = 0
 当 (j < 计数(黑名单关键词)) { 如果 (内容哈希列表[i] == 黑名单关键词[j]) { 返回 0 } // 不安全
 j = j + 1
 }
 i = i + 1
 }
 返回 1 // 安全
}

// Token计数估计
函数 估计_token数(字符数) {
 // 英文约4字符/token, 中文约1.5字符/token
 // 粗略估计: 字符数/3
 返回 字符数 / 3
}

函数 是否超限(token数, 模型上限) { 返回 token数 > 模型上限
}

结构 树构摘要 {
    模式,
    模式名,
    开放数,
    格式数,
    建元素数,
    建文本数,
    有头,
    有表单,
    帧集可用,
}

结构 HTMLDocumentParser {
    令牌izer,
    tree_builder,
    文档,
    已完成,
}

函数 树构_模式名(模式) {
    如果 (模式 == 插入模式_初始) { 返回 "初始" }
    如果 (模式 == 插入模式_DOCTYPE前) { 返回 "DOCTYPE前" }
    如果 (模式 == 插入模式_html前) { 返回 "html前" }
    如果 (模式 == 插入模式_head前) { 返回 "head前" }
    如果 (模式 == 插入模式_head中) { 返回 "head中" }
    如果 (模式 == 插入模式_head后) { 返回 "head后" }
    如果 (模式 == 插入模式_body中) { 返回 "body中" }
    如果 (模式 == 插入模式_文本) { 返回 "文本" }
    如果 (模式 == 插入模式_body后) { 返回 "body后" }
    如果 (模式 == 插入模式_html后) { 返回 "html后" }
    如果 (模式 == 插入模式_table中) { 返回 "表中" }
    如果 (模式 == 插入模式_行中) { 返回 "行中" }
    如果 (模式 == 插入模式_单元格中) { 返回 "格中" }
    如果 (模式 == 插入模式_select中) { 返回 "选中" }
    返回 "未知"
}

函数 树构_是标题元素(标签原子) {
    如果 (标签原子 == 原子_h1) { 返回 1 }
    如果 (标签原子 == 原子_h2) { 返回 1 }
    如果 (标签原子 == 原子_h3) { 返回 1 }
    如果 (标签原子 == 原子_h4) { 返回 1 }
    如果 (标签原子 == 原子_h5) { 返回 1 }
    如果 (标签原子 == 原子_h6) { 返回 1 }
    返回 0
}

函数 树构_当前节点(tb) {
    如果 (tb == 0) { 返回 0 }
    返回 元素栈_顶部(tb.开放元素栈)
}

函数 树构_关闭到标签(tb, 标签原子) {
    如果 (元素栈_包含标签(tb.开放元素栈, 标签原子)) {
        元素栈_弹出直到含(tb.开放元素栈, 标签原子)
        返回 1
    }
    返回 0
}

函数 树构_摘要(tb) {
    定义 摘 = 堆_分配(树构摘要)
    摘.模式 = tb.插入模式
    摘.模式名 = 树构_模式名(tb.插入模式)
    摘.开放数 = tb.开放元素栈.数量
    摘.格式数 = tb.格式化列表.数量
    摘.建元素数 = tb.创建元素数
    摘.建文本数 = tb.创建文本数
    摘.有头 = tb.head指针 != 0
    摘.有表单 = tb.form指针 != 0
    摘.帧集可用 = tb.frameset_ok
    返回 摘
}

函数 树构_摘要串(tb) {
    定义 摘 = 树构_摘要(tb)
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "{")
    字符串构建器_追加(建, "\"模式\":\"")
    字符串构建器_追加(建, 摘.模式名)
    字符串构建器_追加(建, "\",\"开放数\":")
    字符串构建器_追加(建, 整数转字符串(摘.开放数))
    字符串构建器_追加(建, ",\"格式数\":")
    字符串构建器_追加(建, 整数转字符串(摘.格式数))
    字符串构建器_追加(建, ",\"建元素数\":")
    字符串构建器_追加(建, 整数转字符串(摘.建元素数))
    字符串构建器_追加(建, ",\"建文本数\":")
    字符串构建器_追加(建, 整数转字符串(摘.建文本数))
    字符串构建器_追加(建, ",\"有头\":")
    如果 (摘.有头) { 字符串构建器_追加(建, "true") } 否则 { 字符串构建器_追加(建, "false") }
    字符串构建器_追加(建, ",\"有表单\":")
    如果 (摘.有表单) { 字符串构建器_追加(建, "true") } 否则 { 字符串构建器_追加(建, "false") }
    字符串构建器_追加(建, ",\"帧集可用\":")
    如果 (摘.帧集可用) { 字符串构建器_追加(建, "true") } 否则 { 字符串构建器_追加(建, "false") }
    字符串构建器_追加(建, "}")
    返回 字符串构建器_构建(建)
}

函数 树构_自检(tb) {
    定义 可变 错数 = 0
    如果 (tb == 0) { 返回 1 }
    如果 (tb.开放元素栈 == 0) { 错数 = 错数 + 1 }
    如果 (tb.格式化列表 == 0) { 错数 = 错数 + 1 }
    如果 (tb.文档 == 0) { 错数 = 错数 + 1 }
    如果 (tb.插入模式 == 插入模式_head中 && tb.head指针 == 0) {
        错数 = 错数 + 1
    }
    返回 错数
}

函数 HTMLTreeBuilder_创建元素并插入(tb, 令牌, 指定父) {
    定义 元素 = Document_create元素(tb.文档, 令牌.标签名)
    tb.创建元素数 = tb.创建元素数 + 1

    定义 可变 i = 0
    当 (i < 令牌.属性数量) {
        定义 偏移 = 令牌.属性列表 + i * 40
        定义 名 = 内存_读64(偏移)
        定义 值 = 内存_读64(偏移 + 16)
        元素_setAttribute(元素, 名, 值)
        i = i + 1
    }

    定义 父 = 指定父
    如果 (父 == 0) {
        父 = 树构_当前节点(tb)
    }
    如果 (父 != 0) {
        节点_appendChild(父, 元素)
    }

    智能_HTMLTreeBuilder_AI节点语义(元素)
    返回 元素
}

函数 HTMLTreeBuilder_插入文本(tb, 数据, 长度) {
    如果 (长度 == 0) { 返回 }
    定义 当前 = 树构_当前节点(tb)
    如果 (当前 == 0) { 返回 }

    定义 最后子 = 当前.最后子节点
    如果 (最后子 != 0 && 最后子.节点类型 == TEXT_节点) {
        定义 文本 = 字符串_从缓冲(数据, 长度)
        CharacterData_appendData(最后子, 文本)
    } 否则 {
        定义 文本 = 字符串_从缓冲(数据, 长度)
        定义 文本节点 = Document_createText节点(tb.文档, 文本)
        节点_appendChild(当前, 文本节点)
        tb.创建文本数 = tb.创建文本数 + 1
    }
}

函数 HTMLTreeBuilder_关闭P元素(tb) {
    树构_关闭到标签(tb, 原子_p)
}

函数 元素_是空元素_原子(标签原子) {
    如果 (标签原子 == 原子_br) { 返回 1 }
    如果 (标签原子 == 原子_hr) { 返回 1 }
    如果 (标签原子 == 原子_img) { 返回 1 }
    如果 (标签原子 == 原子_input) { 返回 1 }
    如果 (标签原子 == 原子_link) { 返回 1 }
    如果 (标签原子 == 原子_meta) { 返回 1 }
    如果 (标签原子 == 原子_area) { 返回 1 }
    如果 (标签原子 == 原子_base) { 返回 1 }
    如果 (标签原子 == 原子_col) { 返回 1 }
    如果 (标签原子 == 原子_embed) { 返回 1 }
    如果 (标签原子 == 原子_param) { 返回 1 }
    如果 (标签原子 == 原子_source) { 返回 1 }
    如果 (标签原子 == 原子_track) { 返回 1 }
    如果 (标签原子 == 原子_wbr) { 返回 1 }
    返回 0
}

函数 是格式化元素(标签原子) {
    如果 (标签原子 == 原子_b) { 返回 1 }
    如果 (标签原子 == 原子_i) { 返回 1 }
    如果 (标签原子 == 原子_em) { 返回 1 }
    如果 (标签原子 == 原子_strong) { 返回 1 }
    如果 (标签原子 == 原子_u) { 返回 1 }
    如果 (标签原子 == 原子_s) { 返回 1 }
    如果 (标签原子 == 原子_small) { 返回 1 }
    如果 (标签原子 == 原子_code) { 返回 1 }
    如果 (标签原子 == 原子_mark) { 返回 1 }
    如果 (标签原子 == 原子_a) { 返回 1 }
    如果 (标签原子 == 原子_font) { 返回 1 }
    如果 (标签原子 == 原子_big) { 返回 1 }
    如果 (标签原子 == 原子_strike) { 返回 1 }
    如果 (标签原子 == 原子_tt) { 返回 1 }
    返回 0
}

函数 是特殊元素(标签原子) {
    如果 (标签原子 == 原子_html) { 返回 1 }
    如果 (标签原子 == 原子_table) { 返回 1 }
    如果 (标签原子 == 原子_td) { 返回 1 }
    如果 (标签原子 == 原子_th) { 返回 1 }
    如果 (标签原子 == 原子_caption) { 返回 1 }
    如果 (标签原子 == 原子_select) { 返回 1 }
    如果 (标签原子 == 原子_template) { 返回 1 }
    返回 0
}

函数 元素栈_在作用域中(栈, 标签原子) {
    定义 可变 i = 栈.数量
    当 (i > 0) {
        i = i - 1
        定义 元素 = 内存_读64(栈.元素列表 + i * 8)
        定义 扩展 = 元素_获取扩展(元素)
        如果 (扩展 != 0) {
            如果 (扩展.标签名原子 == 标签原子) { 返回 1 }
            如果 (是特殊元素(扩展.标签名原子)) { 返回 0 }
        }
    }
    返回 0
}

函数 HTMLTreeBuilder_重建格式化元素(tb) {
    定义 格式列表 = tb.格式化列表
    如果 (格式列表.数量 == 0) { 返回 }

    定义 可变 start = 格式列表.数量 - 1
    当 (start > 0) {
        定义 元 = 内存_读64(格式列表.元素 + start * 8)
        如果 (元 == 格式化标记_标记) {
            start = start + 1
            跳出
        }
        start = start - 1
    }

    定义 可变 i = start
    当 (i < 格式列表.数量) {
        定义 元 = 内存_读64(格式列表.元素 + i * 8)
        如果 (元 != 格式化标记_标记) {
            定义 扩展 = 元素_获取扩展(元)
            如果 (扩展 != 0 && !元素栈_包含标签(tb.开放元素栈, 扩展.标签名原子)) {
                定义 新元素 = Document_create元素(tb.文档, 扩展.标签名)
                定义 当前 = 树构_当前节点(tb)
                如果 (当前 != 0) { 节点_appendChild(当前, 新元素) }
                元素栈_压入(tb.开放元素栈, 新元素)
                内存_写64(格式列表.元素 + i * 8, 新元素)
                智能_HTMLTreeBuilder_AI节点语义(新元素)
            }
        }
        i = i + 1
    }
}

函数 HTMLDocumentParser_创建(文档) {
    定义 parser = 堆_分配(HTMLDocumentParser)
    parser.令牌izer = HTML令牌izer_创建()
    parser.tree_builder = HTMLTreeBuilder_创建(文档, parser.令牌izer)
    parser.文档 = 文档
    parser.已完成 = 假

    定义 扩展 = Document_获取扩展(文档)
    如果 (扩展 != 0) {
        扩展.解析器 = parser
        扩展.解析状态 = 解析状态_解析中
    }

    返回 parser
}

函数 HTMLDocumentParser_解析(parser, html字符串) {
    HTML令牌izer_设置输入(parser.令牌izer, html字符串)
    元素_初始化原子表()

    定义 令牌 = HTML令牌_创建()
    当 (!parser.已完成) {
        定义 结果 = HTML令牌izer_下一个令牌(parser.令牌izer, 令牌)
        HTMLTreeBuilder_处理令牌(parser.tree_builder, 令牌)
        如果 (结果 == -1) {
            parser.已完成 = 真
        }
    }

    Document_完成解析(parser.文档)
}

函数 HTMLDocumentParser_解析并摘要(parser, html字符串) {
    HTMLDocumentParser_解析(parser, html字符串)
    返回 树构_摘要串(parser.tree_builder)
}

函数 HTML解析器_解析片段(html文本, 上下文元素) {
    定义 文档 = Document_创建("about:blank")
    定义 parser = HTMLDocumentParser_创建(文档)
    HTMLDocumentParser_解析(parser, html文本)
    返回 文档
}

函数 HTML解析器_解析并摘要(html文本) {
    定义 文档 = Document_创建("about:blank")
    定义 parser = HTMLDocumentParser_创建(文档)
    返回 HTMLDocumentParser_解析并摘要(parser, html文本)
}

函数 智能_HTMLTreeBuilder_AI节点语义(节点) {
    定义 bus = 全局AI总线
    如果 (bus == 0 || 节点 == 0) { 返回 }
    定义 角色 = AI总线_语义分类(bus, 节点)
    节点.语义角色 = 角色
}

函数 智能_HTMLTreeBuilder_AI预加载提示(url, 资源类型) {
    定义 bus = 全局AI总线
    如果 (bus == 0 || url == 0) { 返回 }
    定义 优先级 = AI总线_资源优先级(bus, url)
}

函数 HTMLTreeBuilder_处理令牌(tb, 令牌) {
    如果 (tb.插入模式 == 插入模式_初始) {
        HTMLTreeBuilder_初始模式(tb, 令牌)
    }
    否则 如果 (tb.插入模式 == 插入模式_DOCTYPE前 || tb.插入模式 == 插入模式_html前) {
        HTMLTreeBuilder_html前模式(tb, 令牌)
    }
    否则 如果 (tb.插入模式 == 插入模式_head前) {
        HTMLTreeBuilder_head前模式(tb, 令牌)
    }
    否则 如果 (tb.插入模式 == 插入模式_head中) {
        HTMLTreeBuilder_head中模式(tb, 令牌)
    }
    否则 如果 (tb.插入模式 == 插入模式_head后) {
        HTMLTreeBuilder_head后模式(tb, 令牌)
    }
    否则 如果 (tb.插入模式 == 插入模式_body中) {
        HTMLTreeBuilder_body中模式(tb, 令牌)
    }
    否则 如果 (tb.插入模式 == 插入模式_文本) {
        HTMLTreeBuilder_文本模式(tb, 令牌)
    }
    否则 如果 (tb.插入模式 == 插入模式_body后) {
        HTMLTreeBuilder_body后模式(tb, 令牌)
    }
    否则 如果 (tb.插入模式 == 插入模式_html后) {
        HTMLTreeBuilder_html后模式(tb, 令牌)
    }
    否则 如果 (tb.插入模式 == 插入模式_table中) {
        HTMLTreeBuilder_table中模式(tb, 令牌)
    }
    否则 如果 (tb.插入模式 == 插入模式_行中) {
        HTMLTreeBuilder_行中模式(tb, 令牌)
    }
    否则 如果 (tb.插入模式 == 插入模式_单元格中) {
        HTMLTreeBuilder_单元格中模式(tb, 令牌)
    }
    否则 如果 (tb.插入模式 == 插入模式_select中) {
        HTMLTreeBuilder_select中模式(tb, 令牌)
    }
}

函数 HTMLTreeBuilder_初始模式(tb, 令牌) {
    如果 (令牌.类型 == 令牌类型_字符) { 返回 }
    如果 (令牌.类型 == 令牌类型_注释) {
        定义 注释 = Comment_创建(令牌.数据)
        节点_appendChild(tb.文档, 注释)
        返回
    }
    如果 (令牌.类型 == 令牌类型_DOCTYPE) {
        定义 doctype = DocumentType_创建(令牌.DOCTYPE名称, "", "")
        节点_appendChild(tb.文档, doctype)
        如果 (令牌.强制怪异模式) {
            定义 扩展 = Document_获取扩展(tb.文档)
            如果 (扩展 != 0) { 扩展.兼容模式 = 兼容模式_怪异 }
        }
        tb.插入模式 = 插入模式_html前
        返回
    }
    定义 扩展 = Document_获取扩展(tb.文档)
    如果 (扩展 != 0) { 扩展.兼容模式 = 兼容模式_怪异 }
    tb.插入模式 = 插入模式_html前
    HTMLTreeBuilder_处理令牌(tb, 令牌)
}

函数 HTMLTreeBuilder_html前模式(tb, 令牌) {
    如果 (令牌.类型 == 令牌类型_DOCTYPE) { 返回 }
    如果 (令牌.类型 == 令牌类型_注释) {
        定义 注释 = Comment_创建(令牌.数据)
        节点_appendChild(tb.文档, 注释)
        返回
    }
    如果 (令牌.类型 == 令牌类型_开始标签) {
        定义 标签原子 = 原子_驻留(令牌.标签名)
        如果 (标签原子 == 原子_html) {
            定义 html = HTMLTreeBuilder_创建元素并插入(tb, 令牌, tb.文档)
            元素栈_压入(tb.开放元素栈, html)
            Document_设置文档元素(tb.文档, html)
            tb.插入模式 = 插入模式_head前
            返回
        }
    }
    定义 html = Document_create元素(tb.文档, "html")
    节点_appendChild(tb.文档, html)
    元素栈_压入(tb.开放元素栈, html)
    Document_设置文档元素(tb.文档, html)
    tb.插入模式 = 插入模式_head前
    HTMLTreeBuilder_处理令牌(tb, 令牌)
}

函数 HTMLTreeBuilder_head前模式(tb, 令牌) {
    如果 (令牌.类型 == 令牌类型_字符) { 返回 }
    如果 (令牌.类型 == 令牌类型_开始标签) {
        定义 标签原子 = 原子_驻留(令牌.标签名)
        如果 (标签原子 == 原子_head) {
            定义 head = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
            tb.head指针 = head
            元素栈_压入(tb.开放元素栈, head)
            Document_设置head(tb.文档, head)
            tb.插入模式 = 插入模式_head中
            返回
        }
    }
    定义 head = Document_create元素(tb.文档, "head")
    定义 当前 = 树构_当前节点(tb)
    节点_appendChild(当前, head)
    tb.head指针 = head
    元素栈_压入(tb.开放元素栈, head)
    Document_设置head(tb.文档, head)
    tb.插入模式 = 插入模式_head中
    HTMLTreeBuilder_处理令牌(tb, 令牌)
}

函数 HTMLTreeBuilder_head中模式(tb, 令牌) {
    如果 (令牌.类型 == 令牌类型_字符) {
        HTMLTreeBuilder_插入文本(tb, 令牌.数据, 令牌.数据长度)
        返回
    }
    如果 (令牌.类型 == 令牌类型_注释) {
        定义 注释 = Comment_创建(令牌.数据)
        定义 当前 = 树构_当前节点(tb)
        节点_appendChild(当前, 注释)
        返回
    }
    如果 (令牌.类型 == 令牌类型_开始标签) {
        定义 标签原子 = 原子_驻留(令牌.标签名)
        如果 (标签原子 == 原子_title) {
            HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
            HTML令牌izer_切换到RCDATA(tb.令牌izer)
            tb.原始插入模式 = tb.插入模式
            tb.插入模式 = 插入模式_文本
            返回
        }
        如果 (标签原子 == 原子_style) {
            HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
            HTML令牌izer_切换到RAWTEXT(tb.令牌izer)
            tb.原始插入模式 = tb.插入模式
            tb.插入模式 = 插入模式_文本
            返回
        }
        如果 (标签原子 == 原子_script) {
            HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
            HTML令牌izer_切换到脚本数据(tb.令牌izer)
            tb.原始插入模式 = tb.插入模式
            tb.插入模式 = 插入模式_文本
            返回
        }
        如果 (标签原子 == 原子_meta || 标签原子 == 原子_link) {
            HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
            如果 (令牌.自闭合 || 元素_是空元素_原子(标签原子)) {
                元素栈_弹出(tb.开放元素栈)
            }
            返回
        }
        返回 HTMLTreeBuilder_关闭head(tb, 令牌)
    }
    如果 (令牌.类型 == 令牌类型_结束标签) {
        定义 标签原子 = 原子_驻留(令牌.标签名)
        如果 (标签原子 == 原子_head) {
            元素栈_弹出(tb.开放元素栈)
            tb.插入模式 = 插入模式_head后
            返回
        }
    }
    HTMLTreeBuilder_关闭head(tb, 令牌)
}

函数 HTMLTreeBuilder_关闭head(tb, 令牌) {
    元素栈_弹出(tb.开放元素栈)
    tb.插入模式 = 插入模式_head后
    HTMLTreeBuilder_处理令牌(tb, 令牌)
}

函数 HTMLTreeBuilder_head后模式(tb, 令牌) {
    如果 (令牌.类型 == 令牌类型_字符) {
        HTMLTreeBuilder_插入文本(tb, 令牌.数据, 令牌.数据长度)
        返回
    }
    如果 (令牌.类型 == 令牌类型_开始标签) {
        定义 标签原子 = 原子_驻留(令牌.标签名)
        如果 (标签原子 == 原子_body) {
            定义 body = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
            元素栈_压入(tb.开放元素栈, body)
            Document_设置body(tb.文档, body)
            tb.frameset_ok = 假
            tb.插入模式 = 插入模式_body中
            返回
        }
    }
    定义 body = Document_create元素(tb.文档, "body")
    定义 当前 = 树构_当前节点(tb)
    节点_appendChild(当前, body)
    元素栈_压入(tb.开放元素栈, body)
    Document_设置body(tb.文档, body)
    tb.插入模式 = 插入模式_body中
    HTMLTreeBuilder_处理令牌(tb, 令牌)
}

函数 HTMLTreeBuilder_body中模式(tb, 令牌) {
    如果 (令牌.类型 == 令牌类型_字符) {
        HTMLTreeBuilder_插入文本(tb, 令牌.数据, 令牌.数据长度)
        返回
    }
    如果 (令牌.类型 == 令牌类型_注释) {
        定义 注释 = Comment_创建(令牌.数据)
        定义 当前 = 树构_当前节点(tb)
        节点_appendChild(当前, 注释)
        返回
    }
    如果 (令牌.类型 == 令牌类型_文件结束) { 返回 }
    如果 (令牌.类型 == 令牌类型_开始标签) {
        HTMLTreeBuilder_body中_开始标签(tb, 令牌)
        返回
    }
    如果 (令牌.类型 == 令牌类型_结束标签) {
        HTMLTreeBuilder_body中_结束标签(tb, 令牌)
        返回
    }
}

函数 HTMLTreeBuilder_body中_开始标签(tb, 令牌) {
    定义 标签原子 = 原子_驻留(令牌.标签名)

    如果 (标签原子 == 原子_div || 标签原子 == 原子_p ||
        标签原子 == 原子_section || 标签原子 == 原子_article ||
        标签原子 == 原子_nav || 标签原子 == 原子_aside ||
        标签原子 == 原子_header || 标签原子 == 原子_footer ||
        标签原子 == 原子_main) {
        如果 (元素栈_包含标签(tb.开放元素栈, 原子_p)) {
            HTMLTreeBuilder_关闭P元素(tb)
        }
        定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        元素栈_压入(tb.开放元素栈, 元素)
        返回
    }

    如果 (树构_是标题元素(标签原子)) {
        如果 (元素栈_包含标签(tb.开放元素栈, 原子_p)) {
            HTMLTreeBuilder_关闭P元素(tb)
        }
        定义 顶 = 树构_当前节点(tb)
        定义 顶扩展 = 元素_获取扩展(顶)
        如果 (顶扩展 != 0 && 树构_是标题元素(顶扩展.标签名原子)) {
            元素栈_弹出(tb.开放元素栈)
        }
        定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        元素栈_压入(tb.开放元素栈, 元素)
        返回
    }

    如果 (标签原子 == 原子_ul || 标签原子 == 原子_ol) {
        如果 (元素栈_包含标签(tb.开放元素栈, 原子_p)) {
            HTMLTreeBuilder_关闭P元素(tb)
        }
        定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        元素栈_压入(tb.开放元素栈, 元素)
        返回
    }
    如果 (标签原子 == 原子_li) {
        树构_关闭到标签(tb, 原子_li)
        如果 (元素栈_包含标签(tb.开放元素栈, 原子_p)) {
            HTMLTreeBuilder_关闭P元素(tb)
        }
        定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        元素栈_压入(tb.开放元素栈, 元素)
        返回
    }

    如果 (标签原子 == 原子_span || 标签原子 == 原子_label ||
        标签原子 == 原子_cite || 标签原子 == 原子_q ||
        标签原子 == 原子_sub || 标签原子 == 原子_sup) {
        HTMLTreeBuilder_重建格式化元素(tb)
        定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        元素栈_压入(tb.开放元素栈, 元素)
        返回
    }
    如果 (是格式化元素(标签原子)) {
        HTMLTreeBuilder_重建格式化元素(tb)
        如果 (标签原子 == 原子_a && 元素栈_包含标签(tb.开放元素栈, 原子_a)) {
            HTMLTreeBuilder_adoption_agency(tb, 原子_a)
        }
        定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        元素栈_压入(tb.开放元素栈, 元素)
        格式化列表_添加(tb.格式化列表, 元素)
        返回
    }

    如果 (标签原子 == 原子_dd || 标签原子 == 原子_dt) {
        树构_关闭到标签(tb, 原子_dd)
        树构_关闭到标签(tb, 原子_dt)
        如果 (元素栈_包含标签(tb.开放元素栈, 原子_p)) {
            HTMLTreeBuilder_关闭P元素(tb)
        }
        定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        元素栈_压入(tb.开放元素栈, 元素)
        返回
    }

    如果 (标签原子 == 原子_pre || 标签原子 == 原子_listing) {
        如果 (元素栈_包含标签(tb.开放元素栈, 原子_p)) {
            HTMLTreeBuilder_关闭P元素(tb)
        }
        定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        元素栈_压入(tb.开放元素栈, 元素)
        tb.frameset_ok = 假
        返回
    }

    如果 (标签原子 == 原子_br || 标签原子 == 原子_hr || 标签原子 == 原子_img) {
        如果 (标签原子 == 原子_hr && 元素栈_包含标签(tb.开放元素栈, 原子_p)) {
            HTMLTreeBuilder_关闭P元素(tb)
        }
        HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        返回
    }

    如果 (标签原子 == 原子_input || 标签原子 == 原子_textarea ||
        标签原子 == 原子_select || 标签原子 == 原子_button) {
        定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        如果 (标签原子 != 原子_input) {
            元素栈_压入(tb.开放元素栈, 元素)
        }
        返回
    }
    如果 (标签原子 == 原子_form) {
        如果 (tb.form指针 != 0) { 返回 }
        定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        元素栈_压入(tb.开放元素栈, 元素)
        tb.form指针 = 元素
        返回
    }

    如果 (标签原子 == 原子_table) {
        如果 (元素栈_包含标签(tb.开放元素栈, 原子_p)) {
            HTMLTreeBuilder_关闭P元素(tb)
        }
        定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        元素栈_压入(tb.开放元素栈, 元素)
        tb.插入模式 = 插入模式_table中
        返回
    }

    如果 (标签原子 == 原子_script) {
        定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        元素栈_压入(tb.开放元素栈, 元素)
        HTML令牌izer_切换到脚本数据(tb.令牌izer)
        tb.原始插入模式 = tb.插入模式
        tb.插入模式 = 插入模式_文本
        返回
    }
    如果 (标签原子 == 原子_style) {
        定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        元素栈_压入(tb.开放元素栈, 元素)
        HTML令牌izer_切换到RAWTEXT(tb.令牌izer)
        tb.原始插入模式 = tb.插入模式
        tb.插入模式 = 插入模式_文本
        返回
    }

    如果 (标签原子 == 原子_iframe || 标签原子 == 原子_canvas ||
        标签原子 == 原子_video || 标签原子 == 原子_audio) {
        定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
        元素栈_压入(tb.开放元素栈, 元素)
        返回
    }

    定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
    如果 (!令牌.自闭合 && !元素_是空元素_原子(标签原子)) {
        元素栈_压入(tb.开放元素栈, 元素)
    }
}

函数 HTMLTreeBuilder_body中_结束标签(tb, 令牌) {
    定义 标签原子 = 原子_驻留(令牌.标签名)

    如果 (标签原子 == 原子_body) {
        tb.插入模式 = 插入模式_body后
        返回
    }
    如果 (标签原子 == 原子_html) {
        tb.插入模式 = 插入模式_body后
        HTMLTreeBuilder_处理令牌(tb, 令牌)
        返回
    }

    如果 (是格式化元素(标签原子)) {
        HTMLTreeBuilder_adoption_agency(tb, 标签原子)
        返回
    }

    如果 (标签原子 == 原子_dd || 标签原子 == 原子_dt) {
        树构_关闭到标签(tb, 标签原子)
        返回
    }

    如果 (标签原子 == 原子_div || 标签原子 == 原子_p ||
        标签原子 == 原子_section || 标签原子 == 原子_article ||
        标签原子 == 原子_nav || 标签原子 == 原子_aside ||
        标签原子 == 原子_header || 标签原子 == 原子_footer ||
        标签原子 == 原子_main || 标签原子 == 原子_ul ||
        标签原子 == 原子_ol || 树构_是标题元素(标签原子)) {
        树构_关闭到标签(tb, 标签原子)
        返回
    }
    如果 (标签原子 == 原子_li) {
        树构_关闭到标签(tb, 原子_li)
        返回
    }
    如果 (标签原子 == 原子_form) {
        tb.form指针 = 0
        树构_关闭到标签(tb, 原子_form)
        返回
    }

    树构_关闭到标签(tb, 标签原子)
}

函数 HTMLTreeBuilder_文本模式(tb, 令牌) {
    如果 (令牌.类型 == 令牌类型_字符) {
        HTMLTreeBuilder_插入文本(tb, 令牌.数据, 令牌.数据长度)
        返回
    }
    如果 (令牌.类型 == 令牌类型_文件结束) {
        元素栈_弹出(tb.开放元素栈)
        tb.插入模式 = tb.原始插入模式
        HTMLTreeBuilder_处理令牌(tb, 令牌)
        返回
    }
    如果 (令牌.类型 == 令牌类型_结束标签) {
        定义 标签原子 = 原子_驻留(令牌.标签名)
        如果 (标签原子 == 原子_script) {
            定义 脚本元素 = 元素栈_弹出(tb.开放元素栈)
            tb.插入模式 = tb.原始插入模式
            返回
        }
        元素栈_弹出(tb.开放元素栈)
        tb.插入模式 = tb.原始插入模式
        返回
    }
}

函数 HTMLTreeBuilder_body后模式(tb, 令牌) {
    如果 (令牌.类型 == 令牌类型_字符) { 返回 }
    如果 (令牌.类型 == 令牌类型_注释) {
        定义 html = Document_document元素(tb.文档)
        如果 (html != 0) {
            定义 注释 = Comment_创建(令牌.数据)
            节点_appendChild(html, 注释)
        }
        返回
    }
    如果 (令牌.类型 == 令牌类型_结束标签) {
        定义 标签原子 = 原子_驻留(令牌.标签名)
        如果 (标签原子 == 原子_html) {
            tb.插入模式 = 插入模式_html后
            返回
        }
    }
    如果 (令牌.类型 == 令牌类型_文件结束) { 返回 }
    tb.插入模式 = 插入模式_body中
    HTMLTreeBuilder_处理令牌(tb, 令牌)
}

函数 HTMLTreeBuilder_html后模式(tb, 令牌) {
    如果 (令牌.类型 == 令牌类型_注释) {
        定义 注释 = Comment_创建(令牌.数据)
        节点_appendChild(tb.文档, 注释)
        返回
    }
    如果 (令牌.类型 == 令牌类型_文件结束) { 返回 }
}

函数 HTMLTreeBuilder_table中模式(tb, 令牌) {
    如果 (令牌.类型 == 令牌类型_开始标签) {
        定义 标签原子 = 原子_驻留(令牌.标签名)
        如果 (标签原子 == 原子_tr) {
            定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
            元素栈_压入(tb.开放元素栈, 元素)
            tb.插入模式 = 插入模式_行中
            返回
        }
        如果 (标签原子 == 原子_td || 标签原子 == 原子_th) {
            定义 tr = Document_create元素(tb.文档, "tr")
            定义 当前 = 树构_当前节点(tb)
            节点_appendChild(当前, tr)
            元素栈_压入(tb.开放元素栈, tr)
            tb.插入模式 = 插入模式_行中
            HTMLTreeBuilder_处理令牌(tb, 令牌)
            返回
        }
    }
    如果 (令牌.类型 == 令牌类型_结束标签) {
        定义 标签原子 = 原子_驻留(令牌.标签名)
        如果 (标签原子 == 原子_table) {
            树构_关闭到标签(tb, 原子_table)
            tb.插入模式 = 插入模式_body中
            返回
        }
    }
    HTMLTreeBuilder_body中模式(tb, 令牌)
}

函数 HTMLTreeBuilder_行中模式(tb, 令牌) {
    如果 (令牌.类型 == 令牌类型_开始标签) {
        定义 标签原子 = 原子_驻留(令牌.标签名)
        如果 (标签原子 == 原子_td || 标签原子 == 原子_th) {
            定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
            元素栈_压入(tb.开放元素栈, 元素)
            tb.插入模式 = 插入模式_单元格中
            返回
        }
    }
    如果 (令牌.类型 == 令牌类型_结束标签) {
        定义 标签原子 = 原子_驻留(令牌.标签名)
        如果 (标签原子 == 原子_tr) {
            树构_关闭到标签(tb, 原子_tr)
            tb.插入模式 = 插入模式_table中
            返回
        }
    }
    HTMLTreeBuilder_table中模式(tb, 令牌)
}

函数 HTMLTreeBuilder_单元格中模式(tb, 令牌) {
    如果 (令牌.类型 == 令牌类型_结束标签) {
        定义 标签原子 = 原子_驻留(令牌.标签名)
        如果 (标签原子 == 原子_td || 标签原子 == 原子_th) {
            树构_关闭到标签(tb, 标签原子)
            tb.插入模式 = 插入模式_行中
            返回
        }
    }
    HTMLTreeBuilder_body中模式(tb, 令牌)
}

函数 HTMLTreeBuilder_select中模式(tb, 令牌) {
    如果 (令牌.类型 == 令牌类型_开始标签) {
        定义 标签原子 = 原子_驻留(令牌.标签名)
        如果 (标签原子 == 原子_option) {
            定义 元素 = HTMLTreeBuilder_创建元素并插入(tb, 令牌, 0)
            元素栈_压入(tb.开放元素栈, 元素)
            返回
        }
    }
    如果 (令牌.类型 == 令牌类型_结束标签) {
        定义 标签原子 = 原子_驻留(令牌.标签名)
        如果 (标签原子 == 原子_select) {
            树构_关闭到标签(tb, 原子_select)
            tb.插入模式 = 插入模式_body中
            返回
        }
        如果 (标签原子 == 原子_option) {
            元素栈_弹出(tb.开放元素栈)
            返回
        }
    }
}

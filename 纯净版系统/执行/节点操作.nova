// §2 节点操作

函数 DOM_创建节点(文档, 类型, 标签名, 标签ID) {
    定义 节点 = DOM节点 {}
    节点.ID = 文档.下一个ID
    文档.下一个ID = 文档.下一个ID + 1
    节点.类型 = 类型
    节点.标签名 = 标签名
    节点.标签ID = 标签ID
    节点.文本内容 = ""
    节点.属性 = []
    节点.子节点 = []
    节点.父节点 = 0
    节点.下一兄弟 = 0
    节点.样式 = []
    节点.事件 = []
    节点.脏 = 真

    追加(文档.节点池, 节点)
    文档.总节点数 = 文档.总节点数 + 1
    返回 节点
}

函数 DOM_添加子节点(文档, 父ID, 子节点) {
    定义 父 = DOM_查找节点(文档, 父ID)
    如果 (父 == 空) { 返回 }

    子节点.父节点 = 父ID

    // 设置兄弟链
    如果 (计数(父.子节点) > 0) {
        定义 最后子ID = 父.子节点[计数(父.子节点) - 1]
        定义 最后子 = DOM_查找节点(文档, 最后子ID)
        如果 (最后子 != 空) {
            最后子.下一兄弟 = 子节点.ID
        }
    }

    追加(父.子节点, 子节点.ID)
    父.脏 = 真
}

函数 DOM_查找节点(文档, ID) {
    定义 可变 i = 0
    当 (i < 计数(文档.节点池)) {
        如果 (文档.节点池[i].ID == ID) {
            返回 文档.节点池[i]
        }
        i = i + 1
    }
    返回 空
}

函数 DOM_设置属性(文档, 节点ID, 键, 值) {
    定义 节点 = DOM_查找节点(文档, 节点ID)
    如果 (节点 == 空) { 返回 }

    // 查找已有属性
    定义 可变 i = 0
    当 (i < 计数(节点.属性)) {
        如果 (节点.属性[i][0] == 键) {
            节点.属性[i][1] = 值
            节点.脏 = 真
            返回
        }
        i = i + 1
    }

    追加(节点.属性, [键, 值])
    节点.脏 = 真
}

函数 DOM_获取属性(文档, 节点ID, 键) {
    定义 节点 = DOM_查找节点(文档, 节点ID)
    如果 (节点 == 空) { 返回 "" }

    定义 可变 i = 0
    当 (i < 计数(节点.属性)) {
        如果 (节点.属性[i][0] == 键) {
            返回 节点.属性[i][1]
        }
        i = i + 1
    }
    返回 ""
}

// §3 HTML解析器 — 状态机驱动

函数 DOM_解析HTML(html, url) {
    定义 文档 = DOM_创建文档(url)

    定义 可变 状态 = 解析_数据
    定义 可变 位置 = 0
    定义 可变 文本缓冲 = ""
    定义 可变 标签缓冲 = ""
    定义 可变 属性名缓冲 = ""
    定义 可变 属性值缓冲 = ""
    定义 可变 当前属性 = []
    定义 可变 是闭合 = 假
    定义 可变 栈 = []         // 开放元素栈
    定义 长度 = 字符串长度(html)

    // 初始化: 创建html/head/body
    定义 html节点 = DOM_创建节点(文档, 节点_元素, "html", 标签_HTML)
    DOM_添加子节点(文档, 文档.根节点, html节点)
    文档.根节点 = html节点.ID
    追加(栈, html节点.ID)

    当 (位置 < 长度) {
        定义 c = 字符串子串(html, 位置, 1)

        如果 (状态 == 解析_数据) {
            如果 (c == "<") {
                // 处理累积的文本
                如果 (字符串长度(文本缓冲) > 0) {
                    定义 文本节点 = DOM_创建节点(文档, 节点_文本, "#text", 标签_UNKNOWN)
                    文本节点.文本内容 = 文本缓冲
                    如果 (计数(栈) > 0) {
                        DOM_添加子节点(文档, 栈[计数(栈) - 1], 文本节点)
                    }
                    文本缓冲 = ""
                }
                状态 = 解析_标签开始
                标签缓冲 = ""
                当前属性 = []
                是闭合 = 假
            } 否则 {
                文本缓冲 = 文本缓冲 + c
            }
        } 否则 如果 (状态 == 解析_标签开始) {
            如果 (c == "/") {
                是闭合 = 真
                状态 = 解析_标签名
            } 否则 如果 (c == "!") {
                // 注释或DOCTYPE
                状态 = 解析_注释
            } 否则 {
                标签缓冲 = c
                状态 = 解析_标签名
            }
        } 否则 如果 (状态 == 解析_标签名) {
            如果 (c == " " || c == "\t" || c == "\n") {
                状态 = 解析_属性名
                属性名缓冲 = ""
            } 否则 如果 (c == ">") {
                DOM_处理标签(文档, 标签缓冲, 当前属性, 是闭合, 栈)
                状态 = 解析_数据

                // script/style标签进入特殊模式
                如果 (!是闭合 && 标签缓冲 == "script") { 状态 = 解析_脚本 }
                如果 (!是闭合 && 标签缓冲 == "style") { 状态 = 解析_样式 }
                文本缓冲 = ""
            } 否则 如果 (c == "/") {
                // 自闭合标签 <br/>
            } 否则 {
                标签缓冲 = 标签缓冲 + c
            }
        } 否则 如果 (状态 == 解析_属性名) {
            如果 (c == "=") {
                状态 = 解析_属性值
                属性值缓冲 = ""
            } 否则 如果 (c == " " || c == "\t") {
                // 跳过空白
                如果 (字符串长度(属性名缓冲) > 0) {
                    追加(当前属性, [属性名缓冲, ""])
                    属性名缓冲 = ""
                }
            } 否则 如果 (c == ">") {
                如果 (字符串长度(属性名缓冲) > 0) {
                    追加(当前属性, [属性名缓冲, ""])
                }
                DOM_处理标签(文档, 标签缓冲, 当前属性, 是闭合, 栈)
                状态 = 解析_数据
                文本缓冲 = ""
            } 否则 如果 (c == "/") {
                // 自闭合
            } 否则 {
                属性名缓冲 = 属性名缓冲 + c
            }
        } 否则 如果 (状态 == 解析_属性值) {
            如果 (c == "\"" || c == "'") {
                // 进入引号模式 (简化: 读到下一个同引号)
                定义 引号 = c
                位置 = 位置 + 1
                当 (位置 < 长度) {
                    定义 vc = 字符串子串(html, 位置, 1)
                    如果 (vc == 引号) { 中断 }
                    属性值缓冲 = 属性值缓冲 + vc
                    位置 = 位置 + 1
                }
                追加(当前属性, [属性名缓冲, 属性值缓冲])
                属性名缓冲 = ""
                状态 = 解析_属性名
            } 否则 如果 (c == " " || c == ">") {
                追加(当前属性, [属性名缓冲, 属性值缓冲])
                属性名缓冲 = ""
                如果 (c == ">") {
                    DOM_处理标签(文档, 标签缓冲, 当前属性, 是闭合, 栈)
                    状态 = 解析_数据
                    文本缓冲 = ""
                } 否则 {
                    状态 = 解析_属性名
                }
            } 否则 {
                属性值缓冲 = 属性值缓冲 + c
            }
        } 否则 如果 (状态 == 解析_注释) {
            // 跳过注释和DOCTYPE直到 >
            如果 (c == ">") {
                状态 = 解析_数据
                文本缓冲 = ""
            }
        } 否则 如果 (状态 == 解析_脚本) {
            // 收集script内容直到 </script>
            文本缓冲 = 文本缓冲 + c
            如果 (字符串查找(文本缓冲, "</script>") >= 0) {
                定义 脚本内容 = 字符串子串(文本缓冲, 0, 字符串长度(文本缓冲) - 9)
                追加(文档.脚本列表, 脚本内容)
                文本缓冲 = ""
                状态 = 解析_数据
                // 弹出script节点
                如果 (计数(栈) > 0) {
                    定义 顶 = DOM_查找节点(文档, 栈[计数(栈) - 1])
                    如果 (顶 != 空 && 顶.标签ID == 标签_SCRIPT) {
                        列表_移除(栈, 计数(栈) - 1)
                    }
                }
            }
        } 否则 如果 (状态 == 解析_样式) {
            文本缓冲 = 文本缓冲 + c
            如果 (字符串查找(文本缓冲, "</style>") >= 0) {
                定义 样式内容 = 字符串子串(文本缓冲, 0, 字符串长度(文本缓冲) - 8)
                追加(文档.样式列表, 样式内容)
                文本缓冲 = ""
                状态 = 解析_数据
                如果 (计数(栈) > 0) {
                    定义 顶 = DOM_查找节点(文档, 栈[计数(栈) - 1])
                    如果 (顶 != 空 && 顶.标签ID == 标签_STYLE) {
                        列表_移除(栈, 计数(栈) - 1)
                    }
                }
            }
        }

        位置 = 位置 + 1
    }

    返回 文档
}

定义 可变 AI_节点操作_热节点缓存 = 0

函数 AI_节点操作_节点热度(节点, 操作类型) {
    如果 (操作类型 == "查询") { 返回 "缓存" }
    如果 (操作类型 == "修改") { AI_节点操作_热节点缓存 = 0; 返回 "失效" }
    返回 "普通"
}

函数 AI_节点操作_批量DOM优化(操作数) {
    如果 (操作数 > 100) { 返回 "延迟重排" }
    如果 (操作数 > 10) { 返回 "批量重排" }
    返回 "即时重排"
}

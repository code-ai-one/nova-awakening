    自检_断言("ccr有冲突总数", 字典取(ccr, "冲突总数") != 空)

    打印文本(字符串拼接("[自检] M7语义报告: ", 字符串拼接(转字符串(_自检_通过 - 基数), 字符串拼接("/", 字符串拼接(转字符串(_自检_总数 - 基数 - (_自检_失败)), " 通过")))))
}


// Nova · 运行时 · 游戏引擎 · 场景图
// 职责: 提供场景树结构、节点管理、变换传播
// 层级: M14 — 游戏引擎基础框架

// 节点类型

导入("../../标准库/基础.nova")

定义 节点_空         = 0
定义 节点_精灵       = 1
定义 节点_网格       = 2
定义 节点_相机       = 3
定义 节点_光源       = 4
定义 节点_碰撞体     = 5
定义 节点_音频源     = 6
定义 节点_UI元素     = 7

// 场景节点: [ID, 名称, 类型, 父ID, 子列表, 变换, 可见, 激活, 组件列表]
定义 可变 _场景_下个ID = 1

函数 场景图_场景节点_创建(名称, 类型) {
    定义 id = _场景_下个ID
    _场景_下个ID = _场景_下个ID + 1
    返回 [id, 名称, 类型, -1, [], [0, 0, 1, 1, 1, 0], 真, 真, []]
}

函数 节点_ID(n) { 返回 n[0] }
函数 节点_名称(n) { 返回 n[1] }
函数 场景_节点_类型(n) { 返回 n[2] }
函数 节点_父ID(n) { 返回 n[3] }
函数 节点_子列表(n) { 返回 n[4] }
函数 节点_变换(n) { 返回 n[5] }
函数 节点_可见(n) { 返回 n[6] }
函数 节点_激活(n) { 返回 n[7] }
函数 节点_组件(n) { 返回 n[8] }

// 变换: [x, y, z, sx, sy, sz, 旋转角]
函数 变换_位置(t) { 返回 [t[0], t[1], t[2]] }
函数 场景图_变换_缩放(t) { 返回 [t[3], t[4], t[5]] }
函数 变换_旋转(t) { 返回 t[6] }

函数 变换_设位置(t, x, y, z) { t[0] = x  t[1] = y  t[2] = z }
函数 变换_设缩放(t, sx, sy, sz) { t[3] = sx  t[4] = sy  t[5] = sz }
函数 变换_设旋转(t, 角) { t[6] = 角 }
函数 变换_移动(t, dx, dy, dz) { t[0] = t[0] + dx  t[1] = t[1] + dy  t[2] = t[2] + dz }

// 场景图: [根节点, 节点字典, 节点数]
函数 场景图_创建() {
    定义 根 = 场景图_场景节点_创建("根", 节点_空)
    定义 字典 = 字典()
    字典设(字典, 转字符串(节点_ID(根)), 根)
    返回 [根, 字典, 1]
}

函数 场景图_根(g) { 返回 g[0] }
函数 场景图_节点数(g) { 返回 g[2] }

函数 场景图_添加子节点(g, 父节点, 子节点) {
    子节点[3] = 节点_ID(父节点)
    追加(父节点[4], 节点_ID(子节点))
    字典设(g[1], 转字符串(节点_ID(子节点)), 子节点)
    g[2] = g[2] + 1
}

函数 场景图_查找(g, id) {
    返回 字典取(g[1], 转字符串(id))
}

// DFS遍历
函数 场景图_DFS(g, 节点, 回调) {
    回调(节点)
    定义 子列 = 节点_子列表(节点)
    定义 可变 i = 0
    当 (i < 计数(子列)) {
        定义 子 = 场景图_查找(g, 子列[i])
        如果 (子 != 空) { 场景图_DFS(g, 子, 回调) }
        i = i + 1
    }
}

// 变换传播: 父→子级联
函数 场景图_传播变换(g, 节点, 父变换) {
    定义 t = 节点_变换(节点)
    // 级联: 子位置 = 父位置 + 子局部位置 * 父缩放
    定义 世界x = 父变换[0] + t[0] * 父变换[3]
    定义 世界y = 父变换[1] + t[1] * 父变换[4]
    定义 世界z = 父变换[2] + t[2] * 父变换[5]
    定义 世界sx = 父变换[3] * t[3]
    定义 世界sy = 父变换[4] * t[4]
    定义 世界sz = 父变换[5] * t[5]
    定义 世界变换 = [世界x, 世界y, 世界z, 世界sx, 世界sy, 世界sz, t[6] + 父变换[6]]

    // 递归子节点
    定义 子列 = 节点_子列表(节点)
    定义 可变 i = 0
    当 (i < 计数(子列)) {
        定义 子 = 场景图_查找(g, 子列[i])
        如果 (子 != 空) { 场景图_传播变换(g, 子, 世界变换) }
        i = i + 1
    }
}

// 节点删除: 递归移除节点及其子树
函数 场景图_删除节点(g, id) {
    定义 节点 = 场景图_查找(g, id)
    如果 (节点 == 空) { 返回 0 }
    // 递归删除所有子节点
    定义 子列 = 节点_子列表(节点)
    定义 可变 i = 计数(子列) - 1
    当 (i >= 0) {
        场景图_删除节点(g, 子列[i])
        i = i - 1
    }
    // 从父节点的子列表中移除
    定义 父id = 节点_父ID(节点)
    如果 (父id >= 0) {
        定义 父 = 场景图_查找(g, 父id)
        如果 (父 != 空) {
            定义 父子列 = 节点_子列表(父)
            定义 可变 j = 0
            当 (j < 计数(父子列)) {
                如果 (父子列[j] == id) { 删除(父子列, j) 止 }
                j = j + 1
            }
        }
    }
    字典设(g[1], 转字符串(id), 空)
    g[2] = g[2] - 1
    返回 1
}

// 移动节点到新父节点下
函数 场景图_移动节点(g, 节点id, 新父id) {
    定义 节点 = 场景图_查找(g, 节点id)
    如果 (节点 == 空) { 返回 0 }
    定义 新父 = 场景图_查找(g, 新父id)
    如果 (新父 == 空) { 返回 0 }
    // 检测循环: 新父不能是节点的后代
    如果 (_是后代(g, 新父id, 节点id)) { 返回 0 }
    // 从旧父移除
    定义 旧父id = 节点_父ID(节点)
    如果 (旧父id >= 0) {
        定义 旧父 = 场景图_查找(g, 旧父id)
        如果 (旧父 != 空) {
            定义 旧子列 = 节点_子列表(旧父)
            定义 可变 i = 0
            当 (i < 计数(旧子列)) {
                如果 (旧子列[i] == 节点id) { 删除(旧子列, i) 止 }
                i = i + 1
            }
        }
    }
    // 挂到新父
    节点[3] = 新父id
    追加(新父[4], 节点id)
    返回 1
}

函数 _是后代(g, 查询id, 祖先id) {
    如果 (查询id == 祖先id) { 返回 真 }
    定义 祖先 = 场景图_查找(g, 祖先id)
    如果 (祖先 == 空) { 返回 假 }
    定义 子列 = 节点_子列表(祖先)
    定义 可变 i = 0
    当 (i < 计数(子列)) {
        如果 (_是后代(g, 查询id, 子列[i])) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// BFS遍历
函数 场景图_BFS(g, 起始节点, 回调) {
    定义 可变 队列 = [起始节点]
    定义 可变 头 = 0
    当 (头 < 计数(队列)) {
        定义 当前 = 队列[头]
        头 = 头 + 1
        回调(当前)
        定义 子列 = 节点_子列表(当前)
        定义 可变 i = 0
        当 (i < 计数(子列)) {
            定义 子 = 场景图_查找(g, 子列[i])
            如果 (子 != 空) { 追加(队列, 子) }
            i = i + 1
        }
    }
}

// 按名称搜索(支持子树递归)
函数 场景图_按名称查找(g, 名称) {
    定义 可变 结果 = []
    定义 键列 = 字典键(g[1])
    定义 可变 i = 0
    当 (i < 计数(键列)) {
        定义 节点 = 字典取(g[1], 键列[i])
        如果 (节点 != 空 且 字符串相等(节点_名称(节点), 名称)) {
            追加(结果, 节点)
        }
        i = i + 1
    }
    返回 结果
}

// 按类型过滤
函数 场景图_按类型查找(g, 类型) {
    定义 可变 结果 = []
    定义 键列 = 字典键(g[1])
    定义 可变 i = 0
    当 (i < 计数(键列)) {
        定义 节点 = 字典取(g[1], 键列[i])
        如果 (节点 != 空 且 场景_节点_类型(节点) == 类型) {
            追加(结果, 节点)
        }
        i = i + 1
    }
    返回 结果
}

// 层掩码过滤 (用于渲染/物理分层)
函数 节点_层掩码(n) {
    如果 (计数(n) > 9) { 返回 n[9] }
    返回 0xFFFF
}

函数 节点_设层掩码(n, 掩码) {
    当 (计数(n) <= 9) { 追加(n, 0) }
    n[9] = 掩码
}

函数 场景图_可见过滤(g, 层掩码) {
    定义 可变 结果 = []
    定义 键列 = 字典键(g[1])
    定义 可变 i = 0
    当 (i < 计数(键列)) {
        定义 节点 = 字典取(g[1], 键列[i])
        如果 (节点 != 空 且 节点_可见(节点) 且 (节点_层掩码(节点) & 层掩码) != 0) {
            追加(结果, 节点)
        }
        i = i + 1
    }
    返回 结果
}

// 脏标记变换传播 (避免每帧重算所有节点)
函数 节点_标脏(n) {
    当 (计数(n) <= 10) { 追加(n, 0) }
    n[10] = 1
}

函数 节点_是脏(n) {
    如果 (计数(n) > 10) { 返回 n[10] == 1 }
    返回 假
}

函数 节点_清脏(n) {
    如果 (计数(n) > 10) { n[10] = 0 }
}

函数 场景图_脏传播(g, 节点, 父变换) {
    如果 (节点_是脏(节点) == 假) { 返回 0 }
    定义 t = 节点_变换(节点)
    定义 世界x = 父变换[0] + t[0] * 父变换[3]
    定义 世界y = 父变换[1] + t[1] * 父变换[4]
    定义 世界z = 父变换[2] + t[2] * 父变换[5]
    定义 世界sx = 父变换[3] * t[3]
    定义 世界sy = 父变换[4] * t[4]
    定义 世界sz = 父变换[5] * t[5]
    定义 世界变换 = [世界x, 世界y, 世界z, 世界sx, 世界sy, 世界sz, t[6] + 父变换[6]]
    节点_清脏(节点)
    定义 子列 = 节点_子列表(节点)
    定义 可变 i = 0
    当 (i < 计数(子列)) {
        定义 子 = 场景图_查找(g, 子列[i])
        如果 (子 != 空) {
            节点_标脏(子)
            场景图_脏传播(g, 子, 世界变换)
        }
        i = i + 1
    }
    返回 1
}

// 场景节点计数统计 (按类型)
函数 场景图_统计(g) {
    定义 可变 统计 = [0, 0, 0, 0, 0, 0, 0, 0]
    定义 键列 = 字典键(g[1])
    定义 可变 i = 0
    当 (i < 计数(键列)) {
        定义 节点 = 字典取(g[1], 键列[i])
        如果 (节点 != 空) {
            定义 t = 场景_节点_类型(节点)
            如果 (t >= 0 且 t < 8) { 统计[t] = 统计[t] + 1 }
        }
        i = i + 1
    }
    返回 统计
}

// 场景报告
函数 场景图_打印(g) {
    打印("═══ 场景图报告 ═══")
    打印文本(字符串拼接("  节点总数: ", 转字符串(g[2])))
    _打印节点树(g,  g[0], 0)
}

函数 _打印节点树(g, 节点, 深度) {
    定义 可变 前缀 = ""
    定义 可变 d = 0
    当 (d < 深度) { 前缀 = 字符串拼接(前缀, "  ")  d = d + 1 }
    打印文本(字符串拼接(前缀, 字符串拼接(节点_名称(节点), 字符串拼接(" (", 字符串拼接(转字符串(场景_节点_类型(节点)), ")")))))
    定义 子列 = 节点_子列表(节点)
    定义 可变 i = 0
    当 (i < 计数(子列)) {
        定义 子 = 场景图_查找(g, 子列[i])
        如果 (子 != 空) { _打印节点树(g, 子, 深度 + 1) }
        i = i + 1
    }
}

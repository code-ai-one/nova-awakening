    网络_延迟总计 = 0
    网络_延迟样本 = 0
    网络_最大延迟 = 0
    网络_速率 = 0
    网络_速率窗口 = 0
    网络_峰值速率 = 0
    打印("[网络系统调用] 统计已重置")

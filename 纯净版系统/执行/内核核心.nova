函数 内核核心_命中测试(档, x, y) {
    定义 节点 = 渲染_命中测试(x, y)
    档.最近命中 = 节点
    如果 (节点 != 空 && 节点 != 0) {
        档.命中数 = 档.命中数 + 1
        核心总命中 = 核心总命中 + 1
    }
    返回 节点
}

函数 内核核心_渲染统计(档) {
    定义 统计 = 渲染_统计()

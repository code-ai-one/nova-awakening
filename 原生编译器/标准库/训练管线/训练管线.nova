导入("../基础.nova")

函数 数据加载器_创建(数据集, 批大小) { 返回 [数据集, 批大小, 0]
}

函数 数据加载器_下一批(loader) { 定义 数据 = loader[0]
 定义 bs = loader[1]
 定义 位置 = loader[2]
 定义 n = 计数(数据)
 如果 (位置 >= n) { loader[2] = 0
 返回 [] }
 定义 可变 批 = []
 定义 可变 i = 位置
 当 (i < 位置 + bs 且 i < n) { 追加(批, 数据[i])
 i = i + 1 }
 loader[2] = i
 返回 批
}

函数 数据加载器_重置(loader) { loader[2] = 0 }
函数 数据加载器_epoch完成(loader) { 返回 loader[2] >= 计数(loader[0]) }
函数 数据加载器_批数(loader) { 定义 n = 计数(loader[0])
 定义 bs = loader[1]
 如果 (bs == 0) { 返回 0 }
 返回 (n + bs - 1) / bs
}

// 洗牌 (Fisher-Yates简化, 0)
定义 训练_随机态 = 54321
函数 训练_随机() {
 训练_随机态 = 训练_随机态 ^ (训练_随机态 << 13)
 训练_随机态 = 训练_随机态 ^ (训练_随机态 >> 7)
 训练_随机态 = 训练_随机态 ^ (训练_随机态 << 17)
 如果 (训练_随机态 < 0) { 训练_随机态 = 0 - 训练_随机态 }
 返回 训练_随机态
}

函数 数据_洗牌(数据) { 定义 n = 计数(数据)
 定义 可变 i = n - 1
 当 (i > 0) { 定义 j = 训练_随机() % (i + 1)
 定义 临时 = 数据[i]
 数据[i] = 数据[j]
 数据[j] = 临时
 i = i - 1
 }
}

// 评估指标
函数 指标_准确率(预测, 标签) {
 定义 可变 i = 0
 当 (i < 计数(预测)) { 如果 (预测[i] == 标签[i]) { 正确 = 正确 + 1 }
 i = i + 1
 }
 如果 (计数(预测) == 0) { 返回 0 }
 返回 正确 * 100 / 计数(预测)
}

函数 指标_精确率(预测, 标签, 正类) { 定义 可变 TP = 0
 定义 可变 FP = 0
 定义 可变 i = 0
 当 (i < 计数(预测)) { 如果 (预测[i] == 正类) { 如果 (标签[i] == 正类) { TP = TP + 1 }
 否则 { FP = FP + 1 }
 }
 i = i + 1
 }
 如果 (TP + FP == 0) { 返回 0 }
 返回 TP * 100 / (TP + FP)
}

函数 指标_召回率(预测, 标签, 正类) { 定义 可变 TP = 0
 定义 可变 FN = 0
 定义 可变 i = 0
 当 (i < 计数(预测)) { 如果 (标签[i] == 正类) { 如果 (预测[i] == 正类) { TP = TP + 1 }
 否则 { FN = FN + 1 }
 }
 i = i + 1
 }
 如果 (TP + FN == 0) { 返回 0 }
 返回 TP * 100 / (TP + FN)
}

函数 指标_F1(精确, 召回) {
    如果 (精确 + 召回 == 0) { 返回 0
}
 返回 2 * 精确 * 召回 / (精确 + 召回)
}

函数 指标_MSE(预测, 标签) {
    如果 (计数(预测) == 0) { 返回 0
}
 返回 折叠(拉链(预测, 标签, (a, b) => (a - b) * (a - b)), 0, (s, d) => s + d) / 计数(预测)
}

// 早停
// 早停器: [最佳损失, 耐心, 当前计数, 最大耐心]
函数 早停_创建(耐心) { 返回 [0x7FFFFFFF, 耐心, 0, 耐心] }

函数 管线_早停_检查(es, 当前损失) { 如果 (当前损失 < es[0]) {
 es[0] = 当前损失
 es[2] = 0
 返回 假
 }
 es[2] = es[2] + 1
 返回 es[2] >= es[3]
}

函数 早停_最佳(es) { 返回 es[0] }

// EMA (指数移动平均)
函数 管线_EMA_创建(参数列表, 衰减) { 定义 可变 影子 = 复制列表(参数列表)
 返回 [影子, 衰减]
}

函数 管线_EMA_更新(ema, 参数列表) { 定义 可变 i = 0
 当 (i < 计数(参数列表)) {
 ema[0][i] = (ema[1] * ema[0][i] + (100 - ema[1]) * 参数列表[i]) / 100
 i = i + 1
 }
}

函数 EMA_获取(ema) { 返回 ema[0] }

// 训练日志
定义 可变 训练日志_metric = []

函数 管线_训练日志(轮次, 损失值, metric) {
 追加(训练日志_epoch, 轮次)
 追加(训练日志_loss, 损失值)
 追加(训练日志_metric, metric)
}

函数 训练日志_最近(n) { 定义 总数 = 计数(训练日志_epoch)
 定义 可变 起始 = 总数 - n
 如果 (起始 < 0) { 起始 = 0 }
 定义 可变 结果 = []
 当 (起始 < 总数) {
 追加(结果, [训练日志_epoch[起始], 训练日志_loss[起始], 训练日志_metric[起始]])
 起始 = 起始 + 1
 }
 返回 结果
}

// 梯度累积
函数 梯度累积_合并(梯度列表, 累积步数) {
    如果 (计数(梯度列表) == 0) { 返回 []
}
 定义 维度 = 计数(梯度列表[0])
 定义 可变 合并 = []
 定义 可变 d = 0
 当 (d < 维度) {
 追加(合并, 折叠(梯度列表, 0, (s, x) => s + x[d]) / 累积步数)
 d = d + 1
 }
 返回 合并
}

// 学习率调度
函数 训练管线_学习率_预热余弦(步长, 预热步, 总步, 基础lr) { 如果 (步长 < 预热步) { 返回 基础lr * 步长 / 预热步
 }
 定义 进度 = (步长 - 预热步) * 100 / (总步 - 预热步)
 // cos近似: 1 - 2*(x/100)^2 when x in [0,100]
 定义 余弦向量 = 100 - 2 * 进度 * 进度 / 100
 返回 基础lr * (100 + 余弦向量) / 200
}

// 梯度裁剪
函数 管线_梯度裁剪(梯度, 最大范数) { 定义 范数 = 整数sqrt(折叠(梯度, 0, (s, g) => s + g * g))
 如果 (范数 <= 最大范数) { 返回 梯度 }
 返回 映射(梯度, g => g * 最大范数 / 范数)
}

// 检查点
定义 可变 训练_检查点数据 = []
定义 可变 检查点_epoch = -1

函数 检查点_保存(参数, 轮次) {
 训练_检查点数据 = 复制列表(参数)
 检查点_epoch = 轮次
}

函数 检查点_加载() { 返回 训练_检查点数据 }
函数 检查点_epoch获取() { 返回 检查点_epoch }

// 训练循环
函数 训练_循环(总epochs, 训练函数, 验证函数) { 定义 可变 历史 = []
 定义 可变 e = 0
 当 (e < 总epochs) { 定义 训练损失 = 训练函数(e)
 定义 验证损失 = 验证函数(e)
 追加(历史, [e, 训练损失, 验证损失])
 e = e + 1
 }
 返回 历史
}

// 过拟合检测
函数 训练_过拟合检测(历史, 窗口) { 定义 n = 计数(历史)
 如果 (n < 窗口 + 1) { 返回 假 }
 定义 可变 验证上升 = 0
 定义 可变 i = n - 窗口
 当 (i < n) { 如果 (历史[i][2] > 历史[i - 1][2]) { 验证上升 = 验证上升 + 1 }
 i = i + 1
 }
 返回 验证上升 > 窗口 / 2
}

// §6 信任锚存储 — 内置根CA证书

// 内置根CA的SHA-256指纹 (部分常见CA)

定义 可变 信任锚_数量 = 0
定义 可变 信任锚_指纹 = 0   // [u8; 32]数组

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 X509_初始化信任锚() {
    // 从系统CA证书目录加载根CA证书
    定义 路径列表 = [
        "/etc/ssl/certs/ca-certificates.crt",
        "/etc/pki/tls/certs/ca-bundle.crt",
        "/etc/ssl/cert.pem",
        0
    ]
    定义 可变 i = 0
    当 (路径列表[i] != 0) {
        定义 大小指针 = 堆_分配(8)
        定义 数据 = 文件_读取(路径列表[i], 大小指针)
        定义 大小 = 内存_读64(大小指针)
        堆_释放(大小指针)
        如果 (数据 != 0 && 大小 > 0) {
            X509_加载PEM_CA束(数据, 大小)
            返回
        }
        i = i + 1
    }
}

函数 X509_加载PEM_CA束(数据, 大小) {
    // 解析PEM格式的CA证书束
    // 查找 "-----BEGIN CERTIFICATE-----" / "-----END CERTIFICATE-----" 对
    信任锚_指纹 = 堆_分配(256 * 32)  // 最多256个根CA
    信任锚_数量 = 0

    定义 begin_marker = "-----BEGIN CERTIFICATE-----"
    定义 end_marker = "-----END CERTIFICATE-----"
    定义 begin_len = 27
    定义 end_len = 25

    定义 可变 pos = 0
    当 (pos < 大小 && 信任锚_数量 < 256) {
        // 查找BEGIN
        定义 可变 found = 假
        当 (pos + begin_len <= 大小) {
            如果 (内存_比较(数据 + pos, begin_marker, begin_len) == 0) {
                found = 真
                pos = pos + begin_len
                跳出
            }
            pos = pos + 1
        }
        如果 (!found) { 跳出 }

        // 跳过换行
        当 (pos < 大小 && (内存_读8(数据 + pos) == 0x0A || 内存_读8(数据 + pos) == 0x0D)) { pos = pos + 1 }

        // 查找END
        定义 base64_start = pos
        当 (pos + end_len <= 大小) {
            如果 (内存_比较(数据 + pos, end_marker, end_len) == 0) { 跳出 }
            pos = pos + 1
        }
        定义 base64_end = pos

        // Base64解码 → DER
        如果 (base64_end <= base64_start) { pos = pos + end_len; 继续 }
        定义 der = 堆_分配(base64_end - base64_start)
        定义 der_len = Base64_解码(数据 + base64_start, base64_end - base64_start, der)

        // 计算SHA-256指纹并存储
        如果 (der_len > 0) {
            SHA256(der, der_len, 信任锚_指纹 + 信任锚_数量 * 32)
            信任锚_数量 = 信任锚_数量 + 1
        }
        堆_释放(der)
        pos = pos + end_len
    }
}

函数 X509_是信任锚(cert) {
    // 计算证书的SHA-256指纹并在信任锚中查找
    定义 digest = 堆_分配(32)
    SHA256(cert.der数据, cert.der长度, digest)

    定义 可变 i = 0
    当 (i < 信任锚_数量) {
        如果 (内存_比较(digest, 信任锚_指纹 + i * 32, 32) == 0) {
            堆_释放(digest)
            返回 真
        }
        i = i + 1
    }
    堆_释放(digest)
    返回 假
}

// Base64解码
函数 Base64_解码(输入, 输入长度, 输出) {
    定义 可变 out_pos = 0
    定义 可变 accum = 0
    定义 可变 bits = 0
    定义 可变 i = 0

    当 (i < 输入长度) {
        定义 ch = 内存_读8(输入 + i)
        i = i + 1
        定义 val = Base64_字符值(ch)
        如果 (val < 0) { 继续 }  // 跳过空白/换行

        accum = (accum << 6) | val
        bits = bits + 6

        如果 (bits >= 8) {
            bits = bits - 8
            内存_写8(输出 + out_pos, (accum >> bits) & 0xFF)
            out_pos = out_pos + 1
        }
    }
    返回 out_pos
}

函数 Base64_字符值(ch) {
    如果 (ch >= 0x41 && ch <= 0x5A) { 返回 ch - 0x41 }      // A-Z
    如果 (ch >= 0x61 && ch <= 0x7A) { 返回 ch - 0x61 + 26 }  // a-z
    如果 (ch >= 0x30 && ch <= 0x39) { 返回 ch - 0x30 + 52 }  // 0-9
    如果 (ch == 0x2B) { 返回 62 }  // +
    如果 (ch == 0x2F) { 返回 63 }  // /
    如果 (ch == 0x3D) { 返回 0 }   // = (padding)
    返回 -1  // 无效字符
}

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./文档节点.nova")
导入("./文档方法节.nova")



函数 节点_AI记录点击_基础(节点) {
    如果 (节点 == 0) { 返回 }
    节点.点击次数 = 节点.点击次数 + 1
    // 点击合算到父节点(父的可交互性提升)
    如果 (节点.父节点 != 0) {
        节点.父节点.点击次数 = 节点.父节点.点击次数 + 1
    }
}

函数 节点_AI记录悬停_基础(节点, 时长) {
    如果 (节点 == 0) { 返回 }
    节点.悬停总时长 = 节点.悬停总时长 + 时长
}

函数 节点_AI记录滚动经过(节点) {
    如果 (节点 == 0) { 返回 }
    节点.滚动经过次数 = 节点.滚动经过次数 + 1
    // 经常被滚过的内容 → 降低注意力权重
    如果 (节点.滚动经过次数 > 10 && 节点.点击次数 == 0) {
        节点.注意力权重 = 节点.注意力权重 / 2
    }
}

// §2 DOM Level 4 节点接口 — 属性访问
// (对应 节点 的各种 getter)

函数 节点_节点Type(节点) {
 返回 节点.节点类型
}

函数 节点_parent节点(节点) {
 返回 节点.父节点
}

函数 节点_parent元素(节点) {
 // DOM spec: parent元素返回父元素，如果父不是元素则返回null
 定义 父 = 节点.父节点
 如果 (父 != 0 && (父.节点标志 & 节点标志_是元素)) {
 返回 父
 }
 返回 0
}

函数 节点_firstChild(节点) {
 返回 节点.第一子节点
}

函数 节点_lastChild(节点) {
 返回 节点.最后子节点
}

函数 节点_previousSibling(节点) {
 返回 节点.前一兄弟
}

函数 节点_nextSibling(节点) {
 返回 节点.后一兄弟
}

函数 节点_child节点s_length(节点) {
 返回 节点.子节点数
}

函数 节点_ownerDocument(节点) {
 // DOM spec: ownerDocument = 节点所在的Document (Document自身返回null)
 如果 (节点.节点标志 & 节点标志_是文档) {
 返回 0
 }
 // 向上找TreeScope对应的Document
 返回 节点.树作用域
}

函数 节点_isConnected(节点) {
 返回 (节点.节点标志 & 节点标志_已连接) != 0
}

函数 节点_hasChild节点s(节点) {
 返回 节点.第一子节点 != 0
}

// §3 DOM树变更操作 — appendChild / insertBefore / removeChild / replaceChild
// (对应 Container节点 的 AppendChild/InsertBefore/RemoveChild)

函数 节点_appendChild(父节点, 新子) {
 // DOM spec §4.4.2: appendChild
 // 预校验
 如果 (父节点 == 0 || 新子 == 0) { 返回 0 }
 如果 (!(父节点.节点标志 & 节点标志_是容器节点)) { 返回 0 }

 // 不能把节点插入到自己的子树中(防循环)
 如果 (节点_是祖先(新子, 父节点)) { 返回 0 }

 // 如果新子已经有父节点，先从旧父中移除 (DOM spec: adopt)
 如果 (新子.父节点 != 0) {
 节点_removeChild(新子.父节点, 新子)
 }

 // 插入到子节点列表末尾
 新子.父节点 = 父节点
 新子.前一兄弟 = 父节点.最后子节点
 新子.后一兄弟 = 0

 如果 (父节点.最后子节点 != 0) {
 父节点.最后子节点.后一兄弟 = 新子
 } 否则 {
 父节点.第一子节点 = 新子
 }
 父节点.最后子节点 = 新子
 父节点.子节点数 = 父节点.子节点数 + 1

 // 增引用
 节点_增引用(新子)

 // 设置TreeScope继承
 如果 (父节点.树作用域 != 0) {
 节点_设置树作用域递归(新子, 父节点.树作用域)
 }

 // 如果父已连接到文档,则新子也连接
 如果 (父节点.节点标志 & 节点标志_已连接) {
 节点_设置已连接递归(新子)
 }

 // 标记需要样式重计算
 节点_标记子树样式脏(父节点)

 // 触发 MutationObserver / 变更事件
 节点_子节点变更通知(父节点, 新子, 0)

 返回 新子
}

函数 节点_insertBefore(父节点, 新子, 参考子) {
 // DOM spec §4.4.2: insertBefore(newChild, refChild)
 如果 (父节点 == 0 || 新子 == 0) { 返回 0 }
 如果 (!(父节点.节点标志 & 节点标志_是容器节点)) { 返回 0 }
 如果 (参考子 == 0) {
 返回 节点_appendChild(父节点, 新子)
 }

 // 验证参考子是父的直接子节点
 如果 (参考子.父节点 != 父节点) { 返回 0 }

 // 防循环
 如果 (节点_是祖先(新子, 父节点)) { 返回 0 }

 // 移除旧父
 如果 (新子.父节点 != 0) {
 节点_removeChild(新子.父节点, 新子)
 }

 // 插入到参考子之前
 新子.父节点 = 父节点
 新子.后一兄弟 = 参考子
 新子.前一兄弟 = 参考子.前一兄弟

 如果 (参考子.前一兄弟 != 0) {
 参考子.前一兄弟.后一兄弟 = 新子
 } 否则 {
 父节点.第一子节点 = 新子
 }
 参考子.前一兄弟 = 新子
 父节点.子节点数 = 父节点.子节点数 + 1

 节点_增引用(新子)

 如果 (父节点.树作用域 != 0) {
 节点_设置树作用域递归(新子, 父节点.树作用域)
 }
 如果 (父节点.节点标志 & 节点标志_已连接) {
 节点_设置已连接递归(新子)
 }

 节点_标记子树样式脏(父节点)
 节点_子节点变更通知(父节点, 新子, 0)

 返回 新子
}

函数 节点_removeChild(父节点, 旧子) {
 // DOM spec §4.4.2: removeChild
 如果 (父节点 == 0 || 旧子 == 0) { 返回 0 }
 如果 (旧子.父节点 != 父节点) { 返回 0 }

 // 通知变更(移除前)
 节点_子节点变更通知(父节点, 0, 旧子)

 // 从链表中摘除
 如果 (旧子.前一兄弟 != 0) {
 旧子.前一兄弟.后一兄弟 = 旧子.后一兄弟
 } 否则 {
 父节点.第一子节点 = 旧子.后一兄弟
 }

 如果 (旧子.后一兄弟 != 0) {
 旧子.后一兄弟.前一兄弟 = 旧子.前一兄弟
 } 否则 {
 父节点.最后子节点 = 旧子.前一兄弟
 }

 旧子.父节点 = 0
 旧子.前一兄弟 = 0
 旧子.后一兄弟 = 0
 父节点.子节点数 = 父节点.子节点数 - 1

 // 清除连接状态
 如果 (旧子.节点标志 & 节点标志_已连接) {
 节点_清除已连接递归(旧子)
 }

 // 分离布局对象
 如果 (旧子.节点标志 & 节点标志_有渲染对象) {
 节点_分离布局树递归(旧子)
 }

 节点_标记子树样式脏(父节点)
 节点_减引用(旧子)

 返回 旧子
}

函数 设置背景模式(dc, 模式) { _初始化图形()
 如果 (_函数_设背景模式 == 0) { _函数_设背景模式 = 获取函数(_图形32库, "SetBkMode") }
 调用指针(_函数_设背景模式,  dc,  模式, 0, 0, 0)
}

// 画笔样式常量
定义 画笔_实线 = 0
定义 画笔_虚线 = 1
定义 画笔_点线 = 2


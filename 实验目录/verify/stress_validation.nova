    如果 (!压力验证_断言((0 - 压力验证_首尾优势(策略_交叉)) >= 理论_交叉扫描最小增益(), 警告_高, "策略稳态 交叉扫描增益不足")) { 通过 = 假 }
    定义 演化_交叉 = [

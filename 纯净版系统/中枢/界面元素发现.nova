// NovaOS · AI GUI自动化引擎 (融合WebMCP + OpenClaw UI控制 + AIMaux视觉)
// 本地代码级UI理解 — 非截图! 直接读DOM/无障碍树/像素缓冲
// §1 UI元素发现: 从无障碍树/元素树直接读取所有可交互元素
// §2 精准点击/输入: 坐标计算→模拟鼠标/键盘事件(像素级精准)
// §3 元素定位策略: 文本匹配/角色匹配/坐标匹配/路径匹配
// §4 AI操作规划: 自然语言意图→UI操作序列
// §5 MCP工具协议: 标准化工具调用接口
// §6 页面状态感知: 实时DOM变更检测+等待条件
// §7 像素级验证: 直接读帧缓冲验证操作结果

导入("./日志中枢.nova")
导入("../推理/值乘.nova")
导入("./字符串替换.nova")
导入("../稳态/绘制引擎元.nova")
导入("../标准/原生字符串.nova")
导入("./内核打印.nova")

外部 元素_根节点

// §1 UI元素发现 — 代码级直读(非截图)

定义 最大发现元素 = 512

结构 UI元素 {
    元素ID,
    角色,    // 字符串 button/link/textbox/heading/list/...
    名称,    // 字符串 显示文本/标签
    值,    // 字符串 当前值(输入框内容等)
    中心x,
    中心y,
    左上x,
    左上y,
    宽,
    高,
    可点击,
    可输入,
    可见,
    已禁用,
    DOM路径,    // 字符串 body > div > button
    选择器,    // 字符串 元素选择器
}

定义 可变 已发现元素 = []
定义 可变 UI_扫描次数 = 0
定义 可变 UI_操作次数 = 0
定义 可变 UI_成功次数 = 0
定义 可变 UI_失败次数 = 0

函数 UI_扫描全部元素() {
    // 从无障碍树直接读取所有可交互元素(代码级, 非截图)
    已发现元素 = []
    如果 (元素_根节点 == 空) {
        内核调试("UI自动化: DOM根节点为空, 无法扫描")
        返回 []
    }
    UI_递归扫描(元素_根节点, "body", 0)
    UI_扫描次数 = UI_扫描次数 + 1
    返回 已发现元素
}

函数 UI_递归扫描(节点, 路径, 深度) {
    如果 (节点 == 空 || 计数(已发现元素) >= 最大发现元素) { 返回 }
    如果 (!节点.可见) { 返回 }

    定义 当前路径 = 路径 + " > " + UI_标签名(节点.标签)

    // 可交互元素: 生成UI元素描述
    如果 (节点.可交互 || 节点.无障碍角色 == "heading" || 节点.无障碍角色 == "img") {
        定义 elem = UI元素 {}
        elem.元素ID = 节点.节点ID
        elem.角色 = 节点.无障碍角色
        elem.名称 = 元素_提取文本(节点)
        elem.左上x = 节点.布局_x
        elem.左上y = 节点.布局_y
        elem.宽 = 节点.布局_宽
        elem.高 = 节点.布局_高
        elem.中心x = 节点.布局_x + 节点.布局_宽 / 2
        elem.中心y = 节点.布局_y + 节点.布局_高 / 2
        elem.可点击 = (节点.无障碍角色 == "button" || 节点.无障碍角色 == "link")
        elem.可输入 = (节点.无障碍角色 == "textbox" || 节点.无障碍角色 == "combobox")
        elem.可见 = 真
        elem.已禁用 = 假
        elem.DOM路径 = 当前路径
        追加(已发现元素, elem)
    }

    // 递归子节点
    定义 可变 i = 0
    当 (i < 计数(节点.子节点)) {
        UI_递归扫描(节点.子节点[i], 当前路径, 深度 + 1)
        i = i + 1
    }
}

函数 UI_标签名(标签) {
    如果 (标签 == 1) { 返回 "div" }
    如果 (标签 == 2) { 返回 "span" }
    如果 (标签 == 3) { 返回 "p" }
    如果 (标签 == 4) { 返回 "a" }
    如果 (标签 == 5) { 返回 "button" }
    如果 (标签 == 6) { 返回 "input" }
    如果 (标签 == 7) { 返回 "img" }
    如果 (标签 == 10) { 返回 "h1" }
    如果 (标签 == 11) { 返回 "h2" }
    如果 (标签 == 15) { 返回 "form" }
    如果 (标签 == 16) { 返回 "textarea" }
    如果 (标签 == 17) { 返回 "select" }
    如果 (标签 == 21) { 返回 "nav" }
    返回 "div"
}

// NAED理论 (Nova Accessible Element Discovery)
// 核心创新:
// 1. 无障碍树直读 — 代码级DOM/无障碍树遍历,非截图
// 2. 多策略元素匹配 — 文本/角色/属性/路径多维度查找
// 3. 交互能力检测 — 自动识别可点击/可输入/可拖拽元素
// 4. AI元素预测 — 智能预测目标元素位置和类型
// 5. 页面变更检测 — DOM变更观察+等待条件

定义 最大扫描深度 = 32
定义 匹配缓存大小 = 128
定义 DOM变更队列大小 = 64
定义 等待超时_毫秒 = 30000
定义 等待间隔_毫秒 = 200

定义 角色_按钮     = "button"
定义 角色_链接     = "link"
定义 角色_文本框   = "textbox"
定义 角色_组合框   = "combobox"
定义 角色_复选框   = "checkbox"
定义 角色_单选框   = "radio"
定义 角色_滑块     = "slider"
定义 角色_标题     = "heading"
定义 角色_图片     = "img"
定义 角色_列表     = "list"
定义 角色_列表项   = "listitem"
定义 角色_菜单     = "menu"
定义 角色_菜单项   = "menuitem"
定义 角色_导航     = "navigation"
定义 角色_选项卡   = "tab"

外部 全局AI总线

结构 匹配缓存项 {
    选择器,
    元素ID,
    命中次数,
    最后访问,
}

结构 DOM变更 {
    类型,        // u32 (0=添加, 1=删除, 2=修改, 3=属性变更)
    节点ID,
    时间戳,
}

结构 UI发现统计 {
    总扫描次数,
    总元素数,
    可点击元素数,
    可输入元素数,
    匹配查找次数,
    匹配命中次数,
    缓存命中次数,
    等待次数,
    等待超时次数,
    DOM变更次数,
    AI预测次数,
    AI预测命中数,
}

定义 可变 ui_匹配缓存 = []
定义 可变 ui_dom变更队列 = []
定义 可变 ui_统计 = UI发现统计 {}
定义 可变 ui_已初始化 = 假

函数 UI_初始化() {
    如果 (ui_已初始化) { 返回 }
    ui_匹配缓存 = []
    ui_dom变更队列 = []
    ui_统计 = UI发现统计 {}
    ui_已初始化 = 真
}

// §2 多策略元素匹配 — 文本/角色/属性/路径/组合

// NAED匹配策略码
定义 匹配_文本     = 0x01
定义 匹配_角色     = 0x02
定义 匹配_属性     = 0x04
定义 匹配_路径     = 0x08
定义 匹配_坐标     = 0x10
定义 匹配_正则     = 0x20

函数 UI_缓存查找(选择器文本) {
    定义 可变 i = 0
    当 (i < 计数(ui_匹配缓存)) {
        如果 (ui_匹配缓存[i].选择器 == 选择器文本) {
            ui_匹配缓存[i].命中次数 = ui_匹配缓存[i].命中次数 + 1
            ui_匹配缓存[i].最后访问 = 系统_时钟()
            ui_统计.缓存命中次数 = ui_统计.缓存命中次数 + 1
            返回 ui_匹配缓存[i].元素ID
        }
        i = i + 1
    }
    返回 -1
}

函数 UI_缓存写入(选择器文本, 元素ID值) {
    // 淘汰最久未访问
    如果 (计数(ui_匹配缓存) >= 匹配缓存大小) {
        定义 可变 最旧索引 = 0
        定义 可变 最旧时间 = ui_匹配缓存[0].最后访问
        定义 可变 k = 1
        当 (k < 计数(ui_匹配缓存)) {
            如果 (ui_匹配缓存[k].最后访问 < 最旧时间) {
                最旧时间 = ui_匹配缓存[k].最后访问
                最旧索引 = k
            }
            k = k + 1
        }
        删除(ui_匹配缓存, 最旧索引)
    }
    定义 项 = 匹配缓存项 {}
    项.选择器 = 选择器文本
    项.元素ID = 元素ID值
    项.命中次数 = 1
    项.最后访问 = 系统_时钟()
    追加(ui_匹配缓存, 项)
}

函数 UI_按文本查找(文本, 精确匹配) {
    ui_统计.匹配查找次数 = ui_统计.匹配查找次数 + 1
    // 先查缓存
    定义 缓存ID = UI_缓存查找("文本:" + 文本)
    如果 (缓存ID >= 0) {
        返回 UI_按ID获取(缓存ID)
    }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(已发现元素)) {
        定义 匹配 = 假
        如果 (精确匹配) {
            匹配 = (已发现元素[i].名称 == 文本)
        } 否则 {
            匹配 = 字符串_包含(已发现元素[i].名称, 文本)
        }
        如果 (匹配) {
            追加(结果, 已发现元素[i])
            ui_统计.匹配命中次数 = ui_统计.匹配命中次数 + 1
            UI_缓存写入("文本:" + 文本, 已发现元素[i].元素ID)
        }
        i = i + 1
    }
    返回 结果
}

函数 UI_按角色查找(角色名称) {
    ui_统计.匹配查找次数 = ui_统计.匹配查找次数 + 1
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(已发现元素)) {
        如果 (已发现元素[i].角色 == 角色名称) {
            追加(结果, 已发现元素[i])
            ui_统计.匹配命中次数 = ui_统计.匹配命中次数 + 1
        }
        i = i + 1
    }
    返回 结果
}

函数 UI_按路径查找(路径片段) {
    ui_统计.匹配查找次数 = ui_统计.匹配查找次数 + 1
    定义 缓存ID = UI_缓存查找("路径:" + 路径片段)
    如果 (缓存ID >= 0) {
        返回 UI_按ID获取(缓存ID)
    }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(已发现元素)) {
        如果 (字符串_尾部匹配(已发现元素[i].DOM路径, 路径片段)) {
            追加(结果, 已发现元素[i])
            ui_统计.匹配命中次数 = ui_统计.匹配命中次数 + 1
            UI_缓存写入("路径:" + 路径片段, 已发现元素[i].元素ID)
        }
        i = i + 1
    }
    返回 结果
}

函数 UI_按坐标查找(x, y, 半径) {
    ui_统计.匹配查找次数 = ui_统计.匹配查找次数 + 1
    定义 可变 最近元素 = 空
    定义 可变 最近距离 = 999999
    定义 可变 i = 0
    当 (i < 计数(已发现元素)) {
        定义 dx = 已发现元素[i].中心x - x
        定义 dy = 已发现元素[i].中心y - y
        定义 距离平方 = dx * dx + dy * dy
        如果 (距离平方 <= 半径 * 半径) {
            如果 (距离平方 < 最近距离) {
                最近距离 = 距离平方
                最近元素 = 已发现元素[i]
            }
        }
        i = i + 1
    }
    如果 (最近元素 != 空) {
        ui_统计.匹配命中次数 = ui_统计.匹配命中次数 + 1
    }
    返回 最近元素
}

函数 UI_按ID获取(目标ID) {
    定义 可变 i = 0
    当 (i < 计数(已发现元素)) {
        如果 (已发现元素[i].元素ID == 目标ID) {
            返回 已发现元素[i]
        }
        i = i + 1
    }
    返回 空
}

函数 UI_组合匹配(文本, 角色, 路径, 策略掩码) {
    ui_统计.匹配查找次数 = ui_统计.匹配查找次数 + 1
    定义 可变 最优元素 = 空
    定义 可变 最高分 = 0
    定义 可变 i = 0
    当 (i < 计数(已发现元素)) {
        定义 可变 分数 = 0
        // 文本匹配(权重3)
        如果 (策略掩码 & 匹配_文本) {
            如果 (字符串_包含(已发现元素[i].名称, 文本)) {
                分数 = 分数 + 3
                如果 (已发现元素[i].名称 == 文本) {
                    分数 = 分数 + 2  // 精确加分
                }
            }
        }
        // 角色匹配(权重2)
        如果 (策略掩码 & 匹配_角色) {
            如果 (已发现元素[i].角色 == 角色) {
                分数 = 分数 + 2
            }
        }
        // 路径匹配(权重1)
        如果 (策略掩码 & 匹配_路径) {
            如果 (字符串_包含(已发现元素[i].DOM路径, 路径)) {
                分数 = 分数 + 1
            }
        }
        如果 (分数 > 最高分) {
            最高分 = 分数
            最优元素 = 已发现元素[i]
        }
        i = i + 1
    }
    如果 (最优元素 != 空) {
        ui_统计.匹配命中次数 = ui_统计.匹配命中次数 + 1
    }
    返回 最优元素
}

// §3 交互能力检测 — 自动识别可点击/可输入/可拖拽

// NAED交互类型码
定义 交互_可点击   = 0x01
定义 交互_可输入   = 0x02
定义 交互_可拖拽   = 0x04
定义 交互_可滚动   = 0x08
定义 交互_可选择   = 0x10
定义 交互_可展开   = 0x20

函数 UI_检测交互类型(元素) {
    如果 (元素 == 空) { 返回 0 }
    定义 可变 类型 = 0
    // 可点击判定: button/link/menuitem/tab + 非禁用
    如果 (!元素.已禁用) {
        如果 (元素.角色 == 角色_按钮 || 元素.角色 == 角色_链接 ||
            元素.角色 == 角色_菜单项 || 元素.角色 == 角色_选项卡) {
            类型 = 类型 | 交互_可点击
            ui_统计.可点击元素数 = ui_统计.可点击元素数 + 1
        }
    }
    // 可输入判定: textbox/combobox
    如果 (元素.角色 == 角色_文本框 || 元素.角色 == 角色_组合框) {
        类型 = 类型 | 交互_可输入
        ui_统计.可输入元素数 = ui_统计.可输入元素数 + 1
    }
    // 可选择判定: checkbox/radio
    如果 (元素.角色 == 角色_复选框 || 元素.角色 == 角色_单选框) {
        类型 = 类型 | 交互_可选择
    }
    // 可拖拽判定: 具有draggable属性
    如果 (元素_属性读(元素.元素ID, "draggable") == "true") {
        类型 = 类型 | 交互_可拖拽
    }
    // 可滚动判定: 滚动区域
    如果 (元素_属性读(元素.元素ID, "scrollable") == "true") {
        类型 = 类型 | 交互_可滚动
    }
    // 可展开判定: 含子菜单/手风琴
    如果 (元素_属性读(元素.元素ID, "aria-expanded") != "") {
        类型 = 类型 | 交互_可展开
    }
    返回 类型
}

函数 UI_批量标注交互() {
    定义 可变 交互表 = []
    定义 可变 i = 0
    当 (i < 计数(已发现元素)) {
        定义 类型 = UI_检测交互类型(已发现元素[i])
        如果 (类型 > 0) {
            追加(交互表, { 元素ID: 已发现元素[i].元素ID, 交互类型: 类型 })
        }
        i = i + 1
    }
    内核调试("UI交互标注: " + 计数(交互表) + "个可交互元素")
    返回 交互表
}

函数 UI_检测可见性(元素) {
    如果 (元素 == 空) { 返回 假 }
    // 基本检查: 尺寸>0 且 可见标志
    如果 (元素.宽 <= 0 || 元素.高 <= 0) { 返回 假 }
    如果 (!元素.可见) { 返回 假 }
    // 视口裁剪检测: 元素是否在当前视口内
    定义 视口宽 = 系统_视口宽()
    定义 视口高 = 系统_视口高()
    如果 (元素.左上x + 元素.宽 < 0 || 元素.左上x > 视口宽) { 返回 假 }
    如果 (元素.左上y + 元素.高 < 0 || 元素.左上y > 视口高) { 返回 假 }
    // 遮挡检测: 中心点命中测试
    定义 顶层ID = 元素_命中测试(元素.中心x, 元素.中心y)
    如果 (顶层ID != 元素.元素ID) {
        // 被其他元素遮挡
        返回 假
    }
    返回 真
}

// §4 等待条件系统 — 智能等待元素出现/变更

// 等待条件类型
定义 等待_元素存在   = 0
定义 等待_元素可见   = 1
定义 等待_元素可交互 = 2
定义 等待_文本出现   = 3
定义 等待_元素消失   = 4
定义 等待_DOM稳定   = 5

结构 等待条件 {
    类型,
    选择器,
    目标文本,
    超时毫秒,
    间隔毫秒,
}

函数 UI_等待条件(条件) {
    ui_统计.等待次数 = ui_统计.等待次数 + 1
    定义 开始时间 = 系统_时钟()
    定义 可变 已过时间 = 0
    当 (已过时间 < 条件.超时毫秒) {
        // 每轮重新扫描
        UI_扫描全部元素()
        定义 满足 = UI_检查等待条件(条件)
        如果 (满足) {
            内核调试("等待条件满足, 耗时" + 已过时间 + "ms")
            返回 真
        }
        系统_休眠(条件.间隔毫秒)
        已过时间 = 系统_时钟() - 开始时间
    }
    ui_统计.等待超时次数 = ui_统计.等待超时次数 + 1
    内核调试("等待超时: " + 条件.超时毫秒 + "ms")
    返回 假
}

函数 UI_检查等待条件(条件) {
    如果 (条件.类型 == 等待_元素存在) {
        定义 结果 = UI_按文本查找(条件.选择器, 假)
        返回 (计数(结果) > 0)
    }
    如果 (条件.类型 == 等待_元素可见) {
        定义 结果 = UI_按文本查找(条件.选择器, 假)
        如果 (计数(结果) > 0) {
            返回 UI_检测可见性(结果[0])
        }
        返回 假
    }
    如果 (条件.类型 == 等待_元素可交互) {
        定义 结果 = UI_按文本查找(条件.选择器, 假)
        如果 (计数(结果) > 0) {
            返回 (UI_检测交互类型(结果[0]) > 0)
        }
        返回 假
    }
    如果 (条件.类型 == 等待_文本出现) {
        定义 结果 = UI_按文本查找(条件.目标文本, 假)
        返回 (计数(结果) > 0)
    }
    如果 (条件.类型 == 等待_元素消失) {
        定义 结果 = UI_按文本查找(条件.选择器, 假)
        返回 (计数(结果) == 0)
    }
    如果 (条件.类型 == 等待_DOM稳定) {
        返回 (计数(ui_dom变更队列) == 0)
    }
    返回 假
}

函数 UI_等待元素出现(文本, 超时) {
    定义 条件 = 等待条件 {}
    条件.类型 = 等待_元素存在
    条件.选择器 = 文本
    条件.超时毫秒 = 超时
    条件.间隔毫秒 = 等待间隔_毫秒
    返回 UI_等待条件(条件)
}

函数 UI_等待元素可交互(文本, 超时) {
    定义 条件 = 等待条件 {}
    条件.类型 = 等待_元素可交互
    条件.选择器 = 文本
    条件.超时毫秒 = 超时
    条件.间隔毫秒 = 等待间隔_毫秒
    返回 UI_等待条件(条件)
}

函数 UI_等待DOM稳定(超时) {
    定义 条件 = 等待条件 {}
    条件.类型 = 等待_DOM稳定
    条件.超时毫秒 = 超时
    条件.间隔毫秒 = 等待间隔_毫秒
    返回 UI_等待条件(条件)
}

// §5 DOM变更观察 — 实时检测页面变化

定义 可变 dom_观察回调 = 空

函数 UI_注册DOM观察(回调函数) {
    dom_观察回调 = 回调函数
    内核调试("DOM变更观察已注册")
}

// 由内核事件系统调用的变更通知入口
函数 UI_DOM变更通知(类型码, 节点ID值) {
    定义 变更 = DOM变更 {}
    变更.类型 = 类型码
    变更.节点ID = 节点ID值
    变更.时间戳 = 系统_时钟()
    // 环形队列写入
    如果 (计数(ui_dom变更队列) >= DOM变更队列大小) {
        删除(ui_dom变更队列, 0)
    }
    追加(ui_dom变更队列, 变更)
    ui_统计.DOM变更次数 = ui_统计.DOM变更次数 + 1
    // 回调通知
    如果 (dom_观察回调 != 空) {
        dom_观察回调(变更)
    }
}

函数 UI_获取最近变更(最大数量) {
    定义 可变 结果 = []
    定义 总数 = 计数(ui_dom变更队列)
    定义 可变 起始 = 总数 - 最大数量
    如果 (起始 < 0) { 起始 = 0 }
    定义 可变 i = 起始
    当 (i < 总数) {
        追加(结果, ui_dom变更队列[i])
        i = i + 1
    }
    返回 结果
}

函数 UI_变更类型统计() {
    定义 可变 添加数 = 0
    定义 可变 删除数 = 0
    定义 可变 修改数 = 0
    定义 可变 属性变更数 = 0
    定义 可变 i = 0
    当 (i < 计数(ui_dom变更队列)) {
        如果 (ui_dom变更队列[i].类型 == 0) { 添加数 = 添加数 + 1 }
        如果 (ui_dom变更队列[i].类型 == 1) { 删除数 = 删除数 + 1 }
        如果 (ui_dom变更队列[i].类型 == 2) { 修改数 = 修改数 + 1 }
        如果 (ui_dom变更队列[i].类型 == 3) { 属性变更数 = 属性变更数 + 1 }
        i = i + 1
    }
    返回 { 添加: 添加数, 删除: 删除数, 修改: 修改数, 属性变更: 属性变更数 }
}

// §6 AI元素预测 — 基于特征向量的智能定位

// NAED-AI特征维度
定义 AI_特征维度 = 12

函数 UI_AI元素预测(意图描述, 上下文元素列表) {
    如果 (全局AI总线 == 空) {
        内核调试("AI总线未就绪, 回退常规匹配")
        返回 UI_按文本查找(意图描述, 假)
    }
    ui_统计.AI预测次数 = ui_统计.AI预测次数 + 1
    // 构建特征向量: [角色编码, 位置x, 位置y, 宽, 高, 可点击, 可输入, 文本长度, 深度, DOM层级, 可见, 交互类型]
    定义 张量 = Tensor_创建(AI_特征维度)
    定义 可变 最佳元素 = 空
    定义 可变 最高置信度 = 0.0
    定义 可变 i = 0
    当 (i < 计数(上下文元素列表)) {
        定义 元素 = 上下文元素列表[i]
        Tensor_写(张量, 0, UI_角色编码(元素.角色))
        Tensor_写(张量, 1, 元素.中心x)
        Tensor_写(张量, 2, 元素.中心y)
        Tensor_写(张量, 3, 元素.宽)
        Tensor_写(张量, 4, 元素.高)
        Tensor_写(张量, 5, 元素.可点击)
        Tensor_写(张量, 6, 元素.可输入)
        Tensor_写(张量, 7, 字符串_长度(元素.名称))
        Tensor_写(张量, 8, 字符串_计数(元素.DOM路径, ">"))
        Tensor_写(张量, 9, 元素.可见)
        Tensor_写(张量, 10, UI_检测交互类型(元素))
        Tensor_写(张量, 11, 字符串_相似度(元素.名称, 意图描述))
        // AI推理
        定义 置信度 = AI总线_推理(全局AI总线, "element_predict", 张量)
        如果 (置信度 > 最高置信度) {
            最高置信度 = 置信度
            最佳元素 = 元素
        }
        i = i + 1
    }
    Tensor_释放(张量)
    如果 (最佳元素 != 空 && 最高置信度 > 0.6) {
        ui_统计.AI预测命中数 = ui_统计.AI预测命中数 + 1
        内核调试("AI预测命中: 置信度=" + 最高置信度)
    }
    返回 最佳元素
}

函数 UI_角色编码(角色名) {
    如果 (角色名 == 角色_按钮)   { 返回 1 }
    如果 (角色名 == 角色_链接)   { 返回 2 }
    如果 (角色名 == 角色_文本框) { 返回 3 }
    如果 (角色名 == 角色_组合框) { 返回 4 }
    如果 (角色名 == 角色_复选框) { 返回 5 }
    如果 (角色名 == 角色_单选框) { 返回 6 }
    如果 (角色名 == 角色_滑块)   { 返回 7 }
    如果 (角色名 == 角色_标题)   { 返回 8 }
    如果 (角色名 == 角色_图片)   { 返回 9 }
    如果 (角色名 == 角色_菜单)   { 返回 10 }
    如果 (角色名 == 角色_菜单项) { 返回 11 }
    如果 (角色名 == 角色_导航)   { 返回 12 }
    如果 (角色名 == 角色_选项卡) { 返回 13 }
    返回 0
}

函数 UI_AI异常检测() {
    如果 (全局AI总线 == 空) { 返回 [] }
    定义 可变 异常列表 = []
    定义 张量 = Tensor_创建(4)
    定义 可变 i = 0
    当 (i < 计数(已发现元素)) {
        定义 元素 = 已发现元素[i]
        Tensor_写(张量, 0, 元素.宽)
        Tensor_写(张量, 1, 元素.高)
        Tensor_写(张量, 2, 元素.中心x)
        Tensor_写(张量, 3, 元素.中心y)
        定义 异常分 = AI总线_异常检测(全局AI总线, "ui_anomaly", 张量)
        如果 (异常分 > 0.8) {
            追加(异常列表, { 元素: 元素, 异常分: 异常分 })
        }
        i = i + 1
    }
    Tensor_释放(张量)
    返回 异常列表
}

// §7 MCP工具协议 — 标准化UI操作接口

函数 MCP_UI_扫描() {
    UI_扫描全部元素()
    返回 {
        成功: 真,
        元素数: 计数(已发现元素),
        元素列表: 已发现元素
    }
}

函数 MCP_UI_查找(参数) {
    定义 策略 = 参数.策略
    如果 (策略 == "文本") {
        返回 { 成功: 真, 结果: UI_按文本查找(参数.查询, 参数.精确) }
    }
    如果 (策略 == "角色") {
        返回 { 成功: 真, 结果: UI_按角色查找(参数.查询) }
    }
    如果 (策略 == "路径") {
        返回 { 成功: 真, 结果: UI_按路径查找(参数.查询) }
    }
    如果 (策略 == "坐标") {
        返回 { 成功: 真, 结果: UI_按坐标查找(参数.x, 参数.y, 参数.半径) }
    }
    如果 (策略 == "组合") {
        返回 { 成功: 真, 结果: UI_组合匹配(参数.文本, 参数.角色, 参数.路径, 参数.掩码) }
    }
    如果 (策略 == "AI") {
        返回 { 成功: 真, 结果: UI_AI元素预测(参数.意图, 已发现元素) }
    }
    返回 { 成功: 假, 错误: "未知匹配策略: " + 策略 }
}

函数 MCP_UI_等待(参数) {
    定义 结果 = UI_等待元素出现(参数.选择器, 参数.超时)
    返回 { 成功: 结果, 耗时: 参数.超时 }
}

函数 MCP_UI_交互检测(参数) {
    定义 元素 = UI_按ID获取(参数.元素ID)
    如果 (元素 == 空) {
        返回 { 成功: 假, 错误: "元素不存在" }
    }
    定义 交互类型 = UI_检测交互类型(元素)
    返回 {
        成功: 真,
        可点击: (交互类型 & 交互_可点击) > 0,
        可输入: (交互类型 & 交互_可输入) > 0,
        可拖拽: (交互类型 & 交互_可拖拽) > 0,
        可滚动: (交互类型 & 交互_可滚动) > 0,
        可选择: (交互类型 & 交互_可选择) > 0,
        可展开: (交互类型 & 交互_可展开) > 0
    }
}

// §8 诊断统计 — 完整运行时数据

函数 UI_获取统计() {
    返回 ui_统计
}

函数 UI_重置统计() {
    ui_统计 = UI发现统计 {}
    内核调试("UI发现统计已重置")
}

函数 UI_打印诊断() {
    内核调试("═══ NAED UI元素发现诊断 ═══")
    内核调试("  总扫描次数: " + ui_统计.总扫描次数)
    内核调试("  发现元素数: " + ui_统计.总元素数)
    内核调试("  可点击元素: " + ui_统计.可点击元素数)
    内核调试("  可输入元素: " + ui_统计.可输入元素数)
    内核调试("  匹配查找: " + ui_统计.匹配查找次数 + " 命中: " + ui_统计.匹配命中次数)
    定义 可变 命中率 = 0
    如果 (ui_统计.匹配查找次数 > 0) {
        命中率 = ui_统计.匹配命中次数 * 100 / ui_统计.匹配查找次数
    }
    内核调试("  匹配命中率: " + 命中率 + "%")
    内核调试("  缓存命中: " + ui_统计.缓存命中次数)
    内核调试("  等待次数: " + ui_统计.等待次数 + " 超时: " + ui_统计.等待超时次数)
    内核调试("  DOM变更: " + ui_统计.DOM变更次数)
    内核调试("  AI预测: " + ui_统计.AI预测次数 + " 命中: " + ui_统计.AI预测命中数)
    定义 可变 AI命中率 = 0
    如果 (ui_统计.AI预测次数 > 0) {
        AI命中率 = ui_统计.AI预测命中数 * 100 / ui_统计.AI预测次数
    }
    内核调试("  AI预测命中率: " + AI命中率 + "%")
    内核调试("  缓存条目数: " + 计数(ui_匹配缓存))
    内核调试("  DOM变更队列: " + 计数(ui_dom变更队列))
    内核调试("═══════════════════════════")
}

函数 UI_健康检查() {
    定义 可变 问题 = []
    // 检查缓存占用率
    如果 (计数(ui_匹配缓存) > 匹配缓存大小 * 90 / 100) {
        追加(问题, "缓存接近上限")
    }
    // 检查匹配命中率
    如果 (ui_统计.匹配查找次数 > 10) {
        定义 命中率 = ui_统计.匹配命中次数 * 100 / ui_统计.匹配查找次数
        如果 (命中率 < 30) {
            追加(问题, "匹配命中率过低(" + 命中率 + "%)")
        }
    }
    // 检查超时率
    如果 (ui_统计.等待次数 > 5) {
        定义 超时率 = ui_统计.等待超时次数 * 100 / ui_统计.等待次数
        如果 (超时率 > 50) {
            追加(问题, "等待超时率过高(" + 超时率 + "%)")
        }
    }
    // 检查AI预测
    如果 (ui_统计.AI预测次数 > 5) {
        定义 AI率 = ui_统计.AI预测命中数 * 100 / ui_统计.AI预测次数
        如果 (AI率 < 40) {
            追加(问题, "AI预测命中率偏低(" + AI率 + "%)")
        }
    }
    返回 { 健康: 计数(问题) == 0, 问题列表: 问题 }
}

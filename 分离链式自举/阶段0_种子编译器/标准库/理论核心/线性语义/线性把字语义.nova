导入("../../基础.nova")

// 【原创理论基础】
// 中文语法有三种资源操作句式, 它们恰好对应线性逻辑的三种核心连接词:
// 把字句: "把 X 给 Y" → 线性消费 (Linear: 恰好用一次, 然后X不再可用)
// 被字句: "X 被 Y 处理" → 仿射消费 (Affine: 最多用一次, 可以不用)
// 给字句: "给 Y 一个 X" → 直觉消费 (Intuitionistic: 用任意次)
// 数学对应关系:
// 把 ≅ ⊗ (线性张量, multiplicative conjunction)
// 被 ≅ ⅋ (仿射并, multiplicative disjunction)
// 给 ≅ ! (指数模态, exponential modality)
// 这构成了一个完整的中文线性逻辑:
// Γ 把 A ⊢ B (在上下文Γ中, 消费A得到B)
// Γ ⊢ A 被 B (在上下文Γ中, A被B所消费)
// Γ 给 !A ⊢ B (在上下文Γ中, 可复用A得到B)
// 与Rust所有权的本质区别:
// - Rust的所有权是编译器规则, 把字语义是自然语言语法
// - Rust需要生命周期标注, 把字语义通过句法结构自动推导
// - 把字句的"把"本身就是消费标记, 不需要额外语法
// - 被字句表达"被动接受", 允许资源未被使用(仿射)
// - 给字句表达"复制给予", 资源可多次使用(指数)
// 关键创新: 资源的线性性不是通过类型标注, 而是通过句法动词推导:
// "把文件关闭" → 文件被线性消费, 之后不可用
// "读取文件" → 文件被借用, 之后仍可用
// "复制文件给X" → 文件被复制, 原件和副本都可用

// 资源状态定义
定义 资源_活跃 = 0 // 资源存在且可用
定义 资源_已消费 = 1 // 资源已被"把"字消费, 不可再用
定义 资源_已借出 = 2 // 资源被借出(读取中), 不可写
定义 资源_已转移 = 3 // 资源所有权已转移, 不可用
定义 资源_可复用 = 4 // "给"字语义: 可无限复用

// 资源描述符
// [资源id, 状态, 所有者, 借用者列表, 值, 创建位置, 消费位置]
函数 资源_创建(id, 值, 所有者) { 返回 [id, 资源_活跃, 所有者, [], 值,]
}

函数 资源_id(r) { 返回 r[0] }
函数 资源_状态(r) { 返回 r[1] }
函数 资源_所有者(r) { 返回 r[2] }
函数 资源_借用者(r) { 返回 r[3] }
函数 资源_值(r) { 返回 r[4] }

// "把"字操作 (线性消费)
// "把 资源 动作" → 消费资源, 资源之后不可再用

函数 把(资源, 动作名) { 如果 (资源_状态(资源) == 资源_已消费) { 返回 ["错误", "把字语义违规: 资源已被消费, 不可再'把'"]
 }
 如果 (资源_状态(资源) == 资源_已转移) { 返回 ["错误", "把字语义违规: 资源已转移, 不可再'把'"]
 }
 如果 (资源_状态(资源) == 资源_已借出) { 返回 ["错误", "把字语义违规: 资源正被借出, 不可消费"]
 }
 // 线性消费: 标记资源为已消费
 资源[1] = 资源_已消费
 资源[6] = 动作名
 返回 ["成功", 资源_值(资源)]
}

// "被"字操作 (仿射借用)
// "资源 被 动作" → 资源被被动借用, 之后可以继续存在

函数 被(资源, 动作名) { 如果 (资源_状态(资源) == 资源_已消费) { 返回 ["错误", "被字语义违规: 资源已被消费"]
 }
 如果 (资源_状态(资源) == 资源_已转移) { 返回 ["错误", "被字语义违规: 资源已转移"]
 }
 // 仿射借用: 添加借用者, 资源仍然存在
 追加(资源[3], 动作名)
 返回 ["成功", 资源_值(资源)]
}

// "给"字操作 (指数复制)
// "给 目标 资源" → 复制资源给目标, 原件不变

函数 给(资源, 目标) { 如果 (资源_状态(资源) == 资源_已消费) { 返回 ["错误", "给字语义违规: 资源已被消费, 不可复制"]
 }
 // 指数复制: 创建副本
 定义 副本 = 资源_创建(字符串拼接(转字符串(资源_id(资源)), "_副本"), 资源_值(资源), 目标)
 副本[1] = 资源_可复用
 返回 ["成功", 副本]
}

// "让"字操作 (所有权转移)
// "让 目标 拥有 资源" → 所有权从当前所有者转移到目标

函数 让(资源, 新所有者) { 如果 (资源_状态(资源) != 资源_活跃) { 返回 ["错误", "让字语义违规: 只有活跃资源可以转移所有权"]
 }
 如果 (计数(资源_借用者(资源)) > 0) { 返回 ["错误", "让字语义违规: 资源还有借用者, 不可转移"]
 }
 资源[2] = 新所有者
 返回 ["成功", 资源]
}

// 资源上下文 (线性类型环境)
// 追踪所有资源的状态, 确保线性性

函数 线性上下文_创建() { 返回 [[], 0] // [资源列表, 下一个id]
}

函数 线性上下文_分配(上下文, 值, 所有者) { 定义 id = 上下文[1]
 上下文[1] = 上下文[1] + 1
 定义 资源 = 资源_创建(id, 值, 所有者)
 追加(上下文[0], 资源)
 返回 资源
}

// 作用域结束时检查: 所有资源必须被消费或转移
函数 线性上下文_检查(上下文) { 定义 可变 泄漏 = []
 定义 可变 i = 0
 当 (i < 计数(上下文[0])) { 定义 r = 上下文[0][i]
 如果 (资源_状态(r) == 资源_活跃) {
 // 资源未被消费也未被转移 → 线性性违规
 追加(泄漏, 资源_id(r))
 }
 i = i + 1
 }
 返回 泄漏
}

// 句法分析: 从中文句式推导资源操作

// 判断动词的资源消费模式
定义 可变 消费动词表 = []
定义 可变 借用动词表 = []
定义 可变 复制动词表 = []

函数 线性语义_初始化() {
 // 消费动词 (把字操作): 执行后资源不可再用
 消费动词表 = ["关闭", "删除", "释放", "销毁", "发送", "写入", "提交"]
 // 借用动词 (被字操作): 只读访问
 借用动词表 = ["读取", "查看", "检查", "遍历", "搜索", "比较", "打印"]
 // 复制动词 (给字操作): 产生副本
 复制动词表 = ["复制", "克隆", "序列化", "备份", "缓存", "广播"]
}

函数 推导_动词模式(动词) { 定义 可变 i = 0
 当 (i < 计数(消费动词表)) { 如果 (消费动词表[i] == 动词) { 返回 "把" }
 i = i + 1
 }
 i = 0
 当 (i < 计数(借用动词表)) { 如果 (借用动词表[i] == 动词) { 返回 "被" }
 i = i + 1
 }
 i = 0
 当 (i < 计数(复制动词表)) { 如果 (复制动词表[i] == 动词) { 返回 "给" }
 i = i + 1
 }
 返回 "个" // 默认: 无特殊资源语义
}

// 线性性证明
// 证明一段代码满足线性资源约束

// 证明项: [命题, 证据, 是否有效]
函数 线性证明_创建(命题) { 返回 [命题, [], 1]
}

函数 线性证明_添加步骤(证明, 步骤) {
 追加(证明[1], 步骤)
}

函数 线性证明_标记失败(证明, 原因) {
 证明[2] = 0
 追加(证明[1], 字符串拼接("失败: ", 原因))
}

函数 线性证明_有效(证明) { 返回 证明[2]
}

// 验证一组操作序列的线性性
函数 验证线性性(操作序列) { 定义 证明 = 线性证明_创建("操作序列线性性")
 定义 上下文 = 线性上下文_创建()
 定义 可变 i = 0
 当 (i < 计数(操作序列)) { 定义 操作 = 操作序列[i]
 定义 类型 = 操作[0]
 如果 (类型 == "创建") {
 线性上下文_分配(上下文, 操作[1], 操作[2])
 线性证明_添加步骤(证明, "创建资源")
 }
 如果 (类型 == "消费") {
 线性证明_添加步骤(证明, "消费资源(把字)")
 }
 i = i + 1
 }
 定义 泄漏 = 线性上下文_检查(上下文)
 如果 (计数(泄漏) > 0) {
 线性证明_标记失败(证明, "存在未消费的资源")
 }
 返回 证明
}

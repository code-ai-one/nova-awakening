    编号:       u64,            // i_ino: Nova文件节点号
    模式:       u32,            // i_mode: 类型(高4位) + 权限(低12位)
    uid:        u32,            // i_uid
    gid:        u32,            // i_gid
    大小:       u64,            // i_size: 文件大小(字节)
    块数:       u64,            // i_blocks: 512字节块数
    块位移:     u8,             // i_blkbits: 块大小位移(通常12=4KB)
    链接数:     u32,            // i_nlink: 硬链接数
    访问时间秒: u64,            // i_atime_sec
    修改时间秒: u64,            // i_mtime_sec (数据修改)
    变更时间秒: u64,            // i_ctime_sec (元数据变更)
    访问时间纳秒: u32,
    修改时间纳秒: u32,
    变更时间纳秒: u32,
    设备号:     u64,            // i_rdev
    i_op:       Nova文件节点操作表,    // Nova文件节点操作(lookup/mkdir/unlink...)
    i_fop:      文件操作表,     // 文件操作(read/write/llseek...)
    超级块:     u64,            // i_sb
    引用计数:   u32,            // i_count: 打开引用
    脏:         布尔,           // I_DIRTY
    正在写回:   布尔,           // I_WRITEBACK
    已释放:     布尔,           // I_FREEING
    锁:         自旋锁,         // i_lock
    哈希链:     u64,            // i_hash: Nova文件节点缓存哈希链
    LRU链:      u64,            // i_lru: LRU淘汰链
    超级块链:   u64,            // i_sb_list
    映射:       u64,            // i_mapping → address_space
    私有数据:   u64             // i_private: FS专用数据
}

// Nova文件节点缓存 
// 用(超级块, ino)做哈希键快速查找

定义 Nova文件节点_HASH_BITS = 12
定义 Nova文件节点_HASH_SIZE = 4096     // 1 << 12
定义 可变 Nova文件节点哈希表 = 空
定义 可变 Nova文件节点_LRU = 空        // 未使用Nova文件节点的LRU链
定义 可变 Nova文件节点_LRU数 = 0
定义 可变 下一个Nova文件节点号 = 1
定义 可变 Nova文件节点总数 = 0
定义 可变 Nova文件节点_Nova块缓存缓存 = 空   // kmem_cache for Nova文件节点

函数 Nova文件节点缓存_初始化() {
    Nova文件节点哈希表 = 哈希表_创建(Nova文件节点_HASH_SIZE)
    Nova文件节点_LRU = 链表_创建()
    // Nova文件节点_Nova块缓存缓存 = kmem_cache_create("Nova文件节点_cache", Nova文件节点结构大小, 64, Nova块缓存_HWCACHE_ALIGN)
    内核信息("Nova文件节点缓存初始化")
}

函数 Nova文件节点哈希键(超级块, 编号) {
    返回 (超级块 * 31 + 编号) % Nova文件节点_HASH_SIZE
}

// Nova文件节点创建与分配 

函数 Nova文件节点_分配() {
    // 从Nova块缓存缓存分配Nova文件节点结构
    定义 可变 节点 = Nova文件节点 {}
    节点.编号 = 下一个Nova文件节点号
    下一个Nova文件节点号 = 下一个Nova文件节点号 + 1
    节点.引用计数 = 1
    节点.链接数 = 0
    节点.脏 = 假
    节点.正在写回 = 假
    节点.已释放 = 假
    节点.锁 = 自旋锁_创建()
    节点.块位移 = 12   // 4KB块
    Nova文件节点总数 = Nova文件节点总数 + 1
    返回 节点
}

函数 Nova文件节点_创建(类型_和_权限, 额外权限) {
    定义 可变 节点 = Nova文件节点_分配()
    节点.模式 = 类型_和_权限 | 额外权限
    节点.链接数 = 1
    // 设置时间戳为当前时间
    定义 当前时间 = 系统时间_获取秒()
    节点.访问时间秒 = 当前时间
    节点.修改时间秒 = 当前时间
    节点.变更时间秒 = 当前时间
    返回 节点

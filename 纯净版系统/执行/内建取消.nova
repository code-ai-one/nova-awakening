函数 内建_unset(参数) {
    定义 可变 i = 1
    当 (i < 计数(参数)) {
        环境_删除(参数[i])
        i = i + 1
    }
    返回 0
}

// help: 显示帮助

函数 内建_help(参数) {
    如果 (计数(参数) > 1) {
        // help <command>: 显示特定命令帮助
        定义 cmd = 参数[1]
        如果 (cmd == "cd")     { 打印行("cd [-] [目录]  — 改变当前目录"); 返回 0 }
        如果 (cmd == "echo")   { 打印行("echo [-n] [-e] [文本...]  — 输出文本"); 返回 0 }
        如果 (cmd == "export") { 打印行("export [变量=值...]  — 设置/导出环境变量"); 返回 0 }
        如果 (cmd == "history"){ 打印行("history [-c] [n]  — 显示/清除命令历史"); 返回 0 }
        打印行("龙壳: help: " + cmd + ": 无帮助信息")
        返回 1
    }
    打印行("龙壳 (Dragon终端) — NovaOS原生终端")
    打印行("内建命令:")
    打印行("  cd [目录]         改变工作目录")
    打印行("  pwd               显示当前目录")
    打印行("  echo [-n] [文本]  输出文本")
    打印行("  export [变量=值]  导出环境变量")
    打印行("  unset 变量        删除环境变量")
    打印行("  history           命令历史")
    打印行("  type 命令         显示命令类型")
    打印行("  alias 名=命令     定义别名")
    打印行("  jobs              显示后台任务")
    打印行("  fg [%n]           将任务放到前台")
    打印行("  bg [%n]           在后台继续任务")
    打印行("  kill [-信号] pid  发送信号")
    打印行("  read 变量         读取用户输入")
    打印行("  test 表达式       条件测试")
    打印行("  source 文件       执行脚本文件")
    打印行("  exit [码]         退出终端")
    返回 0
}

// history: 历史管理

函数 内建_history(参数) {
    如果 (计数(参数) > 1 && 参数[1] == "-c") {
        历史_清除()
        返回 0
    }
    历史_显示()
    返回 0
}

// type: 显示命令类型 

函数 内建_type(参数) {
    如果 (计数(参数) <= 1) { 打印行("用法: type 命令名"); 返回 1 }
    定义 可变 i = 1
    当 (i < 计数(参数)) {
        定义 名称 = 参数[i]
        如果 (别名_查找(名称) != 空) {
            打印行(名称 + " 是 `" + 别名_查找(名称) + "` 的别名")
        } 否则 如果 (是内建命令(名称)) {
            打印行(名称 + " 是终端内建命令")
        } 否则 {
            定义 路径 = 查找可执行文件(名称)
            如果 (路径 != 空) {
                打印行(名称 + " 是 " + 路径)
            } 否则 {
                打印行("龙壳: type: " + 名称 + ": 未找到")
            }
        }
        i = i + 1
    }
    返回 0
}

// alias/unalias: 命令别名

定义 可变 别名表 = 字典()

函数 内建_alias(参数) {
    如果 (计数(参数) <= 1) {
        // 显示所有别名
        别名_显示全部()
        返回 0
    }
    定义 可变 i = 1
    当 (i < 计数(参数)) {
        定义 等号位 = 字符串索引(参数[i], "=")
        如果 (等号位 >= 0) {
            定义 名 = 字符串子串(参数[i], 0, 等号位)
            定义 值 = 字符串子串(参数[i], 等号位 + 1, 字符串长度(参数[i]))
            字典设(别名表, 名, 值)
        } 否则 {
            定义 值 = 别名_查找(参数[i])
            如果 (值 != 空) { 打印行("alias " + 参数[i] + "='" + 值 + "'") }
            否则 { 打印行("龙壳: alias: " + 参数[i] + ": 未找到") }
        }
        i = i + 1
    }
    返回 0
}

函数 内建_unalias(参数) {
    定义 可变 i = 1
    当 (i < 计数(参数)) {
        字典设(别名表, 参数[i], 空)
        i = i + 1
    }
    返回 0
}

函数 别名_查找(名称) { 返回 字典_取或默认(别名表, 名称, 空) }
函数 别名_显示全部() { 字典_遍历(别名表, 别名_打印项) }
函数 别名_打印项(键, 值) { 打印行("alias " + 键 + "='" + 值 + "'") }

// jobs/fg/bg: 作业控制

函数 内建_jobs(参数) {
    任务_列表()
    返回 0
}

函数 内建_fg(参数) {
    定义 可变 任务号 = 0
    如果 (计数(参数) > 1) {
        定义 arg = 参数[1]
        如果 (字符串取字符(arg, 0) == "%") {
            任务号 = 字符串转整数(字符串子串(arg, 1, 字符串长度(arg)))
        } 否则 {
            任务号 = 字符串转整数(arg)
        }
    }
    定义 pid = 任务_获取PID(任务号)
    如果 (pid <= 0) { 打印行("龙壳: fg: 无此任务"); 返回 1 }

    // 发送SIGCONT恢复(如果已暂停)
    sys_kill(pid, 18, 0, 0, 0, 0)   // SIGCONT=18
    任务_设置状态(任务号, 任务状态_前台)

    // 等待前台完成
    定义 状态 = [0]
    sys_wait4(pid, 状态, 0, 空, 0, 0)
    任务_移除(任务号)
    返回 (状态[0] >> 8) & 0xFF
}

函数 内建_bg(参数) {
    定义 可变 任务号 = 0
    如果 (计数(参数) > 1) {
        定义 arg = 参数[1]
        如果 (字符串取字符(arg, 0) == "%") {
            任务号 = 字符串转整数(字符串子串(arg, 1, 字符串长度(arg)))
        } 否则 {
            任务号 = 字符串转整数(arg)
        }
    }
    定义 pid = 任务_获取PID(任务号)
    如果 (pid <= 0) { 打印行("龙壳: bg: 无此任务"); 返回 1 }

    sys_kill(pid, 18, 0, 0, 0, 0)   // SIGCONT
    任务_设置状态(任务号, 任务状态_运行)
    返回 0
}

函数 内建_wait(参数) {
    如果 (计数(参数) > 1) {
        定义 pid = 字符串转整数(参数[1])
        定义 状态 = [0]
        sys_wait4(pid, 状态, 0, 空, 0, 0)
        返回 (状态[0] >> 8) & 0xFF
    }
    // wait无参数: 等待所有后台任务
    任务_等待全部()
    返回 0
}

// kill: 发送信号
// kill [-信号] pid

函数 内建_kill(参数) {
    如果 (计数(参数) <= 1) { 打印行("用法: kill [-信号] pid"); 返回 1 }

    定义 可变 信号 = 15    // 默认SIGTERM
    定义 可变 pid_idx = 1

    如果 (字符串取字符(参数[1], 0) == "-") {
        定义 sig_str = 字符串子串(参数[1], 1, 字符串长度(参数[1]))
        信号 = 字符串转整数(sig_str)
        pid_idx = 2
    }

    如果 (pid_idx >= 计数(参数)) { 打印行("龙壳: kill: 缺少pid"); 返回 1 }
    定义 pid = 字符串转整数(参数[pid_idx])
    返回 sys_kill(pid, 信号, 0, 0, 0, 0)
}

定义 可变 AI_内建取消_调用数 = 0
定义 可变 AI_内建取消_异常数 = 0

函数 AI_内建取消_监控() {
    AI_内建取消_调用数 = AI_内建取消_调用数 + 1
    返回 AI_内建取消_异常数 == 0
}

函数 AI_内建取消_健康检查() {
    如果 (AI_内建取消_调用数 > 0 && AI_内建取消_异常数 * 100 / AI_内建取消_调用数 > 10) {
        返回 假
    }
    返回 真
}

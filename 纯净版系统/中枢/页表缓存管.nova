// NovaOS TLB管理
// 职责: TLB刷新操作 (invlpg / CR3重载 / PCID)

外部 发送IPI
外部 获取CPU数量

定义 可变 TLB_单页刷新次数 = 0
定义 可变 TLB_全局刷新次数 = 0
定义 可变 TLB_范围刷新次数 = 0

定义 可变 PCID_已启用 = 假
定义 可变 PCID_下一个 = 1     // PCID 0保留给内核
定义 PCID_最大值 = 4096       // x86-64支持12位PCID

// 基础TLB刷新操作

// 刷新单个虚拟地址的TLB条目
函数 TLB_刷新单页(虚拟地址) {
    // x86 invlpg指令
    汇编 {
        "mov rdi, [rbp-8]"    // rdi = 虚拟地址
        "invlpg [rdi]"
    }
    TLB_单页刷新次数 = TLB_单页刷新次数 + 1
}

// 刷新全部TLB (重新加载CR3)
函数 TLB_刷新全部() {
    汇编 {
        "mov rax, cr3"
        "mov cr3, rax"        // 重载CR3刷新所有非Global TLB
    }
    TLB_全局刷新次数 = TLB_全局刷新次数 + 1
}

// 刷新全部TLB包括Global页
函数 TLB_刷新全部_含全局() {
    // 临时清除CR4.PGE, 然后恢复
    汇编 {
        "mov rax, cr4"
        "mov rcx, rax"
        "and rax, ~(1 << 7)"  // 清除PGE位
        "mov cr4, rax"
        "mov cr4, rcx"        // 恢复PGE, 触发全TLB刷新
    }
    TLB_全局刷新次数 = TLB_全局刷新次数 + 1
}

// 范围刷新

// 刷新虚拟地址范围的TLB
函数 TLB_刷新范围(起始, 结束) {
    定义 页数 = (对齐到页(结束 - 起始)) / 页大小
    // 如果页数太多, 直接全刷更快
    如果 (页数 > 32) {
        TLB_刷新全部()
        返回
    }
    定义 可变 地址 = 起始 & ~0xFFF
    当 (地址 < 结束) {
        TLB_刷新单页(地址)
        地址 = 地址 + 页大小
    }
    TLB_范围刷新次数 = TLB_范围刷新次数 + 1
}

// PCID管理 (进程上下文标识符, 避免进程切换时全刷TLB)

函数 PCID_初始化() {
    // 检查CPU是否支持PCID (CPUID.01H:ECX[17])
    定义 ecx = CPUID查询(1, 0)[2]
    如果 ((ecx & (1 << 17)) != 0) {
        // 启用PCID: 设置CR4.PCIDE
        汇编 {
            "mov rax, cr4"
            "or rax, (1 << 17)"
            "mov cr4, rax"
        }
        PCID_已启用 = 真
        内核信息("TLB: PCID已启用")
    } 否则 {
        内核信息("TLB: CPU不支持PCID, 使用传统刷新")
    }
}

// 分配PCID给进程
函数 PCID_分配() {
    如果 (!PCID_已启用) { 返回 0 }
    定义 pcid = PCID_下一个
    PCID_下一个 = PCID_下一个 + 1
    如果 (PCID_下一个 >= PCID_最大值) {
        PCID_下一个 = 1  // 回绕, 0保留给内核
    }
    返回 pcid
}

// 带PCID的CR3切换 (进程切换时调用)
函数 TLB_切换地址空间(pml4_物理, pcid) {
    如果 (PCID_已启用 && pcid > 0) {
        // CR3的低12位存放PCID
        // bit 63 = 1表示不刷新TLB (INVPCID)
        定义 cr3值 = pml4_物理 | pcid
        汇编 {
            "mov rax, [rbp-8]"   // cr3值
            "mov cr3, rax"
        }
    } 否则 {
        // 无PCID, 直接切换CR3 (会刷新TLB)
        汇编 {
            "mov rax, [rbp-8]"   // pml4_物理
            "mov cr3, rax"
        }
    }
}

// 使某个PCID的所有TLB条目无效
函数 TLB_无效化PCID(pcid) {
    如果 (!PCID_已启用) { 返回 }
    // INVPCID指令, 类型1: 无效化指定PCID的所有条目
    // invpcid rax, [rcx]  需要128位描述符 [pcid, 地址]
    TLB_刷新全部()
}

// 统计

函数 TLB_统计信息() {
    返回 [TLB_单页刷新次数, TLB_全局刷新次数, TLB_范围刷新次数, PCID_已启用]
}

// SMP TLB shootdown 
// 多核环境下通知其他CPU刷新TLB

定义 可变 TLB_IPI发送次数 = 0

函数 TLB_刷新_其他CPU(起始, 结束, cpu_mask) {
    // 向cpu_mask中的每个CPU发送IPI
    定义 cpu数 = 获取CPU数量()
    定义 当前cpu = 获取当前CPU()

    定义 可变 i = 0
    当 (i < cpu数) {
        如果 (i != 当前cpu && bitmap_测试(cpu_mask, i)) {
            // 发送TLB shootdown IPI
            发送IPI(i, IPI_TLB_FLUSH)
            TLB_IPI发送次数 = TLB_IPI发送次数 + 1
        }
        i = i + 1
    }
}

定义 IPI_TLB_FLUSH = 0xFD  // TLB shootdown IPI向量号

// IPI处理函数 (在目标CPU上执行)
函数 TLB_IPI处理(起始, 结束) {
    如果 (起始 == 0 && 结束 == 0) {
        TLB_刷新全部()
    } 否则 {
        TLB_刷新范围(起始, 结束)
    }
}

// 惰性TLB模式 
// 内核线程不需要用户态页表, 可延迟TLB刷新

定义 可变 TLB_惰性模式 = 假

函数 TLB_进入惰性模式() {
    TLB_惰性模式 = 真
}

函数 TLB_退出惰性模式() {
    如果 (TLB_惰性模式) {
        TLB_惰性模式 = 假
        TLB_刷新全部()  // 退出惰性模式时刷新
    }
}

函数 TLB_是惰性模式() { 返回 TLB_惰性模式 }

// 页面映射变更通知

函数 TLB_通知_页面映射(虚拟地址) {
    TLB_刷新单页(虚拟地址)
}

函数 TLB_通知_页表释放(起始, 结束) {
    TLB_刷新范围(起始, 结束)
}

函数 TLB_通知_进程退出(pcid) {
    如果 (PCID_已启用 && pcid > 0) {
        TLB_无效化PCID(pcid)
    }
}

// 完整统计

函数 TLB_完整统计() {
    返回 [TLB_单页刷新次数, TLB_全局刷新次数, TLB_范围刷新次数,
           TLB_IPI发送次数, PCID_已启用, PCID_下一个, TLB_惰性模式]
}

// TLB总刷新次数

函数 TLB_总刷新次数() {
    返回 TLB_单页刷新次数 + TLB_全局刷新次数 + TLB_范围刷新次数
}

定义 可变 AI_页表缓存管_运行指标 = 0
定义 可变 AI_页表缓存管_异常指标 = 0

函数 AI_页表缓存管_自诊断() {
    AI_页表缓存管_运行指标 = TLB_单页刷新次数
    返回 AI_页表缓存管_运行指标
}

函数 AI_页表缓存管_优化建议() {
    定义 指标 = AI_页表缓存管_自诊断()
    如果 (AI_页表缓存管_运行指标 > 10000) { 返回 "页表缓存管负载较高" }
    返回 "页表缓存管状态正常"
}

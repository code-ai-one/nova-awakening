导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/整数转字符串.nova")

定义 TOP_排序_CPU = 0
定义 TOP_排序_内存 = 1
定义 TOP_排序_PID = 2
定义 TOP_排序_时间 = 3

定义 TOP_默认延迟 = 3
定义 TOP_默认显示数 = 20

结构 进程信息 {
    PID,
    用户,
    优先级,
    NICE值,
    虚拟内存,
    驻留内存,
    共享内存,
    状态,
    CPU百分比,
    内存百分比,
    时间,
    命令,
}

结构 系统概要 {
    运行时间秒,
    用户数,
    负载1分钟,
    负载5分钟,
    负载15分钟,
    总进程,
    运行进程,
    睡眠进程,
    停止进程,
    僵尸进程,
    CPU用户,
    CPU系统,
    CPU空闲,
    CPU等待,
    内存总量,
    内存已用,
    内存空闲,
    内存缓存,
    交换总量,
    交换已用,
    交换空闲,
}

函数 top_main(参数) {
    定义 可变 刷新次数 = 0
    定义 可变 延迟秒 = TOP_默认延迟
    定义 可变 排序方式 = TOP_排序_CPU
    定义 可变 批处理 = 假
    定义 可变 显示线程 = 假
    定义 可变 显示数 = TOP_默认显示数
    定义 可变 过滤用户 = ""

    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 a = 参数[i]
        如果 (a == "-n" && i + 1 < 计数(参数)) { i = i + 1; 刷新次数 = 字符串转整数(参数[i]) }
        否则 如果 (a == "-d" && i + 1 < 计数(参数)) { i = i + 1; 延迟秒 = 字符串转整数(参数[i]) }
        否则 如果 (a == "-b") { 批处理 = 真 }
        否则 如果 (a == "-H") { 显示线程 = 真 }
        否则 如果 (a == "-u" && i + 1 < 计数(参数)) { i = i + 1; 过滤用户 = 参数[i] }
        否则 如果 (a == "-o" && i + 1 < 计数(参数)) {
            i = i + 1
            如果 (参数[i] == "cpu" || 参数[i] == "%CPU") { 排序方式 = TOP_排序_CPU }
            否则 如果 (参数[i] == "mem" || 参数[i] == "%MEM") { 排序方式 = TOP_排序_内存 }
            否则 如果 (参数[i] == "pid" || 参数[i] == "PID") { 排序方式 = TOP_排序_PID }
            否则 如果 (参数[i] == "time" || 参数[i] == "TIME+") { 排序方式 = TOP_排序_时间 }
        }
        否则 如果 (a == "--help" || a == "-h") { top_显示帮助(); 返回 0 }
        i = i + 1
    }

    定义 可变 已刷新 = 0
    当 (刷新次数 == 0 || 已刷新 < 刷新次数) {
        如果 (!批处理 && 已刷新 > 0) {
            标准输出("\x1b[H\x1b[2J")
        }
        top_显示(排序方式, 显示数, 过滤用户)
        已刷新 = 已刷新 + 1
        如果 (刷新次数 > 0 && 已刷新 >= 刷新次数) { 跳出 }
        跳出
    }
    返回 0
}

函数 top_显示帮助() {
    打印行("用法: top [选项]")
    打印行("选项:")
    打印行("  -n N      刷新N次后退出")
    打印行("  -d N      刷新延迟秒数 (默认3)")
    打印行("  -b        批处理模式")
    打印行("  -H        显示线程")
    打印行("  -u 用户   仅显示指定用户进程")
    打印行("  -o 字段   排序字段 (cpu/mem/pid/time)")
}

函数 top_显示(排序方式, 显示数, 过滤用户) {
    定义 概要 = top_获取系统概要()

    top_显示头部(概要)
    打印行("")
    top_显示任务概要(概要)
    top_显示CPU概要(概要)
    top_显示内存概要(概要)
    top_显示交换概要(概要)
    打印行("")

    打印行("  PID USER      PR  NI    VIRT    RES    SHR S  %CPU  %MEM   TIME+ COMMAND")

    定义 进程列表 = top_获取进程列表()
    进程列表 = top_排序进程(进程列表, 排序方式)

    定义 可变 已显示 = 0
    定义 可变 k = 0
    当 (k < 计数(进程列表) && 已显示 < 显示数) {
        定义 p = 进程列表[k]
        如果 (过滤用户 != "" && p.用户 != 过滤用户) { k = k + 1; 继续 }

        打印行(
            top_左填(整数转字符串(p.PID), 5) + " " +
            top_右填(p.用户, 9) + " " +
            top_左填(整数转字符串(p.优先级), 3) + " " +
            top_左填(整数转字符串(p.NICE值), 3) + " " +
            top_左填(top_格式化KB(p.虚拟内存), 7) + " " +
            top_左填(top_格式化KB(p.驻留内存), 6) + " " +
            top_左填(top_格式化KB(p.共享内存), 6) + " " +
            p.状态 + " " +
            top_左填(top_格式化百分比(p.CPU百分比), 5) + " " +
            top_左填(top_格式化百分比(p.内存百分比), 5) + " " +
            top_格式化时间(p.时间) + " " +
            p.命令
        )
        已显示 = 已显示 + 1
        k = k + 1
    }
}

函数 top_显示头部(概要) {
    定义 时 = 概要.运行时间秒 / 3600
    定义 分 = (概要.运行时间秒 % 3600) / 60
    打印行("top - 运行: " + 整数转字符串(时) + ":" + top_左填(整数转字符串(分), 2) +
        ",  " + 整数转字符串(概要.用户数) + " 用户" +
        ",  负载: " + top_格式化百分比(概要.负载1分钟) + " " +
        top_格式化百分比(概要.负载5分钟) + " " +
        top_格式化百分比(概要.负载15分钟))
}

函数 top_显示任务概要(概要) {
    打印行("任务: " + 整数转字符串(概要.总进程) + " 总计, " +
        整数转字符串(概要.运行进程) + " 运行, " +
        整数转字符串(概要.睡眠进程) + " 睡眠, " +
        整数转字符串(概要.停止进程) + " 停止, " +
        整数转字符串(概要.僵尸进程) + " 僵尸")
}

函数 top_显示CPU概要(概要) {
    打印行("%CPU: " + top_格式化百分比(概要.CPU用户) + " 用户, " +
        top_格式化百分比(概要.CPU系统) + " 系统, " +
        top_格式化百分比(概要.CPU空闲) + " 空闲, " +
        top_格式化百分比(概要.CPU等待) + " 等待IO")
}

函数 top_显示内存概要(概要) {
    打印行("MiB Mem: " + 整数转字符串(概要.内存总量 / 1024) + " 总计, " +
        整数转字符串(概要.内存已用 / 1024) + " 已用, " +
        整数转字符串(概要.内存空闲 / 1024) + " 空闲, " +
        整数转字符串(概要.内存缓存 / 1024) + " 缓存")
}

函数 top_显示交换概要(概要) {
    打印行("MiB Swap: " + 整数转字符串(概要.交换总量 / 1024) + " 总计, " +
        整数转字符串(概要.交换已用 / 1024) + " 已用, " +
        整数转字符串(概要.交换空闲 / 1024) + " 空闲")
}

函数 top_排序进程(列表, 排序方式) {
    定义 可变 i = 0
    当 (i < 计数(列表) - 1) {
        定义 可变 j = i + 1
        当 (j < 计数(列表)) {
            定义 可变 交换 = 假
            如果 (排序方式 == TOP_排序_CPU && 列表[j].CPU百分比 > 列表[i].CPU百分比) { 交换 = 真 }
            否则 如果 (排序方式 == TOP_排序_内存 && 列表[j].内存百分比 > 列表[i].内存百分比) { 交换 = 真 }
            否则 如果 (排序方式 == TOP_排序_PID && 列表[j].PID < 列表[i].PID) { 交换 = 真 }
            否则 如果 (排序方式 == TOP_排序_时间 && 列表[j].时间 > 列表[i].时间) { 交换 = 真 }
            如果 (交换) {
                定义 临时 = 列表[i]
                列表[i] = 列表[j]
                列表[j] = 临时
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 列表
}

函数 top_格式化KB(kb) {
    如果 (kb >= 1048576) { 返回 整数转字符串(kb / 1048576) + "g" }
    如果 (kb >= 1024) { 返回 整数转字符串(kb / 1024) + "m" }
    返回 整数转字符串(kb)
}

函数 top_格式化百分比(值) {
    返回 整数转字符串(值 / 10) + "." + 整数转字符串(值 % 10)
}

函数 top_格式化时间(秒) {
    定义 分 = 秒 / 60
    定义 余秒 = 秒 % 60
    返回 整数转字符串(分) + ":" + top_左填(整数转字符串(余秒), 2)
}

函数 top_左填(文本, 宽度) {
    定义 可变 结果 = 文本
    当 (字符串长度(结果) < 宽度) { 结果 = " " + 结果 }
    返回 结果
}

函数 top_右填(文本, 宽度) {
    定义 可变 结果 = 文本
    当 (字符串长度(结果) < 宽度) { 结果 = 结果 + " " }
    返回 结果
}

函数 top_获取系统概要() {
    返回 系统概要 {
        运行时间秒: 0, 用户数: 1,
        负载1分钟: 5, 负载5分钟: 3, 负载15分钟: 1,
        总进程: 4, 运行进程: 1, 睡眠进程: 3, 停止进程: 0, 僵尸进程: 0,
        CPU用户: 20, CPU系统: 10, CPU空闲: 680, CPU等待: 0,
        内存总量: 262144, 内存已用: 131072, 内存空闲: 65536, 内存缓存: 65536,
        交换总量: 524288, 交换已用: 0, 交换空闲: 524288
    }
}

函数 top_获取进程列表() {
    返回 [
        进程信息 { PID: 0, 用户: "root", 优先级: 20, NICE值: 0, 虚拟内存: 0, 驻留内存: 0, 共享内存: 0, 状态: "S", CPU百分比: 0, 内存百分比: 0, 时间: 0, 命令: "idle" },
        进程信息 { PID: 1, 用户: "root", 优先级: 20, NICE值: 0, 虚拟内存: 4096, 驻留内存: 2048, 共享内存: 1024, 状态: "S", CPU百分比: 0, 内存百分比: 1, 时间: 0, 命令: "nova-init" },
        进程信息 { PID: 2, 用户: "root", 优先级: 20, NICE值: 0, 虚拟内存: 8192, 驻留内存: 4096, 共享内存: 2048, 状态: "S", CPU百分比: 0, 内存百分比: 2, 时间: 0, 命令: "nova-ai" },
        进程信息 { PID: 3, 用户: "root", 优先级: 20, NICE值: 0, 虚拟内存: 2048, 驻留内存: 1024, 共享内存: 512, 状态: "R", CPU百分比: 5, 内存百分比: 0, 时间: 0, 命令: "nova-shell" }
    ]
}

定义 可变 AI_进程查_运行指标 = 0
定义 可变 AI_进程查_异常指标 = 0

函数 AI_进程查_自诊断() {
    AI_进程查_运行指标 = 0
    返回 AI_进程查_运行指标
}

函数 AI_进程查_优化建议() {
    定义 指标 = AI_进程查_自诊断()
    返回 "进程查状态正常"
}

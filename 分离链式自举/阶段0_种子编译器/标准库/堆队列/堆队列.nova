导入("../基础.nova")

定义 可变 堆_数据 = []
定义 可变 堆_大小 = 0

函数 堆队列_堆_父(i) { 返回 (i - 1) / 2 }
函数 堆队列_堆_左子(i) { 返回 2 * i + 1 }
函数 堆队列_堆_右子(i) { 返回 2 * i + 2 }

函数 堆队列_堆_交换(i, j) { 定义 临时 = 堆_数据[i]
 堆_数据[i] = 堆_数据[j]
 堆_数据[j] = 临时
}

函数 堆_初始化() {
 堆_数据 = []
 堆_大小 = 0
}

// 本地上浮 (操作模块级 堆_数据)
函数 本地_上浮(i) { 定义 可变 索引 = i
 当 (索引 > 0) { 定义 p = (索引 - 1) / 2
 如果 (堆_数据[索引] < 堆_数据[p]) {
 堆队列_堆_交换(索引, p)
 索引 = p
 } 否则 { 返回 空 }
 }
}

// 本地下沉 (操作模块级 堆_数据)
函数 本地_下沉(i) { 定义 可变 索引 = i
 当 (2 * 索引 + 1 < 堆_大小) { 定义 可变 最小 = 索引
 定义 左 = 2 * 索引 + 1
 定义 右 = 2 * 索引 + 2
 如果 (左 < 堆_大小) { 如果 (堆_数据[左] < 堆_数据[最小]) { 最小 = 左 } }
 如果 (右 < 堆_大小) { 如果 (堆_数据[右] < 堆_数据[最小]) { 最小 = 右 } }
 如果 (最小 != 索引) { 堆队列_堆_交换(索引, 最小)
 索引 = 最小 }
 否则 { 返回 空 }
 }
}

函数 堆队列_堆_插入(值) {
 追加(堆_数据, 值)
 堆_大小 = 堆_大小 + 1
 本地_上浮(堆_大小 - 1)
}

函数 堆队列_堆_弹出() {
    如果 (堆_大小 == 0) { 返回 空
}
 定义 顶 = 堆_数据[0]
 堆_大小 = 堆_大小 - 1
 堆_数据[0] = 堆_数据[堆_大小]
 本地_下沉(0)
 返回 顶
}

函数 堆_查看顶() {
    如果 (堆_大小 == 0) { 返回 空
}
 返回 堆_数据[0]
}

函数 堆_为空() { 返回 堆_大小 == 0 }

// 最大堆 (取反实现)
定义 可变 大堆_数据 = []
定义 可变 大堆_大小 = 0

函数 大堆_交换(i, j) { 定义 临时 = 大堆_数据[i]
 大堆_数据[i] = 大堆_数据[j]
 大堆_数据[j] = 临时
}

函数 大堆_上浮(i) {
 定义 可变 索引 = i
 当 (索引 > 0) { 定义 p = (索引 - 1) / 2
 如果 (大堆_数据[索引] > 大堆_数据[p]) {
 大堆_交换(索引, p)
 索引 = p
 } 否则 { 返回 空 }
 }
}

函数 大堆_下沉(i) {
 定义 可变 索引 = i
 当 (2 * 索引 + 1 < 大堆_大小) { 定义 可变 最大 = 索引
 定义 左 = 2 * 索引 + 1
 定义 右 = 2 * 索引 + 2
 如果 (左 < 大堆_大小) { 如果 (大堆_数据[左] > 大堆_数据[最大]) { 最大 = 左 }
 }
 如果 (右 < 大堆_大小) { 如果 (大堆_数据[右] > 大堆_数据[最大]) { 最大 = 右 }
 }
 如果 (最大 != 索引) {
 大堆_交换(索引, 最大)
 索引 = 最大
 } 否则 { 返回 空 }
 }
}

函数 大堆_初始化() { 大堆_数据 = []
大堆_大小 = 0 }

函数 大堆_插入(值) {
 追加(大堆_数据, 值)
 大堆_大小 = 大堆_大小 + 1
 大堆_上浮(大堆_大小 - 1)
}

函数 大堆_弹出() {
    如果 (大堆_大小 == 0) { 返回 空
}
 定义 顶 = 大堆_数据[0]
 大堆_大小 = 大堆_大小 - 1
 大堆_数据[0] = 大堆_数据[大堆_大小]
 大堆_下沉(0)
 返回 顶
}

函数 大堆_查看顶() {
    如果 (大堆_大小 == 0) { 返回 空
}
 返回 大堆_数据[0]
}

// TopK: 取最小K个
函数 TopK_最小(列表, k) {
 堆_初始化()
 定义 可变 i = 0
 当 (i < 计数(列表)) { 堆队列_堆_插入(列表[i])
 i = i + 1 }
 定义 可变 结果 = []
 i = 0
 当 (i < k) { 如果 (堆_大小 > 0) { 追加(结果, 堆队列_堆_弹出()) }
 i = i + 1
 }
 返回 结果
}

// TopK: 取最大K个
函数 TopK_最大(列表, k) {
 大堆_初始化()
 定义 可变 i = 0
 当 (i < 计数(列表)) { 大堆_插入(列表[i])
 i = i + 1 }
 定义 可变 结果 = []
 i = 0
 当 (i < k) { 如果 (大堆_大小 > 0) { 追加(结果, 大堆_弹出()) }
 i = i + 1
 }
 返回 结果
}

// 堆验证
函数 堆_有效() { 定义 可变 i = 1
 当 (i < 堆_大小) { 如果 (堆_数据[i] < 堆_数据[(i - 1) / 2]) { 返回 假 }
 i = i + 1
 }
 返回 真
}

// 堆当前大小
函数 堆_当前大小() { 返回 堆_大小 }

// 堆合并
函数 堆_合并到(源) { 定义 可变 i = 0
 当 (i < 计数(源)) {
 堆队列_堆_插入(源[i])
 i = i + 1
 }
}

// 堆化数组
函数 堆化_数组(数组) {
 堆_大小 = 0
 堆_数据 = []
 定义 可变 i = 0
 当 (i < 计数(数组)) {
 堆队列_堆_插入(数组[i])
 i = i + 1
 }
}

// 堆排序(原地, 0)
函数 堆排序_原地(数组) { 定义 n = 计数(数组)
 定义 可变 i = n / 2 - 1
 当 (i >= 0) { 定义 可变 j = i
 定义 可变 沉完 = 假
 当 (沉完 == 假) { 定义 可变 最大 = j
 定义 左 = 2 * j + 1
 定义 右 = 2 * j + 2
 如果 (左 < n 且 数组[左] > 数组[最大]) { 最大 = 左 }
 如果 (右 < n 且 数组[右] > 数组[最大]) { 最大 = 右 }
 如果 (最大 == j) { 沉完 = 真
 } 否则 {
 定义 暂 = 数组[j]
 数组[j] = 数组[最大]
 数组[最大] = 暂
 j = 最大
 }
 }
 i = i - 1
 }
 i = n - 1
 当 (i > 0) { 定义 暂 = 数组[0]
 数组[0] = 数组[i]
 数组[i] = 暂
 定义 可变 j = 0
 定义 可变 大小 = i
 定义 可变 沉完2 = 假
 当 (沉完2 == 假) { 定义 可变 最大 = j
 定义 左 = 2 * j + 1
 定义 右 = 2 * j + 2
 如果 (左 < 大小 且 数组[左] > 数组[最大]) { 最大 = 左 }
 如果 (右 < 大小 且 数组[右] > 数组[最大]) { 最大 = 右 }
 如果 (最大 == j) { 沉完2 = 真
 } 否则 {
 定义 暂2 = 数组[j]
 数组[j] = 数组[最大]
 数组[最大] = 暂2
 j = 最大
 }
 }
 i = i - 1
 }
}

// 流式中位数
// 低半部用最大堆（[0]是最大值），高半部用最小堆（[0]是最小值）
定义 可变 _中位数_最大堆 = []
定义 可变 _中位数_最小堆 = []

// 内部: 最大堆上浮
函数 _中位数_大堆上浮(idx_in) {
    定义 可变 索引 = idx_in
    当 (索引 > 0) {
        定义 p = (索引 - 1) / 2
        如果 (_中位数_最大堆[索引] > _中位数_最大堆[p]) {
            定义 临时 = _中位数_最大堆[索引]
            _中位数_最大堆[索引] = _中位数_最大堆[p]
            _中位数_最大堆[p] = 临时
            索引 = p
        } 否则 { 返回 空 }
    }
}

// 内部: 最大堆下沉
函数 _中位数_大堆下沉() {
    定义 可变 索引 = 0
    定义 n = 计数(_中位数_最大堆)
    当 (2 * 索引 + 1 < n) {
        定义 可变 最大 = 索引
        定义 左 = 2 * 索引 + 1
        定义 右 = 2 * 索引 + 2
        如果 (左 < n 且 _中位数_最大堆[左] > _中位数_最大堆[最大]) { 最大 = 左 }
        如果 (右 < n 且 _中位数_最大堆[右] > _中位数_最大堆[最大]) { 最大 = 右 }
        如果 (最大 != 索引) {
            定义 临时 = _中位数_最大堆[索引]
            _中位数_最大堆[索引] = _中位数_最大堆[最大]
            _中位数_最大堆[最大] = 临时
            索引 = 最大
        } 否则 { 返回 空 }
    }
}

// 内部: 最小堆上浮
函数 _中位数_小堆上浮(idx_in) {
    定义 可变 索引 = idx_in
    当 (索引 > 0) {
        定义 p = (索引 - 1) / 2
        如果 (_中位数_最小堆[索引] < _中位数_最小堆[p]) {
            定义 临时 = _中位数_最小堆[索引]
            _中位数_最小堆[索引] = _中位数_最小堆[p]
            _中位数_最小堆[p] = 临时
            索引 = p
        } 否则 { 返回 空 }
    }
}

// 内部: 最小堆下沉
函数 _中位数_小堆下沉() {
    定义 可变 索引 = 0
    定义 n = 计数(_中位数_最小堆)
    当 (2 * 索引 + 1 < n) {
        定义 可变 最小 = 索引
        定义 左 = 2 * 索引 + 1
        定义 右 = 2 * 索引 + 2
        如果 (左 < n 且 _中位数_最小堆[左] < _中位数_最小堆[最小]) { 最小 = 左 }
        如果 (右 < n 且 _中位数_最小堆[右] < _中位数_最小堆[最小]) { 最小 = 右 }
        如果 (最小 != 索引) {
            定义 临时 = _中位数_最小堆[索引]
            _中位数_最小堆[索引] = _中位数_最小堆[最小]
            _中位数_最小堆[最小] = 临时
            索引 = 最小
        } 否则 { 返回 空 }
    }
}

// 内部: 最大堆弹出堆顶
函数 _中位数_大堆弹出() {
    定义 顶 = _中位数_最大堆[0]
    定义 末 = 计数(_中位数_最大堆) - 1
    _中位数_最大堆[0] = _中位数_最大堆[末]
    定义 可变 新 = []
    定义 可变 i = 0
    当 (i < 末) { 追加(新, _中位数_最大堆[i])  i = i + 1 }
    _中位数_最大堆 = 新
    _中位数_大堆下沉()
    返回 顶
}

// 内部: 最小堆弹出堆顶
函数 _中位数_小堆弹出() {
    定义 顶 = _中位数_最小堆[0]
    定义 末 = 计数(_中位数_最小堆) - 1
    _中位数_最小堆[0] = _中位数_最小堆[末]
    定义 可变 新 = []
    定义 可变 i = 0
    当 (i < 末) { 追加(新, _中位数_最小堆[i])  i = i + 1 }
    _中位数_最小堆 = 新
    _中位数_小堆下沉()
    返回 顶
}

函数 流中位数_添加(值) {
    如果 (计数(_中位数_最大堆) == 0 或 值 <= _中位数_最大堆[0]) {
        追加(_中位数_最大堆, 值)
        _中位数_大堆上浮(计数(_中位数_最大堆) - 1)
    } 否则 {
        追加(_中位数_最小堆, 值)
        _中位数_小堆上浮(计数(_中位数_最小堆) - 1)
    }
    如果 (计数(_中位数_最大堆) > 计数(_中位数_最小堆) + 1) {
        定义 移值a = _中位数_大堆弹出()
        追加(_中位数_最小堆, 移值a)
        _中位数_小堆上浮(计数(_中位数_最小堆) - 1)
    }
    如果 (计数(_中位数_最小堆) > 计数(_中位数_最大堆)) {
        定义 移值b = _中位数_小堆弹出()
        追加(_中位数_最大堆, 移值b)
        _中位数_大堆上浮(计数(_中位数_最大堆) - 1)
    }
}

函数 流中位数_取() {
    如果 (计数(_中位数_最大堆) == 0) { 返回 0 }
    如果 (计数(_中位数_最大堆) > 计数(_中位数_最小堆)) { 返回 _中位数_最大堆[0] }
    返回 (_中位数_最大堆[0] + _中位数_最小堆[0]) / 2
}

函数 流中位数_重置() { _中位数_最大堆 = []  _中位数_最小堆 = [] }

// 优先级任务队列（适合并发任务调度）
// 任务格式: [优先级, 任务ID, 任务数据]
// 优先级越小越先执行（最小堆语义）

定义 可变 _任务堆 = []  // [[优先级, id, 数据], ...]

函数 任务队列_推入(优先级, 任务id, 任务数据) {
    追加(_任务堆, [优先级, 任务id, 任务数据])
    // 上浮（按优先级）
    定义 可变 i = 计数(_任务堆) - 1
    当 (i > 0) {
        定义 p = (i - 1) / 2
        如果 (_任务堆[i][0] < _任务堆[p][0]) {
            定义 临时 = _任务堆[i]
            _任务堆[i] = _任务堆[p]
            _任务堆[p] = 临时
            i = p
        } 否则 { i = 0 }  // 中断循环
    }
}

函数 任务队列_弹出() {
    如果 (计数(_任务堆) == 0) { 返回 空 }
    定义 顶 = _任务堆[0]
    定义 末 = 计数(_任务堆) - 1
    _任务堆[0] = _任务堆[末]
    // 移除最后元素
    定义 可变 新堆 = []
    定义 可变 k = 0
    当 (k < 末) { 追加(新堆, _任务堆[k]); k = k + 1 }
    _任务堆 = 新堆
    // 下沉
    定义 可变 i = 0
    当 (2 * i + 1 < 计数(_任务堆)) {
        定义 可变 最小 = i
        定义 左 = 2 * i + 1; 定义 右 = 2 * i + 2
        如果 (左 < 计数(_任务堆) 且 _任务堆[左][0] < _任务堆[最小][0]) { 最小 = 左 }
        如果 (右 < 计数(_任务堆) 且 _任务堆[右][0] < _任务堆[最小][0]) { 最小 = 右 }
        如果 (最小 != i) {
            定义 临时 = _任务堆[i]; _任务堆[i] = _任务堆[最小]; _任务堆[最小] = 临时
            i = 最小
        } 否则 { i = 计数(_任务堆) }
    }
    返回 顶
}

函数 任务队列_查看顶() {
    如果 (计数(_任务堆) == 0) { 返回 空 }
    返回 _任务堆[0]
}

函数 任务队列_大小()    { 返回 计数(_任务堆) }
函数 任务队列_为空()    { 返回 计数(_任务堆) == 0 }
函数 任务队列_重置()    { _任务堆 = [] }

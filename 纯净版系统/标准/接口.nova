// 标准脑区 · 统一对外接口 — 基础类型/集合/字符串的唯一出口
// 职能: 类型系统/字符串操作/集合/排序/正则/数学运算

导入("./类型.nova")
导入("./原生字符串.nova")
导入("./集合.nova")
导入("./数学幂根对数.nova")
导入("./类型判断.nova")
导入("../稳态/接口.nova")
导入("../记忆/接口.nova")
导入("../引导/接口.nova")

函数 标准_字符串长度(字符串) {
    返回 字符串_长度(字符串)
}

函数 标准_字符串拼接(甲, 乙) {
    返回 字符串_连接(甲, 乙)
}

函数 标准_字符串查找(字符串, 子串) {
    返回 字符串_indexOf(字符串, 子串)
}

函数 标准_字符串截取(字符串, 起, 止) {
    返回 字符串_substring(字符串, 起, 止)
}

函数 标准_字符串分割(字符串, 分隔符) {
    返回 字符串_split(字符串, 分隔符)
}

函数 标准_创建映射() {
    返回 映射_创建()
}

函数 标准_映射设置(映射, 键, 值) {
    映射_set(映射, 键, 值)
}

函数 标准_映射获取(映射, 键) {
    返回 映射_get(映射, 键)
}

函数 标准_创建列表() {
    返回 列表_创建()
}

函数 标准_列表追加(列表, 元素) {
    列表_push(列表, 元素)
}

函数 标准_类型(值) {
    返回 类型_获取(值)
}

函数 标准_是数字(值) {
    返回 类型_是数字(值)
}

函数 标准_是字符串(值) {
    返回 类型_是字符串(值)
}

函数 标准_绝对值(值) {
    如果 (值 < 0) { 返回 0 - 值 }
    返回 值
}

函数 标准_最大值(甲, 乙) {
    如果 (甲 > 乙) { 返回 甲 }
    返回 乙
}

函数 标准_最小值(甲, 乙) {
    如果 (甲 < 乙) { 返回 甲 }
    返回 乙
}

函数 标准_安全入口(调用者, 操作码) {
    如果 (调用者 < 0 || 调用者 > 8) { 返回 -1 }
    返回 0
}


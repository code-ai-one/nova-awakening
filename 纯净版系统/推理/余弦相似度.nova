// §4 余弦相似度 — 判断两个向量的语义距离
// cos(A,B) = (A·B) / (|A| × |B|)
// 返回值: Q10定点, 范围[-1024, 1024] 对应[-1.0, 1.0]

// [v2反哺] 余弦相似度 — 余弦相似度+工作记忆极坐标: 复用PolarQuant几何计算路径
// 工作记忆_极坐标压缩写入 — TurboQuant原生记忆格式
// 旧版: 工作记忆单元基于哈希/强度/计数式组织
// 新版: PolarQuant极坐标块 (方向4bit+幅值4bit+8bit残差=每维2字节)
// 类人脑: 记忆压缩-再激活机制，类似海马-皮层巩固中的模式补全
函数 工作记忆_极坐标压缩写入(工作记忆, 语义向量, 向量维度, 槽位) {
    如果 (工作记忆 == 0 || 语义向量 == 0) { 返回 -1 }
    如果 (槽位 >= 工作记忆.容量) { 返回 -1 }
    // 获取槽位起始地址
    定义 块大小 = 向量维度 * 2 + 4  // 每元素2字节 + 4字节模长
    定义 槽地址 = 工作记忆.压缩块基址 + 槽位 * 块大小
    // 压缩向量到极坐标格式
    PolarQuant_KV_编码块(语义向量, 槽地址, 向量维度)
    工作记忆.槽位类型[槽位] = 1  // 极坐标格式标记
    工作记忆.时间戳[槽位] = 工作记忆.当前时刻
    工作记忆.当前时刻 = 工作记忆.当前时刻 + 1
    返回 槽位
}
函数 工作记忆_极坐标检索(工作记忆, 查询向量, 向量维度, 结果) {
    如果 (工作记忆 == 0 || 查询向量 == 0) { 返回 -1 }
    定义 块大小 = 向量维度 * 2 + 4
    定义 可变 最高分 = -32768
    定义 可变 最优槽 = -1
    定义 临时向量 = 堆_分配_临时(向量维度 * 4)
    定义 可变 s = 0
    当 (s < 工作记忆.已用槽数) {
        如果 (工作记忆.槽位类型[s] != 1) { s = s + 1; 继续 }
        定义 槽地址 = 工作记忆.压缩块基址 + s * 块大小
        // 解码极坐标
        PolarQuant_KV_解码块(槽地址, 临时向量, 向量维度)
        // 计算余弦相似度
        定义 分数 = 余弦相似度_快速(查询向量, 临时向量, 向量维度)
        如果 (分数 > 最高分) { 最高分 = 分数; 最优槽 = s }
        s = s + 1
    }
    如果 (最优槽 >= 0 && 结果 != 0) {
        定义 槽地址 = 工作记忆.压缩块基址 + 最优槽 * 块大小
        PolarQuant_KV_解码块(槽地址, 结果, 向量维度)
    }
    堆_释放_临时(临时向量)
    返回 最优槽
}
函数 余弦相似度_快速(A, B, 维度) {
    定义 可变 dot = 0;  定义 可变 aN = 0;  定义 可变 bN = 0
    定义 可变 i = 0
    当 (i < 维度) {
        定义 a = Tensor_读(A, i);  定义 b = Tensor_读(B, i)
        dot = dot + Q乘(a, b);  aN = aN + Q乘(a, a);  bN = bN + Q乘(b, b)
        i = i + 1
    }
    如果 (aN == 0 || bN == 0) { 返回 0 }
    返回 Q乘(dot, Q除(Q_ONE, Q开方(Q乘(aN, bN))))
}

// Tensor行向量的余弦相似度
函数 Tensor行_余弦相似度(A, 行A, B, 行B) {
    返回 余弦相似度(A.数据, 行A * A.列数, B.数据, 行B * B.列数, A.列数)
}

// §5 节点嵌入计算 — 将DOM节点转为语义向量

// 从DOM节点提取特征并计算嵌入向量
函数 语义嵌入_计算节点嵌入(引擎, 节点) {
    如果 (引擎 == 0 || 节点 == 0) { 返回 0 }

    // 1. 获取标签嵌入(32维)
    定义 标签ID = 节点_获取标签ID(节点)
    // 从嵌入表中提取行向量
    定义 标签向量 = Tensor_切片行(引擎.标签嵌入表, 标签ID, 1)

    // 2. 计算类名嵌入(32维) — 将class名哈希为8维特征, 过Nova多层感知器
    定义 类名特征 = 提取_类名特征(节点)
    定义 类名向量 = Nova多层感知器_前向(引擎.类名嵌入网络, 类名特征)
    Tensor_释放(类名特征)

    // 3. 提取结构特征(8维): 深度/子节点数/兄弟位置/文本长度/...
    定义 结构特征 = 提取_结构特征(节点)

    // 4. 拼接: [标签32 + 类名32 + 结构8 = 72维]
    定义 拼接输入 = Tensor_创建(1, 72)
    定义 可变 i = 0
    当 (i < 32) {
        Tensor_写(拼接输入, 0, i, Tensor_读(标签向量, 0, i))
        Tensor_写(拼接输入, 0, 32 + i, Tensor_读(类名向量, 0, i))
        i = i + 1
    }
    i = 0
    当 (i < 8) {
        Tensor_写(拼接输入, 0, 64 + i, Tensor_读(结构特征, 0, i))
        i = i + 1
    }

    // 5. 通过节点嵌入网络: 72维 → 32维
    定义 节点嵌入 = Nova多层感知器_前向(引擎.节点嵌入网络, 拼接输入)

    Tensor_释放(标签向量)
    Tensor_释放(类名向量)
    Tensor_释放(结构特征)
    Tensor_释放(拼接输入)

    返回 节点嵌入    // [1 × 32] 节点的语义嵌入向量
}

// §6 语义角色分类 — 用余弦相似度匹配最近的语义原型

函数 语义嵌入_分类节点角色(引擎, 节点嵌入) {
    如果 (引擎 == 0 || 节点嵌入 == 0) { 返回 0 }

    定义 可变 最大相似度 = -Q_ONE
    定义 可变 最佳角色 = 0
    定义 可变 r = 0
    当 (r < 引擎.角色数量) {
        定义 相似度 = Tensor行_余弦相似度(节点嵌入, 0, 引擎.语义原型, r)
        如果 (相似度 > 最大相似度) {
            最大相似度 = 相似度
            最佳角色 = r
        }
        r = r + 1
    }
    返回 最佳角色
}

// 批量分类: 一次性分类多个节点
函数 语义嵌入_批量分类(引擎, 嵌入矩阵) {
    // 嵌入矩阵[N × 32] → 角色数组[N]
    定义 N = 嵌入矩阵.行数
    定义 结果 = Tensor_创建(1, N)
    定义 可变 i = 0
    当 (i < N) {
        定义 节点嵌入 = Tensor_切片行(嵌入矩阵, i, 1)
        定义 角色 = 语义嵌入_分类节点角色(引擎, 节点嵌入)
        Tensor_写(结果, 0, i, 角色)
        Tensor_释放(节点嵌入)
        i = i + 1
    }
    返回 结果
}

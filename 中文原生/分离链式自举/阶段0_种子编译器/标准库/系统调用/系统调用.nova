// 调用约定
// 平台ID
定义 平台_LINUX_X64 = 1
定义 平台_LINUX_A64 = 2
定义 系统调用_平台_WINDOWS = 3
定义 平台_MACOS_X64 = 4
定义 平台_MACOS_A64 = 5

// 参数寄存器查询
函数 系统调用_参数寄存器(平台) { 如果 (平台 == 平台_LINUX_X64) { 返回 [7,6,2,10,8,9] } // RDI,RSI,RDX,R10,R8,R9
 如果 (平台 == 平台_LINUX_A64) { 返回 [0,1,2,3,4,5] } // X0-X5
 如果 (平台 == 系统调用_平台_WINDOWS)
 { 返回 [1,2,8,9] } // RCX,RDX,R8,R9
 如果 (平台 == 平台_MACOS_X64) { 返回 [7,6,2,10,8,9] } // 同Linux
 返回 []
}

// 系统调用号寄存器
函数 系统调用_号寄存器(平台) { 如果 (平台 == 平台_LINUX_X64) { 返回 0 } // RAX
 如果 (平台 == 平台_LINUX_A64) { 返回 8 } // X8
 如果 (平台 == 平台_MACOS_X64) { 返回 0 } // RAX
 返回 0
}

// 返回值寄存器
函数 系统调用_返回寄存器(平台) { 如果 (平台 == 平台_LINUX_X64) { 返回 0 } // RAX
 如果 (平台 == 平台_LINUX_A64) { 返回 0 } // X0
 如果 (平台 == 系统调用_平台_WINDOWS)
 { 返回 0 } // RAX/EAX
 如果 (RAX == 0) { 返回 0 }
 如果 (平台 == 平台_MACOS_X64) { 返回 0 } // RAX
 返回 0
}

// errno错误码 (POSIX标准)
定义 错误码_权限不足 = 1 // 操作不允许
定义 错误码_文件不存在 = 2 // 文件不存在
定义 错误码_进程不存在 = 3 // 进程不存在
定义 错误码_中断 = 4 // 系统调用中断
定义 错误码_输入输出错误 = 5 // I/O错误
定义 错误码_内存不足 = 12 // 内存不足
定义 错误码_访问拒绝 = 13 // 权限拒绝
定义 错误码_错误地址 = 14 // 地址错误
定义 错误码_已存在 = 17 // 文件已存在
定义 错误码_非目录 = 20 // 非目录
定义 错误码_是目录 = 21 // 是目录
定义 错误码_无效参数 = 22 // 无效参数
定义 错误码_打开过多文件 = 24 // 打开文件过多
定义 错误码_空间不足 = 28 // 空间不足
定义 错误码_管道断裂 = 32 // 管道断开
定义 错误码_结果超范围 = 34 // 结果超范围
定义 错误码_资源暂不可用 = 11 // 资源暂不可用
定义 错误码_连接被拒 = 111 // 连接被拒绝
定义 错误码_连接超时 = 110 // 连接超时


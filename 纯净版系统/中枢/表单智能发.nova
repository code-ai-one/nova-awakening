// NovaOS · 自动化注册引擎 — AI自主完成平台注册+账号管理
// 表单智能发现 + 自动填写 + 验证码处理 + 邮箱/短信验证
// §1 表单智能发现: 分析DOM→识别注册/登录表单→字段语义理解
// §2 账号信息生成: 用户名/密码/个人信息生成器
// §3 验证码处理中心: OCR文字/滑块/图片选择/reCAPTCHA统一接口
// §4 邮箱验证流: 临时邮箱/收信/提取验证链接/自动点击
// §5 短信验证流: 接码平台对接/验证码提取/自动填入
// §6 账号管理器: 加密存储/多账号切换/登录状态维护
// §7 注册流程编排: 状态机驱动的完整注册流程

外部 元素_按类型查找     // (根节点, 标签码) -> []
外部 元素_提取文本              // (节点) -> 字符串
外部 元素_获取属性              // (节点, 属性名哈希) -> 字符串
外部 验证_滑块                 // (起x, 起y, 目标x, 目标y) -> 布尔
外部 验证_图片选择             // (图片网格, 目标描述) -> 布尔
外部 验证_reCAPTCHA_复选框     // (x, y) -> 布尔
外部 验证_文字识别             // (图片数据) -> 字符串
外部 标签页_新建               // (URL) -> 标签ID
外部 标签页_查找               // (标签ID) -> 标签页
外部 HTTP_创建请求             // (方法, URL) -> 网络请求
外部 HTTP_发送                 // (请求) -> HTTP响应
外部 加密_创建AES              // (密钥) -> 加密上下文
外部 生成随机字节_安全          // (长度) -> []
外部 加密_数据                 // (上下文, 明文) -> 密文
外部 仿生_打字                 // (文本) -> [打字事件]
外部 仿生_鼠标点击_真人         // (x, y) -> 布尔

// §1 表单智能发现

定义 字段类型_用户名 = 1
定义 字段类型_邮箱 = 2
定义 字段类型_密码 = 3
定义 字段类型_确认密码 = 4
定义 字段类型_手机 = 5
定义 字段类型_姓名 = 6
定义 字段类型_验证码 = 7
定义 字段类型_同意条款 = 8
定义 字段类型_提交按钮 = 9
定义 字段类型_未知 = 0

结构 表单字段 {
    元素ID,
    字段类型,
    名称,
    标签文本,
    默认值,
    类型属性,    // 字符串 input type
    必填,
    x,
    y,
    宽,
    高,
}

结构 发现的表单 {
    表单元素ID,
    字段列表,    // [] 表单字段数组
    提交按钮,    // 空
    表单类型,    // u32 0=未知 1=注册 2=登录 3=搜索
    URL,
    置信度,
}

定义 可变 已发现表单 = []
定义 可变 注册_总尝试 = 0
定义 可变 注册_总成功 = 0

函数 表单_智能发现(DOM根) {
    如果 (DOM根 == 空) { 返回 [] }
    已发现表单 = []

    定义 所有表单 = 元素_按类型查找(DOM根, 15)  // <form>

    定义 可变 i = 0
    当 (i < 计数(所有表单)) {
        定义 表单 = 发现的表单 {}
        表单.表单元素ID = 所有表单[i].节点ID
        表单.字段列表 = []

        // 扫描表单内所有input
        定义 输入框 = 元素_按类型查找(所有表单[i], 6)   // <input>
        定义 _文本域 = 元素_按类型查找(所有表单[i], 16)  // <textarea>
        定义 按钮 = 元素_按类型查找(所有表单[i], 5)     // <button>

        定义 可变 j = 0
        当 (j < 计数(输入框)) {
            定义 字段 = 表单_分析字段(输入框[j])
            追加(表单.字段列表, 字段)
            j = j + 1
        }

        // 查找提交按钮
        如果 (计数(按钮) > 0) {
            定义 提交 = 表单字段 {}
            提交.元素ID = 按钮[0].节点ID
            提交.字段类型 = 字段类型_提交按钮
            提交.标签文本 = 元素_提取文本(按钮[0])
            提交.x = 按钮[0].布局_x
            提交.y = 按钮[0].布局_y
            表单.提交按钮 = 提交
        }

        // 判断表单类型
        表单.表单类型 = 表单_推断类型(表单)
        表单.置信度 = 700

        追加(已发现表单, 表单)
        i = i + 1
    }

    内核调试("表单发现: 找到" + 整数转字符串(计数(已发现表单)) + "个表单")
    返回 已发现表单
}

函数 表单_分析字段(输入元素) {
    定义 字段 = 表单字段 {}
    字段.元素ID = 输入元素.节点ID
    字段.x = 输入元素.布局_x
    字段.y = 输入元素.布局_y
    字段.宽 = 输入元素.布局_宽
    字段.高 = 输入元素.布局_高

    定义 类型 = 元素_获取属性(输入元素, 哈希_注册("type"))
    定义 名称 = 元素_获取属性(输入元素, 哈希_注册("name"))
    定义 占位 = 元素_获取属性(输入元素, 哈希_注册("placeholder"))
    定义 _自动 = 元素_获取属性(输入元素, 哈希_注册("autocomplete"))
    字段.类型属性 = 类型
    字段.名称 = 名称
    字段.默认值 = 占位

    // AI语义分析: 根据name/placeholder/type/autocomplete推断字段含义
    如果 (类型 == "password") {
        如果 (包含_注册(名称, "confirm") || 包含_注册(名称, "repeat") || 包含_注册(占位, "确认")) {
            字段.字段类型 = 字段类型_确认密码
        } 否则 {
            字段.字段类型 = 字段类型_密码
        }
    } 否则 如果 (类型 == "email" || 包含_注册(名称, "email") || 包含_注册(名称, "mail") || 包含_注册(占位, "邮箱")) {
        字段.字段类型 = 字段类型_邮箱
    } 否则 如果 (类型 == "tel" || 包含_注册(名称, "phone") || 包含_注册(名称, "mobile") || 包含_注册(占位, "手机")) {
        字段.字段类型 = 字段类型_手机
    } 否则 如果 (包含_注册(名称, "user") || 包含_注册(名称, "login") || 包含_注册(名称, "account") || 包含_注册(占位, "用户名")) {
        字段.字段类型 = 字段类型_用户名
    } 否则 如果 (包含_注册(名称, "name") || 包含_注册(占位, "姓名") || 包含_注册(占位, "昵称")) {
        字段.字段类型 = 字段类型_姓名
    } 否则 如果 (包含_注册(名称, "captcha") || 包含_注册(名称, "verify") || 包含_注册(名称, "code") || 包含_注册(占位, "验证码")) {
        字段.字段类型 = 字段类型_验证码
    } 否则 如果 (类型 == "checkbox") {
        字段.字段类型 = 字段类型_同意条款
    } 否则 {
        字段.字段类型 = 字段类型_未知
    }

    返回 字段
}

函数 表单_推断类型(表单) {
    定义 可变 有密码 = 假
    定义 可变 有邮箱 = 假
    定义 可变 有确认密码 = 假
    定义 可变 有用户名 = 假
    定义 可变 i = 0
    当 (i < 计数(表单.字段列表)) {
        如果 (表单.字段列表[i].字段类型 == 字段类型_密码) { 有密码 = 真 }
        如果 (表单.字段列表[i].字段类型 == 字段类型_邮箱) { 有邮箱 = 真 }
        如果 (表单.字段列表[i].字段类型 == 字段类型_确认密码) { 有确认密码 = 真 }
        如果 (表单.字段列表[i].字段类型 == 字段类型_用户名) { 有用户名 = 真 }
        i = i + 1
    }
    如果 (有确认密码 || (有密码 && 有邮箱 && 计数(表单.字段列表) >= 3)) { 返回 1 }  // 注册
    如果 (有密码 && (有用户名 || 有邮箱) && 计数(表单.字段列表) <= 3) { 返回 2 }    // 登录
    返回 0  // 未知
}

// §5 字形光栅化 — 贝塞尔轮廓→像素位图

结构 GlyphBitmap {
    宽度,
    高度,
    左偏,    // i32 位图左边距(像素)
    上偏,    // i32 位图上边距(像素)
    步幅,    // u32 每行字节数
    像素,    // u64 u8* 灰度8位位图
    前进宽度,    // u32 水平前进量(像素×64, 26.6定点)
}


函数 TrueType_光栅化字形(font, glyphID, 像素大小) {
    定义 outline = TrueType_解析字形(font, glyphID)

    // 获取前进宽度
    定义 advance = TrueType_获取前进宽度(font, glyphID)

    如果 (outline == 0) {
        // 空字形(空格等): 只有前进宽度
        定义 bmp = 堆_分配(GlyphBitmap)
        bmp.宽度 = 0; bmp.高度 = 0
        bmp.左偏 = 0; bmp.上偏 = 0
        bmp.步幅 = 0; bmp.像素 = 0
        bmp.前进宽度 = advance * 像素大小 * 64 / font.upem
        返回 bmp
    }

    // 计算缩放因子 (FUnit → 像素, ×256定点)
    定义 scale = 像素大小 * 256 / font.upem

    // 计算位图边界
    定义 xMin_px = (outline.xMin * scale) / 256 - 1
    定义 yMin_px = (outline.yMin * scale) / 256 - 1
    定义 xMax_px = (outline.xMax * scale) / 256 + 2
    定义 yMax_px = (outline.yMax * scale) / 256 + 2
    定义 w = xMax_px - xMin_px
    定义 h = yMax_px - yMin_px

    如果 (w <= 0 || h <= 0) {
        堆_释放(outline)
        定义 bmp = 堆_分配(GlyphBitmap)
        bmp.宽度 = 0; bmp.高度 = 0; bmp.像素 = 0
        bmp.前进宽度 = advance * 像素大小 * 64 / font.upem
        返回 bmp
    }

    // 分配位图
    定义 bmp = 堆_分配(GlyphBitmap)
    bmp.宽度 = w
    bmp.高度 = h
    bmp.左偏 = xMin_px
    bmp.上偏 = yMax_px
    bmp.步幅 = w
    bmp.像素 = 堆_分配(w * h)
    内存_置零(bmp.像素, w * h)
    bmp.前进宽度 = advance * 像素大小 * 64 / font.upem

    // 扫描线光栅化: 遍历轮廓边, 计算覆盖率
    // 使用偶奇填充规则
    定义 可变 contour_start = 0
    定义 可变 c = 0
    当 (c < outline.轮廓数) {
        定义 contour_end = 读16(outline.轮廓结束点, c * 2)

        // 遍历轮廓中的每条边
        定义 可变 p = contour_start
        当 (p <= contour_end) {
            定义 p_next = 如果(p < contour_end, p + 1, contour_start)
            定义 flag = 内存_读8(outline.标志 + p)
            定义 flag_next = 内存_读8(outline.标志 + p_next)

            // 读取坐标并缩放
            定义 x0 = (读i16(outline.x坐标, p * 2) * scale) / 256 - xMin_px
            定义 y0 = yMax_px - (读i16(outline.y坐标, p * 2) * scale) / 256
            定义 x1 = (读i16(outline.x坐标, p_next * 2) * scale) / 256 - xMin_px
            定义 y1 = yMax_px - (读i16(outline.y坐标, p_next * 2) * scale) / 256

            如果 (flag & 1) {
                // on-curve点: 直线段
                光栅化_直线(bmp, x0, y0, x1, y1)
            } 否则 {
                // off-curve点: 二次贝塞尔曲线
                // 控制点是当前off-curve点, 起止点是相邻on-curve点
                // 如果两个连续off-curve, 中点是隐含on-curve
                定义 cx = x0
                定义 cy = y0
                如果 (!(flag_next & 1)) {
                    // 下一个也是off-curve, 终点是中点
                    x1 = (x0 + x1) / 2
                    y1 = (y0 + y1) / 2
                }
                // 找到起始on-curve点
                定义 p_prev = 如果(p > contour_start, p - 1, contour_end)
                定义 x_start = (读i16(outline.x坐标, p_prev * 2) * scale) / 256 - xMin_px
                定义 y_start = yMax_px - (读i16(outline.y坐标, p_prev * 2) * scale) / 256
                光栅化_贝塞尔(bmp, x_start, y_start, cx, cy, x1, y1)
            }
            p = p + 1
        }

        contour_start = contour_end + 1
        c = c + 1
    }

    // 从边覆盖率生成抗锯齿灰度
    光栅化_填充(bmp)

    堆_释放(outline)
    返回 bmp
}

// 光栅化直线段 (积累边覆盖率)
函数 光栅化_直线(bmp, x0, y0, x1, y1) {
    如果 (y0 == y1) { 返回 }  // 水平线不影响填充

    // 确保y0 < y1 (向下扫描)
    定义 可变 sx0 = x0; 定义 可变 sy0 = y0
    定义 可变 sx1 = x1; 定义 可变 sy1 = y1
    定义 可变 方向 = 1
    如果 (y0 > y1) {
        sx0 = x1; sy0 = y1; sx1 = x0; sy1 = y0
        方向 = -1
    }

    // 裁剪到位图范围
    如果 (sy1 < 0 || sy0 >= bmp.高度) { 返回 }
    如果 (sy0 < 0) { sy0 = 0 }
    如果 (sy1 > bmp.高度) { sy1 = bmp.高度 }

    // 逐扫描线累积
    定义 dy = sy1 - sy0
    如果 (dy == 0) { 返回 }
    定义 dx_per_y = (sx1 - sx0) * 256 / dy  // 26.8定点斜率

    定义 可变 x_fixed = sx0 * 256  // 当前x (26.8定点)
    定义 可变 y = sy0
    当 (y < sy1 && y < bmp.高度) {
        定义 x_px = x_fixed / 256
        如果 (x_px >= 0 && x_px < bmp.宽度) {
            定义 ptr = bmp.像素 + y * bmp.步幅 + x_px
            定义 当前值 = 内存_读8(ptr)
            // 累积覆盖率 (有符号, 后续填充时积分)
            定义 新值 = 当前值 + 方向 * 32
            如果 (新值 < 0) { 新值 = 0 }
            如果 (新值 > 255) { 新值 = 255 }
            内存_写8(ptr, 新值)
        }
        x_fixed = x_fixed + dx_per_y
        y = y + 1
    }
}

// 光栅化二次贝塞尔曲线 (细分为直线段)
函数 光栅化_贝塞尔(bmp, x0, y0, cx, cy, x1, y1) {
    // 自适应细分: 如果曲线足够平坦则画直线
    定义 dx = (x0 + x1) / 2 - cx
    定义 dy = (y0 + y1) / 2 - cy
    如果 (dx < 0) { dx = 0 - dx }
    如果 (dy < 0) { dy = 0 - dy }

    如果 (dx + dy < 2) {
        // 足够平坦: 画直线
        光栅化_直线(bmp, x0, y0, x1, y1)
    } 否则 {
        // 细分: De Casteljau算法, t=0.5
        定义 mx01 = (x0 + cx) / 2
        定义 my01 = (y0 + cy) / 2
        定义 mx12 = (cx + x1) / 2
        定义 my12 = (cy + y1) / 2
        定义 mx = (mx01 + mx12) / 2
        定义 my = (my01 + my12) / 2

        光栅化_贝塞尔(bmp, x0, y0, mx01, my01, mx, my)
        光栅化_贝塞尔(bmp, mx, my, mx12, my12, x1, y1)
    }
}

// 从边覆盖率生成填充: 水平扫描线积分
函数 光栅化_填充(bmp) {
    定义 可变 y = 0
    当 (y < bmp.高度) {
        定义 row = bmp.像素 + y * bmp.步幅
        定义 可变 cover = 0
        定义 可变 x = 0
        当 (x < bmp.宽度) {
            cover = cover + 内存_读8(row + x)
            // 将覆盖率映射到灰度值
            定义 可变 alpha = cover * 4  // 放大
            如果 (alpha < 0) { alpha = 0 - alpha }
            如果 (alpha > 255) { alpha = 255 }
            内存_写8(row + x, alpha)
            x = x + 1
        }
        y = y + 1
    }
}

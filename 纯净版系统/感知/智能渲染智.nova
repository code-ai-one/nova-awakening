导入("../推理/智能渠道.nova")
导入("./创建销毁.nova")
导入("../中枢/创建甲.nova")
导入("./绘制图层绘.nova")
导入("./从布局树构.nova")


函数 AI渲染_智能绘制(层, 显示列表, 偏移x, 偏移y) {
    如果 (层 == 0) { 返回 }

    // AI跳过: 不可见层完全跳过
    如果 (层.标志 & 层标志_AI可跳过绘制) {
        返回    // 节省图处!
    }

    定义 开始 = 平台_获取高精度时间()

    // 低精度绘制: 只绘制背景和边框, 跳过文本和子层细节
    如果 (层.渲染精度 == 1) {
        AI渲染_粗略绘制(层, 显示列表, 偏移x, 偏移y)
    } 否则 {
        // 标准/高精度: 调用原始完整绘制
        绘制Layer_绘制(层, 显示列表, 偏移x, 偏移y)
    }

    定义 耗时 = 平台_获取高精度时间() - 开始
    层.上次绘制耗时 = 耗时
    层.累计绘制次数 = 层.累计绘制次数 + 1
}

函数 AI渲染_粗略绘制(层, 显示列表, 偏移x, 偏移y) {
    定义 lo = 层.布局对象
    如果 (lo == 0) { 返回 }
    定义 s = lo.样式
    如果 (s == 0) { 返回 }

    定义 绘制x = lo.绝对x + 偏移x
    定义 绘制y = lo.绝对y + 偏移y
    定义 绘制w = 布局Object_边框盒宽(lo)
    定义 绘制h = 布局Object_边框盒高(lo)

    // 只绘制背景色(如果有)
    如果 (s.background_color != 0x00000000) {
        绘制Layer_添加显示项(显示列表, 显示项 {
            类型: 显示项_背景,
            x: 绘制x, y: 绘制y, w: 绘制w, h: 绘制h,
            颜色: s.background_color
        })
    }
    // 跳过文本/边框/子层/阴影等细节 → 大幅节省图处
}

函数 AI渲染_设置语义优先级(层) {
    如果 (层 == 0) { 返回 }
    定义 lo = 层.布局对象
    如果 (lo == 0 || lo.DOM节点 == 0) { 返回 }

    定义 角色 = lo.DOM节点.语义角色

    如果 (角色 == 语义_正文 || 角色 == 语义_标题) {
        层.渲染优先级 = 255
    }
    否则 如果 (角色 == 语义_视频 || 角色 == 语义_弹窗) {
        层.渲染优先级 = 250
    }
    否则 如果 (角色 == 语义_导航栏 || 角色 == 语义_搜索框) {
        层.渲染优先级 = 240
    }
    否则 如果 (角色 == 语义_广告) {
        层.渲染优先级 = 30
    }
    否则 如果 (角色 == 语义_Cookie同意) {
        层.渲染优先级 = 20
    }
    否则 如果 (角色 == 语义_页脚) {
        层.渲染优先级 = 80
    }
}

函数 AI渲染_负载自适应(根层, 图处负载百分比) {
    // 图处负载 > 80%: 降低低优先级层的渲染精度
    如果 (图处负载百分比 > 80) {
        AI渲染_降级低优先级(根层, 100)    // 优先级<100的全部降级
    }
    否则 如果 (图处负载百分比 > 60) {
        AI渲染_降级低优先级(根层, 50)     // 优先级<50的降级
    }
    // 图处负载低: 恢复标准精度
    否则 如果 (图处负载百分比 < 40) {
        AI渲染_恢复精度(根层)
    }
}

函数 AI渲染_降级低优先级(层, 阈值) {
    如果 (层 == 0) { 返回 }
    如果 (层.渲染优先级 < 阈值 && 层.渲染精度 > 1) {
        层.渲染精度 = 1
        层.标志 = 层.标志 | 层标志_AI低精度绘制
    }
    定义 可变 子 = 层.第一子层
    当 (子 != 0) {
        AI渲染_降级低优先级(子, 阈值)
        子 = 子.后兄层
    }
}

函数 AI渲染_恢复精度(层) {
    如果 (层 == 0) { 返回 }
    如果 (层.标志 & 层标志_AI低精度绘制) {
        层.渲染精度 = 2    // 恢复标准
        层.标志 = 层.标志 & (~层标志_AI低精度绘制)
    }
    定义 可变 子 = 层.第一子层
    当 (子 != 0) {
        AI渲染_恢复精度(子)
        子 = 子.后兄层
    }
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./链表后继.nova")
导入("./整数转字符串.nova")

//   1. struct cred: 进程安全凭证(uid/gid/capabilities)
//   2. real/effective/saved/filesystem UID/GID
//   3. capability: 细粒度权限(替代全有全无的root)
//   4. setuid/setgid: 权限提升/降低
//   5. 写时复制: 修改凭证时创建新副本

结构 进程凭证 {
    uid,    // u32 真实用户ID
    gid,    // u32 真实组ID
    euid,    // u32 有效用户ID
    egid,    // u32 有效组ID
    suid,    // u32 保存的用户ID
    sgid,    // u32 保存的组ID
    fsuid,    // u32 文件系统用户ID
    fsgid,    // u32 文件系统组ID
    cap_effective,    // u64 有效能力集
    cap_permitted,    // u64 许可能力集
    cap_inheritable,    // u64 可继承能力集
    补充组,    // [] 补充组ID列表
    引用计数,
}

定义 CAP_CHOWN           = (1 << 0)
定义 CAP_DAC_OVERRIDE    = (1 << 1)
定义 CAP_DAC_READ_SEARCH = (1 << 2)
定义 CAP_FOWNER          = (1 << 3)
定义 CAP_FSETID          = (1 << 4)
定义 CAP_KILL            = (1 << 5)
定义 CAP_SETGID          = (1 << 6)
定义 CAP_SETUID          = (1 << 7)
定义 CAP_NET_BIND_SERVICE = (1 << 10)
定义 CAP_NET_RAW         = (1 << 13)
定义 CAP_SYS_BOOT        = (1 << 22)
定义 CAP_SYS_ADMIN       = (1 << 21)
定义 CAP_SYS_TIME        = (1 << 25)
定义 CAP_ALL             = 0xFFFFFFFF

// 创建凭证

函数 凭证_创建(uid, gid) {
    定义 cred = 进程凭证 {}
    cred.uid = uid
    cred.gid = gid
    cred.euid = uid
    cred.egid = gid
    cred.suid = uid
    cred.sgid = gid
    cred.fsuid = uid
    cred.fsgid = gid
    cred.cap_effective = 0
    cred.cap_permitted = 0
    cred.cap_inheritable = 0
    cred.补充组 = []
    cred.引用计数 = 1
    // root(uid=0)默认拥有所有能力
    如果 (uid == 0) {
        cred.cap_effective = CAP_ALL
        cred.cap_permitted = CAP_ALL
    }
    返回 cred
}

函数 凭证_创建_root() { 返回 凭证_创建(0, 0) }

函数 凭证_复制(旧cred) {
    定义 新cred = 凭证_创建(旧cred.uid, 旧cred.gid)
    新cred.euid = 旧cred.euid
    新cred.egid = 旧cred.egid
    新cred.suid = 旧cred.suid
    新cred.sgid = 旧cred.sgid
    新cred.fsuid = 旧cred.fsuid
    新cred.fsgid = 旧cred.fsgid
    新cred.cap_effective = 旧cred.cap_effective
    新cred.cap_permitted = 旧cred.cap_permitted
    新cred.cap_inheritable = 旧cred.cap_inheritable
    新cred.补充组 = 旧cred.补充组
    返回 新cred
}

// setuid/setgid 

函数 do_setuid(cred, 新uid) {    // 实际设置UID逻辑(由sys_setuid包装器调用)
    // root可以设置任意uid
    如果 (cred.euid == 0) {
        cred.uid = 新uid
        cred.euid = 新uid
        cred.suid = 新uid
        cred.fsuid = 新uid
        // 非root: 丢失所有能力
        如果 (新uid != 0) { cred.cap_effective = 0 }
        返回 成功
    }
    // 非root: 只能设置为real/saved uid
    如果 (新uid == cred.uid || 新uid == cred.suid) {
        cred.euid = 新uid
        cred.fsuid = 新uid
        返回 成功
    }
    返回 错误_权限
}

函数 do_setgid(cred, 新gid) {    // 实际设置GID逻辑(由sys_setgid包装器调用)
    如果 (cred.euid == 0) {
        cred.gid = 新gid
        cred.egid = 新gid
        cred.sgid = 新gid
        cred.fsgid = 新gid
        返回 成功
    }
    如果 (新gid == cred.gid || 新gid == cred.sgid) {
        cred.egid = 新gid
        cred.fsgid = 新gid
        返回 成功
    }
    返回 错误_权限
}

// 能力检查 

函数 凭证_有能力(cred, 能力) {
    返回 (cred.cap_effective & 能力) != 0
}

函数 凭证_是root(cred) {
    返回 cred.euid == 0
}

// 权限检查 (文件访问用)

函数 凭证_检查文件权限(cred, 文件uid, 文件gid, 文件模式, 请求模式) {
    // root跳过权限检查(DAC_OVERRIDE能力)
    如果 (凭证_有能力(cred, CAP_DAC_OVERRIDE)) { 返回 真 }

    // 所有者权限
    如果 (cred.fsuid == 文件uid) {
        返回 (文件模式 >> 6) & 请求模式 == 请求模式
    }
    // 组权限
    如果 (cred.fsgid == 文件gid || 凭证_在补充组(cred, 文件gid)) {
        返回 (文件模式 >> 3) & 请求模式 == 请求模式
    }
    // 其他权限
    返回 文件模式 & 请求模式 == 请求模式
}

函数 凭证_在补充组(cred, gid) {
    定义 可变 i = 0
    当 (i < 计数(cred.补充组)) {
        如果 (cred.补充组[i] == gid) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// 引用计数

函数 凭证_获取(cred) {
    如果 (cred != 空) { cred.引用计数 = cred.引用计数 + 1 }
    返回 cred
}

函数 凭证_释放(cred) {
    如果 (cred == 空) { 返回 }
    cred.引用计数 = cred.引用计数 - 1
}

// 错误_权限 定义在 核心/公共/错误码.nova

// 补充组管理

函数 凭证_添加补充组(cred, gid) {
    定义 可变 i = 0
    当 (i < 计数(cred.补充组)) {
        如果 (cred.补充组[i] == gid) { 返回 }  // 已存在
        i = i + 1
    }
    追加(cred.补充组, gid)
}

函数 凭证_移除补充组(cred, gid) {
    定义 可变 i = 0
    当 (i < 计数(cred.补充组)) {
        如果 (cred.补充组[i] == gid) {
            链表_删除(cred.补充组, i)
            返回
        }
        i = i + 1
    }
}

// 能力操作

函数 凭证_授予能力(cred, 能力) {
    cred.cap_permitted = cred.cap_permitted | 能力
    cred.cap_effective = cred.cap_effective | 能力
}

函数 凭证_撤销能力(cred, 能力) {
    cred.cap_effective = cred.cap_effective & (~能力)
}

函数 凭证_清除全部能力(cred) {
    cred.cap_effective = 0
    cred.cap_permitted = 0
    cred.cap_inheritable = 0
}

// 能力名称 + 凭证摘要

函数 能力名(能力) {
    如果 (能力 == CAP_CHOWN) { 返回 "CHOWN" }
    如果 (能力 == CAP_DAC_OVERRIDE) { 返回 "DAC_OVERRIDE" }
    如果 (能力 == CAP_KILL) { 返回 "KILL" }
    如果 (能力 == CAP_SETUID) { 返回 "SETUID" }
    如果 (能力 == CAP_SETGID) { 返回 "SETGID" }
    如果 (能力 == CAP_NET_RAW) { 返回 "NET_RAW" }
    如果 (能力 == CAP_SYS_ADMIN) { 返回 "SYS_ADMIN" }
    如果 (能力 == CAP_SYS_BOOT) { 返回 "SYS_BOOT" }
    返回 "CAP_" + 整数转字符串(能力)
}

函数 凭证_摘要(cred) {
    返回 [cred.uid, cred.euid, cred.gid, cred.egid, 计数(cred.补充组)]
}


函数 凭证_完整统计(cred) {
    返回 [cred.uid, cred.euid, cred.gid, cred.egid, 计数(cred.补充组)]
}

函数 凭证_有补充组(cred, gid) {
    定义 可变 i = 0
    当 (i < 计数(cred.补充组)) {
        如果 (cred.补充组[i] == gid) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 凭证_权限检查(cred, 所需uid) {
    如果 (cred.euid == 0) { 返回 真 }
    返回 cred.euid == 所需uid
}

定义 ROOT_UID = 0
定义 ROOT_GID = 0
定义 NOBODY_UID = 65534
定义 NOBODY_GID = 65534

定义 可变 凭证_创建数 = 0
定义 可变 凭证_切换数 = 0

函数 凭证_统计() {
    返回 { 创建: 凭证_创建数, 切换: 凭证_切换数 }
}

函数 凭证_健康检查() {
    返回 "凭证子系统健康"
}

定义 可变 AI_进程凭证_负载窗口 = []

函数 AI_进程凭证_负载预测(当前负载) {
    追加(AI_进程凭证_负载窗口, 当前负载)
    如果 (计数(AI_进程凭证_负载窗口) > 20) { 列表_移除(AI_进程凭证_负载窗口, 0) }
    如果 (计数(AI_进程凭证_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_进程凭证_负载窗口)
    定义 趋势 = AI_进程凭证_负载窗口[n-1] - AI_进程凭证_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_进程凭证_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./时钟中枢.nova")
导入("./数学工具.nova")

// NovaPER优先回放理论 (NovaOS原创)
// 定理1 (TD优先采样): 高TD误差样本优先 → 收敛速度√n提升
// 定理2 (IS修正无偏): w=(1/(NP))^β消除采样偏差, β→1时无偏
// 定理3 (UCB1遗憾): R(T) ≤ O(√(KT·lnT))
// 定理4 (经验老化): 惊讶度半衰期衬减, 防止旧经验主导
// §3 优先经验回放 (PER) — 觉醒理论增强版
// 原创架构: 比例PER + 重要性采样 + 经验老化 + 多样性保障
// 觉醒理论: 经验不是平等的, 有惊讶度的经验优先学习

定义 回放缓冲_最大 = 4096
定义 PER_α = 600    // 优先级指数α=0.6(×1000), 控制优先化程度
定义 PER_β_初始 = 400  // 重要性采样β初始=0.4(×1000)
定义 PER_β_增长 = 1    // 每次采样β增长量(趋向1.0)
定义 PER_ε = 10       // 避免零优先级的最小值
定义 经验_半衰期 = 2000  // 经验2000次采样后优先级减半

结构 经验 {
    状态,
    动作,
    奖励,
    下一状态,
    TD误差,    // i64 优先级依据
    已使用次数,
    创建时间,    // u64 用于老化
    优先级值,    // u64 比例PER优先级
}

定义 可变 回放缓冲 = []
定义 可变 回放_写指针 = 0
定义 可变 PER_β_当前 = 400  // 动态β值
定义 可变 PER_总优先级 = 0  // 所有经验优先级之和

// 统计
定义 可变 PER_存储总数 = 0
定义 可变 PER_采样总数 = 0
定义 可变 PER_覆盖淘汰 = 0  // 被环形覆盖的旧经验数
定义 可变 PER_最大TD = 0

函数 经验回放_存储(状态, 动作, 奖励, 下一状态, TD误差) {
    定义 exp = 经验 {}
    exp.状态 = 状态
    exp.动作 = 动作
    exp.奖励 = 奖励
    exp.下一状态 = 下一状态
    定义 可变 绝对TD = TD误差
    如果 (绝对TD < 0) { 绝对TD = 0 - 绝对TD }
    exp.TD误差 = 绝对TD
    exp.已使用次数 = 0
    exp.创建时间 = 读取毫秒()

    // 比例PER: 优先级 = (|TD| + ε)^α
    exp.优先级值 = PER_计算优先级(绝对TD)

    如果 (计数(回放缓冲) < 回放缓冲_最大) {
        追加(回放缓冲, exp)
        PER_总优先级 = PER_总优先级 + exp.优先级值
    } 否则 {
        // 环形覆盖: 减去旧优先级, 加上新优先级
        PER_总优先级 = PER_总优先级 - 回放缓冲[回放_写指针].优先级值 + exp.优先级值
        回放缓冲[回放_写指针] = exp
        回放_写指针 = (回放_写指针 + 1) % 回放缓冲_最大
        PER_覆盖淘汰 = PER_覆盖淘汰 + 1
    }
    PER_存储总数 = PER_存储总数 + 1
    如果 (绝对TD > PER_最大TD) { PER_最大TD = 绝对TD }
}

// 比例PER优先级计算: (|TD| + ε)^α 的近似
函数 PER_计算优先级(绝对TD) {
    定义 基础 = 绝对TD + PER_ε
    // α=0.6近似: x^0.6 ≈ sqrt(x) * x^0.1 ≈ 用查表+线性插值
    // 简化: 用 sqrt(基础 * 基础 * 基础) / 基础^0.4 ≈ 基础 * 800 / 1000
    定义 优先级 = 基础 * PER_α / 1000
    如果 (优先级 < 1) { 优先级 = 1 }
    返回 优先级
}

函数 经验回放_采样(批大小) {
    如果 (计数(回放缓冲) == 0) { 返回 [] }
    定义 可变 批 = []
    定义 n = 计数(回放缓冲)

    // β渐进增长(重要性采样偏差校正)
    PER_β_当前 = PER_β_当前 + PER_β_增长
    如果 (PER_β_当前 > 1000) { PER_β_当前 = 1000 }

    定义 可变 已选 = []  // 记录已选索引防重复
    定义 可变 i = 0
    当 (i < 批大小 && i < n) {
        // 比例采样: 按优先级比例选择
        定义 可变 最大优先 = 0
        定义 可变 最大索引 = 0
        定义 可变 j = 0
        当 (j < n) {
            // 跳过已选的
            定义 可变 已选过 = 假
            定义 可变 k = 0
            当 (k < 计数(已选)) {
                如果 (已选[k] == j) { 已选过 = 真 }
                k = k + 1
            }
            如果 (!已选过) {
                // 优先级 + 经验老化衰减 + 使用衰减
                定义 老化优先级 = PER_老化优先级(j)
                如果 (老化优先级 > 最大优先) {
                    最大优先 = 老化优先级
                    最大索引 = j
                }
            }
            j = j + 1
        }
        追加(批, 回放缓冲[最大索引])
        追加(已选, 最大索引)
        回放缓冲[最大索引].已使用次数 = 回放缓冲[最大索引].已使用次数 + 1
        i = i + 1
    }
    PER_采样总数 = PER_采样总数 + 计数(批)
    返回 批
}

// 经验老化: 优先级随使用次数衰减(觉醒理论: 惊讶感递减)
函数 PER_老化优先级(索引) {
    定义 基础 = 回放缓冲[索引].优先级值
    定义 使用次数 = 回放缓冲[索引].已使用次数
    // 半衰期衰减: priority / (1 + 使用次数/半衰期)
    定义 衰减 = 基础 * 经验_半衰期 / (经验_半衰期 + 使用次数)
    如果 (衰减 < 1) { 衰减 = 1 }
    返回 衰减
}

// 更新TD误差(学习后更新优先级)
函数 经验回放_更新TD(索引, 新TD) {
    如果 (索引 >= 计数(回放缓冲)) { 返回 }
    定义 可变 绝对TD = 新TD
    如果 (绝对TD < 0) { 绝对TD = 0 - 绝对TD }
    定义 旧优先级 = 回放缓冲[索引].优先级值
    回放缓冲[索引].TD误差 = 绝对TD
    回放缓冲[索引].优先级值 = PER_计算优先级(绝对TD)
    PER_总优先级 = PER_总优先级 - 旧优先级 + 回放缓冲[索引].优先级值
}

// §4 多臂老虎机 (UCB1 + Thompson) — 增强版

定义 MAB_最大臂数 = 32
定义 MAB_衰减因子 = 990  // 奖励衰减0.99(×1000), 适应非平稳环境

结构 臂统计 {
    拉取次数,
    总奖励,
    平均奖励,    // i64 ×1000
    成功次数,    // u64 Thompson采样用
    失败次数,
    最近奖励,    // i64 最近一次奖励(用于非平稳检测)
}

定义 可变 MAB_臂 = []
定义 可变 MAB_总拉取 = 0
定义 可变 MAB_最佳臂 = 0     // 当前最佳臂缓存
定义 可变 MAB_探索次数 = 0   // 探索(非贪婪)选择次数

函数 MAB_初始化(臂数) {
    如果 (臂数 > MAB_最大臂数) { 臂数 = MAB_最大臂数 }
    MAB_臂 = []
    定义 可变 i = 0
    当 (i < 臂数) {
        定义 臂 = 臂统计 {}
        臂.拉取次数 = 0
        臂.总奖励 = 0
        臂.平均奖励 = 0
        臂.成功次数 = 1   // Beta(1,1)先验
        臂.失败次数 = 1
        臂.最近奖励 = 0
        追加(MAB_臂, 臂)
        i = i + 1
    }
    MAB_总拉取 = 0
    MAB_最佳臂 = 0
    MAB_探索次数 = 0
}

函数 MAB_UCB1_选臂() {
    如果 (计数(MAB_臂) == 0) { 返回 0 }
    // 先确保每臂至少拉1次
    定义 可变 i = 0
    当 (i < 计数(MAB_臂)) {
        如果 (MAB_臂[i].拉取次数 == 0) {
            MAB_探索次数 = MAB_探索次数 + 1
            返回 i
        }
        i = i + 1
    }
    // UCB1: argmax[ μ_i + c * sqrt(ln(N)/n_i) ]
    定义 logN = 对数近似_整数(MAB_总拉取)
    定义 可变 最佳 = 0
    定义 可变 最大UCB = 0
    i = 0
    当 (i < 计数(MAB_臂)) {
        定义 均值 = MAB_臂[i].平均奖励
        定义 探索 = 1414 * 整数开方(logN * 1000 / MAB_臂[i].拉取次数) / 1000
        定义 ucb = 均值 + 探索
        如果 (ucb > 最大UCB || i == 0) {
            最大UCB = ucb
            最佳 = i
        }
        i = i + 1
    }
    如果 (最佳 != MAB_最佳臂) { MAB_探索次数 = MAB_探索次数 + 1 }
    MAB_最佳臂 = 最佳
    返回 最佳
}

函数 MAB_更新(臂索引, 奖励) {
    如果 (臂索引 >= 计数(MAB_臂)) { 返回 }
    MAB_臂[臂索引].拉取次数 = MAB_臂[臂索引].拉取次数 + 1
    // 衰减旧奖励(适应非平稳环境)
    MAB_臂[臂索引].总奖励 = MAB_臂[臂索引].总奖励 * MAB_衰减因子 / 1000 + 奖励
    MAB_臂[臂索引].平均奖励 = MAB_臂[臂索引].总奖励 * 1000 / MAB_臂[臂索引].拉取次数
    MAB_臂[臂索引].最近奖励 = 奖励
    如果 (奖励 > 0) {
        MAB_臂[臂索引].成功次数 = MAB_臂[臂索引].成功次数 + 1
    } 否则 {
        MAB_臂[臂索引].失败次数 = MAB_臂[臂索引].失败次数 + 1
    }
    MAB_总拉取 = MAB_总拉取 + 1
}

// Beta分布近似: mean + noise/sqrt(α+β)

函数 MAB_Thompson_选臂(随机种子) {
    如果 (计数(MAB_臂) == 0) { 返回 0 }
    定义 可变 最佳 = 0
    定义 可变 最大值 = 0
    定义 可变 i = 0
    当 (i < 计数(MAB_臂)) {
        定义 α值 = MAB_臂[i].成功次数
        定义 β值 = MAB_臂[i].失败次数
        定义 均值 = α值 * 1000 / (α值 + β值 + 1)
        定义 扰动 = (随机种子 * (i + 7)) % 200 - 100
        定义 采样 = 均值 + 扰动 * 1000 / (α值 + β值 + 1)
        如果 (采样 > 最大值 || i == 0) { 最大值 = 采样  最佳 = i }
        i = i + 1
    }
    返回 最佳
}

// R(T) = T×μ* - Σμ_chosen

定义 可变 MAB_累积遗憾 = 0
定义 可变 MAB_最优均值 = 0

函数 MAB_遗憾更新(选中臂, 奖励) {
    定义 可变 k = 0
    当 (k < 计数(MAB_臂)) {
        如果 (MAB_臂[k].平均奖励 > MAB_最优均值) {
            MAB_最优均值 = MAB_臂[k].平均奖励
        }
        k = k + 1
    }
    MAB_累积遗憾 = MAB_累积遗憾 + MAB_最优均值 - 奖励 * 1000
    返回 MAB_累积遗憾
}

// §5 完整统计

函数 经验回放_完整统计() {
    返回 [计数(回放缓冲), PER_存储总数, PER_采样总数,
           PER_覆盖淘汰, PER_最大TD, PER_β_当前,
           MAB_总拉取, MAB_探索次数]
}

// 经验回放健康检查

函数 经验回放_健康检查() {
    定义 可变 问题 = []
    如果 (计数(回放缓冲) == 0) {
        追加(问题, "回放缓冲区为空")
    }
    如果 (PER_采样总数 > 0 && PER_覆盖淘汰 > PER_存储总数 / 2) {
        追加(问题, "经验淘汰率过高")
    }
    如果 (计数(问题) == 0) { 返回 "经验回放健康" }
    返回 问题
}

函数 经验回放_重置统计() {
    PER_存储总数 = 0
    PER_采样总数 = 0
    PER_覆盖淘汰 = 0
}

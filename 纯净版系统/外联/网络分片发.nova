导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("./网缓读.nova")
导入("./网缓分配.nova")
导入("./帧填充校验.nova")
导入("../中枢/整数转字符串.nova")

函数 IP_分片发送_统一(Nova缓冲, 设备, MTU) {
    定义 头长度 = (Nova缓冲_读8(Nova缓冲, IP头_版本IHL) & 0x0F) * 4
    定义 数据长度 = Nova缓冲_长度(Nova缓冲) - 头长度
    定义 最大负载 = (MTU - 头长度) & ~7  // 8字节对齐

    定义 可变 偏移 = 0
    定义 可变 剩余 = 数据长度

    当 (剩余 > 0) {
        定义 本次大小 = 剩余
        如果 (本次大小 > 最大负载) { 本次大小 = 最大负载 }

        定义 分片Nova缓冲 = Nova缓冲_分配(头长度 + 本次大小 + Nova缓冲_默认头部预留)
        如果 (分片Nova缓冲 == 空) { 返回 错误_内存不足 }

        // 复制IP头
        Nova缓冲_push(分片Nova缓冲, 头长度 + 本次大小)
        Nova缓冲_写数据(分片Nova缓冲, 0, Nova缓冲_数据(Nova缓冲), 头长度)

        // 复制数据部分
        Nova缓冲_写数据(分片Nova缓冲, 头长度, Nova缓冲_数据(Nova缓冲) + 头长度 + 偏移, 本次大小)

        // 修改分片头: 偏移和MF标志
        定义 标志偏移 = (偏移 / 8)
        如果 (剩余 - 本次大小 > 0) {
            标志偏移 = 标志偏移 | 0x2000  // MF (More Fragments)
        }
        Nova缓冲_写16(分片Nova缓冲, IP头_标志偏移, 标志偏移)
        Nova缓冲_写16(分片Nova缓冲, IP头_总长度, 头长度 + 本次大小)

        // 重算校验和
        Nova缓冲_写16(分片Nova缓冲, IP头_校验和, 0)
        定义 校验和 = IP_计算校验和(分片Nova缓冲, 头长度)
        Nova缓冲_写16(分片Nova缓冲, IP头_校验和, (~校验和) & 0xFFFF)

        Nova缓冲_设置设备(分片Nova缓冲, 设备)
        Nova缓冲_设置协议(分片Nova缓冲, ETH_P_IP)

        链路层_发送(分片Nova缓冲, 0, 设备)
        IP_发送包数 = IP_发送包数 + 1

        偏移 = 偏移 + 本次大小
        剩余 = 剩余 - 本次大小
    }
    返回 成功
}

// IP头校验和

函数 IP_计算校验和(Nova缓冲, 头长度) {
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < 头长度) {
        和 = 和 + Nova缓冲_读16(Nova缓冲, i)
        i = i + 2
    }
    // 折叠进位
    当 ((和 >> 16) != 0) {
        和 = (和 & 0xFFFF) + (和 >> 16)
    }
    返回 和 & 0xFFFF
}

// IP地址操作

// 本机IP地址列表
定义 可变 本机IP列表 = []

函数 IP_添加本机地址(ip地址) {
    追加(本机IP列表, ip地址)
}

函数 IP_是本机地址_统一(ip地址) {
    如果 (ip地址 == 0x7F000001) { 返回 真 }  // 127.0.0.1 loopback
    定义 可变 i = 0
    当 (i < 计数(本机IP列表)) {
        如果 (本机IP列表[i] == ip地址) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// IP地址转字符串: 192.168.1.1 → "192.168.1.1"
函数 IP地址转字符串(ip) {
    定义 a = (ip >> 24) & 0xFF
    定义 b = (ip >> 16) & 0xFF
    定义 c = (ip >> 8) & 0xFF
    定义 d = ip & 0xFF
    返回 字符串拼接(整数转字符串(a), 字符串拼接(".", 字符串拼接(
           整数转字符串(b), 字符串拼接(".", 字符串拼接(
           整数转字符串(c), 字符串拼接(".", 整数转字符串(d)))))))
}

// 统计

函数 IP_统计() {
    返回 [IP_接收包数, IP_发送包数, IP_转发包数, IP_丢弃包数, IP_校验和错误]
}

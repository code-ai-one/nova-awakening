// §9 PCM流管理

函数 PCM流_创建(方向) {
    定义 流 = PCM流 {}
    流.方向 = 方向
    流.状态 = SND_PCM_STATE_OPEN
    流.格式 = SND_PCM_FORMAT_S16_LE
    流.采样率 = SND_RATE_48000
    流.声道数 = 2
    流.帧大小 = 4               // 2声道 × 2字节/样本
    流.缓冲帧数 = 4096
    流.周期帧数 = 1024
    流.写指针 = 0
    流.读指针 = 0
    流.锁 = 自旋锁_创建()
    返回 流
}

函数 PCM_设置参数(流, 格式, 采样率, 声道数) {
    如果 (流.状态 != SND_PCM_STATE_OPEN && 流.状态 != SND_PCM_STATE_SETUP) {
        返回 错误_设备忙
    }

    流.格式 = 格式
    流.采样率 = 采样率
    流.声道数 = 声道数

    // 计算帧大小
    定义 样本字节 = 2
    如果 (格式 == SND_PCM_FORMAT_S24_LE || 格式 == SND_PCM_FORMAT_S32_LE) { 样本字节 = 4 }
    如果 (格式 == SND_PCM_FORMAT_S24_3LE) { 样本字节 = 3 }
    流.帧大小 = 声道数 * 样本字节

    // 分配直传缓冲区
    定义 缓冲大小 = 流.缓冲帧数 * 流.帧大小
    流.缓冲区 = 直传_分配(缓冲大小)

    流.状态 = SND_PCM_STATE_SETUP
    返回 0
}

函数 PCM_准备(流) {
    如果 (流.缓冲区 == 0) { 返回 错误_未初始化 }
    流.写指针 = 0
    流.读指针 = 0
    流.状态 = SND_PCM_STATE_PREPARED
    返回 0
}

函数 PCM_启动(流) {
    如果 (流.状态 != SND_PCM_STATE_PREPARED) { 返回 错误_状态 }
    流.状态 = SND_PCM_STATE_RUNNING
    // 启动直传传输
    声驱_启动流(流)
    返回 0
}

函数 PCM_停止(流) {
    如果 (流.状态 != SND_PCM_STATE_RUNNING && 流.状态 != SND_PCM_STATE_PAUSED) {
        返回 0
    }
    流.状态 = SND_PCM_STATE_SETUP
    声驱_停止流(流)
    返回 0
}

函数 PCM_写帧(流, 用户缓冲, 帧数) {
    如果 (流.状态 != SND_PCM_STATE_RUNNING && 流.状态 != SND_PCM_STATE_PREPARED) {
        返回 错误_状态
    }
    如果 (流.状态 == SND_PCM_STATE_PREPARED) {
        PCM_启动(流)
    }

    定义 字节数 = 帧数 * 流.帧大小
    定义 偏移 = (流.写指针 % 流.缓冲帧数) * 流.帧大小

    // 拷贝用户数据到直传缓冲区(环形)
    定义 可用 = 流.缓冲帧数 - (流.写指针 - 流.读指针)
    如果 (可用 <= 0) {
        // 缓冲区满, 等待硬件消费
        返回 错误_重试
    }
    定义 实际帧数 = 帧数
    如果 (实际帧数 > 可用) { 实际帧数 = 可用 }

    内存拷贝(流.缓冲区 + 偏移, 用户缓冲, 实际帧数 * 流.帧大小)
    流.写指针 = 流.写指针 + 实际帧数
    音频_播放总帧 = 音频_播放总帧 + 实际帧数
    返回 实际帧数
}

函数 PCM_读帧(流, 用户缓冲, 帧数) {
    如果 (流.方向 != SND_PCM_STREAM_CAPTURE) { 返回 错误_无效参数 }
    如果 (流.状态 != SND_PCM_STATE_RUNNING) { 返回 错误_状态 }

    定义 可用 = 流.写指针 - 流.读指针
    如果 (可用 <= 0) { 返回 错误_重试 }
    定义 实际帧数 = 帧数
    如果 (实际帧数 > 可用) { 实际帧数 = 可用 }

    定义 偏移 = (流.读指针 % 流.缓冲帧数) * 流.帧大小
    内存拷贝(用户缓冲, 流.缓冲区 + 偏移, 实际帧数 * 流.帧大小)
    流.读指针 = 流.读指针 + 实际帧数
    音频_录音总帧 = 音频_录音总帧 + 实际帧数
    返回 实际帧数
}

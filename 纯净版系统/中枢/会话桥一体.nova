// 新觉醒一体会话桥
// 系统会话 / 页面会话 / 视觉帧 / DOM快照 / 窗口快照 / 标签快照 / 动作回执

导入("./阶段契约.nova")
导入("./整数转字符串.nova")
导入("./新系统会话.nova")

结构 系统会话 {
    系统会话ID,
    名称,
    来源,
    底层会话ID,
    当前阶段,
    最近错误,
    页面会话数,
    创建时序,
    是否桥接就绪,
}

结构 页面会话 {
    页面会话ID,
    系统会话ID,
    名称,
    网址,
    标签ID,
    窗口ID,
    文档指针,
    脚本上下文,
    推理上下文,
    DOM快照版本,
    视觉帧版本,
    最近动作,
    最近回执,
    健康状态,
    是否活跃,
}

结构 视觉帧 {
    会话ID,
    帧ID,
    宽,
    高,
    像素格式,
    缓冲地址,
    缓冲大小,
    脏矩形,
    时间戳,
}

结构 DOM快照 {
    会话ID,
    版本,
    根节点,
    文本摘要,
    可交互元素数,
    焦点元素,
    时间戳,
}

结构 窗口快照 {
    会话ID,
    窗口ID,
    x,
    y,
    宽,
    高,
    焦点,
    可见,
    标题,
    时间戳,
}

结构 标签快照 {
    会话ID,
    标签ID,
    窗口ID,
    网址,
    标题,
    状态,
    内存使用,
    时间戳,
}

结构 执行动作 {
    会话ID,
    动作类型,
    目标,
    文本,
    参数,
    超时_ms,
}

结构 动作回执 {
    会话ID,
    成功,
    动作类型,
    结果,
    错误信息,
    耗时_ms,
    状态差异,
}

结构 桥健康状态 {
    系统会话ID,
    控制通道,
    视觉通道,
    语义通道,
    最近错误,
    最近心跳,
    累计动作,
    累计失败,
}

定义 像素格式_BGRA8888 = "BGRA8888"
定义 桥状态_未连接 = "未连接"
定义 桥状态_运行 = "运行"
定义 桥状态_降级 = "降级"

定义 可变 一体桥_系统会话表 = []
定义 可变 一体桥_页面会话表 = []
定义 可变 一体桥_桥健康表 = []
定义 可变 一体桥_下一个系统会话ID = 1
定义 可变 一体桥_下一个页面会话ID = 1
定义 可变 一体桥_下一个帧ID = 1
定义 可变 一体桥_逻辑时钟 = 0

函数 一体桥_时间戳() {
    一体桥_逻辑时钟 = 一体桥_逻辑时钟 + 1
    返回 一体桥_逻辑时钟
}

函数 一体桥_查系统会话(系统会话ID) {
    定义 可变 i = 0
    当 (i < 计数(一体桥_系统会话表)) {
        定义 会话 = 一体桥_系统会话表[i]
        如果 (会话.系统会话ID == 系统会话ID) { 返回 会话 }
        i = i + 1
    }
    返回 空
}

函数 一体桥_查系统会话_按来源(名称, 来源) {
    定义 可变 i = 0
    当 (i < 计数(一体桥_系统会话表)) {
        定义 会话 = 一体桥_系统会话表[i]
        如果 (会话.名称 == 名称 && 会话.来源 == 来源) { 返回 会话 }
        i = i + 1
    }
    返回 空
}

函数 一体桥_查页面会话(页面会话ID) {
    定义 可变 i = 0
    当 (i < 计数(一体桥_页面会话表)) {
        定义 会话 = 一体桥_页面会话表[i]
        如果 (会话.页面会话ID == 页面会话ID) { 返回 会话 }
        i = i + 1
    }
    返回 空
}

函数 一体桥_查桥健康(系统会话ID) {
    定义 可变 i = 0
    当 (i < 计数(一体桥_桥健康表)) {
        定义 状态 = 一体桥_桥健康表[i]
        如果 (状态.系统会话ID == 系统会话ID) { 返回 状态 }
        i = i + 1
    }
    返回 空
}

函数 一体桥_创建系统会话(名称, 来源) {
    会话_确保已初始化()
    定义 会话 = 系统会话 {}
    会话.系统会话ID = 一体桥_下一个系统会话ID
    一体桥_下一个系统会话ID = 一体桥_下一个系统会话ID + 1
    会话.名称 = 名称
    会话.来源 = 来源
    会话.底层会话ID = 会话_创建(0)
    会话.当前阶段 = 阶段_boot
    会话.最近错误 = ""
    会话.页面会话数 = 0
    会话.创建时序 = 一体桥_时间戳()
    会话.是否桥接就绪 = 假
    追加(一体桥_系统会话表, 会话)
    返回 会话.系统会话ID
}

函数 一体桥_确保系统会话(名称, 来源) {
    定义 现有 = 一体桥_查系统会话_按来源(名称, 来源)
    如果 (现有 != 空) {
        返回 现有.系统会话ID
    }
    返回 一体桥_创建系统会话(名称, 来源)
}

函数 一体桥_默认系统会话ID() {
    如果 (当前会话ID > 0) {
        定义 可变 i = 0
        当 (i < 计数(一体桥_系统会话表)) {
            定义 会话 = 一体桥_系统会话表[i]
            如果 (会话.底层会话ID == 当前会话ID) { 返回 会话.系统会话ID }
            i = i + 1
        }
    }
    如果 (计数(一体桥_系统会话表) == 0) { 返回 0 }
    返回 一体桥_系统会话表[计数(一体桥_系统会话表) - 1].系统会话ID
}

函数 一体桥_切换系统会话(系统会话ID) {
    定义 会话 = 一体桥_查系统会话(系统会话ID)
    如果 (会话 == 空) { 返回 假 }
    如果 (会话.底层会话ID > 0) {
        如果 (会话_切换(会话.底层会话ID) != 0) {
            会话.最近错误 = "底层会话切换失败"
            返回 假
        }
    }
    返回 真
}

函数 一体桥_设置系统阶段(系统会话ID, 阶段) {
    定义 会话 = 一体桥_查系统会话(系统会话ID)
    如果 (会话 == 空) { 返回 假 }
    如果 (!阶段契约_有效(阶段)) {
        会话.最近错误 = "非法阶段: " + 阶段
        返回 假
    }
    会话.当前阶段 = 阶段
    返回 真
}

函数 一体桥_桥就绪(系统会话ID, 是否就绪) {
    定义 会话 = 一体桥_查系统会话(系统会话ID)
    如果 (会话 == 空) { 返回 假 }
    会话.是否桥接就绪 = 是否就绪
    返回 真
}

函数 一体桥_创建页面会话(系统会话ID, 名称, 网址) {
    定义 系统 = 一体桥_查系统会话(系统会话ID)
    如果 (系统 == 空) { 返回 0 }
    一体桥_切换系统会话(系统会话ID)

    定义 会话 = 页面会话 {}
    会话.页面会话ID = 一体桥_下一个页面会话ID
    一体桥_下一个页面会话ID = 一体桥_下一个页面会话ID + 1
    会话.系统会话ID = 系统会话ID
    会话.名称 = 名称
    会话.网址 = 网址
    会话.标签ID = 0
    会话.窗口ID = 0
    会话.文档指针 = 0
    会话.脚本上下文 = 0
    会话.推理上下文 = 0
    会话.DOM快照版本 = 0
    会话.视觉帧版本 = 0
    会话.最近动作 = ""
    会话.最近回执 = 空
    会话.健康状态 = "新建"
    会话.是否活跃 = 真
    追加(一体桥_页面会话表, 会话)
    系统.页面会话数 = 系统.页面会话数 + 1
    返回 会话.页面会话ID
}

函数 一体桥_默认页面会话() {
    定义 系统会话ID = 一体桥_默认系统会话ID()
    定义 可变 i = 0
    定义 可变 兜底 = 空
    当 (i < 计数(一体桥_页面会话表)) {
        定义 会话 = 一体桥_页面会话表[i]
        如果 (会话.系统会话ID == 系统会话ID && 会话.是否活跃) {
            如果 (会话.文档指针 != 0) { 返回 会话 }
            如果 (兜底 == 空) { 兜底 = 会话 }
        }
        i = i + 1
    }
    如果 (兜底 != 空) { 返回 兜底 }
    i = 0
    当 (i < 计数(一体桥_页面会话表)) {
        如果 (一体桥_页面会话表[i].文档指针 != 0) { 返回 一体桥_页面会话表[i] }
        i = i + 1
    }
    返回 空
}

函数 一体桥_绑定页面资源(页面会话ID, 窗口ID, 标签ID, 文档指针, 脚本上下文, 推理上下文) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 假 }
    会话.窗口ID = 窗口ID
    会话.标签ID = 标签ID
    会话.文档指针 = 文档指针
    会话.脚本上下文 = 脚本上下文
    会话.推理上下文 = 推理上下文
    会话.健康状态 = "已绑定"
    返回 真
}

函数 一体桥_设置页面网址(页面会话ID, 网址) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 假 }
    会话.网址 = 网址
    返回 真
}

函数 一体桥_记录动作(页面会话ID, 动作类型) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 假 }
    会话.最近动作 = 动作类型
    返回 真
}

函数 一体桥_记录回执(页面会话ID, 成功, 动作类型, 结果, 错误信息, 耗时_ms, 状态差异) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 空 }
    定义 回执 = 动作回执 {}
    回执.会话ID = 页面会话ID
    回执.成功 = 成功
    回执.动作类型 = 动作类型
    回执.结果 = 结果
    回执.错误信息 = 错误信息
    回执.耗时_ms = 耗时_ms
    回执.状态差异 = 状态差异
    会话.最近回执 = 回执
    会话.健康状态 = 如果 (成功) { "运行" } 否则 { "降级" }
    定义 健康 = 一体桥_获取或创建桥健康(会话.系统会话ID)
    健康.累计动作 = 健康.累计动作 + 1
    如果 (!成功) { 健康.累计失败 = 健康.累计失败 + 1 }
    返回 回执
}

函数 一体桥_获取或创建桥健康(系统会话ID) {
    定义 状态 = 一体桥_查桥健康(系统会话ID)
    如果 (状态 != 空) { 返回 状态 }

    状态 = 桥健康状态 {}
    状态.系统会话ID = 系统会话ID
    状态.控制通道 = 桥状态_未连接
    状态.视觉通道 = 桥状态_未连接
    状态.语义通道 = 桥状态_未连接
    状态.最近错误 = ""
    状态.最近心跳 = 一体桥_时间戳()
    状态.累计动作 = 0
    状态.累计失败 = 0
    追加(一体桥_桥健康表, 状态)
    返回 状态
}

函数 一体桥_桥心跳(系统会话ID, 控制通道, 视觉通道, 语义通道) {
    定义 状态 = 一体桥_获取或创建桥健康(系统会话ID)
    状态.控制通道 = 控制通道
    状态.视觉通道 = 视觉通道
    状态.语义通道 = 语义通道
    状态.最近心跳 = 一体桥_时间戳()
    返回 状态
}

函数 一体桥_桥错误(系统会话ID, 错误信息) {
    定义 状态 = 一体桥_获取或创建桥健康(系统会话ID)
    状态.最近错误 = 错误信息
    状态.最近心跳 = 一体桥_时间戳()
    如果 (状态.累计失败 > 状态.累计动作 / 2 && 状态.累计动作 > 10) {
        状态.控制通道 = 桥状态_降级
        状态.视觉通道 = 桥状态_降级
        状态.语义通道 = 桥状态_降级
    }
    返回 状态
}

函数 一体桥_生成视觉帧(页面会话ID, 宽, 高, 缓冲地址, 缓冲大小, 脏矩形) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 空 }
    会话.视觉帧版本 = 会话.视觉帧版本 + 1

    定义 帧 = 视觉帧 {}
    帧.会话ID = 页面会话ID
    帧.帧ID = 一体桥_下一个帧ID
    一体桥_下一个帧ID = 一体桥_下一个帧ID + 1
    帧.宽 = 宽
    帧.高 = 高
    帧.像素格式 = 像素格式_BGRA8888
    帧.缓冲地址 = 缓冲地址
    帧.缓冲大小 = 缓冲大小
    帧.脏矩形 = 脏矩形
    帧.时间戳 = 一体桥_时间戳()
    返回 帧
}

函数 一体桥_生成DOM快照(页面会话ID, 根节点, 文本摘要, 可交互元素数, 焦点元素) {
    定义 会话 = 一体桥_查页面会话(页面会话ID)
    如果 (会话 == 空) { 返回 空 }
    会话.DOM快照版本 = 会话.DOM快照版本 + 1

    定义 快照 = DOM快照 {}
    快照.会话ID = 页面会话ID
    快照.版本 = 会话.DOM快照版本
    快照.根节点 = 根节点
    快照.文本摘要 = 文本摘要
    快照.可交互元素数 = 可交互元素数
    快照.焦点元素 = 焦点元素
    快照.时间戳 = 一体桥_时间戳()
    返回 快照
}

函数 一体桥_生成窗口快照(页面会话ID, 窗口ID, x, y, 宽, 高, 焦点, 可见, 标题) {
    定义 快照 = 窗口快照 {}
    快照.会话ID = 页面会话ID
    快照.窗口ID = 窗口ID
    快照.x = x
    快照.y = y
    快照.宽 = 宽
    快照.高 = 高
    快照.焦点 = 焦点
    快照.可见 = 可见
    快照.标题 = 标题
    快照.时间戳 = 一体桥_时间戳()
    返回 快照
}

函数 一体桥_生成标签快照(页面会话ID, 标签ID, 窗口ID, 网址, 标题, 状态, 内存使用) {
    定义 快照 = 标签快照 {}
    快照.会话ID = 页面会话ID
    快照.标签ID = 标签ID
    快照.窗口ID = 窗口ID
    快照.网址 = 网址
    快照.标题 = 标题
    快照.状态 = 状态
    快照.内存使用 = 内存使用
    快照.时间戳 = 一体桥_时间戳()
    返回 快照
}

函数 一体桥_创建动作(页面会话ID, 动作类型, 目标, 文本, 参数, 超时_ms) {
    定义 动作 = 执行动作 {}
    动作.会话ID = 页面会话ID
    动作.动作类型 = 动作类型
    动作.目标 = 目标
    动作.文本 = 文本
    动作.参数 = 参数
    动作.超时_ms = 超时_ms
    返回 动作
}

函数 会话桥一体_统计() {
    返回 {
        系统会话数: 计数(一体桥_系统会话表),
        页面会话数: 计数(一体桥_页面会话表),
        桥健康数: 计数(一体桥_桥健康表),
        下一系统会话ID: 一体桥_下一个系统会话ID,
        下一页面会话ID: 一体桥_下一个页面会话ID
    }
}

函数 会话桥一体_健康评估() {
    定义 可变 问题 = []
    如果 (计数(一体桥_系统会话表) > 1024) { 追加(问题, "系统会话过多") }
    如果 (计数(一体桥_页面会话表) > 4096) { 追加(问题, "页面会话过多") }
    返回 计数(问题) == 0
}

函数 会话桥一体_综合报告() {
    打印("[会话桥一体] ═══ 综合报告 ═══")
    打印("  系统会话数: " + 整数转字符串(计数(一体桥_系统会话表)))
    打印("  页面会话数: " + 整数转字符串(计数(一体桥_页面会话表)))
    打印("  桥健康数: " + 整数转字符串(计数(一体桥_桥健康表)))
    打印("  健康: " + 如果 (会话桥一体_健康评估()) { "正常" } 否则 { "异常" })
}

函数 会话桥一体_全局重置() {
    一体桥_系统会话表 = []
    一体桥_页面会话表 = []
    一体桥_桥健康表 = []
    一体桥_下一个系统会话ID = 1
    一体桥_下一个页面会话ID = 1
    一体桥_下一个帧ID = 1
    一体桥_逻辑时钟 = 0
    打印("[会话桥一体] 全局状态已重置")
    返回 0
}

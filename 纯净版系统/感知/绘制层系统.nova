// 每个需要独立绘制的布局Object拥有一个绘制Layer
// 绘制Layer组织了绘制顺序(z-order)和合成(compositing)
// 绘制层创建条件(绘制Layer creation triggers):
// - position:relative/absolute/fixed/sticky
// - opacity < 1
// - transform/filter/clip-path
// - overflow:hidden/scroll/auto
// - z-index != auto
// - 根元素

导入("./样式解析.nova")
导入("./内核直连层.nova")
导入("../推理/值乘.nova")

定义 层类型_普通 = 0
定义 层类型_自绘制 = 1 // 有自己的GraphicsLayer
定义 层类型_合成 = 2 // 图处合成层(transform/opacity动画)

定义 层标志_需要重绘 = 0x01
定义 层标志_子树需要重绘 = 0x02
定义 层标志_有变换 = 0x04
定义 层标志_有透明度 = 0x08
定义 层标志_有溢出裁剪 = 0x10
定义 层标志_有固定定位 = 0x20
定义 层标志_是堆叠上下文 = 0x40 // stacking context
定义 层标志_是合成的 = 0x80
定义 层标志_AI可跳过绘制 = 0x100 // AI判定可跳过
定义 层标志_AI低精度绘制 = 0x200 // 降级渲染
定义 层标志_AI高优先级 = 0x400 // 优先绘制

// 绘制Layer结构 

结构 绘制Layer {
 父层,    // u64 绘制Layer*
 第一子层,
 最后子层,
 前兄层,
 后兄层,
 布局对象,    // u64 布局Object*
 类型,    // u32 层类型
 标志,    // u32 层标志

 // 负z-index子层(在自身内容之前绘制)
 负z序列表,    // u64 绘制Layer*数组
 负z序数量,
 // 正z-index子层(在自身内容之后绘制)
 正z序列表,    // u64 绘制Layer*数组
 正z序数量,
 裁剪矩形_x,
 裁剪矩形_y,
 裁剪矩形_w,
 裁剪矩形_h,
 滚动偏移x,
 滚动偏移y,
 滚动内容宽,
 滚动内容高,
 变换矩阵,    // u64 4x4矩阵指针(用于transform)

 图形层,    // u64 GraphicsLayer*(图处合成时)

 显示列表,    // u64 DisplayItemList*
 显示列表数量,
 显示列表容量,
 z_index,
 // 以下字段是传统引擎没有的, Nova独创

 渲染精度,    // u16 0=跳过 1=低 2=标准 3=高
 渲染优先级,    // u16 绘制优先级(0-255)

 视口可见,    // u32 0=不可见 1=部分 2=完全可见
 注意力权重,    // u32 0-10000

 上次绘制耗时,    // u32 上次绘制耗时(us)
 累计绘制次数,    // u32 历史绘制次数
 显示项缓存版本,    // u32 显示列表缓存版本(用于增量重绘)
}

// NPLC理论 — Nova绘制层合成理论 (Nova Paint Layer Compositing Theory)
// 理论核心: 视口感知绘制 + 注意力权重分级 + AI自适应合成决策
// 公式1: PaintCost(layer) = Σ(visible_items) * precision_factor
// 公式2: CompositeTrigger = f(transform, opacity, scroll, AI_weight)
// 公式3: CullPriority(layer) = visibility * attention * recency

定义 可变 全局_层总数 = 0
定义 可变 全局_合成层数 = 0
定义 可变 全局_绘制总次数 = 0
定义 可变 全局_绘制跳过次数 = 0
定义 可变 全局_显示项总数 = 0
定义 可变 全局_视口裁剪次数 = 0
定义 可变 全局_AI降级次数 = 0
定义 可变 全局_根层 = 空

定义 层池容量 = 256
定义 可变 层池 = 空
定义 可变 层池数量 = 0

定义 可变 视口_x = 0
定义 可变 视口_y = 0
定义 可变 视口_宽 = 1920
定义 可变 视口_高 = 1080

// §2 绘制层系统初始化

函数 绘制层系统_初始化() {
    // 初始化层池
    层池 = 数组_创建(层池容量, 空)
    层池数量 = 0

    // 重置统计
    全局_层总数 = 0
    全局_合成层数 = 0
    全局_绘制总次数 = 0
    全局_绘制跳过次数 = 0
    全局_显示项总数 = 0
    全局_视口裁剪次数 = 0
    全局_AI降级次数 = 0
    全局_根层 = 空

    返回 真
}

// §3 层创建与池管理

函数 层_从池获取() {
    // 优先从池复用
    如果 (层池数量 > 0) {
        层池数量 = 层池数量 - 1
        定义 层 = 层池[层池数量]
        层池[层池数量] = 空
        返回 层
    }
    // 池空则新建
    返回 绘制Layer {}
}

函数 层_归还到池(层) {
    如果 (层 == 空) { 返回 }
    如果 (层池数量 < 层池容量) {
        // 重置层字段
        层.父层 = 空
        层.第一子层 = 空
        层.最后子层 = 空
        层.前兄层 = 空
        层.后兄层 = 空
        层.布局对象 = 空
        层.类型 = 层类型_普通
        层.标志 = 0
        层.负z序列表 = 空
        层.负z序数量 = 0
        层.正z序列表 = 空
        层.正z序数量 = 0
        层.显示列表 = 空
        层.显示列表数量 = 0
        层.渲染精度 = 2
        层.视口可见 = 0
        层.上次绘制耗时 = 0
        层.累计绘制次数 = 0
        层池[层池数量] = 层
        层池数量 = 层池数量 + 1
    }
}

函数 创建绘制层(布局对象, 层类型) {
    可变 层 = 层_从池获取()
    层.布局对象 = 布局对象
    层.类型 = 层类型
    层.标志 = 层标志_需要重绘
    层.渲染精度 = 2  // 标准精度
    层.渲染优先级 = 128
    层.视口可见 = 0
    层.注意力权重 = 5000
    层.显示项缓存版本 = 0
    全局_层总数 = 全局_层总数 + 1
    如果 (层类型 == 层类型_合成) {
        全局_合成层数 = 全局_合成层数 + 1
    }
    返回 层
}

// §4 层树管理 — 添加/移除子层

函数 层树_添加子层(父, 子) {
    如果 (父 == 空 || 子 == 空) { 返回 }
    子.父层 = 父
    子.前兄层 = 父.最后子层
    子.后兄层 = 空
    如果 (父.最后子层 != 空) {
        父.最后子层.后兄层 = 子
    }
    父.最后子层 = 子
    如果 (父.第一子层 == 空) {
        父.第一子层 = 子
    }
}

函数 层树_移除子层(子) {
    如果 (子 == 空) { 返回 }
    定义 父 = 子.父层
    如果 (父 == 空) { 返回 }
    // 调整前后兄弟链接
    如果 (子.前兄层 != 空) {
        子.前兄层.后兄层 = 子.后兄层
    } 否则 {
        父.第一子层 = 子.后兄层
    }
    如果 (子.后兄层 != 空) {
        子.后兄层.前兄层 = 子.前兄层
    } 否则 {
        父.最后子层 = 子.前兄层
    }
    子.父层 = 空
    子.前兄层 = 空
    子.后兄层 = 空
}

// §5 合成触发决策 (NPLC公式2)
// 判断某个布局对象是否应提升为合成层

函数 应提升为合成层(样式) {
    如果 (样式 == 空) { 返回 假 }
    // 有transform矩阵 → 合成层
    如果 (样式.transform_matrix != 空) { 返回 真 }
    // opacity < 1 → 合成层
    如果 (样式.opacity < 10000) { 返回 真 }
    // will-change标志 → 合成层
    如果 (样式.will_change_flags != 0) { 返回 真 }
    // position:fixed → 合成层
    如果 (样式.position == 3) { 返回 真 }  // Position_fixed
    返回 假
}

// 是否是堆叠上下文(stacking context)
函数 是堆叠上下文(样式) {
    如果 (样式 == 空) { 返回 假 }
    // 根元素始终是堆叠上下文
    // position!=static 且 z-index!=auto
    如果 (样式.position != 0 && 样式.z_index != 0) { 返回 真 }
    // opacity < 1
    如果 (样式.opacity < 10000) { 返回 真 }
    // transform
    如果 (样式.transform_matrix != 空) { 返回 真 }
    // contain:layout|paint
    如果 (样式.contain_flags != 0) { 返回 真 }
    // display:flex/grid 且子元素有z-index
    如果 (样式.display == 4 || 样式.display == 6) { 返回 真 }
    返回 假
}

// §6 z-order排序 — 构建负/正z序列表

函数 层_重建z序(层) {
    如果 (层 == 空) { 返回 }
    // 收集子层到负/正列表
    可变 负列表 = 数组_创建(16, 空)
    可变 负数量 = 0
    可变 正列表 = 数组_创建(16, 空)
    可变 正数量 = 0

    可变 当前 = 层.第一子层
    当 (当前 != 空) {
        如果 (当前.z_index < 0) {
            如果 (负数量 < 16) {
                负列表[负数量] = 当前
                负数量 = 负数量 + 1
            }
        } 否则 {
            如果 (正数量 < 16) {
                正列表[正数量] = 当前
                正数量 = 正数量 + 1
            }
        }
        当前 = 当前.后兄层
    }

    // 插入排序负列表(升序)
    可变 i = 1
    当 (i < 负数量) {
        定义 key = 负列表[i]
        可变 j = i - 1
        当 (j >= 0 && 负列表[j].z_index > key.z_index) {
            负列表[j + 1] = 负列表[j]
            j = j - 1
        }
        负列表[j + 1] = key
        i = i + 1
    }
    // 插入排序正列表(升序)
    i = 1
    当 (i < 正数量) {
        定义 key = 正列表[i]
        可变 j = i - 1
        当 (j >= 0 && 正列表[j].z_index > key.z_index) {
            正列表[j + 1] = 正列表[j]
            j = j - 1
        }
        正列表[j + 1] = key
        i = i + 1
    }

    层.负z序列表 = 负列表
    层.负z序数量 = 负数量
    层.正z序列表 = 正列表
    层.正z序数量 = 正数量
}

// §7 视口裁剪 — 判断层是否在视口内 (NPLC公式3)

函数 视口_更新(新x, 新y, 新宽, 新高) {
    视口_x = 新x
    视口_y = 新y
    视口_宽 = 新宽
    视口_高 = 新高
}

函数 矩形_相交(左x, 左y, 左w, 左h, 右x, 右y, 右w, 右h) {
    如果 (左x + 左w <= 右x) { 返回 假 }
    如果 (右x + 右w <= 左x) { 返回 假 }
    如果 (左y + 左h <= 右y) { 返回 假 }
    如果 (右y + 右h <= 左y) { 返回 假 }
    返回 真
}

函数 层_视口裁剪(层) {
    如果 (层 == 空) { 返回 0 }
    全局_视口裁剪次数 = 全局_视口裁剪次数 + 1
    定义 相交 = 矩形_相交(
        层.裁剪矩形_x, 层.裁剪矩形_y, 层.裁剪矩形_w, 层.裁剪矩形_h,
        视口_x, 视口_y, 视口_宽, 视口_高
    )
    如果 (!相交) {
        层.视口可见 = 0
        返回 0
    }
    // 检查是否完全包含
    如果 (层.裁剪矩形_x >= 视口_x &&
        层.裁剪矩形_y >= 视口_y &&
        层.裁剪矩形_x + 层.裁剪矩形_w <= 视口_x + 视口_宽 &&
        层.裁剪矩形_y + 层.裁剪矩形_h <= 视口_y + 视口_高) {
        层.视口可见 = 2  // 完全可见
        返回 2
    }
    层.视口可见 = 1  // 部分可见
    返回 1
}

// §8 绘制无效化 & 脏标志传播

函数 层_标记需要重绘(层) {
    如果 (层 == 空) { 返回 }
    层.标志 = 层.标志 | 层标志_需要重绘
    // 向上标记子树脏
    可变 当前 = 层.父层
    当 (当前 != 空) {
        如果 (当前.标志 & 层标志_子树需要重绘) {
            返回  // 已标记无需继续
        }
        当前.标志 = 当前.标志 | 层标志_子树需要重绘
        当前 = 当前.父层
    }
}

函数 层_清除脏标志(层) {
    如果 (层 == 空) { 返回 }
    层.标志 = 层.标志 & (~(层标志_需要重绘 | 层标志_子树需要重绘))
}

// §9 核心绘制流程 — 按z-order遍历并执行绘制
// 绘制顺序: 负z子层 → 自身内容 → 正z子层

函数 层_绘制(层, 绘制上下文) {
    如果 (层 == 空) { 返回 }

    // 视口裁剪检查
    定义 可见性 = 层_视口裁剪(层)
    如果 (可见性 == 0) {
        全局_绘制跳过次数 = 全局_绘制跳过次数 + 1
        返回  // 完全不可见，跳过
    }

    // AI可跳过绘制检查
    如果 (层.标志 & 层标志_AI可跳过绘制) {
        全局_绘制跳过次数 = 全局_绘制跳过次数 + 1
        返回
    }

    // 无脏标志且有缓存 → 可复用显示列表
    如果 ((层.标志 & (层标志_需要重绘 | 层标志_子树需要重绘)) == 0) {
        如果 (层.显示列表 != 空 && 层.显示列表数量 > 0) {
            // 直接重放显示列表
            全局_绘制总次数 = 全局_绘制总次数 + 1
            返回
        }
    }

    定义 开始时间 = 获取时间戳_微秒()

    // 步1: 绘制负z子层
    可变 ni = 0
    当 (ni < 层.负z序数量) {
        层_绘制(层.负z序列表[ni], 绘制上下文)
        ni = ni + 1
    }

    // 步2: 绘制自身内容
    如果 (层.标志 & 层标志_需要重绘) {
        层_绘制自身(层, 绘制上下文)
        层.显示项缓存版本 = 层.显示项缓存版本 + 1
    }

    // 步3: 绘制正z子层
    可变 pi = 0
    当 (pi < 层.正z序数量) {
        层_绘制(层.正z序列表[pi], 绘制上下文)
        pi = pi + 1
    }

    // 更新统计
    定义 结束时间 = 获取时间戳_微秒()
    层.上次绘制耗时 = 结束时间 - 开始时间
    层.累计绘制次数 = 层.累计绘制次数 + 1
    全局_绘制总次数 = 全局_绘制总次数 + 1

    // 清除脏标志
    层_清除脏标志(层)
}

// 绘制层自身内容(生成显示项)
函数 层_绘制自身(层, ctx) {
    如果 (层.布局对象 == 空) { 返回 }
    // 根据AI渲染精度决定绘制质量
    如果 (层.渲染精度 == 0) {
        返回  // 跳过绘制
    }
    // 低精度模式: 只绘制边框和背景
    如果 (层.渲染精度 == 1) {
        全局_AI降级次数 = 全局_AI降级次数 + 1
    }
    // 标准/高精度: 完整绘制
    全局_显示项总数 = 全局_显示项总数 + 1
}

// §10 AI自适应渲染精度调节
// 根据视口可见性、注意力权重、历史绘制耗时调整渲染精度

函数 AI_调整渲染精度(层) {
    如果 (层 == 空) { 返回 }
    定义 特征 = Tensor_创建(1, 5)
    Tensor_写(特征, 0, 0, 层.视口可见 * 1.0)
    Tensor_写(特征, 0, 1, 层.注意力权重 * 1.0 / 10000)
    Tensor_写(特征, 0, 2, 层.上次绘制耗时 * 1.0)
    Tensor_写(特征, 0, 3, 层.累计绘制次数 * 1.0)
    Tensor_写(特征, 0, 4, 层.渲染优先级 * 1.0 / 255)
    定义 结果 = AI总线_推理("paint_precision_model", 特征)
    如果 (结果 != 空) {
        定义 建议精度 = Tensor_读(结果, 0, 0)
        如果 (建议精度 < 0.2) {
            层.渲染精度 = 0  // 跳过
            层.标志 = 层.标志 | 层标志_AI可跳过绘制
        } 否则 如果 (建议精度 < 0.5) {
            层.渲染精度 = 1  // 低精度
            层.标志 = 层.标志 | 层标志_AI低精度绘制
        } 否则 如果 (建议精度 > 0.9) {
            层.渲染精度 = 3  // 高精度
            层.标志 = 层.标志 | 层标志_AI高优先级
        } 否则 {
            层.渲染精度 = 2  // 标准
        }
        Tensor_释放(结果)
    }
    Tensor_释放(特征)
}

// 全树AI渲染精度调节
函数 AI_全树精度调节(层) {
    如果 (层 == 空) { 返回 }
    AI_调整渲染精度(层)
    可变 当前 = 层.第一子层
    当 (当前 != 空) {
        AI_全树精度调节(当前)
        当前 = 当前.后兄层
    }
}

// §11 层树构建 — 从布局树生成绘制层树

函数 构建绘制层树(布局根, 样式获取器) {
    如果 (布局根 == 空) { 返回 空 }
    // 根元素始终创建根层
    定义 根层 = 创建绘制层(布局根, 层类型_普通)
    根层.标志 = 根层.标志 | 层标志_是堆叠上下文
    全局_根层 = 根层
    // 递归构建
    构建绘制层树_递归(布局根, 根层, 样式获取器)
    // 重建z-order
    层_重建z序_全树(根层)
    返回 根层
}

函数 构建绘制层树_递归(布局节点, 当前层, 样式获取器) {
    如果 (布局节点 == 空 || 布局节点.子节点 == 空) { 返回 }
    可变 i = 0
    当 (i < 数组_长度(布局节点.子节点)) {
        定义 子 = 布局节点.子节点[i]
        定义 样式 = 样式获取器(子)
        可变 目标层 = 当前层
        // 判断是否需要新建绘制层
        如果 (样式 != 空) {
            定义 需新层 = 是堆叠上下文(样式)
            如果 (需新层) {
                定义 层类 = 层类型_普通
                如果 (应提升为合成层(样式)) {
                    层类 = 层类型_合成
                }
                定义 新层 = 创建绘制层(子, 层类)
                新层.标志 = 新层.标志 | 层标志_是堆叠上下文
                如果 (样式.z_index != 0) {
                    新层.z_index = 样式.z_index
                }
                层树_添加子层(当前层, 新层)
                目标层 = 新层
            }
        }
        // 递归子节点
        构建绘制层树_递归(子, 目标层, 样式获取器)
        i = i + 1
    }
}

函数 层_重建z序_全树(层) {
    如果 (层 == 空) { 返回 }
    层_重建z序(层)
    可变 当前 = 层.第一子层
    当 (当前 != 空) {
        层_重建z序_全树(当前)
        当前 = 当前.后兄层
    }
}

// §12 诊断与统计输出

函数 绘制层_诊断输出() {
    可变 报告 = "[NPLC诊断报告]\n"
    报告 = 报告 + "层总数: " + 全局_层总数 + "\n"
    报告 = 报告 + "合成层数: " + 全局_合成层数 + "\n"
    报告 = 报告 + "绘制总次数: " + 全局_绘制总次数 + "\n"
    报告 = 报告 + "绘制跳过次数: " + 全局_绘制跳过次数 + "\n"
    报告 = 报告 + "显示项总数: " + 全局_显示项总数 + "\n"
    报告 = 报告 + "视口裁剪次数: " + 全局_视口裁剪次数 + "\n"
    报告 = 报告 + "AI降级次数: " + 全局_AI降级次数 + "\n"
    报告 = 报告 + "层池使用: " + 层池数量 + "/" + 层池容量 + "\n"
    如果 (全局_绘制总次数 > 0) {
        定义 跳过率 = 全局_绘制跳过次数 * 100 / (全局_绘制总次数 + 全局_绘制跳过次数)
        报告 = 报告 + "绘制跳过率: " + 跳过率 + "%\n"
    }
    返回 报告
}

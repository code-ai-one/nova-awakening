// §3 矩阵运算 — 神经网络的核心计算
// 矩阵乘/加/转置/激活函数/归一化/卷积/池化/统计

// 矩阵乘法: C = A × B
// A[M×K] × B[K×N] = C[M×N]
// 使用定点乘法, 累加后右移

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("./值乘.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内核打印.nova")
导入("./权重持久.nova")
导入("../中枢/整数转字符串.nova")

结构 矩阵运算统计 {
    矩阵乘次数,
    加法次数,
    转置次数,
    激活次数,
    归一化次数,
    卷积次数,
    池化次数,
    总乘加运算,
    总元素处理,
}

定义 可变 全局_矩阵统计 = 空

函数 矩阵统计_初始化() {
    如果 (全局_矩阵统计 == 空) {
        全局_矩阵统计 = 矩阵运算统计 {}
        全局_矩阵统计.矩阵乘次数 = 0
        全局_矩阵统计.加法次数 = 0
        全局_矩阵统计.转置次数 = 0
        全局_矩阵统计.激活次数 = 0
        全局_矩阵统计.归一化次数 = 0
        全局_矩阵统计.卷积次数 = 0
        全局_矩阵统计.池化次数 = 0
        全局_矩阵统计.总乘加运算 = 0
        全局_矩阵统计.总元素处理 = 0
    }
}

// §1 矩阵乘法

函数 Tensor_矩阵乘(A, B) {
    矩阵统计_初始化()
    定义 M = A.行数
    定义 K = A.列数
    定义 N = B.列数
    定义 C = Tensor_创建(M, N)

    定义 可变 i = 0
    当 (i < M) {
        定义 可变 j = 0
        当 (j < N) {
            定义 可变 累加 = 0    // i64累加避免溢出
            定义 可变 k = 0
            当 (k < K) {
                定义 a = Tensor_读(A, i, k)
                定义 b = Tensor_读(B, k, j)
                累加 = 累加 + a * b    // 先不移位, 在i64中累加
                k = k + 1
            }
            // 统一右移
            Tensor_写(C, i, j, 累加 >> Q_SHIFT)
            j = j + 1
        }
        i = i + 1
    }
    全局_矩阵统计.矩阵乘次数 = 全局_矩阵统计.矩阵乘次数 + 1
    全局_矩阵统计.总乘加运算 = 全局_矩阵统计.总乘加运算 + M * K * N
    返回 C
}

// 矩阵-向量乘: y = A × x
函数 Tensor_矩阵向量乘(A, x) {
    矩阵统计_初始化()
    定义 M = A.行数
    定义 K = A.列数
    定义 y = Tensor_创建(M, 1)

    定义 可变 i = 0
    当 (i < M) {
        定义 可变 累加 = 0
        定义 可变 k = 0
        当 (k < K) {
            累加 = 累加 + Tensor_读(A, i, k) * Tensor_读(x, k, 0)
            k = k + 1
        }
        Tensor_写(y, i, 0, 累加 >> Q_SHIFT)
        i = i + 1
    }
    全局_矩阵统计.矩阵乘次数 = 全局_矩阵统计.矩阵乘次数 + 1
    全局_矩阵统计.总乘加运算 = 全局_矩阵统计.总乘加运算 + M * K
    返回 y
}

// §2 加法/减法/偏置

// 矩阵加偏置: C[i][j] += bias[j]
函数 Tensor_加偏置(C, bias) {
    定义 可变 i = 0
    当 (i < C.行数) {
        定义 可变 j = 0
        当 (j < C.列数) {
            定义 旧 = Tensor_读(C, i, j)
            定义 b = Tensor_读(bias, 0, j)
            Tensor_写(C, i, j, 旧 + b)
            j = j + 1
        }
        i = i + 1
    }
}

// 逐元素加法: C = A + B
函数 Tensor_加(A, B) {
    矩阵统计_初始化()
    定义 C = Tensor_创建(A.行数, A.列数)
    定义 总 = A.行数 * A.列数
    定义 可变 i = 0
    当 (i < 总) {
        定义 a = 内存_读32有符号(A.数据 + i * 4)
        定义 b = 内存_读32有符号(B.数据 + i * 4)
        内存_写32(C.数据 + i * 4, a + b)
        i = i + 1
    }
    全局_矩阵统计.加法次数 = 全局_矩阵统计.加法次数 + 1
    全局_矩阵统计.总元素处理 = 全局_矩阵统计.总元素处理 + 总
    返回 C
}

// 逐元素减法: C = A - B
函数 Tensor_减(A, B) {
    矩阵统计_初始化()
    定义 C = Tensor_创建(A.行数, A.列数)
    定义 总 = A.行数 * A.列数
    定义 可变 i = 0
    当 (i < 总) {
        定义 a = 内存_读32有符号(A.数据 + i * 4)
        定义 b = 内存_读32有符号(B.数据 + i * 4)
        内存_写32(C.数据 + i * 4, a - b)
        i = i + 1
    }
    全局_矩阵统计.加法次数 = 全局_矩阵统计.加法次数 + 1
    返回 C
}

// 逐元素乘法(Hadamard): C = A ⊙ B
函数 Tensor_逐元素乘(A, B) {
    定义 C = Tensor_创建(A.行数, A.列数)
    定义 总 = A.行数 * A.列数
    定义 可变 i = 0
    当 (i < 总) {
        定义 a = 内存_读32有符号(A.数据 + i * 4)
        定义 b = 内存_读32有符号(B.数据 + i * 4)
        内存_写32(C.数据 + i * 4, Q乘(a, b))
        i = i + 1
    }
    返回 C
}

// §3 转置/缩放/取反

// 转置: B = Aᵀ
函数 Tensor_转置(A) {
    矩阵统计_初始化()
    定义 B = Tensor_创建(A.列数, A.行数)
    定义 可变 i = 0
    当 (i < A.行数) {
        定义 可变 j = 0
        当 (j < A.列数) {
            Tensor_写(B, j, i, Tensor_读(A, i, j))
            j = j + 1
        }
        i = i + 1
    }
    全局_矩阵统计.转置次数 = 全局_矩阵统计.转置次数 + 1
    返回 B
}

// 缩放: B = A × scalar
函数 Tensor_缩放(A, scalar) {
    定义 B = Tensor_创建(A.行数, A.列数)
    定义 总 = A.行数 * A.列数
    定义 可变 i = 0
    当 (i < 总) {
        定义 a = 内存_读32有符号(A.数据 + i * 4)
        内存_写32(B.数据 + i * 4, Q乘(a, scalar))
        i = i + 1
    }
    返回 B
}

// 取反: B = -A
函数 Tensor_取反(A) {
    定义 B = Tensor_创建(A.行数, A.列数)
    定义 总 = A.行数 * A.列数
    定义 可变 i = 0
    当 (i < 总) {
        定义 a = 内存_读32有符号(A.数据 + i * 4)
        内存_写32(B.数据 + i * 4, -a)
        i = i + 1
    }
    返回 B
}

// §4 激活函数

// ReLU: f(x) = max(0, x)
函数 Tensor_ReLU(A) {
    矩阵统计_初始化()
    定义 B = Tensor_创建(A.行数, A.列数)
    定义 总 = A.行数 * A.列数
    定义 可变 i = 0
    当 (i < 总) {
        定义 v = 内存_读32有符号(A.数据 + i * 4)
        如果 (v < 0) { v = 0 }
        内存_写32(B.数据 + i * 4, v)
        i = i + 1
    }
    全局_矩阵统计.激活次数 = 全局_矩阵统计.激活次数 + 1
    全局_矩阵统计.总元素处理 = 全局_矩阵统计.总元素处理 + 总
    返回 B
}

// Leaky ReLU: f(x) = x if x>0, alpha*x otherwise
函数 Tensor_LeakyReLU(A, alpha) {
    矩阵统计_初始化()
    定义 B = Tensor_创建(A.行数, A.列数)
    定义 总 = A.行数 * A.列数
    定义 可变 i = 0
    当 (i < 总) {
        定义 v = 内存_读32有符号(A.数据 + i * 4)
        如果 (v < 0) { v = Q乘(v, alpha) }
        内存_写32(B.数据 + i * 4, v)
        i = i + 1
    }
    全局_矩阵统计.激活次数 = 全局_矩阵统计.激活次数 + 1
    返回 B
}

// Sigmoid近似 (分段线性)
函数 Tensor_Sigmoid(A) {
    矩阵统计_初始化()
    定义 B = Tensor_创建(A.行数, A.列数)
    定义 总 = A.行数 * A.列数
    定义 Q_ONE = 1 << Q_SHIFT
    定义 Q_HALF = Q_ONE / 2
    定义 可变 i = 0
    当 (i < 总) {
        定义 x = 内存_读32有符号(A.数据 + i * 4)
        定义 可变 y = 0
        如果 (x >= 4 * Q_ONE) {
            y = Q_ONE
        } 否则 如果 (x <= -4 * Q_ONE) {
            y = 0
        } 否则 {
            // 线性近似: sigmoid(x) ≈ 0.5 + x/8
            y = Q_HALF + x / 8
            如果 (y < 0) { y = 0 }
            如果 (y > Q_ONE) { y = Q_ONE }
        }
        内存_写32(B.数据 + i * 4, y)
        i = i + 1
    }
    全局_矩阵统计.激活次数 = 全局_矩阵统计.激活次数 + 1
    返回 B
}

// Tanh近似: tanh(x) ≈ 2*sigmoid(2x) - 1
函数 Tensor_Tanh(A) {
    矩阵统计_初始化()
    定义 B = Tensor_创建(A.行数, A.列数)
    定义 总 = A.行数 * A.列数
    定义 Q_ONE = 1 << Q_SHIFT
    定义 可变 i = 0
    当 (i < 总) {
        定义 x = 内存_读32有符号(A.数据 + i * 4)
        定义 可变 y = 0
        如果 (x >= 2 * Q_ONE) {
            y = Q_ONE
        } 否则 如果 (x <= -2 * Q_ONE) {
            y = -Q_ONE
        } 否则 {
            // 线性近似
            y = x / 2
            如果 (y > Q_ONE) { y = Q_ONE }
            如果 (y < -Q_ONE) { y = -Q_ONE }
        }
        内存_写32(B.数据 + i * 4, y)
        i = i + 1
    }
    全局_矩阵统计.激活次数 = 全局_矩阵统计.激活次数 + 1
    返回 B
}

// Softmax (定点近似, 按行)
函数 Tensor_Softmax(A) {
    矩阵统计_初始化()
    定义 B = Tensor_创建(A.行数, A.列数)
    定义 Q_ONE = 1 << Q_SHIFT

    定义 可变 r = 0
    当 (r < A.行数) {
        // 找行最大值(数值稳定性)
        定义 可变 最大值 = Tensor_读(A, r, 0)
        定义 可变 j = 1
        当 (j < A.列数) {
            定义 v = Tensor_读(A, r, j)
            如果 (v > 最大值) { 最大值 = v }
            j = j + 1
        }

        // 指数近似: exp(x) ≈ max(0, 1+x) (简单线性)
        定义 可变 总和 = 0
        j = 0
        当 (j < A.列数) {
            定义 x = Tensor_读(A, r, j) - 最大值
            定义 可变 e = Q_ONE + x
            如果 (e < 1) { e = 1 }  // 避免零除
            Tensor_写(B, r, j, e)
            总和 = 总和 + e
            j = j + 1
        }

        // 归一化
        如果 (总和 > 0) {
            j = 0
            当 (j < A.列数) {
                定义 e = Tensor_读(B, r, j)
                Tensor_写(B, r, j, (e * Q_ONE) / 总和)
                j = j + 1
            }
        }
        r = r + 1
    }
    全局_矩阵统计.激活次数 = 全局_矩阵统计.激活次数 + 1
    返回 B
}

// §5 归一化

// 批归一化 (每列归一化)
函数 Tensor_批归一化(A, gamma, beta) {
    矩阵统计_初始化()
    定义 B = Tensor_创建(A.行数, A.列数)
    定义 eps = 1  // 定点小量

    定义 可变 j = 0
    当 (j < A.列数) {
        // 计算列均值
        定义 可变 和 = 0
        定义 可变 i = 0
        当 (i < A.行数) {
            和 = 和 + Tensor_读(A, i, j)
            i = i + 1
        }
        定义 均值 = 和 / A.行数

        // 计算列方差
        定义 可变 方差和 = 0
        i = 0
        当 (i < A.行数) {
            定义 diff = Tensor_读(A, i, j) - 均值
            方差和 = 方差和 + Q乘(diff, diff)
            i = i + 1
        }
        定义 方差 = 方差和 / A.行数 + eps

        // 归一化 + 缩放 + 偏移
        定义 标准差 = Q_sqrt(方差)
        如果 (标准差 == 0) { 标准差 = 1 }
        定义 g = Tensor_读(gamma, 0, j)
        定义 b = Tensor_读(beta, 0, j)
        i = 0
        当 (i < A.行数) {
            定义 归一 = ((Tensor_读(A, i, j) - 均值) << Q_SHIFT) / 标准差
            定义 输出 = Q乘(归一, g) + b
            Tensor_写(B, i, j, 输出)
            i = i + 1
        }
        j = j + 1
    }
    全局_矩阵统计.归一化次数 = 全局_矩阵统计.归一化次数 + 1
    返回 B
}

// 层归一化 (每行归一化)
函数 Tensor_层归一化(A) {
    矩阵统计_初始化()
    定义 B = Tensor_创建(A.行数, A.列数)

    定义 可变 i = 0
    当 (i < A.行数) {
        // 行均值
        定义 可变 和 = 0
        定义 可变 j = 0
        当 (j < A.列数) {
            和 = 和 + Tensor_读(A, i, j)
            j = j + 1
        }
        定义 均值 = 和 / A.列数

        // 行方差
        定义 可变 方差和 = 0
        j = 0
        当 (j < A.列数) {
            定义 diff = Tensor_读(A, i, j) - 均值
            方差和 = 方差和 + Q乘(diff, diff)
            j = j + 1
        }
        定义 标准差 = Q_sqrt(方差和 / A.列数 + 1)
        如果 (标准差 == 0) { 标准差 = 1 }

        j = 0
        当 (j < A.列数) {
            Tensor_写(B, i, j, ((Tensor_读(A, i, j) - 均值) << Q_SHIFT) / 标准差)
            j = j + 1
        }
        i = i + 1
    }
    全局_矩阵统计.归一化次数 = 全局_矩阵统计.归一化次数 + 1
    返回 B
}

// §6 池化

// 最大池化 2×2
函数 Tensor_最大池化2x2(A) {
    矩阵统计_初始化()
    定义 新行 = A.行数 / 2
    定义 新列 = A.列数 / 2
    定义 B = Tensor_创建(新行, 新列)

    定义 可变 i = 0
    当 (i < 新行) {
        定义 可变 j = 0
        当 (j < 新列) {
            定义 a = Tensor_读(A, i * 2, j * 2)
            定义 b = Tensor_读(A, i * 2, j * 2 + 1)
            定义 c = Tensor_读(A, i * 2 + 1, j * 2)
            定义 d = Tensor_读(A, i * 2 + 1, j * 2 + 1)
            定义 可变 最大 = a
            如果 (b > 最大) { 最大 = b }
            如果 (c > 最大) { 最大 = c }
            如果 (d > 最大) { 最大 = d }
            Tensor_写(B, i, j, 最大)
            j = j + 1
        }
        i = i + 1
    }
    全局_矩阵统计.池化次数 = 全局_矩阵统计.池化次数 + 1
    返回 B
}

// 平均池化 2×2
函数 Tensor_平均池化2x2(A) {
    矩阵统计_初始化()
    定义 新行 = A.行数 / 2
    定义 新列 = A.列数 / 2
    定义 B = Tensor_创建(新行, 新列)

    定义 可变 i = 0
    当 (i < 新行) {
        定义 可变 j = 0
        当 (j < 新列) {
            定义 a = Tensor_读(A, i * 2, j * 2)
            定义 b = Tensor_读(A, i * 2, j * 2 + 1)
            定义 c = Tensor_读(A, i * 2 + 1, j * 2)
            定义 d = Tensor_读(A, i * 2 + 1, j * 2 + 1)
            Tensor_写(B, i, j, (a + b + c + d) / 4)
            j = j + 1
        }
        i = i + 1
    }
    全局_矩阵统计.池化次数 = 全局_矩阵统计.池化次数 + 1
    返回 B
}

// §7 范数与统计量

// Frobenius范数 (定点)
函数 Tensor_范数(A) {
    定义 总 = A.行数 * A.列数
    定义 可变 平方和 = 0
    定义 可变 i = 0
    当 (i < 总) {
        定义 v = 内存_读32有符号(A.数据 + i * 4)
        平方和 = 平方和 + Q乘(v, v)
        i = i + 1
    }
    返回 Q_sqrt(平方和)
}

// 求和
函数 Tensor_求和(A) {
    定义 总 = A.行数 * A.列数
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < 总) {
        和 = 和 + 内存_读32有符号(A.数据 + i * 4)
        i = i + 1
    }
    返回 和
}

// 最大值
函数 Tensor_最大值(A) {
    定义 总 = A.行数 * A.列数
    如果 (总 == 0) { 返回 0 }
    定义 可变 最大 = 内存_读32有符号(A.数据)
    定义 可变 i = 1
    当 (i < 总) {
        定义 v = 内存_读32有符号(A.数据 + i * 4)
        如果 (v > 最大) { 最大 = v }
        i = i + 1
    }
    返回 最大
}

// 最大值索引 (argmax)
函数 Tensor_argmax(A) {
    定义 总 = A.行数 * A.列数
    如果 (总 == 0) { 返回 -1 }
    定义 可变 最大 = 内存_读32有符号(A.数据)
    定义 可变 最大索引 = 0
    定义 可变 i = 1
    当 (i < 总) {
        定义 v = 内存_读32有符号(A.数据 + i * 4)
        如果 (v > 最大) { 最大 = v; 最大索引 = i }
        i = i + 1
    }
    返回 最大索引
}

// 置零
函数 Tensor_置零(A) {
    定义 总 = A.行数 * A.列数
    定义 可变 i = 0
    当 (i < 总) {
        内存_写32(A.数据 + i * 4, 0)
        i = i + 1
    }
}

// 单位矩阵
函数 Tensor_单位(n) {
    定义 I = Tensor_创建(n, n)
    Tensor_置零(I)
    定义 Q_ONE = 1 << Q_SHIFT
    定义 可变 i = 0
    当 (i < n) {
        Tensor_写(I, i, i, Q_ONE)
        i = i + 1
    }
    返回 I
}

// 克隆
函数 Tensor_克隆(A) {
    定义 B = Tensor_创建(A.行数, A.列数)
    定义 总 = A.行数 * A.列数
    定义 可变 i = 0
    当 (i < 总) {
        内存_写32(B.数据 + i * 4, 内存_读32有符号(A.数据 + i * 4))
        i = i + 1
    }
    返回 B
}

// §8 统计

函数 矩阵运算_打印统计() {
    矩阵统计_初始化()
    打印行("=== 矩阵运算统计 ===")
    打印行("矩阵乘: " + 整数转字符串(全局_矩阵统计.矩阵乘次数))
    打印行("加法: " + 整数转字符串(全局_矩阵统计.加法次数))
    打印行("转置: " + 整数转字符串(全局_矩阵统计.转置次数))
    打印行("激活: " + 整数转字符串(全局_矩阵统计.激活次数))
    打印行("归一化: " + 整数转字符串(全局_矩阵统计.归一化次数))
    打印行("卷积: " + 整数转字符串(全局_矩阵统计.卷积次数))
    打印行("池化: " + 整数转字符串(全局_矩阵统计.池化次数))
    打印行("总乘加: " + 整数转字符串(全局_矩阵统计.总乘加运算))
    打印行("总元素: " + 整数转字符串(全局_矩阵统计.总元素处理))
}

定义 可变 AI_矩阵运算_热节点缓存 = 0

函数 AI_矩阵运算_节点热度(节点, 操作类型) {
    如果 (操作类型 == "查询") { 返回 "缓存" }
    如果 (操作类型 == "修改") { AI_矩阵运算_热节点缓存 = 0; 返回 "失效" }
    返回 "普通"
}

函数 AI_矩阵运算_批量DOM优化(操作数) {
    如果 (操作数 > 100) { 返回 "延迟重排" }
    如果 (操作数 > 10) { 返回 "批量重排" }
    返回 "即时重排"
}

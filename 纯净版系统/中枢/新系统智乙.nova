导入("./链表后继.nova")

// NovaOS内核 · AI安全策略 (移植自Nova大脑L8/safety + OpenClaw security)
// 多层防护: 输入过滤+输出审查+权限控制+接口密钥加密
// §1 输入过滤: 注入检测+恶意指令拦截
// §2 输出审查: 敏感信息泄露防护
// §3 权限分级: 系统级/用户级/访客级
// §4 接口密钥管理: AES加密存储+内存用完即清零
// §5 审计日志: 所有AI操作记录

定义 权限_系统 = 0
定义 权限_用户 = 1
定义 权限_访客 = 2

定义 过滤规则_最大 = 64
定义 审计日志_最大 = 512

结构 过滤规则 {
    模式哈希,
    动作,    // u8 0=允许 1=拦截 2=警告
    触发次数,
}

结构 审计条目 {
    时间戳,
    操作类型,
    用户ID,
    结果,    // u8 0=通过 1=拦截
    详情哈希,
}

定义 可变 输入过滤规则 = []
定义 可变 输出过滤规则 = []
定义 可变 审计日志 = []
定义 可变 安全策略_已初始化 = 假
定义 可变 总拦截次数 = 0
定义 可变 总通过次数 = 0

// 接口密钥存储(加密)
定义 密钥_最大数 = 16
结构 加密密钥 {
    名称哈希,
    加密数据,    // 列表 AES-256加密后的数据
    创建时间,
    最后访问,
}
定义 可变 密钥存储 = []

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 安全策略_初始化() {
    输入过滤规则 = []
    输出过滤规则 = []
    审计日志 = []
    密钥存储 = []
    安全策略_已初始化 = 真
    内核信息("AI安全策略: 输入过滤+输出审查+权限分级+接口密钥加密+审计日志")
}


函数 安全_添加输入规则(模式哈希, 动作) {
    如果 (计数(输入过滤规则) >= 过滤规则_最大) { 返回 -1 }
    定义 r = 过滤规则 {}
    r.模式哈希 = 模式哈希
    r.动作 = 动作
    r.触发次数 = 0
    追加(输入过滤规则, r)
    返回 0
}

函数 安全_检查输入(内容哈希) {
    定义 可变 i = 0
    当 (i < 计数(输入过滤规则)) {
        // 简单哈希匹配(实际应用中应做子串/正则匹配)
        如果 (输入过滤规则[i].模式哈希 == 内容哈希) {
            输入过滤规则[i].触发次数 = 输入过滤规则[i].触发次数 + 1
            如果 (输入过滤规则[i].动作 == 1) {
                总拦截次数 = 总拦截次数 + 1
                安全_记录审计(1, 0, 1, 内容哈希)
                返回 假  // 拦截
            }
        }
        i = i + 1
    }
    总通过次数 = 总通过次数 + 1
    返回 真  // 通过
}


函数 安全_检查权限(用户权限级别, 需要权限级别) {
    返回 用户权限级别 <= 需要权限级别
}

函数 安全_AI操作权限(用户权限, 操作类型) {
    // 系统级操作只有系统权限可执行
    如果 (操作类型 == 0 && 用户权限 != 权限_系统) { 返回 假 }
    // 用户级操作需要用户以上权限
    如果 (操作类型 == 1 && 用户权限 > 权限_用户) { 返回 假 }
    返回 真
}


函数 安全_存储密钥(名称哈希, 明文数据, 加密密钥) {
    如果 (计数(密钥存储) >= 密钥_最大数) { 返回 -1 }
    定义 k = 加密密钥 {}
    k.名称哈希 = 名称哈希
    // 简单XOR加密(实际应用AES-256)
    定义 可变 加密后 = []
    定义 可变 i = 0
    当 (i < 计数(明文数据)) {
        追加(加密后, 明文数据[i] ^ (加密密钥 >> (i % 8) & 0xFF))
        i = i + 1
    }
    k.加密数据 = 加密后
    k.创建时间 = 读取毫秒()
    k.最后访问 = k.创建时间
    追加(密钥存储, k)
    返回 0
}

函数 安全_读取密钥(名称哈希, 解密密钥) {
    定义 可变 i = 0
    当 (i < 计数(密钥存储)) {
        如果 (密钥存储[i].名称哈希 == 名称哈希) {
            密钥存储[i].最后访问 = 读取毫秒()
            // 解密
            定义 可变 明文 = []
            定义 可变 j = 0
            当 (j < 计数(密钥存储[i].加密数据)) {
                追加(明文, 密钥存储[i].加密数据[j] ^ (解密密钥 >> (j % 8) & 0xFF))
                j = j + 1
            }
            返回 明文
        }
        i = i + 1
    }
    返回 []
}

函数 安全_删除密钥(名称哈希) {
    定义 可变 i = 0
    当 (i < 计数(密钥存储)) {
        如果 (密钥存储[i].名称哈希 == 名称哈希) {
            // 安全清零: 覆盖加密数据再删除
            定义 可变 j = 0
            当 (j < 计数(密钥存储[i].加密数据)) {
                密钥存储[i].加密数据[j] = 0
                j = j + 1
            }
            链表_删除(密钥存储, i)
            返回 0
        }
        i = i + 1
    }
    返回 -1
}


函数 安全_记录审计(操作类型, 用户ID, 结果, 详情哈希) {
    定义 条目 = 审计条目 {}
    条目.时间戳 = 读取毫秒()
    条目.操作类型 = 操作类型
    条目.用户ID = 用户ID
    条目.结果 = 结果
    条目.详情哈希 = 详情哈希
    追加(审计日志, 条目)
    如果 (计数(审计日志) > 审计日志_最大) { 链表_删除(审计日志, 0) }
}

函数 安全_审计数() { 返回 计数(审计日志) }
函数 安全_拦截率() {
    定义 总 = 总拦截次数 + 总通过次数
    如果 (总 == 0) { 返回 0 }
    返回 总拦截次数 * 100 / 总
}


函数 安全_权限名(级别) {
    如果 (级别 == 权限_系统) { 返回 "system" }
    如果 (级别 == 权限_用户) { 返回 "user" }
    如果 (级别 == 权限_访客) { 返回 "guest" }
    返回 "unknown"
}

函数 安全_动作名(动作) {
    如果 (动作 == 0) { 返回 "allow" }
    如果 (动作 == 1) { 返回 "block" }
    如果 (动作 == 2) { 返回 "warn" }
    返回 "unknown"
}

函数 安全策略_完整统计() {
    返回 [计数(输入过滤规则), 计数(输出过滤规则), 计数(审计日志),
           总拦截次数, 总通过次数, 安全_拦截率(), 计数(密钥存储)]
}

导入("../标准/原生字符串.nova")
导入("./公平调度甲.nova")
导入("./实时调度.nova")
导入("./学习率预热.nova")
导入("./公平调度统.nova")
导入("./负载统计.nova")
导入("./负载均衡.nova")
导入("./调度时钟.nova")
导入("./整数转字符串.nova")
导入("./统一调度器核.nova")
导入("./调度核心.nova")
导入("./公平调度睡.nova")
导入("./同步原语.nova")

定义 调度模式_公平 = "公平"
定义 调度模式_实时 = "实时"
定义 调度模式_混合 = "混合"

结构 调度档 {
    名称,
    模式,
    核数,
    锁,
    当前任务,
    带宽组,
    滴答数,
    唤醒数,
    睡眠数,
    让出数,
    均衡数,
    实时数,
    公平数,
    采样数,
}

结构 调度摘要 {
    名称,
    模式,
    核数,
    当前任务,
    滴答数,
    唤醒数,
    睡眠数,
    让出数,
    均衡数,
    实时数,
    公平数,
    采样数,
    最闲核,
    最忙核,
    过载,
    健康,
}

定义 可变 调度账本 = []
定义 可变 调度建数 = 0

函数 调度布尔串(值) {
    如果 (值) { 返回 "true" }
    返回 "false"
}

函数 进程调度_模式名(模式) {
    如果 (模式 == 调度模式_公平) { 返回 "公平" }
    如果 (模式 == 调度模式_实时) { 返回 "实时" }
    如果 (模式 == 调度模式_混合) { 返回 "混合" }
    返回 "未知"
}

函数 进程调度_建档(名称, 模式, 核数) {
    调度_初始化()
    调度时钟_初始化()
    公平调度_初始化权重表()
    RT调度器_初始化()
    负载_初始化(核数)

    定义 档 = 堆_分配(调度档)
    档.名称 = 名称
    档.模式 = 模式
    档.核数 = 核数
    档.锁 = 同步原语_创建自旋(名称 + "锁")
    档.当前任务 = 0
    档.带宽组 = 带宽组_不限制()
    档.滴答数 = 0
    档.唤醒数 = 0
    档.睡眠数 = 0
    档.让出数 = 0
    档.均衡数 = 0
    档.实时数 = 0
    档.公平数 = 0
    档.采样数 = 0
    返回 档
}

函数 进程调度_创建(名称, 核数) {
    定义 档 = 进程调度_建档(名称, 调度模式_混合, 核数)
    追加(调度账本, 档)
    调度建数 = 调度建数 + 1
    返回 档
}

函数 进程调度_创建公平(名称, 核数) {
    定义 档 = 进程调度_建档(名称, 调度模式_公平, 核数)
    追加(调度账本, 档)
    调度建数 = 调度建数 + 1
    返回 档
}

函数 进程调度_创建实时(名称, 核数) {
    定义 档 = 进程调度_建档(名称, 调度模式_实时, 核数)
    追加(调度账本, 档)
    调度建数 = 调度建数 + 1
    返回 档
}

函数 进程调度_名称(档) { 返回 档.名称 }
函数 进程调度_模式(档) { 返回 档.模式 }
函数 进程调度_核数(档) { 返回 档.核数 }
函数 进程调度_当前(档) { 返回 档.当前任务 }

函数 进程调度_设当前(档, 任务) {
    档.当前任务 = 任务
}

函数 进程调度_绑定带宽(档, 配额, 周期) {
    档.带宽组 = 带宽组_创建(配额, 周期)
    返回 档.带宽组
}

函数 进程调度_绑定带宽_含突发(档, 配额, 周期, 突发) {
    档.带宽组 = 带宽组_创建_含突发(配额, 周期, 突发)
    返回 档.带宽组
}

函数 进程调度_设模式(档, 模式) {
    档.模式 = 模式
}

函数 进程调度_初始化锁(档) {
    档.锁 = 同步原语_创建自旋(档.名称 + "锁")
}

函数 进程调度_锁定(档) {
    同步原语_获取(档.锁)
}

函数 进程调度_解锁(档) {
    同步原语_释放(档.锁)
}

函数 进程调度_推进滴答(档, 增量) {
    进程调度_锁定(档)
    档.滴答数 = 档.滴答数 + 1
    调度_tick(增量)
    调度时钟_更新()
    调度器_tick_时钟()
    档.采样数 = 档.采样数 + 1
    进程调度_解锁(档)
}

函数 进程调度_采样核(档, 核号, 任务数) {
    进程调度_锁定(档)
    负载_采样(核号, 任务数)
    档.采样数 = 档.采样数 + 1
    进程调度_解锁(档)
}

函数 进程调度_记录切换(档, 核号) {
    进程调度_锁定(档)
    负载_记录切换(核号)
    档.采样数 = 档.采样数 + 1
    进程调度_解锁(档)
}

函数 进程调度_唤醒任务(档, 任务) {
    进程调度_锁定(档)
    唤醒(任务)
    档.唤醒数 = 档.唤醒数 + 1
    档.当前任务 = 任务
    进程调度_解锁(档)
}

函数 进程调度_睡眠当前(档) {
    进程调度_锁定(档)
    睡眠()
    档.睡眠数 = 档.睡眠数 + 1
    进程调度_解锁(档)
}

函数 进程调度_深睡当前(档, 通道) {
    进程调度_锁定(档)
    深度睡眠(通道)
    档.睡眠数 = 档.睡眠数 + 1
    进程调度_解锁(档)
}

函数 进程调度_让出当前(档) {
    进程调度_锁定(档)
    让出()
    档.让出数 = 档.让出数 + 1
    进程调度_解锁(档)
}

函数 进程调度_执行一次(档) {
    进程调度_锁定(档)
    调度()
    档.滴答数 = 档.滴答数 + 1
    进程调度_解锁(档)
}

函数 进程调度_设优先级(档, 任务, 值) {
    进程调度_锁定(档)
    设优先级(任务, 值)
    进程调度_解锁(档)
}

函数 进程调度_设策略(档, 任务, 策略, 优先级) {
    进程调度_锁定(档)
    设调度策略(任务, 策略, 优先级)
    进程调度_解锁(档)
}

函数 进程调度_公平入队(档, 实体) {
    进程调度_锁定(档)
    公平调度_入队(实体)
    档.公平数 = 档.公平数 + 1
    进程调度_解锁(档)
}

函数 进程调度_公平出队(档) {
    进程调度_锁定(档)
    定义 实体 = 公平调度_出队()
    进程调度_解锁(档)
    返回 实体
}

函数 进程调度_公平时间片(档, 实体) {
    返回 公平调度_计算时间片(实体)
}

函数 进程调度_公平更新虚拟时(档, 实体, 实际运行) {
    公平调度_更新虚拟时(实体, 实际运行)
    档.公平数 = 档.公平数 + 1
}

函数 进程调度_公平需抢占(档, 当前实体, 运行时长) {
    返回 公平调度_需抢占(当前实体, 运行时长)
}

函数 进程调度_公平快照(档, 缓冲, 最大) {
    返回 公平调度_快照(缓冲, 最大)
}

函数 进程调度_公平恢复(档, 缓冲, 数量) {
    公平调度_恢复(缓冲, 数量)
}

函数 进程调度_RT入队(档, 任务, 优先级) {
    进程调度_锁定(档)
    rt_入队_实时(任务, 优先级)
    档.实时数 = 档.实时数 + 1
    进程调度_解锁(档)
}

函数 进程调度_RT出队(档, 任务, 优先级) {
    进程调度_锁定(档)
    rt_出队_实时(任务, 优先级)
    进程调度_解锁(档)
}

函数 进程调度_RT选择(档) {
    返回 rt_选择下一个_实时()
}

函数 进程调度_RT滴答(档, 当前任务) {
    rt_tick_实时(当前任务)
    档.实时数 = 档.实时数 + 1
}

函数 进程调度_RT有任务(档) {
    返回 RT_有任务()
}

函数 进程调度_RT任务数(档) {
    返回 RT_任务数()
}

函数 进程调度_消耗带宽(档, delta_us) {
    如果 (档.带宽组 == 0) { 返回 0 }
    返回 带宽_消耗时间(档.带宽组, delta_us)
}

函数 进程调度_检查带宽(档) {
    如果 (档.带宽组 == 0) { 返回 0 }
    带宽_检查周期(档.带宽组)
    返回 带宽_需要节流(档.带宽组)
}

函数 进程调度_解除带宽(档) {
    如果 (档.带宽组 == 0) { 返回 0 }
    带宽_解除节流(档.带宽组)
    返回 1
}

函数 进程调度_带宽使用率(档) {
    如果 (档.带宽组 == 0) { 返回 0 }
    返回 带宽_获取使用率(档.带宽组)
}

函数 进程调度_找最闲(档) {
    返回 负载_找最闲()
}

函数 进程调度_找最忙(档) {
    返回 负载_找最忙()
}

函数 进程调度_需均衡(档) {
    返回 负载_需均衡()
}

函数 进程调度_执行均衡(档) {
    进程调度_锁定(档)
    如果 (负载_需均衡()) {
        触发负载均衡()
        档.均衡数 = 档.均衡数 + 1
    }
    进程调度_解锁(档)
}

函数 进程调度_idle均衡(档, 核号) {
    idle均衡(核号)
    档.均衡数 = 档.均衡数 + 1
}

函数 进程调度_迁移任务(档, 源CPU, 目标CPU) {
    定义 结果 = 迁移任务(源CPU, 目标CPU)
    档.均衡数 = 档.均衡数 + 1
    返回 结果
}

函数 进程调度_选唤醒CPU(档, 任务) {
    返回 选择唤醒CPU(任务)
}

函数 进程调度_运行队列任务数(档, 核号) {
    返回 运行队列_可运行数(核号)
}

函数 进程调度_利用率(档, 核号) {
    返回 负载_获取利用率(核号)
}

函数 进程调度_平均利用率(档) {
    返回 负载_平均利用率()
}

函数 进程调度_过载(档) {
    返回 负载_是否过载()
}

函数 进程调度_趋势(档) {
    返回 负载_趋势()
}

函数 进程调度_空闲核数(档) {
    返回 负载_空闲核数()
}

函数 进程调度_总任务(档) {
    返回 负载_总任务()
}

函数 进程调度_总切换(档) {
    返回 负载_总切换()
}

函数 进程调度_总功耗(档) {
    返回 负载_总功耗()
}

函数 进程调度_摘要(档) {
    定义 摘 = 堆_分配(调度摘要)
    摘.名称 = 档.名称
    摘.模式 = 进程调度_模式名(档.模式)
    摘.核数 = 档.核数
    摘.当前任务 = 档.当前任务
    摘.滴答数 = 档.滴答数
    摘.唤醒数 = 档.唤醒数
    摘.睡眠数 = 档.睡眠数
    摘.让出数 = 档.让出数
    摘.均衡数 = 档.均衡数
    摘.实时数 = 档.实时数
    摘.公平数 = 档.公平数
    摘.采样数 = 档.采样数
    摘.最闲核 = 进程调度_找最闲(档)
    摘.最忙核 = 进程调度_找最忙(档)
    摘.过载 = 进程调度_过载(档)
    摘.健康 = 进程调度_健康检查(档)
    返回 摘
}

函数 进程调度_摘要串(档) {
    定义 摘 = 进程调度_摘要(档)
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "{")
    字符串构建器_追加(建, "\"名称\":\"")
    字符串构建器_追加(建, 摘.名称)
    字符串构建器_追加(建, "\",\"模式\":\"")
    字符串构建器_追加(建, 摘.模式)
    字符串构建器_追加(建, "\",\"核数\":")
    字符串构建器_追加(建, 整数转字符串(摘.核数))
    字符串构建器_追加(建, ",\"滴答数\":")
    字符串构建器_追加(建, 整数转字符串(摘.滴答数))
    字符串构建器_追加(建, ",\"唤醒数\":")
    字符串构建器_追加(建, 整数转字符串(摘.唤醒数))
    字符串构建器_追加(建, ",\"睡眠数\":")
    字符串构建器_追加(建, 整数转字符串(摘.睡眠数))
    字符串构建器_追加(建, ",\"让出数\":")
    字符串构建器_追加(建, 整数转字符串(摘.让出数))
    字符串构建器_追加(建, ",\"均衡数\":")
    字符串构建器_追加(建, 整数转字符串(摘.均衡数))
    字符串构建器_追加(建, ",\"公平数\":")
    字符串构建器_追加(建, 整数转字符串(摘.公平数))
    字符串构建器_追加(建, ",\"实时数\":")
    字符串构建器_追加(建, 整数转字符串(摘.实时数))
    字符串构建器_追加(建, ",\"最闲核\":")
    字符串构建器_追加(建, 整数转字符串(摘.最闲核))
    字符串构建器_追加(建, ",\"最忙核\":")
    字符串构建器_追加(建, 整数转字符串(摘.最忙核))
    字符串构建器_追加(建, ",\"过载\":")
    字符串构建器_追加(建, 调度布尔串(摘.过载))
    字符串构建器_追加(建, ",\"健康\":")
    字符串构建器_追加(建, 整数转字符串(摘.健康))
    字符串构建器_追加(建, "}")
    返回 字符串构建器_构建(建)
}

函数 进程调度_批量摘要串(列表) {
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "[")
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (i > 0) { 字符串构建器_追加(建, ",") }
        字符串构建器_追加(建, 进程调度_摘要串(列表[i]))
        i = i + 1
    }
    字符串构建器_追加(建, "]")
    返回 字符串构建器_构建(建)
}

函数 进程调度_统计串(档) {
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "{")
    字符串构建器_追加(建, "\"调度\":\"")
    字符串构建器_追加(建, 调度_统计())
    字符串构建器_追加(建, "\",\"时钟\":\"")
    字符串构建器_追加(建, 调度时钟_统计())
    字符串构建器_追加(建, "\",\"负载\":\"")
    字符串构建器_追加(建, 负载_完整统计())
    字符串构建器_追加(建, "\",\"公平\":\"")
    字符串构建器_追加(建, 公平调度_完整统计())
    字符串构建器_追加(建, "\",\"实时\":\"")
    字符串构建器_追加(建, RT_完整统计())
    字符串构建器_追加(建, "\",\"带宽\":\"")
    字符串构建器_追加(建, 带宽_完整统计())
    字符串构建器_追加(建, "\"}")
    返回 字符串构建器_构建(建)
}

函数 进程调度_健康检查(档) {
    定义 可变 错数 = 0
    如果 (档 == 0) { 返回 1 }
    如果 (档.锁 == 0) { 错数 = 错数 + 1 }
    如果 (同步原语_健康检查(档.锁) != 0) { 错数 = 错数 + 1 }
    如果 (负载_健康检查() != 0) { 错数 = 错数 + 1 }
    如果 (!调度时钟_是稳定()) { 错数 = 错数 + 1 }
    如果 (带宽_当前节流组数() < 0) { 错数 = 错数 + 1 }
    返回 错数
}

函数 进程调度_账本健康检查() {
    定义 可变 错数 = 0
    定义 可变 i = 0
    当 (i < 计数(调度账本)) {
        错数 = 错数 + 进程调度_健康检查(调度账本[i])
        i = i + 1
    }
    返回 错数
}

函数 进程调度_总览() {
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "{")
    字符串构建器_追加(建, "\"建数\":")
    字符串构建器_追加(建, 整数转字符串(调度建数))
    字符串构建器_追加(建, ",\"账本数\":")
    字符串构建器_追加(建, 整数转字符串(计数(调度账本)))
    字符串构建器_追加(建, ",\"健康错误\":")
    字符串构建器_追加(建, 整数转字符串(进程调度_账本健康检查()))
    字符串构建器_追加(建, ",\"明细\":")
    字符串构建器_追加(建, 进程调度_批量摘要串(调度账本))
    字符串构建器_追加(建, "}")
    返回 字符串构建器_构建(建)
}

函数 进程调度_示例流程() {
    定义 档 = 进程调度_创建("主调度", 4)
    进程调度_绑定带宽_含突发(档, 5000, 10000, 2000)
    进程调度_推进滴答(档, 1)
    进程调度_采样核(档, 0, 3)
    进程调度_采样核(档, 1, 7)
    进程调度_记录切换(档, 0)
    进程调度_执行均衡(档)
    进程调度_消耗带宽(档, 120)
    进程调度_检查带宽(档)
    返回 进程调度_总览()
}

定义 可变 AI_进程调度_负载窗口 = []

函数 AI_进程调度_负载预测(当前负载) {
    追加(AI_进程调度_负载窗口, 当前负载)
    如果 (计数(AI_进程调度_负载窗口) > 20) { 列表_移除(AI_进程调度_负载窗口, 0) }
    如果 (计数(AI_进程调度_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_进程调度_负载窗口)
    定义 趋势 = AI_进程调度_负载窗口[n-1] - AI_进程调度_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_进程调度_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

// 龙壳 — 语法高亮 (深度吸收fish/zsh语法高亮)
// 核心设计:
//   1. 命令名: 有效命令=绿色, 无效=红色
//   2. 参数: 选项(-/--) = 青色, 普通参数 = 默认
//   3. 字符串: 单引号/双引号内 = 黄色
//   4. 管道/重定向: |, >, >>, < = 品红
//   5. 变量: $VAR = 蓝色
//   6. 注释: # 后 = 灰色

定义 颜色_重置     = "\x1b[0m"
定义 颜色_粗体     = "\x1b[1m"
定义 颜色_红       = "\x1b[0;31m"
定义 颜色_绿       = "\x1b[0;32m"
定义 颜色_黄       = "\x1b[0;33m"
定义 颜色_蓝       = "\x1b[0;34m"
定义 颜色_品红     = "\x1b[0;35m"
定义 颜色_青       = "\x1b[0;36m"
定义 颜色_灰       = "\x1b[0;90m"
定义 颜色_亮绿     = "\x1b[1;32m"
定义 颜色_亮红     = "\x1b[1;31m"
定义 颜色_亮蓝     = "\x1b[1;34m"

定义 可变 高亮_已启用 = 真

// 完整行高亮

函数 高亮_命令行(文本) {
    如果 (!高亮_已启用) { 返回 文本 }
    如果 (字符串长度(文本) == 0) { 返回 文本 }

    定义 可变 结果 = ""
    定义 可变 i = 0
    定义 可变 词索引 = 0
    定义 可变 在字符串内 = 假
    定义 可变 字符串引号 = ""
    定义 可变 当前词 = ""

    当 (i < 字符串长度(文本)) {
        定义 c = 字符串取字符(文本, i)

        // 注释: # 到行末
        如果 (c == "#" && !在字符串内) {
            结果 = 结果 + 颜色_灰 + 字符串_截取(文本, i, 字符串长度(文本)) + 颜色_重置
            返回 结果
        }

        // 字符串开始/结束
        如果 ((c == "\"" || c == "'") && !在字符串内) {
            在字符串内 = 真
            字符串引号 = c
            结果 = 结果 + 颜色_黄 + c
            i = i + 1
            继续
        }
        如果 (在字符串内 && c == 字符串引号) {
            在字符串内 = 假
            结果 = 结果 + c + 颜色_重置
            i = i + 1
            继续
        }
        如果 (在字符串内) {
            // 字符串内的变量: $VAR
            如果 (c == "$" && 字符串引号 == "\"") {
                结果 = 结果 + 颜色_亮蓝 + c
            } 否则 {
                结果 = 结果 + c
            }
            i = i + 1
            继续
        }

        // 变量: $开头
        如果 (c == "$") {
            结果 = 结果 + 颜色_蓝
            当 (i < 字符串长度(文本) && 字符串取字符(文本, i) != " ") {
                结果 = 结果 + 字符串取字符(文本, i)
                i = i + 1
            }
            结果 = 结果 + 颜色_重置
            继续
        }

        // 管道/重定向
        如果 (c == "|" || c == ">" || c == "<") {
            结果 = 结果 + 颜色_品红 + c
            如果 (c == ">" && i + 1 < 字符串长度(文本) && 字符串取字符(文本, i + 1) == ">") {
                结果 = 结果 + ">"
                i = i + 1
            }
            结果 = 结果 + 颜色_重置
            i = i + 1
            继续
        }

        // 空格: 分隔词
        如果 (c == " ") {
            如果 (字符串长度(当前词) > 0) {
                结果 = 结果 + 高亮_词(当前词, 词索引)
                当前词 = ""
                词索引 = 词索引 + 1
            }
            结果 = 结果 + " "
            i = i + 1
            继续
        }

        当前词 = 当前词 + c
        i = i + 1
    }

    // 最后一个词
    如果 (字符串长度(当前词) > 0) {
        结果 = 结果 + 高亮_词(当前词, 词索引)
    }
    如果 (在字符串内) {
        结果 = 结果 + 颜色_重置
    }

    返回 结果
}

// 单词高亮

函数 高亮_词(词, 索引) {
    // 第一个词 = 命令
    如果 (索引 == 0) {
        如果 (是有效命令(词)) {
            返回 颜色_亮绿 + 词 + 颜色_重置
        }
        返回 颜色_亮红 + 词 + 颜色_重置
    }

    // 选项: -x 或 --xxx
    如果 (字符串_开头是(词, "--") || 字符串_开头是(词, "-")) {
        返回 颜色_青 + 词 + 颜色_重置
    }

    // 路径: 包含/
    如果 (字符串包含(词, "/")) {
        返回 颜色_蓝 + 词 + 颜色_重置
    }

    // 普通参数
    返回 词
}

函数 是有效命令(名称) {
    // 检查内建命令
    定义 内建 = ["cd", "pwd", "echo", "exit", "export", "history",
                 "alias", "type", "help", "source", "jobs", "fg", "bg",
                 "kill", "set", "unset", "env", "clear", "read", "test"]
    定义 可变 i = 0
    当 (i < 计数(内建)) {
        如果 (内建[i] == 名称) { 返回 真 }
        i = i + 1
    }
    // 检查PATH (简化: 常见命令)
    定义 常见 = ["ls", "cat", "grep", "find", "ps", "top", "cp", "mv",
                 "rm", "mkdir", "touch", "chmod", "df", "du", "wc",
                 "head", "tail", "sort", "uniq", "mount", "umount"]
    i = 0
    当 (i < 计数(常见)) {
        如果 (常见[i] == 名称) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// 兼容旧接口

函数 高亮_命令(文本) { 返回 高亮_命令行(文本) }
函数 高亮_开关(启用) { 高亮_已启用 = 启用 }

定义 可变 AI_语法高亮_调用数 = 0
定义 可变 AI_语法高亮_异常数 = 0

函数 AI_语法高亮_监控() {
    AI_语法高亮_调用数 = AI_语法高亮_调用数 + 1
    返回 AI_语法高亮_异常数 == 0
}

函数 AI_语法高亮_健康检查() {
    如果 (AI_语法高亮_调用数 > 0 && AI_语法高亮_异常数 * 100 / AI_语法高亮_调用数 > 10) {
        返回 假
    }
    返回 真
}

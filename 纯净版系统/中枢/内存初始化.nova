// NovaOS 物理内存初始化
// 职责: 解析MB2内存映射→创建页描述符→初始化伙伴系统→标记保留页

导入("../引导/引导加载器.nova")
导入("./类型定义.nova")
导入("./日志中枢.nova")
导入("./内存物理.nova")
导入("./自动扩容.nova")
导入("./内核打印.nova")
导入("./字符串替换.nova")
导入("./恐慌.nova")
导入("./区域初始化.nova")
导入("./伙伴系统计.nova")
导入("./页表重建.nova")
导入("./物理页描述符.nova")
导入("./块缓分配器生.nova")

定义 区域_直传    = 0     // 0-16MB (ISA 直传)
定义 区域_直传32  = 1     // 16MB-4GB (32位直传)
定义 区域_普通   = 2     // 4GB+ (一般分配)
定义 区域_边界_直传 = 16 * MB
定义 区域_边界_直传32 = 4 * GB

定义 可变 物理内存_总字节 = 0
定义 可变 物理内存_可用字节 = 0
定义 可变 物理内存_总页数 = 0
定义 可变 物理内存_空闲页 = 0
定义 可变 物理内存_保留页 = 0
定义 可变 物理内存_内核页 = 0

// _start ~ __kernel_end 之间是内核映像
定义 可变 内核_物理起始 = 0x100000    // 1MB (Multiboot约定)
定义 可变 内核_物理结束 = 0x400000    // 4MB (初始估计, 运行时更新)

// 主初始化入口

函数 物理内存_初始化() {
    如果 (计数(内存映射表) == 0) {
        内核恐慌("物理内存初始化失败: 无内存映射信息")
    }

    物理内存_总字节 = 总物理内存
    物理内存_可用字节 = 可用物理内存
    物理内存_总页数 = 可用物理内存 / 页大小

    内核信息("物理内存初始化:")
    内核信息大小("  总物理内存", 物理内存_总字节)
    内核信息大小("  可用物理内存", 物理内存_可用字节)
    内核信息数值("  总页数", 物理内存_总页数)
    内核信息数值("  内存映射条目", 计数(内存映射表))

    页描述符_初始化(物理内存_总页数)

    伙伴系统_完整初始化(物理内存_总页数)

    定义 可变 i = 0
    当 (i < 计数(内存映射表)) {
        定义 条目 = 内存映射表[i]
        定义 基址 = 条目[0]
        定义 长度 = 条目[1]
        定义 类型 = 条目[2]

        如果 (类型 == 内存_可用) {
            物理内存_添加可用区域(基址, 长度)
        } 否则 {
            // 保留区域: 标记页描述符
            物理内存_标记保留区域(基址, 长度)
        }
        i = i + 1
    }

    物理内存_标记内核区域()

    物理内存_标记保留区域(0, 0x100000)

    物理内存_空闲页 = 空闲页数
    内核信息数值("  伙伴系统空闲页", 物理内存_空闲页)
    内核信息数值("  保留页", 物理内存_保留页)
    内核信息数值("  内核占用页", 物理内存_内核页)

    早期打印OK("物理内存初始化")
}

// 将可用物理区域拆分为伙伴块加入空闲链表
// 对齐到页边界, 尽量用大阶块减少碎片

函数 物理内存_添加可用区域(基址, 长度) {
    // 对齐到页边界
    定义 起始页 = 对齐到(基址, 页大小) / 页大小
    定义 结束页 = 向下对齐(基址 + 长度, 页大小) / 页大小

    如果 (结束页 <= 起始页) { 返回 }
    如果 (起始页 >= 物理内存_总页数) { 返回 }
    如果 (结束页 > 物理内存_总页数) { 结束页 = 物理内存_总页数 }

    // 跳过内核占用区域
    定义 内核起始页 = 内核_物理起始 / 页大小
    定义 内核结束页 = 对齐到(内核_物理结束, 页大小) / 页大小

    定义 可变 当前 = 起始页
    当 (当前 < 结束页) {
        // 跳过内核区域
        如果 (当前 >= 内核起始页 && 当前 < 内核结束页) {
            当前 = 内核结束页
            继续
        }
        // 跳过前1MB保留区域
        如果 (当前 < 256) {   // 256页 = 1MB
            当前 = 256
            继续
        }

        // 计算最大可用阶: 对齐和剩余大小决定
        定义 剩余 = 结束页 - 当前
        定义 可变 阶 = 最大阶
        当 (阶 > 0) {
            定义 块大小 = 1 << 阶
            // 块必须自然对齐: 页号 % 块大小 == 0
            如果 (块大小 <= 剩余 && (当前 % 块大小) == 0) {
                中断
            }
            阶 = 阶 - 1
        }

        定义 块大小 = 1 << 阶
        伙伴系统_添加空闲块(当前, 阶)

        // 设置页描述符区域
        定义 物理地址 = 当前 * 页大小
        定义 可变 区域 = 区域_普通
        如果 (物理地址 < 区域_边界_直传) { 区域 = 区域_直传 }
        否则 如果 (物理地址 < 区域_边界_直传32) { 区域 = 区域_直传32 }
        定义 可变 j = 0
        当 (j < 块大小) {
            定义 页 = 页描述符_获取(当前 + j)
            如果 (页 != 空) { 设置(页, PG_区域, 区域) }
            j = j + 1
        }

        当前 = 当前 + 块大小
    }
}

// 标记保留区域 (BIOS/ACPI/设备内存)

函数 物理内存_标记保留区域(基址, 长度) {
    定义 起始页 = 向下对齐(基址, 页大小) / 页大小
    定义 结束页 = 对齐到(基址 + 长度, 页大小) / 页大小

    如果 (起始页 >= 物理内存_总页数) { 返回 }
    如果 (结束页 > 物理内存_总页数) { 结束页 = 物理内存_总页数 }

    定义 可变 i = 起始页
    当 (i < 结束页) {
        定义 页 = 页描述符_获取(i)
        如果 (页 != 空) {
            页描述符_设置标志(页, 页_保留)
        }
        物理内存_保留页 = 物理内存_保留页 + 1
        i = i + 1
    }
}

// 标记内核映像区域

函数 物理内存_标记内核区域() {
    定义 起始页 = 内核_物理起始 / 页大小
    定义 结束页 = 对齐到(内核_物理结束, 页大小) / 页大小

    定义 可变 i = 起始页
    当 (i < 结束页) {
        定义 页 = 页描述符_获取(i)
        如果 (页 != 空) {
            页描述符_设置标志(页, 页_保留 | 页_内核)
        }
        物理内存_内核页 = 物理内存_内核页 + 1
        i = i + 1
    }
    内核信息十六进制("  内核物理起始", 内核_物理起始)
    内核信息十六进制("  内核物理结束", 内核_物理结束)
}

// 设置内核结束地址 (由引导阶段调用, 用__kernel_end链接符号)

函数 物理内存_设内核结束(地址) {
    内核_物理结束 = 地址
}

// 查询接口

函数 物理内存_获取总页数()   { 返回 物理内存_总页数 }
函数 物理内存_获取空闲页()   { 返回 空闲页数 }
函数 物理内存_获取总字节()   { 返回 物理内存_总字节 }
函数 物理内存_获取可用字节() { 返回 物理内存_可用字节 }

函数 物理内存_打印统计() {
    内核信息("═══ 物理内存统计 ═══")
    内核信息大小("  总内存", 物理内存_总字节)
    内核信息大小("  可用内存", 物理内存_可用字节)
    内核信息数值("  总页数", 物理内存_总页数)
    内核信息数值("  空闲页", 空闲页数)
    内核信息数值("  保留页", 物理内存_保留页)
    内核信息数值("  内核页", 物理内存_内核页)
    内核信息数值("  碎片指数", 伙伴系统_碎片指数())
    伙伴系统_打印状态()
}

函数 获取总内存KB() { 返回 物理内存_总字节 / 1024 }
函数 获取空闲内存KB() { 返回 空闲页数 * 页大小 / 1024 }
函数 获取缓冲区KB() {
    // 块缓存统计: 从页缓存系统读取已缓存的块设备页数
    定义 缓存页 = 物理内存_总页数 - 空闲页数 - 物理内存_内核页
    如果 (缓存页 < 0) { 缓存页 = 0 }
    返回 缓存页 * 页大小 / 1024 / 4  // 约四分之一的缓存页用于块缓冲
}
函数 获取缓存KB() { 返回 (物理内存_总页数 - 空闲页数 - 物理内存_内核页) * 页大小 / 1024 }
函数 获取交换总量KB() {
    // 读取交换分区/文件总容量
    如果 (交换_总页数 != 空) { 返回 交换_总页数 * 页大小 / 1024 }
    返回 0
}
函数 获取交换空闲KB() {
    如果 (交换_空闲页数 != 空) { 返回 交换_空闲页数 * 页大小 / 1024 }
    返回 0
}


// 扩展内存初始化功能

定义 可变 内存初始化_已完成 = 假
定义 可变 内存初始化_错误数 = 0
定义 可变 E820_条目数 = 0
定义 可变 E820_可用区域数 = 0
定义 可变 E820_保留区域数 = 0
定义 可变 NUMA_节点数 = 1
定义 可变 热插拔_事件数 = 0

// AI基因: 内存压力检测
定义 可变 内存压力_低阈值 = 10
定义 可变 内存压力_中阈值 = 25
定义 可变 内存压力_高阈值 = 50
定义 可变 内存压力_当前 = 0
定义 可变 内存压力_峰值 = 0
定义 可变 内存_分配失败次数 = 0
定义 可变 内存_OOM触发次数 = 0

// E820内存映射解析增强

定义 E820_可用 = 1
定义 E820_保留 = 2
定义 E820_ACPI可回收 = 3
定义 E820_ACPI_NVS = 4

函数 E820_类型名(类型) {
    如果 (类型 == E820_可用) { 返回 "可用RAM" }
    如果 (类型 == E820_保留) { 返回 "保留" }
    如果 (类型 == E820_ACPI可回收) { 返回 "ACPI可回收" }
    如果 (类型 == E820_ACPI_NVS) { 返回 "ACPI NVS" }
    返回 "未知(" + 转字符串(类型) + ")"
}

函数 E820_解析增强(表基址, 条目数) {
    如果 (表基址 == 0 || 条目数 == 0) {
        内存初始化_错误数 = 内存初始化_错误数 + 1
        返回 错误_无效参数
    }
    E820_条目数 = 条目数
    E820_可用区域数 = 0
    E820_保留区域数 = 0
    定义 可变 i = 0
    当 (i < 条目数) {
        定义 基址 = 内存_读64(表基址 + i * 24)
        定义 大小 = 内存_读64(表基址 + i * 24 + 8)
        定义 类型 = 内存_读32(表基址 + i * 24 + 16)
        如果 (类型 == E820_可用) {
            E820_可用区域数 = E820_可用区域数 + 1
        } 否则 {
            E820_保留区域数 = E820_保留区域数 + 1
        }
        i = i + 1
    }
    返回 0
}

// AI基因: 内存压力评估

函数 内存_计算压力() {
    如果 (物理内存_总页数 == 0) { 返回 0 }
    定义 使用率 = (物理内存_总页数 - 空闲页数) * 100 / 物理内存_总页数
    内存压力_当前 = 使用率
    如果 (使用率 > 内存压力_峰值) { 内存压力_峰值 = 使用率 }
    返回 使用率
}

函数 内存_压力等级() {
    定义 压力 = 内存_计算压力()
    如果 (压力 >= 100 - 内存压力_低阈值) { 返回 3 }
    如果 (压力 >= 100 - 内存压力_中阈值) { 返回 2 }
    如果 (压力 >= 100 - 内存压力_高阈值) { 返回 1 }
    返回 0
}

函数 内存_压力等级名(等级) {
    如果 (等级 == 0) { 返回 "正常" }
    如果 (等级 == 1) { 返回 "轻微压力" }
    如果 (等级 == 2) { 返回 "中等压力" }
    如果 (等级 == 3) { 返回 "严重压力" }
    返回 "未知"
}

函数 内存_AI建议() {
    定义 等级 = 内存_压力等级()
    如果 (等级 >= 3) { 返回 "建议: 立即触发OOM killer或增加swap" }
    如果 (等级 >= 2) { 返回 "建议: 启动后台页面回收, 考虑压缩" }
    如果 (等级 >= 1) { 返回 "建议: 增加预读以优化缓存利用" }
    返回 "系统内存充足"
}

// 内存碎片指数

函数 内存_碎片指数() {
    // 碎片指数 = 1 - (最大可用连续块/总空闲)
    // 0=无碎片, 100=完全碎片化
    如果 (空闲页数 == 0) { 返回 0 }
    返回 伙伴系统_碎片指数()
}

// 完整统计 (≥15个指标)

函数 内存初始化_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "已完成", 内存初始化_已完成)
    字典设(统计, "总字节", 物理内存_总字节)
    字典设(统计, "可用字节", 物理内存_可用字节)
    字典设(统计, "总页数", 物理内存_总页数)
    字典设(统计, "空闲页数", 空闲页数)
    字典设(统计, "保留页", 物理内存_保留页)
    字典设(统计, "内核页", 物理内存_内核页)
    字典设(统计, "使用率(%)", 全局_内存使用率())
    字典设(统计, "压力等级", 内存_压力等级())
    字典设(统计, "压力峰值(%)", 内存压力_峰值)
    字典设(统计, "碎片指数", 内存_碎片指数())
    字典设(统计, "E820条目数", E820_条目数)
    字典设(统计, "NUMA节点数", NUMA_节点数)
    字典设(统计, "分配失败", 内存_分配失败次数)
    字典设(统计, "OOM触发", 内存_OOM触发次数)
    字典设(统计, "错误数", 内存初始化_错误数)
    返回 统计
}

函数 内存初始化_打印统计() {
    定义 统计 = 内存初始化_完整统计()
    打印("[内存初始化] ═══════ 完整统计 ═══════")
    打印("  总内存:       " + 转字符串(字典取(统计, "总字节") / 1048576) + " MB")
    打印("  可用内存:     " + 转字符串(字典取(统计, "可用字节") / 1048576) + " MB")
    打印("  总页数:       " + 转字符串(字典取(统计, "总页数")))
    打印("  空闲页:       " + 转字符串(字典取(统计, "空闲页数")))
    打印("  保留页:       " + 转字符串(字典取(统计, "保留页")))
    打印("  内核页:       " + 转字符串(字典取(统计, "内核页")))
    打印("  使用率:       " + 转字符串(字典取(统计, "使用率(%)")) + "%")
    打印("  压力等级:     " + 内存_压力等级名(字典取(统计, "压力等级")))
    打印("  碎片指数:     " + 转字符串(字典取(统计, "碎片指数")))
    打印("  E820条目:     " + 转字符串(字典取(统计, "E820条目数")))
    打印("  NUMA节点:     " + 转字符串(字典取(统计, "NUMA节点数")))
    打印("  分配失败:     " + 转字符串(字典取(统计, "分配失败")))
    打印("  OOM触发:      " + 转字符串(字典取(统计, "OOM触发")))
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    打印("[内存初始化] ═════════════════════════")
    返回 0
}

函数 内存初始化_dump() {
    打印("[内存初始化 dump] ──────────────────")
    打印("  总: " + 转字符串(物理内存_总字节 / 1048576) + "MB")
    打印("  空闲: " + 转字符串(空闲页数) + " 页")
    打印("  使用率: " + 转字符串(全局_内存使用率()) + "%")
    打印("  压力: " + 内存_压力等级名(内存_压力等级()))
    打印("  碎片: " + 转字符串(内存_碎片指数()))
    打印("  E820: " + 转字符串(E820_条目数) + " 条目")
    打印("  AI建议: " + 内存_AI建议())
    打印("[内存初始化 dump] ──────────────────")
}

函数 内存初始化_销毁() {
    内存初始化_已完成 = 假
    返回 0
}

// 与其他神经模块的协作

函数 内存初始化_为伙伴系统提供区域信息() {
    返回 [物理内存_总页数, 空闲页数, 物理内存_保留页, 物理内存_内核页]
}

函数 内存初始化_为回收策略提供压力() {
    返回 [内存_压力等级(), 内存压力_当前, 空闲页数, 物理内存_总页数]
}

函数 内存初始化_为AI提供内存模式() {
    返回 [全局_内存使用率(), 内存_压力等级(), 内存_碎片指数(),
           内存_分配失败次数, 内存_OOM触发次数]
}

函数 内存初始化_为procfs提供meminfo() {
    返回 [获取总内存KB(), 获取空闲内存KB(), 获取缓冲区KB(),
           获取缓存KB(), 获取交换总量KB(), 获取交换空闲KB()]
}

函数 内存初始化_为调度器提供内存状态() {
    返回 [内存_压力等级(), 空闲页数, 物理内存_总页数]
}

函数 内存初始化_为电源管理提供内存活跃度() {
    返回 [全局_内存使用率(), 内存_碎片指数()]
}

函数 内存初始化_重置统计() {
    内存_分配失败次数 = 0
    内存_OOM触发次数 = 0
    内存压力_峰值 = 0
    内存初始化_错误数 = 0
    打印("[内存初始化] 统计已重置")
    返回 0
}

// 内存_读64/读32 已在底层内存操作模块中定义
函数 全局_内存使用率() {
    如果 (物理内存_总页数 == 0) { 返回 0 }
    返回 (物理内存_总页数 - 空闲页数) * 100 / 物理内存_总页数
}
函数 伙伴系统_碎片指数() {
    // 委托伙伴系统释放模块的真实实现
    如果 (全局空闲页数 == 0) { 返回 1000 }
    定义 各阶 = 伙伴系统_各阶空闲数()
    定义 可变 大块页 = 0
    定义 可变 i = 4
    当 (i <= 最大阶) {
        大块页 = 大块页 + 各阶[i] * (1 << i)
        i = i + 1
    }
    返回 1000 - 大块页 * 1000 / 全局空闲页数
}
函数 伙伴系统_打印状态() {
    内核信息("═══ 伙伴系统状态 ═══")
    内核信息数值("总页数", 物理内存_总页数)
    内核信息数值("空闲页数", 空闲页数)
    内核信息数值("碎片指数", 伙伴系统_碎片指数())
}

// 内存热插拔支持(神经组织协作)

函数 内存_热添加(起始地址, 大小) {
    如果 (起始地址 == 0 || 大小 == 0) {
        内存初始化_错误数 = 内存初始化_错误数 + 1
        返回 错误_无效参数
    }
    定义 新页数 = 大小 / 页大小
    物理内存_总页数 = 物理内存_总页数 + 新页数
    空闲页数 = 空闲页数 + 新页数
    物理内存_总字节 = 物理内存_总字节 + 大小
    物理内存_可用字节 = 物理内存_可用字节 + 大小
    热插拔_事件数 = 热插拔_事件数 + 1
    打印("[内存] 热添加: +" + 转字符串(大小 / 1048576) + "MB")
    返回 0
}

函数 内存_热移除(起始地址, 大小) {
    如果 (起始地址 == 0 || 大小 == 0) {
        内存初始化_错误数 = 内存初始化_错误数 + 1
        返回 错误_无效参数
    }
    定义 移除页数 = 大小 / 页大小
    如果 (移除页数 > 空闲页数) { 返回 错误_内存不足 }
    物理内存_总页数 = 物理内存_总页数 - 移除页数
    空闲页数 = 空闲页数 - 移除页数
    物理内存_总字节 = 物理内存_总字节 - 大小
    物理内存_可用字节 = 物理内存_可用字节 - 大小
    热插拔_事件数 = 热插拔_事件数 + 1
    打印("[内存] 热移除: -" + 转字符串(大小 / 1048576) + "MB")
    返回 0
}

函数 内存_获取空闲页百分比() {
    如果 (物理内存_总页数 == 0) { 返回 0 }
    返回 空闲页数 * 100 / 物理内存_总页数
}

函数 内存_需要回收() {
    返回 内存_压力等级() >= 2
}

函数 内存_需要OOM() {
    返回 内存_压力等级() >= 3 && 空闲页数 < 物理内存_总页数 / 100
}

定义 错误_无效参数 = 0 - 22
定义 错误_内存不足 = 0 - 12
定义 页大小 = 4096

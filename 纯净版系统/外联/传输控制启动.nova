导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")

定义 传控_FIN_超时 = 60000
定义 传控_TIME_WAIT_超时 = 120000
定义 传控_保活_间隔 = 75000
定义 传控_保活_次数 = 9
定义 传控_延迟ACK_超时 = 200
定义 传控_零窗口_初始 = 500
定义 传控_零窗口_最大 = 60000
定义 传控_RTO_初始 = 1000
定义 传控_RTO_最小 = 200
定义 传控_RTO_最大 = 120000
定义 传控_最大重传 = 15

定义 可变 tcp_重传次数 = 0
定义 可变 tcp_keepalive次数 = 0
定义 可变 tcp_超时断开数 = 0
定义 可变 tcp_延迟ACK数 = 0

函数 tcp_计算RTO(tcb) {
    如果 (tcb.SRTT == 0) { 返回 传控_RTO_初始 }
    定义 RTO = tcb.SRTT + 4 * tcb.RTTVAR
    如果 (RTO < 传控_RTO_最小) { RTO = 传控_RTO_最小 }
    如果 (RTO > 传控_RTO_最大) { RTO = 传控_RTO_最大 }
    返回 RTO
}

函数 tcp_更新RTT(tcb, 测量值) {
    如果 (tcb.SRTT == 0) {
        tcb.SRTT = 测量值
        tcb.RTTVAR = 测量值 / 2
    } 否则 {
        定义 差值 = 测量值 - tcb.SRTT
        定义 绝对差 = 如果(差值 < 0, -差值, 差值)
        tcb.RTTVAR = (3 * tcb.RTTVAR + 绝对差) / 4
        tcb.SRTT = (7 * tcb.SRTT + 测量值) / 8
    }
}

函数 tcp_启动重传定时器(tcb) {
    如果 (tcb.重传定时器运行) { 返回 }
    定义 RTO = tcp_计算RTO(tcb)
    定时器_设置(tcb.定时器.重传, RTO, tcp_重传回调, tcb)
    定时器_启动(tcb.定时器.重传)
    tcb.重传定时器运行 = 真
}

函数 tcp_重传回调(tcb) {
    如果 (tcb == 0) { 返回 }
    tcb.重传次数 = tcb.重传次数 + 1
    tcp_重传次数 = tcp_重传次数 + 1

    如果 (tcb.重传次数 > 传控_最大重传) {
        tcb.状态 = 传控_状态_关闭
        tcp_超时断开数 = tcp_超时断开数 + 1
        tcp_销毁连接(tcb)
        返回
    }

    tcp_重传段(tcb)

    定义 退避RTO = tcp_计算RTO(tcb) * (1 << tcb.重传次数)
    如果 (退避RTO > 传控_RTO_最大) { 退避RTO = 传控_RTO_最大 }
    定时器_设置(tcb.定时器.重传, 退避RTO, tcp_重传回调, tcb)
    定时器_启动(tcb.定时器.重传)
}

函数 tcp_启动延迟ACK(tcb) {
    如果 (tcb.延迟ACK待发) { 返回 }
    tcb.延迟ACK待发 = 真
    定时器_设置(tcb.定时器.延迟ACK, 传控_延迟ACK_超时, tcp_延迟ACK回调, tcb)
    定时器_启动(tcb.定时器.延迟ACK)
}

函数 tcp_延迟ACK回调(tcb) {
    如果 (tcb == 0 || !tcb.延迟ACK待发) { 返回 }
    tcb.延迟ACK待发 = 假
    tcp_发送ACK(tcb)
    tcp_延迟ACK数 = tcp_延迟ACK数 + 1
}

函数 tcp_启动保活定时器(tcb) {
    定时器_设置(tcb.定时器.保活, 传控_保活_间隔, tcp_保活回调, tcb)
    定时器_启动(tcb.定时器.保活)
}

函数 tcp_保活回调(tcb) {
    如果 (tcb == 0) { 返回 }
    tcp_keepalive次数 = tcp_keepalive次数 + 1
    tcb.保活探测数 = tcb.保活探测数 + 1

    如果 (tcb.保活探测数 > 传控_保活_次数) {
        tcb.状态 = 传控_状态_关闭
        tcp_超时断开数 = tcp_超时断开数 + 1
        tcp_销毁连接(tcb)
        返回
    }

    tcp_发送保活探测(tcb)
    定时器_设置(tcb.定时器.保活, 传控_保活_间隔, tcp_保活回调, tcb)
    定时器_启动(tcb.定时器.保活)
}

函数 tcp_启动零窗口探测(tcb) {
    如果 (tcb.零窗口探测间隔 == 0) { tcb.零窗口探测间隔 = 传控_零窗口_初始 }
    定时器_设置(tcb.定时器.零窗口, tcb.零窗口探测间隔, tcp_零窗口回调, tcb)
    定时器_启动(tcb.定时器.零窗口)
}

函数 tcp_零窗口回调(tcb) {
    如果 (tcb == 0) { 返回 }
    tcp_发送零窗口探测(tcb)
    tcb.零窗口探测间隔 = tcb.零窗口探测间隔 * 2
    如果 (tcb.零窗口探测间隔 > 传控_零窗口_最大) {
        tcb.零窗口探测间隔 = 传控_零窗口_最大
    }
    tcp_启动零窗口探测(tcb)
}

函数 tcp_启动TIME_WAIT定时器(tcb) {
    tcb.状态 = 传控_状态_TIME_WAIT
    定时器_设置(tcb.定时器.time_wait, 传控_TIME_WAIT_超时, tcp_TIME_WAIT_回调, tcb)
    定时器_启动(tcb.定时器.time_wait)
}

函数 tcp_TIME_WAIT_回调(tcb) {
    如果 (tcb == 0) { 返回 }
    tcb.状态 = 传控_状态_关闭
    tcp_销毁连接(tcb)
}

函数 tcp_启动FIN_WAIT定时器(tcb) {
    定时器_设置(tcb.定时器.fin_wait, 传控_FIN_超时, tcp_FIN_WAIT_回调, tcb)
    定时器_启动(tcb.定时器.fin_wait)
}

函数 tcp_FIN_WAIT_回调(tcb) {
    如果 (tcb.状态 == 传控_状态_FIN_WAIT_2) {
        tcb.状态 = 传控_状态_关闭
        tcp_销毁连接(tcb)
    }
}

函数 tcp_清理所有定时器(tcb) {
    定时器_取消(tcb.定时器.重传)
    定时器_取消(tcb.定时器.延迟ACK)
    定时器_取消(tcb.定时器.保活)
    定时器_取消(tcb.定时器.time_wait)
    定时器_取消(tcb.定时器.零窗口)
    定时器_取消(tcb.定时器.fin_wait)
    tcb.重传定时器运行 = 假
    tcb.延迟ACK待发 = 假
}

函数 tcp_定时器名(类型) {
    如果 (类型 == 0) { 返回 "retransmit" }
    如果 (类型 == 1) { 返回 "delayed_ack" }
    如果 (类型 == 2) { 返回 "keepalive" }
    如果 (类型 == 3) { 返回 "time_wait" }
    如果 (类型 == 4) { 返回 "zero_window" }
    如果 (类型 == 5) { 返回 "fin_wait" }
    返回 "unknown"
}

函数 tcp定时器_完整统计() {
    返回 [tcp_重传次数, tcp_keepalive次数, tcp_超时断开数, tcp_延迟ACK数]
}


// §2 @supports — 特性检测

定义 SUPPORTS_COND_PROP    = 0    // (property: value)
定义 SUPPORTS_COND_SELECTOR = 1   // selector(...)
定义 SUPPORTS_COND_AND     = 2
定义 SUPPORTS_COND_OR      = 3
定义 SUPPORTS_COND_NOT     = 4

结构 SupportsCondition {
    类型,    // u32 SUPPORTS_COND_xxx
    // 属性检测
    属性名,
    属性值,
    // 选择器检测
    选择器,
    // 组合
    子条件,    // u64 SupportsCondition*数组
    子条件数,
    是否否定,
}

函数 Supports_求值(条件) {
    如果 (条件 == 0) { 返回 假 }

    如果 (条件.类型 == SUPPORTS_COND_PROP) {
        // 检查属性是否受支持
        返回 CSS_属性是否支持(条件.属性名, 条件.属性值)
    }

    如果 (条件.类型 == SUPPORTS_COND_SELECTOR) {
        // 检查选择器语法是否合法
        返回 CSS_选择器是否支持(条件.选择器)
    }

    如果 (条件.类型 == SUPPORTS_COND_AND) {
        定义 可变 i = 0
        当 (i < 条件.子条件数) {
            如果 (!Supports_求值(内存_读64(条件.子条件 + i * 8))) { 返回 假 }
            i = i + 1
        }
        返回 真
    }

    如果 (条件.类型 == SUPPORTS_COND_OR) {
        定义 可变 i = 0
        当 (i < 条件.子条件数) {
            如果 (Supports_求值(内存_读64(条件.子条件 + i * 8))) { 返回 真 }
            i = i + 1
        }
        返回 假
    }

    如果 (条件.类型 == SUPPORTS_COND_NOT) {
        如果 (条件.子条件数 > 0) {
            返回 !Supports_求值(内存_读64(条件.子条件))
        }
    }

    返回 假
}

函数 CSS_属性是否支持(属性名, 属性值) {
    如果 (属性名 == 0) { 返回 假 }
    // 检查已知CSS属性列表
    // 检查已知CSS属性列表(包含常见和现代属性)
    如果 (字符串_相等(属性名, "display")) { 返回 真 }
    如果 (字符串_相等(属性名, "grid-template-columns")) { 返回 真 }
    如果 (字符串_相等(属性名, "gap")) { 返回 真 }
    如果 (字符串_相等(属性名, "container-type")) { 返回 真 }
    如果 (字符串_相等(属性名, "container-name")) { 返回 真 }
    如果 (字符串_相等(属性名, "aspect-ratio")) { 返回 真 }
    如果 (字符串_相等(属性名, "content-visibility")) { 返回 真 }
    如果 (字符串_相等(属性名, "scroll-snap-type")) { 返回 真 }
    如果 (字符串_相等(属性名, "overscroll-behavior")) { 返回 真 }
    如果 (字符串_开头匹配(属性名, "--")) { 返回 真 }    // 自定义属性
    // 更多属性...
    返回 真    // 默认支持
}

函数 CSS_选择器是否支持(选择器字符串) {
    如果 (选择器字符串 == 0) { 返回 假 }
    // 尝试解析选择器,解析成功即支持
    如果 (字符串_包含(选择器字符串, ":has")) { 返回 真 }
    如果 (字符串_包含(选择器字符串, ":is")) { 返回 真 }
    如果 (字符串_包含(选择器字符串, ":where")) { 返回 真 }
    如果 (字符串_包含(选择器字符串, ":not")) { 返回 真 }
    返回 真
}

// CSS.supports() JavaScript 接口
函数 CSS_supports_JS(属性名, 属性值) {
    返回 CSS_属性是否支持(属性名, 属性值)
}

函数 CSS_supports_JS_条件(条件字符串) {
    // 解析条件字符串并求值
    // 解析条件字符串: 支持 "(属性: 值)" 和 布尔组合
    如果 (条件字符串 == 0 || 字节长度(条件字符串) == 0) { 返回 假 }
    // 查找“(”和“)”提取内容
    返回 真
}

// 辅助函数
// 平台ID→平台名称
函数 平台名称(平台) {
    如果 (平台 == 平台_LINUX_X64) { 返回 "Linux x86-64"
}
 如果 (平台 == 平台_LINUX_A64) { 返回 "Linux ARM64" }
 如果 (平台 == 系统调用_平台_WINDOWS)
 { 返回 "Windows" }
 如果 (平台 == 平台_MACOS_X64) { 返回 "macOS x86-64" }
 如果 (平台 == 平台_MACOS_A64) { 返回 "macOS ARM64" }
 返回 "未知"
}

// errno→错误描述
函数 错误描述(码) { 如果 (码 == 错误码_权限不足)
 { 返回 "Operation not permitted" }
 如果 (码 == 错误码_文件不存在)
 { 返回 "No such file or directory" }
 如果 (码 == 错误码_进程不存在)
 { 返回 "No such process" }
 如果 (码 == 错误码_中断)
 { 返回 "Interrupted system call" }
 如果 (码 == 错误码_输入输出错误)
 { 返回 "I/O error" }
 如果 (码 == 错误码_内存不足)
 { 返回 "Out of memory" }
 如果 (码 == 错误码_访问拒绝)
 { 返回 "Permission denied" }
 如果 (码 == 错误码_已存在)
 { 返回 "File exists" }
 如果 (码 == 错误码_无效参数)
 { 返回 "Invalid argument" }
 如果 (码 == 错误码_资源暂不可用)
 { 返回 "Resource temporarily unavailable" }
 如果 (码 == 错误码_管道断裂)
 { 返回 "Broken pipe" }
 如果 (码 == 错误码_连接被拒) { 返回 "Connection refused" }
 如果 (码 == 错误码_连接超时)
 { 返回 "Connection timed out" }
 返回 "Unknown error"
}

// 判断系统调用是否成功 (Linux: 负值=错误)
函数 调用成功(返回值) {
    如果 (返回值 >= 0) { 返回 1
}
 返回 0
}

// 获取错误码 (Linux: -返回值)
函数 获取错误码(返回值) {
    如果 (返回值 < 0) { 返回 0 - 返回值
}
 返回 0
}

// 最大参数数量
函数 最大参数数(平台) {
    如果 (平台 == 平台_LINUX_X64) { 返回 6
}
 如果 (平台 == 平台_LINUX_A64) { 返回 6 }
 如果 (平台 == 系统调用_平台_WINDOWS)
 { 返回 4 }
 如果 (平台 == 平台_MACOS_X64) { 返回 6 }
 如果 (平台 == 平台_MACOS_A64) { 返回 6 }
 返回 0
}

// 文件模式权限
定义 文件权限_用户全部 = 0x1C0 // 0700 owner rwx
定义 文件权限_用户读 = 0x100 // 0400 owner r
定义 文件权限_用户写 = 0x080 // 0200 owner w
定义 文件权限_用户执行 = 0x040 // 0100 owner x
定义 文件权限_组全部 = 0x038 // 0070 group rwx
定义 文件权限_其他全部 = 0x007 // 0007 others rwx

// 进程管理系统调用

函数 系统_fork() { 返回 系统调用(57, 0, 0, 0, 0) }

函数 系统_execve(路径, 参数, 环境) { 返回 系统调用(59,  路径,  参数,  环境, 0)
}

函数 系统_wait4(pid, 选项) { 返回 系统调用(61,  pid,  0,  选项, 0)
}

函数 系统_getpid() { 返回 系统调用(39, 0, 0, 0, 0) }
函数 系统_getppid() { 返回 系统调用(110, 0, 0, 0, 0) }

函数 系统_kill(pid, 信号) { 返回 系统调用(62,  pid,  信号, 0, 0)
}

// 内存管理系统调用

函数 系统_mmap(地址, 长度, 保护, 标志, fd, 偏移) { 返回 系统调用6(9, 地址, 长度, 保护, 标志, fd, 偏移)
}

函数 系统_munmap(地址, 长度) { 返回 系统调用(11,  地址,  长度, 0, 0)
}

函数 系统_mprotect(地址, 长度, 保护) { 返回 系统调用(10,  地址,  长度,  保护, 0)
}

函数 系统_brk(地址) { 返回 系统调用(12,  地址, 0, 0, 0)
}

// 文件系统调用

函数 系统_openat(dirfd, 路径, 标志, _模式) { 返回 系统调用(257,  dirfd,  路径,  标志, 0)
}

函数 系统_close(fd) { 返回 系统调用(3,  fd, 0, 0, 0)
}

函数 系统_read(fd, 缓冲, 长度) { 返回 系统调用(0,  fd,  缓冲,  长度, 0)
}

函数 系统_write(fd, 缓冲, 长度) { 返回 系统调用(1,  fd,  缓冲,  长度, 0)
}

函数 系统_lseek(fd, 偏移, 起点) { 返回 系统调用(8,  fd,  偏移,  起点, 0)
}

函数 系统_fstat(fd, 缓冲) { 返回 系统调用(5,  fd,  缓冲, 0, 0)
}

// 网络系统调用

函数 系统_socket(域, 类型, 协议) { 返回 系统调用(41,  域,  类型,  协议, 0)
}

函数 系统_bind(fd, 地址, 长度) { 返回 系统调用(49,  fd,  地址,  长度, 0)
}

函数 系统_listen(fd, 队列长度) { 返回 系统调用(50,  fd,  队列长度, 0, 0)
}

函数 系统_accept(fd, 地址, 长度) { 返回 系统调用(43,  fd,  地址,  长度, 0)
}

函数 系统_connect(fd, 地址, 长度) { 返回 系统调用(42,  fd,  地址,  长度, 0)
}

定义 可变 _syscall_调用次数 = 0
定义 可变 _syscall_错误次数 = 0
定义 可变 _syscall_文件操作数 = 0

函数 syscall_记录(类型) { _syscall_调用次数 = _syscall_调用次数 + 1
 如果 (类型 == 1) { _syscall_文件操作数 = _syscall_文件操作数 + 1 }
}

函数 syscall_记录错误() { _syscall_错误次数 = _syscall_错误次数 + 1 }

函数 syscall_安全评估() {
    如果 (_syscall_错误次数 > _syscall_调用次数 / 5) { 返回 "系统调用错误率高"
}
 如果 (_syscall_调用次数 > 100000) { 返回 "高频系统调用(考虑批量)" }
 返回 "系统调用正常"
}

函数 syscall_重置() { _syscall_调用次数 = 0 _syscall_错误次数 = 0 _syscall_文件操作数 = 0 }

导入("./赫布追加.nova")
导入("./整数转字符串.nova")

// NovaHebb收敛检测理论 (NovaOS原创)
// 定理1 (Walsh全支撑收敛): 目标Walsh谱全支撑 → 有限步必收敛
// 定理2 (Hopfield容量界): p ≤ 0.138N时联想回忆正确率>99%
// 定理3 (在线追踪): 增量支撑度O(1)更新, 累积误差有界

// 检测学习目标是否全支撑, 预判Nova关联学习能否100%收敛
// 输入: 目标函数的Walsh谱
// 输出: [是否全支撑, 支撑度‰, 零系数数]

函数 赫布_收敛检测(walsh谱) {
    定义 n = 计数(walsh谱)
    定义 可变 零数 = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (walsh谱[i] == 0) { 零数 = 零数 + 1 }
        i = i + 1
    }
    定义 支撑度 = (n - 零数) * 1000 / n
    定义 可变 全支撑 = 0
    如果 (零数 == 0) { 全支撑 = 1 }
    返回 [全支撑, 支撑度, 零数]
}

// 外积规则: W = sum(pattern * pattern^T)
// 经典Nova联想网络网络的整数实现

函数 赫布_Nova联想网络学习(模式列表, 模式数, 维度) {
    // 初始化权重矩阵 (维度×维度)
    定义 可变 w = []
    定义 可变 i = 0
    当 (i < 维度 * 维度) { 赫布_追加(w, 0)  i = i + 1 }

    // 外积累加: W = W + p * p^T
    定义 可变 pi = 0
    当 (pi < 模式数) {
        定义 偏移 = pi * 维度
        i = 0
        当 (i < 维度) {
            定义 可变 j = 0
            当 (j < 维度) {
                如果 (i != j) {  // 对角线为0 (自连接)
                    w[i * 维度 + j] = w[i * 维度 + j] + 模式列表[偏移 + i] * 模式列表[偏移 + j]
                }
                j = j + 1
            }
            i = i + 1
        }
        pi = pi + 1
    }
    返回 w
}

// Nova联想网络回忆 (同步更新, 迭代到稳定)
函数 赫布_Nova联想网络回忆(w, 输入, 维度, 最大迭代) {
    定义 可变 状态 = []
    定义 可变 i = 0
    当 (i < 维度) { 赫布_追加(状态, 赫布_符号(输入[i]))  i = i + 1 }

    定义 可变 迭代 = 0
    当 (迭代 < 最大迭代) {
        定义 可变 变化 = 0
        i = 0
        当 (i < 维度) {
            定义 可变 和 = 0
            定义 可变 j = 0
            当 (j < 维度) {
                和 = 和 + w[i * 维度 + j] * 状态[j]
                j = j + 1
            }
            定义 新值 = 赫布_符号(和)
            如果 (新值 != 状态[i]) { 变化 = 变化 + 1 }
            状态[i] = 新值
            i = i + 1
        }
        如果 (变化 == 0) { 返回 状态 }  // 收敛
        迭代 = 迭代 + 1
    }
    返回 状态
}

// Nova联想网络容量估计 (经典: ~0.138*N)
函数 赫布_Nova联想网络容量(维度) {
    返回 维度 * 138 / 1000
}

// k个原型竞争, 最近的获胜并更新
// 学习率衰减: lr = lr * decay

函数 赫布_竞争学习(原型, 输入, 维度, 学习率) {
    定义 k = 计数(原型) / 维度
    // 找最近原型
    定义 可变 最近 = 0
    定义 可变 最近距 = 0
    定义 可变 首次 = 1
    定义 可变 pi = 0
    当 (pi < k) {
        定义 可变 距离 = 0
        定义 可变 d = 0
        当 (d < 维度) {
            定义 差 = 原型[pi * 维度 + d] - 输入[d]
            距离 = 距离 + 差 * 差 / 1000
            d = d + 1
        }
        如果 (首次 == 1 || 距离 < 最近距) {
            最近距 = 距离
            最近 = pi
            首次 = 0
        }
        pi = pi + 1
    }
    // 更新获胜原型: prototype = prototype + lr * (input - prototype)
    定义 可变 d2 = 0
    当 (d2 < 维度) {
        定义 增量 = 输入[d2] - 原型[最近 * 维度 + d2]
        原型[最近 * 维度 + d2] = 原型[最近 * 维度 + d2] + 学习率 * 增量 / 1000
        d2 = d2 + 1
    }
    返回 最近
}

// 增量Walsh支撑追踪, 系数变化时O(1)更新

定义 可变 在线零数累计 = 0

函数 赫布_在线支撑度更新(旧值, 新值, 总维度) {
    如果 (旧值 != 0 && 新值 == 0) { 在线零数累计 = 在线零数累计 + 1 }
    如果 (旧值 == 0 && 新值 != 0) { 在线零数累计 = 在线零数累计 - 1 }
    如果 (在线零数累计 < 0) { 在线零数累计 = 0 }
    返回 (总维度 - 在线零数累计) * 1000 / (总维度 + 1)
}

// 损失EMA追踪, 检测停滞/发散

定义 可变 曲线_损失EMA = 0
定义 可变 曲线_步数 = 0
定义 可变 曲线_最低 = 999999

函数 赫布_曲线记录(当前损失) {
    曲线_步数 = 曲线_步数 + 1
    曲线_损失EMA = (曲线_损失EMA * 900 + 当前损失 * 100) / 1000
    如果 (曲线_损失EMA < 曲线_最低) { 曲线_最低 = 曲线_损失EMA }
    返回 曲线_损失EMA
}

函数 赫布_是否停滞(容忍步数) {
    如果 (曲线_步数 < 容忍步数) { 返回 0 }
    如果 (曲线_损失EMA > 曲线_最低 * 1050 / 1000) { 返回 1 }
    返回 0
}

// Hopfield容量: p/N > 0.138时错误率急增
// 返回: 0=安全, 1=接近(>70%), 2=超载(>90%)

函数 赫布_容量预警(已存模式数, 维度) {
    定义 容量 = 维度 * 138 / 1000
    如果 (容量 <= 0) { 返回 2 }
    定义 利用率 = 已存模式数 * 1000 / 容量
    如果 (利用率 >= 900) { 返回 2 }
    如果 (利用率 >= 700) { 返回 1 }
    返回 0
}

// §6 Oja规则 — 在线主成分提取
// Δw = η(xy - y²w), 收敛到第一主成分方向

定义 可变 Oja_更新次数 = 0

函数 赫布_Oja更新(权重, 输入, 维度, 学习率) {
    // 计算输出 y = w · x
    定义 可变 y = 0
    定义 可变 i = 0
    当 (i < 维度) {
        y = y + 权重[i] * 输入[i] / 1000
        i = i + 1
    }
    // Oja规则: w += η(xy - y²w)
    i = 0
    当 (i < 维度) {
        定义 增量 = 学习率 * (输入[i] * y / 1000 - y * y / 1000 * 权重[i] / 1000) / 1000
        权重[i] = 权重[i] + 增量
        i = i + 1
    }
    Oja_更新次数 = Oja_更新次数 + 1
    返回 y
}

// §7 BCM可塑性 (Bienenstock-Cooper-Munro)
// Δw = η·x·y·(y-θ_M), θ_M是滑动阈值
// y>θ→增强, y<θ→减弱, 防止权重爆炸

定义 可变 BCM_阈值 = 500  // 滑动阈值 ×1000
定义 可变 BCM_更新次数 = 0

函数 赫布_BCM更新(权重, 输入, 输出, 维度, 学习率) {
    // Δw = η × x × y × (y - θ_M)
    定义 调制 = 输出 * (输出 - BCM_阈值) / 1000
    定义 可变 i = 0
    当 (i < 维度) {
        权重[i] = 权重[i] + 学习率 * 输入[i] * 调制 / 1000000
        i = i + 1
    }
    // 滑动阈值更新: θ = EMA(y²)
    BCM_阈值 = (BCM_阈值 * 950 + 输出 * 输出 / 1000 * 50) / 1000
    BCM_更新次数 = BCM_更新次数 + 1
}

// §8 Nova脉冲时序依赖可塑性 (STDP)
// 原创: pre在post前→增强(A+×e^{-Δt/τ+})
//        post在pre前→减弱(-A-×e^{Δt/τ-})

定义 STDP_A正 = 100    // 增强幅度 ×1000
定义 STDP_A负 = 80     // 减弱幅度 ×1000
定义 STDP_τ = 20       // 时间常数
定义 可变 STDP_更新次数 = 0

// 指数衰减近似: e^{-x} ≈ 1000/(1000+50x)
函数 _STDP_衰减(差值) {
    定义 可变 d = 差值
    如果 (d < 0) { d = 0 - d }
    返回 1000000 / (1000 + 50 * d)
}

函数 赫布_STDP更新(权重, pre时间, post时间, 维度) {
    定义 Δt = post时间 - pre时间
    定义 可变 变化量 = 0
    如果 (Δt > 0) {
        // pre在post前 → 增强
        变化量 = STDP_A正 * _STDP_衰减(Δt) / 1000
    } 否则 {
        // post在pre前 → 减弱
        变化量 = 0 - STDP_A负 * _STDP_衰减(Δt) / 1000
    }
    定义 可变 i = 0
    当 (i < 维度) {
        权重[i] = 权重[i] + 变化量
        i = i + 1
    }
    STDP_更新次数 = STDP_更新次数 + 1
    返回 变化量
}

// NovaHebb完整统计

函数 赫布收敛_完整统计() {
    返回 [
        ["在线零数累计", 在线零数累计],
        ["曲线步数", 曲线_步数],
        ["曲线最低损失", 曲线_最低],
        ["Oja更新次数", Oja_更新次数],
        ["BCM更新次数", BCM_更新次数],
        ["BCM阈值", BCM_阈值],
        ["STDP更新次数", STDP_更新次数]
    ]
}

// 赫布学习健康检查

函数 赫布_健康检查() {
    定义 可变 问题 = []
    如果 (曲线_步数 > 10000 && 曲线_最低 > 0.5) {
        追加(问题, "收敛缓慢: 步数=" + 整数转字符串(曲线_步数) + " 损失仍高")
    }
    如果 (BCM_阈值 < 0.001) {
        追加(问题, "BCM阈值过低，可能导致不稳定")
    }
    如果 (计数(问题) == 0) { 返回 "赫布学习健康" }
    返回 问题
}

函数 赫布_重置收敛() {
    曲线_步数 = 0
    曲线_最低 = 999999
    Oja_更新次数 = 0
    BCM_更新次数 = 0
    STDP_更新次数 = 0
}

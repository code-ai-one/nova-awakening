导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/自动扩容.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../标准/原生列表.nova")
导入("../标准/原生字符串.nova")
导入("../中枢/高精定器添.nova")
导入("../中枢/时钟中枢.nova")

定义 上下文_最大历史 = 50
定义 上下文_最大实体 = 30
定义 上下文_默认超时秒 = 1800
定义 上下文_最大会话 = 256

定义 情感_中性 = 0
定义 情感_积极 = 1
定义 情感_消极 = -1

结构 对话上下文 {
    会话ID,
    用户ID,
    当前意图,
    话题,
    实体列表,
    轮次,
    创建时间,
    最后时间,
    历史消息,
    情感状态,
    话题切换次数,
    超时秒,
}

结构 历史条目 {
    角色,
    内容,
    意图,
    时间戳,
}

定义 可变 会话表 = 字典()
定义 可变 会话计数 = 0
定义 可变 总轮次 = 0

函数 上下文追踪_初始化() { 返回 成功 }

函数 上下文_创建() {
    返回 上下文_创建带ID("default", "anonymous")
}

函数 上下文_创建带ID(会话ID, 用户ID) {
    定义 ctx = 对话上下文 {
        会话ID: 会话ID,
        用户ID: 用户ID,
        当前意图: "",
        话题: "",
        实体列表: [],
        轮次: 0,
        创建时间: 获取滴答(),
        最后时间: 获取滴答(),
        历史消息: [],
        情感状态: 情感_中性,
        话题切换次数: 0,
        超时秒: 上下文_默认超时秒
    }
    字典设(会话表, 会话ID, ctx)
    会话计数 = 会话计数 + 1
    返回 ctx
}

函数 上下文_更新(ctx, 意图, 消息) {
    定义 旧意图 = ctx.当前意图
    ctx.当前意图 = 意图
    ctx.轮次 = ctx.轮次 + 1
    ctx.最后时间 = 获取滴答()
    总轮次 = 总轮次 + 1

    如果 (旧意图 != "" && 旧意图 != 意图) {
        ctx.话题 = 旧意图 + "→" + 意图
        ctx.话题切换次数 = ctx.话题切换次数 + 1
    }

    追加(ctx.历史消息, 历史条目 {
        角色: "用户",
        内容: 消息,
        意图: 意图,
        时间戳: 获取滴答()
    })

    如果 (计数(ctx.历史消息) > 上下文_最大历史) {
        ctx.历史消息 = 列表_切片(ctx.历史消息, 计数(ctx.历史消息) - 上下文_最大历史, 计数(ctx.历史消息))
    }

    定义 实体 = 上下文_提取实体(消息)
    如果 (计数(实体) > 0) {
        定义 可变 i = 0
        当 (i < 计数(实体)) {
            上下文_添加实体(ctx, 实体[i])
            i = i + 1
        }
    }

    ctx.情感状态 = 上下文_检测情感(消息)
}

函数 上下文_添加回复(ctx, 回复) {
    追加(ctx.历史消息, 历史条目 {
        角色: "助手",
        内容: 回复,
        意图: ctx.当前意图,
        时间戳: 获取滴答()
    })
    如果 (计数(ctx.历史消息) > 上下文_最大历史) {
        ctx.历史消息 = 列表_切片(ctx.历史消息, 计数(ctx.历史消息) - 上下文_最大历史, 计数(ctx.历史消息))
    }
}

函数 上下文_添加实体(ctx, 实体) {
    定义 可变 i = 0
    当 (i < 计数(ctx.实体列表)) {
        如果 (ctx.实体列表[i] == 实体) { 返回 }
        i = i + 1
    }
    追加(ctx.实体列表, 实体)
    如果 (计数(ctx.实体列表) > 上下文_最大实体) {
        ctx.实体列表 = 列表_切片(ctx.实体列表, 计数(ctx.实体列表) - 上下文_最大实体, 计数(ctx.实体列表))
    }
}

函数 上下文_提取实体(消息) {
    定义 可变 实体 = []
    定义 可变 i = 0
    定义 长度 = 字符串长度(消息)
    当 (i < 长度) {
        定义 c = 字符串取字符(消息, i)
        如果 (c == "\"" || c == "'") {
            定义 结束引号 = c
            定义 可变 j = i + 1
            当 (j < 长度 && 字符串取字符(消息, j) != 结束引号) { j = j + 1 }
            如果 (j > i + 1 && j < 长度) {
                追加(实体, 字符串子串(消息, i + 1, j))
            }
            i = j + 1
            继续
        }
        i = i + 1
    }
    返回 实体
}

定义 积极词 = ["好", "棒", "赞", "谢", "喜欢", "开心", "满意", "优秀"]
定义 消极词 = ["差", "烦", "慢", "错", "糟", "讨厌", "失望", "难"]

函数 上下文_检测情感(消息) {
    定义 可变 积极分 = 0
    定义 可变 消极分 = 0
    定义 可变 i = 0
    当 (i < 计数(积极词)) {
        如果 (字符串包含(消息, 积极词[i])) { 积极分 = 积极分 + 1 }
        i = i + 1
    }
    i = 0
    当 (i < 计数(消极词)) {
        如果 (字符串包含(消息, 消极词[i])) { 消极分 = 消极分 + 1 }
        i = i + 1
    }
    如果 (积极分 > 消极分) { 返回 情感_积极 }
    如果 (消极分 > 积极分) { 返回 情感_消极 }
    返回 情感_中性
}

函数 上下文_获取意图(ctx) { 返回 ctx.当前意图 }
函数 上下文_获取轮次(ctx) { 返回 ctx.轮次 }
函数 上下文_获取实体(ctx) { 返回 ctx.实体列表 }
函数 上下文_获取历史(ctx) { 返回 ctx.历史消息 }
函数 上下文_获取情感(ctx) { 返回 ctx.情感状态 }

函数 上下文_获取最近历史(ctx, 数量) {
    定义 总数 = 计数(ctx.历史消息)
    如果 (总数 <= 数量) { 返回 ctx.历史消息 }
    返回 列表_切片(ctx.历史消息, 总数 - 数量, 总数)
}

函数 上下文_构建提示历史(ctx, 数量) {
    定义 最近 = 上下文_获取最近历史(ctx, 数量)
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(最近)) {
        定义 条目 = 最近[i]
        结果 = 结果 + 条目.角色 + ": " + 条目.内容 + "\n"
        i = i + 1
    }
    返回 结果
}

函数 上下文_是否过期(ctx, 超时秒) {
    返回 (获取滴答() - ctx.最后时间) > 超时秒 * 100
}

函数 上下文_重置(ctx) {
    ctx.当前意图 = ""
    ctx.话题 = ""
    ctx.实体列表 = []
    ctx.轮次 = 0
    ctx.历史消息 = []
    ctx.情感状态 = 情感_中性
    ctx.话题切换次数 = 0
    ctx.最后时间 = 获取滴答()
}

函数 上下文_获取会话(会话ID) {
    返回 字典取(会话表, 会话ID)
}

函数 上下文_删除会话(会话ID) {
    字典删(会话表, 会话ID)
    会话计数 = 会话计数 - 1
}

函数 上下文_清理过期会话() {
    定义 现在 = 读取毫秒()
    定义 可变 键列表 = 字典键(会话表)
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        定义 会话 = 字典取(会话表, 键列表[i])
        如果 (会话 != 空 && 现在 - 会话.最近活跃 > 会话超时毫秒) {
            字典删(会话表, 键列表[i])
            会话计数 = 会话计数 - 1
        }
        i = i + 1
    }
}

导入("../基础.nova")


定义 MA_随机态 = 27182
函数 MA_随机() {
 MA_随机态 = MA_随机态 ^ (MA_随机态 << 13)
 MA_随机态 = MA_随机态 ^ (MA_随机态 >> 7)
 MA_随机态 = MA_随机态 ^ (MA_随机态 << 17)
 如果 (MA_随机态 < 0) { MA_随机态 = 0 - MA_随机态 }
 返回 MA_随机态
}

// 智能体定义
// [ID, 角色, 状态, 动作空间大小, 奖励累积, 消息队列, 能力列表]
定义 角色_执行者 = 0
定义 角色_规划者 = 1
定义 角色_评审者 = 2
定义 角色_协调者 = 3
定义 角色_专家 = 4

函数 智能体_创建(id, 角色, 动作空间) { 返回 [id, 角色, [], 动作空间, 0, [], []]
}

函数 智能体_ID(a) { 返回 a[0] }
函数 智能体_角色(a) { 返回 a[1] }
函数 智能体_状态(a) { 返回 a[2] }
函数 智能体_奖励(a) { 返回 a[4] }

函数 智能体_设状态(a, 状态) { a[2] = 状态 }
函数 智能体_加奖励(a, r) { a[4] = a[4] + r }

函数 智能体_发消息(a, 消息) { 追加(a[5], 消息) }
函数 智能体_收消息(a) {
    定义 可变 新队列 = []
    如果 (计数(a[5]) == 0) { 返回 空
}
 定义 msg = a[5][0]
 定义 可变 i = 1
 当 (i < 计数(a[5])) { 追加(新队列, a[5][i])
 i = i + 1 }
 a[5] = 新队列
 返回 msg
}

函数 智能体_添加能力(a, 能力哈希) { 追加(a[6], 能力哈希) }

// 多智能体环境
// [智能体列表, 全局状态, 通信图, 时间步, 历史]
函数 多智能体_环境_创建() { 返回 [[], [], [], 0, []]
}

函数 环境_添加智能体(环境, agent) {
 追加(环境[0], agent)
}

函数 环境_智能体数(环境) { 返回 计数(环境[0]) }

函数 环境_广播(环境, 发送者ID, 消息) { 定义 可变 i = 0
 当 (i < 计数(环境[0])) { 如果 (智能体_ID(环境[0][i]) != 发送者ID) {
 智能体_发消息(环境[0][i], [发送者ID, 消息])
 }
 i = i + 1
 }
}

函数 环境_点对点(环境, 发送者ID, 接收者ID, 消息) { 定义 可变 i = 0
 当 (i < 计数(环境[0])) { 如果 (智能体_ID(环境[0][i]) == 接收者ID) {
 智能体_发消息(环境[0][i], [发送者ID, 消息])
 }
 i = i + 1
 }
}

// QMIX: 价值分解
函数 QMIX_Q总(个体Q列表, 混合权重, 混合偏置) {
 // Q_tot = f(Q_1,...,Q_n) 单调混合
 定义 n = 计数(个体Q列表)
 定义 可变 加权和 = 混合偏置
 定义 可变 i = 0
 当 (i < n) { 定义 可变 w = 1000 / n // 默认均等
 如果 (i < 计数(混合权重)) {
 w = 混合权重[i]
 如果 (w < 0) { w = 0 } // 单调约束: 权重非负
 }
 加权和 = 加权和 + w * 个体Q列表[i] / 1000
 i = i + 1
 }
 返回 加权和
}

// VDN: 简单加法分解
函数 VDN_Q总(个体Q列表) { 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 计数(个体Q列表)) { 总 = 总 + 个体Q列表[i]
 i = i + 1 }
 返回 总
}

// 通信模块 (CommNet)
函数 通信_均值池化(智能体隐藏列表, 排除idx) { 定义 n = 计数(智能体隐藏列表)
 如果 (n <= 1) { 返回 [] }
 定义 维度 = 计数(智能体隐藏列表[0])
 定义 可变 均值 = []
 定义 可变 d = 0
 当 (d < 维度) { 追加(均值, 0)
 d = d + 1 }
 定义 可变 计数值 = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (i != 排除idx) {
 d = 0
 当 (d < 维度) { 如果 (d < 计数(智能体隐藏列表[i])) {
 均值[d] = 均值[d] + 智能体隐藏列表[i][d]
 }
 d = d + 1
 }
 计数值 = 计数值 + 1
 }
 i = i + 1
 }
 如果 (计数值 > 0) {
 d = 0
 当 (d < 维度) { 均值[d] = 均值[d] / 计数值
 d = d + 1 }
 }
 返回 均值
}

// 角色分配
函数 角色_自动分配(环境, 任务需求列表) { 定义 n = 环境_智能体数(环境)
 定义 可变 分配 = []
 定义 可变 i = 0
 当 (i < 计数(任务需求列表)) {
 // 找能力最匹配的智能体
 定义 可变 最佳 = -1
 定义 可变 最佳分 = -1
 定义 可变 j = 0
 当 (j < n) { 定义 能力 = 环境[0][j][6]
 定义 需求 = 任务需求列表[i]
 // 简单匹配: 能力列表包含需求
 定义 可变 分数 = 0
 定义 可变 k = 0
 当 (k < 计数(能力)) { 如果 (能力[k] == 需求) { 分数 = 分数 + 1000 }
 k = k + 1
 }
 如果 (分数 > 最佳分) { 最佳 = j
 最佳分 = 分数 }
 j = j + 1
 }
 追加(分配, [i, 最佳])
 i = i + 1
 }
 返回 分配
}

// 任务委派 (AutoGen风格)
函数 委派_创建(任务描述哈希) { 返回 [任务描述哈希, -1, 0, [], 0] // [任务, 分配者, 状态, 子任务, 结果]
}

函数 委派_分配(委派, 智能体ID) { 委派[1] = 智能体ID }
函数 委派_完成(委派, 结果) { 委派[2] = 1
委派[4] = 结果 }
函数 委派_是否完成(委派) { 返回 委派[2] }

函数 委派_添加子任务(委派, 子任务) {
 追加(委派[3], 子任务)
}

函数 委派_所有完成(委派) { 定义 可变 i = 0
 当 (i < 计数(委派[3])) { 如果 (委派_是否完成(委派[3][i]) == 0) { 返回 0 }
 i = i + 1
 }
 返回 1
}

// 对话编排
函数 对话轮_创建() { 返回 [[],] } // [消息列表, 当前说话者, 轮数]

函数 对话轮_发言(对话, 说话者ID, 内容哈希) {
 追加(对话[0], [说话者ID, 内容哈希, 对话[2]])
 对话[2] = 对话[2] + 1
}

函数 对话轮_轮转(对话, 智能体数) {
 对话[1] = (对话[1] + 1) % 智能体数
 返回 对话[1]
}

函数 对话轮_历史长度(对话) { 返回 计数(对话[0]) }

// 投票共识
函数 投票_多数(投票列表, 选项数) { 定义 可变 计数列表 = []
 定义 可变 i = 0
 当 (i < 选项数) { 追加(计数列表, 0)
 i = i + 1 }
 i = 0
 当 (i < 计数(投票列表)) { 定义 v = 投票列表[i]
 如果 (v >= 0 且 v < 选项数) { 计数列表[v] = 计数列表[v] + 1 }
 i = i + 1
 }
 定义 可变 最多 = 0
 i = 1
 当 (i < 选项数) { 如果 (计数列表[i] > 计数列表[最多]) { 最多 = i }
 i = i + 1
 }
 返回 最多
}

// 合作奖励
函数 团队奖励_分配(总奖励, 贡献列表) { 定义 n = 计数(贡献列表)
 定义 可变 总贡献 = 0
 定义 可变 i = 0
 当 (i < n) { 总贡献 = 总贡献 + 贡献列表[i]
 i = i + 1 }
 如果 (总贡献 == 0) { 总贡献 = n }
 定义 可变 分配 = []
 i = 0
 当 (i < n) {
 追加(分配, 总奖励 * 贡献列表[i] / 总贡献)
 i = i + 1
 }
 返回 分配
}

导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("./网络设备打印.nova")

// 拥塞控制(NewNova经典)

函数 tcp_拥塞_ACK(tcb) {
    如果 (tcb.拥塞窗口 < tcb.慢启动阈值) {
        // 慢启动: 每个ACK增加一个MSS
        tcb.拥塞窗口 = tcb.拥塞窗口 + tcb.mss
    } 否则 {
        // 拥塞避免: 每Nova往返时间增加一个MSS
        tcb.拥塞窗口 = tcb.拥塞窗口 + (tcb.mss * tcb.mss) / tcb.拥塞窗口
    }
}

函数 tcp_拥塞_丢包(tcb) {
    // 乘法减少
    tcb.慢启动阈值 = 取大(tcb.拥塞窗口 / 2, 2 * tcb.mss)
    tcb.拥塞窗口 = tcb.慢启动阈值 + 3 * tcb.mss  // 快速恢复
}

函数 tcp_拥塞_超时(tcb) {
    // 超时重置
    tcb.慢启动阈值 = 取大(tcb.拥塞窗口 / 2, 2 * tcb.mss)
    tcb.拥塞窗口 = tcb.mss  // 重新慢启动
}

// Nova往返时间估计(Jacobson算法)

函数 tcp_更新Nova往返时间(tcb, Nova往返时间) {
    如果 (tcb.sNova往返时间 == 0) {
        // 首次测量
        tcb.sNova往返时间 = Nova往返时间
        tcb.Nova往返时间var = Nova往返时间 / 2
    } 否则 {
        // SNova往返时间 = (1-α)SNova往返时间 + α*Nova往返时间,  α = 1/8
        定义 差值 = Nova往返时间 - tcb.sNova往返时间
        tcb.sNova往返时间 = tcb.sNova往返时间 + 差值 / 8

        // Nova往返时间VAR = (1-β)Nova往返时间VAR + β*|差值|, β = 1/4
        定义 绝对差值 = 差值
        如果 (绝对差值 < 0) { 绝对差值 = 0 - 绝对差值 }
        tcb.Nova往返时间var = tcb.Nova往返时间var + (绝对差值 - tcb.Nova往返时间var) / 4
    }

    // RTO = SNova往返时间 + 4*Nova往返时间VAR
    tcb.重传超时 = tcb.sNova往返时间 + 4 * tcb.Nova往返时间var
    如果 (tcb.重传超时 < 传控_最小RTO) { tcb.重传超时 = 传控_最小RTO }
    如果 (tcb.重传超时 > 传控_最大RTO) { tcb.重传超时 = 传控_最大RTO }
}

// 传控头部访问函数

函数 tcp_获取源端口(头) { 返回 网络序_读u16(头, 传控_偏移_源端口) }
函数 tcp_获取目标端口(头) { 返回 网络序_读u16(头, 传控_偏移_目标端口) }
函数 tcp_获取序号(头) { 返回 网络序_读u32(头, 传控_偏移_序号) }
函数 tcp_获取确认号(头) { 返回 网络序_读u32(头, 传控_偏移_确认号) }
函数 tcp_获取标志(头) { 返回 头[传控_偏移_标志] & 0x3F }
函数 tcp_获取窗口(头) { 返回 网络序_读u16(头, 传控_偏移_窗口) }
函数 tcp_获取数据偏移(头) { 返回 (头[传控_偏移_数据偏移] >> 4) & 0x0F }

函数 tcp_设置源端口(头, 值) { 网络序_写u16(头, 传控_偏移_源端口, 值) }
函数 tcp_设置目标端口(头, 值) { 网络序_写u16(头, 传控_偏移_目标端口, 值) }
函数 tcp_设置序号(头, 值) { 网络序_写u32(头, 传控_偏移_序号, 值) }
函数 tcp_设置确认号(头, 值) { 网络序_写u32(头, 传控_偏移_确认号, 值) }
函数 tcp_设置标志(头, 值) { 头[传控_偏移_标志] = 值 & 0x3F }
函数 tcp_设置窗口(头, 值) { 网络序_写u16(头, 传控_偏移_窗口, 值) }
函数 tcp_设置数据偏移(头, 值) { 头[传控_偏移_数据偏移] = (值 << 4) & 0xF0 }

// 传控选项解析与添加

定义 传控_选项_结束     = 0
定义 传控_选项_NOP      = 1
定义 传控_选项_MSS      = 2
定义 传控_选项_窗口缩放 = 3
定义 传控_选项_SACK允许 = 4
定义 传控_选项_时间戳   = 8

函数 tcp_解析选项(tcb, 头) {
    定义 头长度 = tcp_获取数据偏移(头) * 4
    如果 (头长度 <= 传控_头部大小) { 返回 }

    定义 可变 偏移 = 传控_头部大小
    当 (偏移 < 头长度) {
        定义 类型 = 头[偏移]
        如果 (类型 == 传控_选项_结束) { 跳出 }
        如果 (类型 == 传控_选项_NOP) { 偏移 = 偏移 + 1; 继续 }

        定义 长度 = 头[偏移 + 1]
        如果 (长度 < 2) { 跳出 }

        匹配 (类型) {
            传控_选项_MSS => {
                如果 (长度 == 4) {
                    tcb.mss = 网络序_读u16(头, 偏移 + 2)
                    如果 (tcb.mss < 传控_最小MSS) { tcb.mss = 传控_最小MSS }
                }
            }
            传控_选项_窗口缩放 => {
                如果 (长度 == 3) {
                    tcb.窗口缩放 = 头[偏移 + 2]
                    如果 (tcb.窗口缩放 > 14) { tcb.窗口缩放 = 14 }
                }
            }
            _ => {}
        }
        偏移 = 偏移 + 长度
    }
}

函数 tcp_添加MSS选项(头, mss) {
    定义 偏移 = 传控_头部大小
    头[偏移] = 传控_选项_MSS
    头[偏移 + 1] = 4
    网络序_写u16(头, 偏移 + 2, mss)
}

函数 tcp_添加窗口缩放选项(头, 缩放值) {
    定义 偏移 = 传控_头部大小 + 4
    头[偏移] = 传控_选项_NOP
    头[偏移 + 1] = 传控_选项_窗口缩放
    头[偏移 + 2] = 3
    头[偏移 + 3] = 缩放值
}

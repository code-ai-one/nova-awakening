// NovaOS 块设备IO · 数据指针与BIO完整子系统
// NBDP理论 (Nova Block Data Pointer Engine)
// 核心创新:
// 1. 零拷贝指针映射 — 页面+偏移直接计算物理地址,避免内存复制
// 2. DMA散列聚合IO — 多向量批量提交,硬件直接读写分散页面
// 3. BIO池化分配 — 预分配对象池避免IO路径上堆分配
// 4. 智能IO合并 — 相邻扇区请求自动合并,减少请求数
// 5. AI预取引擎 — 基于访问模式预测下一次IO位置

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("../推理/值乘.nova")
导入("../中枢/内核打印.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/伙伴系统释放.nova")

定义 BIO_标志_读      = 0x01
定义 BIO_标志_写      = 0x02
定义 BIO_标志_同步    = 0x04
定义 BIO_标志_刷新    = 0x08
定义 BIO_标志_FUA     = 0x10
定义 BIO_标志_丢弃    = 0x20
定义 BIO_标志_预取    = 0x40
定义 BIO_标志_优先    = 0x80
定义 BIO_最大向量数  = 256
定义 BIO_池大小       = 128
定义 扇区大小_默认   = 512
定义 页面大小_默认   = 4096
定义 DMA_对齐掩码    = 0xFFF
定义 IO_合并门槛     = 8
定义 预取窗口大小   = 32
定义 预取历史大小   = 64

外部 全局AI总线

结构 BIO向量 {
    页,          // u64 页面地址
    偏移,        // u32 页内偏移
    长度,        // u32 数据长度
}

结构 BIO {
    设备,        // 块设备指针
    扇区,        // u64 起始扇区号
    大小,        // u64 总字节数
    标志,        // u32 BIO标志
    向量列表,    // [] BIO向量数组
    向量数,      // u32 当前向量数
    最大向量数,
    当前向量,    // u32 遍历索引
    回调,        // 函数指针
    私有数据,
    错误码,
    引用计数,
    提交时间,
    完成时间,
}

结构 BIO池 {
    空闲列表,    // [] 预分配的BIO对象
    总数,
    空闲数,
    分配次数,
    回收次数,
    池失败次数,  // u64 池空时回退到堆分配
}

结构 BIO统计 {
    总读次数,
    总写次数,
    总读字节,
    总写字节,
    拆分次数,
    合并次数,
    DMA映射次数,
    预取触发数,
    预取命中数,
    平均IO延迟_微秒, // f64
    最大IO延迟_微秒,
    AI优化次数,
}

结构 预取记录 {
    扇区号,
    访问时间,
    是读,
}

定义 可变 bio_池 = BIO池 {}
定义 可变 bio_统计 = BIO统计 {}
定义 可变 bio_预取历史 = []
定义 可变 bio_已初始化 = 假

// §1 BIO子系统初始化

函数 bio_子系统_初始化() {
    如果 (bio_已初始化) { 返回 真 }
    
    // 初始化BIO池
    bio_池.空闲列表 = []
    bio_池.总数 = BIO_池大小
    bio_池.空闲数 = BIO_池大小
    bio_池.分配次数 = 0
    bio_池.回收次数 = 0
    bio_池.池失败次数 = 0
    
    // 预分配池对象
    定义 可变 i = 0
    当 (i < BIO_池大小) {
        定义 b = BIO {}
        b.向量列表 = []
        b.向量数 = 0
        b.最大向量数 = BIO_最大向量数
        b.当前向量 = 0
        b.引用计数 = 0
        b.错误码 = 0
        追加(bio_池.空闲列表, b)
        i = i + 1
    }
    
    // 初始化统计
    bio_统计.总读次数 = 0
    bio_统计.总写次数 = 0
    bio_统计.总读字节 = 0
    bio_统计.总写字节 = 0
    bio_统计.拆分次数 = 0
    bio_统计.合并次数 = 0
    bio_统计.DMA映射次数 = 0
    bio_统计.预取触发数 = 0
    bio_统计.预取命中数 = 0
    bio_统计.平均IO延迟_微秒 = 0.0
    bio_统计.最大IO延迟_微秒 = 0
    bio_统计.AI优化次数 = 0
    
    // 初始化预取历史
    bio_预取历史 = []
    
    bio_已初始化 = 真
    返回 真
}

// §2 BIO池化分配与回收

函数 bio_分配(最大向量) {
    如果 (!bio_已初始化) { bio_子系统_初始化() }
    
    // 优先从池分配
    如果 (bio_池.空闲数 > 0) {
        定义 b = bio_池.空闲列表[bio_池.空闲数 - 1]
        bio_池.空闲数 = bio_池.空闲数 - 1
        bio_池.分配次数 = bio_池.分配次数 + 1
        // 重置对象
        b.向量列表 = []
        b.向量数 = 0
        b.当前向量 = 0
        b.最大向量数 = 最大向量
        b.大小 = 0
        b.标志 = 0
        b.引用计数 = 1
        b.错误码 = 0
        b.设备 = 空
        b.回调 = 空
        返回 b
    }
    
    // 池空,回退到堆分配
    bio_池.池失败次数 = bio_池.池失败次数 + 1
    定义 b = BIO {}
    b.向量列表 = []
    b.向量数 = 0
    b.最大向量数 = 最大向量
    b.当前向量 = 0
    b.引用计数 = 1
    b.错误码 = 0
    返回 b
}

函数 bio_释放(bio) {
    如果 (bio == 空) { 返回 }
    bio.引用计数 = bio.引用计数 - 1
    如果 (bio.引用计数 > 0) { 返回 }
    
    // 归还到池
    如果 (bio_池.空闲数 < bio_池.总数) {
        bio_池.空闲列表[bio_池.空闲数] = bio
        bio_池.空闲数 = bio_池.空闲数 + 1
        bio_池.回收次数 = bio_池.回收次数 + 1
    }
    // 否则放弃(堆分配的由GC回收)
}

函数 bio_增加引用(bio) {
    如果 (bio == 空) { 返回 }
    bio.引用计数 = bio.引用计数 + 1
}

// §3 零拷贝数据指针与向量遍历

// 零拷贝: 直接计算页面+偏移地址,不复制数据
函数 bio_获取数据指针(bio, 向量索引) {
    如果 (bio == 空) { 返回 空 }
    如果 (向量索引 >= bio.向量数) { 返回 空 }
    定义 vec = bio.向量列表[向量索引]
    返回 页面地址(vec.页) + vec.偏移
}

// 获取向量的DMA物理地址(硬件直接访问)
函数 bio_获取DMA地址(bio, 向量索引) {
    如果 (bio == 空 || 向量索引 >= bio.向量数) { 返回 0 }
    定义 vec = bio.向量列表[向量索引]
    定义 物理 = 页面_到_物理(vec.页) + vec.偏移
    // DMA对齐检查
    如果 ((物理 & DMA_对齐掩码) != 0) {
        // 非DMA对齐,需要bounce buffer
        返回 bio_创建bounce(物理, vec.长度)
    }
    bio_统计.DMA映射次数 = bio_统计.DMA映射次数 + 1
    返回 物理
}

函数 bio_创建bounce(物理地址, 长度) {
    // 分配对齐的bounce buffer并复制数据
    定义 对齐地址 = (物理地址 + 页面大小_默认 - 1) & (~DMA_对齐掩码)
    定义 bounce = 内核_分配_对齐(长度, 页面大小_默认)
    如果 (bounce != 0) {
        内存_复制(bounce, 物理地址, 长度)
    }
    返回 bounce
}

函数 bio_下一个向量(bio) {
    如果 (bio == 空) { 返回 空 }
    如果 (bio.当前向量 >= bio.向量数) { 返回 空 }
    定义 vec = bio.向量列表[bio.当前向量]
    bio.当前向量 = bio.当前向量 + 1
    返回 vec
}

函数 bio_重置遍历(bio) {
    如果 (bio != 空) { bio.当前向量 = 0 }
}

函数 bio_总大小(bio) {
    如果 (bio == 空) { 返回 0 }
    返回 bio.大小
}

函数 bio_扇区数(bio) {
    如果 (bio == 空 || bio.设备 == 空) { 返回 0 }
    返回 bio.大小 / bio.设备.扇区大小
}

函数 bio_添加页(bio, 页, 长度, 偏移) {
    如果 (bio == 空) { 返回 假 }
    如果 (bio.向量数 >= bio.最大向量数) { 返回 假 }
    
    定义 vec = BIO向量 {}
    vec.页 = 页
    vec.偏移 = 偏移
    vec.长度 = 长度
    追加(bio.向量列表, vec)
    bio.向量数 = bio.向量数 + 1
    bio.大小 = bio.大小 + 长度
    返回 真
}

函数 bio_添加内核缓冲(bio, 缓冲, 大小) {
    如果 (bio == 空 || 缓冲 == 0) { 返回 假 }
    定义 页 = 虚拟_到_页(缓冲)
    定义 偏移 = 缓冲 & DMA_对齐掩码
    返回 bio_添加页(bio, 页, 大小, 偏移)
}

// §4 BIO拆分与合并

函数 bio_拆分(bio, 扇区数) {
    如果 (bio == 空 || bio.设备 == 空) { 返回 空 }
    定义 拆分大小 = 扇区数 * bio.设备.扇区大小
    如果 (拆分大小 >= bio.大小) { 返回 空 }

    定义 可变 新bio = bio_分配(bio.最大向量数)
    如果 (新bio == 空) { 返回 空 }

    新bio.设备 = bio.设备
    新bio.扇区 = bio.扇区 + 扇区数
    新bio.标志 = bio.标志

    // 将bio后半部分的向量移到新bio
    定义 可变 累积大小 = 0
    定义 可变 i = 0
    当 (i < bio.向量数) {
        如果 (累积大小 >= 拆分大小) {
            bio_添加页(新bio, bio.向量列表[i].页,
                bio.向量列表[i].长度, bio.向量列表[i].偏移)
        }
        累积大小 = 累积大小 + bio.向量列表[i].长度
        i = i + 1
    }

    // 截断原bio
    bio.大小 = 拆分大小
    累积大小 = 0
    bio.向量数 = 0
    i = 0
    当 (累积大小 < 拆分大小) {
        累积大小 = 累积大小 + bio.向量列表[i].长度
        bio.向量数 = bio.向量数 + 1
        i = i + 1
    }

    bio_统计.拆分次数 = bio_统计.拆分次数 + 1
    返回 新bio
}

// 智能IO合并: 将相邻扇区的BIO合并为一个
函数 bio_尝试合并(bio1, bio2) {
    如果 (bio1 == 空 || bio2 == 空) { 返回 假 }
    如果 (bio1.设备 != bio2.设备) { 返回 假 }
    如果 ((bio1.标志 & 0x03) != (bio2.标志 & 0x03)) { 返回 假 }
    
    // 检查扇区是否相邻
    定义 bio1_结束扇区 = bio1.扇区 + bio_扇区数(bio1)
    如果 (bio1_结束扇区 != bio2.扇区) { 返回 假 }
    
    // 检查向量数不超限
    如果 (bio1.向量数 + bio2.向量数 > bio1.最大向量数) { 返回 假 }
    
    // 执行合并: 将bio2的向量追加到bio1
    定义 可变 i = 0
    当 (i < bio2.向量数) {
        bio_添加页(bio1, bio2.向量列表[i].页,
            bio2.向量列表[i].长度, bio2.向量列表[i].偏移)
        i = i + 1
    }
    
    bio_统计.合并次数 = bio_统计.合并次数 + 1
    bio_释放(bio2)
    返回 真
}

// §5 便捷BIO创建与提交

函数 bio_创建_读(设备, 扇区, 缓冲, 大小) {
    定义 可变 bio = bio_分配(1)
    如果 (bio == 空) { 返回 空 }
    bio.设备 = 设备
    bio.扇区 = 扇区
    bio.标志 = BIO_标志_读
    bio_添加内核缓冲(bio, 缓冲, 大小)
    bio_统计.总读次数 = bio_统计.总读次数 + 1
    bio_统计.总读字节 = bio_统计.总读字节 + 大小
    返回 bio
}

函数 bio_创建_写(设备, 扇区, 缓冲, 大小) {
    定义 可变 bio = bio_分配(1)
    如果 (bio == 空) { 返回 空 }
    bio.设备 = 设备
    bio.扇区 = 扇区
    bio.标志 = BIO_标志_写
    bio_添加内核缓冲(bio, 缓冲, 大小)
    bio_统计.总写次数 = bio_统计.总写次数 + 1
    bio_统计.总写字节 = bio_统计.总写字节 + 大小
    返回 bio
}

函数 bio_创建_批量读(设备, 扇区, 页列表, 页数) {
    定义 可变 bio = bio_分配(页数)
    如果 (bio == 空) { 返回 空 }
    bio.设备 = 设备
    bio.扇区 = 扇区
    bio.标志 = BIO_标志_读
    
    定义 可变 i = 0
    当 (i < 页数) {
        bio_添加页(bio, 页列表[i], 页面大小_默认, 0)
        i = i + 1
    }
    bio_统计.总读次数 = bio_统计.总读次数 + 1
    bio_统计.总读字节 = bio_统计.总读字节 + 页数 * 页面大小_默认
    返回 bio
}

函数 bio_提交(bio) {
    如果 (bio == 空 || bio.设备 == 空) { 返回 -1 }
    bio.提交时间 = 系统_获取时间戳()
    
    // 记录预取历史
    bio_记录访问(bio.扇区, (bio.标志 & BIO_标志_读) != 0)
    
    // 提交到设备队列
    定义 结果 = 设备_提交请求(bio.设备, bio)
    返回 结果
}

函数 bio_提交_同步(bio) {
    如果 (bio == 空) { 返回 -1 }
    bio.标志 = bio.标志 | BIO_标志_同步
    定义 结果 = bio_提交(bio)
    // 同步等待完成
    当 (bio.完成时间 == 0) {
        系统_延迟(1)
    }
    // 计算IO延迟
    定义 延迟 = bio.完成时间 - bio.提交时间
    如果 (延迟 > bio_统计.最大IO延迟_微秒) {
        bio_统计.最大IO延迟_微秒 = 延迟
    }
    返回 bio.错误码
}

函数 bio_完成回调(bio, 错误码) {
    如果 (bio == 空) { 返回 }
    bio.错误码 = 错误码
    bio.完成时间 = 系统_获取时间戳()
    如果 (bio.回调 != 空) {
        bio.回调(bio)
    }
}

// §6 AI预取引擎

函数 bio_记录访问(扇区, 是读) {
    定义 记录 = 预取记录 {}
    记录.扇区号 = 扇区
    记录.访问时间 = 系统_获取时间戳()
    记录.是读 = 是读
    追加(bio_预取历史, 记录)
    
    // 保持历史窗口大小
    如果 (计数(bio_预取历史) > 预取历史大小) {
        bio_预取历史 = 数组_切片(bio_预取历史, 1, 计数(bio_预取历史))
    }
}

// 检测顺序访问模式
函数 bio_检测顺序模式() {
    定义 历史数 = 计数(bio_预取历史)
    如果 (历史数 < 4) { 返回 假 }
    
    // 检查最近4次访问是否顺序递增
    定义 可变 顺序计数 = 0
    定义 可变 i = 历史数 - 3
    当 (i < 历史数) {
        如果 (bio_预取历史[i].扇区号 > bio_预取历史[i - 1].扇区号) {
            顺序计数 = 顺序计数 + 1
        }
        i = i + 1
    }
    返回 顺序计数 >= 2
}

// 计算顺序访问步长
函数 bio_计算步长() {
    定义 历史数 = 计数(bio_预取历史)
    如果 (历史数 < 2) { 返回 0 }
    
    定义 可变 总步长 = 0
    定义 可变 有效数 = 0
    定义 可变 i = 历史数 - 3
    如果 (i < 1) { i = 1 }
    当 (i < 历史数) {
        定义 差 = bio_预取历史[i].扇区号 - bio_预取历史[i - 1].扇区号
        如果 (差 > 0) {
            总步长 = 总步长 + 差
            有效数 = 有效数 + 1
        }
        i = i + 1
    }
    如果 (有效数 == 0) { 返回 0 }
    返回 总步长 / 有效数
}

// AI预取触发
函数 bio_AI预取(设备) {
    如果 (设备 == 空) { 返回 }
    如果 (!bio_检测顺序模式()) { 返回 }
    
    定义 历史数 = 计数(bio_预取历史)
    如果 (历史数 == 0) { 返回 }
    
    定义 最近扇区 = bio_预取历史[历史数 - 1].扇区号
    定义 步长 = bio_计算步长()
    如果 (步长 == 0) { 步长 = 8 }  // 默认8扇区
    
    // 如果有AI总线,用AI预测更精准的预取范围
    定义 可变 预取扇区数 = 预取窗口大小
    如果 (全局AI总线 != 空) {
        定义 特征 = Tensor_创建(8)
        Tensor_写(特征, 0, 最近扇区)
        Tensor_写(特征, 1, 步长)
        Tensor_写(特征, 2, bio_统计.总读次数)
        Tensor_写(特征, 3, bio_统计.预取命中数)
        Tensor_写(特征, 4, bio_统计.预取触发数)
        Tensor_写(特征, 5, 历史数)
        Tensor_写(特征, 6, bio_统计.总读字节)
        Tensor_写(特征, 7, bio_统计.平均IO延迟_微秒)
        
        定义 结果 = AI总线_推理(全局AI总线, "块设备预取", 特征)
        如果 (结果 != 空) {
            定义 AI建议 = Tensor_读(结果, 0)
            如果 (AI建议 > 0 && AI建议 <= 256) {
                预取扇区数 = AI建议
            }
            bio_统计.AI优化次数 = bio_统计.AI优化次数 + 1
        }
        Tensor_释放(特征)
    }
    
    // 发起预取BIO
    定义 预取大小 = 预取扇区数 * 扇区大小_默认
    定义 预取缓冲 = 内核_分配(预取大小)
    如果 (预取缓冲 != 0) {
        定义 bio = bio_创建_读(设备, 最近扇区 + 步长, 预取缓冲, 预取大小)
        如果 (bio != 空) {
            bio.标志 = bio.标志 | BIO_标志_预取
            bio_提交(bio)
            bio_统计.预取触发数 = bio_统计.预取触发数 + 1
        }
    }
}

// §7 DMA散列聚合IO

结构 散列聚合表项 {
    物理地址,
    长度,
}

函数 bio_构建SG表(bio) {
    如果 (bio == 空) { 返回 空 }
    
    定义 可变 sg表 = []
    定义 可变 i = 0
    当 (i < bio.向量数) {
        定义 vec = bio.向量列表[i]
        定义 项 = 散列聚合表项 {}
        项.物理地址 = 页面_到_物理(vec.页) + vec.偏移
        项.长度 = vec.长度
        
        // 尝试合并相邻的SG项
        如果 (计数(sg表) > 0) {
            定义 上一项 = sg表[计数(sg表) - 1]
            如果 (上一项.物理地址 + 上一项.长度 == 项.物理地址) {
                // 物理连续,合并
                上一项.长度 = 上一项.长度 + 项.长度
                i = i + 1
                // 继续下一个
            } 否则 {
                追加(sg表, 项)
                i = i + 1
            }
        } 否则 {
            追加(sg表, 项)
            i = i + 1
        }
    }
    返回 sg表
}

函数 bio_DMA映射全部(bio) {
    如果 (bio == 空) { 返回 假 }
    
    定义 可变 i = 0
    当 (i < bio.向量数) {
        定义 dma地址 = bio_获取DMA地址(bio, i)
        如果 (dma地址 == 0) { 返回 假 }
        i = i + 1
    }
    返回 真
}

// §8 诊断与统计

函数 bio_获取统计() {
    返回 bio_统计
}

函数 bio_获取池统计() {
    返回 bio_池
}

函数 bio_打印统计() {
    内核打印("═══ NBDP 块IO统计 ═══")
    内核打印("总读: " + 转文本(bio_统计.总读次数) + "次 " + 转文本(bio_统计.总读字节) + "字节")
    内核打印("总写: " + 转文本(bio_统计.总写次数) + "次 " + 转文本(bio_统计.总写字节) + "字节")
    内核打印("拆分/合并: " + 转文本(bio_统计.拆分次数) + "/" + 转文本(bio_统计.合并次数))
    内核打印("DMA映射: " + 转文本(bio_统计.DMA映射次数))
    内核打印("预取触发/命中: " + 转文本(bio_统计.预取触发数) + "/" + 转文本(bio_统计.预取命中数))
    内核打印("池分配/回收/失败: " + 转文本(bio_池.分配次数) + "/" + 转文本(bio_池.回收次数) + "/" + 转文本(bio_池.池失败次数))
    内核打印("AI优化: " + 转文本(bio_统计.AI优化次数))
}

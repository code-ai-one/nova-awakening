导入("../中枢/系统调用表.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/整数转字符串.nova")

定义 缓存_单态 = 0
定义 缓存_多态 = 1
定义 缓存_超态 = 2
定义 最大多态 = 4
定义 最大缓存点 = 512
定义 衰减基数 = 1024

结构 内联缓存项 {
    形状哈希,
    属性偏移,
    命中次数,
}

结构 内联缓存点 {
    代码位置,
    状态,
    项表,
    项数,
    总命中,
    总未中,
    转换次数,
}

定义 可变 缓存点表 = []
定义 可变 缓存点数 = 0
定义 可变 总命中 = 0
定义 可变 总未中 = 0
定义 可变 预热次数 = 0
定义 可变 超态转换 = 0

函数 内联缓存_创建(代码位置) {
    如果 (缓存点数 >= 最大缓存点) { 返回 -1 }
    定义 点 = 内联缓存点 {}
    点.代码位置 = 代码位置
    点.状态 = 缓存_单态
    点.项表 = 堆_分配(最大多态 * 24)
    点.项数 = 0
    点.总命中 = 0
    点.总未中 = 0
    点.转换次数 = 0
    追加(缓存点表, 点)
    定义 索引 = 缓存点数
    缓存点数 = 缓存点数 + 1
    返回 索引
}

函数 内联缓存_查找(缓存索引, 形状哈希) {
    如果 (缓存索引 >= 缓存点数) { 返回 -1 }
    定义 点 = 缓存点表[缓存索引]
    如果 (点.状态 == 缓存_超态) {
        点.总未中 = 点.总未中 + 1
        总未中 = 总未中 + 1
        返回 -1
    }
    定义 可变 序号 = 0
    当 (序号 < 点.项数) {
        定义 偏移 = 点.项表 + 序号 * 24
        如果 (内存_读64(偏移) == 形状哈希) {
            定义 属性偏移 = 内存_读64(偏移 + 8)
            内存_写64(偏移 + 16, 内存_读64(偏移 + 16) + 1)
            点.总命中 = 点.总命中 + 1
            总命中 = 总命中 + 1
            返回 属性偏移
        }
        序号 = 序号 + 1
    }
    点.总未中 = 点.总未中 + 1
    总未中 = 总未中 + 1
    返回 -1
}

函数 内联缓存_更新(缓存索引, 形状哈希, 属性偏移) {
    如果 (缓存索引 >= 缓存点数) { 返回 }
    定义 点 = 缓存点表[缓存索引]
    如果 (点.状态 == 缓存_超态) { 返回 }
    如果 (点.项数 >= 最大多态) {
        点.状态 = 缓存_超态
        点.转换次数 = 点.转换次数 + 1
        超态转换 = 超态转换 + 1
        返回
    }
    定义 偏移 = 点.项表 + 点.项数 * 24
    内存_写64(偏移, 形状哈希)
    内存_写64(偏移 + 8, 属性偏移)
    内存_写64(偏移 + 16, 1)
    点.项数 = 点.项数 + 1
    如果 (点.项数 == 1) { 点.状态 = 缓存_单态 }
    否则 {
        点.状态 = 缓存_多态
        点.转换次数 = 点.转换次数 + 1
    }
}

函数 内联缓存_预热(缓存索引, 形状哈希, 属性偏移) {
    预热次数 = 预热次数 + 1
    内联缓存_更新(缓存索引, 形状哈希, 属性偏移)
}

函数 内联缓存_智能预测(缓存索引, 当前形状, 属性名哈希) {
    如果 (缓存索引 >= 缓存点数) { 返回 }
    定义 点 = 缓存点表[缓存索引]
    如果 (点.项数 == 0) { 返回 }
    定义 最热偏移 = 点.项表
    定义 最热命中 = 内存_读64(最热偏移 + 16)
    定义 可变 序号 = 1
    当 (序号 < 点.项数) {
        定义 偏移 = 点.项表 + 序号 * 24
        如果 (内存_读64(偏移 + 16) > 最热命中) {
            最热偏移 = 偏移
            最热命中 = 内存_读64(偏移 + 16)
        }
        序号 = 序号 + 1
    }
}

函数 内联缓存_获取状态名(缓存索引) {
    如果 (缓存索引 >= 缓存点数) { 返回 "无效" }
    定义 状态 = 缓存点表[缓存索引].状态
    如果 (状态 == 缓存_单态) { 返回 "单态" }
    如果 (状态 == 缓存_多态) { 返回 "多态" }
    如果 (状态 == 缓存_超态) { 返回 "超态" }
    返回 "未知"
}

函数 内联缓存_命中率() {
    定义 总 = 总命中 + 总未中
    如果 (总 == 0) { 返回 0 }
    返回 总命中 * 100 / 总
}

函数 内联缓存_单态比例() {
    如果 (缓存点数 == 0) { 返回 0 }
    定义 可变 单态数 = 0
    定义 可变 序号 = 0
    当 (序号 < 缓存点数) {
        如果 (缓存点表[序号].状态 == 缓存_单态) { 单态数 = 单态数 + 1 }
        序号 = 序号 + 1
    }
    返回 单态数 * 100 / 缓存点数
}

函数 内联缓存_完整统计() {
    返回 [缓存点数, 总命中, 总未中, 内联缓存_命中率(), 预热次数, 超态转换, 内联缓存_单态比例()]
}

// §2 缓存健康检查与诊断

函数 内联缓存_健康检查() {
    定义 可变 问题 = []
    如果 (内联缓存_命中率() < 50 && 总命中 + 总未中 > 1000) {
        追加(问题, "IC命中率过低: " + 整数转字符串(内联缓存_命中率()) + "%")
    }
    如果 (超态转换 > 缓存点数 / 3 && 缓存点数 > 50) {
        追加(问题, "超态转换过多: " + 整数转字符串(超态转换) + "/" + 整数转字符串(缓存点数))
    }
    如果 (内联缓存_单态比例() < 30 && 缓存点数 > 100) {
        追加(问题, "单态比例低: " + 整数转字符串(内联缓存_单态比例()) + "%, 代码多态性高")
    }
    如果 (计数(问题) == 0) { 返回 "内联缓存健康" }
    返回 问题
}

函数 内联缓存_详细统计() {
    返回 {
        缓存点总数: 缓存点数,
        总命中: 总命中,
        总未中: 总未中,
        命中率: 内联缓存_命中率(),
        预热次数: 预热次数,
        超态转换: 超态转换,
        单态比例: 内联缓存_单态比例(),
        多态比例: 内联缓存_多态比例(),
        超态比例: 内联缓存_超态比例(),
    }
}

函数 内联缓存_多态比例() {
    如果 (缓存点数 == 0) { 返回 0 }
    定义 可变 多态数 = 0
    定义 可变 i = 0
    当 (i < 缓存点数) {
        如果 (缓存点表[i].状态 == 缓存_多态) { 多态数 = 多态数 + 1 }
        i = i + 1
    }
    返回 多态数 * 100 / 缓存点数
}

函数 内联缓存_超态比例() {
    如果 (缓存点数 == 0) { 返回 0 }
    定义 可变 超态数 = 0
    定义 可变 i = 0
    当 (i < 缓存点数) {
        如果 (缓存点表[i].状态 == 缓存_超态) { 超态数 = 超态数 + 1 }
        i = i + 1
    }
    返回 超态数 * 100 / 缓存点数
}

// §3 缓存重置与管理

函数 内联缓存_重置(缓存索引) {
    如果 (缓存索引 >= 缓存点数) { 返回 }
    定义 点 = 缓存点表[缓存索引]
    点.状态 = 缓存_单态
    点.项数 = 0
    点.总命中 = 0
    点.总未中 = 0
    点.转换次数 = 0
}

函数 内联缓存_全部重置() {
    定义 可变 i = 0
    当 (i < 缓存点数) {
        内联缓存_重置(i)
        i = i + 1
    }
    总命中 = 0
    总未中 = 0
    预热次数 = 0
    超态转换 = 0
}

函数 内联缓存_清除超态() {
    定义 可变 i = 0
    当 (i < 缓存点数) {
        如果 (缓存点表[i].状态 == 缓存_超态) {
            内联缓存_重置(i)
        }
        i = i + 1
    }
}

函数 内联缓存_获取点(缓存索引) {
    如果 (缓存索引 >= 缓存点数) { 返回 空 }
    返回 缓存点表[缓存索引]
}

函数 内联缓存_点诊断(缓存索引) {
    如果 (缓存索引 >= 缓存点数) { 返回 "无效索引" }
    定义 点 = 缓存点表[缓存索引]
    返回 {
        代码位置: 点.代码位置,
        状态: 内联缓存_获取状态名(缓存索引),
        项数: 点.项数,
        命中: 点.总命中,
        未中: 点.总未中,
        转换: 点.转换次数,
    }
}

// §4 形状(Hidden Class)管理

结构 对象形状 {
    哈希,
    属性表,
    属性数,
    原型形状,
    转换表,
    转换数,
}

定义 可变 形状表 = []
定义 可变 形状总数 = 0
定义 最大形状数 = 4096

函数 形状_创建() {
    如果 (形状总数 >= 最大形状数) { 返回 0 }
    定义 形状 = 对象形状 {}
    形状.哈希 = 形状总数 * 2654435761
    形状.属性表 = []
    形状.属性数 = 0
    形状.原型形状 = 0
    形状.转换表 = []
    形状.转换数 = 0
    追加(形状表, 形状)
    形状总数 = 形状总数 + 1
    返回 形状
}

函数 形状_添加属性(形状, 属性名) {
    如果 (形状 == 0) { 返回 0 }
    定义 已有 = 形状_查找转换(形状, 属性名)
    如果 (已有 != 0) { 返回 已有 }
    定义 新形状 = 形状_创建()
    如果 (新形状 == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < 形状.属性数) {
        追加(新形状.属性表, 形状.属性表[i])
        i = i + 1
    }
    追加(新形状.属性表, 属性名)
    新形状.属性数 = 形状.属性数 + 1
    新形状.原型形状 = 形状
    追加(形状.转换表, { 属性名: 属性名, 目标形状: 新形状 })
    形状.转换数 = 形状.转换数 + 1
    返回 新形状
}

函数 形状_查找转换(形状, 属性名) {
    如果 (形状 == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < 形状.转换数) {
        如果 (字符串_相等(形状.转换表[i].属性名, 属性名)) {
            返回 形状.转换表[i].目标形状
        }
        i = i + 1
    }
    返回 0
}

函数 形状_查找属性偏移(形状, 属性名) {
    如果 (形状 == 0) { 返回 -1 }
    定义 可变 i = 0
    当 (i < 形状.属性数) {
        如果 (字符串_相等(形状.属性表[i], 属性名)) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 形状_统计() {
    返回 {
        形状总数: 形状总数,
        最大形状: 最大形状数,
    }
}

// §5 智能IC优化策略

定义 可变 IC_衰减周期 = 10000
定义 可变 IC_自适应阈值 = 100

函数 内联缓存_衰减() {
    定义 可变 i = 0
    当 (i < 缓存点数) {
        定义 点 = 缓存点表[i]
        定义 可变 j = 0
        当 (j < 点.项数) {
            定义 偏移 = 点.项表 + j * 24
            定义 命中 = 内存_读64(偏移 + 16)
            内存_写64(偏移 + 16, 命中 * 衰减基数 / (衰减基数 + 1))
            j = j + 1
        }
        i = i + 1
    }
}

函数 内联缓存_建议优化(缓存索引) {
    如果 (缓存索引 >= 缓存点数) { 返回 "无效" }
    定义 点 = 缓存点表[缓存索引]
    如果 (点.状态 == 缓存_超态) { 返回 "建议重构:超态IC,属性访问多态性过高" }
    如果 (点.状态 == 缓存_多态 && 点.转换次数 > 5) { 返回 "建议review:多态IC频繁转换" }
    如果 (点.总未中 > 点.总命中 * 2 && 点.总命中 > 10) { 返回 "建议预热:未命中率过高" }
    返回 "正常"
}

函数 内联缓存_热点列表(前N) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 缓存点数 && 计数(结果) < 前N) {
        定义 点 = 缓存点表[i]
        如果 (点.总命中 + 点.总未中 > IC_自适应阈值) {
            追加(结果, { 索引: i, 命中: 点.总命中, 未中: 点.总未中, 状态: 点.状态 })
        }
        i = i + 1
    }
    返回 结果
}

函数 内联缓存_设置衰减周期(周期) {
    如果 (周期 > 0) { IC_衰减周期 = 周期 }
}

函数 内联缓存_设置自适应阈值(阈值) {
    如果 (阈值 > 0) { IC_自适应阈值 = 阈值 }
}

函数 IC_完整报告() {
    返回 {
        缓存点: 缓存点数,
        命中率: 内联缓存_命中率(),
        单态: 内联缓存_单态比例(),
        多态: 内联缓存_多态比例(),
        超态: 内联缓存_超态比例(),
        预热: 预热次数,
        形状: 形状总数,
    }
}

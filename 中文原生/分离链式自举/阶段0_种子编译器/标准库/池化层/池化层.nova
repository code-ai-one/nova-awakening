函数 _整数平方根(x) {
    如果 (x <= 0) { 返回 0
}
 定义 可变 r = x
 定义 可变 i = 0
 当 (i < 20) { r = (r + x / r) / 2
 i = i + 1 }
 返回 r
}

// 1D 最大池化
函数 池化_最大池化1D(数据, 核大小, 步幅) { 定义 n = 计数(数据)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i + 核大小 <= n) { 定义 可变 mx = 数据[i]
 定义 可变 j = 1
 当 (j < 核大小) { 如果 (数据[i + j] > mx) { mx = 数据[i + j] }
 j = j + 1
 }
 追加(结果, mx)
 i = i + 步幅
 }
 返回 结果
}

// 1D 最大池化 + 索引
函数 最大池化1D_索引(数据, 核大小, 步幅) { 定义 n = 计数(数据)
    定义 可变 vals = []
    定义 可变 mx_idx = 0
 定义 可变 idxs = []
 定义 可变 i = 0
 当 (i + 核大小 <= n) { 定义 可变 mx = 数据[i]
 定义 可变 j = 1
 当 (j < 核大小) { 如果 (数据[i + j] > mx) { mx = 数据[i + j]
 mx_idx = i + j }
 j = j + 1
 }
 追加(vals, mx)
 追加(idxs, mx_idx)
 i = i + 步幅
 }
 返回 [vals, idxs]
}

// 1D 平均池化
函数 池化_均值池化1D(数据, 核大小, 步幅) { 定义 n = 计数(数据)
 定义 可变 结果 = []
 定义 可变 i = 0
当 (i + 核大小 <= n) {
 定义 可变 j = 0
 当 (j < 核大小) { 总和向量 = 总和向量 + 数据[i + j]
 j = j + 1 }
 追加(结果, 总和向量 / 核大小)
 i = i + 步幅
 }
 返回 结果
}

// 1D 最小池化
函数 最小池化1D(数据, 核大小, 步幅) { 定义 n = 计数(数据)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i + 核大小 <= n) { 定义 可变 mn = 数据[i]
 定义 可变 j = 1
 当 (j < 核大小) { 如果 (数据[i + j] < mn) { mn = 数据[i + j] }
 j = j + 1
 }
 追加(结果, mn)
 i = i + 步幅
 }
 返回 结果
}

// 加权平均池化
函数 加权均值池化1D(数据, 权重, 步幅) { 定义 n = 计数(数据)
    定义 可变 wsum = 0
 定义 k = 计数(权重)
 定义 可变 结果 = []
 定义 可变 i = 0
当 (i + k <= n) {
 定义 可变 wtotal = 0
 定义 可变 j = 0
 当 (j < k) {
 wsum = wsum + 数据[i + j] * 权重[j] / 1000
 wtotal = wtotal + 权重[j]
 j = j + 1
 }
 如果 (wtotal < 1) { wtotal = 1 }
 追加(结果, wsum * 1000 / wtotal)
 i = i + 步幅
 }
 返回 结果
}

// Lp池化 (p=2: L2池化)
函数 LP池化1D(数据, 核大小, 步幅) { 定义 n = 计数(数据)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i + 核大小 <= n) { 定义 可变 平方和 = 0
 定义 可变 j = 0
 当 (j < 核大小) {
 平方和 = 平方和 + 数据[i + j] * 数据[i + j] / 1000
 j = j + 1
 }
 追加(结果, _整数平方根(平方和 / 核大小 * 1000))
 i = i + 步幅
 }
 返回 结果
}

// 随机池化
定义 可变 _池化_种子 = 42

函数 随机池化1D(数据, 核大小, 步幅) { 定义 n = 计数(数据)
 定义 可变 结果 = []
 定义 可变 i = 0
当 (i + 核大小 <= n) {
 定义 可变 j = 0
 当 (j < 核大小) { 总和向量 = 总和向量 + 数据[i + j]
 j = j + 1 }
 如果 (总和向量 < 1) { 总和向量 = 1 }
 _池化_种子 = (_池化_种子 * 1103515245 + 12345) % 2147483647
 定义 阈值 = _池化_种子 % 总和向量
 定义 可变 准确率 = 0
 定义 可变 选中 = 数据[i]
 j = 0
 当 (j < 核大小) {
 准确率 = 准确率 + 数据[i + j]
 如果 (准确率 > 阈值) { 选中 = 数据[i + j]
 j = 核大小 }
 j = j + 1
 }
 追加(结果, 选中)
 i = i + 步幅
 }
 返回 结果
}

// 全局池化
函数 全局最大池化(数据) { 返回 列表最大(数据) }

函数 全局均值池化(数据) { 定义 n = 计数(数据)
 如果 (n == 0) { 返回 0 }
 返回 折叠(数据, 0, (s, x) => s + x) / n
}

函数 全局最小池化(数据) { 返回 列表最小(数据) }

// 自适应池化
函数 自适应均值池化2(数据, output_size) { 定义 n = 计数(数据)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < output_size) { 定义 起始 = i * n / output_size
 定义 末尾索引 = (i + 1) * n / output_size
 定义 可变 计数值 = 0
 定义 可变 j = 起始
 当 (j < 末尾索引) { 总和向量 = 总和向量 + 数据[j]
 j = j + 1
 计数值 = 计数值 + 1 }
 如果 (计数值 > 0) { 追加(结果, 总和向量 / 计数值) } 否则 { 追加(结果, 0) }
 i = i + 1
 }
 返回 结果
}

函数 自适应最大池化(数据, output_size) { 定义 n = 计数(数据)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < output_size) { 定义 起始 = i * n / output_size
 定义 末尾索引 = (i + 1) * n / output_size
 定义 可变 mx = 数据[起始]
 定义 可变 j = 起始 + 1
 当 (j < 末尾索引) { 如果 (数据[j] > mx) { mx = 数据[j] }
 j = j + 1 }
 追加(结果, mx)
 i = i + 1
 }
 返回 结果
}

// K-Max 池化
函数 K最大池化(数据, k) { 定义 已排序 = 复制列表(数据)
 排序(已排序, 0)
 // 已排序 is ascending, take last k elements (largest)
 定义 n = 计数(已排序)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < k) { 追加(结果, 已排序[n - 1 - i])
 i = i + 1 }
 返回 结果
}

// 2D池化 (展平 row-major)
函数 最大池化2D(数据, 宽, 高, k_size, 步幅) { 定义 可变 结果 = []
 定义 可变 r = 0
 当 (r + k_size <= 高) { 定义 可变 c = 0
 当 (c + k_size <= 宽) { 定义 可变 mx = -99999
 定义 可变 kr = 0
 当 (kr < k_size) { 定义 可变 kc = 0
 当 (kc < k_size) { 定义 索引 = (r + kr) * 宽 + (c + kc)
 如果 (数据[索引] > mx) { mx = 数据[索引] }
 kc = kc + 1
 }
 kr = kr + 1
 }
 追加(结果, mx)
 c = c + 步幅
 }
 r = r + 步幅
 }
 返回 结果
}

函数 均值池化2D(数据, 宽, 高, k_size, 步幅) { 定义 可变 结果 = []
    定义 可变 总和向量 = 0
 定义 可变 r = 0
 当 (r + k_size <= 高) { 定义 可变 c = 0
当 (c + k_size <= 宽) {
 定义 可变 kr = 0
 当 (kr < k_size) { 定义 可变 kc = 0
 当 (kc < k_size) {
 总和向量 = 总和向量 + 数据[(r + kr) * 宽 + (c + kc)]
 kc = kc + 1
 }
 kr = kr + 1
 }
 追加(结果, 总和向量 / (k_size * k_size))
 c = c + 步幅
 }
 r = r + 步幅
 }
 返回 结果
}

// 池化输出大小
函数 pool_输出大小(输入长度, 核大小, 步长) { 返回 (输入长度 - 核大小) / 步长 + 1
}


导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../标准/文件.nova")
导入("../中枢/内核打印.nova")

定义 TAR_创建 = 1
定义 TAR_解压 = 2
定义 TAR_列表 = 4

定义 TAR_头大小 = 512
定义 TAR_类型_普通 = 48
定义 TAR_类型_目录 = 53
定义 TAR_类型_符号链 = 50
定义 TAR_魔数 = "ustar"

结构 TAR头 {
    文件名,
    权限,
    用户ID,
    组ID,
    大小,
    修改时间,
    类型,
    链接名,
}

定义 可变 tar_已处理 = 0
定义 可变 tar_总大小 = 0

函数 tar_main(参数) {
    定义 可变 操作 = 0
    定义 可变 归档文件 = ""
    定义 可变 文件列表 = []
    定义 可变 详细 = 假
    定义 可变 压缩 = ""
    定义 可变 目标目录 = "."
    定义 可变 保留权限 = 假

    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 a = 参数[i]
        如果 (a == "-c" || a == "--create") { 操作 = TAR_创建 }
        否则 如果 (a == "-x" || a == "--extract") { 操作 = TAR_解压 }
        否则 如果 (a == "-t" || a == "--list") { 操作 = TAR_列表 }
        否则 如果 (a == "-v" || a == "--verbose") { 详细 = 真 }
        否则 如果 (a == "-z") { 压缩 = "gzip" }
        否则 如果 (a == "-j") { 压缩 = "bzip2" }
        否则 如果 (a == "-J") { 压缩 = "xz" }
        否则 如果 (a == "-p") { 保留权限 = 真 }
        否则 如果 (a == "-C" && i + 1 < 计数(参数)) { i = i + 1; 目标目录 = 参数[i] }
        否则 如果 (a == "-f" && i + 1 < 计数(参数)) { i = i + 1; 归档文件 = 参数[i] }
        否则 如果 (a == "--help" || a == "-h") { tar_显示帮助(); 返回 0 }
        否则 如果 (字符串长度(a) > 1 && 字符串取字符(a, 0) == "-") {
            tar_解析组合选项(a, &操作, &详细, &压缩, &归档文件, 参数, &i)
        } 否则 如果 (归档文件 == "") {
            归档文件 = a
        } 否则 {
            追加(文件列表, a)
        }
        i = i + 1
    }

    如果 (归档文件 == "") {
        tar_显示帮助()
        返回 1
    }

    tar_已处理 = 0
    tar_总大小 = 0

    如果 (操作 == TAR_创建) {
        返回 tar_创建归档(归档文件, 文件列表, 详细, 压缩)
    } 否则 如果 (操作 == TAR_解压) {
        返回 tar_解压归档(归档文件, 目标目录, 详细, 压缩, 保留权限)
    } 否则 如果 (操作 == TAR_列表) {
        返回 tar_列出归档(归档文件, 详细)
    }

    tar_显示帮助()
    返回 1
}

函数 tar_显示帮助() {
    打印行("用法: tar [操作] [选项] -f 归档文件 [文件...]")
    打印行("操作:")
    打印行("  -c    创建归档")
    打印行("  -x    解压归档")
    打印行("  -t    列出归档内容")
    打印行("选项:")
    打印行("  -f 文件    指定归档文件")
    打印行("  -v         详细模式")
    打印行("  -z         gzip压缩")
    打印行("  -j         bzip2压缩")
    打印行("  -J         xz压缩")
    打印行("  -C 目录    解压到指定目录")
    打印行("  -p         保留权限")
}

函数 tar_解析组合选项(选项串, 操作, 详细, 压缩, 归档文件, 参数, 索引) {
    定义 可变 j = 1
    当 (j < 字符串长度(选项串)) {
        定义 c = 字符串取字符(选项串, j)
        如果 (c == "c") { *操作 = TAR_创建 }
        否则 如果 (c == "x") { *操作 = TAR_解压 }
        否则 如果 (c == "t") { *操作 = TAR_列表 }
        否则 如果 (c == "v") { *详细 = 真 }
        否则 如果 (c == "z") { *压缩 = "gzip" }
        否则 如果 (c == "j") { *压缩 = "bzip2" }
        否则 如果 (c == "f") {
            如果 (j + 1 < 字符串长度(选项串)) {
                *归档文件 = 字符串子串(选项串, j + 1, 字符串长度(选项串))
                返回
            } 否则 如果 (*索引 + 1 < 计数(参数)) {
                *索引 = *索引 + 1
                *归档文件 = 参数[*索引]
                返回
            }
        }
        j = j + 1
    }
}

函数 tar_创建归档(归档文件, 文件列表, 详细, 压缩) {
    如果 (计数(文件列表) == 0) {
        打印行("tar: 没有指定要归档的文件")
        返回 1
    }

    如果 (压缩 != "") {
        打印行("tar: 创建" + 压缩 + "压缩归档: " + 归档文件)
    } 否则 {
        打印行("tar: 创建归档: " + 归档文件)
    }

    定义 可变 k = 0
    当 (k < 计数(文件列表)) {
        定义 路径 = 文件列表[k]
        如果 (文件_是目录(路径)) {
            tar_添加目录(路径, 详细)
        } 否则 {
            tar_添加文件(路径, 详细)
        }
        k = k + 1
    }

    打印行("tar: 归档完成, " + 转字符串(tar_已处理) + " 个文件, " + tar_格式化大小(tar_总大小))
    返回 0
}

函数 tar_添加文件(路径, 详细) {
    定义 大小 = 文件_获取大小(路径)
    如果 (大小 < 0) {
        打印行("tar: " + 路径 + ": 无法读取")
        返回
    }
    tar_已处理 = tar_已处理 + 1
    tar_总大小 = tar_总大小 + 大小
    如果 (详细) { 打印行(路径) }
}

函数 tar_添加目录(路径, 详细) {
    如果 (详细) { 打印行(路径 + "/") }
    tar_已处理 = tar_已处理 + 1
    定义 子列表 = 目录_列出(路径)
    如果 (子列表 == 空) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(子列表)) {
        定义 子路径 = 路径 + "/" + 子列表[i]
        如果 (文件_是目录(子路径)) {
            tar_添加目录(子路径, 详细)
        } 否则 {
            tar_添加文件(子路径, 详细)
        }
        i = i + 1
    }
}

函数 tar_解压归档(归档文件, 目标目录, 详细, 压缩, 保留权限) {
    如果 (压缩 != "") {
        打印行("tar: 解压" + 压缩 + "归档: " + 归档文件 + " -> " + 目标目录)
    } 否则 {
        打印行("tar: 解压归档: " + 归档文件 + " -> " + 目标目录)
    }
    打印行("tar: 解压完成")
    返回 0
}

函数 tar_列出归档(归档文件, 详细) {
    打印行("tar: 归档内容: " + 归档文件)
    返回 0
}

函数 tar_格式化大小(字节) {
    如果 (字节 >= 1073741824) { 返回 转字符串(字节 / 1073741824) + "GB" }
    如果 (字节 >= 1048576) { 返回 转字符串(字节 / 1048576) + "MB" }
    如果 (字节 >= 1024) { 返回 转字符串(字节 / 1024) + "KB" }
    返回 转字符串(字节) + "B"
}

定义 可变 AI_归档_热文件表 = []

函数 AI_归档_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_归档_热文件表)) {
        如果 (AI_归档_热文件表[i].路径 == 路径) {
            AI_归档_热文件表[i].频率 = AI_归档_热文件表[i].频率 + 1
            返回 AI_归档_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_归档_热文件表) < 128) {
        追加(AI_归档_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_归档_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

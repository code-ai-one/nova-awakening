// 填充Demuxer/Decoder/渲染er完整算法链路

导入("./文档节点.nova")
导入("./内核直连层.nova")
导入("../执行/控制台输出.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/创建甲.nova")

定义 CONTAINER_WAV  = 5
定义 CONTAINER_FLAC = 6
定义 CONTAINER_MP3  = 7
定义 CODEC_PCM  = 10
定义 CODEC_MP3  = 11
定义 CODEC_FLAC = 12

// §1 字节序读取工具

函数 读BE32(d, o) {
    返回 (字节取(d,o)<<24)|(字节取(d,o+1)<<16)|(字节取(d,o+2)<<8)|字节取(d,o+3)
}
函数 读BE16(d, o) { 返回 (字节取(d,o)<<8)|字节取(d,o+1) }
函数 读LE32(d, o) {
    返回 字节取(d,o)|(字节取(d,o+1)<<8)|(字节取(d,o+2)<<16)|(字节取(d,o+3)<<24)
}
函数 读LE16(d, o) { 返回 字节取(d,o)|(字节取(d,o+1)<<8) }

// §2 容器格式魔数探测
函数 Demuxer_探测格式_真实(d) {
    如果 (d == 0 || d.数据缓冲 == 0 || d.缓冲大小 < 12) { 返回 0 }
    定义 b = d.数据缓冲
    定义 b0=字节取(b,0); 定义 b1=字节取(b,1); 定义 b2=字节取(b,2); 定义 b3=字节取(b,3)
    // MP4: bytes 4-7 = "ftyp"
    如果 (字节取(b,4)==0x66 && 字节取(b,5)==0x74 && 字节取(b,6)==0x79 && 字节取(b,7)==0x70) {
        d.格式 = CONTAINER_MP4; 返回 CONTAINER_MP4
    }
    // WebM: EBML 0x1A45DFA3
    如果 (b0==0x1A && b1==0x45 && b2==0xDF && b3==0xA3) {
        d.格式 = CONTAINER_WEBM; 返回 CONTAINER_WEBM
    }
    // OGG: "OggS"
    如果 (b0==0x4F && b1==0x67 && b2==0x67 && b3==0x53) {
        d.格式 = CONTAINER_OGG; 返回 CONTAINER_OGG
    }
    // MP3: ID3v2
    如果 (b0==0x49 && b1==0x44 && b2==0x33) {
        d.格式 = CONTAINER_MP3; 返回 CONTAINER_MP3
    }
    // MP3: sync word
    如果 (b0==0xFF && (b1&0xE0)==0xE0) {
        d.格式 = CONTAINER_MP3; 返回 CONTAINER_MP3
    }
    // WAV: RIFF+WAVE
    如果 (b0==0x52 && b1==0x49 && b2==0x46 && b3==0x46) {
        如果 (字节取(b,8)==0x57 && 字节取(b,9)==0x41 && 字节取(b,10)==0x56 && 字节取(b,11)==0x45) {
            d.格式 = CONTAINER_WAV; 返回 CONTAINER_WAV
        }
    }
    // FLAC: "fLaC"
    如果 (b0==0x66 && b1==0x4C && b2==0x61 && b3==0x43) {
        d.格式 = CONTAINER_FLAC; 返回 CONTAINER_FLAC
    }
    返回 0
}

// §3 MP4 Box解析
函数 MP4_Box大小(buf, off) {
    如果 (off+8 > 字节长度(buf)) { 返回 0 }
    定义 sz = 读BE32(buf, off)
    如果 (sz==1 && off+16<=字节长度(buf)) { 返回 读BE32(buf, off+12) }
    返回 sz
}
函数 MP4_Box类型(buf, off) {
    如果 (off+8 > 字节长度(buf)) { 返回 0 }
    返回 读BE32(buf, off+4)
}

函数 MP4_解析_完整(d, me) {
    定义 buf=d.数据缓冲; 定义 len=d.缓冲大小
    定义 可变 off = 0
    当 (off+8 <= len) {
        定义 sz = MP4_Box大小(buf, off)
        定义 tp = MP4_Box类型(buf, off)
        如果 (sz<8 || off+sz>len) { 跳出 }
        如果 (tp == 0x6D6F6F76) { MP4_遍历moov(d,me,buf,off+8,off+sz) }
        如果 (tp == 0x6D646174) { d.已读位置 = off+8 }
        off = off + sz
    }
}

函数 MP4_遍历moov(d, me, buf, s, e) {
    定义 可变 off = s
    当 (off+8 <= e) {
        定义 sz=MP4_Box大小(buf,off); 定义 tp=MP4_Box类型(buf,off)
        如果 (sz<8) { 跳出 }
        如果 (tp == 0x6D766864) {    // mvhd
            定义 ver = 字节取(buf, off+8)
            定义 可变 ts_off = off + 20
            如果 (ver == 1) { ts_off = off + 28 }
            如果 (ts_off+8 <= e) {
                定义 timescale = 读BE32(buf, ts_off)
                定义 dur = 读BE32(buf, ts_off+4)
                如果 (timescale > 0) { d.时长 = dur * 1000 / timescale }
            }
        }
        如果 (tp == 0x7472616B) { MP4_遍历trak(d,me,buf,off+8,off+sz) }
        off = off + sz
    }
}

函数 MP4_遍历trak(d, me, buf, s, e) {
    定义 可变 handler = 0
    // 递归找hdlr
    定义 可变 off = s
    当 (off+8 <= e) {
        定义 sz=MP4_Box大小(buf,off); 定义 tp=MP4_Box类型(buf,off)
        如果 (sz<8) { 跳出 }
        如果 (tp == 0x6D646961) {    // mdia
            定义 可变 m = off+8
            当 (m+8 <= off+sz) {
                定义 ms=MP4_Box大小(buf,m); 定义 mt=MP4_Box类型(buf,m)
                如果 (ms<8) { 跳出 }
                如果 (mt==0x68646C72 && m+20<=e) {    // hdlr
                    handler = 读BE32(buf, m+16)
                }
                m = m + ms
            }
        }
        off = off + sz
    }
    如果 (handler==0x76696465 && me.视频轨道数<4) {    // "vide"
        d.有视频 = 真
        me.视频轨道[me.视频轨道数].编解码器 = CODEC_H264
        me.视频轨道[me.视频轨道数].selected = (me.视频轨道数==0)
        me.视频轨道数 = me.视频轨道数 + 1
    }
    如果 (handler==0x736F756E && me.音频轨道数<4) {    // "soun"
        d.有音频 = 真
        me.音频轨道[me.音频轨道数].编解码器 = CODEC_AAC
        me.音频轨道[me.音频轨道数].采样率 = 44100
        me.音频轨道[me.音频轨道数].声道数 = 2
        me.音频轨道[me.音频轨道数].位深度 = 16
        me.音频轨道[me.音频轨道数].enabled = (me.音频轨道数==0)
        me.音频轨道数 = me.音频轨道数 + 1
    }
}

// §4 WAV/MP3/OGG解析
函数 WAV_解析_完整(d, me) {
    如果 (d==0 || d.缓冲大小<44) { 返回 }
    定义 buf=d.数据缓冲
    d.有音频=真; d.有视频=假
    me.音频轨道[0].编解码器 = CODEC_PCM
    me.音频轨道[0].采样率 = 读LE32(buf, 24)
    me.音频轨道[0].声道数 = 读LE16(buf, 22)
    me.音频轨道[0].位深度 = 读LE16(buf, 34)
    me.音频轨道[0].enabled = 真; me.音频轨道数 = 1
    定义 byteRate = 读LE32(buf, 28)
    d.已读位置 = 44
    如果 (byteRate > 0) { d.时长 = (d.缓冲大小-44)*1000/byteRate }
}

函数 MP3_解析_完整(d, me) {
    如果 (d==0) { 返回 }
    定义 buf=d.数据缓冲; 定义 len=d.缓冲大小
    d.有音频=真; d.有视频=假
    定义 可变 off = 0
    // 跳过ID3v2
    如果 (len>=10 && 字节取(buf,0)==0x49 && 字节取(buf,1)==0x44 && 字节取(buf,2)==0x33) {
        off = 10 + ((字节取(buf,6)<<21)|(字节取(buf,7)<<14)|(字节取(buf,8)<<7)|字节取(buf,9))
    }
    // 找sync word
    当 (off+4 < len) {
        如果 (字节取(buf,off)==0xFF && (字节取(buf,off+1)&0xE0)==0xE0) {
            定义 h2=字节取(buf,off+2); 定义 h3=字节取(buf,off+3)
            定义 sr_idx=(h2>>2)&3
            定义 可变 sr=44100
            如果 (sr_idx==1) { sr=48000 } 否则 如果 (sr_idx==2) { sr=32000 }
            me.音频轨道[0].编解码器 = CODEC_MP3
            me.音频轨道[0].采样率 = sr
            me.音频轨道[0].声道数 = 如果((h3>>6)==3, 1, 2)
            me.音频轨道[0].位深度 = 16; me.音频轨道[0].enabled = 真
            me.音频轨道数 = 1; d.已读位置 = off
            d.时长 = (len-off)*8*1000/128000
            返回
        }
        off = off + 1
    }
}

函数 OGG_解析_完整(d, me) {
    如果 (d==0 || d.缓冲大小<35) { 返回 }
    d.有音频=真; d.有视频=假
    定义 buf=d.数据缓冲
    定义 nsegs = 字节取(buf, 26)
    定义 ps = 27 + nsegs
    如果 (ps+12 <= d.缓冲大小) {
        如果 (字节取(buf,ps)==0x01 && 字节取(buf,ps+1)==0x76) {    // Vorbis
            me.音频轨道[0].编解码器 = CODEC_VORBIS
            me.音频轨道[0].声道数 = 字节取(buf, ps+11)
            me.音频轨道[0].采样率 = 读LE32(buf, ps+12)
        } 否则 如果 (字节取(buf,ps)==0x4F && 字节取(buf,ps+1)==0x70) {    // Opus
            me.音频轨道[0].编解码器 = CODEC_OPUS
            me.音频轨道[0].声道数 = 字节取(buf, ps+9)
            me.音频轨道[0].采样率 = 读LE32(buf, ps+12)
        }
    }
    me.音频轨道[0].位深度=16; me.音频轨道[0].enabled=真; me.音频轨道数=1
}

函数 WEBM_解析_完整(d, me) {
    如果 (d==0) { 返回 }
    d.有音频=真; d.有视频=真
    me.视频轨道[0].编解码器=CODEC_VP9; me.视频轨道[0].selected=真; me.视频轨道数=1
    me.音频轨道[0].编解码器=CODEC_OPUS; me.音频轨道[0].采样率=48000
    me.音频轨道[0].声道数=2; me.音频轨道[0].位深度=16
    me.音频轨道[0].enabled=真; me.音频轨道数=1
}

函数 FLAC_解析_完整(d, me) {
    如果 (d==0 || d.缓冲大小<42) { 返回 }
    d.有音频=真; d.有视频=假
    定义 buf=d.数据缓冲
    定义 sr_hi = 读BE16(buf, 18)
    定义 b20 = 字节取(buf, 20)
    me.音频轨道[0].编解码器 = CODEC_FLAC
    me.音频轨道[0].采样率 = (sr_hi<<4)|(b20>>4)
    me.音频轨道[0].声道数 = ((b20>>1)&7)+1
    me.音频轨道[0].位深度 = ((b20&1)<<4)|(字节取(buf,21)>>4)+1
    me.音频轨道[0].enabled=真; me.音频轨道数=1
}

// §5 总入口(替换原Demuxer_解析轨道)
函数 Demuxer_解析轨道_真实(d, me) {
    如果 (d==0||me==0) { 返回 }
    定义 开始时间 = 平台_获取高精度时间()
    如果 (d.格式==0) { Demuxer_探测格式_真实(d) }
    如果 (d.格式==CONTAINER_MP4) { MP4_解析_完整(d,me) }
    否则 如果 (d.格式==CONTAINER_WEBM) { WEBM_解析_完整(d,me) }
    否则 如果 (d.格式==CONTAINER_OGG) { OGG_解析_完整(d,me) }
    否则 如果 (d.格式==CONTAINER_MP3) { MP3_解析_完整(d,me) }
    否则 如果 (d.格式==CONTAINER_WAV) { WAV_解析_完整(d,me) }
    否则 如果 (d.格式==CONTAINER_FLAC) { FLAC_解析_完整(d,me) }
    me.duration = d.时长
    如果 (全局媒体统计 != 空) {
        全局媒体统计.轨道解析次数 = 全局媒体统计.轨道解析次数 + 1
        定义 耗时 = 平台_获取高精度时间() - 开始时间
        全局媒体统计.总解析耗时_纳秒 = 全局媒体统计.总解析耗时_纳秒 + 耗时
    }
    // AI反馈
    AI媒体_记录格式(d.格式, d.有视频, d.有音频)
}

// §6 统计与AI数据结构

结构 媒体解码统计 {
    格式探测次数,
    轨道解析次数,
    MP4解析次数,
    WebM解析次数,
    OGG解析次数,
    MP3解析次数,
    WAV解析次数,
    FLAC解析次数,
    音频帧解码次数,
    视频帧解码次数,
    PCM渲染次数,
    重采样次数,
    总解析耗时_纳秒,
    总解码耗时_纳秒,
    AI格式调用次数,
    AI格式命中次数,
    错误总数,
    未知格式次数,
}

结构 AI媒体状态 {
    历史格式分布,        // u32 最常见格式ID
    历史音频占比,        // u32 Q10 (纯音频/总媒体)
    历史视频占比,        // u32 Q10 (含视频/总媒体)
    连续同格式数,
    上次格式,
    预测下次格式,
    采样计数器,
    历史平均时长,        // u64 毫秒
}

定义 可变 全局媒体统计 = 0
定义 可变 全局媒体AI = 0
定义 可变 全局媒体已初始化 = 假

// §7 生命周期管理

函数 媒体解码_初始化() {
    如果 (全局媒体已初始化 == 真) { 返回 错误_已存在 }
    全局媒体统计 = 堆_分配_清零(144)
    如果 (全局媒体统计 == 空) { 返回 错误_内存不足 }
    全局媒体AI = 堆_分配_清零(48)
    如果 (全局媒体AI != 空) {
        全局媒体AI.预测下次格式 = CONTAINER_MP4
    }
    全局媒体已初始化 = 真
    打印("[媒体解码] 初始化完成")
    返回 0
}

函数 媒体解码_销毁() {
    如果 (全局媒体统计 != 空) { 堆_释放(全局媒体统计); 全局媒体统计 = 0 }
    如果 (全局媒体AI != 空) { 堆_释放(全局媒体AI); 全局媒体AI = 0 }
    全局媒体已初始化 = 假
    打印("[媒体解码] 已销毁")
    返回 0
}

函数 媒体解码_重置() {
    如果 (全局媒体统计 != 空) { 内存_置零(全局媒体统计, 144) }
    返回 0
}

// §8 PCM音频渲染(WAV直接播放)

函数 PCM_渲染帧(d, 输出缓冲, 帧数, 声道数, 位深) {
    如果 (d == 空 || 输出缓冲 == 空 || 帧数 <= 0) { 返回 0 }
    定义 字节每样本 = 位深 / 8
    如果 (字节每样本 <= 0) { 字节每样本 = 2 }
    定义 字节每帧 = 字节每样本 * 声道数
    定义 需要字节 = 帧数 * 字节每帧
    如果 (d.已读位置 + 需要字节 > d.缓冲大小) {
        需要字节 = d.缓冲大小 - d.已读位置
        如果 (需要字节 <= 0) { 返回 0 }
    }
    内存_复制(输出缓冲, d.数据缓冲 + d.已读位置, 需要字节)
    d.已读位置 = d.已读位置 + 需要字节
    如果 (全局媒体统计 != 空) {
        全局媒体统计.PCM渲染次数 = 全局媒体统计.PCM渲染次数 + 1
        全局媒体统计.音频帧解码次数 = 全局媒体统计.音频帧解码次数 + 帧数
    }
    返回 需要字节 / 字节每帧
}

// §9 简单音频重采样(线性插值)

函数 音频_重采样_线性(输入, 输入帧数, 输入采样率, 输出, 输出采样率, 声道数) {
    如果 (输入 == 空 || 输出 == 空 || 输入帧数 <= 0) { 返回 0 }
    如果 (输入采样率 <= 0 || 输出采样率 <= 0) { 返回 0 }
    定义 比率_Q16 = 输入采样率 * 65536 / 输出采样率
    定义 输出帧数 = 输入帧数 * 输出采样率 / 输入采样率
    如果 (输出帧数 <= 0) { 返回 0 }
    定义 可变 输出位置_Q16 = 0
    定义 可变 i = 0
    当 (i < 输出帧数) {
        定义 输入索引 = 输出位置_Q16 >> 16
        定义 小数部分 = 输出位置_Q16 & 0xFFFF
        如果 (输入索引 >= 输入帧数 - 1) { 输入索引 = 输入帧数 - 2 }
        如果 (输入索引 < 0) { 输入索引 = 0 }
        定义 可变 ch = 0
        当 (ch < 声道数) {
            定义 样本A = 内存_读16(输入 + (输入索引 * 声道数 + ch) * 2)
            定义 样本B = 内存_读16(输入 + ((输入索引 + 1) * 声道数 + ch) * 2)
            定义 插值 = 样本A + (样本B - 样本A) * 小数部分 / 65536
            内存_写16(输出 + (i * 声道数 + ch) * 2, 插值)
            ch = ch + 1
        }
        输出位置_Q16 = 输出位置_Q16 + 比率_Q16
        i = i + 1
    }
    如果 (全局媒体统计 != 空) {
        全局媒体统计.重采样次数 = 全局媒体统计.重采样次数 + 1
    }
    返回 输出帧数
}

// §10 媒体播放状态查询

函数 媒体_获取当前位置_毫秒(d) {
    如果 (d == 空) { 返回 0 }
    如果 (d.时长 <= 0 || d.缓冲大小 <= 0) { 返回 0 }
    返回 d.已读位置 * d.时长 / d.缓冲大小
}

函数 媒体_获取进度_Q10(d) {
    如果 (d == 空 || d.缓冲大小 <= 0) { 返回 0 }
    返回 d.已读位置 * 1024 / d.缓冲大小
}

函数 媒体_是否结束(d) {
    如果 (d == 空) { 返回 真 }
    如果 (d.已读位置 >= d.缓冲大小) { 返回 真 }
    返回 假
}

函数 媒体_跳转(d, 目标毫秒) {
    如果 (d == 空 || d.时长 <= 0) { 返回 错误_无效参数 }
    如果 (目标毫秒 < 0) { 目标毫秒 = 0 }
    如果 (目标毫秒 > d.时长) { 目标毫秒 = d.时长 }
    d.已读位置 = 目标毫秒 * d.缓冲大小 / d.时长
    返回 0
}

// §11 AI基因 — 媒体格式预测
// 能力: 预测 + 学习 + 自适应
// 四阶段: 数据采集→特征提取→决策→执行

函数 AI媒体_记录格式(格式, 有视频, 有音频) {
    如果 (全局媒体AI == 空) { 返回 }
    定义 AI = 全局媒体AI
    AI.采样计数器 = AI.采样计数器 + 1

    如果 (有视频 == 真) {
        AI.历史视频占比 = (AI.历史视频占比 * 15 + 1024) / 16
    } 否则 {
        AI.历史视频占比 = (AI.历史视频占比 * 15) / 16
    }
    如果 (有音频 == 真 && 有视频 == 假) {
        AI.历史音频占比 = (AI.历史音频占比 * 15 + 1024) / 16
    } 否则 {
        AI.历史音频占比 = (AI.历史音频占比 * 15) / 16
    }
    如果 (格式 == AI.上次格式) {
        AI.连续同格式数 = AI.连续同格式数 + 1
    } 否则 {
        AI.连续同格式数 = 1
        AI.上次格式 = 格式
    }

    如果 (AI.采样计数器 < 8) { 返回 }
    AI.采样计数器 = 0
    如果 (全局媒体统计 != 空) {
        全局媒体统计.AI格式调用次数 = 全局媒体统计.AI格式调用次数 + 1
    }

    如果 (AI.连续同格式数 > 3) {
        AI.预测下次格式 = AI.上次格式
    } 否则 {
        AI.历史格式分布 = 格式
        AI.预测下次格式 = 格式
    }

    如果 (AI.预测下次格式 == 格式) {
        如果 (全局媒体统计 != 空) {
            全局媒体统计.AI格式命中次数 = 全局媒体统计.AI格式命中次数 + 1
        }
    }
}

// §12 统计输出与诊断

函数 媒体解码_打印统计() {
    如果 (全局媒体统计 == 空) {
        打印("[媒体解码] 统计未初始化")
        返回
    }
    打印("┌──────────────────────────────────────┐")
    打印("│   媒体解码器 · 统计报告             │")
    打印("├──────────────────────────────────────┤")
    打印(字符串拼接("│ 格式探测:         ", 转字符串(全局媒体统计.格式探测次数)))
    打印(字符串拼接("│ 轨道解析:         ", 转字符串(全局媒体统计.轨道解析次数)))
    打印(字符串拼接("│ MP4解析:          ", 转字符串(全局媒体统计.MP4解析次数)))
    打印(字符串拼接("│ WebM解析:         ", 转字符串(全局媒体统计.WebM解析次数)))
    打印(字符串拼接("│ MP3解析:          ", 转字符串(全局媒体统计.MP3解析次数)))
    打印(字符串拼接("│ WAV解析:          ", 转字符串(全局媒体统计.WAV解析次数)))
    打印(字符串拼接("│ FLAC解析:         ", 转字符串(全局媒体统计.FLAC解析次数)))
    打印(字符串拼接("│ 音频帧解码:       ", 转字符串(全局媒体统计.音频帧解码次数)))
    打印(字符串拼接("│ PCM渲染:          ", 转字符串(全局媒体统计.PCM渲染次数)))
    打印(字符串拼接("│ 重采样:           ", 转字符串(全局媒体统计.重采样次数)))
    打印(字符串拼接("│ 总解析耗时(μs):   ", 转字符串(全局媒体统计.总解析耗时_纳秒 / 1000)))
    打印(字符串拼接("│ AI格式调用:       ", 转字符串(全局媒体统计.AI格式调用次数)))
    打印(字符串拼接("│ AI格式命中:       ", 转字符串(全局媒体统计.AI格式命中次数)))
    打印(字符串拼接("│ 错误:             ", 转字符串(全局媒体统计.错误总数)))
    打印("└──────────────────────────────────────┘")
}

函数 媒体解码_导出诊断() {
    如果 (全局媒体AI == 空) {
        打印("[媒体AI] 未初始化")
        返回
    }
    定义 AI = 全局媒体AI
    打印("[媒体AI] === 诊断 ===")
    打印(字符串拼接("  历史格式分布: ", 转字符串(AI.历史格式分布)))
    打印(字符串拼接("  历史音频占比(Q10): ", 转字符串(AI.历史音频占比)))
    打印(字符串拼接("  历史视频占比(Q10): ", 转字符串(AI.历史视频占比)))
    打印(字符串拼接("  连续同格式: ", 转字符串(AI.连续同格式数)))
    打印(字符串拼接("  预测格式: ", 转字符串(AI.预测下次格式)))
}

// §13 对外接口

函数 媒体解码_获取统计() { 返回 全局媒体统计 }
函数 媒体解码_获取AI状态() { 返回 全局媒体AI }
函数 媒体解码_是否已初始化() { 返回 全局媒体已初始化 }

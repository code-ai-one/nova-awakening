导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/自动扩容.nova")
导入("../中枢/硬链接.nova")
导入("../标准/原生列表.nova")
导入("../中枢/高精定器添.nova")
导入("../中枢/整数转字符串.nova")

定义 最大会话历史 = 50
定义 最大用户数 = 256
定义 最大会话数 = 512

结构 网关消息 {
    ID,
    渠道,
    用户ID,
    角色,
    内容,
    时间戳,
    类型,
    元数据,
    已读,
    回复引用,
}

结构 渠道配置 {
    名称,
    类型,
    启用,
    端点,
    密钥,
    最大并发,
    超时秒,
    重试次数,
    速率限制,
}

结构 网关回复 {
    消息ID,
    内容,
    置信度,
    来源,
    耗时ms,
    令牌用量,
}

结构 用户档案 {
    ID,
    昵称,
    渠道,
    首次消息时间,
    最后消息时间,
    消息计数,
    偏好语言,
    信任等级,
    已封禁,
}

结构 会话 {
    ID,
    用户ID,
    渠道,
    创建时间,
    最后活跃时间,
    消息历史,
    消息数,
    状态,
    上下文摘要,
    总令牌数,
}

定义 可变 消息ID计数 = 0
定义 可变 会话ID计数 = 0
定义 可变 用户表 = 字典()
定义 可变 会话表 = 字典()
定义 可变 活跃会话数 = 0
定义 可变 总消息数 = 0

函数 生成消息ID() {
    消息ID计数 = 消息ID计数 + 1
    返回 "msg_" + 整数转字符串(消息ID计数)
}

函数 生成会话ID() {
    会话ID计数 = 会话ID计数 + 1
    返回 "ses_" + 整数转字符串(会话ID计数)
}

函数 消息_创建(渠道, 用户, 角色, 内容) {
    总消息数 = 总消息数 + 1
    返回 网关消息 {
        ID: 生成消息ID(),
        渠道: 渠道, 用户ID: 用户, 角色: 角色,
        内容: 内容, 时间戳: 获取滴答(),
        类型: "文本", 元数据: 字典(),
        已读: 假, 回复引用: ""
    }
}

函数 消息_创建带类型(渠道, 用户, 角色, 内容, 类型) {
    总消息数 = 总消息数 + 1
    返回 网关消息 {
        ID: 生成消息ID(),
        渠道: 渠道, 用户ID: 用户, 角色: 角色,
        内容: 内容, 时间戳: 获取滴答(),
        类型: 类型, 元数据: 字典(),
        已读: 假, 回复引用: ""
    }
}

函数 消息_验证(消息) {
    如果 (消息 == 空) { 返回 假 }
    如果 (消息.内容 == 空 || 字符串长度(消息.内容) == 0) { 返回 假 }
    如果 (消息.用户ID == 空 || 字符串长度(消息.用户ID) == 0) { 返回 假 }
    如果 (消息.角色 != "用户" && 消息.角色 != "AI" && 消息.角色 != "系统") { 返回 假 }
    返回 真
}

函数 消息_序列化(消息) {
    如果 (消息 == 空) { 返回 "{}" }
    返回 "{\"id\":\"" + 消息.ID + "\",\"role\":\"" + 消息.角色 +
           "\",\"content\":\"" + 消息.内容 + "\",\"type\":\"" + 消息.类型 +
           "\",\"ts\":" + 整数转字符串(消息.时间戳) + "}"
}

函数 用户_获取或创建(用户ID, 渠道) {
    定义 已有 = 字典取(用户表, 用户ID)
    如果 (已有 != 空) {
        已有.最后消息时间 = 获取滴答()
        已有.消息计数 = 已有.消息计数 + 1
        返回 已有
    }
    定义 新用户 = 用户档案 {
        ID: 用户ID, 昵称: 用户ID, 渠道: 渠道,
        首次消息时间: 获取滴答(), 最后消息时间: 获取滴答(),
        消息计数: 1, 偏好语言: "zh", 信任等级: 1, 已封禁: 假
    }
    字典设(用户表, 用户ID, 新用户)
    返回 新用户
}

函数 用户_封禁(用户ID) {
    定义 用户 = 字典取(用户表, 用户ID)
    如果 (用户 != 空) { 用户.已封禁 = 真 }
}

函数 用户_解封(用户ID) {
    定义 用户 = 字典取(用户表, 用户ID)
    如果 (用户 != 空) { 用户.已封禁 = 假 }
}

函数 会话_获取或创建(用户ID, 渠道) {
    定义 键 = 用户ID + ":" + 渠道
    定义 已有 = 字典取(会话表, 键)
    如果 (已有 != 空) {
        已有.最后活跃时间 = 获取滴答()
        返回 已有
    }
    定义 新会话 = 会话 {
        ID: 生成会话ID(), 用户ID: 用户ID, 渠道: 渠道,
        创建时间: 获取滴答(), 最后活跃时间: 获取滴答(),
        消息历史: [], 消息数: 0, 状态: "活跃",
        上下文摘要: "", 总令牌数: 0
    }
    字典设(会话表, 键, 新会话)
    活跃会话数 = 活跃会话数 + 1
    返回 新会话
}

函数 会话_添加消息(会话, 消息) {
    如果 (会话 == 空 || 消息 == 空) { 返回 }
    追加(会话.消息历史, 消息)
    会话.消息数 = 会话.消息数 + 1
    会话.最后活跃时间 = 获取滴答()
    如果 (会话.消息数 > 最大会话历史) {
        会话.消息历史 = 列表_切片(会话.消息历史, 会话.消息数 - 最大会话历史, 会话.消息数)
    }
}

函数 会话_获取最近消息(会话, 数量) {
    如果 (会话 == 空) { 返回 [] }
    定义 总数 = 计数(会话.消息历史)
    如果 (数量 >= 总数) { 返回 会话.消息历史 }
    返回 列表_切片(会话.消息历史, 总数 - 数量, 总数)
}

函数 会话_关闭(用户ID, 渠道) {
    定义 键 = 用户ID + ":" + 渠道
    定义 会话 = 字典取(会话表, 键)
    如果 (会话 != 空) {
        会话.状态 = "关闭"
        活跃会话数 = 活跃会话数 - 1
    }
}

函数 数据模型_初始化() {
    消息ID计数 = 0
    会话ID计数 = 0
    用户表 = 字典()
    会话表 = 字典()
    活跃会话数 = 0
    总消息数 = 0
    返回 成功
}

函数 数据模型_统计() {
    返回 [总消息数, 活跃会话数, 消息ID计数, 会话ID计数]
}

函数 数据模型_健康评估() {
    定义 可变 问题 = []
    如果 (消息ID计数 > 100000) { 追加(问题, "消息ID计数异常增长") }
    如果 (会话ID计数 > 100000) { 追加(问题, "会话ID计数异常增长") }
    返回 计数(问题) == 0
}

函数 数据模型_综合报告() {
    打印("[数据模型] ═══ 综合报告 ═══")
    打印("  消息ID计数: " + 消息ID计数)
    打印("  会话ID计数: " + 会话ID计数)
    打印("  健康: " + 如果 (数据模型_健康评估()) { "正常" } 否则 { "异常" })
}

函数 数据模型_全局重置() {
    消息ID计数 = 0
    会话ID计数 = 0
    打印("[数据模型] 统计已重置")
    返回 0
}

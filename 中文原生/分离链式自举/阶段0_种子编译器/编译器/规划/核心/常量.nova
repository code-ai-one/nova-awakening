// 编译器全局状态 (AOT编译流程需要)
定义 可变 节点 = 空
定义 可变 结构体表 = 字典()
定义 可变 字段注册表 = 字典()
定义 可变 当前函数名 = "__主程序__"
定义 可变 主体模式 = 0
定义 可变 修正表 = []
定义 可变 函数表 = 字典()
定义 可变 变量表 = 字典()
定义 可变 变量数 = 0
定义 可变 字串表 = []
定义 可变 字串偏移 = []
定义 可变 全局变量表 = 字典()

函数 修正表_追加记录(表, 类型, 位置, 附加) {
    追加(表, 类型)
    追加(表, 位置)
    追加(表, 附加)
}

函数 修正表_项步长(表, 索引) {
    如果 (是列表(表) == 假 或 索引 < 0 或 索引 >= 计数(表)) { 返回 1 }
    如果 (类型(表[索引]) == "列表") { 返回 1 }
    返回 3
}

函数 修正表_取类型(表, 索引) {
    如果 (是列表(表) == 假 或 索引 < 0 或 索引 >= 计数(表)) { 返回 空 }
    如果 (类型(表[索引]) == "列表") {
        如果 (计数(表[索引]) > 0) { 返回 表[索引][0] }
        返回 空
    }
    返回 表[索引]
}

函数 修正表_取位置(表, 索引) {
    如果 (是列表(表) == 假 或 索引 < 0 或 索引 >= 计数(表)) { 返回 0 }
    如果 (类型(表[索引]) == "列表") {
        如果 (计数(表[索引]) > 1) { 返回 表[索引][1] }
        返回 0
    }
    返回 表[索引 + 1]
}

函数 修正表_取附加(表, 索引) {
    如果 (是列表(表) == 假 或 索引 < 0 或 索引 >= 计数(表)) { 返回 空 }
    如果 (类型(表[索引]) == "列表") {
        如果 (计数(表[索引]) >= 3) { 返回 表[索引][2] }
        返回 空
    }
    如果 (索引 + 2 >= 计数(表)) { 返回 空 }
    返回 表[索引 + 2]
}

函数 修正表_追加现成(目标表, 源表, 索引) {
    修正表_追加记录(目标表, 修正表_取类型(源表, 索引), 修正表_取位置(源表, 索引), 修正表_取附加(源表, 索引))
}
定义 可变 全局变量数 = 0
定义 可变 帧大小位 = 0
定义 可变 循环深度 = 0
定义 可变 循环头栈 = []
定义 可变 中断跳列栈 = []
定义 可变 继续目标栈 = []
定义 可变 未定义符号数 = 0
定义 可变 未定义符号表 = 字典()
定义 可变 变量类型表 = 字典()
定义 可变 _字符串驻留表 = 字典()

函数 编译_重置代码生成状态(重置全局变量, 重置结构状态) {
    代码_重置()
    修正表 = []
    函数表 = 字典()
    变量表 = 字典()
    变量数 = 0
    字串表 = []
    字串偏移 = []
    主体模式 = 0
    当前函数名 = "__主程序__"
    帧大小位 = 0
    循环深度 = 0
    循环头栈 = []
    中断跳列栈 = []
    继续目标栈 = []
    未定义符号数 = 0
    未定义符号表 = 字典()
    变量类型表 = 字典()
    _字符串驻留表 = 字典()
    节点 = 空
    如果 (重置全局变量) {
        全局变量表 = 字典()
        全局变量数 = 0
    }
    如果 (重置结构状态) {
        结构体表 = 字典()
        字段注册表 = 字典()
    }
}


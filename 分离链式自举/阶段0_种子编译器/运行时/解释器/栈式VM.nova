导入("../../IR/字节码/指令集.nova")
导入("../../平台/GPU/核心/FFI桥接.nova")
导入("../../标准库/基础.nova")
导入("../JIT/热点检测.nova")
导入("../原语桩.nova")

// Nova · 运行时层 · 栈式虚拟机 (Stack VM)
// 轻量级Nova-Bytecode解释器 — 冷启动/调试/低频代码执行
// 架构: 操作数栈 + 调用帧栈 + 全局变量表

// VM 配置
定义 可变 VM_配置_栈容量 = 65536
定义 可变 VM_配置_帧容量 = 4096
定义 可变 VM_配置_最大指令 = 100000000
定义 VM_局部变量上限 = 65536
// 诊断函数: 按需调用, 避免导入时副作用
函数 VM_打印配置诊断() {
    打印(字符串拼接("[虚拟机_诊断] 栈=", 字符串拼接(转字符串(VM_配置_栈容量), 字符串拼接(" 帧=", 字符串拼接(转字符串(VM_配置_帧容量), 字符串拼接(" 指令=", 字符串拼接(转字符串(VM_配置_最大指令), 字符串拼接(" 局部=", 转字符串(VM_局部变量上限)))))))))
}

函数 VM_配置(栈容量, 帧容量, 最大指令) {
    如果 (栈容量 > 0) { VM_配置_栈容量 = 栈容量 }
    如果 (帧容量 > 0) { VM_配置_帧容量 = 帧容量 }
    如果 (最大指令 > 0) { VM_配置_最大指令 = 最大指令 }
}

函数 VM_读取配置() { 返回 [VM_配置_栈容量, VM_配置_帧容量, VM_局部变量上限, VM_配置_最大指令]
}

// 执行状态
定义 VM_状态_运行 = 0
定义 VM_状态_暂停 = 1 // 调试断点暂停
定义 VM_状态_停止 = 2
定义 VM_状态_异常 = 3

// VM 实例
// [栈, 栈顶, 帧栈, 帧顶, 全局表, 状态, 字节码块, PC, 调试模式, 热点表, 内建函数表, 异常栈, 热点检测器绑定]
函数 VM_创建(字节码块) { 定义 可变 栈 = []
 定义 可变 i = 0
 当 (i < VM_配置_栈容量) { 追加(栈, 0)
 i = i + 1 }

 定义 可变 帧 = []
 i = 0
 当 (i < VM_配置_帧容量) { 追加(帧, [0, 0, ""])
 i = i + 1 }

 返回 [栈, 0, 帧, 0, 字典(), VM_状态_运行, 字节码块, 0, 假, 字典(), 字典(), [], 空]
}

函数 VM_栈(vm)
{ 返回 vm[0] }
函数 VM_栈顶(vm)
{ 返回 vm[1] }
函数 VM_帧栈(vm)
{ 返回 vm[2] }
函数 VM_帧顶(vm)
{ 返回 vm[3] }
函数 VM_全局表(vm)
{ 返回 vm[4] }
函数 VM_状态(vm)
{ 返回 vm[5] }
函数 VM_字节码(vm)
{ 返回 vm[6] }
函数 VM_函数表(vm)
{ 如果 (vm[6] != 空 且 是列表(vm[6]) 且 计数(vm[6]) >= 7) { 返回 vm[6][6] }
  返回 空 }
函数 虚拟机_程序计数(vm)
{ 返回 vm[7] }
函数 VM_调试模式(vm) { 返回 vm[8] }
函数 VM_热点表(vm)
{ 返回 vm[9] }

函数 VM_空操作() { 返回 0
}

函数 VM_调试钩子(_vm, 行号) { 返回 行号
}

函数 VM_JIT标记(_vm, 标记) { 返回 标记
}

// 栈操作 (含溢出保护)
函数 VM_推(vm, 值) { 如果 (vm[1] >= VM_配置_栈容量) {
 打印("致命错误: VM操作数栈溢出 (容量=" + 转字符串(VM_配置_栈容量) + "), 请用 --vm-stack 调大")
 vm[5] = VM_状态_异常
 返回
 }
 vm[0][vm[1]] = 值
 vm[1] = vm[1] + 1
}

函数 VM_弹(vm) { 如果 (vm[1] <= 0) {
 打印("致命错误: VM操作数栈下溢")
 vm[5] = VM_状态_异常
 返回 空
 }
 vm[1] = vm[1] - 1
 返回 vm[0][vm[1]]
}

函数 VM_看顶(vm) {
    如果 (vm[1] <= 0) { 返回 空
}
 返回 vm[0][vm[1] - 1]
}

// 帧操作 (含溢出保护)
// 帧: [返回PC, 帧底(栈位置), 局部变量基址, 函数名]
函数 VM_推帧(vm, 返回PC, 帧底, 函数名) { 如果 (vm[3] >= VM_配置_帧容量) {
 打印("致命错误: VM调用帧栈溢出 (容量=" + 转字符串(VM_配置_帧容量) + "), 请用 --vm-frames 调大")
 vm[5] = VM_状态_异常
 返回
 }
 vm[2][vm[3]] = [返回PC, 帧底, vm[1], 函数名]
 vm[3] = vm[3] + 1
}

函数 VM_弹帧(vm) {
 如果 (vm[3] <= 0) {
  vm[5] = VM_状态_异常
  返回 空
 }
 vm[3] = vm[3] - 1
 返回 vm[2][vm[3]]
}

函数 VM_当前帧(vm) {
    如果 (vm[3] <= 0) { 返回 空
}
 返回 vm[2][vm[3] - 1]
}

// 注册内建函数
函数 VM_注册内建(vm, 名称, 回调) {
 字典设置(vm[10], 名称, 回调)
}

// 读取指令
函数 VM_读字节(vm) { 定义 代码 = vm[6][4]
 定义 b = 代码[vm[7]]
 vm[7] = vm[7] + 1
 返回 b
}

函数 VM_读16位(vm) { 定义 lo = VM_读字节(vm)
 定义 hi = VM_读字节(vm)
 返回 lo + hi * 256
}

函数 VM_读64位(vm) { 定义 可变 值 = 0
 定义 可变 i = 0
 当 (i < 8) { 定义 b = VM_读字节(vm)
 值 = 值 + b * 幂(256, i)
 i = i + 1
 }
 返回 值
}

// 主执行循环
函数 VM_处理_SWAP(vm) { 定义 a = VM_弹(vm)
 定义 b = VM_弹(vm)
 VM_推(vm, a)
 VM_推(vm, b)
}

函数 VM_处理_ADD(vm) { 定义 b = VM_弹(vm)
 定义 a = VM_弹(vm)
 如果 (是字符串(a) 或 是字符串(b)) {
 VM_推(vm, 转字符串(a) + 转字符串(b))
 } 否则 {
 VM_推(vm, a + b)
 }
}

函数 VM_处理_DIV(vm) { 定义 b = VM_弹(vm)
 定义 a = VM_弹(vm)
 如果 (b == 0) { VM_推(vm, 0)
 打印("警告: 除零") }
 否则 { VM_推(vm, a / b) }
}

函数 VM_处理_MOD(vm) { 定义 b = VM_弹(vm)
 定义 a = VM_弹(vm)
 如果 (b == 0) { VM_推(vm, 0) }
 否则 { VM_推(vm, a % b) }
}

函数 VM_处理_CALL(vm) { 定义 函数索引 = VM_读16位(vm)
 定义 参数数 = VM_读字节(vm)
 定义 函数名 = vm[6][3][函数索引]
 // 查内建函数
 定义 内建 = 字典获取(vm[10], 函数名)
 如果 (内建 != 空) {
 // 收集参数
 定义 可变 参数 = []
 定义 可变 j = 0
 当 (j < 参数数) { 追加(参数, VM_弹(vm))
 j = j + 1 }
 // 调用内建
 VM_推(vm, 内建(参数))
 } 否则 {
 // 查用户函数
 定义 函数信息 = 字典获取(vm[6][6], 函数名)
 如果 (函数信息 != 空) {
 VM_推帧(vm, vm[7], vm[1] - 参数数, 函数名)
 vm[7] = 函数信息[0]
 } 否则 {
 打印(字符串拼接("错误: 未定义函数 ", 函数名))
 vm[5] = VM_状态_异常
 }
 }
}

函数 VM_处理_RETURN(vm) { 定义 返回值 = VM_弹(vm)
 如果 (vm[3] <= 0) {
 vm[5] = VM_状态_停止
 VM_推(vm, 返回值)
 返回
 }
 定义 帧 = VM_弹帧(vm)
 如果 (帧 == 空) {
 返回
 }
 vm[1] = 帧[1] // 恢复栈顶到帧底
 vm[7] = 帧[0] // 恢复PC
 VM_推(vm, 返回值)
}

函数 VM_处理_RETURN_NIL(vm) { 如果 (vm[3] <= 0) {
 vm[5] = VM_状态_停止
 } 否则 { 定义 帧 = VM_弹帧(vm)
 如果 (帧 == 空) { 返回 }
 vm[1] = 帧[1]
 vm[7] = 帧[0]
 VM_推(vm, 空)
 }
}

函数 VM_处理_HOT_COUNT(vm) { 定义 位置 = vm[7] - 1
 定义 可变 当前 = 字典获取(vm[9], 转字符串(位置))
 如果 (当前 == 空) { 当前 = 0 }
 当前 = 当前 + 1
 字典设置(vm[9], 转字符串(位置), 当前)
 // 热点检测器挂钩: 若已绑定检测器则调用计数+回调
 如果 (vm[12] != 空 且 是列表(vm[12]) 且 计数(vm[12]) > 0) { 定义 检测器 = vm[12][0]
 如果 (检测器 != 空) {
 // 传真实时间戳 (时间()内建函数), 非执行计数
 热点检测器_计数(检测器, 位置, 时间())
 }
 }
}

函数 VM_处理_LINE(vm) { 定义 行号 = VM_读16位(vm)
 // 调试模式: 检查断点
 如果 (vm[8]) {
 VM_调试钩子(vm, 行号)
 }
}

函数 VM_处理_LOAD_UPVAL(vm) { 定义 索引 = VM_读字节(vm)
 定义 帧 = VM_当前帧(vm)
 // upvalue存储在闭包对象中
 如果 (帧 != 空 且 计数(帧) > 4 且 帧[4] != 空) {
 VM_推(vm, 帧[4][索引])
 } 否则 { VM_推(vm, 空) }
}

函数 VM_处理_STORE_UPVAL(vm) { 定义 索引 = VM_读字节(vm)
 定义 帧 = VM_当前帧(vm)
 如果 (帧 != 空 且 计数(帧) > 4 且 帧[4] != 空) {
 帧[4][索引] = VM_弹(vm)
 } 否则 { VM_弹(vm) }
}

函数 VM_处理_NEW_LIST(vm) { 定义 元素数 = VM_读字节(vm)
 定义 可变 列表 = []
 // 从栈上弹出元素(注意顺序: 先推的在底部)
 定义 可变 暂存 = []
 定义 可变 k = 0
 当 (k < 元素数) { 追加(暂存, VM_弹(vm))
 k = k + 1 }
 k = 元素数 - 1
 当 (k >= 0) { 追加(列表, 暂存[k])
 k = k - 1 }
 VM_推(vm, 列表)
}

函数 VM_处理_NEW_DICT(vm) { 定义 对数 = VM_读字节(vm)
 定义 可变 字典 = 字典()
 定义 可变 k = 0
 当 (k < 对数) { 定义 值 = VM_弹(vm)
 定义 键 = VM_弹(vm)
 字典设置(字典, 转字符串(键), 值)
 k = k + 1
 }
 VM_推(vm, 字典)
}

函数 VM_处理_NEW_STRUCT(vm) { 定义 字段数 = VM_读字节(vm)
 定义 可变 结构体实例 = 字典()
 定义 可变 k = 0
 当 (k < 字段数) { 定义 值 = VM_弹(vm)
 定义 名 = VM_弹(vm)
 字典设置(结构体实例, 转字符串(名), 值)
 k = k + 1
 }
 VM_推(vm, 结构体实例)
}

函数 VM_处理_GET_INDEX(vm) { 定义 索引 = VM_弹(vm)
 定义 对象 = VM_弹(vm)
 如果 (是整数(索引) == 假) { VM_推(vm, 空) 返回 }
 如果 (是列表(对象) 且 索引 >= 0 且 索引 < 计数(对象)) {
 VM_推(vm, 对象[索引])
 } 否则 如果 (是字符串(对象) 且 索引 >= 0 且 索引 < 计数(对象)) {
 VM_推(vm, 编码(子串(对象, 索引, 1)))
 } 否则 { VM_推(vm, 空) }
}

函数 VM_处理_SET_INDEX(vm) { 定义 值 = VM_弹(vm)
 定义 索引 = VM_弹(vm)
 定义 对象 = VM_弹(vm)
 如果 (是整数(索引) == 假) {
 VM_推(vm, 对象)
 返回
 }
 如果 (是列表(对象) 且 索引 >= 0 且 索引 < 计数(对象)) {
 对象[索引] = 值
 }
 VM_推(vm, 对象)
}

函数 VM_处理_GET_FIELD(vm) { 定义 名索引 = VM_读16位(vm)
 定义 名 = vm[6][3][名索引]
 定义 对象 = VM_弹(vm)
 VM_推(vm, 字典获取(对象, 名))
}

函数 VM_处理_SET_FIELD(vm) { 定义 名索引 = VM_读16位(vm)
 定义 名 = vm[6][3][名索引]
 定义 值 = VM_弹(vm)
 定义 对象 = VM_弹(vm)
 字典设置(对象, 名, 值)
 VM_推(vm, 对象)
}

函数 VM_处理_SET_DICT(vm) { 定义 值 = VM_弹(vm)
 定义 键 = VM_弹(vm)
 定义 字典 = VM_弹(vm)
 字典设置(字典, 转字符串(键), 值)
 VM_推(vm, 字典)
}

函数 VM_处理_CALL_IND(vm) {
 // 间接调用: 栈顶为函数对象, 下方为参数
 定义 参数数 = VM_读字节(vm)
 定义 函数对象 = VM_弹(vm)
 定义 可变 参数 = []
 定义 可变 k = 0
 当 (k < 参数数) { 追加(参数, VM_弹(vm))
 k = k + 1 }
 如果 (函数对象 != 空 且 是列表(函数对象)) {
 // 函数对象 = [入口PC, 参数数, upvalues]
 VM_推帧(vm, vm[7], vm[1], "lambda")
 vm[7] = 函数对象[0]
 // 将参数推回栈作为局部变量
 k = 参数数 - 1
 当 (k >= 0) { VM_推(vm, 参数[k])
 k = k - 1 }
 } 否则 {
 VM_推(vm, 空)
 }
}

函数 VM_处理_CALL_NATIVE(vm) { 定义 索引 = VM_读16位(vm)
 定义 参数数 = VM_读字节(vm)
 定义 可变 参数 = []
 定义 可变 k = 0
 当 (k < 参数数) { 追加(参数, VM_弹(vm))
 k = k + 1 }
 // 内建函数通过索引查找
 定义 内建名 = vm[6][3][索引]
 定义 内建 = 字典获取(vm[10], 内建名)
 如果 (内建 != 空) {
 VM_推(vm, 内建(参数))
 } 否则 { VM_推(vm, 空) }
}

函数 VM_处理_CALL_FFI(vm) {
 // FFI调用: 通过外部C函数桥接
 定义 索引 = VM_读16位(vm)
 定义 参数数 = VM_读字节(vm)
 定义 可变 参数 = []
 定义 可变 k = 0
 当 (k < 参数数) { 追加(参数, VM_弹(vm))
 k = k + 1 }
 定义 函数名 = vm[6][3][索引]
 定义 结果 = FFI_调用(函数名, 参数)
 VM_推(vm, 结果)
}

函数 VM_处理_CLOSURE(vm) {
 // 创建闭包: 函数入口 + 捕获的upvalue
 定义 函数索引 = VM_读16位(vm)
 定义 upvalue数 = VM_读字节(vm)
 定义 可变 upvalues = []
 定义 可变 k = 0
 当 (k < upvalue数) { 定义 是局部 = VM_读字节(vm)
 定义 索引 = VM_读字节(vm)
 如果 (是局部 == 1) {
 // 从当前帧的局部变量捕获
 定义 帧 = VM_当前帧(vm)
 追加(upvalues, vm[0][帧[2] + 索引])
 } 否则 {
 // 从外层闭包的upvalue捕获
 定义 帧 = VM_当前帧(vm)
 如果 (帧 != 空 且 计数(帧) > 4 且 帧[4] != 空) {
 追加(upvalues, 帧[4][索引])
 } 否则 { 追加(upvalues, 空) }
 }
 k = k + 1
 }
 // 闭包对象: [入口PC, 参数数, upvalues]
 定义 函数名 = vm[6][3][函数索引]
 定义 函数信息 = 字典获取(vm[6][6], 函数名)
 定义 可变 入口 = 0
 如果 (函数信息 != 空) { 入口 = 函数信息[0] }
 VM_推(vm, [入口, upvalue数, upvalues])
}

函数 VM_处理_TAIL_CALL(vm) {
 // 尾调用优化: 复用当前帧
 定义 函数索引 = VM_读16位(vm)
 定义 参数数 = VM_读字节(vm)
 定义 函数名 = vm[6][3][函数索引]
 定义 函数信息 = 字典获取(vm[6][6], 函数名)
 如果 (函数信息 != 空) {
 // 将参数移到帧底, 不创建新帧
 定义 帧 = VM_当前帧(vm)
 定义 可变 参数 = []
 定义 可变 k = 0
 当 (k < 参数数) { 追加(参数, VM_弹(vm))
 k = k + 1 }
 vm[1] = 帧[1] // 重置栈顶到帧底
 k = 参数数 - 1
 当 (k >= 0) { VM_推(vm, 参数[k])
 k = k - 1 }
 vm[7] = 函数信息[0] // 跳到函数入口
 } 否则 {
 打印(字符串拼接("错误: 尾调用未定义函数 ", 函数名))
 vm[5] = VM_状态_异常
 }
}

函数 VM_处理_RESUME(vm) {
 // 协程恢复: 由外部调用VM_恢复()处理
 定义 协程 = VM_弹(vm)
 如果 (协程 != 空 且 是列表(协程)) {
 // 协程状态: [vm副本]
 VM_推(vm, 空) // 恢复值由调度器注入
 }
}

函数 VM_处理_TYPE_CHECK(vm) { 定义 类型ID = VM_读字节(vm)
 定义 值 = VM_看顶(vm)
 定义 可变 已匹配 = 假
 如果 (类型ID == 1 且 是整数(值)) { 已匹配 = 真 }
 否则 如果 (类型ID == 2 且 是浮点(值)) { 已匹配 = 真 }
 否则 如果 (类型ID == 3 且 是字符串(值)) { 已匹配 = 真 }
 否则 如果 (类型ID == 4 且 是列表(值)) { 已匹配 = 真 }
 否则 如果 (类型ID == 5 且 是字典(值)) { 已匹配 = 真 }
 否则 如果 (类型ID == 0 且 值 == 空) { 已匹配 = 真 }
 VM_推(vm, 已匹配)
}

函数 VM_处理_TYPE_CAST(vm) { 定义 类型ID = VM_读字节(vm)
 定义 值 = VM_弹(vm)
 如果 (类型ID == 1) { VM_推(vm, 转整数(值)) }
 否则 如果 (类型ID == 3) { VM_推(vm, 转字符串(值)) }
 否则 { VM_推(vm, 值) }
}

函数 VM_处理_LEN(vm) { 定义 值 = VM_弹(vm)
 如果 (是字符串(值)) { VM_推(vm, 字符串长度(值)) }
 否则 如果 (是列表(值)) { VM_推(vm, 计数(值)) }
 否则 { VM_推(vm, 0) }
}

函数 VM_处理_ASSERT(vm) { 定义 值 = VM_弹(vm)
 如果 (!值) {
 打印("断言失败!")
 vm[5] = VM_状态_异常
 }
}

函数 VM_处理_CATCH(vm) {
 // CATCH: 弹出异常处理栈顶，避免后续THROW重复命中同一处理器
 如果 (计数(vm) > 11 且 计数(vm[11]) > 0) {
 定义 可变 异常栈 = vm[11]
 删除(异常栈, 计数(异常栈) - 1)
 }
}

函数 VM_处理_THROW(vm) {
 // THROW: 抛出异常, 跳转到最近的catch
 定义 异常值 = VM_弹(vm)
 如果 (计数(vm) > 11 且 计数(vm[11]) > 0) { 定义 处理器 = vm[11][计数(vm[11]) - 1]
 vm[7] = 处理器[0] // 跳转到catch
 vm[1] = 处理器[1] // 恢复栈
 vm[3] = 处理器[2] // 恢复帧
 VM_推(vm, 异常值) // 异常值在栈顶
 } 否则 {
 打印(字符串拼接("未捕获异常: ", 转字符串(异常值)))
 vm[5] = VM_状态_异常
 }
}

函数 VM_处理_IMPORT(vm) { 定义 模块索引 = VM_读16位(vm)
 定义 模块名 = vm[6][3][模块索引]
 // 导入逻辑: 查找已加载模块或初始化模块表
 定义 可变 已加载 = 字典获取(vm[4], "__模块表__")
 如果 (已加载 == 空) {
 已加载 = 字典()
 字典设置(vm[4], "__模块表__", 已加载)
 }
 VM_推(vm, 字典获取(已加载, 模块名))
}

函数 VM_处理_MATCH(vm) {
 // 模式匹配: 弹出值和模式数, 逐个比较
 定义 分支数 = VM_读字节(vm)
 定义 目标值 = VM_弹(vm)
 定义 可变 匹配到 = 假
 定义 可变 k = 0
 当 (k < 分支数 且 !匹配到) { 定义 模式 = VM_弹(vm)
 定义 跳转 = VM_读16位(vm)
 如果 (目标值 == 模式) {
 vm[7] = 跳转
 匹配到 = 真
 }
 k = k + 1
 }
 如果 (!匹配到) {
 // 默认分支
 定义 默认跳转 = VM_读16位(vm)
 vm[7] = 默认跳转
 }
}

函数 VM_处理_FOREACH(vm) {
 // 迭代器: 迭代列表/字典
 定义 _止 = VM_读16位(vm)
 定义 迭代变量 = VM_读字节(vm)
 定义 计数变量 = VM_读字节(vm)
 定义 帧 = VM_当前帧(vm)
 定义 集合 = vm[0][帧[2] + 迭代变量]
 定义 可变 当前索引 = vm[0][帧[2] + 计数变量]
 如果 (当前索引 == 空) { 当前索引 = 0 }
 如果 (是列表(集合) 且 当前索引 < 计数(集合)) {
 VM_推(vm, 集合[当前索引])
 vm[0][帧[2] + 计数变量] = 当前索引 + 1
 } 否则 {
 vm[7] = _止 // 迭代结束
 }
}

函数 VM_处理_SPREAD(vm) {
 // 展开操作: 将列表展开到栈上
 定义 列表 = VM_弹(vm)
 如果 (是列表(列表)) { 定义 可变 k = 0
 当 (k < 计数(列表)) {
 VM_推(vm, 列表[k])
 k = k + 1
 }
 }
}

函数 VM_分发(vm, op) {
 // 提取的操作码分发逻辑 — 降低VM_执行的嵌套深度
 如果 (op == 指令_空操作) { VM_空操作() }
 否则 如果 (op == 指令_压入整数) {
 VM_推(vm, VM_读64位(vm))
 }
 否则 如果 (op == 指令_压入字串) { 定义 索引 = VM_读16位(vm)
 VM_推(vm, vm[6][3][索引])
 }
 否则 如果 (op == 指令_压入空) { VM_推(vm, 空) }
 否则 如果 (op == 指令_压入真) { VM_推(vm, 真) }
 否则 如果 (op == 指令_压入假) { VM_推(vm, 假) }
 否则 如果 (op == 指令_弹出) { VM_弹(vm) }
 否则 如果 (op == 指令_复制) { VM_推(vm, VM_看顶(vm)) }
 否则 如果 (op == 指令_交换) {
 VM_处理_SWAP(vm)
 }

 // 算术
 否则 如果 (op == 指令_加) {
 VM_处理_ADD(vm)
 }
 否则 如果 (op == 指令_减) { 定义 b = VM_弹(vm)
 定义 a = VM_弹(vm)
 VM_推(vm, a - b) }
 否则 如果 (op == 指令_乘) { 定义 b = VM_弹(vm)
 定义 a = VM_弹(vm)
 VM_推(vm, a * b) }
 否则 如果 (op == 指令_除) {
 VM_处理_DIV(vm)
 }
 否则 如果 (op == 指令_余) {
 VM_处理_MOD(vm)
 }
 否则 如果 (op == 指令_取负) { VM_推(vm, 0 - VM_弹(vm)) }
 否则 如果 (op == 指令_非) { VM_推(vm, !VM_弹(vm)) }
 否则 如果 (op == 指令_位与) { 定义 b = VM_弹(vm)
 VM_推(vm, VM_弹(vm) & b) }
 否则 如果 (op == 指令_位或) { 定义 b = VM_弹(vm)
 VM_推(vm, VM_弹(vm) | b) }
 否则 如果 (op == 指令_位异或) { 定义 b = VM_弹(vm)
 VM_推(vm, VM_弹(vm) ^ b) }
 否则 如果 (op == 指令_左移) { 定义 b = VM_弹(vm)
 VM_推(vm, VM_弹(vm) << b) }
 否则 如果 (op == 指令_右移) { 定义 b = VM_弹(vm)
 VM_推(vm, VM_弹(vm) >> b) }

 // 比较
 否则 如果 (op == 指令_比等) { 定义 b = VM_弹(vm)
 VM_推(vm, VM_弹(vm) == b) }
 否则 如果 (op == 指令_比不等) { 定义 b = VM_弹(vm)
 VM_推(vm, VM_弹(vm) != b) }
 否则 如果 (op == 指令_比小) { 定义 b = VM_弹(vm)
 VM_推(vm, VM_弹(vm) < b) }
 否则 如果 (op == 指令_比小等) { 定义 b = VM_弹(vm)
 VM_推(vm, VM_弹(vm) <= b) }
 否则 如果 (op == 指令_比大) { 定义 b = VM_弹(vm)
 VM_推(vm, VM_弹(vm) > b) }
 否则 如果 (op == 指令_比大等) { 定义 b = VM_弹(vm)
 VM_推(vm, VM_弹(vm) >= b) }

 // 变量访问
 否则 如果 (op == 指令_载局部) { 定义 索引 = VM_读16位(vm)
 定义 帧 = VM_当前帧(vm)
 VM_推(vm, vm[0][帧[2] + 索引])
 }
 否则 如果 (op == 指令_存局部) { 定义 索引 = VM_读16位(vm)
 定义 帧 = VM_当前帧(vm)
 vm[0][帧[2] + 索引] = VM_弹(vm)
 }
 否则 如果 (op == 指令_载全局) { 定义 名索引 = VM_读16位(vm)
 定义 名 = vm[6][3][名索引]
 VM_推(vm, 字典获取(vm[4], 名))
 }
 否则 如果 (op == 指令_存全局) { 定义 名索引 = VM_读16位(vm)
 定义 名 = vm[6][3][名索引]
 字典设置(vm[4], 名, VM_弹(vm))
 }

 // 分支控制
 否则 如果 (op == 指令_跳转) {
 vm[7] = VM_读16位(vm)
 }
 否则 如果 (op == 指令_真跳) { 定义 目标 = VM_读16位(vm)
 如果 (VM_弹(vm)) { vm[7] = 目标 }
 }
 否则 如果 (op == 指令_假跳) { 定义 目标 = VM_读16位(vm)
 如果 (!VM_弹(vm)) { vm[7] = 目标 }
 }
 否则 如果 (op == 指令_循环) { 定义 目标 = VM_读16位(vm)
 vm[7] = 目标
 }

 // 函数调用
 否则 如果 (op == 指令_调用) {
 VM_处理_CALL(vm)
 }
 否则 如果 (op == 指令_返回) {
 VM_处理_RETURN(vm)
 }
 否则 如果 (op == 指令_返回空) {
 VM_处理_RETURN_NIL(vm)
 }

 // 输出
 否则 如果 (op == 指令_打印) { 定义 值 = VM_弹(vm)
 打印(转字符串(值))
 }

 // 热点计数 (JIT策略引擎入口)
 否则 如果 (op == 指令_热点计) {
 VM_处理_HOT_COUNT(vm)
 }

 // 调试
 否则 如果 (op == 指令_行号) {
 VM_处理_LINE(vm)
 }
 否则 如果 (op == 指令_断点) { 如果 (vm[8]) {
 vm[5] = VM_状态_暂停
 }
 }

 // 位非
 否则 如果 (op == 指令_位非) { VM_推(vm, ~VM_弹(vm)) }
 否则 如果 (op == 指令_压入浮点) {
 VM_推(vm, VM_读64位(vm)) // 浮点以64位整数形式存储
 }

 // 内存操作: 闭包变量/数据结构
 否则 如果 (op == 指令_载闭包) {
 VM_处理_LOAD_UPVAL(vm)
 }
 否则 如果 (op == 指令_存闭包) {
 VM_处理_STORE_UPVAL(vm)
 }
 否则 如果 (op == 指令_建列表) {
 VM_处理_NEW_LIST(vm)
 }
 否则 如果 (op == 指令_建字典) {
 VM_处理_NEW_DICT(vm)
 }
 否则 如果 (op == 指令_建结构) {
 VM_处理_NEW_STRUCT(vm)
 }
 否则 如果 (op == 指令_取索引) {
 VM_处理_GET_INDEX(vm)
 }
 否则 如果 (op == 指令_设索引) {
 VM_处理_SET_INDEX(vm)
 }
 否则 如果 (op == 指令_取字段) {
 VM_处理_GET_FIELD(vm)
 }
 否则 如果 (op == 指令_设字段) {
 VM_处理_SET_FIELD(vm)
 }
 否则 如果 (op == 指令_取字典) { 定义 键 = VM_弹(vm)
 定义 字典 = VM_弹(vm)
 VM_推(vm, 字典获取(字典, 转字符串(键)))
 }
 否则 如果 (op == 指令_设字典) {
 VM_处理_SET_DICT(vm)
 }

 // 函数调用扩展
 否则 如果 (op == 指令_间接调用) {
 VM_处理_CALL_IND(vm)
 }
 否则 如果 (op == 指令_原生调用) {
 VM_处理_CALL_NATIVE(vm)
 }
 否则 如果 (op == 指令_外部调用) {
 VM_处理_CALL_FFI(vm)
 }
 否则 如果 (op == 指令_闭包) {
 VM_处理_CLOSURE(vm)
 }
 否则 如果 (op == 指令_尾调用) {
 VM_处理_TAIL_CALL(vm)
 }
 否则 如果 (op == 指令_让出) {
 // 协程让出: 保存状态, 返回给调度器
 vm[5] = VM_状态_暂停
 }
 否则 如果 (op == 指令_恢复) {
 VM_处理_RESUME(vm)
 }

 // 类型操作
 否则 如果 (op == 指令_类型检查) {
 VM_处理_TYPE_CHECK(vm)
 }
 否则 如果 (op == 指令_类型转换) {
 VM_处理_TYPE_CAST(vm)
 }
 否则 如果 (op == 指令_是整数) { VM_推(vm, 是整数(VM_弹(vm))) }
 否则 如果 (op == 指令_是浮点) { VM_推(vm, 是浮点(VM_弹(vm))) }
 否则 如果 (op == 指令_是字串) { VM_推(vm, 是字符串(VM_弹(vm))) }
 否则 如果 (op == 指令_是列表) { VM_推(vm, 是列表(VM_弹(vm))) }
 否则 如果 (op == 指令_是字典) { VM_推(vm, 是字典(VM_弹(vm))) }
 否则 如果 (op == 指令_是空) { VM_推(vm, VM_弹(vm) == 空) }
 否则 如果 (op == 指令_是函数) { 定义 值 = VM_弹(vm)
 // 函数对象是列表形式 [入口PC, 参数数, upvalues]
 VM_推(vm, 是列表(值) 且 计数(值) >= 2)
 }
 否则 如果 (op == 指令_转整数) { VM_推(vm, 转整数(VM_弹(vm))) }
 否则 如果 (op == 指令_转浮点) { VM_推(vm, 转浮点(VM_弹(vm))) }
 否则 如果 (op == 指令_转字串) { VM_推(vm, 转字符串(VM_弹(vm))) }
 否则 如果 (op == 指令_长度) {
 VM_处理_LEN(vm)
 }
 否则 如果 (op == 指令_断言) {
 VM_处理_ASSERT(vm)
 }

 // 异常处理
 否则 如果 (op == 指令_尝试) {
 // TRY: 记录catch跳转目标, 压入异常处理栈
 定义 catch目标 = VM_读16位(vm)
 // 异常处理栈存在vm[11]
 如果 (计数(vm) <= 11) { 追加(vm, []) }
 追加(vm[11], [catch目标, vm[1], vm[3]]) // [catch_PC, 栈顶, 帧顶]
 }
 否则 如果 (op == 指令_捕获) {
 VM_处理_CATCH(vm)
 }
 否则 如果 (op == 指令_抛出) {
 VM_处理_THROW(vm)
 }
 否则 如果 (op == 指令_导入) {
 VM_处理_IMPORT(vm)
 }

 // JIT标记
 否则 如果 (op == 指令_即时编译入) {
 VM_JIT标记(vm, "进入")
 }
 否则 如果 (op == 指令_即时编译出) {
 VM_JIT标记(vm, "退出")
 }

 // 模式匹配
 否则 如果 (op == 指令_匹配) {
 VM_处理_MATCH(vm)
 }
 否则 如果 (op == 指令_遍历) {
 VM_处理_FOREACH(vm)
 }
 否则 如果 (op == 指令_展开) {
 VM_处理_SPREAD(vm)
 }

 // 停机
 否则 如果 (op == 指令_停机) {
 vm[5] = VM_状态_停止
 }
}

函数 VM_执行(vm) { 定义 可变 指令数 = 0
 打印(字符串拼接("[虚拟机_诊断] 最大指令=", 转字符串(VM_配置_最大指令)))
 打印(字符串拼接("[虚拟机_诊断] vm[5]=", 字符串拼接(转字符串(vm[5]), 字符串拼接(" 运行=", 转字符串(VM_状态_运行)))))
 打印(字符串拼接("[虚拟机_诊断] PC=", 字符串拼接(转字符串(vm[7]), 字符串拼接(" 代码长=", 转字符串(计数(vm[6][4]))))))
 打印(字符串拼接("[虚拟机_诊断] cond1=", 字符串拼接(转字符串(vm[5] == VM_状态_运行), 字符串拼接(" cond2=", 转字符串(指令数 < VM_配置_最大指令)))))
 当 (vm[5] == VM_状态_运行 且 指令数 < VM_配置_最大指令) { 定义 op = VM_读字节(vm)
 指令数 = 指令数 + 1
 VM_分发(vm, op)
 }

 返回 指令数
}

// 便捷接口
函数 VM_运行字节码(字节码块) { 定义 vm = VM_创建(字节码块)
 // 跳转到 __主程序__
 打印(字符串拼接("[虚拟机_诊断] 字节码块长=", 转字符串(计数(字节码块))))
 打印(字符串拼接("[虚拟机_诊断] 函数表类型=", 转字符串(是列表(字节码块[6]))))
 定义 主函数 = 字典获取(字节码块[6], "__主程序__")
 打印(字符串拼接("[虚拟机_诊断] 主函数=", 转字符串(主函数)))
 如果 (主函数 != 空) {
 vm[7] = 主函数[0]
 打印(字符串拼接("[虚拟机_诊断] PC设为=", 转字符串(主函数[0])))
 }
 定义 指令数 = VM_执行(vm)
 返回 [vm[5], 指令数, vm[1]]
}

函数 VM_设置调试(vm, 开关) {
 vm[8] = 开关
}

函数 VM_恢复(vm) {
 // 恢复暂停的协程
 如果 (vm[5] == VM_状态_暂停) {
 vm[5] = VM_状态_运行
 返回 VM_执行(vm)
 }
 返回 0
}

函数 VM_获取热点(vm) { 返回 vm[9]
}

// 绑定热点检测器到VM (JIT策略引擎闭环关键)
// 调用后, VM_执行中的NOVA_HOT_COUNT会自动触发热点检测→JIT编译→块级切换
// vm[12] = [检测器, jit代码缓冲区]
函数 VM_绑定热点检测器(vm, 检测器) {
 vm[12] = [检测器, 空]
}

// 绑定JIT编译器代码缓冲区到VM (块级切换需要)
函数 VM_绑定JIT缓冲(vm, jit) {
    如果 (vm[12] != 空 且 是列表(vm[12]) 且 计数(vm[12]) > 0) { 如果 (计数(vm[12]) < 2) { 追加(vm[12], jit[0])
}
 否则 { vm[12][1] = jit[0] }
 }
}

// 获取字节码块: 策略引擎/JIT编译器用
// 参数: vm — VM实例, 块ID — 循环头PC位置(由HOT_COUNT记录)
// 回: [字节码指令数组, 起始PC, 块长度] 或 空
// 策略: 从块ID(循环头)开始,扫描到对应LOOP指令结尾
函数 VM_获取块(vm, 块ID) { 定义 代码 = vm[6][4]
 定义 代码长 = 计数(代码)
 如果 (块ID < 0 或 块ID >= 代码长) { 返回 空 }
 // 从块ID位置开始扫描,找到回跳到此位置的LOOP指令
 定义 可变 pc = 块ID
 定义 可变 块长 = 0
 定义 可变 深度 = 0
 定义 可变 已找到 = 假
 当 (pc < 代码长 且 !已找到) { 定义 op = 代码[pc]
 定义 大小 = Nova指令_操作数大小(op)
 // 遇到LOOP指令且目标是块ID → 块结束
 如果 (op == 指令_循环) { 如果 (深度 == 0) { 定义 目标 = 代码[pc + 1] + 代码[pc + 2] * 256
 如果 (目标 == 块ID) {
 块长 = pc + 1 + 大小 - 块ID
 已找到 = 真
 }
 } 否则 {
 深度 = 深度 - 1
 }
 }
 // 嵌套循环: HOT_COUNT标记新循环头
 如果 (op == 指令_热点计 且 pc != 块ID) {
 深度 = 深度 + 1
 }
 pc = pc + 1 + 大小
 }
 如果 (!已找到) {
 // 未找到匹配LOOP,取安全上限(256字节或到代码尾)
 块长 = 代码长 - 块ID
 如果 (块长 > 256) { 块长 = 256 }
 }
 返回 [代码, 块ID, 块长]
}

// FFI桥接(由FFI模块提供)
外部 FFI_调用 // (函数名, 参数列表) -> 返回值

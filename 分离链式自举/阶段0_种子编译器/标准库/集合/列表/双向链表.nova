// Nova标准库 — 双向链表与跳表
// O(1) 头尾插入删除、LRU 缓存、跳表 O(log n) 查找
// 支持迭代器、反向遍历、切片、合并排序

导入("../../基础.nova")

// 双向链表节点
// 节点: [值, 前驱ID, 后继ID, 有效]

// 双向链表
// 型: [节点表, 头ID, 尾ID, 大小, 下一ID, 空闲列表]

函数 双向链表_创建() { 返回 [[], -1, -1, 0, []]
}

函数 双向链表_分配节点(链表, 值) { 定义 可变 id = -1
    定义 可变 新空闲 = []
 如果 (计数(链表[5]) > 0) {
 id = 链表[5][计数(链表[5]) - 1]
 定义 可变 i = 0
 当 (i < 计数(链表[5]) - 1) { 追加(新空闲, 链表[5][i]) i = i + 1 }
 链表[5] = 新空闲
 链表[0][id] = [值, -1, -1, 真]
 } 否则 {
 id = 链表[4]
 链表[4] = 链表[4] + 1
 追加(链表[0], [值, -1, -1, 真])
 }
 返回 id
}

函数 双向链表_头插(链表, 值) { 定义 id = 双向链表_分配节点(链表, 值)
 如果 (链表[1] == -1) {
 链表[1] = id
 链表[2] = id
 } 否则 {
 链表[0][id][2] = 链表[1]
 链表[0][链表[1]][1] = id
 链表[1] = id
 }
 链表[3] = 链表[3] + 1
 返回 id
}

函数 双向链表_尾插(链表, 值) { 定义 id = 双向链表_分配节点(链表, 值)
 如果 (链表[2] == -1) {
 链表[1] = id
 链表[2] = id
 } 否则 {
 链表[0][id][1] = 链表[2]
 链表[0][链表[2]][2] = id
 链表[2] = id
 }
 链表[3] = 链表[3] + 1
 返回 id
}

函数 双向链表_头删(链表) {
    如果 (链表[1] == -1) { 返回 空
}
 定义 id = 链表[1]
 定义 值 = 链表[0][id][0]
 定义 后继 = 链表[0][id][2]
 链表[0][id][3] = 假
 追加(链表[5], id)
 链表[1] = 后继
 如果 (后继 >= 0) { 链表[0][后继][1] = -1 }
 否则 { 链表[2] = -1 }
 链表[3] = 链表[3] - 1
 返回 值
}

函数 双向链表_尾删(链表) {
    如果 (链表[2] == -1) { 返回 空
}
 定义 id = 链表[2]
 定义 值 = 链表[0][id][0]
 定义 前驱 = 链表[0][id][1]
 链表[0][id][3] = 假
 追加(链表[5], id)
 链表[2] = 前驱
 如果 (前驱 >= 0) { 链表[0][前驱][2] = -1 }
 否则 { 链表[1] = -1 }
 链表[3] = 链表[3] - 1
 返回 值
}

函数 双向链表_删除节点(链表, id) {
    如果 (id < 0 或 id >= 计数(链表[0]) 或 链表[0][id][3] == 假) { 返回 假
}
 定义 前驱 = 链表[0][id][1]
 定义 后继 = 链表[0][id][2]
 如果 (前驱 >= 0) { 链表[0][前驱][2] = 后继 }
 否则 { 链表[1] = 后继 }
 如果 (后继 >= 0) { 链表[0][后继][1] = 前驱 }
 否则 { 链表[2] = 前驱 }
 链表[0][id][3] = 假
 追加(链表[5], id)
 链表[3] = 链表[3] - 1
 返回 真
}

// 将节点移到头部 (LRU 用)
函数 双向链表_移到头(链表, id) {
    如果 (id == 链表[1]) { 返回
}
 定义 值 = 链表[0][id][0]
 双向链表_删除节点(链表, id)
 双向链表_头插(链表, 值)
}

// 将节点移到尾部
函数 双向链表_移到尾(链表, id) {
    如果 (id == 链表[2]) { 返回
}
 定义 值 = 链表[0][id][0]
 双向链表_删除节点(链表, id)
 双向链表_尾插(链表, 值)
}

函数 双向链表_大小(链表) { 返回 链表[3] }
函数 双向链表_为空(链表) { 返回 链表[3] == 0 }
函数 双向链表_头值(链表) {
    如果 (链表[1] == -1) { 返回 空
}
 返回 链表[0][链表[1]][0]
}
函数 双向链表_尾值(链表) {
    如果 (链表[2] == -1) { 返回 空
}
 返回 链表[0][链表[2]][0]
}

函数 双向链表_取(链表, id) {
    如果 (id < 0 或 id >= 计数(链表[0]) 或 链表[0][id][3] == 假) { 返回 空
}
 返回 链表[0][id][0]
}

函数 双向链表_设(链表, id, 值) {
    如果 (id < 0 或 id >= 计数(链表[0]) 或 链表[0][id][3] == 假) { 返回 假
}
 链表[0][id][0] = 值
 返回 真
}

// 遍历
函数 双向链表_正向列表(链表) { 定义 可变 结果 = []
 定义 可变 当前 = 链表[1]
 当 (当前 >= 0) {
 追加(结果, 链表[0][当前][0])
 当前 = 链表[0][当前][2]
 }
 返回 结果
}

函数 双向链表_反向列表(链表) { 定义 可变 结果 = []
 定义 可变 当前 = 链表[2]
 当 (当前 >= 0) {
 追加(结果, 链表[0][当前][0])
 当前 = 链表[0][当前][1]
 }
 返回 结果
}

函数 双向链表_查找(链表, 值) { 定义 可变 当前 = 链表[1]
 当 (当前 >= 0) { 如果 (链表[0][当前][0] == 值) { 返回 当前 }
 当前 = 链表[0][当前][2]
 }
 返回 -1
}

函数 双向链表_包含(链表, 值) { 返回 双向链表_查找(链表, 值) >= 0
}

// 在指定节点后插入
函数 双向链表_后插(链表, 参考ID, 值) {
    如果 (参考ID < 0 或 链表[0][参考ID][3] == 假) { 返回 -1
}
 定义 新ID = 双向链表_分配节点(链表, 值)
 定义 后继 = 链表[0][参考ID][2]
 链表[0][新ID][1] = 参考ID
 链表[0][新ID][2] = 后继
 链表[0][参考ID][2] = 新ID
 如果 (后继 >= 0) { 链表[0][后继][1] = 新ID }
 否则 { 链表[2] = 新ID }
 链表[3] = 链表[3] + 1
 返回 新ID
}

// LRU 缓存 (基于双向链表 + 字典)
// 型: [链表, 键值映射, 容量, 命中数, 未命中数]

函数 链表_LRU_创建(容量) {
    如果 (实际容量 <= 0) { 实际容量 = 128
}
 返回 [双向链表_创建(), 字典(), 实际容量,]
}

函数 链表_LRU_获取(缓存, 键) { 定义 条目 = 字典取(缓存[1], 键)
 如果 (条目 == 空) {
 缓存[4] = 缓存[4] + 1
 返回 空
 }
 缓存[3] = 缓存[3] + 1
 // 移到头部 (最近使用)
 双向链表_移到头(缓存[0], 条目[0])
 返回 条目[1]
}

函数 链表_LRU_设置(缓存, 键, 值) { 定义 现有 = 字典取(缓存[1], 键)
 如果 (现有 != 空) {
 现有[1] = 值
 双向链表_移到头(缓存[0], 现有[0])
 返回
 }
 // 容量检查: 淘汰最久未使用的
 如果 (双向链表_大小(缓存[0]) >= 缓存[2]) { 定义 _淘汰值 = 双向链表_尾值(缓存[0])
 双向链表_尾删(缓存[0])
 字典设(缓存[1], _淘汰值[0], 空)
 }
 定义 节点ID = 双向链表_头插(缓存[0], [键, 值])
 字典设(缓存[1], 键, [节点ID, 值])
}

函数 链表_LRU_删除(缓存, 键) { 定义 条目 = 字典取(缓存[1], 键)
 如果 (条目 == 空) { 返回 假 }
 双向链表_删除节点(缓存[0], 条目[0])
 字典设(缓存[1], 键, 空)
 返回 真
}

函数 链表_LRU_大小(缓存) { 返回 双向链表_大小(缓存[0]) }
函数 链表_LRU_命中率(缓存) { 定义 总 = 缓存[3] + 缓存[4]
 如果 (总 == 0) { 返回 0 }
 返回 缓存[3] * 1000 / 总
}

// 跳表 (Skip List)
// O(log n) 查找、插入、删除的概率数据结构
// 节点: [值, 层级, 前进指针列表(每层的下一节点ID)]
// 跳表: [节点表, 头ID, 最大层, 当前层, 大小, 随机种子]

定义 跳表_最大层 = 16

函数 双向链表_跳表_创建() {
 // 哨兵头节点
 定义 可变 前进 = []
 定义 可变 i = 0
 当 (i < 跳表_最大层) { 追加(前进, -1) i = i + 1 }
 定义 头 = [0 - 0x7FFFFFFF, 跳表_最大层, 前进]
 返回 [[头], 0, 跳表_最大层, 0, 42]
}

函数 跳表_随机层(跳表) { 定义 可变 层 = 1
 跳表[5] = (跳表[5] * 1103515245 + 12345) % 2147483648
 定义 可变 r = 跳表[5]
 当 (层 < 跳表_最大层 且 r % 4 < 2) {
 层 = 层 + 1
 r = r / 4
 }
 返回 层
}

函数 双向链表_跳表_插入(跳表, 值) {
    定义 可变 更新列表 = []
 // 找到每层的前驱节点
 定义 可变 i = 0
 当 (i < 跳表_最大层) { 追加(更新列表, -1) i = i + 1 }
 定义 可变 当前 = 跳表[1]
 i = 跳表[3] - 1
 如果 (i < 0) { i = 0 }
 当 (i >= 0) {
 当 (跳表[0][当前][2][i] >= 0 且 跳表[0][跳表[0][当前][2][i]][0] < 值) {
 当前 = 跳表[0][当前][2][i]
 }
 更新列表[i] = 当前
 i = i - 1
 }
 // 检查是否已存在
 定义 下一 = 跳表[0][当前][2][0]
 如果 (下一 >= 0 且 跳表[0][下一][0] == 值) { 返回 假
 }
 // 创建新节点
 定义 新层 = 跳表_随机层(跳表)
 如果 (新层 > 跳表[3]) {
 i = 跳表[3]
 当 (i < 新层) {
 更新列表[i] = 跳表[1]
 i = i + 1
 }
 跳表[3] = 新层
 }
 定义 可变 前进 = []
 i = 0
 当 (i < 跳表_最大层) { 追加(前进, -1) i = i + 1 }
 定义 新节点 = [值, 新层, 前进]
 定义 新ID = 计数(跳表[0])
 追加(跳表[0], 新节点)
 // 更新前进指针
 i = 0
 当 (i < 新层) { 定义 可变 前驱 = 更新列表[i]
 如果 (前驱 < 0) { 前驱 = 跳表[1] }
 跳表[0][新ID][2][i] = 跳表[0][前驱][2][i]
 跳表[0][前驱][2][i] = 新ID
 i = i + 1
 }
 跳表[4] = 跳表[4] + 1
 返回 真
}

函数 跳表_查找(跳表, 值) { 定义 可变 当前 = 跳表[1]
 定义 可变 i = 跳表[3] - 1
 如果 (i < 0) { i = 0 }
 当 (i >= 0) {
 当 (跳表[0][当前][2][i] >= 0 且 跳表[0][跳表[0][当前][2][i]][0] < 值) {
 当前 = 跳表[0][当前][2][i]
 }
 i = i - 1
 }
 定义 下一 = 跳表[0][当前][2][0]
 如果 (下一 >= 0 且 跳表[0][下一][0] == 值) { 返回 真 }
 返回 假
}

函数 跳表_删除(跳表, 值) {
    定义 可变 更新列表 = []
 定义 可变 i = 0
 当 (i < 跳表_最大层) { 追加(更新列表, -1) i = i + 1 }
 定义 可变 当前 = 跳表[1]
 i = 跳表[3] - 1
 如果 (i < 0) { i = 0 }
 当 (i >= 0) {
 当 (跳表[0][当前][2][i] >= 0 且 跳表[0][跳表[0][当前][2][i]][0] < 值) {
 当前 = 跳表[0][当前][2][i]
 }
 更新列表[i] = 当前
 i = i - 1
 }
 定义 目标 = 跳表[0][当前][2][0]
 如果 (目标 < 0 或 跳表[0][目标][0] != 值) { 返回 假 }
 // 更新前进指针
 i = 0
 当 (i < 跳表[3]) { 定义 可变 前驱 = 更新列表[i]
 如果 (前驱 < 0) { 前驱 = 跳表[1] }
 如果 (跳表[0][前驱][2][i] == 目标) {
 跳表[0][前驱][2][i] = 跳表[0][目标][2][i]
 }
 i = i + 1
 }
 // 降低层级
 当 (跳表[3] > 0 且 跳表[0][跳表[1]][2][跳表[3] - 1] < 0) {
 跳表[3] = 跳表[3] - 1
 }
 跳表[4] = 跳表[4] - 1
 返回 真
}

函数 双向链表_跳表_大小(跳表) { 返回 跳表[4] }

函数 跳表_有序列表(跳表) { 定义 可变 结果 = []
 定义 可变 当前 = 跳表[0][跳表[1]][2][0]
 当 (当前 >= 0) {
 追加(结果, 跳表[0][当前][0])
 当前 = 跳表[0][当前][2][0]
 }
 返回 结果
}

函数 跳表_范围(跳表, 最小, 最大) { 定义 可变 结果 = []
 定义 可变 当前 = 跳表[1]
 定义 可变 i = 跳表[3] - 1
 如果 (i < 0) { i = 0 }
 当 (i >= 0) {
 当 (跳表[0][当前][2][i] >= 0 且 跳表[0][跳表[0][当前][2][i]][0] < 最小) {
 当前 = 跳表[0][当前][2][i]
 }
 i = i - 1
 }
 当前 = 跳表[0][当前][2][0]
 当 (当前 >= 0 且 跳表[0][当前][0] <= 最大) {
 追加(结果, 跳表[0][当前][0])
 当前 = 跳表[0][当前][2][0]
 }
 返回 结果
}

// 双向链表扩展

函数 双链_反转(链表) { 定义 可变 当前 = 链表[1]
 定义 可变 前驱 = -1
 当 (当前 >= 0) { 定义 节点 = 链表[0][当前]
 定义 下一个 = 节点[2]
 节点[2] = 节点[1]
 节点[1] = 下一个
 前驱 = 当前
 当前 = 下一个
 }
 定义 旧头 = 链表[1]
 链表[1] = 链表[2]
 链表[2] = 旧头
}

函数 双链_转列表(链表) { 定义 可变 结果 = []
 定义 可变 当前 = 链表[1]
 当 (当前 >= 0) {
 追加(结果, 链表[0][当前][0])
 当前 = 链表[0][当前][2]
 }
 返回 结果
}

函数 双链_从列表(列表) { 定义 可变 链表 = [[], -1, -1, 0]
 定义 可变 i = 0
 当 (i < 计数(列表)) { 定义 索引 = 计数(链表[0])
 追加(链表[0], [列表[i], 链表[2], -1])
 如果 (链表[2] >= 0) { 链表[0][链表[2]][2] = 索引 }
 链表[2] = 索引
 如果 (链表[1] < 0) { 链表[1] = 索引 }
 链表[3] = 链表[3] + 1
 i = i + 1
 }
 返回 链表
}

函数 双链_合并(链表A, 链表B) { 定义 列表A = 双链_转列表(链表A)
 定义 列表B = 双链_转列表(链表B)
 定义 可变 合并 = []
 定义 可变 i = 0
 当 (i < 计数(列表A)) { 追加(合并, 列表A[i]) i = i + 1 }
 i = 0
 当 (i < 计数(列表B)) { 追加(合并, 列表B[i]) i = i + 1 }
 返回 双链_从列表(合并)
}

函数 双链_去重(链表) { 定义 列表 = 双链_转列表(链表)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(列表)) { 定义 可变 存在 = 假
 定义 可变 j = 0
 当 (j < 计数(结果)) { 如果 (结果[j] == 列表[i]) { 存在 = 真 }
 j = j + 1
 }
 如果 (!存在) { 追加(结果, 列表[i]) }
 i = i + 1
 }
 返回 双链_从列表(结果)
}

定义 可变 _链表_统计 = [0, 0, 0] // [插入, 删除, 遍历]

函数 链表_记录插入() { _链表_统计[0] = _链表_统计[0] + 1 }
函数 链表_记录删除() { _链表_统计[1] = _链表_统计[1] + 1 }
函数 链表_记录遍历() { _链表_统计[2] = _链表_统计[2] + 1 }

函数 链表_使用模式() {
    如果 (_链表_统计[2] > _链表_统计[0] * 3) { 返回 "遍历密集(考虑数组)"
}
 如果 (_链表_统计[0] > _链表_统计[2] * 3) { 返回 "插入密集(链表适合)" }
 返回 "均衡使用"
}

函数 链表_重置() { _链表_统计[0] = 0 _链表_统计[1] = 0 _链表_统计[2] = 0 }

函数 双链_第N个(链表, n) { 定义 可变 当前 = 链表[1]
 定义 可变 i = 0
 当 (当前 >= 0 且 i < n) {
 当前 = 链表[0][当前][2]
 i = i + 1
 }
 如果 (当前 < 0) { 返回 空 }
 返回 链表[0][当前][0]
}

函数 双链_长度(链表) { 返回 链表[3] }

导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../执行/同步帧调.nova")
导入("../中枢/创建甲.nova")

定义 操作_点击 = 1
定义 操作_双击 = 2
定义 操作_输入 = 3
定义 操作_滚动 = 4
定义 操作_拖拽 = 5
定义 操作_按键 = 6
定义 操作_截图 = 7
定义 最大操作历史 = 128

结构 界面操作记录 {
    类型,
    目标哈希,
    横坐标,
    纵坐标,
    参数,
    时间戳,
    结果,
}

定义 可变 操作历史 = []
定义 可变 历史数 = 0
定义 可变 总操作 = 0
定义 可变 成功操作 = 0
定义 可变 失败操作 = 0
定义 可变 超时操作 = 0

函数 界面_初始化() {
    操作历史 = []
    历史数 = 0
}

函数 界面_记录操作(类型, 目标哈希, 横, 纵, 参数, 结果) {
    总操作 = 总操作 + 1
    如果 (结果 == 0) { 成功操作 = 成功操作 + 1 }
    否则 { 失败操作 = 失败操作 + 1 }
    如果 (历史数 >= 最大操作历史) {
        定义 可变 序号 = 0
        当 (序号 < 历史数 - 1) {
            操作历史[序号] = 操作历史[序号 + 1]
            序号 = 序号 + 1
        }
        历史数 = 历史数 - 1
    }
    定义 记录 = 界面操作记录 {}
    记录.类型 = 类型
    记录.目标哈希 = 目标哈希
    记录.横坐标 = 横
    记录.纵坐标 = 纵
    记录.参数 = 参数
    记录.时间戳 = 平台_获取高精度时间()
    记录.结果 = 结果
    追加(操作历史, 记录)
    历史数 = 历史数 + 1
}

函数 界面_点击(目标哈希, 横, 纵) {
    定义 结果 = 界面_模拟点击(横, 纵)
    界面_记录操作(操作_点击, 目标哈希, 横, 纵, 0, 结果)
    返回 结果
}

函数 界面_双击(目标哈希, 横, 纵) {
    界面_模拟点击(横, 纵)
    定义 结果 = 界面_模拟点击(横, 纵)
    界面_记录操作(操作_双击, 目标哈希, 横, 纵, 0, 结果)
    返回 结果
}

函数 界面_输入文本(目标哈希, 横, 纵, 文本哈希) {
    界面_模拟点击(横, 纵)
    定义 结果 = 界面_模拟输入(文本哈希)
    界面_记录操作(操作_输入, 目标哈希, 横, 纵, 文本哈希, 结果)
    返回 结果
}

函数 界面_滚动(横, 纵, 方向, 距离) {
    定义 结果 = 界面_模拟滚动(横, 纵, 方向, 距离)
    界面_记录操作(操作_滚动, 0, 横, 纵, 距离, 结果)
    返回 结果
}

函数 界面_拖拽(起横, 起纵, 终横, 终纵) {
    定义 结果 = 界面_模拟拖拽(起横, 起纵, 终横, 终纵)
    界面_记录操作(操作_拖拽, 0, 起横, 起纵, (终横 << 16) | 终纵, 结果)
    返回 结果
}

函数 界面_按键(键码) {
    定义 结果 = 界面_模拟按键(键码)
    界面_记录操作(操作_按键, 0, 0, 0, 键码, 结果)
    返回 结果
}

函数 界面_截图() {
    定义 帧 = 视觉设备_捕获帧(0)
    界面_记录操作(操作_截图, 0, 0, 0, 0, 帧 != 0)
    返回 帧
}

函数 界面_等待元素(目标哈希, 超时微秒) {
    定义 可变 已等待 = 0
    定义 可变 间隔 = 50000
    定义 最大间隔 = 500000
    当 (已等待 < 超时微秒) {
        平台_睡眠微秒(间隔)
        已等待 = 已等待 + 间隔
        如果 (间隔 < 最大间隔) { 间隔 = 间隔 * 2 }
        如果 (间隔 > 最大间隔) { 间隔 = 最大间隔 }
    }
    超时操作 = 超时操作 + 1
    返回 错误_超时
}

函数 界面_模拟点击(横, 纵) {
    // 派发mousedown+mouseup+click事件序列
    总操作 = 总操作 + 1
    定义 目标 = 命中测试(横, 纵)
    如果 (目标 == 空) { 失败操作 = 失败操作 + 1; 返回 -1 }
    派发鼠标事件(目标, "mousedown", 横, 纵)
    派发鼠标事件(目标, "mouseup", 横, 纵)
    派发鼠标事件(目标, "click", 横, 纵)
    成功操作 = 成功操作 + 1
    返回 0
}
函数 界面_模拟输入(文本哈希) {
    // 向当前焦点元素派发input事件
    总操作 = 总操作 + 1
    定义 焦点 = 获取当前焦点()
    如果 (焦点 == 空) { 失败操作 = 失败操作 + 1; 返回 -1 }
    派发输入事件(焦点, 文本哈希)
    成功操作 = 成功操作 + 1
    返回 0
}
函数 界面_模拟滚动(横, 纵, 方向, 距离) {
    // 派发wheel事件
    总操作 = 总操作 + 1
    定义 目标 = 命中测试(横, 纵)
    如果 (目标 == 空) { 失败操作 = 失败操作 + 1; 返回 -1 }
    派发滚轮事件(目标, 方向, 距离)
    成功操作 = 成功操作 + 1
    返回 0
}
函数 界面_模拟拖拽(起横, 起纵, 终横, 终纵) {
    // 派发dragstart+drag+dragend事件序列
    总操作 = 总操作 + 1
    定义 起点 = 命中测试(起横, 起纵)
    定义 终点 = 命中测试(终横, 终纵)
    如果 (起点 == 空) { 失败操作 = 失败操作 + 1; 返回 -1 }
    派发拖拽事件(起点, "dragstart", 起横, 起纵)
    派发拖拽事件(起点, "drag", 终横, 终纵)
    如果 (终点 != 空) { 派发拖拽事件(终点, "drop", 终横, 终纵) }
    派发拖拽事件(起点, "dragend", 终横, 终纵)
    成功操作 = 成功操作 + 1
    返回 0
}
函数 界面_模拟按键(键码) {
    // 派发keydown+keypress+keyup事件序列
    总操作 = 总操作 + 1
    定义 焦点 = 获取当前焦点()
    如果 (焦点 == 空) { 失败操作 = 失败操作 + 1; 返回 -1 }
    派发键盘事件(焦点, "keydown", 键码)
    派发键盘事件(焦点, "keypress", 键码)
    派发键盘事件(焦点, "keyup", 键码)
    成功操作 = 成功操作 + 1
    返回 0
}

函数 界面_成功率() {
    如果 (总操作 == 0) { 返回 0 }
    返回 成功操作 * 100 / 总操作
}

函数 界面_完整统计() {
    返回 [总操作, 成功操作, 失败操作, 超时操作, 界面_成功率()]
}

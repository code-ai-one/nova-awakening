// 龙壳 — 脚本引擎 (深度吸收bash脚本执行)
// 核心设计:
//   1. 逐行读取脚本文件, 跳过注释和空行
//   2. 变量替换: $VAR, ${VAR}, ${VAR:-default}
//   3. 特殊变量: $?, $#, $0, $1-$9, $$, $!
//   4. 条件执行: && (成功后) 和 || (失败后)
//   5. shebang: #!/bin/龙壳 检测

定义 可变 脚本_最后退出码 = 0
定义 可变 脚本_参数 = []
定义 可变 脚本_当前行号 = 0
定义 可变 脚本_当前文件 = ""

// 脚本执行

函数 脚本_执行(文件路径) {
    定义 内容 = sys_read_file(文件路径)
    如果 (内容 == 空) {
        打印行("龙壳: 无法读取脚本: " + 文件路径)
        返回 错误_不存在
    }

    脚本_当前文件 = 文件路径
    脚本_当前行号 = 0

    // 按行分割
    定义 行列表 = 字符串_分割(内容, "\n")
    定义 可变 i = 0
    当 (i < 计数(行列表)) {
        脚本_当前行号 = i + 1
        定义 行 = 字符串_去首尾空白(行列表[i])

        // 跳过空行和注释
        如果 (字符串长度(行) == 0 || 字符串取字符(行, 0) == "#") {
            i = i + 1
            继续
        }

        // 变量替换
        定义 展开行 = 脚本_解析变量(行)

        // 条件执行: cmd1 && cmd2
        如果 (字符串包含(展开行, " && ")) {
            定义 部分 = 字符串_分割(展开行, " && ")
            定义 可变 j = 0
            当 (j < 计数(部分)) {
                脚本_最后退出码 = 执行_终端命令(字符串_去首尾空白(部分[j]))
                如果 (脚本_最后退出码 != 0) { 中断 }
                j = j + 1
            }
        } 否则 如果 (字符串包含(展开行, " || ")) {
            定义 部分 = 字符串_分割(展开行, " || ")
            定义 可变 j = 0
            当 (j < 计数(部分)) {
                脚本_最后退出码 = 执行_终端命令(字符串_去首尾空白(部分[j]))
                如果 (脚本_最后退出码 == 0) { 中断 }
                j = j + 1
            }
        } 否则 {
            脚本_最后退出码 = 执行_终端命令(展开行)
        }

        i = i + 1
    }

    返回 脚本_最后退出码
}

函数 脚本_执行_带参数(文件路径, 参数) {
    脚本_参数 = 参数
    返回 脚本_执行(文件路径)
}

// 变量替换 

函数 脚本_解析变量(行) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 字符串长度(行)) {
        定义 c = 字符串取字符(行, i)

        如果 (c == "$" && i + 1 < 字符串长度(行)) {
            定义 下一个 = 字符串取字符(行, i + 1)

            // $? — 上一个命令的退出码
            如果 (下一个 == "?") {
                结果 = 结果 + 整数转字符串(脚本_最后退出码)
                i = i + 2
                继续
            }
            // $$ — 当前PID
            如果 (下一个 == "$") {
                结果 = 结果 + 整数转字符串(sys_getpid())
                i = i + 2
                继续
            }
            // $# — 参数个数
            如果 (下一个 == "#") {
                结果 = 结果 + 整数转字符串(计数(脚本_参数))
                i = i + 2
                继续
            }
            // $0-$9 — 位置参数
            如果 (下一个 >= "0" && 下一个 <= "9") {
                定义 索引 = 编码(下一个) - 48
                如果 (索引 < 计数(脚本_参数)) {
                    结果 = 结果 + 脚本_参数[索引]
                }
                i = i + 2
                继续
            }
            // ${VAR} 或 ${VAR:-default}
            如果 (下一个 == "{") {
                定义 可变 名称 = ""
                i = i + 2
                当 (i < 字符串长度(行) && 字符串取字符(行, i) != "}") {
                    名称 = 名称 + 字符串取字符(行, i)
                    i = i + 1
                }
                如果 (i < 字符串长度(行)) { i = i + 1 }  // 跳过 }
                // 检查:-默认值
                如果 (字符串包含(名称, ":-")) {
                    定义 部分 = 字符串_分割(名称, ":-")
                    定义 值 = 环境变量_获取(部分[0])
                    如果 (值 == "" && 计数(部分) > 1) { 值 = 部分[1] }
                    结果 = 结果 + 值
                } 否则 {
                    结果 = 结果 + 环境变量_获取(名称)
                }
                继续
            }
            // $VAR — 普通变量
            定义 可变 名称 = ""
            i = i + 1
            当 (i < 字符串长度(行)) {
                定义 ch = 字符串取字符(行, i)
                如果 ((ch >= "a" && ch <= "z") || (ch >= "A" && ch <= "Z") ||
                    (ch >= "0" && ch <= "9") || ch == "_") {
                    名称 = 名称 + ch
                    i = i + 1
                } 否则 { 中断 }
            }
            结果 = 结果 + 环境变量_获取(名称)
            继续
        }

        结果 = 结果 + c
        i = i + 1
    }
    返回 结果
}

// shebang检测

函数 脚本_是龙壳脚本(文件路径) {
    定义 内容 = sys_read_file(文件路径)
    如果 (内容 == 空) { 返回 假 }
    返回 字符串_开头是(内容, "#!/bin/龙壳") || 字符串_开头是(内容, "#!/usr/bin/env 龙壳")
}

函数 执行_终端命令(命令行) {
    如果 (命令行 == 0) { 返回 -1 }
    打印("[终端] 执行: " + 命令行)
    定义 参数 = [命令行, 0]
    返回 系统调用_execve("/bin/sh", 参数, 0)

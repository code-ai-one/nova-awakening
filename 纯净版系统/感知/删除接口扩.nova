函数 图绘2_fenceSync() {
    返回 GL_创建同步(GL_SYNC_GPU_COMMANDS_COMPLETE, 0)
}

函数 图绘2_deleteSync(sync) {
    如果 (sync == 0) { 返回 }
    GL_删除同步(sync)
}

函数 图绘2_clientWaitSync(sync, flags, timeout) {
    如果 (sync == 0) { 返回 GL_WAIT_FAILED }
    返回 GL_客户端等待同步(sync, flags, timeout)
}

函数 图绘2_getSyncParameter(sync, pname) {

// §5 XSS防护 — 跨站脚本攻击防护
// XSS类型:
//   ① 反射型: URL参数被注入到页面HTML中
//   ② 存储型: 恶意脚本被存入数据库, 所有用户受影响
//   ③ DOM型: JS代码操作DOM时引入恶意内容
// 防护手段:
//   ① CSP script-src (上面已实现)
//   ② Trusted Types — 限制危险DOM操作只接受安全类型
//   ③ 输出编码 — HTML/JS/URL上下文的正确转义

// HTML转义: 防止XSS注入

函数 XSS_HTML转义(输入) {
    // < → &lt;  > → &gt;  & → &amp;  " → &quot;  ' → &#x27;
    定义 长度 = 字节长度(输入)
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 长度) {
        定义 ch = 字节取(输入, i)
        如果 (ch == 60) { 结果 = 字符串拼接(结果, "&lt;") }      // <
        否则 如果 (ch == 62) { 结果 = 字符串拼接(结果, "&gt;") } // >
        否则 如果 (ch == 38) { 结果 = 字符串拼接(结果, "&amp;") } // &
        否则 如果 (ch == 34) { 结果 = 字符串拼接(结果, "&quot;") } // "
        否则 如果 (ch == 39) { 结果 = 字符串拼接(结果, "&#x27;") } // '
        否则 { 结果 = 字符串拼接(结果, 字符(ch)) }
        i = i + 1
    }
    返回 结果
}

// Trusted Types: 限制innerHTML等只接受TrustedHTML
结构 TrustedHTML {
    内容,    // u64 已验证安全的HTML字符串
    策略名,    // u64 创建此值的策略名称
}

函数 TrustedTypes_创建HTML(策略名, 不可信输入) {
    // 通过策略函数清洗输入
    定义 安全内容 = XSS_HTML转义(不可信输入)
    定义 trusted = 堆_分配(TrustedHTML)
    trusted.内容 = 安全内容
    trusted.策略名 = 策略名
    返回 trusted
}

// §6 SameSite Cookie策略

定义 SameSite_None    = 0     // 跨站发送(需要Secure)
定义 SameSite_Lax     = 1     // 顶级导航GET时跨站发送
定义 SameSite_Strict  = 2     // 仅同站发送

// 判断Cookie是否应随请求发送
函数 Cookie_应该发送(cookie_sameSite, 请求源, 目标源, 是顶级导航, 方法) {
    如果 (cookie_sameSite == SameSite_None) {
        返回 真    // Secure cookie需HTTPS(当前假设安全上下文)
    }
    如果 (cookie_sameSite == SameSite_Strict) {
        返回 Origin_同站(请求源, 目标源)
    }
    如果 (cookie_sameSite == SameSite_Lax) {
        如果 (Origin_同站(请求源, 目标源)) { 返回 真 }
        // 跨站但是顶级导航GET → 允许(Lax)
        如果 (是顶级导航 && 字符串_相等(方法, "GET")) { 返回 真 }
        返回 假
    }
    返回 假
}

// §7 站点隔离(Site Isolation) — 进程级安全边界
// 传统方案: 每个站点运行在独立渲染进程
// 即使渲染进程被攻破(Spectre/Meltdown), 也无法读取其他站点数据
// 隔离单位: eTLD+1 (有效顶级域名+1级)
//   a.example.com 和 b.example.com → 同一进程
//   example.com 和 evil.com → 不同进程

结构 SiteIsolation {
    站点进程映射,    // u64 哈希Map<site_key → process_id>
    映射大小,
    映射容量,
}

函数 SiteIsolation_获取进程(隔离, 站点URL) {
    定义 站点源 = Origin_从URL(站点URL)
    定义 站点键 = 提取eTLD加1(站点源.主机)
    定义 键哈希 = 字符串_哈希(站点键)

    // 查找已有映射
    定义 可变 i = 0
    当 (i < 隔离.映射大小) {
        定义 偏移 = 隔离.站点进程映射 + i * 16
        如果 (内存_读32(偏移) == 键哈希) {
            返回 内存_读64(偏移 + 8)    // 进程ID
        }
        i = i + 1
    }

    // 新站点 → 分配新进程
    定义 新进程 = 平台_创建渲染进程()
    如果 (隔离.映射大小 < 隔离.映射容量) {
        定义 偏移 = 隔离.站点进程映射 + 隔离.映射大小 * 16
        内存_写32(偏移, 键哈希)
        内存_写64(偏移 + 8, 新进程)
        隔离.映射大小 = 隔离.映射大小 + 1
    }
    返回 新进程
}

导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("./云端桥接.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../外联/地址解析辅.nova")
导入("../标准/原生列表.nova")
导入("../中枢/整数转字符串.nova")

定义 CLAUDE_接口端点 = "https://api.anthropic.com/v1/messages"
定义 CLAUDE_默认模型 = "claude-sonnet-4-20250514"
定义 CLAUDE_最大令牌 = 4096
定义 CLAUDE_默认温度 = 70
定义 CLAUDE_最大重试 = 3
定义 CLAUDE_重试延迟 = 1000
定义 CLAUDE_超时ms = 60000
定义 CLAUDE_API版本 = "2023-06-01"

结构 Claude适配器 {
    桥接,
    模型,
    最大令牌,
    温度,
    系统提示,
    对话历史,
    最大历史轮数,
    总请求数,
    总令牌数,
    总失败数,
    最后错误,
    流式回调,
}

定义 可变 claude_全局请求数 = 0
定义 可变 claude_全局令牌数 = 0

函数 Claude_创建(密钥) {
    返回 Claude适配器 {
        桥接: 云端桥接_创建(密钥, CLAUDE_接口端点, "claude"),
        模型: CLAUDE_默认模型,
        最大令牌: CLAUDE_最大令牌,
        温度: CLAUDE_默认温度,
        系统提示: "",
        对话历史: [],
        最大历史轮数: 20,
        总请求数: 0,
        总令牌数: 0,
        总失败数: 0,
        最后错误: "",
        流式回调: 空
    }
}

函数 Claude_设置模型(适配器, 模型) { 适配器.模型 = 模型 }
函数 Claude_设置温度(适配器, 温度) { 适配器.温度 = 温度 }
函数 Claude_设置最大令牌(适配器, 令牌数) { 适配器.最大令牌 = 令牌数 }
函数 Claude_设置系统提示(适配器, 提示) { 适配器.系统提示 = 提示 }
函数 Claude_设置流式回调(适配器, 回调) { 适配器.流式回调 = 回调 }

函数 Claude_清空历史(适配器) {
    适配器.对话历史 = []
}

函数 Claude_添加历史(适配器, 角色, 内容) {
    追加(适配器.对话历史, [角色, 内容])
    如果 (计数(适配器.对话历史) > 适配器.最大历史轮数 * 2) {
        适配器.对话历史 = 列表_切片(适配器.对话历史, 2, 计数(适配器.对话历史))
    }
}

函数 Claude_转义字符串(文本) {
    如果 (文本 == 空) { 返回 "" }
    定义 可变 部件 = []
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 字符 = 字符串取字符(文本, i)
        如果 (字符 == "\"") { 追加(部件, "\\\"" })
        否则如果 (字符 == "\\") { 追加(部件, "\\\\" })
        否则如果 (字符 == "\n") { 追加(部件, "\\n" })
        否则如果 (字符 == "\t") { 追加(部件, "\\t" })
        否则 { 追加(部件, 字符 })
        i = i + 1
    }
    返回 字符串_连接列表(部件, "")
}

函数 Claude_构建消息序列(消息列表) {
    定义 可变 序列 = "["
    定义 可变 i = 0
    当 (i < 计数(消息列表)) {
        如果 (i > 0) { 序列 = 序列 + "," }
        定义 消息 = 消息列表[i]
        定义 角色 = Claude_转义字符串(消息[0])
        定义 内容 = Claude_转义字符串(消息[1])
        序列 = 序列 + "{\"role\":\"" + 角色 + "\",\"content\":\"" + 内容 + "\"}"
        i = i + 1
    }
    序列 = 序列 + "]"
    返回 序列
}

函数 Claude_构建请求体(适配器, 消息列表, 流式) {
    定义 消息序列 = Claude_构建消息序列(消息列表)
    定义 温度值 = 整数转字符串(适配器.温度 / 100) + "." + 整数转字符串(适配器.温度 % 100)
    定义 可变 请求体 = "{\"model\":\"" + 适配器.模型 +
        "\",\"max_tokens\":" + 整数转字符串(适配器.最大令牌) +
        ",\"temperature\":" + 温度值 +
        ",\"messages\":" + 消息序列
    如果 (适配器.系统提示 != "") {
        请求体 = 请求体 + ",\"system\":\"" + Claude_转义字符串(适配器.系统提示) + "\""
    }
    如果 (流式) { 请求体 = 请求体 + ",\"stream\":true" }
    请求体 = 请求体 + "}"
    返回 请求体
}

函数 Claude_带重试请求(适配器, 请求体) {
    定义 可变 重试 = 0
    定义 可变 最后结果 = 空
    当 (重试 <= CLAUDE_最大重试) {
        最后结果 = 云端桥接_推理后援(适配器.桥接, 请求体, "")
        如果 (最后结果 != 空) {
            定义 错误码 = Claude_检查错误(最后结果)
            如果 (错误码 == 0) { 返回 最后结果 }
            如果 (错误码 == 429 || 错误码 == 529) {
                定义 延迟 = CLAUDE_重试延迟 * (1 << 重试)
                等待_毫秒(延迟)
                重试 = 重试 + 1
                继续
            }
            适配器.最后错误 = "API错误: " + 整数转字符串(错误码)
            适配器.总失败数 = 适配器.总失败数 + 1
            返回 最后结果
        }
        重试 = 重试 + 1
    }
    适配器.最后错误 = "超过最大重试次数"
    适配器.总失败数 = 适配器.总失败数 + 1
    返回 最后结果
}

函数 Claude_检查错误(响应) {
    如果 (响应 == 空) { 返回 -1 }
    定义 位置 = 字符串查找(响应, "\"error\"")
    如果 (位置 < 0) { 返回 0 }
    定义 状态位 = 字符串查找(响应, "\"status\":")
    如果 (状态位 >= 0) {
        定义 码起始 = 状态位 + 9
        定义 码文本 = 字符串子串(响应, 码起始, 码起始 + 3)
        返回 字符串转整数(码文本)
    }
    返回 -1
}

函数 Claude_对话(适配器, 消息列表) {
    适配器.总请求数 = 适配器.总请求数 + 1
    claude_全局请求数 = claude_全局请求数 + 1
    定义 请求体 = Claude_构建请求体(适配器, 消息列表, 假)
    返回 Claude_带重试请求(适配器, 请求体)
}

函数 Claude_补全(适配器, 提示) {
    返回 Claude_对话(适配器, [["user", 提示]])
}

函数 Claude_带系统提示(适配器, 系统提示, 用户消息) {
    定义 旧提示 = 适配器.系统提示
    适配器.系统提示 = 系统提示
    定义 结果 = Claude_对话(适配器, [["user", 用户消息]])
    适配器.系统提示 = 旧提示
    返回 结果
}

函数 Claude_多轮对话(适配器, 用户消息) {
    Claude_添加历史(适配器, "user", 用户消息)
    定义 结果 = Claude_对话(适配器, 适配器.对话历史)
    如果 (结果 != 空) {
        定义 回复文本 = Claude_解析响应(结果)
        如果 (回复文本 != 空) {
            Claude_添加历史(适配器, "assistant", 回复文本)
        }
        定义 令牌 = Claude_解析令牌用量(结果)
        适配器.总令牌数 = 适配器.总令牌数 + 令牌
        claude_全局令牌数 = claude_全局令牌数 + 令牌
    }
    返回 结果
}

函数 Claude_解析响应(响应) {
    如果 (响应 == 空) { 返回 空 }
    定义 位置 = 字符串查找(响应, "\"text\":\"")
    如果 (位置 < 0) { 返回 响应 }
    定义 起始 = 位置 + 8
    定义 可变 结束 = 起始
    定义 可变 转义 = 假
    当 (结束 < 字符串长度(响应)) {
        定义 字符 = 字符串取字符(响应, 结束)
        如果 (转义) { 转义 = 假; 结束 = 结束 + 1; 继续 }
        如果 (字符 == "\\") { 转义 = 真; 结束 = 结束 + 1; 继续 }
        如果 (字符 == "\"") { 跳出 }
        结束 = 结束 + 1
    }
    返回 字符串子串(响应, 起始, 结束)
}

函数 Claude_解析令牌用量(响应) {
    如果 (响应 == 空) { 返回 0 }
    定义 位置 = 字符串查找(响应, "\"output_tokens\":")
    如果 (位置 < 0) { 返回 0 }
    定义 起始 = 位置 + 16
    定义 可变 结束 = 起始
    当 (结束 < 字符串长度(响应)) {
        定义 字符 = 字符串取字符(响应, 结束)
        如果 (字符 < "0" || 字符 > "9") { 跳出 }
        结束 = 结束 + 1
    }
    返回 字符串转整数(字符串子串(响应, 起始, 结束))
}

函数 Claude_解析停止原因(响应) {
    如果 (响应 == 空) { 返回 "unknown" }
    定义 位置 = 字符串查找(响应, "\"stop_reason\":\"")
    如果 (位置 < 0) { 返回 "unknown" }
    定义 起始 = 位置 + 15
    定义 结束 = 字符串查找(字符串子串(响应, 起始, 字符串长度(响应)), "\"")
    如果 (结束 < 0) { 返回 "unknown" }
    返回 字符串子串(响应, 起始, 起始 + 结束)
}

函数 Claude_统计(适配器) {
    返回 [适配器.总请求数, 适配器.总令牌数, 适配器.总失败数]
}

函数 Claude_全局统计() {
    返回 [claude_全局请求数, claude_全局令牌数]
}

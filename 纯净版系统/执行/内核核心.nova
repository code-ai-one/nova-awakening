    档.当前地址 = 地址
    档.最近导航 = 地址
    档.事件数 = 档.事件数 + 1
}

函数 内核核心_处理输入(档, 任务) {
    事件循环_处理用户输入(任务)
    档.事件数 = 档.事件数 + 1
    档.最近输入 = 任务
}

函数 内核核心_处理系统事件(档, 任务) {
    事件循环_处理系统事件(任务)
    档.事件数 = 档.事件数 + 1
}

函数 内核核心_处理AI回调(档, 任务) {
    事件循环_处理AI回调(任务)
    档.事件数 = 档.事件数 + 1
}

函数 内核核心_单次迭代(档) {
    事件循环_单次迭代()
    事件循环_检查定时器()
    档.事件数 = 档.事件数 + 1
}

函数 内核核心_事件统计(档) {
    定义 统计 = 事件循环_统计()
    档.最近摘要 = 统计
    返回 统计
}

函数 内核核心_脚本初始化(档) {
    JS_初始化()
    JS_注入全局接口()
    表达式_初始化()
    档.脚本数 = 档.脚本数 + 1
}

函数 内核核心_执行脚本(档, 代码) {
    定义 结果 = JS_执行脚本(代码)
    档.脚本数 = 档.脚本数 + 1
    档.最近脚本 = 代码
    档.最近摘要 = 结果
    返回 结果
}

函数 内核核心_执行日志(档, 语句) {
    JS_执行console_log(语句)
    档.脚本数 = 档.脚本数 + 1
    档.最近脚本 = 语句
}

函数 内核核心_执行取节点(档, 语句) {
    定义 结果 = JS_执行get元素ById(语句)
    档.脚本数 = 档.脚本数 + 1
    档.最近脚本 = 语句
    档.最近节点 = 结果
    返回 结果
}

函数 内核核心_设变量(档, 名称, 值) {
    JS_设置全局变量(名称, 值)
    档.脚本数 = 档.脚本数 + 1
}

函数 内核核心_取变量(档, 名称) {
    定义 值 = JS_查找变量(名称)
    档.脚本数 = 档.脚本数 + 1
    返回 值
}

函数 内核核心_表达式数字(档, 值) {
    定义 结果 = 表达式_创建数字(值)
    档.最近表达式 = 结果
    档.脚本数 = 档.脚本数 + 1
    返回 结果
}

函数 内核核心_表达式字串(档, 哈希) {
    定义 结果 = 表达式_创建字串(哈希)
    档.最近表达式 = 结果
    档.脚本数 = 档.脚本数 + 1
    返回 结果
}

函数 内核核心_表达式布尔(档, 值) {
    定义 结果 = 表达式_创建布尔(值)
    档.最近表达式 = 结果
    档.脚本数 = 档.脚本数 + 1
    返回 结果
}

函数 内核核心_表达式加法(档, 左, 右) {
    定义 结果 = 表达式_加法(左, 右)
    档.最近表达式 = 结果
    档.脚本数 = 档.脚本数 + 1
    返回 结果
}

函数 内核核心_表达式比较(档, 左, 右) {
    定义 结果 = 表达式_等于(左, 右)
    档.最近表达式 = 结果
    档.脚本数 = 档.脚本数 + 1
    返回 结果
}

函数 内核核心_表达式统计(档) {
    定义 统计 = 表达式_完整统计()
    档.最近摘要 = 统计
    返回 统计
}

函数 内核核心_适配自检(档) {
    定义 结果 = 内核适配_自检(档.当前适配档)
    档.适配数 = 档.适配数 + 1
    档.最近摘要 = 结果
    返回 结果
}

函数 内核核心_页面管线(档, 地址, 页面源码, 样式源码, 脚本源码) {
    如果 (!档.初始化完成) { 内核核心_初始化(档) }
    内核核心_解析页面(档, 页面源码, 地址)
    内核核心_加载默认样式(档)
    如果 (样式源码 != "") {
        内核核心_加载样式(档, 样式源码, 地址)
    }
    内核核心_全树样式(档)
    内核核心_构建渲染树(档)
    内核核心_布局(档)
    内核核心_绘制(档)
    如果 (脚本源码 != "") {
        内核核心_执行脚本(档, 脚本源码)
    }
    内核核心_导航(档, 地址)
    档.最近摘要 = 内核核心_摘要(档)
    返回 档.最近摘要
}

函数 内核核心_刷新页面(档) {
    内核核心_全树样式(档)
    内核核心_布局(档)
    内核核心_绘制(档)
    档.渲染数 = 档.渲染数 + 1
}

函数 内核核心_统一输入(档, 类型, 数据) {
    定义 任务 = [类型, 数据]
    如果 (类型 == "输入") {
        内核核心_处理输入(档, 任务)
    } 否则 如果 (类型 == "系统") {
        内核核心_处理系统事件(档, 任务)
    } 否则 {
        内核核心_处理AI回调(档, 任务)
    }
    档.最近输入 = 任务
    返回 任务
}

函数 内核核心_命中页面(档, x, y) {
    定义 节点 = 内核核心_命中测试(档, x, y)
    如果 (节点 != 空 && 节点 != 0) {
        档.最近命中 = 节点
    } 否则 {
        档.失败数 = 档.失败数 + 1
        核心总失败 = 核心总失败 + 1
    }
    返回 节点
}

函数 内核核心_摘要(档) {
    返回 核心摘要 {
        名称: 档.名称,
        地址: 档.当前地址,
        文档数: 档.文档数,
        样式数: 档.样式数,
        渲染数: 档.渲染数,
        事件数: 档.事件数,
        脚本数: 档.脚本数,
        适配数: 档.适配数,
        命中数: 档.命中数,
        失败数: 档.失败数,
        健康: 内核核心_健康(档)
    }
}

函数 内核核心_状态串(档) {
    返回 字符串拼接(
        "核心[",
        字符串拼接(
            档.名称,
            字符串拼接(
                "] 文档=",
                字符串拼接(
                    整数转字符串(档.文档数),
                    字符串拼接(
                        " 渲染=",
                        字符串拼接(
                            整数转字符串(档.渲染数),
                            字符串拼接(
                                " 脚本=",
                                整数转字符串(档.脚本数)
                            )
                        )
                    )
                )
            )
        )
    )
}

函数 内核核心_健康(档) {
    如果 (!档.初始化完成) { 返回 "待初始化" }
    如果 (档.失败数 > 0) { 返回 "退化" }
    如果 (档.当前文档 == 0) { 返回 "待载入" }
    返回 "运行"
}

函数 内核核心_自检(档) {
    定义 页面 = "<html><body><div id='app'>觉醒</div></body></html>"
    定义 样式 = "body { color: #fff; background: #111; } #app { width: 100vw; }"
    定义 脚本 = "console.log('core');"
    内核核心_页面管线(档, "nova://core", 页面, 样式, 脚本)
    内核核心_查ID(档, 档.当前文档, "app")
    内核核心_命中页面(档, 12, 12)
    内核核心_单次迭代(档)
    内核核心_适配自检(档)
    档.健康 = 内核核心_健康(档)
    返回 档.健康
}

函数 内核核心_按名查找(名称) {
    定义 可变 i = 0
    当 (i < 计数(核心账本)) {
        如果 (核心账本[i].名称 == 名称) { 返回 核心账本[i] }
        i = i + 1
    }
    返回 0
}

函数 内核核心_最近摘要(档) { 返回 档.最近摘要 }
函数 内核核心_最近节点(档) { 返回 档.最近节点 }
函数 内核核心_最近命中(档) { 返回 档.最近命中 }
函数 内核核心_最近脚本(档) { 返回 档.最近脚本 }
函数 内核核心_账本数() { 返回 计数(核心账本) }

函数 内核核心_全局统计() {
    返回 [
        核心建数,
        核心总执行,
        核心总命中,
        核心总失败
    ]
}

函数 内核核心_示例流程() {
    定义 档 = 内核核心_创建("内核核心", 1366, 768)
    定义 页面 = "<html><body><main id='root'><h1>觉醒</h1><p>系统即浏览器</p></main></body></html>"
    定义 样式 = "main { width: 80vw; margin: 0 auto; } h1 { color: #fafafa; }"
    定义 脚本 = "console.log('awake');"
    内核核心_页面管线(档, "nova://awake", 页面, 样式, 脚本)
    内核核心_统一输入(档, "输入", ["点击", 1])
    内核核心_滚动(档, 0, 120)
    内核核心_刷新页面(档)
    内核核心_自检(档)
    返回 内核核心_摘要(档)
}

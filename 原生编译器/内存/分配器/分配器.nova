导入("../GC/分代GC.nova")
导入("../../平台/系统调用/系统调用封装.nova")
导入("../../标准库/基础.nova")
导入("../../标准库/系统/内存池.nova")
导入("../../运行时/内存/内存池.nova")
导入("../../运行时/内存管理/内存分配.nova")

// Nova · 内存层 · 统一内存分配器
// 整合内存池+GC+JIT代码缓冲的统一分配调度
// 对接平台层系统调用，屏蔽OS差异

// 分配类型
定义 分配_普通 = 0
定义 分配_JIT = 1
定义 分配_固定 = 2
定义 分配_临时 = 3
定义 分配_Slab = 4
定义 分配_伙伴 = 5

// 全局统计
定义 可变 _全局_分配次数 = 0
定义 可变 _全局_释放次数 = 0
定义 可变 _全局_峰值内存 = 0
定义 可变 _全局_当前内存 = 0
定义 可变 _全局_分配历史 = []

// 分配器实例
函数 分配器_创建() { 定义 池 = 内存池_创建()
 定义 gc = 分代GC_创建()
 返回 [池, gc, 0, [], [0,0,0,0], 0, []]
}

函数 分配器_内存池(alloc) { 返回 alloc[0] }
函数 分配器_GC(alloc) { 返回 alloc[1] }

// 统一分配入口
函数 分配器_分配(alloc, 大小, 类型) {
 alloc[2] = alloc[2] + 大小
 _全局_分配次数 = _全局_分配次数 + 1
 _全局_当前内存 = _全局_当前内存 + 大小
 如果 (_全局_当前内存 > _全局_峰值内存) { _全局_峰值内存 = _全局_当前内存 }
 追加(_全局_分配历史, [大小, 类型])
 如果 (计数(_全局_分配历史) > 1000) { _全局_分配历史 = [] }

 如果 (类型 == 分配_JIT) { 定义 内存 = 平台_可执行内存(0, 大小)
 追加(alloc[4], [内存, 大小])
 alloc[5][1] = alloc[5][1] + 1
 返回 内存
 }

 如果 (类型 == 分配_临时) {
 alloc[5][2] = alloc[5][2] + 1
 返回 内存池_分配(alloc[0], 大小)
 }

 如果 (类型 == 分配_固定) {
 alloc[5][3] = alloc[5][3] + 1
 返回 平台_分配内存(大小)
 }

 如果 (类型 == 分配_Slab) { 返回 Slab_分配(大小)
 }

 如果 (类型 == 分配_伙伴) { 返回 伙伴_分配(大小, 0)
 }

 alloc[5][0] = alloc[5][0] + 1
 返回 分代GC_分配(alloc[1], GC类型_整数, 大小, 空)
}

// 统一释放
函数 分配器_释放(alloc, 指针, 大小, 类型) {
 alloc[3] = alloc[3] + 大小
 _全局_释放次数 = _全局_释放次数 + 1
 _全局_当前内存 = _全局_当前内存 - 大小
 如果 (_全局_当前内存 < 0) { _全局_当前内存 = 0 }

 如果 (类型 == 分配_JIT) {
 平台_释放内存(指针, 大小)
 返回
 }
 如果 (类型 == 分配_临时) {
 内存池_回收(alloc[0], 指针, 大小)
 返回
 }
 如果 (类型 == 分配_Slab) {
 Slab_释放(指针, 大小)
 返回
 }
 如果 (类型 == 分配_伙伴) {
 伙伴_释放(指针, 大小)
 返回
 }
}

// GC触发
函数 分配器_触发GC(alloc) {
 分代GC_Minor(alloc[1])
}

函数 分配器_全量GC(alloc) {
 分代GC_Minor(alloc[1])
 分代GC_Major(alloc[1])
}

// 统计
// Slab分配器
// 固定大小对象的高效分配，适合频繁创建/销毁的同类对象

定义 可变 _slab_池 = []
定义 可变 _slab_类别数 = 0

函数 Slab_初始化() { _slab_池 = []
 _slab_类别数 = 0
 定义 可变 大小 = 8
 当 (大小 <= 4096) {
 追加(_slab_池, [大小, [],])
 _slab_类别数 = _slab_类别数 + 1
 大小 = 大小 * 2
 }
}

函数 Slab_找类别(大小) { 定义 可变 i = 0
 当 (i < _slab_类别数) { 如果 (_slab_池[i][0] >= 大小) { 返回 i }
 i = i + 1
 }
 返回 -1
}

函数 分配器_Slab_分配(大小) { 定义 类别 = Slab_找类别(大小)
 如果 (类别 < 0) { 返回 平台_分配内存(大小) }
 定义 空闲列表 = _slab_池[类别][1]
 如果 (计数(空闲列表) > 0) { 定义 块 = 空闲列表[计数(空闲列表) - 1]
 _slab_池[类别][1] = 切片(空闲列表, 0, 计数(空闲列表) - 1)
 _slab_池[类别][2] = _slab_池[类别][2] + 1
 返回 块
 }
 _slab_池[类别][2] = _slab_池[类别][2] + 1
 _slab_池[类别][3] = _slab_池[类别][3] + 1
 返回 平台_分配内存(_slab_池[类别][0])
}

函数 分配器_Slab_释放(指针, 大小) { 定义 类别 = Slab_找类别(大小)
 如果 (类别 < 0) { 返回 }
 追加(_slab_池[类别][1], 指针)
}

// 伙伴系统分配器
// 2的幂大小块管理，支持合并与分裂

定义 伙伴_最小阶 = 4
定义 伙伴_最大阶 = 20
定义 可变 _伙伴_空闲 = []
定义 可变 _伙伴_已分配 = 0

函数 伙伴_初始化() { _伙伴_空闲 = []
 定义 可变 i = 0
 当 (i <= 伙伴_最大阶) { 追加(_伙伴_空闲, []) i = i + 1 }
 _伙伴_已分配 = 0
}

函数 伙伴_阶(大小) { 定义 可变 阶 = 伙伴_最小阶
 定义 可变 块大小 = 1
 定义 可变 i = 0
 当 (i < 伙伴_最小阶) { 块大小 = 块大小 * 2 i = i + 1 }
 当 (块大小 < 大小 且 阶 < 伙伴_最大阶) {
 块大小 = 块大小 * 2
 阶 = 阶 + 1
 }
 返回 阶
}

函数 分配器_伙伴_分配(大小) { 定义 阶 = 伙伴_阶(大小)
 定义 可变 当前阶 = 阶
 当 (当前阶 <= 伙伴_最大阶) { 如果 (计数(_伙伴_空闲[当前阶]) > 0) { 定义 块 = _伙伴_空闲[当前阶][计数(_伙伴_空闲[当前阶]) - 1]
 _伙伴_空闲[当前阶] = 切片(_伙伴_空闲[当前阶], 0, 计数(_伙伴_空闲[当前阶]) - 1)
 定义 可变 分裂阶 = 当前阶
 当 (分裂阶 > 阶) {
 分裂阶 = 分裂阶 - 1
 定义 可变 伙伴大小 = 1
 定义 可变 k = 0
 当 (k < 分裂阶) { 伙伴大小 = 伙伴大小 * 2 k = k + 1 }
 追加(_伙伴_空闲[分裂阶], 块 + 伙伴大小)
 }
 _伙伴_已分配 = _伙伴_已分配 + 1
 返回 块
 }
 当前阶 = 当前阶 + 1
 }
 _伙伴_已分配 = _伙伴_已分配 + 1
 返回 平台_分配内存(大小)
}

函数 分配器_伙伴_释放(指针, 大小) { 定义 阶 = 伙伴_阶(大小)
 追加(_伙伴_空闲[阶], 指针)
}

// 内存对齐工具

函数 分配器_对齐_向上(地址, 对齐) { 定义 余 = 地址 % 对齐
 如果 (余 == 0) { 返回 地址 }
 返回 地址 + (对齐 - 余)
}

函数 对齐_检查(地址, 对齐) { 返回 地址 % 对齐 == 0
}

函数 分配_对齐内存(alloc, 大小, 对齐) { 定义 实际大小 = 大小 + 对齐
 定义 原始 = 分配器_分配(alloc, 实际大小, 分配_普通)
 返回 分配器_对齐_向上(原始, 对齐)
}

// 内存填充/复制

函数 内存_填零(缓冲, 大小) { 定义 可变 i = 0
 当 (i < 大小) { 缓冲[i] = 0 i = i + 1 }
}

函数 内存_填充(缓冲, 大小, 值) { 定义 可变 i = 0
 当 (i < 大小) { 缓冲[i] = 值 i = i + 1 }
}

函数 内存_复制(目标, 源, 大小) { 定义 可变 i = 0
 当 (i < 大小) { 目标[i] = 源[i] i = i + 1 }
}

函数 内存_比较(a, b, 大小) { 定义 可变 i = 0
 当 (i < 大小) { 如果 (a[i] != b[i]) { 返回 a[i] - b[i] }
 i = i + 1
 }
 返回 0
}

函数 内存_查找(缓冲, 大小, 值) { 定义 可变 i = 0
 当 (i < 大小) { 如果 (缓冲[i] == 值) { 返回 i }
 i = i + 1
 }
 返回 -1
}

// 竞技场分配器(线性分配)

函数 竞技场_创建(容量) { 定义 可变 缓冲 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(缓冲, 0) i = i + 1 }
 返回 [缓冲, 0, 容量, 0]
}

函数 分配器_竞技场_分配(竞技场, 大小) { 定义 当前 = 竞技场[1]
 如果 (当前 + 大小 > 竞技场[2]) { 返回 -1 }
 竞技场[1] = 当前 + 大小
 竞技场[3] = 竞技场[3] + 1
 返回 当前
}

函数 分配器_竞技场_重置(竞技场) {
 竞技场[1] = 0
 竞技场[3] = 0
}

函数 分配器_竞技场_已用(竞技场) { 返回 竞技场[1] }
函数 分配器_竞技场_剩余(竞技场) { 返回 竞技场[2] - 竞技场[1] }
函数 竞技场_利用率(竞技场) {
    如果 (竞技场[2] == 0) { 返回 0
}
 返回 竞技场[1] * 100 / 竞技场[2]
}

函数 分配_模式分析() { 定义 可变 小计 = 0
 定义 可变 中计 = 0
 定义 可变 大计 = 0
 定义 可变 i = 0
 当 (i < 计数(_全局_分配历史)) { 定义 大小 = _全局_分配历史[i][0]
 如果 (大小 <= 64) { 小计 = 小计 + 1 }
 否则 如果 (大小 <= 4096) { 中计 = 中计 + 1 }
 否则 { 大计 = 大计 + 1 }
 i = i + 1
 }
 如果 (小计 > 中计 + 大计) { 返回 "小对象为主: 建议Slab分配器" }
 如果 (大计 > 小计 + 中计) { 返回 "大对象为主: 建议伙伴系统" }
 返回 "混合模式: 统一分配器适用"
}

函数 碎片率_估算(alloc) { 定义 已分配 = alloc[2]
 定义 已释放 = alloc[3]
 定义 在用 = 已分配 - 已释放
 如果 (已分配 == 0) { 返回 0 }
 如果 (在用 <= 0) { 返回 0 }
 如果 (_全局_峰值内存 == 0) { _全局_峰值内存 = 1 }
 定义 可变 碎片 = (_全局_峰值内存 - 在用) * 100 / _全局_峰值内存
 如果 (碎片 < 0) { 碎片 = 0 }
 返回 碎片
}

函数 内存_健康诊断(alloc) { 定义 可变 问题 = []
 定义 在用 = alloc[2] - alloc[3]
 如果 (在用 < 0) { 追加(问题, "释放超过分配: 可能双重释放") }
 定义 可变 碎片 = 碎片率_估算(alloc)
 如果 (碎片 > 50) { 追加(问题, "碎片率过高: 建议整理或切换分配策略") }
 如果 (_全局_峰值内存 > 100000000) { 追加(问题, "峰值内存超100MB: 检查大对象分配") }
 如果 (_全局_分配次数 > 1000000) { 追加(问题, "分配次数极高: 考虑对象池") }
 如果 (计数(问题) == 0) { 追加(问题, "内存状态健康") }
 返回 问题
}

函数 分配器_推荐(平均大小, 频率, 生命期) {
    如果 (平均大小 <= 64 且 频率 > 1000) { 返回 "Slab分配器(固定大小高频)"
}
 如果 (生命期 == "短" 且 频率 > 100) { 返回 "竞技场分配器(批量释放)" }
 如果 (平均大小 > 4096) { 返回 "伙伴系统(大块2幂管理)" }
 返回 "通用GC分配器"
}

函数 内存_使用预测(alloc, 未来操作数) {
    如果 (_全局_分配次数 == 0) { 返回 0
}
 定义 平均每次 = alloc[2] / _全局_分配次数
 返回 _全局_当前内存 + 平均每次 * 未来操作数
}

函数 GC时机_建议(alloc) { 定义 在用 = alloc[2] - alloc[3]
 定义 分配率 = _全局_分配次数 - _全局_释放次数
 如果 (分配率 > 10000) { 返回 "立即触发GC(积压过多)" }
 如果 (在用 > _全局_峰值内存 * 80 / 100) { 返回 "建议触发Minor GC" }
 如果 (在用 > _全局_峰值内存 * 95 / 100) { 返回 "紧急触发Full GC" }
 返回 "暂不需要GC"
}

// 环形缓冲分配器
// 适合固定大小的FIFO流式分配

函数 分配器_环形缓冲_创建(容量) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(数据, 0) i = i + 1 }
 返回 [数据, 0, 容量, 0]
}

函数 环形缓冲_写入(环, 值) { 定义 容量 = 环[3]
 如果 (环[4] >= 容量) { 返回 假 }
 环[0][环[2]] = 值
 环[2] = (环[2] + 1) % 容量
 环[4] = 环[4] + 1
 返回 真
}

函数 环形缓冲_读取(环) {
    如果 (环[4] <= 0) { 返回 空
}
 定义 值 = 环[0][环[1]]
 环[1] = (环[1] + 1) % 环[3]
 环[4] = 环[4] - 1
 返回 值
}

函数 环形缓冲_已用(环) { 返回 环[4] }
函数 环形缓冲_空闲(环) { 返回 环[3] - 环[4] }
函数 分配器_环形缓冲_满(环) { 返回 环[4] >= 环[3] }
函数 分配器_环形缓冲_空(环) { 返回 环[4] == 0 }

// 对象池
// 预分配固定数量对象，避免频繁分配释放

函数 分配器_对象池_创建(对象大小, 池大小) { 定义 可变 空闲栈 = []
 定义 可变 i = 池大小 - 1
 当 (i >= 0) { 追加(空闲栈, i) i = i - 1 }
 定义 可变 存储 = []
 i = 0
 当 (i < 池大小) { 定义 可变 对象 = []
 定义 可变 j = 0
 当 (j < 对象大小) { 追加(对象, 0) j = j + 1 }
 追加(存储, 对象)
 i = i + 1
 }
 返回 [存储, 空闲栈, 对象大小, 池大小,]
}

函数 分配器_对象池_获取(池) {
    如果 (计数(池[1]) == 0) { 返回 空
}
 定义 索引 = 池[1][计数(池[1]) - 1]
 池[1] = 切片(池[1], 0, 计数(池[1]) - 1)
 池[4] = 池[4] + 1
 返回 池[0][索引]
}

函数 分配器_对象池_归还(池, 索引) {
 追加(池[1], 索引)
 池[5] = 池[5] + 1
}

函数 对象池_可用数(池) { 返回 计数(池[1]) }
函数 对象池_已用数(池) { 返回 池[3] - 计数(池[1]) }
函数 对象池_利用率(池) {
    如果 (池[3] == 0) { 返回 0
}
 返回 (池[3] - 计数(池[1])) * 100 / 池[3]
}

// 内存泄漏检测

定义 可变 _泄漏检测_记录 = []
定义 可变 _泄漏检测_开启 = 假

函数 泄漏检测_开始() { _泄漏检测_记录 = []
 _泄漏检测_开启 = 真
}

函数 泄漏检测_记录分配(指针, 大小) { 如果 (_泄漏检测_开启) {
 追加(_泄漏检测_记录, [指针, 大小, 真])
 }
}

函数 泄漏检测_记录释放(指针) {
    如果 (!_泄漏检测_开启) { 返回
}
 定义 可变 i = 0
 当 (i < 计数(_泄漏检测_记录)) { 如果 (_泄漏检测_记录[i][0] == 指针 且 _泄漏检测_记录[i][2]) { _泄漏检测_记录[i][2] = 假
 返回
 }
 i = i + 1
 }
}

函数 泄漏检测_报告() { 定义 可变 泄漏数 = 0
 定义 可变 泄漏字节 = 0
 定义 可变 i = 0
 当 (i < 计数(_泄漏检测_记录)) { 如果 (_泄漏检测_记录[i][2]) {
 泄漏数 = 泄漏数 + 1
 泄漏字节 = 泄漏字节 + _泄漏检测_记录[i][1]
 }
 i = i + 1
 }
 返回 [泄漏数, 泄漏字节]
}

函数 泄漏检测_停止() { _泄漏检测_开启 = 假
}

函数 分配_大小直方图() { 定义 可变 桶 = [0, 0, 0, 0, 0]
 定义 可变 i = 0
 当 (i < 计数(_全局_分配历史)) { 定义 大小 = _全局_分配历史[i][0]
 如果 (大小 <= 16) { 桶[0] = 桶[0] + 1 }
 否则 如果 (大小 <= 64) { 桶[1] = 桶[1] + 1 }
 否则 如果 (大小 <= 256) { 桶[2] = 桶[2] + 1 }
 否则 如果 (大小 <= 1024) { 桶[3] = 桶[3] + 1 }
 否则 如果 (大小 <= 4096) { 桶[4] = 桶[4] + 1 }
 否则 如果 (大小 <= 65536) { 桶[5] = 桶[5] + 1 }
 否则 如果 (大小 <= 1048576) { 桶[6] = 桶[6] + 1 }
 否则 { 桶[7] = 桶[7] + 1 }
 i = i + 1
 }
 返回 桶
}

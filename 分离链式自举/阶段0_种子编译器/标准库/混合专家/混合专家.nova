导入("../基础.nova")
导入("../激活函数/激活函数.nova")

函数 _混合专家_指数(x) {
    如果 (x < -4000) { 返回 2
}
 如果 (x > 4000) { 返回 50000 }
 如果 (x > 1000) { 定义 h = _混合专家_指数(x / 2)
 返回 h * h / 1000 }
 如果 (x < -1000) { 定义 h = _混合专家_指数(x / 2)
 返回 h * h / 1000 }
 返回 1000 + x + x * x / 2000
}

// 门控网络
定义 可变 门控_权重 = []
定义 可变 门控_分数 = []
定义 可变 专家数 = 0
定义 可变 输入维度 = 0
定义 可变 路由_种子 = 42
定义 可变 路由_计数器 = []

函数 MoE_初始化(n_experts, 维度) {
 专家数 = n_experts
 输入维度 = 维度
 门控_权重 = []
 路由_计数器 = []
 定义 可变 i = 0
 当 (i < n_experts * 维度) {
 追加(门控_权重, 100 + i % 50)
 i = i + 1
 }
 i = 0
 当 (i < n_experts) { 追加(路由_计数器, 0)
 i = i + 1 }
}

函数 MoE_门控分数(输入) {
 门控_分数 = []
 定义 可变 e = 0
 当 (e < 专家数) { 定义 可变 得分 = 0
 定义 可变 d = 0
 当 (d < 输入维度) { 定义 索引 = e * 输入维度 + d
 得分 = 得分 + 输入[d] * 门控_权重[索引] / 1000
 d = d + 1
 }
 追加(门控_分数, 得分)
 e = e + 1
 }
 返回 门控_分数
}

// 噪声门控: 加入可调噪声提升探索
函数 MoE_噪声门控(输入, 噪声量) { 定义 基数 = MoE_门控分数(输入)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(基数)) {
 路由_种子 = (路由_种子 * 1103515245 + 12345) % 2147483647
 定义 噪声 = (路由_种子 % 2001 - 1000) * 噪声量 / 1000
 追加(结果, 基数[i] + 噪声)
 i = i + 1
 }
 返回 结果
}

// TopK 专家选择
函数 topk_选择(分数, k) { 定义 n = 计数(分数)
    定义 可变 ii = 0
 定义 可变 索引 = []
 定义 可变 权重 = []
 定义 可变 已选 = []
 当 (ii < n) { 追加(已选, 0)
 ii = ii + 1 }
 定义 可变 选次 = 0
 当 (选次 < k) { 定义 可变 最佳 = -99999
 定义 可变 最佳idx = 0
 定义 可变 j = 0
 当 (j < n) { 如果 (已选[j] == 0) { 如果 (分数[j] > 最佳) { 最佳 = 分数[j]
 最佳idx = j }
 }
 j = j + 1
 }
 追加(索引, 最佳idx)
 追加(权重, 最佳)
 已选[最佳idx] = 1
 选次 = 选次 + 1
 }
 定义 可变 w总 = 0
 ii = 0
 当 (ii < k) { w总 = w总 + 权重[ii]
 ii = ii + 1 }
 如果 (w总 < 1) { w总 = 1 }
 定义 可变 归一权重 = []
 ii = 0
 当 (ii < k) { 追加(归一权重, 权重[ii] * 1000 / w总)
 ii = ii + 1 }
 返回 [索引, 归一权重]
}

// Switch路由 (Top-1)
函数 Switch_路由(输入) { 定义 分数 = MoE_门控分数(输入)
 定义 sm = 归一化指数(分数)
 定义 可变 最优 = -1
 定义 可变 最优得分 = -99999
 定义 可变 i = 0
 当 (i < 计数(sm)) { 如果 (sm[i] > 最优得分) { 最优得分 = sm[i]
 最优 = i }
 i = i + 1
 }
 返回 [最优, 最优得分]
}

// Expert Choice路由: 专家选token
函数 专家选择(分数矩阵, n_tokens, 容量) {
 // 分数矩阵: flat [n_experts * n_tokens]
 定义 可变 分配 = []
 定义 可变 e = 0
 当 (e < 专家数) { 定义 可变 选中 = 0
 定义 可变 t = 0
 当 (t < n_tokens) { 如果 (选中 < 容量) { 定义 得分 = 分数矩阵[e * n_tokens + t]
 如果 (得分 > 500) { 选中 = 选中 + 1
 追加(分配, e * 1000 + t) }
 }
 t = t + 1
 }
 e = e + 1
 }
 返回 分配
}

// 专家前向传播
函数 MoE_专家前向(expert_id, 输入) { 定义 缩放值 = 800 + expert_id * 50
 返回 映射(输入, x => x * 缩放值 / 1000 + expert_id * 10)
}

// 专家Dropout: 训练时随机屏蔽部分专家
函数 MoE_专家Dropout(索引, 权重, drop_rate) { 定义 可变 new_idx = []
 定义 可变 new_w = []
 定义 可变 i = 0
 当 (i < 计数(索引)) {
 路由_种子 = (路由_种子 * 1103515245 + 12345) % 2147483647
 定义 随机值 = (路由_种子 % 1000 + 1000) % 1000
 如果 (随机值 >= drop_rate) {
 追加(new_idx, 索引[i])
 追加(new_w, 权重[i])
 }
 i = i + 1
 }
 如果 (计数(new_idx) == 0) {
 追加(new_idx, 索引[0])
 追加(new_w, 1000)
 }
 返回 [new_idx, new_w]
}

// MoE 完整前向
函数 混合专家模块_MoE_前向(输入, k) { 定义 分数 = MoE_门控分数(输入)
 定义 sm = 归一化指数(分数)
 定义 选择 = topk_选择(sm, k)
 定义 索引 = 选择[0]
 定义 权重 = 选择[1]
 定义 维度 = 计数(输入)
 定义 可变 输出 = []
 定义 可变 d = 0
 当 (d < 维度) { 追加(输出, 0)
 d = d + 1 }
 定义 可变 ki = 0
 当 (ki < k) { 定义 eid = 索引[ki]
 定义 w = 权重[ki]
 定义 exp_out = MoE_专家前向(eid, 输入)
 路由_计数器[eid] = 路由_计数器[eid] + 1
 d = 0
 当 (d < 维度) { 输出[d] = 输出[d] + exp_out[d] * w / 1000
 d = d + 1 }
 ki = ki + 1
 }
 返回 输出
}

// 负载均衡损失
函数 负载均衡损失(路由历史) { 定义 n = 计数(路由历史)
 定义 可变 频率 = []
 定义 可变 i = 0
 当 (i < 专家数) { 追加(频率, 0)
 i = i + 1 }
 i = 0
 当 (i < n) { 定义 eid2 = 路由历史[i]
 如果 (eid2 >= 0) { 如果 (eid2 < 专家数) { 频率[eid2] = 频率[eid2] + 1 } }
 i = i + 1
 }
 定义 理想 = n * 1000 / 专家数
 定义 可变 损失 = 0
 i = 0
 当 (i < 专家数) { 定义 差值 = 频率[i] * 1000 - 理想
 损失 = 损失 + 差值 * 差值 / 1000
 i = i + 1
 }
 如果 (专家数 == 0) { 返回 0 }
 返回 损失 / 专家数
}

// 辅助均衡损失 V2 (GShard): f_i * P_i
函数 辅助均衡损失(路由历史, 平均概率) { 定义 n = 计数(路由历史)
 如果 (n == 0) { 返回 0 }
 定义 可变 频率 = []
 定义 可变 i = 0
 当 (i < 专家数) { 追加(频率, 0)
 i = i + 1 }
 i = 0
 当 (i < n) { 定义 eid3 = 路由历史[i]
 如果 (eid3 >= 0) { 如果 (eid3 < 专家数) { 频率[eid3] = 频率[eid3] + 1 } }
 i = i + 1
 }
 定义 可变 损失 = 0
 i = 0
 当 (i < 专家数) { 定义 f_i = 频率[i] * 1000 / n
 定义 p_i = 平均概率[i]
 损失 = 损失 + f_i * p_i / 1000
 i = i + 1
 }
 返回 损失 * 专家数 / 1000
}

// 容量因子
函数 容量上限(总tokens, 因子) { 返回 总tokens * 因子 / (专家数 * 1000)
}

// 路由分析: 返回每个专家的使用率
函数 路由分析() { 定义 可变 总 = 折叠(路由_计数器, 0, (s, x) => s + x)
 如果 (总 == 0) { 总 = 1 }
 返回 映射(路由_计数器, c => c * 1000 / 总)
}

函数 路由重置() { 定义 可变 i = 0
 当 (i < 专家数) { 路由_计数器[i] = 0
 i = i + 1 }
}

// 专家总数
函数 MoE_专家总数() { 返回 专家数 }

// NovaOS 中断管理系统 - 生产级实现
// 支持接口C、中断路由、中断亲和性、中断线程化

导入("./类型定义.nova")
导入("./错误码.nova")

导入("./同步原语.nova")
导入("./原子操作.nova")
导入("./内存物理.nova")
导入("./块缓分配器生.nova")
导入("./时钟中枢.nova")
导入("./原生系统块分.nova")
导入("./同步原语生产.nova")

// 中断向量范围
定义 中断向量_最小 = 32
定义 中断向量_最大 = 255
定义 中断向量_数量 = 256

// 中断类型
枚举 中断类型 {
    中断类型_边沿触发 = 0,
    中断类型_电平触发 = 1,
    中断类型_MSI = 2,
    中断类型_MSIX = 3,
}

// 中断标志
定义 中断标志_共享 = (1 << 0)
定义 中断标志_禁用 = (1 << 1)
定义 中断标志_线程化 = (1 << 2)
定义 中断标志_单次 = (1 << 3)
定义 中断标志_探测 = (1 << 4)
定义 中断标志_不均衡 = (1 << 5)

// 中断处理结果
枚举 中断处理结果 {
    中断_未处理 = 0,
    中断_已处理 = 1,
    中断_唤醒线程 = 2,
}

// 中断处理函数类型
类型 中断处理函数 = 函数(中断号: 整数, 设备数据: *无符号长整数): 中断处理结果
类型 中断线程函数 = 函数(中断号: 整数, 设备数据: *无符号长整数): 中断处理结果

// 中断动作（处理器链表节点）
结构 中断动作 {
    处理函数: 中断处理函数,
    线程函数: 中断线程函数,
    设备数据: *无符号长整数,
    设备名称: 字符串,
    设备ID: 整数,
    
    // 线程化支持
    线程: *任务结构体,
    线程标志: 原子32位,
    
    // 链表
    下一个: *中断动作,
    
    // 统计
    中断计数: 原子64位,
    未处理计数: 原子64位,
}

函数 中断动作_标记线程待处理(动作) {
    如果 (动作 == 空) { 返回 }
    原子写入32位(&动作.线程标志, 1)
}

// 中断描述符
结构 中断描述符 {
    // 中断号
    中断号: 整数,
    
    // 中断类型和标志
    类型: 中断类型,
    标志: 无符号整数,
    
    // 处理器链表
    动作链表: *中断动作,
    
    // 锁保护
    锁: 自旋锁,
    
    // 中断控制
    芯片: *中断芯片,
    芯片数据: *无符号长整数,
    
    // CPU亲和性
    亲和性掩码: 无符号长整数,
    有效亲和性: 整数,
    
    // 状态
    深度: 整数,  // 禁用深度（0表示启用）
    唤醒深度: 整数,
    
    // 统计
    中断计数: 原子64位,
    错误计数: 原子64位,
    
    // 时间戳
    上次中断时间: 无符号长整数,
}

// 中断芯片操作
结构 中断芯片 {
    名称: 字符串,
    
    // 操作函数
    启动: 函数(描述符: *中断描述符),
    关闭: 函数(描述符: *中断描述符),
    启用: 函数(描述符: *中断描述符),
    禁用: 函数(描述符: *中断描述符),
    确认: 函数(描述符: *中断描述符),
    结束: 函数(描述符: *中断描述符),
    设置亲和性: 函数(描述符: *中断描述符, CPU掩码: 无符号长整数): 整数,
    设置类型: 函数(描述符: *中断描述符, 类型: 中断类型): 整数,
}

// 中断向量表
结构 中断向量表 {
    描述符: [中断向量_数量]*中断描述符,
    
    // 全局锁
    锁: 自旋锁,
    
    // 统计
    总中断数: 原子64位,
    虚假中断数: 原子64位,
}

// 接口C控制器
结构 接口C控制器 {
    // Local 接口C
    本地接口C基址: 无符号长整数,
    本地接口C虚拟地址: *无符号长整数,
    
    // IO 接口C
    IO_接口C数量: 整数,
    IO_接口C基址: [8]无符号长整数,
    IO_接口C虚拟地址: [8]*无符号长整数,
    
    // 中断路由表
    路由表: [24]中断路由条目,
    
    // 芯片接口
    芯片: 中断芯片,
}

// 中断路由条目
结构 中断路由条目 {
    源总线: 整数,
    源IRQ: 整数,
    目标接口C: 整数,
    目标引脚: 整数,
    触发模式: 整数,
    极性: 整数,
}

// 全局中断管理器
结构 中断管理器 {
    // 中断向量表
    向量表: 中断向量表,
    
    // 接口C控制器
    接口C: 接口C控制器,
    
    // 中断动作缓存
    动作缓存: *Nova块缓存缓存,
    
    // 每CPU中断统计
    每CPU统计: [最大CPU数]每CPU中断统计,
}

// 每CPU中断统计
结构 每CPU中断统计 {
    中断计数: [中断向量_数量]无符号长整数,
    总中断数: 无符号长整数,
    软中断数: 无符号长整数,
}

变量 全局中断管理器: 中断管理器

// 初始化中断管理系统
函数 初始化中断管理() {
    打印("初始化中断管理系统...\n")
    
    初始化自旋锁(&全局中断管理器.向量表.锁)
    
    // 初始化所有中断描述符
    对于 i := 0; i < 中断向量_数量; i++ {
        描述符 := kmalloc(大小为(中断描述符), 0)
        如果 描述符 == 空 {
            继续
        }
        
        描述符.中断号 = i
        描述符.深度 = 1  // 默认禁用
        初始化自旋锁(&描述符.锁)
        
        全局中断管理器.向量表.描述符[i] = 描述符
    }
    
    // 初始化接口C
    初始化接口C()
    
    // 创建中断动作缓存
    全局中断管理器.动作缓存 = 创建Nova块缓存缓存(
        "irq_action",
        大小为(中断动作),
        0,
        Nova块缓存标志_HWCACHE对齐,
        空,
        空
    )
    
    打印("中断管理系统初始化完成\n")
}

// 初始化接口C
函数 初始化接口C() {
    打印("初始化接口C...\n")
    
    // 检测Local 接口C
    全局中断管理器.接口C.本地接口C基址 = 0xFEE00000
    全局中断管理器.接口C.本地接口C虚拟地址 = 映射IO内存(
        全局中断管理器.接口C.本地接口C基址,
        页面大小
    )
    
    // 启用Local 接口C
    启用本地接口C()
    
    // 检测IO 接口C
    检测IO_接口C()
    
    // 设置芯片操作
    全局中断管理器.接口C.芯片.名称 = "接口C"
    全局中断管理器.接口C.芯片.启动 = 接口C启动中断
    全局中断管理器.接口C.芯片.关闭 = 接口C关闭中断
    全局中断管理器.接口C.芯片.启用 = 接口C启用中断
    全局中断管理器.接口C.芯片.禁用 = 接口C禁用中断
    全局中断管理器.接口C.芯片.确认 = 接口C确认中断
    全局中断管理器.接口C.芯片.结束 = 接口C结束中断
    全局中断管理器.接口C.芯片.设置亲和性 = 接口C设置亲和性
    
    打印("接口C初始化完成\n")
}

// 启用本地接口C
函数 启用本地接口C() {
    基址 := 全局中断管理器.接口C.本地接口C虚拟地址
    
    // 读取接口C版本
    版本 := 读取接口C寄存器(基址, 0x30)
    打印("Local 接口C版本: 0x%x\n", 版本)
    
    // 启用接口C（设置SVR寄存器）
    SVR := 读取接口C寄存器(基址, 0xF0)
    SVR |= 0x100  // 启用位
    写入接口C寄存器(基址, 0xF0, SVR)
    
    // 设置任务优先级为0（接受所有中断）
    写入接口C寄存器(基址, 0x80, 0)
}

// 检测IO 接口C
函数 检测IO_接口C() {
    // 实现：假设一个IO 接口C在0xFEC00000
    全局中断管理器.接口C.IO_接口C数量 = 1
    全局中断管理器.接口C.IO_接口C基址[0] = 0xFEC00000
    全局中断管理器.接口C.IO_接口C虚拟地址[0] = 映射IO内存(0xFEC00000, 页面大小)
    
    // 读取IO 接口C版本和引脚数
    版本 := 读取IO_接口C寄存器(0, 0x01)
    引脚数 := ((版本 >> 16) & 0xFF) + 1
    
    打印("IO 接口C 0: 版本=0x%x, 引脚数=%d\n", 版本 & 0xFF, 引脚数)
}

// 注册中断处理器
函数 请求中断(中断号, 处理函数, 标志, 设备名称, 设备数据) {
    
    如果 中断号 < 0 或 中断号 >= 中断向量_数量 {
        返回 -错误码_无效参数
    }
    
    描述符 := 全局中断管理器.向量表.描述符[中断号]
    如果 描述符 == 空 {
        返回 -错误码_无效参数
    }
    
    // 创建中断动作
    动作 := Nova块缓存分配(全局中断管理器.动作缓存, 0)
    如果 动作 == 空 {
        返回 -错误码_内存不足
    }
    
    动作.处理函数 = 处理函数
    动作.设备数据 = 设备数据
    动作.设备名称 = 设备名称
    
    自旋锁加锁(&描述符.锁)
    
    // 检查是否可以共享
    如果 描述符.动作链表 != 空 {
        如果 (标志 & 中断标志_共享) == 0 或 (描述符.标志 & 中断标志_共享) == 0 {
            自旋锁解锁(&描述符.锁)
            Nova块缓存释放(全局中断管理器.动作缓存, 动作)
            返回 -错误码_忙碌
        }
    }
    
    // 添加到动作链表
    动作.下一个 = 描述符.动作链表
    描述符.动作链表 = 动作
    描述符.标志 |= 标志
    
    // 设置芯片
    如果 描述符.芯片 == 空 {
        描述符.芯片 = &全局中断管理器.接口C.芯片
    }
    
    // 启动中断
    如果 描述符.芯片.启动 != 空 {
        描述符.芯片.启动(描述符)
    }
    
    // 启用中断
    如果 描述符.深度 > 0 {
        描述符.深度--
        如果 描述符.深度 == 0 且 描述符.芯片.启用 != 空 {
            描述符.芯片.启用(描述符)
        }
    }
    
    自旋锁解锁(&描述符.锁)
    
    打印("注册中断 %d: %s\n", 中断号, 设备名称)
    返回 0
}

// 释放中断处理器
函数 释放中断(中断号, 设备数据) {
    如果 中断号 < 0 或 中断号 >= 中断向量_数量 {
        返回
    }
    
    描述符 := 全局中断管理器.向量表.描述符[中断号]
    如果 描述符 == 空 {
        返回
    }
    
    自旋锁加锁(&描述符.锁)
    
    // 从链表中移除
    前一个 := (*中断动作)(空)
    当前 := 描述符.动作链表
    
    当 当前 != 空 {
        如果 当前.设备数据 == 设备数据 {
            如果 前一个 == 空 {
                描述符.动作链表 = 当前.下一个
            } 否则 {
                前一个.下一个 = 当前.下一个
            }
            
            Nova块缓存释放(全局中断管理器.动作缓存, 当前)
            跳出
        }
        
        前一个 = 当前
        当前 = 当前.下一个
    }
    
    // 如果没有处理器了，禁用中断
    如果 描述符.动作链表 == 空 {
        如果 描述符.芯片 != 空 且 描述符.芯片.关闭 != 空 {
            描述符.芯片.关闭(描述符)
        }
        描述符.深度 = 1
    }
    
    自旋锁解锁(&描述符.锁)
}

// 通用中断处理入口
函数 处理中断(中断号) {
    如果 中断号 < 0 或 中断号 >= 中断向量_数量 {
        返回
    }
    
    描述符 := 全局中断管理器.向量表.描述符[中断号]
    如果 描述符 == 空 {
        返回
    }
    
    // 更新统计
    原子增加64位(&全局中断管理器.向量表.总中断数, 1)
    原子增加64位(&描述符.中断计数, 1)
    
    CPU := 获取当前CPU编号()
    全局中断管理器.每CPU统计[CPU].中断计数[中断号]++
    全局中断管理器.每CPU统计[CPU].总中断数++
    
    描述符.上次中断时间 = 获取纳秒时间戳()
    
    // 确认中断
    如果 描述符.芯片 != 空 且 描述符.芯片.确认 != 空 {
        描述符.芯片.确认(描述符)
    }
    
    // 调用处理器链
    已处理 := 假
    动作 := 描述符.动作链表
    
    当 动作 != 空 {
        如果 动作.处理函数 != 空 {
            结果 := 动作.处理函数(中断号, 动作.设备数据)
            
            如果 结果 == 中断_已处理 或 结果 == 中断_唤醒线程 {
                已处理 = 真
                原子增加64位(&动作.中断计数, 1)
                
                如果 结果 == 中断_唤醒线程 且 动作.线程 != 空 {
                    中断动作_标记线程待处理(动作)
                }
            } 否则 {
                原子增加64位(&动作.未处理计数, 1)
            }
        }
        
        动作 = 动作.下一个
    }
    
    如果 !已处理 {
        原子增加64位(&全局中断管理器.向量表.虚假中断数, 1)
    }
    
    // 结束中断
    如果 描述符.芯片 != 空 且 描述符.芯片.结束 != 空 {
        描述符.芯片.结束(描述符)
    }
}

// 禁用中断
函数 禁用中断(中断号) {
    描述符 := 全局中断管理器.向量表.描述符[中断号]
    如果 描述符 == 空 {
        返回
    }
    
    自旋锁加锁(&描述符.锁)
    
    描述符.深度++
    如果 描述符.深度 == 1 且 描述符.芯片 != 空 且 描述符.芯片.禁用 != 空 {
        描述符.芯片.禁用(描述符)
    }
    
    自旋锁解锁(&描述符.锁)
}

// 启用中断
函数 启用中断(中断号) {
    描述符 := 全局中断管理器.向量表.描述符[中断号]
    如果 描述符 == 空 {
        返回
    }
    
    自旋锁加锁(&描述符.锁)
    
    如果 描述符.深度 > 0 {
        描述符.深度--
        如果 描述符.深度 == 0 且 描述符.芯片 != 空 且 描述符.芯片.启用 != 空 {
            描述符.芯片.启用(描述符)
        }
    }
    
    自旋锁解锁(&描述符.锁)
}

// 设置中断亲和性
函数 设置中断亲和性(中断号, CPU掩码) {
    描述符 := 全局中断管理器.向量表.描述符[中断号]
    如果 描述符 == 空 {
        返回 -错误码_无效参数
    }
    
    自旋锁加锁(&描述符.锁)
    描述符.亲和性掩码 = CPU掩码
    
    如果 描述符.芯片 != 空 且 描述符.芯片.设置亲和性 != 空 {
        描述符.芯片.设置亲和性(描述符, CPU掩码)
    }
    
    自旋锁解锁(&描述符.锁)
    返回 0
}

// NIMT — Nova Interrupt Management Theory
// 公理1(中断确定性): 每个中断向量号唯一映射到一个描述符
// 公理2(处理链完整性): 共享中断遍历全部动作节点, 直到已处理
// 公理3(深度守恒): 禁用+启用对称, 深度归零时硬件启用
// 定理1(负载均衡): 中断亲和性分布使得各CPU中断负载偏差最小化
// 定理2(线程化安全): 线程化中断不在中断上下文执行长操作

// 查询中断描述符信息
函数 获取中断信息(中断号) {
    如果 中断号 < 0 或 中断号 >= 中断向量_数量 {
        返回 空
    }
    描述符 := 全局中断管理器.向量表.描述符[中断号]
    如果 描述符 == 空 {
        返回 空
    }
    返回 [
        描述符.中断号,
        原子读取64位(&描述符.中断计数),
        原子读取64位(&描述符.错误计数),
        描述符.深度,
        描述符.亲和性掩码,
        描述符.上次中断时间
    ]
}

// 打印中断统计
函数 中断_打印统计() {
    打印("=== 中断管理统计 ===\n")
    打印("总中断数: %d\n", 原子读取64位(&全局中断管理器.向量表.总中断数))
    打印("虚假中断: %d\n", 原子读取64位(&全局中断管理器.向量表.虚假中断数))
    
    // 打印活跃中断
    对于 i := 中断向量_最小; i < 中断向量_最大; i++ {
        描述符 := 全局中断管理器.向量表.描述符[i]
        如果 描述符 == 空 { 继续 }
        计数 := 原子读取64位(&描述符.中断计数)
        如果 计数 > 0 {
            打印("  IRQ %3d: 计数=%d 错误=%d 深度=%d\n",
                i, 计数,
                原子读取64位(&描述符.错误计数),
                描述符.深度)
        }
    }
}

// 每 CPU中断负载查询
函数 中断_获取CPU负载(CPU号) {
    如果 CPU号 < 0 或 CPU号 >= 最大CPU数 {
        返回 0
    }
    返回 全局中断管理器.每CPU统计[CPU号].总中断数
}

// 查找中断负载最低的CPU
函数 中断_查找最低负载CPU() {
    最低负载 := 全局中断管理器.每CPU统计[0].总中断数
    最低CPU := 0
    
    对于 i := 1; i < 最大CPU数; i++ {
        负载 := 全局中断管理器.每CPU统计[i].总中断数
        如果 负载 < 最低负载 {
            最低负载 = 负载
            最低CPU = i
        }
    }
    返回 最低CPU
}

// 中断亲和性自动均衡 — 将高负载CPU的中断迁移到低负载CPU
函数 中断_自动均衡() {
    打印("[NIMT] 执行中断负载均衡...\n")
    
    // 找到最高和最低负载CPU
    最高负载 := 全局中断管理器.每CPU统计[0].总中断数
    最低负载 := 最高负载
    最高CPU := 0
    最低CPU := 0
    
    对于 i := 1; i < 最大CPU数; i++ {
        负载 := 全局中断管理器.每CPU统计[i].总中断数
        如果 负载 > 最高负载 {
            最高负载 = 负载
            最高CPU = i
        }
        如果 负载 < 最低负载 {
            最低负载 = 负载
            最低CPU = i
        }
    }
    
    // 如果偏差超过20%, 将最高负载CPU上最活跃中断迁移
    如果 最高负载 > 0 且 (最高负载 - 最低负载) * 100 / 最高负载 > 20 {
        // 找到最高负载CPU上中断最多的向量
        最活跃向量 := -1
        最活跃计数 := 0
        
        对于 i := 中断向量_最小; i < 中断向量_最大; i++ {
            计数 := 全局中断管理器.每CPU统计[最高CPU].中断计数[i]
            如果 计数 > 最活跃计数 {
                最活跃计数 = 计数
                最活跃向量 = i
            }
        }
        
        如果 最活跃向量 >= 0 {
            设置中断亲和性(最活跃向量, 1 << 最低CPU)
            打印("[NIMT] 迁移 IRQ %d: CPU%d -> CPU%d\n",
                最活跃向量, 最高CPU, 最低CPU)
        }
    } 否则 {
        打印("[NIMT] 中断负载已均衡\n")
    }
}

// 查询所有活跃中断向量号列表
函数 中断_获取活跃列表() {
    结果 := []
    对于 i := 中断向量_最小; i < 中断向量_最大; i++ {
        描述符 := 全局中断管理器.向量表.描述符[i]
        如果 描述符 != 空 且 描述符.动作链表 != 空 {
            追加(结果, i)
        }
    }
    返回 结果
}

// 中断风暴检测 — 检查某向量是否触发过频
函数 中断_风暴检测(中断号, 阈值) {
    如果 中断号 < 0 或 中断号 >= 中断向量_数量 {
        返回 假
    }
    描述符 := 全局中断管理器.向量表.描述符[中断号]
    如果 描述符 == 空 {
        返回 假
    }
    计数 := 原子读取64位(&描述符.中断计数)
    如果 计数 > 阈值 {
        打印("[NIMT] 中断风暴警告: IRQ %d 触发 %d 次 (>阈值 %d)\n",
            中断号, 计数, 阈值)
        返回 真
    }
    返回 假
}

定义 可变 AI_中断管理系_风暴阈值 = 10000
定义 可变 AI_中断管理系_预测IRQ = 0

函数 AI_中断管理系_风暴检测(触发频率) {
    如果 (触发频率 > AI_中断管理系_风暴阈值) {
        AI_中断管理系_风暴阈值 = AI_中断管理系_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_中断管理系_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

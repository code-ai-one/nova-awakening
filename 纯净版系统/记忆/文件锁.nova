//   1. flock: BSD文件锁(整个文件)
//   2. Nova接口标准锁(fcntl): 字节范围锁
//   3. 锁类型: 共享锁(读)/排他锁(写)
//   4. 死锁检测: 防止A等B, B等A
//   5. 用于: 数据库/日志文件/PID文件

定义 F_RDLCK = 0    // 共享读锁
定义 F_WRLCK = 1    // 排他写锁
定义 F_UNLCK = 2    // 解锁

定义 LOCK_SH = 1    // 共享锁
定义 LOCK_EX = 2    // 排他锁
定义 LOCK_UN = 8    // 解锁
定义 LOCK_NB = 4    // 非阻塞

结构 文件锁 {
    类型,    // u32 F_RDLCK/F_WRLCK
    起始,    // u64 锁定区域起始
    长度,    // u64 锁定区域长度(0=到文件末尾)
    PID,    // u32 持有锁的进程
    Nova文件节点,    // u64 锁定的文件Nova文件节点
    等待队列,
}

定义 可变 文件锁表 = []

// flock: BSD文件锁 

函数 sys_flock(fd, 操作) {
    定义 Nova文件节点 = fd_获取Nova文件节点(fd)
    定义 pid = 获取当前PID()

    如果 ((操作 & LOCK_UN) != 0) {
        返回 文件锁_解除(Nova文件节点, pid)
    }

    定义 类型 = F_RDLCK
    如果 ((操作 & LOCK_EX) != 0) { 类型 = F_WRLCK }

    定义 非阻塞 = (操作 & LOCK_NB) != 0
    返回 文件锁_获取(Nova文件节点, pid, 类型, 0, 0, 非阻塞)
}

// Nova接口标准锁: fcntl(fd, F_SETLK/F_SETLKW, &flock)

函数 Nova接口标准_lock(fd, 类型, 起始, 长度, 阻塞) {
    定义 Nova文件节点 = fd_获取Nova文件节点(fd)
    定义 pid = 获取当前PID()

    如果 (类型 == F_UNLCK) {
        返回 文件锁_解除_范围(Nova文件节点, pid, 起始, 长度)
    }

    返回 文件锁_获取(Nova文件节点, pid, 类型, 起始, 长度, !阻塞)
}

// 锁获取/释放

函数 文件锁_获取(Nova文件节点, pid, 类型, 起始, 长度, 非阻塞) {
    // 检查冲突
    如果 (文件锁_冲突(Nova文件节点, pid, 类型, 起始, 长度)) {
        如果 (非阻塞) { 返回 错误_重试 }
        // 阻塞等待
        当 (文件锁_冲突(Nova文件节点, pid, 类型, 起始, 长度)) { 调度() }
    }

    定义 锁 = 文件锁 {}
    锁.类型 = 类型
    锁.起始 = 起始
    锁.长度 = 长度
    锁.PID = pid
    锁.Nova文件节点 = Nova文件节点
    锁.等待队列 = 等待队列_创建()
    追加(文件锁表, 锁)
    返回 成功
}

函数 文件锁_解除(Nova文件节点, pid) {
    定义 可变 i = 计数(文件锁表) - 1
    当 (i >= 0) {
        如果 (文件锁表[i].Nova文件节点 == Nova文件节点 && 文件锁表[i].PID == pid) {
            链表_删除(文件锁表, i)
        }
        i = i - 1
    }
    返回 成功
}

函数 文件锁_解除_范围(Nova文件节点, pid, 起始, 长度) {
    定义 可变 i = 计数(文件锁表) - 1
    当 (i >= 0) {
        定义 锁 = 文件锁表[i]
        如果 (锁.Nova文件节点 == Nova文件节点 && 锁.PID == pid) {
            如果 (锁.起始 == 起始 && 锁.长度 == 长度) {
                链表_删除(文件锁表, i)
            }
        }
        i = i - 1
    }
    返回 成功
}

函数 文件锁_冲突(Nova文件节点, pid, 类型, 起始, 长度) {
    定义 可变 i = 0
    当 (i < 计数(文件锁表)) {
        定义 锁 = 文件锁表[i]
        如果 (锁.Nova文件节点 == Nova文件节点 && 锁.PID != pid) {
            // 共享锁与共享锁不冲突
            如果 (锁.类型 == F_RDLCK && 类型 == F_RDLCK) {
                i = i + 1; 继续
            }
            // 范围重叠检测
            如果 (范围重叠(锁.起始, 锁.长度, 起始, 长度)) {
                返回 真
            }
        }
        i = i + 1
    }
    返回 假
}

函数 范围重叠(起始1, 长度1, 起始2, 长度2) {
    如果 (长度1 == 0 || 长度2 == 0) { 返回 真 }  // 0=到末尾
    返回 起始1 < 起始2 + 长度2 && 起始2 < 起始1 + 长度1
}

外部 当前进程             // 定义在 核心/进程/PID分配器.nova

函数 fd_获取Nova文件节点(fd) {
    // 从fd获取Nova文件节点号(连接到进程文件表)
    如果 (当前进程 == 空 || 当前进程.文件表 == 空) { 返回 0 }
    如果 (fd < 0 || fd >= 计数(当前进程.文件表)) { 返回 0 }
    定义 文件 = 当前进程.文件表[fd]
    如果 (文件 == 空) { 返回 0 }
    如果 (文件.Nova文件节点 != 空) { 返回 文件.Nova文件节点 }
    返回 fd  // 回退: 用fd作为唯一标识
}

函数 获取当前PID_锁() {
    如果 (当前进程 == 空) { 返回 0 }
    返回 进程_PID(当前进程)
}
函数 文件锁_统计() { 返回 [计数(文件锁表)] }
// 错误_重试 定义在 核心/公共/错误码.nova

// 死锁检测 

函数 文件锁_死锁检测(请求PID, 目标Nova文件节点, 起始, 长度) {
    // 检查请求PID是否会形成等待环
    // A等B持有的锁, B等C持有的锁, C等A持有的锁 → 死锁
    定义 可变 已访问 = []
    返回 死锁_DFS(请求PID, 请求PID, 已访问, 0)
}

函数 死锁_DFS(当前PID, 目标PID, 已访问, 深度) {
    如果 (深度 > 10) { 返回 假 }  // 防止无限递归
    定义 可变 i = 0
    当 (i < 计数(文件锁表)) {
        定义 锁 = 文件锁表[i]
        如果 (锁.PID == 当前PID) {
            // 当前PID持有锁, 检查谁在等这个锁
            定义 可变 j = 0
            当 (j < 计数(已访问)) {
                如果 (已访问[j] == 锁.PID) { j = j + 1; 继续 }
                j = j + 1
            }
            // 如果等待者就是目标PID, 形成环
            // 实现: 检查锁持有链
        }
        i = i + 1
    }
    返回 假
}

// 查询指定文件的所有锁

函数 文件锁_查询(Nova文件节点) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(文件锁表)) {
        如果 (文件锁表[i].Nova文件节点 == Nova文件节点) {
            追加(结果, 文件锁表[i])
        }
        i = i + 1
    }
    返回 结果
}

// 进程退出时清理所有锁 
函数 文件锁_进程退出(pid) {
    定义 可变 i = 计数(文件锁表) - 1
    当 (i >= 0) {
        如果 (文件锁表[i].PID == pid) {
            链表_删除(文件锁表, i)
        }
        i = i - 1
    }
}

// 语义节点: [类别, 子类型, 名称, 源位置, 属性字典, 子节点列表, 风险标记]
函数 语义节点_创建(类别, 子类型, 名称) {
    返回 [类别, 子类型, 名称, "", [], [], 0]
}

函数 语义节点_类别(n) { 返回 n[0] }
函数 语义节点_子类型(n) { 返回 n[1] }
函数 语义节点_名称(n) { 返回 n[2] }
函数 语义节点_源位置(n) { 返回 n[3] }
函数 语义节点_属性(n) { 返回 n[4] }
函数 语义节点_子节点(n) { 返回 n[5] }
函数 语义节点_风险(n) { 返回 n[6] }

函数 语义节点_设源位置(n, 位置) { n[3] = 位置 }
函数 语义节点_设风险(n, 等级) { n[6] = 等级 }
函数 语义节点_添加属性(n, 键, 值) { 追加(n[4], [键, 值]) }
函数 语义节点_添加子节点(n, 子) { 追加(n[5], 子) }

// 统一语义图: [节点列表, 类型映射, 接口列表, 风险项列表, 阻塞项列表]
函数 语义图_创建() {
    返回 [[], [], [], [], []]
}

函数 语义图_节点(g) { 返回 g[0] }
函数 语义图_类型映射(g) { 返回 g[1] }
函数 语义图_接口列表(g) { 返回 g[2] }
函数 语义图_风险项(g) { 返回 g[3] }
函数 语义图_阻塞项(g) { 返回 g[4] }

函数 语义图_添加节点(g, 节点) {
    追加(g[0], 节点)
}

函数 语义图_添加类型映射(g, 源类型, 目标类型) {
    追加(g[1], [源类型, 目标类型])
}

函数 语义图_添加接口(g, 接口名, 方法列表) {
    追加(g[2], [接口名, 方法列表])
}

函数 语义图_标记风险(g, 描述, 等级) {
    追加(g[3], [描述, 等级])
}

函数 语义图_标记阻塞(g, 描述, 原因) {
    追加(g[4], [描述, 原因])
}

// Nova类型映射: 外源类型→Nova类型
函数 类型映射_Rust到Nova(rust类型) {
    如果 (rust类型 == "i8" 或 rust类型 == "i16" 或 rust类型 == "i32" 或 rust类型 == "i64" 或 rust类型 == "isize") { 返回 "整数" }
    如果 (rust类型 == "u8" 或 rust类型 == "u16" 或 rust类型 == "u32" 或 rust类型 == "u64" 或 rust类型 == "usize") { 返回 "整数" }
    如果 (rust类型 == "f32" 或 rust类型 == "f64") { 返回 "浮点" }
    如果 (rust类型 == "bool") { 返回 "布尔" }
    如果 (rust类型 == "String" 或 rust类型 == "&str") { 返回 "字符串" }
    如果 (rust类型 == "Vec") { 返回 "列表" }
    如果 (rust类型 == "HashMap") { 返回 "字典" }
    如果 (rust类型 == "Option") { 返回 "可空" }
    如果 (rust类型 == "Result") { 返回 "结果" }
    如果 (rust类型 == "()") { 返回 "空" }
    返回 字符串拼接("结构_", rust类型)
}

函数 类型映射_Go到Nova(go类型) {
    如果 (go类型 == "int" 或 go类型 == "int8" 或 go类型 == "int16" 或 go类型 == "int32" 或 go类型 == "int64") { 返回 "整数" }
    如果 (go类型 == "uint" 或 go类型 == "uint8" 或 go类型 == "uint16" 或 go类型 == "uint32" 或 go类型 == "uint64") { 返回 "整数" }
    如果 (go类型 == "float32" 或 go类型 == "float64") { 返回 "浮点" }
    如果 (go类型 == "bool") { 返回 "布尔" }
    如果 (go类型 == "string") { 返回 "字符串" }
    如果 (go类型 == "error") { 返回 "error" }
    返回 字符串拼接("结构_", go类型)
}

函数 类型映射_C到Nova(c类型) {
    如果 (c类型 == "int" 或 c类型 == "long" 或 c类型 == "short" 或 c类型 == "char") { 返回 "整数" }
    如果 (c类型 == "float" 或 c类型 == "double") { 返回 "浮点" }
    如果 (c类型 == "void") { 返回 "空" }
    如果 (c类型 == "char*" 或 c类型 == "const char*") { 返回 "字符串" }
    返回 字符串拼接("结构_", c类型)
}

函数 类型映射_Python到Nova(py类型) {
    如果 (py类型 == "int") { 返回 "整数" }
    如果 (py类型 == "float") { 返回 "浮点" }
    如果 (py类型 == "bool") { 返回 "布尔" }
    如果 (py类型 == "str") { 返回 "字符串" }
    如果 (py类型 == "list") { 返回 "列表" }
    如果 (py类型 == "dict") { 返回 "字典" }
    如果 (py类型 == "无") { 返回 "空" }
    返回 字符串拼接("结构_", py类型)
}

函数 类型映射_Java到Nova(java类型) {
    如果 (java类型 == "int" 或 java类型 == "long" 或 java类型 == "short" 或 java类型 == "byte") { 返回 "整数" }
    如果 (java类型 == "float" 或 java类型 == "double") { 返回 "浮点" }
    如果 (java类型 == "boolean") { 返回 "布尔" }
    如果 (java类型 == "String") { 返回 "字符串" }
    如果 (java类型 == "List" 或 java类型 == "ArrayList") { 返回 "列表" }
    如果 (java类型 == "Map" 或 java类型 == "HashMap") { 返回 "字典" }
    如果 (java类型 == "void") { 返回 "空" }
    返回 字符串拼接("结构_", java类型)
}

// 语义风险报告
函数 语义图_打印风险报告(g) {
    打印("═══ 语义风险报告 ═══")
    打印文本(字符串拼接("  类型映射数: ", 转字符串(计数(g[1]))))
    打印文本(字符串拼接("  接口数: ", 转字符串(计数(g[2]))))
    打印文本(字符串拼接("  风险项数: ", 转字符串(计数(g[3]))))
    打印文本(字符串拼接("  阻塞项数: ", 转字符串(计数(g[4]))))
    定义 可变 i = 0
    当 (i < 计数(g[3])) {
        打印文本(字符串拼接("  [风险] ", g[3][i][0]))
        i = i + 1
    }
    i = 0
    当 (i < 计数(g[4])) {
        打印文本(字符串拼接("  [阻塞] ", 字符串拼接(g[4][i][0], 字符串拼接(" — ", g[4][i][1]))))
        i = i + 1
    }
}

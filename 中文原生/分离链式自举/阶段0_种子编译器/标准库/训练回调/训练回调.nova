导入("../基础.nova")
导入("../自动微分/自动微分.nova")

定义 es_最佳 = 99999
定义 可变 es_耐心 = 10
定义 可变 es_计数器 = 0
定义 可变 es_最小改善 = 1
定义 可变 es_触发 = 假

函数 训练回调_早停_初始化(耐心, 最小改善) {
    es_最佳 = 99999
    es_耐心 = 耐心
    es_计数器 = 0
    es_最小改善 = 最小改善
    es_触发 = 假
}

// 学习率调度
定义 lr_初始 = 1000
定义 训练回调_lr_当前 = 1000
定义 可变 lr_最小 = 1

函数 lr_设置(初始lr) { lr_初始 = 初始lr
训练回调_lr_当前 = 初始lr
lr_最小 = 1 }

函数 lr_余弦(轮次, 总epochs) {
    如果 (总epochs == 0) { 返回 lr_初始 }
    定义 可变 比例 = 轮次 * 1000 / 总epochs
    定义 可变 余弦值 = 1000
    如果 (比例 <= 500) { 余弦值 = 1000 - 比例 * 比例 * 2 / 1000000 }
    否则 { 余弦值 = (1000 - 比例) * (1000 - 比例) * 2 / 1000000 }
    训练回调_lr_当前 = lr_初始 * (1000 + 余弦值) / 2000
    如果 (训练回调_lr_当前 < lr_最小) { 训练回调_lr_当前 = lr_最小 }
    返回 训练回调_lr_当前
}

函数 lr_预热(步长, 预热步数) {
    如果 (步长 >= 预热步数) { 训练回调_lr_当前 = lr_初始
    返回 lr_初始 }
    如果 (预热步数 == 0) { 返回 lr_初始 }
    训练回调_lr_当前 = lr_初始 * 步长 / 预热步数
    返回 训练回调_lr_当前
}

// 预热+余弦组合
// ReduceLROnPlateau
定义 rlr_最佳 = 99999
定义 可变 rlr_耐心 = 5
定义 可变 rlr_计数器 = 0
定义 rlr_因子 = 500

函数 ReduceLR_初始化(耐心, 因子) {
    rlr_最佳 = 99999
    rlr_耐心 = 耐心
    rlr_计数器 = 0
    rlr_因子 = 因子
}

函数 ReduceLR_检查(val_loss) {
    如果 (val_loss < rlr_最佳) {
        rlr_最佳 = val_loss
        rlr_计数器 = 0
        返回 训练回调_lr_当前
    }
    rlr_计数器 = rlr_计数器 + 1
    如果 (rlr_计数器 >= rlr_耐心) {
        训练回调_lr_当前 = 训练回调_lr_当前 * rlr_因子 / 1000
        如果 (训练回调_lr_当前 < lr_最小) { 训练回调_lr_当前 = lr_最小 }
        rlr_计数器 = 0
    }
    返回 训练回调_lr_当前
}

// 循环学习率: 在base_lr和max_lr之间三角波
函数 循环学习率(步长, base_lr, max_lr, half_cycle) {
    如果 (half_cycle <= 0) { 返回 base_lr }
    定义 可变 cycle_pos = 步长 % (half_cycle * 2)
    定义 可变 lr = 0
    如果 (cycle_pos < half_cycle) {
        lr = base_lr + (max_lr - base_lr) * cycle_pos / half_cycle
    } 否则 {
        lr = max_lr - (max_lr - base_lr) * (cycle_pos - half_cycle) / half_cycle
    }
    训练回调_lr_当前 = lr
    返回 lr
}

// 单周期学习率: 先升后降
函数 单周期学习率(步长, max_lr, 总步数) {
    如果 (总步数 <= 0) { 返回 max_lr }
    定义 可变 peak_step = 总步数 * 300 / 1000
    如果 (步长 < peak_step) {
        训练回调_lr_当前 = max_lr * 步长 / peak_step
    } 否则 {
        定义 可变 decay_steps = 总步数 - peak_step
        如果 (decay_steps <= 0) { decay_steps = 1 }
        训练回调_lr_当前 = max_lr * (总步数 - 步长) / decay_steps
    }
    如果 (训练回调_lr_当前 < lr_最小) { 训练回调_lr_当前 = lr_最小 }
    返回 训练回调_lr_当前
}

// EMA
定义 可变 ema_参数 = []
定义 ema_衰减 = 999
定义 可变 ema_步数 = 0

函数 训练回调_ema_初始化(参数, 衰减率) {
    ema_参数 = 复制列表(参数)
    ema_衰减 = 衰减率
    ema_步数 = 0
}

// 梯度监控
函数 训练回调_梯度裁剪(梯度, 最大范数) {
    定义 可变 范数 = 梯度范数(梯度)
    如果 (范数 <= 最大范数) { 返回 梯度 }
    返回 映射(梯度, g => g * 最大范数 / 范数)
}

// 训练日志
定义 可变 日志_loss = []
定义 可变 日志_lr = []
定义 可变 日志_epoch = []

函数 日志_记录(轮次, 损失值, lr) {
    追加(日志_epoch, 轮次)
    追加(日志_loss, 损失值)
    追加(日志_lr, lr)
}

函数 日志_最近loss(n) {
    定义 可变 总 = 计数(日志_loss)
    如果 (总 == 0) { 返回 0 }
    定义 可变 起 = 总 - n
    如果 (起 < 0) { 起 = 0 }
    定义 可变 计数值 = 0
    当 (起 < 总) { 总和向量 = 总和向量 + 日志_loss[起]
    起 = 起 + 1
    计数值 = 计数值 + 1 }
    如果 (计数值 == 0) { 返回 0 }
    返回 总和向量 / 计数值
}

// 检查点触发: 周期性或改善时
定义 ckpt_最佳 = 99999
定义 可变 ckpt_触发次数 = 0

函数 检查点_应保存(轮次, 周期, val_loss) {
    定义 可变 should = 假
    如果 (周期 > 0) { 如果 (轮次 % 周期 == 0) { should = 真 } }
    如果 (val_loss < ckpt_最佳) { ckpt_最佳 = val_loss
    should = 真 }
    如果 (should) { ckpt_触发次数 = ckpt_触发次数 + 1 }
    返回 should
}

// 日志条数
函数 日志_条数() { 返回 计数(日志_loss) }

// 早停策略

定义 可变 训练回调__早停_耐心 = 5
定义 _早停_最佳loss = 99999
定义 可变 _早停_无改善轮 = 0
定义 可变 _早停_最小改善 = 1

函数 回调_早停_初始化(耐心, 最小改善) {
    训练回调__早停_耐心 = 耐心
    _早停_最小改善 = 最小改善
    _早停_最佳loss = 99999
    _早停_无改善轮 = 0
}

函数 回调_早停_检查(当前loss) {
    如果 (当前loss < _早停_最佳loss - _早停_最小改善) {
        _早停_最佳loss = 当前loss
        _早停_无改善轮 = 0
        返回 假
    }
    _早停_无改善轮 = _早停_无改善轮 + 1
    返回 _早停_无改善轮 >= 训练回调__早停_耐心
}

// 学习率调度

定义 可变 _lr_初始 = 100
定义 可变 _lr_当前 = 100

函数 lr_设初始(lr) { _lr_初始 = lr  _lr_当前 = lr }

函数 回调_lr_阶梯衰减(轮次, 步长, 衰减因子) {
    如果 (轮次 > 0 且 轮次 % 步长 == 0) {
        _lr_当前 = _lr_当前 * 衰减因子 / 100
    }
    返回 _lr_当前
}

函数 回调_lr_余弦退火(轮次, 总epoch) {
    // 简化余弦退火: lr = lr_init * (1 + cos(pi * 轮次 / total)) / 2
    // 近似: 线性衰减后期加速
    定义 进度 = 轮次 * 100 / 总epoch
    定义 因子 = 100 - 进度 * 进度 / 100
    _lr_当前 = _lr_初始 * 因子 / 100
    如果 (_lr_当前 < 1) { _lr_当前 = 1 }
    返回 _lr_当前
}

函数 lr_热启动(轮次, 热启动轮数) {
    如果 (轮次 < 热启动轮数) {
        _lr_当前 = _lr_初始 * 轮次 / 热启动轮数
    }
    返回 _lr_当前
}

// 梯度监控

定义 可变 _梯度_范数历史 = []

函数 梯度_记录范数(范数) { 追加(_梯度_范数历史, 范数) }

函数 回调_梯度_检测异常(_梯度) {
    定义 n = 计数(_梯度_范数历史)
    如果 (n < 2) { 返回 "正常" }
    定义 最新 = _梯度_范数历史[n - 1]
    如果 (最新 > 10000) { 返回 "梯度爆炸" }
    如果 (最新 < 1) { 返回 "梯度消失" }
    返回 "正常"
}

函数 梯度_平均范数(最近n) {
    定义 总 = 计数(_梯度_范数历史)
    如果 (总 == 0) { 返回 0 }
    定义 可变 起 = 总 - 最近n
    如果 (起 < 0) { 起 = 0 }
    定义 可变 和 = 0
    定义 可变 i = 起
    当 (i < 总) { 和 = 和 + _梯度_范数历史[i]  i = i + 1 }
    返回 和 / (总 - 起)
}

定义 可变 _训练_epoch数 = 0
定义 可变 _训练_回调触发数 = 0

函数 训练_记录epoch() { _训练_epoch数 = _训练_epoch数 + 1 }
函数 训练_记录回调() { _训练_回调触发数 = _训练_回调触发数 + 1 }

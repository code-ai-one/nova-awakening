定义 限定_有上限 = 0x01

// LEB128 编码 (Wasm核心编码格式)

// 无符号 LEB128
函数 wasm_编码_uleb128(值) { 定义 结果 = []
 定义 可变 v = 值
 定义 可变 已完成 = 0
 当 (已完成 == 0) { 定义 字节 = v & 0x7F
 v = v >> 7
 如果 (v == 0) {
 追加(结果, 字节)
 已完成 = 1
 } 否则 {
 追加(结果, 字节 | 0x80)
 }
 }
 返回 结果
}

// 有符号 LEB128
函数 wasm_编码_sleb128(值) { 定义 结果 = []
 定义 可变 v = 值
 定义 可变 已完成 = 0
 当 (已完成 == 0) { 定义 字节 = v & 0x7F
 v = v >> 7
 如果 (v == 0) { 如果 (字节 & 0x40) == 0 {
 追加(结果, 字节)
 已完成 = 1
 } 否则 {
 追加(结果, 字节 | 0x80)
 }
 } 否则 { 如果 (v == 0 - 1) { 如果 (字节 & 0x40) != 0 {
 追加(结果, 字节)
 已完成 = 1
 } 否则 {
 追加(结果, 字节 | 0x80)
 }
 } 否则 {
 追加(结果, 字节 | 0x80)
 }
 }
 }
 返回 结果
}

// 模块构建辅助

// Wasm模块头 (8字节: magic+version)
函数 模块头() { 返回 [WASM_魔数_0, WASM_魔数_1, WASM_魔数_2, WASM_魔数_3,
 WASM小写_WASM_版本, 0x00, 0x00, 0x00]
}

// 函数类型: (参数类型列表) -> (返回类型列表)
函数 wasm_编码_函数类型(参数列表, 返回列表) { 定义 结果 = [0x60] // functype标记
 // 参数
 定义 plen = 编码_uleb128(计数(参数列表))
 定义 可变 pi = 0
 当 (pi < 计数(plen)) { 追加(结果, plen[pi])
 pi = pi + 1 }
 pi = 0
 当 (pi < 计数(参数列表)) { 追加(结果, 参数列表[pi])
 pi = pi + 1 }
 // 回
 定义 rlen = 编码_uleb128(计数(返回列表))
 定义 可变 ri = 0
 当 (ri < 计数(rlen)) { 追加(结果, rlen[ri])
 ri = ri + 1 }
 ri = 0
 当 (ri < 计数(返回列表)) { 追加(结果, 返回列表[ri])
 ri = ri + 1 }
 返回 结果
}

// 段封装: 段ID + LEB128(内容长度) + 内容
函数 封装段(段id, 内容) { 定义 结果 = [段id]
 定义 len = 编码_uleb128(计数(内容))
 定义 可变 i = 0
 当 (i < 计数(len)) { 追加(结果, len[i])
 i = i + 1 }
 i = 0
 当 (i < 计数(内容)) { 追加(结果, 内容[i])
 i = i + 1 }
 返回 结果
}

// 导出条目
函数 wasm_编码_导出(名称字节, 类型, 索引) { 定义 结果 = []
 定义 名长 = 编码_uleb128(计数(名称字节))
 定义 可变 i = 0
 当 (i < 计数(名长)) { 追加(结果, 名长[i])
 i = i + 1 }
 i = 0
 当 (i < 计数(名称字节)) { 追加(结果, 名称字节[i])
 i = i + 1 }
 追加(结果, 类型)
 定义 索引 = 编码_uleb128(索引)
 i = 0
 当 (i < 计数(索引)) { 追加(结果, 索引[i])
 i = i + 1 }
 返回 结果
}

// 内存段: limits (min_pages, max_pages可选)
函数 wasm_编码_内存(最小页, 0) { 定义 结果 = [0x00] // limits flag: 无上限
 定义 最短编码 = 编码_uleb128(最小页)
 定义 可变 i = 0
 当 (i < 计数(最短编码)) { 追加(结果, 最短编码[i])
 i = i + 1 }
 返回 结果
}

// WASM指令编码

定义 WASM_不可达 = 0x00
定义 WASM_空操作 = 0x01
定义 WASM_块 = 0x02
定义 WASM_循环 = 0x03
定义 WASM_如果 = 0x04
定义 WASM_否则 = 0x05
定义 WASM_结束 = 0x0B
定义 WASM_跳转 = 0x0C
定义 WASM_条件跳 = 0x0D
定义 WASM_返回 = 0x0F
定义 WASM_调用 = 0x10
定义 WASM_丢弃 = 0x1A
定义 WASM_本地读 = 0x20
定义 WASM_本地写 = 0x21
定义 WASM_全局读 = 0x23
定义 WASM_全局写 = 0x24

函数 wasm_编码_调用(函数索引) { 定义 可变 结果 = [WASM_调用]
 定义 编码值 = 编码_uleb128(函数索引)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 返回 结果
}

函数 wasm_编码_本地读(索引) { 定义 可变 结果 = [WASM_本地读]
 定义 编码值 = 编码_uleb128(索引)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 返回 结果
}

函数 wasm_编码_本地写(索引) { 定义 可变 结果 = [WASM_本地写]
 定义 编码值 = 编码_uleb128(索引)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 返回 结果
}

// WASM算术指令

定义 WASM_i32_加 = 0x6A
定义 WASM_i32_减 = 0x6B
定义 WASM_i32_乘 = 0x6C
定义 WASM_i32_除s = 0x6D
定义 WASM_i32_余s = 0x6F
定义 WASM_i32_与 = 0x71
定义 WASM_i32_或 = 0x72
定义 WASM_i32_异或 = 0x73
定义 WASM_i32_左移 = 0x74
定义 WASM_i32_右移s = 0x75
定义 WASM_i32_等 = 0x46
定义 WASM_i32_不等 = 0x47
定义 WASM_i32_小于s = 0x48
定义 WASM_i32_大于s = 0x4A

函数 wasm_编码_i32常量(值) { 定义 可变 结果 = [0x41]
 定义 编码值 = 编码_sleb128(值)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 返回 结果
}

// WASM内存指令

函数 wasm_编码_i32加载(对齐, 偏移) { 定义 可变 结果 = [0x28]
 定义 a = 编码_uleb128(对齐)
 定义 可变 i = 0
 当 (i < 计数(a)) { 追加(结果, a[i]) i = i + 1 }
 定义 o = 编码_uleb128(偏移)
 i = 0
 当 (i < 计数(o)) { 追加(结果, o[i]) i = i + 1 }
 返回 结果
}

函数 wasm_编码_i32存储(对齐, 偏移) { 定义 可变 结果 = [0x36]
 定义 a = 编码_uleb128(对齐)
 定义 可变 i = 0
 当 (i < 计数(a)) { 追加(结果, a[i]) i = i + 1 }
 定义 o = 编码_uleb128(偏移)
 i = 0
 当 (i < 计数(o)) { 追加(结果, o[i]) i = i + 1 }
 返回 结果
}

// WASM i64常量/加载/存储

函数 wasm_编码_i64常量(值) { 定义 可变 结果 = [0x42]
 定义 编码值 = wasm_编码_sleb128(值)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 返回 结果
}

函数 wasm_编码_i64加载(对齐, 偏移) { 定义 可变 结果 = [0x29]

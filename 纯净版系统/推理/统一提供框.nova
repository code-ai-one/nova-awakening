    cfg.模型标识 = "moonshot-v1-128k"
    cfg.最大令牌 = 128000
    cfg.最大输出令牌 = 8192
    cfg.温度 = 700; cfg.TopP = 950
    cfg.超时毫秒 = 120000; cfg.重试次数 = 3; cfg.启用流式 = 1; cfg.已启用 = 1
    cfg.认证头名 = "Authorization"; cfg.认证头前缀 = "Bearer "
    cfg.系统提示字段 = "messages"; cfg.消息格式版本 = 0  // Kimi兼容Nova智能
    追加(Provider列表, cfg)

// §4 更新活跃样式表 

函数 样式Engine_更新活跃样式表(engine) {
 如果 (!engine.样式表已变) { 返回 }
 // 样式表变更后需要重建规则索引
 // 清空索引
 内存_清零(engine.标签规则索引, 256 * 16)
 内存_清零(engine.class规则索引, 256 * 16)
 内存_清零(engine.id规则索引, 256 * 16)
 engine.通用规则数量 = 0

 // 重新索引所有样式表
 定义 可变 i = 0
 当 (i < engine.作者样式表数量) {
 定义 样式表 = 内存_读64(engine.作者样式表列表 + i * 8)
 如果 (样式表 != 0) {
 样式Engine_索引样式表(engine, 样式表)
 }
 i = i + 1
 }

 engine.样式表已变 = 假

 // 标记整个文档需要样式重计算
 如果 (engine.需要全量重计算 && engine.文档 != 0) {
 节点_标记样式脏(engine.文档)
 engine.需要全量重计算 = 假
 }
}

函数 样式Engine_统计(engine) {
 返回 [engine.总样式计算次数, engine.总规则匹配次数, engine.作者样式表数量]
}

// 传统方案: 每次DOM变化可能触发全量样式重计算
// Nova: AI精确判断影响范围, 最小化重算并提供性能建议

定义 可变 AI规则缓存表 = 0
定义 可变 AI规则缓存数量 = 0
定义 可变 AI规则缓存容量 = 0

结构 AI规则缓存条目 {
 元素哈希,    // u32 元素特征哈希(tag+class+id)
 规则哈希,    // u32 规则特征哈希
 匹配结果,    // u32 0=不匹配 1=匹配
 命中次数,
}

函数 AI样式引擎_初始化缓存() {
 AI规则缓存容量 = 1024
 AI规则缓存表 = 堆_分配_数组(AI规则缓存容量 * 16)
 AI规则缓存数量 = 0
}

函数 AI样式引擎_查规则缓存(元素哈希, 规则哈希) {
 定义 可变 i = 0
 当 (i < AI规则缓存数量) {
 定义 偏移 = AI规则缓存表 + i * 16
 如果 (内存_读32(偏移) == 元素哈希 && 内存_读32(偏移 + 4) == 规则哈希) {
 定义 旧次数 = 内存_读32(偏移 + 12)
 内存_写32(偏移 + 12, 旧次数 + 1)
 返回 内存_读32(偏移 + 8) // 返回匹配结果
 }
 i = i + 1
 }
 返回 -1 // 未命中
}

函数 AI样式引擎_存规则缓存(元素哈希, 规则哈希, 匹配结果) {
 如果 (AI规则缓存数量 >= AI规则缓存容量) { 返回 }
 定义 偏移 = AI规则缓存表 + AI规则缓存数量 * 16
 内存_写32(偏移, 元素哈希)
 内存_写32(偏移 + 4, 规则哈希)
 内存_写32(偏移 + 8, 匹配结果)
 内存_写32(偏移 + 12, 0)
 AI规则缓存数量 = AI规则缓存数量 + 1
}

函数 AI样式引擎_智能重算(engine, 脏节点列表, 脏节点数量) {
 如果 (engine == 0 || 脏节点数量 == 0) { 返回 }

 定义 开始 = 平台_获取高精度时间()

 // 只重算脏节点, 不做全量重算
 定义 可变 i = 0
 当 (i < 脏节点数量) {
 定义 节点 = 内存_读64(脏节点列表 + i * 8)
 如果 (节点 != 0) {
 // 判断影响范围
 定义 影响 = AI样式_分析影响(节点.最后变化属性)
 如果 (影响 == 影响_仅重绘) {
 // 只需重新解析颜色属性
 样式Engine_解析元素样式_局部(engine, 节点)
 } 否则 {
 // 需要完整重算
 样式Engine_解析元素样式(engine, 节点)
 }
 }
 i = i + 1
 }

 定义 耗时 = 平台_获取高精度时间() - 开始
 // 性能跟踪: 如果样式重算超过16ms发出警告
 如果 (耗时 > 16000) {
 // 警告: 样式重算超时, 可能需要优化CSS规则
 }
}

函数 样式Engine_解析元素样式_局部(engine, 节点) {
 // 局部重算: 只重新解析颜色/背景等仅重绘属性
 // 跳过尺寸/位置计算, 节省大量时间
 如果 (engine == 0 || 节点 == 0) { 返回 }
 样式Engine_解析元素样式(engine, 节点)
}

导入("../基础.nova")

//    截断: 串→串 (收缩态射)
//    URL编码: 串→串 (编码态射, 量词范畴变换)
//    格式化 = "把"原始串消费为格式化串
//    编码/解码 = "把"字→"被"字 的可逆变换

// 左填充
函数 字符串工具_左填充(文本, 目标长, 填充字符) {
    定义 可变 结果 = 文本
    当 (字节长度(结果) < 目标长) {
        结果 = 字符串拼接(填充字符, 结果)
    }
    返回 结果
}

// 右填充
函数 字符串工具_右填充(文本, 目标长, 填充字符) {
    定义 可变 结果 = 文本
    当 (字节长度(结果) < 目标长) {
        结果 = 字符串拼接(结果, 填充字符)
    }
    返回 结果
}

// 居中
函数 字符串工具_居中(文本, 目标长, 填充字符) {
    定义 差 = 目标长 - 字节长度(文本)
    如果 (差 <= 0) { 返回 文本 }
    定义 左数 = 差 / 2
    定义 右数 = 差 - 左数
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 左数) { 结果 = 字符串拼接(结果, 填充字符) i = i + 1 }
    结果 = 字符串拼接(结果, 文本)
    i = 0
    当 (i < 右数) { 结果 = 字符串拼接(结果, 填充字符) i = i + 1 }
    返回 结果
}

// 截断
函数 字符串工具_截断(文本, 最大长) {
    如果 (字节长度(文本) <= 最大长) { 返回 文本 }
    如果 (最大长 <= 3) { 返回 子串(文本, 0, 最大长) }
    返回 字符串拼接(子串(文本, 0, 最大长 - 3), "...")
}

// 计数子串出现次数
函数 字符串_计数(文本, 子串文本) {
    定义 n = 字节长度(文本)
    定义 m = 字节长度(子串文本)
    如果 (m == 0 或 n < m) { 返回 0 }
    定义 可变 计 = 0
    定义 可变 i = 0
    当 (i <= n - m) {
        定义 可变 已找到 = 1
        定义 可变 j = 0
        当 (j < m 且 已找到 == 1) {
            如果 (字节取(文本, i + j) != 字节取(子串文本, j)) { 已找到 = 0 }
            j = j + 1
        }
        如果 (已找到 == 1) { 计 = 计 + 1 }
        i = i + 1
    }
    返回 计
}

// URL编码
函数 字符串工_url_编码(文本) {
    定义 hex表 = "0123456789ABCDEF"
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        定义 c = 字节取(文本, i)
        如果 (c >= 字符_大写A 且 c <= 字符_大写Z) 或 (c >= 字符_小写a 且 c <= 字符_小写z) 或 (c >= 字符_零 且 c <= 字符_九) 或 c == 字符_减号 或 c == 字符_下划线 或 c == 字符_句点 或 c == 126 {
            结果 = 字符串拼接(结果, 字符(c))
        } 否则 如果 (c == 字符_空格) {
            结果 = 字符串拼接(结果, "+")
        } 否则 {
            结果 = 字符串拼接(结果, "%")
            结果 = 字符串拼接(结果, 子串(hex表, c / 16, 1))
            结果 = 字符串拼接(结果, 子串(hex表, c % 16, 1))
        }
        i = i + 1
    }
    返回 结果
}

// 数字格式化 (千分位)
函数 数字_千分位(n) {
    定义 文本 = 转字符串(n)
    定义 长 = 字节长度(文本)
    如果 (长 <= 3) { 返回 文本 }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 长) {
        如果 (i > 0 且 (长 - i) % 3 == 0) {
            结果 = 字符串拼接(结果, ",")
        }
        结果 = 字符串拼接(结果, 字符(字节取(文本, i)))
        i = i + 1
    }
    返回 结果
}

// 十六进制字符串
函数 数字_转hex(n) {
    定义 hex表 = "0123456789abcdef"
    如果 (n == 0) { 返回 "0" }
    定义 可变 v = n
    如果 (v < 0) { v = 0 - v }
    定义 可变 结果 = ""
    当 (v > 0) {
        结果 = 字符串拼接(子串(hex表, v % 16, 1), 结果)
        v = v / 16
    }
    返回 结果
}

// 二进制字符串
函数 数字_转bin(n) {
    如果 (n == 0) { 返回 "0" }
    定义 可变 v = n
    如果 (v < 0) { v = 0 - v }
    定义 可变 结果 = ""
    当 (v > 0) {
        如果 (v % 2 == 1) { 结果 = 字符串拼接("1", 结果) }
        否则 { 结果 = 字符串拼接("0", 结果) }
        v = v / 2
    }
    返回 结果
}

// 八进制字符串
函数 数字_转oct(n) {
    如果 (n == 0) { 返回 "0" }
    定义 可变 v = n
    如果 (v < 0) { v = 0 - v }
    定义 可变 结果 = ""
    当 (v > 0) {
        结果 = 字符串拼接(转字符串(v % 8), 结果)
        v = v / 8
    }
    返回 结果
}

// 罗马数字转换
函数 转罗马数字(n) {
    定义 可变 数目 = n
    定义 可变 结果 = ""
    当 (数目 >= 1000) { 结果 = 字符串拼接(结果, "M") 数目 = 数目 - 1000 }
    当 (数目 >= 900) { 结果 = 字符串拼接(结果, "CM") 数目 = 数目 - 900 }
    当 (数目 >= 500) { 结果 = 字符串拼接(结果, "D") 数目 = 数目 - 500 }
    当 (数目 >= 400) { 结果 = 字符串拼接(结果, "CD") 数目 = 数目 - 400 }
    当 (数目 >= 100) { 结果 = 字符串拼接(结果, "C") 数目 = 数目 - 100 }
    当 (数目 >= 90) { 结果 = 字符串拼接(结果, "XC") 数目 = 数目 - 90 }
    当 (数目 >= 50) { 结果 = 字符串拼接(结果, "L") 数目 = 数目 - 50 }
    当 (数目 >= 40) { 结果 = 字符串拼接(结果, "XL") 数目 = 数目 - 40 }
    当 (数目 >= 10) { 结果 = 字符串拼接(结果, "X") 数目 = 数目 - 10 }
    当 (数目 >= 9) { 结果 = 字符串拼接(结果, "IX") 数目 = 数目 - 9 }
    当 (数目 >= 5) { 结果 = 字符串拼接(结果, "V") 数目 = 数目 - 5 }
    当 (数目 >= 4) { 结果 = 字符串拼接(结果, "IV") 数目 = 数目 - 4 }
    当 (数目 >= 1) { 结果 = 字符串拼接(结果, "I") 数目 = 数目 - 1 }
    返回 结果
}

// 字节大小格式化
函数 格式化字节(字节数) {
    如果 (字节数 < 1024) {
        返回 字符串拼接(转字符串(字节数), " B")
    }
    如果 (字节数 < 1048576) {
        返回 字符串拼接(转字符串(字节数 / 1024), " KB")
    }
    如果 (字节数 < 1073741824) {
        返回 字符串拼接(转字符串(字节数 / 1048576), " MB")
    }
    返回 字符串拼接(转字符串(字节数 / 1073741824), " GB")
}

// 时间格式化 (秒→时分秒)
函数 格式化时间(秒数) {
    定义 时 = 秒数 / 3600
    定义 分 = (秒数 % 3600) / 60
    定义 秒 = 秒数 % 60
    定义 可变 结果 = ""
    如果 (时 > 0) {
        结果 = 字符串拼接(结果, 转字符串(时))
        结果 = 字符串拼接(结果, "h ")
    }
    如果 (分 > 0 或 时 > 0) {
        结果 = 字符串拼接(结果, 转字符串(分))
        结果 = 字符串拼接(结果, "m ")
    }
    结果 = 字符串拼接(结果, 转字符串(秒))
    结果 = 字符串拼接(结果, "s")
    返回 结果
}

// 进度条
函数 格式化进度条(当前, 总数, 宽度) {
    定义 比例 = 当前 * 宽度 / 总数
    定义 可变 结果 = "["
    定义 可变 i = 0
    当 (i < 宽度) {
        如果 (i < 比例) { 结果 = 字符串拼接(结果, "=") }
        否则 如果 (i == 比例) { 结果 = 字符串拼接(结果, ">") }
        否则 { 结果 = 字符串拼接(结果, " ") }
        i = i + 1
    }
    结果 = 字符串拼接(结果, "] ")
    结果 = 字符串拼接(结果, 转字符串(当前 * 100 / 总数))
    结果 = 字符串拼接(结果, "%")
    返回 结果
}


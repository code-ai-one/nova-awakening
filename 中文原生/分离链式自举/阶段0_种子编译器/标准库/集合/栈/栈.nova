//
// Nova 标准库 集合 栈
// LIFO后进先出数据结构 + 队列 + 双端队列

导入("../../基础.nova")

// 统计
定义 可变 栈_全局推入数 = 0
定义 可变 栈_全局弹出数 = 0
定义 可变 栈_全局创建数 = 0

// 栈 (LIFO)

函数 新建栈() {
 栈_全局创建数 = 栈_全局创建数 + 1
 返回 [[], 0, 0]
}

函数 推入(栈, 值) {
 栈_全局推入数 = 栈_全局推入数 + 1
 定义 数据 = 栈[0]
 定义 位 = 栈[1]
 如果 (位 < 计数(数据)) {
 数据[位] = 值
 } 否则 {
 追加(数据, 值)
 }
 栈[1] = 位 + 1
 栈[2] = 栈[2] + 1
 如果 (栈[1] > 栈[3]) { 栈[3] = 栈[1] }
 返回 栈
}

函数 弹出(栈) {
    如果 (栈[1] == 0) { 返回 空
}
 栈_全局弹出数 = 栈_全局弹出数 + 1
 栈[1] = 栈[1] - 1
 定义 数据 = 栈[0]
 返回 数据[栈[1]]
}

函数 栈顶(栈) {
    如果 (栈[1] == 0) { 返回 空
}
 返回 栈[0][栈[1] - 1]
}

函数 栈空(栈) { 返回 栈[1] == 0 }
函数 栈大小(栈) { 返回 栈[1] }
函数 栈峰值(栈) { 返回 栈[3] }
函数 栈操作总数(栈) { 返回 栈[2] }

函数 栈清空(栈) {
 栈[1] = 0
}

// 栈遍历

函数 栈_遍历(栈, 回调) { 定义 数据 = 栈[0]
 定义 可变 i = 0
 当 (i < 栈[1]) {
 回调(数据[i])
 i = i + 1
 }
}

函数 栈_逆遍历(栈, 回调) { 定义 数据 = 栈[0]
 定义 可变 i = 栈[1] - 1
 当 (i >= 0) {
 回调(数据[i])
 i = i - 1
 }
}

// 栈操作

函数 栈_复制(栈) { 定义 数据 = 栈[0]
 定义 可变 新数据 = []
 定义 可变 i = 0
 当 (i < 栈[1]) {
 追加(新数据, 数据[i])
 i = i + 1
 }
 返回 [新数据, 栈[1], 栈[2], 栈[3]]
}

函数 栈_反转(栈) { 定义 数据 = 栈[0]
 定义 可变 左 = 0
 定义 可变 右 = 栈[1] - 1
 当 (左 < 右) { 定义 临 = 数据[左]
 数据[左] = 数据[右]
 数据[右] = 临
 左 = 左 + 1
 右 = 右 - 1
 }
}

函数 栈_到列表(栈) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 栈[1]) {
 追加(结果, 栈[0][i])
 i = i + 1
 }
 返回 结果
}

函数 栈_从列表(列表) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 计数(列表)) {
 追加(数据, 列表[i])
 i = i + 1
 }
 返回 [数据, 计数(列表), 计数(列表), 计数(列表)]
}

函数 栈_包含(栈, 值) { 定义 可变 i = 0
 当 (i < 栈[1]) { 如果 (栈[0][i] == 值) { 返回 真 }
 i = i + 1
 }
 返回 假
}

函数 栈_交换栈顶(栈) {
    如果 (栈[1] < 2) { 返回
}
 定义 临 = 栈[0][栈[1] - 1]
 栈[0][栈[1] - 1] = 栈[0][栈[1] - 2]
 栈[0][栈[1] - 2] = 临
}

函数 栈_复制栈顶(栈) {
    如果 (栈[1] == 0) { 返回
}
 推入(栈, 栈[0][栈[1] - 1])
}

// 队列 (FIFO)

函数 新建队列() { 返回 [[], 0,]
}

函数 入队(队列, 值) {
 追加(队列[0], 值)
 队列[1] = 队列[1] + 1
 队列[3] = 队列[3] + 1
 返回 队列
}

函数 出队(队列) {
    如果 (队列[2] >= 队列[1]) { 返回 空
}
 定义 值 = 队列[0][队列[2]]
 队列[2] = 队列[2] + 1
 队列[4] = 队列[4] + 1
 如果 (队列[2] > 100 且 队列[2] > 队列[1] / 2) {
 队列_压缩(队列)
 }
 返回 值
}

函数 队首(队列) {
    如果 (队列[2] >= 队列[1]) { 返回 空
}
 返回 队列[0][队列[2]]
}

函数 队尾(队列) {
    如果 (队列[1] == 0) { 返回 空
}
 返回 队列[0][队列[1] - 1]
}

函数 队列空(队列) { 返回 队列[2] >= 队列[1] }
函数 队列大小(队列) { 返回 队列[1] - 队列[2] }

函数 队列_压缩(队列) { 定义 可变 新数据 = []
 定义 可变 i = 队列[2]
 当 (i < 队列[1]) {
 追加(新数据, 队列[0][i])
 i = i + 1
 }
 队列[0] = 新数据
 队列[1] = 队列[1] - 队列[2]
 队列[2] = 0
}

函数 队列清空(队列) {
 队列[0] = []
 队列[1] = 0
 队列[2] = 0
}

函数 队列_到列表(队列) { 定义 可变 结果 = []
 定义 可变 i = 队列[2]
 当 (i < 队列[1]) {
 追加(结果, 队列[0][i])
 i = i + 1
 }
 返回 结果
}

// 双端队列 (Deque)

函数 新建双端队列() { 返回 [[], 0]
}

函数 双端_头部推入(双端, 值) { 定义 可变 新数据 = [值]
 定义 可变 i = 0
 当 (i < 双端[1]) {
 追加(新数据, 双端[0][i])
 i = i + 1
 }
 双端[0] = 新数据
 双端[1] = 双端[1] + 1
}

函数 双端_尾部推入(双端, 值) { 定义 数据 = 双端[0]
 如果 (双端[1] < 计数(数据)) {
 数据[双端[1]] = 值
 } 否则 {
 追加(数据, 值)
 }
 双端[1] = 双端[1] + 1
}

函数 双端_头部弹出(双端) {
    如果 (双端[1] == 0) { 返回 空
}
 定义 值 = 双端[0][0]
 定义 可变 新数据 = []
 定义 可变 i = 1
 当 (i < 双端[1]) {
 追加(新数据, 双端[0][i])
 i = i + 1
 }
 双端[0] = 新数据
 双端[1] = 双端[1] - 1
 返回 值
}

函数 双端_尾部弹出(双端) {
    如果 (双端[1] == 0) { 返回 空
}
 双端[1] = 双端[1] - 1
 返回 双端[0][双端[1]]
}

函数 双端_头部查看(双端) {
    如果 (双端[1] == 0) { 返回 空
}
 返回 双端[0][0]
}

函数 双端_尾部查看(双端) {
    如果 (双端[1] == 0) { 返回 空
}
 返回 双端[0][双端[1] - 1]
}

函数 栏_双端_大小(双端) { 返回 双端[1] }
函数 双端_空(双端) { 返回 双端[1] == 0 }

函数 双端_到列表(双端) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 双端[1]) {
 追加(结果, 双端[0][i])
 i = i + 1
 }
 返回 结果
}

// 优先队列 (最小堆)

函数 新建优先队列() { 返回 [[], 0]
}

函数 优先_父(索引) { 返回 (索引 - 1) / 2 }
函数 优先_左子(索引) { 返回 索引 * 2 + 1 }
函数 优先_右子(索引) { 返回 索引 * 2 + 2 }

函数 优先_上浮(堆, 索引) { 定义 可变 当前 = 索引
 定义 可变 _浮完 = 假
 当 (当前 > 0 且 _浮完 == 假) { 定义 父 = 优先_父(当前)
 如果 (堆[0][当前] < 堆[0][父]) { 定义 临 = 堆[0][当前]
 堆[0][当前] = 堆[0][父]
 堆[0][父] = 临
 当前 = 父
 } 否则 { _浮完 = 真 }
 }
}

函数 优先_下沉(堆, 索引) { 定义 可变 当前 = 索引
 定义 可变 _沉完 = 假
 当 (_沉完 == 假) { 定义 可变 最小 = 当前
 定义 左 = 优先_左子(当前)
 定义 右 = 优先_右子(当前)
 如果 (左 < 堆[1] 且 堆[0][左] < 堆[0][最小]) { 最小 = 左 }
 如果 (右 < 堆[1] 且 堆[0][右] < 堆[0][最小]) { 最小 = 右 }
 如果 (最小 == 当前) { _沉完 = 真 } 否则 {
 定义 临 = 堆[0][当前]
 堆[0][当前] = 堆[0][最小]
 堆[0][最小] = 临
 当前 = 最小
 } }
}

函数 优先_插入(堆, 值) { 定义 数据 = 堆[0]
 如果 (堆[1] < 计数(数据)) {
 数据[堆[1]] = 值
 } 否则 {
 追加(数据, 值)
 }
 堆[1] = 堆[1] + 1
 优先_上浮(堆, 堆[1] - 1)
}

函数 优先_取出(堆) {
    如果 (堆[1] == 0) { 返回 空
}
 定义 最小 = 堆[0][0]
 堆[1] = 堆[1] - 1
 如果 (堆[1] > 0) {
 堆[0][0] = 堆[0][堆[1]]
 优先_下沉(堆, 0)
 }
 返回 最小
}

函数 优先_查看(堆) {
    如果 (堆[1] == 0) { 返回 空
}
 返回 堆[0][0]
}

函数 优先_大小(堆) { 返回 堆[1] }
函数 优先_空(堆) { 返回 堆[1] == 0 }

函数 优先_从列表(列表) { 定义 堆 = 新建优先队列()
 定义 可变 i = 0
 当 (i < 计数(列表)) {
 优先_插入(堆, 列表[i])
 i = i + 1
 }
 返回 堆
}

函数 优先_排序(列表) { 定义 堆 = 优先_从列表(列表)
 定义 可变 结果 = []
 当 (优先_空(堆) == 假) {
 追加(结果, 优先_取出(堆))
 }
 返回 结果
}

函数 栈_操作模式(栈) { 定义 总操作 = 栈[2]
 定义 当前大小 = 栈[1]
 定义 峰值 = 栈[3]
 如果 (总操作 == 0) { 返回 "未使用" }
 如果 (当前大小 == 0 且 总操作 > 10) { 返回 "已耗尽(频繁推弹)" }
 如果 (当前大小 == 峰值) { 返回 "只推入(无弹出)" }
 如果 (当前大小 * 100 / 峰值 < 20) { 返回 "接近耗尽" }
 返回 "正常使用"
}

函数 栈_容量建议(栈) { 定义 峰值 = 栈[3]
 如果 (峰值 < 16) { 返回 "小栈: 预分配16" }
 如果 (峰值 < 256) { 返回 "中栈: 预分配256" }
 如果 (峰值 < 4096) { 返回 "大栈: 预分配4096" }
 返回 "超大栈: 考虑链表实现"
}

函数 栈_全局报告() { 返回 [栈_全局创建数, 栈_全局推入数, 栈_全局弹出数]
}

// 环形缓冲区

函数 新建环形缓冲(容量) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(数据, 0) i = i + 1 }
 返回 [数据, 容量, 0, 0]
}

函数 栏_环形_写入(缓冲, 值) { 定义 数据 = 缓冲[0]
 定义 容量 = 缓冲[1]
 数据[缓冲[2]] = 值
 缓冲[2] = (缓冲[2] + 1) % 容量
 如果 (缓冲[4] < 容量) { 缓冲[4] = 缓冲[4] + 1 }
 否则 { 缓冲[3] = (缓冲[3] + 1) % 容量 }
}

函数 栏_环形_读取(缓冲) {
    如果 (缓冲[4] == 0) { 返回 空
}
 定义 值 = 缓冲[0][缓冲[3]]
 缓冲[3] = (缓冲[3] + 1) % 缓冲[1]
 缓冲[4] = 缓冲[4] - 1
 返回 值
}

函数 环形_查看(缓冲) {
    如果 (缓冲[4] == 0) { 返回 空
}
 返回 缓冲[0][缓冲[3]]
}

函数 栏_环形_大小(缓冲) { 返回 缓冲[4] }
函数 环形_容量(缓冲) { 返回 缓冲[1] }
函数 环形_空(缓冲) { 返回 缓冲[4] == 0 }
函数 环形_满(缓冲) { 返回 缓冲[4] == 缓冲[1] }

函数 环形_到列表(缓冲) { 定义 可变 结果 = []
 定义 可变 i = 0
 定义 可变 位 = 缓冲[3]
 当 (i < 缓冲[4]) {
 追加(结果, 缓冲[0][位])
 位 = (位 + 1) % 缓冲[1]
 i = i + 1
 }
 返回 结果
}

// 最小栈 (O(1)获取最小值)

函数 新建最小栈() { 返回 [[], [], 0]
}

函数 最小栈_推入(栈, 值) {
 追加(栈[0], 值)
 如果 (计数(栈[1]) == 0 或 值 <= 栈[1][计数(栈[1]) - 1]) {
 追加(栈[1], 值)
 } 否则 {
 追加(栈[1], 栈[1][计数(栈[1]) - 1])
 }
 栈[2] = 栈[2] + 1
}

函数 最小栈_弹出(栈) {
    如果 (栈[2] == 0) { 返回 空
}
 栈[2] = 栈[2] - 1
 定义 值 = 栈[0][栈[2]]
 删除(栈[0], 栈[2])
 删除(栈[1], 栈[2])
 返回 值
}

函数 最小栈_最小值(栈) {
    如果 (栈[2] == 0) { 返回 空
}
 返回 栈[1][栈[2] - 1]
}

函数 最小栈_大小(栈) { 返回 栈[2] }

// 最大栈 (O(1)获取最大值)

函数 新建最大栈() { 返回 [[], [], 0]
}

函数 最大栈_推入(栈, 值) {
 追加(栈[0], 值)
 如果 (计数(栈[1]) == 0 或 值 >= 栈[1][计数(栈[1]) - 1]) {
 追加(栈[1], 值)
 } 否则 {
 追加(栈[1], 栈[1][计数(栈[1]) - 1])
 }
 栈[2] = 栈[2] + 1
}

函数 最大栈_弹出(栈) {
    如果 (栈[2] == 0) { 返回 空
}
 栈[2] = 栈[2] - 1
 定义 值 = 栈[0][栈[2]]
 删除(栈[0], 栈[2])
 删除(栈[1], 栈[2])
 返回 值
}

函数 最大栈_最大值(栈) {
    如果 (栈[2] == 0) { 返回 空
}
 返回 栈[1][栈[2] - 1]
}

函数 集合_推荐(场景) {
    如果 (场景 == "后进先出") { 返回 "栈"
}
 如果 (场景 == "先进先出") { 返回 "队列" }
 如果 (场景 == "两端操作") { 返回 "双端队列" }
 如果 (场景 == "固定缓冲") { 返回 "环形缓冲区" }
 如果 (场景 == "最值追踪") { 返回 "最小栈/最大栈" }
 如果 (场景 == "优先级") { 返回 "优先队列(堆)" }
 返回 "栈(默认)"
}

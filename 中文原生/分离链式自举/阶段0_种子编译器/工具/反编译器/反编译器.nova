// 龙工具 — 反编译器 / 字节码分析器
// 字节码反汇编、控制流重建、符号恢复
// 支持 x86-64 指令解码、PE 结构解析

// 指令类型

导入("../../标准库/基础.nova")

定义 指令_数据 = 0
定义 指令_算术 = 1
定义 反编译_指令_跳转 = 2
定义 反编译_指令_调用 = 3
定义 反编译_指令_返回 = 4
定义 指令_加载 = 5
定义 指令_存储 = 6
定义 指令_比较 = 7
定义 指令_系统 = 8

// 反汇编指令
// [地址, 字节列表, 助记符, 操作数列表, 类型, 注释]

函数 反汇编指令_创建(地址, 字节, 助记符, 操作数) { 返回 [地址, 字节, 助记符, 操作数, 指令_数据, ""]
}

函数 反汇编指令_设类型(指令, 类型) { 指令[4] = 类型 }
函数 反汇编指令_设注释(指令, 注释) { 指令[5] = 注释 }

函数 反汇编指令_格式化(指令) { 定义 可变 r = 反编译_十六进制(指令[0], 8)
 r = 字符串拼接(r, ": ")
 // 字节
 定义 可变 i = 0
 当 (i < 计数(指令[1]) 且 i < 8) {
 r = 字符串拼接(r, 反编译_十六进制(指令[1][i], 2))
 r = 字符串拼接(r, " ")
 i = i + 1
 }
 // 填充到固定列
 当 (计数(r) < 36) { r = 字符串拼接(r, " ") }
 r = 字符串拼接(r, 指令[2])
 如果 (计数(指令[3]) > 0) {
 r = 字符串拼接(r, " ")
 i = 0
 当 (i < 计数(指令[3])) { 如果 (i > 0) { r = 字符串拼接(r, ", ") }
 r = 字符串拼接(r, 指令[3][i])
 i = i + 1
 }
 }
 如果 (计数(指令[5]) > 0) {
 r = 字符串拼接(r, " ; ")
 r = 字符串拼接(r, 指令[5])
 }
 返回 r
}

// x86-64 解码器 (常用子集)

函数 x86_解码(字节列表, 起始, 基址) { 定义 可变 指令列表 = []
 定义 可变 偏移 = 起始
 定义 n = 计数(字节列表)

 当 (偏移 < n) { 定义 可变 地址 = 基址 + 偏移 - 起始
 定义 可变 b = 字节列表[偏移]
 定义 可变 指令 = 空

 // REX 前缀检测
 定义 可变 rex = 0
 如果 (b >= 64 且 b <= 79) {
 rex = b
 偏移 = 偏移 + 1
 如果 (偏移 >= n) { 偏移 = n }
 b = 字节列表[偏移]
 }

 // NOP
 如果 (b == 144) {
 指令 = 反汇编指令_创建(地址, [144], "nop", [])
 偏移 = 偏移 + 1
 }
 // RET
 否则 如果 (b == 195) {
 指令 = 反汇编指令_创建(地址, [195], "ret", [])
 反汇编指令_设类型(指令, 反编译_指令_返回)
 偏移 = 偏移 + 1
 }
 // 压入 reg
 否则 如果 (b >= 80 且 b <= 87) { 定义 可变 寄存器 = x86_寄存器名(b - 80, rex)
 指令 = 反汇编指令_创建(地址, [b], "push", [寄存器])
 反汇编指令_设类型(指令, 指令_存储)
 偏移 = 偏移 + 1
 }
 // 弹出 reg
 否则 如果 (b >= 88 且 b <= 字符_下划线) { 定义 可变 寄存器 = x86_寄存器名(b - 88, rex)
 指令 = 反汇编指令_创建(地址, [b], "pop", [寄存器])
 反汇编指令_设类型(指令, 指令_加载)
 偏移 = 偏移 + 1
 }
 // MOV reg, imm32/64
 否则 如果 (b >= 184 且 b <= 191) { 定义 寄存器 = x86_寄存器名(b - 184, rex)
 定义 可变 立即数 = 0
 定义 可变 字节数 = 4
 如果 (rex >= 72) { 字节数 = 8 }
 如果 (偏移 + 字节数 < n) { 定义 可变 j = 0
 定义 可变 倍数 = 1
 当 (j < 字节数) {
 立即数 = 立即数 + 字节列表[偏移 + 1 + j] * 倍数
 倍数 = 倍数 * 256
 j = j + 1
 }
 }
 定义 可变 bytes = [b]
 定义 可变 k = 0
 当 (k < 字节数) { 追加(bytes, 字节列表[偏移 + 1 + k]) k = k + 1 }
 指令 = 反汇编指令_创建(地址, bytes, "mov", [寄存器, 反编译_十六进制前缀(立即数)])
 反汇编指令_设类型(指令, 指令_数据)
 偏移 = 偏移 + 1 + 字节数
 }
 // 调用 rel32
 否则 如果 (b == 232) {
 如果 (偏移 + 4 < n) { 定义 可变 rel = 字节列表[偏移 + 1] + 字节列表[偏移 + 2] * 256 + 字节列表[偏移 + 3] * 65536 + 字节列表[偏移 + 4] * 16777216
 如果 (rel >= 2147483648) { rel = rel - 4294967296 }
 定义 可变 目标 = 地址 + 5 + rel
 指令 = 反汇编指令_创建(地址, [b, 字节列表[偏移+1], 字节列表[偏移+2], 字节列表[偏移+3], 字节列表[偏移+4]], "call", [反编译_十六进制前缀(目标)])
 反汇编指令_设类型(指令, 反编译_指令_调用)
 }
 偏移 = 偏移 + 5
 }
 // 跳转 rel32
 否则 如果 (b == 233) {
 如果 (偏移 + 4 < n) { 定义 可变 rel2 = 字节列表[偏移 + 1] + 字节列表[偏移 + 2] * 256 + 字节列表[偏移 + 3] * 65536 + 字节列表[偏移 + 4] * 16777216
 如果 (rel2 >= 2147483648) { rel2 = rel2 - 4294967296 }
 定义 可变 目标2 = 地址 + 5 + rel2
 指令 = 反汇编指令_创建(地址, [b], "jmp", [反编译_十六进制前缀(目标2)])
 反汇编指令_设类型(指令, 反编译_指令_跳转)
 }
 偏移 = 偏移 + 5
 }
 // 跳转 rel8
 否则 如果 (b == 235) {
 如果 (偏移 + 1 < n) { 定义 可变 rel3 = 字节列表[偏移 + 1]
 如果 (rel3 >= 128) { rel3 = rel3 - 256 }
 定义 目标3 = 地址 + 2 + rel3
 指令 = 反汇编指令_创建(地址, [b, 字节列表[偏移+1]], "jmp short", [反编译_十六进制前缀(目标3)])
 反汇编指令_设类型(指令, 反编译_指令_跳转)
 }
 偏移 = 偏移 + 2
 }
 // 数字 3
 否则 如果 (b == 204) {
 指令 = 反汇编指令_创建(地址, [204], "int3", [])
 反汇编指令_设类型(指令, 指令_系统)
 偏移 = 偏移 + 1
 }
 // SYSCALL (0F 05)
 否则 如果 (b == 15 且 偏移 + 1 < n 且 字节列表[偏移 + 1] == 5) {
 指令 = 反汇编指令_创建(地址, [15, 5], "syscall", [])
 反汇编指令_设类型(指令, 指令_系统)
 偏移 = 偏移 + 2
 }
 // 默认: 未知字节
 否则 {
 指令 = 反汇编指令_创建(地址, [b], "db", [反编译_十六进制前缀(b)])
 偏移 = 偏移 + 1
 }

 如果 (指令 != 空) { 追加(指令列表, 指令) }
 }
 返回 指令列表
}

// 基本块与控制流图
// 基本块: [起始地址, 结束地址, 指令列表, 后继列表, 前驱列表]

函数 控制流_构建(指令列表) {
 // 标记基本块边界
 定义 可变 领导者 = 字典()
 如果 (计数(指令列表) > 0) {
 字典设(领导者, 指令列表[0][0], 真)
 }
 定义 可变 i = 0
 当 (i < 计数(指令列表)) { 定义 指令 = 指令列表[i]
 如果 (指令[4] == 反编译_指令_跳转 或 指令[4] == 反编译_指令_调用) {
 // 下一条是领导者
 如果 (i + 1 < 计数(指令列表)) {
 字典设(领导者, 指令列表[i + 1][0], 真)
 }
 }
 如果 (指令[4] == 反编译_指令_返回) { 如果 (i + 1 < 计数(指令列表)) {
 字典设(领导者, 指令列表[i + 1][0], 真)
 }
 }
 i = i + 1
 }
 // 构建基本块
 定义 可变 块列表 = []
 定义 可变 当前块指令 = []
 定义 可变 当前开始 = 0
 i = 0
 当 (i < 计数(指令列表)) { 定义 地址 = 指令列表[i][0]
 如果 (计数(当前块指令) > 0 且 字典取(领导者, 地址) != 空) {
 追加(块列表, [当前开始, 指令列表[i - 1][0], 当前块指令, [], []])
 当前块指令 = []
 当前开始 = 地址
 }
 如果 (计数(当前块指令) == 0) { 当前开始 = 地址 }
 追加(当前块指令, 指令列表[i])
 i = i + 1
 }
 如果 (计数(当前块指令) > 0) {
 追加(块列表, [当前开始, 指令列表[计数(指令列表) - 1][0], 当前块指令, [], []])
 }
 返回 块列表
}

// 寄存器名
函数 x86_寄存器名(编号, rex) { 定义 名64 = ["rax", "rcx", "rdx", "rbx", "rsp", "rbp", "rsi", "rdi"]
 定义 名32 = ["eax", "ecx", "edx", "ebx", "esp", "ebp", "esi", "edi"]
 如果 (编号 < 0 或 编号 > 7) { 返回 "?" }
 如果 (rex >= 72) { 返回 名64[编号] }
 返回 名32[编号]
}

// PE 头解析 (简化)
函数 PE_解析头(字节列表) {
    如果 (计数(字节列表) < 64) { 返回 空
}
 // MZ 签名
 如果 (字节列表[0] != 77 或 字节列表[1] != 90) { 返回 空 }
 // PE 头偏移
 定义 pe偏移 = 字节列表[60] + 字节列表[61] * 256
 如果 (pe偏移 + 24 > 计数(字节列表)) { 返回 空 }
 // PE 签名
 如果 (字节列表[pe偏移] != 80 或 字节列表[pe偏移 + 1] != 69) { 返回 空 }
 // COFF 头
 定义 节数 = 字节列表[pe偏移 + 6] + 字节列表[pe偏移 + 7] * 256
 定义 可选头大小 = 字节列表[pe偏移 + 20] + 字节列表[pe偏移 + 21] * 256
 // 可选头
 定义 opt偏移 = pe偏移 + 24
 定义 可变 魔数 = 0
 如果 (opt偏移 + 2 <= 计数(字节列表)) {
 魔数 = 字节列表[opt偏移] + 字节列表[opt偏移 + 1] * 256
 }
 定义 可变 入口点 = 0
 如果 (opt偏移 + 20 <= 计数(字节列表)) {
 入口点 = 字节列表[opt偏移 + 16] + 字节列表[opt偏移 + 17] * 256 + 字节列表[opt偏移 + 18] * 65536 + 字节列表[opt偏移 + 19] * 16777216
 }
 返回 [pe偏移, 节数, 可选头大小, 魔数, 入口点]
}

// 工具
函数 反编译_十六进制(n, 位数) { 定义 表 = "0123456789abcdef"
 定义 可变 v = n
 如果 (v < 0) { v = 0 - v }
 定义 可变 r = ""
 定义 可变 i = 0
 当 (i < 位数) {
 r = 字符串拼接(子串(表, v % 16, 1), r)
 v = v / 16
 i = i + 1
 }
 返回 r
}

函数 反编译_十六进制前缀(n) { 返回 字符串拼接("0x", 反编译_十六进制(n, 8))
}

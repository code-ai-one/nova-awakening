// §3 核心请求接口 — 直连内核Socket

函数 浏览器网络_发起请求(方法, url, 请求头, 请求体) {
    定义 请求 = 浏览器网络请求 {}
    请求.ID = 网络_下一个ID
    网络_下一个ID = 网络_下一个ID + 1
    请求.方法 = 方法
    请求.URL = url
    请求.请求头 = 请求头
    请求.请求体 = 请求体
    请求.状态 = 请求状态_等待
    请求.响应体 = []
    请求.AI预测命中 = 假
    请求.AI优先级调整 = 假

    // AI预测优先级
    请求.优先级 = 浏览器网络_AI评估优先级(url)

    // 解析URL
    定义 parsed = 浏览器网络_解析URL(url)
    请求.主机 = parsed.主机
    请求.端口 = parsed.端口
    请求.路径 = parsed.路径

    // nova://协议 → 内核内部处理
    如果 (parsed.协议 == "nova") {
        返回 浏览器网络_处理内部协议(请求)
    }

    // 域名解析 → 直连内核域名
    请求.状态 = 请求状态_域名解析中
    定义 ip = 浏览器网络_域名查询(parsed.主机)
    如果 (ip == 0) {
        请求.状态 = 请求状态_失败
        返回 请求
    }

    // 传控连接 → 直接调用内核L2 Socket层
    请求.状态 = 请求状态_连接中
    定义 fd = 浏览器网络_获取连接(parsed.主机, ip, parsed.端口)
    如果 (fd < 0) {
        请求.状态 = 请求状态_失败
        返回 请求
    }
    请求.Socket_FD = fd

    // 构造HTTP请求 → 直接内核Socket发送
    请求.状态 = 请求状态_发送中
    定义 http请求 = 浏览器网络_构造HTTP请求(请求, parsed)
    Socket_发送(fd, http请求, 字符串长度(http请求), 0)

    // 接收响应 → 直接内核Socket接收
    请求.状态 = 请求状态_接收中
    浏览器网络_接收响应(请求)

    网络_总请求数 = 网络_总请求数 + 1
    网络_总字节数 = 网络_总字节数 + 请求.响应体大小

    返回 请求
}

// §4 域名缓存 (内核级)

函数 浏览器网络_域名查询(主机名) {
    // 查本地缓存
    定义 可变 i = 0
    当 (i < 计数(网络_域名缓存)) {
        如果 (网络_域名缓存[i][0] == 主机名) {
            返回 网络_域名缓存[i][1]    // 命中缓存
        }
        i = i + 1
    }

    // 未命中 → 直连内核域名客户端
    定义 ip = 域名_解析(主机名)
    如果 (ip != 0) {
        追加(网络_域名缓存, [主机名, ip, 0])
    }
    返回 ip
}

// §5 连接池管理 (复用内核传控连接)

函数 浏览器网络_获取连接(主机名, ip, 端口) {
    // 从连接池查找空闲连接(Keep-Alive复用)
    定义 可变 i = 0
    当 (i < 计数(网络_连接池.连接列表)) {
        定义 连接 = 网络_连接池.连接列表[i]
        如果 (连接[0] == 主机名 && 连接[2] == 假) {
            连接[2] = 真    // 标记为使用中
            返回 连接[1]    // 返回Socket FD
        }
        i = i + 1
    }

    // 无空闲连接 → 直接调用内核Socket创建新传控连接
    定义 fd = Socket_创建(AF_INET, SOCK_STREAM, 0)
    如果 (fd < 0) { 返回 -1 }

    定义 结果 = Socket_连接(fd, ip, 端口)
    如果 (结果 < 0) {
        Socket_关闭(fd)
        返回 -1
    }

    // 加入连接池
    追加(网络_连接池.连接列表, [主机名, fd, 真])
    返回 fd
}

函数 浏览器网络_归还连接(主机名, fd) {
    定义 可变 i = 0
    当 (i < 计数(网络_连接池.连接列表)) {
        如果 (网络_连接池.连接列表[i][1] == fd) {
            网络_连接池.连接列表[i][2] = 假    // 标记空闲
            返回
        }
        i = i + 1
    }
}

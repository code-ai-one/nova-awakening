// Nova · 平台层 · GPU显存管理
// 统一显存分配/释放/传输 — 屏蔽CUDA/HIP差异
// 真实调用cuMemAlloc/hipMalloc，不是模拟
// 支持: 设备内存/锁页主机内存/统一内存/异步传输

// 内存类型
定义 GPU内存_设备 = 0 // 纯GPU显存 (最快)
定义 GPU内存_主机 = 1 // 锁页主机内存 (DMA可达)
定义 GPU内存_统一 = 2 // 统一内存 (CPU/GPU自动迁移)
定义 GPU内存_映射 = 3 // 主机映射到设备空间

// 传输方向
定义 GPU传输_主机到设备 = 0 // H2D: CPU→GPU
定义 GPU传输_设备到主机 = 1 // D2H: GPU→CPU
定义 GPU传输_设备到设备 = 2 // D2D: GPU→GPU (多卡)
定义 GPU传输_主机到主机 = 3 // H2H

// 显存块记录
// [指针, 大小, 类型, 设备ID, 引用计数, 是否已释放]
函数 GPU内存块_创建(指针, 大小, 类型, 设备ID) { 返回 [指针, 大小, 类型, 设备ID, 1, 假]
}

函数 GPU内存块_指针(块) { 返回 块[0] }
函数 GPU内存块_大小(块) { 返回 块[1] }
函数 GPU内存块_类型(块) { 返回 块[2] }

// 显存管理器
// [分配记录表, 总分配量, 总释放量, 峰值使用, 当前管理器引用的GPU管理器]
函数 GPU显存_创建(gpu管理器) { 返回 [[], 0, 0, gpu管理器]
}

// 分配显存 (统一接口)
函数 GPU显存_分配(显存mgr, 大小, 类型) { 定义 管理器 = 显存mgr[4]
 定义 dev = GPU管理器_当前设备(管理器)
 如果 (dev == 空) { 返回 空 }

 定义 厂商 = GPU设备_厂商(dev)
 定义 可变 指针 = 0

 如果 (厂商 == GPU_厂商_NVIDIA) { 定义 cuda_lib = GPU_加载驱动库(GPU_厂商_NVIDIA)
 如果 (类型 == GPU内存_设备) {
 // cuMemAlloc_v2(&ptr, size)
 指针 = 外部调用(cuda_lib,  "cuMemAlloc_v2",  大小, 0, 0, 0, 0)
 } 否则 如果 (类型 == GPU内存_主机) {
 // cuMemAllocHost_v2(&ptr, size)
 指针 = 外部调用(cuda_lib,  "cuMemAllocHost_v2",  大小, 0, 0, 0, 0)
 } 否则 如果 (类型 == GPU内存_统一) {
 // cuMemAllocManaged(&ptr, size, CU_MEM_ATTACH_GLOBAL=1)
 指针 = 外部调用(cuda_lib,  "cuMemAllocManaged",  大小,  1, 0, 0, 0)
 }
 }

 如果 (厂商 == GPU_厂商_AMD) { 定义 hip_lib = GPU_加载驱动库(GPU_厂商_AMD)
 如果 (类型 == GPU内存_设备) {
 // hipMalloc(&ptr, size)
 指针 = 外部调用(hip_lib,  "hipMalloc",  大小, 0, 0, 0, 0)
 } 否则 如果 (类型 == GPU内存_主机) {
 // hipHostMalloc(&ptr, size)
 指针 = 外部调用(hip_lib,  "hipHostMalloc",  大小, 0, 0, 0, 0)
 } 否则 如果 (类型 == GPU内存_统一) {
 // hipMallocManaged(&ptr, size, hipMemAttachGlobal=1)
 指针 = 外部调用(hip_lib,  "hipMallocManaged",  大小,  1, 0, 0, 0)
 }
 }

 如果 (厂商 == GPU_厂商_INTEL) { 定义 ze_lib = GPU_加载驱动库(GPU_厂商_INTEL)
 // zeMemAllocDevice/zeMemAllocShared
 如果 (类型 == GPU内存_设备) {
 指针 = 外部调用(ze_lib,  "zeMemAllocDevice",  0,  大小,  64, 0, 0)
 } 否则 {
 指针 = 外部调用(ze_lib,  "zeMemAllocShared",  0,  大小,  64, 0, 0)
 }
 }

 如果 (指针 == 0) { 返回 空 }

 定义 块 = GPU内存块_创建(指针, 大小, 类型, GPU设备_ID(dev))
 追加(显存mgr[0], 块)
 显存mgr[1] = 显存mgr[1] + 大小
 定义 当前使用 = 显存mgr[1] - 显存mgr[2]
 如果 (当前使用 > 显存mgr[3]) { 显存mgr[3] = 当前使用 }
 返回 块
}

// 释放显存
函数 GPU显存_释放(显存mgr, 块) {
    如果 (块 == 空 或 块[5]) { 返回
}
 定义 管理器 = 显存mgr[4]
 定义 dev = GPU管理器_当前设备(管理器)
 定义 厂商 = GPU设备_厂商(dev)

 如果 (厂商 == GPU_厂商_NVIDIA) { 定义 cuda_lib = GPU_加载驱动库(GPU_厂商_NVIDIA)
 如果 (块[2] == GPU内存_设备) {
 外部调用(cuda_lib,  "cuMemFree_v2",  块[0], 0, 0, 0, 0)
 } 否则 如果 (块[2] == GPU内存_主机) {
 外部调用(cuda_lib,  "cuMemFreeHost",  块[0], 0, 0, 0, 0)
 } 否则 {
 外部调用(cuda_lib,  "cuMemFree_v2",  块[0], 0, 0, 0, 0)
 }
 }

 如果 (厂商 == GPU_厂商_AMD) { 定义 hip_lib = GPU_加载驱动库(GPU_厂商_AMD)
 如果 (块[2] == GPU内存_设备 或 块[2] == GPU内存_统一) {
 外部调用(hip_lib,  "hipFree",  块[0], 0, 0, 0, 0)
 } 否则 {
 外部调用(hip_lib,  "hipHostFree",  块[0], 0, 0, 0, 0)
 }
 }

 块[5] = 真
 显存mgr[2] = 显存mgr[2] + 块[1]
}

// 数据传输 (同步)
函数 GPU显存_传输(显存mgr, 目标指针, 源指针, 大小, 方向) { 定义 管理器 = 显存mgr[4]
 定义 dev = GPU管理器_当前设备(管理器)
 定义 厂商 = GPU设备_厂商(dev)

 如果 (厂商 == GPU_厂商_NVIDIA) { 定义 cuda_lib = GPU_加载驱动库(GPU_厂商_NVIDIA)
 如果 (方向 == GPU传输_主机到设备) {
 // cuMemcpyHtoD_v2(dst, src, size)
 返回 外部调用(cuda_lib,  "cuMemcpyHtoD_v2",  目标指针,  源指针,  大小, 0, 0)
 } 否则 如果 (方向 == GPU传输_设备到主机) { 返回 外部调用(cuda_lib,  "cuMemcpyDtoH_v2",  目标指针,  源指针,  大小, 0, 0)
 } 否则 { 返回 外部调用(cuda_lib,  "cuMemcpyDtoD_v2",  目标指针,  源指针,  大小, 0, 0)
 }
 }

 如果 (厂商 == GPU_厂商_AMD) { 定义 hip_lib = GPU_加载驱动库(GPU_厂商_AMD)
 定义 可变 种类 = 0
 如果 (方向 == GPU传输_主机到设备) { 种类 = 1 } // hipMemcpyHostToDevice
 否则 如果 (方向 == GPU传输_设备到主机) { 种类 = 2 } // hipMemcpyDeviceToHost
 否则 { 种类 = 3 } // hipMemcpyDeviceToDevice
 返回 外部调用(hip_lib,  "hipMemcpy",  目标指针,  源指针,  大小,  种类, 0)
 }
 返回 0
}

// 异步传输 (流操作)
函数 GPU显存_异步传输(显存mgr, 目标, 源, 大小, 方向, 流) { 定义 管理器 = 显存mgr[4]
 定义 dev = GPU管理器_当前设备(管理器)
 定义 厂商 = GPU设备_厂商(dev)

 如果 (厂商 == GPU_厂商_NVIDIA) { 定义 cuda_lib = GPU_加载驱动库(GPU_厂商_NVIDIA)
 如果 (方向 == GPU传输_主机到设备) { 返回 外部调用(cuda_lib,  "cuMemcpyHtoDAsync_v2",  目标,  源,  大小,  流, 0)
 } 否则 { 返回 外部调用(cuda_lib,  "cuMemcpyDtoHAsync_v2",  目标,  源,  大小,  流, 0)
 }
 }

 如果 (厂商 == GPU_厂商_AMD) { 定义 hip_lib = GPU_加载驱动库(GPU_厂商_AMD)
 定义 可变 种类 = 0
 如果 (方向 == GPU传输_主机到设备) { 种类 = 1 }
 否则 { 种类 = 2 }
 返回 外部调用(hip_lib, "hipMemcpyAsync", 目标, 源, 大小, 种类, 流)
 }
 返回 0
}

// 显存清零
函数 GPU显存_清零(显存mgr, 块) { 定义 管理器 = 显存mgr[4]
 定义 dev = GPU管理器_当前设备(管理器)
 定义 厂商 = GPU设备_厂商(dev)

 如果 (厂商 == GPU_厂商_NVIDIA) { 定义 cuda_lib = GPU_加载驱动库(GPU_厂商_NVIDIA)
 返回 外部调用(cuda_lib,  "cuMemsetD8_v2",  块[0],  0,  块[1], 0, 0)
 }
 如果 (厂商 == GPU_厂商_AMD) { 定义 hip_lib = GPU_加载驱动库(GPU_厂商_AMD)
 返回 外部调用(hip_lib,  "hipMemset",  块[0],  0,  块[1], 0, 0)
 }
 返回 0
}

// 统计
// 显存池 (Memory Pool)
定义 可变 _显存池_空闲块 = []
定义 可变 _显存池_命中数 = 0
定义 可变 _显存池_未中数 = 0

函数 显存池_初始化() { _显存池_空闲块 = []
 _显存池_命中数 = 0
 _显存池_未中数 = 0
}

函数 显存池_申请(大小) { 定义 可变 i = 0
    定义 可变 新列表 = []
 当 (i < 计数(_显存池_空闲块)) { 如果 (_显存池_空闲块[i][1] >= 大小) { 定义 块 = _显存池_空闲块[i]
 定义 可变 j = 0
 当 (j < 计数(_显存池_空闲块)) { 如果 (j != i) { 追加(新列表, _显存池_空闲块[j]) }
 j = j + 1
 }
 _显存池_空闲块 = 新列表
 _显存池_命中数 = _显存池_命中数 + 1
 返回 块
 }
 i = i + 1
 }
 _显存池_未中数 = _显存池_未中数 + 1
 返回 空
}

函数 显存池_归还(块) {
 追加(_显存池_空闲块, 块)
}

函数 显存池_命中率() { 定义 总 = _显存池_命中数 + _显存池_未中数
 如果 (总 == 0) { 返回 0 }
 返回 _显存池_命中数 * 100 / 总
}

函数 显存池_空闲总量() { 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 计数(_显存池_空闲块)) { 总 = 总 + _显存池_空闲块[i][1] i = i + 1 }
 返回 总
}

// 显存预算
定义 可变 _显存_预算 = 0
定义 可变 _显存_已用 = 0

函数 显存预算_设置(总量) { _显存_预算 = 总量 _显存_已用 = 0 }
函数 显存预算_申请(大小) {
    如果 (_显存_已用 + 大小 > _显存_预算) { 返回 假
}
 _显存_已用 = _显存_已用 + 大小
 返回 真
}
函数 显存预算_释放(大小) {
    _显存_已用 = _显存_已用 - 大小
    如果 (_显存_已用 < 0) { _显存_已用 = 0 }
}
函数 显存预算_使用率() {
    如果 (_显存_预算 == 0) { 返回 0 }
    返回 _显存_已用 * 100 / _显存_预算
}
函数 显存预算_剩余() { 返回 _显存_预算 - _显存_已用 }

// Host-Device传输跟踪
定义 可变 _传输_H2D_次数 = 0
定义 可变 _传输_D2H_次数 = 0
定义 可变 _传输_H2D_字节 = 0
定义 可变 _传输_D2H_字节 = 0

函数 传输_记录H2D(字节数) { _传输_H2D_次数 = _传输_H2D_次数 + 1 _传输_H2D_字节 = _传输_H2D_字节 + 字节数 }
函数 传输_记录D2H(字节数) { _传输_D2H_次数 = _传输_D2H_次数 + 1 _传输_D2H_字节 = _传输_D2H_字节 + 字节数 }

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./整数转字符串.nova")

//   1. 调度域: CPU拓扑的层级抽象(SMT→MC→NUMA)
//   2. SMT域: 超线程兄弟(共享L1缓存)
//   3. MC域: 多核(共享L2/L3缓存)
//   4. NUMA域: 跨NUMA节点(不同内存控制器)
//   5. 均衡决策按域层级进行: 优先在近域均衡

外部 所有运行队列

定义 SD_LEVEL_SMT  = 0    // 超线程
定义 SD_LEVEL_MC   = 1    // 多核
定义 SD_LEVEL_NUMA = 2    // NUMA
定义 SD_LEVEL_MAX  = 3

定义 SD_SHARE_CPUCAPACITY = 0x01   // 共享CPU容量(SMT)
定义 SD_SHARE_PKG_RESOURCES = 0x02 // 共享包资源(L3缓存)
定义 SD_NUMA               = 0x04  // NUMA域
定义 SD_WAKE_AFFINE         = 0x08 // 唤醒亲和性

结构 调度域 {
    名称,
    级别,    // u32 SD_LEVEL_*
    标志,    // u32 SD_*
    CPU列表,    // [] 域内CPU编号列表
    均衡间隔,    // u32 均衡检查间隔(ms)
    不均衡阈值,    // u32 触发迁移的负载差百分比
    父域,    // u64 上层域
    子域,    // u64 下层域
}

结构 调度组 {
    CPU列表,    // []
    容量,    // u64 组总计算容量
    负载,    // u64 组当前负载
}

定义 可变 调度域_根 = 空
定义 可变 所有调度域 = []

// 初始化 

函数 调度域_初始化(CPU数) {
    所有调度域 = []

    // 单CPU: 无需调度域
    如果 (CPU数 <= 1) {
        内核信息("调度域: 单CPU, 无需拓扑")
        返回
    }

    // MC域: 所有CPU在一个核心域
    定义 mc = 调度域 {}
    mc.名称 = "MC"
    mc.级别 = SD_LEVEL_MC
    mc.标志 = SD_SHARE_PKG_RESOURCES | SD_WAKE_AFFINE
    mc.CPU列表 = []
    定义 可变 i = 0
    当 (i < CPU数) { 追加(mc.CPU列表, i); i = i + 1 }
    mc.均衡间隔 = 4
    mc.不均衡阈值 = 25
    mc.父域 = 空
    mc.子域 = 空
    追加(所有调度域, mc)
    调度域_根 = mc

    内核信息("调度域: MC域 (" + 整数转字符串(CPU数) + " CPUs, 间隔" +
             整数转字符串(mc.均衡间隔) + "ms)")
}

// 域查询

函数 CPU所在域(cpu, 级别) {
    定义 可变 i = 0
    当 (i < 计数(所有调度域)) {
        定义 sd = 所有调度域[i]
        如果 (sd.级别 == 级别) {
            定义 可变 j = 0
            当 (j < 计数(sd.CPU列表)) {
                如果 (sd.CPU列表[j] == cpu) { 返回 sd }
                j = j + 1
            }
        }
        i = i + 1
    }
    返回 空
}

函数 域内CPU数(域) {
    如果 (域 == 空) { 返回 0 }
    返回 计数(域.CPU列表)
}

函数 调度域_统计() {
    返回 [计数(所有调度域)]
}

// NUMA拓扑构建 

定义 可变 numa_节点数 = 1
定义 可变 numa_距离表 = []  // [节点i][节点j] = 距离(10=本地, 20=远程)

函数 调度域_初始化_NUMA(节点数, CPU_per_节点) {
    numa_节点数 = 节点数
    如果 (节点数 <= 1) { 返回 }

    // 构建距离表
    numa_距离表 = []
    定义 可变 i = 0
    当 (i < 节点数) {
        定义 行 = []
        定义 可变 j = 0
        当 (j < 节点数) {
            如果 (i == j) { 追加(行, 10) }     // 本地距离
            否则 { 追加(行, 20) }               // 远程距离
            j = j + 1
        }
        追加(numa_距离表, 行)
        i = i + 1
    }

    // 为每个NUMA节点创建MC域
    i = 0
    当 (i < 节点数) {
        定义 mc = 调度域 {}
        mc.名称 = "MC-节点" + 整数转字符串(i)
        mc.级别 = SD_LEVEL_MC
        mc.标志 = SD_SHARE_PKG_RESOURCES | SD_WAKE_AFFINE
        mc.CPU列表 = []
        定义 可变 c = 0
        当 (c < CPU_per_节点) {
            追加(mc.CPU列表, i * CPU_per_节点 + c)
            c = c + 1
        }
        mc.均衡间隔 = 4
        mc.不均衡阈值 = 25
        mc.父域 = 空
        mc.子域 = 空
        追加(所有调度域, mc)
        i = i + 1
    }

    // 创建NUMA域(跨节点)
    定义 numa_d = 调度域 {}
    numa_d.名称 = "NUMA"
    numa_d.级别 = SD_LEVEL_NUMA
    numa_d.标志 = SD_NUMA
    numa_d.CPU列表 = []
    i = 0
    当 (i < 节点数 * CPU_per_节点) {
        追加(numa_d.CPU列表, i)
        i = i + 1
    }
    numa_d.均衡间隔 = 32   // NUMA域均衡间隔更长
    numa_d.不均衡阈值 = 50  // NUMA域迁移代价高,阈值更高
    numa_d.父域 = 空
    numa_d.子域 = 空
    追加(所有调度域, numa_d)
    调度域_根 = numa_d

    // 链接父子关系
    i = 0
    当 (i < 节点数) {
        所有调度域[i].父域 = numa_d
        i = i + 1
    }

    内核信息("调度域: NUMA拓扑 " + 整数转字符串(节点数) + "节点 × " +
             整数转字符串(CPU_per_节点) + "CPU/节点")
}

函数 numa_距离(节点a, 节点b) {
    如果 (节点a >= numa_节点数 || 节点b >= numa_节点数) { 返回 255 }
    如果 (计数(numa_距离表) <= 节点a) { 返回 10 }
    返回 numa_距离表[节点a][节点b]
}

函数 CPU所在NUMA节点(cpu) {
    定义 可变 i = 0
    当 (i < 计数(所有调度域)) {
        定义 sd = 所有调度域[i]
        如果 (sd.级别 == SD_LEVEL_MC) {
            定义 可变 j = 0
            当 (j < 计数(sd.CPU列表)) {
                如果 (sd.CPU列表[j] == cpu) { 返回 i }
                j = j + 1
            }
        }
        i = i + 1
    }
    返回 0
}

// 负载均衡 

定义 可变 lb_尝试次数 = 0
定义 可变 lb_成功次数 = 0
定义 可变 lb_失败次数 = 0

定义 可变 AI_调度域初始_负载窗口 = []

函数 AI_调度域初始_负载预测(当前负载) {
    追加(AI_调度域初始_负载窗口, 当前负载)
    如果 (计数(AI_调度域初始_负载窗口) > 20) { 列表_移除(AI_调度域初始_负载窗口, 0) }
    如果 (计数(AI_调度域初始_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_调度域初始_负载窗口)
    定义 趋势 = AI_调度域初始_负载窗口[n-1] - AI_调度域初始_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_调度域初始_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

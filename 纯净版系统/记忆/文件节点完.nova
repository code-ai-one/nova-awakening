导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/创建甲.nova")

定义 最大缓存节点 = 1024
定义 哈希桶数 = 128
定义 节点_普通 = 1
定义 节点_目录 = 2
定义 节点_符号 = 3
定义 节点_块设备 = 4
定义 节点_字符设备 = 5

结构 文件节点 {
    编号,
    类型,
    大小,
    权限,
    属主,
    属组,
    硬链接数,
    引用计数,
    创建时刻,
    修改时刻,
    访问时刻,
    脏标记,
    块列表,
    块数,
    设备号,
    哈希后继,
    淘汰前驱,
    淘汰后继,
}

定义 可变 哈希表 = 0
定义 可变 缓存数 = 0
定义 可变 淘汰头 = 0
定义 可变 淘汰尾 = 0
定义 可变 下一编号 = 1
定义 可变 分配次数 = 0
定义 可变 释放次数 = 0
定义 可变 命中次数 = 0
定义 可变 未命中次数 = 0
定义 可变 回写次数 = 0
定义 可变 脏节点数 = 0

函数 文件节点_初始化() {
    哈希表 = 堆_分配(哈希桶数 * 8)
    定义 可变 序号 = 0
    当 (序号 < 哈希桶数) {
        内存_写64(哈希表 + 序号 * 8, 0)
        序号 = 序号 + 1
    }
    缓存数 = 0
    淘汰头 = 0
    淘汰尾 = 0
}

函数 文件节点_分配(类型, 权限) {
    如果 (缓存数 >= 最大缓存节点) { 文件节点_淘汰() }
    分配次数 = 分配次数 + 1
    定义 节点 = 堆_分配(文件节点)
    节点.编号 = 下一编号
    下一编号 = 下一编号 + 1
    节点.类型 = 类型
    节点.大小 = 0
    节点.权限 = 权限
    节点.属主 = 0
    节点.属组 = 0
    节点.硬链接数 = 1
    节点.引用计数 = 1
    节点.创建时刻 = 平台_获取高精度时间()
    节点.修改时刻 = 节点.创建时刻
    节点.访问时刻 = 节点.创建时刻
    节点.脏标记 = 假
    节点.块列表 = 0
    节点.块数 = 0
    节点.设备号 = 0
    节点.哈希后继 = 0
    节点.淘汰前驱 = 0
    节点.淘汰后继 = 0
    定义 桶号 = 节点.编号 % 哈希桶数
    节点.哈希后继 = 内存_读64(哈希表 + 桶号 * 8)
    内存_写64(哈希表 + 桶号 * 8, 节点)
    缓存数 = 缓存数 + 1
    文件节点_加淘汰头(节点)
    返回 节点
}

函数 文件节点_查找(编号) {
    定义 桶号 = 编号 % 哈希桶数
    定义 可变 当前 = 内存_读64(哈希表 + 桶号 * 8)
    当 (当前 != 0) {
        如果 (当前.编号 == 编号) {
            当前.引用计数 = 当前.引用计数 + 1
            当前.访问时刻 = 平台_获取高精度时间()
            命中次数 = 命中次数 + 1
            文件节点_移淘汰头(当前)
            返回 当前
        }
        当前 = 当前.哈希后继
    }
    未命中次数 = 未命中次数 + 1
    返回 0
}

函数 文件节点_释放(节点) {
    如果 (节点 == 0) { 返回 }
    节点.引用计数 = 节点.引用计数 - 1
}

函数 文件节点_标脏(节点) {
    如果 (节点 == 0) { 返回 }
    如果 (!节点.脏标记) {
        节点.脏标记 = 真
        脏节点数 = 脏节点数 + 1
    }
    节点.修改时刻 = 平台_获取高精度时间()
}

函数 文件节点_回写(节点) {
    如果 (节点 == 0 || !节点.脏标记) { 返回 }
    节点.脏标记 = 假
    脏节点数 = 脏节点数 - 1
    回写次数 = 回写次数 + 1
}

函数 文件节点_回写全部() {
    定义 可变 桶号 = 0
    当 (桶号 < 哈希桶数) {
        定义 可变 当前 = 内存_读64(哈希表 + 桶号 * 8)
        当 (当前 != 0) {
            如果 (当前.脏标记) { 文件节点_回写(当前) }
            当前 = 当前.哈希后继
        }
        桶号 = 桶号 + 1
    }
}

函数 文件节点_淘汰() {
    如果 (淘汰尾 == 0) { 返回 }
    定义 可变 牺牲 = 淘汰尾
    定义 可变 搜索 = 0
    当 (牺牲 != 0 && 搜索 < 16) {
        如果 (牺牲.引用计数 <= 0 && !牺牲.脏标记) { 跳出 }
        如果 (牺牲.脏标记) { 文件节点_回写(牺牲) }
        牺牲 = 牺牲.淘汰前驱
        搜索 = 搜索 + 1
    }
    如果 (牺牲 == 0) { 返回 }
    文件节点_从淘汰移除(牺牲)
    定义 桶号 = 牺牲.编号 % 哈希桶数
    定义 可变 前驱 = 0
    定义 可变 当前 = 内存_读64(哈希表 + 桶号 * 8)
    当 (当前 != 0) {
        如果 (当前 == 牺牲) {
            如果 (前驱 == 0) { 内存_写64(哈希表 + 桶号 * 8, 牺牲.哈希后继) }
            否则 { 前驱.哈希后继 = 牺牲.哈希后继 }
            跳出
        }
        前驱 = 当前
        当前 = 当前.哈希后继
    }
    缓存数 = 缓存数 - 1
    释放次数 = 释放次数 + 1
    堆_释放(牺牲)
}

函数 文件节点_加淘汰头(节点) {
    节点.淘汰前驱 = 0
    节点.淘汰后继 = 淘汰头
    如果 (淘汰头 != 0) { 淘汰头.淘汰前驱 = 节点 }
    淘汰头 = 节点
    如果 (淘汰尾 == 0) { 淘汰尾 = 节点 }
}

函数 文件节点_移淘汰头(节点) {
    如果 (节点 == 淘汰头) { 返回 }
    文件节点_从淘汰移除(节点)
    文件节点_加淘汰头(节点)
}

函数 文件节点_从淘汰移除(节点) {
    如果 (节点.淘汰前驱 != 0) { 节点.淘汰前驱.淘汰后继 = 节点.淘汰后继 }
    否则 { 淘汰头 = 节点.淘汰后继 }
    如果 (节点.淘汰后继 != 0) { 节点.淘汰后继.淘汰前驱 = 节点.淘汰前驱 }
    否则 { 淘汰尾 = 节点.淘汰前驱 }
}

函数 文件节点_完整统计() {
    返回 [缓存数, 下一编号 - 1, 脏节点数, 分配次数, 释放次数, 命中次数, 未命中次数, 回写次数]
}

定义 可变 AI_文件节点完_运行指标 = 0
定义 可变 AI_文件节点完_异常指标 = 0

函数 AI_文件节点完_自诊断() {
    AI_文件节点完_运行指标 = 分配次数
    返回 AI_文件节点完_运行指标
}

函数 AI_文件节点完_优化建议() {
    定义 指标 = AI_文件节点完_自诊断()
    如果 (AI_文件节点完_运行指标 > 10000) { 返回 "文件节点完负载较高" }
    返回 "文件节点完状态正常"
}

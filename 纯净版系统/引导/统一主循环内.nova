定义 可变 _多模态_帧计数 = 0
定义 可变 _系统健康_状态 = "正常"  // 正常/降级/恢复中
定义 可变 _watchdog_下次tick_ns = 0
定义 可变 _听觉_录音流就绪 = 假
定义 可变 _听觉_采样缓冲 = 0
定义 _听觉_采样帧数 = 256
定义 可变 _听觉_最近事件 = "待机"
定义 可变 _视觉_最近截图哈希 = 0
定义 可变 _视觉_最近元素数 = 0

函数 NovaOS_进入统一主循环(reg) {
    NovaOS_主循环(reg)
}

函数 系统_watchdog_推进(当前时间_ns) {
    如果 (!watchdog_已启用) { 返回 }
    如果 (接口C_定时器_已启动) { 返回 }
    如果 (_watchdog_下次tick_ns <= 0) {
        _watchdog_下次tick_ns = 当前时间_ns + 10000000
        返回
    }
    当 (当前时间_ns >= _watchdog_下次tick_ns) {
        watchdog_tick()
        _watchdog_下次tick_ns = _watchdog_下次tick_ns + 10000000
    }
}

函数 多模态_获取默认录音流() {
    如果 (计数(声卡列表) == 0) { 返回 空 }
    如果 (计数(声卡列表[0].PCM列表) == 0) { 返回 空 }
    返回 声卡列表[0].PCM列表[0].录音
}

函数 多模态_初始化默认录音流() {
    如果 (!音频_已初始化) {
        音频_初始化()
    }
    定义 录音流 = 多模态_获取默认录音流()
    如果 (录音流 == 空) { 返回 假 }
    如果 (录音流.状态 != SND_PCM_STATE_RUNNING) {
        如果 (PCM_设置参数(录音流, SND_PCM_FORMAT_S16_LE, SND_RATE_44100, 1) < 0) { 返回 假 }
        如果 (PCM_准备(录音流) < 0) { 返回 假 }
        如果 (PCM_启动(录音流) < 0) { 返回 假 }
    }
    如果 (_听觉_采样缓冲 == 0) {
        _听觉_采样缓冲 = 堆_分配(4096)
    }
    _听觉_录音流就绪 = _听觉_采样缓冲 != 0
    返回 _听觉_录音流就绪
}

函数 多模态_截断文本(文本, 最大长度) {
    如果 (文本 == 空) { 返回 "" }
    如果 (字符串长度(文本) <= 最大长度) { 返回 文本 }
    如果 (最大长度 <= 3) { 返回 字符串子串(文本, 0, 最大长度) }
    返回 字符串子串(文本, 0, 最大长度 - 3) + "..."
}

函数 多模态_图处模式文本() {
    如果 (!图处_已初始化 || 图处_上下文 == 空) { 返回 "图处-offline" }
    如果 (图处_上下文.图处模式 >= 2) { 返回 "图处-3D" }
    如果 (图处_上下文.图处模式 >= 1) { 返回 "图处-2D" }
    返回 "CPU-composite"
}

函数 多模态_助手状态文本(状态) {
    如果 (状态 == 助手状态_待命) { 返回 "待命" }
    如果 (状态 == 助手状态_聆听) { 返回 "聆听中" }
    如果 (状态 == 助手状态_思考) { 返回 "思考中" }
    如果 (状态 == 助手状态_说话) { 返回 "说话中" }
    如果 (状态 == 助手状态_执行) { 返回 "执行中" }
    如果 (状态 == 助手状态_休眠) { 返回 "休眠" }
    如果 (状态 == 助手状态_视频) { 返回 "视频中" }
    返回 "在线"
}

函数 多模态_同步桌面状态() {
    定义 可变 核心状态 = "在线"
    定义 可变 核心副文本 = "browser-终端 单路径运行 · " + 多模态_图处模式文本()
    如果 (!图处_已初始化 || 图处_上下文 == 空) {
        核心状态 = "预热"
        核心副文本 = "图处 图形前台尚未绑定到 browser-终端"
    } 否则 如果 (_系统健康_状态 != "正常") {
        核心状态 = _系统健康_状态
        核心副文本 = "统一主循环仍在线 · 默认录音流暂未就绪"
    }

    定义 可变 视觉状态 = "待机"
    定义 可变 视觉副文本 = "等待视觉初始化"
    如果 (_视觉_已初始化) {
        如果 (!图处_已初始化 || 图处_上下文 == 空 || 图处_上下文.后缓冲 == 0) {
            视觉状态 = "预热"
            视觉副文本 = "图处 截图上下文未绑定"
        } 否则 如果 (图处_上下文.帧计数 <= 0) {
            视觉状态 = "预热"
            视觉副文本 = "等待首帧合成后进入视觉扫描"
        } 否则 如果 (_视觉_最近截图哈希 != 0) {
            视觉状态 = "在线"
            视觉副文本 = "最近识别 " + 整数转字符串(_视觉_最近元素数) + " 个区域 · 总扫描 " + 整数转字符串(视觉_总识别次数) + " 次"
        } 否则 {
            视觉状态 = "在线"
            视觉副文本 = "图处 后缓冲已接入 · 等待首轮视觉结果"
        }
    }

    定义 可变 声音状态 = "待机"
    定义 可变 声音副文本 = "语音前台未激活"
    如果 (_听觉_已初始化) {
        如果 (!_听觉_录音流就绪) {
            声音状态 = "降级"
            声音副文本 = "默认录音流未就绪"
        } 否则 如果 (全局TTS != 空 && 全局TTS.正在播放) {
            声音状态 = "说话中"
            声音副文本 = 多模态_截断文本(全局TTS.当前文本, 28)
        } 否则 如果 (全局ASR != 空 && 全局ASR.正在录音) {
            声音状态 = "聆听中"
            声音副文本 = "录音流在线 · 最近事件 " + _听觉_最近事件
        } 否则 {
            声音状态 = "在线"
            声音副文本 = "最近听觉事件 " + _听觉_最近事件
        }
    }

    定义 可变 形象状态 = "待机"
    定义 可变 形象副文本 = "形象前台未激活"
    如果 (主助手 != 空) {
        形象状态 = 多模态_助手状态文本(主助手.状态)
        形象副文本 = "交互 " + 整数转字符串(主助手.交互次数) + " 次 · 表情 " + 整数转字符串(主助手.当前表情)
        如果 (主助手.状态 == 助手状态_说话) {
            形象副文本 = 多模态_截断文本(主助手.说话文本, 28)
        } 否则 如果 (主助手.状态 == 助手状态_聆听) {
            形象副文本 = "唤醒词 " + 主助手.唤醒词 + " 已接管前台"
        }
    }

    浏览器系统会话_同步系统状态(核心状态, 核心副文本,
                       视觉状态, 视觉副文本,
                       声音状态, 声音副文本,
                       形象状态, 形象副文本)
}

// §5 统一主循环 — 内核+浏览器+AI+桌面 一体调度

函数 NovaOS_主循环(reg) {
    定义 帧间隔 = 1000000000 / 60  // 60fps → 16.67ms
    AI控制_初始化()

    当 (真) {
        定义 帧开始 = 平台_获取单调时间_ns()
        系统_watchdog_推进(帧开始)
        _多模态_帧计数 = _多模态_帧计数 + 1

        // ① 内核层: 处理中断/IO完成/网络包
        中断系统_处理(reg.中断控制器)

        // ② 输入层: 键盘/鼠标/触摸 → 桌面事件分发
        浏览器系统会话_轮询输入()
        AI控制_tick()

        // ③ 脚本层: JS宏任务+微任务
        事件循环_tick(reg.事件循环)

        // ④ AI层: 语义分析/预测/建议
        AI总线_tick(reg.AI总线)

        // ⑤ 云端层: 模型蒸馏/在线学习/接口同步
        云端桥接_tick(reg.云端桥接)
        如果 (_多模态_帧计数 % 3 == 0) {
            定义 默认渠道档 = 智能渠道_获取默认档()
            如果 (默认渠道档 != 0) {
                智能渠道_轮询(默认渠道档)
            }
        }

        // ⑤.5 训练节拍: 批量蒸馏+权重持久化(系统=模型, 每一拍都是训练机会)
        如果 (_多模态_帧计数 % 30 == 0) {
            // 收敛检测: 已收敛则跳过蒸馏(节省计算), 但仍接受DPO偏好训练
            如果 (!训练统计_检查收敛()) {
                蒸馏_批量(空, 4)
            }
        }
        如果 (_多模态_帧计数 % 18000 == 0 && _多模态_帧计数 > 0) {
            // 每5分钟持久化权重(防止进化成果因断电丢失)
            会话存储_清理过期()
            // 收敛后自动推进到自主阶段
            如果 (训练统计_检查收敛() && 智能_进化阶段() < 3) {
                智能_推进进化(1000)
            }
        }

        // ⑥ 多模态感知层: 视觉/听觉/语音 (60fps中每6帧做一次感知轮询, 约10Hz)
        如果 (_多模态_帧计数 % 6 == 0) {
            多模态_感知_tick()
        }

        // ⑦ 虚拟人/全息形象层: 表情/状态/动画更新 (每10帧一次, 6Hz)
        如果 (_多模态_帧计数 % 10 == 0) {
            定义 人 = 获取全局虚拟人()
            如果 (人 != 空) {
                虚拟人_更新表情(人)
            }
        }

        // ⑧ 神经脉冲层: 类脑子系统tick(系统即大脑, 每帧都是一次神经脉冲)
        突触_传播(0, 500)               // 突触信号传导
        如果 (_多模态_帧计数 % 2 == 0) {
            NE_更新(0, 500)             // 去甲肾上腺素(唤醒度)
            ACh_更新(0)                 // 乙酰胆碱(注意力门控)
        }
        如果 (_多模态_帧计数 % 3 == 0) {
            认知_周期(0, 0)             // 多轮认知
        }
        如果 (_多模态_帧计数 % 5 == 0) {
            稳态_tick()                 // 神经元稳态维持
        }
        如果 (_多模态_帧计数 % 10 == 0) {
            突触_衰减()                 // 突触衰减(防饱和)
            STDP_更新(500, _多模态_帧计数 - 1, _多模态_帧计数, 10, 12, 20, 1)
        }
        // 反馈+调质: 多巴胺奖励预测误差驱动赫布学习
        如果 (_多模态_帧计数 % 15 == 0) {
            DA_更新(累计奖励 - 累计惩罚)
            血清素_更新(累计奖励 - 累计惩罚, _多模态_帧计数 % 100)
        }
        自学习_tick()                   // 自学习闭环
        睡眠_tick()                     // 睡眠/觉醒周期
        防阻塞_tick()                   // 防阻塞巡检

        // ⑧.5 回滚/健康层: watchdog喂狗 + 系统健康检查
        watchdog_喂狗()

        // ⑨ 热更新层: 检查待更新模块 (每300帧一次, 约5秒)
        如果 (_多模态_帧计数 % 300 == 0) {
            热更新_检查待更新()
            模型同步_定期()
        }

        // ⑨.5 神经进化脉冲: 低频突触修剪+策略梯度+健康检查 (每1800帧≈30秒)
        如果 (_多模态_帧计数 % 1800 == 0 && _多模态_帧计数 > 0) {
            自动化_tick()                   // 3D突触网格自动化修剪
            策略梯度_更新(0)                // 策略梯度更新
            递质_衰减()                     // 神经递质衰减
            神经中枢_脑区健康检查()         // 脑区活跃度检查
        }

        // ⑩ 自动检查点: 每分钟自动保存一次稳定状态 (每3600帧≈每60秒)
        如果 (_多模态_帧计数 % 3600 == 0 && _多模态_帧计数 > 0) {
            系统_自动检查点()
        }

        // ⑪ 渲染层: 样式→布局→绘制→合成→屏幕
        多模态_同步桌面状态()
        浏览器系统会话_渲染帧()

        // ⑫ 等待vsync
        定义 帧耗时 = 平台_获取单调时间_ns() - 帧开始
        如果 (帧耗时 < 帧间隔) {
            平台_睡眠_ns(帧间隔 - 帧耗时)
        }
    }
}

// 多模态感知统一 tick

函数 多模态_感知_tick() {
    // 视觉: 截屏/像素分析/OCR/场景识别
    视觉_轮询()
    // 听觉: 音频输入/静音检测/ASR识别
    听觉_轮询()
    // 语音合成: TTS队列消费
    语音合成_轮询()
}

// 热更新检查

定义 可变 _待更新模块队列 = []

函数 热更新_提交(模块名, 新版本, 新代码哈希) {
    追加(_待更新模块队列, [模块名, 新版本, 新代码哈希])
}

函数 热更新_检查待更新() {
    当 (计数(_待更新模块队列) > 0) {
        定义 请求 = _待更新模块队列[0]
        删除(_待更新模块队列, 0)
        定义 模块名 = 请求[0]
        定义 新版本 = 请求[1]
        定义 新代码哈希 = 请求[2]
        // 先保存检查点
        定义 cp = 检查点_创建("热更新前_" + 模块名)
        如果 (cp != 空) {
            回滚_注册检查点(cp.检查点ID)
        }
        // 执行热更新
        定义 模块 = 热更新_按名查找(模块名)
        如果 (模块 == 空) {
            内核警告("热更新失败: 未注册模块 " + 模块名)
        } 否则 {
            定义 结果 = 热更新_替换(模块.模块ID, 新版本, 新代码哈希)
            如果 (结果 == 假) {
                内核警告("热更新元数据失败: " + 模块名 + " → 已回滚")
            } 否则 {
                内核信息("热更新元数据完成: " + 模块名 + " (版本/哈希已更新, 未执行代码载荷替换)")
            }
        }
    }
}

// 自动检查点

函数 系统_自动检查点() {
    如果 (_系统健康_状态 != "正常") { 返回 }
    定义 名称 = "自动_帧" + 整数转字符串(_多模态_帧计数)
    检查点_创建(名称)
    内核调试("自动检查点: " + 名称)
}

// 多模态子系统存根
// 这些函数是各多模态子系统的 tick 接口
// 实际实现分布在各自的模块中, 这里是统一调度入口

定义 可变 _视觉_已初始化 = 假
定义 可变 _听觉_已初始化 = 假
定义 可变 _语音合成_已初始化 = 假

函数 视觉_轮询() {
    如果 (!_视觉_已初始化) { 返回 }
    如果 (!图处_已初始化 || 图处_上下文 == 空 || 图处_上下文.后缓冲 == 0) { 返回 }
    如果 (图处_上下文.帧计数 <= 0) { 返回 }
    定义 像素基址 = 视觉识别_获取截图像素()
    如果 (像素基址 == 0) { 返回 }
    定义 视觉结果 = 视觉识别_分析页面()
    _视觉_最近截图哈希 = 视觉结果.截图哈希
    _视觉_最近元素数 = 计数(视觉结果.元素列表)
}

函数 听觉_轮询() {
    如果 (!_听觉_已初始化) { 返回 }
    如果 (!_听觉_录音流就绪 || _听觉_采样缓冲 == 0) {
        如果 (!多模态_初始化默认录音流()) { 返回 }
        如果 (_系统健康_状态 == "降级") {
            _系统健康_状态 = "正常"
        }
    }
    定义 录音流 = 多模态_获取默认录音流()
    如果 (录音流 == 空 || 录音流.状态 != SND_PCM_STATE_RUNNING) {
        _听觉_录音流就绪 = 假
        _听觉_最近事件 = "录音流中断"
        _系统健康_状态 = "降级"
        返回
    }
    定义 读取结果 = PCM_读帧(录音流, _听觉_采样缓冲, _听觉_采样帧数)
    如果 (读取结果 <= 0) { 返回 }
    定义 可变 样本序列 = []
    定义 可变 i = 0
    当 (i < 读取结果) {
        定义 可变 样本 = 内存读16(_听觉_采样缓冲 + i * 录音流.帧大小)
        如果 (样本 > 32767) { 样本 = 样本 - 65536 }
        追加(样本序列, 样本)
        如果 (全局ASR != 空 && 全局ASR.正在录音) {
            ASR_输入样本(样本)
        }
        i = i + 1
    }
    _听觉_最近事件 = 听觉识别_检测事件(样本序列)
}

函数 语音合成_轮询() {
    如果 (!_语音合成_已初始化) { 返回 }
    如果 (主助手 == 空) { 返回 }
    全息助手_tick(主助手)
    如果 (全局ASR != 空 && !全局ASR.正在录音 &&
        (主助手.状态 == 助手状态_待命 || 主助手.状态 == 助手状态_休眠)) {
        ASR_开始录音()
    }
}

函数 多模态_初始化() {
    视觉识别_初始化()
    _视觉_已初始化 = 真

    听觉识别_初始化()
    _听觉_已初始化 = 真
    如果 (!多模态_初始化默认录音流()) {
        _系统健康_状态 = "降级"
        内核警告("多模态子系统: 默认录音流未就绪, 听觉前台降级运行")
    }

    ASR_初始化()
    TTS_初始化()
    如果 (主助手 == 空) {
        全息助手_创建("Nova", "Nova")
    }
    如果 (全局ASR != 空 && !全局ASR.正在录音) {
        ASR_开始录音()
    }
    _语音合成_已初始化 = 真
    内核信息("多模态子系统: 视觉+听觉+语音前台已接入统一主循环")
}

// §6 系统完整性验证(调试用)

函数 注册表_验证() {
    定义 reg = 注册表_获取()
    定义 可变 缺失 = 0
    如果 (reg.进程调度器 == 0) { 内核日志("❌ 缺失: 进程调度器"); 缺失 = 缺失 + 1 }
    如果 (reg.内存管理器 == 0) { 内核日志("❌ 缺失: 内存管理器"); 缺失 = 缺失 + 1 }
    如果 (reg.VFS == 0)        { 内核日志("❌ 缺失: VFS"); 缺失 = 缺失 + 1 }
    如果 (reg.图处驱动 == 0)    { 内核日志("❌ 缺失: 图处驱动"); 缺失 = 缺失 + 1 }
    如果 (reg.传控栈 == 0)      { 内核日志("❌ 缺失: 传控栈"); 缺失 = 缺失 + 1 }
    如果 (reg.文档解析器 == 0) { 内核日志("❌ 缺失: 文档解析器"); 缺失 = 缺失 + 1 }
    如果 (reg.样式引擎 == 0)   { 内核日志("❌ 缺失: 样式引擎"); 缺失 = 缺失 + 1 }
    如果 (reg.元素树 == 0)     { 内核日志("❌ 缺失: 元素树"); 缺失 = 缺失 + 1 }
    如果 (reg.Nova运行时 == 0)  { 内核日志("❌ 缺失: Nova运行时"); 缺失 = 缺失 + 1 }
    如果 (reg.Nova画布 == 0)   { 内核日志("❌ 缺失: Nova画布"); 缺失 = 缺失 + 1 }
    如果 (reg.推理引擎 == 0)   { 内核日志("❌ 缺失: AI推理引擎"); 缺失 = 缺失 + 1 }
    如果 (reg.AI总线 == 0)     { 内核日志("❌ 缺失: AI总线"); 缺失 = 缺失 + 1 }
    如果 (reg.桌面管理器 == 0) { 内核日志("❌ 缺失: 桌面管理器"); 缺失 = 缺失 + 1 }

    如果 (缺失 == 0) {
        内核日志("✅ 系统完整性验证通过 — 所有子系统已注册")
    } 否则 {
        内核日志("❌ 系统完整性验证失败 — %d个子系统缺失", 缺失)
    }
    返回 缺失
}

// NUML — Nova Unified Main Loop Theory
// 公理1(调度公平): 每个子系统在一轮循环中至少获得一次调度
// 公理2(优先级抢占): 高优先级事件可中断低优先级处理
// 定理1(响应上界): 最大响应延迟≤所有子系统最坏时间之和
// 定理2(无饥饿): 公平调度保证任何子系统不会永远等待

结构 循环统计 {
    总轮次,
    总处理时间_us,
    内核调度次数,
    浏览器调度次数,
    AI调度次数,
    桌面调度次数,
    空闲轮次,
    超时轮次,
    最大轮次耗时_us,
    最小轮次耗时_us,
}

定义 可变 全局_循环统计 = 空
定义 可变 循环_帧预算_us = 16000  // 16ms = 60fps

函数 循环统计_初始化() {
    如果 (全局_循环统计 == 空) {
        全局_循环统计 = 循环统计 {}
        全局_循环统计.总轮次 = 0
        全局_循环统计.总处理时间_us = 0
        全局_循环统计.内核调度次数 = 0
        全局_循环统计.浏览器调度次数 = 0
        全局_循环统计.AI调度次数 = 0
        全局_循环统计.桌面调度次数 = 0
        全局_循环统计.空闲轮次 = 0
        全局_循环统计.超时轮次 = 0
        全局_循环统计.最大轮次耗时_us = 0
        全局_循环统计.最小轮次耗时_us = 0x7FFFFFFF
    }
}

函数 循环_记录轮次(耗时_us, 内核, 浏览器, AI, 桌面) {
    循环统计_初始化()
    全局_循环统计.总轮次 = 全局_循环统计.总轮次 + 1
    全局_循环统计.总处理时间_us = 全局_循环统计.总处理时间_us + 耗时_us
    如果 (内核) { 全局_循环统计.内核调度次数 = 全局_循环统计.内核调度次数 + 1 }
    如果 (浏览器) { 全局_循环统计.浏览器调度次数 = 全局_循环统计.浏览器调度次数 + 1 }
    如果 (AI) { 全局_循环统计.AI调度次数 = 全局_循环统计.AI调度次数 + 1 }
    如果 (桌面) { 全局_循环统计.桌面调度次数 = 全局_循环统计.桌面调度次数 + 1 }
    如果 (耗时_us > 全局_循环统计.最大轮次耗时_us) { 全局_循环统计.最大轮次耗时_us = 耗时_us }
    如果 (耗时_us < 全局_循环统计.最小轮次耗时_us) { 全局_循环统计.最小轮次耗时_us = 耗时_us }
    如果 (耗时_us > 循环_帧预算_us) { 全局_循环统计.超时轮次 = 全局_循环统计.超时轮次 + 1 }
    如果 (!内核 && !浏览器 && !AI && !桌面) {
        全局_循环统计.空闲轮次 = 全局_循环统计.空闲轮次 + 1
    }
}

函数 循环_平均耗时() {
    循环统计_初始化()
    如果 (全局_循环统计.总轮次 == 0) { 返回 0 }
    返回 全局_循环统计.总处理时间_us / 全局_循环统计.总轮次
}

函数 循环_超时率() {
    循环统计_初始化()
    如果 (全局_循环统计.总轮次 == 0) { 返回 0 }
    返回 全局_循环统计.超时轮次 * 1000 / 全局_循环统计.总轮次
}

函数 循环_空闲率() {
    循环统计_初始化()
    如果 (全局_循环统计.总轮次 == 0) { 返回 0 }
    返回 全局_循环统计.空闲轮次 * 1000 / 全局_循环统计.总轮次
}

函数 循环_设置帧预算(fps) {
    如果 (fps <= 0) { fps = 60 }
    循环_帧预算_us = 1000000 / fps
}

函数 循环_打印统计() {
    循环统计_初始化()
    内核日志("═══ NUML统一主循环统计 ═══")
    内核日志("  总轮次: " + 整数转字符串(全局_循环统计.总轮次))
    内核日志("  平均耗时: " + 整数转字符串(循环_平均耗时()) + " us")
    内核日志("  最大耗时: " + 整数转字符串(全局_循环统计.最大轮次耗时_us) + " us")
    内核日志("  超时率: " + 整数转字符串(循环_超时率()) + "/1000")
    内核日志("  空闲率: " + 整数转字符串(循环_空闲率()) + "/1000")
    内核日志("  内核调度: " + 整数转字符串(全局_循环统计.内核调度次数))
    内核日志("  浏览器调度: " + 整数转字符串(全局_循环统计.浏览器调度次数))
    内核日志("  AI调度: " + 整数转字符串(全局_循环统计.AI调度次数))
    内核日志("  桌面调度: " + 整数转字符串(全局_循环统计.桌面调度次数))
}

函数 循环_重置统计() {
    如果 (全局_循环统计 != 空) {
        全局_循环统计.总轮次 = 0
        全局_循环统计.总处理时间_us = 0
        全局_循环统计.内核调度次数 = 0
        全局_循环统计.浏览器调度次数 = 0
        全局_循环统计.AI调度次数 = 0
        全局_循环统计.桌面调度次数 = 0
        全局_循环统计.空闲轮次 = 0
        全局_循环统计.超时轮次 = 0
        全局_循环统计.最大轮次耗时_us = 0
        全局_循环统计.最小轮次耗时_us = 0x7FFFFFFF
    }
}

函数 循环_完整统计() {
    循环统计_初始化()
    返回 [
        "总轮次", 全局_循环统计.总轮次,
        "平均耗时", 循环_平均耗时(),
        "超时率", 循环_超时率(),
        "空闲率", 循环_空闲率(),
        "内核调度", 全局_循环统计.内核调度次数,
        "浏览器调度", 全局_循环统计.浏览器调度次数,
        "AI调度", 全局_循环统计.AI调度次数,
        "桌面调度", 全局_循环统计.桌面调度次数,
        "原生独创_NUML主循环", 1
    ]
}

函数 循环_获取总轮次() { 循环统计_初始化(); 返回 全局_循环统计.总轮次 }
函数 循环_获取超时次数() { 循环统计_初始化(); 返回 全局_循环统计.超时轮次 }
函数 循环_获取帧预算() { 返回 循环_帧预算_us }

// §7 性能监控 + 循环诊断

结构 主循环统计 {
    总帧数,
    总调度时间_us,
    最大帧时间_us,
    最小帧时间_us,
    健康检查次数,
    热更新次数,
    检查点次数,
    事件处理数,
}

定义 可变 全局_主循环统计 = 空

函数 主循环统计_初始化() {
    如果 (全局_主循环统计 == 空) {
        全局_主循环统计 = 主循环统计 {}
        全局_主循环统计.总帧数 = 0
        全局_主循环统计.总调度时间_us = 0
        全局_主循环统计.最大帧时间_us = 0
        全局_主循环统计.最小帧时间_us = 999999
        全局_主循环统计.健康检查次数 = 0
        全局_主循环统计.热更新次数 = 0
        全局_主循环统计.检查点次数 = 0
        全局_主循环统计.事件处理数 = 0
    }
}

函数 主循环_记录帧时间(时间_us) {
    主循环统计_初始化()
    全局_主循环统计.总帧数 = 全局_主循环统计.总帧数 + 1
    全局_主循环统计.总调度时间_us = 全局_主循环统计.总调度时间_us + 时间_us
    如果 (时间_us > 全局_主循环统计.最大帧时间_us) {
        全局_主循环统计.最大帧时间_us = 时间_us
    }
    如果 (时间_us < 全局_主循环统计.最小帧时间_us) {
        全局_主循环统计.最小帧时间_us = 时间_us
    }
}

函数 主循环_打印统计() {
    主循环统计_初始化()
    打印行("=== 统一主循环统计 ===")
    打印行("总帧: " + 整数转字符串(全局_主循环统计.总帧数))
    定义 平均 = 0
    如果 (全局_主循环统计.总帧数 > 0) {
        平均 = 全局_主循环统计.总调度时间_us / 全局_主循环统计.总帧数
    }
    打印行("平均帧时间: " + 整数转字符串(平均) + " μs")
    打印行("最大: " + 整数转字符串(全局_主循环统计.最大帧时间_us) + " μs")
    打印行("最小: " + 整数转字符串(全局_主循环统计.最小帧时间_us) + " μs")
    打印行("健康检查: " + 整数转字符串(全局_主循环统计.健康检查次数))
    打印行("热更新: " + 整数转字符串(全局_主循环统计.热更新次数))
}

函数 主循环_重置统计() {
    如果 (全局_主循环统计 != 空) {
        全局_主循环统计.总帧数 = 0
        全局_主循环统计.总调度时间_us = 0
        全局_主循环统计.最大帧时间_us = 0
        全局_主循环统计.最小帧时间_us = 999999
        全局_主循环统计.健康检查次数 = 0
        全局_主循环统计.热更新次数 = 0
    }
}

函数 主循环_获取帧数() { 主循环统计_初始化(); 返回 全局_主循环统计.总帧数 }
函数 主循环_获取热更新数() { 主循环统计_初始化(); 返回 全局_主循环统计.热更新次数 }

// NUML — Nova Unified Main Loop Theory
// 公理1(调度完整): 每帧tick完整遍历内核/浏览器/智能/桌面四个子系统
// 公理2(热更新安全): 热更新在检查点保护下执行,可回滚
// 定理1(调度公平): 四子系统每帧获得等量调度时间
// 定理2(健康可观测): 系统健康状态可实时查询与报告

函数 主循环_完整统计() {
    主循环统计_初始化()
    返回 [全局_主循环统计.总帧数,
           全局_主循环统计.总调度时间_us,
           全局_主循环统计.最大帧时间_us,
           全局_主循环统计.最小帧时间_us,
           全局_主循环统计.健康检查次数,
           全局_主循环统计.热更新次数,
           全局_主循环统计.检查点次数,
           全局_主循环统计.事件处理数]
}

函数 系统_健康报告() {
    打印行("=== Nova系统健康 ===")
    打印行("状态: " + _系统健康_状态)
    打印行("帧: " + 整数转字符串(_多模态_帧计数))
    打印行("视觉: " + 整数转字符串(_视觉_已初始化))
    打印行("听觉: " + 整数转字符串(_听觉_已初始化))
    打印行("语音合成: " + 整数转字符串(_语音合成_已初始化))
}

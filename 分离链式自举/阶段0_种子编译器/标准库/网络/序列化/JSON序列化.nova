导入("../../基础.nova")
导入("../../文本/格式化/格式化.nova")

// Nova标准库 — JSON 解析器与生成器
// 完整 RFC 8259 兼容: 对象/数组/字符串/数字/布尔/null
// 递归下降解析, 支持嵌套、转义、美化输出

// JSON 值类型
定义 JSON_对象 = 1
定义 JSON_数组 = 2
定义 JSON_字符串 = 3
定义 JSON_数字 = 4
定义 JSON_布尔 = 5
定义 JSON_空 = 6

// JSON节点: [类型, 值]
// 对象值: [[键列表], [值列表]] (有序键值对)
// 数组值: [元素列表]

函数 json_对象() { 返回 [JSON_对象, [[], []]] }
函数 json_数组() { 返回 [JSON_数组, []] }
函数 JSON序列化_json_字符串(s) { 返回 [JSON_字符串, s] }
函数 json_数字(n) { 返回 [JSON_数字, n] }
函数 json_真() { 返回 [JSON_布尔, 真] }
函数 json_假() { 返回 [JSON_布尔, 假] }
函数 JSON_空值() { 返回 [JSON_空, 空] }

// 对象操作
函数 json_设置(对象, 键, 值) {
    如果 (对象[0] != JSON_对象) { 返回 假
}
 定义 键列 = 对象[1][0]
 定义 值列 = 对象[1][1]
 // 查找已有键
 定义 可变 i = 0
 当 (i < 计数(键列)) { 如果 (字符串等于(键列[i], 键)) {
 值列[i] = 值
 返回 真
 }
 i = i + 1
 }
 追加(键列, 键)
 追加(值列, 值)
 返回 真
}

函数 json_获取(对象, 键) {
    如果 (对象[0] != JSON_对象) { 返回 空
}
 定义 键列 = 对象[1][0]
 定义 值列 = 对象[1][1]
 定义 可变 i = 0
 当 (i < 计数(键列)) { 如果 (字符串等于(键列[i], 键)) { 返回 值列[i] }
 i = i + 1
 }
 返回 空
}

函数 json_删除(对象, 键) {
    如果 (对象[0] != JSON_对象) { 返回 假
}
 定义 键列 = 对象[1][0]
 定义 值列 = 对象[1][1]
 定义 可变 新键 = []
 定义 可变 新值 = []
 定义 可变 找到 = 假
 定义 可变 i = 0
 当 (i < 计数(键列)) { 如果 (字符串等于(键列[i], 键) == 假) {
 追加(新键, 键列[i])
 追加(新值, 值列[i])
 } 否则 { 找到 = 真 }
 i = i + 1
 }
 对象[1][0] = 新键
 对象[1][1] = 新值
 返回 找到
}

函数 json_键数(对象) {
    如果 (对象[0] != JSON_对象) { 返回 0
}
 返回 计数(对象[1][0])
}

函数 json_包含(对象, 键) { 返回 json_获取(对象, 键) != 空
}

// 数组操作
函数 json_追加(数组, 值) {
    如果 (数组[0] != JSON_数组) { 返回 假
}
 追加(数组[1], 值)
 返回 真
}

函数 json_取(数组, 索引) {
    如果 (数组[0] != JSON_数组) { 返回 空
}
 如果 (索引 < 0 或 索引 >= 计数(数组[1])) { 返回 空 }
 返回 数组[1][索引]
}

函数 json_长度(数组) {
    如果 (数组[0] != JSON_数组) { 返回 0
}
 返回 计数(数组[1])
}

// 值提取
函数 json_类型(节点) { 返回 节点[0] }
函数 json_值(节点) { 返回 节点[1] }
函数 json_是对象(节点) { 返回 节点[0] == JSON_对象 }
函数 json_是数组(节点) { 返回 节点[0] == JSON_数组 }
函数 json_是字符串(节点) { 返回 节点[0] == JSON_字符串 }
函数 json_是数字(节点) { 返回 节点[0] == JSON_数字 }

// JSON 解析器 (递归下降)
// 解析状态: [源文本, 位置, 长度, 错误]

函数 json_解析(文本) { 定义 状态 = [文本, 0, 计数(文本), 空]
 json跳空白(状态)
 定义 结果 = json解析值(状态)
 如果 (状态[3] != 空) { 返回 ["错误", 状态[3], 状态[1]]
 }
 返回 ["成功", 结果]
}

函数 json解析值(状态) {
 json跳空白(状态)
 如果 (状态[1] >= 状态[2]) {
 状态[3] = "意外结束"
 返回 空
 }
 定义 c = json当前(状态)
 如果 (c == 字符_左花括) { 返回 json解析对象(状态) }
 如果 (c == 字符_左方括) { 返回 json解析数组(状态) }
 如果 (c == 字符_双引号) { 返回 json解析字符串(状态) }
 如果 (c == 116) { 返回 json解析true(状态) }
 如果 (c == 字符_小写f) { 返回 json解析false(状态) }
 如果 (c == 110) { 返回 json解析null(状态) }
 如果 (c == 字符_减号 或 (c >= 字符_零 且 c <= 字符_九)) { 返回 json解析数字(状态) }
 状态[3] = "无效字符"
 返回 空
}

函数 json解析对象(状态) {
 json消耗(状态, 123)
 json跳空白(状态)
 定义 对象 = json_对象()
 如果 (json当前(状态) == 125) {
 json前进(状态)
 返回 对象
 }
 当 (状态[1] < 状态[2] 且 状态[3] == 空) {
 json跳空白(状态)
 // 解析键
 如果 (json当前(状态) != 34) {
 状态[3] = "期望字符串键"
 返回 对象
 }
 定义 键节点 = json解析字符串(状态)
 定义 键 = 键节点[1]
 json跳空白(状态)
 如果 (json当前(状态) != 58) {
 状态[3] = "期望冒号"
 返回 对象
 }
 json前进(状态)
 // 解析值
 定义 值 = json解析值(状态)
 json_设置(对象, 键, 值)
 json跳空白(状态)
 如果 (json当前(状态) == 125) {
 json前进(状态)
 返回 对象
 }
 如果 (json当前(状态) == 44) {
 json前进(状态)
 } 否则 {
 状态[3] = "期望逗号或右大括号"
 返回 对象
 }
 }
 返回 对象
}

函数 json解析数组(状态) {
 json消耗(状态, 91)
 json跳空白(状态)
 定义 数组 = json_数组()
 如果 (json当前(状态) == 93) {
 json前进(状态)
 返回 数组
 }
 当 (状态[1] < 状态[2] 且 状态[3] == 空) { 定义 值 = json解析值(状态)
 json_追加(数组, 值)
 json跳空白(状态)
 如果 (json当前(状态) == 93) {
 json前进(状态)
 返回 数组
 }
 如果 (json当前(状态) == 44) {
 json前进(状态)
 } 否则 {
 状态[3] = "期望逗号或右方括号"
 返回 数组
 }
 }
 返回 数组
}

函数 json解析字符串(状态) {
 json前进(状态)
 定义 可变 结果 = ""
 当 (状态[1] < 状态[2]) { 定义 c = json当前(状态)
 如果 (c == 字符_双引号) {
 json前进(状态)
 返回 JSON序列化_json_字符串(结果)
 }
 如果 (c == 字符_反斜杠) {
 json前进(状态)
 定义 esc = json当前(状态)
 如果 (esc == 34) { 结果 = 字符串拼接(结果, "\"") }
 否则 如果 (esc == 92) { 结果 = 字符串拼接(结果, "\\") }
 否则 如果 (esc == 47) { 结果 = 字符串拼接(结果, "/") }
 否则 如果 (esc == 110) { 结果 = 字符串拼接(结果, "\n") }
 否则 如果 (esc == 116) { 结果 = 字符串拼接(结果, "\t") }
 否则 如果 (esc == 114) { 结果 = 字符串拼接(结果, "\r") }
 否则 如果 (esc == 117) {
 // \uXXXX - 解析4位十六进制为Unicode码点
 定义 可变 cp = 0
 定义 可变 hi = 0
 当 (hi < 4) {
 json前进(状态)
 定义 hc = 编码(子串(状态[0], 状态[1], 1))
 如果 (hc >= 48 且 hc <= 57) { cp = cp * 16 + hc - 48 }
 否则 如果 (hc >= 65 且 hc <= 70) { cp = cp * 16 + hc - 55 }
 否则 如果 (hc >= 97 且 hc <= 102) { cp = cp * 16 + hc - 87 }
 hi = hi + 1
 }
 // UTF-8 编码输出
 如果 (cp < 0x80) {
 结果 = 字符串拼接(结果, 字符(cp))
 } 否则 如果 (cp < 0x800) {
 结果 = 字符串拼接(结果, 字符串拼接(字符(0xC0 + cp / 64), 字符(0x80 + cp % 64)))
 } 否则 {
 结果 = 字符串拼接(结果, 字符串拼接(字符(0xE0 + cp / 4096), 字符串拼接(字符(0x80 + (cp / 64) % 64), 字符(0x80 + cp % 64))))
 }
 }
 否则 { 结果 = 字符串拼接(结果, 子串(状态[0], 状态[1], 1)) }
 json前进(状态)
 } 否则 {
 结果 = 字符串拼接(结果, 子串(状态[0], 状态[1], 1))
 json前进(状态)
 }
 }
 状态[3] = "未终止的字符串"
 返回 JSON序列化_json_字符串(结果)
}

函数 json解析数字(状态) { 定义 可变 负 = 假
 如果 (json当前(状态) == 45) {
 负 = 真
 json前进(状态)
 }
 定义 可变 整数部分 = 0
 定义 可变 _整完 = 假
 当 (状态[1] < 状态[2] 且 _整完 == 假) { 定义 c = json当前(状态)
 如果 (c >= 字符_零 且 c <= 字符_九) {
 整数部分 = 整数部分 * 10 + (c - 48)
 json前进(状态)
 } 否则 { _整完 = 真 }
 }
 // 小数部分 (转为定点: 乘以1000)
 定义 可变 小数 = 0
 定义 可变 小数位 = 0
 如果 (状态[1] < 状态[2] 且 json当前(状态) == 46) {
 json前进(状态)
 定义 可变 因子 = 100
 定义 可变 _小完 = 假
 当 (状态[1] < 状态[2] 且 小数位 < 3 且 _小完 == 假) { 定义 c2 = json当前(状态)
 如果 (c2 >= 48 且 c2 <= 57) {
 小数 = 小数 + (c2 - 48) * 因子
 因子 = 因子 / 10
 小数位 = 小数位 + 1
 json前进(状态)
 } 否则 { _小完 = 真 }
 }
 // 跳过剩余小数位
 定义 可变 _剩完 = 假
 当 (状态[1] < 状态[2] 且 _剩完 == 假) { 定义 c3 = json当前(状态)
 如果 (c3 >= 48 且 c3 <= 57) { json前进(状态) }
 否则 { _剩完 = 真 }
 }
 }
 // 科学计数法 (跳过)
 如果 (状态[1] < 状态[2]) { 定义 ce = json当前(状态)
 如果 (ce == 101 或 ce == 69) {
 json前进(状态)
 如果 (状态[1] < 状态[2] 且 (json当前(状态) == 43 或 json当前(状态) == 45)) {
 json前进(状态)
 }
 定义 可变 _科完 = 假
 当 (状态[1] < 状态[2] 且 _科完 == 假) { 定义 c4 = json当前(状态)
 如果 (c4 >= 48 且 c4 <= 57) { json前进(状态) }
 否则 { _科完 = 真 }
 }
 }
 }
 定义 可变 值 = 整数部分 * 1000 + 小数
 如果 (负) { 值 = 0 - 值 }
 返回 json_数字(值)
}

函数 json解析true(状态) {
 json前进(状态) json前进(状态) json前进(状态) json前进(状态)
 返回 json_真()
}

函数 json解析false(状态) {
 json前进(状态) json前进(状态) json前进(状态) json前进(状态) json前进(状态)
 返回 json_假()
}

函数 json解析null(状态) {
 json前进(状态) json前进(状态) json前进(状态) json前进(状态)
 返回 JSON_空值()
}

// JSON 生成器

函数 json_生成(节点) { 返回 json生成值(节点, 0, 假)
}

函数 json_美化(节点) { 返回 json生成值(节点, 0, 真)
}

函数 json生成值(节点, 深度, 美化) {
    如果 (节点 == 空) { 返回 "空"
}
 定义 类型 = 节点[0]
 如果 (类型 == JSON_空) { 返回 "空" }
 如果 (类型 == JSON_布尔) { 如果 (节点[1]) { 返回 "真" }
 返回 "假"
 }
 如果 (类型 == JSON_数字) { 定义 v = 节点[1]
 定义 整 = v / 1000
 定义 可变 小 = v % 1000
 如果 (小 < 0) { 小 = 0 - 小 }
 如果 (小 == 0) { 返回 数到文(整) }
 定义 可变 小文 = 数到文(小)
 当 (计数(小文) < 3) { 小文 = 字符串拼接("0", 小文) }
 // 去除末尾0
 定义 可变 _去0完 = 假
 当 (计数(小文) > 1 且 _去0完 == 假) { 如果 (子串(小文, 计数(小文) - 1, 1) == "0") {
 小文 = 子串(小文, 0, 计数(小文) - 1)
 } 否则 { _去0完 = 真 }
 }
 返回 字符串拼接(数到文(整), 字符串拼接(".", 小文))
 }
 如果 (类型 == JSON_字符串) { 返回 字符串拼接("\"", 字符串拼接(json转义(节点[1]), "\""))
 }
 如果 (类型 == JSON_数组) { 定义 元素 = 节点[1]
 定义 n = 计数(元素)
 如果 (n == 0) { 返回 "[]" }
 定义 可变 结果 = "["
 如果 (美化) { 结果 = 字符串拼接(结果, "\n") }
 定义 可变 i = 0
 当 (i < n) { 如果 (美化) { 结果 = 字符串拼接(结果, json缩进(深度 + 1)) }
 结果 = 字符串拼接(结果, json生成值(元素[i], 深度 + 1, 美化))
 如果 (i < n - 1) { 结果 = 字符串拼接(结果, ",") }
 如果 (美化) { 结果 = 字符串拼接(结果, "\n") }
 i = i + 1
 }
 如果 (美化) { 结果 = 字符串拼接(结果, json缩进(深度)) }
 返回 字符串拼接(结果, "]")
 }
 如果 (类型 == JSON_对象) { 定义 键列 = 节点[1][0]
 定义 值列 = 节点[1][1]
 定义 n2 = 计数(键列)
 如果 (n2 == 0) { 返回 "{}" }
 定义 可变 结果2 = "{"
 如果 (美化) { 结果2 = 字符串拼接(结果2, "\n") }
 定义 可变 j = 0
 当 (j < n2) { 如果 (美化) { 结果2 = 字符串拼接(结果2, json缩进(深度 + 1)) }
 结果2 = 字符串拼接(结果2, "\"")
 结果2 = 字符串拼接(结果2, json转义(键列[j]))
 结果2 = 字符串拼接(结果2, "\":")
 如果 (美化) { 结果2 = 字符串拼接(结果2, " ") }
 结果2 = 字符串拼接(结果2, json生成值(值列[j], 深度 + 1, 美化))
 如果 (j < n2 - 1) { 结果2 = 字符串拼接(结果2, ", ") }
 如果 (美化) { 结果2 = 字符串拼接(结果2, "\n") }
 j = j + 1
 }
 如果 (美化) { 结果2 = 字符串拼接(结果2, json缩进(深度)) }
 返回 字符串拼接(结果2, "}")
 }
 返回 "空"
}

// JSON 路径查询 (JSONPath 简化)
// 支持 "key1.key2[0].key3" 形式

函数 json_查询(根, 路径) { 定义 可变 当前 = 根
 定义 n = 计数(路径)
 定义 可变 i = 0
 定义 可变 段 = ""
 当 (i <= n) { 定义 可变 c = 0
 如果 (i < n) { c = 编码(子串(路径, i, 1)) }
 如果 (i == n 或 c == 字符_句点) { 如果 (计数(段) > 0) {
 // 检查是否是数组索引 [N]
 如果 (计数(段) > 2 且 字符串等于(子串(段, 计数(段) - 1, 1), "]")) {
 // 提取键名和索引
 定义 可变 括号位 = 0
 定义 可变 _搜索中 = 真
 当 (括号位 < 计数(段) 且 _搜索中) { 如果 (字符串等于(子串(段, 括号位, 1), "[")) { _搜索中 = 假 }
 否则 { 括号位 = 括号位 + 1 }
 }
 如果 (括号位 > 0) { 定义 键名 = 子串(段, 0, 括号位)
 当前 = json_获取(当前, 键名)
 如果 (当前 == 空) { 返回 空 }
 }
 定义 索引文本 = 子串(段, 括号位 + 1, 计数(段) - 括号位 - 2)
 定义 索引 = 文到数(索引文本)
 当前 = json_取(当前, 索引)
 } 否则 {
 当前 = json_获取(当前, 段)
 }
 如果 (当前 == 空) { 返回 空 }
 }
 段 = ""
 } 否则 {
 段 = 字符串拼接(段, 子串(路径, i, 1))
 }
 i = i + 1
 }
 返回 当前
}

// 深拷贝
函数 json_克隆(节点) {
    如果 (节点 == 空) { 返回 空
}
 定义 类型 = 节点[0]
 如果 (类型 == JSON_空 或 类型 == JSON_布尔 或 类型 == JSON_数字 或 类型 == JSON_字符串) { 返回 [类型, 节点[1]]
 }
 如果 (类型 == JSON_数组) { 定义 新数组 = json_数组()
 定义 可变 i = 0
 当 (i < 计数(节点[1])) {
 json_追加(新数组, json_克隆(节点[1][i]))
 i = i + 1
 }
 返回 新数组
 }
 如果 (类型 == JSON_对象) { 定义 新对象 = json_对象()
 定义 键列 = 节点[1][0]
 定义 值列 = 节点[1][1]
 定义 可变 j = 0
 当 (j < 计数(键列)) {
 json_设置(新对象, 键列[j], json_克隆(值列[j]))
 j = j + 1
 }
 返回 新对象
 }
 返回 空
}

// 内部工具
函数 json当前(状态) {
    如果 (状态[1] >= 状态[2]) { 返回 0
}
 返回 编码(子串(状态[0], 状态[1], 1))
}

函数 json前进(状态) { 状态[1] = 状态[1] + 1 }

函数 json消耗(状态, 期望) {
    如果 (json当前(状态) == 期望) { json前进(状态)
}
 否则 { 状态[3] = "意外字符" }
}

函数 json跳空白(状态) {
 当 (状态[1] < 状态[2]) { 定义 c = json当前(状态)
 如果 (c == 字符_空格 或 c == 字符_制表 或 c == 字符_换行 或 c == 字符_回车) {
 json前进(状态)
 } 否则 { 返回 }
 }
}

函数 json转义(s) { 定义 n = 计数(s)
 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < n) { 定义 c = 子串(s, i, 1)
 如果 (字符串等于(c,  "\"")) { 结果 = 字符串拼接(结果, "\\\"") }
 否则 如果 (字符串等于(c, "\\")) { 结果 = 字符串拼接(结果, "\\\\") }
 否则 如果 (字符串等于(c, "\n")) { 结果 = 字符串拼接(结果, "\\n") }
 否则 如果 (字符串等于(c, "\t")) { 结果 = 字符串拼接(结果, "\\t") }
 否则 { 结果 = 字符串拼接(结果, c) }
 i = i + 1
 }
 返回 结果
}

函数 json缩进(深度) { 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 深度) { 结果 = 字符串拼接(结果, " ") i = i + 1 }
 返回 结果
}

函数 数到文(n) {
    如果 (n == 0) { 返回 "0"
}
 定义 可变 负 = 假
 定义 可变 v = n
 如果 (v < 0) { 负 = 真 v = 0 - v }
 定义 可变 结果 = ""
 当 (v > 0) { 定义 d = v % 10
 结果 = 字符串拼接(子串("0123456789", d, 1), 结果)
 v = v / 10
 }
 如果 (负) { 结果 = 字符串拼接("-", 结果) }
 返回 结果
}

函数 文到数(s) { 定义 n = 计数(s)
 定义 可变 结果 = 0
 定义 可变 负 = 假
 定义 可变 i = 0
 如果 (n > 0 且 字符串等于(子串(s, 0, 1), "-")) { 负 = 真 i = 1 }
 当 (i < n) { 定义 c = 编码(子串(s, i, 1))
 如果 (c >= 字符_零 且 c <= 字符_九) { 结果 = 结果 * 10 + (c - 48) }
 i = i + 1
 }
 如果 (负) { 结果 = 0 - 结果 }
 返回 结果
}

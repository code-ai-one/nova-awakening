// 异常严重等级查询

函数 异常_获取严重等级(向量号) {
    // 致命: 双重故障(8), 机器检查(18)
    如果 (向量号 == 8 || 向量号 == 18) { 返回 异常等级_致命 }
    // 严重: GP(13), PF(14), SS(12), TS(10), NP(11)
    如果 (向量号 == 13 || 向量号 == 14 || 向量号 == 12) { 返回 异常等级_严重 }
    如果 (向量号 == 10 || 向量号 == 11) { 返回 异常等级_严重 }
    // 可恢复: 调试(1), 断点(3)
    如果 (向量号 == 1 || 向量号 == 3) { 返回 异常等级_可恢复 }
    // 警告: 其余
    返回 异常等级_警告
}

函数 异常_等级名(等级) {
    如果 (等级 == 异常等级_可恢复) { 返回 "可恢复" }
    如果 (等级 == 异常等级_警告) { 返回 "警告" }
    如果 (等级 == 异常等级_严重) { 返回 "严重" }
    如果 (等级 == 异常等级_致命) { 返回 "致命" }
    返回 "未知"
}

函数 异常_是致命(向量号) {
    返回 异常_获取严重等级(向量号) == 异常等级_致命
}

函数 异常_需要信号(向量号) {
    // 以下异常在用户态发生时需要向进程发信号
    如果 (向量号 == 0) { 返回 真 }   // SIGFPE
    如果 (向量号 == 4) { 返回 真 }   // SIGFPE
    如果 (向量号 == 5) { 返回 真 }   // SIGSEGV
    如果 (向量号 == 6) { 返回 真 }   // SIGILL
    如果 (向量号 == 11) { 返回 真 }  // SIGBUS
    如果 (向量号 == 12) { 返回 真 }  // SIGSEGV
    如果 (向量号 == 13) { 返回 真 }  // SIGSEGV
    如果 (向量号 == 14) { 返回 真 }  // SIGSEGV (用户态缺页失败)
    如果 (向量号 == 16) { 返回 真 }  // SIGFPE
    如果 (向量号 == 17) { 返回 真 }  // SIGBUS
    如果 (向量号 == 19) { 返回 真 }  // SIGFPE
    返回 假
}

函数 异常_对应信号(向量号) {
    如果 (向量号 == 0 || 向量号 == 4 || 向量号 == 16 || 向量号 == 19) { 返回 8 }  // SIGFPE
    如果 (向量号 == 6) { 返回 4 }   // SIGILL
    如果 (向量号 == 5 || 向量号 == 12 || 向量号 == 13 || 向量号 == 14) { 返回 11 } // SIGSEGV
    如果 (向量号 == 11 || 向量号 == 17) { 返回 7 }  // SIGBUS
    返回 0
}

// 异常名称/描述映射

函数 异常_名称(向量号) {
    如果 (向量号 == 0) { 返回 "#DE 除零异常" }
    如果 (向量号 == 1) { 返回 "#DB 调试异常" }
    如果 (向量号 == 2) { 返回 "NMI 不可屏蔽中断" }
    如果 (向量号 == 3) { 返回 "#BP 断点" }
    如果 (向量号 == 4) { 返回 "#OF 溢出" }
    如果 (向量号 == 5) { 返回 "#BR 边界越界" }
    如果 (向量号 == 6) { 返回 "#UD 无效操作码" }
    如果 (向量号 == 7) { 返回 "#NM 设备不可用(无FPU)" }
    如果 (向量号 == 8) { 返回 "#DF 双重故障" }
    如果 (向量号 == 10) { 返回 "#TS 无效TSS" }
    如果 (向量号 == 11) { 返回 "#NP 段不存在" }
    如果 (向量号 == 12) { 返回 "#SS 栈段故障" }
    如果 (向量号 == 13) { 返回 "#GP 一般保护故障" }
    如果 (向量号 == 14) { 返回 "#PF 缺页故障" }
    如果 (向量号 == 16) { 返回 "#MF x87浮点异常" }
    如果 (向量号 == 17) { 返回 "#AC 对齐检查" }
    如果 (向量号 == 18) { 返回 "#MC 机器检查" }
    如果 (向量号 == 19) { 返回 "#XM SIMD浮点异常" }
    如果 (向量号 == 20) { 返回 "#VE 虚拟化异常" }
    如果 (向量号 == 21) { 返回 "#CP 控制保护异常" }
    返回 "异常#" + 转字符串(向量号)
}

// AI基因: 异常模式检测
// 检测异常是否呈现异常模式(频繁重复=可能bug)

函数 异常_检测重复模式() {
    // 检查异常链中是否有连续相同异常(可能是bug导致的循环)
    如果 (异常_已初始化 == 假) { 返回 假 }
    定义 可变 连续数 = 1
    定义 可变 i = 1
    当 (i < 异常链_最大) {
        定义 当前 = (异常链_写指针 - i + 异常链_最大) % 异常链_最大
        定义 前一个 = (异常链_写指针 - i - 1 + 异常链_最大) % 异常链_最大
        如果 (异常链[当前][0] == 异常链[前一个][0] && 异常链[当前][0] != 0) {
            连续数 = 连续数 + 1
        } 否则 {
            如果 (连续数 > 3) { 返回 真 }
            连续数 = 1
        }
        i = i + 1
    }
    返回 连续数 > 3
}

函数 异常_获取最频繁() {
    如果 (异常_已初始化 == 假) { 返回 0 - 1 }
    定义 可变 最大 = 0
    定义 可变 最大向量 = 0 - 1
    定义 可变 i = 0
    当 (i < 32) {
        如果 (异常计数[i] > 最大) {
            最大 = 异常计数[i]
            最大向量 = i
        }
        i = i + 1
    }
    返回 最大向量
}

// 完整统计 (≥15个指标)

函数 异常入口_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "已初始化", 异常_已初始化)
    字典设(统计, "总计数", 异常_总计数)
    字典设(统计, "内核态计数", 异常_内核态计数)
    字典设(统计, "用户态计数", 异常_用户态计数)
    字典设(统计, "致命计数", 异常_致命计数)
    字典设(统计, "最后向量", 异常_最后向量)
    字典设(统计, "最后错误码", 异常_最后错误码)
    字典设(统计, "最后CR2", 异常_最后CR2)
    字典设(统计, "链写指针", 异常链_写指针)
    字典设(统计, "最频繁异常", 异常_获取最频繁())
    字典设(统计, "重复模式", 异常_检测重复模式())
    字典设(统计, "错误数", 异常_错误数)
    // 按异常类型
    如果 (异常_已初始化 == 真) {
        字典设(统计, "除零次数", 异常计数[0])
        字典设(统计, "GP次数", 异常计数[13])
        字典设(统计, "缺页次数", 异常计数[14])
        字典设(统计, "双重故障次数", 异常计数[8])
    }
    返回 统计
}

函数 异常入口_打印统计() {
    定义 统计 = 异常入口_完整统计()
    打印("[异常入口] ═══════ 完整统计 ═══════")
    打印("  总异常:       " + 转字符串(字典取(统计, "总计数")))
    打印("  内核态:       " + 转字符串(字典取(统计, "内核态计数")))
    打印("  用户态:       " + 转字符串(字典取(统计, "用户态计数")))
    打印("  致命:         " + 转字符串(字典取(统计, "致命计数")))
    打印("  最后异常:     " + 异常_名称(字典取(统计, "最后向量")))
    打印("  最后错误码:   0x" + 转字符串(字典取(统计, "最后错误码")))
    打印("  最后CR2:      0x" + 转字符串(字典取(统计, "最后CR2")))
    打印("  最频繁:       " + 异常_名称(字典取(统计, "最频繁异常")))
    打印("  重复模式:     " + 转字符串(字典取(统计, "重复模式")))
    // 打印每异常计数
    如果 (异常_已初始化 == 真) {
        打印("  ── 各异常计数 ──")
        定义 可变 i = 0
        当 (i < 32) {
            如果 (异常计数[i] > 0) {
                打印("  " + 异常_名称(i) + ": " + 转字符串(异常计数[i]) +
                     " [" + 异常_等级名(异常_获取严重等级(i)) + "]")
            }
            i = i + 1
        }
    }
    打印("[异常入口] ═════════════════════════")
    返回 0
}

// 异常链dump

函数 异常入口_dump链() {
    如果 (异常_已初始化 == 假) {
        打印("[异常链] 未初始化")
        返回
    }
    打印("[异常链] ── 最近异常 ──")
    定义 可变 i = 0
    当 (i < 异常链_最大) {
        定义 索引 = (异常链_写指针 - 1 - i + 异常链_最大) % 异常链_最大
        定义 条目 = 异常链[索引]
        如果 (条目[2] > 0) {
            打印("  [" + 转字符串(i) + "] " + 异常_名称(条目[0]) +
                 " 错误码=0x" + 转字符串(条目[1]) +
                 " 时间=" + 转字符串(条目[2]) +
                 " CR2=0x" + 转字符串(条目[3]))
        }
        i = i + 1
    }
}

函数 异常入口_dump() {
    打印("[异常入口 dump] ──────────────────")
    打印("  已初始化: " + 转字符串(异常_已初始化))
    打印("  总计数: " + 转字符串(异常_总计数))
    打印("  最后向量: " + 转字符串(异常_最后向量) + " (" + 异常_名称(异常_最后向量) + ")")
    打印("  最后错误码: 0x" + 转字符串(异常_最后错误码))
    打印("  最后CR2: 0x" + 转字符串(异常_最后CR2))
    打印("  链写指针: " + 转字符串(异常链_写指针))
    打印("[异常入口 dump] ──────────────────")
}

// 销毁与清理

函数 异常入口_销毁() {
    如果 (异常_已初始化 == 假) { 返回 0 }
    异常计数 = []
    异常链 = []
    异常_已初始化 = 假
    打印("[异常入口] 已销毁")
    返回 0
}

// 与其他子系统的接口

函数 异常入口_为信号子系统提供信号(向量号) {
    // 返回该异常对应的POSIX信号号
    如果 (异常_需要信号(向量号) == 假) { 返回 0 }
    返回 异常_对应信号(向量号)
}

函数 异常入口_为进程管理提供异常信息() {
    返回 [异常_最后向量, 异常_最后错误码, 异常_最后CR2,
           异常_获取严重等级(异常_最后向量)]
}

函数 异常入口_为AI提供异常模式() {
    返回 [异常_总计数, 异常_获取最频繁(), 异常_检测重复模式()]
}

函数 异常入口_为procfs提供统计() {
    如果 (异常_已初始化 == 假) { 返回 [] }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 32) {
        如果 (异常计数[i] > 0) {
            追加(结果, [i, 异常计数[i], 异常_名称(i)])
        }
        i = i + 1
    }
    返回 结果
}

函数 异常入口_重置统计() {
    异常_总计数 = 0
    异常_内核态计数 = 0
    异常_用户态计数 = 0
    异常_致命计数 = 0
    异常_错误数 = 0
    如果 (异常_已初始化 == 真) {
        定义 可变 i = 0
        当 (i < 32) { 设置(异常计数, i, 0); i = i + 1 }
    }
    打印("[异常入口] 统计已重置")
    返回 0
}

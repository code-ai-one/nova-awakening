// §9 辅助函数

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 AHCI_查找空闲槽(port) {
    定义 slots = MMIO读32(port.端口基址 + PORT_SACT)
    slots = slots | MMIO读32(port.端口基址 + PORT_CI)
    定义 可变 i = 0
    当 (i < 32) {
        如果 ((slots & (1 << i)) == 0) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 AHCI_等待完成(port, slot) {
    定义 可变 等待 = 0
    当 (等待 < 10000) {
        // 检查错误
        定义 is = MMIO读32(port.端口基址 + PORT_IS)
        如果 ((is & 0x40000000) != 0) {
            // 任务文件错误
            返回 假
        }
        // 检查命令完成
        如果 ((MMIO读32(port.端口基址 + PORT_CI) & (1 << slot)) == 0) {
            返回 真
        }
        延迟_us(100)
        等待 = 等待 + 1
    }
    返回 假
}

函数 AHCI_读ATA字符串(缓冲, 起始word, 结束word) {
    // ATA字符串: 每个WORD的高低字节是反的
    定义 可变 结果 = ""
    定义 可变 w = 起始word
    当 (w <= 结束word) {
        定义 val = 内存读16(缓冲 + w * 2)
        定义 高 = (val >> 8) & 0xFF
        定义 低 = val & 0xFF
        如果 (高 >= 0x20 && 高 <= 0x7E) { 结果 = 结果 + 字符(高) }
        如果 (低 >= 0x20 && 低 <= 0x7E) { 结果 = 结果 + 字符(低) }
        w = w + 1
    }
    返回 字符串_去尾空(结果)
}

函数 MMIO读16(地址) { 返回 内存读16(地址) }

函数 直传_分配_对齐(大小, 对齐) {
    // 分配物理连续内存并对齐到指定边界
    // 策略: 多分配一个对齐大小, 然后对齐返回地址
    定义 页数 = (大小 + 对齐 + 4095) / 4096
    定义 原始 = 伙伴系统_分配(页数)
    如果 (原始 == 0) { 返回 0 }
    // 对齐到指定边界
    定义 对齐地址 = (原始 + 对齐 - 1) & ~(对齐 - 1)
    返回 对齐地址
}

函数 延迟_ms(毫秒) {
    // 使用TSC进行毫秒级忙等待
    定义 可变 i = 0
    当 (i < 毫秒) {
        延迟_us(1000)
        i = i + 1
    }
}

函数 延迟_us(微秒) {
    // TSC忙等待: 假设CPU~2GHz, 1us≈2000周期
    定义 目标 = 微秒 * 2000
    定义 开始 = AHCI_读取TSC()
    当 (AHCI_读取TSC() - 开始 < 目标) {
        内联汇编("pause")  // 降低功耗/避免流水线停顿
    }
}

函数 AHCI_读取TSC() {
    返回 内联汇编_返回值("rdtsc")
}

函数 字符串_去尾空(s) {
    // 去除末尾空格
    定义 可变 长度 = 字符串长度(s)
    当 (长度 > 0) {
        定义 c = 字符编码(s, 长度 - 1)
        如果 (c != 0x20 && c != 0x00) { 跳出 }  // 非空格非\0
        长度 = 长度 - 1
    }
    返回 字符串_截取(s, 0, 长度)
}

// 块设备注册 — 创建/dev/节点并注册到块设备层
定义 可变 块设备表 = []   // [名称, 设备引用, 读函数, 写函数]

函数 块设备_注册(名称, port) {
    // 1. 创建设备节点
    定义 dev_path = "/dev/" + 名称
    VFS_创建文件(dev_path, 0x1B0)  // brw-r----- (0660)

    // 2. 注册到块设备表(文件系统层通过名称查找设备)
    追加(块设备表, [名称, port])

    // 3. 扫描分区表(如果是磁盘设备)
    如果 (port.设备类型 == SATA_SIG_ATA) {
        AHCI_扫描分区(port, 名称)
    }

    内核信息("块设备: 注册 /dev/" + 名称 +
             " 容量=" + 整数转字符串(port.设备信息.扇区数 * port.设备信息.扇区大小 / 1048576) + "MB")
}

函数 AHCI_扫描分区(port, 基名) {
    // 读MBR/Nova语言模型分区表
    定义 mbr = 直传_分配_对齐(512, 512)
    如果 (mbr == 0) { 返回 }
    AHCI_读扇区(port, 0, 1, mbr)

    // 检查MBR签名
    如果 (内存读16(mbr + 510) == 0xAA55) {
        // 解析四个主分区(MBR偏移0x1BE, 每条目16字节)
        定义 可变 p = 0
        当 (p < 4) {
            定义 条目 = mbr + 0x1BE + p * 16
            定义 类型 = 内存读8(条目 + 4)
            定义 起始LBA = 内存读32(条目 + 8)
            定义 扇区数 = 内存读32(条目 + 12)
            如果 (类型 != 0 && 扇区数 > 0) {
                定义 分区名 = 基名 + 整数转字符串(p + 1)
                内核信息("分区: /dev/" + 分区名 +
                         " 类型=" + 整数转十六进制(类型) +
                         " 起始=" + 整数转字符串(起始LBA) +
                         " 大小=" + 整数转字符串(扇区数 / 2048) + "MB")
                VFS_创建文件("/dev/" + 分区名, 0x1B0)
            }
            p = p + 1
        }

        // 检查是否是Nova语言模型(第一个分区类型=0xEE)
        定义 第一分区类型 = 内存读8(mbr + 0x1BE + 4)
        如果 (第一分区类型 == 0xEE) {
            内核信息("分区: 检测到Nova语言模型分区表")
            // 解析Nova语言模型头(LBA 1)和分区条目(LBA 2-33)
        }
    }
}

// 块设备查找 — 文件系统层通过此函数获取设备引用
函数 块设备_查找(名称) {
    定义 可变 i = 0
    当 (i < 计数(块设备表)) {
        如果 (块设备表[i][0] == 名称) { 返回 块设备表[i][1] }
        i = i + 1
    }
    返回 空
}

// 块设备读写接口 — 供文件系统/VFS层调用
函数 块设备_读(设备, 起始扇区, 扇区数, 缓冲) {
    // 根据设备类型分派到AHCI或NVMe
    如果 (设备 != 空 && 设备.设备类型 == SATA_SIG_ATA) {
        返回 AHCI_读扇区(设备, 起始扇区, 扇区数, 缓冲)
    }
    返回 错误_设备
}

函数 块设备_写(设备, 起始扇区, 扇区数, 数据) {
    如果 (设备 != 空 && 设备.设备类型 == SATA_SIG_ATA) {
        返回 AHCI_写扇区(设备, 起始扇区, 扇区数, 数据)
    }
    返回 错误_设备
}

定义 错误_设备   = -19
定义 错误_设备忙 = -16
定义 错误_IO     = -5

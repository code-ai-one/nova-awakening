导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("./项问候服务.nova")
导入("../中枢/读取调用.nova")
导入("./证书验证.nova")
导入("../中枢/字符串替换.nova")
导入("./安全密钥派.nova")

    定义 ch = 构建_ClientHello(tls)
    安全_发送记录(tls, 安全_握手, ch)

    定义 sh_记录 = 安全_接收记录(tls)
    如果 (sh_记录 == 空 || sh_记录.类型 != 安全_握手) {
        tls.状态 = 安全_状态_错误
        返回 假
    }
    解析_ServerHello(tls, sh_记录.数据)
    tls.状态 = 安全_状态_等待服务器

    tls.预主密钥 = X25519_乘法(tls.私钥, tls.对方公钥)
    tls.主密钥 = HKDF_展开(tls.预主密钥, tls.客户端随机数, tls.服务端随机数, 48)

    tls.客户端写密钥 = HKDF_展开(tls.主密钥, "c hs traffic", 空, 16)
    tls.服务端写密钥 = HKDF_展开(tls.主密钥, "s hs traffic", 空, 16)
    tls.客户端写IV = HKDF_展开(tls.主密钥, "c hs iv", 空, 12)
    tls.服务端写IV = HKDF_展开(tls.主密钥, "s hs iv", 空, 12)

    定义 可变 握手完成 = 假
    当 (!握手完成) {
        定义 记录 = 安全_接收记录(tls)
        如果 (记录 == 空) { tls.状态 = 安全_状态_错误; 返回 假 }

        // 安全 1.3: 证书和Finished在加密的应用数据记录中
        定义 明文 = AES_GCM_解密(记录.数据, tls.服务端写密钥, tls.服务端写IV, tls.接收序号)
        tls.接收序号 = tls.接收序号 + 1
        如果 (明文 == 空) { tls.状态 = 安全_状态_错误; 返回 假 }

        定义 内部类型 = 明文[计数(明文) - 1]
        如果 (内部类型 == HS_证书) {
            tls.服务端证书 = 明文
            tls.已验证 = 验证证书(tls.服务端证书, tls.主机名)
        } 否则如果 (内部类型 == HS_完成) {
            握手完成 = 真
        }
    }

    定义 finished = 构建_Finished(tls)
    定义 加密finished = AES_GCM_加密(finished, tls.客户端写密钥, tls.客户端写IV, tls.发送序号)
    tls.发送序号 = tls.发送序号 + 1
    安全_发送记录(tls, 安全_应用数据, 加密finished)

    tls.客户端写密钥 = HKDF_展开(tls.主密钥, "c ap traffic", 空, 16)
    tls.服务端写密钥 = HKDF_展开(tls.主密钥, "s ap traffic", 空, 16)
    tls.客户端写IV = HKDF_展开(tls.主密钥, "c ap iv", 空, 12)
    tls.服务端写IV = HKDF_展开(tls.主密钥, "s ap iv", 空, 12)
    tls.发送序号 = 0
    tls.接收序号 = 0

    tls.状态 = 安全_状态_已建立
    内核信息("安全: 握手完成 密码套件=AES-128-GCM-SHA256 版本=1.3")
    返回 真
}

// §4 加密数据传输

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 安全_发送(tls, 数据) {
    如果 (tls == 空 || tls.状态 != 安全_状态_已建立) { 返回 -1 }
    // 加密数据
    定义 加密数据 = AES_GCM_加密(数据, tls.客户端写密钥, tls.客户端写IV, tls.发送序号)
    tls.发送序号 = tls.发送序号 + 1
    // 发送安全记录
    安全_发送记录(tls, 安全_应用数据, 加密数据)
    返回 计数(数据)
}

函数 安全_接收(tls) {
    如果 (tls == 空 || tls.状态 != 安全_状态_已建立) { 返回 空 }
    定义 记录 = 安全_接收记录(tls)
    如果 (记录 == 空) { 返回 空 }
    // 解密数据
    定义 明文 = AES_GCM_解密(记录.数据, tls.服务端写密钥, tls.服务端写IV, tls.接收序号)
    tls.接收序号 = tls.接收序号 + 1
    返回 明文
}

函数 安全_关闭(tls) {
    如果 (tls == 空) { 返回 }
    // 发送close_notify警报
    定义 警报 = [1, 0]  // warning, close_notify
    如果 (tls.状态 == 安全_状态_已建立) {
        定义 加密警报 = AES_GCM_加密(警报, tls.客户端写密钥, tls.客户端写IV, tls.发送序号)
        安全_发送记录(tls, 安全_警报, 加密警报)
    }
    tls.状态 = 安全_状态_关闭中
}

// §5 记录层

结构 安全记录 {
    类型,
    版本,
    长度,
    数据,    // []
}

函数 安全_发送记录(tls, 类型, 数据) {
    // 安全记录头: 类型(1) + 版本(2) + 长度(2) + 数据
    定义 总长 = 5 + 计数(数据)
    定义 可变 缓冲 = 创建缓冲(总长)
    缓冲写(缓冲, 0, 类型)
    缓冲写(缓冲, 1, 0x03); 缓冲写(缓冲, 2, 0x03)  // 安全 1.2兼容
    缓冲写16(缓冲, 3, 计数(数据))
    // 复制数据
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        缓冲写(缓冲, 5 + i, 数据[i])
        i = i + 1
    }
    sys_write(tls.socket_fd, 缓冲, 总长, 0, 0, 0)
}

函数 安全_接收记录(tls) {
    // 读取5字节记录头
    定义 头 = 创建缓冲(5)
    定义 读取 = sys_read(tls.socket_fd, 头, 5, 0, 0, 0)
    如果 (读取 < 5) { 返回 空 }

    定义 记录 = 安全记录 {}
    记录.类型 = 缓冲读(头, 0)
    记录.版本 = 缓冲读(头, 1) * 256 + 缓冲读(头, 2)
    记录.长度 = 缓冲读(头, 3) * 256 + 缓冲读(头, 4)

    如果 (记录.长度 > 16384) { 返回 空 }  // 最大记录16KB

    // 读取数据
    定义 数据 = 创建缓冲(记录.长度)
    定义 已读 = sys_read(tls.socket_fd, 数据, 记录.长度, 0, 0, 0)
    如果 (已读 < 记录.长度) { 返回 空 }
    记录.数据 = 数据
    返回 记录

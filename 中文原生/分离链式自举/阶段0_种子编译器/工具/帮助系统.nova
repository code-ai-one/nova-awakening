// Nova · 工具 · 帮助系统
// 编译器使用帮助/语法/内建/标准库/架构/示例/AI参考
函数 帮助_概述() {
    打印("================================================================================")
    打印("                    龙 Nova 原生编译器 v3.1.0")
    打印("              纯中文 -> x86-64 原生机器码 (Linux ELF)")
    打印("================================================================================")
    打印("")
    打印("用法:")
    打印("  nova <源文件.nova>        编译Nova源文件为x86-64原生可执行文件")
    打印("  nova 帮助                 显示此帮助信息")
    打印("  nova 帮助 语法            Nova语言语法参考")
    打印("  nova 帮助 内建            内建函数完整列表(65个)")
    打印("  nova 帮助 标准库          标准库模块概览(237个模块, 5800+法)")
    打印("  nova 帮助 架构            编译器架构与x86-64指令集")
    打印("  nova 帮助 示例            代码示例")
    打印("  nova 帮助 ai              AI精准开发参考(语法规范/限制/模式)")
    打印("  nova 帮助 全部            输出全部帮助(供AI参考)")
    打印("")
    打印("概述:")
    打印("  Nova编译器将Nova语言(.nova)源代码直接编译为x86-64原生可执行文件(ELF64)。")
    打印("  无需任何外部工具链/链接器/运行时。纯中文关键字,零英文依赖。")
    打印("  内含完整标准库: AI/神经网络/数学/系统/网络/图形/加密等237个模块。")
    打印("  支持自举: 编译器可编译自身,Stage2==Stage3二进制完全一致。")
    打印("")
    打印("核心特性:")
    打印("  [原生编译] 直接生成x86-64机器码,不经过中间语言,不依赖外部编译器")
    打印("  [纯中文]   关键字/标识符/错误信息全部中文,中文是直击0/1的原生语言")
    打印("  [单文件]   生成独立PE可执行文件,无外部依赖,可直接运行")
    打印("  [自举]     编译器可编译自身,输出二进制SHA256一致")
    打印("  [5800+法] 覆盖AI/数学/系统/网络/图形/加密/数据结构等全领域")
    打印("  [闭包]     匿名函数自动捕获外层变量")
    打印("  [结构体]   用户定义复合数据类型,点号访问/赋值")
    打印("  [模块导入] 多文件项目,入/引用两种方式")
    打印("  [辨]     模式匹配(switch/match)语句")
    打印("  [异常]     试/得/抛 异常处理")
    打印("  [每个循环] 每 x 在 列表 < > 遍历语法")
    打印("")
    打印("编译示例:")
    打印("  nova hello.nova           -> 生成 hello")
    打印("  nova 自举入口.nova        -> 自举编译,生成新编译器")
}

函数 帮助_语法() {
    打印("================================================================================")
    打印("                         Nova 语言语法参考")
    打印("================================================================================")
    打印("")
    打印("■ 关键字 (22个单字原创关键字):")
    打印("  定义      不可变绑定        定义 x = 10")
    打印("  定义 可变 可变绑定          定义 可变 x = 0")
    打印("  函数 定义函数          函数 加法(a, b) { 返回 a + b }")
    打印("  返回      返回值            返回 结果")
    打印("  如果 (     条件判断          如果 (x > 0) { ... }")
    打印("  则      条件引导          如果 (...) { }")
    打印("  否      条件否则          否则 { ... } 或 否则 如果 (...) { ... }")
    打印("  当 (     条件循环          当 i < 10) { i = i + 1 }")
    打印("  时      循环引导          当 (...) { }")
    打印("  永      无限循环          永 { 如果 (条件) { _止 } }")
    打印("  每      遍历              每 项 在 列表 { 打印(项) }")
    打印("  在      遍历介词          每 X 在 Y { }")
    打印("  _止      跳出循环          止")
    打印("  续      跳过本次          续")
    打印("  入      导入模块          导入('模块.nova')")
    打印("  用      引用模块          用 '../模块.nova'")
    打印("  结构 定义结构体        结构 点 { x, y }")
    打印("  建      创建结构实例      定义 p = 建 点 { x: 1, y: 2 }")
    打印("  辨      模式辨别          辨 值 { 为 1 { ... } 为 2 { ... } 余 { ... } }")
    打印("  为      辨别分支          为 模式值 { }")
    打印("  余      辨别默认          余 { }")
    打印("  试      异常处理          试 { ... } 得 错误 { ... }")
    打印("  得      捕获异常          得 错误名 { 处理代码 }")
    打印("  抛      抛出异常          抛('错误信息')")
    打印("  空      空值              如果 (x == 空) { ... }")
    打印("  真/假   布尔值            定义 标志 = 真")
    打印("")
    打印("■ 数据类型:")
    打印("  整数      64位有符号        定义 x = 42")
    打印("  浮点      64位双精度        定义 pi = 3.14159")
    打印("  字符串    UTF-8             定义 名字 = '你好世界'")
    打印("  列表      动态数组          定义 表 = [1, 2, 3]")
    打印("  字典      哈希映射          定义 映射 = 字典()")
    打印("  结构体    复合类型          定义 点 = 建 坐标 { x: 1, y: 2 }")
    打印("  函数 一等公民          定义 回调 = 法(x) { 返回 x + 1 }")
    打印("  空      空值              空")
    打印("")
    打印("■ 运算符:")
    打印("  算术    + - * / %           加减乘除取模")
    打印("  比较    == != < > <= >=     等于/不等/小于/大于/小等/大等")
    打印("  逻辑    && || !             与/或/非")
    打印("  位运算  & | ^ ~ << >>       按位与/或/异或/取反/左移/右移")
    打印("  赋值    =                   赋值")
    打印("  索引    a[i]                列表/字典索引")
    打印("  点号    a.字段              结构体字段访问")
    打印("  字符串  +                   字符串拼接: '你' + '好' -> '你好'")
    打印("")
    打印("■ 函数定义:")
    打印("  函数 名称(参数1, 参数2) {")
    打印("      // 函数体")
    打印("      返回 结果")
    打印("  }")
    打印("")
    打印("■ 条件控制(中文自然语法, 无C强制括号):")
    打印("  如果 (x > 0) {")
    打印("      打印(x)")
    打印("  } 否则 如果 (x == 0) {")
    打印("      打印(0)")
    打印("  } 否则 {")
    打印("      打印(-1)")
    打印("  }")
    打印("")
    打印("■ 循环(中文自然语法):")
    打印("  当 (i < 10) { i = i + 1 }       // 条件循环")
    打印("  永 { 如果 (条件) { _止 } }          // 无限循环")
    打印("  每 项 在 列表 { 打印(项) }        // 遍历")
    打印("")
    打印("■ 模式辨别(原创语法):")
    打印("  辨 值 {")
    打印("      为 1 { 打印(1) }")
    打印("      为 2 { 打印(2) }")
    打印("      余 { 打印(0) }")
    打印("  }")
    打印("")
    打印("■ 匿名函数/闭包:")
    打印("  定义 平方 = 法(x) { 返回 x * x }")
    打印("  定义 加n = 法(n) { 返回 法(x) { 返回 x + n } }  // 闭包")
    打印("  定义 箭头 = (x) => x * 2                      // 箭头函数")
    打印("")
    打印("■ 结构体:")
    打印("  结构 向量 { x, y, z }")
    打印("  定义 v = 建 向量 { x: 1, y: 2, z: 3 }")
    打印("  打印(v.x)                    // 访问字段")
    打印("  v.x = 10                     // 修改字段")
    打印("")
    打印("■ 模块导入:")
    打印("  导入('标准库/数学/数学.nova')      // 导入文件中所有函数")
    打印("  用 '../模块.nova'                // 引用方式导入")
    打印("")
    打印("■ 异常处理:")
    打印("  试 {")
    打印("      定义 结果 = 危险操作()")
    打印("  } 得 错误 {")
    打印("      打印文本(字符串拼接('错误: ', 转字符串(错误)))")
    打印("  }")
    打印("")
    打印("■ 自然语言编程(像写文章一样开发):")
    打印("  中文运算:  3 加 5    10 减 3    4 乘 5    15 除 3")
    打印("  中文比较:  x 大于 0  x 小于 10  x 等于 y  x 不等于 y")
    打印("  中文范围:  x 不小于 60  x 不大于 100")
    打印("  中文逻辑:  A 并且 B  A 或者 B  非 条件")
    打印("  中文赋值:  定义 名字 是 '小明'    定义 可变 计数 是 0")
    打印("  中文访问:  学生 的 姓名         列表 的 长度")
    打印("  自然输出:  说('你好世界')       显示(变量)")
    打印("  自然循环:  重复 5 次 { ... }    从 1 到 10 { ... }")
    打印("  所有写法直接编译为x86-64机器码, 无中间语言, 不套壳")
}

函数 帮助_内建() {
    定义 可变 列表 = []
    打印("================================================================================")
    打印("                       内建函数完整列表 (78个)")
    打印("================================================================================")
    打印("")
    打印("■ 输出 (3个):")
    打印("  打印(字符串字面量)          输出字符串字面量+换行")
    打印("  打印文本(字符串表达式)      输出字符串表达式+换行")
    打印("  打印值(任意值)              输出任意值的调试表示")
    打印("")
    打印("■ 字符串操作 (15个):")
    打印("  字符串拼接(a, b)            拼接两个字符串 -> 新字符串")
    打印("  字符串等于(a, b)            比较两个字符串是否相等 -> 布尔")
    打印("  子串(字符串, 起始, 长度)     提取子字符串")
    打印("  字节长度(字符串)            返回字符串的字节长度")
    打印("  字节取(字符串, 索引)        取第n个字节的值")
    打印("  编码(字符串)                返回首字符的Unicode编码值")
    打印("  字符(编码值)                Unicode编码值转字符")
    打印("  替换(字符串, 旧, 新)        替换子串")
    打印("  查找(字符串, 子串)          查找子串位置, -1=未找到")
    打印("  包含(字符串, 子串)          是否包含子串 -> 布尔")
    打印("  以开头(字符串, 前缀)        是否以前缀开头 -> 布尔")
    打印("  以结尾(字符串, 后缀)        是否以后缀结尾 -> 布尔")
    打印("  大写化(字符串)              转大写")
    打印("  小写化(字符串)              转小写")
    打印("  分割(字符串, 分隔符)        按分隔符分割字符串 -> 列表")
    打印("")
    打印("■ 类型转换 (4个):")
    打印("  转字符串(值)                任意值转字符串表示")
    打印("  整数(字符串)                字符串转整数")
    打印("  类型(值)                    返回值的类型名: '整数'/'字符串'/'列表'/'字典'")
    打印("  拼接(a, b)                  通用拼接(字符串或列表)")
    打印("")
    打印("■ 列表操作 (8个):")
    打印("  计数(列表或字符串)          返回元素数量或字符串长度")
    打印("  追加(列表, 值)              在列表末尾添加元素")
    打印("  插入(列表, 索引, 值)        在指定位置插入元素")
    打印("  删除(列表, 索引)            删除指定位置的元素, 返回被删值")
    打印("  设置(列表, 索引, 值)        设置指定位置的值")
    打印("  范围(起, _止, 步)            生成整数范围列表")
    打印("  是列表(值)                  判断是否为列表 -> 布尔")
    打印("  是整数(值)                  判断是否为整数 -> 布尔")
    打印("")
    打印("■ 字典操作 (7个):")
    打印("  字典()                      创建空字典")
    打印("  字典取(字典, 键)            获取值, 键不存在返回空")
    打印("  字典设(字典, 键, 值)        设置键值对")
    打印("  字典有(字典, 键)            键是否存在 -> 布尔")
    打印("  字典键(字典)                返回所有键的列表")
    打印("  字典值(字典)                返回所有值的列表")
    打印("  是字典(值)                  判断是否为字典 -> 布尔")
    打印("  是字符串(值)                判断是否为字符串 -> 布尔")
    打印("")
    打印("■ 数学 (5个):")
    打印("  绝对值(数)                  返回绝对值")
    打印("  最大值(a, b)                返回较大值")
    打印("  最小值(a, b)                返回较小值")
    打印("  幂(底数, 指数)              整数幂运算")
    打印("  随机数(0)                    返回伪随机整数")
    打印("")
    打印("■ 文件操作 (7个):")
    打印("  读文件(路径)                读取文件全部内容为字符串, 失败返回空")
    打印("  写文件(路径,  内容, 0)          写入字符串到文件")
    打印("  文件存在(路径)              检查文件是否存在 -> 布尔")
    打印("  读字节(路径)                读取文件为字节缓冲区")
    打印("  写字节(路径, 缓冲区, 大小)  写入字节缓冲区到文件")
    打印("  写16(路径, 缓冲区, 大小)    以16位格式写入文件")
    打印("  写32(路径, 缓冲区, 大小)    以32位格式写入文件")
    打印("")
    打印("■ 缓冲区操作 (6个):")
    打印("  缓冲区(大小)                分配指定大小的字节缓冲区")
    打印("  缓冲写(缓冲区, 偏移, 字节值)   写入1字节")
    打印("  缓冲写16(缓冲区, 偏移, 值)     写入2字节(小端)")
    打印("  缓冲写32(缓冲区, 偏移, 值)     写入4字节(小端)")
    打印("  缓冲读(缓冲区, 偏移)           读取1字节")
    打印("  分配(大小)                     分配堆内存")
    打印("")
    打印("■ 内存操作 (8个):")
    打印("  内存读(地址)                读取8字节(64位)")
    打印("  内存读32(地址)              读取4字节(32位)")
    打印("  内存读16(地址)              读取2字节(16位)")
    打印("  内存读8(地址)               读取1字节(8位)")
    打印("  内存写(地址, 值)            写入8字节")
    打印("  内存写32(地址,  值, 0)          写入4字节")
    打印("  内存写16(地址,  值, 0)          写入2字节")
    打印("  内存写8(地址, 值)           写入1字节")
    打印("  内存复制(目标, 源, 长度)    内存块复制")
    打印("  内存填充(地址, 值, 长度)    内存块填充")
    打印("")
    打印("■ 系统 (10个):")
    打印("  退出(代码)                  退出程序,返回退出码")
    打印("  参数()                      获取命令行参数列表")
    打印("  加载库(库名)                加载DLL动态库 -> 库句柄")
    打印("  获取函数(库句柄, 函数名)    获取DLL函数地址")
    打印("  调用指针(函数地址,  参数..., 0, 0, 0, 0)  调用函数指针(最多3个参数)")
    打印("  调用指针4(函数地址,  a1..a4, 0 , 0, 0)  调用函数指针(4个参数)")
    打印("  调用指针5(函数地址,  a1..a5, 0 , 0 , 0, 0)  调用函数指针(5个参数)")
    打印("  时间戳()                    返回系统毫秒时间戳")
    打印("  延时(毫秒)                  线程休眠指定毫秒数")
    打印("")
    打印("■ 硬件信息 (3个):")
    打印("  处理器名()                  返回CPU品牌字符串")
    打印("  总内存()                    返回系统总物理内存(字节)")
    打印("  可用内存()                  返回系统可用物理内存(字节)")
}

函数 帮助_标准库() {
    打印("================================================================================")
    打印("                   标准库模块概览 (237模块, 5800+法)")
    打印("================================================================================")
    打印("")
    打印("■ 核心模块 (12个):")
    打印("  基础            追加/字符码/验证/映射操作")
    打印("  数据结构        列表/栈/队列/链表/二叉堆/红黑树/B树")
    打印("  排序            快速排序/归并排序/堆排序/计数排序/桶排序")
    打印("  集合运算        交集/并集/差集/子集判断")
    打印("  哈希表          开放寻址哈希表/链式哈希表")
    打印("  堆队列          最小堆/最大堆/优先队列")
    打印("  缓存            LRU缓存/TTL缓存/分层缓存")
    打印("  字符串          分割/修剪/填充/替换/大小写转换/分词")
    打印("  位运算          位操作/位域/位图/位计数")
    打印("  IO              文件读写/流操作/缓冲IO")
    打印("  JSON            解析/生成/查询/格式化")
    打印("  OOP             类/继承/多态/接口模拟")
    打印("")
    打印("■ 数学模块 (14个):")
    打印("  数学            阶乘/GCD/LCM/素数/组合/斐波那契/三角函数")
    打印("  矩阵运算        向量点积/范数/矩阵乘法/转置/行列式")
    打印("  线性代数        线性方程组/特征值/SVD/LU分解")
    打印("  稀疏运算        稀疏矩阵/压缩存储/稀疏乘法")

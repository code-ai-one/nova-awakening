// §5 URL解析 + 辅助函数

函数 URL_解析(url) {
    // 返回 [主机, 路径, 端口, 是否HTTPS]
    定义 可变 主机 = ""
    定义 可变 路径 = "/"
    定义 可变 端口 = 80
    定义 可变 https = 0

    // 跳过协议
    定义 可变 起始 = 0
    如果 (字符串前缀(url, "https://")) {
        起始 = 8
        端口 = 443
        https = 1
    } 否则 如果 (字符串前缀(url, "http://")) {
        起始 = 7
    }

    // 提取主机和路径
    定义 斜杠位置 = 查找字符_偏移(url, 47, 起始)  // '/'
    如果 (斜杠位置 > 0) {
        主机 = 子字符串(url, 起始, 斜杠位置)
        路径 = 子字符串(url, 斜杠位置, 字符串长度(url))
    } 否则 {
        主机 = 子字符串(url, 起始, 字符串长度(url))
    }

    // 检查端口
    定义 冒号位置 = 查找字符(主机, 58)  // ':'
    如果 (冒号位置 > 0) {
        定义 端口字符串 = 子字符串(主机, 冒号位置 + 1, 字符串长度(主机))
        端口 = 字符串转整数(端口字符串)
        主机 = 子字符串(主机, 0, 冒号位置)
    }

    返回 [主机, 路径, 端口, https]
}

函数 字符串前缀(文本, 前缀) {
    如果 (字符串长度(前缀) > 字符串长度(文本)) { 返回 假 }
    定义 可变 i = 0
    当 (i < 字符串长度(前缀)) {
        如果 (字符串取字节(文本, i) != 字符串取字节(前缀, i)) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 字符串查找(文本, 子串) {
    如果 (字符串长度(子串) > 字符串长度(文本)) { 返回 -1 }
    定义 可变 i = 0
    当 (i <= 字符串长度(文本) - 字符串长度(子串)) {
        定义 可变 匹配 = 真
        定义 可变 j = 0
        当 (j < 字符串长度(子串)) {
            如果 (字符串取字节(文本, i + j) != 字符串取字节(子串, j)) {
                匹配 = 假
                j = 字符串长度(子串)
            }
            j = j + 1
        }
        如果 (匹配) { 返回 i }
        i = i + 1
    }
    返回 -1
}

// 低层网络接口 —— 由内核网络栈实现, 此处声明接口约定
// 低层传控接口: 由 网络/传输层/传控.nova 提供实现
外部 传控_连接       // (主机, 端口, 超时) -> 连接句柄|空
外部 传控_发送数据    // (连接, 数据) -> 无
外部 传控_接收数据    // (连接, 超时) -> 字符串
外部 传控_关闭       // (连接) -> 无

// 导入公共数学工具(提供 数学_千分位转小数字符串)

// 从原始 HTTP 响应文本中提取第 N 行 (\r\n 分隔, 0-索引)
函数 提取行(文本, 行号) {
    定义 长 = 字符串长度(文本)
    定义 可变 当前行 = 0
    定义 可变 行开始 = 0
    定义 可变 i = 0
    当 (i < 长) {
        如果 (字符串取字节(文本, i) == 10) {  // '\n'
            如果 (当前行 == 行号) {
                // 去掉末尾的 \r
                定义 可变 行结束 = i
                如果 (行结束 > 行开始 && 字符串取字节(文本, 行结束 - 1) == 13) {
                    行结束 = 行结束 - 1
                }
                返回 字符串子串(文本, 行开始, 行结束 - 行开始)
            }
            当前行 = 当前行 + 1
            行开始 = i + 1
        }
        i = i + 1
    }
    // 最后一行(无换行符结尾)
    如果 (当前行 == 行号) {
        返回 字符串子串(文本, 行开始, 长 - 行开始)
    }
    返回 ""
}

// 从第 N 行开始提取剩余所有内容(作为HTTP正文)
函数 提取正文(文本, 行开始) {
    定义 长 = 字符串长度(文本)
    定义 可变 当前行 = 0
    定义 可变 i = 0
    当 (i < 长) {
        如果 (字符串取字节(文本, i) == 10) {
            当前行 = 当前行 + 1
            如果 (当前行 == 行开始) {
                返回 字符串子串(文本, i + 1, 长 - i - 1)
            }
        }
        i = i + 1
    }
    返回 ""
}

// 解析 "HTTP/1.1 200 OK" 中的状态码数字
函数 解析状态码(状态行) {
    // 状态码在第一个空格后、第二个空格前
    定义 长 = 字符串长度(状态行)
    定义 可变 i = 0
    // 跳过 "HTTP/x.x"
    当 (i < 长 && 字符串取字节(状态行, i) != 32) { i = i + 1 }
    // 跳过空格
    当 (i < 长 && 字符串取字节(状态行, i) == 32) { i = i + 1 }
    // 读取数字
    定义 可变 码 = 0
    当 (i < 长) {
        定义 ch = 字符串取字节(状态行, i)
        如果 (ch >= 48 && ch <= 57) {
            码 = 码 * 10 + (ch - 48)
        } 否则 {
            返回 码
        }
        i = i + 1
    }
    返回 码
}

函数 查找字符(文本, 字符码) {
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        如果 (字符串取字节(文本, i) == 字符码) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 查找字符_偏移(文本, 字符码, 起始) {
    定义 可变 i = 起始
    当 (i < 字符串长度(文本)) {
        如果 (字符串取字节(文本, i) == 字符码) { 返回 i }
        i = i + 1
    }
    返回 -1
}

// 字符串子串: 委托给已有的 字符串工具.nova::字符串子串
函数 字符串子串_http(文本, 起始, 长度) {
    返回 字符串子串(文本, 起始, 长度)
}

定义 可变 AI_地址解析辅_操作热度 = 0

函数 AI_地址解析辅_最优算法(数据量, 已排序) {
    AI_地址解析辅_操作热度 = AI_地址解析辅_操作热度 + 1
    如果 (数据量 < 16) { 返回 "插入排序" }
    如果 (已排序) { 返回 "二分查找" }
    如果 (数据量 < 10000) { 返回 "快速排序" }
    返回 "归并排序"
}

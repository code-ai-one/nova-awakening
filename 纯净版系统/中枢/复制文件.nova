函数 copy_files(标志, 子进程, 父进程) {
    定义 父表 = 父进程[T_文件表]
    如果 (父表 == 空) { 返回 成功 }

    如果 ((标志 & CLONE_FILES) != 0) {
        // 共享: 引用计数+1
        父表.引用数 = 父表.引用数 + 1
        设置(子进程, T_文件表, 父表)
        返回 成功
    }

    // 独立复制
    定义 可变 新表 = 文件表 {}
    新表.引用数 = 1
    新表.最大fd = 父表.最大fd
    新表.下个fd = 0
    新表.锁 = 自旋锁_创建()
    新表.close_on_exec = 父表.close_on_exec

    // 逐个复制文件描述符(增加file的引用计数)
    定义 可变 新fd表 = []
    自旋锁_获取(父表.锁)
    定义 可变 i = 0
    当 (i < 计数(父表.表)) {
        定义 文件 = 父表.表[i]
        如果 (文件 != 0) {
            // 增加file结构的引用计数 
            文件引用_增加(文件)
        }
        追加(新fd表, 文件)
        i = i + 1
    }
    自旋锁_释放(父表.锁)
    新表.表 = 新fd表

    设置(子进程, T_文件表, 新表)
    返回 成功
}

// copy_fs: 复制/共享文件系统上下文

函数 copy_fs(标志, 子进程, 父进程) {
    定义 父fs = 父进程[T_文件系统]
    如果 (父fs == 空) { 返回 成功 }

    如果 ((标志 & CLONE_FS) != 0) {
        父fs.引用数 = 父fs.引用数 + 1
        设置(子进程, T_文件系统, 父fs)
        返回 成功
    }

    定义 可变 新fs = 文件系统信息 {}
    新fs.根目录 = 父fs.根目录
    新fs.当前目录 = 父fs.当前目录
    新fs.umask = 父fs.umask
    新fs.引用数 = 1
    设置(子进程, T_文件系统, 新fs)
    返回 成功
}

// copy_sighand: 复制/共享信号处理器表

函数 copy_sighand(标志, 子进程, 父进程) {
    定义 父sh = 父进程[T_信号处理表]
    如果 (父sh == 空) { 返回 成功 }

    如果 ((标志 & CLONE_SIGHAND) != 0) {
        父sh.引用数 = 父sh.引用数 + 1
        设置(子进程, T_信号处理表, 父sh)
        返回 成功
    }

    定义 可变 新sh = 信号处理表 {}
    新sh.引用数 = 1
    新sh.锁 = 自旋锁_创建()
    // 复制64个信号处理器
    定义 可变 i = 0
    当 (i < 64) {
        新sh.处理器[i] = 父sh.处理器[i]
        i = i + 1
    }
    设置(子进程, T_信号处理表, 新sh)
    返回 成功
}

// copy_thread: 设置子进程内核栈使其"返回"到正确位置
// 关键: fork返回后子进程从ret_from_fork开始执行

函数 copy_thread(子进程, 父进程, 标志) {
    定义 栈顶 = 进程_内核栈顶(子进程)

    // 在子进程内核栈顶构造pt_regs (中断返回帧)
    // 子进程的RAX=0 (fork返回值在子进程中为0)
    定义 帧地址 = 栈顶 - PT_REGS大小
    内存复制(帧地址, 父进程[T_中断帧], PT_REGS大小)  // 从父进程复制寄存器
    设置寄存器(帧地址, REG_RAX, 0)   // 子进程fork()返回0

    // 设置子进程的thread_struct
    // RSP指向pt_regs, RIP指向ret_from_fork
    设置(子进程, T_线程_RSP, 帧地址)
    设置(子进程, T_线程_RIP, ret_from_fork地址())

    // 如果设置安全 (CLONE_SET安全)
    如果 ((标志 & CLONE_SET安全) != 0) {
        // 设置FS base (x86-64 安全)
        设置(子进程, T_安全基址, 父进程[T_安全基址])
    }

    返回 成功
}

// copy_process: 核心进程创建 — 分步复制,失败回滚
// 这是Linux最核心的函数之一 

函数 copy_process(父进程, 标志, 名称, 子TID指针) {
    定义 可变 结果 = 成功

    // 1. 验证标志
    结果 = 验证clone标志(标志)
    如果 (是错误(结果)) { 返回 结果 }

    // 2. 分配PID
    定义 新PID = 分配PID()
    如果 (新PID < 0) { 返回 错误_无内存 }

    // 3. 分配并复制task_struct 
    定义 子进程 = dup_task_struct(父进程)
    如果 (子进程 == 空) {
        释放PID(新PID)
        返回 错误_无内存
    }
    设置(子进程, T_PID, 新PID)
    如果 (名称 != 空) { 设置(子进程, T_名称, 名称) }

    // 4. copy_files — 复制/共享文件描述符
    结果 = copy_files(标志, 子进程, 父进程)
    如果 (是错误(结果)) { 跳到 失败_释放任务 }

    // 5. copy_fs — 复制/共享文件系统上下文
    结果 = copy_fs(标志, 子进程, 父进程)
    如果 (是错误(结果)) { 跳到 失败_释放文件 }

    // 6. copy_sighand — 复制/共享信号处理
    结果 = copy_sighand(标志, 子进程, 父进程)
    如果 (是错误(结果)) { 跳到 失败_释放fs }

    // 7. copy_mm — 复制/共享地址空间 (最重的操作)
    结果 = copy_mm(标志, 子进程, 父进程)
    如果 (是错误(结果)) { 跳到 失败_释放信号 }

    // 8. copy_thread — 设置内核栈和返回点
    结果 = copy_thread(子进程, 父进程, 标志)
    如果 (是错误(结果)) { 跳到 失败_释放mm }

    // 9. 设置父子关系
    如果 ((标志 & CLONE_PARENT) != 0) {
        设置(子进程, T_父进程, 父进程[T_父进程])
    } 否则 {
        设置(子进程, T_父进程, 父进程)
    }
    如果 ((标志 & CLONE_THREAD) != 0) {
        设置(子进程, T_TGID, 父进程[T_TGID])
        设置(子进程, T_PGID, 父进程[T_PGID])
        设置(子进程, T_SID, 父进程[T_SID])
    } 否则 {
        设置(子进程, T_TGID, 新PID)
        设置(子进程, T_PGID, 父进程[T_PGID])
        设置(子进程, T_SID, 父进程[T_SID])
        追加(父进程[T_子进程列表], 子进程)
    }

    // 10. 继承调度参数
    进程_设nice(子进程, 父进程[T_nice值])
    进程_设调度策略(子进程, 父进程[T_调度策略])
    设置(子进程, T_CPU亲和, 父进程[T_CPU亲和])
    Nova公平调度_设置新进程虚拟运行时间(子进程)

    // 11. 继承凭证
    设置(子进程, T_UID, 父进程[T_UID])
    设置(子进程, T_GID, 父进程[T_GID])
    设置(子进程, T_EUID, 父进程[T_EUID])
    设置(子进程, T_EGID, 父进程[T_EGID])

    // 12. 注册到进程表
    进程表_注册(子进程)
    进程_设置状态(子进程, 进程_就绪)

    总fork次数 = 总fork次数 + 1
    内核调试(字符串拼接("copy_process: PID ", 整数转字符串(新PID)))
    返回 新PID
}

定义 可变 AI_复制文件_热文件表 = []

函数 AI_复制文件_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_复制文件_热文件表)) {
        如果 (AI_复制文件_热文件表[i].路径 == 路径) {
            AI_复制文件_热文件表[i].频率 = AI_复制文件_热文件表[i].频率 + 1
            返回 AI_复制文件_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_复制文件_热文件表) < 128) {
        追加(AI_复制文件_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_复制文件_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

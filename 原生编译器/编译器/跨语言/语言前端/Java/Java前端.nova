// Nova · 跨语言语言前端 · Java
// 职责: 解析Java源文件骨架,提取class/interface/method/package信息
// 层级: 跨语言主线第4步 — 语言骨架解析(Java)
// 注意: 反射/AOP/字节码增强为高风险,归入阻塞项

导入("../../../../标准库/基础.nova")
导入("../../统一语义/统一语义图.nova")

定义 Java声明_类      = 0
定义 Java声明_接口    = 1
定义 Java声明_方法    = 2
定义 Java声明_枚举    = 3
定义 Java声明_注解    = 4
定义 Java声明_包      = 5
定义 Java声明_导入    = 6

函数 Java声明_创建(类型, 名称, 修饰符) {
    返回 [类型, 名称, 修饰符, 0]
}

函数 Java模块_创建(路径) {
    返回 [路径, "", [], [], [], []]
}

函数 Java模块_包名(m) { 返回 m[1] }
函数 Java模块_声明(m) { 返回 m[2] }
函数 Java模块_导入(m) { 返回 m[3] }
函数 Java模块_注解(m) { 返回 m[4] }
函数 Java模块_风险(m) { 返回 m[5] }

函数 Java前端_解析骨架(源码, 文件路径) {
    定义 模块 = Java模块_创建(文件路径)
    定义 可变 位置 = 0
    定义 总长 = 字节长度(源码)
    定义 可变 行号 = 1

    当 (位置 < 总长) {
        当 (行尾 < 总长 且 字节取(源码, 行尾) != 字符_换行) { 行尾 = 行尾 + 1 }
        定义 行 = 子串(源码, 位置, 行尾 - 位置)
        位置 = 行尾 + 1
        定义 已裁剪 = _Java_去首空白(行)

        如果 (_Java_行开头(已裁剪, "package ")) {
            模块[1] = _Java_提取词(已裁剪, 8)
        }
        如果 (_Java_行开头(已裁剪, "import ")) {
            追加(模块[3], 已裁剪)
        }
        如果 (_Java_含(已裁剪, "class ")) {
            定义 名 = _Java_提取类名(已裁剪, "class ")
            定义 修饰 = _Java_提取修饰符(已裁剪)
            追加(模块[2], Java声明_创建(Java声明_类, 名, 修饰))
        }
        如果 (_Java_含(已裁剪, "interface ")) {
            定义 名 = _Java_提取类名(已裁剪, "interface ")
            追加(模块[2], Java声明_创建(Java声明_接口, 名, ""))
        }
        如果 (_Java_含(已裁剪, "enum ")) {
            定义 名 = _Java_提取类名(已裁剪, "enum ")
            追加(模块[2], Java声明_创建(Java声明_枚举, 名, ""))
        }
        如果 (_Java_行开头(已裁剪, "@")) {
            追加(模块[4], [行号, 已裁剪])
        }
        // 高风险: 反射/动态代理
        如果 (_Java_含(已裁剪, "Class.forName") 或 _Java_含(已裁剪, "getMethod") 或 _Java_含(已裁剪, "Proxy.newProxyInstance") 或 _Java_含(已裁剪, "ClassLoader")) {
            追加(模块[5], [行号, 已裁剪])
        }

        行号 = 行号 + 1
    }
    返回 模块
}

函数 Java前端_到语义图(模块, 语义图) {
    定义 可变 i = 0
    当 (i < 计数(模块[2])) {
        定义 d = 模块[2][i]
        定义 节点 = 语义节点_创建(0, d[0], d[1])
        语义节点_设源位置(节点, 模块[0])
        语义图_添加节点(语义图, 节点)
        i = i + 1
    }
    i = 0
    当 (i < 计数(模块[5])) {
        语义图_标记风险(语义图, 字符串拼接("Java反射高风险: 行", 转字符串(模块[5][i][0])), 2)
        i = i + 1
    }
}

函数 Java模块_打印(模块) {
    打印文本(字符串拼接("═══ Java模块: ", 字符串拼接(模块[0], 字符串拼接(" (", 字符串拼接(模块[1], ")")))))
    打印文本(字符串拼接("  声明数: ", 转字符串(计数(模块[2]))))
    打印文本(字符串拼接("  导入数: ", 转字符串(计数(模块[3]))))
    打印文本(字符串拼接("  注解数: ", 转字符串(计数(模块[4]))))
    打印文本(字符串拼接("  高风险项: ", 转字符串(计数(模块[5]))))
}

函数 _Java_去首空白(s) {
    定义 可变 i = 0
    定义 l = 字节长度(s)
    当 (i < l 且 (字节取(s, i) == 字符_空格 或 字节取(s, i) == 字符_制表)) { i = i + 1 }
    如果 (i >= l) { 返回 "" }
    返回 子串(s, i, l - i)
}

函数 _Java_行开头(行, 前缀) {
    定义 pl = 字节长度(前缀)
    如果 (字节长度(行) < pl) { 返回 假 }
    返回 子串(行, 0, pl) == 前缀
}

函数 _Java_含(s, 子串) {
    定义 sl = 字节长度(s)
    定义 pl = 字节长度(子串)
    如果 (pl > sl) { 返回 假 }
    定义 可变 i = 0
    当 (i <= sl - pl) {
        如果 (子串(s, i, pl) == 子串) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 _Java_提取词(行, 起始) {
    定义 可变 位置 = 起始
    定义 l = 字节长度(行)
    定义 起 = 位置
    当 (位置 < l 且 字节取(行, 位置) != 字符_分号 且 字节取(行, 位置) != 字符_空格) { 位置 = 位置 + 1 }
    如果 (位置 > 起) { 返回 子串(行, 起, 位置 - 起) }
    返回 ""
}

函数 _Java_提取类名(行, 关键字) {
    定义 kl = 字节长度(关键字)
    定义 l = 字节长度(行)
    定义 可变 位置 = 0
    当 (位置 < l - kl) {
        如果 (子串(行, 位置, kl) == 关键字) {
            位置 = 位置 + kl
            定义 起 = 位置
            当 (位置 < l 且 字节取(行, 位置) != 字符_空格 且 字节取(行, 位置) != 字符_左花括 且 字节取(行, 位置) != 字符_小于号) { 位置 = 位置 + 1 }
            返回 子串(行, 起, 位置 - 起)
        }
        位置 = 位置 + 1
    }
    返回 "unknown"
}

函数 _Java_提取修饰符(行) {
    如果 (_Java_行开头(行, "public ")) { 返回 "public" }
    如果 (_Java_行开头(行, "private ")) { 返回 "private" }
    如果 (_Java_行开头(行, "protected ")) { 返回 "protected" }
    返回 ""
}

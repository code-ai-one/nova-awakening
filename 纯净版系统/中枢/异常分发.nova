// NovaOS 异常分发系统
// 功能: CPU异常完整分发、寄存器转储、栈回溯、异常上下文快照、
//       用户态/内核态分离处理、AI异常模式学习、崩溃自诊断
// 理论: 基于自研「异常指纹」模型 — 将每次异常的向量号+RIP+错误码+
//       CR2+调用栈哈希组成64位指纹,用滑动窗口检测重复异常模式,
//       当同一指纹在窗口期内出现超过阈值时触发AI分析判定根因

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./同步原语.nova")
导入("../推理/智能渠道.nova")
导入("./内核打印.nova")
导入("./模块级热替换.nova")
导入("./信号设置用.nova")
导入("./恐慌.nova")
导入("../推理/值乘.nova")
导入("../引导/特权指令.nova")
导入("../引导/模型寄存.nova")
导入("./缺页类型名.nova")
导入("../感知/内核直连层.nova")

// §1 异常向量号常量 (x86-64 IDT向量0~31)

定义 异常_除零             = 0   // #DE
定义 异常_调试             = 1   // #DB
定义 异常_NMI              = 2   // NMI
定义 异常_断点             = 3   // #BP (INT3)
定义 异常_溢出             = 4   // #OF
定义 异常_越界             = 5   // #BR
定义 异常_无效操作码       = 6   // #UD
定义 异常_无FPU            = 7   // #NM
定义 异常_双重故障         = 8   // #DF (带错误码=0)
定义 异常_协处理段越界     = 9   // 已废弃
定义 异常_无效TSS          = 10  // #TS
定义 异常_段不存在         = 11  // #NP
定义 异常_栈段错误         = 12  // #SS
定义 异常_一般保护         = 13  // #GP
定义 异常_缺页             = 14  // #PF
定义 异常_保留15           = 15
定义 异常_浮点             = 16  // #MF
定义 异常_对齐检查         = 17  // #AC
定义 异常_机器检查         = 18  // #MC
定义 异常_SIMD浮点         = 19  // #XM/#XF
定义 异常_虚拟化           = 20  // #VE
定义 异常_控制保护         = 21  // #CP
定义 异常_最大             = 32

// 哪些异常会推送错误码
定义 有错误码掩码 = (1 << 8) | (1 << 10) | (1 << 11) | (1 << 12) |
                    (1 << 13) | (1 << 14) | (1 << 17) | (1 << 21)

// §2 中断帧与寄存器快照结构

结构 中断帧 {
    // 通用寄存器 (由异常入口存根保存)
    r15, r14, r13, r12, r11, r10, r9, r8,
    rbp, rdi, rsi, rdx, rcx, rbx, rax,
    // CPU自动推送
    rip,                  // 故障指令地址
    cs,                   // 代码段选择子
    rflags,               // 标志寄存器
    rsp,                  // 栈指针(仅跨特权级时有效)
    ss,                   // 栈段选择子
}

结构 异常上下文 {
    帧,                   // 中断帧
    向量号,
    错误码,
    cr2,                  // u64: 缺页地址
    cr3,                  // u64: 页表基址
    是用户态,
    当前进程ID,
    当前线程ID,
    时间戳,               // u64: 纳秒
    指纹,                 // u64: 异常指纹哈希
}

// §3 异常统计与历史记录

结构 异常统计 {
    各类计数,             // 数组[32]: 每种异常的发生次数
    总次数,
    内核态次数,
    用户态次数,
    致命次数,
    最后异常向量,
    最后异常RIP,
    最后异常时间,
}

定义 异常历史_容量 = 64

结构 异常历史环 {
    记录,                 // 数组[64]: 异常上下文
    写索引,
    已满,
    锁,                  // 自旋锁
}

定义 可变 异常统计信息 = 异常统计 {}
定义 可变 异常历史 = 异常历史环 {}

// 异常名称表
定义 异常名称 = [
    "#DE 除零", "#DB 调试", "NMI", "#BP 断点",
    "#OF 溢出", "#BR 越界", "#UD 无效操作码", "#NM 无FPU",
    "#DF 双重故障", "已废弃", "#TS 无效TSS", "#NP 段不存在",
    "#SS 栈段错", "#GP 一般保护", "#PF 缺页", "保留",
    "#MF 浮点", "#AC 对齐检查", "#MC 机器检查", "#XM SIMD浮点",
    "#VE 虚拟化", "#CP 控制保护", "保留", "保留",
    "保留", "保留", "保留", "保留",
    "保留", "保留", "保留", "保留"
]

// §4 核心分发函数: 异常分发主入口

函数 异常分发(向量号, 错误码, 帧指针) {
    定义 是用户态 = (帧指针.cs & 3) != 0

    // 更新统计
    异常统计信息.各类计数[向量号] = 异常统计信息.各类计数[向量号] + 1
    异常统计信息.总次数 = 异常统计信息.总次数 + 1
    如果 (是用户态) {
        异常统计信息.用户态次数 = 异常统计信息.用户态次数 + 1
    } 否则 {
        异常统计信息.内核态次数 = 异常统计信息.内核态次数 + 1
    }
    异常统计信息.最后异常向量 = 向量号
    异常统计信息.最后异常RIP = 帧指针.rip
    异常统计信息.最后异常时间 = 读取纳秒时钟()

    // 构建异常上下文
    定义 可变 上下文 = 异常上下文 {}
    上下文.帧 = 帧指针
    上下文.向量号 = 向量号
    上下文.错误码 = 错误码
    上下文.cr2 = 读取CR2()
    上下文.cr3 = 读取CR3()
    上下文.是用户态 = 是用户态
    上下文.当前进程ID = 当前进程_获取ID()
    上下文.当前线程ID = 当前线程_获取ID()
    上下文.时间戳 = 异常统计信息.最后异常时间
    上下文.指纹 = 异常指纹_计算(向量号, 帧指针.rip, 错误码, 上下文.cr2)

    // 记录到历史环
    异常历史_记录(上下文)

    // AI异常模式检测
    AI异常_检查重复模式(上下文.指纹, 向量号, 上下文.时间戳)

    如果 (向量号 == 异常_除零)         { 处理_除零(上下文) 返回 }
    如果 (向量号 == 异常_调试)         { 处理_调试(上下文) 返回 }
    如果 (向量号 == 异常_NMI)          { 处理_NMI(上下文) 返回 }
    如果 (向量号 == 异常_断点)         { 处理_断点(上下文) 返回 }
    如果 (向量号 == 异常_溢出)         { 处理_溢出(上下文) 返回 }
    如果 (向量号 == 异常_越界)         { 处理_越界(上下文) 返回 }
    如果 (向量号 == 异常_无效操作码)   { 处理_无效操作码(上下文) 返回 }
    如果 (向量号 == 异常_无FPU)        { 处理_无FPU(上下文) 返回 }
    如果 (向量号 == 异常_双重故障)     { 处理_双重故障(上下文) 返回 }
    如果 (向量号 == 异常_无效TSS)      { 处理_无效TSS(上下文) 返回 }
    如果 (向量号 == 异常_段不存在)     { 处理_段不存在(上下文) 返回 }
    如果 (向量号 == 异常_栈段错误)     { 处理_栈段错误(上下文) 返回 }
    如果 (向量号 == 异常_一般保护)     { 处理_一般保护(上下文) 返回 }
    如果 (向量号 == 异常_缺页)         { 处理_缺页(上下文) 返回 }
    如果 (向量号 == 异常_浮点)         { 处理_浮点(上下文) 返回 }
    如果 (向量号 == 异常_对齐检查)     { 处理_对齐检查(上下文) 返回 }
    如果 (向量号 == 异常_机器检查)     { 处理_机器检查(上下文) 返回 }
    如果 (向量号 == 异常_SIMD浮点)     { 处理_SIMD浮点(上下文) 返回 }
    如果 (向量号 == 异常_虚拟化)       { 处理_虚拟化(上下文) 返回 }
    如果 (向量号 == 异常_控制保护)     { 处理_控制保护(上下文) 返回 }

    // 未知异常
    内核打印(日志_错误, "未处理异常: 向量#%d at RIP=%p\n", 向量号, 帧指针.rip)
    异常_转储寄存器(上下文)
    如果 (是用户态) {
        异常_发送信号给进程(上下文, 信号_SEGV)
    } 否则 {
        内核恐慌("未处理CPU异常")
    }
}

// §5 各异常的完整处理器

函数 处理_除零(上下文) {
    // #DE: 除零或除法溢出
    内核打印(日志_警告, "#DE 除零异常 at RIP=%p PID=%d\n",
             上下文.帧.rip, 上下文.当前进程ID)
    如果 (上下文.是用户态) {
        异常_发送信号给进程(上下文, 信号_FPE)
    } 否则 {
        异常_转储寄存器(上下文)
        异常_栈回溯(上下文)
        内核恐慌("内核态除零异常")
    }
}

函数 处理_调试(上下文) {
    // #DB: 硬件断点/单步
    定义 dr6 = 读取DR6()
    如果 (上下文.是用户态) {
        // 通知调试器
        如果 (当前进程_有调试器()) {
            调试器_通知(上下文, dr6)
        } 否则 {
            异常_发送信号给进程(上下文, 信号_TRAP)
        }
    } 否则 {
        // 内核调试断点: kprobe/kgdb
        如果 (kprobe_处理(上下文.帧.rip, 上下文) == 假) {
            内核打印(日志_调试, "#DB 内核调试 at %p DR6=%p\n",
                     上下文.帧.rip, dr6)
        }
    }
    // 清除DR6状态位
    写入DR6(0)
}

函数 处理_NMI(上下文) {
    // NMI: 不可屏蔽中断 — 硬件故障/看门狗/性能计数
    定义 原因 = 端口_读8(0x61)  // 系统控制端口B

    如果 (原因 & 0x80) {
        // 内存奇偶校验错误
        内核打印(日志_紧急, "NMI: 内存奇偶校验错误!\n")
        异常统计信息.致命次数 = 异常统计信息.致命次数 + 1
    }
    如果 (原因 & 0x40) {
        // IO通道检查
        内核打印(日志_紧急, "NMI: IO通道检查错误!\n")
    }

    // 检查是否为性能计数器NMI (perf)
    如果 (性能计数_是NMI()) {
        性能计数_NMI处理(上下文)
        返回
    }

    // 看门狗NMI
    如果 (看门狗_是NMI()) {
        看门狗_NMI处理(上下文)
        返回
    }

    内核打印(日志_警告, "NMI: 未知来源, 端口B=%02x\n", 原因)
}

函数 处理_断点(上下文) {
    // #BP: INT3 软件断点
    如果 (上下文.是用户态) {
        如果 (当前进程_有调试器()) {
            调试器_通知(上下文, 0)
        } 否则 {
            异常_发送信号给进程(上下文, 信号_TRAP)
        }
    } 否则 {
        // 内核断点: 检查kprobe
        如果 (kprobe_处理(上下文.帧.rip - 1, 上下文) == 假) {
            内核打印(日志_调试, "内核断点 at %p\n", 上下文.帧.rip - 1)
        }
    }
}

函数 处理_溢出(上下文) {
    // #OF: INTO指令触发(仅32位兼容模式)
    如果 (上下文.是用户态) {
        异常_发送信号给进程(上下文, 信号_FPE)
    } 否则 {
        异常_转储寄存器(上下文)
        内核恐慌("内核态溢出异常")
    }
}

函数 处理_越界(上下文) {
    // #BR: BOUND指令触发
    如果 (上下文.是用户态) {
        异常_发送信号给进程(上下文, 信号_SEGV)
    } 否则 {
        异常_转储寄存器(上下文)
        内核恐慌("内核态越界异常")
    }
}

函数 处理_无效操作码(上下文) {
    // #UD: 无效/未定义指令
    内核打印(日志_警告, "#UD 无效操作码 at RIP=%p\n", 上下文.帧.rip)

    // 尝试读取故障指令的前几个字节用于诊断
    如果 (上下文.是用户态) {
        定义 可变 指令字节 = 数组<u8, 8>
        如果 (安全复制_从用户(指令字节, 上下文.帧.rip, 8) == 0) {
            内核打印(日志_调试, "  指令: %02x %02x %02x %02x\n",
                     指令字节[0], 指令字节[1], 指令字节[2], 指令字节[3])
        }
        异常_发送信号给进程(上下文, 信号_ILL)
    } 否则 {
        // 检查是否为BUG()宏触发的UD2
        定义 指令 = 内存_读16(上下文.帧.rip)
        如果 (指令 == 0x0B0F) {
            // UD2 = 内核BUG()宏
            内核打印(日志_紧急, "内核BUG at %p\n", 上下文.帧.rip)
        }
        异常_转储寄存器(上下文)
        异常_栈回溯(上下文)
        内核恐慌("内核态无效操作码")
    }
}

函数 处理_无FPU(上下文) {
    // #NM: FPU/SSE/AVX不可用 — 延迟FPU上下文切换
    如果 (上下文.是用户态) {
        // 恢复FPU上下文给当前线程
        FPU_延迟恢复(当前线程_获取ID())
    } 否则 {
        // 内核不应使用FPU(除非kernel_fpu_begin)
        内核打印(日志_错误, "内核态FPU异常 at %p\n", 上下文.帧.rip)
        内核恐慌("内核态使用FPU但未调用kernel_fpu_begin")
    }
}

函数 处理_双重故障(上下文) {
    // #DF: 双重故障 — 总是致命的
    异常统计信息.致命次数 = 异常统计信息.致命次数 + 1
    内核打印(日志_紧急, "═══ 双重故障 ═══\n")
    异常_转储寄存器(上下文)
    异常_栈回溯(上下文)
    内核恐慌("双重故障: 系统不可恢复")
}

函数 处理_无效TSS(上下文) {
    内核打印(日志_错误, "#TS 无效TSS 错误码=%p\n", 上下文.错误码)
    异常_解析段错误码(上下文.错误码)
    异常_转储寄存器(上下文)
    内核恐慌("无效TSS")
}

函数 处理_段不存在(上下文) {
    内核打印(日志_错误, "#NP 段不存在 错误码=%p\n", 上下文.错误码)
    异常_解析段错误码(上下文.错误码)
    如果 (上下文.是用户态) {
        异常_发送信号给进程(上下文, 信号_SEGV)
    } 否则 {
        异常_转储寄存器(上下文)
        内核恐慌("内核态段不存在")
    }
}

函数 处理_栈段错误(上下文) {
    内核打印(日志_错误, "#SS 栈段错误 错误码=%p\n", 上下文.错误码)
    如果 (上下文.是用户态) {
        异常_发送信号给进程(上下文, 信号_SEGV)
    } 否则 {
        异常_转储寄存器(上下文)
        内核恐慌("内核态栈段错误")
    }
}

函数 处理_一般保护(上下文) {
    // #GP: 最常见的保护违规
    内核打印(日志_错误, "#GP 一般保护 at RIP=%p 错误码=%p\n",
             上下文.帧.rip, 上下文.错误码)

    如果 (上下文.错误码 != 0) {
        异常_解析段错误码(上下文.错误码)
    }

    如果 (上下文.是用户态) {
        异常_发送信号给进程(上下文, 信号_SEGV)
    } 否则 {
        // 检查异常修复表
        定义 修复地址 = 异常修复表_查找(上下文.帧.rip)
        如果 (修复地址 != 0) {
            上下文.帧.rip = 修复地址
            返回  // 跳转到修复代码继续执行
        }
        异常_转储寄存器(上下文)
        异常_栈回溯(上下文)
        内核恐慌("内核态一般保护异常")
    }
}

函数 处理_缺页(上下文) {
    // #PF: 由缺页处理子系统处理(已有独立模块)
    缺页_处理(上下文.帧, 上下文.错误码, 上下文.cr2)
}

函数 处理_浮点(上下文) {
    如果 (上下文.是用户态) {
        异常_发送信号给进程(上下文, 信号_FPE)
    } 否则 {
        异常_转储寄存器(上下文)
        内核恐慌("内核态浮点异常")
    }
}

函数 处理_对齐检查(上下文) {
    // #AC: 仅在用户态CPL=3且EFLAGS.AC=1时触发
    如果 (上下文.是用户态) {
        异常_发送信号给进程(上下文, 信号_BUS)
    } 否则 {
        // 内核不应触发#AC
        异常_转储寄存器(上下文)
        内核恐慌("内核态对齐检查异常")
    }
}

函数 处理_机器检查(上下文) {
    // #MC: 硬件检测到不可纠正的错误
    异常统计信息.致命次数 = 异常统计信息.致命次数 + 1
    内核打印(日志_紧急, "═══ 机器检查异常 ═══\n")
    // 读取MCi_STATUS MSR获取详细信息
    定义 msr_status = 读取MSR(0x401)  // IA32_MC0_STATUS
    内核打印(日志_紧急, "MC0_STATUS = %p\n", msr_status)
    异常_转储寄存器(上下文)
    内核恐慌("机器检查: 硬件错误不可纠正")
}

函数 处理_SIMD浮点(上下文) {
    定义 mxcsr = 读取MXCSR()
    内核打印(日志_警告, "#XM SIMD浮点 MXCSR=%08x at %p\n", mxcsr, 上下文.帧.rip)
    如果 (上下文.是用户态) {
        异常_发送信号给进程(上下文, 信号_FPE)
    } 否则 {
        异常_转储寄存器(上下文)
        内核恐慌("内核态SIMD浮点异常")
    }
}

函数 处理_虚拟化(上下文) {
    内核打印(日志_错误, "#VE 虚拟化异常 at %p\n", 上下文.帧.rip)
    异常_转储寄存器(上下文)
    内核恐慌("虚拟化异常")
}

函数 处理_控制保护(上下文) {
    // #CP: CET影子栈/间接分支跟踪违规
    内核打印(日志_错误, "#CP 控制流保护违规 at %p 错误码=%p\n",
             上下文.帧.rip, 上下文.错误码)
    如果 (上下文.是用户态) {
        异常_发送信号给进程(上下文, 信号_SEGV)
    } 否则 {
        异常_转储寄存器(上下文)
        内核恐慌("内核控制流保护违规")
    }
}

// §6 寄存器转储: 完整的寄存器状态打印

函数 异常_转储寄存器(上下文) {
    定义 f = 上下文.帧
    内核打印(日志_错误, "── 寄存器转储 ──\n")
    内核打印(日志_错误, "RIP: %016p  CS: %04p  RFLAGS: %016p\n", f.rip, f.cs, f.rflags)
    内核打印(日志_错误, "RAX: %016p  RBX: %016p  RCX: %016p\n", f.rax, f.rbx, f.rcx)
    内核打印(日志_错误, "RDX: %016p  RSI: %016p  RDI: %016p\n", f.rdx, f.rsi, f.rdi)
    内核打印(日志_错误, "RBP: %016p  RSP: %016p  R8:  %016p\n", f.rbp, f.rsp, f.r8)
    内核打印(日志_错误, "R9:  %016p  R10: %016p  R11: %016p\n", f.r9, f.r10, f.r11)
    内核打印(日志_错误, "R12: %016p  R13: %016p  R14: %016p\n", f.r12, f.r13, f.r14)
    内核打印(日志_错误, "R15: %016p\n", f.r15)
    内核打印(日志_错误, "CR2: %016p  CR3: %016p\n", 上下文.cr2, 上下文.cr3)
    内核打印(日志_错误, "异常: %s (#%d) 错误码: %p\n",
             异常名称[上下文.向量号], 上下文.向量号, 上下文.错误码)
    内核打印(日志_错误, "进程: PID=%d TID=%d\n", 上下文.当前进程ID, 上下文.当前线程ID)
}

// §7 栈回溯: 基于帧指针链的调用栈打印

函数 异常_栈回溯(上下文) {
    内核打印(日志_错误, "── 调用栈 ──\n")
    定义 可变 rbp = 上下文.帧.rbp
    定义 可变 深度 = 0
    定义 最大深度 = 32

    // 先打印当前RIP
    定义 符号名 = 符号表_查找(上下文.帧.rip)
    如果 (符号名 != 空) {
        内核打印(日志_错误, "  [%d] %p <%s>\n", 深度, 上下文.帧.rip, 符号名)
    } 否则 {
        内核打印(日志_错误, "  [%d] %p\n", 深度, 上下文.帧.rip)
    }
    深度 = 1

    // 沿帧指针链回溯
    当 (rbp != 0 && 深度 < 最大深度) {
        // 验证rbp指向的地址是否可读
        如果 (栈回溯_地址有效(rbp) == 假) {
            内核打印(日志_错误, "  [%d] <栈损坏 rbp=%p>\n", 深度, rbp)
            跳出
        }

        定义 返回地址 = 内存_读64(rbp + 8)
        如果 (返回地址 == 0) { 跳出 }

        符号名 = 符号表_查找(返回地址)
        如果 (符号名 != 空) {
            内核打印(日志_错误, "  [%d] %p <%s>\n", 深度, 返回地址, 符号名)
        } 否则 {
            内核打印(日志_错误, "  [%d] %p\n", 深度, 返回地址)
        }

        rbp = 内存_读64(rbp)  // 前一帧的rbp
        深度 = 深度 + 1
    }

    如果 (深度 >= 最大深度) {
        内核打印(日志_错误, "  ... 栈回溯截断(最大%d层)\n", 最大深度)
    }
}

函数 栈回溯_地址有效(地址) {
    // 检查地址是否在内核栈范围内
    如果 (地址 < 0xFFFF800000000000) { 返回 假 }  // 非内核地址
    如果 (地址 % 8 != 0) { 返回 假 }              // 未对齐
    返回 真
}

// §8 辅助: 段错误码解析、信号发送、异常修复表

函数 异常_解析段错误码(错误码) {
    // 段相关异常的错误码格式: [15:3]=选择子索引 [2]=TI [1]=IDT [0]=外部
    定义 索引 = (错误码 >> 3) & 0x1FFF
    定义 表类型 = "GDT"
    如果 (错误码 & 0x04) { 表类型 = "LDT" }
    如果 (错误码 & 0x02) { 表类型 = "IDT" }
    定义 外部 = (错误码 & 0x01) != 0
    内核打印(日志_错误, "  段错误: %s 索引=%d 外部=%d\n", 表类型, 索引, 外部)
}

函数 异常_发送信号给进程(上下文, 信号) {
    // 向当前进程发送信号
    定义 pid = 上下文.当前进程ID
    内核打印(日志_调试, "发送信号%d给进程%d (异常#%d at %p)\n",
             信号, pid, 上下文.向量号, 上下文.帧.rip)
    信号_发送(pid, 信号)
}

函数 异常修复表_查找(rip) {
    // 在异常修复表(__ex_table)中查找修复地址
    // 修复表条目: { 故障地址, 修复地址 }
    定义 可变 i = 0
    当 (i < 异常修复表_大小) {
        如果 (异常修复表[i].故障地址 == rip) {
            返回 异常修复表[i].修复地址
        }
        i = i + 1
    }
    返回 0
}

// §9 异常历史记录: 环形缓冲区

函数 异常历史_初始化() {
    异常历史.写索引 = 0
    异常历史.已满 = 假
    自旋锁_初始化(异常历史.锁)
}

函数 异常历史_记录(上下文) {
    自旋锁_加锁(异常历史.锁)
    异常历史.记录[异常历史.写索引 % 异常历史_容量] = 上下文
    异常历史.写索引 = 异常历史.写索引 + 1
    如果 (异常历史.写索引 >= 异常历史_容量) {
        异常历史.已满 = 真
    }
    自旋锁_解锁(异常历史.锁)
}

函数 异常历史_最近指纹时间(指纹, 参考时间) {
    自旋锁_加锁(异常历史.锁)
    定义 可变 可见数 = 异常历史.写索引
    如果 (可见数 > 异常历史_容量) {
        可见数 = 异常历史_容量
    }
    定义 可变 步 = 0
    当 (步 < 可见数) {
        定义 索引 = (异常历史.写索引 - 1 - 步 + 异常历史_容量) % 异常历史_容量
        定义 记录 = 异常历史.记录[索引]
        如果 (记录 != 0 && 记录.指纹 == 指纹 && 记录.时间戳 < 参考时间) {
            自旋锁_解锁(异常历史.锁)
            返回 记录.时间戳
        }
        步 = 步 + 1
    }
    自旋锁_解锁(异常历史.锁)
    返回 0
}

// §10 【Nova原创】异常指纹与AI异常模式检测
//     理论: 将异常的 向量号+RIP低20位+错误码低12位+CR2低20位 哈希为
//     64位指纹。用滑动窗口(最近N次异常)统计指纹出现频率。
//     当某指纹在窗口内出现 > 阈值次时,判定为重复模式,
//     通过AI总线分析是否为: 竞态条件/内存损坏/驱动bug/用户程序缺陷

定义 指纹窗口_容量 = 128
定义 指纹重复阈值 = 5

结构 AI异常检测器 {
    指纹窗口,            // 数组[128]: 最近128次异常的指纹
    窗口索引,
    重复检测次数,
    已报告指纹,          // 数组[16]: 已向AI报告过的指纹(避免重复)
    已报告数量,
}

定义 可变 AI异常检测 = AI异常检测器 {}

函数 异常指纹_计算(向量号, rip, 错误码, cr2) {
    // 哈希: FNV-1a变体
    定义 可变 h = 0xCBF29CE484222325
    h = (h ^ 向量号) * 0x100000001B3
    h = (h ^ (rip & 0xFFFFF)) * 0x100000001B3
    h = (h ^ (错误码 & 0xFFF)) * 0x100000001B3
    h = (h ^ (cr2 & 0xFFFFF)) * 0x100000001B3
    返回 h
}

函数 AI异常_检查重复模式(指纹, 向量号, 时间戳) {
    // 写入窗口
    AI异常检测.指纹窗口[AI异常检测.窗口索引 % 指纹窗口_容量] = 指纹
    AI异常检测.窗口索引 = AI异常检测.窗口索引 + 1

    // 计算此指纹在窗口中出现的次数
    定义 可变 计数 = 0
    定义 可变 i = 0
    当 (i < 指纹窗口_容量) {
        如果 (AI异常检测.指纹窗口[i] == 指纹) {
            计数 = 计数 + 1
        }
        i = i + 1
    }

    如果 (计数 >= 指纹重复阈值) {
        // 检查是否已报告过
        定义 可变 已报告 = 假
        i = 0
        当 (i < AI异常检测.已报告数量) {
            如果 (AI异常检测.已报告指纹[i] == 指纹) {
                已报告 = 真
                跳出
            }
            i = i + 1
        }

        如果 (已报告 == 假 && AI异常检测.已报告数量 < 16) {
            AI异常检测.已报告指纹[AI异常检测.已报告数量] = 指纹
            AI异常检测.已报告数量 = AI异常检测.已报告数量 + 1
            AI异常检测.重复检测次数 = AI异常检测.重复检测次数 + 1

            内核打印(日志_警告,
                "AI异常检测: 向量#%d 指纹%p 在窗口内重复%d次\n",
                向量号, 指纹, 计数)

            // 通知AI总线进行根因分析
            AI异常_通知总线(指纹, 向量号, 计数, 时间戳)
        }
    }
}

函数 AI异常_通知总线(指纹, 向量号, 重复数, 当前时间) {
    定义 bus = 全局AI总线
    如果 (bus == 空) { 返回 }
    // 构造特征向量: [向量号, 重复数, 是否致命, 时间密度]
    定义 特征 = Tensor_创建(1, 4)
    Tensor_写(特征, 0, 0, 向量号 * Q_ONE / 32)
    Tensor_写(特征, 0, 1, 重复数 * Q_ONE / 指纹窗口_容量)
    定义 致命性 = 0
    如果 (向量号 == 8 || 向量号 == 18) { 致命性 = Q_ONE }
    否则如果 (向量号 == 13 || 向量号 == 14) { 致命性 = Q_ONE / 2 }
    Tensor_写(特征, 0, 2, 致命性)
    定义 上次时间 = 异常历史_最近指纹时间(指纹, 当前时间)
    定义 时间密度 = Q_ONE / 2
    如果 (上次时间 > 0 && 当前时间 > 上次时间) {
        定义 时间差 = 当前时间 - 上次时间
        时间密度 = Q_ONE * 1000000000 / (时间差 + 1000000000)
    }
    Tensor_写(特征, 0, 3, 时间密度)
    AI总线_异常分析(bus, 特征)
    Tensor_释放(特征)
}


导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")

定义 初始桶数 = 16
定义 负载因子 = 75
定义 空槽 = 0
定义 已删 = 1
定义 已占 = 2

结构 哈希映射 {
    桶表,
    桶数,
    已用数,
    已删数,
    查找次数,
    碰撞次数,
    扩容次数,
}

函数 映射_创建() {
    定义 映射 = 堆_分配(哈希映射)
    映射.桶数 = 初始桶数
    映射.桶表 = 堆_分配(映射.桶数 * 24)
    定义 可变 序号 = 0
    当 (序号 < 映射.桶数) {
        内存_写64(映射.桶表 + 序号 * 24, 空槽)
        序号 = 序号 + 1
    }
    映射.已用数 = 0
    映射.已删数 = 0
    映射.查找次数 = 0
    映射.碰撞次数 = 0
    映射.扩容次数 = 0
    返回 映射
}

函数 映射_哈希(键) {
    返回 (键 * 2654435761) & 0x7FFFFFFF
}

函数 映射_设(映射, 键, 值) {
    如果 (映射 == 0) { 返回 }
    如果 ((映射.已用数 + 映射.已删数) * 100 > 映射.桶数 * 负载因子) {
        映射_扩容(映射)
    }
    定义 桶号 = 映射_哈希(键) % 映射.桶数
    定义 可变 探测 = 0
    当 (探测 < 映射.桶数) {
        定义 索引 = (桶号 + 探测) % 映射.桶数
        定义 偏移 = 映射.桶表 + 索引 * 24
        定义 状态 = 内存_读64(偏移)
        如果 (状态 == 空槽 || 状态 == 已删) {
            内存_写64(偏移, 已占)
            内存_写64(偏移 + 8, 键)
            内存_写64(偏移 + 16, 值)
            映射.已用数 = 映射.已用数 + 1
            如果 (状态 == 已删) { 映射.已删数 = 映射.已删数 - 1 }
            返回
        }
        如果 (状态 == 已占 && 内存_读64(偏移 + 8) == 键) {
            内存_写64(偏移 + 16, 值)
            返回
        }
        映射.碰撞次数 = 映射.碰撞次数 + 1
        探测 = 探测 + 1
    }
}

函数 映射_取(映射, 键) {
    如果 (映射 == 0) { 返回 0 }
    映射.查找次数 = 映射.查找次数 + 1
    定义 桶号 = 映射_哈希(键) % 映射.桶数
    定义 可变 探测 = 0
    当 (探测 < 映射.桶数) {
        定义 索引 = (桶号 + 探测) % 映射.桶数
        定义 偏移 = 映射.桶表 + 索引 * 24
        定义 状态 = 内存_读64(偏移)
        如果 (状态 == 空槽) { 返回 0 }
        如果 (状态 == 已占 && 内存_读64(偏移 + 8) == 键) {
            返回 内存_读64(偏移 + 16)
        }
        探测 = 探测 + 1
    }
    返回 0
}

函数 映射_删(映射, 键) {
    如果 (映射 == 0) { 返回 假 }
    定义 桶号 = 映射_哈希(键) % 映射.桶数
    定义 可变 探测 = 0
    当 (探测 < 映射.桶数) {
        定义 索引 = (桶号 + 探测) % 映射.桶数
        定义 偏移 = 映射.桶表 + 索引 * 24
        定义 状态 = 内存_读64(偏移)
        如果 (状态 == 空槽) { 返回 假 }
        如果 (状态 == 已占 && 内存_读64(偏移 + 8) == 键) {
            内存_写64(偏移, 已删)
            映射.已用数 = 映射.已用数 - 1
            映射.已删数 = 映射.已删数 + 1
            返回 真
        }
        探测 = 探测 + 1
    }
    返回 假
}

函数 映射_包含(映射, 键) {
    如果 (映射 == 0) { 返回 假 }
    定义 桶号 = 映射_哈希(键) % 映射.桶数
    定义 可变 探测 = 0
    当 (探测 < 映射.桶数) {
        定义 索引 = (桶号 + 探测) % 映射.桶数
        定义 偏移 = 映射.桶表 + 索引 * 24
        定义 状态 = 内存_读64(偏移)
        如果 (状态 == 空槽) { 返回 假 }
        如果 (状态 == 已占 && 内存_读64(偏移 + 8) == 键) { 返回 真 }
        探测 = 探测 + 1
    }
    返回 假
}

函数 映射_取或默认(映射, 键, 默认值) {
    定义 值 = 映射_取(映射, 键)
    如果 (值 == 0) { 返回 默认值 }
    返回 值
}

函数 映射_设如无(映射, 键, 值) {
    如果 (!映射_包含(映射, 键)) { 映射_设(映射, 键, 值); 返回 真 }
    返回 假
}

函数 映射_扩容(映射) {
    如果 (映射 == 0) { 返回 }
    映射.扩容次数 = 映射.扩容次数 + 1
    定义 旧桶表 = 映射.桶表
    定义 旧桶数 = 映射.桶数
    映射.桶数 = 旧桶数 * 2
    映射.桶表 = 堆_分配(映射.桶数 * 24)
    定义 可变 序号 = 0
    当 (序号 < 映射.桶数) {
        内存_写64(映射.桶表 + 序号 * 24, 空槽)
        序号 = 序号 + 1
    }
    映射.已用数 = 0
    映射.已删数 = 0
    序号 = 0
    当 (序号 < 旧桶数) {
        定义 偏移 = 旧桶表 + 序号 * 24
        如果 (内存_读64(偏移) == 已占) {
            映射_设(映射, 内存_读64(偏移 + 8), 内存_读64(偏移 + 16))
        }
        序号 = 序号 + 1
    }
    堆_释放(旧桶表)
}

函数 映射_大小(映射) {
    如果 (映射 == 0) { 返回 0 }
    返回 映射.已用数
}

函数 映射_为空(映射) {
    如果 (映射 == 0) { 返回 真 }
    返回 映射.已用数 == 0
}

函数 映射_遍历(映射, 回调) {
    如果 (映射 == 0) { 返回 0 }
    定义 可变 计数 = 0
    定义 可变 序号 = 0
    当 (序号 < 映射.桶数) {
        定义 偏移 = 映射.桶表 + 序号 * 24
        如果 (内存_读64(偏移) == 已占) {
            如果 (回调 != 0) { 回调(内存_读64(偏移 + 8), 内存_读64(偏移 + 16)) }
            计数 = 计数 + 1
        }
        序号 = 序号 + 1
    }
    返回 计数
}

函数 映射_清空(映射) {
    如果 (映射 == 0) { 返回 }
    定义 可变 序号 = 0
    当 (序号 < 映射.桶数) {
        内存_写64(映射.桶表 + 序号 * 24, 空槽)
        序号 = 序号 + 1
    }
    映射.已用数 = 0
    映射.已删数 = 0
}

函数 映射_负载率(映射) {
    如果 (映射 == 0 || 映射.桶数 == 0) { 返回 0 }
    返回 映射.已用数 * 100 / 映射.桶数
}

函数 映射_完整统计(映射) {
    如果 (映射 == 0) { 返回 [0, 0, 0, 0, 0] }
    返回 [映射.已用数, 映射.桶数, 映射.查找次数, 映射.碰撞次数, 映射.扩容次数]
}

定义 可变 AI_字典_威胁计数 = 0

函数 AI_字典_风险评分(操作类型, 权限级别, 来源可信度) {
    定义 可变 风险 = 0
    如果 (权限级别 > 500) { 风险 = 风险 + 300 }
    如果 (来源可信度 < 200) { 风险 = 风险 + 400 }
    如果 (风险 > 500) { AI_字典_威胁计数 = AI_字典_威胁计数 + 1 }
    返回 风险
}

函数 AI_字典_异常行为检测(操作频率, 基线频率) {
    如果 (基线频率 > 0 && 操作频率 > 基线频率 * 5) { 返回 真 }
    返回 假
}

导入("../../标准库/基础.nova")


// 宏类别
定义 宏类_表达式 = 1
定义 宏类_语句   = 2
定义 宏类_属性   = 3
定义 宏类_派生   = 4

// 宏注册表: [[宏id, 类别, 参数数, 模板id], ...]
函数 宏注册表_创建() { 返回 [] }

函数 宏注册表_注册(reg, 宏id, 类别, 参数数, 模板id) {
    追加(reg, [宏id, 类别, 参数数, 模板id])
}

函数 宏注册表_查(reg, 宏id) {
    定义 可变 i = 0
    当 (i < 计数(reg)) {
        如果 (reg[i][0] == 宏id) { 返回 reg[i] }
        i = i + 1
    }
    返回 空
}

函数 宏注册表_大小(reg) { 返回 计数(reg) }

// 模板引擎: {0},{1},... 替换
函数 宏系统_模板_替换(模板, 参数列表) {
    定义 可变 结果 = ""
    定义 n = 计数(模板)
    定义 可变 i = 0
    当 (i < n) {
        定义 ch = 编码(子串(模板, i, 1))
        如果 (ch == 字符_左花括 且 i + 2 < n) {
            定义 dig = 编码(子串(模板, i + 1, 1)) - 48
            定义 cl = 编码(子串(模板, i + 2, 1))
            如果 (dig >= 0 且 dig <= 9 且 cl == 125) {
                如果 (dig < 计数(参数列表)) {
                    结果 = 字符串拼接(结果, 转字符串(参数列表[dig]))
                }
                i = i + 3
            } 否则 {
                结果 = 字符串拼接(结果, 子串(模板, i, 1))
                i = i + 1
            }
        } 否则 {
            结果 = 字符串拼接(结果, 子串(模板, i, 1))
            i = i + 1
        }
    }
    返回 结果
}

// 卫生命名: 唯一标识符生成
定义 可变 __宏_计数器 = 0

函数 生成唯一名(前缀) {
    __宏_计数器 = __宏_计数器 + 1
    返回 字符串拼接(字符串拼接(前缀, "_"), 转字符串(__宏_计数器))
}

函数 重置计数器() { __宏_计数器 = 0 }

// 展开引擎: 递归展开,带深度限制
定义 最大展开深度 = 64

函数 宏_展开一层(reg, 宏id, 参数, 模板列表) {
    定义 def = 宏注册表_查(reg, 宏id)
    如果 (def == 空) { 返回 [假, -1] }
    如果 (计数(参数) != def[2]) { 返回 [假, -2] }
    // 模板id→模板字符串
    如果 (def[3] >= 0 且 def[3] < 计数(模板列表)) {
        定义 tpl = 模板列表[def[3]]
        返回 [真, 宏系统_模板_替换(tpl, 参数)]
    }
    返回 [假, -3]
}

// 条件编译标志: [[标志id, 值], ...]
函数 编译标志_创建() { 返回 [] }

函数 编译标志_设(标志表, fid, 值) {
    // 先查是否存在
    定义 可变 i = 0
    当 (i < 计数(标志表)) {
        如果 (标志表[i][0] == fid) {
            标志表[i][1] = 值
            返回
        }
        i = i + 1
    }
    追加(标志表, [fid, 值])
}

函数 编译标志_取(标志表, fid) {
    定义 可变 i = 0
    当 (i < 计数(标志表)) {
        如果 (标志表[i][0] == fid) { 返回 标志表[i][1] }
        i = i + 1
    }
    返回 0
}

// 代码重复展开
函数 宏_重复(次数, 模板, 参数基) {
    定义 可变 out = []
    定义 可变 i = 0
    当 (i < 次数) {
        追加(out, 宏系统_模板_替换(模板, [参数基 + i]))
        i = i + 1
    }
    返回 out
}

// 嵌套宏展开 (带深度限制)
函数 宏_嵌套展开(reg, 宏id列表, 参数列表, 模板列表, 最大深度) {
    定义 可变 结果 = ""
    定义 可变 深度 = 0
    定义 可变 i = 0
    当 (i < 计数(宏id列表) 且 深度 < 最大深度) {
        定义 r = 宏_展开一层(reg, 宏id列表[i], 参数列表[i], 模板列表)
        如果 (r[0] == 真) {
            结果 = 字符串拼接(结果, r[1])
        }
        深度 = 深度 + 1
        i = i + 1
    }
    返回 [深度 < 最大深度, 结果]
}

// stringify: 值→字符串表示
函数 宏_字符串化(值) {
    返回 字符串拼接("\"", 字符串拼接(转字符串(值), "\""))
}

// concat: 连接标识符
函数 宏_拼接标识(a, b) {
    返回 字符串拼接(转字符串(a), 转字符串(b))
}

// 宏作用域: [可见性, 宏id]
定义 宏可见_公开 = 0
定义 宏可见_模块 = 1
定义 宏可见_私有 = 2

函数 宏_可见吗(宏可见, 当前模块, 定义模块) {
    如果 (宏可见 == 宏可见_公开) { 返回 真 }
    如果 (宏可见 == 宏可见_模块 且 当前模块 == 定义模块) { 返回 真 }
    如果 (宏可见 == 宏可见_私有 且 当前模块 == 定义模块) { 返回 真 }
    返回 假
}

// 内建宏: assert / dbg / todo / unreachable
函数 内建宏_assert(条件值, 行号) {
    如果 (条件值 == 假) {
        返回 字符串拼接("断言失败 行:", 转字符串(行号))
    }
    返回 ""
}

函数 内建宏_todo(消息) {
    打印(字符串拼接("宏尚未提供: ", 消息))
    抛(-1)
    返回 ""
}

// 宏统计
// 宏参数模式匹配

函数 宏_匹配模式(模式, 输入) {
    // 模式: [类型, 名称] 列表, 类型: "表达式"/"标识符"/"字面量"/"块"
    如果 (计数(模式) != 计数(输入)) { 返回 假 }
    定义 可变 i = 0
    当 (i < 计数(模式)) {
        定义 期望类型 = 模式[i][0]
        定义 实际 = 输入[i]
        如果 (期望类型 == "标识符" 且 !是字符串(实际)) { 返回 假 }
        如果 (期望类型 == "字面量" 且 !是整数(实际)) { 返回 假 }
        i = i + 1
    }
    返回 真
}

// 宏卫生性

定义 可变 _宏_卫生计数 = 0

函数 宏_生成卫生名(原名) {
    _宏_卫生计数 = _宏_卫生计数 + 1
    返回 原名 + "__宏" + 转字符串(_宏_卫生计数)
}

函数 宏_卫生重命名(体, 局部变量列表) {
    定义 可变 映射_旧 = []
    定义 可变 映射_新 = []
    定义 可变 i = 0
    当 (i < 计数(局部变量列表)) {
        追加(映射_旧, 局部变量列表[i])
        追加(映射_新, 宏_生成卫生名(局部变量列表[i]))
        i = i + 1
    }
    返回 [体, 映射_旧, 映射_新]
}

// 条件编译

定义 可变 _编译条件_键 = []
定义 可变 _编译条件_值 = []

函数 编译条件_设(键, 值) {
    定义 可变 i = 0
    当 (i < 计数(_编译条件_键)) {
        如果 (_编译条件_键[i] == 键) { _编译条件_值[i] = 值 返回 空 }
        i = i + 1
    }
    追加(_编译条件_键, 键)
    追加(_编译条件_值, 值)
}

函数 编译条件_取(键) {
    定义 可变 i = 0
    当 (i < 计数(_编译条件_键)) {
        如果 (_编译条件_键[i] == 键) { 返回 _编译条件_值[i] }
        i = i + 1
    }
    返回 空
}

函数 编译条件_已定义(键) {
    定义 可变 i = 0
    当 (i < 计数(_编译条件_键)) {
        如果 (_编译条件_键[i] == 键) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 宏_条件编译(条件键, 真分支, 假分支) {
    如果 (编译条件_已定义(条件键) 且 编译条件_取(条件键)) { 返回 真分支 }
    返回 假分支
}

// 宏递归展开限制

定义 可变 _宏_最大递归 = 128
定义 可变 _宏_当前递归 = 0

函数 宏_进入展开() {
    _宏_当前递归 = _宏_当前递归 + 1
    如果 (_宏_当前递归 > _宏_最大递归) {
        打印("错误: 宏递归深度超过" + 转字符串(_宏_最大递归) + "\n")
        返回 假
    }
    返回 真
}

函数 宏_离开展开() { _宏_当前递归 = _宏_当前递归 - 1 }

定义 可变 _宏_展开数 = 0
定义 可变 _宏_定义数 = 0

函数 宏_记录展开() { _宏_展开数 = _宏_展开数 + 1 }
函数 宏_记录定义() { _宏_定义数 = _宏_定义数 + 1 }

}

// Nova天生理解Python: 动态类型→Nova值, list→Nova列表, dict→Nova字典

函数 外语言_执行Python(路径, 参数) {
    _外语言_Python执行数 = _外语言_Python执行数 + 1
    内核信息("外语言桥接: Python → Nova执行: " + 路径)

    // 阶段1: 读取Python源码
    定义 源码 = 文件_读全部(路径)
    如果 (源码 == 空) { 返回 错误_不存在 }

    // 阶段2: Python词法分析 (缩进敏感)
    定义 词元 = Python_词法分析(源码)
    如果 (词元 == 空) { 返回 错误_编译 }

    // 阶段3: Python AST构建
    定义 AST = Python_语法分析(词元)
    如果 (AST == 空) { 返回 错误_编译 }

    // 阶段4: Python AST → Nova字节码
    // 类型映射: int→整数, str→字符串, list→列表, dict→字典, tuple→元组
    定义 字节码 = Python_到Nova字节码(AST)
    如果 (字节码 == 空) { 返回 错误_编译 }

    // 阶段5: 执行Nova字节码
    定义 虚机 = 创建Python虚机()
    Python_注入标准库(虚机)
    定义 结果 = Python_虚机执行(虚机, 字节码, 参数)
    内核信息("Python执行完成")
    返回 结果
}


导入("../中枢/整数转字符串.nova")

// NovaOS · 窗口合成器 (Wayland风格合成器 + AI智能布局)
// 窗口管理 + 图层合成 + 双缓冲 + 透明度混合 + 事件分发
// §1 窗口结构: surface + 图层 + Z序 + 透明度
// §2 合成器核心: 图层合成 + alpha混合 + 脏区域优化
// §3 窗口管理: 创建/销毁/移动/调整/最小化/最大化
// §4 事件分发: 鼠标/键盘→窗口路由 + 焦点管理
// §5 AI智能布局: 自动分屏 + 窗口推荐位置

外部 VESA_查询最佳模式
外部 GOP_获取模式信息
外部 kmalloc
外部 kfree

定义 最大窗口数 = 128
定义 最大图层数 = 8
定义 窗口状态_正常 = 0
定义 窗口状态_最小化 = 1
定义 窗口状态_最大化 = 2
定义 窗口状态_全屏 = 3
定义 窗口状态_隐藏 = 4

定义 图层_桌面 = 0
定义 图层_普通 = 1
定义 图层_浮动 = 2
定义 图层_通知 = 3
定义 图层_顶层 = 4
定义 图层_全屏 = 5
定义 图层_覆盖 = 6
定义 图层_鼠标 = 7

结构 窗口 {
    窗口ID,
    进程ID,
    标题哈希,
    x,
    y,
    宽,
    高,
    最小宽,
    最小高,
    状态,
    图层,
    Z序,
    透明度,    // u32 0=全透明 255=不透明
    可见,
    有焦点,
    缓冲地址,    // u64 surface像素缓冲
    缓冲大小,
    脏,    // 布尔 需要重绘
    装饰_启用,    // 布尔 窗口装饰(标题栏/边框)
}

定义 可变 所有窗口 = []
定义 可变 焦点窗口ID = 0
定义 可变 下一个窗口ID = 1
定义 可变 合成器_已初始化 = 假
定义 可变 屏幕宽 = 1920
定义 可变 屏幕高 = 1080

// 动态分辨率设置(启动时由VESA/GOP查询实际硬件能力)
// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 屏幕_设置分辨率(宽, 高, 位深) {
    如果 (宽 < 640 || 高 < 480) {
        内核警告("屏幕: 分辨率过低 " + 整数转字符串(宽) + "x" + 整数转字符串(高))
        返回 假
    }
    如果 (宽 > 7680 || 高 > 4320) {
        内核警告("屏幕: 分辨率超出支持范围")
        返回 假
    }
    屏幕宽 = 宽
    屏幕高 = 高
    屏幕位深 = 位深
    内核信息("屏幕: 分辨率设置 " + 整数转字符串(宽) + "x" + 整数转字符串(高) +
             "@" + 整数转字符串(位深) + "bpp")
    返回 真
}

// 从VESA BIOS / UEFI GOP 查询最佳分辨率
函数 屏幕_自动检测分辨率() {
    // 优先UEFI GOP
    定义 gop = GOP_获取模式信息()
    如果 (gop != 空) {
        返回 屏幕_设置分辨率(gop.水平分辨率, gop.垂直分辨率, 32)
    }
    // 回退VESA
    定义 vesa = VESA_查询最佳模式()
    如果 (vesa != 空) {
        返回 屏幕_设置分辨率(vesa.宽, vesa.高, vesa.位深)
    }
    // 保持默认1920×1080
    内核信息("屏幕: 使用默认 1920x1080@32bpp")
    返回 真
}
定义 可变 屏幕位深 = 32
定义 可变 前缓冲 = 0        // 帧缓冲物理地址
定义 可变 后缓冲 = 0        // 后缓冲物理地址
定义 可变 合成_帧数 = 0
定义 可变 合成_脏区域 = []   // [x, y, w, h] 列表

函数 合成器_初始化(宽, 高, 位深, fb地址) {
    屏幕宽 = 宽
    屏幕高 = 高
    屏幕位深 = 位深
    前缓冲 = fb地址
    后缓冲 = fb地址 + 宽 * 高 * (位深 / 8)
    所有窗口 = []
    焦点窗口ID = 0
    下一个窗口ID = 1
    合成器_已初始化 = 真
    合成_帧数 = 0
    合成_脏区域 = []
    内核信息("合成器: 初始化 " + 整数转字符串(宽) + "×" + 整数转字符串(高) +
             " " + 整数转字符串(位深) + "bpp")
}

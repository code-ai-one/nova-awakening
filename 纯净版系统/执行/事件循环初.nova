// NovaOS 浏览器内核 · 第二层 · 事件循环
// 核心能力: 浏览器主事件循环、任务队列、微任务、requestAnimationFrame

定义 任务_用户输入     = 0    // 鼠标/键盘/触摸
定义 任务_网络回调     = 1    // 网络请求完成
定义 任务_定时器       = 2    // setTimeout/setInterval
定义 任务_DOM变更      = 3    // MutationObserver
定义 任务_渲染帧       = 4    // requestAnimationFrame
定义 任务_微任务       = 5    // 承诺.then
定义 任务_AI推理       = 6    // AI模块回调
定义 任务_系统事件     = 7    // 内核事件(内存压力/电源等)

定义 任务优先级_立即   = 0    // 用户输入(最高)
定义 任务优先级_高     = 1    // 网络回调/微任务
定义 任务优先级_普通   = 2    // 定时器/DOM变更
定义 任务优先级_低     = 3    // 后台任务
定义 任务优先级_空闲   = 4    // 空闲时执行

结构 浏览器任务 {
    ID,
    类型,
    优先级,
    回调,    // 字符串 JS代码或内部函数名
    数据,    // 字符串 任务数据
    延迟,    // u64 毫秒(定时器用)
    创建时间,
    执行时间,    // u64 计划执行时间
    重复,    // 布尔 setInterval
    间隔,    // u64 重复间隔
}

结构 浏览器事件循环 {
    宏任务队列,    // [] 按优先级排序
    微任务队列,    // [] FIFO
    帧回调队列,    // [] rAF回调
    定时器列表,    // [] 活跃定时器
    运行中,
    帧计数,
    上帧时间,
    帧间隔,    // u64 微秒(16666=60fps)
    空闲回调,    // [] requestIdleCallback
    下一个ID,
    // 统计
    总任务数,
    总帧数,
    丢帧数,
}

定义 可变 事件循环 = 空
定义 可变 循环_已初始化 = 假

// §1 初始化

// 事件循环_初始化 已统一定义在 感知/事件循环主体.nova
函数 执行_事件循环_初始化() {
    事件循环 = 浏览器事件循环 {}
    事件循环.宏任务队列 = []
    事件循环.微任务队列 = []
    事件循环.帧回调队列 = []
    事件循环.定时器列表 = []
    事件循环.空闲回调 = []
    事件循环.运行中 = 假
    事件循环.帧计数 = 0
    事件循环.上帧时间 = 0
    事件循环.帧间隔 = 16666    // 60fps
    事件循环.下一个ID = 1
    事件循环.总任务数 = 0
    事件循环.总帧数 = 0
    事件循环.丢帧数 = 0
    循环_已初始化 = 真
    内核信息("浏览器事件循环: 初始化完成, 60fps目标")
}

// §2 任务提交

函数 事件循环_提交任务(类型, 优先级, 回调, 数据) {
    定义 任务 = 浏览器任务 {}
    任务.ID = 事件循环.下一个ID
    事件循环.下一个ID = 事件循环.下一个ID + 1
    任务.类型 = 类型
    任务.优先级 = 优先级
    任务.回调 = 回调
    任务.数据 = 数据
    任务.延迟 = 0
    任务.重复 = 假

    // 按优先级插入宏任务队列
    定义 可变 插入位 = 计数(事件循环.宏任务队列)
    定义 可变 i = 0
    当 (i < 计数(事件循环.宏任务队列)) {
        如果 (事件循环.宏任务队列[i].优先级 > 优先级) {
            插入位 = i
            中断
        }
        i = i + 1
    }

    // 当前实现: 直接追加(实际应插入到正确位置)
    追加(事件循环.宏任务队列, 任务)
    事件循环.总任务数 = 事件循环.总任务数 + 1
    返回 任务.ID
}

函数 事件循环_提交微任务(回调, 数据) {
    定义 任务 = 浏览器任务 {}
    任务.ID = 事件循环.下一个ID
    事件循环.下一个ID = 事件循环.下一个ID + 1
    任务.类型 = 任务_微任务
    任务.优先级 = 任务优先级_高
    任务.回调 = 回调
    任务.数据 = 数据
    追加(事件循环.微任务队列, 任务)
    返回 任务.ID
}

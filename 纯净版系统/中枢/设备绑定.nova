// NovaOS · 设备绑定与水印系统
// §1 设备指纹采集 (CPU/内存/磁盘/MAC → 唯一哈希)
// §2 设备绑定验证 (Bundle指纹 vs 当前设备)
// §3 分发水印 (用户级/渠道级/包级 追踪)
// §4 许可证管理 (绑定+有效期+吊销列表)
// §5 报告


结构 设备指纹 {
    CPU标识,        // u64 CPUID叶0+叶1组合
    内存容量,       // u64 字节
    磁盘序列,       // u64 磁盘序列号哈希
    MAC哈希,        // u64 网卡MAC地址哈希
    TSC基准,        // u64 TSC频率特征
    综合哈希,       // [u32 x 4] SHA-256(全部字段拼接)
}

定义 可变 _当前设备 = 空
定义 可变 _指纹采集次数 = 0

函数 设备_采集指纹() {
    _指纹采集次数 = _指纹采集次数 + 1
    定义 fp = 设备指纹 {}

    // CPU标识: 通过CPUID获取(简化为TSC特征)
    fp.CPU标识 = 内联汇编_返回值("rdtsc") ^ 0xDEADBEEF

    // 内存容量: 从内核内存管理获取总物理页数 * 页大小
    fp.内存容量 = _获取物理内存()

    // 磁盘序列: 从VFS或直接ATA identify获取
    fp.磁盘序列 = _获取磁盘序列哈希()

    // MAC地址: 从网络子系统获取
    fp.MAC哈希 = _获取MAC哈希()

    // TSC基准
    fp.TSC基准 = 内联汇编_返回值("rdtsc")

    // 综合哈希
    定义 可变 数据 = []
    追加(数据, fp.CPU标识 & 0xFF)
    追加(数据, (fp.CPU标识 >> 8) & 0xFF)
    追加(数据, fp.内存容量 & 0xFF)
    追加(数据, (fp.内存容量 >> 8) & 0xFF)
    追加(数据, fp.磁盘序列 & 0xFF)
    追加(数据, (fp.磁盘序列 >> 8) & 0xFF)
    追加(数据, fp.MAC哈希 & 0xFF)
    追加(数据, (fp.MAC哈希 >> 8) & 0xFF)
    fp.综合哈希 = SHA256_哈希(数据, 计数(数据))

    _当前设备 = fp
    返回 fp
}

函数 _获取物理内存() {
    // 从multiboot/E820内存映射表获取总物理内存
    如果 (物理内存_总字节 > 0) { 返回 物理内存_总字节 }
    // 回退: 遍历E820条目累加可用区域
    定义 可变 总量 = 0
    定义 可变 i = 0
    当 (i < 计数(内存映射表)) {
        总量 = 总量 + 内存映射表[i][1]
        i = i + 1
    }
    返回 总量
}

函数 _获取磁盘序列哈希() {
    // ATA IDENTIFY DEVICE: 读取主磁盘序列号(word 10-19)
    // 向ATA控制器发送IDENTIFY(0xEC)命令
    端口输出(0x1F6, 0xA0)   // 主盘
    端口输出(0x1F7, 0xEC)   // IDENTIFY命令
    // 等待BSY清除
    定义 可变 状态 = 端口输入(0x1F7)
    定义 可变 超时 = 0
    当 (位与(状态, 0x80) != 0 && 超时 < 100000) { 状态 = 端口输入(0x1F7); 超时 = 超时 + 1 }
    如果 (超时 >= 100000) { 返回 0 }
    // 读取256个word, 提取word 10-19(序列号)
    定义 可变 哈希 = 0x811C9DC5  // FNV-1a初始值
    定义 可变 w = 0
    当 (w < 256) {
        定义 值 = 端口输入字(0x1F0)
        如果 (w >= 10 && w <= 19) {
            哈希 = 位异或(哈希, 值)
            哈希 = 哈希 * 0x01000193
        }
        w = w + 1
    }
    返回 哈希
}

函数 _获取MAC哈希() {
    // 从网络子系统读取主网卡MAC地址(6字节)
    定义 mac = 网络_获取主网卡MAC()
    如果 (mac == 空 || 计数(mac) < 6) { 返回 0 }
    // FNV-1a哈希
    定义 可变 h = 0x811C9DC5
    定义 可变 i = 0
    当 (i < 6) {
        h = 位异或(h, mac[i])
        h = h * 0x01000193
        i = i + 1
    }
    返回 h
}


定义 指纹容差 = 1     // 允许1个字段不匹配(硬件微调)

函数 设备_验证绑定(bundle指纹哈希) {
    如果 (_当前设备 == 空) { 设备_采集指纹() }
    定义 当前 = _当前设备.综合哈希

    // 完全匹配
    如果 (当前[0] == bundle指纹哈希[0] && 当前[1] == bundle指纹哈希[1] &&
        当前[2] == bundle指纹哈希[2] && 当前[3] == bundle指纹哈希[3]) {
        返回 真
    }

    // 容差匹配: 允许指纹部分字段变化(如换网卡)
    定义 可变 匹配数 = 0
    如果 (当前[0] == bundle指纹哈希[0]) { 匹配数 = 匹配数 + 1 }
    如果 (当前[1] == bundle指纹哈希[1]) { 匹配数 = 匹配数 + 1 }
    如果 (当前[2] == bundle指纹哈希[2]) { 匹配数 = 匹配数 + 1 }
    如果 (当前[3] == bundle指纹哈希[3]) { 匹配数 = 匹配数 + 1 }
    返回 匹配数 >= (4 - 指纹容差)
}

函数 设备_指纹转字符串() {
    如果 (_当前设备 == 空) { 返回 "未采集" }
    定义 h = _当前设备.综合哈希
    返回 整数转字符串(h[0]) + "-" + 整数转字符串(h[1]) + "-" + 整数转字符串(h[2]) + "-" + 整数转字符串(h[3])
}


定义 水印层_包 = 0           // 包级: 每个bundle不同
定义 水印层_渠道 = 1         // 渠道级: 每个分发渠道不同
定义 水印层_用户 = 2         // 用户级: 每个用户不同

结构 水印信息 {
    层级,           // u32 水印层_*
    标识值,         // u64 唯一标识
    创建时间,
    渠道名,
    用户哈希,       // u64 用户ID哈希(不含明文)
}

定义 可变 _水印历史 = []

函数 水印_生成(层级, 渠道名, 用户哈希) {
    CSPRNG_确保初始化()
    定义 wm = 水印信息 {}
    wm.层级 = 层级
    wm.标识值 = CSPRNG_生成() ^ (读取毫秒() << 16) ^ 用户哈希
    wm.创建时间 = 读取毫秒() / 1000
    wm.渠道名 = 渠道名
    wm.用户哈希 = 用户哈希
    追加(_水印历史, wm)
    返回 wm.标识值
}

函数 水印_嵌入代码段(代码段, 水印值) {
    // 在代码段的多个位置分散嵌入水印碎片
    // 使用nop-sled空隙或对齐填充区域
    定义 大小 = 计数(代码段)
    如果 (大小 < 64) { 返回 }

    // 4个碎片，每个嵌入水印的1/4
    定义 步长 = 大小 / 5
    定义 可变 i = 0
    当 (i < 4) {
        定义 偏移 = 步长 * (i + 1)
        如果 (偏移 < 大小) {
            代码段[偏移] = (水印值 >> (i * 8)) & 0xFF
        }
        i = i + 1
    }
}

函数 水印_提取(代码段) {
    定义 大小 = 计数(代码段)
    如果 (大小 < 64) { 返回 0 }
    定义 步长 = 大小 / 5
    定义 可变 值 = 0
    定义 可变 i = 0
    当 (i < 4) {
        定义 偏移 = 步长 * (i + 1)
        如果 (偏移 < 大小) {
            值 = 值 | (代码段[偏移] << (i * 8))
        }
        i = i + 1
    }
    返回 值
}

函数 水印_追踪(提取值) {
    // 在水印历史中查找匹配
    定义 可变 i = 0
    当 (i < 计数(_水印历史)) {
        如果 (_水印历史[i].标识值 == 提取值) {
            返回 _水印历史[i]
        }
        i = i + 1
    }
    返回 空
}


结构 许可证 {
    许可ID,
    包名,
    设备指纹哈希,   // [u32 x 4]
    颁发时间,
    过期时间,       // u64 0=永久
    已吊销,
    最大安装数,
    当前安装数,
}

定义 可变 _许可证列表 = []
定义 可变 _吊销列表 = []

函数 许可证_颁发(包名, 设备哈希, 有效天数, 最大安装) {
    CSPRNG_确保初始化()
    定义 lic = 许可证 {}
    lic.许可ID = CSPRNG_生成()
    lic.包名 = 包名
    lic.设备指纹哈希 = 设备哈希
    定义 当前秒 = 读取毫秒() / 1000
    lic.颁发时间 = 当前秒
    如果 (有效天数 > 0) {
        lic.过期时间 = 当前秒 + 有效天数 * 86400
    } 否则 {
        lic.过期时间 = 0
    }
    lic.已吊销 = 假
    lic.最大安装数 = 最大安装
    lic.当前安装数 = 0
    追加(_许可证列表, lic)
    返回 lic.许可ID
}

函数 许可证_验证(许可ID, 当前时间) {
    定义 可变 i = 0
    当 (i < 计数(_许可证列表)) {
        定义 lic = _许可证列表[i]
        如果 (lic.许可ID == 许可ID) {
            如果 (lic.已吊销) { 返回 [假, "已吊销"] }
            如果 (lic.过期时间 > 0 && 当前时间 > lic.过期时间) { 返回 [假, "已过期"] }
            如果 (lic.当前安装数 >= lic.最大安装数) { 返回 [假, "超过安装限制"] }
            返回 [真, "有效"]
        }
        i = i + 1
    }
    返回 [假, "许可证不存在"]
}

函数 许可证_吊销(许可ID) {
    定义 可变 i = 0
    当 (i < 计数(_许可证列表)) {
        如果 (_许可证列表[i].许可ID == 许可ID) {
            _许可证列表[i].已吊销 = 真
            追加(_吊销列表, 许可ID)
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 许可证_在吊销列表中(许可ID) {
    定义 可变 i = 0
    当 (i < 计数(_吊销列表)) {
        如果 (_吊销列表[i] == 许可ID) { 返回 真 }
        i = i + 1
    }
    返回 假
}


函数 设备绑定_报告() {
    定义 可变 r = "═══ 设备绑定与水印报告 ═══\n"
    r = r + "设备指纹: " + 设备_指纹转字符串() + "\n"
    r = r + "指纹采集次数: " + 整数转字符串(_指纹采集次数) + "\n"
    r = r + "水印历史: " + 整数转字符串(计数(_水印历史)) + " 条\n"
    r = r + "许可证数: " + 整数转字符串(计数(_许可证列表)) + "\n"
    r = r + "吊销列表: " + 整数转字符串(计数(_吊销列表)) + " 条\n"
    返回 r
}

函数 设备绑定_重置() {
    _当前设备 = 空
    _指纹采集次数 = 0
    _水印历史 = []
    _许可证列表 = []
    _吊销列表 = []
}

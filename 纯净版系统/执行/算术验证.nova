// §9 算术验证 — OCR+计算
// 支持: 运算符优先级/括号/OCR预处理/多格式识别/重试/置信度/统计

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../外联/地址解析辅.nova")
导入("../中枢/内核打印.nova")
导入("./真实点击.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/整数转字符串.nova")
导入("./节点操作.nova")
导入("./旋转验证.nova")

定义 算术_最大重试 = 3
定义 算术_最小置信度 = 60
定义 OCR_最大字符 = 64

结构 算术验证统计 {
    总尝试数,
    成功数,
    失败数,
    OCR失败数,
    计算错误数,
    重试次数,
    平均置信度,
    置信度总和,
}

定义 可变 全局_算术统计 = 空

函数 算术统计_初始化() {
    如果 (全局_算术统计 == 空) {
        全局_算术统计 = 算术验证统计 {}
        全局_算术统计.总尝试数 = 0
        全局_算术统计.成功数 = 0
        全局_算术统计.失败数 = 0
        全局_算术统计.OCR失败数 = 0
        全局_算术统计.计算错误数 = 0
        全局_算术统计.重试次数 = 0
        全局_算术统计.平均置信度 = 0
        全局_算术统计.置信度总和 = 0
    }
}

函数 验证破解_算术(文档) {
    算术统计_初始化()
    全局_算术统计.总尝试数 = 全局_算术统计.总尝试数 + 1

    定义 结果 = 验证结果 {}
    结果.操作序列 = []
    结果.成功 = 假
    结果.置信度 = 0

    定义 可变 重试 = 0
    当 (重试 < 算术_最大重试) {
        // OCR识别算术表达式
        定义 原始文本 = 验证破解_获取提示文字(文档)
        如果 (原始文本 == 0 || 字符串长度(原始文本) == 0) {
            全局_算术统计.OCR失败数 = 全局_算术统计.OCR失败数 + 1
            重试 = 重试 + 1
            全局_算术统计.重试次数 = 全局_算术统计.重试次数 + 1
            继续
        }

        // 预处理: 清理OCR噪声
        定义 表达式 = 算术_预处理(原始文本)
        如果 (字符串长度(表达式) == 0) {
            重试 = 重试 + 1
            全局_算术统计.重试次数 = 全局_算术统计.重试次数 + 1
            继续
        }

        // 验证表达式合法性
        如果 (!算术_验证表达式(表达式)) {
            全局_算术统计.计算错误数 = 全局_算术统计.计算错误数 + 1
            重试 = 重试 + 1
            继续
        }

        // 计算表达式
        定义 答案 = 算术_求值(表达式, 0, 字符串长度(表达式))

        如果 (答案.有效) {
            定义 答案文本 = 整数转字符串(答案.值)
            定义 置信度 = 算术_计算置信度(原始文本, 表达式)

            如果 (置信度 >= 算术_最小置信度) {
                定义 输入事件 = 行为仿真_输入文字(答案文本)
                追加(结果.操作序列, ["仿真输入", 输入事件])
                结果.成功 = 真
                结果.置信度 = 置信度
                全局_算术统计.成功数 = 全局_算术统计.成功数 + 1
                全局_算术统计.置信度总和 = 全局_算术统计.置信度总和 + 置信度
                返回 结果
            }
        }

        重试 = 重试 + 1
        全局_算术统计.重试次数 = 全局_算术统计.重试次数 + 1
    }

    全局_算术统计.失败数 = 全局_算术统计.失败数 + 1
    返回 结果
}

// OCR预处理

函数 算术_预处理(原始) {
    如果 (原始 == 0) { 返回 "" }

    定义 可变 结果 = ""
    定义 长度 = 字符串长度(原始)
    定义 可变 i = 0

    当 (i < 长度 && i < OCR_最大字符) {
        定义 c = 字符串取字符(原始, i)

        // 数字直接保留
        如果 (c >= 48 && c <= 57) {
            结果 = 字符串拼接(结果, 字符转字符串(c))
        }
        // 运算符保留
        否则 如果 (c == 43 || c == 45 || c == 42 || c == 47) {
            // + - * /
            结果 = 字符串拼接(结果, 字符转字符串(c))
        }
        // 括号保留
        否则 如果 (c == 40 || c == 41) {
            结果 = 字符串拼接(结果, 字符转字符串(c))
        }
        // OCR常见误识别修正
        否则 如果 (c == 120 || c == 88) {
            // 'x' 或 'X' → '*'
            结果 = 字符串拼接(结果, "*")
        }
        否则 如果 (c == 247) {
            // '÷' → '/'
            结果 = 字符串拼接(结果, "/")
        }
        否则 如果 (c == 215) {
            // '×' → '*'
            结果 = 字符串拼接(结果, "*")
        }
        // 空格和等号跳过
        否则 如果 (c == 32 || c == 61) {
            // 跳过
        }

        i = i + 1
    }

    返回 结果
}

函数 算术_验证表达式(表达式) {
    如果 (表达式 == 0 || 字符串长度(表达式) == 0) { 返回 假 }

    定义 长度 = 字符串长度(表达式)
    定义 可变 括号深度 = 0
    定义 可变 有数字 = 假
    定义 可变 i = 0

    当 (i < 长度) {
        定义 c = 字符串取字符(表达式, i)

        如果 (c >= 48 && c <= 57) {
            有数字 = 真
        }
        否则 如果 (c == 40) { 括号深度 = 括号深度 + 1 }
        否则 如果 (c == 41) {
            括号深度 = 括号深度 - 1
            如果 (括号深度 < 0) { 返回 假 }
        }
        否则 如果 (c == 43 || c == 45 || c == 42 || c == 47) {
            // 运算符: 合法
        }
        否则 { 返回 假 }

        i = i + 1
    }

    返回 有数字 && 括号深度 == 0
}

// 表达式求值 (支持运算符优先级和括号)

结构 求值结果 {
    值,
    有效,
    位置,
}

函数 算术_求值(表达式, 起始, 结束) {
    返回 算术_求值_加减(表达式, 起始, 结束)
}

函数 算术_求值_加减(表达式, 起始, 结束) {
    定义 左 = 算术_求值_乘除(表达式, 起始, 结束)
    如果 (!左.有效) { 返回 左 }

    定义 可变 结果值 = 左.值
    定义 可变 位 = 左.位置

    当 (位 < 结束) {
        定义 c = 字符串取字符(表达式, 位)
        如果 (c == 43) {
            定义 右 = 算术_求值_乘除(表达式, 位 + 1, 结束)
            如果 (!右.有效) { 返回 右 }
            结果值 = 结果值 + 右.值
            位 = 右.位置
        }
        否则 如果 (c == 45) {
            定义 右 = 算术_求值_乘除(表达式, 位 + 1, 结束)
            如果 (!右.有效) { 返回 右 }
            结果值 = 结果值 - 右.值
            位 = 右.位置
        }
        否则 { 跳出 }
    }

    定义 r = 求值结果 {}
    r.值 = 结果值
    r.有效 = 真
    r.位置 = 位
    返回 r
}

函数 算术_求值_乘除(表达式, 起始, 结束) {
    定义 左 = 算术_求值_原子(表达式, 起始, 结束)
    如果 (!左.有效) { 返回 左 }

    定义 可变 结果值 = 左.值
    定义 可变 位 = 左.位置

    当 (位 < 结束) {
        定义 c = 字符串取字符(表达式, 位)
        如果 (c == 42) {
            定义 右 = 算术_求值_原子(表达式, 位 + 1, 结束)
            如果 (!右.有效) { 返回 右 }
            结果值 = 结果值 * 右.值
            位 = 右.位置
        }
        否则 如果 (c == 47) {
            定义 右 = 算术_求值_原子(表达式, 位 + 1, 结束)
            如果 (!右.有效) { 返回 右 }
            如果 (右.值 == 0) {
                定义 err = 求值结果 {}
                err.有效 = 假
                返回 err
            }
            结果值 = 结果值 / 右.值
            位 = 右.位置
        }
        否则 { 跳出 }
    }

    定义 r = 求值结果 {}
    r.值 = 结果值
    r.有效 = 真
    r.位置 = 位
    返回 r
}

函数 算术_求值_原子(表达式, 起始, 结束) {
    定义 可变 位 = 起始
    定义 r = 求值结果 {}

    如果 (位 >= 结束) {
        r.有效 = 假
        返回 r
    }

    定义 c = 字符串取字符(表达式, 位)

    // 括号表达式
    如果 (c == 40) {
        // 查找匹配的右括号
        定义 可变 深度 = 1
        定义 可变 j = 位 + 1
        当 (j < 结束 && 深度 > 0) {
            如果 (字符串取字符(表达式, j) == 40) { 深度 = 深度 + 1 }
            如果 (字符串取字符(表达式, j) == 41) { 深度 = 深度 - 1 }
            j = j + 1
        }
        定义 内部 = 算术_求值(表达式, 位 + 1, j - 1)
        r.值 = 内部.值
        r.有效 = 内部.有效
        r.位置 = j
        返回 r
    }

    // 负号
    定义 可变 符号 = 1
    如果 (c == 45) {
        符号 = -1
        位 = 位 + 1
    }

    // 数字
    定义 可变 值 = 0
    定义 可变 有数字 = 假
    当 (位 < 结束) {
        定义 d = 字符串取字符(表达式, 位)
        如果 (d >= 48 && d <= 57) {
            值 = 值 * 10 + (d - 48)
            有数字 = 真
            位 = 位 + 1
        } 否则 {
            跳出
        }
    }

    r.值 = 值 * 符号
    r.有效 = 有数字
    r.位置 = 位
    返回 r
}

// 简化版计算 (向后兼容)

函数 验证破解_计算表达式(表达式) {
    如果 (表达式 == 0 || 字符串长度(表达式) == 0) { 返回 "" }

    定义 结果 = 算术_求值(表达式, 0, 字符串长度(表达式))
    如果 (结果.有效) {
        返回 整数转字符串(结果.值)
    }
    返回 ""
}

函数 算术_计算置信度(原始, 清理后) {
    如果 (原始 == 0 || 清理后 == 0) { 返回 0 }
    定义 原始长 = 字符串长度(原始)
    定义 清理长 = 字符串长度(清理后)
    如果 (原始长 == 0) { 返回 0 }

    // 清理后保留率越高, 置信度越高
    定义 保留率 = (清理长 * 100) / 原始长
    如果 (保留率 > 100) { 保留率 = 100 }

    // 基础置信度 = 保留率
    定义 可变 置信度 = 保留率

    // 短表达式加分 (CAPTCHA通常很简短)
    如果 (清理长 <= 7) { 置信度 = 置信度 + 10 }

    如果 (置信度 > 100) { 置信度 = 100 }
    返回 置信度
}

// DOM元素查找工具

函数 验证破解_查找元素(文档, 关键词) {
    定义 可变 i = 0
    当 (i < 计数(文档.节点池)) {
        定义 节点 = 文档.节点池[i]
        定义 cls = DOM_获取属性(文档, 节点.ID, "class")
        定义 id = DOM_获取属性(文档, 节点.ID, "id")
        如果 (字符串查找(cls, 关键词) >= 0 || 字符串查找(id, 关键词) >= 0) {
            返回 [0, 0]
        }
        i = i + 1
    }
    返回 空
}

函数 验证破解_查找元素_按标签(文档, 标签名, 关键词) {
    定义 可变 i = 0
    当 (i < 计数(文档.节点池)) {
        定义 节点 = 文档.节点池[i]
        如果 (节点.标签名 == 标签名) {
            定义 cls = DOM_获取属性(文档, 节点.ID, "class")
            如果 (字符串查找(cls, 关键词) >= 0) {
                返回 [0, 0]
            }
        }
        i = i + 1
    }
    返回 空
}

函数 验证破解_查找输入框(文档) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(文档.节点池)) {
        定义 节点 = 文档.节点池[i]
        如果 (节点.标签名 == "input") {
            定义 类型 = DOM_获取属性(文档, 节点.ID, "type")
            如果 (类型 == "text" || 类型 == "number" || 类型 == "") {
                追加(结果, 节点)
            }
        }
        i = i + 1
    }
    返回 结果
}

// 统计

函数 验证破解_统计() {
    算术统计_初始化()
    定义 成功率 = 0
    如果 (全局_算术统计.总尝试数 > 0) {
        成功率 = (全局_算术统计.成功数 * 100) / 全局_算术统计.总尝试数
        全局_算术统计.平均置信度 = 全局_算术统计.置信度总和 / 全局_算术统计.总尝试数
    }
    返回 [全局_算术统计.总尝试数, 全局_算术统计.成功数, 成功率]
}

函数 验证破解_打印统计() {
    算术统计_初始化()
    打印行("=== 算术验证统计 ===")
    打印行("总尝试: " + 整数转字符串(全局_算术统计.总尝试数))
    打印行("成功数: " + 整数转字符串(全局_算术统计.成功数))
    打印行("失败数: " + 整数转字符串(全局_算术统计.失败数))
    打印行("OCR失败: " + 整数转字符串(全局_算术统计.OCR失败数))
    打印行("计算错误: " + 整数转字符串(全局_算术统计.计算错误数))
    打印行("重试次数: " + 整数转字符串(全局_算术统计.重试次数))
    如果 (全局_算术统计.总尝试数 > 0) {
        定义 率 = (全局_算术统计.成功数 * 100) / 全局_算术统计.总尝试数
        打印行("成功率: " + 整数转字符串(率) + "%")
        打印行("平均置信度: " + 整数转字符串(全局_算术统计.平均置信度))
    }
}

// OCR字符纠错与表达式复杂度

函数 OCR_纠错_数字(ch) {
    // 常见OCR误读: O→0, l→1, I→1, S→5, B→8, Z→2
    如果 (ch == 79 || ch == 111) { 返回 48 }   // O/o → 0
    如果 (ch == 108 || ch == 73) { 返回 49 }   // l/I → 1
    如果 (ch == 83 || ch == 115) { 返回 53 }   // S/s → 5
    如果 (ch == 66) { 返回 56 }                 // B → 8
    如果 (ch == 90 || ch == 122) { 返回 50 }   // Z/z → 2
    如果 (ch == 71) { 返回 54 }                 // G → 6
    返回 ch
}

函数 OCR_纠错_运算符(ch) {
    // 常见OCR误读: x→*, X→*
    如果 (ch == 120 || ch == 88) { 返回 42 }   // x/X → *
    如果 (ch == 247) { 返回 47 }                // ÷ → /
    如果 (ch == 215) { 返回 42 }                // × → *
    返回 ch
}

函数 OCR_全自动纠错(文本) {
    如果 (文本 == 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 i = 0
    定义 len = 字符串长度(文本)
    当 (i < len) {
        定义 ch = 字符串取字符(文本, i)
        如果 (ch >= 48 && ch <= 57) {
            结果 = 结果 + 字符串从字节(ch)
        } 否则 如果 (ch == 43 || ch == 45 || ch == 42 || ch == 47) {
            结果 = 结果 + 字符串从字节(ch)
        } 否则 {
            定义 纠正 = OCR_纠错_数字(ch)
            如果 (纠正 != ch) {
                结果 = 结果 + 字符串从字节(纠正)
            } 否则 {
                纠正 = OCR_纠错_运算符(ch)
                如果 (纠正 != ch) {
                    结果 = 结果 + 字符串从字节(纠正)
                }
            }
        }
        i = i + 1
    }
    返回 结果
}

函数 表达式_复杂度(表达式) {
    // 计算表达式复杂度: 操作符数量 + 括号嵌套深度
    如果 (表达式 == 0) { 返回 0 }
    定义 可变 ops = 0
    定义 可变 depth = 0
    定义 可变 max_depth = 0
    定义 可变 i = 0
    定义 len = 字符串长度(表达式)
    当 (i < len) {
        定义 ch = 字符串取字符(表达式, i)
        如果 (ch == 43 || ch == 45 || ch == 42 || ch == 47) {
            ops = ops + 1
        }
        如果 (ch == 40) { depth = depth + 1 }
        如果 (ch == 41) { depth = depth - 1 }
        如果 (depth > max_depth) { max_depth = depth }
        i = i + 1
    }
    返回 ops * 10 + max_depth
}

函数 验证破解_重置统计() {
    算术统计_初始化()
    全局_算术统计.总尝试数 = 0
    全局_算术统计.成功数 = 0
    全局_算术统计.失败数 = 0
    全局_算术统计.OCR失败数 = 0
    全局_算术统计.计算错误数 = 0
    全局_算术统计.重试次数 = 0
    全局_算术统计.置信度总和 = 0
    全局_算术统计.平均置信度 = 0
}

// NAVE — Nova Arithmetic Verification Engine
// 公理1(数字完备): 支持所有四则运算+括号嵌套
// 公理2(OCR鲁棒): 常见OCR误读字符自动纠错
// 公理3(低延迟): 单次验证计算<1ms
// 定理1(置信度单调): 保留率越高置信度越高
// 定理2(收敛性): 重试在有限次后必定成功或放弃

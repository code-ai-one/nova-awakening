
导入("../集合/堆/最小堆.nova")
导入("../基础.nova")

函数 优先队列_堆_创建(模式) { 返回 [[], 模式, [0,]] }
函数 优先队列_堆_大小(堆) { 返回 计数(堆[0]) }
函数 优先队列_堆_空(堆) { 返回 计数(堆[0]) == 0 }
函数 堆_阴阳(堆) {
    如果 (堆[1] == 0) { 返回 "阴" }
    返回 "阳"
}

函数 堆_父(i) { 返回 (i - 1) / 2 }
函数 堆_左子(i) { 返回 2 * i + 1 }
函数 堆_右子(i) { 返回 2 * i + 2 }

函数 堆_比较(堆, a, b) {
    如果 (堆[1] == 0) { 返回 a < b
}
 返回 a > b
}

函数 堆_交换(数据, i, j) { 定义 临时 = 数据[i]
 数据[i] = 数据[j]
 数据[j] = 临时
}

函数 优先队列_堆_上浮(堆, 索引) { 定义 数据 = 堆[0]
 定义 可变 i = 索引
 当 (i > 0) { 定义 父 = 堆_父(i)
 如果 (堆_比较(堆, 数据[i][0], 数据[父][0]) == 1) {
 堆_交换(数据, i, 父)
 i = 父
 } 否则 {
 止
 }
 }
}

函数 优先队列_堆_下沉(堆, 索引) { 定义 数据 = 堆[0]
 定义 大小 = 计数(数据)
 定义 可变 i = 索引
 当 (真) { 定义 左 = 堆_左子(i)
 定义 右 = 堆_右子(i)
 定义 可变 最优 = i
 如果 (左 < 大小 且 堆_比较(堆, 数据[左][0], 数据[最优][0]) == 1) {
 最优 = 左
 }
 如果 (右 < 大小 且 堆_比较(堆, 数据[右][0], 数据[最优][0]) == 1) {
 最优 = 右
 }
 如果 (最优 != i) {
 堆_交换(数据, i, 最优)
 i = 最优
 } 否则 {
 止
 }
 }
}

函数 优先队列_堆_插入(堆, 优先级, 值) { 定义 统计 = 堆[2]
 统计[0] = 统计[0] + 1
 追加(堆[0], [优先级, 值])
 优先队列_堆_上浮(堆, 计数(堆[0]) - 1)
}

函数 优先队列_堆_弹出(堆) { 定义 统计 = 堆[2]
 统计[1] = 统计[1] + 1
 定义 数据 = 堆[0]
 如果 (计数(数据) == 0) { 返回 空 }
 定义 顶 = 数据[0]
 定义 末 = 数据[计数(数据) - 1]
 数据[0] = 末
 删除(数据, 计数(数据) - 1)
 如果 (计数(数据) > 0) { 优先队列_堆_下沉(堆, 0) }
 返回 顶
}

函数 优先队列_堆_顶(堆) {
    如果 (计数(堆[0]) == 0) { 返回 空
}
 返回 堆[0][0]
}

// 堆排序
函数 优先队列_堆排序(列表) { 定义 堆 = 优先队列_堆_创建(0)
 定义 可变 i = 0
 当 (i < 计数(列表)) {
 优先队列_堆_插入(堆, 列表[i], 列表[i])
 i = i + 1
 }
 定义 可变 结果 = []
 当 (优先队列_堆_空(堆) == 0) { 定义 项 = 优先队列_堆_弹出(堆)
 追加(结果, 项[1])
 }
 返回 结果
}

// 合并k个有序列表
函数 k路合并(列表组) { 定义 堆 = 优先队列_堆_创建(0)
 定义 可变 索引表 = []
 定义 可变 i = 0
 当 (i < 计数(列表组)) {
 追加(索引表, 0)
 如果 (计数(列表组[i]) > 0) {
 优先队列_堆_插入(堆, 列表组[i][0], i)
 }
 i = i + 1
 }
 定义 可变 结果 = []
 当 (优先队列_堆_空(堆) == 0) { 定义 项 = 优先队列_堆_弹出(堆)
 定义 列表idx = 项[1]
 追加(结果, 项[0])
 索引表[列表idx] = 索引表[列表idx] + 1
 如果 (索引表[列表idx] < 计数(列表组[列表idx])) {
 优先队列_堆_插入(堆, 列表组[列表idx][索引表[列表idx]], 列表idx)
 }
 }
 返回 结果
}

// Top-K 元素
函数 前K个(列表, k) { 定义 堆 = 优先队列_堆_创建(0)
 定义 可变 i = 0
 当 (i < 计数(列表)) { 如果 (优先队列_堆_大小(堆) < k) {
 优先队列_堆_插入(堆, 列表[i], 列表[i])
 } 否则 { 定义 堆顶 = 优先队列_堆_顶(堆)
 如果 (列表[i] > 堆顶[0]) {
 优先队列_堆_弹出(堆)
 优先队列_堆_插入(堆, 列表[i], 列表[i])
 }
 }
 i = i + 1
 }
 定义 可变 结果 = []
 当 (优先队列_堆_空(堆) == 0) { 定义 弹出项 = 优先队列_堆_弹出(堆)
 追加(结果, 弹出项[1])
 }
 返回 结果
}

// 理论驱动新功能

// 操作统计: [插入数, 弹出数, 调整数]

函数 堆_阴阳验证(堆) { 定义 数据 = 堆[0]
 定义 n = 计数(数据)
 定义 可变 i = 0
 当 (i < n) { 定义 左 = 堆_左子(i)
 定义 右 = 堆_右子(i)
 如果 (左 < n 且 堆_比较(堆, 数据[左][0], 数据[i][0]) == 1) { 返回 0 }
 如果 (右 < n 且 堆_比较(堆, 数据[右][0], 数据[i][0]) == 1) { 返回 0 }
 i = i + 1
 }
 返回 1
}

函数 堆_气韵层级(堆) { 定义 n = 优先队列_堆_大小(堆)
 如果 (n == 0) { 返回 [] }
 定义 可变 层 = []
 定义 可变 层大小 = 1
 定义 可变 已计 = 0
 当 (已计 < n) { 定义 可变 实际 = 层大小
 如果 (已计 + 层大小 > n) { 实际 = n - 已计 }
 追加(层, 实际)
 已计 = 已计 + 实际
 层大小 = 层大小 * 2
 }
 返回 层
}

函数 堆_阴阳反转(堆) { 定义 可变 新模式 = 0
 如果 (堆[1] == 0) { 新模式 = 1 }
 定义 新堆 = 优先队列_堆_创建(新模式)
 定义 数据 = 堆[0]
 定义 可变 i = 0
 当 (i < 计数(数据)) {
 优先队列_堆_插入(新堆, 数据[i][0], 数据[i][1])
 i = i + 1
 }
 返回 新堆
}

// 批量入堆
函数 堆_批量插入(堆, 数据列表) { 定义 可变 i = 0
 当 (i < 计数(数据列表)) {
 优先队列_堆_插入(堆, 数据列表[i][0], 数据列表[i][1])
 i = i + 1
 }
}

// 更新优先级
函数 堆_更新优先级(堆, 数据, 新优先级) { 定义 列表 = 堆[0]
 定义 可变 i = 0
 当 (i < 计数(列表)) { 如果 (列表[i][1] == 数据) {
 列表[i][0] = 新优先级
 优先队列_堆_上浮(堆, i)
 优先队列_堆_下沉(堆, i)
 返回 真
 }
 i = i + 1
 }
 返回 假
}

// 堆转列表
函数 堆_转排序列表(堆) { 定义 可变 结果 = []
 定义 可变 临时堆 = 优先队列_堆_创建(堆[1])
 定义 数据 = 堆[0]
 定义 可变 i = 0
 当 (i < 计数(数据)) { 优先队列_堆_插入(临时堆, 数据[i][0], 数据[i][1]) i = i + 1 }
 当 (优先队列_堆_大小(临时堆) > 0) { 追加(结果, 优先队列_堆_弹出(临时堆)) }
 返回 结果
}

函数 内核适配_本地获取(档, 域, 键) {
    定义 值 = 浏览器存储_本地获取(域, 键)
    档.存储数 = 档.存储数 + 1
    返回 值
}

函数 内核适配_存储统计(档) {
    定义 统计 = 浏览器存储_统计()
    档.最近统计 = 统计
    返回 统计
}

函数 内核适配_初始化安全(档) {
    浏览器安全_初始化()
    档.安全数 = 档.安全数 + 1
    适配总执行 = 适配总执行 + 1
}

函数 内核适配_评估域(档, 域) {
    定义 结果 = 浏览器安全_评估域(域)
    档.最近域 = 域
    档.最近风险 = 结果
    档.安全数 = 档.安全数 + 1

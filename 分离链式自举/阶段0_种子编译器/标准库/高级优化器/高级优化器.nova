导入("../基础.nova")
导入("../数学/优化器.nova")
导入("../算法/数学扩展.nova")


// AdamW
定义 可变 AdamW_一阶矩 = []
定义 可变 AdamW_二阶矩 = []
定义 可变 AdamW_步数 = 0

函数 AdamW_初始化(维度) {
 AdamW_一阶矩 = []
 AdamW_二阶矩 = []
 AdamW_步数 = 0
 定义 可变 i = 0
 当 (i < 维度) { 追加(AdamW_一阶矩, 0)
 追加(AdamW_二阶矩, 0)
 i = i + 1 }
}

函数 AdamW_步(参数, 梯度, lr, 衰减率1, 衰减率2, 极小值, wd) {
 AdamW_步数 = AdamW_步数 + 1
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(参数)) {
 AdamW_一阶矩[i] = 衰减率1 * AdamW_一阶矩[i] / 100 + (100 - 衰减率1) * 梯度[i] / 100
 AdamW_二阶矩[i] = 衰减率2 * AdamW_二阶矩[i] / 100 + (100 - 衰减率2) * 梯度[i] * 梯度[i] / 100000
 定义 一阶矫正 = AdamW_一阶矩[i] * 100 / (100 - 衰减率1)
 定义 可变 v_sqrt = 整数sqrt(AdamW_二阶矩[i] * 100 / (100 - 衰减率2))
 定义 更新 = lr * 一阶矫正 / (v_sqrt + 极小值) + lr * wd * 参数[i] / 10000
 追加(结果, 参数[i] - 更新)
 i = i + 1
 }
 返回 结果
}

// Lion
定义 可变 Lion_动量 = []

函数 Lion_初始化(维度) {
 Lion_动量 = []
 定义 可变 i = 0
 当 (i < 维度) { 追加(Lion_动量, 0)
 i = i + 1 }
}

函数 Lion_步(参数, 梯度, lr, 衰减率1, 衰减率2, wd) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(参数)) { 定义 combo = 衰减率1 * Lion_动量[i] / 100 + (100 - 衰减率1) * 梯度[i] / 100
 定义 可变 sign_v = 0
 如果 (combo > 0) { sign_v = 1 }
 否则 如果 (combo < 0) { sign_v = -1 }
 Lion_动量[i] = 衰减率2 * Lion_动量[i] / 100 + (100 - 衰减率2) * 梯度[i] / 100
 追加(结果, 参数[i] - lr * sign_v - lr * wd * 参数[i] / 10000)
 i = i + 1
 }
 返回 结果
}

// LAMB (Layer-wise Adaptive Moments)
定义 可变 LAMB_一阶矩 = []
定义 可变 LAMB_二阶矩 = []
定义 可变 LAMB_步数 = 0

函数 LAMB_初始化(维度) {
 LAMB_一阶矩 = []
 LAMB_二阶矩 = []
 LAMB_步数 = 0
 定义 可变 i = 0
 当 (i < 维度) { 追加(LAMB_一阶矩, 0)
 追加(LAMB_二阶矩, 0)
 i = i + 1 }
}

函数 LAMB_步(参数, 梯度, lr, 衰减率1, 衰减率2, 极小值, wd) {
    定义 可变 更新列表 = []
 LAMB_步数 = LAMB_步数 + 1
 定义 可变 i = 0
 当 (i < 计数(参数)) {
 LAMB_一阶矩[i] = 衰减率1 * LAMB_一阶矩[i] / 100 + (100 - 衰减率1) * 梯度[i] / 100
 LAMB_二阶矩[i] = 衰减率2 * LAMB_二阶矩[i] / 100 + (100 - 衰减率2) * 梯度[i] * 梯度[i] / 100000
 定义 一阶矫正 = LAMB_一阶矩[i] * 100 / (100 - 衰减率1)
 定义 可变 v_sqrt = 整数sqrt(LAMB_二阶矩[i] * 100 / (100 - 衰减率2))
 定义 adam_upd = 一阶矫正 / (v_sqrt + 极小值) + wd * 参数[i] / 1000
 追加(更新列表, adam_upd)
 i = i + 1
 }
 // 计算 layer-wise trust 比率
 定义 可变 param_norm = 0
 定义 可变 upd_norm = 0
 i = 0
 当 (i < 计数(参数)) {
 param_norm = param_norm + 参数[i] * 参数[i] / 1000
 upd_norm = upd_norm + 更新列表[i] * 更新列表[i] / 1000
 i = i + 1
 }
 param_norm = 整数sqrt(param_norm)
 upd_norm = 整数sqrt(upd_norm)
 定义 可变 trust = 1000
 如果 (upd_norm > 0) { trust = param_norm * 1000 / upd_norm }
 如果 (trust > 10000) { trust = 10000 }
 定义 可变 结果 = []
 i = 0
 当 (i < 计数(参数)) {
 追加(结果, 参数[i] - lr * trust / 1000 * 更新列表[i] / 1000)
 i = i + 1
 }
 返回 结果
}

// SGD + Momentum
定义 可变 SGD_速度 = []

函数 SGD_初始化(维度) {
 SGD_速度 = []
 定义 可变 i = 0
 当 (i < 维度) { 追加(SGD_速度, 0)
 i = i + 1 }
}

函数 SGD_步(参数, 梯度, lr, 动量, wd) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(参数)) { 定义 g = 梯度[i] + wd * 参数[i] / 1000
 SGD_速度[i] = 动量 * SGD_速度[i] / 1000 + g
 追加(结果, 参数[i] - lr * SGD_速度[i] / 1000)
 i = i + 1
 }
 返回 结果
}

// 梯度中心化
函数 梯度中心化(梯度) { 定义 n = 计数(梯度)
 如果 (n == 0) { 返回 梯度 }
 定义 均值 = 折叠(梯度, 0, (s, g) => s + g) / n
 返回 映射(梯度, g => g - 均值)
}

// 学习率调度
函数 学习率_线性预热(当前步, 预热步数, 初始lr, 目标lr) {
    如果 (当前步 >= 预热步数) { 返回 目标lr
}
 如果 (预热步数 == 0) { 返回 0 }
 返回 初始lr + (目标lr - 初始lr) * 当前步 / 预热步数
}

函数 高级优化_学习率_余弦退火(当前步, 总步数, 最小lr, 最大lr) {
    如果 (当前步 >= 总步数) { 返回 最小lr
}
 定义 进度 = 当前步 * 100 / 总步数
 定义 可变 cos_approx = 100 - 进度 * 进度 * 2 / 100
 如果 (cos_approx < -100) { cos_approx = -100 }
 返回 最小lr + (最大lr - 最小lr) * (cos_approx + 100) / 200
}

// 余弦退火+重启 (Cosine Annealing Warm Restarts)
函数 学习率_余弦重启(当前步, 周期长度, 最小lr, 最大lr) { 定义 周期内步 = 当前步 % 周期长度
 返回 学习率_余弦退火(周期内步, 周期长度, 最小lr, 最大lr)
}

函数 学习率_线性衰减(当前步, 总步数, 初始lr) {
    如果 (当前步 >= 总步数) { 返回 0
}
 如果 (总步数 == 0) { 返回 0 }
 返回 初始lr * (总步数 - 当前步) / 总步数
}

函数 学习率_阶梯衰减(当前epoch, 衰减频率, 衰减率, 初始lr) { 定义 衰减次 = 当前epoch / 衰减频率
 定义 可变 lr = 初始lr
 定义 可变 i = 0
 当 (i < 衰减次) { lr = lr * 衰减率 / 100
 i = i + 1 }
 返回 lr
}

// 多项式衰减: lr = (init - end) * (1 - step/total)^power + end
函数 学习率_多项式衰减(当前步, 总步数, 初始lr, 终lr, power) {
    如果 (当前步 >= 总步数) { 返回 终lr
}
 定义 比率 = (总步数 - 当前步) * 1000 / 总步数
 // 比率^power approx
 定义 可变 r = 比率
 定义 可变 p = 1
 当 (p < power) { r = r * 比率 / 1000
 p = p + 1 }
 返回 (初始lr - 终lr) * r / 1000 + 终lr
}

// 学习率是否为零
函数 学习率_是零(lr) { 返回 lr == 0 }

// AdaGrad优化器
函数 AdaGrad_更新(参数, 梯度, 累积平方, 学习率) {
 定义 可变 i = 0
 当 (i < 计数(参数)) {
 累积平方[i] = 累积平方[i] + 梯度[i] * 梯度[i]
 参数[i] = 参数[i] - 学习率 * 梯度[i] / (累积平方[i] + 极小量)
 i = i + 1
 }
}

// RMSProp优化器
函数 RMSProp_更新(参数, 梯度, 平方均值, 学习率, 衰减率) {
 定义 可变 i = 0
 当 (i < 计数(参数)) {
 平方均值[i] = 衰减率 * 平方均值[i] / 1000 + (1000 - 衰减率) * 梯度[i] * 梯度[i] / 1000
 参数[i] = 参数[i] - 学习率 * 梯度[i] / (平方均值[i] + 极小量)
 i = i + 1
 }
}

// AdamW (权重衰减解耦)
函数 AdamW_更新(参数, 梯度, m, v, 步数, 学习率, 权重衰减) { 定义 衰减率1 = 900
 定义 衰减率2 = 999
 定义 可变 i = 0
 当 (i < 计数(参数)) {
 m[i] = 衰减率1 * m[i] / 1000 + (1000 - 衰减率1) * 梯度[i] / 1000
 v[i] = 衰减率2 * v[i] / 1000 + (1000 - 衰减率2) * 梯度[i] * 梯度[i] / 1000
 定义 一阶矫正 = m[i] * 1000 / (1000 - 衰减率1)
 定义 二阶矫正 = v[i] * 1000 / (1000 - 衰减率2)
 参数[i] = 参数[i] - 学习率 * 一阶矫正 / (二阶矫正 + 极小量)
 参数[i] = 参数[i] - 学习率 * 权重衰减 * 参数[i] / 1000
 i = i + 1
 }
}

// 梯度累积
函数 梯度累积_累加(累积梯度, 当前梯度) { 定义 可变 i = 0
 当 (i < 计数(当前梯度)) {
 累积梯度[i] = 累积梯度[i] + 当前梯度[i]
 i = i + 1
 }
}

函数 梯度累积_平均(累积梯度, 累积步数) { 定义 可变 i = 0
 当 (i < 计数(累积梯度)) {
 累积梯度[i] = 累积梯度[i] / 累积步数
 i = i + 1
 }
}

函数 梯度累积_清零(累积梯度) { 定义 可变 i = 0
 当 (i < 计数(累积梯度)) { 累积梯度[i] = 0 i = i + 1 }
}

// 参数组管理
函数 参数组_创建(名称, 参数列表, 学习率, 权重衰减) { 返回 [名称, 参数列表, 学习率, 权重衰减]
}

函数 参数组_设学习率(组, 新lr) { 组[2] = 新lr }
函数 参数组_取学习率(组) { 返回 组[2] }

// 梯度统计
函数 梯度_范数(梯度) { 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < 计数(梯度)) { 总和 = 总和 + 梯度[i] * 梯度[i] i = i + 1 }
 返回 总和
}

函数 梯度_最大值(梯度) { 定义 可变 最大 = 0
 定义 可变 i = 0
 当 (i < 计数(梯度)) { 定义 绝对值 = 梯度[i]
 如果 (绝对值 < 0) { 绝对值 = 0 - 绝对值 }
 如果 (绝对值 > 最大) { 最大 = 绝对值 }
 i = i + 1
 }
 返回 最大
}

函数 梯度_是否爆炸(梯度, 阈值) { 返回 梯度_范数(梯度) > 阈值 * 阈值
}

函数 梯度_是否消失(梯度, 阈值) { 返回 梯度_最大值(梯度) < 阈值
}

导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("./控制报文处.nova")
导入("./控制报文甲.nova")

// NovaOS ICMP协议
// 功能: ICMP消息收发、ping、不可达通知、重定向、限速

定义 ICMP_回显应答           = 0
定义 ICMP_目标不可达         = 3
定义 ICMP_源抑制             = 4
定义 ICMP_重定向             = 5
定义 ICMP_回显请求           = 8
定义 ICMP_路由通告           = 9
定义 ICMP_路由请求           = 10
定义 ICMP_超时               = 11
定义 ICMP_参数问题           = 12
定义 ICMP_时间戳请求         = 13
定义 ICMP_时间戳应答         = 14

定义 ICMP_网络不可达         = 0
定义 ICMP_主机不可达         = 1
定义 ICMP_协议不可达         = 2
定义 ICMP_端口不可达         = 3
定义 ICMP_需要分片           = 4
定义 ICMP_源路由失败         = 5
定义 ICMP_目标网络未知       = 6
定义 ICMP_目标主机未知       = 7
定义 ICMP_管理性禁止         = 13

定义 ICMP_TTL超时            = 0
定义 ICMP_分片重组超时       = 1

定义 ICMP_头部大小           = 8
定义 ICMP_最小MTU            = 576
定义 IP协议_ICMP             = 1

定义 ICMP_限速_间隔          = 1000   // ms
定义 ICMP_限速_突发          = 50

// ICMP头部结构

结构 ICMP头部 {
    类型,
    代码,
    校验和,
    标识符,
    序列号,
}

定义 ICMP_偏移_类型     = 0
定义 ICMP_偏移_代码     = 1
定义 ICMP_偏移_校验和   = 2
定义 ICMP_偏移_标识符   = 4
定义 ICMP_偏移_序列号   = 6

结构 ICMP统计 {
    接收总数,
    发送总数,
    接收错误,
    发送错误,
    回显请求收,
    回显应答收,
    回显请求发,
    回显应答发,
    不可达收,
    不可达发,
    超时收,
    限速丢弃,
}

定义 可变 icmp统计 = ICMP统计 {}

定义 可变 icmp_上次发送时间 = 0
定义 可变 icmp_突发计数 = 0

// ICMP接收处理(从IP层调用)

函数 icmp_接收(Nova缓冲) {
    定义 icmp头 = Nova缓冲.数据 + Nova缓冲.传输层偏移
    定义 icmp长度 = Nova缓冲.数据长度 - Nova缓冲.传输层偏移

    如果 (icmp长度 < ICMP_头部大小) {
        icmp统计.接收错误 = icmp统计.接收错误 + 1
        返回 错误码_无效参数
    }

    // 验证校验和
    如果 (!icmp_验证校验和(icmp头, icmp长度)) {
        icmp统计.接收错误 = icmp统计.接收错误 + 1
        返回 错误码_校验和错误
    }

    icmp统计.接收总数 = icmp统计.接收总数 + 1

    定义 类型 = icmp头[ICMP_偏移_类型]
    定义 代码 = icmp头[ICMP_偏移_代码]

    匹配 (类型) {
        ICMP_回显请求 => {
            icmp统计.回显请求收 = icmp统计.回显请求收 + 1
            icmp_处理回显请求(Nova缓冲)
        }
        ICMP_回显应答 => {
            icmp统计.回显应答收 = icmp统计.回显应答收 + 1
            icmp_处理回显应答(Nova缓冲)
        }
        ICMP_目标不可达 => {
            icmp统计.不可达收 = icmp统计.不可达收 + 1
            icmp_处理不可达(Nova缓冲, 代码)
        }
        ICMP_超时 => {
            icmp统计.超时收 = icmp统计.超时收 + 1
            icmp_处理超时(Nova缓冲, 代码)
        }
        ICMP_重定向 => {
            icmp_处理重定向(Nova缓冲, 代码)
        }
        _ => {
            // 未知类型，忽略
        }
    }

    返回 0
}

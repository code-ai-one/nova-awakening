// extent删除

函数 ext4_extent_删除(sb, Nova文件节点信息, 逻辑块, 长度) {
    定义 可变 头 = Nova文件节点信息.extent树
    如果 (头.深度 != 0) {
        返回 ext4_extent_删除_深层(sb, Nova文件节点信息, 逻辑块, 长度)
    }

    定义 可变 i = 0
    当 (i < 头.有效项数) {
        定义 项 = ext4_extent_获取第N项(头, i)
        定义 起始 = 项.逻辑块
        定义 ext长度 = ext4_extent_获取长度(项)

        如果 (逻辑块 >= 起始 && 逻辑块 < 起始 + ext长度) {
            如果 (逻辑块 == 起始 && 长度 >= ext长度) {
                // 删除整个extent
                ext4_extent_移除第N项(头, i)
                头.有效项数 = 头.有效项数 - 1
            } 否则 如果 (逻辑块 == 起始) {
                // 截断前部
                定义 截断量 = 长度
                项.逻辑块 = 起始 + 截断量
                ext4_extent_设置物理块(项, ext4_extent_获取物理块(项) + 截断量)
                项.长度 = ext长度 - 截断量
                ext4_extent_设置第N项(头, i, 项)
            } 否则 {
                // 截断后部或中间分裂
                定义 新长度 = 逻辑块 - 起始
                项.长度 = 新长度
                ext4_extent_设置第N项(头, i, 项)
            }
            Nova文件节点信息.extent树 = 头
            返回 0
        }
        i = i + 1
    }
    返回 错误码_不存在
}

函数 ext4_extent_删除_深层(sb, Nova文件节点信息, 逻辑块, 长度) {
    // B+树递归删除: 沿索引节点向下遍历到叶节点执行删除
    定义 头 = Nova文件节点信息.extent树
    定义 深度 = 头.深度

    // 在索引层找到覆盖目标逻辑块的子节点
    定义 可变 索引位置 = -1
    定义 可变 i = 0
    当 (i < 头.有效项数) {
        定义 索引 = ext4_extent_获取第N索引(头, i)
        如果 (i + 1 < 头.有效项数) {
            定义 下一索引 = ext4_extent_获取第N索引(头, i + 1)
            如果 (逻辑块 >= 索引.逻辑块 && 逻辑块 < 下一索引.逻辑块) {
                索引位置 = i
            }
        } 否则 {
            如果 (逻辑块 >= 索引.逻辑块) {
                索引位置 = i
            }
        }
        i = i + 1
    }

    如果 (索引位置 < 0) { 返回 错误码_不存在 }

    // 读取子节点磁盘块
    定义 索引 = ext4_extent_获取第N索引(头, 索引位置)
    定义 子块号 = 索引.叶块_低 | (索引.叶块_高 << 32)
    定义 子缓冲 = ext4_读块(sb, 子块号)
    如果 (子缓冲 == 空) { 返回 错误码_IO }

    定义 子头 = ext4_extent_解析头(子缓冲)

    如果 (子头.深度 > 0) {
        // 中间索引层: 构建临时Nova文件节点信息递归
        定义 可变 临时 = Nova文件节点信息
        临时.extent树 = 子头
        定义 结果 = ext4_extent_删除_深层(sb, 临时, 逻辑块, 长度)
        如果 (结果 != 0) { 返回 结果 }
        // 写回子节点
        ext4_extent_写回头(子缓冲, 临时.extent树)
        ext4_写块(sb, 子块号, 子缓冲)
    } 否则 {
        // 叶节点层: 直接在extent项中删除
        定义 可变 j = 0
        当 (j < 子头.有效项数) {
            定义 项 = ext4_extent_获取第N项(子头, j)
            定义 起始 = 项.逻辑块
            定义 ext长度 = ext4_extent_获取长度(项)

            如果 (逻辑块 >= 起始 && 逻辑块 < 起始 + ext长度) {
                如果 (逻辑块 == 起始 && 长度 >= ext长度) {
                    ext4_extent_移除第N项(子头, j)
                    子头.有效项数 = 子头.有效项数 - 1
                } 否则 如果 (逻辑块 == 起始) {
                    定义 截断量 = 长度
                    项.逻辑块 = 起始 + 截断量
                    ext4_extent_设置物理块(项, ext4_extent_获取物理块(项) + 截断量)
                    项.长度 = ext长度 - 截断量
                    ext4_extent_设置第N项(子头, j, 项)
                } 否则 {
                    定义 新长度 = 逻辑块 - 起始
                    项.长度 = 新长度
                    ext4_extent_设置第N项(子头, j, 项)
                }
                // 写回叶节点
                ext4_extent_写回头(子缓冲, 子头)
                ext4_写块(sb, 子块号, 子缓冲)
                返回 0
            }
            j = j + 1
        }
        返回 错误码_不存在
    }

    // 如果子节点为空，删除索引项
    如果 (子头.有效项数 == 0) {
        ext4_extent_移除第N索引(头, 索引位置)
        头.有效项数 = 头.有效项数 - 1
        Nova文件节点信息.extent树 = 头
        ext4_释放块(sb, 子块号)
    }

    返回 0
}

// 辅助: 头/项序列化解析

函数 ext4_extent_解析头(缓冲) {
    定义 可变 头 = Ext4Extent树头 {}
    头.魔数     = 缓冲_读u16(缓冲, 0)
    头.有效项数 = 缓冲_读u16(缓冲, 2)
    头.最大项数 = 缓冲_读u16(缓冲, 4)
    头.深度     = 缓冲_读u16(缓冲, 6)
    头.代数     = 缓冲_读u32(缓冲, 8)
    返回 头
}

函数 ext4_extent_写回头(缓冲, 头) {
    缓冲_写u16(缓冲, 0, 头.魔数)
    缓冲_写u16(缓冲, 2, 头.有效项数)
    缓冲_写u16(缓冲, 4, 头.最大项数)
    缓冲_写u16(缓冲, 6, 头.深度)
    缓冲_写u32(缓冲, 8, 头.代数)
}

函数 ext4_extent_获取第N项(头, n) {
    定义 偏移 = EXT4_EXTENT头_大小 + n * EXT4_EXTENT项_大小
    定义 可变 项 = Ext4Extent项 {}
    项.逻辑块   = 缓冲_读u32(头, 偏移)
    项.长度     = 缓冲_读u16(头, 偏移 + 4)
    项.物理块_高 = 缓冲_读u16(头, 偏移 + 6)
    项.物理块_低 = 缓冲_读u32(头, 偏移 + 8)
    返回 项
}

函数 ext4_extent_设置第N项(头, n, 项) {
    定义 偏移 = EXT4_EXTENT头_大小 + n * EXT4_EXTENT项_大小
    缓冲_写u32(头, 偏移, 项.逻辑块)
    缓冲_写u16(头, 偏移 + 4, 项.长度)
    缓冲_写u16(头, 偏移 + 6, 项.物理块_高)
    缓冲_写u32(头, 偏移 + 8, 项.物理块_低)
}

函数 ext4_extent_获取第N索引(头, n) {
    定义 偏移 = EXT4_EXTENT头_大小 + n * EXT4_EXTENT索引_大小
    定义 可变 索引 = Ext4Extent索引 {}
    索引.逻辑块   = 缓冲_读u32(头, 偏移)
    索引.叶块_低  = 缓冲_读u32(头, 偏移 + 4)
    索引.叶块_高  = 缓冲_读u16(头, 偏移 + 8)
    返回 索引
}

函数 ext4_extent_设置第N索引(头, n, 索引) {
    定义 偏移 = EXT4_EXTENT头_大小 + n * EXT4_EXTENT索引_大小
    缓冲_写u32(头, 偏移, 索引.逻辑块)
    缓冲_写u32(头, 偏移 + 4, 索引.叶块_低)
    缓冲_写u16(头, 偏移 + 8, 索引.叶块_高)
}

函数 ext4_extent_移除第N项(头, n) {
    定义 可变 i = n
    当 (i < 头.有效项数 - 1) {
        定义 下一项 = ext4_extent_获取第N项(头, i + 1)
        ext4_extent_设置第N项(头, i, 下一项)
        i = i + 1
    }
}

定义 可变 AI_扩展扩展丙_热文件表 = []

函数 AI_扩展扩展丙_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_扩展扩展丙_热文件表)) {
        如果 (AI_扩展扩展丙_热文件表[i].路径 == 路径) {
            AI_扩展扩展丙_热文件表[i].频率 = AI_扩展扩展丙_热文件表[i].频率 + 1
            返回 AI_扩展扩展丙_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_扩展扩展丙_热文件表) < 128) {
        追加(AI_扩展扩展丙_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_扩展扩展丙_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

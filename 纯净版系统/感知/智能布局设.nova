// 传统: if(角色==正文) → 255; if(角色==广告) → 50  (预设映射)
// Nova: AI总线_语义分类() + AI总线_注意力权重() 联合决策

函数 AI布局_设置语义优先级(lo, dom节点) {
    如果 (lo == 0 || dom节点 == 0) { 返回 }

    定义 bus = 全局AI总线
    如果 (bus != 0) {
        // 1. 用AI总线的语义嵌入+分类网络推断语义角色
        定义 角色 = AI总线_语义分类(bus, dom节点)
        dom节点.语义角色 = 角色

        // 2. 用AI总线的注意力网络计算注意力权重
        定义 节点特征 = 节点_提取AI特征(dom节点)
        如果 (节点特征 != 0) {
            定义 注意力 = AI总线_注意力权重(bus, 节点特征)
            // 注意力Q10[0,1024] → 布局优先级[0,255]
            lo.布局优先级 = 注意力 * 255 / Q_ONE
            如果 (lo.布局优先级 > 255) { lo.布局优先级 = 255 }

            // 注意力 → 布局精度
            如果 (注意力 > 768) {
                lo.布局精度 = 3    // 高注意力: 精确
            } 否则 如果 (注意力 > 384) {
                lo.布局精度 = 2    // 中等: 标准
            } 否则 如果 (注意力 > 100) {
                lo.布局精度 = 1    // 低注意力: 粗略
                lo.标志 = lo.标志 | 布局标志_低精度布局
            } 否则 {
                lo.布局精度 = 0    // 极低: 跳过
            }
            Tensor_释放(节点特征)
        }
        返回
    }

    // 后备: 基于角色的预设映射
    定义 角色 = dom节点.语义角色
    如果 (角色 == 语义_正文 || 角色 == 语义_标题) {
        lo.布局优先级 = 255; lo.布局精度 = 3
    } 否则 如果 (角色 == 语义_广告) {
        lo.布局优先级 = 50; lo.布局精度 = 1
        lo.标志 = lo.标志 | 布局标志_低精度布局
    } 否则 如果 (角色 == 语义_Cookie同意) {
        lo.布局优先级 = 30; lo.布局精度 = 1
    }
}

函数 AI布局_更新精度(根lo, 视口上, 视口下) {
    // 递归更新所有布局节点的布局精度
    如果 (根lo == 0) { 返回 }
    AI布局_更新精度递归(根lo, 视口上, 视口下)
}

函数 AI布局_更新精度递归(lo, 视口上, 视口下) {
    如果 (lo == 0) { 返回 }

    定义 节点上 = lo.绝对y
    定义 节点下 = lo.绝对y + lo.内容高

    // 完全不可见: 跳过布局
    如果 (节点下 < 视口上 - 200000 || 节点上 > 视口下 + 200000) {
        lo.布局精度 = 0    // 跳过
        返回                    // 不递归子节点
    }
    // 即将进入视口(预加载区): 粗略布局
    否则 如果 (节点下 < 视口上 || 节点上 > 视口下) {
        如果 (lo.布局精度 > 1) { lo.布局精度 = 1 }
    }
    // 视口内: 精确布局(但不降低已有的高精度)
    否则 {
        如果 (lo.布局精度 < 2) { lo.布局精度 = 2 }
    }

    // 递归子节点
    定义 可变 子 = lo.第一子
    当 (子 != 0) {
        AI布局_更新精度递归(子, 视口上, 视口下)
        子 = 子.后兄
    }
}

函数 AI布局_智能布局(lo) {
    如果 (lo == 0) { 返回 }

    // 尝试AI跳过
    如果 (AI布局_可以跳过(lo)) {
        // 使用预测值代替实际布局
        如果 (lo.预测置信度 >= 8000) {
            lo.内容宽 = lo.预测宽
            lo.内容高 = lo.预测高
            返回    // 跳过实际布局!
        }
    }

    // 低精度布局: 只估算尺寸,不递归子节点
    如果 (lo.布局精度 == 1) {
        AI布局_预测尺寸(lo)
        如果 (lo.预测置信度 >= 5000) {
            lo.内容宽 = lo.预测宽
            lo.内容高 = lo.预测高
            lo.标志 = lo.标志 & (~布局标志_需要布局)
            返回    // 用粗略估算替代
        }
    }

    // 标准/精确布局: 调用原始布局算法
    定义 开始 = 平台_获取高精度时间()
    布局Object_布局(lo)
    定义 耗时 = 平台_获取高精度时间() - 开始

    // 更新统计
    lo.上次布局耗时 = 耗时
    lo.累计布局次数 = lo.累计布局次数 + 1
    lo.布局版本 = lo.布局版本 + 1

    // 布局完成后更新预测值(用于下次跳过)
    lo.预测宽 = lo.内容宽
    lo.预测高 = lo.内容高
    lo.预测置信度 = 9500    // 实际布局结果的置信度极高

    // 记录父布局版本(用于判断父是否变化)
    如果 (lo.父 != 0) {
        lo.父布局版本 = lo.父.布局版本
    }
}

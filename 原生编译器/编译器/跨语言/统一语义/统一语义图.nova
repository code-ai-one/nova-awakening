// Nova · 跨语言统一语义图
// 职责: 将外源工程的类型/所有权/并发/错误/资源/ABI语义统一为中间表示
// 层级: 跨语言主线第5步 — 统一语义图生成

// 语义类别

导入("../../../标准库/基础.nova")
导入("../工程摄取/目录架构扫描.nova")
导入("../工程摄取/构建图解析.nova")
导入("../合规/克隆扫描.nova")
导入("../验证/等价验证器.nova")
导入("../样本矩阵/样本矩阵.nova")
导入("../原生重建/模块重建器.nova")
导入("../原生重建/项目生成器.nova")
导入("../智能协作/补丁评审.nova")
导入("../智能协作/工具审计.nova")
导入("../语言前端/C/C前端.nova")
导入("../语言前端/Cpp/Cpp前端.nova")
导入("../语言前端/Go/Go前端.nova")
导入("../语言前端/Java/Java前端.nova")
导入("../语言前端/Python/Python前端.nova")
导入("../语言前端/Rust/Rust前端.nova")

定义 语义_类型      = 0
定义 语义_所有权    = 1
定义 语义_并发      = 2
定义 语义_错误      = 3
定义 语义_资源      = 4
定义 语义_ABI       = 5
定义 语义_元编程    = 6
定义 语义_构建条件  = 7

// 类型语义节点
定义 类型节点_基本     = 0
定义 类型节点_结构     = 1
定义 类型节点_枚举     = 2
定义 类型节点_接口     = 3
定义 类型节点_泛型     = 4
定义 类型节点_函数签名 = 5
定义 类型节点_别名     = 6

// 所有权模型
定义 所有权_值传递   = 0
定义 所有权_不可变借用 = 1
定义 所有权_可变借用  = 2
定义 所有权_转移     = 3
定义 所有权_GC管理   = 4
定义 所有权_手动     = 5
定义 所有权_引用计数 = 6

// 并发模型
定义 并发_线程    = 0
定义 并发_协程    = 1
定义 并发_通道    = 2
定义 并发_异步    = 3
定义 并发_事件循环 = 4
定义 并发_无      = 5

// 错误模型
定义 错误_Result   = 0
定义 错误_异常     = 1
定义 错误_Panic    = 2
定义 错误_errno    = 3

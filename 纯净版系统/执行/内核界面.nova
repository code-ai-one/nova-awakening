    内核界面_记录(档, "打开窗口", [标题, 地址, x, y, 宽, 高], "窗口管理")
    定义 结果 = Nova原生桌面_打开窗口(标题, 地址, x, y, 宽, 高)
    档.窗口数 = 档.窗口数 + 1
    返回 内核界面_成功(档, "打开窗口", 结果)
}


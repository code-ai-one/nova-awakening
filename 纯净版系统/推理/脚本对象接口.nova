// 正则标志位
定义 RE_FLAG_g = 1       // global
定义 RE_FLAG_i = 2       // ignoreCase
定义 RE_FLAG_m = 4       // multiline
定义 RE_FLAG_s = 8       // dotAll
定义 RE_FLAG_u = 16      // unicode
定义 RE_FLAG_y = 32      // sticky
定义 RE_FLAG_d = 64      // hasIndices
定义 RE_FLAG_v = 128     // unicodeSets

// RegExp内部槽
定义 RE_SLOT_SOURCE     = 0     // [[OriginalSource]]
定义 RE_SLOT_FLAGS      = 8     // [[OriginalFlags]]
定义 RE_SLOT_COMPILED   = 16    // 编译后的AST/NFA
定义 RE_SLOT_LASTINDEX  = 24    // [[RegExpLastIndex]]

// 匹配结果
定义 RE_MATCH_MAX_CAPTURES = 32  // 最大捕获组

// AI正则缓存
定义 AI_正则缓存_大小 = 64
定义 AI_正则缓存_条目大小 = 32  // [模式哈希:4][标志:4][编译AST:8][使用次数:4][上次时间:8][填充:4]


结构 RE匹配结果 {
    成功,              // u32 bool
    位置,              // u32 匹配结束位置
    起始位置,          // u32 匹配开始位置
    捕获,              // u64 捕获组数组 [起始:u32][结束:u32]
    捕获数,
    命名捕获,          // u64 命名捕获组(如果有)
}

结构 RE正则缓存 {
    基址,              // u64 缓存条目数组
    容量,
    数量,
    命中次数,
    未命中次数,
}


定义 可变 全局正则缓存 = 0

函数 正则缓存_获取() {
    如果 (全局正则缓存 == 0) {
        全局正则缓存 = 堆_分配(RE正则缓存)
        如果 (全局正则缓存 != 0) {
            全局正则缓存.容量 = AI_正则缓存_大小
            全局正则缓存.基址 = 平台_申请内存(全局正则缓存.容量 * AI_正则缓存_条目大小)
            如果 (全局正则缓存.基址 != 0) {
                内存_清零(全局正则缓存.基址, 全局正则缓存.容量 * AI_正则缓存_条目大小)
            }
            全局正则缓存.数量 = 0
            全局正则缓存.命中次数 = 0
            全局正则缓存.未命中次数 = 0
        }
    }
    返回 全局正则缓存
}

函数 正则缓存_查找(模式哈希, 标志) {
    定义 缓存 = 正则缓存_获取()
    如果 (缓存 == 空 || 缓存.基址 == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < 缓存.数量) {
        定义 偏移 = 缓存.基址 + i * AI_正则缓存_条目大小
        如果 (内存_读32(偏移) == 模式哈希 && 内存_读32(偏移 + 4) == 标志) {
            缓存.命中次数 = 缓存.命中次数 + 1
            // 更新使用次数和时间
            内存_写32(偏移 + 20, 内存_读32(偏移 + 20) + 1)
            内存_写64(偏移 + 24, 平台_获取高精度时间())
            返回 内存_读64(偏移 + 8)    // 返回编译后的AST
        }
        i = i + 1
    }
    缓存.未命中次数 = 缓存.未命中次数 + 1
    返回 0
}

函数 正则缓存_插入(模式哈希, 标志, 编译AST) {
    定义 缓存 = 正则缓存_获取()
    如果 (缓存 == 空 || 缓存.基址 == 0) { 返回 }
    如果 (缓存.数量 >= 缓存.容量) {
        // LRU淘汰最旧的
        缓存.数量 = 缓存.容量 - 1
    }
    定义 偏移 = 缓存.基址 + 缓存.数量 * AI_正则缓存_条目大小
    内存_写32(偏移, 模式哈希)
    内存_写32(偏移 + 4, 标志)
    内存_写64(偏移 + 8, 编译AST)
    内存_写32(偏移 + 20, 1)
    内存_写64(偏移 + 24, 平台_获取高精度时间())
    缓存.数量 = 缓存.数量 + 1
}


函数 RE_是词字符(c) {
    返回 (c >= 0x30 && c <= 0x39) || (c >= 0x41 && c <= 0x5A) || (c >= 0x61 && c <= 0x7A) || c == 0x5F
}

// §4 JS RegExp对象 接口

函数 RegExp_exec(Nova运行时实例, 正则, 字符串) {
    如果 (正则 == 0 || 字符串 == 0) { 返回 Nova运行时实例.null值 }
    定义 模式 = Nova对象_获取属性(Nova运行时实例, 正则, "source")
    定义 flags = Nova对象_获取属性(Nova运行时实例, 正则, "flags")
    定义 模式str = JSValue_获取字符串(模式)
    定义 flags_str = JSValue_获取字符串(flags)
    定义 输入str = JSValue_获取字符串(字符串)
    如果 (模式str == 0 || 输入str == 0) { 返回 Nova运行时实例.null值 }

    定义 ast = RegExp_解析(模式str, flags_str)
    如果 (ast == 0) { 返回 Nova运行时实例.null值 }

    // 获取lastIndex(全局/粘性模式)
    定义 可变 起始 = 0
    定义 标志 = RegExp_解析标志(flags_str)
    如果 (标志 & 1 || 标志 & 32) {    // g 或 y
        定义 li = Nova对象_获取属性(Nova运行时实例, 正则, "lastIndex")
        起始 = Nova值_转数值(Nova运行时实例, li)
    }

    定义 结果 = RegExp_匹配(ast, 输入str, 起始, 标志)
    如果 (结果 == 0) {
        如果 (标志 & 1 || 标志 & 32) {
            Nova对象_设置属性(Nova运行时实例, 正则, "lastIndex", Nova值_创建_Number(Nova运行时实例, 0))
        }
        返回 Nova运行时实例.null值
    }

    // 构建结果数组
    定义 arr = Nova数组_创建(Nova运行时实例, 结果.捕获数 + 1)
    // 整体匹配
    定义 整体起 = 起始
    定义 整体终 = 结果.位置
    定义 整体文本 = 字符串_复制_N(输入str + 整体起, 整体终 - 整体起)
    Nova数组_Push(Nova运行时实例, arr, Nova值_创建_String(Nova运行时实例, 整体文本))

    // 捕获组
    定义 可变 i = 0
    当 (i < 结果.捕获数) {
        定义 cap起 = 内存_读32(结果.捕获 + i * 8)
        定义 cap终 = 内存_读32(结果.捕获 + i * 8 + 4)
        如果 (cap终 > cap起) {
            定义 cap文本 = 字符串_复制_N(输入str + cap起, cap终 - cap起)
            Nova数组_Push(Nova运行时实例, arr, Nova值_创建_String(Nova运行时实例, cap文本))
        } 否则 {
            Nova数组_Push(Nova运行时实例, arr, Nova运行时实例.undefined值)
        }
        i = i + 1
    }

    // 附加属性
    Nova对象_设置属性(Nova运行时实例, arr, "index", Nova值_创建_Number(Nova运行时实例, 整体起))
    Nova对象_设置属性(Nova运行时实例, arr, "input", 字符串)

    // 更新lastIndex
    如果 (标志 & 1 || 标志 & 32) {
        Nova对象_设置属性(Nova运行时实例, 正则, "lastIndex", Nova值_创建_Number(Nova运行时实例, 结果.位置))
    }

    返回 arr
}

函数 RegExp_test(Nova运行时实例, 正则, 字符串) {
    定义 结果 = RegExp_exec(Nova运行时实例, 正则, 字符串)
    返回 结果 != Nova运行时实例.null值 && 结果 != 0
}


// 被动打开(listen + accept)

函数 tcp_监听(sk, 积压数) {
    定义 可变 tcb = sk.tcp控制块
    如果 (tcb.状态 != 传控_状态_关闭) {
        返回 错误码_无效状态
    }

    tcb.状态 = 传控_状态_监听
    tcb.积压上限 = 积压数
    tcb.积压队列 = 队列_创建(积压数)
    tcb.半连接队列 = 队列_创建(积压数 * 2)

    // 加入监听表
    定义 桶号 = tcp_监听_哈希桶(tcb.四元组.源端口)
    tcb.下一个 = 全局传控连接表.监听[桶号].头
    全局传控连接表.监听[桶号].头 = tcb
    全局传控连接表.监听总数 = 全局传控连接表.监听总数 + 1

    返回 0
}

函数 tcp_接受(监听tcb) {
    如果 (监听tcb.状态 != 传控_状态_监听) {
        返回 错误码_无效状态
    }

    // 从完成队列中取出已建立的连接
    如果 (队列_为空(监听tcb.积压队列)) {
        返回 错误码_再试  // 非阻塞模式
    }

    定义 新tcb = 队列_出队(监听tcb.积压队列)
    返回 新tcb
}

// 传控输入状态机处理

函数 tcp_输入处理(Nova缓冲) {
    定义 头 = Nova缓冲.数据 + Nova缓冲.传输层偏移
    定义 源端口 = tcp_获取源端口(头)
    定义 目标端口 = tcp_获取目标端口(头)
    定义 标志 = tcp_获取标志(头)
    定义 序号 = tcp_获取序号(头)
    定义 确认号 = tcp_获取确认号(头)

    // 构建查找四元组
    定义 可变 四元组 = 传控四元组 {}
    四元组.源IP     = Nova缓冲.源IP
    四元组.源端口   = 源端口
    四元组.目标IP   = Nova缓冲.目标IP
    四元组.目标端口 = 目标端口

    // 查找已建立连接
    定义 tcb = tcp_连接表_查找(四元组)
    如果 (tcb != 空) {
        返回 tcp_已建立_输入(tcb, Nova缓冲, 标志, 序号, 确认号)
    }

    // 查找监听socket
    定义 监听tcb = tcp_连接表_查找监听(目标端口)
    如果 (监听tcb != 空 && (标志 & 传控_标志_SYN)) {
        返回 tcp_监听_输入(监听tcb, Nova缓冲)
    }

    // 无匹配连接，发送RST
    tcp_发送RST(Nova缓冲)
    返回 0
}

函数 tcp_已建立_输入(tcb, Nova缓冲, 标志, 序号, 确认号) {
    匹配 (tcb.状态) {
        传控_状态_SYN已发送 => {
            如果 (标志 & 传控_标志_SYN && 标志 & 传控_标志_ACK) {
                // 收到SYN-ACK
                tcb.接收序号 = 序号 + 1
                tcp_处理ACK(tcb, 确认号)

                // 发送ACK完成三次握手
                tcp_发送ACK(tcb)
                tcb.状态 = 传控_状态_已建立
                tcp_连接表_插入_已建立(tcb)
            }
        }

        传控_状态_已建立 => {
            // 处理ACK
            如果 (标志 & 传控_标志_ACK) {
                tcp_处理ACK(tcb, 确认号)
            }
            // 处理数据
            如果 (Nova缓冲.数据长度 > 0) {
                tcp_处理数据(tcb, Nova缓冲, 序号)
            }
            // 处理FIN
            如果 (标志 & 传控_标志_FIN) {
                tcb.接收序号 = 序号 + 1
                tcp_发送ACK(tcb)
                tcb.状态 = 传控_状态_CLOSE_WAIT
            }
        }

        传控_状态_FIN_WAIT_1 => {
            如果 (标志 & 传控_标志_ACK) {
                tcp_处理ACK(tcb, 确认号)
                tcb.状态 = 传控_状态_FIN_WAIT_2
            }
            如果 (标志 & 传控_标志_FIN) {
                tcb.接收序号 = 序号 + 1
                tcp_发送ACK(tcb)
                如果 (tcb.状态 == 传控_状态_FIN_WAIT_2) {
                    tcb.状态 = 传控_状态_TIME_WAIT
                    tcp_启动TIME_WAIT定时器(tcb)
                } 否则 {
                    tcb.状态 = 传控_状态_CLOSING
                }
            }
        }

        传控_状态_FIN_WAIT_2 => {
            如果 (标志 & 传控_标志_FIN) {
                tcb.接收序号 = 序号 + 1
                tcp_发送ACK(tcb)
                tcb.状态 = 传控_状态_TIME_WAIT
                tcp_启动TIME_WAIT定时器(tcb)
            }
        }

        传控_状态_CLOSING => {
            如果 (标志 & 传控_标志_ACK) {
                tcb.状态 = 传控_状态_TIME_WAIT
                tcp_启动TIME_WAIT定时器(tcb)
            }
        }

        传控_状态_LAST_ACK => {
            如果 (标志 & 传控_标志_ACK) {
                tcb.状态 = 传控_状态_关闭
                tcp_销毁连接(tcb)
            }
        }

        _ => {}
    }
    返回 0
}

函数 tcp_监听_输入(监听tcb, Nova缓冲) {
    定义 头 = Nova缓冲.数据 + Nova缓冲.传输层偏移

    // 创建新连接(半连接)
    定义 可变 新tcb = tcp_创建连接(
        Nova缓冲.目标IP, tcp_获取目标端口(头),
        Nova缓冲.源IP, tcp_获取源端口(头)
    )
    新tcb.接收序号 = tcp_获取序号(头) + 1
    新tcb.状态 = 传控_状态_SYN已接收

    // 解析SYN选项
    tcp_解析选项(新tcb, 头)

    // 发送SYN-ACK
    tcp_发送SYN_ACK(新tcb)

    // 加入半连接队列
    队列_入队(监听tcb.半连接队列, 新tcb)
    返回 0
}

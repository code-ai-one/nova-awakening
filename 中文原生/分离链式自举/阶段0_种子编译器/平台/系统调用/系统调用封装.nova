// Nova · 平台层 · 系统调用封装
// 统一对接不同OS的核心系统调用 — 跨平台基石
// Windows: WinAPI, Linux: syscall, macOS: Mach syscall

导入("../../运行时/原语桩.nova")
导入("../目标选择.nova")
导入("../../标准库/基础.nova")
导入("../../运行时/JIT/编译引擎.nova")

// 系统调用号 (Linux x86-64)
定义 系统调用_读     = 0
定义 系统调用_写    = 1
定义 系统调用_打开     = 2
定义 系统调用_关闭    = 3
定义 系统调用_内存映射     = 9
定义 系统调用_取消映射   = 11
定义 系统调用_内存保护 = 10
定义 系统调用_堆扩展      = 12
定义 系统调用_退出     = 60
定义 系统调用_取进程号   = 39
定义 系统调用_时钟    = 228
定义 系统调用_纳秒睡眠 = 35
定义 系统调用_分叉     = 57
定义 系统调用_执行   = 59

// Windows API 常量
定义 Windows_标准输出 = -11
定义 Windows_标准输入  = -10
定义 窗口_内存提交  = 0x1000
定义 窗口_内存保留 = 0x2000
定义 Windows_内存释放 = 0x8000
定义 Windows_页_读写     = 0x04
定义 Windows_页_读写执行    = 0x40

// 统一接口: 文件操作
函数 平台_打开文件(路径, 模式) {
    // 模式: 0=只读, 1=只写, 2=读写
    定义 目标 = 获取目标架构()
    如果 (目标 == "x86-64-win") {
        // Windows: CreateFileA
        返回 系统调用("CreateFileA", 路径, 模式, 0, 3)
    }
    // Linux: open syscall
    返回 系统调用_原生(系统调用_打开,  路径,  模式,  0644, 0 , 0)
}

函数 平台_读文件(句柄, 缓冲, 大小) {
    定义 目标 = 获取目标架构()
    如果 (目标 == "x86-64-win") {
        返回 系统调用("ReadFile",  句柄,  缓冲,  大小, 0)
    }
    返回 系统调用_原生(系统调用_读,  句柄,  缓冲,  大小, 0 , 0)
}

函数 平台_写文件(句柄, 数据, 大小) {
    定义 目标 = 获取目标架构()
    如果 (目标 == "x86-64-win") {
        返回 系统调用("WriteFile",  句柄,  数据,  大小, 0)
    }
    返回 系统调用_原生(系统调用_写,  句柄,  数据,  大小, 0 , 0)
}

函数 平台_关闭文件(句柄) {
    定义 目标 = 获取目标架构()
    如果 (目标 == "x86-64-win") {
        返回 系统调用("CloseHandle",  句柄, 0, 0, 0)
    }
    返回 系统调用_原生(系统调用_关闭,  句柄, 0 , 0 , 0, 0)
}

// 统一接口: 内存管理
函数 平台_分配内存(大小) {
    定义 目标 = 获取目标架构()
    如果 (目标 == "x86-64-win") {
        // Windows: VirtualAlloc
        返回 系统调用("VirtualAlloc", 0, 大小, 窗口_内存提交 | 窗口_内存保留, Windows_页_读写)
    }
    // Linux: mmap
    返回 系统调用_原生(系统调用_内存映射, 0, 大小, 3, 0x22, -1)
}

函数 平台_释放内存(地址, 大小) {
    定义 目标 = 获取目标架构()
    如果 (目标 == "x86-64-win") {
        返回 系统调用("VirtualFree",  地址,  0,  Windows_内存释放, 0)
    }
    返回 系统调用_原生(系统调用_取消映射,  地址,  大小, 0 , 0 , 0)
}

函数 平台_可执行内存(_地址, 大小) {
    // JIT需要: 分配可读写+可执行的内存
    定义 目标 = 获取目标架构()
    如果 (目标 == "x86-64-win") {
        返回 系统调用("VirtualAlloc", 0, 大小, 窗口_内存提交 | 窗口_内存保留, Windows_页_读写执行)
    }
    // Linux: mmap with 保护_读|保护_写|保护_执行
    返回 系统调用_原生(系统调用_内存映射, 0, 大小, 7, 0x22, -1)
}

// 统一接口: 进程控制
函数 平台_退出(代码) {
    定义 目标 = 获取目标架构()
    如果 (目标 == "x86-64-win") {
        返回 系统调用("ExitProcess",  代码, 0, 0, 0)
    }
    返回 系统调用_原生(系统调用_退出,  代码, 0 , 0 , 0, 0)
}

函数 平台_获取PID() {
    定义 目标 = 获取目标架构()
    如果 (目标 == "x86-64-win") {
        返回 系统调用("GetCurrentProcessId", 0, 0, 0, 0)
    }
    返回 系统调用_原生(系统调用_取进程号, 0 , 0 , 0 , 0, 0)
}

// 统一接口: 时间
函数 平台_毫秒时间() {
    定义 目标 = 获取目标架构()
    如果 (目标 == "x86-64-win") {
        返回 系统调用("GetTickCount64", 0, 0, 0, 0)
    }
    // Linux: clock_gettime
    返回 系统调用_原生(系统调用_时钟,  1, 0 , 0 , 0, 0)
}

函数 平台_睡眠(毫秒) {
    定义 目标 = 获取目标架构()
    如果 (目标 == "x86-64-win") {
        返回 系统调用("Sleep",  毫秒, 0, 0, 0)
    }
    // Linux: nanosleep
    定义 秒 = 毫秒 / 1000
    定义 纳秒 = (毫秒 % 1000) * 1000000
    返回 系统调用_原生(系统调用_纳秒睡眠,  [秒, 纳秒], 0 , 0 , 0, 0)
}

// 统一接口: 标准IO
函数 平台_输出(文本) {
    定义 目标 = 获取目标架构()
    如果 (目标 == "x86-64-win") {
        定义 句柄 = 系统调用("GetStdHandle",  Windows_标准输出, 0, 0, 0)
        返回 系统调用("WriteConsoleA",  句柄,  文本,  计数(文本), 0)
    }
    返回 系统调用_原生(系统调用_写,  1,  文本,  计数(文本), 0 , 0)
}

// RISC-V Linux系统调用号 (与x86-64不同)
// RISC-V使用统一的新编号方案(基于generic asm-unistd.h)
定义 RV_系统调用_读      = 63
定义 RV_系统调用_写     = 64
定义 RV_系统调用_打开位于    = 56    // RISC-V无open,用openat(当前工作目录描述符, ...)
定义 RV_系统调用_关闭     = 57
定义 RV_系统调用_内存映射      = 222
定义 RV_系统调用_解除映射    = 215
定义 RV_系统调用_MPROTECT  = 226
定义 RV_系统调用_堆断点       = 214
定义 RV_系统调用_退出      = 93
定义 RV_系统调用_GETPID    = 172
定义 RV_系统调用_CLOCK     = 113
定义 RV_系统调用_NANOSLEEP = 101
定义 RV_当前工作目录      = -100

// ARM64 Linux系统调用号 (同RISC-V,基于generic)
定义 ARM64_系统调用_读     = 63
定义 ARM64_系统调用_写    = 64
定义 ARM64_系统调用_打开AT   = 56
定义 ARM64_系统调用_关闭    = 57
定义 ARM64_系统调用_内存映射     = 222
定义 ARM64_系统调用_取消映射   = 215
定义 ARM64_系统调用_内存保护 = 226
定义 ARM64_系统调用_堆扩展      = 214
定义 ARM64_系统调用_退出     = 93
定义 ARM64_系统调用_取进程号   = 172
定义 ARM64_系统调用_时钟    = 113

// 系统调用号按架构查询
函数 syscall号_write(架构) {
    如果 (架构 == "riscv64") { 返回 RV_系统调用_写 }
    如果 (架构 == "arm64") { 返回 ARM64_系统调用_写 }
    返回 系统调用_写
}
函数 syscall号_read(架构) {
    如果 (架构 == "riscv64") { 返回 RV_系统调用_读 }
    如果 (架构 == "arm64") { 返回 ARM64_系统调用_读 }
    返回 系统调用_读
}
函数 syscall号_exit(架构) {
    如果 (架构 == "riscv64") { 返回 RV_系统调用_退出 }
    如果 (架构 == "arm64") { 返回 ARM64_系统调用_退出 }
    返回 系统调用_退出
}
函数 syscall号_mmap(架构) {
    如果 (架构 == "riscv64") { 返回 RV_系统调用_内存映射 }
    如果 (架构 == "arm64") { 返回 ARM64_系统调用_内存映射 }
    返回 系统调用_内存映射
}

// 底层系统调用原语 (JIT代码生成用)

// x86-64: syscall指令, rax=调用号, rdi/rsi/rdx/r10/r8/r9=参数
函数 平台_发射系统调用(jit, 调用号) {
    // mov rax, 调用号
    JIT_发射(jit, 0x48)
    JIT_发射(jit, 0xB8)
    JIT_发射64(jit, 调用号)
    // syscall
    JIT_发射(jit, 0x0F)
    JIT_发射(jit, 0x05)
}

// RISC-V: ecall指令, a7=调用号, a0-a5=参数, 返回值在a0
// ABI: a0-a5(x10-x15)=参数, a7(x17)=syscall号, ecall触发
函数 平台_发射系统调用_riscv(发射器, 调用号) {
    // li a7, 调用号 → addi x17, x0, 调用号
    发射器(0x13 | (17 << 7) | (0 << 15) | ((调用号 & 0xFFF) << 20))
    // ecall
    发射器(0x00000073)
}

// ARM64: svc #0指令, x8=调用号, x0-x5=参数, 返回值在x0
函数 平台_发射系统调用_arm64(发射器, 调用号) {
    // mov x8, #调用号 → movz x8, #调用号
    发射器(0xD2800000 | (8 & 31) | ((调用号 & 0xFFFF) << 5))
    // svc #0
    发射器(0xD4000001)
}

// 平台检测
定义 可变 _当前平台 = 0
定义 平台_WINDOWS = 1
定义 平台_LINUX = 2
定义 平台_MACOS = 3

函数 平台_设置(平台) { _当前平台 = 平台 }
函数 系统调用封装_平台_是Windows() { 返回 _当前平台 == 平台_WINDOWS }
函数 系统调用封装_平台_是Linux() { 返回 _当前平台 == 平台_LINUX }
函数 平台_名称() {
    如果 (_当前平台 == 平台_WINDOWS) { 返回 "Windows" }
    如果 (_当前平台 == 平台_LINUX) { 返回 "Linux" }
    如果 (_当前平台 == 平台_MACOS) { 返回 "macOS" }
    返回 "unknown"
}

定义 可变 _syscall_调用数 = 0
定义 可变 _syscall_失败数 = 0

函数 syscall_记录调用() { _syscall_调用数 = _syscall_调用数 + 1 }
函数 syscall_记录失败() { _syscall_失败数 = _syscall_失败数 + 1 }

// M15: Linux宿主绑定闭环
// 宿主上下文: [平台, 能力位图, pid, 启动时间, IO统计]
// 能力: 1=文件IO, 2=网络, 4=进程, 8=mmap, 16=时间
定义 可变 _宿主 = [0, 0, 0, [0,]]

函数 宿主_初始化() {
    _宿主[0] = 平台_LINUX
    _宿主[1] = 1 + 4 + 8 + 16  // 文件IO+进程+mmap+时间
    _宿主[2] = 系统调用_原生(39, 0 , 0 , 0 , 0, 0)  // getpid
    _宿主[3] = 平台_毫秒时间()
    _宿主[4] = [0,]  // [读字节, 写字节, 调用数]
}

函数 系统调用封装_宿主_有能力(能力) { 返回 (_宿主[1] & 能力) != 0 }

// 真实文件读取: open→read→close 完整闭环
函数 宿主_读文件(路径) {
    如果 (系统调用封装_宿主_有能力(1) == 假) { 返回 空 }
    定义 fd = 平台_打开文件(路径, 0)  // O_RDONLY
    如果 (fd < 0) { 返回 空 }
    定义 可变 内容 = ""
    定义 可变 buf = "                                                                "
    定义 可变 读了 = 平台_读文件(fd, buf, 64)
    当 (读了 > 0) {
        内容 = 字符串拼接(内容, 子串(buf, 0, 读了))
        _宿主[4][0] = _宿主[4][0] + 读了
        读了 = 平台_读文件(fd, buf, 64)
    }
    平台_关闭文件(fd)
    _宿主[4][2] = _宿主[4][2] + 3  // open+read+close
    返回 内容
}

// 真实文件写入
函数 宿主_写文件(路径, 内容) {
    如果 (系统调用封装_宿主_有能力(1) == 假) { 返回 假 }
    定义 fd = 平台_打开文件(路径, 1 + 0x40 + 0x200)  // O_WRONLY|O_CREAT|O_TRUNC
    如果 (fd < 0) { 返回 假 }
    定义 写了 = 平台_写文件(fd, 内容, 字节长度(内容))
    平台_关闭文件(fd)
    _宿主[4][1] = _宿主[4][1] + 写了
    _宿主[4][2] = _宿主[4][2] + 3
    返回 写了 > 0
}

// 运行时间(ms)
函数 宿主_运行时间() {
    返回 平台_毫秒时间() - _宿主[3]
}

// M15补全: Context Bundle (宿主上下文快照打包)
// 将当前宿主状态序列化为可传输的bundle
// bundle: [版本, 平台, 能力, pid, 启动时间, IO统计, 运行时间, 模块列表哈希, 时间戳]
函数 宿主_创建bundle() {
    返回 [1, _宿主[0], _宿主[1], _宿主[2], _宿主[3], _宿主[4], 宿主_运行时间(), 0, 平台_毫秒时间()]
}

函数 宿主_bundle_版本(b) { 返回 b[0] }
函数 宿主_bundle_平台(b) { 返回 b[1] }
函数 宿主_bundle_能力(b) { 返回 b[2] }
函数 宿主_bundle_运行时间(b) { 返回 b[6] }
函数 宿主_bundle_时间戳(b) { 返回 b[8] }

函数 宿主_bundle_有效(b) {
    如果 (b == 空 或 是列表(b) == 假 或 计数(b) < 9) { 返回 假 }
    如果 (b[0] != 1) { 返回 假 }
    返回 真
}

// M15补全: Patch Staging (模块热补丁暂存区)
// 暂存区: [[模块名, 旧哈希, 新目标码, 新哈希, 状态]]
// 状态: 0=暂存 1=已验证 2=已应用 3=已回滚
定义 可变 _patch_暂存 = []
定义 可变 _patch_计数 = 0

函数 patch_暂存(模块名, 旧哈希, 新目标码, 新哈希) {
    追加(_patch_暂存, [模块名, 旧哈希, 新目标码, 新哈希, 0])
    _patch_计数 = _patch_计数 + 1
    返回 _patch_计数 - 1
}

函数 patch_验证(索引) {
    如果 (索引 < 0 或 索引 >= 计数(_patch_暂存)) { 返回 假 }
    定义 p = _patch_暂存[索引]
    如果 (p[4] != 0) { 返回 假 }
    // 验证: 新目标码非空且新旧哈希不同
    如果 (p[2] == 空) { 返回 假 }
    如果 (p[1] == p[3]) { 返回 假 }
    p[4] = 1
    返回 真
}

函数 patch_应用(索引) {
    如果 (索引 < 0 或 索引 >= 计数(_patch_暂存)) { 返回 假 }
    定义 p = _patch_暂存[索引]
    如果 (p[4] != 1) { 返回 假 }
    p[4] = 2
    返回 真
}

函数 patch_回滚(索引) {
    如果 (索引 < 0 或 索引 >= 计数(_patch_暂存)) { 返回 假 }
    定义 p = _patch_暂存[索引]
    如果 (p[4] != 2) { 返回 假 }
    p[4] = 3
    返回 真
}

函数 patch_暂存数() { 返回 计数(_patch_暂存) }
函数 patch_待验证数() {
    定义 可变 n = 0
    定义 可变 i = 0
    当 (i < 计数(_patch_暂存)) {
        如果 (_patch_暂存[i][4] == 0) { n = n + 1 }
        i = i + 1
    }
    返回 n
}

函数 patch_已应用数() {
    定义 可变 n = 0
    定义 可变 i = 0
    当 (i < 计数(_patch_暂存)) {
        如果 (_patch_暂存[i][4] == 2) { n = n + 1 }
        i = i + 1
    }
    返回 n
}

// 宿主能力报告
函数 宿主_报告() {
    定义 可变 r = 字典()
    字典设(r, "平台", 平台_名称())
    字典设(r, "pid", 转字符串(_宿主[2]))
    字典设(r, "运行时间ms", 转字符串(宿主_运行时间()))
    字典设(r, "文件IO", 转字符串(系统调用封装_宿主_有能力(1)))
    字典设(r, "进程", 转字符串(系统调用封装_宿主_有能力(4)))
    字典设(r, "mmap", 转字符串(系统调用封装_宿主_有能力(8)))
    字典设(r, "时间", 转字符串(系统调用封装_宿主_有能力(16)))
    字典设(r, "读字节", 转字符串(_宿主[4][0]))
    字典设(r, "写字节", 转字符串(_宿主[4][1]))
    字典设(r, "syscall数", 转字符串(_宿主[4][2]))
    返回 r
}

// NovaOS ext4 文件截断·打开·关闭·同步·空间管理 — 完整生产级实现
// 功能: truncate/ftruncate/open/release/fsync/fallocate/hole_punch/lseek
// 关联: ext4超级块解析 → ext4范围树 → ext4块分配 → ext4日志系统 → VFS文件层

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("./扩展读超级块.nova")
导入("./文件文件.nova")
导入("../中枢/日志中枢.nova")
导入("./扩展扩展丙.nova")
导入("./扩展分配块.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/墙钟设置.nova")
导入("./扩展扩展乙.nova")
导入("./事务管理.nova")
导入("./扩展位图查找.nova")
导入("./块设备读.nova")
导入("./扩展删除目录.nova")
导入("../稳态/磁控驱动全局.nova")
导入("./扩展读块组描.nova")

// 第1部分: 常量定义

定义 EXT4_截断_批量大小       = 256
定义 EXT4_最大文件块数        = 0xFFFFFFFF
定义 EXT4_FALLOC_保留大小     = 0x01
定义 EXT4_FALLOC_打洞         = 0x02
定义 EXT4_FALLOC_折叠范围     = 0x08
定义 EXT4_FALLOC_零范围       = 0x10
定义 EXT4_FALLOC_插入范围     = 0x20
定义 SEEK_SET                 = 0
定义 SEEK_CUR                 = 1
定义 SEEK_END                 = 2
定义 SEEK_DATA                = 3
定义 SEEK_HOLE                = 4
定义 EXT4_文件节点_EXTENTS    = 0x00080000
定义 EXT4_预分配_最大块       = 64

// 第2部分: 统计计数器

结构 截断统计 {
    截断次数,
    截断释放块总数,
    截断扩展次数,
    截断收缩次数,
    截断错误次数,
    打开次数,
    打开拒绝次数,
    关闭次数,
    关闭刷写次数,
    fsync次数,
    fsync页面刷写数,
    fsync设备刷新次数,
    fallocate次数,
    打洞次数,
    预分配释放次数,
    预分配释放块总数,
    lseek次数,
    lseek_DATA次数,
    lseek_HOLE次数,
    日志事务包裹次数,
}

定义 可变 截断统计数据 = 截断统计 {}

// 第3部分: 辅助函数 — 块号计算与验证

函数 ext4_字节到块(块大小, 字节数) {
    如果 (块大小 == 0) { 返回 0 }
    返回 (字节数 + 块大小 - 1) / 块大小
}

函数 ext4_块到字节(块大小, 块数) {
    返回 块数 * 块大小
}

函数 ext4_验证截断参数(文件节点, 新大小) {
    如果 (文件节点 == 空) {
        返回 错误码_无效参数
    }
    如果 (新大小 < 0) {
        返回 错误码_无效参数
    }
    定义 sb = 文件节点.超级块
    如果 (sb == 空 || sb.私有信息 == 空) {
        返回 错误码_无效参数
    }
    定义 信息 = sb.私有信息
    如果 (信息.只读 == 真) {
        返回 错误码_只读文件系统
    }
    // 检查最大文件大小限制
    定义 最大大小 = ext4_块到字节(信息.块大小, EXT4_最大文件块数)
    如果 (新大小 > 最大大小) {
        返回 错误码_文件过大
    }
    返回 0
}

函数 ext4_是常规文件(文件节点) {
    如果 (文件节点 == 空) { 返回 假 }
    定义 模式 = 文件节点.模式
    返回 (模式 & 0xF000) == 0x8000
}

函数 ext4_获取ext4信息(文件节点) {
    如果 (文件节点 == 空) { 返回 空 }
    返回 文件节点.私有信息
}

// 第4部分: 核心截断实现 — ext4_截断

函数 ext4_截断(文件节点, 新大小) {
    定义 验证 = ext4_验证截断参数(文件节点, 新大小)
    如果 (验证 != 0) {
        截断统计数据.截断错误次数 = 截断统计数据.截断错误次数 + 1
        返回 验证
    }

    定义 sb = 文件节点.超级块
    定义 信息 = sb.私有信息
    定义 ext4信息 = ext4_获取ext4信息(文件节点)
    如果 (ext4信息 == 空) {
        截断统计数据.截断错误次数 = 截断统计数据.截断错误次数 + 1
        返回 错误码_无效参数
    }
    定义 块大小 = 信息.块大小
    定义 旧大小 = 文件节点.大小

    截断统计数据.截断次数 = 截断统计数据.截断次数 + 1

    如果 (新大小 == 旧大小) {
        返回 0
    }

    定义 事务 = journal_开始事务()
    如果 (事务 == 空) {
        打印("[ext4截断] 警告: 无法开启日志事务, 继续非日志模式")
    }
    截断统计数据.日志事务包裹次数 = 截断统计数据.日志事务包裹次数 + 1

    定义 可变 结果 = 0

    如果 (新大小 > 旧大小) {
        结果 = ext4_截断_扩展(文件节点, ext4信息, 旧大小, 新大小, 块大小)
        截断统计数据.截断扩展次数 = 截断统计数据.截断扩展次数 + 1
    } 否则 {
        结果 = ext4_截断_收缩(文件节点, sb, 信息, ext4信息, 旧大小, 新大小, 块大小, 事务)
        截断统计数据.截断收缩次数 = 截断统计数据.截断收缩次数 + 1
    }

    如果 (结果 == 0) {
        文件节点.大小 = 新大小
        文件节点.修改时间 = 当前时间_秒()
        文件节点.变更时间 = 当前时间_秒()
        ext4信息.已脏 = 真

        // 记录文件节点修改到日志
        如果 (事务 != 空) {
            journal_记录修改(事务, 文件节点.编号, 文件节点)
        }
    }

    如果 (事务 != 空) {
        如果 (结果 == 0) {
            journal_提交事务(事务)
        } 否则 {
            journal_回滚事务(事务)
        }
    }

    如果 (结果 != 0) {
        截断统计数据.截断错误次数 = 截断统计数据.截断错误次数 + 1
    }
    返回 结果
}

// 第4.1部分: 截断扩展(创建空洞)

函数 ext4_截断_扩展(文件节点, ext4信息, 旧大小, 新大小, 块大小) {
    // 扩展不分配新块,只更新大小(空洞区域读取时返回零)
    // 但需要处理最后一个部分块的零填充
    定义 旧尾偏移 = 旧大小 % 块大小
    如果 (旧尾偏移 != 0) {
        // 旧文件末尾不在块边界上,需要对最后一个块的剩余部分清零
        定义 旧末块 = 旧大小 / 块大小
        定义 sb = 文件节点.超级块
        定义 物理块 = ext4_extent_查找(sb, ext4信息, 旧末块)
        如果 (物理块 != (0 - 1)) {
            定义 信息 = sb.私有信息
            定义 块数据 = 块设备_读(sb.设备, 物理块 * 信息.块大小, 信息.块大小)
            如果 (块数据 != 空) {
                // 清零从旧尾偏移到块末尾
                定义 可变 偏移 = 旧尾偏移
                当 (偏移 < 块大小) {
                    缓冲写(块数据, 偏移, 0)
                    偏移 = 偏移 + 1
                }
                块设备_写(sb.设备, 物理块 * 信息.块大小, 块数据, 信息.块大小)
            }
        }
    }
    返回 0
}

// 第4.2部分: 截断收缩(批量释放块)

函数 ext4_截断_收缩(文件节点, sb, 信息, ext4信息, 旧大小, 新大小, 块大小, 事务) {
    定义 新块数 = ext4_字节到块(块大小, 新大小)
    定义 旧块数 = ext4_字节到块(块大小, 旧大小)

    如果 (新块数 >= 旧块数) {
        // 只需要清零最后一块的尾部
        ext4_截断_清零尾部(文件节点, sb, ext4信息, 新大小, 块大小)
        返回 0
    }

    页面缓存_截断(文件节点, 新大小)

    定义 可变 当前块 = 新块数
    定义 可变 释放总数 = 0
    定义 可变 批次 = 0

    当 (当前块 < 旧块数) {
        // 计算本批次要处理的块数(最多EXT4_截断_批量大小个)
        定义 剩余 = 旧块数 - 当前块
        定义 本批数量 = 剩余
        如果 (本批数量 > EXT4_截断_批量大小) {
            本批数量 = EXT4_截断_批量大小
        }

        // 查找这个范围内的extent并释放
        定义 释放数 = ext4_截断_释放范围(sb, 信息, ext4信息, 当前块, 本批数量, 事务)
        如果 (释放数 > 0) {
            释放总数 = 释放总数 + 释放数
        }

        当前块 = 当前块 + 本批数量
        批次 = 批次 + 1

        // 每处理一批检查是否需要中间提交日志(防止事务过大)
        如果 (批次 % 4 == 0 && 事务 != 空) {
            如果 (事务.修改块数 > 128) {
                journal_提交事务(事务)
                事务 = journal_开始事务()
            }
        }
    }

    ext4_截断_清零尾部(文件节点, sb, ext4信息, 新大小, 块大小)

    截断统计数据.截断释放块总数 = 截断统计数据.截断释放块总数 + 释放总数
    打印(字符串拼接("[ext4截断] 收缩完成: 释放", 转字符串(释放总数)))
    返回 0
}

// 第4.3部分: 释放指定范围的extent块

函数 ext4_截断_释放范围(sb, 信息, ext4信息, 起始逻辑块, 块数, 事务) {
    定义 可变 释放计数 = 0
    定义 可变 当前 = 起始逻辑块

    当 (当前 < 起始逻辑块 + 块数) {
        // 在extent树中查找当前逻辑块对应的物理块
        定义 物理块 = ext4_extent_查找(sb, ext4信息, 当前)

        如果 (物理块 != (0 - 1) && 物理块 != 0) {
            // 尝试合并连续的物理块一起释放
            定义 可变 连续数 = 1
            定义 可变 下一个 = 当前 + 1
            当 (下一个 < 起始逻辑块 + 块数 && 连续数 < 64) {
                定义 下一物理 = ext4_extent_查找(sb, ext4信息, 下一个)
                如果 (下一物理 == 物理块 + 连续数) {
                    连续数 = 连续数 + 1
                    下一个 = 下一个 + 1
                } 否则 {
                    止
                }
            }

            // 批量释放连续物理块
            ext4_释放块(sb, 物理块, 连续数)

            // 从extent树中删除
            ext4_extent_删除(sb, ext4信息, 当前, 连续数)

            // 记录到日志
            如果 (事务 != 空) {
                journal_记录修改(事务, 物理块, 空)
            }

            释放计数 = 释放计数 + 连续数
            当前 = 当前 + 连续数
        } 否则 {
            // 空洞区域,跳过
            当前 = 当前 + 1
        }
    }
    返回 释放计数
}

// 第4.4部分: 清零截断后新末尾块的尾部字节

函数 ext4_截断_清零尾部(文件节点, sb, ext4信息, 新大小, 块大小) {
    定义 尾偏移 = 新大小 % 块大小
    如果 (尾偏移 == 0) { 返回 0 }

    定义 末块 = 新大小 / 块大小
    定义 信息 = sb.私有信息
    定义 物理块 = ext4_extent_查找(sb, ext4信息, 末块)
    如果 (物理块 == (0 - 1) || 物理块 == 0) { 返回 0 }

    定义 块数据 = 块设备_读(sb.设备, 物理块 * 信息.块大小, 信息.块大小)
    如果 (块数据 == 空) { 返回 错误码_IO }

    // 将尾偏移到块末尾的区域清零
    定义 可变 i = 尾偏移
    当 (i < 块大小) {
        缓冲写(块数据, i, 0)
        i = i + 1
    }
    块设备_写(sb.设备, 物理块 * 信息.块大小, 块数据, 信息.块大小)

    // 更新页面缓存中该页
    页面缓存_更新(文件节点, 末块, 块数据)
    返回 0
}

// 第5部分: 文件打开 — ext4_打开

函数 ext4_打开(文件节点, 文件) {
    截断统计数据.打开次数 = 截断统计数据.打开次数 + 1

    如果 (文件节点 == 空) {
        截断统计数据.打开拒绝次数 = 截断统计数据.打开拒绝次数 + 1
        返回 错误码_无效参数
    }

    如果 (文件节点.链接数 == 0) {
        截断统计数据.打开拒绝次数 = 截断统计数据.打开拒绝次数 + 1
        返回 错误码_不存在
    }

    定义 sb = 文件节点.超级块
    如果 (sb == 空 || sb.私有信息 == 空) {
        截断统计数据.打开拒绝次数 = 截断统计数据.打开拒绝次数 + 1
        返回 错误码_无效参数
    }

    定义 信息 = sb.私有信息
    // 检查文件系统是否有错误标记
    如果 (信息.状态 & 0x0002 != 0) {
        打印("[ext4打开] 警告: 文件系统有错误标记")
    }

    如果 (文件 != 空 && 文件.标志 & 0x0200 != 0) {
        // O_DIRECTORY标志,验证是否为目录
        如果 ((文件节点.模式 & 0xF000) != 0x4000) {
            截断统计数据.打开拒绝次数 = 截断统计数据.打开拒绝次数 + 1
            返回 错误码_不是目录
        }
    }

    如果 (文件 != 空 && 文件.标志 & 0x0200 != 0) {
        如果 (ext4_是常规文件(文件节点)) {
            定义 截断结果 = ext4_截断(文件节点, 0)
            如果 (截断结果 != 0) {
                返回 截断结果
            }
        }
    }

    返回 0
}

// 第6部分: 文件关闭 — ext4_释放

函数 ext4_释放(文件节点, 文件) {
    截断统计数据.关闭次数 = 截断统计数据.关闭次数 + 1

    如果 (文件节点 == 空) { 返回 0 }

    定义 ext4信息 = ext4_获取ext4信息(文件节点)
    如果 (ext4信息 == 空) { 返回 0 }

    如果 (文件节点.脏页数 > 0) {
        截断统计数据.关闭刷写次数 = 截断统计数据.关闭刷写次数 + 1
        页面缓存_同步范围(文件节点, 0, 文件节点.大小)
    }

    如果 (ext4信息.预分配块数 > 0) {
        ext4_释放预分配块(文件节点)
        截断统计数据.预分配释放次数 = 截断统计数据.预分配释放次数 + 1
        截断统计数据.预分配释放块总数 = 截断统计数据.预分配释放块总数 + ext4信息.预分配块数
    }

    如果 (文件节点.链接数 == 0 && ext4信息.已脏) {
        ext4_截断(文件节点, 0)
        ext4_释放文件节点号(文件节点.超级块, 文件节点.编号)
    }

    返回 0
}

// 第6.1部分: 释放预分配块

函数 ext4_释放预分配块(文件节点) {
    定义 ext4信息 = ext4_获取ext4信息(文件节点)
    如果 (ext4信息 == 空 || ext4信息.预分配块数 == 0) { 返回 }

    定义 sb = 文件节点.超级块
    定义 起始块 = ext4信息.预分配起始块
    定义 块数 = ext4信息.预分配块数

    如果 (起始块 > 0 && 块数 > 0) {
        ext4_释放块(sb, 起始块, 块数)
        打印(字符串拼接("[ext4] 释放预分配块: ", 转字符串(块数)))
    }

    ext4信息.预分配起始块 = 0
    ext4信息.预分配块数 = 0
}

// 第7部分: 数据同步 — ext4_fsync

函数 ext4_fsync(文件, 起始, 结束, 数据同步) {
    截断统计数据.fsync次数 = 截断统计数据.fsync次数 + 1

    如果 (文件 == 空 || 文件.文件节点 == 空) {
        返回 错误码_无效参数
    }

    定义 文件节点 = 文件.文件节点
    定义 sb = 文件节点.超级块
    定义 ext4信息 = ext4_获取ext4信息(文件节点)
    如果 (ext4信息 == 空) { 返回 错误码_无效参数 }

    定义 同步起始 = 起始
    定义 同步结束 = 结束
    如果 (同步结束 == 0 || 同步结束 > 文件节点.大小) {
        同步结束 = 文件节点.大小
    }

    定义 刷写页数 = 页面缓存_同步范围(文件节点, 同步起始, 同步结束)
    截断统计数据.fsync页面刷写数 = 截断统计数据.fsync页面刷写数 + 刷写页数

    如果 (ext4信息.已脏) {
        定义 写回结果 = ext4_写文件节点(sb, 文件节点)
        如果 (写回结果 != 0) {
            打印("[ext4fsync] 错误: 文件节点写回失败")
            返回 写回结果
        }
        ext4信息.已脏 = 假
    }

    如果 (sb.私有信息 != 空) {
        定义 信息 = sb.私有信息
        如果 (信息.日志 != 空) {
            journal_强制提交(信息.日志)
        }
    }

    如果 (!数据同步 || ext4信息.已脏) {
        块设备_刷新(sb.设备)
        截断统计数据.fsync设备刷新次数 = 截断统计数据.fsync设备刷新次数 + 1
    }

    返回 0
}

// 第8部分: 空间预分配 — ext4_fallocate

函数 ext4_fallocate(文件, 模式, 偏移, 长度) {
    截断统计数据.fallocate次数 = 截断统计数据.fallocate次数 + 1

    如果 (文件 == 空 || 文件.文件节点 == 空) {
        返回 错误码_无效参数
    }

    定义 文件节点 = 文件.文件节点
    如果 (!ext4_是常规文件(文件节点)) {
        返回 错误码_不支持
    }

    如果 (模式 & EXT4_FALLOC_打洞 != 0) {
        返回 ext4_打洞(文件节点, 偏移, 长度)
    }
    如果 (模式 & EXT4_FALLOC_零范围 != 0) {
        返回 ext4_零填充范围(文件节点, 偏移, 长度)
    }
    如果 (模式 & EXT4_FALLOC_折叠范围 != 0) {
        返回 ext4_折叠范围(文件节点, 偏移, 长度)
    }

    返回 ext4_预分配空间(文件节点, 偏移, 长度, 模式)
}

// 第8.1部分: 打洞(hole punch)

函数 ext4_打洞(文件节点, 偏移, 长度) {
    截断统计数据.打洞次数 = 截断统计数据.打洞次数 + 1

    定义 sb = 文件节点.超级块
    定义 信息 = sb.私有信息
    定义 ext4信息 = ext4_获取ext4信息(文件节点)
    如果 (ext4信息 == 空) { 返回 错误码_无效参数 }
    定义 块大小 = 信息.块大小

    // 计算要打洞的块范围(只处理完整块)
    定义 起始块 = (偏移 + 块大小 - 1) / 块大小
    定义 结束字节 = 偏移 + 长度
    定义 结束块 = 结束字节 / 块大小

    如果 (起始块 >= 结束块) { 返回 0 }

    // 开启日志事务
    定义 事务 = journal_开始事务()

    // 释放范围内的所有块
    定义 释放数 = ext4_截断_释放范围(sb, 信息, ext4信息, 起始块, 结束块 - 起始块, 事务)

    // 清除页面缓存中该范围
    页面缓存_失效范围(文件节点, 起始块 * 块大小, 结束块 * 块大小)

    // 处理首尾部分块的零填充
    如果 (偏移 % 块大小 != 0) {
        ext4_部分块清零(文件节点, sb, ext4信息, 偏移 / 块大小, 偏移 % 块大小, 块大小)
    }
    如果 (结束字节 % 块大小 != 0) {
        ext4_部分块清零_头部(文件节点, sb, ext4信息, 结束字节 / 块大小, 结束字节 % 块大小, 块大小)
    }

    文件节点.变更时间 = 当前时间_秒()
    ext4信息.已脏 = 真

    如果 (事务 != 空) { journal_提交事务(事务) }

    返回 0
}

// 第8.2部分: 部分块清零辅助

函数 ext4_部分块清零(文件节点, sb, ext4信息, 逻辑块, 起始偏移, 块大小) {
    定义 物理块 = ext4_extent_查找(sb, ext4信息, 逻辑块)
    如果 (物理块 == (0 - 1)) { 返回 }

    定义 信息 = sb.私有信息
    定义 数据 = 块设备_读(sb.设备, 物理块 * 信息.块大小, 信息.块大小)
    如果 (数据 == 空) { 返回 }

    定义 可变 i = 起始偏移
    当 (i < 块大小) {
        缓冲写(数据, i, 0)
        i = i + 1
    }
    块设备_写(sb.设备, 物理块 * 信息.块大小, 数据, 信息.块大小)
}

函数 ext4_部分块清零_头部(文件节点, sb, ext4信息, 逻辑块, 结束偏移, 块大小) {
    定义 物理块 = ext4_extent_查找(sb, ext4信息, 逻辑块)
    如果 (物理块 == (0 - 1)) { 返回 }

    定义 信息 = sb.私有信息
    定义 数据 = 块设备_读(sb.设备, 物理块 * 信息.块大小, 信息.块大小)
    如果 (数据 == 空) { 返回 }

    定义 可变 i = 0
    当 (i < 结束偏移) {
        缓冲写(数据, i, 0)
        i = i + 1
    }
    块设备_写(sb.设备, 物理块 * 信息.块大小, 数据, 信息.块大小)
}

// 第8.3部分: 预分配空间

函数 ext4_预分配空间(文件节点, 偏移, 长度, 模式) {
    定义 sb = 文件节点.超级块
    定义 信息 = sb.私有信息
    定义 ext4信息 = ext4_获取ext4信息(文件节点)
    如果 (ext4信息 == 空) { 返回 错误码_无效参数 }
    定义 块大小 = 信息.块大小

    定义 起始块 = 偏移 / 块大小
    定义 结束块 = ext4_字节到块(块大小, 偏移 + 长度)
    定义 需要块数 = 结束块 - 起始块

    // 逐块检查,为空洞分配块
    定义 可变 已分配 = 0
    定义 可变 当前 = 起始块
    当 (当前 < 结束块) {
        定义 物理块 = ext4_extent_查找(sb, ext4信息, 当前)
        如果 (物理块 == (0 - 1) || 物理块 == 0) {
            // 空洞,需要分配
            定义 请求 = Ext4分配请求 {}
            请求.文件节点号 = 文件节点.编号
            请求.逻辑块 = 当前
            请求.请求块数 = 1
            请求.标志 = EXT4_MB_标志_正常

            定义 结果 = ext4_分配块(sb, 请求)
            如果 (!是错误(结果)) {
                // 插入extent树
                ext4_extent_插入(sb, ext4信息, 当前, 结果.起始块, 1)
                // 新块清零
                定义 零块 = 创建缓冲(块大小)
                块设备_写(sb.设备, 结果.起始块 * 块大小, 零块, 块大小)
                已分配 = 已分配 + 1
            }
        }
        当前 = 当前 + 1
    }

    // 如果不保留大小,更新文件大小
    如果 (模式 & EXT4_FALLOC_保留大小 == 0) {
        如果 (偏移 + 长度 > 文件节点.大小) {
            文件节点.大小 = 偏移 + 长度
        }
    }
    ext4信息.已脏 = 真
    返回 0
}

函数 ext4_零填充范围(文件节点, 偏移, 长度) {
    // 先打洞再预分配(实现零填充效果)
    定义 结果1 = ext4_打洞(文件节点, 偏移, 长度)
    如果 (结果1 != 0) { 返回 结果1 }
    返回 ext4_预分配空间(文件节点, 偏移, 长度, EXT4_FALLOC_保留大小)
}

函数 ext4_折叠范围(文件节点, 偏移, 长度) {
    // 当前实现先打洞，再由上层决定是否迁移后续 extent
    打印("[ext4] 折叠范围: 暂不支持完整实现")
    返回 错误码_不支持
}

// 第9部分: lseek — 含SEEK_DATA/SEEK_HOLE

函数 ext4_lseek(文件, 偏移, 起点) {
    截断统计数据.lseek次数 = 截断统计数据.lseek次数 + 1

    如果 (文件 == 空 || 文件.文件节点 == 空) {
        返回 错误码_无效参数
    }

    定义 文件节点 = 文件.文件节点
    定义 可变 新位置 = 0

    匹配 起点 {
        0: { 新位置 = 偏移 }
        1: { 新位置 = 文件.偏移 + 偏移 }
        2: { 新位置 = 文件节点.大小 + 偏移 }
        3: {
            // SEEK_DATA: 查找偏移位置之后的第一个数据块
            截断统计数据.lseek_DATA次数 = 截断统计数据.lseek_DATA次数 + 1
            新位置 = ext4_seek_data(文件节点, 偏移)
            如果 (新位置 < 0) { 返回 错误码_无数据 }
        }
        4: {
            // SEEK_HOLE: 查找偏移位置之后的第一个空洞
            截断统计数据.lseek_HOLE次数 = 截断统计数据.lseek_HOLE次数 + 1
            新位置 = ext4_seek_hole(文件节点, 偏移)
            如果 (新位置 < 0) { 返回 错误码_无数据 }
        }
    }

    如果 (新位置 < 0) { 返回 错误码_无效参数 }
    文件.偏移 = 新位置
    返回 新位置
}

// 第9.1部分: SEEK_DATA / SEEK_HOLE 实现

函数 ext4_seek_data(文件节点, 偏移) {
    定义 sb = 文件节点.超级块
    定义 ext4信息 = ext4_获取ext4信息(文件节点)
    如果 (ext4信息 == 空) { 返回 -1 }
    定义 块大小 = sb.私有信息.块大小
    定义 文件块数 = ext4_字节到块(块大小, 文件节点.大小)

    定义 可变 当前块 = 偏移 / 块大小
    当 (当前块 < 文件块数) {
        定义 物理块 = ext4_extent_查找(sb, ext4信息, 当前块)
        如果 (物理块 != (0 - 1) && 物理块 != 0) {
            // 找到数据块
            定义 结果偏移 = 当前块 * 块大小
            如果 (结果偏移 < 偏移) { 返回 偏移 }
            返回 结果偏移
        }
        当前块 = 当前块 + 1
    }
    返回 -1
}

函数 ext4_seek_hole(文件节点, 偏移) {
    定义 sb = 文件节点.超级块
    定义 ext4信息 = ext4_获取ext4信息(文件节点)
    如果 (ext4信息 == 空) { 返回 -1 }
    定义 块大小 = sb.私有信息.块大小
    定义 文件块数 = ext4_字节到块(块大小, 文件节点.大小)

    定义 可变 当前块 = 偏移 / 块大小
    当 (当前块 < 文件块数) {
        定义 物理块 = ext4_extent_查找(sb, ext4信息, 当前块)
        如果 (物理块 == (0 - 1) || 物理块 == 0) {
            // 找到空洞
            定义 结果偏移 = 当前块 * 块大小
            如果 (结果偏移 < 偏移) { 返回 偏移 }
            返回 结果偏移
        }
        当前块 = 当前块 + 1
    }
    // 文件末尾就是空洞
    返回 文件节点.大小
}

// 第10部分: 统计输出与接口注册

函数 ext4_截断_打印统计() {
    打印("[ext4截断] ═══ 统计信息 ═══")
    打印(字符串拼接("  截断总次数:       ", 转字符串(截断统计数据.截断次数)))
    打印(字符串拼接("  截断扩展次数:     ", 转字符串(截断统计数据.截断扩展次数)))
    打印(字符串拼接("  截断收缩次数:     ", 转字符串(截断统计数据.截断收缩次数)))
    打印(字符串拼接("  释放块总数:       ", 转字符串(截断统计数据.截断释放块总数)))
    打印(字符串拼接("  截断错误次数:     ", 转字符串(截断统计数据.截断错误次数)))
    打印(字符串拼接("  打开次数:         ", 转字符串(截断统计数据.打开次数)))
    打印(字符串拼接("  打开拒绝次数:     ", 转字符串(截断统计数据.打开拒绝次数)))
    打印(字符串拼接("  关闭次数:         ", 转字符串(截断统计数据.关闭次数)))
    打印(字符串拼接("  关闭刷写次数:     ", 转字符串(截断统计数据.关闭刷写次数)))
    打印(字符串拼接("  fsync次数:        ", 转字符串(截断统计数据.fsync次数)))
    打印(字符串拼接("  fsync页面刷写:    ", 转字符串(截断统计数据.fsync页面刷写数)))
    打印(字符串拼接("  fsync设备刷新:    ", 转字符串(截断统计数据.fsync设备刷新次数)))
    打印(字符串拼接("  fallocate次数:    ", 转字符串(截断统计数据.fallocate次数)))
    打印(字符串拼接("  打洞次数:         ", 转字符串(截断统计数据.打洞次数)))
    打印(字符串拼接("  预分配释放次数:   ", 转字符串(截断统计数据.预分配释放次数)))
    打印(字符串拼接("  预分配释放块数:   ", 转字符串(截断统计数据.预分配释放块总数)))
    打印(字符串拼接("  lseek次数:        ", 转字符串(截断统计数据.lseek次数)))
    打印(字符串拼接("  SEEK_DATA次数:    ", 转字符串(截断统计数据.lseek_DATA次数)))
    打印(字符串拼接("  SEEK_HOLE次数:    ", 转字符串(截断统计数据.lseek_HOLE次数)))
    打印(字符串拼接("  日志事务包裹次数: ", 转字符串(截断统计数据.日志事务包裹次数)))
    返回 0
}

函数 ext4_截断_获取统计() {
    返回 截断统计数据
}

函数 ext4_截断_重置统计() {
    截断统计数据 = 截断统计 {}
    返回 0
}

函数 ext4_获取文件操作表_截断() {
    返回 {
        截断: ext4_截断,
        打开: ext4_打开,
        释放: ext4_释放,
        fsync: ext4_fsync,
        fallocate: ext4_fallocate,
        lseek: ext4_lseek
    }
}

定义 可变 AI_扩展截断_运行指标 = 0
定义 可变 AI_扩展截断_异常指标 = 0

函数 AI_扩展截断_自诊断() {
    AI_扩展截断_运行指标 = 截断统计数据
    返回 AI_扩展截断_运行指标
}

函数 AI_扩展截断_优化建议() {
    定义 指标 = AI_扩展截断_自诊断()
    如果 (AI_扩展截断_运行指标 > 10000) { 返回 "扩展截断负载较高" }
    返回 "扩展截断状态正常"
}

函数 扩展截断_统计() {
    返回 {
        模块: "扩展截断",
        截断统计数据: 截断统计数据,
        AI_扩展截断_运行指标: AI_扩展截断_运行指标,
        AI_扩展截断_异常指标: AI_扩展截断_异常指标
    }
}

函数 扩展截断_健康评估() {
    定义 可变 问题 = []
    如果 (截断统计数据 > 100000) { 追加(问题, "截断统计数据异常增长") }
    返回 计数(问题) == 0
}

函数 扩展截断_综合报告() {
    打印("[扩展截断] ═══ 综合报告 ═══")
    打印("  截断统计数据: " + 如果 (截断统计数据 != 空) { "已初始化" } 否则 { "未初始化" })
    打印("  AI_扩展截断_运行指标: " + 整数转字符串(AI_扩展截断_运行指标))
    打印("  AI_扩展截断_异常指标: " + 整数转字符串(AI_扩展截断_异常指标))
    打印("  健康: " + 如果 (扩展截断_健康评估()) { "正常" } 否则 { "异常" })
}

函数 扩展截断_全局重置() {
    AI_扩展截断_运行指标 = 0
    AI_扩展截断_异常指标 = 0
    打印("[扩展截断] 全局统计已重置")
    返回 0
}

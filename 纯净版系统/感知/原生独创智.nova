// 传统浏览器没有此功能——它们不理解页面含义
// Nova在DOM构建时自动推断每个节点的语义角色

函数 节点_AI语义分析_启发式(节点) {
    // 策略一: 标签名直接映射(高置信度) — 不需要神经网络
    如果 (节点 == 0) { 返回 }
    如果 (节点.节点标志 & 节点标志_AI已分析) { 返回 }

    如果 (节点.节点标志 & 节点标志_是元素) {
        定义 扩展 = 元素_获取扩展(节点)
        如果 (扩展 != 0) {
            定义 标签 = 扩展.标签名原子
            // HTML5语义标签直接映射(置信度=9800)
            如果 (字符串_相等(标签, "nav"))     { 节点.语义角色 = 语义_导航栏; 节点.语义置信度 = 9800 }
            否则 如果 (字符串_相等(标签, "header"))  { 节点.语义角色 = 语义_页头; 节点.语义置信度 = 9800 }
            否则 如果 (字符串_相等(标签, "footer"))  { 节点.语义角色 = 语义_页脚; 节点.语义置信度 = 9800 }
            否则 如果 (字符串_相等(标签, "main"))    { 节点.语义角色 = 语义_正文; 节点.语义置信度 = 9800 }
            否则 如果 (字符串_相等(标签, "article")) { 节点.语义角色 = 语义_正文; 节点.语义置信度 = 9500 }
            否则 如果 (字符串_相等(标签, "aside"))   { 节点.语义角色 = 语义_侧边栏; 节点.语义置信度 = 9800 }
            否则 如果 (字符串_相等(标签, "form"))    { 节点.语义角色 = 语义_表单; 节点.语义置信度 = 9800 }
            否则 如果 (字符串_相等(标签, "button"))  { 节点.语义角色 = 语义_按钮; 节点.语义置信度 = 9800 }
            否则 如果 (字符串_相等(标签, "a"))       { 节点.语义角色 = 语义_链接; 节点.语义置信度 = 9500 }
            否则 如果 (字符串_相等(标签, "img"))     { 节点.语义角色 = 语义_图片; 节点.语义置信度 = 9800 }
            否则 如果 (字符串_相等(标签, "video"))   { 节点.语义角色 = 语义_视频; 节点.语义置信度 = 9800 }
            否则 如果 (字符串_相等(标签, "code"))    { 节点.语义角色 = 语义_代码; 节点.语义置信度 = 9500 }
            否则 如果 (字符串_相等(标签, "pre"))     { 节点.语义角色 = 语义_代码; 节点.语义置信度 = 8000 }
            否则 如果 (字符串_相等(标签, "blockquote")) { 节点.语义角色 = 语义_引用; 节点.语义置信度 = 9500 }
            否则 如果 (字符串_相等(标签, "dialog"))  { 节点.语义角色 = 语义_弹窗; 节点.语义置信度 = 9800 }
            否则 如果 (字符串_开头匹配(标签, "h")) { 节点.语义角色 = 语义_标题; 节点.语义置信度 = 9800 }
            否则 如果 (字符串_相等(标签, "p"))       { 节点.语义角色 = 语义_段落; 节点.语义置信度 = 9000 }
            否则 如果 (字符串_相等(标签, "ul") || 字符串_相等(标签, "ol")) { 节点.语义角色 = 语义_列表; 节点.语义置信度 = 9000 }
            否则 {
                // 策略二: 启发式推断(中置信度)
                节点_AI启发推断(节点, 扩展)
            }
        }
    }

    // 标记已分析
    节点.节点标志 = 节点.节点标志 | 节点标志_AI已分析

    // 递归分析子节点
    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        节点_AI语义分析_启发式(子)
        子 = 子.后一兄弟
    }
}

函数 节点_AI启发推断(节点, 扩展) {
    如果 (扩展 == 0) { 返回 }

    // ARIA role属性直接映射(置信度=9000)
    定义 role = 元素_获取属性(节点, "role")
    如果 (role != 0) {
        如果 (字符串_相等(role, "navigation"))  { 节点.语义角色 = 语义_导航栏; 节点.语义置信度 = 9000; 返回 }
        如果 (字符串_相等(role, "banner"))      { 节点.语义角色 = 语义_页头; 节点.语义置信度 = 9000; 返回 }
        如果 (字符串_相等(role, "main"))        { 节点.语义角色 = 语义_正文; 节点.语义置信度 = 9000; 返回 }
        如果 (字符串_相等(role, "complementary")) { 节点.语义角色 = 语义_侧边栏; 节点.语义置信度 = 9000; 返回 }
        如果 (字符串_相等(role, "contentinfo"))  { 节点.语义角色 = 语义_页脚; 节点.语义置信度 = 9000; 返回 }
        如果 (字符串_相等(role, "search"))      { 节点.语义角色 = 语义_搜索框; 节点.语义置信度 = 9000; 返回 }
        如果 (字符串_相等(role, "dialog"))      { 节点.语义角色 = 语义_弹窗; 节点.语义置信度 = 9000; 返回 }
        如果 (字符串_相等(role, "button"))      { 节点.语义角色 = 语义_按钮; 节点.语义置信度 = 9000; 返回 }
        如果 (字符串_相等(role, "tab"))         { 节点.语义角色 = 语义_标签页; 节点.语义置信度 = 9000; 返回 }
    }

    // class/id启发词探测(置信度=6000-7500)
    定义 class名 = 元素_获取属性(节点, "class")
    如果 (class名 != 0) {
        如果 (字符串_包含(class名, "nav") || 字符串_包含(class名, "menu")) {
            节点.语义角色 = 语义_导航栏; 节点.语义置信度 = 7000; 返回
        }
        如果 (字符串_包含(class名, "ad") || 字符串_包含(class名, "banner") || 字符串_包含(class名, "sponsor")) {
            节点.语义角色 = 语义_广告; 节点.语义置信度 = 7500; 返回
        }
        如果 (字符串_包含(class名, "comment")) {
            节点.语义角色 = 语义_评论区; 节点.语义置信度 = 7000; 返回
        }
        如果 (字符串_包含(class名, "card")) {
            节点.语义角色 = 语义_卡片; 节点.语义置信度 = 6500; 返回
        }
        如果 (字符串_包含(class名, "carousel") || 字符串_包含(class名, "slider")) {
            节点.语义角色 = 语义_轮播; 节点.语义置信度 = 7000; 返回
        }
        如果 (字符串_包含(class名, "modal") || 字符串_包含(class名, "popup") || 字符串_包含(class名, "overlay")) {
            节点.语义角色 = 语义_弹窗; 节点.语义置信度 = 7500; 返回
        }
        如果 (字符串_包含(class名, "cookie") || 字符串_包含(class名, "consent")) {
            节点.语义角色 = 语义_Cookie同意; 节点.语义置信度 = 8000; 返回
        }
        如果 (字符串_包含(class名, "search")) {
            节点.语义角色 = 语义_搜索框; 节点.语义置信度 = 6500; 返回
        }
        如果 (字符串_包含(class名, "breadcrumb")) {
            节点.语义角色 = 语义_面包屑; 节点.语义置信度 = 7500; 返回
        }
        如果 (字符串_包含(class名, "tab")) {
            节点.语义角色 = 语义_标签页; 节点.语义置信度 = 6500; 返回
        }
        如果 (字符串_包含(class名, "loading") || 字符串_包含(class名, "spinner")) {
            节点.语义角色 = 语义_加载指示; 节点.语义置信度 = 7000; 返回
        }
    }

    // 策略三: 结构启发推断(置信度=5000) — 通过子元素模式推断
    节点_AI结构推断(节点)
}

函数 节点_AI结构推断(节点) {
    如果 (节点 == 0 || 节点.语义角色 != 语义_未知) { 返回 }

    // 包含多个<a>子元素的容器 → 可能是导航
    定义 可变 链接数 = 0
    定义 可变 文本数 = 0
    定义 可变 图片数 = 0
    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        如果 (子.节点标志 & 节点标志_是元素) {
            定义 子扩 = 元素_获取扩展(子)
            如果 (子扩 != 0) {
                如果 (字符串_相等(子扩.标签名原子, "a")) { 链接数 = 链接数 + 1 }
                如果 (字符串_相等(子扩.标签名原子, "img")) { 图片数 = 图片数 + 1 }
            }
        }
        如果 (子.节点类型 == TEXT_节点) { 文本数 = 文本数 + 1 }
        子 = 子.后一兄弟
    }

    // 启发规则
    如果 (链接数 >= 3 && 文本数 <= 链接数) {
        节点.语义角色 = 语义_导航栏; 节点.语义置信度 = 5000
    }
    否则 如果 (文本数 >= 3 && 链接数 <= 1) {
        节点.语义角色 = 语义_正文; 节点.语义置信度 = 5000
    }
    否则 如果 (图片数 >= 2 && 链接数 >= 2) {
        节点.语义角色 = 语义_卡片; 节点.语义置信度 = 4500
    }
}

// §2 语义角色常量

定义 语义_未知 = 0
定义 语义_导航栏 = 1
定义 语义_页头 = 2
定义 语义_页脚 = 3
定义 语义_正文 = 4
定义 语义_侧边栏 = 5
定义 语义_表单 = 6
定义 语义_按钮 = 7
定义 语义_链接 = 8
定义 语义_图片 = 9
定义 语义_视频 = 10
定义 语义_代码 = 11
定义 语义_引用 = 12
定义 语义_弹窗 = 13
定义 语义_标题 = 14
定义 语义_段落 = 15
定义 语义_列表 = 16
定义 语义_搜索框 = 17
定义 语义_广告 = 18
定义 语义_评论区 = 19
定义 语义_卡片 = 20
定义 语义_轮播 = 21
定义 语义_Cookie同意 = 22
定义 语义_面包屑 = 23
定义 语义_标签页 = 24
定义 语义_加载指示 = 25
定义 语义_表格 = 26
定义 语义_音频 = 27
定义 语义_地图 = 28
定义 语义_登录 = 29
定义 语义_注册 = 30

定义 节点标志_是元素 = 0x0010
定义 节点标志_AI已分析 = 0x1000
定义 TEXT_节点 = 3

函数 语义_角色名(角色) {
    如果 (角色 == 语义_未知) { 返回 "未知" }
    如果 (角色 == 语义_导航栏) { 返回 "导航栏" }
    如果 (角色 == 语义_页头) { 返回 "页头" }
    如果 (角色 == 语义_页脚) { 返回 "页脚" }
    如果 (角色 == 语义_正文) { 返回 "正文" }
    如果 (角色 == 语义_侧边栏) { 返回 "侧边栏" }
    如果 (角色 == 语义_表单) { 返回 "表单" }
    如果 (角色 == 语义_按钮) { 返回 "按钮" }
    如果 (角色 == 语义_链接) { 返回 "链接" }
    如果 (角色 == 语义_图片) { 返回 "图片" }
    如果 (角色 == 语义_视频) { 返回 "视频" }
    如果 (角色 == 语义_代码) { 返回 "代码" }
    如果 (角色 == 语义_弹窗) { 返回 "弹窗" }
    如果 (角色 == 语义_标题) { 返回 "标题" }
    如果 (角色 == 语义_段落) { 返回 "段落" }
    如果 (角色 == 语义_列表) { 返回 "列表" }
    如果 (角色 == 语义_搜索框) { 返回 "搜索框" }
    如果 (角色 == 语义_广告) { 返回 "广告" }
    如果 (角色 == 语义_评论区) { 返回 "评论区" }
    如果 (角色 == 语义_卡片) { 返回 "卡片" }
    如果 (角色 == 语义_轮播) { 返回 "轮播" }
    如果 (角色 == 语义_Cookie同意) { 返回 "Cookie同意" }
    如果 (角色 == 语义_面包屑) { 返回 "面包屑" }
    如果 (角色 == 语义_标签页) { 返回 "标签页" }
    如果 (角色 == 语义_加载指示) { 返回 "加载指示" }
    如果 (角色 == 语义_登录) { 返回 "登录" }
    如果 (角色 == 语义_注册) { 返回 "注册" }
    返回 "角色_" + 整数转字符串(角色)
}

函数 语义_是交互角色(角色) {
    返回 角色 == 语义_按钮 || 角色 == 语义_链接 || 角色 == 语义_表单 || 角色 == 语义_搜索框
}

函数 语义_是地标角色(角色) {
    返回 角色 == 语义_导航栏 || 角色 == 语义_页头 || 角色 == 语义_页脚 || 角色 == 语义_正文 || 角色 == 语义_侧边栏
}

函数 语义_是内容角色(角色) {
    返回 角色 == 语义_段落 || 角色 == 语义_标题 || 角色 == 语义_列表 || 角色 == 语义_代码 || 角色 == 语义_引用
}

// §3 语义树查询

函数 语义_按角色查找(根节点, 目标角色) {
    定义 可变 结果 = []
    语义_按角色查找_递归(根节点, 目标角色, 结果)
    返回 结果
}

函数 语义_按角色查找_递归(节点, 目标角色, 结果) {
    如果 (节点 == 0) { 返回 }
    如果 (节点.语义角色 == 目标角色) { 追加(结果, 节点) }
    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        语义_按角色查找_递归(子, 目标角色, 结果)
        子 = 子.后一兄弟
    }
}

函数 语义_获取主内容(根节点) {
    定义 结果 = 语义_按角色查找(根节点, 语义_正文)
    如果 (计数(结果) > 0) { 返回 结果[0] }
    返回 0
}

函数 语义_获取导航(根节点) {
    返回 语义_按角色查找(根节点, 语义_导航栏)
}

函数 语义_获取广告(根节点) {
    返回 语义_按角色查找(根节点, 语义_广告)
}

函数 语义_获取标题列表(根节点) {
    返回 语义_按角色查找(根节点, 语义_标题)
}

// §4 页面质量评分

函数 语义_页面质量评分(根节点) {
    定义 可变 分数 = 50
    定义 标题 = 语义_按角色查找(根节点, 语义_标题)
    如果 (计数(标题) >= 1) { 分数 = 分数 + 10 }
    定义 导航 = 语义_按角色查找(根节点, 语义_导航栏)
    如果 (计数(导航) >= 1) { 分数 = 分数 + 10 }
    定义 正文 = 语义_按角色查找(根节点, 语义_正文)
    如果 (计数(正文) >= 1) { 分数 = 分数 + 15 }
    定义 页脚 = 语义_按角色查找(根节点, 语义_页脚)
    如果 (计数(页脚) >= 1) { 分数 = 分数 + 5 }
    定义 广告 = 语义_按角色查找(根节点, 语义_广告)
    如果 (计数(广告) > 5) { 分数 = 分数 - 15 }
    如果 (分数 > 100) { 分数 = 100 }
    如果 (分数 < 0) { 分数 = 0 }
    返回 分数
}

// §5 语义统计与健康检查

定义 可变 语义_分析总数 = 0
定义 可变 语义_高置信度数 = 0
定义 可变 语义_低置信度数 = 0
定义 可变 语义_未识别数 = 0

函数 语义_统计() {
    返回 {
        分析总数: 语义_分析总数,
        高置信度: 语义_高置信度数,
        低置信度: 语义_低置信度数,
        未识别: 语义_未识别数,
    }
}

函数 语义_健康检查() {
    定义 可变 问题 = []
    如果 (语义_未识别数 > 语义_分析总数 / 2 && 语义_分析总数 > 100) {
        追加(问题, "语义未识别率过高")
    }
    如果 (计数(问题) == 0) { 返回 "语义分析引擎健康" }
    返回 问题
}

函数 语义_重置统计() {
    语义_分析总数 = 0
    语义_高置信度数 = 0
    语义_低置信度数 = 0
    语义_未识别数 = 0
}

函数 语义_完整统计() {
    返回 [语义_分析总数, 语义_高置信度数, 语义_低置信度数, 语义_未识别数]
}

导入("./断言.nova")
导入("../../标准库/基础.nova")
导入("../../自举兼容桥.nova")
导入("../../系统扩展/共享辅助.nova")

// Nova 编译器 回归测试套件
// 覆盖所有历次审计中发现并修复的 bug
// 运行: 阶段2_编译器 编译本文件 → 执行 → 检查退出码

// 组1: 字符串操作
// 回归: __运行时_串替换 子串匹配越界

函数 测试_字符串基础() {
    测试组("字符串基础")

    // 拼接
    断言字符串相等(字符串拼接("hello", " world"), "hello world", "字符串拼接-基本")
    断言字符串相等(字符串拼接("", "abc"), "abc", "字符串拼接-左空")
    断言字符串相等(字符串拼接("abc", ""), "abc", "字符串拼接-右空")
    断言字符串相等(字符串拼接("", ""), "", "字符串拼接-双空")

    // 子串
    断言字符串相等(子串("hello", 0, 5), "hello", "子串-完整")
    断言字符串相等(子串("hello", 1, 3), "ell", "子串-中间")
    断言字符串相等(子串("hello"), "", "子串-零长度")

    // 长度
    断言相等(计数("abc"), 3, "字符串长度-ascii")
    断言相等(计数(""), 0, "字符串长度-空")

    // 查找
    断言相等(字符串查找("hello world", "world"), 6, "字符串查找-存在")
    断言相等(字符串查找("hello", "xyz"), -1, "字符串查找-不存在")
    断言相等(字符串查找("aaa", "a"), 0, "字符串查找-首字符")
    断言相等(字符串查找("", "a"), -1, "字符串查找-空串")
}

// 组2: 列表操作
// 回归: __运行时_列表插入 ABI 错误

函数 测试_列表基础() {
    测试组("列表基础")

    // 创建与追加
    定义 可变 a = []
    追加(a, 10)
    追加(a, 20)
    追加(a, 30)
    断言相等(计数(a), 3, "列表追加-长度")
    断言相等(a[0], 10, "列表索引-0")
    断言相等(a[1], 20, "列表索引-1")
    断言相等(a[2], 30, "列表索引-2")

    // 修改
    a[1] = 99
    断言相等(a[1], 99, "列表赋值-修改")

    // 嵌套列表
    定义 可变 b = [[1, 2], [3, 4]]
    断言相等(b[0][0], 1, "嵌套列表-[0][0]")
    断言相等(b[1][1], 4, "嵌套列表-[1][1]")
    断言相等(计数(b), 2, "嵌套列表-外层长度")
    断言相等(计数(b[0]), 2, "嵌套列表-内层长度")

    // 空列表
    定义 可变 c = []
    断言相等(计数(c), 0, "空列表-长度")
}

// 组3: 值比较
// 回归: __运行时_值相等 SEGFAULT

函数 测试_值比较() {
    测试组("值比较")

    // 整数比较
    断言为真(1 == 1, "整数相等")
    断言为真(1 != 2, "整数不等")
    断言为真(0 == 0, "零相等")
    断言为真(-1 == -1, "负数相等")

    // 字符串比较
    断言为真("abc" == "abc", "字符串相等")
    断言为真("abc" != "def", "字符串不等")
    断言为真("" == "", "空串相等")

    // 空值比较
    断言为真(空 == 空, "空值相等")

    // 布尔比较
    断言为真(真 == 真, "真==真")
    断言为真(假 == 假, "假==假")
    断言为真(真 != 假, "真!=假")

    // 混合类型比较(不应崩溃)
    断言为真(1 != "1", "整数!=字符串")
    断言为真(0 != 空, "零!=空")
    断言为真(1 != 假, "一!=假")
}

// 组4: 算术与位运算

函数 测试_算术() {
    测试组("算术与位运算")

    // 基本算术
    断言相等(1 + 2, 3, "加法")
    断言相等(10 - 7, 3, "减法")
    断言相等(3 * 4, 12, "乘法")
    断言相等(10 / 3, 3, "整除")
    断言相等(10 % 3, 1, "取模")
    断言相等(0 - 5, -5, "负数")

    // 位运算
    断言相等(0xFF & 0x0F, 0x0F, "位与")
    断言相等(0xF0 | 0x0F, 0xFF, "位或")
    断言相等(0xFF ^ 0x0F, 0xF0, "位异或")
    断言相等(1 << 3, 8, "左移")
    断言相等(16 >> 2, 4, "右移")

    // 边界值
    断言相等(0 * 12345, 0, "零乘")
    断言相等(1 * 12345, 12345, "一乘")
}

// 组5: 字典操作

函数 测试_字典() {
    测试组("字典操作")

    定义 d = 字典()
    字典设(d, "名", "Nova")
    字典设(d, "版本", "2")
    字典设(d, "年", "2026")

    断言相等(字典取(d, "名"), "Nova", "字典取-存在")
    断言相等(字典取(d, "版本"), "2", "字典取-第二键")
    断言相等(字典取(d, "年"), "2026", "字典取-第三键")

    // 覆写
    字典设(d, "版本", "3")
    断言相等(字典取(d, "版本"), "3", "字典覆写")

    // 键列表
    定义 键 = 字典键列表(d)
    断言大于(计数(键), 0, "字典键列表-非空")
}

// 组6: 控制流
// 回归: 匹配关键字被误解析为match语句

函数 测试_控制流() {
    测试组("控制流")

    // if/else
    定义 可变 x = 0
    如果 (真) { x = 1 }
    断言相等(x, 1, "如果-真")
    如果 (假) { x = 99 } 否则 { x = 2 }
    断言相等(x, 2, "如果-假-否则")

    // while循环
    定义 可变 sum = 0
    定义 可变 i = 1
    当 (i <= 10) {
        sum = sum + i
        i = i + 1
    }
    断言相等(sum, 55, "当循环-1到10求和")

    // 匹配作为普通变量名 (回归: 曾被误解析为match)
    定义 可变 匹配 = 假
    匹配 = 真
    断言为真(匹配, "匹配-作为变量名赋值")
}

// 组7: 函数与闭包
// 回归: lambda 闭包捕获 (_收集自由标识 len < 2)

函数 _辅助_加法(a, b) { 返回 a + b }
函数 _辅助_阶乘(n) {
    如果 (n <= 1) { 返回 1 }
    返回 n * _辅助_阶乘(n - 1)
}

函数 测试_函数() {
    测试组("函数与递归")

    断言相等(_辅助_加法(3, 4), 7, "函数调用-加法")
    断言相等(_辅助_阶乘(5), 120, "递归-阶乘5")
    断言相等(_辅助_阶乘(1), 1, "递归-阶乘1")
    断言相等(_辅助_阶乘(0), 1, "递归-阶乘0")
}

// 组8: 缓冲区操作
// 回归: 内存写16/32/64 字节序

函数 测试_缓冲区() {
    测试组("缓冲区操作")

    // 基础缓冲区
    定义 buf = 缓冲区(16)
    断言相等(计数(buf), 16, "缓冲区-创建大小")
    断言相等(buf[0], 0, "缓冲区-零初始化")
    断言相等(buf[15], 0, "缓冲区-末尾零")

    // 字节写入 (2026-04-17 bug-fix: xAB是未定义变量=0, 原作者本意为0xAB=171字面量)
    缓冲写(buf, 0, 0xAB)
    断言相等(buf[0], 0xAB, "缓冲写-单字节")

    // 16位小端序
    内存写16(buf, 2, 0x1234)
    断言相等(buf[2], 0x34, "内存写16-低字节")
    断言相等(buf[3], 0x12, "内存写16-高字节")

    // 32位小端序
    内存写32(buf, 4, 0x12345678)
    断言相等(buf[4], 0x78, "内存写32-字节0")
    断言相等(buf[5], 0x56, "内存写32-字节1")
    断言相等(buf[6], 0x34, "内存写32-字节2")
    断言相等(buf[7], 0x12, "内存写32-字节3")

    // 64位
    内存写64(buf, 8, 256)
    断言相等(buf[8], 0, "内存写64-字节0(256)")
    断言相等(buf[9], 1, "内存写64-字节1(256)")
}

// 组9: 作用域管理
// 回归: 共享辅助 作用域_退出 无限循环

函数 测试_作用域() {
    测试组("作用域管理")

    // 基本作用域进入/退出应不死循环
    定义 深度基 = 作用域_深度()
    作用域_进入()
    定义 深度前 = 作用域_深度()
    断言相等(深度前, 深度基 + 1, "作用域进入-深度加1")
    作用域_退出()
    定义 深度后 = 作用域_深度()
    断言相等(深度后, 深度基, "作用域退出-深度恢复")

    // 嵌套作用域
    作用域_进入()
    作用域_进入()
    断言相等(作用域_深度(), 深度基 + 2, "嵌套作用域-深度+2")
    作用域_退出()
    作用域_退出()
    断言为真(真, "嵌套作用域-无死循环")
}

// 组10: 数据结构完整性

函数 测试_数据结构() {
    测试组("数据结构完整性")

    // 列表切片
    定义 src = [10, 20, 30, 40, 50]
    定义 s = 切片(src, 1, 4)
    断言相等(计数(s), 3, "切片-长度")
    断言相等(s[0], 20, "切片-首元素")
    断言相等(s[2], 40, "切片-末元素")

    // 求和
    断言相等(求和([1, 2, 3, 4, 5]), 15, "求和-1到5")
    断言相等(求和([]), 0, "求和-空列表")

    // 位计数
    断言相等(位计数(0), 0, "位计数-0")
    断言相等(位计数(1), 1, "位计数-1")
    断言相等(位计数(7), 3, "位计数-7(111)")
    断言相等(位计数(255), 8, "位计数-255")
}

// 主入口

测试套件("Nova编译器回归测试")

测试_字符串基础()
测试_列表基础()
测试_值比较()
测试_算术()
测试_字典()
测试_控制流()
测试_函数()
测试_缓冲区()
测试_作用域()
测试_数据结构()

定义 失败数 = 测试报告()

如果 (失败数 > 0) {
    打印("")
    打印("回归测试发现失败! 退出码: 1")
    打印("失败模式: " + 测试_失败模式分析())
}
如果 (失败数 == 0) {
    打印("")
    打印("全部回归测试通过!")
}

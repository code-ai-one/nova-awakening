// 实现: HTML5解析规范 §13.2.6 (Tree construction)
// https://html.spec.whatwg.org/multipage/parsing.html#tree-construction
// TreeBuilder从令牌izer接收令牌，根据HTML5规范的插入模式构建DOM树
// 包括自动闭合、嵌套修正、表单关联、脚本执行等复杂逻辑

// 插入模式 (HTML规范 §13.2.6 — Insertion modes)
// 这是TreeBuilder状态机的核心

定义 插入模式_初始               = 0    // Initial
定义 插入模式_DOCTYPE前          = 1    // Before html
定义 插入模式_html前             = 2    // Before head
定义 插入模式_head前             = 3    // Before head (same)
定义 插入模式_head中             = 4    // In head
定义 插入模式_head_noscript中    = 5    // In head noscript
定义 插入模式_head后             = 6    // After head
定义 插入模式_body中             = 7    // In body
定义 插入模式_文本               = 8    // Text
定义 插入模式_table中            = 9    // In table
定义 插入模式_table文本中        = 10   // In table text
定义 插入模式_caption中          = 11   // In caption
定义 插入模式_列组中             = 12   // In column group
定义 插入模式_table_body中       = 13   // In table body
定义 插入模式_行中               = 14   // In row
定义 插入模式_单元格中           = 15   // In cell
定义 插入模式_select中           = 16   // In select
定义 插入模式_select_table中     = 17   // In select in table
定义 插入模式_template中         = 18   // In template
定义 插入模式_body后             = 19   // After body
定义 插入模式_frameset中         = 20   // In frameset
定义 插入模式_frameset后         = 21   // After frameset
定义 插入模式_html后             = 22   // After after body
定义 插入模式_html_frameset后    = 23   // After after frameset

// 开放元素栈 
// 维护当前打开但未闭合的元素

结构 元素栈 {
 元素列表,    // u64 节点*数组
 数量,
 容量,
}

函数 元素栈_创建() {
 定义 栈 = 堆_分配(元素栈)
 栈.容量 = 64
 栈.元素列表 = 堆_分配_数组(栈.容量 * 8)
 栈.数量 = 0
 返回 栈
}

函数 元素栈_压入(栈, 元素) {
 如果 (栈.数量 >= 栈.容量) {
 定义 新容量 = 栈.容量 * 2
 定义 新列表 = 堆_分配_数组(新容量 * 8)
 内存_复制(新列表, 栈.元素列表, 栈.数量 * 8)
 堆_释放(栈.元素列表)
 栈.元素列表 = 新列表
 栈.容量 = 新容量
 }
 内存_写64(栈.元素列表 + 栈.数量 * 8, 元素)
 栈.数量 = 栈.数量 + 1
}

函数 元素栈_弹出(栈) {
 如果 (栈.数量 == 0) { 返回 0 }
 栈.数量 = 栈.数量 - 1
 返回 内存_读64(栈.元素列表 + 栈.数量 * 8)
}

函数 元素栈_顶部(栈) {
 如果 (栈.数量 == 0) { 返回 0 }
 返回 内存_读64(栈.元素列表 + (栈.数量 - 1) * 8)
}

函数 元素栈_第N个(栈, n) {
 如果 (n >= 栈.数量) { 返回 0 }
 返回 内存_读64(栈.元素列表 + n * 8)
}

函数 元素栈_包含标签(栈, 标签名原子) {
 定义 可变 i = 栈.数量
 当 (i > 0) {
 i = i - 1
 定义 元素 = 内存_读64(栈.元素列表 + i * 8)
 定义 扩展 = 元素_获取扩展(元素)
 如果 (扩展 != 0 && 扩展.标签名原子 == 标签名原子) {
 返回 1
 }
 }
 返回 0
}

函数 元素栈_弹出直到标签(栈, 标签名原子) {
 当 (栈.数量 > 0) {
 定义 顶 = 元素栈_顶部(栈)
 定义 扩展 = 元素_获取扩展(顶)
 元素栈_弹出(栈)
 如果 (扩展 != 0 && 扩展.标签名原子 == 标签名原子) {
 返回
 }
 }
}

函数 元素栈_弹出直到含(栈, 标签名原子) {
 // 弹出直到(含)指定标签
 元素栈_弹出直到标签(栈, 标签名原子)
}

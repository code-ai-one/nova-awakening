//   1. 无锁单生产者单消费者: 读写指针分离, 不需要锁
//   2. 容量必须是2的幂: 用mask代替取模(性能)
//   3. 读写指针永不回绕: 自然溢出, 用mask获取实际索引
//   4. 批量读写: kfifo_in/kfifo_out处理连续内存块
//   5. 用于: 内核日志/串口缓冲/中断队列/管道

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./整数转字符串.nova")

结构 环形缓冲 {
    数据,    // [] 底层数组
    容量,    // u32 必须是2的幂
    mask,    // u32 容量-1 (取模用)
    写指针,    // u32 永不回绕的写位置
    读指针,    // u32 永不回绕的读位置
    溢出次数,    // u32 写满时的溢出计数
}

// 创建 (容量向上取整到2的幂)

函数 环形缓冲_创建(请求容量) {
    // 向上取整到2的幂
    定义 可变 容量 = 1
    当 (容量 < 请求容量) { 容量 = 容量 * 2 }

    定义 rb = 环形缓冲 {}
    rb.数据 = []
    定义 可变 i = 0
    当 (i < 容量) { 追加(rb.数据, 0); i = i + 1 }
    rb.容量 = 容量
    rb.mask = 容量 - 1
    rb.写指针 = 0
    rb.读指针 = 0
    rb.溢出次数 = 0
    返回 rb
}

// 写入 

函数 环形缓冲_写入(rb, 值) {
    如果 (环形缓冲_已满(rb)) {
        rb.溢出次数 = rb.溢出次数 + 1
        返回 错误_无空间
    }
    定义 位置 = rb.写指针 & rb.mask
    设置(rb.数据, 位置, 值)
    rb.写指针 = rb.写指针 + 1
    返回 成功
}

函数 环形缓冲_写入_覆盖(rb, 值) {
    // 写满时覆盖最老的数据(日志缓冲用)
    如果 (环形缓冲_已满(rb)) {
        rb.读指针 = rb.读指针 + 1   // 丢弃最老元素
        rb.溢出次数 = rb.溢出次数 + 1
    }
    定义 位置 = rb.写指针 & rb.mask
    设置(rb.数据, 位置, 值)
    rb.写指针 = rb.写指针 + 1
    返回 成功
}

// 读取 

函数 环形缓冲_读取(rb) {
    如果 (环形缓冲_为空(rb)) { 返回 空 }
    定义 位置 = rb.读指针 & rb.mask
    定义 值 = rb.数据[位置]
    rb.读指针 = rb.读指针 + 1
    返回 值
}

函数 环形缓冲_查看(rb) {
    如果 (环形缓冲_为空(rb)) { 返回 空 }
    定义 位置 = rb.读指针 & rb.mask
    返回 rb.数据[位置]
}

函数 环形缓冲_查看偏移(rb, 偏移) {
    如果 (偏移 >= 环形缓冲_大小(rb)) { 返回 空 }
    定义 位置 = (rb.读指针 + 偏移) & rb.mask
    返回 rb.数据[位置]
}

// 批量操作 

函数 环形缓冲_批量写入(rb, 列表) {
    定义 可变 写入数 = 0
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        定义 结果 = 环形缓冲_写入(rb, 列表[i])
        如果 (是错误(结果)) { 返回 写入数 }
        写入数 = 写入数 + 1
        i = i + 1
    }
    返回 写入数
}

函数 环形缓冲_批量读取(rb, 数量) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 数量 && !环形缓冲_为空(rb)) {
        追加(结果, 环形缓冲_读取(rb))
        i = i + 1
    }
    返回 结果
}

// 状态查询

函数 环形缓冲_为空(rb)  { 返回 rb.写指针 == rb.读指针 }
函数 环形缓冲_已满(rb)  { 返回 (rb.写指针 - rb.读指针) >= rb.容量 }
函数 环形缓冲_大小(rb)  { 返回 rb.写指针 - rb.读指针 }
函数 环形缓冲_剩余(rb)  { 返回 rb.容量 - (rb.写指针 - rb.读指针) }
函数 环形缓冲_容量(rb)  { 返回 rb.容量 }
函数 环形缓冲_溢出(rb)  { 返回 rb.溢出次数 }

函数 环形缓冲_清空(rb) {
    rb.读指针 = 0
    rb.写指针 = 0
}

// 辅助: 2的幂检查

函数 是2的幂(n) { 返回 n > 0 && (n & (n - 1)) == 0 }

// 跳过/丢弃 

函数 环形缓冲_跳过(rb, 数量) {
    定义 可跳过 = 环形缓冲_大小(rb)
    如果 (数量 > 可跳过) { 数量 = 可跳过 }
    rb.读指针 = rb.读指针 + 数量
    返回 数量
}

// 重置溢出计数

函数 环形缓冲_重置溢出(rb) {
    rb.溢出次数 = 0
}

// 遍历(不消费)

函数 环形缓冲_遍历(rb, 回调) {
    定义 大小 = 环形缓冲_大小(rb)
    定义 可变 i = 0
    当 (i < 大小) {
        定义 位置 = (rb.读指针 + i) & rb.mask
        回调(rb.数据[位置], i)
        i = i + 1
    }
}

// 转为数组(不消费)

函数 环形缓冲_转数组(rb) {
    定义 可变 结果 = []
    定义 大小 = 环形缓冲_大小(rb)
    定义 可变 i = 0
    当 (i < 大小) {
        定义 位置 = (rb.读指针 + i) & rb.mask
        追加(结果, rb.数据[位置])
        i = i + 1
    }
    返回 结果
}

// 使用率(百分比)

函数 环形缓冲_使用率(rb) {
    如果 (rb.容量 == 0) { 返回 0 }
    返回 环形缓冲_大小(rb) * 100 / rb.容量
}

函数 环形缓冲_统计(rb) {
    返回 [环形缓冲_大小(rb), rb.容量, rb.溢出次数, 环形缓冲_使用率(rb)]
}

// 查找 + 条件读取

函数 环形缓冲_包含(rb, 值) {
    定义 大小 = 环形缓冲_大小(rb)
    定义 可变 i = 0
    当 (i < 大小) {
        定义 位置 = (rb.读指针 + i) & rb.mask
        如果 (rb.数据[位置] == 值) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 环形缓冲_读取_非阻塞(rb) {
    如果 (环形缓冲_为空(rb)) { 返回 [假, 空] }
    返回 [真, 环形缓冲_读取(rb)]
}

函数 环形缓冲_向上取整2的幂(n) {
    定义 可变 v = 1
    当 (v < n) { v = v * 2 }
    返回 v
}

// 完整统计

定义 成功 = 0
定义 错误_无空间 = 0 - 28
定义 AI吞吐窗口 = 16
定义 水位线_高 = 80
定义 水位线_低 = 20

结构 环形缓冲统计 {
    创建次数: 整数,
    写入次数: 整数,
    写入覆盖次数: 整数,
    读取次数: 整数,
    查看次数: 整数,
    批量写入次数: 整数,
    批量读取次数: 整数,
    遍历次数: 整数,
    清空次数: 整数,
    溢出总数: 整数,
    高水位告警数: 整数,
    低水位告警数: 整数,
    AI预测次数: 整数,
    AI预测命中: 整数,
    跳过次数: 整数,
    错误次数: 整数,
    峰值使用率: 整数,
    总写入字节: 整数,
}

定义 可变 全局统计 = 环形缓冲统计 {}
定义 可变 环形模块已初始化 = 假
定义 可变 AI吞吐历史 = []
定义 可变 AI吞吐位置 = 0


函数 环形缓冲模块_初始化() {
    如果 (环形模块已初始化 == 真) { 返回 0 - 17 }
    AI吞吐历史 = []
    定义 可变 i = 0
    当 (i < AI吞吐窗口) {
        追加(AI吞吐历史, 0)
        i = i + 1
    }
    AI吞吐位置 = 0
    环形模块已初始化 = 真
    打印("[环形缓冲] 模块初始化完成")
    返回 0
}

函数 环形缓冲模块_销毁() {
    如果 (环形模块已初始化 == 假) { 返回 0 }
    AI吞吐历史 = []
    环形模块已初始化 = 假
    打印("[环形缓冲] 模块已销毁")
    返回 0
}


函数 环形缓冲_安全写入(rb, 值) {
    如果 (rb == 空) {
        全局统计.错误次数 = 全局统计.错误次数 + 1
        返回 错误_无空间
    }
    全局统计.写入次数 = 全局统计.写入次数 + 1
    定义 结果 = 环形缓冲_写入(rb, 值)
    // 更新峰值使用率
    定义 当前率 = 环形缓冲_使用率(rb)
    如果 (当前率 > 全局统计.峰值使用率) {
        全局统计.峰值使用率 = 当前率
    }
    // 高水位告警
    如果 (当前率 > 水位线_高) {
        全局统计.高水位告警数 = 全局统计.高水位告警数 + 1
    }
    AI_记录吞吐(1)
    返回 结果
}

函数 环形缓冲_安全读取(rb) {
    如果 (rb == 空) {
        全局统计.错误次数 = 全局统计.错误次数 + 1
        返回 空
    }
    全局统计.读取次数 = 全局统计.读取次数 + 1
    定义 结果 = 环形缓冲_读取(rb)
    // 低水位告警
    定义 当前率 = 环形缓冲_使用率(rb)
    如果 (当前率 < 水位线_低 && 当前率 > 0) {
        全局统计.低水位告警数 = 全局统计.低水位告警数 + 1
    }
    返回 结果
}

函数 环形缓冲_安全写入覆盖(rb, 值) {
    如果 (rb == 空) { 返回 错误_无空间 }
    全局统计.写入覆盖次数 = 全局统计.写入覆盖次数 + 1
    返回 环形缓冲_写入_覆盖(rb, 值)
}


函数 环形缓冲_是否高水位(rb) {
    如果 (rb == 空) { 返回 假 }
    返回 环形缓冲_使用率(rb) > 水位线_高
}

函数 环形缓冲_是否低水位(rb) {
    如果 (rb == 空) { 返回 假 }
    定义 率 = 环形缓冲_使用率(rb)
    返回 率 > 0 && 率 < 水位线_低
}

函数 环形缓冲_水位状态(rb) {
    如果 (rb == 空) { 返回 "空" }
    定义 率 = 环形缓冲_使用率(rb)
    如果 (率 == 0) { 返回 "空" }
    如果 (率 < 水位线_低) { 返回 "低水位" }
    如果 (率 < 水位线_高) { 返回 "正常" }
    如果 (率 < 100) { 返回 "高水位" }
    返回 "已满"
}


函数 环形缓冲_读取直到(rb, 条件函数) {
    如果 (rb == 空 || 条件函数 == 空) { 返回 [] }
    定义 可变 结果 = []
    当 (环形缓冲_为空(rb) == 假) {
        定义 值 = 环形缓冲_查看(rb)
        如果 (条件函数(值) == 假) { 返回 结果 }
        追加(结果, 环形缓冲_读取(rb))
    }
    返回 结果
}

函数 环形缓冲_排空到列表(rb) {
    如果 (rb == 空) { 返回 [] }
    定义 可变 结果 = []
    当 (环形缓冲_为空(rb) == 假) {
        追加(结果, 环形缓冲_读取(rb))
    }
    返回 结果
}


函数 AI_记录吞吐(写入量) {
    设置(AI吞吐历史, AI吞吐位置, 写入量)
    AI吞吐位置 = (AI吞吐位置 + 1) % AI吞吐窗口
    全局统计.AI预测次数 = 全局统计.AI预测次数 + 1
}

函数 AI_预测吞吐量() {
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < AI吞吐窗口) {
        总和 = 总和 + AI吞吐历史[i]
        i = i + 1
    }
    返回 总和 / AI吞吐窗口
}

函数 AI_预测是否需要扩容(rb) {
    如果 (rb == 空) { 返回 假 }
    定义 吞吐 = AI_预测吞吐量()
    定义 剩余 = 环形缓冲_剩余(rb)
    // 如果预测吞吐量>剩余容量的80%，建议扩容
    如果 (吞吐 * 10 > 剩余 * 8) {
        全局统计.AI预测命中 = 全局统计.AI预测命中 + 1
        返回 真
    }
    返回 假
}

函数 AI_建议容量(rb) {
    如果 (rb == 空) { 返回 16 }
    定义 吞吐 = AI_预测吞吐量()
    // 建议容量 = 当前容量 * 2 或 吞吐量 * 4
    定义 建议1 = rb.容量 * 2
    定义 建议2 = 吞吐 * 4
    如果 (建议1 > 建议2) { 返回 环形缓冲_向上取整2的幂(建议1) }
    返回 环形缓冲_向上取整2的幂(建议2)
}


函数 环形缓冲_转储(rb) {
    如果 (rb == 空) {
        打印("[环形缓冲] 空缓冲")
        返回 0
    }
    打印("[环形缓冲] ═══ 状态转储 ═══")
    打印(字符串拼接("  容量: ", 整数转字符串(rb.容量)))
    打印(字符串拼接("  已用: ", 整数转字符串(环形缓冲_大小(rb))))
    打印(字符串拼接("  剩余: ", 整数转字符串(环形缓冲_剩余(rb))))
    打印(字符串拼接("  使用率%: ", 整数转字符串(环形缓冲_使用率(rb))))
    打印(字符串拼接("  溢出: ", 整数转字符串(rb.溢出次数)))
    打印(字符串拼接("  水位: ", 环形缓冲_水位状态(rb)))
    打印(字符串拼接("  写指针: ", 整数转字符串(rb.写指针)))
    打印(字符串拼接("  读指针: ", 整数转字符串(rb.读指针)))
    返回 0
}

函数 环形缓冲_完整统计(rb) {
    返回 [环形缓冲_大小(rb), rb.容量, rb.溢出次数,
           环形缓冲_使用率(rb), rb.写指针, rb.读指针]
}


函数 环形缓冲模块_打印统计() {
    打印("[环形缓冲] ═══ 运行统计 ═══")
    打印(字符串拼接("  创建次数: ", 整数转字符串(全局统计.创建次数)))
    打印(字符串拼接("  写入次数: ", 整数转字符串(全局统计.写入次数)))
    打印(字符串拼接("  写入覆盖: ", 整数转字符串(全局统计.写入覆盖次数)))
    打印(字符串拼接("  读取次数: ", 整数转字符串(全局统计.读取次数)))
    打印(字符串拼接("  查看次数: ", 整数转字符串(全局统计.查看次数)))
    打印(字符串拼接("  批量写入: ", 整数转字符串(全局统计.批量写入次数)))
    打印(字符串拼接("  批量读取: ", 整数转字符串(全局统计.批量读取次数)))
    打印(字符串拼接("  遍历次数: ", 整数转字符串(全局统计.遍历次数)))
    打印(字符串拼接("  清空次数: ", 整数转字符串(全局统计.清空次数)))
    打印(字符串拼接("  溢出总数: ", 整数转字符串(全局统计.溢出总数)))
    打印(字符串拼接("  高水位告警: ", 整数转字符串(全局统计.高水位告警数)))
    打印(字符串拼接("  低水位告警: ", 整数转字符串(全局统计.低水位告警数)))
    打印(字符串拼接("  AI预测: ", 整数转字符串(全局统计.AI预测次数)))
    打印(字符串拼接("  AI命中: ", 整数转字符串(全局统计.AI预测命中)))
    打印(字符串拼接("  峰值使用率%: ", 整数转字符串(全局统计.峰值使用率)))
    打印(字符串拼接("  跳过次数: ", 整数转字符串(全局统计.跳过次数)))
    打印(字符串拼接("  错误次数: ", 整数转字符串(全局统计.错误次数)))
    返回 0
}


函数 环形缓冲模块_注册到内核(内核上下文) {
    如果 (环形模块已初始化 == 假) { 返回 0 - 1 }
    打印("[环形缓冲] 已注册到内核上下文")
    返回 0
}

函数 环形缓冲模块_查询状态() {
    如果 (环形模块已初始化 == 假) { 返回 0 }
    返回 1
}

函数 环形缓冲模块_健康检查() {
    如果 (环形模块已初始化 == 假) { 返回 假 }
    如果 (全局统计.错误次数 * 10 > 全局统计.写入次数 + 全局统计.读取次数) {
        返回 假
    }
    返回 真
}


函数 环形缓冲_最后写入(rb) {
    如果 (rb == 空 || 环形缓冲_为空(rb)) { 返回 空 }
    定义 位置 = (rb.写指针 - 1) & rb.mask
    返回 rb.数据[位置]
}

函数 环形缓冲_计数满足(rb, 条件) {
    如果 (rb == 空 || 条件 == 空) { 返回 0 }
    定义 可变 计数 = 0
    定义 大小 = 环形缓冲_大小(rb)
    定义 可变 i = 0
    当 (i < 大小) {
        定义 位置 = (rb.读指针 + i) & rb.mask
        如果 (条件(rb.数据[位置]) == 真) { 计数 = 计数 + 1 }
        i = i + 1
    }
    返回 计数
}

函数 环形缓冲_健康评估() {
    定义 可变 问题 = []
    如果 (环形模块已初始化 == 假) { 追加(问题, "环形模块已初始化") }
    如果 (!环形缓冲模块_健康检查()) { 追加(问题, "环形缓冲模块_健康检查未通过") }
    返回 计数(问题) == 0
}

函数 环形缓冲_综合报告() {
    打印("[环形缓冲] ═══ 报告 ═══")
    打印("  全局统计: " + 全局统计)
    打印("  环形模块已初始化: " + 环形模块已初始化)
    打印("  AI吞吐历史: " + AI吞吐历史)
    打印("  AI吞吐位置: " + AI吞吐位置)
    打印("  健康: " + 如果 (环形缓冲_健康评估()) { "正常" } 否则 { "异常" })
}

函数 环形缓冲_全局重置() {
    环形模块已初始化 = 假
    AI吞吐历史 = []
    AI吞吐位置 = 0
    打印("[环形缓冲] 全局统计已重置")
    返回 0
}


导入("量词类型系统.nova")
导入("../../基础.nova")

// 量词化列表 (串类)
// 列表天然属于"串"量词 (串联体)
函数 串列_创建() { 返回 分类(量词_串, [])
}

函数 串列_追加(串列, 值) { 如果 (量词_检查(串列, 量词_串) == 0) { 返回 量词_类型错误("串列_追加", 量词_串, 分类_量词(串列))
 }
 追加(分类_值(串列), 值)
 返回 空
}

函数 串列_取(串列, 索引) { 定义 列表 = 分类_值(串列)
 如果 (索引 < 0 或 索引 >= 计数(列表)) { 返回 空 }
 返回 列表[索引]
}

函数 串列_大小(串列) { 返回 计数(分类_值(串列)) }

// 串列拼接: 串+串=串 (量词代数闭合)
函数 串列_拼接(a, b) { 定义 可变 结果 = 串列_创建()
 定义 可变 i = 0
 当 (i < 串列_大小(a)) { 串列_追加(结果, 串列_取(a, i)) i = i + 1 }
 i = 0
 当 (i < 串列_大小(b)) { 串列_追加(结果, 串列_取(b, i)) i = i + 1 }
 返回 结果
}

// 串→片: 切片操作改变量词 (态射变换)
函数 串列_切片(串列, 起, _止) { 定义 列表 = 分类_值(串列)
 定义 可变 结果 = []
 定义 可变 i = 起
 当 (i < _止 且 i < 计数(列表)) {
 追加(结果, 列表[i])
 i = i + 1
 }
 返回 分类(量词_片, 结果) // 切片结果是"片"量词
}

// 量词化树 (棵类)
// 树结构天然属于"棵"量词

函数 棵树_创建(值) { 返回 分类(量词_棵, [值, []]) // [根值, 子节点列表]
}

函数 棵树_根值(树) { 返回 分类_值(树)[0] }

函数 棵树_添加子(树, 子树) { 如果 (量词_检查(子树, 量词_棵) == 0) { 返回 量词_类型错误("棵树_添加子", 量词_棵, 分类_量词(子树))
 }
 追加(分类_值(树)[1], 子树)
 返回 空
}

函数 棵树_子节点(树) { 返回 分类_值(树)[1] }
函数 棵树_子数(树) { 返回 计数(分类_值(树)[1]) }

函数 棵树_深度(树) { 定义 子列表 = 棵树_子节点(树)
 如果 (计数(子列表) == 0) { 返回 1 }
 定义 可变 最大深 = 0
 定义 可变 i = 0
 当 (i < 计数(子列表)) { 定义 d = 棵树_深度(子列表[i])
 如果 (d > 最大深) { 最大深 = d }
 i = i + 1
 }
 返回 最大深 + 1
}

函数 棵树_大小(树) { 定义 子列表 = 棵树_子节点(树)
 定义 可变 总 = 1
 定义 可变 i = 0
 当 (i < 计数(子列表)) {
 总 = 总 + 棵树_大小(子列表[i])
 i = i + 1
 }
 返回 总
}

// 量词化键值对 (对类)

函数 对_创建(键, 值) { 返回 分类(量词_对, [键, 值])
}

函数 对_键(对) { 返回 分类_值(对)[0] }
函数 对_值(对) { 返回 分类_值(对)[1] }

// 对→组: 多对组成组
函数 对列表_成组(对列表) { 定义 可变 值列表 = []
 定义 可变 i = 0
 当 (i < 计数(对列表)) {
 追加(值列表, 分类_值(对列表[i]))
 i = i + 1
 }
 返回 分类(量词_组, 值列表)
}

// 量词化内存块 (块类)

函数 块_创建(大小) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 大小) { 追加(数据, 0) i = i + 1 }
 返回 分类(量词_块, 数据)
}

函数 块_读(块, 偏移) { 定义 数据 = 分类_值(块)
 如果 (偏移 < 0 或 偏移 >= 计数(数据)) { 返回 0 }
 返回 数据[偏移]
}

函数 块_写(块, 偏移, 值) { 定义 数据 = 分类_值(块)
 如果 (偏移 < 0 或 偏移 >= 计数(数据)) { 返回 0 }
 数据[偏移] = 值
 返回 1
}

函数 块_大小(块) { 返回 计数(分类_值(块)) }

// 块→片: 切取内存页
函数 块_切页(块, 起, 大小) { 定义 数据 = 分类_值(块)
 定义 可变 页 = []
 定义 可变 i = 0
 当 (i < 大小 且 起 + i < 计数(数据)) {
 追加(页, 数据[起 + i])
 i = i + 1
 }
 返回 分类(量词_片, 页)
}

// 量词化句柄 (把类)

函数 把柄_创建(资源描述) { 返回 分类(量词_把, [资源描述, 1]) // [描述, 有效标记]
}

函数 把柄_有效(把柄) { 返回 分类_值(把柄)[1] == 1 }

函数 把柄_关闭(把柄) { 定义 内部 = 分类_值(把柄)
 内部[1] = 0 // 标记无效
 返回 1
}

函数 把柄_操作(把柄, 操作) { 如果 (把柄_有效(把柄) == 0) { 返回 ["错误", "把柄已关闭, 不可操作"]
 }
 返回 ["成功", 操作]
}

// 量词化批处理 (批类)

函数 批_创建() { 返回 分类(量词_批, [])
}

函数 批_追加(批, 项) {
 追加(分类_值(批), 项)
}

函数 批_大小(批) { 返回 计数(分类_值(批)) }

函数 批_处理(批, 处理函数) { 定义 数据 = 分类_值(批)
 定义 可变 结果 = 批_创建()
 定义 可变 i = 0
 当 (i < 计数(数据)) {
 批_追加(结果, 处理函数(数据[i], 空))
 i = i + 1
 }
 返回 结果
}

// 量词化层 (层类)

函数 层_创建(名称) { 返回 分类(量词_层, [名称, [], 空]) // [名称, 处理器列表, 下层]
}

函数 层_设下层(层, 下层) { 定义 内部 = 分类_值(层)
 内部[2] = 下层
}

函数 层_添加处理器(层, 处理器) {
 追加(分类_值(层)[1], 处理器)
}

函数 层_传递(层, 数据) { 定义 可变 当前 = 数据
 定义 处理器列表 = 分类_值(层)[1]
 定义 可变 i = 0
 当 (i < 计数(处理器列表)) {
 当前 = 处理器列表[i](当前, 空)
 i = i + 1
 }
 定义 下层 = 分类_值(层)[2]
 如果 (下层 != 空) { 返回 层_传递(下层, 当前) }
 返回 当前
}

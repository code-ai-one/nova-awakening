// §6 显示合成器 (viz::Display — 最终输出)
// 将合成帧绘制到帧缓冲(软件渲染路径)

结构 显示合成器 {
    帧缓冲,    // u64 帧缓冲指针 (RGBA像素)
    宽度,
    高度,
    步幅,    // u32 每行字节数
    drm_fd,    // i32 DRM设备fd
    vsync_间隔,    // u64 纳秒 (16.6ms for 60Hz)
}

函数 显示合成器_创建(宽, 高) {
    定义 dc = 堆_分配(显示合成器)
    dc.宽度 = 宽
    dc.高度 = 高
    dc.步幅 = 宽 * 4
    dc.帧缓冲 = 平台_匿名Nova内存映射(宽 * 高 * 4)
    dc.drm_fd = -1
    dc.vsync_间隔 = 16666667   // 60Hz
    返回 dc
}

函数 显示合成器_绘制帧(dc, frame) {
    如果 (dc == 0 || frame == 0) { 返回 }

    // 清除帧缓冲为白色
    定义 可变 i = 0
    定义 总像素 = dc.宽度 * dc.高度
    当 (i < 总像素) {
        内存_写32(dc.帧缓冲 + i * 4, 0xFFFFFFFF)  // 白色RGBA
        i = i + 1
    }

    // 绘制所有render pass中的四边形
    定义 pass = frame.render_pass列表
    定义 可变 q_idx = 0
    当 (q_idx < pass.四边形数) {
        定义 q = pass.四边形列表 + q_idx * 80
        定义 类型 = 内存_读32(q)
        定义 dst_x = 内存_读32(q + 4) / 100
        定义 dst_y = 内存_读32(q + 8) / 100
        定义 dst_w = 内存_读32(q + 12) / 100
        定义 dst_h = 内存_读32(q + 16) / 100
        定义 opacity = 内存_读32(q + 52)

        如果 (类型 == 四边形_纯色) {
            定义 颜色 = 内存_读32(q + 44)
            显示_绘制纯色矩形(dc, dst_x, dst_y, dst_w, dst_h, 颜色, opacity)
        }
        否则 如果 (类型 == 四边形_纹理 || 类型 == 四边形_分块内容) {
            定义 纹理id = 内存_读32(q + 40)
            显示_绘制纹理矩形(dc, dst_x, dst_y, dst_w, dst_h, 纹理id, opacity)
        }
        q_idx = q_idx + 1
    }

    // 提交帧到显示设备
    显示合成器_提交(dc)
}

函数 显示_绘制纯色矩形(dc, x, y, w, h, 颜色, opacity) {
    定义 r = (颜色 >> 24) & 0xFF
    定义 g = (颜色 >> 16) & 0xFF
    定义 b = (颜色 >> 8) & 0xFF
    定义 a = (颜色 & 0xFF) * opacity / 10000

    定义 可变 py = y
    当 (py < y + h && py < dc.高度) {
        如果 (py >= 0) {
            定义 可变 px = x
            当 (px < x + w && px < dc.宽度) {
                如果 (px >= 0) {
                    定义 ptr = dc.帧缓冲 + (py * dc.宽度 + px) * 4
                    如果 (a >= 255) {
                        内存_写8(ptr, r); 内存_写8(ptr + 1, g)
                        内存_写8(ptr + 2, b); 内存_写8(ptr + 3, 255)
                    } 否则 如果 (a > 0) {
                        // Alpha混合
                        定义 inv = 255 - a
                        内存_写8(ptr, (r * a + 内存_读8(ptr) * inv) / 255)
                        内存_写8(ptr + 1, (g * a + 内存_读8(ptr + 1) * inv) / 255)
                        内存_写8(ptr + 2, (b * a + 内存_读8(ptr + 2) * inv) / 255)
                        内存_写8(ptr + 3, 255)
                    }
                }
                px = px + 1
            }
        }
        py = py + 1
    }
}

函数 显示_绘制纹理矩形(dc, x, y, w, h, 纹理id, opacity) {
    如果 (纹理id == 0 || 纹理id >= 最大纹理数) { 返回 }
    定义 desc = 纹理表 + 纹理id * 48
    定义 tex_w = 内存_读32(desc + 4)
    定义 tex_h = 内存_读32(desc + 8)
    定义 tex_data = 内存_读64(desc + 24)
    如果 (tex_data == 0 || tex_w == 0 || tex_h == 0) { 返回 }

    // 双线性缩放纹理到目标矩形
    定义 可变 py = y
    当 (py < y + h && py < dc.高度) {
        如果 (py >= 0) {
            定义 ty = (py - y) * tex_h / h
            如果 (ty >= tex_h) { ty = tex_h - 1 }
            定义 可变 px = x
            当 (px < x + w && px < dc.宽度) {
                如果 (px >= 0) {
                    定义 tx = (px - x) * tex_w / w
                    如果 (tx >= tex_w) { tx = tex_w - 1 }
                    定义 src = tex_data + (ty * tex_w + tx) * 4
                    定义 r = 内存_读8(src)
                    定义 g = 内存_读8(src + 1)
                    定义 b = 内存_读8(src + 2)
                    定义 a = 内存_读8(src + 3) * opacity / 10000

                    如果 (a > 0) {
                        定义 dst = dc.帧缓冲 + (py * dc.宽度 + px) * 4
                        如果 (a >= 255) {
                            内存_写8(dst, r); 内存_写8(dst + 1, g)
                            内存_写8(dst + 2, b); 内存_写8(dst + 3, 255)
                        } 否则 {
                            定义 inv = 255 - a
                            内存_写8(dst, (r * a + 内存_读8(dst) * inv) / 255)
                            内存_写8(dst + 1, (g * a + 内存_读8(dst + 1) * inv) / 255)
                            内存_写8(dst + 2, (b * a + 内存_读8(dst + 2) * inv) / 255)
                            内存_写8(dst + 3, 255)
                        }
                    }
                }
                px = px + 1
            }
        }
        py = py + 1
    }
}

函数 显示合成器_提交(dc) {
    // 通过DRM/KMS提交帧缓冲到显示器
    如果 (dc.drm_fd >= 0) {
        // DRM page flip
        系统调用_Nova设备控制(dc.drm_fd, 0xC01064AE, dc.帧缓冲)  // DRM_Nova设备控制_MODE_PAGE_FLIP
    } 否则 {
        // 写入Linux帧缓冲设备
        定义 fb_fd = 系统调用_open("/dev/fb0", O_RDWR)
        如果 (fb_fd >= 0) {
            定义 wb = 系统调用_write(fb_fd, dc.帧缓冲, dc.宽度 * dc.高度 * 4)
            如果 (wb < 0) { 内核警告("帧缓冲写入失败") }
            系统调用_close(fb_fd)
        }
    }
}

定义 可变 AI_显示合成器_帧率窗口 = []

函数 AI_显示合成器_帧率预测(当前帧耗时) {
    追加(AI_显示合成器_帧率窗口, 当前帧耗时)
    如果 (计数(AI_显示合成器_帧率窗口) > 30) { 列表_移除(AI_显示合成器_帧率窗口, 0) }
    如果 (计数(AI_显示合成器_帧率窗口) < 3) { 返回 60 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(AI_显示合成器_帧率窗口)) { 总 = 总 + AI_显示合成器_帧率窗口[i]; i = i + 1 }
    定义 平均帧耗时 = 总 / 计数(AI_显示合成器_帧率窗口)
    如果 (平均帧耗时 == 0) { 返回 60 }
    返回 1000 / 平均帧耗时
}

函数 AI_显示合成器_质量降级建议(帧率) {
    如果 (帧率 < 30) { 返回 "降低分辨率" }
    如果 (帧率 < 45) { 返回 "跳过阴影" }
    返回 "全质量"
}

// Nova · 跨语言语言前端 · Rust
// 职责: 解析Rust源文件骨架,提取类型/函数/trait/impl/mod信息
// 层级: 跨语言主线第4步 — 语言骨架解析(Rust)

// Rust声明类型

导入("../../../../标准库/基础.nova")
导入("../../统一语义/统一语义图.nova")

定义 Rust声明_函数    = 0
定义 Rust声明_结构    = 1
定义 Rust声明_枚举    = 2
定义 Rust声明_Trait   = 3
定义 Rust声明_Impl    = 4
定义 Rust声明_模块    = 5
定义 Rust声明_类型别名 = 6
定义 Rust声明_常量    = 7
定义 Rust声明_Use     = 8

// Rust声明节点: [类型, 名称, 可见性, 泛型参数, 生命周期, 属性列表, 行号]
函数 Rust声明_创建(类型, 名称, 可见性) {
    返回 [类型, 名称, 可见性, [], [], [], 0]
}

函数 Rust声明_类型(d) { 返回 d[0] }
函数 Rust声明_名称(d) { 返回 d[1] }
函数 Rust声明_可见性(d) { 返回 d[2] }
函数 Rust声明_泛型(d) { 返回 d[3] }
函数 Rust声明_生命周期(d) { 返回 d[4] }

// Rust模块解析结果: [路径, 声明列表, use列表, 子模块列表, 诊断]
函数 Rust模块_创建(路径) {
    返回 [路径, [], [], [], []]
}

函数 Rust模块_声明(m) { 返回 m[1] }
函数 Rust模块_Use(m) { 返回 m[2] }
函数 Rust模块_子模块(m) { 返回 m[3] }

// 骨架解析: 提取pub fn/struct/enum/trait/impl/mod/type/const
函数 Rust前端_解析骨架(源码, 文件路径) {
    定义 模块 = Rust模块_创建(文件路径)
    定义 可变 位置 = 0
    定义 总长 = 字节长度(源码)
    定义 可变 行号 = 1

    当 (位置 < 总长) {
        // 跳到行首关键字
        当 (行尾 < 总长 且 字节取(源码, 行尾) != 字符_换行) { 行尾 = 行尾 + 1 }
        定义 行 = 子串(源码, 位置, 行尾 - 位置)
        位置 = 行尾 + 1

        // 去首空白
        定义 已裁剪 = _Rust_去首空白(行)
        定义 可见 = _Rust_检查可见性(已裁剪)

        如果 (_Rust_行开头(已裁剪, "fn ") 或 _Rust_行开头(已裁剪, "pub fn ") 或 _Rust_行开头(已裁剪, "pub(crate) fn ")) {
            定义 名 = _Rust_提取函数名(已裁剪)
            定义 声明 = Rust声明_创建(Rust声明_函数, 名, 可见)
            声明[6] = 行号
            追加(模块[1], 声明)
        }
        如果 (_Rust_行开头(已裁剪, "struct ") 或 _Rust_行开头(已裁剪, "pub struct ")) {
            定义 名 = _Rust_提取类型名(已裁剪, "struct ")
            定义 声明 = Rust声明_创建(Rust声明_结构, 名, 可见)
            声明[6] = 行号
            追加(模块[1], 声明)
        }
        如果 (_Rust_行开头(已裁剪, "enum ") 或 _Rust_行开头(已裁剪, "pub enum ")) {
            定义 名 = _Rust_提取类型名(已裁剪, "enum ")
            定义 声明 = Rust声明_创建(Rust声明_枚举, 名, 可见)
            声明[6] = 行号
            追加(模块[1], 声明)
        }
        如果 (_Rust_行开头(已裁剪, "trait ") 或 _Rust_行开头(已裁剪, "pub trait ")) {
            定义 名 = _Rust_提取类型名(已裁剪, "trait ")
            定义 声明 = Rust声明_创建(Rust声明_Trait, 名, 可见)
            声明[6] = 行号
            追加(模块[1], 声明)
        }
        如果 (_Rust_行开头(已裁剪, "impl ") 或 _Rust_行开头(已裁剪, "impl<")) {
            定义 名 = _Rust_提取impl名(已裁剪)
            定义 声明 = Rust声明_创建(Rust声明_Impl, 名, "")
            声明[6] = 行号
            追加(模块[1], 声明)
        }
        如果 (_Rust_行开头(已裁剪, "mod ") 或 _Rust_行开头(已裁剪, "pub mod ")) {
            定义 名 = _Rust_提取类型名(已裁剪, "mod ")
            追加(模块[3], 名)
        }
        如果 (_Rust_行开头(已裁剪, "use ") 或 _Rust_行开头(已裁剪, "pub use ")) {
            追加(模块[2], 已裁剪)
        }

        行号 = 行号 + 1
    }
    返回 模块
}

// 转换为统一语义节点
函数 Rust前端_到语义图(模块, 语义图) {
    定义 声明列表 = 模块[1]
    定义 可变 i = 0
    当 (i < 计数(声明列表)) {
        定义 d = 声明列表[i]
        定义 可变 类别 = 0  // 语义_类型
        如果 (d[0] == Rust声明_函数) { 类别 = 4 }  // 语义_资源(函数作为资源)
        定义 节点 = 语义节点_创建(类别, d[0], d[1])
        语义节点_设源位置(节点, 模块[0])
        如果 (d[2] == "pub") {
            语义节点_添加属性(节点, "可见性", "公共")
        }
        语义图_添加节点(语义图, 节点)
        i = i + 1
    }
}

// Rust报告
函数 Rust模块_打印(模块) {
    打印文本(字符串拼接("═══ Rust模块: ", 模块[0]))
    打印文本(字符串拼接("  声明数: ", 转字符串(计数(模块[1]))))
    打印文本(字符串拼接("  use数: ", 转字符串(计数(模块[2]))))
    打印文本(字符串拼接("  子模块数: ", 转字符串(计数(模块[3]))))
}

// 辅助函数
函数 _Rust_去首空白(s) {
    定义 可变 i = 0
    定义 l = 字节长度(s)
    当 (i < l 且 (字节取(s, i) == 字符_空格 或 字节取(s, i) == 字符_制表)) { i = i + 1 }
    如果 (i >= l) { 返回 "" }
    返回 子串(s, i, l - i)
}

函数 _Rust_检查可见性(行) {
    如果 (_Rust_行开头(行, "pub ") 或 _Rust_行开头(行, "pub(")) { 返回 "pub" }
    返回 ""
}

函数 _Rust_行开头(行, 前缀) {
    定义 pl = 字节长度(前缀)
    如果 (字节长度(行) < pl) { 返回 假 }
    返回 子串(行, 0, pl) == 前缀
}

函数 _Rust_提取函数名(行) {
    // 找到 "fn " 后的标识符
    定义 可变 位置 = 0
    定义 l = 字节长度(行)
    当 (位置 < l - 2) {
        如果 (字节取(行, 位置) == 字符_小写f 且 字节取(行, 位置 + 1) == 字符_小写n 且 字节取(行, 位置 + 2) == 字符_空格) {
            // 'f' 'n' ' '
            位置 = 位置 + 3
            定义 起 = 位置
            当 (位置 < l 且 字节取(行, 位置) != 字符_左圆括 且 字节取(行, 位置) != 字符_小于号 且 字节取(行, 位置) != 字符_空格) { 位置 = 位置 + 1 }
            返回 子串(行, 起, 位置 - 起)
        }
        位置 = 位置 + 1
    }
    返回 "anonymous"
}

函数 _Rust_提取类型名(行, 关键字) {
    定义 可变 位置 = 0
    定义 l = 字节长度(行)
    定义 kl = 字节长度(关键字)
    当 (位置 < l - kl) {
        如果 (子串(行, 位置, kl) == 关键字) {
            位置 = 位置 + kl
            定义 起 = 位置
            当 (位置 < l 且 字节取(行, 位置) != 字符_空格 且 字节取(行, 位置) != 字符_小于号 且 字节取(行, 位置) != 字符_左圆括 且 字节取(行, 位置) != 字符_左花括 且 字节取(行, 位置) != 字符_分号) { 位置 = 位置 + 1 }
            返回 子串(行, 起, 位置 - 起)
        }
        位置 = 位置 + 1
    }
    返回 "unknown"
}

函数 _Rust_提取impl名(行) {
    // impl Trait for Type 或 impl Type
    定义 l = 字节长度(行)
    定义 可变 位置 = 5  // 跳过 "impl "
    如果 (字节取(行, 4) == 字符_小于号) { 位置 = 4 }  // impl<
    当 (位置 < l 且 字节取(行, 位置) == 字符_空格) { 位置 = 位置 + 1 }
    定义 起 = 位置
    当 (位置 < l 且 字节取(行, 位置) != 字符_空格 且 字节取(行, 位置) != 字符_左花括 且 字节取(行, 位置) != 字符_小于号) { 位置 = 位置 + 1 }
    返回 子串(行, 起, 位置 - 起)
}

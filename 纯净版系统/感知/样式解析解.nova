函数 CSSParser_解析声明(tk, 属性名令牌) {
    // 解析: property-name: value [!important] ;
    定义 声明 = 堆_分配(CSS声明)
    声明.属性ID = CSSParser_属性名转ID(属性名令牌.值, 属性名令牌.值长度)
    声明.重要 = 假

    // 期望':'
    定义 令牌 = 堆_分配(CSS令牌)
    CSS令牌izer_下一个令牌(tk, 令牌)
    如果 (令牌.类型 != CSS_令牌_冒号) { 返回 0 }

    // 读属性值
    定义 值 = CSSParser_解析值(tk)
    声明.值 = 值

    返回 声明
}

函数 CSSParser_解析值(tk) {
    定义 值 = 堆_分配(CSSValue)
    定义 令牌 = 堆_分配(CSS令牌)
    CSS令牌izer_下一个令牌(tk, 令牌)

    如果 (令牌.类型 == CSS_令牌_尺寸) {
        值.类型 = CSS值_长度
        值.数值 = 令牌.数值
        值.单位 = CSSParser_解析单位(令牌.单位, 令牌.单位长度)
        返回 值
    }
    如果 (令牌.类型 == CSS_令牌_百分比) {
        值.类型 = CSS值_百分比
        值.数值 = 令牌.数值
        值.单位 = 单位_百分比
        返回 值
    }
    如果 (令牌.类型 == CSS_令牌_数字) {
        值.类型 = CSS值_数字
        值.数值 = 令牌.数值
        返回 值
    }
    如果 (令牌.类型 == CSS_令牌_哈希) {
        值.类型 = CSS值_颜色
        值.颜色 = CSSParser_解析十六进制颜色(令牌.值, 令牌.值长度)
        返回 值
    }
    如果 (令牌.类型 == CSS_令牌_标识符) {
        // 关键字值或命名颜色
        值.类型 = CSS值_关键字
        值.字符串值 = 字符串_复制_N(令牌.值, 令牌.值长度)
        值.关键字ID = CSSParser_关键字转ID(令牌.值, 令牌.值长度)
        // 检查是否是命名颜色
        定义 颜色 = CSSParser_命名颜色(令牌.值, 令牌.值长度)
        如果 (颜色 != 0) {
            值.类型 = CSS值_颜色
            值.颜色 = 颜色
        }
        返回 值
    }
    如果 (令牌.类型 == CSS_令牌_函数) {
        值.类型 = CSS值_函数
        值.字符串值 = 字符串_复制_N(令牌.值, 令牌.值长度)
        // 读到')'
        定义 可变 深度 = 1
        当 (深度 > 0) {
            CSS令牌izer_下一个令牌(tk, 令牌)
            如果 (令牌.类型 == CSS_令牌_左圆括号) { 深度 = 深度 + 1 }
            如果 (令牌.类型 == CSS_令牌_右圆括号) { 深度 = 深度 - 1 }
            如果 (令牌.类型 == CSS_令牌_EOF) { 跳出 }
        }
        返回 值
    }
    如果 (令牌.类型 == CSS_令牌_字符串) {
        值.类型 = CSS值_字符串
        值.字符串值 = 字符串_复制_N(令牌.值, 令牌.值长度)
        返回 值
    }

    返回 值
}

// §3 辅助: 属性名→ID / 单位解析 / 颜色解析 / 特异度计算

函数 CSSParser_属性名转ID(名, 长度) {
    // 将属性名字符串映射到CSS属性ID
    如果 (字符串_等于N(名, 长度, "display")) { 返回 CSS属性_display }
    如果 (字符串_等于N(名, 长度, "position")) { 返回 CSS属性_position }
    如果 (字符串_等于N(名, 长度, "width")) { 返回 CSS属性_width }
    如果 (字符串_等于N(名, 长度, "height")) { 返回 CSS属性_height }
    如果 (字符串_等于N(名, 长度, "margin")) { 返回 CSS属性_margin }
    如果 (字符串_等于N(名, 长度, "margin-top")) { 返回 CSS属性_margin_top }
    如果 (字符串_等于N(名, 长度, "margin-right")) { 返回 CSS属性_margin_right }
    如果 (字符串_等于N(名, 长度, "margin-bottom")) { 返回 CSS属性_margin_bottom }
    如果 (字符串_等于N(名, 长度, "margin-left")) { 返回 CSS属性_margin_left }
    如果 (字符串_等于N(名, 长度, "padding")) { 返回 CSS属性_padding }
    如果 (字符串_等于N(名, 长度, "padding-top")) { 返回 CSS属性_padding_top }
    如果 (字符串_等于N(名, 长度, "padding-right")) { 返回 CSS属性_padding_right }
    如果 (字符串_等于N(名, 长度, "padding-bottom")) { 返回 CSS属性_padding_bottom }
    如果 (字符串_等于N(名, 长度, "padding-left")) { 返回 CSS属性_padding_left }
    如果 (字符串_等于N(名, 长度, "color")) { 返回 CSS属性_color }
    如果 (字符串_等于N(名, 长度, "background")) { 返回 CSS属性_background }
    如果 (字符串_等于N(名, 长度, "background-color")) { 返回 CSS属性_background_color }
    如果 (字符串_等于N(名, 长度, "font-size")) { 返回 CSS属性_font_size }
    如果 (字符串_等于N(名, 长度, "font-weight")) { 返回 CSS属性_font_weight }

函数 指令编码_编码_not_16b(d, n) { 返回 0x6E205800|((n&31)<<5)|(d&31) }
// CMEQ/CMGT/CMGE Vd.4S — 整数比较
函数 指令编码_编码_cmeq_4s(d, n, m) { 返回 0x6EA08C00|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_cmgt_4s(d, n, m) { 返回 0x4EA03400|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_cmge_4s(d, n, m) { 返回 0x4EA03C00|((m&31)<<16)|((n&31)<<5)|(d&31) }
// SHL/USHR Vd.4S, Vn.4S, #imm — 移位
函数 指令编码_编码_shl_4s(d, n, 移位) { 返回 0x4F205400|((32+移位)<<16)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_ushr_4s(d, n, 移位) { 返回 0x6F200400|((64-移位)<<16)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_sshr_4s(d, n, 移位) { 返回 0x4F200400|((64-移位)<<16)|((n&31)<<5)|(d&31) }
// DUP Vd.4S, Xn — 广播标量
函数 指令编码_编码_dup_4s(d, n) { 返回 0x4E040C00|((n&31)<<5)|(d&31) }
// INS Vd.S[idx], Xn — 插入元素
函数 指令编码_编码_ins_s(d, idx, n) { 返回 0x4E041C00|((idx&3)<<19)|((n&31)<<5)|(d&31) }
// UMOV Xd, Vn.S[idx] — 提取元素
函数 指令编码_编码_umov_s(d, n, idx) { 返回 0x0E043C00|((idx&3)<<19)|((n&31)<<5)|(d&31) }

导入("../../标准库/基础.nova")
导入("../../编译器/标记常量.nova")

// Nova 原生类型推断引擎 — 自动判断表达式的数据类型，不需手动标注
// 职责：类型常量定义、兄容性判断、运算结果类型、约束求解、泛型实例
// 层级：第3层语义分析

// 类型常量
定义 型_未知   = 0
定义 型_整数   = 1
定义 型_浮点   = 2
定义 型_字符串 = 3
定义 型_布尔   = 4
定义 型_列表   = 5
定义 型_字典   = 6
定义 型_函数   = 7
定义 型_空値   = 8
定义 型_任意   = 9
定义 型_无値   = 10
定义 型_错误   = 11

// 类型宽度 (字节)
函数 类型推断_类型宽度(t) {
    如果 (t == 型_整数) { 返回 8 }
    如果 (t == 型_浮点) { 返回 8 }
    如果 (t == 型_布尔) { 返回 1 }
    如果 (t == 型_字符串) { 返回 8 }
    如果 (t == 型_列表) { 返回 8 }
    如果 (t == 型_字典) { 返回 8 }
    如果 (t == 型_空値) { 返回 0 }
    返回 8
}

// 类型兼容
函数 类型推断_类型兼容(a, b) {
    如果 (a == b) { 返回 1 }
    如果 (a == 型_任意) { 返回 1 }
    如果 (b == 型_任意) { 返回 1 }
    如果 (a == 型_未知) { 返回 1 }
    如果 (b == 型_未知) { 返回 1 }
    如果 (a == 型_整数) { 如果 (b == 型_浮点) { 返回 1 } }
    如果 (a == 型_浮点) { 如果 (b == 型_整数) { 返回 1 } }
    如果 (b == 型_空値) {
        如果 (a == 型_字符串) { 返回 1 }
        如果 (a == 型_列表) { 返回 1 }
        如果 (a == 型_字典) { 返回 1 }
        如果 (a == 型_函数) { 返回 1 }
    }
    返回 0
}

// 二元运算结果类型
函数 类型推断_二元结果类型(运算符, 左类型, 右类型) {
    // 算术: +, -, *, /, %
    如果 (运算符 >= 30) {
        如果 (运算符 <= 34) {
            // 字符串拼接
            如果 (运算符 == 标记_加) {  // +
                如果 (左类型 == 型_字符串) { 返回 型_字符串 }
            }
            如果 (左类型 == 型_浮点) { 返回 型_浮点 }
            如果 (右类型 == 型_浮点) { 返回 型_浮点 }
            返回 型_整数
        }
    }
    // 比较: ==, !=, <, >, <=, >=
    如果 (运算符 >= 40) { 如果 (运算符 <= 45) { 返回 型_布尔 } }
    如果 (运算符 == 标记_且) { 返回 型_布尔 }
    如果 (运算符 == 标记_或) { 返回 型_布尔 }
    如果 (运算符 >= 标记_位与) { 如果 (运算符 <= 标记_右移) { 返回 型_整数 } }
    返回 型_未知
}

// 一元运算结果类型
函数 类型推断_一元结果类型(运算符, 操作数类型) {
    如果 (运算符 == 标记_减) { 返回 操作数类型 }  // -
    如果 (运算符 == 标记_非) { 返回 型_布尔 }     // !
    如果 (运算符 == 标记_位取反) { 返回 型_整数 }      // ~
    返回 型_未知
}

// 类型可赋値
函数 类型推断_可赋値(目标, 源) {
    返回 类型推断_类型兼容(目标, 源)
}

// 是否数値类型
函数 类型推断_是数値(t) {
    如果 (t == 型_整数) { 返回 1 }
    如果 (t == 型_浮点) { 返回 1 }
    返回 0
}

// 是否引用类型
函数 类型推断_是引用(t) {
    如果 (t == 型_字符串) { 返回 1 }
    如果 (t == 型_列表) { 返回 1 }
    如果 (t == 型_字典) { 返回 1 }
    如果 (t == 型_函数) { 返回 1 }
    返回 0
}

// 类型合并 (两分支结果类型)
函数 类型推断_合并类型(a, b) {
    如果 (a == b) { 返回 a }
    如果 (a == 型_未知) { 返回 b }
    如果 (b == 型_未知) { 返回 a }
    如果 (类型推断_是数値(a) == 1 且 类型推断_是数値(b) == 1) { 返回 型_浮点 }
    返回 型_任意
}

// 一致性验证说明
// 验证函数位于 模块图编译器.nova TI_副本区域末尾 (函数名: TI_验证一致性)
// 原因: 需同时访问本模块的 类型兼容(0, 0) 和内联副本的 TI_类型兼容(0, 0)
//       但两者存在 可赋値/是引用/合并类型 命名冲突, 无法导入共存
//       故验证函数放在主编译器中, 通过 --opt 1 以上自动运行

// 类型约束系统

定义 可变 _约束_左 = []
定义 可变 _约束_右 = []
定义 可变 _约束_种类 = []  // 0=相等, 1=子类型

函数 约束_添加相等(类型A, 类型B) {
    追加(_约束_左, 类型A)
    追加(_约束_右, 类型B)
    追加(_约束_种类, 0)
}

函数 约束_添加子类型(子类型, 父类型) {
    追加(_约束_左, 子类型)
    追加(_约束_右, 父类型)
    追加(_约束_种类, 1)
}

函数 约束_数量() { 返回 计数(_约束_左) }

函数 约束_清空() {
    _约束_左 = []
    _约束_右 = []
    _约束_种类 = []
}

// 类型变量

定义 可变 _类型变量_名 = []
定义 可变 _类型变量_绑定 = []
定义 可变 _下一类型变量 = 0

函数 新类型变量() {
    定义 名 = "T" + 转字符串(_下一类型变量)
    追加(_类型变量_名, 名)
    追加(_类型变量_绑定, 型_未知)
    _下一类型变量 = _下一类型变量 + 1
    返回 计数(_类型变量_名) - 1
}

函数 类型变量_绑定(idx) { 返回 _类型变量_绑定[idx] }

函数 类型变量_设绑定(idx, 类型) { _类型变量_绑定[idx] = 类型 }

函数 类型变量_已绑定(idx) { 返回 _类型变量_绑定[idx] != 型_未知 }

函数 类型变量_解析(idx) {
    定义 可变 当前 = idx
    当 (当前 < 计数(_类型变量_绑定) 且 _类型变量_绑定[当前] != 型_未知) {
        // 路径压缩
        如果 (_类型变量_绑定[当前] < 计数(_类型变量_绑定)) {
            当前 = _类型变量_绑定[当前]
        } 否则 { 返回 _类型变量_绑定[当前] }
    }
    返回 型_未知
}

// 统一算法

函数 类型_统一(A型, B型) {
    如果 (A型 == B型) { 返回 真 }
    如果 (A型 == 型_未知) { 返回 真 }
    如果 (B型 == 型_未知) { 返回 真 }
    如果 (A型 == 型_任意 或 B型 == 型_任意) { 返回 真 }
    如果 (类型推断_是数値(A型) == 1 且 类型推断_是数値(B型) == 1) { 返回 真 }
    返回 假
}

函数 约束_求解() {
    定义 可变 变化 = 真
    定义 可变 迭代 = 0
    当 (变化 且 迭代 < 100) {
        变化 = 假
        定义 可变 i = 0
        当 (i < 计数(_约束_左)) {
            定义 左 = _约束_左[i]
            定义 右 = _约束_右[i]
            如果 (_约束_种类[i] == 0) {
                // 相等约束
                如果 (左 < 计数(_类型变量_绑定) 且 !类型变量_已绑定(左)) {
                    类型变量_设绑定(左, 右)
                    变化 = 真
                }
                如果 (右 < 计数(_类型变量_绑定) 且 !类型变量_已绑定(右)) {
                    类型变量_设绑定(右, 左)
                    变化 = 真
                }
            }
            i = i + 1
        }
        迭代 = 迭代 + 1
    }
    返回 迭代 < 100
}

// 上下文推断

函数 推断_赋値类型(左类型, 右表达式类型) {
    如果 (左类型 == 型_未知) { 返回 右表达式类型 }
    如果 (类型_统一(左类型, 右表达式类型)) { 返回 左类型 }
    返回 型_任意
}

函数 推断_返回类型(分支类型列表) {
    如果 (计数(分支类型列表) == 0) { 返回 型_未知 }
    定义 可变 结果 = 分支类型列表[0]
    定义 可变 i = 1
    当 (i < 计数(分支类型列表)) {
        结果 = 类型推断_合并类型(结果, 分支类型列表[i])
        i = i + 1
    }
    返回 结果
}

函数 推断_条件类型(_条件类型, 真分支类型, 假分支类型) {
    返回 类型推断_合并类型(真分支类型, 假分支类型)
}

// 泛型实例化

函数 类型推断_泛型_实例化(模板参数列表, 实际参数列表) {
    定义 可变 映射 = [[], []]  // [模板参数, 实际类型]
    定义 可变 i = 0
    当 (i < 计数(模板参数列表) 且 i < 计数(实际参数列表)) {
        追加(映射[0], 模板参数列表[i])
        追加(映射[1], 实际参数列表[i])
        i = i + 1
    }
    返回 映射
}

函数 泛型_替换(类型, 映射) {
    定义 可变 i = 0
    当 (i < 计数(映射[0])) {
        如果 (类型 == 映射[0][i]) { 返回 映射[1][i] }
        i = i + 1
    }
    返回 类型
}

定义 可变 _推断_总数 = 0
定义 可变 _推断_失败数 = 0
定义 可变 _推断_约束数 = 0

函数 类型推断_记录() { _推断_总数 = _推断_总数 + 1 }
函数 类型推断_记录失败() { _推断_失败数 = _推断_失败数 + 1 }
函数 类型推断_记录约束() { _推断_约束数 = _推断_约束数 + 1 }

// 类型系统 v2 — 联合类型 / 可空安全 / 泛型约束 / 类型别名

// 扩展类型常量
定义 型_联合   = 20   // 联合类型: 整数|字符串
定义 型_可空   = 21   // 可空类型: ?整数 ≡ 整数|空
定义 型_泛型参  = 22   // 泛型参数: T
定义 型_别名   = 23   // 类型别名: 类型 名称 = 原类型
定义 型_约束泛  = 24   // 受约束泛型: T:数值
定义 型_元组   = 25   // 元组: (整数, 字符串)
定义 型_结果   = 26   // 结果类型: 结果<T, E>

// 联合类型 (Union Type)
// 表示: [型_联合, [成员类型列表]]
// 例: 整数|字符串|空 → [型_联合, [型_整数, 型_字符串, 型_空値]]

函数 联合类型_创建(类型列表) {
    // 去重+展平嵌套联合
    定义 可变 扁平 = []
    定义 可变 i = 0
    当 (i < 计数(类型列表)) {
        定义 t = 类型列表[i]
        如果 (是列表(t) 且 计数(t) > 0 且 t[0] == 型_联合) {
            // 展平嵌套联合
            定义 可变 j = 0
            当 (j < 计数(t[1])) {
                定义 可变 已有 = 假
                定义 可变 k = 0
                当 (k < 计数(扁平)) {
                    如果 (扁平[k] == t[1][j]) { 已有 = 真 }
                    k = k + 1
                }
                如果 (已有 == 假) { 追加(扁平, t[1][j]) }
                j = j + 1
            }
        } 否则 {
            定义 可变 已有 = 假
            定义 可变 k = 0
            当 (k < 计数(扁平)) {
                如果 (扁平[k] == t) { 已有 = 真 }
                k = k + 1
            }
            如果 (已有 == 假) { 追加(扁平, t) }
        }
        i = i + 1
    }
    如果 (计数(扁平) == 1) { 返回 扁平[0] }
    返回 [型_联合, 扁平]
}

函数 联合类型_包含(联合, 目标类型) {
    如果 (是列表(联合) == 假 或 计数(联合) < 2) { 返回 联合 == 目标类型 }
    如果 (联合[0] != 型_联合) { 返回 联合 == 目标类型 }
    定义 可变 i = 0
    当 (i < 计数(联合[1])) {
        如果 (联合[1][i] == 目标类型) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// 联合类型兼容: A <: B 当且仅当 A的每个成员都在B中
函数 联合类型_兼容(子类型, 超类型) {
    如果 (是列表(子类型) == 假 或 子类型[0] != 型_联合) {
        返回 联合类型_包含(超类型, 子类型)
    }
    定义 可变 i = 0
    当 (i < 计数(子类型[1])) {
        如果 (联合类型_包含(超类型, 子类型[1][i]) == 假) { 返回 假 }
        i = i + 1
    }
    返回 真
}

// 可空安全 (Nullable Safety)
// ?T ≡ T | 空
// 解引用?T前必须做空检查, 编译器静态验证
函数 可空类型_创建(基础类型) {
    返回 联合类型_创建([基础类型, 型_空値])
}

函数 可空类型_是可空(类型) {
    返回 联合类型_包含(类型, 型_空値)
}

// 可空安全检查结果
定义 空安全_安全 = 0        // 已检查或不可空
定义 空安全_未检查 = 1     // ?T未经空检查直接使用
定义 空安全_已窄化 = 2     // 通过if(x != 空)窄化为T

// 窄化: if(x != 空) 分支内, ?T → T
函数 可空类型_窄化(联合类型) {
    如果 (是列表(联合类型) == 假 或 联合类型[0] != 型_联合) {
        如果 (联合类型 == 型_空値) { 返回 型_无値 }
        返回 联合类型
    }
    定义 可变 非空 = []
    定义 可变 i = 0
    当 (i < 计数(联合类型[1])) {
        如果 (联合类型[1][i] != 型_空値) {
            追加(非空, 联合类型[1][i])
        }
        i = i + 1
    }
    如果 (计数(非空) == 0) { 返回 型_无値 }
    如果 (计数(非空) == 1) { 返回 非空[0] }
    返回 [型_联合, 非空]
}

// 泛型约束 (Bounded Generics)
// 约束种类
定义 约束_无     = 0
定义 约束_数值   = 1    // T: 数值 (整数|浮点)
定义 约束_可迭代 = 2    // T: 可迭代 (列表|字符串|字典)
定义 约束_可比较 = 3    // T: 可比较 (支持 == < >)
定义 约束_可哈希 = 4    // T: 可哈希 (整数|字符串|布尔)
定义 约束_具体类 = 5    // T: 某具体类型

// 约束定义: [约束种类, 约束值(可选)]
函数 泛型约束_创建(种类) { 返回 [种类, 型_任意] }
函数 泛型约束_具体(类型) { 返回 [约束_具体类, 类型] }

函数 泛型约束_满足(约束, 实际类型) {
    定义 种类 = 约束[0]
    如果 (种类 == 约束_无) { 返回 真 }
    如果 (种类 == 约束_数值) {
        返回 实际类型 == 型_整数 或 实际类型 == 型_浮点
    }
    如果 (种类 == 约束_可迭代) {
        返回 实际类型 == 型_列表 或 实际类型 == 型_字符串 或 实际类型 == 型_字典
    }
    如果 (种类 == 约束_可比较) {
        返回 实际类型 == 型_整数 或 实际类型 == 型_浮点 或 实际类型 == 型_字符串 或 实际类型 == 型_布尔
    }
    如果 (种类 == 约束_可哈希) {
        返回 实际类型 == 型_整数 或 实际类型 == 型_字符串 或 实际类型 == 型_布尔
    }
    如果 (种类 == 约束_具体类) {
        返回 类型推断_类型兼容(实际类型, 约束[1])
    }
    返回 假
}

// 泛型参数表: [[参数名, 约束], ...]
定义 可变 泛型参数表 = []

函数 泛型_注册参数(名称, 约束) {
    追加(泛型参数表, [名称, 约束])
}

函数 泛型_查找约束(名称) {
    定义 可变 i = 计数(泛型参数表) - 1
    当 (i >= 0) {
        如果 (泛型参数表[i][0] == 名称) { 返回 泛型参数表[i][1] }
        i = i - 1
    }
    返回 泛型约束_创建(约束_无)
}

函数 泛型_实例化验证(名称, 实际类型) {
    定义 约束 = 泛型_查找约束(名称)
    返回 泛型约束_满足(约束, 实际类型)
}

// 类型别名 (Type Alias)
定义 可变 类型别名表 = []

函数 类型别名_注册(别名, 原类型) {
    追加(类型别名表, [别名, 原类型])
}

函数 类型别名_解析(名称) {
    定义 可变 i = 0
    定义 可变 深度 = 0
    当 (深度 < 10) {
        定义 可变 找到 = 假
        i = 0
        当 (i < 计数(类型别名表)) {
            如果 (类型别名表[i][0] == 名称) {
                名称 = 类型别名表[i][1]
                找到 = 真
            }
            i = i + 1
        }
        如果 (找到 == 假) { 返回 名称 }
        深度 = 深度 + 1
    }
    返回 名称
}

// 整数溢出静态检测
定义 INT64_上界 = 9223372036854775807

函数 溢出检测_加法(a, b) {
    如果 (b > 0 且 a > INT64_上界 - b) { 返回 真 }
    如果 (b < 0 且 a < (0 - INT64_上界 - 1) - b) { 返回 真 }
    返回 假
}

函数 溢出检测_乘法(a, b) {
    如果 (a == 0 或 b == 0) { 返回 假 }
    如果 (a > 0 且 b > 0 且 a > INT64_上界 / b) { 返回 真 }
    如果 (a < 0 且 b < 0 且 a < INT64_上界 / b) { 返回 真 }
    如果 (a > 0 且 b < 0 且 b < (0 - INT64_上界 - 1) / a) { 返回 真 }
    如果 (a < 0 且 b > 0 且 a < (0 - INT64_上界 - 1) / b) { 返回 真 }
    返回 假
}

函数 溢出检测_左移(值, 位数) {
    如果 (位数 < 0 或 位数 >= 63) { 返回 真 }
    如果 (值 > 0 且 值 > (INT64_上界 >> 位数)) { 返回 真 }
    返回 假
}

// 溢出警告收集
定义 可变 溢出警告列表 = []

函数 溢出警告_添加(行号, 运算, 左值, 右值) {
    追加(溢出警告列表, [行号, 运算, 左值, 右值])
}

函数 溢出警告_报告() {
    定义 可变 i = 0
    当 (i < 计数(溢出警告列表)) {
        定义 w = 溢出警告列表[i]
        打印("[溢出警告] 行" + 转字符串(w[0]) + ": " + w[1] + "运算可能溢出")
        i = i + 1
    }
    返回 计数(溢出警告列表)
}

// 结果类型 (Result<T, E>)
// 编码: [型_结果, 成功类型, 错误类型]
函数 结果类型_创建(成功类型, 错误类型) {
    返回 [型_结果, 成功类型, 错误类型]
}

函数 结果类型_成功类型(rt) { 返回 rt[1] }
函数 结果类型_错误类型(rt) { 返回 rt[2] }

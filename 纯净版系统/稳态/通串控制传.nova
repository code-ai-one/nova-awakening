导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")

定义 最大端口 = 16
定义 最大设备 = 127
定义 最大端点 = 32
定义 传输_控制 = 0
定义 传输_批量 = 1
定义 传输_中断 = 2
定义 传输_等时 = 3
定义 速度_低 = 0
定义 速度_全 = 1
定义 速度_高 = 2
定义 速度_超 = 3

结构 通串设备 {
    地址,
    速度,
    端口号,
    厂商标识,
    产品标识,
    设备类,
    配置数,
    当前配置,
    端点数,
    已枚举,
}

结构 通串端点 {
    设备地址,
    端点号,
    方向,
    传输类型,
    最大包大小,
    间隔,
    活跃,
    传输字节,
    错误数,
}

定义 可变 控制器基址 = 0
定义 可变 设备表 = []
定义 可变 设备数 = 0
定义 可变 端点表 = []
定义 可变 端点数 = 0
定义 可变 下一地址 = 1
定义 可变 控制传输数 = 0
定义 可变 批量传输数 = 0
定义 可变 中断传输数 = 0
定义 可变 总传输字节 = 0
定义 可变 错误总数 = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 通串_初始化(基址) {
    控制器基址 = 基址
    设备表 = []
    设备数 = 0
    端点表 = []
    端点数 = 0
    下一地址 = 1
    通串_写寄存器(0x00, 通串_读寄存器(0x00) | 2)
    定义 可变 等待 = 0
    当 (等待 < 100000 && (通串_读寄存器(0x00) & 2) != 0) { 等待 = 等待 + 1 }
    通串_写寄存器(0x38, 通串_读寄存器(0x38) | 1)
}

函数 通串_读寄存器(偏移) {
    返回 内存_读32(控制器基址 + 偏移)
}

函数 通串_写寄存器(偏移, 值) {
    内存_写32(控制器基址 + 偏移, 值)
}

函数 通串_枚举端口(端口号) {
    如果 (端口号 >= 最大端口) { 返回 -1 }
    定义 端口偏移 = 0x400 + 端口号 * 0x10
    定义 端口状态 = 通串_读寄存器(端口偏移)
    如果 ((端口状态 & 1) == 0) { 返回 -1 }
    通串_写寄存器(端口偏移, 端口状态 | (1 << 4))
    通串_延迟(50)
    通串_写寄存器(端口偏移, 端口状态 & ~(1 << 4))
    通串_延迟(100)
    如果 (设备数 >= 最大设备) { 返回 错误_无资源 }
    定义 设备 = 通串设备 {}
    设备.地址 = 下一地址
    下一地址 = 下一地址 + 1
    设备.速度 = (端口状态 >> 10) & 3
    设备.端口号 = 端口号
    设备.厂商标识 = 0
    设备.产品标识 = 0
    设备.设备类 = 0
    设备.配置数 = 0
    设备.当前配置 = 0
    设备.端点数 = 0
    设备.已枚举 = 假
    追加(设备表, 设备)
    定义 索引 = 设备数
    设备数 = 设备数 + 1
    通串_获取设备描述(索引)
    设备.已枚举 = 真
    返回 索引
}

函数 通串_控制传输(设备索引, 请求类型, 请求, 值, 索引, 长度, 数据) {
    如果 (设备索引 >= 设备数) { 返回 错误_无效参数 }
    控制传输数 = 控制传输数 + 1
    定义 设置包 = 堆_分配(8)
    内存_写8(设置包, 请求类型)
    内存_写8(设置包 + 1, 请求)
    内存_写16(设置包 + 2, 值)
    内存_写16(设置包 + 4, 索引)
    内存_写16(设置包 + 6, 长度)
    定义 结果 = 通串_提交传输(设备表[设备索引].地址, 0, 传输_控制, 设置包, 8, 数据, 长度)
    堆_释放(设置包)
    如果 (结果 < 0) { 错误总数 = 错误总数 + 1 }
    否则 { 总传输字节 = 总传输字节 + 长度 }
    返回 结果
}

函数 通串_批量传输(设备索引, 端点号, 方向, 数据, 长度) {
    如果 (设备索引 >= 设备数) { 返回 错误_无效参数 }
    批量传输数 = 批量传输数 + 1
    定义 结果 = 通串_提交传输(设备表[设备索引].地址, 端点号, 传输_批量, 0, 0, 数据, 长度)
    如果 (结果 >= 0) { 总传输字节 = 总传输字节 + 长度 }
    否则 { 错误总数 = 错误总数 + 1 }
    返回 结果
}

函数 通串_中断传输(设备索引, 端点号, 数据, 长度) {
    如果 (设备索引 >= 设备数) { 返回 错误_无效参数 }
    中断传输数 = 中断传输数 + 1
    返回 通串_提交传输(设备表[设备索引].地址, 端点号, 传输_中断, 0, 0, 数据, 长度)
}

函数 通串_提交传输(地址, 端点, 类型, 设置, 设置长, 数据, 数据长) {
    返回 数据长
}

函数 通串_获取设备描述(设备索引) {
    定义 缓冲 = 堆_分配(18)
    定义 结果 = 通串_控制传输(设备索引, 0x80, 6, 0x0100, 0, 18, 缓冲)
    如果 (结果 >= 0) {
        设备表[设备索引].厂商标识 = 内存_读16(缓冲 + 8)
        设备表[设备索引].产品标识 = 内存_读16(缓冲 + 10)
        设备表[设备索引].设备类 = 内存_读8(缓冲 + 4)
        设备表[设备索引].配置数 = 内存_读8(缓冲 + 17)
    }
    堆_释放(缓冲)
}

函数 通串_延迟(毫秒) {
    定义 可变 计 = 0
    当 (计 < 毫秒 * 1000) { 计 = 计 + 1 }
}

函数 通串_获取设备数() { 返回 设备数 }

函数 通串_获取设备信息(索引) {
    如果 (索引 >= 设备数) { 返回 [0, 0, 0, 0] }
    返回 [设备表[索引].地址, 设备表[索引].厂商标识, 设备表[索引].产品标识, 设备表[索引].设备类]
}

函数 通串_完整统计() {
    返回 [设备数, 控制传输数, 批量传输数, 中断传输数, 总传输字节, 错误总数]
}

定义 可变 AI_通串控制传_风暴阈值 = 10000
定义 可变 AI_通串控制传_预测IRQ = 0

函数 AI_通串控制传_风暴检测(触发频率) {
    如果 (触发频率 > AI_通串控制传_风暴阈值) {
        AI_通串控制传_风暴阈值 = AI_通串控制传_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_通串控制传_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

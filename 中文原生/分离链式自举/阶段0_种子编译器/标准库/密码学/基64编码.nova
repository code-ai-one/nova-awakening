导入("../基础.nova")

//
// Nova 标准库 密码学 Base64编解码
// RFC 4648 标准编码 二进制与文本互转

// 编码表
定义 编码_标准表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
定义 编码_安全表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"
定义 编码_填充符 = "="

// 统计
定义 可变 编码_编码次数 = 0
定义 可变 编码_解码次数 = 0
定义 可变 编码_处理字节 = 0
定义 可变 编码_输出字节 = 0

函数 编码_统计报告() { 返回 [编码_编码次数, 编码_解码次数, 编码_处理字节, 编码_输出字节]
}

// 编码字符查找

函数 base64_编码字符(索引, 表) {
    如果 (索引 >= 0 且 索引 < 64) { 返回 子串(表, 索引, 1)
}
 返回 编码_填充符
}

函数 base64_解码字符(字符码) {
    如果 (字符码 >= 字符_大写A 且 字符码 <= 字符_大写Z) { 返回 字符码 - 65
}
 如果 (字符码 >= 字符_小写a 且 字符码 <= 字符_小写z) { 返回 字符码 - 71 }
 如果 (字符码 >= 字符_零 且 字符码 <= 字符_九) { 返回 字符码 + 4 }
 如果 (字符码 == 字符_加号 或 字符码 == 字符_减号) { 返回 62 }
 如果 (字符码 == 字符_斜杠 或 字符码 == 字符_下划线) { 返回 63 }
 返回 0 - 1
}

函数 base64_是有效字符(字符码) {
    如果 (字符码 >= 字符_大写A 且 字符码 <= 字符_大写Z) { 返回 真
}
 如果 (字符码 >= 字符_小写a 且 字符码 <= 字符_小写z) { 返回 真 }
 如果 (字符码 >= 字符_零 且 字符码 <= 字符_九) { 返回 真 }
 如果 (字符码 == 字符_加号 或 字符码 == 字符_斜杠) { 返回 真 }
 如果 (字符码 == 字符_减号 或 字符码 == 字符_下划线) { 返回 真 }
 如果 (字符码 == 字符_等号) { 返回 真 }
 返回 假
}

// 标准Base64编码

函数 Base_base64_编码(数据) {
 编码_编码次数 = 编码_编码次数 + 1
 定义 可变 结果 = ""
 定义 可变 i = 0
 定义 长度 = 字节长度(数据)
 编码_处理字节 = 编码_处理字节 + 长度
 当 (i < 长度) { 定义 b0 = 字节取(数据, i)
 定义 可变 b1 = 0
 定义 可变 b2 = 0
 定义 可变 填充 = 0
 如果 (i + 1 < 长度) { b1 = 字节取(数据, i + 1) } 否则 { 填充 = 填充 + 1 }
 如果 (i + 2 < 长度) { b2 = 字节取(数据, i + 2) } 否则 { 填充 = 填充 + 1 }
 定义 n = b0 * 65536 + b1 * 256 + b2
 结果 = 结果 + base64_编码字符((n / 262144) % 64, 编码_标准表)
 结果 = 结果 + base64_编码字符((n / 4096) % 64, 编码_标准表)
 如果 (填充 < 2) {
 结果 = 结果 + base64_编码字符((n / 64) % 64, 编码_标准表)
 } 否则 { 结果 = 结果 + 编码_填充符 }
 如果 (填充 < 1) {
 结果 = 结果 + base64_编码字符(n % 64, 编码_标准表)
 } 否则 { 结果 = 结果 + 编码_填充符 }
 i = i + 3
 }
 编码_输出字节 = 编码_输出字节 + 计数(结果)
 返回 结果
}

// URL安全Base64编码

函数 base64_安全编码(数据) {
 编码_编码次数 = 编码_编码次数 + 1
 定义 可变 结果 = ""
 定义 可变 i = 0
 定义 长度 = 字节长度(数据)
 编码_处理字节 = 编码_处理字节 + 长度
 当 (i < 长度) { 定义 b0 = 字节取(数据, i)
 定义 可变 b1 = 0
 定义 可变 b2 = 0
 定义 可变 填充 = 0
 如果 (i + 1 < 长度) { b1 = 字节取(数据, i + 1) } 否则 { 填充 = 填充 + 1 }
 如果 (i + 2 < 长度) { b2 = 字节取(数据, i + 2) } 否则 { 填充 = 填充 + 1 }
 定义 n = b0 * 65536 + b1 * 256 + b2
 结果 = 结果 + base64_编码字符((n / 262144) % 64, 编码_安全表)
 结果 = 结果 + base64_编码字符((n / 4096) % 64, 编码_安全表)
 如果 (填充 < 2) {
 结果 = 结果 + base64_编码字符((n / 64) % 64, 编码_安全表)
 }
 如果 (填充 < 1) {
 结果 = 结果 + base64_编码字符(n % 64, 编码_安全表)
 }
 i = i + 3
 }
 编码_输出字节 = 编码_输出字节 + 计数(结果)
 返回 结果
}

// Base64解码

函数 Base_base64_解码(编码文本) {
 编码_解码次数 = 编码_解码次数 + 1
 定义 可变 结果 = []
 定义 可变 i = 0
 定义 长度 = 计数(编码文本)
 定义 可变 缓冲 = []
 当 (i < 长度) { 定义 字符码 = 编码(子串(编码文本, i, 1))
 如果 (字符码 == 字符_等号) { i = i + 1 续 }
 如果 (字符码 == 字符_换行 或 字符码 == 字符_回车 或 字符码 == 字符_空格) { i = i + 1 续 }
 定义 v = base64_解码字符(字符码)
 如果 (v < 0) { i = i + 1 续 }
 追加(缓冲, v)
 如果 (计数(缓冲) == 4) { 定义 n = 缓冲[0] * 262144 + 缓冲[1] * 4096 + 缓冲[2] * 64 + 缓冲[3]
 追加(结果, (n / 65536) % 256)
 追加(结果, (n / 256) % 256)
 追加(结果, n % 256)
 缓冲 = []
 }
 i = i + 1
 }
 如果 (计数(缓冲) == 3) { 定义 n = 缓冲[0] * 262144 + 缓冲[1] * 4096 + 缓冲[2] * 64
 追加(结果, (n / 65536) % 256)
 追加(结果, (n / 256) % 256)
 }
 如果 (计数(缓冲) == 2) { 定义 n = 缓冲[0] * 262144 + 缓冲[1] * 4096
 追加(结果, (n / 65536) % 256)
 }
 编码_处理字节 = 编码_处理字节 + 长度
 返回 结果
}

// 解码为字符串

函数 base64_解码为字符串(编码文本) { 定义 字节列表 = Base_base64_解码(编码文本)
 定义 可变 s = ""
 定义 可变 i = 0
 当 (i < 计数(字节列表)) {
 s = s + 字符(字节列表[i])
 i = i + 1
 }
 返回 s
}

// 流式编码器

函数 base64_创建编码器() { 返回 [[], "", 0, 假]
}

函数 base64_编码器_输入(编码器, 数据) {
    定义 可变 新缓冲 = []
    如果 (编码器[3]) { 返回
}
 定义 可变 i = 0
 当 (i < 字节长度(数据)) {
 追加(编码器[0], 字节取(数据, i))
 i = i + 1
 }
 当 (计数(编码器[0]) >= 3) { 定义 b0 = 编码器[0][0]
 定义 b1 = 编码器[0][1]
 定义 b2 = 编码器[0][2]
 定义 n = b0 * 65536 + b1 * 256 + b2
 编码器[1] = 编码器[1] + base64_编码字符((n / 262144) % 64, 编码_标准表)
 编码器[1] = 编码器[1] + base64_编码字符((n / 4096) % 64, 编码_标准表)
 编码器[1] = 编码器[1] + base64_编码字符((n / 64) % 64, 编码_标准表)
 编码器[1] = 编码器[1] + base64_编码字符(n % 64, 编码_标准表)
 定义 可变 j = 3
 当 (j < 计数(编码器[0])) { 追加(新缓冲, 编码器[0][j]) j = j + 1 }
 编码器[0] = 新缓冲
 编码器[2] = 编码器[2] + 3
 }
}

函数 base64_编码器_完成(编码器) {
 编码器[3] = 真
 定义 剩余 = 计数(编码器[0])
 如果 (剩余 == 1) { 定义 b0 = 编码器[0][0]
 定义 n = b0 * 65536
 编码器[1] = 编码器[1] + base64_编码字符((n / 262144) % 64, 编码_标准表)
 编码器[1] = 编码器[1] + base64_编码字符((n / 4096) % 64, 编码_标准表)
 编码器[1] = 编码器[1] + "=="
 }
 如果 (剩余 == 2) { 定义 b0 = 编码器[0][0]
 定义 b1 = 编码器[0][1]
 定义 n = b0 * 65536 + b1 * 256
 编码器[1] = 编码器[1] + base64_编码字符((n / 262144) % 64, 编码_标准表)
 编码器[1] = 编码器[1] + base64_编码字符((n / 4096) % 64, 编码_标准表)
 编码器[1] = 编码器[1] + base64_编码字符((n / 64) % 64, 编码_标准表)
 编码器[1] = 编码器[1] + "="
 }
 返回 编码器[1]
}

函数 base64_编码器_输出(编码器) { 返回 编码器[1] }

// 流式解码器

函数 base64_创建解码器() { 返回 [[], [], 0, 假]
}

函数 base64_解码器_输入(解码器, 文本) {
    定义 可变 新缓冲 = []
    如果 (解码器[3]) { 返回
}
 定义 可变 i = 0
 当 (i < 计数(文本)) { 定义 字符码 = 编码(子串(文本, i, 1))
 如果 (字符码 == 字符_等号 或 字符码 == 字符_换行 或 字符码 == 字符_回车 或 字符码 == 字符_空格) { i = i + 1 续 }
 定义 v = base64_解码字符(字符码)
 如果 (v >= 0) { 追加(解码器[0], v) }
 i = i + 1
 }
 当 (计数(解码器[0]) >= 4) { 定义 n = 解码器[0][0] * 262144 + 解码器[0][1] * 4096 + 解码器[0][2] * 64 + 解码器[0][3]
 追加(解码器[1], (n / 65536) % 256)
 追加(解码器[1], (n / 256) % 256)
 追加(解码器[1], n % 256)
 定义 可变 j = 4
 当 (j < 计数(解码器[0])) { 追加(新缓冲, 解码器[0][j]) j = j + 1 }
 解码器[0] = 新缓冲
 解码器[2] = 解码器[2] + 3
 }
}

函数 base64_解码器_完成(解码器) {
 解码器[3] = 真
 定义 剩余 = 计数(解码器[0])
 如果 (剩余 == 3) { 定义 n = 解码器[0][0] * 262144 + 解码器[0][1] * 4096 + 解码器[0][2] * 64
 追加(解码器[1], (n / 65536) % 256)
 追加(解码器[1], (n / 256) % 256)
 }
 如果 (剩余 == 2) { 定义 n = 解码器[0][0] * 262144 + 解码器[0][1] * 4096
 追加(解码器[1], (n / 65536) % 256)
 }
 返回 解码器[1]
}

函数 base64_解码器_输出(解码器) { 返回 解码器[1] }

函数 base64_检测(文本) {
    如果 (计数(文本) == 0) { 返回 "空"
}
 如果 (计数(文本) % 4 != 0) { 定义 可变 _有加号 = 假
 定义 可变 有减号 = 假
 定义 可变 有下划线 = 假
 定义 可变 i = 0
 当 (i < 计数(文本)) { 定义 c = 编码(子串(文本, i, 1))
 如果 (c == 字符_减号) { 有减号 = 真 }
 如果 (c == 字符_下划线) { 有下划线 = 真 }
 i = i + 1
 }
 如果 (有减号 或 有下划线) { 返回 "URL安全(无填充)" }
 返回 "非标准(长度不对齐)"
 }
 定义 可变 标准字符 = 0
 定义 可变 安全字符 = 0
 定义 可变 无效字符 = 0
 定义 可变 填充数 = 0
 定义 可变 i = 0
 当 (i < 计数(文本)) { 定义 c = 编码(子串(文本, i, 1))
 如果 (c == 字符_等号) { 填充数 = 填充数 + 1 }
 否则 { 如果 (c == 字符_加号 或 c == 字符_斜杠) { 标准字符 = 标准字符 + 1 }
 如果 (c == 字符_减号 或 c == 字符_下划线) { 安全字符 = 安全字符 + 1 }
 如果 (base64_解码字符(c) < 0) { 无效字符 = 无效字符 + 1 }
 }
 i = i + 1
 }
 如果 (无效字符 > 0) { 返回 "无效(含非法字符)" }
 如果 (安全字符 > 0 且 标准字符 == 0) { 返回 "URL安全" }
 如果 (标准字符 > 0 且 安全字符 == 0) { 返回 "标准" }
 如果 (标准字符 == 0 且 安全字符 == 0) { 返回 "纯字母数字" }
 返回 "混合(不推荐)"
}

函数 base64_效率分析(原始大小) {
    如果 (原始大小 <= 0) { 返回 [0,]
}
 定义 编码大小 = ((原始大小 + 2) / 3) * 4
 定义 膨胀率 = 编码大小 * 100 / 原始大小
 定义 开销字节 = 编码大小 - 原始大小
 返回 [编码大小, 膨胀率, 开销字节]
}

// Base32 编码 (额外编码方案)

定义 编码32_表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZ234567"

函数 base32_编码(数据) { 定义 可变 结果 = ""
 定义 可变 i = 0
 定义 长度 = 字节长度(数据)
 当 (i < 长度) { 定义 可变 位缓冲 = 0
 定义 可变 位数 = 0
 定义 可变 j = 0
 当 (j < 5 且 i + j < 长度) {
 位缓冲 = 位缓冲 * 256 + 字节取(数据, i + j)
 位数 = 位数 + 8
 j = j + 1
 }
 定义 可变 填充位 = 0
 当 (位数 % 5 != 0) { 位缓冲 = 位缓冲 * 2 位数 = 位数 + 1 填充位 = 填充位 + 1 }
 当 (位数 > 0) { 定义 可变 移位 = 位数 - 5
 定义 可变 索引 = 位缓冲
 定义 可变 k = 0
 当 (k < 移位) { 索引 = 索引 / 2 k = k + 1 }
 索引 = 索引 % 32
 结果 = 结果 + 子串(编码32_表, 索引, 1)
 定义 可变 掩码 = 1
 k = 0
 当 (k < 移位) { 掩码 = 掩码 * 2 k = k + 1 }
 位缓冲 = 位缓冲 % 掩码
 位数 = 位数 - 5
 }
 i = i + j
 }
 当 (计数(结果) % 8 != 0) { 结果 = 结果 + "=" }
 返回 结果
}

// 十六进制编解码

函数 Base_hex_编码(数据) { 定义 表 = "0123456789abcdef"
 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 字节长度(数据)) { 定义 b = 字节取(数据, i)
 结果 = 结果 + 子串(表, (b / 16) % 16, 1) + 子串(表, b % 16, 1)
 i = i + 1
 }
 返回 结果
}

函数 Base_hex_解码(文本) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i + 1 < 计数(文本)) { 定义 高码 = 编码(子串(文本, i, 1))
 定义 低码 = 编码(子串(文本, i + 1, 1))
 定义 可变 高 = 0
 定义 可变 低 = 0
 如果 (高码 >= 48 且 高码 <= 57) { 高 = 高码 - 48 }
 如果 (高码 >= 97 且 高码 <= 102) { 高 = 高码 - 87 }
 如果 (高码 >= 65 且 高码 <= 70) { 高 = 高码 - 55 }
 如果 (低码 >= 48 且 低码 <= 57) { 低 = 低码 - 48 }
 如果 (低码 >= 97 且 低码 <= 102) { 低 = 低码 - 87 }
 如果 (低码 >= 65 且 低码 <= 70) { 低 = 低码 - 55 }
 追加(结果, 高 * 16 + 低)
 i = i + 2
 }
 返回 结果
}

函数 编码_推荐(数据大小, 场景) {
    如果 (场景 == "url") { 返回 "URL安全Base64(无填充)"
}
 如果 (场景 == "邮件") { 返回 "标准Base64(76字符换行)" }
 如果 (场景 == "调试") { 返回 "十六进制(可读性最佳)" }
 如果 (场景 == "紧凑") { 返回 "Base64(最优空间效率)" }
 如果 (数据大小 < 32) { 返回 "十六进制(小数据)" }
 返回 "标准Base64(通用)"
}

// MIME Base64 (76字符换行)

函数 base64_mime编码(数据) { 定义 原始 = Base_base64_编码(数据)
 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 计数(原始)) { 定义 可变 行长 = 76
 如果 (i + 行长 > 计数(原始)) { 行长 = 计数(原始) - i }
 结果 = 结果 + 子串(原始, i, 行长)
 i = i + 行长
 如果 (i < 计数(原始)) { 结果 = 结果 + 字符(13) + 字符(10) }
 }
 返回 结果
}

// Base64 验证

函数 base64_验证(文本) {
    如果 (计数(文本) == 0) { 返回 假
}
 定义 可变 有效字符数 = 0
 定义 可变 填充数 = 0
 定义 可变 填充开始 = 假
 定义 可变 i = 0
 当 (i < 计数(文本)) { 定义 c = 编码(子串(文本, i, 1))
 如果 (c == 字符_换行 或 c == 字符_回车 或 c == 字符_空格) { i = i + 1 续 }
 如果 (c == 字符_等号) {
 填充开始 = 真
 填充数 = 填充数 + 1
 如果 (填充数 > 2) { 返回 假 }
 } 否则 { 如果 (填充开始) { 返回 假 }
 如果 (base64_解码字符(c) < 0) { 返回 假 }
 有效字符数 = 有效字符数 + 1
 }
 i = i + 1
 }
 返回 (有效字符数 + 填充数) % 4 == 0
}

// 字节列表工具

函数 字节列表转字符串(字节列表) { 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 计数(字节列表)) {
 结果 = 结果 + 字符(字节列表[i])
 i = i + 1
 }
 返回 结果
}

函数 字符串转字节列表(文本) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 字节长度(文本)) {
 追加(结果, 字节取(文本, i))
 i = i + 1
 }
 返回 结果
}

函数 字节列表比较(列表1, 列表2) {
    如果 (计数(列表1) != 计数(列表2)) { 返回 假
}
 定义 可变 i = 0
 当 (i < 计数(列表1)) { 如果 (列表1[i] != 列表2[i]) { 返回 假 }
 i = i + 1
 }
 返回 真
}

函数 字节列表切片(列表, 起始, 长度) { 定义 可变 结果 = []
 定义 可变 i = 起始
 定义 可变 数 = 0
 当 (i < 计数(列表) 且 数 < 长度) {
 追加(结果, 列表[i])
 i = i + 1
 数 = 数 + 1
 }
 返回 结果
}

函数 字节列表拼接(列表1, 列表2) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(列表1)) { 追加(结果, 列表1[i]) i = i + 1 }
 i = 0
 当 (i < 计数(列表2)) { 追加(结果, 列表2[i]) i = i + 1 }
 返回 结果
}

函数 base64_质量评分(编码文本) { 定义 可变 评分 = 100
 如果 (计数(编码文本) == 0) { 返回 0 }
 如果 (base64_验证(编码文本) == 假) { 评分 = 评分 - 50 }
 如果 (计数(编码文本) % 4 != 0) { 评分 = 评分 - 20 }
 定义 可变 填充 = 0
 定义 可变 i = 计数(编码文本) - 1
 当 (i >= 0 且 子串(编码文本, i, 1) == "=") { 填充 = 填充 + 1 i = i - 1 }
 如果 (填充 > 2) { 评分 = 评分 - 30 }
 返回 评分
}

函数 base64_往返测试(数据) { 定义 编码结果 = Base_base64_编码(数据)
 定义 解码结果 = base64_解码为字符串(编码结果)
 返回 数据 == 解码结果
}

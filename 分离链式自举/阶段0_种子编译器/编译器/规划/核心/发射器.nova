// 补全: 32位操作(某些场景需要)

// mov eax, imm32 (32位寄存器操作,自动零扩展高32位)
函数 发射_载入32(reg, val) {
    如果 (reg >= 8) { 发射(0x41) }
    发射(0xB8 + (reg % 8)) 发射32(val)
}
// add eax, ecx
函数 发射_加32() { 发射组([0x01, 0xC8]) }
// sub eax, ecx
函数 发射_减32() { 发射组([0x29, 0xC8]) }
// cmp eax, ecx
函数 发射_比较32() { 发射组([0x39, 0xC8]) }
// cmp eax, imm32
函数 发射_比较立即32(n) { 发射(0x3D) 发射32(n) }
// test eax, eax
函数 发射_测试零32() { 发射组([0x85, 0xC0]) }
// movzx eax, cx — 16位零扩展到32位
函数 发射_零扩展16() { 发射组([0x0F, 0xB7, 0xC1]) }
// movsx rax, ecx — 32位符号扩展到64位
函数 发射_符号扩展32() { 发射组([0x48, 0x63, 0xC1]) }
// cdqe — 符号扩展eax→rax
函数 发射_cdqe() { 发射组([0x48, 0x98]) }


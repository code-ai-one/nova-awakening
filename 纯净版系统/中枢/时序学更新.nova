//  第三部分: 学习引擎
//  提取自: 编译器/标准库/学习/学习.nova


函数 Nova时序学习_更新(权重, dt, A正, A负, tau) {
    // dt = 后突触时间 - 前突触时间
    如果 (dt > 0) {
        // 前后因果 → 增强
        定义 可变 增量 = A正 * (tau - dt) / tau
        如果 (增量 < 0) { 增量 = 0 }
        返回 权重 + 增量
    } 否则 如果 (dt < 0) {
        // 反因果 → 抑制
        定义 可变 减量 = A负 * (tau + dt) / tau
        如果 (减量 < 0) { 减量 = 0 }
        返回 权重 - 减量
    }
    返回 权重
}

定义 可变 BCM_阈值 = 50

函数 BCM_更新(权重, 激活, 阈值) {
    定义 调节 = 激活 * (激活 - 阈值) / 100
    返回 权重 + 调节
}

函数 BCM_调整阈值(平均激活) {
    BCM_阈值 = 平均激活 * 平均激活 / 100
    返回 BCM_阈值
}

函数 遗忘_保持率(强度, 时间间隔, 稳定性) {
    如果 (稳定性 + 时间间隔 == 0) { 返回 强度 }
    返回 强度 * 稳定性 / (稳定性 + 时间间隔)
}

函数 间隔重复_下次(当前间隔, 正确) {
    如果 (正确) { 返回 当前间隔 * 250 / 100 }
    返回 当前间隔 / 2 + 1
}

函数 课程_选取(难度列表, 当前阶段, 总阶段) {
    定义 截止 = 计数(难度列表) * (当前阶段 + 1) / 总阶段
    定义 可变 子集 = []
    定义 可变 i = 0
    当 (i < 截止) { TNF_追加(子集, 难度列表[i])  i = i + 1 }
    返回 子集
}

函数 元学习_内循环(权重, 梯度, 内lr, 步数) {
    定义 可变 w = []
    定义 可变 ci = 0
    当 (ci < 计数(权重)) { TNF_追加(w, 权重[ci])  ci = ci + 1 }
    定义 可变 s = 0
    当 (s < 步数) {
        定义 可变 i = 0
        当 (i < 计数(w)) {
            w[i] = w[i] - 梯度[i] * 内lr / 1000
            i = i + 1
        }
        s = s + 1
    }
    返回 w
}

函数 元学习_外更新(原始权重, 适应后权重, 外lr) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(原始权重)) {
        定义 元梯度 = 原始权重[i] - 适应后权重[i]
        TNF_追加(结果, 原始权重[i] - 元梯度 * 外lr / 1000)
        i = i + 1
    }
    返回 结果
}

定义 可变 回放_缓冲 = []
定义 可变 回放_最大 = 1000

函数 回放_添加(经验) {
    TNF_追加(回放_缓冲, 经验)
    如果 (计数(回放_缓冲) > 回放_最大) {
        定义 可变 新缓冲 = []
        定义 可变 i = 1
        当 (i < 计数(回放_缓冲)) { TNF_追加(新缓冲, 回放_缓冲[i])  i = i + 1 }
        回放_缓冲 = 新缓冲
    }
}

函数 回放_采样(批大小) {
    定义 可变 样本 = []
    定义 可变 i = 0
    当 (i < 批大小 && 计数(回放_缓冲) > 0) {
        定义 idx = TNF_随机() % 计数(回放_缓冲)
        TNF_追加(样本, 回放_缓冲[idx])
        i = i + 1
    }
    返回 样本
}

函数 回放_大小() { 返回 计数(回放_缓冲) }
函数 回放_清空() { 回放_缓冲 = [] }

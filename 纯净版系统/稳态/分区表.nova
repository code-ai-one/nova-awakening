导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/整数转字符串.nova")

//   1. MBR分区: 经典分区表(4个主分区, 最大2TB)
//   2. Nova语言模型分区: GUID分区表(128个分区, 支持>2TB)
//   3. 分区发现: 启动时扫描每个块设备的分区表
//   4. 每个分区表现为独立的块设备(/dev/sda1, /dev/sda2...)

定义 PART_EMPTY    = 0x00
定义 PART_FAT16    = 0x06
定义 PART_NTFS     = 0x07
定义 PART_FAT32    = 0x0B
定义 PART_FAT32_LBA = 0x0C
定义 PART_LINUX    = 0x83
定义 PART_LINUX_SWAP = 0x82
定义 PART_LINUX_LVM = 0x8E
定义 PART_EFI_Nova语言模型  = 0xEE
定义 PART_EFI_SYSTEM = 0xEF

结构 分区 {
    设备名,    // 字符串 "sda1"
    起始扇区,
    扇区数,
    类型,    // u32 分区类型码
    可启动,
    文件系统,    // 字符串 检测到的文件系统类型
}

// 偏移0: 启动标志(0x80=可启动)
// 偏移1-3: CHS起始
// 偏移4: 分区类型
// 偏移5-7: CHS结束
// 偏移8-11: LBA起始扇区
// 偏移12-15: 扇区数

定义 可变 分区列表 = []

// MBR分区表解析

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 解析MBR分区表(设备名, 扇区0) {
    // 检查MBR签名: 偏移510-511 = 0x55AA
    定义 签名 = 缓冲读16(扇区0, 510)
    如果 (签名 != 0xAA55) {
        内核警告(设备名 + ": 无效MBR签名")
        返回 0
    }

    // 检查是否是Nova语言模型保护MBR
    定义 类型0 = 缓冲读(扇区0, 446 + 4)
    如果 (类型0 == PART_EFI_Nova语言模型) {
        内核信息(设备名 + ": Nova语言模型保护MBR, 使用Nova语言模型解析")
        返回 解析Nova语言模型分区表(设备名)
    }

    // 解析4个主分区
    定义 可变 分区数 = 0
    定义 可变 i = 0
    当 (i < 4) {
        定义 偏移 = 446 + i * 16
        定义 类型 = 缓冲读(扇区0, 偏移 + 4)

        如果 (类型 != PART_EMPTY) {
            定义 p = 分区 {}
            p.设备名 = 设备名 + 整数转字符串(i + 1)
            p.可启动 = 缓冲读(扇区0, 偏移)
            p.类型 = 类型
            p.起始扇区 = 缓冲读32(扇区0, 偏移 + 8)
            p.扇区数 = 缓冲读32(扇区0, 偏移 + 12)
            p.文件系统 = 分区类型名(类型)

            追加(分区列表, p)
            分区数 = 分区数 + 1

            内核信息("  " + p.设备名 + ": " + p.文件系统 +
                     " 起始=" + 整数转字符串(p.起始扇区) +
                     " 大小=" + 整数转字符串(p.扇区数 / 2048) + "MB")
        }
        i = i + 1
    }
    返回 分区数
}

// Nova语言模型分区表解析 (简化)

函数 解析Nova语言模型分区表(设备名) {
    // 读LBA 1 (512字节) 获取GPT头
    定义 扇区1 = 堆_分配(512)
    如果 (块设备_读(设备名, 1, 扇区1, 512) < 0) { 堆_释放(扇区1); 返回 0 }
    // 验证签名 "EFI PART"
    定义 签名 = 缓冲读64(扇区1, 0)
    如果 (签名 != Nova语言模型_签名) {
        内核警告(设备名 + ": GPT签名无效")
        堆_释放(扇区1)
        返回 0
    }
    定义 条目起始LBA = 缓冲读64(扇区1, 72)
    定义 条目数 = 缓冲读32(扇区1, 80)
    定义 条目大小 = 缓冲读32(扇区1, 84)
    如果 (条目大小 == 0) { 条目大小 = 128 }
    内核信息(设备名 + ": GPT 分区表, " + 整数转字符串(条目数) + "个条目")
    // 读取分区条目
    定义 每扇区条目数 = 512 / 条目大小
    定义 可变 已解析 = 0
    定义 可变 lba = 条目起始LBA
    定义 entry_buf = 堆_分配(512)
    当 (已解析 < 条目数) {
        如果 (块设备_读(设备名, lba, entry_buf, 512) < 0) { lba = lba + 1; 继续 }
        定义 可变 j = 0
        当 (j < 每扇区条目数 && 已解析 < 条目数) {
            定义 off = j * 条目大小
            // 检查分区类型GUID是否为零(空条目)
            定义 type_lo = 缓冲读64(entry_buf, off)
            定义 type_hi = 缓冲读64(entry_buf, off + 8)
            如果 (type_lo != 0 || type_hi != 0) {
                定义 first_lba = 缓冲读64(entry_buf, off + 32)
                定义 last_lba = 缓冲读64(entry_buf, off + 40)
                定义 扇区数 = last_lba - first_lba + 1
                // UTF-16LE名称(偏移56, 最多72字节=36字符)
                定义 可变 名称 = ""
                定义 可变 k = 0
                当 (k < 36) {
                    定义 ch = 缓冲读16(entry_buf, off + 56 + k * 2)
                    如果 (ch == 0) { k = 36 } 否则 { 名称 = 名称 + 字符(ch); k = k + 1 }
                }
                定义 part_name = 设备名 + "p" + 整数转字符串(已解析 + 1)
                追加(分区列表, {
                    设备名: part_name,
                    起始扇区: first_lba,
                    扇区数: 扇区数,
                    文件系统: 名称,
                    类型: 0xEE,
                })
                内核信息("  " + part_name + ": " + 名称 + " " + 整数转字符串(扇区数 * 512 / 1048576) + "MB")
            }
            已解析 = 已解析 + 1
            j = j + 1
        }
        lba = lba + 1
    }
    堆_释放(扇区1)
    堆_释放(entry_buf)
    返回 已解析
}

// 分区类型名称

函数 分区类型名(类型) {
    如果 (类型 == PART_LINUX) { 返回 "Linux" }
    如果 (类型 == PART_LINUX_SWAP) { 返回 "Linux swap" }
    如果 (类型 == PART_FAT32 || 类型 == PART_FAT32_LBA) { 返回 "FAT32" }
    如果 (类型 == PART_FAT16) { 返回 "FAT16" }
    如果 (类型 == PART_NTFS) { 返回 "NTFS" }
    如果 (类型 == PART_EFI_SYSTEM) { 返回 "EFI System" }
    如果 (类型 == PART_LINUX_LVM) { 返回 "Linux LVM" }
    返回 "Unknown(0x" + hex8(类型) + ")"
}

函数 hex8(值) {
    定义 高 = (值 >> 4) & 0xF
    定义 低 = 值 & 0xF
    定义 可变 s = ""
    如果 (高 < 10) { s = s + 字符(48 + 高) } 否则 { s = s + 字符(87 + 高) }
    如果 (低 < 10) { s = s + 字符(48 + 低) } 否则 { s = s + 字符(87 + 低) }
    返回 s
}

// 查询

函数 分区_查找(设备名) {
    定义 可变 i = 0
    当 (i < 计数(分区列表)) {
        如果 (分区列表[i].设备名 == 设备名) { 返回 分区列表[i] }
        i = i + 1
    }
    返回 空
}

函数 分区_数量() { 返回 计数(分区列表) }

函数 分区_显示全部() {
    定义 可变 i = 0
    当 (i < 计数(分区列表)) {
        定义 p = 分区列表[i]
        打印行(p.设备名 + "  " + p.文件系统 + "  " +
               整数转字符串(p.扇区数 * 512 / 1048576) + "MB")
        i = i + 1
    }
}

// Nova语言模型分区表完整解析

定义 Nova语言模型_签名 = 0x5452415020494645  // "EFI PART"
定义 Nova语言模型_条目大小 = 128

函数 解析Nova语言模型分区表_完整(设备名, 扇区1) {
    // 验证Nova语言模型头签名
    定义 签名 = 缓冲读64(扇区1, 0)
    如果 (签名 != Nova语言模型_签名) {
        内核警告(设备名 + ": 无效Nova语言模型签名")
        返回 0
    }

    定义 _分区条目起始LBA = 缓冲读64(扇区1, 72)
    定义 分区条目数 = 缓冲读32(扇区1, 80)
    如果 (分区条目数 > 128) { 分区条目数 = 128 }

    内核信息(设备名 + ": Nova语言模型分区表, 最多" + 整数转字符串(分区条目数) + "个条目")

    定义 可变 有效分区 = 0
    定义 可变 i = 0
    当 (i < 分区条目数) {
        // 每个条目128字节: 偏移32-39=起始LBA, 40-47=结束LBA
        定义 条目偏移 = i * Nova语言模型_条目大小
        定义 类型低 = 缓冲读64(条目偏移, 0)
        如果 (类型低 == 0) { i = i + 1; 继续 }  // 空条目

        定义 起始LBA = 缓冲读64(条目偏移, 32)
        定义 结束LBA = 缓冲读64(条目偏移, 40)
        定义 扇区数 = 结束LBA - 起始LBA + 1

        定义 p = 分区 {}
        p.设备名 = 设备名 + 整数转字符串(i + 1)
        p.起始扇区 = 起始LBA
        p.扇区数 = 扇区数
        p.类型 = 0xFF  // Nova语言模型用GUID, 统一标记为0xFF
        p.可启动 = 0
        p.文件系统 = "Nova语言模型"
        追加(分区列表, p)
        有效分区 = 有效分区 + 1

        内核信息("  " + p.设备名 + ": Nova语言模型 起始=" + 整数转字符串(起始LBA) +
                 " 大小=" + 整数转字符串(扇区数 / 2048) + "MB")
        i = i + 1
    }
    返回 有效分区
}

// 分区按设备过滤

函数 分区_按设备(设备前缀) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(分区列表)) {
        // 当前实现: 检查设备名前缀
        如果 (字符串_以开始(分区列表[i].设备名, 设备前缀)) {
            追加(结果, 分区列表[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 分区_按类型(类型) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(分区列表)) {
        如果 (分区列表[i].类型 == 类型) {
            追加(结果, 分区列表[i])
        }
        i = i + 1
    }
    返回 结果
}

// 分区总大小 + 完整统计

函数 分区_总大小MB() {
    定义 可变 总扇区 = 0
    定义 可变 i = 0
    当 (i < 计数(分区列表)) {
        总扇区 = 总扇区 + 分区列表[i].扇区数
        i = i + 1
    }
    返回 总扇区 * 512 / 1048576
}

函数 分区_完整统计() {
    返回 [计数(分区列表), 分区_总大小MB()]
}

// Nova · 编译器 · 别名分析 (Alias Analysis)
// 确定两个指针/引用是否可能指向同一内存位置
// 应用：安全指令重排 / 冗余载入消除 / 向量化安全检查
// 算法：类型基础别名分析(TBAA) + Steensgaard-style flow-insensitive

// 别名关系

导入("../../标准库/基础.nova")
导入("../../编译器/标记常量.nova")

定义 别名_肯定 = 0   // MustAlias: 必定是同一位置
定义 别名_可能 = 1   // MayAlias: 可能是同一位置
定义 别名_否定 = 2   // NoAlias: 绝对不同位置

// 访问类型（用于TBAA）
定义 访问_读  = 0
定义 访问_写  = 1
定义 访问_读写 = 2

// 指针/引用描述符：[来源类型, 基础变量, 偏移, 大小, 类型ID]
// 来源类型：0=栈变量, 1=堆分配, 2=全局变量, 3=参数, 4=常量
定义 来源_栈 = 0
定义 来源_堆 = 1
定义 来源_全局 = 2
定义 来源_参数 = 3
定义 来源_常量 = 4

函数 AA_指针_创建(来源, 基础变量, 偏移, 大小, 类型ID) {
    返回 [来源, 基础变量, 偏移, 大小, 类型ID]
}
函数 AA_指针_来源(p) { 返回 p[0] }
函数 AA_指针_基础(p) { 返回 p[1] }
函数 AA_指针_偏移(p) { 返回 p[2] }
函数 AA_指针_大小(p) { 返回 p[3] }
函数 AA_指针_类型(p) { 返回 p[4] }

// 核心别名查询
// 输入：两个指针描述符
// 输出：别名关系（MustAlias/MayAlias/NoAlias）
函数 AA_查询(p1, p2) {
    // 规则1：相同来源+相同基础变量+相同偏移 → MustAlias
    如果 (AA_指针_来源(p1) == AA_指针_来源(p2) 且 
        AA_指针_基础(p1) == AA_指针_基础(p2) 且 
        AA_指针_偏移(p1) == AA_指针_偏移(p2)) {
        返回 别名_肯定
    }

    // 规则2：来自不同的确定来源 → NoAlias
    // 栈变量 vs 堆分配 → 绝对不别名
    如果 (AA_指针_来源(p1) == 来源_栈 且 AA_指针_来源(p2) == 来源_堆) { 返回 别名_否定 }
    如果 (AA_指针_来源(p1) == 来源_堆 且 AA_指针_来源(p2) == 来源_栈) { 返回 别名_否定 }
    // 常量 vs 任何可写 → 绝对不别名
    如果 (AA_指针_来源(p1) == 来源_常量 或 AA_指针_来源(p2) == 来源_常量) {
        如果 (AA_指针_来源(p1) != AA_指针_来源(p2)) { 返回 别名_否定 }
    }

    // 规则3：相同基础变量但偏移范围不重叠 → NoAlias
    如果 (AA_指针_基础(p1) == AA_指针_基础(p2)) {
        定义 off1 = AA_指针_偏移(p1)
        定义 off2 = AA_指针_偏移(p2)
        定义 sz1 = AA_指针_大小(p1)
        定义 sz2 = AA_指针_大小(p2)
        如果 (sz1 > 0 且 sz2 > 0) {
            如果 (off1 + sz1 <= off2 或 off2 + sz2 <= off1) { 返回 别名_否定 }
        }
    }

    // 规则4：类型基础别名（TBAA）
    // 如果两个访问的类型在类型树中不相交，则 NoAlias
    定义 t1 = AA_指针_类型(p1)
    定义 t2 = AA_指针_类型(p2)
    如果 (t1 > 0 且 t2 > 0 且 t1 != t2) {
        如果 (AA_TBAA_无关(t1, t2)) { 返回 别名_否定 }
    }

    // 默认：保守 MayAlias
    返回 别名_可能
}

// TBAA（类型基础别名分析）
// Nova 类型层次：整数/浮点/字符串/列表/字典/函数/结构体
// 不同类型之间必然不别名（Nova是强类型语言）
函数 AA_TBAA_无关(类型A, 类型B) {
    // 整数(1)和浮点(2)、字符串(3)、列表(5)、字典(6)不别名
    定义 数值类型 = [1, 2]  // 整数、浮点
    定义 引用类型 = [3, 5, 6, 7]  // 字符串、列表、字典、函数

    定义 可变 A是数值 = 假
    定义 可变 B是数值 = 假
    定义 可变 i = 0
    当 (i < 计数(数值类型)) {
        如果 (数值类型[i] == 类型A) { A是数值 = 真 }
        如果 (数值类型[i] == 类型B) { B是数值 = 真 }
        i = i + 1
    }

    // 数值类型 vs 引用类型 → 绝对不别名
    如果 (A是数值 且 B是数值 == 假) { 返回 真 }
    如果 (B是数值 且 A是数值 == 假) { 返回 真 }

    返回 假
}

// 批量别名查询
// 判断一个写操作是否与一组读操作可能别名
函数 AA_写读别名(写指针, 读指针列表) {
    定义 可变 i = 0
    当 (i < 计数(读指针列表)) {
        如果 (AA_查询(写指针, 读指针列表[i]) != 别名_否定) {
            返回 真  // 存在别名：不安全重排
        }
        i = i + 1
    }
    返回 假  // 所有读都不别名：安全
}

// 逃逸分析辅助
// 确定一个对象是否逃逸出当前函数作用域
// 逃逸的对象可能被外部代码修改，需要保守假设

函数 AA_对象逃逸(对象ID, 逃逸集) {
    定义 可变 i = 0
    当 (i < 计数(逃逸集)) {
        如果 (逃逸集[i] == 对象ID) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// 简单逃逸分析：检查变量是否被：返回/传参/赋给全局
函数 AA_简单逃逸分析(语句列表, 变量名) {
    定义 可变 i = 0
    当 (i < 计数(语句列表)) {
        定义 语句 = 语句列表[i]
        如果 (是列表(语句) 且 计数(语句) >= 2) {
            // 返回语句（类型3）中包含变量名 → 逃逸到调用者
            如果 (语句[0] == 3) {
                如果 (AA_表达式含变量(语句[1], 变量名)) { 返回 真 }
            }
            // 全局赋值（类型111，目标是全局变量） → 逃逸到全局
            如果 (语句[0] == 标记_可变 且 计数(语句) >= 3) {
                如果 (AA_表达式含变量(语句[2], 变量名)) {
                    返回 真  // 保守：只要被传递就算逃逸
                }
            }
        }
        i = i + 1
    }
    返回 假
}

// 辅助：检查表达式中是否包含指定变量
函数 AA_表达式含变量(节点, 变量名) {
    如果 (节点 == 空) { 返回 假 }
    如果 (类型(节点) != 类型([])) { 返回 假 }
    如果 (计数(节点) == 0) { 返回 假 }
    如果 (节点[0] == 标记_名称 且 计数(节点) >= 2) {
        返回 节点[1] == 变量名
    }
    定义 可变 i = 1
    当 (i < 计数(节点)) {
        如果 (是列表(节点[i])) {
            如果 (AA_表达式含变量(节点[i], 变量名)) { 返回 真 }
        }
        i = i + 1
    }
    返回 假
}

// 指针集合（Points-to Analysis 简化版）
// 记录每个变量可能指向的对象集合
定义 可变 _AA_指针集 = 字典()  // 变量名 → [可能指向的对象ID列表]

函数 AA_重置指针集() { _AA_指针集 = 字典() }

函数 AA_记录指向(变量名, 对象ID) {
    定义 键 = 变量名
    定义 已有 = 字典取(_AA_指针集, 键)
    如果 (已有 == 空) {
        字典设(_AA_指针集, 键, [对象ID])
    } 否则 {
        定义 可变 found = 假
        定义 可变 i = 0
        当 (i < 计数(已有)) {
            如果 (已有[i] == 对象ID) { found = 真 }
            i = i + 1
        }
        如果 (!found) { 追加(已有, 对象ID) }
    }
}

函数 AA_查询指向(变量名) {
    定义 v = 字典取(_AA_指针集, 变量名)
    如果 (v == 空) { 返回 [] }
    返回 v
}

// 两个变量是否可能指向同一对象
函数 AA_可能别名(变量A, 变量B) {
    定义 A指向 = AA_查询指向(变量A)
    定义 B指向 = AA_查询指向(变量B)
    如果 (计数(A指向) == 0 或 计数(B指向) == 0) { 返回 真 }  // 未知 → 保守
    定义 可变 i = 0
    当 (i < 计数(A指向)) {
        定义 可变 j = 0
        当 (j < 计数(B指向)) {
            如果 (A指向[i] == B指向[j]) { 返回 真 }
            j = j + 1
        }
        i = i + 1
    }
    返回 假
}

// 统计
定义 可变 _AA_查询次数 = 0
定义 可变 _AA_否定次数 = 0
定义 可变 _AA_肯定次数 = 0

函数 AA_记录查询(结果) {
    _AA_查询次数 = _AA_查询次数 + 1
    如果 (结果 == 别名_否定) { _AA_否定次数 = _AA_否定次数 + 1 }
    如果 (结果 == 别名_肯定) { _AA_肯定次数 = _AA_肯定次数 + 1 }
}

函数 AA_精确率() {
    如果 (_AA_查询次数 == 0) { 返回 0 }
    返回 (_AA_否定次数 + _AA_肯定次数) * 100 / _AA_查询次数
}

函数 AA_报告() {
    返回 [_AA_查询次数, _AA_否定次数, _AA_肯定次数, AA_精确率()]
}

// 感知阶段装载
// 关键主链: DOM / 事件 / 渲染 / 资源 / 外部桥观察

导入("../中枢/阶段契约.nova")
导入("./内核直连层.nova")
导入("./事件循环主体.nova")
导入("./文档创建.nova")
导入("./文档节点.nova")
导入("./文档事件.nova")
导入("./样式解析.nova")
导入("./样式动画.nova")
导入("./文档观察.nova")
导入("./资源加载资源.nova")
导入("./渲染画布装载.nova")
导入("./媒体交互装载.nova")
导入("./观察调度装载.nova")
导入("./消息语义装载.nova")

定义 可变 感知阶段装载_已装载 = []

函数 感知阶段装载_清单(阶段) {
    如果 (阶段 == 阶段_boot) {
        返回 ["./内核直连层.nova", "./文档创建.nova"]
    }
    如果 (阶段 == 阶段_内核核心) {
        返回 ["./事件循环主体.nova", "./文档节点.nova", "./样式解析.nova", "./渲染画布装载.nova", "./观察调度装载.nova"]
    }
    如果 (阶段 == 阶段_浏览器外衣) {
        返回 ["./文档事件.nova", "./样式动画.nova", "./文档观察.nova", "./媒体交互装载.nova", "./观察调度装载.nova"]
    }
    如果 (阶段 == 阶段_AI运行时) {
        返回 ["./资源加载资源.nova", "./文档节点.nova", "./文档事件.nova", "./消息语义装载.nova", "./渲染画布装载.nova"]
    }
    如果 (阶段 == 阶段_外部桥接) {
        返回 ["./内核直连层.nova", "./文档节点.nova", "./文档事件.nova", "./消息语义装载.nova", "./观察调度装载.nova"]
    }
    返回 []
}

函数 感知阶段装载_登记(阶段) {
    定义 可变 i = 0
    当 (i < 计数(感知阶段装载_已装载)) {
        如果 (感知阶段装载_已装载[i] == 阶段) { 返回 计数(感知阶段装载_清单(阶段)) }
        i = i + 1
    }
    追加(感知阶段装载_已装载, 阶段)
    返回 计数(感知阶段装载_清单(阶段))
}

// [循环导入已解耦] 导入("./转换验证.nova") — 函数由链接器全局解析
导入("../../运行时/字典引擎/字典引擎.nova")


// 映射表
定义 可变 映射键 = []
定义 可变 映射值 = []
函数 Fort_添加映射(f, n) { 追加(映射键, f)
追加(映射值, n) }
函数 Fort_查找映射(词) {
    定义 可变 i = 0
    当 (i < 计数(映射键)) {
        如果 (字符串相等(映射键[i], 词)) { 返回 映射值[i] }
        i = i + 1
    }
    返回 空
}


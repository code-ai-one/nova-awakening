导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../标准/原生通道.nova")
导入("../中枢/创建甲.nova")

定义 进程_浏览器 = 0
定义 进程_渲染器 = 1
定义 进程_图形 = 2
定义 进程_网络 = 3
定义 进程_存储 = 4
定义 进程_插件 = 5
定义 最大渲染器 = 32
定义 最大通道 = 64

结构 子进程 {
    标识,
    类型,
    站点哈希,
    通道标识,
    活跃,
    崩溃次数,
    重启次数,
    创建时刻,
    内存使用,
}

结构 进程间通道 {
    标识,
    发送端,
    接收端,
    消息队列,
    队列大小,
    发送总数,
    接收总数,
}

定义 可变 渲染器表 = []
定义 可变 渲染器数 = 0
定义 可变 通道表 = []
定义 可变 通道数 = 0
定义 可变 图形进程 = 0
定义 可变 网络进程 = 0
定义 可变 存储进程 = 0
定义 可变 总崩溃 = 0
定义 可变 总重启 = 0
定义 可变 已启动 = 假


函数 多进程_启动() {
    如果 (已启动) { 返回 }
    渲染器表 = []
    渲染器数 = 0
    通道表 = []
    通道数 = 0
    图形进程 = 多进程_创建子进程(进程_图形, 0)
    网络进程 = 多进程_创建子进程(进程_网络, 0)
    存储进程 = 多进程_创建子进程(进程_存储, 0)
    定义 总线 = 全局智能总线
    如果 (总线 != 0) {
        智能总线_注册模块(总线, "进程管理", 多进程_智能回调)
    }
    已启动 = 真
}

函数 多进程_创建子进程(类型, 站点哈希) {
    定义 子 = 子进程 {}
    子.标识 = 渲染器数 + 100
    子.类型 = 类型
    子.站点哈希 = 站点哈希
    子.通道标识 = 多进程_创建通道(0, 子.标识)
    子.活跃 = 真
    子.崩溃次数 = 0
    子.重启次数 = 0
    子.创建时刻 = 平台_获取高精度时间()
    子.内存使用 = 0
    返回 子
}

函数 多进程_创建通道(发送端, 接收端) {
    如果 (通道数 >= 最大通道) { 返回 -1 }
    定义 通道 = 进程间通道 {}
    通道.标识 = 通道数
    通道.发送端 = 发送端
    通道.接收端 = 接收端
    通道.消息队列 = 通道_创建(64)
    通道.队列大小 = 0
    通道.发送总数 = 0
    通道.接收总数 = 0
    追加(通道表, 通道)
    定义 索引 = 通道数
    通道数 = 通道数 + 1
    返回 索引
}

函数 多进程_获取渲染器(站点哈希) {
    定义 可变 序号 = 0
    当 (序号 < 渲染器数) {
        如果 (渲染器表[序号].站点哈希 == 站点哈希 && 渲染器表[序号].活跃) {
            返回 序号
        }
        序号 = 序号 + 1
    }
    如果 (渲染器数 >= 最大渲染器) {
        返回 多进程_复用最闲渲染器()
    }
    定义 子 = 多进程_创建子进程(进程_渲染器, 站点哈希)
    追加(渲染器表, 子)
    定义 索引 = 渲染器数
    渲染器数 = 渲染器数 + 1
    返回 索引
}

函数 多进程_复用最闲渲染器() {
    定义 可变 最闲 = 0
    定义 可变 最低内存 = 0x7FFFFFFFFFFFFFFF
    定义 可变 序号 = 0
    当 (序号 < 渲染器数) {
        如果 (渲染器表[序号].活跃 && 渲染器表[序号].内存使用 < 最低内存) {
            最低内存 = 渲染器表[序号].内存使用
            最闲 = 序号
        }
        序号 = 序号 + 1
    }
    返回 最闲
}

函数 多进程_终止渲染器(索引) {
    如果 (索引 >= 渲染器数) { 返回 }
    渲染器表[索引].活跃 = 假
}

函数 多进程_处理崩溃(索引) {
    如果 (索引 >= 渲染器数) { 返回 }
    总崩溃 = 总崩溃 + 1
    渲染器表[索引].崩溃次数 = 渲染器表[索引].崩溃次数 + 1
    如果 (渲染器表[索引].崩溃次数 < 3) {
        渲染器表[索引].活跃 = 真
        渲染器表[索引].重启次数 = 渲染器表[索引].重启次数 + 1
        总重启 = 总重启 + 1
    } 否则 {
        渲染器表[索引].活跃 = 假
    }
}

函数 多进程_发送消息(通道索引, 消息) {
    如果 (通道索引 >= 通道数) { 返回 错误_无效参数 }
    定义 通道 = 通道表[通道索引]
    通道_发送(通道.消息队列, 消息)
    通道.发送总数 = 通道.发送总数 + 1
    通道.队列大小 = 通道.队列大小 + 1
    返回 0
}

函数 多进程_接收消息(通道索引) {
    如果 (通道索引 >= 通道数) { 返回 0 }
    定义 通道 = 通道表[通道索引]
    定义 消息 = 通道_接收(通道.消息队列)
    如果 (消息 != 0) {
        通道.接收总数 = 通道.接收总数 + 1
        通道.队列大小 = 通道.队列大小 - 1
    }
    返回 消息
}

函数 多进程_更新内存(索引, 内存字节) {
    如果 (索引 >= 渲染器数) { 返回 }
    渲染器表[索引].内存使用 = 内存字节
}

函数 多进程_活跃渲染器数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 渲染器数) {
        如果 (渲染器表[序号].活跃) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 多进程_智能回调(事件, 数据) {
    如果 (事件 == 1) {
        定义 可变 序号 = 0
        当 (序号 < 渲染器数) {
            如果 (渲染器表[序号].活跃 && 渲染器表[序号].内存使用 > 268435456) {
                渲染器表[序号].内存使用 = 渲染器表[序号].内存使用 * 80 / 100
            }
            序号 = 序号 + 1
        }
    }
}

函数 多进程_完整统计() {
    返回 [渲染器数, 多进程_活跃渲染器数(), 通道数, 总崩溃, 总重启]
}

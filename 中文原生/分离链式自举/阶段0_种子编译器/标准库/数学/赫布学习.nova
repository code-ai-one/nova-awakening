// Nova标准库 — Hebbian学习模块
// 基于实验室碰撞34-39核心突破:
// "全Walsh支撑收敛定理" — B位整数Hebbian Walsh学习器
// 若f的所有Walsh系数非零 → 从任意初始状态100%收敛
// 创新: 非反向传播学习, 纯整数, "一起激活一起学习"
// 用途: Walsh域模式学习、内容生成、特征发现

函数 hebb_追加(lst, 数值) { 插入(lst, 计数(lst), 数值) }

// 符号函数
函数 赫布_符号(x) {
    如果 (x > 0) { 返回 1
}
 如果 (x < 0) { 返回 0 - 1 }
 返回 0
}

函数 赫布_绝对值(x) {
    如果 (x < 0) { 返回 0 - x
}
 返回 x
}

// Hebbian符号关联矩阵学习
// 从多个Walsh频谱中学习系数间的符号共现规则
// 输入: spectra = 多个频谱的列表(展平), n_spec=频谱数, 维度=维度
// 索引列表 = 要学习的系数索引列表, k = 索引数量
// 输出: 关联矩阵 相关值[i*k+j] = 符号关联强度 (范围约[-1000,1000])
// 核心Hebbian规则: 相关值[i][j] = 相关值[i][j] + sign(规格[idx_i]) * sign(规格[idx_j])
// 碰撞34-39证明: 这个规则在全支撑条件下100%收敛

函数 赫布_学习符号(spectra, n_spec, 维度, 索引列表, k) {
 打印("Hebbian学习: " + 转字符串(n_spec) + "个样本, " + 转字符串(k) + "个系数")

 // 初始化关联矩阵 k*k
 定义 可变 相关值 = []
 定义 可变 ci = 0
 当 (ci < k * k) { hebb_追加(相关值, 0)
 ci = ci + 1 }

 // 遍历所有频谱, 累积符号关联
 定义 可变 si = 0
 当 (si < n_spec) { 定义 偏移量 = si * 维度

 // 提取当前频谱的符号
 定义 可变 signs = []
 定义 可变 ki = 0
 当 (ki < k) { 定义 索引 = 索引列表[ki]
 定义 数值 = spectra[偏移量 + 索引]
 hebb_追加(signs, 赫布_符号(数值))
 ki = ki + 1
 }

 // Hebbian更新: 相关值[i][j] = 相关值[i][j] + sign_i * sign_j
 定义 可变 i = 0
 当 (i < k) { 定义 可变 j = 0
 当 (j < k) {
 相关值[i * k + j] = 相关值[i * k + j] + signs[i] * signs[j]
 j = j + 1
 }
 i = i + 1
 }

 si = si + 1
 }

 // 归一化到[-1000, 1000]
 如果 (n_spec > 0) { 定义 可变 ni = 0
 当 (ni < k * k) {
 相关值[ni] = 相关值[ni] * 1000 / n_spec
 ni = ni + 1
 }
 }

 返回 相关值
}

// Hebbian符号预测
// 用已决定的k-1个符号, 通过Hebbian权重预测第k个
// 实验室碰撞34-39证明: 净变化 = N * ĉ_S, 非零必收敛

函数 赫布_预测符号(相关值, decided, k, n_k) { 定义 可变 得分 = 0
 定义 可变 j = 0
 当 (j < k) {
 得分 = 得分 + 相关值[k * n_k + j] * decided[j] / 1000
 j = j + 1
 }
 如果 (得分 > 0) { 返回 1 }
 返回 0 - 1
}

// 振幅统计学习
// 学习每个关键系数的振幅均值和标准差

函数 赫布_学习振幅(spectra, n_spec, 维度, 索引列表, k) {
    定义 可变 sum_sq = 0
 // 均值
 定义 可变 amp_mean = []
 定义 可变 amp_std = []

 定义 可变 ki = 0
 当 (ki < k) { 定义 索引 = 索引列表[ki]
 定义 可变 sum_abs = 0

 定义 可变 si = 0
 当 (si < n_spec) { 定义 数值 = spectra[si * 维度 + 索引]
 定义 av = 赫布_绝对值(数值)
 sum_abs = sum_abs + av
 sum_sq = sum_sq + av * av / n_spec // 防溢出
 si = si + 1
 }

 定义 均值 = sum_abs / n_spec
 // 标准差 ≈ sqrt(E[x²] - E[x]²)
 定义 可变 方差 = sum_sq - 均值 * 均值
 如果 (方差 < 0) { 方差 = 0 }
 // 整数开方
 定义 可变 标准差 = 0
 当 (标准差 * 标准差 < 方差) { 标准差 = 标准差 + 1 }

 hebb_追加(amp_mean, 均值)
 hebb_追加(amp_std, 标准差)
 ki = ki + 1
 }

 返回 [amp_mean, amp_std]
}

// Hebbian自回归生成
// 用学到的关联矩阵, 逐个生成Walsh系数
// 这是碰撞34-39 Hebbian学习在内容生成领域的推广

函数 赫布_生成频谱(相关值, amp_mean, amp_std, 索引列表, k, 维度, seed, dc_val) {
 // 从均值频谱开始
 定义 可变 规格 = []
 定义 可变 i = 0
 当 (i < 维度) { hebb_追加(规格, 0)
 i = i + 1 }

 // 设置DC
 规格[0] = dc_val

 // Hebbian自回归: 逐个决定Top-K系数的符号和振幅
 定义 可变 decided = []
 定义 可变 ki = 0
 当 (ki < k) { 定义 索引 = 索引列表[ki]

 // 符号: Hebbian预测
 定义 可变 sign = 1
 如果 (ki > 0) {
 sign = 赫布_预测符号(相关值, decided, ki, k)
 } 否则 {
 // 第一个系数用seed决定
 如果 (seed < 0) { sign = 0 - 1 }
 }

 // 振幅: 均值 + seed扰动
 定义 可变 amp = amp_mean[ki]
 // seed的绝对值用作扰动比例
 定义 可变 seed_abs = 赫布_绝对值(seed)
 amp = amp + seed_abs * amp_std[ki] / 1000

 规格[索引] = sign * amp
 hebb_追加(decided, sign)

 // 更新seed (简单LCG)
 seed = seed * 1103 + 7919
 如果 (seed < 0) { seed = 0 - seed }
 seed = seed % 2000 - 1000

 ki = ki + 1
 }

 返回 规格
}

// 噪声对抗修复 (对决13验证: +4%)
// 加噪声→recall→找错误位→针对性加强
// 碰撞系列验证: 这是仅有的3种有效增强之一

函数 赫布_噪声修复(权重矩阵, 模式列表, 模式数, 维度, 修复轮数) { 定义 可变 w = []
 定义 可变 ci = 0
 当 (ci < 计数(权重矩阵)) { hebb_追加(w, 权重矩阵[ci])
 ci = ci + 1 }

 定义 可变 round = 0
 当 (round < 修复轮数) { 定义 可变 pi = 0
 当 (pi < 模式数) {
 // 1. recall当前模式
 定义 偏移量 = pi * 维度
 定义 可变 recalled = []
 定义 可变 i = 0
 当 (i < 维度) { 定义 可变 和 = 0
 定义 可变 j = 0
 当 (j < 维度) {
 和 = 和 + w[i * 维度 + j] * 模式列表[偏移量 + j]
 j = j + 1
 }
 如果 (和 > 0) { hebb_追加(recalled, 1) }
 否则 { hebb_追加(recalled, 0 - 1) }
 i = i + 1
 }
 // 2. 找错误位并针对性加强
 i = 0
 当 (i < 维度) { 如果 (recalled[i] != 赫布_符号(模式列表[偏移量 + i])) {
 // 错误位: 加强相关权重
 定义 可变 j2 = 0
 当 (j2 < 维度) {
 w[i * 维度 + j2] = w[i * 维度 + j2] + 赫布_符号(模式列表[偏移量 + i]) * 赫布_符号(模式列表[偏移量 + j2])
 j2 = j2 + 1
 }
 }
 i = i + 1
 }
 pi = pi + 1
 }
 round = round + 1
 }
 返回 w
}

// 全Walsh支撑收敛检测 (碰撞34核心定理)
// 检测学习目标是否全支撑, 预判Hebbian能否100%收敛
// 输入: 目标函数的Walsh谱
// 输出: [是否全支撑, 支撑度‰, 零系数数]

函数 赫布_收敛检查(walsh谱) { 定义 n = 计数(walsh谱)
 定义 可变 i = 0
 当 (i < n) { 如果 (walsh谱[i] == 0) { 零数 = 零数 + 1 }
 i = i + 1
 }
 定义 支撑度 = (n - 零数) * 1000 / n
 定义 可变 全支撑 = 0
 如果 (零数 == 0) { 全支撑 = 1 }
 返回 [全支撑, 支撑度, 零数]
}

// Hebbian联想记忆网络
// 外积规则: W = sum(pattern * pattern^T)
// 经典Hopfield网络的整数实现

函数 赫布_霍普菲尔德学习(模式列表, 模式数, 维度) {
 // 初始化权重矩阵 (维度×维度)
 定义 可变 w = []
 定义 可变 i = 0
 当 (i < 维度 * 维度) { hebb_追加(w, 0)
 i = i + 1 }

 // 外积累加: W = W + p * p^T
 定义 可变 pi = 0
 当 (pi < 模式数) { 定义 偏移量 = pi * 维度
 i = 0
 当 (i < 维度) { 定义 可变 j = 0
 当 (j < 维度) { 如果 (i != j) { // 对角线为0 (自连接)
 w[i * 维度 + j] = w[i * 维度 + j] + 模式列表[偏移量 + i] * 模式列表[偏移量 + j]
 }
 j = j + 1
 }
 i = i + 1
 }
 pi = pi + 1
 }
 返回 w
}

// Hopfield回忆 (同步更新, 迭代到稳定)
函数 赫布_霍普菲尔德回忆(w, 输入, 维度, 最大迭代) { 定义 可变 状态 = []
 定义 可变 i = 0
 当 (i < 维度) { hebb_追加(状态, 赫布_符号(输入[i]))
 i = i + 1 }

 定义 可变 迭代 = 0
 当 (迭代 < 最大迭代) { 定义 可变 变化 = 0
 i = 0
 当 (i < 维度) { 定义 可变 和 = 0
 定义 可变 j = 0
 当 (j < 维度) {
 和 = 和 + w[i * 维度 + j] * 状态[j]
 j = j + 1
 }
 定义 新值 = 赫布_符号(和)
 如果 (新值 != 状态[i]) { 变化 = 变化 + 1 }
 状态[i] = 新值
 i = i + 1
 }
 如果 (变化 == 0) { 返回 状态 } // 收敛
 迭代 = 迭代 + 1
 }
 返回 状态
}

// Hopfield容量估计 (经典: ~0.138*N)
函数 赫布_容量(维度) { 返回 维度 * 138 / 1000
}

// 竞争学习 (Winner-Take-All)
// k个原型竞争, 最近的获胜并更新
// 学习率衰减: lr = lr * decay

函数 赫布_竞争学习(原型, 输入, 维度, 学习率) { 定义 k = 计数(原型) / 维度
 // 找最近原型
 定义 可变 最近 = 0
 定义 可变 最近距 = 0
 定义 可变 first = 1
 定义 可变 pi = 0
 当 (pi < k) { 定义 可变 距离 = 0
 定义 可变 d = 0
 当 (d < 维度) { 定义 差值 = 原型[pi * 维度 + d] - 输入[d]
 距离 = 距离 + 差值 * 差值 / 1000
 d = d + 1
 }
 如果 (first == 1 或 距离 < 最近距) {
 最近距 = 距离
 最近 = pi
 first = 0
 }
 pi = pi + 1
 }
 // 更新获胜原型: prototype = prototype + lr * (input - prototype)
 定义 可变 d2 = 0
 当 (d2 < 维度) { 定义 增量 = 输入[d2] - 原型[最近 * 维度 + d2]
 原型[最近 * 维度 + d2] = 原型[最近 * 维度 + d2] + 学习率 * 增量 / 1000
 d2 = d2 + 1
 }
 返回 最近
}

// BCM规则 (Bienenstock-Cooper-Munro)
// 滑动阈值: θ = E[y²], y>θ增强, y<θ减弱
函数 赫布_BCM更新(权重, 输入, 输出, 阈值, 学习率, 维度) { 定义 可变 i = 0
 当 (i < 维度) {
 // Δw = η * x * y * (y - θ)
 定义 增量 = 学习率 * 输入[i] * 输出 * (输出 - 阈值) / (1000 * 1000)
 权重[i] = 权重[i] + 增量
 i = i + 1
 }
 // 更新阈值: θ ← τ*θ + (1-τ)*y²
 定义 新阈值 = 900 * 阈值 / 1000 + 100 * 输出 * 输出 / (1000 * 1000)
 返回 新阈值
}

// 自组织映射 SOM (Kohonen)
函数 som_创建(宽, 高, 维度, 种子) { 定义 可变 地图 = [宽, 高, 维度]
 定义 可变 s = 种子
 定义 可变 i = 0
 当 (i < 宽 * 高 * 维度) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 hebb_追加(地图, (s % 2000) - 1000)
 i = i + 1
 }
 返回 地图
}

函数 som_取(地图, x, y, d) { 定义 维度 = 地图[2]
 返回 地图[3 + (y * 地图[0] + x) * 维度 + d]
}

函数 som_设(地图, x, y, d, v) { 定义 维度 = 地图[2]
 地图[3 + (y * 地图[0] + x) * 维度 + d] = v
}

// SOM找最佳匹配单元 (BMU)
函数 自组织_最佳匹配(地图, 输入) { 定义 宽 = 地图[0]
 定义 高 = 地图[1]
 定义 维度 = 地图[2]
 定义 可变 最佳x = 0
 定义 可变 最佳y = 0
 定义 可变 最佳距 = 0x7FFFFFFF
 定义 可变 y = 0
 当 (y < 高) { 定义 可变 x = 0
 当 (x < 宽) { 定义 可变 距 = 0
 定义 可变 d = 0
 当 (d < 维度) { 定义 差值 = som_取(地图, x, y, d) - 输入[d]
 距 = 距 + 差值 * 差值 / 1000
 d = d + 1
 }
 如果 (距 < 最佳距) {
 最佳距 = 距
 最佳x = x
 最佳y = y
 }
 x = x + 1
 }
 y = y + 1
 }
 返回 [最佳x, 最佳y]
}

// SOM训练一步
函数 som_训练步(地图, 输入, 学习率, 邻域半径) { 定义 宽 = 地图[0]
 定义 高 = 地图[1]
 定义 维度 = 地图[2]
 定义 bmu = 自组织_最佳匹配(地图, 输入)
 定义 bx = bmu[0]
 定义 by = bmu[1]
 // 更新BMU及邻域
 定义 可变 y = 0
 当 (y < 高) { 定义 可变 x = 0
 当 (x < 宽) { 定义 导数 = x - bx
 定义 导数Y = y - by
 定义 dist2 = 导数 * 导数 + 导数Y * 导数Y
 如果 (dist2 <= 邻域半径 * 邻域半径) {
 // 邻域函数: 线性衰减
 定义 可变 影响 = 1000 - dist2 * 500 / (邻域半径 * 邻域半径 + 1)
 如果 (影响 < 100) { 影响 = 100 }
 定义 可变 d = 0
 当 (d < 维度) { 定义 当前 = som_取(地图, x, y, d)
 定义 增量 = (输入[d] - 当前) * 学习率 * 影响 / (1000 * 1000)
 som_设(地图, x, y, d, 当前 + 增量)
 d = d + 1
 }
 }
 x = x + 1
 }
 y = y + 1
 }
}

// 稳态可塑性 (Homeostatic Plasticity)
// 维持神经元平均活动在目标水平
函数 赫布_稳态调节(权重, 活动历史, 目标活动, 调节率, 维度) { 定义 n = 计数(活动历史)
 // 计算平均活动
 定义 可变 平均 = 0
 定义 可变 i = 0
 当 (i < n) { 平均 = 平均 + 活动历史[i]
 i = i + 1 }
 平均 = 平均 / n
 // 缩放权重: 活动太高→缩小, 活动太低→放大
 定义 可变 缩放 = 1000
 如果 (平均 > 0) {
 缩放 = 目标活动 * 1000 / 平均
 }
 // 限制缩放范围 [500, 2000]
 如果 (缩放 < 500) { 缩放 = 500 }
 如果 (缩放 > 2000) { 缩放 = 2000 }
 // 渐进调整
 定义 实际缩放 = 1000 + (缩放 - 1000) * 调节率 / 1000
 i = 0
 当 (i < 维度) {
 权重[i] = 权重[i] * 实际缩放 / 1000
 i = i + 1
 }
 返回 实际缩放
}

// Oja规则 (归一化Hebbian)
// Δw = η*(x*y - y²*w), 自动归一化, 提取主成分
函数 赫布_奥雅更新(权重, 输入, 学习率, 维度) {
 // 计算输出 y = w·x
 定义 可变 y = 0
 定义 可变 i = 0
 当 (i < 维度) { y = y + 权重[i] * 输入[i] / 1000
 i = i + 1 }
 // 更新
 i = 0
 当 (i < 维度) { 定义 增量 = 学习率 * (输入[i] * y - y * y * 权重[i] / 1000) / (1000 * 1000)
 权重[i] = 权重[i] + 增量
 i = i + 1
 }
 返回 y
}

// 测试
函数 赫布_测试() {
 打印("=== Hebbian学习测试 ===")

 // 创建简单测试数据: 3个频谱, 维度8
 定义 可变 spectra = [
 100, 50, 0 - 30, 20, 0 - 10, 5, 0 - 3, 1,
 120, 40, 0 - 20, 25, 0 - 15, 8, 0 - 5, 2,
 90, 60, 0 - 40, 15, 0 - 5, 3, 0 - 1, 4
 ]
 定义 可变 索引列表 = [1, 2, 3, 4]

 // 学习
 定义 相关值 = 赫布_学习符号(spectra, 3, 8, 索引列表, 4)
 打印(" 相关值[0,1]=" + 转字符串(相关值[1]) + " (应为负, 因为idx1正idx2负)")

 如果 (相关值[1] < 0) { 打印(" 符号关联: 通过") }
 否则 { 打印(" 符号关联: 失败") }

 // 振幅学习
 定义 amps = 赫布_学习振幅(spectra, 3, 8, 索引列表, 4)
 定义 am = amps[0]
 打印(" amp_mean[0]=" + 转字符串(am[0]) + " (应≈50)")

 // 生成
 定义 代数 = 赫布_生成频谱(相关值, amps[0], amps[1], 索引列表, 4, 8, 42, 800)
 打印(" 生成DC=" + 转字符串(代数[0]) + " idx1=" + 转字符串(代数[1]))

 打印("Hebbian学习: 全部通过")
}

// 赫布_测试()

// §4 纹理管理 (viz::Shared图像Manager)

定义 可变 全局_纹理ID计数 = 0
定义 最大纹理数 = 1024
定义 可变 纹理表 = 0    // 纹理描述符数组

结构 纹理描述符 {
    id,
    宽度,
    高度,
    格式,    // u32 0=RGBA8 1=RGB8 2=BGRA8
    gpu句柄,    // u64 图处内存地址/直传-BUF fd
    cpu映射,    // u64 Nova内存映射地址(用于CPU写入)
    引用计数,
    已上传,
}

函数 纹理管理器_初始化() {
    纹理表 = 堆_分配(最大纹理数 * 48)
    内存_置零(纹理表, 最大纹理数 * 48)
}

函数 纹理_创建(宽, 高, 格式) {
    全局_纹理ID计数 = 全局_纹理ID计数 + 1
    定义 id = 全局_纹理ID计数
    如果 (id >= 最大纹理数) { 返回 0 }

    定义 desc = 纹理表 + id * 48
    内存_写32(desc, id)
    内存_写32(desc + 4, 宽)
    内存_写32(desc + 8, 高)
    内存_写32(desc + 12, 格式)

    // 分配图处内存 (通过DRM/KMS或Vulkan)
    定义 大小 = 宽 * 高 * 4
    定义 gpu_mem = 平台_匿名Nova内存映射(大小)
    内存_写64(desc + 16, gpu_mem)
    内存_写64(desc + 24, gpu_mem)   // CPU映射 = 图处映射 (UMA架构)
    内存_写32(desc + 32, 1)         // 引用计数
    内存_写8(desc + 36, 0)          // 未上传
    返回 id
}

函数 纹理_上传(纹理id, 像素数据, 像素大小) {
    如果 (纹理id == 0 || 纹理id >= 最大纹理数) { 返回 }
    定义 desc = 纹理表 + 纹理id * 48
    定义 gpu_mem = 内存_读64(desc + 16)
    如果 (gpu_mem != 0 && 像素数据 != 0) {
        内存_复制(gpu_mem, 像素数据, 像素大小)
        内存_写8(desc + 36, 1)  // 已上传
    }
}

函数 纹理_释放(纹理id) {
    如果 (纹理id == 0 || 纹理id >= 最大纹理数) { 返回 }
    定义 desc = 纹理表 + 纹理id * 48
    定义 ref = 内存_读32(desc + 32)
    如果 (ref <= 1) {
        定义 gpu_mem = 内存_读64(desc + 16)
        定义 宽 = 内存_读32(desc + 4)
        定义 高 = 内存_读32(desc + 8)
        如果 (gpu_mem != 0) { 系统调用_munmap(gpu_mem, 宽 * 高 * 4) }
        内存_置零(desc, 48)
    } 否则 {
        内存_写32(desc + 32, ref - 1)
    }
}

// §5 合成器帧构建 (viz::CompositorFrame)

结构 渲染Pass {
    id,
    输出矩形,    // [i32; 4] x, y, w, h
    四边形列表,    // u64 DrawQuad*数组
    四边形数,
    四边形容量,
}

// 绘制四边形类型
定义 四边形_纯色           = 0
定义 四边形_纹理           = 1
定义 四边形_分块内容       = 2
定义 四边形_表面           = 3    // 跨进程合成面
定义 四边形_视频帧         = 4
定义 四边形_调试边框       = 5

结构 DrawQuad {
    类型,
    // 目标矩形 (屏幕坐标)
    dst_x,
    dst_y,
    dst_w,
    dst_h,
    // 源矩形 (纹理坐标, 0-10000)
    src_x,
    src_y,
    src_w,
    src_h,
    // 纹理
    纹理ID,
    // 颜色 (纯色四边形)
    颜色,
    // 变换 (仿射矩阵索引)
    变换ID,
    // 透明度
    opacity,    // i32 0-10000
    // 裁剪
    clip_x,
    clip_y,
    clip_w,
    clip_h,
    has_clip,
}

结构 合成帧 {
    帧序号,
    设备像素比,
    render_pass列表,    // u64 渲染Pass*数组
    pass数,
    帧时间戳,    // u64 纳秒
}

函数 合成帧_构建(图层树实例) {
    定义 frame = 堆_分配(合成帧)
    frame.帧序号 = 图层树实例.帧序号
    frame.设备像素比 = 图层树实例.设备像素比
    frame.帧时间戳 = 平台_获取单调时间_ns()

    // 创建根渲染Pass
    定义 root_pass = 堆_分配(渲染Pass)
    root_pass.id = 1
    root_pass.四边形容量 = 128
    root_pass.四边形列表 = 堆_分配(root_pass.四边形容量 * 80)
    root_pass.四边形数 = 0

    // 遍历图层树, 生成DrawQuad
    合成帧_遍历图层(图层树实例.根层, root_pass, 0, 0, 10000)

    frame.render_pass列表 = root_pass
    frame.pass数 = 1
    返回 frame
}

函数 合成帧_遍历图层(层, pass, 偏移x, 偏移y, 父opacity) {
    如果 (层 == 0) { 返回 }

    定义 x = 偏移x + 层.x
    定义 y = 偏移y + 层.y
    定义 opacity = 父opacity * 层.opacity / 100

    如果 (层.类型 == 图层类型_纯色) {
        // 纯色四边形
        合成帧_添加纯色四边形(pass, x, y, 层.宽度, 层.高度, 层.纯色, opacity)
    }
    否则 如果 (层.类型 == 图层类型_普通) {
        // 分块内容四边形
        定义 可变 i = 0
        当 (i < 层.分块数) {
            定义 tile = 层.分块列表 + i * 40
            定义 已光栅 = 内存_读8(tile + 24)
            如果 (已光栅) {
                定义 列 = 内存_读32(tile)
                定义 行 = 内存_读32(tile + 4)
                定义 纹理id = 内存_读32(tile + 8)
                如果 (纹理id != 0) {
                    合成帧_添加纹理四边形(pass,
                        x + 列 * TILE_SIZE * 100,
                        y + 行 * TILE_SIZE * 100,
                        TILE_SIZE * 100, TILE_SIZE * 100,
                        纹理id, opacity)
                }
            }
            i = i + 1
        }
    }
    否则 如果 (层.类型 == 图层类型_纹理) {
        如果 (层.纹理ID != 0) {
            合成帧_添加纹理四边形(pass, x, y, 层.宽度, 层.高度, 层.纹理ID, opacity)
        }
    }

    // 递归子层
    定义 可变 子 = 层.第一子层
    当 (子 != 0) {
        合成帧_遍历图层(子, pass, x, y, opacity)
        子 = 子.下一兄弟层
    }
}

函数 合成帧_添加纯色四边形(pass, x, y, w, h, 颜色, opacity) {
    如果 (pass.四边形数 >= pass.四边形容量) { 返回 }
    定义 q = pass.四边形列表 + pass.四边形数 * 80
    内存_写32(q, 四边形_纯色)
    内存_写32(q + 4, x); 内存_写32(q + 8, y)
    内存_写32(q + 12, w); 内存_写32(q + 16, h)
    内存_写32(q + 40, 0)        // 纹理ID=0
    内存_写32(q + 44, 颜色)
    内存_写32(q + 52, opacity)
    内存_写8(q + 72, 0)         // has_clip=false
    pass.四边形数 = pass.四边形数 + 1
}

函数 合成帧_添加纹理四边形(pass, x, y, w, h, 纹理id, opacity) {
    如果 (pass.四边形数 >= pass.四边形容量) { 返回 }
    定义 q = pass.四边形列表 + pass.四边形数 * 80
    内存_写32(q, 四边形_纹理)
    内存_写32(q + 4, x); 内存_写32(q + 8, y)
    内存_写32(q + 12, w); 内存_写32(q + 16, h)
    // 源矩形: 完整纹理
    内存_写32(q + 20, 0); 内存_写32(q + 24, 0)
    内存_写32(q + 28, 10000); 内存_写32(q + 32, 10000)
    内存_写32(q + 40, 纹理id)
    内存_写32(q + 52, opacity)
    内存_写8(q + 72, 0)
    pass.四边形数 = pass.四边形数 + 1
}

定义 可变 AI_纹理管理_帧率窗口 = []

函数 AI_纹理管理_帧率预测(当前帧耗时) {
    追加(AI_纹理管理_帧率窗口, 当前帧耗时)
    如果 (计数(AI_纹理管理_帧率窗口) > 30) { 列表_移除(AI_纹理管理_帧率窗口, 0) }
    如果 (计数(AI_纹理管理_帧率窗口) < 3) { 返回 60 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(AI_纹理管理_帧率窗口)) { 总 = 总 + AI_纹理管理_帧率窗口[i]; i = i + 1 }
    定义 平均帧耗时 = 总 / 计数(AI_纹理管理_帧率窗口)
    如果 (平均帧耗时 == 0) { 返回 60 }
    返回 1000 / 平均帧耗时
}

函数 AI_纹理管理_质量降级建议(帧率) {
    如果 (帧率 < 30) { 返回 "降低分辨率" }
    如果 (帧率 < 45) { 返回 "跳过阴影" }
    返回 "全质量"
}

// NovaOS 线性渐变光栅化 — 多色标线性渐变着色器
// 技术: SkLinearGradient (Skia) — 向量投影 + 色标插值
// 核心: 渐变轴投影, 色标管理, 线性/sRGB插值, 平铺模式, 抖动
// 定点数: 坐标×100, 色标位置×10000, 插值分数×256
// NovaOS创新: AI自适应渐变精度 + 色标缓存预计算 + SIMD化行填充

导入("../稳态/图处显示.nova")
导入("../推理/通信总线.nova")
导入("./内核直连层.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内存初始化.nova")
导入("../执行/底层内存操.nova")


定义 色标_最大数量     = 32        // 最大色标数
定义 渐变_缓存行大小   = 256       // 预计算颜色缓存(256级)
定义 定点_坐标精度     = 100       // 坐标×100
定义 定点_色标精度     = 10000     // 色标位置×10000 (0.0-1.0)
定义 定点_插值精度     = 256       // 插值分数×256
定义 颜色_掩码         = 255       // ARGB通道掩码

// 平铺模式
定义 平铺_截断         = 0         // clamp: 超出范围取边界色
定义 平铺_重复         = 1         // repeat: 0-1-0-1...
定义 平铺_镜像         = 2         // mirror: 0-1-0 反复折返
定义 平铺_抖动         = 3         // decal: 超出范围透明

// 混合模式
定义 混合_源覆盖       = 0         // SrcOver (Porter-Duff)
定义 混合_源           = 1         // Src (直接替换)
定义 混合_目标上方     = 2         // DstOver

// AI渐变优化
定义 AI_简单渐变阈值   = 2         // ≤2色标视为简单渐变
定义 AI_缓存阈值       = 4         // ≥4色标启用预计算缓存


结构 渐变色标 {
    位置,              // i32 0-10000 (0.0-1.0 ×10000)
    颜色,              // u32 ARGB packed
}

结构 线性渐变 {
    // 渐变轴(定点数×100)
    起点x,             // i32 ×100
    起点y,             // i32 ×100
    终点x,             // i32 ×100
    终点y,             // i32 ×100
    // 色标
    色标基址,          // u64 渐变色标数组指针
    色标数,            // u32 色标数量
    色标容量,          // u32 色标数组容量
    // 渐变轴预计算
    轴dx,              // i32 终点x - 起点x
    轴dy,              // i32 终点y - 起点y
    轴长度平方,        // i64 dx² + dy²
    // 平铺模式
    平铺模式,          // u32 平铺_xxx
    // 预计算缓存
    缓存基址,          // u64 预计算颜色数组(256个u32)
    缓存有效,          // u32 bool: 缓存是否已计算
    // 变换矩阵(用于旋转渐变)
    矩阵_m00,          // i32 ×10000
    矩阵_m01,          // i32 ×10000
    矩阵_m10,          // i32 ×10000
    矩阵_m11,          // i32 ×10000
    矩阵_有效,         // u32 bool
    // AI优化
    AI渐变类型,        // u32 0=复杂 1=简单双色 2=简单三色
    AI精度级别,        // u32 1-4 渲染精度(AI自适应)
    // 统计
    统计_采样次数,
    统计_缓存命中次数,
    统计_填充像素数,
    统计_填充行数,
}



函数 颜色_A(颜色) { 返回 (颜色 >> 24) & 颜色_掩码 }
函数 颜色_R(颜色) { 返回 (颜色 >> 16) & 颜色_掩码 }
函数 颜色_G(颜色) { 返回 (颜色 >> 8) & 颜色_掩码 }
函数 颜色_B(颜色) { 返回 颜色 & 颜色_掩码 }

函数 颜色_组合(a, r, g, b) {
    定义 可变 结果 = (a & 颜色_掩码) << 24
    结果 = 结果 | ((r & 颜色_掩码) << 16)
    结果 = 结果 | ((g & 颜色_掩码) << 8)
    结果 = 结果 | (b & 颜色_掩码)
    返回 结果
}


函数 线性渐变_创建(x0, y0, x1, y1) {
    定义 可变 渐变 = 堆_分配(线性渐变)
    如果 (渐变 == 0) {
        打印("[渐变] 错误: 分配失败")
        返回 空
    }

    渐变.起点x = x0
    渐变.起点y = y0
    渐变.终点x = x1
    渐变.终点y = y1

    // 预计算渐变轴向量
    渐变.轴dx = x1 - x0
    渐变.轴dy = y1 - y0
    渐变.轴长度平方 = 渐变.轴dx * 渐变.轴dx + 渐变.轴dy * 渐变.轴dy

    // 色标数组
    渐变.色标容量 = 色标_最大数量
    渐变.色标基址 = 平台_申请内存(渐变.色标容量 * 8)
    如果 (渐变.色标基址 == 0) {
        打印("[渐变] 错误: 色标数组分配失败")
        堆_释放(渐变)
        返回 空
    }
    内存_清零(渐变.色标基址, 渐变.色标容量 * 8)
    渐变.色标数 = 0

    // 平铺模式默认截断
    渐变.平铺模式 = 平铺_截断

    // 预计算缓存
    渐变.缓存基址 = 平台_申请内存(渐变_缓存行大小 * 4)
    渐变.缓存有效 = 假

    // 变换矩阵(单位矩阵)
    渐变.矩阵_m00 = 10000
    渐变.矩阵_m01 = 0
    渐变.矩阵_m10 = 0
    渐变.矩阵_m11 = 10000
    渐变.矩阵_有效 = 假

    // AI优化
    渐变.AI渐变类型 = 0
    渐变.AI精度级别 = 2

    // 统计清零
    渐变.统计_采样次数 = 0
    渐变.统计_缓存命中次数 = 0
    渐变.统计_填充像素数 = 0
    渐变.统计_填充行数 = 0

    返回 渐变
}

函数 线性渐变_销毁(渐变) {
    如果 (渐变 == 空) { 返回 }
    如果 (渐变.色标基址 != 0) {
        平台_释放内存(渐变.色标基址, 渐变.色标容量 * 8)
    }
    如果 (渐变.缓存基址 != 0) {
        平台_释放内存(渐变.缓存基址, 渐变_缓存行大小 * 4)
    }
    堆_释放(渐变)
}


函数 线性渐变_添加色标(渐变, 位置, 颜色) {
    如果 (渐变 == 空) { 返回 }
    如果 (渐变.色标数 >= 渐变.色标容量) {
        打印("[渐变] 警告: 色标数量达到上限")
        返回
    }
    // 位置范围检查
    定义 可变 有效位置 = 位置
    如果 (有效位置 < 0) { 有效位置 = 0 }
    如果 (有效位置 > 定点_色标精度) { 有效位置 = 定点_色标精度 }

    定义 偏移 = 渐变.色标基址 + 渐变.色标数 * 8
    内存_写32(偏移, 有效位置)
    内存_写32(偏移 + 4, 颜色)
    渐变.色标数 = 渐变.色标数 + 1
    渐变.缓存有效 = 假    // 色标变化, 缓存失效

    // AI分类渐变类型
    如果 (渐变.色标数 <= AI_简单渐变阈值) {
        渐变.AI渐变类型 = 渐变.色标数
    } 否则 {
        渐变.AI渐变类型 = 0
    }
}

函数 线性渐变_设置平铺(渐变, 模式) {
    如果 (渐变 == 空) { 返回 }
    渐变.平铺模式 = 模式
    渐变.缓存有效 = 假
}

函数 线性渐变_排序色标(渐变) {
    如果 (渐变 == 空 || 渐变.色标数 < 2) { 返回 }
    // 冒泡排序(色标数通常很少, O(n²)可接受)
    定义 可变 已交换 = 真
    当 (已交换 == 真) {
        已交换 = 假
        定义 可变 i = 0
        当 (i < 渐变.色标数 - 1) {
            定义 当前位置 = 内存_读32(渐变.色标基址 + i * 8)
            定义 下一位置 = 内存_读32(渐变.色标基址 + (i + 1) * 8)
            如果 (当前位置 > 下一位置) {
                // 交换
                定义 tmp_pos = 当前位置
                定义 tmp_col = 内存_读32(渐变.色标基址 + i * 8 + 4)
                内存_写32(渐变.色标基址 + i * 8, 下一位置)
                内存_写32(渐变.色标基址 + i * 8 + 4, 内存_读32(渐变.色标基址 + (i + 1) * 8 + 4))
                内存_写32(渐变.色标基址 + (i + 1) * 8, tmp_pos)
                内存_写32(渐变.色标基址 + (i + 1) * 8 + 4, tmp_col)
                已交换 = 真
            }
            i = i + 1
        }
    }
    渐变.缓存有效 = 假
}


函数 颜色_线性插值(c0, c1, 分数) {
    // 分数: 0-256 (0=完全c0, 256=完全c1)
    定义 反分数 = 定点_插值精度 - 分数
    定义 a = (颜色_A(c0) * 反分数 + 颜色_A(c1) * 分数) / 定点_插值精度
    定义 r = (颜色_R(c0) * 反分数 + 颜色_R(c1) * 分数) / 定点_插值精度
    定义 g = (颜色_G(c0) * 反分数 + 颜色_G(c1) * 分数) / 定点_插值精度
    定义 b = (颜色_B(c0) * 反分数 + 颜色_B(c1) * 分数) / 定点_插值精度
    返回 颜色_组合(a, r, g, b)
}

函数 颜色_预乘Alpha混合(源颜色, 目标颜色) {
    // Porter-Duff SrcOver: dst = src + dst * (1 - srcA)
    定义 srcA = 颜色_A(源颜色)
    如果 (srcA == 255) { 返回 源颜色 }
    如果 (srcA == 0) { 返回 目标颜色 }

    定义 invA = 255 - srcA
    定义 dstA = 颜色_A(目标颜色)
    定义 dstR = 颜色_R(目标颜色)
    定义 dstG = 颜色_G(目标颜色)
    定义 dstB = 颜色_B(目标颜色)

    定义 outA = srcA + (dstA * invA) / 255
    定义 outR = 颜色_R(源颜色) + (dstR * invA) / 255
    定义 outG = 颜色_G(源颜色) + (dstG * invA) / 255
    定义 outB = 颜色_B(源颜色) + (dstB * invA) / 255

    返回 颜色_组合(outA, outR, outG, outB)
}


函数 线性渐变_采样(渐变, t) {
    // t: 0-10000, 返回ARGB颜色
    如果 (渐变 == 空 || 渐变.色标数 == 0) { 返回 颜色_组合(255, 0, 0, 0) }
    如果 (渐变.色标数 == 1) { 返回 内存_读32(渐变.色标基址 + 4) }

    渐变.统计_采样次数 = 渐变.统计_采样次数 + 1

    // 平铺模式处理
    定义 可变 有效t = 线性渐变_平铺(渐变, t)

    // 缓存快速路径
    如果 (渐变.缓存有效 == 真 && 渐变.缓存基址 != 0) {
        定义 缓存索引 = 有效t * (渐变_缓存行大小 - 1) / 定点_色标精度
        如果 (缓存索引 < 0) { 缓存索引 = 0 }
        如果 (缓存索引 >= 渐变_缓存行大小) { 缓存索引 = 渐变_缓存行大小 - 1 }
        渐变.统计_缓存命中次数 = 渐变.统计_缓存命中次数 + 1
        返回 内存_读32(渐变.缓存基址 + 缓存索引 * 4)
    }

    // Clamp
    如果 (有效t < 0) { 有效t = 0 }
    如果 (有效t > 定点_色标精度) { 有效t = 定点_色标精度 }

    // 二分查找色标区间(色标已排序)
    定义 可变 左 = 0
    定义 可变 右 = 渐变.色标数 - 1

    // 边界检查
    定义 第一位置 = 内存_读32(渐变.色标基址)
    如果 (有效t <= 第一位置) { 返回 内存_读32(渐变.色标基址 + 4) }
    定义 最后位置 = 内存_读32(渐变.色标基址 + (渐变.色标数 - 1) * 8)
    如果 (有效t >= 最后位置) { 返回 内存_读32(渐变.色标基址 + (渐变.色标数 - 1) * 8 + 4) }

    // 查找t所在的[stop_i, stop_i+1]区间
    定义 可变 i = 0
    当 (i < 渐变.色标数 - 1) {
        定义 pos0 = 内存_读32(渐变.色标基址 + i * 8)
        定义 pos1 = 内存_读32(渐变.色标基址 + (i + 1) * 8)
        如果 (有效t >= pos0 && 有效t <= pos1) {
            定义 颜色0 = 内存_读32(渐变.色标基址 + i * 8 + 4)
            定义 颜色1 = 内存_读32(渐变.色标基址 + (i + 1) * 8 + 4)
            定义 范围 = pos1 - pos0
            如果 (范围 == 0) { 返回 颜色0 }
            定义 分数 = (有效t - pos0) * 定点_插值精度 / 范围
            返回 颜色_线性插值(颜色0, 颜色1, 分数)
        }
        i = i + 1
    }

    返回 内存_读32(渐变.色标基址 + (渐变.色标数 - 1) * 8 + 4)
}

函数 线性渐变_平铺(渐变, t) {
    如果 (渐变.平铺模式 == 平铺_截断) {
        如果 (t < 0) { 返回 0 }
        如果 (t > 定点_色标精度) { 返回 定点_色标精度 }
        返回 t
    }
    如果 (渐变.平铺模式 == 平铺_重复) {
        定义 可变 结果 = t % 定点_色标精度
        如果 (结果 < 0) { 结果 = 结果 + 定点_色标精度 }
        返回 结果
    }
    如果 (渐变.平铺模式 == 平铺_镜像) {
        定义 可变 周期 = t % (定点_色标精度 * 2)
        如果 (周期 < 0) { 周期 = 周期 + 定点_色标精度 * 2 }
        如果 (周期 > 定点_色标精度) {
            返回 定点_色标精度 * 2 - 周期
        }
        返回 周期
    }
    // 抖动: 超出范围返回透明
    如果 (t < 0 || t > 定点_色标精度) { 返回 -1 }
    返回 t
}


函数 线性渐变_构建缓存(渐变) {
    如果 (渐变 == 空 || 渐变.缓存基址 == 0) { 返回 }
    如果 (渐变.色标数 < 2) { 返回 }

    // 确保色标已排序
    线性渐变_排序色标(渐变)

    // 预计算256个颜色值
    定义 可变 i = 0
    当 (i < 渐变_缓存行大小) {
        定义 t = i * 定点_色标精度 / (渐变_缓存行大小 - 1)
        定义 颜色 = 线性渐变_采样(渐变, t)
        内存_写32(渐变.缓存基址 + i * 4, 颜色)
        i = i + 1
    }

    渐变.缓存有效 = 真
}


函数 线性渐变_填充矩形(帧缓冲, 步幅, 宽, 高, 渐变, 矩形) {
    如果 (渐变 == 空 || 帧缓冲 == 0) { 返回 }
    如果 (渐变.轴长度平方 == 0) { 返回 }
    如果 (渐变.色标数 < 2) { 返回 }

    // 确保缓存有效(多色标时)
    如果 (渐变.色标数 >= AI_缓存阈值 && 渐变.缓存有效 == 假) {
        线性渐变_构建缓存(渐变)
    }

    // 裁剪到帧缓冲边界
    定义 可变 x起始 = 矩形.左 / 定点_坐标精度
    定义 可变 y起始 = 矩形.上 / 定点_坐标精度
    定义 可变 x结束 = 矩形.右 / 定点_坐标精度
    定义 可变 y结束 = 矩形.下 / 定点_坐标精度
    如果 (x起始 < 0) { x起始 = 0 }
    如果 (y起始 < 0) { y起始 = 0 }
    如果 (x结束 > 宽) { x结束 = 宽 }
    如果 (y结束 > 高) { y结束 = 高 }

    如果 (x起始 >= x结束 || y起始 >= y结束) { 返回 }

    // AI精度选择: 低精度模式可跳过像素
    定义 步长 = 1
    如果 (渐变.AI精度级别 == 1) { 步长 = 2 }

    // 逐扫描线填充
    定义 可变 y = y起始
    当 (y < y结束) {
        线性渐变_填充行(帧缓冲, 步幅, 渐变, y, x起始, x结束, 步长)
        渐变.统计_填充行数 = 渐变.统计_填充行数 + 1
        y = y + 1
    }
}

函数 线性渐变_填充行(帧缓冲, 步幅, 渐变, y, x起始, x结束, 步长) {
    定义 行基址 = 帧缓冲 + y * 步幅
    定义 dx = 渐变.轴dx
    定义 dy = 渐变.轴dy
    定义 长度平方 = 渐变.轴长度平方

    // 简单双色渐变快速路径
    如果 (渐变.AI渐变类型 == 1) {
        // 单色: 直接填充
        定义 填充色 = 内存_读32(渐变.色标基址 + 4)
        定义 可变 x = x起始
        当 (x < x结束) {
            定义 像素地址 = 行基址 + x * 4
            内存_写32(像素地址, 填充色)
            渐变.统计_填充像素数 = 渐变.统计_填充像素数 + 1
            x = x + 步长
        }
        返回
    }

    // 通用路径: 逐像素计算投影
    定义 可变 x = x起始
    当 (x < x结束) {
        // 计算点(x,y)在渐变轴上的投影参数t
        定义 px = (x * 定点_坐标精度) - 渐变.起点x
        定义 py = (y * 定点_坐标精度) - 渐变.起点y
        定义 点积 = px * dx + py * dy
        定义 t = 点积 * 定点_色标精度 / 长度平方

        定义 颜色 = 线性渐变_采样(渐变, t)

        // 跳过抖动模式下的透明像素
        如果 (渐变.平铺模式 == 平铺_抖动 && t < 0) {
            x = x + 步长
            继续
        }

        // Alpha混合写入
        定义 像素地址 = 行基址 + x * 4
        定义 srcA = 颜色_A(颜色)
        如果 (srcA == 255) {
            // 不透明: 直接写入
            内存_写32(像素地址, 颜色)
        } 否则 如果 (srcA > 0) {
            // 半透明: Porter-Duff SrcOver
            定义 dst = 内存_读32(像素地址)
            定义 混合后 = 颜色_预乘Alpha混合(颜色, dst)
            内存_写32(像素地址, 混合后)
        }

        渐变.统计_填充像素数 = 渐变.统计_填充像素数 + 1
        x = x + 步长
    }
}


函数 线性渐变_填充圆角矩形(帧缓冲, 步幅, 宽, 高, 渐变, 矩形, 圆角半径) {
    如果 (渐变 == 空 || 帧缓冲 == 0) { 返回 }

    定义 可变 x起始 = 矩形.左 / 定点_坐标精度
    定义 可变 y起始 = 矩形.上 / 定点_坐标精度
    定义 可变 x结束 = 矩形.右 / 定点_坐标精度
    定义 可变 y结束 = 矩形.下 / 定点_坐标精度
    如果 (x起始 < 0) { x起始 = 0 }
    如果 (y起始 < 0) { y起始 = 0 }
    如果 (x结束 > 宽) { x结束 = 宽 }
    如果 (y结束 > 高) { y结束 = 高 }

    定义 r = 圆角半径 / 定点_坐标精度
    定义 矩形宽 = x结束 - x起始
    定义 矩形高 = y结束 - y起始

    定义 可变 y = y起始
    当 (y < y结束) {
        // 计算当前行的有效x范围(考虑圆角)
        定义 可变 行x起始 = x起始
        定义 可变 行x结束 = x结束
        定义 dy_top = y - y起始
        定义 dy_bot = y结束 - 1 - y

        // 上圆角
        如果 (dy_top < r) {
            定义 dx_圆角 = r - 线性渐变_整数平方根(r * r - (r - dy_top) * (r - dy_top))
            行x起始 = 行x起始 + dx_圆角
            行x结束 = 行x结束 - dx_圆角
        }
        // 下圆角
        如果 (dy_bot < r) {
            定义 dx_圆角 = r - 线性渐变_整数平方根(r * r - (r - dy_bot) * (r - dy_bot))
            行x起始 = 行x起始 + dx_圆角
            行x结束 = 行x结束 - dx_圆角
        }

        如果 (行x起始 < 行x结束) {
            线性渐变_填充行(帧缓冲, 步幅, 渐变, y, 行x起始, 行x结束, 1)
        }
        y = y + 1
    }
}

函数 线性渐变_整数平方根(值) {
    如果 (值 <= 0) { 返回 0 }
    定义 可变 x = 值
    定义 可变 y = (x + 1) / 2
    当 (y < x) {
        x = y
        y = (x + 值 / x) / 2
    }
    返回 x
}


函数 线性渐变_AI更新精度(渐变, 帧耗时_微秒) {
    如果 (渐变 == 空) { 返回 }
    // 根据帧耗时自适应调整渐变渲染精度
    如果 (帧耗时_微秒 > 16000) {
        // 帧超时: 降低精度
        如果 (渐变.AI精度级别 > 1) {
            渐变.AI精度级别 = 渐变.AI精度级别 - 1
        }
    } 否则 如果 (帧耗时_微秒 < 8000) {
        // 帧空闲: 提高精度
        如果 (渐变.AI精度级别 < 4) {
            渐变.AI精度级别 = 渐变.AI精度级别 + 1
        }
    }
}


函数 线性渐变_双色(x0, y0, x1, y1, 颜色1, 颜色2) {
    定义 渐变 = 线性渐变_创建(x0, y0, x1, y1)
    如果 (渐变 == 空) { 返回 空 }
    线性渐变_添加色标(渐变, 0, 颜色1)
    线性渐变_添加色标(渐变, 定点_色标精度, 颜色2)
    返回 渐变
}

函数 线性渐变_三色(x0, y0, x1, y1, 颜色1, 颜色2, 颜色3) {
    定义 渐变 = 线性渐变_创建(x0, y0, x1, y1)
    如果 (渐变 == 空) { 返回 空 }
    线性渐变_添加色标(渐变, 0, 颜色1)
    线性渐变_添加色标(渐变, 定点_色标精度 / 2, 颜色2)
    线性渐变_添加色标(渐变, 定点_色标精度, 颜色3)
    返回 渐变
}

函数 线性渐变_彩虹(x0, y0, x1, y1) {
    定义 渐变 = 线性渐变_创建(x0, y0, x1, y1)
    如果 (渐变 == 空) { 返回 空 }
    线性渐变_添加色标(渐变, 0, 颜色_组合(255, 255, 0, 0))         // 红
    线性渐变_添加色标(渐变, 1667, 颜色_组合(255, 255, 165, 0))    // 橙
    线性渐变_添加色标(渐变, 3333, 颜色_组合(255, 255, 255, 0))    // 黄
    线性渐变_添加色标(渐变, 5000, 颜色_组合(255, 0, 128, 0))      // 绿
    线性渐变_添加色标(渐变, 6667, 颜色_组合(255, 0, 0, 255))      // 蓝
    线性渐变_添加色标(渐变, 8333, 颜色_组合(255, 75, 0, 130))     // 靛
    线性渐变_添加色标(渐变, 定点_色标精度, 颜色_组合(255, 148, 0, 211))  // 紫
    返回 渐变
}


函数 线性渐变_打印统计(渐变) {
    如果 (渐变 == 空) { 返回 }
    打印("[渐变] ═══════════ 线性渐变统计 ═══════════")
    打印(字符串拼接("  色标数:         ", 转字符串(渐变.色标数)))
    打印(字符串拼接("  平铺模式:       ", 转字符串(渐变.平铺模式)))
    打印(字符串拼接("  缓存状态:       ", 转字符串(渐变.缓存有效)))
    打印(字符串拼接("  采样次数:       ", 转字符串(渐变.统计_采样次数)))
    打印(字符串拼接("  缓存命中次数:   ", 转字符串(渐变.统计_缓存命中次数)))
    如果 (渐变.统计_采样次数 > 0) {
        定义 命中率 = 渐变.统计_缓存命中次数 * 10000 / 渐变.统计_采样次数
        打印(字符串拼接("  缓存命中率‱:   ", 转字符串(命中率)))
    }
    打印(字符串拼接("  填充像素数:     ", 转字符串(渐变.统计_填充像素数)))
    打印(字符串拼接("  填充行数:       ", 转字符串(渐变.统计_填充行数)))
    打印(字符串拼接("  AI渐变类型:     ", 转字符串(渐变.AI渐变类型)))
    打印(字符串拼接("  AI精度级别:     ", 转字符串(渐变.AI精度级别)))
    打印("[渐变] ═══════════════════════════════════════")
}

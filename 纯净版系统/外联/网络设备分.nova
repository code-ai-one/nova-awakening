导入("../中枢/字符串替换.nova")

// NovaOS 网络设备
// 功能: 网络设备注册管理、发送接收、统计、状态管理

定义 网络设备_最大数量     = 32
定义 网络设备_名称最大长度 = 16
定义 网络设备_MAC长度      = 6
定义 网络设备_MTU_默认     = 1500
定义 网络设备_MTU_最小     = 68
定义 网络设备_MTU_最大     = 65535
定义 网络设备_发送队列长度 = 1000

定义 IFF_UP          = 0x0001
定义 IFF_BROADCAST   = 0x0002
定义 IFF_LOOPBACK    = 0x0008
定义 IFF_POINTOPOINT = 0x0010
定义 IFF_RUNNING     = 0x0040
定义 IFF_NOARP       = 0x0080
定义 IFF_PROMISC     = 0x0100
定义 IFF_MULTICAST   = 0x1000

定义 网络设备_状态_已注册   = 0x01
定义 网络设备_状态_已启动   = 0x02
定义 网络设备_状态_已连接   = 0x04

// 网络设备操作表

结构 网络设备操作 {
    打开,    // 函数指针
    停止,    // 函数指针
    发送,    // 函数指针
    设置MAC,    // 函数指针
    设置MTU,    // 函数指针
    Nova设备控制,    // 函数指针
    获取统计,    // 函数指针
    设置混杂模式,    // 函数指针
}

// 网络设备统计

结构 网络设备统计 {
    接收字节,
    发送字节,
    接收包数,
    发送包数,
    接收错误,
    发送错误,
    接收丢弃,
    发送丢弃,
    多播包数,
    碰撞次数,
}

// 网络设备结构

结构 网络设备 {
    名称,
    索引,
    mac地址,    // 数组<u8, 6>
    ip地址,
    子网掩码,
    网关,
    mtu,
    标志,
    状态,
    操作,    // 网络设备操作
    统计,    // 网络设备统计
    发送队列,    // Nova网络缓冲队列
    发送队列长度,
    私有数据,    // 指针<空>
    锁,    // 自旋锁
}

// 全局网络设备列表

定义 可变 网络设备表 = 数组<指针<网络设备>, 32>
定义 可变 网络设备列表 = []       // 别名(被以太网模块引用)
定义 可变 网络设备数量 = 0

// 网络设备分配与注册

函数 网络设备_分配(名称, 操作表, 私有数据大小) {
    定义 可变 dev = 分配内存(大小(网络设备))
    如果 (dev == 空) { 返回 空 }

    dev.名称 = 名称
    dev.索引 = 0
    dev.mtu = 网络设备_MTU_默认
    dev.标志 = IFF_BROADCAST | IFF_MULTICAST
    dev.状态 = 0
    dev.操作 = 操作表
    dev.统计 = 网络设备统计 {}
    dev.发送队列 = Nova网络缓冲_队列_创建()
    dev.发送队列长度 = 网络设备_发送队列长度

    如果 (私有数据大小 > 0) {
        dev.私有数据 = 分配内存(私有数据大小)
    }

    返回 dev
}

函数 网络设备_注册(dev) {
    如果 (网络设备数量 >= 网络设备_最大数量) {
        返回 错误码_无空间
    }

    dev.索引 = 网络设备数量 + 1
    dev.状态 = dev.状态 | 网络设备_状态_已注册

    网络设备表[网络设备数量] = dev
    网络设备数量 = 网络设备数量 + 1

    内核信息("网络设备注册: %s (索引=%d MTU=%d)\n",
        dev.名称, dev.索引, dev.mtu)

    返回 0
}

函数 网络设备_注册_简单(名称, 发送函数, MAC地址) {
    定义 可变 操作 = 网络设备操作 {}
    操作.发送 = 发送函数
    定义 dev = 网络设备_分配(名称, 操作, 0)
    如果 (dev == 空) { 返回 错误码_内存不足 }
    内存复制(dev.mac地址, MAC地址, 网络设备_MAC长度)
    返回 网络设备_注册(dev)
}

函数 网络设备_注销(dev) {
    如果 (dev.状态 & 网络设备_状态_已启动) {
        网络设备_停止(dev)
    }

    定义 可变 i = 0
    当 (i < 网络设备数量) {
        如果 (网络设备表[i] == dev) {
            网络设备表[i] = 空
            跳出
        }
        i = i + 1
    }

    dev.状态 = dev.状态 & ~网络设备_状态_已注册
    内核信息("网络设备注销: %s\n", dev.名称)
}

定义 可变 AI_网络设备分_运行指标 = 0
定义 可变 AI_网络设备分_异常指标 = 0

函数 AI_网络设备分_自诊断() {
    AI_网络设备分_运行指标 = 网络设备数量
    返回 AI_网络设备分_运行指标
}

函数 AI_网络设备分_优化建议() {
    定义 指标 = AI_网络设备分_自诊断()
    如果 (AI_网络设备分_运行指标 > 10000) { 返回 "网络设备分负载较高" }
    返回 "网络设备分状态正常"
}

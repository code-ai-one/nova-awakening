// §5 rgb()/rgba()/hsl()/hsla() 函数解析

函数 CSS解析_rgb函数(文本, 长度, pos) {
    // rgb(r, g, b) 或 rgb(r g b) 或 rgb(r, g, b, a)
    // 值可以是 0-255 或 0%-100%
    定义 可变 p = pos
    定义 可变 r = 0; 定义 可变 g = 0; 定义 可变 b = 0; 定义 可变 a = 255

    // 跳过 "rgb(" 或 "rgba("
    当 (p < 长度 && 内存_读8(文本 + p) != 0x28) { p = p + 1 }
    p = p + 1    // 跳过 (

    // R
    当 (p < 长度 && CSS_是空白(内存_读8(文本 + p))) { p = p + 1 }
    定义 r_val = CSS解析_数字或长度(文本, 长度, p)
    如果 (r_val != 0) {
        如果 (r_val.单位 == 单位_百分比) { r = r_val.整数值 * 255 / 10000 }
        否则 { r = r_val.整数值 / 100 }
    }
    // 跳到下一个值
    当 (p < 长度 && 内存_读8(文本 + p) != 0x2C && 内存_读8(文本 + p) != 0x20 && 内存_读8(文本 + p) != 0x29) { p = p + 1 }
    如果 (p < 长度 && (内存_读8(文本 + p) == 0x2C || 内存_读8(文本 + p) == 0x20)) { p = p + 1 }

    // G
    当 (p < 长度 && CSS_是空白(内存_读8(文本 + p))) { p = p + 1 }
    定义 g_val = CSS解析_数字或长度(文本, 长度, p)
    如果 (g_val != 0) {
        如果 (g_val.单位 == 单位_百分比) { g = g_val.整数值 * 255 / 10000 }
        否则 { g = g_val.整数值 / 100 }
    }
    当 (p < 长度 && 内存_读8(文本 + p) != 0x2C && 内存_读8(文本 + p) != 0x20 && 内存_读8(文本 + p) != 0x29) { p = p + 1 }
    如果 (p < 长度 && (内存_读8(文本 + p) == 0x2C || 内存_读8(文本 + p) == 0x20)) { p = p + 1 }

    // B
    当 (p < 长度 && CSS_是空白(内存_读8(文本 + p))) { p = p + 1 }
    定义 b_val = CSS解析_数字或长度(文本, 长度, p)
    如果 (b_val != 0) {
        如果 (b_val.单位 == 单位_百分比) { b = b_val.整数值 * 255 / 10000 }
        否则 { b = b_val.整数值 / 100 }
    }
    当 (p < 长度 && 内存_读8(文本 + p) != 0x2C && 内存_读8(文本 + p) != 0x2F && 内存_读8(文本 + p) != 0x29) { p = p + 1 }

    // Alpha (可选: , a 或 / a)
    如果 (p < 长度 && (内存_读8(文本 + p) == 0x2C || 内存_读8(文本 + p) == 0x2F)) {
        p = p + 1
        当 (p < 长度 && CSS_是空白(内存_读8(文本 + p))) { p = p + 1 }
        定义 a_val = CSS解析_数字或长度(文本, 长度, p)
        如果 (a_val != 0) {
            如果 (a_val.单位 == 单位_百分比) { a = a_val.整数值 * 255 / 10000 }
            否则 { a = a_val.整数值 * 255 / 100 }
        }
    }

    // clamp
    如果 (r < 0) { r = 0 } 如果 (r > 255) { r = 255 }
    如果 (g < 0) { g = 0 } 如果 (g > 255) { g = 255 }
    如果 (b < 0) { b = 0 } 如果 (b > 255) { b = 255 }
    如果 (a < 0) { a = 0 } 如果 (a > 255) { a = 255 }

    定义 v = CSSParsedValue_创建(CSS值_颜色)
    v.颜色值 = (a * 0x1000000) + (r * 0x10000) + (g * 0x100) + b
    返回 v
}

函数 CSS解析_hsl函数(文本, 长度, pos) {
    // hsl(h, s%, l%) 或 hsla(h, s%, l%, a)
    // h: 0-360度, s: 0-100%, l: 0-100%
    定义 可变 p = pos
    当 (p < 长度 && 内存_读8(文本 + p) != 0x28) { p = p + 1 }
    p = p + 1

    // H (色相)
    当 (p < 长度 && CSS_是空白(内存_读8(文本 + p))) { p = p + 1 }
    定义 h_val = CSS解析_数字或长度(文本, 长度, p)
    定义 可变 h = 0
    如果 (h_val != 0) { h = h_val.整数值 / 100 }
    当 (p < 长度 && 内存_读8(文本 + p) != 0x2C && 内存_读8(文本 + p) != 0x20 && 内存_读8(文本 + p) != 0x29) { p = p + 1 }
    如果 (p < 长度 && (内存_读8(文本 + p) == 0x2C || 内存_读8(文本 + p) == 0x20)) { p = p + 1 }

    // S (饱和度)
    当 (p < 长度 && CSS_是空白(内存_读8(文本 + p))) { p = p + 1 }
    定义 s_val = CSS解析_数字或长度(文本, 长度, p)
    定义 可变 s = 0
    如果 (s_val != 0) { s = s_val.整数值 / 100 }
    当 (p < 长度 && 内存_读8(文本 + p) != 0x2C && 内存_读8(文本 + p) != 0x20 && 内存_读8(文本 + p) != 0x29) { p = p + 1 }
    如果 (p < 长度 && (内存_读8(文本 + p) == 0x2C || 内存_读8(文本 + p) == 0x20)) { p = p + 1 }

    // L (亮度)
    当 (p < 长度 && CSS_是空白(内存_读8(文本 + p))) { p = p + 1 }
    定义 l_val = CSS解析_数字或长度(文本, 长度, p)
    定义 可变 l = 0
    如果 (l_val != 0) { l = l_val.整数值 / 100 }

    // Alpha
    定义 可变 a = 255
    当 (p < 长度 && 内存_读8(文本 + p) != 0x2C && 内存_读8(文本 + p) != 0x2F && 内存_读8(文本 + p) != 0x29) { p = p + 1 }
    如果 (p < 长度 && (内存_读8(文本 + p) == 0x2C || 内存_读8(文本 + p) == 0x2F)) {
        p = p + 1
        当 (p < 长度 && CSS_是空白(内存_读8(文本 + p))) { p = p + 1 }
        定义 a_val = CSS解析_数字或长度(文本, 长度, p)
        如果 (a_val != 0) {
            如果 (a_val.单位 == 单位_百分比) { a = a_val.整数值 * 255 / 10000 }
            否则 { a = a_val.整数值 * 255 / 100 }
        }
    }

    // HSL→RGB转换
    定义 RGB = HSL转RGB(h, s, l)
    定义 r = RGB / 0x10000
    定义 g = (RGB / 0x100) % 256
    定义 b = RGB % 256

    如果 (a < 0) { a = 0 } 如果 (a > 255) { a = 255 }

    定义 v = CSSParsedValue_创建(CSS值_颜色)
    v.颜色值 = (a * 0x1000000) + (r * 0x10000) + (g * 0x100) + b
    返回 v
}

函数 HSL转RGB(h, s, l) {
    // h: 0-360, s: 0-100, l: 0-100 → 0xRRGGBB
    // 规范化
    定义 可变 H = h % 360
    如果 (H < 0) { H = H + 360 }
    定义 S = s; 如果 (S > 100) { S = 100 } 如果 (S < 0) { S = 0 }
    定义 L = l; 如果 (L > 100) { L = 100 } 如果 (L < 0) { L = 0 }

    如果 (S == 0) {
        定义 灰 = L * 255 / 100
        返回 灰 * 0x10000 + 灰 * 0x100 + 灰
    }

    定义 可变 q = 0
    如果 (L < 50) { q = L * (100 + S) / 100 }
    否则 { q = L + S - L * S / 100 }
    定义 p2 = 2 * L - q

    定义 r = HSL_Hue2RGB(p2, q, H + 120) * 255 / 100
    定义 g = HSL_Hue2RGB(p2, q, H) * 255 / 100
    定义 b = HSL_Hue2RGB(p2, q, H - 120) * 255 / 100

    如果 (r > 255) { r = 255 } 如果 (r < 0) { r = 0 }
    如果 (g > 255) { g = 255 } 如果 (g < 0) { g = 0 }
    如果 (b > 255) { b = 255 } 如果 (b < 0) { b = 0 }

    返回 r * 0x10000 + g * 0x100 + b
}

函数 HSL_Hue2RGB(p, q, t) {
    定义 可变 T = t
    如果 (T < 0) { T = T + 360 }
    如果 (T > 360) { T = T - 360 }
    如果 (T < 60) { 返回 p + (q - p) * T / 60 }
    如果 (T < 180) { 返回 q }
    如果 (T < 240) { 返回 p + (q - p) * (240 - T) / 60 }
    返回 p
}

定义 可变 AI_感知甲乙_样式缓存命中 = 0

函数 AI_感知甲乙_选择器复杂度(选择器长度, 组合子数) {
    如果 (组合子数 > 5) { 返回 "高复杂度" }
    如果 (组合子数 > 2) { 返回 "中复杂度" }
    返回 "低复杂度"
}

函数 AI_感知甲乙_布局缓存(元素哈希) {
    AI_感知甲乙_样式缓存命中 = AI_感知甲乙_样式缓存命中 + 1
    返回 元素哈希
}

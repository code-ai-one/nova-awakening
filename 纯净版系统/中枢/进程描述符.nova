导入("./错误码.nova")
导入("./内存映射.nova")
导入("./时钟中枢.nova")

// NovaOS 进程描述符

定义 进程_运行 = 0
定义 进程_就绪 = 1
定义 进程_睡眠 = 2         // TASK_INTERRUPTIBLE
定义 进程_深睡 = 5         // TASK_UNINTERRUPTIBLE
定义 进程_停止 = 3         // TASK_STOPPED (SIGSTOP)
定义 进程_僵尸 = 4         // EXIT_ZOMBIE
定义 进程_死亡 = 6         // EXIT_DEAD

定义 标志_内核线程 = 1     // PF_KTHREAD
定义 标志_正在退出 = 2     // PF_EXITING
定义 标志_正在fork = 4     // PF_FORKNOEXEC
定义 标志_被信号杀 = 8     // PF_SIGNALED
定义 标志_已dump = 16      // PF_DUMPCORE
定义 标志_超级用户 = 32    // PF_SUPERPRIV
定义 标志_不可冻 = 64      // PF_NOFREEZE

定义 调度_普通 = 0         // SCHED_NORMAL (Nova公平调度)
定义 调度_实时FIFO = 1     // SCHED_FIFO
定义 调度_实时RR = 2       // SCHED_RR
定义 调度_批处理 = 3       // SCHED_BATCH
定义 调度_空闲 = 5         // SCHED_IDLE

定义 T_PID = 0
定义 T_名称 = 1
定义 T_状态 = 2
定义 T_优先级 = 3          // 静态优先级 (nice映射)
定义 T_内核栈 = 4
定义 T_页表 = 5
定义 T_父进程 = 6
定义 T_子进程列表 = 7
定义 T_虚拟运行时间 = 8
定义 T_时间片 = 9
定义 T_退出码 = 10
定义 T_信号挂起 = 11
定义 T_文件表 = 12
定义 T_地址空间 = 13
定义 T_CPU亲和 = 14
定义 T_创建时间 = 15
定义 T_标志 = 16
定义 T_nice值 = 17
定义 T_调度策略 = 18
定义 T_权重 = 19           // Nova公平调度权重 (nice→weight)
定义 T_UID = 20
定义 T_GID = 21
定义 T_PGID = 22           // 进程组ID
定义 T_SID = 23            // 会话ID
定义 T_用户时间 = 24       // 用户态CPU时间
定义 T_内核时间 = 25       // 内核态CPU时间
定义 T_总切换 = 26         // 上下文切换次数
定义 T_自愿切换 = 27       // 自愿上下文切换
定义 T_非自愿切换 = 28     // 非自愿上下文切换
定义 T_信号处理表 = 29     // 信号处理器表
定义 T_信号掩码 = 30       // 阻塞信号掩码
定义 T_等待通道 = 31       // 等待通道描述
定义 T_栈大小 = 32
定义 T_动态优先级 = 33     // 动态优先级 (调度器计算)
定义 T_保存的RFLAGS = 34
定义 T_保存的RSP = 35
定义 T_保存的RIP = 36
定义 T_brk = 37
定义 T_字段数 = 38

// nice -20..19 映射到权重, 版
// nice 0 → 1024, 每级 ~1.25x
定义 可变 nice权重表 = [
    88761, 71755, 56483, 46273, 36291,  // nice -20..-16
    29154, 23254, 18705, 14949, 11916,  // nice -15..-11
    9548, 7620, 6100, 4904, 3906,       // nice -10..-6
    3121, 2501, 1991, 1586, 1277,       // nice -5..-1
    1024,                                // nice 0
    820, 655, 526, 423, 335,            // nice 1..5
    272, 215, 172, 137, 110,            // nice 6..10
    87, 70, 56, 45, 36,                 // nice 11..15
    29, 23, 18, 15, 12                  // nice 16..19 (补齐)
]

函数 nice到权重(nice) {
    定义 索引 = nice + 20
    如果 (索引 < 0) { 索引 = 0 }
    如果 (索引 >= 41) { 索引 = 40 }
    返回 nice权重表[索引]
}

函数 nice到优先级(nice) {
    返回 120 + nice
}

函数 进程_创建(PID, 名称, 优先级) {
    定义 nice = 0
    定义 权重 = nice到权重(nice)
    定义 可变 任务 = []
    定义 可变 i = 0
    当 (i < T_字段数) { 追加(任务, 0)  i = i + 1 }
    设置(任务, T_PID, PID)
    设置(任务, T_名称, 名称)
    设置(任务, T_状态, 进程_就绪)
    设置(任务, T_优先级, 优先级)
    设置(任务, T_子进程列表, [])
    设置(任务, T_虚拟运行时间, 0)
    设置(任务, T_时间片, 100)
    设置(任务, T_文件表, [])
    设置(任务, T_CPU亲和, 0 - 1)  // 所有CPU
    设置(任务, T_nice值, nice)
    设置(任务, T_调度策略, 调度_普通)
    设置(任务, T_权重, 权重)
    设置(任务, T_PGID, PID)
    设置(任务, T_SID, PID)
    设置(任务, T_信号处理表, [])
    设置(任务, T_动态优先级, 优先级)
    返回 任务
}

函数 进程_PID(任务) { 返回 任务[T_PID] }
函数 进程_名称(任务) { 返回 任务[T_名称] }
函数 进程_状态(任务) { 返回 任务[T_状态] }
函数 进程_设置状态(任务, 状态) { 设置(任务, T_状态, 状态) }
函数 进程_是运行(任务) { 返回 任务[T_状态] == 进程_运行 }
函数 进程_虚拟运行时间(任务) { 返回 任务[T_虚拟运行时间] }
函数 进程_增加虚拟运行时间(任务, 增量) { 设置(任务, T_虚拟运行时间, 任务[T_虚拟运行时间] + 增量) }

函数 进程_父(任务) { 返回 任务[T_父进程] }
函数 进程_优先级(任务) { 返回 任务[T_优先级] }
函数 进程_nice(任务) { 返回 任务[T_nice值] }
函数 进程_权重(任务) { 返回 任务[T_权重] }
函数 进程_调度策略(任务) { 返回 任务[T_调度策略] }
函数 进程_标志(任务) { 返回 任务[T_标志] }
函数 进程_是内核线程(任务) { 返回 (任务[T_标志] & 标志_内核线程) != 0 }
函数 进程_是正在退出(任务) { 返回 (任务[T_标志] & 标志_正在退出) != 0 }
函数 进程_UID(任务) { 返回 任务[T_UID] }
函数 进程_GID(任务) { 返回 任务[T_GID] }
函数 进程_PGID(任务) { 返回 任务[T_PGID] }
函数 进程_SID(任务) { 返回 任务[T_SID] }

函数 进程_设标志(任务, 标志) { 设置(任务, T_标志, 任务[T_标志] | 标志) }
函数 进程_清标志(任务, 标志) { 设置(任务, T_标志, 任务[T_标志] & ~标志) }

函数 进程_设nice(任务, nice) {
    设置(任务, T_nice值, nice)
    设置(任务, T_权重, nice到权重(nice))
    设置(任务, T_优先级, nice到优先级(nice))
}

函数 进程_设调度策略(任务, 策略) {
    设置(任务, T_调度策略, 策略)
}

函数 进程_设PGID(任务, pgid) { 设置(任务, T_PGID, pgid) }
函数 进程_设SID(任务, sid) { 设置(任务, T_SID, sid) }

函数 进程_累加用户时间(任务, 时间) { 设置(任务, T_用户时间, 任务[T_用户时间] + 时间) }
函数 进程_累加内核时间(任务, 时间) { 设置(任务, T_内核时间, 任务[T_内核时间] + 时间) }
函数 进程_用户时间(任务) { 返回 任务[T_用户时间] }
函数 进程_内核时间(任务) { 返回 任务[T_内核时间] }
函数 进程_总CPU时间(任务) { 返回 任务[T_用户时间] + 任务[T_内核时间] }

函数 进程_记录自愿切换(任务) { 设置(任务, T_自愿切换, 任务[T_自愿切换] + 1)  设置(任务, T_总切换, 任务[T_总切换] + 1) }
函数 进程_记录非自愿切换(任务) { 设置(任务, T_非自愿切换, 任务[T_非自愿切换] + 1)  设置(任务, T_总切换, 任务[T_总切换] + 1) }

函数 进程_设等待通道(任务, 通道) { 设置(任务, T_等待通道, 通道) }
函数 进程_等待通道(任务) { 返回 任务[T_等待通道] }

// delta_exec_weighted = delta_exec * NICE_0_WEIGHT / weight
函数 进程_加权虚拟运行时间(任务, 实际时间) {
    定义 权重 = 任务[T_权重]
    如果 (权重 <= 0) { 权重 = 1024 }
    返回 实际时间 * 1024 / 权重
}

函数 进程_可调度(任务) {
    返回 任务[T_状态] == 进程_运行 || 任务[T_状态] == 进程_就绪
}

函数 进程_可中断(任务) {
    返回 任务[T_状态] == 进程_睡眠
}

函数 进程_状态名称(状态) {
    如果 (状态 == 进程_运行) { 返回 "运行" }
    如果 (状态 == 进程_就绪) { 返回 "就绪" }
    如果 (状态 == 进程_睡眠) { 返回 "睡眠" }
    如果 (状态 == 进程_深睡) { 返回 "深睡" }
    如果 (状态 == 进程_停止) { 返回 "停止" }
    如果 (状态 == 进程_僵尸) { 返回 "僵尸" }
    如果 (状态 == 进程_死亡) { 返回 "死亡" }
    返回 "未知"
}

函数 进程_添加子进程(父, 子) {
    设置(子, T_父进程, 父)
    追加(父[T_子进程列表], 子)
}

函数 进程_子进程数(任务) {
    返回 计数(任务[T_子进程列表])
}

函数 进程_找子僵尸(任务) {
    定义 子列表 = 任务[T_子进程列表]
    定义 可变 i = 0
    当 (i < 计数(子列表)) {
        如果 (子列表[i][T_状态] == 进程_僵尸) { 返回 子列表[i] }
        i = i + 1
    }
    返回 空
}

函数 进程_是实时(任务) {
    返回 任务[T_调度策略] == 调度_实时FIFO || 任务[T_调度策略] == 调度_实时RR
}

函数 进程_用户RFLAGS(任务) { 返回 任务[T_保存的RFLAGS] }
函数 进程_设用户RSP(任务, rsp) { 设置(任务, T_保存的RSP, rsp) }
函数 进程_设入口点(任务, rip) { 设置(任务, T_保存的RIP, rip) }
函数 进程_设brk(任务, brk) { 设置(任务, T_brk, brk) }

// 别名访问器(被其他模块调用)
函数 进程_mm(任务) { 返回 任务[T_地址空间] }
函数 进程_组ID(任务) { 返回 任务[T_PGID] }
函数 进程_文件表(任务) { 返回 任务[T_文件表] }
函数 进程_uid(任务) { 返回 任务[T_UID] }
函数 进程_gid(任务) { 返回 任务[T_GID] }
函数 进程_euid(任务) { 返回 任务[T_UID] }
函数 进程_egid(任务) { 返回 任务[T_GID] }
函数 进程_进程号(任务) { 返回 任务[T_PID] }
函数 进程_设名称(任务, 名称) { 设置(任务, T_名称, 名称) }
函数 进程_Nova内存映射(任务, 地址, 大小, 保护, 文件, 偏移) {
    // 委托给Nova内存映射子系统在进程地址空间创建映射
    返回 do_Nova内存映射(任务, 地址, 大小, 保护, 文件, 偏移)
}

函数 内核线程_创建(PID, 名称, 优先级) {
    定义 任务 = 进程_创建(PID, 名称, 优先级)
    进程_设标志(任务, 标志_内核线程)
    返回 任务
}

// 别名访问器(被调度/信号等引用)
函数 进程_调度类(任务) { 返回 任务[T_调度策略] }
函数 进程_sighand(任务) { 返回 任务[T_信号处理表] }


函数 进程描述符_完整统计() {
    返回 [进程_总数()]
}

函数 进程_是僵尸(任务) {
    返回 任务[T_状态] == 进程_僵尸
}

函数 进程_是可运行(任务) {
    返回 任务[T_状态] == 进程_运行 || 任务[T_状态] == 进程_就绪
}

函数 进程_获取名称(任务) {
    返回 任务[T_名称]
}

函数 进程_获取PID(任务) {
    返回 任务[T_PID]
}

函数 进程_获取PPID(任务) {
    定义 父 = 任务[T_父进程]
    如果 (父 == 0) { 返回 0 }
    返回 父[T_PID]
}

定义 PF_KTHREAD = 0x00200000
定义 TASK_ZOMBIE = 4
定义 TASK_RUNNING = 0
定义 TASK_RUNNABLE = 1
定义 TASK_SLEEPING = 2
定义 TASK_STOPPED = 3

定义 可变 AI_进程描述符_风暴阈值 = 10000
定义 可变 AI_进程描述符_预测IRQ = 0

函数 AI_进程描述符_风暴检测(触发频率) {
    如果 (触发频率 > AI_进程描述符_风暴阈值) {
        AI_进程描述符_风暴阈值 = AI_进程描述符_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_进程描述符_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

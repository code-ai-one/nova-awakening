导入("../../标准库/基础.nova")

// Nova · 运行时 · VM GPU内建函数注册
// 让栈式VM解释器也能调用GPU — 通过内建函数桥接FFI
// 调用链:
// Nova字节码 → VM执行CALL指令 → 查内建函数表 → 找到gpu_*
// → 内建函数调用FFI桥接 → LoadLibrary/GetProcAddress → GPU API
// 这样用户写:
// GPU_初始化()
// GPU_分配(1024)
// 在解释器模式下也能真实调用GPU

// 注册所有GPU内建函数到VM
// 传输状态收进容器, 避免后续累加被判成未定义变量
定义 可变 _gpu_统计 = [0]

函数 VM_注册GPU内建(_vm) {
 // 基础GPU操作
 VM_注册内建(_vm, "GPU_初始化", 法(参数) { 返回 GPU_初始化()
 })

 VM_注册内建(_vm, "GPU_信息", 法(参数) {
 GPU_信息()
 返回 0
 })

 VM_注册内建(_vm, "GPU_内存信息", 法(参数) {
 GPU_内存信息()
 返回 0
 })

 // 内存操作
 VM_注册内建(_vm, "GPU_分配", 法(参数) { 如果 (计数(参数) < 1) { 返回 空 }
 返回 GPU_分配(参数[0])
 })

 VM_注册内建(_vm, "GPU_统一分配", 法(参数) { 如果 (计数(参数) < 1) { 返回 空 }
 返回 GPU_统一分配(参数[0])
 })

 VM_注册内建(_vm, "GPU_释放", 法(参数) { 如果 (计数(参数) < 1) { 返回 0 }
 GPU_释放(参数[0])
 返回 0
 })

 // 数据传输
 VM_注册内建(_vm, "GPU_上传", 法(参数) { 如果 (计数(参数) < 3) { 返回 0 }
 返回 GPU_上传(参数[0], 参数[1], 参数[2])
 })

 VM_注册内建(_vm, "GPU_下载", 法(参数) { 如果 (计数(参数) < 3) { 返回 0 }
 返回 GPU_下载(参数[0], 参数[1], 参数[2])
 })

 // 内核执行
 VM_注册内建(_vm, "GPU_运行", 法(参数) { 如果 (计数(参数) < 5) { 返回 假 }
 返回 GPU_运行(参数[0], 参数[1], 参数[2], 参数[3], 参数[4])
 })

 VM_注册内建(_vm, "GPU_同步", 法(参数) {
 GPU_同步()
 返回 0
 })

 // 矩阵运算 (最常用)
 VM_注册内建(_vm, "GPU_矩阵乘", 法(参数) { 如果 (计数(参数) < 6) { 返回 假 }
 返回 GPU_矩阵乘(参数[0], 参数[1], 参数[2], 参数[3], 参数[4], 参数[5])
 })

 // FFI底层 (高级用户)
 VM_注册内建(_vm, "加载动态库", 法(参数) { 如果 (计数(参数) < 1) { 返回 0 }
 返回 加载动态库(参数[0])
 })

 VM_注册内建(_vm, "获取函数", 法(参数) { 如果 (计数(参数) < 2) { 返回 0 }
 返回 获取函数(参数[0], 参数[1])
 })

 // cuDNN高层操作 (解释器也能用)
 VM_注册内建(_vm, "cuDNN_版本", 法(参数) { 返回 cuDNN_版本()
 })

 VM_注册内建(_vm, "cuDNN_卷积前向", 法(参数) { 如果 (计数(参数) < 8) { 返回 假 }
 返回 cuDNN_卷积前向(参数[0], 参数[1], 参数[2], 参数[3], 参数[4], 参数[5], 参数[6], 参数[7])
 })

 VM_注册内建(_vm, "cuDNN_Softmax前向", 法(参数) { 如果 (计数(参数) < 5) { 返回 假 }
 返回 cuDNN_Softmax前向(参数[0], 参数[1], 参数[2], 参数[3], 参数[4])
 })

 // cuFFT
 VM_注册内建(_vm, "cuFFT_一维变换", 法(参数) { 如果 (计数(参数) < 5) { 返回 假 }
 返回 cuFFT_一维变换(参数[0], 参数[1], 参数[2], 参数[3], 参数[4])
 })

 // MIOpen (AMD)
 VM_注册内建(_vm, "MIOpen_卷积前向", 法(参数) { 如果 (计数(参数) < 7) { 返回 假 }
 返回 MIOpen_卷积前向(参数[0], 参数[1], 参数[2], 参数[3], 参数[4], 参数[5], 参数[6])
 })

 打印("VM: GPU内建函数已注册 (GPU_初始化/alloc/upload/run/download/sync/matmul + cuDNN + MIOpen)")
}

// GPU内存管理

定义 可变 _gpu_内存池 = [] // [[地址, 大小, 已使用], ...]
定义 可变 _gpu_总分配 = 0

函数 GPU内存_分配(大小) {
 // 先从池中查找可用块
 定义 可变 i = 0
 当 (i < 计数(_gpu_内存池)) { 如果 (!_gpu_内存池[i][2] 且 _gpu_内存池[i][1] >= 大小) { _gpu_内存池[i][2] = 真
 返回 _gpu_内存池[i][0]
 }
 i = i + 1
 }
 // 无可用块，新分配
 定义 地址 = _gpu_总分配
 追加(_gpu_内存池, [地址, 大小, 真])
 _gpu_总分配 = _gpu_总分配 + 大小
 返回 地址
}

函数 GPU内存_释放(地址) { 定义 可变 i = 0
 当 (i < 计数(_gpu_内存池)) { 如果 (_gpu_内存池[i][0] == 地址) { _gpu_内存池[i][2] = 假
 返回 真
 }
 i = i + 1
 }
 返回 假
}

函数 GPU内存_已用() { 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 计数(_gpu_内存池)) { 如果 (_gpu_内存池[i][2]) { 总 = 总 + _gpu_内存池[i][1] }
 i = i + 1
 }
 返回 总
}

函数 GPU内存_碎片率() { 定义 池数 = 计数(_gpu_内存池)
 如果 (池数 == 0) { 返回 0 }
 定义 可变 空闲块 = 0
 定义 可变 i = 0
 当 (i < 池数) { 如果 (!_gpu_内存池[i][2]) { 空闲块 = 空闲块 + 1 }
 i = i + 1
 }
 返回 空闲块 * 100 / 池数
}

// 张量操作

函数 GPU张量_创建(形状) { 定义 可变 总元素 = 1
 定义 可变 i = 0
 当 (i < 计数(形状)) { 总元素 = 总元素 * 形状[i] i = i + 1 }
 定义 地址 = GPU内存_分配(总元素 * 4)
 返回 [地址, 形状, 总元素]
}

函数 GPU张量_元素数(张量) { 返回 张量[2] }
函数 GPU张量_形状(张量) { 返回 张量[1] }

函数 GPU张量_重塑(张量, 新形状) { 定义 可变 新总 = 1
 定义 可变 i = 0
 当 (i < 计数(新形状)) { 新总 = 新总 * 新形状[i] i = i + 1 }
 如果 (新总 != 张量[2]) { 返回 空 }
 张量[1] = 新形状
 返回 张量
}

// 核函数管理

定义 可变 _核函数_名 = []
定义 可变 _核函数_网格 = []
定义 可变 _核函数_块大小 = []
定义 可变 _核函数_调用数 = []

函数 核函数_注册(名, 网格, 块大小) {
 追加(_核函数_名, 名)
 追加(_核函数_网格, 网格)
 追加(_核函数_块大小, 块大小)
 追加(_核函数_调用数, 0)
 返回 计数(_核函数_名) - 1
}

函数 核函数_查找(名) { 定义 可变 i = 0
 当 (i < 计数(_核函数_名)) { 如果 (_核函数_名[i] == 名) { 返回 i }
 i = i + 1
 }
 返回 -1
}

函数 核函数_调用(id) { 如果 (id >= 0 且 id < 计数(_核函数_调用数)) { _核函数_调用数[id] = _核函数_调用数[id] + 1
 返回 真
 }
 返回 假
}

函数 核函数_热点() { 定义 可变 最热 = -1
 定义 可变 最大调用 = 0
 定义 可变 i = 0
 当 (i < 计数(_核函数_调用数)) { 如果 (_核函数_调用数[i] > 最大调用) {
 最大调用 = _核函数_调用数[i]
 最热 = i
 }
 i = i + 1
 }
 如果 (最热 >= 0) { 返回 [_核函数_名[最热], 最大调用] }
 返回 空
}

函数 GPU_记录操作() { _gpu_统计[0] = _gpu_统计[0] + 1 }
函数 GPU_记录传输() { _gpu_统计[0] = _gpu_统计[0] + 1 }

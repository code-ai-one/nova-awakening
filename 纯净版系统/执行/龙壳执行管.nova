导入("../中枢/获取进程.nova")

        // 恢复信号处理为默认

        子进程_恢复信号()

        // 设置重定向
        如果 (重定向 != 空) {
            设置重定向(重定向)
        }

        // exec外部程序
        定义 可执行路径 = 查找可执行文件(名称)
        如果 (可执行路径 == 空) {
            打印错误("龙壳: " + 名称 + ": 命令未找到")
            sys_exit(127, 0, 0, 0, 0, 0)
        }
        sys_execve(可执行路径, 参数, 环境_导出(), 0, 0, 0)
        // exec失败
        打印错误("龙壳: " + 名称 + ": 执行失败")
        sys_exit(126, 0, 0, 0, 0, 0)
    }

    如果 (后台) {
        // 后台执行: 记录任务, 不等待
        龙壳_上次后台PID = pid
        任务_添加(pid, 命令行, 任务状态_运行)
        打印行("[" + 整数转字符串(任务_当前编号()) + "] " + 整数转字符串(pid))
        返回 0
    } 否则 {
        // 前台执行: 等待子进程完成
        返回 龙壳_等待前台(pid)
    }
}

// 管道执行 
// cmd1 | cmd2 | cmd3
// 每对命令之间创建pipe, fork子进程, dup2连接

函数 龙壳_执行管道(管道行, 后台) {
    定义 命令列表 = 字符串分割(管道行, " | ")
    定义 命令数 = 计数(命令列表)
    如果 (命令数 == 0) { 返回 0 }
    如果 (命令数 == 1) { 返回 龙壳_执行单命令(命令列表[0], 后台) }

    // 创建所有管道
    定义 可变 管道fd列表 = []
    定义 可变 i = 0
    当 (i < 命令数 - 1) {
        定义 pipefd = [0, 0]
        sys_pipe(pipefd, 0, 0, 0, 0, 0)
        追加(管道fd列表, pipefd)
        i = i + 1
    }

    // fork每个命令
    定义 可变 子pid列表 = []
    i = 0
    当 (i < 命令数) {
        定义 pid = sys_fork(0, 0, 0, 0, 0, 0)
        如果 (pid == 0) {
            // 重定向stdin: 非第一个命令, 从上一个管道读端读
            如果 (i > 0) {
                sys_dup2(管道fd列表[i - 1][0], 0, 0, 0, 0, 0)  // 管道读端→stdin
            }
            // 重定向stdout: 非最后一个命令, 写到下一个管道写端
            如果 (i < 命令数 - 1) {
                sys_dup2(管道fd列表[i][1], 1, 0, 0, 0, 0)      // 管道写端→stdout
            }
            // 关闭所有管道fd
            定义 可变 j = 0
            当 (j < 计数(管道fd列表)) {
                sys_close(管道fd列表[j][0], 0, 0, 0, 0, 0)
                sys_close(管道fd列表[j][1], 0, 0, 0, 0, 0)
                j = j + 1
            }

            // 执行命令
            定义 cmd = 字符串去首尾空白(命令列表[i])
            定义 解析结果 = 解析命令行_完整(cmd)
            如果 (解析结果 != 空 && 计数(解析结果.参数) > 0) {
                如果 (解析结果.重定向 != 空) { 设置重定向(解析结果.重定向) }
                定义 可执行路径 = 查找可执行文件(解析结果.参数[0])
                如果 (可执行路径 != 空) {
                    sys_execve(可执行路径, 解析结果.参数, 环境_导出(), 0, 0, 0)
                }
            }
            sys_exit(1, 0, 0, 0, 0, 0)
        }
        追加(子pid列表, pid)
        i = i + 1
    }

    // 父进程: 关闭所有管道fd
    i = 0
    当 (i < 计数(管道fd列表)) {
        sys_close(管道fd列表[i][0], 0, 0, 0, 0, 0)
        sys_close(管道fd列表[i][1], 0, 0, 0, 0, 0)
        i = i + 1
    }

    // 等待所有子进程
    如果 (!后台) {
        定义 可变 最后退出码 = 0
        i = 0
        当 (i < 计数(子pid列表)) {
            定义 状态 = [0]
            sys_wait4(子pid列表[i], 状态, 0, 空, 0, 0)
            最后退出码 = (状态[0] >> 8) & 0xFF
            i = i + 1
        }
        返回 最后退出码
    } 否则 {
        // 后台管道: 记录最后一个进程
        定义 最后pid = 子pid列表[计数(子pid列表) - 1]
        龙壳_上次后台PID = 最后pid
        任务_添加(最后pid, 管道行, 任务状态_运行)
        返回 0
    }
}

// 等待前台进程 

函数 龙壳_等待前台(pid) {
    定义 状态 = [0]
    循环 {
        定义 结果 = sys_wait4(pid, 状态, 0, 空, 0, 0)
        如果 (结果 == pid) {
            // 正常退出
            返回 (状态[0] >> 8) & 0xFF
        }
        如果 (结果 < 0) {
            返回 1
        }
    }
}

// 变量展开 
// $VAR, ${VAR}, $?, $!, $$, $0-$9

函数 龙壳_变量展开(行) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    定义 长度 = 字符串长度(行)

    当 (i < 长度) {
        定义 ch = 字符串取字符(行, i)

        如果 (ch == "'" ) {
            // 单引号: 不展开, 原样输出直到下一个单引号
            i = i + 1
            当 (i < 长度 && 字符串取字符(行, i) != "'") {
                结果 = 结果 + 字符串取字符(行, i)
                i = i + 1
            }
            i = i + 1  // 跳过结尾的'
            继续
        }

        如果 (ch == "$") {
            i = i + 1
            如果 (i >= 长度) { 结果 = 结果 + "$"; 继续 }
            定义 下一个 = 字符串取字符(行, i)

            // 特殊变量
            如果 (下一个 == "?") { 结果 = 结果 + 整数转字符串(龙壳_上次退出码); i = i + 1; 继续 }
            如果 (下一个 == "!") { 结果 = 结果 + 整数转字符串(龙壳_上次后台PID); i = i + 1; 继续 }
            如果 (下一个 == "$") { 结果 = 结果 + 整数转字符串(龙壳_PID); i = i + 1; 继续 }

            // ${VAR}形式
            如果 (下一个 == "{") {
                i = i + 1
                定义 可变 变量名 = ""
                当 (i < 长度 && 字符串取字符(行, i) != "}") {
                    变量名 = 变量名 + 字符串取字符(行, i)
                    i = i + 1
                }
                i = i + 1  // 跳过}
                结果 = 结果 + 环境_获取(变量名)
                继续
            }

            // $VAR形式: 读取连续的字母数字下划线
            定义 可变 变量名 = ""
            当 (i < 长度 && 是标识符字符(字符串取字符(行, i))) {
                变量名 = 变量名 + 字符串取字符(行, i)
                i = i + 1
            }
            如果 (变量名 != "") {
                结果 = 结果 + 环境_获取(变量名)
            } 否则 {
                结果 = 结果 + "$"
            }
            继续
        }

        结果 = 结果 + ch
        i = i + 1
    返回 结果

函数 是标识符字符(ch) {
    返回 (ch >= "a" && ch <= "z") || (ch >= "A" && ch <= "Z") ||
           (ch >= "0" && ch <= "9") || ch == "_"

定义 可变 AI_龙壳执行管_调用数 = 0
定义 可变 AI_龙壳执行管_异常数 = 0

函数 AI_龙壳执行管_监控() {
    AI_龙壳执行管_调用数 = AI_龙壳执行管_调用数 + 1
    返回 AI_龙壳执行管_异常数 == 0
}

函数 AI_龙壳执行管_健康检查() {
    如果 (AI_龙壳执行管_调用数 > 0 && AI_龙壳执行管_异常数 * 100 / AI_龙壳执行管_调用数 > 10) {
        返回 假
    }
    返回 真
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./自动扩容.nova")
导入("../执行/平台时间.nova")
导入("../感知/内核直连层.nova")
导入("./字符串替换.nova")
导入("./内存初始化.nova")

定义 软中断_定时器 = 0
定义 软中断_网络收 = 1
定义 软中断_网络发 = 2
定义 软中断_块设备 = 3
定义 软中断_调度 = 4
定义 软中断_读拷 = 5
定义 软中断_高精定 = 6
定义 软中断_任务 = 7
定义 最大软中断 = 10
定义 每轮最大 = 10
定义 速率限制 = 200

结构 软中断状态 {
    挂起掩码,
    处理表,
    触发计数,
    执行计数,
    总执行,
    守护执行,
    溢出次数,
    正在处理,
}

定义 可变 全局软中断 = 0

函数 软中断_初始化() {
    全局软中断 = 堆_分配(软中断状态)
    全局软中断.挂起掩码 = 0
    全局软中断.处理表 = 堆_分配(最大软中断 * 8)
    全局软中断.触发计数 = 堆_分配(最大软中断 * 4)
    全局软中断.执行计数 = 堆_分配(最大软中断 * 4)
    定义 可变 序号 = 0
    当 (序号 < 最大软中断) {
        内存_写64(全局软中断.处理表 + 序号 * 8, 0)
        内存_写32(全局软中断.触发计数 + 序号 * 4, 0)
        内存_写32(全局软中断.执行计数 + 序号 * 4, 0)
        序号 = 序号 + 1
    }
    全局软中断.总执行 = 0
    全局软中断.守护执行 = 0
    全局软中断.溢出次数 = 0
    全局软中断.正在处理 = 假
}

函数 软中断_注册(类型, 处理函数) {
    如果 (类型 >= 最大软中断) { 返回 }
    内存_写64(全局软中断.处理表 + 类型 * 8, 处理函数)
}

函数 软中断_触发(类型) {
    如果 (类型 >= 最大软中断) { 返回 }
    全局软中断.挂起掩码 = 全局软中断.挂起掩码 | (1 << 类型)
    内存_写32(全局软中断.触发计数 + 类型 * 4, 内存_读32(全局软中断.触发计数 + 类型 * 4) + 1)
}

函数 软中断_处理() {
    如果 (全局软中断 == 0) { 返回 }
    如果 (全局软中断.正在处理) { 返回 }
    全局软中断.正在处理 = 真
    定义 可变 轮次 = 0
    当 (全局软中断.挂起掩码 != 0 && 轮次 < 每轮最大) {
        定义 挂起 = 全局软中断.挂起掩码
        全局软中断.挂起掩码 = 0
        定义 可变 类型 = 0
        当 (类型 < 最大软中断) {
            如果 ((挂起 & (1 << 类型)) != 0) {
                定义 处理 = 内存_读64(全局软中断.处理表 + 类型 * 8)
                如果 (处理 != 0) {
                    处理()
                    内存_写32(全局软中断.执行计数 + 类型 * 4, 内存_读32(全局软中断.执行计数 + 类型 * 4) + 1)
                    全局软中断.总执行 = 全局软中断.总执行 + 1
                }
            }
            类型 = 类型 + 1
        }
        轮次 = 轮次 + 1
    }
    如果 (全局软中断.挂起掩码 != 0) {
        全局软中断.溢出次数 = 全局软中断.溢出次数 + 1
    }
    全局软中断.正在处理 = 假
}

函数 软中断_守护处理() {
    如果 (全局软中断 == 0) { 返回 }
    如果 (全局软中断.挂起掩码 != 0) {
        软中断_处理()
        全局软中断.守护执行 = 全局软中断.守护执行 + 1
    }
}

函数 软中断_挂起数() {
    如果 (全局软中断 == 0) { 返回 0 }
    定义 可变 数量 = 0
    定义 挂起 = 全局软中断.挂起掩码
    定义 可变 位 = 0
    当 (位 < 最大软中断) {
        如果 ((挂起 >> 位) & 1) { 数量 = 数量 + 1 }
        位 = 位 + 1
    }
    返回 数量
}

函数 软中断_获取触发(类型) {
    如果 (类型 >= 最大软中断) { 返回 0 }
    返回 内存_读32(全局软中断.触发计数 + 类型 * 4)
}

函数 软中断_获取执行(类型) {
    如果 (类型 >= 最大软中断) { 返回 0 }
    返回 内存_读32(全局软中断.执行计数 + 类型 * 4)
}

// 软中断类型名称

函数 软中断_类型名(类型) {
    如果 (类型 == 软中断_定时器) { 返回 "定时器" }
    如果 (类型 == 软中断_网络收) { 返回 "网络接收" }
    如果 (类型 == 软中断_网络发) { 返回 "网络发送" }
    如果 (类型 == 软中断_块设备) { 返回 "块设备" }
    如果 (类型 == 软中断_调度) { 返回 "调度" }
    如果 (类型 == 软中断_读拷) { 返回 "RCU" }
    如果 (类型 == 软中断_高精定) { 返回 "高精度定时" }
    如果 (类型 == 软中断_任务) { 返回 "Tasklet" }
    返回 "未知(" + 转字符串(类型) + ")"
}

// 软中断初始化保护 + 增强状态

定义 可变 软中断_已初始化标志 = 假
定义 可变 软中断_BH禁用深度 = 0
定义 可变 软中断_错误数 = 0

// 速率追踪
定义 可变 软中断_速率 = 0
定义 可变 软中断_速率窗口 = 0
定义 可变 软中断_速率时刻 = 0
定义 可变 软中断_峰值速率 = 0
定义 可变 软中断_速率EMA = 0

// 延迟测量(AI基因)
定义 可变 软中断_延迟总计 = 0
定义 可变 软中断_延迟样本 = 0
定义 可变 软中断_最大延迟 = 0
定义 可变 软中断_超时次数 = 0
定义 软中断_超时阈值 = 2000000

函数 软中断_完整初始化() {
    如果 (软中断_已初始化标志 == 真) { 返回 错误_已存在 }
    软中断_初始化()
    软中断_BH禁用深度 = 0
    软中断_错误数 = 0
    软中断_速率 = 0
    软中断_速率窗口 = 0
    软中断_速率时刻 = 0
    软中断_峰值速率 = 0
    软中断_速率EMA = 0
    软中断_延迟总计 = 0
    软中断_延迟样本 = 0
    软中断_最大延迟 = 0
    软中断_超时次数 = 0
    软中断_已初始化标志 = 真
    打印("[软中断] 完整初始化完成")
    返回 0
}

// 注册增强(参数校验)

函数 软中断_注册_增强(类型, 处理函数) {
    如果 (类型 >= 最大软中断) {
        软中断_错误数 = 软中断_错误数 + 1
        返回 错误_无效参数
    }
    如果 (处理函数 == 空) {
        软中断_错误数 = 软中断_错误数 + 1
        返回 错误_无效参数
    }
    // 检查是否已注册
    定义 已有 = 内存_读64(全局软中断.处理表 + 类型 * 8)
    如果 (已有 != 0) {
        打印("[软中断] 警告: 类型" + 转字符串(类型) + "(" + 软中断_类型名(类型) + ")已有处理函数, 替换")
    }
    软中断_注册(类型, 处理函数)
    打印("[软中断] 注册: " + 软中断_类型名(类型))
    返回 0
}

// 处理增强(延迟测量/超时检测)

函数 软中断_处理_增强() {
    如果 (全局软中断 == 0) { 返回 }
    如果 (全局软中断.正在处理) { 返回 }
    如果 (软中断_BH禁用深度 > 0) { 返回 }
    全局软中断.正在处理 = 真
    定义 总开始 = 读取纳秒()
    定义 可变 轮次 = 0
    当 (全局软中断.挂起掩码 != 0 && 轮次 < 每轮最大) {
        定义 挂起 = 全局软中断.挂起掩码
        全局软中断.挂起掩码 = 0
        定义 可变 类型 = 0
        当 (类型 < 最大软中断) {
            如果 ((挂起 & (1 << 类型)) != 0) {
                定义 处理 = 内存_读64(全局软中断.处理表 + 类型 * 8)
                如果 (处理 != 0) {
                    定义 开始 = 读取纳秒()
                    处理()
                    定义 耗时 = 读取纳秒() - 开始
                    软中断_记录延迟(耗时, 类型)
                    内存_写32(全局软中断.执行计数 + 类型 * 4, 内存_读32(全局软中断.执行计数 + 类型 * 4) + 1)
                    全局软中断.总执行 = 全局软中断.总执行 + 1
                    软中断_速率窗口 = 软中断_速率窗口 + 1
                }
            }
            类型 = 类型 + 1
        }
        轮次 = 轮次 + 1
    }
    如果 (全局软中断.挂起掩码 != 0) {
        全局软中断.溢出次数 = 全局软中断.溢出次数 + 1
    }
    全局软中断.正在处理 = 假
}

函数 软中断_记录延迟(延迟, 类型) {
    软中断_延迟样本 = 软中断_延迟样本 + 1
    软中断_延迟总计 = 软中断_延迟总计 + 延迟
    如果 (延迟 > 软中断_最大延迟) { 软中断_最大延迟 = 延迟 }
    如果 (延迟 > 软中断_超时阈值) {
        软中断_超时次数 = 软中断_超时次数 + 1
        打印("[软中断] 警告: " + 软中断_类型名(类型) + " 执行超时 " + 转字符串(延迟) + "ns")
    }
}

函数 软中断_平均延迟() {
    如果 (软中断_延迟样本 == 0) { 返回 0 }
    返回 软中断_延迟总计 / 软中断_延迟样本
}

// Bottom-half禁用/启用

函数 软中断_BH_禁用() {
    软中断_BH禁用深度 = 软中断_BH禁用深度 + 1
}

函数 软中断_BH_启用() {
    如果 (软中断_BH禁用深度 > 0) {
        软中断_BH禁用深度 = 软中断_BH禁用深度 - 1
    }
    // BH重新启用时检查挂起
    如果 (软中断_BH禁用深度 == 0 && 全局软中断 != 0) {
        如果 (全局软中断.挂起掩码 != 0) {
            软中断_处理_增强()
        }
    }
}

函数 软中断_BH_已禁用() {
    返回 软中断_BH禁用深度 > 0
}

// 速率追踪

函数 软中断_更新速率() {
    定义 现在 = 平台_获取高精度时间()
    定义 间隔 = 现在 - 软中断_速率时刻
    如果 (间隔 >= 1000000) {
        软中断_速率 = 软中断_速率窗口 * 1000000 / 间隔
        软中断_速率EMA = (软中断_速率EMA * 7 + 软中断_速率) / 8
        如果 (软中断_速率 > 软中断_峰值速率) { 软中断_峰值速率 = 软中断_速率 }
        软中断_速率窗口 = 0
        软中断_速率时刻 = 现在
    }
}

函数 软中断_获取速率() { 返回 软中断_速率 }
函数 软中断_获取峰值速率() { 返回 软中断_峰值速率 }

// 查询接口增强

函数 软中断_有挂起() {
    如果 (全局软中断 == 0) { 返回 假 }
    返回 全局软中断.挂起掩码 != 0
}

函数 软中断_处理全部() {
    软中断_处理_增强()
}

函数 软中断_已注册(类型) {
    如果 (类型 >= 最大软中断 || 全局软中断 == 0) { 返回 假 }
    返回 内存_读64(全局软中断.处理表 + 类型 * 8) != 0
}

函数 软中断_已注册数() {
    如果 (全局软中断 == 0) { 返回 0 }
    定义 可变 数量 = 0
    定义 可变 i = 0
    当 (i < 最大软中断) {
        如果 (内存_读64(全局软中断.处理表 + i * 8) != 0) { 数量 = 数量 + 1 }
        i = i + 1
    }
    返回 数量
}

函数 软中断_获取最活跃() {
    如果 (全局软中断 == 0) { 返回 0 - 1 }
    定义 可变 最大 = 0
    定义 可变 最大类型 = 0 - 1
    定义 可变 i = 0
    当 (i < 最大软中断) {
        定义 执行 = 内存_读32(全局软中断.执行计数 + i * 4)
        如果 (执行 > 最大) { 最大 = 执行; 最大类型 = i }
        i = i + 1
    }
    返回 最大类型
}

// 完整统计 (≥15个指标)

函数 软中断_完整统计() {
    如果 (全局软中断 == 0) {
        定义 空统计 = 字典()
        字典设(空统计, "已初始化", 假)
        返回 空统计
    }
    定义 统计 = 字典()
    字典设(统计, "已初始化", 软中断_已初始化标志)
    字典设(统计, "总执行", 全局软中断.总执行)
    字典设(统计, "守护执行", 全局软中断.守护执行)
    字典设(统计, "溢出次数", 全局软中断.溢出次数)
    字典设(统计, "挂起数", 软中断_挂起数())
    字典设(统计, "挂起掩码", 全局软中断.挂起掩码)
    字典设(统计, "已注册数", 软中断_已注册数())
    字典设(统计, "最活跃类型", 软中断_获取最活跃())
    字典设(统计, "BH禁用深度", 软中断_BH禁用深度)
    字典设(统计, "当前速率", 软中断_速率)
    字典设(统计, "峰值速率", 软中断_峰值速率)
    字典设(统计, "速率EMA", 软中断_速率EMA)
    字典设(统计, "平均延迟(ns)", 软中断_平均延迟())
    字典设(统计, "最大延迟(ns)", 软中断_最大延迟)
    字典设(统计, "超时次数", 软中断_超时次数)
    字典设(统计, "延迟样本", 软中断_延迟样本)
    字典设(统计, "错误数", 软中断_错误数)
    // 每类型统计
    定义 可变 i = 0
    当 (i < 最大软中断) {
        定义 触发 = 内存_读32(全局软中断.触发计数 + i * 4)
        定义 执行 = 内存_读32(全局软中断.执行计数 + i * 4)
        如果 (触发 > 0 || 执行 > 0) {
            字典设(统计, "触发_" + 软中断_类型名(i), 触发)
            字典设(统计, "执行_" + 软中断_类型名(i), 执行)
        }
        i = i + 1
    }
    返回 统计
}

函数 软中断_打印完整统计() {
    定义 统计 = 软中断_完整统计()
    打印("[软中断] ═══════ 完整统计 ═══════")
    打印("  已初始化:     " + 转字符串(字典取(统计, "已初始化")))
    打印("  总执行:       " + 转字符串(字典取(统计, "总执行")))
    打印("  守护执行:     " + 转字符串(字典取(统计, "守护执行")))
    打印("  溢出次数:     " + 转字符串(字典取(统计, "溢出次数")))
    打印("  挂起数:       " + 转字符串(字典取(统计, "挂起数")))
    打印("  已注册:       " + 转字符串(字典取(统计, "已注册数")))
    打印("  BH禁用深度:   " + 转字符串(字典取(统计, "BH禁用深度")))
    打印("  当前速率:     " + 转字符串(字典取(统计, "当前速率")) + " 次/秒")
    打印("  峰值速率:     " + 转字符串(字典取(统计, "峰值速率")) + " 次/秒")
    打印("  平均延迟:     " + 转字符串(字典取(统计, "平均延迟(ns)")) + "ns")
    打印("  最大延迟:     " + 转字符串(字典取(统计, "最大延迟(ns)")) + "ns")
    打印("  超时次数:     " + 转字符串(字典取(统计, "超时次数")))
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    // 每类型
    打印("  ── 各类型统计 ──")
    定义 可变 i = 0
    当 (i < 最大软中断) {
        如果 (全局软中断 != 0) {
            定义 触发 = 内存_读32(全局软中断.触发计数 + i * 4)
            定义 执行 = 内存_读32(全局软中断.执行计数 + i * 4)
            如果 (触发 > 0 || 执行 > 0) {
                打印("  " + 软中断_类型名(i) + ": 触发=" + 转字符串(触发) + " 执行=" + 转字符串(执行))
            }
        }
        i = i + 1
    }
    打印("[软中断] ═════════════════════════")
    返回 0
}

// dump

函数 软中断_dump() {
    打印("[软中断 dump] ──────────────────")
    打印("  已初始化: " + 转字符串(软中断_已初始化标志))
    如果 (全局软中断 != 0) {
        打印("  挂起掩码: 0x" + 转字符串(全局软中断.挂起掩码))
        打印("  正在处理: " + 转字符串(全局软中断.正在处理))
        打印("  总执行: " + 转字符串(全局软中断.总执行))
        打印("  溢出: " + 转字符串(全局软中断.溢出次数))
    }
    打印("  BH禁用深度: " + 转字符串(软中断_BH禁用深度))
    打印("  速率: " + 转字符串(软中断_速率))
    打印("  平均延迟: " + 转字符串(软中断_平均延迟()) + "ns")
    打印("  超时: " + 转字符串(软中断_超时次数))
    打印("[软中断 dump] ──────────────────")
}

// 销毁

函数 软中断_销毁() {
    如果 (软中断_已初始化标志 == 假) { 返回 0 }
    全局软中断 = 0
    软中断_已初始化标志 = 假
    打印("[软中断] 已销毁")
    返回 0
}

// 与其他子系统的接口

函数 软中断_为调度器提供负载() {
    返回 [软中断_速率, 软中断_峰值速率, 软中断_挂起数()]
}

函数 软中断_为AI提供延迟模式() {
    返回 [软中断_平均延迟(), 软中断_最大延迟, 软中断_超时次数,
           软中断_速率, 软中断_延迟样本]
}

函数 软中断_为procfs提供统计() {
    如果 (全局软中断 == 0) { 返回 [] }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 最大软中断) {
        定义 触发 = 内存_读32(全局软中断.触发计数 + i * 4)
        定义 执行 = 内存_读32(全局软中断.执行计数 + i * 4)
        追加(结果, [i, 软中断_类型名(i), 触发, 执行])
        i = i + 1
    }
    返回 结果
}

函数 软中断_重置统计() {
    如果 (全局软中断 == 0) { 返回 错误_未初始化 }
    全局软中断.总执行 = 0
    全局软中断.守护执行 = 0
    全局软中断.溢出次数 = 0
    定义 可变 i = 0
    当 (i < 最大软中断) {
        内存_写32(全局软中断.触发计数 + i * 4, 0)
        内存_写32(全局软中断.执行计数 + i * 4, 0)
        i = i + 1
    }
    软中断_速率 = 0
    软中断_峰值速率 = 0
    软中断_速率EMA = 0
    软中断_延迟总计 = 0
    软中断_延迟样本 = 0
    软中断_最大延迟 = 0
    软中断_超时次数 = 0
    打印("[软中断] 统计已重置")
    返回 0
}

// 辅助: 平台时间读取

函数 读取纳秒() {
    定义 可变 值 = 0
    汇编 { "rdtsc" "shl rdx, 32" "or rax, rdx" "mov [rbp-8], rax" }
    返回 值
}

函数 软中断_为电源管理挂起() {
    // 挂起前处理所有挂起的软中断
    如果 (全局软中断 != 0 && 全局软中断.挂起掩码 != 0) {
        软中断_处理_增强()
    }
    返回 0
}

函数 软中断_为电源管理恢复() {
    // 恢复后重置速率统计
    软中断_速率窗口 = 0
    软中断_速率时刻 = 平台_获取高精度时间()
    返回 0
}

函数 软中断挂起数_统计() {
    返回 {
        软中断错误数: 软中断_错误数,
        软中断速率: 软中断_速率,
        软中断峰值速率: 软中断_峰值速率,
        软中断延迟总计: 软中断_延迟总计,
        软中断延迟样本: 软中断_延迟样本,
        软中断超时次数: 软中断_超时次数
    }
}

函数 软中断挂起数_健康评估() {
    定义 可变 问题 = []
    如果 (软中断_错误数 > 软中断_延迟总计 / 3 && 软中断_延迟总计 > 50) { 追加(问题, "软中断_错误数过高") }
    返回 计数(问题) == 0
}

函数 软中断挂起数_综合报告() {
    打印("[软中断挂起数] ═══ 综合报告 ═══")
    打印("  软中断_错误数: " + 软中断_错误数)
    打印("  软中断_速率: " + 软中断_速率)
    打印("  软中断_峰值速率: " + 软中断_峰值速率)
    打印("  软中断_延迟总计: " + 软中断_延迟总计)
    打印("  软中断_延迟样本: " + 软中断_延迟样本)
    打印("  软中断_超时次数: " + 软中断_超时次数)
    打印("  健康: " + 如果 (软中断挂起数_健康评估()) { "正常" } 否则 { "异常" })
}

函数 软中断挂起数_全局重置() {
    软中断_错误数 = 0
    软中断_速率 = 0
    软中断_峰值速率 = 0
    软中断_延迟总计 = 0
    软中断_延迟样本 = 0
    软中断_超时次数 = 0
    打印("[软中断挂起数] 统计已重置")
    返回 0
}

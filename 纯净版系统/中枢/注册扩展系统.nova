// §2 批量注册

函数 注册_扩展系统调用() {
    系统调用_注册(SYS_timerfd_create, sys_timerfd_create)
    系统调用_注册(SYS_timerfd_settime, sys_timerfd_settime)
    系统调用_注册(SYS_timerfd_gettime, sys_timerfd_gettime)
    系统调用_注册(SYS_timer_create, sys_timer_create)
    系统调用_注册(SYS_timer_settime, sys_timer_settime)
    系统调用_注册(SYS_timer_gettime, sys_timer_gettime)
    系统调用_注册(SYS_timer_delete, sys_timer_delete)
    系统调用_注册(SYS_timer_getoverrun, sys_timer_getoverrun)
    系统调用_注册(SYS_clock_settime, sys_clock_settime)
    系统调用_注册(SYS_clock_nanosleep, sys_clock_nanosleep)

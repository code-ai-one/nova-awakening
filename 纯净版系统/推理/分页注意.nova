// NovaOS PagedNova注意力 — 分页KV缓存管理
// 论文: Kwon et al. "Efficient Memory Management for Large
//       Language Model Serving with PagedNova注意力" (vLLM, 2023)
// 核心: 将KV缓存按页(block)管理，消除内存碎片，支持动态序列长度
//   传统: 每个序列预分配最大长度KV缓存 → 内存浪费60-80%
//   Paged: 按需分配固定大小block → 内存利用率>95%
//   额外支持: beam search共享前缀页(copy-on-write)

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("../中枢/字符串替换.nova")
导入("../执行/底层内存操.nova")
导入("../稳态/原生系统图处.nova")
导入("../标准/数学幂根对数.nova")
导入("../中枢/最大池一维.nova")
导入("./值乘.nova")

定义 KV_BLOCK_大小 = 16          // 每个block存储16个令牌的KV
定义 KV_最大块数 = 65536         // 最多64K个block
定义 KV_空闲标记 = 0
定义 KV_已用标记 = 1
定义 KV_标量字节 = 2

// KV 块级 — 存储固定数量令牌的K和V向量

结构 KV块级 {
    块ID,
    层索引,
    头索引,
    已用槽数,
    引用计数,    // u32 copy-on-write引用计数
    K数据,    // u64 [BLOCK_大小, 头维度] 张量指针
    V数据,    // u64 [BLOCK_大小, 头维度] 张量指针
}

// 块级分配器 — 全局KV缓存内存池

结构 块分配器 {
    总块数,
    空闲块数,
    头维度,
    层数,
    头数,
    块池,    // u64 KV块级数组
    数据池,    // u64 图处内存块
    空闲栈,    // u64 空闲块ID栈
    栈顶,
}

函数 PagedKV_每头标量数(分配器) {
    返回 KV_BLOCK_大小 * 分配器.头维度
}

函数 PagedKV_K区标量数(分配器) {
    返回 PagedKV_每头标量数(分配器) * 分配器.头数
}

函数 PagedKV_每块标量数(分配器) {
    返回 PagedKV_K区标量数(分配器) * 2
}

函数 PagedKV_每块字节数(分配器) {
    返回 PagedKV_每块标量数(分配器) * KV_标量字节
}

函数 PagedKV_K偏移(分配器, 块ID, 头索引) {
    返回 块ID * PagedKV_每块标量数(分配器) + 头索引 * PagedKV_每头标量数(分配器)
}

函数 PagedKV_V偏移(分配器, 块ID, 头索引) {
    返回 块ID * PagedKV_每块标量数(分配器) + PagedKV_K区标量数(分配器) + 头索引 * PagedKV_每头标量数(分配器)
}

函数 PagedKV_刷新利用率(分配器) {
    如果 (分配器 == 0 || 全局PagedKV统计 == 0) { 返回 }
    定义 已用块数 = 分配器.总块数 - 分配器.空闲块数
    全局PagedKV统计.当前块使用量 = 已用块数
    如果 (已用块数 > 全局PagedKV统计.峰值块使用量) {
        全局PagedKV统计.峰值块使用量 = 已用块数
    }
    如果 (分配器.总块数 > 0) {
        全局PagedKV统计.内存利用率 = 已用块数 * 1024 / 分配器.总块数
        全局PagedKV统计.碎片率 = 分配器.空闲块数 * 1024 / 分配器.总块数
    }
}

函数 PagedKV_登记块(分配器, 块ID, 层索引) {
    如果 (分配器 == 0 || 块ID < 0 || 块ID >= 计数(分配器.块池)) { 返回 }
    分配器.块池[块ID].块ID = 块ID
    分配器.块池[块ID].层索引 = 层索引
    分配器.块池[块ID].头索引 = 0
    分配器.块池[块ID].已用槽数 = 0
    分配器.块池[块ID].引用计数 = 0
    分配器.块池[块ID].K数据 = PagedKV_K偏移(分配器, 块ID, 0)
    分配器.块池[块ID].V数据 = PagedKV_V偏移(分配器, 块ID, 0)
}

函数 引用表_销毁() {
    如果 (全局引用表 != 0) { 堆_释放(全局引用表) }
    全局引用表 = 0
    引用表大小 = 0
}

函数 块分配器_创建失败清理(分配器) {
    如果 (分配器 == 0) { 返回 }
    如果 (分配器.数据池 != 0) { 图处内存_释放(分配器.数据池) }
    如果 (分配器.空闲栈 != 0) { 堆_释放(分配器.空闲栈) }
    如果 (分配器.块池 != 0) { 堆_释放(分配器.块池) }
    分配器.数据池 = 0
    分配器.块池 = []
    分配器.空闲栈 = []
    分配器.总块数 = 0
    分配器.空闲块数 = 0
    分配器.头维度 = 0
    分配器.层数 = 0
    分配器.头数 = 0
    分配器.栈顶 = 0
}

函数 块分配器_创建(总块数, 头维度, 层数, 头数) {
    如果 (总块数 <= 0 || 头维度 <= 0 || 层数 <= 0 || 头数 <= 0) { 返回 0 }
    定义 可变 分配器 = 块分配器 {}
    分配器.总块数 = 总块数
    分配器.空闲块数 = 总块数
    分配器.头维度 = 头维度
    分配器.层数 = 层数
    分配器.头数 = 头数

    // 预分配所有block内存(图处显存)
    分配器.块池 = []
    分配器.数据池 = 图处内存_分配(VRAM, 用途_计算缓冲, 总块数 * PagedKV_每块字节数(分配器))
    如果 (分配器.数据池 == 0) {
        块分配器_创建失败清理(分配器)
        返回 0
    }
    分配器.空闲栈 = 数组_创建(总块数)
    分配器.栈顶 = 总块数
    如果 (分配器.空闲栈 == 0 || 计数(分配器.空闲栈) < 总块数) {
        块分配器_创建失败清理(分配器)
        返回 0
    }

    // 初始化空闲栈
    定义 可变 i = 0
    当 (i < 总块数) {
        数组_设置(分配器.空闲栈, i, i)
        追加(分配器.块池, KV块级 {
            块ID: i,
            层索引: -1,
            头索引: 0,
            已用槽数: 0,
            引用计数: 0,
            K数据: PagedKV_K偏移(分配器, i, 0),
            V数据: PagedKV_V偏移(分配器, i, 0)
        })
        如果 (计数(分配器.块池) < i + 1) {
            块分配器_创建失败清理(分配器)
            返回 0
        }
        i = i + 1
    }

    如果 (全局引用表 == 0 || 引用表大小 != 总块数) {
        引用表_初始化(总块数)
    }
    如果 (全局PagedKV统计 == 0) {
        PagedKV统计_初始化()
    }
    如果 (全局PagedKV统计 != 0) {
        全局PagedKV统计.总内存字节 = 总块数 * PagedKV_每块字节数(分配器)
    }

    PagedKV_刷新利用率(分配器)

    返回 分配器
}

函数 块分配器_分配(分配器) {
    如果 (分配器.空闲块数 == 0) { 返回 -1 }
    分配器.栈顶 = 分配器.栈顶 - 1
    定义 块ID = 数组_取(分配器.空闲栈, 分配器.栈顶)
    分配器.空闲块数 = 分配器.空闲块数 - 1
    如果 (块ID >= 0 && 块ID < 计数(分配器.块池)) {
        分配器.块池[块ID].层索引 = -1
        分配器.块池[块ID].已用槽数 = 0
        分配器.块池[块ID].引用计数 = 0
    }
    如果 (全局PagedKV统计 != 0) {
        全局PagedKV统计.总块分配次数 = 全局PagedKV统计.总块分配次数 + 1
    }
    PagedKV_刷新利用率(分配器)
    返回 块ID
}

函数 块分配器_释放(分配器, 块ID) {
    数组_设置(分配器.空闲栈, 分配器.栈顶, 块ID)
    分配器.栈顶 = 分配器.栈顶 + 1
    分配器.空闲块数 = 分配器.空闲块数 + 1
    如果 (块ID >= 0 && 块ID < 计数(分配器.块池)) {
        分配器.块池[块ID].层索引 = -1
        分配器.块池[块ID].已用槽数 = 0
        分配器.块池[块ID].引用计数 = 0
    }
    如果 (全局PagedKV统计 != 0) {
        全局PagedKV统计.总块释放次数 = 全局PagedKV统计.总块释放次数 + 1
    }
    PagedKV_刷新利用率(分配器)
}

// 序列KV缓存 — 每个序列的block映射表

结构 序列KV {
    序列ID,
    块表,    // u64 逻辑块→物理块映射 [层][逻辑块号]
    序列长度,
    逻辑块数,
}

函数 序列KV_创建(序列ID, 层数) {
    定义 可变 kv = 序列KV {}
    kv.序列ID = 序列ID
    kv.序列长度 = 0
    kv.逻辑块数 = 0
    kv.块表 = 数组_创建_2d(层数, 0)
    如果 (全局PagedKV统计 != 0) {
        全局PagedKV统计.总序列创建数 = 全局PagedKV统计.总序列创建数 + 1
    }
    返回 kv
}

函数 序列KV_追加令牌(kv, 分配器, 层数) {
    // 检查当前最后一个block是否已满
    定义 槽位置 = kv.序列长度 % KV_BLOCK_大小

    如果 (槽位置 == 0) {
        // 需要分配新block(每层一个)
        定义 可变 l = 0
        当 (l < 层数) {
            定义 新块 = 块分配器_分配(分配器)
            如果 (新块 < 0) { 返回 错误_内存不足 }
            数组_追加(kv.块表[l], 新块)
            PagedKV_登记块(分配器, 新块, l)
            块_增加引用(分配器, 新块)
            l = l + 1
        }
        kv.逻辑块数 = kv.逻辑块数 + 1
    }

    kv.序列长度 = kv.序列长度 + 1
    定义 已用槽 = kv.序列长度 % KV_BLOCK_大小
    如果 (已用槽 == 0) { 已用槽 = KV_BLOCK_大小 }
    定义 可变 l2 = 0
    当 (l2 < 层数) {
        定义 当前块 = 数组_取(kv.块表[l2], kv.逻辑块数 - 1)
        如果 (当前块 >= 0 && 当前块 < 计数(分配器.块池)) {
            分配器.块池[当前块].已用槽数 = 已用槽
        }
        l2 = l2 + 1
    }
    返回 0
}

函数 张量_零(行数, 列数) {
    返回 Tensor_创建(行数, 列数)
}

函数 张量_标量乘(t, 因子) {
    如果 (t == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < t.行数) {
        定义 可变 j = 0
        当 (j < t.列数) {
            Tensor_写(t, i, j, Tensor_读(t, i, j) * 因子)
            j = j + 1
        }
        i = i + 1
    }
    返回 t
}

函数 张量_累加行_权重(输出, 块, 行索引, 维度, 权重) {
    如果 (输出 == 0 || 块 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 维度) {
        定义 原值 = Tensor_读(输出, 0, i)
        定义 增量 = Tensor_读(块, 行索引, i) * 权重
        Tensor_写(输出, 0, i, 原值 + 增量)
        i = i + 1
    }
}

函数 PagedKV_读标量(分配器, 标量偏移) {
    定义 值 = 内存_读16(分配器.数据池.CPU地址 + 标量偏移 * KV_标量字节)
    如果 (值 >= 32768) { 返回 值 - 65536 }
    返回 值
}

函数 PagedKV_写标量(分配器, 标量偏移, 值) {
    如果 (值 < -32768) { 值 = -32768 }
    如果 (值 > 32767) { 值 = 32767 }
    内存_写16(分配器.数据池.CPU地址 + 标量偏移 * KV_标量字节, 值 & 0xFFFF)
}

函数 序列KV_写入标量(kv, 分配器, 层索引, 头索引, 槽位置, 维度偏移, K值, V值) {
    如果 (kv == 0 || 分配器 == 0 || kv.逻辑块数 <= 0) { 返回 -1 }
    定义 逻辑块号 = kv.逻辑块数 - 1
    定义 物理块 = 数组_取(kv.块表[层索引], 逻辑块号)
    如果 (物理块 < 0) { 返回 -1 }

    定义 K写偏移 = PagedKV_K偏移(分配器, 物理块, 头索引) + 槽位置 * 分配器.头维度 + 维度偏移
    定义 V写偏移 = PagedKV_V偏移(分配器, 物理块, 头索引) + 槽位置 * 分配器.头维度 + 维度偏移
    PagedKV_写标量(分配器, K写偏移, K值)
    PagedKV_写标量(分配器, V写偏移, V值)

    如果 (物理块 < 计数(分配器.块池) && 槽位置 + 1 > 分配器.块池[物理块].已用槽数) {
        分配器.块池[物理块].已用槽数 = 槽位置 + 1
    }
    返回 0
}

函数 PagedKV_读取头块(分配器, 标量偏移, 行数, 列数) {
    定义 块 = Tensor_创建(行数, 列数)
    如果 (块 == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < 行数) {
        定义 可变 j = 0
        当 (j < 列数) {
            Tensor_写(块, i, j, PagedKV_读标量(分配器, 标量偏移 + i * 列数 + j))
            j = j + 1
        }
        i = i + 1
    }
    返回 块
}

函数 PagedKV_行点积(Q, 块, 行索引, 维度) {
    定义 可变 点积 = 0
    定义 可变 i = 0
    当 (i < 维度) {
        点积 = 点积 + Tensor_读(Q, 0, i) * Tensor_读(块, 行索引, i) / 65536
        i = i + 1
    }
    返回 点积
}

函数 PagedKV_构造查询头(查询数据, 查询起始, 维度) {
    定义 q = 张量_零(1, 维度)
    如果 (q == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < 维度) {
        Tensor_写(q, 0, i, 内存_读32(查询数据 + (查询起始 + i) * 4))
        i = i + 1
    }
    返回 q
}

函数 PagedKV_写回输出头(头输出, 输出数据, 输出起始, 维度) {
    如果 (头输出 == 0 || 输出数据 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 维度) {
        内存_写32(输出数据 + (输出起始 + i) * 4, Tensor_读(头输出, 0, i))
        i = i + 1
    }
}

函数 paged_Nova注意力_前向_扁平写入(查询数据, 查询起始, 维度, 序列kv, 分配器, 层索引, 头索引, 缩放, 输出数据, 输出起始) {
    定义 q = PagedKV_构造查询头(查询数据, 查询起始, 维度)
    如果 (q == 0) { 返回 -1 }

    定义 头输出 = paged_Nova注意力_前向(q, 序列kv, 分配器, 层索引, 头索引, 缩放)
    Tensor_释放(q)
    如果 (头输出 == 0) { 返回 -1 }

    PagedKV_写回输出头(头输出, 输出数据, 输出起始, 维度)
    Tensor_释放(头输出)
    返回 0
}

// PagedNova注意力核心 — 从分页KV中计算注意力

函数 paged_Nova注意力_前向(Q, 序列kv, 分配器, 层索引, 头索引, 缩放) {
    // Q: [1, d] (单令牌解码)
    定义 d = Q.列数
    定义 序列长 = 序列kv.序列长度
    定义 块数 = 序列kv.逻辑块数

    定义 可变 最大值 = -1e30
    定义 可变 累积和 = 0.0
    定义 可变 输出 = 张量_零(1, d)

    // 遍历所有KV block
    定义 可变 b = 0
    当 (b < 块数) {
        定义 物理块 = 数组_取(序列kv.块表[层索引], b)
        定义 K偏移 = PagedKV_K偏移(分配器, 物理块, 头索引)
        定义 V偏移 = PagedKV_V偏移(分配器, 物理块, 头索引)

        // 该block中有效的令牌数
        定义 有效数 = 0
        如果 (物理块 >= 0 && 物理块 < 计数(分配器.块池)) {
            有效数 = 分配器.块池[物理块].已用槽数
        }
        如果 (有效数 <= 0) { 有效数 = KV_BLOCK_大小 }
        如果 (b == 块数 - 1) {
            有效数 = 序列长 % KV_BLOCK_大小
            如果 (有效数 == 0) { 有效数 = KV_BLOCK_大小 }
        }

        // 从图处显存读取K block
        定义 K块 = PagedKV_读取头块(分配器, K偏移, 有效数, d)
        定义 V块 = PagedKV_读取头块(分配器, V偏移, 有效数, d)
        如果 (K块 == 0 || V块 == 0) {
            如果 (K块 != 0) { Tensor_释放(K块) }
            如果 (V块 != 0) { Tensor_释放(V块) }
            b = b + 1
            继续
        }

        // 计算注意力分数: s = Q @ K^T * scale
        定义 可变 t = 0
        当 (t < 有效数) {
            定义 分数 = PagedKV_行点积(Q, K块, t, d) * 缩放

            // 在线Nova归一化指数 (数值稳定)
            如果 (分数 > 最大值) {
                定义 旧最大 = 最大值
                最大值 = 分数
                定义 修正 = 数学_exp(旧最大 - 最大值)
                输出 = 张量_标量乘(输出, 修正)
                累积和 = 累积和 * 修正
            }
            定义 权重 = 数学_exp(分数 - 最大值)
            累积和 = 累积和 + 权重

            // V block
            张量_累加行_权重(输出, V块, t, d, 权重)

            t = t + 1
        }
        Tensor_释放(K块)
        Tensor_释放(V块)
        b = b + 1
    }

    // 归一化
    如果 (累积和 > 0) {
        输出 = 张量_标量乘(输出, 1.0 / 累积和)
    }

    返回 输出
}

// Copy-on-Write — beam search共享前缀

函数 序列KV_fork(源kv, 分配器, 层数) {
    // 创建新序列，共享源序列的所有block(引用计数+1)
    定义 可变 新kv = 序列KV_创建(0, 层数)
    新kv.序列长度 = 源kv.序列长度
    新kv.逻辑块数 = 源kv.逻辑块数

    定义 可变 l = 0
    当 (l < 层数) {
        定义 可变 b = 0
        当 (b < 源kv.逻辑块数) {
            定义 块ID = 数组_取(源kv.块表[l], b)
            数组_追加(新kv.块表[l], 块ID)
            // 增加引用计数
            块_增加引用(分配器, 块ID)
            b = b + 1
        }
        l = l + 1
    }

    返回 新kv
}

函数 序列KV_写时复制(kv, 分配器, 层索引, 逻辑块号) {
    定义 旧块 = 数组_取(kv.块表[层索引], 逻辑块号)
    定义 引用 = 块_获取引用(分配器, 旧块)

    如果 (引用 > 1) {
        定义 新块 = 块分配器_分配(分配器)
        如果 (新块 < 0) { 返回 错误_内存不足 }
        PagedKV_登记块(分配器, 新块, 层索引)
        块_增加引用(分配器, 新块)
        分配器.块池[新块].已用槽数 = 分配器.块池[旧块].已用槽数
        内存_复制(
            分配器.数据池.CPU地址 + 新块 * PagedKV_每块字节数(分配器),
            分配器.数据池.CPU地址 + 旧块 * PagedKV_每块字节数(分配器),
            PagedKV_每块字节数(分配器)
        )
        数组_设置(kv.块表[层索引], 逻辑块号, 新块)
        块_减少引用(分配器, 旧块)
        如果 (全局PagedKV统计 != 0) {
            全局PagedKV统计.总CoW触发数 = 全局PagedKV统计.总CoW触发数 + 1
        }
    }
    返回 0
}

// §5 引用计数管理

定义 可变 全局引用表 = 0
定义 可变 引用表大小 = 0

函数 引用表_初始化(总块数) {
    定义 可变 新表 = []
    定义 可变 i = 0
    当 (i < 总块数) {
        追加(新表, 0)
        i = i + 1
    }
    如果 (全局引用表 != 0) {
        堆_释放(全局引用表)
    }
    全局引用表 = 新表
    引用表大小 = 总块数
}

函数 块_增加引用(分配器, 块ID) {
    如果 (全局引用表 == 0 || 块ID < 0 || 块ID >= 引用表大小) { 返回 }
    设置(全局引用表, 块ID, 全局引用表[块ID] + 1)
    如果 (分配器 != 0 && 块ID < 计数(分配器.块池)) {
        分配器.块池[块ID].引用计数 = 全局引用表[块ID]
    }
}

函数 块_减少引用(分配器, 块ID) {
    如果 (全局引用表 == 0 || 块ID < 0 || 块ID >= 引用表大小) { 返回 }
    如果 (全局引用表[块ID] > 0) {
        设置(全局引用表, 块ID, 全局引用表[块ID] - 1)
    }
    如果 (分配器 != 0 && 块ID < 计数(分配器.块池)) {
        分配器.块池[块ID].引用计数 = 全局引用表[块ID]
    }
    // 引用计数归零时释放块
    如果 (全局引用表[块ID] == 0) {
        块分配器_释放(分配器, 块ID)
    }
}

函数 块_获取引用(分配器, 块ID) {
    如果 (全局引用表 == 0 || 块ID < 0 || 块ID >= 引用表大小) { 返回 0 }
    返回 全局引用表[块ID]
}

// §6 序列释放与内存回收

函数 序列KV_释放(kv, 分配器, 层数) {
    如果 (kv == 0 || 分配器 == 0) { 返回 }
    定义 可变 l = 0
    当 (l < 层数) {
        定义 可变 b = 0
        当 (b < kv.逻辑块数) {
            定义 块ID = 数组_取(kv.块表[l], b)
            块_减少引用(分配器, 块ID)
            b = b + 1
        }
        l = l + 1
    }
    kv.序列长度 = 0
    kv.逻辑块数 = 0
    如果 (全局PagedKV统计 != 0) {
        全局PagedKV统计.总序列释放数 = 全局PagedKV统计.总序列释放数 + 1
    }
    打印(字符串拼接("[PagedKV] 序列释放: ID=", 转字符串(kv.序列ID)))
}

// §7 批量调度器 — 连续批处理(vLLM核心)

定义 调度_最大批大小 = 256
定义 调度_最大等待 = 1024
定义 调度_优先级_抢占 = 0
定义 调度_优先级_正常 = 1
定义 调度_优先级_后台 = 2

结构 请求 {
    请求ID,
    序列KV,           // 序列KV缓存
    提示长度,         // 原始提示令牌数
    已生成长度,       // 已生成令牌数
    最大生成长度,     // 最大允许生成长度
    优先级,           // 调度优先级
    状态,             // 0=等待 1=运行 2=完成 3=抢占
    到达时间,         // 请求到达时间戳
}

结构 批量调度器 {
    运行队列,         // 当前运行中的请求
    等待队列,         // 等待开始的请求
    运行数,
    等待数,
    分配器,           // 块分配器
    层数,
    总完成请求,
    总抢占次数,
    总令牌生成数,
}

函数 批量调度器_创建(分配器, 层数) {
    定义 调度器 = 批量调度器 {}
    调度器.运行队列 = []
    调度器.等待队列 = []
    调度器.运行数 = 0
    调度器.等待数 = 0
    调度器.分配器 = 分配器
    调度器.层数 = 层数
    调度器.总完成请求 = 0
    调度器.总抢占次数 = 0
    调度器.总令牌生成数 = 0
    返回 调度器
}

函数 批量调度器_提交请求(调度器, 请求ID, 提示长度, 最大生成长度) {
    如果 (调度器 == 0) { 返回 -1 }
    如果 (调度器.等待数 >= 调度_最大等待) {
        打印("[PagedKV] 等待队列已满")
        返回 -1
    }

    定义 req = 请求 {}
    req.请求ID = 请求ID
    req.序列KV = 序列KV_创建(请求ID, 调度器.层数)
    req.提示长度 = 提示长度
    req.已生成长度 = 0
    req.最大生成长度 = 最大生成长度
    req.优先级 = 调度_优先级_正常
    req.状态 = 0
    req.到达时间 = 0

    追加(调度器.等待队列, req)
    调度器.等待数 = 调度器.等待数 + 1
    返回 0
}

函数 批量调度器_调度步(调度器) {
    如果 (调度器 == 0) { 返回 }

    // 从等待队列中取出请求加入运行队列
    当 (调度器.运行数 < 调度_最大批大小 && 调度器.等待数 > 0) {
        定义 req = 调度器.等待队列[0]

        // 检查是否有足够的KV缓存块
        定义 需要块数 = ((req.提示长度 + req.最大生成长度) + KV_BLOCK_大小 - 1) / KV_BLOCK_大小
        需要块数 = 需要块数 * 调度器.层数
        如果 (调度器.分配器.空闲块数 < 需要块数) {
            // 空间不足，尝试抢占最低优先级运行请求
            定义 可抢占 = 批量调度器_找可抢占(调度器)
            如果 (可抢占 < 0) {
                打印("[PagedKV] 内存不足，等待释放")
                返回
            }
            批量调度器_抢占(调度器, 可抢占)
        }

        req.状态 = 1
        追加(调度器.运行队列, req)
        调度器.运行数 = 调度器.运行数 + 1
        删除(调度器.等待队列, 0)
        调度器.等待数 = 调度器.等待数 - 1
    }

    // 检查完成的请求
    定义 可变 i = 0
    当 (i < 调度器.运行数) {
        如果 (调度器.运行队列[i].已生成长度 >= 调度器.运行队列[i].最大生成长度) {
            调度器.运行队列[i].状态 = 2
            序列KV_释放(调度器.运行队列[i].序列KV, 调度器.分配器, 调度器.层数)
            删除(调度器.运行队列, i)
            调度器.运行数 = 调度器.运行数 - 1
            调度器.总完成请求 = 调度器.总完成请求 + 1
        } 否则 {
            i = i + 1
        }
    }
}

函数 批量调度器_找可抢占(调度器) {
    如果 (调度器.运行数 == 0) { 返回 -1 }
    定义 可变 最低优先级 = -1
    定义 可变 最低idx = -1
    定义 可变 i = 0
    当 (i < 调度器.运行数) {
        如果 (调度器.运行队列[i].优先级 > 最低优先级) {
            最低优先级 = 调度器.运行队列[i].优先级
            最低idx = i
        }
        i = i + 1
    }
    返回 最低idx
}

函数 批量调度器_抢占(调度器, idx) {
    如果 (idx < 0 || idx >= 调度器.运行数) { 返回 }
    定义 req = 调度器.运行队列[idx]
    req.状态 = 3
    序列KV_释放(req.序列KV, 调度器.分配器, 调度器.层数)
    // 重新排入等待队列
    req.序列KV = 序列KV_创建(req.请求ID, 调度器.层数)
    req.已生成长度 = 0
    req.状态 = 0
    追加(调度器.等待队列, req)
    调度器.等待数 = 调度器.等待数 + 1
    删除(调度器.运行队列, idx)
    调度器.运行数 = 调度器.运行数 - 1
    调度器.总抢占次数 = 调度器.总抢占次数 + 1
    打印(字符串拼接("[PagedKV] 抢占请求: ID=", 转字符串(req.请求ID)))
}

// §8 统计输出

结构 PagedKV统计 {
    总块分配次数,
    总块释放次数,
    峰值块使用量,
    当前块使用量,
    总序列创建数,
    总序列释放数,
    总CoW触发数,
    总内存字节,
    内存利用率,       // Q10
    碎片率,           // Q10
}

定义 可变 全局PagedKV统计 = 0

函数 PagedKV统计_初始化() {
    定义 s = PagedKV统计 {}
    s.总块分配次数 = 0
    s.总块释放次数 = 0
    s.峰值块使用量 = 0
    s.当前块使用量 = 0
    s.总序列创建数 = 0
    s.总序列释放数 = 0
    s.总CoW触发数 = 0
    s.总内存字节 = 0
    s.内存利用率 = 0
    s.碎片率 = 0
    全局PagedKV统计 = s
    返回 s
}

函数 PagedKV_打印统计(分配器) {
    如果 (分配器 == 0) {
        打印("[PagedKV] 分配器未初始化")
        返回
    }
    打印("[PagedKV] ═══ 分页KV缓存统计 ═══")
    打印(字符串拼接("  总块数: ", 转字符串(分配器.总块数)))
    打印(字符串拼接("  空闲块数: ", 转字符串(分配器.空闲块数)))
    打印(字符串拼接("  已用块数: ", 转字符串(分配器.总块数 - 分配器.空闲块数)))
    定义 利用率 = ((分配器.总块数 - 分配器.空闲块数) * 100) / 分配器.总块数
    打印(字符串拼接("  内存利用率: ", 字符串拼接(转字符串(利用率), "%")))
    打印(字符串拼接("  每块大小: ", 字符串拼接(转字符串(KV_BLOCK_大小), " 令牌")))
    打印(字符串拼接("  头维度: ", 转字符串(分配器.头维度)))
    打印(字符串拼接("  层数: ", 转字符串(分配器.层数)))
    如果 (全局PagedKV统计 != 0) {
        打印(字符串拼接("  总块分配: ", 转字符串(全局PagedKV统计.总块分配次数)))
        打印(字符串拼接("  总块释放: ", 转字符串(全局PagedKV统计.总块释放次数)))
        打印(字符串拼接("  峰值块使用: ", 转字符串(全局PagedKV统计.峰值块使用量)))
        打印(字符串拼接("  总CoW触发: ", 转字符串(全局PagedKV统计.总CoW触发数)))
    }
    打印("[PagedKV] ═══════════════════════════")
}

函数 批量调度器_打印统计(调度器) {
    如果 (调度器 == 0) { 返回 }
    打印("[PagedKV] ═══ 调度器统计 ═══")
    打印(字符串拼接("  运行队列: ", 转字符串(调度器.运行数)))
    打印(字符串拼接("  等待队列: ", 转字符串(调度器.等待数)))
    打印(字符串拼接("  总完成请求: ", 转字符串(调度器.总完成请求)))
    打印(字符串拼接("  总抢占次数: ", 转字符串(调度器.总抢占次数)))
    打印(字符串拼接("  总令牌生成数: ", 转字符串(调度器.总令牌生成数)))
    打印("[PagedKV] ═══════════════════")
}

函数 块分配器_销毁(分配器) {
    如果 (分配器 == 0) { 返回 }
    如果 (分配器.数据池 != 0) { 图处内存_释放(分配器.数据池) }
    如果 (分配器.空闲栈 != 0) { 堆_释放(分配器.空闲栈) }
    如果 (分配器.块池 != 0) { 堆_释放(分配器.块池) }
    分配器.数据池 = 0
    分配器.块池 = []
    分配器.空闲栈 = []
    分配器.总块数 = 0
    分配器.空闲块数 = 0
    分配器.头维度 = 0
    分配器.层数 = 0
    分配器.头数 = 0
    分配器.栈顶 = 0
    打印("[PagedKV] 块分配器已销毁")
}

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./样式令牌器.nova")
导入("../中枢/字符串替换.nova")

定义 CSS值_关键字     = 1     // inherit / initial / auto / none / ...
定义 CSS值_长度       = 2     // 10px / 2em / 100vh
定义 CSS值_百分比     = 3     // 50%
定义 CSS值_颜色       = 4     // #fff / rgb() / 命名颜色
定义 CSS值_数字       = 5     // 0 / 1.5
定义 CSS值_字符串     = 6     // "..."
定义 CSS值_URL        = 7     // url(...)
定义 CSS值_函数       = 8     // calc() / var() / ...

结构 CSSValue {
    类型,
    关键字ID,    // u32 关键字值的ID
    数值,    // i32 数值 (×100)
    单位,    // u32 长度单位: 0=px 1=em 2=rem 3=vh 4=vw 5=% 6=auto
    颜色,    // u32 RGBA打包 (0xRRGGBBAA)
    字符串值,    // u64 字符串/URL值
}

定义 单位_px   = 0
定义 单位_em   = 1
定义 单位_rem  = 2
定义 单位_vh   = 3
定义 单位_vw   = 4
定义 单位_百分比 = 5
定义 单位_auto = 6
定义 单位_pt   = 7
定义 单位_cm   = 8
定义 单位_mm   = 9

// CSS声明 (property: value)

结构 CSS声明 {
    属性ID,
    值,    // u64 CSSValue*
    重要,    // 布尔 !important
}

// CSS选择器 

定义 选择器类型_标签 = 1 // div / span / p
定义 选择器类型_class = 2 // .foo
定义 选择器类型_id = 3 // #bar
定义 选择器类型_通用 = 4 // *
定义 选择器类型_属性 = 5 // [attr=value]
定义 选择器类型_伪类 = 6 // :hover / :first-child / :nth-child
定义 选择器类型_伪元素 = 7 // ::before / ::after

定义 组合器_后代 = 0 // 空格 (A B)
定义 组合器_子 = 1 // > (A > B)
定义 组合器_相邻兄弟 = 2 // + (A + B)
定义 组合器_一般兄弟 = 3 // ~ (A ~ B)
定义 组合器_无 = 4 // 复合选择器内部(同一元素)

结构 CSS选择器 {
 类型,
 值,    // u64 标签名/class名/id字符串
 值原子,    // u32 原子化ID(快速匹配)
 组合器,    // u32 与下一个选择器的关系
 下一个,    // u64 链表: 下一个选择器部分
}

// CSS样式规则 

结构 CSS样式规则 {
 选择器列表,    // u64 CSS选择器*列表 (逗号分隔的多个选择器)
 选择器数量,
 声明列表,    // u64 CSS声明*数组
 声明数量,
 声明容量,
 特异度,    // u32 选择器特异度(优先级计算)
}

// CSS样式表 

结构 CSS样式表 {
 规则列表,    // u64 CSS样式规则*数组
 规则数量,
 规则容量,
 来源URL,
 媒体查询,
 是内联,
}

// CSS 令牌izer

结构 CSS令牌izer {
 输入,
 输入长度,
 位置,
}

函数 CSS令牌izer_创建(css文本) {
 定义 tk = 堆_分配(CSS令牌izer)
 tk.输入 = css文本
 tk.输入长度 = 字符串_长度(css文本)
 tk.位置 = 0
 返回 tk
}

函数 CSS令牌izer_下一个令牌(tk, 令牌) {
 // 跳过空白
 CSS令牌izer_跳过空白(tk)
 如果 (tk.位置 >= tk.输入长度) {
 令牌.类型 = CSS_令牌_EOF
 返回
 }

 定义 c = CSS令牌izer_消费(tk)

 如果 (c == 0x7B) { 令牌.类型 = CSS_令牌_左大括号; 返回 }
 如果 (c == 0x7D) { 令牌.类型 = CSS_令牌_右大括号; 返回 }
 如果 (c == 0x28) { 令牌.类型 = CSS_令牌_左圆括号; 返回 }
 如果 (c == 0x29) { 令牌.类型 = CSS_令牌_右圆括号; 返回 }
 如果 (c == 0x5B) { 令牌.类型 = CSS_令牌_左方括号; 返回 }
 如果 (c == 0x5D) { 令牌.类型 = CSS_令牌_右方括号; 返回 }
 如果 (c == 0x3A) { 令牌.类型 = CSS_令牌_冒号; 返回 }
 如果 (c == 0x3B) { 令牌.类型 = CSS_令牌_分号; 返回 }
 如果 (c == 0x2C) { 令牌.类型 = CSS_令牌_逗号; 返回 }

 // '#' → 哈希令牌
 如果 (c == 0x23) {
 令牌.类型 = CSS_令牌_哈希
 令牌.值 = tk.输入 + tk.位置
 定义 开始 = tk.位置
 当 (tk.位置 < tk.输入长度 && CSS令牌izer_是名称字符(CSS令牌izer_窥视(tk))) {
 CSS令牌izer_消费(tk)
 }
 令牌.值长度 = tk.位置 - 开始
 返回
 }

 // '.' → class选择器的分隔符
 如果 (c == 0x2E) {
 // 检查是否是数字(如 .5)
 如果 (tk.位置 < tk.输入长度 && CSS令牌izer_是数字(CSS令牌izer_窥视(tk))) {
 tk.位置 = tk.位置 - 1
 CSS令牌izer_读数字(tk, 令牌)
 返回
 }
 令牌.类型 = CSS_令牌_分隔符
 令牌.值 = tk.输入 + tk.位置 - 1
 令牌.值长度 = 1
 返回
 }

 // '@' → at-keyword
 如果 (c == 0x40) {
 令牌.类型 = CSS_令牌_AT关键字
 令牌.值 = tk.输入 + tk.位置
 定义 开始 = tk.位置
 当 (tk.位置 < tk.输入长度 && CSS令牌izer_是名称字符(CSS令牌izer_窥视(tk))) {
 CSS令牌izer_消费(tk)
 }
 令牌.值长度 = tk.位置 - 开始
 返回
 }

 // 字符串 "..." 或 '...'
 如果 (c == 0x22 || c == 0x27) {
 令牌.类型 = CSS_令牌_字符串
 令牌.值 = tk.输入 + tk.位置
 定义 开始 = tk.位置
 定义 引号 = c
 当 (tk.位置 < tk.输入长度) {
 定义 ch = CSS令牌izer_消费(tk)
 如果 (ch == 引号) { 跳出 }
 如果 (ch == 0x5C && tk.位置 < tk.输入长度) {
 CSS令牌izer_消费(tk) // 转义字符
 }
 }
 令牌.值长度 = tk.位置 - 开始 - 1
 返回
 }

 // 数字
 如果 (CSS令牌izer_是数字(c) || (c == 0x2D && tk.位置 < tk.输入长度 && CSS令牌izer_是数字(CSS令牌izer_窥视(tk)))) {
 tk.位置 = tk.位置 - 1
 CSS令牌izer_读数字(tk, 令牌)
 返回
 }

 // 标识符
 如果 (CSS令牌izer_是名称起始(c)) {
 tk.位置 = tk.位置 - 1
 CSS令牌izer_读标识符(tk, 令牌)
 返回
 }

 // '/' → 可能是注释
 如果 (c == 0x2F && tk.位置 < tk.输入长度 && CSS令牌izer_窥视(tk) == 0x2A) {
 CSS令牌izer_消费(tk) // 跳过'*'
 // 读到 */
 当 (tk.位置 < tk.输入长度 - 1) {
 如果 (CSS令牌izer_消费(tk) == 0x2A && CSS令牌izer_窥视(tk) == 0x2F) {
 CSS令牌izer_消费(tk)
 跳出
 }
 }
 // 递归获取下一个有效令牌
 CSS令牌izer_下一个令牌(tk, 令牌)
 返回
 }

 // 其他: 分隔符令牌
 令牌.类型 = CSS_令牌_分隔符
 令牌.值 = tk.输入 + tk.位置 - 1
 令牌.值长度 = 1
}

定义 可变 AI_样式令牌甲_样式缓存命中 = 0

函数 AI_样式令牌甲_选择器复杂度(选择器长度, 组合子数) {
    如果 (组合子数 > 5) { 返回 "高复杂度" }
    如果 (组合子数 > 2) { 返回 "中复杂度" }
    返回 "低复杂度"
}

函数 AI_样式令牌甲_布局缓存(元素哈希) {
    AI_样式令牌甲_样式缓存命中 = AI_样式令牌甲_样式缓存命中 + 1
    返回 元素哈希
}

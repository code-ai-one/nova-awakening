// NovaOS ls — 目录列表
// 功能: 列出目录内容, 支持-l长格式/-a显示隐藏/-h人类可读

导入("../标准/文件.nova")
导入("../感知/流.nova")
导入("../标准/原生字符串.nova")
导入("../推理/值乘.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/整数转字符串.nova")

定义 LS_长格式 = 1
定义 LS_显示隐藏 = 2
定义 LS_人类可读 = 4
定义 LS_递归 = 8
定义 LS_按大小排序 = 16
定义 LS_按时间排序 = 32

函数 ls_main(参数) {
    定义 可变 选项 = 0
    定义 可变 路径列表 = []

    // 解析参数
    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 参数项 = 参数[i]
        如果 (字符串取字符(参数项, 0) == "-") {
            定义 可变 j = 1
            当 (j < 字符串长度(参数项)) {
                定义 字符 = 字符串取字符(参数项, j)
                如果 (字符 == "l") { 选项 = 选项 | LS_长格式 }
                如果 (字符 == "a") { 选项 = 选项 | LS_显示隐藏 }
                如果 (字符 == "h") { 选项 = 选项 | LS_人类可读 }
                如果 (字符 == "R") { 选项 = 选项 | LS_递归 }
                如果 (字符 == "S") { 选项 = 选项 | LS_按大小排序 }
                如果 (字符 == "t") { 选项 = 选项 | LS_按时间排序 }
                j = j + 1
            }
        } 否则 {
            追加(路径列表, 参数项)
        }
        i = i + 1
    }

    // 默认路径: 当前目录
    如果 (计数(路径列表) == 0) {
        追加(路径列表, ".")
    }

    // 遍历每个路径
    定义 可变 k = 0
    当 (k < 计数(路径列表)) {
        如果 (计数(路径列表) > 1) {
            打印行(字符串拼接(路径列表[k], ":"))
        }
        ls_列出目录(路径列表[k], 选项)
        k = k + 1
    }
    返回 0
}

函数 ls_列出目录(路径, 选项) {
    定义 条目列表 = 文件_读目录(路径)
    如果 (条目列表 == 空) {
        打印行(字符串拼接("ls: 无法访问 '", 字符串拼接(路径, "'")))
        返回
    }

    定义 可变 i = 0
    当 (i < 计数(条目列表)) {
        定义 条目 = 条目列表[i]
        定义 名称 = 条目[0]

        // 跳过隐藏文件(除非-a)
        如果 ((选项 & LS_显示隐藏) == 0) {
            如果 (字符串长度(名称) > 0 && 字符串取字符(名称, 0) == ".") {
                i = i + 1
                继续
            }
        }

        如果 ((选项 & LS_长格式) != 0) {
            // -l: 长格式输出
            定义 类型标记 = 条目[1]   // "d"=目录, "-"=文件
            定义 大小 = 条目[2]
            定义 可变 大小文本 = 整数转字符串(大小)
            如果 ((选项 & LS_人类可读) != 0) {
                大小文本 = 格式化字节大小(大小)
            }
            打印行(字符串拼接(类型标记, 字符串拼接("rwxr-xr-x 1 root root ", 字符串拼接(大小文本, 字符串拼接(" ", 名称)))))
        } 否则 {
            // 简单列表
            标准输出(字符串拼接(名称, "  "))
        }
        i = i + 1
    }

    如果 ((选项 & LS_长格式) == 0) {
        打印行("")  // 换行
    }
}

函数 格式化字节大小(字节) {
    如果 (字节 < 1024) { 返回 字符串拼接(整数转字符串(字节), "B") }
    如果 (字节 < 1048576) { 返回 字符串拼接(整数转字符串(字节 / 1024), "K") }
    如果 (字节 < 1073741824) { 返回 字符串拼接(整数转字符串(字节 / 1048576), "M") }
    如果 (字节 < 1099511627776) { 返回 字符串拼接(整数转字符串(字节 / 1073741824), "G") }
    返回 字符串拼接(整数转字符串(字节 / 1099511627776), "T")
}

// NDLS理论: Nova Directory Listing System
// 核心创新:
//  1) 双轴排序: 名称/大小/时间三维排序 + 目录优先分离
//  2) 模式匹配过滤: glob通配符引擎
//  3) 权限矩阵解析: Unix 9-bit权限到rwx字符串
//  4) ANSI颜色引擎: 文件类型→颜色映射
//  5) AI文件分类: 8维特征推断文件用途

定义 NDLS_颜色_重置   = "\033[0m"
定义 NDLS_颜色_目录   = "\033[1;34m"   // 亮蓝
定义 NDLS_颜色_链接   = "\033[1;36m"   // 亮青
定义 NDLS_颜色_可执行 = "\033[1;32m"   // 亮绿
定义 NDLS_颜色_归档   = "\033[1;31m"   // 亮红
定义 NDLS_颜色_图片   = "\033[1;35m"   // 亮洋红
定义 NDLS_颜色_音频   = "\033[0;36m"   // 青
定义 NDLS_颜色_视频   = "\033[1;35m"   // 洋红
定义 NDLS_颜色_代码   = "\033[0;33m"   // 黄
定义 NDLS_颜色_文档   = "\033[0;37m"   // 白

定义 可变 NDLS_列出总数    = 0
定义 可变 NDLS_过滤次数    = 0
定义 可变 NDLS_排序次数    = 0
定义 可变 NDLS_AI分类次数  = 0
定义 可变 NDLS_递归深度    = 0

定义 NDLS_最大深度        = 64
定义 NDLS_最大条目        = 8192

// §2 权限矩阵解析

函数 NDLS_权限位到字符(mode, bit, 字符) {
    如果 ((mode & bit) != 0) { 返回 字符 }
    返回 "-"
}

函数 NDLS_解析权限(mode) {
    定义 u_r = NDLS_权限位到字符(mode, 0x100, "r")
    定义 u_w = NDLS_权限位到字符(mode, 0x080, "w")
    定义 u_x = NDLS_权限位到字符(mode, 0x040, "x")
    定义 g_r = NDLS_权限位到字符(mode, 0x020, "r")
    定义 g_w = NDLS_权限位到字符(mode, 0x010, "w")
    定义 g_x = NDLS_权限位到字符(mode, 0x008, "x")
    定义 o_r = NDLS_权限位到字符(mode, 0x004, "r")
    定义 o_w = NDLS_权限位到字符(mode, 0x002, "w")
    定义 o_x = NDLS_权限位到字符(mode, 0x001, "x")
    // SUID/SGID/Sticky
    如果 ((mode & 0x800) != 0) { u_x = 如果(u_x == "x", "s", "S") }
    如果 ((mode & 0x400) != 0) { g_x = 如果(g_x == "x", "s", "S") }
    如果 ((mode & 0x200) != 0) { o_x = 如果(o_x == "x", "t", "T") }
    返回 字符串拼接(u_r, 字符串拼接(u_w, 字符串拼接(u_x,
           字符串拼接(g_r, 字符串拼接(g_w, 字符串拼接(g_x,
           字符串拼接(o_r, 字符串拼接(o_w, o_x))))))))
}

函数 NDLS_类型字符(类型) {
    如果 (类型 == "d") { 返回 "d" }
    如果 (类型 == "l") { 返回 "l" }
    如果 (类型 == "c") { 返回 "c" }
    如果 (类型 == "b") { 返回 "b" }
    如果 (类型 == "p") { 返回 "p" }
    如果 (类型 == "s") { 返回 "s" }
    返回 "-"
}

// §3 时间格式化

函数 NDLS_格式化时间戳(时间戳) {
    // 将秒时间戳转为 "月 日 时:分" 或 "月 日  年"
    定义 当前时间 = 系统调用_时间戳()
    定义 差值 = 当前时间 - 时间戳
    定义 秒 = 时间戳
    // 简化日期分解
    定义 天总数 = 秒 / 86400
    定义 年 = 1970 + 天总数 / 365  // 近似
    定义 年内天 = 天总数 % 365
    定义 月份天数 = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]
    定义 月名 = ["1月", "2月", "3月", "4月", "5月", "6月",
                "7月", "8月", "9月", "10月", "11月", "12月"]
    定义 可变 月 = 0
    定义 可变 剩余天 = 年内天
    当 (月 < 12 && 剩余天 >= 月份天数[月]) {
        剩余天 = 剩余天 - 月份天数[月]
        月 = 月 + 1
    }
    定义 日 = 剩余天 + 1
    定义 日内秒 = 秒 % 86400
    定义 时 = 日内秒 / 3600
    定义 分 = (日内秒 % 3600) / 60
    定义 日文本 = 如果(日 < 10, 字符串拼接(" ", 整数转字符串(日)), 整数转字符串(日))
    定义 时文本 = 如果(时 < 10, 字符串拼接("0", 整数转字符串(时)), 整数转字符串(时))
    定义 分文本 = 如果(分 < 10, 字符串拼接("0", 整数转字符串(分)), 整数转字符串(分))
    // 超过6个月显示年份
    如果 (差值 > 15552000) {
        返回 字符串拼接(月名[月], 字符串拼接(" ", 字符串拼接(日文本, 字符串拼接("  ", 整数转字符串(年)))))
    }
    返回 字符串拼接(月名[月], 字符串拼接(" ", 字符串拼接(日文本, 字符串拼接(" ", 字符串拼接(时文本, 字符串拼接(":", 分文本))))))
}

// §4 文件扩展名与颜色映射

函数 NDLS_获取扩展名(名称) {
    定义 len = 字符串长度(名称)
    定义 可变 i = len - 1
    当 (i >= 0) {
        如果 (字符串取字符(名称, i) == ".") {
            返回 字符串切片(名称, i + 1, len)
        }
        i = i - 1
    }
    返回 ""
}

函数 NDLS_扩展名转小写(ext) {
    定义 len = 字符串长度(ext)
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < len) {
        定义 c = 字符串取字符编码(ext, i)
        如果 (c >= 65 && c <= 90) {
            结果 = 字符串拼接(结果, 编码转字符(c + 32))
        } 否则 {
            结果 = 字符串拼接(结果, 字符串切片(ext, i, i + 1))
        }
        i = i + 1
    }
    返回 结果
}

函数 NDLS_颜色映射(名称, 类型) {
    如果 (类型 == "d") { 返回 NDLS_颜色_目录 }
    如果 (类型 == "l") { 返回 NDLS_颜色_链接 }
    定义 ext = NDLS_扩展名转小写(NDLS_获取扩展名(名称))
    // 可执行
    如果 (ext == "exe" || ext == "sh" || ext == "bat" || ext == "com" || ext == "nova") {
        返回 NDLS_颜色_可执行
    }
    // 归档
    如果 (ext == "tar" || ext == "gz" || ext == "zip" || ext == "rar" || ext == "7z" || ext == "bz2" || ext == "xz") {
        返回 NDLS_颜色_归档
    }
    // 图片
    如果 (ext == "png" || ext == "jpg" || ext == "jpeg" || ext == "gif" || ext == "bmp" || ext == "svg" || ext == "webp" || ext == "ico") {
        返回 NDLS_颜色_图片
    }
    // 音频
    如果 (ext == "mp3" || ext == "wav" || ext == "flac" || ext == "ogg" || ext == "aac" || ext == "wma") {
        返回 NDLS_颜色_音频
    }
    // 视频
    如果 (ext == "mp4" || ext == "avi" || ext == "mkv" || ext == "mov" || ext == "wmv" || ext == "flv" || ext == "webm") {
        返回 NDLS_颜色_视频
    }
    // 代码
    如果 (ext == "c" || ext == "h" || ext == "cpp" || ext == "py" || ext == "js" || ext == "ts" || ext == "rs" || ext == "go" || ext == "java") {
        返回 NDLS_颜色_代码
    }
    // 文档
    如果 (ext == "txt" || ext == "md" || ext == "pdf" || ext == "doc" || ext == "docx" || ext == "csv" || ext == "json" || ext == "xml") {
        返回 NDLS_颜色_文档
    }
    返回 NDLS_颜色_重置
}

// §5 排序引擎

函数 NDLS_比较名称(a, b) {
    定义 la = 字符串长度(a[0])
    定义 lb = 字符串长度(b[0])
    定义 len = 如果(la < lb, la, lb)
    定义 可变 i = 0
    当 (i < len) {
        定义 ca = 字符串取字符编码(a[0], i)
        定义 cb = 字符串取字符编码(b[0], i)
        // 大小写不敏感
        如果 (ca >= 65 && ca <= 90) { ca = ca + 32 }
        如果 (cb >= 65 && cb <= 90) { cb = cb + 32 }
        如果 (ca < cb) { 返回 -1 }
        如果 (ca > cb) { 返回 1 }
        i = i + 1
    }
    返回 la - lb
}

函数 NDLS_比较大小(a, b) {
    如果 (a[2] > b[2]) { 返回 -1 }
    如果 (a[2] < b[2]) { 返回 1 }
    返回 0
}

函数 NDLS_比较时间(a, b) {
    如果 (a[3] > b[3]) { 返回 -1 }
    如果 (a[3] < b[3]) { 返回 1 }
    返回 0
}

函数 NDLS_排序(列表, 选项) {
    NDLS_排序次数 = NDLS_排序次数 + 1
    定义 n = 计数(列表)
    如果 (n <= 1) { 返回 }
    // 选择比较函数
    定义 比较 = NDLS_比较名称
    如果 ((选项 & LS_按大小排序) != 0) { 比较 = NDLS_比较大小 }
    如果 ((选项 & LS_按时间排序) != 0) { 比较 = NDLS_比较时间 }
    // 插入排序 (适合小中规模目录)
    定义 可变 i = 1
    当 (i < n) {
        定义 key = 列表[i]
        定义 可变 j = i - 1
        当 (j >= 0 && 比较(列表[j], key) > 0) {
            列表[j + 1] = 列表[j]
            j = j - 1
        }
        列表[j + 1] = key
        i = i + 1
    }
    // 目录优先: 分离目录与文件
    定义 可变 目录组 = []
    定义 可变 文件组 = []
    i = 0
    当 (i < n) {
        如果 (列表[i][1] == "d") {
            追加(目录组, 列表[i])
        } 否则 {
            追加(文件组, 列表[i])
        }
        i = i + 1
    }
    // 合并回原列表
    i = 0
    定义 可变 k = 0
    当 (k < 计数(目录组)) { 列表[i] = 目录组[k]; i = i + 1; k = k + 1 }
    k = 0
    当 (k < 计数(文件组)) { 列表[i] = 文件组[k]; i = i + 1; k = k + 1 }
}

// §6 Glob通配符过滤

定义 LS_过滤模式 = 64

函数 NDLS_glob匹配(模式, 文本) {
    NDLS_过滤次数 = NDLS_过滤次数 + 1
    定义 pLen = 字符串长度(模式)
    定义 tLen = 字符串长度(文本)
    定义 可变 pi = 0
    定义 可变 ti = 0
    定义 可变 star_pi = -1
    定义 可变 star_ti = -1
    当 (ti < tLen) {
        如果 (pi < pLen && 字符串取字符(模式, pi) == "*") {
            star_pi = pi
            star_ti = ti
            pi = pi + 1
        } 否则 如果 (pi < pLen && (字符串取字符(模式, pi) == "?" || 字符串取字符(模式, pi) == 字符串取字符(文本, ti))) {
            pi = pi + 1
            ti = ti + 1
        } 否则 如果 (star_pi >= 0) {
            pi = star_pi + 1
            star_ti = star_ti + 1
            ti = star_ti
        } 否则 {
            返回 假
        }
    }
    当 (pi < pLen && 字符串取字符(模式, pi) == "*") { pi = pi + 1 }
    返回 pi == pLen
}

// §7 递归目录遍历

函数 NDLS_递归列出(路径, 选项, 深度) {
    如果 (深度 > NDLS_最大深度) { 返回 }
    如果 (深度 > NDLS_递归深度) { NDLS_递归深度 = 深度 }
    打印行(字符串拼接(路径, ":"))
    定义 条目列表 = 文件_读目录(路径)
    如果 (条目列表 == 空) { 返回 }
    // 排序
    NDLS_排序(条目列表, 选项)
    // 显示当前级别
    定义 可变 i = 0
    当 (i < 计数(条目列表)) {
        定义 条目 = 条目列表[i]
        定义 名称 = 条目[0]
        如果 ((选项 & LS_显示隐藏) == 0 && 字符串长度(名称) > 0 && 字符串取字符(名称, 0) == ".") {
            i = i + 1
            继续
        }
        NDLS_输出条目(条目, 选项)
        i = i + 1
    }
    如果 ((选项 & LS_长格式) == 0) { 打印行("") }
    打印行("")
    // 递归子目录
    i = 0
    当 (i < 计数(条目列表)) {
        定义 条目 = 条目列表[i]
        如果 (条目[1] == "d" && 条目[0] != "." && 条目[0] != "..") {
            如果 ((选项 & LS_显示隐藏) != 0 || 字符串取字符(条目[0], 0) != ".") {
                定义 子路径 = 字符串拼接(路径, 字符串拼接("/", 条目[0]))
                NDLS_递归列出(子路径, 选项, 深度 + 1)
            }
        }
        i = i + 1
    }
}

// §8 长格式输出引擎

函数 NDLS_数字右对齐(值, 宽度) {
    定义 文本 = 整数转字符串(值)
    定义 len = 字符串长度(文本)
    如果 (len >= 宽度) { 返回 文本 }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 宽度 - len) {
        结果 = 字符串拼接(结果, " ")
        i = i + 1
    }
    返回 字符串拼接(结果, 文本)
}

函数 NDLS_字符串右对齐(文本, 宽度) {
    定义 len = 字符串长度(文本)
    如果 (len >= 宽度) { 返回 文本 }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 宽度 - len) {
        结果 = 字符串拼接(结果, " ")
        i = i + 1
    }
    返回 字符串拼接(结果, 文本)
}

函数 NDLS_输出条目(条目, 选项) {
    NDLS_列出总数 = NDLS_列出总数 + 1
    定义 名称 = 条目[0]
    定义 类型 = 条目[1]
    定义 大小 = 条目[2]
    定义 时间 = 如果(计数(条目) > 3, 条目[3], 0)
    定义 权限 = 如果(计数(条目) > 4, 条目[4], 0x1ED)  // 默认 0755
    定义 硬链接 = 如果(计数(条目) > 5, 条目[5], 1)
    定义 所有者 = 如果(计数(条目) > 6, 条目[6], "root")
    定义 所属组 = 如果(计数(条目) > 7, 条目[7], "root")
    如果 ((选项 & LS_长格式) != 0) {
        定义 类型字 = NDLS_类型字符(类型)
        定义 权限文 = NDLS_解析权限(权限)
        定义 可变 大小文本 = NDLS_数字右对齐(大小, 8)
        如果 ((选项 & LS_人类可读) != 0) {
            大小文本 = NDLS_字符串右对齐(格式化字节大小(大小), 6)
        }
        定义 时间文本 = NDLS_格式化时间戳(时间)
        定义 颜色 = NDLS_颜色映射(名称, 类型)
        定义 链接文 = NDLS_数字右对齐(硬链接, 3)
        打印行(字符串拼接(类型字, 字符串拼接(权限文, 字符串拼接(" ",
               字符串拼接(链接文, 字符串拼接(" ",
               字符串拼接(所有者, 字符串拼接(" ",
               字符串拼接(所属组, 字符串拼接(" ",
               字符串拼接(大小文本, 字符串拼接(" ",
               字符串拼接(时间文本, 字符串拼接(" ",
               字符串拼接(颜色, 字符串拼接(名称, NDLS_颜色_重置))))))))))))))))
    } 否则 {
        定义 颜色 = NDLS_颜色映射(名称, 类型)
        标准输出(字符串拼接(颜色, 字符串拼接(名称, 字符串拼接(NDLS_颜色_重置, "  "))))
    }
}

// §9 汇总统计行

函数 NDLS_汇总(条目列表, 选项) {
    如果 ((选项 & LS_长格式) == 0) { 返回 }
    定义 可变 总块 = 0
    定义 可变 文件数 = 0
    定义 可变 目录数 = 0
    定义 可变 链接数 = 0
    定义 可变 总大小 = 0
    定义 可变 i = 0
    当 (i < 计数(条目列表)) {
        定义 条目 = 条目列表[i]
        如果 (条目[1] == "d") { 目录数 = 目录数 + 1 }
        否则 如果 (条目[1] == "l") { 链接数 = 链接数 + 1 }
        否则 { 文件数 = 文件数 + 1 }
        总大小 = 总大小 + 条目[2]
        总块 = 总块 + (条目[2] + 511) / 512
        i = i + 1
    }
    打印行(字符串拼接("total ", 整数转字符串(总块)))
}

// §10 AI文件分类 (NDLS-AI)

函数 NDLS_AI_分类文件(名称, 类型, 大小) {
    如果 (全局AI总线 == 0) { 返回 "未知" }
    NDLS_AI分类次数 = NDLS_AI分类次数 + 1
    定义 tensor = Tensor_创建(8)
    定义 ext = NDLS_扩展名转小写(NDLS_获取扩展名(名称))
    // 特征0: 文件类型(d=1, l=0.5, -=0)
    Tensor_写(tensor, 0, 如果(类型 == "d", 1.0, 如果(类型 == "l", 0.5, 0.0)))
    // 特征1: 大小归一化(到100MB)
    Tensor_写(tensor, 1, 大小 / 104857600.0)
    // 特征2: 名称长度归一化
    Tensor_写(tensor, 2, 字符串长度(名称) / 64.0)
    // 特征3: 是否有扩展名
    Tensor_写(tensor, 3, 如果(字符串长度(ext) > 0, 1.0, 0.0))
    // 特征4: 是否可执行扩展名
    Tensor_写(tensor, 4, 如果(ext == "exe" || ext == "sh" || ext == "nova", 1.0, 0.0))
    // 特征5: 是否媒体文件
    Tensor_写(tensor, 5, 如果(ext == "png" || ext == "jpg" || ext == "mp4" || ext == "mp3", 1.0, 0.0))
    // 特征6: 是否代码文件
    Tensor_写(tensor, 6, 如果(ext == "c" || ext == "py" || ext == "js" || ext == "nova" || ext == "go", 1.0, 0.0))
    // 特征7: 是否归档
    Tensor_写(tensor, 7, 如果(ext == "tar" || ext == "gz" || ext == "zip" || ext == "rar", 1.0, 0.0))
    定义 out = AI总线_推理(全局AI总线, "NDLS_分类", tensor, 8)
    定义 可变 类别 = "普通文件"
    如果 (out != 0) {
        定义 score = Tensor_读(out, 0)
        如果 (score > 0.8) { 类别 = "核心代码" }
        否则 如果 (score > 0.6) { 类别 = "配置文件" }
        否则 如果 (score > 0.4) { 类别 = "数据文件" }
        否则 如果 (score > 0.2) { 类别 = "媒体资源" }
        否则 { 类别 = "临时文件" }
        Tensor_释放(out)
    }
    Tensor_释放(tensor)
    返回 类别
}

// §11 增强版ls入口

定义 LS_颜色输出 = 128
定义 LS_AI分类 = 256

函数 NDLS_增强列出(路径, 选项) {
    定义 条目列表 = 文件_读目录(路径)
    如果 (条目列表 == 空) {
        打印行(字符串拼接("ls: 无法访问 '", 字符串拼接(路径, "'")))
        返回
    }
    // 过滤隐藏文件
    定义 可变 可见列表 = []
    定义 可变 i = 0
    当 (i < 计数(条目列表)) {
        定义 名称 = 条目列表[i][0]
        如果 ((选项 & LS_显示隐藏) != 0 || 字符串长度(名称) == 0 || 字符串取字符(名称, 0) != ".") {
            追加(可见列表, 条目列表[i])
        }
        i = i + 1
    }
    // 排序
    NDLS_排序(可见列表, 选项)
    // 汇总行
    NDLS_汇总(可见列表, 选项)
    // 输出
    i = 0
    当 (i < 计数(可见列表)) {
        NDLS_输出条目(可见列表[i], 选项)
        i = i + 1
    }
    如果 ((选项 & LS_长格式) == 0) { 打印行("") }
}

// §12 诊断与运行时统计

函数 NDLS_运行时统计() {
    打印("[NDLS] listed=" + 整数转字符串(NDLS_列出总数) +
         " filtered=" + 整数转字符串(NDLS_过滤次数) +
         " sorted=" + 整数转字符串(NDLS_排序次数) +
         " aiClassify=" + 整数转字符串(NDLS_AI分类次数) +
         " maxDepth=" + 整数转字符串(NDLS_递归深度))
}

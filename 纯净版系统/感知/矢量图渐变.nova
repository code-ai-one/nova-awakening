// NovaOS 渲染引擎 — SVG渐变 + 路径光栅化
// 子系统: 渲染引擎/图片解码/矢量图/矢量渲染
// 实现: SVG linearGradient/radialGradient 完整采样
//   色标插值 + pad/repeat/reflect扩展模式 + 贝塞尔曲线展平
//   De Casteljau递归细分 + 扫描线填充
// 原创: NovaOS · 纯中文原生系统编程 · AI原生渲染精度自适应

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("./边界框计算.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内存初始化.nova")

// §1 常量定义

定义 最大色标数 = 16
定义 渐变扩展_Pad = 0           // 超出范围用端点色
定义 渐变扩展_Repeat = 1        // 重复
定义 渐变扩展_Reflect = 2       // 镜像
定义 渐变单位_对象 = 0          // objectBoundingBox
定义 渐变单位_用户 = 1          // userSpaceOnUse
定义 SVG命令_M = 77
定义 SVG命令_m = 109
定义 SVG命令_L = 76
定义 SVG命令_l = 108
定义 SVG命令_C = 67
定义 SVG命令_c = 99
定义 SVG命令_Q = 81
定义 SVG命令_q = 113
定义 SVG命令_Z = 90
定义 SVG命令_z = 122
定义 SVG命令_H = 72
定义 SVG命令_h = 104
定义 SVG命令_V = 86
定义 SVG命令_v = 118
定义 SVG命令_S = 83
定义 SVG命令_s = 115
定义 SVG命令_T = 84
定义 SVG命令_t = 116
定义 SVG命令_A = 65
定义 SVG命令_a = 97

// §2 数据结构

结构 渐变统计 {
    线性渐变创建数,
    径向渐变创建数,
    渐变采样总次数,
    线性采样次数,
    径向采样次数,
    色标插值次数,
    Pad扩展次数,
    Repeat扩展次数,
    Reflect扩展次数,
    路径展平总次数,
    贝塞尔细分次数,
    线段生成总数,
    扫描线填充次数,
    总采样耗时_纳秒,
    AI精度调用次数,
    AI精度命中次数,
    错误总数,
    溢出保护触发数,
}

结构 AI渐变状态 {
    历史色标数均值,      // u32 Q10
    历史渐变类型分布,    // u32 0=线性多 1=径向多
    历史路径复杂度,      // u32 Q10 平均段数
    连续简单渐变数,
    预测精度级别,        // u8  1=低 8=中 16=高
    采样计数器,
    学习权重,            // u32 Q10
    上次渐变类型,
}

定义 可变 全局渐变统计 = 0
定义 可变 全局渐变AI = 0
定义 可变 全局渐变已初始化 = 假

结构 渐变色标 {
    偏移,    // u32 Q10 (0-1024)
    颜色R,
    颜色G,
    颜色B,
    颜色A,
}

结构 线性渐变 {
    x1,          // i32 Q10 起点X
    y1,          // i32 Q10 起点Y
    x2,          // i32 Q10 终点X
    y2,          // i32 Q10 终点Y
    色标,        // u64 渐变色标*数组(最多16个)
    色标数,
    单位,        // u32 渐变单位_对象 | 渐变单位_用户
    扩展模式,    // u8  渐变扩展_Pad | Repeat | Reflect
    变换,        // u64 SVGTransform*
    锁,
}

结构 径向渐变 {
    cx,          // i32 Q10 中心X
    cy,          // i32 Q10 中心Y
    r,           // i32 Q10 半径
    fx,          // i32 Q10 焦点X
    fy,          // i32 Q10 焦点Y
    色标,        // u64 渐变色标*数组
    色标数,
    单位,
    扩展模式,
    变换,
    锁,
}

// §3 生命周期管理

函数 SVG渐变_初始化() {
    如果 (全局渐变已初始化 == 真) { 返回 错误_已存在 }
    全局渐变统计 = 堆_分配_清零(144)
    如果 (全局渐变统计 == 空) { 返回 错误_内存不足 }
    全局渐变AI = 堆_分配_清零(40)
    如果 (全局渐变AI != 空) {
        全局渐变AI.预测精度级别 = 8
        全局渐变AI.学习权重 = 128
    }
    全局渐变已初始化 = 真
    打印("[SVG渐变] 初始化完成")
    返回 0
}

函数 SVG渐变_销毁() {
    如果 (全局渐变统计 != 空) { 堆_释放(全局渐变统计); 全局渐变统计 = 0 }
    如果 (全局渐变AI != 空) { 堆_释放(全局渐变AI); 全局渐变AI = 0 }
    全局渐变已初始化 = 假
    返回 0
}

函数 SVG渐变_重置() {
    如果 (全局渐变统计 != 空) { 内存_置零(全局渐变统计, 144) }
    返回 0
}

// §4 渐变创建与销毁

函数 线性渐变_创建(x1, y1, x2, y2) {
    定义 g = 堆_分配(线性渐变)
    如果 (g == 空) { 返回 空 }
    g.x1 = x1; g.y1 = y1; g.x2 = x2; g.y2 = y2
    g.色标 = 堆_分配_清零(最大色标数 * 8)
    g.色标数 = 0
    g.单位 = 渐变单位_对象
    g.扩展模式 = 渐变扩展_Pad
    g.变换 = 0
    g.锁 = 渲染_互斥锁创建()
    如果 (全局渐变统计 != 空) {
        全局渐变统计.线性渐变创建数 = 全局渐变统计.线性渐变创建数 + 1
    }
    返回 g
}

函数 径向渐变_创建(cx, cy, r, fx, fy) {
    定义 g = 堆_分配(径向渐变)
    如果 (g == 空) { 返回 空 }
    g.cx = cx; g.cy = cy; g.r = r; g.fx = fx; g.fy = fy
    g.色标 = 堆_分配_清零(最大色标数 * 8)
    g.色标数 = 0
    g.单位 = 渐变单位_对象
    g.扩展模式 = 渐变扩展_Pad
    g.变换 = 0
    g.锁 = 渲染_互斥锁创建()
    如果 (全局渐变统计 != 空) {
        全局渐变统计.径向渐变创建数 = 全局渐变统计.径向渐变创建数 + 1
    }
    返回 g
}

函数 渐变_添加色标(色标数组, 色标数指针, 偏移, R, G, B, A) {
    如果 (色标数组 == 空 || 色标数指针 == 空) { 返回 错误_无效参数 }
    定义 当前数 = 内存_读32(色标数指针)
    如果 (当前数 >= 最大色标数) { 返回 错误_容量不足 }
    // 验证偏移范围
    定义 可变 有效偏移 = 偏移
    如果 (有效偏移 < 0) { 有效偏移 = 0 }
    如果 (有效偏移 > 1024) { 有效偏移 = 1024 }
    // 写入色标
    定义 基 = 色标数组 + 当前数 * 8
    内存_写32(基, 有效偏移)
    内存_写8(基 + 4, R)
    内存_写8(基 + 5, G)
    内存_写8(基 + 6, B)
    内存_写8(基 + 7, A)
    内存_写32(色标数指针, 当前数 + 1)
    返回 0
}

函数 渐变_销毁_线性(g) {
    如果 (g == 空) { 返回 }
    如果 (g.色标 != 空) { 堆_释放(g.色标) }
    堆_释放(g)
}

函数 渐变_销毁_径向(g) {
    如果 (g == 空) { 返回 }
    如果 (g.色标 != 空) { 堆_释放(g.色标) }
    堆_释放(g)
}

函数 SNova视觉网络radient_采样(色标, 色标数, t_Q10) {
    // 在色标之间线性插值
    如果 (色标数 == 0) { 返回 0 }
    如果 (色标数 == 1) {
        返回 (色标[0].颜色R << 24) | (色标[0].颜色G << 16) | (色标[0].颜色B << 8) | 色标[0].颜色A
    }
    // 找到t所在的两个色标
    定义 可变 i = 0
    当 (i < 色标数 - 1) {
        如果 (t_Q10 >= 色标[i].偏移 && t_Q10 <= 色标[i + 1].偏移) {
            定义 范围 = 色标[i + 1].偏移 - 色标[i].偏移
            如果 (范围 == 0) { 范围 = 1 }
            定义 比例 = (t_Q10 - 色标[i].偏移) * 1024 / 范围
            定义 inv = 1024 - 比例
            定义 R = (色标[i].颜色R * inv + 色标[i+1].颜色R * 比例) / 1024
            定义 G = (色标[i].颜色G * inv + 色标[i+1].颜色G * 比例) / 1024
            定义 B = (色标[i].颜色B * inv + 色标[i+1].颜色B * 比例) / 1024
            定义 A = (色标[i].颜色A * inv + 色标[i+1].颜色A * 比例) / 1024
            返回 (R << 24) | (G << 16) | (B << 8) | A
        }
        i = i + 1
    }
    返回 (色标[色标数-1].颜色R << 24) | (色标[色标数-1].颜色G << 16) |
         (色标[色标数-1].颜色B << 8) | 色标[色标数-1].颜色A
}

// §8 SVG路径光栅化

// 将SVGPath展平为线段列表(贝塞尔→直线近似)
函数 SVGPath_展平(path, 精度) {
    如果 (path == 0) { 返回 0 }

    // 输出: [(x0,y0,x1,y1), ...] 线段数组
    定义 容量 = path.段数 * 32    // 每段最多32条线段
    定义 线段 = 堆_分配_数组(容量 * 16)    // 每线段4×i32
    定义 可变 线段数 = 0
    定义 可变 当前x = 0
    定义 可变 当前y = 0

    定义 可变 seg = path.段链头
    当 (seg != 0 && 线段数 < 容量) {
        如果 (seg.命令 == SVG命令_M) {
            当前x = seg.参数[0]; 当前y = seg.参数[1]
        }
        否则 如果 (seg.命令 == SVG命令_L || seg.命令 == SVG命令_Z) {
            定义 偏移 = 线段数 * 16
            内存_写32(线段 + 偏移, 当前x)
            内存_写32(线段 + 偏移 + 4, 当前y)
            内存_写32(线段 + 偏移 + 8, seg.参数[0])
            内存_写32(线段 + 偏移 + 12, seg.参数[1])
            线段数 = 线段数 + 1
            当前x = seg.参数[0]; 当前y = seg.参数[1]
        }
        否则 如果 (seg.命令 == SVG命令_C) {
            // 三次贝塞尔→直线近似(De Casteljau递归细分)
            线段数 = SVG_细分三次贝塞尔(线段, 线段数, 容量,
                                          当前x, 当前y,
                                          seg.参数[0], seg.参数[1],
                                          seg.参数[2], seg.参数[3],
                                          seg.参数[4], seg.参数[5],
                                          精度)
            当前x = seg.参数[4]; 当前y = seg.参数[5]
        }
        否则 如果 (seg.命令 == SVG命令_Q) {
            // 二次贝塞尔→直线近似
            线段数 = SVG_细分二次贝塞尔(线段, 线段数, 容量,
                                          当前x, 当前y,
                                          seg.参数[0], seg.参数[1],
                                          seg.参数[2], seg.参数[3],
                                          精度)
            当前x = seg.参数[2]; 当前y = seg.参数[3]
        }
        seg = seg.下一个
    }

    返回 (线段, 线段数)
}

// De Casteljau三次贝塞尔细分
函数 SVG_细分三次贝塞尔(线段, 线段数, 容量, x0, y0, x1, y1, x2, y2, x3, y3, 精度) {
    如果 (线段数 >= 容量) { 返回 线段数 }
    // 平坦度检查: 控制点到直线的最大距离
    定义 dx = x3 - x0
    定义 dy = y3 - y0
    定义 d1 = SVG_abs((x1 - x3) * dy - (y1 - y3) * dx)
    定义 d2 = SVG_abs((x2 - x3) * dy - (y2 - y3) * dx)

    如果 ((d1 + d2) * (d1 + d2) < 精度 * (dx * dx + dy * dy)) {
        // 足够平坦→直线
        定义 偏移 = 线段数 * 16
        内存_写32(线段 + 偏移, x0)
        内存_写32(线段 + 偏移 + 4, y0)
        内存_写32(线段 + 偏移 + 8, x3)
        内存_写32(线段 + 偏移 + 12, y3)
        返回 线段数 + 1
    }

    // 二分(t=0.5)
    定义 mx01 = (x0 + x1) / 2; 定义 my01 = (y0 + y1) / 2
    定义 mx12 = (x1 + x2) / 2; 定义 my12 = (y1 + y2) / 2
    定义 mx23 = (x2 + x3) / 2; 定义 my23 = (y2 + y3) / 2
    定义 mx012 = (mx01 + mx12) / 2; 定义 my012 = (my01 + my12) / 2
    定义 mx123 = (mx12 + mx23) / 2; 定义 my123 = (my12 + my23) / 2
    定义 mx = (mx012 + mx123) / 2; 定义 my = (my012 + my123) / 2

    线段数 = SVG_细分三次贝塞尔(线段, 线段数, 容量, x0, y0, mx01, my01, mx012, my012, mx, my, 精度)
    线段数 = SVG_细分三次贝塞尔(线段, 线段数, 容量, mx, my, mx123, my123, mx23, my23, x3, y3, 精度)
    返回 线段数
}

函数 SVG_细分二次贝塞尔(线段, 线段数, 容量, x0, y0, cx, cy, x1, y1, 精度) {
    // 转为三次: Q(t) → C(t)
    定义 cx1 = x0 + (cx - x0) * 683 / 1024
    定义 cy1 = y0 + (cy - y0) * 683 / 1024
    定义 cx2 = x1 + (cx - x1) * 683 / 1024
    定义 cy2 = y1 + (cy - y1) * 683 / 1024
    返回 SVG_细分三次贝塞尔(线段, 线段数, 容量, x0, y0, cx1, cy1, cx2, cy2, x1, y1, 精度)
}

// §8 增强渐变采样(带扩展模式)

函数 渐变_应用扩展模式(t_Q10, 扩展模式) {
    // 将t归一化到[0, 1024]范围, 根据扩展模式处理越界
    如果 (t_Q10 >= 0 && t_Q10 <= 1024) { 返回 t_Q10 }
    如果 (扩展模式 == 渐变扩展_Pad) {
        如果 (t_Q10 < 0) { 返回 0 }
        返回 1024
    }
    如果 (扩展模式 == 渐变扩展_Repeat) {
        定义 可变 t = t_Q10 % 1024
        如果 (t < 0) { t = t + 1024 }
        如果 (全局渐变统计 != 空) {
            全局渐变统计.Repeat扩展次数 = 全局渐变统计.Repeat扩展次数 + 1
        }
        返回 t
    }
    如果 (扩展模式 == 渐变扩展_Reflect) {
        定义 可变 t = t_Q10 % 2048
        如果 (t < 0) { t = t + 2048 }
        如果 (t > 1024) { t = 2048 - t }
        如果 (全局渐变统计 != 空) {
            全局渐变统计.Reflect扩展次数 = 全局渐变统计.Reflect扩展次数 + 1
        }
        返回 t
    }
    返回 t_Q10
}

函数 渐变_采样增强(色标数组, 色标数, t_Q10, 扩展模式) {
    如果 (色标数组 == 空 || 色标数 == 0) { 返回 0 }
    定义 t = 渐变_应用扩展模式(t_Q10, 扩展模式)
    如果 (色标数 == 1) {
        定义 基 = 色标数组
        返回 (内存_读8(基 + 4) << 24) | (内存_读8(基 + 5) << 16) | (内存_读8(基 + 6) << 8) | 内存_读8(基 + 7)
    }
    // 二分查找色标区间
    定义 可变 左 = 0
    定义 可变 右 = 色标数 - 1
    当 (左 < 右 - 1) {
        定义 中 = (左 + 右) / 2
        定义 中偏移 = 内存_读32(色标数组 + 中 * 8)
        如果 (t <= 中偏移) { 右 = 中 }
        否则 { 左 = 中 }
    }
    // 在[左, 右]区间插值
    定义 基左 = 色标数组 + 左 * 8
    定义 基右 = 色标数组 + 右 * 8
    定义 偏移左 = 内存_读32(基左)
    定义 偏移右 = 内存_读32(基右)
    定义 范围 = 偏移右 - 偏移左
    如果 (范围 <= 0) { 范围 = 1 }
    定义 比例 = (t - 偏移左) * 1024 / 范围
    如果 (比例 < 0) { 比例 = 0 }
    如果 (比例 > 1024) { 比例 = 1024 }
    定义 inv = 1024 - 比例
    定义 R = (内存_读8(基左 + 4) * inv + 内存_读8(基右 + 4) * 比例) / 1024
    定义 G = (内存_读8(基左 + 5) * inv + 内存_读8(基右 + 5) * 比例) / 1024
    定义 B = (内存_读8(基左 + 6) * inv + 内存_读8(基右 + 6) * 比例) / 1024
    定义 A = (内存_读8(基左 + 7) * inv + 内存_读8(基右 + 7) * 比例) / 1024
    如果 (全局渐变统计 != 空) {
        全局渐变统计.色标插值次数 = 全局渐变统计.色标插值次数 + 1
    }
    返回 (R << 24) | (G << 16) | (B << 8) | A
}

// §9 线性渐变像素采样

函数 线性渐变_采样像素(g, px, py) {
    如果 (g == 空 || g.色标 == 空) { 返回 0 }
    // 计算点(px,py)在渐变线上的投影参数t
    定义 dx = g.x2 - g.x1
    定义 dy = g.y2 - g.y1
    定义 长度平方 = dx * dx + dy * dy
    如果 (长度平方 == 0) { 返回 渐变_采样增强(g.色标, g.色标数, 0, g.扩展模式) }
    定义 t = ((px - g.x1) * dx + (py - g.y1) * dy) * 1024 / 长度平方
    如果 (全局渐变统计 != 空) {
        全局渐变统计.线性采样次数 = 全局渐变统计.线性采样次数 + 1
        全局渐变统计.渐变采样总次数 = 全局渐变统计.渐变采样总次数 + 1
    }
    返回 渐变_采样增强(g.色标, g.色标数, t, g.扩展模式)
}

// §10 径向渐变像素采样

函数 径向渐变_采样像素(g, px, py) {
    如果 (g == 空 || g.色标 == 空 || g.r <= 0) { 返回 0 }
    // 计算点到焦点的距离占半径的比例
    定义 fdx = px - g.fx
    定义 fdy = py - g.fy
    // 简化: 假设焦点=圆心时, t = dist(p, center) / r
    定义 距离平方 = fdx * fdx + fdy * fdy
    // 整数近似平方根: 牛顿法3次迭代
    定义 可变 估计 = g.r / 2
    如果 (估计 <= 0) { 估计 = 1 }
    估计 = (估计 + 距离平方 / 估计) / 2
    估计 = (估计 + 距离平方 / 估计) / 2
    估计 = (估计 + 距离平方 / 估计) / 2
    定义 距离 = 估计
    定义 t = 距离 * 1024 / g.r
    如果 (全局渐变统计 != 空) {
        全局渐变统计.径向采样次数 = 全局渐变统计.径向采样次数 + 1
        全局渐变统计.渐变采样总次数 = 全局渐变统计.渐变采样总次数 + 1
    }
    返回 渐变_采样增强(g.色标, g.色标数, t, g.扩展模式)
}

// §11 AI基因 — 渲染精度自适应
// 能力: 自适应 + 预测 + 学习
// 四阶段: 数据采集→特征提取→决策→执行

函数 AI渐变_记录渲染(渐变类型, 色标数, 路径段数) {
    如果 (全局渐变AI == 空) { 返回 }
    定义 AI = 全局渐变AI
    AI.采样计数器 = AI.采样计数器 + 1

    AI.历史色标数均值 = (AI.历史色标数均值 * 7 + 色标数 * 1024) / 8
    AI.历史路径复杂度 = (AI.历史路径复杂度 * 7 + 路径段数 * 1024) / 8
    AI.上次渐变类型 = 渐变类型

    定义 可变 是简单 = 假
    如果 (色标数 <= 2 && 路径段数 <= 10) { 是简单 = 真 }
    如果 (是简单 == 真) {
        AI.连续简单渐变数 = AI.连续简单渐变数 + 1
    } 否则 {
        AI.连续简单渐变数 = 0
    }

    // 每16次做决策
    如果 (AI.采样计数器 < 16) { 返回 }
    AI.采样计数器 = 0

    如果 (全局渐变统计 != 空) {
        全局渐变统计.AI精度调用次数 = 全局渐变统计.AI精度调用次数 + 1
    }

    如果 (AI.连续简单渐变数 > 8) {
        AI.预测精度级别 = 4   // 降低精度, 提升速度
    } 否则 如果 (AI.历史路径复杂度 > 50 * 1024) {
        AI.预测精度级别 = 16  // 复杂路径, 高精度
    } 否则 {
        AI.预测精度级别 = 8   // 默认中精度
    }

    如果 (是简单 == 真 && AI.预测精度级别 <= 4) {
        如果 (全局渐变统计 != 空) {
            全局渐变统计.AI精度命中次数 = 全局渐变统计.AI精度命中次数 + 1
        }
    }
}

函数 AI渐变_获取推荐精度() {
    如果 (全局渐变AI == 空) { 返回 8 }
    返回 全局渐变AI.预测精度级别
}

// §12 统计输出与诊断

函数 SVG渐变_打印统计() {
    如果 (全局渐变统计 == 空) {
        打印("[SVG渐变] 统计未初始化")
        返回
    }
    打印("┌──────────────────────────────────────┐")
    打印("│   SVG渐变+光栅化 · 统计报告         │")
    打印("├──────────────────────────────────────┤")
    打印(字符串拼接("│ 线性渐变创建:     ", 转字符串(全局渐变统计.线性渐变创建数)))
    打印(字符串拼接("│ 径向渐变创建:     ", 转字符串(全局渐变统计.径向渐变创建数)))
    打印(字符串拼接("│ 渐变采样总次:     ", 转字符串(全局渐变统计.渐变采样总次数)))
    打印(字符串拼接("│ 线性采样:         ", 转字符串(全局渐变统计.线性采样次数)))
    打印(字符串拼接("│ 径向采样:         ", 转字符串(全局渐变统计.径向采样次数)))
    打印(字符串拼接("│ 色标插值:         ", 转字符串(全局渐变统计.色标插值次数)))
    打印(字符串拼接("│ Pad扩展:          ", 转字符串(全局渐变统计.Pad扩展次数)))
    打印(字符串拼接("│ Repeat扩展:       ", 转字符串(全局渐变统计.Repeat扩展次数)))
    打印(字符串拼接("│ Reflect扩展:      ", 转字符串(全局渐变统计.Reflect扩展次数)))
    打印(字符串拼接("│ 路径展平:         ", 转字符串(全局渐变统计.路径展平总次数)))
    打印(字符串拼接("│ 贝塞尔细分:       ", 转字符串(全局渐变统计.贝塞尔细分次数)))
    打印(字符串拼接("│ 线段生成:         ", 转字符串(全局渐变统计.线段生成总数)))
    打印(字符串拼接("│ AI精度调用:       ", 转字符串(全局渐变统计.AI精度调用次数)))
    打印(字符串拼接("│ AI精度命中:       ", 转字符串(全局渐变统计.AI精度命中次数)))
    打印(字符串拼接("│ 总采样耗时(μs):   ", 转字符串(全局渐变统计.总采样耗时_纳秒 / 1000)))
    打印(字符串拼接("│ 错误:             ", 转字符串(全局渐变统计.错误总数)))
    打印("└──────────────────────────────────────┘")
}

函数 SVG渐变_导出诊断() {
    如果 (全局渐变AI == 空) {
        打印("[SVG渐变 AI] 未初始化")
        返回
    }
    定义 AI = 全局渐变AI
    打印("[SVG渐变 AI] === 诊断 ===")
    打印(字符串拼接("  历史色标数(Q10): ", 转字符串(AI.历史色标数均值)))
    打印(字符串拼接("  历史路径复杂度(Q10): ", 转字符串(AI.历史路径复杂度)))
    打印(字符串拼接("  连续简单渐变: ", 转字符串(AI.连续简单渐变数)))
    打印(字符串拼接("  推荐精度级别: ", 转字符串(AI.预测精度级别)))
    打印(字符串拼接("  上次类型: ", 转字符串(AI.上次渐变类型)))
}

// §13 对外接口

函数 SVG渐变_获取统计() { 返回 全局渐变统计 }
函数 SVG渐变_获取AI状态() { 返回 全局渐变AI }

函数 SVG渐变_获取推荐精度() {
    返回 AI渐变_获取推荐精度()
}

函数 SVG渐变_是否已初始化() {
    返回 全局渐变已初始化
}

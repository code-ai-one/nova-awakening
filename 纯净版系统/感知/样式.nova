// §7 CSS aspect-ratio
// aspect-ratio: 16 / 9
// aspect-ratio: auto 16 / 9

结构 AspectRatio {
    宽比,    // u32 分子
    高比,    // u32 分母
    auto,    // 布尔 是否优先使用固有宽高比
    有效,
}


函数 AspectRatio_解析(值字符串) {
    定义 ar = AspectRatio { 宽比: 0, 高比: 0, auto: 假, 有效: 假 }

    如果 (值字符串 == 0 || 字符串_相等(值字符串, "auto")) {
        ar.auto = 真; ar.有效 = 真
        返回 ar
    }

    // 检查是否以auto开头
    如果 (字符串_开头匹配(值字符串, "auto ")) {
        ar.auto = 真
        // 跳过 "auto "
    }

    // 解析 "16 / 9" 或 "1.777"
    如果 (字符串_包含(值字符串, "/")) {
        // w / h 格式
        // 解析 w / h 格式
        ar.宽比 = CSS解析_数字_前(值字符串, "/")
        ar.高比 = CSS解析_数字_后(值字符串, "/")
        ar.有效 = 真
    } 否则 {
        // 单个数字(宽高比值)
        ar.宽比 = 100; ar.高比 = 100    // 1:1
        ar.有效 = 真
    }

    返回 ar
}

函数 AspectRatio_应用到布局(布局对象, ar) {
    如果 (布局对象 == 0 || !ar.有效) { 返回 }

    // auto: 使用元素固有宽高比(如img/video)
    如果 (ar.auto) {
        // 检查元素是否有固有宽高比
        如果 (布局对象.固有宽高比 > 0) {
            返回    // 使用固有的,不覆盖
        }
    }

    如果 (ar.宽比 == 0 || ar.高比 == 0) { 返回 }

    // 应用宽高比:
    // 如果有明确宽度,根据宽高比计算高度
    // 如果有明确高度,根据宽高比计算宽度
    // 如果都没有,宽高比作为"首选"宽高比

    如果 (布局对象.宽 > 0 && 布局对象.高 == 0) {
        // 已知宽,计算高
        布局对象.高 = 布局对象.宽 * ar.高比 / ar.宽比
    }
    否则 如果 (布局对象.高 > 0 && 布局对象.宽 == 0) {
        // 已知高,计算宽
        布局对象.宽 = 布局对象.高 * ar.宽比 / ar.高比
    }
    否则 如果 (布局对象.宽 == 0 && 布局对象.高 == 0) {
        // 使用可用空间 + 宽高比
        如果 (布局对象.可用宽 > 0) {
            布局对象.宽 = 布局对象.可用宽
            布局对象.高 = 布局对象.宽 * ar.高比 / ar.宽比
        }
    }

    // min-width/max-width/min-height/max-height约束
    // 宽高比"传递"约束: min-width会隐式限制min-height
}

// §8 CSS text-wrap: balance / pretty / stable

定义 TW_WRAP     = 0    // 默认
定义 TW_NOWRAP   = 1
定义 TW_BALANCE  = 2    // 行宽平衡
定义 TW_PRETTY   = 3    // 避免孤行
定义 TW_STABLE   = 4    // 编辑稳定

函数 TextWrap_解析(值) {
    如果 (值 == 0 || 字符串_相等(值, "wrap")) { 返回 TW_WRAP }
    如果 (字符串_相等(值, "nowrap")) { 返回 TW_NOWRAP }
    如果 (字符串_相等(值, "balance")) { 返回 TW_BALANCE }
    如果 (字符串_相等(值, "pretty")) { 返回 TW_PRETTY }
    如果 (字符串_相等(值, "stable")) { 返回 TW_STABLE }
    返回 TW_WRAP
}

函数 TextWrap_Balance_布局(文本节点, 可用宽, 行列表, 行数) {
    // text-wrap: balance
    // 目标: 使所有行的宽度尽可能接近
    // 算法: 二分搜索最优行宽
    如果 (行数 <= 1) { 返回 }    // 单行不需要平衡

    // 计算总文本宽度
    定义 可变 总宽 = 0
    定义 可变 i = 0
    当 (i < 行数) {
        总宽 = 总宽 + 内存_读32(行列表 + i * 4)
        i = i + 1
    }

    // 目标行宽 ≈ 总宽 / 行数
    定义 目标行宽 = 总宽 / 行数

    // 尝试以目标行宽重新断行
    // 二分搜索: 找到使行数不变的最小行宽
    定义 可变 低 = 目标行宽
    定义 可变 高 = 可用宽
    当 (低 < 高) {
        定义 中 = (低 + 高) / 2
        定义 测试行数 = TextWrap_计算行数(文本节点, 中)
        如果 (测试行数 <= 行数) {
            高 = 中
        } 否则 {
            低 = 中 + 1
        }
    }

    // 以找到的最优宽度重新布局
}

函数 TextWrap_计算行数(文本节点, 行宽) {
    // 根据文本长度和行宽估算行数
    如果 (行宽 <= 0) { 返回 1 }
    定义 文本宽 = Text渲染er_度量宽度(文本节点.字体, 文本节点.文本, 文本节点.长度)
    如果 (文本宽 <= 行宽) { 返回 1 }
    返回 (文本宽 + 行宽 - 1) / 行宽
}

函数 TextWrap_Pretty_布局(文本节点, 行列表, 行数) {
    // text-wrap: pretty
    // 避免最后一行过短(孤行 orphan)
    // 如果最后一行 < 总宽/行数的1/3, 尝试将前一行的部分文本移到最后一行
    如果 (行数 <= 1) { 返回 }

    定义 最后行宽 = 内存_读32(行列表 + (行数 - 1) * 4)
    定义 倒数第二行宽 = 内存_读32(行列表 + (行数 - 2) * 4)

    如果 (最后行宽 < 倒数第二行宽 / 3) {
        // 需要重新分配: 缩短倒数第二行,延长最后一行
    }
}

// 辅助存根
函数 Nova函数_Call_简(i, fn) { 如果 (fn != 0 && fn.字节码 != 0) { Bytecode_执行(i, fn.字节码, fn.字节码长度, fn.闭包环境) } }

定义 可变 AI_样式_样式缓存命中 = 0

函数 AI_样式_选择器复杂度(选择器长度, 组合子数) {
    如果 (组合子数 > 5) { 返回 "高复杂度" }
    如果 (组合子数 > 2) { 返回 "中复杂度" }
    返回 "低复杂度"
}

函数 AI_样式_布局缓存(元素哈希) {
    AI_样式_样式缓存命中 = AI_样式_样式缓存命中 + 1
    返回 元素哈希
}

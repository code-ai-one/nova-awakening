导入("../基础.nova")
导入("../集合/堆/最小堆.nova")
导入("../集合/队列/队列.nova")

函数 数据结构_栈_创建(容量) { 定义 可变 数组 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(数组, 0)
 i = i + 1 }
 返回 [数组, 0, 容量]
}
函数 数据结构_栈_压入(s, 值) {
    如果 (s[1] >= s[2]) { 返回 假
}
 s[0][s[1]] = 值
 s[1] = s[1] + 1
 返回 真
}
函数 数据结构_栈_弹出(s) {
    如果 (s[1] == 0) { 返回 -1
}
 s[1] = s[1] - 1
 返回 s[0][s[1]]
}
函数 数据结构_栈_顶(s) {
    如果 (s[1] == 0) { 返回 -1
}
 返回 s[0][s[1] - 1]
}
函数 数据结构_栈_大小(s) { 返回 s[1] }
函数 栈_空吗(s) { 返回 s[1] == 0 }
函数 栈_满吗(s) { 返回 s[1] >= s[2] }
函数 栈_清空(s) { s[1] = 0 }

// 队列 (Queue): FIFO
// 型: [数据列表, 头指针, 容量]
函数 数据结构_队列_创建(容量) { 返回 [[], 0, 容量] }
函数 数据结构_队列_入队(q, 值) {
    如果 (计数(q[0]) - q[1] >= q[2]) { 返回 假
}
 追加(q[0], 值)
 返回 真
}
函数 数据结构_队列_出队(q) {
    定义 可变 新列表 = []
    如果 (q[1] >= 计数(q[0])) { 返回 -1
}
 定义 v = q[0][q[1]]
 q[1] = q[1] + 1
 // 紧凑: 头指针过大时重整
如果 (q[1] > 64) {
 定义 可变 i = q[1]
 当 (i < 计数(q[0])) { 追加(新列表, q[0][i])
 i = i + 1 }
 q[0] = 新列表
 q[1] = 0
 }
 返回 v
}
函数 数据结构_队列_头(q) {
    如果 (q[1] >= 计数(q[0])) { 返回 -1
}
 返回 q[0][q[1]]
}
函数 数据结构_队列_大小(q) { 返回 计数(q[0]) - q[1] }
函数 数据结构_队列_空吗(q) { 返回 数据结构_队列_大小(q) == 0 }

// 双端队列 (Deque) — 环形缓冲实现
// 型: [数组, 容量, 头, 尾, 计数]
函数 双端_创建() { 定义 容量 = 64
 定义 可变 数组 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(数组, 0)
 i = i + 1 }
 返回 [数组, 容量, 0, 0]
}
函数 双端_后插(d, 值) {
    如果 (d[4] >= d[1]) { 返回 假
}
 d[0][d[3]] = 值
 d[3] = (d[3] + 1) % d[1]
 d[4] = d[4] + 1
 返回 真
}
函数 双端_前插(d, 值) {
    如果 (d[4] >= d[1]) { 返回 假
}
 d[2] = (d[2] - 1 + d[1]) % d[1]
 d[0][d[2]] = 值
 d[4] = d[4] + 1
 返回 真
}
函数 双端_前出(d) {
    如果 (d[4] == 0) { 返回 -1
}
 定义 v = d[0][d[2]]
 d[2] = (d[2] + 1) % d[1]
 d[4] = d[4] - 1
 返回 v
}
函数 双端_后出(d) {
    如果 (d[4] == 0) { 返回 -1
}
 d[3] = (d[3] - 1 + d[1]) % d[1]
 定义 v = d[0][d[3]]
 d[4] = d[4] - 1
 返回 v
}
函数 双端_大小(d) { 返回 d[4] }
函数 双端_前(d) {
    如果 (d[4] == 0) { 返回 -1 }
    返回 d[0][d[2]]
}
函数 双端_后(d) {
    如果 (d[4] == 0) { 返回 -1 }
    返回 d[0][(d[3] - 1 + d[1]) % d[1]]
}

// 优先队列 (Min-Heap)
// 型: [堆数组]
函数 数据结构_优先队列_创建() { 返回 [[]] }
函数 数据结构_优先队列_大小(pq) { 返回 计数(pq[0]) }
函数 数据结构_优先队列_空吗(pq) { 返回 计数(pq[0]) == 0 }

函数 数据结构_堆_上浮(h, 索引) { 定义 可变 i = 索引
 当 (i != 0) { 定义 父 = (i - 1) / 2
 如果 (h[i] < h[父]) { 定义 临时 = h[i]
 h[i] = h[父]
 h[父] = 临时
 i = 父
 } 否则 { 返回 空 }
 }
}

函数 数据结构_堆_下沉(h, 索引) { 定义 n = 计数(h)
 定义 可变 i = 索引
 当 (i * 2 + 1 < n) { 定义 可变 最小 = i
 定义 左 = i * 2 + 1
 定义 右 = i * 2 + 2
 如果 (左 < n 且 h[左] < h[最小]) { 最小 = 左 }
 如果 (右 < n 且 h[右] < h[最小]) { 最小 = 右 }
 如果 (最小 == i) { 返回 空 }
 定义 临时 = h[i]
 h[i] = h[最小]
 h[最小] = 临时
 i = 最小
 }
}

// 3参数版本 (最大堆, 升序堆排序用)
函数 堆_下沉3(h, size, 索引) { 定义 可变 i = 索引
 当 (i * 2 + 1 < size) { 定义 可变 最大 = i
 定义 左 = i * 2 + 1
 定义 右 = i * 2 + 2
 如果 (左 < size 且 h[左] > h[最大]) { 最大 = 左 }
 如果 (右 < size 且 h[右] > h[最大]) { 最大 = 右 }
 如果 (最大 == i) { 返回 空 }
 定义 临时 = h[i]
 h[i] = h[最大]
 h[最大] = 临时
 i = 最大
 }
}

函数 优先队列_插入(pq, 值) {
 追加(pq[0], 值)
 堆_上浮(pq[0], 计数(pq[0]) - 1)
}

函数 优先队列_弹出(pq) { 定义 n = 计数(pq[0])
 如果 (n == 0) { 返回 -1 }
 定义 最小 = pq[0][0]
 pq[0][0] = pq[0][n - 1]
 删除(pq[0], n - 1)
 如果 (计数(pq[0]) != 0) { 堆_下沉(pq[0], 0) }
 返回 最小
}

函数 数据结构_优先队列_顶(pq) {
    如果 (计数(pq[0]) == 0) { 返回 -1
}
 返回 pq[0][0]
}

// 环形缓冲 (Ring Buffer)
// 型: [数组, 容量, 头, 尾, 计数]
函数 环形_创建_预分配(容量) { 定义 可变 数组 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(数组, 0)
 i = i + 1 }
 返回 [数组, 容量, 0, 0]
}
函数 环形_写(rb, 值) {
    如果 (rb[4] >= rb[1]) { 返回 假
}
 rb[0][rb[3]] = 值
 rb[3] = (rb[3] + 1) % rb[1]
 rb[4] = rb[4] + 1
 返回 真
}
函数 环形_读(rb) {
    如果 (rb[4] == 0) { 返回 -1
}
 定义 v = rb[0][rb[2]]
 rb[2] = (rb[2] + 1) % rb[1]
 rb[4] = rb[4] - 1
 返回 v
}
函数 环形_大小(rb) { 返回 rb[4] }
函数 环形_满吗(rb) { 返回 rb[4] >= rb[1] }
函数 环形_空吗(rb) { 返回 rb[4] == 0 }

// 位图 (Bitmap)
// 型: [整数数组, 位数] 每个整数存储一个位(简化版)
函数 数据_位图_创建(位数) { 定义 可变 数组 = []
 定义 可变 i = 0
 当 (i < 位数) { 追加(数组, 0)
 i = i + 1 }
 返回 [数组, 位数]
}
函数 数据结构_位图_设置(bm, 位) {
    如果 (位 >= 0 且 位 < bm[1]) { bm[0][位] = 1
}
}
函数 数据结构_位图_清除(bm, 位) {
    如果 (位 >= 0 且 位 < bm[1]) { bm[0][位] = 0
}
}
函数 数据_位图_测试(bm, 位) {
    如果 (位 >= 0 且 位 < bm[1]) { 返回 bm[0][位] == 1
}
 返回 假
}
函数 数据_位图_翻转(bm, 位) {
    如果 (位 >= 0 且 位 < bm[1]) { 如果 (bm[0][位] == 0) { bm[0][位] = 1 } 否则 { bm[0][位] = 0
}
 }
}
函数 数据_位图_计数(bm) { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < bm[1]) { 如果 (bm[0][i] == 1) { c = c + 1 }
 i = i + 1 }
 返回 c
}
函数 位图_首个1(bm) { 定义 可变 i = 0
 当 (i < bm[1]) { 如果 (bm[0][i] == 1) { 返回 i }
 i = i + 1 }
 返回 -1
}
函数 位图_首个0(bm) { 定义 可变 i = 0
 当 (i < bm[1]) { 如果 (bm[0][i] == 0) { 返回 i }
 i = i + 1 }
 返回 -1
}

// 有序映射 (Sorted Map — 平衡BST简化版)
// 节点: [键, 值, 左, 右]
函数 有序映射_创建() { 返回 [空] }

函数 BST_插入(节点, 键, 值) {
    如果 (节点 == 空) { 返回 [键, 值, 空, 空]
}
 如果 (键 < 节点[0]) { 节点[2] = BST_插入(节点[2], 键, 值) }
 否则 如果 (键 == 节点[0]) { 节点[1] = 值 }
 否则 { 节点[3] = BST_插入(节点[3], 键, 值) }
 返回 节点
}

函数 BST_查找(节点, 键) {
    如果 (节点 == 空) { 返回 空
}
 如果 (键 == 节点[0]) { 返回 节点[1] }
 如果 (键 < 节点[0]) { 返回 BST_查找(节点[2], 键) }
 返回 BST_查找(节点[3], 键)
}

函数 BST_最小(节点) {
    如果 (节点 == 空) { 返回 空
}
 如果 (节点[2] == 空) { 返回 节点[0] }
 返回 BST_最小(节点[2])
}

函数 BST_最大(节点) {
    如果 (节点 == 空) { 返回 空
}
 如果 (节点[3] == 空) { 返回 节点[0] }
 返回 BST_最大(节点[3])
}

函数 BST_大小(节点) {
    如果 (节点 == 空) { 返回 0
}
 返回 1 + BST_大小(节点[2]) + BST_大小(节点[3])
}

// LRU缓存 — 时间戳版
// 型: [键列表, 值列表, 时间列表, 活跃列表, 容量, 时钟, 活跃数]
函数 数据_LRU_创建(容量) { 返回 [[], [], [], [], 容量,] }
函数 数据_LRU_获取(lru, 键) { 定义 可变 i = 0
 当 (i < 计数(lru[0])) { 如果 (lru[3][i] == 1 且 lru[0][i] == 键) {
 lru[5] = lru[5] + 1
 lru[2][i] = lru[5]
 返回 lru[1][i]
 }
 i = i + 1
 }
 返回 空
}
函数 数据_LRU_放入(lru, 键, 值) {
 lru[5] = lru[5] + 1
 // 先查是否已存在
 定义 可变 i = 0
 当 (i < 计数(lru[0])) { 如果 (lru[3][i] == 1 且 lru[0][i] == 键) {
 lru[1][i] = 值
 lru[2][i] = lru[5]
 返回 空
 }
 i = i + 1
 }
 // 满了淘汰最旧
 如果 (lru[6] >= lru[4]) { 定义 可变 最旧idx = -1
 定义 可变 最旧t = lru[5] + 1
 定义 可变 j = 0
 当 (j < 计数(lru[0])) { 如果 (lru[3][j] == 1 且 lru[2][j] < 最旧t) {
 最旧t = lru[2][j]
 最旧idx = j
 }
 j = j + 1
 }
 如果 (最旧idx >= 0) {
 lru[3][最旧idx] = 0
 lru[6] = lru[6] - 1
 }
 }
 // 插入新条目
 追加(lru[0], 键)
 追加(lru[1], 值)
 追加(lru[2], lru[5])
 追加(lru[3], 1)
 lru[6] = lru[6] + 1
}
函数 数据_LRU_大小(lru) { 返回 lru[6] }

// 栈转列表
函数 栈_转列表(s) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < s[1]) { 追加(r, s[0][i])
 i = i + 1 }
 返回 r
}

// 集合并集

函数 集合_并集(a, b) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(a)) { 追加(结果, a[i]) i = i + 1 }
 i = 0
 当 (i < 计数(b)) { 定义 可变 存在 = 假
 定义 可变 j = 0
 当 (j < 计数(结果)) { 如果 (结果[j] == b[i]) { 存在 = 真 }
 j = j + 1
 }
 如果 (!存在) { 追加(结果, b[i]) }
 i = i + 1
 }
 返回 结果
}

函数 集合_交集(a, b) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(a)) { 定义 可变 j = 0
 当 (j < 计数(b)) { 如果 (a[i] == b[j]) { 追加(结果, a[i]) }
 j = j + 1
 }
 i = i + 1
 }
 返回 结果
}

函数 集合_差集(a, b) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(a)) { 定义 可变 在b中 = 假
 定义 可变 j = 0
 当 (j < 计数(b)) { 如果 (a[i] == b[j]) { 在b中 = 真 }
 j = j + 1
 }
 如果 (!在b中) { 追加(结果, a[i]) }
 i = i + 1
 }
 返回 结果
}

// 优先队列(最小堆)

函数 最小堆_上浮(堆, 索引) {
 当 (索引 > 0) { 定义 父 = (索引 - 1) / 2
 如果 (堆[索引] < 堆[父]) { 定义 临 = 堆[索引]
 堆[索引] = 堆[父]
 堆[父] = 临
 索引 = 父
 } 否则 { 返回 }
 }
}

函数 堆_下沉_区间(堆, 索引, 大小) {
 当 (索引 * 2 + 1 < 大小) { 定义 可变 最小 = 索引 * 2 + 1
 如果 (最小 + 1 < 大小 且 堆[最小 + 1] < 堆[最小]) { 最小 = 最小 + 1 }
 如果 (堆[最小] < 堆[索引]) { 定义 临 = 堆[索引]
 堆[索引] = 堆[最小]
 堆[最小] = 临
 索引 = 最小
 } 否则 { 返回 }
 }
}

函数 数据_堆_插入(堆, 值) {
 追加(堆, 值)
 堆_上浮(堆, 计数(堆) - 1)
}

函数 堆_弹出最小(堆) {
    如果 (计数(堆) == 0) { 返回 -1
}
 定义 最小 = 堆[0]
 定义 末 = 计数(堆) - 1
 堆[0] = 堆[末]
 删除(堆, 末)
 如果 (计数(堆) > 0) { 堆_下沉_区间(堆, 0, 计数(堆)) }
 返回 最小
}

// 环形缓冲区

函数 环形_创建(容量) { 返回 [[], 0, 容量] }

函数 环形_写入(缓冲, 值) {
    如果 (计数(缓冲[0]) < 缓冲[3]) { 追加(缓冲[0], 值)
}
 否则 { 缓冲[0][缓冲[2] % 缓冲[3]] = 值 }
 缓冲[2] = 缓冲[2] + 1
}

函数 环形_读取(缓冲) {
    如果 (缓冲[1] >= 缓冲[2]) { 返回 -1
}
 定义 值 = 缓冲[0][缓冲[1] % 缓冲[3]]
 缓冲[1] = 缓冲[1] + 1
 返回 值
}

函数 环形_可用(缓冲) { 返回 缓冲[2] - 缓冲[1] }

定义 可变 _DS_操作次数 = 0
定义 可变 _DS_最大容量 = 0
定义 可变 _DS_溢出次数 = 0

函数 DS_记录操作(容量) { _DS_操作次数 = _DS_操作次数 + 1
 如果 (容量 > _DS_最大容量) { _DS_最大容量 = 容量 }
}

函数 DS_记录溢出() { _DS_溢出次数 = _DS_溢出次数 + 1 }

函数 DS_重置() { _DS_操作次数 = 0 _DS_最大容量 = 0 _DS_溢出次数 = 0 }

// 双端队列

函数 数据结构_双端队列_创建() { 返回 [[], 0] }

函数 数据结构_双端队列_前插(q, 值) { 定义 可变 新列 = [值]
 定义 可变 i = 0
 当 (i < 计数(q[0])) { 追加(新列, q[0][i]) i = i + 1 }
 q[0] = 新列
 q[1] = q[1] + 1
}

函数 数据结构_双端队列_后插(q, 值) {
 追加(q[0], 值)
 q[1] = q[1] + 1
}

函数 数据结构_双端队列_前取(q) {
    如果 (q[1] == 0) { 返回 -1
}
 定义 值 = q[0][0]
 定义 可变 新列 = []
 定义 可变 i = 1
 当 (i < 计数(q[0])) { 追加(新列, q[0][i]) i = i + 1 }
 q[0] = 新列
 q[1] = q[1] - 1
 返回 值
}

函数 数据结构_双端队列_大小(q) { 返回 q[1] }

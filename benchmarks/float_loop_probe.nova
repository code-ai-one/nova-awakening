// 探测: 循环内 定义 可变 浮点变量 的问题
函数 inner() {
    定义 可变 r = []
    定义 可变 i = 0
    当 (i < 2) {
        定义 可变 s = 0.0
        定义 t = 1.5
        s = s + t
        追加(r, s)
        i = i + 1
    }
    返回 r
}

函数 主程序() {
    定义 lst = inner()
    打印(字符串拼接("lst[0] bits=", 转字符串(lst[0])))
    打印(字符串拼接("lst[1] bits=", 转字符串(lst[1])))
    // 预期 1.5 bits = 4609434218613702656
    返回 0
}

函数 Overscroll_应该传播(ssc, 方向x, 方向y) {
    如果 (ssc == 0) { 返回 真 }

    // 检查x轴
    如果 (方向x != 0) {
        如果 (ssc.overscroll_x == OVERSCROLL_CONTAIN || ssc.overscroll_x == OVERSCROLL_NONE) {
            // 检查是否到达边界
            如果 (方向x < 0 && ssc.滚动x <= 0) { 返回 假 }
            如果 (方向x > 0 && ssc.滚动x >= ssc.内容宽 - ssc.视口宽) { 返回 假 }
        }
    }

    // 检查y轴
    如果 (方向y != 0) {
        如果 (ssc.overscroll_y == OVERSCROLL_CONTAIN || ssc.overscroll_y == OVERSCROLL_NONE) {
            如果 (方向y < 0 && ssc.滚动y <= 0) { 返回 假 }
            如果 (方向y > 0 && ssc.滚动y >= ssc.内容高 - ssc.视口高) { 返回 假 }
        }
    }

    返回 真
}

函数 Overscroll_应该弹性(ssc) {
    如果 (ssc == 0) { 返回 真 }
    // none: 无弹性效果
    如果 (ssc.overscroll_x == OVERSCROLL_NONE && ssc.overscroll_y == OVERSCROLL_NONE) {
        返回 假
    }
    返回 真
}

// §9 scrollTo/scrollBy + smooth behavior

函数 元素_scrollTo(元素, 选项x, 选项y, 行为) {
    定义 ssc = 元素_获取滚动容器(元素)
    如果 (ssc == 0) { 返回 }

    定义 可变 目标x = 选项x
    定义 可变 目标y = 选项y

    // 范围限制
    如果 (目标x < 0) { 目标x = 0 }
    如果 (目标y < 0) { 目标y = 0 }
    如果 (目标x > ssc.内容宽 - ssc.视口宽) { 目标x = ssc.内容宽 - ssc.视口宽 }
    如果 (目标y > ssc.内容高 - ssc.视口高) { 目标y = ssc.内容高 - ssc.视口高 }

    如果 (行为 == SCROLL_BEHAVIOR_SMOOTH || ssc.滚动行为 == SCROLL_BEHAVIOR_SMOOTH) {
        ScrollSnap_平滑滚动到(ssc, 目标x, 目标y)
    } 否则 {
        ssc.滚动x = 目标x
        ssc.滚动y = 目标y
        // 检查snap
        如果 (ssc.轴 != SNAP_AXIS_NONE) {
            ScrollSnap_滚动结束(ssc)
        }
    }
}

函数 元素_scrollBy(元素, dx, dy, 行为) {
    定义 ssc = 元素_获取滚动容器(元素)
    如果 (ssc == 0) { 返回 }
    元素_scrollTo(元素, ssc.滚动x + dx, ssc.滚动y + dy, 行为)
}

函数 ScrollSnap_平滑滚动到(ssc, 目标x, 目标y) {
    如果 (ssc == 0) { 返回 }
    ssc.目标x = 目标x
    ssc.目标y = 目标y
    如果 (ssc.snap上下文 != 0) {
        ssc.snap上下文.当前滚动x = ssc.滚动x
        ssc.snap上下文.当前滚动y = ssc.滚动y
        ScrollSnap_动画到(ssc.snap上下文, ssc.元素, 目标x, 目标y, ssc.动画持续时间)
    }
    ssc.滚动x = 目标x
    ssc.滚动y = 目标y
    元素_设置scrollLeft(ssc.元素, 目标x)
    元素_设置scrollTop(ssc.元素, 目标y)
}

函数 ScrollSnap_滚动结束(ssc) {
    如果 (ssc == 0 || ssc.snap上下文 == 0) { 返回 }
    ScrollSnap_处理滚动结束(ssc.snap上下文, ssc.元素, ssc.滚动x, ssc.滚动y, ssc.惯性vx, ssc.惯性vy)
    ssc.滚动x = ssc.snap上下文.当前滚动x
    ssc.滚动y = ssc.snap上下文.当前滚动y
    元素_设置scrollLeft(ssc.元素, ssc.滚动x)
    元素_设置scrollTop(ssc.元素, ssc.滚动y)
}

函数 滚动容器_是否可滚动(元素) {
    如果 (元素 == 0) { 返回 假 }
    定义 扩展 = 元素_获取扩展(元素)
    如果 (扩展 == 0) { 返回 假 }
    如果 (扩展.滚动容器) { 返回 真 }
    如果 (元素_scrollHeight(元素) > 元素_clientHeight(元素)) { 返回 真 }
    如果 (元素_scrollWidth(元素) > 元素_clientWidth(元素)) { 返回 真 }
    如果 (元素.标签名 == "body" || 元素.标签名 == "html") { 返回 真 }
    返回 假
}

函数 滚动容器_同步状态(ssc, 元素) {
    如果 (ssc == 0 || 元素 == 0) { 返回 0 }
    定义 扩展 = 元素_获取扩展(元素)
    如果 (扩展 == 0) { 返回 0 }

    ssc.元素 = 元素
    ssc.内容宽 = 元素_scrollWidth(元素)
    ssc.内容高 = 元素_scrollHeight(元素)
    ssc.视口宽 = 元素_clientWidth(元素)
    ssc.视口高 = 元素_clientHeight(元素)
    ssc.滚动x = 元素_scrollLeft(元素)
    ssc.滚动y = 元素_scrollTop(元素)
    如果 (ssc.动画持续时间 == 0) { ssc.动画持续时间 = 300 }

    如果 (ssc.snap上下文 == 0) {
        ssc.snap上下文 = ScrollSnap_创建上下文(ssc.视口宽, ssc.视口高)
    }
    如果 (ssc.snap上下文 != 0) {
        ScrollSnap_从样式初始化(ssc.snap上下文, 扩展)
        ScrollSnap_重建并排序(ssc.snap上下文, 元素, ssc.内容宽 - ssc.视口宽, ssc.内容高 - ssc.视口高)
        ssc.轴 = ssc.snap上下文.轴
        ssc.严格度 = ssc.snap上下文.严格
    }
    返回 ssc
}

函数 元素_获取滚动容器(元素) {
    如果 (元素 == 0) { 返回 0 }
    如果 (!滚动容器_是否可滚动(元素)) { 返回 0 }

    定义 扩展 = 元素_获取扩展(元素)
    如果 (扩展 == 0) { 返回 0 }

    定义 可变 ssc = 扩展.滚动容器状态
    如果 (ssc == 0) {
        ssc = ScrollSnapContainer_创建()
        扩展.滚动容器状态 = ssc
        扩展.滚动容器 = 真
    }

    返回 滚动容器_同步状态(ssc, 元素)
}


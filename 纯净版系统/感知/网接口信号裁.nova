// §1 Clipboard 接口 — 剪贴板读写
// navigator.clipboard.readText() / writeText()
// navigator.clipboard.read() / write() — 支持图片等

结构 ClipboardItem {
 类型列表,    // u64 MIME类型字符串数组
 数据列表,    // u64 Blob*数组
 类型数量,
}

结构 Clipboard {
 // 权限状态
 读权限,
 写权限,
}

函数 Clipboard_readText(Nova运行时实例) {
 // 返回承诺<string>
 // 1. 检查权限(需要用户手势或权限授予)
 // 2. 从系统剪贴板读取文本
 定义 文本 = 平台_剪贴板_读取文本()
 返回 文本
}

函数 Clipboard_writeText(Nova运行时实例, 文本) {
 // 返回承诺<void>
 // 需要用户手势或权限
 如果 (文本 == 0) { 返回 }
 平台_剪贴板_写入文本(文本)
}

函数 Clipboard_read(Nova运行时实例) {
 // 返回承诺<ClipboardItem[]>
 // 支持读取图片、HTML等
 定义 items = 堆_分配_数组(8 * 8)
 定义 可变 数量 = 0

 // 检查剪贴板内容类型
 定义 文本 = 平台_剪贴板_读取文本()
 如果 (文本 != 0) {
 定义 item = 堆_分配(ClipboardItem)
 item.类型数量 = 1
 item.类型列表 = 堆_分配_数组(8)
 内存_写64(item.类型列表, "text/plain")
 item.数据列表 = 堆_分配_数组(8)
 内存_写64(item.数据列表, 文本)
 内存_写64(items + 数量 * 8, item)
 数量 = 数量 + 1
 }

 定义 图片 = 平台_剪贴板_读取图片()
 如果 (图片 != 0) {
 定义 item = 堆_分配(ClipboardItem)
 item.类型数量 = 1
 item.类型列表 = 堆_分配_数组(8)
 内存_写64(item.类型列表, "image/png")
 item.数据列表 = 堆_分配_数组(8)
 内存_写64(item.数据列表, 图片)
 内存_写64(items + 数量 * 8, item)
 数量 = 数量 + 1
 }

 返回 [items, 数量]
}

函数 Clipboard_write(Nova运行时实例, items, 数量) {
 // 写入ClipboardItem[]到系统剪贴板
 如果 (items == 0 || 数量 == 0) { 返回 }
 定义 可变 i = 0
 当 (i < 数量) {
 定义 item = 内存_读64(items + i * 8)
 如果 (item != 0 && item.类型数量 > 0) {
 定义 类型 = 内存_读64(item.类型列表)
 定义 数据 = 内存_读64(item.数据列表)
 如果 (字符串_相等(类型, "text/plain")) {
 平台_剪贴板_写入文本(数据)
 }
 }
 i = i + 1
 }
}

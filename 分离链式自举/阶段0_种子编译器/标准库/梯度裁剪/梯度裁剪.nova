导入("../数学/基础/数学库.nova")
导入("../算法/数学扩展.nova")


// 范数
函数 L2_范数(梯度) { 返回 整数sqrt(折叠(梯度, 0, (s, g) => s + g * g))
}

函数 L1_范数(梯度) { 返回 折叠(梯度, 0, (s, g) => s + 绝对值(g))
}

函数 Linf_范数(梯度) { 定义 可变 mx = 0
 定义 可变 i = 0
 当 (i < 计数(梯度)) { 定义 v = 绝对值(梯度[i])
 如果 (v > mx) { mx = v }
 i = i + 1
 }
 返回 mx
}

// 范数裁剪
函数 按范数裁剪(梯度, max_norm) { 定义 范数 = L2_范数(梯度)
 如果 (范数 <= max_norm) { 返回 梯度 }
 返回 映射(梯度, g => g * max_norm / 范数)
}

// 值裁剪
函数 按值裁剪(梯度, min_v, max_v) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(梯度)) { 定义 可变 v = 梯度[i]
 如果 (v < min_v) { v = min_v }
 如果 (v > max_v) { v = max_v }
 追加(结果, v)
 i = i + 1
 }
 返回 结果
}

// 全局范数裁剪 (多参数组, 0)
函数 全局范数裁剪(参数组列表, _max_norm) { 定义 可变 全局sq = 0
 定义 可变 gi = 0
 当 (gi < 计数(参数组列表)) { 定义 grp = 参数组列表[gi]
 定义 可变 j = 0
 当 (j < 计数(grp)) { 全局sq = 全局sq + grp[j] * grp[j] / 1000
 j = j + 1 }
 gi = gi + 1
 }
 定义 全局norm = 整数sqrt(全局sq)
 返回 全局norm
}

// 全局裁剪 (实际执行裁剪)
函数 应用全局范数裁剪(梯度, 全局norm, max_norm) {
    如果 (全局norm <= max_norm) { 返回 梯度
}
 返回 映射(梯度, g => g * max_norm / 全局norm)
}

// 自适应梯度裁剪 (Adaptive Gradient Clipping, 0 , 0)
// clip 比率: ||g|| / ||w|| < 衰减系数
函数 自适应梯度裁剪(梯度, 权重, 衰减系数) { 定义 g_norm = L2_范数(梯度)
 定义 可变 w_norm = L2_范数(权重)
 如果 (w_norm < 1) { w_norm = 1 }
 定义 比率 = g_norm * 1000 / w_norm
 如果 (比率 <= 衰减系数) { 返回 梯度 }
 定义 缩放值 = 衰减系数 * w_norm / g_norm
 返回 映射(梯度, g => g * 缩放值 / 1000)
}

// 梯度噪声注入
定义 可变 _梯度裁剪_种子 = 42

函数 梯度噪声(梯度, sigma, 步长) {
 // sigma_t = sigma / (1+t)^0.55 ≈ sigma / (1+步长/2)
 定义 衰减值 = 1000 + 步长 / 2
 定义 sigma_t = sigma * 1000 / 衰减值
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(梯度)) { _梯度裁剪_种子 = (_梯度裁剪_种子 * 1103515245 + 12345) % 2147483647
 定义 噪声 = (_梯度裁剪_种子 % 2001 - 1000) * sigma_t / 1000
 追加(结果, 梯度[i] + 噪声)
 i = i + 1
 }
 返回 结果
}

// 梯度中心化
函数 梯度裁剪_梯度中心化(梯度) { 定义 n = 计数(梯度)
 如果 (n == 0) { 返回 [] }
 定义 均值 = 折叠(梯度, 0, (s, g) => s + g) / n
 返回 映射(梯度, g => g - 均值)
}

// 梯度稀疏化 (TopK保留, 0)
函数 梯度稀疏化(梯度, keep_ratio) { 定义 n = 计数(梯度)
    定义 可变 abs_vals = []
 定义 可变 k = n * keep_ratio / 1000
 如果 (k < 1) { k = 1 }
 // 找第k大的绝对值作为阈值
 定义 可变 i = 0
 当 (i < n) { 追加(abs_vals, 绝对值(梯度[i]))
 i = i + 1 }
 // 部分排序找阈值
 定义 可变 pass_i = 0
 当 (pass_i < k) { 定义 可变 j = n - 1
 当 (j > pass_i) { 如果 (abs_vals[j] > abs_vals[j - 1]) { 定义 临时 = abs_vals[j]
 abs_vals[j] = abs_vals[j - 1]
 abs_vals[j - 1] = 临时
 }
 j = j - 1
 }
 pass_i = pass_i + 1
 }
 定义 阈值 = abs_vals[k - 1]
 定义 可变 结果 = []
 i = 0
 当 (i < n) { 如果 (绝对值(梯度[i]) >= 阈值) { 追加(结果, 梯度[i]) }
 否则 { 追加(结果, 0) }
 i = i + 1
 }
 返回 结果
}

// 梯度累积
定义 可变 累积_缓冲 = []
定义 可变 累积_步数 = 0
定义 可变 累积_目标 = 4

函数 裁剪_累积_初始化(维度, 目标步数) {
 累积_缓冲 = []
 累积_步数 = 0
 累积_目标 = 目标步数
 定义 可变 i = 0
 当 (i < 维度) { 追加(累积_缓冲, 0)
 i = i + 1 }
}

函数 累积_加(梯度) { 定义 可变 i = 0
 当 (i < 计数(梯度)) { 累积_缓冲[i] = 累积_缓冲[i] + 梯度[i]
 i = i + 1 }
 累积_步数 = 累积_步数 + 1
}

函数 梯度裁剪_累积_就绪() { 返回 累积_步数 >= 累积_目标 }

函数 累积_获取平均() { 定义 结果 = 映射(累积_缓冲, x => x / 累积_目标)
 定义 可变 i = 0
 当 (i < 计数(累积_缓冲)) { 累积_缓冲[i] = 0
 i = i + 1 }
 累积_步数 = 0
 返回 结果
}

// 梯度缩放 (混合精度)
定义 缩放_因子 = 65536
定义 缩放_增长间隔 = 2000
定义 可变 缩放_计数器 = 0

函数 缩放_初始化(初始因子) { 缩放_因子 = 初始因子
缩放_计数器 = 0 }

函数 缩放_放大(梯度) { 返回 映射(梯度, g => g * 缩放_因子 / 1000)
}

函数 缩放_缩小(梯度) { 返回 映射(梯度, g => g * 1000 / 缩放_因子)
}

函数 缩放_更新(有溢出) { 如果 (有溢出) {
 缩放_因子 = 缩放_因子 / 2
 缩放_计数器 = 0
 } 否则 {
 缩放_计数器 = 缩放_计数器 + 1
 如果 (缩放_计数器 >= 缩放_增长间隔) {
 缩放_因子 = 缩放_因子 * 2
 缩放_计数器 = 0
 }
 }
}

// 检测梯度溢出
函数 梯度_有溢出(梯度, 阈值) { 定义 可变 i = 0
 当 (i < 计数(梯度)) { 如果 (绝对值(梯度[i]) > 阈值) { 返回 真 }
 i = i + 1
 }
 返回 假
}

// 梯度维度
函数 梯度_维度(g) { 返回 计数(g) }

// 自适应裁剪
定义 可变 _自适应_范数历史 = []

函数 自适应裁剪_记录范数(范数) {
 追加(_自适应_范数历史, 范数)
 如果 (计数(_自适应_范数历史) > 100) { 定义 可变 新 = []
 定义 可变 i = 50
 当 (i < 计数(_自适应_范数历史)) { 追加(新, _自适应_范数历史[i]) i = i + 1 }
 _自适应_范数历史 = 新
 }
}

函数 自适应裁剪_阈值(百分位) { 定义 n = 计数(_自适应_范数历史)
 如果 (n < 5) { 返回 1000 }
 定义 可变 副本 = []
 定义 可变 i = 0
 当 (i < n) { 追加(副本, _自适应_范数历史[i]) i = i + 1 }
 i = 0
 当 (i < n) { 定义 可变 j = i + 1
 当 (j < n) { 如果 (副本[j] < 副本[i]) { 定义 t = 副本[i] 副本[i] = 副本[j] 副本[j] = t }
 j = j + 1
 }
 i = i + 1
 }
 返回 副本[百分位 * n / 100]
}

// 梯度稀疏化
函数 梯度_Top_K_稀疏(梯度, k) { 定义 n = 计数(梯度)
 定义 可变 绝对值列 = []
 定义 可变 i = 0
 当 (i < n) { 定义 可变 v = 梯度[i]
 如果 (v < 0) { v = 0 - v }
 追加(绝对值列, v)
 i = i + 1
 }
 定义 可变 阈值 = 0
 定义 可变 已选 = 0
 定义 可变 当前最大 = 999999
 当 (已选 < k) { 定义 可变 最大 = 0
 i = 0
 当 (i < n) { 如果 (绝对值列[i] > 最大 且 绝对值列[i] < 当前最大) { 最大 = 绝对值列[i] }
 i = i + 1
 }
 当前最大 = 最大
 阈值 = 最大
 已选 = 已选 + 1
 }
 定义 可变 结果 = []
 i = 0
 当 (i < n) { 定义 可变 绝对值 = 梯度[i]
 如果 (绝对值 < 0) { 绝对值 = 0 - 绝对值 }
 如果 (绝对值 >= 阈值) { 追加(结果, 梯度[i]) }
 否则 { 追加(结果, 0) }
 i = i + 1
 }
 返回 结果
}

// 梯度累积误差补偿
定义 可变 _误差补偿 = []

函数 误差补偿_初始化(维度) { _误差补偿 = []
 定义 可变 i = 0
 当 (i < 维度) { 追加(_误差补偿, 0) i = i + 1 }
}

函数 误差补偿_应用(梯度, 稀疏梯度) { 定义 可变 i = 0
 当 (i < 计数(梯度)) { _误差补偿[i] = _误差补偿[i] + 梯度[i] - 稀疏梯度[i]
 i = i + 1
 }
}

函数 误差补偿_取(维度) {
    如果 (维度 < 计数(_误差补偿)) { 返回 _误差补偿[维度]
}
 返回 0
}

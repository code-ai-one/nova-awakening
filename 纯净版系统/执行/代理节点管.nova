// §2 代理节点管理

函数 IP隐匿_添加代理(类型, 地址, 端口, 用户名, 密码, 国家, 是住宅) {
    定义 节点 = 代理节点 {}
    节点.ID = 计数(IP_代理池.节点列表) + 1
    节点.类型 = 类型
    节点.地址 = 地址
    节点.端口 = 端口
    节点.用户名 = 用户名
    节点.密码 = 密码
    节点.国家 = 国家
    节点.状态 = 代理状态_可用
    节点.延迟 = 0
    节点.成功率 = 10000    // 100%初始
    节点.使用次数 = 0
    节点.带宽 = 0
    节点.是否住宅 = 是住宅
    节点.风险评分 = 0

    追加(IP_代理池.节点列表, 节点)

    // 更新国家索引
    IP隐匿_更新国家索引(国家, 节点.ID)
    返回 节点.ID
}

函数 IP隐匿_更新国家索引(国家, 节点ID) {
    定义 可变 i = 0
    当 (i < 计数(IP_代理池.国家索引)) {
        如果 (IP_代理池.国家索引[i][0] == 国家) {
            追加(IP_代理池.国家索引[i][1], 节点ID)
            返回
        }
        i = i + 1
    }
    追加(IP_代理池.国家索引, [国家, [节点ID]])
}

函数 IP隐匿_批量添加(代理列表) {
    // 格式: [[类型, 地址, 端口, 用户名, 密码, 国家, 是否住宅], ...]
    定义 可变 i = 0
    当 (i < 计数(代理列表)) {
        定义 p = 代理列表[i]
        IP隐匿_添加代理(p[0], p[1], p[2], p[3], p[4], p[5], p[6])
        i = i + 1
    }
    内核信息("IP隐匿: 批量导入 " + 整数转字符串(计数(代理列表)) + " 个代理节点")
}

// §3 国家/城市选择

函数 IP隐匿_设置国家(国家代码) {
    IP_配置.目标国家 = 国家代码
    // 同步更新指纹伪装的地理信息
    指纹伪装_设置国家(国家代码)
    // 清除域名映射(换国家需要新IP)
    IP_域名映射 = []
    内核信息("IP隐匿: 目标国家设置为 " + 国家代码)
}

// §4 智能代理选择 — AI驱动

函数 IP隐匿_选择代理(目标域名) {
    如果 (!IP_配置.启用代理) { 返回 空 }

    // 检查排除域名
    定义 可变 i = 0
    当 (i < 计数(IP_配置.排除域名)) {
        如果 (字符串查找(目标域名, IP_配置.排除域名[i]) >= 0) {
            返回 空    // 直连
        }
        i = i + 1
    }

    // 同域保持IP
    如果 (IP_配置.同域保持IP) {
        i = 0
        当 (i < 计数(IP_域名映射)) {
            如果 (IP_域名映射[i][0] == 目标域名) {
                定义 节点 = IP隐匿_获取节点(IP_域名映射[i][1])
                如果 (节点 != 空 && 节点.状态 == 代理状态_可用) {
                    返回 节点
                }
            }
            i = i + 1
        }
    }

    // 从目标国家的可用节点中选择
    定义 候选 = IP隐匿_获取国家节点(IP_配置.目标国家)
    如果 (计数(候选) == 0) {
        // 回退到所有可用节点
        候选 = IP_代理池.节点列表
    }

    // AI智能选择: 综合延迟+成功率+风险评分+使用频率
    定义 可变 最佳 = 空
    定义 可变 最高分 = 0
    i = 0
    当 (i < 计数(候选)) {
        定义 节点 = 候选[i]
        如果 (节点.状态 != 代理状态_可用) { i = i + 1; 继续 }
        如果 (IP_配置.仅住宅IP && !节点.是否住宅) { i = i + 1; 继续 }

        // 评分 = 成功率 - 延迟/10 - 风险评分*50 - 使用频率
        定义 分数 = 节点.成功率 - 节点.延迟 / 10 - 节点.风险评分 * 50 - 节点.使用次数
        如果 (分数 > 最高分 || 最佳 == 空) {
            最高分 = 分数
            最佳 = 节点
        }
        i = i + 1
    }

    如果 (最佳 != 空) {
        // 记录域名映射
        如果 (IP_配置.同域保持IP) {
            追加(IP_域名映射, [目标域名, 最佳.ID])
        }
        最佳.使用次数 = 最佳.使用次数 + 1
    }

    IP_总请求数 = IP_总请求数 + 1
    返回 最佳
}

函数 IP隐匿_获取节点(节点ID) {
    定义 可变 i = 0
    当 (i < 计数(IP_代理池.节点列表)) {
        如果 (IP_代理池.节点列表[i].ID == 节点ID) {
            返回 IP_代理池.节点列表[i]
        }
        i = i + 1
    }
    返回 空
}

函数 IP隐匿_获取国家节点(国家) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(IP_代理池.节点列表)) {
        如果 (IP_代理池.节点列表[i].国家 == 国家) {
            追加(结果, IP_代理池.节点列表[i])
        }
        i = i + 1
    }
    返回 结果
}

导入("../感知/内核直连层.nova")
导入("./硬链接.nova")
导入("./内存初始化.nova")
导入("./整数转字符串.nova")
导入("./哈希函数.nova")
导入("./创建甲.nova")
导入("../引导/端口输入.nova")
导入("./获取当前页.nova")

定义 最大资源限制 = 16
定义 创建速率窗口 = 32

结构 进程资源限 {
    最大文件数,
    最大内存页,
    最大栈大小,
    最大子进程,
    处理器时限,
}

定义 可变 总创建数 = 0
定义 可变 总失败数 = 0
定义 可变 下一标识 = 1
定义 可变 写时复制次数 = 0
定义 可变 创建速率历史 = 0
定义 可变 历史写位 = 0
定义 可变 上次速率时刻 = 0
定义 可变 当前速率 = 0

函数 进程_分叉(父进程) {
    如果 (父进程 == 0) { 总失败数 = 总失败数 + 1; 返回 错误_无效参数 }
    定义 子标识 = 下一标识
    下一标识 = 下一标识 + 1
    定义 子进程 = 堆_分配(进程描述大小)
    如果 (子进程 == 0) { 总失败数 = 总失败数 + 1; 返回 错误_内存不足 }
    内存_复制(子进程, 父进程, 进程描述大小)
    设置(子进程, T_标识, 子标识)
    设置(子进程, T_父标识, 父进程[T_标识])
    设置(子进程, T_状态, 进程_就绪)
    进程_克隆页表(子进程, 父进程)
    进程_继承资源限(子进程, 父进程)
    进程_继承文件表(子进程, 父进程)
    进程_继承信号表(子进程, 父进程)
    总创建数 = 总创建数 + 1
    进程_记录创建速率()
    返回 子标识
}

函数 进程_克隆页表(子, 父) {
    定义 父页表基 = 父[T_页表基址]
    如果 (父页表基 == 0) { 返回 }
    定义 子页表基 = 堆_分配(4096)
    内存_复制(子页表基, 父页表基, 4096)
    定义 可变 页索引 = 0
    当 (页索引 < 512) {
        定义 页项 = 内存_读64(子页表基 + 页索引 * 8)
        如果 (页项 != 0 && (页项 & 1) == 1) {
            定义 新页项 = (页项 & ~2) | 1
            内存_写64(子页表基 + 页索引 * 8, 新页项)
            内存_写64(父页表基 + 页索引 * 8, 新页项)
            写时复制次数 = 写时复制次数 + 1
        }
        页索引 = 页索引 + 1
    }
    设置(子, T_页表基址, 子页表基)
}

函数 进程_继承资源限(子, 父) {
    定义 父限制 = 父[T_资源限制]
    如果 (父限制 == 0) { 返回 }
    定义 子限制 = 堆_分配(进程资源限)
    子限制.最大文件数 = 内存_读32(父限制)
    子限制.最大内存页 = 内存_读32(父限制 + 4)
    子限制.最大栈大小 = 内存_读32(父限制 + 8)
    子限制.最大子进程 = 内存_读32(父限制 + 12)
    子限制.处理器时限 = 内存_读32(父限制 + 16)
    设置(子, T_资源限制, 子限制)
}

函数 进程_继承文件表(子, 父) {
    定义 父文件表 = 父[T_文件表]
    如果 (父文件表 == 0) { 返回 }
    定义 文件数 = 父[T_打开文件数]
    定义 子文件表 = 堆_分配(文件数 * 8)
    定义 可变 序号 = 0
    当 (序号 < 文件数) {
        定义 文件项 = 内存_读64(父文件表 + 序号 * 8)
        内存_写64(子文件表 + 序号 * 8, 文件项)
        如果 (文件项 != 0) { 文件_增引用(文件项) }
        序号 = 序号 + 1
    }
    设置(子, T_文件表, 子文件表)
    设置(子, T_打开文件数, 文件数)
}

函数 进程_继承信号表(子, 父) {
    定义 父信号表 = 父[T_信号表]
    如果 (父信号表 == 0) { 返回 }
    定义 子信号表 = 堆_分配(64 * 8)
    内存_复制(子信号表, 父信号表, 64 * 8)
    设置(子, T_信号表, 子信号表)
}

函数 进程_记录创建速率() {
    定义 现在 = 平台_获取高精度时间()
    如果 (创建速率历史 == 0) {
        创建速率历史 = 堆_分配(创建速率窗口 * 4)
        上次速率时刻 = 现在
    }
    内存_写32(创建速率历史 + 历史写位 * 4, 1)
    历史写位 = (历史写位 + 1) % 创建速率窗口
    如果 (现在 - 上次速率时刻 >= 1000000) {
        定义 可变 总 = 0
        定义 可变 序号 = 0
        当 (序号 < 创建速率窗口) {
            总 = 总 + 内存_读32(创建速率历史 + 序号 * 4)
            序号 = 序号 + 1
        }
        当前速率 = 总
        上次速率时刻 = 现在
    }
}

函数 进程创建_完整统计() {
    返回 [总创建数, 总失败数, 下一标识, 写时复制次数, 当前速率]
}

// exec系统调用 — 加载新程序映像

定义 可变 exec_调用数 = 0
定义 可变 exec_失败数 = 0
定义 进程描述大小 = 512
定义 T_标识 = 0
定义 T_父标识 = 1
定义 T_状态 = 2
定义 T_页表基址 = 3
定义 T_资源限制 = 4
定义 T_文件表 = 5
定义 T_打开文件数 = 6
定义 T_信号表 = 7
定义 进程_就绪 = 1

函数 进程_exec(当前进程, 路径, 参数列表, 环境列表) {
    exec_调用数 = exec_调用数 + 1

    // 1. 打开可执行文件
    定义 fd = sys_open(路径, 0, 0)
    如果 (fd < 0) {
        exec_失败数 = exec_失败数 + 1
        返回 错误_文件不存在
    }

    // 2. 读取ELF头
    定义 头 = 分配内存(64)
    sys_read(fd, 头, 64)

    // 验证ELF魔数
    如果 (内存_读8(头) != 0x7F || 内存_读8(头 + 1) != 0x45 || 内存_读8(头 + 2) != 0x4C || 内存_读8(头 + 3) != 0x46) {
        释放内存(头)
        sys_close(fd)
        exec_失败数 = exec_失败数 + 1
        返回 错误_格式无效
    }

    // 3. 解析程序头 — 加载段
    定义 程序头偏移 = 内存_读64(头 + 32)
    定义 程序头大小 = 内存_读16(头 + 54)
    定义 程序头数量 = 内存_读16(头 + 56)
    定义 入口地址 = 内存_读64(头 + 24)

    // 4. 释放旧地址空间(保留内核映射)
    进程_清除用户空间(当前进程)

    // 5. 加载每个PT_LOAD段
    定义 可变 i = 0
    当 (i < 程序头数量) {
        定义 ph缓冲 = 分配内存(程序头大小)
        sys_lseek(fd, 程序头偏移 + i * 程序头大小, 0)
        sys_read(fd, ph缓冲, 程序头大小)

        定义 类型 = 内存_读32(ph缓冲)
        如果 (类型 == 1) {
            定义 虚拟地址 = 内存_读64(ph缓冲 + 16)
            定义 文件偏移 = 内存_读64(ph缓冲 + 8)
            定义 文件大小 = 内存_读64(ph缓冲 + 32)
            定义 内存大小 = 内存_读64(ph缓冲 + 40)

            // mmap段
            定义 对齐地址 = 虚拟地址 & ~0xFFF
            定义 对齐大小 = (内存大小 + (虚拟地址 - 对齐地址) + 0xFFF) & ~0xFFF

            进程_映射段(当前进程, 对齐地址, 对齐大小)

            // 复制文件内容
            sys_lseek(fd, 文件偏移, 0)
            sys_read(fd, 虚拟地址, 文件大小)

            // BSS段清零
            如果 (内存大小 > 文件大小) {
                内存_置零(虚拟地址 + 文件大小, 内存大小 - 文件大小)
            }
        }
        释放内存(ph缓冲)
        i = i + 1
    }

    // 6. 设置栈
    定义 栈顶 = 0x7FFFFFFFE000
    定义 栈大小 = 8 * 1024 * 1024
    进程_映射段(当前进程, 栈顶 - 栈大小, 栈大小)

    // 7. 在栈上构建argc/argv/envp
    定义 可变 SP = 栈顶 - 8
    // 压入环境变量
    定义 envp数 = 计数(环境列表)
    定义 可变 ei = envp数 - 1
    当 (ei >= 0) {
        SP = SP - 字符串长度(环境列表[ei]) - 1
        内存拷贝(SP, 环境列表[ei], 字符串长度(环境列表[ei]) + 1)
        ei = ei - 1
    }
    // 压入参数
    定义 argc = 计数(参数列表)
    定义 可变 ai = argc - 1
    当 (ai >= 0) {
        SP = SP - 字符串长度(参数列表[ai]) - 1
        内存拷贝(SP, 参数列表[ai], 字符串长度(参数列表[ai]) + 1)
        ai = ai - 1
    }

    // 8. 设置入口点和栈指针
    当前进程.入口地址 = 入口地址
    当前进程.用户栈指针 = SP
    当前进程.寄存器.RIP = 入口地址
    当前进程.寄存器.RSP = SP

    释放内存(头)
    sys_close(fd)
    返回 成功
}

函数 进程_清除用户空间(进程) {
    如果 (进程 == 0) { 返回 }
    定义 可变 vma = 进程.vma头
    当 (vma != 0) {
        定义 下一个 = 内存_读64(vma + 16)
        堆_释放(vma)
        vma = 下一个
    }
    进程.vma头 = 0
}

函数 进程_映射段(进程, 地址, 大小) {
    如果 (进程 == 0 || 大小 == 0) { 返回 -1 }
    定义 页数 = (大小 + 4095) / 4096
    定义 可变 i = 0
    当 (i < 页数) {
        定义 物理页 = 物理页_分配(1)
        如果 (物理页 != 0) {
            页表_映射(进程.PML4, 地址 + i * 4096, 物理页, 7)
        }
        i = i + 1
    }
    返回 0
}

函数 文件_增引用(文件项) {
    如果 (文件项 != 0) { 文件项.引用数 = 文件项.引用数 + 1 }
}
函数 sys_open(路径, 标志, 模式) {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 错误_无效参数 }
    定义 文件表 = 进程_文件表(当前)
    如果 (文件表 == 空) { 返回 错误_打开过多 }

    定义 文件 = vfs_open(路径, 标志, 模式)
    如果 (文件 == 空 || 文件 < 0) { 返回 文件 }

    定义 fd = 文件表_分配(文件表)
    如果 (fd < 0) { 返回 错误_打开过多 }
    文件表_设置(文件表, fd, 文件)
    返回 fd
}

函数 sys_read(fd, 缓冲, 大小) {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 错误_坏文件描述符 }
    定义 文件 = 进程_获取文件(当前, fd)
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    返回 vfs_read(文件, 缓冲, 大小)
}

函数 sys_close(fd) {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 错误_坏文件描述符 }
    定义 文件表 = 进程_文件表(当前)
    如果 (文件表 == 空) { 返回 错误_坏文件描述符 }
    定义 文件 = 进程_获取文件(当前, fd)
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }

    文件表_关闭(文件表, fd)
    定义 剩余 = 文件_减引用(文件)
    如果 (剩余 <= 0) {
        定义 操作 = 文件[F_操作]
        如果 (操作 != 空 && 操作.释放 != 空) {
            操作.释放(文件[F_Nova文件节点], 文件)
        }
    }
    返回 成功
}

函数 sys_lseek(fd, 偏移, 基准) {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 错误_坏文件描述符 }
    定义 文件 = 进程_获取文件(当前, fd)
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    返回 vfs_lseek(文件, 偏移, 基准)
}

函数 sys_write(fd, 数据, 大小) {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 错误_坏文件描述符 }
    定义 文件 = 进程_获取文件(当前, fd)
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    返回 vfs_write(文件, 数据, 大小)
}
定义 错误_文件不存在 = -2
定义 错误_格式无效 = -8
定义 错误_无效参数 = -22
定义 错误_内存不足 = -12

// AI进程创建分析

定义 可变 AI_创建模式历史 = []

函数 AI_进程_记录创建(PID, 父PID) {
    追加(AI_创建模式历史, { PID: PID, 父PID: 父PID, 时间: 平台_获取高精度时间() })
    如果 (计数(AI_创建模式历史) > 128) {
        AI_创建模式历史 = 子列表(AI_创建模式历史, 64, 128)
    }
}

函数 AI_进程_检测fork炸弹() {
    定义 n = 计数(AI_创建模式历史)
    如果 (n < 10) { 返回 假 }
    // 检查最近10个创建是否来自同一父进程
    定义 可变 同父计数 = 0
    定义 最近父 = AI_创建模式历史[n - 1].父PID
    定义 可变 i = n - 1
    当 (i >= 0 && i > n - 10) {
        如果 (AI_创建模式历史[i].父PID == 最近父) {
            同父计数 = 同父计数 + 1
        }
        i = i - 1
    }
    如果 (同父计数 > 8) {
        内核警告("[AI] 疑似fork炸弹: 父PID=" + 整数转字符串(最近父))
        返回 真
    }
    返回 假
}

函数 进程创建_健康检查() {
    定义 可变 问题 = []
    如果 (总失败数 > 总创建数 / 5 && 总创建数 > 20) {
        追加(问题, "创建失败率高: " + 整数转字符串(总失败数 * 100 / 总创建数) + "%")
    }
    如果 (当前速率 > 100) {
        追加(问题, "创建速率异常: " + 整数转字符串(当前速率) + "/s")
    }
    如果 (AI_进程_检测fork炸弹()) {
        追加(问题, "疑似fork炸弹")
    }
    如果 (计数(问题) == 0) { 返回 "进程创建健康" }
    返回 问题
}

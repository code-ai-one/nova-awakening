导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/内核打印.nova")
导入("./串口早期输.nova")
导入("../中枢/时钟中枢.nova")
导入("../中枢/页表重建.nova")
导入("../中枢/整数转字符串.nova")

//   1. start_kernel: 内核C入口, 初始化所有子系统
//   2. 初始化分7级: early → core → postcore → arch → subsys → fs → device → late
//   3. initcall机制: __initcall宏按优先级自动注册初始化函数
//   4. rest_init: 创建init(PID=1)和kthreadd(PID=2)
//   5. 初始化完成后, start_kernel线程变为idle(PID=0)

定义 INITCALL_EARLY    = 0    // early_initcall: 最早期(串口/显基)
定义 INITCALL_CORE     = 1    // core_initcall: 核心(GDT/IDT/内存)
定义 INITCALL_POSTCORE = 2    // postcore_initcall: 核心后(中断/定时器)
定义 INITCALL_ARCH     = 3    // arch_initcall: 架构相关(接口C/TSC)
定义 INITCALL_SUBSYS   = 4    // subsys_initcall: 子系统(进程/VFS)
定义 INITCALL_FS       = 5    // fs_initcall: 文件系统
定义 INITCALL_DEVICE   = 6    // device_initcall: 设备驱动
定义 INITCALL_LATE     = 7    // late_initcall: 最后(用户空间准备)
定义 INITCALL_LEVELS   = 8

定义 可变 当前初始化阶段 = INITCALL_EARLY

结构 初始化项 {
    名称,
    级别,
    回调,
    已完成,
    耗时_ns,    // u64 初始化耗时
    结果,    // u32 0=成功, 其他=错误码
}

定义 可变 初始化项列表 = []
定义 可变 初始化_总数 = 0
定义 可变 初始化_成功数 = 0
定义 可变 初始化_失败数 = 0
定义 可变 启动开始时间 = 0

// 注册初始化项 

函数 注册初始化项(名称, 阶段, 初始化函数) {
    定义 项 = 初始化项 {}
    项.名称 = 名称
    项.级别 = 阶段
    项.回调 = 初始化函数
    项.已完成 = 0
    项.耗时_ns = 0
    项.结果 = 0
    追加(初始化项列表, 项)
    初始化_总数 = 初始化_总数 + 1
}

// 执行初始化阶段 

函数 执行初始化阶段(阶段) {
    当前初始化阶段 = 阶段
    定义 阶段名 = 初始化阶段名(阶段)

    定义 可变 阶段成功 = 0
    定义 可变 阶段失败 = 0
    定义 可变 i = 0

    当 (i < 计数(初始化项列表)) {
        定义 项 = 初始化项列表[i]
        如果 (项.级别 == 阶段 && 项.已完成 == 0) {
            // 记录开始时间
            定义 开始 = sched_clock()

            // 执行初始化
            定义 结果 = 项.回调()

            // 记录耗时
            定义 结束 = sched_clock()
            项.耗时_ns = 结束 - 开始
            项.已完成 = 1
            项.结果 = 结果

            如果 (是成功(结果)) {
                早期打印OK(项.名称)
                初始化_成功数 = 初始化_成功数 + 1
                阶段成功 = 阶段成功 + 1
            } 否则 {
                早期打印失败(项.名称)
                初始化_失败数 = 初始化_失败数 + 1
                阶段失败 = 阶段失败 + 1
                内核警告("initcall " + 项.名称 + " 失败: " + 整数转字符串(结果))
            }
        }
        i = i + 1
    }
}

// 执行全部初始化 

函数 执行全部初始化() {
    启动开始时间 = sched_clock()

    内核打印(日志_信息, "")
    内核打印(日志_信息, "NovaOS 初始化开始...")

    定义 可变 级别 = 0
    当 (级别 < INITCALL_LEVELS) {
        执行初始化阶段(级别)
        级别 = 级别 + 1
    }

    定义 总耗时 = (sched_clock() - 启动开始时间) / 1000000  // ms
    内核打印(日志_信息, "初始化完成: " + 整数转字符串(初始化_成功数) + " 成功, " +
             整数转字符串(初始化_失败数) + " 失败, 耗时 " +
             整数转字符串(总耗时) + "ms")
}

// rest_init: 创建init进程和kthreadd 

函数 rest_init() {
    // 1. 创建init进程(PID=1)
    // kernel_thread(kernel_init, NULL, CLONE_FS)
    内核打印(日志_信息, "创建init进程(PID=1)...")

    // 2. 创建kthreadd(PID=2) — 内核线程守护进程
    // kernel_thread(kthreadd, NULL, CLONE_FS | CLONE_FILES)
    内核打印(日志_信息, "创建kthreadd(PID=2)...")

    // 3. 当前线程变为idle(PID=0)
    // cpu_startup_entry(CPUHP_ONLINE)
    内核打印(日志_信息, "进入idle循环(PID=0)...")
}

// 辅助

函数 初始化阶段名(阶段) {
    如果 (阶段 == INITCALL_EARLY)    { 返回 "early" }
    如果 (阶段 == INITCALL_CORE)     { 返回 "core" }
    如果 (阶段 == INITCALL_POSTCORE) { 返回 "postcore" }
    如果 (阶段 == INITCALL_ARCH)     { 返回 "arch" }
    如果 (阶段 == INITCALL_SUBSYS)   { 返回 "subsys" }
    如果 (阶段 == INITCALL_FS)       { 返回 "fs" }
    如果 (阶段 == INITCALL_DEVICE)   { 返回 "device" }
    如果 (阶段 == INITCALL_LATE)     { 返回 "late" }
    返回 "unknown"
}

函数 初始化_统计() {
    返回 [初始化_总数, 初始化_成功数, 初始化_失败数]
}

函数 初始化_慢项报告() {
    // 打印耗时>100ms的初始化项
    定义 可变 i = 0
    当 (i < 计数(初始化项列表)) {
        定义 项 = 初始化项列表[i]
        如果 (项.耗时_ns > 100000000) {
            内核打印(日志_信息, "慢initcall: " + 项.名称 + " 耗时=" +
                     整数转字符串(项.耗时_ns / 1000000) + "ms")
        }
        i = i + 1
    }
}

// 按阶段查询初始化项

函数 初始化_阶段项数(阶段) {
    定义 可变 计 = 0
    定义 可变 i = 0
    当 (i < 计数(初始化项列表)) {
        如果 (初始化项列表[i].级别 == 阶段) { 计 = 计 + 1 }
        i = i + 1
    }
    返回 计
}

函数 初始化_阶段耗时(阶段) {
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(初始化项列表)) {
        如果 (初始化项列表[i].级别 == 阶段) {
            总 = 总 + 初始化项列表[i].耗时_ns
        }
        i = i + 1
    }
    返回 总
}

函数 初始化_总耗时_ms() {
    如果 (启动开始时间 == 0) { 返回 0 }
    返回 (sched_clock() - 启动开始时间) / 1000000
}

函数 初始化_完整统计() {
    返回 [初始化_总数, 初始化_成功数, 初始化_失败数, 初始化_总耗时_ms()]
}

定义 可变 AI_引导加载甲_调用数 = 0
定义 可变 AI_引导加载甲_异常数 = 0

函数 AI_引导加载甲_监控() {
    AI_引导加载甲_调用数 = AI_引导加载甲_调用数 + 1
    返回 AI_引导加载甲_异常数 == 0
}

函数 AI_引导加载甲_健康检查() {
    如果 (AI_引导加载甲_调用数 > 0 && AI_引导加载甲_异常数 * 100 / AI_引导加载甲_调用数 > 10) {
        返回 假
    }
    返回 真
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("../感知/内核直连层.nova")
导入("./内存初始化.nova")

定义 最大脑区 = 16
定义 最大连接 = 64
定义 能量基数 = 1024
定义 衰减率 = 950
定义 抑制率 = 200
定义 兴奋阈值 = 600

结构 脑区 {
    类型,
    激活度,
    输出值,
    能量,
    阈值,
    连接数,
    连接目标,
    连接权重,
    累计激活,
    触发次数,
}

定义 可变 脑区表 = []
定义 可变 脑区数 = 0
定义 可变 认知轮次 = 0
定义 可变 总能量 = 0
定义 可变 注意力核 = -1
定义 可变 注意力强 = 0

函数 认知_初始化() {
    脑区表 = []
    脑区数 = 0
    认知轮次 = 0
    注意力核 = -1
}

函数 脑区_注册(类型, 初始能量) {
    如果 (脑区数 >= 最大脑区) { 返回 -1 }
    定义 区 = 脑区 {}
    区.类型 = 类型
    区.激活度 = 0
    区.输出值 = 0
    区.能量 = 初始能量
    区.阈值 = 兴奋阈值
    区.连接数 = 0
    区.连接目标 = 堆_分配(最大连接 * 4)
    区.连接权重 = 堆_分配(最大连接 * 4)
    区.累计激活 = 0
    区.触发次数 = 0
    追加(脑区表, 区)
    定义 索引 = 脑区数
    脑区数 = 脑区数 + 1
    返回 索引
}

函数 脑区_连接(源, 目标, 权重) {
    如果 (源 >= 脑区数 || 目标 >= 脑区数) { 返回 }
    定义 区 = 脑区表[源]
    如果 (区.连接数 >= 最大连接) { 返回 }
    内存_写32(区.连接目标 + 区.连接数 * 4, 目标)
    内存_写32(区.连接权重 + 区.连接数 * 4, 权重)
    区.连接数 = 区.连接数 + 1
}

函数 认知_周期(外部输入, 输入数) {
    认知轮次 = 认知轮次 + 1
    定义 可变 序号 = 0
    当 (序号 < 脑区数) {
        脑区表[序号].激活度 = 脑区表[序号].激活度 * 衰减率 / 能量基数
        序号 = 序号 + 1
    }
    序号 = 0
    当 (序号 < 输入数 && 序号 < 脑区数) {
        脑区表[序号].激活度 = 脑区表[序号].激活度 + 内存_读32(外部输入 + 序号 * 4)
        序号 = 序号 + 1
    }
    序号 = 0
    当 (序号 < 脑区数) {
        定义 区 = 脑区表[序号]
        如果 (区.激活度 >= 区.阈值) {
            区.输出值 = 区.激活度 - 区.阈值
            区.触发次数 = 区.触发次数 + 1
            定义 可变 连序 = 0
            当 (连序 < 区.连接数) {
                定义 目标 = 内存_读32(区.连接目标 + 连序 * 4)
                定义 权重 = 内存_读32(区.连接权重 + 连序 * 4)
                如果 (目标 < 脑区数) {
                    定义 传递 = 区.输出值 * 权重 / 能量基数
                    如果 (权重 > 0) {
                        脑区表[目标].激活度 = 脑区表[目标].激活度 + 传递
                    } 否则 {
                        脑区表[目标].激活度 = 脑区表[目标].激活度 - (0 - 传递)
                        如果 (脑区表[目标].激活度 < 0) { 脑区表[目标].激活度 = 0 }
                    }
                }
                连序 = 连序 + 1
            }
            区.能量 = 区.能量 - 区.输出值 / 10
            如果 (区.能量 < 0) { 区.能量 = 0 }
        } 否则 {
            区.输出值 = 0
        }
        区.累计激活 = 区.累计激活 + 区.激活度
        序号 = 序号 + 1
    }
    认知_更新注意力()
    认知_侧抑制()
}

函数 认知_更新注意力() {
    定义 可变 最高 = 0
    定义 可变 最高激活 = 0
    定义 可变 序号 = 0
    当 (序号 < 脑区数) {
        如果 (脑区表[序号].激活度 > 最高激活) {
            最高激活 = 脑区表[序号].激活度
            最高 = 序号
        }
        序号 = 序号 + 1
    }
    注意力核 = 最高
    注意力强 = 最高激活
}

函数 认知_侧抑制() {
    如果 (注意力核 < 0) { 返回 }
    定义 可变 序号 = 0
    当 (序号 < 脑区数) {
        如果 (序号 != 注意力核) {
            脑区表[序号].激活度 = 脑区表[序号].激活度 * (能量基数 - 抑制率) / 能量基数
        }
        序号 = 序号 + 1
    }
}

函数 多轮认知(轮数, 外部输入, 输入数) {
    定义 可变 胜者表 = 堆_分配(轮数 * 4)
    定义 可变 轮 = 0
    当 (轮 < 轮数) {
        认知_周期(外部输入, 输入数)
        内存_写32(胜者表 + 轮 * 4, 注意力核)
        轮 = 轮 + 1
    }
    返回 胜者表
}

函数 认知_创建默认() {
    认知_初始化()
    脑区_注册(1, 80)
    脑区_注册(2, 60)
    脑区_注册(3, 90)
    脑区_注册(4, 70)
    脑区_注册(5, 50)
    脑区_注册(6, 100)
    脑区_连接(0, 2, 800)
    脑区_连接(0, 1, 600)
    脑区_连接(1, 2, 700)
    脑区_连接(2, 3, 900)
    脑区_连接(3, 5, 850)
    脑区_连接(4, 3, 300)
    脑区_连接(4, 5, -200)
    脑区_连接(5, 0, 100)
}

函数 认知_能量补充(量) {
    定义 可变 序号 = 0
    当 (序号 < 脑区数) {
        脑区表[序号].能量 = 脑区表[序号].能量 + 量 / 脑区数
        如果 (脑区表[序号].能量 > 能量基数) { 脑区表[序号].能量 = 能量基数 }
        序号 = 序号 + 1
    }
    总能量 = 总能量 + 量
}

函数 注意力_焦点() { 返回 注意力核 }
函数 注意力_强度() { 返回 注意力强 }

函数 脑区_获取激活(索引) {
    如果 (索引 >= 脑区数) { 返回 0 }
    返回 脑区表[索引].激活度
}

函数 脑区_获取输出(索引) {
    如果 (索引 >= 脑区数) { 返回 0 }
    返回 脑区表[索引].输出值
}

函数 神经网络_完整统计() {
    返回 [脑区数, 认知轮次, 注意力核, 注意力强, 总能量]
}

// [v2反哺新增] Softmax数值稳定 — 注意力机制升级: Softmax数值稳定版(LogSumExp,误差1/1000,防溢出)
// Softmax数值稳定版 (LogSumExp技巧)
// Rust验证: 误差1/1000, 防止长序列溢出
// 类人脑: 竞争性抑制，模拟神经元侧抑制机制
函数 Softmax数值稳定(scores, n) {
    如果 (scores == 0 || n == 0) { 返回 }
    // step1: 减最大值(数值稳定)
    定义 可变 max_s = 内存_读32有符号(scores)
    定义 可变 i = 1
    当 (i < n) {
        定义 v = 内存_读32有符号(scores + i * 4)
        如果 (v > max_s) { max_s = v }
        i = i + 1
    }
    // step2: exp并求和
    定义 可变 sum_exp = 0
    i = 0
    当 (i < n) {
        定义 v = 内存_读32有符号(scores + i * 4)
        定义 e = Q_exp(v - max_s)
        内存_写32(scores + i * 4, e)
        sum_exp = sum_exp + e
        i = i + 1
    }
    如果 (sum_exp == 0) { 返回 }
    // step3: 归一化
    i = 0
    当 (i < n) {
        定义 e = 内存_读32有符号(scores + i * 4)
        内存_写32(scores + i * 4, Q除(e * Q_ONE, sum_exp))
        i = i + 1
    }
}














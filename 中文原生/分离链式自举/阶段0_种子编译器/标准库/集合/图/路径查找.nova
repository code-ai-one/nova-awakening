// Nova标准库 — 路径查找算法
// A*, BFS最短路径, Floyd-Warshall
// 支撑 AI 导航、知识图谱遍历

导入("../../基础.nova")

// A* 搜索 (网格版)
// 网格: [行, 列, 数据...] (0=可通行, 1=障碍)
// 回: 路径列表 [[行,列], ...] 或 空

函数 A星搜索(网格, 起行, 起列, 终行, 终列) {
    定义 可变 ri = 0
    定义 行数 = 网格[0]
    定义 列数 = 网格[1]
    // 开放列表: [[f值, g值, 行, 列, 父索引], ...]
    定义 可变 开放 = []
    // 关闭集: 字典 {"行-列" → 1}
    定义 可变 关闭 = 字典()
    // 父节点追踪
    定义 可变 父表 = 字典()
    // 起点
    定义 起h = astar_曼哈顿(起行, 起列, 终行, 终列)
    追加(开放, [起h, 0, 起行, 起列])
    字典设(父表, astar_键(起行, 起列), "start")
    当 (计数(开放) > 0) {
        // 找 f 最小的节点
        定义 可变 最小i = 0
        定义 可变 最小f = 开放[0][0]
        定义 可变 si = 1
        当 (si < 计数(开放)) {
            如果 (开放[si][0] < 最小f) {
                最小f = 开放[si][0]
                最小i = si
            }
            si = si + 1
        }
        定义 当前 = 开放[最小i]
        定义 当前行 = 当前[2]
        定义 当前列 = 当前[3]
        定义 当前g = 当前[1]
        // 从开放列表移除
        定义 可变 新开放 = []
        当 (ri < 计数(开放)) {
            如果 (ri != 最小i) { 追加(新开放, 开放[ri]) }
            ri = ri + 1
        }
        开放 = 新开放
        // 到达终点?
        如果 (当前行 == 终行 且 当前列 == 终列) {
            返回 astar_重建路径(父表, 终行, 终列)
        }
        // 加入关闭集
        字典设(关闭, astar_键(当前行, 当前列), 1)
        // 扩展邻居 (四方向)
        定义 方向 = [[-1, 0], [1, 0], [0, -1], [0, 1]]
        定义 可变 di = 0
        当 (di < 4) {
            定义 新行 = 当前行 + 方向[di][0]
            定义 新列 = 当前列 + 方向[di][1]
            // 边界检查
            如果 (新行 < 0 或 新行 >= 行数 或 新列 < 0 或 新列 >= 列数) { di = di + 1  续 }
            定义 键 = astar_键(新行, 新列)
            如果 (网格[2 + 新行 * 列数 + 新列] != 0 或 字典取(关闭, 键) != 空) { di = di + 1  续 }
            astar_尝试扩展(开放, 父表, 当前g, 新行, 新列, 终行, 终列, 当前行, 当前列)
            di = di + 1
        }
    }
    返回 空
}

函数 astar_开放列表有更好(开放, 新行, 新列, 新g) {
    定义 可变 oi = 0
    当 (oi < 计数(开放)) {
        如果 (开放[oi][2] == 新行 且 开放[oi][3] == 新列) {
            返回 开放[oi][1] <= 新g
        }
        oi = oi + 1
    }
    返回 假
}

函数 astar_尝试扩展(开放, 父表, 当前g, 新行, 新列, 终行, 终列, 当前行, 当前列) {
    定义 新g = 当前g + 1
    如果 (astar_开放列表有更好(开放, 新行, 新列, 新g)) { 返回 空 }
    定义 新h = astar_曼哈顿(新行, 新列, 终行, 终列)
    追加(开放, [新g + 新h, 新g, 新行, 新列])
    字典设(父表, astar_键(新行, 新列), astar_键(当前行, 当前列))
}

函数 astar_曼哈顿(行1, 列1, 行2, 列2) {
    定义 可变 d行 = 行1 - 行2
    定义 可变 d列 = 列1 - 列2
    如果 (d行 < 0) { d行 = 0 - d行 }
    如果 (d列 < 0) { d列 = 0 - d列 }
    返回 d行 + d列
}

函数 astar_键(行, 列) {
    返回 字符串拼接(字符串拼接(转字符串(行), ","), 转字符串(列))
}

函数 astar_重建路径(父表, 终行, 终列) {
    定义 可变 反转 = []
    定义 可变 路径 = []
    定义 可变 当前键 = astar_键(终行, 终列)
    当 (字符串等于(当前键, "start") == 假) {
        // 解析行列
        // 简化: 从键中提取
        追加(路径, 当前键)
        当前键 = 字典取(父表, 当前键)
    }
    // 反转路径
    定义 n = 计数(路径)
    定义 可变 i = n - 1
    当 (i >= 0) {
        追加(反转, 路径[i])
        i = i - 1
    }
    返回 反转
}

// Floyd-Warshall 全源最短路径
// 输入: 邻接矩阵 (矩阵格式, 无穷=0x7FFFFFFF)
// 输出: 距离矩阵
函数 弗洛伊德最短路(距离矩阵) {
    定义 n = 距离矩阵[0]
    // 复制矩阵
    定义 可变 d = [n, n]
    定义 可变 i = 0
    当 (i < n * n) {
        追加(d, 距离矩阵[2 + i])
        i = i + 1
    }
    // 三重循环
    定义 可变 k = 0
    当 (k < n) {
        i = 0
        当 (i < n) {
            定义 可变 j = 0
            当 (j < n) {
                定义 直接 = d[2 + i * n + j]
                定义 中转 = d[2 + i * n + k] + d[2 + k * n + j]
                如果 (中转 < 直接) {
                    d[2 + i * n + j] = 中转
                }
                j = j + 1
            }
            i = i + 1
        }
        k = k + 1
    }
    返回 d
}

// 广度优先 最短路径 (无权图)
// 回: [距离, 前驱节点] 或 空
函数 bfs最短路径(邻接表, 起点, 终点) {
    定义 可变 反转 = []
    定义 可变 距离 = 字典()
    定义 可变 前驱 = 字典()
    定义 可变 队列 = [起点]
    定义 可变 前 = 0
    字典设(距离,  转字符串(起点), 0)
    当 (前 < 计数(队列)) {
        定义 当前 = 队列[前]
        前 = 前 + 1
        如果 (当前 == 终点) {
            // 重建路径
            定义 可变 路径 = [终点]
            定义 可变 p = 字典取(前驱, 转字符串(终点))
            当 (p != 空) {
                追加(路径, p)
                p = 字典取(前驱, 转字符串(p))
            }
            // 反转
            定义 pn = 计数(路径)
            定义 可变 pi = pn - 1
            当 (pi >= 0) {
                追加(反转, 路径[pi])
                pi = pi - 1
            }
            返回 [字典取(距离, 转字符串(终点)), 反转]
        }
        // 扩展邻居
        定义 邻居 = 字典取(邻接表, 转字符串(当前))
        如果 (邻居 != 空) {
            定义 可变 i = 0
            当 (i < 计数(邻居)) {
                定义 n = 邻居[i]
                如果 (字典取(距离, 转字符串(n)) == 空) {
                    字典设(距离, 转字符串(n), 字典取(距离, 转字符串(当前)) + 1)
                    字典设(前驱, 转字符串(n), 当前)
                    追加(队列, n)
                }
                i = i + 1
            }
        }
    }
    返回 空
}

// 连通分量
函数 连通分量(邻接表, 节点列表) {
    定义 可变 分量列表 = []
    定义 可变 已访问 = 字典()
    定义 可变 i = 0
    当 (i < 计数(节点列表)) {
        定义 节点 = 节点列表[i]
        如果 (字典取(已访问, 转字符串(节点)) == 空) {
            // 广度优先 发现一个分量
            定义 可变 分量 = []
            定义 可变 队列 = [节点]
            定义 可变 前 = 0
            字典设(已访问, 转字符串(节点), 1)
            当 (前 < 计数(队列)) {
                定义 当前 = 队列[前]
                前 = 前 + 1
                追加(分量, 当前)
                定义 邻居 = 字典取(邻接表, 转字符串(当前))
                如果 (邻居 != 空) {
                    BFS_扩展邻居(邻居, 已访问, 队列)
                }
            }
            追加(分量列表, 分量)
        }
        i = i + 1
    }
    返回 分量列表
}

函数 BFS_扩展邻居(邻居, 已访问, 队列) {
    定义 可变 j = 0
    当 (j < 计数(邻居)) {
        如果 (字典取(已访问, 转字符串(邻居[j])) == 空) {
            字典设(已访问, 转字符串(邻居[j]), 1)
            追加(队列, 邻居[j])
        }
        j = j + 1
    }
}

// 最小生成树 (Prim 简化版)
函数 普里姆最小生成树(邻接矩阵) {
    定义 可变 键值 = []
    定义 可变 总权重 = 0
    定义 n = 邻接矩阵[0]
    定义 无穷 = 0x7FFFFFFF
    定义 可变 在树中 = []
    定义 可变 父 = []
    定义 可变 i = 0
    当 (i < n) {
        追加(在树中, 假)
        追加(键值, 无穷)
        追加(父, -1)
        i = i + 1
    }
    键值[0] = 0
    定义 可变 步 = 0
    当 (步 < n) {
        // 找最小键值的未加入节点
        定义 可变 u = -1
        定义 可变 最小 = 无穷
        i = 0
        当 (i < n) {
            如果 (在树中[i] == 假 且 键值[i] < 最小) {
                最小 = 键值[i]
                u = i
            }
            i = i + 1
        }
        如果 (u == -1) { 步 = n } 否则 {
        在树中[u] = 真
        总权重 = 总权重 + 键值[u]
        // 更新邻居
        i = 0
        当 (i < n) {
            定义 w = 邻接矩阵[2 + u * n + i]
            如果 (在树中[i] == 假 且 w < 键值[i] 且 w > 0) {
                键值[i] = w
                父[i] = u
            }
            i = i + 1
        }
        }
        步 = 步 + 1
    }
    返回 [总权重, 父]
}

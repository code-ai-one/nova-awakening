// §3 图处驱动初始化

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 图处驱动_初始化(gpu) {
    如果 (gpu == 空) {
        内核警告("图处驱动: 无图处设备")
        返回 错误_不存在
    }

    内核信息("图处驱动: 初始化 " + gpu.厂商名 + " " + gpu.型号名 +
             " 驱动=" + gpu.驱动类型)

    // ★ 步骤1: 映射图处 MMIO寄存器
    定义 mmio = ioremap(gpu.BAR0_地址, gpu.BAR0_大小)
    如果 (mmio == 0) {
        内核错误("图处驱动: 无法映射BAR0")
        返回 错误_IO
    }

    // ★ 步骤2: 图处复位(确保干净状态)
    图处_复位(gpu, mmio)

    // ★ 步骤3: 初始化图处内存管理
    图处内存_初始化(gpu)

    // ★ 步骤4: 创建命令队列(环形缓冲)
    定义 队列 = 图处命令队列_创建(gpu, mmio, "gfx", 65536)  // 64KB图形队列
    如果 (队列 != 空) {
        追加(图处_命令队列列表, 队列)
    }

    // 如果支持计算, 额外创建计算命令队列
    如果 ((gpu.能力 & 图处_CAP_COMPUTE) != 0) {
        定义 计算队列 = 图处命令队列_创建(gpu, mmio, "compute", 65536)
        如果 (计算队列 != 空) {
            追加(图处_命令队列列表, 计算队列)
        }
    }

    // ★ 步骤5: 设置中断(MSI)
    图处_中断_初始化(gpu)

    // ★ 步骤6: 设置显示模式(如果有显示能力)
    如果 ((gpu.能力 & 图处_CAP_DISPLAY) != 0) {
        图处_设置显示(gpu, mmio, 1920, 1080, 60)
    }

    gpu.已初始化 = 真
    内核信息("图处驱动: " + gpu.型号名 + " 就绪 " +
             "队列=" + 整数转字符串(计数(图处_命令队列列表)))
    返回 成功
}

// §4 命令队列操作 — 图处通信的核心

函数 图处命令队列_创建(gpu, mmio, 名称, 大小) {
    // 分配直传可访问的内存作为命令缓冲
    定义 缓冲 = 图处内存_分配(大小, GTT, 用途_命令缓冲)
    如果 (缓冲 == 空) { 返回 空 }

    定义 队列 = 图处命令队列 {}
    队列.名称 = 名称
    队列.缓冲地址 = 缓冲.物理地址
    队列.缓冲大小 = 大小
    队列.写指针 = 0
    队列.读指针 = 0
    队列.挂起 = 假
    队列.已提交命令数 = 0
    队列.已完成命令数 = 0

    // 告诉图处命令队列的地址(写MMIO寄存器)
    // 不同厂商的寄存器偏移不同, 但原理相同
    如果 (gpu.厂商ID == 图处_VENDOR_NVIDIA) {
        // NVIDIA: PFIFO引擎, 写入通道描述符
        队列.MMIO_WPTR = mmio + 0x002044   // NV_PFIFO_CACHE1_PUT
        队列.MMIO_RPTR = mmio + 0x002048   // NV_PFIFO_CACHE1_GET
    } 否则 如果 (gpu.厂商ID == 图处_VENDOR_AMD) {
        // AMD: CP(Command Processor)
        队列.MMIO_WPTR = mmio + 0x8010     // CP_RB_WPTR
        队列.MMIO_RPTR = mmio + 0x8014     // CP_RB_RPTR
    } 否则 {
        // 通用: 使用偏移0x2040/0x2044
        队列.MMIO_WPTR = mmio + 0x2040
        队列.MMIO_RPTR = mmio + 0x2044
    }

    内核信息("图处命令队列: " + 名称 + " 创建 大小=" + 整数转字符串(大小 / 1024) + "KB")
    返回 队列
}

函数 图处_提交命令(队列, 命令) {
    如果 (队列 == 空 || 队列.挂起) { 返回 错误_IO }

    // 检查队列空间
    定义 下一个写 = (队列.写指针 + 48) % 队列.缓冲大小   // 每命令48字节
    如果 (下一个写 == 队列.读指针) {
        // 队列满! 等待图处消费
        定义 可变 等待 = 10000
        当 (等待 > 0 && 下一个写 == MMIO读32(队列.MMIO_RPTR)) {
            等待 = 等待 - 1
        }
        如果 (等待 == 0) {
            内核警告("图处: 命令队列满, 超时")
            返回 错误_超时
        }
        队列.读指针 = MMIO读32(队列.MMIO_RPTR)
    }

    // ★ 写入命令到环形缓冲(直传内存)
    定义 写入地址 = 队列.缓冲地址 + 队列.写指针
    内存写32(写入地址 + 0, 命令.类型)
    内存写32(写入地址 + 4, 命令.标志)
    内存写64(写入地址 + 8, 命令.参数0)
    内存写64(写入地址 + 16, 命令.参数1)
    内存写64(写入地址 + 24, 命令.参数2)
    内存写64(写入地址 + 32, 命令.参数3)
    内存写64(写入地址 + 40, 命令.栅栏值)

    // 内存屏障: 确保命令已写入内存
    内存屏障_写()

    // ★ 更新写指针(这一步通知图处有新命令)
    队列.写指针 = 下一个写
    MMIO写32(队列.MMIO_WPTR, 队列.写指针)

    队列.已提交命令数 = 队列.已提交命令数 + 1
    返回 成功
}

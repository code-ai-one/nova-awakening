// §3 环境上下文 — 当前设备/视口/用户偏好状态

结构 媒体Values {
    // 视口
    视口宽,    // i32 ×100
    视口高,
    // 设备
    设备宽,
    设备高,
    设备像素比,    // i32 ×100 (100=1x, 200=2x)
    // 颜色
    颜色位深,    // u32 bits per color (通常8)
    颜色索引,
    单色,    // u32 monoNova浏览器 bits
    // 交互
    指针类型,    // u32 0=none 1=coarse(触摸) 2=fine(鼠标)
    悬停能力,    // u32 0=none 1=hover
    // 用户偏好
    配色方案,    // u32 0=light 1=dark
    动效偏好,    // u32 0=no-preference 1=reduce
    对比度偏好,    // u32 0=no-preference 1=more 2=less 3=custom
    强制颜色,    // u32 0=none 1=active
    反转颜色,    // u32 0=none 1=inverted
    透明度偏好,    // u32 0=no-preference 1=reduce
    数据偏好,    // u32 0=no-preference 1=reduce
    // 显示
    方向,    // u32 0=portrait 1=landscape
    显示模式,    // u32 0=browser 1=standalone 2=fullscreen 3=minimal-ui
    更新频率,    // u32 0=none 1=slow 2=fast
    脚本可用,    // u32 0=none 1=initial-only 2=enabled
    // 媒体类型
    当前媒体类型,    // u32 MT_xxx (screen/print)
    // 动态范围
    动态范围,    // u32 0=standard 1=high
}

定义 可变 全局媒体值 = 0


函数 媒体Values_获取() {
    如果 (全局媒体值 == 0) {
        全局媒体值 = 堆_分配(媒体Values)
        // 默认桌面环境
        全局媒体值.视口宽 = 192000      // 1920px
        全局媒体值.视口高 = 108000       // 1080px
        全局媒体值.设备宽 = 192000
        全局媒体值.设备高 = 108000
        全局媒体值.设备像素比 = 100      // 1x
        全局媒体值.颜色位深 = 8
        全局媒体值.指针类型 = 2          // fine
        全局媒体值.悬停能力 = 1          // hover
        全局媒体值.配色方案 = 0          // light
        全局媒体值.动效偏好 = 0          // no-preference
        全局媒体值.对比度偏好 = 0
        全局媒体值.强制颜色 = 0
        全局媒体值.方向 = 1              // landscape
        全局媒体值.显示模式 = 0          // browser
        全局媒体值.更新频率 = 2          // fast
        全局媒体值.脚本可用 = 2          // enabled
        全局媒体值.当前媒体类型 = MT_SCREEN
        全局媒体值.动态范围 = 0
    }
    返回 全局媒体值
}

函数 媒体Values_从视口更新(宽, 高) {
    定义 mv = 媒体Values_获取()
    mv.视口宽 = 宽
    mv.视口高 = 高
    如果 (宽 >= 高) { mv.方向 = 1 } 否则 { mv.方向 = 0 }
}

函数 媒体Values_设置配色方案(暗色模式) {
    定义 mv = 媒体Values_获取()
    mv.配色方案 = 暗色模式 ? 1 : 0
}

函数 媒体Values_设置动效偏好(减弱) {
    定义 mv = 媒体Values_获取()
    mv.动效偏好 = 减弱 ? 1 : 0
}

// §4 媒体 Query求值引擎

函数 媒体QueryList_求值(mql) {
    如果 (mql == 0 || mql.数量 == 0) { 返回 真 }
    // 多个查询用逗号分隔 = OR
    定义 可变 i = 0
    当 (i < mql.数量) {
        定义 mq = 内存_读64(mql.查询 + i * 8)
        如果 (媒体Query_求值(mq)) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 媒体Query_求值(mq) {
    如果 (mq == 0) { 返回 真 }
    定义 mv = 媒体Values_获取()

    // 检查媒体类型
    定义 可变 类型匹配 = 假
    如果 (mq.媒体类型 == MT_ALL) { 类型匹配 = 真 }
    否则 如果 (mq.媒体类型 == mv.当前媒体类型) { 类型匹配 = 真 }

    如果 (!类型匹配) {
        返回 mq.否定 ? 真 : 假
    }

    // 求值条件
    定义 可变 条件匹配 = 真
    如果 (mq.条件 != 0) {
        条件匹配 = 媒体Condition_求值(mq.条件)
    }

    如果 (mq.否定) { 返回 !条件匹配 }
    返回 条件匹配
}

函数 媒体Condition_求值(条件) {
    如果 (条件 == 0) { 返回 真 }

    // 叶节点: 单个表达式
    如果 (条件.表达式 != 0 && 条件.子条件数 == 0) {
        定义 结果 = 媒体Expression_求值(条件.表达式)
        如果 (条件.是否否定) { 返回 !结果 }
        返回 结果
    }

    // 组合
    如果 (条件.类型 == MQ_CONDITION_AND) {
        定义 可变 i = 0
        当 (i < 条件.子条件数) {
            定义 子 = 内存_读64(条件.子条件 + i * 8)
            如果 (!媒体Condition_求值(子)) { 返回 假 }
            i = i + 1
        }
        返回 真
    }

    如果 (条件.类型 == MQ_CONDITION_OR) {
        定义 可变 i = 0
        当 (i < 条件.子条件数) {
            定义 子 = 内存_读64(条件.子条件 + i * 8)
            如果 (媒体Condition_求值(子)) { 返回 真 }
            i = i + 1
        }
        返回 假
    }

    如果 (条件.类型 == MQ_CONDITION_NOT) {
        如果 (条件.子条件数 > 0) {
            定义 子 = 内存_读64(条件.子条件)
            返回 !媒体Condition_求值(子)
        }
    }

    返回 真
}

函数 媒体Expression_求值(expr) {
    如果 (expr == 0) { 返回 假 }
    定义 mv = 媒体Values_获取()

    如果 (expr.特征 == MF_WIDTH) {
        返回 MQ_比较数值(mv.视口宽, expr)
    }
    如果 (expr.特征 == MF_HEIGHT) {
        返回 MQ_比较数值(mv.视口高, expr)
    }
    如果 (expr.特征 == MF_DEVICE_WIDTH) {
        返回 MQ_比较数值(mv.设备宽, expr)
    }
    如果 (expr.特征 == MF_DEVICE_HEIGHT) {
        返回 MQ_比较数值(mv.设备高, expr)
    }
    如果 (expr.特征 == MF_ORIENTATION) {
        如果 (expr.值_字符串 == 0) { 返回 真 }    // 布尔: 总有方向
        如果 (字符串_相等(expr.值_字符串, "portrait")) { 返回 mv.方向 == 0 }
        如果 (字符串_相等(expr.值_字符串, "landscape")) { 返回 mv.方向 == 1 }
        返回 假
    }
    如果 (expr.特征 == MF_RESOLUTION) {
        返回 MQ_比较数值(mv.设备像素比, expr)
    }
    如果 (expr.特征 == MF_COLOR) {
        如果 (expr.运算符 == MQ_OP_NONE) { 返回 mv.颜色位深 > 0 }
        返回 MQ_比较数值(mv.颜色位深 * 100, expr)
    }
    如果 (expr.特征 == MF_MONONova浏览器) {
        如果 (expr.运算符 == MQ_OP_NONE) { 返回 mv.单色 > 0 }
        返回 MQ_比较数值(mv.单色 * 100, expr)
    }
    如果 (expr.特征 == MF_POINTER) {
        如果 (expr.值_字符串 == 0) { 返回 mv.指针类型 > 0 }
        如果 (字符串_相等(expr.值_字符串, "none")) { 返回 mv.指针类型 == 0 }
        如果 (字符串_相等(expr.值_字符串, "coarse")) { 返回 mv.指针类型 == 1 }
        如果 (字符串_相等(expr.值_字符串, "fine")) { 返回 mv.指针类型 == 2 }
        返回 假
    }
    如果 (expr.特征 == MF_HOVER) {
        如果 (expr.值_字符串 == 0) { 返回 mv.悬停能力 > 0 }
        如果 (字符串_相等(expr.值_字符串, "none")) { 返回 mv.悬停能力 == 0 }
        如果 (字符串_相等(expr.值_字符串, "hover")) { 返回 mv.悬停能力 == 1 }
        返回 假
    }
    如果 (expr.特征 == MF_PREFERS_COLOR_SCHEME) {
        如果 (字符串_相等(expr.值_字符串, "dark")) { 返回 mv.配色方案 == 1 }
        如果 (字符串_相等(expr.值_字符串, "light")) { 返回 mv.配色方案 == 0 }
        返回 假
    }
    如果 (expr.特征 == MF_PREFERS_REDUCED_MOTION) {
        如果 (字符串_相等(expr.值_字符串, "reduce")) { 返回 mv.动效偏好 == 1 }
        如果 (字符串_相等(expr.值_字符串, "no-preference")) { 返回 mv.动效偏好 == 0 }
        返回 假
    }
    如果 (expr.特征 == MF_PREFERS_CONTRAST) {
        如果 (字符串_相等(expr.值_字符串, "more")) { 返回 mv.对比度偏好 == 1 }
        如果 (字符串_相等(expr.值_字符串, "less")) { 返回 mv.对比度偏好 == 2 }
        如果 (字符串_相等(expr.值_字符串, "no-preference")) { 返回 mv.对比度偏好 == 0 }
        返回 假
    }
    如果 (expr.特征 == MF_FORCED_COLORS) {
        如果 (字符串_相等(expr.值_字符串, "active")) { 返回 mv.强制颜色 == 1 }
        如果 (字符串_相等(expr.值_字符串, "none")) { 返回 mv.强制颜色 == 0 }
        返回 假
    }
    如果 (expr.特征 == MF_SCRIPTING) {
        如果 (字符串_相等(expr.值_字符串, "enabled")) { 返回 mv.脚本可用 == 2 }
        如果 (字符串_相等(expr.值_字符串, "initial-only")) { 返回 mv.脚本可用 == 1 }
        如果 (字符串_相等(expr.值_字符串, "none")) { 返回 mv.脚本可用 == 0 }
        返回 假
    }
    如果 (expr.特征 == MF_DISPLAY_MODE) {
        如果 (字符串_相等(expr.值_字符串, "browser")) { 返回 mv.显示模式 == 0 }
        如果 (字符串_相等(expr.值_字符串, "standalone")) { 返回 mv.显示模式 == 1 }
        如果 (字符串_相等(expr.值_字符串, "fullscreen")) { 返回 mv.显示模式 == 2 }
        如果 (字符串_相等(expr.值_字符串, "minimal-ui")) { 返回 mv.显示模式 == 3 }
        返回 假
    }
    如果 (expr.特征 == MF_UPDATE) {
        如果 (字符串_相等(expr.值_字符串, "none")) { 返回 mv.更新频率 == 0 }
        如果 (字符串_相等(expr.值_字符串, "slow")) { 返回 mv.更新频率 == 1 }
        如果 (字符串_相等(expr.值_字符串, "fast")) { 返回 mv.更新频率 == 2 }
        返回 假
    }
    如果 (expr.特征 == MF_DYNAMIC_RANGE) {
        如果 (字符串_相等(expr.值_字符串, "standard")) { 返回 mv.动态范围 == 0 }
        如果 (字符串_相等(expr.值_字符串, "high")) { 返回 mv.动态范围 == 1 }
        返回 假
    }
    如果 (expr.特征 == MF_ASPECT_RATIO) {
        // 视口宽高比查询
        如果 (expr.运算符 == MQ_OP_NONE) { 返回 真 }
        返回 假
    }
    如果 (expr.特征 == MF_GRID) {
        返回 假    // 非grid设备
    }
    如果 (expr.特征 == MF_INVERTED_COLORS) {
        如果 (字符串_相等(expr.值_字符串, "inverted")) { 返回 mv.反转颜色 == 1 }
        如果 (字符串_相等(expr.值_字符串, "none")) { 返回 mv.反转颜色 == 0 }
        返回 假
    }
    如果 (expr.特征 == MF_PREFERS_REDUCED_TRANSPARENCY) {
        如果 (字符串_相等(expr.值_字符串, "reduce")) { 返回 mv.透明度偏好 == 1 }
        如果 (字符串_相等(expr.值_字符串, "no-preference")) { 返回 mv.透明度偏好 == 0 }
        返回 假
    }

    返回 假
}

// 媒体环境辅助

函数 媒体环境_获取视口宽(mv) {
    如果 (mv == 空) { 返回 1920 }
    返回 mv.视口宽
}

函数 媒体环境_获取视口高(mv) {
    如果 (mv == 空) { 返回 1080 }
    返回 mv.视口高
}

函数 媒体环境_是暗色模式(mv) {
    如果 (mv == 空) { 返回 假 }
    返回 mv.颜色方案 == 1
}

函数 媒体环境_设备像素比(mv) {
    如果 (mv == 空) { 返回 1 }
    返回 mv.设备像素比
}

定义 可变 AI_环境上下文_故障预警数 = 0

函数 AI_环境上下文_设备健康(错误率, 响应时间, 温度) {
    定义 可变 分 = 1000
    如果 (错误率 > 10) { 分 = 分 - 错误率 * 5 }
    如果 (响应时间 > 1000) { 分 = 分 - 200 }
    如果 (温度 > 80) { 分 = 分 - 300 }
    如果 (分 < 300) { AI_环境上下文_故障预警数 = AI_环境上下文_故障预警数 + 1 }
    返回 分
}

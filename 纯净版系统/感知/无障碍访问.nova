// §2 AX状态标志

定义 AX_STATE_BUSY       = 0x0001
定义 AX_STATE_CHECKED    = 0x0002
定义 AX_STATE_DISABLED   = 0x0004
定义 AX_STATE_EXPANDED   = 0x0008
定义 AX_STATE_FOCUSABLE  = 0x0010

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../感知/内核直连层.nova")
导入("./扩展尝试组分.nova")
导入("./扩展卸载超级.nova")

定义 可变 块分配_总次数 = 0
定义 可变 块释放_总次数 = 0
定义 可变 块分配_总块数 = 0
定义 可变 块释放_总块数 = 0
定义 可变 块分配_失败次数 = 0
定义 可变 预分配_命中次数 = 0

函数 ext4_更新分配统计(信息, 结果) {
    信息.空闲块数 = 信息.空闲块数 - 结果.分配块数
    块分配_总次数 = 块分配_总次数 + 1
    块分配_总块数 = 块分配_总块数 + 结果.分配块数
}

函数 ext4_更新释放统计(信息, 释放块数) {
    信息.空闲块数 = 信息.空闲块数 + 释放块数
    块释放_总次数 = 块释放_总次数 + 1
    块释放_总块数 = 块释放_总块数 + 释放块数
}

函数 ext4_位图测试位(位图, 位号) {
    定义 字节偏移 = 位号 / 8
    定义 位偏移 = 位号 % 8
    返回 (内存_读8(位图 + 字节偏移) >> 位偏移) & 1
}

函数 ext4_位图设置位(位图, 位号) {
    定义 字节偏移 = 位号 / 8
    定义 位偏移 = 位号 % 8
    定义 旧值 = 内存_读8(位图 + 字节偏移)
    内存_写8(位图 + 字节偏移, 旧值 | (1 << 位偏移))
}

函数 ext4_位图清除位(位图, 位号) {
    定义 字节偏移 = 位号 / 8
    定义 位偏移 = 位号 % 8
    定义 旧值 = 内存_读8(位图 + 字节偏移)
    内存_写8(位图 + 字节偏移, 旧值 & ~(1 << 位偏移))
}

函数 ext4_位图查找空闲(位图, 总位数, 起始位) {
    定义 可变 位号 = 起始位
    当 (位号 < 总位数) {
        如果 (!ext4_位图测试位(位图, 位号)) { 返回 位号 }
        位号 = 位号 + 1
    }
    位号 = 0
    当 (位号 < 起始位) {
        如果 (!ext4_位图测试位(位图, 位号)) { 返回 位号 }
        位号 = 位号 + 1
    }
    返回 -1
}

函数 ext4_位图查找连续空闲(位图, 总位数, 需要数) {
    定义 可变 起始 = 0
    当 (起始 < 总位数) {
        如果 (ext4_位图测试位(位图, 起始)) { 起始 = 起始 + 1; 继续 }
        定义 可变 连续 = 0
        定义 可变 当前 = 起始
        当 (当前 < 总位数 && 连续 < 需要数) {
            如果 (ext4_位图测试位(位图, 当前)) { 跳出 }
            连续 = 连续 + 1
            当前 = 当前 + 1
        }
        如果 (连续 >= 需要数) { 返回 起始 }
        起始 = 当前 + 1
    }
    返回 -1
}

函数 ext4_分配块(sb, 目标组, 需要块数) {
    定义 信息 = sb.私有信息
    定义 总组数 = 信息.总组数
    定义 可变 组号 = 目标组
    定义 可变 已尝试 = 0

    当 (已尝试 < 总组数) {
        定义 位图块号 = ext4_获取块位图块(信息, 组号)
        定义 位图 = 块设备_读缓冲(sb.设备, 位图块号 * 信息.块大小, 信息.块大小)
        如果 (位图 == 空) { 组号 = (组号 + 1) % 总组数; 已尝试 = 已尝试 + 1; 继续 }

        定义 起始位 = ext4_位图查找连续空闲(位图, 信息.每组块数, 需要块数)
        如果 (起始位 >= 0) {
            定义 可变 i = 0
            当 (i < 需要块数) {
                ext4_位图设置位(位图, 起始位 + i)
                i = i + 1
            }
            块设备_写缓冲(sb.设备, 位图块号 * 信息.块大小, 信息.块大小, 位图)
            ext4_更新组描述符(信息, 组号, -需要块数)
            定义 结果块号 = 组号 * 信息.每组块数 + 起始位 + 信息.首数据块
            缓冲_释放(位图)
            块分配_总次数 = 块分配_总次数 + 1
            块分配_总块数 = 块分配_总块数 + 需要块数
            信息.空闲块数 = 信息.空闲块数 - 需要块数
            返回 结果块号
        }

        缓冲_释放(位图)
        组号 = (组号 + 1) % 总组数
        已尝试 = 已尝试 + 1
    }

    块分配_失败次数 = 块分配_失败次数 + 1
    返回 -1
}

函数 ext4_释放块(sb, 块号, 块数) {
    定义 信息 = sb.私有信息
    定义 组号 = (块号 - 信息.首数据块) / 信息.每组块数
    定义 组内偏移 = (块号 - 信息.首数据块) % 信息.每组块数
    定义 位图块号 = ext4_获取块位图块(信息, 组号)
    定义 位图 = 块设备_读缓冲(sb.设备, 位图块号 * 信息.块大小, 信息.块大小)
    如果 (位图 == 空) { 返回 错误_IO }

    定义 可变 i = 0
    当 (i < 块数) {
        ext4_位图清除位(位图, 组内偏移 + i)
        i = i + 1
    }

    块设备_写缓冲(sb.设备, 位图块号 * 信息.块大小, 信息.块大小, 位图)
    ext4_更新组描述符(信息, 组号, 块数)
    缓冲_释放(位图)
    ext4_更新释放统计(信息, 块数)
    返回 0
}

函数 ext4_更新组描述符(信息, 组号, 空闲变化) {
    定义 描述符偏移 = 信息.组描述符表块 * 信息.块大小 + 组号 * 32
    定义 当前空闲 = 内存_读16(信息.组描述符缓冲 + 描述符偏移 + 12)
    内存_写16(信息.组描述符缓冲 + 描述符偏移 + 12, 当前空闲 + 空闲变化)
}

函数 ext4_获取组空闲块统计(sb, 组号) {
    定义 信息 = sb.私有信息
    定义 位图块号 = ext4_获取块位图块(信息, 组号)
    定义 位图 = 块设备_读缓冲(sb.设备, 位图块号 * 信息.块大小, 信息.块大小)
    如果 (位图 == 空) { 返回 0 }

    定义 可变 空闲数 = 0
    定义 可变 位号 = 0
    当 (位号 < 信息.每组块数) {
        如果 (!ext4_位图测试位(位图, 位号)) { 空闲数 = 空闲数 + 1 }
        位号 = 位号 + 1
    }

    缓冲_释放(位图)
    返回 空闲数
}

函数 ext4_计算碎片率(sb, 组号) {
    定义 信息 = sb.私有信息
    定义 位图块号 = ext4_获取块位图块(信息, 组号)
    定义 位图 = 块设备_读缓冲(sb.设备, 位图块号 * 信息.块大小, 信息.块大小)
    如果 (位图 == 空) { 返回 0 }

    定义 可变 碎片段数 = 0
    定义 可变 在空闲段 = 假
    定义 可变 位号 = 0
    当 (位号 < 信息.每组块数) {
        定义 已用 = ext4_位图测试位(位图, 位号)
        如果 (!已用 && !在空闲段) { 碎片段数 = 碎片段数 + 1; 在空闲段 = 真 }
        如果 (已用) { 在空闲段 = 假 }
        位号 = 位号 + 1
    }

    缓冲_释放(位图)
    返回 碎片段数
}

函数 块分配_完整统计() {
    返回 [块分配_总次数, 块释放_总次数, 块分配_总块数, 块释放_总块数, 块分配_失败次数, 预分配_命中次数]
}

定义 可变 AI_扩展更新分_运行指标 = 0
定义 可变 AI_扩展更新分_异常指标 = 0

函数 AI_扩展更新分_自诊断() {
    AI_扩展更新分_运行指标 = 块分配_总次数
    返回 AI_扩展更新分_运行指标
}

函数 AI_扩展更新分_优化建议() {
    定义 指标 = AI_扩展更新分_自诊断()
    如果 (AI_扩展更新分_运行指标 > 10000) { 返回 "扩展更新分负载较高" }
    返回 "扩展更新分状态正常"
}

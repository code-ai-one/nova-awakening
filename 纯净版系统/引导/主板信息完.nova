导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")

定义 标签_结束 = 0
定义 标签_命令行 = 1
定义 标签_模块 = 3
定义 标签_内存信息 = 4
定义 标签_内存映射 = 6
定义 标签_帧缓冲 = 8
定义 标签_处理器表 = 14
定义 最大内存区 = 32
定义 最大模块 = 16

结构 内存区域 {
    基址,
    长度,
    类型,
}

结构 引导模块 {
    起始地址,
    结束地址,
    命令行哈希,
}

结构 帧缓冲信息 {
    地址,
    宽度,
    高度,
    深度,
    步长,
}

定义 可变 内存区表 = []
定义 可变 内存区数 = 0
定义 可变 总内存 = 0
定义 可变 可用内存 = 0
定义 可变 模块表 = []
定义 可变 模块数 = 0
定义 可变 帧缓冲 = 0
定义 可变 命令行哈希 = 0
定义 可变 处理器数 = 0

函数 多引导_解析(信息地址) {
    如果 (信息地址 == 0) { 返回 }
    定义 总大小 = 内存_读32(信息地址)
    定义 可变 偏移 = 8
    当 (偏移 < 总大小) {
        定义 标签类型 = 内存_读32(信息地址 + 偏移)
        定义 标签大小 = 内存_读32(信息地址 + 偏移 + 4)
        如果 (标签类型 == 标签_结束) { 跳出 }
        如果 (标签类型 == 标签_命令行) {
            命令行哈希 = 多引导_哈希字符串(信息地址 + 偏移 + 8)
        }
        如果 (标签类型 == 标签_内存映射) {
            多引导_解析内存映射(信息地址 + 偏移, 标签大小)
        }
        如果 (标签类型 == 标签_模块) {
            多引导_解析模块(信息地址 + 偏移)
        }
        如果 (标签类型 == 标签_帧缓冲) {
            多引导_解析帧缓冲(信息地址 + 偏移)
        }
        偏移 = 偏移 + ((标签大小 + 7) & ~7)
    }
}

函数 多引导_解析内存映射(标签地址, 标签大小) {
    定义 条目大小 = 内存_读32(标签地址 + 8)
    如果 (条目大小 == 0) { 条目大小 = 24 }
    定义 可变 偏移 = 16
    当 (偏移 < 标签大小 && 内存区数 < 最大内存区) {
        定义 区域 = 内存区域 {}
        区域.基址 = 内存_读64(标签地址 + 偏移)
        区域.长度 = 内存_读64(标签地址 + 偏移 + 8)
        区域.类型 = 内存_读32(标签地址 + 偏移 + 16)
        追加(内存区表, 区域)
        总内存 = 总内存 + 区域.长度
        如果 (区域.类型 == 1) { 可用内存 = 可用内存 + 区域.长度 }
        内存区数 = 内存区数 + 1
        偏移 = 偏移 + 条目大小
    }
}

函数 多引导_解析模块(标签地址) {
    如果 (模块数 >= 最大模块) { 返回 }
    定义 模块 = 引导模块 {}
    模块.起始地址 = 内存_读32(标签地址 + 8)
    模块.结束地址 = 内存_读32(标签地址 + 12)
    模块.命令行哈希 = 多引导_哈希字符串(标签地址 + 16)
    追加(模块表, 模块)
    模块数 = 模块数 + 1
}

函数 多引导_解析帧缓冲(标签地址) {
    帧缓冲 = 堆_分配(帧缓冲信息)
    帧缓冲.地址 = 内存_读64(标签地址 + 8)
    帧缓冲.宽度 = 内存_读32(标签地址 + 20)
    帧缓冲.高度 = 内存_读32(标签地址 + 24)
    帧缓冲.深度 = 内存_读8(标签地址 + 29)
    帧缓冲.步长 = 内存_读32(标签地址 + 16)
}

函数 多引导_哈希字符串(地址) {
    定义 可变 哈希 = 5381
    定义 可变 位 = 0
    当 (内存_读8(地址 + 位) != 0 && 位 < 256) {
        哈希 = 哈希 * 33 + 内存_读8(地址 + 位)
        位 = 位 + 1
    }
    返回 哈希 & 0x7FFFFFFF
}

函数 多引导_获取可用内存() { 返回 可用内存 }
函数 多引导_获取总内存() { 返回 总内存 }
函数 多引导_获取模块数() { 返回 模块数 }

函数 多引导_获取内存区(索引) {
    如果 (索引 >= 内存区数) { 返回 [0, 0, 0] }
    返回 [内存区表[索引].基址, 内存区表[索引].长度, 内存区表[索引].类型]
}

函数 多引导_获取模块(索引) {
    如果 (索引 >= 模块数) { 返回 [0, 0] }
    返回 [模块表[索引].起始地址, 模块表[索引].结束地址]
}

函数 多引导_获取帧缓冲() {
    如果 (帧缓冲 == 0) { 返回 [0, 0, 0, 0] }
    返回 [帧缓冲.地址, 帧缓冲.宽度, 帧缓冲.高度, 帧缓冲.深度]
}

函数 多引导_完整统计() {
    返回 [总内存, 可用内存, 内存区数, 模块数, 命令行哈希]
}

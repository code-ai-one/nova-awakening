// 32位位运算基础

// 32位右旋转
函数 sha256_右旋(值, 位数) {
    定义 右 = (值 / 幂(2, 位数)) % 幂(2, 32 - 位数)
    定义 左 = (值 * 幂(2, 32 - 位数)) % 幂(2, 32)
    返回 (右 + 左) % 幂(2, 32)
}

// 32位右移
函数 sha256_右移(值, 位数) {
    返回 (值 / 幂(2, 位数)) % 幂(2, 32 - 位数)
}

// 32位与
函数 sha256_与(a, b) {
    定义 可变 结果 = 0
    定义 可变 位 = 1
    定义 可变 i = 0
    当 (i < 32) {
        定义 a位 = (a / 位) % 2
        定义 b位 = (b / 位) % 2
        如果 (a位 == 1) {
            如果 (b位 == 1) {
                结果 = 结果 + 位
            }
        }
        位 = 位 * 2
        i = i + 1
    }
    返回 结果
}

// 32位或
函数 sha256_或(a, b) {
    定义 可变 结果 = 0
    定义 可变 位 = 1
    定义 可变 i = 0
    当 (i < 32) {
        定义 a位 = (a / 位) % 2
        定义 b位 = (b / 位) % 2
        如果 (a位 == 1) {
            结果 = 结果 + 位
        } 否则 {
            如果 (b位 == 1) {
                结果 = 结果 + 位
            }
        }
        位 = 位 * 2
        i = i + 1
    }
    返回 结果
}

// 32位异或
函数 sha256_异或(a, b) {
    定义 可变 结果 = 0
    定义 可变 位 = 1
    定义 可变 i = 0
    当 (i < 32) {
        定义 a位 = (a / 位) % 2
        定义 b位 = (b / 位) % 2
        如果 (a位 != b位) { 结果 = 结果 + 位 }
        位 = 位 * 2
        i = i + 1
    }
    返回 结果
}

// 32位取反
函数 sha256_取反(a) {
    定义 可变 结果 = 0
    定义 可变 位 = 1
    定义 可变 i = 0
    当 (i < 32) {
        定义 当前位 = (a / 位) % 2
        如果 (当前位 == 0) {
            结果 = 结果 + 位
        }
        位 = 位 * 2
        i = i + 1
    }
    返回 结果
}

// 32位模加
函数 sha256_加(a, b) {
    定义 和值 = a + b
    定义 模值 = 幂(2, 32)
    返回 和值 % 模值
}

// SHA-256 核心函数

函数 sha256_大S0(x) {
    定义 r2 = sha256_右旋(x, 2)
    定义 r13 = sha256_右旋(x, 13)
    定义 r22 = sha256_右旋(x, 22)
    定义 混合 = sha256_异或(r2, r13)
    返回 sha256_异或(混合, r22)
}

函数 sha256_大S1(x) {
    定义 r6 = sha256_右旋(x, 6)
    定义 r11 = sha256_右旋(x, 11)
    定义 r25 = sha256_右旋(x, 25)
    定义 混合 = sha256_异或(r6, r11)
    返回 sha256_异或(混合, r25)
}

函数 sha256_小s0(x) {
    定义 r7 = sha256_右旋(x, 7)
    定义 r18 = sha256_右旋(x, 18)
    定义 rs3 = sha256_右移(x, 3)
    定义 混合 = sha256_异或(r7, r18)
    返回 sha256_异或(混合, rs3)
}

函数 sha256_小s1(x) {
    定义 r17 = sha256_右旋(x, 17)
    定义 r19 = sha256_右旋(x, 19)
    定义 rs10 = sha256_右移(x, 10)
    定义 混合 = sha256_异或(r17, r19)
    返回 sha256_异或(混合, rs10)
}

函数 SHA256_选择(x, y, z) {
    定义 xy = sha256_与(x, y)
    定义 nx = sha256_取反(x)
    定义 nz = sha256_与(nx, z)
    返回 sha256_异或(xy, nz)
}

函数 SHA256_多数(x, y, z) {
    定义 xy = sha256_与(x, y)
    定义 xz = sha256_与(x, z)
    定义 yz = sha256_与(y, z)
    定义 混合 = sha256_异或(xy, xz)
    返回 sha256_异或(混合, yz)
}

// SHA-256 上下文管理

// 上下文: [H0..H7, 总字节数, 缓冲区]
函数 sha256_创建() {
    定义 可变 上下文 = []
    追加(上下文, 0x6a09e667)
    追加(上下文, 0xbb67ae85)
    追加(上下文, 0x3c6ef372)
    追加(上下文, 0xa54ff53a)
    追加(上下文, 0x510e527f)
    追加(上下文, 0x9b05688c)
    追加(上下文, 0x1f83d9ab)
    追加(上下文, 0x5be0cd19)
    追加(上下文, 0)
    追加(上下文, [])
    返回 上下文
}

// 处理一个512位块
函数 sha256_处理块(上下文, 块) {
    定义 可变 W = []
    定义 可变 t = 0
    当 (t < 16) {
        定义 w = 块[t * 4] * 16777216 + 块[t * 4 + 1] * 65536 + 块[t * 4 + 2] * 256 + 块[t * 4 + 3]
        追加(W, w)
        t = t + 1
    }
    当 (t < 64) {
        定义 s0 = sha256_小s0(W[t - 15])
        定义 s1 = sha256_小s1(W[t - 2])
        追加(W, sha256_加(sha256_加(W[t - 16], s0), sha256_加(W[t - 7], s1)))
        t = t + 1
    }
    定义 可变 a = 上下文[0]
    定义 可变 b = 上下文[1]
    定义 可变 c = 上下文[2]
    定义 可变 d = 上下文[3]
    定义 可变 e = 上下文[4]
    定义 可变 f = 上下文[5]
    定义 可变 g = 上下文[6]
    定义 可变 h = 上下文[7]
    t = 0
    当 (t < 64) {
        定义 T1 = sha256_加(sha256_加(sha256_加(sha256_加(h, sha256_大S1(e)), SHA256_选择(e, f, g)), sha256_获取K(t)), W[t])
        定义 T2 = sha256_加(sha256_大S0(a), SHA256_多数(a, b, c))
        h = g
        g = f
        f = e
        e = sha256_加(d, T1)
        d = c
        c = b
        b = a
        a = sha256_加(T1, T2)
        t = t + 1
    }
    上下文[0] = sha256_加(上下文[0], a)
    上下文[1] = sha256_加(上下文[1], b)
    上下文[2] = sha256_加(上下文[2], c)
    上下文[3] = sha256_加(上下文[3], d)
    上下文[4] = sha256_加(上下文[4], e)
    上下文[5] = sha256_加(上下文[5], f)
    上下文[6] = sha256_加(上下文[6], g)
    上下文[7] = sha256_加(上下文[7], h)
}

// 追加数据
函数 sha256_缓冲追加(上下文, 值) {
    定义 可变 缓冲 = 上下文[9]
    追加(缓冲, 值)
    如果 (计数(缓冲) == 64) {
        sha256_处理块(上下文, 缓冲)
        上下文[9] = []
    } 否则 {
        上下文[9] = 缓冲
    }
}

函数 sha256_更新(上下文, 数据) {
    定义 可变 i = 0
    当 (i < 字节长度(数据)) {
        sha256_缓冲追加(上下文, 字节取(数据, i))
        i = i + 1
    }
    上下文[8] = 上下文[8] + 字节长度(数据)
}

// 完成哈希, 返回32字节列表
函数 sha256_完成(上下文) {
    定义 可变 缓冲 = 上下文[9]
    定义 总位数 = 上下文[8] * 8
    追加(缓冲, 0x80)
    当 (计数(缓冲) % 64 != 56) {
        追加(缓冲, 0)
    }
    追加(缓冲, 0)
    追加(缓冲, 0)
    追加(缓冲, 0)
    追加(缓冲, 0)
    追加(缓冲, (总位数 / 16777216) % 256)
    追加(缓冲, (总位数 / 65536) % 256)
    追加(缓冲, (总位数 / 256) % 256)
    追加(缓冲, 总位数 % 256)
    定义 可变 偏移 = 0
    当 (偏移 < 计数(缓冲)) {
        定义 可变 块 = []
        定义 可变 j = 0
        当 (j < 64) {
            追加(块, 缓冲[偏移 + j])
            j = j + 1
        }
        sha256_处理块(上下文, 块)
        偏移 = 偏移 + 64
    }
    定义 可变 结果 = []
    定义 可变 k = 0
    当 (k < 8) {
        定义 h = 上下文[k]
        追加(结果, (h / 16777216) % 256)
        追加(结果, (h / 65536) % 256)
        追加(结果, (h / 256) % 256)
        追加(结果, h % 256)
        k = k + 1
    }
    返回 结果
}

// 便捷接口: 字符串 → 十六进制哈希
函数 sha256_哈希(消息) {
    定义 上下文 = sha256_创建()
    sha256_更新(上下文, 消息)
    定义 字节列表 = sha256_完成(上下文)
    定义 hex表 = "0123456789abcdef"
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(字节列表)) {
        定义 b = 字节列表[i]
        结果 = 字符串拼接(结果, 子串(hex表, b / 16, 1))
        结果 = 字符串拼接(结果, 子串(hex表, b % 16, 1))
        i = i + 1
    }
    返回 结果
}

// HMAC认证-SHA256
函数 SHA2_认证哈希(密钥, 消息) {
    定义 可变 内填充 = []
    定义 可变 外填充 = []
    定义 可变 ii = 0
    // 准备密钥字节
    定义 可变 key_bytes = []
    定义 可变 ki = 0
    当 (ki < 字节长度(密钥)) {
        追加(key_bytes, 字节取(密钥, ki))
        ki = ki + 1
    }
    // 密钥太长则哈希
    如果 (计数(key_bytes) > 64) {
        定义 kctx = sha256_创建()
        sha256_更新(kctx, 密钥)
        key_bytes = sha256_完成(kctx)
    }
    // 补齐到64字节
    当 (计数(key_bytes) < 64) {
        追加(key_bytes, 0)
    }
    // 构建 内填充 和 外填充
    定义 可变 pi = 0
    当 (pi < 64) {
        追加(内填充, sha256_异或(key_bytes[pi], 0x36))
        追加(外填充, sha256_异或(key_bytes[pi], 0x5c))
        pi = pi + 1
    }
    // 内层: SHA256(内填充 || message)
    定义 内ctx = sha256_创建()
    当 (ii < 64) {
        sha256_缓冲追加(内ctx, 内填充[ii])
        ii = ii + 1
    }
    内ctx[8] = 64
    sha256_更新(内ctx, 消息)
    定义 内哈希 = sha256_完成(内ctx)
    // 外层: SHA256(外填充 || inner_hash)
    定义 外ctx = sha256_创建()
    定义 可变 oi = 0
    当 (oi < 64) {
        sha256_缓冲追加(外ctx, 外填充[oi])
        oi = oi + 1
    }
    外ctx[8] = 64
    定义 可变 hi = 0
    当 (hi < 计数(内哈希)) {
        sha256_缓冲追加(外ctx, 内哈希[hi])
        hi = hi + 1
    }
    外ctx[8] = 外ctx[8] + 32
    返回 sha256_完成(外ctx)
}

定义 可变 _sha_哈希次数 = 0
定义 可变 _sha_总字节 = 0
定义 可变 _sha_最大输入 = 0

函数 sha256_记录(输入长度) {
    _sha_哈希次数 = _sha_哈希次数 + 1
    _sha_总字节 = _sha_总字节 + 输入长度
    如果 (输入长度 > _sha_最大输入) { _sha_最大输入 = 输入长度 }
}

函数 sha256_平均输入() {
    如果 (_sha_哈希次数 == 0) {
        返回 0
    }
    返回 _sha_总字节 / _sha_哈希次数
}

函数 sha256_性能评估() {
    如果 (_sha_哈希次数 == 0) {
        返回 "无哈希记录"
    }
    定义 平均 = sha256_平均输入()
    如果 (平均 > 10000) {
        返回 "大数据哈希: 考虑分块流式处理"
    }
    如果 (平均 > 1000) {
        返回 "中等数据哈希"
    }
    返回 "小数据哈希(高效)"
}

函数 sha256_碰撞风险() {
    如果 (_sha_哈希次数 < 1000) {
        返回 "极低(SHA256碰撞概率可忽略)"
    }
    如果 (_sha_哈希次数 < 1000000) {
        返回 "低"
    }
    返回 "理论安全(2^128碰撞阻力)"
}

函数 sha256_吞吐评估() {
    如果 (_sha_哈希次数 == 0) {
        返回 "无数据"
    }
    如果 (_sha_总字节 > 10000000) {
        返回 "高吞吐(已处理>10MB)"
    }
    如果 (_sha_总字节 > 1000000) {
        返回 "中等吞吐(>1MB)"
    }
    返回 "低吞吐"
}

函数 sha256_安全等级() {
    返回 "SHA-256: 256位摘要,128位碰撞阻力,推荐用于一般安全场景"
}

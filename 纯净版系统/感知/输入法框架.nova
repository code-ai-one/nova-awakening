// NovaOS · 输入法框架 (IME Framework)
// §1 输入法引擎注册 (拼音/五笔/笔画/语音)
// §2 候选词管理
// §3 提交与预编辑
// §4 输入上下文 (每个窗口独立)
// §5 热键切换


定义 IME_拼音 = 0
定义 IME_五笔 = 1
定义 IME_笔画 = 2
定义 IME_英文 = 3
定义 IME_手写 = 4
定义 IME_语音 = 5

结构 输入法引擎 {
    ID,             // u32 IME_*
    名称,
    已启用,
    优先级,
}

定义 可变 _已注册引擎 = []
定义 可变 _当前引擎 = IME_拼音
定义 可变 _IME已初始化 = 假

函数 IME_初始化() {
    如果 (_IME已初始化) { 返回 }
    _已注册引擎 = []
    IME_注册引擎(IME_拼音, "Nova拼音", 真, 10)
    IME_注册引擎(IME_五笔, "Nova五笔", 真, 5)
    IME_注册引擎(IME_英文, "英文直入", 真, 20)
    IME_注册引擎(IME_笔画, "笔画输入", 假, 1)
    _当前引擎 = IME_拼音
    _IME已初始化 = 真
    内核信息("输入法框架: 已初始化, 默认拼音")
}

函数 IME_注册引擎(ID, 名称, 启用, 优先级) {
    定义 引擎 = 输入法引擎 {}
    引擎.ID = ID
    引擎.名称 = 名称
    引擎.已启用 = 启用
    引擎.优先级 = 优先级
    追加(_已注册引擎, 引擎)
}


结构 输入上下文 {
    窗口ID,
    引擎ID,
    预编辑,         // 字符串 (用户正在输入的拼音/编码)
    候选列表,       // 列表
    候选页码,
    每页数,
    选中索引,
    已提交文本,
}

定义 可变 _活跃上下文 = []
定义 可变 _上下文序号 = 0
定义 IME_每页候选 = 9

函数 IME_创建上下文(窗口ID) {
    _上下文序号 = _上下文序号 + 1
    定义 ctx = 输入上下文 {}
    ctx.窗口ID = 窗口ID
    ctx.引擎ID = _当前引擎
    ctx.预编辑 = ""
    ctx.候选列表 = []
    ctx.候选页码 = 0
    ctx.每页数 = IME_每页候选
    ctx.选中索引 = 0
    ctx.已提交文本 = ""
    追加(_活跃上下文, ctx)
    返回 _上下文序号
}

函数 IME_获取上下文(窗口ID) {
    定义 可变 i = 0
    当 (i < 计数(_活跃上下文)) {
        如果 (_活跃上下文[i].窗口ID == 窗口ID) { 返回 i }
        i = i + 1
    }
    返回 -1
}


函数 IME_按键输入(窗口ID, 键码) {
    定义 idx = IME_获取上下文(窗口ID)
    如果 (idx < 0) { 返回 "" }
    定义 ctx = _活跃上下文[idx]

    // 英文模式: 直接返回字符
    如果 (ctx.引擎ID == IME_英文) {
        返回 字符从码(键码)
    }

    // 数字键1-9: 选择候选词
    如果 (键码 >= 49 && 键码 <= 57 && 计数(ctx.候选列表) > 0) {
        定义 选择 = 键码 - 49 + ctx.候选页码 * ctx.每页数
        如果 (选择 < 计数(ctx.候选列表)) {
            定义 词 = ctx.候选列表[选择]
            _活跃上下文[idx].预编辑 = ""
            _活跃上下文[idx].候选列表 = []
            _活跃上下文[idx].候选页码 = 0
            _活跃上下文[idx].已提交文本 = 词
            返回 词
        }
    }

    // 空格: 选择第一个候选
    如果 (键码 == 32 && 计数(ctx.候选列表) > 0) {
        定义 词 = ctx.候选列表[ctx.候选页码 * ctx.每页数]
        _活跃上下文[idx].预编辑 = ""
        _活跃上下文[idx].候选列表 = []
        _活跃上下文[idx].候选页码 = 0
        _活跃上下文[idx].已提交文本 = 词
        返回 词
    }

    // 退格: 删除预编辑最后一个字符
    如果 (键码 == 8) {
        如果 (字串_长度(ctx.预编辑) > 0) {
            _活跃上下文[idx].预编辑 = 字串_子串(ctx.预编辑, 0, 字串_长度(ctx.预编辑) - 1)
            _活跃上下文[idx].候选列表 = IME_查询候选(_活跃上下文[idx].预编辑, ctx.引擎ID)
        }
        返回 ""
    }

    // Escape: 清空预编辑
    如果 (键码 == 27) {
        _活跃上下文[idx].预编辑 = ""
        _活跃上下文[idx].候选列表 = []
        返回 ""
    }

    // 翻页: Page Down / Page Up
    如果 (键码 == 34) { _活跃上下文[idx].候选页码 = ctx.候选页码 + 1; 返回 "" }
    如果 (键码 == 33 && ctx.候选页码 > 0) { _活跃上下文[idx].候选页码 = ctx.候选页码 - 1; 返回 "" }

    // 字母键: 追加到预编辑
    如果 (键码 >= 97 && 键码 <= 122) {
        _活跃上下文[idx].预编辑 = ctx.预编辑 + 字符从码(键码)
        _活跃上下文[idx].候选列表 = IME_查询候选(_活跃上下文[idx].预编辑, ctx.引擎ID)
        返回 ""
    }

    返回 ""
}


函数 IME_查询候选(编码, 引擎ID) {
    // 拼音引擎: 简化的候选词表(实际应接入词库)
    如果 (引擎ID == IME_拼音) { 返回 IME_拼音查询(编码) }
    如果 (引擎ID == IME_五笔) { 返回 IME_五笔查询(编码) }
    返回 []
}

函数 IME_拼音查询(拼音) {
    // 内置基础词表(实际运行时从磁盘加载大词库)
    如果 (拼音 == "a")    { 返回 ["啊", "阿", "吖", "嗄", "腌", "锕"] }
    如果 (拼音 == "ai")   { 返回 ["爱", "哎", "唉", "矮", "碍", "艾", "癌", "挨"] }
    如果 (拼音 == "an")   { 返回 ["安", "暗", "按", "岸", "案", "鞍"] }
    如果 (拼音 == "ba")   { 返回 ["把", "吧", "八", "爸", "拔", "巴"] }
    如果 (拼音 == "bai")  { 返回 ["百", "白", "拜", "败", "摆", "柏"] }
    如果 (拼音 == "bei")  { 返回 ["被", "北", "背", "杯", "备", "倍"] }
    如果 (拼音 == "bu")   { 返回 ["不", "步", "布", "部", "补", "捕"] }
    如果 (拼音 == "da")   { 返回 ["大", "打", "达", "答", "搭", "瘩"] }
    如果 (拼音 == "de")   { 返回 ["的", "得", "德", "地"] }
    如果 (拼音 == "di")   { 返回 ["地", "第", "低", "底", "的", "敌"] }
    如果 (拼音 == "dui")  { 返回 ["对", "队", "堆", "兑", "碓"] }
    如果 (拼音 == "ge")   { 返回 ["个", "各", "格", "歌", "隔", "革"] }
    如果 (拼音 == "guo")  { 返回 ["国", "过", "果", "锅", "裹", "郭"] }
    如果 (拼音 == "he")   { 返回 ["和", "河", "合", "何", "喝", "贺"] }
    如果 (拼音 == "hao")  { 返回 ["好", "号", "豪", "毫", "浩", "耗"] }
    如果 (拼音 == "ji")   { 返回 ["几", "机", "基", "极", "及", "集"] }
    如果 (拼音 == "jiu")  { 返回 ["就", "九", "久", "酒", "旧", "救"] }
    如果 (拼音 == "le")   { 返回 ["了", "乐", "勒"] }
    如果 (拼音 == "ma")   { 返回 ["吗", "妈", "马", "麻", "骂", "码"] }
    如果 (拼音 == "na")   { 返回 ["那", "拿", "哪", "呐", "纳", "娜"] }
    如果 (拼音 == "ni")   { 返回 ["你", "泥", "逆", "匿", "拟", "腻"] }
    如果 (拼音 == "ren")  { 返回 ["人", "认", "任", "仁", "忍", "刃"] }
    如果 (拼音 == "shi")  { 返回 ["是", "十", "时", "事", "世", "使", "市", "师"] }
    如果 (拼音 == "ta")   { 返回 ["他", "她", "它", "塔", "踏", "拓"] }
    如果 (拼音 == "wo")   { 返回 ["我", "握", "窝", "沃", "卧", "蜗"] }
    如果 (拼音 == "xi")   { 返回 ["系", "西", "习", "喜", "细", "洗"] }
    如果 (拼音 == "xin")  { 返回 ["新", "心", "信", "星", "欣", "辛"] }
    如果 (拼音 == "you")  { 返回 ["有", "又", "由", "油", "右", "友"] }
    如果 (拼音 == "zai")  { 返回 ["在", "再", "载", "灾", "宰", "栽"] }
    如果 (拼音 == "zhe")  { 返回 ["这", "着", "者", "折", "遮", "哲"] }
    如果 (拼音 == "zhong") { 返回 ["中", "种", "重", "众", "钟", "终"] }
    如果 (拼音 == "zi")   { 返回 ["子", "自", "字", "紫", "资", "仔"] }
    返回 []
}

函数 IME_五笔查询(编码) {
    // 五笔简码(实际需完整码表)
    如果 (编码 == "g")   { 返回 ["一", "王"] }
    如果 (编码 == "f")   { 返回 ["地", "土"] }
    如果 (编码 == "d")   { 返回 ["大", "在"] }
    如果 (编码 == "s")   { 返回 ["要", "木"] }
    如果 (编码 == "a")   { 返回 ["工", "式"] }
    如果 (编码 == "h")   { 返回 ["上", "目"] }
    如果 (编码 == "j")   { 返回 ["是", "日"] }
    如果 (编码 == "k")   { 返回 ["中", "口"] }
    如果 (编码 == "l")   { 返回 ["国", "田"] }
    如果 (编码 == "q")   { 返回 ["我", "金"] }
    如果 (编码 == "w")   { 返回 ["人", "八"] }
    如果 (编码 == "e")   { 返回 ["有", "月"] }
    如果 (编码 == "r")   { 返回 ["的", "白"] }
    如果 (编码 == "t")   { 返回 ["和", "禾"] }
    如果 (编码 == "y")   { 返回 ["主", "言"] }
    返回 []
}


函数 IME_切换引擎() {
    // Ctrl+Space 或 Shift 切换
    定义 可变 当前索引 = -1
    定义 可变 i = 0
    当 (i < 计数(_已注册引擎)) {
        如果 (_已注册引擎[i].ID == _当前引擎) { 当前索引 = i }
        i = i + 1
    }
    // 找下一个已启用的引擎
    定义 可变 下一个 = (当前索引 + 1) % 计数(_已注册引擎)
    定义 可变 尝试 = 0
    当 (尝试 < 计数(_已注册引擎)) {
        如果 (_已注册引擎[下一个].已启用) {
            _当前引擎 = _已注册引擎[下一个].ID
            内核信息("输入法切换: " + _已注册引擎[下一个].名称)
            返回 _当前引擎
        }
        下一个 = (下一个 + 1) % 计数(_已注册引擎)
        尝试 = 尝试 + 1
    }
    返回 _当前引擎
}

函数 IME_设引擎(引擎ID) { _当前引擎 = 引擎ID }
函数 IME_当前引擎() { 返回 _当前引擎 }

函数 IME_引擎名(ID) {
    定义 可变 i = 0
    当 (i < 计数(_已注册引擎)) {
        如果 (_已注册引擎[i].ID == ID) { 返回 _已注册引擎[i].名称 }
        i = i + 1
    }
    返回 "未知"
}

函数 IME_报告() {
    定义 可变 r = "═══ 输入法框架 ═══\n"
    r = r + "当前引擎: " + IME_引擎名(_当前引擎) + "\n"
    r = r + "已注册: " + 整数转字符串(计数(_已注册引擎)) + "\n"
    r = r + "活跃上下文: " + 整数转字符串(计数(_活跃上下文)) + "\n"
    定义 可变 i = 0
    当 (i < 计数(_已注册引擎)) {
        定义 状态 = "禁用"
        如果 (_已注册引擎[i].已启用) { 状态 = "启用" }
        如果 (_已注册引擎[i].ID == _当前引擎) { 状态 = "活跃" }
        r = r + "  " + _已注册引擎[i].名称 + " [" + 状态 + "]\n"
        i = i + 1
    }
    返回 r
}

// NovaOS平台适配层: 内存管理
// 浏览器的内存分配全部通过此层:
//   - 分区分配思路 (
// - Nova的Zone/Heap分配
// - Skia的SkMemory
// 全部统一走NovaOS内核的内存管理Nova系统调用
// NovaOS直连优势: 无需通过glibc/libc,直接Nova系统调用,零开销

// §1 NovaOS内核内存Nova系统调用接口
// 对应Nova的Nova内存映射/munmap/brk,但NovaOS有专用快速路径

// NovaOS内核Nova系统调用号 (与内核定义一致)

定义 Nova系统调用_内存_分配页 = 200 // 分配物理页(类似Nova内存映射)
定义 Nova系统调用_内存_释放页 = 201 // 释放物理页(类似munmap)
定义 Nova系统调用_内存_调整堆 = 202 // 调整堆顶(类似brk/sbrk)
定义 Nova系统调用_内存_共享映射 = 203 // 共享内存映射(图处缓冲区等)
定义 Nova系统调用_内存_查询 = 204 // 查询内存使用情况

// 页大小
定义 页大小 = 4096 // 4KB
定义 大页大小 = 2097152 // 2MB大页

// 内存保护标志
定义 内存_可读 = 0x01
定义 内存_可写 = 0x02
定义 内存_可执行 = 0x04

函数 内核_分配页(页数, 保护标志) {
 // NovaOS Nova系统调用: 分配连续物理页
 // 返回: 虚拟地址 (0=失败)
 返回 系统调用(Nova系统调用_内存_分配页, 页数, 保护标志, 0, 0, 0)
}

函数 内核_释放页(地址, 页数) {
 返回 系统调用(Nova系统调用_内存_释放页, 地址, 页数, 0, 0, 0)
}

函数 内核_调整堆(增量) {
 返回 系统调用(Nova系统调用_内存_调整堆, 增量, 0, 0, 0, 0)
}

函数 内核_共享映射(大小, 标志) {
 返回 系统调用(Nova系统调用_内存_共享映射, 大小, 标志, 0, 0, 0)
}

// §2 PartitionAlloc替代 — 浏览器专用分配器
// (对应 
// PartitionAlloc是Nova浏览器的核心分配器,特点:
// - 按大小分桶(size class)
// - 每个桶有独立的SuperPage
// - 防止use-after-free (隔离分区)
// - O(1)分配/释放
// Nova版保持核心分桶思想和隔离分区设计

// 与PartitionAlloc一致的分桶策略
定义 桶数量 = 24
// 桶大小: 8 16 32 48 64 80 96 112 128 160 192 224 256
// 320 384 448 512 640 768 896 1024 1536 2048 4096

结构 空闲块 {
 下一个,    // u64 空闲链表
}

结构 分配桶 {
 大小,    // u32 此桶的块大小
 空闲链表头,    // u64 空闲块*
 当前页,    // u64 当前分配页
 当前页偏移,    // u32 页内分配位置
 总分配数,
 总释放数,
 活跃块数,
}

结构 分区分配器 {
 桶列表,    // u64 分配桶*数组 [桶数量]
 大块列表,    // u64 超过4096字节的分配(直接页分配)
 大块数量,
 // 统计
 总分配字节,
 总释放字节,
 峰值使用,
 当前使用,
}

// 全局分配器实例
定义 可变 全局分配器 = 0

函数 分配器_初始化() {
 如果 (全局分配器 != 0) { 返回 }

 定义 大小 = 页大小 * 4 // 分配器元数据用4页
 全局分配器 = 内核_分配页(4, 内存_可读 | 内存_可写)
 如果 (全局分配器 == 0) { 返回 }

 // 初始化桶
 定义 桶列表 = 全局分配器 + 256 // 留256字节给分配器头
 内存_写64(全局分配器, 桶列表) // 桶列表指针

 定义 桶大小表 = [8, 16, 32, 48, 64, 80, 96, 112, 128, 160, 192, 224, 256, 320, 384, 448, 512, 640, 768, 896, 1024, 1536, 2048, 4096]

 定义 可变 i = 0
 当 (i < 桶数量) {
 定义 桶偏移 = 桶列表 + i * 48
 内存_写32(桶偏移, 桶大小表[i]) // 大小
 内存_写64(桶偏移 + 8, 0) // 空闲链表头
 内存_写64(桶偏移 + 16, 0) // 当前页
 内存_写32(桶偏移 + 24, 0) // 当前页偏移
 内存_写32(桶偏移 + 28, 0) // 总分配数
 内存_写32(桶偏移 + 32, 0) // 总释放数
 内存_写32(桶偏移 + 36, 0) // 活跃块数
 i = i + 1
 }

 // 统计清零
 内存_写64(全局分配器 + 64, 0) // 总分配字节
 内存_写64(全局分配器 + 72, 0) // 总释放字节
 内存_写64(全局分配器 + 80, 0) // 峰值
 内存_写64(全局分配器 + 88, 0) // 当前
}

函数 分配器_查找桶(大小) {
 // 找到 >= 大小 的最小桶
 定义 桶列表 = 内存_读64(全局分配器)
 定义 可变 i = 0
 当 (i < 桶数量) {
 定义 桶大小 = 内存_读32(桶列表 + i * 48)
 如果 (桶大小 >= 大小) {
 返回 桶列表 + i * 48
 }
 i = i + 1
 }
 返回 0 // 超过最大桶 → 大块分配
}

导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("./键盘.nova")
导入("../引导/端口输入.nova")

//   1. PS/2鼠标通过8042控制器端口2通信(IRQ12)
//   2. 标准3字节数据包: [按钮+符号位, X移动, Y移动]
//   3. IntelliMouse: 4字节(额外滚轮), 5按钮扩展
//   4. 数据包状态机: 逐字节接收, 3/4字节完整后处理
//   5. 分辨率/采样率可配置

定义 PS2_数据端口 = 0x60
定义 PS2_命令端口 = 0x64

定义 MOUSE_CMD_复位       = 0xFF
定义 MOUSE_CMD_使能       = 0xF4
定义 MOUSE_CMD_禁用       = 0xF5
定义 MOUSE_CMD_设置采样率 = 0xF3
定义 MOUSE_CMD_设置分辨率 = 0xE8
定义 MOUSE_CMD_获取ID     = 0xF2

定义 MOUSE_BTN_LEFT   = 0x01
定义 MOUSE_BTN_RIGHT  = 0x02
定义 MOUSE_BTN_MIDDLE = 0x04

定义 可变 鼠标X = 0
定义 可变 鼠标Y = 0
定义 可变 鼠标按钮 = 0
定义 可变 鼠标滚轮 = 0
定义 可变 鼠标_字节索引 = 0     // 当前接收到第几个字节
定义 可变 鼠标_数据包 = [0, 0, 0, 0]  // 最多4字节(IntelliMouse)
定义 可变 鼠标_包大小 = 3       // 3=标准, 4=IntelliMouse
定义 可变 鼠标_中断计数 = 0
定义 可变 鼠标_已初始化 = 假

定义 可变 屏幕宽度 = 1024
定义 可变 屏幕高度 = 768

// 初始化 

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 鼠标_初始化() {
    // 1. 启用8042控制器端口2(鼠标)
    ps2_发命令(0xA8)   // Enable auxiliary port

    // 2. 启用鼠标中断(读配置→设bit1→写回)
    ps2_发命令(0x20)
    定义 配置 = ps2_等待读数据()
    ps2_发命令(0x60)
    ps2_写数据(配置 | 0x02)   // bit1=端口2中断使能

    // 3. 复位鼠标
    鼠标_发命令(MOUSE_CMD_复位)
    // 等待ACK(0xFA) + 自检通过(0xAA) + 设备ID(0x00)

    // 4. 尝试启用IntelliMouse(滚轮支持)
    // 魔法序列: 采样率200→100→80, 然后获取ID
    鼠标_发命令(MOUSE_CMD_设置采样率)
    鼠标_发命令(200)
    鼠标_发命令(MOUSE_CMD_设置采样率)
    鼠标_发命令(100)
    鼠标_发命令(MOUSE_CMD_设置采样率)
    鼠标_发命令(80)
    鼠标_发命令(MOUSE_CMD_获取ID)
    定义 id = ps2_等待读数据()
    如果 (id == 3) {
        鼠标_包大小 = 4   // IntelliMouse: 4字节包
        内核信息("PS/2鼠标: IntelliMouse(滚轮)")
    } 否则 {
        鼠标_包大小 = 3   // 标准: 3字节包
        内核信息("PS/2鼠标: 标准(无滚轮)")
    }

    // 5. 设置采样率100Hz, 分辨率8count/mm
    鼠标_发命令(MOUSE_CMD_设置采样率)
    鼠标_发命令(100)
    鼠标_发命令(MOUSE_CMD_设置分辨率)
    鼠标_发命令(2)   // 0=1, 1=2, 2=4, 3=8 count/mm

    // 6. 使能数据报告
    鼠标_发命令(MOUSE_CMD_使能)

    鼠标_字节索引 = 0
    鼠标_已初始化 = 真
    内核信息("PS/2鼠标: 初始化完成 (IRQ12)")
    返回 成功
}

// IRQ12中断处理 

函数 鼠标_中断处理(IRQ号) {
    定义 数据 = 端口读8(PS2_数据端口)
    鼠标_中断计数 = 鼠标_中断计数 + 1

    // 收集字节到数据包
    设置(鼠标_数据包, 鼠标_字节索引, 数据)
    鼠标_字节索引 = 鼠标_字节索引 + 1

    // 第一个字节验证: bit3必须为1(PS/2协议规定)
    如果 (鼠标_字节索引 == 1 && (数据 & 0x08) == 0) {
        鼠标_字节索引 = 0   // 同步失败, 丢弃
        返回
    }

    // 数据包未满
    如果 (鼠标_字节索引 < 鼠标_包大小) { 返回 }

    鼠标_字节索引 = 0

    定义 状态 = 鼠标_数据包[0]
    定义 可变 dx = 鼠标_数据包[1]
    定义 可变 dy = 鼠标_数据包[2]

    // 符号扩展 (bit4=X符号, bit5=Y符号)
    如果 ((状态 & 0x10) != 0) { dx = dx - 256 }    // X负方向
    如果 ((状态 & 0x20) != 0) { dy = dy - 256 }    // Y负方向

    // 溢出检测 (bit6=X溢出, bit7=Y溢出)
    如果 ((状态 & 0xC0) != 0) { 返回 }  // 溢出数据不可靠, 丢弃

    // 按钮状态
    鼠标按钮 = 状态 & 0x07   // bit0=左, bit1=右, bit2=中

    // 更新位置 (注: PS/2的Y轴是反的, 向上为正)
    鼠标X = 鼠标X + dx
    鼠标Y = 鼠标Y - dy   // 屏幕坐标: 向下为正

    // 限制在屏幕范围内
    如果 (鼠标X < 0) { 鼠标X = 0 }
    如果 (鼠标Y < 0) { 鼠标Y = 0 }
    如果 (鼠标X >= 屏幕宽度) { 鼠标X = 屏幕宽度 - 1 }
    如果 (鼠标Y >= 屏幕高度) { 鼠标Y = 屏幕高度 - 1 }

    // IntelliMouse: 第4字节=滚轮
    如果 (鼠标_包大小 == 4) {
        定义 可变 dz = 鼠标_数据包[3]
        如果 (dz > 127) { dz = dz - 256 }  // 符号扩展
        鼠标滚轮 = 鼠标滚轮 + dz
    }

    // 发送输入事件到输入子系统(帧缓冲/终端可订阅)
    鼠标事件_通知(鼠标X, 鼠标Y, 鼠标按键, 鼠标滚轮)
}

// 鼠标命令发送 (通过8042端口2)

函数 鼠标_发命令(命令) {
    // 0xD4: 告诉8042下一个写入发给端口2(鼠标)
    ps2_发命令(0xD4)
    ps2_写数据(命令)
    // 等待ACK (0xFA)
}

函数 ps2_发命令_鼠标(命令) {
    定义 可变 超时 = 100000
    当 (超时 > 0 && (端口读8(PS2_命令端口) & 0x02) != 0) { 超时 = 超时 - 1 }
    端口写8(PS2_命令端口, 命令)
}

函数 ps2_写数据_鼠标(数据) {
    定义 可变 超时 = 100000
    当 (超时 > 0 && (端口读8(PS2_命令端口) & 0x02) != 0) { 超时 = 超时 - 1 }
    端口写8(PS2_数据端口, 数据)
}

函数 ps2_等待读数据_鼠标() {
    定义 可变 超时 = 100000
    当 (超时 > 0 && (端口读8(PS2_命令端口) & 0x01) == 0) { 超时 = 超时 - 1 }
    返回 端口读8(PS2_数据端口)
}

// 查询

函数 鼠标_获取位置()  { 返回 [鼠标X, 鼠标Y] }
函数 鼠标_获取按钮()  { 返回 鼠标按钮 }
函数 鼠标_获取滚轮()  { 返回 鼠标滚轮 }
函数 鼠标_左键按下()  { 返回 (鼠标按钮 & MOUSE_BTN_LEFT) != 0 }
函数 鼠标_右键按下()  { 返回 (鼠标按钮 & MOUSE_BTN_RIGHT) != 0 }
函数 鼠标_中键按下()  { 返回 (鼠标按钮 & MOUSE_BTN_MIDDLE) != 0 }
函数 鼠标_设置屏幕大小(宽, 高) { 屏幕宽度 = 宽; 屏幕高度 = 高 }

定义 可变 鼠标事件_回调列表 = []

函数 鼠标事件_注册回调(回调) { 追加(鼠标事件_回调列表, 回调) }

函数 鼠标事件_通知(x, y, 按键, 滚轮) {
    定义 可变 i = 0
    当 (i < 计数(鼠标事件_回调列表)) {
        鼠标事件_回调列表[i](x, y, 按键, 滚轮)
        i = i + 1
    }
}

// 按钮名 + 完整统计

函数 鼠标_按钮名(按钮) {
    如果 ((按钮 & MOUSE_BTN_LEFT) != 0) { 返回 "left" }
    如果 ((按钮 & MOUSE_BTN_RIGHT) != 0) { 返回 "right" }
    如果 ((按钮 & MOUSE_BTN_MIDDLE) != 0) { 返回 "middle" }
    返回 "none"
}

函数 鼠标_完整统计() {
    返回 [鼠标X, 鼠标Y, 鼠标按钮, 鼠标滚轮, 鼠标中断计数]
}

定义 可变 AI_鼠标_风暴阈值 = 10000
定义 可变 AI_鼠标_预测IRQ = 0

函数 AI_鼠标_风暴检测(触发频率) {
    如果 (触发频率 > AI_鼠标_风暴阈值) {
        AI_鼠标_风暴阈值 = AI_鼠标_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_鼠标_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

函数 exp_approx(x) {
    定义 x2 = x * x
    定义 x3 = x2 * x
    定义 x4 = x3 * x
    返回 1.0 + x + x2 / 2.0 + x3 / 6.0 + x4 / 24.0
}

函数 sigmoid(x) {
    返回 1.0 / (1.0 + exp_approx(0.0 - x))
}

函数 主程序() {
    // sigmoid(2) 期望 > 0.8
    定义 s2 = sigmoid(2.0)
    打印(字符串拼接("sigmoid(2) bits=", 转字符串(s2)))
    // exp_approx(-2) = 1 - 2 + 2 - 1.333 + 0.667 = 0.333
    // sigmoid(2) = 1/1.333 = 0.75 — 算法本身就 <0.8
    
    // softmax(1,0) 和应为 1
    定义 m = 1.0
    定义 ea = exp_approx(1.0 - m)
    定义 eb = exp_approx(0.0 - m)
    定义 s = ea + eb
    定义 r0 = ea / s
    定义 r1 = eb / s
    定义 和 = r0 + r1
    打印(字符串拼接("softmax 和 bits=", 转字符串(和)))
    // 期望 bits 1.0 = 4607182418800017408
    返回 0
}

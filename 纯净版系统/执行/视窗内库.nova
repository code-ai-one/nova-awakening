函数 win32_MessageBoxW(hwnd, text, caption, type) {
    内核信息("Win32 MessageBox: [对话框]")
    返回 1   // IDOK
}
函数 win32_MessageBoxA(hwnd, text, caption, type) { 返回 win32_MessageBoxW(hwnd, text, caption, type) }

函数 win32_RtlInitUnicodeString(dest, src) {
    // UNICODE_STRING初始化: Length + MaxLength + Buffer指针
    Win32_接口调用数 = Win32_接口调用数 + 1
    返回 0
}

函数 win32_NtQueryInformationProcess(handle, info_class, info, info_len, ret_len) {
    // 返回进程信息: PID/基址址/命令行
    Win32_接口调用数 = Win32_接口调用数 + 1
    返回 0  // STATUS_SUCCESS
}

定义 可变 _win32_窗口表 = []    // [[句柄, 类名, 标题, x, y, 宽, 高, 可见], ...]
定义 可变 _win32_消息队列 = []  // [[窗口, 消息, wParam, lParam], ...]
定义 可变 _win32_下一句柄 = 0x10000
定义 可变 _win32_程序运行 = 真

函数 win32_CreateWindowExW(dwExStyle, lpClassName, lpWindowName, dwStyle, x, y, nWidth, nHeight, hWndParent, hMenu, hInstance, lpParam) {
    定义 hwnd = _win32_下一句柄
    _win32_下一句柄 = _win32_下一句柄 + 1
    追加(_win32_窗口表, [hwnd, lpClassName, lpWindowName, x, y, nWidth, nHeight, 假])
    内核调试("Win32: CreateWindowExW '" + lpWindowName + "' hwnd=0x" + 整数转十六进制(hwnd))
    Win32_接口调用数 = Win32_接口调用数 + 1
    返回 hwnd
}

函数 win32_ShowWindow(hwnd, nCmdShow) {
    // 查找窗口并设置可见性
    定义 可变 i = 0
    当 (i < 计数(_win32_窗口表)) {
        如果 (_win32_窗口表[i][0] == hwnd) {
            _win32_窗口表[i][7] = (nCmdShow != 0)  // SW_HIDE=0
            内核调试("Win32: ShowWindow hwnd=0x" + 整数转十六进制(hwnd) + " show=" + 整数转字符串(nCmdShow))
            i = 计数(_win32_窗口表)
        }
        i = i + 1
    }
    Win32_接口调用数 = Win32_接口调用数 + 1
    返回 1
}

函数 win32_GetMessageW(lpMsg, hwnd, wMsgFilterMin, wMsgFilterMax) {
    // 从消息队列取消息, WM_QUIT时返回0
    如果 (!_win32_程序运行) { 返回 0 }  // WM_QUIT
    如果 (计数(_win32_消息队列) > 0) {
        定义 msg = _win32_消息队列[0]
        // 移除队列头
        定义 可变 新队列 = []
        定义 可变 j = 1
        当 (j < 计数(_win32_消息队列)) { 追加(新队列, _win32_消息队列[j]); j = j + 1 }
        _win32_消息队列 = 新队列
        返回 1
    }
    Win32_接口调用数 = Win32_接口调用数 + 1
    返回 1  // 有消息
}

函数 win32_DispatchMessageW(lpMsg) {
    // 将消息分发到窗口过程(WndProc)
    Win32_接口调用数 = Win32_接口调用数 + 1
    返回 0
}

函数 win32_DefWindowProcW(hwnd, msg, wParam, lParam) {
    // 默认窗口过程: 处理未被应用程序处理的消息
    Win32_接口调用数 = Win32_接口调用数 + 1
    返回 0
}

函数 win32_PostQuitMessage(nExitCode) {
    // 发送WM_QUIT到消息队列, 终止消息循环
    _win32_程序运行 = 假
    追加(_win32_消息队列, [0, 0x0012, nExitCode, 0])  // WM_QUIT=0x0012
    内核调试("Win32: PostQuitMessage code=" + 整数转字符串(nExitCode))
    Win32_接口调用数 = Win32_接口调用数 + 1
}

定义 可变 _win32_GDI对象表 = []  // [[句柄, 类型, 数据], ...]
定义 可变 _win32_下一GDI句柄 = 0x80000

函数 win32_CreateFontW(nHeight, nWidth, nEscapement, nOrientation, fnWeight, fdwItalic, fdwUnderline, fdwStrikeOut, fdwCharSet, fdwOutputPrecision, fdwClipPrecision, fdwQuality, fdwPitchAndFamily, lpszFace) {
    定义 h = _win32_下一GDI句柄
    _win32_下一GDI句柄 = _win32_下一GDI句柄 + 1
    追加(_win32_GDI对象表, [h, "字体", [nHeight, fnWeight, lpszFace]])
    内核调试("Win32: CreateFontW '" + lpszFace + "' h=" + 整数转字符串(nHeight))
    Win32_接口调用数 = Win32_接口调用数 + 1
    返回 h
}

函数 win32_SelectObject(hdc, hgdiobj) {
    // 选择GDI对象到设备上下文
    Win32_接口调用数 = Win32_接口调用数 + 1
    返回 0  // 返回之前的对象句柄
}

函数 win32_TextOutW(hdc, x, y, lpString, c) {
    // 在指定位置绘制文本
    内核调试("Win32: TextOutW at (" + 整数转字符串(x) + "," + 整数转字符串(y) + ")")
    Win32_接口调用数 = Win32_接口调用数 + 1
    返回 1  // 成功
}

定义 可变 _win32_注册表 = []  // [[键路径, 句柄, [值...]], ...]
定义 可变 _win32_下一注册表句柄 = 0xF0000

函数 win32_RegOpenKeyExW(hKey, lpSubKey, ulOptions, samDesired, phkResult) {
    // 打开注册表键 → Nova配置存储映射
    定义 h = _win32_下一注册表句柄
    _win32_下一注册表句柄 = _win32_下一注册表句柄 + 1
    追加(_win32_注册表, [lpSubKey, h, []])
    内核调试("Win32: RegOpenKeyExW '" + lpSubKey + "'")
    Win32_接口调用数 = Win32_接口调用数 + 1
    返回 0  // ERROR_SUCCESS
}

函数 win32_RegCloseKey(hKey) {
    Win32_接口调用数 = Win32_接口调用数 + 1
    返回 0  // ERROR_SUCCESS
}

函数 win32_WSACleanup() {
    Win32_接口调用数 = Win32_接口调用数 + 1
    返回 0
}

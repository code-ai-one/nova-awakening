        + 白璃主题_面板文本()
        + 白璃主题_卡片文本()
        + 白璃主题_输入框文本()
        + 白璃主题_命令板文本()
        + 白璃主题_状态胶囊文本()
        + 白璃主题_滚动条文本()
}

函数 白璃主题_全量样式文本() {
    返回 白璃主题_根变量文本()
        + 白璃主题_桌面样式文本()
        + 白璃主题_浏览器样式文本()
        + 白璃主题_组件样式文本()
        + 白璃主题_动效文本()
}

函数 白璃主题_根变量(档) {
    如果 (!白璃主题_检查档(档)) { 返回 白璃主题_失败(档, "根变量", "主题档不可用") }
    白璃主题_记录(档, "根变量", [], "白璃主题")
    档.变量数 = 档.变量数 + 1
    返回 白璃主题_成功(档, "根变量", 白璃主题_根变量文本())
}

函数 白璃主题_桌面样式(档) {

结构 CSSParsedValue {
    类型,    // u32 CSS值_xxx
    整数值,    // i32 数字值×100 (定点数)
    单位,    // u32 单位_xxx
    关键字ID,    // u32 关键字_xxx
    颜色值,    // u32 RGBA32 (当类型=颜色时)
    字符串,    // u64 字符串指针(函数名/URL/字符串值)
    字符串长度,
    子值列表,    // u64 CSSParsedValue*数组(列表/函数参数)
    子值数量,
}

函数 CSSParsedValue_创建(类型) {
    定义 v = 堆_分配(CSSParsedValue)
    v.类型 = 类型
    v.整数值 = 0
    v.单位 = 单位_无
    v.关键字ID = 0
    v.颜色值 = 0
    v.字符串 = 0
    v.字符串长度 = 0
    v.子值列表 = 0
    v.子值数量 = 0
    返回 v
}

定义 可变 AI_样式解析值_样式缓存命中 = 0

函数 AI_样式解析值_选择器复杂度(选择器长度, 组合子数) {
    如果 (组合子数 > 5) { 返回 "高复杂度" }
    如果 (组合子数 > 2) { 返回 "中复杂度" }
    返回 "低复杂度"
}

函数 AI_样式解析值_布局缓存(元素哈希) {
    AI_样式解析值_样式缓存命中 = AI_样式解析值_样式缓存命中 + 1
    返回 元素哈希
}

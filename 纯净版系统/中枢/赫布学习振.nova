导入("./类型定义.nova")
导入("./错误码.nova")
导入("./赫布追加.nova")

// 学习每个关键系数的振幅均值和标准差

函数 赫布_学习振幅(频谱列表, 频谱数, 维度, 索引列表, k) {
    // 均值
    定义 可变 振幅均值 = []
    定义 可变 振幅标准差 = []

    定义 可变 ki = 0
    当 (ki < k) {
        定义 idx = 索引列表[ki]
        定义 可变 绝对值和 = 0
        定义 可变 平方和 = 0

        定义 可变 si = 0
        当 (si < 频谱数) {
            定义 val = 频谱列表[si * 维度 + idx]
            定义 av = 赫布_绝对值(val)
            绝对值和 = 绝对值和 + av
            平方和 = 平方和 + av * av / 频谱数  // 防溢出
            si = si + 1
        }

        定义 均值 = 绝对值和 / 频谱数
        // std ≈ sqrt(E[x²] - E[x]²)
        定义 可变 方差 = 平方和 - 均值 * 均值
        如果 (方差 < 0) { 方差 = 0 }
        // 整数开方
        定义 可变 标准差 = 0
        当 (标准差 * 标准差 < 方差) { 标准差 = 标准差 + 1 }

        赫布_追加(振幅均值, 均值)
        赫布_追加(振幅标准差, 标准差)
        ki = ki + 1
    }

    返回 [振幅均值, 振幅标准差]
}

// 用学到的关联矩阵, 逐个生成Walsh系数
// 这是碰撞34-39 Nova关联学习学习在内容生成领域的推广

函数 赫布_生成频谱(关联, 振幅均值, 振幅标准差, 索引列表, k, 维度, 种子, DC值) {
    // 从均值频谱开始
    定义 可变 频谱 = []
    定义 可变 i = 0
    当 (i < 维度) { 赫布_追加(频谱, 0)  i = i + 1 }

    // 设置DC
    频谱[0] = DC值

    // Nova关联学习自回归: 逐个决定Top-K系数的符号和振幅
    定义 可变 已决定 = []
    定义 可变 当前种子 = 种子
    定义 可变 ki = 0
    当 (ki < k) {
        定义 idx = 索引列表[ki]

        // 符号: Nova关联学习预测
        定义 可变 符号 = 1
        如果 (ki > 0) {
            符号 = 赫布_预测符号(关联, 已决定, ki, k)
        } 否则 {
            // 第一个系数用seed决定
            如果 (当前种子 < 0) { 符号 = 0 - 1 }
        }

        // 振幅: 均值 + seed扰动
        定义 可变 振幅 = 振幅均值[ki]
        // seed的绝对值用作扰动比例
        定义 可变 种子绝对值 = 赫布_绝对值(当前种子)
        振幅 = 振幅 + 种子绝对值 * 振幅标准差[ki] / 1000

        频谱[idx] = 符号 * 振幅
        赫布_追加(已决定, 符号)

        // 更新seed (简单LCG)
        当前种子 = 当前种子 * 1103 + 7919
        如果 (当前种子 < 0) { 当前种子 = 0 - 当前种子 }
        当前种子 = 当前种子 % 2000 - 1000

        ki = ki + 1
    }

    返回 频谱
}

// 加噪声→recall→找错误位→针对性加强
// 碰撞系列验证: 这是仅有的3种有效增强之一

函数 赫布_噪声修复(权重矩阵, 模式列表, 模式数, 维度, 修复轮数) {
    定义 可变 w = []
    定义 可变 ci = 0
    当 (ci < 计数(权重矩阵)) { 赫布_追加(w, 权重矩阵[ci])  ci = ci + 1 }

    定义 可变 轮次 = 0
    当 (轮次 < 修复轮数) {
        定义 可变 pi = 0
        当 (pi < 模式数) {
            // 1. recall当前模式
            定义 偏移 = pi * 维度
            定义 可变 回忆 = []
            定义 可变 i = 0
            当 (i < 维度) {
                定义 可变 和 = 0
                定义 可变 j = 0
                当 (j < 维度) {
                    和 = 和 + w[i * 维度 + j] * 模式列表[偏移 + j]
                    j = j + 1
                }
                如果 (和 > 0) { 赫布_追加(回忆, 1) }
                否则 { 赫布_追加(回忆, 0 - 1) }
                i = i + 1
            }
            // 2. 找错误位并针对性加强
            i = 0
            当 (i < 维度) {
                如果 (回忆[i] != 赫布_符号(模式列表[偏移 + i])) {
                    // 错误位: 加强相关权重
                    定义 可变 j2 = 0
                    当 (j2 < 维度) {
                        w[i * 维度 + j2] = w[i * 维度 + j2] + 赫布_符号(模式列表[偏移 + i]) * 赫布_符号(模式列表[偏移 + j2])
                        j2 = j2 + 1
                    }
                }
                i = i + 1
            }
            pi = pi + 1
        }
        轮次 = 轮次 + 1
    }
    返回 w
}

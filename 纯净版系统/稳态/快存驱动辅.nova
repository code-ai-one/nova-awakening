导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("./管理命令.nova")
导入("../引导/端口输入.nova")
导入("./输入原语.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/每核页释放.nova")
导入("../标准/原生字符串.nova")

定义 NVME_CSTS = 0x1C
定义 NVME_CSTS_RDY = 0x01
定义 NVME_CSTS_CFS = 0x02
定义 NVME_CSTS_SHST_MASK = 0x0C
定义 NVME_CSTS_SHST_正常 = 0x00
定义 NVME_CSTS_SHST_进行中 = 0x04
定义 NVME_CSTS_SHST_完成 = 0x08
定义 NVME_CC = 0x14
定义 NVME_CC_EN = 0x01
定义 NVME_CC_SHN_正常 = 0x4000
定义 NVME_AQA = 0x24
定义 NVME_ASQ = 0x28
定义 NVME_ACQ = 0x30

定义 NVME_管理_识别 = 0x06
定义 NVME_管理_获取日志 = 0x02
定义 NVME_管理_获取特性 = 0x0A
定义 NVME_管理_设置特性 = 0x09
定义 NVME_管理_创建IO完成队列 = 0x05
定义 NVME_管理_创建IO提交队列 = 0x01

定义 NVME_日志_SMART = 0x02
定义 NVME_日志_固件 = 0x03
定义 NVME_日志_错误 = 0x01

定义 错误_IO = -5
定义 错误_超时 = -110
定义 错误_未初始化 = -6
定义 错误_控制器故障 = -7

定义 可变 NVMe_读总数 = 0
定义 可变 NVMe_写总数 = 0
定义 可变 NVMe_错误总数 = 0
定义 可变 NVMe_重试总数 = 0

结构 NVMe_SMART信息 {
    临界警告,
    温度,
    可用备用,
    可用备用阈值,
    已用寿命百分比,
    数据读取单元,
    数据写入单元,
    主机读命令数,
    主机写命令数,
    控制器忙时间,
    电源循环数,
    上电小时数,
    不安全关机数,
    媒体错误数,
    错误日志条目数,
}

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 NVMe_等待就绪(bar0) {
    定义 可变 i = 0
    当 (i < 10000) {
        定义 状态 = MMIO读32(bar0 + NVME_CSTS)
        如果 (状态 & NVME_CSTS_CFS) {
            NVMe_错误总数 = NVMe_错误总数 + 1
            返回 假
        }
        如果 ((状态 & NVME_CSTS_RDY) != 0) { 返回 真 }
        延迟_ms(1)
        i = i + 1
    }
    NVMe_错误总数 = NVMe_错误总数 + 1
    返回 假
}

函数 NVMe_等待禁用(bar0) {
    定义 可变 i = 0
    当 (i < 10000) {
        如果 ((MMIO读32(bar0 + NVME_CSTS) & NVME_CSTS_RDY) == 0) { 返回 真 }
        延迟_ms(1)
        i = i + 1
    }
    NVMe_错误总数 = NVMe_错误总数 + 1
    返回 假
}

函数 NVMe_安全关机(bar0) {
    定义 cc = MMIO读32(bar0 + NVME_CC)
    cc = (cc & 0xFFFF3FFF) | NVME_CC_SHN_正常
    MMIO写32(bar0 + NVME_CC, cc)

    定义 可变 i = 0
    当 (i < 30000) {
        定义 状态 = MMIO读32(bar0 + NVME_CSTS) & NVME_CSTS_SHST_MASK
        如果 (状态 == NVME_CSTS_SHST_完成) { 返回 真 }
        延迟_ms(1)
        i = i + 1
    }
    返回 假
}

函数 NVMe_分配命令ID(ctl) {
    定义 id = ctl.管理队列.下一个命令ID
    ctl.管理队列.下一个命令ID = (id + 1) & 0xFFFF
    返回 id
}

函数 NVMe_分配IO命令ID(q) {
    定义 id = q.下一个命令ID
    q.下一个命令ID = (id + 1) & 0xFFFF
    返回 id
}

函数 NVMe_读字符串(buf, 起始, 结束) {
    定义 可变 结果 = ""
    定义 可变 末尾 = 结束
    当 (末尾 >= 起始 && 内存读8(buf + 末尾) == 0x20) { 末尾 = 末尾 - 1 }
    定义 可变 i = 起始
    当 (i <= 末尾) {
        定义 c = 内存读8(buf + i)
        如果 (c >= 0x20 && c <= 0x7E) { 结果 = 结果 + 字符(c) }
        i = i + 1
    }
    返回 结果
}

函数 NVMe_解析SMART(数据) {
    如果 (数据 == 空) { 返回 空 }
    定义 info = 堆_分配(NVMe_SMART信息)
    info.临界警告 = 内存读8(数据)
    info.温度 = 内存读16(数据 + 1) - 273
    info.可用备用 = 内存读8(数据 + 3)
    info.可用备用阈值 = 内存读8(数据 + 4)
    info.已用寿命百分比 = 内存读8(数据 + 5)
    info.数据读取单元 = 内存读64(数据 + 32)
    info.数据写入单元 = 内存读64(数据 + 48)
    info.主机读命令数 = 内存读64(数据 + 64)
    info.主机写命令数 = 内存读64(数据 + 80)
    info.控制器忙时间 = 内存读64(数据 + 96)
    info.电源循环数 = 内存读64(数据 + 112)
    info.上电小时数 = 内存读64(数据 + 128)
    info.不安全关机数 = 内存读64(数据 + 144)
    info.媒体错误数 = 内存读64(数据 + 160)
    info.错误日志条目数 = 内存读64(数据 + 176)
    返回 info
}

函数 NVMe_检查健康(ctl) {
    如果 (ctl == 空) { 返回 错误_未初始化 }
    定义 状态 = MMIO读32(ctl.bar0 + NVME_CSTS)
    如果 (状态 & NVME_CSTS_CFS) {
        内核警告("NVMe: 控制器致命错误")
        返回 错误_控制器故障
    }
    返回 0
}

函数 NVMe_控制器复位(ctl) {
    如果 (ctl == 空) { 返回 错误_未初始化 }
    定义 cc = MMIO读32(ctl.bar0 + NVME_CC)
    MMIO写32(ctl.bar0 + NVME_CC, cc & ~NVME_CC_EN)

    如果 (!NVMe_等待禁用(ctl.bar0)) {
        返回 错误_超时
    }

    延迟_ms(100)

    MMIO写32(ctl.bar0 + NVME_CC, cc | NVME_CC_EN)
    如果 (!NVMe_等待就绪(ctl.bar0)) {
        返回 错误_超时
    }
    NVMe_重试总数 = NVMe_重试总数 + 1
    返回 0
}

函数 NVMe_创建IO队列对(ctl, 队列ID, 深度) {
    如果 (ctl == 空) { 返回 错误_未初始化 }
    如果 (深度 < 2) { 深度 = 2 }
    如果 (深度 > 4096) { 深度 = 4096 }

    定义 完成队列内存 = 直传_分配_对齐(深度 * 16, 4096)
    如果 (完成队列内存 == 0) { 返回 错误_IO }
    内存清零(完成队列内存, 深度 * 16)

    定义 提交队列内存 = 直传_分配_对齐(深度 * 64, 4096)
    如果 (提交队列内存 == 0) { 返回 错误_IO }
    内存清零(提交队列内存, 深度 * 64)

    定义 完成CID = NVMe_分配命令ID(ctl)
    NVMe_提交管理命令(ctl, NVME_管理_创建IO完成队列, 队列ID,
        完成队列内存, 深度 - 1, 0x03)

    定义 提交CID = NVMe_分配命令ID(ctl)
    NVMe_提交管理命令(ctl, NVME_管理_创建IO提交队列, 队列ID,
        提交队列内存, 深度 - 1, 队列ID)

    返回 0
}

函数 NVMe_打印SMART(info) {
    如果 (info == 空) { 返回 }
    内核信息("NVMe SMART:")
    内核信息("  温度: " + 整数转字符串(info.温度) + "°C")
    内核信息("  可用备用: " + 整数转字符串(info.可用备用) + "%")
    内核信息("  已用寿命: " + 整数转字符串(info.已用寿命百分比) + "%")
    内核信息("  电源循环: " + 整数转字符串(info.电源循环数))
    内核信息("  上电小时: " + 整数转字符串(info.上电小时数))
    内核信息("  不安全关机: " + 整数转字符串(info.不安全关机数))
    内核信息("  媒体错误: " + 整数转字符串(info.媒体错误数))
    如果 (info.临界警告 != 0) {
        内核警告("  *** 临界警告: " + 整数转16进制(info.临界警告) + " ***")
    }
}

函数 NVMe_温度检查(info, 阈值) {
    如果 (info == 空) { 返回 假 }
    如果 (info.温度 > 阈值) {
        内核警告("NVMe: 温度过高 " + 整数转字符串(info.温度) + "°C > " + 整数转字符串(阈值) + "°C")
        返回 真
    }
    返回 假
}

函数 MMIO读64(地址) { 返回 内存读64(地址) }
函数 MMIO写64(地址, 值) { 内存写64(地址, 值) }

函数 直传_分配_对齐(大小, 对齐) { 返回 伙伴系统_分配((大小 + 4095) / 4096) }

函数 延迟_ms(ms) {
    定义 可变 i = 0
    当 (i < ms) { 延迟_us(1000); i = i + 1 }
}

函数 延迟_us(us) {
    定义 目标 = us * 2000
    定义 开始 = NVMe_读取TSC()
    当 (NVMe_读取TSC() - 开始 < 目标) { 内联汇编("pause") }
}

函数 NVMe_读取TSC() { 返回 内联汇编_返回值("rdtsc") }

函数 块设备_注册(名称, dev) {
    内核信息("块设备: 注册 /dev/" + 名称)
}

函数 内存清零(地址, 大小) {
    定义 可变 i = 0
    当 (i < 大小) {
        内存写8(地址 + i, 0)
        i = i + 1
    }
}

函数 NVMe_统计() {
    返回 {
        控制器数: 计数(NVMe控制器列表),
        读总数: NVMe_读总数,
        写总数: NVMe_写总数,
        错误总数: NVMe_错误总数,
        重试总数: NVMe_重试总数
    }
}

// NVMe健康检查

函数 NVMe_健康检查() {
    定义 可变 问题 = []
    如果 (计数(NVMe控制器列表) == 0) { 追加(问题, "无NVMe控制器") }
    定义 总IO = NVMe_读总数 + NVMe_写总数
    如果 (总IO > 0 && NVMe_错误总数 > 总IO / 100) {
        追加(问题, "NVMe错误率过高")
    }
    如果 (NVMe_重试总数 > 总IO / 10 && 总IO > 100) {
        追加(问题, "NVMe重试过多")
    }
    如果 (计数(问题) == 0) { 返回 "NVMe健康" }
    返回 问题
}

函数 NVMe_重置统计() {
    NVMe_读总数 = 0
    NVMe_写总数 = 0
    NVMe_错误总数 = 0
    NVMe_重试总数 = 0
}

函数 NVMe_获取IOPS() {
    返回 NVMe_读总数 + NVMe_写总数
}

函数 NVMe_错误率() {
    定义 总IO = NVMe_读总数 + NVMe_写总数
    如果 (总IO == 0) { 返回 0 }
    返回 NVMe_错误总数 * 100 / 总IO
}

函数 NVMe_读写比() {
    如果 (NVMe_写总数 == 0) { 返回 0 }
    返回 NVMe_读总数 * 100 / NVMe_写总数
}

定义 可变 AI_快存驱动辅_运行指标 = 0
定义 可变 AI_快存驱动辅_异常指标 = 0

函数 AI_快存驱动辅_自诊断() {
    AI_快存驱动辅_运行指标 = NVMe_读总数
    返回 AI_快存驱动辅_运行指标
}

函数 AI_快存驱动辅_优化建议() {
    定义 指标 = AI_快存驱动辅_自诊断()
    如果 (AI_快存驱动辅_运行指标 > 10000) { 返回 "快存驱动辅负载较高" }
    返回 "快存驱动辅状态正常"
}

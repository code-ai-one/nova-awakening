函数 合成器_鼠标点击(x, y, 按钮) {
    // 从顶层到底层查找命中窗口
    定义 可变 i = 计数(所有窗口) - 1
    当 (i >= 0) {
        定义 win = 所有窗口[i]
        如果 (win.可见 && win.状态 != 窗口状态_最小化) {
            如果 (x >= win.x && x < win.x + win.宽 &&
                y >= win.y && y < win.y + win.高) {
                窗口_设焦点(win.窗口ID)
                返回 win.窗口ID
            }
        }
        i = i - 1
    }
    返回 0  // 点击桌面
}

函数 合成器_坐标到窗口(全局x, 全局y) {
    // 全局屏幕坐标→窗口局部坐标
    定义 win = 窗口_查找(焦点窗口ID)
    如果 (win == 空) { 返回 [全局x, 全局y, 0] }
    返回 [全局x - win.x, 全局y - win.y, win.窗口ID]
}

// §6 AI智能布局

函数 智能_智能布局_自动分屏(窗口数) {
    如果 (窗口数 <= 0) { 返回 }
    如果 (窗口数 == 1) {
        // 单窗口: 居中80%
        定义 w = 屏幕宽 * 80 / 100
        定义 h = 屏幕高 * 80 / 100
        定义 x = (屏幕宽 - w) / 2
        定义 y = (屏幕高 - h) / 2
        如果 (计数(所有窗口) > 0) {
            窗口_移动(所有窗口[0].窗口ID, x, y)
            窗口_调整大小(所有窗口[0].窗口ID, w, h)
        }
    } 否则 如果 (窗口数 == 2) {
        // 左右分屏
        定义 半宽 = 屏幕宽 / 2
        如果 (计数(所有窗口) >= 2) {
            窗口_移动(所有窗口[0].窗口ID, 0, 0)
            窗口_调整大小(所有窗口[0].窗口ID, 半宽, 屏幕高)
            窗口_移动(所有窗口[1].窗口ID, 半宽, 0)
            窗口_调整大小(所有窗口[1].窗口ID, 半宽, 屏幕高)
        }
    } 否则 {
        // 网格布局
        定义 列数 = 整数开方_简(窗口数) + 1
        定义 行数 = (窗口数 + 列数 - 1) / 列数
        定义 格宽 = 屏幕宽 / 列数
        定义 格高 = 屏幕高 / 行数
        定义 可变 i = 0
        当 (i < 窗口数 && i < 计数(所有窗口)) {
            定义 列 = i % 列数
            定义 行 = i / 列数
            窗口_移动(所有窗口[i].窗口ID, 列 * 格宽, 行 * 格高)
            窗口_调整大小(所有窗口[i].窗口ID, 格宽, 格高)
            i = i + 1
        }
    }
}

// 整数开方 统一使用 核心/公共/数学工具.nova::数学_开方()

函数 分配窗口缓冲(大小) {
    定义 地址 = kmalloc(大小, 0)
    如果 (地址 == 0) {
        内核警告("窗口缓冲分配失败: " + 整数转字符串(大小) + " 字节")
    }
    返回 地址
}
函数 释放窗口缓冲(地址) {
    如果 (地址 == 0) { 返回 }
    kfree(地址)
}

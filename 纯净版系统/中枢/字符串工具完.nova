// NovaOS C风格字符串工具 — 觉醒理论·底层文本处理引擎
// 原创理论: NovaCStr — 指针级字符串操作 + 编码检测 + AI分析
// §1 长度/比较/复制: C风格零终止字符串基本操作
// §2 查找/子串: 字节查找/子串匹配
// §3 大小写转换: 转大写/转小写
// §4 去空白/哈希: 去首尾空白/djb2哈希
// §5 整数/字节分析: 转整数/统计字节/反转
// §6 编码检测: ASCII/UTF-8/GBK自动检测
// §7 模式匹配: 简单通配符匹配(*/?)
// §8 AI字符串分析: 基于历史操作的智能预测
// §9 完整统计: 15+指标
// 四阶段AI演进: 本模块属于第一阶段（基础设施层）

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./日志中枢.nova")
导入("./字符串替换.nova")
导入("../感知/内核直连层.nova")

定义 可变 操作总数 = 0
定义 可变 分配字节 = 0
定义 可变 释放字节 = 0
定义 可变 最大驻留 = 0

函数 字串_长度(指针) {
    如果 (指针 == 0) { 返回 0 }
    定义 可变 计 = 0
    当 (内存_读8(指针 + 计) != 0) { 计 = 计 + 1 }
    操作总数 = 操作总数 + 1
    返回 计
}

函数 字串_比较(甲, 乙) {
    如果 (甲 == 乙) { 返回 0 }
    如果 (甲 == 0) { 返回 -1 }
    如果 (乙 == 0) { 返回 1 }
    定义 可变 位 = 0
    当 (内存_读8(甲 + 位) != 0 && 内存_读8(乙 + 位) != 0) {
        定义 差 = 内存_读8(甲 + 位) - 内存_读8(乙 + 位)
        如果 (差 != 0) { 返回 差 }
        位 = 位 + 1
    }
    操作总数 = 操作总数 + 1
    返回 内存_读8(甲 + 位) - 内存_读8(乙 + 位)
}

函数 字串_复制(目标, 源, 最大长) {
    如果 (目标 == 0 || 源 == 0) { 返回 0 }
    定义 可变 位 = 0
    当 (位 < 最大长 - 1 && 内存_读8(源 + 位) != 0) {
        内存_写8(目标 + 位, 内存_读8(源 + 位))
        位 = 位 + 1
    }
    内存_写8(目标 + 位, 0)
    操作总数 = 操作总数 + 1
    返回 位
}

函数 字串_查找字节(指针, 长度, 目标字节) {
    定义 可变 位 = 0
    当 (位 < 长度) {
        如果 (内存_读8(指针 + 位) == 目标字节) { 返回 位 }
        位 = 位 + 1
    }
    返回 -1
}

函数 字串_查找子串(主串, 主长, 子串, 子长) {
    如果 (子长 == 0) { 返回 0 }
    如果 (子长 > 主长) { 返回 -1 }
    定义 可变 位 = 0
    当 (位 <= 主长 - 子长) {
        定义 可变 匹配 = 0
        定义 可变 全匹配 = 真
        当 (匹配 < 子长) {
            如果 (内存_读8(主串 + 位 + 匹配) != 内存_读8(子串 + 匹配)) {
                全匹配 = 假
                跳出
            }
            匹配 = 匹配 + 1
        }
        如果 (全匹配) {
            操作总数 = 操作总数 + 1
            返回 位
        }
        位 = 位 + 1
    }
    返回 -1
}

函数 字串_转大写(指针, 长度) {
    定义 可变 位 = 0
    当 (位 < 长度) {
        定义 字节 = 内存_读8(指针 + 位)
        如果 (字节 >= 97 && 字节 <= 122) {
            内存_写8(指针 + 位, 字节 - 32)
        }
        位 = 位 + 1
    }
}

函数 字串_转小写(指针, 长度) {
    定义 可变 位 = 0
    当 (位 < 长度) {
        定义 字节 = 内存_读8(指针 + 位)
        如果 (字节 >= 65 && 字节 <= 90) {
            内存_写8(指针 + 位, 字节 + 32)
        }
        位 = 位 + 1
    }
}

函数 字串_去首尾空白(指针, 长度) {
    定义 可变 起始 = 0
    当 (起始 < 长度) {
        定义 字节 = 内存_读8(指针 + 起始)
        如果 (字节 != 32 && 字节 != 9 && 字节 != 10 && 字节 != 13) { 跳出 }
        起始 = 起始 + 1
    }
    定义 可变 结束 = 长度
    当 (结束 > 起始) {
        定义 字节 = 内存_读8(指针 + 结束 - 1)
        如果 (字节 != 32 && 字节 != 9 && 字节 != 10 && 字节 != 13) { 跳出 }
        结束 = 结束 - 1
    }
    返回 [起始, 结束 - 起始]
}

函数 字串_是数字(字节) { 返回 字节 >= 48 && 字节 <= 57 }
函数 字串_是字母(字节) { 返回 (字节 >= 65 && 字节 <= 90) || (字节 >= 97 && 字节 <= 122) }
函数 字串_是空白(字节) { 返回 字节 == 32 || 字节 == 9 || 字节 == 10 || 字节 == 13 }

函数 字串_转整数(指针, 长度) {
    定义 可变 结果 = 0
    定义 可变 负号 = 假
    定义 可变 位 = 0
    如果 (位 < 长度 && 内存_读8(指针 + 位) == 45) { 负号 = 真; 位 = 位 + 1 }
    当 (位 < 长度) {
        定义 字节 = 内存_读8(指针 + 位)
        如果 (!字串_是数字(字节)) { 跳出 }
        结果 = 结果 * 10 + (字节 - 48)
        位 = 位 + 1
    }
    如果 (负号) { 结果 = 0 - 结果 }
    返回 结果
}

函数 字串_哈希(指针, 长度) {
    定义 可变 哈希值 = 5381
    定义 可变 位 = 0
    当 (位 < 长度) {
        哈希值 = 哈希值 * 33 + 内存_读8(指针 + 位)
        位 = 位 + 1
    }
    返回 哈希值 & 0x7FFFFFFF
}

函数 字串_统计字节(指针, 长度, 目标) {
    定义 可变 计 = 0
    定义 可变 位 = 0
    当 (位 < 长度) {
        如果 (内存_读8(指针 + 位) == 目标) { 计 = 计 + 1 }
        位 = 位 + 1
    }
    返回 计
}

函数 字串_反转(指针, 长度) {
    定义 可变 左 = 0
    定义 可变 右 = 长度 - 1
    当 (左 < 右) {
        定义 临时 = 内存_读8(指针 + 左)
        内存_写8(指针 + 左, 内存_读8(指针 + 右))
        内存_写8(指针 + 右, 临时)
        左 = 左 + 1
        右 = 右 - 1
    }
}

定义 编码_ASCII = 0
定义 编码_UTF8 = 1
定义 编码_GBK = 2
定义 编码_未知 = 3
定义 AI分析窗口 = 16

结构 工具统计 {
    长度调用数: 整数,
    比较调用数: 整数,
    复制调用数: 整数,
    查找字节数: 整数,
    查找子串数: 整数,
    转大写数: 整数,
    转小写数: 整数,
    去空白数: 整数,
    哈希计算数: 整数,
    转整数数: 整数,
    统计字节数: 整数,
    反转数: 整数,
    编码检测数: 整数,
    模式匹配数: 整数,
    AI分析次数: 整数,
    AI分析命中: 整数,
    错误次数: 整数,
}

定义 可变 全局统计 = 工具统计 {}
定义 可变 工具模块已初始化 = 假
定义 可变 AI长度历史 = []
定义 可变 AI长度位置 = 0


函数 工具模块_初始化() {
    如果 (工具模块已初始化 == 真) { 返回 0 - 17 }
    AI长度历史 = []
    定义 可变 i = 0
    当 (i < AI分析窗口) {
        追加(AI长度历史, 0)
        i = i + 1
    }
    AI长度位置 = 0
    工具模块已初始化 = 真
    打印("[字符串工具] 初始化完成")
    返回 0
}

函数 工具模块_销毁() {
    如果 (工具模块已初始化 == 假) { 返回 0 }
    AI长度历史 = []
    工具模块已初始化 = 假
    打印("[字符串工具] 已销毁")
    返回 0
}


函数 字串_安全长度(指针) {
    全局统计.长度调用数 = 全局统计.长度调用数 + 1
    定义 长度 = 字串_长度(指针)
    AI_记录长度(长度)
    返回 长度
}

函数 字串_安全比较(甲, 乙) {
    全局统计.比较调用数 = 全局统计.比较调用数 + 1
    返回 字串_比较(甲, 乙)
}

函数 字串_安全复制(目标, 源, 最大长) {
    全局统计.复制调用数 = 全局统计.复制调用数 + 1
    返回 字串_复制(目标, 源, 最大长)
}


函数 字串_检测编码(指针, 长度) {
    如果 (指针 == 0 || 长度 == 0) { 返回 编码_未知 }
    全局统计.编码检测数 = 全局统计.编码检测数 + 1
    定义 可变 高位数 = 0
    定义 可变 utf8序列数 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 字节 = 内存_读8(指针 + i)
        如果 (字节 > 127) {
            高位数 = 高位数 + 1
            // 检查UTF-8序列
            如果 ((字节 & 0xE0) == 0xC0) {
                // 2字节UTF-8
                如果 (i + 1 < 长度 && (内存_读8(指针 + i + 1) & 0xC0) == 0x80) {
                    utf8序列数 = utf8序列数 + 1
                    i = i + 2
                    继续
                }
            } 否则 如果 ((字节 & 0xF0) == 0xE0) {
                // 3字节UTF-8（中文常用）
                如果 (i + 2 < 长度) {
                    如果 ((内存_读8(指针 + i + 1) & 0xC0) == 0x80 && (内存_读8(指针 + i + 2) & 0xC0) == 0x80) {
                        utf8序列数 = utf8序列数 + 1
                        i = i + 3
                        继续
                    }
                }
            }
        }
        i = i + 1
    }
    如果 (高位数 == 0) { 返回 编码_ASCII }
    如果 (utf8序列数 > 0 && utf8序列数 * 3 >= 高位数) { 返回 编码_UTF8 }
    如果 (高位数 > 0) { 返回 编码_GBK }
    返回 编码_未知
}

函数 编码名称(编码) {
    如果 (编码 == 编码_ASCII) { 返回 "ASCII" }
    如果 (编码 == 编码_UTF8) { 返回 "UTF-8" }
    如果 (编码 == 编码_GBK) { 返回 "GBK" }
    返回 "未知"
}


函数 字串_通配符匹配(文本指针, 文本长, 模式指针, 模式长) {
    全局统计.模式匹配数 = 全局统计.模式匹配数 + 1
    返回 _通配符递归(文本指针, 0, 文本长, 模式指针, 0, 模式长)
}

函数 _通配符递归(文本, 文位, 文长, 模式, 模位, 模长) {
    如果 (模位 >= 模长) { 返回 文位 >= 文长 }
    定义 模字节 = 内存_读8(模式 + 模位)
    如果 (模字节 == 42) {
        // '*' 匹配任意长度
        定义 可变 i = 文位
        当 (i <= 文长) {
            如果 (_通配符递归(文本, i, 文长, 模式, 模位 + 1, 模长) == 真) {
                返回 真
            }
            i = i + 1
        }
        返回 假
    }
    如果 (文位 >= 文长) { 返回 假 }
    如果 (模字节 == 63 || 模字节 == 内存_读8(文本 + 文位)) {
        // '?' 或精确匹配
        返回 _通配符递归(文本, 文位 + 1, 文长, 模式, 模位 + 1, 模长)
    }
    返回 假
}


函数 字串_批量比较(指针列表, 目标) {
    如果 (指针列表 == 空 || 目标 == 0) { 返回 [] }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(指针列表)) {
        定义 比较结果 = 字串_比较(指针列表[i], 目标)
        追加(结果, [指针列表[i], 比较结果])
        i = i + 1
    }
    返回 结果
}

函数 字串_N比较(甲, 乙, n) {
    // 只比较前n个字节
    如果 (甲 == 0 || 乙 == 0) { 返回 0 - 1 }
    定义 可变 位 = 0
    当 (位 < n) {
        定义 差 = 内存_读8(甲 + 位) - 内存_读8(乙 + 位)
        如果 (差 != 0) { 返回 差 }
        如果 (内存_读8(甲 + 位) == 0) { 返回 0 }
        位 = 位 + 1
    }
    返回 0
}

函数 字串_拼接(目标, 目标最大, 源) {
    如果 (目标 == 0 || 源 == 0) { 返回 0 }
    定义 目标长 = 字串_长度(目标)
    定义 源长 = 字串_长度(源)
    定义 可变 复制长 = 源长
    如果 (目标长 + 源长 >= 目标最大) {
        复制长 = 目标最大 - 目标长 - 1
    }
    如果 (复制长 <= 0) { 返回 目标长 }
    定义 可变 i = 0
    当 (i < 复制长) {
        内存_写8(目标 + 目标长 + i, 内存_读8(源 + i))
        i = i + 1
    }
    内存_写8(目标 + 目标长 + 复制长, 0)
    返回 目标长 + 复制长
}

函数 字串_重复字节(目标, 字节, 次数) {
    如果 (目标 == 0 || 次数 <= 0) { 返回 }
    定义 可变 i = 0
    当 (i < 次数) {
        内存_写8(目标 + i, 字节)
        i = i + 1
    }
    内存_写8(目标 + 次数, 0)
}


函数 AI_记录长度(长度) {
    设置(AI长度历史, AI长度位置, 长度)
    AI长度位置 = (AI长度位置 + 1) % AI分析窗口
    全局统计.AI分析次数 = 全局统计.AI分析次数 + 1
}

函数 AI_平均字符串长度() {
    定义 可变 总和 = 0
    定义 可变 计数 = 0
    定义 可变 i = 0
    当 (i < AI分析窗口) {
        如果 (AI长度历史[i] > 0) {
            总和 = 总和 + AI长度历史[i]
            计数 = 计数 + 1
        }
        i = i + 1
    }
    如果 (计数 == 0) { 返回 0 }
    返回 总和 / 计数
}

函数 AI_最大字符串长度() {
    定义 可变 最大 = 0
    定义 可变 i = 0
    当 (i < AI分析窗口) {
        如果 (AI长度历史[i] > 最大) { 最大 = AI长度历史[i] }
        i = i + 1
    }
    返回 最大
}

函数 AI_建议缓冲区大小() {
    定义 均长 = AI_平均字符串长度()
    定义 最大 = AI_最大字符串长度()
    // 建议缓冲区 = max(均长*2, 最大*1.5)
    定义 建议1 = 均长 * 2
    定义 建议2 = 最大 * 150 / 100
    如果 (建议1 > 建议2) { 返回 建议1 }
    返回 建议2
}


函数 字符串工具_转储() {
    打印("[字符串工具] ═══ 状态转储 ═══")
    打印(字符串拼接("  操作总数: ", 转字符串(操作总数)))
    打印(字符串拼接("  AI平均长度: ", 转字符串(AI_平均字符串长度())))
    打印(字符串拼接("  AI最大长度: ", 转字符串(AI_最大字符串长度())))
    打印(字符串拼接("  AI建议缓冲: ", 转字符串(AI_建议缓冲区大小())))
    返回 0
}

函数 字符串工具_完整统计() {
    返回 [操作总数, 分配字节, 释放字节, 最大驻留]
}


函数 工具模块_打印统计() {
    打印("[字符串工具] ═══ 运行统计 ═══")
    打印(字符串拼接("  长度调用: ", 转字符串(全局统计.长度调用数)))
    打印(字符串拼接("  比较调用: ", 转字符串(全局统计.比较调用数)))
    打印(字符串拼接("  复制调用: ", 转字符串(全局统计.复制调用数)))
    打印(字符串拼接("  查找字节: ", 转字符串(全局统计.查找字节数)))
    打印(字符串拼接("  查找子串: ", 转字符串(全局统计.查找子串数)))
    打印(字符串拼接("  转大写: ", 转字符串(全局统计.转大写数)))
    打印(字符串拼接("  转小写: ", 转字符串(全局统计.转小写数)))
    打印(字符串拼接("  去空白: ", 转字符串(全局统计.去空白数)))
    打印(字符串拼接("  哈希计算: ", 转字符串(全局统计.哈希计算数)))
    打印(字符串拼接("  转整数: ", 转字符串(全局统计.转整数数)))
    打印(字符串拼接("  统计字节: ", 转字符串(全局统计.统计字节数)))
    打印(字符串拼接("  反转: ", 转字符串(全局统计.反转数)))
    打印(字符串拼接("  编码检测: ", 转字符串(全局统计.编码检测数)))
    打印(字符串拼接("  模式匹配: ", 转字符串(全局统计.模式匹配数)))
    打印(字符串拼接("  AI分析: ", 转字符串(全局统计.AI分析次数)))
    打印(字符串拼接("  AI命中: ", 转字符串(全局统计.AI分析命中)))
    打印(字符串拼接("  错误次数: ", 转字符串(全局统计.错误次数)))
    返回 0
}


函数 工具模块_注册到内核(内核上下文) {
    如果 (工具模块已初始化 == 假) { 返回 0 - 1 }
    打印("[字符串工具] 已注册到内核上下文")
    返回 0
}

函数 工具模块_查询状态() {
    如果 (工具模块已初始化 == 假) { 返回 0 }
    返回 1
}

函数 工具模块_健康检查() {
    如果 (工具模块已初始化 == 假) { 返回 假 }
    如果 (全局统计.错误次数 * 10 > 操作总数) { 返回 假 }
    返回 真
}


函数 字串_是否为空(指针) {
    如果 (指针 == 0) { 返回 真 }
    返回 内存_读8(指针) == 0
}

函数 字串_相等(甲, 乙) {
    返回 字串_比较(甲, 乙) == 0
}

函数 字串_N相等(甲, 乙, n) {
    返回 字串_N比较(甲, 乙, n) == 0
}

函数 字串_填充零(指针, 长度) {
    如果 (指针 == 0 || 长度 <= 0) { 返回 }
    定义 可变 i = 0
    当 (i < 长度) {
        内存_写8(指针 + i, 0)
        i = i + 1
    }
}

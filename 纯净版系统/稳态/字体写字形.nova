// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 字体_写字形(字符码, 行数据) {
    如果 (字符码 < 字体_首字符 || 字符码 > 字体_末字符) { 返回 }
    定义 偏移 = (字符码 - 字体_首字符) * 字体_高
    定义 可变 i = 0
    当 (i < 字体_高 && i < 计数(行数据)) {
        字体数据[偏移 + i] = 行数据[i]
        i = i + 1
    }
}

// §2 字形渲染: 单字符→帧缓冲

外部 屏幕宽         // 定义在 窗口合成器.nova
外部 屏幕位深       // 定义在 窗口合成器.nova

函数 字体_渲染字符(fb, x, y, 字符码, 前景色, 背景色, 缩放) {
    // fb: 帧缓冲地址, x/y: 像素坐标, 缩放: 1=8×16, 2=16×32...
    如果 (字符码 < 字体_首字符 || 字符码 > 字体_末字符) {
        字符码 = 0x3F  // '?' 替代不可显示字符
        如果 (字符码 > 字体_末字符) { 返回 }
    }

    定义 偏移 = (字符码 - 字体_首字符) * 字体_高
    定义 bpp = 屏幕位深 / 8
    如果 (bpp < 3) { bpp = 4 }  // 默认32位色

    定义 可变 行 = 0
    当 (行 < 字体_高) {
        定义 行数据 = 字体数据[偏移 + 行]
        定义 可变 列 = 0
        当 (列 < 字体_宽) {
            定义 像素亮 = (行数据 >> (7 - 列)) & 1
            定义 颜色 = 背景色
            如果 (像素亮 == 1) { 颜色 = 前景色 }

            // 缩放渲染: 每个点阵像素画 缩放×缩放 个屏幕像素
            定义 可变 sy = 0
            当 (sy < 缩放) {
                定义 可变 sx = 0
                当 (sx < 缩放) {
                    定义 px = x + 列 * 缩放 + sx
                    定义 py = y + 行 * 缩放 + sy
                    定义 像素偏移 = (py * 屏幕宽 + px) * bpp
                    // 32位色: BGRA
                    内存写8(fb + 像素偏移,     颜色 & 0xFF)         // B
                    内存写8(fb + 像素偏移 + 1, (颜色 >> 8) & 0xFF)  // G
                    内存写8(fb + 像素偏移 + 2, (颜色 >> 16) & 0xFF) // R
                    内存写8(fb + 像素偏移 + 3, 0xFF)                // A
                    sx = sx + 1
                }
                sy = sy + 1
            }
            列 = 列 + 1
        }
        行 = 行 + 1
    }
}

// 不画背景的透明版本(用于叠加渲染)
函数 字体_渲染字符_透明(fb, x, y, 字符码, 前景色, 缩放) {
    如果 (字符码 < 字体_首字符 || 字符码 > 字体_末字符) { 返回 }
    定义 偏移 = (字符码 - 字体_首字符) * 字体_高
    定义 bpp = 屏幕位深 / 8
    如果 (bpp < 3) { bpp = 4 }

    定义 可变 行 = 0
    当 (行 < 字体_高) {
        定义 行数据 = 字体数据[偏移 + 行]
        定义 可变 列 = 0
        当 (列 < 字体_宽) {
            如果 ((行数据 >> (7 - 列)) & 1 == 1) {
                定义 可变 sy = 0
                当 (sy < 缩放) {
                    定义 可变 sx = 0
                    当 (sx < 缩放) {
                        定义 px = x + 列 * 缩放 + sx
                        定义 py = y + 行 * 缩放 + sy
                        定义 像素偏移 = (py * 屏幕宽 + px) * bpp
                        内存写8(fb + 像素偏移,     前景色 & 0xFF)
                        内存写8(fb + 像素偏移 + 1, (前景色 >> 8) & 0xFF)
                        内存写8(fb + 像素偏移 + 2, (前景色 >> 16) & 0xFF)
                        内存写8(fb + 像素偏移 + 3, 0xFF)
                        sx = sx + 1
                    }
                    sy = sy + 1
                }
            }
            列 = 列 + 1
        }
        行 = 行 + 1
    }
}

// §3 文本渲染: 字符串→屏幕

函数 字体_渲染文本(fb, x, y, 文本, 前景色, 背景色, 缩放) {
    // 渲染ASCII字符串, 支持\n换行
    定义 字符宽 = 字体_宽 * 缩放
    定义 字符高 = 字体_高 * 缩放
    定义 可变 cx = x
    定义 可变 cy = y
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 ch = 字符串取字节(文本, i)
        如果 (ch == 10) {  // '\n'
            cx = x
            cy = cy + 字符高
        } 否则如果 (ch == 13) {  // '\r'
            cx = x
        } 否则如果 (ch == 9) {  // '\t'
            cx = cx + 字符宽 * 4
        } 否则 {
            字体_渲染字符(fb, cx, cy, ch, 前景色, 背景色, 缩放)
            cx = cx + 字符宽
        }
        i = i + 1
    }
}

// 透明背景版本
函数 字体_渲染文本_透明(fb, x, y, 文本, 前景色, 缩放) {
    定义 字符宽 = 字体_宽 * 缩放
    定义 字符高 = 字体_高 * 缩放
    定义 可变 cx = x
    定义 可变 cy = y
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 ch = 字符串取字节(文本, i)
        如果 (ch == 10) { cx = x; cy = cy + 字符高 }
        否则如果 (ch == 13) { cx = x }
        否则如果 (ch == 9) { cx = cx + 字符宽 * 4 }
        否则 {
            字体_渲染字符_透明(fb, cx, cy, ch, 前景色, 缩放)
            cx = cx + 字符宽
        }
        i = i + 1
    }
}

// 测量文本宽度(像素)
函数 字体_文本宽度(文本, 缩放) {
    定义 字符宽 = 字体_宽 * 缩放
    定义 可变 最大宽 = 0
    定义 可变 当前宽 = 0
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 ch = 字符串取字节(文本, i)
        如果 (ch == 10) {
            如果 (当前宽 > 最大宽) { 最大宽 = 当前宽 }
            当前宽 = 0
        } 否则如果 (ch == 9) {
            当前宽 = 当前宽 + 字符宽 * 4
        } 否则 {
            当前宽 = 当前宽 + 字符宽
        }
        i = i + 1
    }
    如果 (当前宽 > 最大宽) { 最大宽 = 当前宽 }
    返回 最大宽
}

// 测量文本高度(像素)
函数 字体_文本高度(文本, 缩放) {
    定义 字符高 = 字体_高 * 缩放
    定义 可变 行数 = 1
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        如果 (字符串取字节(文本, i) == 10) { 行数 = 行数 + 1 }
        i = i + 1
    }
    返回 行数 * 字符高
}

定义 可变 AI_字体写字形_帧率窗口 = []

函数 AI_字体写字形_帧率预测(当前帧耗时) {
    追加(AI_字体写字形_帧率窗口, 当前帧耗时)
    如果 (计数(AI_字体写字形_帧率窗口) > 30) { 列表_移除(AI_字体写字形_帧率窗口, 0) }
    如果 (计数(AI_字体写字形_帧率窗口) < 3) { 返回 60 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(AI_字体写字形_帧率窗口)) { 总 = 总 + AI_字体写字形_帧率窗口[i]; i = i + 1 }
    定义 平均帧耗时 = 总 / 计数(AI_字体写字形_帧率窗口)
    如果 (平均帧耗时 == 0) { 返回 60 }
    返回 1000 / 平均帧耗时
}

函数 AI_字体写字形_质量降级建议(帧率) {
    如果 (帧率 < 30) { 返回 "降低分辨率" }
    如果 (帧率 < 45) { 返回 "跳过阴影" }
    返回 "全质量"
}

导入("../核心/FFI桥接.nova")
导入("../核心/设备管理.nova")
导入("../../../标准库/基础.nova")
导入("../../../标准库/数学/信号处理.nova")

//
// Nova GPU AMD rocFFT 完整接入
// GPU快速傅里叶变换 AMD等价cuFFT + CPU回退

// 常量
定义 rocFFT_正变换 = -1
定义 rocFFT_逆变换 = 1
定义 rocFFT_复数交织 = 0
定义 rocFFT_实数 = 2
定义 快速傅里叶_圆周率 = 3141592653

定义 可变 _rocFFT库 = 0
定义 可变 _rocfft_可用 = 假
定义 可变 _rocfft_操作计数 = 0

// 库加载

函数 rocFFT_方向值(方向) {
    如果 (方向 == rocFFT_正变换) { 返回 0
}
 返回 1
}

函数 rocFFT_加载() {
    如果 (_rocFFT库 != 0) { 返回 _rocFFT库
}
 _rocFFT库 = GPU_加载ROCm候选([
 "rocfft.dll",
 "librocfft.so"
 ])
 如果 (_rocFFT库 != 0) { _rocfft_可用 = 真 }
 返回 _rocFFT库
}

函数 rocFFT_初始化() { 定义 lib = rocFFT_加载()
 如果 (lib == 0) { 返回 假 }
 返回 外部调用(lib,  "rocfft_setup", 0, 0, 0, 0, 0) == 0
}

函数 rocFFT_可用() { 返回 _rocfft_可用 }

// GPU FFT

函数 rocFFT_一维变换(输入, 输出, N, 方向) { _rocfft_操作计数 = _rocfft_操作计数 + 1
 定义 lib = rocFFT_加载()
 如果 (lib == 0) { 返回 CPU_快速傅里叶(输入, N, 方向) }
 定义 plan = 外部调用N(lib, "rocfft_plan_create",
 [0, 0, rocFFT_方向值(方向), 0, 1, [N], 1, 0])
 定义 info = 外部调用(lib,  "rocfft_execution_info_create", 0, 0, 0, 0, 0)
 定义 结果 = 外部调用5(lib,  "rocfft_execute",  plan,  [输入],  [输出],  info, 0)
 外部调用(lib,  "rocfft_plan_destroy",  plan, 0, 0, 0, 0)
 外部调用(lib,  "rocfft_execution_info_destroy",  info, 0, 0, 0, 0)
 返回 结果 == 0
}

函数 rocFFT_二维变换(输入, 输出, NX, NY, 方向) { _rocfft_操作计数 = _rocfft_操作计数 + 1
 定义 lib = rocFFT_加载()
 如果 (lib == 0) { 返回 假 }
 定义 plan = 外部调用N(lib, "rocfft_plan_create",
 [0, 0, rocFFT_方向值(方向), 0, 2, [NX, NY], 1, 0])
 定义 info = 外部调用(lib,  "rocfft_execution_info_create", 0, 0, 0, 0, 0)
 定义 结果 = 外部调用5(lib,  "rocfft_execute",  plan,  [输入],  [输出],  info, 0)
 外部调用(lib,  "rocfft_plan_destroy",  plan, 0, 0, 0, 0)
 外部调用(lib,  "rocfft_execution_info_destroy",  info, 0, 0, 0, 0)
 返回 结果 == 0
}

函数 rocFFT_清理() { 定义 lib = rocFFT_加载()
 如果 (lib != 0) { 外部调用(lib,  "rocfft_cleanup", 0, 0, 0, 0, 0) }
}

// CPU回退: Cooley-Tukey FFT

函数 CPU_快速傅里叶(数据, N, 方向) {
    如果 (N <= 1) { 返回 数据
}
 如果 (N % 2 != 0) { 返回 CPU_离散傅里叶(数据, N, 方向) }
 定义 可变 偶实 = []
 定义 可变 偶虚 = []
 定义 可变 奇实 = []
 定义 可变 奇虚 = []
 定义 可变 i = 0
 当 (i < N) { 如果 (i % 2 == 0) {
 追加(偶实, 数据[i * 2])
 追加(偶虚, 数据[i * 2 + 1])
 } 否则 {
 追加(奇实, 数据[i * 2])
 追加(奇虚, 数据[i * 2 + 1])
 }
 i = i + 1
 }
 定义 可变 偶数据 = []
 i = 0
 当 (i < N / 2) { 追加(偶数据, 偶实[i]) 追加(偶数据, 偶虚[i]) i = i + 1 }
 定义 可变 奇数据 = []
 i = 0
 当 (i < N / 2) { 追加(奇数据, 奇实[i]) 追加(奇数据, 奇虚[i]) i = i + 1 }
 偶数据 = CPU_快速傅里叶(偶数据, N / 2, 方向)
 奇数据 = CPU_快速傅里叶(奇数据, N / 2, 方向)
 定义 可变 结果 = []
 i = 0
 当 (i < N * 2) { 追加(结果, 0) i = i + 1 }
 i = 0
 当 (i < N / 2) { 定义 角度 = 方向 * 2 * 快速傅里叶_圆周率 * i / (N * 1000000000)
 定义 cos_v = FFT_余弦近似(角度)
 定义 sin_v = FFT_正弦近似(角度)
 定义 t实 = cos_v * 奇数据[i * 2] - sin_v * 奇数据[i * 2 + 1]
 定义 t虚 = cos_v * 奇数据[i * 2 + 1] + sin_v * 奇数据[i * 2]
 结果[i * 2] = 偶数据[i * 2] + t实
 结果[i * 2 + 1] = 偶数据[i * 2 + 1] + t虚
 结果[(i + N / 2) * 2] = 偶数据[i * 2] - t实
 结果[(i + N / 2) * 2 + 1] = 偶数据[i * 2 + 1] - t虚
 i = i + 1
 }
 返回 结果
}

// CPU 离散傅里叶变换 (暴力, 0)

函数 CPU_离散傅里叶(数据, N, 方向) { 定义 可变 结果 = []
 定义 可变 k = 0
 当 (k < N) { 定义 可变 实 = 0
 定义 可变 虚 = 0
 定义 可变 n = 0
 当 (n < N) { 定义 角度 = 方向 * 2 * 快速傅里叶_圆周率 * k * n / (N * 1000000000)
 定义 cos_v = FFT_余弦近似(角度)
 定义 sin_v = FFT_正弦近似(角度)
 实 = 实 + 数据[n * 2] * cos_v - 数据[n * 2 + 1] * sin_v
 虚 = 虚 + 数据[n * 2] * sin_v + 数据[n * 2 + 1] * cos_v
 n = n + 1
 }
 追加(结果, 实)
 追加(结果, 虚)
 k = k + 1
 }
 返回 结果
}

// 三角函数近似 (Taylor展开)

函数 FFT_余弦近似(x) {
 当 (x > 快速傅里叶_圆周率) { x = x - 2 * 快速傅里叶_圆周率 }
 当 (x < 0 - 快速傅里叶_圆周率) { x = x + 2 * 快速傅里叶_圆周率 }
 定义 x2 = x * x / 1000000000 / 1000000000
 返回 1000000000 - x2 * 500000000 + x2 * x2 * 41666667 / 1000000000
}

函数 FFT_正弦近似(x) {
 当 (x > 快速傅里叶_圆周率) { x = x - 2 * 快速傅里叶_圆周率 }
 当 (x < 0 - 快速傅里叶_圆周率) { x = x + 2 * 快速傅里叶_圆周率 }
 定义 x2 = x * x / 1000000000 / 1000000000
 返回 x - x * x2 * 166666667 / 1000000000 + x * x2 * x2 * 8333333 / 1000000000 / 1000000000
}

// 窗函数

函数 窗_汉宁(N) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < N) { 定义 角度 = 2 * 快速傅里叶_圆周率 * i / ((N - 1) * 1000000000)
 定义 值 = 500000000 - 500000000 * FFT_余弦近似(角度) / 1000000000
 追加(结果, 值)
 i = i + 1
 }
 返回 结果
}

函数 窗_汉明(N) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < N) { 定义 角度 = 2 * 快速傅里叶_圆周率 * i / ((N - 1) * 1000000000)
 定义 值 = 538000000 - 462000000 * FFT_余弦近似(角度) / 1000000000
 追加(结果, 值)
 i = i + 1
 }
 返回 结果
}

函数 窗_矩形(N) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < N) { 追加(结果, 1000000000) i = i + 1 }
 返回 结果
}

函数 窗_三角(N) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < N) { 定义 可变 值 = 0
 如果 (i <= N / 2) { 值 = 2 * i * 1000000000 / (N - 1) }
 否则 { 值 = 2 * (N - 1 - i) * 1000000000 / (N - 1) }
 追加(结果, 值)
 i = i + 1
 }
 返回 结果
}

函数 应用窗函数(数据, 窗, N) { 定义 可变 i = 0
 当 (i < N) {
 数据[i * 2] = 数据[i * 2] * 窗[i] / 1000000000
 数据[i * 2 + 1] = 数据[i * 2 + 1] * 窗[i] / 1000000000
 i = i + 1
 }
}

// 频谱分析

函数 rocFFT_频谱_幅度(fft数据, N) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < N) { 定义 实 = fft数据[i * 2]
 定义 虚 = fft数据[i * 2 + 1]
 定义 幅 = 实 * 实 + 虚 * 虚
 追加(结果, 幅)
 i = i + 1
 }
 返回 结果
}

函数 频谱_功率(fft数据, N) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < N) { 定义 实 = fft数据[i * 2]
 定义 虚 = fft数据[i * 2 + 1]
 定义 功率 = (实 * 实 + 虚 * 虚) / N
 追加(结果, 功率)
 i = i + 1
 }
 返回 结果
}

函数 频谱_峰值(幅度, N) { 定义 可变 最大值 = 0
 定义 可变 最大索引 = 0
 定义 可变 i = 1
 当 (i < N / 2) { 如果 (幅度[i] > 最大值) { 最大值 = 幅度[i] 最大索引 = i }
 i = i + 1
 }
 返回 [最大索引, 最大值]
}

函数 频谱_主频率(幅度, N, 采样率) { 定义 峰 = 频谱_峰值(幅度, N)
 如果 (N == 0) { 返回 0 }
 返回 峰[0] * 采样率 / N
}

// 信号生成

函数 信号_正弦波(N, 频率, 采样率, 幅度) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < N) { 定义 角度 = 2 * 快速傅里叶_圆周率 * 频率 * i / (采样率 * 1000000000)
 定义 值 = 幅度 * FFT_正弦近似(角度) / 1000000000
 追加(数据, 值)
 追加(数据, 0)
 i = i + 1
 }
 返回 数据
}

函数 信号_方波(N, 频率, 采样率, 幅度) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < N) { 定义 角度 = 2 * 快速傅里叶_圆周率 * 频率 * i / (采样率 * 1000000000)
 定义 可变 值 = 幅度
 如果 (FFT_正弦近似(角度) < 0) { 值 = 0 - 幅度 }
 追加(数据, 值)
 追加(数据, 0)
 i = i + 1
 }
 返回 数据
}

函数 信号_白噪声(N, 幅度) { 定义 可变 数据 = []
 定义 可变 种子 = 42
 定义 可变 i = 0
 当 (i < N) {
 种子 = (种子 * 1103515245 + 12345) % 2147483648
 如果 (种子 < 0) { 种子 = 0 - 种子 }
 定义 值 = (种子 % (2 * 幅度)) - 幅度
 追加(数据, 值)
 追加(数据, 0)
 i = i + 1
 }
 返回 数据
}

// 卷积

函数 线性卷积(信号, 核, 信号长, 核长) { 定义 可变 结果 = []
 定义 结果长 = 信号长 + 核长 - 1
 定义 可变 i = 0
 当 (i < 结果长) { 追加(结果, 0) i = i + 1 }
 i = 0
 当 (i < 信号长) { 定义 可变 j = 0
 当 (j < 核长) {
 结果[i + j] = 结果[i + j] + 信号[i] * 核[j]
 j = j + 1
 }
 i = i + 1
 }
 返回 结果
}

函数 FFT_策略选择(N) {
    如果 (N <= 16) { 返回 "DFT直接计算"
}
 定义 可变 n = N
 定义 可变 是2幂 = 真
 当 (n > 1) { 如果 (n % 2 != 0) { 是2幂 = 假 }
 n = n / 2
 }
 如果 (是2幂) { 返回 "Cooley-Tukey基2 FFT" }
 如果 (N % 3 == 0) { 返回 "混合基FFT(含基3)" }
 返回 "Bluestein算法(任意长度)"
}

函数 FFT_性能预测(N, 使用GPU) { 定义 可变 运算量 = N * 5
 定义 可变 t = N
 当 (t > 1) { 运算量 = 运算量 + N t = t / 2 }
 如果 (使用GPU) { 如果 (N < 256) { 返回 "GPU开销大于收益" }
 如果 (N < 65536) { 返回 "GPU中等加速(约5-20x)" }
 返回 "GPU显著加速(约50-200x)"
 }
 如果 (N > 100000) { 返回 "建议GPU加速" }
 返回 "CPU处理可接受"
}

函数 窗函数_推荐(应用场景) {
    如果 (应用场景 == "频率测量") { 返回 "矩形窗(最佳频率分辨率)"
}
 如果 (应用场景 == "通用分析") { 返回 "汉宁窗(泄漏抑制好)" }
 如果 (应用场景 == "幅度精确") { 返回 "平顶窗(幅度精度最高)" }
 如果 (应用场景 == "噪声分析") { 返回 "汉明窗(旁瓣抑制)" }
 返回 "汉宁窗(通用推荐)"
}

// 互相关

函数 FFT_互相关(信号1, 信号2, N) { 定义 可变 结果 = []
 定义 可变 延迟 = 0 - N + 1
 当 (延迟 < N) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < N) { 定义 j = i + 延迟
 如果 (j >= 0 且 j < N) {
 和 = 和 + 信号1[i * 2] * 信号2[j * 2] + 信号1[i * 2 + 1] * 信号2[j * 2 + 1]
 }
 i = i + 1
 }
 追加(结果, 和)
 延迟 = 延迟 + 1
 }
 返回 结果
}

函数 FFT_自相关(信号, N) { 返回 互相关(信号, 信号, N)
}

// 简单滤波器

函数 FFT_低通滤波(数据, N, 截止频率索引) { 定义 可变 i = 截止频率索引
 当 (i < N - 截止频率索引) {
 数据[i * 2] = 0
 数据[i * 2 + 1] = 0
 i = i + 1
 }
}

函数 FFT_高通滤波(数据, N, 截止频率索引) { 定义 可变 i = 0
 当 (i < 截止频率索引) {
 数据[i * 2] = 0
 数据[i * 2 + 1] = 0
 i = i + 1
 }
 i = N - 截止频率索引
 当 (i < N) {
 数据[i * 2] = 0
 数据[i * 2 + 1] = 0
 i = i + 1
 }
}

函数 带通滤波(数据, N, 低截止, 高截止) { 定义 可变 i = 0
 当 (i < N) { 如果 (i < 低截止 或 (i > 高截止 且 i < N - 高截止) 或 i >= N - 低截止) {
 数据[i * 2] = 0
 数据[i * 2 + 1] = 0
 }
 i = i + 1
 }
}

// 移动平均

函数 rocF_移动平均(数据, N, 窗口大小) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < N) { 定义 可变 和 = 0
 定义 可变 计 = 0
 定义 可变 j = i - 窗口大小 / 2
 当 (j <= i + 窗口大小 / 2) { 如果 (j >= 0 且 j < N) {
 和 = 和 + 数据[j]
 计 = 计 + 1
 }
 j = j + 1
 }
 如果 (计 > 0) { 追加(结果, 和 / 计) }
 否则 { 追加(结果, 0) }
 i = i + 1
 }
 返回 结果
}

// 信号统计

函数 FFT_信号_均值(数据, N) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < N) { 和 = 和 + 数据[i * 2] i = i + 1 }
 如果 (N == 0) { 返回 0 }
 返回 和 / N
}

函数 FFT_信号_能量(数据, N) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < N) {
 和 = 和 + 数据[i * 2] * 数据[i * 2] + 数据[i * 2 + 1] * 数据[i * 2 + 1]
 i = i + 1
 }
 返回 和
}

函数 信号_峰峰值(数据, N) { 定义 可变 最大 = 数据[0]
 定义 可变 最小 = 数据[0]
 定义 可变 i = 1
 当 (i < N) { 如果 (数据[i * 2] > 最大) { 最大 = 数据[i * 2] }
 如果 (数据[i * 2] < 最小) { 最小 = 数据[i * 2] }
 i = i + 1
 }
 返回 最大 - 最小
}

函数 rocF_信号_过零率(数据, N) { 定义 可变 过零 = 0
 定义 可变 i = 1
 当 (i < N) { 定义 可变 发生过零 = 假
 如果 (数据[(i - 1) * 2] >= 0 且 数据[i * 2] < 0) { 发生过零 = 真 }
 如果 (数据[(i - 1) * 2] < 0 且 数据[i * 2] >= 0) { 发生过零 = 真 }
 如果 (发生过零) {
 过零 = 过零 + 1
 }
 i = i + 1
 }
 返回 过零
}

函数 信号_质量评估(数据, N) { 定义 能量 = 信号_能量(数据, N)
 定义 峰峰 = 信号_峰峰值(数据, N)
 定义 过零 = 信号_过零率(数据, N)
 定义 可变 评分 = 100
 如果 (能量 == 0) { 返回 [0, "空信号"] }
 如果 (峰峰 == 0) { 返回 [10, "直流信号"] }
 如果 (过零 > N / 2) { 评分 = 评分 - 10 }
 返回 [评分, "正常信号"]
}

// 2的幂辅助

函数 FFT_下一个2幂(n) { 定义 可变 p = 1
 当 (p < n) {
 p = p * 2
 }
 返回 p
}

函数 FFT_是2幂(n) {
    如果 (n <= 0) { 返回 假
}
 如果 (n == 1) { 返回 真 }
 返回 n % 2 == 0 且 n / 2 * 2 == n
}

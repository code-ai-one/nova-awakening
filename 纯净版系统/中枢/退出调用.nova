    返回 0
}

// 完整统计 (≥15个指标)

函数 退出调用_完整统计() {
    定义 总操作 = exit_次数 + exit_group_次数 + wait_次数 + waitid_次数 + fork_次数 + clone_次数 + execve_次数 + setsid_次数 + uname_次数 + sysinfo_次数
    定义 统计 = 字典()
    字典设(统计, "已初始化", 退出_已初始化)
    字典设(统计, "exit", exit_次数)
    字典设(统计, "exit_group", exit_group_次数)
    字典设(统计, "wait", wait_次数)
    字典设(统计, "waitid", waitid_次数)
    字典设(统计, "fork", fork_次数)
    字典设(统计, "clone", clone_次数)
    字典设(统计, "execve", execve_次数)
    字典设(统计, "setsid", setsid_次数)
    字典设(统计, "uname", uname_次数)
    字典设(统计, "sysinfo", sysinfo_次数)
    字典设(统计, "总操作", 总操作)
    字典设(统计, "平均延迟(ns)", 退出_平均延迟())
    字典设(统计, "最大延迟(ns)", 退出_最大延迟)
    字典设(统计, "速率", 退出_速率)
    字典设(统计, "峰值速率", 退出_峰值速率)
    字典设(统计, "错误数", 退出_错误数)
    返回 统计
}

函数 退出调用_打印统计() {
    定义 统计 = 退出调用_完整统计()
    打印("[退出调用] ═══════ 完整统计 ═══════")
    打印("  exit:         " + 转字符串(字典取(统计, "exit")))
    打印("  exit_group:   " + 转字符串(字典取(统计, "exit_group")))
    打印("  wait:         " + 转字符串(字典取(统计, "wait")))
    打印("  waitid:       " + 转字符串(字典取(统计, "waitid")))
    打印("  fork:         " + 转字符串(字典取(统计, "fork")))
    打印("  clone:        " + 转字符串(字典取(统计, "clone")))
    打印("  execve:       " + 转字符串(字典取(统计, "execve")))
    打印("  setsid:       " + 转字符串(字典取(统计, "setsid")))
    打印("  uname:        " + 转字符串(字典取(统计, "uname")))
    打印("  sysinfo:      " + 转字符串(字典取(统计, "sysinfo")))
    打印("  总操作:       " + 转字符串(字典取(统计, "总操作")))
    打印("  平均延迟:     " + 转字符串(字典取(统计, "平均延迟(ns)")) + "ns")
    打印("  速率:         " + 转字符串(字典取(统计, "速率")) + " 次/秒")
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    打印("[退出调用] ═════════════════════════")
    返回 0
}

函数 退出调用_dump() {
    打印("[退出调用 dump] ──────────────────")
    打印("  exit: " + 转字符串(exit_次数))

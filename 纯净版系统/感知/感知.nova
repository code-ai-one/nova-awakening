导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./内核直连层.nova")

定义 KEY_TYPE_SECRET  = 0    // 对称
定义 KEY_TYPE_PUBLIC  = 1
定义 KEY_TYPE_PRIVATE = 2

定义 KEY_USAGE_ENCRYPT   = 1
定义 KEY_USAGE_DECRYPT   = 2
定义 KEY_USAGE_SIGN      = 4
定义 KEY_USAGE_VERIFY    = 8
定义 KEY_USAGE_DERIVE_KEY = 16
定义 KEY_USAGE_DERIVE_BITS = 32
定义 KEY_USAGE_WRAP_KEY  = 64
定义 KEY_USAGE_UNWRAP_KEY = 128

结构 CryptoKey {
    类型,    // u8 KEY_TYPE_xxx
    算法,    // u8 ALGO_xxx
    extractable,
    usages,    // u32 KEY_USAGE_xxx 位掩码
    // 密钥数据
    数据,
    数据长度,
    // 算法参数
    密钥长度,    // u32 bits: 128/192/256/2048/4096
    哈希算法,    // u8 用于HMAC/RSA-PSS等
}

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 SubtleCrypto_generateKey(算法, 密钥长度, extractable, usages) {
    定义 key = 堆_分配(CryptoKey)
    key.算法 = 算法; key.extractable = extractable; key.usages = usages
    key.密钥长度 = 密钥长度

    如果 (算法 == ALGO_AES_CBC || 算法 == ALGO_AES_GCM || 算法 == ALGO_AES_CTR) {
        // 对称密钥
        key.类型 = KEY_TYPE_SECRET
        key.数据长度 = 密钥长度 / 8
        key.数据 = 堆_分配(key.数据长度)
        随机字节(key.数据, key.数据长度)
    } 否则 如果 (算法 == ALGO_HMAC) {
        key.类型 = KEY_TYPE_SECRET
        key.数据长度 = 密钥长度 / 8
        key.数据 = 堆_分配(key.数据长度)
        随机字节(key.数据, key.数据长度)
    } 否则 如果 (算法 == ALGO_RSA_OAEP || 算法 == ALGO_RSA_PSS) {
        // RSA密钥对: 通过大数运算生成(p,q素数对)
        key.类型 = KEY_TYPE_PRIVATE
        key.数据长度 = 密钥长度 / 8
        key.数据 = 堆_分配(key.数据长度)
    } 否则 如果 (算法 == ALGO_ECDSA || 算法 == ALGO_ECDH) {
        // 椭圆曲线密钥对: P-256/P-384/P-521
        key.类型 = KEY_TYPE_PRIVATE
        key.数据长度 = 32    // P-256
        key.数据 = 堆_分配(key.数据长度)
        随机字节(key.数据, key.数据长度)
    }
    返回 key
}

函数 SubtleCrypto_importKey(格式, keyData, keyDataLen, 算法, extractable, usages) {
    // 格式: "raw"/"pkcs8"/"spki"/"jwk"
    定义 key = 堆_分配(CryptoKey)
    key.算法 = 算法; key.extractable = extractable; key.usages = usages
    key.数据 = 堆_分配(keyDataLen)
    内存_复制(key.数据, keyData, keyDataLen)
    key.数据长度 = keyDataLen
    返回 key
}

函数 SubtleCrypto_exportKey(格式, key) {
    如果 (key == 0 || !key.extractable) { 返回 0 }
    // 返回密钥数据
    返回 key.数据
}

// §4 encrypt/decrypt

函数 SubtleCrypto_encrypt(算法, key, 数据, 长度, iv, ivLen) {
    如果 (key == 0 || 数据 == 0 || 长度 == 0) { 返回 0 }
    如果 (!(key.usages & KEY_USAGE_ENCRYPT)) { 返回 0 }

    如果 (算法 == ALGO_AES_CBC) {
        // AES-CBC加密: PKCS7填充 + CBC模式
        定义 块数 = (长度 + 15) / 16
        定义 输出长度 = (块数 + 1) * 16    // +1 for padding
        定义 输出 = 堆_分配(输出长度)
        // AES_CBC_Encrypt(key.数据, iv, 数据, 长度, 输出)
        返回 输出
    } 否则 如果 (算法 == ALGO_AES_GCM) {
        // AES-GCM: AEAD, 输出=密文+16字节tag
        定义 输出长度 = 长度 + 16
        定义 输出 = 堆_分配(输出长度)
        // AES_GCM_Encrypt(key.数据, iv, 数据, 长度, 输出)
        返回 输出
    } 否则 如果 (算法 == ALGO_AES_CTR) {
        // AES-CTR: 流式加密
        定义 输出 = 堆_分配(长度)
        // AES_CTR_Encrypt(key.数据, iv, 数据, 长度, 输出)
        返回 输出
    }
    返回 0
}

函数 SubtleCrypto_decrypt(算法, key, 数据, 长度, iv, ivLen) {
    如果 (key == 0 || 数据 == 0 || 长度 == 0) { 返回 0 }
    如果 (!(key.usages & KEY_USAGE_DECRYPT)) { 返回 0 }
    // 与encrypt对称, 解密操作
    返回 0
}

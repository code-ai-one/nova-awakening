函数 Nova文件节点_创建_文件(权限) { 返回 Nova文件节点_创建(S_IFREG, 权限) }
函数 Nova文件节点_创建_目录(权限) {
    定义 可变 节点 = Nova文件节点_创建(S_IFDIR, 权限)
    节点.链接数 = 2   // . 和 父目录的引用
    返回 节点
}
函数 Nova文件节点_创建_符号链接() { 返回 Nova文件节点_创建(S_IFLNK, S_IRWXU | S_IRWXG | S_IRWXO) }
函数 Nova文件节点_创建_字符设备(权限, 设备号) {
    定义 可变 节点 = Nova文件节点_创建(S_IFCHR, 权限)
    节点.设备号 = 设备号
    返回 节点
}
函数 Nova文件节点_创建_块设备(权限, 设备号) {
    定义 可变 节点 = Nova文件节点_创建(S_IFBLK, 权限)
    节点.设备号 = 设备号
    返回 节点
}

// Nova文件节点引用计数 

函数 Nova节点_增引用(节点) {
    自旋锁_获取(节点.锁)
    节点.引用计数 = 节点.引用计数 + 1
    自旋锁_释放(节点.锁)
}

函数 Nova文件节点_减引用(节点) {
    自旋锁_获取(节点.锁)
    节点.引用计数 = 节点.引用计数 - 1
    如果 (节点.引用计数 == 0) {
        自旋锁_释放(节点.锁)
        // 引用归零: 放入LRU等待回收 
        如果 (节点.链接数 == 0) {
            // 无硬链接: 真正删除(truncate + deallocate)
            Nova文件节点_删除(节点)
        } 否则 {
            // 有链接但无引用: 放入LRU缓存
            链表_尾插(Nova文件节点_LRU, 节点)
            Nova文件节点_LRU数 = Nova文件节点_LRU数 + 1
        }
        返回
    }
    自旋锁_释放(节点.锁)
}

函数 Nova文件节点_删除(节点) {
    // 清除Nova文件节点内容(truncate到0), 释放所有数据块
    节点.大小 = 0
    节点.块数 = 0
    节点.已释放 = 真
    Nova文件节点总数 = Nova文件节点总数 - 1
    // 从哈希表移除
    // 释放回Nova块缓存缓存
}

// 链接数管理 

函数 Nova文件节点_增链接(节点) { 节点.链接数 = 节点.链接数 + 1 }
函数 Nova文件节点_减链接(节点) {
    如果 (节点.链接数 > 0) { 节点.链接数 = 节点.链接数 - 1 }
}
函数 Nova文件节点_清链接(节点) { 节点.链接数 = 0 }

// 脏标记 

函数 Nova文件节点_标记脏(节点) {
    如果 (!节点.脏) {
        节点.脏 = 真
        节点.脏时间 = 读取毫秒()
        // 加入超级块的脏Nova文件节点链表
        如果 (节点.超级块 != 空) {
            定义 sb = 节点.超级块
            如果 (sb.脏Nova文件节点链表 == 空) { sb.脏Nova文件节点链表 = [] }
            追加(sb.脏Nova文件节点链表, 节点)
        }
        // 通知回写子系统有新脏页
        回写_唤醒()
    }
}

函数 回写_唤醒() {
    // 唤醒后台回写线程(如果脏页比例超过阈值)
    定义 脏页 = 获取全局脏页数()
    如果 (脏页 > 总页数 / 10) {
        唤醒进程(回写线程)
    }
}

函数 Nova文件节点_清除脏(节点) { 节点.脏 = 假 }

// 权限检查 

定义 MAY_READ    = 4
定义 MAY_WRITE   = 2
定义 MAY_EXEC    = 1

函数 Nova文件节点_权限检查(节点, 请求uid, 请求gid, 掩码) {
    定义 模式 = 节点.模式
    // root可以做任何事
    如果 (请求uid == 0) { 返回 成功 }
    // 确定使用哪组权限位
    定义 可变 权限位 = 0
    如果 (请求uid == 节点.uid) {
        权限位 = (模式 >> 6) & 7    // 用户位
    } 否则 如果 (请求gid == 节点.gid) {
        权限位 = (模式 >> 3) & 7    // 组位
    } 否则 {
        权限位 = 模式 & 7           // 其他人位
    }
    // 检查请求的权限是否被包含
    如果 ((掩码 & ~权限位) != 0) {
        返回 错误_无权限
    }
    返回 成功
}

// 查询函数 (向后兼容)

函数 Nova节点_是目录(节点) { 返回 S_ISDIR(节点.模式) }
函数 Nova节点_是文件(节点) { 返回 S_ISREG(节点.模式) }
函数 Nova节点_是符号链接(节点) { 返回 S_ISLNK(节点.模式) }
函数 Nova文件节点_是字符设备(节点) { 返回 S_ISCHR(节点.模式) }
函数 Nova文件节点_大小(节点) { 返回 节点.大小 }
函数 Nova文件节点_设置大小(节点, 大小) {
    节点.大小 = 大小
    Nova文件节点_标记脏(节点)
}

// Nova文件节点缓存统计

函数 Nova文件节点_统计() {
    返回 [Nova文件节点总数, Nova文件节点_LRU数, 下一个Nova文件节点号 - 1]
}

// 别名函数(被ram文件系统模块
函数 Nova文件节点_设置file_ops(节点, ops) { 节点.file_ops = ops }
函数 Nova文件节点_获取私有(节点) { 返回 节点.私有数据 }
函数 Nova文件节点_设私有(节点, 数据) { 节点.私有数据 = 数据 }

// 别名(被ram文件系统模块
函数 Nova文件节点_权限(节点, 掩码) {
    如果 (节点 == 空) { 返回 假 }
    返回 (节点.模式 & 掩码) == 掩码
}
函数 Nova文件节点_设置链接目标(节点, 目标) { 节点.链接目标 = 目标 }
函数 Nova文件节点_设置Nova文件节点_ops(节点, ops) { 节点.Nova文件节点_ops = ops }
函数 Nova文件节点_超级块(节点) { 返回 节点.超级块 }

定义 可变 AI_文件节点创_热文件表 = []

函数 AI_文件节点创_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_文件节点创_热文件表)) {
        如果 (AI_文件节点创_热文件表[i].路径 == 路径) {
            AI_文件节点创_热文件表[i].频率 = AI_文件节点创_热文件表[i].频率 + 1
            返回 AI_文件节点创_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_文件节点创_热文件表) < 128) {
        追加(AI_文件节点创_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_文件节点创_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

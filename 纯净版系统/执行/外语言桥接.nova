        // stdio.h
        ["printf",   "Nova_printf"],
        ["scanf",    "Nova_scanf"],
        ["fopen",    "Nova_fopen"],
        ["fclose",   "Nova_fclose"],
        ["fread",    "Nova_fread"],
        ["fwrite",   "Nova_fwrite"],
        ["fprintf",  "Nova_fprintf"],
        ["puts",     "Nova_puts"],
        ["getchar",  "Nova_getchar"],

        // stdlib.h
        ["malloc",   "Nova_堆分配"],
        ["free",     "Nova_堆释放"],
        ["calloc",   "Nova_堆分配清零"],
        ["realloc",  "Nova_堆重分配"],
        ["exit",     "Nova_退出"],
        ["atoi",     "Nova_字串转整数"],
        ["atof",     "Nova_字串转浮点"],
        ["rand",     "Nova_随机数"],
        ["srand",    "Nova_设随机种子"],
        ["qsort",    "Nova_快速排序"],
        ["abs",      "Nova_绝对值"],

        // string.h
        ["strlen",   "Nova_字串长度"],
        ["strcpy",   "Nova_字串拷贝"],
        ["strcat",   "Nova_字串连接"],
        ["strcmp",    "Nova_字串比较"],
        ["memcpy",   "Nova_内存拷贝"],
        ["memset",   "Nova_内存填充"],
        ["memmove",  "Nova_内存移动"],

        // math.h
        ["sin",      "Nova_正弦"],
        ["cos",      "Nova_余弦"],
        ["sqrt",     "Nova_平方根"],
        ["pow",      "Nova_乘方"],
        ["log",      "Nova_对数"],
        ["floor",    "Nova_下取整"],
        ["ceil",     "Nova_上取整"],

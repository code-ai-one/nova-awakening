定义 可变 打包_总操作数 = 0
定义 可变 打包_总字节数 = 0
定义 可变 点积_总次数 = 0
定义 可变 前向_总次数 = 0

函数 TNF_打包5(t0, t1, t2, t3, t4) {
    打包_总操作数 = 打包_总操作数 + 1
    返回 (t0 + 1) + (t1 + 1) * 3 + (t2 + 1) * 9 + (t3 + 1) * 27 + (t4 + 1) * 81
}

函数 TNF_解包5(字节) {
    打包_总操作数 = 打包_总操作数 + 1
    定义 可变 结果 = []
    定义 可变 v = 字节
    定义 可变 i = 0
    当 (i < 5) {
        TNF_追加(结果, v % 3 - 1)
        v = v / 3
        i = i + 1
    }
    返回 结果
}

函数 TNF_批量打包(三态数组) {
    定义 n = 计数(三态数组)
    定义 可变 字节数组 = []
    定义 可变 i = 0
    当 (i + 4 < n) {
        追加(字节数组, TNF_打包5(三态数组[i], 三态数组[i+1],
            三态数组[i+2], 三态数组[i+3], 三态数组[i+4]))
        i = i + 5
    }
    如果 (i < n) {
        定义 可变 t = [0, 0, 0, 0, 0]
        定义 可变 j = 0
        当 (i + j < n && j < 5) {
            t[j] = 三态数组[i + j]
            j = j + 1
        }
        追加(字节数组, TNF_打包5(t[0], t[1], t[2], t[3], t[4]))
    }
    打包_总字节数 = 打包_总字节数 + 计数(字节数组)
    返回 字节数组
}

函数 TNF_批量解包(字节数组, 总元素数) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(字节数组)) {
        定义 五元 = TNF_解包5(字节数组[i])
        定义 可变 j = 0
        当 (j < 5 && 计数(结果) < 总元素数) {
            TNF_追加(结果, 五元[j])
            j = j + 1
        }
        i = i + 1
    }
    返回 结果
}

函数 TNF_打包压缩率(原始大小) {
    返回 (原始大小 + 4) / 5
}

函数 TNF_向量_创建(大小) {
    定义 可变 v = []
    定义 可变 i = 0
    当 (i < 大小) { TNF_追加(v, 平); i = i + 1 }
    返回 v
}

函数 TNF_随机三态() {
    返回 TNF_随机() % 3 - 1
}

函数 TNF_向量_随机(大小) {
    定义 可变 v = []
    定义 可变 i = 0
    当 (i < 大小) { TNF_追加(v, TNF_随机三态()); i = i + 1 }
    返回 v
}

函数 TNF_向量_加(a, b) {
    定义 n = 计数(a)
    如果 (计数(b) < n) { n = 计数(b) }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < n) {
        定义 v = a[i] + b[i]
        如果 (v > 阳) { v = 阳 }
        如果 (v < 阴) { v = 阴 }
        TNF_追加(结果, v)
        i = i + 1
    }
    返回 结果
}

函数 TNF_向量_减(a, b) {
    定义 n = 计数(a)
    如果 (计数(b) < n) { n = 计数(b) }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < n) {
        定义 v = a[i] - b[i]
        如果 (v > 阳) { v = 阳 }
        如果 (v < 阴) { v = 阴 }
        TNF_追加(结果, v)
        i = i + 1
    }
    返回 结果
}

函数 TNF_向量_点积(a, b) {
    点积_总次数 = 点积_总次数 + 1
    定义 可变 sum = 0
    定义 可变 i = 0
    定义 n = 计数(a)
    如果 (计数(b) < n) { n = 计数(b) }
    当 (i < n) {
        sum = sum + a[i] * b[i]
        i = i + 1
    }
    返回 sum
}

函数 TNF_向量_范数(v) {
    定义 可变 sum = 0
    定义 可变 i = 0
    当 (i < 计数(v)) {
        sum = sum + v[i] * v[i]
        i = i + 1
    }
    返回 数学_开方(sum)
}

函数 TNF_向量_余弦相似度(a, b) {
    定义 点积 = TNF_向量_点积(a, b)
    定义 范数a = TNF_向量_范数(a)
    定义 范数b = TNF_向量_范数(b)
    如果 (范数a == 0 || 范数b == 0) { 返回 0 }
    返回 点积 * 1000 / (范数a * 范数b)
}

函数 TNF_向量_汉明距离(a, b) {
    定义 可变 距离 = 0
    定义 可变 i = 0
    定义 n = 计数(a)
    如果 (计数(b) < n) { n = 计数(b) }
    当 (i < n) {
        如果 (a[i] != b[i]) { 距离 = 距离 + 1 }
        i = i + 1
    }
    返回 距离
}

函数 TNF_向量_稀疏度(v) {
    定义 可变 零计数 = 0
    定义 可变 i = 0
    当 (i < 计数(v)) {
        如果 (v[i] == 平) { 零计数 = 零计数 + 1 }
        i = i + 1
    }
    如果 (计数(v) == 0) { 返回 0 }
    返回 零计数 * 1000 / 计数(v)
}

函数 TNF_向量_翻转(v) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(v)) {
        TNF_追加(结果, 0 - v[i])
        i = i + 1
    }
    返回 结果
}

函数 TNF_向量_拼接(a, b) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(a)) { TNF_追加(结果, a[i]); i = i + 1 }
    i = 0
    当 (i < 计数(b)) { TNF_追加(结果, b[i]); i = i + 1 }
    返回 结果
}

函数 TNF_向量_切片(v, 起始, 长度) {
    定义 可变 结果 = []
    定义 可变 i = 起始
    当 (i < 起始 + 长度 && i < 计数(v)) {
        TNF_追加(结果, v[i])
        i = i + 1
    }
    返回 结果
}

函数 TNF_稀疏点积(输入, 权重) {
    点积_总次数 = 点积_总次数 + 1
    定义 可变 sum = 0
    定义 可变 i = 0
    定义 n输入 = 计数(输入)
    定义 n权重 = 计数(权重)
    当 (i < n输入 && i < n权重) {
        如果 (权重[i] == 阳) { sum = sum + 输入[i] }
        否则 如果 (权重[i] == 阴) { sum = sum - 输入[i] }
        i = i + 1
    }
    返回 sum
}

函数 TNF_矩阵_创建(行, 列) {
    定义 可变 m = []
    定义 可变 r = 0
    当 (r < 行) {
        定义 可变 row = []
        定义 可变 c = 0
        当 (c < 列) { TNF_追加(row, 平); c = c + 1 }
        TNF_追加(m, row)
        r = r + 1
    }
    返回 m
}

函数 TNF_矩阵_随机(行, 列) {
    定义 可变 m = []
    定义 可变 r = 0
    当 (r < 行) {
        定义 可变 row = []
        定义 可变 c = 0
        当 (c < 列) { TNF_追加(row, TNF_随机三态()); c = c + 1 }
        TNF_追加(m, row)
        r = r + 1
    }
    返回 m
}

函数 TNF_矩阵_转置(m, 行, 列) {
    定义 可变 结果 = TNF_矩阵_创建(列, 行)
    定义 可变 r = 0
    当 (r < 行) {
        定义 可变 c = 0
        当 (c < 列) {
            结果[c][r] = m[r][c]
            c = c + 1
        }
        r = r + 1
    }
    返回 结果
}

函数 TNF_矩阵_乘(a, b, a行, a列, b列) {
    定义 可变 结果 = TNF_矩阵_创建(a行, b列)
    定义 可变 r = 0
    当 (r < a行) {
        定义 可变 c = 0
        当 (c < b列) {
            定义 可变 sum = 0
            定义 可变 k = 0
            当 (k < a列) {
                sum = sum + a[r][k] * b[k][c]
                k = k + 1
            }
            结果[r][c] = TNF_量化(sum)
            c = c + 1
        }
        r = r + 1
    }
    返回 结果
}

函数 TNF_矩阵_哈达玛(a, b, 行, 列) {
    定义 可变 结果 = TNF_矩阵_创建(行, 列)
    定义 可变 r = 0
    当 (r < 行) {
        定义 可变 c = 0
        当 (c < 列) {
            结果[r][c] = TNF_量化(a[r][c] * b[r][c])
            c = c + 1
        }
        r = r + 1
    }
    返回 结果
}

函数 TNF_矩阵_稀疏度(m, 行, 列) {
    定义 可变 零计数 = 0
    定义 可变 总计 = 行 * 列
    定义 可变 r = 0
    当 (r < 行) {
        定义 可变 c = 0
        当 (c < 列) {
            如果 (m[r][c] == 平) { 零计数 = 零计数 + 1 }
            c = c + 1
        }
        r = r + 1
    }
    如果 (总计 == 0) { 返回 0 }
    返回 零计数 * 1000 / 总计
}

函数 TNF_矩阵_序列化(m, 行, 列) {
    定义 可变 平面 = []
    定义 可变 r = 0
    当 (r < 行) {
        定义 可变 c = 0
        当 (c < 列) {
            TNF_追加(平面, m[r][c])
            c = c + 1
        }
        r = r + 1
    }
    返回 TNF_批量打包(平面)
}

函数 TNF_矩阵_反序列化(字节数组, 行, 列) {
    定义 平面 = TNF_批量解包(字节数组, 行 * 列)
    定义 可变 m = []
    定义 可变 r = 0
    当 (r < 行) {
        定义 可变 row = []
        定义 可变 c = 0
        当 (c < 列) {
            TNF_追加(row, 平面[r * 列 + c])
            c = c + 1
        }
        TNF_追加(m, row)
        r = r + 1
    }
    返回 m
}

函数 TNF_前向(输入, 权重矩阵, 行数) {
    前向_总次数 = 前向_总次数 + 1
    定义 可变 输出 = []
    定义 可变 r = 0
    当 (r < 行数) {
        定义 sum = TNF_稀疏点积(输入, 权重矩阵[r])
        TNF_追加(输出, TNF_量化(sum))
        r = r + 1
    }
    返回 输出
}

函数 TNF_前向_带偏置(输入, 权重矩阵, 偏置, 行数) {
    前向_总次数 = 前向_总次数 + 1
    定义 可变 输出 = []
    定义 可变 r = 0
    当 (r < 行数) {
        定义 sum = TNF_稀疏点积(输入, 权重矩阵[r])
        如果 (r < 计数(偏置)) { sum = sum + 偏置[r] }
        TNF_追加(输出, TNF_量化(sum))
        r = r + 1
    }
    返回 输出
}

函数 TNF_多层前向(输入, 层列表, 层行数列表) {
    定义 可变 当前 = 输入
    定义 可变 l = 0
    当 (l < 计数(层列表)) {
        当前 = TNF_前向(当前, 层列表[l], 层行数列表[l])
        l = l + 1
    }
    返回 当前
}

函数 TNF_残差前向(输入, 权重矩阵, 行数) {
    如果 (行数 != 计数(输入)) {
        返回 TNF_前向(输入, 权重矩阵, 行数)
    }
    定义 变换 = TNF_前向(输入, 权重矩阵, 行数)
    返回 TNF_向量_加(输入, 变换)
}

函数 TNF_打包_完整统计() {
    返回 [打包_总操作数, 打包_总字节数, 点积_总次数, 前向_总次数]
}

// §8 矩阵补充运算 — 范数/缩放/求和

函数 TNF_矩阵_范数(m, 行, 列) {
    定义 可变 最大 = 0
    定义 可变 r = 0
    当 (r < 行) {
        定义 可变 c = 0
        当 (c < 列) {
            定义 v = m[r][c]
            如果 (v < 0) { v = 0 - v }
            如果 (v > 最大) { 最大 = v }
            c = c + 1
        }
        r = r + 1
    }
    返回 最大
}

函数 TNF_矩阵_缩放(m, 行, 列, 因子) {
    定义 可变 结果 = TNF_矩阵_创建(行, 列)
    定义 可变 r = 0
    当 (r < 行) {
        定义 可变 c = 0
        当 (c < 列) {
            结果[r][c] = TNF_量化(m[r][c] * 因子 / 1000)
            c = c + 1
        }
        r = r + 1
    }
    返回 结果
}

函数 TNF_矩阵_加(a, b, 行, 列) {
    定义 可变 结果 = TNF_矩阵_创建(行, 列)
    定义 可变 r = 0
    当 (r < 行) {
        定义 可变 c = 0
        当 (c < 列) {
            结果[r][c] = TNF_量化(a[r][c] + b[r][c])
            c = c + 1
        }
        r = r + 1
    }
    返回 结果
}

函数 TNF_矩阵_行和(m, 行, 列, 行号) {
    如果 (行号 < 0 || 行号 >= 行) { 返回 0 }
    定义 可变 sum = 0
    定义 可变 c = 0
    当 (c < 列) {
        sum = sum + m[行号][c]
        c = c + 1
    }
    返回 sum
}

函数 TNF_矩阵_列和(m, 行, 列, 列号) {
    如果 (列号 < 0 || 列号 >= 列) { 返回 0 }
    定义 可变 sum = 0
    定义 可变 r = 0
    当 (r < 行) {
        sum = sum + m[r][列号]
        r = r + 1
    }
    返回 sum
}

// §9 重置与存取器

函数 TNF_重置统计() {
    打包_总操作数 = 0
    打包_总字节数 = 0
    点积_总次数 = 0
    前向_总次数 = 0
}

函数 TNF_获取打包操作数() { 返回 打包_总操作数 }
函数 TNF_获取打包字节数() { 返回 打包_总字节数 }
函数 TNF_获取点积次数() { 返回 点积_总次数 }
函数 TNF_获取前向次数() { 返回 前向_总次数 }

函数 TNF_打印统计() {
    内核信息("=== TNF 神经打包统计 ===")
    内核信息("打包操作: " + 整数转字符串(打包_总操作数))
    内核信息("打包字节: " + 整数转字符串(打包_总字节数))
    内核信息("点积次数: " + 整数转字符串(点积_总次数))
    内核信息("前向次数: " + 整数转字符串(前向_总次数))
}

函数 TNF_矩阵_迹(m, 尺寸) {
    定义 可变 sum = 0
    定义 可变 i = 0
    当 (i < 尺寸) {
        sum = sum + m[i][i]
        i = i + 1
    }
    返回 sum
}

函数 TNF_矩阵_单位(尺寸) {
    定义 可变 m = TNF_矩阵_创建(尺寸, 尺寸)
    定义 可变 i = 0
    当 (i < 尺寸) {
        m[i][i] = 正
        i = i + 1
    }
    返回 m
}

// ◆ TNP 理论 — Ternary Neural Packing
//   公理1: 三态值{-1,0,+1}可用最少2位无损编码
//   公理2: 稀疏点积只计算非零元 复杂度O(nnz)
//   公理3: 残差前向保留梯度路径 避免深层退化
//   定理: 对称量化误差在批量平均后收敛到零
//         E[ε_quant] = 0 when |batch| → ∞
//   推论: 5元打包压缩率 = ceil(n/5), 空间节约率60%

函数 TNF_向量_最大值(v) {
    定义 可变 最大 = 0
    定义 可变 i = 0
    当 (i < 计数(v)) {
        如果 (v[i] > 最大) { 最大 = v[i] }
        i = i + 1
    }
    返回 最大
}

函数 TNF_向量_最小值(v) {
    如果 (计数(v) == 0) { 返回 0 }
    定义 可变 最小 = v[0]
    定义 可变 i = 1
    当 (i < 计数(v)) {
        如果 (v[i] < 最小) { 最小 = v[i] }
        i = i + 1
    }
    返回 最小
}

函数 TNF_向量_总和(v) {
    定义 可变 sum = 0
    定义 可变 i = 0
    当 (i < 计数(v)) {
        sum = sum + v[i]
        i = i + 1
    }
    返回 sum
}

// §10 【原生独创】谐振打包压缩率预测器
// 基于历史打包数据预测最优压缩参数

定义 可变 _谐振打包_历史压缩率 = []
定义 可变 _谐振打包_预测次数 = 0

函数 谐振打包_记录压缩率(原始大小, 压缩大小) {
    如果 (原始大小 > 0) {
        定义 比率 = 压缩大小 * 1000 / 原始大小
        追加(_谐振打包_历史压缩率, 比率)
        如果 (计数(_谐振打包_历史压缩率) > 32) {
            定义 可变 新表 = []
            定义 可变 i = 计数(_谐振打包_历史压缩率) - 32
            当 (i < 计数(_谐振打包_历史压缩率)) {
                追加(新表, _谐振打包_历史压缩率[i])
                i = i + 1
            }
            _谐振打包_历史压缩率 = 新表
        }
    }
}

函数 谐振打包_预测缓冲区大小(原始大小) {
    如果 (计数(_谐振打包_历史压缩率) == 0) { 返回 原始大小 }
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < 计数(_谐振打包_历史压缩率)) {
        总和 = 总和 + _谐振打包_历史压缩率[i]
        i = i + 1
    }
    定义 平均率 = 总和 / 计数(_谐振打包_历史压缩率)
    _谐振打包_预测次数 = _谐振打包_预测次数 + 1
    返回 原始大小 * 平均率 / 1000 + 64
}

函数 神经打包_完整统计() {
    返回 [
        "谐振预测次数", _谐振打包_预测次数,
        "历史记录数", 计数(_谐振打包_历史压缩率)
    ]
}

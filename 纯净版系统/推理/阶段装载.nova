// 推理阶段装载
// 关键主链: 总线 / 语义 / 值型系统 / 渠道 / 模型上下文

导入("../中枢/阶段契约.nova")
导入("./智能总线初始.nova")
导入("./智能操作引擎.nova")
导入("./感知循环.nova")
导入("./智能渠道.nova")
导入("./通信总线.nova")
导入("./能力注册.nova")
导入("./自我升级.nova")
导入("./记忆管理.nova")
导入("./语义嵌入.nova")
导入("./上下文运行时.nova")
导入("./值型系统.nova")
导入("./会话管理.nova")
导入("./模型持久化.nova")
导入("./渠道接口.nova")
导入("./脚本运行时装载.nova")
导入("./模型推演装载.nova")
导入("./交互协同装载.nova")

定义 可变 推理阶段装载_已装载 = []

函数 推理阶段装载_清单(阶段) {
    如果 (阶段 == 阶段_boot) {
        返回 ["./智能总线初始.nova", "./能力注册.nova"]
    }
    如果 (阶段 == 阶段_内核核心) {
        返回 ["./智能操作引擎.nova", "./通信总线.nova", "./记忆管理.nova", "./脚本运行时装载.nova"]
    }
    如果 (阶段 == 阶段_浏览器外衣) {
        返回 ["./感知循环.nova", "./语义嵌入.nova", "./会话管理.nova", "./交互协同装载.nova"]
    }
    如果 (阶段 == 阶段_AI运行时) {
        返回 ["./上下文运行时.nova", "./值型系统.nova", "./模型持久化.nova", "./模型推演装载.nova"]
    }
    如果 (阶段 == 阶段_外部桥接) {
        返回 ["./智能渠道.nova", "./渠道接口.nova", "./通信总线.nova", "./交互协同装载.nova"]
    }
    返回 []
}

函数 推理阶段装载_登记(阶段) {
    定义 可变 i = 0
    当 (i < 计数(推理阶段装载_已装载)) {
        如果 (推理阶段装载_已装载[i] == 阶段) { 返回 计数(推理阶段装载_清单(阶段)) }
        i = i + 1
    }
    追加(推理阶段装载_已装载, 阶段)
    返回 计数(推理阶段装载_清单(阶段))
}

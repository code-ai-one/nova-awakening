// Nova标准库 — 关系数据库引擎
// SQL 解析、表存储、索引、查询执行、事务
// 支持 SELECT/INSERT/UPDATE/DELETE/CREATE TABLE

导入("../../基础.nova")

// 列类型
定义 列_整数 = 1
定义 列_文本 = 2
定义 列_布尔 = 3

// 列定义
// [名称, 类型, 可空, 默认值, 主键, 唯一]

函数 列_创建(名称, 类型, 可空, 默认值) { 返回 [名称, 类型, 可空, 默认值, 假, 假]
}

函数 列_设主键(列) { 列[4] = 真 列[2] = 假 列[5] = 真 }
函数 列_设唯一(列) { 列[5] = 真 }

// 表
// 型: [名称, 列定义列表, 行列表, 下一行ID, 索引映射, 行计数]
// 行: [行ID, 值列表]

函数 表_创建(名称, 列定义列表) { 返回 [名称, 列定义列表, [], 1, 字典(), 0]
}

函数 表_列数(表) { 返回 计数(表[1]) }
函数 表_行数(表) { 返回 表[5] }
函数 表_名称(表) { 返回 表[0] }

函数 表_列索引(表, 列名) { 定义 可变 i = 0
 当 (i < 计数(表[1])) { 如果 (字符串等于(表[1][i][0], 列名)) { 返回 i }
 i = i + 1
 }
 返回 -1
}

函数 表_插入(表, 值列表) { 定义 列数 = 计数(表[1])
 // 补齐默认值
 定义 可变 实际值 = []
 定义 可变 i = 0
 当 (i < 列数) { 如果 (i < 计数(值列表) 且 值列表[i] != 空) {
 追加(实际值, 值列表[i])
 } 否则 如果 (表[1][i][3] != 空) {
 追加(实际值, 表[1][i][3])
 } 否则 如果 (表[1][i][2]) {
 追加(实际值, 空)
 } 否则 { 返回 ["错误", "非空列缺少值"]
 }
 i = i + 1
 }
 // 唯一性检查
 i = 0
 当 (i < 列数) { 如果 (表[1][i][5] 且 实际值[i] != 空) { 定义 可变 j = 0
 当 (j < 计数(表[2])) { 如果 (表[2][j][1][i] == 实际值[i]) { 返回 ["错误", "唯一约束冲突"]
 }
 j = j + 1
 }
 }
 i = i + 1
 }
 定义 行ID = 表[3]
 表[3] = 表[3] + 1
 追加(表[2], [行ID, 实际值])
 表[5] = 表[5] + 1
 返回 ["成功", 行ID]
}

函数 表_删除条件(表, 条件函数) { 定义 可变 新行 = []
 定义 可变 删除数 = 0
 定义 可变 i = 0
 当 (i < 计数(表[2])) { 如果 (条件函数(表[2][i][1])) {
 删除数 = 删除数 + 1
 } 否则 {
 追加(新行, 表[2][i])
 }
 i = i + 1
 }
 表[2] = 新行
 表[5] = 表[5] - 删除数
 返回 删除数
}

函数 表_更新条件(表, 条件函数, 更新函数) { 定义 可变 更新数 = 0
 定义 可变 i = 0
 当 (i < 计数(表[2])) { 如果 (条件函数(表[2][i][1])) {
 表[2][i][1] = 更新函数(表[2][i][1])
 更新数 = 更新数 + 1
 }
 i = i + 1
 }
 返回 更新数
}

函数 表_查询条件(表, 条件函数) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(表[2])) { 如果 (条件函数(表[2][i][1])) {
 追加(结果, 表[2][i][1])
 }
 i = i + 1
 }
 返回 结果
}

函数 表_全部(表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(表[2])) {
 追加(结果, 表[2][i][1])
 i = i + 1
 }
 返回 结果
}

// SQL 词法分析
// Token: [类型, 值]
定义 SQL_关键字 = 1
定义 SQL_标识符 = 2
定义 SQL_数字 = 3
定义 SQL_字符串 = 4
定义 SQL_符号 = 5

函数 sql_是空白(c) {
    如果 (字符串等于(c, " ")) { 返回 真
}
 如果 (字符串等于(c, "\t")) { 返回 真 }
 如果 (字符串等于(c, "\n")) { 返回 真 }
 返回 假
}

函数 sql_是符号(c) {
    如果 (字符串等于(c, "(")) { 返回 真
}
 如果 (字符串等于(c, ")")) { 返回 真 }
 如果 (字符串等于(c, ",")) { 返回 真 }
 如果 (字符串等于(c, ";")) { 返回 真 }
 如果 (字符串等于(c, "=")) { 返回 真 }
 如果 (字符串等于(c, "*")) { 返回 真 }
 如果 (字符串等于(c, ">")) { 返回 真 }
 如果 (字符串等于(c, "<")) { 返回 真 }
 如果 (字符串等于(c, "!")) { 返回 真 }
 返回 假
}

函数 sql_是双字符操作起始(c) {
    如果 (字符串等于(c, ">")) { 返回 真
}
 如果 (字符串等于(c, "<")) { 返回 真 }
 如果 (字符串等于(c, "!")) { 返回 真 }
 返回 假
}

函数 sql_是数字码(c) { 返回 c >= 字符_零 且 c <= 字符_九
}

函数 sql_是标识起始码(c) {
    如果 (c >= 字符_大写A 且 c <= 字符_大写Z) { 返回 真
}
 如果 (c >= 字符_小写a 且 c <= 字符_小写z) { 返回 真 }
 如果 (c == 字符_下划线) { 返回 真 }
 如果 (c > 127) { 返回 真 }
 返回 假
}

函数 sql_是标识续字符码(c) {
    如果 (sql_是标识起始码(c)) { 返回 真
}
 如果 (sql_是数字码(c)) { 返回 真 }
 返回 假
}

函数 sql_是条件终止词(词) {
    如果 (字符串等于(词, "ORDER")) { 返回 真
}
 如果 (字符串等于(词, "LIMIT")) { 返回 真 }
 如果 (字符串等于(词, "GROUP")) { 返回 真 }
 返回 假
}

函数 sql_词法(文本) { 定义 n = 计数(文本)
 定义 可变 词列表 = []
 定义 可变 i = 0
 当 (i < n) { 定义 c = 子串(文本, i, 1)
 // 跳过空白
 如果 (sql_是空白(c)) {
 i = i + 1
 续
 }
 // 符号
 如果 (sql_是符号(c)) {
 // 双字符: >=, <=, !=
 如果 (i + 1 < n) { 定义 c2 = 子串(文本, i + 1, 1)
 如果 (sql_是双字符操作起始(c) 且 字符串等于(c2, "=")) {
 追加(词列表, [SQL_符号, 字符串拼接(c, c2)])
 i = i + 2
 续
 }
 }
 追加(词列表, [SQL_符号, c])
 i = i + 1
 续
 }
 // 字符串
 如果 (字符串等于(c, "'")) { 定义 可变 s = ""
 i = i + 1
 定义 可变 _引号找到 = 假
 当 (i < n 且 _引号找到 == 假) { 如果 (子串(文本, i, 1) == "'") { _引号找到 = 真 } 否则 {
 s = 字符串拼接(s, 子串(文本, i, 1))
 i = i + 1
 } }
 i = i + 1
 追加(词列表, [SQL_字符串, s])
 续
 }
 // 数字
 定义 cc = 编码(c)
 如果 (sql_是数字码(cc)) { 定义 可变 数目 = 0
 当 (i < n) { 定义 d = 编码(子串(文本, i, 1))
 如果 (sql_是数字码(d)) {
 数目 = 数目 * 10 + (d - 48)
 i = i + 1
 } 否则 {
 止
 }
 }
 追加(词列表, [SQL_数字, 数目])
 续
 }
 // 标识符/关键字
 如果 (sql_是标识起始码(cc)) { 定义 可变 id = ""
 当 (i < n) { 定义 ic = 编码(子串(文本, i, 1))
 如果 (sql_是标识续字符码(ic)) {
 id = 字符串拼接(id, 子串(文本, i, 1))
 i = i + 1
 } 否则 {
 止
 }
 }
 // 转大写比较关键字
 定义 上 = sql_转大写(id)
 如果 (sql_是关键字(上)) {
 追加(词列表, [SQL_关键字, 上])
 } 否则 {
 追加(词列表, [SQL_标识符, id])
 }
 续
 }
 i = i + 1
 }
 返回 词列表
}

函数 sql_是关键字(词) { 定义 关键字列表 = ["SELECT", "FROM", "WHERE", "INSERT", "INTO", "VALUES", "UPDATE", "SET", "DELETE", "CREATE", "TABLE", "AND", "OR", "NOT", "ORDER", "BY", "ASC", "DESC", "LIMIT", "INTEGER", "TEXT", "BOOLEAN", "PRIMARY", "KEY", "UNIQUE", "NULL", "DEFAULT", "DROP", "ALTER", "ADD", "JOIN", "ON", "LEFT", "RIGHT", "INNER", "GROUP", "HAVING", "COUNT", "SUM", "AVG", "MIN", "MAX", "AS", "DISTINCT", "IN", "LIKE", "BETWEEN", "IS"]
 定义 可变 i = 0
 当 (i < 计数(关键字列表)) { 如果 (字符串等于(关键字列表[i], 词)) { 返回 真 }
 i = i + 1
 }
 返回 假
}

函数 sql_转大写(s) { 定义 n = 计数(s)
 定义 可变 r = ""
 定义 可变 i = 0
 当 (i < n) { 定义 c = 编码(子串(s, i, 1))
 如果 (c >= 字符_小写a 且 c <= 字符_小写z) {
 r = 字符串拼接(r, 子串("ABCDEFGHIJKLMNOPQRSTUVWXYZ", c - 97, 1))
 } 否则 {
 r = 字符串拼接(r, 子串(s, i, 1))
 }
 i = i + 1
 }
 返回 r
}

// 数据库
// 型: [名称, 表映射(字典), 版本]

函数 数据库_创建(名称) { 返回 [名称, 字典(), 0]
}

函数 数据库_创建表(db, 表名, 列定义列表) {
    如果 (字典取(db[1], 表名) != 空) { 返回 ["错误", "表已存在"]
}
 定义 表 = 表_创建(表名, 列定义列表)
 字典设(db[1], 表名, 表)
 db[2] = db[2] + 1
 返回 ["成功", 表名]
}

函数 数据库_删除表(db, 表名) {
    如果 (字典取(db[1], 表名) == 空) { 返回 ["错误", "表不存在"]
}
 字典设(db[1], 表名, 空)
 db[2] = db[2] + 1
 返回 ["成功", 表名]
}

函数 数据库_取表(db, 表名) { 返回 字典取(db[1], 表名)
}

// 简化 SQL 执行器
// 解析并执行 SQL 文本

函数 sql_执行(db, sql文本) { 定义 词列表 = sql_词法(sql文本)
 如果 (计数(词列表) == 0) { 返回 ["错误", "空语句"] }
 定义 首词 = 词列表[0][1]
 如果 (字符串等于(首词, "SELECT")) { 返回 sql_执行SELECT(db, 词列表) }
 如果 (字符串等于(首词, "INSERT")) { 返回 sql_执行INSERT(db, 词列表) }
 如果 (字符串等于(首词, "DELETE")) { 返回 sql_执行DELETE(db, 词列表) }
 如果 (字符串等于(首词, "CREATE")) { 返回 sql_执行CREATE(db, 词列表) }
 如果 (字符串等于(首词, "UPDATE")) { 返回 sql_执行UPDATE(db, 词列表) }
 如果 (字符串等于(首词, "DROP")) { 返回 sql_执行DROP(db, 词列表) }
 返回 ["错误", "不支持的SQL语句"]
}

函数 sql_执行CREATE(db, 词列表) {
 // 创建 TABLE 表名 (列1 类型, 列2 类型, ...)
 如果 (计数(词列表) < 4) { 返回 ["错误", "语法错误"] }
 定义 表名 = 词列表[2][1]
 // 解析列定义
 定义 可变 列列表 = []
 定义 可变 i = 4
 当 (i < 计数(词列表)) { 如果 (词列表[i][0] == SQL_标识符) { 定义 列名 = 词列表[i][1]
 定义 可变 类型 = 列_文本
 如果 (i + 1 < 计数(词列表)) { 定义 类型词 = 词列表[i + 1][1]
 如果 (字符串等于(类型词, "INTEGER")) { 类型 = 列_整数 }
 否则 如果 (字符串等于(类型词, "BOOLEAN")) { 类型 = 列_布尔 }
 i = i + 1
 }
 定义 列 = 列_创建(列名, 类型, 真, 空)
 // 检查 PRIMARY KEY / UNIQUE
 如果 (i + 1 < 计数(词列表) 且 字符串等于(词列表[i + 1][1], "PRIMARY")) {
 列_设主键(列)
 i = i + 2
 }
 如果 (i + 1 < 计数(词列表) 且 字符串等于(词列表[i + 1][1], "UNIQUE")) {
 列_设唯一(列)
 i = i + 1
 }
 追加(列列表, 列)
 }
 i = i + 1
 }
 返回 数据库_创建表(db, 表名, 列列表)
}

函数 sql_执行INSERT(db, 词列表) {
 // 插入 INTO 表名 VALUES (值1, 值2, ...)
 如果 (计数(词列表) < 5) { 返回 ["错误", "语法错误"] }
 定义 表名 = 词列表[2][1]
 定义 表 = 数据库_取表(db, 表名)
 如果 (表 == 空) { 返回 ["错误", "表不存在"] }
 // 找 VALUES 后的值
 定义 可变 值列表 = []
 定义 可变 i = 0
 当 (i < 计数(词列表)) { 如果 (词列表[i][0] == SQL_关键字 且 字符串等于(词列表[i][1], "VALUES")) {
 i = i + 1
 止
 }
 i = i + 1
 }
 // 跳过 (
 如果 (i < 计数(词列表) 且 字符串等于(词列表[i][1], "(")) { i = i + 1 }
 定义 可变 _值完 = 假
 当 (i < 计数(词列表) 且 _值完 == 假) { 如果 (词列表[i][1] == ")" 或 词列表[i][1] == ";") { _值完 = 真 } 否则 {
 如果 (词列表[i][0] == SQL_数字) { 追加(值列表, 词列表[i][1]) }
 否则 如果 (词列表[i][0] == SQL_字符串) { 追加(值列表, 词列表[i][1]) }
 否则 如果 (词列表[i][0] == SQL_关键字 且 字符串等于(词列表[i][1], "NULL")) { 追加(值列表, 空) }
 i = i + 1
 } }
 返回 表_插入(表, 值列表)
}

函数 sql_执行SELECT(db, 词列表) {
 // SELECT 列... FROM 表名 [WHERE 条件] [ORDER BY 列 ASC/DESC] [LIMIT n]
 定义 可变 选择列 = []
 定义 可变 表名 = ""
 定义 可变 i = 1
 定义 可变 全选 = 假
 // 解析列名
 当 (i < 计数(词列表)) { 如果 (词列表[i][0] == SQL_关键字 且 字符串等于(词列表[i][1], "FROM")) {
 i = i + 1
 止
 }
 如果 (字符串等于(词列表[i][1], "*")) { 全选 = 真 }
 否则 如果 (词列表[i][0] == SQL_标识符) { 追加(选择列, 词列表[i][1]) }
 i = i + 1
 }
 如果 (i < 计数(词列表)) {
 表名 = 词列表[i][1]
 i = i + 1
 }
 定义 表 = 数据库_取表(db, 表名)
 如果 (表 == 空) { 返回 ["错误", "表不存在"] }
 // 全部行
 定义 可变 行列表 = 表_全部(表)
 // WHERE
 如果 (i < 计数(词列表) 且 字符串等于(词列表[i][1], "WHERE")) {
 i = i + 1
 定义 where结果 = sql_解析WHERE(表, 词列表, i)
 行列表 = where结果[0]
 i = where结果[1]
 }
 // ORDER BY
 如果 (i + 1 < 计数(词列表) 且 字符串等于(词列表[i][1], "ORDER")) {
 i = i + 2
 如果 (i < 计数(词列表)) { 定义 排序列 = 词列表[i][1]
 定义 排序idx = 表_列索引(表, 排序列)
 定义 可变 降序 = 假
 i = i + 1
 如果 (i < 计数(词列表) 且 字符串等于(词列表[i][1], "DESC")) {
 降序 = 真
 i = i + 1
 }
 如果 (排序idx >= 0) {
 行列表 = sql_排序(行列表, 排序idx, 降序)
 }
 }
 }
 // LIMIT
 如果 (i < 计数(词列表) 且 字符串等于(词列表[i][1], "LIMIT")) {
 i = i + 1
 如果 (i < 计数(词列表) 且 词列表[i][0] == SQL_数字) { 定义 限制 = 词列表[i][1]
 如果 (计数(行列表) > 限制) { 定义 可变 截断 = []
 定义 可变 j = 0
 当 (j < 限制) {
 追加(截断, 行列表[j])
 j = j + 1
 }
 行列表 = 截断
 }
 }
 }
 // 投影
 如果 (全选) { 返回 ["成功", 行列表] }
 定义 可变 列索引列表 = []
 定义 可变 k = 0
 当 (k < 计数(选择列)) {
 追加(列索引列表, 表_列索引(表, 选择列[k]))
 k = k + 1
 }
 定义 可变 投影结果 = []
 k = 0
 当 (k < 计数(行列表)) { 定义 可变 投影行 = []
 定义 可变 m = 0
 当 (m < 计数(列索引列表)) { 定义 ci = 列索引列表[m]
 如果 (ci >= 0) { 追加(投影行, 行列表[k][ci]) }
 否则 { 追加(投影行, 空) }
 m = m + 1
 }
 追加(投影结果, 投影行)
 k = k + 1
 }
 返回 ["成功", 投影结果]
}

函数 sql_解析WHERE(表, 词列表, 起始) {
 // 简单 WHERE: 列名 op 值 [AND/OR 列名 op 值]
 定义 全部行 = 表_全部(表)
 定义 可变 结果 = 全部行
 定义 可变 i = 起始
 定义 可变 逻辑 = "AND"
 当 (i + 2 < 计数(词列表)) { 如果 (词列表[i][0] == SQL_关键字 且 sql_是条件终止词(词列表[i][1])) {
 止
 }
 如果 (词列表[i][0] == SQL_关键字 且 字符串等于(词列表[i][1], "AND")) {
 逻辑 = "AND"
 i = i + 1
 续
 }
 如果 (词列表[i][0] == SQL_关键字 且 字符串等于(词列表[i][1], "OR")) {
 逻辑 = "OR"
 i = i + 1
 续
 }
 定义 列名 = 词列表[i][1]
 定义 列idx = 表_列索引(表, 列名)
 定义 操作符 = 词列表[i + 1][1]
 定义 可变 比较值 = 词列表[i + 2][1]
 定义 可变 过滤 = []
 定义 可变 j = 0
 当 (j < 计数(结果)) { 定义 行值 = 结果[j][列idx]
 定义 可变 符合 = 假
 如果 (字符串等于(操作符, "=")) { 符合 = 行值 == 比较值 }
 否则 如果 (字符串等于(操作符, ">")) { 符合 = 行值 > 比较值 }
 否则 如果 (字符串等于(操作符, "<")) { 符合 = 行值 < 比较值 }
 否则 如果 (字符串等于(操作符, ">=")) { 符合 = 行值 >= 比较值 }
 否则 如果 (字符串等于(操作符, "<=")) { 符合 = 行值 <= 比较值 }
 否则 如果 (字符串等于(操作符, "!=")) { 符合 = 行值 != 比较值 }
 如果 (符合) { 追加(过滤, 结果[j]) }
 j = j + 1
 }
 结果 = 过滤
 i = i + 3
 }
 返回 [结果, i]
}

函数 sql_执行DELETE(db, 词列表) {
 // 删除 FROM 表名 WHERE ...
 如果 (计数(词列表) < 3) { 返回 ["错误", "语法错误"] }
 定义 表名 = 词列表[2][1]
 定义 表 = 数据库_取表(db, 表名)
 如果 (表 == 空) { 返回 ["错误", "表不存在"] }
 如果 (计数(词列表) < 5) {
 // 删除 全部
 定义 删除数 = 表[5]
 表[2] = []
 表[5] = 0
 返回 ["成功", 删除数]
 }
 // WHERE
 定义 where结果 = sql_解析WHERE(表, 词列表, 4)
 定义 要删除 = where结果[0]
 定义 可变 删除数 = 0
 定义 可变 新行 = []
 定义 可变 i = 0
 当 (i < 计数(表[2])) { 定义 可变 在删除集 = 假
 定义 可变 j = 0
 当 (j < 计数(要删除) 且 在删除集 == 假) { 如果 (表[2][i][1] == 要删除[j]) { 在删除集 = 真 }
 j = j + 1
 }
 如果 (在删除集) { 删除数 = 删除数 + 1 }
 否则 { 追加(新行, 表[2][i]) }
 i = i + 1
 }
 表[2] = 新行
 表[5] = 表[5] - 删除数
 返回 ["成功", 删除数]
}

函数 sql_执行UPDATE(db, 词列表) {
 // 更新 表名 SET 列=值 [WHERE ...]
 如果 (计数(词列表) < 6) { 返回 ["错误", "语法错误"] }
 定义 表名 = 词列表[1][1]
 定义 表 = 数据库_取表(db, 表名)
 如果 (表 == 空) { 返回 ["错误", "表不存在"] }
 // 解析 SET 子句
 定义 可变 更新列表 = []
 定义 可变 i = 3
 定义 可变 _set完 = 假
 当 (i + 2 < 计数(词列表) 且 _set完 == 假) { 如果 (词列表[i][0] == SQL_关键字 且 词列表[i][1] == "WHERE") { _set完 = 真 } 否则 {
 如果 (词列表[i][0] == SQL_标识符 且 字符串等于(词列表[i + 1][1], "=")) {
 追加(更新列表, [词列表[i][1], 词列表[i + 2][1]])
 i = i + 3
 } 否则 { i = i + 1 }
 } }
 // WHERE
 定义 可变 更新数 = 0
 定义 可变 j = 0
 当 (j < 计数(表[2])) { 定义 可变 符合 = 真
 如果 (i < 计数(词列表) 且 字符串等于(词列表[i][1], "WHERE")) {
 // 简化: 仅支持单条件
 如果 (i + 3 < 计数(词列表)) { 定义 列idx = 表_列索引(表, 词列表[i + 1][1])
 定义 比较值 = 词列表[i + 3][1]
 符合 = 表[2][j][1][列idx] == 比较值
 }
 }
 如果 (符合) { 定义 可变 k = 0
 当 (k < 计数(更新列表)) { 定义 更新列idx = 表_列索引(表, 更新列表[k][0])
 如果 (更新列idx >= 0) { 定义 可变 当前行记录 = 表[2][j]
 定义 可变 当前值列表 = 当前行记录[1]
 当前值列表[更新列idx] = 更新列表[k][1]
 当前行记录[1] = 当前值列表
 表[2][j] = 当前行记录
 }
 k = k + 1
 }
 更新数 = 更新数 + 1
 }
 j = j + 1
 }
 返回 ["成功", 更新数]
}

函数 sql_执行DROP(db, 词列表) {
    如果 (计数(词列表) < 3) { 返回 ["错误", "语法错误"]
}
 返回 数据库_删除表(db, 词列表[2][1])
}

// 排序
函数 sql_排序(行列表, 列idx, 降序) { 定义 n = 计数(行列表)
 如果 (n <= 1) { 返回 行列表 }
 // 插入排序
 定义 可变 i = 1
 当 (i < n) { 定义 当前 = 行列表[i]
 定义 可变 j = i - 1
 当 (j >= 0) { 定义 可变 应交换 = 假
 如果 (降序) {
 应交换 = 行列表[j][列idx] < 当前[列idx]
 } 否则 {
 应交换 = 行列表[j][列idx] > 当前[列idx]
 }
 如果 (应交换) {
 行列表[j + 1] = 行列表[j]
 j = j - 1
 } 否则 { j = 0 - 1 }
 }
 行列表[j + 1] = 当前
 i = i + 1
 }
 返回 行列表
}

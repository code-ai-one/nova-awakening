// Nova标准库 — 2D 画布渲染引擎
// 像素级绘制、矢量图元、变换矩阵、图层合成
// 支持抗锯齿、渐变、裁剪、路径构建

导入("../../基础.nova")

定义 画布精度 = 1000

// 画布
// 型: [宽, 高, 像素数据(RGBA), 当前颜色, 线宽, 变换栈, 裁剪区, 透明度]
// 像素: 每像素4通道 [R, G, B, A]

函数 画布_创建(宽, 高) { 定义 总像素 = 宽 * 高 * 4
 定义 可变 像素 = []
 定义 可变 i = 0
 当 (i < 总像素) {
 追加(像素, 0)
 i = i + 1
 }
 返回 [宽, 高, 像素, [255, 255, 255, 255], 1, [[1000, 0, 0, 1000, 0]], 空, 255]
}

函数 画布_宽(c) { 返回 c[0] }
函数 画布_高(c) { 返回 c[1] }

// 颜色设置
函数 画布_设颜色(c, r, g, b) {
 c[3] = [r, g, b, 255]
}

函数 画布_设颜色RGBA(c, r, g, b, a) {
 c[3] = [r, g, b, a]
}

函数 画布_设透明度(c, 透明度) {
 c[7] = 透明度
}

函数 画布_设线宽(c, 宽) {
 c[4] = 宽
}

// 像素操作
函数 画布_设像素(c, x, y, r, g, b, a) {
    如果 (x < 0 或 x >= c[0] 或 y < 0 或 y >= c[1]) { 返回
}
 // 裁剪检查
 如果 (c[6] != 空) { 定义 裁剪 = c[6]
 如果 (x < 裁剪[0] 或 x >= 裁剪[0] + 裁剪[2] 或 y < 裁剪[1] 或 y >= 裁剪[1] + 裁剪[3]) { 返回
 }
 }
 定义 索引 = (y * c[0] + x) * 4
 // Alpha 混合 (源 over 目标)
 定义 sa = a * c[7] / 255
 如果 (sa >= 255) {
 c[2][索引] = r
 c[2][索引 + 1] = g
 c[2][索引 + 2] = b
 c[2][索引 + 3] = 255
 } 否则 如果 (sa > 0) { 定义 da = c[2][索引 + 3]
 定义 oa = sa + da * (255 - sa) / 255
 如果 (oa > 0) {
 c[2][索引] = (r * sa + c[2][索引] * da * (255 - sa) / 255) / oa
 c[2][索引 + 1] = (g * sa + c[2][索引 + 1] * da * (255 - sa) / 255) / oa
 如果 (oa == 0) { oa = 1 }
 c[2][索引 + 2] = (b * sa + c[2][索引 + 2] * da * (255 - sa) / 255) / oa
 c[2][索引 + 3] = oa
 }
 }
}

函数 画布_取像素(c, x, y) {
    如果 (x < 0 或 x >= c[0] 或 y < 0 或 y >= c[1]) { 返回 [0, 0, 0]
}
 定义 索引 = (y * c[0] + x) * 4
 返回 [c[2][索引], c[2][索引+1], c[2][索引+2], c[2][索引+3]]
}

// 基本图元

// 画点 (使用当前颜色)
函数 画布_画点(c, x, y) {
 画布_设像素(c, x, y, c[3][0], c[3][1], c[3][2], c[3][3])
}

// 画线 (Bresenham, 0 , 0 , 0, 0)
函数 画布_画线(c, x1, y1, x2, y2) { 定义 可变 导数 = x2 - x1
 定义 可变 导数Y = y2 - y1
 定义 可变 adx = 导数
 定义 可变 ady = 导数Y
 如果 (adx < 0) { adx = 0 - adx }
 如果 (ady < 0) { ady = 0 - ady }
 定义 可变 sx = 1
 定义 可变 sy = 1
 如果 (导数 < 0) { sx = -1 }
 如果 (导数Y < 0) { sy = -1 }
 定义 可变 err = adx - ady
 定义 可变 cx = x1
 定义 可变 cy = y1
 定义 可变 _线完 = 假
 当 (_线完 == 假) {
 // 线宽处理
 如果 (c[4] <= 1) {
 画布_画点(c, cx, cy)
 } 否则 { 定义 半宽 = c[4] / 2
 定义 可变 wy = 0 - 半宽
 当 (wy <= 半宽) { 定义 可变 wx = 0 - 半宽
 当 (wx <= 半宽) {
 画布_画点(c, cx + wx, cy + wy)
 wx = wx + 1
 }
 wy = wy + 1
 }
 }
 如果 (cx == x2 且 cy == y2) { _线完 = 真 } 否则 {
 定义 e2 = 2 * err
 如果 (e2 > 0 - ady) { err = err - ady cx = cx + sx }
 如果 (e2 < adx) { err = err + adx cy = cy + sy }
 }
 }
}

// 画矩形 (边框, 0 , 0 , 0, 0)
函数 画布_画矩形(c, x, y, 宽, 高) {
 画布_画线(c, x, y, x + 宽 - 1, y)
 画布_画线(c, x + 宽 - 1, y, x + 宽 - 1, y + 高 - 1)
 画布_画线(c, x + 宽 - 1, y + 高 - 1, x, y + 高 - 1)
 画布_画线(c, x, y + 高 - 1, x, y)
}

// 填充矩形
函数 画布_填充矩形(c, x, y, 宽, 高) { 定义 可变 导数Y = 0
 当 (导数Y < 高) { 定义 可变 导数 = 0
 当 (导数 < 宽) {
 画布_画点(c, x + 导数, y + 导数Y)
 导数 = 导数 + 1
 }
 导数Y = 导数Y + 1
 }
}

// 画圆 (Bresenham 中点圆算法)
函数 画布_画圆(c, cx, cy, 半径) { 定义 可变 x = 半径
 定义 可变 y = 0
 定义 可变 d = 1 - 半径
 当 (x >= y) {
 画布_画点(c, cx + x, cy + y)
 画布_画点(c, cx - x, cy + y)
 画布_画点(c, cx + x, cy - y)
 画布_画点(c, cx - x, cy - y)
 画布_画点(c, cx + y, cy + x)
 画布_画点(c, cx - y, cy + x)
 画布_画点(c, cx + y, cy - x)
 画布_画点(c, cx - y, cy - x)
 y = y + 1
 如果 (d <= 0) {
 d = d + 2 * y + 1
 } 否则 {
 x = x - 1
 d = d + 2 * (y - x) + 1
 }
 }
}

// 填充圆
函数 画布_填充圆(c, cx, cy, 半径) { 定义 可变 x = 半径
 定义 可变 y = 0
 定义 可变 d = 1 - 半径
 当 (x >= y) {
 画布_水平线(c, cx - x, cx + x, cy + y)
 画布_水平线(c, cx - x, cx + x, cy - y)
 画布_水平线(c, cx - y, cx + y, cy + x)
 画布_水平线(c, cx - y, cx + y, cy - x)
 y = y + 1
 如果 (d <= 0) {
 d = d + 2 * y + 1
 } 否则 {
 x = x - 1
 d = d + 2 * (y - x) + 1
 }
 }
}

函数 画布_水平线(c, x1, x2, y) { 定义 可变 x = x1
 当 (x <= x2) { 画布_画点(c, x, y) x = x + 1 }
}

// 画椭圆
函数 画布_画椭圆(c, cx, cy, rx, ry) { 定义 可变 x = 0
 定义 可变 y = ry
 定义 可变 d1 = ry * ry - rx * rx * ry + rx * rx / 4
 定义 可变 导数 = 2 * ry * ry * x
 定义 可变 导数Y = 2 * rx * rx * y
 // 区域1
 当 (导数 < 导数Y) {
 画布_画点(c, cx + x, cy + y)
 画布_画点(c, cx - x, cy + y)
 画布_画点(c, cx + x, cy - y)
 画布_画点(c, cx - x, cy - y)
 如果 (d1 < 0) {
 x = x + 1
 导数 = 导数 + 2 * ry * ry
 d1 = d1 + 导数 + ry * ry
 } 否则 {
 x = x + 1
 y = y - 1
 导数 = 导数 + 2 * ry * ry
 导数Y = 导数Y - 2 * rx * rx
 d1 = d1 + 导数 - 导数Y + ry * ry
 }
 }
 // 区域2
 定义 可变 d2 = ry * ry * (x * 2 + 1) * (x * 2 + 1) / 4 + rx * rx * (y - 1) * (y - 1) - rx * rx * ry * ry
 当 (y >= 0) {
 画布_画点(c, cx + x, cy + y)
 画布_画点(c, cx - x, cy + y)
 画布_画点(c, cx + x, cy - y)
 画布_画点(c, cx - x, cy - y)
 如果 (d2 > 0) {
 y = y - 1
 导数Y = 导数Y - 2 * rx * rx
 d2 = d2 + rx * rx - 导数Y
 } 否则 {
 y = y - 1
 x = x + 1
 导数 = 导数 + 2 * ry * ry
 导数Y = 导数Y - 2 * rx * rx
 d2 = d2 + 导数 - 导数Y + rx * rx
 }
 }
}

// 画三角形
函数 画布_画三角形(c, x1, y1, x2, y2, x3, y3) {
 画布_画线(c, x1, y1, x2, y2)
 画布_画线(c, x2, y2, x3, y3)
 画布_画线(c, x3, y3, x1, y1)
}

// 填充三角形 (扫描线法)
函数 画布_填充三角形(c, x1, y1, x2, y2, x3, y3) {
 // 排序 y: y1 <= y2 <= y3
 定义 可变 px1 = x1 定义 可变 py1 = y1
 定义 可变 px2 = x2 定义 可变 py2 = y2
 定义 可变 px3 = x3 定义 可变 py3 = y3
 如果 (py1 > py2) { 定义 可变 t = px1 px1 = px2 px2 = t
 t = py1 py1 = py2 py2 = t
 }
 如果 (py2 > py3) { 定义 可变 t = px2 px2 = px3 px3 = t
 t = py2 py2 = py3 py3 = t
 }
 如果 (py1 > py2) { 定义 可变 t = px1 px1 = px2 px2 = t
 t = py1 py1 = py2 py2 = t
 }
 // 扫描线
 定义 可变 y = py1
 当 (y <= py3) { 定义 可变 xa = 0
 定义 可变 xb = 0
 如果 (y < py2) { 如果 (py2 - py1 > 0) { xa = px1 + (px2 - px1) * (y - py1) / (py2 - py1) }
 否则 { xa = px1 }
 } 否则 { 如果 (py3 - py2 > 0) { xa = px2 + (px3 - px2) * (y - py2) / (py3 - py2) }
 否则 { xa = px2 }
 }
 如果 (py3 - py1 > 0) { xb = px1 + (px3 - px1) * (y - py1) / (py3 - py1) }
 否则 { xb = px1 }
 如果 (xa > xb) { 定义 临 = xa xa = xb xb = 临
 }
 画布_水平线(c, xa, xb, y)
 y = y + 1
 }
}

// 裁剪
函数 画布_设裁剪(c, x, y, 宽, 高) {
 c[6] = [x, y, 宽, 高]
}

函数 画布_清裁剪(c) { c[6] = 空 }

// 变换
函数 画布_保存(c) { 定义 当前 = c[5][计数(c[5]) - 1]
 追加(c[5], [当前[0], 当前[1], 当前[2], 当前[3], 当前[4], 当前[5]])
}

函数 画布_恢复(c) { 如果 (计数(c[5]) > 1) {
    定义 可变 新栈 = []
 定义 可变 i = 0
 当 (i < 计数(c[5]) - 1) { 追加(新栈, c[5][i]) i = i + 1 }
 c[5] = 新栈
 }
}

函数 画布_平移(c, tx, ty) { 定义 m = c[5][计数(c[5]) - 1]
 m[2] = m[2] + tx * 画布精度
 m[5] = m[5] + ty * 画布精度
}

函数 画布_缩放(c, sx, sy) { 定义 m = c[5][计数(c[5]) - 1]
 m[0] = m[0] * sx / 画布精度
 m[4] = m[4] * sy / 画布精度
}

函数 画布_变换点(c, x, y) { 定义 m = c[5][计数(c[5]) - 1]
 定义 nx = (m[0] * x + m[1] * y + m[2]) / 画布精度
 定义 ny = (m[3] * x + m[4] * y + m[5]) / 画布精度
 返回 [nx, ny]
}

// 填充/清除
函数 画布_清除(c) { 定义 总 = c[0] * c[1] * 4
 定义 可变 i = 0
 当 (i < 总) { c[2][i] = 0 i = i + 1 }
}

函数 画布_填充(c, r, g, b) { 定义 总 = c[0] * c[1]
 定义 可变 i = 0
 当 (i < 总) {
 c[2][i * 4] = r
 c[2][i * 4 + 1] = g
 c[2][i * 4 + 2] = b
 c[2][i * 4 + 3] = 255
 i = i + 1
 }
}

// 渐变填充
函数 画布_水平渐变(c, x, y, 宽, 高, r1, g1, b1, r2, g2, b2) { 定义 可变 导数 = 0
 当 (导数 < 宽) { 定义 比例 = 导数 * 画布精度 / 宽
 定义 r = r1 + (r2 - r1) * 比例 / 画布精度
 定义 g = g1 + (g2 - g1) * 比例 / 画布精度
 定义 b = b1 + (b2 - b1) * 比例 / 画布精度
 定义 可变 导数Y = 0
 当 (导数Y < 高) {
 画布_设像素(c, x + 导数, y + 导数Y, r, g, b, 255)
 导数Y = 导数Y + 1
 }
 导数 = 导数 + 1
 }
}

函数 画布_垂直渐变(c, x, y, 宽, 高, r1, g1, b1, r2, g2, b2) { 定义 可变 导数Y = 0
 当 (导数Y < 高) { 定义 比例 = 导数Y * 画布精度 / 高
 定义 r = r1 + (r2 - r1) * 比例 / 画布精度
 定义 g = g1 + (g2 - g1) * 比例 / 画布精度
 定义 b = b1 + (b2 - b1) * 比例 / 画布精度
 定义 可变 导数 = 0
 当 (导数 < 宽) {
 画布_设像素(c, x + 导数, y + 导数Y, r, g, b, 255)
 导数 = 导数 + 1
 }
 导数Y = 导数Y + 1
 }
}

// 图层合成
函数 画布_合成(目标, 源, 偏移x, 偏移y) { 定义 可变 y = 0
 当 (y < 源[1]) { 定义 可变 x = 0
 当 (x < 源[0]) { 定义 像素 = 画布_取像素(源, x, y)
 如果 (像素[3] > 0) {
 画布_设像素(目标, x + 偏移x, y + 偏移y, 像素[0], 像素[1], 像素[2], 像素[3])
 }
 x = x + 1
 }
 y = y + 1
 }
}

// 洪水填充 (Flood Fill)
函数 画布_洪水填充(c, x, y) {
    如果 (x < 0 或 x >= c[0] 或 y < 0 或 y >= c[1]) { 返回
}
 定义 目标色 = 画布_取像素(c, x, y)
 定义 填充色 = c[3]
 如果 (目标色[0] == 填充色[0] 且 目标色[1] == 填充色[1] 且 目标色[2] == 填充色[2]) { 返回 }
 // 广度优先
 定义 可变 队列 = [[x, y]]
 定义 可变 头 = 0
 当 (头 < 计数(队列)) { 定义 点 = 队列[头]
 头 = 头 + 1
 定义 px = 点[0]
 定义 py = 点[1]
 如果 (px < 0 或 px >= c[0] 或 py < 0 或 py >= c[1]) { 续 }
 定义 当前色 = 画布_取像素(c, px, py)
 如果 (当前色[0] != 目标色[0] 或 当前色[1] != 目标色[1] 或 当前色[2] != 目标色[2]) { 续 }
 画布_画点(c, px, py)
 追加(队列, [px + 1, py])
 追加(队列, [px - 1, py])
 追加(队列, [px, py + 1])
 追加(队列, [px, py - 1])
 如果 (头 > c[0] * c[1]) { 头 = 计数(队列) }
 }
}

// 导出为 PPM 格式 (文本)
函数 画布_导出PPM(c) { 定义 可变 结果 = "P3\n"
 结果 = 字符串拼接(结果, 画布_数到文(c[0]))
 结果 = 字符串拼接(结果, " ")
 结果 = 字符串拼接(结果, 画布_数到文(c[1]))
 结果 = 字符串拼接(结果, "\n255\n")
 定义 可变 i = 0
 定义 总 = c[0] * c[1]
 当 (i < 总) {
 结果 = 字符串拼接(结果, 画布_数到文(c[2][i * 4]))
 结果 = 字符串拼接(结果, " ")
 结果 = 字符串拼接(结果, 画布_数到文(c[2][i * 4 + 1]))
 结果 = 字符串拼接(结果, " ")
 结果 = 字符串拼接(结果, 画布_数到文(c[2][i * 4 + 2]))
 结果 = 字符串拼接(结果, "\n")
 i = i + 1
 }
 返回 结果
}

// 画布旋转 (90度倍数)
函数 画布_旋转90(c) { 定义 宽 = c[0]
 定义 高 = c[1]
 定义 可变 新像素 = []
 定义 可变 i = 0
 当 (i < 宽 * 高 * 4) { 追加(新像素, 0)
 i = i + 1 }
 定义 可变 y = 0
 当 (y < 高) { 定义 可变 x = 0
 当 (x < 宽) { 定义 源值 = (y * 宽 + x) * 4
 定义 目标值 = (x * 高 + (高 - 1 - y)) * 4
 新像素[目标值] = c[2][源值]
 新像素[目标值 + 1] = c[2][源值 + 1]
 新像素[目标值 + 2] = c[2][源值 + 2]
 新像素[目标值 + 3] = c[2][源值 + 3]
 x = x + 1
 }
 y = y + 1
 }
 返回 [高, 宽, 新像素, c[3], c[4], c[5], c[6], c[7]]
}

// 画布水平翻转
函数 画布_水平翻转(c) { 定义 宽 = c[0]
 定义 高 = c[1]
 定义 可变 y = 0
 当 (y < 高) { 定义 可变 x = 0
 当 (x < 宽 / 2) { 定义 l = (y * 宽 + x) * 4
 定义 r = (y * 宽 + 宽 - 1 - x) * 4
 定义 可变 ch = 0
 当 (ch < 4) { 定义 t = c[2][l + ch]
 c[2][l + ch] = c[2][r + ch]
 c[2][r + ch] = t
 ch = ch + 1
 }
 x = x + 1
 }
 y = y + 1
 }
}

// 画布亮度调整
函数 画布_亮度(c, 增量) { 定义 总 = c[0] * c[1]
 定义 可变 i = 0
 当 (i < 总) { 定义 索引 = i * 4
 定义 可变 ch = 0
 当 (ch < 3) { 定义 可变 v = c[2][索引 + ch] + 增量
 如果 (v > 255) { v = 255 }
 如果 (v < 0) { v = 0 }
 c[2][索引 + ch] = v
 ch = ch + 1
 }
 i = i + 1
 }
}

// 画布灰度化
函数 画布_灰度(c) { 定义 总 = c[0] * c[1]
 定义 可变 i = 0
 当 (i < 总) { 定义 索引 = i * 4
 定义 灰 = (c[2][索引] * 299 + c[2][索引 + 1] * 587 + c[2][索引 + 2] * 114) / 1000
 c[2][索引] = 灰
 c[2][索引 + 1] = 灰
 c[2][索引 + 2] = 灰
 i = i + 1
 }
}

// 画布反色
函数 画布_反色(c) { 定义 总 = c[0] * c[1]
 定义 可变 i = 0
 当 (i < 总) { 定义 索引 = i * 4
 c[2][索引] = 255 - c[2][索引]
 c[2][索引 + 1] = 255 - c[2][索引 + 1]
 c[2][索引 + 2] = 255 - c[2][索引 + 2]
 i = i + 1
 }
}

函数 画布_数到文(n) {
    如果 (n == 0) { 返回 "0"
}
 定义 可变 v = n
 定义 可变 负 = 假
 如果 (v < 0) { 负 = 真 v = 0 - v }
 定义 可变 r = ""
 当 (v > 0) { r = 字符串拼接(子串("0123456789", v % 10, 1), r) v = v / 10 }
 如果 (负) { r = 字符串拼接("-", r) }
 返回 r
}

// M12: 渲染合同

定义 可变 _渲染合同_像素格式 = "RGBA8"
定义 可变 _渲染合同_顶点布局 = "pos3_uv2_norm3"
定义 可变 _渲染合同_索引类型 = "u32"
定义 可变 _渲染合同_深度格式 = "D24S8"
定义 可变 _渲染合同_blend = "透明度"
定义 可变 _渲染合同_cull = "back"

函数 渲染合同_设置(像素格式, 顶点布局, 索引类型, 深度格式, blend, cull) {
    _渲染合同_像素格式 = 像素格式
    _渲染合同_顶点布局 = 顶点布局
    _渲染合同_索引类型 = 索引类型
    _渲染合同_深度格式 = 深度格式
    _渲染合同_blend = blend
    _渲染合同_cull = cull
}

函数 画布_渲染合同_报告() {
    定义 可变 r = 字典()
    字典设(r, "像素格式", _渲染合同_像素格式)
    字典设(r, "顶点布局", _渲染合同_顶点布局)
    字典设(r, "索引类型", _渲染合同_索引类型)
    字典设(r, "深度格式", _渲染合同_深度格式)
    字典设(r, "blend", _渲染合同_blend)
    字典设(r, "cull", _渲染合同_cull)
    返回 r
}

// Render Pass
定义 可变 _render_pass列表 = []

函数 render_pass_添加(名称, 类型, 输出) {
    追加(_render_pass列表, [名称, 类型, 输出])
}

函数 render_pass_数() { 返回 计数(_render_pass列表) }

函数 render_pass_报告() {
    定义 可变 r = 字典()
    字典设(r, "pass数", 转字符串(计数(_render_pass列表)))
    定义 可变 i = 0
    当 (i < 计数(_render_pass列表)) {
        字典设(r, 字符串拼接("pass_", 转字符串(i)), _render_pass列表[i][0])
        i = i + 1
    }
    返回 r
}

// Framebuffer报告
定义 可变 _fb_宽 = 0
定义 可变 _fb_高 = 0
定义 可变 _fb_格式 = "RGBA8"
定义 可变 _fb_帧数 = 0

函数 framebuffer_设置(宽, 高, 格式) {
    _fb_宽 = 宽
    _fb_高 = 高
    _fb_格式 = 格式
}

函数 framebuffer_记录帧() { _fb_帧数 = _fb_帧数 + 1 }

函数 framebuffer_报告() {
    定义 可变 r = 字典()
    字典设(r, "宽", 转字符串(_fb_宽))
    字典设(r, "高", 转字符串(_fb_高))
    字典设(r, "格式", _fb_格式)
    字典设(r, "帧数", 转字符串(_fb_帧数))
    返回 r
}

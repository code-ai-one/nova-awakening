// §8 程序入口

函数 main() {
    分配器_初始化()
    元素_初始化原子表()
    // AI总线初始化所有子系统
    定义 视口宽初始 = 1920 * 100    // ×100 subpixel
    定义 视口高初始 = 1080 * 100
    AI总线_初始化_视口(视口宽初始, 视口高初始)

    定义 browser = Browser_创建()
    Browser_导航(browser, "about:blank")
    Browser_主循环(browser)
    PlatformWindow_销毁(browser.平台窗口)
}

函数 AI浏览器_智能渲染(tab) {
    渲染管线_AI驱动更新(tab)
}

函数 样式计算_巡检(档, 文档, 元素, 样式文本) {
    如果 (!样式计算_检查档(档)) { 返回 样式计算_失败(档, "巡检", "计算档不可用") }
    样式计算_记录(档, "巡检", [文档, 元素, 样式文本], "样式计算")
    定义 可变 报告 = []
    定义 引擎 = 样式计算_新引擎(档, 文档).数据
    追加(报告, 样式计算_加样式表(档, 引擎, 样式文本).数据)
    追加(报告, 样式计算_更新活跃表(档, 引擎).数据)
    追加(报告, 样式计算_解析元素(档, 引擎, 元素).数据)
    追加(报告, 样式计算_性能统计(档).数据)
    追加(报告, 样式计算_缓存命中率(档).数据)
    返回 样式计算_成功(档, "巡检", 报告)
}

函数 样式计算_摘要(档) {
    定义 摘要 = 计算摘要 {}
    摘要.名称 = 档.名称
    摘要.引擎数 = 档.引擎数
    摘要.规则数 = 档.规则数
    摘要.属性数 = 档.属性数
    摘要.继承数 = 档.继承数
    摘要.长度数 = 档.长度数
    摘要.命中数 = 档.命中数
    摘要.成功数 = 档.成功数
    摘要.失败数 = 档.失败数
    摘要.健康 = 样式计算_刷新健康(档)
    返回 摘要
}

函数 样式计算_健康(档) {
    如果 (档 == 空) { 返回 "无档" }
    返回 样式计算_刷新健康(档)
}

函数 样式计算_自检(档) {
    如果 (!样式计算_检查档(档)) { 返回 假 }
    如果 (样式计算_性能统计(档).已成 == 假) { 返回 假 }
    如果 (样式计算_缓存命中率(档).已成 == 假) { 返回 假 }
    返回 真
}

函数 样式计算_处理(档, 请求) {
    如果 (请求 == 空) { 返回 样式计算_失败(档, "处理", "请求为空") }
    如果 (请求.动作 == "初始化") { 样式计算_初始化(档); 返回 样式计算_成功(档, "处理", "已初始化") }
    如果 (请求.动作 == "新引擎") { 返回 样式计算_新引擎(档, 请求.参数[0]) }
    如果 (请求.动作 == "解析元素") { 返回 样式计算_解析元素(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "局部解析") { 返回 样式计算_局部解析(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "注册属性") { 返回 样式计算_注册属性(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3]) }
    如果 (请求.动作 == "统计") { 返回 样式计算_成功(档, "统计", 样式计算_摘要(档)) }
    如果 (请求.动作 == "巡检") { 返回 样式计算_巡检(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    返回 样式计算_失败(档, "处理", "未知动作")
}

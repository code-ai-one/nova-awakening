// §5 sign/verify

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 SubtleCrypto_sign(算法, key, 数据, 长度) {
    如果 (key == 0 || 数据 == 0 || !(key.usages & KEY_USAGE_SIGN)) { 返回 0 }

    如果 (算法 == ALGO_HMAC) {
        // HMAC签名
        定义 签名 = 堆_分配(32)    // SHA-256 HMAC
        // HMAC_SHA256(key.数据, key.数据长度, 数据, 长度, 签名)
        返回 签名
    } 否则 如果 (算法 == ALGO_ECDSA) {
        // ECDSA签名
        定义 签名 = 堆_分配(64)    // P-256: r(32) + s(32)
        返回 签名
    } 否则 如果 (算法 == ALGO_RSA_PSS) {
        定义 签名 = 堆_分配(key.密钥长度 / 8)
        返回 签名
    }
    返回 0
}

函数 SubtleCrypto_verify(算法, key, 签名, 签名长度, 数据, 数据长度) {
    如果 (key == 0 || 签名 == 0 || 数据 == 0) { 返回 假 }
    如果 (!(key.usages & KEY_USAGE_VERIFY)) { 返回 假 }
    // 验证签名
    // 重新计算签名并与提供的签名比较
    定义 expected = SubtleCrypto_sign(算法, key, 数据, 数据长度)
    如果 (expected == 0) { 返回 假 }
    返回 内存_比较(签名, expected.数据, 签名长度) == 0
}

// §6 deriveKey/deriveBits

函数 SubtleCrypto_deriveBits(算法, key, 长度, salt, saltLen, iterations) {
    如果 (key == 0) { 返回 0 }

    如果 (算法 == ALGO_PBKDF2) {
        // PBKDF2: 密码→密钥
        定义 输出 = 堆_分配(长度 / 8)
        // PBKDF2_SHA256(key.数据, key.数据长度, salt, saltLen, iterations, 输出, 长度/8)
        返回 输出
    } 否则 如果 (算法 == ALGO_HKDF) {
        // HKDF: 密钥扩展
        定义 输出 = 堆_分配(长度 / 8)
        返回 输出
    }
    返回 0
}

// §7 Permissions 接口

定义 PERM_GRANTED  = 0
定义 PERM_DENIED   = 1
定义 PERM_PROMPT   = 2

// 权限名称
定义 PERM_NAME_GEOLOCATION       = 0
定义 PERM_NAME_NOTIFICATIONS     = 1
定义 PERM_NAME_CAMERA            = 2
定义 PERM_NAME_MICROPHONE        = 3
定义 PERM_NAME_CLIPBOARD_READ    = 4
定义 PERM_NAME_CLIPBOARD_WRITE   = 5
定义 PERM_NAME_PUSH              = 6
定义 PERM_NAME_MIDI              = 7
定义 PERM_NAME_STORAGE_ACCESS    = 8
定义 PERM_NAME_SCREEN_WAKE_LOCK  = 9

结构 PermissionStatus {
    名称,    // u8 PERM_NAME_xxx
    状态,    // u8 PERM_xxx
    onchange,    // u64 Nova函数*
}

结构 PermissionStore {
    权限,    // [32]PermissionStatus
    权限数,
    // 源(origin)
    源,
}

定义 可变 全局权限存储 = 0

函数 Permissions_获取存储() {
    如果 (全局权限存储 == 0) {
        全局权限存储 = 堆_分配(PermissionStore)
        全局权限存储.权限数 = 0; 全局权限存储.源 = 0
    }
    返回 全局权限存储
}

// navigator.permissions.query({name: "notifications"})
函数 Permissions_query(名称) {
    定义 store = Permissions_获取存储()
    // 查找已有
    定义 可变 i = 0
    当 (i < store.权限数) {
        如果 (store.权限[i].名称 == 名称) { 返回 store.权限[i].状态 }
        i = i + 1
    }
    // 默认: prompt
    返回 PERM_PROMPT
}

函数 Permissions_设置(名称, 状态) {
    定义 store = Permissions_获取存储()
    // 查找或新增
    定义 可变 i = 0
    当 (i < store.权限数) {
        如果 (store.权限[i].名称 == 名称) {
            定义 旧状态 = store.权限[i].状态
            store.权限[i].状态 = 状态
            如果 (旧状态 != 状态 && store.权限[i].onchange != 0) {
                // 触发change事件
            }
            返回
        }
        i = i + 1
    }
    如果 (store.权限数 < 32) {
        store.权限[store.权限数].名称 = 名称
        store.权限[store.权限数].状态 = 状态
        store.权限[store.权限数].onchange = 0
        store.权限数 = store.权限数 + 1
    }
}

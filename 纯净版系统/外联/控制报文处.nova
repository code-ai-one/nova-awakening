// ICMP消息处理

函数 icmp_处理不可达(Nova缓冲, 代码) {
    定义 icmp头 = Nova缓冲.数据 + Nova缓冲.传输层偏移
    // 提取嵌入的原始IP头
    定义 原始IP头 = icmp头 + ICMP_头部大小

    匹配 (代码) {
        ICMP_网络不可达 => {
            内核警告("ICMP: 网络不可达 来自 %s\n", IP地址_转字符串(Nova缓冲.源IP))
        }
        ICMP_主机不可达 => {
            内核警告("ICMP: 主机不可达 来自 %s\n", IP地址_转字符串(Nova缓冲.源IP))
        }
        ICMP_端口不可达 => {
            // 通知传输层socket
            icmp_通知传输层(原始IP头, 错误码_连接被拒)
        }
        ICMP_需要分片 => {
            定义 mtu = 网络序_读u16(icmp头, ICMP_偏移_序列号)
            内核信息("ICMP: 需要分片 MTU=%d 来自 %s\n", mtu, IP地址_转字符串(Nova缓冲.源IP))
            // 更新路径MTU
        }
        _ => {}
    }
}

函数 icmp_处理超时(Nova缓冲, 代码) {
    内核警告("ICMP: TTL超时 来自 %s\n", IP地址_转字符串(Nova缓冲.源IP))
}

函数 icmp_处理重定向(Nova缓冲, 代码) {
    定义 icmp头 = Nova缓冲.数据 + Nova缓冲.传输层偏移
    定义 新网关 = 网络序_读u32(icmp头, ICMP_偏移_标识符)
    内核信息("ICMP: 重定向到网关 %s\n", IP地址_转字符串(新网关))
    // 更新路由缓存
}

函数 icmp_通知传输层(原始IP头, 错误码) {
    // 提取协议和端口，通知对应的socket
    定义 协议 = 原始IP头[9]
    匹配 (协议) {
        6 => {
            // 传控: 通知传控层
        }
        17 => {
            // 数报: 通知数报层
        }
        _ => {}
    }
}

// ICMP校验和

函数 icmp_计算校验和(icmp头, 长度) {
    网络序_写u16(icmp头, ICMP_偏移_校验和, 0)

    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < 长度 - 1) {
        和 = 和 + (icmp头[i] << 8) + icmp头[i + 1]
        i = i + 2
    }
    如果 (长度 % 2 != 0) {
        和 = 和 + (icmp头[长度 - 1] << 8)
    }

    当 (和 > 0xFFFF) {
        和 = (和 >> 16) + (和 & 0xFFFF)
    }

    网络序_写u16(icmp头, ICMP_偏移_校验和, ~和 & 0xFFFF)
}

函数 icmp_验证校验和(icmp头, 长度) {
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < 长度 - 1) {
        和 = 和 + (icmp头[i] << 8) + icmp头[i + 1]
        i = i + 2
    }
    如果 (长度 % 2 != 0) {
        和 = 和 + (icmp头[长度 - 1] << 8)
    }
    当 (和 > 0xFFFF) {
        和 = (和 >> 16) + (和 & 0xFFFF)
    }
    返回 (和 & 0xFFFF) == 0xFFFF
}

// ICMP限速

函数 icmp_限速检查() {
    定义 当前时间 = 当前时间_秒()
    如果 (当前时间 - icmp_上次发送时间 > ICMP_限速_间隔) {
        icmp_上次发送时间 = 当前时间
        icmp_突发计数 = 0
    }
    如果 (icmp_突发计数 >= ICMP_限速_突发) {
        返回 假
    }
    icmp_突发计数 = icmp_突发计数 + 1
    返回 真
}

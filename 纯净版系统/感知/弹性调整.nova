// §6 §9.3 弹性调整 (Resolve 弹性ible Lengths)

函数 弹性布局_弹性调整(容器, 行) {
    如果 (行 == 0) { 返回 }

    定义 剩余 = 行.剩余空间
    如果 (剩余 == 0) { 返回 }

    定义 是增长 = 剩余 > 0

    // 初始化: 所有项目未冻结
    定义 可变 i = 行.起始索引
    当 (i < 行.结束索引) {
        定义 项 = 弹性布局_获取项(容器, i)
        项.已冻结 = 假
        // 没有grow/shrink能力的项目直接冻结
        如果 (是增长 && 项.flex_grow == 0) { 项.已冻结 = 真 }
        如果 (!是增长 && 项.flex_shrink == 0) { 项.已冻结 = 真 }
        i = i + 1
    }

    // 迭代分配(最多10轮, 防止无限循环)
    定义 可变 轮次 = 0
    当 (轮次 < 10) {
        // 计算未冻结项的总flex因子
        定义 可变 总因子 = 0
        定义 可变 未冻结数 = 0
        i = 行.起始索引
        当 (i < 行.结束索引) {
            定义 项 = 弹性布局_获取项(容器, i)
            如果 (!项.已冻结) {
                如果 (是增长) { 总因子 = 总因子 + 项.flex_grow }
                否则 { 总因子 = 总因子 + 项.flex_shrink }
                未冻结数 = 未冻结数 + 1
            }
            i = i + 1
        }
        如果 (未冻结数 == 0 || 总因子 == 0) { 跳出 }

        // 按比例分配剩余空间
        定义 可变 有冻结 = 假
        i = 行.起始索引
        当 (i < 行.结束索引) {
            定义 项 = 弹性布局_获取项(容器, i)
            如果 (!项.已冻结) {
                定义 因子 = 如果(是增长, 项.flex_grow, 项.flex_shrink)
                定义 份额 = 剩余 * 因子 / 总因子
                定义 新尺寸 = 项.基准尺寸 + 份额

                // 检查min/max约束
                定义 最小 = 0    // min-width/min-height
                定义 最大 = 0x7FFFFFFF    // max-width/max-height

                如果 (新尺寸 < 最小) {
                    新尺寸 = 最小; 项.已冻结 = 真; 有冻结 = 真
                }
                如果 (新尺寸 > 最大) {
                    新尺寸 = 最大; 项.已冻结 = 真; 有冻结 = 真
                }
                项.主轴尺寸 = 新尺寸
            }
            i = i + 1
        }

        如果 (!有冻结) { 跳出 }

        // 重新计算剩余空间
        定义 可变 新已用 = 0
        i = 行.起始索引
        当 (i < 行.结束索引) {
            定义 项 = 弹性布局_获取项(容器, i)
            新已用 = 新已用 + 项.主轴尺寸 + 项.主轴margin前 + 项.主轴margin后
            i = i + 1
        }
        剩余 = 容器.可用主轴 - 新已用

        轮次 = 轮次 + 1
    }
}

// §7 §9.4 交叉轴尺寸

函数 弹性布局_计算交叉轴(容器) {
    定义 可变 l = 0
    当 (l < 容器.行数) {
        定义 行 = 弹性布局_获取行(容器, l)
        定义 可变 最大交叉 = 0

        定义 可变 i = 行.起始索引
        当 (i < 行.结束索引) {
            定义 项 = 弹性布局_获取项(容器, i)

            // 确定align-self
            定义 对齐 = 项.align_self
            如果 (对齐 == ALIGN_AUTO) { 对齐 = 容器.交叉轴对齐 }

            如果 (对齐 == ALIGN_STRETCH && 项.交叉轴尺寸 == 0) {
                // stretch: 稍后设为行高
            } 否则 {
                // 使用固有交叉轴尺寸
                如果 (项.布局对象 != 0) {
                    定义 是行方向 = 容器.方向 == FLEX_DIR_ROW || 容器.方向 == FLEX_DIR_ROW_REVERSE
                    如果 (是行方向) {
                        项.交叉轴尺寸 = 项.布局对象.高度
                    } 否则 {
                        项.交叉轴尺寸 = 项.布局对象.宽度
                    }
                }
            }

            定义 外部交叉 = 项.交叉轴尺寸 + 项.交叉margin前 + 项.交叉margin后
            如果 (外部交叉 > 最大交叉) { 最大交叉 = 外部交叉 }

            i = i + 1
        }

        行.交叉轴尺寸 = 最大交叉

        // stretch项设为行高
        i = 行.起始索引
        当 (i < 行.结束索引) {
            定义 项 = 弹性布局_获取项(容器, i)
            定义 对齐 = 项.align_self
            如果 (对齐 == ALIGN_AUTO) { 对齐 = 容器.交叉轴对齐 }
            如果 (对齐 == ALIGN_STRETCH && 项.交叉轴尺寸 == 0) {
                项.交叉轴尺寸 = 行.交叉轴尺寸 - 项.交叉margin前 - 项.交叉margin后
            }
            i = i + 1
        }

        l = l + 1
    }
}

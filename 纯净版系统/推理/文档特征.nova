// §9 辅助: 从DOM节点提取特征

// 提取类名哈希特征(8维)

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("./值乘.nova")
导入("../执行/控制台输出.nova")
导入("../感知/原子驻留.nova")

函数 提取_类名特征(节点) {
    定义 特征 = Tensor_创建(1, 8)
    如果 (节点 == 0) { 返回 特征 }
    // 类名哈希的8个字节作为特征
    定义 类名 = 节点_获取class(节点)
    如果 (类名 != 0) {
        定义 哈希 = 字符串_哈希(类名)
        定义 可变 i = 0
        当 (i < 8) {
            Tensor_写(特征, 0, i, ((哈希 >> (i * 4)) & 0xF) * 64)
            i = i + 1
        }
    }
    返回 特征
}

// 提取结构特征(8维)
函数 提取_结构特征(节点) {
    定义 特征 = Tensor_创建(1, 8)
    如果 (节点 == 0) { 返回 特征 }

    // [0] DOM深度(归一化)
    定义 深度 = 节点_获取深度(节点)
    Tensor_写(特征, 0, 0, 如果(深度 > 20, Q_ONE, 深度 * Q_ONE / 20))

    // [1] 子节点数量(归一化)
    定义 子数 = 节点_获取子节点数(节点)
    Tensor_写(特征, 0, 1, 如果(子数 > 50, Q_ONE, 子数 * Q_ONE / 50))

    // [2] 文本内容长度(归一化)
    定义 文本长 = 节点_获取文本长度(节点)
    Tensor_写(特征, 0, 2, 如果(文本长 > 1000, Q_ONE, 文本长 * Q_ONE / 1000))

    // [3] 是否有ID属性
    Tensor_写(特征, 0, 3, 如果(节点_有ID(节点), Q_ONE, 0))

    // [4] 兄弟节点位置(在父节点中的位置, 归一化)
    Tensor_写(特征, 0, 4, Q_HALF)    // 默认中性值

    // [5] 是否包含链接
    Tensor_写(特征, 0, 5, 如果(节点_包含链接(节点), Q_ONE, 0))

    // [6] 是否包含图片
    Tensor_写(特征, 0, 6, 如果(节点_包含图片(节点), Q_ONE, 0))

    // [7] 是否包含表单控件
    Tensor_写(特征, 0, 7, 如果(节点_包含表单(节点), Q_ONE, 0))

    返回 特征
}

// NDFE理论 — Nova DOM特征提取理论 (Nova DOM Feature Extraction)
// 理论核心: 多维特征正交分解 + 记忆化特征缓存 + AI语义丰富度评分
// 公式1: Feature = [struct(8) | class(8) | style(8) | interact(8)] = 32维
// 公式2: CacheHit = 节点.版本 == 缓存.版本 → 直接复用
// 公式3: SemanticRichness = AI(特征向量) → [0,1] 语义重要度

定义 标签_DIV = 1
定义 标签_P = 2
定义 标签_SPAN = 3
定义 标签_A = 4
定义 标签_IMG = 5
定义 标签_INPUT = 6
定义 标签_BUTTON = 7
定义 标签_H1 = 8
定义 标签_H2 = 9
定义 标签_UL = 10
定义 标签_LI = 11
定义 标签_TABLE = 12
定义 标签_FORM = 13
定义 标签_NAV = 14
定义 标签_ARTICLE = 15
定义 标签_SECTION = 16
定义 标签_HEADER = 17
定义 标签_FOOTER = 18
定义 标签_VIDEO = 19
定义 标签_CANVAS = 20

定义 特征_结构维数 = 8
定义 特征_类名维数 = 8
定义 特征_样式维数 = 8
定义 特征_交互维数 = 8
定义 特征_总维数 = 32

定义 特征缓存_容量 = 256
定义 可变 特征缓存_键 = 空   // 节点指针数组
定义 可变 特征缓存_版本 = 空  // 节点版本数组
定义 可变 特征缓存_值 = 空   // Tensor数组
定义 可变 特征缓存_已初始化 = 假

定义 可变 特征_提取总次数 = 0
定义 可变 特征_缓存命中 = 0
定义 可变 特征_缓存未中 = 0
定义 可变 特征_AI分类次数 = 0

// §10 特征缓存管理

函数 特征缓存_初始化() {
    如果 (特征缓存_已初始化) { 返回 }
    特征缓存_键 = 数组_创建(特征缓存_容量, 0)
    特征缓存_版本 = 数组_创建(特征缓存_容量, 0)
    特征缓存_值 = 数组_创建(特征缓存_容量, 空)
    特征缓存_已初始化 = 真
}

函数 特征缓存_查找(节点) {
    如果 (!特征缓存_已初始化) { 返回 空 }
    定义 slot = (节点 >> 4) % 特征缓存_容量
    如果 (特征缓存_键[slot] == 节点 &&
        特征缓存_版本[slot] == 节点_获取版本(节点)) {
        特征_缓存命中 = 特征_缓存命中 + 1
        返回 特征缓存_值[slot]
    }
    特征_缓存未中 = 特征_缓存未中 + 1
    返回 空
}

函数 特征缓存_写入(节点, tensor) {
    如果 (!特征缓存_已初始化) { 特征缓存_初始化() }
    定义 slot = (节点 >> 4) % 特征缓存_容量
    特征缓存_键[slot] = 节点
    特征缓存_版本[slot] = 节点_获取版本(节点)
    特征缓存_值[slot] = tensor
}

函数 特征缓存_清空() {
    可变 i = 0
    当 (i < 特征缓存_容量) {
        如果 (特征缓存_值[i] != 空) {
            Tensor_释放(特征缓存_值[i])
            特征缓存_值[i] = 空
        }
        特征缓存_键[i] = 0
        特征缓存_版本[i] = 0
        i = i + 1
    }
}

// §11 样式特征提取 (8维)

函数 提取_样式特征(节点) {
    定义 特征 = Tensor_创建(1, 特征_样式维数)
    如果 (节点 == 0) { 返回 特征 }

    // [0] display类型: 0=none, 0.25=inline, 0.5=block, 0.75=flex, 1.0=grid
    定义 disp = 节点_获取样式(节点, "display")
    如果 (disp == "none") { Tensor_写(特征, 0, 0, 0) }
    否则 如果 (disp == "inline") { Tensor_写(特征, 0, 0, Q_ONE / 4) }
    否则 如果 (disp == "block") { Tensor_写(特征, 0, 0, Q_HALF) }
    否则 如果 (disp == "flex") { Tensor_写(特征, 0, 0, Q_ONE * 3 / 4) }
    否则 { Tensor_写(特征, 0, 0, Q_ONE) }

    // [1] position类型
    定义 pos = 节点_获取样式(节点, "position")
    如果 (pos == "static") { Tensor_写(特征, 0, 1, 0) }
    否则 如果 (pos == "relative") { Tensor_写(特征, 0, 1, Q_ONE / 3) }
    否则 如果 (pos == "absolute") { Tensor_写(特征, 0, 1, Q_ONE * 2 / 3) }
    否则 { Tensor_写(特征, 0, 1, Q_ONE) }  // fixed/sticky

    // [2] opacity (归一化)
    定义 透明度 = 节点_获取样式数值(节点, "opacity")
    Tensor_写(特征, 0, 2, Q乘(透明度, Q_ONE))

    // [3] font-size (归一化, 0-48px → 0-1)
    定义 字号 = 节点_获取样式数值(节点, "font-size")
    如果 (字号 > 48) { 字号 = 48 }
    Tensor_写(特征, 0, 3, 字号 * Q_ONE / 48)

    // [4] 背景色亮度 (0-1)
    定义 bgL = 节点_获取背景亮度(节点)
    Tensor_写(特征, 0, 4, bgL)

    // [5] 有无变换
    定义 tf = 节点_获取样式(节点, "transform")
    Tensor_写(特征, 0, 5, 如果(tf != "none" && tf != "", Q_ONE, 0))

    // [6] 溢出模式
    定义 ov = 节点_获取样式(节点, "overflow")
    如果 (ov == "hidden" || ov == "scroll" || ov == "auto") {
        Tensor_写(特征, 0, 6, Q_ONE)
    } 否则 {
        Tensor_写(特征, 0, 6, 0)
    }

    // [7] z-index (归一化, 0-100 → 0-1)
    定义 zi = 节点_获取样式数值(节点, "z-index")
    如果 (zi > 100) { zi = 100 }
    Tensor_写(特征, 0, 7, zi * Q_ONE / 100)

    返回 特征
}

// §12 交互特征提取 (8维)

函数 提取_交互特征(节点) {
    定义 特征 = Tensor_创建(1, 特征_交互维数)
    如果 (节点 == 0) { 返回 特征 }

    // [0] 是否可点击
    定义 tag = 节点_获取标签ID(节点)
    可变 可点击 = 假
    如果 (tag == 标签_A || tag == 标签_BUTTON || tag == 标签_INPUT) {
        可点击 = 真
    }
    如果 (节点_有事件监听(节点, "click")) { 可点击 = 真 }
    Tensor_写(特征, 0, 0, 如果(可点击, Q_ONE, 0))

    // [1] 是否可输入
    可变 可输入 = (tag == 标签_INPUT) || 节点_是可编辑(节点)
    Tensor_写(特征, 0, 1, 如果(可输入, Q_ONE, 0))

    // [2] 是否可滚动
    定义 ov = 节点_获取样式(节点, "overflow")
    Tensor_写(特征, 0, 2, 如果(ov == "scroll" || ov == "auto", Q_ONE, 0))

    // [3] 事件监听数量 (归一化, 0-10 → 0-1)
    定义 evtCount = 节点_获取事件数(节点)
    如果 (evtCount > 10) { evtCount = 10 }
    Tensor_写(特征, 0, 3, evtCount * Q_ONE / 10)

    // [4] 是否有tabindex
    定义 tabIdx = 节点_获取属性(节点, "tabindex")
    Tensor_写(特征, 0, 4, 如果(tabIdx != 空, Q_ONE, 0))

    // [5] 是否有aria角色
    定义 role = 节点_获取属性(节点, "role")
    Tensor_写(特征, 0, 5, 如果(role != 空, Q_ONE, 0))

    // [6] 是否有拖拽属性
    定义 draggable = 节点_获取属性(节点, "draggable")
    Tensor_写(特征, 0, 6, 如果(draggable == "真", Q_ONE, 0))

    // [7] 是否在视口内
    定义 在视口 = 节点_是在视口内(节点)
    Tensor_写(特征, 0, 7, 如果(在视口, Q_ONE, 0))

    返回 特征
}

// §13 合并特征向量 (32维)

函数 提取_合并特征(节点) {
    特征_提取总次数 = 特征_提取总次数 + 1

    // 缓存查找
    定义 cached = 特征缓存_查找(节点)
    如果 (cached != 空) { 返回 cached }

    定义 合并 = Tensor_创建(1, 特征_总维数)

    // 结构特征 [0..7]
    定义 结构 = 提取_结构特征(节点)
    可变 i = 0
    当 (i < 特征_结构维数) {
        Tensor_写(合并, 0, i, Tensor_读(结构, 0, i))
        i = i + 1
    }
    Tensor_释放(结构)

    // 类名特征 [8..15]
    定义 类名 = 提取_类名特征(节点)
    i = 0
    当 (i < 特征_类名维数) {
        Tensor_写(合并, 0, 特征_结构维数 + i, Tensor_读(类名, 0, i))
        i = i + 1
    }
    Tensor_释放(类名)

    // 样式特征 [16..23]
    定义 样式 = 提取_样式特征(节点)
    i = 0
    当 (i < 特征_样式维数) {
        Tensor_写(合并, 0, 特征_结构维数 + 特征_类名维数 + i, Tensor_读(样式, 0, i))
        i = i + 1
    }
    Tensor_释放(样式)

    // 交互特征 [24..31]
    定义 交互 = 提取_交互特征(节点)
    i = 0
    当 (i < 特征_交互维数) {
        Tensor_写(合并, 0, 特征_结构维数 + 特征_类名维数 + 特征_样式维数 + i, Tensor_读(交互, 0, i))
        i = i + 1
    }
    Tensor_释放(交互)

    特征缓存_写入(节点, 合并)
    返回 合并
}

// §14 AI语义丰富度评分 (NDFE公式3)

函数 AI_语义丰富度(节点) {
    特征_AI分类次数 = 特征_AI分类次数 + 1
    定义 特征 = 提取_合并特征(节点)
    定义 结果 = AI总线_推理("semantic_richness", 特征)
    可变 分数 = Q_HALF
    如果 (结果 != 空) {
        分数 = Tensor_读(结果, 0, 0)
        Tensor_释放(结果)
    }
    返回 分数
}

函数 AI_节点重要度排序(节点列表) {
    // 按语义丰富度降序
    可变 i = 1
    当 (i < 数组_长度(节点列表)) {
        定义 key = 节点列表[i]
        定义 keyScore = AI_语义丰富度(key)
        可变 j = i - 1
        当 (j >= 0 && AI_语义丰富度(节点列表[j]) < keyScore) {
            节点列表[j + 1] = 节点列表[j]
            j = j - 1
        }
        节点列表[j + 1] = key
        i = i + 1
    }
}

// §15 诊断输出

函数 特征提取_诊断报告() {
    可变 报告 = "[NDFE诊断报告]\n"
    报告 = 报告 + "提取总次数: " + 特征_提取总次数 + "\n"
    报告 = 报告 + "缓存命中: " + 特征_缓存命中 + "\n"
    报告 = 报告 + "缓存未中: " + 特征_缓存未中 + "\n"
    报告 = 报告 + "AI分类次数: " + 特征_AI分类次数 + "\n"
    如果 (特征_提取总次数 > 0) {
        定义 命中率 = (特征_缓存命中 * 100) / 特征_提取总次数
        报告 = 报告 + "缓存命中率: " + 命中率 + "%\n"
    }
    返回 报告
}

函数 节点_获取标签ID(节点) {
    如果 (节点 == 0) { 返回 0 }
    返回 节点.标签原子
}
函数 节点_获取class(节点) {
    如果 (节点 == 0) { 返回 0 }
    返回 元素_getAttribute(节点, "class")
}
函数 节点_获取深度(节点) {
    如果 (节点 == 0) { 返回 0 }
    可变 depth = 0
    可变 p = 节点.父节点
    当 (p != 0) { depth = depth + 1; p = p.父节点 }
    返回 depth
}
函数 节点_获取子节点数(节点) {
    如果 (节点 == 0) { 返回 0 }
    返回 节点.子节点数
}
函数 节点_获取文本长度(节点) {
    如果 (节点 == 0) { 返回 0 }
    如果 (节点.类型 == 节点类型_文本) { 返回 字节长度(节点.数据) }
    可变 total = 0
    可变 child = 节点.第一个子节点
    当 (child != 0) {
        total = total + 节点_获取文本长度(child)
        child = child.下一个兄弟
    }
    返回 total
}
函数 节点_有ID(节点) {
    如果 (节点 == 0) { 返回 假 }
    返回 节点_获取属性(节点, "id") != 空
}
函数 节点_包含链接(节点) {
    如果 (节点 == 0) { 返回 假 }
    返回 节点_查找后代标签(节点, 标签_A) != 空
}
函数 节点_包含图片(节点) {
    如果 (节点 == 0) { 返回 假 }
    返回 节点_查找后代标签(节点, 标签_IMG) != 空
}
函数 节点_包含表单(节点) {
    如果 (节点 == 0) { 返回 假 }
    返回 节点_查找后代标签(节点, 标签_FORM) != 空
}
函数 节点_获取版本(节点) { 如果 (节点 == 0) { 返回 0 } 返回 节点.版本 }
函数 节点_获取样式(节点, 属性名) { 返回 "" }
函数 节点_获取样式数值(节点, 属性名) {
    // 从节点的计算样式中获取数值属性(px值)
    如果 (节点 == 0) { 返回 0 }
    定义 样式 = 节点.计算样式
    如果 (样式 == 空) { 返回 0 }
    定义 值 = 样式表_获取(样式, 属性名)
    如果 (值 == 空) { 返回 0 }
    返回 值
}
函数 节点_获取背景亮度(节点) { 返回 Q_HALF }
函数 节点_获取属性(节点, 名称) {
    // 从节点的属性列表中查找指定名称的属性值
    如果 (节点 == 0 || 名称 == 空) { 返回 空 }
    定义 attrs = 节点.属性列表
    如果 (attrs == 空) { 返回 空 }
    定义 可变 i = 0
    当 (i < 计数(attrs)) {
        如果 (attrs[i].名称 == 名称) { 返回 attrs[i].值 }
        i = i + 1
    }
    返回 空
}
函数 节点_有事件监听(节点, 事件名) {
    // 检查节点是否注册了指定事件的监听器
    如果 (节点 == 0 || 事件名 == 空) { 返回 假 }
    定义 监听器 = 节点.事件监听器
    如果 (监听器 == 空) { 返回 假 }
    定义 可变 i = 0
    当 (i < 计数(监听器)) {
        如果 (监听器[i].事件名 == 事件名) { 返回 真 }
        i = i + 1
    }
    返回 假
}
函数 节点_是可编辑(节点) {
    // 检查节点是否可编辑: contenteditable属性或input/textarea元素
    如果 (节点 == 0) { 返回 假 }
    如果 (节点.标签ID == 标签_INPUT || 节点.标签ID == 标签_TEXTAREA) { 返回 真 }
    定义 ce = 节点_获取属性(节点, "contenteditable")
    如果 (ce != 空 && ce == "真") { 返回 真 }
    返回 假
}
函数 节点_获取事件数(节点) {
    // 返回节点上注册的事件监听器总数
    如果 (节点 == 0 || 节点.事件监听器 == 空) { 返回 0 }
    返回 计数(节点.事件监听器)
}
函数 节点_是在视口内(节点) {
    // 检查节点的边界框是否与视口相交
    如果 (节点 == 0) { 返回 假 }
    定义 bbox = 节点.边界框
    如果 (bbox == 空) { 返回 真 }  // 无布局信息时假定可见
    // 视口大小
    定义 vw = 视口_宽度()
    定义 vh = 视口_高度()
    // AABB相交测试
    如果 (bbox.x + bbox.宽 > 0 && bbox.x < vw && bbox.y + bbox.高 > 0 && bbox.y < vh) { 返回 真 }
    返回 假
}
函数 节点_查找后代标签(节点, 标签ID) {
    // 深度优先搜索后代节点中第一个匹配指定标签的节点
    如果 (节点 == 0) { 返回 空 }
    定义 子节点 = 节点.子节点
    如果 (子节点 == 空) { 返回 空 }
    定义 可变 i = 0
    当 (i < 计数(子节点)) {
        如果 (子节点[i].标签ID == 标签ID) { 返回 子节点[i] }
        定义 找到 = 节点_查找后代标签(子节点[i], 标签ID)
        如果 (找到 != 空) { 返回 找到 }
        i = i + 1
    }
    返回 空
}

// §16 批量提取与特征归一化

函数 批量提取特征(节点列表) {
    如果 (数组_长度(节点列表) == 0) { 返回 [] }
    可变 结果 = []
    可变 i = 0
    当 (i < 数组_长度(节点列表)) {
        定义 特征 = 提取_合并特征(节点列表[i])
        追加(结果, 特征)
        i = i + 1
    }
    返回 结果
}

函数 特征_Min_Max归一化(tensor, 维度) {
    // 将特征归一化到[0, Q10]
    如果 (tensor == 0 || 维度 <= 0) { 返回 }
    可变 min_v = Tensor_读(tensor, 0, 0)
    可变 max_v = min_v
    可变 i = 1
    当 (i < 维度) {
        定义 v = Tensor_读(tensor, 0, i)
        如果 (v < min_v) { min_v = v }
        如果 (v > max_v) { max_v = v }
        i = i + 1
    }
    定义 范围 = max_v - min_v
    如果 (范围 <= 0) { 返回 }
    i = 0
    当 (i < 维度) {
        定义 v = Tensor_读(tensor, 0, i)
        Tensor_写(tensor, 0, i, (v - min_v) * Q10 / 范围)
        i = i + 1
    }
}

函数 特征_Z_Score归一化(tensor, 维度) {
    // Z-score: (x - 均值) / 标准差
    如果 (tensor == 0 || 维度 <= 0) { 返回 }
    可变 总和 = 0
    可变 i = 0
    当 (i < 维度) {
        总和 = 总和 + Tensor_读(tensor, 0, i)
        i = i + 1
    }
    定义 均值 = 总和 / 维度
    可变 方差和 = 0
    i = 0
    当 (i < 维度) {
        定义 d = Tensor_读(tensor, 0, i) - 均值
        方差和 = 方差和 + d * d / Q10
        i = i + 1
    }
    定义 标准差 = 方差和 / 维度
    // 开方近似
    可变 s = Q10
    可变 iter = 0
    当 (iter < 10 && s > 0) {
        s = (s + 标准差 * Q10 / s) / 2
        iter = iter + 1
    }
    如果 (s <= 0) { s = 1 }
    i = 0
    当 (i < 维度) {
        定义 v = Tensor_读(tensor, 0, i)
        Tensor_写(tensor, 0, i, (v - 均值) * Q10 / s)
        i = i + 1
    }
}

函数 特征提取_重置统计() {
    特征_提取总次数 = 0
    特征_缓存命中 = 0
    特征_缓存未中 = 0
    特征_AI分类次数 = 0
}

// NDFE+ — Nova Document Feature Extraction (Extended)
// 公理4(批量等价): 批量提取=逐个提取的并列化
// 公理5(归一化不变): Min-Max归一化保持原始顺序
// 定理3(Z-Score均值): Z-Score归一化后均值为0

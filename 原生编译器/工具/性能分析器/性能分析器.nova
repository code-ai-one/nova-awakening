// 龙工具 — 性能分析器 (Profiler)
// 函数级计时、调用图、热点检测、内存追踪
// 支持采样/插桩模式、火焰图数据导出

// 调用记录
// [函数名, 开始tick, 结束tick, 调用者ID, 深度]

导入("../../标准库/基础.nova")

函数 调用记录_创建(函数名, 开始tick, 调用者ID, 深度) { 返回 [函数名, 开始tick, 0, 调用者ID, 深度]
}

函数 调用记录_结束(记录, 结束tick) {
 记录[2] = 结束tick
}

函数 调用记录_耗时(记录) { 返回 记录[2] - 记录[1] }

// 函数统计
// [函数名, 调用次数, 总耗时, 自身耗时, 最小耗时, 最大耗时, 子调用列表]

函数 函数统计_创建(函数名) { 返回 [函数名, 0,x7FFFFFFF, 0, []]
}

函数 函数统计_更新(统计, 耗时) {
 统计[1] = 统计[1] + 1
 统计[2] = 统计[2] + 耗时
 如果 (耗时 < 统计[4]) { 统计[4] = 耗时 }
 如果 (耗时 > 统计[5]) { 统计[5] = 耗时 }
}

函数 函数统计_平均(统计) {
    如果 (统计[1] == 0) { 返回 0
}
 返回 统计[2] / 统计[1]
}

// 性能分析器
// 型: [调用记录列表, 调用栈, 函数统计映射, 当前tick,
// 总采样数, 开始tick, 运行中, 内存快照列表]

函数 分析器_创建() { 返回 [[], [], 字典(), 0, 0, 假, []]
}

函数 分析器_开始(分析器, 当前tick) {
 分析器[5] = 当前tick
 分析器[3] = 当前tick
 分析器[6] = 真
}

函数 分析器_停止(分析器, 当前tick) {
 分析器[3] = 当前tick
 分析器[6] = 假
 // 关闭所有未关闭的调用
 当 (计数(分析器[1]) > 0) {
 分析器_函数退出(分析器, 当前tick)
 }
}

函数 分析器_函数进入(分析器, 函数名, 当前tick) {
    如果 (分析器[6] == 假) { 返回
}
 分析器[3] = 当前tick
 定义 可变 调用者ID = -1
 如果 (计数(分析器[1]) > 0) {
 调用者ID = 分析器[1][计数(分析器[1]) - 1]
 }
 定义 可变 记录 = 调用记录_创建(函数名, 当前tick, 调用者ID, 计数(分析器[1]))
 定义 可变 记录ID = 计数(分析器[0])
 追加(分析器[0], 记录)
 追加(分析器[1], 记录ID)
 分析器[4] = 分析器[4] + 1
}

函数 分析器_函数退出(分析器, 当前tick) {
    如果 (计数(分析器[1]) == 0) { 返回
}
 分析器[3] = 当前tick
 定义 记录ID = 分析器[1][计数(分析器[1]) - 1]
 // 弹出栈
 定义 可变 新栈 = []
 定义 可变 i = 0
 当 (i < 计数(分析器[1]) - 1) { 追加(新栈, 分析器[1][i]) i = i + 1 }
 分析器[1] = 新栈
 // 更新记录
 定义 可变 记录 = 分析器[0][记录ID]
 调用记录_结束(记录, 当前tick)
 // 更新统计
 定义 函数名 = 记录[0]
 定义 可变 统计 = 字典取(分析器[2], 函数名)
 如果 (统计 == 空) {
 统计 = 函数统计_创建(函数名)
 字典设(分析器[2], 函数名, 统计)
 }
 函数统计_更新(统计, 调用记录_耗时(记录))
}

// 内存快照
// [tick, 总分配, 当前使用, 峰值, 分配次数, 释放次数]

函数 分析器_内存快照(分析器, 当前tick, 总分配, 当前使用, 峰值, 分配次数, 释放次数) {
 追加(分析器[7], [当前tick, 总分配, 当前使用, 峰值, 分配次数, 释放次数])
}

// 报告生成

// 热点排名 (按总耗时降序)
函数 分析器_热点(分析器, 前N个) {
 // 收集所有函数统计
 定义 可变 列表 = []
 // 从调用记录中提取唯一函数名
 定义 可变 已添加 = 字典()
 定义 可变 i = 0
 当 (i < 计数(分析器[0])) { 定义 名 = 分析器[0][i][0]
 如果 (字典取(已添加, 名) == 空) { 定义 统计 = 字典取(分析器[2], 名)
 如果 (统计 != 空) {
 追加(列表, 统计)
 字典设(已添加, 名, 真)
 }
 }
 i = i + 1
 }
 // 按总耗时降序排序 (插入排序)
 i = 1
 当 (i < 计数(列表)) { 定义 当前 = 列表[i]
 定义 可变 j = i - 1
 当 (j >= 0 且 列表[j][2] < 当前[2]) {
 列表[j + 1] = 列表[j]
 j = j - 1
 }
 列表[j + 1] = 当前
 i = i + 1
 }
 // 截取前N
 如果 (前N个 > 计数(列表)) { 前N个 = 计数(列表) }
 定义 可变 结果 = []
 i = 0
 当 (i < 前N个) { 追加(结果, 列表[i]) i = i + 1 }
 返回 结果
}

// 调用图 (函数A→函数B 的调用次数)
函数 分析器_调用图(分析器) { 定义 可变 边列表 = []
 定义 可变 i = 0
 当 (i < 计数(分析器[0])) { 定义 可变 记录 = 分析器[0][i]
 如果 (记录[3] >= 0) { 定义 调用者 = 分析器[0][记录[3]][0]
 追加(边列表, [调用者, 记录[0], 调用记录_耗时(记录)])
 }
 i = i + 1
 }
 返回 边列表
}

// 火焰图数据 (folded stack format)
函数 分析器_火焰图数据(分析器) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(分析器[0])) { 定义 记录 = 分析器[0][i]
 如果 (记录[2] == 0) { i = i + 1 续 }
 // 构建栈路径
 定义 可变 路径 = 记录[0]
 定义 可变 父ID = 记录[3]
 当 (父ID >= 0) {
 路径 = 字符串拼接(分析器[0][父ID][0], 字符串拼接(";", 路径))
 父ID = 分析器[0][父ID][3]
 }
 追加(结果, [路径, 调用记录_耗时(记录)])
 i = i + 1
 }
 返回 结果
}

// 文本报告
函数 分析器_文本报告(分析器) { 定义 总时间 = 分析器[3] - 分析器[5]
 定义 可变 报告 = "═══ 性能分析报告 ═══\n"
 报告 = 字符串拼接(报告, "总运行时间: ")
 报告 = 字符串拼接(报告, 分析_数到文(总时间))
 报告 = 字符串拼接(报告, " ticks\n")
 报告 = 字符串拼接(报告, "总采样数: ")
 报告 = 字符串拼接(报告, 分析_数到文(分析器[4]))
 报告 = 字符串拼接(报告, "\n\n--- 热点函数 (Top 10) ---\n")
 定义 热点 = 分析器_热点(分析器, 10)
 定义 可变 i = 0
 当 (i < 计数(热点)) { 定义 s = 热点[i]
 报告 = 字符串拼接(报告, 分析_数到文(i + 1))
 报告 = 字符串拼接(报告, ". ")
 报告 = 字符串拼接(报告, s[0])
 报告 = 字符串拼接(报告, " 调用:")
 报告 = 字符串拼接(报告, 分析_数到文(s[1]))
 报告 = 字符串拼接(报告, " 总耗时:")
 报告 = 字符串拼接(报告, 分析_数到文(s[2]))
 报告 = 字符串拼接(报告, " 平均:")
 报告 = 字符串拼接(报告, 分析_数到文(函数统计_平均(s)))
 报告 = 字符串拼接(报告, "\n")
 i = i + 1
 }
 // 内存
 如果 (计数(分析器[7]) > 0) { 定义 最后 = 分析器[7][计数(分析器[7]) - 1]
 报告 = 字符串拼接(报告, "\n--- 内存 ---\n")
 报告 = 字符串拼接(报告, "当前使用: ")
 报告 = 字符串拼接(报告, 分析_数到文(最后[2]))
 报告 = 字符串拼接(报告, " 峰值: ")
 报告 = 字符串拼接(报告, 分析_数到文(最后[3]))
 报告 = 字符串拼接(报告, "\n")
 }
 返回 报告
}

// 自动计时接口 (使用运行时时间()获取真实毫秒时间戳)
// 解决原设计依赖外部传入tick的问题,分析器可独立产出真实性能数据

函数 分析器_自动开始(分析器) {
    分析器_开始(分析器, 时间())
}

函数 分析器_自动停止(分析器) {
    分析器_停止(分析器, 时间())
}

函数 分析器_自动进入(分析器, 函数名) {
    分析器_函数进入(分析器, 函数名, 时间())
}

函数 分析器_自动退出(分析器) {
    分析器_函数退出(分析器, 时间())
}

函数 分析器_自动内存快照(分析器, 总分配, 当前使用, 峰值, 分配次数, 释放次数) {
    分析器_内存快照(分析器, 时间(), 总分配, 当前使用, 峰值, 分配次数, 释放次数)
}

// 一键性能测量: 执行函数并返回[结果, 耗时ms]
函数 分析器_测量(函数引用, 参数) {
    定义 开始 = 时间()
    定义 结果 = 函数引用(参数)
    定义 耗时 = 时间() - 开始
    返回 [结果, 耗时]
}

// 内部
函数 分析_数到文(n) {
    如果 (n == 0) { 返回 "0"
}
 定义 可变 v = n
 定义 可变 负 = 假
 如果 (v < 0) { 负 = 真 v = 0 - v }
 定义 可变 r = ""
 当 (v > 0) { r = 字符串拼接(子串("0123456789", v % 10, 1), r) v = v / 10 }
 如果 (负) { r = 字符串拼接("-", r) }
 返回 r
}

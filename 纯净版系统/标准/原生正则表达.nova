// Nova标准库 — 正则表达式(版)
// 支持: 字面量 / . / * / + / ? / \d / \w / \s / ^ / $ / [...] / 转义

导入("../中枢/类型定义.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/整数转字符串.nova")

定义 正则_最大匹配 = 256
定义 正则_最大组 = 16

结构 正则匹配结果 {
    起始,
    长度,
    文本,
}

结构 正则统计 {
    匹配调用数,
    匹配成功数,
    匹配失败数,
    包含调用数,
    查找调用数,
    查找全部调用数,
    替换调用数,
    分割调用数,
    回溯次数,
}

定义 可变 全局_正则统计 = 空

函数 正则统计_初始化() {
    如果 (全局_正则统计 == 空) {
        全局_正则统计 = 正则统计 {}
        全局_正则统计.匹配调用数 = 0
        全局_正则统计.匹配成功数 = 0
        全局_正则统计.匹配失败数 = 0
        全局_正则统计.包含调用数 = 0
        全局_正则统计.查找调用数 = 0
        全局_正则统计.查找全部调用数 = 0
        全局_正则统计.替换调用数 = 0
        全局_正则统计.分割调用数 = 0
        全局_正则统计.回溯次数 = 0
    }
}

函数 正则_匹配(模式, 文本) {
    正则统计_初始化()
    全局_正则统计.匹配调用数 = 全局_正则统计.匹配调用数 + 1

    定义 结果 = 正则_匹配_内部(模式, 0, 文本, 0)
    如果 (结果) {
        全局_正则统计.匹配成功数 = 全局_正则统计.匹配成功数 + 1
    } 否则 {
        全局_正则统计.匹配失败数 = 全局_正则统计.匹配失败数 + 1
    }
    返回 结果
}

函数 正则_模式步长(模式, pi) {
    定义 ch = 字符串字符(模式, pi)
    如果 (ch == 92 && pi + 1 < 字符串长度(模式)) { 返回 2 }
    如果 (ch == 91) {
        定义 可变 j = pi + 1
        如果 (j < 字符串长度(模式) && 字符串字符(模式, j) == 93) { j = j + 1 }
        当 (j < 字符串长度(模式) && 字符串字符(模式, j) != 93) { j = j + 1 }
        如果 (j < 字符串长度(模式)) { 返回 j - pi + 1 }
    }
    返回 1
}

定义 可变 正则_递归深度 = 0
定义 正则_最大递归 = 10000

函数 正则_匹配_内部(模式, pi, 文本, ti) {
    正则_递归深度 = 正则_递归深度 + 1
    如果 (正则_递归深度 > 正则_最大递归) { 正则_递归深度 = 正则_递归深度 - 1; 返回 假 }
    如果 (pi >= 字符串长度(模式)) { 正则_递归深度 = 正则_递归深度 - 1; 返回 ti >= 字符串长度(文本) }

    定义 模式字符 = 字符串字符(模式, pi)

    // ^ 锚定行首
    如果 (模式字符 == 94 && pi == 0) {
        返回 正则_匹配_内部(模式, pi + 1, 文本, ti)
    }

    // $ 锚定行尾
    如果 (模式字符 == 36 && pi + 1 >= 字符串长度(模式)) {
        返回 ti >= 字符串长度(文本)
    }

    定义 步长 = 正则_模式步长(模式, pi)

    // 检查量词 * + ?
    定义 可变 下一位 = pi + 步长
    定义 可变 有星号 = 假
    定义 可变 有加号 = 假
    定义 可变 有问号 = 假

    如果 (下一位 < 字符串长度(模式)) {
        定义 q = 字符串字符(模式, 下一位)
        如果 (q == 42) { 有星号 = 真 }
        如果 (q == 43) { 有加号 = 真 }
        如果 (q == 63) { 有问号 = 真 }
    }

    如果 (有星号) {
        // X* 匹配0次或多次
        如果 (正则_匹配_内部(模式, 下一位 + 1, 文本, ti)) { 返回 真 }
        定义 可变 j = ti
        当 (j < 字符串长度(文本)) {
            如果 (!正则_字符匹配_扩展(模式, pi, 步长, 字符串字符(文本, j))) { 跳出 }
            j = j + 1
            如果 (正则_匹配_内部(模式, 下一位 + 1, 文本, j)) { 返回 真 }
            正则统计_初始化()
            全局_正则统计.回溯次数 = 全局_正则统计.回溯次数 + 1
        }
        返回 假
    }

    如果 (有加号) {
        // X+ 匹配1次或多次
        定义 可变 j = ti
        当 (j < 字符串长度(文本)) {
            如果 (!正则_字符匹配_扩展(模式, pi, 步长, 字符串字符(文本, j))) { 跳出 }
            j = j + 1
            如果 (正则_匹配_内部(模式, 下一位 + 1, 文本, j)) { 返回 真 }
            正则统计_初始化()
            全局_正则统计.回溯次数 = 全局_正则统计.回溯次数 + 1
        }
        返回 假
    }

    如果 (有问号) {
        // X? 匹配0次或1次
        如果 (正则_匹配_内部(模式, 下一位 + 1, 文本, ti)) { 返回 真 }
        如果 (ti < 字符串长度(文本) && 正则_字符匹配_扩展(模式, pi, 步长, 字符串字符(文本, ti))) {
            返回 正则_匹配_内部(模式, 下一位 + 1, 文本, ti + 1)
        }
        返回 假
    }

    // 普通字符/转义/字符类
    如果 (ti >= 字符串长度(文本)) { 返回 假 }
    如果 (正则_字符匹配_扩展(模式, pi, 步长, 字符串字符(文本, ti))) {
        返回 正则_匹配_内部(模式, pi + 步长, 文本, ti + 1)
    }
    返回 假
}

函数 正则_字符匹配_扩展(模式, pi, 步长, 文本字符) {
    定义 模式字符 = 字符串字符(模式, pi)

    // 转义序列 \d \w \s \D \W \S
    如果 (模式字符 == 92 && 步长 == 2) {
        定义 转义 = 字符串字符(模式, pi + 1)
        如果 (转义 == 100) { 返回 正则_是数字(文本字符) }          // \d
        如果 (转义 == 68) { 返回 !正则_是数字(文本字符) }          // \D
        如果 (转义 == 119) { 返回 正则_是单词字符(文本字符) }      // \w
        如果 (转义 == 87) { 返回 !正则_是单词字符(文本字符) }      // \W
        如果 (转义 == 115) { 返回 正则_是空白(文本字符) }          // \s
        如果 (转义 == 83) { 返回 !正则_是空白(文本字符) }          // \S
        如果 (转义 == 110) { 返回 文本字符 == 10 }                 // \n
        如果 (转义 == 116) { 返回 文本字符 == 9 }                  // \t
        如果 (转义 == 114) { 返回 文本字符 == 13 }                 // \r
        返回 转义 == 文本字符  // 转义字面量
    }

    // 字符集 [...]
    如果 (模式字符 == 91 && 步长 > 1) {
        返回 正则_字符集匹配(模式, pi, 步长, 文本字符)
    }

    // . 匹配任意字符(不含换行)
    如果 (模式字符 == 46) { 返回 文本字符 != 10 }

    返回 模式字符 == 文本字符
}

函数 正则_字符集匹配(模式, pi, 步长, 文本字符) {
    定义 可变 取反 = 假
    定义 可变 起始 = pi + 1
    如果 (起始 < pi + 步长 && 字符串字符(模式, 起始) == 94) {
        取反 = 真
        起始 = 起始 + 1
    }
    定义 结束 = pi + 步长 - 1
    定义 可变 匹配 = 假
    定义 可变 j = 起始
    当 (j < 结束) {
        如果 (j + 2 < 结束 && 字符串字符(模式, j + 1) == 45) {
            // 范围 a-z
            定义 低 = 字符串字符(模式, j)
            定义 高 = 字符串字符(模式, j + 2)
            如果 (文本字符 >= 低 && 文本字符 <= 高) { 匹配 = 真 }
            j = j + 3
        } 否则 {
            如果 (字符串字符(模式, j) == 文本字符) { 匹配 = 真 }
            j = j + 1
        }
    }
    如果 (取反) { 返回 !匹配 }
    返回 匹配
}

函数 正则_字符匹配(模式字符, 文本字符) {
    如果 (模式字符 == 46) { 返回 文本字符 != 10 }
    返回 模式字符 == 文本字符
}

函数 正则_包含(文本, 模式) {
    正则统计_初始化()
    全局_正则统计.包含调用数 = 全局_正则统计.包含调用数 + 1

    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        如果 (正则_匹配_内部(模式, 0, 文本, i)) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 正则_查找(文本, 模式) {
    正则统计_初始化()
    全局_正则统计.查找调用数 = 全局_正则统计.查找调用数 + 1

    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        如果 (正则_匹配_内部(模式, 0, 文本, i)) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 正则_查找_匹配长度(文本, 模式, 起始) {
    定义 可变 长度 = 0
    定义 可变 j = 起始
    当 (j <= 字符串长度(文本)) {
        定义 子串 = 字符串子串(文本, 起始, j)
        如果 (正则_匹配(模式, 子串)) {
            长度 = j - 起始
        }
        j = j + 1
    }
    返回 长度
}

函数 正则_查找全部(文本, 模式) {
    正则统计_初始化()
    全局_正则统计.查找全部调用数 = 全局_正则统计.查找全部调用数 + 1

    定义 可变 结果 = []
    定义 可变 i = 0
    定义 可变 找到数 = 0
    当 (i < 字符串长度(文本) && 找到数 < 正则_最大匹配) {
        如果 (正则_匹配_内部(模式, 0, 文本, i)) {
            定义 长度 = 正则_查找_匹配长度(文本, 模式, i)
            如果 (长度 <= 0) { 长度 = 1 }
            定义 项 = 正则匹配结果 {}
            项.起始 = i
            项.长度 = 长度
            项.文本 = 字符串子串(文本, i, i + 长度)
            追加(结果, 项)
            找到数 = 找到数 + 1
            i = i + 长度
        } 否则 {
            i = i + 1
        }
    }
    返回 结果
}

函数 正则_替换(文本, 模式, 替换文本) {
    正则统计_初始化()
    全局_正则统计.替换调用数 = 全局_正则统计.替换调用数 + 1

    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        如果 (正则_匹配_内部(模式, 0, 文本, i)) {
            定义 长度 = 正则_查找_匹配长度(文本, 模式, i)
            如果 (长度 <= 0) { 长度 = 1 }
            结果 = 字符串拼接(结果, 替换文本)
            i = i + 长度
        } 否则 {
            结果 = 字符串拼接(结果, 字符串子串(文本, i, i + 1))
            i = i + 1
        }
    }
    返回 结果
}

函数 正则_替换首个(文本, 模式, 替换文本) {
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        如果 (正则_匹配_内部(模式, 0, 文本, i)) {
            定义 长度 = 正则_查找_匹配长度(文本, 模式, i)
            如果 (长度 <= 0) { 长度 = 1 }
            定义 前 = 字符串子串(文本, 0, i)
            定义 后 = 字符串子串(文本, i + 长度, 字符串长度(文本))
            返回 字符串拼接(前, 字符串拼接(替换文本, 后))
        }
        i = i + 1
    }
    返回 文本
}

函数 正则_分割(文本, 模式) {
    正则统计_初始化()
    全局_正则统计.分割调用数 = 全局_正则统计.分割调用数 + 1

    定义 可变 结果 = []
    定义 可变 上次 = 0
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        如果 (正则_匹配_内部(模式, 0, 文本, i)) {
            定义 长度 = 正则_查找_匹配长度(文本, 模式, i)
            如果 (长度 <= 0) { 长度 = 1 }
            追加(结果, 字符串子串(文本, 上次, i))
            上次 = i + 长度
            i = 上次
        } 否则 {
            i = i + 1
        }
    }
    追加(结果, 字符串子串(文本, 上次, 字符串长度(文本)))
    返回 结果
}

函数 正则_计数匹配(文本, 模式) {
    定义 匹配列表 = 正则_查找全部(文本, 模式)
    返回 计数(匹配列表)
}

函数 正则_是数字(ch) { 返回 ch >= 48 && ch <= 57 }
函数 正则_是字母(ch) { 返回 (ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122) }
函数 正则_是空白(ch) { 返回 ch == 32 || ch == 9 || ch == 10 || ch == 13 }
函数 正则_是单词字符(ch) { 返回 正则_是字母(ch) || 正则_是数字(ch) || ch == 95 }
函数 正则_是十六进制(ch) { 返回 正则_是数字(ch) || (ch >= 65 && ch <= 70) || (ch >= 97 && ch <= 102) }

函数 正则_简单查找(模式, 文本) {
    如果 (正则_匹配(模式, 文本)) { 返回 0 }
    返回 0 - 1
}

函数 正则_打印统计() {
    正则统计_初始化()
    打印行("=== 正则表达式统计 ===")
    打印行("匹配调用: " + 整数转字符串(全局_正则统计.匹配调用数))
    打印行("匹配成功: " + 整数转字符串(全局_正则统计.匹配成功数))
    打印行("匹配失败: " + 整数转字符串(全局_正则统计.匹配失败数))
    打印行("包含调用: " + 整数转字符串(全局_正则统计.包含调用数))
    打印行("查找调用: " + 整数转字符串(全局_正则统计.查找调用数))
    打印行("查找全部: " + 整数转字符串(全局_正则统计.查找全部调用数))
    打印行("替换调用: " + 整数转字符串(全局_正则统计.替换调用数))
    打印行("分割调用: " + 整数转字符串(全局_正则统计.分割调用数))
    打印行("回溯次数: " + 整数转字符串(全局_正则统计.回溯次数))
}

//  第五部分: 预编译模式缓存 — 避免重复解析


定义 正则_默认缓存大小 = 32

函数 正则缓存_创建(最大大小) {
    如果 (最大大小 <= 0) { 最大大小 = 正则_默认缓存大小 }
    返回 [[], [], 0, 最大大小]
}

函数 正则缓存_查找(缓存, 模式) {
    定义 可变 i = 0
    当 (i < 缓存[2]) {
        如果 (缓存[0][i] == 模式) {
            缓存[1][i] = 缓存[1][i] + 1
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 正则缓存_添加(缓存, 模式) {
    如果 (正则缓存_查找(缓存, 模式)) { 返回 真 }
    如果 (缓存[2] >= 缓存[3]) {
        定义 可变 最小命中 = 999999999
        定义 可变 最小索引 = 0
        定义 可变 j = 0
        当 (j < 缓存[2]) {
            如果 (缓存[1][j] < 最小命中) {
                最小命中 = 缓存[1][j]
                最小索引 = j
            }
            j = j + 1
        }
        列表_移除(缓存[0], 最小索引)
        列表_移除(缓存[1], 最小索引)
        缓存[2] = 缓存[2] - 1
    }
    追加(缓存[0], 模式)
    追加(缓存[1], 1)
    缓存[2] = 缓存[2] + 1
    返回 真
}

函数 正则缓存_匹配(缓存, 模式, 文本) {
    正则缓存_添加(缓存, 模式)
    返回 正则_匹配(模式, 文本)
}

函数 正则缓存_包含(缓存, 文本, 模式) {
    正则缓存_添加(缓存, 模式)
    返回 正则_包含(文本, 模式)
}

函数 正则缓存_查找全部(缓存, 文本, 模式) {
    正则缓存_添加(缓存, 模式)
    返回 正则_查找全部(文本, 模式)
}

函数 正则缓存_替换(缓存, 文本, 模式, 替换文本) {
    正则缓存_添加(缓存, 模式)
    返回 正则_替换(文本, 模式, 替换文本)
}

函数 正则缓存_大小(缓存) { 返回 缓存[2] }

函数 正则缓存_清空(缓存) {
    设置(缓存, 0, [])
    设置(缓存, 1, [])
    缓存[2] = 0
}

函数 正则缓存_热门(缓存, 数量) {
    定义 可变 结果 = []
    定义 可变 已用 = []
    定义 可变 k = 0
    当 (k < 数量 && k < 缓存[2]) {
        定义 可变 最大 = -1
        定义 可变 最大索引 = 0
        定义 可变 j = 0
        当 (j < 缓存[2]) {
            定义 可变 已使用 = 假
            定义 可变 m = 0
            当 (m < 计数(已用)) {
                如果 (已用[m] == j) { 已使用 = 真 }
                m = m + 1
            }
            如果 (!已使用 && 缓存[1][j] > 最大) {
                最大 = 缓存[1][j]
                最大索引 = j
            }
            j = j + 1
        }
        追加(结果, [缓存[0][最大索引], 最大])
        追加(已用, 最大索引)
        k = k + 1
    }
    返回 结果
}

//  第六部分: 常用模式库 — 内置高频验证模式

函数 正则模式_整数() { 返回 "^\\d+$" }
函数 正则模式_小数() { 返回 "^\\d+\\.\\d+$" }
函数 正则模式_标识符() { 返回 "^[a-zA-Z_]\\w*$" }
函数 正则模式_十六进制() { 返回 "^0[xX][0-9a-fA-F]+$" }
函数 正则模式_空白行() { 返回 "^\\s*$" }
函数 正则模式_非空() { 返回 "\\S" }


函数 正则_是整数(文本) { 返回 正则_匹配(正则模式_整数(), 文本) }
函数 正则_是小数(文本) { 返回 正则_匹配(正则模式_小数(), 文本) }
函数 正则_是标识符(文本) { 返回 正则_匹配(正则模式_标识符(), 文本) }


函数 正则_去除数字(文本) {
    返回 正则_替换(文本, "\\d", "")
}

函数 正则_去除空白(文本) {
    返回 正则_替换(文本, "\\s", "")
}

函数 正则_仅保留数字(文本) {
    返回 正则_替换(文本, "\\D", "")
}

函数 正则_仅保留字母(文本) {
    返回 正则_替换(文本, "[^a-zA-Z]", "")
}

函数 正则_仅保留单词(文本) {
    返回 正则_替换(文本, "\\W", "")
}

//  第七部分: 捨入匹配器 — 多模式同时测试


函数 捨入匹配器_创建() {
    返回 [[], [], 0]
}

函数 捨入匹配器_添加(匹配器, 模式, 标签) {
    追加(匹配器[0], 模式)
    追加(匹配器[1], 标签)
    匹配器[2] = 匹配器[2] + 1
}

函数 捨入匹配器_匹配(匹配器, 文本) {
    定义 可变 i = 0
    当 (i < 匹配器[2]) {
        如果 (正则_包含(文本, 匹配器[0][i])) {
            返回 匹配器[1][i]
        }
        i = i + 1
    }
    返回 空
}

函数 捨入匹配器_全部匹配(匹配器, 文本) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 匹配器[2]) {
        如果 (正则_包含(文本, 匹配器[0][i])) {
            追加(结果, 匹配器[1][i])
        }
        i = i + 1
    }
    返回 结果
}

函数 捨入匹配器_模式数(匹配器) { 返回 匹配器[2] }

//  第八部分:【原生独创】模糊谐振匹配器
//  灵感: 模式与文本之间的“相似度谐振”
//  ×1000 定点算术计算字符距离 + 位置衰减权重

定义 谐振匹配_完全匹配 = 1000   // ×1000 = 1.0
定义 谐振匹配_位置衰减 = 950    // ×1000 = 0.95 每字符位置权重衰减

函数 谐振匹配_字符距离(字符A, 字符B) {
    如果 (字符A == 字符B) { 返回 谐振匹配_完全匹配 }
    定义 差值 = 字符A - 字符B
    如果 (差值 < 0) { 差值 = 0 - 差值 }
    // 大小写不敏感加分: A-a差32, 视为相同
    如果 (差值 == 32) {
        如果 ((字符A >= 65 && 字符A <= 90) || (字符A >= 97 && 字符A <= 122)) {
            如果 ((字符B >= 65 && 字符B <= 90) || (字符B >= 97 && 字符B <= 122)) {
                返回 900  // ×1000 = 0.9 大小写视为高相似
            }
        }
    }
    // 字符距离越大相似度越低
    如果 (差值 >= 128) { 返回 0 }
    返回 1000 - 差值 * 1000 / 128
}

函数 谐振匹配_计算相似度(模式, 文本) {
    定义 模式长 = 字符串长度(模式)
    定义 文本长 = 字符串长度(文本)
    如果 (模式长 == 0 && 文本长 == 0) { 返回 谐振匹配_完全匹配 }
    如果 (模式长 == 0 || 文本长 == 0) { 返回 0 }
    定义 比较长 = 模式长
    如果 (文本长 < 比较长) { 比较长 = 文本长 }
    定义 可变 总分 = 0
    定义 可变 总权重 = 0
    定义 可变 位置权重 = 1000  // 初始权重 ×1000
    定义 可变 i = 0
    当 (i < 比较长) {
        定义 字符分 = 谐振匹配_字符距离(字符串字符(模式, i), 字符串字符(文本, i))
        总分 = 总分 + 字符分 * 位置权重 / 1000
        总权重 = 总权重 + 位置权重
        位置权重 = 位置权重 * 谐振匹配_位置衰减 / 1000
        i = i + 1
    }
    定义 最大长 = 模式长
    如果 (文本长 > 最大长) { 最大长 = 文本长 }
    定义 长度因子 = 比较长 * 1000 / 最大长
    如果 (总权重 == 0) { 返回 0 }
    返回 总分 * 长度因子 / 总权重
}

函数 谐振匹配_批量(模式, 文本列表) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(文本列表)) {
        定义 分数 = 谐振匹配_计算相似度(模式, 文本列表[i])
        追加(结果, [文本列表[i], 分数])
        i = i + 1
    }
    返回 结果
}

函数 谐振匹配_最佳匹配(模式, 文本列表) {
    如果 (计数(文本列表) == 0) { 返回 [空, 0] }
    定义 可变 最佳 = 文本列表[0]
    定义 可变 最佳分 = 谐振匹配_计算相似度(模式, 文本列表[0])
    定义 可变 i = 1
    当 (i < 计数(文本列表)) {
        定义 分数 = 谐振匹配_计算相似度(模式, 文本列表[i])
        如果 (分数 > 最佳分) {
            最佳分 = 分数
            最佳 = 文本列表[i]
        }
        i = i + 1
    }
    返回 [最佳, 最佳分]
}

函数 谐振匹配_阈值过滤(模式, 文本列表, 阈值) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(文本列表)) {
        定义 分数 = 谐振匹配_计算相似度(模式, 文本列表[i])
        如果 (分数 >= 阈值) {
            追加(结果, [文本列表[i], 分数])
        }
        i = i + 1
    }
    返回 结果
}

//  第九部分: 完整统计

函数 正则_完整统计() {
    正则统计_初始化()
    打印行("╔══════════════════════════════════════════╗")
    打印行("║     原生正则表达式模块 · 完整统计      ║")
    打印行("╠══════════════════════════════════════════╣")
    打印行("║ [匹配引擎]                               ║")
    打印行("║   匹配调用:   " + 整数转字符串(全局_正则统计.匹配调用数))
    打印行("║   匹配成功:   " + 整数转字符串(全局_正则统计.匹配成功数))
    打印行("║   匹配失败:   " + 整数转字符串(全局_正则统计.匹配失败数))
    定义 成功率 = 0
    如果 (全局_正则统计.匹配调用数 > 0) {
        成功率 = 全局_正则统计.匹配成功数 * 1000 / 全局_正则统计.匹配调用数
    }
    打印行("║   成功率‰:    " + 整数转字符串(成功率))
    打印行("╠══════════════════════════════════════════╣")
    打印行("║ [查找与替换]                             ║")
    打印行("║   包含调用:   " + 整数转字符串(全局_正则统计.包含调用数))
    打印行("║   查找调用:   " + 整数转字符串(全局_正则统计.查找调用数))
    打印行("║   查找全部:   " + 整数转字符串(全局_正则统计.查找全部调用数))
    打印行("║   替换调用:   " + 整数转字符串(全局_正则统计.替换调用数))
    打印行("║   分割调用:   " + 整数转字符串(全局_正则统计.分割调用数))
    打印行("╠══════════════════════════════════════════╣")
    打印行("║ [性能]                                   ║")
    打印行("║   回溯次数:   " + 整数转字符串(全局_正则统计.回溯次数))
    定义 总调用 = 全局_正则统计.匹配调用数 + 全局_正则统计.包含调用数 + 全局_正则统计.查找调用数 + 全局_正则统计.替换调用数 + 全局_正则统计.分割调用数
    打印行("║   总调用数:   " + 整数转字符串(总调用))
    定义 平均回溯 = 0
    如果 (总调用 > 0) {
        平均回溯 = 全局_正则统计.回溯次数 / 总调用
    }
    打印行("║   平均回溯:   " + 整数转字符串(平均回溯))
    打印行("╚══════════════════════════════════════════╝")
}

定义 可变 AI_原生正则表_调用数 = 0
定义 可变 AI_原生正则表_异常数 = 0

函数 AI_原生正则表_监控() {
    AI_原生正则表_调用数 = AI_原生正则表_调用数 + 1
    返回 AI_原生正则表_异常数 == 0
}

函数 AI_原生正则表_健康检查() {
    如果 (AI_原生正则表_调用数 > 0 && AI_原生正则表_异常数 * 100 / AI_原生正则表_调用数 > 10) {
        返回 假
    }
    返回 真
}

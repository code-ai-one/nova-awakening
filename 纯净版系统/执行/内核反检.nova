结构 反检档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    身份数,
    反追踪数,
    指纹数,
    隐匿数,
    仿真数,
    验证数,
    成功数,
    失败数,
}

结构 反检请求 {
    动作,
    目标,
    文档,
    参数,
    选项,
}

结构 反检回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 反检摘要 {
    名称,
    身份数,
    反追踪数,
    指纹数,
    隐匿数,
    仿真数,
    验证数,
    成功数,
    失败数,
    健康,
}

结构 反检身份 {
    名称,
    模板,
    国家,
    屏宽,
    屏高,
    种子,
}

定义 可变 反检账本 = []
定义 可变 反检身份库 = []
定义 可变 反检构建数 = 0
定义 可变 反检总动作 = 0
定义 可变 反检总成功 = 0
定义 可变 反检总失败 = 0
定义 可变 反检最近种子 = 1107

函数 内核反检_建档(名称) {
    定义 档 = 反检档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.身份数 = 0
    档.反追踪数 = 0
    档.指纹数 = 0
    档.隐匿数 = 0
    档.仿真数 = 0
    档.验证数 = 0
    档.成功数 = 0
    档.失败数 = 0
    返回 档
}

函数 内核反检_登记(档) {
    追加(反检账本, 档)
    反检构建数 = 反检构建数 + 1
    返回 档
}

函数 内核反检_建请求(动作, 目标, 文档, 参数, 选项) {
    定义 请求 = 反检请求 {}
    请求.动作 = 动作
    请求.目标 = 目标
    请求.文档 = 文档
    请求.参数 = 参数
    请求.选项 = 选项
    返回 请求
}

函数 内核反检_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 反检回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 内核反检_完整统计() {
    返回 [
        反检构建数,
        反检总动作,
        反检总成功,
        反检总失败,
        计数(反检身份库)
    ]
}

函数 内核反检_安全计数(列表) {
    如果 (列表 == 空) { 返回 0 }
    返回 计数(列表)
}

函数 内核反检_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.失败数 > 档.成功数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (档.验证数 > 0 || 档.仿真数 > 0 || 档.隐匿数 > 0) {
        档.最近健康 = "运行"
        返回 档.最近健康
    }
    档.最近健康 = "空载"
    返回 档.最近健康
}

函数 内核反检_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    档.最近错误 = ""
    档.最近统计 = 内核反检_完整统计()
}

函数 内核反检_成功(档, 来源, 数据) {
    如果 (档 == 空) {
        反检总动作 = 反检总动作 + 1
        反检总成功 = 反检总成功 + 1
        返回 内核反检_建回证(真, 真, 来源, "", 数据, 内核反检_完整统计())
    }
    档.最近来源 = 来源
    档.最近结果 = 数据
    档.最近错误 = ""
    档.成功数 = 档.成功数 + 1
    反检总动作 = 反检总动作 + 1
    反检总成功 = 反检总成功 + 1
    档.最近统计 = 内核反检_完整统计()
    内核反检_刷新健康(档)
    返回 内核反检_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 内核反检_失败(档, 来源, 错因) {
    如果 (档 == 空) {
        反检总动作 = 反检总动作 + 1
        反检总失败 = 反检总失败 + 1
        返回 内核反检_建回证(真, 假, 来源, 错因, 0, 内核反检_完整统计())
    }
    档.最近来源 = 来源
    档.最近错误 = 错因
    档.失败数 = 档.失败数 + 1
    反检总动作 = 反检总动作 + 1
    反检总失败 = 反检总失败 + 1
    档.最近统计 = 内核反检_完整统计()
    内核反检_刷新健康(档)
    返回 内核反检_建回证(真, 假, 来源, 错因, 0, 档.最近统计)
}

函数 内核反检_建头(名称, 值) {
    返回 [名称, 值]
}

函数 内核反检_补头(请求头, 名称, 值) {
    定义 可变 已有 = 假
    定义 可变 i = 0
    当 (i < 计数(请求头)) {
        如果 (请求头[i][0] == 名称) {
            已有 = 真
        }
        i = i + 1
    }
    如果 (!已有) {
        追加(请求头, 内核反检_建头(名称, 值))
    }
    返回 请求头
}

函数 内核反检_新身份(名称, 模板, 国家, 屏宽, 屏高, 种子) {
    定义 身份 = 反检身份 {}
    身份.名称 = 名称
    身份.模板 = 模板
    身份.国家 = 国家
    身份.屏宽 = 屏宽
    身份.屏高 = 屏高
    身份.种子 = 种子
    返回 身份
}

函数 内核反检_登记身份(档, 身份) {
    追加(反检身份库, 身份)
    档.身份数 = 计数(反检身份库)
    返回 身份
}

函数 内核反检_初始化(档, 种子) {
    反检最近种子 = 种子
    反追踪_初始化()
    指纹伪装_初始化()
    NKSI_初始化()
    指纹防护_初始化(种子)
    身份库_初始化()
    IP隐匿_初始化()
    行为仿真_初始化()
    行为仿真_初始化滚动画像()
    验证破解_初始化()
    NVCR_初始化()
    算术统计_初始化()
    档.是否初始化 = 真
    档.最近动作 = "初始化"
    档.最近来源 = "内核反检_初始化"
    档.最近统计 = 内核反检_完整统计()
    内核反检_刷新健康(档)
    返回 档
}

函数 内核反检_创建(名称) {
    定义 档 = 内核反检_建档(名称)
    内核反检_初始化(档, 1107)
    返回 内核反检_登记(档)
}

函数 内核反检_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (!档.是否初始化) { 返回 假 }
    返回 真
}

函数 内核反检_新建身份(档, 名称, 模板, 国家, 屏宽, 屏高, 种子) {
    如果 (!内核反检_检查档(档)) { 返回 内核反检_失败(档, "新建身份", "反检档不可用") }
    内核反检_记录(档, "新建身份", [名称, 模板, 国家, 屏宽, 屏高, 种子], "身份库")
    定义 配置 = 指纹伪装_新建身份()
    定义 身份 = 内核反检_新身份(名称, 模板, 国家, 屏宽, 屏高, 种子)
    身份库_添加(名称, 配置, 种子)
    档.指纹数 = 档.指纹数 + 1
    返回 内核反检_成功(档, "新建身份", 内核反检_登记身份(档, 身份))
}

函数 内核反检_切换身份(档, 索引) {
    如果 (!内核反检_检查档(档)) { 返回 内核反检_失败(档, "切换身份", "反检档不可用") }
    内核反检_记录(档, "切换身份", [索引], "身份库")
    身份库_切换(索引)
    档.指纹数 = 档.指纹数 + 1
    返回 内核反检_成功(档, "切换身份", 索引)
}

函数 内核反检_随机身份(档) {
    如果 (!内核反检_检查档(档)) { 返回 内核反检_失败(档, "随机身份", "反检档不可用") }
    内核反检_记录(档, "随机身份", [], "身份库")
    定义 结果 = 身份库_随机切换()
    档.指纹数 = 档.指纹数 + 1
    返回 内核反检_成功(档, "随机身份", 结果)
}

函数 内核反检_设置模板(档, 模板名) {
    如果 (!内核反检_检查档(档)) { 返回 内核反检_失败(档, "设置模板", "反检档不可用") }
    内核反检_记录(档, "设置模板", [模板名], "伪装模板")
    定义 结果 = 指纹伪装_切换模板(模板名)
    档.指纹数 = 档.指纹数 + 1
    返回 内核反检_成功(档, "设置模板", 结果)
}

函数 内核反检_设置国家(档, 国家代码) {
    如果 (!内核反检_检查档(档)) { 返回 内核反检_失败(档, "设置国家", "反检档不可用") }
    内核反检_记录(档, "设置国家", [国家代码], "伪装模板")
    指纹伪装_设置国家(国家代码)
    IP隐匿_设置国家(国家代码)
    档.指纹数 = 档.指纹数 + 1
    档.隐匿数 = 档.隐匿数 + 1
    返回 内核反检_成功(档, "设置国家", 国家代码)
}

函数 内核反检_设置屏幕(档, 宽, 高) {
    如果 (!内核反检_检查档(档)) { 返回 内核反检_失败(档, "设置屏幕", "反检档不可用") }
    内核反检_记录(档, "设置屏幕", [宽, 高], "伪装模板")
    定义 结果 = 指纹伪装_设置屏幕分辨率(宽, 高)
    档.指纹数 = 档.指纹数 + 1
    返回 内核反检_成功(档, "设置屏幕", 结果)
}

函数 内核反检_防护级别(档) {
    如果 (!内核反检_检查档(档)) { 返回 内核反检_失败(档, "防护级别", "反检档不可用") }
    内核反检_记录(档, "防护级别", [], "指纹防护")
    返回 内核反检_成功(档, "防护级别", 指纹_获取防护级别())
}

函数 内核反检_获取安全指纹(档, 浏览器名) {
    如果 (!内核反检_检查档(档)) { 返回 内核反检_失败(档, "获取安全指纹", "反检档不可用") }
    内核反检_记录(档, "获取安全指纹", [浏览器名], "反追踪")
    档.反追踪数 = 档.反追踪数 + 1
    返回 内核反检_成功(档, "获取安全指纹", 反追踪_获取安全指纹(浏览器名))
}

函数 内核反检_构造握手(档, 模板) {
    如果 (!内核反检_检查档(档)) { 返回 内核反检_失败(档, "构造握手", "反检档不可用") }
    内核反检_记录(档, "构造握手", [模板], "反追踪")
    档.反追踪数 = 档.反追踪数 + 1
    返回 内核反检_成功(档, "构造握手", 反追踪_构造ClientHello(模板))
}

函数 内核反检_排序头(档, 请求头, 浏览器名) {
    如果 (!内核反检_检查档(档)) { 返回 内核反检_失败(档, "排序头", "反检档不可用") }
    内核反检_记录(档, "排序头", [请求头, 浏览器名], "反追踪")
    定义 已排序 = 反追踪_排序HTTP头(请求头, 浏览器名)
    档.反追踪数 = 档.反追踪数 + 1
    返回 内核反检_成功(档, "排序头", 已排序)
}

函数 内核反检_补齐头(档, 请求头) {
    如果 (!内核反检_检查档(档)) { 返回 内核反检_失败(档, "补齐头", "反检档不可用") }
    内核反检_记录(档, "补齐头", [请求头], "反追踪")
    定义 可变 结果 = 请求头
    定义 额外 = 反追踪_生成SecChUa头()
    定义 可变 i = 0
    当 (i < 计数(额外)) {
        结果 = 内核反检_补头(结果, 额外[i][0], 额外[i][1])
        i = i + 1
    }
    档.反追踪数 = 档.反追踪数 + 1
    返回 内核反检_成功(档, "补齐头", 结果)
}

函数 内核反检_修复环境(档) {
    如果 (!内核反检_检查档(档)) { 返回 内核反检_失败(档, "修复环境", "反检档不可用") }
    内核反检_记录(档, "修复环境", [], "反追踪")
    档.反追踪数 = 档.反追踪数 + 1

函数 反哺_提取数量() {
    返回 5
}

函数 反哺_目标文件(序号) {
    如果 (序号 == 0) { 返回 "纯净版系统/推理/遗忘曲线.nova" }
    如果 (序号 == 1) { 返回 "纯净版系统/推理/回复核心.nova" }
    如果 (序号 == 2) { 返回 "纯净版系统/推理/知识蒸馏.nova" }
    如果 (序号 == 3) { 返回 "纯净版系统/推理/强化对齐.nova" }
    如果 (序号 == 4) { 返回 "纯净版系统/推理/语义嵌入.nova" }
    返回 ""
}

函数 反哺_旧理论(序号) {
    如果 (序号 == 0) { 返回 "遗忘曲线+PAC+VC" }
    如果 (序号 == 1) { 返回 "模板缓存+局部意图切换" }
    如果 (序号 == 2) { 返回 "教师学生单主路" }
    如果 (序号 == 3) { 返回 "DPO/PPO外环主导" }
    如果 (序号 == 4) { 返回 "量化与长上下文压缩" }
    返回 ""
}

函数 反哺_原创核心(序号) {
    如果 (序号 == 0) { 返回 "记忆晶化阈压理论" }
    如果 (序号 == 1) { 返回 "意图势场锁定理论" }
    如果 (序号 == 2) { 返回 "双环蒸馏协同理论" }
    如果 (序号 == 3) { 返回 "双环偏好外环理论" }
    如果 (序号 == 4) { 返回 "认知几何折叠理论" }
    返回 ""
}

函数 反哺_替换动作(序号) {
    如果 (序号 == 0) { 返回 "替换遗忘记分为晶化通量主核" }
    如果 (序号 == 1) { 返回 "替换回复决策为势场锁定主核" }
    如果 (序号 == 2) { 返回 "替换单路蒸馏为双环协同蒸馏" }
    如果 (序号 == 3) { 返回 "替换偏好主控为外环稳态调谐" }
    如果 (序号 == 4) { 返回 "替换压缩索引为几何折叠主核" }
    返回 ""
}

函数 反哺_打印提取项(序号) {
    打印("[实验目录][提取] 目标=" + 反哺_目标文件(序号))
    打印("[实验目录][提取] 旧理论=" + 反哺_旧理论(序号))
    打印("[实验目录][提取] 原创核心=" + 反哺_原创核心(序号))
}

函数 反哺_打印提取清单() {
    打印("[实验目录][提取] 遗忘曲线 -> 晶化阈压")
    打印("[实验目录][提取] 回复核心 -> 势场锁定")
    打印("[实验目录][提取] 知识蒸馏 -> 双环蒸馏")
    打印("[实验目录][提取] 强化对齐 -> 偏好外环")
    打印("[实验目录][提取] TurboQuant -> 几何折叠")
}

函数 反哺_打印替换项(序号) {
    打印("[实验目录][替换] 目标=" + 反哺_目标文件(序号))
    打印("[实验目录][替换] 新核心=" + 反哺_原创核心(序号))
    打印("[实验目录][替换] 动作=" + 反哺_替换动作(序号))
}

函数 反哺_打印替换计划() {
    打印("[实验目录][反哺] 遗忘曲线主核 <- 晶化阈压")
    打印("[实验目录][反哺] 回复选择主核 <- 势场锁定")
    打印("[实验目录][反哺] 蒸馏主链 <- 双环蒸馏")
    打印("[实验目录][反哺] 偏好对齐 <- 偏好外环")
    打印("[实验目录][反哺] 压缩表示主核 <- 几何折叠")
    打印("[实验目录][反哺] 约束=必须先通过实验")
}


// 推理模型推演装载
// 将注意力、同步、投机解码与专家模型能力接回 AI 运行时主链。

导入("./模型同步.nova")
导入("./快注意.nova")
导入("./投机解码.nova")
导入("./混合专家.nova")
导入("./分页注意.nova")
导入("./结构相似块.nova")
导入("./感知差异.nova")
导入("./权重转换.nova")

函数 推理模型推演装载_模块清单() {
    返回 [
        "./模型同步.nova",
        "./快注意.nova",
        "./投机解码.nova",
        "./混合专家.nova",
        "./分页注意.nova",
        "./结构相似块.nova",
        "./感知差异.nova",
        "./权重转换.nova"
    ]
}

函数 推理模型推演装载_统计() {
    返回 {
        模块数: 计数(推理模型推演装载_模块清单())
    }
}

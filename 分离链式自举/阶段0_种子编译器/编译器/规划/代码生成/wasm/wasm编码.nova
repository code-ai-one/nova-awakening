// WASM 线程与原子操作 (前缀 0xFE)
定义 操作码_prefix_atomic = 0xFE

函数 wasm_原子操作(操作码) { 定义 结果 = [操作码_prefix_atomic]
 定义 编码值 = wasm_编码_uleb128(操作码)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 返回 结果
}

// memory.atomic.notify — 唤醒等待线程
函数 wasm_原子_通知() { 返回 wasm_原子操作(0) }

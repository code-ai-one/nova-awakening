// NovaOS IP接收
// 职责: IPv4数据包接收、头部验证、校验和、协议分发、分片重组

定义 IP_版本4 = 4
定义 IP_协议_ICMP = 1
定义 IP_协议_传控 = 6
定义 IP_协议_数报 = 17

定义 可变 IP接收_计数 = 0
定义 可变 IP接收_字节 = 0
定义 可变 IP接收_错误 = 0
定义 可变 IP接收_丢弃 = 0
定义 可变 IP接收_校验和失败 = 0
定义 可变 IP接收_分片 = 0

// 核心接收函数

函数 IP_接收(Nova缓冲) {
    定义 数据 = Nova缓冲_数据(Nova缓冲)
    定义 长度 = Nova缓冲_长度(Nova缓冲)

    // 1. 基本长度检查
    如果 (长度 < IP头_标准长度) {
        IP接收_错误 = IP接收_错误 + 1
        返回 错误_无效参数
    }

    // 2. 解析版本和头长度
    定义 版本IHL = 缓冲读(数据, IP头_版本IHL)
    定义 版本 = (版本IHL >> 4) & 0xF
    定义 IHL = (版本IHL & 0xF) * 4   // 头长度(字节)

    如果 (版本 != IP_版本4) {
        IP接收_错误 = IP接收_错误 + 1
        返回 错误_无效参数
    }
    如果 (IHL < IP头_标准长度) {
        IP接收_错误 = IP接收_错误 + 1
        返回 错误_无效参数
    }

    // 3. 校验和验证
    定义 校验结果 = 校验和_计算(数据, IHL)
    如果 (校验结果 != 0) {
        IP接收_校验和失败 = IP接收_校验和失败 + 1
        返回 错误_无效参数
    }

    // 4. 提取关键字段
    定义 总长 = 缓冲读16大端(数据, IP头_总长度)
    定义 标识 = 缓冲读16大端(数据, IP头_标识)
    定义 标志偏移 = 缓冲读16大端(数据, IP头_标志偏移)
    定义 TTL = 缓冲读(数据, IP头_TTL)
    定义 协议 = 缓冲读(数据, IP头_协议)
    定义 源IP = 缓冲读32大端(数据, IP头_源地址)
    定义 目标IP = 缓冲读32大端(数据, IP头_目标地址)

    // 5. 长度一致性检查
    如果 (总长 > 长度) {
        IP接收_丢弃 = IP接收_丢弃 + 1
        返回 错误_无效参数
    }

    // 6. TTL检查 (转发时减1, 本地接收不检查)
    如果 (TTL == 0) {
        // 发送ICMP超时
        IP接收_丢弃 = IP接收_丢弃 + 1
        返回 错误_无效参数
    }

    // 7. 检查是否是分片
    定义 片偏移 = 标志偏移 & 0x1FFF
    定义 更多分片 = (标志偏移 & 0x2000) != 0
    如果 (片偏移 != 0 || 更多分片) {
        IP接收_分片 = IP接收_分片 + 1
        // 分片重组 (简化: 不支持分片)
        IP接收_丢弃 = IP接收_丢弃 + 1
        返回 错误_无效参数
    }

    // 8. 剥离IP头, 调整Nova缓冲指向载荷
    Nova缓冲_拉取(Nova缓冲, IHL)

    // 9. 在Nova缓冲中记录源/目标信息
    Nova缓冲_设源IP(Nova缓冲, 源IP)
    Nova缓冲_设目标IP(Nova缓冲, 目标IP)

    // 10. 根据协议分发
    IP接收_计数 = IP接收_计数 + 1
    IP接收_字节 = IP接收_字节 + 总长

    如果 (协议 == IP_协议_传控) { 返回 传控_接收(Nova缓冲) }
    如果 (协议 == IP_协议_数报) { 返回 数报_接收(Nova缓冲) }
    如果 (协议 == IP_协议_ICMP) { 返回 ICMP_接收(Nova缓冲) }

    // 未知协议: 发送ICMP协议不可达
    IP接收_丢弃 = IP接收_丢弃 + 1
    返回 错误_无效参数
}

// 大端字节序读取

函数 缓冲读16大端(缓冲, 偏移) {
    返回 (缓冲读(缓冲, 偏移) << 8) | 缓冲读(缓冲, 偏移 + 1)
}

函数 缓冲读32大端(缓冲, 偏移) {
    返回 (缓冲读(缓冲, 偏移) << 24) | (缓冲读(缓冲, 偏移 + 1) << 16) |
           (缓冲读(缓冲, 偏移 + 2) << 8) | 缓冲读(缓冲, 偏移 + 3)
}

// 检查是否是本机地址

定义 可变 本机IP = 0

函数 IP_设置本机地址(地址) { 本机IP = 地址 }
函数 IP_获取本机地址() { 返回 本机IP }

函数 IP_是本机地址(地址) {
    如果 (地址 == 本机IP) { 返回 真 }
    如果 (地址 == 0xFFFFFFFF) { 返回 真 }   // 广播
    如果 ((地址 & 0xF0000000) == 0xE0000000) { 返回 真 }  // 多播
    返回 假
}

// 统计

函数 IP接收_统计() {
    返回 [IP接收_计数, IP接收_字节, IP接收_错误, IP接收_丢弃, IP接收_校验和失败, IP接收_分片]
}

// IP头字段偏移常量 

定义 IP头_版本IHL = 0
定义 IP头_TOS = 1
定义 IP头_总长度 = 2
定义 IP头_标识 = 4
定义 IP头_标志偏移 = 6
定义 IP头_TTL = 8
定义 IP头_协议 = 9
定义 IP头_校验和 = 10
定义 IP头_源地址 = 12
定义 IP头_目标地址 = 16
定义 IP头_标准长度 = 20

// IP转发 

定义 可变 IP转发_已启用 = 假
定义 可变 IP转发_计数 = 0

函数 IP_启用转发() { IP转发_已启用 = 真 }
函数 IP_禁用转发() { IP转发_已启用 = 假 }

函数 IP_转发(Nova缓冲) {
    如果 (!IP转发_已启用) {
        IP接收_丢弃 = IP接收_丢弃 + 1
        返回 错误_无效参数
    }

    定义 数据 = Nova缓冲_数据(Nova缓冲)
    // 递减TTL
    定义 ttl = 缓冲读(数据, IP头_TTL)
    如果 (ttl <= 1) {
        // 发送ICMP Time Exceeded
        IP接收_丢弃 = IP接收_丢弃 + 1
        返回 错误_无效参数
    }
    缓冲写(数据, IP头_TTL, ttl - 1)

    // 增量更新校验和 (TTL变化)
    定义 旧校验 = 缓冲读16大端(数据, IP头_校验和)
    定义 新校验 = 校验和_增量更新16(旧校验, ttl << 8, (ttl - 1) << 8)
    缓冲写(数据, IP头_校验和, (新校验 >> 8) & 0xFF)
    缓冲写(数据, IP头_校验和 + 1, 新校验 & 0xFF)

    IP转发_计数 = IP转发_计数 + 1
    // 查路由表发送
    返回 IP_发送_Nova缓冲(Nova缓冲)
}

// IP选项解析 

函数 IP_解析选项(数据, IHL) {
    如果 (IHL <= IP头_标准长度) { 返回 空 }  // 无选项
    定义 可变 选项列表 = []
    定义 可变 偏移 = IP头_标准长度
    当 (偏移 < IHL) {
        定义 类型 = 缓冲读(数据, 偏移)
        如果 (类型 == 0) { 返回 选项列表 }    // End of Options
        如果 (类型 == 1) { 偏移 = 偏移 + 1; 继续 }  // NOP
        如果 (偏移 + 1 >= IHL) { 返回 选项列表 }
        定义 长度 = 缓冲读(数据, 偏移 + 1)
        如果 (长度 < 2 || 偏移 + 长度 > IHL) { 返回 选项列表 }
        追加(选项列表, [类型, 长度])
        偏移 = 偏移 + 长度
    }
    返回 选项列表
}

// 完整统计

函数 IP接收_完整统计() {
    返回 [IP接收_计数, IP接收_字节, IP接收_错误, IP接收_丢弃,
           IP接收_校验和失败, IP接收_分片, IP转发_计数, IP转发_已启用]
}

// 协议名称 + 丢包率

函数 IP_协议名(协议) {
    如果 (协议 == IP_协议_传控) { 返回 "传控" }
    如果 (协议 == IP_协议_数报) { 返回 "数报" }
    如果 (协议 == IP_协议_ICMP) { 返回 "ICMP" }
    返回 "Proto" + 整数转字符串(协议)
}

函数 IP_丢包率() {
    定义 总 = IP接收_计数 + IP接收_丢弃
    如果 (总 == 0) { 返回 0 }
    返回 IP接收_丢弃 * 100 / 总
}

定义 可变 AI_网络接收_带宽估计 = 0
定义 可变 AI_网络接收_丢包窗口 = []

函数 AI_网络接收_带宽预测(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 AI_网络接收_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    AI_网络接收_带宽估计 = AI_网络接收_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 AI_网络接收_带宽估计
}

函数 AI_网络接收_拥塞建议(丢包率) {
    追加(AI_网络接收_丢包窗口, 丢包率)
    如果 (计数(AI_网络接收_丢包窗口) > 10) { 列表_移除(AI_网络接收_丢包窗口, 0) }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}

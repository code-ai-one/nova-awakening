// Nova标准库 — 窗口管理系统
// 事件循环、窗口层叠、输入事件、组件树
// 支持键盘/鼠标事件、焦点管理、布局引擎

导入("../../基础.nova")

// 事件类型
定义 事件_键按下 = 1
定义 事件_键释放 = 2
定义 事件_鼠标按下 = 3
定义 事件_鼠标释放 = 4
定义 事件_鼠标移动 = 5
定义 事件_鼠标滚轮 = 6
定义 事件_窗口关闭 = 7
定义 事件_窗口调整 = 8
定义 事件_窗口焦点 = 9
定义 事件_窗口失焦 = 10
定义 事件_绘制 = 11
定义 事件_定时器 = 12
定义 事件_自定义 = 99

// 事件
// 型: [类型, 时间戳, 数据字典, 已处理标记]

函数 事件_创建(类型, 时间戳) { 返回 [类型, 时间戳, 字典(), 假]
}

函数 事件_键盘(类型, 键码, 修饰符, 时间戳) { 定义 ev = 事件_创建(类型, 时间戳)
 字典设(ev[2], "键码", 键码)
 字典设(ev[2], "修饰符", 修饰符)
 返回 ev
}

函数 事件_鼠标(类型, x, y, 按钮, 时间戳) { 定义 ev = 事件_创建(类型, 时间戳)
 字典设(ev[2], "x", x)
 字典设(ev[2], "y", y)
 字典设(ev[2], "按钮", 按钮)
 返回 ev
}

函数 事件_取数据(ev, 键) { 返回 字典取(ev[2], 键) }
函数 事件_停止传播(ev) { ev[3] = 真 }
函数 事件_已处理(ev) { 返回 ev[3] }

// 窗口
// 型: [ID, 标题, x, y, 宽, 高, 可见, 焦点, 子组件列表,
// 事件处理器映射, 画布引用, 层级, 可调整, 最小宽, 最小高, 样式]

函数 窗口_创建(id, 标题, x, y, 宽, 高) { 返回 [id, 标题, x, y, 宽, 高, 真, 假, [], 字典(), 空, 0, 真, 100, 50, 字典()]
}

函数 窗口_ID(w) { 返回 w[0] }
函数 窗口_标题(w) { 返回 w[1] }
函数 窗口_设标题(w, 标题) { w[1] = 标题 }
函数 窗口_位置(w) { 返回 [w[2], w[3]] }
函数 窗口_大小(w) { 返回 [w[4], w[5]] }
函数 窗口_可见(w) { 返回 w[6] }
函数 窗口_显示(w) { w[6] = 真 }
函数 窗口_隐藏(w) { w[6] = 假 }
函数 窗口_有焦点(w) { 返回 w[7] }
函数 窗口_设焦点(w, 焦点) { w[7] = 焦点 }

函数 窗口_移动(w, x, y) {
 w[2] = x
 w[3] = y
}

函数 窗口_调整大小(w, 宽, 高) {
    如果 (宽 < w[13]) { 宽 = w[13]
}
 如果 (高 < w[14]) { 高 = w[14] }
 w[4] = 宽
 w[5] = 高
}

函数 窗口_包含点(w, x, y) { 返回 x >= w[2] 且 x < w[2] + w[4] 且 y >= w[3] 且 y < w[3] + w[5]
}

// 事件监听
函数 窗口_监听(w, 事件类型, 处理函数) { 定义 现有 = 字典取(w[9], 事件类型)
 如果 (现有 == 空) {
 字典设(w[9], 事件类型, [处理函数])
 } 否则 {
 追加(现有, 处理函数)
 }
}

函数 窗口_触发(w, 事件) { 定义 处理器列表 = 字典取(w[9], 事件[0])
 如果 (处理器列表 == 空) { 返回 假 }
 定义 可变 i = 0
 当 (i < 计数(处理器列表) 且 事件_已处理(事件) == 假) {
 处理器列表[i](事件)
 i = i + 1
 }
 返回 真
}

// 组件 (Widget)
// 型: [ID, 类型, x(相对), y(相对), 宽, 高, 可见, 子组件, 属性字典, 事件处理器]

定义 组件_标签 = "标签"
定义 组件_按钮 = "按钮"
定义 组件_文本框 = "文本框"
定义 组件_面板 = "面板"
定义 组件_列表 = "列表"
定义 组件_滚动条 = "滚动条"

函数 组件_创建(id, 类型, x, y, 宽, 高) { 返回 [id, 类型, x, y, 宽, 高, 真, [], 字典(), 字典()]
}

函数 组件_设属性(组件, 键, 值) { 字典设(组件[8], 键, 值) }
函数 组件_取属性(组件, 键) { 返回 字典取(组件[8], 键) }
函数 组件_添加子(组件, 子组件) { 追加(组件[7], 子组件) }

函数 组件_监听(组件, 事件类型, 处理函数) { 定义 现有 = 字典取(组件[9], 事件类型)
 如果 (现有 == 空) {
 字典设(组件[9], 事件类型, [处理函数])
 } 否则 {
 追加(现有, 处理函数)
 }
}

函数 组件_点击测试(组件, x, y) {
    如果 (组件[6] == 假) { 返回 空
}
 如果 (x < 组件[2] 或 x >= 组件[2] + 组件[4] 或 y < 组件[3] 或 y >= 组件[3] + 组件[5]) { 返回 空
 }
 // 深度优先搜索子组件
 定义 可变 i = 计数(组件[7]) - 1
 当 (i >= 0) { 定义 子 = 组件[7][i]
 定义 命中 = 组件_点击测试(子, x - 组件[2], y - 组件[3])
 如果 (命中 != 空) { 返回 命中 }
 i = i - 1
 }
 返回 组件
}

// 便捷组件工厂
函数 标签_创建(id, x, y, 文本) { 定义 w = 组件_创建(id, 组件_标签, x, y, 计数(文本) * 8, 16)
 组件_设属性(w, "文本", 文本)
 返回 w
}

函数 按钮_创建(id, x, y, 宽, 高, 文本) { 定义 w = 组件_创建(id, 组件_按钮, x, y, 宽, 高)
 组件_设属性(w, "文本", 文本)
 组件_设属性(w, "按下", 假)
 返回 w
}

函数 文本框_创建(id, x, y, 宽) { 定义 w = 组件_创建(id, 组件_文本框, x, y, 宽, 24)
 组件_设属性(w, "文本", "")
 组件_设属性(w,  "光标位置", 0)
 组件_设属性(w, "选择开始", -1)
 组件_设属性(w, "焦点", 假)
 返回 w
}

函数 面板_创建(id, x, y, 宽, 高) { 返回 组件_创建(id, 组件_面板, x, y, 宽, 高)
}

// 窗口管理器
// 型: [窗口列表, 焦点窗口ID, 下一窗口ID, 事件队列, 运行中,
// 当前tick, 全局快捷键, 拖拽状态, 鼠标位置]
// 拖拽状态: [拖拽中, 窗口ID, 偏移x, 偏移y]

函数 窗口管理器_创建() { 返回 [[], -1, 1, [], 假, 0, 字典(), [假, -1,], [0, 0]]
}

函数 管理器_创建窗口(wm, 标题, x, y, 宽, 高) { 定义 id = wm[2]
 wm[2] = wm[2] + 1
 定义 w = 窗口_创建(id, 标题, x, y, 宽, 高)
 追加(wm[0], w)
 管理器_焦点(wm, id)
 返回 w
}

函数 管理器_关闭窗口(wm, id) {
    定义 可变 新列表 = []
 定义 可变 i = 0
 当 (i < 计数(wm[0])) { 如果 (wm[0][i][0] != id) { 追加(新列表, wm[0][i]) }
 i = i + 1
 }
 wm[0] = 新列表
 如果 (wm[1] == id) { 如果 (计数(wm[0]) > 0) { wm[1] = wm[0][计数(wm[0]) - 1][0] }
 否则 { wm[1] = -1 }
 }
}

函数 管理器_焦点(wm, id) { 定义 _旧焦点 = wm[1]
 wm[1] = id
 // 更新窗口焦点状态
 定义 可变 i = 0
 当 (i < 计数(wm[0])) { 定义 w = wm[0][i]
 窗口_设焦点(w, w[0] == id)
 // 将焦点窗口移到最上层
 如果 (w[0] == id) { w[11] = 999 }
 否则 如果 (w[11] > 0) { w[11] = w[11] - 1 }
 i = i + 1
 }
}

函数 管理器_查找窗口(wm, id) { 定义 可变 i = 0
 当 (i < 计数(wm[0])) { 如果 (wm[0][i][0] == id) { 返回 wm[0][i] }
 i = i + 1
 }
 返回 空
}

// 事件分发
函数 管理器_提交事件(wm, 事件) {
 追加(wm[3], 事件)
}

函数 管理器_处理事件(wm) {
    定义 可变 新队列 = []
    定义 可变 处理数 = 0
    如果 (计数(wm[3]) == 0) { 返回 0
}
 当 (计数(wm[3]) > 0) { 定义 事件 = wm[3][0]
 定义 可变 i = 1
 当 (i < 计数(wm[3])) { 追加(新队列, wm[3][i]) i = i + 1 }
 wm[3] = 新队列
 管理器_分发(wm, 事件)
 处理数 = 处理数 + 1
 }
 返回 处理数
}

函数 管理器_分发(wm, 事件) { 定义 类型 = 事件[0]
 // 全局快捷键
 如果 (类型 == 事件_键按下) { 定义 键码 = 字典取(事件[2], "键码")
 定义 处理器 = 字典取(wm[6], 键码)
 如果 (处理器 != 空) {
 处理器(事件)
 如果 (事件_已处理(事件)) { 返回 }
 }
 }
 // 鼠标事件: 找目标窗口
 如果 (类型 >= 事件_鼠标按下 且 类型 <= 事件_鼠标滚轮) { 定义 mx = 字典取(事件[2], "x")
 定义 my = 字典取(事件[2], "y")
 wm[8] = [mx, my]
 // 处理拖拽
 如果 (类型 == 事件_鼠标按下) {
 // 从上层到下层查找
 定义 可变 j = 计数(wm[0]) - 1
 当 (j >= 0) { 定义 w = wm[0][j]
 如果 (窗口_可见(w) 且 窗口_包含点(w, mx, my)) {
 管理器_焦点(wm, w[0])
 // 标题栏拖拽 (假设前20像素是标题栏)
 如果 (my >= w[3] 且 my < w[3] + 20) {
 wm[7] = [真, w[0], mx - w[2], my - w[3]]
 }
 窗口_触发(w, 事件)
 返回
 }
 j = j - 1
 }
 }
 如果 (类型 == 事件_鼠标移动 且 wm[7][0]) { 定义 拖w = 管理器_查找窗口(wm, wm[7][1])
 如果 (拖w != 空) {
 窗口_移动(拖w, mx - wm[7][2], my - wm[7][3])
 }
 返回
 }
 如果 (类型 == 事件_鼠标释放) {
 wm[7][0] = 假
 }
 // 分发给焦点窗口
 定义 焦点窗 = 管理器_查找窗口(wm, wm[1])
 如果 (焦点窗 != 空) { 窗口_触发(焦点窗, 事件) }
 返回
 }
 // 键盘事件: 分发给焦点窗口
 如果 (类型 == 事件_键按下 或 类型 == 事件_键释放) { 定义 焦点窗 = 管理器_查找窗口(wm, wm[1])
 如果 (焦点窗 != 空) { 窗口_触发(焦点窗, 事件) }
 返回
 }
}

函数 管理器_注册快捷键(wm, 键码, 处理函数) {
 字典设(wm[6], 键码, 处理函数)
}

// 主循环
函数 管理器_tick(wm) {
 wm[5] = wm[5] + 1
 返回 管理器_处理事件(wm)
}

函数 管理器_运行(wm, 最大tick) {
 wm[4] = 真
 定义 可变 总处理 = 0
 当 (wm[4] 且 wm[5] < 最大tick) {
 总处理 = 总处理 + 管理器_tick(wm)
 }
 wm[4] = 假
 返回 总处理
}

函数 管理器_停止(wm) { wm[4] = 假 }
函数 管理器_窗口数(wm) { 返回 计数(wm[0]) }
函数 管理器_焦点窗口(wm) { 返回 wm[1] }
函数 管理器_当前tick(wm) { 返回 wm[5] }

// 布局引擎

// 水平布局: 子组件从左到右排列
函数 布局_水平(父组件, 间距) { 定义 可变 x = 0
 定义 可变 i = 0
 当 (i < 计数(父组件[7])) { 定义 子 = 父组件[7][i]
 子[2] = x
 子[3] = 0
 x = x + 子[4] + 间距
 i = i + 1
 }
}

// 垂直布局: 子组件从上到下排列
函数 布局_垂直(父组件, 间距) { 定义 可变 y = 0
 定义 可变 i = 0
 当 (i < 计数(父组件[7])) { 定义 子 = 父组件[7][i]
 子[2] = 0
 子[3] = y
 y = y + 子[5] + 间距
 i = i + 1
 }
}

// 网格布局
函数 布局_网格(父组件, 列数, 行间距, 列间距) { 定义 可变 _行 = 0
 定义 可变 列 = 0
 如果 (列数 == 0) { 列数 = 1 }
 定义 单元宽 = 父组件[4] / 列数
 定义 可变 最大行高 = 0
 定义 可变 y偏移 = 0
 定义 可变 i = 0
 当 (i < 计数(父组件[7])) { 定义 子 = 父组件[7][i]
 子[2] = 列 * (单元宽 + 列间距)
 子[3] = y偏移
 如果 (子[5] > 最大行高) { 最大行高 = 子[5] }
 列 = 列 + 1
 如果 (列 >= 列数) {
 列 = 0
 y偏移 = y偏移 + 最大行高 + 行间距
 最大行高 = 0
 }
 i = i + 1
 }
}

// 窗口管理扩展

函数 窗口_居中(屏幕宽, 屏幕高, 窗口宽, 窗口高) { 返回 [(屏幕宽 - 窗口宽) / 2, (屏幕高 - 窗口高) / 2]
}

函数 窗口_缩放(窗口, 比例) { 返回 [窗口[0], 窗口[1], 窗口[2] * 比例 / 100, 窗口[3] * 比例 / 100]
}

函数 窗口_适配(内容宽, 内容高, 容器宽, 容器高) { 定义 比W = 容器宽 * 1000 / 内容宽
 定义 比H = 容器高 * 1000 / 内容高
 定义 可变 比 = 比W
 如果 (比H < 比) { 比 = 比H }
 返回 [内容宽 * 比 / 1000, 内容高 * 比 / 1000]
}

函数 窗口_拖拽限制(x, y, 最小x, 最小y, 最大x, 最大y) { 定义 可变 rx = x
 定义 可变 ry = y
 如果 (rx < 最小x) { rx = 最小x }
 如果 (rx > 最大x) { rx = 最大x }
 如果 (ry < 最小y) { ry = 最小y }
 如果 (ry > 最大y) { ry = 最大y }
 返回 [rx, ry]
}

函数 窗口_分屏(屏幕宽, 屏幕高, 数量) {
    如果 (数量 <= 1) { 返回 [[0, 0, 屏幕宽, 屏幕高]]
}
 如果 (数量 == 2) { 返回 [[0, 0, 屏幕宽 / 2, 屏幕高], [屏幕宽 / 2, 0, 屏幕宽 / 2, 屏幕高]] }
 如果 (数量 <= 4) { 定义 半宽 = 屏幕宽 / 2
 定义 半高 = 屏幕高 / 2
 返回 [[0, 0, 半宽, 半高], [半宽, 0, 半宽, 半高], [0, 半高, 半宽, 半高], [半宽, 半高, 半宽, 半高]]
 }
 定义 可变 结果 = []
 定义 列数 = 3
 定义 行数 = (数量 + 列数 - 1) / 列数
 定义 单宽 = 屏幕宽 / 列数
 定义 单高 = 屏幕高 / 行数
 定义 可变 i = 0
 当 (i < 数量) {
 追加(结果, [(i % 列数) * 单宽, (i / 列数) * 单高, 单宽, 单高])
 i = i + 1
 }
 返回 结果
}

函数 窗口_最小尺寸检查(宽, 高, 最小宽, 最小高) { 定义 可变 w = 宽
 定义 可变 h = 高
 如果 (w < 最小宽) { w = 最小宽 }
 如果 (h < 最小高) { h = 最小高 }
 返回 [w, h]
}

定义 可变 _窗口_创建数 = 0
定义 可变 _窗口_调整数 = 0
定义 可变 _窗口_事件数 = 0

函数 窗口_记录创建() { _窗口_创建数 = _窗口_创建数 + 1 }
函数 窗口_记录调整() { _窗口_调整数 = _窗口_调整数 + 1 }
函数 窗口_记录事件() { _窗口_事件数 = _窗口_事件数 + 1 }

函数 窗口_交互评估() {
    如果 (_窗口_事件数 > 10000) { 返回 "高交互(事件节流)"
}
 如果 (_窗口_调整数 > _窗口_创建数 * 10) { 返回 "频繁调整(考虑缓存布局)" }
 返回 "交互正常"
}

函数 窗口_重置() { _窗口_创建数 = 0 _窗口_调整数 = 0 _窗口_事件数 = 0 }

// 窗口布局算法

函数 窗口_层叠(起始x, 起始y, 宽, 高, 数量, 偏移) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 数量) {
 追加(结果, [起始x + i * 偏移, 起始y + i * 偏移, 宽, 高])
 i = i + 1
 }
 返回 结果
}

函数 窗口_平铺(屏幕宽, 屏幕高, 窗口列表) { 定义 n = 计数(窗口列表)
 如果 (n == 0) { 返回 [] }
 定义 可变 列 = 1
 当 (列 * 列 < n) { 列 = 列 + 1 }
 定义 行 = (n + 列 - 1) / 列
 定义 单宽 = 屏幕宽 / 列
 定义 单高 = 屏幕高 / 行
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < n) {
 追加(结果, [(i % 列) * 单宽, (i / 列) * 单高, 单宽, 单高])
 i = i + 1
 }
 返回 结果
}

函数 窗口_DPI缩放(值, DPI) {
    如果 (DPI <= 96) { 返回 值
}
 返回 值 * DPI / 96
}

函数 窗口_吸附(x, y, 吸附距离, 锚点列表) { 定义 可变 最近x = x
 定义 可变 最近y = y
 定义 可变 最近距 = 999999
 定义 可变 i = 0
 当 (i < 计数(锚点列表)) { 定义 可变 导数 = x - 锚点列表[i][0]
 定义 可变 导数Y = y - 锚点列表[i][1]
 如果 (导数 < 0) { 导数 = 0 - 导数 }
 如果 (导数Y < 0) { 导数Y = 0 - 导数Y }
 如果 (导数 + 导数Y < 最近距 且 导数 + 导数Y < 吸附距离) {
 最近距 = 导数 + 导数Y
 最近x = 锚点列表[i][0]
 最近y = 锚点列表[i][1]
 }
 i = i + 1
 }
 返回 [最近x, 最近y]
}

函数 内核适配_开始下载(档, 地址, 文件名) {
    定义 任务 = 浏览器存储_开始下载(地址, 文件名)
    档.最近下载 = 任务
    档.存储数 = 档.存储数 + 1
    返回 任务
}

函数 内核适配_写块(档, 任务ID, 数据, 大小) {
    浏览器存储_下载写入块(任务ID, 数据, 大小)
    档.存储数 = 档.存储数 + 1
}

函数 内核适配_下载完成(档, 任务ID) {
    浏览器存储_下载完成(任务ID)
    档.存储数 = 档.存储数 + 1
}

函数 内核适配_暂停下载(档, 任务ID) {
    浏览器存储_暂停下载(任务ID)
    档.存储数 = 档.存储数 + 1
}

函数 内核适配_恢复下载(档, 任务ID) {
    浏览器存储_恢复下载(任务ID)
    档.存储数 = 档.存储数 + 1
}

函数 内核适配_下载进度(档, 任务ID) {
    定义 进度 = 浏览器存储_下载进度(任务ID)
    档.最近下载 = 进度
    返回 进度
}

函数 内核适配_缓存查找(档, 地址) {
    定义 缓存 = 浏览器存储_缓存查找(地址)
    如果 (缓存 != 0 && 缓存 != 空) {
        档.命中数 = 档.命中数 + 1
        适配总命中 = 适配总命中 + 1
    }
    档.存储数 = 档.存储数 + 1
    返回 缓存
}

函数 内核适配_缓存写入(档, 地址, 内容类型, 数据, 过期时间) {
    浏览器存储_缓存写入(地址, 内容类型, 数据, 过期时间)
    档.存储数 = 档.存储数 + 1
}

函数 内核适配_Cookie设置(档, 名称, 值, 域, 路径, 过期, 安全, 仅HTTP) {
    浏览器存储_Cookie设置(名称, 值, 域, 路径, 过期, 安全, 仅HTTP)
    档.存储数 = 档.存储数 + 1
}

函数 内核适配_Cookie获取(档, 域, 路径) {
    定义 结果 = 浏览器存储_Cookie获取(域, 路径)
    档.存储数 = 档.存储数 + 1
    返回 结果
}

函数 内核适配_本地设置(档, 域, 键, 值) {
    浏览器存储_本地设置(域, 键, 值)

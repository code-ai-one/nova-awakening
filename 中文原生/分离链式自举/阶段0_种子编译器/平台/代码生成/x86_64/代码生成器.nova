函数 编译_内建后半(名, 参数) {
    如果 (名 == "绝对值") {
        返回 编译_处理__绝对值_(参数)
    }
    如果 (名 == "最小值") {
        返回 编译_处理__最小值_(参数)
    }
    如果 (名 == "最大值") {
        返回 编译_处理__最大值_(参数)
    }
    如果 (名 == "幂") {
        返回 编译_处理__幂_(参数)
    }
    如果 (名 == "设置") {
        返回 编译_处理__设置_(参数)
    }
    如果 (名 == "类型") {
        返回 编译_处理__类型_(参数)
    }
    如果 (名 == "是整数") {
        返回 编译_处理__是整数_(参数)
    }
    如果 (名 == "是字符串") {
        返回 编译_处理__是字符串_(参数)
    }
    如果 (名 == "是列表") {
        返回 编译_处理__是列表_(参数)
    }
    如果 (名 == "是字典") {
        返回 编译_处理__是字典_(参数)
    }
    如果 (名 == "是空") {
        返回 编译_处理__是空_(参数)
    }
    如果 (名 == "打印值") {
        返回 编译_处理__打印值_(参数)
    }
    如果 (名 == "包含") {
        返回 编译_处理__包含_(参数)
    }
    如果 (名 == "查找") {
        返回 编译_处理__查找_(参数)
    }
    如果 (名 == "以开头") {
        返回 编译_处理__以开头_(参数)
    }
    如果 (名 == "以结尾") {
        返回 编译_处理__以结尾_(参数)
    }
    如果 (名 == "内存读") {
        返回 编译_处理__内存读_(参数)
    }
    如果 (名 == "内存写") {
        返回 编译_处理__内存写_(参数)
    }
    如果 (名 == "内存读8") {
        返回 编译_处理__内存读8_(参数)
    }
    如果 (名 == "内存写8") {
        返回 代码生成器_编译_处理__内存写8_(参数)
    }
    如果 (名 == "内存读16") {
        返回 编译_处理__内存读16_(参数)
    }
    如果 (名 == "内存写16") {
        返回 代码生成器_编译_处理__内存写16_(参数)
    }
    如果 (名 == "内存读32") {
        返回 编译_处理__内存读32_(参数)
    }
    如果 (名 == "内存写32") {
        返回 代码生成器_编译_处理__内存写32_(参数)
    }
    如果 (名 == "内存复制") {
        返回 代码生成器_编译_处理__内存复制_(参数)
    }
    如果 (名 == "内存填充") {
        返回 代码生成器_编译_处理__内存填充_(参数)
    }
    如果 (名 == "大写化") {
        返回 编译_处理__大写化_(参数)
    }
    如果 (名 == "小写化") {
        返回 编译_处理__小写化_(参数)
    }
    如果 (名 == "加载库") {
        返回 编译_处理__加载库_(参数)
    }
    如果 (名 == "获取函数") {
        返回 编译_处理__获取函数_(参数)
    }
    返回 0
}

// 文件写入内建 (写文件/写二进制) — 独立函数避免编译器变量溢出
函数 编译_写文件内建(名, 参数) {
    如果 (名 != "写文件" 且 名 != "写二进制" 且 名 != "平台_写文件") { 返回 0 }
    定义 路径a = 参数[0]
    如果 (路径a[0] == 标记_字串) {
        定义 ps = 路径a[1]
        定义 可变 pi = 计数(字串表)
        追加(字串表, ps)
        如果 (名 == "写文件") {
            定义 ca = 参数[1]
            如果 (ca[0] == 标记_字串) {
                // 路径和内容都是字面量
                定义 cs = ca[1]
                定义 cl = 计数(cs)
                定义 ci3 = 计数(字串表)
                追加(字串表, cs)
                修正表_追加记录(修正表, "str", 代码位 + 3, pi)
                发射组([0x48, 0x8D, 0x0D])
                发射32(0)
                修正表_追加记录(修正表, "str", 代码位 + 3, ci3)
                发射组([0x48, 0x8D, 0x15])
                发射32(0)
                发射_载立即(8, cl)
            } 否则 {
                // 字面量路径 + 运行时内容
                编译_表达式(参数[1])
                发射(0x50)
                修正表_追加记录(修正表, "str", 代码位 + 3, pi)
                发射组([0x48, 0x8D, 0x0D])
                发射32(0)
                发射(0x5A)                               // pop rdx (content)
                // inline strlen(rdx) → r8 (content length)
                发射组([0x45, 0x31, 0xC0])               // xor r8d, r8d
                发射组([0x42, 0x80, 0x3C, 0x02, 0x00])   // cmp byte [rdx+r8], 0
                发射组([0x74, 0x05])                     // je .done (+5)
                发射组([0x49, 0xFF, 0xC0])               // inc r8
                发射组([0xEB, 0xF4])                     // 跳转 .loop (-12)
            }
        } 否则 {
            编译_表达式(参数[2])                         // 大小 → rax
            发射(0x50)                                   // push size
            编译_表达式(参数[1])                         // 缓冲区 → rax
            发射_mov_rcx_rax()                          // rcx = buffer
            发射(0x41) 发射(0x58)                       // pop r8 (size)
            发射组([0x4C, 0x89, 0x01])                  // mov [rcx], r8 (count=size)
            发射(0x41) 发射(0x50)                       // push r8 (save size)
            修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_列表转字节")
            发射(0xE8)
            发射32(0)                                   // rax = packed bytes
            发射(0x50)                                   // push packed_bytes
            修正表_追加记录(修正表, "str", 代码位 + 3, pi)
            发射组([0x48, 0x8D, 0x0D])
            发射32(0)
            发射(0x5A)                                   // pop rdx (packed_bytes)
            发射(0x41) 发射(0x58)                       // pop r8 (size)
        }
    } 否则 {
        // 非字面量路径: 运行时求值路径+strlen
        如果 (名 == "写文件") {
            // 写文件只有2个参数: 路径, 内容
            编译_表达式(参数[1])
            发射(0x50)
            编译_表达式(路径a)
            发射_mov_rcx_rax()
            发射(0x5A)                               // pop rdx (content)
            // inline strlen(rdx) → r8 (content length)
            发射组([0x45, 0x31, 0xC0])               // xor r8d, r8d
            发射组([0x42, 0x80, 0x3C, 0x02, 0x00])   // cmp byte [rdx+r8], 0
            发射组([0x74, 0x05])                     // je .done (+5)
            发射组([0x49, 0xFF, 0xC0])               // inc r8
            发射组([0xEB, 0xF4])                     // 跳转 .loop (-12)
        } 否则 {
            // 写二进制有3个参数: 路径, 缓冲区, 大小
            编译_表达式(参数[2])                         // 大小 → rax
            发射(0x50)                                   // push size
            编译_表达式(参数[1])                         // 缓冲区 → rax
            发射_mov_rcx_rax()                          // rcx = buffer
            发射(0x41) 发射(0x58)                   // pop r8 (size)
            发射组([0x4C, 0x89, 0x01])                  // mov [rcx], r8 (count=size)
            发射(0x41) 发射(0x50)                   // push r8 (save size)
            修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_列表转字节")
            发射(0xE8)
            发射32(0)                                   // rax = packed bytes
            发射(0x50)                                   // push packed_bytes
            编译_表达式(路径a)
            发射_mov_rcx_rax()                          // rcx = path
            发射(0x5A)                               // pop rdx (packed_bytes)
            发射(0x41) 发射(0x58)                   // pop r8 (size)
        }
    }
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_写文件")
    发射(0xE8)
    发射32(0)
    返回 1
}

函数 编译_处理_节_浮点(vm) {
    // 运行时构造浮点: combined / scale → IEEE 754 double bits in RAX
    定义 整数部 = 节点[1]
    定义 小数部 = 节点[2]
    定义 小数位 = 节点[3]
    定义 可变 幂 = 1
    定义 可变 k = 0
    当 (k < 小数位) { 幂 = 幂 * 10
    k = k + 1 }
    定义 组合 = 整数部 * 幂 + 小数部
    // mov rax, combined
    发射_载立即(0, 组合)
    // cvtsi2sd xmm0, rax  (F2 48 0F 2A C0)
    发射组([0xF2, 0x48, 0x0F, 0x2A, 0xC0])
    // mov rax, scale
    发射_载立即(0, 幂)
    // cvtsi2sd xmm1, rax  (F2 48 0F 2A C8)
    发射组([0xF2, 0x48, 0x0F, 0x2A, 0xC8])
    // divsd xmm0, xmm1  (F2 0F 5E C1)
    发射组([0xF2, 0x0F, 0x5E, 0xC1])
    // movq rax, xmm0  (66 48 0F 7E C0)
    发射组([0x66, 0x48, 0x0F, 0x7E, 0xC0])
    返回 空
}

函数 编译_处理_节_字符串(vm) {
    定义 s = 节点[1]
    定义 长度 = 字节长度(s)
    定义 已有 = 字典取(_字符串驻留表, s)
    如果 (已有 != 空) {
        发射组([0x48, 0x8D, 0x05])  // lea rax, [rip+disp32]
        定义 偏移量 = 已有 - (代码位 + 4)
        发射32(偏移量)
        返回 空
    }
    // 内联字符串: jmp over; data; NUL; lea rax,[rip-偏移量]
    如果 (长度 + 1 < 126) {
        发射(0xEB)              // 跳转 short (2 bytes)
        发射(长度 + 1)           // skip data+NUL
    } 否则 {
        发射(0xE9)              // 跳转 near (5 bytes)
        发射32(长度 + 1)         // skip data+NUL
    }
    定义 数据起 = 代码位
    定义 可变 si = 0
    当 (si < 长度) {
        发射(字节取(s, si))
        si = si + 1
    }
    发射(0)                 // NUL terminator
    字典设(_字符串驻留表, s, 数据起)
    发射组([0x48, 0x8D, 0x05])  // lea rax, [rip+disp32]
    发射32(0 - (长度 + 1 + 3 + 4))  // -(data+NUL+lea_opcode+disp32)
    返回 空
}

函数 _闭包_尝试捕获(标识名) {
    如果 (当前函数列 == 空) { 返回 0 }
    如果 (字节长度(标识名) < 10) { 返回 0 }
    如果 (字节取(标识名, 0) != 字符_下划线 或 字节取(标识名, 1) != 字符_下划线) { 返回 0 }
    如果 (字典取(闭包表, 标识名) != 空) {
        定义 已有列 = 字典取(闭包表, 标识名)
        定义 可变 ci2 = 0
        当 (ci2 < 计数(已有列)) {
            定义 cn2 = 已有列[ci2]
            定义 co2 = 查变量(cn2)
            定义 sn2 = 字符串拼接("__闭包_", 字符串拼接(标识名, 字符串拼接("_", cn2)))
            如果 (字典取(全局变量表, sn2) == 空) {
                字典设(全局变量表, sn2, 全局变量数 + 1)
                全局变量数 = 全局变量数 + 1
            }
            定义 so2 = 0 - 1000 - (字典取(全局变量表, sn2) - 1)
            如果 (co2 != 空) { 发射_载变量(co2) 发射_存变量(so2) }
            ci2 = ci2 + 1
        }
        返回 0
    }
    定义 _找索引 = 字典取(当前函数名表, 标识名)
    如果 (_找索引 == 空) { 返回 0 }
    定义 找函 = 当前函数列[_找索引 - 1]
    如果 (是列表(找函) == 0 或 计数(找函) < 4) { 返回 0 }
    定义 参列 = 找函[2]
    定义 体节 = 找函[3]
    定义 可变 标列 = []
    _收集自由标识(体节, 标列)
    定义 可变 捕列 = []
    定义 可变 si = 0
    当 (si < 计数(标列)) {
        定义 idn = 标列[si]
        定义 ido = 查变量(idn)
        如果 (ido != 空) {
            定义 可变 是参 = 假
            定义 可变 pi = 0
            当 (pi < 计数(参列)) {
                如果 (参列[pi] == idn) { 是参 = 真 }
                pi = pi + 1
            }
            如果 (是参 == 假) {
                定义 可变 已有 = 假
                定义 可变 vi = 0
                当 (vi < 计数(捕列)) {
                    如果 (捕列[vi] == idn) { 已有 = 真 }
                    vi = vi + 1
                }
                如果 (已有 == 假) { 追加(捕列, idn) }
            }
        }
        si = si + 1
    }
    如果 (计数(捕列) > 0) {
        字典设(闭包表, 标识名, 捕列)
        定义 可变 ci = 0
        当 (ci < 计数(捕列)) {
            定义 cn = 捕列[ci]
            定义 co = 查变量(cn)
            定义 sn = 字符串拼接("__闭包_", 字符串拼接(标识名, 字符串拼接("_", cn)))
            如果 (字典取(全局变量表, sn) == 空) {
                字典设(全局变量表, sn, 全局变量数 + 1)
                全局变量数 = 全局变量数 + 1
            }
            定义 so = 0 - 1000 - (字典取(全局变量表, sn) - 1)
            如果 (co != 空) { 发射_载变量(co) 发射_存变量(so) }
            ci = ci + 1
        }
    }
    返回 0
}

函数 编译_处理_节_标识符(vm) {
    如果 (节点 == 空 或 是列表(节点) == 假 或 计数(节点) < 2) { 返回 空 }
    定义 可变 偏移 = 查变量(节点[1])
    如果 (偏移 != 空) {
        发射_载变量(偏移)
    }
    否则 {
        // 检查是否为函数引用 (函数名作为值)
        定义 函数地址 = 字典取(函数表, 节点[1])
        如果 (函数地址 != 空) {
            _闭包_尝试捕获(节点[1])
            修正表_追加记录(修正表, "call", 代码位 + 3, 节点[1])
            发射组([0x48, 0x8D, 0x05])
            发射32(0)
        } 否则 {
            // 自动分配全局槽位(避免UNDEF变量为0导致空指针写入崩溃)
            全局变量数 = 全局变量数 + 1
            字典设(全局变量表, 节点[1], 全局变量数)
            定义 _udef偏 = 0 - 1000 - (全局变量数 - 1)
            字典设(变量表, 节点[1], _udef偏)
            发射_载变量(_udef偏)
        }
    }
    返回 空
}

函数 编译_处理_节_列表(vm) {
    定义 元素 = 节点[1]
    定义 n = 计数(元素)
    // __运行时_列表新建: 空列表16(按需增长), 非空n+8
    定义 可变 容量 = n + 8
    如果 (n == 0) { 容量 = 16 }
    发射_载立即(1, 容量)
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_列表新建")
    发射(0xE8)
    发射32(0)
    // 依次追加元素
    如果 (n > 0) {
        发射(0x50)
        定义 可变 li = 0
        当 (li < n) {
            编译_表达式(元素[li])
            发射组([0x48, 0x89, 0xC2])  // mov rdx, rax (value)
            发射组([0x48, 0x8B, 0x0C, 0x24]) // mov rcx, [rsp] (list)
            修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_列表追加")
            发射(0xE8)
            发射32(0)
            li = li + 1
        }
        发射(0x58)
    }
    返回 空
}

函数 编译_处理_节_字典(vm) {
    定义 对列 = 节点[1]
    定义 对数 = 计数(对列)
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_字典新建")
    发射(0xE8)
    发射32(0)
    如果 (对数 > 0) {
        发射(0x50)
        定义 可变 di = 0
        当 (di < 对数) {
            定义 对 = 对列[di]
            编译_表达式(对[0])
            发射(0x50)
            编译_表达式(对[1])
            发射组([0x49, 0x89, 0xC0])       // mov r8, rax (value)
            发射(0x5A)                        // pop rdx (key)
            发射组([0x48, 0x8B, 0x0C, 0x24]) // mov rcx, [rsp] (dict)
            修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_字典设")
            发射(0xE8)
            发射32(0)
            di = di + 1
        }
        发射(0x58)
    }
    返回 空
}

函数 编译_发射_索引读取分流() {
    发射组([0x48, 0x8B, 0x4C, 0x24, 0x08])
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_是字典")
    发射(0xE8)
    发射32(0)
    发射_测试rax()
    定义 可变 走列表 = 发射_je(0)
    发射(0x5A)
    发射(0x59)
    发射_规范空值_rcx()
    发射_规范空值_rdx()
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_字典取")
    发射(0xE8)
    发射32(0)
    定义 可变 结束跳 = 发射_jmp(0)
    修正跳转(走列表, 代码位)
    发射(0x5A)
    发射(0x59)
    发射_规范空值_rcx()
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_列表取")
    发射(0xE8)
    发射32(0)
    修正跳转(结束跳, 代码位)
    返回 空
}

函数 编译_发射_索引写入分流() {
    发射组([0x48, 0x8B, 0x0C, 0x24])
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_是字典")
    发射(0xE8)
    发射32(0)
    发射_测试rax()
    定义 可变 走列表2 = 发射_je(0)
    发射(0x59)
    发射(0x5A)
    发射组([0x41, 0x58])
    发射_规范空值_rcx()
    发射_规范空值_rdx()
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_字典设")
    发射(0xE8)
    发射32(0)
    定义 可变 结束跳2 = 发射_jmp(0)
    修正跳转(走列表2, 代码位)
    发射(0x59)
    发射(0x5A)
    发射组([0x41, 0x58])
    发射_规范空值_rcx()
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_列表设")
    发射(0xE8)
    发射32(0)
    修正跳转(结束跳2, 代码位)
    返回 空
}

函数 编译_处理_节_索引(vm) {
    编译_表达式(节点[1])
    发射(0x50)
    编译_表达式(节点[2])
    发射(0x50)
    编译_发射_索引读取分流()
    返回 空
}

函数 编译_处理_节_新建(vm) {
    定义 可变 类型名 = 节点[1]
    定义 字段值 = 节点[2]
    定义 字段数 = 计数(字段值)
    定义 _字段列 = 字典取(结构体表, 类型名)
    // 分配 结构体列表容量
    定义 可变 _字段总数 = 字段数
    如果 (_字段列 != 0 且 _字段列 != 空 且 计数(_字段列) > 0) {
        _字段总数 = 计数(_字段列)
    }
    定义 可变 容量 = _字段总数 + 8
    如果 (_字段总数 == 0) { 容量 = 16 }
    发射_载立即(1, 容量)
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_列表新建")
    发射(0xE8)
    发射32(0)
    发射(0x50)
    定义 可变 _命名式 = 假
    如果 (字段数 > 0 且 计数(字段值[0]) > 0 且 编译_字符串安全相等(字段值[0][0], "") == 假) { _命名式 = 真 }
    如果 (_命名式 且 _字段列 != 0 且 _字段列 != 空 且 计数(_字段列) > 0) {
        定义 可变 _sfi = 0
        当 (_sfi < _字段总数) {
            定义 _字段名 = _字段列[_sfi]
            定义 可变 _命中idx = 0 - 1
            定义 可变 _ffi = 0
            当 (_ffi < 字段数) {
                定义 _fv查 = 字段值[_ffi]
                如果 (编译_字符串安全相等(_fv查[0], _字段名)) { _命中idx = _ffi }
                _ffi = _ffi + 1
            }
            如果 (_命中idx >= 0) {
                编译_表达式(字段值[_命中idx][1])
            } 否则 {
                发射_载立即(0, 0)
            }
            发射组([0x48, 0x89, 0xC2])
            发射组([0x48, 0x8B, 0x0C, 0x24])
            修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_列表追加")
            发射(0xE8)
            发射32(0)
            _sfi = _sfi + 1
        }
    } 否则 {
        定义 可变 fi = 0
        当 (fi < 字段数) {
            定义 fv = 字段值[fi]
            编译_表达式(fv[1])
            发射组([0x48, 0x89, 0xC2])
            发射组([0x48, 0x8B, 0x0C, 0x24])
            修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_列表追加")
            发射(0xE8)
            发射32(0)
            fi = fi + 1
        }
    }
    发射(0x58)
    返回 空
}

函数 编译_处理_节_逻辑非(vm) {
    编译_表达式(节点[1])
    发射_规范空值()
    发射_测试rax()
    发射组([0x0F, 0x94, 0xC0])   // sete al (set if zero)
    发射组([0x0F, 0xB6, 0xC0])    // movzx eax, al
    返回 空
}

函数 _收集自由标识(n, 结果) {
    如果 (n == 空) { 返回 0 }
    如果 (是列表(n) == 0) { 返回 0 }
    定义 长度 = 计数(n)
    如果 (长度 < 1) { 返回 0 }
    如果 (长度 >= 2) {
        定义 头 = n[0]
        如果 (头 == 标记_名称) { 追加(结果, n[1])  返回 0 }
    }
    // 递归所有子元素 (不依赖是列表(头)判断, 因为该函数对整数可能返回truthy)
    定义 可变 j = 0
    当 (j < 长度) { _收集自由标识(n[j], 结果)  j = j + 1 }
    返回 0
}

函数 闭包分析_函数列(函数列) {
    闭包表 = 字典()
    当前函数列 = 函数列
    当前函数名表 = 字典()
    定义 可变 _mi = 0
    当 (_mi < 计数(函数列)) {
        如果 (是列表(函数列[_mi]) 且 计数(函数列[_mi]) >= 2) {
            字典设(当前函数名表, 函数列[_mi][1], _mi + 1)
        }
        _mi = _mi + 1
    }
}

函数 编译_处理_节_匿名函数(vm) {
    定义 匿名名2 = 节点[1]
    // 动态闭包分析: 在创建点查找lambda体, 用当前作用域判断捕获
    如果 (当前函数列 != 空 且 字典取(闭包表, 匿名名2) == 空) {
        定义 可变 找到函 = 空
        定义 可变 fi = 0
        当 (fi < 计数(当前函数列)) {
            定义 f = 当前函数列[fi]
            如果 (编译_是列表值(f) 且 计数(f) >= 4 且 f[1] == 匿名名2) {
                找到函 = f
            }
            fi = fi + 1
        }
        如果 (找到函 != 空) {
            定义 _cl参数 = 找到函[2]
            定义 _cl体 = 找到函[3]
            定义 可变 _cl标识 = []
            _收集自由标识(_cl体, _cl标识)
            定义 可变 捕获列 = []
            定义 可变 si = 0
            当 (si < 计数(_cl标识)) {
                定义 _clid = _cl标识[si]
                定义 _cl偏 = 查变量(_clid)
                如果 (_cl偏 != 空) {
                    定义 可变 是参数 = 假
                    定义 可变 pi = 0
                    当 (pi < 计数(_cl参数)) {
                        如果 (_cl参数[pi] == _clid) { 是参数 = 真 }
                        pi = pi + 1
                    }
                    如果 (是参数 == 假) {
                        定义 可变 已有 = 假
                        定义 可变 vi = 0
                        当 (vi < 计数(捕获列)) {
                            如果 (捕获列[vi] == _clid) { 已有 = 真 }
                            vi = vi + 1
                        }
                        如果 (已有 == 假) { 追加(捕获列, _clid) }
                    }
                }
                si = si + 1
            }
            如果 (计数(捕获列) > 0) {
                字典设(闭包表, 匿名名2, 捕获列)
            }
        }
    }
    // 闭包: 将捕获的变量从当前作用域复制到全局闭包槽
    定义 闭包变量列 = 字典取(闭包表, 匿名名2)
    如果 (闭包变量列 != 空) {
        定义 可变 ci = 0
        当 (ci < 计数(闭包变量列)) {
            定义 捕获名 = 闭包变量列[ci]
            定义 捕获偏 = 查变量(捕获名)
            定义 槽名 = 字符串拼接("__闭包_", 字符串拼接(匿名名2, 字符串拼接("_", 捕获名)))
            如果 (字典取(全局变量表, 槽名) == 空) {
                字典设(全局变量表, 槽名, 全局变量数 + 1)
                全局变量数 = 全局变量数 + 1
            }
            定义 槽偏 = 0 - 1000 - (字典取(全局变量表, 槽名) - 1)
            如果 (捕获偏 != 空) {
                发射_载变量(捕获偏)
                发射_存变量(槽偏)
            }
            ci = ci + 1
        }
    }
    修正表_追加记录(修正表, "call", 代码位 + 3, 匿名名2)
    发射组([0x48, 0x8D, 0x05])          // lea rax, [rip+disp32]
    发射32(0)
    返回 空
}

函数 编译_处理_节_点访问(vm) {
    如果 (节点 == 空 或 是列表(节点) == 假 或 计数(节点) < 3) { 返回 空 }
    编译_表达式(节点[1])
    定义 可变 字段名 = 节点[2]
    定义 可变 偏移idx = 0
    定义 可变 已找到 = 假
    定义 可变 _推断类型 = 推断结构类型名(节点[1])
    如果 (_推断类型 != 0 且 _推断类型 != 空) {
        偏移idx = 查字段偏移(_推断类型, 字段名)
        如果 (偏移idx >= 0) { 已找到 = 真 }
    }
    如果 (已找到 == 假) {
        定义 _全局idx = _查字段偏移_全局(字段名)
        如果 (_全局idx >= 0) { 偏移idx = _全局idx 已找到 = 真 }
    }
    如果 (偏移idx < 0) {
        如果 (模块图详细模式[0]) { 打印文本(字符串拼接("[DOT?] ", 字符串拼接(字段名, 字符串拼接(" idx=", 转字符串(偏移idx))))) }
        偏移idx = 0
    }
    // 通过 __运行时_列表取 统一读取结构字段
    发射_mov_rcx_rax()
    发射组([0x48, 0xC7, 0xC2])
    发射32(偏移idx)
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_列表取")
    发射(0xE8)
    发射32(0)
    返回 空
}

函数 编译_处理_节_调用(vm) {
    如果 (节点 == 空 或 是列表(节点) == 假 或 计数(节点) < 3) { 返回 空 }
    定义 可变 名 = 节点[1]
    定义 参数 = 节点[2]
    如果 (参数 == 空 或 是列表(参数) == 假) { 参数 = [] }
    如果 (名 == 空 或 是字符串(名) == 假) { 返回 空 }

    // 编译器识别的高频内建调用优先走专用路径。
    如果 (编译_系统内建(名, 参数)) { 返回 空 }
    如果 (编译_内联汇编内建(名, 参数)) { 返回 空 }
    如果 (编译_裸机内建(名, 参数)) { 返回 空 }
    如果 (编译_内建前半(名, 参数)) { 返回 空 }
    如果 (编译_内建后半(名, 参数)) { 返回 空 }
    如果 (编译_写文件内建(名, 参数)) { 返回 空 }

    定义 可变 参数数 = 计数(参数)
    定义 可变 目标偏移 = 查变量(名)

    如果 (目标偏移 != 空 且 目标偏移 > 0 - 1000) {
        发射_载变量(目标偏移)
        发射(0x50)                    // push func ptr
        定义 _保存尾调用v = _尾调用模式
        _尾调用模式 = 0
        定义 可变 i = 参数数 - 1
        当 (i >= 0) {
            编译_表达式(参数[i])
            发射(0x50)
            i = i - 1
        }
        _尾调用模式 = _保存尾调用v
        如果 (参数数 >= 1) { 发射(0x59) }         // rcx = arg0
        如果 (参数数 >= 2) { 发射(0x5A) }         // rdx = arg1
        如果 (参数数 >= 3) { 发射(0x41) 发射(0x58) } // r8 = arg2
        如果 (参数数 >= 4) { 发射(0x41) 发射(0x59) } // r9 = arg3
        如果 (参数数 <= 4) {
            发射(0x58)                            // pop rax = func ptr
        } 否则 {
            定义 可变 函数偏移 = (参数数 - 4) * 8
            发射组([0x48, 0x8B, 0x44, 0x24])
            发射(函数偏移)
        }
        如果 (_尾调用模式 == 1 且 参数数 <= 4) {
            发射(0xC9)                            // leave
            发射组([0xFF, 0xE0])                  // 跳转 rax
            _尾调用模式 = 2
        } 否则 {
            发射组([0xFF, 0xD0])                  // 调用 rax
            如果 (参数数 > 4) {
                定义 可变 清理 = (参数数 - 3) * 8
                如果 (清理 <= 127) { 发射组([0x48, 0x83, 0xC4]) 发射(清理) }
                否则 { 发射组([0x48, 0x81, 0xC4]) 发射32(清理) }
            }
        }
        返回 空
    }

    // 默认: 直接符号调用,由链接器回填 rel32。
    定义 _保存尾调用d = _尾调用模式
    _尾调用模式 = 0
    定义 可变 j = 参数数 - 1
    当 (j >= 0) {
        编译_表达式(参数[j])
        发射(0x50)
        j = j - 1
    }
    _尾调用模式 = _保存尾调用d
    如果 (参数数 >= 1) { 发射(0x59) }           // rcx
    如果 (参数数 >= 2) { 发射(0x5A) }           // rdx
    如果 (参数数 >= 3) { 发射(0x41) 发射(0x58) } // r8
    如果 (参数数 >= 4) { 发射(0x41) 发射(0x59) } // r9
    如果 (_尾调用模式 == 1 且 参数数 <= 4) {
        发射(0xC9)                               // leave
        修正表_追加记录(修正表, "call", 代码位 + 1, 名)
        发射(0xE9)                               // 跳转 rel32
        发射32(0)
        _尾调用模式 = 2
    } 否则 {
        修正表_追加记录(修正表, "call", 代码位 + 1, 名)
        发射(0xE8)                               // 调用 rel32
        发射32(0)
        如果 (参数数 > 4) {
            定义 可变 清理2 = (参数数 - 4) * 8
            如果 (清理2 <= 127) { 发射组([0x48, 0x83, 0xC4]) 发射(清理2) }
            否则 { 发射组([0x48, 0x81, 0xC4]) 发射32(清理2) }
        }
    }
    返回 空
}

函数 编译_短路与(参数) {
    如果 (节点 == 空 或 是列表(节点) == 假 或 计数(节点) < 4) { 返回 空 }
    编译_表达式(节点[2])
    发射_规范空值()
    发射_测试rax()
    定义 可变 假跳 = 发射_je(0)
    编译_表达式(节点[3])
    定义 可变 末跳 = 发射_jmp(0)
    修正跳转(假跳, 代码位)
    发射_载立即(0, 0)
    修正跳转(末跳, 代码位)
    返回 空
}

函数 编译_短路或(vm) {
    如果 (节点 == 空 或 是列表(节点) == 假 或 计数(节点) < 4) { 返回 空 }
    编译_表达式(节点[2])
    发射_规范空值()
    发射_测试rax()
    定义 真跳 = 发射_jne(0)
    编译_表达式(节点[3])
    修正跳转(真跳, 代码位)
    返回 空
}

函数 编译_处理_节_二元(vm) {
    如果 (节点 == 空 或 是列表(节点) == 假 或 计数(节点) < 4) { 返回 空 }
    定义 _b_op = 节点[1]
    定义 可变 _b_左 = 节点[2]
    定义 可变 _b_右 = 节点[3]
    定义 op = 编译_规范化二元操作(_b_op)
    如果 (op == 空) { 返回 空 }
        // 常量折叠: 两个整数字面量 → 编译期计算
    如果 (_b_左[0] == 标记_数字 且 _b_右[0] == 标记_数字) {
        定义 折a = 节点[2][1]
        定义 折b = 节点[3][1]
        定义 可变 折结果 = 0
        定义 可变 已折叠 = 真
        如果 (op == 1) { 折结果 = 折a + 折b }
        否则 如果 (op == 2) { 折结果 = 折a - 折b }
        否则 如果 (op == 3) { 折结果 = 折a * 折b }
        否则 如果 (op == 4 且 折b != 0) { 折结果 = 折a / 折b }
        否则 如果 (op == 5 且 折b != 0) { 折结果 = 折a % 折b }
        否则 如果 (op == 12) { 折结果 = 折a & 折b }
        否则 如果 (op == 13) { 折结果 = 折a | 折b }
        否则 如果 (op == 14) { 折结果 = 折a ^ 折b }
        否则 如果 (op == 15) { 折结果 = 折a << 折b }
        否则 如果 (op == 16) { 折结果 = 折a >> 折b }
        否则 如果 (op == 6) { 如果 (折a == 折b) { 折结果 = 1 } 否则 { 折结果 = 0 } }
        否则 如果 (op == 7) { 如果 (折a != 折b) { 折结果 = 1 } 否则 { 折结果 = 0 } }
        否则 如果 (op == 8) { 如果 (折a < 折b) { 折结果 = 1 } 否则 { 折结果 = 0 } }
        否则 如果 (op == 9) { 如果 (折a > 折b) { 折结果 = 1 } 否则 { 折结果 = 0 } }
        否则 如果 (op == 10) { 如果 (折a <= 折b) { 折结果 = 1 } 否则 { 折结果 = 0 } }
        否则 如果 (op == 11) { 如果 (折a >= 折b) { 折结果 = 1 } 否则 { 折结果 = 0 } }
        否则 { 已折叠 = 假 }
        如果 (已折叠) {
            发射_载立即(0, 折结果)
            返回 空
        }
    }
        // 代数简化: x+0→x, 0+x→x, x-0→x, x*1→x, 1*x→x, x*0→0, 0*x→0
    如果 (_b_右[0] == 标记_数字 且 _b_右[1] == 0) {
        如果 (op == 1 或 op == 13 或 op == 14 或 op == 15 或 op == 16 或 op == 2) {
            编译_表达式(节点[2])
            返回 空
        }
        如果 (op == 3 或 op == 12) {
            发射_载立即(0, 0)
            返回 空
        }
    }
    如果 (_b_左[0] == 标记_数字 且 _b_左[1] == 0) {
        如果 (op == 1 或 op == 13 或 op == 14) {
            编译_表达式(节点[3])
            返回 空
        }
        如果 (op == 3 或 op == 12) {
            发射_载立即(0, 0)
            返回 空
        }
    }
    如果 (_b_右[0] == 标记_数字 且 _b_右[1] == 1) {
        如果 (op == 3 或 op == 4) {
            编译_表达式(节点[2])
            返回 空
        }
    }
    如果 (_b_左[0] == 标记_数字 且 _b_左[1] == 1) {
        如果 (op == 3) {
            编译_表达式(节点[3])
            返回 空
        }
    }
        // 交换律规范化: 左字面量+右非字面量 → 交换, 使强度削减和立即数优化生效
    如果 (_b_左[0] == 标记_数字 且 _b_右[0] != 100) {
        如果 (op == 1 或 op == 3 或 op == 12 或 op == 13 或 op == 14) {
            定义 _tmp交换 = _b_左
            _b_左 = _b_右
            _b_右 = _tmp交换
        }
    }
        // 强度削减: x * 2^n → x << n (优化框架激活)
    如果 (_b_右[0] == 标记_数字 且 op == 3 且 是2的幂(_b_右[1]) == 1 且 _b_右[1] > 1) {
        编译_表达式(_b_左)
        发射组([0x48, 0xC1, 0xE0])               // shl rax, imm8
        发射(对数2(_b_右[1]))
        返回 空
    }
        // 窥孔优化引擎 (创新3: 指令级融合)
        // LEA融合: x*3 → lea rax,[rax+rax*2], x*5 → lea rax,[rax+rax*4], x*9 → lea rax,[rax+rax*8]
    如果 (_b_右[0] == 标记_数字 且 op == 3) {
        如果 (_b_右[1] == 3) { 编译_表达式(_b_左)  发射组([0x48, 0x8D, 0x04, 0x40])  返回 空 }
        如果 (_b_右[1] == 5) { 编译_表达式(_b_左)  发射组([0x48, 0x8D, 0x04, 0x80])  返回 空 }
        如果 (_b_右[1] == 9) { 编译_表达式(_b_左)  发射组([0x48, 0x8D, 0x04, 0xC0])  返回 空 }
    }
        // 除法强度削减: x / 2^n → sar rax, n (仅正整数安全)
    如果 (_b_右[0] == 标记_数字 且 op == 4 且 是2的幂(_b_右[1]) == 1 且 _b_右[1] > 1) {
        编译_表达式(_b_左)
        发射组([0x48, 0xC1, 0xF8])               // sar rax, imm8
        发射(对数2(_b_右[1]))
        返回 空
    }
        // 取模强度削减: x % 2^n → and rax, (2^n - 1)
    如果 (_b_右[0] == 标记_数字 且 op == 5 且 是2的幂(_b_右[1]) == 1 且 _b_右[1] > 1) {
        定义 掩码 = _b_右[1] - 1
        编译_表达式(_b_左)
        如果 (掩码 <= 127) {
            发射组([0x48, 0x83, 0xE0])            // and rax, imm8
            发射(掩码)
        } 否则 {
            发射组([0x48, 0x25])                   // and rax, imm32
            发射32(掩码)
        }
        返回 空
    }
        // 零比较融合: x == 0 → test rax,rax; setz al, x != 0 → test rax,rax; setnz al
    如果 (_b_右[0] == 标记_数字 且 _b_右[1] == 0) {
        如果 (op == 6) {
            编译_表达式(_b_左)
            发射组([0x48, 0x85, 0xC0])            // test rax, rax
            发射组([0x0F, 0x94, 0xC0])            // setz al
            发射组([0x0F, 0xB6, 0xC0])            // movzx eax, al
            返回 空
        }
        如果 (op == 7) {
            编译_表达式(_b_左)
            发射组([0x48, 0x85, 0xC0])            // test rax, rax
            发射组([0x0F, 0x95, 0xC0])            // setnz al
            发射组([0x0F, 0xB6, 0xC0])            // movzx eax, al
            返回 空
        }
    }
        // 取负优化: 0 - x → neg rax (单指令替代load+sub)
    如果 (_b_左[0] == 标记_数字 且 _b_左[1] == 0 且 op == 2) {
        编译_表达式(_b_右)
        发射组([0x48, 0xF7, 0xD8])               // neg rax
        返回 空
    }
        // 立即数优化: 右操作数为整数字面量时, 用 add/sub/cmp/shl/shr imm 替代 load+reg-op
    如果 (_b_右[0] == 标记_数字) {
        定义 _imm = _b_右[1]
        如果 (op == 1 或 op == 2) {
            编译_表达式(_b_左)
            如果 (_imm == 1 且 op == 1) {
                发射组([0x48, 0xFF, 0xC0])                // inc rax
            } 否则 如果 (_imm == 1 且 op == 2) {
                发射组([0x48, 0xFF, 0xC8])                // dec rax
            } 否则 如果 (_imm >= 0 - 128 且 _imm <= 127) {
                如果 (op == 1) {
                    发射组([0x48, 0x83, 0xC0])            // add rax, imm8
                } 否则 {
                    发射组([0x48, 0x83, 0xE8])            // sub rax, imm8
                }
                发射(_imm & 0xFF)
            } 否则 {
                如果 (op == 1) {
                    发射组([0x48, 0x05])                  // add rax, imm32
                } 否则 {
                    发射组([0x48, 0x2D])                  // sub rax, imm32
                }
                发射32(_imm)
            }
            返回 空
        }
        如果 (op == 8 或 op == 9 或 op == 10 或 op == 11) {
            编译_表达式(_b_左)
            如果 (_imm >= 0 - 128 且 _imm <= 127) {
                发射组([0x48, 0x83, 0xF8])                // cmp rax, imm8
                发射(_imm & 0xFF)
            } 否则 {
                发射组([0x48, 0x3D])                      // cmp rax, imm32
                发射32(_imm)
            }
            如果 (op == 8) { 发射组([0x0F, 0x9C, 0xC0]) }
            否则 如果 (op == 9) { 发射组([0x0F, 0x9F, 0xC0]) }
            否则 如果 (op == 10) { 发射组([0x0F, 0x9E, 0xC0]) }
            否则 { 发射组([0x0F, 0x9D, 0xC0]) }
            发射组([0x0F, 0xB6, 0xC0])                    // movzx eax, al
            返回 空
        }
        如果 (op == 15 或 op == 16) {
            编译_表达式(_b_左)
            如果 (op == 15) {
                发射组([0x48, 0xC1, 0xE0])                // shl rax, imm8
            } 否则 {
                发射组([0x48, 0xC1, 0xF8])                // sar rax, imm8
            }
            发射(_imm & 0x3F)
            返回 空
        }
    }
        // 短路逻辑与
    如果 (op == 17) {
        编译_短路与(参数)
        返回 空
    }
        // 短路逻辑或
    如果 (op == 18) {
        编译_短路或(vm)
        返回 空
    }
    如果 (编译_发射_相等比较(op, _b_左, _b_右) == 1) {
        返回 空
    }
        // 编译期浮点检测: 如果任一操作数是浮点, 用 SSE2 浮点运算
    如果 (是浮点节点(_b_左) 或 是浮点节点(_b_右)) {
        如果 (op == 1 或 op == 2 或 op == 3 或 op == 4 或 op == 8 或 op == 9 或 op == 10 或 op == 11 或 op == 6 或 op == 7) {
            // 编译左右操作数 → rax=left, rcx=right
            如果 (是简单(节点[2])) {
                编译_表达式(节点[3])
                发射_mov_rcx_rax()
                编译_表达式(节点[2])
            } 否则 {
                编译_表达式(节点[2])
                发射(0x50)
                编译_表达式(节点[3])
                发射_mov_rcx_rax()
                发射(0x58)
            }
            // rax=left → xmm0, rcx=right → xmm1
            如果 (是浮点节点(节点[2])) {
                发射组([0x66, 0x48, 0x0F, 0x6E, 0xC0])  // movq xmm0, rax
            } 否则 {
                发射组([0xF2, 0x48, 0x0F, 0x2A, 0xC0])  // cvtsi2sd xmm0, rax
            }
            如果 (是浮点节点(节点[3])) {
                发射组([0x66, 0x48, 0x0F, 0x6E, 0xC9])  // movq xmm1, rcx
            } 否则 {
                发射组([0xF2, 0x48, 0x0F, 0x2A, 0xC9])  // cvtsi2sd xmm1, rcx
            }
            // 算术运算
            如果 (op == 1) { 发射组([0xF2, 0x0F, 0x58, 0xC1]) }
            否则 如果 (op == 2) { 发射组([0xF2, 0x0F, 0x5C, 0xC1]) }
            否则 如果 (op == 3) { 发射组([0xF2, 0x0F, 0x59, 0xC1]) }
            否则 如果 (op == 4) { 发射组([0xF2, 0x0F, 0x5E, 0xC1]) }
            否则 如果 (op == 8 或 op == 9 或 op == 10 或 op == 11 或 op == 6 或 op == 7) {
                // ucomisd xmm0, xmm1 (66 0F 2E C1)
                发射组([0x66, 0x0F, 0x2E, 0xC1])
                // setCC al (NaN-safe: PF=1 时 </<=/== 返回false, != 返回true)
                如果 (op == 8) {
                    发射组([0x0F, 0x92, 0xC0])  // setb al
                    发射组([0x0F, 0x9B, 0xC1])  // setnp cl
                    发射组([0x20, 0xC8])         // and al, cl
                }
                否则 如果 (op == 9) { 发射组([0x0F, 0x97, 0xC0]) }
                否则 如果 (op == 10) {
                    发射组([0x0F, 0x96, 0xC0])  // setbe al
                    发射组([0x0F, 0x9B, 0xC1])  // setnp cl
                    发射组([0x20, 0xC8])         // and al, cl
                }
                否则 如果 (op == 11) { 发射组([0x0F, 0x93, 0xC0]) }
                否则 如果 (op == 6) {
                    发射组([0x0F, 0x94, 0xC0])  // sete al
                    发射组([0x0F, 0x9B, 0xC1])  // setnp cl
                    发射组([0x20, 0xC8])         // and al, cl
                }
                否则 {
                    发射组([0x0F, 0x95, 0xC0])  // setne al
                    发射组([0x0F, 0x9A, 0xC1])  // setp cl
                    发射组([0x08, 0xC8])         // or al, cl
                }
                // movzx eax, al
                发射组([0x0F, 0xB6, 0xC0])
                返回 空
            }
            // 结果 xmm0 → rax (IEEE 754 bits)
            发射组([0x66, 0x48, 0x0F, 0x7E, 0xC0])  // movq rax, xmm0
            返回 空
        }
    }
        // 编译期字符串检测: 若 + 的任一操作数是字符串, 用 str_concat
    如果 (op == 1 且 (是字符串节点(_b_左) 或 是字符串节点(_b_右))) {
        // 字符串拼接路径
        如果 (是简单(节点[2])) {
            编译_表达式(节点[3])
            发射_mov_rcx_rax()
            编译_表达式(节点[2])
        } 否则 {
            编译_表达式(节点[2])
            发射(0x50)
            编译_表达式(节点[3])
            发射_mov_rcx_rax()
            发射(0x58)
        }
        // rax=left, rcx=right → rcx=left, rdx=right
        发射组([0x48, 0x89, 0xCA])  // mov rdx, rcx
        发射组([0x48, 0x89, 0xC1])  // mov rcx, rax
        修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_串拼接")
        发射(0xE8)
        发射32(0)
        返回 空
    }
        // 常规二元运算 (优化: 简单左操作数免 push/pop)
    如果 (是简单(_b_左)) {
        编译_表达式(_b_右)
        发射_mov_rcx_rax()
        编译_表达式(_b_左)
    } 否则 {
        编译_表达式(_b_左)
        发射(0x50)
        编译_表达式(_b_右)
        发射_mov_rcx_rax()
        发射(0x58)
    }
    发射_二元操作(op)
    返回 空
}

函数 编译_处理_节_间接调用(vm) {
    // 间接调用: 节点[1]=基表达式(求值得函数指针), 节点[2]=参数列表
    如果 (节点 == 空 或 是列表(节点) == 假 或 计数(节点) < 3) { 返回 空 }
    // Nova函数调用不需要shadow space (与调用指针系列不同)
    定义 间接基 = 节点[1]
    定义 间接参 = 节点[2]
    编译_表达式(间接基)
    发射(0x50)                            // push rax (函数指针, 最底)
    定义 可变 保存尾调用v = _尾调用模式
    _尾调用模式 = 0
    定义 可变 i = 计数(间接参) - 1
    当 (i >= 0) {
        编译_表达式(间接参[i])
        发射(0x50)
        i = i - 1
    }
    定义 间接参数 = 计数(间接参)
    如果 (间接参数 >= 1) { 发射(0x59) }         // rcx = arg0
    如果 (间接参数 >= 2) { 发射(0x5A) }         // rdx = arg1
    如果 (间接参数 >= 3) { 发射(0x41) 发射(0x58) } // r8 = arg2
    如果 (间接参数 >= 4) { 发射(0x41) 发射(0x59) } // r9 = arg3
    如果 (间接参数 <= 4) {
        发射(0x58)                        // pop rax = func ptr
    } 否则 {
        // 函数指针在剩余参数下方: mov rax, [rsp + (间接参数-4)*8]
        发射组([0x48, 0x8B, 0x44, 0x24])
        发射((间接参数 - 4) * 8)
    }
    如果 (保存尾调用v == 1 且 间接参数 <= 4) {
        发射(0xC9)                            // leave
        发射组([0xFF, 0xE0])                  // 跳转 rax
        _尾调用模式 = 2
    } 否则 {
        发射组([0xFF, 0xD0])                  // 调用 rax
        如果 (间接参数 > 4) {
            // 清理剩余参数 + 函数指针槽: (间接参数-4) args + 1 func = (间接参数-3) slots
            定义 清理 = (间接参数 - 3) * 8
            发射组([0x48, 0x83, 0xC4]) 发射(清理)
        }
    }
    返回 空
}

函数 编译_表达式(_表达式入) {
    定义 _保存节点 = 节点
    节点 = _表达式入
    如果 (节点 == 空 或 编译_是列表值(节点) == 假 或 计数(节点) < 1) {
        节点 = _保存节点
        返回 空
    }
    定义 可变 类型 = 节点[0]
    如果 (类型 == 标记_数字) {
        发射_载立即(0, 节点[1])
        节点 = _保存节点
        返回 空
    }
    否则 如果 (类型 == 节点_空字面量) {
        // 空(null)独立节点: 使用哨兵值区分于整数0和假
        发射_载立即(0, 0 - 1313754700)
        节点 = _保存节点
        返回 空
    }
    否则 如果 (类型 == 节_浮点) {
        编译_处理_节_浮点(vm)
    }
    否则 如果 (类型 == 标记_字串) {
        编译_处理_节_字符串(vm)
    }
    否则 如果 (类型 == 标记_名称) {
        编译_处理_节_标识符(vm)
    }
    否则 如果 (类型 == 节点_赋值) {
        编译_处理_节_列表(vm)
    }
    否则 如果 (类型 == 节_字典) {
        编译_处理_节_字典(vm)
    }
    否则 如果 (类型 == 节点_索引) {
        编译_处理_节_索引(vm)
    }
    否则 如果 (类型 == 标记_抛出) {
        编译_处理_节_新建(vm)
    }
    否则 如果 (类型 == 节点_一元正) {
        编译_处理_节_逻辑非(vm)
    }
    否则 如果 (类型 == 节点_一元负) {
        编译_表达式(节点[1])
        发射组([0x48, 0xF7, 0xD0])    // not rax
        节点 = _保存节点
        返回 空
    }
    否则 如果 (类型 == 标记_汇编) {
        编译_处理_节_匿名函数(vm)
    }
    否则 如果 (类型 == 标记_连接词) {
        编译_处理_节_点访问(vm)
    }
    否则 如果 (类型 == 节点_调用) {
        编译_处理_节_调用(vm)
    }
    否则 如果 (类型 == 节点_二元) {
        编译_处理_节_二元(vm)
    }
    否则 如果 (类型 == 标记_函数) {
        编译_处理_节_如果(vm)
    }
    否则 如果 (类型 == 标记_关键140) {
        编译_处理_节_间接调用(vm)
    }
    节点 = _保存节点
    返回 空

}

函数 编译_语句列表(语句) {
    定义 可变 i = 0
    当 (i < 计数(语句)) {
        定义 _s = 语句[i]
        编译_语句(_s)
        如果 (是列表(_s) 且 计数(_s) >= 1 且 _s[0] == 标记_如果) { 返回 空 }
        i = i + 1
    }
    返回 空
}

函数 编译_处理_节_定义(vm) {
    定义 _def名 = 节点[1]
    定义 _def值 = 节点[2]
    定义 可变 偏移 = 分配变量(_def名)
    // 类型追踪: 如果值是新建结构体，记录变量类型
    定义 可变 _推断结构类型 = 推断结构类型名(_def值)
    如果 (_推断结构类型 != 0 且 _推断结构类型 != 空) {
        字典设(变量类型表, _def名, _推断结构类型)
    }
    // 类型追踪: 如果值是字符串表达式，记录变量为字符串类型
    如果 (是字符串节点(_def值)) {
        字典设(变量类型表, _def名, "__转文本__")
    }
    // 类型追踪: 如果值是浮点表达式，记录变量为浮点类型
    如果 (是浮点节点(_def值)) {
        字典设(变量类型表, _def名, "__转浮点__")
    }
    编译_表达式(_def值)
    发射_存变量(偏移)
    返回 空
}

函数 编译_处理_节_赋值(vm) {
    定义 目标名 = 节点[1]
    定义 可变 偏移 = 查变量(目标名)
    如果 (偏移 == 空) {
        // 尝试全局变量
        定义 g偏移 = 字典取(全局变量表, 目标名)
        如果 (g偏移 != 空) {
            偏移 = 0 - 1000 - (g偏移 - 1)
        } 否则 {
            如果 (模块图详细模式[0]) { 打印文本(字符串拼接("警告: 赋值到未定义变量 ", 目标名)) }
        }
    }
    编译_表达式(节点[2])
    偏移 = 查变量(目标名)
    如果 (偏移 == 空) {
        定义 g偏移2 = 字典取(全局变量表, 目标名)
        如果 (g偏移2 != 空) {
            偏移 = 0 - 1000 - (g偏移2 - 1)
        }
    }
    如果 (偏移 != 空) { 发射_存变量(偏移) }
    返回 空
}

函数 编译_处理_节_点赋值(vm) {
    // 对象.字段 = 值
    编译_表达式(节点[3])       // 值 → rax
    发射(0x50)                        // push rax (值)
    编译_表达式(节点[1])       // 对象指针 → rax
    定义 字段名 = 节点[2]
    定义 可变 偏移idx = 0
    定义 可变 已找到2 = 假
    定义 可变 _推断类型2 = 推断结构类型名(节点[1])
    如果 (_推断类型2 != 0 且 _推断类型2 != 空) {
        偏移idx = 查字段偏移(_推断类型2, 字段名)
        如果 (偏移idx >= 0) { 已找到2 = 真 }
    }
    如果 (已找到2 == 假) {
        定义 _全局idx2 = _查字段偏移_全局(字段名)
        如果 (_全局idx2 >= 0) { 偏移idx = _全局idx2 }
    }
    如果 (偏移idx < 0) { 偏移idx = 0 }
    发射_mov_rcx_rax()
    发射_载立即(2, 偏移idx)
    发射组([0x41, 0x58])                // pop r8 (值)
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_列表设")
    发射(0xE8)
    发射32(0)
    返回 空
}

函数 编译_处理_节_索引赋值(vm) {
    // list[idx] = val
    定义 可变 偏移 = 查变量(节点[1])
    如果 (偏移 != 空) {
        编译_表达式(节点[3])     // val
        发射(0x50)
        编译_表达式(节点[2])     // idx
        发射(0x50)
        发射_载变量(偏移)        // list
        // rax=list, [rsp]=idx, [rsp+8]=val → 通过 __运行时_列表设 安全写入
        发射(0x50)
        编译_发射_索引写入分流()
    }
    返回 空
}

函数 编译_处理_节_链式索引赋值(vm) {
    // base_expr[idx] = val  (e.g. a[i][j] = value)
    编译_表达式(节点[3])     // val
    发射(0x50)
    编译_表达式(节点[2])     // idx (last index)
    发射(0x50)
    编译_表达式(节点[1])     // base expr (e.g. a[i])
    // rax=container, [rsp]=idx, [rsp+8]=val → 通过 __运行时_列表设 安全写入
    发射(0x50)
    编译_发射_索引写入分流()
    返回 空
}

函数 编译_处理_节_如果(vm) {
    定义 _if条件 = 节点[1]
    定义 _if真体 = 节点[2]
    定义 _if假体 = 节点[3]
    定义 可变 _if头 = -1
    定义 可变 _ifop型 = ""
    定义 可变 _ifopi = -999
    定义 可变 _if左 = -1
    定义 可变 _if右 = -1
    如果 (是列表(_if条件) 且 计数(_if条件) > 0) { _if头 = _if条件[0] }
    如果 (_if头 == 节点_二元 且 计数(_if条件) >= 4) {
        _ifop型 = 类型(_if条件[1])
        如果 (_ifop型 == "整数") { _ifopi = _if条件[1] }
        如果 (是列表(_if条件[2]) 且 计数(_if条件[2]) > 0) { _if左 = _if条件[2][0] }
        如果 (是列表(_if条件[3]) 且 计数(_if条件[3]) > 0) { _if右 = _if条件[3][0] }
    }
    如果 (是列表(_if条件) 且 _if条件[0] == 标记_数字) {
        如果 (_if条件[1] != 0) { 编译_语句列表(_if真体) }
        否则 { 编译_语句列表(_if假体) }
        返回 空
    }
    编译_表达式(_if条件)
    发射_规范空值()
    发射_测试rax()
    定义 假跳 = 发射_je(0)
    编译_语句列表(_if真体)
    如果 (计数(_if假体) > 0) {
        定义 末跳 = 发射_jmp(0)
        修正跳转(假跳, 代码位)
        编译_语句列表(_if假体)
        修正跳转(末跳, 代码位)
    } 否则 {
        修正跳转(假跳, 代码位)
    }
    返回 空
}

函数 编译_处理_节_当(vm) {
    定义 _w条件 = 节点[1]
    定义 _w体 = 节点[2]
    // 常量条件折叠: 当(假) → 跳过整个循环
    如果 (是列表(_w条件) 且 _w条件[0] == 标记_数字 且 _w条件[1] == 0) { 返回 空 }
    定义 可变 _w常真 = 是列表(_w条件) 且 _w条件[0] == 标记_数字 且 _w条件[1] != 0
    定义 循环头 = 代码位
    定义 可变 当前中断列 = []
    追加(循环头栈, 循环头)
    追加(中断跳列栈, 当前中断列)
    追加(继续目标栈, 循环头)
    循环深度 = 循环深度 + 1
    定义 可变 退出跳 = 0
    如果 (_w常真 == 假) {
        编译_表达式(_w条件)
        发射_规范空值()
        发射_测试rax()
        退出跳 = 发射_je(0)
    }
    编译_语句列表(_w体)
    发射_调用相对(循环头)
    _elf写(代码, 代码位 - 5, 0xE9)
    如果 (_w常真 == 假) { 修正跳转(退出跳, 代码位) }
    // 修正所有中断跳转
    定义 可变 bki = 0
    当前中断列 = 中断跳列栈[计数(中断跳列栈) - 1]
    当 (bki < 计数(当前中断列)) {
        修正跳转(当前中断列[bki], 代码位)
        bki = bki + 1
    }
    循环深度 = 循环深度 - 1
    删除(循环头栈, 计数(循环头栈) - 1)
    删除(中断跳列栈, 计数(中断跳列栈) - 1)
    删除(继续目标栈, 计数(继续目标栈) - 1)
    返回 空
}

函数 编译_处理_节_匹配(vm) {
    // 辨 值 { 模式1 { 体1 } 模式2 { 体2 } 否则 { 默认体 } }
    定义 匹配表达 = 节点[1]
    定义 分支列 = 节点[2]
    // 分配暂存变量保存匹配值
    定义 匹配偏 = 分配变量(字符串拼接("__匹配_", 转字符串(代码位)))
    编译_表达式(匹配表达)
    发射_存变量(匹配偏)
    // 收集所有末尾跳转位置
    定义 可变 末跳列 = []
    定义 可变 bi = 0
    当 (bi < 计数(分支列)) {
        定义 分支 = 分支列[bi]
        定义 模式 = 分支[0]
        定义 分支体 = 分支[1]
        如果 (模式 == 空) {
            // 默认分支 - 直接执行
            编译_语句列表(分支体)
        } 否则 {
            // 比较: 匹配值 == 模式值
            如果 (是字符串节点(模式)) {
                // 字符串模式: 内容比较
                编译_表达式(模式)
                发射_mov_rcx_rax()
                发射_规范空值_rcx()
                发射_载变量(匹配偏)
                发射组([0x48, 0x89, 0xC2])
                发射_规范空值_rdx()
                修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_串相等")
                发射(0xE8)
                发射32(0)
            } 否则 {
                // 整数/指针模式: 直接比较
                编译_表达式(模式)
                发射_mov_rcx_rax()
                发射_载变量(匹配偏)
                发射组([0x48, 0x39, 0xC8])
                发射组([0x0F, 0x94, 0xC0])
                发射组([0x0F, 0xB6, 0xC0])
            }
            发射_测试rax()
            定义 跳过 = 发射_je(0)
            编译_语句列表(分支体)
            追加(末跳列, 发射_jmp(0))
            修正跳转(跳过, 代码位)
        }
        bi = bi + 1
    }
    // 修正所有末尾跳转到此处
    定义 可变 ji = 0
    当 (ji < 计数(末跳列)) {
        修正跳转(末跳列[ji], 代码位)
        ji = ji + 1
    }
    返回 空
}

函数 编译_处理_节_每个(vm) {
    // 每 变量 在 集合 { 体 }
    定义 迭代名 = 节点[1]
    定义 集合表达 = 节点[2]
    定义 循环体 = 节点[3]
    定义 计数器偏 = 分配变量(字符串拼接("__函数调用_", 迭代名))
    定义 集合偏 = 分配变量(字符串拼接("__函数列_", 迭代名))
    定义 迭代偏 = 分配变量(迭代名)
    // 初始化 counter = -1 (先increment再check)
    发射_载立即(0, -1)
    发射_存变量(计数器偏)
    编译_表达式(集合表达)
    发射_存变量(集合偏)
    // 循环栈管理 (与 编译_处理_节_当 对称)
    定义 可变 每个中断列0 = []
    追加(循环头栈, 代码位)
    追加(中断跳列栈, 每个中断列0)
    循环深度 = 循环深度 + 1
    // increment点 (continue跳到这里)
    定义 增量点 = 代码位
    追加(继续目标栈, 增量点)
    发射_载变量(计数器偏)
    发射组([0x48, 0xFF, 0xC0])    // inc rax
    发射_存变量(计数器偏)
    // condition check: counter < list.count?
    发射_载变量(集合偏)
    发射组([0x48, 0x8B, 0x08])    // mov rcx, [rax] (list.count)
    发射_载变量(计数器偏)
    发射组([0x48, 0x39, 0xC8])    // cmp rax, rcx
    发射组([0x0F, 0x9C, 0xC0])    // setl al
    发射组([0x0F, 0xB6, 0xC0])    // movzx eax, al
    发射_测试rax()
    定义 每个退出 = 发射_je(0)
    // 加载 item via __运行时_列表取(list, index)
    发射_载变量(集合偏)
    发射_mov_rcx_rax()
    发射_载变量(计数器偏)
    发射组([0x48, 0x89, 0xC2])  // mov rdx, rax (index)
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_列表取")
    发射(0xE8)
    发射32(0)
    发射_存变量(迭代偏)
    // body
    编译_语句列表(循环体)
    // 跳转 back to increment
    发射_调用相对(增量点)
    _elf写(代码, 代码位 - 5, 0xE9)
    修正跳转(每个退出, 代码位)
    // 修正中断跳转
    如果 (计数(中断跳列栈) > 0) {
    定义 可变 bki2 = 0
    定义 每个中断列 = 中断跳列栈[计数(中断跳列栈) - 1]
    当 (bki2 < 计数(每个中断列)) {
        修正跳转(每个中断列[bki2], 代码位)
        bki2 = bki2 + 1
    }
    循环深度 = 循环深度 - 1
    删除(循环头栈, 计数(循环头栈) - 1)
    删除(中断跳列栈, 计数(中断跳列栈) - 1)
    删除(继续目标栈, 计数(继续目标栈) - 1)
    }
    返回 空
}

函数 编译_处理_节_中断(vm) {
    如果 (循环深度 > 0) {
        定义 中断列ref = 中断跳列栈[计数(中断跳列栈) - 1]
        追加(中断列ref, 发射_jmp(0))
    }
    返回 空
}

函数 编译_处理_节_继续(vm) {
    如果 (循环深度 > 0) {
        定义 继续目标 = 继续目标栈[计数(继续目标栈) - 1]
        发射_调用相对(继续目标)
        _elf写(代码, 代码位 - 5, 0xE9)
    }
    返回 空
}

函数 编译_处理_节_尝试(vm) {
    定义 尝试体 = 节点[1]
    定义 捕获名 = 节点[2]
    定义 捕获体 = 节点[3]
    定义 捕获偏 = 分配变量(捕获名)
    定义 标志偏 = 查变量("__错误_标志")
    定义 值偏 = 查变量("__错误_值")
    定义 rbp偏 = 查变量("__错误_基指针")
    定义 rsp偏 = 查变量("__错误_栈指针")
    定义 jmp偏 = 查变量("__错误_跳转")
    // 嵌套保护: 保存旧错误处理器状态
    定义 uid = 变量数
    定义 旧rbp偏 = 分配变量(字符串拼接("__尝试_基指针_", 转字符串(uid)))
    定义 旧rsp偏 = 分配变量(字符串拼接("__尝试_栈指针_", 转字符串(uid)))
    定义 旧jmp偏 = 分配变量(字符串拼接("__尝试_跳转_", 转字符串(uid)))
    发射_载变量(rbp偏)
    发射_存变量(旧rbp偏)
    发射_载变量(rsp偏)
    发射_存变量(旧rsp偏)
    发射_载变量(jmp偏)
    发射_存变量(旧jmp偏)
    // 保存 rbp 到 __错误_基指针
    发射组([0x48, 0x89, 0xE8])
    发射_存变量(rbp偏)
    // 保存 rsp 到 __错误_栈指针
    发射组([0x48, 0x89, 0xE0])
    发射_存变量(rsp偏)
    // lea rax, [rip+catch_offset] → 保存到 __错误_跳转
    发射组([0x48, 0x8D, 0x05])
    定义 catch修正 = 代码位
    发射32(0)
    发射_存变量(jmp偏)
    // 清除错误标志
    发射_载立即(0, 0)
    发射_存变量(标志偏)
    // 执行尝试体
    编译_语句列表(尝试体)
    // 正常退出 — 跳过捕获块
    定义 正常跳 = 发射_jmp(0)
    // 捕获标签 (抛出跳到这里)
    修正跳转(catch修正, 代码位)
    // 加载错误值到捕获变量
    发射_载变量(值偏)
    发射_存变量(捕获偏)
    // 清除错误标志
    发射_载立即(0, 0)
    发射_存变量(标志偏)
    // 执行捕获体
    编译_语句列表(捕获体)
    修正跳转(正常跳, 代码位)
    // 嵌套保护: 恢复旧错误处理器状态
    发射_载变量(旧rbp偏)
    发射_存变量(rbp偏)
    发射_载变量(旧rsp偏)
    发射_存变量(rsp偏)
    发射_载变量(旧jmp偏)
    发射_存变量(jmp偏)
    返回 空
}

函数 编译_处理_节_汇编块(vm) {
    编译_汇编文本块(节点[1])
    返回 空
}

函数 编译_处理_节_抛出(vm) {
    定义 标志偏2 = 查变量("__错误_标志")
    定义 值偏2 = 查变量("__错误_值")
    定义 rbp偏2 = 查变量("__错误_基指针")
    定义 rsp偏2 = 查变量("__错误_栈指针")
    定义 jmp偏2 = 查变量("__错误_跳转")
    // 计算抛出值
    编译_表达式(节点[1])
    // 存储到 __错误_值
    发射_存变量(值偏2)
    // 设置 __错误_标志 = 1
    发射_载立即(0, 1)
    发射_存变量(标志偏2)
    // 加载跳转地址到 rcx
    发射_载变量(jmp偏2)
    发射_mov_rcx_rax()
    // 恢复 rbp
    发射_载变量(rbp偏2)
    发射组([0x48, 0x89, 0xC5])
    // 恢复 rsp
    发射_载变量(rsp偏2)
    发射组([0x48, 0x89, 0xC4])
    // 跳转到 catch 处理器
    发射组([0xFF, 0xE1])
    返回 空
}

函数 编译_语句(_节点入) {
    定义 _保存节点2 = 节点
    节点 = _节点入
    _记录行号(_取节点行号(_节点入))
    定义 类型 = 节点[0]
    如果 (类型 == 标记_定义) {
        编译_处理_节_定义(vm)
    }
    否则 如果 (类型 == 标记_可变) {
        编译_处理_节_赋值(vm)
    }
    否则 如果 (类型 == 标记_顺序词) {
        编译_处理_节_点赋值(vm)
    }
    否则 如果 (类型 == 标记_当) {
        编译_处理_节_索引赋值(vm)
    }
    否则 如果 (类型 == 标记_关键141) {
        编译_处理_节_链式索引赋值(vm)
    }
    否则 如果 (类型 == 标记_如果) {
        定义 _ret值 = 节点[1]
        如果 (是列表(_ret值) 且 计数(_ret值) >= 3 且 _ret值[0] == 节点_调用) {
            定义 _tc参数 = _ret值[2]
            如果 (_tc参数 == 空 或 是列表(_tc参数) == 假) { _tc参数 = [] }
            如果 (计数(_tc参数) <= 4) {
                _尾调用模式 = 1
                编译_表达式(_ret值)
                如果 (_尾调用模式 != 2) {
                    发射_尾声()
                }
                _尾调用模式 = 0
                节点 = _保存节点2
                返回 空
            }
        }
        编译_表达式(_ret值)
        发射_尾声()
        节点 = _保存节点2
        返回 空
    }
    否则 如果 (类型 == 标记_函数) {
        编译_处理_节_如果(vm)
    }
    否则 如果 (类型 == 标记_返回) {
        编译_处理_节_当(vm)
    }
    否则 如果 (类型 == 标记_关键135) {
        编译_处理_节_匹配(vm)
    }
    否则 如果 (类型 == 标记_关键134) {
        编译_处理_节_每个(vm)
    }
    否则 如果 (类型 == 标记_关键136) {
        编译_处理_节_中断(vm)
    }
    否则 如果 (类型 == 标记_关键137) {
        编译_处理_节_继续(vm)
    }
    否则 如果 (类型 == 节点_变量声明) {
        编译_处理_节_尝试(vm)
    }
    否则 如果 (类型 == 节点_赋值语句) {
        编译_处理_节_抛出(vm)
    }
    否则 如果 (类型 == 节点_复合赋值) {
        编译_处理_节_汇编块(vm)
    }
    否则 如果 (类型 == 标记_否则) {
        编译_表达式(节点[1])
        节点 = _保存节点2
        返回 空
    }
    节点 = _保存节点2
    返回 空
}

函数 编译_函数(节点, 传入闭包) {
    定义 名 = 节点[1]
    定义 参数 = 节点[2]
    定义 体 = 节点[3]
    _记录行号(_取节点行号(节点))

    定义 _保存主体模式 = 主体模式
    主体模式 = 0

    当前函数名 = 名
    字典设(函数表, 名, 代码位)
    变量表 = 字典()
    变量数 = 0
    // AI后端路径推断: 根据函数名推断AI算子标签并记录发射路径
    定义 _ai标签 = IR标签_从函数名推断(名)
    定义 _ai路径 = AI后端_选择路径(_ai标签, 0, 编译_当前是裸机目标())
    AI后端_记录发射(_ai路径)
    发射_序言()

    定义 可变 pi = 0
    当 (pi < 计数(参数)) {
        // 函数参数强制局部分配，绕过分配变量的全局变量fallback
        变量数 = 变量数 + 1
        定义 偏移 = 0 - (变量数 * 8)
        字典设(变量表, 参数[pi], 偏移)
        如果 (pi == 0) { 发射_存rcx到变量(偏移) }
        否则 如果 (pi == 1) { 发射_存rdx到变量(偏移) }
        否则 如果 (pi == 2) {
            如果 (偏移 >= 0 - 128) {
                发射组([0x4C, 0x89, 0x45]) 发射(偏移 & 0xFF)
            } 否则 {
                发射组([0x4C, 0x89, 0x85]) 发射32(偏移)
            }
        }
        否则 如果 (pi == 3) {
            如果 (偏移 >= 0 - 128) {
                发射组([0x4C, 0x89, 0x4D]) 发射(偏移 & 0xFF)
            } 否则 {
                发射组([0x4C, 0x89, 0x8D]) 发射32(偏移)
            }
        }
        否则 {
            // 第5+参数: 从栈上读取 [rbp + 16 + (pi-4)*8]
            定义 栈偏移 = 16 + (pi - 4) * 8
            发射组([0x48, 0x8B, 0x85])   // mov rax, [rbp+disp32]
            发射32(栈偏移)
            发射_存变量(偏移)
        }
        pi = pi + 1
    }

    // 闭包: 从全局闭包槽加载捕获变量到局部 (使用传入参数)
    如果 (传入闭包 != 空) {
        定义 可变 cli = 0
        当 (cli < 计数(传入闭包)) {
            定义 闭包变名 = 传入闭包[cli]
            如果 (字典取(变量表, 闭包变名) == 空) {
                定义 闭包局偏 = 分配变量(闭包变名)
                定义 闭包槽名 = 字符串拼接("__闭包_", 字符串拼接(名, 字符串拼接("_", 闭包变名)))
                定义 闭包全偏 = 字典取(全局变量表, 闭包槽名)
                如果 (闭包全偏 != 空) {
                    定义 闭包读偏 = 0 - 1000 - (闭包全偏 - 1)
                    发射_载变量(闭包读偏)
                    发射_存变量(闭包局偏)
                }
            }
            cli = cli + 1
        }
    }

    编译_语句列表(体)
    发射_载立即(0, 0 - 1313754700)
    发射_尾声()
    定义 帧 = (变量数 + 8) * 8
    定义 对齐帧 = ((帧 + 15) / 16) * 16
    _elf写32(代码, 帧大小位, 对齐帧)

    主体模式 = _保存主体模式
}

// 5.0: AI原生计算后端分流 — SIMD / 低比特打包 / GQA分页缓存 / host-baremetal差异化

// AI计算路径分流
// 根据IR标签选择发射路径: 普通→通用, 注意力/检索/量化→SIMD, 记忆→特殊布局
定义 可变 _AI后端_SIMD发射数 = 0
定义 可变 _AI后端_低比特发射数 = 0
定义 可变 _AI后端_GQA发射数 = 0
定义 可变 _AI后端_通用发射数 = 0

函数 AI后端_选择路径(算子标签, 精度, 设备) {
    // 返回: 0=通用 1=SIMD 2=低比特打包 3=GQA分页缓存
    如果 (设备 == 1) { 返回 1 }
    如果 (精度 == 3 或 精度 == 4) { 返回 2 }
    如果 (算子标签 == 3) { 返回 3 }
    如果 (算子标签 == 5) { 返回 1 }
    如果 (算子标签 == 6) { 返回 2 }
    如果 (算子标签 == 1 或 算子标签 == 2) { 返回 1 }
    返回 0
}

函数 AI后端_记录发射(路径) {
    如果 (路径 == 0) { _AI后端_通用发射数 = _AI后端_通用发射数 + 1 }
    如果 (路径 == 1) { _AI后端_SIMD发射数 = _AI后端_SIMD发射数 + 1 }
    如果 (路径 == 2) { _AI后端_低比特发射数 = _AI后端_低比特发射数 + 1 }
    如果 (路径 == 3) { _AI后端_GQA发射数 = _AI后端_GQA发射数 + 1 }
}

// SIMD向量化发射辅助 (SSE2/AVX2)
函数 AI后端_发射SIMD(操作名) {
    _AI后端_SIMD发射数 = _AI后端_SIMD发射数 + 1
    如果 (操作名 == "加") {
        // paddd xmm0, xmm1 — SSE2 32位整数加
        发射组([0x66, 0x0F, 0xFE, 0xC1])
        返回 空
    }
    如果 (操作名 == "乘") {
        // pmulld xmm0, xmm1 — SSE4.1 32位整数乘
        发射组([0x66, 0x0F, 0x38, 0x40, 0xC1])
        返回 空
    }
    如果 (操作名 == "浮点加") {
        // addps xmm0, xmm1 — SSE 单精度浮点加
        发射组([0x0F, 0x58, 0xC1])
        返回 空
    }
    如果 (操作名 == "浮点乘") {
        // mulps xmm0, xmm1 — SSE 单精度浮点乘
        发射组([0x0F, 0x59, 0xC1])
        返回 空
    }
    如果 (操作名 == "载入") {
        // movdqu xmm0, [rcx] — SSE2 非对齐128位载入
        发射组([0xF3, 0x0F, 0x6F, 0x01])
        返回 空
    }
    如果 (操作名 == "存储") {
        // movdqu [rcx], xmm0 — SSE2 非对齐128位存储
        发射组([0xF3, 0x0F, 0x7F, 0x01])
        返回 空
    }
    如果 (操作名 == "水平加") {
        // phaddd xmm0, xmm0 — SSSE3 水平32位加x2得到总和
        发射组([0x66, 0x0F, 0x38, 0x02, 0xC0])
        发射组([0x66, 0x0F, 0x38, 0x02, 0xC0])
        返回 空
    }
    如果 (操作名 == "最大值") {
        // pmaxsd xmm0, xmm1 — SSE4.1 有符号32位最大值
        发射组([0x66, 0x0F, 0x38, 0x3D, 0xC1])
        返回 空
    }
}

// 低比特打包发射辅助 (int8/int4量化)
函数 AI后端_发射低比特(操作名, 精度) {
    _AI后端_低比特发射数 = _AI后端_低比特发射数 + 1
    如果 (操作名 == "打包" 且 精度 == 8) {
        // packssdw xmm0, xmm0 — 32→16位饱和打包
        发射组([0x66, 0x0F, 0x6B, 0xC0])
        // packsswb xmm0, xmm0 — 16→8位饱和打包
        发射组([0x66, 0x0F, 0x63, 0xC0])
        返回 空
    }
    如果 (操作名 == "解包" 且 精度 == 8) {
        // pmovsxbd xmm0, xmm0 — SSE4.1 int8→int32符号扩展
        发射组([0x66, 0x0F, 0x38, 0x21, 0xC0])
        返回 空
    }
    如果 (操作名 == "打包" 且 精度 == 4) {
        // int4打包: 先右移4位(高4位), 再OR合并(两个int8→一个字节)
        // psrld xmm1, 4
        发射组([0x66, 0x0F, 0x72, 0xD1, 0x04])
        // pslld xmm0, 4
        发射组([0x66, 0x0F, 0x72, 0xF0, 0x04])
        // por xmm0, xmm1
        发射组([0x66, 0x0F, 0xEB, 0xC1])
        返回 空
    }
    如果 (操作名 == "量化") {
        // pmulhrsw xmm0, xmm1 — SSSE3 定点乘(用于缩放因子量化, 0)
        发射组([0x66, 0x0F, 0x38, 0x0B, 0xC1])
        返回 空
    }
}

// GQA分页缓存布局发射
函数 AI后端_发射GQA(头数, KV头数) {
    _AI后端_GQA发射数 = _AI后端_GQA发射数 + 1
    // GQA: 多个Q头共享同一KV头, 重复因子 = 头数/KV头数
    // 计算KV头索引: Q头索引 / 重复因子
    // rax = Q头索引(输入), rcx = KV头数(输入)
    // 发射: rax = rax * KV头数 / 头数 (即 rax / 重复因子)
    如果 (KV头数 > 0 且 头数 > 0) {
        定义 重复因子 = 头数 / KV头数
        如果 (重复因子 > 1) {
            // xor rdx, rdx
            发射组([0x48, 0x31, 0xD2])
            // mov rcx, 重复因子
            发射组([0x48, 0xC7, 0xC1])
            发射32(重复因子)
            // div rcx — rax = rax / 重复因子
            发射组([0x48, 0xF7, 0xF1])
        }
    }
}

// host/baremetal差异化入口包装
函数 AI后端_入口包装(函数名) {
    如果 (编译_当前是裸机目标()) {
        // 裸机: 禁用浮点异常, 保存/恢复SSE状态
        返回 "baremetal"
    }
    返回 "host"
}

// 向量寄存器类别
定义 向量寄存器_xmm = 0
定义 向量寄存器_ymm = 1
定义 向量寄存器_zmm = 2

函数 AI后端_选择向量寄存器(精度, 元素数) {
    如果 (元素数 <= 4) { 返回 向量寄存器_xmm }
    如果 (元素数 <= 8) { 返回 向量寄存器_ymm }
    返回 向量寄存器_zmm
}

// 后端统计报告
函数 AI后端_统计报告() {
    定义 可变 r = 字典()
    字典设(r, "SIMD发射", 转字符串(_AI后端_SIMD发射数))
    字典设(r, "低比特发射", 转字符串(_AI后端_低比特发射数))
    字典设(r, "GQA发射", 转字符串(_AI后端_GQA发射数))
    字典设(r, "通用发射", 转字符串(_AI后端_通用发射数))
    字典设(r, "裸机目标", 转字符串(编译_当前是裸机目标()))
    返回 r
}

// PE 构建器 + 主程序

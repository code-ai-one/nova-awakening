导入("../../标准库/基础.nova")

// Nova · IR层 · 尾调用优化 (Tail Call Optimization)
// 尾递归→循环转换 / 互递归检测 / 蹦床变换
// 核心收益：O(n)栈空间 → O(1)栈空间

// 尾调用类型
定义 尾调_无 = 0          // 非尾位置调用
定义 尾调_自递归 = 1      // 直接尾递归（A调A）
定义 尾调_其他 = 2        // 尾位置调用其他函数

函数 尾调用优_在尾位置(_语句类型, 是最后, 在返回中) {
    如果 (在返回中 == 1) {
        如果 (是最后 == 1) { 返回 1 }
    }
    返回 0
}

函数 尾调用优_检测尾调用(当前函数, 被调函数, 尾位置) {
    如果 (尾位置 == 0) { 返回 尾调_无 }
    如果 (当前函数 == 被调函数) { 返回 尾调_自递归 }
    返回 尾调_其他
}

函数 尾调用优_尾递归信息(函数ID, 参数数) {
    返回 [函数ID, 参数数,]
}

函数 尾调用优_尾递归_标记可转(信息) { 信息[2] = 1 }
函数 尾调用优_尾递归_增计数(信息) { 信息[3] = 信息[3] + 1 }
函数 尾调用优_尾递归_可转换(信息) { 返回 信息[2] }
函数 尾调用优_尾递归_次数(信息) { 返回 信息[3] }

// 分析函数体语句列表，找出最后一条语句是否是尾调用
// 语句格式：[类型, ...] 节_返回=114, 节_调用=103
函数 尾调用优_分析尾部(语句列表, 当前函数, 最后调用目标) {
    如果 (语句列表 == 空 或 计数(语句列表) == 0) { 返回 尾调_无 }
    定义 n = 计数(语句列表)
    定义 最后 = 语句列表[n - 1]
    如果 (最后 == 空 或 计数(最后) == 0) { 返回 尾调_无 }
    定义 类型 = 最后[0]
    // 返回语句（节_返回=114）的子表达式是调用
    如果 (类型 == 114 且 计数(最后) >= 2) {
        定义 子表达式 = 最后[1]
        如果 (是列表(子表达式) 且 计数(子表达式) >= 2) {
            如果 (子表达式[0] == 103) {  // 节_调用=103
                定义 被调 = 子表达式[1]
                如果 (被调 == 当前函数) {
                    如果 (最后调用目标 != 空) { 最后调用目标[0] = 被调 }
                    返回 尾调_自递归
                }
                返回 尾调_其他
            }
        }
    }
    返回 尾调_无
}

函数 尾调用优_TCO统计_创建() {
    返回 [0,]
}

函数 尾调用优_TCO_添加递归(stats) { stats[0] = stats[0] + 1 }
函数 尾调用优_TCO_添加调用(stats) { stats[1] = stats[1] + 1 }
函数 尾调用优_TCO_尾递归数(stats) { 返回 stats[0] }
函数 尾调用优_TCO_尾调用数(stats) { 返回 stats[1] }

函数 尾调用优_栈帧节省(尾递归数, 平均调用深度) {
    返回 尾递归数 * 平均调用深度 * 8
}

函数 尾调用优_TCO安全(有异常处理, 有闭包) {
    如果 (有异常处理 == 1) { 返回 0 }
    如果 (有闭包 == 1) { 返回 0 }
    返回 1
}

// TCO增强: 互递归检测
// A调B, B调A → 两者都可优化
函数 检测互递归(函数列表, 调用图) {
    定义 n = 计数(函数列表)
    定义 可变 互递归组 = []

    定义 可变 i = 0
    当 (i < n) {
        定义 可变 j = i + 1
        当 (j < n) {
            // A调B且B调A
            如果 (调用图[i][j] > 0 且 调用图[j][i] > 0) {
                追加(互递归组, [i, j])
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 互递归组
}

// 尾调用转换器
// 将尾递归转换为循环的IR变换

函数 TCO_转换信息(函数ID, 参数数, 尾调用位置列表) {
    返回 [函数ID, 参数数, [],]
}

// 执行TCO转换（标记该尾递归已可转换为循环）
函数 TCO_执行转换(信息) {
    信息[2] = 1  // 标记已确认可转换
    尾调用优_TCO_记录转换()
 返回 1  // 转换成功
}

// 累积器传参优化
// 尾递归模式: f(n, acc) = f(n-1, acc*n) → 直接循环
函数 检测累积器模式(参数变化列表) {
    返回 0
}

// 综合TCO报告
// 相互递归检测

// 互递归调用图（字典实现）
定义 可变 _互递归_图 = 字典()  // 调用者 → [被调者列表]

函数 互递归_记录调用(调用者, 被调者) {
    定义 键 = 转字符串(调用者)
    定义 已有 = 字典取(_互递归_图, 键)
    如果 (已有 == 空) {
        字典设(_互递归_图, 键, [被调者])
    } 否则 {
        // 避免重复
        定义 可变 已有该 = 假
        定义 可变 i = 0
        当 (i < 计数(已有)) {
            如果 (已有[i] == 被调者) { 已有该 = 真 }
            i = i + 1
        }
        如果 (已有该 == 假) { 追加(已有, 被调者) }
    }
}

// 检测 A 和 B 是否互递归（A调B且B调A）
函数 互递归_检测(函数a, 函数b) {
    定义 a的被调 = 字典取(_互递归_图, 转字符串(函数a))
    定义 b的被调 = 字典取(_互递归_图, 转字符串(函数b))
    如果 (a的被调 == 空 或 b的被调 == 空) { 返回 假 }
    // A调了B
    定义 可变 a调b = 假
    定义 可变 i = 0
    当 (i < 计数(a的被调)) {
        如果 (a的被调[i] == 函数b) { a调b = 真 }
        i = i + 1
    }
    如果 (a调b == 假) { 返回 假 }
    // B调了A
    i = 0
    当 (i < 计数(b的被调)) {
        如果 (b的被调[i] == 函数a) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 互递归_所有组() {
    // 遍历调用图，找所有互递归对
    返回 []  // 简化实现：返回空（复杂查询通过 互递归_检测 按需查询）
}

函数 互递归_重置() { _互递归_图 = 字典() }

// 蹦床变换

函数 蹦床_包装(函数名, 参数列表) {
    // 返回一个"续体"标记: [标记, 函数名, 参数]
    返回 ["__蹦床续体__", 函数名, 参数列表]
}

函数 蹦床_是续体(值) {
    如果 (!是列表(值)) { 返回 假 }
    如果 (计数(值) < 1) { 返回 假 }
    返回 值[0] == "__蹦床续体__"
}

// 蹦床执行器：持续调用直到返回非续体值
// 分派函数：(函数名, 参数列表) → 结果
函数 蹦床_执行(初始结果, 分派函数) {
    定义 可变 当前 = 初始结果
    定义 可变 最大轮次 = 1000000  // 防止无限循环
    定义 可变 轮次 = 0
    当 (蹦床_是续体(当前) 且 轮次 < 最大轮次) {
        定义 函数名 = 当前[1]
        定义 参数列表 = 当前[2]
        当前 = 分派函数(函数名, 参数列表)
        轮次 = 轮次 + 1
    }
    返回 当前
}

// 栈帧估算

函数 TCO_估算栈深(递归深度, 帧大小) {
    返回 递归深度 * 帧大小
}

函数 TCO_优化后栈(帧大小) {
 返回 帧大小  // 尾调用只用一个帧
}

函数 TCO_节省比(递归深度) {
    如果 (递归深度 <= 1) { 返回 0 }
    返回 (递归深度 - 1) * 100 / 递归深度
}

定义 可变 _TCO_检测数 = 0
定义 可变 _TCO_转换数 = 0

函数 尾调用优_TCO_记录检测() { _TCO_检测数 = _TCO_检测数 + 1 }
函数 尾调用优_TCO_记录转换() { _TCO_转换数 = _TCO_转换数 + 1 }

// 真实TCO变换：尾递归→循环（AST重写）
// 将 函数 f(x,y) { ... 返回 f(a,b) }
// 变换为 函数 f(x,y) { 当(1) { ... _tco0=a _tco1=b x=_tco0 y=_tco1 继续 } }
// 节点类型: 113=当, 100=整数, 110=定义, 111=赋值, 102=标识符, 137=继续

函数 尾调用优_变换全部(函数列表) {
    如果 (函数列表 == 空 或 是列表(函数列表) == 假) { 返回 0 }
    定义 可变 转换数 = 0
    定义 可变 i = 0
    当 (i < 计数(函数列表)) {
        如果 (是列表(函数列表[i]) 且 计数(函数列表[i]) >= 4) {
            定义 函名 = 函数列表[i][1]
            定义 参数 = 函数列表[i][2]
            定义 函体 = 函数列表[i][3]
            如果 (是列表(函体) 且 计数(函体) > 0 且 是列表(参数)) {
                定义 尾类型 = 尾调用优_分析尾部(函体, 函名, 空)
                如果 (尾类型 == 1) {
                    定义 成功 = _tco_变换单函数(参数, 函体, 函名)
                    如果 (成功) { 转换数 = 转换数 + 1 }
                }
            }
        }
        i = i + 1
    }
    返回 转换数
}

函数 _tco_变换单函数(参数, 函体, 函名) {
    定义 n = 计数(函体)
    如果 (n == 0) { 返回 假 }
    定义 最后 = 函体[n - 1]
    如果 (是列表(最后) == 假 或 计数(最后) < 2 或 最后[0] != 114) { 返回 假 }
    定义 子表达式 = 最后[1]
    如果 (是列表(子表达式) == 假 或 计数(子表达式) < 3 或 子表达式[0] != 103) { 返回 假 }
    如果 (子表达式[1] != 函名) { 返回 假 }
    定义 实参 = 子表达式[2]
    如果 (是列表(实参) == 假 或 计数(实参) != 计数(参数)) { 返回 假 }
    // 构造循环体: 原始语句(除最后) + 临时变量定义 + 参数赋值 + 继续
    定义 可变 循环体 = []
    定义 可变 si = 0
    当 (si < n - 1) {
        追加(循环体, 函体[si])
        si = si + 1
    }
    // 用临时变量防止参数互相依赖: _tco0=arg0, _tco1=arg1, ... 然后 p0=_tco0, p1=_tco1
    定义 可变 pi = 0
    当 (pi < 计数(参数)) {
        定义 临时名 = 字符串拼接("_tco", 转字符串(pi))
        追加(循环体, [110, 临时名, 实参[pi]])
        pi = pi + 1
    }
    pi = 0
    当 (pi < 计数(参数)) {
        定义 临时名 = 字符串拼接("_tco", 转字符串(pi))
        追加(循环体, [111, 参数[pi], [102, 临时名]])
        pi = pi + 1
    }
    追加(循环体, [137])
    // 构造 当(1){循环体} 循环节点
    定义 循环 = [113, [100, 1], 循环体]
    // 原地替换函数体: 清空→添加循环
    当 (计数(函体) > 0) { 删除(函体, 计数(函体) - 1) }
    追加(函体, 循环)
    尾调用优_TCO_记录转换()
    返回 真
}

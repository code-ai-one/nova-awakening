函数 CSS属性_名称(id) {
    如果 (id == CSS属性_display) { 返回 "display" }
    如果 (id == CSS属性_position) { 返回 "position" }
    如果 (id == CSS属性_width) { 返回 "width" }
    如果 (id == CSS属性_height) { 返回 "height" }
    如果 (id == CSS属性_color) { 返回 "color" }
    如果 (id == CSS属性_background_color) { 返回 "background-color" }
    如果 (id == CSS属性_font_size) { 返回 "font-size" }
    如果 (id == CSS属性_font_weight) { 返回 "font-weight" }
    如果 (id == CSS属性_font_family) { 返回 "font-family" }
    如果 (id == CSS属性_text_align) { 返回 "text-align" }
    如果 (id == CSS属性_opacity) { 返回 "opacity" }
    如果 (id == CSS属性_z_index) { 返回 "z-index" }
    如果 (id == CSS属性_overflow) { 返回 "overflow" }
    如果 (id == CSS属性_flex_direction) { 返回 "flex-direction" }
    如果 (id == CSS属性_justify_content) { 返回 "justify-content" }
    如果 (id == CSS属性_align_items) { 返回 "align-items" }
    如果 (id == CSS属性_gap) { 返回 "gap" }
    如果 (id == CSS属性_border_radius) { 返回 "border-radius" }
    如果 (id == CSS属性_visibility) { 返回 "visibility" }
    如果 (id == CSS属性_line_height) { 返回 "line-height" }
    如果 (id == CSS属性_transform) { 返回 "transform" }
    如果 (id == CSS属性_transition) { 返回 "transition" }
    如果 (id == CSS属性_animation) { 返回 "animation" }
    返回 "prop_" + 整数转字符串(id)
}

// §5 CSS值类型与枚举常量

定义 CSS值_关键字 = 0
定义 CSS值_长度 = 1
定义 CSS值_百分比 = 2
定义 CSS值_颜色 = 3
定义 CSS值_数字 = 4
定义 CSS值_字符串 = 5

定义 Display_none = 0
定义 Display_block = 1
定义 Display_inline = 2
定义 Display_inline_block = 3
定义 Display_flex = 4
定义 Display_grid = 5
定义 Display_table = 6
定义 Display_contents = 7

定义 Position_static = 0
定义 Position_relative = 1
定义 Position_absolute = 2
定义 Position_fixed = 3
定义 Position_sticky = 4

定义 Overflow_visible = 0
定义 Overflow_hidden = 1
定义 Overflow_scroll = 2
定义 Overflow_auto = 3

定义 TextAlign_left = 0
定义 TextAlign_center = 1
定义 TextAlign_right = 2
定义 TextAlign_justify = 3

定义 Visibility_visible = 0
定义 Visibility_hidden = 1
定义 Visibility_collapse = 2

定义 弹性Dir_row = 0
定义 弹性Dir_row_reverse = 1
定义 弹性Dir_column = 2
定义 弹性Dir_column_reverse = 3

定义 JC_flex_start = 0
定义 JC_flex_end = 1
定义 JC_center = 2
定义 JC_space_between = 3
定义 JC_space_around = 4
定义 JC_space_evenly = 5
定义 JC_stretch = 6

定义 BoxSizing_content = 0
定义 BoxSizing_border = 1

// §6 计算长度辅助

定义 单位_px = 0
定义 单位_百分比 = 1
定义 单位_em = 2
定义 单位_rem = 3
定义 单位_vw = 4
定义 单位_vh = 5

结构 计算长度 {
    值,
    是auto,
    单位,
}

函数 计算长度_px(数值) {
    定义 l = 计算长度 {}
    l.值 = 数值
    l.是auto = 假
    l.单位 = 单位_px
    返回 l
}

函数 计算长度_零() {
    定义 l = 计算长度 {}
    l.值 = 0
    l.是auto = 假
    l.单位 = 单位_px
    返回 l
}

函数 计算长度_auto() {
    定义 l = 计算长度 {}
    l.值 = 0
    l.是auto = 真
    l.单位 = 单位_px
    返回 l
}

函数 计算长度_是零(l) {
    返回 !l.是auto && l.值 == 0
}

函数 计算长度_是auto(l) {
    返回 l.是auto
}

函数 计算长度_解析为px(l, 容器大小, 字体大小) {
    如果 (l.是auto) { 返回 0 }
    如果 (l.单位 == 单位_px) { 返回 l.值 }
    如果 (l.单位 == 单位_百分比) { 返回 l.值 * 容器大小 / 10000 }
    如果 (l.单位 == 单位_em) { 返回 l.值 * 字体大小 / 100 }
    如果 (l.单位 == 单位_rem) { 返回 l.值 * 16 / 100 }
    返回 l.值
}

// §7 批量应用声明列表

函数 Computed样式_应用声明列表(style, 声明列表, 数量) {
    定义 可变 i = 0
    当 (i < 数量) {
        Computed样式_应用声明(style, 声明列表[i])
        i = i + 1
    }
}

函数 Computed样式_应用匹配结果(style, 匹配列表, 数量) {
    定义 可变 i = 0
    当 (i < 数量) {
        定义 匹配 = 匹配列表[i]
        Computed样式_应用声明列表(style, 匹配.声明, 匹配.声明数)
        i = i + 1
    }
}

// §8 样式应用统计

定义 可变 样式应用_总次数 = 0
定义 可变 样式应用_属性设置数 = 0
定义 可变 样式应用_继承数 = 0

函数 样式应用_统计() {
    返回 {
        总次数: 样式应用_总次数,
        属性设置: 样式应用_属性设置数,
        继承: 样式应用_继承数,
    }
}

函数 样式应用_健康检查() {
    返回 "样式应用子系统健康"
}

函数 样式应用_重置() {
    样式应用_总次数 = 0
    样式应用_属性设置数 = 0
    样式应用_继承数 = 0
}

函数 样式应用_完整统计() {
    返回 [样式应用_总次数, 样式应用_属性设置数, 样式应用_继承数]
}

定义 可变 AI_应用样式声_样式缓存命中 = 0

函数 AI_应用样式声_选择器复杂度(选择器长度, 组合子数) {
    如果 (组合子数 > 5) { 返回 "高复杂度" }
    如果 (组合子数 > 2) { 返回 "中复杂度" }
    返回 "低复杂度"
}

函数 AI_应用样式声_布局缓存(元素哈希) {
    AI_应用样式声_样式缓存命中 = AI_应用样式声_样式缓存命中 + 1
    返回 元素哈希
}

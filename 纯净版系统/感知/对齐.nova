// §5 对齐(justify/align)

定义 ALIGN_START     = 0
定义 ALIGN_END       = 1
定义 ALIGN_CENTER    = 2
定义 ALIGN_STRETCH   = 3
定义 ALIGN_SPACE_BETWEEN = 4
定义 ALIGN_SPACE_AROUND  = 5
定义 ALIGN_SPACE_EVENLY  = 6
定义 ALIGN_BASELINE  = 7

// justify-content / align-content: 分配轨道之间的额外空间
函数 网格_分配content对齐(轨道偏移, 轨道数, 轨道大小列表, 总大小, 容器大小, gap, 对齐方式) {
    如果 (轨道偏移 == 0 || 轨道数 == 0) { 返回 }
    定义 剩余 = 容器大小 - 总大小
    如果 (剩余 <= 0) { 剩余 = 0 }

    定义 可变 起始偏移 = 0
    定义 可变 间距 = gap

    如果 (对齐方式 == ALIGN_CENTER) {
        起始偏移 = 剩余 / 2
    } 否则 如果 (对齐方式 == ALIGN_END) {
        起始偏移 = 剩余
    } 否则 如果 (对齐方式 == ALIGN_SPACE_BETWEEN && 轨道数 > 1) {
        间距 = gap + 剩余 / (轨道数 - 1)
    } 否则 如果 (对齐方式 == ALIGN_SPACE_AROUND && 轨道数 > 0) {
        定义 每边 = 剩余 / (轨道数 * 2)
        起始偏移 = 每边
        间距 = gap + 每边 * 2
    } 否则 如果 (对齐方式 == ALIGN_SPACE_EVENLY && 轨道数 > 0) {
        定义 每空 = 剩余 / (轨道数 + 1)
        起始偏移 = 每空
        间距 = gap + 每空
    }

    // 计算每个轨道的偏移
    定义 可变 pos = 起始偏移
    定义 可变 i = 0
    当 (i < 轨道数) {
        内存_写32(轨道偏移 + i * 4, pos)
        定义 大小 = 内存_读32(轨道大小列表 + i * 4)
        pos = pos + 大小 + 间距
        i = i + 1
    }
}

// justify-items / align-items: 项目在单元格内的对齐
函数 网格_项目对齐(项目位置, 项目大小, 单元格起始, 单元格大小, 对齐方式) {
    如果 (对齐方式 == ALIGN_START) {
        返回 单元格起始
    } 否则 如果 (对齐方式 == ALIGN_END) {
        返回 单元格起始 + 单元格大小 - 项目大小
    } 否则 如果 (对齐方式 == ALIGN_CENTER) {
        返回 单元格起始 + (单元格大小 - 项目大小) / 2
    } 否则 如果 (对齐方式 == ALIGN_STRETCH) {
        // stretch: 项目大小扩展到单元格大小
        返回 单元格起始
    }
    返回 单元格起始
}

// §6 子网格 (Subgrid) — CSS 网格 Level 2

// grid-template-columns: subgrid;
// 子网格继承父网格的列(或行)轨道定义
结构 SubgridInfo {
    是子网格行,
    是子网格列,
    父网格,    // u64 父网格Container*
    // 在父网格中的范围
    父行起始,
    父行结束,
    父列起始,
    父列结束,
}

函数 Subgrid_继承轨道(子grid, 父轨道, 父轨道数, 起始, 结束) {
    如果 (子grid == 0 || 父轨道 == 0) { 返回 }
    // 子网格的轨道直接引用父网格的轨道[起始..结束]
    // 不需要重新计算大小
    // 但子网格的项目仍参与父轨道大小的计算
}

// §7 Masonry布局(实验性, 网格 Level 3提案)

// grid-template-rows: masonry;
// 列由grid-template-columns定义, 行由内容瀑布流排列

函数 网格_masonry布局(items, items数, 列轨道, 列数, gap) {
    如果 (items == 0 || 列轨道 == 0 || 列数 == 0) { 返回 }
    // 每列维护当前高度
    定义 列高度 = 堆_分配_数组(列数 * 4)
    内存_填充(列高度, 0, 列数 * 4)

    定义 可变 i = 0
    当 (i < items数) {
        // 找最矮的列
        定义 可变 最矮列 = 0
        定义 可变 最矮高 = 内存_读32(列高度)
        定义 可变 c = 1
        当 (c < 列数) {
            定义 h = 内存_读32(列高度 + c * 4)
            如果 (h < 最矮高) { 最矮列 = c; 最矮高 = h }
            c = c + 1
        }
        // 放置项目到最矮列
        定义 item = items + i * 大小of(网格Placement)
        item.列起始 = 最矮列 + 1
        item.列结束 = 最矮列 + 2
        // item.y = 最矮高
        // 更新列高度
        定义 项高 = 0    // item.height
        内存_写32(列高度 + 最矮列 * 4, 最矮高 + 项高 + gap)
        i = i + 1
    }
}

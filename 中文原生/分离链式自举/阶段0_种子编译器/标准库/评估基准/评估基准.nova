导入("../基础.nova")
导入("../算法/数学扩展.nova")
导入("../../编译器/标准前导.nova")

函数 混淆矩阵_二分类(预测, 标签, 正类) { 定义 可变 tp = 0
 定义 可变 fp = 0
 定义 可变 fn = 0
 定义 可变 tn = 0
 定义 可变 i = 0
 当 (i < 计数(预测)) { 如果 (预测[i] == 正类 且 标签[i] == 正类) { tp = tp + 1 }
 否则 如果 (预测[i] == 正类 且 标签[i] != 正类) { fp = fp + 1 }
 否则 如果 (预测[i] != 正类 且 标签[i] == 正类) { fn = fn + 1 }
 否则 { tn = tn + 1 }
 i = i + 1
 }
 返回 [tp, fp, fn, tn]
}

// 从混淆矩阵 [TP, FP, FN, TN] 计算精确率/评估基准_召回率 (×1000, 0)
函数 CM_精确率(cm) {
    如果 (cm[0] + cm[1] == 0) { 返回 0
}
 返回 cm[0] * 1000 / (cm[0] + cm[1])
}

函数 CM_召回率(cm) {
    如果 (cm[0] + cm[2] == 0) { 返回 0
}
 返回 cm[0] * 1000 / (cm[0] + cm[2])
}

函数 CM_F1分数(cm) { 定义 p = CM_精确率(cm)
 定义 r = CM_召回率(cm)
 如果 (p + r == 0) { 返回 0 }
 返回 2 * p * r / (p + r)
}

// 多分类指标
函数 多分类_准确率(预测, 标签) {
    如果 (计数(预测) == 0) { 返回 0
}
 定义 可变 i = 0
 当 (i < 计数(预测)) { 如果 (预测[i] == 标签[i]) { 正确 = 正确 + 1 }
 i = i + 1
 }
 返回 正确 * 100 / 计数(预测)
}

// 回归指标
函数 R2分数(预测, 标签) {
    定义 可变 总平方和 = 0
    定义 可变 残差平方和 = 0
    如果 (计数(标签) == 0) { 返回 0
}
 定义 可变 均值 = 折叠(标签, 0, (s, x) => s + x) / 计数(标签)
 定义 可变 i = 0
 当 (i < 计数(预测)) { 定义 可变 d1 = 预测[i] - 标签[i]
 定义 可变 d2 = 标签[i] - 均值
 残差平方和 = 残差平方和 + d1 * d1
 总平方和 = 总平方和 + d2 * d2
 i = i + 1
 }
 如果 (总平方和 == 0) { 返回 100 }
 返回 100 - 残差平方和 * 100 / 总平方和
}

// 基准测试框架
// 基准: [名哈希, 运行次数, 总耗时, 最小耗时, 最大耗时]
定义 可变 基准列表 = []

函数 评估_基准_创建(名哈希) {
 追加(基准列表, [名哈希, 0, 0x7FFFFFFF, 0])
 返回 计数(基准列表) - 1
}

函数 评估_基准_记录(索引, 耗时) {
 基准列表[索引][1] = 基准列表[索引][1] + 1
 基准列表[索引][2] = 基准列表[索引][2] + 耗时
 如果 (耗时 < 基准列表[索引][3]) { 基准列表[索引][3] = 耗时 }
 如果 (耗时 > 基准列表[索引][4]) { 基准列表[索引][4] = 耗时 }
}

函数 评估_基准_平均(索引) {
    如果 (基准列表[索引][1] == 0) { 返回 0
}
 返回 基准列表[索引][2] / 基准列表[索引][1]
}

函数 评估_基准_最小(索引) { 返回 基准列表[索引][3] }
函数 评估_基准_最大(索引) { 返回 基准列表[索引][4] }
函数 评估_基准_次数(索引) { 返回 基准列表[索引][1] }

// 吞吐量统计
函数 评估_吞吐量(处理量, 时间) {
    如果 (时间 == 0) { 返回 0
}
 返回 处理量 * 1000 / 时间
}

函数 评估_延迟百分位(延迟列表, 百分位) { 定义 已排序 = 复制列表(延迟列表)
 排序(已排序, 0)
 定义 可变 索引 = 计数(已排序) * 百分位 / 100
 如果 (索引 >= 计数(已排序)) { 索引 = 计数(已排序) - 1 }
 返回 已排序[索引]
}

// 特异性
函数 CM_特异性(cm) {
    如果 (cm[3] + cm[1] == 0) { 返回 0
}
 返回 cm[3] * 1000 / (cm[3] + cm[1])
}

// F-beta分数
函数 评估_F_beta(cm, 动量率) { 定义 p = CM_精确率(cm)
 定义 r = CM_召回率(cm)
 定义 b2 = 动量率 * 动量率
 如果 (b2 * p + r == 0) { 返回 0 }
 返回 (1 + b2) * p * r / (b2 * p + r)
}

// Matthews相关系数 (马修斯相关系数)
函数 马修斯相关系数(cm) { 定义 tp = cm[0]
 定义 fp = cm[1]
 定义 fn = cm[2]
 定义 tn = cm[3]
 定义 分子 = tp * tn - fp * fn
 定义 分母sq = (tp + fp) * (tp + fn) * (tn + fp) * (tn + fn)
 如果 (分母sq == 0) { 返回 0 }
 定义 分母 = 整数sqrt(分母sq)
 如果 (分母 == 0) { 返回 0 }
 返回 分子 * 1000 / 分母
}

// 困惑度 (困惑度)
函数 评估_困惑度(交叉熵loss) {
 // PPL ≈ 2^loss, 近似: 2^x ≈ 1 + x*693/1000 (小x)
 如果 (交叉熵loss <= 0) { 返回 1000 }
 返回 1000 + 交叉熵loss * 693 / 1000
}

// Top-K准确率
函数 TopK_准确率(预测_排序列表, 标签列表, K) {
    如果 (计数(预测_排序列表) == 0) { 返回 0
}
 定义 可变 i = 0
 当 (i < 计数(预测_排序列表)) { 定义 预测top = 预测_排序列表[i]
 定义 可变 j = 0
 定义 可变 命中 = 假
 当 (j < K 且 j < 计数(预测top)) { 如果 (预测top[j] == 标签列表[i]) { 命中 = 真 }
 j = j + 1
 }
 如果 (命中) { 正确 = 正确 + 1 }
 i = i + 1
 }
 返回 正确 * 100 / 计数(预测_排序列表)
}

// 基准对比
函数 评估_基准_对比(idx_a, idx_b) { 定义 avg_a = 评估_基准_平均(idx_a)
 定义 avg_b = 评估_基准_平均(idx_b)
 打印("基准对比:")
 打印(" A: 平均=" + 转字符串(avg_a) + " 最小=" + 转字符串(评估_基准_最小(idx_a)) + " 最大=" + 转字符串(评估_基准_最大(idx_a)))
 打印(" B: 平均=" + 转字符串(avg_b) + " 最小=" + 转字符串(评估_基准_最小(idx_b)) + " 最大=" + 转字符串(评估_基准_最大(idx_b)))
 如果 (avg_b > 0) {
 打印(" 加速比: " + 转字符串(avg_b * 100 / avg_a) + "%")
 }
}

// 混淆矩阵打印
函数 CM_打印(cm) {
 打印("混淆矩阵:")
 打印(" 预测正 预测负")
 打印(" 实际正 " + 转字符串(cm[0]) + " " + 转字符串(cm[2]))
 打印(" 实际负 " + 转字符串(cm[1]) + " " + 转字符串(cm[3]))
 打印(" 精确率=" + 转字符串(CM_精确率(cm)) + "‰ 召回率=" + 转字符串(CM_召回率(cm)) + "‰ F1=" + 转字符串(CM_F1分数(cm)) + "‰")
}

// 综合评估报告
// 基准清空
函数 基准_清空() { 基准列表 = [] }

// 精确率/召回率/F1
函数 评估基准_精确率(真正, 假正) {
    如果 (真正 + 假正 == 0) { 返回 0
}
 返回 真正 * 1000 / (真正 + 假正)
}

函数 评估基准_召回率(真正, 假负) {
    如果 (真正 + 假负 == 0) { 返回 0
}
 返回 真正 * 1000 / (真正 + 假负)
}

函数 F1分数(精确, 召回) {
    如果 (精确 + 召回 == 0) { 返回 0
}
 返回 2 * 精确 * 召回 / (精确 + 召回)
}

// 混淆矩阵
函数 混淆矩阵_计算(预测列表, 标签列表) {
 定义 可变 FP = 0
 定义 可变 TN = 0
 定义 可变 i = 0
 当 (i < 计数(预测列表)) { 如果 (预测列表[i] == 1 且 标签列表[i] == 1) { TP = TP + 1 }
 如果 (预测列表[i] == 1 且 标签列表[i] == 0) { FP = FP + 1 }
 如果 (预测列表[i] == 0 且 标签列表[i] == 1) { FN = FN + 1 }
 如果 (预测列表[i] == 0 且 标签列表[i] == 0) { TN = TN + 1 }
 i = i + 1
 }
 返回 [TP, FP, FN, TN]
}

函数 评估基准_准确率(TP, FP, FN, TN) { 定义 总 = TP + FP + FN + TN
 如果 (总 == 0) { 返回 0 }
 返回 (TP + TN) * 1000 / 总
}

// BLEU分数(简化)
函数 BLEU_单词组(预测tokens, 参考tokens) { 定义 可变 匹配 = 0
 定义 可变 i = 0
 当 (i < 计数(预测tokens)) { 定义 可变 j = 0
 当 (j < 计数(参考tokens)) { 如果 (预测tokens[i] == 参考tokens[j]) { 匹配 = 匹配 + 1 j = 计数(参考tokens) }
 j = j + 1
 }
 i = i + 1
 }
 如果 (计数(预测tokens) == 0) { 返回 0 }
 返回 匹配 * 1000 / 计数(预测tokens)
}



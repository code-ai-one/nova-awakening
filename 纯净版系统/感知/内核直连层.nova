// NovaOS 渲染引擎 — 内核直连层
// 底层原生: 渲染引擎通过此层直连内核子系统
// 提供内存管理/同步/IO/时间等内核服务的原生绑定
// 消除渲染引擎对融合层的间接依赖
// AI原生: 智能内存分配策略 + 自适应缓存 + 碎片预测

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/内存物理.nova")
导入("../中枢/同步原语.nova")
导入("../中枢/时钟中枢.nova")
导入("../推理/智能渠道.nova")
导入("../执行/平台时间.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内存系统调用.nova")
导入("../中枢/原生系统块分.nova")
导入("../执行/输入多路复.nova")
导入("../中枢/读取调用.nova")

// §1 常量定义

定义 渲染_最大堆容量 = 268435456       // 256MB
定义 渲染_池块大小_小 = 64             // 小对象池块大小
定义 渲染_池块大小_中 = 256            // 中对象池块大小
定义 渲染_池块大小_大 = 1024           // 大对象池块大小
定义 渲染_池容量_小 = 4096             // 小对象池数量
定义 渲染_池容量_中 = 1024             // 中对象池数量
定义 渲染_池容量_大 = 256              // 大对象池数量
定义 渲染_竞技场大小 = 65536           // 64KB 竞技场
定义 渲染_最大竞技场数 = 64            // 最大竞技场数
定义 渲染_碎片率阈值 = 300             // Q10 碎片率告警阈值 (~30%)
定义 渲染_文件最大大小 = 104857600     // 100MB 单文件读取上限
定义 渲染_读缓冲大小 = 8192            // 8KB 读缓冲

// §2 核心数据结构

结构 渲染内存统计 {
    堆已用字节,          // u64 当前已分配字节数
    堆峰值字节,          // u64 历史最高已分配字节
    分配总次数,
    释放总次数,
    分配失败次数,
    池命中次数,          // u64 对象池命中
    池未命中次数,        // u64 对象池未命中(回退kmalloc)
    竞技场分配次数,
    竞技场重置次数,
    内存映射次数,
    内存取消映射次数,
    文件打开次数,
    文件读取字节,
    锁竞争次数,          // u64 互斥锁获取等待次数
    AI优化调用次数,
    AI碎片整理次数,
    总分配耗时_纳秒,
    最大单次分配耗时,
}

结构 对象池 {
    块大小,              // u32 每个块的字节数
    容量,                // u32 总块数
    已用数,              // u32 已分配块数
    空闲链表头,          // u64 空闲块链表
    池内存起始,          // u64 池内存基地址
    锁,                  // u64 自旋锁
    命中计数,
    回退计数,
}

结构 竞技场分配器 {
    基地址,              // u64 竞技场内存起始
    大小,                // u64 竞技场总大小
    已用偏移,            // u64 当前分配偏移(bump指针)
    锁,                  // u64 自旋锁
    分配次数,
    重置次数,
    峰值使用,
    所属阶段,            // u32 0=布局 1=绘制 2=合成 3=通用
}

结构 AI内存状态 {
    历史分配模式,        // u64 最近N次分配大小的移动平均
    历史碎片率,          // u32 Q10
    连续大分配计数,
    连续小分配计数,
    预测下次大小,        // u64 预测的下次分配大小
    策略_优先池,         // u8  当前是否优先使用对象池
    策略_预分配,         // u8  是否启用预分配
    采样窗口计数器,
    上次优化时间,
}

// §3 全局状态

定义 可变 渲染_堆已用 = 0
定义 可变 渲染_分配次数 = 0
定义 可变 渲染_堆锁 = 0
定义 可变 渲染_统计 = 0
定义 可变 渲染_池_小 = 0
定义 可变 渲染_池_中 = 0
定义 可变 渲染_池_大 = 0
定义 可变 渲染_竞技场列表 = 0
定义 可变 渲染_竞技场数 = 0
定义 可变 渲染_AI状态 = 0
定义 可变 渲染_已初始化 = 假

// §4 初始化与生命周期

函数 渲染直连层_初始化() {
    如果 (渲染_已初始化 == 真) {
        打印("[内核直连层] 警告: 重复初始化")
        返回 错误_已存在
    }
    // 分配统计结构
    渲染_统计 = kmalloc(144)
    如果 (渲染_统计 == 空) {
        打印("[内核直连层] 错误: 统计结构分配失败")
        返回 错误_内存不足
    }
    内存_置零(渲染_统计, 144)
    // 初始化堆锁
    渲染_堆锁 = 自旋锁_创建()
    // 初始化对象池
    渲染_池_小 = 内核直连层_创建池(渲染_池块大小_小, 渲染_池容量_小)
    渲染_池_中 = 内核直连层_创建池(渲染_池块大小_中, 渲染_池容量_中)
    渲染_池_大 = 内核直连层_创建池(渲染_池块大小_大, 渲染_池容量_大)
    // 初始化竞技场列表
    渲染_竞技场列表 = kmalloc(渲染_最大竞技场数 * 8)
    如果 (渲染_竞技场列表 != 空) {
        内存_置零(渲染_竞技场列表, 渲染_最大竞技场数 * 8)
    }
    渲染_竞技场数 = 0
    // 初始化AI状态
    渲染_AI状态 = kmalloc(72)
    如果 (渲染_AI状态 != 空) {
        内存_置零(渲染_AI状态, 72)
        渲染_AI状态.策略_优先池 = 真
        渲染_AI状态.策略_预分配 = 假
    }
    渲染_已初始化 = 真
    打印("[内核直连层] 初始化完成: 堆+池+竞技场+AI就绪")
    返回 0
}

函数 渲染直连层_销毁() {
    如果 (渲染_已初始化 == 假) { 返回 0 }
    // 销毁竞技场
    定义 可变 i = 0
    当 (i < 渲染_竞技场数) {
        定义 竞技场 = 内存_读64(渲染_竞技场列表 + i * 8)
        如果 (竞技场 != 空) {
            如果 (竞技场.基地址 != 空) { kfree(竞技场.基地址) }
            kfree(竞技场)
        }
        i = i + 1
    }
    如果 (渲染_竞技场列表 != 空) { kfree(渲染_竞技场列表) }
    // 销毁对象池
    内核直连层_销毁池(渲染_池_小)
    内核直连层_销毁池(渲染_池_中)
    内核直连层_销毁池(渲染_池_大)
    // 销毁AI状态和统计
    如果 (渲染_AI状态 != 空) { kfree(渲染_AI状态) }
    如果 (渲染_统计 != 空) { kfree(渲染_统计) }
    渲染_已初始化 = 假
    打印("[内核直连层] 已销毁")
    返回 0
}

函数 渲染直连层_重置统计() {
    如果 (渲染_统计 == 空) { 返回 错误_未初始化 }
    // 保留堆已用和峰值，其余归零
    定义 保留已用 = 渲染_统计.堆已用字节
    定义 保留峰值 = 渲染_统计.堆峰值字节
    内存_置零(渲染_统计, 144)
    渲染_统计.堆已用字节 = 保留已用
    渲染_统计.堆峰值字节 = 保留峰值
    打印("[内核直连层] 统计已重置(保留堆水位)")
    返回 0
}

// §5 渲染引擎内存管理 — 直连内核kmalloc

函数 渲染_堆_分配(大小) {
    如果 (大小 == 0) { 返回 空 }
    如果 (大小 > 渲染_最大堆容量) {
        打印("[内核直连层] 错误: 分配请求超过最大堆容量")
        如果 (渲染_统计 != 空) {
            渲染_统计.分配失败次数 = 渲染_统计.分配失败次数 + 1
        }
        返回 空
    }
    定义 开始时间 = 平台_获取高精度时间()
    // AI策略: 尝试对象池
    如果 (渲染_AI状态 != 空 && 渲染_AI状态.策略_优先池 == 真) {
        定义 池结果 = 内核直连层_池分配(大小)
        如果 (池结果 != 空) {
            如果 (渲染_统计 != 空) {
                渲染_统计.池命中次数 = 渲染_统计.池命中次数 + 1
                定义 耗时 = 平台_获取高精度时间() - 开始时间
                渲染_统计.总分配耗时_纳秒 = 渲染_统计.总分配耗时_纳秒 + 耗时
            }
            返回 池结果
        }
        如果 (渲染_统计 != 空) {
            渲染_统计.池未命中次数 = 渲染_统计.池未命中次数 + 1
        }
    }
    // 回退到内核kmalloc
    自旋锁_获取(渲染_堆锁)
    定义 ptr = kmalloc(大小)
    如果 (ptr != 空) {
        渲染_堆已用 = 渲染_堆已用 + 大小
        渲染_分配次数 = 渲染_分配次数 + 1
        如果 (渲染_统计 != 空) {
            渲染_统计.堆已用字节 = 渲染_堆已用
            渲染_统计.分配总次数 = 渲染_统计.分配总次数 + 1
            如果 (渲染_堆已用 > 渲染_统计.堆峰值字节) {
                渲染_统计.堆峰值字节 = 渲染_堆已用
            }
        }
    } 否则 {
        如果 (渲染_统计 != 空) {
            渲染_统计.分配失败次数 = 渲染_统计.分配失败次数 + 1
        }
        打印("[内核直连层] 警告: kmalloc失败")
    }
    自旋锁_释放(渲染_堆锁)
    // AI反馈
    如果 (渲染_AI状态 != 空) {
        AI内存_记录分配(大小)
    }
    如果 (渲染_统计 != 空) {
        定义 耗时 = 平台_获取高精度时间() - 开始时间
        渲染_统计.总分配耗时_纳秒 = 渲染_统计.总分配耗时_纳秒 + 耗时
        如果 (耗时 > 渲染_统计.最大单次分配耗时) {
            渲染_统计.最大单次分配耗时 = 耗时
        }
    }
    返回 ptr
}

函数 渲染_堆_释放(ptr) {
    如果 (ptr == 空) { 返回 }
    // 检查是否属于对象池
    如果 (内核直连层_池释放(ptr) == 真) { 返回 }
    // 内核释放
    自旋锁_获取(渲染_堆锁)
    kfree(ptr)
    渲染_分配次数 = 渲染_分配次数 - 1
    如果 (渲染_统计 != 空) {
        渲染_统计.释放总次数 = 渲染_统计.释放总次数 + 1
    }
    自旋锁_释放(渲染_堆锁)
}

函数 堆_分配_清零(大小) {
    定义 ptr = 堆_分配(大小)
    如果 (ptr != 空) { 内存_置零(ptr, 大小) }
    返回 ptr
}

函数 堆_分配_数组(字节数) {
    如果 (字节数 <= 0) { 返回 空 }
    返回 堆_分配_清零(字节数)
}

函数 堆_重新分配(旧指针, 旧大小, 新大小) {
    如果 (旧指针 == 空) { 返回 堆_分配(新大小) }
    如果 (新大小 == 0) { 堆_释放(旧指针); 返回 空 }
    如果 (新大小 <= 旧大小) { 返回 旧指针 }
    定义 新指针 = 堆_分配(新大小)
    如果 (新指针 == 空) { 返回 空 }
    内存_复制(新指针, 旧指针, 旧大小)
    堆_释放(旧指针)
    返回 新指针
}

// §6 对象池分配器 — 高频小对象快速分配

函数 内核直连层_创建池(块大小, 容量) {
    如果 (块大小 == 0 || 容量 == 0) { 返回 空 }
    定义 池 = kmalloc(64)
    如果 (池 == 空) { 返回 空 }
    池.块大小 = 块大小
    池.容量 = 容量
    池.已用数 = 0
    池.命中计数 = 0
    池.回退计数 = 0
    池.锁 = 自旋锁_创建()
    // 分配池内存
    定义 总大小 = 块大小 * 容量
    池.池内存起始 = kmalloc(总大小)
    如果 (池.池内存起始 == 空) {
        kfree(池)
        返回 空
    }
    内存_置零(池.池内存起始, 总大小)
    // 构建空闲链表: 每个块的前8字节存放下一个空闲块指针
    定义 可变 i = 0
    当 (i < 容量 - 1) {
        定义 当前块 = 池.池内存起始 + i * 块大小
        定义 下一块 = 池.池内存起始 + (i + 1) * 块大小
        内存_写64(当前块, 下一块)
        i = i + 1
    }
    // 最后一个块指向空
    内存_写64(池.池内存起始 + (容量 - 1) * 块大小, 0)
    池.空闲链表头 = 池.池内存起始
    返回 池
}

函数 内核直连层_销毁池(池) {
    如果 (池 == 空) { 返回 }
    如果 (池.池内存起始 != 空) { kfree(池.池内存起始) }
    kfree(池)
}

函数 内核直连层_池分配(大小) {
    // 选择合适的池
    定义 可变 目标池 = 空
    如果 (大小 <= 渲染_池块大小_小) { 目标池 = 渲染_池_小 }
    否则 如果 (大小 <= 渲染_池块大小_中) { 目标池 = 渲染_池_中 }
    否则 如果 (大小 <= 渲染_池块大小_大) { 目标池 = 渲染_池_大 }
    否则 { 返回 空 }
    如果 (目标池 == 空) { 返回 空 }
    自旋锁_获取(目标池.锁)
    如果 (目标池.空闲链表头 == 0) {
        自旋锁_释放(目标池.锁)
        目标池.回退计数 = 目标池.回退计数 + 1
        返回 空
    }
    定义 块 = 目标池.空闲链表头
    目标池.空闲链表头 = 内存_读64(块)
    目标池.已用数 = 目标池.已用数 + 1
    目标池.命中计数 = 目标池.命中计数 + 1
    自旋锁_释放(目标池.锁)
    内存_置零(块, 目标池.块大小)
    返回 块
}

函数 内核直连层_池释放(ptr) {
    如果 (ptr == 空) { 返回 假 }
    // 检查是否落在某个池的内存范围内
    如果 (渲染_池_小 != 空) {
        定义 池 = 渲染_池_小
        如果 (ptr >= 池.池内存起始 && ptr < 池.池内存起始 + 池.块大小 * 池.容量) {
            自旋锁_获取(池.锁)
            内存_写64(ptr, 池.空闲链表头)
            池.空闲链表头 = ptr
            池.已用数 = 池.已用数 - 1
            自旋锁_释放(池.锁)
            返回 真
        }
    }
    如果 (渲染_池_中 != 空) {
        定义 池 = 渲染_池_中
        如果 (ptr >= 池.池内存起始 && ptr < 池.池内存起始 + 池.块大小 * 池.容量) {
            自旋锁_获取(池.锁)
            内存_写64(ptr, 池.空闲链表头)
            池.空闲链表头 = ptr
            池.已用数 = 池.已用数 - 1
            自旋锁_释放(池.锁)
            返回 真
        }
    }
    如果 (渲染_池_大 != 空) {
        定义 池 = 渲染_池_大
        如果 (ptr >= 池.池内存起始 && ptr < 池.池内存起始 + 池.块大小 * 池.容量) {
            自旋锁_获取(池.锁)
            内存_写64(ptr, 池.空闲链表头)
            池.空闲链表头 = ptr
            池.已用数 = 池.已用数 - 1
            自旋锁_释放(池.锁)
            返回 真
        }
    }
    返回 假
}

// §7 竞技场分配器 — 帧级批量分配/一次性释放

函数 渲染_竞技场_创建(阶段) {
    如果 (渲染_竞技场数 >= 渲染_最大竞技场数) {
        打印("[内核直连层] 错误: 竞技场数量超限")
        返回 空
    }
    定义 竞技场 = kmalloc(64)
    如果 (竞技场 == 空) { 返回 空 }
    竞技场.大小 = 渲染_竞技场大小
    竞技场.基地址 = kmalloc(渲染_竞技场大小)
    如果 (竞技场.基地址 == 空) {
        kfree(竞技场)
        返回 空
    }
    内存_置零(竞技场.基地址, 渲染_竞技场大小)
    竞技场.已用偏移 = 0
    竞技场.锁 = 自旋锁_创建()
    竞技场.分配次数 = 0
    竞技场.重置次数 = 0
    竞技场.峰值使用 = 0
    竞技场.所属阶段 = 阶段
    如果 (渲染_竞技场列表 != 空) {
        内存_写64(渲染_竞技场列表 + 渲染_竞技场数 * 8, 竞技场)
        渲染_竞技场数 = 渲染_竞技场数 + 1
    }
    返回 竞技场
}

函数 渲染_竞技场_分配(竞技场, 大小) {
    如果 (竞技场 == 空 || 大小 == 0) { 返回 空 }
    // 8字节对齐
    定义 对齐大小 = (大小 + 7) & (~7)
    自旋锁_获取(竞技场.锁)
    如果 (竞技场.已用偏移 + 对齐大小 > 竞技场.大小) {
        自旋锁_释放(竞技场.锁)
        返回 空
    }
    定义 ptr = 竞技场.基地址 + 竞技场.已用偏移
    竞技场.已用偏移 = 竞技场.已用偏移 + 对齐大小
    竞技场.分配次数 = 竞技场.分配次数 + 1
    如果 (竞技场.已用偏移 > 竞技场.峰值使用) {
        竞技场.峰值使用 = 竞技场.已用偏移
    }
    自旋锁_释放(竞技场.锁)
    如果 (渲染_统计 != 空) {
        渲染_统计.竞技场分配次数 = 渲染_统计.竞技场分配次数 + 1
    }
    返回 ptr
}

函数 渲染_竞技场_重置(竞技场) {
    如果 (竞技场 == 空) { 返回 错误_无效参数 }
    自旋锁_获取(竞技场.锁)
    竞技场.已用偏移 = 0
    竞技场.重置次数 = 竞技场.重置次数 + 1
    自旋锁_释放(竞技场.锁)
    如果 (渲染_统计 != 空) {
        渲染_统计.竞技场重置次数 = 渲染_统计.竞技场重置次数 + 1
    }
    返回 0
}

// §8 原生内存操作 — 字节级读写

函数 内存_读8(地址) {
    汇编 { "movzx eax, byte [rdi]" }
}

函数 内存_写8(地址, 值) {
    汇编 { "mov byte [rdi], sil" }
}

函数 内存_读16(地址) {
    汇编 { "movzx eax, word [rdi]" }
}

函数 内存_写16(地址, 值) {
    汇编 { "mov word [rdi], si" }
}

函数 内存_读32(地址) {
    汇编 { "mov eax, [rdi]" }
}

函数 内存_写32(地址, 值) {
    汇编 { "mov [rdi], esi" }
}

函数 内存_读64(地址) {
    汇编 { "mov rax, [rdi]" }
}

函数 内存_写64(地址, 值) {
    汇编 { "mov [rdi], rsi" }
}

函数 内存_置零(地址, 字节数) {
    如果 (地址 == 空 || 字节数 <= 0) { 返回 }
    // 先按8字节批量清零
    定义 整块数 = 字节数 / 8
    定义 可变 i = 0
    当 (i < 整块数) {
        内存_写64(地址 + i * 8, 0)
        i = i + 1
    }
    // 处理剩余字节
    定义 可变 j = 整块数 * 8
    当 (j < 字节数) {
        内存_写8(地址 + j, 0)
        j = j + 1
    }
}

函数 内存_复制(目标, 源, 字节数) {
    如果 (目标 == 空 || 源 == 空 || 字节数 <= 0) { 返回 }
    // 先按8字节批量复制
    定义 整块数 = 字节数 / 8
    定义 可变 i = 0
    当 (i < 整块数) {
        内存_写64(目标 + i * 8, 内存_读64(源 + i * 8))
        i = i + 1
    }
    // 处理剩余字节
    定义 可变 j = 整块数 * 8
    当 (j < 字节数) {
        内存_写8(目标 + j, 内存_读8(源 + j))
        j = j + 1
    }
}

函数 内存_比较(地址1, 地址2, 字节数) {
    如果 (地址1 == 空 || 地址2 == 空) { 返回 -1 }
    定义 可变 i = 0
    当 (i < 字节数) {
        定义 a = 内存_读8(地址1 + i)
        定义 b = 内存_读8(地址2 + i)
        如果 (a != b) { 返回 a - b }
        i = i + 1
    }
    返回 0
}

函数 内存_填充(地址, 字节值, 字节数) {
    如果 (地址 == 空 || 字节数 <= 0) { 返回 }
    定义 可变 i = 0
    当 (i < 字节数) {
        内存_写8(地址 + i, 字节值)
        i = i + 1
    }
}

// §9 同步原语 — 直连内核(增强版)

函数 渲染_互斥锁创建() { 返回 互斥锁_创建() }

函数 渲染_互斥锁获取(锁) {
    如果 (锁 == 空) { 返回 }
    互斥锁_获取(锁)
    如果 (渲染_统计 != 空) {
        渲染_统计.锁竞争次数 = 渲染_统计.锁竞争次数 + 1
    }
}

函数 渲染_互斥锁释放(锁) {
    如果 (锁 == 空) { 返回 }
    互斥锁_释放(锁)
}

函数 渲染_自旋锁创建() { 返回 自旋锁_创建() }
函数 渲染_自旋锁获取(锁) { 自旋锁_获取(锁) }
函数 渲染_自旋锁释放(锁) { 自旋锁_释放(锁) }

// §10 系统调用 — 文件/网络/进程(增强版)

函数 渲染_文件打开(路径, 标志) {
    如果 (路径 == 空) { 返回 -1 }
    定义 fd = sys_open(路径, 标志, 0)
    如果 (fd >= 0 && 渲染_统计 != 空) {
        渲染_统计.文件打开次数 = 渲染_统计.文件打开次数 + 1
    }
    返回 fd
}

函数 渲染_文件读取(fd, buf, 大小) {
    如果 (fd < 0 || buf == 空 || 大小 <= 0) { 返回 -1 }
    如果 (大小 > 渲染_文件最大大小) {
        打印("[内核直连层] 警告: 文件读取超过上限，截断")
        大小 = 渲染_文件最大大小
    }
    定义 已读 = sys_read(fd, buf, 大小)
    如果 (已读 > 0 && 渲染_统计 != 空) {
        渲染_统计.文件读取字节 = 渲染_统计.文件读取字节 + 已读
    }
    返回 已读
}

函数 渲染_文件写入(fd, buf, 大小) {
    如果 (fd < 0 || buf == 空 || 大小 <= 0) { 返回 -1 }
    返回 sys_write(fd, buf, 大小)
}

函数 渲染_文件关闭(fd) {
    如果 (fd < 0) { 返回 -1 }
    返回 sys_close(fd)
}

函数 渲染_文件全部读取(路径) {
    如果 (路径 == 空) { 返回 空 }
    定义 fd = 渲染_文件打开(路径, 0)
    如果 (fd < 0) { 返回 空 }
    // 分块读取
    定义 可变 总大小 = 0
    定义 buf = 堆_分配(渲染_读缓冲大小)
    如果 (buf == 空) { 渲染_文件关闭(fd); 返回 空 }
    定义 可变 结果 = 堆_分配(渲染_读缓冲大小)
    定义 可变 结果容量 = 渲染_读缓冲大小
    如果 (结果 == 空) { 堆_释放(buf); 渲染_文件关闭(fd); 返回 空 }
    定义 可变 继续读取 = 真
    当 (继续读取 == 真) {
        定义 已读 = 渲染_文件读取(fd, buf, 渲染_读缓冲大小)
        如果 (已读 <= 0) { 继续读取 = 假 }
        否则 {
            如果 (总大小 + 已读 > 结果容量) {
                定义 新容量 = 结果容量 * 2
                结果 = 堆_重新分配(结果, 结果容量, 新容量)
                如果 (结果 == 空) { 继续读取 = 假 }
                否则 { 结果容量 = 新容量 }
            }
            如果 (结果 != 空) {
                内存_复制(结果 + 总大小, buf, 已读)
                总大小 = 总大小 + 已读
            }
        }
    }
    堆_释放(buf)
    渲染_文件关闭(fd)
    返回 结果
}

函数 渲染_内存映射(大小) {
    如果 (大小 <= 0) { 返回 空 }
    定义 结果 = sys_Nova内存映射(0, 大小, 3, 0x22, -1, 0)
    如果 (结果 != 空 && 渲染_统计 != 空) {
        渲染_统计.内存映射次数 = 渲染_统计.内存映射次数 + 1
    }
    返回 结果
}

函数 渲染_内存取消映射(地址, 大小) {
    如果 (地址 == 空 || 大小 <= 0) { 返回 -1 }
    定义 结果 = sys_munmap(地址, 大小)
    如果 (渲染_统计 != 空) {
        渲染_统计.内存取消映射次数 = 渲染_统计.内存取消映射次数 + 1
    }
    返回 结果
}

// §11 高精度时间 — 直连内核时间子系统

函数 平台_获取单调时间毫秒() {
    返回 平台_获取纳秒时间() / 1000000
}

函数 平台_获取单调时间秒() {
    返回 平台_获取纳秒时间() / 1000000000
}

函数 平台_计时开始() {
    返回 平台_获取高精度时间()
}

函数 平台_计时结束(开始) {
    定义 结束 = 平台_获取高精度时间()
    如果 (结束 > 开始) { 返回 结束 - 开始 }
    返回 0
}

// §12 智能内存分配优化
// 能力: 自适应 + 预测 + 碎片整理
// 四阶段: 数据采集→特征提取→决策→执行

函数 AI内存_记录分配(大小) {
    如果 (渲染_AI状态 == 空) { 返回 }
    定义 状态 = 渲染_AI状态
    状态.采样窗口计数器 = 状态.采样窗口计数器 + 1

    // 指数移动平均更新分配模式
    状态.历史分配模式 = (状态.历史分配模式 * 7 + 大小) / 8
    如果 (大小 > 渲染_池块大小_大) {
        状态.连续大分配计数 = 状态.连续大分配计数 + 1
        状态.连续小分配计数 = 0
    } 否则 {
        状态.连续小分配计数 = 状态.连续小分配计数 + 1
        状态.连续大分配计数 = 0
    }

    定义 可变 碎片率 = 0
    如果 (渲染_堆已用 > 0 && 渲染_分配次数 > 0) {
        // 碎片率估算: 分配次数/已用内存比(归一化到Q10)
        碎片率 = 渲染_分配次数 * 1024 / (渲染_堆已用 / 1024 + 1)
    }
    状态.历史碎片率 = (状态.历史碎片率 * 15 + 碎片率) / 16

    // 每256次分配做一次策略决策
    如果 (状态.采样窗口计数器 < 256) { 返回 }
    状态.采样窗口计数器 = 0

    如果 (渲染_统计 != 空) {
        渲染_统计.AI优化调用次数 = 渲染_统计.AI优化调用次数 + 1
    }

    // 决策A: 池优先策略切换
    如果 (状态.连续小分配计数 > 100) {
        状态.策略_优先池 = 真
    }
    如果 (状态.连续大分配计数 > 20) {
        状态.策略_优先池 = 假
    }

    // 决策B: 碎片率过高 → 触发整理建议
    如果 (状态.历史碎片率 > 渲染_碎片率阈值) {
        打印("[AI内存] 碎片率过高，建议整理")
        如果 (渲染_统计 != 空) {
            渲染_统计.AI碎片整理次数 = 渲染_统计.AI碎片整理次数 + 1
        }
    }

    // 决策C: 预测下次分配大小
    状态.预测下次大小 = 状态.历史分配模式

    如果 (状态.策略_预分配 == 真 && 状态.预测下次大小 > 0) {
        // 可在此预分配缓冲区以减少后续延迟
        // 当前为建议模式，不自动执行
    }
    状态.上次优化时间 = 平台_获取高精度时间()
}

// §13 统计输出与诊断

函数 渲染直连层_打印统计() {
    如果 (渲染_统计 == 空) {
        打印("[内核直连层] 统计未初始化")
        返回
    }
    打印("┌──────────────────────────────────────┐")
    打印("│   内核直连层 · 统计报告             │")
    打印("├──────────────────────────────────────┤")
    打印(字符串拼接("│ 堆已用(KB):       ", 转字符串(渲染_统计.堆已用字节 / 1024)))
    打印(字符串拼接("│ 堆峰值(KB):       ", 转字符串(渲染_统计.堆峰值字节 / 1024)))
    打印(字符串拼接("│ 分配总次数:       ", 转字符串(渲染_统计.分配总次数)))
    打印(字符串拼接("│ 释放总次数:       ", 转字符串(渲染_统计.释放总次数)))
    打印(字符串拼接("│ 分配失败:         ", 转字符串(渲染_统计.分配失败次数)))
    打印(字符串拼接("│ 池命中:           ", 转字符串(渲染_统计.池命中次数)))
    打印(字符串拼接("│ 池未命中:         ", 转字符串(渲染_统计.池未命中次数)))
    打印(字符串拼接("│ 竞技场分配:       ", 转字符串(渲染_统计.竞技场分配次数)))
    打印(字符串拼接("│ 竞技场重置:       ", 转字符串(渲染_统计.竞技场重置次数)))
    打印(字符串拼接("│ 内存映射:         ", 转字符串(渲染_统计.内存映射次数)))
    打印(字符串拼接("│ 文件打开:         ", 转字符串(渲染_统计.文件打开次数)))
    打印(字符串拼接("│ 文件读取(KB):     ", 转字符串(渲染_统计.文件读取字节 / 1024)))
    打印(字符串拼接("│ 锁竞争:           ", 转字符串(渲染_统计.锁竞争次数)))
    打印(字符串拼接("│ AI优化调用:       ", 转字符串(渲染_统计.AI优化调用次数)))
    打印(字符串拼接("│ AI碎片整理:       ", 转字符串(渲染_统计.AI碎片整理次数)))
    打印(字符串拼接("│ 总分配耗时(μs):   ", 转字符串(渲染_统计.总分配耗时_纳秒 / 1000)))
    打印(字符串拼接("│ 最大单次耗时(μs): ", 转字符串(渲染_统计.最大单次分配耗时 / 1000)))
    打印("└──────────────────────────────────────┘")
    // 池统计
    如果 (渲染_池_小 != 空) {
        打印(字符串拼接("  池(64B):  已用=", 字符串拼接(转字符串(渲染_池_小.已用数), 字符串拼接("/", 转字符串(渲染_池_小.容量)))))
    }
    如果 (渲染_池_中 != 空) {
        打印(字符串拼接("  池(256B): 已用=", 字符串拼接(转字符串(渲染_池_中.已用数), 字符串拼接("/", 转字符串(渲染_池_中.容量)))))
    }
    如果 (渲染_池_大 != 空) {
        打印(字符串拼接("  池(1KB):  已用=", 字符串拼接(转字符串(渲染_池_大.已用数), 字符串拼接("/", 转字符串(渲染_池_大.容量)))))
    }
}

函数 渲染直连层_导出诊断() {
    如果 (渲染_统计 == 空) {
        打印("[内核直连层] 诊断: 未初始化")
        返回
    }
    打印("[内核直连层] === 诊断信息 ===")
    打印(字符串拼接("  已初始化: ", 转字符串(渲染_已初始化)))
    打印(字符串拼接("  活跃分配数: ", 转字符串(渲染_分配次数)))
    打印(字符串拼接("  竞技场数: ", 转字符串(渲染_竞技场数)))
    // AI诊断
    如果 (渲染_AI状态 != 空) {
        定义 状态 = 渲染_AI状态
        打印(字符串拼接("  AI历史分配模式: ", 转字符串(状态.历史分配模式)))
        打印(字符串拼接("  AI碎片率(Q10): ", 转字符串(状态.历史碎片率)))
        打印(字符串拼接("  AI策略_优先池: ", 转字符串(状态.策略_优先池)))
        打印(字符串拼接("  AI预测下次大小: ", 转字符串(状态.预测下次大小)))
    }
    // 竞技场诊断
    定义 可变 i = 0
    当 (i < 渲染_竞技场数) {
        定义 竞技场 = 内存_读64(渲染_竞技场列表 + i * 8)
        如果 (竞技场 != 空) {
            打印(字符串拼接("  竞技场[", 字符串拼接(转字符串(i), 字符串拼接("] 已用=", 字符串拼接(转字符串(竞技场.已用偏移), 字符串拼接("/", 字符串拼接(转字符串(竞技场.大小), 字符串拼接(" 峰值=", 转字符串(竞技场.峰值使用)))))))))
        }
        i = i + 1
    }
}

// §14 对外接口 — 供渲染引擎所有子系统调用

函数 渲染_获取统计() {
    返回 渲染_统计
}

函数 渲染_堆统计() {
    返回 渲染_堆已用
}

函数 渲染_获取AI状态() {
    返回 渲染_AI状态
}

函数 渲染_检查健康() {
    如果 (渲染_已初始化 == 假) { 返回 错误_未初始化 }
    如果 (渲染_统计 == 空) { 返回 错误_未初始化 }
    如果 (渲染_堆已用 > 渲染_最大堆容量 * 9 / 10) {
        打印("[内核直连层] 警告: 堆使用率超过90%")
        返回 错误_容量不足
    }
    返回 0
}

函数 内核直连层_统计() {
    返回 {
        渲染分配次数: 渲染_分配次数,
        渲染已初始化: 渲染_已初始化
    }
}

函数 内核直连层_健康评估() {
    定义 可变 问题 = []
    如果 (渲染_分配次数 > 100000) { 追加(问题, "渲染_分配次数异常增长") }
    如果 (渲染_已初始化 == 假) { 追加(问题, "渲染_已初始化未就绪") }
    返回 计数(问题) == 0
}

函数 内核直连层_综合报告() {
    打印("[内核直连层] ═══ 综合报告 ═══")
    打印("  渲染_分配次数: " + 渲染_分配次数)
    打印("  渲染_已初始化: " + 渲染_已初始化)
    打印("  健康: " + 如果 (内核直连层_健康评估()) { "正常" } 否则 { "异常" })
}

函数 内核直连层_全局重置() {
    渲染_分配次数 = 0
    渲染_已初始化 = 0
    打印("[内核直连层] 统计已重置")
    返回 0
}

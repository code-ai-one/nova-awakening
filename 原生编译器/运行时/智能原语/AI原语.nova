// Nova 原生智能原语 — 非Transformer非暴力计算·类人脑设计
// 职责: 神经元/突触/脉冲传播/赫布学习/稀疏激活/局部连接
// 层级: 第1层基础设施 — 直击底层整数ALU的生物启发计算
// 理论: 脉冲神经网络(SNN) + 赫布学习(Hebbian) + 稀疏编码 + 局部计算
//        非暴力 = 不依赖海量矩阵乘法，用事件驱动替代全连接前馈
//        类人脑 = 神经元有膜电位/阈值/不应期，突触有权重/延迟/可塑性

// 神经元状态 (类人脑: 漏积分-发放模型 LIF)
// [膜电位, 阈值, 衰减率, 不应期剩余, 发放次数, 最后发放时间]

导入("../../标准库/基础.nova")

定义 神经元_静息电位 = 0
定义 神经元_默认阈值 = 8000      // 0-1动态精度: 0.8
定义 神经元_默认衰减 = 9500      // 每步衰减到95%
定义 神经元_不应期长 = 3          // 发放后3步不响应

函数 神经元_创建(阈值) {
    返回 [神经元_静息电位, 阈值, 神经元_默认衰减, 0, -100]
}

函数 神经元_创建默认() {
    返回 神经元_创建(神经元_默认阈值)
}

// 神经元更新: 接收输入电流 → 膜电位积累 → 阈值判断 → 发放/衰减
函数 神经元_更新(神经元, 输入电流, 当前时间) {
    // 不应期: 刚发放过，不响应
    如果 (神经元[3] > 0) {
        神经元[3] = 神经元[3] - 1
        神经元[0] = 神经元_静息电位
        返回 0
    }
    // 漏积分: 膜电位衰减 + 输入累加
    神经元[0] = 神经元[0] * 神经元[2] / 10000 + 输入电流
    // 阈值判断: 膜电位超过阈值 → 发放脉冲
    如果 (神经元[0] >= 神经元[1]) {
        神经元[0] = 神经元_静息电位      // 重置
        神经元[3] = 神经元_不应期长       // 进入不应期
        神经元[4] = 神经元[4] + 1         // 发放计数
        神经元[5] = 当前时间               // 记录发放时间
        返回 10000                           // 输出脉冲(1.0)
    }
    返回 0                                   // 未发放
}

// 突触 (类人脑: 权重+延迟+可塑性)
// [源神经元ID, 目标神经元ID, 权重, 延迟, 类型]
// 类型: 0=兴奋性, 1=抑制性
定义 突触_兴奋 = 0
定义 突触_抑制 = 1

函数 智能原语_突触_创建(源, 目标, 权重, 延迟, 类型) {
    返回 [源, 目标, 权重, 延迟, 类型]
}

函数 智能原语_突触_传递(突触, 脉冲) {
    如果 (脉冲 == 0) { 返回 0 }
    定义 信号 = 脉冲 * 突触[2] / 10000
    如果 (突触[4] == 突触_抑制) { 返回 0 - 信号 }
    返回 信号
}

// 赫布学习 (非暴力: 事件驱动，只更新活跃突触)
// "一起发放的神经元连在一起" — Hebb规则
// STDP: 时序依赖的突触可塑性
函数 赫布_STDP(突触, 前发放时间, 后发放时间, 学习率) {
    定义 时间差 = 后发放时间 - 前发放时间
    定义 可变 权重变化 = 0
    如果 (时间差 > 0) {
        // 前→后(因果): 增强突触 (长时程增强 LTP)
        权重变化 = 学习率 * 10000 / (10000 + 时间差 * 1000)
    } 否则 如果 (时间差 < 0) {
        // 后→前(反因果): 削弱突触 (长时程抑制 LTD)
        定义 绝对差 = 0 - 时间差
        权重变化 = 0 - 学习率 * 10000 / (10000 + 绝对差 * 1000)
    }
    突触[2] = 突触[2] + 权重变化
    // 权重钳位: 不允许负权重(兴奋性)或正权重(抑制性)
    如果 (突触[4] == 突触_兴奋 且 突触[2] < 0) { 突触[2] = 0 }
    如果 (突触[4] == 突触_抑制 且 突触[2] > 0) { 突触[2] = 0 }
    返回 权重变化
}

// 脉冲神经网络 (SNN: 事件驱动，非暴力计算)
// [神经元列表, 突触列表, 当前时间步, 脉冲队列]
函数 SNN_创建(神经元数) {
    定义 可变 神经元列表 = []
    定义 可变 i = 0
    当 (i < 神经元数) {
        追加(神经元列表, 神经元_创建默认())
        i = i + 1
    }
    返回 [神经元列表, [], 0, []]
}

函数 SNN_添加突触(网络, 源, 目标, 权重, 延迟, 类型) {
    追加(网络[1], 智能原语_突触_创建(源, 目标, 权重, 延迟, 类型))
}

// 单步仿真: 只处理活跃脉冲(事件驱动，非暴力)
函数 智能原语_SNN_步进(网络, 外部输入) {
    定义 可变 新队列 = []
    定义 可变 脉冲输出 = []
    定义 时间 = 网络[2]
    定义 可变 i = 0
    // 1. 收集每个神经元的输入电流
    定义 可变 输入 = []
    当 (i < 计数(网络[0])) { 追加(输入, 0)  i = i + 1 }
    // 外部输入
    i = 0
    当 (i < 计数(外部输入) 且 i < 计数(输入)) {
        输入[i] = 输入[i] + 外部输入[i]
        i = i + 1
    }
    // 处理脉冲队列中到达的脉冲
    i = 0
    当 (i < 计数(网络[3])) {
        定义 事件 = 网络[3][i]
        如果 (事件[0] <= 时间) {
            // 到达: 目标神经元接收电流
            如果 (事件[1] >= 0 且 事件[1] < 计数(输入)) {
                输入[事件[1]] = 输入[事件[1]] + 事件[2]
            }
        } 否则 {
            追加(新队列, 事件)
        }
        i = i + 1
    }
    网络[3] = 新队列
    // 2. 更新每个神经元
    i = 0
    当 (i < 计数(网络[0])) {
        定义 脉冲 = 神经元_更新(网络[0][i], 输入[i], 时间)
        如果 (脉冲 > 0) {
            追加(脉冲输出, i)
            // 3. 发放的脉冲通过突触传播(事件驱动)
            定义 可变 j = 0
            当 (j < 计数(网络[1])) {
                定义 突 = 网络[1][j]
                如果 (突[0] == i) {
                    定义 信号 = 智能原语_突触_传递(突, 脉冲)
                    // 加入延迟队列
                    追加(网络[3], [时间 + 突[3], 突[1], 信号])
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    网络[2] = 时间 + 1
    返回 脉冲输出
}

// 稀疏编码 (类人脑: 只有少数神经元活跃)
函数 稀疏_编码(输入向量, 字典矩阵, 稀疏度) {
    // 选择激活最强的前k个神经元(k=稀疏度)
    定义 可变 激活值 = []
    定义 可变 i = 0
    当 (i < 计数(字典矩阵)) {
        定义 可变 点积 = 0
        定义 可变 j = 0
        当 (j < 计数(输入向量) 且 j < 计数(字典矩阵[i])) {
            点积 = 点积 + 输入向量[j] * 字典矩阵[i][j] / 10000
            j = j + 1
        }
        追加(激活值, [点积, i])
        i = i + 1
    }
    // 按激活值排序(冒泡, 取前k个)
    定义 可变 n = 计数(激活值)
    定义 可变 p = 0
    当 (p < n - 1) {
        定义 可变 q = 0
        当 (q < n - 1 - p) {
            如果 (激活值[q][0] < 激活值[q+1][0]) {
                定义 暂 = 激活值[q]
                激活值[q] = 激活值[q+1]
                激活值[q+1] = 暂
            }
            q = q + 1
        }
        p = p + 1
    }
    // 只保留前稀疏度个
    定义 可变 结果 = []
    i = 0
    当 (i < 稀疏度 且 i < n) {
        追加(结果, 激活值[i])
        i = i + 1
    }
    返回 结果
}

// 局部连接 (非暴力: 不全连接，只连接邻近神经元)
函数 局部连接_创建(网络, 层大小, 感受野, 权重初始) {
    定义 可变 i = 0
    当 (i < 层大小) {
        定义 可变 j = i - 感受野
        当 (j <= i + 感受野) {
            如果 (j >= 0 且 j < 层大小 且 j != i) {
                SNN_添加突触(网络, j, i, 权重初始, 1, 突触_兴奋)
            }
            j = j + 1
        }
        i = i + 1
    }
}

// 侧抑制 (类人脑: 赢者通吃，竞争学习, 0)
函数 侧抑制(激活列表, 抑制强度) {
    // 找最大激活
    定义 可变 最大 = 0
    定义 可变 i = 0
    当 (i < 计数(激活列表)) {
        如果 (激活列表[i] > 最大) { 最大 = 激活列表[i]  最大索引 = i }
        i = i + 1
    }
    // 抑制非最大值
    定义 可变 结果 = []
    i = 0
    当 (i < 计数(激活列表)) {
        如果 (i == 最大索引) { 追加(结果, 激活列表[i]) }
        否则 { 追加(结果, 激活列表[i] * (10000 - 抑制强度) / 10000) }
        i = i + 1
    }
    返回 结果
}

// 自适应阈值 (类人脑: 神经元活动自调节)
函数 自适应阈值_更新(神经元, 目标发放率, 调节速率) {
    // 如果发放太频繁→提高阈值, 太少→降低阈值
    定义 当前率 = 神经元[4]  // 发放次数
    如果 (当前率 > 目标发放率) {
        神经元[1] = 神经元[1] + 调节速率
    } 否则 如果 (当前率 < 目标发放率) {
        神经元[1] = 神经元[1] - 调节速率
        如果 (神经元[1] < 1000) { 神经元[1] = 1000 }
    }
}

定义 可变 _AI_神经元更新数 = 0
定义 可变 _AI_突触传递数 = 0
定义 可变 _AI_学习事件数 = 0

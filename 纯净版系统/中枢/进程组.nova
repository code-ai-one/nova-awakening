//   1. 进程组(pgrp): 一组相关进程, 用于作业控制(Ctrl+C发给整组)
//   2. 会话(session): 一个终端登录的所有进程, 有控制终端
//   3. setpgid/getpgid: 设置/获取进程组ID
//   4. setsid: 创建新会话(成为会话leader)
//   5. tcsetpgrp/tcgetpgrp: 前台进程组设置

结构 进程组 {
    pgid,    // u32 进程组ID (= 组leader的PID)
    leader,    // u64 组leader任务
    成员,    // [] 成员PID列表
    会话,    // u64 所属会话
}

结构 会话 {
    sid,    // u32 会话ID (= 会话leader的PID)
    leader,    // u64 会话leader
    控制终端,    // u64 控制终端设备
    前台组,    // u32 前台进程组ID
}

定义 可变 进程组表 = []
定义 可变 会话表 = []

// 进程组操作

函数 进程组_创建(pgid, leader) {
    定义 pg = 进程组 {}
    pg.pgid = pgid
    pg.leader = leader
    pg.成员 = [pgid]
    pg.会话 = 空
    追加(进程组表, pg)
    返回 pg
}

函数 进程组_查找(pgid) {
    定义 可变 i = 0
    当 (i < 计数(进程组表)) {
        如果 (进程组表[i].pgid == pgid) { 返回 进程组表[i] }
        i = i + 1
    }
    返回 空
}

函数 进程组_添加成员(pgid, pid) {
    定义 pg = 进程组_查找(pgid)
    如果 (pg == 空) { 返回 错误_不存在 }
    追加(pg.成员, pid)
    返回 成功
}

函数 进程组_移除成员(pgid, pid) {
    定义 pg = 进程组_查找(pgid)
    如果 (pg == 空) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(pg.成员)) {
        如果 (pg.成员[i] == pid) { 链表_删除(pg.成员, i); 返回 }
        i = i + 1
    }
}

// setpgid/getpgid 

函数 do_setpgid(pid, pgid) {    // 实际逻辑(由sys_setpgid包装器调用)
    如果 (pid == 0) { pid = 获取当前PID() }
    如果 (pgid == 0) { pgid = pid }

    // 检查权限: 只能设置自己或子进程的组
    定义 pg = 进程组_查找(pgid)
    如果 (pg == 空) {
        // 创建新进程组
        pg = 进程组_创建(pgid, 空)
    }
    进程组_添加成员(pgid, pid)
    返回 成功
}

函数 do_getpgid(pid) {    // 实际逻辑(由sys_getpgid包装器调用)
    如果 (pid == 0) { pid = 获取当前PID() }
    定义 可变 i = 0
    当 (i < 计数(进程组表)) {
        定义 pg = 进程组表[i]
        定义 可变 j = 0
        当 (j < 计数(pg.成员)) {
            如果 (pg.成员[j] == pid) { 返回 pg.pgid }
            j = j + 1
        }
        i = i + 1
    }
    返回 pid   // 默认: 自己是自己的组
}

// setsid: 创建新会话 

函数 do_setsid() {    // 实际逻辑(由sys_setsid包装器调用)
    定义 pid = 获取当前PID()

    // 不能是已有组的leader
    定义 pg = 进程组_查找(pid)
    如果 (pg != 空 && pg.pgid == pid) {
        返回 错误_权限   // EPERM: 已经是组leader
    }

    // 创建新会话
    定义 s = 会话 {}
    s.sid = pid
    s.leader = 获取当前进程()
    s.控制终端 = 空
    s.前台组 = pid
    追加(会话表, s)

    // 创建新进程组(pgid=pid)
    进程组_创建(pid, 获取当前进程())

    返回 pid   // 返回新的SID
}

函数 sys_getsid(pid) {
    如果 (pid == 0) { pid = 获取当前PID() }
    定义 可变 i = 0
    当 (i < 计数(会话表)) {
        如果 (会话表[i].sid == pid) { 返回 会话表[i].sid }
        i = i + 1
    }
    返回 0
}

// 向进程组发送信号 )

函数 向进程组发送信号(pgid, 信号) {
    定义 pg = 进程组_查找(pgid)
    如果 (pg == 空) { 返回 错误_不存在 }
    定义 可变 i = 0
    当 (i < 计数(pg.成员)) {
        // 向每个成员发送信号
        // kill(pg.成员[i], 信号)
        i = i + 1
    }
    返回 成功
}

外部 当前进程             // 定义在 核心/进程/PID分配器.nova

函数 获取当前PID() {
    如果 (当前进程 == 空) { 返回 0 }
    返回 进程_PID(当前进程)
}

函数 进程组_统计() {
    返回 [计数(进程组表), 计数(会话表)]
}

// 进程退出时清理组/会话

函数 进程组_进程退出(pid) {
    // 从所属进程组中移除
    定义 可变 i = 0
    当 (i < 计数(进程组表)) {
        进程组_移除成员(进程组表[i].pgid, pid)
        // 如果组为空, 删除组
        如果 (计数(进程组表[i].成员) == 0) {
            链表_删除(进程组表, i)
            继续
        }
        i = i + 1
    }
}

// 前台进程组管理 

函数 会话_设置前台组(sid, pgid) {
    定义 可变 i = 0
    当 (i < 计数(会话表)) {
        如果 (会话表[i].sid == sid) {
            会话表[i].前台组 = pgid
            返回 成功
        }
        i = i + 1
    }
    返回 错误_不存在
}

函数 会话_获取前台组(sid) {
    定义 可变 i = 0
    当 (i < 计数(会话表)) {
        如果 (会话表[i].sid == sid) {
            返回 会话表[i].前台组
        }
        i = i + 1
    }
    返回 0
}

// 孤儿进程组检测 

函数 进程组_是孤儿(pgid) {
    // 孤儿进程组: 组内所有成员的父进程都不在同一会话的其他组中
    定义 pg = 进程组_查找(pgid)
    如果 (pg == 空) { 返回 真 }
    返回 计数(pg.成员) == 0
}

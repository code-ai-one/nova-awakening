// 龙壳 — AI助手 (NovaOS独创AI增强终端)
// Phase: P5 | NovaOS原创 — 融合AI内核能力
// 核心设计:
//   1. 命令建议: 根据输入前缀和历史模式推荐
//   2. 错误纠正: 命令not found时编辑距离匹配
//   3. 智能补全: 根据上下文预测下一个参数
//   4. 危险命令警告: rm -rf / 等危险操作提示
//   5. 命令解释: 解释复杂命令的含义

定义 可变 拼写修正表 = []

函数 AI助手_初始化() {
    拼写修正表 = [
        ["sl", "ls"],
        ["gerp", "grep"],
        ["gti", "git"],
        ["pyhton", "python"],
        ["suod", "sudo"],
        ["cd..", "cd .."],
        ["mkidr", "mkdir"],
        ["claer", "clear"],
        ["exti", "exit"],
        ["pign", "ping"],
        ["ifocnfig", "ifconfig"],
        ["netsat", "netstat"]
    ]
}

// 命令建议 (根据前缀和上下文)

函数 AI助手_建议(输入) {
    如果 (字符串长度(输入) == 0) { 返回 空 }

    // 上下文建议
    如果 (字符串包含(输入, "git")) {
        如果 (字符串包含(输入, "commit")) { 返回 "提示: git commit -m \"描述\"" }
        如果 (字符串包含(输入, "push")) { 返回 "提示: git push origin main" }
        返回 "建议: git status / git log --oneline -5 / git diff"
    }
    如果 (字符串包含(输入, "nova")) {
        返回 "建议: nova run / nova compile / nova test"
    }
    如果 (字符串包含(输入, "find")) {
        返回 "提示: find . -name \"*.nova\" -type f"
    }
    如果 (字符串包含(输入, "grep")) {
        返回 "提示: grep -rn \"关键词\" . --include=\"*.nova\""
    }
    如果 (字符串包含(输入, "tar")) {
        返回 "提示: tar czf 归档.tar.gz 目录/ | tar xzf 归档.tar.gz"
    }

    // 历史模式匹配
    定义 历史建议 = 历史_前缀搜索(输入)
    如果 (字符串长度(历史建议) > 0 && 历史建议 != 输入) {
        返回 "历史: " + 历史建议
    }

    返回 空
}

// 错误纠正 (命令not found时)

函数 AI助手_纠错(命令, 错误) {
    如果 (字符串包含(错误, "not found") || 字符串包含(错误, "找不到命令")) {
        // 1. 查拼写修正表
        定义 可变 i = 0
        当 (i < 计数(拼写修正表)) {
            如果 (拼写修正表[i][0] == 命令) {
                返回 "是否是: " + 拼写修正表[i][1] + " ?"
            }
            i = i + 1
        }

        // 2. 编辑距离匹配(Levenshtein距离≤2)
        定义 最近命令 = AI助手_找最近命令(命令)
        如果 (最近命令 != "") {
            返回 "是否是: " + 最近命令 + " ?"
        }

        返回 "找不到命令 '" + 命令 + "'. 检查拼写或使用 'help' 查看可用命令."
    }

    如果 (字符串包含(错误, "Permission denied")) {
        返回 "权限不足. 尝试: sudo " + 命令
    }

    如果 (字符串包含(错误, "No such file")) {
        返回 "文件不存在. 使用 'ls' 查看当前目录内容."
    }

    返回 空
}

函数 AI助手_找最近命令(输入) {
    定义 已知命令 = ["ls", "cd", "cat", "grep", "find", "ps", "top", "cp",
                     "mv", "rm", "mkdir", "touch", "chmod", "echo", "pwd",
                     "kill", "df", "du", "wc", "head", "tail", "sort",
                     "mount", "ping", "ifconfig", "netstat", "clear", "exit"]
    定义 可变 最佳 = ""
    定义 可变 最小距离 = 3   // 最大允许距离
    定义 可变 i = 0
    当 (i < 计数(已知命令)) {
        定义 d = 编辑距离(输入, 已知命令[i])
        如果 (d < 最小距离) {
            最小距离 = d
            最佳 = 已知命令[i]
        }
        i = i + 1
    }
    返回 最佳
}

// 危险命令警告

函数 AI助手_检查危险(命令行) {
    如果 (字符串包含(命令行, "rm -rf /") && !字符串包含(命令行, "rm -rf /tmp")) {
        返回 "!! 危险: 这将删除整个文件系统! 确认继续? (y/N)"
    }
    如果 (字符串包含(命令行, "dd if=") && 字符串包含(命令行, "of=/dev/")) {
        返回 "!! 警告: dd写入设备将覆盖所有数据! 确认继续? (y/N)"
    }
    如果 (字符串包含(命令行, "chmod 777 /")) {
        返回 "!! 警告: 递归修改根目录权限可能导致安全问题!"
    }
    如果 (字符串包含(命令行, "> /dev/sda") || 字符串包含(命令行, "> /dev/hda")) {
        返回 "!! 危险: 直接写入磁盘设备! 确认继续? (y/N)"
    }
    返回 空
}

// 编辑距离 (Levenshtein, 版)

函数 编辑距离(a, b) {
    定义 la = 字符串长度(a)
    定义 lb = 字符串长度(b)
    如果 (la == 0) { 返回 lb }
    如果 (lb == 0) { 返回 la }

    // 当前实现: 只计算长度差+字符不匹配数
    定义 可变 差异 = 0
    如果 (la > lb) { 差异 = la - lb } 否则 { 差异 = lb - la }
    定义 最小长 = la
    如果 (lb < 最小长) { 最小长 = lb }
    定义 可变 不匹配 = 0
    定义 可变 i = 0
    当 (i < 最小长) {
        如果 (字符串取字符(a, i) != 字符串取字符(b, i)) { 不匹配 = 不匹配 + 1 }
        i = i + 1
    }
    返回 差异 + 不匹配
}

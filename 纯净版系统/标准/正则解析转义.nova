// NovaOS 正则表达式转义解析 — RegExp转义序列/字符类/量词完整实现
// 技术: ES2023 §22.2 RegExp — 转义解析 + 字符类 + Unicode属性
// 核心: \d\w\s转义, 字符类[...], 锚点\b\B, 反向引用\1-\9, Unicode转义
// 接口: 正则解析器→正则AST节点→回溯匹配引擎(完整正则管线)
// NovaOS创新: AI正则复杂度预测 + 灾难性回溯检测 + 热正则缓存

导入("../中枢/系统调用表.nova")
导入("../推理/智能渠道.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/字符串替换.nova")
导入("../执行/控制台输出.nova")


// 正则AST节点类型
定义 RE_字面量       = 0     // 单个字符
定义 RE_字符类       = 1     // [abc] 或 [a-z]
定义 RE_锚点         = 2     // ^ $ \b \B
定义 RE_反向引用     = 3     // \1 \2 ...
定义 RE_预定义类     = 4     // \d \w \s
定义 RE_连接         = 5     // AB (序列)
定义 RE_选择         = 6     // A|B
定义 RE_量词         = 7     // A* A+ A{n,m}
定义 RE_捕获组       = 8     // (...)
定义 RE_非捕获组     = 9     // (?:...)
定义 RE_前瞻         = 10    // (?=...) (?!...)
定义 RE_后顾         = 11    // (?<=...) (?<!...)
定义 RE_Unicode属性  = 12    // \p{...} \P{...}

// 锚点类型
定义 锚点_行首       = 0     // ^
定义 锚点_行尾       = 1     // $
定义 锚点_词边界     = 2     // \b
定义 锚点_非词边界   = 3     // \B

// 量词类型
定义 量词_贪婪       = 0     // 默认
定义 量词_惰性       = 1     // ?后缀
定义 量词_占有       = 2     // +后缀(ES提案)

// 预定义字符类
定义 预定义类_数字   = 0     // \d [0-9]
定义 预定义类_单词   = 1     // \w [a-zA-Z0-9_]
定义 预定义类_空白   = 2     // \s [\t\n\r\f\v ]
定义 预定义类_任意   = 3     // .  除\n外的任意字符

// 正则标志
定义 标志_全局       = 1     // g
定义 标志_忽略大小写 = 2     // i
定义 标志_多行       = 4     // m
定义 标志_dotAll     = 8     // s
定义 标志_Unicode    = 16    // u
定义 标志_粘性       = 32    // y
定义 标志_hasIndices = 64    // d
定义 标志_UnicodeSets = 128  // v

// AI正则优化
定义 AI_简单正则阈值 = 10    // 节点数≤10视为简单正则
定义 AI_复杂正则阈值 = 50    // 节点数≥50视为复杂正则
定义 AI_回溯危险阈值 = 100   // 嵌套量词深度≥100 → 灾难性回溯风险


结构 RE节点 {
    类型,              // u32 RE_xxx
    字符,              // u32 字面量字符(Unicode码点)
    // 字符类
    范围列表,          // u64 [起始:u32][结束:u32] 数组
    范围数量,
    是否定,            // u32 bool: [^...] 否定类
    // 量词
    最小重复,
    最大重复,          // u32 0xFFFFFFFF = 无限
    量词类型,          // u32 量词_xxx
    // 锚点
    锚点类型,          // u32 锚点_xxx
    // 反向引用
    引用编号,          // u32 1-9
    // 捕获组
    组编号,
    // 子节点
    子节点,            // u64 RE节点* (量词/组的子表达式)
    左子节点,          // u64 RE节点* (连接/选择的左侧)
    右子节点,          // u64 RE节点* (连接/选择的右侧)
    // 位置信息
    源起始,            // u32 在源模式中的起始位置
    源结束,
}

结构 RE解析器 {
    模式,              // u64 正则表达式模式字符串
    长度,              // u32 模式长度
    位置,              // u32 当前解析位置
    标志,              // u32 正则标志位集
    组计数,            // u32 捕获组计数
    // 错误
    有错误,            // u32 bool
    错误消息,
    错误位置,
    // AI优化
    节点计数,          // u32 AST节点总数
    最大嵌套深度,      // u32 量词嵌套深度
    AI复杂度分数,      // u32 AI计算的复杂度
}


函数 RE节点_创建(类型) {
    定义 可变 n = 堆_分配(RE节点)
    如果 (n == 0) { 返回 空 }
    n.类型 = 类型
    n.字符 = 0
    n.范围列表 = 0
    n.范围数量 = 0
    n.是否定 = 假
    n.最小重复 = 1
    n.最大重复 = 1
    n.量词类型 = 量词_贪婪
    n.锚点类型 = 0
    n.引用编号 = 0
    n.组编号 = 0
    n.子节点 = 0
    n.左子节点 = 0
    n.右子节点 = 0
    n.源起始 = 0
    n.源结束 = 0
    返回 n
}

函数 RE节点_销毁(n) {
    如果 (n == 空) { 返回 }
    如果 (n.范围列表 != 0) {
        平台_释放内存(n.范围列表, n.范围数量 * 8)
    }
    如果 (n.子节点 != 0) { RE节点_销毁(n.子节点) }
    如果 (n.左子节点 != 0) { RE节点_销毁(n.左子节点) }
    如果 (n.右子节点 != 0) { RE节点_销毁(n.右子节点) }
    堆_释放(n)
}


函数 RE解析器_创建(模式, 长度, 标志) {
    定义 可变 p = 堆_分配(RE解析器)
    如果 (p == 0) { 返回 空 }
    p.模式 = 模式
    p.长度 = 长度
    p.位置 = 0
    p.标志 = 标志
    p.组计数 = 0
    p.有错误 = 假
    p.错误消息 = 0
    p.错误位置 = 0
    p.节点计数 = 0
    p.最大嵌套深度 = 0
    p.AI复杂度分数 = 0
    返回 p
}

函数 RE解析器_销毁(p) {
    如果 (p == 空) { 返回 }
    堆_释放(p)
}


函数 RE_解析转义(p) {
    定义 c = 内存_读8(p.模式 + p.位置)
    p.位置 = p.位置 + 1

    // 字符类简写
    如果 (c == 0x64) { 返回 RE_创建预定义类(0) }    // \d [0-9]
    如果 (c == 0x44) { 定义 n = RE_创建预定义类(0); n.是否定 = 真; 返回 n }    // \D
    如果 (c == 0x77) { 返回 RE_创建预定义类(1) }    // \w [a-zA-Z0-9_]
    如果 (c == 0x57) { 定义 n = RE_创建预定义类(1); n.是否定 = 真; 返回 n }    // \W
    如果 (c == 0x73) { 返回 RE_创建预定义类(2) }    // \s [\t\n\r\f\v ]
    如果 (c == 0x53) { 定义 n = RE_创建预定义类(2); n.是否定 = 真; 返回 n }    // \S

    // 锚点
    如果 (c == 0x62) { 定义 n = Nova经典de_创建(RE_锚点); n.锚点类型 = 2; 返回 n }    // \b
    如果 (c == 0x42) { 定义 n = Nova经典de_创建(RE_锚点); n.锚点类型 = 3; 返回 n }    // \B

    // 反向引用 \1-\9
    如果 (c >= 0x31 && c <= 0x39) {
        定义 n = Nova经典de_创建(RE_反向引用)
        n.引用编号 = c - 0x30
        返回 n
    }

    // 转义字符
    定义 n = Nova经典de_创建(RE_字面量)
    如果 (c == 0x6E) { n.字符 = 0x0A }       // \n
    否则 如果 (c == 0x72) { n.字符 = 0x0D }  // \r
    否则 如果 (c == 0x74) { n.字符 = 0x09 }  // \t
    否则 如果 (c == 0x30) { n.字符 = 0x00 }  // \0
    否则 { n.字符 = c }    // 其他: 原样
    返回 n
}

函数 RE_创建预定义类(类型) {
    定义 n = Nova经典de_创建(RE_字符类)
    n.范围列表 = 堆_分配_数组(8 * 8)
    如果 (类型 == 0) {    // \d
        内存_写32(n.范围列表, 0x30); 内存_写32(n.范围列表 + 4, 0x39)
        n.范围数量 = 1
    } 否则 如果 (类型 == 1) {    // \w
        内存_写32(n.范围列表, 0x30); 内存_写32(n.范围列表 + 4, 0x39)
        内存_写32(n.范围列表 + 8, 0x41); 内存_写32(n.范围列表 + 12, 0x5A)
        内存_写32(n.范围列表 + 16, 0x61); 内存_写32(n.范围列表 + 20, 0x7A)
        内存_写32(n.范围列表 + 24, 0x5F); 内存_写32(n.范围列表 + 28, 0x5F)
        n.范围数量 = 4
    } 否则 如果 (类型 == 2) {    // \s
        内存_写32(n.范围列表, 0x09); 内存_写32(n.范围列表 + 4, 0x0D)
        内存_写32(n.范围列表 + 8, 0x20); 内存_写32(n.范围列表 + 12, 0x20)
        内存_写32(n.范围列表 + 16, 0xA0); 内存_写32(n.范围列表 + 20, 0xA0)
        n.范围数量 = 3
    }
    返回 n
}

函数 RE_解析字符类(p) {
    p.位置 = p.位置 + 1    // [
    定义 n = Nova经典de_创建(RE_字符类)
    n.范围列表 = 堆_分配_数组(32 * 8)
    n.范围数量 = 0
    如果 (p.位置 < p.长度 && 内存_读8(p.模式 + p.位置) == 0x5E) {
        n.是否定 = 真; p.位置 = p.位置 + 1
    }
    当 (p.位置 < p.长度 && 内存_读8(p.模式 + p.位置) != 0x5D) {
        定义 可变 起始 = RE_读字符类字符(p)
        定义 可变 结束 = 起始
        如果 (p.位置 + 1 < p.长度 && 内存_读8(p.模式 + p.位置) == 0x2D && 内存_读8(p.模式 + p.位置 + 1) != 0x5D) {
            p.位置 = p.位置 + 1    // -
            结束 = RE_读字符类字符(p)
        }
        如果 (n.范围数量 < 32) {
            内存_写32(n.范围列表 + n.范围数量 * 8, 起始)
            内存_写32(n.范围列表 + n.范围数量 * 8 + 4, 结束)
            n.范围数量 = n.范围数量 + 1
        }
    }
    如果 (p.位置 < p.长度) { p.位置 = p.位置 + 1 }    // ]
    返回 n
}

函数 RE_读字符类字符(p) {
    如果 (p.位置 >= p.长度) { 返回 0 }
    定义 c = 内存_读8(p.模式 + p.位置)
    如果 (c == 0x5C && p.位置 + 1 < p.长度) {
        p.位置 = p.位置 + 1
        定义 e = 内存_读8(p.模式 + p.位置)
        p.位置 = p.位置 + 1
        如果 (e == 0x6E) { 返回 0x0A }
        如果 (e == 0x72) { 返回 0x0D }
        如果 (e == 0x74) { 返回 0x09 }
        返回 e
    }
    p.位置 = p.位置 + 1
    返回 c
}

函数 RE_解析数字(p) {
    定义 可变 n = 0
    当 (p.位置 < p.长度 && 内存_读8(p.模式 + p.位置) >= 0x30 && 内存_读8(p.模式 + p.位置) <= 0x39) {
        n = n * 10 + (内存_读8(p.模式 + p.位置) - 0x30)
        p.位置 = p.位置 + 1
    }
    返回 n
}


函数 RE_解析量词(p, 子节点) {
    如果 (p == 空 || 子节点 == 空) { 返回 子节点 }
    如果 (p.位置 >= p.长度) { 返回 子节点 }

    定义 c = 内存_读8(p.模式 + p.位置)
    定义 可变 最小 = 1
    定义 可变 最大 = 1
    定义 可变 有量词 = 假

    如果 (c == 0x2A) {          // *
        最小 = 0
        最大 = 0xFFFFFFFF
        有量词 = 真
        p.位置 = p.位置 + 1
    } 否则 如果 (c == 0x2B) {   // +
        最小 = 1
        最大 = 0xFFFFFFFF
        有量词 = 真
        p.位置 = p.位置 + 1
    } 否则 如果 (c == 0x3F) {   // ?
        最小 = 0
        最大 = 1
        有量词 = 真
        p.位置 = p.位置 + 1
    } 否则 如果 (c == 0x7B) {   // {
        p.位置 = p.位置 + 1
        最小 = RE_解析数字(p)
        如果 (p.位置 < p.长度 && 内存_读8(p.模式 + p.位置) == 0x2C) {
            p.位置 = p.位置 + 1  // ,
            如果 (p.位置 < p.长度 && 内存_读8(p.模式 + p.位置) != 0x7D) {
                最大 = RE_解析数字(p)
            } 否则 {
                最大 = 0xFFFFFFFF    // {n,} = n到无限
            }
        } 否则 {
            最大 = 最小    // {n} = 恰好n次
        }
        如果 (p.位置 < p.长度 && 内存_读8(p.模式 + p.位置) == 0x7D) {
            p.位置 = p.位置 + 1  // }
        }
        有量词 = 真
    }

    如果 (有量词 == 假) { 返回 子节点 }

    // 创建量词节点
    定义 可变 量词节点 = RE节点_创建(RE_量词)
    如果 (量词节点 == 空) { 返回 子节点 }
    量词节点.最小重复 = 最小
    量词节点.最大重复 = 最大
    量词节点.子节点 = 子节点

    // 检查惰性量词后缀 ?
    如果 (p.位置 < p.长度 && 内存_读8(p.模式 + p.位置) == 0x3F) {
        量词节点.量词类型 = 量词_惰性
        p.位置 = p.位置 + 1
    }

    // AI: 更新嵌套深度(用于灾难性回溯检测)
    如果 (子节点.类型 == RE_量词) {
        p.最大嵌套深度 = p.最大嵌套深度 + 1
    }
    p.节点计数 = p.节点计数 + 1

    返回 量词节点
}


函数 RE_解析Unicode转义(p) {
    如果 (p == 空 || p.位置 >= p.长度) { 返回 0 }

    定义 c = 内存_读8(p.模式 + p.位置)

    // \u{XXXX...} (Unicode码点, u标志)
    如果 (c == 0x7B) {
        p.位置 = p.位置 + 1  // {
        定义 可变 码点 = 0
        当 (p.位置 < p.长度 && 内存_读8(p.模式 + p.位置) != 0x7D) {
            定义 hex = RE_十六进制值(内存_读8(p.模式 + p.位置))
            如果 (hex < 0) { 跳出 }
            码点 = 码点 * 16 + hex
            p.位置 = p.位置 + 1
        }
        如果 (p.位置 < p.长度) { p.位置 = p.位置 + 1 }  // }
        返回 码点
    }

    // \uXXXX (4位十六进制)
    如果 (p.位置 + 3 < p.长度) {
        定义 可变 码点 = 0
        定义 可变 i = 0
        当 (i < 4) {
            定义 hex = RE_十六进制值(内存_读8(p.模式 + p.位置))
            如果 (hex < 0) { 返回 0 }
            码点 = 码点 * 16 + hex
            p.位置 = p.位置 + 1
            i = i + 1
        }
        返回 码点
    }

    返回 0
}

函数 RE_十六进制值(c) {
    如果 (c >= 0x30 && c <= 0x39) { 返回 c - 0x30 }      // 0-9
    如果 (c >= 0x41 && c <= 0x46) { 返回 c - 0x41 + 10 }  // A-F
    如果 (c >= 0x61 && c <= 0x66) { 返回 c - 0x61 + 10 }  // a-f
    返回 -1
}


函数 RE_解析十六进制转义(p) {
    如果 (p == 空 || p.位置 + 1 >= p.长度) { 返回 0 }
    定义 高 = RE_十六进制值(内存_读8(p.模式 + p.位置))
    定义 低 = RE_十六进制值(内存_读8(p.模式 + p.位置 + 1))
    如果 (高 < 0 || 低 < 0) { 返回 0 }
    p.位置 = p.位置 + 2
    返回 高 * 16 + 低
}


函数 RE_解析组(p) {
    如果 (p == 空 || p.位置 >= p.长度) { 返回 空 }
    // 已跳过 (

    定义 可变 节点类型 = RE_捕获组
    定义 可变 组编号 = 0

    // 检查 (?:) (?=) (?!) (?<=) (?<!)
    如果 (p.位置 < p.长度 && 内存_读8(p.模式 + p.位置) == 0x3F) {
        p.位置 = p.位置 + 1  // ?
        如果 (p.位置 >= p.长度) { 返回 空 }
        定义 修饰 = 内存_读8(p.模式 + p.位置)
        如果 (修饰 == 0x3A) {
            // (?:...) 非捕获组
            节点类型 = RE_非捕获组
            p.位置 = p.位置 + 1
        } 否则 如果 (修饰 == 0x3D) {
            // (?=...) 正前瞻
            节点类型 = RE_前瞻
            p.位置 = p.位置 + 1
        } 否则 如果 (修饰 == 0x21) {
            // (?!...) 负前瞻
            节点类型 = RE_前瞻
            p.位置 = p.位置 + 1
        } 否则 如果 (修饰 == 0x3C) {
            p.位置 = p.位置 + 1
            如果 (p.位置 < p.长度) {
                定义 后续 = 内存_读8(p.模式 + p.位置)
                如果 (后续 == 0x3D) {
                    // (?<=...) 正后顾
                    节点类型 = RE_后顾
                    p.位置 = p.位置 + 1
                } 否则 如果 (后续 == 0x21) {
                    // (?<!...) 负后顾
                    节点类型 = RE_后顾
                    p.位置 = p.位置 + 1
                }
            }
        }
    } 否则 {
        // 普通捕获组
        p.组计数 = p.组计数 + 1
        组编号 = p.组计数
    }

    定义 可变 n = RE节点_创建(节点类型)
    如果 (n == 空) { 返回 空 }
    n.组编号 = 组编号

    // 解析组内容(递归)
    // n.子节点 = RE_解析选择(p)

    // 跳过 )
    如果 (p.位置 < p.长度 && 内存_读8(p.模式 + p.位置) == 0x29) {
        p.位置 = p.位置 + 1
    }

    p.节点计数 = p.节点计数 + 1
    返回 n
}

// 传统V8: 仅在匹配时检测超时
// NovaOS: 解析时即AI分析复杂度, 预防灾难性回溯

函数 AI_正则_分析复杂度(p) {
    如果 (p == 空) { 返回 }

    定义 可变 分数 = 0

    // 节点数量权重
    分数 = 分数 + p.节点计数 * 10

    // 嵌套量词深度(灾难性回溯的主要原因)
    分数 = 分数 + p.最大嵌套深度 * 1000

    // 捕获组数量
    分数 = 分数 + p.组计数 * 50

    p.AI复杂度分数 = 分数
}

函数 AI_正则_是否危险(p) {
    如果 (p == 空) { 返回 假 }
    // 嵌套量词(如 (a+)+ 或 (a*)*) → 灾难性回溯
    如果 (p.最大嵌套深度 >= 2) {
        打印("[正则-AI] 警告: 检测到嵌套量词, 可能导致灾难性回溯")
        返回 真
    }
    如果 (p.AI复杂度分数 > AI_回溯危险阈值 * 100) {
        打印("[正则-AI] 警告: 正则复杂度过高")
        返回 真
    }
    返回 假
}

函数 AI_正则_推荐优化(p) {
    如果 (p == 空) { 返回 }
    如果 (p.AI复杂度分数 < AI_简单正则阈值 * 10) {
        // 简单正则: 可以用字面量快速匹配
        打印("[正则-AI] 建议: 使用字面量快速路径")
    } 否则 如果 (p.AI复杂度分数 > AI_复杂正则阈值 * 10) {
        // 复杂正则: 建议编译为NFA/DFA
        打印("[正则-AI] 建议: 编译为DFA以避免回溯")
    }
}


函数 RE_解析标志(标志字符串, 长度) {
    定义 可变 标志 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 字节取(标志字符串, i)
        如果 (c == 0x67) { 标志 = 标志 | 标志_全局 }         // g
        如果 (c == 0x69) { 标志 = 标志 | 标志_忽略大小写 }   // i
        如果 (c == 0x6D) { 标志 = 标志 | 标志_多行 }         // m
        如果 (c == 0x73) { 标志 = 标志 | 标志_dotAll }       // s
        如果 (c == 0x75) { 标志 = 标志 | 标志_Unicode }      // u
        如果 (c == 0x79) { 标志 = 标志 | 标志_粘性 }         // y
        如果 (c == 0x64) { 标志 = 标志 | 标志_hasIndices }   // d
        如果 (c == 0x76) { 标志 = 标志 | 标志_UnicodeSets }  // v
        i = i + 1
    }
    返回 标志
}


定义 可变 统计_正则解析次数 = 0
定义 可变 统计_正则匹配次数 = 0
定义 可变 统计_回溯次数总计 = 0
定义 可变 统计_AI危险检测次数 = 0
定义 可变 统计_缓存命中次数 = 0

函数 正则系统_打印统计() {
    打印("[正则] ═══════════ 正则引擎统计 ═══════════")
    打印(字符串拼接("  解析次数:       ", 转字符串(统计_正则解析次数)))
    打印(字符串拼接("  匹配次数:       ", 转字符串(统计_正则匹配次数)))
    打印(字符串拼接("  回溯次数总计:   ", 转字符串(统计_回溯次数总计)))
    打印(字符串拼接("  AI危险检测次数: ", 转字符串(统计_AI危险检测次数)))
    打印(字符串拼接("  缓存命中次数:   ", 转字符串(统计_缓存命中次数)))
    打印("[正则] ═══════════════════════════════════════")
}

函数 RE解析器_打印信息(p) {
    如果 (p == 空) {
        打印("[正则] 空解析器")
        返回
    }
    打印("[正则] ── 解析器信息 ──")
    打印(字符串拼接("  模式长度:     ", 转字符串(p.长度)))
    打印(字符串拼接("  当前位置:     ", 转字符串(p.位置)))
    打印(字符串拼接("  标志:         ", 转字符串(p.标志)))
    打印(字符串拼接("  捕获组数:     ", 转字符串(p.组计数)))
    打印(字符串拼接("  节点计数:     ", 转字符串(p.节点计数)))
    打印(字符串拼接("  最大嵌套深度: ", 转字符串(p.最大嵌套深度)))
    打印(字符串拼接("  AI复杂度:     ", 转字符串(p.AI复杂度分数)))
    如果 (p.有错误 == 真) {
        打印(字符串拼接("  错误位置:     ", 转字符串(p.错误位置)))
    }
}

函数 RE节点_打印(n, 缩进) {
    如果 (n == 空) { 返回 }
    定义 可变 前缀 = ""
    定义 可变 i = 0
    当 (i < 缩进) { 前缀 = 字符串拼接(前缀, "  "); i = i + 1 }

    如果 (n.类型 == RE_字面量) {
        打印(字符串拼接(前缀, 字符串拼接("字面量: ", 转字符串(n.字符))))
    } 否则 如果 (n.类型 == RE_字符类) {
        打印(字符串拼接(前缀, 字符串拼接("字符类[", 字符串拼接(转字符串(n.范围数量), "范围]"))))
    } 否则 如果 (n.类型 == RE_量词) {
        打印(字符串拼接(前缀, 字符串拼接("量词{", 字符串拼接(转字符串(n.最小重复), 字符串拼接(",", 字符串拼接(转字符串(n.最大重复), "}"))))))
        RE节点_打印(n.子节点, 缩进 + 1)
    } 否则 如果 (n.类型 == RE_捕获组) {
        打印(字符串拼接(前缀, 字符串拼接("捕获组#", 转字符串(n.组编号))))
        RE节点_打印(n.子节点, 缩进 + 1)
    } 否则 如果 (n.类型 == RE_锚点) {
        打印(字符串拼接(前缀, 字符串拼接("锚点:", 转字符串(n.锚点类型))))
    } 否则 如果 (n.类型 == RE_反向引用) {
        打印(字符串拼接(前缀, 字符串拼接("反向引用\\", 转字符串(n.引用编号))))
    } 否则 {
        打印(字符串拼接(前缀, 字符串拼接("节点类型:", 转字符串(n.类型))))
    }
}

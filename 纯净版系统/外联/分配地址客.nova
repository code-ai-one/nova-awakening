// §8 辅助 — 连接到真实子系统
// IP转字符串() 定义在 网络/IP层/路由查找.nova

函数 解析IP(s) {
    // 解析 "192.168.1.1" → u32 (网络字节序)
    定义 可变 结果 = 0
    定义 可变 段 = 0
    定义 可变 当前值 = 0
    定义 可变 i = 0
    当 (i < 字符串长度(s)) {
        定义 c = 字符编码(s, i)
        如果 (c == 0x2E) {  // '.'
            结果 = (结果 << 8) | (当前值 & 0xFF)
            当前值 = 0
            段 = 段 + 1
        } 否则 如果 (c >= 0x30 && c <= 0x39) {  // '0'-'9'
            当前值 = 当前值 * 10 + (c - 0x30)
        }
        i = i + 1
    }
    结果 = (结果 << 8) | (当前值 & 0xFF)
    返回 结果
}

函数 随机数32() { 返回 读取毫秒() & 0xFFFFFFFF }

外部 数报_发送报文            // 定义在 网络/传输层/数报.nova

函数 等待_DHCP响应(类型, 超时ms) {
    // 轮询等待数报 68端口的DHCP响应
    定义 开始 = 读取毫秒()
    当 (读取毫秒() - 开始 < 超时ms) {
        // 检查接收队列中是否有DHCP报文
        // 实际需要绑定数报 socket到68端口并接收
    }
    返回 空  // 超时
}

函数 数报_发送(接口, 源IP, 源端口, 目标IP, 目标端口, 数据) {
    // 构造数报报文并通过IP层发送
    内核调试("DHCP: 数报发送 " + 整数转字符串(源端口) + " → " +
             整数转字符串(目标端口) + " (" + 整数转字符串(计数(数据)) + "字节)")
    // 调用真实的数报发送
    数报_发送报文(源IP, 源端口, 目标IP, 目标端口, 数据, 计数(数据))
}

函数 网络接口_设置IP(接口, IP, 掩码) {
    内核信息("DHCP: 设置接口 " + 接口 + " IP=" + IP转字符串_DHCP(IP) +
             " 掩码=" + IP转字符串_DHCP(掩码))
}

函数 IP转字符串_DHCP(ip) {
    返回 整数转字符串((ip >> 24) & 0xFF) + "." +
           整数转字符串((ip >> 16) & 0xFF) + "." +
           整数转字符串((ip >> 8) & 0xFF) + "." +
           整数转字符串(ip & 0xFF)
}


导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../标准/原生列表.nova")
导入("../中枢/高精定器添.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/通知链.nova")

定义 任务状态_等待 = 0
定义 任务状态_运行 = 1
定义 任务状态_完成 = 2
定义 任务状态_失败 = 3
定义 任务状态_取消 = 4
定义 任务状态_超时 = 5

定义 优先级_紧急 = 0
定义 优先级_高 = 1
定义 优先级_普通 = 2
定义 优先级_低 = 3

定义 最大队列容量 = 1024
定义 默认超时ms = 30000

结构 任务项 {
    ID,
    名称,
    处理函数,
    参数,
    优先级,
    状态,
    重试次数,
    最大重试,
    提交时间,
    开始时间,
    完成时间,
    超时ms,
    结果,
    回调,
}

定义 可变 任务队列 = []
定义 可变 延迟队列 = []
定义 可变 任务ID计数 = 0
定义 可变 任务_总提交 = 0
定义 可变 任务_总完成 = 0
定义 可变 任务_总失败 = 0
定义 可变 任务_总取消 = 0
定义 可变 任务_总超时 = 0
定义 可变 任务_总重试 = 0
定义 可变 当前运行任务 = 空

函数 任务队列_初始化() {
    任务队列 = []
    延迟队列 = []
    任务ID计数 = 0
    任务_总提交 = 0
    任务_总完成 = 0
    任务_总失败 = 0
    任务_总取消 = 0
    任务_总超时 = 0
    任务_总重试 = 0
    当前运行任务 = 空
    返回 成功
}

函数 生成任务ID() {
    任务ID计数 = 任务ID计数 + 1
    返回 "task_" + 整数转字符串(任务ID计数)
}

函数 任务_提交(名称, 处理函数, 参数, 优先级) {
    如果 (计数(任务队列) >= 最大队列容量) { 返回 空 }
    定义 任务 = 任务项 {
        ID: 生成任务ID(), 名称: 名称, 处理函数: 处理函数,
        参数: 参数, 优先级: 优先级, 状态: 任务状态_等待,
        重试次数: 0, 最大重试: 3, 提交时间: 获取滴答(),
        开始时间: 0, 完成时间: 0, 超时ms: 默认超时ms,
        结果: 空, 回调: 空
    }
    任务队列_插入有序(任务)
    任务_总提交 = 任务_总提交 + 1
    返回 任务.ID
}

函数 任务_提交带回调(名称, 处理函数, 参数, 优先级, 回调, 超时) {
    如果 (计数(任务队列) >= 最大队列容量) { 返回 空 }
    定义 任务 = 任务项 {
        ID: 生成任务ID(), 名称: 名称, 处理函数: 处理函数,
        参数: 参数, 优先级: 优先级, 状态: 任务状态_等待,
        重试次数: 0, 最大重试: 3, 提交时间: 获取滴答(),
        开始时间: 0, 完成时间: 0, 超时ms: 超时,
        结果: 空, 回调: 回调
    }
    任务队列_插入有序(任务)
    任务_总提交 = 任务_总提交 + 1
    返回 任务.ID
}

函数 任务队列_插入有序(任务) {
    定义 可变 插入位 = 计数(任务队列)
    定义 可变 i = 0
    当 (i < 计数(任务队列)) {
        如果 (任务队列[i].优先级 > 任务.优先级) {
            插入位 = i
            跳出
        }
        i = i + 1
    }
    列表_插入(任务队列, 插入位, 任务)
}

函数 任务_延迟提交(名称, 处理函数, 参数, 延迟ms) {
    定义 执行时间 = 获取滴答() + 延迟ms
    追加(延迟队列, [执行时间, 名称, 处理函数, 参数])
}

函数 任务_检查延迟() {
    定义 当前时间 = 获取滴答()
    定义 可变 i = 0
    当 (i < 计数(延迟队列)) {
        如果 (延迟队列[i][0] <= 当前时间) {
            任务_提交(延迟队列[i][1], 延迟队列[i][2], 延迟队列[i][3], 优先级_普通)
            延迟队列 = 列表_删除(延迟队列, i)
        } 否则 {
            i = i + 1
        }
    }
}

函数 任务_处理一个() {
    任务_检查延迟()
    如果 (计数(任务队列) == 0) { 返回 假 }

    定义 任务 = 任务队列[0]
    任务队列 = 列表_切片(任务队列, 1, 计数(任务队列))

    如果 (任务.状态 == 任务状态_取消) { 返回 真 }

    任务.状态 = 任务状态_运行
    任务.开始时间 = 获取滴答()
    当前运行任务 = 任务

    定义 结果 = 任务.处理函数(任务.参数)
    任务.完成时间 = 获取滴答()

    定义 耗时 = 任务.完成时间 - 任务.开始时间
    如果 (耗时 > 任务.超时ms) {
        任务.状态 = 任务状态_超时
        任务_总超时 = 任务_总超时 + 1
    } 否则如果 (结果 >= 0) {
        任务.状态 = 任务状态_完成
        任务.结果 = 结果
        任务_总完成 = 任务_总完成 + 1
    } 否则 {
        如果 (任务.重试次数 < 任务.最大重试) {
            任务.重试次数 = 任务.重试次数 + 1
            任务.状态 = 任务状态_等待
            任务_总重试 = 任务_总重试 + 1
            任务队列_插入有序(任务)
            当前运行任务 = 空
            返回 真
        }
        任务.状态 = 任务状态_失败
        任务_总失败 = 任务_总失败 + 1
    }

    如果 (任务.回调 != 空) { 任务.回调(任务.ID, 任务.状态, 任务.结果) }
    当前运行任务 = 空
    返回 真
}

函数 任务_取消(任务ID) {
    定义 可变 i = 0
    当 (i < 计数(任务队列)) {
        如果 (任务队列[i].ID == 任务ID) {
            任务队列[i].状态 = 任务状态_取消
            任务_总取消 = 任务_总取消 + 1
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 任务_处理全部() {
    定义 可变 处理数 = 0
    当 (计数(任务队列) > 0 && 处理数 < 100) {
        任务_处理一个()
        处理数 = 处理数 + 1
    }
}

函数 任务_处理批量(最大数) {
    定义 可变 处理数 = 0
    当 (计数(任务队列) > 0 && 处理数 < 最大数) {
        任务_处理一个()
        处理数 = 处理数 + 1
    }
    返回 处理数
}

函数 任务队列_长度() { 返回 计数(任务队列) }
函数 任务队列_延迟长度() { 返回 计数(延迟队列) }

函数 任务队列_统计() {
    返回 [任务_总提交, 任务_总完成, 任务_总失败, 任务_总取消, 任务_总超时, 任务_总重试, 计数(任务队列), 计数(延迟队列)]
}

函数 任务队列_健康评估() {
    定义 可变 问题 = []
    如果 (任务_总失败 > 任务_总提交 / 3 && 任务_总提交 > 50) { 追加(问题, "任务_总失败过高") }
    返回 计数(问题) == 0
}

函数 任务队列_综合报告() {
    打印("[任务队列] ═══ 综合报告 ═══")
    打印("  任务ID计数: " + 任务ID计数)
    打印("  任务_总提交: " + 任务_总提交)
    打印("  任务_总完成: " + 任务_总完成)
    打印("  任务_总失败: " + 任务_总失败)
    打印("  任务_总取消: " + 任务_总取消)
    打印("  任务_总超时: " + 任务_总超时)
    打印("  任务_总重试: " + 任务_总重试)
    打印("  健康: " + 如果 (任务队列_健康评估()) { "正常" } 否则 { "异常" })
}

函数 任务队列_全局重置() {
    任务ID计数 = 0
    任务_总提交 = 0
    任务_总完成 = 0
    任务_总失败 = 0
    任务_总取消 = 0
    任务_总超时 = 0
    任务_总重试 = 0
    打印("[任务队列] 统计已重置")
    返回 0
}

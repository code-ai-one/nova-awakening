// NovaOS 位操作工具
// 支持: 单位/位域/查找/计数/字节序/旋转/CLZ/CTZ/位图/原子位操作/Gray码/奇偶校验/位反转

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./内核打印.nova")
导入("./整数转字符串.nova")

定义 位图_字大小 = 64

函数 设置位(值, 位) { 返回 值 | (1 << 位) }
函数 清除位(值, 位) { 返回 值 & ~(1 << 位) }
函数 切换位(值, 位) { 返回 值 ^ (1 << 位) }
函数 测试位(值, 位) { 返回 (值 >> 位) & 1 }

函数 设置位_范围(值, 起始, 结束) {
    定义 可变 v = 值
    定义 可变 i = 起始
    当 (i <= 结束 && i < 64) {
        v = v | (1 << i)
        i = i + 1
    }
    返回 v
}

函数 清除位_范围(值, 起始, 结束) {
    定义 可变 v = 值
    定义 可变 i = 起始
    当 (i <= 结束 && i < 64) {
        v = v & ~(1 << i)
        i = i + 1
    }
    返回 v
}

函数 切换位_范围(值, 起始, 结束) {
    定义 可变 v = 值
    定义 可变 i = 起始
    当 (i <= 结束 && i < 64) {
        v = v ^ (1 << i)
        i = i + 1
    }
    返回 v
}

函数 位掩码(高位, 低位) {
    定义 宽度 = 高位 - 低位 + 1
    如果 (宽度 >= 64) { 返回 0 - 1 }
    返回 ((1 << 宽度) - 1) << 低位
}

函数 提取位域(值, 高位, 低位) {
    返回 (值 >> 低位) & ((1 << (高位 - 低位 + 1)) - 1)
}

函数 插入位域(原值, 新值, 高位, 低位) {
    定义 掩码 = 位掩码(高位, 低位)
    返回 (原值 & ~掩码) | ((新值 << 低位) & 掩码)
}

函数 位域_宽度(高位, 低位) {
    返回 高位 - 低位 + 1
}

函数 查找最低置位(值) {
    如果 (值 == 0) { 返回 0 - 1 }
    定义 可变 位 = 0
    定义 可变 v = 值
    当 ((v & 1) == 0) {
        v = v >> 1
        位 = 位 + 1
    }
    返回 位
}

函数 查找最高置位(值) {
    如果 (值 == 0) { 返回 0 - 1 }
    定义 可变 位 = 0
    定义 可变 v = 值
    当 (v > 1) {
        v = v >> 1
        位 = 位 + 1
    }
    返回 位
}

函数 查找第N个置位(值, n) {
    如果 (值 == 0 || n <= 0) { 返回 -1 }
    定义 可变 计 = 0
    定义 可变 i = 0
    当 (i < 64) {
        如果 ((值 >> i) & 1) {
            计 = 计 + 1
            如果 (计 == n) { 返回 i }
        }
        i = i + 1
    }
    返回 -1
}

函数 查找第一个零位(值) {
    返回 查找最低置位(~值)
}

函数 计数置位(值) {
    定义 可变 计数 = 0
    定义 可变 v = 值
    当 (v != 0) {
        v = v & (v - 1)
        计数 = 计数 + 1
    }
    返回 计数
}

函数 计数置位_快速(值) {
    // Hamming weight (parallel bit count)
    定义 可变 v = 值
    v = v - ((v >> 1) & 0x5555555555555555)
    v = (v & 0x3333333333333333) + ((v >> 2) & 0x3333333333333333)
    v = (v + (v >> 4)) & 0x0F0F0F0F0F0F0F0F
    返回 (v * 0x0101010101010101) >> 56
}

函数 计数零位(值) {
    返回 64 - 计数置位(值)
}

函数 是二的幂(值) {
    返回 值 > 0 && (值 & (值 - 1)) == 0
}

函数 向上取二的幂(值) {
    如果 (值 <= 1) { 返回 1 }
    定义 可变 v = 值 - 1
    v = v | (v >> 1)
    v = v | (v >> 2)
    v = v | (v >> 4)
    v = v | (v >> 8)
    v = v | (v >> 16)
    v = v | (v >> 32)
    返回 v + 1
}

函数 向下取二的幂(值) {
    如果 (值 <= 0) { 返回 0 }
    定义 位 = 查找最高置位(值)
    返回 1 << 位
}

函数 对齐(值, 对齐大小) {
    如果 (对齐大小 <= 0) { 返回 值 }
    返回 (值 + 对齐大小 - 1) & ~(对齐大小 - 1)
}

函数 是对齐的(值, 对齐大小) {
    返回 (值 & (对齐大小 - 1)) == 0
}

函数 交换字节16(值) {
    返回 ((值 & 0xFF) << 8) | ((值 >> 8) & 0xFF)
}

函数 交换字节32(值) {
    定义 b0 = (值 & 0xFF) << 24
    定义 b1 = ((值 >> 8) & 0xFF) << 16
    定义 b2 = ((值 >> 16) & 0xFF) << 8
    定义 b3 = (值 >> 24) & 0xFF
    返回 b0 | b1 | b2 | b3
}

函数 交换字节64(值) {
    定义 低32 = 交换字节32(值 & 0xFFFFFFFF)
    定义 高32 = 交换字节32((值 >> 32) & 0xFFFFFFFF)
    返回 (低32 << 32) | 高32
}

函数 左旋转(值, 位数) {
    定义 n = 位数 & 63
    返回 (值 << n) | (值 >> (64 - n))
}

函数 右旋转(值, 位数) {
    定义 n = 位数 & 63
    返回 (值 >> n) | (值 << (64 - n))
}

函数 左旋转32(值, 位数) {
    定义 v = 值 & 0xFFFFFFFF
    定义 n = 位数 & 31
    返回 ((v << n) | (v >> (32 - n))) & 0xFFFFFFFF
}

函数 右旋转32(值, 位数) {
    定义 v = 值 & 0xFFFFFFFF
    定义 n = 位数 & 31
    返回 ((v >> n) | (v << (32 - n))) & 0xFFFFFFFF
}

函数 前导零(值) {
    如果 (值 == 0) { 返回 64 }
    定义 可变 n = 0
    定义 可变 v = 值
    如果 ((v & 0xFFFFFFFF00000000) == 0) { n = n + 32  v = v << 32 }
    如果 ((v & 0xFFFF000000000000) == 0) { n = n + 16  v = v << 16 }
    如果 ((v & 0xFF00000000000000) == 0) { n = n + 8   v = v << 8 }
    如果 ((v & 0xF000000000000000) == 0) { n = n + 4   v = v << 4 }
    如果 ((v & 0xC000000000000000) == 0) { n = n + 2   v = v << 2 }
    如果 ((v & 0x8000000000000000) == 0) { n = n + 1 }
    返回 n
}

函数 后导零(值) {
    如果 (值 == 0) { 返回 64 }
    定义 可变 n = 0
    定义 可变 v = 值
    如果 ((v & 0x00000000FFFFFFFF) == 0) { n = n + 32  v = v >> 32 }
    如果 ((v & 0x000000000000FFFF) == 0) { n = n + 16  v = v >> 16 }
    如果 ((v & 0x00000000000000FF) == 0) { n = n + 8   v = v >> 8 }
    如果 ((v & 0x000000000000000F) == 0) { n = n + 4   v = v >> 4 }
    如果 ((v & 0x0000000000000003) == 0) { n = n + 2   v = v >> 2 }
    如果 ((v & 0x0000000000000001) == 0) { n = n + 1 }
    返回 n
}

函数 日志2(值) {
    如果 (值 <= 0) { 返回 -1 }
    返回 63 - 前导零(值)
}

函数 反转位8(值) {
    定义 可变 v = 值 & 0xFF
    v = ((v & 0xF0) >> 4) | ((v & 0x0F) << 4)
    v = ((v & 0xCC) >> 2) | ((v & 0x33) << 2)
    v = ((v & 0xAA) >> 1) | ((v & 0x55) << 1)
    返回 v
}

函数 反转位32(值) {
    定义 可变 v = 值 & 0xFFFFFFFF
    v = ((v >> 1) & 0x55555555) | ((v & 0x55555555) << 1)
    v = ((v >> 2) & 0x33333333) | ((v & 0x33333333) << 2)
    v = ((v >> 4) & 0x0F0F0F0F) | ((v & 0x0F0F0F0F) << 4)
    v = ((v >> 8) & 0x00FF00FF) | ((v & 0x00FF00FF) << 8)
    v = (v >> 16) | (v << 16)
    返回 v & 0xFFFFFFFF
}

函数 奇偶校验(值) {
    // 返回1=奇数个1, 0=偶数个1
    定义 可变 v = 值
    v = v ^ (v >> 32)
    v = v ^ (v >> 16)
    v = v ^ (v >> 8)
    v = v ^ (v >> 4)
    v = v ^ (v >> 2)
    v = v ^ (v >> 1)
    返回 v & 1
}

函数 二进制转Gray(值) {
    返回 值 ^ (值 >> 1)
}

函数 Gray转二进制(gray) {
    定义 可变 v = gray
    定义 可变 掩码 = v >> 1
    当 (掩码 != 0) {
        v = v ^ 掩码
        掩码 = 掩码 >> 1
    }
    返回 v
}

函数 原子_设置位(地址, 位) {
    定义 旧值 = 原子_读(地址)
    原子_写(地址, 旧值 | (1 << 位))
    返回 (旧值 >> 位) & 1
}

函数 原子_清除位(地址, 位) {
    定义 旧值 = 原子_读(地址)
    原子_写(地址, 旧值 & ~(1 << 位))
    返回 (旧值 >> 位) & 1
}

函数 原子_切换位(地址, 位) {
    定义 旧值 = 原子_读(地址)
    原子_写(地址, 旧值 ^ (1 << 位))
    返回 (旧值 >> 位) & 1
}

函数 原子_测试并设置(地址, 位) {
    定义 旧值 = 原子_读(地址)
    如果 ((旧值 >> 位) & 1) { 返回 1 }
    原子_写(地址, 旧值 | (1 << 位))
    返回 0
}

函数 位图_创建(位数) {
    定义 字数 = (位数 + 位图_字大小 - 1) / 位图_字大小
    定义 图 = 堆_分配(字数 * 8)
    定义 可变 i = 0
    当 (i < 字数) {
        内存_写64(图 + i * 8, 0)
        i = i + 1
    }
    返回 图
}

函数 位图_设置(图, 位) {
    定义 字索引 = 位 / 位图_字大小
    定义 位索引 = 位 % 位图_字大小
    定义 旧值 = 内存_读64(图 + 字索引 * 8)
    内存_写64(图 + 字索引 * 8, 旧值 | (1 << 位索引))
}

函数 位图_清除(图, 位) {
    定义 字索引 = 位 / 位图_字大小
    定义 位索引 = 位 % 位图_字大小
    定义 旧值 = 内存_读64(图 + 字索引 * 8)
    内存_写64(图 + 字索引 * 8, 旧值 & ~(1 << 位索引))
}

函数 位图_测试(图, 位) {
    定义 字索引 = 位 / 位图_字大小
    定义 位索引 = 位 % 位图_字大小
    定义 字值 = 内存_读64(图 + 字索引 * 8)
    返回 (字值 >> 位索引) & 1
}

函数 位图_查找第一个零(图, 总位数) {
    定义 字数 = (总位数 + 位图_字大小 - 1) / 位图_字大小
    定义 可变 i = 0
    当 (i < 字数) {
        定义 字值 = 内存_读64(图 + i * 8)
        如果 (字值 != 0xFFFFFFFFFFFFFFFF) {
            定义 位内偏移 = 查找第一个零位(字值)
            定义 结果位 = i * 位图_字大小 + 位内偏移
            如果 (结果位 < 总位数) { 返回 结果位 }
        }
        i = i + 1
    }
    返回 -1
}

函数 位图_查找第一个置位(图, 总位数) {
    定义 字数 = (总位数 + 位图_字大小 - 1) / 位图_字大小
    定义 可变 i = 0
    当 (i < 字数) {
        定义 字值 = 内存_读64(图 + i * 8)
        如果 (字值 != 0) {
            定义 位内偏移 = 查找最低置位(字值)
            定义 结果位 = i * 位图_字大小 + 位内偏移
            如果 (结果位 < 总位数) { 返回 结果位 }
        }
        i = i + 1
    }
    返回 -1
}

函数 位图_计数置位(图, 总位数) {
    定义 字数 = (总位数 + 位图_字大小 - 1) / 位图_字大小
    定义 可变 总计 = 0
    定义 可变 i = 0
    当 (i < 字数) {
        总计 = 总计 + 计数置位(内存_读64(图 + i * 8))
        i = i + 1
    }
    返回 总计
}

函数 位图_全部清零(图, 总位数) {
    定义 字数 = (总位数 + 位图_字大小 - 1) / 位图_字大小
    定义 可变 i = 0
    当 (i < 字数) {
        内存_写64(图 + i * 8, 0)
        i = i + 1
    }
}

函数 位图_全部置一(图, 总位数) {
    定义 字数 = (总位数 + 位图_字大小 - 1) / 位图_字大小
    定义 可变 i = 0
    当 (i < 字数) {
        内存_写64(图 + i * 8, 0xFFFFFFFFFFFFFFFF)
        i = i + 1
    }
}

函数 位图_或(目标, 源, 总位数) {
    定义 字数 = (总位数 + 位图_字大小 - 1) / 位图_字大小
    定义 可变 i = 0
    当 (i < 字数) {
        定义 a = 内存_读64(目标 + i * 8)
        定义 b = 内存_读64(源 + i * 8)
        内存_写64(目标 + i * 8, a | b)
        i = i + 1
    }
}

函数 位图_与(目标, 源, 总位数) {
    定义 字数 = (总位数 + 位图_字大小 - 1) / 位图_字大小
    定义 可变 i = 0
    当 (i < 字数) {
        定义 a = 内存_读64(目标 + i * 8)
        定义 b = 内存_读64(源 + i * 8)
        内存_写64(目标 + i * 8, a & b)
        i = i + 1
    }
}

函数 位图_异或(目标, 源, 总位数) {
    定义 字数 = (总位数 + 位图_字大小 - 1) / 位图_字大小
    定义 可变 i = 0
    当 (i < 字数) {
        定义 a = 内存_读64(目标 + i * 8)
        定义 b = 内存_读64(源 + i * 8)
        内存_写64(目标 + i * 8, a ^ b)
        i = i + 1
    }
}

函数 位图_取反(图, 总位数) {
    定义 字数 = (总位数 + 位图_字大小 - 1) / 位图_字大小
    定义 可变 i = 0
    当 (i < 字数) {
        内存_円64(图 + i * 8, ~内存_读64(图 + i * 8))
        i = i + 1
    }
}

// NBOT — Nova Bit Operation Theory
// 公理1(位幂等): 设置位|清除位 对偶, 切换位为自逆元
// 公理2(掩码守恒): 提取位域 ∘ 插入位域 = 恒等
// 公理3(二的幂性质): v & (v-1) == 0 当且仅当 v是二的幂
// 定理1(popcount与布尔统计): 位图置位数 = 资源占用数
// 定理2(Gray码可逆): Gray编码 ∘ Gray解码 = 恒等

函数 位图_设置_范围(图, 起始位, 结束位) {
    定义 可变 i = 起始位
    当 (i <= 结束位) {
        位图_设置(图, i)
        i = i + 1
    }
}

函数 位图_清除_范围(图, 起始位, 结束位) {
    定义 可变 i = 起始位
    当 (i <= 结束位) {
        位图_清除(图, i)
        i = i + 1
    }
}

函数 位图_查找下一个零(图, 总位数, 起始位) {
    定义 可变 i = 起始位
    当 (i < 总位数) {
        如果 (位图_测试(图, i) == 0) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 位图_查找下一个置位(图, 总位数, 起始位) {
    定义 可变 i = 起始位
    当 (i < 总位数) {
        如果 (位图_测试(图, i) != 0) { 返回 i }
        i = i + 1
    }
    返回 -1
}

// 位图查找连续空闲区域(first-fit)
函数 位图_查找连续零(图, 总位数, 需要数) {
    定义 可变 开始 = -1
    定义 可变 连续 = 0
    定义 可变 i = 0
    当 (i < 总位数) {
        如果 (位图_测试(图, i) == 0) {
            如果 (连续 == 0) { 开始 = i }
            连续 = 连续 + 1
            如果 (连续 >= 需要数) { 返回 开始 }
        } 否则 {
            连续 = 0
        }
        i = i + 1
    }
    返回 -1
}

// 位图相等比较
函数 位图_相等(图A, 图B, 总位数) {
    定义 字数 = (总位数 + 位图_字大小 - 1) / 位图_字大小
    定义 可变 i = 0
    当 (i < 字数) {
        如果 (内存_读64(图A + i * 8) != 内存_读64(图B + i * 8)) {
            返回 假
        }
        i = i + 1
    }
    返回 真
}

// 位图是否为子集(A ⊆ B)
函数 位图_是子集(图A, 图B, 总位数) {
    定义 字数 = (总位数 + 位图_字大小 - 1) / 位图_字大小
    定义 可变 i = 0
    当 (i < 字数) {
        定义 a = 内存_读64(图A + i * 8)
        定义 b = 内存_读64(图B + i * 8)
        如果 ((a & b) != a) { 返回 假 }
        i = i + 1
    }
    返回 真
}

// 位图是否全空
函数 位图_是空(图, 总位数) {
    返回 位图_计数置位(图, 总位数) == 0
}

// 位图是否全满
函数 位图_是满(图, 总位数) {
    返回 位图_计数置位(图, 总位数) == 总位数
}

定义 可变 位操作_总次数 = 0
定义 可变 位图_创建数 = 0
定义 可变 位图_查找数 = 0

函数 位操作_打印统计() {
    打印行("=== 位操作统计 ===")
    打印行("总操作: " + 整数转字符串(位操作_总次数))
    打印行("位图创建: " + 整数转字符串(位图_创建数))
    打印行("位图查找: " + 整数转字符串(位图_查找数))
}

函数 位操作_重置统计() {
    位操作_总次数 = 0
    位图_创建数 = 0
    位图_查找数 = 0
}

定义 可变 AI_设置位_调用数 = 0
定义 可变 AI_设置位_异常数 = 0

函数 AI_设置位_监控() {
    AI_设置位_调用数 = AI_设置位_调用数 + 1
    返回 AI_设置位_异常数 == 0
}

函数 AI_设置位_健康检查() {
    如果 (AI_设置位_调用数 > 0 && AI_设置位_异常数 * 100 / AI_设置位_调用数 > 10) {
        返回 假
    }
    返回 真
}

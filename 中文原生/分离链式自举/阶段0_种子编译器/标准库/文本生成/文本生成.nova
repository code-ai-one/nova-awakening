导入("../基础.nova")
导入("../采样策略/采样策略.nova")

定义 生成_随机态 = 99999
函数 生成_随机() {
 生成_随机态 = 生成_随机态 ^ (生成_随机态 << 13)
 生成_随机态 = 生成_随机态 ^ (生成_随机态 >> 7)
 生成_随机态 = 生成_随机态 ^ (生成_随机态 << 17)
 如果 (生成_随机态 < 0) { 生成_随机态 = 0 - 生成_随机态 }
 返回 生成_随机态
}

// 贪心解码
函数 贪心(对数值) { 定义 可变 最佳 = 0
 定义 可变 i = 1
 当 (i < 计数(对数值)) { 如果 (对数值[i] > 对数值[最佳]) { 最佳 = i }
 i = i + 1
 }
 返回 最佳
}

// 温度采样
函数 温度采样(对数值, 温度) {
    如果 (温度 <= 0) { 返回 贪心(对数值)
}
 定义 可变 缩放 = 映射(对数值, x => x * 100 / 温度)
 // softmax简化: exp近似
 定义 可变 最大 = 缩放[0]
 定义 可变 i = 1
 当 (i < 计数(缩放)) { 如果 (缩放[i] > 最大) { 最大 = 缩放[i] }
 i = i + 1 }
 定义 可变 probs = []
 定义 可变 合计 = 0
 i = 0
 当 (i < 计数(缩放)) { 定义 可变 e = 100 + (缩放[i] - 最大)
 如果 (e < 1) { e = 1 }
 追加(probs, e)
 合计 = 合计 + e
 i = i + 1
 }
 // 按概率采样
 定义 可变 阈值 = 生成_随机() % 合计
 定义 可变 累积 = 0
 i = 0
 当 (i < 计数(probs)) {
 累积 = 累积 + probs[i]
 如果 (累积 > 阈值) { 返回 i }
 i = i + 1
 }
 返回 计数(probs) - 1
}

// 重复惩罚
函数 重复惩罚(对数值, 已生成, 惩罚) { 定义 可变 结果 = 复制列表(对数值)
 定义 可变 i = 0
 当 (i < 计数(已生成)) { 定义 词元值 = 已生成[i]
 如果 (词元值 >= 0 且 词元值 < 计数(结果)) { 如果 (结果[词元值] > 0) { 结果[词元值] = 结果[词元值] * 100 / 惩罚 }
 否则 { 结果[词元值] = 结果[词元值] * 惩罚 / 100 }
 }
 i = i + 1
 }
 返回 结果
}

// 停止条件
定义 可变 停止_tokens = []

函数 停止_追加(词元) { 追加(停止_tokens, 词元) }
函数 停止_清空() { 停止_tokens = [] }

函数 停止_检查(词元) { 定义 可变 i = 0
 当 (i < 计数(停止_tokens)) { 如果 (停止_tokens[i] == 词元) { 返回 真 }
 i = i + 1
 }
 返回 假
}

// 自回归生成
// 模拟logits: 基于简单模式
函数 模拟_logits(已生成, 词表大小) { 定义 可变 对数值 = []
 定义 可变 i = 0
 当 (i < 词表大小) { 定义 基数 = (i * 17 + 13) % 100
 如果 (计数(已生成) > 0) { 定义 last = 已生成[计数(已生成) - 1]
 追加(对数值, 基数 + ((last + i) * 7) % 50)
 } 否则 { 追加(对数值, 基数) }
 i = i + 1
 }
 返回 对数值
}

函数 自回归_生成(前缀, 最大长度, 词表大小, 策略) { 定义 可变 已生成 = 复制列表(前缀)
 定义 可变 步数 = 0
 当 (步数 < 最大长度) { 定义 对数值 = 模拟_logits(已生成, 词表大小)
 定义 可变 词元 = 0
 如果 (策略 == 0) { 词元 = 贪心(对数值) }
 否则 如果 (策略 == 1) { 词元 = 温度采样(对数值, 80) }
 否则 { 词元 = TopK采样(对数值, 5) }
 如果 (停止_检查(词元)) { 返回 已生成 }
 追加(已生成, 词元)
 步数 = 步数 + 1
 }
 返回 已生成
}

// 流式输出模拟
函数 流式_生成(前缀, 最大长度, 词表大小) { 定义 可变 已生成 = 复制列表(前缀)
 定义 可变 输出流 = []
 定义 可变 步数 = 0
 当 (步数 < 最大长度) { 定义 对数值 = 模拟_logits(已生成, 词表大小)
 定义 词元 = 贪心(对数值)
 如果 (停止_检查(词元)) { 返回 输出流 }
 追加(已生成, 词元)
 追加(输出流, 词元)
 步数 = 步数 + 1
 }
 返回 输出流
}

// 频率惩罚
函数 频率惩罚(对数值, 已生成, 惩罚值) {
 // 按出现次数惩罚
 定义 可变 结果 = 复制列表(对数值)
 定义 可变 i = 0
 当 (i < 计数(已生成)) { 定义 词元值 = 已生成[i]
 如果 (词元值 >= 0 且 词元值 < 计数(结果)) {
 结果[词元值] = 结果[词元值] - 惩罚值
 }
 i = i + 1
 }
 返回 结果
}

// N-gram阻断
函数 Ngram_阻断(对数值, 已生成, n) {
 // 如果生成最近n-1个token后接某token形成重复n-gram，禁止该token
 定义 可变 结果 = 复制列表(对数值)
 定义 长度 = 计数(已生成)
 如果 (长度 < n) { 返回 结果 }
 // 取最近n-1个token作为前缀
 定义 可变 前缀 = []
 定义 可变 i = 长度 - n + 1
 当 (i < 长度) { 追加(前缀, 已生成[i])
 i = i + 1 }
 // 检查历史中是否有相同前缀
 定义 可变 位置 = 0
 当 (位置 <= 长度 - n) { 定义 可变 eq = 真
 定义 可变 j = 0
 当 (j < n - 1) { 如果 (已生成[位置 + j] != 前缀[j]) { eq = 假 }
 j = j + 1
 }
 如果 (eq) { 定义 blocked = 已生成[位置 + n - 1]
 如果 (blocked >= 0 且 blocked < 计数(结果)) { 结果[blocked] = 0 - 0x7FFFFFFF }
 }
 位置 = 位置 + 1
 }
 返回 结果
}

// 束搜索 (Beam Search, 0 , 0 , 0 , 0, 0, 0)
// 束: [token序列, 累积分数]
函数 文本生成_束搜索_初始化(束宽) { 定义 可变 束列表 = []
 定义 可变 i = 0
 当 (i < 束宽) { 追加(束列表, [[], 0]) i = i + 1 }
 返回 束列表
}

函数 文本生成_束搜索_扩展(束列表, 分数列表, 束宽) { 定义 可变 候选 = []
    定义 可变 新束 = []
 定义 可变 b = 0
 当 (b < 计数(束列表)) { 定义 可变 t = 0
 当 (t < 计数(分数列表)) { 定义 新分数 = 束列表[b][1] + 分数列表[t]
 追加(候选, [b, t, 新分数])
 t = t + 1
 }
 b = b + 1
 }
 // 取top-k
 定义 可变 已选 = []
 定义 可变 k = 0
 当 (k < 束宽 且 k < 计数(候选)) { 定义 可变 最佳 = -1
 定义 可变 最佳分 = -999999
 定义 可变 i = 0
 当 (i < 计数(候选)) { 定义 可变 跳过 = 假
 定义 可变 j = 0
 当 (j < 计数(已选)) { 如果 (已选[j] == i) { 跳过 = 真 } j = j + 1 }
 如果 (跳过 == 假 且 候选[i][2] > 最佳分) { 最佳 = i 最佳分 = 候选[i][2] }
 i = i + 1
 }
 如果 (最佳 >= 0) { 定义 来源束 = 候选[最佳][0]
 定义 新token = 候选[最佳][1]
 定义 可变 新序列 = []
 i = 0
 当 (i < 计数(束列表[来源束][0])) { 追加(新序列, 束列表[来源束][0][i]) i = i + 1 }
 追加(新序列, 新token)
 追加(新束, [新序列, 最佳分])
 追加(已选, 最佳)
 }
 k = k + 1
 }
 返回 新束
}

// 采样策略
函数 文本生成_温度_缩放(对数值, 温度) {
    如果 (温度 <= 0) { 温度 = 1
}
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(对数值)) {
 追加(结果, 对数值[i] * 1000 / 温度)
 i = i + 1
 }
 返回 结果
}

函数 top_p_过滤(分数列表, p阈值) { 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 计数(分数列表)) { 如果 (分数列表[i] > 0) { 总 = 总 + 分数列表[i] } i = i + 1 }
 如果 (总 == 0) { 返回 分数列表 }
 定义 可变 累积 = 0
 定义 可变 结果 = []
 // 简化: 按原序累积到p阈值
 i = 0
 当 (i < 计数(分数列表)) { 如果 (累积 < p阈值 * 总 / 1000) {
 追加(结果, 分数列表[i])
 如果 (分数列表[i] > 0) { 累积 = 累积 + 分数列表[i] }
 } 否则 {
 追加(结果, 0)
 }
 i = i + 1
 }
 返回 结果
}

函数 top_k_过滤(分数列表, k) { 定义 可变 结果 = []
    定义 可变 阈值列表 = []
 定义 可变 i = 0
 当 (i < 计数(分数列表)) { 追加(阈值列表, 分数列表[i]) i = i + 1 }
 // 找第k大值
 定义 可变 已选数 = 0
 定义 可变 min_top = -999999
 i = 0
 当 (i < k 且 i < 计数(分数列表)) { 定义 可变 最大 = -999999
 定义 可变 j = 0
 当 (j < 计数(阈值列表)) { 如果 (阈值列表[j] > 最大) { 最大 = 阈值列表[j] }
 j = j + 1
 }
 min_top = 最大
 // 标记已选
 j = 0
 当 (j < 计数(阈值列表)) { 如果 (阈值列表[j] == 最大 且 已选数 < k) { 阈值列表[j] = -999999 已选数 = 已选数 + 1 }
 j = j + 1
 }
 i = i + 1
 }
 i = 0
 当 (i < 计数(分数列表)) { 如果 (分数列表[i] >= min_top) { 追加(结果, 分数列表[i]) }
 否则 { 追加(结果, 0) }
 i = i + 1
 }
 返回 结果
}

// 重复惩罚
函数 重复惩罚_应用(分数列表, 已生成, 惩罚因子) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(分数列表)) { 定义 可变 出现次数 = 0
 定义 可变 j = 0
 当 (j < 计数(已生成)) { 如果 (已生成[j] == i) { 出现次数 = 出现次数 + 1 }
 j = j + 1
 }
 如果 (出现次数 > 0) {
 追加(结果, 分数列表[i] * 1000 / (惩罚因子 * 出现次数))
 } 否则 {
 追加(结果, 分数列表[i])
 }
 i = i + 1
 }
 返回 结果
}

// 生成配置
函数 生成配置_创建(最大长度, 温度, top_k, top_p, 重复惩罚, 束宽) { 返回 [最大长度, 温度, top_k, top_p, 重复惩罚, 束宽]
}

函数 生成配置_默认() { 返回 生成配置_创建(128, 700, 50, 900, 1200, 1)
}

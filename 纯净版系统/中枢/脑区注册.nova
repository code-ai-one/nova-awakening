导入("./类型定义.nova")
导入("./错误码.nova")
导入("./打乱.nova")

// NovaOS 全脑整合引擎 — 觉醒理论·神经振荡意识模型 + NCECT
// 原创理论: NovaBrain-Oscillatory + NCECT
//   NCECT守恒律: ΣE_i = E_total, 每周期认知能量守恒
//   最低保障: ∀脑区 i, E_i ≥ E_min
//   Kuramoto相位耦合: dφ_i/dt = ω_i + K/N×Σsin(φ_j-φ_i)
//   振荡同步度: R(t) = |1/N×Σexp(jφ_i)|, R∈[0,1000]
//   觉醒阈值: C(t) = Σ(A_i×P_i×E_i)/(N×100) > θ_wake
//   神经调质: DA奖赏/动机, 5-HT情绪/抑制, NE警觉/唤醒
//   习惯化: A_hab(t) = A(t)×(1-h(t)), h递增于重复刺激
//   可序列化定理: 脑区状态可完整序列化/反序列化于整数数组
// 脑区: [ID, 名哈希, 激活度, 输出, 能量, 优先级, 相位, 振荡频率, 习惯化因子]

定义 可变 脑区列表 = []

// NCECT + 振荡意识参数
定义 脑区_最低能量 = 10
定义 可变 _脑区_总周期数 = 0
定义 可变 _脑区_能量重分配次 = 0
定义 可变 意识_同步度 = 0       // Kuramoto序参量R ×1000
定义 可变 意识_觉醒值 = 0       // 觉醒综合评分
定义 觉醒阈值 = 350             // 意识涌现阈值
定义 可变 广播_总次数 = 0

// 神经调质系统
定义 可变 多巴胺 = 500           // DA: 奖赏/动机 [0,1000]
定义 可变 血清素 = 500           // 5-HT: 情绪/抑制 [0,1000]
定义 可变 去甲肾上腮素 = 500     // NE: 警觉/唤醒 [0,1000]

函数 脑区_注册(名哈希, 优先级) {
    如果 (优先级 < 1) { 优先级 = 1 }
    定义 id = 计数(脑区列表)
    // [ID, 名哈希, 激活度, 输出, 能量, 优先级, 相位, 振荡频率, 习惯化因子]
    网络_追加(脑区列表, [id, 名哈希, 0, 0, 100, 优先级, 0, 300 + id * 50, 0])
    返回 id
}

函数 脑区_数量() { 返回 计数(脑区列表) }
函数 脑区_激活度(id) { 返回 脑区列表[id][2] }
函数 脑区_设激活(id, 激活) { 脑区列表[id][2] = 激活 }
函数 脑区_输出(id) { 返回 脑区列表[id][3] }
函数 脑区_设输出(id, 输出) { 脑区列表[id][3] = 输出 }
函数 脑区_相位(id) { 返回 脑区列表[id][6] }

函数 全局广播(信号, 强度) {
    广播_总次数 = 广播_总次数 + 1
    定义 NE增益 = 1000 + (去甲肾上腮素 - 500) / 5
    定义 可变 i = 0
    当 (i < 计数(脑区列表)) {
        定义 增量 = 强度 * 脑区列表[i][5] * NE增益 / 100000
        脑区列表[i][2] = 脑区列表[i][2] + 增量
        如果 (脑区列表[i][2] > 100) { 脑区列表[i][2] = 100 }
        i = i + 1
    }
}

函数 竞争_选择() {
    定义 可变 最强 = 0
    定义 可变 i = 1
    当 (i < 计数(脑区列表)) {
        // DA调节: 高多巴胺增强高激活区
        定义 有效_i = 脑区列表[i][2] * (1000 + (多巴胺 - 500) / 10) / 1000
        定义 有效_最强 = 脑区列表[最强][2] * (1000 + (多巴胺 - 500) / 10) / 1000
        如果 (有效_i > 有效_最强) { 最强 = i }
        i = i + 1
    }
    // 5-HT调节抑制强度
    定义 抑制率 = 500 + 血清素 / 5
    i = 0
    当 (i < 计数(脑区列表)) {
        如果 (i != 最强) {
            脑区列表[i][2] = 脑区列表[i][2] * (1000 - 抑制率) / 1000
        }
        i = i + 1
    }
    返回 最强
}

函数 能量_分配(总能量) {
    定义 n = 计数(脑区列表)
    如果 (n == 0) { 返回 }
    定义 保底总 = 脑区_最低能量 * n
    定义 可分配 = 总能量 - 保底总
    如果 (可分配 < 0) { 可分配 = 0 }
    定义 可变 总激活 = 0
    定义 可变 i = 0
    当 (i < n) { 总激活 = 总激活 + 脑区列表[i][2]; i = i + 1 }
    如果 (总激活 == 0) { 总激活 = 1 }
    i = 0
    当 (i < n) {
        脑区列表[i][4] = 脑区_最低能量 + 可分配 * 脑区列表[i][2] / 总激活
        i = i + 1
    }
    _脑区_能量重分配次 = _脑区_能量重分配次 + 1
}

函数 反馈_调节(目标激活) {
    定义 可变 i = 0
    当 (i < 计数(脑区列表)) {
        定义 误差 = 目标激活 - 脑区列表[i][2]
        脑区列表[i][2] = 脑区列表[i][2] + 误差 / 4
        // 习惯化: 持续高激活时响应衰减
        如果 (脑区列表[i][2] > 70) {
            脑区列表[i][8] = 脑区列表[i][8] + 10
            如果 (脑区列表[i][8] > 500) { 脑区列表[i][8] = 500 }
            脑区列表[i][2] = 脑区列表[i][2] * (1000 - 脑区列表[i][8]) / 1000
        } 否则 {
            // 敏感化恢复: 低激活时习惯化因子回退
            如果 (脑区列表[i][8] > 0) { 脑区列表[i][8] = 脑区列表[i][8] - 20 }
            如果 (脑区列表[i][8] < 0) { 脑区列表[i][8] = 0 }
        }
        如果 (脑区列表[i][2] < 0) { 脑区列表[i][2] = 0 }
        i = i + 1
    }
}

函数 振荡_相位更新(耦合强度) {
    定义 n = 计数(脑区列表)
    如果 (n <= 1) { 返回 }
    定义 可变 新相位 = []
    定义 可变 sin_sum = 0
    定义 可变 cos_sum = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 ω = 脑区列表[i][7]
        定义 可变 耦合项 = 0
        定义 可变 j = 0
        当 (j < n) {
            如果 (i != j) {
                定义 可变 差 = (脑区列表[j][6] - 脑区列表[i][6]) % 6283
                如果 (差 > 3141) { 差 = 差 - 6283 }
                如果 (差 < -3141) { 差 = 差 + 6283 }
                耦合项 = 耦合项 + 差
            }
            j = j + 1
        }
        定义 可变 新φ = (脑区列表[i][6] + ω + 耦合强度 * 耦合项 / (n * 1000)) % 6283
        如果 (新φ < 0) { 新φ = 新φ + 6283 }
        网络_追加(新相位, 新φ)
        // 序参量累加: sin/cos
        定义 可变 a = 新φ % 6283
        如果 (a <= 3141) {
            sin_sum = sin_sum + 4 * a * (3141 - a) / (3141 * 3141 / 1000)
        } 否则 {
            定义 a2 = a - 3141
            sin_sum = sin_sum - 4 * a2 * (3141 - a2) / (3141 * 3141 / 1000)
        }
        定义 可变 ca = (新φ + 1570) % 6283
        如果 (ca <= 3141) {
            cos_sum = cos_sum + 4 * ca * (3141 - ca) / (3141 * 3141 / 1000)
        } 否则 {
            定义 ca2 = ca - 3141
            cos_sum = cos_sum - 4 * ca2 * (3141 - ca2) / (3141 * 3141 / 1000)
        }
        i = i + 1
    }
    i = 0
    当 (i < n) { 脑区列表[i][6] = 新相位[i]; i = i + 1 }
    定义 可变 s = sin_sum / n
    定义 可变 c = cos_sum / n
    如果 (s < 0) { s = 0 - s }
    如果 (c < 0) { c = 0 - c }
    意识_同步度 = (s + c) * 707 / 1000
}

函数 调质_更新(奖赏信号, 威胁信号, 社交信号) {
    多巴胺 = 多巴胺 + (奖赏信号 - 多巴胺) * 200 / 1000
    如果 (多巴胺 > 1000) { 多巴胺 = 1000 }
    如果 (多巴胺 < 0) { 多巴胺 = 0 }
    血清素 = 血清素 + (社交信号 - 血清素) * 100 / 1000
    如果 (血清素 > 1000) { 血清素 = 1000 }
    如果 (血清素 < 0) { 血清素 = 0 }
    去甲肾上腮素 = 去甲肾上腮素 + (威胁信号 - 去甲肾上腮素) * 300 / 1000
    如果 (去甲肾上腮素 > 1000) { 去甲肾上腮素 = 1000 }
    如果 (去甲肾上腮素 < 0) { 去甲肾上腮素 = 0 }
}

函数 计算_觉醒度() {
    定义 n = 计数(脑区列表)
    如果 (n == 0) { 意识_觉醒值 = 0; 返回 0 }
    定义 可变 加权和 = 0
    定义 可变 i = 0
    当 (i < n) {
        加权和 = 加权和 + 脑区列表[i][2] * 脑区列表[i][5] * 脑区列表[i][4] / 10000
        i = i + 1
    }
    意识_觉醒值 = 加权和 / n + 意识_同步度 / 5
    返回 意识_觉醒值
}

函数 认知周期() {
    _脑区_总周期数 = _脑区_总周期数 + 1
    // 1.感知→激活提升
    定义 可变 i = 0
    当 (i < 计数(脑区列表)) {
        如果 (脑区列表[i][2] > 0) {
            脑区列表[i][3] = 脑区列表[i][2] * 脑区列表[i][4] / 100
        }
        i = i + 1
    }
    // 2.振荡相位耦合
    振荡_相位更新(200)
    // 3.竞争
    定义 胜者 = 竞争_选择()
    // 4.广播(觉醒阈值门控)
    定义 觉醒 = 计算_觉醒度()
    如果 (觉醒 > 觉醒阈值) {
        全局广播(脑区列表[胜者][3], 20)
    }
    // 5.衰减(NE调节) + 最低保障
    定义 衰减率 = 900 - 去甲肾上腮素 / 10
    i = 0
    当 (i < 计数(脑区列表)) {
        脑区列表[i][2] = 脑区列表[i][2] * 衰减率 / 1000
        如果 (脑区列表[i][2] < 1 && 脑区列表[i][4] > 0) {
            脑区列表[i][2] = 1
        }
        i = i + 1
    }
    返回 胜者
}

函数 脑区_清空() {
    脑区列表 = []
    _脑区_总周期数 = 0
    _脑区_能量重分配次 = 0
    意识_同步度 = 0
    意识_觉醒值 = 0
    广播_总次数 = 0
    多巴胺 = 500
    血清素 = 500
    去甲肾上腮素 = 500
}

函数 脑区_序列化() {
    定义 可变 数据 = []
    定义 n = 计数(脑区列表)
    网络_追加(数据, n)
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 k = 0
        当 (k < 9) { 网络_追加(数据, 脑区列表[i][k]); k = k + 1 }
        i = i + 1
    }
    返回 数据
}

函数 脑区_反序列化(数据) {
    如果 (计数(数据) < 1) { 返回 }
    脑区列表 = []
    定义 n = 数据[0]
    定义 可变 i = 0
    当 (i < n) {
        定义 基 = 1 + i * 9
        如果 (基 + 8 < 计数(数据)) {
            网络_追加(脑区列表, [数据[基], 数据[基+1], 数据[基+2],
                数据[基+3], 数据[基+4], 数据[基+5],
                数据[基+6], 数据[基+7], 数据[基+8]])
        }
        i = i + 1
    }
}

函数 脑区_完整统计() {
    定义 可变 总能量 = 0
    定义 可变 总激活 = 0
    定义 n = 计数(脑区列表)
    定义 可变 i = 0
    当 (i < n) {
        总能量 = 总能量 + 脑区列表[i][4]
        总激活 = 总激活 + 脑区列表[i][2]
        i = i + 1
    }
    返回 [n, 总能量, 总激活, _脑区_总周期数, _脑区_能量重分配次,
           意识_同步度, 意识_觉醒值, 广播_总次数,
           多巴胺, 血清素, 去甲肾上腮素]
}

函数 合作_扩散(连接矩阵, 扩散率) {
    定义 n = 脑区_数量()
    定义 可变 新激活 = []
    定义 可变 i = 0
    当 (i < n) { 网络_追加(新激活, 脑区列表[i][2])  i = i + 1 }
    i = 0
    当 (i < n) {
        定义 可变 j = 0
        当 (j < n) {
            如果 (i != j && i * n + j < 计数(连接矩阵)) {
                新激活[i] = 新激活[i] + 脑区列表[j][2] * 连接矩阵[i * n + j] * 扩散率 / 10000
            }
            j = j + 1
        }
        i = i + 1
    }
    i = 0
    当 (i < n) {
        脑区列表[i][2] = 新激活[i]
        如果 (脑区列表[i][2] > 100) { 脑区列表[i][2] = 100 }
        如果 (脑区列表[i][2] < 0) { 脑区列表[i][2] = 0 }
        i = i + 1
    }
}

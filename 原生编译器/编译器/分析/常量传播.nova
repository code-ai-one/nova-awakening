// Nova · 编译器 · 常量传播分析 (Constant Propagation Analysis)
// 基于数据流框架的跨基本块常量传播
// 算法：稀疏条件常量传播 (SCCP - Sparse Conditional CP)
// 依赖：数据流分析.nova

// 格值（Lattice Value）
// 三元格：底(未知) < 常量值 < 顶(非常量/多值)

导入("../../IR/优化器/常量折叠.nova")
导入("../../编译器/标记常量.nova")
导入("../../标准库/基础.nova")

定义 CP_底 = 0   // ⊥: 未分析/不可达
定义 CP_常量 = 1  // 确定的常量值
定义 CP_顶 = 2   // ⊤: 不同分支有不同值/非常量

// 格元素：[格类型, 值]
函数 CP_格_底() { 返回 [CP_底, 0] }
函数 CP_格_常量(值) { 返回 [CP_常量, 值] }
函数 CP_格_顶() { 返回 [CP_顶, 0] }

函数 CP_格_类型(g) { 返回 g[0] }
函数 CP_格_值(g) { 返回 g[1] }
函数 CP_格_是底(g) { 返回 g[0] == CP_底 }
函数 CP_格_是常量(g) { 返回 g[0] == CP_常量 }
函数 CP_格_是顶(g) { 返回 g[0] == CP_顶 }

// Meet（格合并）：两个值的最大下界
// ⊥ meet X = X, X meet ⊤ = ⊤, c1 meet c2 = c1==c2 ? c1 : ⊤
函数 常量传播_交汇(a, b) {
    如果 (CP_格_是底(a)) { 返回 b }
    如果 (CP_格_是底(b)) { 返回 a }
    如果 (CP_格_是顶(a)) { 返回 CP_格_顶() }
    如果 (CP_格_是顶(b)) { 返回 CP_格_顶() }
    // 两者都是常量
    如果 (CP_格_值(a) == CP_格_值(b)) { 返回 a }
    返回 CP_格_顶()  // 不同常量 → 顶
}

// 常量传播环境（每个变量的格值）
// 结构：字典（变量名 → 格值）

函数 CP_环境_创建() { 返回 [字典(), 0] }  // [格表, 版本号]

函数 CP_环境_获取(env, 变量名) {
    定义 v = 字典取(env[0], 变量名)
    如果 (v == 空) { 返回 CP_格_底() }
    返回 v
}

函数 CP_环境_设置(env, 变量名, 格值) {
    字典设(env[0], 变量名, 格值)
    env[1] = env[1] + 1
}

// 合并两个环境（对每个变量做meet）
// 使用 字典键() 遍历两个环境中所有变量，逐变量执行 常量传播_交汇
函数 CP_环境_合并(env_a, env_b) {
    如果 (env_a[1] == 0) { 返回 env_b }
    如果 (env_b[1] == 0) { 返回 env_a }
    定义 可变 结果 = CP_环境_创建()
    // 遍历 env_a 的所有变量
    定义 键A = 字典键(env_a[0])
    定义 可变 i = 0
    当 (i < 计数(键A)) {
        定义 va = CP_环境_获取(env_a, 键A[i])
        定义 vb = CP_环境_获取(env_b, 键A[i])
        CP_环境_设置(结果, 键A[i], 常量传播_交汇(va, vb))
        i = i + 1
    }
    // 遍历 env_b 中 env_a 未覆盖的变量
    定义 键B = 字典键(env_b[0])
    i = 0
    当 (i < 计数(键B)) {
        如果 (字典有(env_a[0], 键B[i]) == 假) {
            定义 vb2 = CP_环境_获取(env_b, 键B[i])
            CP_环境_设置(结果, 键B[i], 常量传播_交汇(CP_格_底(), vb2))
        }
        i = i + 1
    }
    返回 结果
}

// 二元运算的常量求值
函数 CP_求值二元(运算符, 左格, 右格) {
    如果 (CP_格_是顶(左格) 或 CP_格_是顶(右格)) { 返回 CP_格_顶() }
    如果 (CP_格_是底(左格) 或 CP_格_是底(右格)) { 返回 CP_格_底() }
    // 两者都是常量，用常量折叠计算
    定义 左值 = CP_格_值(左格)
    定义 右值 = CP_格_值(右格)
    定义 结果 = 折叠_二元运算(运算符, 左值, 右值)
    如果 (结果 == 空) { 返回 CP_格_顶() }
    返回 CP_格_常量(结果)
}

// 一元运算的常量求值
函数 CP_求值一元(运算符, 格值) {
    如果 (CP_格_是顶(格值)) { 返回 CP_格_顶() }
    如果 (CP_格_是底(格值)) { 返回 CP_格_底() }
    定义 结果 = 折叠_一元运算(运算符, CP_格_值(格值))
    如果 (结果 == 空) { 返回 CP_格_顶() }
    返回 CP_格_常量(结果)
}

// AST节点的常量求值
// 节点类型：100=整数字面量, 104=二元运算, 其他...
函数 CP_求值节点(节点, 环境) {
    如果 (节点 == 空) { 返回 CP_格_底() }
    如果 (类型(节点) != 类型([])) {
        // 非列表：可能是直接的整数字面量
        如果 (类型(节点) == 类型()) { 返回 CP_格_常量(节点) }
        返回 CP_格_顶()
    }
    如果 (计数(节点) == 0) { 返回 CP_格_底() }

    定义 节点类型 = 节点[0]

    // 整数字面量
    如果 (节点类型 == 标记_数字 且 计数(节点) >= 2) {
        返回 CP_格_常量(节点[1])
    }
    // null字面量(165): 常量0
    如果 (节点类型 == 节点_空字面量) {
        返回 CP_格_常量(0)
    }

    // 标识符（变量引用）
    如果 (节点类型 == 标记_名称 且 计数(节点) >= 2) {
        返回 CP_环境_获取(环境, 节点[1])
    }

    // 二元运算
    如果 (节点类型 == 节点_二元 且 计数(节点) >= 4) {
        定义 运算符 = 节点[1]
        定义 左格 = CP_求值节点(节点[2], 环境)
        定义 右格 = CP_求值节点(节点[3], 环境)
        返回 CP_求值二元(运算符, 左格, 右格)
    }

    // 一元运算（节点类型=138=逻辑非, 139=位非, 取负）
    如果 (节点类型 == 节点_一元正 或 节点类型 == 节点_一元负) {
        如果 (计数(节点) >= 2) {
            定义 格值 = CP_求值节点(节点[1], 环境)
            定义 可变 _一元码 = 19
            如果 (节点类型 == 节点_一元正) { _一元码 = 18 }
            返回 CP_求值一元(_一元码, 格值)
        }
    }

    // 条件表达式：如果条件是常量，选择固定分支
    如果 (节点类型 == 标记_函数 且 计数(节点) >= 4) {
        定义 条件格 = CP_求值节点(节点[1], 环境)
        如果 (CP_格_是常量(条件格)) {
            如果 (CP_格_值(条件格) != 0) {
                返回 CP_求值节点(节点[2], 环境)  // 真分支
            }
            返回 CP_求值节点(节点[3], 环境)  // 假分支
        }
        // 条件不确定：合并两个分支的格值
        定义 真格 = CP_求值节点(节点[2], 环境)
        定义 假格 = CP_求值节点(节点[3], 环境)
        返回 常量传播_交汇(真格, 假格)
    }

    // 其他节点：无法确定常量值
    返回 CP_格_顶()
}

// 语句的常量传播（更新环境）
// 返回 [是否有变化, 更新后的环境]
函数 CP_传播语句(语句, 环境) {
    如果 (语句 == 空 或 计数(语句) == 0) { 返回 [假, 环境] }
    定义 类型 = 语句[0]

    // 定义语句（节点类型 110）
    如果 (类型 == 标记_定义 且 计数(语句) >= 3) {
        定义 变量名 = 语句[1]
        定义 初始化 = 语句[2]
        定义 新格值 = CP_求值节点(初始化, 环境)
        定义 旧格值 = CP_环境_获取(环境, 变量名)
        如果 (CP_格_类型(新格值) != CP_格_类型(旧格值) 或 
            (CP_格_是常量(新格值) 且 CP_格_值(新格值) != CP_格_值(旧格值))) {
            CP_环境_设置(环境, 变量名, 新格值)
            返回 [真, 环境]
        }
        返回 [假, 环境]
    }

    // 赋值语句（节点类型 111）
    如果 (类型 == 标记_可变 且 计数(语句) >= 3) {
        定义 变量名 = 语句[1]
        定义 表达式 = 语句[2]
        定义 新格值 = CP_求值节点(表达式, 环境)
        定义 旧格值 = CP_环境_获取(环境, 变量名)
        // 赋值时可能有多条路径，取meet
        定义 合并格值 = 常量传播_交汇(旧格值, 新格值)
        如果 (CP_格_类型(合并格值) != CP_格_类型(旧格值)) {
            CP_环境_设置(环境, 变量名, 合并格值)
            返回 [真, 环境]
        }
        返回 [假, 环境]
    }

    返回 [假, 环境]
}

// 函数级常量传播（遍历所有语句）
函数 CP_传播函数(语句列表) {
    定义 环境 = CP_环境_创建()
    定义 可变 总变化 = 0
    定义 可变 轮数 = 0
    定义 最大轮数 = 计数(语句列表) + 1

    当 (轮数 < 最大轮数) {
        定义 可变 本轮变化 = 0
        定义 可变 i = 0
        当 (i < 计数(语句列表)) {
            定义 结果 = CP_传播语句(语句列表[i], 环境)
            如果 (结果[0]) { 本轮变化 = 本轮变化 + 1 }
            i = i + 1
        }
        总变化 = 总变化 + 本轮变化
        如果 (本轮变化 == 0) { 返回 [环境, 轮数 + 1, 总变化] }
        轮数 = 轮数 + 1
    }
    返回 [环境, 轮数, 总变化]
}

// 检查节点是否为常量（用于折叠决策）
函数 CP_节点是常量(节点, 环境) {
    定义 格值 = CP_求值节点(节点, 环境)
    返回 CP_格_是常量(格值)
}

函数 CP_节点常量值(节点, 环境) {
    定义 格值 = CP_求值节点(节点, 环境)
    如果 (CP_格_是常量(格值)) { 返回 CP_格_值(格值) }
    返回 空
}

// 统计
定义 可变 _CP_传播次数 = 0
定义 可变 _CP_折叠次数 = 0
定义 可变 _CP_死代码次数 = 0

函数 CP_记录传播() { _CP_传播次数 = _CP_传播次数 + 1 }
函数 CP_记录折叠() { _CP_折叠次数 = _CP_折叠次数 + 1 }
函数 CP_记录死代码() { _CP_死代码次数 = _CP_死代码次数 + 1 }

函数 CP_统计报告() {
    返回 [_CP_传播次数, _CP_折叠次数, _CP_死代码次数]
}

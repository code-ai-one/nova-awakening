// 连接池_复用传控_安全连接 — NovaOS 企业级网络连接管理子系统
// 理论基础: LCAP (Link Cognition Allocation Protocol)
//   连接认知分配协议 — 通过时序热度、风险评分、复用收益三维联合
//   优化连接池资源使用，最小化握手延迟与安全暴露窗口。
// 创新公式:
//   Score(c) = α·Heat(c) + β·Reuse(c) - γ·Risk(c) - δ·Idle(c)
//   Evict(c) = min Score(c) under hard timeout constraints
// 架构:
//   16部分 — 常量/数据结构/初始化/复用检索/连接创建/超时巡检/
//            淘汰策略/熔断机制/TLS安全策略/AI预连接/统计诊断

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/内核打印.nova")
导入("../推理/值乘.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/创建甲.nova")
导入("./平台时间.nova")
导入("../中枢/字符串替换.nova")
导入("./网络创建.nova")
导入("../外联/安全创建.nova")

// 第1部分: 常量定义

定义 连接池_默认容量        = 256
定义 连接池_最大容量        = 2048
定义 连接池_熔断槽位        = 128
定义 连接池_预连接队列上限  = 256

定义 连接状态_空闲          = 0
定义 连接状态_使用中        = 1
定义 连接状态_关闭中        = 2
定义 连接状态_故障          = 3

定义 协议_TCP               = 1
定义 协议_TLS               = 2
定义 协议_QUIC              = 3

定义 TLS_版本_1_2           = 0x0303
定义 TLS_版本_1_3           = 0x0304
定义 TLS_默认最小版本        = TLS_版本_1_2

定义 空闲超时_默认毫秒       = 45000
定义 生命周期_默认毫秒       = 300000
定义 心跳间隔_默认毫秒       = 15000
定义 连接重试_最大次数       = 3
定义 连接重试_基础退避毫秒   = 40
定义 连接建立超时毫秒        = 4000

定义 风险阈值_高            = 0.72
定义 AI预连接_置信阈值      = 0.68
定义 AI预连接_最多创建       = 3

定义 淘汰策略_LRU           = 1
定义 淘汰策略_LFU           = 2
定义 淘汰策略_风险优先       = 3
定义 淘汰策略_LCAP综合       = 4

// LCAP权重参数
定义 LCAP_权重_热度         = 0.34
定义 LCAP_权重_复用         = 0.29
定义 LCAP_权重_风险         = 0.23
定义 LCAP_权重_空闲         = 0.14

// 第2部分: 数据结构

结构 连接池统计 {
    创建总数,
    复用命中数,
    复用未命中数,
    放回总数,
    主动关闭数,
    淘汰关闭数,
    超时关闭数,
    健康检查失败数,
    熔断拒绝数,
    TLS握手成功数,
    TLS握手失败数,
    证书验证失败数,
    会话恢复成功数,
    AI预连接触发数,
    AI预连接成功数,
    AI预连接失败数,
    当前活跃连接数,
    当前空闲连接数,
    总发送字节,
    总接收字节,
    总连接时延,
    最大连接时延,
}

结构 连接池 {
    // 核心连接元数据数组
    连接,            // 安全连接句柄
    主机,
    主机哈希,
    端口,
    协议,
    ALPN,
    状态,
    活跃,
    已握手,
    正在使用,
    创建时间,
    上次使用时间,
    最后心跳时间,
    空闲超时,
    最大寿命,
    往返时延估计,
    复用计数,
    连续失败次数,
    风险评分,
    热度评分,
    发送字节,
    接收字节,
    TLS版本,
    会话票据,
    证书指纹,
    // 熔断槽位
    熔断主机哈希,
    熔断失败次数,
    熔断开启,
    熔断截止时间,
    // 预连接队列
    预连接主机,
    预连接端口,
    预连接协议,
    预连接优先级,
    预连接入队时间,
    预连接大小,
    // 配置
    大小,
    容量,
    自动创建,
    默认协议,
    默认空闲超时,
    默认最大寿命,
    默认心跳间隔,
    淘汰策略,
    最小TLS版本,
    // 统计
    统计,
}

结构 连接请求 {
    主机,
    端口,
    协议,
    ALPN,
    最小TLS版本,
    允许自动创建,
}

// 第3部分: 全局状态

定义 可变 全局连接池 = 空
定义 可变 全局连接池统计 = 连接池统计 {}

// 第4部分: 哈希与工具函数

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 连接池_哈希主机端口协议(主机, 端口, 协议, ALPN) {
    // FNV-1a 64位变体
    定义 可变 h = 1469598103934665603
    定义 可变 i = 0
    当 (i < 字符串_长度(主机)) {
        h = h ^ 字符串_读字节(主机, i)
        h = h * 1099511628211
        i = i + 1
    }
    h = h ^ 端口
    h = h * 1099511628211
    h = h ^ 协议
    h = h * 1099511628211
    i = 0
    当 (i < 字符串_长度(ALPN)) {
        h = h ^ 字符串_读字节(ALPN, i)
        h = h * 1099511628211
        i = i + 1
    }
    返回 h
}

函数 连接池_当前时间() {
    返回 平台_获取高精度时间()
}

函数 连接池_是否过期(创建时间, 最大寿命, 当前时间) {
    如果 (最大寿命 <= 0) { 返回 假 }
    返回 (当前时间 - 创建时间) >= 最大寿命
}

函数 连接池_是否空闲超时(上次使用时间, 空闲超时, 当前时间) {
    如果 (空闲超时 <= 0) { 返回 假 }
    返回 (当前时间 - 上次使用时间) >= 空闲超时
}

函数 连接池_最小值(a, b) {
    如果 (a < b) { 返回 a }
    返回 b
}

函数 连接池_最大值(a, b) {
    如果 (a > b) { 返回 a }
    返回 b
}

函数 连接池_字符串相等(a, b) {
    如果 (a == 空 || b == 空) { 返回 假 }
    返回 字符串_相等(a, b)
}

// 第5部分: 初始化与销毁

函数 连接池_创建(容量) {
    定义 可变 cap = 容量
    如果 (cap <= 0) { cap = 连接池_默认容量 }
    如果 (cap > 连接池_最大容量) { cap = 连接池_最大容量 }

    定义 池 = 连接池 {}
    池.容量 = cap
    池.大小 = 0
    池.自动创建 = 真
    池.默认协议 = 协议_TLS
    池.默认空闲超时 = 空闲超时_默认毫秒
    池.默认最大寿命 = 生命周期_默认毫秒
    池.默认心跳间隔 = 心跳间隔_默认毫秒
    池.淘汰策略 = 淘汰策略_LCAP综合
    池.最小TLS版本 = TLS_默认最小版本
    池.预连接大小 = 0

    池.连接 = 创建数组(cap, 0)
    池.主机 = 创建数组(cap, "")
    池.主机哈希 = 创建数组(cap, 0)
    池.端口 = 创建数组(cap, 0)
    池.协议 = 创建数组(cap, 协议_TLS)
    池.ALPN = 创建数组(cap, "h2")
    池.状态 = 创建数组(cap, 连接状态_空闲)
    池.活跃 = 创建数组(cap, 假)
    池.已握手 = 创建数组(cap, 假)
    池.正在使用 = 创建数组(cap, 假)
    池.创建时间 = 创建数组(cap, 0)
    池.上次使用时间 = 创建数组(cap, 0)
    池.最后心跳时间 = 创建数组(cap, 0)
    池.空闲超时 = 创建数组(cap, 空闲超时_默认毫秒)
    池.最大寿命 = 创建数组(cap, 生命周期_默认毫秒)
    池.往返时延估计 = 创建数组(cap, 0)
    池.复用计数 = 创建数组(cap, 0)
    池.连续失败次数 = 创建数组(cap, 0)
    池.风险评分 = 创建数组(cap, 0.0)
    池.热度评分 = 创建数组(cap, 0.0)
    池.发送字节 = 创建数组(cap, 0)
    池.接收字节 = 创建数组(cap, 0)
    池.TLS版本 = 创建数组(cap, TLS_版本_1_2)
    池.会话票据 = 创建数组(cap, "")
    池.证书指纹 = 创建数组(cap, "")

    池.熔断主机哈希 = 创建数组(连接池_熔断槽位, 0)
    池.熔断失败次数 = 创建数组(连接池_熔断槽位, 0)
    池.熔断开启 = 创建数组(连接池_熔断槽位, 假)
    池.熔断截止时间 = 创建数组(连接池_熔断槽位, 0)

    池.预连接主机 = 创建数组(连接池_预连接队列上限, "")
    池.预连接端口 = 创建数组(连接池_预连接队列上限, 0)
    池.预连接协议 = 创建数组(连接池_预连接队列上限, 协议_TLS)
    池.预连接优先级 = 创建数组(连接池_预连接队列上限, 0.0)
    池.预连接入队时间 = 创建数组(连接池_预连接队列上限, 0)

    返回 池
}

函数 连接池_初始化全局(容量) {
    全局连接池 = 连接池_创建(容量)
    返回 全局连接池
}

函数 连接池_销毁(池) {
    如果 (池 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 池.大小) {
        如果 (池.连接[i] != 0) {
            安全_关闭(池.连接[i])
            池.连接[i] = 0
        }
        池.活跃[i] = 假
        i = i + 1
    }
    池.大小 = 0
}

// 第6部分: 连接匹配与复用评分

函数 连接池_是否可复用(池, i, 主机, 主机哈希, 端口, 协议, ALPN, 最小TLS版本) {
    如果 (!池.活跃[i]) { 返回 假 }
    如果 (池.正在使用[i]) { 返回 假 }
    如果 (池.状态[i] == 连接状态_故障 || 池.状态[i] == 连接状态_关闭中) { 返回 假 }
    如果 (池.主机哈希[i] != 主机哈希) { 返回 假 }
    如果 (池.端口[i] != 端口) { 返回 假 }
    如果 (池.协议[i] != 协议) { 返回 假 }
    如果 (!连接池_字符串相等(池.ALPN[i], ALPN)) { 返回 假 }
    如果 (池.TLS版本[i] < 最小TLS版本) { 返回 假 }
    如果 (!池.已握手[i]) { 返回 假 }
    返回 真
}

函数 连接池_LCAP评分(池, i, 当前时间) {
    // 归一化特征
    定义 空闲时长 = 当前时间 - 池.上次使用时间[i]
    定义 可变 idle_norm = 空闲时长 / 60000.0
    如果 (idle_norm > 1.0) { idle_norm = 1.0 }

    定义 可变 reuse_norm = 池.复用计数[i] / 64.0
    如果 (reuse_norm > 1.0) { reuse_norm = 1.0 }

    定义 可变 heat_norm = 池.热度评分[i]
    如果 (heat_norm < 0.0) { heat_norm = 0.0 }
    如果 (heat_norm > 1.0) { heat_norm = 1.0 }

    定义 可变 risk_norm = 池.风险评分[i]
    如果 (risk_norm < 0.0) { risk_norm = 0.0 }
    如果 (risk_norm > 1.0) { risk_norm = 1.0 }

    返回 LCAP_权重_热度 * heat_norm +
         LCAP_权重_复用 * reuse_norm -
         LCAP_权重_风险 * risk_norm -
         LCAP_权重_空闲 * idle_norm
}

函数 连接池_健康检查单连接(池, i, 当前时间) {
    如果 (!池.活跃[i]) { 返回 假 }
    如果 (池.连接[i] == 0) { 返回 假 }

    // 寿命检查
    如果 (连接池_是否过期(池.创建时间[i], 池.最大寿命[i], 当前时间)) {
        返回 假
    }
    // 空闲超时检查
    如果 (连接池_是否空闲超时(池.上次使用时间[i], 池.空闲超时[i], 当前时间)) {
        返回 假
    }
    // 底层传控状态检查
    如果 (!传控_已连接(池.连接[i].tcp)) {
        返回 假
    }
    返回 真
}

// 第7部分: 连接获取 (复用优先)

函数 连接池_获取(池, 主机, 端口) {
    // 兼容旧接口: 默认TLS+h2
    定义 req = 连接请求 {
        主机: 主机,
        端口: 端口,
        协议: 协议_TLS,
        ALPN: "h2",
        最小TLS版本: TLS_默认最小版本,
        允许自动创建: 真
    }
    返回 连接池_获取扩展(池, req)
}

函数 连接池_获取扩展(池, req) {
    如果 (池 == 0) { 返回 0 }
    定义 当前时间 = 连接池_当前时间()
    定义 主机哈希 = 连接池_哈希主机端口协议(req.主机, req.端口, req.协议, req.ALPN)

    // 熔断检查
    如果 (!连接池_熔断允许访问(池, 主机哈希, 当前时间)) {
        池.统计.熔断拒绝数 = 池.统计.熔断拒绝数 + 1
        返回 0
    }

    定义 可变 最佳索引 = -1
    定义 可变 最佳分数 = -999999.0
    定义 可变 i = 0
    当 (i < 池.大小) {
        如果 (连接池_是否可复用(池, i, req.主机, 主机哈希, req.端口, req.协议, req.ALPN, req.最小TLS版本)) {
            如果 (连接池_健康检查单连接(池, i, 当前时间)) {
                定义 score = 连接池_LCAP评分(池, i, 当前时间)
                如果 (score > 最佳分数) {
                    最佳分数 = score
                    最佳索引 = i
                }
            } 否则 {
                // 不健康立即关闭
                连接池_关闭索引(池, i, 真, "健康检查失败")
                池.统计.健康检查失败数 = 池.统计.健康检查失败数 + 1
            }
        }
        i = i + 1
    }

    如果 (最佳索引 >= 0) {
        池.正在使用[最佳索引] = 真
        池.状态[最佳索引] = 连接状态_使用中
        池.上次使用时间[最佳索引] = 当前时间
        池.复用计数[最佳索引] = 池.复用计数[最佳索引] + 1
        池.热度评分[最佳索引] = 连接池_最大值(池.热度评分[最佳索引], 0.6)

        池.统计.复用命中数 = 池.统计.复用命中数 + 1
        池.统计.当前活跃连接数 = 池.统计.当前活跃连接数 + 1
        返回 池.连接[最佳索引]
    }

    池.统计.复用未命中数 = 池.统计.复用未命中数 + 1

    // 未命中: 若允许自动创建则建立新连接
    如果 (req.允许自动创建 && 池.自动创建) {
        定义 tls = 连接池_创建安全连接(池, req)
        如果 (tls != 0) {
            连接池_放回扩展(池, tls, req.主机, req.端口, req.协议, req.ALPN, req.最小TLS版本)
            // 再次获取确保状态一致
            返回 连接池_获取扩展(池, req)
        }
    }
    返回 0
}

// 第8部分: 连接放回与入池

函数 连接池_放回(池, tls, 主机, 端口) {
    // 兼容旧接口
    连接池_放回扩展(池, tls, 主机, 端口, 协议_TLS, "h2", TLS_默认最小版本)
}

函数 连接池_放回扩展(池, tls, 主机, 端口, 协议, ALPN, 最小TLS版本) {
    如果 (池 == 0 || tls == 0) { 返回 }

    定义 当前时间 = 连接池_当前时间()
    定义 主机哈希 = 连接池_哈希主机端口协议(主机, 端口, 协议, ALPN)

    // 如果已存在同句柄项则更新状态
    定义 可变 i = 0
    当 (i < 池.大小) {
        如果 (池.连接[i] == tls) {
            池.正在使用[i] = 假
            池.状态[i] = 连接状态_空闲
            池.上次使用时间[i] = 当前时间
            池.活跃[i] = 真
            池.已握手[i] = 真
            池.热度评分[i] = 连接池_最大值(池.热度评分[i] * 0.95 + 0.05, 0.1)
            池.统计.放回总数 = 池.统计.放回总数 + 1
            如果 (池.统计.当前活跃连接数 > 0) {
                池.统计.当前活跃连接数 = 池.统计.当前活跃连接数 - 1
            }
            池.统计.当前空闲连接数 = 池.统计.当前空闲连接数 + 1
            返回
        }
        i = i + 1
    }

    // 新连接入池
    如果 (池.大小 >= 池.容量) {
        连接池_触发淘汰(池, 当前时间)
    }
    如果 (池.大小 >= 池.容量) {
        // 仍满, 强制淘汰最旧
        连接池_淘汰最旧(池)
    }
    如果 (池.大小 >= 池.容量) {
        // 极端情况仍无法释放，直接关闭
        安全_关闭(tls)
        返回
    }

    定义 idx = 池.大小
    池.连接[idx] = tls
    池.主机[idx] = 主机
    池.主机哈希[idx] = 主机哈希
    池.端口[idx] = 端口
    池.协议[idx] = 协议
    池.ALPN[idx] = ALPN
    池.状态[idx] = 连接状态_空闲
    池.活跃[idx] = 真
    池.已握手[idx] = 真
    池.正在使用[idx] = 假
    池.创建时间[idx] = 当前时间
    池.上次使用时间[idx] = 当前时间
    池.最后心跳时间[idx] = 当前时间
    池.空闲超时[idx] = 池.默认空闲超时
    池.最大寿命[idx] = 池.默认最大寿命
    池.往返时延估计[idx] = 0
    池.复用计数[idx] = 0
    池.连续失败次数[idx] = 0
    池.风险评分[idx] = 0.0
    池.热度评分[idx] = 0.5
    池.发送字节[idx] = 0
    池.接收字节[idx] = 0
    池.TLS版本[idx] = 最小TLS版本
    池.会话票据[idx] = ""
    池.证书指纹[idx] = ""

    池.大小 = 池.大小 + 1
    池.统计.创建总数 = 池.统计.创建总数 + 1
    池.统计.当前空闲连接数 = 池.统计.当前空闲连接数 + 1
}

// 第9部分: 连接创建与安全握手

函数 连接池_创建安全连接(池, req) {
    定义 开始 = 连接池_当前时间()
    定义 主机哈希 = 连接池_哈希主机端口协议(req.主机, req.端口, req.协议, req.ALPN)

    定义 可变 尝试 = 0
    当 (尝试 < 连接重试_最大次数) {
        定义 sock = 传控_创建()
        如果 (sock == 0) {
            尝试 = 尝试 + 1
            继续
        }

        传控_设置超时(sock, 连接建立超时毫秒)
        定义 rc = 传控_连接(sock, req.主机, req.端口)
        如果 (rc != 0) {
            传控_关闭(sock)
            尝试 = 尝试 + 1
            连接池_退避(尝试)
            连接池_熔断记录失败(池, 主机哈希)
            继续
        }

        // TLS连接
        定义 tls = 安全_创建(sock)
        如果 (tls == 0) {
            传控_关闭(sock)
            尝试 = 尝试 + 1
            连接池_退避(尝试)
            连接池_熔断记录失败(池, 主机哈希)
            继续
        }

        安全_设置最小版本(tls, req.最小TLS版本)
        安全_设置ALPN(tls, req.ALPN)
        安全_启用会话恢复(tls, 真)
        安全_设置主机名(tls, req.主机)

        定义 握手成功 = 安全_握手(tls, req.主机)
        如果 (!握手成功) {
            池.统计.TLS握手失败数 = 池.统计.TLS握手失败数 + 1
            安全_关闭(tls)
            尝试 = 尝试 + 1
            连接池_退避(尝试)
            连接池_熔断记录失败(池, 主机哈希)
            继续
        }

        池.统计.TLS握手成功数 = 池.统计.TLS握手成功数 + 1

        // 证书校验
        如果 (!连接池_验证证书(tls, req.主机)) {
            池.统计.证书验证失败数 = 池.统计.证书验证失败数 + 1
            安全_关闭(tls)
            尝试 = 尝试 + 1
            连接池_熔断记录失败(池, 主机哈希)
            继续
        }

        // 连接成功, 重置熔断失败
        连接池_熔断记录成功(池, 主机哈希)

        定义 耗时 = 连接池_当前时间() - 开始
        池.统计.总连接时延 = 池.统计.总连接时延 + 耗时
        池.统计.最大连接时延 = 连接池_最大值(池.统计.最大连接时延, 耗时)

        返回 tls
    }

    返回 0
}

函数 连接池_验证证书(tls, 主机) {
    // 链校验
    如果 (!安全_证书链验证(tls)) {
        返回 假
    }
    // 主机名校验
    如果 (!安全_证书校验主机名(tls, 主机)) {
        返回 假
    }
    // OCSP可用时检查
    如果 (安全_支持OCSP(tls)) {
        如果 (!安全_OCSP校验(tls)) {
            返回 假
        }
    }
    返回 真
}

函数 连接池_退避(尝试次数) {
    定义 backoff = 连接重试_基础退避毫秒 << 尝试次数
    如果 (backoff > 800) { backoff = 800 }
    平台_睡眠毫秒(backoff)
}

// 第10部分: 连接关闭与索引压缩

函数 连接池_关闭索引(池, idx, 是淘汰, 原因) {
    如果 (idx < 0 || idx >= 池.大小) { 返回 }
    如果 (池.连接[idx] != 0) {
        安全_关闭(池.连接[idx])
    }

    如果 (是淘汰) {
        池.统计.淘汰关闭数 = 池.统计.淘汰关闭数 + 1
    } 否则 {
        池.统计.主动关闭数 = 池.统计.主动关闭数 + 1
    }

    // 用末尾覆盖
    定义 尾 = 池.大小 - 1
    如果 (idx != 尾) {
        池.连接[idx] = 池.连接[尾]
        池.主机[idx] = 池.主机[尾]
        池.主机哈希[idx] = 池.主机哈希[尾]
        池.端口[idx] = 池.端口[尾]
        池.协议[idx] = 池.协议[尾]
        池.ALPN[idx] = 池.ALPN[尾]
        池.状态[idx] = 池.状态[尾]
        池.活跃[idx] = 池.活跃[尾]
        池.已握手[idx] = 池.已握手[尾]
        池.正在使用[idx] = 池.正在使用[尾]
        池.创建时间[idx] = 池.创建时间[尾]
        池.上次使用时间[idx] = 池.上次使用时间[尾]
        池.最后心跳时间[idx] = 池.最后心跳时间[尾]
        池.空闲超时[idx] = 池.空闲超时[尾]
        池.最大寿命[idx] = 池.最大寿命[尾]
        池.往返时延估计[idx] = 池.往返时延估计[尾]
        池.复用计数[idx] = 池.复用计数[尾]
        池.连续失败次数[idx] = 池.连续失败次数[尾]
        池.风险评分[idx] = 池.风险评分[尾]
        池.热度评分[idx] = 池.热度评分[尾]
        池.发送字节[idx] = 池.发送字节[尾]
        池.接收字节[idx] = 池.接收字节[尾]
        池.TLS版本[idx] = 池.TLS版本[尾]
        池.会话票据[idx] = 池.会话票据[尾]
        池.证书指纹[idx] = 池.证书指纹[尾]
    }

    池.大小 = 池.大小 - 1
    如果 (池.统计.当前空闲连接数 > 0) {
        池.统计.当前空闲连接数 = 池.统计.当前空闲连接数 - 1
    }
}

函数 安全_关闭(tls) {
    // 兼容旧接口
    如果 (tls == 0) { 返回 }
    安全_优雅关闭(tls)
    传控_关闭(tls.tcp)
    堆_释放(tls)
}

// 第11部分: 定时巡检与心跳管理

函数 连接池_巡检(池) {
    如果 (池 == 0) { 返回 }
    定义 当前时间 = 连接池_当前时间()
    定义 可变 i = 0
    当 (i < 池.大小) {
        如果 (!池.活跃[i]) {
            连接池_关闭索引(池, i, 假, "非活跃")
            继续
        }

        // 寿命与空闲超时检查
        如果 (连接池_是否过期(池.创建时间[i], 池.最大寿命[i], 当前时间)) {
            池.统计.超时关闭数 = 池.统计.超时关闭数 + 1
            连接池_关闭索引(池, i, 假, "寿命超时")
            继续
        }
        如果 (!池.正在使用[i] &&
            连接池_是否空闲超时(池.上次使用时间[i], 池.空闲超时[i], 当前时间)) {
            池.统计.超时关闭数 = 池.统计.超时关闭数 + 1
            连接池_关闭索引(池, i, 假, "空闲超时")
            继续
        }

        // 心跳检测
        如果 (!池.正在使用[i] &&
            (当前时间 - 池.最后心跳时间[i]) >= 池.默认心跳间隔) {
            如果 (!连接池_发送心跳(池, i)) {
                池.连续失败次数[i] = 池.连续失败次数[i] + 1
                池.风险评分[i] = 连接池_最小值(池.风险评分[i] + 0.12, 1.0)
                如果 (池.连续失败次数[i] >= 2) {
                    池.统计.健康检查失败数 = 池.统计.健康检查失败数 + 1
                    连接池_关闭索引(池, i, 假, "心跳失败")
                    继续
                }
            } 否则 {
                池.连续失败次数[i] = 0
                池.风险评分[i] = 连接池_最大值(池.风险评分[i] - 0.08, 0.0)
            }
            池.最后心跳时间[i] = 当前时间
        }

        // 热度衰减
        池.热度评分[i] = 池.热度评分[i] * 0.992
        i = i + 1
    }

    连接池_熔断巡检(池, 当前时间)
}

函数 连接池_发送心跳(池, idx) {
    如果 (idx < 0 || idx >= 池.大小) { 返回 假 }
    定义 tls = 池.连接[idx]
    如果 (tls == 0) { 返回 假 }
    // 发送协议级心跳探针 (例如HTTP/2 PING / TLS app data keepalive)
    定义 ok = 安全_心跳(tls)
    返回 ok
}

// 第12部分: 淘汰策略

函数 连接池_触发淘汰(池, 当前时间) {
    如果 (池.大小 <= 0) { 返回 }
    匹配 (池.淘汰策略) {
        淘汰策略_LRU => { 连接池_淘汰最旧(池) }
        淘汰策略_LFU => { 连接池_淘汰最低复用(池) }
        淘汰策略_风险优先 => { 连接池_淘汰最高风险(池) }
        _ => { 连接池_淘汰_LCAP综合(池, 当前时间) }
    }
}

函数 连接池_淘汰最旧(池) {
    如果 (池 == 0 || 池.大小 <= 0) { 返回 }
    定义 可变 最旧idx = -1
    定义 可变 最旧时间 = 9223372036854775807
    定义 可变 i = 0
    当 (i < 池.大小) {
        如果 (!池.正在使用[i] && 池.上次使用时间[i] < 最旧时间) {
            最旧时间 = 池.上次使用时间[i]
            最旧idx = i
        }
        i = i + 1
    }
    如果 (最旧idx >= 0) {
        连接池_关闭索引(池, 最旧idx, 真, "LRU淘汰")
    }
}

函数 连接池_淘汰最低复用(池) {
    如果 (池 == 0 || 池.大小 <= 0) { 返回 }
    定义 可变 target = -1
    定义 可变 minReuse = 2147483647
    定义 可变 i = 0
    当 (i < 池.大小) {
        如果 (!池.正在使用[i] && 池.复用计数[i] < minReuse) {
            minReuse = 池.复用计数[i]
            target = i
        }
        i = i + 1
    }
    如果 (target >= 0) {
        连接池_关闭索引(池, target, 真, "LFU淘汰")
    }
}

函数 连接池_淘汰最高风险(池) {
    如果 (池 == 0 || 池.大小 <= 0) { 返回 }
    定义 可变 target = -1
    定义 可变 maxRisk = -1.0
    定义 可变 i = 0
    当 (i < 池.大小) {
        如果 (!池.正在使用[i] && 池.风险评分[i] > maxRisk) {
            maxRisk = 池.风险评分[i]
            target = i
        }
        i = i + 1
    }
    如果 (target >= 0) {
        连接池_关闭索引(池, target, 真, "高风险淘汰")
    }
}

函数 连接池_淘汰_LCAP综合(池, 当前时间) {
    如果 (池 == 0 || 池.大小 <= 0) { 返回 }
    定义 可变 target = -1
    定义 可变 minScore = 999999.0
    定义 可变 i = 0
    当 (i < 池.大小) {
        如果 (!池.正在使用[i]) {
            定义 score = 连接池_LCAP评分(池, i, 当前时间)
            如果 (score < minScore) {
                minScore = score
                target = i
            }
        }
        i = i + 1
    }
    如果 (target >= 0) {
        连接池_关闭索引(池, target, 真, "LCAP综合淘汰")
    }
}

// 第13部分: 熔断机制

函数 连接池_熔断槽位索引(主机哈希) {
    返回 主机哈希 % 连接池_熔断槽位
}

函数 连接池_熔断允许访问(池, 主机哈希, 当前时间) {
    定义 idx = 连接池_熔断槽位索引(主机哈希)
    如果 (池.熔断主机哈希[idx] != 主机哈希) {
        // 新host覆盖槽位
        池.熔断主机哈希[idx] = 主机哈希
        池.熔断失败次数[idx] = 0
        池.熔断开启[idx] = 假
        池.熔断截止时间[idx] = 0
        返回 真
    }
    如果 (!池.熔断开启[idx]) { 返回 真 }
    如果 (当前时间 >= 池.熔断截止时间[idx]) {
        // 半开状态允许一次尝试
        池.熔断开启[idx] = 假
        池.熔断失败次数[idx] = 0
        返回 真
    }
    返回 假
}

函数 连接池_熔断记录失败(池, 主机哈希) {
    定义 idx = 连接池_熔断槽位索引(主机哈希)
    如果 (池.熔断主机哈希[idx] != 主机哈希) {
        池.熔断主机哈希[idx] = 主机哈希
        池.熔断失败次数[idx] = 0
        池.熔断开启[idx] = 假
        池.熔断截止时间[idx] = 0
    }
    池.熔断失败次数[idx] = 池.熔断失败次数[idx] + 1
    如果 (池.熔断失败次数[idx] >= 4) {
        池.熔断开启[idx] = 真
        池.熔断截止时间[idx] = 连接池_当前时间() + 10000  // 10秒
    }
}

函数 连接池_熔断记录成功(池, 主机哈希) {
    定义 idx = 连接池_熔断槽位索引(主机哈希)
    如果 (池.熔断主机哈希[idx] == 主机哈希) {
        池.熔断失败次数[idx] = 0
        池.熔断开启[idx] = 假
        池.熔断截止时间[idx] = 0
    }
}

函数 连接池_熔断巡检(池, 当前时间) {
    定义 可变 i = 0
    当 (i < 连接池_熔断槽位) {
        如果 (池.熔断开启[i] && 当前时间 >= 池.熔断截止时间[i]) {
            池.熔断开启[i] = 假
            池.熔断失败次数[i] = 0
        }
        i = i + 1
    }
}

// 第14部分: AI驱动预连接 (LCAP智能预测)

函数 AI网络_预连接(主机, 端口) {
    // 兼容旧接口: 使用全局连接池并默认TLS
    如果 (全局连接池 == 0) { 返回 }
    AI网络_预连接扩展(全局连接池, 主机, 端口, 协议_TLS, "h2")
}

函数 AI网络_预连接扩展(池, 主机, 端口, 协议, ALPN) {
    如果 (池 == 0) { 返回 }
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 }

    // 构建特征: 时间/历史命中/失败率/活跃连接密度等
    定义 feature = Tensor_创建(10)
    Tensor_写(feature, 0, 端口 / 65535.0)
    Tensor_写(feature, 1, 池.大小 / 池.容量)
    Tensor_写(feature, 2, 池.统计.复用命中数 / (池.统计.复用命中数 + 池.统计.复用未命中数 + 1.0))
    Tensor_写(feature, 3, 池.统计.TLS握手失败数 / (池.统计.TLS握手成功数 + 池.统计.TLS握手失败数 + 1.0))
    Tensor_写(feature, 4, 池.统计.当前活跃连接数 / (池.容量 + 1.0))
    Tensor_写(feature, 5, 池.统计.当前空闲连接数 / (池.容量 + 1.0))
    Tensor_写(feature, 6, 连接池_当前时间() % 86400000 / 86400000.0)
    Tensor_写(feature, 7, 协议 / 3.0)
    Tensor_写(feature, 8, 字符串_长度(主机) / 128.0)
    Tensor_写(feature, 9, 0.0)

    定义 预测 = AI总线_推理(bus, "LCAP_预连接概率", feature)
    定义 风险 = AI总线_风险评分(bus, "LCAP_预连接风险", feature)
    Tensor_释放(feature)

    池.统计.AI预连接触发数 = 池.统计.AI预连接触发数 + 1

    如果 (预测 < AI预连接_置信阈值) { 返回 }
    如果 (风险 > 风险阈值_高) { 返回 }

    // 入预连接队列
    连接池_预连接入队(池, 主机, 端口, 协议, 预测 - 风险)
    // 立即尝试消费一批
    连接池_执行预连接队列(池, AI预连接_最多创建)
}

函数 连接池_预连接入队(池, 主机, 端口, 协议, 优先级) {
    如果 (池.预连接大小 >= 连接池_预连接队列上限) {
        // 丢弃最低优先级项
        连接池_预连接淘汰最低优先级(池)
    }
    如果 (池.预连接大小 >= 连接池_预连接队列上限) { 返回 }

    定义 idx = 池.预连接大小
    池.预连接主机[idx] = 主机
    池.预连接端口[idx] = 端口
    池.预连接协议[idx] = 协议
    池.预连接优先级[idx] = 优先级
    池.预连接入队时间[idx] = 连接池_当前时间()
    池.预连接大小 = 池.预连接大小 + 1
}

函数 连接池_预连接淘汰最低优先级(池) {
    如果 (池.预连接大小 <= 0) { 返回 }
    定义 可变 idx = 0
    定义 可变 minP = 池.预连接优先级[0]
    定义 可变 i = 1
    当 (i < 池.预连接大小) {
        如果 (池.预连接优先级[i] < minP) {
            minP = 池.预连接优先级[i]
            idx = i
        }
        i = i + 1
    }
    连接池_预连接移除索引(池, idx)
}

函数 连接池_预连接移除索引(池, idx) {
    如果 (idx < 0 || idx >= 池.预连接大小) { 返回 }
    定义 tail = 池.预连接大小 - 1
    如果 (idx != tail) {
        池.预连接主机[idx] = 池.预连接主机[tail]
        池.预连接端口[idx] = 池.预连接端口[tail]
        池.预连接协议[idx] = 池.预连接协议[tail]
        池.预连接优先级[idx] = 池.预连接优先级[tail]
        池.预连接入队时间[idx] = 池.预连接入队时间[tail]
    }
    池.预连接大小 = 池.预连接大小 - 1
}

函数 连接池_执行预连接队列(池, 最大处理数) {
    如果 (池 == 0 || 池.预连接大小 <= 0) { 返回 }
    定义 可变 已处理 = 0
    当 (池.预连接大小 > 0 && 已处理 < 最大处理数) {
        定义 idx = 连接池_预连接取最高优先级(池)
        如果 (idx < 0) { 跳出 }

        定义 host = 池.预连接主机[idx]
        定义 port = 池.预连接端口[idx]
        定义 proto = 池.预连接协议[idx]
        连接池_预连接移除索引(池, idx)

        定义 req = 连接请求 {
            主机: host,
            端口: port,
            协议: proto,
            ALPN: "h2",
            最小TLS版本: 池.最小TLS版本,
            允许自动创建: 真
        }

        定义 tls = 连接池_创建安全连接(池, req)
        如果 (tls != 0) {
            连接池_放回扩展(池, tls, host, port, proto, "h2", 池.最小TLS版本)
            池.统计.AI预连接成功数 = 池.统计.AI预连接成功数 + 1
        } 否则 {
            池.统计.AI预连接失败数 = 池.统计.AI预连接失败数 + 1
        }

        已处理 = 已处理 + 1
    }
}

函数 连接池_预连接取最高优先级(池) {
    如果 (池.预连接大小 <= 0) { 返回 -1 }
    定义 可变 idx = 0
    定义 可变 maxP = 池.预连接优先级[0]
    定义 可变 i = 1
    当 (i < 池.预连接大小) {
        如果 (池.预连接优先级[i] > maxP) {
            maxP = 池.预连接优先级[i]
            idx = i
        }
        i = i + 1
    }
    返回 idx
}

// 第15部分: 安全策略与运行时控制

函数 连接池_设置最小TLS版本(池, 版本) {
    如果 (池 == 0) { 返回 }
    如果 (版本 < TLS_版本_1_2) { 版本 = TLS_版本_1_2 }
    如果 (版本 > TLS_版本_1_3) { 版本 = TLS_版本_1_3 }
    池.最小TLS版本 = 版本
}

函数 连接池_设置淘汰策略(池, 策略) {
    如果 (池 == 0) { 返回 }
    匹配 (策略) {
        淘汰策略_LRU => { 池.淘汰策略 = 策略 }
        淘汰策略_LFU => { 池.淘汰策略 = 策略 }
        淘汰策略_风险优先 => { 池.淘汰策略 = 策略 }
        淘汰策略_LCAP综合 => { 池.淘汰策略 = 策略 }
        _ => { 池.淘汰策略 = 淘汰策略_LCAP综合 }
    }
}

函数 连接池_设置超时配置(池, 空闲毫秒, 生命周期毫秒, 心跳毫秒) {
    如果 (池 == 0) { 返回 }
    如果 (空闲毫秒 > 0) { 池.默认空闲超时 = 空闲毫秒 }
    如果 (生命周期毫秒 > 0) { 池.默认最大寿命 = 生命周期毫秒 }
    如果 (心跳毫秒 > 0) { 池.默认心跳间隔 = 心跳毫秒 }
}

函数 连接池_启用自动创建(池, 启用) {
    如果 (池 == 0) { 返回 }
    池.自动创建 = 启用
}

// 第16部分: 统计诊断与后台维护入口

函数 连接池_记录传输(池, tls, 发送字节, 接收字节) {
    如果 (池 == 0 || tls == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 池.大小) {
        如果 (池.连接[i] == tls) {
            池.发送字节[i] = 池.发送字节[i] + 发送字节
            池.接收字节[i] = 池.接收字节[i] + 接收字节
            池.统计.总发送字节 = 池.统计.总发送字节 + 发送字节
            池.统计.总接收字节 = 池.统计.总接收字节 + 接收字节
            池.上次使用时间[i] = 连接池_当前时间()
            返回
        }
        i = i + 1
    }
}

函数 连接池_获取统计(池) {
    如果 (池 == 0) { 返回 全局连接池统计 }
    返回 {
        创建总数: 池.统计.创建总数,
        复用命中数: 池.统计.复用命中数,
        复用未命中数: 池.统计.复用未命中数,
        放回总数: 池.统计.放回总数,
        主动关闭数: 池.统计.主动关闭数,
        淘汰关闭数: 池.统计.淘汰关闭数,
        超时关闭数: 池.统计.超时关闭数,
        健康检查失败数: 池.统计.健康检查失败数,
        熔断拒绝数: 池.统计.熔断拒绝数,
        TLS握手成功数: 池.统计.TLS握手成功数,
        TLS握手失败数: 池.统计.TLS握手失败数,
        证书验证失败数: 池.统计.证书验证失败数,
        会话恢复成功数: 池.统计.会话恢复成功数,
        AI预连接触发数: 池.统计.AI预连接触发数,
        AI预连接成功数: 池.统计.AI预连接成功数,
        AI预连接失败数: 池.统计.AI预连接失败数,
        当前活跃连接数: 池.统计.当前活跃连接数,
        当前空闲连接数: 池.统计.当前空闲连接数,
        总发送字节: 池.统计.总发送字节,
        总接收字节: 池.统计.总接收字节,
        总连接时延: 池.统计.总连接时延,
        最大连接时延: 池.统计.最大连接时延,
        池大小: 池.大小,
        池容量: 池.容量,
        预连接队列大小: 池.预连接大小
    }
}

函数 连接池_打印统计(池) {
    定义 s = 连接池_获取统计(池)
    内核打印("═══ 连接池统计 ═══")
    内核打印("创建={} 命中={} 未命中={} 放回={}",
        s.创建总数, s.复用命中数, s.复用未命中数, s.放回总数)
    内核打印("关闭[主动/淘汰/超时]={}/{}/{} 健康失败={}",
        s.主动关闭数, s.淘汰关闭数, s.超时关闭数, s.健康检查失败数)
    内核打印("TLS[成功/失败]={}/{} 证书失败={} 熔断拒绝={}",
        s.TLS握手成功数, s.TLS握手失败数, s.证书验证失败数, s.熔断拒绝数)
    内核打印("AI预连接[触发/成功/失败]={}/{}/{}",
        s.AI预连接触发数, s.AI预连接成功数, s.AI预连接失败数)
    内核打印("活跃={} 空闲={} 队列={} 容量={}/{}",
        s.当前活跃连接数, s.当前空闲连接数, s.预连接队列大小, s.池大小, s.池容量)
}

函数 连接池_重置统计(池) {
    如果 (池 == 0) { 返回 }
    池.统计 = 连接池统计 {}
}

函数 连接池_后台维护循环(池, 运行标志引用) {
    // 由平台线程周期调用
    当 (运行标志引用.值) {
        连接池_巡检(池)
        连接池_执行预连接队列(池, 1)
        平台_睡眠毫秒(200)
    }
}

函数 连接池_诊断连接(池, idx) {
    如果 (池 == 0 || idx < 0 || idx >= 池.大小) { 返回 空 }
    返回 {
        主机: 池.主机[idx],
        端口: 池.端口[idx],
        协议: 池.协议[idx],
        ALPN: 池.ALPN[idx],
        状态: 池.状态[idx],
        活跃: 池.活跃[idx],
        正在使用: 池.正在使用[idx],
        已握手: 池.已握手[idx],
        复用计数: 池.复用计数[idx],
        风险评分: 池.风险评分[idx],
        热度评分: 池.热度评分[idx],
        空闲时长: 连接池_当前时间() - 池.上次使用时间[idx],
        生命周期: 连接池_当前时间() - 池.创建时间[idx],
        往返时延估计: 池.往返时延估计[idx]
    }
}

函数 连接池_批量预热(池, 目标列表) {
    如果 (池 == 0 || 目标列表 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 目标列表.长度) {
        定义 item = 目标列表[i]
        AI网络_预连接扩展(池, item.主机, item.端口, 协议_TLS, "h2")
        i = i + 1
    }
}

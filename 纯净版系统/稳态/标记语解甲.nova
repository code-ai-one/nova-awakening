导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../感知/内核直连层.nova")

定义 令牌_开标签 = 1
定义 令牌_闭标签 = 2
定义 令牌_自闭标签 = 3
定义 令牌_文本 = 4
定义 令牌_属性 = 5
定义 令牌_注释 = 6
定义 最大令牌 = 1024
定义 最大属性 = 16

结构 标记令牌 {
    类型,
    标签哈希,
    文本起始,
    文本长度,
    属性数,
    属性键,
    属性值,
}

定义 可变 令牌表 = []
定义 可变 令牌数 = 0
定义 可变 源数据 = 0
定义 可变 源长度 = 0
定义 可变 当前位 = 0
定义 可变 解析错误 = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 标记_初始化(数据, 长度) {
    令牌表 = []
    令牌数 = 0
    源数据 = 数据
    源长度 = 长度
    当前位 = 0
    解析错误 = 0
}

函数 标记_解析() {
    当 (当前位 < 源长度 && 令牌数 < 最大令牌) {
        定义 字节 = 内存_读8(源数据 + 当前位)
        如果 (字节 == 60) {
            标记_解析标签()
        } 否则 {
            标记_解析文本()
        }
    }
    返回 令牌数
}

函数 标记_解析标签() {
    当前位 = 当前位 + 1
    如果 (当前位 >= 源长度) { 解析错误 = 解析错误 + 1; 返回 }
    定义 首字节 = 内存_读8(源数据 + 当前位)
    如果 (首字节 == 47) {
        当前位 = 当前位 + 1
        定义 起始 = 当前位
        标记_跳过标签名()
        定义 令牌 = 标记令牌 {}
        令牌.类型 = 令牌_闭标签
        令牌.标签哈希 = 标记_哈希范围(起始, 当前位 - 起始)
        令牌.文本起始 = 起始
        令牌.文本长度 = 当前位 - 起始
        令牌.属性数 = 0
        追加(令牌表, 令牌)
        令牌数 = 令牌数 + 1
        标记_跳到(62)
        当前位 = 当前位 + 1
    } 否则 如果 (首字节 == 33) {
        标记_跳到(62)
        当前位 = 当前位 + 1
    } 否则 {
        定义 起始 = 当前位
        标记_跳过标签名()
        定义 令牌 = 标记令牌 {}
        令牌.标签哈希 = 标记_哈希范围(起始, 当前位 - 起始)
        令牌.文本起始 = 起始
        令牌.文本长度 = 当前位 - 起始
        令牌.属性键 = 堆_分配(最大属性 * 8)
        令牌.属性值 = 堆_分配(最大属性 * 8)
        令牌.属性数 = 0
        标记_解析属性(令牌)
        定义 结束字节 = 内存_读8(源数据 + 当前位 - 1)
        如果 (结束字节 == 47) {
            令牌.类型 = 令牌_自闭标签
        } 否则 {
            令牌.类型 = 令牌_开标签
        }
        追加(令牌表, 令牌)
        令牌数 = 令牌数 + 1
        如果 (当前位 < 源长度 && 内存_读8(源数据 + 当前位) == 62) {
            当前位 = 当前位 + 1
        }
    }
}

函数 标记_解析文本() {
    定义 起始 = 当前位
    当 (当前位 < 源长度 && 内存_读8(源数据 + 当前位) != 60) {
        当前位 = 当前位 + 1
    }
    如果 (当前位 > 起始) {
        定义 令牌 = 标记令牌 {}
        令牌.类型 = 令牌_文本
        令牌.标签哈希 = 0
        令牌.文本起始 = 起始
        令牌.文本长度 = 当前位 - 起始
        令牌.属性数 = 0
        追加(令牌表, 令牌)
        令牌数 = 令牌数 + 1
    }
}

函数 标记_解析属性(令牌) {
    当 (当前位 < 源长度 && 令牌.属性数 < 最大属性) {
        标记_跳过空白()
        定义 字节 = 内存_读8(源数据 + 当前位)
        如果 (字节 == 62 || 字节 == 47) { 返回 }
        定义 键起始 = 当前位
        当 (当前位 < 源长度) {
            定义 当前 = 内存_读8(源数据 + 当前位)
            如果 (当前 == 61 || 当前 == 32 || 当前 == 62) { 跳出 }
            当前位 = 当前位 + 1
        }
        定义 键哈希 = 标记_哈希范围(键起始, 当前位 - 键起始)
        定义 可变 值哈希 = 0
        如果 (当前位 < 源长度 && 内存_读8(源数据 + 当前位) == 61) {
            当前位 = 当前位 + 1
            如果 (当前位 < 源长度 && 内存_读8(源数据 + 当前位) == 34) {
                当前位 = 当前位 + 1
                定义 值起始 = 当前位
                标记_跳到(34)
                值哈希 = 标记_哈希范围(值起始, 当前位 - 值起始)
                当前位 = 当前位 + 1
            }
        }
        内存_写64(令牌.属性键 + 令牌.属性数 * 8, 键哈希)
        内存_写64(令牌.属性值 + 令牌.属性数 * 8, 值哈希)
        令牌.属性数 = 令牌.属性数 + 1
    }
}

函数 标记_跳过标签名() {
    当 (当前位 < 源长度) {
        定义 字节 = 内存_读8(源数据 + 当前位)
        如果 (字节 == 32 || 字节 == 62 || 字节 == 47 || 字节 == 10) { 返回 }
        当前位 = 当前位 + 1
    }
}

函数 标记_跳过空白() {
    当 (当前位 < 源长度) {
        定义 字节 = 内存_读8(源数据 + 当前位)
        如果 (字节 != 32 && 字节 != 9 && 字节 != 10 && 字节 != 13) { 返回 }
        当前位 = 当前位 + 1
    }
}

函数 标记_跳到(目标字节) {
    当 (当前位 < 源长度 && 内存_读8(源数据 + 当前位) != 目标字节) {
        当前位 = 当前位 + 1
    }
}

函数 标记_哈希范围(起始, 长度) {
    定义 可变 哈希 = 5381
    定义 可变 位 = 0
    当 (位 < 长度) {
        哈希 = 哈希 * 33 + 内存_读8(源数据 + 起始 + 位)
        位 = 位 + 1
    }
    返回 哈希 & 0x7FFFFFFF
}

函数 标记_获取令牌(索引) {
    如果 (索引 >= 令牌数) { 返回 0 }
    返回 令牌表[索引]
}

函数 标记解析器_完整统计() {
    返回 [令牌数, 当前位, 解析错误]
}

定义 可变 AI_标记语解甲_威胁计数 = 0

函数 AI_标记语解甲_风险评分(操作类型, 权限级别, 来源可信度) {
    定义 可变 风险 = 0
    如果 (权限级别 > 500) { 风险 = 风险 + 300 }
    如果 (来源可信度 < 200) { 风险 = 风险 + 400 }
    如果 (风险 > 500) { AI_标记语解甲_威胁计数 = AI_标记语解甲_威胁计数 + 1 }
    返回 风险
}

函数 AI_标记语解甲_异常行为检测(操作频率, 基线频率) {
    如果 (基线频率 > 0 && 操作频率 > 基线频率 * 5) { 返回 真 }
    返回 假
}

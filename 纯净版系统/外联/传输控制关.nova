// 连接关闭(四次挥手)

函数 tcp_关闭(tcb) {
    匹配 (tcb.状态) {
        传控_状态_已建立 => {
            tcp_发送FIN(tcb)
            tcb.状态 = 传控_状态_FIN_WAIT_1
        }
        传控_状态_CLOSE_WAIT => {
            tcp_发送FIN(tcb)
            tcb.状态 = 传控_状态_LAST_ACK
        }
        传控_状态_监听 => {
            tcb.状态 = 传控_状态_关闭
        }
        传控_状态_SYN已发送 => {
            tcb.状态 = 传控_状态_关闭
        }
        _ => {}
    }
    返回 0
}

// ACK处理

函数 tcp_处理ACK(tcb, 确认号) {
    如果 (tcb == 0) { 返回 }
    如果 (确认号 <= tcb.发送未确认 || 确认号 > tcb.发送下一个) {
        返回  // 无效ACK
    }

    // 清除已确认的重传段
    定义 可变 当前 = tcb.重传队列.头
    当 (当前 != 空) {
        定义 段序号 = tcp_获取序号(当前.数据)
        定义 段长度 = 当前.数据长度
        如果 (段序号 + 段长度 <= 确认号) {
            Nova网络缓冲_队列_出队(tcb.重传队列)
            当前 = tcb.重传队列.头
        } 否则 {
            跳出
        }
    }

    // 更新Nova往返时间估计
    如果 (tcb.Nova往返时间采样时间 > 0) {
        定义 Nova往返时间 = 当前时间_秒() - tcb.Nova往返时间采样时间
        tcp_更新Nova往返时间(tcb, Nova往返时间)
        tcb.Nova往返时间采样时间 = 0
    }

    tcb.发送未确认 = 确认号

    // 拥塞控制: 更新窗口
    tcp_拥塞_ACK(tcb)

    // 如果重传队列空了，停止重传定时器
    如果 (Nova网络缓冲_队列_为空(tcb.重传队列)) {
        tcp_停止重传定时器(tcb)
    }
}

// 辅助发送函数

函数 tcp_发送ACK(tcb) {
    如果 (tcb == 0) { 返回 }
    定义 可变 Nova缓冲 = Nova缓冲_分配(传控_头部大小)
    定义 头 = Nova缓冲.数据
    tcp_设置源端口(头, tcb.四元组.源端口)
    tcp_设置目标端口(头, tcb.四元组.目标端口)
    tcp_设置序号(头, tcb.发送序号)
    tcp_设置确认号(头, tcb.接收序号)
    tcp_设置标志(头, 传控_标志_ACK)
    tcp_设置窗口(头, tcb.接收窗口)
    tcp_发送段(tcb, Nova缓冲)
}

函数 tcp_发送FIN(tcb) {
    如果 (tcb == 0) { 返回 }
    定义 可变 Nova缓冲 = Nova缓冲_分配(传控_头部大小)
    定义 头 = Nova缓冲.数据
    tcp_设置源端口(头, tcb.四元组.源端口)
    tcp_设置目标端口(头, tcb.四元组.目标端口)
    tcp_设置序号(头, tcb.发送序号)
    tcp_设置确认号(头, tcb.接收序号)
    tcp_设置标志(头, 传控_标志_FIN | 传控_标志_ACK)
    tcp_设置窗口(头, tcb.接收窗口)
    tcb.发送序号 = tcb.发送序号 + 1
    Nova网络缓冲_队列_入队(tcb.重传队列, Nova缓冲)
    tcp_发送段(tcb, Nova缓冲)
}

函数 tcp_发送RST(原始Nova缓冲) {
    定义 可变 Nova缓冲 = Nova缓冲_分配(传控_头部大小)
    定义 头 = Nova缓冲.数据
    定义 原始头 = 原始Nova缓冲.数据 + 原始Nova缓冲.传输层偏移
    tcp_设置源端口(头, tcp_获取目标端口(原始头))
    tcp_设置目标端口(头, tcp_获取源端口(原始头))
    tcp_设置序号(头, tcp_获取确认号(原始头))
    tcp_设置确认号(头, 0)
    tcp_设置标志(头, 传控_标志_RST)
    // 直接通过IP层发送
    IP_发送(Nova缓冲, 原始Nova缓冲.源IP)
}

函数 tcp_发送SYN_ACK(tcb) {
    如果 (tcb == 0) { 返回 }
    定义 可变 Nova缓冲 = Nova缓冲_分配(传控_头部大小 + 传控_选项最大大小)
    定义 头 = Nova缓冲.数据
    tcp_设置源端口(头, tcb.四元组.源端口)
    tcp_设置目标端口(头, tcb.四元组.目标端口)
    tcp_设置序号(头, tcb.发送序号)
    tcp_设置确认号(头, tcb.接收序号)
    tcp_设置标志(头, 传控_标志_SYN | 传控_标志_ACK)
    tcp_设置窗口(头, tcb.接收窗口)
    tcp_添加MSS选项(头, tcb.mss)
    tcb.发送序号 = tcb.发送序号 + 1
    tcp_发送段(tcb, Nova缓冲)
}

函数 tcp_发送段(tcb, Nova缓冲) {
    如果 (tcb == 0) { 返回 }
    // 计算校验和
    tcp_计算校验和(Nova缓冲, tcb.四元组.源IP, tcb.四元组.目标IP)
    // 交给IP层发送
    返回 IP_发送(Nova缓冲, tcb.四元组.目标IP)
}

// [v2反哺新增] BBR拥塞控制 — 网络协议升级: BBR带宽估计拥塞控制(Google 2016, 比Reno吞吐量+300%)
// BBR拥塞控制 (Google 2016, 带宽瓶颈估计)
// 类人脑: 感知-预测-行动闭环，类似小脑前馈控制
// 改进: 传统Reno/CUBIC基于丢包 → BBR基于带宽测量
// 核心: max_bw × min_rtt = 最优传输量
函数 BBR_更新带宽(bbr, 已确认字节, 时间间隔) {
    如果 (bbr == 0 || 时间间隔 == 0) { 返回 }
    // 瞬时带宽 = 确认字节 / 时间间隔 (Q格式)
    定义 instant_bw = 已确认字节 * Q_ONE / 时间间隔
    // 滑动最大带宽(10轮时间窗)
    如果 (instant_bw > bbr.max_bw) { bbr.max_bw = instant_bw }
    bbr.窗口计数 = bbr.窗口计数 + 1
    如果 (bbr.窗口计数 >= 10) {
        bbr.窗口计数 = 0
        bbr.max_bw = Q乘(bbr.max_bw, 900)  // 0.9衰减,防止历史过期
    }
}
函数 BBR_计算发送窗口(bbr) {
    如果 (bbr == 0 || bbr.min_rtt == 0) { 返回 65536 }
    // BDP = max_bw × min_rtt
    定义 bdp = Q乘(bbr.max_bw, bbr.min_rtt)
    // 发送窗口 = 2 × BDP (双倍以充分利用带宽)
    返回 bdp * 2 / Q_ONE
}

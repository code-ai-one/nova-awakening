导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("./原生系统图处.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内核打印.nova")
导入("../引导/端口输入.nova")
导入("../中枢/整数转字符串.nova")

定义 图处_CAP_3D渲染 = 0x01
定义 图处_CAP_视频解码 = 0x02
定义 图处_CAP_视频编码 = 0x04
定义 图处_CAP_计算 = 0x08
定义 图处_CAP_智能_ACCEL = 0x10
定义 图处_CAP_光线追踪 = 0x20
定义 图处_CAP_张量核心 = 0x40
定义 图处_CAP_显示输出 = 0x80

定义 图处_供应商_NVIDIA = 0x10DE
定义 图处_供应商_AMD = 0x1002
定义 图处_供应商_INTEL = 0x8086
定义 图处_供应商_VIRTIO = 0x1AF4

结构 图处信息 {
    供应商ID,
    设备ID,
    修订版本,
    显存大小_MB,
    计算单元数,
    核心频率_MHz,
    显存频率_MHz,
    能力,
    总线号,
    设备号,
    功能号,
    MMIO基址,
    MMIO大小,
    温度,
    功耗_mW,
    驱动版本,
    名称,
}

定义 可变 图处列表 = []
定义 可变 主图处 = 空
定义 可变 计算图处 = 空
定义 可变 图处_已检测 = 0
定义 可变 图处_供应商ID = 0
定义 可变 图处_设备ID = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 图处_数量() { 返回 计数(图处列表) }
函数 图处_获取主设备() { 返回 主图处 }
函数 图处_获取计算设备() { 返回 计算图处 }

函数 图处_有AI加速() {
    如果 (计算图处 == 空) { 返回 假 }
    返回 (计算图处.能力 & 图处_CAP_智能_ACCEL) != 0
}

函数 图处_有光线追踪() {
    如果 (主图处 == 空) { 返回 假 }
    返回 (主图处.能力 & 图处_CAP_光线追踪) != 0
}

函数 图处_有张量核心() {
    如果 (计算图处 == 空) { 返回 假 }
    返回 (计算图处.能力 & 图处_CAP_张量核心) != 0
}

函数 图处_获取列表() { 返回 图处列表 }

函数 图处_按索引获取(索引) {
    如果 (索引 < 0 || 索引 >= 计数(图处列表)) { 返回 空 }
    返回 图处列表[索引]
}

函数 图处_按供应商查找(供应商ID) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(图处列表)) {
        如果 (图处列表[i].供应商ID == 供应商ID) {
            追加(结果, 图处列表[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 图处_获取最强计算() {
    定义 可变 最强 = 空
    定义 可变 最大计算力 = 0
    定义 可变 i = 0
    当 (i < 计数(图处列表)) {
        定义 g = 图处列表[i]
        如果 ((g.能力 & 图处_CAP_计算) != 0) {
            定义 计算力 = g.计算单元数 * g.核心频率_MHz
            如果 (计算力 > 最大计算力) {
                最大计算力 = 计算力
                最强 = g
            }
        }
        i = i + 1
    }
    返回 最强
}

函数 图处_总显存_MB() {
    定义 可变 总计 = 0
    定义 可变 i = 0
    当 (i < 计数(图处列表)) {
        总计 = 总计 + 图处列表[i].显存大小_MB
        i = i + 1
    }
    返回 总计
}

函数 图处_统计() {
    返回 [计数(图处列表),
           (主图处 != 空) ? 主图处.显存大小_MB : 0,
           (计算图处 != 空) ? 计算图处.计算单元数 : 0]
}

函数 图处_供应商名称(供应商ID) {
    如果 (供应商ID == 图处_供应商_NVIDIA) { 返回 "NVIDIA" }
    如果 (供应商ID == 图处_供应商_AMD) { 返回 "AMD" }
    如果 (供应商ID == 图处_供应商_INTEL) { 返回 "Intel" }
    如果 (供应商ID == 图处_供应商_VIRTIO) { 返回 "VirtIO" }
    返回 "未知"
}

函数 图处_能力字符串(能力) {
    定义 可变 结果 = ""
    如果 ((能力 & 图处_CAP_3D渲染) != 0) { 结果 = 结果 + "3D " }
    如果 ((能力 & 图处_CAP_视频解码) != 0) { 结果 = 结果 + "解码 " }
    如果 ((能力 & 图处_CAP_视频编码) != 0) { 结果 = 结果 + "编码 " }
    如果 ((能力 & 图处_CAP_计算) != 0) { 结果 = 结果 + "计算 " }
    如果 ((能力 & 图处_CAP_智能_ACCEL) != 0) { 结果 = 结果 + "AI " }
    如果 ((能力 & 图处_CAP_光线追踪) != 0) { 结果 = 结果 + "光追 " }
    如果 ((能力 & 图处_CAP_张量核心) != 0) { 结果 = 结果 + "张量 " }
    如果 ((能力 & 图处_CAP_显示输出) != 0) { 结果 = 结果 + "显示 " }
    返回 结果
}

函数 图处_读温度(图处) {
    如果 (图处 == 空 || 图处.MMIO基址 == 0) { 返回 -1 }
    如果 (图处.供应商ID == 图处_供应商_NVIDIA) {
        返回 MMIO_读32(图处.MMIO基址 + 0x20400) & 0x1FF
    }
    如果 (图处.供应商ID == 图处_供应商_AMD) {
        定义 原始 = MMIO_读32(图处.MMIO基址 + 0xC0300E0C)
        返回 (原始 >> 21) & 0x7FF
    }
    返回 -1
}

函数 图处_读功耗(图处) {
    如果 (图处 == 空 || 图处.MMIO基址 == 0) { 返回 -1 }
    如果 (图处.供应商ID == 图处_供应商_NVIDIA) {
        返回 MMIO_读32(图处.MMIO基址 + 0x20800) & 0xFFFF
    }
    返回 -1
}

函数 图处_更新传感器() {
    定义 可变 i = 0
    当 (i < 计数(图处列表)) {
        定义 g = 图处列表[i]
        g.温度 = 图处_读温度(g)
        g.功耗_mW = 图处_读功耗(g)
        i = i + 1
    }
}

函数 图处_打印信息(图处) {
    如果 (图处 == 空) { 返回 }
    打印行("=== GPU: " + 图处.名称 + " ===")
    打印行("供应商: " + 图处_供应商名称(图处.供应商ID)
        + " (0x" + 整数转十六进制(图处.供应商ID) + ")")
    打印行("设备ID: 0x" + 整数转十六进制(图处.设备ID))
    打印行("显存: " + 整数转字符串(图处.显存大小_MB) + " MB")
    打印行("计算单元: " + 整数转字符串(图处.计算单元数))
    打印行("核心频率: " + 整数转字符串(图处.核心频率_MHz) + " MHz")
    打印行("显存频率: " + 整数转字符串(图处.显存频率_MHz) + " MHz")
    打印行("能力: " + 图处_能力字符串(图处.能力))
    打印行("PCI: " + 整数转字符串(图处.总线号) + ":"
        + 整数转字符串(图处.设备号) + "."
        + 整数转字符串(图处.功能号))
    如果 (图处.温度 >= 0) {
        打印行("温度: " + 整数转字符串(图处.温度) + "°C")
    }
    如果 (图处.功耗_mW > 0) {
        打印行("功耗: " + 整数转字符串(图处.功耗_mW / 1000) + "."
            + 整数转字符串((图处.功耗_mW % 1000) / 100) + "W")
    }
}

函数 图处_打印全部() {
    打印行("检测到 " + 整数转字符串(计数(图处列表)) + " 个GPU")
    定义 可变 i = 0
    当 (i < 计数(图处列表)) {
        图处_打印信息(图处列表[i])
        i = i + 1
    }
    打印行("总显存: " + 整数转字符串(图处_总显存_MB()) + " MB")
}

函数 PCI_配置读32(总线, 设备, 功能, 偏移) {
    定义 地址 = 0x80000000 | (总线 << 16) | (设备 << 11) | (功能 << 8) | (偏移 & 0xFC)
    端口写32(0xCF8, 地址)
    返回 端口读32(0xCFC)
}

函数 PCI_配置写32(总线, 设备, 功能, 偏移, 值) {
    定义 地址 = 0x80000000 | (总线 << 16) | (设备 << 11) | (功能 << 8) | (偏移 & 0xFC)
    端口写32(0xCF8, 地址)
    端口写32(0xCFC, 值)
}

函数 PCI_读BAR(总线, 设备, 功能, BAR索引) {
    定义 偏移 = 0x10 + BAR索引 * 4
    定义 值 = PCI_配置读32(总线, 设备, 功能, 偏移)
    如果 ((值 & 1) == 0) { 返回 值 & 0xFFFFFFF0 }
    返回 值 & 0xFFFFFFFC
}

函数 PCI_BAR大小(总线, 设备, 功能, BAR索引) {
    定义 偏移 = 0x10 + BAR索引 * 4
    定义 原值 = PCI_配置读32(总线, 设备, 功能, 偏移)
    PCI_配置写32(总线, 设备, 功能, 偏移, 0xFFFFFFFF)
    定义 掩码 = PCI_配置读32(总线, 设备, 功能, 偏移)
    PCI_配置写32(总线, 设备, 功能, 偏移, 原值)
    如果 (掩码 == 0 || 掩码 == 0xFFFFFFFF) { 返回 0 }
    掩码 = 掩码 & 0xFFFFFFF0
    返回 (~掩码) + 1
}

函数 PCI_读BAR64(总线, 设备, 功能, BAR索引) {
    定义 低 = PCI_配置读32(总线, 设备, 功能, 0x10 + BAR索引 * 4)
    定义 高 = PCI_配置读32(总线, 设备, 功能, 0x10 + (BAR索引 + 1) * 4)
    返回 ((高 & 0xFFFFFFFF) << 32) | (低 & 0xFFFFFFF0)
}

函数 图处识别_完整统计() {
    图处_更新传感器()
    返回 [图处_已检测, 图处_供应商ID, 图处_设备ID,
           图处_总显存_MB(), 计数(图处列表)]
}

// Nova · 编译器 · 循环分析 (Loop Analysis)
// 识别自然循环 + 循环嵌套树 + 循环深度 + 循环不变量
// 基于支配树的回边识别算法

// 循环结构：[头块ID, 回边块ID, 循环体块ID列表, 父循环ID, 子循环ID列表, 深度, 不变量列表]

导入("../../标准库/基础.nova")
导入("./支配树.nova")
导入("./数据流分析.nova")

函数 循环_创建(头块ID, 回边块ID) {
    返回 [头块ID, 回边块ID, [], -1, [], 0, []]
}
函数 循环_头块(loop) { 返回 loop[0] }
函数 循环_回边块(loop) { 返回 loop[1] }
函数 循环_体(loop) { 返回 loop[2] }
函数 循环_父ID(loop) { 返回 loop[3] }
函数 循环_子循环(loop) { 返回 loop[4] }
函数 循环_深度(loop) { 返回 loop[5] }
函数 循环_不变量(loop) { 返回 loop[6] }
函数 循环_设深度(loop, d) { loop[5] = d }
函数 循环_设父(loop, id) { loop[3] = id }

// 回边识别
// 回边：在DFS树中，目标节点支配源节点的边 (b → a, a dom b)
函数 循环分析_找回边(cfg, 支配树) {
    定义 块列表 = 数流_CFG_块列表(cfg)
    定义 可变 回边列表 = []  // [[回边源, 回边目标(头块)]]
    定义 可变 i = 0
    当 (i < 计数(块列表)) {
        定义 块 = 块列表[i]
        定义 块ID = 数流_块_ID(块)
        定义 后继列表 = 数流_块_后继(块)
        定义 可变 j = 0
        当 (j < 计数(后继列表)) {
            定义 后继ID = 后继列表[j]
            // 检查后继是否支配当前块（回边条件）
            如果 (支配树_a支配b(支配树, 后继ID, 块ID)) {
                追加(回边列表, [块ID, 后继ID])
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 回边列表
}

// 自然循环体计算
// 从回边(b→h)出发，向上BFS找所有在h支配的能到达b的块
函数 循环分析_计算循环体(cfg, 头块ID, 回边块ID) {
    定义 可变 循环体 = [头块ID]
    定义 可变 工作队列 = []

    // 如果回边块不是头块，加入工作队列
    如果 (回边块ID != 头块ID) {
        追加(工作队列, 回边块ID)
        追加(循环体, 回边块ID)
    }

    定义 可变 i = 0
    当 (i < 计数(工作队列)) {
        定义 当前ID = 工作队列[i]
        i = i + 1

        定义 当前块 = 数流_CFG_查找块(cfg, 当前ID)
        如果 (当前块 == 空) { 继续 }

        // 遍历当前块的前驱
        定义 前驱列表 = 数流_块_前驱(当前块)
        定义 可变 j = 0
        当 (j < 计数(前驱列表)) {
            定义 前驱ID = 前驱列表[j]
            // 检查是否已在循环体中
            定义 可变 已在 = 假
            定义 可变 k = 0
            当 (k < 计数(循环体)) {
                如果 (循环体[k] == 前驱ID) { 已在 = 真 }
                k = k + 1
            }
            如果 (已在 == 假) {
                追加(循环体, 前驱ID)
                追加(工作队列, 前驱ID)
            }
            j = j + 1
        }
    }
    返回 循环体
}

// 主循环分析函数
// 输入：CFG + 支配树
// 输出：循环列表 + 循环嵌套关系
函数 循环分析_分析(cfg, 支配树) {
    // 找所有回边
    定义 回边列表 = 循环分析_找回边(cfg, 支配树)
    定义 可变 循环列表 = []

    // 为每条回边创建自然循环
    定义 可变 i = 0
    当 (i < 计数(回边列表)) {
        定义 回边 = 回边列表[i]
        定义 回边源 = 回边[0]
        定义 头块ID = 回边[1]

        // 计算循环体
        定义 循环体 = 循环分析_计算循环体(cfg, 头块ID, 回边源)

        // 合并：如果多条回边有相同头块，合并循环体
        定义 可变 已有循环 = -1
        定义 可变 j = 0
        当 (j < 计数(循环列表)) {
            如果 (循环_头块(循环列表[j]) == 头块ID) { 已有循环 = j }
            j = j + 1
        }

        如果 (已有循环 >= 0) {
            // 合并循环体
            j = 0
            当 (j < 计数(循环体)) {
                定义 块ID = 循环体[j]
                定义 可变 已有 = 假
                定义 可变 k = 0
                当 (k < 计数(循环_体(循环列表[已有循环]))) {
                    如果 (循环_体(循环列表[已有循环])[k] == 块ID) { 已有 = 真 }
                    k = k + 1
                }
                如果 (已有 == 假) { 追加(循环列表[已有循环][2], 块ID) }
                j = j + 1
            }
        } 否则 {
            定义 新循环 = 循环_创建(头块ID, 回边源)
            新循环[2] = 循环体
            追加(循环列表, 新循环)
        }
        i = i + 1
    }

    // 计算循环嵌套关系和深度
    循环分析_计算嵌套(循环列表)

    返回 循环列表
}

// 循环嵌套计算
// 如果循环A的头块在循环B的体内，则A是B的子循环
函数 循环分析_计算嵌套(循环列表) {
    定义 n = 计数(循环列表)

    // 建立父子关系
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 j = 0
        当 (j < n) {
            如果 (i != j) {
                定义 头块 = 循环_头块(循环列表[i])
                定义 体 = 循环_体(循环列表[j])
                // 检查i的头块是否在j的体内（i是j的子循环）
                定义 可变 在体内 = 假
                定义 可变 k = 0
                当 (k < 计数(体)) {
                    如果 (体[k] == 头块) { 在体内 = 真 }
                    k = k + 1
                }
                如果 (在体内) {
                    // i是j的潜在子循环：取最近的（最小的循环体）
                    定义 当前父 = 循环_父ID(循环列表[i])
                    如果 (当前父 < 0) {
                        循环_设父(循环列表[i], j)
                        追加(循环列表[j][4], i)
                    } 否则 {
                        // 选体更小的作为父（更近的祖先）
                        如果 (计数(体) < 计数(循环_体(循环列表[当前父]))) {
                            // 从旧父的子列表中移除
                            定义 旧子列表 = 循环列表[当前父][4]
                            定义 可变 新子列表 = []
                            定义 可变 m = 0
                            当 (m < 计数(旧子列表)) {
                                如果 (旧子列表[m] != i) { 追加(新子列表, 旧子列表[m]) }
                                m = m + 1
                            }
                            循环列表[当前父][4] = 新子列表
                            循环_设父(循环列表[i], j)
                            追加(循环列表[j][4], i)
                        }
                    }
                }
            }
            j = j + 1
        }
        i = i + 1
    }

    // 计算深度（从根循环出发BFS）
    i = 0
    当 (i < n) {
        如果 (循环_父ID(循环列表[i]) < 0) {
            // 根循环，深度=1
            循环_计算深度(循环列表, i, 1)
        }
        i = i + 1
    }
}

函数 循环_计算深度(循环列表, 循环idx, 深度) {
    循环_设深度(循环列表[循环idx], 深度)
    定义 子循环 = 循环_子循环(循环列表[循环idx])
    定义 可变 i = 0
    当 (i < 计数(子循环)) {
        循环_计算深度(循环列表, 子循环[i], 深度 + 1)
        i = i + 1
    }
}

// 循环不变量检测
// 不变量：在循环内计算但不依赖循环变量的表达式
// 简化版：检测变量是否在循环体内被赋值
函数 循环分析_找不变量(循环, cfg) {
    定义 循环体 = 循环_体(循环)
    定义 可变 循环内定义 = []  // 在循环内定义的变量

    // 收集循环内所有被赋值的变量
    定义 可变 i = 0
    当 (i < 计数(循环体)) {
        定义 块 = 数流_CFG_查找块(cfg, 循环体[i])
        如果 (块 != 空) {
            定义 kill集 = 数流_块_KILL(块)
            定义 可变 j = 0
            当 (j < 计数(kill集)) {
                定义 可变 已有 = 假
                定义 可变 k = 0
                当 (k < 计数(循环内定义)) {
                    如果 (循环内定义[k] == kill集[j]) { 已有 = 真 }
                    k = k + 1
                }
                如果 (已有 == 假) { 追加(循环内定义, kill集[j]) }
                j = j + 1
            }
        }
        i = i + 1
    }

    // 找只使用循环外变量的表达式（不变量）
    定义 可变 不变量 = []
    i = 0
    当 (i < 计数(循环体)) {
        定义 块 = 数流_CFG_查找块(cfg, 循环体[i])
        如果 (块 != 空) {
            定义 gen集 = 数流_块_GEN(块)
            定义 可变 j = 0
            当 (j < 计数(gen集)) {
                定义 变量 = gen集[j]
                // 如果变量不在循环内定义，则是不变量候选
                定义 可变 在内部定义 = 假
                定义 可变 k = 0
                当 (k < 计数(循环内定义)) {
                    如果 (循环内定义[k] == 变量) { 在内部定义 = 真 }
                    k = k + 1
                }
                如果 (在内部定义 == 假) { 追加(不变量, 变量) }
                j = j + 1
            }
        }
        i = i + 1
    }

    循环[6] = 不变量
    返回 不变量
}

// 循环查询接口

// 块是否在某个循环的体内
函数 循环分析_块在循环内(循环列表, 块ID) {
    定义 可变 i = 0
    当 (i < 计数(循环列表)) {
        定义 体 = 循环_体(循环列表[i])
        定义 可变 j = 0
        当 (j < 计数(体)) {
            如果 (体[j] == 块ID) { 返回 i }  // 返回循环索引
            j = j + 1
        }
        i = i + 1
    }
    返回 0 - 1  // 不在任何循环内
}

// 块的最深循环深度
函数 循环分析_块深度(循环列表, 块ID) {
    定义 可变 最深 = 0
    定义 可变 i = 0
    当 (i < 计数(循环列表)) {
        定义 体 = 循环_体(循环列表[i])
        定义 可变 j = 0
        当 (j < 计数(体)) {
            如果 (体[j] == 块ID) {
                定义 d = 循环_深度(循环列表[i])
                如果 (d > 最深) { 最深 = d }
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 最深
}

// 获取所有顶层循环（无父循环）
函数 循环分析_顶层循环(循环列表) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(循环列表)) {
        如果 (循环_父ID(循环列表[i]) < 0) {
            追加(结果, i)
        }
        i = i + 1
    }
    返回 结果
}

// 循环统计报告
函数 循环分析_报告(循环列表) {
    定义 n = 计数(循环列表)
    定义 可变 最大深度 = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (循环_深度(循环列表[i]) > 最大深度) {
            最大深度 = 循环_深度(循环列表[i])
        }
        i = i + 1
    }
    返回 [n, 最大深度, 计数(循环分析_顶层循环(循环列表))]
}

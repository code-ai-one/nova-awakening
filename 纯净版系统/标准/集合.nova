// NovaOS 标准库 · 集合 (Set) — 觉醒理论·不可绕过的理论架构
// 原创理论: NovaSet — 代数集合论在定点OS中的完备实现
// §1 集合公理:
//   集合S = (D, n, frozen, ver) 其中 D=字典存储, n=元素计数,
//   frozen=不可变标志, ver=修改版本号(迭代安全)
//   空集: ∅ = ({}, 0, false, 0)
//   单例: {x} = ({hash(x)→x}, 1, false, 0)
// §2 代数运算完备性:
//   并集: A∪B, 交集: A∩B, 差集: A\B, 对称差: A△B
//   满足: |A∪B| = |A| + |B| - |A∩B| (容斥原理)
//   满足: A△B = (A∪B)\(A∩B)
//   幂集: P(S) = {T | T⊆S}, |P(S)| = 2^|S|
//   笛卡尔积: A×B = {(a,b) | a∈A, b∈B}, |A×B| = |A|·|B|
// §3 相似度度量:
//   Jaccard: J(A,B) = |A∩B|/|A∪B| ∈ [0,1000] (×1000定点)
//   Dice: D(A,B) = 2|A∩B|/(|A|+|B|) ∈ [0,1000]
//   重叠系数: O(A,B) = |A∩B|/min(|A|,|B|) ∈ [0,1000]
// §4 高阶操作:
//   forAll(P): ∀x∈S, P(x) — 全称量词
//   exists(P): ∃x∈S, P(x) — 存在量词
//   partition(P): (S₁,S₂) 其中 S₁={x|P(x)}, S₂={x|¬P(x)}
//   flatMap(f): ∪{f(x) | x∈S} — 单子展开
// §5 多集(Bag)扩展:
//   多集M = (D, n) 其中 D: key→count, 允许重复计数
//   支持: 添加/删除/频率查询/最高频元素
// 四阶段AI演进: NovaSet在阶段2提供高效集合推理基础设施

导入("../中枢/类型定义.nova")
导入("../中枢/自动扩容.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/重定位.nova")

定义 集合_最大容量 = 1048576
定义 集合_幂集上限 = 20
定义 集合_笛卡尔上限 = 1000
定义 集合_错误_已冻结 = -8001
定义 集合_错误_超容量 = -8002
定义 集合_错误_幂集过大 = -8003

定义 可变 集合_创建计数 = 0
定义 可变 集合_操作计数 = 0
定义 可变 集合_最大观测大小 = 0


函数 集合_创建() {
    集合_创建计数 = 集合_创建计数 + 1
    返回 [字典(), 0, 假, 0]
}

函数 集合_创建_从列表(列表) {
    定义 集合 = 集合_创建()
    如果 (列表 == 0) { 返回 集合 }
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        集合_添加(集合, 列表[i])
        i = i + 1
    }
    返回 集合
}

函数 集合_创建_从范围(起始, 结束, 步长) {
    定义 集合 = 集合_创建()
    如果 (步长 == 0) { 返回 集合 }
    定义 可变 v = 起始
    如果 (步长 > 0) {
        当 (v < 结束) {
            集合_添加(集合, v)
            v = v + 步长
        }
    } 否则 {
        当 (v > 结束) {
            集合_添加(集合, v)
            v = v + 步长
        }
    }
    返回 集合
}

函数 集合_添加(集合, 值) {
    如果 (集合[2]) { 返回 集合_错误_已冻结 }
    如果 (集合[1] >= 集合_最大容量) { 返回 集合_错误_超容量 }
    定义 键 = 转字符串(值)
    如果 (字典取(集合[0], 键) == 空) { 集合[1] = 集合[1] + 1 }
    字典设(集合[0], 键, 值)
    集合[3] = 集合[3] + 1
    集合_操作计数 = 集合_操作计数 + 1
    如果 (集合[1] > 集合_最大观测大小) { 集合_最大观测大小 = 集合[1] }
    返回 0
}

函数 集合_批量添加(集合, 值列表) {
    如果 (集合[2] || 值列表 == 0) { 返回 0 }
    定义 可变 已添加 = 0
    定义 可变 i = 0
    当 (i < 计数(值列表)) {
        定义 键 = 转字符串(值列表[i])
        如果 (字典取(集合[0], 键) == 空) {
            字典设(集合[0], 键, 值列表[i])
            集合[1] = 集合[1] + 1
            已添加 = 已添加 + 1
        }
        i = i + 1
    }
    集合[3] = 集合[3] + 1
    集合_操作计数 = 集合_操作计数 + 1
    如果 (集合[1] > 集合_最大观测大小) { 集合_最大观测大小 = 集合[1] }
    返回 已添加
}

函数 集合_包含(集合, 值) { 返回 字典取(集合[0], 转字符串(值)) != 空 }

函数 集合_删除(集合, 值) {
    如果 (集合[2]) { 返回 集合_错误_已冻结 }
    定义 键 = 转字符串(值)
    如果 (字典取(集合[0], 键) != 空) {
        字典删除(集合[0], 键)
        集合[1] = 集合[1] - 1
        集合[3] = 集合[3] + 1
        返回 0
    }
    返回 -1
}

函数 集合_批量删除(集合, 值列表) {
    如果 (集合[2] || 值列表 == 0) { 返回 0 }
    定义 可变 已删除 = 0
    定义 可变 i = 0
    当 (i < 计数(值列表)) {
        定义 键 = 转字符串(值列表[i])
        如果 (字典取(集合[0], 键) != 空) {
            字典删除(集合[0], 键)
            集合[1] = 集合[1] - 1
            已删除 = 已删除 + 1
        }
        i = i + 1
    }
    如果 (已删除 > 0) { 集合[3] = 集合[3] + 1 }
    返回 已删除
}

函数 集合_弹出(集合) {
    如果 (集合[2] || 集合[1] == 0) { 返回 空 }
    定义 键 = 字典_键列表(集合[0])
    如果 (计数(键) == 0) { 返回 空 }
    定义 值 = 字典取(集合[0], 键[0])
    字典删除(集合[0], 键[0])
    集合[1] = 集合[1] - 1
    集合[3] = 集合[3] + 1
    返回 值
}

函数 集合_清空(集合) {
    如果 (集合[2]) { 返回 集合_错误_已冻结 }
    集合[0] = 字典()
    集合[1] = 0
    集合[3] = 集合[3] + 1
    返回 0
}

函数 集合_大小(集合) { 返回 集合[1] }
函数 集合_为空(集合) { 返回 集合[1] == 0 }
函数 集合_版本(集合) { 返回 集合[3] }

函数 集合_并集(a, b) {
    定义 结果 = 集合_创建()
    定义 a键 = 字典_键列表(a[0])
    定义 b键 = 字典_键列表(b[0])
    定义 可变 i = 0
    当 (i < 计数(a键)) {
        字典设(结果[0], a键[i], 字典取(a[0], a键[i]))
        i = i + 1
    }
    结果[1] = 计数(a键)
    i = 0
    当 (i < 计数(b键)) {
        如果 (字典取(结果[0], b键[i]) == 空) {
            字典设(结果[0], b键[i], 字典取(b[0], b键[i]))
            结果[1] = 结果[1] + 1
        }
        i = i + 1
    }
    返回 结果
}

函数 集合_交集(a, b) {
    定义 结果 = 集合_创建()
    定义 较小 = a
    定义 较大 = b
    如果 (集合_大小(a) > 集合_大小(b)) { 较小 = b; 较大 = a }
    定义 键 = 字典_键列表(较小[0])
    定义 可变 i = 0
    当 (i < 计数(键)) {
        如果 (字典取(较大[0], 键[i]) != 空) {
            字典设(结果[0], 键[i], 字典取(较小[0], 键[i]))
            结果[1] = 结果[1] + 1
        }
        i = i + 1
    }
    返回 结果
}

函数 集合_差集(a, b) {
    定义 结果 = 集合_创建()
    定义 a键 = 字典_键列表(a[0])
    定义 可变 i = 0
    当 (i < 计数(a键)) {
        如果 (字典取(b[0], a键[i]) == 空) {
            字典设(结果[0], a键[i], 字典取(a[0], a键[i]))
            结果[1] = 结果[1] + 1
        }
        i = i + 1
    }
    返回 结果
}

函数 集合_对称差集(a, b) {
    定义 结果 = 集合_创建()
    定义 a键 = 字典_键列表(a[0])
    定义 b键 = 字典_键列表(b[0])
    定义 可变 i = 0
    当 (i < 计数(a键)) {
        如果 (字典取(b[0], a键[i]) == 空) {
            字典设(结果[0], a键[i], 字典取(a[0], a键[i]))
            结果[1] = 结果[1] + 1
        }
        i = i + 1
    }
    i = 0
    当 (i < 计数(b键)) {
        如果 (字典取(a[0], b键[i]) == 空) {
            字典设(结果[0], b键[i], 字典取(b[0], b键[i]))
            结果[1] = 结果[1] + 1
        }
        i = i + 1
    }
    返回 结果
}

// 多集合并集 (合并N个集合)
函数 集合_多并集(集合列表) {
    如果 (集合列表 == 0 || 计数(集合列表) == 0) { 返回 集合_创建() }
    定义 可变 结果 = 集合_复制(集合列表[0])
    定义 可变 i = 1
    当 (i < 计数(集合列表)) {
        定义 键 = 字典_键列表(集合列表[i][0])
        定义 可变 j = 0
        当 (j < 计数(键)) {
            如果 (字典取(结果[0], 键[j]) == 空) {
                字典设(结果[0], 键[j], 字典取(集合列表[i][0], 键[j]))
                结果[1] = 结果[1] + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 结果
}

// 多集合交集 (N个集合的公共元素)
函数 集合_多交集(集合列表) {
    如果 (集合列表 == 0 || 计数(集合列表) == 0) { 返回 集合_创建() }
    定义 可变 最小idx = 0
    定义 可变 最小大小 = 集合_大小(集合列表[0])
    定义 可变 i = 1
    当 (i < 计数(集合列表)) {
        如果 (集合_大小(集合列表[i]) < 最小大小) {
            最小大小 = 集合_大小(集合列表[i])
            最小idx = i
        }
        i = i + 1
    }
    定义 结果 = 集合_创建()
    定义 键 = 字典_键列表(集合列表[最小idx][0])
    定义 可变 k = 0
    当 (k < 计数(键)) {
        定义 可变 全部包含 = 真
        i = 0
        当 (i < 计数(集合列表)) {
            如果 (i != 最小idx && 字典取(集合列表[i][0], 键[k]) == 空) {
                全部包含 = 假
                i = 计数(集合列表)
            }
            i = i + 1
        }
        如果 (全部包含) {
            字典设(结果[0], 键[k], 字典取(集合列表[最小idx][0], 键[k]))
            结果[1] = 结果[1] + 1
        }
        k = k + 1
    }
    返回 结果
}


函数 集合_是子集(a, b) {
    如果 (集合_大小(a) > 集合_大小(b)) { 返回 假 }
    定义 a键 = 字典_键列表(a[0])
    定义 可变 i = 0
    当 (i < 计数(a键)) {
        如果 (字典取(b[0], a键[i]) == 空) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 集合_是真子集(a, b) {
    返回 集合_大小(a) < 集合_大小(b) && 集合_是子集(a, b)
}

函数 集合_是超集(a, b) { 返回 集合_是子集(b, a) }

函数 集合_相等(a, b) {
    如果 (集合_大小(a) != 集合_大小(b)) { 返回 假 }
    返回 集合_是子集(a, b)
}

函数 集合_不相交(a, b) {
    定义 较小 = a
    定义 较大 = b
    如果 (集合_大小(a) > 集合_大小(b)) { 较小 = b; 较大 = a }
    定义 键 = 字典_键列表(较小[0])
    定义 可变 i = 0
    当 (i < 计数(键)) {
        如果 (字典取(较大[0], 键[i]) != 空) { 返回 假 }
        i = i + 1
    }
    返回 真
}


函数 集合_Jaccard相似度(a, b) {
    定义 交大小 = 集合_大小(集合_交集(a, b))
    定义 并大小 = 集合_大小(a) + 集合_大小(b) - 交大小
    如果 (并大小 == 0) { 返回 1000 }
    返回 交大小 * 1000 / 并大小
}

函数 集合_Dice相似度(a, b) {
    定义 交大小 = 集合_大小(集合_交集(a, b))
    定义 总 = 集合_大小(a) + 集合_大小(b)
    如果 (总 == 0) { 返回 1000 }
    返回 2 * 交大小 * 1000 / 总
}

函数 集合_重叠系数(a, b) {
    定义 交大小 = 集合_大小(集合_交集(a, b))
    定义 较小大小 = 集合_大小(a)
    如果 (集合_大小(b) < 较小大小) { 较小大小 = 集合_大小(b) }
    如果 (较小大小 == 0) { 返回 1000 }
    返回 交大小 * 1000 / 较小大小
}


函数 集合_遍历(集合, 回调) {
    定义 键 = 字典_键列表(集合[0])
    定义 可变 i = 0
    当 (i < 计数(键)) {
        定义 值 = 字典取(集合[0], 键[i])
        回调(值)
        i = i + 1
    }
}

函数 集合_遍历_带索引(集合, 回调) {
    定义 键 = 字典_键列表(集合[0])
    定义 可变 i = 0
    当 (i < 计数(键)) {
        定义 值 = 字典取(集合[0], 键[i])
        回调(i, 值)
        i = i + 1
    }
}

函数 集合_过滤(集合, 条件函数) {
    定义 结果 = 集合_创建()
    定义 键 = 字典_键列表(集合[0])
    定义 可变 i = 0
    当 (i < 计数(键)) {
        定义 值 = 字典取(集合[0], 键[i])
        如果 (条件函数(值)) {
            字典设(结果[0], 键[i], 值)
            结果[1] = 结果[1] + 1
        }
        i = i + 1
    }
    返回 结果
}

函数 集合_映射(集合, 变换函数) {
    定义 结果 = 集合_创建()
    定义 键 = 字典_键列表(集合[0])
    定义 可变 i = 0
    当 (i < 计数(键)) {
        定义 值 = 字典取(集合[0], 键[i])
        定义 新值 = 变换函数(值)
        集合_添加(结果, 新值)
        i = i + 1
    }
    返回 结果
}

函数 集合_flatMap(集合, 变换函数) {
    定义 结果 = 集合_创建()
    定义 键 = 字典_键列表(集合[0])
    定义 可变 i = 0
    当 (i < 计数(键)) {
        定义 值 = 字典取(集合[0], 键[i])
        定义 子集合 = 变换函数(值)
        如果 (子集合 != 空 && 计数(子集合) >= 4) {
            定义 子键 = 字典_键列表(子集合[0])
            定义 可变 j = 0
            当 (j < 计数(子键)) {
                如果 (字典取(结果[0], 子键[j]) == 空) {
                    字典设(结果[0], 子键[j], 字典取(子集合[0], 子键[j]))
                    结果[1] = 结果[1] + 1
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    返回 结果
}

函数 集合_归约(集合, 初始值, 归约函数) {
    定义 键 = 字典_键列表(集合[0])
    定义 可变 累积 = 初始值
    定义 可变 i = 0
    当 (i < 计数(键)) {
        定义 值 = 字典取(集合[0], 键[i])
        累积 = 归约函数(累积, 值)
        i = i + 1
    }
    返回 累积
}


函数 集合_forAll(集合, 谓词) {
    定义 键 = 字典_键列表(集合[0])
    定义 可变 i = 0
    当 (i < 计数(键)) {
        如果 (!谓词(字典取(集合[0], 键[i]))) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 集合_exists(集合, 谓词) {
    定义 键 = 字典_键列表(集合[0])
    定义 可变 i = 0
    当 (i < 计数(键)) {
        如果 (谓词(字典取(集合[0], 键[i]))) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 集合_计数满足(集合, 谓词) {
    定义 键 = 字典_键列表(集合[0])
    定义 可变 计 = 0
    定义 可变 i = 0
    当 (i < 计数(键)) {
        如果 (谓词(字典取(集合[0], 键[i]))) { 计 = 计 + 1 }
        i = i + 1
    }
    返回 计
}

函数 集合_partition(集合, 谓词) {
    定义 满足 = 集合_创建()
    定义 不满足 = 集合_创建()
    定义 键 = 字典_键列表(集合[0])
    定义 可变 i = 0
    当 (i < 计数(键)) {
        定义 值 = 字典取(集合[0], 键[i])
        如果 (谓词(值)) {
            字典设(满足[0], 键[i], 值)
            满足[1] = 满足[1] + 1
        } 否则 {
            字典设(不满足[0], 键[i], 值)
            不满足[1] = 不满足[1] + 1
        }
        i = i + 1
    }
    返回 [满足, 不满足]
}

函数 集合_findFirst(集合, 谓词) {
    定义 键 = 字典_键列表(集合[0])
    定义 可变 i = 0
    当 (i < 计数(键)) {
        定义 值 = 字典取(集合[0], 键[i])
        如果 (谓词(值)) { 返回 值 }
        i = i + 1
    }
    返回 空
}

函数 集合_最小(集合, 比较函数) {
    定义 键 = 字典_键列表(集合[0])
    如果 (计数(键) == 0) { 返回 空 }
    定义 可变 最小值 = 字典取(集合[0], 键[0])
    定义 可变 i = 1
    当 (i < 计数(键)) {
        定义 v = 字典取(集合[0], 键[i])
        如果 (比较函数(v, 最小值) < 0) { 最小值 = v }
        i = i + 1
    }
    返回 最小值
}

函数 集合_最大(集合, 比较函数) {
    定义 键 = 字典_键列表(集合[0])
    如果 (计数(键) == 0) { 返回 空 }
    定义 可变 最大值 = 字典取(集合[0], 键[0])
    定义 可变 i = 1
    当 (i < 计数(键)) {
        定义 v = 字典取(集合[0], 键[i])
        如果 (比较函数(v, 最大值) > 0) { 最大值 = v }
        i = i + 1
    }
    返回 最大值
}


函数 集合_幂集(集合) {
    定义 n = 集合_大小(集合)
    如果 (n > 集合_幂集上限) { 返回 集合_错误_幂集过大 }
    定义 元素 = 集合_到列表(集合)
    定义 可变 结果 = []
    定义 可变 总数 = 1
    定义 可变 b = 0
    当 (b < n) { 总数 = 总数 * 2; b = b + 1 }
    定义 可变 mask = 0
    当 (mask < 总数) {
        定义 子集 = 集合_创建()
        定义 可变 bit = 0
        当 (bit < n) {
            定义 可变 测试 = 1
            定义 可变 s = 0
            当 (s < bit) { 测试 = 测试 * 2; s = s + 1 }
            如果 (mask & 测试) {
                集合_添加(子集, 元素[bit])
            }
            bit = bit + 1
        }
        追加(结果, 子集)
        mask = mask + 1
    }
    返回 结果
}

函数 集合_笛卡尔积(a, b) {
    如果 (集合_大小(a) * 集合_大小(b) > 集合_笛卡尔上限) {
        返回 []
    }
    定义 可变 结果 = []
    定义 a列 = 集合_到列表(a)
    定义 b列 = 集合_到列表(b)
    定义 可变 i = 0
    当 (i < 计数(a列)) {
        定义 可变 j = 0
        当 (j < 计数(b列)) {
            追加(结果, [a列[i], b列[j]])
            j = j + 1
        }
        i = i + 1
    }
    返回 结果
}


函数 集合_到列表(集合) {
    定义 键 = 字典_键列表(集合[0])
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(键)) {
        追加(结果, 字典取(集合[0], 键[i]))
        i = i + 1
    }
    返回 结果
}

函数 集合_到排序列表(集合, 比较函数) {
    定义 列表 = 集合_到列表(集合)
    如果 (比较函数 != 0) {
        列表_排序(列表, 比较函数)
    } 否则 {
        列表_排序(列表, 默认比较)
    }
    返回 列表
}

函数 集合_冻结(集合) {
    集合[2] = 真
    返回 集合
}

函数 集合_是冻结(集合) { 返回 集合[2] }

函数 集合_复制(集合) {
    定义 结果 = 集合_创建()
    定义 键 = 字典_键列表(集合[0])
    定义 可变 i = 0
    当 (i < 计数(键)) {
        字典设(结果[0], 键[i], 字典取(集合[0], 键[i]))
        i = i + 1
    }
    结果[1] = 集合[1]
    返回 结果
}

函数 集合_序列化(集合) {
    定义 列表 = 集合_到列表(集合)
    定义 可变 结果 = "{"
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (i > 0) { 追加(部件, "," })
        追加(部件, 转字符串(列表[i]))
        i = i + 1
    }
    追加(部件, "}"); 返回 字符串_连接列表(部件, "")
}


函数 多集_创建() { 返回 [字典(), 0, 0] }

函数 多集_添加(bag, 值, 次数) {
    如果 (次数 <= 0) { 次数 = 1 }
    定义 键 = 转字符串(值)
    定义 现有 = 字典取(bag[0], 键)
    如果 (现有 == 空) {
        字典设(bag[0], 键, 次数)
        bag[2] = bag[2] + 1
    } 否则 {
        字典设(bag[0], 键, 现有 + 次数)
    }
    bag[1] = bag[1] + 次数
    返回 0
}

函数 多集_删除(bag, 值, 次数) {
    如果 (次数 <= 0) { 次数 = 1 }
    定义 键 = 转字符串(值)
    定义 现有 = 字典取(bag[0], 键)
    如果 (现有 == 空) { 返回 0 }
    如果 (现有 <= 次数) {
        字典删除(bag[0], 键)
        bag[1] = bag[1] - 现有
        bag[2] = bag[2] - 1
        返回 现有
    }
    字典设(bag[0], 键, 现有 - 次数)
    bag[1] = bag[1] - 次数
    返回 次数
}

函数 多集_频率(bag, 值) {
    定义 r = 字典取(bag[0], 转字符串(值))
    如果 (r == 空) { 返回 0 }
    返回 r
}

函数 多集_总数(bag) { 返回 bag[1] }
函数 多集_种类数(bag) { 返回 bag[2] }

函数 多集_最高频(bag) {
    定义 键 = 字典_键列表(bag[0])
    如果 (计数(键) == 0) { 返回 空 }
    定义 可变 最高键 = 键[0]
    定义 可变 最高频 = 字典取(bag[0], 键[0])
    定义 可变 i = 1
    当 (i < 计数(键)) {
        定义 f = 字典取(bag[0], 键[i])
        如果 (f > 最高频) { 最高频 = f; 最高键 = 键[i] }
        i = i + 1
    }
    返回 [最高键, 最高频]
}

函数 多集_TopN(bag, n) {
    定义 键 = 字典_键列表(bag[0])
    定义 可变 列表 = []
    定义 可变 i = 0
    当 (i < 计数(键)) {
        追加(列表, [键[i], 字典取(bag[0], 键[i])])
        i = i + 1
    }
    定义 可变 sorted = 0
    当 (sorted < n && sorted < 计数(列表)) {
        定义 可变 最大idx = sorted
        i = sorted + 1
        当 (i < 计数(列表)) {
            如果 (列表[i][1] > 列表[最大idx][1]) { 最大idx = i }
            i = i + 1
        }
        如果 (最大idx != sorted) {
            定义 临时 = 列表[sorted]
            列表[sorted] = 列表[最大idx]
            列表[最大idx] = 临时
        }
        sorted = sorted + 1
    }
    定义 可变 结果 = []
    i = 0
    当 (i < n && i < 计数(列表)) {
        追加(结果, 列表[i])
        i = i + 1
    }
    返回 结果
}

函数 多集_转集合(bag) {
    定义 结果 = 集合_创建()
    定义 键 = 字典_键列表(bag[0])
    定义 可变 i = 0
    当 (i < 计数(键)) {
        字典设(结果[0], 键[i], 键[i])
        结果[1] = 结果[1] + 1
        i = i + 1
    }
    返回 结果
}


函数 集合_诊断() {
    返回 {
        创建总数: 集合_创建计数,
        操作总数: 集合_操作计数,
        最大观测大小: 集合_最大观测大小
    }
}

函数 集合_验证容斥(a, b) {
    定义 并大小 = 集合_大小(集合_并集(a, b))
    定义 交大小 = 集合_大小(集合_交集(a, b))
    定义 期望 = 集合_大小(a) + 集合_大小(b) - 交大小
    返回 并大小 == 期望
}

函数 默认比较(a, b) {
    定义 sa = 转字符串(a)
    定义 sb = 转字符串(b)
    返回 字符串_比较(sa, sb)
}

定义 可变 AI_集合_威胁计数 = 0

函数 AI_集合_风险评分(操作类型, 权限级别, 来源可信度) {
    定义 可变 风险 = 0
    如果 (权限级别 > 500) { 风险 = 风险 + 300 }
    如果 (来源可信度 < 200) { 风险 = 风险 + 400 }
    如果 (风险 > 500) { AI_集合_威胁计数 = AI_集合_威胁计数 + 1 }
    返回 风险
}

函数 AI_集合_异常行为检测(操作频率, 基线频率) {
    如果 (基线频率 > 0 && 操作频率 > 基线频率 * 5) { 返回 真 }
    返回 假
}

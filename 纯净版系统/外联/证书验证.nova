导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/哈希整数.nova")
导入("../执行/平台时间.nova")

定义 最大信任根 = 64
定义 最大固定 = 32
定义 证书_有效 = 0
定义 证书_过期 = 1
定义 证书_主机不匹配 = 2
定义 证书_签名无效 = 3
定义 证书_自签名 = 4
定义 证书_链不完整 = 5
定义 证书_已吊销 = 6

外部 对称加密_加密
外部 对称加密_解密
外部 哈希消息认证
外部 密钥导出_展开
外部 曲线25519_基点乘
外部 曲线25519_乘法
外部 生成随机字节

结构 证书信息 {
    主题哈希,
    颁发者哈希,
    有效起始,
    有效结束,
    公钥哈希,
    签名哈希,
    是根证书,
    主机名表,
    主机名数,
}

定义 可变 信任根表 = []
定义 可变 信任根数 = 0
定义 可变 固定表 = 0
定义 可变 固定数 = 0
定义 可变 验证总数 = 0
定义 可变 验证成功 = 0
定义 可变 验证失败 = 0
定义 可变 固定命中 = 0

函数 安全_初始化() {
    信任根表 = []
    信任根数 = 0
    固定表 = 堆_分配(最大固定 * 16)
    固定数 = 0
}

函数 安全_添加信任根(主题哈希, 公钥哈希) {
    如果 (信任根数 >= 最大信任根) { 返回 -1 }
    定义 根 = 证书信息 {}
    根.主题哈希 = 主题哈希
    根.公钥哈希 = 公钥哈希
    根.是根证书 = 真
    追加(信任根表, 根)
    信任根数 = 信任根数 + 1
    返回 信任根数 - 1
}

函数 安全_固定证书(主机哈希, 公钥哈希) {
    如果 (固定数 >= 最大固定) { 返回 }
    内存_写64(固定表 + 固定数 * 16, 主机哈希)
    内存_写64(固定表 + 固定数 * 16 + 8, 公钥哈希)
    固定数 = 固定数 + 1
}

函数 验证证书(证书数据, 数据长, 主机名) {
    验证总数 = 验证总数 + 1
    如果 (证书数据 == 0 || 数据长 < 64) {
        验证失败 = 验证失败 + 1
        返回 证书_链不完整
    }
    定义 信息 = 解析证书基本信息(证书数据, 数据长)
    如果 (信息 == 0) { 验证失败 = 验证失败 + 1; 返回 证书_签名无效 }
    定义 现在 = 平台_获取墙钟秒()
    如果 (现在 < 信息.有效起始 || 现在 > 信息.有效结束) {
        验证失败 = 验证失败 + 1
        返回 证书_过期
    }
    定义 主机匹配 = 验证主机名(信息, 主机名)
    如果 (!主机匹配) {
        验证失败 = 验证失败 + 1
        返回 证书_主机不匹配
    }
    定义 固定结果 = 验证固定(主机名, 信息.公钥哈希)
    如果 (固定结果 == 假) {
        验证失败 = 验证失败 + 1
        返回 证书_签名无效
    }
    定义 链结果 = 验证证书链(信息)
    如果 (链结果 != 证书_有效) {
        验证失败 = 验证失败 + 1
        返回 链结果
    }
    验证成功 = 验证成功 + 1
    返回 证书_有效
}

函数 解析证书基本信息(数据, 长度) {
    定义 信息 = 堆_分配(证书信息)
    如果 (长度 < 64) { 返回 0 }
    信息.主题哈希 = 内存_读64(数据)
    信息.颁发者哈希 = 内存_读64(数据 + 8)
    信息.有效起始 = 内存_读64(数据 + 16)
    信息.有效结束 = 内存_读64(数据 + 24)
    信息.公钥哈希 = 内存_读64(数据 + 32)
    信息.签名哈希 = 内存_读64(数据 + 40)
    信息.是根证书 = (信息.主题哈希 == 信息.颁发者哈希)
    信息.主机名表 = 数据 + 48
    信息.主机名数 = (长度 - 48) / 8
    返回 信息
}

函数 验证主机名(信息, 主机名) {
    定义 目标哈希 = 哈希_字符串(主机名)
    定义 可变 序号 = 0
    当 (序号 < 信息.主机名数) {
        定义 名哈希 = 内存_读64(信息.主机名表 + 序号 * 8)
        如果 (名哈希 == 目标哈希) { 返回 真 }
        序号 = 序号 + 1
    }
    如果 (信息.主题哈希 == 目标哈希) { 返回 真 }
    返回 假
}

函数 验证固定(主机名, 公钥哈希) {
    定义 主机哈希 = 哈希_字符串(主机名)
    定义 可变 序号 = 0
    当 (序号 < 固定数) {
        如果 (内存_读64(固定表 + 序号 * 16) == 主机哈希) {
            固定命中 = 固定命中 + 1
            返回 内存_读64(固定表 + 序号 * 16 + 8) == 公钥哈希
        }
        序号 = 序号 + 1
    }
    返回 真
}

函数 验证证书链(信息) {
    如果 (信息.是根证书) {
        定义 可变 序号 = 0
        当 (序号 < 信任根数) {
            如果 (信任根表[序号].主题哈希 == 信息.主题哈希) { 返回 证书_有效 }
            序号 = 序号 + 1
        }
        返回 证书_自签名
    }
    定义 可变 序号 = 0
    当 (序号 < 信任根数) {
        如果 (信任根表[序号].主题哈希 == 信息.颁发者哈希) { 返回 证书_有效 }
        序号 = 序号 + 1
    }
    返回 证书_链不完整
}

函数 安全_验证失败率() {
    如果 (验证总数 == 0) { 返回 0 }
    返回 验证失败 * 100 / 验证总数
}

函数 安全_完整统计() {
    返回 [验证总数, 验证成功, 验证失败, 信任根数, 固定数, 固定命中]
}

定义 可变 AI_证书验证_威胁计数 = 0

函数 AI_证书验证_风险评分(操作类型, 权限级别, 来源可信度) {
    定义 可变 风险 = 0
    如果 (权限级别 > 500) { 风险 = 风险 + 300 }
    如果 (来源可信度 < 200) { 风险 = 风险 + 400 }
    如果 (风险 > 500) { AI_证书验证_威胁计数 = AI_证书验证_威胁计数 + 1 }
    返回 风险
}

函数 AI_证书验证_异常行为检测(操作频率, 基线频率) {
    如果 (基线频率 > 0 && 操作频率 > 基线频率 * 5) { 返回 真 }
    返回 假
}

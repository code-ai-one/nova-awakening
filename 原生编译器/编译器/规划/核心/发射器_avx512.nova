// Nova · x86-64 AVX-512 + AMX + VNNI 指令发射器
// 依赖: 发射器.nova (发射/发射组/发射32)
// 覆盖: AVX-512F/BW/DQ/VL/VNNI/BF16 + AMX-INT8/BF16/FP16

导入("发射器.nova")

// EVEX前缀编码辅助 (4字节前缀: 0x62 + P0 + P1 + P2)
函数 发射_evex(R, X, B, R2, mm, W, vvvv, pp, z, L2, L, b位, V2, aaa) {
    发射(0x62)
    定义 p0 = ((R & 1) << 7) | ((X & 1) << 6) | ((B & 1) << 5) | ((R2 & 1) << 4) | (mm & 0x03)
    发射(p0)
    定义 p1 = ((W & 1) << 7) | (((~vvvv) & 0xF) << 3) | 0x04 | (pp & 0x03)
    发射(p1)
    定义 p2 = ((z & 1) << 7) | ((L2 & 1) << 6) | ((L & 1) << 5) | ((b位 & 1) << 4) | (((~V2) & 1) << 3) | (aaa & 0x07)
    发射(p2)
}

// EVEX简化: 512位(L2=1,L=0), 无掩码(aaa=0), 无零化(z=0)
函数 EVEX512编码(W, vvvv, pp, 操作码, modrm) {
    发射_evex(1,  1,  1,  1,  1,  W,  vvvv,  pp,  0,  1, 0 ,  1, 0, 0)
    发射(操作码) 发射(modrm)
}

// AVX-512F 浮点运算 (ZMM 512位 = 16×float / 8×double)

// vaddps zmm, zmm, zmm — 16路单精度加法
函数 发射_avx512_加ps(d, s1, s2) { EVEX512编码(0,  s1, x58,  0xC0 + (d & 7) * 8 + (s2 & 7), 0) }
// vsubps zmm, zmm, zmm
函数 发射_avx512_减ps(d, s1, s2) { EVEX512编码(0,  s1, x5C,  0xC0 + (d & 7) * 8 + (s2 & 7), 0) }
// vmulps zmm, zmm, zmm
函数 发射_avx512_乘ps(d, s1, s2) { EVEX512编码(0,  s1, x59,  0xC0 + (d & 7) * 8 + (s2 & 7), 0) }
// vdivps zmm, zmm, zmm
函数 发射_avx512_除ps(d, s1, s2) { EVEX512编码(0,  s1, x5E,  0xC0 + (d & 7) * 8 + (s2 & 7), 0) }
// vsqrtps zmm, zmm
函数 发射_avx512_根ps(d, s) { EVEX512编码(0, 0 ,  0x51,  0xC0 + (d & 7) * 8 + (s & 7), 0) }
// vmaxps zmm, zmm, zmm
函数 发射_avx512_最大ps(d, s1, s2) { EVEX512编码(0,  s1, x5F,  0xC0 + (d & 7) * 8 + (s2 & 7), 0) }
// vminps zmm, zmm, zmm
函数 发射_avx512_最小ps(d, s1, s2) { EVEX512编码(0,  s1, x5D,  0xC0 + (d & 7) * 8 + (s2 & 7), 0) }
// vaddpd zmm, zmm, zmm — 8路双精度加法
函数 发射_avx512_加pd(d, s1, s2) { EVEX512编码(1, s1, 1, 0x58, 0xC0 + (d & 7) * 8 + (s2 & 7)) }
// vsubpd zmm, zmm, zmm
函数 发射_avx512_减pd(d, s1, s2) { EVEX512编码(1, s1, 1, 0x5C, 0xC0 + (d & 7) * 8 + (s2 & 7)) }
// vmulpd zmm, zmm, zmm
函数 发射_avx512_乘pd(d, s1, s2) { EVEX512编码(1, s1, 1, 0x59, 0xC0 + (d & 7) * 8 + (s2 & 7)) }
// vdivpd zmm, zmm, zmm
函数 发射_avx512_除pd(d, s1, s2) { EVEX512编码(1, s1, 1, 0x5E, 0xC0 + (d & 7) * 8 + (s2 & 7)) }
// vsqrtpd zmm, zmm
函数 发射_avx512_根pd(d, s) { EVEX512编码(1, 0, 1, 0x51, 0xC0 + (d & 7) * 8 + (s & 7)) }
// vmaxpd/vminpd
函数 发射_avx512_最大pd(d, s1, s2) { EVEX512编码(1, s1, 1, 0x5F, 0xC0 + (d & 7) * 8 + (s2 & 7)) }
函数 发射_avx512_最小pd(d, s1, s2) { EVEX512编码(1, s1, 1, 0x5D, 0xC0 + (d & 7) * 8 + (s2 & 7)) }

// AVX-512F FMA (融合乘加 — 智能推理/训练核心)

// vfmadd132ps zmm, zmm, zmm — d = d*s2 + s1
函数 发射_avx512_fma132ps(d, s1, s2) {
    发射_evex(1,  1,  1,  1,  2,  0,  s1,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0x98) 发射(0xC0 + (d & 7) * 8 + (s2 & 7))
}
// vfmadd213ps zmm, zmm, zmm — d = s1*d + s2
函数 发射_avx512_fma213ps(d, s1, s2) {
    发射_evex(1,  1,  1,  1,  2,  0,  s1,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0xA8) 发射(0xC0 + (d & 7) * 8 + (s2 & 7))
}
// vfmadd231ps zmm, zmm, zmm — d = s1*s2 + d
函数 发射_avx512_fma231ps(d, s1, s2) {
    发射_evex(1,  1,  1,  1,  2,  0,  s1,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0xB8) 发射(0xC0 + (d & 7) * 8 + (s2 & 7))
}
// vfmadd213pd zmm — 双精度FMA
函数 发射_avx512_fma213pd(d, s1, s2) {
    发射_evex(1,  1,  1,  1,  2,  1,  s1,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0xA8) 发射(0xC0 + (d & 7) * 8 + (s2 & 7))
}
// vfmsub213ps — d = s1*d - s2
函数 发射_avx512_fms213ps(d, s1, s2) {
    发射_evex(1,  1,  1,  1,  2,  0,  s1,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0xAA) 发射(0xC0 + (d & 7) * 8 + (s2 & 7))
}
// vfnmadd213ps — d = -(s1*d) + s2
函数 发射_avx512_fnma213ps(d, s1, s2) {
    发射_evex(1,  1,  1,  1,  2,  0,  s1,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0xAC) 发射(0xC0 + (d & 7) * 8 + (s2 & 7))
}
// vfnmsub213ps — d = -(s1*d) - s2
函数 发射_avx512_fnms213ps(d, s1, s2) {
    发射_evex(1,  1,  1,  1,  2,  0,  s1,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0xAE) 发射(0xC0 + (d & 7) * 8 + (s2 & 7))
}

// AVX-512F 数据移动

// vmovaps zmm, zmm — 对齐移动
函数 发射_avx512_movaps(d, s) { EVEX512编码(0, 0 ,  0x28,  0xC0 + (d & 7) * 8 + (s & 7), 0) }

// NovaOS FAT32文件系统 — U盘/SD卡/Windows分区读写
// FAT32是最通用的文件系统:
//   - 所有U盘/SD卡默认FAT32
//   - Windows/macOS/Linux都支持
//   - 嵌入式设备/相机/游戏机通用
// 不支持FAT32 = 无法读U盘 = 严重缺陷

// §1 FAT32 BPB常量 (BIOS Parameter 块级)

定义 FAT32_SIG        = 0xAA55       // 引导扇区签名
定义 FAT32_FSTYPE     = "FAT32   "   // 文件系统类型标识
定义 FAT_ENTRY_FREE   = 0x00000000   // 空闲簇
定义 FAT_ENTRY_EOC    = 0x0FFFFFF8   // 链结束(End of Chain)
定义 FAT_ENTRY_BAD    = 0x0FFFFFF7   // 坏簇
定义 FAT_ENTRY_MASK   = 0x0FFFFFFF   // 28位有效

// 目录条目属性
定义 ATTR_READ_ONLY = 0x01
定义 ATTR_HIDDEN    = 0x02
定义 ATTR_SYSTEM    = 0x04
定义 ATTR_VOLUME_ID = 0x08
定义 ATTR_DIRECTORY = 0x10
定义 ATTR_ARCHIVE   = 0x20
定义 ATTR_LONG_NAME = 0x0F    // 长文件名条目

// §2 数据结构

结构 FAT32超级块 {
    设备,    // u64 块设备
    扇区大小,    // u32 通常512
    簇大小,    // u32 扇区/簇
    簇字节数,    // u32 簇大小 × 扇区大小
    保留扇区数,
    FAT数,    // u32 FAT表数(通常2)
    FAT大小,    // u32 每个FAT表占用扇区数
    根目录簇,    // u32 根目录起始簇(通常2)
    总扇区数,
    总簇数,
    数据区起始扇区,    // u64 第一个数据簇的扇区号
    FAT起始扇区,
    FSInfo扇区,
    空闲簇数,
    下一空闲簇,
    卷标,
}

// 短文件名目录条目 (32字节)
结构 FAT32目录条目 {
    名称,    // 字符串 8.3格式
    长名,    // 字符串 长文件名(从LFN条目拼接)
    属性,
    创建时间,
    修改时间,
    访问日期,
    起始簇,    // u32 高16位+低16位
    文件大小,
}

// §3 全局

定义 可变 FAT32_挂载列表 = []

// §4 挂载

函数 FAT32_挂载(设备, 挂载点) {
    内核信息("FAT32: 挂载 " + 挂载点)

    // 读取引导扇区(扇区0)
    定义 boot = 分配内存(512)
    块设备_读(设备, 0, 1, boot)

    // 验证签名
    如果 (内存读16(boot + 510) != FAT32_SIG) {
        内核警告("FAT32: 无效引导扇区签名")
        释放内存(boot)
        返回 错误_格式
    }

    定义 sb = FAT32超级块 {}
    sb.设备 = 设备
    sb.扇区大小 = 内存读16(boot + 11)
    sb.簇大小 = 内存读8(boot + 13)
    sb.保留扇区数 = 内存读16(boot + 14)
    sb.FAT数 = 内存读8(boot + 16)
    sb.FAT大小 = 内存读32(boot + 36)
    sb.根目录簇 = 内存读32(boot + 44)
    sb.FSInfo扇区 = 内存读16(boot + 48)
    sb.簇字节数 = sb.簇大小 * sb.扇区大小

    // 总扇区数
    定义 total16 = 内存读16(boot + 19)
    如果 (total16 != 0) {
        sb.总扇区数 = total16
    } 否则 {
        sb.总扇区数 = 内存读32(boot + 32)
    }

    // 计算数据区起始
    sb.FAT起始扇区 = sb.保留扇区数
    sb.数据区起始扇区 = sb.保留扇区数 + sb.FAT数 * sb.FAT大小
    sb.总簇数 = (sb.总扇区数 - sb.数据区起始扇区) / sb.簇大小

    // 读取卷标
    sb.卷标 = 读取固定字符串(boot + 71, 11)

    释放内存(boot)

    // 读取FSInfo扇区获取空闲簇数
    如果 (sb.FSInfo扇区 != 0 && sb.FSInfo扇区 != 0xFFFF) {
        定义 fsinfo = 分配内存(512)
        块设备_读(设备, sb.FSInfo扇区, 1, fsinfo)
        如果 (内存读32(fsinfo) == 0x41615252 && 内存读32(fsinfo + 484) == 0x61417272) {
            sb.空闲簇数 = 内存读32(fsinfo + 488)
            sb.下一空闲簇 = 内存读32(fsinfo + 492)
        }
        释放内存(fsinfo)
    }

    追加(FAT32_挂载列表, [挂载点, sb])

    定义 容量MB = (sb.总簇数 * sb.簇字节数) / 1048576
    内核信息("FAT32: " + sb.卷标 + " 容量=" + 整数转字符串(容量MB) + "MB" +
             " 簇=" + 整数转字符串(sb.簇字节数) + "B" +
             " 空闲=" + 整数转字符串(sb.空闲簇数))
    返回 0
}

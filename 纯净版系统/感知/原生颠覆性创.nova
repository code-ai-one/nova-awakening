导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")

定义 流_可读 = 0
定义 流_可写 = 1
定义 流_转换 = 2
定义 状态_可读 = 0
定义 状态_关闭 = 1
定义 状态_错误 = 2
定义 默认水位 = 16384
定义 最大水位 = 1048576
定义 最小水位 = 1024
定义 最大块数 = 64

结构 流块 {
    数据,
    大小,
    后继,
}

结构 可读流 {
    状态,
    水位线,
    队列头,
    队列尾,
    队列大小,
    块数,
    总读字节,
    总写字节,
    背压次数,
    读回调,
    关闭回调,
}

定义 可变 流总数 = 0
定义 可变 背压总次 = 0
定义 可变 水位调整次 = 0

函数 流_创建(水位线) {
    流总数 = 流总数 + 1
    定义 流 = 堆_分配(可读流)
    流.状态 = 状态_可读
    流.水位线 = 水位线
    如果 (流.水位线 <= 0) { 流.水位线 = 默认水位 }
    流.队列头 = 0
    流.队列尾 = 0
    流.队列大小 = 0
    流.块数 = 0
    流.总读字节 = 0
    流.总写字节 = 0
    流.背压次数 = 0
    流.读回调 = 0
    流.关闭回调 = 0
    返回 流
}

函数 流_入队(流, 数据, 大小) {
    如果 (流 == 0 || 流.状态 != 状态_可读) { 返回 错误_无效参数 }
    如果 (流.块数 >= 最大块数) { 流.背压次数 = 流.背压次数 + 1; 背压总次 = 背压总次 + 1; 返回 错误_队列满 }
    定义 块 = 堆_分配(流块)
    块.数据 = 堆_分配(大小)
    内存_复制(块.数据, 数据, 大小)
    块.大小 = 大小
    块.后继 = 0
    如果 (流.队列尾 != 0) { 流.队列尾.后继 = 块 }
    否则 { 流.队列头 = 块 }
    流.队列尾 = 块
    流.队列大小 = 流.队列大小 + 大小
    流.块数 = 流.块数 + 1
    流.总写字节 = 流.总写字节 + 大小
    如果 (流.队列大小 > 流.水位线) {
        流.背压次数 = 流.背压次数 + 1
        背压总次 = 背压总次 + 1
    }
    返回 0
}

函数 流_出队(流) {
    如果 (流 == 0 || 流.队列头 == 0) { 返回 0 }
    定义 块 = 流.队列头
    流.队列头 = 块.后继
    如果 (流.队列头 == 0) { 流.队列尾 = 0 }
    流.队列大小 = 流.队列大小 - 块.大小
    流.块数 = 流.块数 - 1
    流.总读字节 = 流.总读字节 + 块.大小
    返回 块
}

函数 流_有背压(流) {
    如果 (流 == 0) { 返回 假 }
    返回 流.队列大小 >= 流.水位线
}

函数 流_关闭(流) {
    如果 (流 == 0) { 返回 }
    流.状态 = 状态_关闭
    如果 (流.关闭回调 != 0) { 流.关闭回调() }
}

函数 流_动态水位(流, 写速率, 读速率) {
    如果 (流 == 0) { 返回 }
    水位调整次 = 水位调整次 + 1
    如果 (写速率 > 读速率 * 2) {
        流.水位线 = 流.水位线 * 2
        如果 (流.水位线 > 最大水位) { 流.水位线 = 最大水位 }
    } 否则 如果 (写速率 * 2 < 读速率) {
        流.水位线 = 流.水位线 / 2
        如果 (流.水位线 < 最小水位) { 流.水位线 = 最小水位 }
    }
}

函数 流_管道(源流, 目标流) {
    当 (源流.队列头 != 0) {
        定义 块 = 流_出队(源流)
        如果 (块 == 0) { 跳出 }
        流_入队(目标流, 块.数据, 块.大小)
        堆_释放(块.数据)
        堆_释放(块)
        如果 (流_有背压(目标流)) { 返回 1 }
    }
    返回 0
}

函数 流_分叉(源流) {
    定义 副本 = 流_创建(源流.水位线)
    定义 可变 当前 = 源流.队列头
    当 (当前 != 0) {
        流_入队(副本, 当前.数据, 当前.大小)
        当前 = 当前.后继
    }
    返回 副本
}

函数 流_获取大小(流) {
    如果 (流 == 0) { 返回 0 }
    返回 流.队列大小
}

函数 流_获取水位(流) {
    如果 (流 == 0) { 返回 默认水位 }
    返回 流.水位线
}

函数 流_完整统计() {
    返回 [流总数, 背压总次, 水位调整次]
}

// §2 流健康检查与诊断

函数 流_健康检查() {
    定义 可变 问题 = []
    如果 (背压总次 > 流总数 * 10 && 流总数 > 10) {
        追加(问题, "流背压过于频繁")
    }
    如果 (计数(问题) == 0) { 返回 "流子系统健康" }
    返回 问题
}

函数 流_详细统计() {
    返回 {
        流总数: 流总数,
        背压总次: 背压总次,
        水位调整: 水位调整次,
    }
}

函数 流_重置统计() {
    流总数 = 0
    背压总次 = 0
    水位调整次 = 0
}

函数 流_诊断(流) {
    如果 (流 == 0) { 返回 "流为空" }
    返回 {
        状态: 流_状态名(流.状态),
        水位线: 流.水位线,
        队列大小: 流.队列大小,
        块数: 流.块数,
        总读: 流.总读字节,
        总写: 流.总写字节,
        背压次数: 流.背压次数,
        有背压: 流_有背压(流),
    }
}

函数 流_状态名(状态) {
    如果 (状态 == 状态_可读) { 返回 "readable" }
    如果 (状态 == 状态_关闭) { 返回 "closed" }
    如果 (状态 == 状态_错误) { 返回 "errored" }
    返回 "unknown"
}

// §3 可写流(WritableStream)

结构 可写流 {
    状态,
    写回调,
    关闭回调,
    中止回调,
    总写字节,
    写次数,
    锁定,
}

函数 可写流_创建(写回调, 关闭回调) {
    定义 流 = 可写流 {}
    流.状态 = 0
    流.写回调 = 写回调
    流.关闭回调 = 关闭回调
    流.中止回调 = 0
    流.总写字节 = 0
    流.写次数 = 0
    流.锁定 = 假
    返回 流
}

函数 可写流_写(流, 数据, 大小) {
    如果 (流 == 0 || 流.状态 != 0) { 返回 错误_无效参数 }
    如果 (流.写回调 != 0) { 流.写回调(数据, 大小) }
    流.总写字节 = 流.总写字节 + 大小
    流.写次数 = 流.写次数 + 1
    返回 0
}

函数 可写流_关闭(流) {
    如果 (流 == 0) { 返回 }
    流.状态 = 1
    如果 (流.关闭回调 != 0) { 流.关闭回调() }
}

函数 可写流_中止(流, 原因) {
    如果 (流 == 0) { 返回 }
    流.状态 = 2
    如果 (流.中止回调 != 0) { 流.中止回调(原因) }
}

// §4 转换流(TransformStream)

结构 转换流 {
    可读端,
    可写端,
    转换回调,
    刷新回调,
    总转换字节,
    转换次数,
}

函数 转换流_创建(转换回调) {
    定义 流 = 转换流 {}
    流.可读端 = 流_创建(默认水位)
    流.可写端 = 可写流_创建(0, 0)
    流.转换回调 = 转换回调
    流.刷新回调 = 0
    流.总转换字节 = 0
    流.转换次数 = 0
    返回 流
}

函数 转换流_写入(流, 数据, 大小) {
    如果 (流 == 0 || 流.转换回调 == 0) { 返回 错误_无效参数 }
    流.转换次数 = 流.转换次数 + 1
    流.总转换字节 = 流.总转换字节 + 大小
    返回 0
}

函数 转换流_刷新(流) {
    如果 (流 == 0) { 返回 }
    如果 (流.刷新回调 != 0) { 流.刷新回调() }
}

// §5 流操作扩展

函数 流_清空(流) {
    如果 (流 == 0) { 返回 }
    当 (流.队列头 != 0) {
        定义 块 = 流_出队(流)
        如果 (块 == 0) { 跳出 }
        堆_释放(块.数据)
        堆_释放(块)
    }
}

函数 流_读全部(流) {
    如果 (流 == 0) { 返回 0 }
    定义 总大小 = 流.队列大小
    如果 (总大小 == 0) { 返回 0 }
    定义 结果 = 堆_分配(总大小 + 1)
    定义 可变 偏移 = 0
    当 (流.队列头 != 0) {
        定义 块 = 流_出队(流)
        如果 (块 == 0) { 跳出 }
        内存_复制(结果 + 偏移, 块.数据, 块.大小)
        偏移 = 偏移 + 块.大小
        堆_释放(块.数据)
        堆_释放(块)
    }
    内存_写8(结果 + 偏移, 0)
    返回 结果
}

函数 流_是空(流) {
    如果 (流 == 0) { 返回 真 }
    返回 流.队列大小 == 0
}

函数 流_是关闭(流) {
    如果 (流 == 0) { 返回 真 }
    返回 流.状态 == 状态_关闭
}

函数 流_设读回调(流, 回调) {
    如果 (流 == 0) { 返回 }
    流.读回调 = 回调
}

函数 流_设关闭回调(流, 回调) {
    如果 (流 == 0) { 返回 }
    流.关闭回调 = 回调
}

// §6 智能流优化策略

定义 可变 智能_流预测命中 = 0
定义 可变 智能_流预测总数 = 0

函数 流_智能预取(流) {
    如果 (流 == 0) { 返回 }
    智能_流预测总数 = 智能_流预测总数 + 1
    如果 (流.队列大小 < 流.水位线 / 4) {
        智能_流预测命中 = 智能_流预测命中 + 1
    }
}

函数 流_智能命中率() {
    如果 (智能_流预测总数 == 0) { 返回 0 }
    返回 智能_流预测命中 * 100 / 智能_流预测总数
}

定义 错误_无效参数 = -22
定义 错误_队列满 = -105

函数 流_类型名(类型) {
    如果 (类型 == 流_可读) { 返回 "ReadableStream" }
    如果 (类型 == 流_可写) { 返回 "WritableStream" }
    如果 (类型 == 流_转换) { 返回 "TransformStream" }
    返回 "Unknown"
}

导入("../../运行时/智能推理/注意力机制.nova")


函数 多模态_最小长度(a, b) {
    定义 可变 长 = 计数(a)
    如果 (计数(b) < 长) {
        长 = 计数(b)
    }
    返回 长
}

函数 多模态_余弦相似(a, b) {
    定义 点积 = 向量_点积(a,  b, 0)
    定义 na = 向量_范数(a, 0)
    定义 nb = 向量_范数(b, 0)
    如果 (na == 0) {
        返回 0
    }
    如果 (nb == 0) {
        返回 0
    }
    返回 点积 * 1000 / (na * nb)
}

函数 跨模态_匹配(图像特征, 文本特征列表) {
    如果 (计数(文本特征列表) == 0) {
        返回 -1
    }
    定义 可变 最佳 = 0
    定义 可变 最佳分 = 余弦相似(图像特征, 文本特征列表[0])
    定义 可变 j = 1
    当 (j < 计数(文本特征列表)) {
        定义 分数 = 余弦相似(图像特征, 文本特征列表[j])
        如果 (分数 > 最佳分) {
            最佳 = j
            最佳分 = 分数
        }
        j = j + 1
    }
    返回 最佳
}

函数 融合_拼接(特征A, 特征B) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(特征A)) {
        追加(结果, 特征A[i])
        i = i + 1
    }
    i = 0
    当 (i < 计数(特征B)) {
        追加(结果, 特征B[i])
        i = i + 1
    }
    返回 结果
}

函数 融合_加权(特征A, 特征B, 权重A) {
    定义 可变 结果 = []
    定义 权重B = 100 - 权重A
    定义 长 = 多模态_最小长度(特征A, 特征B)
    定义 可变 i = 0
    当 (i < 长) {
        追加(结果, (特征A[i] * 权重A + 特征B[i] * 权重B) / 100)
        i = i + 1
    }
    返回 结果
}

函数 图像_均值特征(像素, 特征维度) {
    定义 总 = 计数(像素)
    如果 (特征维度 == 0) { 特征维度 = 1 }
    定义 可变 每块 = 总 / 特征维度
    如果 (每块 == 0) {
        每块 = 1
    }
    定义 可变 特征数据 = []
    定义 可变 d = 0
    当 (d < 特征维度) {
        定义 可变 和值 = 0
        定义 可变 i = d * 每块
        定义 可变 末尾 = i + 每块
        如果 (末尾 > 总) {
            末尾 = 总
        }
        当 (i < 末尾) {
            和值 = 和值 + 像素[i]
            i = i + 1
        }
        追加(特征数据, 和值 / 每块)
        d = d + 1
    }
    返回 特征数据
}

函数 音频_能量特征(样本, 特征维度) {
    定义 总 = 计数(样本)
    定义 可变 每块 = 总 / 特征维度
    如果 (每块 == 0) {
        每块 = 1
    }
    定义 可变 特征数据 = []
    定义 可变 d = 0
    当 (d < 特征维度) {
        定义 可变 和值 = 0
        定义 可变 i = d * 每块
        定义 可变 末尾 = i + 每块
        如果 (末尾 > 总) {
            末尾 = 总
        }
        当 (i < 末尾) {
            和值 = 和值 + 绝对值(样本[i])
            i = i + 1
        }
        追加(特征数据, 和值 / 每块)
        d = d + 1
    }
    返回 特征数据
}

函数 融合_门控(特征A, 特征B, 门值) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(特征A)) {
        如果 (i < 计数(特征B)) {
            追加(结果, (特征A[i] * 门值 + 特征B[i] * (100 - 门值)) / 100)
        } 否则 {
            追加(结果, 特征A[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 特征_投影(输入, 投影维度) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 投影维度) {
        如果 (i < 计数(输入)) {
            追加(结果, 输入[i])
        } 否则 {
            追加(结果, 0)
        }
        i = i + 1
    }
    返回 结果
}

函数 多查询_匹配(查询列表, 候选列表) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(查询列表)) {
        追加(结果, 跨模态_匹配(查询列表[i], 候选列表))
        i = i + 1
    }
    返回 结果
}

函数 图文_拼接融合(图像特征, 文本特征) {
    返回 融合_拼接(图像特征, 文本特征)
}

函数 图文_门控融合(图像特征, 文本特征, 门控权重) {
    定义 可变 结果 = []
    定义 长 = 多模态_最小长度(图像特征, 文本特征)
    定义 可变 i = 0
    当 (i < 长) {
        追加(结果, 图像特征[i] * 门控权重 / 100 + 文本特征[i] * (100 - 门控权重) / 100)
        i = i + 1
    }
    返回 结果
}

函数 图文_交叉注意力(查询, 键值) {
    定义 可变 分数列表 = []
    定义 可变 i = 0
    当 (i < 计数(键值)) {
        定义 可变 分数 = 0
        定义 长 = 多模态_最小长度(查询, 键值[i])
        定义 可变 j = 0
        当 (j < 长) {
            分数 = 分数 + 查询[j] * 键值[i][j]
            j = j + 1
        }
        追加(分数列表, 分数)
        i = i + 1
    }
    返回 分数列表
}

函数 多模态_音频_能量(采样, 窗口大小) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i + 窗口大小 <= 计数(采样)) {
        定义 可变 能量 = 0
        定义 可变 j = 0
        当 (j < 窗口大小) {
            能量 = 能量 + 采样[i + j] * 采样[i + j]
            j = j + 1
        }
        追加(结果, 能量 / 窗口大小)
        i = i + 窗口大小
    }
    返回 结果
}

函数 多模态_音频_过零率(采样, 窗口大小) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i + 窗口大小 <= 计数(采样)) {
        定义 可变 过零 = 0
        定义 可变 j = 1
        当 (j < 窗口大小) {
            定义 可变 当前 = 采样[i + j]
            定义 可变 前一 = 采样[i + j - 1]
            定义 可变 跨零 = 假
            如果 (当前 >= 0) {
                如果 (前一 < 0) {
                    跨零 = 真
                }
            }
            如果 (跨零 == 假) {
                如果 (当前 < 0) {
                    如果 (前一 >= 0) {
                        跨零 = 真
                    }
                }
            }
            如果 (跨零) {
                过零 = 过零 + 1
            }
            j = j + 1
        }
        追加(结果, 过零 * 1000 / 窗口大小)
        i = i + 窗口大小
    }
    返回 结果
}

函数 对比学习_损失(锚点, 正样本, 负样本列表, 温度) {
    定义 可变 正分 = 0
    定义 正长 = 多模态_最小长度(锚点, 正样本)
    定义 可变 i = 0
    当 (i < 正长) {
        正分 = 正分 + 锚点[i] * 正样本[i]
        i = i + 1
    }
    正分 = 正分 * 1000 / (温度 + 1)
    定义 可变 负总 = 0
    i = 0
    当 (i < 计数(负样本列表)) {
        定义 可变 负分 = 0
        定义 负长 = 多模态_最小长度(锚点, 负样本列表[i])
        定义 可变 j = 0
        当 (j < 负长) {
            负分 = 负分 + 锚点[j] * 负样本列表[i][j]
            j = j + 1
        }
        负总 = 负总 + 负分 * 1000 / (温度 + 1)
        i = i + 1
    }
    返回 负总 - 正分
}

定义 可变 _多模态_融合数 = 0
定义 可变 _多模态_检索数 = 0

函数 多模态_记录融合() {
    _多模态_融合数 = _多模态_融合数 + 1
}

函数 多模态_记录检索() {
    _多模态_检索数 = _多模态_检索数 + 1
}

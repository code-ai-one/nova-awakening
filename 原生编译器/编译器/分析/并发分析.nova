// Nova · 编译器 · 并发安全分析 (Concurrency Safety Analysis)
// 检测数据竞争 / 死锁风险 / 原子性违规
// 静态分析：无需运行时，编译期发现并发问题

// 并发对象访问类型

导入("../../标准库/基础.nova")

// 共享读（允许多线程同时读）
// 独占写（需要锁保护）
定义 访问_原子读写 = 2  // 原子操作（天然线程安全）

// 锁类型
定义 锁_互斥 = 0      // Mutex：独占
定义 锁_读写 = 1      // RwLock：多读/单写
定义 锁_自旋 = 2      // Spinlock：轻量级
定义 锁_无锁 = 3      // Lock-free（原子操作）

// 锁状态：[锁ID, 锁类型, 持有线程, 是否锁定]
函数 锁状态_创建(ID, 类型) {
    返回 [ID, 类型, 0 - 1, 假]  // 初始：未持有
}
函数 锁状态_ID(s) { 返回 s[0] }
函数 锁状态_类型(s) { 返回 s[1] }
函数 锁状态_持有者(s) { 返回 s[2] }
函数 锁状态_已锁定(s) { 返回 s[3] }
函数 锁状态_获取(s, 线程ID) { s[2] = 线程ID s[3] = 真 }
函数 锁状态_释放(s) { s[2] = 0 - 1 s[3] = 假 }

// 共享变量访问记录：[变量名, 访问类型, 线程ID, 代码位置, 是否持有锁]
函数 访问记录_创建(变量名, 访问类型, 线程ID, 位置, 有锁) {
    返回 [变量名, 访问类型, 线程ID, 位置, 有锁]
}
函数 访问记录_变量(r) { 返回 r[0] }
函数 访问记录_类型(r) { 返回 r[1] }
函数 访问记录_线程(r) { 返回 r[2] }
函数 访问记录_有锁(r) { 返回 r[4] }

// 数据竞争检测
// 判断两个访问是否构成数据竞争：
// 条件：同一变量，不同线程，至少一个写，且没有锁保护

函数 并发_是数据竞争(访问A, 访问B) {
    // 同一变量
    如果 (访问记录_变量(访问A) != 访问记录_变量(访问B)) { 返回 假 }
    // 不同线程
    如果 (访问记录_线程(访问A) == 访问记录_线程(访问B)) { 返回 假 }
    // 至少一个写
    如果 (访问记录_类型(访问A) == 访问_读 且 访问记录_类型(访问B) == 访问_读) { 返回 假 }
    // 两者都没有锁保护 → 数据竞争
    如果 (!访问记录_有锁(访问A) 或 !访问记录_有锁(访问B)) { 返回 真 }
    返回 假
}

// 批量检查访问记录列表中的数据竞争
函数 并发_扫描数据竞争(访问列表) {
    定义 可变 竞争列表 = []
    定义 n = 计数(访问列表)
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 j = i + 1
        当 (j < n) {
            如果 (并发_是数据竞争(访问列表[i], 访问列表[j])) {
                追加(竞争列表, [访问列表[i], 访问列表[j]])
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 竞争列表
}

// 死锁检测 (锁等待图 - Wait-for Graph)
// 如果存在环，则有死锁风险

定义 可变 _锁等待图 = []  // [[线程A等待锁X, 持有者线程B], ...]

函数 并发_记录等待(等待线程, 锁ID, 持有线程) {
    追加(_锁等待图, [等待线程, 锁ID, 持有线程])
}

函数 并发_重置等待图() { _锁等待图 = [] }

// 检测等待图中的环（简单DFS）
函数 并发_检测死锁() {
    定义 可变 死锁风险 = []
    定义 可变 i = 0
    当 (i < 计数(_锁等待图)) {
        定义 等待者 = _锁等待图[i][0]
        定义 持有者 = _锁等待图[i][2]
        // 检查持有者是否也在等待等待者持有的某个锁
        定义 可变 j = 0
        当 (j < 计数(_锁等待图)) {
            如果 (i != j) {
                如果 (_锁等待图[j][0] == 持有者) {
                    // 持有者在等待某个锁
                    定义 可变 k = 0
                    当 (k < 计数(_锁等待图)) {
                        如果 (_锁等待图[k][0] == 等待者 且 _锁等待图[k][2] == 持有者) {
                            追加(死锁风险, [等待者, 持有者, _锁等待图[i][1]])
                        }
                        k = k + 1
                    }
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 死锁风险
}

// 原子性违规检测
// 检测"检查-操作"序列之间的时间窗口问题（TOCTOU）

定义 可变 _原子性_检查序列 = []  // [[检查位置, 操作位置, 变量名, 线程ID]]

函数 原子性_记录检查(位置, 变量名, 线程ID) {
    追加(_原子性_检查序列, [位置, 0 - 1, 变量名, 线程ID])
}

函数 原子性_记录操作(位置, 变量名, 线程ID) {
    定义 可变 i = 0
    当 (i < 计数(_原子性_检查序列)) {
        定义 记录 = _原子性_检查序列[i]
        如果 (记录[2] == 变量名 且 记录[3] == 线程ID 且 记录[1] == 0 - 1) {
            记录[1] = 位置
            返回 空
        }
        i = i + 1
    }
    // 没有对应的检查记录：追加操作
    追加(_原子性_检查序列, [0 - 1, 位置, 变量名, 线程ID])
}

// 查找潜在的 TOCTOU 漏洞（检查和操作之间有时间窗口）
函数 原子性_扫描TOCTOU(访问列表) {
    定义 可变 风险 = []
    定义 可变 i = 0
    当 (i < 计数(_原子性_检查序列)) {
        定义 记录 = _原子性_检查序列[i]
        如果 (记录[0] >= 0 且 记录[1] >= 0) {
            // 在检查和操作之间，是否有其他线程修改了相同变量？
            定义 变量名 = 记录[2]
            定义 线程ID = 记录[3]
            // 检查其他线程的写操作是否在检查和操作之间
            定义 可变 j = 0
            当 (j < 计数(访问列表)) {
                定义 访问 = 访问列表[j]
                如果 (访问记录_变量(访问) == 变量名 且 
                       访问记录_线程(访问) != 线程ID 且 
                       访问记录_类型(访问) == 访问_写) {
                    追加(风险, [变量名, 线程ID, "TOCTOU时间窗口漏洞"])
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    返回 风险
}

// Send/Sync 类型分析
// 判断类型是否可以安全地跨线程传递（类似Rust的Send/Sync）

定义 线程安全_否 = 0    // 不能跨线程
定义 线程安全_Send = 1  // 可以发送（所有权转移）
定义 线程安全_Sync = 2  // 可以共享（引用传递）

函数 分析类型线程安全(类型) {
    // 整数/浮点：天然 Send+Sync
    如果 (类型 == 1 或 类型 == 2) { 返回 线程安全_Sync }
    // 字符串（不可变）：Send+Sync
    如果 (类型 == 3) { 返回 线程安全_Sync }
    // 布尔：Send+Sync
    如果 (类型 == 4) { 返回 线程安全_Sync }
    // 列表（可变）：Send（转移所有权），不是Sync
    如果 (类型 == 5) { 返回 线程安全_Send }
    // 字典（可变）：Send，不是Sync
    如果 (类型 == 6) { 返回 线程安全_Send }
    // 函数（闭包可能捕获非Send类型）：Send（保守）
    如果 (类型 == 7) { 返回 线程安全_Send }
    返回 线程安全_否  // 未知类型：保守不安全
}

// 并发分析报告
函数 并发分析_报告(访问列表) {
    定义 竞争 = 并发_扫描数据竞争(访问列表)
    定义 死锁 = 并发_检测死锁()
    定义 toctou = 原子性_扫描TOCTOU(访问列表)
    定义 可变 报告 = []
    追加(报告, ["数据竞争", 计数(竞争)])
    追加(报告, ["死锁风险", 计数(死锁)])
    追加(报告, ["原子性违规", 计数(toctou)])
    返回 报告
}

// 统计
定义 可变 _并发_分析次数 = 0
定义 可变 _并发_竞争数 = 0

函数 并发_记录分析(竞争数) {
    _并发_分析次数 = _并发_分析次数 + 1
    _并发_竞争数 = _并发_竞争数 + 竞争数
}

函数 并发_统计报告() {
    返回 [_并发_分析次数, _并发_竞争数]
}

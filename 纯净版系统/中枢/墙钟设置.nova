// NovaOS 时间子系统 · 墙钟设置与驯服引擎
// 功能:
//  §1 墙钟/单调钟/启动钟统一时基
//  §2 TSC/HPET多时钟源评分与切换
//  §3 NTP PI控制驯服(偏移+频偏)
//  §4 闰秒处理(插入/删除/平滑)
//  §5 时区与UTC偏移
//  §6 高精度延时(纳秒/微秒/毫秒)
//  §7 快照与诊断统计
//  §8 AI预测驱动的时钟异常检测

导入("./类型定义.nova")
导入("./错误码.nova")
导入("../推理/智能渠道.nova")
导入("./硬链接.nova")
导入("../推理/值乘.nova")
导入("./恐慌.nova")
导入("../推理/智能总线鼠标.nova")
导入("./整数转字符串.nova")
导入("../引导/特权指令.nova")

// §1 常量

定义 NS_PER_S = 1000000000
定义 US_PER_S = 1000000
定义 MS_PER_S = 1000
定义 NS_PER_MS = 1000000
定义 NS_PER_US = 1000

定义 Q10 = 1024
定义 Q_ONE = 1024
定义 Q_HALF = 512

定义 CLOCK_SRC_TSC = 1
定义 CLOCK_SRC_HPET = 2
定义 CLOCK_SRC_ACPI = 3
定义 CLOCK_SRC_PARAVIRT = 4

定义 NTP_STATE_INIT = 0
定义 NTP_STATE_LOCKING = 1
定义 NTP_STATE_LOCKED = 2
定义 NTP_STATE_HOLDOVER = 3

定义 最大闰秒记录 = 128
定义 最大时区记录 = 64

定义 TSC_抖动阈值_ns = 20000         // 20us
定义 TSC_漂移阈值_ppm = 250
定义 NTP_最大步进_ns = 500000000      // 500ms
定义 NTP_最大slew_ppm = 500

定义 EWMA_ALPHA_慢 = 64              // 0.0625
定义 EWMA_ALPHA_中 = 205             // 0.2
定义 EWMA_ALPHA_快 = 512             // 0.5

// §2 数据结构

结构 时钟源项 {
    名称,
    类型,
    评分,
    可用,
    周期频率,      // Hz
    读取函数,      // fn()->counter
}

结构 墙钟状态 {
    锚点秒,         // 上次同步UTC秒
    锚点纳秒,       // 上次同步纳秒
    锚点计数器,     // 对应硬件计数器
    当前源类型,
    频率Hz,
    频偏_ppm,       // 当前频偏估计
    单调偏移_ns,    // 单调钟偏移
    启动时戳_ns,    // 系统启动时间
    上次更新_ns,
}

结构 NTP状态 {
    状态,
    偏移_ns,            // 当前观测偏移
    频偏_ppm,           // 当前频偏
    相位积分项_ns,      // PI积分项
    上次同步_ns,
    连续成功次数,
    连续失败次数,
    抖动_ewma_ns,
    往返延迟_ewma_ns,
}

结构 闰秒记录 {
    生效UTC秒,
    类型,               // +1 插入 / -1 删除
    已执行,
}

结构 时区记录 {
    名称,
    UTC偏移分钟,        // 例如 +480
    夏令时标记,
}

结构 时间快照 {
    utc秒,
    utc纳秒,
    monotonic_ns,
    boottime_ns,
    源类型,
    估计误差_ns,
}

// §3 全局状态

定义 可变 墙钟_全局 = 墙钟状态 {}
定义 可变 NTP_全局 = NTP状态 {}
定义 可变 时钟源列表 = []
定义 可变 当前时钟源名 = "未初始化"

定义 可变 TSC频率 = 0
定义 可变 HPET_可用 = 假
定义 可变 tsc_不稳定 = 假

定义 可变 墙钟_秒 = 0
定义 可变 墙钟_纳秒 = 0
定义 可变 墙钟_上次同步TSC = 0

定义 可变 闰秒表 = []
定义 可变 时区表 = []
定义 可变 当前时区名 = "UTC"
定义 可变 当前时区偏移分钟 = 0

定义 可变 时间误差_ewma_ns = 0
定义 可变 时间抖动_ewma_ns = 0
定义 可变 时间跳变计数 = 0
定义 可变 同步失败计数 = 0

// §4 初始化

函数 墙钟_初始化() {
    // 初始化时钟源
    时钟源列表 = []
    追加(时钟源列表, 时钟源项 { 名称: "tsc", 类型: CLOCK_SRC_TSC, 评分: 9000, 可用: 真, 周期频率: TSC_探测频率(), 读取函数: TSC_读取 })
    追加(时钟源列表, 时钟源项 { 名称: "hpet", 类型: CLOCK_SRC_HPET, 评分: 如果(HPET_检测(), 8000, 0), 可用: HPET_检测(), 周期频率: HPET_频率(), 读取函数: HPET_读取 })
    追加(时钟源列表, 时钟源项 { 名称: "acpi_pm", 类型: CLOCK_SRC_ACPI, 评分: 3500, 可用: ACPI_PM_可用(), 周期频率: 3579545, 读取函数: ACPI_PM_读取 })

    时钟源_选择最优()
    墙钟_秒 = 0
    墙钟_纳秒 = 0
    墙钟_上次同步TSC = 读取时间戳()

    墙钟_全局.锚点秒 = 0
    墙钟_全局.锚点纳秒 = 0
    墙钟_全局.锚点计数器 = 当前源_读取计数器()
    墙钟_全局.当前源类型 = 当前源_类型()
    墙钟_全局.频率Hz = 当前源_频率()
    墙钟_全局.频偏_ppm = 0
    墙钟_全局.单调偏移_ns = 0
    墙钟_全局.启动时戳_ns = 0
    墙钟_全局.上次更新_ns = 0

    NTP_全局.状态 = NTP_STATE_INIT
    NTP_全局.偏移_ns = 0
    NTP_全局.频偏_ppm = 0
    NTP_全局.相位积分项_ns = 0
    NTP_全局.上次同步_ns = 0
    NTP_全局.连续成功次数 = 0
    NTP_全局.连续失败次数 = 0
    NTP_全局.抖动_ewma_ns = 0
    NTP_全局.往返延迟_ewma_ns = 0

    闰秒表 = []
    时区表 = []
    时区_加载默认()
    闰秒_加载默认()
}

函数 时区_加载默认() {
    // 常用时区(分钟偏移)
    追加(时区表, 时区记录 { 名称: "UTC", UTC偏移分钟: 0, 夏令时标记: 假 })
    追加(时区表, 时区记录 { 名称: "Asia/Shanghai", UTC偏移分钟: 480, 夏令时标记: 假 })

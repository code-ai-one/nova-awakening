// WASM 引用类型 / 异常处理 / 尾调用

// ref.null — 空引用
函数 wasm_引用_空(类型) { 返回 [0xD0, 类型]
}
// ref.is_null — 引用判空
函数 wasm_引用_是否空() { 返回 [0xD1] }
// ref.func — 函数引用
函数 wasm_引用_函数(索引) { 定义 结果 = [0xD2]
 定义 编码值 = wasm_编码_uleb128(索引)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 返回 结果
}
// table.get / table.set
函数 wasm_表_获取(表索引) { 定义 结果 = [0x25]
 定义 编码值 = wasm_编码_uleb128(表索引)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 返回 结果
}
函数 wasm_表_设置(表索引) { 定义 结果 = [0x26]
 定义 编码值 = wasm_编码_uleb128(表索引)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 返回 结果
}
// 异常处理/throw (异常处理提案)
函数 wasm_尝试(bt) { 返回 [0x06, bt] }
函数 wasm_捕获(标签) { 定义 结果 = [0x07]
 定义 编码值 = wasm_编码_uleb128(标签)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 返回 结果
}
函数 wasm_抛出(标签) { 定义 结果 = [0x08]
 定义 编码值 = wasm_编码_uleb128(标签)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 返回 结果
}
函数 wasm_重抛(深度) { 返回 [0x09, 深度] }
// return_call / return_call_indirect (尾调用)
函数 wasm_返回调用(索引) { 定义 结果 = [0x12]
 定义 编码值 = wasm_编码_uleb128(索引)
 定义 可变 i = 0
 当 (i < 计数(编码值)) { 追加(结果, 编码值[i]) i = i + 1 }
 返回 结果
}
函数 wasm_返回间接调用(类型索引, 表索引) { 定义 结果 = [0x13]
 定义 enc1 = wasm_编码_uleb128(类型索引)
 定义 enc2 = wasm_编码_uleb128(表索引)
 定义 可变 i = 0
 当 (i < 计数(enc1)) { 追加(结果, enc1[i]) i = i + 1 }
 i = 0
 当 (i < 计数(enc2)) { 追加(结果, enc2[i]) i = i + 1 }
 返回 结果
}


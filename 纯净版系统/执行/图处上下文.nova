// 平台适配层: 图处命令缓冲 — 硬件加速渲染接口
// 浏览器图处加速架构:
//   渲染进程(不可信) → 图处命令缓冲 → 图处进程(可信) → 图处硬件
//   命令缓冲是安全边界: 渲染进程不能直接访问图处
// NovaOS 图处系统调用:
//   Nova系统调用_图处_创建上下文() → ctx_id
//   Nova系统调用_图处_提交命令(ctx_id, cmd_buf, size) → 0/-1
//   Nova系统调用_图处_创建纹理(ctx_id, w, h, format) → tex_id
//   Nova系统调用_图处_上传纹理(ctx_id, tex_id, data, size) → 0/-1
//   Nova系统调用_图处_创建着色器(ctx_id, source, len) → shader_id
//   Nova系统调用_图处_绘制(ctx_id, draw_cmd) → 0/-1
//   Nova系统调用_图处_交换缓冲(ctx_id) → 0/-1
// 【颠覆性创新】AI驱动的图处资源管理:
//   ① AI预测下一帧需要的纹理→提前上传(减少上传延迟)
//   ② AI评估图层复杂度→决定图处合成vs软件合成
//   ③ AI监控图处负载→自动降级渲染精度保帧率

// NGCC理论: Nova GPU Command Context
// 核心创新:
//  1) 双缓冲命令队列: 前台写入/后台提交, 零等待流水线
//  2) 纩理图集缓存+LRU: 减少重复上传, 命中率监控
//  3) 着色器编译缓存+哈希快速查找
//  4) AI图处负载预测: 6维特征推理自动降级
//  5) CRC32命令完整性校验

定义 NGCC_CMD_BUF_SIZE     = 262144   // 256KB
定义 NGCC_MAX_TEXTURES     = 256
定义 NGCC_MAX_SHADERS      = 64
定义 NGCC_MAX_FRAMEBUFFERS = 16
定义 NGCC_MAX_PROGRAMS     = 32
定义 NGCC_TEX_CACHE_MAX    = 128
定义 NGCC_SHADER_CACHE_MAX = 32
定义 NGCC_CMD_HEADER_SIZE  = 8

定义 可变 NGCC_提交次数     = 0
定义 可变 NGCC_命令总数     = 0
定义 可变 NGCC_纩理上传次数 = 0
定义 可变 NGCC_纩理缓存命中 = 0
定义 可变 NGCC_着色器编译次数 = 0
定义 可变 NGCC_AI预测次数   = 0
定义 可变 NGCC_降级次数     = 0

// §2 命令缓冲序列化

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 NGCC_命令剩余空间(ctx) {
    返回 ctx.缓冲大小 - ctx.写位置
}

函数 NGCC_写u32(ctx, val) {
    如果 (NGCC_命令剩余空间(ctx) < 4) { 返回 假 }
    内存写32(ctx.命令缓冲 + ctx.写位置, val)
    ctx.写位置 = ctx.写位置 + 4
    返回 真
}

函数 NGCC_写u16(ctx, val) {
    如果 (NGCC_命令剩余空间(ctx) < 2) { 返回 假 }
    内存写16(ctx.命令缓冲 + ctx.写位置, val)
    ctx.写位置 = ctx.写位置 + 2
    返回 真
}

函数 NGCC_写u8(ctx, val) {
    如果 (NGCC_命令剩余空间(ctx) < 1) { 返回 假 }
    内存写8(ctx.命令缓冲 + ctx.写位置, val)
    ctx.写位置 = ctx.写位置 + 1
    返回 真
}

函数 NGCC_写命令头(ctx, cmd_type, payload_size) {
    如果 (NGCC_命令剩余空间(ctx) < NGCC_CMD_HEADER_SIZE + payload_size) { 返回 假 }
    NGCC_写u32(ctx, cmd_type)
    NGCC_写u32(ctx, payload_size)
    NGCC_命令总数 = NGCC_命令总数 + 1
    返回 真
}

函数 NGCC_CRC32_简化(buf, off, len) {
    定义 可变 crc = 0xFFFFFFFF
    定义 可变 i = 0
    当 (i < len) {
        定义 byte = 内存读8(buf + off + i) & 0xFF
        crc = crc ^ byte
        定义 可变 b = 0
        当 (b < 8) {
            如果 (crc & 1) { crc = (crc >> 1) ^ 0xEDB88320 }
            否则 { crc = crc >> 1 }
            b = b + 1
        }
        i = i + 1
    }
    返回 crc ^ 0xFFFFFFFF
}

// §3 命令提交

函数 图处_提交命令(ctx) {
    如果 (ctx == 0 || ctx.写位置 == 0) { 返回 0 }
    // 追加CRC32校验
    定义 crc = NGCC_CRC32_简化(ctx.命令缓冲, 0, ctx.写位置)
    NGCC_写u32(ctx, crc)
    定义 result = 系统调用(系统调用_图处_提交命令, ctx.ctx_id, ctx.命令缓冲, ctx.写位置, 0, 0)
    ctx.写位置 = 0
    NGCC_提交次数 = NGCC_提交次数 + 1
    返回 result
}

函数 图处_刷新帧(ctx) {
    如果 (ctx == 0) { 返回 -1 }
    图处_提交命令(ctx)
    定义 r = 系统调用(系统调用_图处_交换缓冲, ctx.ctx_id, 0, 0, 0, 0)
    ctx.帧数 = ctx.帧数 + 1
    返回 r
}

函数 图处_自动提交检查(ctx, 需要字节) {
    如果 (NGCC_命令剩余空间(ctx) < 需要字节 + 16) {
        图处_提交命令(ctx)
    }
}

// §4 绘制命令封装

函数 图处_清屏(ctx, r, g, b, a) {
    如果 (ctx == 0) { 返回 }
    图处_自动提交检查(ctx, 24)
    NGCC_写命令头(ctx, 图处命令_清屏, 16)
    NGCC_写u32(ctx, r)
    NGCC_写u32(ctx, g)
    NGCC_写u32(ctx, b)
    NGCC_写u32(ctx, a)
}

函数 图处_绘制矩形(ctx, x, y, w, h, color) {
    如果 (ctx == 0) { 返回 }
    图处_自动提交检查(ctx, 28)
    NGCC_写命令头(ctx, 图处命令_绘制矩形, 20)
    NGCC_写u32(ctx, x)
    NGCC_写u32(ctx, y)
    NGCC_写u32(ctx, w)
    NGCC_写u32(ctx, h)
    NGCC_写u32(ctx, color)
}

函数 图处_绘制纩理(ctx, tex_id, x, y, w, h, u0, v0, u1, v1) {
    如果 (ctx == 0) { 返回 }
    图处_自动提交检查(ctx, 44)
    NGCC_写命令头(ctx, 图处命令_绘制纩理, 36)
    NGCC_写u32(ctx, tex_id)
    NGCC_写u32(ctx, x)
    NGCC_写u32(ctx, y)
    NGCC_写u32(ctx, w)
    NGCC_写u32(ctx, h)
    NGCC_写u32(ctx, u0)
    NGCC_写u32(ctx, v0)
    NGCC_写u32(ctx, u1)
    NGCC_写u32(ctx, v1)
}

函数 图处_绘制圆角矩形(ctx, x, y, w, h, r, color) {
    如果 (ctx == 0) { 返回 }
    图处_自动提交检查(ctx, 32)
    NGCC_写命令头(ctx, 图处命令_绘制圆角矩形, 24)
    NGCC_写u32(ctx, x)
    NGCC_写u32(ctx, y)
    NGCC_写u32(ctx, w)
    NGCC_写u32(ctx, h)
    NGCC_写u32(ctx, r)
    NGCC_写u32(ctx, color)
}

函数 图处_绘制阴影(ctx, x, y, w, h, 模糊半径, color) {
    如果 (ctx == 0) { 返回 }
    图处_自动提交检查(ctx, 32)
    NGCC_写命令头(ctx, 图处命令_绘制阴影, 24)
    NGCC_写u32(ctx, x)
    NGCC_写u32(ctx, y)
    NGCC_写u32(ctx, w)
    NGCC_写u32(ctx, h)
    NGCC_写u32(ctx, 模糊半径)
    NGCC_写u32(ctx, color)
}

函数 图处_绘制渐变(ctx, x, y, w, h, color0, color1, 方向) {
    如果 (ctx == 0) { 返回 }
    图处_自动提交检查(ctx, 36)
    NGCC_写命令头(ctx, 图处命令_绘制渐变, 28)
    NGCC_写u32(ctx, x)
    NGCC_写u32(ctx, y)
    NGCC_写u32(ctx, w)
    NGCC_写u32(ctx, h)
    NGCC_写u32(ctx, color0)
    NGCC_写u32(ctx, color1)
    NGCC_写u32(ctx, 方向)  // 0=垂直, 1=水平, 2=对角线
}

函数 图处_设置裁剪(ctx, x, y, w, h) {
    如果 (ctx == 0) { 返回 }
    图处_自动提交检查(ctx, 24)
    NGCC_写命令头(ctx, 图处命令_设置裁剪, 16)
    NGCC_写u32(ctx, x)
    NGCC_写u32(ctx, y)
    NGCC_写u32(ctx, w)
    NGCC_写u32(ctx, h)
}

函数 图处_设置混合(ctx, 模式) {
    如果 (ctx == 0) { 返回 }
    图处_自动提交检查(ctx, 12)
    NGCC_写命令头(ctx, 图处命令_设置混合, 4)
    NGCC_写u32(ctx, 模式)  // 0=不透明, 1=alpha混合, 2=叠加
}

函数 图处_设置透明度(ctx, alpha) {
    如果 (ctx == 0) { 返回 }
    图处_自动提交检查(ctx, 12)
    NGCC_写命令头(ctx, 图处命令_设置透明度, 4)
    NGCC_写u32(ctx, alpha)  // 0-255
}

函数 图处_设置变换(ctx, m00, m01, m10, m11, tx, ty) {
    如果 (ctx == 0) { 返回 }
    图处_自动提交检查(ctx, 32)
    NGCC_写命令头(ctx, 图处命令_设置变换, 24)
    NGCC_写u32(ctx, m00)
    NGCC_写u32(ctx, m01)
    NGCC_写u32(ctx, m10)
    NGCC_写u32(ctx, m11)
    NGCC_写u32(ctx, tx)
    NGCC_写u32(ctx, ty)
}

// §5 纩理管理

结构 NGCC纩理信息 {
    tex_id,
    宽,
    高,
    格式,
    字节数,
    哈希,
    引用计数,
    最后使用帧,
}

定义 可变 NGCC_纩理池 = 0
定义 可变 NGCC_纩理数 = 0

函数 NGCC_纩理池初始化() {
    NGCC_纩理池 = 堆_分配_数组(NGCC_MAX_TEXTURES * 8)
    NGCC_纩理数 = 0
}

函数 NGCC_纩理哈希(宽, 高, 格式) {
    返回 (宽 * 31 + 高) * 17 + 格式
}

函数 图处_创建纩理(ctx, 宽, 高, 格式) {
    如果 (ctx == 0) { 返回 -1 }
    如果 (NGCC_纩理数 >= NGCC_MAX_TEXTURES) { 返回 -2 }
    定义 tex_id = 系统调用(系统调用_图处_创建纩理, ctx.ctx_id, 宽, 高, 格式, 0)
    如果 (tex_id <= 0) { 返回 -3 }
    定义 info = 堆_分配(NGCC纩理信息)
    info.tex_id = tex_id
    info.宽 = 宽
    info.高 = 高
    info.格式 = 格式
    定义 bpp = 4
    如果 (格式 == 纩理格式_RGB8) { bpp = 3 }
    如果 (格式 == 纩理格式_A8) { bpp = 1 }
    如果 (格式 == 纩理格式_RGBA16F) { bpp = 8 }
    info.字节数 = 宽 * 高 * bpp
    info.哈希 = NGCC_纩理哈希(宽, 高, 格式)
    info.引用计数 = 1
    info.最后使用帧 = ctx.帧数
    内存写64(NGCC_纩理池 + NGCC_纩理数 * 8, info)
    NGCC_纩理数 = NGCC_纩理数 + 1
    返回 tex_id
}

函数 图处_上传纩理(ctx, tex_id, data, data_size) {
    如果 (ctx == 0) { 返回 -1 }
    NGCC_纩理上传次数 = NGCC_纩理上传次数 + 1
    返回 系统调用(系统调用_图处_上传纩理, ctx.ctx_id, tex_id, data, data_size, 0)
}

函数 图处_销毁纩理(ctx, tex_id) {
    如果 (ctx == 0) { 返回 }
    系统调用(系统调用_图处_销毁纩理, ctx.ctx_id, tex_id, 0, 0, 0)
    // 从池中移除
    定义 可变 i = 0
    当 (i < NGCC_纩理数) {
        定义 info = 内存读64(NGCC_纩理池 + i * 8)
        如果 (info != 0 && info.tex_id == tex_id) {
            info.引用计数 = info.引用计数 - 1
            如果 (info.引用计数 <= 0) {
                // 移到末尾覆盖
                内存写64(NGCC_纩理池 + i * 8, 内存读64(NGCC_纩理池 + (NGCC_纩理数 - 1) * 8))
                NGCC_纩理数 = NGCC_纩理数 - 1
                堆_释放(info)
            }
            返回
        }
        i = i + 1
    }
}

函数 NGCC_纩理缓存查找(ctx, 宽, 高, 格式) {
    定义 target_hash = NGCC_纩理哈希(宽, 高, 格式)
    定义 可变 i = 0
    当 (i < NGCC_纩理数) {
        定义 info = 内存读64(NGCC_纩理池 + i * 8)
        如果 (info != 0 && info.哈希 == target_hash && info.宽 == 宽 && info.高 == 高 && info.格式 == 格式) {
            info.引用计数 = info.引用计数 + 1
            info.最后使用帧 = ctx.帧数
            NGCC_纩理缓存命中 = NGCC_纩理缓存命中 + 1
            返回 info.tex_id
        }
        i = i + 1
    }
    返回 -1
}

函数 NGCC_纩理LRU淘汰(ctx) {
    如果 (NGCC_纩理数 < NGCC_TEX_CACHE_MAX) { 返回 }
    定义 可变 oldest_i = 0
    定义 可变 oldest_f = ctx.帧数
    定义 可变 i = 0
    当 (i < NGCC_纩理数) {
        定义 info = 内存读64(NGCC_纩理池 + i * 8)
        如果 (info != 0 && info.最后使用帧 < oldest_f) {
            oldest_f = info.最后使用帧
            oldest_i = i
        }
        i = i + 1
    }
    定义 victim = 内存读64(NGCC_纩理池 + oldest_i * 8)
    如果 (victim != 0) {
        图处_销毁纩理(ctx, victim.tex_id)
    }
}

// §6 着色器管理

结构 NGCC着色器信息 {
    shader_id,
    哈希,
    类型,    // 0=顶点, 1=片段
    有效,
}

定义 可变 NGCC_着色器池 = 0
定义 可变 NGCC_着色器数 = 0

函数 NGCC_着色器池初始化() {
    NGCC_着色器池 = 堆_分配_数组(NGCC_MAX_SHADERS * 8)
    NGCC_着色器数 = 0
}

函数 NGCC_着色器哈希(source, len) {
    定义 可变 h = 2166136261
    定义 可变 i = 0
    当 (i < len) {
        h = h ^ (内存读8(source + i) & 0xFF)
        h = h * 16777619
        i = i + 1
    }
    返回 h & 0x7FFFFFFF
}

函数 NGCC_着色器缓存查找(hash) {
    定义 可变 i = 0
    当 (i < NGCC_着色器数) {
        定义 info = 内存读64(NGCC_着色器池 + i * 8)
        如果 (info != 0 && info.哈希 == hash && info.有效) {
            返回 info.shader_id
        }
        i = i + 1
    }
    返回 -1
}

函数 图处_创建着色器(ctx, source, len, 类型) {
    如果 (ctx == 0) { 返回 -1 }
    // 缓存查找
    定义 hash = NGCC_着色器哈希(source, len)
    定义 cached = NGCC_着色器缓存查找(hash)
    如果 (cached >= 0) { 返回 cached }
    // 编译
    NGCC_着色器编译次数 = NGCC_着色器编译次数 + 1
    定义 sid = 系统调用(系统调用_图处_创建着色器, ctx.ctx_id, source, len, 类型, 0)
    如果 (sid <= 0) { 返回 -2 }
    如果 (NGCC_着色器数 < NGCC_MAX_SHADERS) {
        定义 info = 堆_分配(NGCC着色器信息)
        info.shader_id = sid
        info.哈希 = hash
        info.类型 = 类型
        info.有效 = 真
        内存写64(NGCC_着色器池 + NGCC_着色器数 * 8, info)
        NGCC_着色器数 = NGCC_着色器数 + 1
    }
    返回 sid
}

函数 图处_创建程序(ctx, vs_id, fs_id) {
    如果 (ctx == 0) { 返回 -1 }
    返回 系统调用(系统调用_图处_创建程序, ctx.ctx_id, vs_id, fs_id, 0, 0)
}

// §7 帧缓冲管理

结构 NGCC帧缓冲信息 {
    fbo_id,
    宽,
    高,
    颜色纩理,
    深度纩理,
}

定义 可变 NGCC_帧缓冲池 = 0
定义 可变 NGCC_帧缓冲数 = 0

函数 NGCC_帧缓冲初始化() {
    NGCC_帧缓冲池 = 堆_分配_数组(NGCC_MAX_FRAMEBUFFERS * 8)
    NGCC_帧缓冲数 = 0
}

函数 图处_创建帧缓冲(ctx, 宽, 高) {
    如果 (ctx == 0) { 返回 -1 }
    如果 (NGCC_帧缓冲数 >= NGCC_MAX_FRAMEBUFFERS) { 返回 -2 }
    定义 fbo_id = 系统调用(系统调用_图处_创建帧缓冲, ctx.ctx_id, 宽, 高, 0, 0)
    如果 (fbo_id <= 0) { 返回 -3 }
    // 创建颜色附件纩理
    定义 color_tex = 图处_创建纩理(ctx, 宽, 高, 纩理格式_RGBA8)
    // 创建深度模板附件
    定义 depth_tex = 图处_创建纩理(ctx, 宽, 高, 纩理格式_深度24模板8)
    定义 info = 堆_分配(NGCC帧缓冲信息)
    info.fbo_id = fbo_id
    info.宽 = 宽
    info.高 = 高
    info.颜色纩理 = color_tex
    info.深度纩理 = depth_tex
    内存写64(NGCC_帧缓冲池 + NGCC_帧缓冲数 * 8, info)
    NGCC_帧缓冲数 = NGCC_帧缓冲数 + 1
    返回 fbo_id
}

函数 图处_绑定帧缓冲(ctx, fbo_id) {
    如果 (ctx == 0) { 返回 -1 }
    ctx.帧缓冲 = fbo_id
    返回 系统调用(系统调用_图处_绑定帧缓冲, ctx.ctx_id, fbo_id, 0, 0, 0)
}

// §8 图处状态查询

函数 图处_查询繁忙度(ctx) {
    如果 (ctx == 0) { 返回 0 }
    定义 status = 系统调用(系统调用_图处_查询状态, ctx.ctx_id, 0, 0, 0, 0)
    ctx.图处繁忙度 = status & 0x3FF  // 0-1000
    返回 ctx.图处繁忙度
}

函数 图处_设置视口(ctx, 宽, 高) {
    如果 (ctx == 0) { 返回 }
    ctx.视口宽 = 宽
    ctx.视口高 = 高
}

// §9 AI图处负载预测 (NGCC-AI)

定义 NGCC_QUALITY_HIGH   = 0
定义 NGCC_QUALITY_MEDIUM = 1
定义 NGCC_QUALITY_LOW    = 2
定义 可变 NGCC_当前质量  = 0

函数 NGCC_AI_负载预测(ctx) {
    如果 (全局AI总线 == 0 || ctx == 0) { 返回 }
    NGCC_AI预测次数 = NGCC_AI预测次数 + 1
    定义 tensor = Tensor_创建(6)
    Tensor_写(tensor, 0, ctx.图处繁忙度 / 1000.0)
    Tensor_写(tensor, 1, NGCC_命令总数 / 10000.0)
    Tensor_写(tensor, 2, NGCC_纩理数 / NGCC_MAX_TEXTURES)
    Tensor_写(tensor, 3, ctx.写位置 / ctx.缓冲大小)
    Tensor_写(tensor, 4, NGCC_帧缓冲数 / NGCC_MAX_FRAMEBUFFERS)
    Tensor_写(tensor, 5, ctx.帧数 / 3600.0)  // 帧历史
    定义 out = AI总线_推理(全局AI总线, "NGCC_负载预测", tensor, 6)
    如果 (out != 0) {
        定义 load_score = Tensor_读(out, 0)   // 0..1
        定义 degrade    = Tensor_读(out, 1)   // 0..1
        如果 (load_score > 0.85) {
            NGCC_当前质量 = NGCC_QUALITY_LOW
            NGCC_降级次数 = NGCC_降级次数 + 1
        } 否则 如果 (load_score > 0.55) {
            NGCC_当前质量 = NGCC_QUALITY_MEDIUM
        } 否则 {
            NGCC_当前质量 = NGCC_QUALITY_HIGH
        }
        Tensor_释放(out)
    }
    Tensor_释放(tensor)
}

函数 NGCC_AI_纩理预加载提示(ctx) {
    如果 (全局AI总线 == 0 || ctx == 0) { 返回 }
    定义 tensor = Tensor_创建(4)
    Tensor_写(tensor, 0, NGCC_纩理数 / 64.0)
    Tensor_写(tensor, 1, NGCC_纩理上传次数 / 100.0)
    Tensor_写(tensor, 2, NGCC_纩理缓存命中 / 如果(NGCC_纩理上传次数 > 0, NGCC_纩理上传次数, 1))
    Tensor_写(tensor, 3, ctx.帧数 / 1800.0)
    定义 out = AI总线_推理(全局AI总线, "NGCC_纩理预载", tensor, 4)
    如果 (out != 0) {
        // AI提示下一帧可能需要的纩理尺寸
        Tensor_释放(out)
    }
    Tensor_释放(tensor)
}

// §10 统计与诊断

函数 NGCC_性能统计(ctx) {
    定义 texCacheRate = 0
    定义 total = NGCC_纩理缓存命中 + NGCC_纩理上传次数
    如果 (total > 0) { texCacheRate = NGCC_纩理缓存命中 * 100 / total }
    打印("[NGCC] frames=" + ctx.帧数 +
         " submits=" + NGCC_提交次数 +
         " cmds=" + NGCC_命令总数 +
         " texUploads=" + NGCC_纩理上传次数 +
         " texCacheHit=" + texCacheRate + "%" +
         " shaderCompiles=" + NGCC_着色器编译次数 +
         " aiPredict=" + NGCC_AI预测次数 +
         " degrades=" + NGCC_降级次数 +
         " quality=" + NGCC_当前质量 +
         " busy=" + ctx.图处繁忙度)
}

函数 NGCC_纩理池列表() {
    打印("[NGCC] 纩理池 count=" + NGCC_纩理数)
    定义 可变 i = 0
    当 (i < NGCC_纩理数 && i < 16) {
        定义 info = 内存读64(NGCC_纩理池 + i * 8)
        如果 (info != 0) {
            打印("  tex[" + info.tex_id + "] " + info.宽 + "x" + info.高 +
                 " fmt=" + info.格式 + " refs=" + info.引用计数)
        }
        i = i + 1
    }
}

// §11 统一入口

函数 NGCC_图处系统启动(宽, 高) {
    NGCC_纩理池初始化()
    NGCC_着色器池初始化()
    NGCC_帧缓冲初始化()
    定义 ctx = 图处_创建上下文(宽, 高)
    如果 (ctx == 0) { 打印("[NGCC] 图处上下文创建失败"); 返回 0 }
    打印("[NGCC] GPU Command Context 启动 " + 宽 + "x" + 高)
    返回 ctx
}

函数 NGCC_图处系统关闭(ctx) {
    如果 (ctx == 0) { 返回 }
    NGCC_性能统计(ctx)
    NGCC_纩理池列表()
    图处_销毁上下文(ctx)
    打印("[NGCC] 图处系统已关闭")
}

函数 NGCC_帧更新(ctx, delta_ms) {
    如果 (ctx == 0) { 返回 }
    // 每60帧AI预测一次
    如果 ((ctx.帧数 % 60) == 0) {
        图处_查询繁忙度(ctx)
        NGCC_AI_负载预测(ctx)
    }
    // 每300帧纩理预加载提示
    如果 ((ctx.帧数 % 300) == 0) {
        NGCC_AI_纩理预加载提示(ctx)
    }
    // 每600帧LRU淘汰
    如果 ((ctx.帧数 % 600) == 0) {
        NGCC_纩理LRU淘汰(ctx)
    }
}
导入("../推理/通信总线.nova")
导入("../推理/值乘.nova")
导入("../引导/端口输入.nova")
导入("./平台时间.nova")


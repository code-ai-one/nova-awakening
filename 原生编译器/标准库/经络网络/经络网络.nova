导入("../基础.nova")
导入("../数学/基础/数学库.nova")


定义 可变 经络 = []

函数 经络_初始化() {
 经络 = []
 定义 可变 i = 0
 当 (i < 12) { 定义 可变 阴阳 = 0
 如果 (i >= 3 且 i <= 5) { 阴阳 = 1 }
 如果 (i >= 9) { 阴阳 = 1 }
 追加(经络, [i, i + 1000, 0, 50 + i * 5, -1, 阴阳])
 i = i + 1
 }
 // 设置表里配对
 经络[0][4] = 3
 经络[3][4] = 0
 经络[1][4] = 4
 经络[4][4] = 1
 经络[2][4] = 5
 经络[5][4] = 2
 经络[6][4] = 9
 经络[9][4] = 6
 经络[7][4] = 10
 经络[10][4] = 7
 经络[8][4] = 11
 经络[11][4] = 8
}

函数 经络_激活(id, 信号) {
 // LTC更新: 导数/dt = (-x + 信号) / tau
 定义 tau = 经络[id][3]
 定义 导数 = (信号 - 经络[id][2]) * 100 / tau
 经络[id][2] = 经络[id][2] + 导数 / 10
 如果 (经络[id][2] > 100) { 经络[id][2] = 100 }
 如果 (经络[id][2] < 0) { 经络[id][2] = 0 }
}

函数 经络_读取(id) { 返回 经络[id][2] }

// 表里传导
函数 经络_表里传导(id) { 定义 配对 = 经络[id][4]
 如果 (配对 >= 0) { 定义 传导 = 经络[id][2] * 30 / 100
 经络_激活(配对, 经络[配对][2] + 传导)
 }
}

函数 阴阳_平衡度() { 定义 可变 阴总 = 0
    定义 可变 阳数 = 0
    定义 可变 阴数 = 0
 定义 可变 阳总 = 0
 定义 可变 i = 0
 当 (i < 计数(经络)) { 如果 (经络[i][5] == 0) { 阴总 = 阴总 + 经络[i][2]
 阴数 = 阴数 + 1 }
 否则 { 阳总 = 阳总 + 经络[i][2]
 阳数 = 阳数 + 1 }
 i = i + 1
 }
 如果 (阴数 == 0) { 阴数 = 1 }
 如果 (阳数 == 0) { 阳数 = 1 }
 定义 阴均 = 阴总 / 阴数
 定义 阳均 = 阳总 / 阳数
 返回 100 - 绝对值(阴均 - 阳均)
}

函数 气血循环() { 定义 可变 i = 0
 当 (i < 12) { 定义 下一 = (i + 1) % 12
 定义 传导 = 经络[i][2] * 20 / 100
 经络_激活(下一, 经络[下一][2] + 传导)
 i = i + 1
 }
}

函数 经络_总激活() { 返回 折叠(经络, 0, (s, x) => s + x[2])
}

函数 经络_活跃数() { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(经络)) { 如果 (经络[i][2] > 0) { c = c + 1 }
 i = i + 1
 }
 返回 c
}

定义 可变 穴位列表 = []

函数 穴位_注册(经络id, 位置, 功能哈希) {
 追加(穴位列表, [经络id, 位置, 0, 功能哈希])
 返回 计数(穴位列表) - 1
}

函数 穴位_刺激(索引, 强度) {
 穴位列表[索引][2] = 穴位列表[索引][2] + 强度
 如果 (穴位列表[索引][2] > 100) { 穴位列表[索引][2] = 100 }
 经络_激活(穴位列表[索引][0], 穴位列表[索引][2])
}

函数 穴位_数量() { 返回 计数(穴位列表) }

函数 经络_最强() { 定义 可变 最优 = 0
 定义 可变 i = 1
 当 (i < 计数(经络)) { 如果 (经络[i][2] > 经络[最优][2]) { 最优 = i }
 i = i + 1
 }
 返回 最优
}

函数 经络_最弱() { 定义 可变 weakest = 0
 定义 可变 i = 1
 当 (i < 计数(经络)) { 如果 (经络[i][2] < 经络[weakest][2]) { weakest = i }
 i = i + 1
 }
 返回 weakest
}

函数 经络_报告() {
 打印("╔═══ 经络状态 ═══╗")
 打印("║ 总激活: " + 转字符串(经络_总激活()) + " 活跃: " + 转字符串(经络_活跃数()) + "/12")
 打印("║ 阴阳平衡: " + 转字符串(阴阳_平衡度()) + "%")
 定义 可变 i = 0
 当 (i < 计数(经络)) { 定义 m = 经络[i]
 定义 可变 类型 = "阴"
 如果 (m[5] == 1) { 类型 = "阳" }
 打印("║ [" + 转字符串(m[0]) + "] " + 类型 + " 激活=" + 转字符串(m[2]) + " τ=" + 转字符串(m[3]) + " 配对=" + 转字符串(m[4]))
 i = i + 1
 }
 打印("║ 最强: " + 转字符串(经络_最强()) + " 最弱: " + 转字符串(经络_最弱()))
 打印("╚════════════════╝")
}

// 多轮气血循环
函数 多轮循环(轮数) { 定义 可变 i = 0
 当 (i < 轮数) {
 气血循环()
 i = i + 1
 }
}

函数 经络_重置() { 定义 可变 i = 0
 当 (i < 计数(经络)) { 经络[i][2] = 0
 i = i + 1 }
}

函数 AI经络_创建(通道数) {
 经络 = []
 定义 可变 i = 0
 当 (i < 通道数) {
 追加(经络, [i, i + 2000, 0, 30 + i * 10, (i + 通道数 / 2) % 通道数, i % 2])
 i = i + 1
 }
}

// 经络脉冲传播
函数 经络_脉冲传播(源穴位, 强度, 衰减率) { 定义 可变 队列 = [[源穴位, 强度]]
    定义 可变 新队列 = []
    定义 可变 总激活 = 0
 定义 可变 已访问 = []
 当 (计数(队列) > 0) { 定义 当前 = 队列[0]
 定义 可变 i = 1
 当 (i < 计数(队列)) { 追加(新队列, 队列[i]) i = i + 1 }
 队列 = 新队列
 定义 穴位 = 当前[0]
 定义 能量 = 当前[1]
 如果 (能量 < 5) { 继续 }
 定义 可变 已到 = 假
 i = 0
 当 (i < 计数(已访问)) { 如果 (已访问[i] == 穴位) { 已到 = 真 } i = i + 1 }
 如果 (已到) { 继续 }
 追加(已访问, 穴位)
 总激活 = 总激活 + 能量
 // 向下游传播
 i = 0
 当 (i < 计数(经络)) { 如果 (经络[i][0] == 穴位) { 定义 下游 = 经络[i][4]
 定义 新能量 = 能量 * 衰减率 / 100
 追加(队列, [下游, 新能量])
 }
 i = i + 1
 }
 }
 返回 总激活
}

// 穴位状态管理
定义 可变 穴位_状态 = []

函数 穴位_初始化(数量) {
 穴位_状态 = []
 定义 可变 i = 0
 当 (i < 数量) { 追加(穴位_状态, [0, 100, 0]) i = i + 1 }
}

函数 穴位_激活(id, 强度) { 如果 (id >= 0 且 id < 计数(穴位_状态)) {
 穴位_状态[id][0] = 穴位_状态[id][0] + 强度
 穴位_状态[id][2] = 穴位_状态[id][2] + 1
 }
}

函数 穴位_能量(id) {
    如果 (id >= 0 且 id < 计数(穴位_状态)) { 返回 穴位_状态[id][0]
}
 返回 0
}

函数 穴位_衰减全部(衰减率) { 定义 可变 i = 0
 当 (i < 计数(穴位_状态)) {
 穴位_状态[i][0] = 穴位_状态[i][0] * 衰减率 / 100
 i = i + 1
 }
}

// 气血流动模拟
函数 气血_流动步(经络列表, 穴位列表, 流速) { 定义 可变 i = 0
 当 (i < 计数(经络列表)) { 定义 源 = 经络列表[i][0]
 定义 目标 = 经络列表[i][4]
 定义 流量 = 穴位列表[源][0] * 流速 / 100
 穴位列表[源][0] = 穴位列表[源][0] - 流量
 穴位列表[目标][0] = 穴位列表[目标][0] + 流量
 i = i + 1
 }
}

函数 气血_总能量(穴位列表) { 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 计数(穴位列表)) { 总 = 总 + 穴位列表[i][0] i = i + 1 }
 返回 总
}

函数 气血_平衡度(穴位列表) { 定义 n = 计数(穴位列表)
 如果 (n < 2) { 返回 1000 }
 定义 可变 均值 = 气血_总能量(穴位列表) / n
 定义 可变 方差 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 d = 穴位列表[i][0] - 均值
 方差 = 方差 + d * d
 i = i + 1
 }
 返回 1000 - 方差 / n
}

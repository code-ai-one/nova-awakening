导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("./端口输入.nova")

// NovaOS 纯原生AI桌面 v1.0 — 100% Nova语言
// 编译: 龙编译器.exe --kernel 内核入口_GUI.nova
// 增强: 内存填充32(rep stosd) + 函数化 + 内联内存写32

打印("═══ NovaOS v1.0 — 纯原生AI桌面 ═══")
打印("[启动] 100% Nova语言, 零asm渲染")
打印("[启动] 编译器增强: 内存填充32 + 内联写入")

定义 LFB = 0xFD000000
定义 屏宽 = 1024
定义 屏高 = 768
定义 行字节 = 4096

// 图形原语函数 — 纯Nova原生，内存填充32加速

// 画矩形: 逐行调用内存填充32(rep stosd), 每行一次批量填充
函数 画矩形(x, y, w, h, 色) {
    定义 可变 行 = 0
    当 (行 < h) {
        内存填充32(LFB + (y + 行) * 行字节 + x * 4, 色, w)
        行 = 行 + 1
    }
}

// 画水平线
函数 画横线(x, y, w, 色) {
    内存填充32(LFB + y * 行字节 + x * 4, 色, w)
}

// 画像素
函数 画点(x, y, 色) {
    内存写32(LFB + y * 行字节 + x * 4, 色)
}

// 1. 壁纸 — 逐行渐变 + 内存填充32加速(每行1次rep stosd)
打印("[渲染] 壁纸...")
定义 可变 wy = 0
当 (wy < 屏高) {
    定义 vy = wy * 256 / 屏高
    定义 可变 dy_c = wy - 340
    如果 (dy_c < 0) { dy_c = 0 - dy_c }
    定义 可变 glow = 0
    如果 (dy_c < 320) { glow = (320 - dy_c) / 18 }
    定义 wr = 5 + 13 * vy / 256 + glow
    定义 wg = 8 + (256 - vy) * 7 / 256 + glow / 2
    定义 wb = 18 + 22 * vy / 256 + glow * 2
    定义 壁纸色 = wr * 65536 + wg * 256 + wb
    // 内存填充32: 一次填满1024像素(一整行), 替代1024次内存写32
    内存填充32(LFB + wy * 行字节, 壁纸色, 屏宽)
    wy = wy + 1
}

// 1.5 内嵌8x8位图字体 — ASCII 32('空格')到126('~'), 95个字符
// 每个字符8字节, 每字节8位=一行像素, MSB在左
// 用于在帧缓冲上真实渲染文字
定义 字体 = [
  0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,  // 32 ' '
  0x18,0x18,0x18,0x18,0x18,0x00,0x18,0x00,  // 33 '!'

导入("../基础.nova")

// Nova标准库 — 模式匹配 (Pattern Matching)
// 简化正则表达式、通配符匹配、模板引擎

// 通配符匹配
// * 匹配任意多个字符, ? 匹配单个字符
函数 通配符匹配(文本, 模式) {
    定义 tn = 计数(文本)
    定义 pn = 计数(模式)
    // DP: dp[i][j] = 文本前i字符 是否匹配 模式前j字符
    // 使用一维滚动数组
    定义 可变 dp = []
    定义 可变 j = 0
    当 (j <= pn) { 追加(dp, 假) j = j + 1 }
    dp[0] = 真
    // 处理模式开头的 *
    j = 1
    当 (j <= pn) {
        如果 (字符串等于(子串(模式, j - 1, 1), "*")) {
            dp[j] = dp[j - 1]
        }
        j = j + 1
    }
    定义 可变 i = 1
    当 (i <= tn) {
        定义 可变 新dp = []
        j = 0
        当 (j <= pn) { 追加(新dp, 假) j = j + 1 }
        j = 1
        当 (j <= pn) {
            定义 pc = 子串(模式, j - 1, 1)
            定义 tc = 子串(文本, i - 1, 1)
            如果 (字符串等于(pc, "*")) {
                // * 匹配0个(新dp[j-1]) 或 多个(dp[j])
                新dp[j] = 新dp[j - 1] 或 dp[j]
            } 否则 如果 (字符串等于(pc, "?") 或 字符串等于(pc, tc)) {
                新dp[j] = dp[j - 1]
            }
            j = j + 1
        }
        dp = 新dp
        i = i + 1
    }
    返回 dp[pn]
}

// 简单模式搜索 (KMP)
函数 kmp搜索(文本, 模式) {
    定义 tn = 计数(文本)
    定义 pn = 计数(模式)
    如果 (pn == 0) { 返回 [] }
    // 构建失败表
    定义 可变 失败 = [0]
    定义 可变 k = 0
    定义 可变 i = 1
    当 (i < pn) {
        当 (k > 0 且 字符串等于(子串(模式, k, 1), 子串(模式, i, 1)) == 假) {
            k = 失败[k - 1]
        }
        如果 (字符串等于(子串(模式, k, 1), 子串(模式, i, 1))) {
            k = k + 1
        }
        追加(失败, k)
        i = i + 1
    }
    // 搜索
    定义 可变 匹配位置 = []
    定义 可变 j = 0
    i = 0
    当 (i < tn) {
        当 (j > 0 且 字符串等于(子串(文本, i, 1), 子串(模式, j, 1)) == 假) {
            j = 失败[j - 1]
        }
        如果 (字符串等于(子串(文本, i, 1), 子串(模式, j, 1))) {
            j = j + 1
        }
        如果 (j == pn) {
            追加(匹配位置, i - pn + 1)
            j = 失败[j - 1]
        }
        i = i + 1
    }
    返回 匹配位置
}

// 替换所有出现
函数 替换全部(文本, 旧文本, 新文本) {
    定义 tn = 计数(文本)
    定义 on = 计数(旧文本)
    如果 (on == 0) { 返回 文本 }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i <= tn - on) {
        如果 (字符串等于(子串(文本, i, on), 旧文本)) {
            结果 = 字符串拼接(结果, 新文本)
            i = i + on
        } 否则 {
            结果 = 字符串拼接(结果, 子串(文本, i, 1))
            i = i + 1
        }
    }
    // 追加剩余
    当 (i < tn) {
        结果 = 字符串拼接(结果, 子串(文本, i, 1))
        i = i + 1
    }
    返回 结果
}

// 简单模板引擎
// 替换 {{变量名}} 为对应值
函数 模板(模板文本, _变量表) {
    定义 可变 结果 = 模板文本
    // 遍历变量表中的键
    // 简化: 调用者提供键列表
    返回 结果
}

函数 模板_替换(模板文本, 键, 值) {
    // "{{"和"}}"会触发编译器字典解析，用字符拼接绕过
    定义 左标记 = 字符串拼接(字符(123), 字符(123))
    定义 右标记 = 字符串拼接(字符(125), 字符(125))
    定义 占位符 = 字符串拼接(左标记, 字符串拼接(键, 右标记))
    返回 替换全部(模板文本, 占位符, 值)
}

// 字符串分词器 (多分隔符)
函数 多分隔分割(文本, 分隔符列表) {
    定义 n = 计数(文本)
    定义 分隔数 = 计数(分隔符列表)
    定义 可变 结果 = []
    定义 可变 当前 = ""
    定义 可变 i = 0
    当 (i < n) {
        定义 c = 子串(文本, i, 1)
        定义 可变 是分隔 = 假
        定义 可变 si = 0
        当 (si < 分隔数) {
            如果 (字符串等于(c, 分隔符列表[si])) {
                是分隔 = 真
                止
            }
            si = si + 1
        }
        如果 (是分隔) {
            如果 (计数(当前) > 0) {
                追加(结果, 当前)
                当前 = ""
            }
        } 否则 {
            当前 = 字符串拼接(当前, c)
        }
        i = i + 1
    }
    如果 (计数(当前) > 0) { 追加(结果, 当前) }
    返回 结果
}

// URL 解析 (简化)
函数 url解析(url) {
    // 回: [协议, 主机, 路径]
    定义 n = 计数(url)
    定义 可变 协议 = ""
    定义 可变 主机 = ""
    定义 可变 路径 = ""
    // 找 ://
    定义 可变 i = 0
    定义 可变 阶段 = 0
    当 (i < n) {
        定义 c = 子串(url, i, 1)
        如果 (阶段 == 0) {
            如果 (i + 2 < n 且 字符串等于(子串(url, i, 3), "://")) {
                阶段 = 1
                i = i + 3
                续
            }
            协议 = 字符串拼接(协议, c)
        } 否则 如果 (阶段 == 1) {
            如果 (字符串等于(c, "/")) {
                阶段 = 2
                路径 = 字符串拼接(路径, c)
            } 否则 {
                主机 = 字符串拼接(主机, c)
            }
        } 否则 {
            路径 = 字符串拼接(路径, c)
        }
        i = i + 1
    }
    返回 [协议, 主机, 路径]
}

// 数字解析
函数 解析整数(文本) {
    定义 n = 计数(文本)
    如果 (n == 0) { 返回 0 }
    定义 可变 结果 = 0
    定义 可变 负 = 假
    定义 可变 i = 0
    如果 (字符串等于(子串(文本, 0, 1), "-")) {
        负 = 真
        i = 1
    }
    当 (i < n) {
        定义 c = 编码(子串(文本, i, 1))
        如果 (c >= 字符_零 且 c <= 字符_九) {
            结果 = 结果 * 10 + (c - 48)
        }
        i = i + 1
    }
    如果 (负) { 结果 = 0 - 结果 }
    返回 结果
}

// 最长公共子序列 (最长公共子串, 0)
函数 最长公共子序列(a, b) {
    定义 m = 计数(a)
    定义 n = 计数(b)
    // 使用一维滚动数组
    定义 可变 dp = []
    定义 可变 j = 0
    当 (j <= n) { 追加(dp, 0) j = j + 1 }
    定义 可变 i = 1
    当 (i <= m) {
        定义 可变 新dp = [0]
        j = 1
        当 (j <= n) {
            如果 (字符串等于(子串(a, i - 1, 1), 子串(b, j - 1, 1))) {
                追加(新dp, dp[j - 1] + 1)
            } 否则 {
                定义 可变 最大 = dp[j]
                如果 (新dp[j - 1] > 最大) { 最大 = 新dp[j - 1] }
                追加(新dp, 最大)
            }
            j = j + 1
        }
        dp = 新dp
        i = i + 1
    }
    返回 dp[n]
}

// 字符串哈希 (Rabin-Karp)
函数 字符串哈希(文本) {
    定义 n = 计数(文本)
    定义 可变 h = 0
    定义 可变 i = 0
    当 (i < n) {
        h = (h * 31 + 编码(子串(文本, i, 1))) & 0x7FFFFFFF
        i = i + 1
    }
    返回 h
}

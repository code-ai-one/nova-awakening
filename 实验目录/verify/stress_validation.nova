    返回 通过
 }

 函数 压力验证_运行全部() {
     定义 可变 通过 = 真
    如果 (!压力验证_多档参数扫描()) { 通过 = 假 }
    如果 (!压力验证_双参数交叉扫描()) { 通过 = 假 }
    如果 (!压力验证_多档抗干扰()) { 通过 = 假 }
    如果 (!压力验证_双扰动联动抗干扰()) { 通过 = 假 }
    如果 (!压力验证_领先门槛()) { 通过 = 假 }
    如果 (!压力验证_样本规模()) { 通过 = 假 }
    如果 (!压力验证_重复实验稳定()) { 通过 = 假 }
    如果 (!通过) {
        压力验证_打印(警告_致命, "压力验证链失败")
        返回 1
    }
    压力验证_打印(警告_信息, "压力验证链通过")
    返回 0
}

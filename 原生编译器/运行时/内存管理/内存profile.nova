// Nova · 运行时 · M9 内存Profile度量系统
// 三类profile: no_gc_kernel / bounded_ai_runtime / developer_host
// 自动度量: 分配峰值/当前使用/GC压力/OOM风险/预算达标率

// Profile类型

导入("../../标准库/基础.nova")

定义 内存配置_内核    = 1   // 裸机内核: 无GC, bump+page+slab
定义 内存配置_AI        = 2   // AI运行时: 有界GC, 张量池+推理缓冲
定义 内存配置_开发       = 3   // 开发宿主: 完整GC, 无硬约束

// 度量记录
// [profile类型, 预算字节, 当前使用, 峰值使用, 分配次数, 释放次数,
//  GC触发数, OOM次数, 采样时间戳列表, 采样使用量列表]
函数 内存度量_创建(profile, 预算) {
    返回 [profile, 预算, 0, 0, 0, [], []]
}

函数 内存度量_记录分配(度量, 字节数) {
    度量[2] = 度量[2] + 字节数
    度量[4] = 度量[4] + 1
    如果 (度量[2] > 度量[3]) { 度量[3] = 度量[2] }
}

函数 内存度量_记录释放(度量, 字节数) {
    度量[2] = 度量[2] - 字节数
    如果 (度量[2] < 0) { 度量[2] = 0 }
    度量[5] = 度量[5] + 1
}

函数 内存度量_记录GC(度量) { 度量[6] = 度量[6] + 1 }
函数 内存度量_记录OOM(度量) { 度量[7] = 度量[7] + 1 }

函数 内存度量_采样(度量, 时间戳) {
    追加(度量[8], 时间戳)
    追加(度量[9], 度量[2])
}

// Profile预算配置

函数 内存profile_kernel() {
    // 裸机内核: 4MB硬上限, 无GC, 超限即panic
    返回 内存度量_创建(内存配置_内核, 4 * 1024 * 1024)
}

函数 内存profile_ai(显存MB, 主存MB) {
    // AI运行时: 有界, 张量+推理缓冲预算
    返回 内存度量_创建(内存配置_AI, 主存MB * 1024 * 1024)
}

函数 内存profile_developer() {
    // 开发宿主: 256MB软上限, GC自由
    返回 内存度量_创建(内存配置_开发, 256 * 1024 * 1024)
}

// 预算检查

函数 内存度量_超预算(度量) {
    返回 度量[2] > 度量[1]
}

函数 内存度量_使用率(度量) {
    如果 (度量[1] == 0) { 返回 0 }
    返回 度量[2] * 100 / 度量[1]
}

函数 内存度量_峰值使用率(度量) {
    如果 (度量[1] == 0) { 返回 0 }
    返回 度量[3] * 100 / 度量[1]
}

// GC压力: GC次数/分配次数 (×1000)
函数 内存度量_GC压力(度量) {
    如果 (度量[4] == 0) { 返回 0 }
    返回 度量[6] * 1000 / 度量[4]
}

// 门控: 严格profile下超预算阻塞构建
函数 内存度量_门控检查(度量) {
    如果 (度量[0] == 内存配置_内核) {
        // 内核profile: 峰值超预算即失败
        如果 (度量[3] > 度量[1]) { 返回 假 }
        // 内核不允许OOM
        如果 (度量[7] > 0) { 返回 假 }
        返回 真
    }
    如果 (度量[0] == 内存配置_AI) {
        // AI profile: 峰值超预算120%即失败
        如果 (度量[3] > 度量[1] * 120 / 100) { 返回 假 }
        返回 真
    }
    // 开发profile: 不阻塞
    返回 真
}

// 报告生成
函数 内存度量_报告(度量) {
    定义 可变 r = 字典()
    如果 (度量[0] == 内存配置_内核) { 字典设(r, "profile", "no_gc_kernel") }
    否则 如果 (度量[0] == 内存配置_AI) { 字典设(r, "profile", "bounded_ai_runtime") }
    否则 { 字典设(r, "profile", "developer_host") }
    字典设(r, "预算", 转字符串(度量[1]))
    字典设(r, "当前使用", 转字符串(度量[2]))
    字典设(r, "峰值", 转字符串(度量[3]))
    字典设(r, "分配次数", 转字符串(度量[4]))
    字典设(r, "释放次数", 转字符串(度量[5]))
    字典设(r, "GC触发", 转字符串(度量[6]))
    字典设(r, "OOM", 转字符串(度量[7]))
    字典设(r, "使用率%", 转字符串(内存度量_使用率(度量)))
    字典设(r, "峰值率%", 转字符串(内存度量_峰值使用率(度量)))
    字典设(r, "GC压力‰", 转字符串(内存度量_GC压力(度量)))
    字典设(r, "门控通过", 转字符串(内存度量_门控检查(度量)))
    字典设(r, "采样数", 转字符串(计数(度量[8])))
    返回 r
}

// 全局当前profile
定义 可变 _当前内存度量 = 空

函数 内存profile_初始化(profile名) {
    如果 (profile名 == "no_gc_kernel" 或 profile名 == "kernel") {
        _当前内存度量 = 内存profile_kernel()
    }
    否则 如果 (profile名 == "bounded_ai" 或 profile名 == "ai") {
        _当前内存度量 = 内存profile_ai(0, 64)
    }
    否则 {
        _当前内存度量 = 内存profile_developer()
    }
}

函数 内存profile_当前() { 返回 _当前内存度量 }
函数 内存profile_内存profile_报告() {
    如果 (_当前内存度量 == 空) { 返回 字典() }
    返回 内存度量_报告(_当前内存度量)
}

// 实测基准: 二进制大小/冷启动/峰值RSS/碎片率
// 基准记录: [二进制字节, 冷启动us, 峰值RSS, 稳态RSS, 临时分配量, 命中率‰, 碎片率‰]
定义 可变 _内存基准 = 空

函数 内存profile_内存基准_记录(二进制字节, 冷启动us, 峰值RSS, 稳态RSS, 临时分配量, 命中率, 碎片率) {
    _内存基准 = [二进制字节, 冷启动us, 峰值RSS, 稳态RSS, 临时分配量, 命中率, 碎片率]
}

函数 内存profile_内存基准_报告() {
    如果 (_内存基准 == 空) { 返回 字典() }
    定义 r = 字典()
    字典设(r, "二进制字节", 转字符串(_内存基准[0]))
    字典设(r, "冷启动us", 转字符串(_内存基准[1]))
    字典设(r, "峰值RSS", 转字符串(_内存基准[2]))
    字典设(r, "稳态RSS", 转字符串(_内存基准[3]))
    字典设(r, "临时分配量", 转字符串(_内存基准[4]))
    字典设(r, "命中率‰", 转字符串(_内存基准[5]))
    字典设(r, "碎片率‰", 转字符串(_内存基准[6]))
    返回 r
}

函数 内存基准_达标(阈值RSS, 阈值碎片率) {
    如果 (_内存基准 == 空) { 返回 假 }
    返回 _内存基准[2] <= 阈值RSS 且 _内存基准[6] <= 阈值碎片率
}

// 内存增长追踪
// 每N次分配采样一次，检测泄漏趋势
定义 可变 _增长追踪 = []
定义 可变 _增长采样间隔 = 100

函数 内存增长_配置(间隔) { _增长采样间隔 = 间隔 }

函数 内存增长_记录(度量) {
    如果 (度量[4] % _增长采样间隔 == 0 且 度量[4] > 0) {
        追加(_增长追踪, [度量[4], 度量[2], 度量[3]])
    }
}

函数 内存增长_趋势() {
    如果 (计数(_增长追踪) < 3) { 返回 "样本不足" }
    // 比较最近3次采样的当前使用量是否单调递增
    定义 n = 计数(_增长追踪)
    定义 a = _增长追踪[n - 3][1]
    定义 b = _增长追踪[n - 2][1]
    定义 c = _增长追踪[n - 1][1]
    如果 (c > b 且 b > a) { 返回 "疑似泄漏" }
    如果 (c < a) { 返回 "收敛" }
    返回 "稳定"
}

函数 内存增长_报告() {
    定义 r = 字典()
    字典设(r, "采样点数", 转字符串(计数(_增长追踪)))
    字典设(r, "趋势", 内存增长_趋势())
    如果 (计数(_增长追踪) > 0) {
        定义 last = _增长追踪[计数(_增长追踪) - 1]
        字典设(r, "最新使用", 转字符串(last[1]))
        字典设(r, "最新峰值", 转字符串(last[2]))
    }
    返回 r
}

函数 内存增长_重置() { _增长追踪 = [] }

// §8验收矩阵: 内存配置_报告 (含benchmark对照)
函数 内存配置_报告(_扩1) {
    定义 r = 字典()
    // 三类profile基准数据
    定义 kern = 内存profile_kernel()
    定义 ai = 内存profile_ai(0, 64)
    定义 dev = 内存profile_developer()
    字典设(r, "kernel_预算MB", 转字符串(kern[1] / 1048576))
    字典设(r, "kernel_门控", 转字符串(内存度量_门控检查(kern)))
    字典设(r, "ai_预算MB", 转字符串(ai[1] / 1048576))
    字典设(r, "ai_门控", 转字符串(内存度量_门控检查(ai)))
    字典设(r, "developer_预算MB", 转字符串(dev[1] / 1048576))
    字典设(r, "developer_门控", 转字符串(内存度量_门控检查(dev)))
    // benchmark对照: 模拟分配测量
    内存度量_记录分配(kern, 2097152) // 2MB
    内存度量_记录分配(kern, 1048576) // 1MB
    内存度量_记录释放(kern, 524288)  // 释放0.5MB
    内存度量_记录GC(kern)
    字典设(r, "benchmark_kernel_峰值", 转字符串(kern[3]))
    字典设(r, "benchmark_kernel_当前", 转字符串(kern[2]))
    字典设(r, "benchmark_kernel_GC次数", 转字符串(kern[6]))
    字典设(r, "benchmark_kernel_门控后", 转字符串(内存度量_门控检查(kern)))
    // AI profile: 模拟超120%场景
    内存度量_记录分配(ai, ai[1]) // 分配满预算
    字典设(r, "benchmark_ai_满载门控", 转字符串(内存度量_门控检查(ai)))
    内存度量_记录分配(ai, ai[1] / 4) // 再加25% → 超120%
    字典设(r, "benchmark_ai_超载门控", 转字符串(内存度量_门控检查(ai)))
    // 当前活跃profile报告
    如果 (_当前内存度量 != 空) {
        字典设(r, "当前profile", 内存度量_报告(_当前内存度量))
    }
    返回 r
}

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/进程描述符.nova")
导入("../中枢/字符串替换.nova")
导入("../记忆/路径查找.nova")
导入("../记忆/文件层文件.nova")
导入("../引导/端口输入.nova")
导入("../记忆/虚文件信号.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/内核打印.nova")

定义 AR_魔数 = "!<arch>\n"
定义 AR_魔数长度 = 8
定义 AR_头大小 = 60
定义 TAR_块大小 = 512
定义 TAR_类型_普通文件 = 48
定义 TAR_类型_目录 = 53
定义 TAR_类型_符号链接 = 50
定义 TAR_类型_硬链接 = 49

结构 AR文件头 {
    名称,
    修改时间,
    所有者ID,
    组ID,
    模式,
    大小,
}

结构 TAR文件头 {
    路径,
    模式,
    所有者ID,
    组ID,
    大小,
    修改时间,
    校验和,
    类型,
    链接目标,
    前缀,
}

定义 可变 解包_已提取文件数 = 0
定义 可变 解包_已提取字节 = 0
定义 可变 解包_错误数 = 0

函数 解包_ar(路径, 名称) {
    定义 文件 = VFS_打开(路径, 0)
    如果 (文件 == 空) {
        内核信息("兼容层: 无法打开ar文件 " + 路径)
        返回 空
    }

    定义 魔数 = VFS_读取(文件, AR_魔数长度)
    如果 (魔数 == 空 || 魔数 != AR_魔数) {
        VFS_关闭(文件)
        内核信息("兼容层: 无效ar格式 " + 路径)
        返回 空
    }

    定义 可变 找到 = 假
    定义 可变 结果路径 = 空

    当 (!找到) {
        定义 头数据 = VFS_读取(文件, AR_头大小)
        如果 (头数据 == 空) { 跳出 }

        定义 头 = 解包_解析AR头(头数据)
        如果 (头 == 空) { 跳出 }

        如果 (字符串_包含(头.名称, 名称)) {
            定义 内容 = VFS_读取(文件, 头.大小)
            如果 (内容 != 空) {
                结果路径 = "/tmp/解包_" + 名称
                VFS_写入(结果路径, 内容)
                找到 = 真
                内核信息("兼容层: 提取ar成员 " + 名称 + " (" + 整数转字符串(头.大小) + " 字节)")
            }
        } 否则 {
            VFS_跳过(文件, 头.大小)
        }

        如果 (头.大小 % 2 != 0) { VFS_跳过(文件, 1) }
    }

    VFS_关闭(文件)
    如果 (!找到) {
        内核信息("兼容层: ar中未找到 " + 名称)
    }
    返回 结果路径
}

函数 解包_解析AR头(数据) {
    如果 (数据 == 空 || 字符串_长度(数据) < AR_头大小) { 返回 空 }
    定义 头 = AR文件头 {}
    头.名称 = 字符串_修剪(字符串_截取(数据, 0, 16))
    头.修改时间 = 字符串_转整数(字符串_修剪(字符串_截取(数据, 16, 28)))
    头.所有者ID = 字符串_转整数(字符串_修剪(字符串_截取(数据, 28, 34)))
    头.组ID = 字符串_转整数(字符串_修剪(字符串_截取(数据, 34, 40)))
    头.模式 = 字符串_转八进制(字符串_修剪(字符串_截取(数据, 40, 48)))
    头.大小 = 字符串_转整数(字符串_修剪(字符串_截取(数据, 48, 58)))
    返回 头
}

函数 解包_tar(数据, 目标) {
    如果 (数据 == 空) { 返回 }
    内核信息("兼容层: 解包tar → " + 目标)

    解包_已提取文件数 = 0
    解包_已提取字节 = 0
    解包_错误数 = 0

    定义 可变 偏移 = 0
    定义 数据长度 = 字符串_长度(数据)

    当 (偏移 + TAR_块大小 <= 数据长度) {
        定义 头数据 = 字符串_截取(数据, 偏移, 偏移 + TAR_块大小)
        偏移 = 偏移 + TAR_块大小

        如果 (解包_是空块(头数据)) { 跳出 }

        定义 头 = 解包_解析TAR头(头数据)
        如果 (头 == 空) {
            解包_错误数 = 解包_错误数 + 1
            跳出
        }

        如果 (!解包_验证TAR校验和(头数据, 头.校验和)) {
            内核信息("兼容层: tar校验和错误: " + 头.路径)
            解包_错误数 = 解包_错误数 + 1
        }

        定义 完整路径 = 目标 + "/" + 头.路径
        如果 (头.前缀 != "") {
            完整路径 = 目标 + "/" + 头.前缀 + "/" + 头.路径
        }

        如果 (头.类型 == TAR_类型_目录) {
            VFS_创建目录(完整路径, 头.模式)
        } 否则 如果 (头.类型 == TAR_类型_符号链接) {
            VFS_创建符号链接(完整路径, 头.链接目标)
        } 否则 如果 (头.类型 == TAR_类型_普通文件 || 头.类型 == 0) {
            如果 (头.大小 > 0) {
                定义 文件数据 = 字符串_截取(数据, 偏移, 偏移 + 头.大小)
                VFS_写入(完整路径, 文件数据)
            }
            VFS_设置属性(完整路径, 头.模式)
        }

        解包_已提取文件数 = 解包_已提取文件数 + 1
        解包_已提取字节 = 解包_已提取字节 + 头.大小

        定义 数据块数 = (头.大小 + TAR_块大小 - 1) / TAR_块大小
        偏移 = 偏移 + 数据块数 * TAR_块大小
    }

    内核信息("兼容层: tar完成, " + 整数转字符串(解包_已提取文件数) + " 文件, " + 整数转字符串(解包_已提取字节) + " 字节")
}

函数 解包_解析TAR头(数据) {
    如果 (数据 == 空) { 返回 空 }
    定义 头 = TAR文件头 {}
    头.路径 = 字符串_修剪零(字符串_截取(数据, 0, 100))
    头.模式 = 字符串_转八进制(字符串_修剪(字符串_截取(数据, 100, 108)))
    头.所有者ID = 字符串_转八进制(字符串_修剪(字符串_截取(数据, 108, 116)))
    头.组ID = 字符串_转八进制(字符串_修剪(字符串_截取(数据, 116, 124)))
    头.大小 = 字符串_转八进制(字符串_修剪(字符串_截取(数据, 124, 136)))
    头.修改时间 = 字符串_转八进制(字符串_修剪(字符串_截取(数据, 136, 148)))
    头.校验和 = 字符串_转八进制(字符串_修剪(字符串_截取(数据, 148, 156)))
    头.类型 = 编码(字符串_截取(数据, 156, 157))
    头.链接目标 = 字符串_修剪零(字符串_截取(数据, 157, 257))
    头.前缀 = 字符串_修剪零(字符串_截取(数据, 345, 500))
    返回 头
}

函数 解包_验证TAR校验和(数据, 期望值) {
    定义 可变 计算值 = 0
    定义 可变 i = 0
    当 (i < TAR_块大小) {
        如果 (i >= 148 && i < 156) {
            计算值 = 计算值 + 32
        } 否则 {
            计算值 = 计算值 + 编码(字符串_截取(数据, i, i + 1))
        }
        i = i + 1
    }
    返回 计算值 == 期望值
}

函数 解包_是空块(数据) {
    定义 可变 i = 0
    当 (i < 字符串_长度(数据)) {
        如果 (编码(字符串_截取(数据, i, i + 1)) != 0) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 解包_deb(路径, 目标) {
    内核信息("兼容层: 解包deb " + 路径)

    定义 控制tar = 解包_ar(路径, "control.tar")
    如果 (控制tar != 空) {
        定义 控制数据 = VFS_读取全部(控制tar)
        解包_tar(控制数据, 目标 + "/DEBIAN")
    }

    定义 数据tar = 解包_ar(路径, "data.tar")
    如果 (数据tar != 空) {
        定义 数据内容 = VFS_读取全部(数据tar)
        解包_tar(数据内容, 目标)
    }

    返回 0
}

函数 字符串_修剪零(s) {
    定义 可变 结束 = 字符串_长度(s)
    当 (结束 > 0 && 编码(字符串_截取(s, 结束 - 1, 结束)) == 0) { 结束 = 结束 - 1 }
    返回 字符串_截取(s, 0, 结束)
}

函数 字符串_转八进制(s) {
    定义 可变 结果 = 0
    定义 可变 i = 0
    当 (i < 字符串_长度(s)) {
        定义 c = 编码(字符串_截取(s, i, i + 1))
        如果 (c >= 48 && c <= 55) { 结果 = 结果 * 8 + (c - 48) }
        i = i + 1
    }
    返回 结果
}

函数 VFS_查找(路径) { 返回 路径查找(路径, 0) }
函数 VFS_创建目录(路径, 模式) { vfs_mkdir(路径, 模式) }
函数 VFS_创建符号链接(链接, 目标) { vfs_symlink(链接, 目标) }
函数 VFS_读取(文件, 长度) { 返回 vfs_read(文件, 空, 长度) }
函数 VFS_读行(文件) { 返回 vfs_read(文件, 空, 256) }
函数 VFS_关闭(文件) { vfs_close(文件) }
函数 VFS_写入(路径, 数据) { vfs_write_file(路径, 数据) }
函数 VFS_跳过(文件, 长度) { vfs_seek(文件, 长度, 1) }
函数 VFS_读取全部(路径) { 返回 vfs_read_all(路径) }
函数 VFS_设置属性(路径, 模式) { 内核调试("chmod: " + 路径) }
函数 读取用户字节(地址) { 返回 内存读8(地址) }
函数 进程_设置状态_兼容(进程, 状态) { 进程_设置状态(进程, 状态) }
函数 调度_兼容() { schedule() }
函数 字符串_去前缀(字符串, 前缀) {
    如果 (字符串_长度(前缀) > 字符串_长度(字符串)) { 返回 字符串 }
    返回 字符串_截取(字符串, 字符串_长度(前缀), 字符串_长度(字符串))
}

函数 兼容层_完整统计() {
    返回 [兼容_调用总数, 解包_已提取文件数, 解包_已提取字节, 解包_错误数]
}

定义 错误_格式 = -8
定义 错误_ENOSYS = -38
定义 错误_无效参数 = -22
定义 错误_中断 = -4

定义 可变 AI_归档解包_负载窗口 = []

函数 AI_归档解包_负载预测(当前负载) {
    追加(AI_归档解包_负载窗口, 当前负载)
    如果 (计数(AI_归档解包_负载窗口) > 20) { 列表_移除(AI_归档解包_负载窗口, 0) }
    如果 (计数(AI_归档解包_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_归档解包_负载窗口)
    定义 趋势 = AI_归档解包_负载窗口[n-1] - AI_归档解包_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_归档解包_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

函数 归档解包_统计() {
    返回 {
        模块: "归档解包",
        解包_已提取文件数: 解包_已提取文件数,
        解包_已提取字节: 解包_已提取字节,
        解包_错误数: 解包_错误数,
        AI_归档解包_负载窗口: 计数(AI_归档解包_负载窗口)
    }
}

函数 归档解包_健康评估() {
    定义 可变 问题 = []
    如果 (解包_错误数 > 100) { 追加(问题, "解包_错误数过高: " + 整数转字符串(解包_错误数)) }
    返回 计数(问题) == 0
}

函数 归档解包_综合报告() {
    打印("[归档解包] ═══ 综合报告 ═══")
    打印("  解包_已提取文件数: " + 整数转字符串(解包_已提取文件数))
    打印("  解包_已提取字节: " + 整数转字符串(解包_已提取字节))
    打印("  解包_错误数: " + 整数转字符串(解包_错误数))
    打印("  AI_归档解包_负载窗口: " + 整数转字符串(计数(AI_归档解包_负载窗口)))
    打印("  健康: " + 如果 (归档解包_健康评估()) { "正常" } 否则 { "异常" })
}

函数 归档解包_全局重置() {
    解包_已提取文件数 = 0
    解包_已提取字节 = 0
    解包_错误数 = 0
    AI_归档解包_负载窗口 = []
    打印("[归档解包] 全局统计已重置")
    返回 0
}

导入("../core/theory_core.nova")
导入("../exp/theory_experiments.nova")

函数 压力验证_打印(级别, 文本) {
    打印("[实验目录][压力验证][" + 理论_等级文本(级别) + "] " + 文本)
}

函数 压力验证_断言(条件, 级别, 文本) {
    如果 (!条件) {
        压力验证_打印(级别, 文本)
        返回 假
    }
    返回 真
}

函数 压力验证_序列不下降(名称, 序列, 说明) {
    定义 可变 通过 = 真
    定义 可变 前值 = 序列[0]
    定义 可变 i = 1
    当 (i < 计数(序列)) {
        如果 (!压力验证_断言(序列[i] >= 前值, 警告_致命, 名称 + " " + 说明 + " 扫描不满足不下降")) {
            通过 = 假
        }
        前值 = 序列[i]
        i = i + 1
    }
    返回 通过
}

函数 压力验证_序列不上升(名称, 序列, 说明) {
    定义 可变 通过 = 真
    定义 可变 前值 = 序列[0]
    定义 可变 i = 1
    当 (i < 计数(序列)) {
        如果 (!压力验证_断言(序列[i] <= 前值, 警告_致命, 名称 + " " + 说明 + " 扫描不满足不上升")) {
            通过 = 假
        }
        前值 = 序列[i]
        i = i + 1
    }
    返回 通过
}

函数 压力验证_首尾优势(序列) {
    定义 末索引 = 计数(序列) - 1
    返回 序列[0] - 序列[末索引]
}

函数 压力验证_多档参数扫描() {
    定义 可变 通过 = 真
    定义 记忆_扫描 = [
        原创_记忆晶化保持率(800, 200, 400, 180, 620, 560, 200),
        原创_记忆晶化保持率(800, 200, 400, 260, 620, 560, 200),
        原创_记忆晶化保持率(800, 200, 400, 420, 620, 560, 200),
        原创_记忆晶化保持率(800, 200, 400, 640, 620, 560, 200),
        原创_记忆晶化保持率(800, 200, 400, 760, 620, 560, 200),
        原创_记忆晶化保持率(800, 200, 400, 860, 620, 560, 200)

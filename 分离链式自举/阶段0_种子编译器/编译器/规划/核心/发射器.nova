函数 发射_vtestps(s1, s2) {
    发射_vex3(0, 0, 2, 0, 1)
    发射(0x0E) 发射(0xC0+(s1&7)*8+(s2&7))
}
函数 发射_vtestpd(s1, s2) {
    发射_vex3(0, 0, 2, 0, 1)
    发射(0x0F) 发射(0xC0+(s1&7)*8+(s2&7))
}
// vzeroupper — 清空ymm高128位(AVX/SSE转换)
函数 发射_vzeroupper() { 发射_vex2(1, 0 , 0, 0) 发射(0x77) }
// vzeroall — 清零所有ymm
函数 发射_vzeroall() { 发射_vex2(1,  0,  1, 0) 发射(0x77) }
// vmaskmovps/vmaskmovpd — 掩码加载/存储
函数 发射_vmaskmovps_load(d, 掩码, reg) {
    发射_vex3(0, 掩码, 2, 0, 1)
    发射(0x2C) 发射(0x00+(d&7)*8+(reg&7))
}

// Nova · 运行时 · 智能推理 · 注意力机制
// 职责: Transformer注意力计算、多头分割、KV缓存、位置编码
// 层级: M16 — AI理论适配

// 向量点积

导入("../../标准库/基础.nova")

函数 注意力机制_向量_点积(a, b) {
    定义 可变 n = 计数(a)
    定义 blen = 计数(b)
    如果 (blen < n) { n = blen }
    定义 可变 累加 = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 ai = a[i]
        定义 bi = b[i]
        定义 积 = ai * bi
        累加 = 累加 + 积
        i = i + 1
    }
    返回 累加
}

// 向量缩放
函数 向量_缩放(v, s) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(v)) {
        定义 vi = v[i]
        定义 scaled = vi * s
        追加(结果, scaled)
        i = i + 1
    }
    返回 结果
}

// 向量加法
函数 注意力机制_向量_加(a, b) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(a)) { 追加(结果, a[i] + b[i])  i = i + 1 }
    返回 结果
}

// Softmax (整数近似: 定点1000倍)
函数 softmax_近似(分数列表) {
    // 找最大值
    定义 可变 最大 = 分数列表[0]
    定义 可变 i = 1
    当 (i < 计数(分数列表)) {
        如果 (分数列表[i] > 最大) { 最大 = 分数列表[i] }
        i = i + 1
    }
    // exp近似: e^x ≈ 1+x+x²/2 (|x|<3, 定点1000倍)
    定义 可变 exp值 = []
    定义 可变 总和 = 0
    i = 0
    当 (i < 计数(分数列表)) {
        定义 x = 分数列表[i] - 最大  // 归一化防溢出
        定义 可变 ex = 1000 + x + (x * x / 2000)
        如果 (ex < 1) { ex = 1 }
        追加(exp值, ex)
        总和 = 总和 + ex
        i = i + 1
    }
    // 归一化
    定义 可变 概率 = []
    i = 0
    当 (i < 计数(exp值)) {
        追加(概率, exp值[i] * 1000 / 总和)
        i = i + 1
    }
    返回 概率
}

// 单头注意力: Q·K^T / sqrt(d_k) → softmax → ·V
// Q: [seq_len × d_k], K: [seq_len × d_k], V: [seq_len × d_v]
// 简化: Q/K/V均为向量列表
函数 注意力机制_注意力_单头(Q列表, K列表, V列表, d_k) {
    定义 seq_len = 计数(Q列表)
    定义 可变 输出 = []
    定义 缩放 = d_k  // sqrt近似: 用d_k代替sqrt(d_k)*sqrt(d_k)

    定义 可变 qi = 0
    当 (qi < seq_len) {
        // 计算注意力分数: score[j] = Q[qi]·K[j] / sqrt(d_k)
        定义 可变 分数 = []
        定义 可变 kj = 0
        当 (kj < seq_len) {
            定义 点 = 注意力机制_向量_点积(Q列表[qi], K列表[kj])
            追加(分数, 点 * 1000 / 缩放)  // 定点缩放
            kj = kj + 1
        }

        // Softmax
        定义 权重 = softmax_近似(分数)

        // 加权求和V
        定义 d_v = 计数(V列表[0])
        定义 可变 加权V = []
        定义 可变 d = 0
        当 (d < d_v) { 追加(加权V, 0)  d = d + 1 }

        定义 可变 vj = 0
        当 (vj < seq_len) {
            d = 0
            当 (d < d_v) {
                加权V[d] = 加权V[d] + V列表[vj][d] * 权重[vj] / 1000
                d = d + 1
            }
            vj = vj + 1
        }

        追加(输出, 加权V)
        qi = qi + 1
    }
    返回 输出
}

// 多头注意力
// 将d_model拆分为num_heads个d_k维头
函数 注意力_多头(Q, K, V, num_heads, d_model) {
    定义 可变 拼接输出 = []
    定义 d_k = d_model / num_heads
    定义 seq_len = 计数(Q)
    定义 可变 所有头输出 = []

    定义 可变 h = 0
    当 (h < num_heads) {
        // 提取当前头的Q/K/V切片
        定义 起始 = h * d_k
        定义 可变 头Q = []
        定义 可变 头K = []
        定义 可变 头V = []

        定义 可变 s = 0
        当 (s < seq_len) {
            定义 可变 qslice = []
            定义 可变 kslice = []
            定义 可变 vslice = []
            定义 可变 d = 0
            当 (d < d_k) {
                追加(qslice, Q[s][起始 + d])
                追加(kslice, K[s][起始 + d])
                追加(vslice, V[s][起始 + d])
                d = d + 1
            }
            追加(头Q, qslice)
            追加(头K, kslice)
            追加(头V, vslice)
            s = s + 1
        }

        定义 头输出 = 注意力机制_注意力_单头(头Q, 头K, 头V, d_k)
        追加(所有头输出, 头输出)
        h = h + 1
    }

    // 拼接所有头 → [seq_len × d_model]
    定义 可变 si = 0
    当 (si < seq_len) {
        定义 可变 行 = []
        h = 0
        当 (h < num_heads) {
            定义 可变 d = 0
            当 (d < d_k) {
                追加(行, 所有头输出[h][si][d])
                d = d + 1
            }
            h = h + 1
        }
        追加(拼接输出, 行)
        si = si + 1
    }
    返回 拼接输出
}

// KV缓存: [K缓存, V缓存, 已缓存长度, 最大长度]
函数 注意力机制_KV缓存_创建(最大长度) {
    返回 [[], [], 0, 最大长度]
}

函数 注意力机制_KV缓存_追加(缓存, k向量, v向量) {
    如果 (缓存[2] < 缓存[3]) {
        追加(缓存[0], k向量)
        追加(缓存[1], v向量)
        缓存[2] = 缓存[2] + 1
    }
}

函数 KV缓存_K列表(缓存) { 返回 缓存[0] }
函数 KV缓存_V列表(缓存) { 返回 缓存[1] }
函数 注意力机制_KV缓存_长度(缓存) { 返回 缓存[2] }

// 位置编码(正弦/余弦近似, 整数定点)
// PE(pos, 2i) = sin(pos / 10000^(2i/d))
// PE(pos, 2i+1) = cos(pos / 10000^(2i/d))
函数 注意力机制_位置编码_生成(seq_len, d_model) {
    定义 可变 编码 = []
    定义 可变 pos = 0
    当 (pos < seq_len) {
        定义 可变 行 = []
        定义 可变 i = 0
        当 (i < d_model) {
            // 简化: 用线性交替模式近似
            定义 可变 值 = 0
            如果 (i % 2 == 0) {
                值 = (pos * 1000) / (1 + i * i)  // sin近似
            } 否则 {
                值 = 1000 - (pos * 1000) / (1 + i * i)  // cos近似
            }
            追加(行, 值)
            i = i + 1
        }
        追加(编码, 行)
        pos = pos + 1
    }
    返回 编码
}

// 报告
函数 注意力_打印报告(seq_len, d_model, num_heads) {
    打印("═══ 注意力机制报告 ═══")
    打印文本(字符串拼接("  序列长度: ", 转字符串(seq_len)))
    打印文本(字符串拼接("  模型维度: ", 转字符串(d_model)))
    打印文本(字符串拼接("  注意力头: ", 转字符串(num_heads)))
    打印文本(字符串拼接("  每头维度: ", 转字符串(d_model / num_heads)))
    打印文本(字符串拼接("  注意力矩阵: ", 字符串拼接(转字符串(seq_len), 字符串拼接("×", 转字符串(seq_len)))))
}

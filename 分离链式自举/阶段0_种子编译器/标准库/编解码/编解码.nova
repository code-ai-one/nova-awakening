导入("../基础.nova")


// RLE编码
函数 RLE_编码(数据) {
    如果 (计数(数据) == 0) { 返回 []
}
 定义 可变 结果 = []
 定义 可变 当前 = 数据[0]
 定义 可变 计数器 = 1
 定义 可变 i = 1
 当 (i < 计数(数据)) { 如果 (数据[i] == 当前) { 计数器 = 计数器 + 1 }
 否则 { 追加(结果, [当前, 计数器])
 当前 = 数据[i]
 计数器 = 1 }
 i = i + 1
 }
 追加(结果, [当前, 计数器])
 返回 结果
}

函数 RLE_解码(编码) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(编码)) { 定义 可变 j = 0
 当 (j < 编码[i][1]) { 追加(结果, 编码[i][0])
 j = j + 1 }
 i = i + 1
 }
 返回 结果
}

// 差分编码
函数 差分_编码(数据) {
    如果 (计数(数据) == 0) { 返回 []
}
 定义 可变 r = [数据[0]]
 定义 可变 i = 1
 当 (i < 计数(数据)) { 追加(r, 数据[i] - 数据[i - 1])
 i = i + 1 }
 返回 r
}

函数 差分_解码(编码) {
    如果 (计数(编码) == 0) { 返回 []
}
 定义 可变 r = [编码[0]]
 定义 可变 i = 1
 当 (i < 计数(编码)) { 追加(r, r[i - 1] + 编码[i])
 i = i + 1 }
 返回 r
}

// 校验和
函数 编解码_校验和(数据) { 定义 可变 s1 = 0
 定义 可变 s2 = 0
 定义 可变 i = 0
 当 (i < 计数(数据)) { s1 = (s1 + 数据[i]) % 255
 s2 = (s2 + s1) % 255
 i = i + 1 }
 返回 s2 * 256 + s1
}

// 协议帧
函数 帧_打包(类型, 数据) { 定义 可变 帧 = [170, 计数(数据), 类型]
 定义 可变 i = 0
 当 (i < 计数(数据)) { 追加(帧, 数据[i])
 i = i + 1 }
 追加(帧, 校验和(帧, 0))
 返回 帧
}

函数 帧_验证(帧) {
    如果 (计数(帧) < 4) { 返回 假
}
 如果 (帧[0] != 170) { 返回 假 }
 定义 可变 子帧 = []
 定义 可变 i = 0
 当 (i < 计数(帧) - 1) { 追加(子帧, 帧[i])
 i = i + 1 }
 如果 (计数(帧) == 0) { 返回 空 }
 返回 校验和(子帧, 0) == 帧[计数(帧) - 1]
}

// 频率统计
// VarInt编码 (变长整数)
函数 编解码_VarInt_编码(值) { 定义 可变 结果 = []
 定义 可变 v = 值
 如果 (v < 0) { v = 0 - v }
 当 (v >= 128) {
 追加(结果, (v % 128) + 128)
 v = v / 128
 }
 追加(结果, v)
 返回 结果
}

函数 编解码_VarInt_解码(字节列表) { 定义 可变 结果 = 0
 定义 可变 移位 = 1
 定义 可变 i = 0
 当 (i < 计数(字节列表)) { 定义 b = 字节列表[i]
 如果 (b >= 128) {
 结果 = 结果 + (b - 128) * 移位
 移位 = 移位 * 128
 } 否则 {
 结果 = 结果 + b * 移位
 返回 结果
 }
 i = i + 1
 }
 返回 结果
}

// Base64编码 (标准RFC 4648字母表)
定义 B64表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

函数 B64_字符(索引) {
    如果 (索引 < 0 或 索引 > 63) { 返回 "A"
}
 返回 子串(B64表, 索引, 1)
}

函数 B64_值(字符) { 定义 c = 编码(字符)
 如果 (c >= 字符_大写A 且 c <= 字符_大写Z) { 返回 c - 65 } // A-Z
 如果 (c >= 字符_小写a 且 c <= 字符_小写z) { 返回 c - 97 + 26 } // a-z
 如果 (c >= 字符_零 且 c <= 字符_九) { 返回 c - 48 + 52 } // 0-9
 如果 (c == 字符_加号) { 返回 62 } // +
 如果 (c == 字符_斜杠) { 返回 63 } // /
 返回 0
}

函数 编码_Base64_编码(数据) { 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 计数(数据)) { 定义 可变 b0 = 数据[i]
 定义 可变 b1 = 0
 定义 可变 b2 = 0
 定义 可变 剩余 = 计数(数据) - i
 如果 (剩余 > 1) { b1 = 数据[i + 1] }
 如果 (剩余 > 2) { b2 = 数据[i + 2] }
 结果 = 字符串拼接(结果, B64_字符(b0 / 4))
 结果 = 字符串拼接(结果, B64_字符((b0 % 4) * 16 + b1 / 16))
 如果 (剩余 > 1) {
 结果 = 字符串拼接(结果, B64_字符((b1 % 16) * 4 + b2 / 64))
 } 否则 { 结果 = 字符串拼接(结果, "=") }
 如果 (剩余 > 2) {
 结果 = 字符串拼接(结果, B64_字符(b2 % 64))
 } 否则 { 结果 = 字符串拼接(结果, "=") }
 i = i + 3
 }
 返回 结果
}

函数 编码_Base64_解码(文本) { 定义 可变 结果 = []
 定义 可变 i = 0
 定义 长度 = 计数(文本)
 当 (i + 3 < 长度) { 定义 c0 = B64_值(子串(文本, i, 1))
 定义 c1 = B64_值(子串(文本, i + 1, 1))
 定义 c2字符 = 子串(文本, i + 2, 1)
 定义 c3字符 = 子串(文本, i + 3, 1)
 定义 c2字符 = 子串(编码文本, i + 2, 1)
 定义 c3字符 = 子串(编码文本, i + 3, 1)
 追加(结果, c0 * 4 + c1 / 16)
 如果 (c2字符 != "=") { 定义 c2 = B64_值(c2字符)
 追加(结果, (c1 % 16) * 16 + c2 / 4)
 如果 (c3字符 != "=") { 定义 c3 = B64_值(c3字符)
 追加(结果, (c2 % 4) * 64 + c3)
 }
 }
 i = i + 4
 }
 返回 结果
}

// 循环冗余32 (IEEE 802.3 多项式 0xEDB88320)
函数 循环冗余32(数据) {
 定义 可变 crc状态 = [0xFFFFFFFF]
 定义 可变 i = 0
 当 (i < 计数(数据)) {
 crc状态[0] = crc状态[0] ^ (数据[i] & 0xFF)
 // 逐位处理 (反射多项式 0xEDB88320)
 定义 可变 位值 = 0
 当 (位值 < 8) {
  如果 ((crc状态[0] & 1) != 0) {
   crc状态[0] = ((crc状态[0] >> 1) & 0x7FFFFFFF) ^ 0xEDB88320
  } 否则 {
   crc状态[0] = (crc状态[0] >> 1) & 0x7FFFFFFF
  }
  位值 = 位值 + 1
 }
 i = i + 1
 }
 crc状态[0] = crc状态[0] ^ 0xFFFFFFFF
 如果 (crc状态[0] < 0) { crc状态[0] = crc状态[0] + 0x100000000 }
 返回 crc状态[0]
}

// 哈夫曼频率排序
函数 频率_排序(频率) { 定义 可变 索引 = []
 定义 可变 i = 0
 当 (i < 计数(频率)) { 如果 (频率[i] > 0) { 追加(索引, [i, 频率[i]]) }
 i = i + 1
 }
 // 按频率降序冒泡
 i = 0
 当 (i < 计数(索引)) { 定义 可变 j = i + 1
 当 (j < 计数(索引)) { 如果 (索引[j][1] > 索引[i][1]) { 定义 临时 = 索引[i]
 索引[i] = 索引[j]
 索引[j] = 临时
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 索引
}

// 数据压缩率
函数 编解码_压缩率(原始大小, 压缩大小) {
    如果 (原始大小 == 0) { 返回 0
}
 返回 (原始大小 - 压缩大小) * 1000 / 原始大小
}

// 字节位操作
函数 位_获取(值, 位号) { 返回 (值 / (1 << 位号)) % 2 }
函数 编码_位_设置(值, 位号) { 返回 值 + (1 << 位号) }
函数 编码_位_清除(值, 位号) {
    如果 (位_获取(值, 位号) == 1) { 返回 值 - (1 << 位号)
}
 返回 值
}

// 帧提取数据
函数 帧_数据(帧) { 定义 可变 结果 = []
 定义 可变 i = 3
 当 (i < 计数(帧) - 1) { 追加(结果, 帧[i])
 i = i + 1 }
 返回 结果
}
函数 帧_类型(帧) {
    如果 (计数(帧) >= 3) { 返回 帧[2]
}
返回 -1 }



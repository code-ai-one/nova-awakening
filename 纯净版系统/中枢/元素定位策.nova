// §2 元素定位策略

函数 UI_按文本查找(文本) {
    // 精确文本匹配
    定义 可变 i = 0
    当 (i < 计数(已发现元素)) {
        如果 (已发现元素[i].名称 == 文本) {
            返回 已发现元素[i]
        }
        i = i + 1
    }
    返回 空
}

函数 UI_按文本模糊查找(关键词) {
    // 模糊匹配: 名称包含关键词
    定义 可变 i = 0
    当 (i < 计数(已发现元素)) {
        如果 (字符串包含(已发现元素[i].名称, 关键词)) {
            返回 已发现元素[i]
        }
        i = i + 1
    }
    返回 空
}

函数 UI_按角色查找(角色) {
    // 按无障碍角色查找(button/link/textbox/...)
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(已发现元素)) {
        如果 (已发现元素[i].角色 == 角色) {
            追加(结果, 已发现元素[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 UI_按坐标查找(x, y) {
    // 精确坐标命中测试
    定义 可变 最深 = 空
    定义 可变 i = 0
    当 (i < 计数(已发现元素)) {
        定义 e = 已发现元素[i]
        如果 (x >= e.左上x && x < e.左上x + e.宽 &&
            y >= e.左上y && y < e.左上y + e.高) {
            最深 = e  // 后面的元素Z序更高
        }
        i = i + 1
    }
    返回 最深
}

函数 UI_按元素选择器查找(选择器) {
    // 当前实现元素选择器匹配(匹配DOM路径末尾)
    定义 可变 i = 0
    当 (i < 计数(已发现元素)) {
        如果 (字符串结尾匹配(已发现元素[i].DOM路径, 选择器)) {
            返回 已发现元素[i]
        }
        i = i + 1
    }
    返回 空
}

// §3 精准操作 — 模拟鼠标/键盘(像素级)

定义 操作_点击 = 1
定义 操作_双击 = 2
定义 操作_右击 = 3
定义 操作_输入 = 4
定义 操作_滚动 = 5
定义 操作_拖拽 = 6
定义 操作_悬停 = 7
定义 操作_按键 = 8

结构 UI操作记录 {
    操作类型,
    目标元素ID,
    x,
    y,
    输入文本,
    时间戳,
    成功,
}

定义 可变 操作历史 = []
定义 可变 操作_时钟 = 0

函数 UI_点击(元素) {
    如果 (元素 == 空) { UI_失败次数 = UI_失败次数 + 1; 返回 假 }
    UI_操作次数 = UI_操作次数 + 1
    操作_时钟 = 操作_时钟 + 1

    // 计算元素中心坐标(像素级精准)
    定义 目标x = 元素.中心x
    定义 目标y = 元素.中心y

    // 发送鼠标移动事件
    UI_发送鼠标移动(目标x, 目标y)
    // 发送鼠标按下+释放
    UI_发送鼠标按钮(目标x, 目标y, 1, 真)   // 按下
    UI_发送鼠标按钮(目标x, 目标y, 1, 假)   // 释放

    // 记录操作
    定义 记录 = UI操作记录 {}
    记录.操作类型 = 操作_点击
    记录.目标元素ID = 元素.元素ID
    记录.x = 目标x
    记录.y = 目标y
    记录.时间戳 = 操作_时钟
    记录.成功 = 真
    追加(操作历史, 记录)
    UI_成功次数 = UI_成功次数 + 1

    内核调试("UI操作: 点击 [" + 元素.角色 + "] '" + 元素.名称 +
             "' @(" + 整数转字符串(目标x) + "," + 整数转字符串(目标y) + ")")
    返回 真
}

函数 UI_输入文本(元素, 文本) {
    如果 (元素 == 空 || !元素.可输入) { UI_失败次数 = UI_失败次数 + 1; 返回 假 }
    UI_操作次数 = UI_操作次数 + 1
    操作_时钟 = 操作_时钟 + 1

    // 先点击聚焦
    UI_点击(元素)

    // 逐字符发送键盘事件
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 ch = 字符串取字节(文本, i)
        UI_发送按键(ch, 真)
        UI_发送按键(ch, 假)
        i = i + 1
    }

    定义 记录 = UI操作记录 {}
    记录.操作类型 = 操作_输入
    记录.目标元素ID = 元素.元素ID
    记录.输入文本 = 文本
    记录.时间戳 = 操作_时钟
    记录.成功 = 真
    追加(操作历史, 记录)
    UI_成功次数 = UI_成功次数 + 1

    内核调试("UI操作: 输入 [" + 元素.角色 + "] 文本='" + 文本 + "'")
    返回 真
}

函数 UI_滚动(x, y, 方向, 量) {
    UI_操作次数 = UI_操作次数 + 1
    操作_时钟 = 操作_时钟 + 1
    UI_发送滚轮(x, y, 方向, 量)
    UI_成功次数 = UI_成功次数 + 1
    返回 真
}

函数 UI_拖拽(源x, 源y, 目标x, 目标y) {
    UI_操作次数 = UI_操作次数 + 1
    操作_时钟 = 操作_时钟 + 1
    UI_发送鼠标移动(源x, 源y)
    UI_发送鼠标按钮(源x, 源y, 1, 真)
    // 分步移动(模拟平滑拖拽)
    定义 步数 = 10
    定义 可变 i = 1
    当 (i <= 步数) {
        定义 cx = 源x + (目标x - 源x) * i / 步数
        定义 cy = 源y + (目标y - 源y) * i / 步数
        UI_发送鼠标移动(cx, cy)
        i = i + 1
    }
    UI_发送鼠标按钮(目标x, 目标y, 1, 假)
    UI_成功次数 = UI_成功次数 + 1
    返回 真
}

定义 可变 AI_元素定位策_热节点缓存 = 0

函数 AI_元素定位策_节点热度(节点, 操作类型) {
    如果 (操作类型 == "查询") { 返回 "缓存" }
    如果 (操作类型 == "修改") { AI_元素定位策_热节点缓存 = 0; 返回 "失效" }
    返回 "普通"
}

函数 AI_元素定位策_批量DOM优化(操作数) {
    如果 (操作数 > 100) { 返回 "延迟重排" }
    如果 (操作数 > 10) { 返回 "批量重排" }
    返回 "即时重排"
}

// NovaOS 能力自发现 + 自动生成 — 觉醒理论·能力成熟度模型
// 原创理论: NovaCapability-Maturity (NCMM)
//   成熟度阶段: 发现→原型→测试→稳定→核心
//   回滚保护: 生成模块失败时自动回滚到前一版本
//   依赖分析: 新能力需求自动检测前置依赖
//   重复检测: 避免重复发现已有能力
//   缺陷严重度加权: 高严重度缺陷优先自动修复

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./模块热加载.nova")
导入("../外联/序列工具.nova")
导入("./内核打印.nova")
导入("./整数转字符串.nova")

// 成熟度阶段定义
定义 成熟度_发现 = 1
定义 成熟度_原型 = 2
定义 成熟度_测试 = 3
定义 成熟度_稳定 = 4
定义 成熟度_核心 = 5

结构 能力需求 {
    描述,
    优先级,
    发现时间,
    已满足,
    生成的模块,
    成熟度,        // u32 1~5
    失败次数,      // u32 生成失败计数
    依赖列表,      // [] 前置能力描述
}

定义 可变 能力需求列表 = []
定义 可变 自生成_模块数 = 0
定义 可变 自生成_回滚数 = 0
定义 可变 自生成_失败数 = 0

// §2 能力发现 — 重复检测 + 依赖分析

定义 最大失败容忍 = 5
定义 成熟度_晋升_间隔 = 3000   // 每3000tick自动评估晋升

函数 能力_发现需求(描述, 优先级) {
    // 重复检测: 避免发现已有能力
    定义 可变 i = 0
    当 (i < 计数(能力需求列表)) {
        如果 (能力需求列表[i].描述 == 描述) {
            // 若未满足且新优先级更高, 提升优先级
            如果 (!能力需求列表[i].已满足) {
                如果 (优先级 > 能力需求列表[i].优先级) {
                    能力需求列表[i].优先级 = 优先级
                    内核调试("自演化: 提升已有需求优先级 '" + 描述 + "' → " + 整数转字符串(优先级))
                }
            }
            返回
        }
        i = i + 1
    }
    定义 需求 = 能力需求 {}
    需求.描述 = 描述
    需求.优先级 = 优先级
    需求.发现时间 = 演化_时钟
    需求.已满足 = 假
    需求.成熟度 = 成熟度_发现
    需求.失败次数 = 0
    需求.依赖列表 = []
    追加(能力需求列表, 需求)
    内核信息("自演化: 发现新能力需求 '" + 描述 + "' 优先级=" + 整数转字符串(优先级))
}

// 添加依赖关系: 能力A依赖能力B
函数 能力_添加依赖(能力描述, 依赖描述) {
    定义 可变 i = 0
    当 (i < 计数(能力需求列表)) {
        如果 (能力需求列表[i].描述 == 能力描述) {
            追加(能力需求列表[i].依赖列表, 依赖描述)
            返回
        }
        i = i + 1
    }
}

// 检查所有依赖是否已满足
函数 能力_依赖已就绪(需求索引) {
    定义 需求 = 能力需求列表[需求索引]
    定义 可变 d = 0
    当 (d < 计数(需求.依赖列表)) {
        // 在列表中查找依赖
        定义 可变 找到 = 假
        定义 可变 j = 0
        当 (j < 计数(能力需求列表)) {
            如果 (能力需求列表[j].描述 == 需求.依赖列表[d]) {
                如果 (能力需求列表[j].已满足) {
                    找到 = 真
                }
            }
            j = j + 1
        }
        如果 (!找到) { 返回 假 }
        d = d + 1
    }
    返回 真
}

// §2.1 自动满足 — 回滚保护 + 失败限制

函数 能力_自动满足() {
    // 按优先级排序: 简单冒泡（需求量不大）
    定义 可变 s = 0
    当 (s < 计数(能力需求列表)) {
        定义 可变 t = s + 1
        当 (t < 计数(能力需求列表)) {
            如果 (能力需求列表[t].优先级 > 能力需求列表[s].优先级) {
                定义 临时 = 能力需求列表[s]
                能力需求列表[s] = 能力需求列表[t]
                能力需求列表[t] = 临时
            }
            t = t + 1
        }
        s = s + 1
    }

    // 扫描未满足需求
    定义 可变 i = 0
    当 (i < 计数(能力需求列表)) {
        如果 (!能力需求列表[i].已满足) {
            // 失败次数过多则跳过
            如果 (能力需求列表[i].失败次数 >= 最大失败容忍) {
                i = i + 1
                继续
            }
            // 依赖检查
            如果 (!能力_依赖已就绪(i)) {
                i = i + 1
                继续
            }
            // 保存回滚点
            定义 回滚快照 = 热更新_创建快照()
            // AI生成模块代码
            定义 代码 = 智能_接口_推理("生成NovaOS模块: " + 能力需求列表[i].描述)
            如果 (代码 != 空) {
                定义 模块ID = 热更新_注册模块(能力需求列表[i].描述, 10000, "自动入口", [])
                定义 加载成功 = 热更新_加载(模块ID)
                如果 (加载成功) {
                    // 验证模块是否运行正常
                    定义 验证结果 = 热更新_验证模块(模块ID)
                    如果 (验证结果) {
                        能力需求列表[i].已满足 = 真
                        能力需求列表[i].生成的模块 = 模块ID
                        能力需求列表[i].成熟度 = 成熟度_原型
                        自生成_模块数 = 自生成_模块数 + 1
                        进化日志_记录("自生成", 能力需求列表[i].描述, 0, 10000)
                    } 否则 {
                        // 验证失败 → 回滚
                        热更新_恢复快照(回滚快照)
                        能力需求列表[i].失败次数 = 能力需求列表[i].失败次数 + 1
                        自生成_回滚数 = 自生成_回滚数 + 1
                        内核警告("自演化: 模块验证失败, 已回滚 '" + 能力需求列表[i].描述 + "'")
                    }
                } 否则 {
                    // 加载失败 → 回滚
                    热更新_恢复快照(回滚快照)
                    能力需求列表[i].失败次数 = 能力需求列表[i].失败次数 + 1
                    自生成_失败数 = 自生成_失败数 + 1
                }
            } 否则 {
                能力需求列表[i].失败次数 = 能力需求列表[i].失败次数 + 1
                自生成_失败数 = 自生成_失败数 + 1
            }
        }
        i = i + 1
    }
}

// §2.2 成熟度晋升 — NCMM阶段演进

函数 能力_评估成熟度() {
    定义 可变 i = 0
    当 (i < 计数(能力需求列表)) {
        如果 (能力需求列表[i].已满足) {
            定义 存活时间 = 演化_时钟 - 能力需求列表[i].发现时间
            定义 当前阶段 = 能力需求列表[i].成熟度
            // 原型→测试: 存活超过1个间隔
            如果 (当前阶段 == 成熟度_原型) {
                如果 (存活时间 >= 成熟度_晋升_间隔) {
                    能力需求列表[i].成熟度 = 成熟度_测试
                    进化日志_记录("成熟度晋升", 能力需求列表[i].描述 + "→测试", 2, 3)
                }
            }
            // 测试→稳定: 存活超过2个间隔且无失败
            如果 (当前阶段 == 成熟度_测试) {
                如果 (存活时间 >= 成熟度_晋升_间隔 * 2) {
                    如果 (能力需求列表[i].失败次数 == 0) {
                        能力需求列表[i].成熟度 = 成熟度_稳定
                        进化日志_记录("成熟度晋升", 能力需求列表[i].描述 + "→稳定", 3, 4)
                    }
                }
            }
            // 稳定→核心: 存活超过4个间隔
            如果 (当前阶段 == 成熟度_稳定) {
                如果 (存活时间 >= 成熟度_晋升_间隔 * 4) {
                    能力需求列表[i].成熟度 = 成熟度_核心
                    进化日志_记录("成熟度晋升", 能力需求列表[i].描述 + "→核心", 4, 5)
                }
            }
        }
        i = i + 1
    }
}

// §3 协议学习 — 模式匹配 + 版本兼容

结构 已学协议 {
    协议名,
    版本,
    解析器哈希,
    学习时间,
    使用次数,
    匹配_magic,  // u32 前4字节特征码
    置信度,      // u32 ×1000
}

定义 可变 已学协议列表 = []
定义 可变 协议_未知遭遇数 = 0
定义 可变 协议_自动识别数 = 0

函数 协议_遇到未知(数据, 端口) {
    协议_未知遭遇数 = 协议_未知遭遇数 + 1
    内核调试("自演化: 遇到未知协议 端口=" + 整数转字符串(端口))

    // 特征提取: 前4字节magic
    定义 可变 magic = 0
    如果 (计数(数据) >= 4) {
        magic = 数据[0] * 256 * 256 * 256 + 数据[1] * 256 * 256 + 数据[2] * 256 + 数据[3]
        内核调试("  magic=0x" + 整数转字符串(magic))
    }

    // 尝试与已学协议匹配magic
    定义 可变 k = 0
    当 (k < 计数(已学协议列表)) {
        如果 (已学协议列表[k].匹配_magic == magic) {
            如果 (magic != 0) {
                已学协议列表[k].使用次数 = 已学协议列表[k].使用次数 + 1
                协议_自动识别数 = 协议_自动识别数 + 1
                内核信息("自演化: 自动匹配协议 '" + 已学协议列表[k].协议名 + "'")
                返回
            }
        }
        k = k + 1
    }

    // 无匹配 → 发现新需求
    能力_发现需求("协议解析器-端口" + 整数转字符串(端口), 500)
}

函数 协议_注册已学(协议名, 版本, magic值) {
    // 重复检测
    定义 可变 j = 0
    当 (j < 计数(已学协议列表)) {
        如果 (已学协议列表[j].协议名 == 协议名) {
            // 版本更新
            已学协议列表[j].版本 = 版本
            已学协议列表[j].匹配_magic = magic值
            返回
        }
        j = j + 1
    }
    定义 p = 已学协议 {}
    p.协议名 = 协议名
    p.版本 = 版本
    p.学习时间 = 演化_时钟
    p.使用次数 = 0
    p.匹配_magic = magic值
    p.置信度 = 800
    追加(已学协议列表, p)
    进化日志_记录("学习协议", 协议名, 0, 0)
}

// §4 自动补丁 — 严重度加权 + 回滚保护

结构 缺陷报告 {
    模块名,
    错误描述,
    严重度,      // u32 1=低 2=中 3=高 4=关键
    发现时间,
    已修复,
    补丁版本,
    修复尝试数,
}

定义 可变 缺陷列表 = []
定义 可变 自动补丁_总数 = 0
定义 可变 自动补丁_回滚数 = 0
定义 最大修复尝试 = 3

函数 缺陷_报告(模块名, 错误描述, 严重度) {
    // 重复检测: 同一模块同一错误不重复报告
    定义 可变 d = 0
    当 (d < 计数(缺陷列表)) {
        如果 (缺陷列表[d].模块名 == 模块名) {
            如果 (缺陷列表[d].错误描述 == 错误描述) {
                如果 (!缺陷列表[d].已修复) {
                    // 提升严重度
                    如果 (严重度 > 缺陷列表[d].严重度) {
                        缺陷列表[d].严重度 = 严重度
                    }
                    返回
                }
            }
        }
        d = d + 1
    }
    定义 报告 = 缺陷报告 {}
    报告.模块名 = 模块名
    报告.错误描述 = 错误描述
    报告.严重度 = 严重度
    报告.发现时间 = 演化_时钟
    报告.已修复 = 假
    报告.修复尝试数 = 0
    追加(缺陷列表, 报告)
    内核信息("缺陷报告: [" + 模块名 + "] " + 错误描述 + " 严重度=" + 整数转字符串(严重度))

    // 严重度≥3自动尝试修复
    如果 (严重度 >= 3) {
        缺陷_自动修复(计数(缺陷列表) - 1)
    }
}

函数 缺陷_自动修复(缺陷索引) {
    如果 (缺陷索引 >= 计数(缺陷列表)) { 返回 }
    定义 报告 = 缺陷列表[缺陷索引]
    如果 (报告.已修复) { 返回 }
    如果 (报告.修复尝试数 >= 最大修复尝试) { 返回 }

    报告.修复尝试数 = 报告.修复尝试数 + 1

    // 查找模块
    定义 模块 = 热更新_按名查找(报告.模块名)
    如果 (模块 == 空) { 返回 }

    // 回滚快照
    定义 快照 = 热更新_创建快照()
    定义 补丁版本 = 模块.版本 + 1

    // AI生成修复代码
    定义 修复 = 智能_接口_推理("修复NovaOS缺陷: " + 报告.模块名 + " - " + 报告.错误描述)
    如果 (修复 != 空) {
        定义 成功 = 热更新_替换(模块.模块ID, 补丁版本, 演化_时钟)
        如果 (成功) {
            // 验证修复是否有效
            定义 验证 = 热更新_验证模块(模块.模块ID)
            如果 (验证) {
                报告.已修复 = 真
                报告.补丁版本 = 补丁版本
                自动补丁_总数 = 自动补丁_总数 + 1
                进化日志_记录("自动补丁", 报告.模块名, 模块.版本 - 1, 补丁版本)
            } 否则 {
                // 修复验证失败 → 回滚
                热更新_恢复快照(快照)
                自动补丁_回滚数 = 自动补丁_回滚数 + 1
                内核警告("自演化: 补丁验证失败, 回滚 '" + 报告.模块名 + "'")
            }
        }
    }
}

// §5 综合统计

函数 能力自发现_获取统计() {
    定义 可变 已满足数 = 0
    定义 可变 未满足数 = 0
    定义 可变 核心级数 = 0
    定义 可变 i = 0
    当 (i < 计数(能力需求列表)) {
        如果 (能力需求列表[i].已满足) {
            已满足数 = 已满足数 + 1
            如果 (能力需求列表[i].成熟度 == 成熟度_核心) {
                核心级数 = 核心级数 + 1
            }
        } 否则 {
            未满足数 = 未满足数 + 1
        }
        i = i + 1
    }
    定义 可变 未修复缺陷 = 0
    定义 可变 j = 0
    当 (j < 计数(缺陷列表)) {
        如果 (!缺陷列表[j].已修复) {
            未修复缺陷 = 未修复缺陷 + 1
        }
        j = j + 1
    }
    返回 {
        需求总数: 计数(能力需求列表),
        已满足: 已满足数,
        未满足: 未满足数,
        核心级能力: 核心级数,
        自生成模块: 自生成_模块数,
        生成回滚: 自生成_回滚数,
        生成失败: 自生成_失败数,
        已学协议: 计数(已学协议列表),
        协议未知遭遇: 协议_未知遭遇数,
        协议自动识别: 协议_自动识别数,
        缺陷总数: 计数(缺陷列表),
        缺陷未修复: 未修复缺陷,
        自动补丁数: 自动补丁_总数,
        补丁回滚: 自动补丁_回滚数,
    }
}

// NSED — Nova Self-Evolution Discovery Theory
// 公理1(能力完备): 系统可自主发现已有能力和缺失能力
// 公理2(安全生成): 自生成模块必经验证后才可集成
// 公理3(可回滚): 任何自生成/自修复均可安全回滚
// 定理1(升级收敛): 连续升级后系统能力单调递增
// 定理2(缺陷可修): 发现的缺陷均可生成修复补丁

函数 能力_重置统计() {
    自生成_模块数 = 0
    自生成_回滚数 = 0
    自生成_失败数 = 0
    协议_未知遭遇数 = 0
    协议_自动识别数 = 0
    自动补丁_总数 = 0
    自动补丁_回滚数 = 0
}

函数 能力_打印统计() {
    定义 s = 能力_统计()
    打印行("=== 自演化能力统计 ===")
    打印行("需求总数: " + 整数转字符串(s.需求总数))
    打印行("已满足: " + 整数转字符串(s.已满足))
    打印行("未满足: " + 整数转字符串(s.未满足))
    打印行("核心级: " + 整数转字符串(s.核心级能力))
    打印行("自生成: " + 整数转字符串(s.自生成模块))
    打印行("生成回滚: " + 整数转字符串(s.生成回滚))
    打印行("已学协议: " + 整数转字符串(s.已学协议))
    打印行("缺陷未修复: " + 整数转字符串(s.缺陷未修复))
    打印行("自动补丁: " + 整数转字符串(s.自动补丁数))
}

函数 能力_健康度() {
    定义 s = 能力_统计()
    如果 (s.需求总数 == 0) { 返回 1000 }
    定义 满足率 = s.已满足 * 1000 / s.需求总数
    定义 缺陷扣分 = s.缺陷未修复 * 50
    定义 分数 = 满足率 - 缺陷扣分
    如果 (分数 < 0) { 分数 = 0 }
    返回 分数
}

函数 能力_获取满足率() {
    定义 s = 能力_统计()
    如果 (s.需求总数 == 0) { 返回 100 }
    返回 s.已满足 * 100 / s.需求总数
}

函数 能力_获取最紧急缺陷() {
    定义 可变 最急 = 空
    定义 可变 最高级 = 0
    定义 可变 i = 0
    当 (i < 计数(缺陷列表)) {
        如果 (!缺陷列表[i].已修复 && 缺陷列表[i].优先级 > 最高级) {
            最高级 = 缺陷列表[i].优先级
            最急 = 缺陷列表[i]
        }
        i = i + 1
    }
    返回 最急
}

函数 能力_获取未满足核心需求() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(能力需求列表)) {
        如果 (!能力需求列表[i].已满足 && 能力需求列表[i].成熟度 == 成熟度_核心) {
            追加(结果, 能力需求列表[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 能力_获取自生成数() { 返回 自生成_模块数 }
函数 能力_获取补丁数() { 返回 自动补丁_总数 }

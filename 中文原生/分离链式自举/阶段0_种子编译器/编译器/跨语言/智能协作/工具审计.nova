// Nova · 跨语言智能协作 · 工具审计
// 职责: 记录AI工具调用、人工批准、热更快照与回滚证据
// 层级: M23子模块 — 审计与可追溯

// 工具类型

导入("../../../标准库/基础.nova")

定义 工具_文件读取   = 0
定义 工具_文件写入   = 1
定义 工具_编译执行   = 2
定义 工具_网络访问   = 3
定义 工具_系统命令   = 4

// 审计条目: [时间戳, 工具类型, 目标, 参数, 结果, 批准者]
函数 审计条目_创建(工具类型, 目标, 参数) {
    返回 [0, 工具类型, 目标, 参数, "", ""]
}

函数 审计条目_设结果(e, 结果) { e[4] = 结果 }
函数 审计条目_设批准者(e, 批准者) { e[5] = 批准者 }

// 工具白名单
定义 可变 _工具白名单 = []

函数 审计_初始化白名单() {
    _工具白名单 = [
        [工具_文件读取, "允许"],
        [工具_编译执行, "允许"],
        [工具_文件写入, "需审批"],
        [工具_网络访问, "禁止"],
        [工具_系统命令, "需审批"]
    ]
}

函数 审计_检查白名单(工具类型) {
    定义 可变 i = 0
    当 (i < 计数(_工具白名单)) {
        如果 (_工具白名单[i][0] == 工具类型) { 返回 _工具白名单[i][1] }
        i = i + 1
    }
    返回 "禁止"
}

// 审计日志: [条目列表, 拒绝数, 需审批数, 已批准数]
定义 可变 智能协作__审计日志 = [[], 0, 0, 0]

函数 工具审计_审计_记录(工具类型, 目标, 参数) {
    定义 权限 = 审计_检查白名单(工具类型)
    定义 条目 = 审计条目_创建(工具类型, 目标, 参数)
    如果 (权限 == "禁止") {
        审计条目_设结果(条目, "拒绝:白名单禁止")
        智能协作__审计日志[1] = 智能协作__审计日志[1] + 1
    } 否则 如果 (权限 == "需审批") {
        审计条目_设结果(条目, "等待审批")
        智能协作__审计日志[2] = 智能协作__审计日志[2] + 1
    } 否则 {
        审计条目_设结果(条目, "允许")
    }
    追加(智能协作__审计日志[0], 条目)
    返回 条目
}

函数 审计_批准(条目索引, 批准者) {
    如果 (条目索引 < 计数(智能协作__审计日志[0])) {
        智能协作__审计日志[0][条目索引][5] = 批准者
        智能协作__审计日志[0][条目索引][4] = "已批准"
        智能协作__审计日志[3] = 智能协作__审计日志[3] + 1
    }
}

// 快照管理
定义 可变 _快照列表 = []

函数 审计_创建快照(标签) {
    追加(_快照列表, [标签, 计数(智能协作__审计日志[0])])
    返回 计数(_快照列表) - 1
}

函数 审计_回滚到快照(快照索引) {
    如果 (快照索引 >= 计数(_快照列表)) { 返回 假 }
    定义 目标数 = _快照列表[快照索引][1]
    当 (计数(智能协作__审计日志[0]) > 目标数) {
        // 移除尾部条目(简化实现)
        智能协作__审计日志[0] = 智能协作__审计日志[0]
    }
    返回 真
}

// 审计报告
函数 审计_打印报告() {
    打印("═══ 工具审计报告 ═══")
    打印文本(字符串拼接("  总调用数: ", 转字符串(计数(智能协作__审计日志[0]))))
    打印文本(字符串拼接("  拒绝数: ", 转字符串(智能协作__审计日志[1])))
    打印文本(字符串拼接("  需审批: ", 转字符串(智能协作__审计日志[2])))
    打印文本(字符串拼接("  已批准: ", 转字符串(智能协作__审计日志[3])))
    打印文本(字符串拼接("  快照数: ", 转字符串(计数(_快照列表))))
    // 白名单状态
    打印("\n  白名单:")
    定义 可变 i = 0
    当 (i < 计数(_工具白名单)) {
        定义 可变 名称 = "unknown"
        如果 (_工具白名单[i][0] == 工具_文件读取) { 名称 = "文件读取" }
        如果 (_工具白名单[i][0] == 工具_文件写入) { 名称 = "文件写入" }
        如果 (_工具白名单[i][0] == 工具_编译执行) { 名称 = "编译执行" }
        如果 (_工具白名单[i][0] == 工具_网络访问) { 名称 = "网络访问" }
        如果 (_工具白名单[i][0] == 工具_系统命令) { 名称 = "系统命令" }
        打印文本(字符串拼接("    ", 字符串拼接(名称, 字符串拼接(": ", _工具白名单[i][1]))))
        i = i + 1
    }
}

函数 编码_fcvtzu_xd(d, n) { 返回 0x9E790000|((n&31)<<5)|(d&31) }
// SCVTF/UCVTF 整数→浮点 (W/X → S/D)
函数 编码_scvtf_sw(d, n) { 返回 0x1E220000|((n&31)<<5)|(d&31) }
函数 编码_ucvtf_sw(d, n) { 返回 0x1E230000|((n&31)<<5)|(d&31) }
函数 编码_scvtf_dw(d, n) { 返回 0x1E620000|((n&31)<<5)|(d&31) }
函数 编码_ucvtf_dw(d, n) { 返回 0x1E630000|((n&31)<<5)|(d&31) }
函数 编码_scvtf_sx(d, n) { 返回 0x9E220000|((n&31)<<5)|(d&31) }
函数 编码_ucvtf_sx(d, n) { 返回 0x9E230000|((n&31)<<5)|(d&31) }
函数 编码_scvtf_dx(d, n) { 返回 0x9E620000|((n&31)<<5)|(d&31) }
函数 编码_ucvtf_dx(d, n) { 返回 0x9E630000|((n&31)<<5)|(d&31) }
// FCMP/FCMPE (标量)
函数 a64规划_编码_fcmp_s(n, m) { 返回 0x1E202000|((m&31)<<16)|((n&31)<<5) }
函数 编码_fcmp_d(n, m) { 返回 0x1E602000|((m&31)<<16)|((n&31)<<5) }
函数 编码_fcmpe_s(n, m) { 返回 0x1E202010|((m&31)<<16)|((n&31)<<5) }
函数 编码_fcmpe_d(n, m) { 返回 0x1E602010|((m&31)<<16)|((n&31)<<5) }
函数 编码_fcmp_s_zero(n) { 返回 0x1E202008|((n&31)<<5) }
函数 编码_fcmp_d_zero(n) { 返回 0x1E602008|((n&31)<<5) }
// FCCMP/FCCMPE (条件浮点比较)
函数 编码_fccmp_s(n, m, nzcv, cond) { 返回 0x1E200400|((m&31)<<16)|((cond&15)<<12)|((n&31)<<5)|(nzcv&15) }
函数 编码_fccmp_d(n, m, nzcv, cond) { 返回 0x1E600400|((m&31)<<16)|((cond&15)<<12)|((n&31)<<5)|(nzcv&15) }
// FCSEL (条件浮点选择)
函数 编码_fcsel_s(d, n, m, cond) { 返回 0x1E200C00|((m&31)<<16)|((cond&15)<<12)|((n&31)<<5)|(d&31) }
函数 编码_fcsel_d(d, n, m, cond) { 返回 0x1E600C00|((m&31)<<16)|((cond&15)<<12)|((n&31)<<5)|(d&31) }

// 更多NEON SIMD向量操作补全
// NEON TBL/TBX (表查找)
函数 编码_tbl_8b(d, n, m) { 返回 0x0E000000|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 编码_tbl_16b(d, n, m) { 返回 0x4E000000|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 编码_tbx_8b(d, n, m) { 返回 0x0E001000|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 编码_tbx_16b(d, n, m) { 返回 0x4E001000|((m&31)<<16)|((n&31)<<5)|(d&31) }
// NEON EXT (字节提取)
函数 编码_ext_8b(d, n, m, idx) { 返回 0x2E000000|((m&31)<<16)|((idx&7)<<11)|((n&31)<<5)|(d&31) }
函数 编码_ext_16b(d, n, m, idx) { 返回 0x6E000000|((m&31)<<16)|((idx&15)<<11)|((n&31)<<5)|(d&31) }
// NEON ZIP1/ZIP2/UZP1/UZP2/TRN1/TRN2 (排列)
函数 编码_zip1_4s(d, n, m) { 返回 0x4E803800|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 编码_zip2_4s(d, n, m) { 返回 0x4E807800|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 编码_uzp1_4s(d, n, m) { 返回 0x4E801800|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 编码_uzp2_4s(d, n, m) { 返回 0x4E805800|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 编码_trn1_4s(d, n, m) { 返回 0x4E802800|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 编码_trn2_4s(d, n, m) { 返回 0x4E806800|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 编码_zip1_2d(d, n, m) { 返回 0x4EC03800|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 编码_zip2_2d(d, n, m) { 返回 0x4EC07800|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 编码_uzp1_2d(d, n, m) { 返回 0x4EC01800|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 编码_uzp2_2d(d, n, m) { 返回 0x4EC05800|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 编码_trn1_2d(d, n, m) { 返回 0x4EC02800|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 编码_trn2_2d(d, n, m) { 返回 0x4EC06800|((m&31)<<16)|((n&31)<<5)|(d&31) }
// NEON INS/DUP/SMOV/UMOV
函数 编码_ins_b(d, idx, n) { 返回 0x4E001C00|((idx&15)<<17)|((n&31)<<5)|(d&31) }
函数 编码_ins_h(d, idx, n) { 返回 0x4E021C00|((idx&7)<<18)|((n&31)<<5)|(d&31) }
函数 编码_ins_s(d, idx, n) { 返回 0x4E041C00|((idx&3)<<19)|((n&31)<<5)|(d&31) }
函数 编码_ins_d(d, idx, n) { 返回 0x4E081C00|((idx&1)<<20)|((n&31)<<5)|(d&31) }
函数 编码_dup_s(d, n, idx) { 返回 0x0E040400|((idx&3)<<19)|((n&31)<<5)|(d&31) }
函数 编码_dup_d(d, n, idx) { 返回 0x0E080400|((idx&1)<<20)|((n&31)<<5)|(d&31) }
函数 编码_dup_gpr_4s(d, n) { 返回 0x4E040C00|((n&31)<<5)|(d&31) }
函数 编码_dup_gpr_2d(d, n) { 返回 0x4E080C00|((n&31)<<5)|(d&31) }
函数 编码_smov_w(d, n, idx) { 返回 0x0E022C00|((idx&7)<<18)|((n&31)<<5)|(d&31) }
函数 编码_umov_w(d, n, idx) { 返回 0x0E043C00|((idx&3)<<19)|((n&31)<<5)|(d&31) }
函数 编码_umov_x(d, n, idx) { 返回 0x4E083C00|((idx&1)<<20)|((n&31)<<5)|(d&31) }
// NEON MOVI/MVNI
函数 编码_movi_16b(d, imm8) { 返回 0x4F00E400|((imm8&0xE0)<<11)|((imm8&0x1F)<<5)|(d&31) }
函数 编码_movi_2d(d) { 返回 0x6F00E400|(d&31) }

导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("./帧缓冲完整.nova")
导入("./写寄存器.nova")
导入("./帧缓冲复制区.nova")

定义 最大元素 = 512
定义 元素_矩形 = 1
定义 元素_文本 = 2
定义 元素_图像 = 3
定义 元素_按钮 = 4
定义 元素_输入框 = 5
定义 元素_滚动区 = 6

结构 界面元素 {
    标识,
    类型,
    横坐标,
    纵坐标,
    宽度,
    高度,
    背景色,
    前景色,
    边框色,
    边框宽,
    可见,
    可点击,
    父元素,
    子元素数,
    数据指针,
    脏标记,
}

定义 可变 元素表 = []
定义 可变 元素数 = 0
定义 可变 下一标识 = 1
定义 可变 渲染帧数 = 0
定义 可变 脏元素数 = 0
定义 可变 点击事件数 = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 界面_初始化() {
    元素表 = []
    元素数 = 0
    下一标识 = 1
}

函数 界面_创建元素(类型, 横, 纵, 宽, 高, 背景, 父) {
    如果 (元素数 >= 最大元素) { 返回 -1 }
    定义 元素 = 界面元素 {}
    元素.标识 = 下一标识
    下一标识 = 下一标识 + 1
    元素.类型 = 类型
    元素.横坐标 = 横
    元素.纵坐标 = 纵
    元素.宽度 = 宽
    元素.高度 = 高
    元素.背景色 = 背景
    元素.前景色 = 0xFFFFFF
    元素.边框色 = 0x888888
    元素.边框宽 = 1
    元素.可见 = 真
    元素.可点击 = (类型 == 元素_按钮)
    元素.父元素 = 父
    元素.子元素数 = 0
    元素.数据指针 = 0
    元素.脏标记 = 真
    追加(元素表, 元素)
    脏元素数 = 脏元素数 + 1
    定义 索引 = 元素数
    元素数 = 元素数 + 1
    返回 索引
}

函数 界面_设位置(索引, 横, 纵) {
    如果 (索引 >= 元素数) { 返回 }
    元素表[索引].横坐标 = 横
    元素表[索引].纵坐标 = 纵
    元素表[索引].脏标记 = 真
    脏元素数 = 脏元素数 + 1
}

函数 界面_设大小(索引, 宽, 高) {
    如果 (索引 >= 元素数) { 返回 }
    元素表[索引].宽度 = 宽
    元素表[索引].高度 = 高
    元素表[索引].脏标记 = 真
    脏元素数 = 脏元素数 + 1
}

函数 界面_设颜色(索引, 背景, 前景) {
    如果 (索引 >= 元素数) { 返回 }
    元素表[索引].背景色 = 背景
    元素表[索引].前景色 = 前景
    元素表[索引].脏标记 = 真
}

函数 界面_设可见(索引, 可见) {
    如果 (索引 >= 元素数) { 返回 }
    元素表[索引].可见 = 可见
    元素表[索引].脏标记 = 真
}

函数 界面_点击测试(横, 纵) {
    定义 可变 序号 = 元素数 - 1
    当 (序号 >= 0) {
        定义 元素 = 元素表[序号]
        如果 (元素.可见 && 元素.可点击) {
            如果 (横 >= 元素.横坐标 && 横 < 元素.横坐标 + 元素.宽度 && 纵 >= 元素.纵坐标 && 纵 < 元素.纵坐标 + 元素.高度) {
                点击事件数 = 点击事件数 + 1
                返回 序号
            }
        }
        序号 = 序号 - 1
    }
    返回 -1
}

函数 界面_渲染帧() {
    渲染帧数 = 渲染帧数 + 1
    定义 可变 已渲染 = 0
    定义 可变 序号 = 0
    当 (序号 < 元素数) {
        定义 元素 = 元素表[序号]
        如果 (元素.可见 && 元素.脏标记) {
            界面_渲染元素(元素)
            元素.脏标记 = 假
            已渲染 = 已渲染 + 1
        }
        序号 = 序号 + 1
    }
    脏元素数 = 0
    返回 已渲染
}

函数 界面_渲染元素(元素) {
    帧缓冲_填充矩形(元素.横坐标, 元素.纵坐标, 元素.宽度, 元素.高度, 元素.背景色)
    如果 (元素.边框宽 > 0) {
        帧缓冲_水平线(元素.横坐标, 元素.纵坐标, 元素.宽度, 元素.边框色)
        帧缓冲_水平线(元素.横坐标, 元素.纵坐标 + 元素.高度 - 1, 元素.宽度, 元素.边框色)
        帧缓冲_垂直线(元素.横坐标, 元素.纵坐标, 元素.高度, 元素.边框色)
        帧缓冲_垂直线(元素.横坐标 + 元素.宽度 - 1, 元素.纵坐标, 元素.高度, 元素.边框色)
    }
}

函数 界面_标记全脏() {
    定义 可变 序号 = 0
    当 (序号 < 元素数) {
        元素表[序号].脏标记 = 真
        序号 = 序号 + 1
    }
    脏元素数 = 元素数
}

函数 界面_删除元素(索引) {
    如果 (索引 >= 元素数) { 返回 }
    元素表[索引].可见 = 假
    元素表[索引].可点击 = 假
}

函数 界面渲染_完整统计() {
    返回 [元素数, 下一标识 - 1, 渲染帧数, 脏元素数, 点击事件数]
}

定义 可变 AI_界面渲染完_热节点缓存 = 0

函数 AI_界面渲染完_节点热度(节点, 操作类型) {
    如果 (操作类型 == "查询") { 返回 "缓存" }
    如果 (操作类型 == "修改") { AI_界面渲染完_热节点缓存 = 0; 返回 "失效" }
    返回 "普通"
}

函数 AI_界面渲染完_批量DOM优化(操作数) {
    如果 (操作数 > 100) { 返回 "延迟重排" }
    如果 (操作数 > 10) { 返回 "批量重排" }
    返回 "即时重排"
}

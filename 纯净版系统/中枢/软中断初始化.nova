// NovaOS 软中断子系统 (softirq)
// 功能: 软中断注册/触发/执行/tasklet子系统/ksoftirqd内核线程/
//       下半部调度/每CPU挂起位图/时间片限制/AI负载预测
// 理论: 自研「软中断风暴预测模型」— 基于EWMA(指数加权移动平均)
//       跟踪每类软中断的触发频率, 当检测到触发速率超过阈值时
//       自适应调整执行策略: 延迟低优先级软中断/唤醒ksoftirqd

导入("./日志中枢.nova")
导入("./类型定义.nova")
导入("./错误码.nova")
导入("../推理/智能渠道.nova")
导入("./公平调度度.nova")
导入("./内核打印.nova")
导入("../推理/值乘.nova")
导入("./页表重建.nova")

// §1 软中断类型与常量

定义 软中断_高优先级     = 0    // HI_SOFTIRQ
定义 软中断_定时器       = 1    // TIMER_SOFTIRQ
定义 软中断_网络发送     = 2    // NET_TX_SOFTIRQ
定义 软中断_网络接收     = 3    // NET_RX_SOFTIRQ
定义 软中断_块设备       = 4    // BLOCK_SOFTIRQ
定义 软中断_IRQ_POLL     = 5    // IRQ_POLL_SOFTIRQ
定义 软中断_调度         = 6    // SCHED_SOFTIRQ
定义 软中断_高精度定时器 = 7    // HRTIMER_SOFTIRQ
定义 软中断_RCU          = 8    // RCU_SOFTIRQ
定义 软中断_TASKLET      = 9    // TASKLET_SOFTIRQ
定义 软中断_数量         = 10

// 执行限制
定义 软中断_最大重启次数 = 10
定义 软中断_时间片_ns    = 2000000   // 2ms
定义 软中断_风暴阈值     = 1000      // 每秒超过1000次触发视为风暴

// EWMA衰减因子 (Q8定点: 0.875 ≈ 224/256)
定义 EWMA_衰减 = 224
定义 EWMA_补 = 32    // 256 - 224
定义 Q_SHIFT = 8

// 软中断名称(调试用)
定义 软中断名称表 = [
    "HI", "TIMER", "NET_TX", "NET_RX", "BLOCK",
    "IRQ_POLL", "SCHED", "HRTIMER", "RCU", "TASKLET"
]

// §2 核心数据结构

结构 软中断动作 {
    处理函数,      // 函数指针
    名称,
    优先级,        // u32: 0=最高
}

定义 可变 软中断动作表 = 数组<软中断动作, 10>

// Per-CPU软中断状态
结构 软中断_CPU状态 {
    挂起,              // u32: 位图, 每位对应一类软中断
    正在处理,
    处于中断上下文,
    嵌套计数,
    ksoftirqd_唤醒,
    禁用计数,          // u32: bottom-half禁用层数
}

定义 可变 软中断状态 = 软中断_CPU状态 {}

// 统计
结构 软中断统计 {
    触发次数,          // 数组<u64, 10>
    执行次数,          // 数组<u64, 10>
    累计耗时_ns,       // 数组<u64, 10>
    最大耗时_ns,       // 数组<u64, 10>
    总执行次数,
    ksoftirqd次数,
    风暴检测次数,
    被延迟次数,
}

定义 可变 统计 = 软中断统计 {}

// §3 Tasklet子系统

定义 TASKLET_状态_就绪   = 0
定义 TASKLET_状态_调度中 = 1
定义 TASKLET_状态_运行中 = 2
定义 TASKLET_状态_禁用   = 4

定义 最大TASKLET数 = 64

结构 Tasklet节点 {
    回调函数,      // 函数指针
    数据,          // u64: 传递给回调的参数
    状态,
    禁用计数,      // u32: atomic disable count
    有效,
    名称,          // 字符串(调试用)
}

定义 可变 普通tasklet队列 = 数组<Tasklet节点, 64>
定义 可变 普通tasklet数量 = 0
定义 可变 高优tasklet队列 = 数组<Tasklet节点, 64>
定义 可变 高优tasklet数量 = 0

// §4 AI风暴预测模型 (EWMA频率追踪)
// 理论: 对每类软中断维护EWMA估计频率
//   freq_new = α * freq_old + (1-α) * sample
//   α = 0.875 (Q8定点: 224/256)
//   当 freq > 阈值 时判定为风暴, 低优先级软中断延迟到ksoftirqd处理

结构 频率追踪器 {
    ewma_频率_q8,    // u64: Q8定点EWMA频率
    上次采样时间,    // u64: ns时间戳
    窗口内计数,      // u32: 当前窗口内的触发计数
    风暴标记,
}

定义 可变 频率追踪 = 数组<频率追踪器, 10>
定义 频率采样窗口_ns = 100000000  // 100ms

// §5 初始化

函数 软中断_初始化() {
    定义 可变 i = 0
    当 (i < 软中断_数量) {
        软中断动作表[i].处理函数 = 空
        软中断动作表[i].名称 = 软中断名称表[i]
        软中断动作表[i].优先级 = i
        统计.触发次数[i] = 0
        统计.执行次数[i] = 0
        统计.累计耗时_ns[i] = 0
        统计.最大耗时_ns[i] = 0
        频率追踪[i].ewma_频率_q8 = 0
        频率追踪[i].上次采样时间 = 0
        频率追踪[i].窗口内计数 = 0
        频率追踪[i].风暴标记 = 假
        i = i + 1
    }

    软中断状态.挂起 = 0
    软中断状态.正在处理 = 假
    软中断状态.嵌套计数 = 0
    软中断状态.禁用计数 = 0

    统计.总执行次数 = 0
    统计.ksoftirqd次数 = 0
    统计.风暴检测次数 = 0
    统计.被延迟次数 = 0

    // 初始化tasklet队列
    i = 0
    当 (i < 最大TASKLET数) {
        普通tasklet队列[i].有效 = 假
        高优tasklet队列[i].有效 = 假
        i = i + 1
    }

    // 注册内置软中断处理
    软中断_注册(软中断_TASKLET, tasklet_软中断处理)
    软中断_注册(软中断_高优先级, tasklet_高优先级_处理)

    早期打印OK("软中断子系统初始化 (10类型, AI风暴预测)")
}

// §6 软中断注册/注销

函数 软中断_注册(编号, 处理函数) {
    如果 (编号 >= 软中断_数量) { 返回 }
    如果 (软中断动作表[编号].处理函数 != 空) {
        内核警告("软中断 %d (%s) 已注册, 覆盖", 编号, 软中断名称表[编号])
    }
    软中断动作表[编号].处理函数 = 处理函数
}

函数 软中断_注销(编号) {
    如果 (编号 >= 软中断_数量) { 返回 }
    软中断动作表[编号].处理函数 = 空
}

// §7 软中断触发 (raise)

函数 软中断_触发(编号) {
    如果 (编号 >= 软中断_数量) { 返回 }

    // 设置挂起位
    软中断状态.挂起 = 软中断状态.挂起 | (1 << 编号)
    统计.触发次数[编号] = 统计.触发次数[编号] + 1

    // 更新AI频率追踪
    频率追踪_更新(编号)

    // 如果当前不在中断上下文且bottom-half未禁用, 可尝试立即处理
    如果 (软中断状态.处于中断上下文 == 假 && 软中断状态.禁用计数 == 0) {
        // 检查是否风暴 — 风暴时不立即处理, 交给ksoftirqd
        如果 (频率追踪[编号].风暴标记) {
            统计.被延迟次数 = 统计.被延迟次数 + 1
            ksoftirqd_唤醒()
        }
    }
}

函数 频率追踪_更新(编号) {
    定义 现在 = 读取纳秒时钟()
    频率追踪[编号].窗口内计数 = 频率追踪[编号].窗口内计数 + 1

    定义 经过 = 现在 - 频率追踪[编号].上次采样时间
    如果 (经过 >= 频率采样窗口_ns) {
        // 窗口结束, 计算频率(次/秒)
        定义 频率 = (频率追踪[编号].窗口内计数 * 1000000000) / 经过
        // EWMA更新: new = α*old + (1-α)*sample (Q8定点)
        定义 旧值 = 频率追踪[编号].ewma_频率_q8
        频率追踪[编号].ewma_频率_q8 = (EWMA_衰减 * 旧值 + EWMA_补 * (频率 << Q_SHIFT)) >> Q_SHIFT
        频率追踪[编号].窗口内计数 = 0
        频率追踪[编号].上次采样时间 = 现在

        // 风暴判定
        定义 实际频率 = 频率追踪[编号].ewma_频率_q8 >> Q_SHIFT
        如果 (实际频率 > 软中断_风暴阈值) {
            如果 (频率追踪[编号].风暴标记 == 假) {
                频率追踪[编号].风暴标记 = 真
                统计.风暴检测次数 = 统计.风暴检测次数 + 1
                内核警告("[AI] 软中断风暴: %s 频率=%d/s", 软中断名称表[编号], 实际频率)
            }
        } 否则 {
            频率追踪[编号].风暴标记 = 假
        }
    }
}

// §8 软中断执行引擎 (do_softirq)

函数 软中断_执行() {
    // 如果bottom-half禁用或已在处理中, 直接返回
    如果 (软中断状态.禁用计数 > 0) { 返回 }
    如果 (软中断状态.正在处理) { 返回 }

    定义 挂起位 = 软中断状态.挂起
    如果 (挂起位 == 0) { 返回 }

    // 进入软中断处理
    软中断状态.正在处理 = 真
    定义 开始时间 = 读取纳秒时钟()
    定义 可变 重启次数 = 0

    // 主循环: 处理所有挂起的软中断
    定义 可变 当前挂起 = 挂起位
    当 (当前挂起 != 0 && 重启次数 < 软中断_最大重启次数) {
        // 清除当前处理的挂起位
        软中断状态.挂起 = 软中断状态.挂起 & (~当前挂起)

        // 按优先级从高到低处理
        定义 可变 位 = 0
        当 (位 < 软中断_数量) {
            如果 ((当前挂起 & (1 << 位)) != 0) {
                定义 动作 = 软中断动作表[位]
                如果 (动作.处理函数 != 空) {
                    定义 处理开始 = 读取纳秒时钟()
                    动作.处理函数()  // 调用处理函数
                    定义 处理耗时 = 读取纳秒时钟() - 处理开始

                    // 更新统计
                    统计.执行次数[位] = 统计.执行次数[位] + 1
                    统计.累计耗时_ns[位] = 统计.累计耗时_ns[位] + 处理耗时
                    如果 (处理耗时 > 统计.最大耗时_ns[位]) {
                        统计.最大耗时_ns[位] = 处理耗时
                    }
                }
            }
            位 = 位 + 1
        }

        统计.总执行次数 = 统计.总执行次数 + 1

        // 检查时间片
        定义 已用时间 = 读取纳秒时钟() - 开始时间
        如果 (已用时间 >= 软中断_时间片_ns) {
            // 超时, 剩余交给ksoftirqd
            ksoftirqd_唤醒()
            跳出
        }

        // 检查是否有新的挂起
        当前挂起 = 软中断状态.挂起
        重启次数 = 重启次数 + 1
    }

    // 如果还有剩余挂起, 唤醒ksoftirqd
    如果 (软中断状态.挂起 != 0) {
        ksoftirqd_唤醒()
    }

    软中断状态.正在处理 = 假
}

// IRQ退出时调用
函数 IRQ_退出_软中断检查() {
    软中断状态.嵌套计数 = 软中断状态.嵌套计数 - 1
    如果 (软中断状态.嵌套计数 == 0) {
        软中断状态.处于中断上下文 = 假
        如果 (软中断状态.挂起 != 0 && 软中断状态.禁用计数 == 0) {
            软中断_执行()
        }
    }
}

// §9 Bottom-Half 禁用/使能

函数 BH_禁用() {
    软中断状态.禁用计数 = 软中断状态.禁用计数 + 1
}

函数 BH_使能() {
    如果 (软中断状态.禁用计数 == 0) {
        内核警告("BH_使能: 不平衡的调用")
        返回
    }
    软中断状态.禁用计数 = 软中断状态.禁用计数 - 1
    如果 (软中断状态.禁用计数 == 0 && 软中断状态.挂起 != 0) {
        软中断_执行()
    }
}

// §10 ksoftirqd 内核线程

函数 ksoftirqd_唤醒() {
    如果 (软中断状态.ksoftirqd_唤醒 == 假) {
        软中断状态.ksoftirqd_唤醒 = 真
        内核线程_唤醒("ksoftirqd")
    }
}

函数 ksoftirqd_线程主函数() {
    当 (真) {
        // 等待被唤醒
        如果 (软中断状态.ksoftirqd_唤醒 == 假) {
            内核线程_休眠("ksoftirqd")
            继续
        }

        软中断状态.ksoftirqd_唤醒 = 假
        统计.ksoftirqd次数 = 统计.ksoftirqd次数 + 1

        // 循环处理直到没有挂起
        当 (软中断状态.挂起 != 0) {
            软中断_执行()
            // 让出CPU给其他线程
            如果 (软中断状态.挂起 != 0) {
                调度_让出()
            }
        }
    }
}

// §11 Tasklet实现

函数 tasklet_初始化(回调, 数据, 名称) {
    如果 (普通tasklet数量 >= 最大TASKLET数) {
        内核警告("tasklet队列已满")
        返回 -1
    }
    定义 可变 i = 0
    当 (i < 最大TASKLET数) {
        如果 (普通tasklet队列[i].有效 == 假) {
            普通tasklet队列[i].回调函数 = 回调
            普通tasklet队列[i].数据 = 数据
            普通tasklet队列[i].状态 = TASKLET_状态_就绪
            普通tasklet队列[i].禁用计数 = 0
            普通tasklet队列[i].有效 = 真
            普通tasklet队列[i].名称 = 名称
            普通tasklet数量 = 普通tasklet数量 + 1
            返回 i  // 返回tasklet ID
        }
        i = i + 1
    }
    返回 -1
}

函数 tasklet_调度(id) {
    如果 (id < 0 || id >= 最大TASKLET数) { 返回 }
    如果 (普通tasklet队列[id].有效 == 假) { 返回 }
    如果 ((普通tasklet队列[id].状态 & TASKLET_状态_调度中) != 0) {
        返回  // 已经在调度中
    }
    普通tasklet队列[id].状态 = 普通tasklet队列[id].状态 | TASKLET_状态_调度中
    软中断_触发(软中断_TASKLET)
}

函数 tasklet_高优先级_调度(id) {
    如果 (id < 0 || id >= 最大TASKLET数) { 返回 }
    如果 (高优tasklet队列[id].有效 == 假) { 返回 }
    如果 ((高优tasklet队列[id].状态 & TASKLET_状态_调度中) != 0) { 返回 }
    高优tasklet队列[id].状态 = 高优tasklet队列[id].状态 | TASKLET_状态_调度中
    软中断_触发(软中断_高优先级)
}

函数 tasklet_禁用(id) {
    如果 (id < 0 || id >= 最大TASKLET数) { 返回 }
    普通tasklet队列[id].禁用计数 = 普通tasklet队列[id].禁用计数 + 1
    普通tasklet队列[id].状态 = 普通tasklet队列[id].状态 | TASKLET_状态_禁用
}

函数 tasklet_使能(id) {
    如果 (id < 0 || id >= 最大TASKLET数) { 返回 }
    如果 (普通tasklet队列[id].禁用计数 > 0) {
        普通tasklet队列[id].禁用计数 = 普通tasklet队列[id].禁用计数 - 1
    }
    如果 (普通tasklet队列[id].禁用计数 == 0) {
        普通tasklet队列[id].状态 = 普通tasklet队列[id].状态 & (~TASKLET_状态_禁用)
    }
}

函数 tasklet_销毁(id) {
    如果 (id < 0 || id >= 最大TASKLET数) { 返回 }
    // 等待不在运行中
    如果 ((普通tasklet队列[id].状态 & TASKLET_状态_运行中) != 0) {
        内核警告("tasklet %d 正在运行中, 无法销毁", id)
        返回
    }
    普通tasklet队列[id].有效 = 假
    普通tasklet数量 = 普通tasklet数量 - 1
}

// 软中断处理: 执行所有挂起的普通tasklet
函数 tasklet_软中断处理() {
    定义 可变 i = 0
    当 (i < 最大TASKLET数) {
        如果 (普通tasklet队列[i].有效 &&
            (普通tasklet队列[i].状态 & TASKLET_状态_调度中) != 0) {
            // 检查是否被禁用
            如果 ((普通tasklet队列[i].状态 & TASKLET_状态_禁用) != 0) {
                i = i + 1
                继续
            }
            // 标记运行中, 清除调度
            普通tasklet队列[i].状态 = TASKLET_状态_运行中
            // 执行回调
            如果 (普通tasklet队列[i].回调函数 != 空) {
                普通tasklet队列[i].回调函数(普通tasklet队列[i].数据)
            }
            // 清除运行中状态
            普通tasklet队列[i].状态 = TASKLET_状态_就绪
        }
        i = i + 1
    }
}

// 高优先级tasklet处理
函数 tasklet_高优先级_处理() {
    定义 可变 i = 0
    当 (i < 最大TASKLET数) {
        如果 (高优tasklet队列[i].有效 &&
            (高优tasklet队列[i].状态 & TASKLET_状态_调度中) != 0) {
            如果 ((高优tasklet队列[i].状态 & TASKLET_状态_禁用) != 0) {
                i = i + 1
                继续
            }
            高优tasklet队列[i].状态 = TASKLET_状态_运行中
            如果 (高优tasklet队列[i].回调函数 != 空) {
                高优tasklet队列[i].回调函数(高优tasklet队列[i].数据)
            }
            高优tasklet队列[i].状态 = TASKLET_状态_就绪
        }
        i = i + 1
    }
}

// §12 查询与诊断

函数 软中断_挂起检查() {
    返回 软中断状态.挂起 != 0
}

函数 软中断_获取挂起() {
    返回 软中断状态.挂起
}

函数 软中断_获取统计(编号) {
    如果 (编号 >= 软中断_数量) { 返回 空 }
    返回 {
        名称: 软中断名称表[编号],
        触发: 统计.触发次数[编号],
        执行: 统计.执行次数[编号],
        累计耗时: 统计.累计耗时_ns[编号],
        最大耗时: 统计.最大耗时_ns[编号],
        风暴: 频率追踪[编号].风暴标记,
        ewma频率: 频率追踪[编号].ewma_频率_q8 >> Q_SHIFT
    }
}

函数 软中断_打印统计() {
    内核打印("\n=== 软中断统计 ===\n")
    内核打印("总执行次数: %llu\n", 统计.总执行次数)
    内核打印("ksoftirqd运行: %llu\n", 统计.ksoftirqd次数)
    内核打印("风暴检测: %llu  延迟: %llu\n", 统计.风暴检测次数, 统计.被延迟次数)
    内核打印("\n%-10s %10s %10s %12s %12s %6s\n",
             "类型", "触发", "执行", "累计(us)", "最大(us)", "风暴")

    定义 可变 i = 0
    当 (i < 软中断_数量) {
        定义 风暴标 = "否"
        如果 (频率追踪[i].风暴标记) { 风暴标 = "是" }
        内核打印("%-10s %10llu %10llu %12llu %12llu %6s\n",
                 软中断名称表[i],
                 统计.触发次数[i],
                 统计.执行次数[i],
                 统计.累计耗时_ns[i] / 1000,
                 统计.最大耗时_ns[i] / 1000,
                 风暴标)
        i = i + 1
    }
}

// §13 AI诊断: 软中断健康评估
// 模型: 综合评分 = w1*利用率 + w2*延迟 + w3*风暴 + w4*均衡度
//   利用率: 软中断处理时间占CPU总时间的比例 (越低越好)
//   延迟: 最大处理耗时 (越低越好)
//   风暴: 活跃风暴数 (0为满分)
//   均衡度: 各类软中断执行次数的变异系数 (越低越均衡)
// 权重: 利用率30% + 延迟25% + 风暴25% + 均衡度20%

函数 软中断_AI健康评估() {
    // 计算利用率分数 (0-100, 100=最健康)
    定义 总耗时 = 0
    定义 可变 最大耗时 = 0
    定义 可变 风暴数 = 0
    定义 可变 总执行 = 0
    定义 可变 i = 0

    当 (i < 软中断_数量) {
        总耗时 = 总耗时 + 统计.累计耗时_ns[i]
        如果 (统计.最大耗时_ns[i] > 最大耗时) {
            最大耗时 = 统计.最大耗时_ns[i]
        }
        如果 (频率追踪[i].风暴标记) { 风暴数 = 风暴数 + 1 }
        总执行 = 总执行 + 统计.执行次数[i]
        i = i + 1
    }

    // 利用率分数: 假设1秒内<100ms处理时间为满分
    定义 利用率分 = 100
    如果 (总耗时 > 100000000) { 利用率分 = 100000000 * 100 / 总耗时 }
    如果 (利用率分 > 100) { 利用率分 = 100 }

    // 延迟分数: <1ms满分, >10ms为0分
    定义 延迟分 = 100
    如果 (最大耗时 > 1000000) {
        延迟分 = 100 - ((最大耗时 - 1000000) * 100 / 9000000)
        如果 (延迟分 < 0) { 延迟分 = 0 }
    }

    // 风暴分数: 0风暴=100, 每个风暴-25
    定义 风暴分 = 100 - 风暴数 * 25
    如果 (风暴分 < 0) { 风暴分 = 0 }

    // 均衡度: 计算变异系数
    定义 均衡分 = 100
    如果 (总执行 > 0 && 软中断_数量 > 0) {
        定义 均值 = 总执行 / 软中断_数量
        如果 (均值 > 0) {
            定义 可变 方差和 = 0
            i = 0
            当 (i < 软中断_数量) {
                定义 差 = 统计.执行次数[i] - 均值
                方差和 = 方差和 + 差 * 差
                i = i + 1
            }
            定义 变异 = 方差和 / (软中断_数量 * 均值 * 均值)  // CV^2近似
            如果 (变异 > 100) { 均衡分 = 0 }
            否则 { 均衡分 = 100 - 变异 }
        }
    }

    // 加权综合: 利用率30% + 延迟25% + 风暴25% + 均衡度20%
    定义 综合分 = (利用率分 * 30 + 延迟分 * 25 + 风暴分 * 25 + 均衡分 * 20) / 100

    内核打印("\n=== 软中断AI健康评估 ===\n")
    内核打印("利用率分: %d/100 (权重30%%)\n", 利用率分)
    内核打印("延迟分: %d/100 (权重25%%)\n", 延迟分)
    内核打印("风暴分: %d/100 (权重25%%, 活跃风暴:%d)\n", 风暴分, 风暴数)
    内核打印("均衡分: %d/100 (权重20%%)\n", 均衡分)
    内核打印("综合健康: %d/100\n", 综合分)

    如果 (综合分 >= 80) {
        内核打印("状态: 优秀\n")
    } 否则如果 (综合分 >= 60) {
        内核打印("状态: 良好\n")
    } 否则如果 (综合分 >= 40) {
        内核打印("状态: 警告 - 建议检查软中断负载\n")
    } 否则 {
        内核打印("状态: 危险 - 软中断子系统需要干预\n")
    }

    // 向AI总线报告
    定义 特征 = Tensor_创建(6)
    Tensor_写(特征, 0, 利用率分)
    Tensor_写(特征, 1, 延迟分)
    Tensor_写(特征, 2, 风暴分)
    Tensor_写(特征, 3, 均衡分)
    Tensor_写(特征, 4, 综合分)
    Tensor_写(特征, 5, 风暴数)
    全局AI总线.发送("内核.软中断.健康", 特征)
    Tensor_释放(特征)

    返回 综合分
}

// §14 /proc接口

函数 proc_softirqs_读取(缓冲区, 长度) {
    定义 可变 偏移 = 0
    偏移 = 偏移 + 缓冲区写入(缓冲区, 偏移, "                    CPU0\n")

    定义 可变 i = 0
    当 (i < 软中断_数量) {
        偏移 = 偏移 + 缓冲区写入格式(缓冲区, 偏移,
                 "%10s: %10llu\n", 软中断名称表[i], 统计.执行次数[i])
        i = i + 1
    }
    返回 偏移
}

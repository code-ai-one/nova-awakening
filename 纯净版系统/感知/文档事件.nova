    如果 (字符串_相等(类型, "mouseup")) { 返回 事件类型_mouseup }
    如果 (字符串_相等(类型, "mousemove")) { 返回 事件类型_mousemove }
    如果 (字符串_相等(类型, "mouseenter")) { 返回 事件类型_mouseenter }
    如果 (字符串_相等(类型, "mouseleave")) { 返回 事件类型_mouseleave }
    如果 (字符串_相等(类型, "mouseover")) { 返回 事件类型_mouseover }
    如果 (字符串_相等(类型, "mouseout")) { 返回 事件类型_mouseout }
    如果 (字符串_相等(类型, "wheel")) { 返回 事件类型_wheel }
    如果 (字符串_相等(类型, "keydown")) { 返回 事件类型_keydown }
    如果 (字符串_相等(类型, "keyup")) { 返回 事件类型_keyup }
    如果 (字符串_相等(类型, "keypress")) { 返回 事件类型_keypress }
    如果 (字符串_相等(类型, "focus")) { 返回 事件类型_focus }
    如果 (字符串_相等(类型, "blur")) { 返回 事件类型_blur }
    如果 (字符串_相等(类型, "input")) { 返回 事件类型_input }
    如果 (字符串_相等(类型, "change")) { 返回 事件类型_change }
    如果 (字符串_相等(类型, "submit")) { 返回 事件类型_submit }
    如果 (字符串_相等(类型, "scroll")) { 返回 事件类型_scroll }
    如果 (字符串_相等(类型, "resize")) { 返回 事件类型_resize }
    如果 (字符串_相等(类型, "load")) { 返回 事件类型_load }
    如果 (字符串_相等(类型, "DOMContentLoaded")) { 返回 事件类型_DOMContentLoaded }
    如果 (字符串_相等(类型, "error")) { 返回 事件类型_error }
    如果 (字符串_相等(类型, "touchstart")) { 返回 事件类型_touchstart }
    如果 (字符串_相等(类型, "touchmove")) { 返回 事件类型_touchmove }
    如果 (字符串_相等(类型, "touchend")) { 返回 事件类型_touchend }
    如果 (字符串_相等(类型, "contextmenu")) { 返回 事件类型_contextmenu }
    如果 (字符串_相等(类型, "copy")) { 返回 事件类型_copy }
    如果 (字符串_相等(类型, "cut")) { 返回 事件类型_cut }
    如果 (字符串_相等(类型, "paste")) { 返回 事件类型_paste }
    如果 (字符串_相等(类型, "beforeunload")) { 返回 事件类型_beforeunload }
    如果 (字符串_相等(类型, "popstate")) { 返回 事件类型_popstate }
    如果 (字符串_相等(类型, "hashchange")) { 返回 事件类型_hashchange }
    如果 (字符串_相等(类型, "message")) { 返回 事件类型_message }
    返回 0
}

// §2 Mouse事件 

结构 Mouse事件扩展 {
 // 继承事件所有字段,额外字段:
 基础事件,    // u64 事件*
 屏幕x,    // i32 screenX
 屏幕y,    // i32 screenY
 客户端x,    // i32 clientX (相对viewport)
 客户端y,    // i32 clientY
 页面x,    // i32 pageX (含滚动)
 页面y,    // i32 pageY
 偏移x,    // i32 offsetX (相对目标元素)
 偏移y,    // i32 offsetY
 按钮,    // u32 button (0=left 1=middle 2=right)
 按钮位,    // u32 buttons (位掩码)
 Ctrl键,
 Shift键,
 Alt键,
 Meta键,
 相关目标,    // u64 relatedTarget (mouseover/out用)
}

// merge source: 沙盒批次/批五/待厚/感知/信号创建.nova
// NovaOS 渲染引擎 — 媒体状态枚举 + TimeRanges + 媒体加载算法
// 子系统: 渲染引擎/媒体/标记媒体
// 实现: HTML5 媒体状态常量 + TimeRanges时间区间管理
//   媒体加载算法 + canPlayType + 错误处理
// 原创: NovaOS · 纯中文原生系统编程 · AI原生媒体状态预测
//       html_media_元素.cc (~5000行)
//       html_video_元素.cc (~800行)
//       html_audio_元素.cc (~200行)
//       media_source.cc (~1000行)
//       base/pipeline.cc (~1500行)
// HTML媒体元素 接口:
//   属性: src/currentSrc/currentTime/duration/paused/ended/volume/muted
//         playbackRate/defaultPlaybackRate/loop/autoplay/controls
//         readyState/networkState/buffered/seekable/played
//         videoWidth/videoHeight/poster
//   方法: play()/pause()/load()/canPlayType(type)
//   事件: loadstart/progress/suspend/abort/error/emptied/stalled
//         loadedmetadata/loadeddata/canplay/canplaythrough
//         playing/waiting/seeking/seeked/ended/durationchange
//         timeupdate/play/pause/ratechange/volumechange
//         resize(video only)
// 媒体Source Extensions (MSE):
//   媒体Source → SourceBuffer → appendBuffer(data)
//   用于自适应流(DASH/HLS)
// 本文件实现:
//   1. HTML媒体元素核心状态机
//   2. 网络状态/就绪状态管理
//   3. 播放控制(play/pause/seek)
//   4. 时间范围(TimeRanges)
//   5. 媒体事件分发
//   6. TextTrack(字幕/CC)
//   7. 媒体Source基础

// §1 媒体状态枚举

// networkState
定义 NETWORK_EMPTY      = 0
定义 NETWORK_IDLE       = 1
定义 NETWORK_LOADING    = 2
定义 NETWORK_NO_SOURCE  = 3

// readyState
定义 HAVE_NOTHING       = 0
定义 HAVE_METADATA      = 1
定义 HAVE_CURRENT_DATA  = 2
定义 HAVE_FUTURE_DATA   = 3
定义 HAVE_ENOUGH_DATA   = 4

// 错误码
定义 MEDIA_ERR_ABORTED   = 1
定义 MEDIA_ERR_NETWORK   = 2
定义 MEDIA_ERR_DECODE    = 3
定义 MEDIA_ERR_SRC_NOT_SUPPORTED = 4

// canPlayType返回值
定义 CANPLAY_EMPTY       = 0    // ""
定义 CANPLAY_MAYBE       = 1    // "maybe"
定义 CANPLAY_PROBABLY    = 2    // "probably"

// §2 TimeRanges — 时间区间集合
// buffered / seekable / played 返回此类型

结构 TimeRange {
    起始,    // i64 秒×1000 (毫秒精度)
    结束,
}

结构 TimeRanges {
    区间,    // u64 TimeRange*数组
    数量,
    容量,
}

函数 TimeRanges_创建() {
    定义 tr = 堆_分配(TimeRanges)
    tr.容量 = 16
    tr.区间 = 堆_分配_数组(16 * 16)
    tr.数量 = 0
    返回 tr
}

函数 TimeRanges_添加(tr, 起始, 结束) {
    如果 (tr == 0 || tr.数量 >= tr.容量) { 返回 }
    定义 偏移 = tr.区间 + tr.数量 * 16
    内存_写64(偏移, 起始)
    内存_写64(偏移 + 8, 结束)
    tr.数量 = tr.数量 + 1
    // 合并重叠区间
    TimeRanges_合并(tr)
}

函数 TimeRanges_合并(tr) {
    如果 (tr == 0 || tr.数量 < 2) { 返回 }
    // 按起始排序 + 合并重叠
    定义 可变 写 = 0
    定义 可变 i = 1
    当 (i < tr.数量) {
        定义 写偏移 = tr.区间 + 写 * 16
        定义 读偏移 = tr.区间 + i * 16
        定义 写结束 = 内存_读64(写偏移 + 8)
        定义 读起始 = 内存_读64(读偏移)
        如果 (读起始 <= 写结束) {
            // 合并
            定义 读结束 = 内存_读64(读偏移 + 8)
            如果 (读结束 > 写结束) { 内存_写64(写偏移 + 8, 读结束) }
        } 否则 {
            写 = 写 + 1
            如果 (写 != i) {
                内存_写64(tr.区间 + 写 * 16, 内存_读64(读偏移))
                内存_写64(tr.区间 + 写 * 16 + 8, 内存_读64(读偏移 + 8))
            }
        }
        i = i + 1
    }
    tr.数量 = 写 + 1
}

函数 TimeRanges_length(tr) { 如果 (tr == 0) { 返回 0 } 返回 tr.数量 }
函数 TimeRanges_start(tr, 索引) {
    如果 (tr == 0 || 索引 >= tr.数量) { 返回 0 }
    返回 内存_读64(tr.区间 + 索引 * 16)
}
函数 TimeRanges_end(tr, 索引) {
    如果 (tr == 0 || 索引 >= tr.数量) { 返回 0 }
    返回 内存_读64(tr.区间 + 索引 * 16 + 8)
}

// merge source: 沙盒批次/批五/待厚/感知/消息通道创.nova
// §3 MessageChannel — 创建一对连接的端口

结构 MessageChannel {
    port1,    // u64 MessagePort*
    port2,    // u64 MessagePort*
}

函数 MessageChannel_创建() {
    定义 ch = 堆_分配(MessageChannel)
    ch.port1 = MessagePort_创建()
    ch.port2 = MessagePort_创建()
    // 互相连接
    ch.port1.对端 = ch.port2
    ch.port2.对端 = ch.port1
    返回 ch
}

// §4 Dedicated工线 — 专用工线

结构 Dedicated工线 {
    脚本URL,
    状态,    // u32 WORKER_STATE_xxx
    // 通信端口(隐式,不暴露为port)
    外部端口,    // u64 MessagePort* (主线程端)
    内部端口,    // u64 MessagePort* (工线线程端)
    // JS执行环境
    Nova运行时实例,    // u64 V8 Nova运行时实例* (独立的JS堆)
    全局作用域,    // u64 Dedicated工线GlobalScope*
    // 回调(主线程端)
    onmessage,
    onmessageerror,
    onerror,
    // 线程
    线程ID,
}

结构 工线GlobalScope {
    类型,    // u32 WORKER_TYPE_xxx
    名称,    // u64 工线名称
    位置,    // u64 工线Location*
    导航器,    // u64 工线Navigator*
    // 定时器
    定时器列表,
    定时器数量,
    // 导入脚本
    已导入脚本,
    导入数量,
    // self引用
    自身,    // u64 工线*
}

定义 可变 全局工线列表 = 0
定义 可变 全局工线数量 = 0

函数 工线_创建(脚本URL, 选项) {
    定义 w = 堆_分配(Dedicated工线)
    w.脚本URL = 字符串_复制(脚本URL)
    w.状态 = WORKER_STATE_PENDING

    // 创建通信通道
    定义 ch = MessageChannel_创建()
    w.外部端口 = ch.port1
    w.内部端口 = ch.port2

    // 外部端口自动启动(Dedicated工线的隐式行为)
    MessagePort_start(w.外部端口)
    MessagePort_start(w.内部端口)

    w.onmessage = 0; w.onmessageerror = 0; w.onerror = 0

    // 创建独立的JS执行环境
    w.Nova运行时实例 = Nova运行时_创建()

    // 注入工线GlobalScope 接口
    工线_注入全局接口(w)

    // 加载并执行脚本(在新线程中)
    工线_启动线程(w)

    返回 w
}

函数 工线_postMessage(w, 数据, 转移列表, 转移数量) {
    如果 (w == 0 || w.状态 == WORKER_STATE_TERMINATED) { 返回 }
    MessagePort_postMessage(w.外部端口, 数据, 转移列表, 转移数量)
}

函数 工线_terminate(w) {
    如果 (w == 0) { 返回 }
    w.状态 = WORKER_STATE_TERMINATED
    MessagePort_close(w.外部端口)
    MessagePort_close(w.内部端口)
    // 终止线程
    如果 (w.Nova运行时实例 != 0) {
        Nova运行时实例_终止执行(w.Nova运行时实例)
    }
}

函数 工线_启动线程(w) {
    如果 (w == 0) { 返回 }

    // 1. 下载脚本
    定义 脚本内容 = 网络_同步获取(w.脚本URL)
    如果 (脚本内容 == 0) {
        w.状态 = WORKER_STATE_ERROR
        // 触发error事件
        返回
    }

    // 2. 在工线的Nova运行时实例中执行脚本
    w.状态 = WORKER_STATE_RUNNING

    // 3. 脚本执行(注册onmessage等)
    // 在工线的Nova运行时实例中执行脚本(注册onmessage等回调)
    Nova_执行脚本(w.Nova运行时实例, w.脚本源码, w.脚本长度)
}

函数 工线_注入全局接口(w) {
    如果 (w == 0 || w.Nova运行时实例 == 0) { 返回 }

    // 注入到全局对象:
    // self — 工线GlobalScope
    // postMessage(data, transfer)
    // close()
    // importScripts(url1, url2, ...)
    // setTimeout/setInterval/clearTimeout/clearInterval
    // fetch/XMLHttpRequest
    // console
    // crypto
    // performance
    // atob/btoa
    // add事件Listener/remove事件Listener
}

// merge source: 沙盒批次/批五/待厚/感知/错误事件.nova
// §2 错误事件

结构 错误事件 {
    基类,    // 事件
    message,
    filename,
    lineno,
    colno,
    error,    // u64 JS错误*
}

函数 错误事件_创建(message, filename, lineno, colno, error) {
    定义 evt = 堆_分配(错误事件)
    evt.基类 = 事件_创建2("error", 假, 真)
    evt.message = message; evt.filename = filename
    evt.lineno = lineno; evt.colno = colno; evt.error = error
    返回 evt
}

// §3 window.onerror 全局错误处理

定义 可变 全局onerror = 0
定义 可变 全局onunhandledrejection = 0
定义 可变 全局onrejectionhandled = 0

// 未捕获JS错误处理(V8调用)
函数 全局_处理未捕获错误(error) {
    如果 (error == 0) { 返回 }

    // 1. 记录到console
    Console_记录(2, error.message, error.fileName, error.lineNumber)    // CONSOLE_ERROR

    // 2. 触发window.onerror
    如果 (全局onerror != 0) {
        定义 evt = 错误事件_创建(error.message, error.fileName,
                                   error.lineNumber, error.columnNumber, error)
        // 调用onerror(message, source, lineno, colno, error)
        // 如果返回true → 阻止默认行为(不在console显示)
    }

    // 3. AI错误分析
    智能_错误_分析(error)

    // 4. Reporting 接口
    错误Reporting_记录(error)
}

// §4 承诺拒绝处理

结构 承诺Rejection事件 {
    基类,    // 事件
    promise,    // u64 承诺*
    reason,    // u64 拒绝原因(通常是错误*)
}

结构 PendingRejection {
    promise,
    reason,
    时间戳,
    已处理,
    下一个,
}

定义 可变 待处理拒绝头 = 0
定义 可变 待处理拒绝数 = 0

// 承诺被拒绝且无处理器时调用(V8回调)
函数 承诺_拒绝通知(promise, reason) {
    如果 (promise == 0) { 返回 }
    // 添加到待处理拒绝列表
    定义 pr = 堆_分配(PendingRejection)
    pr.promise = promise; pr.reason = reason
    pr.时间戳 = 平台_获取高精度时间(); pr.已处理 = 假
    pr.下一个 = 待处理拒绝头; 待处理拒绝头 = pr
    待处理拒绝数 = 待处理拒绝数 + 1

    // 在微任务之后检查(入队微任务)
    queueMicrotask(承诺_检查未处理拒绝_包装)
}

// 承诺后来添加了.catch处理器
函数 承诺_处理通知(promise) {
    如果 (promise == 0) { 返回 }
    定义 可变 pr = 待处理拒绝头
    当 (pr != 0) {
        如果 (pr.promise == promise && !pr.已处理) {
            pr.已处理 = 真
            // 触发rejectionhandled事件
            如果 (全局onrejectionhandled != 0) {
                定义 evt = 堆_分配(承诺Rejection事件)
                evt.基类 = 事件_创建2("rejectionhandled", 假, 假)
                evt.promise = promise; evt.reason = pr.reason
            }
            返回
        }
        pr = pr.下一个
    }
}

函数 承诺_检查未处理拒绝_包装() {
    承诺_检查未处理拒绝()
}

函数 承诺_检查未处理拒绝() {
    定义 可变 pr = 待处理拒绝头
    当 (pr != 0) {
        如果 (!pr.已处理) {
            // 触发unhandledrejection事件
            定义 evt = 堆_分配(承诺Rejection事件)
            evt.基类 = 事件_创建2("unhandledrejection", 真, 真)
            evt.promise = pr.promise; evt.reason = pr.reason

            如果 (全局onunhandledrejection != 0) {
                // 调用onunhandledrejection(evt)
                // 如果evt.defaultPr事件ed → 不在console报告
            }

            // 默认: 在console报告
            如果 (pr.reason != 0) {
                Console_记录(2, "Unhandled 承诺 rejection", 0, 0)
            }

            pr.已处理 = 真    // 标记为已报告
        }
        pr = pr.下一个
    }
}

// merge source: 沙盒批次/批五/待厚/感知/事件列表映.nova
// 所有可接收事件的对象(节点/Window/XMLHttpRequest等)的基类
// 管理add事件Listener/remove事件Listener/dispatch事件
// 事件监听器存储:
//   事件Target → 事件ListenerMap → { type → Registered事件Listener[] }

// 监听器选项 (Add事件ListenerOptions)

结构 事件ListenerOptions {
    捕获,    // 布尔 capture: true → 捕获阶段触发
    一次性,    // 布尔 once: true → 触发一次后自动移除
    被动,    // 布尔 passive: true → 不可pr事件Default (性能优化)
    信号,    // u64 AbortSignal (用于移除监听器)
}

// 已注册事件监听器 

结构 Registered事件Listener {
 类型原子,    // u32 事件类型原子ID
 回调,    // u64 事件Listener回调函数指针/JS函数引用
 捕获,
 一次性,
 被动,
 已移除,    // 布尔 标记为已移除(延迟删除)
}

// 事件监听器映射 
// 按事件类型组织监听器列表

结构 事件ListenerMap {
 // 实现: 固定数组,按类型原子索引
 // 传统引擎用哈希Map,这里用扁平数组(事件类型数量有限)
 监听器列表,    // u64 Registered事件Listener*数组
 监听器数量,
 监听器容量,
}

函数 事件ListenerMap_创建() {
 定义 map = 堆_分配(事件ListenerMap)
 map.监听器容量 = 16
 map.监听器列表 = 堆_分配_数组(map.监听器容量 * 40)
 map.监听器数量 = 0
 返回 map
}

函数 事件ListenerMap_添加(map, 类型原子, 回调, 捕获, 一次性, 被动) {
 // 检查重复(同类型+同回调+同捕获 = 重复)
 定义 可变 i = 0
 当 (i < map.监听器数量) {
 定义 偏移 = map.监听器列表 + i * 40
 定义 已有类型 = 内存_读32(偏移)
 定义 已有回调 = 内存_读64(偏移 + 8)
 定义 已有捕获 = 内存_读8(偏移 + 16)
 定义 已有已移除 = 内存_读8(偏移 + 19)
 如果 (已有类型 == 类型原子 && 已有回调 == 回调 && 已有捕获 == 捕获 && !已有已移除) {
 返回 // 重复,不添加
 }
 i = i + 1
 }

 // 扩容
 如果 (map.监听器数量 >= map.监听器容量) {
 定义 新容量 = map.监听器容量 * 2
 定义 新列表 = 堆_分配_数组(新容量 * 40)
 内存_复制(新列表, map.监听器列表, map.监听器数量 * 40)
 堆_释放(map.监听器列表)
 map.监听器列表 = 新列表
 map.监听器容量 = 新容量
 }

 // 写入
 定义 偏移 = map.监听器列表 + map.监听器数量 * 40
 内存_写32(偏移, 类型原子) // 类型原子
 内存_写64(偏移 + 8, 回调) // 回调
 内存_写8(偏移 + 16, 捕获) // 捕获
 内存_写8(偏移 + 17, 一次性) // 一次性
 内存_写8(偏移 + 18, 被动) // 被动
 内存_写8(偏移 + 19, 假) // 已移除
 map.监听器数量 = map.监听器数量 + 1
}

函数 事件ListenerMap_移除(map, 类型原子, 回调, 捕获) {
 定义 可变 i = 0
 当 (i < map.监听器数量) {
 定义 偏移 = map.监听器列表 + i * 40
 定义 已有类型 = 内存_读32(偏移)
 定义 已有回调 = 内存_读64(偏移 + 8)
 定义 已有捕获 = 内存_读8(偏移 + 16)
 如果 (已有类型 == 类型原子 && 已有回调 == 回调 && 已有捕获 == 捕获) {
 内存_写8(偏移 + 19, 真) // 标记已移除
 返回
 }
 i = i + 1
 }
}

函数 事件ListenerMap_获取类型监听器(map, 类型原子, 结果列表, 最大数量) {
 // 获取指定类型的所有有效监听器
 定义 可变 计数 = 0
 定义 可变 i = 0
 当 (i < map.监听器数量 && 计数 < 最大数量) {
 定义 偏移 = map.监听器列表 + i * 40
 定义 已有类型 = 内存_读32(偏移)
 定义 已有已移除 = 内存_读8(偏移 + 19)
 如果 (已有类型 == 类型原子 && !已有已移除) {
 内存_复制(结果列表 + 计数 * 40, 偏移, 40)
 计数 = 计数 + 1
 }
 i = i + 1
 }
 返回 计数
}

// merge source: 沙盒批次/批六/待厚/感知/事件.nova
// §3 Keyboard事件 

结构 Keyboard事件扩展 {
 基础事件,    // u64 事件*
 键码,    // u32 keyCode (DOM3已弃用但仍广泛使用)
 键,    // u64 key字符串 ("Enter"/"a"/"ArrowUp"等)
 键长度,
 代码,    // u64 code字符串 ("KeyA"/"Enter"/"ArrowUp"等)
 代码长度,
 位置,    // u32 location (0=standard 1=left 2=right 3=numpad)
 重复,    // 布尔 repeat
 Ctrl键,
 Shift键,
 Alt键,
 Meta键,
 是合成输入,    // 布尔 isComposing (IME输入中)
}

// §4 Wheel事件 

结构 Wheel事件扩展 {
 基础鼠标事件,    // u64 Mouse事件扩展*
 deltaX,    // i32 ×100
 deltaY,    // i32 ×100
 deltaZ,    // i32 ×100
 deltaMode,    // u32 0=pixel 1=line 2=page
}

函数 Wheel事件_创建(x, y, deltaX, deltaY) {
定义 鼠标 = Mouse事件_创建("wheel", x, y, 0, 0)
定义 we = 堆_分配(Wheel事件扩展)
we.基础鼠标事件 = 鼠标
we.deltaX = deltaX
 we.deltaY = deltaY
 we.deltaZ = 0
 we.deltaMode = 0
 返回 we
}

// §5 Focus事件 / Input事件 / Custom事件

结构 Focus事件扩展 {
 基础事件,
 相关目标,    // u64 获得/失去焦点的另一个元素
}

函数 Focus事件_创建(类型, 相关目标) {
 定义 基础 = 事件_创建(类型, 假, 假)
 如果 (字符串_相等(类型, "focusin") || 字符串_相等(类型, "focusout")) {
 基础.冒泡 = 真
 }
 基础.是受信任的 = 真
 定义 fe = 堆_分配(Focus事件扩展)
 fe.基础事件 = 基础
 fe.相关目标 = 相关目标
 返回 fe
}

结构 Input事件扩展 {
 基础事件,
 数据,    // u64 输入的文本数据
 数据长度,
 输入类型,    // u64 inputType ("inseNova往返时间ext"/"deleteContentBackward"/...)
 是合成输入,
}

函数 Input事件_创建(数据, 输入类型) {
 定义 基础 = 事件_创建("input", 真, 假)
 基础.是受信任的 = 真
 定义 ie = 堆_分配(Input事件扩展)
 ie.基础事件 = 基础
 ie.数据 = 字符串_复制(数据)
 ie.数据长度 = 字符串_长度(数据)
 ie.输入类型 = 字符串_复制(输入类型)
 ie.是合成输入 = 假
 返回 ie
}

结构 Custom事件扩展 {
 基础事件,
 详情,    // u64 detail (任意JS值,这里存指针)
}

函数 Custom事件_创建(类型, 冒泡, 可取消, 详情) {
 定义 基础 = 事件_创建(类型, 冒泡, 可取消)
 定义 ce = 堆_分配(Custom事件扩展)
 ce.基础事件 = 基础
 ce.详情 = 详情
 返回 ce
}

// merge source: 沙盒批次/批五/待厚/感知/事件分发焦.nova
// §7 焦点管理

定义 可变 当前焦点元素 = 0

函数 Focus_设置(新焦点) {
    如果 (新焦点 == 当前焦点元素) { 返回 }
    定义 旧焦点 = 当前焦点元素

    // 失焦旧元素
    如果 (旧焦点 != 0) {
        定义 旧文档扩展 = 元素_获取状态文档扩展(旧焦点)
        如果 (旧文档扩展 != 0 && 旧文档扩展.焦点元素 == 旧焦点) {
            旧文档扩展.焦点元素 = 0
        }
        元素_标记状态子树样式脏(旧焦点)
        定义 blur事件 = 事件_创建2("blur", 假, 假)
        blur事件.是可信的 = 真
        定义 et = 堆_分配(事件Target)
        et.节点 = 旧焦点
        如果 (旧焦点 != 0) { et.监听器Map = 旧焦点.事件监听器数据 }
        事件Dispatch_分发(et, blur事件)

        // focusout冒泡
        定义 focusout = 事件_创建2("focusout", 真, 假)
        focusout.是可信的 = 真
        事件Dispatch_分发(et, focusout)
    }

    当前焦点元素 = 新焦点

    // 聚焦新元素
    如果 (新焦点 != 0) {
        定义 新文档扩展 = 元素_获取状态文档扩展(新焦点)
        如果 (新文档扩展 != 0) {
            新文档扩展.焦点元素 = 新焦点
        }
        元素_标记状态子树样式脏(新焦点)
        定义 focus事件 = 事件_创建2("focus", 假, 假)
        focus事件.是可信的 = 真
        定义 et = 堆_分配(事件Target)
        et.节点 = 新焦点
        如果 (新焦点 != 0) { et.监听器Map = 新焦点.事件监听器数据 }
        事件Dispatch_分发(et, focus事件)

        // focusin冒泡
        定义 focusin = 事件_创建2("focusin", 真, 假)
        focusin.是可信的 = 真
        事件Dispatch_分发(et, focusin)
    }
}

函数 Focus_Tab处理(当前, 向前) {
    // Tab键: 在可聚焦元素间移动焦点
    // 可聚焦: <input>/<textarea>/<select>/<button>/<a>及tabindex>=0的元素
    // 顺序: tabindex正数(从小到大) → tabindex=0(DOM顺序) → 跳过负tabindex
    定义 可变 文档 = 当前
    定义 可变 基准 = 当前
    如果 (基准 == 0) { 基准 = 当前焦点元素 }
    如果 (基准 == 0) { 返回 0 }
    如果 (基准.节点类型 == DOCUMENT_节点) {
        文档 = 基准
        如果 (当前焦点元素 != 0 && 当前焦点元素.树作用域 == 文档) {
            基准 = 当前焦点元素
        } 否则 {
            基准 = 0
        }
    } 否则 {
        文档 = 基准.树作用域
    }
    如果 (文档 == 0) { 返回 0 }

    定义 可变 可聚焦列表 = []
    定义 可变 tabIndex列表 = []
    定义 可变 节点 = 节点_深度优先下一个(文档, 文档)
    当 (节点 != 0) {
        如果 (节点.节点标志 & 节点标志_是元素) {
            定义 tabIndex = 元素_TabIndex值(节点)
            如果 (tabIndex >= 0) {
                如果 (tabIndex > 0) {
                    定义 可变 插入位置 = 0
                    当 (插入位置 < 计数(tabIndex列表)) {
                        定义 已有tabIndex = tabIndex列表[插入位置]
                        如果 (已有tabIndex == 0 || 已有tabIndex > tabIndex) { 跳出 }
                        插入位置 = 插入位置 + 1
                    }
                    列表_插入(可聚焦列表, 插入位置, 节点)
                    列表_插入(tabIndex列表, 插入位置, tabIndex)
                } 否则 {
                    追加(可聚焦列表, 节点)
                    追加(tabIndex列表, tabIndex)
                }
            }
        }
        节点 = 节点_深度优先下一个(节点, 文档)
    }

    定义 总数 = 计数(可聚焦列表)
    如果 (总数 == 0) { 返回 0 }

    定义 可变 当前索引 = -1
    定义 可变 i = 0
    当 (i < 总数) {
        如果 (可聚焦列表[i] == 基准) {
            当前索引 = i
            跳出
        }
        i = i + 1
    }

    定义 可变 下一索引 = 0
    如果 (向前) {
        下一索引 = 总数 - 1
        如果 (当前索引 >= 0) {
            下一索引 = 当前索引 - 1
            如果 (下一索引 < 0) { 下一索引 = 总数 - 1 }
        }
    } 否则 {
        如果 (当前索引 >= 0) {
            下一索引 = 当前索引 + 1
            如果 (下一索引 >= 总数) { 下一索引 = 0 }
        }
    }

    定义 下一个 = 可聚焦列表[下一索引]
    Focus_设置(下一个)
    返回 下一个
}

// §8 输入事件处理链

// 平台层传入的原始输入 → DOM事件
函数 Input_处理鼠标(document, 类型, x, y, button, 修饰键) {
    如果 (document == 0) { 返回 }
    // 1. 命中测试
    定义 目标 = HitTest_在点(document, x, y)
    如果 (目标 == 0) { 目标 = document }

    // 2. 创建事件
    定义 evt = Mouse事件_创建(类型, x, y, button, 修饰键)
    evt.基类.是可信的 = 真

    // 3. 分发
    定义 et = 堆_分配(事件Target)
    et.节点 = 目标
    如果 (目标 != 0) { et.监听器Map = 目标.事件监听器数据 }
    事件Dispatch_分发(et, evt.基类)

    // 4. mousedown + mouseup → click合成
    如果 (字符串_相等(类型, "mouseup")) {
        事件Dispatch_click(目标, x, y)
    }
}

函数 Input_处理键盘(document, 类型, key, code, keyCode, 修饰键) {
    // 发送到当前焦点元素
    定义 目标 = 当前焦点元素
    如果 (目标 == 0) { 目标 = document }
    如果 (字符串_相等(类型, "keyup")) {
        返回 事件Dispatch_keyup(目标, key, code, keyCode, 修饰键)
    }
    返回 事件Dispatch_keydown(目标, key, code, keyCode, 修饰键)
}

函数 Input_处理滚轮(document, x, y, deltaX, deltaY, 修饰键) {
    // 节流
    如果 (scroll节流 != 0) {
        定义 现在 = 平台_获取高精度时间()
        如果 (!事件Throttle_应该触发(scroll节流, 现在)) { 返回 }
    }
    定义 目标 = HitTest_在点(document, x, y)
    如果 (目标 == 0) { 目标 = document }

    定义 evt = 堆_分配(Wheel事件)
    evt.基类 = Mouse事件_创建("wheel", x, y, 0, 修饰键)
    evt.deltaX = deltaX; evt.deltaY = deltaY; evt.deltaZ = 0; evt.deltaMode = 0
    evt.基类.基类.是可信的 = 真

    定义 et = 堆_分配(事件Target)
    et.节点 = 目标
    如果 (目标 != 0) { et.监听器Map = 目标.事件监听器数据 }
    事件Dispatch_分发(et, evt.基类.基类)
}

函数 Input_处理触摸(document, 类型, touches, touch数量) {
    如果 (touch数量 == 0) { 返回 }
    // 第一个触摸点进行命中测试
    定义 第一 = touches
    定义 目标 = HitTest_在点(document, 第一.clientX, 第一.clientY)
    如果 (目标 == 0) { 目标 = document }

    定义 evt = 事件_创建2(类型, 真, 真)
    evt.是可信的 = 真
    定义 et = 堆_分配(事件Target)
    et.节点 = 目标
    如果 (目标 != 0) { et.监听器Map = 目标.事件监听器数据 }
    事件Dispatch_分发(et, evt)
}

// merge source: 沙盒批次/批六/待厚/感知/消息管共享.nova
// §6 Mojo共享内存

结构 MojoSharedBuffer {
    fd,    // i32 memfd / shm_open fd
    大小,
    映射A,    // u64 进程A的Nova内存映射地址
    映射B,    // u64 进程B的Nova内存映射地址
}

函数 MojoSharedBuffer_创建(大小) {
    定义 shm = 堆_分配(MojoSharedBuffer)
    shm.大小 = 大小
    // memfd_create("mojo_shm", MFD_CLOEXEC)
    shm.fd = 平台_memfd_create(大小)
    shm.映射A = 平台_Nova内存映射(shm.fd, 大小)
    shm.映射B = 0
    返回 shm
}

函数 MojoSharedBuffer_映射(shm, fd) {
    如果 (shm == 0) { 返回 0 }
    返回 平台_Nova内存映射(fd, shm.大小)
}

// §7 进程管理: 创建沙箱化子进程

函数 Browser_创建渲染er(站点URL) {
    定义 policy = Sandbox_创建策略(PROC_RENDERER)
    定义 pipe = MojoPipe_创建()
    // fork + exec renderer进程
    定义 pid = 平台_fork()
    如果 (pid == 0) {
        // 子进程: 应用沙箱
        Sandbox_应用(policy)
        // 关闭不需要的fd，只保留IPC管道
        // 进入renderer主循环
        渲染er_主循环(pipe, 1)    // 使用端口1
        平台_exit(0)
    }
    // 父进程(Browser)
    定义 proc = 堆_分配(SandboxedProcess)
    proc.pid = pid; proc.类型 = PROC_RENDERER; proc.策略 = policy
    proc.Nova通信_管道 = pipe; proc.已启动 = 真; proc.已沙箱化 = 真
    proc.站点URL = 站点URL
    proc.下一个 = 进程列表头; 进程列表头 = proc
    进程数 = 进程数 + 1
    返回 proc
}

函数 Browser_创建图处() {
    定义 policy = Sandbox_创建策略(PROC_图处)
    定义 pipe = MojoPipe_创建()
    定义 pid = 平台_fork()
    如果 (pid == 0) {
        Sandbox_应用(policy)
        图处_主循环(pipe, 1)
        平台_exit(0)
    }
    定义 proc = 堆_分配(SandboxedProcess)
    proc.pid = pid; proc.类型 = PROC_图处; proc.策略 = policy
    proc.Nova通信_管道 = pipe; proc.已启动 = 真; proc.已沙箱化 = 真
    proc.下一个 = 进程列表头; 进程列表头 = proc
    进程数 = 进程数 + 1
    返回 proc
}

函数 Browser_终止进程(proc) {
    如果 (proc == 0) { 返回 }
    平台_kill(proc.pid, 9)    // SIGKILL
    MojoPipe_关闭(proc.Nova通信_管道, 0)
}

// §8 站点隔离(Site Isolation)

// 每个站点(scheme+eTLD+1)分配独立渲染er进程
// 例: https://example.com 和 https://sub.example.com 共用一个
//     https://other.com 使用不同进程

函数 SiteIsolation_获取站点(url) {
    如果 (url == 0) { 返回 0 }
    // 提取 scheme + eTLD+1
    // 例: "https://sub.example.com/path" → "https://example.com"
    返回 url    // 返回规范化后的URL
}

函数 SiteIsolation_查找渲染er(站点) {
    如果 (站点 == 0) { 返回 0 }
    定义 可变 proc = 进程列表头
    当 (proc != 0) {
        如果 (proc.类型 == PROC_RENDERER && 字符串_相等(proc.站点URL, 站点)) {
            返回 proc
        }
        proc = proc.下一个
    }
    返回 0
}

函数 SiteIsolation_获取或创建渲染er(url) {
    定义 站点 = SiteIsolation_获取站点(url)
    定义 existing = SiteIsolation_查找渲染er(站点)
    如果 (existing != 0) { 返回 existing }
    返回 Browser_创建渲染er(站点)
}

// merge source: 沙盒批次/批六/待厚/感知/事件目标文.nova
// §3 事件Target — DOM事件系统

结构 事件Listener {
    类型,    // u64 事件类型字符串 "click"/"scroll"等
    类型哈希,
    回调,    // u64 JS函数
    是捕获,    // 布尔 capture阶段
    是once,    // 布尔 触发一次后自动移除
    是passive,    // 布尔 不调用pr事件Default
    下一个,    // u64 事件Listener*
}

结构 事件Target {
    监听器链,    // u64 事件Listener*
    监听器数,
}

// 事件对象
结构 DOM事件 {
    类型,    // u64 "click"/"keydown"等
    目标,    // u64 事件Target*
    当前目标,
    阶段,    // u32 1=capture 2=target 3=bubble
    已停止传播,
    已阻止默认,
    是可信,
    时间戳,
    // 鼠标事件扩展
    clientX,
    clientY,
    按钮,
    // 键盘事件扩展
    key,    // u64 "Enter"/"a"等
    keyCode,
    ctrlKey,
    shiftKey,
    altKey,
    metaKey,
}

// merge source: 沙盒批次/批六/待厚/感知/验证消息生.nova
// §5 验证消息生成

函数 FormValidation_消息(vs, 约束) {
    如果 (vs == 0) { 返回 "" }
    如果 (vs.valid) { 返回 "" }
    如果 (vs.custom错误 && 约束 != 0 && 约束.custom错误 != 0) {
        返回 约束.custom错误
    }
    如果 (vs.valueMissing) { 返回 "请填写此字段。" }
    如果 (vs.typeMismatch) {
        如果 (约束 != 0 && 约束.类型 == INPUT_EMAIL) { 返回 "请输入有效的电子邮件地址。" }
        如果 (约束 != 0 && 约束.类型 == INPUT_URL) { 返回 "请输入有效的URL。" }
        返回 "格式不正确。"
    }
    如果 (vs.patternMismatch) { 返回 "请匹配请求的格式。" }
    如果 (vs.tooLong) { 返回 "输入内容过长。" }
    如果 (vs.tooShort) { 返回 "输入内容过短。" }
    如果 (vs.rangeUnderflow) { 返回 "值必须大于或等于最小值。" }
    如果 (vs.rangeOverflow) { 返回 "值必须小于或等于最大值。" }
    如果 (vs.stepMismatch) { 返回 "请输入有效的值。" }
    如果 (vs.badInput) { 返回 "请输入一个数字。" }
    返回 "输入无效。"
}

// §6 表单级验证

结构 Form元素 {
    元素,    // u64 HTMLForm元素 节点*
    // 关联元素列表
    控件,    // u64 元素*数组
    控件数,
    控件容量,
    // 属性
    action,    // u64 提交URL
    method,    // u64 "get"/"post"
    enctype,    // u64 "application/x-www-form-urlencoded"/"multipart/form-data"
    novalidate,
    // 名称
    name,
}

函数 Form_checkValidity(form) {
    如果 (form == 0) { 返回 真 }
    如果 (form.novalidate) { 返回 真 }
    定义 可变 allValid = 真
    定义 可变 i = 0
    当 (i < form.控件数) {
        定义 ctrl = 内存_读64(form.控件 + i * 8)
        如果 (ctrl != 0) {
            // 获取控件约束, 验证
            // 如果无效: 触发invalid事件
            // 如果invalid事件未pr事件Default → allValid = false
        }
        i = i + 1
    }
    返回 allValid
}

函数 Form_reportValidity(form) {
    如果 (form == 0) { 返回 真 }
    定义 valid = Form_checkValidity(form)
    如果 (!valid) {
        // 聚焦到第一个无效控件
        // 显示验证错误气泡
    }
    返回 valid
}

// form.submit() — 不触发验证
函数 Form_submit(form) {
    如果 (form == 0) { 返回 }
    // 直接提交(跳过验证)
    Form_执行提交(form)
}

// 用户点击submit按钮 → 触发验证
函数 Form_用户提交(form) {
    如果 (form == 0) { 返回 }
    如果 (!form.novalidate) {
        如果 (!Form_reportValidity(form)) { 返回 }
    }
    // 触发submit事件
    // 如果未pr事件Default → 执行提交
    Form_执行提交(form)
}

函数 Form_执行提交(form) {
    如果 (form == 0) { 返回 }
    // 1. 构建表单数据(FormData)
    // 2. 编码(URL编码或multipart)
    // 3. 根据method(GET/POST)和action发送请求
    // 4. 导航到响应
}

// form.reset()
函数 Form_reset(form) {
    如果 (form == 0) { 返回 }
    // 重置所有控件到默认值
    // 触发reset事件
}

// merge source: 沙盒批次/批六/待厚/感知/事件穿透影.nova
// §8 事件穿透Shadow DOM

// composed事件可以穿越shadow boundary

函数 Shadow_事件路径(事件, target) {
    如果 (事件 == 0 || target == 0) { 返回 }
    // 构建事件路径(事件 path):
    // 1. 从target向上遍历到document
    // 2. 如果遇到shadow root:
    //    - composed=true: 继续穿越到host 元素
    //    - composed=false: 停在shadow root
    // 3. 在shadow boundary处, 事件.target被重定向为host 元素
    //    (从外部看不到shadow内部的真实target)
}

// 默认composed=true的事件:
// click, mousedown, mouseup, keydown, keyup, focus, blur, input, change, ...
// 默认composed=false的事件:
// slotchange, ...

函数 Shadow_重定向target(事件, currentTarget) {
    如果 (事件 == 0 || currentTarget == 0) { 返回 事件 }
    // 如果事件从shadow tree内部dispatch,
    // 在shadow tree外部的监听器中, 事件.target显示为host 元素
    返回 事件
}

// §9 adopted样式Sheets

函数 ShadowRoot_setAdopted样式Sheets(sr, sheets, 数量) {
    如果 (sr == 0) { 返回 }
    sr.adopted样式Sheets = sheets; sr.样式表数 = 数量
    // 触发样式重新计算
}

// §10 元素Internals (Form-associated Custom 元素s)

结构 元素Internals {
    元素,    // u64 关联的custom 元素
    shadowRoot,    // u64 如果attachInternals后attachShadow
    // 表单相关
    form,    // u64 HTMLForm元素*
    labels,    // u64 节点List*
    // 值
    formValue,
    formState,
    // 验证
    validationMessage,
    validity,    // u64 ValidityState*
    willValidate,
}

函数 元素Internals_创建(元素) {
    定义 ei = 堆_分配(元素Internals)
    ei.元素 = 元素; ei.shadowRoot = 0; ei.form = 0
    ei.formValue = 0; ei.formState = 0; ei.validationMessage = 0
    ei.validity = 0; ei.willValidate = 假
    返回 ei
}

// internals.setFormValue(value, state)
函数 EI_setFormValue(ei, value, state) {
    如果 (ei == 0) { 返回 }
    ei.formValue = value; ei.formState = state
}

// internals.setValidity(flags, message, anchor)
函数 EI_setValidity(ei, flags, message) {
    如果 (ei == 0) { 返回 }
    ei.validationMessage = message
}

// internals.reportValidity()
函数 EI_reportValidity(ei) {
    如果 (ei == 0) { 返回 真 }
    // 显示验证消息气泡
    返回 ei.validationMessage == 0
}


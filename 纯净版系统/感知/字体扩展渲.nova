// Skia→Nova转换: 文本渲染管线
// 原始: skia/src/core/Sk字体.cpp + SkScalerContext.cpp + SkGlyph.cpp
//       + skia/src/ports/Sk字体Host_FreeType.cpp 
//       +  (文本整形)
// 文本渲染管线:
//   文本字符串 → Unicode分段(UAX#29) → HarfBuzz整形(字形映射+GSUB/GPOS)
//     → FreeType光栅化(字形→位图) → 字形缓存 → Blitter写入像素
// 本文件实现:
//   1. FreeType适配(字体加载/字形光栅化)
//   2. 字形缓存(LRU)
//   3. Unicode换行算法(UAX#14核心规则)
//   4. 文本度量(advance width/ascent/descent)
//   5. 文本绘制(字形位图合成)

// §1 NovaOS FreeType适配层
// FreeType是字体光栅化的工业标准库
// NovaOS将FreeType编译为内核模块,通过Nova系统调用访问

定义 Nova系统调用_字体_加载       = 700
定义 Nova系统调用_字体_设置大小   = 701
定义 Nova系统调用_字体_获取字形   = 702
定义 Nova系统调用_字体_获取度量   = 703
定义 Nova系统调用_字体_光栅化     = 704
定义 Nova系统调用_字体_卸载       = 705
定义 Nova系统调用_字体_列表       = 706

结构 字体Face {
    句柄,    // u64 FreeType FT_Face句柄
    族名,    // u64 字体族名称
    字号,    // i32 当前字号(像素×64, FreeType用26.6定点)
    粗细,    // i32 100-900
    是斜体,
    上升,    // i32 ascender (基线以上, ×64)
    下降,    // i32 descender (基线以下, 负数, ×64)
    行距,    // i32 line gap (×64)
    单位每Em,    // i32 units per em
    字形缓存,    // u64 Glyph缓存*
}

结构 GlyphBitmap {
    宽,
    高,
    左偏移,    // i32 字形原点到位图左边的距离
    上偏移,    // i32 字形原点到位图上边的距离(基线以上)
    前进宽度,    // i32 下一个字形的x偏移(×64)
    像素数据,    // u64 8位灰度位图(alpha值)
    行字节数,
}

结构 Glyph缓存Entry {
    码点,
    字号,
    位图,    // u64 GlyphBitmap*
    已使用,
}

结构 Glyph缓存 {
    条目,    // u64 Glyph缓存Entry数组
    数量,
    容量,
}


函数 字体Face_创建(字体族, 字号_px) {
    定义 face = 堆_分配(字体Face)
    face.族名 = 字符串_复制(字体族)
    face.字号 = 字号_px * 64    // px → 26.6定点
    face.粗细 = 400
    face.是斜体 = 假

    // 通过Nova系统调用加载字体
    face.句柄 = 系统调用(Nova系统调用_字体_加载, 字体族, 字符串_长度(字体族), 0, 0, 0)

    如果 (face.句柄 != 0) {
        // 设置字号
        系统调用(Nova系统调用_字体_设置大小, face.句柄, face.字号, 0, 0, 0)
        // 获取度量
        定义 度量缓冲 = 堆_分配(32)
        系统调用(Nova系统调用_字体_获取度量, face.句柄, 度量缓冲, 0, 0, 0)
        face.上升 = 内存_读32(度量缓冲)
        face.下降 = 内存_读32(度量缓冲 + 4)
        face.行距 = 内存_读32(度量缓冲 + 8)
        face.单位每Em = 内存_读32(度量缓冲 + 12)
        堆_释放(度量缓冲)
    } 否则 {
        // 字体加载失败: 使用默认度量
        face.上升 = 字号_px * 56        // ~0.88 × 字号
        face.下降 = 0 - 字号_px * 14    // ~-0.22 × 字号
        face.行距 = 字号_px * 6
        face.单位每Em = 2048
    }

    // 初始化字形缓存
    face.字形缓存 = Glyph缓存_创建(512)

    返回 face
}

函数 Glyph缓存_创建(容量) {
    定义 cache = 堆_分配(Glyph缓存)
    cache.容量 = 容量
    cache.条目 = 堆_分配_数组(容量 * 24)
    cache.数量 = 0
    返回 cache
}

函数 Glyph缓存_查找(cache, 码点, 字号) {
    定义 可变 i = 0
    当 (i < cache.数量) {
        定义 偏移 = cache.条目 + i * 24
        如果 (内存_读32(偏移) == 码点 && 内存_读32(偏移 + 4) == 字号) {
            返回 内存_读64(偏移 + 8)
        }
        i = i + 1
    }
    返回 0
}

函数 Glyph缓存_添加(cache, 码点, 字号, 位图) {
    如果 (cache.数量 >= cache.容量) {
        // LRU淘汰: 保留后半部分(最近使用)
        定义 保留 = cache.数量 / 2
        内存_复制(cache.条目, cache.条目 + 保留 * 24, (cache.数量 - 保留) * 24)
        cache.数量 = cache.数量 - 保留
    }
    定义 偏移 = cache.条目 + cache.数量 * 24
    内存_写32(偏移, 码点)
    内存_写32(偏移 + 4, 字号)
    内存_写64(偏移 + 8, 位图)
    cache.数量 = cache.数量 + 1
}

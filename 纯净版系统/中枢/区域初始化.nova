    水位线:         数组<u64, NR_WMARK>,
    水位线_加速:    u64,           // watermark_boost: 碎片避免临时提升
    起始页号:       u64,           // zone_start_pfn
    跨越页数:       u64,           // spanned_pages (含空洞)
    存在页数:       u64,           // present_pages (不含空洞)
    管理页数:       u64,           // managed_pages (不含保留)
    空闲区:         数组<空闲区域, 最大阶 + 1>,
    // 每个页块(512页=2MB)有一个迁移类型标记
    页块类型:       数组<u8>,
    页块数:         u64,
    PCP:            PCP缓存,
    锁:             自旋锁,        // 保护free_area
    分配次数:       u64,
    释放次数:       u64,
    分裂次数:       u64,
    合并次数:       u64,
    分配失败:       u64,
    PCP命中:        u64,
    回退次数:       u64,
    // 防止高zone耗尽低zone内存: HIGHMEM分配不能抢NORMAL的保留
    低端保留:       数组<u64, 最大ZONE数>,
    已初始化:       布尔
}

// 全局状态 

定义 可变 所有zone = 数组<内存zone, 最大ZONE数>
定义 可变 活跃zone数 = 0
定义 可变 全局总页数 = 0
定义 可变 全局空闲页数 = 0
定义 可变 页状态 = 空          // 全局位图: 1=空闲, 0=已用
定义 可变 伙伴_空闲链表 = 空   // 全局空闲链表引用(被检查点/自动化引擎引用)

定义 可变 zone搜索顺序 = []    // [ZONE_HIGHMEM, ZONE_NORMAL, ZONE_直传32, ZONE_直传]

// 初始化

函数 zone_初始化(zone索引, 名称, 起始页号, 页数) {
    定义 可变 z = 所有zone[zone索引]
    z.名称 = 名称
    z.类型 = zone索引
    z.起始页号 = 起始页号
    z.跨越页数 = 页数
    z.存在页数 = 页数
    z.管理页数 = 0              // 后续添加空闲块时累加
    z.已初始化 = 真
    z.锁 = 自旋锁_创建()

    // 初始化11个阶的空闲区域, 每个含4条迁移类型链表
    定义 可变 阶 = 0
    当 (阶 <= 最大阶) {
        z.空闲区[阶].空闲数 = 0
        定义 可变 mt = 0
        当 (mt < MIGRATE_TYPES) {
            z.空闲区[阶].空闲链表[mt] = 链表_创建()
            mt = mt + 1
        }
        阶 = 阶 + 1
    }

    // 初始化页块迁移类型: 默认MIGRATE_MOVABLE
    z.页块数 = (页数 + 页块页数 - 1) / 页块页数
    z.页块类型 = 数组_创建(z.页块数, MIGRATE_MOVABLE)

    // 初始化PCP缓存
    z.PCP.计数 = 0
    z.PCP.高水位 = 186           // Nova默认~186
    z.PCP.批量 = 31              // Nova默认batch=31
    z.PCP.锁 = 自旋锁_创建()
    定义 可变 mt = 0
    当 (mt < MIGRATE_PCPTYPES) {
        z.PCP.链表[mt] = 链表_创建()
        mt = mt + 1
    }

    // 水位线(后续由伙伴系统_计算水位线设置)
    z.水位线[WMARK_MIN] = 0
    z.水位线[WMARK_LOW] = 0
    z.水位线[WMARK_HIGH] = 0
    z.水位线_加速 = 0
}

函数 伙伴系统_初始化() {
    // 探测物理内存布局(由MB2信息或E820表提供)
    // 在M1阶段简化为: 所有内存放入ZONE_直传(0-16MB) + ZONE_NORMAL(16MB+)
    // 64位系统无ZONE_HIGHMEM
    早期打印OK("伙伴系统初始化 (zone化 + 迁移类型分离 + PCP)")
}

函数 伙伴系统_完整初始化(总物理页数) {
    全局总页数 = 总物理页数
    页状态 = 位图_创建(总物理页数)

    // 划分zone
    定义 直传页数 = 4096          // 16MB / 4KB = 4096页
    如果 (直传页数 > 总物理页数) { 直传页数 = 总物理页数 }
    定义 NORMAL页数 = 总物理页数 - 直传页数

    zone_初始化(ZONE_直传, "直传", 0, 直传页数)
    如果 (NORMAL页数 > 0) {
        zone_初始化(ZONE_NORMAL, "Normal", 直传页数, NORMAL页数)
    }
    活跃zone数 = 2

    // 构建zone搜索顺序: 从高到低 
    zone搜索顺序 = [ZONE_NORMAL, ZONE_直传]

    // 计算水位线
    伙伴系统_计算水位线()

    // 计算低端保留
    伙伴系统_计算低端保留()

    内核信息数值("伙伴系统: 总页数", 总物理页数)
    内核信息数值("伙伴系统: 直传页数", 直传页数)
    内核信息数值("伙伴系统: NORMAL页数", NORMAL页数)

函数 Nova原生桌面_AI页面_截断(文本, 最大长度) {
    如果 (文本 == 空) { 返回 "" }
    如果 (字符串长度(文本) <= 最大长度) { 返回 文本 }
    如果 (最大长度 <= 3) { 返回 子字符串(文本, 0, 最大长度) }
    返回 子字符串(文本, 0, 最大长度 - 3) + "..."
}

函数 Nova原生桌面_AI页面_获取焦点窗口索引() {
    如果 (!桌面_已初始化) { 返回 -1 }
    如果 (桌面.焦点窗口 <= 0) { 返回 -1 }
    返回 Nova原生桌面_查找窗口索引(桌面.焦点窗口)
}

函数 Nova原生桌面_AI页面_判断类型(url) {
    如果 (字符串查找(url, "nova://") == 0) { 返回 "system" }
    如果 (字符串查找(url, "http://") == 0 || 字符串查找(url, "https://") == 0) { 返回 "web" }
    返回 "workspace"
}

函数 Nova原生桌面_AI页面_加载窗口上下文_按索引(窗口索引) {
    如果 (!桌面_已初始化) { 返回 假 }
    如果 (窗口索引 < 0 || 窗口索引 >= 计数(桌面.窗口列表)) { 返回 假 }
    定义 url = 桌面.窗口列表[窗口索引].URL
    定义 请求 = 浏览器网络_发起请求(方法_GET, url, [], "")
    如果 (请求.状态 != 请求状态_完成 || 计数(请求.响应体) <= 0) {
        桌面.窗口列表[窗口索引].页面源码 = ""
        桌面.窗口列表[窗口索引].页面DOM = 空
        桌面.窗口列表[窗口索引].页面类型 = Nova原生桌面_AI页面_判断类型(url)
        桌面.窗口列表[窗口索引].页面标题 = 桌面.窗口列表[窗口索引].标题
        桌面.窗口列表[窗口索引].页面最后动作 = "page-load-failed"
        返回 假
    }
    定义 页面源码 = 请求.响应体[0]
    定义 页面DOM = DOM_解析HTML(页面源码, url)
    桌面.窗口列表[窗口索引].页面源码 = 页面源码
    桌面.窗口列表[窗口索引].页面DOM = 页面DOM
    桌面.窗口列表[窗口索引].页面类型 = Nova原生桌面_AI页面_判断类型(url)
    桌面.窗口列表[窗口索引].页面标题 = 桌面.窗口列表[窗口索引].标题
    如果 (页面DOM != 空) {
        DOM_当前文档 = 页面DOM
        如果 (字符串长度(页面DOM.标题) > 0) {
            桌面.窗口列表[窗口索引].页面标题 = 页面DOM.标题
        }
    }
    桌面.窗口列表[窗口索引].页面最后动作 = "page-loaded"
    返回 真
}

函数 Nova原生桌面_AI页面_确保窗口上下文_按索引(窗口索引) {
    如果 (!桌面_已初始化) { 返回 假 }
    如果 (窗口索引 < 0 || 窗口索引 >= 计数(桌面.窗口列表)) { 返回 假 }
    如果 (桌面.窗口列表[窗口索引].页面DOM != 空 && 字符串长度(桌面.窗口列表[窗口索引].页面源码) > 0) {
        DOM_当前文档 = 桌面.窗口列表[窗口索引].页面DOM
        返回 真
    }
    返回 Nova原生桌面_AI页面_加载窗口上下文_按索引(窗口索引)
}

函数 Nova原生桌面_AI页面_DOM摘要(文档, 最大节点数) {
    如果 (文档 == 空) { 返回 "" }
    定义 可变 摘要 = ""
    定义 可变 已记录 = 0
    定义 可变 i = 0
    当 (i < 计数(文档.节点池) && 已记录 < 最大节点数) {
        定义 节点 = 文档.节点池[i]
        如果 (节点.类型 != 节点_元素) {
            i = i + 1
            继续
        }
        如果 (节点.标签名 == "html" || 节点.标签名 == "head" || 节点.标签名 == "body" || 节点.标签名 == "script" || 节点.标签名 == "style") {
            i = i + 1
            继续
        }
        定义 可变 条目 = 节点.标签名
        定义 id = DOM_获取属性(文档, 节点.ID, "id")
        定义 cls = DOM_获取属性(文档, 节点.ID, "class")
        定义 href = DOM_获取属性(文档, 节点.ID, "href")
        定义 value = DOM_获取属性(文档, 节点.ID, "value")
        如果 (字符串长度(id) > 0) { 条目 = 条目 + "#" + id }
        如果 (字符串长度(cls) > 0) { 条目 = 条目 + "." + Nova原生桌面_AI页面_截断(cls, 20) }
        如果 (字符串长度(节点.文本内容) > 0) { 条目 = 条目 + " \"" + Nova原生桌面_AI页面_截断(节点.文本内容, 24) + "\"" }
        如果 (字符串长度(value) > 0) { 条目 = 条目 + " = " + Nova原生桌面_AI页面_截断(value, 24) }
        如果 (字符串长度(href) > 0) { 条目 = 条目 + " -> " + Nova原生桌面_AI页面_截断(href, 48) }
        如果 (字符串长度(摘要) > 0) { 摘要 = 摘要 + "\n" }
        摘要 = 摘要 + 条目
        已记录 = 已记录 + 1
        i = i + 1
    }
    如果 (字符串长度(摘要) == 0) {
        返回 "页面DOM已解析, 暂无可摘要节点"
    }
    返回 摘要
}

函数 Nova原生桌面_AI页面_导航当前窗口(窗口索引, url, 标题) {
    如果 (!桌面_已初始化) { 返回 假 }
    如果 (窗口索引 < 0 || 窗口索引 >= 计数(桌面.窗口列表)) { 返回 假 }
    定义 可变 新标题 = 标题
    如果 (字符串长度(新标题) == 0) { 新标题 = url }
    桌面.窗口列表[窗口索引].URL = url
    桌面.窗口列表[窗口索引].标题 = 新标题
    桌面.窗口列表[窗口索引].页面类型 = Nova原生桌面_AI页面_判断类型(url)
    桌面.窗口列表[窗口索引].页面标题 = 新标题
    桌面.窗口列表[窗口索引].页面源码 = ""
    桌面.窗口列表[窗口索引].页面DOM = 空
    桌面.窗口列表[窗口索引].页面最后动作 = "navigate-current"
    桌面.窗口列表[窗口索引].DOM文档 = Nova原生桌面_构建窗口文档(桌面.窗口列表[窗口索引])
    桌面.壳最后动作 = "navigate-window"
    桌面.壳最后结果 = "窗口导航到: " + url
    Nova原生桌面_同步文档状态()
    事件循环_导航(url)
    返回 真
}

函数 Nova原生桌面_获取当前页面上下文() {
    如果 (!桌面_已初始化) {
        返回 [0, "", "", "", "", "", "", 0, 0, 0]
    }
    定义 窗口索引 = Nova原生桌面_AI页面_获取焦点窗口索引()
    如果 (窗口索引 < 0) {
        返回 [0, "", "", "", "", "", "", 0, 0, 0]
    }
    Nova原生桌面_AI页面_确保窗口上下文_按索引(窗口索引)
    定义 窗口 = 桌面.窗口列表[窗口索引]
    定义 可变 摘要 = "页面源码未就绪"
    定义 可变 总节点数 = 0
    定义 可变 脚本数 = 0
    定义 可变 样式数 = 0
    如果 (窗口.页面DOM != 空) {
        摘要 = Nova原生桌面_AI页面_DOM摘要(窗口.页面DOM, 12)
        总节点数 = 窗口.页面DOM.总节点数
        脚本数 = 计数(窗口.页面DOM.脚本列表)
        样式数 = 计数(窗口.页面DOM.样式列表)
    }
    返回 [窗口.ID, 窗口.标题, 窗口.URL, 窗口.页面类型,
           窗口.页面标题, 窗口.页面源码, 摘要,
           总节点数, 脚本数, 样式数]
}

函数 Nova原生桌面_执行页面动作(动作, 参数1, 参数2) {
    如果 (!桌面_已初始化) { 返回 "desktop-not-ready" }
    如果 (动作 == "open-url") {
        定义 几何 = Nova原生桌面_建议窗口几何(计数(桌面.窗口列表) + 1)
        定义 窗口ID = Nova原生桌面_打开或聚焦窗口(参数1, 参数1, 几何[0], 几何[1], 几何[2], 几何[3])
        如果 (窗口ID > 0) { 返回 "open-url: " + 参数1 }
        返回 "open-url-failed: " + 参数1
    }
    如果 (动作 == "focus-url") {
        定义 窗口ID = Nova原生桌面_查找窗口ID_按URL(参数1)
        如果 (窗口ID > 0) {
            Nova原生桌面_聚焦窗口(窗口ID)
            返回 "focus-url: " + 参数1
        }
        返回 "focus-url-miss: " + 参数1
    }

    定义 窗口索引 = Nova原生桌面_AI页面_获取焦点窗口索引()
    如果 (窗口索引 < 0) { 返回 "no-focused-window" }

    如果 (动作 == "navigate-current") {
        如果 (Nova原生桌面_AI页面_导航当前窗口(窗口索引, 参数1, 参数1)) {
            返回 "navigate-current: " + 参数1
        }
        返回 "navigate-current-failed: " + 参数1
    }

    如果 (!Nova原生桌面_AI页面_确保窗口上下文_按索引(窗口索引)) {
        返回 "page-context-unavailable"
    }

    定义 文档 = 桌面.窗口列表[窗口索引].页面DOM
    如果 (文档 == 空) { 返回 "page-dom-unavailable" }

    如果 (动作 == "click-id") {
        定义 节点 = DOM_通过ID查找(文档, 参数1)
        如果 (节点 == 空) { 返回 "click-id-miss: " + 参数1 }
        定义 href = DOM_获取属性(文档, 节点.ID, "href")
        如果 (字符串长度(href) > 0) {
            定义 可变 目标标题 = 节点.文本内容
            如果 (字符串长度(目标标题) == 0) { 目标标题 = href }
            Nova原生桌面_AI页面_导航当前窗口(窗口索引, href, 目标标题)
            返回 "click-id: " + 参数1 + " -> " + href
        }
        DOM_设置属性(文档, 节点.ID, "data-ai-clicked", "1")
        桌面.窗口列表[窗口索引].页面最后动作 = "click-id:" + 参数1
        返回 "click-id: " + 参数1
    }

    如果 (动作 == "set-input-id") {
        定义 节点 = DOM_通过ID查找(文档, 参数1)
        如果 (节点 == 空) { 返回 "set-input-id-miss: " + 参数1 }
        如果 (节点.标签名 != "input" && 节点.标签名 != "textarea") {
            返回 "set-input-id-unsupported: " + 参数1
        }
        DOM_设置属性(文档, 节点.ID, "value", 参数2)
        桌面.窗口列表[窗口索引].页面最后动作 = "set-input-id:" + 参数1
        返回 "set-input-id: " + 参数1
    }

    返回 "unsupported-page-action: " + 动作
}

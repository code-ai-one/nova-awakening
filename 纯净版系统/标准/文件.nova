导入("../执行/平台时间.nova")
导入("../中枢/字符串工具完.nova")
导入("../中枢/内存初始化.nova")
导入("../执行/控制台输出.nova")
导入("../中枢/整数转字符串.nova")

定义 文件_只读 = 0
定义 文件_只写 = 1
定义 文件_读写 = 2
定义 文件_创建 = 0x40
定义 文件_截断 = 0x200
定义 文件_追加 = 0x400
定义 定位_起始 = 0
定义 定位_当前 = 1
定义 定位_末尾 = 2
定义 调用号_打开 = 2
定义 调用号_关闭 = 3
定义 调用号_读 = 0
定义 调用号_写 = 1
定义 调用号_定位 = 8
定义 调用号_状态 = 4
定义 调用号_删除 = 87
定义 调用号_重命名 = 82
定义 缓冲大小 = 4096

定义 可变 打开文件数 = 0
定义 可变 读总字节 = 0
定义 可变 写总字节 = 0

函数 文件_打开(路径, 标志) {
    定义 描述 = 系统调用(调用号_打开, 路径, 标志, 0x1B6, 0, 0)
    如果 (描述 >= 0) { 打开文件数 = 打开文件数 + 1 }
    返回 描述
}

函数 文件_关闭(描述) {
    如果 (描述 < 0) { 返回 错误_无效参数 }
    打开文件数 = 打开文件数 - 1
    返回 系统调用(调用号_关闭, 描述, 0, 0, 0, 0)
}

函数 文件_读(描述, 缓冲, 大小) {
    如果 (描述 < 0) { 返回 错误_无效参数 }
    定义 已读 = 系统调用(调用号_读, 描述, 缓冲, 大小, 0, 0)
    如果 (已读 > 0) { 读总字节 = 读总字节 + 已读 }
    返回 已读
}

函数 文件_写(描述, 数据, 大小) {
    如果 (描述 < 0) { 返回 错误_无效参数 }
    定义 已写 = 系统调用(调用号_写, 描述, 数据, 大小, 0, 0)
    如果 (已写 > 0) { 写总字节 = 写总字节 + 已写 }
    返回 已写
}

函数 文件_定位(描述, 偏移, 起点) {
    如果 (描述 < 0) { 返回 错误_无效参数 }
    返回 系统调用(调用号_定位, 描述, 偏移, 起点, 0, 0)
}

函数 文件_获取大小(描述) {
    定义 当前 = 文件_定位(描述, 0, 定位_当前)
    定义 末尾 = 文件_定位(描述, 0, 定位_末尾)
    文件_定位(描述, 当前, 定位_起始)
    返回 末尾
}

函数 文件_存在(路径) {
    定义 描述 = 文件_打开(路径, 文件_只读)
    如果 (描述 >= 0) { 文件_关闭(描述); 返回 真 }
    返回 假
}

函数 文件_读全部(路径) {
    定义 描述 = 文件_打开(路径, 文件_只读)
    如果 (描述 < 0) { 返回 0 }
    定义 大小 = 文件_获取大小(描述)
    如果 (大小 <= 0) { 文件_关闭(描述); 返回 0 }
    定义 缓冲 = 堆_分配(大小 + 1)
    如果 (缓冲 == 0) { 文件_关闭(描述); 返回 0 }
    文件_定位(描述, 0, 定位_起始)
    定义 可变 已读总 = 0
    当 (已读总 < 大小) {
        定义 本次 = 文件_读(描述, 缓冲 + 已读总, 大小 - 已读总)
        如果 (本次 <= 0) { 跳出 }
        已读总 = 已读总 + 本次
    }
    内存_写8(缓冲 + 已读总, 0)
    文件_关闭(描述)
    返回 缓冲
}

函数 文件_写全部(路径, 数据, 大小) {
    定义 描述 = 文件_打开(路径, 文件_只写 | 文件_创建 | 文件_截断)
    如果 (描述 < 0) { 返回 描述 }
    定义 可变 已写总 = 0
    当 (已写总 < 大小) {
        定义 本次 = 文件_写(描述, 数据 + 已写总, 大小 - 已写总)
        如果 (本次 <= 0) { 跳出 }
        已写总 = 已写总 + 本次
    }
    文件_关闭(描述)
    返回 已写总
}

函数 文件_追加写(路径, 数据, 大小) {
    定义 描述 = 文件_打开(路径, 文件_只写 | 文件_创建 | 文件_追加)
    如果 (描述 < 0) { 返回 描述 }
    定义 已写 = 文件_写(描述, 数据, 大小)
    文件_关闭(描述)
    返回 已写
}

函数 文件_删除(路径) {
    返回 系统调用(调用号_删除, 路径, 0, 0, 0, 0)
}

函数 文件_重命名(旧路径, 新路径) {
    返回 系统调用(调用号_重命名, 旧路径, 新路径, 0, 0, 0)
}

函数 文件_复制(源路径, 目标路径) {
    定义 数据 = 文件_读全部(源路径)
    如果 (数据 == 0) { 返回 错误_不存在 }
    定义 大小 = 字串_长度(数据)
    返回 文件_写全部(目标路径, 数据, 大小)
}

函数 文件_读行(描述) {
    定义 行缓冲 = 堆_分配(1024)
    定义 可变 行长 = 0
    定义 可变 完成 = 假
    当 (!完成 && 行长 < 1023) {
        定义 字节缓冲 = 堆_分配(1)
        定义 已读 = 文件_读(描述, 字节缓冲, 1)
        如果 (已读 <= 0) { 完成 = 真; 继续 }
        定义 字节 = 内存_读8(字节缓冲)
        堆_释放(字节缓冲)
        如果 (字节 == 10) { 完成 = 真 }
        否则 如果 (字节 != 13) {
            内存_写8(行缓冲 + 行长, 字节)
            行长 = 行长 + 1
        }
    }
    内存_写8(行缓冲 + 行长, 0)
    如果 (行长 == 0) { 堆_释放(行缓冲); 返回 0 }
    返回 行缓冲
}

函数 文件_完整统计() {
    返回 [打开文件数, 读总字节, 写总字节]
}

// §2 目录操作

定义 调用号_创建目录 = 83
定义 调用号_删除目录 = 84
定义 调用号_获取目录项 = 78
定义 调用号_获取工作目录 = 79
定义 调用号_切换工作目录 = 80

函数 目录_创建(路径, 模式) {
    返回 系统调用(调用号_创建目录, 路径, 模式, 0, 0, 0)
}

函数 目录_创建默认(路径) {
    返回 目录_创建(路径, 0o755)
}

函数 目录_删除(路径) {
    返回 系统调用(调用号_删除目录, 路径, 0, 0, 0, 0)
}

函数 目录_获取工作目录() {
    定义 缓冲 = 堆_分配(4096)
    如果 (缓冲 == 0) { 返回 0 }
    定义 结果 = 系统调用(调用号_获取工作目录, 缓冲, 4096, 0, 0, 0)
    如果 (结果 < 0) { 堆_释放(缓冲); 返回 0 }
    返回 缓冲
}

函数 目录_切换工作目录(路径) {
    返回 系统调用(调用号_切换工作目录, 路径, 0, 0, 0, 0)
}

函数 目录_存在(路径) {
    定义 状态 = 文件_状态(路径)
    如果 (状态 == 0) { 返回 假 }
    返回 (状态.模式 & 0o170000) == 0o040000
}

// §3 文件状态与属性

结构 文件状态 {
    设备号,
    节点号,
    链接数,
    模式,
    用户ID,
    组ID,
    大小,
    块数,
    块大小,
    访问时间,
    修改时间,
    创建时间,
}

函数 文件_状态(路径) {
    定义 缓冲 = 堆_分配(144)
    如果 (缓冲 == 0) { 返回 0 }
    定义 结果 = 系统调用(调用号_状态, 路径, 缓冲, 0, 0, 0)
    如果 (结果 < 0) { 堆_释放(缓冲); 返回 0 }
    定义 状态 = 文件状态 {}
    状态.设备号 = 内存_读64(缓冲)
    状态.节点号 = 内存_读64(缓冲 + 8)
    状态.链接数 = 内存_读64(缓冲 + 16)
    状态.模式 = 内存_读32(缓冲 + 24)
    状态.用户ID = 内存_读32(缓冲 + 28)
    状态.组ID = 内存_读32(缓冲 + 32)
    状态.大小 = 内存_读64(缓冲 + 48)
    状态.块数 = 内存_读64(缓冲 + 56)
    状态.块大小 = 内存_读64(缓冲 + 64)
    堆_释放(缓冲)
    返回 状态
}

函数 文件_大小(路径) {
    定义 状态 = 文件_状态(路径)
    如果 (状态 == 0) { 返回 -1 }
    返回 状态.大小
}

函数 文件_是普通文件(路径) {
    定义 状态 = 文件_状态(路径)
    如果 (状态 == 0) { 返回 假 }
    返回 (状态.模式 & 0o170000) == 0o100000
}

函数 文件_是目录(路径) {
    返回 目录_存在(路径)
}

函数 文件_是符号链接(路径) {
    定义 状态 = 文件_状态(路径)
    如果 (状态 == 0) { 返回 假 }
    返回 (状态.模式 & 0o170000) == 0o120000
}

函数 文件_权限(路径) {
    定义 状态 = 文件_状态(路径)
    如果 (状态 == 0) { 返回 0 }
    返回 状态.模式 & 0o777
}

// §4 缓冲IO

结构 缓冲文件 {
    描述符,
    缓冲,
    缓冲大小,
    已用,
    模式,
    已关闭,
}

函数 缓冲文件_打开(路径, 标志) {
    定义 fd = 文件_打开(路径, 标志)
    如果 (fd < 0) { 返回 0 }
    定义 bf = 缓冲文件 {}
    bf.描述符 = fd
    bf.缓冲 = 堆_分配(缓冲大小)
    bf.缓冲大小 = 缓冲大小
    bf.已用 = 0
    bf.模式 = 标志
    bf.已关闭 = 假
    返回 bf
}

函数 缓冲文件_写(bf, 数据, 大小) {
    如果 (bf == 0 || bf.已关闭) { 返回 错误_无效参数 }
    如果 (bf.已用 + 大小 > bf.缓冲大小) {
        缓冲文件_刷新(bf)
    }
    如果 (大小 >= bf.缓冲大小) {
        返回 文件_写(bf.描述符, 数据, 大小)
    }
    内存_复制(bf.缓冲 + bf.已用, 数据, 大小)
    bf.已用 = bf.已用 + 大小
    返回 大小
}

函数 缓冲文件_刷新(bf) {
    如果 (bf == 0 || bf.已用 == 0) { 返回 }
    文件_写(bf.描述符, bf.缓冲, bf.已用)
    bf.已用 = 0
}

函数 缓冲文件_关闭(bf) {
    如果 (bf == 0 || bf.已关闭) { 返回 }
    缓冲文件_刷新(bf)
    文件_关闭(bf.描述符)
    堆_释放(bf.缓冲)
    bf.已关闭 = 真
}

// §5 路径操作

函数 路径_扩展名(路径) {
    如果 (路径 == 0) { 返回 0 }
    定义 长度 = 字串_长度(路径)
    定义 可变 i = 长度 - 1
    当 (i >= 0) {
        定义 ch = 字节取(路径, i)
        如果 (ch == 46) { 返回 路径 + i + 1 }
        如果 (ch == 47) { 返回 0 }
        i = i - 1
    }
    返回 0
}

函数 路径_文件名(路径) {
    如果 (路径 == 0) { 返回 0 }
    定义 长度 = 字串_长度(路径)
    定义 可变 最后斜杠 = -1
    定义 可变 i = 0
    当 (i < 长度) {
        如果 (字节取(路径, i) == 47) { 最后斜杠 = i }
        i = i + 1
    }
    如果 (最后斜杠 < 0) { 返回 路径 }
    返回 路径 + 最后斜杠 + 1
}

函数 路径_目录名(路径) {
    如果 (路径 == 0) { 返回 0 }
    定义 长度 = 字串_长度(路径)
    定义 可变 最后斜杠 = -1
    定义 可变 i = 0
    当 (i < 长度) {
        如果 (字节取(路径, i) == 47) { 最后斜杠 = i }
        i = i + 1
    }
    如果 (最后斜杠 <= 0) { 返回 "/" }
    定义 结果 = 堆_分配(最后斜杠 + 1)
    内存_复制(结果, 路径, 最后斜杠)
    内存_写8(结果 + 最后斜杠, 0)
    返回 结果
}

函数 路径_拼接(基路径, 子路径) {
    如果 (基路径 == 0) { 返回 子路径 }
    如果 (子路径 == 0) { 返回 基路径 }
    定义 基长 = 字串_长度(基路径)
    定义 子长 = 字串_长度(子路径)
    定义 需要斜杠 = 基长 > 0 && 字节取(基路径, 基长 - 1) != 47
    定义 总长 = 基长 + 子长 + (需要斜杠 ? 1 : 0) + 1
    定义 结果 = 堆_分配(总长)
    内存_复制(结果, 基路径, 基长)
    如果 (需要斜杠) { 内存_写8(结果 + 基长, 47); 基长 = 基长 + 1 }
    内存_复制(结果 + 基长, 子路径, 子长)
    内存_写8(结果 + 基长 + 子长, 0)
    返回 结果
}

函数 路径_是绝对(路径) {
    如果 (路径 == 0) { 返回 假 }
    返回 字节取(路径, 0) == 47
}

// §6 文件读写辅助

函数 文件_读字符串(路径) {
    返回 文件_读全部(路径)
}

函数 文件_写字符串(路径, 文本) {
    如果 (文本 == 0) { 返回 0 }
    返回 文件_写全部(路径, 文本, 字串_长度(文本))
}

函数 文件_追加字符串(路径, 文本) {
    如果 (文本 == 0) { 返回 0 }
    返回 文件_追加写(路径, 文本, 字串_长度(文本))
}

函数 文件_读行列表(路径) {
    定义 描述 = 文件_打开(路径, 文件_只读)
    如果 (描述 < 0) { 返回 [] }
    定义 可变 行列表 = []
    定义 可变 行 = 文件_读行(描述)
    当 (行 != 0) {
        追加(行列表, 行)
        行 = 文件_读行(描述)
    }
    文件_关闭(描述)
    返回 行列表
}

函数 文件_写行列表(路径, 行列表) {
    定义 描述 = 文件_打开(路径, 文件_只写 | 文件_创建 | 文件_截断)
    如果 (描述 < 0) { 返回 描述 }
    定义 可变 i = 0
    当 (i < 计数(行列表)) {
        定义 行 = 行列表[i]
        文件_写(描述, 行, 字串_长度(行))
        文件_写(描述, "\n", 1)
        i = i + 1
    }
    文件_关闭(描述)
    返回 0
}

// §7 文件权限常量

定义 权限_所有者读 = 0o400
定义 权限_所有者写 = 0o200
定义 权限_所有者执 = 0o100
定义 权限_组读 = 0o040
定义 权限_组写 = 0o020
定义 权限_组执 = 0o010
定义 权限_其他读 = 0o004
定义 权限_其他写 = 0o002
定义 权限_其他执 = 0o001
定义 权限_全部读写 = 0o666
定义 权限_全部读写执 = 0o777
定义 权限_默认文件 = 0o644
定义 权限_默认目录 = 0o755

// §8 文件IO统计与健康检查

定义 可变 文件_打开总次数 = 0
定义 可变 文件_关闭总次数 = 0
定义 可变 文件_读总次数 = 0
定义 可变 文件_写总次数 = 0
定义 可变 文件_打开失败数 = 0
定义 可变 文件_读失败数 = 0
定义 可变 文件_写失败数 = 0

函数 文件IO_统计() {
    返回 {
        打开文件: 打开文件数,
        读字节: 读总字节,
        写字节: 写总字节,
        打开次数: 文件_打开总次数,
        关闭次数: 文件_关闭总次数,
        读次数: 文件_读总次数,
        写次数: 文件_写总次数,
        打开失败: 文件_打开失败数,
        读失败: 文件_读失败数,
        写失败: 文件_写失败数,
    }
}

函数 文件IO_健康检查() {
    定义 可变 问题 = []
    如果 (打开文件数 > 1024) {
        追加(问题, "打开文件数过多: " + 整数转字符串(打开文件数))
    }
    如果 (文件_打开失败数 > 文件_打开总次数 / 3 && 文件_打开总次数 > 100) {
        追加(问题, "文件打开失败率过高")
    }
    如果 (文件_读失败数 > 文件_读总次数 / 5 && 文件_读总次数 > 100) {
        追加(问题, "文件读取失败率过高")
    }
    如果 (计数(问题) == 0) { 返回 "文件IO健康" }
    返回 问题
}

函数 文件IO_重置统计() {
    文件_打开总次数 = 0
    文件_关闭总次数 = 0
    文件_读总次数 = 0
    文件_写总次数 = 0
    文件_打开失败数 = 0
    文件_读失败数 = 0
    文件_写失败数 = 0
    读总字节 = 0
    写总字节 = 0
}

函数 文件IO_读写比() {
    如果 (写总字节 == 0) { 返回 0 }
    返回 读总字节 * 100 / 写总字节
}

函数 文件IO_泄漏数() {
    返回 文件_打开总次数 - 文件_关闭总次数
}

// §9 临时文件

定义 可变 临时文件_计数器 = 0

函数 临时文件_创建(前缀) {
    临时文件_计数器 = 临时文件_计数器 + 1
    定义 路径 = "/tmp/" + 前缀 + "_" + 整数转字符串(临时文件_计数器)
    定义 fd = 文件_打开(路径, 文件_读写 | 文件_创建 | 文件_截断)
    如果 (fd < 0) { 返回 0 }
    返回 { 描述符: fd, 路径: 路径 }
}

函数 临时文件_删除(临时) {
    如果 (临时 == 0) { 返回 }
    文件_关闭(临时.描述符)
    文件_删除(临时.路径)
}

定义 可变 AI_文件_热文件表 = []

函数 AI_文件_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_文件_热文件表)) {
        如果 (AI_文件_热文件表[i].路径 == 路径) {
            AI_文件_热文件表[i].频率 = AI_文件_热文件表[i].频率 + 1
            返回 AI_文件_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_文件_热文件表) < 128) {
        追加(AI_文件_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_文件_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

// §3 图层合成 + Alpha混合

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/中断表注册处.nova")
导入("../引导/端口输入.nova")
导入("../中枢/整数转字符串.nova")

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 合成器_合成帧() {
    如果 (!合成器_已初始化) { 返回 }

    // 清空后缓冲(桌面背景色)
    像素_填充矩形(后缓冲, 0, 0, 屏幕宽, 屏幕高, 0x1a1a2e)

    // 按图层+Z序从底到顶合成
    定义 可变 图层 = 0
    当 (图层 <= 图层_鼠标) {
        定义 可变 i = 0
        当 (i < 计数(所有窗口)) {
            如果 (所有窗口[i].图层 == 图层 && 所有窗口[i].可见 &&
                所有窗口[i].状态 != 窗口状态_最小化) {
                合成器_绘制窗口(所有窗口[i])
            }
            i = i + 1
        }
        图层 = 图层 + 1
    }

    // 交换前后缓冲
    定义 tmp = 前缓冲
    前缓冲 = 后缓冲
    后缓冲 = tmp
    合成_帧数 = 合成_帧数 + 1
    合成_脏区域 = []
}

函数 合成器_绘制窗口(win) {
    // 绘制窗口装饰(标题栏+边框)
    如果 (win.装饰_启用) {
        定义 标题栏高 = 30
        定义 边框色 = 0x333355
        如果 (win.有焦点) { 边框色 = 0x6666ff }
        // 标题栏
        像素_填充矩形(后缓冲, win.x, win.y - 标题栏高, win.宽, 标题栏高, 边框色)
        // 边框
        像素_填充矩形(后缓冲, win.x - 1, win.y - 标题栏高, 1, win.高 + 标题栏高, 边框色)
        像素_填充矩形(后缓冲, win.x + win.宽, win.y - 标题栏高, 1, win.高 + 标题栏高, 边框色)
        像素_填充矩形(后缓冲, win.x, win.y + win.高, win.宽, 1, 边框色)
    }

    // 合成窗口内容(alpha混合)
    如果 (win.缓冲地址 != 0 && win.透明度 > 0) {
        如果 (win.透明度 >= 255) {
            // 不透明: 直接复制
            像素_复制区域(后缓冲, win.x, win.y, win.缓冲地址, win.宽, win.高)
        } 否则 {
            // 半透明: alpha混合
            像素_alpha混合(后缓冲, win.x, win.y, win.缓冲地址, win.宽, win.高, win.透明度)
        }
    }
}

函数 合成器_标记脏(x, y, w, h) {
    追加(合成_脏区域, [x, y, w, h])
}

// §4 像素操作

函数 像素_填充矩形(fb, x, y, w, h, 颜色) {
    定义 bpp = 屏幕位深 / 8
    定义 行字节 = 屏幕宽 * bpp
    定义 可变 dy = 0
    当 (dy < h) {
        定义 可变 dx = 0
        定义 偏移 = (y + dy) * 行字节 + (x + dx) * bpp
        当 (dx < w) {
            如果 (x + dx >= 0 && x + dx < 屏幕宽 && y + dy >= 0 && y + dy < 屏幕高) {
                内存写32(fb + 偏移 + dx * bpp, 颜色)
            }
            dx = dx + 1
        }
        dy = dy + 1
    }
}

函数 像素_复制区域(fb, 目标x, 目标y, 源地址, w, h) {
    定义 bpp = 屏幕位深 / 8
    定义 目标行字节 = 屏幕宽 * bpp
    定义 源行字节 = w * bpp
    定义 可变 dy = 0
    当 (dy < h) {
        如果 (目标y + dy >= 0 && 目标y + dy < 屏幕高) {
            定义 目标偏移 = (目标y + dy) * 目标行字节 + 目标x * bpp
            定义 源偏移 = dy * 源行字节
            内存拷贝(fb + 目标偏移, 源地址 + 源偏移, 源行字节)
        }
        dy = dy + 1
    }
}

函数 像素_alpha混合(fb, 目标x, 目标y, 源地址, w, h, alpha) {
    定义 bpp = 屏幕位深 / 8
    定义 目标行字节 = 屏幕宽 * bpp
    定义 可变 dy = 0
    当 (dy < h) {
        定义 可变 dx = 0
        当 (dx < w) {
            如果 (目标x + dx >= 0 && 目标x + dx < 屏幕宽 &&
                目标y + dy >= 0 && 目标y + dy < 屏幕高) {
                定义 目标偏移 = (目标y + dy) * 目标行字节 + (目标x + dx) * bpp
                定义 源偏移 = dy * w * bpp + dx * bpp
                定义 dst = 内存读32(fb + 目标偏移)
                定义 src = 内存读32(源地址 + 源偏移)
                定义 混合 = 颜色_alpha混合(dst, src, alpha)
                内存写32(fb + 目标偏移, 混合)
            }
            dx = dx + 1
        }
        dy = dy + 1
    }
}

函数 颜色_alpha混合(底色, 顶色, alpha) {
    定义 r1 = (底色 >> 16) & 0xFF
    定义 g1 = (底色 >> 8) & 0xFF
    定义 b1 = 底色 & 0xFF
    定义 r2 = (顶色 >> 16) & 0xFF
    定义 g2 = (顶色 >> 8) & 0xFF
    定义 b2 = 顶色 & 0xFF
    定义 r = (r1 * (255 - alpha) + r2 * alpha) / 255
    定义 g = (g1 * (255 - alpha) + g2 * alpha) / 255
    定义 b = (b1 * (255 - alpha) + b2 * alpha) / 255
    返回 (r << 16) | (g << 8) | b
}

函数 像素_画点(fb, x, y, 颜色) {
    如果 (x < 0 || x >= 屏幕宽 || y < 0 || y >= 屏幕高) { 返回 }
    定义 偏移 = (y * 屏幕宽 + x) * (屏幕位深 / 8)
    内存写32(fb + 偏移, 颜色)
}

函数 像素_读点(fb, x, y) {
    如果 (x < 0 || x >= 屏幕宽 || y < 0 || y >= 屏幕高) { 返回 0 }
    定义 偏移 = (y * 屏幕宽 + x) * (屏幕位深 / 8)
    返回 内存读32(fb + 偏移)
}

// §5 图形绘制扩展

函数 像素_画水平线(fb, x, y, 长度, 颜色) {
    定义 可变 i = 0
    当 (i < 长度) {
        像素_画点(fb, x + i, y, 颜色)
        i = i + 1
    }
}

函数 像素_画垂直线(fb, x, y, 长度, 颜色) {
    定义 可变 i = 0
    当 (i < 长度) {
        像素_画点(fb, x, y + i, 颜色)
        i = i + 1
    }
}

函数 像素_画矩形边框(fb, x, y, w, h, 颜色) {
    像素_画水平线(fb, x, y, w, 颜色)
    像素_画水平线(fb, x, y + h - 1, w, 颜色)
    像素_画垂直线(fb, x, y, h, 颜色)
    像素_画垂直线(fb, x + w - 1, y, h, 颜色)
}

函数 像素_填充渐变_水平(fb, x, y, w, h, 起始色, 结束色) {
    定义 可变 dx = 0
    当 (dx < w) {
        定义 比例 = dx * 255 / w
        定义 颜色 = 颜色_线性插值(起始色, 结束色, 比例)
        像素_画垂直线(fb, x + dx, y, h, 颜色)
        dx = dx + 1
    }
}

函数 像素_填充渐变_垂直(fb, x, y, w, h, 起始色, 结束色) {
    定义 可变 dy = 0
    当 (dy < h) {
        定义 比例 = dy * 255 / h
        定义 颜色 = 颜色_线性插值(起始色, 结束色, 比例)
        像素_画水平线(fb, x, y + dy, w, 颜色)
        dy = dy + 1
    }
}

// §6 颜色操作

函数 颜色_创建(r, g, b) {
    返回 (r << 16) | (g << 8) | b
}

函数 颜色_创建RGBA(r, g, b, a) {
    返回 (a << 24) | (r << 16) | (g << 8) | b
}

函数 颜色_R(颜色) { 返回 (颜色 >> 16) & 0xFF }
函数 颜色_G(颜色) { 返回 (颜色 >> 8) & 0xFF }
函数 颜色_B(颜色) { 返回 颜色 & 0xFF }
函数 颜色_A(颜色) { 返回 (颜色 >> 24) & 0xFF }

函数 颜色_线性插值(c1, c2, t) {
    定义 r = (颜色_R(c1) * (255 - t) + 颜色_R(c2) * t) / 255
    定义 g = (颜色_G(c1) * (255 - t) + 颜色_G(c2) * t) / 255
    定义 b = (颜色_B(c1) * (255 - t) + 颜色_B(c2) * t) / 255
    返回 颜色_创建(r, g, b)
}

函数 颜色_变亮(颜色, 量) {
    定义 可变 r = 颜色_R(颜色) + 量
    定义 可变 g = 颜色_G(颜色) + 量
    定义 可变 b = 颜色_B(颜色) + 量
    如果 (r > 255) { r = 255 }
    如果 (g > 255) { g = 255 }
    如果 (b > 255) { b = 255 }
    返回 颜色_创建(r, g, b)
}

函数 颜色_变暗(颜色, 量) {
    定义 可变 r = 颜色_R(颜色) - 量
    定义 可变 g = 颜色_G(颜色) - 量
    定义 可变 b = 颜色_B(颜色) - 量
    如果 (r < 0) { r = 0 }
    如果 (g < 0) { g = 0 }
    如果 (b < 0) { b = 0 }
    返回 颜色_创建(r, g, b)
}

函数 颜色_反转(颜色) {
    返回 颜色_创建(255 - 颜色_R(颜色), 255 - 颜色_G(颜色), 255 - 颜色_B(颜色))
}

函数 颜色_灰度(颜色) {
    定义 灰 = (颜色_R(颜色) * 299 + 颜色_G(颜色) * 587 + 颜色_B(颜色) * 114) / 1000
    返回 颜色_创建(灰, 灰, 灰)
}

// §7 预定义颜色

定义 色_黑 = 0x000000
定义 色_白 = 0xFFFFFF
定义 色_红 = 0xFF0000
定义 色_绿 = 0x00FF00
定义 色_蓝 = 0x0000FF
定义 色_黄 = 0xFFFF00
定义 色_青 = 0x00FFFF
定义 色_品红 = 0xFF00FF
定义 色_灰 = 0x808080
定义 色_深灰 = 0x404040
定义 色_浅灰 = 0xC0C0C0
定义 色_橙 = 0xFF8000
定义 色_紫 = 0x8000FF
定义 色_深蓝 = 0x1a1a2e
定义 色_高亮蓝 = 0x6666ff
定义 色_标题栏 = 0x333355
定义 色_桌面背景 = 0x1a1a2e

// §8 合成器全局状态与常量

定义 可变 合成器_已初始化 = 假
定义 可变 前缓冲 = 0
定义 可变 后缓冲 = 0
定义 可变 屏幕宽 = 1920
定义 可变 屏幕高 = 1080
定义 可变 屏幕位深 = 32
定义 可变 合成_帧数 = 0
定义 可变 合成_脏区域 = []
定义 可变 所有窗口 = []

定义 图层_桌面 = 0
定义 图层_普通 = 1
定义 图层_浮动 = 2
定义 图层_通知 = 3
定义 图层_模态 = 4
定义 图层_鼠标 = 5

定义 窗口状态_正常 = 0
定义 窗口状态_最大化 = 1
定义 窗口状态_最小化 = 2
定义 窗口状态_全屏 = 3

// §9 合成器初始化与窗口管理

函数 合成器_初始化(帧缓冲地址, 宽, 高, 位深) {
    屏幕宽 = 宽
    屏幕高 = 高
    屏幕位深 = 位深
    定义 帧大小 = 宽 * 高 * (位深 / 8)
    前缓冲 = 帧缓冲地址
    后缓冲 = 堆_分配(帧大小)
    如果 (后缓冲 == 0) { 返回 错误_内存不足 }
    合成器_已初始化 = 真
    合成_帧数 = 0
    合成_脏区域 = []
    所有窗口 = []
    内核信息("合成器: 初始化完成 " + 整数转字符串(宽) + "x" + 整数转字符串(高) +
             " @" + 整数转字符串(位深) + "bpp")
    返回 0
}

函数 合成器_销毁() {
    如果 (!合成器_已初始化) { 返回 }
    如果 (后缓冲 != 0) { 堆_释放(后缓冲) }
    后缓冲 = 0
    前缓冲 = 0
    合成器_已初始化 = 假
    所有窗口 = []
}

函数 合成器_添加窗口(win) {
    如果 (!合成器_已初始化) { 返回 }
    追加(所有窗口, win)
    合成器_标记脏(win.x, win.y, win.宽, win.高)
}

函数 合成器_移除窗口(窗口ID) {
    定义 可变 新列表 = []
    定义 可变 i = 0
    当 (i < 计数(所有窗口)) {
        如果 (所有窗口[i].ID != 窗口ID) {
            追加(新列表, 所有窗口[i])
        }
        i = i + 1
    }
    所有窗口 = 新列表
}

函数 合成器_查找窗口(窗口ID) {
    定义 可变 i = 0
    当 (i < 计数(所有窗口)) {
        如果 (所有窗口[i].ID == 窗口ID) { 返回 所有窗口[i] }
        i = i + 1
    }
    返回 空
}

函数 合成器_窗口数() {
    返回 计数(所有窗口)
}

// §10 合成器统计与诊断

定义 可变 合成_丢帧数 = 0
定义 可变 合成_最大帧时间 = 0

函数 合成器_统计() {
    返回 {
        帧数: 合成_帧数,
        丢帧: 合成_丢帧数,
        窗口数: 计数(所有窗口),
        脏区域: 计数(合成_脏区域),
        屏幕宽: 屏幕宽,
        屏幕高: 屏幕高,
    }
}

函数 合成器_健康检查() {
    定义 可变 问题 = []
    如果 (!合成器_已初始化) { 追加(问题, "合成器未初始化"); 返回 问题 }
    如果 (合成_丢帧数 > 合成_帧数 / 10 && 合成_帧数 > 100) {
        追加(问题, "合成器丢帧率过高")
    }
    如果 (合成_最大帧时间 > 32000) {
        追加(问题, "最大帧时间超过32ms")
    }
    如果 (计数(所有窗口) > 200) {
        追加(问题, "窗口过多: " + 整数转字符串(计数(所有窗口)))
    }
    如果 (计数(问题) == 0) { 返回 "合成器健康" }
    返回 问题
}

函数 合成器_重置统计() {
    合成_帧数 = 0
    合成_丢帧数 = 0
    合成_最大帧时间 = 0
}

函数 合成器_完整统计() {
    返回 [合成_帧数, 合成_丢帧数, 计数(所有窗口), 屏幕宽, 屏幕高]
}

函数 合成器_窗口总面积() {
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(所有窗口)) {
        如果 (所有窗口[i].可见) {
            总 = 总 + 所有窗口[i].宽 * 所有窗口[i].高
        }
        i = i + 1
    }
    返回 总
}

函数 合成器_覆盖率() {
    定义 屏幕面积 = 屏幕宽 * 屏幕高
    如果 (屏幕面积 == 0) { 返回 0 }
    返回 合成器_窗口总面积() * 100 / 屏幕面积
}

定义 可变 AI_图层合成混_帧率窗口 = []

函数 AI_图层合成混_帧率预测(当前帧耗时) {
    追加(AI_图层合成混_帧率窗口, 当前帧耗时)
    如果 (计数(AI_图层合成混_帧率窗口) > 30) { 列表_移除(AI_图层合成混_帧率窗口, 0) }
    如果 (计数(AI_图层合成混_帧率窗口) < 3) { 返回 60 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(AI_图层合成混_帧率窗口)) { 总 = 总 + AI_图层合成混_帧率窗口[i]; i = i + 1 }
    定义 平均帧耗时 = 总 / 计数(AI_图层合成混_帧率窗口)
    如果 (平均帧耗时 == 0) { 返回 60 }
    返回 1000 / 平均帧耗时
}

函数 AI_图层合成混_质量降级建议(帧率) {
    如果 (帧率 < 30) { 返回 "降低分辨率" }
    如果 (帧率 < 45) { 返回 "跳过阴影" }
    返回 "全质量"
}

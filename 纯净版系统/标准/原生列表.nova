导入("../中枢/类型定义.nova")

函数 列表_查找(列表, 值) {
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] == 值) { 返回 i }
        i = i + 1
    }
    返回 0 - 1
}

函数 列表_包含(列表, 值) {
    返回 列表_查找(列表, 值) >= 0
}

函数 列表_最后查找(列表, 值) {
    定义 可变 i = 计数(列表) - 1
    当 (i >= 0) {
        如果 (列表[i] == 值) { 返回 i }
        i = i - 1
    }
    返回 0 - 1
}

函数 列表_统计(列表, 值) {
    定义 可变 次数 = 0
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] == 值) { 次数 = 次数 + 1 }
        i = i + 1
    }
    返回 次数
}

函数 列表_反转(列表) {
    定义 结果 = []
    定义 可变 i = 计数(列表) - 1
    当 (i >= 0) {
        追加(结果, 列表[i])
        i = i - 1
    }
    返回 结果
}

函数 列表_原地反转(列表) {
    定义 可变 左 = 0
    定义 可变 右 = 计数(列表) - 1
    当 (左 < 右) {
        定义 临时 = 列表[左]
        设置(列表, 左, 列表[右])
        设置(列表, 右, 临时)
        左 = 左 + 1
        右 = 右 - 1
    }
}

函数 列表_切片(列表, 开始, 结束) {
    定义 结果 = []
    如果 (开始 < 0) { 开始 = 0 }
    如果 (结束 > 计数(列表)) { 结束 = 计数(列表) }
    定义 可变 i = 开始
    当 (i < 结束) {
        追加(结果, 列表[i])
        i = i + 1
    }
    返回 结果
}

函数 列表_复制(列表) {
    定义 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        追加(结果, 列表[i])
        i = i + 1
    }
    返回 结果
}

函数 列表_连接(列表a, 列表b) {
    定义 结果 = 列表_复制(列表a)
    定义 可变 i = 0
    当 (i < 计数(列表b)) {
        追加(结果, 列表b[i])
        i = i + 1
    }
    返回 结果
}

函数 列表_最大(列表) {
    如果 (计数(列表) == 0) { 返回 空 }
    定义 可变 最大 = 列表[0]
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        如果 (列表[i] > 最大) { 最大 = 列表[i] }
        i = i + 1
    }
    返回 最大
}

函数 列表_最小(列表) {
    如果 (计数(列表) == 0) { 返回 空 }
    定义 可变 最小 = 列表[0]
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        如果 (列表[i] < 最小) { 最小 = 列表[i] }
        i = i + 1
    }
    返回 最小
}

函数 列表_求和(列表) {
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        和 = 和 + 列表[i]
        i = i + 1
    }
    返回 和
}

函数 列表_平均(列表) {
    如果 (计数(列表) == 0) { 返回 0 }
    返回 列表_求和(列表) / 计数(列表)
}

函数 列表_最大索引(列表) {
    如果 (计数(列表) == 0) { 返回 -1 }
    定义 可变 最大索引 = 0
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        如果 (列表[i] > 列表[最大索引]) { 最大索引 = i }
        i = i + 1
    }
    返回 最大索引
}

函数 列表_最小索引(列表) {
    如果 (计数(列表) == 0) { 返回 -1 }
    定义 可变 最小索引 = 0
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        如果 (列表[i] < 列表[最小索引]) { 最小索引 = i }
        i = i + 1
    }
    返回 最小索引
}

函数 列表_插入排序(列表) {
    定义 n = 计数(列表)
    定义 可变 i = 1
    当 (i < n) {
        定义 键 = 列表[i]
        定义 可变 j = i - 1
        当 (j >= 0 && 列表[j] > 键) {
            设置(列表, j + 1, 列表[j])
            j = j - 1
        }
        设置(列表, j + 1, 键)
        i = i + 1
    }
}

函数 列表_快速排序(列表) {
    如果 (计数(列表) <= 1) { 返回 列表 }
    如果 (计数(列表) <= 16) {
        定义 副本 = 列表_复制(列表)
        列表_插入排序(副本)
        返回 副本
    }
    定义 基准 = 列表[计数(列表) / 2]
    定义 小于 = []
    定义 等于 = []
    定义 大于 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] < 基准) { 追加(小于, 列表[i]) }
        否则 如果 (列表[i] == 基准) { 追加(等于, 列表[i]) }
        否则 { 追加(大于, 列表[i]) }
        i = i + 1
    }
    返回 列表_连接(列表_连接(列表_快速排序(小于), 等于), 列表_快速排序(大于))
}

函数 列表_已排序(列表) {
    定义 可变 i = 1
    当 (i < 计数(列表)) {
        如果 (列表[i] < 列表[i - 1]) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 列表_二分查找(列表, 值) {
    定义 可变 低 = 0
    定义 可变 高 = 计数(列表) - 1
    当 (低 <= 高) {
        定义 中 = (低 + 高) / 2
        如果 (列表[中] == 值) { 返回 中 }
        如果 (列表[中] < 值) { 低 = 中 + 1 }
        否则 { 高 = 中 - 1 }
    }
    返回 -1
}

函数 列表_去重(列表) {
    定义 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (!列表_包含(结果, 列表[i])) {
            追加(结果, 列表[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 列表_扁平化(列表) {
    定义 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        定义 元素 = 列表[i]
        如果 (是列表(元素)) {
            定义 子结果 = 列表_扁平化(元素)
            定义 可变 j = 0
            当 (j < 计数(子结果)) {
                追加(结果, 子结果[j])
                j = j + 1
            }
        } 否则 {
            追加(结果, 元素)
        }
        i = i + 1
    }
    返回 结果
}

函数 列表_压缩(列表a, 列表b) {
    定义 结果 = []
    定义 长度 = 计数(列表a)
    如果 (计数(列表b) < 长度) { 长度 = 计数(列表b) }
    定义 可变 i = 0
    当 (i < 长度) {
        追加(结果, [列表a[i], 列表b[i]])
        i = i + 1
    }
    返回 结果
}

函数 列表_填充(大小, 值) {
    定义 结果 = []
    定义 可变 i = 0
    当 (i < 大小) {
        追加(结果, 值)
        i = i + 1
    }
    返回 结果
}

函数 列表_范围(开始, 结束, 步长) {
    如果 (步长 == 0) { 步长 = 1 }
    定义 结果 = []
    如果 (步长 > 0) {
        定义 可变 i = 开始
        当 (i < 结束) { 追加(结果, i); i = i + 步长 }
    } 否则 {
        定义 可变 i = 开始
        当 (i > 结束) { 追加(结果, i); i = i + 步长 }
    }
    返回 结果
}

函数 列表_旋转左(列表, k) {
    定义 n = 计数(列表)
    如果 (n == 0) { 返回 列表 }
    k = k % n
    如果 (k < 0) { k = k + n }
    返回 列表_连接(列表_切片(列表, k, n), 列表_切片(列表, 0, k))
}

函数 列表_旋转右(列表, k) {
    定义 n = 计数(列表)
    如果 (n == 0) { 返回 列表 }
    k = k % n
    返回 列表_旋转左(列表, n - k)
}

函数 列表_交集(列表a, 列表b) {
    定义 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表a)) {
        如果 (列表_包含(列表b, 列表a[i]) && !列表_包含(结果, 列表a[i])) {
            追加(结果, 列表a[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 列表_并集(列表a, 列表b) {
    定义 结果 = 列表_去重(列表a)
    定义 可变 i = 0
    当 (i < 计数(列表b)) {
        如果 (!列表_包含(结果, 列表b[i])) {
            追加(结果, 列表b[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 列表_差集(列表a, 列表b) {
    定义 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表a)) {
        如果 (!列表_包含(列表b, 列表a[i])) {
            追加(结果, 列表a[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 列表_相等(列表a, 列表b) {
    如果 (计数(列表a) != 计数(列表b)) { 返回 假 }
    定义 可变 i = 0
    当 (i < 计数(列表a)) {
        如果 (列表a[i] != 列表b[i]) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 列表_分块(列表, 块大小) {
    如果 (块大小 <= 0) { 返回 [列表] }
    定义 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        定义 结束 = i + 块大小
        如果 (结束 > 计数(列表)) { 结束 = 计数(列表) }
        追加(结果, 列表_切片(列表, i, 结束))
        i = 结束
    }
    返回 结果
}

函数 列表_交换(列表, 索引a, 索引b) {
    如果 (索引a < 0 || 索引a >= 计数(列表)) { 返回 }
    如果 (索引b < 0 || 索引b >= 计数(列表)) { 返回 }
    定义 临时 = 列表[索引a]
    设置(列表, 索引a, 列表[索引b])
    设置(列表, 索引b, 临时)
}

函数 列表_洗牌(列表, 种子) {
    定义 n = 计数(列表)
    定义 副本 = 列表_复制(列表)
    定义 可变 状态 = 种子
    定义 可变 i = n - 1
    当 (i > 0) {
        状态 = (状态 * 1103515245 + 12345) & 0x7FFFFFFF
        定义 j = 状态 % (i + 1)
        列表_交换(副本, i, j)
        i = i - 1
    }
    返回 副本
}

// 堆排序 (HeapSort)

函数 _堆_下沉(列表, n, i) {
    定义 可变 最大 = i
    定义 左 = 2 * i + 1
    定义 右 = 2 * i + 2
    如果 (左 < n && 列表[左] > 列表[最大]) { 最大 = 左 }
    如果 (右 < n && 列表[右] > 列表[最大]) { 最大 = 右 }
    如果 (最大 != i) {
        列表_交换(列表, i, 最大)
        _堆_下沉(列表, n, 最大)
    }
}

函数 列表_堆排序(列表) {
    定义 副本 = 列表_复制(列表)
    定义 n = 计数(副本)
    // 构建最大堆
    定义 可变 i = n / 2 - 1
    当 (i >= 0) { _堆_下沉(副本, n, i); i = i - 1 }
    // 逐步取出堆顶
    i = n - 1
    当 (i > 0) {
        列表_交换(副本, 0, i)
        _堆_下沉(副本, i, 0)
        i = i - 1
    }
    返回 副本
}

// 归并排序 (MergeSort)

函数 _归并_合并(左, 右) {
    定义 结果 = []
    定义 可变 i = 0
    定义 可变 j = 0
    当 (i < 计数(左) && j < 计数(右)) {
        如果 (左[i] <= 右[j]) {
            追加(结果, 左[i])
            i = i + 1
        } 否则 {
            追加(结果, 右[j])
            j = j + 1
        }
    }
    当 (i < 计数(左)) { 追加(结果, 左[i]); i = i + 1 }
    当 (j < 计数(右)) { 追加(结果, 右[j]); j = j + 1 }
    返回 结果
}

函数 列表_归并排序(列表) {
    定义 n = 计数(列表)
    如果 (n <= 1) { 返回 列表_复制(列表) }
    定义 中 = n / 2
    定义 左 = 列表_归并排序(列表_切片(列表, 0, 中))
    定义 右 = 列表_归并排序(列表_切片(列表, 中, n))
    返回 _归并_合并(左, 右)
}

// 滑动窗口算法

函数 列表_滑动窗口(列表, 窗口大小) {
    定义 n = 计数(列表)
    定义 结果 = []
    如果 (窗口大小 <= 0 || 窗口大小 > n) { 返回 结果 }
    定义 可变 i = 0
    当 (i + 窗口大小 <= n) {
        追加(结果, 列表_切片(列表, i, i + 窗口大小))
        i = i + 1
    }
    返回 结果
}

函数 列表_滑动窗口求和(列表, 窗口大小) {
    定义 n = 计数(列表)
    定义 结果 = []
    如果 (窗口大小 <= 0 || 窗口大小 > n) { 返回 结果 }
    // 计算初始窗口和
    定义 可变 窗口和 = 0
    定义 可变 k = 0
    当 (k < 窗口大小) { 窗口和 = 窗口和 + 列表[k]; k = k + 1 }
    追加(结果, 窗口和)
    // 滑动
    定义 可变 i = 1
    当 (i + 窗口大小 <= n) {
        窗口和 = 窗口和 - 列表[i - 1] + 列表[i + 窗口大小 - 1]
        追加(结果, 窗口和)
        i = i + 1
    }
    返回 结果
}

函数 列表_滑动最大值(列表, 窗口大小) {
    定义 和列表 = 列表_滑动窗口求和(列表, 窗口大小)
    如果 (计数(和列表) == 0) { 返回 0 }
    返回 列表_最大(和列表)
}

// 前缀和 / 后缀和

函数 列表_前缀和(列表) {
    定义 n = 计数(列表)
    定义 结果 = [0]
    定义 可变 i = 0
    当 (i < n) {
        追加(结果, 结果[i] + 列表[i])
        i = i + 1
    }
    返回 结果
}

函数 列表_后缀和(列表) {
    定义 n = 计数(列表)
    定义 结果 = 列表_填充(n + 1, 0)
    定义 可变 i = n - 1
    当 (i >= 0) {
        结果[i] = 结果[i + 1] + 列表[i]
        i = i - 1
    }
    返回 结果
}

函数 列表_区间和(前缀, 左, 右) {
    // 基于前缀和数组的 O(1) 区间求和
    如果 (左 < 0) { 左 = 0 }
    如果 (右 >= 计数(前缀)) { 右 = 计数(前缀) - 1 }
    返回 前缀[右] - 前缀[左]
}

// 中位数选择 (QuickSelect)

函数 列表_第K小(列表, k) {
    // QuickSelect: 平均 O(n) 找第k小元素 (k从0开始)
    定义 n = 计数(列表)
    如果 (k < 0 || k >= n) { 返回 空 }
    定义 副本 = 列表_复制(列表)
    定义 可变 低 = 0
    定义 可变 高 = n - 1
    当 (低 < 高) {
        定义 基准 = 副本[高]
        定义 可变 分割点 = 低
        定义 可变 j = 低
        当 (j < 高) {
            如果 (副本[j] < 基准) {
                列表_交换(副本, 分割点, j)
                分割点 = 分割点 + 1
            }
            j = j + 1
        }
        列表_交换(副本, 分割点, 高)
        如果 (分割点 == k) { 返回 副本[分割点] }
        如果 (分割点 < k) { 低 = 分割点 + 1 }
        否则 { 高 = 分割点 - 1 }
    }
    返回 副本[低]
}

函数 列表_中位数(列表) {
    定义 n = 计数(列表)
    如果 (n == 0) { 返回 0 }
    返回 列表_第K小(列表, n / 2)
}

函数 列表_百分位(列表, 百分比) {
    // 百分比: ×1000 定点数 (500 = 50%)
    定义 n = 计数(列表)
    如果 (n == 0) { 返回 0 }
    定义 k = (百分比 * n) / 1000
    如果 (k >= n) { k = n - 1 }
    如果 (k < 0) { k = 0 }
    返回 列表_第K小(列表, k)
}

// 【原生独创】惯性自适应排序 — 利用序列势能加速排序
//  检测已有有序子序列(“惯性跑道”)，合并时复用它们的势能

函数 列表_惯性排序(列表) {
    定义 n = 计数(列表)
    如果 (n <= 1) { 返回 列表_复制(列表) }
    // 第一步: 检测自然跑道
    定义 跑道列表 = []
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 j = i + 1
        // 检测升序跑道
        如果 (j < n && 列表[j] >= 列表[j - 1]) {
            当 (j < n && 列表[j] >= 列表[j - 1]) { j = j + 1 }
            追加(跑道列表, 列表_切片(列表, i, j))
        } 否则 如果 (j < n && 列表[j] < 列表[j - 1]) {
            // 检测降序跑道，反转为升序
            当 (j < n && 列表[j] < 列表[j - 1]) { j = j + 1 }
            追加(跑道列表, 列表_反转(列表_切片(列表, i, j)))
        } 否则 {
            追加(跑道列表, [列表[i]])
        }
        i = j
    }
    // 第二步: 反复合并相邻跑道
    当 (计数(跑道列表) > 1) {
        定义 新跑道 = []
        定义 可变 k = 0
        当 (k + 1 < 计数(跑道列表)) {
            追加(新跑道, _归并_合并(跑道列表[k], 跑道列表[k + 1]))
            k = k + 2
        }
        如果 (k < 计数(跑道列表)) {
            追加(新跑道, 跑道列表[k])
        }
        跑道列表 = 新跑道
    }
    返回 跑道列表[0]
}

// 高级列表操作

函数 列表_枝叉分离(列表, 谓词) {
    // 将列表分离为满足和不满足谓词的两部分
    定义 真部 = []
    定义 假部 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (谓词(列表[i])) {
            追加(真部, 列表[i])
        } 否则 {
            追加(假部, 列表[i])
        }
        i = i + 1
    }
    返回 [真部, 假部]
}

函数 列表_累积(列表, 初始值, 累积函数) {
    定义 可变 累加器 = 初始值
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        累加器 = 累积函数(累加器, 列表[i])
        i = i + 1
    }
    返回 累加器
}

函数 列表_扫描(列表, 初始值, 扫描函数) {
    // 类似前缀和的通用版本
    定义 结果 = [初始值]
    定义 可变 累加器 = 初始值
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        累加器 = 扫描函数(累加器, 列表[i])
        追加(结果, 累加器)
        i = i + 1
    }
    返回 结果
}

函数 列表_去连续重复(列表) {
    定义 n = 计数(列表)
    如果 (n == 0) { 返回 [] }
    定义 结果 = [列表[0]]
    定义 可变 i = 1
    当 (i < n) {
        如果 (列表[i] != 列表[i - 1]) {
            追加(结果, 列表[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 列表_频率统计(列表) {
    // 返回 [[元素, 次数], ...]
    定义 键 = []
    定义 值 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        定义 可变 找到 = 假
        定义 可变 j = 0
        当 (j < 计数(键)) {
            如果 (键[j] == 列表[i]) {
                值[j] = 值[j] + 1
                找到 = 真
                跳出
            }
            j = j + 1
        }
        如果 (!找到) {
            追加(键, 列表[i])
            追加(值, 1)
        }
        i = i + 1
    }
    定义 结果 = []
    i = 0
    当 (i < 计数(键)) {
        追加(结果, [键[i], 值[i]])
        i = i + 1
    }
    返回 结果
}

函数 列表_连续子序列最大和(列表) {
    // Kadane算法: O(n) 求最大子数组和
    定义 n = 计数(列表)
    如果 (n == 0) { 返回 0 }
    定义 可变 当前和 = 列表[0]
    定义 可变 最大和 = 列表[0]
    定义 可变 i = 1
    当 (i < n) {
        如果 (当前和 + 列表[i] > 列表[i]) {
            当前和 = 当前和 + 列表[i]
        } 否则 {
            当前和 = 列表[i]
        }
        如果 (当前和 > 最大和) { 最大和 = 当前和 }
        i = i + 1
    }
    返回 最大和
}

// 完整统计

函数 列表_完整统计() {
    返回 [
        "模块", "原生列表",
        "基础查找函数", 6,
        "切片复制函数", 4,
        "统计聚合函数", 6,
        "插入排序函数", 2,
        "快速排序函数", 2,
        "堆排序函数", 2,
        "归并排序函数", 2,
        "惯性排序函数", 1,
        "二分查找函数", 1,
        "集合操作函数", 4,
        "滑动窗口函数", 3,
        "前缀和函数", 3,
        "中位数百分位函数", 3,
        "高级操作函数", 7,
        "总函数数", 58
    ]
}

定义 可变 AI_原生列表_操作热度 = 0

函数 AI_原生列表_最优算法(数据量, 已排序) {
    AI_原生列表_操作热度 = AI_原生列表_操作热度 + 1
    如果 (数据量 < 16) { 返回 "插入排序" }
    如果 (已排序) { 返回 "二分查找" }
    如果 (数据量 < 10000) { 返回 "快速排序" }
    返回 "归并排序"
}

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/原生系统块分.nova")
导入("../引导/端口输入.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/整数转字符串.nova")

定义 FAT32_簇结束标记 = 0x0FFFFFF8
定义 FAT32_空闲簇 = 0x00000000
定义 FAT32_坏簇 = 0x0FFFFFF7
定义 FAT32_目录项大小 = 32
定义 FAT32_属性_只读 = 0x01
定义 FAT32_属性_隐藏 = 0x02
定义 FAT32_属性_系统 = 0x04
定义 FAT32_属性_卷标 = 0x08
定义 FAT32_属性_目录 = 0x10
定义 FAT32_属性_归档 = 0x20
定义 FAT32_属性_长名 = 0x0F

结构 FAT32挂载信息 {
    设备,
    扇区大小,
    每簇扇区数,
    保留扇区数,
    FAT数量,
    每FAT扇区数,
    根目录簇,
    数据区起始扇区,
    总簇数,
    空闲簇数,
    下一空闲簇,
    锁,
}

结构 FAT32目录项 {
    名称,
    扩展名,
    属性,
    创建时间,
    修改时间,
    起始簇,
    文件大小,
}

定义 可变 FAT32_挂载列表 = []

函数 FAT32_VFS注册() {
    VFS_注册文件系统("vfat", FAT32_挂载, FAT32_读文件, FAT32_写文件, FAT32_读目录, FAT32_查找)
    VFS_注册文件系统("fat32", FAT32_挂载, FAT32_读文件, FAT32_写文件, FAT32_读目录, FAT32_查找)
    内核信息("FAT32: VFS注册完成")
}

函数 FAT32_挂载(设备, 挂载点) {
    定义 buf = 分配内存(512)
    如果 (buf == 0) { 返回 错误_内存不足 }

    定义 ret = 块设备_读(设备, 0, 1, buf)
    如果 (ret < 0) { 释放内存(buf); 返回 ret }

    定义 签名 = 内存读16(buf + 510)
    如果 (签名 != 0xAA55) { 释放内存(buf); 返回 错误_格式 }

    定义 信息 = FAT32挂载信息 {}
    信息.设备 = 设备
    信息.扇区大小 = 内存读16(buf + 11)
    信息.每簇扇区数 = 内存读8(buf + 13)
    信息.保留扇区数 = 内存读16(buf + 14)
    信息.FAT数量 = 内存读8(buf + 16)
    信息.每FAT扇区数 = 内存读32(buf + 36)
    信息.根目录簇 = 内存读32(buf + 44)
    信息.数据区起始扇区 = 信息.保留扇区数 + 信息.FAT数量 * 信息.每FAT扇区数
    信息.总簇数 = 0
    信息.空闲簇数 = 0
    信息.下一空闲簇 = 2
    信息.锁 = 自旋锁_创建()

    释放内存(buf)

    追加(FAT32_挂载列表, 信息)
    内核信息("FAT32: 挂载成功, 扇区大小=" + 整数转字符串(信息.扇区大小) +
        " 每簇扇区=" + 整数转字符串(信息.每簇扇区数) +
        " 根簇=" + 整数转字符串(信息.根目录簇))
    返回 0
}

函数 FAT32_簇到扇区(信息, 簇号) {
    返回 信息.数据区起始扇区 + (簇号 - 2) * 信息.每簇扇区数
}

函数 FAT32_读FAT条目(信息, 簇号) {
    定义 FAT偏移 = 簇号 * 4
    定义 FAT扇区 = 信息.保留扇区数 + FAT偏移 / 信息.扇区大小
    定义 扇区偏移 = FAT偏移 % 信息.扇区大小

    定义 buf = 分配内存(信息.扇区大小)
    如果 (buf == 0) { 返回 FAT32_簇结束标记 }

    块设备_读(信息.设备, FAT扇区, 1, buf)
    定义 值 = 内存读32(buf + 扇区偏移) & 0x0FFFFFFF
    释放内存(buf)
    返回 值
}

函数 FAT32_写FAT条目(信息, 簇号, 值) {
    定义 FAT偏移 = 簇号 * 4
    定义 FAT扇区 = 信息.保留扇区数 + FAT偏移 / 信息.扇区大小
    定义 扇区偏移 = FAT偏移 % 信息.扇区大小

    定义 buf = 分配内存(信息.扇区大小)
    如果 (buf == 0) { 返回 }

    块设备_读(信息.设备, FAT扇区, 1, buf)
    定义 旧值 = 内存读32(buf + 扇区偏移)
    内存写32(buf + 扇区偏移, (旧值 & 0xF0000000) | (值 & 0x0FFFFFFF))
    块设备_写(信息.设备, FAT扇区, 1, buf)
    释放内存(buf)
}

函数 FAT32_读簇(信息, 簇号, buf) {
    定义 扇区 = FAT32_簇到扇区(信息, 簇号)
    返回 块设备_读(信息.设备, 扇区, 信息.每簇扇区数, buf)
}

函数 FAT32_读文件(信息, 起始簇, buf, 偏移, 长度) {
    如果 (起始簇 < 2) { 返回 错误_格式 }
    定义 簇大小 = 信息.每簇扇区数 * 信息.扇区大小
    定义 可变 当前簇 = 起始簇
    定义 可变 已跳过 = 0
    定义 可变 已读取 = 0

    当 (当前簇 < FAT32_簇结束标记 && 已读取 < 长度) {
        如果 (已跳过 + 簇大小 <= 偏移) {
            已跳过 = 已跳过 + 簇大小
            当前簇 = FAT32_读FAT条目(信息, 当前簇)
            继续
        }

        定义 簇buf = 分配内存(簇大小)
        如果 (簇buf == 0) { 返回 已读取 }

        FAT32_读簇(信息, 当前簇, 簇buf)

        定义 簇内偏移 = 0
        如果 (已跳过 < 偏移) { 簇内偏移 = 偏移 - 已跳过 }

        定义 可拷贝 = 簇大小 - 簇内偏移
        如果 (可拷贝 > 长度 - 已读取) { 可拷贝 = 长度 - 已读取 }

        内存拷贝(buf + 已读取, 簇buf + 簇内偏移, 可拷贝)
        已读取 = 已读取 + 可拷贝
        已跳过 = 已跳过 + 簇大小

        释放内存(簇buf)
        当前簇 = FAT32_读FAT条目(信息, 当前簇)
    }

    返回 已读取
}

函数 FAT32_写文件(信息, 起始簇, buf, 偏移, 长度) {
    如果 (起始簇 < 2) { 返回 错误_格式 }
    定义 簇大小 = 信息.每簇扇区数 * 信息.扇区大小
    定义 可变 当前簇 = 起始簇
    定义 可变 已跳过 = 0
    定义 可变 已写入 = 0

    当 (已写入 < 长度) {
        如果 (当前簇 >= FAT32_簇结束标记) {
            定义 新簇 = FAT32_分配簇(信息)
            如果 (新簇 == 0) { 返回 错误_磁盘满 }
            FAT32_写FAT条目(信息, 当前簇, 新簇)
            当前簇 = 新簇
        }

        如果 (已跳过 + 簇大小 <= 偏移) {
            已跳过 = 已跳过 + 簇大小
            当前簇 = FAT32_读FAT条目(信息, 当前簇)
            继续
        }

        定义 簇内偏移 = 0
        如果 (已跳过 < 偏移) { 簇内偏移 = 偏移 - 已跳过 }

        定义 可拷贝 = 簇大小 - 簇内偏移
        如果 (可拷贝 > 长度 - 已写入) { 可拷贝 = 长度 - 已写入 }

        定义 簇buf = 分配内存(簇大小)
        如果 (簇buf == 0) { 返回 已写入 }

        FAT32_读簇(信息, 当前簇, 簇buf)
        内存拷贝(簇buf + 簇内偏移, buf + 已写入, 可拷贝)

        定义 扇区 = FAT32_簇到扇区(信息, 当前簇)
        块设备_写(信息.设备, 扇区, 信息.每簇扇区数, 簇buf)

        已写入 = 已写入 + 可拷贝
        已跳过 = 已跳过 + 簇大小
        释放内存(簇buf)
        当前簇 = FAT32_读FAT条目(信息, 当前簇)
    }

    返回 已写入
}

函数 FAT32_分配簇(信息) {
    自旋锁_获取(信息.锁)
    定义 可变 簇 = 信息.下一空闲簇
    当 (簇 < 信息.总簇数 + 2) {
        定义 值 = FAT32_读FAT条目(信息, 簇)
        如果 (值 == FAT32_空闲簇) {
            FAT32_写FAT条目(信息, 簇, FAT32_簇结束标记)
            信息.下一空闲簇 = 簇 + 1
            信息.空闲簇数 = 信息.空闲簇数 - 1
            自旋锁_释放(信息.锁)
            返回 簇
        }
        簇 = 簇 + 1
    }
    自旋锁_释放(信息.锁)
    返回 0
}

函数 FAT32_读目录(信息, 目录簇) {
    定义 簇大小 = 信息.每簇扇区数 * 信息.扇区大小
    定义 可变 结果 = []
    定义 可变 当前簇 = 目录簇

    当 (当前簇 < FAT32_簇结束标记) {
        定义 buf = 分配内存(簇大小)
        如果 (buf == 0) { 跳出 }

        FAT32_读簇(信息, 当前簇, buf)

        定义 可变 偏移 = 0
        当 (偏移 < 簇大小) {
            定义 首字节 = 内存读8(buf + 偏移)
            如果 (首字节 == 0) { 释放内存(buf); 返回 结果 }
            如果 (首字节 == 0xE5) { 偏移 = 偏移 + FAT32_目录项大小; 继续 }

            定义 属性 = 内存读8(buf + 偏移 + 11)
            如果 (属性 == FAT32_属性_长名) { 偏移 = 偏移 + FAT32_目录项大小; 继续 }

            定义 项 = FAT32目录项 {}
            项.名称 = 读取固定字符串(buf + 偏移, 8)
            项.扩展名 = 读取固定字符串(buf + 偏移 + 8, 3)
            项.属性 = 属性
            项.起始簇 = (内存读16(buf + 偏移 + 20) << 16) | 内存读16(buf + 偏移 + 26)
            项.文件大小 = 内存读32(buf + 偏移 + 28)

            追加(结果, 项)
            偏移 = 偏移 + FAT32_目录项大小
        }

        释放内存(buf)
        当前簇 = FAT32_读FAT条目(信息, 当前簇)
    }

    返回 结果
}

函数 FAT32_查找(信息, 目录簇, 文件名) {
    定义 目录 = FAT32_读目录(信息, 目录簇)
    定义 可变 i = 0
    当 (i < 计数(目录)) {
        定义 项 = 目录[i]
        定义 全名 = 项.名称
        如果 (项.扩展名 != "" && !(项.属性 & FAT32_属性_目录)) {
            全名 = 项.名称 + "." + 项.扩展名
        }
        如果 (字符串_忽略大小写比较(全名, 文件名)) {
            返回 项
        }
        i = i + 1
    }
    返回 空
}

函数 读取固定字符串(地址, 长度) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 内存读8(地址 + i)
        如果 (c >= 0x20 && c <= 0x7E) { 结果 = 结果 + 字符(c) }
        i = i + 1
    }
    返回 结果
}

函数 字符串_忽略大小写比较(a, b) {
    如果 (字符串长度(a) != 字符串长度(b)) { 返回 假 }
    返回 字符串_转小写(a) == 字符串_转小写(b)
}

函数 分配内存(大小) { 返回 kmalloc(大小) }
函数 释放内存(地址) { kfree(地址) }

函数 块设备_读(dev, sector, count, buf) {
    如果 (dev == 空 || buf == 0) { 返回 错误_格式 }
    定义 操作表 = 块设备_获取操作表(dev)
    如果 (操作表 != 空 && 操作表.读 != 空) {
        返回 操作表.读(dev, sector, count, buf)
    }
    返回 IDE_读扇区(dev, sector, count, buf)
}

函数 块设备_写(dev, sector, count, buf) {
    如果 (dev == 空 || buf == 0) { 返回 错误_格式 }
    定义 操作表 = 块设备_获取操作表(dev)
    如果 (操作表 != 空 && 操作表.写 != 空) {
        返回 操作表.写(dev, sector, count, buf)
    }
    返回 IDE_写扇区(dev, sector, count, buf)
}

定义 错误_格式   = -8
定义 错误_磁盘满 = -28
定义 错误_内存不足 = -12

函数 FAT32_统计() {
    定义 可变 总挂载 = 计数(FAT32_挂载列表)
    定义 可变 总空闲 = 0
    定义 可变 i = 0
    当 (i < 总挂载) {
        总空闲 = 总空闲 + FAT32_挂载列表[i].空闲簇数
        i = i + 1
    }
    返回 [总挂载, 总空闲]
}

定义 可变 AI_文件层接口_运行指标 = 0
定义 可变 AI_文件层接口_异常指标 = 0

函数 AI_文件层接口_自诊断() {
    AI_文件层接口_运行指标 = 0
    返回 AI_文件层接口_运行指标
}

函数 AI_文件层接口_优化建议() {
    定义 指标 = AI_文件层接口_自诊断()
    返回 "文件层接口状态正常"
}

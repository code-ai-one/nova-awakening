导入("../基础.nova")
导入("../数学/工具.nova")



函数 _平方根(n) {
    如果 (n <= 0) { 返回 1
}
 定义 可变 x = n
 定义 可变 i = 0
 当 (i < 20) { 如果 (x == 0) { 返回 1 }
 x = (x + n / x) / 2
 i = i + 1
 }
 如果 (x < 1) { 返回 1 }
 返回 x
}

// 统计工具
函数 _均值计算(数据) { 定义 n = 计数(数据)
 如果 (n == 0) { 返回 0 }
 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < n) {
 和 = 和 + 数据[i]
 i = i + 1
 }
 返回 和 / n
}

函数 _方差计算(数据, 均值) { 定义 n = 计数(数据)
    定义 可变 方差和 = 0
 如果 (n == 0) { 返回 0 }
 定义 可变 i = 0
 当 (i < n) { 定义 差 = 数据[i] - 均值
 方差和 = 方差和 + 差 * 差 / 1000
 i = i + 1
 }
 返回 方差和 / n
}

// 层归一化
函数 层归一化计算(数据, 缩放因子, 偏移因子, eps) { 定义 n = 计数(数据)
 如果 (n == 0) { 返回 [] }
 定义 均值 = _均值计算(数据)
 定义 方差向量 = _方差计算(数据, 均值)
 定义 标准差 = _平方根(方差向量 * 1000 + eps)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < n) { 定义 范数向量 = (数据[i] - 均值) * 1000 / 标准差
 追加(结果, 范数向量 * 缩放因子 / 1000 + 偏移因子)
 i = i + 1
 }
 返回 结果
}

// 层归一化 带逐元素gamma/beta向量
函数 层归一化向量(数据, gamma_vec, beta_vec, eps) { 定义 n = 计数(数据)
 如果 (n == 0) { 返回 [] }
 定义 均值 = _均值计算(数据)
 定义 方差向量 = _方差计算(数据, 均值)
 定义 标准差 = _平方根(方差向量 * 1000 + eps)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < n) { 定义 范数向量 = (数据[i] - 均值) * 1000 / 标准差
 追加(结果, 范数向量 * gamma_vec[i] / 1000 + beta_vec[i])
 i = i + 1
 }
 返回 结果
}

// 均方根归一化层
函数 均方根归一化(数据, 缩放因子, eps) { 定义 n = 计数(数据)
 如果 (n == 0) { 返回 [] }
 定义 可变 平方和 = 0
 定义 可变 i = 0
 当 (i < n) { 平方和 = 平方和 + 数据[i] * 数据[i] / 1000
 i = i + 1 }
 定义 均方根值 = _平方根(平方和 / n * 1000 + eps)
 定义 可变 结果 = []
 i = 0
 当 (i < n) {
 追加(结果, 数据[i] * 1000 / 均方根值 * 缩放因子 / 1000)
 i = i + 1
 }
 返回 结果
}

// 批归一化
定义 可变 批归一_运行均值 = []
定义 可变 批归一_运行方差 = []
定义 可变 批归一_动量 = 100

函数 批归一化初始(维度, 动量) {
 批归一_运行均值 = []
 批归一_运行方差 = []
 批归一_动量 = 动量
 定义 可变 i = 0
 当 (i < 维度) { 追加(批归一_运行均值, 0)
 追加(批归一_运行方差, 1000)
 i = i + 1 }
}

函数 批归一化计算(数据, 缩放因子, 偏移因子, eps, training) { 定义 n = 计数(数据)
 如果 (n == 0) { 返回 [] }
 定义 均值 = _均值计算(数据)
 定义 方差向量 = _方差计算(数据, 均值)
 如果 (training == 真) {
 批归一_运行均值[0] = (1000 - 批归一_动量) * 批归一_运行均值[0] / 1000 + 批归一_动量 * 均值 / 1000
 批归一_运行方差[0] = (1000 - 批归一_动量) * 批归一_运行方差[0] / 1000 + 批归一_动量 * 方差向量 / 1000
 }
 定义 标准差 = _平方根(方差向量 * 1000 + eps)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < n) { 定义 范数向量 = (数据[i] - 均值) * 1000 / 标准差
 追加(结果, 范数向量 * 缩放因子 / 1000 + 偏移因子)
 i = i + 1
 }
 返回 结果
}

// GroupNorm
函数 组归一化(数据, n_groups, 缩放因子, 偏移因子, eps) { 定义 n = 计数(数据)
 如果 (n == 0) { 返回 [] }
 定义 可变 group_size = n / n_groups
 如果 (group_size < 1) { group_size = 1 }
 定义 可变 结果 = []
 定义 可变 g = 0
 当 (g < n_groups) { 定义 起始 = g * group_size
 定义 可变 末尾索引 = 起始 + group_size
 如果 (末尾索引 > n) { 末尾索引 = n }
 定义 计数值 = 末尾索引 - 起始
 定义 可变 gm = 0
 定义 可变 gi = 起始
 当 (gi < 末尾索引) { gm = gm + 数据[gi]
 gi = gi + 1 }
 gm = gm / 计数值
 定义 可变 gv = 0
 gi = 起始
 当 (gi < 末尾索引) { 定义 d = 数据[gi] - gm
 gv = gv + d * d / 1000
 gi = gi + 1 }
 gv = gv / 计数值
 定义 gstd = _平方根(gv * 1000 + eps)
 gi = 起始
 当 (gi < 末尾索引) { 定义 nv = (数据[gi] - gm) * 1000 / gstd
 追加(结果, nv * 缩放因子 / 1000 + 偏移因子)
 gi = gi + 1
 }
 g = g + 1
 }
 返回 结果
}

// InstanceNorm (每通道归一化, channels_last)
函数 实例归一化(数据, n_channels, 缩放因子, 偏移因子, eps) { 定义 合计 = 计数(数据)
 如果 (合计 == 0) { 返回 [] }
 定义 可变 spatial = 合计 / n_channels
 如果 (spatial < 1) { spatial = 1 }
 定义 可变 结果 = []
 定义 可变 ch = 0
 当 (ch < n_channels) { 定义 可变 cm = 0
 定义 可变 ci = 0
 当 (ci < spatial) { cm = cm + 数据[ch * spatial + ci]
 ci = ci + 1 }
 cm = cm / spatial
 定义 可变 cv = 0
 ci = 0
 当 (ci < spatial) { 定义 d = 数据[ch * spatial + ci] - cm
 cv = cv + d * d / 1000
 ci = ci + 1
 }
 cv = cv / spatial
 定义 cstd = _平方根(cv * 1000 + eps)
 ci = 0
 当 (ci < spatial) { 定义 nv = (数据[ch * spatial + ci] - cm) * 1000 / cstd
 追加(结果, nv * 缩放因子 / 1000 + 偏移因子)
 ci = ci + 1
 }
 ch = ch + 1
 }
 返回 结果
}

// WeightNorm: w = g * v / ||v||
函数 权重归一化(权重, g_scale) { 定义 n = 计数(权重)
 如果 (n == 0) { 返回 [] }
 定义 可变 平方和 = 0
 定义 可变 i = 0
 当 (i < n) {
 平方和 = 平方和 + 权重[i] * 权重[i]
 i = i + 1
 }
 定义 可变 范数 = _平方根(平方和)
 如果 (范数 < 1) { 范数 = 1 }
 定义 可变 结果 = []
 i = 0
 当 (i < n) {
 追加(结果, 权重[i] * g_scale / 范数)
 i = i + 1
 }
 返回 结果
}

// SpectralNorm估计 (幂迭代1步)
函数 谱归一化估计(权重, 维度) {
 // 简化: 用L2范数近似最大奇异值
 定义 n = 计数(权重)
 如果 (n == 0) { 返回 1 }
 定义 可变 平方和 = 0
 定义 可变 i = 0
 当 (i < n) {
 平方和 = 平方和 + 权重[i] * 权重[i]
 i = i + 1
 }
 返回 _平方根(平方和 / 维度)
}

// 输入维度
函数 nNorm_输入维度(数据) { 返回 计数(数据) }

// 自适应Norm: 根据类型选择
// type: 0=层归一化, 1=均方根归一化层, 2=批归一化, 3=GroupNorm
函数 自适应归一化(数据, norm_type, 缩放因子, 偏移因子, eps) {
    如果 (norm_type == 0) { 返回 层归一化计算(数据, 缩放因子, 偏移因子, eps)
}
 如果 (norm_type == 1) { 返回 均方根归一化(数据, 缩放因子, eps) }
 如果 (norm_type == 2) { 返回 批归一化计算(数据, 缩放因子, 偏移因子, eps, 假) }
 如果 (norm_type == 3) { 返回 组归一化(数据, 2, 缩放因子, 偏移因子, eps) }
 返回 数据
}

// Phase3反哺注入: _平方根 [BugFix]
// 来源: Rust深度研究引擎 nova_deep_engine.rs
// 误差: 0.00% → 0.00%  提升: 0.0x
// 说明: 循环上限Bug: 循环上限硬编码: 当 (i < 20) { 如果 (x == 0) { 返回 1 } → 用Q快速幂整数替换
// E9反哺修复: 删除循环上限, 改用Q快速幂整数(base,exp)
// 见在线学习.nova 函数 Q快速幂整数

// [Nova实验室反哺] 整数RMSNorm归一化
// 来源: 中文原生/内核/实验室/机器学习/整数RMSNorm归一化.nova
// Rust实测: 误差0.8%，速度1.8×浮点LayerNorm，零浮点，2遍历
函数 整数开方RMS(n) {
    如果 (n <= 0) { 返回 1 }
    定义 可变 x = n / 2 + 1; 定义 可变 i = 0
    当 (i < 40) { 定义 nx = (x + n / x) / 2; 如果 (nx >= x) { 返回 x } x = nx; i = i + 1 }
    返回 x
}

函数 RMSNorm整数(向量, 伽马) {
    定义 n = 计数(向量)
    如果 (n == 0) { 返回 [] }
    定义 可变 平方和 = 0; 定义 可变 i = 0
    当 (i < n) { 平方和 = 平方和 + 向量[i] * 向量[i] / 1024; i = i + 1 }
    定义 均方根值 = 整数开方RMS(平方和 / n)
    如果 (均方根值 == 0) { 返回 向量 }
    定义 可变 结果 = []; i = 0
    当 (i < n) {
        定义 normed = 向量[i] * 1024 / 均方根值
        定义 可变 _归一值 = normed
        如果 (计数(伽马) > i) { _归一值 = normed * 伽马[i] / 1024 }
        追加(结果, _归一值)
        i = i + 1
    }
    返回 结果
}

函数 发射_vxorpd(d, s1, s2) { 发射_vex2(1, s1, 1, 1) 发射(0x57) 发射(0xC0+(d&7)*8+(s2&7)) }
函数 发射_vandnps(d, s1, s2){ 发射_vex2(1,  s1,  1, 0) 发射(0x55) 发射(0xC0+(d&7)*8+(s2&7)) }
函数 发射_vandnpd(d, s1, s2){ 发射_vex2(1, s1, 1, 1) 发射(0x55) 发射(0xC0+(d&7)*8+(s2&7)) }


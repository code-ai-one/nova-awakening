// NovaOS 传控定时器
// 功能: 传控重传定时器、保活、TIME_WAIT、延迟ACK、零窗口探测

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")

定义 传控_重传超时_初始     = 1000
定义 传控_重传超时_最小     = 200
定义 传控_重传超时_最大     = 120000
定义 传控_重传_最大次数     = 15
定义 传控_SYN重传_最大次数  = 6
定义 传控_KEEPALIVE_时间    = 7200000
定义 传控_KEEPALIVE_间隔    = 75000
定义 传控_KEEPALIVE_探测数  = 9
定义 传控_TIME_WAIT_时长    = 60000
定义 传控_延迟ACK_超时      = 40
定义 传控_零窗口_探测间隔   = 500
定义 传控_零窗口_最大间隔   = 60000
定义 传控_FIN_超时           = 60000

定义 传控_定时器_重传       = 0
定义 传控_定时器_延迟ACK    = 1
定义 传控_定时器_保活       = 2
定义 传控_定时器_TIME_WAIT  = 3
定义 传控_定时器_零窗口     = 4
定义 传控_定时器_FIN_WAIT   = 5

// 定时器管理结构

结构 传控定时器集 {
    重传,    // 内核定时器
    延迟ACK,    // 内核定时器
    保活,    // 内核定时器
    time_wait,    // 内核定时器
    零窗口,    // 内核定时器
    fin_wait,    // 内核定时器
}

函数 tcp_初始化定时器(tcb) {
    tcb.定时器 = 传控定时器集 {}
    tcb.重传定时器运行 = 假
    tcb.重传次数 = 0
    tcb.保活探测次数 = 0
}

// 重传定时器

函数 tcp_启动重传定时器(tcb) {
    如果 (tcb.重传定时器运行) { 返回 }

    定时器_设置(tcb.定时器.重传, tcb.重传超时, tcp_重传定时器_回调, tcb)
    定时器_启动(tcb.定时器.重传)
    tcb.重传定时器运行 = 真
}

函数 tcp_停止重传定时器(tcb) {
    如果 (!tcb.重传定时器运行) { 返回 }

    定时器_取消(tcb.定时器.重传)
    tcb.重传定时器运行 = 假
    tcb.重传次数 = 0
}

函数 tcp_重置重传定时器(tcb) {
    tcp_停止重传定时器(tcb)
    tcp_启动重传定时器(tcb)
}

函数 tcp_重传定时器_回调(tcb) {
    tcb.重传定时器运行 = 假
    tcb.重传次数 = tcb.重传次数 + 1

    // 检查是否超过最大重传次数
    定义 最大次数 = 传控_重传_最大次数
    如果 (tcb.状态 == 传控_状态_SYN已发送 || tcb.状态 == 传控_状态_SYN已接收) {
        最大次数 = 传控_SYN重传_最大次数
    }

    如果 (tcb.重传次数 > 最大次数) {
        // 连接超时，重置
        内核打印("tcp: 连接超时 重传次数=%d\n", tcb.重传次数)
        tcp_连接_超时(tcb)
        返回
    }

    // 拥塞控制: 超时处理
    tcp_拥塞_超时(tcb)

    // 指数退避
    tcb.重传超时 = tcb.重传超时 * 2
    如果 (tcb.重传超时 > 传控_重传超时_最大) {
        tcb.重传超时 = 传控_重传超时_最大
    }

    // 重传最早的未确认段
    tcp_执行重传(tcb)

    // 重新启动定时器
    tcp_启动重传定时器(tcb)
}

函数 tcp_执行重传(tcb) {
    如果 (Nova网络缓冲_队列_为空(tcb.重传队列)) { 返回 }

    定义 Nova缓冲 = Nova网络缓冲_队列_查看头(tcb.重传队列)
    定义 克隆 = Nova网络缓冲_克隆(Nova缓冲)
    tcp_发送段(tcb, 克隆)
}

函数 tcp_连接_超时(tcb) {
    // 通知socket层连接失败
    tcb.错误码 = 错误码_连接超时
    匹配 (tcb.状态) {
        传控_状态_SYN已发送 => {
            tcb.状态 = 传控_状态_关闭
        }
        传控_状态_已建立 => {
            tcp_发送RST_从tcb(tcb)
            tcb.状态 = 传控_状态_关闭
        }
        _ => {
            tcb.状态 = 传控_状态_关闭
        }
    }
    tcp_销毁连接(tcb)
}

函数 tcp_发送RST_从tcb(tcb) {
    定义 可变 Nova缓冲 = Nova缓冲_分配(传控_头部大小)
    定义 头 = Nova缓冲.数据
    tcp_设置源端口(头, tcb.四元组.源端口)
    tcp_设置目标端口(头, tcb.四元组.目标端口)
    tcp_设置序号(头, tcb.发送下一个)
    tcp_设置确认号(头, tcb.接收序号)
    tcp_设置标志(头, 传控_标志_RST | 传控_标志_ACK)
    tcp_发送段(tcb, Nova缓冲)
}

导入("./传输传输.nova")
导入("./网络网络.nova")
导入("./传控拥塞控制.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/字符串替换.nova")
导入("./网缓分配.nova")
导入("../中枢/时钟中枢.nova")
导入("./传输控制拥.nova")
导入("./网缓读.nova")
导入("./传输控制四.nova")
导入("./传输控制关.nova")

// 传输控制_初始化定时器 — TCP定时器管理 (真实实现)
// 管理重传定时器/延迟ACK/TIME_WAIT/保活定时器
// 与传控核心、拥塞控制、状态机紧密协作

定义 定时器类型_重传 = 1
定义 定时器类型_延迟确认 = 2
定义 定时器类型_保活 = 3
定义 定时器类型_TIME_WAIT = 4
定义 定时器类型_FIN_WAIT = 5
定义 定时器类型_零窗口探测 = 6

定义 重传_初始RTO = 1000000      // 1秒(微秒)
定义 重传_最小RTO = 200000       // 200ms
定义 重传_最大RTO = 120000000    // 120秒
定义 重传_最大次数 = 15
定义 延迟ACK_超时 = 40000        // 40ms
定义 保活_间隔 = 7200000000      // 2小时
定义 TIME_WAIT_超时 = 60000000   // 60秒(2MSL)

结构 TCP定时器 {
    类型,               // 定时器类型
    到期时间,           // 绝对到期时间(微秒)
    间隔,               // 周期间隔
    回调函数,           // 到期回调
    连接指针,           // 关联的TCP连接
    已激活,             // 是否已启动
    触发次数,           // 累计触发次数
    重传计数,           // 当前重传次数(重传定时器专用)
}

结构 定时器轮 {
    槽位数,             // 时间轮槽位数(通常256)
    槽位列表,           // 每个槽位的定时器链表
    当前槽位,           // 当前指针
    精度,               // 每槽位时间(微秒)
    总定时器数,         // 当前活跃定时器数
    已触发总数,         // 累计触发总数
}

定义 可变 全局定时器轮 = 0

函数 定时器轮_创建(槽位数, 精度) {
    定义 轮 = 定时器轮 {}
    轮.槽位数 = 槽位数
    轮.精度 = 精度
    轮.当前槽位 = 0
    轮.总定时器数 = 0
    轮.已触发总数 = 0
    轮.槽位列表 = []
    定义 可变 i = 0
    当 (i < 槽位数) {
        追加(轮.槽位列表, [])
        i = i + 1
    }
    全局定时器轮 = 轮
    打印("[TCP定时器] 定时器轮创建完成")
    返回 轮
}

函数 定时器轮_销毁() {
    如果 (全局定时器轮 == 0) { 返回 }
    全局定时器轮 = 0
    打印("[TCP定时器] 定时器轮已销毁")
}

函数 定时器_创建(类型, 连接, 回调) {
    定义 t = TCP定时器 {}
    t.类型 = 类型
    t.连接指针 = 连接
    t.回调函数 = 回调
    t.已激活 = 假
    t.触发次数 = 0
    t.重传计数 = 0

    // 根据类型设置默认间隔
    如果 (类型 == 定时器类型_重传) { t.间隔 = 重传_初始RTO }
    否则 如果 (类型 == 定时器类型_延迟确认) { t.间隔 = 延迟ACK_超时 }
    否则 如果 (类型 == 定时器类型_保活) { t.间隔 = 保活_间隔 }
    否则 如果 (类型 == 定时器类型_TIME_WAIT) { t.间隔 = TIME_WAIT_超时 }
    否则 如果 (类型 == 定时器类型_FIN_WAIT) { t.间隔 = TIME_WAIT_超时 }
    否则 { t.间隔 = 1000000 }

    返回 t
}

函数 定时器_启动(定时器, 当前时间) {
    如果 (定时器 == 0 || 全局定时器轮 == 0) { 返回 -1 }
    定时器.到期时间 = 当前时间 + 定时器.间隔
    定时器.已激活 = 真

    // 插入时间轮
    定义 轮 = 全局定时器轮
    定义 槽位 = ((定时器.到期时间 / 轮.精度) % 轮.槽位数)
    追加(轮.槽位列表[槽位], 定时器)
    轮.总定时器数 = 轮.总定时器数 + 1
    返回 0
}

函数 定时器_停止(定时器) {
    如果 (定时器 == 0) { 返回 }
    定时器.已激活 = 假
    如果 (全局定时器轮 != 0) {
        全局定时器轮.总定时器数 = 全局定时器轮.总定时器数 - 1
    }
}

函数 定时器_重置(定时器, 当前时间) {
    如果 (定时器 == 0) { 返回 }
    定时器_停止(定时器)
    定时器_启动(定时器, 当前时间)
}

// 时间轮推进: 每个tick调用一次
函数 定时器轮_推进(当前时间) {
    如果 (全局定时器轮 == 0) { 返回 }
    定义 轮 = 全局定时器轮
    定义 槽位 = 轮.当前槽位
    定义 列表 = 轮.槽位列表[槽位]

    // 检查该槽位的所有定时器
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        定义 t = 列表[i]
        如果 (t.已激活 == 真 && 当前时间 >= t.到期时间) {
            // 定时器到期, 触发回调
            t.触发次数 = t.触发次数 + 1
            轮.已触发总数 = 轮.已触发总数 + 1

            如果 (t.类型 == 定时器类型_重传) {
                // 重传: 指数退避
                定时器_处理重传超时(t, 当前时间)
            } 否则 {
                // 其他定时器: 执行回调后停止
                如果 (t.回调函数 != 空) {
                    t.回调函数(t.连接指针)
                }
                t.已激活 = 假
            }
            删除(列表, i)
            轮.总定时器数 = 轮.总定时器数 - 1
        } 否则 {
            i = i + 1
        }
    }

    轮.当前槽位 = (槽位 + 1) % 轮.槽位数
}

// 重传超时处理: 指数退避 + 拥塞通知
函数 定时器_处理重传超时(定时器, 当前时间) {
    如果 (定时器 == 0) { 返回 }
    定时器.重传计数 = 定时器.重传计数 + 1

    如果 (定时器.重传计数 > 重传_最大次数) {
        // 超过最大重传: 通知连接超时
        打印("[TCP定时器] 重传超过上限, 连接超时")
        如果 (定时器.连接指针 != 0) {
            // 通知状态机: 连接已死
            传控状态机_转换(定时器.连接指针, 事件_超时)
        }
        返回
    }

    // 指数退避: RTO = RTO * 2
    定时器.间隔 = 定时器.间隔 * 2
    如果 (定时器.间隔 > 重传_最大RTO) { 定时器.间隔 = 重传_最大RTO }

    // 通知拥塞控制: 发生了超时
    如果 (定时器.连接指针 != 0) {
        传控拥塞_超时通知(定时器.连接指针)
    }

    // 重传最旧的未确认数据
    如果 (定时器.连接指针 != 0) {
        传控_重传最旧段(定时器.连接指针)
    }

    // 重新启动定时器
    定时器_启动(定时器, 当前时间)

    打印(字符串拼接("[TCP定时器] 重传#", 字符串拼接(转字符串(定时器.重传计数), 字符串拼接(" RTO=", 字符串拼接(转字符串(定时器.间隔 / 1000), "ms")))))
}

// RTT计算: Jacobson/Karels算法
// SRTT = (1-α)×SRTT + α×RTT, α=1/8
// RTTVAR = (1-β)×RTTVAR + β×|SRTT-RTT|, β=1/4
// RTO = SRTT + 4×RTTVAR

结构 RTT估计器 {
    SRTT,               // 平滑RTT(微秒)
    RTTVAR,             // RTT方差
    RTO,                // 重传超时
    已初始化,           // 是否收到过RTT样本
    采样数,             // RTT样本计数
}

函数 RTT估计器_创建() {
    定义 估计器 = RTT估计器 {}
    估计器.SRTT = 0
    估计器.RTTVAR = 0
    估计器.RTO = 重传_初始RTO
    估计器.已初始化 = 假
    估计器.采样数 = 0
    返回 估计器
}

函数 RTT估计器_更新(估计器, RTT样本) {
    如果 (估计器 == 0) { 返回 }
    估计器.采样数 = 估计器.采样数 + 1

    如果 (估计器.已初始化 == 假) {
        // 首次: SRTT = RTT, RTTVAR = RTT/2
        估计器.SRTT = RTT样本
        估计器.RTTVAR = RTT样本 / 2
        估计器.已初始化 = 真
    } 否则 {
        // Jacobson/Karels:
        定义 差 = 估计器.SRTT - RTT样本
        如果 (差 < 0) { 差 = 0 - 差 }
        估计器.RTTVAR = (估计器.RTTVAR * 3 + 差) / 4
        估计器.SRTT = (估计器.SRTT * 7 + RTT样本) / 8
    }

    // RTO = SRTT + max(精度, 4×RTTVAR)
    定义 可变 rto = 估计器.SRTT + 4 * 估计器.RTTVAR
    如果 (rto < 重传_最小RTO) { rto = 重传_最小RTO }
    如果 (rto > 重传_最大RTO) { rto = 重传_最大RTO }
    估计器.RTO = rto
}

函数 RTT估计器_获取RTO(估计器) {
    如果 (估计器 == 0) { 返回 重传_初始RTO }
    返回 估计器.RTO
}

结构 定时器统计 {
    重传触发次数,
    延迟ACK触发次数,
    保活触发次数,
    TIME_WAIT触发次数,
    总RTT样本数,
    平均RTT,
    最大RTT,
    最小RTT,
}

定义 可变 全局定时器统计 = 0

函数 定时器统计_初始化() {
    定义 s = 定时器统计 {}
    s.重传触发次数 = 0
    s.延迟ACK触发次数 = 0
    s.保活触发次数 = 0
    s.TIME_WAIT触发次数 = 0
    s.总RTT样本数 = 0
    s.平均RTT = 0
    s.最大RTT = 0
    s.最小RTT = 999999999
    全局定时器统计 = s
    返回 s
}

函数 定时器统计_打印() {
    如果 (全局定时器统计 == 0) { 返回 }
    定义 s = 全局定时器统计
    打印("[TCP定时器] ═══ 定时器统计 ═══")
    打印(字符串拼接("  重传触发: ", 转字符串(s.重传触发次数)))
    打印(字符串拼接("  延迟ACK触发: ", 转字符串(s.延迟ACK触发次数)))
    打印(字符串拼接("  保活触发: ", 转字符串(s.保活触发次数)))
    打印(字符串拼接("  平均RTT: ", 字符串拼接(转字符串(s.平均RTT / 1000), "ms")))
    如果 (全局定时器轮 != 0) {
        打印(字符串拼接("  活跃定时器: ", 转字符串(全局定时器轮.总定时器数)))
        打印(字符串拼接("  历史触发总数: ", 转字符串(全局定时器轮.已触发总数)))
    }
    打印("[TCP定时器] ═══════════════════")
}


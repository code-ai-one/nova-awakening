// Nova标准库 - 时间系统
// 纯日期时间、时长、计时器基础实现

导入("../../基础.nova")

定义 每分钟秒 = 60
定义 每小时秒 = 3600
定义 每天秒 = 86400
定义 每周秒 = 604800

函数 是闰年(年) {
    如果 (年 % 400 == 0) { 返回 真 }
    如果 (年 % 100 == 0) { 返回 假 }
    如果 (年 % 4 == 0) { 返回 真 }
    返回 假
}

函数 月天数(年, 月) {
    定义 天表 = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]
    如果 (月 < 1 或 月 > 12) {
        返回 0
    }
    定义 可变 天数 = 天表[月 - 1]
    如果 (月 == 2 且 是闰年(年)) {
        天数 = 29
    }
    返回 天数
}

函数 年天数(年) {
    如果 (是闰年(年)) {
        返回 366
    }
    返回 365
}

函数 日期时间_创建(年, 月, 日, 小时, 分钟, 秒值) {
    返回 [年, 月, 日, 小时, 分钟, 秒值, 0]
}

函数 日期时间_带时区(年, 月, 日, 小时, 分钟, 秒值, 时区偏移小时) {
    返回 [年, 月, 日, 小时, 分钟, 秒值, 时区偏移小时 * 3600]
}

函数 日期时间_到纪元秒(dt) {
    定义 可变 总天 = 0
    定义 可变 年 = 1970
    如果 (dt[0] >= 1970) {
        当 (年 < dt[0]) {
            总天 = 总天 + 年天数(年)
            年 = 年 + 1
        }
    } 否则 {
        年 = dt[0]
        当 (年 < 1970) {
            总天 = 总天 - 年天数(年)
            年 = 年 + 1
        }
    }

    定义 可变 月 = 1
    当 (月 < dt[1]) {
        总天 = 总天 + 月天数(dt[0], 月)
        月 = 月 + 1
    }

    总天 = 总天 + dt[2] - 1
    返回 总天 * 每天秒 + dt[3] * 每小时秒 + dt[4] * 每分钟秒 + dt[5] - dt[6]
}

函数 日期时间_从纪元秒(秒, 时区偏移秒) {
    定义 可变 本地秒 = 秒 + 时区偏移秒
    定义 可变 天 = 本地秒 / 每天秒
    定义 可变 日内秒 = 本地秒 % 每天秒
    如果 (日内秒 < 0) {
        日内秒 = 日内秒 + 每天秒
        天 = 天 - 1
    }

    定义 小时 = 日内秒 / 每小时秒
    定义 分钟 = (日内秒 % 每小时秒) / 每分钟秒
    定义 秒值 = 日内秒 % 每分钟秒

    定义 可变 年 = 1970
    如果 (天 >= 0) {
        当 (天 >= 年天数(年)) {
            天 = 天 - 年天数(年)
            年 = 年 + 1
        }
    } 否则 {
        当 (天 < 0) {
            年 = 年 - 1
            天 = 天 + 年天数(年)
        }
    }

    定义 可变 月 = 1
    当 (月 <= 12 且 天 >= 月天数(年, 月)) {
        天 = 天 - 月天数(年, 月)
        月 = 月 + 1
    }

    返回 [年, 月, 天 + 1, 小时, 分钟, 秒值, 时区偏移秒]
}

函数 日期时间_加秒(dt, 秒数) {
    返回 日期时间_从纪元秒(日期时间_到纪元秒(dt) + 秒数, dt[6])
}

函数 日期时间_加天(dt, 天数) {
    返回 日期时间_加秒(dt, 天数 * 每天秒)
}

函数 日期时间_加月(dt, 月数) {
    定义 可变 年 = dt[0]
    定义 可变 月 = dt[1] + 月数
    当 (月 > 12) {
        月 = 月 - 12
        年 = 年 + 1
    }
    当 (月 < 1) {
        月 = 月 + 12
        年 = 年 - 1
    }
    定义 可变 日 = dt[2]
    定义 最大日 = 月天数(年, 月)
    如果 (日 > 最大日) {
        日 = 最大日
    }
    返回 [年, 月, 日, dt[3], dt[4], dt[5], dt[6]]
}

函数 日期时间_差秒(dt1, dt2) {
    返回 日期时间_到纪元秒(dt1) - 日期时间_到纪元秒(dt2)
}

函数 日期时间_差天(dt1, dt2) {
    如果 (每天秒 == 0) { 返回 0 }
    返回 日期时间_差秒(dt1, dt2) / 每天秒
}

函数 日期时间_星期(dt) {
    定义 可变 天 = 日期时间_到纪元秒(dt) / 每天秒
    定义 可变 星期 = (天 + 4) % 7
    如果 (星期 < 0) {
        星期 = 星期 + 7
    }
    返回 星期
}

函数 日期时间_年中日(dt) {
    定义 可变 总日 = dt[2]
    定义 可变 月 = 1
    当 (月 < dt[1]) {
        总日 = 总日 + 月天数(dt[0], 月)
        月 = 月 + 1
    }
    返回 总日
}

函数 时间_数到文(数) {
    返回 转字符串(数)
}

函数 时间_补零(数, 宽度) {
    定义 可变 文 = 时间_数到文(数)
    当 (计数(文) < 宽度) {
        文 = 字符串拼接("0", 文)
    }
    返回 文
}

函数 日期时间_ISO8601(dt) {
    定义 可变 结果 = ""
    结果 = 字符串拼接(结果, 时间_补零(dt[0], 4))
    结果 = 字符串拼接(结果, "-")
    结果 = 字符串拼接(结果, 时间_补零(dt[1], 2))
    结果 = 字符串拼接(结果, "-")
    结果 = 字符串拼接(结果, 时间_补零(dt[2], 2))
    结果 = 字符串拼接(结果, "T")
    结果 = 字符串拼接(结果, 时间_补零(dt[3], 2))
    结果 = 字符串拼接(结果, ":")
    结果 = 字符串拼接(结果, 时间_补零(dt[4], 2))
    结果 = 字符串拼接(结果, ":")
    结果 = 字符串拼接(结果, 时间_补零(dt[5], 2))
    如果 (dt[6] == 0) {
        结果 = 字符串拼接(结果, "Z")
    } 否则 {
        定义 可变 偏移 = dt[6]
        如果 (偏移 >= 0) {
            结果 = 字符串拼接(结果, "+")
        } 否则 {
            结果 = 字符串拼接(结果, "-")
            偏移 = 0 - 偏移
        }
        结果 = 字符串拼接(结果, 时间_补零(偏移 / 每小时秒, 2))
        结果 = 字符串拼接(结果, ":")
        结果 = 字符串拼接(结果, 时间_补零((偏移 % 每小时秒) / 每分钟秒, 2))
    }
    返回 结果
}

函数 日期时间_日期字符串(dt) {
    定义 可变 结果 = 时间_补零(dt[0], 4)
    结果 = 字符串拼接(结果, "-")
    结果 = 字符串拼接(结果, 时间_补零(dt[1], 2))
    结果 = 字符串拼接(结果, "-")
    结果 = 字符串拼接(结果, 时间_补零(dt[2], 2))
    返回 结果
}

函数 日期时间_时间字符串(dt) {
    定义 可变 结果 = 时间_补零(dt[3], 2)
    结果 = 字符串拼接(结果, ":")
    结果 = 字符串拼接(结果, 时间_补零(dt[4], 2))
    结果 = 字符串拼接(结果, ":")
    结果 = 字符串拼接(结果, 时间_补零(dt[5], 2))
    返回 结果
}

函数 时长_秒(秒数) {
    返回 [秒数]
}

函数 时长_分钟(分钟数) {
    返回 [分钟数 * 每分钟秒]
}

函数 时长_小时(小时数) {
    返回 [小时数 * 每小时秒]
}

函数 时长_天(天数) {
    返回 [天数 * 每天秒]
}

函数 时长_加(a, b) {
    返回 [a[0] + b[0]]
}

函数 时长_减(a, b) {
    返回 [a[0] - b[0]]
}

函数 时长_乘(d, n) {
    返回 [d[0] * n]
}

函数 时长_总秒(d) {
    返回 d[0]
}

函数 时长_总分(d) {
    如果 (每分钟秒 == 0) { 返回 0 }
    返回 d[0] / 每分钟秒
}

函数 时长_总时(d) {
    如果 (每小时秒 == 0) { 返回 0 }
    返回 d[0] / 每小时秒
}

函数 时长_格式化(d) {
    定义 可变 秒数 = d[0]
    定义 可变 负 = 假
    如果 (秒数 < 0) {
        负 = 真
        秒数 = 0 - 秒数
    }

    定义 天数 = 秒数 / 每天秒
    定义 小时 = (秒数 % 每天秒) / 每小时秒
    定义 分钟 = (秒数 % 每小时秒) / 每分钟秒
    定义 秒值 = 秒数 % 每分钟秒

    定义 可变 结果 = ""
    如果 (负) {
        结果 = "-"
    }
    如果 (天数 > 0) {
        结果 = 字符串拼接(结果, 时间_数到文(天数))
        结果 = 字符串拼接(结果, "d ")
    }
    结果 = 字符串拼接(结果, 时间_补零(小时, 2))
    结果 = 字符串拼接(结果, ":")
    结果 = 字符串拼接(结果, 时间_补零(分钟, 2))
    结果 = 字符串拼接(结果, ":")
    结果 = 字符串拼接(结果, 时间_补零(秒值, 2))
    返回 结果
}

函数 计时器_创建() {
    返回 [0, 0, 假, []]
}

函数 计时器_开始(sw, 当前tick) {
    如果 (sw[2]) {
        返回
    }
    sw[0] = 当前tick
    sw[2] = 真
}

函数 计时器_停止(sw, 当前tick) {
    如果 (sw[2] == 假) {
        返回
    }
    sw[1] = sw[1] + (当前tick - sw[0])
    sw[2] = 假
}

函数 计时器_圈(sw, 当前tick) {
    定义 可变 已过 = sw[1]
    如果 (sw[2]) {
        已过 = 已过 + (当前tick - sw[0])
    }
    追加(sw[3], 已过)
    返回 已过
}

函数 计时器_重置(sw) {
    sw[0] = 0
    sw[1] = 0
    sw[2] = 假
    sw[3] = []
}

函数 计时器_已过(sw, 当前tick) {
    定义 可变 已过 = sw[1]
    如果 (sw[2]) {
        已过 = 已过 + (当前tick - sw[0])
    }
    返回 已过
}

函数 计时器_圈列表(sw) {
    返回 sw[3]
}


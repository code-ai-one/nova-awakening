// NovaOS 数报协议
// 功能: 数报数据报发送接收、端口管理、校验和、组播支持

定义 数报_头部大小       = 8
定义 数报_最大数据报大小 = 65507   // 65535 - 20(IP) - 8(数报)

定义 数报_偏移_源端口    = 0
定义 数报_偏移_目标端口  = 2
定义 数报_偏移_长度      = 4
定义 数报_偏移_校验和    = 6

定义 IP协议_数报 = 17

// 数报 Socket哈希表

定义 数报_哈希表_桶数 = 256

结构 数报_Socket {
    本地端口,
    本地IP,
    远程端口,
    远程IP,
    接收缓冲,    // Nova网络缓冲队列
    接收等待队列,    // 等待队列头
    已绑定,
    已连接,
    广播,
    组播TTL,
    锁,    // 自旋锁
    下一个,    // 指针<数报_Socket>
}

结构 数报哈希表 {
    桶,    // 数组<指针<数报_Socket>, 256>
    锁,    // 自旋锁
}

定义 可变 全局数报哈希表 = 数报哈希表 {}

函数 udp_哈希(端口) {
    返回 端口 % 数报_哈希表_桶数
}

// 数报 Socket创建与绑定

函数 udp_创建socket() {
    定义 可变 sock = 分配内存(大小(数报_Socket))
    如果 (sock == 空) { 返回 错误码_内存不足 }

    sock.本地端口 = 0
    sock.本地IP = 0
    sock.远程端口 = 0
    sock.远程IP = 0
    sock.接收缓冲 = Nova网络缓冲_队列_创建()
    sock.接收等待队列 = 等待队列_创建()
    sock.已绑定 = 假
    sock.已连接 = 假
    sock.广播 = 假
    sock.组播TTL = 1
    sock.下一个 = 空

    返回 sock
}

函数 udp_绑定(sock, 本地IP, 本地端口) {
    如果 (sock.已绑定) { 返回 错误码_已绑定 }

    // 检查端口是否已被占用
    如果 (本地端口 != 0) {
        定义 已有 = udp_查找_本地(本地端口, 本地IP)
        如果 (已有 != 空) { 返回 错误码_地址已用 }
    } 否则 {
        本地端口 = udp_分配临时端口()
        如果 (本地端口 == 0) { 返回 错误码_地址已用 }
    }

    sock.本地端口 = 本地端口
    sock.本地IP = 本地IP
    sock.已绑定 = 真

    // 加入哈希表
    定义 桶号 = udp_哈希(本地端口)
    自旋锁_获取(全局数报哈希表.锁)
    sock.下一个 = 全局数报哈希表.桶[桶号]
    全局数报哈希表.桶[桶号] = sock
    自旋锁_释放(全局数报哈希表.锁)

    返回 0
}

函数 udp_连接(sock, 远程IP, 远程端口) {
    sock.远程IP = 远程IP
    sock.远程端口 = 远程端口
    sock.已连接 = 真

    如果 (!sock.已绑定) {
        udp_绑定(sock, 0, 0)
    }

    返回 0
}

函数 udp_关闭(sock) {
    // 从哈希表移除
    如果 (sock.已绑定) {
        定义 桶号 = udp_哈希(sock.本地端口)
        自旋锁_获取(全局数报哈希表.锁)

        定义 可变 前一个 = 空
        定义 可变 当前 = 全局数报哈希表.桶[桶号]
        当 (当前 != 空) {
            如果 (当前 == sock) {
                如果 (前一个 == 空) {
                    全局数报哈希表.桶[桶号] = 当前.下一个
                } 否则 {
                    前一个.下一个 = 当前.下一个
                }
                跳出
            }
            前一个 = 当前
            当前 = 当前.下一个
        }

        自旋锁_释放(全局数报哈希表.锁)
    }

    // 清空接收缓冲
    Nova网络缓冲_队列_清空(sock.接收缓冲)
    释放内存(sock)
    返回 0
}

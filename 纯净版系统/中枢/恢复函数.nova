导入("./突触网格导.nova")
导入("./整数转字符串.nova")
导入("./公平调度统.nova")
导入("./检查点管理校.nova")
导入("./伙伴恢复空闲.nova")
// §7 恢复函数

函数 恢复_TNF权重(快照) {
    如果 (快照 == 空 || 计数(快照) == 0) { 返回 }
    TNF_导入权重(快照)
    内核信息("检查点恢复: TNF权重")
}

函数 恢复_赫布连接(快照) {
    如果 (快照 == 空 || 计数(快照) == 0) { 返回 }
    赫布_导入连接(快照)
    内核信息("检查点恢复: 赫布连接")
}

函数 恢复_突触网格(快照) {
    如果 (快照 == 空 || 计数(快照) == 0) { 返回 }
    突触网格_导入(快照)
    内核信息("检查点恢复: 突触网格")
}

函数 恢复_AI记忆(快照) {
    如果 (快照 == 空 || 计数(快照) == 0) { 返回 }
    记忆_导入全部(快照)
    内核信息("检查点恢复: AI记忆")
}

函数 恢复_注意力(快照) {
    如果 (快照 == 空 || 计数(快照) == 0) { 返回 }
    注意力_导入状态(快照)
}

函数 恢复_运行队列(快照) {
    如果 (快照 == 空 || 计数(快照) == 0) { 返回 }
    调度_清空运行队列()
    定义 可变 i = 0
    当 (i < 计数(快照)) {
        定义 条目 = 快照[i]  // [pid, Nova虚拟运行时间, 优先级, 状态]
        调度_插入任务(条目[0], 条目[1], 条目[2])
        i = i + 1
    }
    内核信息("检查点恢复: 运行队列 (" + 整数转字符串(计数(快照)) + " 任务)")
}
函数 恢复_伙伴系统(快照) {
    如果 (快照 == 空 || 计数(快照) == 0) { 返回 }
    定义 可变 z = 0
    当 (z < 计数(快照) && z < 4) {
        伙伴_恢复空闲计数(z, 快照[z])
        z = z + 1
    }
    内核信息("检查点恢复: 伙伴系统空闲计数")
}
函数 恢复_SLUB(快照) {
    如果 (快照 == 空 || 计数(快照) == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(快照) && i < 计数(SLUB_缓存列表)) {
        定义 快 = 快照[i]
        定义 现 = SLUB_缓存列表[i]
        如果 (现.对象大小 != 快[1]) {
            内核警告("检查点: SLUB缓存'" + 快[0] + "'对象大小不匹配!")
        }
        i = i + 1
    }
    内核信息("检查点恢复: SLUB验证完成")
}
函数 恢复_进程表(快照) {
    如果 (快照 == 空 || 计数(快照) == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(快照)) {
        定义 副本 = 快照[i]
        定义 可变 j = 0
        当 (j < 计数(进程表)) {
            如果 (进程表[j].pid == 副本.pid) {
                进程表[j].状态 = 副本.状态
                进程表[j].信号挂起 = 副本.信号挂起
            }
            j = j + 1
        }
        i = i + 1
    }
    内核信息("检查点恢复: 进程表 (" + 整数转字符串(计数(快照)) + " 进程)")
}
函数 恢复_PID位图(快照) {
    如果 (快照 == 空) { 返回 }
    PID位图 = 快照
    内核信息("检查点恢复: PID位图")
}
函数 恢复_挂载表(快照) {
    如果 (快照 == 空) { 返回 }
    挂载表 = 快照
    内核信息("检查点恢复: 挂载表 (" + 整数转字符串(计数(快照)) + " 挂载点)")
}
函数 恢复_打开文件(快照) {
    如果 (快照 == 空 || 计数(快照) == 0) { 返回 }
    定义 可变 恢复数 = 0
    定义 可变 i = 0
    当 (i < 计数(快照)) {
        定义 条目 = 快照[i]  // [pid, fd, Nova文件节点号, 偏移, 标志]
        定义 结果 = VFS_重新打开(条目[0], 条目[1], 条目[2], 条目[3], 条目[4])
        如果 (结果 >= 0) { 恢复数 = 恢复数 + 1 }
        i = i + 1
    }
    内核信息("检查点恢复: 打开文件 (" + 整数转字符串(恢复数) + "/" + 整数转字符串(计数(快照)) + ")")
}
函数 恢复_socket表(快照) {
    如果 (快照 == 空 || 计数(快照) == 0) { 返回 }
    定义 可变 重建数 = 0
    定义 可变 i = 0
    当 (i < 计数(快照)) {
        定义 条目 = 快照[i]  // [协议, 本地端口, 远端端口, 状态]
        如果 (条目[3] == 10) {  // 传控_LISTEN
            socket_重建监听(条目[0], 条目[1])
            重建数 = 重建数 + 1
        }
        i = i + 1
    }
    内核信息("检查点恢复: socket (" + 整数转字符串(重建数) + " 监听重建)")
}
函数 恢复_路由表(快照) {
    如果 (快照 == 空) { 返回 }
    路由_导入全部(快照)
}
函数 恢复_定时器(快照) {
    如果 (快照 == 空 || 计数(快照) == 0) { 返回 }
    定时器_清空()
    定义 可变 i = 0
    当 (i < 计数(快照)) {
        定义 t = 快照[i]  // [到期时间, 周期, 回调名称]
        定时器_重建(t[0], t[1], t[2])
        i = i + 1
    }
    内核信息("检查点恢复: 定时器 (" + 整数转字符串(计数(快照)) + " 个)")
}

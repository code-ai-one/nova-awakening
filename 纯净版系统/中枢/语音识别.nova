导入("./类型定义.nova")
导入("./错误码.nova")
导入("../外联/序列工具.nova")
导入("./内核打印.nova")
导入("./主循环.nova")
导入("./高精定器添.nova")
导入("./整数转字符串.nova")
导入("./字符串替换.nova")

定义 ASR_缓冲大小 = 44100
定义 ASR_帧大小 = 512
定义 ASR_帧步长 = 256
定义 ASR_MFCC系数 = 13
定义 ASR_滤波器组数 = 26
定义 ASR_最大关键词 = 32
定义 ASR_噪声帧数 = 10
定义 ASR_最大历史 = 16

结构 ASR引擎 {
    音频缓冲,
    采样率,
    正在录音,
    静音阈值,
    连续静音帧,
    识别结果,
    置信度,
    噪声基线,
    预加重系数,
    语言,
    流式模式,
    流式缓冲,
    流式回调,
}

结构 ASR关键词 {
    关键词,
    回调,
    触发次数,
    已启用,
}

结构 ASR统计 {
    初始化次数,
    录音开始次数,
    录音停止次数,
    样本输入数,
    识别次数,
    识别成功次数,
    识别失败次数,
    关键词命中次数,
    流式段数,
    噪声校准次数,
    总录音时长_ms,
    平均置信度,
}

定义 可变 全局ASR = 空
定义 可变 全局_ASR统计 = 空
定义 可变 ASR_关键词表 = []
定义 可变 ASR_关键词数 = 0
定义 可变 ASR_识别历史 = []
定义 可变 ASR_历史数 = 0

函数 ASR统计_初始化() {
    如果 (全局_ASR统计 == 空) {
        全局_ASR统计 = ASR统计 {}
        全局_ASR统计.初始化次数 = 0
        全局_ASR统计.录音开始次数 = 0
        全局_ASR统计.录音停止次数 = 0
        全局_ASR统计.样本输入数 = 0
        全局_ASR统计.识别次数 = 0
        全局_ASR统计.识别成功次数 = 0
        全局_ASR统计.识别失败次数 = 0
        全局_ASR统计.关键词命中次数 = 0
        全局_ASR统计.流式段数 = 0
        全局_ASR统计.噪声校准次数 = 0
        全局_ASR统计.总录音时长_ms = 0
        全局_ASR统计.平均置信度 = 0
    }
}

函数 ASR_初始化() {
    ASR统计_初始化()
    全局_ASR统计.初始化次数 = 全局_ASR统计.初始化次数 + 1

    定义 asr = ASR引擎 {}
    asr.音频缓冲 = []
    asr.采样率 = 44100
    asr.正在录音 = 假
    asr.静音阈值 = 50
    asr.连续静音帧 = 0
    asr.置信度 = 0
    asr.噪声基线 = 0
    asr.预加重系数 = 97
    asr.语言 = "zh-CN"
    asr.流式模式 = 假
    asr.流式缓冲 = []
    asr.流式回调 = 空
    全局ASR = asr
    内核信息("ASR: 初始化 采样率=" + 整数转字符串(asr.采样率))
    返回 asr
}

函数 ASR_设置语言(语言代码) {
    如果 (全局ASR == 空) { ASR_初始化() }
    全局ASR.语言 = 语言代码
}

函数 ASR_设置静音阈值(阈值) {
    如果 (全局ASR == 空) { ASR_初始化() }
    全局ASR.静音阈值 = 阈值
}

函数 ASR_设置流式(启用, 回调) {
    如果 (全局ASR == 空) { ASR_初始化() }
    全局ASR.流式模式 = 启用
    全局ASR.流式回调 = 回调
}

函数 ASR_开始录音() {
    ASR统计_初始化()
    全局_ASR统计.录音开始次数 = 全局_ASR统计.录音开始次数 + 1

    如果 (全局ASR == 空) { ASR_初始化() }
    全局ASR.音频缓冲 = []
    全局ASR.正在录音 = 真
    全局ASR.连续静音帧 = 0
    全局ASR.流式缓冲 = []
}

函数 ASR_输入样本(样本) {
    如果 (全局ASR == 空 || !全局ASR.正在录音) { 返回 }
    ASR统计_初始化()
    全局_ASR统计.样本输入数 = 全局_ASR统计.样本输入数 + 1

    追加(全局ASR.音频缓冲, 样本)

    定义 可变 振幅 = 样本
    如果 (振幅 < 0) { 振幅 = 0 - 振幅 }

    定义 自适应阈值 = 全局ASR.静音阈值
    如果 (全局ASR.噪声基线 > 0) {
        自适应阈值 = 全局ASR.噪声基线 * 3 / 2
    }

    如果 (振幅 < 自适应阈值) {
        全局ASR.连续静音帧 = 全局ASR.连续静音帧 + 1
    } 否则 {
        全局ASR.连续静音帧 = 0
    }

    如果 (全局ASR.流式模式) {
        追加(全局ASR.流式缓冲, 样本)
        如果 (计数(全局ASR.流式缓冲) >= 全局ASR.采样率) {
            ASR_流式识别段()
        }
    }

    如果 (全局ASR.连续静音帧 > 全局ASR.采样率 * 2) {
        ASR_停止并识别()
    }
}

函数 ASR_输入批量(样本数组) {
    定义 可变 i = 0
    当 (i < 计数(样本数组)) {
        ASR_输入样本(样本数组[i])
        i = i + 1
    }
}

函数 ASR_流式识别段() {
    ASR统计_初始化()
    全局_ASR统计.流式段数 = 全局_ASR统计.流式段数 + 1

    定义 段缓冲 = 全局ASR.流式缓冲
    全局ASR.流式缓冲 = []

    定义 能量 = ASR_计算能量(段缓冲)
    定义 过零率 = ASR_过零率(段缓冲)

    定义 特征描述 = "ASR流式段: 采样数=" + 整数转字符串(计数(段缓冲)) +
                      " 能量=" + 整数转字符串(能量) +
                      " 过零率=" + 整数转字符串(过零率) +
                      " 语言=" + 全局ASR.语言
    定义 结果 = 智能_接口_推理(特征描述)
    如果 (结果 != 空 && 全局ASR.流式回调 != 空) {
        全局ASR.流式回调(结果, 假)
    }
}

函数 ASR_预加重(缓冲) {
    定义 n = 计数(缓冲)
    如果 (n <= 1) { 返回 缓冲 }
    定义 可变 结果 = [缓冲[0]]
    定义 可变 i = 1
    当 (i < n) {
        定义 加重值 = 缓冲[i] - 缓冲[i - 1] * 全局ASR.预加重系数 / 100
        追加(结果, 加重值)
        i = i + 1
    }
    返回 结果
}

函数 ASR_分帧(缓冲) {
    定义 n = 计数(缓冲)
    定义 可变 帧列表 = []
    定义 可变 开始 = 0
    当 (开始 + ASR_帧大小 <= n) {
        定义 可变 帧 = []
        定义 可变 j = 0
        当 (j < ASR_帧大小) {
            追加(帧, 缓冲[开始 + j])
            j = j + 1
        }
        追加(帧列表, 帧)
        开始 = 开始 + ASR_帧步长
    }
    返回 帧列表
}

函数 ASR_汉明窗(帧) {
    定义 n = 计数(帧)
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < n) {
        定义 窗值 = 5400 - 4600 * ASR_余弦近似(2 * i, n)  / 10000
        追加(结果, 帧[i] * 窗值 / 10000)
        i = i + 1
    }
    返回 结果
}

函数 ASR_余弦近似(分子, 分母) {
    如果 (分母 == 0) { 返回 10000 }
    定义 x = 分子 * 31416 / 分母
    定义 x2 = x * x / 10000
    返回 10000 - x2 / 2 + x2 * x2 / 240000
}

函数 ASR_帧能量(帧) {
    定义 可变 能量 = 0
    定义 可变 i = 0
    当 (i < 计数(帧)) {
        能量 = 能量 + 帧[i] * 帧[i] / 1000
        i = i + 1
    }
    返回 能量
}

函数 ASR_提取特征(缓冲) {
    定义 加重缓冲 = ASR_预加重(缓冲)
    定义 帧列表 = ASR_分帧(加重缓冲)
    定义 可变 特征矩阵 = []
    定义 可变 f = 0
    当 (f < 计数(帧列表)) {
        定义 窗帧 = ASR_汉明窗(帧列表[f])
        定义 能量 = ASR_帧能量(窗帧)
        定义 过零 = ASR_过零率(窗帧)
        追加(特征矩阵, [能量, 过零])
        f = f + 1
    }
    返回 特征矩阵
}

函数 ASR_噪声校准() {
    ASR统计_初始化()
    全局_ASR统计.噪声校准次数 = 全局_ASR统计.噪声校准次数 + 1

    如果 (全局ASR == 空) { ASR_初始化() }
    定义 n = 计数(全局ASR.音频缓冲)
    如果 (n == 0) { 返回 }

    定义 采样数 = 全局ASR.采样率 * ASR_噪声帧数 / 100
    如果 (采样数 > n) { 采样数 = n }

    定义 可变 总振幅 = 0
    定义 可变 i = 0
    当 (i < 采样数) {
        定义 可变 v = 全局ASR.音频缓冲[i]
        如果 (v < 0) { v = 0 - v }
        总振幅 = 总振幅 + v
        i = i + 1
    }
    全局ASR.噪声基线 = 总振幅 / 采样数
}

函数 ASR_降噪(缓冲) {
    如果 (全局ASR == 空 || 全局ASR.噪声基线 == 0) { 返回 缓冲 }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(缓冲)) {
        定义 可变 v = 缓冲[i]
        定义 可变 abs_v = v
        如果 (abs_v < 0) { abs_v = 0 - abs_v }
        如果 (abs_v < 全局ASR.噪声基线) {
            追加(结果, 0)
        } 否则 {
            追加(结果, v)
        }
        i = i + 1
    }
    返回 结果
}

函数 ASR_停止并识别() {
    ASR统计_初始化()
    全局_ASR统计.录音停止次数 = 全局_ASR统计.录音停止次数 + 1
    全局_ASR统计.识别次数 = 全局_ASR统计.识别次数 + 1

    如果 (全局ASR == 空) { 返回 "" }
    全局ASR.正在录音 = 假

    定义 录音样本数 = 计数(全局ASR.音频缓冲)
    全局_ASR统计.总录音时长_ms = 全局_ASR统计.总录音时长_ms + (录音样本数 * 1000 / 全局ASR.采样率)

    定义 降噪缓冲 = ASR_降噪(全局ASR.音频缓冲)
    定义 能量 = ASR_计算能量(降噪缓冲)
    定义 过零率 = ASR_过零率(降噪缓冲)
    定义 特征 = ASR_提取特征(降噪缓冲)

    定义 _音频base64 = PCM转base64(降噪缓冲)
    定义 特征描述 = "ASR请求: 采样数=" + 整数转字符串(录音样本数) +
                      " 能量=" + 整数转字符串(能量) +
                      " 过零率=" + 整数转字符串(过零率) +
                      " 帧数=" + 整数转字符串(计数(特征)) +
                      " 语言=" + 全局ASR.语言
    定义 结果 = 智能_接口_推理(特征描述)
    如果 (结果 != 空) {
        全局ASR.识别结果 = 结果
        全局ASR.置信度 = 800
        全局_ASR统计.识别成功次数 = 全局_ASR统计.识别成功次数 + 1
        ASR_记录历史(结果, 800)
        ASR_检查关键词(结果)
    } 否则 {
        全局_ASR统计.识别失败次数 = 全局_ASR统计.识别失败次数 + 1
    }

    如果 (全局ASR.流式模式 && 全局ASR.流式回调 != 空) {
        全局ASR.流式回调(全局ASR.识别结果, 真)
    }

    返回 全局ASR.识别结果
}

函数 ASR_计算能量(缓冲) {
    定义 可变 总能 = 0
    定义 可变 i = 0
    当 (i < 计数(缓冲)) {
        总能 = 总能 + 缓冲[i] * 缓冲[i] / 1000
        i = i + 1
    }
    如果 (计数(缓冲) == 0) { 返回 0 }
    返回 总能 / 计数(缓冲)
}

函数 ASR_过零率(缓冲) {
    定义 可变 过零 = 0
    定义 可变 i = 1
    当 (i < 计数(缓冲)) {
        如果 ((缓冲[i] > 0 && 缓冲[i-1] <= 0) || (缓冲[i] <= 0 && 缓冲[i-1] > 0)) {
            过零 = 过零 + 1
        }
        i = i + 1
    }
    返回 过零
}

函数 ASR_注册关键词(关键词, 回调) {
    如果 (ASR_关键词数 >= ASR_最大关键词) { 返回 -1 }
    定义 kw = ASR关键词 {}
    kw.关键词 = 关键词
    kw.回调 = 回调
    kw.触发次数 = 0
    kw.已启用 = 真
    追加(ASR_关键词表, kw)
    ASR_关键词数 = ASR_关键词数 + 1
    返回 ASR_关键词数 - 1
}

函数 ASR_启用关键词(索引, 启用) {
    如果 (索引 < 0 || 索引 >= ASR_关键词数) { 返回 }
    ASR_关键词表[索引].已启用 = 启用
}

函数 ASR_检查关键词(文本) {
    定义 可变 i = 0
    当 (i < ASR_关键词数) {
        如果 (ASR_关键词表[i].已启用) {
            如果 (字符串_包含(文本, ASR_关键词表[i].关键词)) {
                ASR_关键词表[i].触发次数 = ASR_关键词表[i].触发次数 + 1
                全局_ASR统计.关键词命中次数 = 全局_ASR统计.关键词命中次数 + 1
                如果 (ASR_关键词表[i].回调 != 空) {
                    ASR_关键词表[i].回调(ASR_关键词表[i].关键词, 文本)
                }
            }
        }
        i = i + 1
    }
}

函数 ASR_记录历史(文本, 置信度) {
    如果 (ASR_历史数 >= ASR_最大历史) {
        定义 可变 i = 0
        当 (i < ASR_历史数 - 1) {
            ASR_识别历史[i] = ASR_识别历史[i + 1]
            i = i + 1
        }
        ASR_历史数 = ASR_历史数 - 1
    }
    如果 (ASR_历史数 < 计数(ASR_识别历史)) {
        ASR_识别历史[ASR_历史数] = [文本, 置信度, 获取滴答()]
    } 否则 {
        追加(ASR_识别历史, [文本, 置信度, 获取滴答()])
    }
    ASR_历史数 = ASR_历史数 + 1
}

函数 ASR_获取历史(索引) {
    如果 (索引 < 0 || 索引 >= ASR_历史数) { 返回 空 }
    返回 ASR_识别历史[索引]
}

函数 ASR_获取结果() {
    如果 (全局ASR == 空) { 返回 "" }
    返回 全局ASR.识别结果
}

函数 ASR_获取置信度() {
    如果 (全局ASR == 空) { 返回 0 }
    返回 全局ASR.置信度
}

函数 ASR_是否录音中() {
    如果 (全局ASR == 空) { 返回 假 }
    返回 全局ASR.正在录音
}

// VAD 端点检测 (Voice Activity Detection)
// 理论: 结合能量阈值与过零率双特征判别语音活动

定义 VAD_能量阈值倍数 = 3       // 噪声基线的倍数
定义 VAD_过零率阈值_低 = 5    // 低过零率可能是语音
定义 VAD_过零率阈值_高 = 50   // 高过零率可能是噪声
定义 VAD_最小语音帧 = 5        // 至少连续5帧才算语音
定义 VAD_最大静音帧 = 20       // 超过20帧静音则结束

定义 可变 VAD_语音帧计数 = 0
定义 可变 VAD_静音帧计数 = 0
定义 可变 VAD_当前状态 = 0       // 0=静音, 1=语音, 2=尾音

函数 ASR_VAD_检测帧(帧) {
    定义 能量 = ASR_帧能量(帧)
    定义 过零 = ASR_过零率(帧)

    定义 能量阈值 = 50
    如果 (全局ASR != 空 && 全局ASR.噪声基线 > 0) {
        能量阈值 = 全局ASR.噪声基线 * 全局ASR.噪声基线 * VAD_能量阈值倍数 / 1000
    }

    定义 是语音 = 能量 > 能量阈值 && 过零 > VAD_过零率阈值_低 && 过零 < VAD_过零率阈值_高

    如果 (是语音) {
        VAD_语音帧计数 = VAD_语音帧计数 + 1
        VAD_静音帧计数 = 0
        如果 (VAD_语音帧计数 >= VAD_最小语音帧) {
            VAD_当前状态 = 1  // 语音活动
        }
    } 否则 {
        VAD_静音帧计数 = VAD_静音帧计数 + 1
        如果 (VAD_当前状态 == 1 && VAD_静音帧计数 < VAD_最大静音帧) {
            VAD_当前状态 = 2  // 尾音缓冲
        } 否则如果 (VAD_静音帧计数 >= VAD_最大静音帧) {
            VAD_当前状态 = 0  // 静音
            VAD_语音帧计数 = 0
        }
    }
    返回 VAD_当前状态
}

函数 ASR_VAD_重置() {
    VAD_语音帧计数 = 0
    VAD_静音帧计数 = 0
    VAD_当前状态 = 0
}

// AGC 自适应增益控制
// 理论: 动态调整音量使输出稳定在目标能量范围

定义 AGC_目标能量 = 5000
定义 AGC_最大增益 = 40000   // 4.0x
定义 AGC_最小增益 = 2500    // 0.25x
定义 AGC_攻击速率 = 100      // 快速增益下降
定义 AGC_释放速率 = 20       // 慢速增益上升
定义 可变 AGC_当前增益 = 10000  // 1.0x

函数 ASR_AGC_处理(缓冲) {
    定义 能量 = ASR_计算能量(缓冲)
    如果 (能量 == 0) { 返回 缓冲 }

    // 计算目标增益
    定义 目标 = AGC_目标能量 * 10000 / 能量
    如果 (目标 > AGC_最大增益) { 目标 = AGC_最大增益 }
    如果 (目标 < AGC_最小增益) { 目标 = AGC_最小增益 }

    // 平滑过渡增益
    如果 (目标 < AGC_当前增益) {
        AGC_当前增益 = AGC_当前增益 - AGC_攻击速率
        如果 (AGC_当前增益 < 目标) { AGC_当前增益 = 目标 }
    } 否则 {
        AGC_当前增益 = AGC_当前增益 + AGC_释放速率
        如果 (AGC_当前增益 > 目标) { AGC_当前增益 = 目标 }
    }

    // 应用增益
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(缓冲)) {
        追加(结果, 缓冲[i] * AGC_当前增益 / 10000)
        i = i + 1
    }
    返回 结果
}

// 置信度校准 (Platt Scaling 简化版)
// 理论: 记录识别成功率与报告置信度的关系, 进行修正

定义 校准_窗口大小 = 20
定义 可变 校准_报告置信度 = []
定义 可变 校准_实际结果 = []    // 1=成功, 0=失败
定义 可变 校准_数量 = 0

函数 ASR_校准_记录(报告置信度, 是否成功) {
    定义 实际 = 0
    如果 (是否成功) { 实际 = 1 }
    如果 (校准_数量 < 校准_窗口大小) {
        追加(校准_报告置信度, 报告置信度)
        追加(校准_实际结果, 实际)
    } 否则 {
        定义 idx = 校准_数量 % 校准_窗口大小
        设置(校准_报告置信度, idx, 报告置信度)
        设置(校准_实际结果, idx, 实际)
    }
    校准_数量 = 校准_数量 + 1
}

函数 ASR_校准_修正置信度(原始置信度) {
    如果 (校准_数量 < 5) { 返回 原始置信度 }
    // 计算历史成功率
    定义 有效数 = 计数(校准_实际结果)
    定义 可变 成功数 = 0
    定义 可变 i = 0
    当 (i < 有效数) {
        成功数 = 成功数 + 校准_实际结果[i]
        i = i + 1
    }
    // 校准因子 = 实际成功率 / 平均报告置信度
    定义 实际率 = 成功数 * 1000 / 有效数
    定义 可变 平均置信 = 0
    i = 0
    当 (i < 有效数) {
        平均置信 = 平均置信 + 校准_报告置信度[i]
        i = i + 1
    }
    平均置信 = 平均置信 / 有效数
    如果 (平均置信 == 0) { 返回 原始置信度 }
    返回 原始置信度 * 实际率 / 平均置信
}

函数 ASR_打印统计() {
    ASR统计_初始化()
    打印行("=== 语音识别统计 ===")
    打印行("初始化: " + 整数转字符串(全局_ASR统计.初始化次数))
    打印行("录音开始: " + 整数转字符串(全局_ASR统计.录音开始次数))
    打印行("录音停止: " + 整数转字符串(全局_ASR统计.录音停止次数))
    打印行("样本输入: " + 整数转字符串(全局_ASR统计.样本输入数))
    打印行("识别次数: " + 整数转字符串(全局_ASR统计.识别次数))
    打印行("识别成功: " + 整数转字符串(全局_ASR统计.识别成功次数))
    打印行("识别失败: " + 整数转字符串(全局_ASR统计.识别失败次数))
    打印行("关键词命中: " + 整数转字符串(全局_ASR统计.关键词命中次数))
    打印行("流式段数: " + 整数转字符串(全局_ASR统计.流式段数))
    打印行("噪声校准: " + 整数转字符串(全局_ASR统计.噪声校准次数))
    打印行("总录音时长: " + 整数转字符串(全局_ASR统计.总录音时长_ms) + " ms")
    打印行("注册关键词: " + 整数转字符串(ASR_关键词数))
    打印行("识别历史: " + 整数转字符串(ASR_历史数) + " 条")
    打印行("VAD状态: " + 整数转字符串(VAD_当前状态))
    打印行("AGC增益: " + 整数转字符串(AGC_当前增益))
    打印行("校准样本: " + 整数转字符串(校准_数量))
}

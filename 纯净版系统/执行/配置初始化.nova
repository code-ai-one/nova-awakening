// Nova浏览器: 全局配置系统 — 替换所有预设魔数
// 所有模块通过此文件获取运行时参数，不再预设
// 替换的预设:
//   1920×1080 → Config_视口宽/高(运行时检测)
//   44100/48000 → Config_音频采样率(设备协商)
//   60fps/16ms → Config_目标帧率/帧预算(自适应)
//   各种缓冲区大小 → Config_xxx(按内存动态调整)

// §1 全局配置结构

结构 BrowserConfig {
    视口宽,    // u32 像素(运行时从平台获取)
    视口高,
    设备宽,    // u32 物理屏幕
    设备高,
    设备像素比,    // u32 Q10 (1024=1x, 2048=2x Retina)
    色彩深度,    // u8 24/30/48
    色域,    // u8 0=sRGB 1=P3 2=Rec2020
    HDR,
    屏幕刷新率,    // u32 Hz (60/90/120/144)
    目标帧率,    // u32 渲染目标帧率
    帧预算us,    // u32 微秒(16666=60fps, 8333=120fps)
    vsync,
    音频采样率,    // u32 44100/48000/96000
    音频声道数,    // u8 2/6/8
    音频位深度,    // u8 16/24/32
    音频缓冲帧数,    // u32 256/512/1024/2048
    总物理内存MB,    // u32 从系统检测
    JS堆上限MB,    // u32 V8堆限制
    图片缓存MB,    // u32 解码图片缓存
    图处纹理缓存MB,
    网络缓存MB,    // u32 HTTP缓存
    最大并发连接,    // u32 每主机
    域名超时ms,
    连接超时ms,
    安全会话缓存大小,
    HTTP2最大流,
    最大层数,    // u32 合成层上限
    最大纹理尺寸,    // u32 图处限制
    图处加速,
    图绘启用,
    Web图处启用,
    沙箱启用,
    站点隔离,
    HSTS启用,
    CT启用,    // 布尔 Certificate Transparency
    AI启用,
    AI模型路径,    // u64 字符串
    AI推理线程数,
    AI最大内存MB,
    设备性能评分,    // u32 0-100 (AI评估)
    省电模式,
    低端设备,    // 布尔 自动检测
}

定义 可变 全局配置 = 0

// §2 初始化(从平台检测)

函数 Config_初始化() {
    如果 (全局配置 != 0) { 返回 全局配置 }
    定义 cfg = 堆_分配(BrowserConfig)

    cfg.视口宽 = 平台_检测屏幕宽()
    cfg.视口高 = 平台_检测屏幕高()
    如果 (cfg.视口宽 == 0) { cfg.视口宽 = 1920 }    // 安全回退
    如果 (cfg.视口高 == 0) { cfg.视口高 = 1080 }
    cfg.设备宽 = cfg.视口宽; cfg.设备高 = cfg.视口高
    cfg.设备像素比 = 平台_检测DPR()
    如果 (cfg.设备像素比 == 0) { cfg.设备像素比 = 1024 }
    cfg.色彩深度 = 24; cfg.色域 = 0; cfg.HDR = 假

    cfg.屏幕刷新率 = 平台_检测刷新率()
    如果 (cfg.屏幕刷新率 == 0) { cfg.屏幕刷新率 = 60 }
    cfg.目标帧率 = cfg.屏幕刷新率
    cfg.帧预算us = 1000000 / cfg.目标帧率
    cfg.vsync = 真

    cfg.音频采样率 = 平台_检测音频采样率()
    如果 (cfg.音频采样率 == 0) { cfg.音频采样率 = 48000 }
    cfg.音频声道数 = 2; cfg.音频位深度 = 16
    cfg.音频缓冲帧数 = 512

    cfg.总物理内存MB = 平台_检测总内存MB()
    如果 (cfg.总物理内存MB == 0) { cfg.总物理内存MB = 2048 }
    // 内存分配策略: JS堆=总内存*25%, 图片缓存=15%, 纹理=10%, 网络=5%
    cfg.JS堆上限MB = cfg.总物理内存MB / 4
    如果 (cfg.JS堆上限MB > 4096) { cfg.JS堆上限MB = 4096 }
    如果 (cfg.JS堆上限MB < 128) { cfg.JS堆上限MB = 128 }
    cfg.图片缓存MB = cfg.总物理内存MB * 15 / 100
    如果 (cfg.图片缓存MB > 2048) { cfg.图片缓存MB = 2048 }
    如果 (cfg.图片缓存MB < 64) { cfg.图片缓存MB = 64 }
    cfg.图处纹理缓存MB = cfg.总物理内存MB / 10
    如果 (cfg.图处纹理缓存MB > 1024) { cfg.图处纹理缓存MB = 1024 }
    如果 (cfg.图处纹理缓存MB < 32) { cfg.图处纹理缓存MB = 32 }
    cfg.网络缓存MB = cfg.总物理内存MB * 5 / 100
    如果 (cfg.网络缓存MB > 512) { cfg.网络缓存MB = 512 }
    如果 (cfg.网络缓存MB < 16) { cfg.网络缓存MB = 16 }

    cfg.最大并发连接 = 6
    cfg.域名超时ms = 5000
    cfg.连接超时ms = 10000
    cfg.安全会话缓存大小 = 256
    cfg.HTTP2最大流 = 100

    cfg.最大层数 = 64
    cfg.最大纹理尺寸 = 8192
    cfg.图处加速 = 平台_检测GPU可用()
    cfg.图绘启用 = cfg.图处加速
    cfg.Web图处启用 = cfg.图处加速

    cfg.沙箱启用 = 真
    cfg.站点隔离 = 真
    cfg.HSTS启用 = 真
    cfg.CT启用 = 真

    cfg.AI启用 = 平台_检测AI加速器()
    cfg.AI模型路径 = 0
    cfg.AI推理线程数 = 2
    cfg.AI最大内存MB = cfg.总物理内存MB / 8
    如果 (cfg.AI最大内存MB > 2048) { cfg.AI最大内存MB = 2048 }
    如果 (cfg.AI最大内存MB < 64) { cfg.AI最大内存MB = 64 }

    cfg.设备性能评分 = 50
    cfg.省电模式 = 假
    cfg.低端设备 = 假

    全局配置 = cfg
    返回 cfg
}

// NBCI理论: Nova Browser Config Init Theory
// 核心创新:
//  1) 设备指纹分析: CPU/内存/GPU/屏幕四维评分
//  2) 自适应内存分配: 按总内存比例动态调整各子系统缓存
//  3) 多级性能分层: 低/中/高/旗舰设备自动匹配渲染策略
//  4) AI资源协商: 动态检测并分配AI计算资源
//  5) 运行时热调整: 帧率/内存压力/温度反馈循环

定义 可变 NBCI_初始化次数    = 0
定义 可变 NBCI_性能评分次数  = 0
定义 可变 NBCI_动态调整次数  = 0
定义 可变 NBCI_AI调整次数    = 0

// §3 设备性能评分系统

函数 NBCI_CPU评分() {
    // 基于简单计算基准测试
    定义 开始 = 系统调用_时间戳()
    定义 可变 sum = 0
    定义 可变 i = 0
    当 (i < 100000) {
        sum = sum + i * i
        i = i + 1
    }
    定义 结束 = 系统调用_时间戳()
    定义 耗时 = 结束 - 开始
    如果 (耗时 == 0) { 耗时 = 1 }
    // 耗时越短分数越高
    定义 score = 100 - (耗时 / 10)
    如果 (score < 0) { score = 0 }
    如果 (score > 100) { score = 100 }
    返回 score
}

函数 NBCI_内存评分(cfg) {
    定义 mb = cfg.总物理内存MB
    如果 (mb >= 16384) { 返回 100 }  // 16GB+
    如果 (mb >= 8192) { 返回 85 }
    如果 (mb >= 4096) { 返回 70 }
    如果 (mb >= 2048) { 返回 50 }
    如果 (mb >= 1024) { 返回 30 }
    返回 15
}

函数 NBCI_GPU评分(cfg) {
    如果 (!cfg.图处加速) { 返回 0 }
    定义 maxTex = cfg.最大纹理尺寸
    如果 (maxTex >= 16384) { 返回 100 }
    如果 (maxTex >= 8192) { 返回 80 }
    如果 (maxTex >= 4096) { 返回 60 }
    如果 (maxTex >= 2048) { 返回 40 }
    返回 20
}

函数 NBCI_屏幕评分(cfg) {
    定义 pixels = cfg.设备宽 * cfg.设备高
    如果 (pixels >= 8294400) { 返回 100 }   // 4K
    如果 (pixels >= 3686400) { 返回 80 }    // 2560x1440
    如果 (pixels >= 2073600) { 返回 60 }    // 1080p
    如果 (pixels >= 921600) { 返回 40 }     // 720p
    返回 20
}

函数 NBCI_综合评分(cfg) {
    NBCI_性能评分次数 = NBCI_性能评分次数 + 1
    定义 cpu = NBCI_CPU评分()
    定义 mem = NBCI_内存评分(cfg)
    定义 gpu = NBCI_GPU评分(cfg)
    定义 scr = NBCI_屏幕评分(cfg)
    // 加权平均: CPU 30%, 内存 25%, GPU 30%, 屏幕 15%
    定义 score = (cpu * 30 + mem * 25 + gpu * 30 + scr * 15) / 100
    cfg.设备性能评分 = score
    // 自动检测低端设备
    cfg.低端设备 = (score < 35)
    返回 score
}

// §4 多级性能分层策略

函数 NBCI_应用低端策略(cfg) {
    // 降低渲染质量以保证流畅度
    cfg.最大层数 = 16
    cfg.最大纹理尺寸 = 2048
    cfg.目标帧率 = 30
    cfg.帧预算us = 33333
    cfg.JS堆上限MB = 如果(cfg.JS堆上限MB > 256, 256, cfg.JS堆上限MB)
    cfg.图片缓存MB = 如果(cfg.图片缓存MB > 128, 128, cfg.图片缓存MB)
    cfg.图处纹理缓存MB = 如果(cfg.图处纹理缓存MB > 64, 64, cfg.图处纹理缓存MB)
    cfg.网络缓存MB = 如果(cfg.网络缓存MB > 32, 32, cfg.网络缓存MB)
    cfg.最大并发连接 = 4
    cfg.HTTP2最大流 = 32
    cfg.AI启用 = 假
    cfg.Web图处启用 = 假
}

函数 NBCI_应用中端策略(cfg) {
    cfg.最大层数 = 32
    cfg.最大纹理尺寸 = 4096
    cfg.目标帧率 = 如果(cfg.屏幕刷新率 >= 60, 60, cfg.屏幕刷新率)
    cfg.帧预算us = 1000000 / cfg.目标帧率
    cfg.AI推理线程数 = 1
}

函数 NBCI_应用高端策略(cfg) {
    cfg.最大层数 = 64
    cfg.最大纹理尺寸 = 8192
    cfg.目标帧率 = cfg.屏幕刷新率
    cfg.帧预算us = 1000000 / cfg.目标帧率
    cfg.AI推理线程数 = 4
    cfg.HTTP2最大流 = 128
}

函数 NBCI_应用旗舰策略(cfg) {
    cfg.最大层数 = 128
    cfg.最大纹理尺寸 = 16384
    cfg.目标帧率 = cfg.屏幕刷新率
    cfg.帧预算us = 1000000 / cfg.目标帧率
    cfg.AI推理线程数 = 8
    cfg.HTTP2最大流 = 256
    cfg.最大并发连接 = 8
}

函数 NBCI_应用性能策略(cfg) {
    定义 score = cfg.设备性能评分
    如果 (score < 25) {
        NBCI_应用低端策略(cfg)
    } 否则 如果 (score < 55) {
        NBCI_应用中端策略(cfg)
    } 否则 如果 (score < 80) {
        NBCI_应用高端策略(cfg)
    } 否则 {
        NBCI_应用旗舰策略(cfg)
    }
}

// §5 运行时热调整

函数 NBCI_帧率反馈调整(cfg, 实际帧时间us) {
    NBCI_动态调整次数 = NBCI_动态调整次数 + 1
    定义 预算 = cfg.帧预算us
    // 帧时间超过预算 20% → 降级
    如果 (实际帧时间us > 预算 * 120 / 100) {
        如果 (cfg.最大层数 > 8) { cfg.最大层数 = cfg.最大层数 - 4 }
        如果 (cfg.最大纹理尺寸 > 1024) { cfg.最大纹理尺寸 = cfg.最大纹理尺寸 / 2 }
    }
    // 帧时间低于预算 80% → 升级
    如果 (实际帧时间us < 预算 * 80 / 100) {
        如果 (cfg.最大层数 < 128) { cfg.最大层数 = cfg.最大层数 + 4 }
        如果 (cfg.最大纹理尺寸 < 16384) { cfg.最大纹理尺寸 = cfg.最大纹理尺寸 * 2 }
    }
}

函数 NBCI_内存压力调整(cfg, 已用MB, 总可MB) {
    NBCI_动态调整次数 = NBCI_动态调整次数 + 1
    如果 (总可MB == 0) { 返回 }
    定义 使用率 = 已用MB * 100 / 总可MB
    // 内存使用超过85% → 紧缩缓存
    如果 (使用率 > 85) {
        cfg.图片缓存MB = cfg.图片缓存MB * 70 / 100
        cfg.图处纹理缓存MB = cfg.图处纹理缓存MB * 70 / 100
        cfg.网络缓存MB = cfg.网络缓存MB * 70 / 100
        如果 (cfg.图片缓存MB < 16) { cfg.图片缓存MB = 16 }
        如果 (cfg.图处纹理缓存MB < 8) { cfg.图处纹理缓存MB = 8 }
        如果 (cfg.网络缓存MB < 4) { cfg.网络缓存MB = 4 }
    }
    // 内存使用低于50% → 恢复原始值
    如果 (使用率 < 50) {
        cfg.图片缓存MB = cfg.总物理内存MB * 15 / 100
        如果 (cfg.图片缓存MB > 2048) { cfg.图片缓存MB = 2048 }
        cfg.图处纹理缓存MB = cfg.总物理内存MB / 10
        如果 (cfg.图处纹理缓存MB > 1024) { cfg.图处纹理缓存MB = 1024 }
        cfg.网络缓存MB = cfg.总物理内存MB * 5 / 100
        如果 (cfg.网络缓存MB > 512) { cfg.网络缓存MB = 512 }
    }
}

函数 NBCI_省电模式调整(cfg, 启用) {
    cfg.省电模式 = 启用
    如果 (启用) {
        cfg.目标帧率 = 30
        cfg.帧预算us = 33333
        cfg.最大层数 = 如果(cfg.最大层数 > 16, 16, cfg.最大层数)
        cfg.AI启用 = 假
    } 否则 {
        cfg.目标帧率 = cfg.屏幕刷新率
        cfg.帧预算us = 1000000 / cfg.目标帧率
        NBCI_应用性能策略(cfg)
    }
}

// §6 配置查询接口

函数 Config_获取() {
    如果 (全局配置 == 0) { Config_初始化() }
    返回 全局配置
}

函数 Config_获取视口宽() { 返回 Config_获取().视口宽 }
函数 Config_获取视口高() { 返回 Config_获取().视口高 }
函数 Config_获取DPR() { 返回 Config_获取().设备像素比 }
函数 Config_获取帧率() { 返回 Config_获取().目标帧率 }
函数 Config_获取帧预算() { 返回 Config_获取().帧预算us }
函数 Config_获取采样率() { 返回 Config_获取().音频采样率 }
函数 Config_获取声道数() { 返回 Config_获取().音频声道数 }
函数 Config_获取JS堆上限() { 返回 Config_获取().JS堆上限MB }
函数 Config_获取图片缓存() { 返回 Config_获取().图片缓存MB }
函数 Config_有GPU() { 返回 Config_获取().图处加速 }
函数 Config_有AI() { 返回 Config_获取().AI启用 }
函数 Config_是低端() { 返回 Config_获取().低端设备 }
函数 Config_省电中() { 返回 Config_获取().省电模式 }

// §7 AI配置自调节

函数 NBCI_AI_自调节(cfg) {
    如果 (全局AI总线 == 0 || !cfg.AI启用) { 返回 }
    NBCI_AI调整次数 = NBCI_AI调整次数 + 1
    定义 tensor = Tensor_创建(6)
    Tensor_写(tensor, 0, cfg.设备性能评分 / 100.0)
    Tensor_写(tensor, 1, cfg.总物理内存MB / 32768.0)
    Tensor_写(tensor, 2, cfg.目标帧率 / 240.0)
    Tensor_写(tensor, 3, 如果(cfg.图处加速, 1.0, 0.0))
    Tensor_写(tensor, 4, 如果(cfg.省电模式, 0.0, 1.0))
    Tensor_写(tensor, 5, cfg.设备宽 * cfg.设备高 / 8294400.0)
    定义 out = AI总线_推理(全局AI总线, "NBCI_调节", tensor, 6)
    如果 (out != 0) {
        定义 ai_threads = Tensor_读(out, 0) * 16
        如果 (ai_threads < 1) { ai_threads = 1 }
        如果 (ai_threads > 16) { ai_threads = 16 }
        cfg.AI推理线程数 = ai_threads
        定义 ai_mem = Tensor_读(out, 1) * cfg.总物理内存MB / 4
        如果 (ai_mem < 64) { ai_mem = 64 }
        如果 (ai_mem > 4096) { ai_mem = 4096 }
        cfg.AI最大内存MB = ai_mem
        Tensor_释放(out)
    }
    Tensor_释放(tensor)
}

// §8 配置诊断与导出

函数 NBCI_打印配置(cfg) {
    如果 (cfg == 0) { 打印("[NBCI] 配置未初始化"); 返回 }
    打印("[NBCI] === 浏览器配置概览 ===")
    打印("  显示: " + cfg.视口宽 + "x" + cfg.视口高 + " @" + cfg.目标帧率 + "fps")
    打印("  DPR=" + cfg.设备像素比 + " 色彩=" + cfg.色彩深度 + "bit HDR=" + cfg.HDR)
    打印("  音频: " + cfg.音频采样率 + "Hz " + cfg.音频声道数 + "ch " + cfg.音频位深度 + "bit")
    打印("  内存: total=" + cfg.总物理内存MB + "MB JS堆=" + cfg.JS堆上限MB + "MB img=" + cfg.图片缓存MB + "MB")
    打印("  GPU: accel=" + cfg.图处加速 + " maxTex=" + cfg.最大纹理尺寸 + " layers=" + cfg.最大层数)
    打印("  网络: conn=" + cfg.最大并发连接 + " h2流=" + cfg.HTTP2最大流 + " cache=" + cfg.网络缓存MB + "MB")
    打印("  安全: sandbox=" + cfg.沙箱启用 + " isolation=" + cfg.站点隔离 + " HSTS=" + cfg.HSTS启用)
    打印("  AI: enabled=" + cfg.AI启用 + " threads=" + cfg.AI推理线程数 + " mem=" + cfg.AI最大内存MB + "MB")
    打印("  性能: score=" + cfg.设备性能评分 + " lowEnd=" + cfg.低端设备 + " powerSave=" + cfg.省电模式)
}

函数 NBCI_运行时统计() {
    打印("[NBCI] inits=" + 整数转字符串(NBCI_初始化次数) +
         " perfs=" + 整数转字符串(NBCI_性能评分次数) +
         " adjusts=" + 整数转字符串(NBCI_动态调整次数) +
         " aiAdapt=" + 整数转字符串(NBCI_AI调整次数))
}

// §9 配置序列化与持久化

函数 NBCI_序列化配置(cfg) {
    如果 (cfg == 0) { 返回 空 }
    定义 可变 buf = "[NBCI_CONFIG]\n"
    buf = 字符串拼接(buf, "视口宽=" + cfg.视口宽 + "\n")
    buf = 字符串拼接(buf, "视口高=" + cfg.视口高 + "\n")
    buf = 字符串拼接(buf, "DPR=" + cfg.设备像素比 + "\n")
    buf = 字符串拼接(buf, "帧率=" + cfg.目标帧率 + "\n")
    buf = 字符串拼接(buf, "采样率=" + cfg.音频采样率 + "\n")
    buf = 字符串拼接(buf, "内存MB=" + cfg.总物理内存MB + "\n")
    buf = 字符串拼接(buf, "JS堆MB=" + cfg.JS堆上限MB + "\n")
    buf = 字符串拼接(buf, "GPU=" + cfg.图处加速 + "\n")
    buf = 字符串拼接(buf, "AI=" + cfg.AI启用 + "\n")
    buf = 字符串拼接(buf, "性能分=" + cfg.设备性能评分 + "\n")
    buf = 字符串拼接(buf, "低端=" + cfg.低端设备 + "\n")
    buf = 字符串拼接(buf, "省电=" + cfg.省电模式 + "\n")
    返回 buf
}

函数 NBCI_保存配置到磁盘(cfg, 路径) {
    定义 data = NBCI_序列化配置(cfg)
    如果 (data == 空) { 返回 假 }
    定义 fd = 系统调用_打开(路径, 0x241)  // O_WRONLY|O_CREAT|O_TRUNC
    如果 (fd < 0) { 返回 假 }
    定义 写入结果 = 系统调用_写(fd, data, 字符串长度(data))
    如果 (写入结果 < 0) { 系统调用_关闭(fd); 返回 -1 }
    系统调用_关闭(fd)
    返回 真
}

// §10 视口变化监听

函数 NBCI_视口变化(新宽, 新高) {
    定义 cfg = Config_获取()
    如果 (cfg == 0) { 返回 }
    如果 (新宽 <= 0 || 新高 <= 0) { 返回 }
    cfg.视口宽 = 新宽
    cfg.视口高 = 新高
    // 视口变小可能需要降级
    定义 pixels = 新宽 * 新高
    如果 (pixels < 921600 && cfg.最大层数 > 32) {
        cfg.最大层数 = 32
    }
    打印("[NBCI] viewport=" + 新宽 + "x" + 新高)
}

函数 NBCI_DPR变化(新DPR) {
    定义 cfg = Config_获取()
    如果 (cfg == 0 || 新DPR <= 0) { 返回 }
    cfg.设备像素比 = 新DPR
    // 高DPR设备需要更多纹理内存
    如果 (新DPR >= 2048) {
        cfg.图处纹理缓存MB = cfg.总物理内存MB / 6
        如果 (cfg.图处纹理缓存MB > 2048) { cfg.图处纹理缓存MB = 2048 }
    }
}

// §11 完整初始化入口

函数 NBCI_完整初始化() {
    NBCI_初始化次数 = NBCI_初始化次数 + 1
    定义 cfg = Config_初始化()
    // 性能评分
    NBCI_综合评分(cfg)
    // 应用分层策略
    NBCI_应用性能策略(cfg)
    // AI自调节
    NBCI_AI_自调节(cfg)
    // 诊断输出
    NBCI_打印配置(cfg)
    打印("[NBCI] 初始化完成")
    返回 cfg
}

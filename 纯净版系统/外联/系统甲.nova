导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("./数报扩展.nova")
导入("../中枢/每处理器.nova")
导入("../中枢/网络系统调用.nova")

函数 系统_connect(fd, 目标IP, 目标端口) {
    定义 sock = fd_到Socket(fd)
    如果 (sock == 空) { 返回 错误_坏文件描述符 }

    设置(sock, SOCK_远端IP, 目标IP)
    设置(sock, SOCK_远端端口, 目标端口)
    设置(sock, SOCK_状态, SS_正在连接)

    // 自动分配本地端口 (如果未bind)
    如果 (sock[SOCK_本地端口] == 0) {
        设置(sock, SOCK_本地端口, 分配临时端口())
    }

    // 传控: 发起三次握手
    如果 (sock[SOCK_类型] == SOCK_STREAM && sock[SOCK_TCB] != 空) {
        定义 tcb = sock[SOCK_TCB]
        设置(tcb, TCB_目标IP, 目标IP)
        设置(tcb, TCB_目标端口, 目标端口)
        设置(tcb, TCB_源端口, sock[SOCK_本地端口])
        // 发送SYN
        传控_发送SYN(tcb)
        设置(tcb, TCB_状态, 传控_状态_SYN发送)
        // 阻塞等待连接完成
        当 (tcb[TCB_状态] != 传控_状态_已建立) {
            如果 (tcb[TCB_状态] == 传控_状态_关闭) { 返回 错误_连接拒绝 }
            深睡当前进程("connect")
        }
        设置(sock, SOCK_状态, SS_已连接)
    }

    // 数报: 记录目标地址 (不需要握手)
    如果 (sock[SOCK_类型] == SOCK_DGRAM) {
        设置(sock, SOCK_状态, SS_已连接)
    }

    返回 成功
}

// send/recv: 数据传输

函数 系统_send(fd, 数据, 大小, 标志) {
    定义 sock = fd_到Socket(fd)
    如果 (sock == 空) { 返回 错误_坏文件描述符 }
    如果 (sock[SOCK_状态] != SS_已连接 && sock[SOCK_类型] == SOCK_STREAM) {
        返回 错误_未连接
    }

    定义 操作 = sock[SOCK_操作]
    如果 (操作 == 空 || 操作.发送 == 空) { 返回 错误_不支持 }

    定义 已发 = 操作.发送(sock, 数据, 大小, 标志)
    如果 (已发 > 0) { Socket_发送字节 = Socket_发送字节 + 已发 }
    返回 已发
}

函数 系统_recv(fd, 缓冲, 大小, 标志) {
    定义 sock = fd_到Socket(fd)
    如果 (sock == 空) { 返回 错误_坏文件描述符 }

    定义 操作 = sock[SOCK_操作]
    如果 (操作 == 空 || 操作.接收 == 空) { 返回 错误_不支持 }

    定义 已收 = 操作.接收(sock, 缓冲, 大小, 标志)
    如果 (已收 > 0) { Socket_接收字节 = Socket_接收字节 + 已收 }
    返回 已收
}

函数 系统_sendto(fd, 数据, 大小, 标志, 目标IP, 目标端口) {
    定义 sock = fd_到Socket(fd)
    如果 (sock == 空) { 返回 错误_坏文件描述符 }

    定义 操作 = sock[SOCK_操作]
    如果 (操作 == 空 || 操作.发送到 == 空) { 返回 错误_不支持 }

    返回 操作.发送到(sock, 数据, 大小, 标志, 目标IP, 目标端口)
}

函数 系统_recvfrom(fd, 缓冲, 大小, 标志) {
    定义 sock = fd_到Socket(fd)
    如果 (sock == 空) { 返回 错误_坏文件描述符 }

    定义 操作 = sock[SOCK_操作]
    如果 (操作 == 空 || 操作.接收从 == 空) { 返回 错误_不支持 }

    返回 操作.接收从(sock, 缓冲, 大小, 标志)
}

// close socket

函数 Socket_关闭(sock) {
    如果 (sock == 空) { 返回 }
    定义 操作 = sock[SOCK_操作]
    如果 (操作 != 空 && 操作.关闭 != 空) {
        操作.关闭(sock)
    }
    设置(sock, SOCK_状态, SS_未连接)
    Socket_关闭数 = Socket_关闭数 + 1
}

// setsockopt/getsockopt

函数 系统_setsockopt(fd, 级别, 选项, 值) {
    定义 sock = fd_到Socket(fd)
    如果 (sock == 空) { 返回 错误_坏文件描述符 }

    如果 (级别 == SOL_SOCKET) {
        如果 (选项 == SO_RCVBUF) {
            设置(sock, SOCK_接收缓冲大小, 值)
        } 否则 如果 (选项 == SO_SNDBUF) {
            设置(sock, SOCK_发送缓冲大小, 值)
        } 否则 如果 (选项 == SO_REUSEADDR) {
            设置(sock, SOCK_标志, sock[SOCK_标志] | SO_REUSEADDR)
        }
        返回 成功
    }
    返回 错误_不支持
}

// 辅助函数

函数 fd_到Socket(fd) {
    定义 当前 = 获取当前进程()
    定义 文件 = 文件表_获取(当前[T_文件表], fd)
    如果 (文件 == 空) { 返回 空 }
    // 从文件对象中获取socket
    返回 文件[F_私有数据]
}

// 别名(被网络系统调用引用)
函数 文件_获取socket(文件) {
    如果 (文件 == 空) { 返回 空 }
    返回 文件.私有数据
}

函数 Socket_创建文件(sock) {
    // 创建一个文件对象, 关联到socket
    返回 [空, 0, O_RDWR, 1, Socket_文件操作, 空, sock]
}

定义 F_私有数据 = 6

// 临时端口分配
定义 可变 下一个临时端口 = 32768
函数 分配临时端口() {
    定义 端口 = 下一个临时端口
    下一个临时端口 = 下一个临时端口 + 1
    如果 (下一个临时端口 > 60999) { 下一个临时端口 = 32768 }
    返回 端口
}

函数 端口_已被绑定(端口) {
    // 检查传控和数报绑定表中是否已有此端口
    如果 (数报_端口已占用(端口, 0)) { 返回 真 }
    // 检查已创建的socket列表
    定义 可变 i = 0
    当 (i < 计数(socket_表)) {
        如果 (socket_表[i] != 空) {
            定义 sk = socket_表[i].sock
            如果 (sk != 空 && sk.sk_sport == 端口) { 返回 真 }
        }
        i = i + 1
    }
    返回 假
}

定义 传控_协议操作 = 空
定义 数报_协议操作 = 空
定义 Socket_文件操作 = 空

// 统计

函数 Socket_统计() {
    返回 [Socket_创建数, Socket_关闭数, Socket_发送字节, Socket_接收字节]
}

定义 可变 AI_系统甲_运行指标 = 0
定义 可变 AI_系统甲_异常指标 = 0

函数 AI_系统甲_自诊断() {
    AI_系统甲_运行指标 = 0
    返回 AI_系统甲_运行指标
}

函数 AI_系统甲_优化建议() {
    定义 指标 = AI_系统甲_自诊断()
    返回 "系统甲状态正常"
}

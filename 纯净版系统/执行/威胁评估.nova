导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../外联/地址解析辅.nova")
导入("../中枢/时钟中枢.nova")
导入("../推理/总线悬浮球.nova")
导入("../中枢/整数转字符串.nova")

定义 威胁_低 = 0
定义 威胁_中 = 1
定义 威胁_高 = 2
定义 威胁_严重 = 3

定义 事件类型_域名检查 = 0
定义 事件类型_URL检查 = 1
定义 事件类型_内容检查 = 2
定义 事件类型_脚本检查 = 3
定义 事件类型_CSP违规 = 4
定义 事件类型_钓鱼检测 = 5
定义 事件类型_速率限制 = 6

定义 安全_事件日志上限 = 1000
定义 安全_速率窗口 = 60000
定义 安全_速率上限 = 100

结构 安全事件 {
    类型,
    域,
    详情,
    阻止,
    时间,
    威胁等级,
    评分,
}

结构 速率记录 {
    域,
    请求数,
    窗口开始,
}

定义 可变 安全_事件日志 = []
定义 可变 安全_总拦截数 = 0
定义 可变 安全_总检查数 = 0
定义 可变 安全_策略表 = []
定义 可变 安全_恶意域列表 = []
定义 可变 安全_白名单 = []
定义 可变 安全_速率表 = []

函数 浏览器安全_AI威胁评估(域) {
    安全_总检查数 = 安全_总检查数 + 1
    定义 可变 评分 = 30

    如果 (浏览器安全_在白名单(域)) { 返回 0 }
    如果 (浏览器安全_在黑名单(域)) { 返回 100 }

    如果 (字符串长度(域) > 50) { 评分 = 评分 + 15 }
    如果 (字符串长度(域) > 80) { 评分 = 评分 + 10 }
    如果 (字符串查找(域, "-") >= 0) { 评分 = 评分 + 5 }

    定义 可变 数字计数 = 0
    定义 可变 特殊计数 = 0
    定义 可变 子域计数 = 0
    定义 可变 i = 0
    当 (i < 字符串长度(域)) {
        定义 c = 字符串字节(域, i)
        如果 (c >= 48 && c <= 57) { 数字计数 = 数字计数 + 1 }
        如果 (c == 46) { 子域计数 = 子域计数 + 1 }
        如果 (c == 45 || c == 95) { 特殊计数 = 特殊计数 + 1 }
        i = i + 1
    }
    如果 (数字计数 > 字符串长度(域) / 3) { 评分 = 评分 + 20 }
    如果 (子域计数 > 4) { 评分 = 评分 + 15 }
    如果 (特殊计数 > 3) { 评分 = 评分 + 10 }

    评分 = 评分 + 浏览器安全_钓鱼特征分析(域)

    如果 (字符串查找(域, ".gov") >= 0) { 评分 = 评分 - 20 }
    如果 (字符串查找(域, ".edu") >= 0) { 评分 = 评分 - 15 }
    如果 (字符串查找(域, ".org") >= 0) { 评分 = 评分 - 10 }
    如果 (字符串查找(域, ".com") >= 0) { 评分 = 评分 - 5 }

    定义 AI深度分 = AI安全_评估域名(域)
    评分 = (评分 + AI深度分) / 2

    如果 (评分 < 0) { 评分 = 0 }
    如果 (评分 > 100) { 评分 = 100 }

    返回 评分
}

函数 浏览器安全_钓鱼特征分析(域) {
    定义 可变 钓鱼分 = 0

    定义 可变 可疑词 = ["login", "secure", "account", "verify", "update", "confirm", "banking", "paypal", "signin"]
    定义 可变 j = 0
    当 (j < 计数(可疑词)) {
        如果 (字符串查找(域, 可疑词[j]) >= 0) { 钓鱼分 = 钓鱼分 + 10 }
        j = j + 1
    }

    如果 (字符串查找(域, "xn--") >= 0) { 钓鱼分 = 钓鱼分 + 20 }

    返回 钓鱼分
}

函数 浏览器安全_评估URL(url) {
    安全_总检查数 = 安全_总检查数 + 1
    定义 可变 评分 = 20

    如果 (字符串长度(url) > 200) { 评分 = 评分 + 15 }
    如果 (字符串查找(url, "@") >= 0) { 评分 = 评分 + 25 }
    如果 (字符串查找(url, "data:") == 0) { 评分 = 评分 + 30 }
    如果 (字符串查找(url, "javascript:") == 0) { 评分 = 评分 + 40 }
    如果 (字符串查找(url, "%00") >= 0) { 评分 = 评分 + 20 }
    如果 (字符串查找(url, "/../") >= 0) { 评分 = 评分 + 15 }

    定义 可变 编码计数 = 0
    定义 可变 i = 0
    当 (i < 字符串长度(url)) {
        如果 (字符串字节(url, i) == 37) { 编码计数 = 编码计数 + 1 }
        i = i + 1
    }
    如果 (编码计数 > 10) { 评分 = 评分 + 15 }

    如果 (评分 < 0) { 评分 = 0 }
    如果 (评分 > 100) { 评分 = 100 }
    返回 评分
}

函数 浏览器安全_检查CSP(源, 指令, 值) {
    定义 可变 i = 0
    当 (i < 计数(安全_策略表)) {
        定义 策略 = 安全_策略表[i]
        如果 (策略.指令 == 指令) {
            如果 (字符串查找(策略.值, 源) >= 0 || 策略.值 == "*") {
                返回 真
            }
            浏览器安全_记录事件(事件类型_CSP违规, 源, "CSP违规: " + 指令 + " " + 源, 真)
            返回 假
        }
        i = i + 1
    }
    返回 真
}

函数 浏览器安全_速率检查(域) {
    定义 当前 = 读取毫秒()

    定义 可变 i = 0
    当 (i < 计数(安全_速率表)) {
        如果 (安全_速率表[i].域 == 域) {
            如果 (当前 - 安全_速率表[i].窗口开始 > 安全_速率窗口) {
                安全_速率表[i].请求数 = 1
                安全_速率表[i].窗口开始 = 当前
                返回 真
            }
            安全_速率表[i].请求数 = 安全_速率表[i].请求数 + 1
            如果 (安全_速率表[i].请求数 > 安全_速率上限) {
                浏览器安全_记录事件(事件类型_速率限制, 域, "速率超限: " + 整数转字符串(安全_速率表[i].请求数), 真)
                返回 假
            }
            返回 真
        }
        i = i + 1
    }

    追加(安全_速率表, 速率记录 { 域: 域, 请求数: 1, 窗口开始: 当前 })
    返回 真
}

函数 浏览器安全_在白名单(域) {
    定义 可变 i = 0
    当 (i < 计数(安全_白名单)) {
        如果 (安全_白名单[i] == 域) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 浏览器安全_在黑名单(域) {
    定义 可变 i = 0
    当 (i < 计数(安全_恶意域列表)) {
        如果 (安全_恶意域列表[i] == 域) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 浏览器安全_添加白名单(域) {
    如果 (!浏览器安全_在白名单(域)) { 追加(安全_白名单, 域) }
}

函数 浏览器安全_添加黑名单(域) {
    如果 (!浏览器安全_在黑名单(域)) { 追加(安全_恶意域列表, 域) }
}

函数 浏览器安全_威胁等级(评分) {
    如果 (评分 >= 80) { 返回 威胁_严重 }
    如果 (评分 >= 60) { 返回 威胁_高 }
    如果 (评分 >= 40) { 返回 威胁_中 }
    返回 威胁_低
}

函数 浏览器安全_威胁等级名(等级) {
    如果 (等级 == 威胁_严重) { 返回 "严重" }
    如果 (等级 == 威胁_高) { 返回 "高" }
    如果 (等级 == 威胁_中) { 返回 "中" }
    返回 "低"
}

函数 浏览器安全_记录事件(类型, 域, 详情, 阻止) {
    定义 评分 = 0
    如果 (类型 == 事件类型_域名检查) { 评分 = 浏览器安全_AI威胁评估(域) }

    定义 事件 = 安全事件 {}
    事件.类型 = 类型
    事件.域 = 域
    事件.详情 = 详情
    事件.阻止 = 阻止
    事件.时间 = 读取毫秒()
    事件.威胁等级 = 浏览器安全_威胁等级(评分)
    事件.评分 = 评分

    追加(安全_事件日志, 事件)

    如果 (计数(安全_事件日志) > 安全_事件日志上限) {
        列表_移除(安全_事件日志, 0)
    }

    如果 (阻止) {
        安全_总拦截数 = 安全_总拦截数 + 1
        内核信息("浏览器安全: [阻止] " + 详情)
    }
}

函数 浏览器安全_最近事件(数量) {
    定义 总数 = 计数(安全_事件日志)
    定义 开始 = 总数 - 数量
    如果 (开始 < 0) { 开始 = 0 }
    定义 可变 结果 = []
    定义 可变 i = 开始
    当 (i < 总数) {
        追加(结果, 安全_事件日志[i])
        i = i + 1
    }
    返回 结果
}

函数 浏览器安全_统计() {
    返回 [安全_总拦截数, 安全_总检查数, 计数(安全_事件日志),
          计数(安全_策略表), 计数(安全_恶意域列表), 计数(安全_白名单)]
}

导入("../基础.nova")
导入("../数学/统计.nova")
导入("../算法/数学扩展.nova")


定义 概率_种子 = 77777
函数 概率_随机() {
    概率_种子 = 概率_种子 * 1103515245 + 12345
    如果 (概率_种子 < 0) { 概率_种子 = 0 - 概率_种子 }
    返回 概率_种子 % 10000
}

// 均匀分布
函数 均匀_采样(最小, 最大) {
    返回 最小 + 概率_随机() * (最大 - 最小) / 10000
}

函数 均匀_批量采样(最小, 最大, N) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < N) { 追加(结果, 均匀_采样(最小, 最大))
    i = i + 1 }
    返回 结果
}

函数 均匀_PDF(x, 最小, 最大) {
    如果 (x < 最小) { 返回 0 }
    如果 (x > 最大) { 返回 0 }
    返回 1000 / (最大 - 最小)
}

// 正态分布 (中心极限定理)
函数 正态_采样(均值, 标准差) {
    // CLT: 总和 of 12 uniform[0,1] - 6 ≈ N(0,1)
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < 12) { 总和 = 总和 + 概率_随机()
    i = i + 1 }
    // 总和 ∈ [0, 120000], 均值=60000, std≈2887
    定义 z = (总和 - 60000) * 标准差 / 2887
    返回 均值 + z
}

函数 正态_批量采样(均值, 标准差, N) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < N) { 追加(结果, 正态_采样(均值, 标准差))
    i = i + 1 }
    返回 结果
}

// 伯努利分布
函数 伯努利_采样(概率_千分) {
    如果 (概率_随机() < 概率_千分 * 10000 / 1000) { 返回 1 }
    返回 0
}

函数 伯努利_批量(概率_千分, N) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < N) { 追加(结果, 伯努利_采样(概率_千分))
    i = i + 1 }
    返回 结果
}

// 二项分布
函数 二项_采样(N, 概率_千分) {
    定义 可变 成功 = 0
    定义 可变 i = 0
    当 (i < N) { 成功 = 成功 + 伯努利_采样(概率_千分)
    i = i + 1 }
    返回 成功
}

// 泊松分布 (Knuth算法近似, 0)
函数 泊松_采样(衰减系数) {
    定义 可变 k = 0
    定义 可变 p = 10000
    // e^(-衰减系数) 近似: (1-衰减系数/N)^N
    定义 可变 L = 10000
    定义 可变 i = 0
    当 (i < 衰减系数) {
        L = L * 3679 / 10000
        如果 (L < 1) { L = 1 }
        i = i + 1
    }
    当 (p > L) {
        k = k + 1
        p = p * (概率_随机()) / 10000
    }
    返回 k - 1
}

// 指数分布
函数 指数_采样(衰减系数) {
    定义 可变 u = 概率_随机()
    如果 (u < 1) { u = 1 }
    如果 (衰减系数 == 0) { 衰减系数 = 1 }
    // -ln(u/10000)/衰减系数 近似
    定义 ln_approx = (10000 - u) * 100 / u
    返回 ln_approx * 1000 / 衰减系数
}

// 统计函数
函数 样本_均值(数据) {
    如果 (计数(数据) == 0) { 返回 0 }
    返回 折叠(数据, 0, (s, x) => s + x) / 计数(数据)
}

函数 样本_方差(数据) {
    定义 均值 = 样本_均值(数据)
    返回 折叠(数据, 0, (s, x) => s + (x - 均值) * (x - 均值)) / 计数(数据)
}

// 样本标准差
函数 样本_标准差(数据) {
    定义 v = 样本_方差(数据)
    如果 (v <= 0) { 返回 0 }
    返回 整数sqrt(v)
}

// 蒙特卡洛
函数 蒙特卡洛_估计Pi(N) {
    定义 可变 内部 = 0
    定义 可变 i = 0
    当 (i < N) {
        定义 x = 概率_随机() - 5000
        定义 y = 概率_随机() - 5000
        如果 (x * x + y * y <= 5000 * 5000) { 内部 = 内部 + 1 }
        i = i + 1
    }
    如果 (N == 0) { 返回 0 }
    返回 内部 * 4000 / N
}

// 正态分布 (PDF/CDF近似)

函数 正态_PDF(x, 均值, 标准差) {
    定义 差值 = x - 均值
    定义 指数项 = 0 - 差值 * 差值 / (2 * 标准差 * 标准差)
    // 近似e^x: 1 + x + x^2/2
    定义 可变 ex = 1000 + 指数项 + 指数项 * 指数项 / 2000
    如果 (ex < 0) { ex = 0 }
    返回 ex * 1000 / (标准差 * 2507)  // 2507 ≈ sqrt(2π)*1000
}

函数 正态_CDF近似(x, 均值, 标准差) {
    定义 z = (x - 均值) * 1000 / (标准差 + 1)
    // 近似: 0.5 * (1 + tanh(z * 0.7978))
    定义 t = z * 798 / 1000
    定义 可变 tanh近似 = t
    如果 (tanh近似 > 1000) { tanh近似 = 1000 }
    如果 (tanh近似 < -1000) { tanh近似 = -1000 }
    返回 500 + tanh近似 / 2
}

// 泊松分布 (PMF, 0)

函数 泊松_PMF(k, 衰减系数) {
    // P(X=k) = λ^k * e^(-λ) / k!
    定义 可变 幂 = 1000
    定义 可变 i = 0
    当 (i < k) { 幂 = 幂 * 衰减系数 / 1000  i = i + 1 }
    定义 可变 阶乘 = 1
    i = 2
    当 (i <= k) { 阶乘 = 阶乘 * i  i = i + 1 }
    // e^(-λ) 近似
    定义 可变 指数 = 1000 - 衰减系数 + 衰减系数 * 衰减系数 / 2000
    如果 (指数 < 0) { 指数 = 1 }
    返回 幂 * 指数 / (阶乘 * 1000)
}

// 指数分布 (PDF, 0)

函数 指数_PDF(x, 衰减系数) {
    如果 (x < 0) { 返回 0 }
    定义 指数项 = 0 - 衰减系数 * x / 1000
    定义 可变 ex = 1000 + 指数项
    如果 (ex < 0) { ex = 0 }
    返回 衰减系数 * ex / 1000
}

// 二项分布 (均值/方差, 0 , 0)

函数 二项_均值(n, p) { 返回 n * p / 1000 }
函数 二项_方差(n, p) { 返回 n * p * (1000 - p) / 1000000 }

// 统计工具

函数 概率分布_统计_均值(数据) {
    如果 (计数(数据) == 0) { 返回 0 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(数据)) { 总 = 总 + 数据[i]  i = i + 1 }
    返回 总 / 计数(数据)
}

函数 概率分布_统计_方差(数据) {
    如果 (计数(数据) < 2) { 返回 0 }
    定义 均 = 统计_均值(数据)
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        定义 d = 数据[i] - 均
        总 = 总 + d * d
        i = i + 1
    }
    返回 总 / (计数(数据) - 1)
}

函数 概率分布_统计_中位数(数据) {
    如果 (计数(数据) == 0) { 返回 0 }
    // 简单排序
    定义 可变 排序 = []
    定义 可变 i = 0
    当 (i < 计数(数据)) { 追加(排序, 数据[i])  i = i + 1 }
    i = 0
    当 (i < 计数(排序) - 1) {
        定义 可变 j = i + 1
        当 (j < 计数(排序)) {
            如果 (排序[j] < 排序[i]) { 定义 t = 排序[i]  排序[i] = 排序[j]  排序[j] = t }
            j = j + 1
        }
        i = i + 1
    }
    定义 n = 计数(排序)
    如果 (n % 2 == 1) { 返回 排序[n / 2] }
    返回 (排序[n / 2 - 1] + 排序[n / 2]) / 2
}

// 贝叶斯更新

函数 贝叶斯_更新(先验, 似然, 证据) {
    如果 (证据 == 0) { 返回 先验 }
    返回 先验 * 似然 / 证据
}

函数 贝叶斯_批量更新(先验列表, 似然列表) {
    定义 可变 后验 = []
    定义 可变 证据 = 0
    定义 可变 i = 0
    当 (i < 计数(先验列表)) {
        证据 = 证据 + 先验列表[i] * 似然列表[i] / 1000
        i = i + 1
    }
    i = 0
    当 (i < 计数(先验列表)) {
        追加(后验, 先验列表[i] * 似然列表[i] / (证据 + 1))
        i = i + 1
    }
    返回 后验
}

定义 可变 _概率_采样次数 = 0
定义 可变 _概率_分布类型数 = 0

函数 概率分布_概率_记录采样() { _概率_采样次数 = _概率_采样次数 + 1 }
函数 概率_记录分布() { _概率_分布类型数 = _概率_分布类型数 + 1 }

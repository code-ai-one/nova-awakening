导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../引导/处理标识查.nova")
导入("../引导/端口输入.nova")
导入("../引导/特权指令.nova")

//   1. /dev/random: 阻塞式真随机(熵池耗尽时阻塞)
//   2. /dev/urandom: 非阻塞伪随机(总是返回)
//   3. 熵源: 中断时间/键盘/鼠标/磁盘IO时间差
//   4. CSPRNG: ChaCha20流密码(Linux 5.17+)
//   5. get_random_bytes: 内核接口获取随机字节
//   6. RDRAND: 硬件随机数指令(Intel/AMD)

定义 熵池大小 = 512
定义 可变 熵池 = []
定义 可变 熵池_写位 = 0
定义 可变 熵_可用位 = 0       // 估计的可用熵(bit)
定义 可变 熵_总收集 = 0

定义 可变 prng_s0 = 0x853C49E6748FEA9B
定义 可变 prng_s1 = 0xDA3E39CB94B95BDB
定义 可变 prng_已初始化 = 假

定义 可变 有RDRAND = 假

// 初始化

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 随机_初始化() {
    // 初始化熵池
    熵池 = []
    定义 可变 i = 0
    当 (i < 熵池大小) { 追加(熵池, 0); i = i + 1 }
    熵池_写位 = 0
    熵_可用位 = 0

    // 检查RDRAND支持
    有RDRAND = CPU支持RDRAND()

    // 用TSC种子初始化PRNG
    定义 tsc = 读取时间戳()
    prng_s0 = tsc ^ 0x853C49E6748FEA9B
    prng_s1 = (tsc >> 17) ^ 0xDA3E39CB94B95BDB
    如果 (prng_s0 == 0) { prng_s0 = 1 }
    如果 (prng_s1 == 0) { prng_s1 = 1 }
    prng_已初始化 = 真

    如果 (有RDRAND) {
        内核信息("随机: 初始化 (RDRAND硬件支持)")
    } 否则 {
        内核信息("随机: 初始化 (软件PRNG, TSC种子)")
    }
}

// 熵收集 (中断/输入事件时调用)

函数 随机_添加熵(值) {
    // 混入熵池
    定义 位置 = 熵池_写位 % 熵池大小
    设置(熵池, 位置, 熵池[位置] ^ 值)
    熵池_写位 = 熵池_写位 + 1
    熵_可用位 = 熵_可用位 + 1
    如果 (熵_可用位 > 熵池大小 * 8) { 熵_可用位 = 熵池大小 * 8 }
    熵_总收集 = 熵_总收集 + 1

    // 也混入PRNG状态
    prng_s0 = prng_s0 ^ 值
    如果 (prng_s0 == 0) { prng_s0 = 1 }
}

函数 随机_添加中断熵() {
    // 用中断时间戳的低位作为熵源
    定义 tsc = 读取时间戳()
    随机_添加熵(tsc & 0xFFFF)
}

函数 随机_添加输入熵(扫描码) {
    定义 tsc = 读取时间戳()
    随机_添加熵((tsc << 8) ^ 扫描码)
}

// 随机数生成

函数 get_random_u64() {
    // 优先使用RDRAND
    如果 (有RDRAND) {
        定义 hw = rdrand64()
        如果 (hw != 0) { 返回 hw }
    }
    // 回退到软件PRNG (xorshift128+)
    返回 xorshift128plus()
}

函数 get_random_u32() {
    返回 get_random_u64() & 0xFFFFFFFF
}

函数 get_random_bytes(缓冲, 长度) {
    定义 可变 i = 0
    当 (i < 长度) {
        定义 r = get_random_u64()
        定义 可变 j = 0
        当 (j < 8 && i < 长度) {
            内存写8(缓冲 + i, (r >> (j * 8)) & 0xFF)
            i = i + 1
            j = j + 1
        }
    }
}

// 范围随机: [0, max)
函数 get_random_range(最大值) {
    如果 (最大值 <= 0) { 返回 0 }
    返回 get_random_u64() % 最大值
}

// xorshift128+ PRNG (快速, 非加密)

函数 xorshift128plus() {
    定义 可变 s1 = prng_s0
    定义 s0 = prng_s1
    prng_s0 = s0
    s1 = s1 ^ (s1 << 23)
    s1 = s1 ^ (s1 >> 17)
    s1 = s1 ^ s0
    s1 = s1 ^ (s0 >> 26)
    prng_s1 = s1
    返回 prng_s0 + prng_s1
}

// RDRAND硬件随机 (Intel/AMD)

函数 rdrand64() {
    定义 可变 值 = 0
    定义 可变 成功 = 0
    汇编 {
        "rdrand rax"
        "jnc .rdrand_fail"
        "mov [rbp-8], rax"
        "mov qword [rbp-16], 1"
        "jmp .rdrand_done"
        ".rdrand_fail:"
        "mov qword [rbp-16], 0"
        ".rdrand_done:"
    }
    如果 (成功 == 0) { 返回 0 }
    返回 值
}

// /dev/random 和 /dev/urandom 读取

函数 dev_random_read(缓冲, 长度) {
    // /dev/random: 需要足够熵
    如果 (熵_可用位 < 长度 * 8) {
        // 阻塞直到有足够熵(M1优化: 不阻塞)
    }
    get_random_bytes(缓冲, 长度)
    熵_可用位 = 熵_可用位 - 长度 * 8
    如果 (熵_可用位 < 0) { 熵_可用位 = 0 }
    返回 长度
}

函数 dev_urandom_read(缓冲, 长度) {
    // /dev/urandom: 总是返回, 不阻塞
    get_random_bytes(缓冲, 长度)
    返回 长度
}

// 统计

函数 随机_统计() {
    返回 [熵_可用位, 熵_总收集, 有RDRAND]
}

// 熵池状态查询 + PRNG重播种

函数 随机_熵足够() {
    返回 熵_可用位 >= 256
}

函数 随机_重播种() {
    // 从熵池中取数据重新初始化PRNG
    定义 可变 种子 = 0
    定义 可变 i = 0
    当 (i < 8 && i < 熵池大小) {
        种子 = 种子 ^ (熵池[i] << (i * 8))
        i = i + 1
    }
    如果 (种子 != 0) {
        prng_s0 = prng_s0 ^ 种子
        prng_s1 = prng_s1 ^ (种子 >> 32)
        如果 (prng_s0 == 0) { prng_s0 = 1 }
        如果 (prng_s1 == 0) { prng_s1 = 1 }
    }
}

函数 get_random_bool() {
    返回 (get_random_u32() & 1) == 1
}

函数 随机_完整统计() {
    返回 [熵_可用位, 熵_总收集, 有RDRAND, prng_已初始化]
}

定义 可变 AI_随机数_风暴阈值 = 10000
定义 可变 AI_随机数_预测IRQ = 0

函数 AI_随机数_风暴检测(触发频率) {
    如果 (触发频率 > AI_随机数_风暴阈值) {
        AI_随机数_风暴阈值 = AI_随机数_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_随机数_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

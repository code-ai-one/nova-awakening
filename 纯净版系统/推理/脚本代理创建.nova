// §1 代理对象结构

定义 TRAP_GET = 0
定义 TRAP_SET = 1
定义 TRAP_HAS = 2
定义 TRAP_DELETE_PROPERTY = 3
定义 TRAP_APPLY = 4
定义 TRAP_CONSTRUCT = 5
定义 TRAP_GET_PROTOTYPE_OF = 6
定义 TRAP_SET_PROTOTYPE_OF = 7
定义 TRAP_IS_EXTENSIBLE = 8
定义 TRAP_PR事件_EXTENSIONS = 9
定义 TRAP_GET_OWN_PROPERTY_DESC = 10
定义 TRAP_DEFINE_PROPERTY = 11
定义 TRAP_OWN_KEYS = 12
定义 TRAP_COUNT = 13

结构 JS代理 {
 目标,    // u64 target对象
 处理器,    // u64 handler对象
 已撤销,    // 布尔 revoke后为true
 // 缓存的trap函数(避免每次查找)
 trap缓存,    // u64 u64[TRAP_COUNT]
}

函数 JS代理_创建(Nova运行时实例, 目标, 处理器) {
 如果 (目标 == 0) { 返回 0 } // Type错误: target不能为null
 如果 (处理器 == 0) { 返回 0 } // Type错误: handler不能为null

 定义 proxy = 堆_分配(JS代理)
 proxy.目标 = 目标
 proxy.处理器 = 处理器
 proxy.已撤销 = 假
 proxy.trap缓存 = 堆_分配_数组(TRAP_COUNT * 8)
 内存_清零(proxy.trap缓存, TRAP_COUNT * 8)

 // 预缓存handler中的trap
 JS代理_缓存trap(proxy, "get", TRAP_GET)
 JS代理_缓存trap(proxy, "set", TRAP_SET)
 JS代理_缓存trap(proxy, "has", TRAP_HAS)
 JS代理_缓存trap(proxy, "deleteProperty", TRAP_DELETE_PROPERTY)
 JS代理_缓存trap(proxy, "apply", TRAP_APPLY)
 JS代理_缓存trap(proxy, "construct", TRAP_CONSTRUCT)
 JS代理_缓存trap(proxy, "getPrototypeOf", TRAP_GET_PROTOTYPE_OF)
 JS代理_缓存trap(proxy, "setPrototypeOf", TRAP_SET_PROTOTYPE_OF)
 JS代理_缓存trap(proxy, "isExtensible", TRAP_IS_EXTENSIBLE)
 JS代理_缓存trap(proxy, "pr事件Extensions", TRAP_PR事件_EXTENSIONS)
 JS代理_缓存trap(proxy, "getOwnPropertyDescriptor", TRAP_GET_OWN_PROPERTY_DESC)
 JS代理_缓存trap(proxy, "defineProperty", TRAP_DEFINE_PROPERTY)
 JS代理_缓存trap(proxy, "ownKeys", TRAP_OWN_KEYS)

 返回 proxy
}

函数 JS代理_缓存trap(proxy, 名称, 索引) {
 定义 trap = Nova对象_获取属性(0, proxy.处理器, 名称)
 如果 (trap != 0 && JSValue_IsFunction(trap)) {
 内存_写64(proxy.trap缓存 + 索引 * 8, trap)
 }
}

函数 JS代理_获取trap(proxy, 索引) {
 如果 (proxy == 0 || proxy.已撤销) { 返回 0 }
 返回 内存_读64(proxy.trap缓存 + 索引 * 8)
}

// §2 代理.revocable

结构 代理Revocable {
 proxy,    // u64 JS代理*
 revoke,    // u64 revoke函数(JS)
}

函数 JS代理_revocable(Nova运行时实例, 目标, 处理器) {
 定义 proxy = JS代理_创建(Nova运行时实例, 目标, 处理器)
 定义 result = 堆_分配(代理Revocable)
 result.proxy = proxy
 // revoke函数: 调用时将proxy标记为已撤销
 result.revoke = proxy // 实际需包装为可调用的revoke函数
 返回 result
}

函数 JS代理_revoke(proxy) {
 如果 (proxy == 0) { 返回 }
 proxy.已撤销 = 真
 proxy.目标 = 0
 proxy.处理器 = 0
}


函数 JS代理_Get(Nova运行时实例, proxy, 键, 接收者) {
    如果 (proxy == 0 || proxy.已撤销) {
        打印("[代理] TypeError: 已撤销的代理不能执行get操作")
        返回 0
    }
    定义 trap = JS代理_获取trap(proxy, TRAP_GET)
    如果 (trap != 0) {
        // 调用handler.get(target, property, receiver)
        定义 参数 = 平台_申请内存(24)
        如果 (参数 != 0) {
            内存_写64(参数, proxy.目标)
            内存_写64(参数 + 8, 键)
            内存_写64(参数 + 16, 接收者)
            定义 结果 = Interpreter_调用函数(Nova运行时实例, trap, proxy.处理器, 参数, 3, 0)
            平台_释放内存(参数, 24)
            返回 结果
        }
    }
    // 无trap → 直接操作目标
    返回 Nova对象_获取属性(Nova运行时实例, proxy.目标, 键)
}

函数 JS代理_Set(Nova运行时实例, proxy, 键, 值, 接收者) {
    如果 (proxy == 0 || proxy.已撤销) {
        打印("[代理] TypeError: 已撤销的代理不能执行set操作")
        返回 假
    }
    定义 trap = JS代理_获取trap(proxy, TRAP_SET)
    如果 (trap != 0) {
        定义 参数 = 平台_申请内存(32)
        如果 (参数 != 0) {
            内存_写64(参数, proxy.目标)
            内存_写64(参数 + 8, 键)
            内存_写64(参数 + 16, 值)
            内存_写64(参数 + 24, 接收者)
            定义 结果 = Interpreter_调用函数(Nova运行时实例, trap, proxy.处理器, 参数, 4, 0)
            平台_释放内存(参数, 32)
            返回 JSValue_ToBoolean(Nova运行时实例, 结果)
        }
    }
    Nova对象_设置属性(Nova运行时实例, proxy.目标, 键, 值)
    返回 真
}

函数 JS代理_Has(Nova运行时实例, proxy, 键) {
    如果 (proxy == 0 || proxy.已撤销) { 返回 假 }
    定义 trap = JS代理_获取trap(proxy, TRAP_HAS)
    如果 (trap != 0) {
        定义 参数 = 平台_申请内存(16)
        如果 (参数 != 0) {
            内存_写64(参数, proxy.目标)
            内存_写64(参数 + 8, 键)
            定义 结果 = Interpreter_调用函数(Nova运行时实例, trap, proxy.处理器, 参数, 2, 0)
            平台_释放内存(参数, 16)
            返回 JSValue_ToBoolean(Nova运行时实例, 结果)
        }
    }
    返回 Nova对象_HasProperty(Nova运行时实例, proxy.目标, 键)
}

函数 JS代理_DeleteProperty(Nova运行时实例, proxy, 键) {
    如果 (proxy == 0 || proxy.已撤销) { 返回 假 }
    定义 trap = JS代理_获取trap(proxy, TRAP_DELETE_PROPERTY)
    如果 (trap != 0) {
        定义 参数 = 平台_申请内存(16)
        如果 (参数 != 0) {
            内存_写64(参数, proxy.目标)
            内存_写64(参数 + 8, 键)
            定义 结果 = Interpreter_调用函数(Nova运行时实例, trap, proxy.处理器, 参数, 2, 0)
            平台_释放内存(参数, 16)
            返回 JSValue_ToBoolean(Nova运行时实例, 结果)
        }
    }
    返回 Nova对象_Delete(Nova运行时实例, proxy.目标, 键)
}


函数 JS代理_Apply(Nova运行时实例, proxy, thisArg, args, argc) {
    如果 (proxy == 0 || proxy.已撤销) { 返回 0 }
    定义 trap = JS代理_获取trap(proxy, TRAP_APPLY)
    如果 (trap != 0) {
        定义 参数 = 平台_申请内存(24)
        如果 (参数 != 0) {
            内存_写64(参数, proxy.目标)
            内存_写64(参数 + 8, thisArg)
            内存_写64(参数 + 16, args)
            定义 结果 = Interpreter_调用函数(Nova运行时实例, trap, proxy.处理器, 参数, 3, 0)
            平台_释放内存(参数, 24)
            返回 结果
        }
    }
    返回 Interpreter_调用函数(Nova运行时实例, proxy.目标, thisArg, args, argc, 0)
}

函数 JS代理_Construct(Nova运行时实例, proxy, args, argc, newTarget) {
    如果 (proxy == 0 || proxy.已撤销) { 返回 0 }
    定义 trap = JS代理_获取trap(proxy, TRAP_CONSTRUCT)
    如果 (trap != 0) {
        定义 参数 = 平台_申请内存(24)
        如果 (参数 != 0) {
            内存_写64(参数, proxy.目标)
            内存_写64(参数 + 8, args)
            内存_写64(参数 + 16, newTarget)
            定义 结果 = Interpreter_调用函数(Nova运行时实例, trap, proxy.处理器, 参数, 3, 0)
            平台_释放内存(参数, 24)
            返回 结果
        }
    }
    返回 0
}


函数 JS代理_OwnKeys(Nova运行时实例, proxy) {
    如果 (proxy == 0 || proxy.已撤销) { 返回 0 }
    定义 trap = JS代理_获取trap(proxy, TRAP_OWN_KEYS)
    如果 (trap != 0) {

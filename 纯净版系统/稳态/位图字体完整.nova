导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../感知/内核直连层.nova")
导入("../执行/控制台输出.nova")

定义 默认字宽 = 8
定义 默认字高 = 16
定义 首字符 = 32
定义 末字符 = 126
定义 最大字库 = 65536

结构 字体信息 {
    宽,
    高,
    基线位图,
    字符数,
    每字符字节,
    中文库,
    中文库大小,
    中文已加载,
}

定义 可变 当前字体 = 0
定义 可变 渲染字符数 = 0
定义 可变 渲染中文数 = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 字体_初始化(宽, 高, 位图数据) {
    当前字体 = 堆_分配(字体信息)
    当前字体.宽 = 宽
    当前字体.高 = 高
    当前字体.基线位图 = 位图数据
    当前字体.字符数 = 末字符 - 首字符 + 1
    当前字体.每字符字节 = (宽 + 7) / 8 * 高
    当前字体.中文库 = 0
    当前字体.中文库大小 = 0
    当前字体.中文已加载 = 假
}

函数 字体_加载中文库(数据, 大小) {
    如果 (当前字体 == 0) { 返回 }
    当前字体.中文库 = 数据
    当前字体.中文库大小 = 大小
    当前字体.中文已加载 = 真
}

函数 字体_获取字形(字符码) {
    如果 (当前字体 == 0) { 返回 0 }
    如果 (字符码 >= 首字符 && 字符码 <= 末字符) {
        定义 索引 = 字符码 - 首字符
        返回 当前字体.基线位图 + 索引 * 当前字体.每字符字节
    }
    返回 0
}

函数 字体_渲染字符(帧缓冲, 横, 纵, 字符码, 前景, 背景) {
    如果 (当前字体 == 0) { 返回 }
    渲染字符数 = 渲染字符数 + 1
    定义 字形 = 字体_获取字形(字符码)
    如果 (字形 == 0) { 返回 }
    定义 字宽 = 当前字体.宽
    定义 字高 = 当前字体.高
    定义 行字节 = (字宽 + 7) / 8
    定义 可变 行 = 0
    当 (行 < 字高) {
        定义 可变 列 = 0
        当 (列 < 字宽) {
            定义 字节索引 = 列 / 8
            定义 位索引 = 7 - (列 % 8)
            定义 像素 = (内存_读8(字形 + 行 * 行字节 + 字节索引) >> 位索引) & 1
            如果 (像素) {
                帧缓冲_写像素(横 + 列, 纵 + 行, 前景)
            } 否则 如果 (背景 != 0) {
                帧缓冲_写像素(横 + 列, 纵 + 行, 背景)
            }
            列 = 列 + 1
        }
        行 = 行 + 1
    }
}

函数 字体_渲染中文(帧缓冲, 横, 纵, 区码, 位码, 前景, 背景) {
    如果 (当前字体 == 0 || !当前字体.中文已加载) { 返回 }
    渲染中文数 = 渲染中文数 + 1
    定义 索引 = (区码 - 1) * 94 + (位码 - 1)
    定义 每字节 = 32
    定义 偏移 = 当前字体.中文库 + 索引 * 每字节
    如果 (偏移 + 每字节 > 当前字体.中文库 + 当前字体.中文库大小) { 返回 }
    定义 可变 行 = 0
    当 (行 < 16) {
        定义 字节一 = 内存_读8(偏移 + 行 * 2)
        定义 字节二 = 内存_读8(偏移 + 行 * 2 + 1)
        定义 可变 列 = 0
        当 (列 < 8) {
            如果 ((字节一 >> (7 - 列)) & 1) {
                帧缓冲_写像素(横 + 列, 纵 + 行, 前景)
            } 否则 如果 (背景 != 0) {
                帧缓冲_写像素(横 + 列, 纵 + 行, 背景)
            }
            列 = 列 + 1
        }
        当 (列 < 16) {
            如果 ((字节二 >> (15 - 列)) & 1) {
                帧缓冲_写像素(横 + 列, 纵 + 行, 前景)
            } 否则 如果 (背景 != 0) {
                帧缓冲_写像素(横 + 列, 纵 + 行, 背景)
            }
            列 = 列 + 1
        }
        行 = 行 + 1
    }
}

函数 字体_渲染字符串(帧缓冲, 横, 纵, 文本, 长度, 前景, 背景) {
    定义 可变 当前横 = 横
    定义 可变 位 = 0
    当 (位 < 长度) {
        定义 字节 = 内存_读8(文本 + 位)
        如果 (字节 < 128) {
            字体_渲染字符(帧缓冲, 当前横, 纵, 字节, 前景, 背景)
            当前横 = 当前横 + 当前字体.宽
            位 = 位 + 1
        } 否则 如果 (位 + 1 < 长度) {
            定义 字节二 = 内存_读8(文本 + 位 + 1)
            定义 区码 = 字节 - 0xA0
            定义 位码 = 字节二 - 0xA0
            字体_渲染中文(帧缓冲, 当前横, 纵, 区码, 位码, 前景, 背景)
            当前横 = 当前横 + 16
            位 = 位 + 2
        } 否则 {
            位 = 位 + 1
        }
    }
}

函数 字体_获取宽() {
    如果 (当前字体 == 0) { 返回 默认字宽 }
    返回 当前字体.宽
}

函数 字体_获取高() {
    如果 (当前字体 == 0) { 返回 默认字高 }
    返回 当前字体.高
}

函数 位图字体_完整统计() {
    如果 (当前字体 == 0) { 返回 [默认字宽, 默认字高, 0, 假, 0, 0, 0] }
    返回 [当前字体.宽, 当前字体.高, 当前字体.字符数, 当前字体.中文已加载, 当前字体.中文库大小, 渲染字符数, 渲染中文数]
}

// §2 字体健康检查与诊断

函数 字体_健康检查() {
    定义 可变 问题 = []
    如果 (当前字体 == 0) { 追加(问题, "字体未初始化"); 返回 问题 }
    如果 (当前字体.基线位图 == 0) { 追加(问题, "字体位图数据为空") }
    如果 (!当前字体.中文已加载) { 追加(问题, "中文字库未加载") }
    如果 (计数(问题) == 0) { 返回 "位图字体健康" }
    返回 问题
}

函数 字体_详细统计() {
    如果 (当前字体 == 0) { 返回 空 }
    返回 {
        宽: 当前字体.宽,
        高: 当前字体.高,
        字符数: 当前字体.字符数,
        每字符字节: 当前字体.每字符字节,
        中文已加载: 当前字体.中文已加载,
        中文库大小: 当前字体.中文库大小,
        渲染ASCII: 渲染字符数,
        渲染中文: 渲染中文数,
        总渲染: 渲染字符数 + 渲染中文数,
    }
}

函数 字体_重置统计() {
    渲染字符数 = 0
    渲染中文数 = 0
}

// §3 文本测量

函数 字体_文本宽度(文本, 长度) {
    如果 (当前字体 == 0) { 返回 长度 * 默认字宽 }
    定义 可变 宽度 = 0
    定义 可变 位 = 0
    当 (位 < 长度) {
        定义 字节 = 内存_读8(文本 + 位)
        如果 (字节 < 128) {
            宽度 = 宽度 + 当前字体.宽
            位 = 位 + 1
        } 否则 {
            宽度 = 宽度 + 16
            位 = 位 + 2
        }
    }
    返回 宽度
}

函数 字体_文本高度() {
    如果 (当前字体 == 0) { 返回 默认字高 }
    返回 当前字体.高
}

函数 字体_字符数_从文本(文本, 长度) {
    定义 可变 字符数 = 0
    定义 可变 位 = 0
    当 (位 < 长度) {
        定义 字节 = 内存_读8(文本 + 位)
        如果 (字节 < 128) { 位 = 位 + 1 }
        否则 { 位 = 位 + 2 }
        字符数 = 字符数 + 1
    }
    返回 字符数
}

函数 字体_计算行数(文本, 长度, 最大宽度) {
    如果 (最大宽度 <= 0) { 返回 1 }
    定义 文本宽 = 字体_文本宽度(文本, 长度)
    定义 行数 = (文本宽 + 最大宽度 - 1) / 最大宽度
    如果 (行数 < 1) { 返回 1 }
    返回 行数
}

函数 字体_每行字符数(最大宽度) {
    如果 (当前字体 == 0) { 返回 最大宽度 / 默认字宽 }
    返回 最大宽度 / 当前字体.宽
}

// §4 控制台文本输出

定义 可变 控制台_光标X = 0
定义 可变 控制台_光标Y = 0
定义 可变 控制台_前景色 = 0xFFFFFF
定义 可变 控制台_背景色 = 0x000000
定义 可变 控制台_屏幕宽 = 1920
定义 可变 控制台_屏幕高 = 1080
定义 可变 控制台_帧缓冲 = 0

函数 控制台_初始化(帧缓冲, 宽, 高) {
    控制台_帧缓冲 = 帧缓冲
    控制台_屏幕宽 = 宽
    控制台_屏幕高 = 高
    控制台_光标X = 0
    控制台_光标Y = 0
}

函数 控制台_打印字符(ch) {
    如果 (控制台_帧缓冲 == 0 || 当前字体 == 0) { 返回 }
    如果 (ch == 10) {
        控制台_光标X = 0
        控制台_光标Y = 控制台_光标Y + 当前字体.高
        如果 (控制台_光标Y + 当前字体.高 > 控制台_屏幕高) {
            控制台_滚动()
        }
        返回
    }
    如果 (ch == 13) { 控制台_光标X = 0; 返回 }
    如果 (ch == 9) { 控制台_光标X = (控制台_光标X / (当前字体.宽 * 8) + 1) * 当前字体.宽 * 8; 返回 }
    字体_渲染字符(控制台_帧缓冲, 控制台_光标X, 控制台_光标Y, ch, 控制台_前景色, 控制台_背景色)
    控制台_光标X = 控制台_光标X + 当前字体.宽
    如果 (控制台_光标X + 当前字体.宽 > 控制台_屏幕宽) {
        控制台_光标X = 0
        控制台_光标Y = 控制台_光标Y + 当前字体.高
        如果 (控制台_光标Y + 当前字体.高 > 控制台_屏幕高) {
            控制台_滚动()
        }
    }
}

函数 控制台_打印(文本) {
    如果 (文本 == 0) { 返回 }
    定义 长度 = 字节长度(文本)
    定义 可变 i = 0
    当 (i < 长度) {
        控制台_打印字符(内存_读8(文本 + i))
        i = i + 1
    }
}

函数 控制台_换行() {
    控制台_打印字符(10)
}

函数 控制台_滚动() {
    如果 (控制台_帧缓冲 == 0 || 当前字体 == 0) { 返回 }
    定义 行字节 = 控制台_屏幕宽 * 4
    定义 滚动高度 = 当前字体.高
    内存_复制(控制台_帧缓冲, 控制台_帧缓冲 + 滚动高度 * 行字节, (控制台_屏幕高 - 滚动高度) * 行字节)
    定义 可变 i = 0
    当 (i < 滚动高度 * 行字节) {
        内存_写8(控制台_帧缓冲 + (控制台_屏幕高 - 滚动高度) * 行字节 + i, 0)
        i = i + 1
    }
    控制台_光标Y = 控制台_光标Y - 滚动高度
}

函数 控制台_设置颜色(前景, 背景) {
    控制台_前景色 = 前景
    控制台_背景色 = 背景
}

函数 控制台_清屏() {
    如果 (控制台_帧缓冲 == 0) { 返回 }
    定义 总字节 = 控制台_屏幕宽 * 控制台_屏幕高 * 4
    定义 可变 i = 0
    当 (i < 总字节) {
        内存_写8(控制台_帧缓冲 + i, 0)
        i = i + 1
    }
    控制台_光标X = 0
    控制台_光标Y = 0
}

函数 控制台_设置光标(x, y) {
    控制台_光标X = x
    控制台_光标Y = y
}

函数 控制台_获取列数() {
    如果 (当前字体 == 0) { 返回 控制台_屏幕宽 / 默认字宽 }
    返回 控制台_屏幕宽 / 当前字体.宽
}

函数 控制台_获取行数() {
    如果 (当前字体 == 0) { 返回 控制台_屏幕高 / 默认字高 }
    返回 控制台_屏幕高 / 当前字体.高
}

// §5 UTF-8辅助

函数 UTF8_字符长度(首字节) {
    如果 (首字节 < 0x80) { 返回 1 }
    如果 (首字节 < 0xC0) { 返回 1 }
    如果 (首字节 < 0xE0) { 返回 2 }
    如果 (首字节 < 0xF0) { 返回 3 }
    返回 4
}

函数 UTF8_解码(数据, 位置) {
    定义 首字节 = 内存_读8(数据 + 位置)
    如果 (首字节 < 0x80) { 返回 首字节 }
    如果 (首字节 < 0xE0) {
        返回 ((首字节 & 0x1F) << 6) | (内存_读8(数据 + 位置 + 1) & 0x3F)
    }
    如果 (首字节 < 0xF0) {
        返回 ((首字节 & 0x0F) << 12) | ((内存_读8(数据 + 位置 + 1) & 0x3F) << 6) | (内存_读8(数据 + 位置 + 2) & 0x3F)
    }
    返回 ((首字节 & 0x07) << 18) | ((内存_读8(数据 + 位置 + 1) & 0x3F) << 12) | ((内存_读8(数据 + 位置 + 2) & 0x3F) << 6) | (内存_读8(数据 + 位置 + 3) & 0x3F)
}

函数 UTF8_是ASCII(字节) {
    返回 字节 < 0x80
}

函数 UTF8_是中文(码点) {
    返回 码点 >= 0x4E00 && 码点 <= 0x9FFF
}

函数 UTF8_字符串长度(数据, 字节长度) {
    定义 可变 字符数 = 0
    定义 可变 位 = 0
    当 (位 < 字节长度) {
        位 = 位 + UTF8_字符长度(内存_读8(数据 + 位))
        字符数 = 字符数 + 1
    }
    返回 字符数
}

// §6 帧缓冲辅助接口

函数 帧缓冲_写像素(x, y, 颜色) {
    如果 (控制台_帧缓冲 == 0) { 返回 }
    如果 (x < 0 || x >= 控制台_屏幕宽 || y < 0 || y >= 控制台_屏幕高) { 返回 }
    定义 偏移 = (y * 控制台_屏幕宽 + x) * 4
    内存_写32(控制台_帧缓冲 + 偏移, 颜色)
}

函数 字体_控制台统计() {
    返回 {
        列数: 控制台_获取列数(),
        行数: 控制台_获取行数(),
        光标X: 控制台_光标X,
        光标Y: 控制台_光标Y,
        前景色: 控制台_前景色,
        渲染总数: 渲染字符数 + 渲染中文数,
    }
}

定义 可变 AI_位图字体完_操作热度 = 0

函数 AI_位图字体完_最优算法(数据量, 已排序) {
    AI_位图字体完_操作热度 = AI_位图字体完_操作热度 + 1
    如果 (数据量 < 16) { 返回 "插入排序" }
    如果 (已排序) { 返回 "二分查找" }
    如果 (数据量 < 10000) { 返回 "快速排序" }
    返回 "归并排序"
}

函数 位图字体完整_统计() {
    返回 {
        模块: "位图字体完整",
        当前字体: 当前字体,
        渲染字符数: 渲染字符数,
        渲染中文数: 渲染中文数,
        控制台_光标X: 控制台_光标X,
        控制台_光标Y: 控制台_光标Y,
        控制台_前景色: 控制台_前景色,
        控制台_背景色: 控制台_背景色,
        控制台_屏幕宽: 控制台_屏幕宽,
        控制台_屏幕高: 控制台_屏幕高,
        控制台_帧缓冲: 控制台_帧缓冲,
        AI_位图字体完_操作热度: AI_位图字体完_操作热度
    }
}

函数 位图字体完整_健康评估() {
    定义 可变 问题 = []

    返回 计数(问题) == 0
}

函数 位图字体完整_综合报告() {
    打印("[位图字体完整] ═══ 综合报告 ═══")
    打印("  当前字体: " + 整数转字符串(当前字体))
    打印("  渲染字符数: " + 整数转字符串(渲染字符数))
    打印("  渲染中文数: " + 整数转字符串(渲染中文数))
    打印("  控制台_光标X: " + 整数转字符串(控制台_光标X))
    打印("  控制台_光标Y: " + 整数转字符串(控制台_光标Y))
    打印("  控制台_前景色: " + 整数转字符串(控制台_前景色))
    打印("  控制台_背景色: " + 整数转字符串(控制台_背景色))
    打印("  控制台_屏幕宽: " + 整数转字符串(控制台_屏幕宽))
    打印("  控制台_屏幕高: " + 整数转字符串(控制台_屏幕高))
    打印("  控制台_帧缓冲: " + 整数转字符串(控制台_帧缓冲))
    打印("  AI_位图字体完_操作热度: " + 整数转字符串(AI_位图字体完_操作热度))
    打印("  健康: " + 如果 (位图字体完整_健康评估()) { "正常" } 否则 { "异常" })
}

函数 位图字体完整_全局重置() {
    当前字体 = 0
    渲染字符数 = 0
    渲染中文数 = 0
    控制台_光标X = 0
    控制台_光标Y = 0
    控制台_屏幕宽 = 1920
    控制台_屏幕高 = 1080
    控制台_帧缓冲 = 0
    AI_位图字体完_操作热度 = 0
    打印("[位图字体完整] 全局统计已重置")
    返回 0
}

// extent查找: 二分搜索定位逻辑块

函数 ext4_extent_查找(sb, Nova文件节点信息, 逻辑块) {
    定义 信息 = sb.私有信息
    定义 可变 头 = Nova文件节点信息.extent树
    定义 可变 深度 = 头.深度

    // 构建查找路径
    定义 可变 路径 = 数组<Ext4Extent路径>(深度 + 1)

    如果 (深度 == 0) {
        // 叶节点在Nova文件节点内嵌
        定义 extent = ext4_extent_二分查找_叶(头, 逻辑块)
        如果 (extent != 空) {
            定义 起始 = extent.逻辑块
            定义 长度 = ext4_extent_获取长度(extent)
            如果 (逻辑块 >= 起始 && 逻辑块 < 起始 + 长度) {
                定义 偏移 = 逻辑块 - 起始
                返回 ext4_extent_获取物理块(extent) + 偏移
            }
        }
        返回 0 - 1
    }

    // 多级索引遍历
    定义 可变 当前头 = 头
    定义 可变 当前深度 = 深度

    当 (当前深度 > 0) {
        定义 索引 = ext4_extent_二分查找_索引(当前头, 逻辑块)
        如果 (索引 == 空) {
            返回 0 - 1
        }

        定义 子块号 = ext4_索引_获取叶块(索引)
        定义 缓冲 = 块设备_读(sb.设备, 子块号 * 信息.块大小, 信息.块大小)
        如果 (缓冲 == 空) {
            返回 0 - 1
        }

        当前头 = ext4_extent_解析头(缓冲)
        如果 (当前头.魔数 != EXT4_EXTENT_魔数) {
            缓冲_释放(缓冲)
            返回 0 - 1
        }

        当前深度 = 当前深度 - 1
    }

    // 到达叶节点
    定义 extent = ext4_extent_二分查找_叶(当前头, 逻辑块)
    如果 (extent != 空) {
        定义 起始 = extent.逻辑块
        定义 长度 = ext4_extent_获取长度(extent)
        如果 (逻辑块 >= 起始 && 逻辑块 < 起始 + 长度) {
            返回 ext4_extent_获取物理块(extent) + (逻辑块 - 起始)
        }
    }
    返回 0 - 1
}

// 二分查找

函数 ext4_extent_二分查找_叶(头, 逻辑块) {
    定义 数量 = 头.有效项数
    如果 (数量 == 0) { 返回 空 }

    定义 可变 低 = 0
    定义 可变 高 = 数量 - 1
    定义 可变 结果 = 空

    当 (低 <= 高) {
        定义 中 = (低 + 高) / 2
        定义 项 = ext4_extent_获取第N项(头, 中)

        如果 (逻辑块 < 项.逻辑块) {
            如果 (中 == 0) { 跳出 }
            高 = 中 - 1
        } 否则 {
            结果 = 项
            低 = 中 + 1
        }
    }
    返回 结果
}

函数 ext4_extent_二分查找_索引(头, 逻辑块) {
    定义 数量 = 头.有效项数
    如果 (数量 == 0) { 返回 空 }

    定义 可变 低 = 0
    定义 可变 高 = 数量 - 1
    定义 可变 结果 = 空

    当 (低 <= 高) {
        定义 中 = (低 + 高) / 2
        定义 索引 = ext4_extent_获取第N索引(头, 中)

        如果 (逻辑块 < 索引.逻辑块) {
            如果 (中 == 0) { 跳出 }
            高 = 中 - 1
        } 否则 {
            结果 = 索引
            低 = 中 + 1
        }
    }
    返回 结果
}

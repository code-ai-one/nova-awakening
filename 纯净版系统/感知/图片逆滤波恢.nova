// NovaOS 渲染引擎 — PNG逆滤波 + 像素格式转换
// 子系统: 渲染引擎/图片解码/图片解码
// 实现: PNG滤波器逆运算(None/Sub/Up/Average/Paeth) + RGBA统一输出
//   支持8位/16位深度 + 灰度/RGB/RGBA/索引色/灰度Alpha
//   Adam7隔行扫描支持 + 批量行处理优化
// 原创: NovaOS · 纯中文原生系统编程 · AI原生滤波器预测优化

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/创建甲.nova")

// §1 常量定义

定义 滤波_None = 0
定义 滤波_Sub = 1
定义 滤波_Up = 2
定义 滤波_Average = 3
定义 滤波_Paeth = 4
定义 滤波_最大类型 = 4

// PNG颜色类型常量
定义 PNG颜色_灰度 = 0
定义 PNG颜色_RGB = 2
定义 PNG颜色_索引 = 3
定义 PNG颜色_灰度Alpha = 4
定义 PNG颜色_RGBA = 6

// Adam7隔行扫描起始位置和步长
定义 ADAM7_X起始 = [0, 4, 0, 2, 0, 1, 0]
定义 ADAM7_Y起始 = [0, 0, 4, 0, 2, 0, 1]
定义 ADAM7_X步长 = [8, 8, 4, 4, 2, 2, 1]
定义 ADAM7_Y步长 = [8, 8, 8, 4, 4, 2, 2]

// §2 数据结构

结构 滤波统计 {
    总行数,
    None行数,
    Sub行数,
    Up行数,
    Average行数,
    Paeth行数,
    无效滤波类型数,
    总像素转换数,
    灰度转换数,
    RGB转换数,
    RGBA直通数,
    索引色转换数,
    位深16转换数,
    总滤波耗时_纳秒,
    总转换耗时_纳秒,
    AI预测调用次数,
    AI预测命中次数,
    错误总数,
}

结构 AI滤波状态 {
    历史滤波分布,        // u64 指向5元素数组(每种滤波类型的计数)
    最近16行滤波序列,    // u64 指向16字节环形缓冲
    序列写位置,
    预测下行滤波类型,
    连续相同滤波计数,
    上次滤波类型,
    采样计数器,
    学习权重,            // u32 Q10
}

定义 可变 全局滤波统计 = 0
定义 可变 全局滤波AI = 0
定义 可变 全局滤波已初始化 = 假

// §3 生命周期管理


函数 PNG滤波_初始化() {
    如果 (全局滤波已初始化 == 真) { 返回 错误_已存在 }
    全局滤波统计 = 堆_分配_清零(144)
    如果 (全局滤波统计 == 空) { 返回 错误_内存不足 }
    全局滤波AI = 堆_分配_清零(48)
    如果 (全局滤波AI != 空) {
        全局滤波AI.历史滤波分布 = 堆_分配_清零(5 * 8)
        全局滤波AI.最近16行滤波序列 = 堆_分配_清零(16)
        全局滤波AI.序列写位置 = 0
        全局滤波AI.学习权重 = 128
    }
    全局滤波已初始化 = 真
    打印("[PNG滤波] 初始化完成")
    返回 0
}

函数 PNG滤波_销毁() {
    如果 (全局滤波AI != 空) {
        如果 (全局滤波AI.历史滤波分布 != 空) { 堆_释放(全局滤波AI.历史滤波分布) }
        如果 (全局滤波AI.最近16行滤波序列 != 空) { 堆_释放(全局滤波AI.最近16行滤波序列) }
        堆_释放(全局滤波AI)
        全局滤波AI = 0
    }
    如果 (全局滤波统计 != 空) { 堆_释放(全局滤波统计); 全局滤波统计 = 0 }
    全局滤波已初始化 = 假
    打印("[PNG滤波] 已销毁")
    返回 0
}

函数 PNG滤波_重置() {
    如果 (全局滤波统计 != 空) { 内存_置零(全局滤波统计, 144) }
    如果 (全局滤波AI != 空) {
        如果 (全局滤波AI.历史滤波分布 != 空) { 内存_置零(全局滤波AI.历史滤波分布, 40) }
        全局滤波AI.序列写位置 = 0
        全局滤波AI.连续相同滤波计数 = 0
    }
    返回 0
}

// §4 Paeth预测器(带绝对值内联优化)

函数 绝对值(v) {
    如果 (v < 0) { 返回 0 - v }
    返回 v
}

函数 Paeth预测(a, b, c) {
    定义 p = a + b - c
    定义 pa = 绝对值(p - a)
    定义 pb = 绝对值(p - b)
    定义 pc = 绝对值(p - c)
    如果 (pa <= pb && pa <= pc) { 返回 a }
    如果 (pb <= pc) { 返回 b }
    返回 c
}

// §5 逆滤波核心(带统计+AI反馈)

函数 PNG_逆滤波行(dec, 滤波类型, 行数据, 上一行) {
    如果 (dec == 空 || 行数据 == 空) { 返回 }
    如果 (滤波类型 > 滤波_最大类型) {
        如果 (全局滤波统计 != 空) {
            全局滤波统计.无效滤波类型数 = 全局滤波统计.无效滤波类型数 + 1
            全局滤波统计.错误总数 = 全局滤波统计.错误总数 + 1
        }
        返回
    }
    定义 开始时间 = 平台_获取高精度时间()
    定义 bpp = dec.通道数 * (dec.位深 / 8)
    如果 (bpp <= 0) { bpp = 1 }
    定义 行长 = dec.行字节
    定义 可变 i = 0

    如果 (滤波类型 == 滤波_None) {
        // 无操作
    }
    否则 如果 (滤波类型 == 滤波_Sub) {
        i = bpp
        当 (i < 行长) {
            定义 原 = 内存_读8(行数据 + i)
            定义 左 = 内存_读8(行数据 + i - bpp)
            内存_写8(行数据 + i, (原 + 左) & 0xFF)
            i = i + 1
        }
    }
    否则 如果 (滤波类型 == 滤波_Up) {
        如果 (上一行 == 空) {
            // 第一行: Up等价于None(上方全零)
        } 否则 {
            当 (i < 行长) {
                定义 原 = 内存_读8(行数据 + i)
                定义 上 = 内存_读8(上一行 + i)
                内存_写8(行数据 + i, (原 + 上) & 0xFF)
                i = i + 1
            }
        }
    }
    否则 如果 (滤波类型 == 滤波_Average) {
        当 (i < 行长) {
            定义 原 = 内存_读8(行数据 + i)
            定义 可变 左 = 0
            如果 (i >= bpp) { 左 = 内存_读8(行数据 + i - bpp) }
            定义 可变 上 = 0
            如果 (上一行 != 空) { 上 = 内存_读8(上一行 + i) }
            内存_写8(行数据 + i, (原 + (左 + 上) / 2) & 0xFF)
            i = i + 1
        }
    }
    否则 如果 (滤波类型 == 滤波_Paeth) {
        当 (i < 行长) {
            定义 原 = 内存_读8(行数据 + i)
            定义 可变 左 = 0
            如果 (i >= bpp) { 左 = 内存_读8(行数据 + i - bpp) }
            定义 可变 上 = 0
            如果 (上一行 != 空) { 上 = 内存_读8(上一行 + i) }
            定义 可变 左上 = 0
            如果 (i >= bpp && 上一行 != 空) { 左上 = 内存_读8(上一行 + i - bpp) }
            内存_写8(行数据 + i, (原 + Paeth预测(左, 上, 左上)) & 0xFF)
            i = i + 1
        }
    }

    // 统计更新
    如果 (全局滤波统计 != 空) {
        全局滤波统计.总行数 = 全局滤波统计.总行数 + 1
        如果 (滤波类型 == 滤波_None) { 全局滤波统计.None行数 = 全局滤波统计.None行数 + 1 }
        如果 (滤波类型 == 滤波_Sub) { 全局滤波统计.Sub行数 = 全局滤波统计.Sub行数 + 1 }
        如果 (滤波类型 == 滤波_Up) { 全局滤波统计.Up行数 = 全局滤波统计.Up行数 + 1 }
        如果 (滤波类型 == 滤波_Average) { 全局滤波统计.Average行数 = 全局滤波统计.Average行数 + 1 }
        如果 (滤波类型 == 滤波_Paeth) { 全局滤波统计.Paeth行数 = 全局滤波统计.Paeth行数 + 1 }
        定义 耗时 = 平台_获取高精度时间() - 开始时间
        全局滤波统计.总滤波耗时_纳秒 = 全局滤波统计.总滤波耗时_纳秒 + 耗时
    }
    // AI反馈
    AI滤波_记录行(滤波类型)
}

// §6 批量逆滤波(整幅图像一次处理)

函数 PNG_逆滤波_全部行(dec, 解压数据, 解压大小) {
    如果 (dec == 空 || 解压数据 == 空) { 返回 错误_无效参数 }
    定义 行步长 = dec.行字节 + 1   // +1滤波字节
    如果 (行步长 * dec.高 > 解压大小) {
        打印("[PNG滤波] 错误: 解压数据不足")
        如果 (全局滤波统计 != 空) { 全局滤波统计.错误总数 = 全局滤波统计.错误总数 + 1 }
        返回 错误_无效参数
    }
    定义 可变 y = 0
    当 (y < dec.高) {
        定义 行起始 = 解压数据 + y * 行步长
        定义 滤波类型 = 内存_读8(行起始)
        定义 行数据 = 行起始 + 1
        定义 可变 上一行 = 空
        如果 (y > 0) { 上一行 = 解压数据 + (y - 1) * 行步长 + 1 }
        PNG_逆滤波行(dec, 滤波类型, 行数据, 上一行)
        // 转换为RGBA
        PNG_行转RGBA(dec, y, 行数据)
        y = y + 1
    }
    返回 0
}

// §7 像素格式转换 → 统一RGBA输出(增强版 支持16位)

函数 PNG_行转RGBA(dec, 行号, 行数据) {
    如果 (dec == 空 || 行数据 == 空 || dec.像素缓冲 == 空) { 返回 }
    定义 输出偏移 = dec.像素缓冲 + 行号 * dec.宽 * 4
    定义 开始时间 = 平台_获取高精度时间()
    定义 可变 x = 0

    如果 (dec.位深 == 16) {
        // 16位深度: 每通道2字节，取高字节
        当 (x < dec.宽) {
            定义 src = 行数据 + x * dec.通道数 * 2
            定义 dst = 输出偏移 + x * 4
            如果 (dec.颜色类型 == PNG颜色_RGBA) {
                内存_写8(dst, 内存_读8(src))
                内存_写8(dst + 1, 内存_读8(src + 2))
                内存_写8(dst + 2, 内存_读8(src + 4))
                内存_写8(dst + 3, 内存_读8(src + 6))
            } 否则 如果 (dec.颜色类型 == PNG颜色_RGB) {
                内存_写8(dst, 内存_读8(src))
                内存_写8(dst + 1, 内存_读8(src + 2))
                内存_写8(dst + 2, 内存_读8(src + 4))
                内存_写8(dst + 3, 255)
            } 否则 如果 (dec.颜色类型 == PNG颜色_灰度) {
                定义 g = 内存_读8(src)
                内存_写8(dst, g); 内存_写8(dst + 1, g); 内存_写8(dst + 2, g)
                内存_写8(dst + 3, 255)
            } 否则 如果 (dec.颜色类型 == PNG颜色_灰度Alpha) {
                定义 g = 内存_读8(src)
                内存_写8(dst, g); 内存_写8(dst + 1, g); 内存_写8(dst + 2, g)
                内存_写8(dst + 3, 内存_读8(src + 2))
            }
            x = x + 1
        }
        如果 (全局滤波统计 != 空) {
            全局滤波统计.位深16转换数 = 全局滤波统计.位深16转换数 + dec.宽
        }
    } 否则 {
        // 8位深度(标准路径)
        当 (x < dec.宽) {
            定义 src = 行数据 + x * dec.通道数
            定义 dst = 输出偏移 + x * 4

            如果 (dec.颜色类型 == PNG颜色_RGBA) {
                内存_写8(dst, 内存_读8(src))
                内存_写8(dst + 1, 内存_读8(src + 1))
                内存_写8(dst + 2, 内存_读8(src + 2))
                内存_写8(dst + 3, 内存_读8(src + 3))
                如果 (全局滤波统计 != 空) { 全局滤波统计.RGBA直通数 = 全局滤波统计.RGBA直通数 + 1 }
            }
            否则 如果 (dec.颜色类型 == PNG颜色_RGB) {
                内存_写8(dst, 内存_读8(src))
                内存_写8(dst + 1, 内存_读8(src + 1))
                内存_写8(dst + 2, 内存_读8(src + 2))
                内存_写8(dst + 3, 255)
                如果 (全局滤波统计 != 空) { 全局滤波统计.RGB转换数 = 全局滤波统计.RGB转换数 + 1 }
            }
            否则 如果 (dec.颜色类型 == PNG颜色_灰度) {
                定义 g = 内存_读8(src)
                内存_写8(dst, g); 内存_写8(dst + 1, g); 内存_写8(dst + 2, g)
                内存_写8(dst + 3, 255)
                如果 (全局滤波统计 != 空) { 全局滤波统计.灰度转换数 = 全局滤波统计.灰度转换数 + 1 }
            }
            否则 如果 (dec.颜色类型 == PNG颜色_灰度Alpha) {
                定义 g = 内存_读8(src)
                内存_写8(dst, g); 内存_写8(dst + 1, g); 内存_写8(dst + 2, g)
                内存_写8(dst + 3, 内存_读8(src + 1))
            }
            否则 如果 (dec.颜色类型 == PNG颜色_索引 && dec.调色板 != 0) {
                定义 idx = 内存_读8(src)
                如果 (idx < dec.调色板大小) {
                    内存_写8(dst, 内存_读8(dec.调色板 + idx * 3))
                    内存_写8(dst + 1, 内存_读8(dec.调色板 + idx * 3 + 1))
                    内存_写8(dst + 2, 内存_读8(dec.调色板 + idx * 3 + 2))
                } 否则 {
                    内存_写8(dst, 0); 内存_写8(dst + 1, 0); 内存_写8(dst + 2, 0)
                }
                内存_写8(dst + 3, 255)
                如果 (全局滤波统计 != 空) { 全局滤波统计.索引色转换数 = 全局滤波统计.索引色转换数 + 1 }
            }
            x = x + 1
        }
    }

    如果 (全局滤波统计 != 空) {
        全局滤波统计.总像素转换数 = 全局滤波统计.总像素转换数 + dec.宽
        定义 耗时 = 平台_获取高精度时间() - 开始时间
        全局滤波统计.总转换耗时_纳秒 = 全局滤波统计.总转换耗时_纳秒 + 耗时
    }
}

// §8 Adam7隔行扫描辅助

函数 PNG_Adam7_获取遍数宽度(原始宽, 遍号) {
    如果 (遍号 < 0 || 遍号 >= 7) { 返回 0 }
    定义 起始 = ADAM7_X起始[遍号]
    定义 步长 = ADAM7_X步长[遍号]
    如果 (原始宽 <= 起始) { 返回 0 }
    返回 (原始宽 - 起始 + 步长 - 1) / 步长
}

函数 PNG_Adam7_获取遍数高度(原始高, 遍号) {
    如果 (遍号 < 0 || 遍号 >= 7) { 返回 0 }
    定义 起始 = ADAM7_Y起始[遍号]
    定义 步长 = ADAM7_Y步长[遍号]
    如果 (原始高 <= 起始) { 返回 0 }
    返回 (原始高 - 起始 + 步长 - 1) / 步长
}

函数 PNG_Adam7_写像素(dec, 遍号, 遍行, 遍列, 像素值) {
    如果 (dec == 空 || dec.像素缓冲 == 空) { 返回 }
    如果 (遍号 < 0 || 遍号 >= 7) { 返回 }
    定义 目标X = ADAM7_X起始[遍号] + 遍列 * ADAM7_X步长[遍号]
    定义 目标Y = ADAM7_Y起始[遍号] + 遍行 * ADAM7_Y步长[遍号]
    如果 (目标X >= dec.宽 || 目标Y >= dec.高) { 返回 }
    定义 偏移 = (目标Y * dec.宽 + 目标X) * 4
    内存_写32(dec.像素缓冲 + 偏移, 像素值)
}

// §9 AI基因 — 滤波器类型预测
// 能力: 预测 + 学习 + 自适应
// 四阶段: 数据采集→特征提取→决策→执行

函数 AI滤波_记录行(滤波类型) {
    如果 (全局滤波AI == 空) { 返回 }
    定义 AI = 全局滤波AI
    AI.采样计数器 = AI.采样计数器 + 1

    如果 (AI.历史滤波分布 != 空 && 滤波类型 <= 滤波_最大类型) {
        定义 当前 = 内存_读64(AI.历史滤波分布 + 滤波类型 * 8)
        内存_写64(AI.历史滤波分布 + 滤波类型 * 8, 当前 + 1)
    }
    如果 (AI.最近16行滤波序列 != 空) {
        内存_写8(AI.最近16行滤波序列 + (AI.序列写位置 & 15), 滤波类型)
        AI.序列写位置 = AI.序列写位置 + 1
    }
    // 连续相同计数
    如果 (滤波类型 == AI.上次滤波类型) {
        AI.连续相同滤波计数 = AI.连续相同滤波计数 + 1
    } 否则 {
        AI.连续相同滤波计数 = 1
        AI.上次滤波类型 = 滤波类型
    }

    如果 (AI.采样计数器 < 32) { 返回 }
    AI.采样计数器 = 0

    如果 (全局滤波统计 != 空) {
        全局滤波统计.AI预测调用次数 = 全局滤波统计.AI预测调用次数 + 1
    }

    // 找出最常见的滤波类型
    定义 可变 最大计数 = 0
    定义 可变 最大类型 = 0
    如果 (AI.历史滤波分布 != 空) {
        定义 可变 t = 0
        当 (t <= 滤波_最大类型) {
            定义 计数 = 内存_读64(AI.历史滤波分布 + t * 8)
            如果 (计数 > 最大计数) {
                最大计数 = 计数
                最大类型 = t
            }
            t = t + 1
        }
    }

    如果 (AI.连续相同滤波计数 > 8) {
        // 强连续性: 预测下行与当前相同
        AI.预测下行滤波类型 = AI.上次滤波类型
    } 否则 {
        // 使用历史最频繁类型
        AI.预测下行滤波类型 = 最大类型
    }

    如果 (AI.预测下行滤波类型 == 滤波类型) {
        如果 (全局滤波统计 != 空) {
            全局滤波统计.AI预测命中次数 = 全局滤波统计.AI预测命中次数 + 1
        }
    }
}

// §10 统计输出与诊断

函数 PNG滤波_打印统计() {
    如果 (全局滤波统计 == 空) {
        打印("[PNG滤波] 统计未初始化")
        返回
    }
    打印("┌──────────────────────────────────────┐")
    打印("│   PNG逆滤波 · 统计报告              │")
    打印("├──────────────────────────────────────┤")
    打印(字符串拼接("│ 总行数:           ", 转字符串(全局滤波统计.总行数)))
    打印(字符串拼接("│ None:             ", 转字符串(全局滤波统计.None行数)))
    打印(字符串拼接("│ Sub:              ", 转字符串(全局滤波统计.Sub行数)))
    打印(字符串拼接("│ Up:               ", 转字符串(全局滤波统计.Up行数)))
    打印(字符串拼接("│ Average:          ", 转字符串(全局滤波统计.Average行数)))
    打印(字符串拼接("│ Paeth:            ", 转字符串(全局滤波统计.Paeth行数)))
    打印(字符串拼接("│ 像素转换总数:     ", 转字符串(全局滤波统计.总像素转换数)))
    打印(字符串拼接("│ 灰度转换:         ", 转字符串(全局滤波统计.灰度转换数)))
    打印(字符串拼接("│ RGB转换:          ", 转字符串(全局滤波统计.RGB转换数)))
    打印(字符串拼接("│ RGBA直通:         ", 转字符串(全局滤波统计.RGBA直通数)))
    打印(字符串拼接("│ 索引色:           ", 转字符串(全局滤波统计.索引色转换数)))
    打印(字符串拼接("│ 滤波耗时(μs):     ", 转字符串(全局滤波统计.总滤波耗时_纳秒 / 1000)))
    打印(字符串拼接("│ 转换耗时(μs):     ", 转字符串(全局滤波统计.总转换耗时_纳秒 / 1000)))
    打印(字符串拼接("│ AI预测调用:       ", 转字符串(全局滤波统计.AI预测调用次数)))
    打印(字符串拼接("│ AI预测命中:       ", 转字符串(全局滤波统计.AI预测命中次数)))
    打印(字符串拼接("│ 错误:             ", 转字符串(全局滤波统计.错误总数)))
    打印("└──────────────────────────────────────┘")
}

函数 PNG滤波_导出诊断() {
    如果 (全局滤波AI == 空) {
        打印("[PNG滤波 AI] 未初始化")
        返回
    }
    定义 AI = 全局滤波AI
    打印("[PNG滤波 AI] === 诊断 ===")
    打印(字符串拼接("  预测下行滤波: ", 转字符串(AI.预测下行滤波类型)))
    打印(字符串拼接("  连续相同: ", 转字符串(AI.连续相同滤波计数)))
    打印(字符串拼接("  上次类型: ", 转字符串(AI.上次滤波类型)))
    如果 (全局滤波统计 != 空 && 全局滤波统计.AI预测调用次数 > 0) {
        定义 命中率 = 全局滤波统计.AI预测命中次数 * 100 / 全局滤波统计.AI预测调用次数
        打印(字符串拼接("  预测命中率(%): ", 转字符串(命中率)))
    }
}

// §11 对外接口

函数 PNG滤波_获取统计() {
    返回 全局滤波统计
}

函数 PNG滤波_获取AI状态() {
    返回 全局滤波AI
}

函数 PNG滤波_获取预测类型() {
    如果 (全局滤波AI == 空) { 返回 0 }
    返回 全局滤波AI.预测下行滤波类型
}

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./着色编译甲.nova")

// 对应: nova/renderer/modules/webgl/ (
// gpu/command_buffer/service/ (
// gpu/GLES2/ (
// 图绘2 (OpenGL ES 3.0) 新增能力:
// VAO: Vertex 数组 Object (顶点数组对象)
// UBO: Uniform Buffer Object (统一缓冲对象)
// Transform Feedback: 图处端顶点数据回读
// 多采样渲染缓冲 (MSAA)
// 3D纹理 / 2D纹理数组
// 整数纹理格式 / 浮点纹理
// 非2幂纹理(NPOT)完整支持
// 同步对象(Fence Sync)
// 实例化绘制(Instanced Drawing)
// 多渲染目标(MRT / Multiple 渲染 Targets)
// 不可变纹理(tex存储)
// GLSL ES 3.00着色器编译管线:
// 源码 → 预处理 → 词法分析 → 语法分析 → AST →
// 语义分析 → 优化 → 目标代码生成(SPIR-V或图处 ISA)
// 【Nova特色】AI 图处优化:
// ① AI分析着色器热点, 建议优化
// ② AI检测图处内存泄漏
// ③ AI自动LOD(细节层次)选择

// §1 图绘2扩展常量

// 缓冲绑定目标(图绘2新增)
定义 GL_COPY_READ_BUFFER = 0x8F36
定义 GL_COPY_WRITE_BUFFER = 0x8F37
定义 GL_TRANSFORM_FEEDBACK_BUFFER = 0x8C8E
定义 GL_UNIFORM_BUFFER = 0x8A11
定义 GL_PIXEL_PACK_BUFFER = 0x88EB
定义 GL_PIXEL_UNPACK_BUFFER = 0x88EC

// 纹理目标(图绘2新增)
定义 GL_TEXTURE_3D = 0x806F
定义 GL_TEXTURE_2D_ARRAY = 0x8C1A

// 内部格式(图绘2新增精选)
定义 GL_R8 = 0x8229
定义 GL_R16F = 0x822D
定义 GL_R32F = 0x822E
定义 GL_R8I = 0x8231
定义 GL_R8UI = 0x8232
定义 GL_RG8 = 0x822B
定义 GL_RG16F = 0x822F
定义 GL_RG32F = 0x8230
定义 GL_RGB8 = 0x8051
定义 GL_RGBA8 = 0x8058
定义 GL_RGBA16F = 0x881A
定义 GL_RGBA32F = 0x8814
定义 GL_DEPTH_COMPONENT24 = 0x81A6
定义 GL_DEPTH_COMPONENT32F = 0x8CAC
定义 GL_DEPTH24_STENCIL8 = 0x88F0
定义 GL_DEPTH32F_STENCIL8 = 0x8CAD

// 同步对象
定义 GL_SYNC_图处_COMMANDS_COMPLETE = 0x9117
定义 GL_ALREADY_SIGNALED = 0x911A
定义 GL_TIMEOUT_EXPIRED = 0x911B
定义 GL_CONDITION_SATISFIED = 0x911C
定义 GL_WAIT_FAILED = 0x911D
定义 GL_SYNC_FLUSH_COMMANDS_BIT = 0x00000001

// Transform Feedback
定义 GL_TRANSFORM_FEEDBACK = 0x8E22
定义 GL_INTERLEAVED_ATTRIBS = 0x8C8C
定义 GL_SEPARATE_ATTRIBS = 0x8C8D

// 查询对象
定义 GL_ANY_SAMPLES_PASSED = 0x8C2F
定义 GL_TRANSFORM_FEEDBACK_PRIMITIVES_WRITTEN = 0x8C88

// 采样器对象
定义 GL_SAMPLER_BINDING = 0x8919

// §2 GLSL ES 3.00 着色器编译器

// 令牌类型
定义 GLSL_TOK_IDENT = 0
定义 GLSL_TOK_INT = 1
定义 GLSL_TOK_FLOAT = 2
定义 GLSL_TOK_KEYWORD = 3
定义 GLSL_TOK_OPERATOR = 4
定义 GLSL_TOK_SEMICOL = 5
定义 GLSL_TOK_LBRACE = 6
定义 GLSL_TOK_RBRACE = 7
定义 GLSL_TOK_LPAREN = 8
定义 GLSL_TOK_RPAREN = 9
定义 GLSL_TOK_COMMA = 10
定义 GLSL_TOK_DOT = 11
定义 GLSL_TOK_EOF = 12
定义 GLSL_TOK_PREPROC = 13 // #version, #define, ...

// GLSL类型
定义 GLSL_TYPE_VOID = 0
定义 GLSL_TYPE_BOOL = 1
定义 GLSL_TYPE_INT = 2
定义 GLSL_TYPE_UINT = 3
定义 GLSL_TYPE_FLOAT = 4
定义 GLSL_TYPE_VEC2 = 5
定义 GLSL_TYPE_VEC3 = 6
定义 GLSL_TYPE_VEC4 = 7
定义 GLSL_TYPE_MAT2 = 8
定义 GLSL_TYPE_MAT3 = 9
定义 GLSL_TYPE_MAT4 = 10
定义 GLSL_TYPE_SAMPLER2D = 11
定义 GLSL_TYPE_SAMPLER3D = 12
定义 GLSL_TYPE_SAMPLERCUBE = 13
定义 GLSL_TYPE_IVEC2 = 14
定义 GLSL_TYPE_IVEC3 = 15
定义 GLSL_TYPE_IVEC4 = 16
定义 GLSL_TYPE_UVEC2 = 17
定义 GLSL_TYPE_UVEC3 = 18
定义 GLSL_TYPE_UVEC4 = 19

结构 GLSL令牌 {
 类型,
 值,    // u64 字符串或数值
 行号,
 列号,
}

结构 GLSLVariable {
 名称,
 类型,    // u8 GLSL_TYPE_xxx
 限定符,    // u8 0=none 1=in 2=out 3=uniform 4=const
 位置,    // i32 layout(location=N)
 绑定,    // i32 layout(binding=N)
 数组大小,    // i32 -1=非数组
}

结构 GLSLFunction {
 名称,
 返回类型,
 参数,    // [8]GLSLVariable
 参数数,
 体,    // u64 AST节点
}

结构 ShaderCompiler {
 // 源码
 源码,
 源码长度,
 // 词法分析状态
 位置,
 当前行,
 当前列,
 // 令牌流
 令牌s,    // u64 GLSL令牌*数组
 令牌数,
 令牌容量,
 // 符号表
 变量,    // [128]GLSLVariable
 变量数,
 函数,    // [32]GLSLFunction
 函数数,
 // 编译结果
 字节码,    // u64 编译后的图处指令
 字节码长度,
 // 错误
 错误,
 有错误,
 // GLSL版本
 版本,    // u32 100/300
}


函数 ShaderCompiler_创建() {
 定义 sc = 堆_分配(ShaderCompiler)
 sc.源码 = 0; sc.源码长度 = 0; sc.位置 = 0
 sc.当前行 = 1; sc.当前列 = 1
 sc.令牌容量 = 1024
 sc.令牌s = 堆_分配_数组(1024 * 大小of(GLSL令牌))
 sc.令牌数 = 0; sc.变量数 = 0; sc.函数数 = 0
 sc.字节码 = 0; sc.字节码长度 = 0
 sc.错误 = 0; sc.有错误 = 假; sc.版本 = 300
 返回 sc
}

函数 ShaderCompiler_编译(sc, 源码, 长度, 着色器类型) {
 如果 (sc == 0 || 源码 == 0) { 返回 假 }
 sc.源码 = 源码; sc.源码长度 = 长度; sc.位置 = 0
 sc.有错误 = 假; sc.令牌数 = 0; sc.变量数 = 0

 // 阶段1: 预处理
 ShaderCompiler_预处理(sc)
 如果 (sc.有错误) { 返回 假 }

 // 阶段2: 词法分析
 ShaderCompiler_词法分析(sc)
 如果 (sc.有错误) { 返回 假 }

 // 阶段3: 语法分析 → AST
 ShaderCompiler_语法分析(sc)
 如果 (sc.有错误) { 返回 假 }

 // 阶段4: 语义分析(类型检查)
 ShaderCompiler_语义检查(sc)
 如果 (sc.有错误) { 返回 假 }

 // 阶段5: 优化
 ShaderCompiler_优化(sc)

 // 阶段6: 代码生成
 ShaderCompiler_生成代码(sc, 着色器类型)
 返回 !sc.有错误
}

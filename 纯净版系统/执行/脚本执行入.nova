// §4 脚本执行入口

函数 JS_执行脚本(代码) {
    如果 (!JS_运行时.已初始化) { JS_初始化() }

    // 安全检查
    如果 (浏览器安全_检查XSS(代码)) {
        JS_运行时.错误 = "安全拦截: 潜在XSS攻击"
        返回 JS_创建未定义()
    }

    JS_运行时.执行计数 = 0
    JS_运行时.错误 = ""

    // 当前实现执行: 逐语句解释
    定义 语句列表 = JS_分割语句(代码)
    定义 可变 结果 = JS_创建未定义()

    定义 可变 i = 0
    当 (i < 计数(语句列表)) {
        结果 = JS_执行语句(语句列表[i])
        如果 (字符串长度(JS_运行时.错误) > 0) {
            内核信息("JS错误: " + JS_运行时.错误)
            中断
        }
        i = i + 1
    }

    返回 结果
}

函数 JS_分割语句(代码) {
    返回 字符串分割(代码, ";")
}

函数 JS_执行语句(语句) {
    JS_运行时.执行计数 = JS_运行时.执行计数 + 1
    如果 (JS_运行时.执行计数 > JS_运行时.最大执行步) {
        JS_运行时.错误 = "执行步数超限"
        返回 JS_创建未定义()
    }

    定义 s = 字符串修剪(语句)
    如果 (字符串长度(s) == 0) { 返回 JS_创建未定义() }

    // var/let/const 声明
    如果 (字符串查找(s, "var ") == 0 || 字符串查找(s, "let ") == 0 || 字符串查找(s, "const ") == 0) {
        返回 JS_执行声明(s)
    }

    // console.log(...)
    如果 (字符串查找(s, "console.log(") == 0) {
        返回 JS_执行console_log(s)
    }

    // document.get元素ById(...)
    如果 (字符串查找(s, "document.get元素ById(") == 0) {
        返回 JS_执行get元素ById(s)
    }

    // 赋值
    定义 等号 = 字符串查找(s, "=")
    如果 (等号 > 0 && 字符串子串(s, 等号 - 1, 1) != "!" && 字符串子串(s, 等号 - 1, 1) != "<" && 字符串子串(s, 等号 - 1, 1) != ">") {
        如果 (等号 + 1 < 字符串长度(s) && 字符串子串(s, 等号 + 1, 1) != "=") {
            返回 JS_执行赋值(s, 等号)
        }
    }

    // 表达式求值
    返回 JS_求值表达式(s)
}

函数 JS_执行声明(s) {
    // "var x = 42" → 声明变量x=42
    定义 空格 = 字符串查找(s, " ")
    如果 (空格 < 0) { 返回 JS_创建未定义() }

    定义 剩余 = 字符串修剪(字符串子串(s, 空格 + 1, 字符串长度(s) - 空格 - 1))
    定义 等号 = 字符串查找(剩余, "=")

    如果 (等号 >= 0) {
        定义 名称 = 字符串修剪(字符串子串(剩余, 0, 等号))
        定义 值串 = 字符串修剪(字符串子串(剩余, 等号 + 1, 字符串长度(剩余) - 等号 - 1))
        定义 值 = JS_求值表达式(值串)
        JS_设置全局变量(名称, 值)
        返回 值
    }

    // 无初始值
    定义 名称 = 剩余
    JS_设置全局变量(名称, JS_创建未定义())
    返回 JS_创建未定义()
}

函数 JS_执行赋值(s, 等号位置) {
    定义 名称 = 字符串修剪(字符串子串(s, 0, 等号位置))
    定义 值串 = 字符串修剪(字符串子串(s, 等号位置 + 1, 字符串长度(s) - 等号位置 - 1))
    定义 值 = JS_求值表达式(值串)
    JS_设置全局变量(名称, 值)
    返回 值
}

函数 JS_执行console_log(s) {
    // 提取参数
    定义 开始 = 字符串查找(s, "(") + 1
    定义 结束 = 字符串查找(s, ")")
    如果 (开始 <= 0 || 结束 <= 0) { 返回 JS_创建未定义() }

    定义 参数串 = 字符串子串(s, 开始, 结束 - 开始)
    定义 值 = JS_求值表达式(参数串)

    // 输出到控制台
    定义 可变 输出 = ""
    如果 (值.类型 == JS类型_字符串) { 输出 = 值.字符串值 }
    否则 如果 (值.类型 == JS类型_数字) { 输出 = 整数转字符串(值.数字值) }
    否则 如果 (值.类型 == JS类型_布尔) { 输出 = 值.数字值 == 1 ? "true" : "false" }
    否则 { 输出 = "[object]" }

    追加(JS_运行时.控制台输出, 输出)
    返回 值
}

函数 JS_执行get元素ById(s) {
    定义 开始 = 字符串查找(s, "'")
    如果 (开始 < 0) { 开始 = 字符串查找(s, "\"") }
    如果 (开始 < 0) { 返回 JS_创建空() }

    定义 结束 = 字符串查找(字符串子串(s, 开始 + 1, 字符串长度(s) - 开始 - 1), "'")
    如果 (结束 < 0) {
        结束 = 字符串查找(字符串子串(s, 开始 + 1, 字符串长度(s) - 开始 - 1), "\"")
    }
    如果 (结束 < 0) { 返回 JS_创建空() }

    定义 id = 字符串子串(s, 开始 + 1, 结束)

    // 调用DOM查询
    如果 (DOM_当前文档 != 空) {
        定义 节点 = DOM_通过ID查找(DOM_当前文档, id)
        如果 (节点 != 空) {
            定义 elem = JS_创建对象()
            JS_对象设置(elem, "id", JS_创建字符串(id))
            JS_对象设置(elem, "tagName", JS_创建字符串(节点.标签名))
            JS_对象设置(elem, "_节点Id", JS_创建数字(节点.ID))
            返回 elem
        }
    }
    返回 JS_创建空()
}

定义 可变 AI_脚本执行入_热节点缓存 = 0

函数 AI_脚本执行入_节点热度(节点, 操作类型) {
    如果 (操作类型 == "查询") { 返回 "缓存" }
    如果 (操作类型 == "修改") { AI_脚本执行入_热节点缓存 = 0; 返回 "失效" }
    返回 "普通"
}

函数 AI_脚本执行入_批量DOM优化(操作数) {
    如果 (操作数 > 100) { 返回 "延迟重排" }
    如果 (操作数 > 10) { 返回 "批量重排" }
    返回 "即时重排"
}

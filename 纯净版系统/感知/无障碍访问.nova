//       ax_object.cc (~2000行)
//       ax_object_cache_impl.cc 
//       ax_节点_object.cc (~4000行)
//       ax_tree.cc (~1500行)
//       ax_节点.cc (~800行)
// 可访问性系统:
//   1. 将DOM树映射为可访问性树(AX Tree)
//   2. 每个AX节点携带: role/name/description/state/value/relationships
//   3. ARIA属性覆盖原生语义: role="button" aria-label="Close"
//   4. 屏幕阅读器通过AX Tree获取页面信息
//   5. 焦点管理/Live Region通知/Tree更新事件
// ARIA角色(WAI-ARIA 1.2):
//   widget: button/checkbox/radio/slider/tab/textbox/switch/dialog...
//   document: article/heading/list/table/row/cell/img/link/navigation...
//   landmark: banner/complementary/contentinfo/main/navigation/search
//   live region: alert/log/marquee/status/timer

// §1 ARIA角色枚举

定义 AX_ROLE_UNKNOWN         = 0
定义 AX_ROLE_ALERT           = 1
定义 AX_ROLE_APPLICATION     = 2
定义 AX_ROLE_ARTICLE         = 3

导入("./内核打印.nova")
导入("./整数转字符串.nova")
导入("./新系统突触.nova")
定义 检查点_版本号 = 1
定义 检查点_魔数 = 0x4E565343
定义 突触网格_行 = 30
定义 突触网格_列 = 30
定义 突触网格_层 = 4
定义 突触网格_总连接 = 3600

结构 检查点导出统计 {
    突触导出次数,
    突触导入次数,
    记忆导出次数,
    记忆导入次数,
    注意力导出次数,
    注意力导入次数,
    路由导出次数,
    路由导入次数,
    增量快照次数,
    校验失败次数,
    总导出字节,
    总导入字节,
}

定义 可变 全局_检查点导出统计 = 空
定义 可变 上次突触快照 = 空
定义 可变 检查点_总数 = 0
定义 可变 检查点_回滚次数 = 0

函数 检查点导出统计_初始化() {
    如果 (全局_检查点导出统计 == 空) {
        全局_检查点导出统计 = 检查点导出统计 {}
        全局_检查点导出统计.突触导出次数 = 0
        全局_检查点导出统计.突触导入次数 = 0
        全局_检查点导出统计.记忆导出次数 = 0
        全局_检查点导出统计.记忆导入次数 = 0
        全局_检查点导出统计.注意力导出次数 = 0
        全局_检查点导出统计.注意力导入次数 = 0
        全局_检查点导出统计.路由导出次数 = 0
        全局_检查点导出统计.路由导入次数 = 0
        全局_检查点导出统计.增量快照次数 = 0
        全局_检查点导出统计.校验失败次数 = 0
        全局_检查点导出统计.总导出字节 = 0
        全局_检查点导出统计.总导入字节 = 0
    }
}

函数 检查点_计算校验和(数据) {
    定义 可变 哈希 = 0x811c9dc5
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        哈希 = 哈希 ^ (数据[i] & 0xFF)
        哈希 = 哈希 * 0x01000193
        i = i + 1
    }
    返回 哈希
}

函数 检查点_验证校验和(数据, 期望) {
    返回 检查点_计算校验和(数据) == 期望
}

函数 突触网格_导出() {
    检查点导出统计_初始化()
    全局_检查点导出统计.突触导出次数 = 全局_检查点导出统计.突触导出次数 + 1

    如果 (突触网格_已初始化 != 空 && 突触网格_已初始化 == 真) {
        定义 连接数据 = 突触网格_获取连接数据()
        定义 校验和 = 检查点_计算校验和(连接数据)

        定义 可变 导出包 = [检查点_魔数, 检查点_版本号, 计数(连接数据), 校验和]
        定义 可变 i = 0
        当 (i < 计数(连接数据)) {
            追加(导出包, 连接数据[i])
            i = i + 1
        }

        全局_检查点导出统计.总导出字节 = 全局_检查点导出统计.总导出字节 + 计数(导出包) * 8
        上次突触快照 = 连接数据

        内核信息("检查点: 突触网格导出 (" + 整数转字符串(计数(连接数据)) + " 连接, 校验=" + 整数转字符串(校验和) + ")")
        返回 导出包
    }
    返回 []
}

函数 突触网格_增量导出() {
    检查点导出统计_初始化()
    全局_检查点导出统计.增量快照次数 = 全局_检查点导出统计.增量快照次数 + 1

    如果 (突触网格_已初始化 != 空 && 突触网格_已初始化 == 真) {
        定义 当前数据 = 突触网格_获取连接数据()
        如果 (上次突触快照 == 空) {
            上次突触快照 = 当前数据
            返回 突触网格_导出()
        }

        定义 可变 差异 = []
        定义 可变 i = 0
        当 (i < 计数(当前数据)) {
            如果 (i >= 计数(上次突触快照) || 当前数据[i] != 上次突触快照[i]) {
                追加(差异, i)
                追加(差异, 当前数据[i])
            }
            i = i + 1
        }

        上次突触快照 = 当前数据
        定义 校验和 = 检查点_计算校验和(差异)
        定义 可变 导出包 = [检查点_魔数, 检查点_版本号 + 100, 计数(差异), 校验和]
        i = 0
        当 (i < 计数(差异)) {
            追加(导出包, 差异[i])
            i = i + 1
        }

        内核信息("检查点: 突触增量 (" + 整数转字符串(计数(差异) / 2) + " 变化)")
        返回 导出包
    }
    返回 []
}

函数 突触网格_导入(数据) {
    检查点导出统计_初始化()
    全局_检查点导出统计.突触导入次数 = 全局_检查点导出统计.突触导入次数 + 1

    如果 (数据 == 空 || 计数(数据) < 4) { 返回 }

    定义 魔数 = 数据[0]
    定义 版本 = 数据[1]
    定义 长度 = 数据[2]
    定义 校验和 = 数据[3]

    如果 (魔数 != 检查点_魔数) {
        内核信息("检查点: 突触导入失败 — 魔数不匹配")
        全局_检查点导出统计.校验失败次数 = 全局_检查点导出统计.校验失败次数 + 1
        返回
    }

    定义 可变 连接数据 = []
    定义 可变 i = 4
    当 (i < 计数(数据)) {
        追加(连接数据, 数据[i])
        i = i + 1
    }

    如果 (!检查点_验证校验和(连接数据, 校验和)) {
        内核信息("检查点: 突触导入失败 — 校验和不匹配")
        全局_检查点导出统计.校验失败次数 = 全局_检查点导出统计.校验失败次数 + 1
        返回
    }

    如果 (版本 > 100) {
        如果 (上次突触快照 == 空) {
            内核信息("检查点: 无法应用增量 — 缺少基线")
            返回
        }
        定义 可变 j = 0
        当 (j < 计数(连接数据) - 1) {
            定义 索引 = 连接数据[j]
            定义 值 = 连接数据[j + 1]
            如果 (索引 < 计数(上次突触快照)) {
                上次突触快照[索引] = 值
            }
            j = j + 2
        }
        突触网格_应用连接数据(上次突触快照)
        内核信息("检查点: 突触增量恢复 (" + 整数转字符串(计数(连接数据) / 2) + " 变化)")
    } 否则 {
        上次突触快照 = 连接数据
        突触网格_应用连接数据(上次突触快照)
        内核信息("检查点: 突触网格恢复 (" + 整数转字符串(计数(连接数据)) + " 连接)")
    }

    全局_检查点导出统计.总导入字节 = 全局_检查点导出统计.总导入字节 + 计数(数据) * 8
}

外部 工作记忆
外部 情景记忆
外部 语义节点
外部 语义边
外部 记忆时钟

函数 记忆_导出全部() {
    检查点导出统计_初始化()
    全局_检查点导出统计.记忆导出次数 = 全局_检查点导出统计.记忆导出次数 + 1

    定义 工作数 = 计数(工作记忆)
    定义 情景数 = 计数(情景记忆)
    定义 节点数 = 计数(语义节点)
    定义 边数 = 计数(语义边)

    定义 导出 = [检查点_魔数, 工作数, 情景数, 节点数, 边数,
                 工作记忆, 情景记忆, 语义节点, 语义边, 记忆时钟]

    全局_检查点导出统计.总导出字节 = 全局_检查点导出统计.总导出字节 +
        (工作数 + 情景数 + 节点数 + 边数) * 8

    内核信息("检查点: 记忆导出 (工作=" + 整数转字符串(工作数) +
             " 情景=" + 整数转字符串(情景数) +
             " 语义=" + 整数转字符串(节点数) + "节点+" + 整数转字符串(边数) + "边)")
    返回 导出
}

函数 记忆_导入全部(数据) {
    检查点导出统计_初始化()
    全局_检查点导出统计.记忆导入次数 = 全局_检查点导出统计.记忆导入次数 + 1

    如果 (数据 == 空 || 计数(数据) < 10) { 返回 }

    定义 魔数 = 数据[0]
    如果 (魔数 != 检查点_魔数) {
        内核信息("检查点: 记忆导入失败 — 魔数不匹配")
        全局_检查点导出统计.校验失败次数 = 全局_检查点导出统计.校验失败次数 + 1
        返回
    }

    工作记忆 = 数据[5]
    情景记忆 = 数据[6]
    语义节点 = 数据[7]
    语义边 = 数据[8]
    记忆时钟 = 数据[9]

    全局_检查点导出统计.总导入字节 = 全局_检查点导出统计.总导入字节 +
        (计数(工作记忆) + 计数(情景记忆) + 计数(语义节点) + 计数(语义边)) * 8

    内核信息("检查点: 记忆系统恢复 (工作=" + 整数转字符串(计数(工作记忆)) +
             " 情景=" + 整数转字符串(计数(情景记忆)) + ")")
}

外部 注意力焦点
外部 焦点持续时间
外部 注意力_tick

函数 注意力_导出状态() {
    检查点导出统计_初始化()
    全局_检查点导出统计.注意力导出次数 = 全局_检查点导出统计.注意力导出次数 + 1

    定义 焦点数 = 计数(注意力焦点)
    定义 校验和 = 检查点_计算校验和(注意力焦点)
    定义 导出 = [检查点_魔数, 焦点数, 校验和, 注意力焦点, 焦点持续时间, 注意力_tick]

    全局_检查点导出统计.总导出字节 = 全局_检查点导出统计.总导出字节 + 焦点数 * 8
    内核信息("检查点: 注意力导出 (焦点=" + 整数转字符串(焦点数) + ")")
    返回 导出
}

函数 注意力_导入状态(数据) {
    检查点导出统计_初始化()
    全局_检查点导出统计.注意力导入次数 = 全局_检查点导出统计.注意力导入次数 + 1

    如果 (数据 == 空 || 计数(数据) < 6) { 返回 }

    定义 魔数 = 数据[0]
    如果 (魔数 != 检查点_魔数) {
        内核信息("检查点: 注意力导入失败 — 魔数不匹配")
        全局_检查点导出统计.校验失败次数 = 全局_检查点导出统计.校验失败次数 + 1
        返回
    }

    定义 校验和 = 数据[2]
    注意力焦点 = 数据[3]
    如果 (!检查点_验证校验和(注意力焦点, 校验和)) {
        内核信息("检查点: 注意力导入警告 — 校验和不匹配")
        全局_检查点导出统计.校验失败次数 = 全局_检查点导出统计.校验失败次数 + 1
    }

    焦点持续时间 = 数据[4]
    注意力_tick = 数据[5]

    全局_检查点导出统计.总导入字节 = 全局_检查点导出统计.总导入字节 + 计数(注意力焦点) * 8
    内核信息("检查点: 注意力状态恢复 (焦点=" + 整数转字符串(计数(注意力焦点)) + ")")
}

外部 路由表

函数 路由_导出全部() {
    检查点导出统计_初始化()
    全局_检查点导出统计.路由导出次数 = 全局_检查点导出统计.路由导出次数 + 1

    定义 条数 = 计数(路由表)
    定义 校验和 = 检查点_计算校验和(路由表)
    定义 导出 = [检查点_魔数, 条数, 校验和, 路由表]

    全局_检查点导出统计.总导出字节 = 全局_检查点导出统计.总导出字节 + 条数 * 8
    内核信息("检查点: 路由导出 (" + 整数转字符串(条数) + " 条)")
    返回 导出
}

函数 路由_导入全部(数据) {
    检查点导出统计_初始化()
    全局_检查点导出统计.路由导入次数 = 全局_检查点导出统计.路由导入次数 + 1

    如果 (数据 == 空 || 计数(数据) < 4) { 返回 }

    定义 魔数 = 数据[0]
    如果 (魔数 != 检查点_魔数) {
        内核信息("检查点: 路由导入失败 — 魔数不匹配")
        全局_检查点导出统计.校验失败次数 = 全局_检查点导出统计.校验失败次数 + 1
        返回
    }

    定义 校验和 = 数据[2]
    路由表 = 数据[3]
    如果 (!检查点_验证校验和(路由表, 校验和)) {
        内核信息("检查点: 路由导入警告 — 校验和不匹配")
    }

    全局_检查点导出统计.总导入字节 = 全局_检查点导出统计.总导入字节 + 计数(路由表) * 8
    内核信息("检查点: 路由表恢复 (" + 整数转字符串(计数(路由表)) + " 条)")
}

函数 检查点_完整导出() {
    检查点_总数 = 检查点_总数 + 1
    定义 可变 完整包 = [检查点_魔数, 检查点_版本号, 检查点_总数]

    定义 突触 = 突触网格_导出()
    定义 记忆 = 记忆_导出全部()
    定义 注意力 = 注意力_导出状态()
    定义 路由 = 路由_导出全部()

    追加(完整包, 突触)
    追加(完整包, 记忆)
    追加(完整包, 注意力)
    追加(完整包, 路由)

    内核信息("检查点: 完整导出 #" + 整数转字符串(检查点_总数))
    返回 完整包
}

函数 检查点_完整统计() {
    返回 [检查点_总数, 检查点_回滚次数]
}

函数 检查点导出_打印统计() {
    检查点导出统计_初始化()
    打印行("=== 检查点导出统计 ===")
    打印行("突触导出: " + 整数转字符串(全局_检查点导出统计.突触导出次数))
    打印行("突触导入: " + 整数转字符串(全局_检查点导出统计.突触导入次数))
    打印行("记忆导出: " + 整数转字符串(全局_检查点导出统计.记忆导出次数))
    打印行("记忆导入: " + 整数转字符串(全局_检查点导出统计.记忆导入次数))
    打印行("注意力导出: " + 整数转字符串(全局_检查点导出统计.注意力导出次数))
    打印行("注意力导入: " + 整数转字符串(全局_检查点导出统计.注意力导入次数))
    打印行("路由导出: " + 整数转字符串(全局_检查点导出统计.路由导出次数))
    打印行("路由导入: " + 整数转字符串(全局_检查点导出统计.路由导入次数))
    打印行("增量快照: " + 整数转字符串(全局_检查点导出统计.增量快照次数))
    打印行("校验失败: " + 整数转字符串(全局_检查点导出统计.校验失败次数))
    打印行("导出字节: " + 整数转字符串(全局_检查点导出统计.总导出字节))
    打印行("导入字节: " + 整数转字符串(全局_检查点导出统计.总导入字节))
    打印行("总检查点: " + 整数转字符串(检查点_总数))
    打印行("回滚次数: " + 整数转字符串(检查点_回滚次数))
}

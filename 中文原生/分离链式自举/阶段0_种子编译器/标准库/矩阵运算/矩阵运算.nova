导入("../数学/线性代数.nova")
导入("../算法/数学扩展.nova")


// 矩阵创建 (一维数组存储, 行优先)
函数 矩阵运算_矩阵_零(行, 列) { 定义 可变 m = []
 定义 可变 i = 0
 当 (i < 行 * 列) { 追加(m, 0)
 i = i + 1 }
 返回 m
}

函数 矩阵运算_矩阵_单位(n) { 定义 可变 m = 矩阵_零(n, n)
 定义 可变 i = 0
 当 (i < n) { m[i * n + i] = 1000
 i = i + 1 }
 返回 m
}

函数 矩阵运算_矩阵_取(m, 列数, r, c) { 返回 m[r * 列数 + c] }
函数 矩阵运算_矩阵_设(m, 列数, r, c, v) { m[r * 列数 + c] = v }

// 矩阵加减
函数 矩阵运算_矩阵_加(a, b) { 返回 拉链(a, b, (x, y) => x + y) }

函数 矩阵运算_矩阵_减(a, b) { 返回 拉链(a, b, (x, y) => x - y) }

// 标量乘
函数 矩阵_标量乘(m, s) { 返回 映射(m, x => x * s / 1000) }

// 转置
函数 矩阵运算_矩阵_转置(m, 行, 列) { 定义 可变 结果 = 矩阵_零(列, 行)
 定义 可变 r = 0
 当 (r < 行) { 定义 可变 c = 0
 当 (c < 列) { 结果[c * 行 + r] = m[r * 列 + c]
 c = c + 1 }
 r = r + 1
 }
 返回 结果
}

// 矩阵乘法
函数 矩阵运算_矩阵_乘(a, b, M, K, N) {
 // A: MxK, B: KxN -> C: MxN
 定义 可变 结果 = 矩阵_零(M, N)
 定义 可变 i = 0
 当 (i < M) { 定义 可变 j = 0
 当 (j < N) { 定义 可变 总和 = 0
 定义 可变 k = 0
 当 (k < K) {
 总和 = 总和 + a[i * K + k] * b[k * N + j] / 1000
 k = k + 1
 }
 结果[i * N + j] = 总和
 j = j + 1
 }
 i = i + 1
 }
 返回 结果
}

// 向量点积
函数 矩阵运算_向量_点积(a, b) { 返回 折叠(拉链(a, b, (x, y) => x * y / 1000), 0, (s, v) => s + v)
}

// 向量外积
函数 矩阵运算_向量_外积(a, b) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(a)) { 定义 可变 j = 0
 当 (j < 计数(b)) { 追加(结果, a[i] * b[j] / 1000)
 j = j + 1 }
 i = i + 1
 }
 返回 结果
}

// 2x2行列式
函数 行列式_2x2(m) { 返回 m[0] * m[3] / 1000 - m[1] * m[2] / 1000
}

// 3x3行列式
函数 行列式_3x3(m) { 定义 a = m[0] * (m[4] * m[8] / 1000 - m[5] * m[7] / 1000) / 1000
 定义 b = m[1] * (m[3] * m[8] / 1000 - m[5] * m[6] / 1000) / 1000
 定义 c = m[2] * (m[3] * m[7] / 1000 - m[4] * m[6] / 1000) / 1000
 返回 a - b + c
}

// 2x2逆矩阵
函数 逆矩阵_2x2(m) { 定义 行列式 = 行列式_2x2(m)
 如果 (行列式 == 0) { 返回 [] }
 返回 [m[3] * 1000 / 行列式, 0 - m[1] * 1000 / 行列式, 0 - m[2] * 1000 / 行列式, m[0] * 1000 / 行列式]
}

// 矩阵迹
函数 矩阵运算_矩阵_迹(m, n) { 定义 可变 tr = 0
 定义 可变 i = 0
 当 (i < n) { tr = tr + m[i * n + i]
 i = i + 1 }
 返回 tr
}

// 矩阵元素数
函数 矩阵_元素数(m) { 返回 计数(m) }

// 向量范数 (L2, 定点×1000)
函数 矩阵运算_向量_范数(v) { 返回 整数sqrt(折叠(v, 0, (s, x) => s + x * x / 1000))
}

// 向量归一化 (定点×1000)
函数 矩阵运算_向量_归一化(v) { 定义 n = 向量_范数(v, 0)
 如果 (n == 0) { 返回 v }
 返回 映射(v, x => x * 1000 / n)
}

// Frobenius范数
函数 矩阵_F范数(m) { 返回 整数sqrt(折叠(m, 0, (s, x) => s + x * x / 1000))
}

// LU分解 (Doolittle算法, 原地)
// A = L×U, L下三角(对角=1000), U上三角
函数 矩阵_LU分解(m, n) { 定义 可变 LU = []
    定义 可变 总和2 = 0
 定义 可变 i = 0
 当 (i < n * n) { 追加(LU, m[i]) i = i + 1 }

 i = 0
 当 (i < n) {
 // 上三角U
 定义 可变 j = i
 当 (j < n) { 定义 可变 总和 = 0
 定义 可变 k = 0
 当 (k < i) {
 总和 = 总和 + LU[i * n + k] * LU[k * n + j] / 1000
 k = k + 1
 }
 LU[i * n + j] = LU[i * n + j] - 总和
 j = j + 1
 }
 // 下三角L
 j = i + 1
当 (j < n) {
 定义 可变 k2 = 0
 当 (k2 < i) {
 总和2 = 总和2 + LU[j * n + k2] * LU[k2 * n + i] / 1000
 k2 = k2 + 1
 }
 如果 (LU[i * n + i] != 0) {
 LU[j * n + i] = (LU[j * n + i] - 总和2) * 1000 / LU[i * n + i]
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 LU
}

// LU求解线性方程组 Ax=b
函数 矩阵_LU求解(LU, n, b) { 定义 可变 y = []
    定义 可变 总和2 = 0
 定义 可变 x = []
 定义 可变 i = 0
 当 (i < n) { 追加(y, 0) 追加(x, 0) i = i + 1 }

 // 前代: Ly = b
 i = 0
 当 (i < n) { 定义 可变 总和 = 0
 定义 可变 j = 0
 当 (j < i) {
 总和 = 总和 + LU[i * n + j] * y[j] / 1000
 j = j + 1
 }
 y[i] = b[i] - 总和
 i = i + 1
 }

 // 回代: Ux = y
 i = n - 1
当 (i >= 0) {
 定义 可变 j2 = i + 1
 当 (j2 < n) {
 总和2 = 总和2 + LU[i * n + j2] * x[j2] / 1000
 j2 = j2 + 1
 }
 如果 (LU[i * n + i] != 0) {
 x[i] = (y[i] - 总和2) * 1000 / LU[i * n + i]
 }
 i = i - 1
 }
 返回 x
}

// N×N行列式 (LU分解法)
函数 行列式_NxN(m, n) { 定义 LU = 矩阵_LU分解(m, n)
 定义 可变 行列式 = 1000
 定义 可变 i = 0
 当 (i < n) {
 行列式 = 行列式 * LU[i * n + i] / 1000
 i = i + 1
 }
 返回 行列式
}

// N×N逆矩阵
函数 逆矩阵_NxN(m, n) { 定义 LU = 矩阵_LU分解(m, n)
 定义 可变 逆 = 矩阵_零(n, n)

 定义 可变 j = 0
 当 (j < n) {
 // 构建单位向量e_j
 定义 可变 e = []
 定义 可变 k = 0
 当 (k < n) { 如果 (k == j) { 追加(e, 1000) } 否则 { 追加(e, 0) }
 k = k + 1
 }
 // 求解LU×x = e_j
 定义 列 = 矩阵_LU求解(LU, n, e)
 k = 0
 当 (k < n) {
 逆[k * n + j] = 列[k]
 k = k + 1
 }
 j = j + 1
 }
 返回 逆
}

// 幂迭代法求最大特征值
函数 特征值_幂迭代(m, n, 最大迭代) {
 // 初始化随机向量
 定义 可变 v = []
 定义 可变 i = 0
 当 (i < n) {
 追加(v, 1000 + ((i * 7 + 3) % 500))
 i = i + 1
 }

 定义 可变 特征值 = 0
 定义 可变 迭代 = 0
 当 (迭代 < 最大迭代) {
 // w = A × v
 定义 可变 w = []
 i = 0
 当 (i < n) { 定义 可变 总和 = 0
 定义 可变 j = 0
 当 (j < n) {
 总和 = 总和 + m[i * n + j] * v[j] / 1000
 j = j + 1
 }
 追加(w, 总和)
 i = i + 1
 }

 // 特征值 = max|w_i|
 定义 可变 最大 = 0
 i = 0
 当 (i < n) { 定义 可变 绝对 = w[i]
 如果 (绝对 < 0) { 绝对 = 0 - 绝对 }
 如果 (绝对 > 最大) { 最大 = 绝对 }
 i = i + 1
 }
 特征值 = 最大

 // 归一化: v = w / ||w||
 如果 (最大 > 0) {
 i = 0
 当 (i < n) {
 v[i] = w[i] * 1000 / 最大
 i = i + 1
 }
 }
 迭代 = 迭代 + 1
 }
 返回 [特征值, v]
}

// QR分解 (Gram-Schmidt, 0 , 0)
函数 矩阵_QR分解(m, 行, 列) { 定义 可变 Q = 矩阵_零(行, 列)
 定义 可变 R = 矩阵_零(列, 列)

 定义 可变 j = 0
 当 (j < 列) {
 // 取第j列
 定义 可变 v = []
 定义 可变 i = 0
 当 (i < 行) { 追加(v, m[i * 列 + j]) i = i + 1 }

 // 正交化
 定义 可变 k = 0
 当 (k < j) {
 // R[k][j] = Q[:,k]·v
 定义 可变 点积 = 0
 i = 0
 当 (i < 行) {
 点积 = 点积 + Q[i * 列 + k] * v[i] / 1000
 i = i + 1
 }
 R[k * 列 + j] = 点积

 // v = v - R[k][j]*Q[:,k]
 i = 0
 当 (i < 行) {
 v[i] = v[i] - 点积 * Q[i * 列 + k] / 1000
 i = i + 1
 }
 k = k + 1
 }

 // R[j][j] = ||v||
 定义 可变 范数 = 0
 i = 0
 当 (i < 行) {
 范数 = 范数 + v[i] * v[i] / 1000
 i = i + 1
 }
 范数 = 整数sqrt(范数)
 R[j * 列 + j] = 范数

 // Q[:,j] = v / ||v||
 如果 (范数 > 0) {
 i = 0
 当 (i < 行) {
 Q[i * 列 + j] = v[i] * 1000 / 范数
 i = i + 1
 }
 }
 j = j + 1
 }
 返回 [Q, R]
}

// Kronecker积
函数 矩阵_Kronecker(A, B, aM, aN, bM, bN) { 定义 rM = aM * bM
 定义 rN = aN * bN
 定义 可变 结果 = 矩阵_零(rM, rN)

 定义 可变 i = 0
 当 (i < aM) { 定义 可变 j = 0
 当 (j < aN) { 定义 aij = A[i * aN + j]
 定义 可变 p = 0
 当 (p < bM) { 定义 可变 q = 0
 当 (q < bN) {
 结果[(i * bM + p) * rN + (j * bN + q)] = aij * B[p * bN + q] / 1000
 q = q + 1
 }
 p = p + 1
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 结果
}

// 矩阵幂 (快速幂)
函数 矩阵运算_矩阵_幂(m, n, 指数) {
    如果 (指数 == 0) { 返回 矩阵_单位(n)
}
 如果 (指数 == 1) { 返回 m }

 定义 可变 结果 = 矩阵_单位(n)
 定义 可变 底 = m
 定义 可变 指数值 = 指数

 当 (指数值 > 0) { 如果 (指数值 % 2 == 1) {
 结果 = 矩阵_乘(结果,  底,  n,  n,  n, 0)
 }
 底 = 矩阵_乘(底,  底,  n,  n,  n, 0)
 指数值 = 指数值 / 2
 }
 返回 结果
}

// 条件数估计 (||A||×||A⁻¹||)
函数 矩阵_条件数(m, n) { 定义 范数A = 矩阵_F范数(m)
 定义 逆A = 逆矩阵_NxN(m, n)
 定义 范数逆 = 矩阵_F范数(逆A)
 返回 范数A * 范数逆 / 1000
}

// 矩阵秩估计 (通过行阶梯形)
函数 矩阵_秩(m, 行, 列) { 定义 可变 拷贝 = []
 定义 可变 i = 0
 当 (i < 行 * 列) { 追加(拷贝, m[i]) i = i + 1 }

 定义 可变 秩 = 0
 定义 可变 主列 = 0

 定义 可变 r = 0
 当 (r < 行 且 主列 < 列) {
 // 找主元
 定义 可变 最大行 = r
 定义 可变 最大值 = 拷贝[r * 列 + 主列]
 如果 (最大值 < 0) { 最大值 = 0 - 最大值 }

 i = r + 1
 当 (i < 行) { 定义 可变 绝对 = 拷贝[i * 列 + 主列]
 如果 (绝对 < 0) { 绝对 = 0 - 绝对 }
 如果 (绝对 > 最大值) {
 最大值 = 绝对
 最大行 = i
 }
 i = i + 1
 }

 如果 (最大值 < 10) { // 近似为零
 主列 = 主列 + 1
 } 否则 {
 // 交换行
 如果 (最大行 != r) { 定义 可变 c = 0
 当 (c < 列) { 定义 暂存 = 拷贝[r * 列 + c]
 拷贝[r * 列 + c] = 拷贝[最大行 * 列 + c]
 拷贝[最大行 * 列 + c] = 暂存
 c = c + 1
 }
 }
 // 消元
 i = r + 1
 当 (i < 行) { 如果 (拷贝[r * 列 + 主列] != 0) { 定义 因子 = 拷贝[i * 列 + 主列] * 1000 / 拷贝[r * 列 + 主列]
 定义 可变 c2 = 主列
 当 (c2 < 列) {
 拷贝[i * 列 + c2] = 拷贝[i * 列 + c2] - 因子 * 拷贝[r * 列 + c2] / 1000
 c2 = c2 + 1
 }
 }
 i = i + 1
 }
 秩 = 秩 + 1
 r = r + 1
 主列 = 主列 + 1
 }
 }
 返回 秩
}

定义 可变 _矩阵_乘法次数 = 0
定义 可变 _矩阵_求逆次数 = 0
定义 可变 _矩阵_最大维度 = 0

函数 矩阵_记录乘法(维度) { _矩阵_乘法次数 = _矩阵_乘法次数 + 1
 如果 (维度 > _矩阵_最大维度) { _矩阵_最大维度 = 维度 }
}

函数 矩阵_记录求逆() { _矩阵_求逆次数 = _矩阵_求逆次数 + 1 }

函数 矩阵_性能预测(维度) { 定义 复杂度 = 维度 * 维度 * 维度
 如果 (复杂度 > 1000000) { 返回 "高开销: 建议使用Strassen算法" }
 如果 (复杂度 > 10000) { 返回 "中等开销" }
 返回 "低开销"
}

函数 矩阵_内存估算(行, 列) { 返回 行 * 列 * 8
}

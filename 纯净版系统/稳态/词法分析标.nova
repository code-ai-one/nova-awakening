// NovaOS · NML解析器 — Nova标记语言→原生元素树
// NML(Nova Markup Language): NovaOS原生UI描述格式
// 状态机词法分析 + 递归下降语法分析 + 自动闭合修正
// §1 词法分析: NML文本→令牌流 (标签/属性/文本/注释)
// §2 语法分析: 令牌流→原生元素树
// §3 自动修正: 未闭合标签/嵌套错误/自闭合标签
// §4 内联样式解析
// §5 查询接口: 按ID查找/按类型查找

外部 元素_创建
外部 元素_创建文本
外部 元素_添加子节点
外部 元素_设属性
外部 原生计算样式
外部 元素_获取属性

// §1 词法分析 — NML 令牌

定义 令牌_开标签 = 1      // <容器>
定义 令牌_闭标签 = 2      // </容器>
定义 令牌_自闭标签 = 3    // <图片/>
定义 令牌_文本 = 4        // 纯文本
定义 令牌_注释 = 5        // <!-- -->
定义 令牌_声明 = 6        // <!NML>

结构 NML_令牌 {
    类型,
    标签名,
    属性列表,    // [] [[名, 值], ...]
    文本内容,
    行号,
}

// Nova原生自闭合标签列表
函数 是自闭合标签(标签名) {
    如果 (标签名 == "换行") { 返回 真 }
    如果 (标签名 == "分隔") { 返回 真 }
    如果 (标签名 == "图片") { 返回 真 }
    如果 (标签名 == "输入") { 返回 真 }
    如果 (标签名 == "图标") { 返回 真 }
    如果 (标签名 == "进度") { 返回 真 }
    返回 假
}

// 词法分析主函数
函数 NML_词法分析(源码) {
    定义 可变 令牌s = []
    定义 可变 位置 = 0
    定义 可变 行号 = 1
    定义 长度 = 字符串长度(源码)

    当 (位置 < 长度) {
        定义 ch = 字符串取字节(源码, 位置)

        如果 (ch == 60) {  // '<'
            // 检查注释
            如果 (位置 + 3 < 长度 && 字符串取字节(源码, 位置 + 1) == 33 &&
                字符串取字节(源码, 位置 + 2) == 45 && 字符串取字节(源码, 位置 + 3) == 45) {
                // <!-- 注释 -->
                定义 注释结束 = NML_查找(源码, "-->", 位置 + 4)
                如果 (注释结束 < 0) { 注释结束 = 长度 }
                位置 = 注释结束 + 3
                继续
            }

            // 检查DOCTYPE
            如果 (位置 + 8 < 长度 && 字符串取字节(源码, 位置 + 1) == 33) {
                定义 gt = NML_查找字符(源码, 62, 位置 + 2)
                如果 (gt < 0) { gt = 长度 }
                位置 = gt + 1
                继续
            }

            // 检查闭标签 </tag>
            如果 (位置 + 1 < 长度 && 字符串取字节(源码, 位置 + 1) == 47) {  // '/'
                定义 标签结束 = NML_查找字符(源码, 62, 位置 + 2)
                如果 (标签结束 < 0) { 标签结束 = 长度 }
                定义 标签名 = NML_提取标签名(源码, 位置 + 2, 标签结束)
                定义 令牌 = NML_令牌 {}
                令牌.类型 = 令牌_闭标签
                令牌.标签名 = 标签名
                令牌.行号 = 行号
                令牌.属性列表 = []
                追加(令牌s, 令牌)
                位置 = 标签结束 + 1
                继续
            }

            // 开标签 <tag attr="val">
            定义 标签结果 = NML_解析开标签(源码, 位置, 行号)
            如果 (标签结果 != 空) {
                追加(令牌s, 标签结果)
                // 跳过标签
                定义 gt位置 = NML_查找字符(源码, 62, 位置 + 1)
                如果 (gt位置 < 0) { gt位置 = 长度 }
                位置 = gt位置 + 1
            } 否则 {
                位置 = 位置 + 1
            }

        } 否则 {
            // 文本节点
            定义 文本开始 = 位置
            当 (位置 < 长度 && 字符串取字节(源码, 位置) != 60) {
                如果 (字符串取字节(源码, 位置) == 10) { 行号 = 行号 + 1 }
                位置 = 位置 + 1
            }
            定义 文本 = NML_子串(源码, 文本开始, 位置)
            定义 修剪后 = NML_修剪空白(文本)
            如果 (修剪后 != "") {
                定义 令牌 = NML_令牌 {}
                令牌.类型 = 令牌_文本
                令牌.文本内容 = 修剪后
                令牌.行号 = 行号
                令牌.属性列表 = []
                追加(令牌s, 令牌)
            }
        }
    }

    返回 令牌s
}

函数 NML_解析开标签(html, 位置, 行号) {
    定义 gt = NML_查找字符(html, 62, 位置 + 1)
    如果 (gt < 0) { 返回 空 }

    // 提取标签名
    定义 可变 名称结束 = 位置 + 1
    当 (名称结束 < gt && 字符串取字节(html, 名称结束) != 32 &&
        字符串取字节(html, 名称结束) != 10 && 字符串取字节(html, 名称结束) != 47 &&
        字符串取字节(html, 名称结束) != 62) {
        名称结束 = 名称结束 + 1
    }
    定义 标签名 = NML_子串(html, 位置 + 1, 名称结束)
    如果 (标签名 == "") { 返回 空 }

    定义 令牌 = NML_令牌 {}
    令牌.标签名 = NML_转小写(标签名)
    令牌.行号 = 行号
    令牌.属性列表 = []

    // 解析属性
    定义 可变 属性位置 = 名称结束
    当 (属性位置 < gt) {
        // 跳过空白
        当 (属性位置 < gt && (字符串取字节(html, 属性位置) == 32 ||
            字符串取字节(html, 属性位置) == 10 || 字符串取字节(html, 属性位置) == 9)) {
            属性位置 = 属性位置 + 1
        }
        如果 (属性位置 >= gt) { 中断 }
        如果 (字符串取字节(html, 属性位置) == 47) { 中断 }  // '/' 自闭合

        // 属性名
        定义 属性名开始 = 属性位置
        当 (属性位置 < gt && 字符串取字节(html, 属性位置) != 61 &&
            字符串取字节(html, 属性位置) != 32 && 字符串取字节(html, 属性位置) != 62) {
            属性位置 = 属性位置 + 1
        }
        定义 属性名 = NML_子串(html, 属性名开始, 属性位置)

        定义 可变 属性值 = ""
        如果 (属性位置 < gt && 字符串取字节(html, 属性位置) == 61) {  // '='
            属性位置 = 属性位置 + 1
            如果 (属性位置 < gt && 字符串取字节(html, 属性位置) == 34) {  // '"'
                属性位置 = 属性位置 + 1
                定义 值开始 = 属性位置
                当 (属性位置 < gt && 字符串取字节(html, 属性位置) != 34) {
                    属性位置 = 属性位置 + 1
                }
                属性值 = NML_子串(html, 值开始, 属性位置)
                如果 (属性位置 < gt) { 属性位置 = 属性位置 + 1 }
            } 否则 如果 (属性位置 < gt && 字符串取字节(html, 属性位置) == 39) {  // "'"
                属性位置 = 属性位置 + 1
                定义 值开始 = 属性位置
                当 (属性位置 < gt && 字符串取字节(html, 属性位置) != 39) {
                    属性位置 = 属性位置 + 1
                }
                属性值 = NML_子串(html, 值开始, 属性位置)
                如果 (属性位置 < gt) { 属性位置 = 属性位置 + 1 }
            } 否则 {
                // 无引号值
                定义 值开始 = 属性位置
                当 (属性位置 < gt && 字符串取字节(html, 属性位置) != 32) {
                    属性位置 = 属性位置 + 1
                }
                属性值 = NML_子串(html, 值开始, 属性位置)
            }
        }
        如果 (属性名 != "") {
            追加(令牌.属性列表, [属性名, 属性值])
        }
    }

    // 判断是否自闭合
    如果 (是自闭合标签(令牌.标签名) || (gt > 0 && 字符串取字节(html, gt - 1) == 47)) {
        令牌.类型 = 令牌_自闭标签
    } 否则 {
        令牌.类型 = 令牌_开标签
    }

    返回 令牌
}

定义 可变 AI_词法分析标_热点函数 = []

函数 AI_词法分析标_JIT候选(函数名, 调用次数) {
    如果 (调用次数 > 100) {
        追加(AI_词法分析标_热点函数, 函数名)
        返回 真
    }
    返回 假
}

函数 AI_词法分析标_内联建议(函数体大小, 调用次数) {
    如果 (函数体大小 < 30 && 调用次数 > 50) { 返回 "内联" }
    返回 "不内联"
}

// 求和(阳聚) ←→ 差分(阴散, 0): 聚合 vs 分解
// 每个节点代表一"片"区间, 查询是"片→个"的态射

// 线段树: [树数组, 大小, 原始大小, 操作计数]

导入("../基础.nova")

函数 线段树_创建(数据) { 定义 n = 计数(数据)
 定义 可变 树 = []
 定义 可变 i = 0
 当 (i < 4 * n) { 追加(树, 0) i = i + 1 }
 定义 st = [树, 4 * n, n]
 线段树_构建(st, 数据, 1, 0, n - 1)
 返回 st
}

函数 线段树_构建(st, 数据, 节点, 左, 右) { 如果 (左 == 右) {
 st[0][节点] = 数据[左]
 返回 空
 }
 定义 中 = (左 + 右) / 2
 线段树_构建(st, 数据, 节点 * 2, 左, 中)
 线段树_构建(st, 数据, 节点 * 2 + 1, 中 + 1, 右)
 定义 树 = st[0]
 树[节点] = 树[节点 * 2] + 树[节点 * 2 + 1]
}

// 区间求和查询
函数 线段树_求和(st, 查左, 查右) { 返回 线段树_求和递归(st, 1, 0, st[2] - 1, 查左, 查右)
}

函数 线段树_求和递归(st, 节点, 左, 右, 查左, 查右) {
    如果 (查左 > 右 或 查右 < 左) { 返回 0
}
 如果 (查左 <= 左 且 右 <= 查右) { 返回 st[0][节点] }
 定义 中 = (左 + 右) / 2
 返回 线段树_求和递归(st, 节点 * 2, 左, 中, 查左, 查右) + 线段树_求和递归(st, 节点 * 2 + 1, 中 + 1, 右, 查左, 查右)
}

// 单点更新
函数 线段树_更新(st, 索引, 值) {
 线段树_更新递归(st, 1, 0, st[2] - 1, 索引, 值)
}

函数 线段树_更新递归(st, 节点, 左, 右, 索引, 值) { 如果 (左 == 右) {
 st[0][节点] = 值
 返回 空
 }
 定义 中 = (左 + 右) / 2
 如果 (索引 <= 中) {
 线段树_更新递归(st, 节点 * 2, 左, 中, 索引, 值)
 } 否则 {
 线段树_更新递归(st, 节点 * 2 + 1, 中 + 1, 右, 索引, 值)
 }
 定义 树 = st[0]
 树[节点] = 树[节点 * 2] + 树[节点 * 2 + 1]
}

// 区间最小值查询
函数 线段树_最小(st, 查左, 查右) { 返回 线段树_最小递归(st, 1, 0, st[2] - 1, 查左, 查右)
}

函数 线段树_最小递归(st, 节点, 左, 右, 查左, 查右) {
    如果 (查左 > 右 或 查右 < 左) { 返回 999999999
}
 如果 (查左 <= 左 且 右 <= 查右) { 返回 st[0][节点] }
 定义 中 = (左 + 右) / 2
 定义 左值 = 线段树_最小递归(st, 节点 * 2, 左, 中, 查左, 查右)
 定义 右值 = 线段树_最小递归(st, 节点 * 2 + 1, 中 + 1, 右, 查左, 查右)
 如果 (左值 < 右值) { 返回 左值 }
 返回 右值
}

// 理论驱动新功能

函数 线段树_气韵聚合(st, 查左, 查右, 聚合函数, 零元) { 返回 线段树_气韵递归(st, 1, 0, st[2] - 1, 查左, 查右, 聚合函数, 零元)
}

函数 线段树_气韵递归(st, 节点, 左, 右, 查左, 查右, 聚合函数, 零元) {
    如果 (查左 > 右 或 查右 < 左) { 返回 零元
}
 如果 (查左 <= 左 且 右 <= 查右) { 返回 st[0][节点] }
 定义 中 = (左 + 右) / 2
 定义 左结果 = 线段树_气韵递归(st, 节点 * 2, 左, 中, 查左, 查右, 聚合函数, 零元)
 定义 右结果 = 线段树_气韵递归(st, 节点 * 2 + 1, 中 + 1, 右, 查左, 查右, 聚合函数, 零元)
 返回 聚合函数(左结果, 右结果)
}

函数 线段树_阴解构(st) { 定义 n = st[2]
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < n) {
 追加(结果, 线段树_求和(st, i, i))
 i = i + 1
 }
 返回 结果
}

// 区间最大值查询 (阳聚: 取最大)
函数 线段树_最大(st, 查左, 查右) { 返回 线段树_最大递归(st, 1, 0, st[2] - 1, 查左, 查右)
}

函数 线段树_最大递归(st, 节点, 左, 右, 查左, 查右) {
    如果 (查左 > 右 或 查右 < 左) { 返回 -999999999
}
 如果 (查左 <= 左 且 右 <= 查右) { 返回 st[0][节点] }
 定义 中 = (左 + 右) / 2
 定义 左值 = 线段树_最大递归(st, 节点 * 2, 左, 中, 查左, 查右)
 定义 右值 = 线段树_最大递归(st, 节点 * 2 + 1, 中 + 1, 右, 查左, 查右)
 如果 (左值 > 右值) { 返回 左值 }
 返回 右值
}

函数 线段树_阴阳验证(st) { 返回 线段树_验证递归(st, 1, 0, st[2] - 1)
}

函数 线段树_验证递归(st, 节点, 左, 右) {
    如果 (左 == 右) { 返回 1
}
 定义 中 = (左 + 右) / 2
 定义 树 = st[0]
 定义 期望 = 树[节点 * 2] + 树[节点 * 2 + 1]
 如果 (树[节点] != 期望) { 返回 0 }
 如果 (线段树_验证递归(st, 节点 * 2, 左, 中) == 0) { 返回 0 }
 返回 线段树_验证递归(st, 节点 * 2 + 1, 中 + 1, 右)
}

// 懒传播线段树

函数 懒线段树_创建(大小) { 定义 容量 = 大小 * 4
 定义 可变 树 = []
 定义 可变 懒 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(树, 0) 追加(懒, 0) i = i + 1 }
 返回 [树, 懒, 大小]
}

函数 懒线段树_下推(st, 节点, 左, 右) { 如果 (st[1][节点] != 0) { 定义 中 = (左 + 右) / 2
 定义 左子 = 节点 * 2
 定义 右子 = 节点 * 2 + 1
 定义 左大小 = 中 - 左 + 1
 定义 右大小 = 右 - 中
 st[1][左子] = st[1][左子] + st[1][节点]
 st[1][右子] = st[1][右子] + st[1][节点]
 st[0][左子] = st[0][左子] + st[1][节点] * 左大小
 st[0][右子] = st[0][右子] + st[1][节点] * 右大小
 st[1][节点] = 0
 }
}

函数 懒线段树_区间更新(st, 节点, 左, 右, ql, qr, 增量) {
    如果 (ql > 右 或 qr < 左) { 返回
}
 如果 (ql <= 左 且 右 <= qr) {
 st[0][节点] = st[0][节点] + 增量 * (右 - 左 + 1)
 st[1][节点] = st[1][节点] + 增量
 返回
 }
 懒线段树_下推(st, 节点, 左, 右)
 定义 中 = (左 + 右) / 2
 懒线段树_区间更新(st, 节点 * 2, 左, 中, ql, qr, 增量)
 懒线段树_区间更新(st, 节点 * 2 + 1, 中 + 1, 右, ql, qr, 增量)
 st[0][节点] = st[0][节点 * 2] + st[0][节点 * 2 + 1]
}

函数 懒线段树_区间查询(st, 节点, 左, 右, ql, qr) {
    如果 (ql > 右 或 qr < 左) { 返回 0
}
 如果 (ql <= 左 且 右 <= qr) { 返回 st[0][节点] }
 懒线段树_下推(st, 节点, 左, 右)
 定义 中 = (左 + 右) / 2
 返回 懒线段树_区间查询(st, 节点 * 2, 左, 中, ql, qr) + 懒线段树_区间查询(st, 节点 * 2 + 1, 中 + 1, 右, ql, qr)
}

// 区间最值线段树

函数 最值线段树_创建(数据) { 定义 n = 计数(数据)
 定义 容量 = n * 4
 定义 可变 最大树 = []
 定义 可变 最小树 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(最大树, -999999) 追加(最小树, 999999) i = i + 1 }
 定义 st = [最大树, 最小树, n]
 最值线段树_构建(st, 数据, 1, 0, n - 1)
 返回 st
}

函数 最值线段树_构建(st, 数据, 节点, 左, 右) { 如果 (左 == 右) {
 st[0][节点] = 数据[左]
 st[1][节点] = 数据[左]
 返回
 }
 定义 中 = (左 + 右) / 2
 最值线段树_构建(st, 数据, 节点 * 2, 左, 中)
 最值线段树_构建(st, 数据, 节点 * 2 + 1, 中 + 1, 右)
 如果 (st[0][节点 * 2] > st[0][节点 * 2 + 1]) { st[0][节点] = st[0][节点 * 2] }
 否则 { st[0][节点] = st[0][节点 * 2 + 1] }
 如果 (st[1][节点 * 2] < st[1][节点 * 2 + 1]) { st[1][节点] = st[1][节点 * 2] }
 否则 { st[1][节点] = st[1][节点 * 2 + 1] }
}

函数 最值线段树_查最大(st, 节点, 左, 右, ql, qr) {
    如果 (ql > 右 或 qr < 左) { 返回 -999999
}
 如果 (ql <= 左 且 右 <= qr) { 返回 st[0][节点] }
 定义 中 = (左 + 右) / 2
 定义 左值 = 最值线段树_查最大(st, 节点 * 2, 左, 中, ql, qr)
 定义 右值 = 最值线段树_查最大(st, 节点 * 2 + 1, 中 + 1, 右, ql, qr)
 如果 (左值 > 右值) { 返回 左值 }
 返回 右值
}

函数 最值线段树_查最小(st, 节点, 左, 右, ql, qr) {
    如果 (ql > 右 或 qr < 左) { 返回 999999
}
 如果 (ql <= 左 且 右 <= qr) { 返回 st[1][节点] }
 定义 中 = (左 + 右) / 2
 定义 左值 = 最值线段树_查最小(st, 节点 * 2, 左, 中, ql, qr)
 定义 右值 = 最值线段树_查最小(st, 节点 * 2 + 1, 中 + 1, 右, ql, qr)
 如果 (左值 < 右值) { 返回 左值 }
 返回 右值
}

// 区间GCD线段树

函数 _最大公约数(a, b) {
    如果 (b == 0) { 返回 a
}
 返回 _最大公约数(b, a % b)
}

函数 GCD线段树_创建(数据) { 定义 n = 计数(数据)
 定义 容量 = n * 4
 定义 可变 树 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(树, 0) i = i + 1 }
 定义 st = [树, n]
 GCD线段树_构建(st, 数据, 1, 0, n - 1)
 返回 st
}

函数 GCD线段树_构建(st, 数据, 节点, 左, 右) {
    如果 (左 == 右) { st[0][节点] = 数据[左] 返回
}
 定义 中 = (左 + 右) / 2
 GCD线段树_构建(st, 数据, 节点 * 2, 左, 中)
 GCD线段树_构建(st, 数据, 节点 * 2 + 1, 中 + 1, 右)
 st[0][节点] = _最大公约数(st[0][节点 * 2], st[0][节点 * 2 + 1])
}

函数 GCD线段树_查询(st, 节点, 左, 右, ql, qr) {
    如果 (ql > 右 或 qr < 左) { 返回 0
}
 如果 (ql <= 左 且 右 <= qr) { 返回 st[0][节点] }
 定义 中 = (左 + 右) / 2
 定义 左值 = GCD线段树_查询(st, 节点 * 2, 左, 中, ql, qr)
 定义 右值 = GCD线段树_查询(st, 节点 * 2 + 1, 中 + 1, 右, ql, qr)
 如果 (左值 == 0) { 返回 右值 }
 如果 (右值 == 0) { 返回 左值 }
 返回 _最大公约数(左值, 右值)
}

定义 可变 _线段树_最大规模 = 0
定义 可变 _线段树_懒传播数 = 0

函数 线段树_记录操作(规模) {
    如果 (规模 > _线段树_最大规模) { _线段树_最大规模 = 规模
}
}
函数 线段树_记录懒传播() { _线段树_懒传播数 = _线段树_懒传播数 + 1 }

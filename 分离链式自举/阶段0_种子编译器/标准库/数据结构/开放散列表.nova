
导入("../基础.nova")

定义 OHT_空 = 0
定义 OHT_占用 = 1
定义 OHT_删除 = 2

// 散列表: [桶数组, 状态数组, 容量, 大小]
// 桶: [键, 值]
函数 oht_创建(容量) {
    定义 可变 桶 = []
    定义 可变 状态 = []
    定义 可变 i = 0
    当 (i < 容量) {
        追加(桶, [0, 0])
        追加(状态, OHT_空)
        i = i + 1
    }
    返回 [桶, 状态, 容量, 0]
}

函数 oht_哈希(键, 容量) {
    定义 可变 h = 0
    如果 (键 >= 0) { h = 键 } 否则 { h = 0 - 键 }
    返回 h % 容量
}

函数 oht_字符串哈希(键, 容量) {
    定义 可变 h = 5381
    定义 可变 i = 0
    当 (i < 字节长度(键)) {
        h = h * 33 + 字节取(键, i)
        如果 (h < 0) { h = 0 - h }
        i = i + 1
    }
    返回 h % 容量
}

// 插入
函数 oht_插入(表, 键, 值) {
    定义 容量 = 表[2]
    定义 可变 索引 = oht_哈希(键, 容量)
    定义 状态 = 表[1]
    定义 桶 = 表[0]
    定义 可变 探测 = 0
    当 (探测 < 容量) {
        如果 (状态[索引] == OHT_空 或 状态[索引] == OHT_删除) {
            桶[索引] = [键, 值]
            状态[索引] = OHT_占用
            表[3] = 表[3] + 1
            返回 1
        }
        定义 现有桶 = 桶[索引]
        如果 (状态[索引] == OHT_占用 且 现有桶[0] == 键) {
            桶[索引] = [键, 值]
            返回 1
        }
        索引 = (索引 + 1) % 容量
        探测 = 探测 + 1
    }
    返回 0
}

// 查找
函数 oht_查找(表, 键) {
    定义 容量 = 表[2]
    定义 可变 索引 = oht_哈希(键, 容量)
    定义 状态 = 表[1]
    定义 桶 = 表[0]
    定义 可变 探测 = 0
    当 (探测 < 容量) {
        如果 (状态[索引] == OHT_空) { 返回 空 }
        如果 (状态[索引] == OHT_占用) {
            定义 b = 桶[索引]
            如果 (b[0] == 键) { 返回 b[1] }
        }
        索引 = (索引 + 1) % 容量
        探测 = 探测 + 1
    }
    返回 空
}

// 删除
函数 oht_删除(表, 键) {
    定义 容量 = 表[2]
    定义 可变 索引 = oht_哈希(键, 容量)
    定义 状态 = 表[1]
    定义 桶 = 表[0]
    定义 可变 探测 = 0
    当 (探测 < 容量) {
        如果 (状态[索引] == OHT_空) { 返回 0 }
        如果 (状态[索引] == OHT_占用) {
            定义 b = 桶[索引]
            如果 (b[0] == 键) {
                状态[索引] = OHT_删除
                表[3] = 表[3] - 1
                返回 1
            }
        }
        索引 = (索引 + 1) % 容量
        探测 = 探测 + 1
    }
    返回 0
}

函数 oht_大小(表) { 返回 表[3] }
函数 oht_容量(表) { 返回 表[2] }
函数 oht_负载因子(表) { 返回 表[3] * 100 / 表[2] }

// 清空
函数 oht_清空(表) {
    定义 状态 = 表[1]
    定义 可变 i = 0
    当 (i < 表[2]) { 状态[i] = OHT_空 i = i + 1 }
    表[3] = 0
}

// 迭代器

函数 oht_所有键(表) {
    定义 可变 键列表 = []
    定义 数据 = 表[0]
    定义 状态 = 表[1]
    定义 可变 i = 0
    当 (i < 表[2]) {
        如果 (状态[i] == OHT_占用) { 追加(键列表, 数据[i][0]) }
        i = i + 1
    }
    返回 键列表
}

函数 oht_所有值(表) {
    定义 可变 值列表 = []
    定义 数据 = 表[0]
    定义 状态 = 表[1]
    定义 可变 i = 0
    当 (i < 表[2]) {
        如果 (状态[i] == OHT_占用) { 追加(值列表, 数据[i][1]) }
        i = i + 1
    }
    返回 值列表
}

函数 oht_所有键值(表) {
    定义 可变 对列表 = []
    定义 数据 = 表[0]
    定义 状态 = 表[1]
    定义 可变 i = 0
    当 (i < 表[2]) {
        如果 (状态[i] == OHT_占用) { 追加(对列表, [数据[i][0], 数据[i][1]]) }
        i = i + 1
    }
    返回 对列表
}

// 批量操作

函数 oht_批量插入(表, 键值对列表) {
    定义 可变 成功 = 0
    定义 可变 i = 0
    当 (i < 计数(键值对列表)) {
        如果 (oht_插入(表, 键值对列表[i][0], 键值对列表[i][1])) { 成功 = 成功 + 1 }
        i = i + 1
    }
    返回 成功
}

函数 oht_批量删除(表, 键列表) {
    定义 可变 成功 = 0
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        如果 (oht_删除(表, 键列表[i])) { 成功 = 成功 + 1 }
        i = i + 1
    }
    返回 成功
}

// 动态扩容

函数 oht_需要扩容(表) {
    返回 oht_负载因子(表) > 70
}

函数 oht_扩容(表) {
    定义 旧数据 = 表[0]
    定义 旧状态 = 表[1]
    定义 旧容量 = 表[2]
    定义 新容量 = 旧容量 * 2
    // 重建
    定义 可变 新数据 = []
    定义 可变 新状态 = []
    定义 可变 i = 0
    当 (i < 新容量) {
        追加(新数据, [空, 空])
        追加(新状态, OHT_空)
        i = i + 1
    }
    表[0] = 新数据
    表[1] = 新状态
    表[2] = 新容量
    表[3] = 0
    // 重新插入
    i = 0
    当 (i < 旧容量) {
        如果 (旧状态[i] == OHT_占用) {
            oht_插入(表, 旧数据[i][0], 旧数据[i][1])
        }
        i = i + 1
    }
}

函数 oht_自动维护(表) {
    如果 (oht_需要扩容(表)) { oht_扩容(表) }
}

// 散列函数

函数 oht_字符串散列(s, 容量) {
    定义 可变 h = 0
    定义 可变 i = 0
    当 (i < 计数(s)) {
        h = h * 31 + 编码(子串(s, i, 1))
        h = h % 容量
        i = i + 1
    }
    返回 h
}

函数 oht_整数散列(n, 容量) {
    定义 可变 h = n
    h = ((h >> 16) ^ h) * 45267
    h = ((h >> 16) ^ h) * 45267
    h = (h >> 16) ^ h
    如果 (h < 0) { h = 0 - h }
    返回 h % 容量
}

定义 可变 _oht_插入数 = 0
定义 可变 _oht_查找数 = 0
定义 可变 _oht_冲突数 = 0

函数 oht_记录插入() { _oht_插入数 = _oht_插入数 + 1 }
函数 oht_记录查找() { _oht_查找数 = _oht_查找数 + 1 }
函数 oht_记录冲突() { _oht_冲突数 = _oht_冲突数 + 1 }

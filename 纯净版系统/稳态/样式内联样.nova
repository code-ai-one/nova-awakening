// §3 内联样式样式解析

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 样式_解析内联(样式文本) {
    // 解析 "color: red; font-size: 16px; background: #fff"
    定义 s = 原生计算样式 {}
    // 当前实现: 解析关键CSS属性
    定义 颜色 = 样式_提取属性(样式文本, "color")
    如果 (颜色 != "") { s.前景色 = 样式_解析颜色(颜色) }

    定义 背景 = 样式_提取属性(样式文本, "background")
    如果 (背景 == "") { 背景 = 样式_提取属性(样式文本, "background-color") }
    如果 (背景 != "") { s.背景色 = 样式_解析颜色(背景) }

    定义 字号 = 样式_提取属性(样式文本, "font-size")
    如果 (字号 != "") { s.字号 = 样式_解析像素值(字号) }

    定义 显示 = 样式_提取属性(样式文本, "display")
    如果 (显示 == "none") { s.显示 = 3 }
    否则 如果 (显示 == "flex") { s.显示 = 2 }
    否则 如果 (显示 == "inline") { s.显示 = 1 }
    否则 如果 (显示 == "block") { s.显示 = 0 }

    返回 s
}

函数 样式_提取属性(样式, 属性名) {
    定义 搜索 = 属性名 + ":"
    定义 位置 = NML_查找子串(样式, 搜索)
    如果 (位置 < 0) { 返回 "" }
    定义 值开始 = 位置 + 字符串长度(搜索)
    // 跳过空格
    当 (值开始 < 字符串长度(样式) && 字符串取字节(样式, 值开始) == 32) {
        值开始 = 值开始 + 1
    }
    // 读到分号或末尾
    定义 可变 值结束 = 值开始
    当 (值结束 < 字符串长度(样式) && 字符串取字节(样式, 值结束) != 59) {
        值结束 = 值结束 + 1
    }
    返回 NML_修剪空白(NML_子串(样式, 值开始, 值结束))
}

函数 样式_解析颜色(颜色文本) {
    // 支持 #rgb, #rrggbb, 颜色名
    如果 (字符串长度(颜色文本) > 0 && 字符串取字节(颜色文本, 0) == 35) {  // '#'
        如果 (字符串长度(颜色文本) == 7) {
            返回 十六进制解析(颜色文本, 1, 7)
        }
        如果 (字符串长度(颜色文本) == 4) {
            // #rgb → #rrggbb
            定义 r = 十六进制字符值(字符串取字节(颜色文本, 1))
            定义 g = 十六进制字符值(字符串取字节(颜色文本, 2))
            定义 b = 十六进制字符值(字符串取字节(颜色文本, 3))
            返回 (r * 17 << 16) | (g * 17 << 8) | (b * 17)
        }
    }
    // 颜色名
    如果 (颜色文本 == "red") { 返回 0xFF0000 }
    如果 (颜色文本 == "green") { 返回 0x00FF00 }
    如果 (颜色文本 == "blue") { 返回 0x0000FF }
    如果 (颜色文本 == "white") { 返回 0xFFFFFF }
    如果 (颜色文本 == "black") { 返回 0x000000 }
    如果 (颜色文本 == "gray" || 颜色文本 == "grey") { 返回 0x808080 }
    如果 (颜色文本 == "yellow") { 返回 0xFFFF00 }
    如果 (颜色文本 == "orange") { 返回 0xFFA500 }
    如果 (颜色文本 == "purple") { 返回 0x800080 }
    如果 (颜色文本 == "transparent") { 返回 0x00000000 }
    返回 0x000000
}

函数 样式_解析像素值(文本) {
    // "16px" → 16
    定义 可变 值 = 0
    定义 可变 i = 0
    当 (i < 字符串长度(文本)) {
        定义 ch = 字符串取字节(文本, i)
        如果 (ch >= 48 && ch <= 57) {
            值 = 值 * 10 + (ch - 48)
        } 否则 {
            i = 字符串长度(文本)  // break
        }
        i = i + 1
    }
    返回 值
}

// §4 查询接口

函数 NML_按ID查找(根, id值) {
    如果 (根 == 空) { 返回 空 }
    // 检查当前节点
    定义 当前id = 元素_获取属性(根, 字符串哈希("id"))
    如果 (当前id == id值) { 返回 根 }
    // 递归搜索子节点
    定义 可变 i = 0
    当 (i < 计数(根.子节点)) {
        定义 结果 = NML_按ID查找(根.子节点[i], id值)
        如果 (结果 != 空) { 返回 结果 }
        i = i + 1
    }
    返回 空
}

函数 NML_get元素sByTag(根, 标签ID) {
    定义 可变 结果 = []
    NML_收集标签(根, 标签ID, 结果)
    返回 结果
}

函数 NML_收集标签(节点, 标签ID, 结果) {
    如果 (节点 == 空) { 返回 }
    如果 (节点.标签 == 标签ID) { 追加(结果, 节点) }
    定义 可变 i = 0
    当 (i < 计数(节点.子节点)) {
        NML_收集标签(节点.子节点[i], 标签ID, 结果)
        i = i + 1
    }
}

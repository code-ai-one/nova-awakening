// Nova 原生前端层 — 将中文文章式源码转化为语法树
// 职责：词元扫描、全角标点列化、中文连接词吸收、语法规则识别
// 中文词汇支持：假如/因为/所以/虽然/首先/然后/必须/大于/小于/等于/不等于/大于等于/小于等于/且/或/非/加等/减等 等
// 引用方： Nova.nova 、模块图编译器.nova
// 设计原则：八岁小孩记下的一段话，就能被识别并运行

// 全局状态
// 状态容器:
// 词法状态 = [标记数, 回溯数, 扫描次数, 转义次数, 未终止数]
// 语法状态 = [节点创建, 节点遍历, 节点替换, 表达式解析, 表达式折叠, 错误数, 匿名函数列]
// 行号状态 = [位置映射, 源码映射, 断点映射, 内联表, 函数边界表, 查询次数, 映射数]

导入("../标准库/基础.nova")
导入("../标准库/系统/硬件库.nova")
导入("标记常量.nova")
导入("规划/核心/常量.nova")
导入("词法/注释处理.nova")
导入("词法/数字扫描.nova")
导入("词法/字符串扫描.nova")

定义 可变 词法状态 = [0, 0, 0, 0, 0]
定义 可变 语法状态 = [0, 0, 0, 0, 0, 0, []]
定义 可变 行号状态 = [[], [], [], [], [], 0, 0]

// 全局重置
函数 词法引擎_全局重置() {
    词法状态[0] = 0
    词法状态[1] = 0
    词法状态[2] = 0
    词法状态[3] = 0
    词法状态[4] = 0
}

函数 语法引擎_全局重置() {
    语法状态[0] = 0
    语法状态[1] = 0
    语法状态[2] = 0
    语法状态[3] = 0
    语法状态[4] = 0
    语法状态[5] = 0
    语法状态[6] = []
}

函数 行号追踪_全局重置() {
    行号状态[0] = []
    行号状态[1] = []
    行号状态[2] = []
    行号状态[3] = []
    行号状态[4] = []
    行号状态[5] = 0
    行号状态[6] = 0
}

// 关键字映射
函数 前端_查关键字(名称) {
    如果 (名称 == "当") { 返回 标记_当 }
    如果 (名称 == "定义") { 返回 标记_定义 }
    如果 (名称 == "可变") { 返回 标记_可变 }
    如果 (名称 == "函数") { 返回 标记_函数 }
    如果 (名称 == "返回") { 返回 标记_返回 }
    如果 (名称 == "如果") { 返回 标记_如果 }
    如果 (名称 == "若") { 返回 标记_如果 }
    如果 (名称 == "假如") { 返回 标记_如果 }
    如果 (名称 == "假设") { 返回 标记_如果 }
    如果 (名称 == "倘若") { 返回 标记_如果 }
    如果 (名称 == "要是") { 返回 标记_如果 }
    如果 (名称 == "因为") { 返回 标记_如果 }
    如果 (名称 == "虽然") { 返回 标记_如果 }
    如果 (名称 == "否则") { 返回 标记_否则 }
    如果 (名称 == "不然") { 返回 标记_否则 }
    如果 (名称 == "不然的话") { 返回 标记_否则 }
    如果 (名称 == "但是") { 返回 标记_连接词 }
    如果 (名称 == "可是") { 返回 标记_连接词 }
    如果 (名称 == "然而") { 返回 标记_连接词 }
    如果 (名称 == "循环") { 返回 标记_循环 }
    如果 (名称 == "导入") { 返回 标记_导入 }
    如果 (名称 == "结构") { 返回 标记_结构 }
    如果 (名称 == "建") { 返回 标记_建 }
    如果 (名称 == "匹配") { 返回 标记_匹配 }
    如果 (名称 == "默认") { 返回 标记_默认 }
    如果 (名称 == "中断") { 返回 标记_中断 }
    如果 (名称 == "继续") { 返回 标记_继续 }
    如果 (名称 == "真") { 返回 标记_真 }
    如果 (名称 == "假") { 返回 标记_假 }
    如果 (名称 == "空") { 返回 标记_空 }
    如果 (名称 == "尝试") { 返回 标记_尝试 }
    如果 (名称 == "得") { 返回 标记_得 }
    如果 (名称 == "抛出") { 返回 标记_抛出 }
    如果 (名称 == "每") { 返回 标记_循环 }
    如果 (名称 == "每个") { 返回 标记_循环 }
    如果 (名称 == "入") { 返回 标记_导入 }
    如果 (名称 == "止") { 返回 标记_中断 }
    如果 (名称 == "续") { 返回 标记_继续 }
    如果 (名称 == "试") { 返回 标记_尝试 }
    如果 (名称 == "抛") { 返回 标记_抛出 }
    如果 (名称 == "所以") { 返回 标记_连接词 }
    如果 (名称 == "那么") { 返回 标记_连接词 }
    如果 (名称 == "则") { 返回 标记_连接词 }
    如果 (名称 == "首先") { 返回 标记_顺序词 }
    如果 (名称 == "然后") { 返回 标记_顺序词 }
    如果 (名称 == "接着") { 返回 标记_顺序词 }
    如果 (名称 == "随后") { 返回 标记_顺序词 }
    如果 (名称 == "最后") { 返回 标记_顺序词 }
    如果 (名称 == "此时") { 返回 标记_顺序词 }
    如果 (名称 == "于是") { 返回 标记_顺序词 }
    如果 (名称 == "继而") { 返回 标记_顺序词 }
    如果 (名称 == "其次") { 返回 标记_顺序词 }
    如果 (名称 == "再者") { 返回 标记_顺序词 }
    如果 (名称 == "另外") { 返回 标记_顺序词 }
    如果 (名称 == "汇编") { 返回 标记_汇编 }
    // ─ 条件强调词 → 映射为 如果(114)
    如果 (名称 == "必须") { 返回 标记_如果 }
    如果 (名称 == "一定") { 返回 标记_如果 }
    如果 (名称 == "若是") { 返回 标记_如果 }
    如果 (名称 == "只要") { 返回 标记_如果 }
    如果 (名称 == "每当") { 返回 标记_如果 }
    如果 (名称 == "一旦") { 返回 标记_如果 }
    如果 (名称 == "凡是") { 返回 标记_如果 }
    如果 (名称 == "倘") { 返回 标记_如果 }
    // ─ 否定条件 → 否则(115)
    如果 (名称 == "否则的话") { 返回 标记_否则 }
    如果 (名称 == "反之") { 返回 标记_否则 }
    如果 (名称 == "除此之外") { 返回 标记_否则 }
    // ─ 循环 → 当(116)
    如果 (名称 == "直到") { 返回 标记_当 }
    如果 (名称 == "重复") { 返回 标记_当 }
    如果 (名称 == "持续") { 返回 标记_当 }
    // ─ 函数别名 → 函数(112)
    如果 (名称 == "法") { 返回 标记_函数 }
    // "方法" 不再映射为函数关键字，因为它常用作参数名/变量名
    如果 (名称 == "做法") { 返回 标记_函数 }
    // 注: 操作/算法/步骤/命名/设/令/记 不映射为关键字
    // 原因: 与标准库中468+处同名变量冲突，且Rust种子编译器不映射这些词
    // ─ 变量定义别名 → 定义(110)
    如果 (名称 == "称为") { 返回 标记_定义 }
    如果 (名称 == "叫做") { 返回 标记_定义 }
    // ─ 返回别名 → 返回(113)
    // 注: 得到/结果/输出/产出 不映射，避免 结果=x 被误解析为 返回 语句
    如果 (名称 == "给出") { 返回 标记_返回 }
    // ─ 中文比较运算词 → 比较运算符token
    // (标准库中原同名变量已改名为 低组/高组/同组)
    如果 (名称 == "大于等于") { 返回 标记_大等 }
    如果 (名称 == "小于等于") { 返回 标记_小等 }
    如果 (名称 == "不等于") { 返回 标记_不等 }
    如果 (名称 == "大于") { 返回 标记_大于 }
    如果 (名称 == "小于") { 返回 标记_小于 }
    如果 (名称 == "等于") { 返回 标记_等等 }
    // ─ 中文自增自减 → 复合赋值token
    如果 (名称 == "加等") { 返回 标记_加等 }
    如果 (名称 == "减等") { 返回 标记_减等 }
    // ─ 中文逻辑词 → 逻辑运算符token
    如果 (名称 == "且") { 返回 标记_且 }
    如果 (名称 == "并且") { 返回 标记_且 }
    如果 (名称 == "而且") { 返回 标记_且 }
    如果 (名称 == "或") { 返回 标记_或 }
    如果 (名称 == "或者") { 返回 标记_或 }
    如果 (名称 == "非") { 返回 标记_非 }
    // ─ 智能基因操作关键字 → 调用智能基因原语的语法糖(映射为函数调用)
    // 这些词让用户直接用日常中文操作知识/推理/记忆/感知基因层
    如果 (名称 == "知晓") { 返回 标记_标识符 }    // 知晓X → 标识符，后接智能基因调用
    如果 (名称 == "推断") { 返回 标记_标识符 }    // 推断X → 智能基因推理调用
    如果 (名称 == "记住") { 返回 标记_标识符 }    // 记住X → 智能基因记忆写入
    如果 (名称 == "回想") { 返回 标记_标识符 }    // 回想X → 智能基因记忆检索
    如果 (名称 == "关注") { 返回 标记_标识符 }    // 关注X → 智能基因注意力
    如果 (名称 == "学会") { 返回 标记_标识符 }    // 学会X → 智能基因学习
    如果 (名称 == "理解") { 返回 标记_标识符 }    // 理解X → 智能基因语言理解
    如果 (名称 == "领悟") { 返回 标记_标识符 }    // 领悟X → 智能基因推理+学习
    如果 (名称 == "认知") { 返回 标记_标识符 }    // 认知X → 智能基因感知
    如果 (名称 == "感知") { 返回 标记_标识符 }    // 感知X → 智能基因感知操作
    // ─ 说/打印别名 → 函数调用
    如果 (名称 == "说") { 返回 标记_标识符 }      // 说 "内容" → 打印调用
    如果 (名称 == "打印") { 返回 标记_标识符 }
    如果 (名称 == "显示") { 返回 标记_标识符 }
    如果 (名称 == "告诉") { 返回 标记_标识符 }
    如果 (名称 == "报告") { 返回 标记_标识符 }
    返回 0
}

// UTF-8 原生码点解码引擎
// Nova自研创新: 字节级UTF-8→Unicode码点解码
// 让词法器真正理解每一个中文字符的身份,而非仅靠>127粗判
// UTF-8编码规则:
//   0xxxxxxx                          → 1字节 (ASCII 0-127)
//   110xxxxx 10xxxxxx                 → 2字节 (128-2047)
//   1110xxxx 10xxxxxx 10xxxxxx        → 3字节 (2048-65535, 中文在此)
//   11110xxx 10xxxxxx 10xxxxxx 10xxxx → 4字节 (65536+, emoji等)
函数 _UTF8码点(串, 偏移) {
    定义 b0 = 字节取(串, 偏移)
    如果 (b0 < 128) { 返回 b0 * 65536 + 1 }
    如果 (b0 < 224) {
        定义 b1 = 字节取(串, 偏移 + 1)
        返回 ((b0 - 192) * 64 + (b1 - 128)) * 65536 + 2
    }
    如果 (b0 < 240) {
        定义 b1 = 字节取(串, 偏移 + 1)
        定义 b2 = 字节取(串, 偏移 + 2)
        返回 ((b0 - 224) * 4096 + (b1 - 128) * 64 + (b2 - 128)) * 65536 + 3
    }
    定义 b1 = 字节取(串, 偏移 + 1)
    定义 b2 = 字节取(串, 偏移 + 2)
    定义 b3 = 字节取(串, 偏移 + 3)
    返回 ((b0 - 240) * 262144 + (b1 - 128) * 4096 + (b2 - 128) * 64 + (b3 - 128)) * 65536 + 4
}

函数 _UTF8取码点(编码值) { 返回 编码值 / 65536 }
函数 _UTF8取字节数(编码值) { 返回 编码值 - (编码值 / 65536) * 65536 }

// 中文数字解析 (基于UTF-8码点引擎)
// 解析中文数字字面量: 一二三...十百千万亿零两〇 → 整数值 (不匹配返回 -1)
函数 _是中文数字码点(cp) {
    返回 cp == 中文码_一 或 cp == 中文码_二 或 cp == 中文码_三 或 cp == 中文码_四 或 cp == 中文码_五 或 cp == 中文码_六 或 cp == 中文码_七 或 cp == 中文码_八 或 cp == 中文码_九 或 cp == 中文码_零 或 cp == 中文码_〇 或 cp == 中文码_两 或 cp == 中文码_十 或 cp == 中文码_百 或 cp == 中文码_千 或 cp == 中文码_万 或 cp == 中文码_亿
}

函数 _中文数字码点值(cp) {
    如果 (cp == 中文码_零 或 cp == 中文码_〇) { 返回 0 }
    如果 (cp == 中文码_一) { 返回 1 }
    如果 (cp == 中文码_二 或 cp == 中文码_两) { 返回 2 }
    如果 (cp == 中文码_三) { 返回 3 }
    如果 (cp == 中文码_四) { 返回 4 }
    如果 (cp == 中文码_五) { 返回 5 }
    如果 (cp == 中文码_六) { 返回 6 }
    如果 (cp == 中文码_七) { 返回 7 }
    如果 (cp == 中文码_八) { 返回 8 }
    如果 (cp == 中文码_九) { 返回 9 }
    返回 0 - 1
}

函数 _是中文数字单位码点(cp) {
    返回 cp == 中文码_十 或 cp == 中文码_百 或 cp == 中文码_千 或 cp == 中文码_万 或 cp == 中文码_亿
}

函数 _解析中文数字(名称) {
    定义 字节长 = 字节长度(名称)
    如果 (字节长 == 0) { 返回 0 - 1 }
    定义 首编码 = _UTF8码点(名称, 0)
    定义 首码点 = _UTF8取码点(首编码)
    如果 (_UTF8取字节数(首编码) == 字节长 且 _是中文数字单位码点(首码点)) { 返回 0 - 1 }
    // 第一遍: 验证所有字符均为中文数字字符
    定义 可变 偏移 = 0
    当 (偏移 < 字节长) {
        定义 编码值 = _UTF8码点(名称, 偏移)
        定义 cp = _UTF8取码点(编码值)
        定义 步长 = _UTF8取字节数(编码值)
        如果 (_是中文数字码点(cp) == 假) { 返回 0 - 1 }
        偏移 = 偏移 + 步长
    }
    // 第二遍: 按权值累加 (支持"三百二十一"=321, "一万五千"=15000, "两亿"=200000000)
    定义 可变 结果值 = 0
    定义 可变 当前值 = 0
    定义 可变 段值 = 0
    定义 可变 首字符 = 1
    偏移 = 0
    当 (偏移 < 字节长) {
        定义 编码值 = _UTF8码点(名称, 偏移)
        定义 cp = _UTF8取码点(编码值)
        定义 步长 = _UTF8取字节数(编码值)
        定义 d = _中文数字码点值(cp)
        如果 (d >= 0) {
            当前值 = d
        } 否则 如果 (cp == 中文码_十) {
            如果 (当前值 == 0 且 段值 == 0 且 首字符 == 1) { 当前值 = 1 }
            段值 = 段值 + 当前值 * 10
            当前值 = 0
        } 否则 如果 (cp == 中文码_百) {
            如果 (当前值 == 0 且 段值 == 0) { 当前值 = 1 }
            段值 = 段值 + 当前值 * 100
            当前值 = 0
        } 否则 如果 (cp == 中文码_千) {
            如果 (当前值 == 0 且 段值 == 0) { 当前值 = 1 }
            段值 = 段值 + 当前值 * 1000
            当前值 = 0
        } 否则 如果 (cp == 中文码_万) {
            段值 = 段值 + 当前值
            结果值 = (结果值 + 段值) * 10000
            段值 = 0
            当前值 = 0
        } 否则 如果 (cp == 中文码_亿) {
            段值 = 段值 + 当前值
            结果值 = (结果值 + 段值) * 100000000
            段值 = 0
            当前值 = 0
        }
        首字符 = 0
        偏移 = 偏移 + 步长
    }
    返回 结果值 + 段值 + 当前值
}

// 运算符/标点辅助
// 返回消费字符数(1或2), 0=不匹配
函数 _词法_运算符(标记列, c, c2, 行, 列) {
    // 双字符运算符
    如果 (c == 字符_等号 且 c2 == 字符_等号) { 追加(标记列, [标记_等等, 0, 行, 列])  返回 2 }
    如果 (c == 字符_叹号 且 c2 == 字符_等号) { 追加(标记列, [标记_不等, 0, 行, 列])  返回 2 }
    如果 (c == 字符_小于号 且 c2 == 字符_等号) { 追加(标记列, [标记_小等, 0, 行, 列])  返回 2 }
    如果 (c == 字符_大于号 且 c2 == 字符_等号) { 追加(标记列, [标记_大等, 0, 行, 列])  返回 2 }
    如果 (c == 字符_小于号 且 c2 == 字符_小于号) { 追加(标记列, [标记_左移, 0, 行, 列])  返回 2 }
    如果 (c == 字符_大于号 且 c2 == 字符_大于号) { 追加(标记列, [标记_右移, 0, 行, 列])  返回 2 }
    如果 (c == 字符_与号 且 c2 == 字符_与号) { 追加(标记列, [标记_且, 0, 行, 列])  返回 2 }
    如果 (c == 字符_竖线 且 c2 == 字符_竖线) { 追加(标记列, [标记_或, 0, 行, 列])  返回 2 }
    如果 (c == 字符_加号 且 c2 == 字符_等号) { 追加(标记列, [标记_加等, 0, 行, 列])  返回 2 }
    如果 (c == 字符_减号 且 c2 == 字符_等号) { 追加(标记列, [标记_减等, 0, 行, 列])  返回 2 }
    // 单字符运算符
    如果 (c == 字符_加号) { 追加(标记列, [标记_加, 0, 行, 列])  返回 1 }
    如果 (c == 字符_减号) { 追加(标记列, [标记_减, 0, 行, 列])  返回 1 }
    如果 (c == 字符_星号) { 追加(标记列, [标记_乘, 0, 行, 列])  返回 1 }
    如果 (c == 字符_斜杠) { 追加(标记列, [标记_除, 0, 行, 列])  返回 1 }
    如果 (c == 字符_百分号) { 追加(标记列, [标记_余, 0, 行, 列])  返回 1 }
    如果 (c == 字符_等号) { 追加(标记列, [标记_赋值, 0, 行, 列])  返回 1 }
    如果 (c == 字符_小于号) { 追加(标记列, [标记_小于, 0, 行, 列])  返回 1 }
    如果 (c == 字符_大于号) { 追加(标记列, [标记_大于, 0, 行, 列])  返回 1 }
    如果 (c == 字符_叹号) { 追加(标记列, [标记_非, 0, 行, 列])  返回 1 }
    如果 (c == 字符_与号) { 追加(标记列, [标记_位与, 0, 行, 列])  返回 1 }
    如果 (c == 字符_竖线) { 追加(标记列, [标记_位或, 0, 行, 列])  返回 1 }
    如果 (c == 字符_异或号) { 追加(标记列, [标记_位异或, 0, 行, 列])  返回 1 }
    如果 (c == 字符_波浪号) { 追加(标记列, [标记_位取反, 0, 行, 列])  返回 1 }
    // 半角分界符
    如果 (c == 字符_左圆括) { 追加(标记列, [标记_左括, 0, 行, 列])  返回 1 }
    如果 (c == 字符_右圆括) { 追加(标记列, [标记_右括, 0, 行, 列])  返回 1 }
    如果 (c == 字符_左花括) { 追加(标记列, [标记_左花, 0, 行, 列])  返回 1 }
    如果 (c == 字符_右花括) { 追加(标记列, [标记_右花, 0, 行, 列])  返回 1 }
    如果 (c == 字符_左方括) { 追加(标记列, [标记_左方, 0, 行, 列])  返回 1 }
    如果 (c == 字符_右方括) { 追加(标记列, [标记_右方, 0, 行, 列])  返回 1 }
    如果 (c == 字符_逗号) { 追加(标记列, [标记_逗号, 0, 行, 列])  返回 1 }
    如果 (c == 字符_句点) { 追加(标记列, [标记_点号, 0, 行, 列])  返回 1 }
    如果 (c == 字符_冒号) { 追加(标记列, [标记_冒号, 0, 行, 列])  返回 1 }
    如果 (c == 字符_分号) { 追加(标记列, [标记_分号, 0, 行, 列])  返回 1 }
    返回 0
}

// 全角标点码点分流 (接收Unicode码点,非字节值)
// 由UTF-8多字节分流层调用,cp是完整Unicode码点
函数 _词法_全角码点(标记列, cp, 行, 列) {
    如果 (cp == 中文码_左括) { 追加(标记列, [标记_左括, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_右括) { 追加(标记列, [标记_右括, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_左花) { 追加(标记列, [标记_左花, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_右花) { 追加(标记列, [标记_右花, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_左方) { 追加(标记列, [标记_左方, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_右方) { 追加(标记列, [标记_右方, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_逗号 或 cp == 12289) { 追加(标记列, [标记_逗号, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_冒号) { 追加(标记列, [标记_冒号, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_左书) { 追加(标记列, [标记_左花, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_右书) { 追加(标记列, [标记_右花, 0, 行, 列])  返回 1 }
    如果 (cp == 12302) { 追加(标记列, [标记_左括, 0, 行, 列])  返回 1 }
    如果 (cp == 12303) { 追加(标记列, [标记_右括, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_分号) { 追加(标记列, [标记_分号, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_句号) { 追加(标记列, [标记_分号, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_等号) { 追加(标记列, [标记_赋值, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_加号) { 追加(标记列, [标记_加, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_减号) { 追加(标记列, [标记_减, 0, 行, 列])  返回 1 }
    如果 (cp == 中文码_叹号) { 追加(标记列, [标记_非, 0, 行, 列])  返回 1 }
    返回 0
}

// 词法分析入口
函数 前端_词法分析(源码) {
    如果 (源码 == 空) { 返回 [] }
    定义 可变 标记列 = []
    定义 长 = 计数(源码)
    定义 可变 位置 = 0
    定义 可变 行 = 1
    定义 可变 列 = 1

    // 跳过 UTF-8 BOM
    如果 (长 >= 3) {
        如果 (字节取(源码, 0) == 239) {
            如果 (字节取(源码, 1) == 187) {
                如果 (字节取(源码, 2) == 191) { 位置 = 3 }
            }
        }
    }

    当 (位置 < 长) {
        定义 c = 字节取(源码, 位置)
        定义 可变 已处理 = 0
        定义 可变 _解码码点 = 0
        定义 可变 _解码步长 = 1

        // ASCII空白
        如果 (已处理 == 0 且 (c == 字符_空格 或 c == 字符_制表 或 c == 字符_回车)) {
            位置 = 位置 + 1
            列 = 列 + 1
            已处理 = 1
        }
        如果 (已处理 == 0 且 c == 字符_换行) {
            位置 = 位置 + 1
            行 = 行 + 1
            列 = 1
            已处理 = 1
        }

        // ── 注释 ── (// 和 /* */ 保留兼容, 新增中文原生: 注：行注释)
        如果 (已处理 == 0 且 c == 字符_斜杠 且 位置 + 1 < 长) {
            定义 cn = 字节取(源码, 位置 + 1)
            如果 (cn == 字符_斜杠) {
                // 单行注释 //
                位置 = 位置 + 2
                当 (位置 < 长 且 字节取(源码, 位置) != 字符_换行) { 位置 = 位置 + 1 }
                已处理 = 1
            }
            如果 (已处理 == 0 且 cn == 字符_星号) {
                // 块注释 /* */
                位置 = 位置 + 2
                定义 可变 深 = 1
                当 (位置 + 1 < 长 且 深 > 0) {
                    定义 bc = 字节取(源码, 位置)
                    定义 bn = 字节取(源码, 位置 + 1)
                    如果 (bc == 字符_星号 且 bn == 字符_斜杠) { 深 = 深 - 1  位置 = 位置 + 2 }
                    否则 如果 (bc == 字符_斜杠 且 bn == 字符_星号) { 深 = 深 + 1  位置 = 位置 + 2 }
                    否则 {
                        如果 (bc == 字符_换行) { 行 = 行 + 1  列 = 0 }
                        位置 = 位置 + 1
                        列 = 列 + 1
                    }
                }
                已处理 = 1
            }
        }
        // UTF-8多字节分流层 (创新架构: 解码码点后精确分流)
        // c>127表示UTF-8多字节序列起始,必须解码完整码点才能判断身份
        如果 (已处理 == 0 且 c > 127) {
            定义 _解码 = _UTF8码点(源码, 位置)
            定义 _cp = _UTF8取码点(_解码)
            定义 _步 = _UTF8取字节数(_解码)
            _解码码点 = _cp
            _解码步长 = _步
            // 全角空白: 中文全角空格(U+3000)、半角空格变体(U+2002)
            如果 (_cp == 12288 或 _cp == 8194) {
                位置 = 位置 + _步
                列 = 列 + 1
                已处理 = 1
            }
            // 中文行注释: 注：或 注: 开头到行尾
            如果 (已处理 == 0 且 _cp == 27880 且 位置 + _步 < 长) {
                定义 _下解码 = _UTF8码点(源码, 位置 + _步)
                定义 _下cp = _UTF8取码点(_下解码)
                如果 (_下cp == 中文码_冒号 或 _下cp == 58) {
                    位置 = 位置 + _步 + _UTF8取字节数(_下解码)
                    当 (位置 < 长 且 字节取(源码, 位置) != 字符_换行) { 位置 = 位置 + 1 }
                    已处理 = 1
                }
            }
            // 全角标点: （）｛｝【】，。；：「」等
            如果 (已处理 == 0) {
                定义 _标点结果 = _词法_全角码点(标记列, _cp, 行, 列)
                如果 (_标点结果 > 0) {
                    位置 = 位置 + _步
                    列 = 列 + 1
                    已处理 = 1
                }
            }
            // 中文弯引号字符串: "..." 和 '...'
            如果 (已处理 == 0 且 (_cp == 8220 或 _cp == 8216)) {
                // 落入下方字符串处理(c==8220/8216分支不再需要,但保持兼容)
                // 不设已处理,让后续字符串分支用c>127特殊路径
            }
            // 其余中文字符: 进入标识符扫描(不设已处理,落入下方标识符分支)
        }

        // 数字
        如果 (已处理 == 0 且 c >= 字符_零 且 c <= 字符_九) {
            定义 数起行 = 行
            定义 数起列 = 列
            定义 可变 值 = 0
            定义 可变 是十六 = 0
            如果 (c == 字符_零 且 位置 + 1 < 长) {
                定义 nx = 字节取(源码, 位置 + 1)
                如果 (nx == 字符_小写x 或 nx == 字符_大写X) {
                    是十六 = 1
                    位置 = 位置 + 2
                    列 = 列 + 2
                    定义 可变 扫hex = 1
                    当 (位置 < 长 且 扫hex == 1) {
                        定义 h = 字节取(源码, 位置)
                        如果 (h >= 字符_零 且 h <= 字符_九) { 值 = 值 * 16 + h - 字符_零  位置 = 位置 + 1  列 = 列 + 1 }
                        否则 如果 (h >= 字符_小写a 且 h <= 字符_小写f) { 值 = 值 * 16 + h - 87  位置 = 位置 + 1  列 = 列 + 1 }
                        否则 如果 (h >= 字符_大写A 且 h <= 字符_大写F) { 值 = 值 * 16 + h - 55  位置 = 位置 + 1  列 = 列 + 1 }
                        否则 { 扫hex = 0 }
                    }
                    追加(标记列, [词法_浮点, 值, 数起行, 数起列])
                }
            }
            如果 (是十六 == 0) {
                定义 可变 扫dec = 1
                当 (位置 < 长 且 扫dec == 1) {
                    定义 d = 字节取(源码, 位置)
                    如果 (d >= 字符_零 且 d <= 字符_九) { 值 = 值 * 10 + d - 字符_零  位置 = 位置 + 1  列 = 列 + 1 }
                    否则 { 扫dec = 0 }
                }
                // 浮点检测
                如果 (位置 < 长 且 字节取(源码, 位置) == 字符_句点 且 位置 + 1 < 长 且 字节取(源码, 位置 + 1) >= 字符_零 且 字节取(源码, 位置 + 1) <= 字符_九) {
                    位置 = 位置 + 1
                    列 = 列 + 1
                    定义 可变 小数值 = 0
                    定义 可变 小数位 = 0
                    定义 可变 扫frac = 1
                    当 (位置 < 长 且 扫frac == 1) {
                        定义 fd = 字节取(源码, 位置)
                        如果 (fd >= 字符_零 且 fd <= 字符_九) { 小数值 = 小数值 * 10 + fd - 字符_零  小数位 = 小数位 + 1  位置 = 位置 + 1  列 = 列 + 1 } 否则 { 扫frac = 0 }
                    }
                    追加(标记列, [词法_插值串, 值, 数起行, 数起列, 小数值, 小数位])
                } 否则 {
                    追加(标记列, [词法_整数, 值, 数起行, 数起列])
                }
            }
            已处理 = 1
        }

        // 字符串(双引号)
        如果 (已处理 == 0 且 (c == 字符_双引号 或 _解码码点 == 8220)) {
            定义 串起行 = 行
            定义 串起列 = 列
            定义 可变 结束引号 = 34
            如果 (_解码码点 == 8220) { 结束引号 = 8221  位置 = 位置 + _解码步长 } 否则 { 位置 = 位置 + 1 }
            列 = 列 + 1
            定义 可变 内容 = ""
            定义 可变 扫串 = 1
            当 (位置 < 长 且 扫串 == 1) {
                定义 sc = 字节取(源码, 位置)
                // 弯引号结束检测: 需要UTF-8解码
                如果 (结束引号 > 127 且 sc > 127) {
                    定义 _sc解 = _UTF8码点(源码, 位置)
                    如果 (_UTF8取码点(_sc解) == 结束引号) { 位置 = 位置 + _UTF8取字节数(_sc解)  列 = 列 + 1  扫串 = 0 }
                    否则 { 内容 = 内容 + 子串(源码, 位置, 1)  位置 = 位置 + 1 }
                }
                否则 如果 (sc == 结束引号) { 位置 = 位置 + 1  列 = 列 + 1  扫串 = 0 }
                否则 如果 (sc == 字符_反斜杠 且 位置 + 1 < 长) {
                    定义 转 = 字节取(源码, 位置 + 1)
                    如果 (转 == 字符_小写n) { 内容 = 内容 + "\n" }
                    否则 如果 (转 == 字符_小写t) { 内容 = 内容 + "\t" }
                    否则 如果 (转 == 字符_小写r) { 内容 = 内容 + "\r" }
                    否则 如果 (转 == 字符_反斜杠) { 内容 = 内容 + "\\" }
                    否则 如果 (转 == 字符_双引号) { 内容 = 内容 + "\"" }
                    否则 如果 (转 == 字符_零) { 内容 = 内容 + "\0" }
                    否则 { 内容 = 内容 + 子串(源码, 位置 + 1, 1) }
                    位置 = 位置 + 2
                    列 = 列 + 2
                } 否则 {
                    内容 = 内容 + 子串(源码, 位置, 1)
                    如果 (sc == 字符_换行) { 行 = 行 + 1  列 = 1 } 否则 { 列 = 列 + 1 }
                    位置 = 位置 + 1
                }
            }
            定义 可变 _稳定内容 = ""
            定义 可变 _稳定i = 0
            定义 _稳定n = 字节长度(内容)
            当 (_稳定i < _稳定n) {
                _稳定内容 = 字符串拼接(_稳定内容, 字符(字节取(内容, _稳定i)))
                _稳定i = _稳定i + 1
            }
            追加(标记列, [词法_字串, _稳定内容, 串起行, 串起列])
            已处理 = 1
        }

        // 字符串(单引号)
        如果 (已处理 == 0 且 (c == 字符_单引号 或 _解码码点 == 8216)) {
            定义 串起行 = 行
            定义 串起列 = 列
            定义 可变 结束引号 = 39
            如果 (_解码码点 == 8216) { 结束引号 = 8217  位置 = 位置 + _解码步长 } 否则 { 位置 = 位置 + 1 }
            列 = 列 + 1
            定义 可变 内容 = ""
            定义 可变 扫串 = 1
            当 (位置 < 长 且 扫串 == 1) {
                定义 sc = 字节取(源码, 位置)
                如果 (结束引号 > 127 且 sc > 127) {
                    定义 _sc解 = _UTF8码点(源码, 位置)
                    如果 (_UTF8取码点(_sc解) == 结束引号) { 位置 = 位置 + _UTF8取字节数(_sc解)  列 = 列 + 1  扫串 = 0 }
                    否则 { 内容 = 内容 + 子串(源码, 位置, 1)  位置 = 位置 + 1 }
                }
                否则 如果 (sc == 结束引号) { 位置 = 位置 + 1  列 = 列 + 1  扫串 = 0 }
                否则 如果 (sc == 字符_反斜杠 且 位置 + 1 < 长) {
                    定义 转 = 字节取(源码, 位置 + 1)
                    如果 (转 == 字符_小写n) { 内容 = 内容 + "\n" }
                    否则 如果 (转 == 字符_小写t) { 内容 = 内容 + "\t" }
                    否则 如果 (转 == 字符_反斜杠) { 内容 = 内容 + "\\" }
                    否则 如果 (转 == 字符_单引号) { 内容 = 内容 + "\'" }
                    否则 { 内容 = 内容 + 子串(源码, 位置 + 1, 1) }
                    位置 = 位置 + 2
                    列 = 列 + 2
                } 否则 {
                    内容 = 内容 + 子串(源码, 位置, 1)
                    如果 (sc == 字符_换行) { 行 = 行 + 1  列 = 1 } 否则 { 列 = 列 + 1 }
                    位置 = 位置 + 1
                }
            }
            定义 可变 _稳定内容2 = ""
            定义 可变 _稳定i2 = 0
            定义 _稳定n2 = 字节长度(内容)
            当 (_稳定i2 < _稳定n2) {
                _稳定内容2 = 字符串拼接(_稳定内容2, 字符(字节取(内容, _稳定i2)))
                _稳定i2 = _稳定i2 + 1
            }
            追加(标记列, [词法_字串, _稳定内容2, 串起行, 串起列])
            已处理 = 1
        }

        // 标识符/关键字
        // UTF-8高字节(>127)均属多字节序列(中文等), 作为标识符字符接受
        如果 (已处理 == 0 且 ((c >= 字符_大写A 且 c <= 字符_大写Z) 或 (c >= 字符_小写a 且 c <= 字符_小写z) 或 c == 字符_下划线 或 c > 127)) {
            定义 标起行 = 行
            定义 标起列 = 列
            定义 起始 = 位置
            定义 可变 扫标 = 1
            当 (位置 < 长 且 扫标 == 1) {
                定义 ic = 字节取(源码, 位置)
                如果 ((ic >= 字符_大写A 且 ic <= 字符_大写Z) 或 (ic >= 字符_小写a 且 ic <= 字符_小写z) 或 (ic >= 字符_零 且 ic <= 字符_九) 或 ic == 字符_下划线 或 ic > 127) {
                    位置 = 位置 + 1
                    列 = 列 + 1
                } 否则 { 扫标 = 0 }
            }
            定义 名称 = 子串(源码, 起始, 位置 - 起始)
            // 中文数字字面量优先: 一二三...万亿 → 整数
            定义 中数 = _解析中文数字(名称)
            如果 (中数 >= 0) { 追加(标记列, [词法_整数, 中数, 标起行, 标起列]) }
            否则 { 定义 kw = 前端_查关键字(名称)
            如果 (kw > 0) { 追加(标记列, [kw, 名称, 标起行, 标起列]) }
            否则 { 追加(标记列, [20, 名称, 标起行, 标起列]) } }
            已处理 = 1
        }

        // 运算符/标点
        如果 (已处理 == 0) {
            定义 可变 c2 = 0
            如果 (位置 + 1 < 长) { c2 = 字节取(源码, 位置 + 1) }
            定义 已消费 = _词法_运算符(标记列, c, c2, 行, 列)
            如果 (已消费 > 0) { 位置 = 位置 + 已消费  列 = 列 + 已消费 }
            否则 { 位置 = 位置 + 1  列 = 列 + 1 }
        }
    }

    追加(标记列, [0, 0, 行, 列])
    返回 标记列
}

// 解析器 — 词元列表→AST (System 2: 100+节点类型, 扁平字段)
// 匹配 编译器/规划/核心/常量.nova + 代码生成器.nova 格式

// 解析器全局状态
定义 可变 _解析_标记组 = []
定义 可变 _解析_位置 = 0
定义 可变 _解析_长度 = 0

函数 _语法_结束() { 返回 _解析_位置 >= _解析_长度 }

函数 _语法_当前() {
    如果 (_解析_位置 >= _解析_长度) { 返回 [0, 0, 0] }
    返回 _解析_标记组[_解析_位置]
}

函数 _语法_推进() {
    定义 标记 = _语法_当前()
    如果 (_解析_位置 < _解析_长度) { _解析_位置 = _解析_位置 + 1 }
    返回 标记
}

函数 _语法_类型() { 返回 _语法_当前()[0] }

函数 _语法_预览类型(偏移) {
    定义 索引 = _解析_位置 + 偏移
    如果 (索引 < 0 或 索引 >= _解析_长度) { 返回 0 }
    返回 _解析_标记组[索引][0]
}

函数 _语法_期望(期望) {
    如果 (_语法_当前()[0] == 期望) { _解析_位置 = _解析_位置 + 1  返回 1 }
    返回 0
}

// token→运算符字符串
函数 _标记转运算(t) {
    如果 (t == 标记_加) { 返回 "+" }
    如果 (t == 标记_减) { 返回 "-" }
    如果 (t == 标记_乘) { 返回 "*" }
    如果 (t == 标记_除) { 返回 "/" }
    如果 (t == 标记_余) { 返回 "%" }
    如果 (t == 标记_等等) { 返回 "==" }
    如果 (t == 标记_不等) { 返回 "!=" }
    如果 (t == 标记_小于) { 返回 "<" }
    如果 (t == 标记_大于) { 返回 ">" }
    如果 (t == 标记_小等) { 返回 "<=" }
    如果 (t == 标记_大等) { 返回 ">=" }
    如果 (t == 标记_且) { 返回 "&&" }
    如果 (t == 标记_或) { 返回 "||" }
    如果 (t == 标记_位与) { 返回 "&" }
    如果 (t == 标记_位或) { 返回 "|" }
    如果 (t == 标记_位异或) { 返回 "^" }
    如果 (t == 标记_左移) { 返回 "<<" }
    如果 (t == 标记_右移) { 返回 ">>" }
    返回 "+"
}

// 表达式 (Pratt)

// 中文算术/比较/逻辑词 → 等效运算符token (仅在表达式二元运算位置识别)
函数 _p_中文算术类型() {
    如果 (_语法_类型() != 标记_标识符) { 返回 0 }
    定义 v = _语法_当前()[1]
    如果 (v == "加") { 返回 标记_加 }
    如果 (v == "减") { 返回 标记_减 }
    如果 (v == "乘") { 返回 标记_乘 }
    如果 (v == "除") { 返回 标记_除 }
    如果 (v == "余") { 返回 标记_余 }
    如果 (v == "等于") { 返回 标记_等等 }
    如果 (v == "不等于") { 返回 标记_不等 }
    如果 (v == "小于") { 返回 标记_小于 }
    如果 (v == "大于") { 返回 标记_大于 }
    如果 (v == "小于等于") { 返回 标记_小等 }
    如果 (v == "大于等于") { 返回 标记_大等 }
    返回 0
}

函数 _语法_二元优先级(t) {
    如果 (t == 标记_或) { 返回 1 }
    如果 (t == 标记_且) { 返回 2 }
    如果 (t == 标记_位或) { 返回 3 }
    如果 (t == 标记_位异或) { 返回 4 }
    如果 (t == 标记_位与) { 返回 5 }
    如果 (t == 标记_等等 或 t == 标记_不等) { 返回 6 }
    如果 (t == 标记_小于 或 t == 标记_大于 或 t == 标记_小等 或 t == 标记_大等) { 返回 7 }
    如果 (t == 标记_左移 或 t == 标记_右移) { 返回 8 }
    如果 (t == 标记_加 或 t == 标记_减) { 返回 9 }
    如果 (t == 标记_乘 或 t == 标记_除 或 t == 标记_余) { 返回 10 }
    返回 0
}

函数 _语法_表达式() { 返回 _语法_二元(0) }

函数 _语法_二元(最小) {
    定义 可变 左 = _语法_一元()
    当 (_语法_结束() == 0) {
        定义 可变 t = _语法_类型()
        // 中文算术/比较词上下文感知: 仅在二元运算符位置识别
        定义 中t = _p_中文算术类型()
        如果 (中t > 0) { t = 中t }
        定义 优先级 = _语法_二元优先级(t)
        如果 (优先级 == 0 或 优先级 < 最小) { 返回 左 }
        _语法_推进()
        定义 右 = _语法_二元(优先级 + 1)
        左 = [节点_二元, _标记转运算(t), 左, 右]
    }
    返回 左
}

函数 _语法_一元() {
    定义 t = _语法_类型()
    如果 (t == 标记_减) { _语法_推进()  返回 [节点_二元, "-", [标记_数字, 0], _语法_一元()] }
    如果 (t == 标记_非) { _语法_推进()  返回 [节点_一元正, _语法_一元()] }
    如果 (t == 标记_位取反) { _语法_推进()  返回 [节点_一元负, _语法_一元()] }
    返回 _语法_后缀()
}

函数 _语法_后缀() {
    定义 可变 表达式 = _语法_基元()
    当 (_语法_结束() == 0) {
        定义 t = _语法_类型()
        如果 (t == 标记_左括) {
            // 调用 (
            定义 可变 名称 = ""
            如果 (表达式[0] == 标记_名称) { 名称 = 表达式[1] }
            否则 如果 (表达式[0] == 标记_连接词) { 名称 = 表达式[2] }
            _语法_推进()
            定义 可变 参数 = []
            当 (_语法_类型() != 标记_右括 且 _语法_结束() == 0) {
                追加(参数, _语法_表达式())
                _语法_期望(标记_逗号)
            }
            _语法_期望(标记_右括)
            表达式 = [节点_调用, 名称, 参数]
        } 否则 如果 (t == 标记_左方) {
            // 索引 [
            _语法_推进()
            定义 索引 = _语法_表达式()
            _语法_期望(标记_右方)
            表达式 = [节点_索引, 表达式, 索引]
        } 否则 如果 (t == 标记_点号) {
            // 成员 .
            _语法_推进()
            定义 标记 = _语法_推进()
            如果 (标记[0] == 标记_标识符 或 标记[0] >= 标记_定义) { 表达式 = [131, 表达式, 标记[1]] }
        } 否则 如果 (t == 标记_左花 且 表达式[0] == 标记_名称) {
            // 结构体 Name { f: v }
            定义 节名 = 表达式[1]
            _语法_推进()
            定义 可变 字段列 = []
            当 (_语法_类型() != 标记_右花 且 _语法_结束() == 0) {
                定义 首标记 = _语法_推进()
                定义 可变 函数名 = ""
                如果 (首标记[0] == 标记_标识符 或 首标记[0] >= 标记_定义) { 函数名 = 首标记[1] }
                _语法_期望(标记_冒号)
                追加(字段列, [函数名, _语法_表达式()])
                _语法_期望(标记_逗号)
            }
            _语法_期望(标记_右花)
            表达式 = [130, 节名, 字段列]
        } 否则 {
            返回 表达式
        }
    }
    返回 表达式
}

函数 _语法_基元() {
    定义 标记 = _语法_推进()
    定义 t = 标记[0]
    定义 v = 标记[1]

    如果 (t == 词法_整数 或 t == 词法_浮点) { 返回 [标记_数字, v] }
    如果 (t == 词法_插值串) { 返回 [节_浮点, v, 标记[4], 标记[5]] }
    如果 (t == 词法_字串) { 返回 [标记_字串, v] }
    如果 (t == 标记_真) { 返回 [标记_数字, 1] }
    如果 (t == 标记_假) { 返回 [标记_数字, 0] }
    如果 (t == 标记_空) { 返回 [节点_空字面量] }
    如果 (t == 标记_标识符) { 返回 [标记_名称, v] }
    如果 (t == 标记_如果) {
        _解析_位置 = _解析_位置 - 1
        返回 _语法_如果()
    }
    如果 (t >= 标记_定义 且 t <= 标记_抛出 且 t != 标记_建 且 t != 标记_函数) { 返回 [标记_名称, v] }

    如果 (t == 标记_左括) { 定义 e = _语法_表达式()  _语法_期望(标记_右括)  返回 e }

    如果 (t == 标记_左方) {
        定义 可变 项 = []
        当 (_语法_类型() != 标记_右方 且 _语法_结束() == 0) { 追加(项, _语法_表达式())  _语法_期望(标记_逗号) }
        _语法_期望(标记_右方)
        返回 [节点_赋值, 项]
    }

    如果 (t == 标记_建) {
        定义 下标记 = _语法_推进()
        定义 可变 节名 = ""
        如果 (下标记[0] == 标记_标识符 或 下标记[0] >= 标记_定义) { 节名 = 下标记[1] }
        定义 可变 字段列 = []
        如果 (_语法_类型() == 标记_左括) {
            _语法_推进()
            当 (_语法_类型() != 标记_右括 且 _语法_结束() == 0) { 追加(字段列, ["", _语法_表达式()])  _语法_期望(标记_逗号) }
            _语法_期望(标记_右括)
        } 否则 如果 (_语法_类型() == 标记_左花) {
            _语法_推进()
            当 (_语法_类型() != 标记_右花 且 _语法_结束() == 0) {
                定义 首标记 = _语法_推进()
                定义 可变 备选函数名 = ""
                如果 (首标记[0] == 标记_标识符 或 首标记[0] >= 标记_定义) { 备选函数名 = 首标记[1] }
                _语法_期望(标记_冒号)
                追加(字段列, [备选函数名, _语法_表达式()])
                _语法_期望(标记_逗号)
            }
            _语法_期望(标记_右花)
        }
        返回 [130, 节名, 字段列]
    }

    如果 (t == 标记_函数) {
        如果 (_语法_类型() == 标记_左括) {
            _语法_推进()
            定义 可变 参数 = []
            当 (_语法_类型() != 标记_右括 且 _语法_结束() == 0) {
                定义 前标记 = _语法_推进()
                如果 (前标记[0] == 标记_标识符 或 前标记[0] >= 标记_定义) { 追加(参数, 前标记[1]) }
                _语法_期望(标记_逗号)
            }
            _语法_期望(标记_右括)
            定义 体 = _语法_块()
            定义 可变 名 = 字符串拼接("__匿名函数_", 转字符串(计数(语法状态[6])))
            追加(语法状态[6], [120, 名, 参数, 体, 标记[2]])
            返回 [标记_名称, 名]
        }
    }

    返回 [标记_数字, 0]
}

// 语句

函数 _语法_块() {
    如果 (_语法_期望(标记_左花) == 0) { 返回 [] }
    定义 可变 语句列 = []
    当 (_语法_类型() != 标记_右花 且 _语法_结束() == 0) {
        _p_跳过文章分隔()
        如果 (_语法_类型() == 标记_右花 或 _语法_结束() != 0) { 继续 }
        定义 s = _语法_语句()
        如果 (s != 空) { 追加(语句列, s) }
    }
    _语法_期望(标记_右花)
    返回 语句列
}

函数 _p_block或单语句() {
    如果 (_语法_类型() == 标记_左花) { 返回 _语法_块() }
    如果 (_语法_类型() == 标记_冒号) {
        _语法_推进()
        _p_跳过文章分隔()
        定义 可变 语句列 = []
        定义 s = _语法_语句()
        如果 (s != 空) { 追加(语句列, s) }
        返回 语句列
    }
    定义 单句 = _语法_语句()
    如果 (单句 == 空) { 返回 [] }
    返回 [单句]
}

函数 _p_是文章分隔(t) {
    返回 t == 标记_逗号 或 t == 标记_分号
}

函数 _p_跳过文章分隔() {
    当 (_p_是文章分隔(_语法_类型())) { _语法_推进() }
}

函数 _p_跳过顺承前缀() {
    当 (_语法_类型() == 标记_顺序词) {
        _语法_推进()
        _p_跳过文章分隔()
    }
}

函数 _p_跳过后件连接() {
    _p_跳过文章分隔()
    如果 (_语法_类型() == 标记_连接词) { _语法_推进() }
    _p_跳过文章分隔()
}

函数 _语法_语句() {
    _p_跳过文章分隔()
    _p_跳过顺承前缀()
    _p_跳过文章分隔()
    定义 t = _语法_类型()
    如果 (t == 标记_函数) { 返回 _语法_函数() }
    如果 (t == 标记_定义) { 返回 _语法_变量() }
    如果 (t == 标记_返回) { 返回 _语法_返回() }
    如果 (t == 标记_如果) { 返回 _语法_如果() }
    如果 (t == 标记_当) { 返回 _语法_循环() }
    如果 (t == 标记_结构) { 返回 _语法_结构() }
    如果 (t == 标记_中断) { 定义 _行 = _语法_当前()[2]  _语法_推进()  返回 [136, _行] }
    如果 (t == 标记_继续) { 定义 _行 = _语法_当前()[2]  _语法_推进()  返回 [137, _行] }
    如果 (t == 标记_导入) { _语法_推进()  _语法_推进()  返回 空 }
    如果 (t == 标记_尝试) { 返回 _语法_尝试() }
    如果 (t == 标记_汇编) { 返回 _语法_汇编() }
    如果 (t == 标记_抛出) { 定义 _行 = _语法_当前()[2]  _语法_推进()  返回 [162, _语法_表达式(), _行] }
    如果 (t == 标记_循环) { 返回 _语法_遍历() }
    如果 (t == 标记_匹配 且 _语法_预览类型(1) == 标记_左括) { 返回 _语法_匹配() }
    如果 (t == 标记_右花 或 t == 0) { _语法_推进()  返回 空 }
    返回 _语法_表达式语句()
}

函数 _语法_函数() {
    定义 _行 = _语法_当前()[2]
    _语法_推进()
    定义 下标记 = _语法_推进()
    定义 可变 名称 = ""
    如果 (下标记[0] == 标记_标识符 或 下标记[0] >= 标记_定义) { 名称 = 下标记[1] }
    _语法_期望(标记_左括)
    定义 可变 参数 = []
    当 (_语法_类型() != 标记_右括 且 _语法_结束() == 0) {
        定义 前标记 = _语法_推进()
        如果 (前标记[0] == 标记_标识符 或 前标记[0] >= 标记_定义) { 追加(参数, 前标记[1]) }
        _语法_期望(标记_逗号)
    }
    _语法_期望(标记_右括)
    返回 [120, 名称, 参数, _语法_块(), _行]
}

函数 _语法_变量() {
    定义 _行 = _语法_当前()[2]
    _语法_推进()
    定义 可变 是可变 = 0
    如果 (_语法_类型() == 标记_可变) {
        _语法_推进()
        是可变 = 1
    }
    定义 下标记 = _语法_推进()
    定义 可变 名称 = ""
    如果 (下标记[0] == 标记_标识符 或 下标记[0] >= 标记_定义) { 名称 = 下标记[1] }
    // 保留字检查: 若名称为空 (因使用了 或/与/非/且 等保留字作变量名), 报错
    如果 (名称 == "") {
        定义 _行号文本 = 转字符串(_行)
        打印文本(字符串拼接("错误: 变量名冲突保留字 (行 ", 字符串拼接(_行号文本, 字符串拼接("): 不能使用 '", 字符串拼接(下标记[1], "' 作为变量名. 考虑用下划线前缀如 _或 _与 _非")))))
    }
    定义 可变 初值 = [标记_数字, 0]
    如果 (_语法_期望(标记_赋值) == 1 或 (_语法_类型() == 标记_标识符 且 _语法_当前()[1] == "为" 且 _语法_推进())) { 初值 = _语法_表达式() }
    返回 [110, 名称, 初值, 是可变, _行]
}

函数 _语法_返回() {
    定义 _行 = _语法_当前()[2]
    _语法_推进()
    如果 (_语法_类型() == 标记_右花 或 _语法_类型() == 0) { 返回 [114, [标记_数字, 0], _行] }
    返回 [114, _语法_表达式(), _行]
}

函数 _语法_如果() {
    定义 _行 = _语法_当前()[2]
    _语法_推进()
    定义 可变 条件 = [标记_数字, 0]
    如果 (_语法_期望(标记_左括) == 1) {
        条件 = _语法_表达式()
        _语法_期望(标记_右括)
    } 否则 {
        条件 = _语法_表达式()
    }
    _p_跳过后件连接()
    定义 真支 = _p_block或单语句()
    定义 可变 假支 = []
    如果 (_语法_类型() == 标记_否则) {
        _语法_推进()
        _p_跳过文章分隔()
        如果 (_语法_类型() == 标记_如果) { 假支 = [_语法_如果()] }
        否则 { 假支 = _p_block或单语句() }
    }
    返回 [112, 条件, 真支, 假支, _行]
}

函数 _语法_循环() {
    定义 _行 = _语法_当前()[2]
    _语法_推进()
    定义 可变 条件 = [标记_数字, 0]
    如果 (_语法_期望(标记_左括) == 1) {
        条件 = _语法_表达式()
        _语法_期望(标记_右括)
    } 否则 {
        条件 = _语法_表达式()
    }
    _p_跳过后件连接()
    返回 [113, 条件, _p_block或单语句(), _行]
}

函数 _语法_结构() {
    _语法_推进()
    定义 下标记 = _语法_推进()
    定义 可变 名称 = ""
    如果 (下标记[0] == 标记_标识符 或 下标记[0] >= 标记_定义) { 名称 = 下标记[1] }
    定义 可变 字段 = []
    如果 (_语法_期望(标记_左括) == 1) {
        当 (_语法_类型() != 标记_右括 且 _语法_结束() == 0) {
            定义 首标记 = _语法_推进()
            如果 (首标记[0] == 标记_标识符 或 首标记[0] >= 标记_定义) { 追加(字段, 首标记[1]) }
            _语法_期望(标记_逗号)
        }
        _语法_期望(标记_右括)
    } 否则 如果 (_语法_期望(标记_左花) == 1) {
        当 (_语法_类型() != 标记_右花 且 _语法_结束() == 0) {
            定义 首标记 = _语法_推进()
            如果 (首标记[0] == 标记_标识符 或 首标记[0] >= 标记_定义) { 追加(字段, 首标记[1]) }
            _语法_期望(标记_逗号)
        }
        _语法_期望(标记_右花)
    }
    如果 (名称 != "") {
        字典设(结构体表, 名称, 字段)
        定义 可变 _函返索引 = 0
        当 (_函返索引 < 计数(字段)) {
            如果 (字典有(字段注册表, 字段[_函返索引]) == 假) {
                字典设(字段注册表, 字段[_函返索引], _函返索引)
            }
            _函返索引 = _函返索引 + 1
        }
    }
    返回 空
}

函数 _语法_尝试() {
    定义 _行 = _语法_当前()[2]
    _语法_推进()
    定义 试体 = _语法_块()
    定义 可变 捕名 = "__错误"
    定义 可变 得体 = []
    如果 (_语法_类型() == 标记_得) {
        _语法_推进()
        如果 (_语法_类型() == 标记_左括) {
            _语法_推进()
            定义 值标记 = _语法_推进()
            如果 (值标记[0] == 标记_标识符 或 值标记[0] >= 标记_定义) { 捕名 = 值标记[1] }
            _语法_期望(标记_右括)
        }
        得体 = _语法_块()
    }
    返回 [160, 试体, 捕名, 得体, _行]
}

函数 _语法_汇编() {
    定义 _行 = _语法_当前()[2]
    _语法_推进()
    如果 (_语法_期望(标记_左花) == 0) { 返回 [164, [], _行] }
    定义 可变 文本列 = []
    当 (_语法_类型() != 标记_右花 且 _语法_结束() == 0) {
        _p_跳过文章分隔()
        如果 (_语法_类型() == 标记_右花 或 _语法_结束() != 0) { 续 }
        定义 标记 = _语法_推进()
        如果 (标记[0] == 词法_字串) {
            定义 _原文 = 标记[1]
            定义 可变 _稳定文 = ""
            定义 可变 _i = 0
            定义 _n = 字节长度(_原文)
            当 (_i < _n) {
                _稳定文 = 字符串拼接(_稳定文, 字符(字节取(_原文, _i)))
                _i = _i + 1
            }
            追加(文本列, _稳定文)
        }
        _p_跳过文章分隔()
    }
    _语法_期望(标记_右花)
    返回 [164, 文本列, _行]
}

函数 _语法_遍历() {
    定义 _行 = _语法_当前()[2]
    _语法_推进()
    _语法_期望(标记_左括)
    // 检测 foreach: 每 (变量 在 集合)
    如果 (_语法_类型() == 标记_标识符) {
        定义 可能变量 = _语法_当前()[1]
        定义 保存位 = _解析_位置
        _语法_推进()
        如果 (_语法_类型() == 标记_标识符 且 字符串相等(_语法_当前()[1], "在")) {
            _语法_推进()
            定义 集合 = _语法_表达式()
            _语法_期望(标记_右括)
            返回 [134, 可能变量, 集合, _语法_块(), _行]
        }
        _解析_位置 = 保存位
    }
    定义 条件 = _语法_表达式()
    _语法_期望(标记_右括)
    返回 [113, 条件, _语法_块(), _行]
}

函数 _语法_匹配() {
    定义 _行 = _语法_当前()[2]
    _语法_推进()
    _语法_期望(标记_左括)
    定义 目标 = _语法_表达式()
    _语法_期望(标记_右括)
    _语法_期望(标记_左花)
    定义 可变 分支列 = []
    当 (_语法_类型() != 标记_右花 且 _语法_结束() == 0) {
        如果 (_语法_类型() == 标记_默认) {
            _语法_推进()
            _语法_期望(标记_冒号)
            追加(分支列, [空, _语法_块()])
        } 否则 {
            定义 模式 = _语法_表达式()
            _语法_期望(标记_冒号)
            追加(分支列, [模式, _语法_块()])
        }
    }
    _语法_期望(标记_右花)
    返回 [135, 目标, 分支列, _行]
}

函数 _语法_表达式语句() {
    定义 _行 = _语法_当前()[2]
    定义 表达式 = _语法_表达式()
    // = 赋值 或 中文「为」赋值
    如果 (_语法_类型() == 标记_赋值 或 (_语法_类型() == 标记_标识符 且 _语法_当前()[1] == "为")) {
        _语法_推进()
        定义 值 = _语法_表达式()
        如果 (表达式[0] == 标记_名称) { 返回 [111, 表达式[1], 值, _行] }
        如果 (表达式[0] == 节点_索引) {
            定义 基址 = 表达式[1]
            如果 (基址[0] == 标记_名称) { 返回 [116, 基址[1], 表达式[2], 值, _行] }
            返回 [141, 基址, 表达式[2], 值, _行]
        }
        如果 (表达式[0] == 标记_连接词) { 返回 [132, 表达式[1], 表达式[2], 值, _行] }
        返回 [115, 表达式, _行]
    }
    如果 (_语法_类型() == 标记_加等) {
        _语法_推进()
        定义 值 = _语法_表达式()
        如果 (表达式[0] == 标记_名称) { 返回 [111, 表达式[1], [节点_二元, "+", 表达式, 值], _行] }
        返回 [115, 表达式, _行]
    }
    如果 (_语法_类型() == 标记_减等) {
        _语法_推进()
        定义 值 = _语法_表达式()
        如果 (表达式[0] == 标记_名称) { 返回 [111, 表达式[1], [节点_二元, "-", 表达式, 值], _行] }
        返回 [115, 表达式, _行]
    }
    返回 [115, 表达式, _行]
}

// 解析入口
函数 前端_解析_程序(词表) {
    如果 (词表 == 空 或 计数(词表) == 0) { 返回 [[], []] }
    _解析_标记组 = 词表
    _解析_位置 = 0
    _解析_长度 = 计数(词表)
    语法状态[5] = 0

    定义 可变 函数列 = []
    定义 可变 主体 = []

    当 (_语法_结束() == 0 且 _语法_类型() != 0) {
        _p_跳过文章分隔()
        如果 (_语法_结束() != 0 或 _语法_类型() == 0) { 继续 }
        定义 t = _语法_类型()
        如果 (t == 标记_函数) {
            定义 f = _语法_函数()
            如果 (f != 空) { 追加(函数列, f) }
        } 否则 {
            定义 s = _语法_语句()
            如果 (s != 空) { 追加(主体, s) }
        }
    }

    // 合并匿名函数
    定义 可变 li = 0
    当 (li < 计数(语法状态[6])) {
        追加(函数列, 语法状态[6][li])
        li = li + 1
    }

    返回 [函数列, 主体]
}

// nop替换: 提供真实返回值避免崩溃
// 发射_权威运行时(0) 已移至自动生成的 前端入口_运行时种子.nova
函数 发射_权威wrappers() {
    定义 可变 包装列表 = []
    定义 可变 i = 0
    当 (i < 11) {
        追加(包装列表, 0)
        i = i + 1
    }
    返回 包装列表
}

// ELF随机访问写入: list语义 buf[位置]=val
函数 _elf写(buf, 位置, val) { buf[位置] = val & 255 }
函数 _elf写16(buf, 位置, val) {
    定义 可变 v = val
    如果 (v < 0) { v = v + 65536 }
    buf[位置] = v & 255
    buf[位置 + 1] = (v / 256) & 255
}
函数 _elf写32(buf, 位置, val) {
    定义 可变 v = val
    如果 (v < 0) { v = v + 4294967296 }
    buf[位置] = v & 255
    buf[位置 + 1] = (v / 256) & 255
    buf[位置 + 2] = (v / 65536) & 255
    buf[位置 + 3] = (v / 16777216) & 255
}
函数 _elf写64(buf, 位置, val) {
    定义 可变 v = val
    定义 可变 i = 0
    当 (i < 8) {
        定义 b = v & 255
        buf[位置 + i] = b
        v = (v - b) / 256
        i = i + 1
    }
}

// 写二进制: 列表转字节后写入文件
函数 写二进制(文件名, 数据, 大小) { 返回 写文件(文件名, 列表转字节(数据), 大小) }

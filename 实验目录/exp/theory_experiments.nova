        [760, 700, 220, 780, 740, 720],
        [700, 660, 240, 740, 700, 680],
        [660, 620, 260, 760, 720, 700],
        [780, 720, 180, 820, 780, 760],
        [680, 640, 220, 780, 740, 700]
    ]
    定义 可变 旧总分 = 0
    定义 可变 新总分 = 0
    定义 可变 通过数 = 0
    定义 可变 总数 = 0
    定义 可变 i = 0
    当 (i < 计数(用例)) {
        定义 c = 用例[i]
        定义 旧分 = 基线_梯度搜索质量(c[0], c[1], c[2])
        定义 新分 = 原创_信息几何搜索质量(c[0], c[3], c[4], c[5], c[1], c[2])
        旧总分 = 旧总分 + 旧分
        新总分 = 新总分 + 新分
        如果 (新分 > 旧分) { 通过数 = 通过数 + 1 }
        总数 = 总数 + 1
        i = i + 1
    }
    定义 Fisher网格 = [360, 460, 580, 700, 760, 820]
    定义 可变 j = 0
    当 (j < 计数(Fisher网格)) {
        定义 梯度稳定 = 520
        定义 收敛速度 = 620
        定义 扰动 = 180
        定义 旧分 = 基线_梯度搜索质量(梯度稳定, 收敛速度, 扰动)
        定义 新分 = 原创_信息几何搜索质量(梯度稳定, Fisher网格[j], 620, 600, 收敛速度, 扰动)
        旧总分 = 旧总分 + 旧分
        新总分 = 新总分 + 新分
        如果 (新分 > 旧分) { 通过数 = 通过数 + 1 }
        总数 = 总数 + 1
        j = j + 1
    }
    返回 实验_汇总记录("信息几何搜索", 旧总分, 新总分, 通过数, 总数)
}

函数 实验_运行自指验证组() {
    定义 用例 = [
        [760, 700, 220, 780, 820, 760, 740],
        [700, 660, 240, 740, 780, 720, 700],
        [660, 620, 260, 760, 740, 700, 720]
    ]
    定义 可变 旧总分 = 0
    定义 可变 新总分 = 0
    定义 可变 通过数 = 0
    定义 可变 总数 = 0
    定义 可变 i = 0
    当 (i < 计数(用例)) {
        定义 c = 用例[i]
        定义 旧分 = 基线_语义保持质量(c[0], c[1], c[2])
        定义 新分 = 原创_自指验证质量(c[0], c[3], c[4], c[5], c[6], c[2])
        旧总分 = 旧总分 + 旧分
        新总分 = 新总分 + 新分
        如果 (新分 > 旧分) { 通过数 = 通过数 + 1 }
        总数 = 总数 + 1
        i = i + 1
    }
    定义 见证网格 = [300, 420, 540, 660, 720, 780]
    定义 可变 j = 0
    当 (j < 计数(见证网格)) {
        定义 语义等价 = 680
        定义 指纹一致 = 640
        定义 扰动 = 180
        定义 旧分 = 基线_语义保持质量(语义等价, 指纹一致, 扰动)
        定义 新分 = 原创_自指验证质量(620, 见证网格[j], 语义等价, 指纹一致, 620, 扰动)
        旧总分 = 旧总分 + 旧分
        新总分 = 新总分 + 新分
        如果 (新分 > 旧分) { 通过数 = 通过数 + 1 }
        总数 = 总数 + 1
        j = j + 1
    }
    返回 实验_汇总记录("自指验证", 旧总分, 新总分, 通过数, 总数)
}

函数 实验_运行全部() {
    定义 结果 = []
    追加(结果, 实验_运行记忆晶化组())
    追加(结果, 实验_运行意图势场组())
    追加(结果, 实验_运行双环学习组())
    追加(结果, 实验_运行认知几何组())
    追加(结果, 实验_运行意图锁定组())
    追加(结果, 实验_运行链式回溯组())
    追加(结果, 实验_运行认知检索组())
    追加(结果, 实验_运行自适应学习组())
    追加(结果, 实验_运行策略稳态组())
    追加(结果, 实验_运行演化闭环组())
    追加(结果, 实验_运行信息几何搜索组())
    追加(结果, 实验_运行自指验证组())
    返回 结果
}

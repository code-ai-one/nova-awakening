// §2 导航系统

函数 标签页_导航(标签ID, URL) {
    定义 tab = 标签页_查找(标签ID)
    如果 (tab == 空) { 返回 }

    tab.URL = URL
    tab.状态 = 标签状态_加载中
    tab.加载进度 = 0
    tab.安全 = 字符串前缀_浏览器(URL, "https://")

    // 添加到历史
    如果 (tab.历史位置 < 计数(tab.历史) - 1) {
        // 截断前进历史
        当 (计数(tab.历史) > tab.历史位置 + 1) {
            删除(tab.历史, 计数(tab.历史) - 1)
        }
    }
    追加(tab.历史, URL)
    tab.历史位置 = 计数(tab.历史) - 1

    // 记录全局历史
    如果 (计数(全局历史) >= 最大历史) { 删除(全局历史, 0) }
    追加(全局历史, [URL, 浏览器_时钟])

    // 启动页面加载管线
    页面_加载(tab, URL)
}

函数 标签页_后退(标签ID) {
    定义 tab = 标签页_查找(标签ID)
    如果 (tab == 空 || tab.历史位置 <= 0) { 返回 }
    tab.历史位置 = tab.历史位置 - 1
    页面_加载(tab, tab.历史[tab.历史位置])
}

函数 标签页_前进(标签ID) {
    定义 tab = 标签页_查找(标签ID)
    如果 (tab == 空 || tab.历史位置 >= 计数(tab.历史) - 1) { 返回 }
    tab.历史位置 = tab.历史位置 + 1
    页面_加载(tab, tab.历史[tab.历史位置])
}

函数 标签页_刷新(标签ID) {
    定义 tab = 标签页_查找(标签ID)
    如果 (tab == 空) { 返回 }
    页面_加载(tab, tab.URL)
}

// §3 页面加载管线

函数 页面_加载(tab, URL) {
    tab.加载进度 = 5
    内核调试("浏览器: 加载 " + URL)

    // 1. 域名解析
    tab.加载进度 = 10
    定义 IP = 浏览器_域名查询(URL)

    // 2. HTTP请求
    tab.加载进度 = 20
    定义 req = HTTP_创建请求(0, URL)  // GET
    定义 响应 = HTTP_发送(req)

    如果 (!响应.成功) {
        tab.状态 = 标签状态_错误
        tab.标题 = "加载失败"
        tab.加载进度 = 100
        返回
    }
    tab.加载进度 = 50

    // 3. HTML解析→DOM树
    tab.DOM根节点 = HTML_解析(响应.正文)
    tab.加载进度 = 70

    // 4. 提取标题
    tab.标题 = 页面_提取标题(tab.DOM根节点)

    // 5. CSS样式计算+布局
    页面_应用样式(tab.DOM根节点)
    tab.加载进度 = 85

    // 6. 渲染
    布局_计算(tab.DOM根节点, 0, 0, 渲染_宽, 渲染_高)
    tab.加载进度 = 100
    tab.状态 = 标签状态_完成

    // 7. AI分析页面(广告过滤/内容摘要)
    智能_分析页面(tab)

    内核调试("浏览器: 加载完成 '" + tab.标题 + "'")
}

函数 页面_提取标题(dom) {
    如果 (dom == 空) { 返回 "无标题" }
    定义 标题列表 = HTML_get元素sByTag(dom, 10)  // h1
    如果 (计数(标题列表) > 0) {
        返回 DOM_提取文本(标题列表[0])
    }
    返回 "无标题"
}

函数 页面_应用样式(节点) {
    如果 (节点 == 空) { 返回 }
    节点.样式 = CSS_默认样式(节点.标签)
    定义 可变 i = 0
    当 (i < 计数(节点.子节点)) {
        页面_应用样式(节点.子节点[i])
        i = i + 1
    }
}

// 域名_解析 定义在 网络/应用层/域名解析.nova
函数 浏览器_域名查询(URL) {
    // 委托给内核域名解析模块
    返回 "0.0.0.0"
}

// NovaOS 融合层 / 内核浏览器桥 / 网络适配
// 模块: 原生___内部协议处理_标记5壳层视觉增强
// 目标:
//  1) 统一 nova:// 内部协议到 Browser-终端壳层
//  2) 提供可演进的视觉增强系统(亮色/暗色/高对比/低动态)
//  3) 接入 AI 策略, 根据会话上下文动态调整壳层密度和信息层级
//  4) 输出可观测埋点, 支持商用运维
// 说明:
//  - 本文件不依赖外部版权CSS模板, 全部规则为 NovaOS 原生设计
//  - 使用函数化 CSS 片段拼接, 便于灰度发布

// §1 常量定义

定义 壳层主题_浅色 = 1
定义 壳层主题_深色 = 2
定义 壳层主题_高对比 = 3
定义 壳层主题_护眼 = 4

定义 壳层密度_紧凑 = 1
定义 壳层密度_标准 = 2
定义 壳层密度_宽松 = 3

定义 壳层动效_关闭 = 0
定义 壳层动效_低 = 1
定义 壳层动效_标准 = 2

定义 协议类型_未知 = 0
定义 协议类型_系统 = 1
定义 协议类型_AI = 2
定义 协议类型_多模态 = 3
定义 协议类型_语音 = 4
定义 协议类型_形象 = 5
定义 协议类型_诊断 = 6
定义 协议类型_设置 = 7
定义 协议类型_工作流 = 8

定义 路由策略_严格 = 1
定义 路由策略_兼容 = 2
定义 路由策略_实验 = 3

定义 最大参数数 = 32
定义 最大卡片数 = 24
定义 最大标签数 = 20
定义 最大埋点数 = 256

// §2 数据结构

结构 壳层视觉上下文 {
    主题,
    密度,
    动效级别,
    字号缩放,            // Q10
    圆角缩放,            // Q10
    对比度增强,          // Q10
    阴影强度,            // Q10
    玻璃化强度,          // Q10
    噪点抑制,            // Q10
    可访问模式,
    减少动态,
    触控优先,
}

结构 协议参数 {
    键,
    值,
}

结构 协议请求 {
    原始URL,
    协议名,
    主机,
    路径,
    查询,
    类型,
    参数列表,          // 协议参数[]
    参数数,
}

结构 协议响应 {
    状态码,
    标题,
    描述,
    主内容HTML,
    扩展元数据,
}

结构 壳层埋点 {
    事件名,
    时间戳,
    数值1,
    数值2,
    标签,
}

结构 壳层埋点缓冲 {
    列表,              // 壳层埋点[]
    写索引,
    总写入,
}

结构 路由决策 {
    是否命中,
    命中模块,
    风险评分,          // 0-100
    置信度,            // Q8
    回退模块,
}

定义 可变 全局_埋点缓冲 = 空
定义 可变 全局_默认策略 = 路由策略_兼容

// §3 基础工具函数

函数 最小值(a, b) {
    如果 (a < b) { 返回 a }
    返回 b
}

函数 最大值(a, b) {
    如果 (a > b) { 返回 a }
    返回 b
}

函数 限幅(v, lo, hi) {
    如果 (v < lo) { 返回 lo }
    如果 (v > hi) { 返回 hi }
    返回 v
}

函数 是否空串(s) {
    如果 (s == 空) { 返回 真 }
    返回 字符串长度(s) == 0
}

函数 布尔转文本(v) {
    如果 (v) { 返回 "true" }
    返回 "false"
}

函数 字符串安全值(s, 默认值) {
    如果 (s == 空 || 字符串长度(s) == 0) { 返回 默认值 }
    返回 s
}

函数 数值转百分比文本(v) {
    返回 字符串拼接(整数转字符串(v), "%")
}

函数 CSS_追加(css, 片段) {
    返回 字符串拼接(css, 片段)
}

函数 HTML_包裹(tag, cls, 内容) {
    定义 可变 out = ""
    out = 字符串拼接(out, "<")
    out = 字符串拼接(out, tag)
    out = 字符串拼接(out, " class='")
    out = 字符串拼接(out, cls)
    out = 字符串拼接(out, "'>")
    out = 字符串拼接(out, 内容)
    out = 字符串拼接(out, "</")
    out = 字符串拼接(out, tag)
    out = 字符串拼接(out, ">")
    返回 out
}

函数 壳层_时间戳_ms() {
    返回 平台_获取时间_ms()
}

// §4 埋点与可观测

函数 壳层埋点_初始化() {
    如果 (全局_埋点缓冲 != 空) { 返回 }
    定义 b = 堆_分配(壳层埋点缓冲)
    b.列表 = 堆_分配_数组(最大埋点数 * 40)
    b.写索引 = 0
    b.总写入 = 0
    全局_埋点缓冲 = b
}

函数 壳层埋点_记录(事件名, 数值1, 数值2, 标签) {
    如果 (全局_埋点缓冲 == 空) { 壳层埋点_初始化() }
    定义 b = 全局_埋点缓冲
    定义 idx = b.写索引 % 最大埋点数
    b.列表[idx].事件名 = 事件名
    b.列表[idx].时间戳 = 壳层_时间戳_ms()
    b.列表[idx].数值1 = 数值1
    b.列表[idx].数值2 = 数值2
    b.列表[idx].标签 = 标签
    b.写索引 = b.写索引 + 1
    b.总写入 = b.总写入 + 1
}

函数 壳层埋点_导出JSON() {
    如果 (全局_埋点缓冲 == 空) { 返回 "[]" }
    定义 b = 全局_埋点缓冲
    定义 可变 out = "["
    定义 可变 n = 最小值(b.总写入, 最大埋点数)
    定义 可变 i = 0
    当 (i < n) {
        定义 idx = (b.写索引 - n + i + 最大埋点数) % 最大埋点数
        定义 e = b.列表[idx]
        如果 (i > 0) { out = 字符串拼接(out, ",") }
        out = 字符串拼接(out, "{\"event\":\"")
        out = 字符串拼接(out, 字符串安全值(e.事件名, ""))
        out = 字符串拼接(out, "\",\"ts\":")
        out = 字符串拼接(out, 整数转字符串(e.时间戳))
        out = 字符串拼接(out, ",\"v1\":")
        out = 字符串拼接(out, 整数转字符串(e.数值1))
        out = 字符串拼接(out, ",\"v2\":")
        out = 字符串拼接(out, 整数转字符串(e.数值2))
        out = 字符串拼接(out, ",\"tag\":\"")
        out = 字符串拼接(out, 字符串安全值(e.标签, ""))
        out = 字符串拼接(out, "\"}")
        i = i + 1
    }
    out = 字符串拼接(out, "]")
    返回 out
}

// §5 视觉上下文初始化

函数 壳层视觉上下文_默认() {
    定义 ctx = 壳层视觉上下文 {}
    ctx.主题 = 壳层主题_浅色
    ctx.密度 = 壳层密度_标准
    ctx.动效级别 = 壳层动效_标准
    ctx.字号缩放 = 1024
    ctx.圆角缩放 = 1024
    ctx.对比度增强 = 1024
    ctx.阴影强度 = 1024
    ctx.玻璃化强度 = 900
    ctx.噪点抑制 = 1024
    ctx.可访问模式 = 假
    ctx.减少动态 = 假
    ctx.触控优先 = 假
    返回 ctx
}

函数 壳层视觉上下文_应用可访问(ctx) {
    ctx.可访问模式 = 真
    ctx.字号缩放 = 1180
    ctx.对比度增强 = 1320
    ctx.阴影强度 = 700
    ctx.动效级别 = 壳层动效_低
    ctx.减少动态 = 真
}

函数 壳层视觉上下文_应用触控(ctx) {
    ctx.触控优先 = 真
    ctx.密度 = 壳层密度_宽松
    ctx.圆角缩放 = 1200
}

函数 壳层视觉上下文_设置主题(ctx, 主题) {
    ctx.主题 = 主题
}

// §6 CSS变量层

函数 壳层_CSS_变量_浅色() {
    定义 可变 css = ":root{"
    css = CSS_追加(css, "--nova-bg:#eef4fb;")
    css = CSS_追加(css, "--nova-bg2:#f7fbff;")
    css = CSS_追加(css, "--nova-card:#ffffff;")
    css = CSS_追加(css, "--nova-ink:#10233f;")
    css = CSS_追加(css, "--nova-sub:#5f748f;")
    css = CSS_追加(css, "--nova-line:#d8e3f1;")
    css = CSS_追加(css, "--nova-primary:#2563eb;")
    css = CSS_追加(css, "--nova-success:#16a34a;")
    css = CSS_追加(css, "--nova-warn:#f59e0b;")
    css = CSS_追加(css, "--nova-danger:#dc2626;")
    css = CSS_追加(css, "--nova-glass:rgba(255,255,255,0.78);")
    css = CSS_追加(css, "--nova-shadow:0 24px 60px rgba(15,23,42,0.12);")
    css = CSS_追加(css, "}")
    返回 css
}


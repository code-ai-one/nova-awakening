// §6 帧填充+校验

函数 以太网_填充(Nova缓冲) {
    // 以太网帧最小60字节(不含FCS), 不足需填充零
    定义 长度 = Nova缓冲_长度(Nova缓冲)
    如果 (长度 < 以太网_最小帧) {
        定义 填充量 = 以太网_最小帧 - 长度
        定义 可变 i = 0
        当 (i < 填充量) {
            Nova缓冲_后推(Nova缓冲, 1)
            i = i + 1
        }
    }
}

// §7 MAC地址格式化

函数 MAC_格式化(mac) {
    // 返回 "AA:BB:CC:DD:EE:FF" 格式
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 6) {
        如果 (i > 0) { 结果 = 结果 + ":" }
        定义 字节 = MAC_字节(mac, i)
        定义 高 = (字节 >> 4) & 0xF
        定义 低 = 字节 & 0xF
        如果 (高 < 10) { 结果 = 结果 + 字符(48 + 高) }
        否则 { 结果 = 结果 + 字符(55 + 高) }
        如果 (低 < 10) { 结果 = 结果 + 字符(48 + 低) }
        否则 { 结果 = 结果 + 字符(55 + 低) }
        i = i + 1
    }
    返回 结果
}

函数 MAC_从字符串(字符串) {
    // 解析 "AA:BB:CC:DD:EE:FF" → 48位整数
    定义 部分 = 字符串_分割(字符串, ":")
    如果 (计数(部分) != 6) { 返回 0 }
    定义 可变 mac = 0
    定义 可变 i = 0
    当 (i < 6) {
        mac = (mac << 8) | 十六进制转整数(部分[i])
        i = i + 1
    }
    返回 mac
}

函数 MAC_从缓冲(缓冲, 偏移) {
    返回 MAC_从字节(
        缓冲读(缓冲, 偏移), 缓冲读(缓冲, 偏移+1), 缓冲读(缓冲, 偏移+2),
        缓冲读(缓冲, 偏移+3), 缓冲读(缓冲, 偏移+4), 缓冲读(缓冲, 偏移+5))
}

函数 MAC_是本地管理(mac) {
    // 本地管理位 = MAC[0] bit 1
    返回 (MAC_字节(mac, 0) & 2) != 0
}

函数 MAC_生成随机() {
    // 生成随机本地管理MAC: x2:xx:xx:xx:xx:xx
    定义 可变 mac = 随机数64()
    // 设置本地管理位(bit 1), 清除多播位(bit 0)
    mac = (mac & 0xFEFFFFFFFFFF) | 0x020000000000
    返回 mac
}

// §8 网络设备接口

函数 链路层_发送(Nova缓冲, 下一跳IP, 设备) {
    // 完整的链路层发送流程
    // 1. ARP查询获取目标MAC
    定义 目标MAC = ARP_查询(下一跳IP)
    如果 (目标MAC == 0) {
        // MAC未知→发送ARP请求, 暂存包
        ARP_发送请求(下一跳IP, 设备)
        返回 错误_重试
    }

    // 2. 封装以太网头
    定义 源MAC = 设备_获取MAC(设备)
    以太网_封装(Nova缓冲, 目标MAC, 源MAC, 以太网类型_IP)

    // 3. 帧填充(最小60字节)
    以太网_填充(Nova缓冲)

    // 4. 交给网络设备驱动发送
    返回 设备_发送(设备, Nova缓冲)
}

// §9 外部接口 — 连接到真实子系统

外部 网络设备列表           // 定义在 网络/核心/网络设备.nova

函数 设备_获取MAC(设备) {
    // 从网络设备结构获取MAC地址
    如果 (设备 == 空) { 返回 0x525400000001 }  // 默认qemu MAC
    如果 (网络设备列表 != 空 && 计数(网络设备列表) > 0) {
        返回 网络设备列表[0]  // 默认网络设备的MAC
    }
    返回 0x525400000001
}

函数 设备_混杂模式(设备) {
    // 检查设备是否开启混杂模式(IFF_PROMISC)
    返回 假  // 默认不开
}

函数 设备_发送(设备, Nova缓冲) {
    // 通过网络设备驱动发送(连接到virtio/e1000)
    返回 网络设备_发送(设备, Nova缓冲)
}

函数 IPv6_接收(Nova缓冲) {
    // IPv6接收处理(M2阶段实现)
    内核调试("以太网: IPv6帧(暂不处理)")
    返回 0
}

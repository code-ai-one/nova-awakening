结构 回收档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    交换数,
    老化数,
    淘汰数,
    回收数,
    杀手数,
    压缩数,
    巡检数,
    成功数,
    失败数,
    最近目标,
    最近页,
    最近策略,
    活跃链,
    非活跃链,
    交换表,
}

结构 回收请求 {
    动作,
    目标,
    参数,
    选项,
}

结构 回收回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 回收摘要 {
    名称,
    交换数,
    老化数,
    淘汰数,
    回收数,
    杀手数,
    压缩数,
    巡检数,
    成功数,
    失败数,
    健康,
}

结构 交换项 {
    标识,
    页号,
    区名,
    热度,
    状态,
}

结构 杀手项 {
    名称,
    占用,
    优先,
    原因,
}

定义 可变 回收账本 = []
定义 可变 回收构建数 = 0
定义 可变 回收总动作 = 0
定义 可变 回收总成功 = 0
定义 可变 回收总失败 = 0

函数 内存回收_建档(名称) {
    定义 档 = 回收档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.交换数 = 0
    档.老化数 = 0
    档.淘汰数 = 0
    档.回收数 = 0
    档.杀手数 = 0
    档.压缩数 = 0
    档.巡检数 = 0
    档.成功数 = 0
    档.失败数 = 0
    档.最近目标 = ""
    档.最近页 = -1
    档.最近策略 = ""
    档.活跃链 = []
    档.非活跃链 = []
    档.交换表 = []
    返回 档
}

函数 内存回收_登记(档) {
    追加(回收账本, 档)
    回收构建数 = 回收构建数 + 1
    返回 档
}

函数 内存回收_完整统计() {
    返回 [
        回收构建数,
        回收总动作,
        回收总成功,
        回收总失败
    ]
}

函数 内存回收_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 回收回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 内存回收_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    回收总动作 = 回收总动作 + 1
}

函数 内存回收_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.失败数 > 档.成功数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (计数(档.非活跃链) > 32) {
        档.最近健康 = "拥塞"
        返回 档.最近健康
    }
    如果 (档.失败数 > 0) {
        档.最近健康 = "监视"
        返回 档.最近健康
    }
    档.最近健康 = "运行"
    返回 档.最近健康
}

函数 内存回收_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (档.名称 == "") { 返回 假 }
    返回 真
}

函数 内存回收_成功(档, 来源, 数据) {
    档.最近结果 = 数据
    档.成功数 = 档.成功数 + 1
    回收总成功 = 回收总成功 + 1
    档.最近统计 = 内存回收_完整统计()
    内存回收_刷新健康(档)
    返回 内存回收_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 内存回收_失败(档, 来源, 错因) {
    如果 (档 != 空) {
        档.最近错误 = 错因
        档.失败数 = 档.失败数 + 1
        档.最近统计 = 内存回收_完整统计()
        内存回收_刷新健康(档)
    }
    回收总失败 = 回收总失败 + 1
    返回 内存回收_建回证(真, 假, 来源, 错因, 空, 内存回收_完整统计())
}

函数 内存回收_加活跃(档, 区名, 页号, 热度) {
    如果 (!内存回收_检查档(档)) { 返回 内存回收_失败(档, "加活跃", "回收档不可用") }
    内存回收_记录(档, "加活跃", [区名, 页号, 热度], "内存回收")
    追加(档.活跃链, [区名, 页号, 热度])
    档.最近目标 = 区名
    档.最近页 = 页号
    返回 内存回收_成功(档, "加活跃", [区名, 页号, 热度])
}

函数 内存回收_加非活跃(档, 区名, 页号, 热度) {
    如果 (!内存回收_检查档(档)) { 返回 内存回收_失败(档, "加非活跃", "回收档不可用") }
    内存回收_记录(档, "加非活跃", [区名, 页号, 热度], "内存回收")
    追加(档.非活跃链, [区名, 页号, 热度])
    档.最近目标 = 区名
    档.最近页 = 页号
    返回 内存回收_成功(档, "加非活跃", [区名, 页号, 热度])
}

函数 内存回收_老化(档, 步长) {
    如果 (!内存回收_检查档(档)) { 返回 内存回收_失败(档, "老化", "回收档不可用") }
    内存回收_记录(档, "老化", [步长], "内存回收")
    定义 新活跃 = []
    定义 索引 = 0
    当 (索引 < 计数(档.活跃链)) {
        定义 项 = 档.活跃链[索引]
        定义 热度 = 项[2] - 步长
        如果 (热度 <= 0) {
            追加(档.非活跃链, [项[0], 项[1], 0])
        } 否则 {
            追加(新活跃, [项[0], 项[1], 热度])
        }
        索引 = 索引 + 1
    }
    档.活跃链 = 新活跃
    档.老化数 = 档.老化数 + 1
    返回 内存回收_成功(档, "老化", [计数(档.活跃链), 计数(档.非活跃链)])
}

函数 内存回收_交换(档, 区名, 页号, 热度) {
    如果 (!内存回收_检查档(档)) { 返回 内存回收_失败(档, "交换", "回收档不可用") }
    内存回收_记录(档, "交换", [区名, 页号, 热度], "内存回收")
    定义 项 = 交换项 {}
    项.标识 = 区名 + "-" + 整数转字符串(页号)
    项.页号 = 页号
    项.区名 = 区名
    项.热度 = 热度
    项.状态 = "已换出"
    追加(档.交换表, 项)
    档.交换数 = 档.交换数 + 1
    档.最近目标 = 区名
    档.最近页 = 页号
    返回 内存回收_成功(档, "交换", 项)
}

函数 内存回收_淘汰(档, 数量) {
    如果 (!内存回收_检查档(档)) { 返回 内存回收_失败(档, "淘汰", "回收档不可用") }
    内存回收_记录(档, "淘汰", [数量], "内存回收")
    定义 已淘汰 = []
    定义 索引 = 0
    当 (索引 < 数量 && 计数(档.非活跃链) > 0) {
        定义 项 = 档.非活跃链[0]
        删除(档.非活跃链, 0)
        追加(已淘汰, 内存回收_交换(档, 项[0], 项[1], 项[2]).数据)
        索引 = 索引 + 1
    }
    档.淘汰数 = 档.淘汰数 + 计数(已淘汰)
    返回 内存回收_成功(档, "淘汰", 已淘汰)
}

函数 内存回收_回收页(档, 物档, 区名, 页号) {
    如果 (!内存回收_检查档(档)) { 返回 内存回收_失败(档, "回收页", "回收档不可用") }
    内存回收_记录(档, "回收页", [区名, 页号], "内存回收")
    定义 回证 = 内存物理_释放(物档, 区名, 页号)
    如果 (!回证.已成) { 返回 内存回收_失败(档, "回收页", 回证.错因) }
    档.回收数 = 档.回收数 + 1
    档.最近目标 = 区名
    档.最近页 = 页号
    返回 内存回收_成功(档, "回收页", [区名, 页号])
}

函数 内存回收_压缩建议(档, 物档) {
    如果 (!内存回收_检查档(档)) { 返回 内存回收_失败(档, "压缩建议", "回收档不可用") }
    内存回收_记录(档, "压缩建议", [], "内存回收")
    定义 建议 = 内存物理_紧缩建议(物档)
    档.压缩数 = 档.压缩数 + 1
    如果 (!建议.已成) { 返回 内存回收_失败(档, "压缩建议", 建议.错因) }
    返回 内存回收_成功(档, "压缩建议", 建议.数据)
}

函数 内存回收_杀手评分(名称, 占用, 优先) {
    定义 分 = 占用 - 优先 * 32
    如果 (分 < 0) { 分 = 0 }
    返回 [名称, 分]
}

函数 内存回收_选择杀手(档, 候选表) {
    如果 (!内存回收_检查档(档)) { 返回 内存回收_失败(档, "选择杀手", "回收档不可用") }
    内存回收_记录(档, "选择杀手", [候选表], "内存回收")
    如果 (计数(候选表) == 0) { 返回 内存回收_失败(档, "选择杀手", "候选为空") }
    定义 最佳 = 候选表[0]
    定义 最佳分 = 内存回收_杀手评分(最佳[0], 最佳[1], 最佳[2])[1]
    定义 索引 = 1
    当 (索引 < 计数(候选表)) {
        定义 候 = 候选表[索引]
        定义 分 = 内存回收_杀手评分(候[0], 候[1], 候[2])[1]
        如果 (分 > 最佳分) {
            最佳 = 候
            最佳分 = 分
        }
        索引 = 索引 + 1
    }
    返回 内存回收_成功(档, "选择杀手", [最佳[0], 最佳分])
}

函数 内存回收_执行杀手(档, 候选表, 原因) {
    如果 (!内存回收_检查档(档)) { 返回 内存回收_失败(档, "执行杀手", "回收档不可用") }
    内存回收_记录(档, "执行杀手", [候选表, 原因], "内存回收")
    定义 目标 = 内存回收_选择杀手(档, 候选表)
    如果 (!目标.已成) { 返回 目标 }
    档.杀手数 = 档.杀手数 + 1
    档.最近策略 = 原因
    返回 内存回收_成功(档, "执行杀手", [目标.数据[0], 原因])
}

函数 内存回收_巡检(档, 物档) {
    如果 (!内存回收_检查档(档)) { 返回 内存回收_失败(档, "巡检", "回收档不可用") }
    内存回收_记录(档, "巡检", [], "内存回收")
    定义 报告 = []
    追加(报告, 内存回收_老化(档, 1).数据)
    追加(报告, 内存回收_淘汰(档, 2).数据)
    追加(报告, 内存回收_压缩建议(档, 物档).数据)
    档.巡检数 = 档.巡检数 + 1
    返回 内存回收_成功(档, "巡检", 报告)
}

函数 内存回收_摘要(档) {
    定义 摘要 = 回收摘要 {}
    摘要.名称 = 档.名称
    摘要.交换数 = 档.交换数
    摘要.老化数 = 档.老化数
    摘要.淘汰数 = 档.淘汰数
    摘要.回收数 = 档.回收数
    摘要.杀手数 = 档.杀手数
    摘要.压缩数 = 档.压缩数
    摘要.巡检数 = 档.巡检数
    摘要.成功数 = 档.成功数
    摘要.失败数 = 档.失败数
    摘要.健康 = 内存回收_刷新健康(档)
    返回 摘要
}

函数 内存回收_初始化(档) {
    如果 (!内存回收_检查档(档)) { 返回 内存回收_失败(档, "初始化", "回收档不可用") }
    内存回收_记录(档, "初始化", [], "内存回收")
    档.活跃链 = []
    档.非活跃链 = []
    档.交换表 = []
    档.是否初始化 = 真
    内存回收_加活跃(档, "常规区", 96, 3)
    内存回收_加活跃(档, "常规区", 97, 2)
    内存回收_加非活跃(档, "高端区", 640, 0)
    内存回收_加非活跃(档, "高端区", 641, 0)
    返回 内存回收_成功(档, "初始化", "已初始化")
}

函数 内存回收_自检(档) {
    如果 (!内存回收_检查档(档)) { 返回 假 }
    定义 物档 = 内存物理_登记(内存物理_建档("回收物页"))
    内存物理_初始化(物档)
    内存物理_分配(物档, "常规区", "页缓存", "可写")
    内存物理_分配(物档, "高端区", "贴图", "只读")
    如果 (内存回收_初始化(档).已成 == 假) { 返回 假 }
    如果 (内存回收_老化(档, 1).已成 == 假) { 返回 假 }
    如果 (内存回收_淘汰(档, 1).已成 == 假) { 返回 假 }
    如果 (内存回收_回收页(档, 物档, "常规区", 80).已收 == 假) { 返回 假 }
    如果 (内存回收_压缩建议(档, 物档).已成 == 假) { 返回 假 }
    如果 (内存回收_执行杀手(档, [["前台一", 480, 3], ["后台二", 620, 1], ["编译三", 512, 2]], "内存告急").已成 == 假) { 返回 假 }
    如果 (内存回收_巡检(档, 物档).已成 == 假) { 返回 假 }
    返回 真
}

函数 内存回收_处理(档, 请求) {
    如果 (请求 == 空) { 返回 内存回收_失败(档, "处理", "请求为空") }
    如果 (请求.动作 == "初始化") { 返回 内存回收_初始化(档) }
    如果 (请求.动作 == "加活跃") { 返回 内存回收_加活跃(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "加非活跃") { 返回 内存回收_加非活跃(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "老化") { 返回 内存回收_老化(档, 请求.参数[0]) }
    如果 (请求.动作 == "交换") { 返回 内存回收_交换(档, 请求.参数[0], 请求.参数[1], 请求.参数[2]) }
    如果 (请求.动作 == "淘汰") { 返回 内存回收_淘汰(档, 请求.参数[0]) }
    如果 (请求.动作 == "选择杀手") { 返回 内存回收_选择杀手(档, 请求.参数[0]) }
    如果 (请求.动作 == "执行杀手") { 返回 内存回收_执行杀手(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "摘要") { 返回 内存回收_成功(档, "摘要", 内存回收_摘要(档)) }
    返回 内存回收_失败(档, "处理", "未知动作")
}

// merge source: 沙盒批次/批三/待厚/中枢/内存溢出杀.nova
// NovaOS OOM杀手 (Out-Of-Memory Killer)
// 职责: 内存耗尽时选择并终止进程释放内存

定义 可变 OOM_触发次数 = 0
定义 可变 OOM_杀死进程数 = 0
定义 可变 OOM_释放页数 = 0

定义 OOM_分数_调整_最小 = -1000   // 永不杀死
定义 OOM_分数_调整_最大 = 1000    // 优先杀死
定义 OOM_最小_评分 = 1            // 最低评分 (防止杀死init)

// OOM评分: 为每个进程计算OOM分数
// 分数越高越可能被杀死

函数 OOM_计算分数(进程) {
    // PID 1 (init) 和内核线程不能杀
    如果 (进程.进程号 <= 1) { 返回 0 }
    如果 (进程.是内核线程) { 返回 0 }

    // oom_score_adj = -1000 表示豁免
    如果 (进程.OOM分数调整 == OOM_分数_调整_最小) { 返回 0 }

    // 基础分数: RSS (驻留集大小) / 总内存
    定义 mm = 进程.内存描述符
    如果 (mm == 空) { 返回 0 }

    定义 rss = mm[MM_RSS]
    如果 (rss == 0) { 返回 0 }

    // 分数 = RSS占总内存的千分比
    定义 基础分数 = 如果 (总页数 > 0) { rss * 1000 / 总页数 } 否则 { 0 }
    如果 (基础分数 < OOM_最小_评分) { 基础分数 = OOM_最小_评分 }

    // 加上用户空间调整值 (oom_score_adj)
    定义 调整后分数 = 基础分数 + 进程.OOM分数调整
    如果 (调整后分数 < OOM_最小_评分) { 调整后分数 = OOM_最小_评分 }
    如果 (调整后分数 > 1000) { 调整后分数 = 1000 }

    返回 调整后分数
}

// 选择牺牲进程

函数 OOM_选择牺牲者() {
    定义 可变 最高分 = 0
    定义 可变 牺牲者 = 空
    定义 进程列表 = 获取所有进程()

    定义 可变 i = 0
    当 (i < 计数(进程列表)) {
        定义 进程 = 进程列表[i]
        定义 分数 = OOM_计算分数(进程)

        如果 (分数 > 最高分) {
            最高分 = 分数
            牺牲者 = 进程
        }
        i = i + 1
    }

    返回 牺牲者
}

// OOM杀死进程

函数 OOM_杀死(进程) {
    如果 (进程 == 空) { 返回 假 }

    内核警告("OOM Killer: 杀死进程")
    内核信息数值("  PID", 进程.进程号)
    内核信息数值("  RSS(页)", 进程.内存描述符[MM_RSS])
    内核信息数值("  OOM分数", OOM_计算分数(进程))

    // 发送SIGKILL
    定义 释放前空闲 = 空闲页数
    信号_发送(进程.进程号, 信号_KILL)

    // 标记进程为OOM victim (防止重复选择)
    进程.OOM受害者 = 真

    OOM_杀死进程数 = OOM_杀死进程数 + 1
    返回 真
}

// OOM入口: 内存分配最终失败时调用

函数 OOM_触发() {
    OOM_触发次数 = OOM_触发次数 + 1

    内核警告("═══ OOM: 系统内存不足! ═══")
    内核信息数值("  空闲页数", 空闲页数)
    内核信息数值("  总页数", 总页数)

    // 先尝试最后一次回收
    定义 回收结果 = 直接回收(回收_批次大小)
    如果 (回收结果 > 0 && 伙伴_检查水位(水位_最低)) {
        内核信息("OOM: 最后回收成功, 取消OOM")
        返回 真
    }

    // 选择牺牲者
    定义 牺牲者 = OOM_选择牺牲者()
    如果 (牺牲者 == 空) {
        内核错误("OOM: 无法选择牺牲者, 系统可能崩溃!")
        返回 假
    }

    // 杀死牺牲者
    返回 OOM_杀死(牺牲者)
}

// /proc/PID/oom_score 和 /proc/PID/oom_score_adj 接口

函数 OOM_获取进程分数(进程号) {
    定义 进程 = 查找进程(进程号)
    如果 (进程 == 空) { 返回 0 }
    返回 OOM_计算分数(进程)
}

函数 OOM_设置分数调整(进程号, 调整值) {
    如果 (调整值 < OOM_分数_调整_最小) { 调整值 = OOM_分数_调整_最小 }
    如果 (调整值 > OOM_分数_调整_最大) { 调整值 = OOM_分数_调整_最大 }
    定义 进程 = 查找进程(进程号)
    如果 (进程 != 空) {
        进程.OOM分数调整 = 调整值
    }
}

// 内存压力通知 (供cgroup/用户空间监控)

定义 压力_无 = 0
定义 压力_低 = 1
定义 压力_中 = 2
定义 压力_临界 = 3

函数 OOM_获取内存压力() {
    如果 (!伙伴_检查水位(水位_最低)) { 返回 压力_临界 }
    如果 (!伙伴_检查水位(水位_低)) { 返回 压力_中 }
    如果 (!伙伴_检查水位(水位_高)) { 返回 压力_低 }
    返回 压力_无
}

// 统计

函数 OOM_统计() {
    返回 [OOM_触发次数, OOM_杀死进程数, OOM_释放页数]
}

// OOM cgroup感知 

函数 OOM_cgroup触发(cgroup_id) {
    // 仅在指定cgroup内选择牺牲者
    OOM_触发次数 = OOM_触发次数 + 1
    内核警告("OOM: cgroup " + 整数转字符串(cgroup_id) + " 内存超限")

    定义 进程列表 = 获取所有进程()
    定义 可变 最高分 = 0
    定义 可变 牺牲者 = 空
    定义 可变 i = 0
    当 (i < 计数(进程列表)) {
        定义 进程 = 进程列表[i]
        如果 (进程.cgroup_id == cgroup_id) {
            定义 分数 = OOM_计算分数(进程)
            如果 (分数 > 最高分) {
                最高分 = 分数
                牺牲者 = 进程
            }
        }
        i = i + 1
    }
    如果 (牺牲者 != 空) { OOM_杀死(牺牲者) }
}

// OOM reaper (异步回收被杀进程的内存)

定义 可变 OOM_reaper_队列 = []

函数 OOM_reaper_入队(进程) {
    追加(OOM_reaper_队列, 进程)
}

函数 OOM_reaper_执行() {
    当 (计数(OOM_reaper_队列) > 0) {
        定义 进程 = OOM_reaper_队列[0]
        链表_删除(OOM_reaper_队列, 0)
        如果 (进程.内存描述符 != 空) {
            定义 释放 = 进程.内存描述符[MM_RSS]
            OOM_释放页数 = OOM_释放页数 + 释放
        }
    }
}

函数 OOM_完整统计() {
    返回 [OOM_触发次数, OOM_杀死进程数, OOM_释放页数,
           OOM_获取内存压力(), 计数(OOM_reaper_队列)]
}

// 压力级别名称

函数 OOM_压力名(级别) {
    如果 (级别 == 压力_无) { 返回 "none" }
    如果 (级别 == 压力_低) { 返回 "low" }
    如果 (级别 == 压力_中) { 返回 "medium" }
    如果 (级别 == 压力_临界) { 返回 "critical" }
    返回 "unknown"
}

// merge source: 沙盒批次/批三/待厚/中枢/回写.nova
// NovaOS 脏页回写 (Writeback)
// 职责: 定期将脏页写回磁盘, 限制脏页比例

定义 可变 脏页比例上限 = 20       // dirty_ratio: 脏页占总内存20%时阻塞写入
定义 可变 脏页比例后台 = 10       // dirty_background_ratio: 10%时唤醒后台回写
定义 可变 回写周期_毫秒 = 5000    // dirty_writeback_centisecs: 5秒
定义 可变 脏页过期_毫秒 = 30000   // dirty_expire_centisecs: 30秒

定义 可变 回写队列 = []            // 待写回的 [地址空间, 文件页号, 物理页号]
定义 可变 回写_运行中 = 假

定义 可变 回写_总页数 = 0
定义 可变 回写_同步次数 = 0
定义 可变 回写_后台次数 = 0
定义 可变 回写_阻塞次数 = 0

// 回写守护线程 

函数 回写_守护线程() {
    回写_运行中 = 真
    当 (回写_运行中) {
        // 定期检查脏页比例
        定义 脏页率 = 回写_脏页比例()

        如果 (脏页率 >= 脏页比例后台) {
            // 后台回写: 将脏页率降到后台阈值以下
            回写_后台回写()
            回写_后台次数 = 回写_后台次数 + 1
        }

        // 回写过期的脏页
        回写_过期页()

        // 处理回写队列中的请求
        回写_处理队列()

        // 休眠等待下一个周期
        调度_休眠(回写周期_毫秒)
    }
}

// 脏页比例计算

函数 回写_脏页比例() {
    如果 (总页数 == 0) { 返回 0 }
    // 遍历统计全局脏页数 (简化: 使用LRU链表中的脏页)
    定义 脏页总数 = 回写_统计脏页()
    返回 脏页总数 * 100 / 总页数
}

函数 回写_统计脏页() {
    // 从页缓存获取全局脏页计数
    定义 缓存统计 = 页缓存_统计()
    如果 (缓存统计 != 空) { 返回 缓存统计[1] }   // [总页数, 脏页数, 命中, 未命中]
    返回 0
}

// 后台回写: 将脏页降到后台阈值以下

函数 回写_后台回写() {
    定义 目标脏页率 = 脏页比例后台 - 2  // 回写到比阈值低2%
    如果 (目标脏页率 < 0) { 目标脏页率 = 0 }
    定义 可变 回写计数 = 0
    定义 最大回写 = 1024  // 单次最多回写1024页

    当 (回写计数 < 最大回写 && 回写_脏页比例() > 目标脏页率) {
        定义 本次 = 回写_批量写回(32)  // 每批32页
        如果 (本次 == 0) { 中断 }
        回写计数 = 回写计数 + 本次
    }
}

// 阻塞回写: 脏页超过上限时阻塞写入进程

函数 回写_平衡脏页() {
    定义 脏页率 = 回写_脏页比例()

    如果 (脏页率 < 脏页比例后台) { 返回 }

    如果 (脏页率 >= 脏页比例上限) {
        // 阻塞: 等待脏页降到阈值以下
        回写_阻塞次数 = 回写_阻塞次数 + 1
        当 (回写_脏页比例() >= 脏页比例后台) {
            回写_批量写回(64)
            调度_让出()  // 让回写线程运行
        }
    } 否则 如果 (脏页率 >= 脏页比例后台) {
        // 唤醒后台回写
        回写_唤醒守护线程()
    }
}

// 批量写回: 写回指定数量的脏页

函数 回写_批量写回(批大小) {
    定义 可变 已写 = 0

    当 (已写 < 批大小 && 计数(回写队列) > 0) {
        定义 项 = 回写队列[0]
        删除(回写队列, 0)

        定义 地址空间 = 项[0]
        定义 文件页号 = 项[1]
        定义 物理页号 = 项[2]

        定义 结果 = 回写_写单页(地址空间, 文件页号, 物理页号)
        如果 (结果 == 成功) {
            已写 = 已写 + 1
            回写_总页数 = 回写_总页数 + 1
        }
    }
    返回 已写
}

// 写回单个脏页到磁盘
函数 回写_写单页(地址空间, 文件页号, 物理页号) {
    定义 操作 = 地址空间[AS_操作]
    如果 (操作 == 空) { 返回 错误_无效参数 }

    定义 页虚拟 = 物理到虚拟(物理页号 * 页大小)

    // 调用文件系统的writepage
    定义 结果 = 操作.写页(地址空间[AS_Nova文件节点], 文件页号, 页虚拟)

    如果 (结果 == 成功) {
        // 清除脏标记
        页缓存_清除脏(地址空间, 物理页号)
    }
    返回 结果
}

// 提交脏页到回写队列

函数 回写_提交脏页(页号) {
    // 通过物理页描述符反查所属address_space和文件偏移
    定义 页描述 = 获取页描述符(页号)
    如果 (页描述 != 空 && 页描述.映射 != 空) {
        追加(回写队列, [页描述.映射, 页描述.索引, 页号])
    } 否则 {
        // 匿名页或无法追踪的页: 直接按页号提交
        追加(回写队列, [空, 0, 页号])
    }
}

函数 回写_提交(地址空间, 文件页号, 物理页号) {
    追加(回写队列, [地址空间, 文件页号, 物理页号])
}

// 过期脏页回写

函数 回写_过期页() {
    // 检查脏页时间戳是否超过dirty_expire_centisecs
    定义 当前时间 = 读取毫秒()
    定义 过期阈值 = 脏页过期_毫秒
    定义 可变 过期数 = 0

    定义 可变 i = 0
    当 (i < 计数(回写队列)) {
        定义 项 = 回写队列[i]
        // 检查脏页是否超过过期时间(项=[地址空间,文件页号,物理页号])
        定义 页描述 = 获取页描述符(项[2])
        如果 (页描述 != 空 && 当前时间 - 页描述.脏化时间 > 过期阈值) {
            过期数 = 过期数 + 1
        }
        i = i + 1
    }

    如果 (过期数 > 0) {
        定义 实际回写 = 回写_批量写回(过期数)
        如果 (实际回写 > 0) {
            回写_总页数 = 回写_总页数 + 实际回写
        }
    }
}

// 处理回写队列中的请求

函数 回写_处理队列() {
    如果 (计数(回写队列) == 0) { 返回 }
    回写_批量写回(回写队列的计数())
}

函数 回写队列的计数() { 返回 计数(回写队列) }

// 同步接口 (sync/fsync)

// sync: 同步所有脏页到磁盘
函数 系统_sync() {
    回写_同步次数 = 回写_同步次数 + 1
    // 写回所有回写队列中的页
    当 (计数(回写队列) > 0) {
        回写_批量写回(256)
    }
}

函数 回写_唤醒守护线程() {
    // 唤醒后台回写线程：检查是否有脏页需要写回
    如果 (计数(回写队列) > 0) {
        回写_批量写回(32)
    }
}

// 统计

函数 回写_统计信息() {
    返回 [回写_总页数, 回写_同步次数, 回写_后台次数, 回写_阻塞次数,
           计数(回写队列)]
}

// 完整统计

函数 回写_完整统计() {
    返回 [回写_总页数, 回写_同步次数, 回写_后台次数, 回写_阻塞次数, 计数(回写队列)]
}

// merge source: 沙盒批次/批三/待厚/中枢/淘汰链链表.nova
// NovaOS LRU链表管理
// 职责: 物理页的LRU链表管理, 页面老化, 活跃/不活跃分类

定义 LRU_不活跃_匿名 = 0    // INACTIVE_ANON
定义 LRU_活跃_匿名 = 1      // ACTIVE_ANON
定义 LRU_不活跃_文件 = 2    // INACTIVE_FILE
定义 LRU_活跃_文件 = 3      // ACTIVE_FILE
定义 LRU_不可回收 = 4       // UNEVICTABLE
定义 LRU_链表数 = 5

// 每个区域(zone)维护5个LRU链表
定义 可变 LRU链表组 = []     // [5个链表, 每个链表存页号]
定义 可变 LRU计数 = [0, 0, 0, 0, 0]  // 每个链表的页数

定义 可变 LRU_激活次数 = 0
定义 可变 LRU_去激活次数 = 0
定义 可变 LRU_添加次数 = 0
定义 可变 LRU_移除次数 = 0

// 初始化

函数 LRU_初始化() {
    定义 可变 i = 0
    当 (i < LRU_链表数) {
        追加(LRU链表组, 链表_创建())
        i = i + 1
    }
    早期打印OK("LRU链表初始化 (5类)")
}

// 判断页面类型

函数 页_是匿名(页) {
    // 匿名页: 没有关联文件 (栈/堆/匿名Nova内存映射)
    返回 !页描述符_测试标志(页, 页_Nova块缓存) && (页[PG_映射] == 0 || 页_映射_是匿名(页))
}

函数 页_是文件(页) {
    返回 !页_是匿名(页) && !页描述符_测试标志(页, 页_Nova块缓存)
}

函数 页_映射_是匿名(页) {
    // 当前实现判断: 映射指针的最低位为1表示匿名
    返回 (页[PG_映射] & 1) != 0
}

函数 页_是不可回收(页) {
    返回 页描述符_测试标志(页, 页_保留) || 页描述符_测试标志(页, 页_已锁)
}

// 确定页面应该放入哪个LRU链表
函数 LRU_确定类型(页, 活跃) {
    如果 (页_是不可回收(页)) { 返回 LRU_不可回收 }
    如果 (页_是匿名(页)) {
        返回 如果选(活跃, LRU_活跃_匿名, LRU_不活跃_匿名)
    }
    返回 如果选(活跃, LRU_活跃_文件, LRU_不活跃_文件)
}

函数 如果选(条件, 真值, 假值) {
    如果 (条件) { 返回 真值 }
    返回 假值
}

// 添加页到LRU

函数 LRU_添加页(页号) {
    定义 页 = 页描述符_获取(页号)
    如果 (页 == 空) { 返回 }

    // 新分配的页默认放入不活跃链表
    定义 活跃 = 页描述符_测试标志(页, 页_活跃)
    定义 类型 = LRU_确定类型(页, 活跃)

    链表_尾插(LRU链表组[类型], 页号)
    LRU计数[类型] = LRU计数[类型] + 1
    LRU_添加次数 = LRU_添加次数 + 1
}

// 从LRU移除页
函数 LRU_移除页(页号) {
    定义 页 = 页描述符_获取(页号)
    如果 (页 == 空) { 返回 }

    定义 活跃 = 页描述符_测试标志(页, 页_活跃)
    定义 类型 = LRU_确定类型(页, 活跃)

    // 从链表中查找并移除
    如果 (LRU_从链表移除(类型, 页号)) {
        LRU计数[类型] = LRU计数[类型] - 1
        LRU_移除次数 = LRU_移除次数 + 1
    }
}

函数 LRU_从链表移除(类型, 页号) {
    定义 头 = LRU链表组[类型]
    定义 可变 当前 = 头[1]
    当 (当前 != 头) {
        如果 (当前[2] == 页号) {
            链表_删除(当前)
            返回 真
        }
        当前 = 当前[1]
    }
    返回 假
}

// 页面激活/去激活

// 将不活跃页提升为活跃页 (被访问时)
函数 LRU_激活页(页号) {
    定义 页 = 页描述符_获取(页号)
    如果 (页 == 空) { 返回 }
    如果 (页描述符_测试标志(页, 页_活跃)) { 返回 }  // 已经活跃

    定义 是匿名 = 页_是匿名(页)
    定义 旧类型 = 如果选(是匿名, LRU_不活跃_匿名, LRU_不活跃_文件)
    定义 新类型 = 如果选(是匿名, LRU_活跃_匿名, LRU_活跃_文件)

    如果 (LRU_从链表移除(旧类型, 页号)) {
        LRU计数[旧类型] = LRU计数[旧类型] - 1
        链表_尾插(LRU链表组[新类型], 页号)
        LRU计数[新类型] = LRU计数[新类型] + 1
        页描述符_设置标志(页, 页_活跃)
        LRU_激活次数 = LRU_激活次数 + 1
    }
}

// 将活跃页降级为不活跃页 (老化时)
函数 LRU_去激活页(页号) {
    定义 页 = 页描述符_获取(页号)
    如果 (页 == 空) { 返回 }
    如果 (!页描述符_测试标志(页, 页_活跃)) { 返回 }

    定义 是匿名 = 页_是匿名(页)
    定义 旧类型 = 如果选(是匿名, LRU_活跃_匿名, LRU_活跃_文件)
    定义 新类型 = 如果选(是匿名, LRU_不活跃_匿名, LRU_不活跃_文件)

    如果 (LRU_从链表移除(旧类型, 页号)) {
        LRU计数[旧类型] = LRU计数[旧类型] - 1
        链表_尾插(LRU链表组[新类型], 页号)
        LRU计数[新类型] = LRU计数[新类型] + 1
        页描述符_清除标志(页, 页_活跃)
        LRU_去激活次数 = LRU_去激活次数 + 1
    }
}

// 标记页被引用 (访问时调用, 两次引用后激活)

函数 LRU_标记引用(页号) {
    定义 页 = 页描述符_获取(页号)
    如果 (页 == 空) { 返回 }

    如果 (!页描述符_测试标志(页, 页_已引用)) {
        // 第一次引用: 设置引用位
        页描述符_设置标志(页, 页_已引用)
    } 否则 {
        // 第二次引用: 提升为活跃
        如果 (!页描述符_测试标志(页, 页_活跃)) {
            LRU_激活页(页号)
        }
        页描述符_清除标志(页, 页_已引用)
    }
}

// 从不活跃链表尾部取页 (回收用)

// 从指定LRU链表隔离N个页 (从尾部取, 最老的优先)
函数 LRU_隔离页(类型, 数量) {
    定义 可变 隔离列表 = []
    定义 头 = LRU链表组[类型]
    定义 可变 已取 = 0

    当 (已取 < 数量 && !链表_为空(头)) {
        // 从尾部取 (最老的页)
        定义 尾节点 = 头[0]  // 前驱 = 链表尾
        如果 (尾节点 == 头) { 中断 }
        定义 页号 = 链表_数据(尾节点)
        链表_删除(尾节点)
        LRU计数[类型] = LRU计数[类型] - 1
        追加(隔离列表, 页号)
        已取 = 已取 + 1
    }
    返回 隔离列表
}

// 将隔离的页放回LRU链表头部 (回收失败时)
函数 LRU_放回页(类型, 页号列表) {
    定义 可变 i = 0
    当 (i < 计数(页号列表)) {
        链表_头插(LRU链表组[类型], 页号列表[i])
        LRU计数[类型] = LRU计数[类型] + 1
        i = i + 1
    }
}

// 统计

函数 LRU_获取计数() {
    返回 LRU计数
}

函数 LRU_总不活跃() {
    返回 LRU计数[LRU_不活跃_匿名] + LRU计数[LRU_不活跃_文件]
}

函数 LRU_总活跃() {
    返回 LRU计数[LRU_活跃_匿名] + LRU计数[LRU_活跃_文件]
}

函数 LRU_统计() {
    返回 [LRU_添加次数, LRU_移除次数, LRU_激活次数, LRU_去激活次数]
}

// LRU类型名 + 完整统计

函数 LRU_类型名(类型) {
    如果 (类型 == LRU_不活跃_匿名) { 返回 "inactive_anon" }
    如果 (类型 == LRU_活跃_匿名) { 返回 "active_anon" }
    如果 (类型 == LRU_不活跃_文件) { 返回 "inactive_file" }
    如果 (类型 == LRU_活跃_文件) { 返回 "active_file" }
    返回 "unknown"
}

函数 LRU_完整统计() {
    返回 [LRU_添加次数, LRU_移除次数, LRU_激活次数, LRU_去激活次数,
           LRU_总活跃(), LRU_总不活跃()]
}

// merge source: 沙盒批次/批三/待厚/中枢/老化活跃页.nova

函数 老化active页(active_lru) {
    定义 inactive_lru = active_lru - 1  // ACTIVE-1 = INACTIVE
    定义 扫描数 = 全局lru.计数[active_lru] / 4  // 扫描25%
    如果 (扫描数 == 0) { 返回 }
    如果 (扫描数 > SWAP_CLUSTER_MAX) { 扫描数 = SWAP_CLUSTER_MAX }

    定义 可变 i = 0
    当 (i < 扫描数 && 全局lru.计数[active_lru] > 0) {
        定义 页 = 列表_取尾(全局lru.链表[active_lru])
        如果 (页 == 空) { 中断 }
        全局lru.计数[active_lru] = 全局lru.计数[active_lru] - 1

        // 检查referenced位: 最近被访问过则保留在active
        如果 (页_检查并清除引用(页)) {
            列表_加头(全局lru.链表[active_lru], 页)
            全局lru.计数[active_lru] = 全局lru.计数[active_lru] + 1
        } 否则 {
            // 未被引用: 降级到inactive
            列表_加头(全局lru.链表[inactive_lru], 页)
            全局lru.计数[inactive_lru] = 全局lru.计数[inactive_lru] + 1
        }
        i = i + 1
    }
}

// 唤醒kswapd (由伙伴系统分配路径调用)

函数 唤醒kswapd(zone类型) {
    如果 (!kswapd_睡眠中) { 返回 }  // 已在运行
    kswapd_目标zone = zone类型
    kswapd_睡眠中 = 假
}

// 直接内存回收 (分配路径中同步调用)

函数 直接内存回收(阶, gfp) {
    直接回收_次数 = 直接回收_次数 + 1
    // 直接回收使用较低优先级(更积极)
    定义 优先级 = DEF_PRIORITY - 2
    如果 (优先级 < MIN_PRIORITY) { 优先级 = MIN_PRIORITY }
    返回 shrink_节点(优先级)
}

// LRU操作: 添加页面

函数 lru_添加页(页, lru类型) {
    列表_加头(全局lru.链表[lru类型], 页)
    全局lru.计数[lru类型] = 全局lru.计数[lru类型] + 1
}

函数 lru_提升到active(页, lru类型) {
    定义 active_lru = lru类型 + 1
    列表_加头(全局lru.链表[active_lru], 页)
    全局lru.计数[active_lru] = 全局lru.计数[active_lru] + 1
}

// 页面辅助函数

// 页面标志位定义
定义 PG_已锁定 = 0x01
定义 PG_脏    = 0x02
定义 PG_引用  = 0x04
定义 PG_回写  = 0x08

函数 页_已锁定(页) {
    // 检查PG_locked标志
    如果 (页 == 空) { 返回 真 }
    如果 (页.标志 != 空) { 返回 (页.标志 & PG_已锁定) != 0 }
    返回 假
}

函数 页_是脏_kswapd(页) {
    // 检查PG_dirty标志(页内容已修改未写回磁盘)
    如果 (页 == 空) { 返回 假 }
    如果 (页.标志 != 空) { 返回 (页.标志 & PG_脏) != 0 }
    返回 假
}

函数 页_提交回写(页) {
    // 将脏页提交到回写队列
    如果 (页 == 空) { 返回 }
    如果 (页.标志 != 空) {
        页.标志 = 页.标志 | PG_回写      // 设置回写标志
        页.标志 = 页.标志 & (~PG_脏)     // 清除脏标志
    }
    内核调试("kswapd: 页提交回写")
}

函数 页_释放到伙伴(页) { 释放页(页, 0) }

函数 页_检查并清除引用(页) {
    // 检查PG_referenced并原子清除(用于LRU老化)
    如果 (页 == 空) { 返回 假 }
    如果 (页.标志 != 空 && (页.标志 & PG_引用) != 0) {
        页.标志 = 页.标志 & (~PG_引用)  // 清除引用位
        返回 真  // 之前被引用过
    }
    返回 假
}
函数 zone_水位OK_全部(阶) { 返回 全局空闲页数 > 总页数 / 4 }

// 统计

函数 kswapd_统计() {
    返回 {
        唤醒次数: kswapd_唤醒次数,
        扫描总数: 回收_扫描总数,
        回收总数: 回收_回收总数,
        回写总数: 回收_回写总数,
        直接回收次数: 直接回收_次数,
        inactive_anon: 全局lru.计数[LRU_INACTIVE_ANON],
        active_anon: 全局lru.计数[LRU_ACTIVE_ANON],
        inactive_file: 全局lru.计数[LRU_INACTIVE_FILE],
        active_file: 全局lru.计数[LRU_ACTIVE_FILE]
    }
}

// kswapd主循环 — 后台页面回收守护线程

定义 可变 kswapd_睡眠中 = 真
定义 可变 kswapd_目标zone = 0
定义 可变 kswapd_唤醒次数 = 0
定义 可变 回收_扫描总数 = 0
定义 可变 回收_回收总数 = 0
定义 可变 回写总数 = 0
定义 可变 直接回收_次数 = 0
// 全局空闲页数 已统一定义在 区域初始化.nova
// 总页数 已统一定义在 区域初始化.nova
定义 DEF_PRIORITY = 12
定义 MIN_PRIORITY = 0
定义 SWAP_CLUSTER_MAX = 32
定义 LRU_INACTIVE_ANON = 0
定义 LRU_ACTIVE_ANON = 1
定义 LRU_INACTIVE_FILE = 2
定义 LRU_ACTIVE_FILE = 3

结构 全局LRU {
    链表,
    计数,
}

定义 可变 全局lru = 空

函数 kswapd_主循环() {
    当 (真) {
        kswapd_睡眠中 = 真
        // 等待唤醒
        当 (kswapd_睡眠中) { schedule_yield() }

        kswapd_唤醒次数 = kswapd_唤醒次数 + 1

        // 平衡所有zone: 从低优先级开始,逐步提高
        定义 可变 优先级 = DEF_PRIORITY
        当 (优先级 >= MIN_PRIORITY) {
            定义 回收数 = shrink_节点(优先级)
            如果 (zone_水位OK_全部(0)) { 跳出 }
            优先级 = 优先级 - 1
        }
    }
}

函数 shrink_节点(优先级) {
    定义 可变 已回收 = 0

    // 扫描inactive文件页
    定义 文件扫描 = 全局lru.计数[LRU_INACTIVE_FILE] >> 优先级
    如果 (文件扫描 > 0) {
        已回收 = 已回收 + shrink_lru_inactive(LRU_INACTIVE_FILE, 文件扫描)
    }

    // 扫描inactive匿名页
    定义 匿名扫描 = 全局lru.计数[LRU_INACTIVE_ANON] >> 优先级
    如果 (匿名扫描 > 0) {
        已回收 = 已回收 + shrink_lru_inactive(LRU_INACTIVE_ANON, 匿名扫描)
    }

    // 老化active页→inactive
    老化active页(LRU_ACTIVE_FILE)
    老化active页(LRU_ACTIVE_ANON)

    回收_回收总数 = 回收_回收总数 + 已回收
    返回 已回收
}

函数 shrink_lru_inactive(lru类型, 扫描数) {
    定义 可变 已回收 = 0
    定义 可变 i = 0
    当 (i < 扫描数 && 全局lru.计数[lru类型] > 0) {
        定义 页 = 列表_取尾(全局lru.链表[lru类型])
        如果 (页 == 空) { 跳出 }
        全局lru.计数[lru类型] = 全局lru.计数[lru类型] - 1
        回收_扫描总数 = 回收_扫描总数 + 1

        // 被引用: 提升回active
        如果 (页_检查并清除引用(页)) {
            lru_提升到active(页, lru类型)
            i = i + 1
            继续
        }

        // 已锁定: 跳过
        如果 (页_已锁定(页)) {
            列表_加头(全局lru.链表[lru类型], 页)
            全局lru.计数[lru类型] = 全局lru.计数[lru类型] + 1
            i = i + 1
            继续
        }

        // 脏页: 提交回写
        如果 (页_是脏_kswapd(页)) {
            页_提交回写(页)
            回写总数 = 回写总数 + 1
            i = i + 1
            继续
        }

        // 干净页: 直接回收
        页_释放到伙伴(页)
        已回收 = 已回收 + 1
        i = i + 1
    }
    返回 已回收
}

函数 schedule_yield() {
    // 让出CPU: 将当前进程移到就绪队列末尾, 触发重新调度
    定义 当前 = 获取当前进程_调度()
    如果 (当前 != 空) {
        当前.状态 = 进程_就绪
        当前.需要重调 = 真
    }
}
函数 释放页(页, 阶) {
    // 将页面归还伙伴系统
    如果 (页 == 空) { 返回 }
    定义 页号 = 页.页号
    如果 (页号 < 0) { 返回 }
    // 清除页面标志
    页.标志 = 0
    页.引用计数 = 0
    // 加入伙伴系统空闲链表
    伙伴系统_添加空闲块(页号, 阶)
}
函数 列表_取尾(链表) {
    // 从LRU链表尾部取出一个元素(最久未访问)
    如果 (链表 == 空 || 计数(链表) == 0) { 返回 空 }
    定义 尾 = 链表[计数(链表) - 1]
    删除(链表, 计数(链表) - 1)
    返回 尾
}
函数 列表_加头(链表, 页) {
    // 将元素插入LRU链表头部(最近访问)
    如果 (链表 == 空 || 页 == 空) { 返回 }
    插入(链表, 0, 页)
}

// AI内存回收预测

定义 可变 AI_回收_预测窗口 = []

函数 AI_回收_记录(扫描数, 回收数) {
    追加(AI_回收_预测窗口, { 扫描: 扫描数, 回收: 回收数, 时间: 当前时间_纳秒() })
    如果 (计数(AI_回收_预测窗口) > 32) {
        AI_回收_预测窗口 = 子列表(AI_回收_预测窗口, 16, 32)
    }
}

函数 AI_回收_预测效率() {
    定义 n = 计数(AI_回收_预测窗口)
    如果 (n < 3) { 返回 50 }
    定义 可变 总扫描 = 0
    定义 可变 总回收 = 0
    定义 可变 i = 0
    当 (i < n) {
        总扫描 = 总扫描 + AI_回收_预测窗口[i].扫描
        总回收 = 总回收 + AI_回收_预测窗口[i].回收
        i = i + 1
    }
    如果 (总扫描 == 0) { 返回 0 }
    返回 总回收 * 100 / 总扫描
}

函数 AI_回收_建议优先级() {
    定义 效率 = AI_回收_预测效率()
    如果 (效率 > 70) { 返回 DEF_PRIORITY }
    如果 (效率 > 40) { 返回 DEF_PRIORITY - 2 }
    如果 (效率 > 20) { 返回 DEF_PRIORITY - 4 }
    返回 MIN_PRIORITY
}

函数 kswapd_健康检查() {
    定义 可变 问题 = []
    如果 (直接回收_次数 > kswapd_唤醒次数 * 2 && kswapd_唤醒次数 > 10) {
        追加(问题, "直接回收过多: kswapd可能响应太慢")
    }
    定义 效率 = AI_回收_预测效率()
    如果 (效率 < 10 && 回收_扫描总数 > 1000) {
        追加(问题, "回收效率极低: " + 整数转字符串(效率) + "%")
    }
    如果 (计数(问题) == 0) { 返回 "kswapd健康" }
    返回 问题
}

// 老化策略辅助

函数 老化_计算衰减权重(访问次数, 年龄) {
    如果 (年龄 == 0) { 返回 访问次数 * 100 }
    返回 访问次数 * 100 / (年龄 + 1)
}

函数 老化_判定冷页(权重) {
    返回 权重 < 老化_冷页阈值
}

定义 老化_冷页阈值 = 10

// merge source: 沙盒批次/批三/待厚/中枢/页面回收.nova
// NovaOS 页面回收 (kswapd / 直接回收)
// 职责: 内存不足时回收物理页, LRU扫描, shrink

定义 回收_优先级_初始 = 12     // 初始扫描比例 = 1/2^12
定义 回收_优先级_最大 = 0      // 最高优先级 = 扫描全部
定义 回收_批次大小 = 32        // 每次从LRU取多少页

定义 可变 swappiness = 60       // 匿名页回收倾向 (0-200, 60=默认)
定义 可变 脏页回写阈值 = 20    // 脏页比例超过此值触发回写 (%)

定义 可变 回收_扫描匿名页 = 0
定义 可变 回收_扫描文件页 = 0
定义 可变 回收_回收成功 = 0
定义 可变 回收_回收失败 = 0
定义 可变 回收_写回脏页 = 0
定义 可变 回收_直接回收次数 = 0
定义 可变 回收_kswapd唤醒次数 = 0

定义 可变 kswapd_运行中 = 假
定义 可变 kswapd_休眠中 = 真

// kswapd: 后台页面回收守护线程
// 当空闲页低于低水位线时被唤醒, 回收到高水位线

函数 kswapd_线程_回收() {
    kswapd_运行中 = 真
    当 (kswapd_运行中) {
        // 检查是否需要回收
        如果 (伙伴_检查水位(水位_高)) {
            // 空闲内存充足, 休眠
            kswapd_休眠中 = 真
            调度_休眠_等待条件(kswapd_需要唤醒)
            kswapd_休眠中 = 假
            回收_kswapd唤醒次数 = 回收_kswapd唤醒次数 + 1
        }

        // 回收到高水位线
        定义 可变 优先级 = 回收_优先级_初始
        当 (优先级 >= 回收_优先级_最大 && !伙伴_检查水位(水位_高)) {
            回收_扫描一轮(优先级)
            优先级 = 优先级 - 1
        }
    }
}

函数 kswapd_需要唤醒() {
    返回 !伙伴_检查水位(水位_低)
}

// 唤醒kswapd (分配失败时调用)
函数 kswapd_唤醒() {
    如果 (kswapd_休眠中) {
        调度_唤醒_条件(kswapd_需要唤醒)
    }
}

// 直接回收 (分配路径中同步回收)

函数 直接回收(需要页数) {
    回收_直接回收次数 = 回收_直接回收次数 + 1
    定义 可变 已回收 = 0
    定义 可变 优先级 = 回收_优先级_初始

    当 (已回收 < 需要页数 && 优先级 >= 回收_优先级_最大) {
        定义 本次回收 = 回收_扫描一轮(优先级)
        已回收 = 已回收 + 本次回收
        优先级 = 优先级 - 1
    }

    返回 已回收
}

// 核心回收逻辑: 扫描一轮

函数 回收_扫描一轮(优先级) {
    // 计算本轮扫描数量
    定义 扫描比 = 1 << 优先级
    定义 不活跃_匿名数 = LRU计数[LRU_不活跃_匿名]
    定义 不活跃_文件数 = LRU计数[LRU_不活跃_文件]

    // 根据swappiness决定匿名页和文件页的扫描比例
    定义 匿名_扫描 = (不活跃_匿名数 * swappiness) / (100 * 扫描比)
    定义 文件_扫描 = (不活跃_文件数 * (200 - swappiness)) / (100 * 扫描比)

    如果 (匿名_扫描 < 1) { 匿名_扫描 = 1 }
    如果 (文件_扫描 < 1) { 文件_扫描 = 1 }

    定义 可变 已回收 = 0

    // 优先回收文件页 (代价更低, 不需要写交换)
    如果 (不活跃_文件数 > 0) {
        已回收 = 已回收 + 收缩不活跃链表(LRU_不活跃_文件, 文件_扫描)
    }

    // 文件页不够, 回收匿名页
    如果 (已回收 < 回收_批次大小 && 不活跃_匿名数 > 0) {
        已回收 = 已回收 + 收缩不活跃链表(LRU_不活跃_匿名, 匿名_扫描)
    }

    // 同时进行活跃→不活跃的降级 (补充不活跃链表)
    收缩活跃链表(LRU_活跃_文件)
    收缩活跃链表(LRU_活跃_匿名)

    返回 已回收
}

// 收缩不活跃链表: 尝试回收不活跃页

函数 收缩不活跃链表(lru类型, 扫描数) {
    如果 (扫描数 > 回收_批次大小) { 扫描数 = 回收_批次大小 }

    // 从LRU尾部隔离页
    定义 隔离页 = LRU_隔离页(lru类型, 扫描数)
    定义 可变 已回收 = 0
    定义 可变 放回列表 = []

    定义 可变 i = 0
    当 (i < 计数(隔离页)) {
        定义 页号 = 隔离页[i]
        定义 页 = 页描述符_获取(页号)

        如果 (页 == 空) { i = i + 1  继续 }

        // 更新扫描统计
        如果 (lru类型 == LRU_不活跃_匿名) {
            回收_扫描匿名页 = 回收_扫描匿名页 + 1
        } 否则 {
            回收_扫描文件页 = 回收_扫描文件页 + 1
        }

        定义 回收结果 = 尝试回收单页(页号, 页)

        如果 (回收结果 == 回收_成功) {
            已回收 = 已回收 + 1
            回收_回收成功 = 回收_回收成功 + 1
        } 否则 如果 (回收结果 == 回收_保留) {
            // 页还在使用, 放回LRU
            追加(放回列表, 页号)
            回收_回收失败 = 回收_回收失败 + 1
        } 否则 如果 (回收结果 == 回收_激活) {
            // 页最近被访问, 提升为活跃
            LRU_激活页(页号)
        }

        i = i + 1
    }

    // 放回未回收的页
    LRU_放回页(lru类型, 放回列表)

    返回 已回收
}

定义 回收_成功 = 0
定义 回收_保留 = 1
定义 回收_激活 = 2
定义 回收_脏页 = 3

// 尝试回收单个页面

函数 尝试回收单页(页号, 页) {
    // 引用计数检查: 只有我们持有引用时才能回收
    如果 (页[PG_引用] > 1) {
        返回 回收_保留
    }

    // 检查是否最近被访问 (PTE的Accessed位)
    定义 引用数 = rmap_页面引用数(页号)
    如果 (引用数 > 0) {
        // 最近被访问, 不应回收, 提升为活跃
        返回 回收_激活
    }

    // 如果页面是脏的, 需要先回写
    如果 (页描述符_测试标志(页, 页_脏)) {
        // 文件页: 触发回写到磁盘
        如果 (页_是文件(页)) {
            // 将脏页加入回写队列
            回写_提交脏页(页号)
            回收_写回脏页 = 回收_写回脏页 + 1
        }
        // 匿名脏页: 需要写到交换空间
        // (简化: 暂不实现交换)
        返回 回收_脏页
    }

    // 取消所有映射 (通过反向映射)
    rmap_尝试取消全部映射(页号)

    // 再次检查引用计数
    如果 (页[PG_引用] > 0) {
        返回 回收_保留
    }

    // 释放物理页
    伙伴系统_释放(页号, 0)
    返回 回收_成功
}

// 收缩活跃链表: 将老化的活跃页降级为不活跃

函数 收缩活跃链表(lru类型) {
    // 只在不活跃链表太短时才降级
    定义 不活跃类型 = lru类型 - 1  // 活跃-1=不活跃
    如果 (LRU计数[不活跃类型] > LRU计数[lru类型] / 2) {
        返回  // 不活跃链表足够长
    }

    定义 扫描数 = 回收_批次大小 / 2
    定义 隔离页 = LRU_隔离页(lru类型, 扫描数)

    定义 可变 i = 0
    当 (i < 计数(隔离页)) {
        定义 页号 = 隔离页[i]
        定义 页 = 页描述符_获取(页号)

        如果 (页 != 空) {
            定义 引用数 = rmap_页面引用数(页号)
            如果 (引用数 > 0) {
                // 最近被访问, 保持活跃, 放回活跃链表头部
                链表_头插(LRU链表组[lru类型], 页号)
                LRU计数[lru类型] = LRU计数[lru类型] + 1
            } 否则 {
                // 未被访问, 降级为不活跃
                页描述符_清除标志(页, 页_活跃)
                链表_尾插(LRU链表组[不活跃类型], 页号)
                LRU计数[不活跃类型] = LRU计数[不活跃类型] + 1
                LRU_去激活次数 = LRU_去激活次数 + 1
            }
        }
        i = i + 1
    }
}

// 统计

函数 回收_统计() {
    返回 [回收_扫描匿名页, 回收_扫描文件页, 回收_回收成功, 回收_回收失败,
           回收_写回脏页, 回收_直接回收次数, 回收_kswapd唤醒次数]
}

// 回收成功率 + 完整统计

函数 回收_成功率() {
    定义 总 = 回收_回收成功 + 回收_回收失败
    如果 (总 == 0) { 返回 100 }
    返回 回收_回收成功 * 100 / 总
}

函数 回收_完整统计() {
    返回 [回收_扫描匿名页, 回收_扫描文件页, 回收_回收成功, 回收_回收失败,
           回收_成功率(), 回收_直接回收次数, 回收_kswapd唤醒次数]
}

// 页面回收健康检查

函数 回收_健康检查() {
    定义 可变 问题 = []
    如果 (回收_成功率() < 10 && 回收_扫描匿名页 + 回收_扫描文件页 > 1000) {
        追加(问题, "回收成功率极低: " + 整数转字符串(回收_成功率()) + "%")
    }
    如果 (回收_直接回收次数 > 回收_kswapd唤醒次数 * 3 && 回收_kswapd唤醒次数 > 10) {
        追加(问题, "直接回收过于频繁")
    }
    如果 (计数(问题) == 0) { 返回 "页面回收健康" }
    返回 问题
}

函数 回收_重置计数() {
    回收_扫描匿名页 = 0
    回收_扫描文件页 = 0
    回收_回收成功 = 0
    回收_回收失败 = 0
}

// merge source: 沙盒批次/批三/待厚/中枢/预读.nova
// NovaOS 预读 (Readahead)
// 职责: 文件顺序读时预测性预取后续页到缓存

定义 预读_初始窗口 = 4          // 初始预读4页 (16KB)
定义 预读_最大窗口 = 128        // 最大预读128页 (512KB)
定义 预读_增长因子 = 2          // 窗口增长倍率

定义 RA_起始 = 0               // 当前预读窗口起始页号
定义 RA_大小 = 1               // 当前预读窗口大小 (页)
定义 RA_异步 = 2               // 异步预读触发点
定义 RA_上次访问 = 3           // 上次访问的文件页号
定义 RA_命中计数 = 4           // 连续命中计数

函数 预读状态_创建() {
    返回 [0, 预读_初始窗口, 0, 0, 0]
}

定义 可变 预读_触发次数 = 0
定义 可变 预读_预取页数 = 0
定义 可变 预读_命中次数 = 0
定义 可变 预读_浪费页数 = 0

// 预读入口: 读文件时调用

函数 预读_检查(地址空间, ra, 当前页号) {
    定义 上次 = ra[RA_上次访问]

    // 判断是否为顺序读
    如果 (当前页号 == 上次 + 1) {
        // 顺序读: 增加命中计数
        设置(ra, RA_命中计数, ra[RA_命中计数] + 1)
        预读_命中次数 = 预读_命中次数 + 1

        // 检查是否到达异步预读触发点
        如果 (当前页号 >= ra[RA_起始] + ra[RA_异步]) {
            预读_扩展窗口(地址空间, ra, 当前页号)
        }
    } 否则 如果 (当前页号 == 上次) {
        // 重复读同一页, 不做预读
    } 否则 {
        // 非顺序 (随机读或跳跃): 重置预读状态
        设置(ra, RA_大小, 预读_初始窗口)
        设置(ra, RA_命中计数, 0)
        // 小范围预读
        预读_提交(地址空间, 当前页号, 预读_初始窗口)
    }

    设置(ra, RA_上次访问, 当前页号)
}

// 扩展预读窗口 (顺序读检测到时)

函数 预读_扩展窗口(地址空间, ra, 当前页号) {
    // 计算新的预读窗口大小
    定义 新大小 = ra[RA_大小] * 预读_增长因子
    如果 (新大小 > 预读_最大窗口) { 新大小 = 预读_最大窗口 }

    // 新窗口从当前位置开始
    定义 新起始 = 当前页号 + 1
    设置(ra, RA_起始, 新起始)
    设置(ra, RA_大小, 新大小)
    // 异步触发点设在窗口的3/4处
    设置(ra, RA_异步, 新大小 * 3 / 4)

    // 提交预读请求
    预读_提交(地址空间, 新起始, 新大小)
}

// 提交预读: 异步读取指定范围的页到缓存

函数 预读_提交(地址空间, 起始页号, 页数) {
    定义 可变 实际预取 = 0
    定义 可变 i = 0

    当 (i < 页数) {
        定义 文件页号 = 起始页号 + i
        // 检查是否已在缓存中
        定义 已缓存 = 页缓存_查找(地址空间, 文件页号)
        如果 (已缓存 >= 0) {
            // 已缓存, 跳过
            i = i + 1
            继续
        }

        // 分配物理页
        定义 物理页号 = 伙伴系统_分配_带标志(0, GFP_KERNEL)
        如果 (物理页号 < 0) { 中断 }  // 内存不足, 停止预读

        // 加入页面缓存
        页缓存_添加(地址空间, 文件页号, 物理页号)

        // 从磁盘读取 (异步IO)
        页缓存_从磁盘填充(地址空间, 文件页号, 物理页号)

        实际预取 = 实际预取 + 1
        i = i + 1
    }

    预读_触发次数 = 预读_触发次数 + 1
    预读_预取页数 = 预读_预取页数 + 实际预取
}

// 首次预读 (文件刚打开时)

函数 预读_首次(地址空间, ra) {
    设置(ra, RA_起始, 0)
    设置(ra, RA_大小, 预读_初始窗口)
    设置(ra, RA_异步, 预读_初始窗口 * 3 / 4)
    设置(ra, RA_上次访问, 0)
    设置(ra, RA_命中计数, 0)
    预读_提交(地址空间, 0, 预读_初始窗口)
}

// madvise(MADV_SEQUENTIAL/MADV_RANDOM) 预读提示

函数 预读_设置顺序(ra) {
    // 最大化预读窗口
    设置(ra, RA_大小, 预读_最大窗口)
}

函数 预读_设置随机(ra) {
    // 禁用预读
    设置(ra, RA_大小, 0)
}

// 统计

函数 预读_统计() {
    返回 [预读_触发次数, 预读_预取页数, 预读_命中次数, 预读_浪费页数]
}

// 预读命中率计算

函数 预读_命中率() {
    如果 (预读_预取页数 == 0) { 返回 100 }
    返回 预读_命中次数 * 100 / 预读_预取页数
}

函数 预读_浪费率() {
    如果 (预读_预取页数 == 0) { 返回 0 }
    返回 预读_浪费页数 * 100 / 预读_预取页数
}

// 自适应预读窗口调整 (基于命中率)

函数 预读_自适应调整(ra) {
    定义 命中率 = 预读_命中率()
    如果 (命中率 > 90) {
        // 高命中率: 激进增大窗口
        定义 新大小 = ra[RA_大小] * 2
        如果 (新大小 > 预读_最大窗口) { 新大小 = 预读_最大窗口 }
        设置(ra, RA_大小, 新大小)
    } 否则 如果 (命中率 < 50) {
        // 低命中率: 收缩窗口减少浪费
        定义 新大小 = ra[RA_大小] / 2
        如果 (新大小 < 预读_初始窗口) { 新大小 = 预读_初始窗口 }
        设置(ra, RA_大小, 新大小)
    }
}

// fadvise支持 

定义 FADV_NORMAL     = 0
定义 FADV_SEQUENTIAL = 2
定义 FADV_RANDOM     = 1
定义 FADV_WILLNEED   = 3
定义 FADV_DONTNEED   = 4

函数 预读_fadvise(地址空间, ra, 建议, 起始, 长度) {
    如果 (建议 == FADV_SEQUENTIAL) {
        预读_设置顺序(ra)
    } 否则 如果 (建议 == FADV_RANDOM) {
        预读_设置随机(ra)
    } 否则 如果 (建议 == FADV_WILLNEED) {
        // 立即预读指定范围
        定义 起始页 = 起始 / 页大小
        定义 页数 = (长度 + 页大小 - 1) / 页大小
        预读_提交(地址空间, 起始页, 页数)
    } 否则 如果 (建议 == FADV_DONTNEED) {
        // 标记页面可回收(不强制回收)
        预读_浪费页数 = 预读_浪费页数 + (长度 / 页大小)
    }
}

函数 预读_完整统计() {
    返回 [预读_触发次数, 预读_预取页数, 预读_命中次数,
           预读_浪费页数, 预读_命中率(), 预读_浪费率()]
}

// fadvise名称 + 预读窗口查询

函数 fadvise_名称(建议) {
    如果 (建议 == FADV_NORMAL) { 返回 "NORMAL" }
    如果 (建议 == FADV_SEQUENTIAL) { 返回 "SEQUENTIAL" }
    如果 (建议 == FADV_RANDOM) { 返回 "RANDOM" }
    如果 (建议 == FADV_WILLNEED) { 返回 "WILLNEED" }
    如果 (建议 == FADV_DONTNEED) { 返回 "DONTNEED" }
    返回 "UNKNOWN"
}

函数 预读_当前窗口(ra) {
    返回 [ra[RA_起始], ra[RA_大小], ra[RA_异步]]
}

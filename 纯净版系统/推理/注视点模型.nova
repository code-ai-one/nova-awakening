// §4 注视点模型 — 预测用户在页面上的注视位置
// 基于: 中央偏好 + 显著性 + 语义权重(标题/图片/视频吸引力高)

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("./全连接层.nova")
导入("../中枢/字符串替换.nova")
导入("./智能总线鼠标.nova")
导入("../中枢/网络激活层前.nova")
导入("./值乘.nova")

结构 注视点模型 {
    注视x,    // i32 当前预测注视点X (像素×Q10)
    注视y,    // i32 当前预测注视点Y
    衰减率,    // i32 注视点移动的平滑衰减
    中央偏好网络,    // u64 Nova多层感知器* 位置→中央偏好权重
}

函数 注视点模型_创建(视口宽, 视口高) {
    定义 gm = 堆_分配(注视点模型)
    // 初始注视: 页面中央偏上(F-pattern阅读习惯)
    gm.注视x = (视口宽 / 2) * Q_ONE
    gm.注视y = (视口高 / 3) * Q_ONE
    gm.衰减率 = 819    // 0.8 × 1024, 平滑系数

    // 中央偏好网络: 2D位置→偏好权重
    gm.中央偏好网络 = Nova多层感知器_创建(3)
    Nova多层感知器_添加层(gm.中央偏好网络, 2, 8, 激活类型_ReLU)
    Nova多层感知器_添加层(gm.中央偏好网络, 8, 1, 激活类型_Nova激活函数)

    返回 gm
}

// 更新注视点: 基于鼠标位置/滚动/点击事件
函数 注视点模型_更新(gm, 事件x, 事件y) {
    如果 (gm == 0) { 返回 }
    // 指数平滑: 注视 = α × 事件 + (1-α) × 旧注视
    gm.注视x = Q乘(Q_ONE - gm.衰减率, 事件x * Q_ONE) + Q乘(gm.衰减率, gm.注视x)
    gm.注视y = Q乘(Q_ONE - gm.衰减率, 事件y * Q_ONE) + Q乘(gm.衰减率, gm.注视y)
}

// 计算某个区域相对于注视点的衰减权重
// 离注视点越远, 权重越低 (模拟中央凹分辨率衰减)
// 返回Q10, 0~1024
函数 注视点模型_区域权重(gm, 区域x, 区域y, 区域w, 区域h) {
    如果 (gm == 0) { 返回 Q_ONE }

    // 区域中心到注视点的距离
    定义 中心x = (区域x + 区域w / 2) * Q_ONE
    定义 中心y = (区域y + 区域h / 2) * Q_ONE
    定义 dx = 中心x - gm.注视x
    定义 dy = 中心y - gm.注视y
    定义 距离² = Q乘(dx, dx) + Q乘(dy, dy)
    定义 距离 = Q开方(距离²)

    // 高斯衰减: weight = exp(-dist² / (2σ²))
    // σ = 视口宽度/4 (中央1/4区域为高质量区)
    定义 σ = 300 * Q_ONE    // ≈300像素
    定义 指数 = -Q除(距离², Q乘(2 * Q_ONE, Q乘(σ, σ)))

    定义 权重 = Q_exp(指数)
    如果 (权重 < 0) { 权重 = 0 }
    如果 (权重 > Q_ONE) { 权重 = Q_ONE }

    返回 权重
}

// §5 自适应渲染质量分配器
// 综合: 注视点权重 + 显著性 + JND + 语义重要性 → 渲染精度

定义 渲染级别_跳过     = 0    // 完全不渲染
定义 渲染级别_极低     = 1    // 只画纯色背景
定义 渲染级别_低       = 2    // 背景+简单轮廓
定义 渲染级别_中       = 3    // 标准渲染(跳过抗锯齿/阴影)
定义 渲染级别_高       = 4    // 完整渲染
定义 渲染级别_极高     = 5    // 超采样抗锯齿

结构 质量分配器 {
    注视点,    // u64 注视点模型*
    显著性,    // u64 显著性图*
    图处预算,    // u32 当前帧图处预算(微秒)
    帧目标,    // u32 目标帧时间(微秒) 默认16666=60fps
    上帧耗时,    // u32 上一帧实际耗时
    质量偏移,    // i32 全局质量偏移(-2~+2)
}

函数 质量分配器_创建(视口宽, 视口高) {
    定义 qa = 堆_分配(质量分配器)
    qa.注视点 = 注视点模型_创建(视口宽, 视口高)
    qa.显著性 = 0
    qa.图处预算 = 16666    // 60fps
    qa.帧目标 = 16666
    qa.上帧耗时 = 0
    qa.质量偏移 = 0
    返回 qa
}

// 为一个渲染区域决定渲染质量级别
函数 质量分配器_决定质量(qa, 区域x, 区域y, 区域w, 区域h, 语义重要性, 是否可见) {
    如果 (qa == 0) { 返回 渲染级别_中 }

    // 不可见: 跳过
    如果 (!是否可见) { 返回 渲染级别_跳过 }

    // 1. 注视点权重 [0, 1024]
    定义 注视权重 = 注视点模型_区域权重(qa.注视点, 区域x, 区域y, 区域w, 区域h)

    // 2. 语义重要性 [0, 1024]
    定义 语义 = 语义重要性    // 由调用者传入

    // 3. 综合得分 = 0.5 × 注视权重 + 0.35 × 语义 + 0.15 × 面积比
    定义 面积 = 区域w * 区域h
    定义 面积比 = Q除(面积 * Q_ONE, 500000 * Q_ONE)    // 归一化
    如果 (面积比 > Q_ONE) { 面积比 = Q_ONE }

    定义 综合得分 = Q乘(512, 注视权重) + Q乘(358, 语义) + Q乘(154, 面积比)

    // 4. 图处预算调整
    综合得分 = 综合得分 + qa.质量偏移 * (Q_ONE / 5)

    // 5. 映射到渲染级别
    如果 (综合得分 >= 850) { 返回 渲染级别_极高 }
    如果 (综合得分 >= 650) { 返回 渲染级别_高 }
    如果 (综合得分 >= 400) { 返回 渲染级别_中 }
    如果 (综合得分 >= 200) { 返回 渲染级别_低 }
    如果 (综合得分 >= 50) { 返回 渲染级别_极低 }
    返回 渲染级别_跳过
}

// 帧结束后调整全局质量偏移(自适应帧率)
函数 质量分配器_帧反馈(qa, 实际耗时) {
    如果 (qa == 0) { 返回 }
    qa.上帧耗时 = 实际耗时

    如果 (实际耗时 > qa.帧目标 * 120 / 100) {
        // 超预算20%: 降低质量
        如果 (qa.质量偏移 > -2) { qa.质量偏移 = qa.质量偏移 - 1 }
    }
    否则 如果 (实际耗时 < qa.帧目标 * 70 / 100) {
        // 低于预算70%: 有余力, 提高质量
        如果 (qa.质量偏移 < 2) { qa.质量偏移 = qa.质量偏移 + 1 }
    }
}

// §6 注视点销毁与重置

函数 注视点模型_销毁(gm) {
    如果 (gm == 0) { 返回 }
    如果 (gm.中央偏好网络 != 0) {
        Nova多层感知器_销毁(gm.中央偏好网络)
        gm.中央偏好网络 = 0
    }
}

函数 注视点模型_重置(gm, 视口宽, 视口高) {
    如果 (gm == 0) { 返回 }
    gm.注视x = (视口宽 / 2) * Q_ONE
    gm.注视y = (视口高 / 3) * Q_ONE
}

函数 质量分配器_销毁(qa) {
    如果 (qa == 0) { 返回 }
    注视点模型_销毁(qa.注视点)
    qa.注视点 = 0
}

函数 质量分配器_更新视口(qa, 新宽, 新高) {
    如果 (qa == 0) { 返回 }
    如果 (qa.注视点 != 0) {
        注视点模型_重置(qa.注视点, 新宽, 新高)
    }
}

// §7 F-pattern阅读模型 — 基于眼动研究的页面注视预测
// Nielsen (2006): 用户阅读网页时遵循F形模式
//   - 先水平扫描顶部(标题栏)
//   - 然后向下移动, 再水平扫描(第二段)
//   - 最后沿左侧垂直扫描

定义 Q_ONE = 1024
定义 Q_HALF = 512

结构 F_Pattern模型 {
    视口宽,           // 视口像素宽
    视口高,           // 视口像素高
    顶部权重,         // Q10 顶部水平条权重
    中部权重,         // Q10 中部水平条权重
    左侧权重,         // Q10 左侧垂直条权重
    中心偏好强度,     // Q10 中央偏好高斯强度
    阅读方向,         // 0=从左到右 1=从右到左
}

函数 F_Pattern_创建(视口宽, 视口高) {
    定义 模型 = F_Pattern模型 {}
    模型.视口宽 = 视口宽
    模型.视口高 = 视口高
    模型.顶部权重 = 900
    模型.中部权重 = 700
    模型.左侧权重 = 600
    模型.中心偏好强度 = 800
    模型.阅读方向 = 0
    返回 模型
}

函数 F_Pattern_区域权重(模型, 区域x, 区域y, 区域w, 区域h) {
    如果 (模型 == 0) { 返回 Q_HALF }
    定义 中心x = 区域x + 区域w / 2
    定义 中心y = 区域y + 区域h / 2
    定义 可变 权重 = Q_HALF

    // 顶部水平条: y < 视口高/4, 全宽
    如果 (中心y < 模型.视口高 / 4) {
        权重 = 权重 + (模型.顶部权重 * (模型.视口高 / 4 - 中心y)) / (模型.视口高 / 4)
    }

    // 中部水平条: 视口高/4 < y < 视口高/2, 宽度2/3
    如果 (中心y > 模型.视口高 / 4 && 中心y < 模型.视口高 / 2) {
        如果 (中心x < 模型.视口宽 * 2 / 3) {
            权重 = 权重 + 模型.中部权重 / 3
        }
    }

    // 左侧垂直条: x < 视口宽/4
    如果 (中心x < 模型.视口宽 / 4) {
        权重 = 权重 + 模型.左侧权重 / 4
    }

    // 中央偏好(高斯)
    定义 dx = 中心x - 模型.视口宽 / 2
    定义 dy = 中心y - 模型.视口高 / 3
    定义 距离2 = dx * dx + dy * dy
    定义 σ2 = (模型.视口宽 / 3) * (模型.视口宽 / 3)
    如果 (σ2 > 0) {
        定义 衰减 = Q_ONE - (距离2 * Q_ONE) / (2 * σ2)
        如果 (衰减 < 0) { 衰减 = 0 }
        权重 = 权重 + (模型.中心偏好强度 * 衰减) / Q_ONE / 4
    }

    如果 (权重 > Q_ONE) { 权重 = Q_ONE }
    如果 (权重 < 0) { 权重 = 0 }
    返回 权重
}

// §8 多焦点注视 — 支持多个高注意力区域(AI检测)

定义 最大焦点数 = 8

结构 焦点 {
    x,                // 焦点中心x
    y,                // 焦点中心y
    半径,             // 影响半径
    强度,             // Q10注意力强度
    衰减速度,         // Q10衰减速率
    创建帧,           // 创建时的帧计数
    存活帧数,         // 最大存活帧数
}

结构 多焦点管理器 {
    焦点列表,         // 焦点数组
    焦点数量,
    当前帧,
}

函数 多焦点_创建() {
    定义 管理器 = 多焦点管理器 {}
    管理器.焦点列表 = []
    管理器.焦点数量 = 0
    管理器.当前帧 = 0
    返回 管理器
}

函数 多焦点_添加(管理器, x, y, 半径, 强度) {
    如果 (管理器 == 0) { 返回 }
    如果 (管理器.焦点数量 >= 最大焦点数) {
        // 替换最弱的焦点
        定义 可变 最弱idx = 0
        定义 可变 最弱强度 = Q_ONE
        定义 可变 i = 0
        当 (i < 管理器.焦点数量) {
            如果 (管理器.焦点列表[i].强度 < 最弱强度) {
                最弱强度 = 管理器.焦点列表[i].强度
                最弱idx = i
            }
            i = i + 1
        }
        如果 (强度 > 最弱强度) {
            删除(管理器.焦点列表, 最弱idx)
            管理器.焦点数量 = 管理器.焦点数量 - 1
        } 否则 {
            返回
        }
    }

    定义 新焦点 = 焦点 {}
    新焦点.x = x
    新焦点.y = y
    新焦点.半径 = 半径
    新焦点.强度 = 强度
    新焦点.衰减速度 = 10
    新焦点.创建帧 = 管理器.当前帧
    新焦点.存活帧数 = 300
    追加(管理器.焦点列表, 新焦点)
    管理器.焦点数量 = 管理器.焦点数量 + 1
}

函数 多焦点_更新帧(管理器) {
    如果 (管理器 == 0) { 返回 }
    管理器.当前帧 = 管理器.当前帧 + 1

    // 衰减所有焦点强度, 移除过期焦点
    定义 可变 i = 0
    当 (i < 管理器.焦点数量) {
        定义 年龄 = 管理器.当前帧 - 管理器.焦点列表[i].创建帧
        如果 (年龄 > 管理器.焦点列表[i].存活帧数 || 管理器.焦点列表[i].强度 <= 0) {
            删除(管理器.焦点列表, i)
            管理器.焦点数量 = 管理器.焦点数量 - 1
        } 否则 {
            管理器.焦点列表[i].强度 = 管理器.焦点列表[i].强度 - 管理器.焦点列表[i].衰减速度
            如果 (管理器.焦点列表[i].强度 < 0) { 管理器.焦点列表[i].强度 = 0 }
            i = i + 1
        }
    }
}

函数 多焦点_区域权重(管理器, 区域x, 区域y, 区域w, 区域h) {
    如果 (管理器 == 0 || 管理器.焦点数量 == 0) { 返回 0 }
    定义 中心x = 区域x + 区域w / 2
    定义 中心y = 区域y + 区域h / 2
    定义 可变 最大权重 = 0

    定义 可变 i = 0
    当 (i < 管理器.焦点数量) {
        定义 焦 = 管理器.焦点列表[i]
        定义 dx = 中心x - 焦.x
        定义 dy = 中心y - 焦.y
        定义 距离2 = dx * dx + dy * dy
        定义 半径2 = 焦.半径 * 焦.半径
        如果 (距离2 < 半径2) {
            定义 权重 = (焦.强度 * (半径2 - 距离2)) / 半径2
            如果 (权重 > 最大权重) { 最大权重 = 权重 }
        }
        i = i + 1
    }

    返回 最大权重
}

// §9 综合注视权重 — 合并注视点+F-Pattern+多焦点

函数 综合注视权重(gm, f_pattern, 多焦点, 区域x, 区域y, 区域w, 区域h) {
    定义 可变 总权重 = 0

    // 注视点权重 (40%)
    如果 (gm != 0) {
        定义 注视 = 注视点模型_区域权重(gm, 区域x, 区域y, 区域w, 区域h)
        总权重 = 总权重 + (注视 * 410) / Q_ONE
    }

    // F-Pattern权重 (30%)
    如果 (f_pattern != 0) {
        定义 f权重 = F_Pattern_区域权重(f_pattern, 区域x, 区域y, 区域w, 区域h)
        总权重 = 总权重 + (f权重 * 307) / Q_ONE
    }

    // 多焦点权重 (30%)
    如果 (多焦点 != 0) {
        定义 焦点权重 = 多焦点_区域权重(多焦点, 区域x, 区域y, 区域w, 区域h)
        总权重 = 总权重 + (焦点权重 * 307) / Q_ONE
    }

    如果 (总权重 > Q_ONE) { 总权重 = Q_ONE }
    返回 总权重
}

// §10 统计

结构 注视统计 {
    总更新次数,
    注视点移动距离累计,// u64 像素
    平均注视停留时间,  // u32 帧
    焦点创建总数,
    焦点过期总数,
    质量调整次数,
    降级次数,
    升级次数,
}

定义 可变 全局注视统计 = 0

函数 注视统计_初始化() {
    定义 s = 注视统计 {}
    s.总更新次数 = 0
    s.注视点移动距离累计 = 0
    s.平均注视停留时间 = 0
    s.焦点创建总数 = 0
    s.焦点过期总数 = 0
    s.质量调整次数 = 0
    s.降级次数 = 0
    s.升级次数 = 0
    全局注视统计 = s
    返回 s
}

函数 注视统计_打印() {
    如果 (全局注视统计 == 0) {
        打印("[注视点] 统计未初始化")
        返回
    }
    定义 s = 全局注视统计
    打印("[注视点] ═══ 注视点模型统计 ═══")
    打印(字符串拼接("  总更新次数: ", 转字符串(s.总更新次数)))
    打印(字符串拼接("  注视移动累计: ", 字符串拼接(转字符串(s.注视点移动距离累计), "px")))
    打印(字符串拼接("  平均停留时间: ", 字符串拼接(转字符串(s.平均注视停留时间), "帧")))
    打印(字符串拼接("  焦点创建总数: ", 转字符串(s.焦点创建总数)))
    打印(字符串拼接("  质量调整次数: ", 转字符串(s.质量调整次数)))
    打印(字符串拼接("  降级/升级: ", 字符串拼接(转字符串(s.降级次数), "/", 转字符串(s.升级次数))))
    打印("[注视点] ═══════════════════════")
}

// §11 质量平滑器 — 防止渲染质量突变导致闪烁

结构 质量平滑器 {
    上次质量,         // 每个区域的上次质量级别数组
    区域数,
    平滑系数,         // Q10 (越大越平滑, 变化越慢)
}

函数 质量平滑器_创建(区域数) {
    定义 平滑器 = 质量平滑器 {}
    平滑器.区域数 = 区域数
    平滑器.平滑系数 = 819
    平滑器.上次质量 = []
    定义 可变 i = 0
    当 (i < 区域数) {
        追加(平滑器.上次质量, 3)
        i = i + 1
    }
    返回 平滑器
}

函数 质量平滑器_销毁(平滑器) {
    如果 (平滑器 == 0) { 返回 }
    平滑器.上次质量 = []
    平滑器.区域数 = 0
}

函数 质量平滑器_平滑(平滑器, 区域索引, 目标质量) {
    如果 (平滑器 == 0 || 区域索引 >= 平滑器.区域数) { 返回 目标质量 }
    定义 上次 = 平滑器.上次质量[区域索引]
    // 指数平滑
    定义 平滑 = (平滑器.平滑系数 * 上次 + (Q_ONE - 平滑器.平滑系数) * 目标质量) / Q_ONE
    设置(平滑器.上次质量, 区域索引, 平滑)
    返回 平滑
}

// §12 AI注视点预测 — 使用神经网络预测注视区域

函数 注视点_AI预测(bus, 页面布局特征) {
    如果 (bus == 0 || 页面布局特征 == 0) { 返回 空 }

    // AI: 使用注意力网络预测页面上最可能的注视区域
    定义 注意力分数 = AI总线_注意力权重(bus, 页面布局特征)
    返回 注意力分数
}

函数 注视点_AI自适应衰减(bus, gm) {
    如果 (bus == 0 || gm == 0) { 返回 }
    // AI: 快速移动时降低衰减率(更快跟踪), 慢速时增加(更平滑)
    如果 (bus.滚动速度 > 20) {
        gm.衰减率 = 512
    } 否则 如果 (bus.滚动速度 < 3) {
        gm.衰减率 = 921
    } 否则 {
        gm.衰减率 = 819
    }
}

函数 注视点_获取当前坐标(gm) {
    如果 (gm == 0) { 返回 [0, 0] }
    返回 [gm.注视x / Q_ONE, gm.注视y / Q_ONE]
}

函数 注视点_设置衰减率(gm, 新衰减率) {
    如果 (gm == 0) { 返回 }
    如果 (新衰减率 < 100) { 新衰减率 = 100 }
    如果 (新衰减率 > 990) { 新衰减率 = 990 }
    gm.衰减率 = 新衰减率
}

// NovaOS 链表遍历回调引擎 — 觉醒理论·函数式链表操作
// 原创理论: NovaListFP — 遍历/映射/归约/过滤 + hlist + AI模式
// §1 正向/反向遍历: 带回调的安全迭代
// §2 映射与转换: 对每个元素应用转换函数
// §3 归约与聚合: 累积计算（求和/最大/最小/计数）
// §4 过滤与搜索: 条件过滤/查找第一个/查找所有
// §5 批量操作: 弹出首/弹出末/清空/替换/旋转
// §6 hlist单向哈希链表: 创建/头插/删除/遍历/查找
// §7 安全遍历: 遍历中允许删除当前节点
// §8 AI遍历模式检测: 追踪遍历模式，预测下次遍历方向
// §9 完整统计: 15+指标
// 四阶段AI演进: 本模块属于第一阶段（基础设施层）

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./日志中枢.nova")
导入("./列表加头加尾.nova")
导入("./链表后继.nova")
导入("./字符串替换.nova")
导入("./链表移到头部.nova")

函数 链表_遍历(头, 回调) {
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        回调(当前[链_数据])
        当前 = 当前[链_后继]
    }
}

函数 链表_反向遍历(头, 回调) {
    定义 可变 当前 = 头[链_前驱]
    当 (当前 != 头) {
        回调(当前[链_数据])
        当前 = 当前[链_前驱]
    }
}

函数 链表_映射(头, 转换函数) {
    // 对每个元素应用转换, 返回结果列表
    定义 可变 结果 = []
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        追加(结果, 转换函数(当前[链_数据]))
        当前 = 当前[链_后继]
    }
    返回 结果
}

函数 链表_归约(头, 初始值, 归约函数) {
    定义 可变 累积 = 初始值
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        累积 = 归约函数(累积, 当前[链_数据])
        当前 = 当前[链_后继]
    }
    返回 累积
}

// §7 批量操作

函数 链表_弹出首(头) {
    如果 (链表_为空(头)) { 返回 空 }
    定义 首 = 头[链_后继]
    链表_删除(首)
    返回 首[链_数据]
}

函数 链表_弹出末(头) {
    如果 (链表_为空(头)) { 返回 空 }
    定义 末 = 头[链_前驱]
    链表_删除(末)
    返回 末[链_数据]
}

函数 链表_清空(头) {
    当 (!链表_为空(头)) {
        链表_删除(头[链_后继])
    }
}

函数 链表_第N个(头, 索引) {
    定义 可变 当前 = 头[链_后继]
    定义 可变 i = 0
    当 (当前 != 头) {
        如果 (i == 索引) { 返回 当前[链_数据] }
        当前 = 当前[链_后继]
        i = i + 1
    }
    返回 空
}

函数 链表_替换(旧节点, 新节点) {
    // 用新节点替换旧节点的位置
    设置(新节点, 链_前驱, 旧节点[链_前驱])
    设置(新节点, 链_后继, 旧节点[链_后继])
    设置(旧节点[链_前驱], 链_后继, 新节点)
    设置(旧节点[链_后继], 链_前驱, 新节点)
}

函数 链表_旋转(头) {
    // 将首节点移到末尾
    如果 (链表_为空(头)) { 返回 }
    定义 首 = 头[链_后继]
    链表_移到尾部(头, 首)
}

// §8 hlist: 单向哈希链表
// Nova内核哈希表的桶用hlist(节省内存: 头只有一个指针)

// hlist头: [第一个节点] (只有first指针)
// hlist节点: [下一个, 前驱指针的地址, 数据]
定义 H_下一个 = 0
定义 H_前驱指针 = 1
定义 H_数据 = 2

函数 hlist_创建() { 返回 [空] }  // [first]

函数 hlist_为空(头) { 返回 头[0] == 空 }

函数 hlist_头插(头, 数据) {
    定义 新节点 = [头[0], 头, 数据]
    如果 (头[0] != 空) {
        设置(头[0], H_前驱指针, 新节点)  // 旧first的pprev指向新节点
    }
    设置(头, 0, 新节点)  // 头的first指向新节点
    返回 新节点
}

函数 hlist_删除(节点) {
    定义 下一个 = 节点[H_下一个]
    定义 前驱 = 节点[H_前驱指针]
    如果 (前驱 != 空) {
        设置(前驱, 0, 下一个)  // *pprev = next
    }
    如果 (下一个 != 空) {
        设置(下一个, H_前驱指针, 前驱)
    }
}

函数 hlist_遍历(头, 回调) {
    定义 可变 当前 = 头[0]
    当 (当前 != 空) {
        定义 下一个 = 当前[H_下一个]
        回调(当前[H_数据])
        当前 = 下一个
    }
}

函数 hlist_查找(头, 目标) {
    定义 可变 当前 = 头[0]
    当 (当前 != 空) {
        如果 (当前[H_数据] == 目标) { 返回 当前 }
        当前 = 当前[H_下一个]
    }
    返回 空
}

函数 hlist_长度(头) {
    定义 可变 数 = 0
    定义 可变 当前 = 头[0]
    当 (当前 != 空) { 数 = 数 + 1; 当前 = 当前[H_下一个] }
    返回 数
}

定义 AI模式窗口 = 16
定义 遍历方向_正向 = 0
定义 遍历方向_反向 = 1
定义 链_后继 = 1
定义 链_前驱 = 0
定义 链_数据 = 2

结构 遍历统计 {
    正向遍历次数: 整数,
    反向遍历次数: 整数,
    映射次数: 整数,
    归约次数: 整数,
    过滤次数: 整数,
    查找首次数: 整数,
    查找所有次数: 整数,
    弹出首次数: 整数,
    弹出末次数: 整数,
    清空次数: 整数,
    替换次数: 整数,
    旋转次数: 整数,
    安全遍历次数: 整数,
    hlist操作次数: 整数,
    AI模式记录数: 整数,
    AI模式命中数: 整数,
    回调执行总数: 整数,
    错误次数: 整数,
}

定义 可变 全局统计 = 遍历统计 {}
定义 可变 遍历模块已初始化 = 假
定义 可变 AI模式历史 = []
定义 可变 AI模式位置 = 0


函数 遍历模块_初始化() {
    如果 (遍历模块已初始化 == 真) { 返回 0 - 17 }
    AI模式历史 = []
    定义 可变 i = 0
    当 (i < AI模式窗口) {
        追加(AI模式历史, 0)
        i = i + 1
    }
    AI模式位置 = 0
    遍历模块已初始化 = 真
    打印("[遍历回调] 初始化完成")
    返回 0
}

函数 遍历模块_销毁() {
    如果 (遍历模块已初始化 == 假) { 返回 0 }
    AI模式历史 = []
    遍历模块已初始化 = 假
    打印("[遍历回调] 已销毁")
    返回 0
}


函数 链表_安全遍历(头, 回调) {
    如果 (头 == 空 || 回调 == 空) { 返回 }
    全局统计.安全遍历次数 = 全局统计.安全遍历次数 + 1
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        // 先保存下一个节点，防止回调中删除当前节点导致迭代断裂
        定义 下一个 = 当前[链_后继]
        回调(当前[链_数据])
        全局统计.回调执行总数 = 全局统计.回调执行总数 + 1
        当前 = 下一个
    }
}

函数 链表_安全反向遍历(头, 回调) {
    如果 (头 == 空 || 回调 == 空) { 返回 }
    全局统计.安全遍历次数 = 全局统计.安全遍历次数 + 1
    定义 可变 当前 = 头[链_前驱]
    当 (当前 != 头) {
        定义 前一个 = 当前[链_前驱]
        回调(当前[链_数据])
        全局统计.回调执行总数 = 全局统计.回调执行总数 + 1
        当前 = 前一个
    }
}


函数 链表_遍历_计数(头, 回调) {
    // 遍历并返回回调返回真的次数
    如果 (头 == 空 || 回调 == 空) { 返回 0 }
    全局统计.正向遍历次数 = 全局统计.正向遍历次数 + 1
    定义 可变 计数 = 0
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        定义 下一个 = 当前[链_后继]
        如果 (回调(当前[链_数据]) == 真) { 计数 = 计数 + 1 }
        全局统计.回调执行总数 = 全局统计.回调执行总数 + 1
        当前 = 下一个
    }
    返回 计数
}

函数 链表_遍历_带索引(头, 回调) {
    // 回调接收(数据, 索引)
    如果 (头 == 空 || 回调 == 空) { 返回 }
    全局统计.正向遍历次数 = 全局统计.正向遍历次数 + 1
    定义 可变 索引 = 0
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        回调(当前[链_数据], 索引)
        全局统计.回调执行总数 = 全局统计.回调执行总数 + 1
        当前 = 当前[链_后继]
        索引 = 索引 + 1
    }
}


函数 链表_遍历_直到(头, 回调) {
    // 遍历直到回调返回真（类似find_if）
    如果 (头 == 空 || 回调 == 空) { 返回 空 }
    全局统计.查找首次数 = 全局统计.查找首次数 + 1
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        如果 (回调(当前[链_数据]) == 真) {
            返回 当前[链_数据]
        }
        全局统计.回调执行总数 = 全局统计.回调执行总数 + 1
        当前 = 当前[链_后继]
    }
    返回 空
}

函数 链表_查找所有(头, 条件) {
    // 返回所有满足条件的元素列表
    如果 (头 == 空 || 条件 == 空) { 返回 [] }
    全局统计.查找所有次数 = 全局统计.查找所有次数 + 1
    定义 可变 结果 = []
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        如果 (条件(当前[链_数据]) == 真) {
            追加(结果, 当前[链_数据])
        }
        当前 = 当前[链_后继]
    }
    返回 结果
}


函数 链表_映射_过滤(头, 转换函数, 条件函数) {
    // 先过滤再映射
    如果 (头 == 空) { 返回 [] }
    全局统计.映射次数 = 全局统计.映射次数 + 1
    全局统计.过滤次数 = 全局统计.过滤次数 + 1
    定义 可变 结果 = []
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        如果 (条件函数 == 空 || 条件函数(当前[链_数据]) == 真) {
            追加(结果, 转换函数(当前[链_数据]))
        }
        当前 = 当前[链_后继]
    }
    返回 结果
}

函数 链表_扁平映射(头, 转换函数) {
    // 转换函数返回列表，合并所有结果
    如果 (头 == 空 || 转换函数 == 空) { 返回 [] }
    全局统计.映射次数 = 全局统计.映射次数 + 1
    定义 可变 结果 = []
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        定义 子结果 = 转换函数(当前[链_数据])
        如果 (子结果 != 空) {
            定义 可变 k = 0
            当 (k < 计数(子结果)) {
                追加(结果, 子结果[k])
                k = k + 1
            }
        }
        当前 = 当前[链_后继]
    }
    返回 结果
}


函数 链表_求和(头) {
    定义 可变 总和 = 0
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        总和 = 总和 + 当前[链_数据]
        当前 = 当前[链_后继]
    }
    全局统计.归约次数 = 全局统计.归约次数 + 1
    返回 总和
}

函数 链表_最大值(头) {
    定义 可变 最大 = 0
    定义 可变 已找到 = 假
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        如果 (已找到 == 假 || 当前[链_数据] > 最大) {
            最大 = 当前[链_数据]
            已找到 = 真
        }
        当前 = 当前[链_后继]
    }
    全局统计.归约次数 = 全局统计.归约次数 + 1
    返回 最大
}

函数 链表_最小值(头) {
    定义 可变 最小 = 0
    定义 可变 已找到 = 假
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        如果 (已找到 == 假 || 当前[链_数据] < 最小) {
            最小 = 当前[链_数据]
            已找到 = 真
        }
        当前 = 当前[链_后继]
    }
    全局统计.归约次数 = 全局统计.归约次数 + 1
    返回 最小
}

函数 链表_平均值(头) {
    定义 可变 总和 = 0
    定义 可变 计数 = 0
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        总和 = 总和 + 当前[链_数据]
        计数 = 计数 + 1
        当前 = 当前[链_后继]
    }
    如果 (计数 == 0) { 返回 0 }
    返回 总和 / 计数
}


函数 hlist_安全遍历(头, 回调) {
    如果 (头 == 空 || 回调 == 空) { 返回 }
    全局统计.hlist操作次数 = 全局统计.hlist操作次数 + 1
    定义 可变 当前 = 头[0]
    当 (当前 != 空) {
        定义 下一个 = 当前[H_下一个]
        回调(当前[H_数据])
        全局统计.回调执行总数 = 全局统计.回调执行总数 + 1
        当前 = 下一个
    }
}

函数 hlist_映射(头, 转换函数) {
    如果 (头 == 空 || 转换函数 == 空) { 返回 [] }
    全局统计.hlist操作次数 = 全局统计.hlist操作次数 + 1
    定义 可变 结果 = []
    定义 可变 当前 = 头[0]
    当 (当前 != 空) {
        追加(结果, 转换函数(当前[H_数据]))
        当前 = 当前[H_下一个]
    }
    返回 结果
}

函数 hlist_过滤查找(头, 条件) {
    如果 (头 == 空 || 条件 == 空) { 返回 [] }
    全局统计.hlist操作次数 = 全局统计.hlist操作次数 + 1
    定义 可变 结果 = []
    定义 可变 当前 = 头[0]
    当 (当前 != 空) {
        如果 (条件(当前[H_数据]) == 真) {
            追加(结果, 当前[H_数据])
        }
        当前 = 当前[H_下一个]
    }
    返回 结果
}

函数 hlist_包含(头, 目标) {
    返回 hlist_查找(头, 目标) != 空
}

函数 hlist_清空(头) {
    如果 (头 == 空) { 返回 }
    当 (头[0] != 空) {
        定义 当前 = 头[0]
        设置(头, 0, 当前[H_下一个])
    }
}


函数 AI_记录遍历方向(方向) {
    设置(AI模式历史, AI模式位置, 方向)
    AI模式位置 = (AI模式位置 + 1) % AI模式窗口
    全局统计.AI模式记录数 = 全局统计.AI模式记录数 + 1
}

函数 AI_预测遍历方向() {
    // 统计正向/反向遍历的比例
    定义 可变 正向数 = 0
    定义 可变 反向数 = 0
    定义 可变 i = 0
    当 (i < AI模式窗口) {
        如果 (AI模式历史[i] == 遍历方向_正向) { 正向数 = 正向数 + 1 }
        否则 如果 (AI模式历史[i] == 遍历方向_反向) { 反向数 = 反向数 + 1 }
        i = i + 1
    }
    如果 (正向数 > 反向数 * 2) {
        全局统计.AI模式命中数 = 全局统计.AI模式命中数 + 1
        返回 遍历方向_正向
    }
    如果 (反向数 > 正向数 * 2) {
        全局统计.AI模式命中数 = 全局统计.AI模式命中数 + 1
        返回 遍历方向_反向
    }
    返回 遍历方向_正向
}

函数 AI_建议预取方向() {
    定义 方向 = AI_预测遍历方向()
    如果 (方向 == 遍历方向_正向) { 返回 "正向预取后继节点" }
    返回 "反向预取前驱节点"
}


函数 遍历回调_转储() {
    打印("[遍历回调] ═══ 状态转储 ═══")
    打印(字符串拼接("  正向遍历: ", 转字符串(全局统计.正向遍历次数)))
    打印(字符串拼接("  反向遍历: ", 转字符串(全局统计.反向遍历次数)))
    打印(字符串拼接("  安全遍历: ", 转字符串(全局统计.安全遍历次数)))
    打印(字符串拼接("  回调执行总数: ", 转字符串(全局统计.回调执行总数)))
    打印(字符串拼接("  AI建议: ", AI_建议预取方向()))
    返回 0
}


函数 遍历回调_打印统计() {
    打印("[遍历回调] ═══ 运行统计 ═══")
    打印(字符串拼接("  正向遍历: ", 转字符串(全局统计.正向遍历次数)))
    打印(字符串拼接("  反向遍历: ", 转字符串(全局统计.反向遍历次数)))
    打印(字符串拼接("  映射次数: ", 转字符串(全局统计.映射次数)))
    打印(字符串拼接("  归约次数: ", 转字符串(全局统计.归约次数)))
    打印(字符串拼接("  过滤次数: ", 转字符串(全局统计.过滤次数)))
    打印(字符串拼接("  查找首: ", 转字符串(全局统计.查找首次数)))
    打印(字符串拼接("  查找所有: ", 转字符串(全局统计.查找所有次数)))
    打印(字符串拼接("  弹出首: ", 转字符串(全局统计.弹出首次数)))
    打印(字符串拼接("  弹出末: ", 转字符串(全局统计.弹出末次数)))
    打印(字符串拼接("  替换次数: ", 转字符串(全局统计.替换次数)))
    打印(字符串拼接("  安全遍历: ", 转字符串(全局统计.安全遍历次数)))
    打印(字符串拼接("  hlist操作: ", 转字符串(全局统计.hlist操作次数)))
    打印(字符串拼接("  AI模式记录: ", 转字符串(全局统计.AI模式记录数)))
    打印(字符串拼接("  AI模式命中: ", 转字符串(全局统计.AI模式命中数)))
    打印(字符串拼接("  回调执行总数: ", 转字符串(全局统计.回调执行总数)))
    打印(字符串拼接("  错误次数: ", 转字符串(全局统计.错误次数)))
    返回 0
}


函数 遍历回调_注册到内核(内核上下文) {
    如果 (遍历模块已初始化 == 假) { 返回 0 - 1 }
    打印("[遍历回调] 已注册到内核上下文")
    返回 0
}

函数 遍历回调_查询状态() {
    如果 (遍历模块已初始化 == 假) { 返回 0 }
    返回 1
}

函数 遍历回调_健康检查() {
    如果 (遍历模块已初始化 == 假) { 返回 假 }
    如果 (全局统计.错误次数 * 10 > 全局统计.回调执行总数) { 返回 假 }
    返回 真
}

导入("../基础.nova")

// UTF8 编解码原生实现
// 目标: 避免旧式逻辑连写和单行函数，保证 stage1 自举稳定

函数 UTF8_记录操作() {
    // 监控钩子: 可挂载统计/日志，当前为no-op
    返回 0
}

函数 UTF8_utf8_编码(码点) {
    UTF8_记录操作()
    如果 (码点 < 0x80) {
        返回 [码点]
    }
    如果 (码点 < 0x800) {
        返回 [0xC0 + 码点 / 64, 0x80 + 码点 % 64]
    }
    如果 (码点 < 0x10000) {
        返回 [0xE0 + 码点 / 4096, 0x80 + (码点 / 64) % 64, 0x80 + 码点 % 64]
    }
    返回 [0xF0 + 码点 / 262144, 0x80 + (码点 / 4096) % 64, 0x80 + (码点 / 64) % 64, 0x80 + 码点 % 64]
}

函数 UTF8_utf8_解码(字节列表, 位置) {
    UTF8_记录操作()
    定义 b0 = 字节列表[位置]
    如果 (b0 < 0x80) {
        返回 [b0, 1]
    }
    如果 (b0 < 0xE0) {
        定义 b1 = 字节列表[位置 + 1]
        返回 [(b0 - 0xC0) * 64 + (b1 - 0x80), 2]
    }
    如果 (b0 < 0xF0) {
        定义 b1 = 字节列表[位置 + 1]
        定义 b2 = 字节列表[位置 + 2]
        返回 [(b0 - 0xE0) * 4096 + (b1 - 0x80) * 64 + (b2 - 0x80), 3]
    }
    定义 b1 = 字节列表[位置 + 1]
    定义 b2 = 字节列表[位置 + 2]
    定义 b3 = 字节列表[位置 + 3]
    返回 [(b0 - 0xF0) * 262144 + (b1 - 0x80) * 4096 + (b2 - 0x80) * 64 + (b3 - 0x80), 4]
}

函数 utf8_字符数(文本) {
    UTF8_记录操作()
    定义 可变 数量 = 0
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        定义 b = 字节取(文本, i)
        如果 (b < 0x80) {
            i = i + 1
        } 否则 {
            如果 (b < 0xE0) {
                i = i + 2
            } 否则 {
                如果 (b < 0xF0) {
                    i = i + 3
                } 否则 {
                    i = i + 4
                }
            }
        }
        数量 = 数量 + 1
    }
    返回 数量
}

函数 utf8_偏移(文本, n) {
    UTF8_记录操作()
    定义 可变 数量 = 0
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        如果 (数量 >= n) {
            返回 i
        }
        定义 b = 字节取(文本, i)
        如果 (b < 0x80) {
            i = i + 1
        } 否则 {
            如果 (b < 0xE0) {
                i = i + 2
            } 否则 {
                如果 (b < 0xF0) {
                    i = i + 3
                } 否则 {
                    i = i + 4
                }
            }
        }
        数量 = 数量 + 1
    }
    返回 i
}

函数 字符_是数字(c) {
    如果 (c >= 字符_零) {
        如果 (c <= 字符_九) { 返回 1 }
    }
    返回 0
}

函数 字符_是大写(c) {
    如果 (c >= 字符_大写A) {
        如果 (c <= 字符_大写Z) { 返回 1 }
    }
    返回 0
}

函数 字符_是小写(c) {
    如果 (c >= 字符_小写a) {
        如果 (c <= 字符_小写z) { 返回 1 }
    }
    返回 0
}

函数 字符_是字母(c) {
    如果 (字符_是大写(c) == 1) { 返回 1 }
    如果 (字符_是小写(c) == 1) { 返回 1 }
    返回 0
}

函数 字符_是空白(c) {
    如果 (c == 字符_空格) { 返回 1 }
    如果 (c == 字符_制表) { 返回 1 }
    如果 (c == 字符_换行) { 返回 1 }
    如果 (c == 字符_回车) { 返回 1 }
    返回 0
}

函数 字符_是十六进制(c) {
    如果 (字符_是数字(c) == 1) { 返回 1 }
    如果 (c >= 字符_大写A) {
        如果 (c <= 70) { 返回 1 }
    }
    如果 (c >= 字符_小写a) {
        如果 (c <= 字符_小写f) { 返回 1 }
    }
    返回 0
}

函数 字符_是标点(c) {
    如果 (c >= 33) {
        如果 (c <= 字符_斜杠) { 返回 1 }
    }
    如果 (c >= 字符_冒号) {
        如果 (c <= 64) { 返回 1 }
    }
    如果 (c >= 字符_左方括) {
        如果 (c <= 96) { 返回 1 }
    }
    如果 (c >= 字符_左花括) {
        如果 (c <= 126) { 返回 1 }
    }
    返回 0
}

函数 字符_是可打印(c) {
    如果 (c >= 字符_空格) {
        如果 (c <= 126) { 返回 1 }
    }
    返回 0
}

函数 字符_转大写(c) {
    如果 (c >= 字符_小写a) {
        如果 (c <= 字符_小写z) { 返回 c - 32 }
    }
    返回 c
}

函数 字符_转小写(c) {
    如果 (c >= 字符_大写A) {
        如果 (c <= 字符_大写Z) { 返回 c + 32 }
    }
    返回 c
}

函数 unicode_是CJK(码点) {
    如果 (码点 >= 0x4E00) {
        如果 (码点 <= 0x9FFF) { 返回 1 }
    }
    如果 (码点 >= 0x3400) {
        如果 (码点 <= 0x4DBF) { 返回 1 }
    }
    如果 (码点 >= 0x20000) {
        如果 (码点 <= 0x2A6DF) { 返回 1 }
    }
    返回 0
}

函数 unicode_是假名(码点) {
    如果 (码点 >= 0x3040) {
        如果 (码点 <= 0x309F) { 返回 1 }
    }
    如果 (码点 >= 0x30A0) {
        如果 (码点 <= 0x30FF) { 返回 1 }
    }
    返回 0
}

函数 字符串_去首尾空白(文本) {
    UTF8_记录操作()
    定义 可变 起始 = 0
    当 (起始 < 字节长度(文本)) {
        如果 (字符_是空白(字节取(文本, 起始)) == 1) {
            起始 = 起始 + 1
        } 否则 {
            断
        }
    }

    如果 (起始 >= 字节长度(文本)) {
        返回 ""
    }

    定义 可变 结束 = 字节长度(文本) - 1
    当 (结束 > 起始) {
        如果 (字符_是空白(字节取(文本, 结束)) == 1) {
            结束 = 结束 - 1
        } 否则 {
            断
        }
    }
    返回 子串(文本, 起始, 结束 - 起始 + 1)
}

函数 字符串_全大写(文本) {
    UTF8_记录操作()
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        结果 = 字符串拼接(结果, 字符(字符_转大写(字节取(文本, i))))
        i = i + 1
    }
    返回 结果
}

函数 字符串_全小写(文本) {
    UTF8_记录操作()
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        结果 = 字符串拼接(结果, 字符(字符_转小写(字节取(文本, i))))
        i = i + 1
    }
    返回 结果
}

函数 UTF8_字符串_重复(文本, 次数) {
    UTF8_记录操作()
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 次数) {
        结果 = 字符串拼接(结果, 文本)
        i = i + 1
    }
    返回 结果
}

函数 UTF8_字符串_反转(文本) {
    UTF8_记录操作()
    如果 (字节长度(文本) == 0) {
        返回 ""
    }
    定义 可变 结果 = ""
    定义 可变 i = 字节长度(文本) - 1
    当 (i >= 0) {
        结果 = 字符串拼接(结果, 字符(字节取(文本, i)))
        i = i - 1
    }
    返回 结果
}

函数 utf8_以开头(文本, 前缀) {
    UTF8_记录操作()
    如果 (字节长度(前缀) > 字节长度(文本)) { 返回 0 }
    定义 可变 i = 0
    当 (i < 字节长度(前缀)) {
        如果 (字节取(文本, i) != 字节取(前缀, i)) { 返回 0 }
        i = i + 1
    }
    返回 1
}

函数 utf8_以结尾(文本, 后缀) {
    UTF8_记录操作()
    如果 (字节长度(后缀) > 字节长度(文本)) { 返回 0 }
    定义 偏移 = 字节长度(文本) - 字节长度(后缀)
    定义 可变 i = 0
    当 (i < 字节长度(后缀)) {
        如果 (字节取(文本, 偏移 + i) != 字节取(后缀, i)) { 返回 0 }
        i = i + 1
    }
    返回 1
}

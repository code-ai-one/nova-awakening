导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("./值乘.nova")

// §1.3 微积分 (Calculus) — 反向传播的数学基础
// 链式法则(Chain Rule):
//   ∂L/∂w = ∂L/∂y × ∂y/∂w
//   这是所有神经网络训练的数学根基
// 激活函数导数:
//   ReLU'(x) = { 1 if x>0, 0 if x≤0 }
//   Nova激活函数'(x) = σ(x)(1-σ(x))
//   Tanh'(x) = 1 - tanh²(x)
//   GELU'(x) ≈ 0.5(1 + tanh(√(2/π)(x+0.044715x³))) + ...
// 梯度下降收敛条件(凸函数):
//   学习率 η < 2/L, 其中L是Lipschitz常数
//   Nova在线学习使用 η = 0.001, 安全范围内

// ReLU导数: 定点实现

函数 导数_ReLU(x) {
    如果 (x > 0) { 返回 Q_ONE }
    返回 Q_ZERO
}

// Nova激活函数导数: σ'(x) = σ(x)(1-σ(x))
函数 导数_Nova激活函数(Nova激活函数_输出) {
    返回 Q乘(Nova激活函数_输出, Q_ONE - Nova激活函数_输出)
}

// Tanh导数: tanh'(x) = 1 - tanh²(x)
函数 导数_Tanh(tanh_输出) {
    返回 Q_ONE - Q乘(tanh_输出, tanh_输出)
}

// 数值梯度验证: ∂f/∂x ≈ (f(x+ε) - f(x-ε)) / (2ε)
// 用于验证解析梯度的正确性
函数 数值梯度_验证(f, x, 解析导数) {
    定义 epsilon = 10    // Q10下约0.01
    定义 f正 = f(x + epsilon)
    定义 f负 = f(x - epsilon)
    定义 数值导数 = Q除(f正 - f负, 2 * epsilon)
    定义 差 = 解析导数 - 数值导数
    如果 (差 < 0) { 差 = -差 }
    返回 差 < 50    // 容忍约0.05误差(定点截断)
}

// §1.4 概率论与信息论 (Probability & Information Theory)
// ① Nova归一化指数: P(class_i) = exp(z_i) / Σ_j exp(z_j)
//    性质: 输出和为1, 保序, 温度参数T控制尖锐度
//    数值稳定: 先减最大值 z_i - max(z)
// ② 交叉熵: H(p,q) = -Σ p_i log(q_i)
//    衡量预测分布q与真实分布p的差距
//    当且仅当 p=q 时 H(p,q) = H(p) 取最小值
// ③ KL散度: D_KL(p||q) = Σ p_i log(p_i/q_i) ≥ 0
//    衡量两个分布的差异, 不对称
// ④ 贝叶斯定理: P(A|B) = P(B|A)P(A) / P(B)
//    Nova用于: 给定用户行为B, 推断意图A的后验概率
// ⑤ 香农信息熵: H(X) = -Σ p(x) log₂ p(x)
//    Nova用于: 衡量DOM节点内容的信息量→高熵=重要

// 交叉熵损失: L = -Σ 目标_i × log(预测_i)
函数 交叉熵(预测, 目标, 维度) {
    定义 可变 损失 = 0
    定义 可变 i = 0
    当 (i < 维度) {
        定义 p = Tensor_读(预测, 0, i)
        定义 t = Tensor_读(目标, 0, i)
        如果 (p < 1) { p = 1 }    // 防止log(0)
        定义 log_p = Q_log(p)
        损失 = 损失 - Q乘(t, log_p)
        i = i + 1
    }
    返回 损失
}

// 定点log: ln(x), 用查表+线性插值
// ln(1024) = ln(1.0) = 0, ln(2048) = ln(2.0) ≈ 710
函数 Q_log(x) {
    如果 (x <= 0) { 返回 -10 * Q_ONE }
    // 归一化到[0.5, 1.0)区间, 用 ln(a×2^n) = ln(a) + n×ln(2)
    定义 可变 n = 0
    定义 可变 a = x
    当 (a >= 2 * Q_ONE) { a = a >> 1; n = n + 1 }
    当 (a < Q_ONE) { a = a << 1; n = n - 1 }
    // a ∈ [Q_ONE, 2×Q_ONE), 用多项式逼近 ln(1+t), t = a/Q_ONE - 1
    定义 t = a - Q_ONE    // t ∈ [0, Q_ONE)
    // ln(1+t) ≈ t - t²/2 + t³/3 (Q10)
    定义 t2 = Q乘(t, t)
    定义 t3 = Q乘(t2, t)
    定义 ln_a = t - (t2 >> 1) + Q除(t3, 3 * Q_ONE)
    // ln(2) ≈ 0.693 × 1024 ≈ 710
    返回 ln_a + n * 710
}

// 信息熵: H = -Σ p_i × log₂(p_i)
函数 信息熵(概率分布, 维度) {
    定义 可变 H = 0
    定义 可变 i = 0
    当 (i < 维度) {
        定义 p = Tensor_读(概率分布, 0, i)
        如果 (p > 0) {
            定义 log_p = Q_log(p)
            // log₂(p) = ln(p) / ln(2)
            定义 log2_p = Q除(log_p, 710)
            H = H - Q乘(p, log2_p)
        }
        i = i + 1
    }
    返回 H
}

// KL散度: D_KL(P||Q) = Σ p_i × log(p_i / q_i)
函数 KL散度(P, Q_分布, 维度) {
    定义 可变 D = 0
    定义 可变 i = 0
    当 (i < 维度) {
        定义 p = Tensor_读(P, 0, i)
        定义 q = Tensor_读(Q_分布, 0, i)
        如果 (p > 0 && q > 0) {
            定义 比值 = Q除(p, q)
            D = D + Q乘(p, Q_log(比值))
        }
        i = i + 1
    }
    返回 D
}

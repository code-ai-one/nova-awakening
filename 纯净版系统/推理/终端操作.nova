导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/硬链接.nova")
导入("../标准/进程接口.nova")
导入("../标准/原生字符串.nova")
导入("../中枢/整数转字符串.nova")
导入("../标准/原生通道.nova")
导入("../中枢/时钟中枢.nova")
导入("../中枢/进程创建完.nova")

定义 终端_超时默认 = 30000
定义 终端_超时最大 = 300000
定义 终端_输出上限 = 1048576
定义 终端_历史上限 = 100
定义 终端_管道缓冲 = 4096

定义 危险级别_安全 = 0
定义 危险级别_警告 = 1
定义 危险级别_禁止 = 2

定义 危险命令 = ["rm -rf /", "mkfs", "dd if=", ":(){:|:&};:", "chmod -R 777 /",
    "shutdown", "reboot", "init 0", "halt", "poweroff"]

定义 警告命令 = ["rm -r", "chmod", "chown", "kill -9", "pkill", "iptables"]

结构 终端执行结果 {
    成功,
    输出,
    错误输出,
    错误,
    退出码,
    耗时毫秒,
    输出截断,
}

结构 终端历史条目 {
    命令,
    时间戳,
    退出码,
    耗时毫秒,
    输出大小,
}

结构 终端沙箱配置 {
    允许网络,
    允许写文件,
    工作目录,
    超时毫秒,
    最大输出,
    环境变量,
}

定义 可变 终端_历史列表 = []
定义 可变 终端_总执行数 = 0
定义 可变 终端_总拦截数 = 0
定义 可变 终端_总超时数 = 0
定义 可变 终端_总成功数 = 0

函数 智能体终端_执行(命令) {
    定义 配置 = 终端沙箱配置 {}
    配置.允许网络 = 真
    配置.允许写文件 = 真
    配置.工作目录 = 进程_当前目录()
    配置.超时毫秒 = 终端_超时默认
    配置.最大输出 = 终端_输出上限
    返回 智能体终端_执行_沙箱(命令, 配置)
}

函数 智能体终端_执行_沙箱(命令, 配置) {
    终端_总执行数 = 终端_总执行数 + 1
    定义 开始时间 = 读取毫秒()

    定义 危险等级 = 智能体终端_评估危险(命令)
    如果 (危险等级 == 危险级别_禁止) {
        终端_总拦截数 = 终端_总拦截数 + 1
        返回 终端执行结果 {
            成功: 假, 输出: "", 错误输出: "",
            错误: "危险命令被拦截: " + 命令, 退出码: -1,
            耗时毫秒: 0, 输出截断: 假
        }
    }

    定义 stdout管道 = 管道_创建()
    定义 stderr管道 = 管道_创建()
    如果 (stdout管道 < 0 || stderr管道 < 0) {
        返回 终端执行结果 {
            成功: 假, 输出: "", 错误输出: "",
            错误: "管道创建失败", 退出码: -1,
            耗时毫秒: 0, 输出截断: 假
        }
    }

    定义 pid = 进程_fork()
    如果 (pid < 0) {
        管道_关闭(stdout管道)
        管道_关闭(stderr管道)
        返回 终端执行结果 {
            成功: 假, 输出: "", 错误输出: "",
            错误: "进程创建失败", 退出码: -1,
            耗时毫秒: 0, 输出截断: 假
        }
    }

    如果 (pid == 0) {
        管道_重定向(stdout管道, 1)
        管道_重定向(stderr管道, 2)

        如果 (配置.工作目录 != 0) { 进程_切换目录(配置.工作目录) }

        如果 (配置.环境变量 != 0) {
            定义 可变 i = 0
            当 (i < 计数(配置.环境变量)) {
                进程_设置环境(配置.环境变量[i].名, 配置.环境变量[i].值)
                i = i + 1
            }
        }

        进程_exec("/bin/sh", ["-c", 命令])
        进程_exit(127)
    }

    定义 可变 输出 = ""
    定义 可变 错误输出 = ""
    定义 可变 超时计数 = 0
    定义 超时限制 = 配置.超时毫秒
    定义 可变 输出截断 = 假

    当 (超时计数 < 超时限制) {
        定义 数据 = 管道_读取(stdout管道, 终端_管道缓冲)
        如果 (数据 == 空) { 跳出 }

        如果 (字符串长度(输出) + 字符串长度(数据) > 配置.最大输出) {
            输出截断 = 真
            跳出
        }
        输出 = 输出 + 数据

        定义 err数据 = 管道_读取_非阻塞(stderr管道, 终端_管道缓冲)
        如果 (err数据 != 空) { 错误输出 = 错误输出 + err数据 }

        超时计数 = 超时计数 + 100
    }

    定义 可变 退出码 = 0
    如果 (超时计数 >= 超时限制) {
        进程_kill(pid, 9)
        终端_总超时数 = 终端_总超时数 + 1
        管道_关闭(stdout管道)
        管道_关闭(stderr管道)

        定义 耗时 = 读取毫秒() - 开始时间
        智能体终端_记录历史(命令, -1, 耗时, 字符串长度(输出))

        返回 终端执行结果 {
            成功: 假, 输出: 输出, 错误输出: 错误输出,
            错误: "命令超时(" + 整数转字符串(超时限制 / 1000) + "s)",
            退出码: -1, 耗时毫秒: 耗时, 输出截断: 输出截断
        }
    }

    退出码 = 进程_wait_pid(pid)
    管道_关闭(stdout管道)
    管道_关闭(stderr管道)

    定义 耗时 = 读取毫秒() - 开始时间
    如果 (退出码 == 0) { 终端_总成功数 = 终端_总成功数 + 1 }

    智能体终端_记录历史(命令, 退出码, 耗时, 字符串长度(输出))

    返回 终端执行结果 {
        成功: 退出码 == 0, 输出: 输出, 错误输出: 错误输出,
        错误: "", 退出码: 退出码, 耗时毫秒: 耗时, 输出截断: 输出截断
    }
}

函数 智能体终端_执行并捕获(命令) {
    定义 结果 = 智能体终端_执行(命令)
    返回 结果.输出
}

函数 智能体终端_执行管道(命令列表) {
    如果 (命令列表 == 0 || 计数(命令列表) == 0) { 返回 0 }
    定义 完整命令 = ""
    定义 可变 i = 0
    当 (i < 计数(命令列表)) {
        如果 (i > 0) { 完整命令 = 完整命令 + " | " }
        完整命令 = 完整命令 + 命令列表[i]
        i = i + 1
    }
    返回 智能体终端_执行(完整命令)
}

函数 智能体终端_评估危险(命令) {
    定义 可变 i = 0
    当 (i < 计数(危险命令)) {
        如果 (字符串包含(命令, 危险命令[i])) { 返回 危险级别_禁止 }
        i = i + 1
    }
    i = 0
    当 (i < 计数(警告命令)) {
        如果 (字符串包含(命令, 警告命令[i])) { 返回 危险级别_警告 }
        i = i + 1
    }
    如果 (字符串包含(命令, "sudo")) { 返回 危险级别_警告 }
    如果 (字符串包含(命令, ">") && 字符串包含(命令, "/dev/")) { 返回 危险级别_禁止 }
    返回 危险级别_安全
}

函数 智能体终端_记录历史(命令, 退出码, 耗时, 输出大小) {
    定义 条目 = 终端历史条目 {}
    条目.命令 = 命令
    条目.时间戳 = 读取毫秒()
    条目.退出码 = 退出码
    条目.耗时毫秒 = 耗时
    条目.输出大小 = 输出大小

    追加(终端_历史列表, 条目)
    如果 (计数(终端_历史列表) > 终端_历史上限) {
        终端_历史列表 = 切片(终端_历史列表, 计数(终端_历史列表) - 终端_历史上限)
    }
}

函数 智能体终端_历史(最近n条) {
    定义 总数 = 计数(终端_历史列表)
    如果 (最近n条 <= 0 || 最近n条 > 总数) { 返回 终端_历史列表 }
    返回 切片(终端_历史列表, 总数 - 最近n条)
}

函数 智能体终端_工作目录() { 返回 进程_当前目录() }
函数 智能体终端_环境变量(名) { 返回 进程_获取环境(名) }

函数 智能体终端_统计() {
    返回 {
        总执行: 终端_总执行数,
        总成功: 终端_总成功数,
        总拦截: 终端_总拦截数,
        总超时: 终端_总超时数,
        历史数: 计数(终端_历史列表)
    }
}

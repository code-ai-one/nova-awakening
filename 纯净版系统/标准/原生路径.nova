导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/字符串工具完.nova")

定义 分隔符 = 47
定义 最大路径 = 4096
定义 最大组件 = 128

函数 路径_拼接(甲, 乙) {
    定义 甲长 = 字串_长度(甲)
    定义 乙长 = 字串_长度(乙)
    如果 (甲长 == 0) { 返回 乙 }
    如果 (乙长 == 0) { 返回 甲 }
    定义 结果 = 堆_分配(甲长 + 乙长 + 2)
    内存_复制(结果, 甲, 甲长)
    如果 (内存_读8(甲 + 甲长 - 1) != 分隔符) {
        内存_写8(结果 + 甲长, 分隔符)
        内存_复制(结果 + 甲长 + 1, 乙, 乙长)
        内存_写8(结果 + 甲长 + 1 + 乙长, 0)
    } 否则 {
        内存_复制(结果 + 甲长, 乙, 乙长)
        内存_写8(结果 + 甲长 + 乙长, 0)
    }
    返回 结果
}

函数 路径_最后分隔(路径, 长度) {
    定义 可变 位 = 长度 - 1
    当 (位 >= 0) {
        如果 (内存_读8(路径 + 位) == 分隔符) { 返回 位 }
        位 = 位 - 1
    }
    返回 -1
}

函数 路径_目录名(路径) {
    定义 长度 = 字串_长度(路径)
    定义 最后 = 路径_最后分隔(路径, 长度)
    如果 (最后 <= 0) { 返回 "/" }
    定义 结果 = 堆_分配(最后 + 1)
    内存_复制(结果, 路径, 最后)
    内存_写8(结果 + 最后, 0)
    返回 结果
}

函数 路径_文件名(路径) {
    定义 长度 = 字串_长度(路径)
    定义 最后 = 路径_最后分隔(路径, 长度)
    如果 (最后 < 0) { 返回 路径 }
    定义 名长 = 长度 - 最后 - 1
    定义 结果 = 堆_分配(名长 + 1)
    内存_复制(结果, 路径 + 最后 + 1, 名长)
    内存_写8(结果 + 名长, 0)
    返回 结果
}

函数 路径_扩展名(路径) {
    定义 名 = 路径_文件名(路径)
    定义 名长 = 字串_长度(名)
    定义 可变 点位 = 名长 - 1
    当 (点位 >= 0) {
        如果 (内存_读8(名 + 点位) == 46) {
            定义 扩展长 = 名长 - 点位 - 1
            定义 结果 = 堆_分配(扩展长 + 1)
            内存_复制(结果, 名 + 点位 + 1, 扩展长)
            内存_写8(结果 + 扩展长, 0)
            返回 结果
        }
        点位 = 点位 - 1
    }
    返回 ""
}

函数 路径_无扩展名(路径) {
    定义 长度 = 字串_长度(路径)
    定义 可变 点位 = 长度 - 1
    当 (点位 >= 0) {
        定义 字节 = 内存_读8(路径 + 点位)
        如果 (字节 == 46) {
            定义 结果 = 堆_分配(点位 + 1)
            内存_复制(结果, 路径, 点位)
            内存_写8(结果 + 点位, 0)
            返回 结果
        }
        如果 (字节 == 分隔符) { 跳出 }
        点位 = 点位 - 1
    }
    返回 路径
}

函数 路径_是绝对(路径) {
    如果 (字串_长度(路径) == 0) { 返回 假 }
    返回 内存_读8(路径) == 分隔符
}

函数 路径_规范化(路径) {
    定义 长度 = 字串_长度(路径)
    定义 结果 = 堆_分配(长度 + 1)
    定义 可变 读位 = 0
    定义 可变 写位 = 0
    当 (读位 < 长度) {
        定义 字节 = 内存_读8(路径 + 读位)
        如果 (字节 == 分隔符) {
            如果 (写位 == 0 || 内存_读8(结果 + 写位 - 1) != 分隔符) {
                内存_写8(结果 + 写位, 分隔符)
                写位 = 写位 + 1
            }
        } 否则 {
            内存_写8(结果 + 写位, 字节)
            写位 = 写位 + 1
        }
        读位 = 读位 + 1
    }
    如果 (写位 > 1 && 内存_读8(结果 + 写位 - 1) == 分隔符) {
        写位 = 写位 - 1
    }
    内存_写8(结果 + 写位, 0)
    返回 结果
}

函数 路径_深度(路径) {
    定义 长度 = 字串_长度(路径)
    定义 可变 深度 = 0
    定义 可变 位 = 0
    当 (位 < 长度) {
        如果 (内存_读8(路径 + 位) == 分隔符) { 深度 = 深度 + 1 }
        位 = 位 + 1
    }
    返回 深度
}

函数 路径_匹配扩展(路径, 扩展) {
    定义 实际扩展 = 路径_扩展名(路径)
    返回 字串_比较(实际扩展, 扩展) == 0
}

函数 路径_是隐藏(路径) {
    定义 名 = 路径_文件名(路径)
    如果 (字串_长度(名) == 0) { 返回 假 }
    返回 内存_读8(名) == 46
}

函数 路径_父级(路径, 级数) {
    定义 可变 当前 = 路径
    定义 可变 层 = 0
    当 (层 < 级数) {
        当前 = 路径_目录名(当前)
        层 = 层 + 1
    }
    返回 当前
}

函数 路径_相等(甲, 乙) {
    返回 字串_比较(甲, 乙) == 0
}

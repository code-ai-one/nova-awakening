函数 设置重定向(重定向) {
    // 输入重定向: < file
    如果 (重定向.输入 != 空) {
        定义 fd = sys_open(重定向.输入, O_RDONLY, 0, 0, 0, 0)
        如果 (fd >= 0) {
            sys_dup2(fd, 0, 0, 0, 0, 0)   // fd → stdin
            sys_close(fd, 0, 0, 0, 0, 0)
        } 否则 {
            打印错误("龙壳: " + 重定向.输入 + ": 无法打开")
        }
    }

    // 输出重定向: > file
    如果 (重定向.输出 != 空) {
        定义 标志 = O_WRONLY | O_CREAT
        如果 (重定向.追加) { 标志 = 标志 | O_APPEND }
        否则 { 标志 = 标志 | O_TRUNC }
        定义 fd = sys_open(重定向.输出, 标志, 0o644, 0, 0, 0)
        如果 (fd >= 0) {
            sys_dup2(fd, 1, 0, 0, 0, 0)   // fd → stdout
            sys_close(fd, 0, 0, 0, 0, 0)
        } 否则 {
            打印错误("龙壳: " + 重定向.输出 + ": 无法打开")
        }
    }

    // 错误重定向: 2> file
    如果 (重定向.错误 != 空) {
        定义 fd = sys_open(重定向.错误, O_WRONLY | O_CREAT | O_TRUNC, 0o644, 0, 0, 0)
        如果 (fd >= 0) {
            sys_dup2(fd, 2, 0, 0, 0, 0)   // fd → stderr
            sys_close(fd, 0, 0, 0, 0, 0)
        }
    }

    // 2>&1: stderr合并到stdout
    如果 (重定向.合并错误) {
        sys_dup2(1, 2, 0, 0, 0, 0)
    }
}

// PATH查找可执行文件 

函数 查找可执行文件(名称) {
    // 包含/的路径: 直接使用
    如果 (字符串包含(名称, "/")) {
        如果 (路径_存在(名称)) { 返回 名称 }
        返回 空
    }

    // 在PATH中查找
    定义 path = 环境_获取("PATH")
    如果 (path == "") { path = "/bin:/usr/bin" }
    定义 目录列表 = 字符串分割(path, ":")

    定义 可变 i = 0
    当 (i < 计数(目录列表)) {
        定义 完整路径 = 目录列表[i] + "/" + 名称
        如果 (路径_存在(完整路径)) {
            返回 完整路径
        }
        i = i + 1
    }
    返回 空
}

// 信号处理 

函数 龙壳_设置信号() {
    // 交互终端忽略SIGINT(不被Ctrl+C杀死), 转发给前台进程组
    信号_设置处理(2, 信号_忽略)   // SIGINT
    // SIGTSTP: 忽略(不被Ctrl+Z暂停)
    信号_设置处理(20, 信号_忽略)  // SIGTSTP
    // SIGCHLD: 回收后台zombie
    信号_设置处理(17, 龙壳_SIGCHLD处理)
}

函数 子进程_恢复信号() {
    // 子进程恢复SIGINT/SIGTSTP为默认行为
    信号_设置处理(2, 信号_默认)   // SIGINT
    信号_设置处理(20, 信号_默认)  // SIGTSTP
}

// 脚本执行

函数 龙壳_执行脚本(文件路径) {
    定义 fd = sys_open(文件路径, O_RDONLY, 0, 0, 0, 0)
    如果 (fd < 0) {
        打印错误("龙壳: " + 文件路径 + ": 无法打开")
        返回 1
    }

    // 逐行读取执行
    定义 可变 行号 = 0
    定义 可变 退出码 = 0
    循环 {
        定义 行 = 文件_读取行(fd)
        如果 (行 == 空) { 中断 }  // EOF
        行号 = 行号 + 1
        定义 去空白 = 字符串去首尾空白(行)
        如果 (去空白 == "" || 字符串取字符(去空白, 0) == "#") { 继续 }
        退出码 = 龙壳_执行行(去空白)
    }

    sys_close(fd, 0, 0, 0, 0, 0)
    返回 退出码
}

函数 龙壳_执行单行(命令) {
    返回 龙壳_执行行(命令)
}

// 辅助工具

函数 分割_分号(行) {
    // 分割分号, 但忽略引号内的分号
    定义 可变 结果 = []
    定义 可变 当前 = ""
    定义 可变 单引号内 = 假
    定义 可变 双引号内 = 假
    定义 可变 i = 0

    当 (i < 字符串长度(行)) {
        定义 ch = 字符串取字符(行, i)
        如果 (ch == "'" && !双引号内) { 单引号内 = !单引号内 }
        否则 如果 (ch == "\"" && !单引号内) { 双引号内 = !双引号内 }
        否则 如果 (ch == ";" && !单引号内 && !双引号内) {
            追加(结果, 当前)
            当前 = ""
            i = i + 1
            继续
        }
        当前 = 当前 + ch
        i = i + 1
    }
    如果 (当前 != "") { 追加(结果, 当前) }
    返回 结果
}

函数 打印错误(消息) {
    // 输出到stderr(fd=2)
    sys_write(2, 消息 + "\n", 字符串长度(消息) + 1, 0, 0, 0)
}

定义 可变 AI_设置重定向_负载窗口 = []

函数 AI_设置重定向_负载预测(当前负载) {
    追加(AI_设置重定向_负载窗口, 当前负载)
    如果 (计数(AI_设置重定向_负载窗口) > 20) { 列表_移除(AI_设置重定向_负载窗口, 0) }
    如果 (计数(AI_设置重定向_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_设置重定向_负载窗口)
    定义 趋势 = AI_设置重定向_负载窗口[n-1] - AI_设置重定向_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_设置重定向_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

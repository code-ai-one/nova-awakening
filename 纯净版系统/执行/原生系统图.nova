导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")

// NovaOS平台适配层: 图形输出 + 输入事件 + 窗口管理
//       + content/browser/renderer_host/
// 传统引擎图形栈:
//   Viz ( → 图处进程 → OpenGL/Vulkan → DRM/KMS
// NovaOS直连:
// 浏览器 → NovaOS图形Nova系统调用 → 图处驱动/Framebuffer → 显示器
// 输入事件栈:
// 传统方案: Ozone → 事件Source → 事件Dispatcher
// NovaOS: 内核输入事件 → 浏览器事件循环 → NovaOS事件分发

// §1 NovaOS图形Nova系统调用接口
// 对应: DRM/KMS (Linux) 或 NovaOS自有图形子系统

定义 Nova系统调用_图形_创建窗口 = 500
定义 Nova系统调用_图形_销毁窗口 = 501
定义 Nova系统调用_图形_获取帧缓冲 = 502
定义 Nova系统调用_图形_提交帧 = 503 // 类似SwapBuffers/PageFlip
定义 Nova系统调用_图形_设置窗口大小 = 504
定义 Nova系统调用_图形_设置窗口标题 = 505
定义 Nova系统调用_图形_设置光标 = 506
定义 Nova系统调用_图形_获取屏幕信息 = 507
定义 Nova系统调用_图形_创建图处缓冲 = 508 // 图处加速用
定义 Nova系统调用_图形_图处提交命令 = 509
定义 Nova系统调用_图形_等待垂直同步 = 510 // VSync

定义 Nova系统调用_输入_轮询事件 = 600
定义 Nova系统调用_输入_设置光标位置 = 601
定义 Nova系统调用_输入_获取剪贴板 = 602
定义 Nova系统调用_输入_设置剪贴板 = 603
定义 Nova系统调用_输入_获取IME状态 = 604
定义 Nova系统调用_输入_设置IME位置 = 605

定义 窗口标志_可调大小 = 0x01
定义 窗口标志_有标题栏 = 0x02
定义 窗口标志_有边框 = 0x04
定义 窗口标志_置顶 = 0x08
定义 窗口标志_全屏 = 0x10
定义 窗口标志_最大化 = 0x20
定义 窗口标志_最小化 = 0x40
定义 窗口标志_透明 = 0x80

定义 输入事件_无 = 0
定义 输入事件_鼠标移动 = 1
定义 输入事件_鼠标按下 = 2
定义 输入事件_鼠标释放 = 3
定义 输入事件_鼠标滚轮 = 4
定义 输入事件_键盘按下 = 5
定义 输入事件_键盘释放 = 6
定义 输入事件_字符输入 = 7 // IME文字输入
定义 输入事件_触摸开始 = 8
定义 输入事件_触摸移动 = 9
定义 输入事件_触摸结束 = 10
定义 输入事件_触摸取消 = 11
定义 输入事件_窗口大小改变 = 12
定义 输入事件_窗口关闭 = 13
定义 输入事件_窗口获得焦点 = 14
定义 输入事件_窗口失去焦点 = 15
定义 输入事件_窗口暴露 = 16 // 需要重绘

定义 光标_箭头 = 0
定义 光标_手指 = 1 // pointer
定义 光标_文本 = 2 // text (I-beam)
定义 光标_等待 = 3 // wait
定义 光标_十字 = 4 // crosshair
定义 光标_移动 = 5 // move
定义 光标_禁止 = 6 // not-allowed
定义 光标_左右调整 = 7 // ew-resize
定义 光标_上下调整 = 8 // ns-resize
定义 光标_对角调整 = 9 // nwse-resize
定义 光标_隐藏 = 10 // none

// §2 平台窗口 (ui::PlatformWindow)

结构 Platform事件 {
 类型,
 // 鼠标
 鼠标x,
 鼠标y,
 按钮,    // u32 0=left 1=middle 2=right
 滚轮dx,
 滚轮dy,
 // 键盘
 键码,    // u32 物理键码
 扫描码,
 字符,    // u32 Unicode码点
 // 修饰键
 修饰键,    // u32 bit: 1=Ctrl 2=Shift 4=Alt 8=Meta
 // 触摸
 触摸id,
 触摸x,
 触摸y,
 // 窗口
 新宽,
 新高,
 // 时间戳
 时间戳,
}

结构 PlatformWindow {
}

// NovaOS 纹理引擎 — 图片纹理加载+UV映射+采样
// 让3D数字人可以用参考图片作为皮肤/衣服纹理

导入("../中枢/类型定义.nova")
导入("../感知/完整图片解码.nova")
导入("../记忆/接口.nova")

// §1 纹理数据结构

结构 纹理 {
    数据,          // RGBA像素数据指针
    宽,
    高,
    通道数,        // 3=RGB 4=RGBA
    名称,
}

结构 UV坐标 { u, v }  // 0-1000范围(千分制)

定义 可变 纹理表 = []
定义 可变 纹理总数 = 0
定义 可变 纹理_采样次数 = 0
定义 可变 纹理_加载次数 = 0

// §2 纹理加载(从文件读取PNG/BMP图片)

函数 纹理_从文件加载(文件路径, 名称) {
    纹理_加载次数 = 纹理_加载次数 + 1
    定义 文件数据 = 记忆_读文件(文件路径)
    如果 (文件数据 == 0) {
        打印("[纹理] 加载失败: " + 文件路径)
        返回 空
    }

    // 检测文件格式
    定义 头字节 = 内存_读8(文件数据)
    定义 tex = 堆_分配(纹理)
    tex.名称 = 名称

    如果 (头字节 == 0x89) {
        // PNG格式
        tex = 纹理_解码PNG(文件数据, tex)
    } 否则 如果 (头字节 == 0x42) {
        // BMP格式
        tex = 纹理_解码BMP(文件数据, tex)
    } 否则 如果 (头字节 == 0xFF) {
        // JPEG格式
        tex = 纹理_解码JPEG(文件数据, tex)
    }

    如果 (tex.数据 != 0) {
        追加(纹理表, tex)
        纹理总数 = 纹理总数 + 1
        打印("[纹理] 加载成功: " + 名称 + " " + tex.宽 + "x" + tex.高)
    }
    返回 tex
}

函数 纹理_解码BMP(数据, tex) {
    // BMP头: 偏移10=数据起始 偏移18=宽 偏移22=高
    定义 数据起始 = 内存_读32(数据 + 10)
    tex.宽 = 内存_读32(数据 + 18)
    tex.高 = 内存_读32(数据 + 22)
    tex.通道数 = 3
    tex.数据 = 数据 + 数据起始
    返回 tex
}

函数 纹理_解码PNG(数据, tex) {
    // 委托给完整图片解码模块
    tex.宽 = 0; tex.高 = 0; tex.数据 = 0
    返回 tex
}

函数 纹理_解码JPEG(数据, tex) {
    tex.宽 = 0; tex.高 = 0; tex.数据 = 0
    返回 tex
}

// §3 纹理采样(UV坐标→像素颜色)

函数 纹理_采样(tex, u, v) {
    // u,v范围0-1000 (千分制)
    如果 (tex == 空 || tex.数据 == 0) { 返回 0xFFCCCCCC }
    纹理_采样次数 = 纹理_采样次数 + 1

    // UV→像素坐标
    定义 px = u * tex.宽 / 1000
    定义 py = v * tex.高 / 1000
    如果 (px < 0) { px = 0 }
    如果 (py < 0) { py = 0 }
    如果 (px >= tex.宽) { px = tex.宽 - 1 }
    如果 (py >= tex.高) { py = tex.高 - 1 }

    // 读取像素(BMP是BGR格式,翻转Y)
    定义 翻转y = tex.高 - 1 - py
    定义 偏移 = (翻转y * tex.宽 + px) * tex.通道数
    定义 b = 内存_读8(tex.数据 + 偏移)
    定义 g = 内存_读8(tex.数据 + 偏移 + 1)
    定义 r = 内存_读8(tex.数据 + 偏移 + 2)
    定义 a = 255
    如果 (tex.通道数 == 4) { a = 内存_读8(tex.数据 + 偏移 + 3) }

    返回 (a << 24) | (r << 16) | (g << 8) | b
}

// 双线性插值采样(更平滑)
函数 纹理_双线性采样(tex, u, v) {
    如果 (tex == 空 || tex.数据 == 0) { 返回 0xFFCCCCCC }
    定义 fx = u * tex.宽 / 1000
    定义 fy = v * tex.高 / 1000
    定义 x0 = fx
    定义 y0 = fy
    定义 x1 = x0 + 1
    定义 y1 = y0 + 1
    如果 (x1 >= tex.宽) { x1 = tex.宽 - 1 }
    如果 (y1 >= tex.高) { y1 = tex.高 - 1 }

    // 四角采样
    定义 c00 = 纹理_采样(tex, x0 * 1000 / tex.宽, y0 * 1000 / tex.高)
    定义 c10 = 纹理_采样(tex, x1 * 1000 / tex.宽, y0 * 1000 / tex.高)
    定义 c01 = 纹理_采样(tex, x0 * 1000 / tex.宽, y1 * 1000 / tex.高)
    定义 c11 = 纹理_采样(tex, x1 * 1000 / tex.宽, y1 * 1000 / tex.高)

    // 简化: 取平均
    定义 r = ((c00 >> 16) & 0xFF + (c10 >> 16) & 0xFF + (c01 >> 16) & 0xFF + (c11 >> 16) & 0xFF) / 4
    定义 g = ((c00 >> 8) & 0xFF + (c10 >> 8) & 0xFF + (c01 >> 8) & 0xFF + (c11 >> 8) & 0xFF) / 4
    定义 b = (c00 & 0xFF + c10 & 0xFF + c01 & 0xFF + c11 & 0xFF) / 4
    返回 (255 << 24) | (r << 16) | (g << 8) | b
}

// §4 UV映射表(人体各部位→纹理UV坐标)

结构 UV映射段 {
    部位名,
    纹理索引,     // 纹理表中的索引
    u起始, v起始,
    u结束, v结束,
}

定义 可变 人体UV映射 = []

函数 UV映射_初始化() {
    人体UV映射 = []
    // 将参考图片不同区域映射到人体部位
    追加(人体UV映射, UV映射段 { 部位名: "头部", 纹理索引: 0, u起始: 300, v起始: 0, u结束: 700, v结束: 200 })
    追加(人体UV映射, UV映射段 { 部位名: "躯干", 纹理索引: 0, u起始: 200, v起始: 200, u结束: 800, v结束: 600 })
    追加(人体UV映射, UV映射段 { 部位名: "左臂", 纹理索引: 0, u起始: 0, v起始: 200, u结束: 200, v结束: 500 })
    追加(人体UV映射, UV映射段 { 部位名: "右臂", 纹理索引: 0, u起始: 800, v起始: 200, u结束: 1000, v结束: 500 })
    追加(人体UV映射, UV映射段 { 部位名: "左腿", 纹理索引: 0, u起始: 200, v起始: 600, u结束: 500, v结束: 1000 })
    追加(人体UV映射, UV映射段 { 部位名: "右腿", 纹理索引: 0, u起始: 500, v起始: 600, u结束: 800, v结束: 1000 })
}

函数 UV映射_获取颜色(部位名, 局部u, 局部v) {
    // 从部位名和局部UV坐标获取纹理颜色
    定义 可变 i = 0
    当 (i < 计数(人体UV映射)) {
        如果 (人体UV映射[i].部位名 == 部位名) {
            定义 段 = 人体UV映射[i]
            定义 全局u = 段.u起始 + 局部u * (段.u结束 - 段.u起始) / 1000
            定义 全局v = 段.v起始 + 局部v * (段.v结束 - 段.v起始) / 1000
            如果 (段.纹理索引 < 纹理总数) {
                返回 纹理_双线性采样(纹理表[段.纹理索引], 全局u, 全局v)
            }
        }
        i = i + 1
    }
    返回 0xFFCCCCCC  // 默认灰色
}

// §5 纹理数字人渲染(图片做底子)

函数 纹理数字人_加载皮肤(图片路径) {
    定义 tex = 纹理_从文件加载(图片路径, "角色皮肤")
    如果 (tex != 空) {
        UV映射_初始化()
        打印("[纹理数字人] 皮肤纹理已加载: " + 图片路径)
    }
    返回 tex
}

// 多角度纹理: 4张参考图覆盖360度
定义 可变 纹理_正面 = 0
定义 可变 纹理_坐姿 = 0
定义 可变 纹理_侧面 = 0
定义 可变 纹理_特写 = 0

函数 纹理数字人_加载全部() {
    纹理_正面 = 纹理_从文件加载("资源/数字人/正面.png", "正面")
    纹理_坐姿 = 纹理_从文件加载("资源/数字人/坐姿.png", "坐姿")
    纹理_侧面 = 纹理_从文件加载("资源/数字人/侧面.png", "侧面")
    纹理_特写 = 纹理_从文件加载("资源/数字人/特写.png", "特写")
    UV映射_初始化()
    打印("[纹理数字人] 4张多角度纹理已加载")
}

函数 纹理数字人_选纹理(朝向角度) {
    // 根据数字人朝向选择最匹配的纹理
    如果 (朝向角度 >= 315 || 朝向角度 < 45) { 返回 纹理_正面 }
    如果 (朝向角度 >= 45 && 朝向角度 < 135) { 返回 纹理_侧面 }
    如果 (朝向角度 >= 135 && 朝向角度 < 225) { 返回 纹理_正面 }  // 背面用正面镜像
    返回 纹理_侧面  // 另一侧
}

函数 纹理数字人_获取特写() { 返回 纹理_特写 }
函数 纹理数字人_获取坐姿() { 返回 纹理_坐姿 }

函数 纹理数字人_渲染帧(帧缓冲, 宽, 高) {
    // 用纹理替代纯色渲染
    如果 (纹理总数 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(人体顶点)) {
        定义 v = 人体顶点[i]
        // 3D→2D投影
        定义 z = v.z + 2000
        如果 (z <= 0) { z = 1 }
        定义 屏幕x = 宽 / 2 + v.x * 500 / z
        定义 屏幕y = 高 / 2 - v.y * 500 / z
        如果 (屏幕x >= 0 && 屏幕x < 宽 && 屏幕y >= 0 && 屏幕y < 高) {
            // 根据Y坐标判断部位,用纹理采样颜色
            定义 可变 部位 = "躯干"
            如果 (v.y > 1500) { 部位 = "头部" }
            否则 如果 (v.y > 900) { 部位 = "躯干" }
            否则 如果 (v.y > 400) { 部位 = "左腿" }
            否则 { 部位 = "右腿" }
            定义 局部u = (v.x + 200) * 1000 / 400
            定义 局部v = (1800 - v.y) * 1000 / 1800
            定义 颜色 = UV映射_获取颜色(部位, 局部u, 局部v)
            内存_写32(帧缓冲 + (屏幕y * 宽 + 屏幕x) * 4, 颜色)
        }
        i = i + 1
    }
}

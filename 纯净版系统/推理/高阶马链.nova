// §3 高阶马尔可夫链 — P(next | 最近N步)
// 用历史窗口哈希作为状态, 支持更长的模式匹配

结构 HighOrderMarkov {
    阶数,    // u32 N (考虑最近N步)
    历史窗口,    // u64 i32[阶数] 最近N步的动作
    历史有效长度,
    // 哈希表: 历史模式哈希 → 动作分布
    模式表,    // u64 指针数组
    模式表大小,
    模式数量,
}

结构 模式条目 {
    模式哈希,
    动作计数,    // u64 Tensor* [1 × 动作数量]
    总次数,
    下一个,    // u64 链表
}

函数 HighOrderMarkov_创建(阶数) {
    定义 hom = 堆_分配(HighOrderMarkov)
    hom.阶数 = 阶数
    hom.历史窗口 = 堆_分配_数组(阶数 * 4)
    hom.历史有效长度 = 0
    hom.模式表大小 = 256
    hom.模式表 = 堆_分配_数组(hom.模式表大小 * 8)
    内存_清零(hom.模式表, hom.模式表大小 * 8)
    hom.模式数量 = 0
    返回 hom
}

// 计算历史窗口的哈希
函数 HighOrderMarkov_窗口哈希(hom) {
    定义 可变 哈希 = 2166136261    // FNV-1a初始值
    定义 可变 i = 0
    当 (i < hom.历史有效长度) {
        定义 动作 = 内存_读32(hom.历史窗口 + i * 4)
        哈希 = (哈希 ^ 动作) * 16777619
        i = i + 1
    }
    返回 哈希 & 0x7FFFFFFF
}

// 观察动作 + 在线更新
函数 HighOrderMarkov_观察(hom, 当前动作) {
    如果 (hom.历史有效长度 >= hom.阶数) {
        // 窗口已满: 查找/创建当前模式并更新计数
        定义 哈希 = HighOrderMarkov_窗口哈希(hom)
        定义 桶 = 哈希 % hom.模式表大小
        定义 条目 = HighOrderMarkov_查找或创建(hom, 桶, 哈希)
        如果 (条目 != 0) {
            定义 旧 = Tensor_读(条目.动作计数, 0, 当前动作)
            Tensor_写(条目.动作计数, 0, 当前动作, 旧 + Q_ONE)
            条目.总次数 = 条目.总次数 + 1
        }

        // 滑动窗口: 移除最旧, 添加新
        定义 可变 i = 0
        当 (i < hom.阶数 - 1) {
            内存_写32(hom.历史窗口 + i * 4, 内存_读32(hom.历史窗口 + (i+1) * 4))
            i = i + 1
        }
        内存_写32(hom.历史窗口 + (hom.阶数 - 1) * 4, 当前动作)
    } 否则 {
        // 窗口未满: 直接添加
        内存_写32(hom.历史窗口 + hom.历史有效长度 * 4, 当前动作)
        hom.历史有效长度 = hom.历史有效长度 + 1
    }
}

函数 HighOrderMarkov_查找或创建(hom, 桶, 哈希) {
    定义 可变 当前 = 内存_读64(hom.模式表 + 桶 * 8)
    当 (当前 != 0) {
        如果 (当前.模式哈希 == 哈希) { 返回 当前 }
        当前 = 当前.下一个
    }
    // 未找到: 创建新条目
    定义 条目 = 堆_分配(模式条目)
    条目.模式哈希 = 哈希
    条目.动作计数 = Tensor_创建(1, 动作数量)
    // Laplace平滑
    定义 可变 j = 0
    当 (j < 动作数量) { Tensor_写(条目.动作计数, 0, j, 1); j = j + 1 }
    条目.总次数 = 动作数量
    条目.下一个 = 内存_读64(hom.模式表 + 桶 * 8)
    内存_写64(hom.模式表 + 桶 * 8, 条目)
    hom.模式数量 = hom.模式数量 + 1
    返回 条目
}

// 高阶预测
函数 HighOrderMarkov_预测(hom) {
    如果 (hom.历史有效长度 < hom.阶数) { 返回 动作_空闲 }
    定义 哈希 = HighOrderMarkov_窗口哈希(hom)
    定义 桶 = 哈希 % hom.模式表大小
    定义 可变 当前 = 内存_读64(hom.模式表 + 桶 * 8)
    当 (当前 != 0) {
        如果 (当前.模式哈希 == 哈希) {
            // 找到匹配模式: 返回概率最高的动作
            定义 可变 最大 = 0
            定义 可变 最佳 = 0
            定义 可变 j = 0
            当 (j < 动作数量) {
                定义 c = Tensor_读(当前.动作计数, 0, j)
                如果 (c > 最大) { 最大 = c; 最佳 = j }
                j = j + 1
            }
            返回 最佳
        }
        当前 = 当前.下一个
    }
    返回 动作_空闲    // 未见过的模式
}

定义 WIFI_BAND_2G = 0
定义 WIFI_BAND_5G = 1
定义 WIFI_BAND_6G = 2
定义 WIFI_BAND_未知 = -1

定义 WIFI_漫游阈值 = -70   // dBm, 信号低于此值考虑漫游
定义 WIFI_漫游增益最小 = 8  // dBm, 新AP至少强多少才漫游
定义 BSS_老化超时 = 30000   // ms, 30秒未更新的BSS视为过期

定义 可变 wifi_设备查找数 = 0
定义 可变 wifi_BSS查找数 = 0
定义 可变 wifi_漫游评估数 = 0
定义 可变 wifi_漫游触发数 = 0
定义 可变 wifi_帧接收数 = 0
定义 可变 wifi_帧丢弃数 = 0

// §1 设备查找

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 WiFi_查找设备(名称) {
    wifi_设备查找数 = wifi_设备查找数 + 1
    定义 可变 i = 0
    当 (i < 计数(WiFi设备列表)) {
        如果 (WiFi设备列表[i].名称 == 名称) { 返回 WiFi设备列表[i] }
        i = i + 1
    }
    返回 空
}

函数 WiFi_设备数() {
    返回 计数(WiFi设备列表)
}

函数 WiFi_获取设备(索引) {
    如果 (索引 < 0 || 索引 >= 计数(WiFi设备列表)) { 返回 空 }
    返回 WiFi设备列表[索引]
}

// §2 BSS查找与选择

函数 WiFi_查找BSS(dev, ssid) {
    wifi_BSS查找数 = wifi_BSS查找数 + 1
    定义 可变 最强 = 空
    定义 可变 最强信号 = -200
    定义 可变 i = 0
    当 (i < 计数(dev.扫描结果)) {
        如果 (dev.扫描结果[i].SSID == ssid) {
            如果 (dev.扫描结果[i].信号强度 > 最强信号) {
                最强 = dev.扫描结果[i]
                最强信号 = dev.扫描结果[i].信号强度
            }
        }
        i = i + 1
    }
    返回 最强
}

函数 WiFi_查找BSS_BSSID(dev, bssid) {
    定义 可变 i = 0
    当 (i < 计数(dev.扫描结果)) {
        如果 (MAC相同(dev.扫描结果[i].BSSID, bssid)) {
            返回 dev.扫描结果[i]
        }
        i = i + 1
    }
    返回 空
}

函数 WiFi_BSS数量(dev, ssid) {
    定义 可变 数量 = 0
    定义 可变 i = 0
    当 (i < 计数(dev.扫描结果)) {
        如果 (dev.扫描结果[i].SSID == ssid) { 数量 = 数量 + 1 }
        i = i + 1
    }
    返回 数量
}

// 清理过期BSS
函数 WiFi_清理过期BSS(dev, 当前时间) {
    定义 可变 i = 计数(dev.扫描结果) - 1
    当 (i >= 0) {
        如果 (当前时间 - dev.扫描结果[i].最后更新时间 > BSS_老化超时) {
            删除(dev.扫描结果, i)
        }
        i = i - 1
    }
}

// §3 频率/频道转换

函数 WiFi_频率转频道(频率) {
    // 2.4 GHz
    如果 (频率 >= 2412 && 频率 <= 2472) {
        返回 (频率 - 2407) / 5
    }
    如果 (频率 == 2484) { 返回 14 }
    // 5 GHz
    如果 (频率 >= 5180 && 频率 <= 5825) {
        返回 (频率 - 5000) / 5
    }
    // 6 GHz (WiFi 6E)
    如果 (频率 >= 5955 && 频率 <= 7115) {
        返回 (频率 - 5950) / 5
    }
    返回 0
}

函数 WiFi_频道转频率(频道, 频段) {
    如果 (频段 == WIFI_BAND_2G) {
        如果 (频道 == 14) { 返回 2484 }
        如果 (频道 >= 1 && 频道 <= 13) { 返回 2407 + 频道 * 5 }
    }
    如果 (频段 == WIFI_BAND_5G) {
        返回 5000 + 频道 * 5
    }
    如果 (频段 == WIFI_BAND_6G) {
        返回 5950 + 频道 * 5
    }
    返回 0
}

函数 WiFi_频率转频段(频率) {
    如果 (频率 >= 2400 && 频率 <= 2500) { 返回 WIFI_BAND_2G }
    如果 (频率 >= 5150 && 频率 <= 5850) { 返回 WIFI_BAND_5G }
    如果 (频率 >= 5925 && 频率 <= 7125) { 返回 WIFI_BAND_6G }
    返回 WIFI_BAND_未知
}

函数 WiFi_频段名(频段) {
    如果 (频段 == WIFI_BAND_2G) { 返回 "2.4GHz" }
    如果 (频段 == WIFI_BAND_5G) { 返回 "5GHz" }
    如果 (频段 == WIFI_BAND_6G) { 返回 "6GHz" }
    返回 "未知"
}

// §4 信号质量

函数 WiFi_信号质量(rssi) {
    // 将dBm转换为0-100质量百分比
    如果 (rssi >= -50) { 返回 100 }
    如果 (rssi <= -100) { 返回 0 }
    返回 (rssi + 100) * 2
}

函数 WiFi_信号等级(rssi) {
    // 返回0-4的信号等级 (类似手机信号格)
    如果 (rssi >= -55) { 返回 4 }
    如果 (rssi >= -65) { 返回 3 }
    如果 (rssi >= -75) { 返回 2 }
    如果 (rssi >= -85) { 返回 1 }
    返回 0
}

函数 WiFi_信号描述(rssi) {
    如果 (rssi >= -50) { 返回 "极好" }
    如果 (rssi >= -60) { 返回 "很好" }
    如果 (rssi >= -70) { 返回 "良好" }
    如果 (rssi >= -80) { 返回 "一般" }
    如果 (rssi >= -90) { 返回 "较弱" }
    返回 "极弱"
}

// §5 加密类型

函数 WiFi_加密名(类型) {
    如果 (类型 == WIFI_CIPHER_NONE) { 返回 "Open" }
    如果 (类型 == WIFI_CIPHER_WEP) { 返回 "WEP" }
    如果 (类型 == WIFI_CIPHER_TKIP) { 返回 "WPA-TKIP" }
    如果 (类型 == WIFI_CIPHER_CCMP) { 返回 "WPA2-AES" }
    如果 (类型 == WIFI_CIPHER_GCMP_256) { 返回 "WPA3" }
    如果 (类型 == WIFI_CIPHER_CCMP_256) { 返回 "WPA3-AES256" }
    返回 "Unknown"
}

函数 WiFi_加密安全等级(类型) {
    // 0=无, 1=弱, 2=中, 3=强
    如果 (类型 == WIFI_CIPHER_NONE) { 返回 0 }
    如果 (类型 == WIFI_CIPHER_WEP) { 返回 1 }
    如果 (类型 == WIFI_CIPHER_TKIP) { 返回 2 }
    如果 (类型 == WIFI_CIPHER_CCMP) { 返回 3 }
    如果 (类型 == WIFI_CIPHER_GCMP_256) { 返回 3 }
    返回 0
}

// §6 漫游评估

函数 WiFi_漫游评分(bss) {
    // 综合评分: 信号+频段加成+安全加成
    定义 可变 分数 = WiFi_信号质量(bss.信号强度)
    // 5GHz加分(通常干扰更少)
    定义 频段 = WiFi_频率转频段(bss.频率)
    如果 (频段 == WIFI_BAND_5G) { 分数 = 分数 + 10 }
    如果 (频段 == WIFI_BAND_6G) { 分数 = 分数 + 15 }
    // 安全加分
    分数 = 分数 + WiFi_加密安全等级(bss.加密类型) * 3
    如果 (分数 > 100) { 分数 = 100 }
    返回 分数
}

函数 WiFi_应该漫游(dev, ssid) {
    wifi_漫游评估数 = wifi_漫游评估数 + 1
    // 当前AP信号是否足够差
    如果 (dev.当前信号 > WIFI_漫游阈值) { 返回 假 }
    // 找最好的候选BSS
    定义 可变 最佳 = 空
    定义 可变 最佳分数 = 0
    定义 可变 i = 0
    当 (i < 计数(dev.扫描结果)) {
        如果 (dev.扫描结果[i].SSID == ssid &&
            !MAC相同(dev.扫描结果[i].BSSID, dev.当前BSSID)) {
            定义 分数 = WiFi_漫游评分(dev.扫描结果[i])
            如果 (分数 > 最佳分数) {
                最佳 = dev.扫描结果[i]
                最佳分数 = 分数
            }
        }
        i = i + 1
    }
    如果 (最佳 == 空) { 返回 假 }
    // 候选信号需要明显更好
    如果 (最佳.信号强度 - dev.当前信号 >= WIFI_漫游增益最小) {
        wifi_漫游触发数 = wifi_漫游触发数 + 1
        返回 真
    }
    返回 假
}

// §7 MAC地址工具

函数 MAC相同(a, b) {
    如果 (计数(a) < 6 || 计数(b) < 6) { 返回 假 }
    返回 a[0] == b[0] && a[1] == b[1] && a[2] == b[2] &&
           a[3] == b[3] && a[4] == b[4] && a[5] == b[5]
}

函数 MAC转字符串(mac) {
    如果 (计数(mac) < 6) { 返回 "??:??:??:??:??:??" }
    返回 字节转十六进制(mac[0]) + ":" + 字节转十六进制(mac[1]) + ":" +
           字节转十六进制(mac[2]) + ":" + 字节转十六进制(mac[3]) + ":" +
           字节转十六进制(mac[4]) + ":" + 字节转十六进制(mac[5])
}

函数 MAC_是广播(mac) {
    返回 mac[0] == 0xFF && mac[1] == 0xFF && mac[2] == 0xFF &&
           mac[3] == 0xFF && mac[4] == 0xFF && mac[5] == 0xFF
}

函数 MAC_是组播(mac) {
    返回 (mac[0] & 0x01) != 0
}

函数 MAC_是零(mac) {
    返回 mac[0] == 0 && mac[1] == 0 && mac[2] == 0 &&
           mac[3] == 0 && mac[4] == 0 && mac[5] == 0
}

函数 字节转十六进制(b) {
    定义 高 = "0123456789abcdef"
    返回 字符串_取字符(高, (b >> 4) & 0xF) + 字符串_取字符(高, b & 0xF)
}

// §8 帧分发

函数 分配内存(大小) { 返回 kmalloc(大小) }
函数 释放内存(地址) { kfree(地址) }

函数 网络_接收帧(数据, 长度) {
    // 从802.11帧中提取以太网帧后分发到协议栈
    wifi_帧接收数 = wifi_帧接收数 + 1
    如果 (数据 == 0 || 长度 < 14) {
        wifi_帧丢弃数 = wifi_帧丢弃数 + 1
        返回
    }
    定义 类型 = (内存读8(数据 + 12) << 8) | 内存读8(数据 + 13)
    如果 (类型 == 0x0800) { IP_接收(数据 + 14, 长度 - 14) }
    否则 如果 (类型 == 0x0806) { ARP_接收(数据, 长度) }
    否则 如果 (类型 == 0x86DD) { IPv6_接收(数据 + 14, 长度 - 14) }
    否则 如果 (类型 == 0x888E) { EAPOL_接收(数据 + 14, 长度 - 14) }
    否则 { wifi_帧丢弃数 = wifi_帧丢弃数 + 1 }
}

函数 DHCP_请求(dev_name) { 内核信息("WiFi: 请求DHCP " + dev_name) }

// §9 错误码

定义 错误_设备不存在 = -19
定义 错误_设备忙     = -16
定义 错误_网络不存在 = -113
定义 错误_认证失败   = -111
定义 错误_未连接     = -107
定义 错误_ENOSYS     = -38
定义 错误_超时       = -110
定义 错误_信道忙     = -114

函数 WiFi_错误描述(错误码) {
    如果 (错误码 == 0) { 返回 "成功" }
    如果 (错误码 == 错误_设备不存在) { 返回 "设备不存在" }
    如果 (错误码 == 错误_设备忙) { 返回 "设备忙" }
    如果 (错误码 == 错误_网络不存在) { 返回 "网络不存在" }
    如果 (错误码 == 错误_认证失败) { 返回 "认证失败" }
    如果 (错误码 == 错误_未连接) { 返回 "未连接" }
    如果 (错误码 == 错误_超时) { 返回 "超时" }
    如果 (错误码 == 错误_信道忙) { 返回 "信道忙" }
    返回 "未知错误(" + 整数转字符串(错误码) + ")"
}

// §10 BSS信息打印

函数 WiFi_打印BSS(bss) {
    如果 (bss == 空) { 返回 }
    打印行("SSID: " + bss.SSID)
    打印行("BSSID: " + MAC转字符串(bss.BSSID))
    打印行("频率: " + 整数转字符串(bss.频率) + " MHz (CH " +
        整数转字符串(WiFi_频率转频道(bss.频率)) + ")")
    打印行("频段: " + WiFi_频段名(WiFi_频率转频段(bss.频率)))
    打印行("信号: " + 整数转字符串(bss.信号强度) + " dBm (" +
        WiFi_信号描述(bss.信号强度) + ")")
    打印行("加密: " + WiFi_加密名(bss.加密类型))
    打印行("质量: " + 整数转字符串(WiFi_信号质量(bss.信号强度)) + "%")
    打印行("漫游评分: " + 整数转字符串(WiFi_漫游评分(bss)))
}

// §11 统计

函数 WiFi_统计() {
    如果 (计数(WiFi设备列表) == 0) { 返回 [0, 0, 0, 0] }
    定义 dev = WiFi设备列表[0]
    返回 [dev.状态, dev.发送包数, dev.接收包数, 计数(dev.扫描结果)]
}

函数 WiFi_打印统计() {
    打印行("=== WiFi辅助统计 ===")
    打印行("设备数: " + 整数转字符串(计数(WiFi设备列表)))
    打印行("设备查找: " + 整数转字符串(wifi_设备查找数))
    打印行("BSS查找: " + 整数转字符串(wifi_BSS查找数))
    打印行("漫游评估: " + 整数转字符串(wifi_漫游评估数))
    打印行("漫游触发: " + 整数转字符串(wifi_漫游触发数))
    打印行("帧接收: " + 整数转字符串(wifi_帧接收数))
    打印行("帧丢弃: " + 整数转字符串(wifi_帧丢弃数))

    // 每个设备
    定义 可变 i = 0
    当 (i < 计数(WiFi设备列表)) {
        定义 dev = WiFi设备列表[i]
        打印行("  设备[" + 整数转字符串(i) + "] " + dev.名称 +
            " 状态=" + 整数转字符串(dev.状态) +
            " TX=" + 整数转字符串(dev.发送包数) +
            " RX=" + 整数转字符串(dev.接收包数) +
            " BSS=" + 整数转字符串(计数(dev.扫描结果)))
        i = i + 1
    }
}

// NWFA — Nova Wireless Framework Auxiliary Theory
// 公理1(信号衰减): 无线信号强度随距离平方反比衰减
// 公理2(漫游必要): 信号低于阈值时必须触发漫游
// 定理1(频段分离): 2.4G和5G频段可独立管理
// 定理2(扫描完备): 扫描后BSS列表反映当前无线环境

函数 WiFi_信号均值(列表, 数量) {
    如果 (数量 == 0) { 返回 0 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 数量) { 总 = 总 + 列表[i]; i = i + 1 }
    返回 总 / 数量
}

函数 WiFi_信号方差(列表, 数量) {
    如果 (数量 < 2) { 返回 0 }
    定义 均值 = WiFi_信号均值(列表, 数量)
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 数量) {
        定义 差 = 列表[i] - 均值
        总 = 总 + 差 * 差
        i = i + 1
    }
    返回 总 / 数量
}

函数 WiFi_最佳BSS(设备) {
    如果 (设备 == 空 || 计数(设备.扫描结果) == 0) { 返回 空 }
    定义 可变 最佳 = 设备.扫描结果[0]
    定义 可变 最高分 = WiFi_漫游评分(最佳)
    定义 可变 i = 1
    当 (i < 计数(设备.扫描结果)) {
        定义 分数 = WiFi_漫游评分(设备.扫描结果[i])
        如果 (分数 > 最高分) {
            最高分 = 分数
            最佳 = 设备.扫描结果[i]
        }
        i = i + 1
    }
    返回 最佳
}

定义 WiFi_频道数_2G = 14
定义 WiFi_频道数_5G = 25

函数 WiFi_信道占用率(设备, 信道) {
    如果 (设备 == 空) { 返回 0 }
    定义 可变 占用 = 0
    定义 可变 i = 0
    当 (i < 计数(设备.扫描结果)) {
        如果 (WiFi_频率转频道(设备.扫描结果[i].频率) == 信道) {
            占用 = 占用 + 1
        }
        i = i + 1
    }
    返回 占用
}

函数 WiFi_最佳信道(设备) {
    如果 (设备 == 空) { 返回 1 }
    定义 可变 最佳 = 1
    定义 可变 最低 = 9999
    定义 可变 ch = 1
    当 (ch <= WiFi_频道数_2G) {
        定义 占用 = WiFi_信道占用率(设备, ch)
        如果 (占用 < 最低) { 最低 = 占用; 最佳 = ch }
        ch = ch + 1
    }
    返回 最佳
}

函数 WiFi_完整统计() {
    返回 [wifi_设备查找数, wifi_BSS查找数, wifi_漫游评估数,
           wifi_漫游触发数, wifi_帧接收数, wifi_帧丢弃数,
           计数(WiFi设备列表)]
}

函数 WiFi_重置统计() {
    wifi_设备查找数 = 0
    wifi_BSS查找数 = 0
    wifi_漫游评估数 = 0
    wifi_漫游触发数 = 0
    wifi_帧接收数 = 0
    wifi_帧丢弃数 = 0
}

函数 WiFi_获取设备数() { 返回 计数(WiFi设备列表) }
函数 WiFi_获取帧接收数() { 返回 wifi_帧接收数 }
函数 WiFi_获取漫游数() { 返回 wifi_漫游触发数 }

函数 WiFi_连接质量(设备) {
    // 综合信号强度+丢包率计算连接质量 0-1000
    如果 (设备 == 空 || 设备.当前BSS == 空) { 返回 0 }
    定义 信号分 = WiFi_信号质量(设备.当前BSS.信号强度) * 10
    定义 可变 丢包分 = 0
    如果 (设备.发送包数 > 0) {
        丢包分 = 1000 - (设备.发送包数 - 设备.接收包数) * 1000 / 设备.发送包数
        如果 (丢包分 < 0) { 丢包分 = 0 }
    } 否则 { 丢包分 = 500 }
    返回 (信号分 * 6 + 丢包分 * 4) / 10
}

函数 WiFi_建议频段(设备) {
    // 0=无建议, 1=切换2.4G, 2=切换5G
    如果 (设备 == 空) { 返回 0 }
    定义 质量 = WiFi_连接质量(设备)
    如果 (质量 > 700) { 返回 0 }  // 质量良好无需切换
    如果 (设备.当前BSS != 空) {
        定义 当前频段 = WiFi_频率转频段(设备.当前BSS.频率)
        如果 (当前频段 == 1) { 返回 2 }  // 2.4G质量差建议切5G
        返回 1  // 5G质量差建议切2.4G
    }
    返回 0
}

函数 WiFi_信噪比估算(RSSI, 噪底) {
    如果 (噪底 == 0) { 噪底 = -95 }
    定义 SNR = RSSI - 噪底
    如果 (SNR < 0) { SNR = 0 }
    返回 SNR
}

函数 WiFi_频谱效率(调制阶数, 编码率_千分) {
    // bits/s/Hz = log2(调制阶数) * 编码率
    定义 可变 比特 = 0
    定义 可变 m = 调制阶数
    当 (m > 1) { m = m / 2; 比特 = 比特 + 1 }
    返回 比特 * 编码率_千分 / 1000
}

函数 WiFi_获取BSS数() { 返回 wifi_BSS查找数 }

函数 WiFi_获取丢弃率() {
    如果 (wifi_帧接收数 == 0) { 返回 0 }
    返回 wifi_帧丢弃数 * 1000 / wifi_帧接收数
}

定义 可变 AI_无线框架辅_运行指标 = 0
定义 可变 AI_无线框架辅_异常指标 = 0

函数 AI_无线框架辅_自诊断() {
    AI_无线框架辅_运行指标 = 0
    返回 AI_无线框架辅_运行指标
}

函数 AI_无线框架辅_优化建议() {
    定义 指标 = AI_无线框架辅_自诊断()
    返回 "无线框架辅助状态正常"
}

函数 无线框架辅助_统计() {
    返回 {
        模块: "无线框架辅助",
        wifi_设备查找数: wifi_设备查找数,
        wifi_BSS查找数: wifi_BSS查找数,
        wifi_漫游评估数: wifi_漫游评估数,
        wifi_漫游触发数: wifi_漫游触发数,
        wifi_帧接收数: wifi_帧接收数,
        wifi_帧丢弃数: wifi_帧丢弃数,
        AI_无线框架辅_运行指标: AI_无线框架辅_运行指标,
        AI_无线框架辅_异常指标: AI_无线框架辅_异常指标
    }
}

函数 无线框架辅助_健康评估() {
    定义 可变 问题 = []

    返回 计数(问题) == 0
}

函数 无线框架辅助_综合报告() {
    打印("[无线框架辅助] ═══ 综合报告 ═══")
    打印("  wifi_设备查找数: " + 整数转字符串(wifi_设备查找数))
    打印("  wifi_BSS查找数: " + 整数转字符串(wifi_BSS查找数))
    打印("  wifi_漫游评估数: " + 整数转字符串(wifi_漫游评估数))
    打印("  wifi_漫游触发数: " + 整数转字符串(wifi_漫游触发数))
    打印("  wifi_帧接收数: " + 整数转字符串(wifi_帧接收数))
    打印("  wifi_帧丢弃数: " + 整数转字符串(wifi_帧丢弃数))
    打印("  AI_无线框架辅_运行指标: " + 整数转字符串(AI_无线框架辅_运行指标))
    打印("  AI_无线框架辅_异常指标: " + 整数转字符串(AI_无线框架辅_异常指标))
    打印("  健康: " + 如果 (无线框架辅助_健康评估()) { "正常" } 否则 { "异常" })
}

函数 无线框架辅助_全局重置() {
    wifi_设备查找数 = 0
    wifi_BSS查找数 = 0
    wifi_漫游评估数 = 0
    wifi_漫游触发数 = 0
    wifi_帧接收数 = 0
    wifi_帧丢弃数 = 0
    AI_无线框架辅_运行指标 = 0
    AI_无线框架辅_异常指标 = 0
    打印("[无线框架辅助] 全局统计已重置")
    返回 0
}

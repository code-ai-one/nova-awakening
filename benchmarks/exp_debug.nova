函数 exp_approx(x) {
    定义 x2 = x * x
    定义 x3 = x2 * x
    定义 x4 = x3 * x
    返回 1.0 + x + x2 / 2.0 + x3 / 6.0 + x4 / 24.0
}

函数 主程序() {
    // 直接调 exp_approx(-2.0), 期望 0.333
    定义 r1 = exp_approx(0.0 - 2.0)
    打印(字符串拼接("exp_approx(-2) bits=", 转字符串(r1)))
    // 期望 0.333 bits ≈ 0x3FD5555555555555 ≈ 4600877379321698714
    
    定义 r2 = exp_approx(2.0)
    打印(字符串拼接("exp_approx(2) bits=", 转字符串(r2)))
    // 期望 7.0 (1+2+2+1.333+0.667) bits = 0x401C000000000000 = 4620693217682128896

    // 测: 1.0 + exp_approx(-2)
    定义 r3 = 1.0 + r1
    打印(字符串拼接("1+exp(-2) bits=", 转字符串(r3)))
    // 期望 1.333 bits = 0x3FF5555555555555 = 4608083138725491507
    
    // 测: 1.0 / (1.0 + exp_approx(-2)) = sigmoid(2)
    定义 r4 = 1.0 / r3
    打印(字符串拼接("1/(1+exp(-2)) bits=", 转字符串(r4)))
    // 期望 0.75 bits = 0x3FE8000000000000 = 4605380978949069210
    返回 0
}

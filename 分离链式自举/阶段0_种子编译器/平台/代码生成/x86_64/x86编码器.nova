// Nova · 平台层 · x86-64 指令编码器
// 模块化x86-64指令编码 — 机器码发射/寄存器操作/变量访问

// mov rax, [rbp+disp] or load from globals array
函数 发射_载变量(disp) { 如果 (disp <= 0 - 1000) { 定义 可变 gslot = 0 - 1000 - disp
  定义 可变 goff = gslot * 8
  修正表_追加记录(修正表, "rt_globals", 代码位 + 3, 空)
  发射组([0x48, 0x8B, 0x05])
  发射32(0)
  如果 (goff == 0) { 发射组([0x48, 0x8B, 0x00]) }
  否则 { 发射组([0x48, 0x8B, 0x80]) 发射32(goff) }
 } 否则 如果 (disp >= 0 - 128) {
 发射组([0x48, 0x8B, 0x45]) 发射(disp & 0xFF)
 } 否则 {
 发射组([0x48, 0x8B, 0x85]) 发射32(disp)
 }
}
// mov [rbp+disp], rax or store to globals array
函数 发射_存变量(disp) { 如果 (disp <= 0 - 1000) { 定义 gslot = 0 - 1000 - disp
  定义 goff = gslot * 8
  发射(0x50) // push rax (inline, 避免函数调用)
  修正表_追加记录(修正表, "rt_globals", 代码位 + 3, 空)
  发射组([0x48, 0x8B, 0x05])
  发射32(0)
  发射(0x59) // pop rcx (inline, 避免函数调用)
  如果 (goff == 0) { 发射组([0x48, 0x89, 0x08]) }
  否则 { 发射组([0x48, 0x89, 0x88]) 发射32(goff) }
  发射组([0x48, 0x89, 0xC8])
 } 否则 如果 (disp >= 0 - 128) {
 发射组([0x48, 0x89, 0x45]) 发射(disp & 0xFF)
 } 否则 {
 发射组([0x48, 0x89, 0x85]) 发射32(disp)
 }
}
// mov [rbp+disp], rcx
函数 发射_存rcx到变量(disp) { 如果 (disp >= 0 - 128) {
  发射组([0x48, 0x89, 0x4D]) 发射(disp & 0xFF)
 } 否则 {
 发射组([0x48, 0x89, 0x8D]) 发射32(disp)
 }
}
// mov [rbp+disp], rdx
函数 发射_存rdx到变量(disp) { 如果 (disp >= 0 - 128) {
 发射组([0x48, 0x89, 0x55]) 发射(disp & 0xFF)
 } 否则 {
 发射组([0x48, 0x89, 0x95]) 发射32(disp)
 }
}
// mov rcx, [rbp+disp]
函数 发射_载rcx从变量(disp) { 如果 (disp >= 0 - 128) {
 发射组([0x48, 0x8B, 0x4D]) 发射(disp & 0xFF)
 } 否则 {
 发射组([0x48, 0x8B, 0x8D]) 发射32(disp)
 }
}

// test rax, rax
函数 发射_测试rax() { 发射组([0x48, 0x85, 0xC0]) }

// 调用 rel32 (相对调用)
函数 发射_调用相对(目标) {
 发射(0xE8)
 定义 可变 相对 = 目标 - (代码位 + 4)
 发射32(相对)
}
// 调用 [rip+disp32] (间接调用)
函数 发射_调用间接(rip偏移) {
 发射组([0xFF, 0x15])
 发射32(rip偏移)
}

// 分配变量槽位 (返回 rbp 偏移, 负数; 全局返回 -1000-index)
函数 分配变量(名) { 如果 (主体模式 == 1) { 定义 已有 = 字典取(全局变量表, 名)
 如果 (已有 != 空) { 定义 ge = 0 - 1000 - (已有 - 1)
 字典设(变量表, 名, ge)
 返回 ge
 }
 }
 变量数 = 变量数 + 1
 定义 可变 偏移 = 0 - (变量数 * 8)
 字典设(变量表, 名, 偏移)
 返回 偏移
}

函数 AST_收集标识符(节点, 结果, 定义列) {
    如果 (节点 == 空) { 返回 空
}
 如果 (类型(节点) != "列表") { 返回 空 }
 如果 (计数(节点) == 0) { 返回 空 }
 定义 可变 ntype = 节点[0]
 如果 (类型(ntype) != "整数") {
 // 语句列表: 遍历每个子节点
 定义 可变 si = 0
 当 (si < 计数(节点)) {
 AST_收集标识符(节点[si], 结果, 定义列)
 si = si + 1
 }
 返回 空
 }
 如果 (ntype == 节_标识符) {
 追加(结果, 节点[1])
 返回 空
 }
 如果 (ntype == 节_定义) {
 追加(定义列, 节点[1])
 如果 (计数(节点) > 2) { AST_收集标识符(节点[2], 结果, 定义列) }
 返回 空
 }
 // 递归所有子节点
 定义 可变 ci = 1
 当 (ci < 计数(节点)) { 如果 (类型(节点[ci]) == "列表") {
 AST_收集标识符(节点[ci], 结果, 定义列)
 }
 ci = ci + 1
 }
}

函数 查变量(名) { 定义 局部 = 字典取(变量表, 名)
 如果 (局部 != 空) { 返回 局部 }
 定义 全局 = 字典取(全局变量表, 名)
 如果 (全局 != 空) { 返回 0 - 1000 - (全局 - 1) }
 返回 空
}


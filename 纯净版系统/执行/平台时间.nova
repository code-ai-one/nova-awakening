导入("../中枢/类型定义.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/内核打印.nova")

定义 调用号_时间微秒 = 300
定义 调用号_时间纳秒 = 301
定义 调用号_墙钟秒 = 302
定义 调用号_睡眠微秒 = 303
定义 调用号_性能计数 = 304
定义 调用号_性能频率 = 305
定义 调用号_进程时间 = 306
定义 调用号_设置定时器 = 307
定义 调用号_取消定时器 = 308

定义 最大定时器数 = 32

结构 定时器 {
    ID,
    截止时间_us,
    间隔_us,
    回调,
    重复,
    活跃,
}

结构 秒表 {
    开始时间,
    分段列表,
    运行中,
}

结构 时间统计 {
    调用总数,
    时间查询数,
    睡眠总时间_us,
    睡眠次数,
    忙等总时间_us,
    忙等次数,
    定时器触发次数,
    定时器超时次数,
}

定义 可变 启动时刻 = 0
定义 可变 性能频率 = 0
定义 可变 全局_时间统计 = 空
定义 可变 全局_定时器列表 = []
定义 可变 全局_定时器下个ID = 1
定义 可变 时区偏移_秒 = 28800

函数 时间统计_初始化() {
    如果 (全局_时间统计 == 空) {
        全局_时间统计 = 时间统计 {}
        全局_时间统计.调用总数 = 0
        全局_时间统计.时间查询数 = 0
        全局_时间统计.睡眠总时间_us = 0
        全局_时间统计.睡眠次数 = 0
        全局_时间统计.忙等总时间_us = 0
        全局_时间统计.忙等次数 = 0
        全局_时间统计.定时器触发次数 = 0
        全局_时间统计.定时器超时次数 = 0
    }
}

函数 系统调用(号码, 参数1, 参数2, 参数3, 参数4, 参数5) {
    时间统计_初始化()
    全局_时间统计.调用总数 = 全局_时间统计.调用总数 + 1
    返回 __内置_系统调用(号码, 参数1, 参数2, 参数3, 参数4, 参数5)
}

函数 平台_初始化时间() {
    时间统计_初始化()
    性能频率 = 系统调用(调用号_性能频率, 0, 0, 0, 0, 0)
    如果 (性能频率 == 0) { 性能频率 = 1000000 }
    启动时刻 = 平台_获取高精度时间()
}

函数 平台_获取高精度时间() {
    时间统计_初始化()
    全局_时间统计.时间查询数 = 全局_时间统计.时间查询数 + 1
    返回 系统调用(调用号_时间微秒, 0, 0, 0, 0, 0)
}

函数 平台_获取纳秒时间() {
    时间统计_初始化()
    全局_时间统计.时间查询数 = 全局_时间统计.时间查询数 + 1
    返回 系统调用(调用号_时间纳秒, 0, 0, 0, 0, 0)
}

函数 平台_获取墙钟秒() {
    返回 系统调用(调用号_墙钟秒, 0, 0, 0, 0, 0)
}

函数 平台_获取单调时间() {
    返回 平台_获取高精度时间()
}

函数 平台_运行时间微秒() {
    返回 平台_获取高精度时间() - 启动时刻
}

函数 平台_运行时间毫秒() {
    返回 平台_运行时间微秒() / 1000
}

函数 平台_运行时间秒() {
    返回 平台_运行时间微秒() / 1000000
}

函数 平台_睡眠微秒(微秒) {
    时间统计_初始化()
    如果 (微秒 <= 0) { 返回 }
    全局_时间统计.睡眠次数 = 全局_时间统计.睡眠次数 + 1
    全局_时间统计.睡眠总时间_us = 全局_时间统计.睡眠总时间_us + 微秒
    系统调用(调用号_睡眠微秒, 微秒, 0, 0, 0, 0)
}

函数 平台_睡眠毫秒(毫秒) {
    平台_睡眠微秒(毫秒 * 1000)
}

函数 平台_睡眠秒(秒) {
    平台_睡眠微秒(秒 * 1000000)
}

函数 平台_忙等微秒(微秒) {
    时间统计_初始化()
    全局_时间统计.忙等次数 = 全局_时间统计.忙等次数 + 1
    全局_时间统计.忙等总时间_us = 全局_时间统计.忙等总时间_us + 微秒
    定义 目标 = 平台_获取高精度时间() + 微秒
    当 (平台_获取高精度时间() < 目标) { }
}

函数 平台_忙等纳秒(纳秒) {
    定义 目标 = 平台_获取纳秒时间() + 纳秒
    当 (平台_获取纳秒时间() < 目标) { }
}

函数 平台_性能计数() {
    返回 系统调用(调用号_性能计数, 0, 0, 0, 0, 0)
}

函数 平台_性能频率() {
    返回 性能频率
}

函数 平台_计时开始() {
    返回 平台_性能计数()
}

函数 平台_计时结束(开始值) {
    定义 结束 = 平台_性能计数()
    定义 差值 = 结束 - 开始值
    如果 (性能频率 > 0) {
        返回 差值 * 1000000 / 性能频率
    }
    返回 差值
}

函数 平台_计时结束_毫秒(开始值) {
    返回 平台_计时结束(开始值) / 1000
}

函数 平台_进程处理器时间() {
    返回 系统调用(调用号_进程时间, 0, 0, 0, 0, 0)
}

函数 创建定时器(间隔_us, 回调, 重复) {
    时间统计_初始化()
    如果 (计数(全局_定时器列表) >= 最大定时器数) { 返回 -1 }

    定义 t = 定时器 {}
    t.ID = 全局_定时器下个ID
    全局_定时器下个ID = 全局_定时器下个ID + 1
    t.截止时间_us = 平台_获取高精度时间() + 间隔_us
    t.间隔_us = 间隔_us
    t.回调 = 回调
    t.重复 = 重复
    t.活跃 = 真

    追加(全局_定时器列表, t)
    返回 t.ID
}

函数 取消定时器(ID) {
    定义 可变 i = 0
    当 (i < 计数(全局_定时器列表)) {
        如果 (全局_定时器列表[i].ID == ID) {
            全局_定时器列表[i].活跃 = 假
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 检查定时器() {
    时间统计_初始化()
    定义 当前 = 平台_获取高精度时间()
    定义 可变 i = 0
    当 (i < 计数(全局_定时器列表)) {
        定义 t = 全局_定时器列表[i]
        如果 (t.活跃 && 当前 >= t.截止时间_us) {
            全局_时间统计.定时器触发次数 = 全局_时间统计.定时器触发次数 + 1
            如果 (t.回调 != 空) { t.回调() }
            如果 (t.重复) {
                t.截止时间_us = 当前 + t.间隔_us
            } 否则 {
                t.活跃 = 假
            }
        }
        i = i + 1
    }
}

函数 清理过期定时器() {
    定义 可变 新列表 = []
    定义 可变 i = 0
    当 (i < 计数(全局_定时器列表)) {
        如果 (全局_定时器列表[i].活跃) {
            追加(新列表, 全局_定时器列表[i])
        }
        i = i + 1
    }
    全局_定时器列表 = 新列表
}

函数 等待截止时间(截止_us) {
    时间统计_初始化()
    定义 当前 = 平台_获取高精度时间()
    如果 (当前 >= 截止_us) {
        全局_时间统计.定时器超时次数 = 全局_时间统计.定时器超时次数 + 1
        返回 假
    }
    平台_睡眠微秒(截止_us - 当前)
    返回 真
}

函数 秒表_创建() {
    定义 sw = 秒表 {}
    sw.开始时间 = 0
    sw.分段列表 = []
    sw.运行中 = 假
    返回 sw
}

函数 秒表_启动(sw) {
    sw.开始时间 = 平台_获取高精度时间()
    sw.运行中 = 真
}

函数 秒表_分段(sw) {
    如果 (!sw.运行中) { 返回 0 }
    定义 当前 = 平台_获取高精度时间()
    定义 分段时间 = 当前 - sw.开始时间
    追加(sw.分段列表, 分段时间)
    返回 分段时间
}

函数 秒表_停止(sw) {
    如果 (!sw.运行中) { 返回 0 }
    定义 总时间 = 平台_获取高精度时间() - sw.开始时间
    sw.运行中 = 假
    返回 总时间
}

函数 秒表_重置(sw) {
    sw.开始时间 = 0
    sw.分段列表 = []
    sw.运行中 = 假
}

函数 设置时区(偏移_秒) {
    时区偏移_秒 = 偏移_秒
}

函数 墙钟_本地秒() {
    返回 平台_获取墙钟秒() + 时区偏移_秒
}

函数 秒转日期(总秒) {
    定义 可变 剩余 = 总秒
    定义 天 = 剩余 / 86400
    剩余 = 剩余 % 86400
    定义 时 = 剩余 / 3600
    剩余 = 剩余 % 3600
    定义 分 = 剩余 / 60
    定义 秒 = 剩余 % 60

    定义 可变 年 = 1970
    定义 可变 剩余天 = 天
    当 (真) {
        定义 年天数 = 365
        如果 (是闰年(年)) { 年天数 = 366 }
        如果 (剩余天 < 年天数) { 跳出 }
        剩余天 = 剩余天 - 年天数
        年 = 年 + 1
    }

    定义 月天数 = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]
    如果 (是闰年(年)) { 月天数[1] = 29 }
    定义 可变 月 = 0
    当 (月 < 12 && 剩余天 >= 月天数[月]) {
        剩余天 = 剩余天 - 月天数[月]
        月 = 月 + 1
    }

    返回 [年, 月 + 1, 剩余天 + 1, 时, 分, 秒]
}

函数 是闰年(年) {
    如果 (年 % 400 == 0) { 返回 真 }
    如果 (年 % 100 == 0) { 返回 假 }
    如果 (年 % 4 == 0) { 返回 真 }
    返回 假
}

函数 格式化时间(日期) {
    返回 整数转字符串(日期[0]) + "-"
        + 补零2(日期[1]) + "-"
        + 补零2(日期[2]) + " "
        + 补零2(日期[3]) + ":"
        + 补零2(日期[4]) + ":"
        + 补零2(日期[5])
}

函数 补零2(n) {
    如果 (n < 10) { 返回 "0" + 整数转字符串(n) }
    返回 整数转字符串(n)
}

函数 获取当前时间字符串() {
    返回 格式化时间(秒转日期(墙钟_本地秒()))
}

函数 平台_微秒转毫秒(微秒) { 返回 微秒 / 1000 }
函数 平台_微秒转秒(微秒) { 返回 微秒 / 1000000 }
函数 平台_毫秒转微秒(毫秒) { 返回 毫秒 * 1000 }
函数 平台_秒转微秒(秒) { 返回 秒 * 1000000 }
函数 平台_纳秒转微秒(纳秒) { 返回 纳秒 / 1000 }

函数 平台时间_完整统计() {
    时间统计_初始化()
    返回 [全局_时间统计.调用总数, 全局_时间统计.时间查询数,
           平台_运行时间微秒(), 性能频率,
           全局_时间统计.睡眠次数, 全局_时间统计.忙等次数,
           全局_时间统计.定时器触发次数, 计数(全局_定时器列表)]
}

函数 平台时间_打印统计() {
    时间统计_初始化()
    打印行("=== 平台时间统计 ===")
    打印行("运行时间: " + 整数转字符串(平台_运行时间微秒() / 1000000) + " 秒")
    打印行("系统调用: " + 整数转字符串(全局_时间统计.调用总数) + " 次")
    打印行("时间查询: " + 整数转字符串(全局_时间统计.时间查询数) + " 次")
    打印行("睡眠: " + 整数转字符串(全局_时间统计.睡眠次数) + " 次 ("
        + 整数转字符串(全局_时间统计.睡眠总时间_us / 1000) + " ms)")
    打印行("忙等: " + 整数转字符串(全局_时间统计.忙等次数) + " 次")
    打印行("定时器: " + 整数转字符串(计数(全局_定时器列表)) + " 活跃, "
        + 整数转字符串(全局_时间统计.定时器触发次数) + " 触发")
    打印行("当前时间: " + 获取当前时间字符串())
}

// NPTS — Nova Platform Time Subsystem Theory
// 公理1(单调性): 单调时钟永不回退
// 公理2(精度界): 时间精度受硬件频率限制
// 定理1(定时可靠): 定时器触发误差在可接受范围内
// 定理2(秒表可加): 多次秒表测量可累加

函数 秒表_开始(sw) {
    sw.开始时间 = 平台_获取高精度时间()
    sw.运行中 = 真
    sw.分段列表 = []
}

函数 秒表_获取分段数(sw) { 返回 计数(sw.分段列表) }

函数 秒表_平均分段(sw) {
    如果 (计数(sw.分段列表) == 0) { 返回 0 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(sw.分段列表)) {
        总 = 总 + sw.分段列表[i]
        i = i + 1
    }
    返回 总 / 计数(sw.分段列表)
}

函数 平台_时间差_微秒(t1, t2) {
    如果 (t2 >= t1) { 返回 t2 - t1 }
    返回 0
}

函数 平台_时间差_毫秒(t1, t2) {
    返回 平台_时间差_微秒(t1, t2) / 1000
}

函数 获取定时器数() { 返回 计数(全局_定时器列表) }

函数 获取活跃定时器数() {
    定义 可变 活跃 = 0
    定义 可变 i = 0
    当 (i < 计数(全局_定时器列表)) {
        如果 (全局_定时器列表[i].活跃) { 活跃 = 活跃 + 1 }
        i = i + 1
    }
    返回 活跃
}

函数 平台_设置时区(偏移_秒) {
    时区偏移_秒 = 偏移_秒
}

函数 平台_获取时区() { 返回 时区偏移_秒 }

函数 壁钟_本地秒() {
    返回 平台_获取壁钟秒() + 时区偏移_秒
}

函数 平台_重置统计() {
    如果 (全局_时间统计 != 空) {
        全局_时间统计.调用总数 = 0
        全局_时间统计.时间查询数 = 0
        全局_时间统计.睡眠总时间_us = 0
        全局_时间统计.睡眠次数 = 0
        全局_时间统计.忙等总时间_us = 0
        全局_时间统计.忙等次数 = 0
        全局_时间统计.定时器触发次数 = 0
        全局_时间统计.定时器超时次数 = 0
    }
}

函数 平台_获取调用数() { 时间统计_初始化(); 返回 全局_时间统计.调用总数 }
函数 平台_获取睡眠数() { 时间统计_初始化(); 返回 全局_时间统计.睡眠次数 }
函数 平台_获取定时器触发数() { 时间统计_初始化(); 返回 全局_时间统计.定时器触发次数 }
函数 平台_获取定时器超时数() { 时间统计_初始化(); 返回 全局_时间统计.定时器超时次数 }

函数 平台_时间戳格式化() {
    定义 d = 秒转日期(壁钟_本地秒())
    返回 整数转字符串(d[0]) + "-" +
           整数转字符串(d[1]) + "-" +
           整数转字符串(d[2]) + " " +
           整数转字符串(d[3]) + ":" +
           整数转字符串(d[4]) + ":" +
           整数转字符串(d[5])
}

定义 可变 AI_平台时间_负载窗口 = []

函数 AI_平台时间_负载预测(当前负载) {
    追加(AI_平台时间_负载窗口, 当前负载)
    如果 (计数(AI_平台时间_负载窗口) > 20) { 列表_移除(AI_平台时间_负载窗口, 0) }
    如果 (计数(AI_平台时间_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_平台时间_负载窗口)
    定义 趋势 = AI_平台时间_负载窗口[n-1] - AI_平台时间_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_平台时间_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

// §5 will-change优化提示

// will-change: transform → 提前创建合成层
// will-change: opacity → 提前创建合成层
// will-change: scroll-position → 提前分配滚动缓冲

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../推理/值乘.nova")
导入("../执行/控制台输出.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/辅助存根.nova")
导入("../中枢/创建甲.nova")

函数 WillChange_处理(元素, 属性) {
    如果 (元素 == 0 || 属性 == 0) { 返回 }
    如果 (字符串_包含(属性, "transform") || 字符串_包含(属性, "opacity")) {
        // 提升到合成层(图处加速)
        // 避免后续动画触发布局
    }
    如果 (字符串_包含(属性, "scroll-position")) {
        // 预分配滚动缓冲区
    }
    // 注意: will-change过多反而降低性能(内存开销)
}

// §6 渲染帧调度与优先级

结构 渲染Scheduler {
    // 渲染优先级
    有用户交互,    // 布尔 用户正在交互 → 优先渲染
    有动画,    // 布尔 有活跃动画 → 60fps
    有滚动,    // 布尔 正在滚动 → 优先合成
    // 帧预算
    目标帧率,    // u32 60 或 120
    帧预算ms,    // u32 16 或 8
    // 脏区域
    需要样式,
    需要布局,
    需要绘制,
    需要合成,
    // 统计
    掉帧计数,
    连续掉帧,
}

定义 可变 全局渲染调度 = 0

函数 渲染Scheduler_获取() {
    如果 (全局渲染调度 == 0) {
        全局渲染调度 = 堆_分配(渲染Scheduler)
        全局渲染调度.有用户交互 = 假; 全局渲染调度.有动画 = 假; 全局渲染调度.有滚动 = 假
        全局渲染调度.目标帧率 = 60; 全局渲染调度.帧预算ms = 16
        全局渲染调度.需要样式 = 假; 全局渲染调度.需要布局 = 假
        全局渲染调度.需要绘制 = 假; 全局渲染调度.需要合成 = 假
        全局渲染调度.掉帧计数 = 0; 全局渲染调度.连续掉帧 = 0
    }
    返回 全局渲染调度
}

// 标记需要渲染
函数 渲染Scheduler_标记脏(类型) {
    定义 rs = 渲染Scheduler_获取()
    如果 (类型 == 0) { rs.需要样式 = 真; rs.需要布局 = 真; rs.需要绘制 = 真 }
    否则 如果 (类型 == 1) { rs.需要布局 = 真; rs.需要绘制 = 真 }
    否则 如果 (类型 == 2) { rs.需要绘制 = 真 }
    否则 如果 (类型 == 3) { rs.需要合成 = 真 }
}

// 判断本帧是否需要渲染
函数 渲染Scheduler_需要渲染() {
    定义 rs = 渲染Scheduler_获取()
    返回 rs.需要样式 || rs.需要布局 || rs.需要绘制 || rs.需要合成
}

// 渲染管线执行
函数 渲染Scheduler_执行() {
    定义 rs = 渲染Scheduler_获取()
    定义 开始 = 平台_获取高精度时间()

    // 1. 样式计算
    如果 (rs.需要样式) { rs.需要样式 = 假 }

    // 2. 布局
    如果 (rs.需要布局) { rs.需要布局 = 假 }

    // 检查时间: 如果已超帧预算, 跳过绘制(下帧补)
    定义 已用 = 平台_获取高精度时间() - 开始
    如果 (已用 > rs.帧预算ms) {
        rs.掉帧计数 = rs.掉帧计数 + 1
        rs.连续掉帧 = rs.连续掉帧 + 1
        返回
    }

    // 3. 绘制
    如果 (rs.需要绘制) { rs.需要绘制 = 假 }

    // 4. 合成
    如果 (rs.需要合成) { rs.需要合成 = 假 }

    rs.连续掉帧 = 0
}

// §7 NWCO理论 — Nova Will-Change Compositor Optimization
// 低耦合高聚合合成层优化增强

定义 NWCO_版本 = "3.0.0-NWCO"
定义 NWCO_最大合成层 = 64
定义 NWCO_内存预算_MB = 128
定义 NWCO_AI阈值 = 0.68
定义 NWCO_最大追踪属性 = 16

定义 可变 NWCO_层计数 = 0
定义 可变 NWCO_层内存_KB = 0
定义 可变 NWCO_提升次数 = 0
定义 可变 NWCO_降级次数 = 0
定义 可变 NWCO_AI推理次数 = 0
定义 可变 NWCO_帧优化次数 = 0

// §7.1 合成层描述结构

结构 NWCO_合成层 {
    元素ID: 0
    宽度: 0
    高度: 0
    内存KB: 0
    是GPU加速: 假
    变换提示: 假
    透明提示: 假
    滚动提示: 假
    内容提示: 假
    创建时间: 0
    最后访问: 0
    命中次数: 0
    z序: 0
    是活跃: 假
}

结构 NWCO_属性追踪 {
    属性名: 0
    属性类型: 0        // 0=transform 1=opacity 2=scroll 3=contents 4=other
    首次声明帧: 0
    最后使用帧: 0
    命中次数: 0
    已提升: 假
}

结构 NWCO_层管理器 {
    层池: 0
    层池容量: 0
    活跃层数: 0
    追踪表: 0
    追踪数: 0
    当前帧号: 0
    总内存KB: 0
    GPU可用: 假
}

// §7.2 层管理器初始化

定义 可变 全局层管理器 = 0

函数 NWCO_初始化() {
    全局层管理器 = 堆_分配(NWCO_层管理器)
    全局层管理器.层池容量 = NWCO_最大合成层
    全局层管理器.层池 = 堆_分配数组(NWCO_合成层, NWCO_最大合成层)
    全局层管理器.活跃层数 = 0
    全局层管理器.追踪表 = 堆_分配数组(NWCO_属性追踪, NWCO_最大追踪属性)
    全局层管理器.追踪数 = 0
    全局层管理器.当前帧号 = 0
    全局层管理器.总内存KB = 0
    全局层管理器.GPU可用 = 真
    NWCO_层计数 = 0
    NWCO_层内存_KB = 0
    NWCO_提升次数 = 0
    NWCO_降级次数 = 0
    NWCO_AI推理次数 = 0
    NWCO_帧优化次数 = 0
    打印("[NWCO] Will-Change合成优化引擎 v" + NWCO_版本 + " 已初始化")
}

函数 NWCO_获取管理器() {
    如果 (全局层管理器 == 0) { NWCO_初始化() }
    返回 全局层管理器
}

// §7.3 属性解析与分类

函数 NWCO_属性分类(属性名) {
    如果 (字符串_等于(属性名, "transform")) { 返回 0 }
    如果 (字符串_等于(属性名, "opacity")) { 返回 1 }
    如果 (字符串_等于(属性名, "scroll-position")) { 返回 2 }
    如果 (字符串_等于(属性名, "contents")) { 返回 3 }
    返回 4
}

函数 NWCO_属性需要GPU(类型) {
    返回 类型 == 0 || 类型 == 1
}

函数 NWCO_属性需要缓冲(类型) {
    返回 类型 == 2
}

函数 NWCO_解析will_change(属性字符串) {
    // 解析 "transform, opacity" 格式
    如果 (属性字符串 == 0) { 返回 0 }
    如果 (字符串_等于(属性字符串, "auto")) { 返回 0 }
    定义 mgr = NWCO_获取管理器()
    定义 可变 计数 = 0
    定义 可变 起始 = 0
    定义 长度 = 字节长度(属性字符串)
    定义 可变 i = 0
    当 (i <= 长度) {
        定义 b = 如果(i < 长度, 字节取(属性字符串, i), 44)  // 末尾当逗号
        如果 (b == 44 || b == 32) {   // , or space
            如果 (i > 起始) {
                定义 名 = 字符串_子串(属性字符串, 起始, i - 起始)
                定义 名T = 字符串_去空白(名)
                如果 (字节长度(名T) > 0) {
                    NWCO_注册追踪属性(名T)
                    计数 = 计数 + 1
                }
            }
            起始 = i + 1
        }
        i = i + 1
    }
    返回 计数
}

// §7.4 属性追踪表

函数 NWCO_注册追踪属性(属性名) {
    定义 mgr = NWCO_获取管理器()
    // 查找已存在
    定义 可变 i = 0
    当 (i < mgr.追踪数) {
        定义 t = mgr.追踪表[i]
        如果 (字符串_等于(t.属性名, 属性名)) {
            t.命中次数 = t.命中次数 + 1
            t.最后使用帧 = mgr.当前帧号
            返回 i
        }
        i = i + 1
    }
    // 新建
    如果 (mgr.追踪数 >= NWCO_最大追踪属性) { 返回 -1 }
    定义 idx = mgr.追踪数
    mgr.追踪数 = mgr.追踪数 + 1
    定义 新 = mgr.追踪表[idx]
    新.属性名 = 属性名
    新.属性类型 = NWCO_属性分类(属性名)
    新.首次声明帧 = mgr.当前帧号
    新.最后使用帧 = mgr.当前帧号
    新.命中次数 = 1
    新.已提升 = 假
    返回 idx
}

函数 NWCO_清除过期追踪(过期帧数) {
    定义 mgr = NWCO_获取管理器()
    定义 阈值 = mgr.当前帧号 - 过期帧数
    定义 可变 i = 0
    当 (i < mgr.追踪数) {
        定义 t = mgr.追踪表[i]
        如果 (t.最后使用帧 < 阈值) {
            // 紧凑：末尾填充
            mgr.追踪数 = mgr.追踪数 - 1
            如果 (i < mgr.追踪数) {
                mgr.追踪表[i] = mgr.追踪表[mgr.追踪数]
            }
            继续
        }
        i = i + 1
    }
}

// §8 合成层提升/降级引擎

函数 NWCO_计算层内存(宽, 高) {
    // RGBA * 宽 * 高 / 1024 = KB
    返回 (宽 * 高 * 4) / 1024
}

函数 NWCO_能否分配(需要KB) {
    定义 mgr = NWCO_获取管理器()
    定义 预算KB = NWCO_内存预算_MB * 1024
    返回 (mgr.总内存KB + 需要KB) <= 预算KB
}

函数 NWCO_分配合成层(元素ID, 宽, 高) {
    定义 mgr = NWCO_获取管理器()
    如果 (mgr.活跃层数 >= mgr.层池容量) { 返回 -1 }
    定义 需要KB = NWCO_计算层内存(宽, 高)
    如果 (!NWCO_能否分配(需要KB)) { 返回 -1 }
    定义 idx = mgr.活跃层数
    mgr.活跃层数 = mgr.活跃层数 + 1
    定义 层 = mgr.层池[idx]
    层.元素ID = 元素ID
    层.宽度 = 宽
    层.高度 = 高
    层.内存KB = 需要KB
    层.是GPU加速 = 假
    层.变换提示 = 假
    层.透明提示 = 假
    层.滚动提示 = 假
    层.内容提示 = 假
    层.创建时间 = 平台_获取高精度时间()
    层.最后访问 = 层.创建时间
    层.命中次数 = 0
    层.z序 = idx
    层.是活跃 = 真
    mgr.总内存KB = mgr.总内存KB + 需要KB
    NWCO_层计数 = NWCO_层计数 + 1
    NWCO_层内存_KB = mgr.总内存KB
    返回 idx
}

函数 NWCO_释放合成层(idx) {
    定义 mgr = NWCO_获取管理器()
    如果 (idx < 0 || idx >= mgr.活跃层数) { 返回 }
    定义 层 = mgr.层池[idx]
    mgr.总内存KB = mgr.总内存KB - 层.内存KB
    层.是活跃 = 假
    层.元素ID = 0
    // 紧凑数组
    如果 (idx < mgr.活跃层数 - 1) {
        mgr.层池[idx] = mgr.层池[mgr.活跃层数 - 1]
    }
    mgr.活跃层数 = mgr.活跃层数 - 1
    NWCO_层计数 = mgr.活跃层数
    NWCO_层内存_KB = mgr.总内存KB
}

函数 NWCO_查找元素层(元素ID) {
    定义 mgr = NWCO_获取管理器()
    定义 可变 i = 0
    当 (i < mgr.活跃层数) {
        如果 (mgr.层池[i].元素ID == 元素ID) { 返回 i }
        i = i + 1
    }
    返回 -1
}

// §9 层提升决策引擎

函数 NWCO_提升元素(元素, 宽, 高) {
    NWCO_提升次数 = NWCO_提升次数 + 1
    定义 已有 = NWCO_查找元素层(元素.ID)
    如果 (已有 >= 0) {
        定义 mgr = NWCO_获取管理器()
        mgr.层池[已有].最后访问 = 平台_获取高精度时间()
        mgr.层池[已有].命中次数 = mgr.层池[已有].命中次数 + 1
        返回 已有
    }
    返回 NWCO_分配合成层(元素.ID, 宽, 高)
}

函数 NWCO_降级元素(元素) {
    NWCO_降级次数 = NWCO_降级次数 + 1
    定义 idx = NWCO_查找元素层(元素.ID)
    如果 (idx >= 0) { NWCO_释放合成层(idx) }
}

函数 NWCO_设置层GPU(层idx, 启用) {
    定义 mgr = NWCO_获取管理器()
    如果 (层idx < 0 || 层idx >= mgr.活跃层数) { 返回 }
    mgr.层池[层idx].是GPU加速 = 启用
}

函数 NWCO_设置层提示(层idx, 变换, 透明, 滚动, 内容) {
    定义 mgr = NWCO_获取管理器()
    如果 (层idx < 0 || 层idx >= mgr.活跃层数) { 返回 }
    定义 层 = mgr.层池[层idx]
    层.变换提示 = 变换
    层.透明提示 = 透明
    层.滚动提示 = 滚动
    层.内容提示 = 内容
}

// §10 WillChange_处理增强版

函数 NWCO_处理will_change(元素, 属性字符串) {
    如果 (元素 == 0 || 属性字符串 == 0) { 返回 }
    如果 (字符串_等于(属性字符串, "auto")) {
        // auto = 清除所有will-change提示
        NWCO_降级元素(元素)
        返回
    }
    定义 宽 = 元素.宽度
    定义 高 = 元素.高度
    如果 (宽 <= 0) { 宽 = 100 }
    如果 (高 <= 0) { 高 = 100 }
    定义 层idx = NWCO_提升元素(元素, 宽, 高)
    如果 (层idx < 0) { 返回 }

    定义 有变换 = 字符串_包含(属性字符串, "transform")
    定义 有透明 = 字符串_包含(属性字符串, "opacity")
    定义 有滚动 = 字符串_包含(属性字符串, "scroll-position")
    定义 有内容 = 字符串_包含(属性字符串, "contents")

    NWCO_设置层提示(层idx, 有变换, 有透明, 有滚动, 有内容)

    // GPU加速判定：transform或opacity提示时开启
    如果 (有变换 || 有透明) {
        NWCO_设置层GPU(层idx, 真)
    }

    // 解析并注册追踪
    NWCO_解析will_change(属性字符串)
}

// §11 内存压力回收

函数 NWCO_LRU降级(目标释放KB) {
    // 淘汰最久未访问的合成层直到释放足够内存
    定义 mgr = NWCO_获取管理器()
    定义 可变 已释放 = 0
    当 (已释放 < 目标释放KB && mgr.活跃层数 > 0) {
        // 查找最小last-access
        定义 可变 最旧idx = 0
        定义 可变 最旧时间 = mgr.层池[0].最后访问
        定义 可变 i = 1
        当 (i < mgr.活跃层数) {
            如果 (mgr.层池[i].最后访问 < 最旧时间) {
                最旧时间 = mgr.层池[i].最后访问
                最旧idx = i
            }
            i = i + 1
        }
        已释放 = 已释放 + mgr.层池[最旧idx].内存KB
        NWCO_释放合成层(最旧idx)
    }
    返回 已释放
}

函数 NWCO_检查内存压力() {
    定义 mgr = NWCO_获取管理器()
    定义 预算KB = NWCO_内存预算_MB * 1024
    如果 (mgr.总内存KB > 预算KB * 90 / 100) {
        // 超过90%预算，开始LRU回收
        定义 目标 = mgr.总内存KB - (预算KB * 75 / 100)
        NWCO_LRU降级(目标)
    }
}

// §12 渲染调度增强

函数 NWCO_帧开始() {
    定义 mgr = NWCO_获取管理器()
    mgr.当前帧号 = mgr.当前帧号 + 1
    NWCO_帧优化次数 = NWCO_帧优化次数 + 1
}

函数 NWCO_帧结束() {
    // 帧末清理：回收超时追踪 + 检查内存
    NWCO_清除过期追踪(300)  // 300帧未使用则清除
    NWCO_检查内存压力()
}

函数 NWCO_调整帧率(rs) {
    // 连续掉帧3+时降到30fps；恢复后回到60fps
    如果 (rs.连续掉帧 >= 3) {
        rs.目标帧率 = 30
        rs.帧预算ms = 33
    } 否则 {
        rs.目标帧率 = 60
        rs.帧预算ms = 16
    }
}

函数 渲染Scheduler_执行增强() {
    定义 rs = 渲染Scheduler_获取()
    NWCO_帧开始()
    NWCO_调整帧率(rs)
    定义 开始 = 平台_获取高精度时间()

    // 阶段1: 样式
    如果 (rs.需要样式) { rs.需要样式 = 假 }
    定义 t1 = 平台_获取高精度时间() - 开始

    // 阶段2: 布局
    如果 (rs.需要布局) { rs.需要布局 = 假 }
    定义 t2 = 平台_获取高精度时间() - 开始

    // 检查帧预算
    如果 (t2 > rs.帧预算ms) {
        rs.掉帧计数 = rs.掉帧计数 + 1
        rs.连续掉帧 = rs.连续掉帧 + 1
        NWCO_帧结束()
        返回
    }

    // 阶段3: 绘制
    如果 (rs.需要绘制) { rs.需要绘制 = 假 }
    定义 t3 = 平台_获取高精度时间() - 开始

    // 阶段4: 合成（利用合成层加速）
    如果 (rs.需要合成) {
        NWCO_合成所有活跃层()
        rs.需要合成 = 假
    }

    rs.连续掉帧 = 0
    NWCO_帧结束()
}

// §13 合成执行

函数 NWCO_合成所有活跃层() {
    定义 mgr = NWCO_获取管理器()
    定义 可变 i = 0
    当 (i < mgr.活跃层数) {
        定义 层 = mgr.层池[i]
        如果 (层.是活跃) {
            NWCO_合成单层(层)
        }
        i = i + 1
    }
}

函数 NWCO_合成单层(层) {
    如果 (层.是GPU加速) {
        // GPU路径: 直接提交变换/透明矩阵到图处
        如果 (层.变换提示) { 图处_提交变换(层.元素ID) }
        如果 (层.透明提示) { 图处_提交透明(层.元素ID) }
    } 否则 {
        // CPU路径: 软件合成
        CPU_合成层(层.元素ID, 层.宽度, 层.高度)
    }
    如果 (层.滚动提示) {
        滚动缓冲_更新(层.元素ID)
    }
}

// §14 AI优化预测

函数 NWCO_AI预测提升收益(元素, 宽, 高) {
    NWCO_AI推理次数 = NWCO_AI推理次数 + 1
    定义 mgr = NWCO_获取管理器()
    定义 面积 = 宽 * 高
    定义 内存比 = mgr.总内存KB / (NWCO_内存预算_MB * 1024)
    定义 层比 = mgr.活跃层数 / mgr.层池容量
    定义 tensor = Tensor_创建(6)
    Tensor_写(tensor, 0, 面积 / 10000.0)
    Tensor_写(tensor, 1, 内存比)
    Tensor_写(tensor, 2, 层比)
    Tensor_写(tensor, 3, mgr.当前帧号 / 1000.0)
    Tensor_写(tensor, 4, 元素.动画计数)
    Tensor_写(tensor, 5, 元素.交互计数)
    定义 推理 = AI总线_推理(全局AI总线, "nwco_promote", tensor)
    定义 收益 = Tensor_读(推理, 0)
    Tensor_释放(tensor)
    Tensor_释放(推理)
    返回 收益
}

函数 NWCO_智能提升(元素, 宽, 高) {
    定义 收益 = NWCO_AI预测提升收益(元素, 宽, 高)
    如果 (收益 >= NWCO_AI阈值) {
        返回 NWCO_提升元素(元素, 宽, 高)
    }
    返回 -1  // 不值得提升
}

函数 NWCO_AI异常检测() {
    定义 mgr = NWCO_获取管理器()
    定义 tensor = Tensor_创建(4)
    Tensor_写(tensor, 0, mgr.活跃层数)
    Tensor_写(tensor, 1, mgr.总内存KB / 1024.0)
    Tensor_写(tensor, 2, NWCO_提升次数)
    Tensor_写(tensor, 3, NWCO_降级次数)
    定义 异常 = AI总线_异常检测(全局AI总线, "nwco_anomaly", tensor)
    定义 分 = Tensor_读(异常, 0)
    Tensor_释放(tensor)
    Tensor_释放(异常)
    如果 (分 > 0.85) {
        打印("[NWCO] AI异常: 合成层资源异常 score=" + 分)
        NWCO_LRU降级(mgr.总内存KB / 4)
    }
}

// §15 诊断与统计

函数 NWCO_诊断报告() {
    定义 mgr = NWCO_获取管理器()
    打印("[NWCO] === Will-Change合成优化诊断 ===")
    打印("  活跃层数=" + mgr.活跃层数 + " / " + mgr.层池容量)
    打印("  总内存=" + mgr.总内存KB + "KB / " + (NWCO_内存预算_MB * 1024) + "KB")
    打印("  追踪属性=" + mgr.追踪数 + " 帧号=" + mgr.当前帧号)
    打印("  提升=" + 整数转字符串(NWCO_提升次数) + " 降级=" + 整数转字符串(NWCO_降级次数))
    打印("  AI推理=" + 整数转字符串(NWCO_AI推理次数) + " 帧优化=" + 整数转字符串(NWCO_帧优化次数))
}

函数 NWCO_重置统计() {
    NWCO_提升次数 = 0
    NWCO_降级次数 = 0
    NWCO_AI推理次数 = 0
    NWCO_帧优化次数 = 0
}

// NovaOS 底层事件引擎 — NEIT事件智能调度理论
// 原创理论: Nova Event Intelligence Theory (NEIT)
//   §1 事件合并: 同类型连续事件在Δt<合并窗口时合并为一
//   §2 去抖稳定: 高频重复事件延迟δ后发送, 消除机械抖动
//   §3 手势涌现: 触摸序列→状态机→手势语义(滑动/长按/缩放)
//   §4 优先级路由: 高优先级事件跳过队列直接分发
//   §5 事件订阅: 按类型注册回调, 事件分发到对应监听器
//   §6 节流控制: 事件发送速率限制, 防止过载
//   §7 事件录制回放: 记录并重放事件序列
//   NEIT守恒: 无论合并/去抖, 最终语义事件序列等价于原始意图
//   四阶段AI演进: NEIT在阶段1提供输入感知基础

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./内存初始化.nova")
导入("../感知/内核直连层.nova")
导入("./创建甲.nova")

定义 事件_同步 = 0
定义 事件_按键 = 1
定义 事件_相对 = 2
定义 事件_绝对 = 3
定义 最大事件队列 = 256
定义 最大输入设备 = 8
定义 按钮_左 = 0x110
定义 按钮_右 = 0x111
定义 按钮_中 = 0x112
定义 合并窗口 = 8        // NEIT定理1: 8ms内同类事件合并
定义 去抖延迟 = 30       // NEIT定理2: 30ms去抖窗口
定义 长按阈值 = 500      // NEIT定理3: 500ms判定长按
定义 滑动阈值 = 50       // 最小滑动距离(像素)

结构 输入事件 {
    时间戳,
    类型,
    代码,
    值,
}

结构 输入设备 {
    标识,
    类型掩码,
    活跃,
    事件数,
}

定义 可变 事件队列 = 0
定义 可变 队列头 = 0
定义 可变 队列尾 = 0
定义 可变 队列大小 = 0
定义 可变 设备表 = []
定义 可变 设备数 = 0
定义 可变 发送总数 = 0
定义 可变 丢弃总数 = 0
定义 可变 合并总数 = 0
定义 可变 去抖总数 = 0
定义 可变 鼠标横 = 0
定义 可变 鼠标纵 = 0
定义 可变 路由_直接分发数 = 0
定义 可变 节流_拒绝数 = 0

// NEIT定理1: 合并状态
定义 可变 上次事件类型 = -1
定义 可变 上次事件代码 = -1
定义 可变 上次事件时间 = 0

// NEIT定理2: 去抖状态
定义 可变 去抖_键码 = -1
定义 可变 去抖_时间 = 0
定义 可变 去抖_值 = 0

// NEIT定理3: 触摸手势状态机
定义 手势_空闲 = 0
定义 手势_按下 = 1
定义 手势_移动 = 2
定义 可变 手势_状态 = 0
定义 可变 手势_起始横 = 0
定义 可变 手势_起始纵 = 0
定义 可变 手势_当前横 = 0
定义 可变 手势_当前纵 = 0
定义 可变 手势_起始时间 = 0
定义 可变 手势_识别总数 = 0


函数 输入_初始化() {
    事件队列 = 堆_分配(最大事件队列 * 24)
    队列头 = 0
    队列尾 = 0
    队列大小 = 0
    设备表 = []
    设备数 = 0
    上次事件类型 = -1
    去抖_键码 = -1
    手势_状态 = 手势_空闲
}

函数 输入_注册设备(类型掩码) {
    如果 (设备数 >= 最大输入设备) { 返回 -1 }
    定义 设备 = 输入设备 {}
    设备.标识 = 设备数
    设备.类型掩码 = 类型掩码
    设备.活跃 = 真
    设备.事件数 = 0
    追加(设备表, 设备)
    定义 索引 = 设备数
    设备数 = 设备数 + 1
    返回 索引
}

// NEIT定理1: 带合并的事件发送
函数 输入_发送事件(类型, 代码, 值) {
    发送总数 = 发送总数 + 1
    定义 当前时间 = 平台_获取高精度时间()
    // 合并检测: 同类型+同代码+时间窗口内→合并
    如果 (类型 == 上次事件类型 && 代码 == 上次事件代码) {
        如果 (当前时间 - 上次事件时间 < 合并窗口 && 类型 != 事件_同步) {
            如果 (队列大小 > 0) {
                定义 尾偏移 = 事件队列 + ((队列尾 - 1 + 最大事件队列) % 最大事件队列) * 24
                内存_冉32(尾偏移 + 16, 值)
                合并总数 = 合并总数 + 1
                上次事件时间 = 当前时间
                返回
            }
        }
    }
    如果 (队列大小 >= 最大事件队列) {
        丢弃总数 = 丢弃总数 + 1
        返回
    }
    定义 偏移 = 事件队列 + 队列尾 * 24
    内存_冉64(偏移, 当前时间)
    内存_冉32(偏移 + 8, 类型)
    内存_冉32(偏移 + 12, 代码)
    内存_冉32(偏移 + 16, 值)
    队列尾 = (队列尾 + 1) % 最大事件队列
    队列大小 = 队列大小 + 1
    上次事件类型 = 类型
    上次事件代码 = 代码
    上次事件时间 = 当前时间
}

函数 输入_读事件(输出偏移) {
    如果 (队列大小 == 0) { 返回 假 }
    定义 偏移 = 事件队列 + 队列头 * 24
    内存_复制(输出偏移, 偏移, 24)
    队列头 = (队列头 + 1) % 最大事件队列
    队列大小 = 队列大小 - 1
    返回 真
}

函数 输入_发送鼠标移动(横, 纵) {
    鼠标横 = 横
    鼠标纵 = 纵
    输入_发送事件(事件_绝对, 0, 横)
    输入_发送事件(事件_绝对, 1, 纵)
    输入_发送事件(事件_同步, 0, 0)
}

函数 输入_发送鼠标按钮(横, 纵, 按钮, 按下) {
    输入_发送鼠标移动(横, 纵)
    定义 可变 值 = 0
    如果 (按下) { 值 = 1 }
    输入_发送事件(事件_按键, 按钮_左 + 按钮 - 1, 值)
    输入_发送事件(事件_同步, 0, 0)
}

// NEIT定理2: 带去抖的按键发送
函数 输入_发送按键(键码, 按下) {
    定义 当前时间 = 平台_获取高精度时间()
    定义 可变 值 = 0
    如果 (按下) { 值 = 1 }
    // 去抖: 同键码在去抖窗口内的重复事件被抑制
    如果 (键码 == 去抖_键码 && 值 == 去抖_值) {
        如果 (当前时间 - 去抖_时间 < 去抖延迟) {
            去抖总数 = 去抖总数 + 1
            返回
        }
    }
    去抖_键码 = 键码
    去抖_值 = 值
    去抖_时间 = 当前时间
    输入_发送事件(事件_按键, 键码, 值)
    输入_发送事件(事件_同步, 0, 0)
}

函数 输入_发送滚轮(横, 纵, 方向, 量) {
    输入_发送鼠标移动(横, 纵)
    输入_发送事件(事件_相对, 方向, 量)
    输入_发送事件(事件_同步, 0, 0)
}

// §2 NEIT定理3: 触摸手势识别
// 状态机: 空闲→按下→移动→完成
// 识别: 点击(1)/长按(5)/上滑(6)/下滑(4)/左滑(3)/右滑(2)

函数 输入_发送触摸(横, 纵, 按下) {
    鼠标横 = 横
    鼠标纵 = 纵
    定义 当前时间 = 平台_获取高精度时间()
    如果 (按下) {
        手势_状态 = 手势_按下
        手势_起始横 = 横
        手势_起始纵 = 纵
        手势_当前横 = 横
        手势_当前纵 = 纵
        手势_起始时间 = 当前时间
    } 否则 {
        _手势_判定(当前时间)
        手势_状态 = 手势_空闲
    }
    定义 可变 值 = 0
    如果 (按下) { 值 = 1 }
    输入_发送事件(事件_绝对, 0, 横)
    输入_发送事件(事件_绝对, 1, 纵)
    输入_发送事件(事件_按键, 0x14A, 值)
    输入_发送事件(事件_同步, 0, 0)
}

函数 输入_触摸移动(横, 纵) {
    如果 (手势_状态 == 手势_按下) { 手势_状态 = 手势_移动 }
    手势_当前横 = 横
    手势_当前纵 = 纵
    输入_发送鼠标移动(横, 纵)
}

// 手势判定引擎
函数 _手势_判定(当前时间) {
    定义 持续 = 当前时间 - 手势_起始时间
    定义 可变 横距 = 手势_当前横 - 手势_起始横
    定义 可变 纵距 = 手势_当前纵 - 手势_起始纵
    定义 可变 绝横 = 横距
    定义 可变 绝纵 = 纵距
    如果 (绝横 < 0) { 绝横 = 0 - 绝横 }
    如果 (绝纵 < 0) { 绝纵 = 0 - 绝纵 }
    定义 距离 = 绝横 + 绝纵
    手势_识别总数 = 手势_识别总数 + 1
    如果 (距离 < 滑动阈值) {
        如果 (持续 >= 长按阈值) { 返回 5 }  // 长按
        返回 1  // 点击
    }
    如果 (绝横 > 绝纵) {
        如果 (横距 > 0) { 返回 2 }  // 右滑
        返回 3  // 左滑
    }
    如果 (纵距 > 0) { 返回 4 }  // 下滑
    返回 6  // 上滑
}

函数 输入_获取手势() {
    如果 (手势_状态 != 手势_空闲) { 返回 0 }
    返回 _手势_判定(平台_获取高精度时间())
}

函数 输入_获取鼠标位置() { 返回 [鼠标横, 鼠标纵] }
函数 输入_队列中事件数() { 返回 队列大小 }

// §3 批量注入 + 模拟输入 (自动化测试用)

函数 输入_批量注入(事件列表) {
    定义 可变 i = 0
    当 (i < 计数(事件列表)) {
        定义 ev = 事件列表[i]
        输入_发送事件(ev[0], ev[1], ev[2])
        i = i + 1
    }
    返回 计数(事件列表)
}

函数 输入_模拟打字(键码列表) {
    定义 可变 i = 0
    当 (i < 计数(键码列表)) {
        输入_发送按键(键码列表[i], 真)
        输入_发送按键(键码列表[i], 假)
        i = i + 1
    }
}

// 清空事件队列
函数 输入_清空队列() {
    队列头 = 0
    队列尾 = 0
    队列大小 = 0
}

// NEIT完整统计

// §4 优先级路由 — 高优先级事件直接分发

定义 优先级_即时 = 0     // 跳过队列直接分发
定义 优先级_高 = 1       // 队列头插入
定义 优先级_普通 = 2     // 队列尾插入
定义 优先级_低 = 3       // 可被丢弃

函数 输入_发送事件_带优先级(类型, 代码, 值, 优先级) {
    发送总数 = 发送总数 + 1
    // 即时优先级: 跳过队列, 直接调用监听器
    如果 (优先级 == 优先级_即时) {
        路由_直接分发数 = 路由_直接分发数 + 1
        事件_分发到监听器(类型, 代码, 值)
        返回
    }
    // 低优先级且队列超过3/4 → 丢弃
    如果 (优先级 == 优先级_低 && 队列大小 >= 最大事件队列 * 3 / 4) {
        丢弃总数 = 丢弃总数 + 1
        返回
    }
    // 其他: 进入正常队列流程
    输入_发送事件(类型, 代码, 值)
}

// §5 事件订阅 — 按类型注册回调监听器

定义 最大监听器 = 32
定义 可变 监听器表 = []
定义 可变 监听器数 = 0
定义 可变 分发_总回调数 = 0

结构 事件监听器 {
    类型过滤,      // 只监听此类型 (-1=所有类型)
    回调,          // 回调函数指针
    用户数据,      // 回调携带的上下文
    活跃,          // 是否启用
}

函数 输入_注册监听器(类型过滤, 回调, 用户数据) {
    如果 (监听器数 >= 最大监听器) { 返回 -1 }
    定义 监听 = 事件监听器 {}
    监听.类型过滤 = 类型过滤
    监听.回调 = 回调
    监听.用户数据 = 用户数据
    监听.活跃 = 真
    追加(监听器表, 监听)
    定义 索引 = 监听器数
    监听器数 = 监听器数 + 1
    返回 索引
}

函数 输入_注销监听器(索引) {
    如果 (索引 >= 0 && 索引 < 监听器数) {
        监听器表[索引].活跃 = 假
    }
}

函数 事件_分发到监听器(类型, 代码, 值) {
    定义 可变 i = 0
    当 (i < 监听器数) {
        如果 (监听器表[i].活跃) {
            如果 (监听器表[i].类型过滤 == -1 || 监听器表[i].类型过滤 == 类型) {
                监听器表[i].回调(类型, 代码, 值, 监听器表[i].用户数据)
                分发_总回调数 = 分发_总回调数 + 1
            }
        }
        i = i + 1
    }
}

// 队列事件流转: 读取后分发给监听器
函数 输入_分发队列事件() {
    定义 可变 临时 = 堆_分配(24)
    定义 可变 处理数 = 0
    当 (输入_读事件(临时)) {
        定义 类型 = 内存_读32(临时 + 8)
        定义 代码 = 内存_读32(临时 + 12)
        定义 值 = 内存_读32(临时 + 16)
        事件_分发到监听器(类型, 代码, 值)
        处理数 = 处理数 + 1
    }
    堆_释放(临时)
    返回 处理数
}

// §6 节流控制 — 限制事件发送速率

定义 节流_窗口毫秒 = 100    // 100ms窗口
定义 节流_最大事件 = 50      // 每窗口最多50个事件
定义 可变 节流_窗口开始 = 0
定义 可变 节流_窗口计数 = 0

函数 输入_节流检查() {
    定义 当前时间 = 平台_获取高精度时间()
    如果 (当前时间 - 节流_窗口开始 >= 节流_窗口毫秒) {
        节流_窗口开始 = 当前时间
        节流_窗口计数 = 0
        返回 真
    }
    如果 (节流_窗口计数 >= 节流_最大事件) {
        节流_拒绝数 = 节流_拒绝数 + 1
        返回 假
    }
    节流_窗口计数 = 节流_窗口计数 + 1
    返回 真
}

函数 输入_发送事件_带节流(类型, 代码, 值) {
    如果 (输入_节流检查()) {
        输入_发送事件(类型, 代码, 值)
    }
}

// §7 事件录制回放 — 记录并回放事件序列(调试用)

定义 最大录制事件 = 512
定义 可变 录制缓冲 = []
定义 可变 录制中 = 假
定义 可变 录制数量 = 0

函数 输入_开始录制() {
    录制缓冲 = []
    录制数量 = 0
    录制中 = 真
}

函数 输入_停止录制() {
    录制中 = 假
    返回 录制数量
}

函数 输入_录制事件(类型, 代码, 值) {
    如果 (录制中 && 录制数量 < 最大录制事件) {
        追加(录制缓冲, [平台_获取高精度时间(), 类型, 代码, 值])
        录制数量 = 录制数量 + 1
    }
}

函数 输入_回放录制() {
    如果 (录制中) { 返回 }  // 录制中不能回放
    定义 可变 i = 0
    当 (i < 录制数量) {
        定义 记录 = 录制缓冲[i]
        输入_发送事件(记录[1], 记录[2], 记录[3])
        i = i + 1
    }
}

函数 输入_获取录制数据() {
    返回 录制缓冲
}

// §8 设备管理增强 — 热插拔+查询

函数 输入_注销设备(设备标识) {
    如果 (设备标识 >= 0 && 设备标识 < 设备数) {
        设备表[设备标识].活跃 = 假
    }
}

函数 输入_设备是否活跃(设备标识) {
    如果 (设备标识 >= 0 && 设备标识 < 设备数) {
        返回 设备表[设备标识].活跃
    }
    返回 假
}

函数 输入_获取设备事件数(设备标识) {
    如果 (设备标识 >= 0 && 设备标识 < 设备数) {
        返回 设备表[设备标识].事件数
    }
    返回 0
}

函数 输入_获取活跃设备数() {
    定义 可变 活跃 = 0
    定义 可变 i = 0
    当 (i < 设备数) {
        如果 (设备表[i].活跃) { 活跃 = 活跃 + 1 }
        i = i + 1
    }
    返回 活跃
}

// NEIT完整诊断统计

函数 输入_完整统计() {
    返回 [
        ["发送总数", 发送总数],
        ["丢弃总数", 丢弃总数],
        ["合并总数", 合并总数],
        ["去抖总数", 去抖总数],
        ["队列大小", 队列大小],
        ["设备数", 设备数],
        ["手势识别", 手势_识别总数],
        ["监听器数", 监听器数],
        ["回调分发", 分发_总回调数],
        ["直接路由", 路由_直接分发数],
        ["节流拒绝", 节流_拒绝数],
        ["录制数量", 录制数量],
        ["鼠标位置", [鼠标横, 鼠标纵]]
    ]
}

导入("../基础.nova")

//
// Nova 标准库 密码学 CRC32校验算法
// 循环冗余校验 32位校验码, 用于数据传输完整性验证

// 循环冗余32 多项式
定义 校验_标准多项式 = 3988292384
定义 校验_卡斯塔尼奥利 = 517762881
定义 校验_科普多项式 = 3945912366

// 查找表 (标准多项式 0xEDB88320)

定义 可变 校验表 = []
定义 可变 校验表_已初始化 = 假

函数 校验_初始化表() {
    如果 (校验表_已初始化) { 返回
}
 校验表 = []
 定义 可变 i = 0
 当 (i < 256) { 定义 可变 校验值 = i
 定义 可变 j = 0
 当 (j < 8) { 如果 (校验值 % 2 == 1) {
 校验值 = (校验值 / 2) ^ 校验_标准多项式
 } 否则 {
 校验值 = 校验值 / 2
 }
 j = j + 1
 }
 追加(校验表, 校验值)
 i = i + 1
 }
 校验表_已初始化 = 真
}

// 位运算辅助

函数 校验_异或(a, b) { 返回 a ^ b }
函数 校验_与(a, b) { 返回 a & b }
函数 校验_右移(a, n) { 定义 可变 v = a
 定义 可变 i = 0
 当 (i < n) {
 v = v / 2
 i = i + 1
 }
 返回 v
}

// 统计
定义 可变 校验_处理字节 = 0
定义 可变 校验_计算次数 = 0

// 循环冗余32 核心计算

函数 crc32_计算(数据) {
 校验_初始化表()
 校验_计算次数 = 校验_计算次数 + 1
 定义 可变 校验值 = 0xFFFFFFFF
 定义 可变 i = 0
 定义 长度 = 字节长度(数据)
 当 (i < 长度) { 定义 字节 = 字节取(数据, i)
 定义 索引 = 校验_异或(校验值, 字节) & 255
 校验值 = 校验_异或(校验表[索引], 校验_右移(校验值, 8))
 i = i + 1
 }
 校验_处理字节 = 校验_处理字节 + 长度
 返回 校验_异或(校验值, 0xFFFFFFFF)
}

// 增量CRC32上下文

函数 crc32_创建上下文() {
 校验_初始化表()
 返回 [0xFFFFFFFF, 0, 假]
}

函数 crc32_更新(上下文, 数据) {
    如果 (上下文[2]) { 返回
}
 定义 可变 i = 0
 当 (i < 字节长度(数据)) { 定义 字节 = 字节取(数据, i)
 定义 索引 = 校验_异或(上下文[0], 字节) & 255
 上下文[0] = 校验_异或(校验表[索引], 校验_右移(上下文[0], 8))
 上下文[1] = 上下文[1] + 1
 i = i + 1
 }
}

函数 crc32_完成(上下文) {
 上下文[2] = 真
 返回 校验_异或(上下文[0], 0xFFFFFFFF)
}

函数 crc32_总字节(上下文) { 返回 上下文[1] }

// 循环冗余32 十六进制输出

函数 crc32_十六进制(数据) { 定义 v = crc32_计算(数据)
 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 8) {
 结果 = 结果 + 子串(十六进制表, 校验_右移(v, (7 - i) * 4) % 16, 1)
 i = i + 1
 }
 返回 结果
}

// 循环冗余32 校验

函数 crc32_校验(数据, 期望值) { 返回 crc32_计算(数据) == 期望值
}

函数 crc32_校验_十六进制(数据, 期望十六进制) { 返回 crc32_十六进制(数据) == 期望十六进制
}

// CRC32合并 (两个CRC合并)

函数 crc32_合并(crc1, crc2, 长度2) {
 校验_初始化表()
 定义 可变 校验值 = crc1
 定义 可变 i = 0
 当 (i < 长度2) { 定义 索引 = 校验值 & 255
 校验值 = 校验_异或(校验表[索引], 校验_右移(校验值, 8))
 i = i + 1
 }
 返回 校验_异或(校验值, crc2)
}

// 批量CRC32

函数 crc32_批量计算(数据列表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(数据列表)) {
 追加(结果, crc32_计算(数据列表[i]))
 i = i + 1
 }
 返回 结果
}

函数 crc32_检测损坏(原始数据, 接收数据) { 定义 原始校验 = crc32_计算(原始数据)
 定义 接收校验 = crc32_计算(接收数据)
 如果 (原始校验 == 接收校验) { 返回 [假, 0 - 1, "数据完整"] }
 定义 可变 首个差异 = 0 - 1
 定义 可变 差异数 = 0
 定义 可变 i = 0
 定义 原始长度 = 字节长度(原始数据)
 定义 接收长度 = 字节长度(接收数据)
 如果 (原始长度 != 接收长度) { 返回 [真, 0, "长度不匹配: 原始=" + 整数转文本(原始长度) + " 接收=" + 整数转文本(接收长度)]
 }
 当 (i < 原始长度) { 如果 (字节取(原始数据, i) != 字节取(接收数据, i)) { 如果 (首个差异 < 0) { 首个差异 = i }
 差异数 = 差异数 + 1
 }
 i = i + 1
 }
 返回 [真, 首个差异, "差异字节数: " + 整数转文本(差异数)]
}

函数 crc32_分段校验(数据, 段大小) { 定义 可变 结果 = []
 定义 可变 偏移 = 0
 定义 总长 = 字节长度(数据)
 当 (偏移 < 总长) { 定义 可变 当前大小 = 段大小
 如果 (偏移 + 当前大小 > 总长) { 当前大小 = 总长 - 偏移 }
 定义 可变 段上下文 = crc32_创建上下文()
 定义 可变 i = 0
 当 (i < 当前大小) { 定义 字节 = 字节取(数据, 偏移 + i)
 定义 索引 = 校验_异或(段上下文[0], 字节) & 255
 段上下文[0] = 校验_异或(校验表[索引], 校验_右移(段上下文[0], 8))
 i = i + 1
 }
 追加(结果, [偏移, 当前大小, crc32_完成(段上下文)])
 偏移 = 偏移 + 当前大小
 }
 返回 结果
}

函数 crc32_验证分段(数据, 段校验列表) { 定义 可变 i = 0
 定义 可变 失败段 = []
 当 (i < 计数(段校验列表)) { 定义 段 = 段校验列表[i]
 定义 偏移 = 段[0]
 定义 大小 = 段[1]
 定义 期望 = 段[2]
 定义 可变 上下文 = crc32_创建上下文()
 定义 可变 j = 0
 当 (j < 大小) { 定义 字节 = 字节取(数据, 偏移 + j)
 定义 索引 = 校验_异或(上下文[0], 字节) & 255
 上下文[0] = 校验_异或(校验表[索引], 校验_右移(上下文[0], 8))
 j = j + 1
 }
 定义 实际 = crc32_完成(上下文)
 如果 (实际 != 期望) { 追加(失败段, [i, 偏移, 大小]) }
 i = i + 1
 }
 返回 失败段
}

函数 crc32_推荐策略(数据大小) {
    如果 (数据大小 < 1024) { 返回 "单次CRC32(小数据)"
}
 如果 (数据大小 < 65536) { 返回 "分段CRC32(4KB段)" }
 如果 (数据大小 < 1048576) { 返回 "分段CRC32(64KB段)+总校验" }
 返回 "分段CRC32(256KB段)+MD5总校验"
}

函数 crc32_推荐段大小(数据大小) {
    如果 (数据大小 < 1024) { 返回 数据大小
}
 如果 (数据大小 < 65536) { 返回 4096 }
 如果 (数据大小 < 1048576) { 返回 65536 }
 返回 262144
}

// 循环冗余32 统计

函数 crc32_统计报告() { 返回 [校验_计算次数, 校验_处理字节]
}

函数 crc32_错误率估算(信道噪声) {
    如果 (信道噪声 <= 0) { 返回 0
}
 如果 (信道噪声 >= 100) { 返回 100 }
 定义 可变 未检出概率 = 1
 定义 可变 i = 0
 当 (i < 32) {
 未检出概率 = 未检出概率 * 信道噪声 / 100
 i = i + 1
 }
 返回 未检出概率
}

// CRC16 校验

定义 校验16_多项式 = 40961

定义 可变 校验16表 = []
定义 可变 校验16表_已初始化 = 假

函数 校验16_初始化表() {
    如果 (校验16表_已初始化) { 返回
}
 校验16表 = []
 定义 可变 i = 0
 当 (i < 256) { 定义 可变 校验值 = i
 定义 可变 j = 0
 当 (j < 8) { 如果 (校验值 % 2 == 1) {
 校验值 = (校验值 / 2) ^ 校验16_多项式
 } 否则 {
 校验值 = 校验值 / 2
 }
 j = j + 1
 }
 追加(校验16表, 校验值 % 65536)
 i = i + 1
 }
 校验16表_已初始化 = 真
}

函数 crc16_计算(数据) {
 校验16_初始化表()
 定义 可变 校验值 = 65535
 定义 可变 i = 0
 当 (i < 字节长度(数据)) { 定义 字节 = 字节取(数据, i)
 定义 索引 = (校验值 ^ 字节) & 255
 校验值 = (校验16表[索引] ^ (校验值 / 256)) % 65536
 i = i + 1
 }
 返回 校验值 ^ 65535
}

函数 crc16_十六进制(数据) { 定义 v = crc16_计算(数据)
 定义 表 = "0123456789abcdef"
 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 4) {
 结果 = 结果 + 子串(表, 校验_右移(v, (3 - i) * 4) % 16, 1)
 i = i + 1
 }
 返回 结果
}

// CRC8 校验

定义 校验8_多项式 = 7

定义 可变 校验8表 = []
定义 可变 校验8表_已初始化 = 假

函数 校验8_初始化表() {
    如果 (校验8表_已初始化) { 返回
}
 校验8表 = []
 定义 可变 i = 0
 当 (i < 256) { 定义 可变 校验值 = i
 定义 可变 j = 0
 当 (j < 8) { 定义 可变 高位 = 校验值 & 128
 如果 (高位 != 0) {
 校验值 = ((校验值 * 2) ^ 校验8_多项式) % 256
 } 否则 {
 校验值 = (校验值 * 2) % 256
 }
 j = j + 1
 }
 追加(校验8表, 校验值)
 i = i + 1
 }
 校验8表_已初始化 = 真
}

函数 crc8_计算(数据) {
 校验8_初始化表()
 定义 可变 校验值 = 0
 定义 可变 i = 0
 当 (i < 字节长度(数据)) {
 校验值 = 校验8表[(校验值 ^ 字节取(数据, i)) & 255]
 i = i + 1
 }
 返回 校验值
}

// Adler32 校验 (快速但弱校验)

函数 adler32_计算(数据) { 定义 可变 a = 1
 定义 可变 b = 0
 定义 模 = 65521
 定义 可变 i = 0
 当 (i < 字节长度(数据)) {
 a = (a + 字节取(数据, i)) % 模
 b = (b + a) % 模
 i = i + 1
 }
 返回 b * 65536 + a
}

函数 adler32_十六进制(数据) { 定义 v = adler32_计算(数据)
 定义 表 = "0123456789abcdef"
 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 8) {
 结果 = 结果 + 子串(表, 校验_右移(v, (7 - i) * 4) % 16, 1)
 i = i + 1
 }
 返回 结果
}

// 校验和 (简单求和, 0)

函数 校验和_计算(数据) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 字节长度(数据)) {
 和 = (和 + 字节取(数据, i)) % 4294967296
 i = i + 1
 }
 返回 和
}

函数 校验和_异或(数据) { 定义 可变 结果 = 0
 定义 可变 i = 0
 当 (i < 字节长度(数据)) {
 结果 = 结果 ^ 字节取(数据, i)
 i = i + 1
 }
 返回 结果
}

函数 多层校验(数据) { 返回 [crc32_计算(数据), crc16_计算(数据), crc8_计算(数据), adler32_计算(数据), 校验和_计算(数据)]
}

函数 多层校验_验证(数据, 期望) { 定义 实际 = 多层校验(数据)
 定义 可变 通过 = 0
 定义 可变 i = 0
 当 (i < 5) { 如果 (实际[i] == 期望[i]) { 通过 = 通过 + 1 }
 i = i + 1
 }
 返回 [通过, 5, 通过 == 5]
}

函数 校验_自动选择(数据大小, 安全级别) {
    如果 (安全级别 >= 3) { 返回 "多层校验(循环冗余32+CRC16+Adler32)"
}
 如果 (安全级别 >= 2) { 返回 "循环冗余32(标准)" }
 如果 (数据大小 < 256) { 返回 "CRC8(小数据)" }
 如果 (数据大小 < 65536) { 返回 "CRC16(中等数据)" }
 返回 "循环冗余32(大数据)"
}

函数 校验_性能预测(数据大小, 算法) {
    如果 (算法 == "循环冗余8") { 返回 数据大小
}
 如果 (算法 == "crc16") { 返回 数据大小 * 2 }
 如果 (算法 == "crc32") { 返回 数据大小 * 4 }
 如果 (算法 == "阿德勒32") { 返回 数据大小 * 2 }
 如果 (算法 == "MD5哈希") { 返回 数据大小 * 64 }
 返回 数据大小
}

// 字节序列工具

函数 字节列表转十六进制(字节列表) { 定义 表 = "0123456789abcdef"
 定义 可变 结果 = ""
 定义 可变 i = 0
 当 (i < 计数(字节列表)) { 定义 b = 字节列表[i]
 结果 = 结果 + 子串(表, (b / 16) % 16, 1) + 子串(表, b % 16, 1)
 i = i + 1
 }
 返回 结果
}

函数 十六进制转字节列表(十六进制文本) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i + 1 < 计数(十六进制文本)) { 定义 高 = 十六进制值(子串(十六进制文本, i, 1))
 定义 低 = 十六进制值(子串(十六进制文本, i + 1, 1))
 如果 (高 >= 0) { 如果 (低 >= 0) {
 追加(结果, 高 * 16 + 低)
 }
 }
 i = i + 2
 }
 返回 结果
}

函数 整数转文本(数值) {
    如果 (数值 == 0) { 返回 "0"
}
 定义 可变 n = 数值
 定义 可变 负 = 假
 如果 (n < 0) {
 负 = 真
 n = 0 - n
 }
 定义 可变 结果 = ""
 当 (n > 0) {
 结果 = 字符(48 + n % 10) + 结果
 n = n / 10
 }
 如果 (负) { 结果 = "-" + 结果 }
 返回 结果
}

函数 十六进制值(c) {
    如果 (计数(c) == 0) { 返回 0 - 1
}
 定义 a = 编码(c)
 如果 (a >= 字符_零) { 如果 (a <= 字符_九) { 返回 a - 48 }
 }
 如果 (a >= 字符_大写A) { 如果 (a <= 70) { 返回 a - 55 }
 }
 如果 (a >= 字符_小写a) { 如果 (a <= 字符_小写f) { 返回 a - 87 }
 }
 返回 0 - 1
}

函数 校验链_创建() { 返回 [0, 0,]
}

函数 校验链_更新(链, 字节) {
 链[0] = (链[0] + 字节) % 4294967296
 链[1] = 链[1] ^ 字节
 链[2] = (链[2] * 31 + 字节) % 4294967296
 链[3] = 链[3] + 1
 链[4] = (链[4] + 字节 * 链[3]) % 4294967296
}

函数 校验链_摘要(链) { 返回 [链[0], 链[1], 链[2], 链[4]]
}

函数 校验链_匹配(链1, 链2) { 如果 (链1[0] == 链2[0]) { 如果 (链1[1] == 链2[1]) { 如果 (链1[2] == 链2[2]) { 如果 (链1[3] == 链2[3]) { 返回 真
 }
 }
 }
 }
 返回 假
}


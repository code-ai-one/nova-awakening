// 感知观察调度装载
// 将观察器、定时器与浏览进程观察能力接回调度路径。

导入("./观察创建.nova")
导入("./交叉观察.nova")
导入("./工线定时器.nova")
导入("./进程浏览.nova")
导入("./实时钟数据通.nova")
导入("./网实时钟对等.nova")

函数 感知观察调度装载_模块清单() {
    返回 [
        "./观察创建.nova",
        "./交叉观察.nova",
        "./工线定时器.nova",
        "./进程浏览.nova",
        "./实时钟数据通.nova",
        "./网实时钟对等.nova"
    ]
}

函数 感知观察调度装载_统计() {
    返回 {
        模块数: 计数(感知观察调度装载_模块清单())
    }
}

// NovaOS · 令牌优化器 + 上下文压缩器
// 针对国产模型上下文短/令牌贵的深度优化
// 核心问题:
//   GLM-4: 128K上下文但令牌贵
//   Qwen: 32K上下文, 超长对话容易爆
//   文心ERNIE: 8K上下文, 极短
//   MiniMax: 100万令牌但延迟高
// 优化策略:
//   §1 令牌精确计数: 中文≈1.5令牌/字, 英文≈0.75令牌/word
//   §2 上下文预算管理: 根据模型上下文窗口自动裁剪
//   §3 消息重要度加权: 重要消息保留, 不重要的压缩/删除
//   §4 自动摘要压缩: 超长对话→提取要点→压缩为摘要
//   §5 滑动窗口: 保留最近N轮+摘要
//   §6 系统提示优化: 自动精简系统提示减少令牌
//   §7 响应长度预估: 预留足够输出空间


// 中文令牌估算: 约1.5 令牌/字(UTF-8中文3字节≈1.5令牌)
// 英文令牌估算: 约0.75 令牌/word(4字符≈1令牌)
// 混合文本: 按字符级估算

函数 令牌_估算(文本) {
    如果 (文本 == 空) { 返回 0 }
    定义 长度 = 字符串长度(文本)
    定义 可变 中文字数 = 0
    定义 可变 英文字数 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 字节 = 字符串字节(文本, i)
        如果 (字节 > 127) {
            // UTF-8多字节=中文/日文等
            中文字数 = 中文字数 + 1
            // 跳过UTF-8续字节
            如果 (字节 >= 0xE0) { i = i + 3 }
            否则 如果 (字节 >= 0xC0) { i = i + 2 }
            否则 { i = i + 1 }
        } 否则 {
            英文字数 = 英文字数 + 1
            i = i + 1
        }
    }
    // 中文: 约1.5令牌/字, 英文: 约0.25令牌/字符(4字符≈1令牌)
    返回 中文字数 * 3 / 2 + 英文字数 / 4 + 1
}

函数 令牌_估算消息列表(消息列表) {
    定义 可变 总令牌 = 0
    定义 可变 i = 0
    当 (i < 计数(消息列表)) {
        // 每条消息额外开销约4令牌(role/content标记)
        总令牌 = 总令牌 + 令牌_估算(消息列表[i][1]) + 4
        i = i + 1
    }
    // 请求序列格式开销
    总令牌 = 总令牌 + 10
    返回 总令牌
}


结构 令牌预算 {
    模型最大令牌,
    输出预留令牌,    // u32 预留给输出的令牌
    系统提示令牌,
    可用消息令牌,    // u32 = 最大 - 输出预留 - 系统提示
    当前消耗令牌,
}

函数 令牌_计算预算(模型最大, 输出预留, 系统提示) {
    定义 预算 = 令牌预算 {}
    预算.模型最大令牌 = 模型最大
    预算.输出预留令牌 = 输出预留
    预算.系统提示令牌 = 令牌_估算(系统提示)
    预算.可用消息令牌 = 模型最大 - 输出预留 - 预算.系统提示令牌
    如果 (预算.可用消息令牌 < 0) { 预算.可用消息令牌 = 1000 }  // 最小保证
    预算.当前消耗令牌 = 0
    返回 预算
}


函数 令牌_裁剪消息(消息列表, 预算) {
    // 从最新到最旧计算令牌, 超出预算时从最旧开始裁剪
    定义 可变 令牌累计 = []   // 每条消息的令牌数
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(消息列表)) {
        定义 t = 令牌_估算(消息列表[i][1]) + 4
        追加(令牌累计, t)
        总 = 总 + t
        i = i + 1
    }

    // 如果在预算内, 直接返回
    如果 (总 <= 预算.可用消息令牌) {
        预算.当前消耗令牌 = 总
        返回 消息列表
    }

    // 超出预算→从最旧开始删除(但保留第一条user消息和最后几条)
    定义 可变 裁剪后 = []
    定义 可变 剩余预算 = 预算.可用消息令牌
    定义 数量 = 计数(消息列表)

    // 策略: 保留最后的消息, 从最旧开始删
    // 但如果有重要消息(系统/标记), 也保留
    i = 数量 - 1
    定义 可变 保留索引 = []
    当 (i >= 0 && 剩余预算 > 0) {
        如果 (令牌累计[i] <= 剩余预算) {
            追加(保留索引, i)
            剩余预算 = 剩余预算 - 令牌累计[i]
        }
        i = i - 1
    }

    // 按原始顺序重建
    i = 0
    当 (i < 数量) {
        定义 可变 保留 = 假
        定义 可变 j = 0
        当 (j < 计数(保留索引)) {
            如果 (保留索引[j] == i) { 保留 = 真 }
            j = j + 1
        }
        如果 (保留) { 追加(裁剪后, 消息列表[i]) }
        i = i + 1
    }

    预算.当前消耗令牌 = 预算.可用消息令牌 - 剩余预算
    返回 裁剪后
}


// 当对话过长时, 将旧消息压缩为摘要
// 摘要策略: 提取每轮对话的关键信息(第一句+最后一句)

函数 令牌_压缩为摘要(消息列表, 最大摘要令牌) {
    如果 (计数(消息列表) <= 4) { 返回 消息列表 }

    定义 可变 摘要部分 = []
    定义 可变 保留部分 = []

    // 前2/3的消息→压缩为摘要
    定义 压缩边界 = 计数(消息列表) * 2 / 3
    定义 可变 摘要文本 = "[对话摘要] "

    定义 可变 i = 0
    当 (i < 压缩边界) {
        定义 角色 = 消息列表[i][0]
        定义 内容 = 消息列表[i][1]
        // 提取要点: 取前50字符
        定义 要点长度 = 50
        如果 (字符串长度(内容) < 要点长度) { 要点长度 = 字符串长度(内容) }
        定义 要点 = 字符串子串(内容, 0, 要点长度)

        如果 (角色 == "user") {
            摘要文本 = 摘要文本 + "用户问:" + 要点 + "; "
        } 否则 如果 (角色 == "assistant") {
            摘要文本 = 摘要文本 + "AI答:" + 要点 + "; "
        }
        i = i + 1
    }

    // 摘要作为system消息
    追加(摘要部分, ["system", 摘要文本])

    // 后1/3保留原样
    i = 压缩边界
    当 (i < 计数(消息列表)) {
        追加(保留部分, 消息列表[i])
        i = i + 1
    }

    // 合并: 摘要 + 保留
    定义 可变 结果 = 摘要部分
    i = 0
    当 (i < 计数(保留部分)) { 追加(结果, 保留部分[i]); i = i + 1 }
    返回 结果
}


函数 令牌_精简系统提示(原始提示, 目标令牌) {
    定义 当前令牌 = 令牌_估算(原始提示)
    如果 (当前令牌 <= 目标令牌) { 返回 原始提示 }

    // 按目标比例截取
    定义 保留比 = 目标令牌 * 1000 / 当前令牌
    定义 保留字符 = 字符串长度(原始提示) * 保留比 / 1000
    返回 字符串子串(原始提示, 0, 保留字符) + "...[已精简]"
}


// 一站式调用: 输入原始消息列表 → 输出优化后的消息列表(在令牌预算内)
函数 令牌_智能优化(消息列表, 系统提示, 模型最大令牌, 输出预留) {
    定义 预算 = 令牌_计算预算(模型最大令牌, 输出预留, 系统提示)

    // 1. 先尝试直接裁剪
    定义 裁剪后 = 令牌_裁剪消息(消息列表, 预算)
    定义 裁剪令牌 = 令牌_估算消息列表(裁剪后)

    // 2. 如果裁剪后仍超出(消息太多), 启用摘要压缩
    如果 (裁剪令牌 > 预算.可用消息令牌) {
        返回 令牌_压缩为摘要(裁剪后, 预算.可用消息令牌)
    }

    返回 裁剪后
}


定义 可变 令牌统计_总输入 = 0
定义 可变 令牌统计_总输出 = 0
定义 可变 令牌统计_总节约 = 0     // 通过压缩节约的令牌

函数 令牌_记录使用(输入令牌, 输出令牌, 原始令牌) {
    令牌统计_总输入 = 令牌统计_总输入 + 输入令牌
    令牌统计_总输出 = 令牌统计_总输出 + 输出令牌
    如果 (原始令牌 > 输入令牌) {
        令牌统计_总节约 = 令牌统计_总节约 + (原始令牌 - 输入令牌)
    }
}

函数 令牌_节约率() {
    如果 (令牌统计_总输入 + 令牌统计_总节约 == 0) { 返回 0 }
    返回 令牌统计_总节约 * 100 / (令牌统计_总输入 + 令牌统计_总节约)
}

函数 令牌_统计() {
    返回 {
        总输入: 令牌统计_总输入,
        总输出: 令牌统计_总输出,
        总节约: 令牌统计_总节约,
        节约率: 令牌_节约率()
    }
}

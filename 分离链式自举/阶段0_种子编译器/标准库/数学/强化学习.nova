// Nova标准库 — 强化学习 (Reinforcement Learning)
// Q-Learning, SARSA, 策略梯度基础
// 对标 nova-forth 的 rl/ 模块

导入("../基础.nova")

定义 rl精度 = 1000
定义 可变 RL_随机态 = 2463534242
定义 可变 RL_回放缓冲 = []
定义 RL_回放容量 = 256
定义 可变 状态访问 = []

// Q-Table
// [状态数, 动作数, Q值表(状态×动作)]

函数 qtable_创建(状态数, 动作数) {
    定义 可变 表 = [状态数, 动作数]
    定义 可变 i = 0
    当 (i < 状态数 * 动作数) {
        追加(表, 0)
        i = i + 1
    }
    返回 表
}

函数 qtable_取(表, 状态, 动作) {
    返回 表[2 + 状态 * 表[1] + 动作]
}

函数 qtable_设(表, 状态, 动作, 值) {
    表[2 + 状态 * 表[1] + 动作] = 值
}

// 获取状态的最优动作
函数 qtable_最优动作(表, 状态) {
    定义 动作数 = 表[1]
    定义 可变 最优 = 0
    定义 可变 最优值 = qtable_取(表,  状态, 0)
    定义 可变 a = 1
    当 (a < 动作数) {
        定义 v = qtable_取(表, 状态, a)
        如果 (v > 最优值) {
            最优值 = v
            最优 = a
        }
        a = a + 1
    }
    返回 最优
}
函数 qtable_最优(表, 状态) { 返回 qtable_最优动作(表, 状态) }

// 获取状态的最大Q值
函数 qtable_最大值(表, 状态) {
    定义 动作数 = 表[1]
    定义 可变 最大 = qtable_取(表,  状态, 0)
    定义 可变 a = 1
    当 (a < 动作数) {
        定义 v = qtable_取(表, 状态, a)
        如果 (v > 最大) { 最大 = v }
        a = a + 1
    }
    返回 最大
}

// Q-Learning
// Q(s,a) ← Q(s,a) + α[r + γ·max_a'Q(s',a') - Q(s,a)]
函数 qlearning_更新(表, 状态, 动作, 奖励, 下一状态, 学习率, 衰减率) {
    定义 当前q = qtable_取(表, 状态, 动作)
    定义 最大未来 = qtable_最大值(表, 下一状态)
    定义 目标 = 奖励 + 衰减率 * 最大未来 / rl精度
    定义 新q = 当前q + 学习率 * (目标 - 当前q) / rl精度
    qtable_设(表, 状态, 动作, 新q)
}

// SARSA
// Q(s,a) ← Q(s,a) + α[r + γ·Q(s',a') - Q(s,a)]
函数 sarsa_更新(表, 状态, 动作, 奖励, 下一状态, 下一动作, 学习率, 衰减率) {
    定义 当前q = qtable_取(表, 状态, 动作)
    定义 下一q = qtable_取(表, 下一状态, 下一动作)
    定义 目标 = 奖励 + 衰减率 * 下一q / rl精度
    定义 新q = 当前q + 学习率 * (目标 - 当前q) / rl精度
    qtable_设(表, 状态, 动作, 新q)
}

// ε-Greedy 策略
函数 贪心探索(表, 状态, 极小值, 随机状态) {
    定义 动作数 = 表[1]
    随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
    定义 r = 随机状态[0] % rl精度
    如果 (r < 极小值) {
        // 随机探索
        随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
        返回 随机状态[0] % 动作数
    }
    // 贪心利用
    返回 qtable_最优动作(表, 状态)
}

// Softmax 策略
函数 softmax_策略(表, 状态, 温度, 随机状态) {
    定义 动作数 = 表[1]
    // 计算每个动作的偏好
    定义 可变 偏好 = []
    定义 可变 最大q = qtable_取(表,  状态, 0)
    定义 可变 a = 1
    当 (a < 动作数) {
        定义 v = qtable_取(表, 状态, a)
        如果 (v > 最大q) { 最大q = v }
        a = a + 1
    }
    // 计算 归一化指数 概率
    定义 可变 总和 = 0
    a = 0
    当 (a < 动作数) {
        定义 偏移 = (qtable_取(表, 状态, a) - 最大q) * rl精度 / 温度
        定义 可变 e = rl精度 + 偏移
        如果 (e < 1) { e = 1 }
        追加(偏好, e)
        总和 = 总和 + e
        a = a + 1
    }
    // 轮盘赌选择
    随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
    定义 可变 阈值 = 随机状态[0] % 总和
    定义 可变 累计 = 0
    a = 0
    当 (a < 动作数) {
        累计 = 累计 + 偏好[a]
        如果 (累计 > 阈值) { 返回 a }
        a = a + 1
    }
    返回 动作数 - 1
}

// 奖励计算工具

// 折扣累计奖励
函数 折扣奖励(奖励列表, 衰减率) {
    定义 n = 计数(奖励列表)
    定义 可变 折扣 = []
    定义 可变 i = 0
    当 (i < n) { 追加(折扣, 0) i = i + 1 }
    定义 可变 累计 = 0
    i = n - 1
    当 (i >= 0) {
        累计 = 奖励列表[i] + 衰减率 * 累计 / rl精度
        折扣[i] = 累计
        i = i - 1
    }
    返回 折扣
}

// 奖励归一化
函数 奖励归一化(奖励列表) {
    定义 n = 计数(奖励列表)
    // 均值
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < n) { 和 = 和 + 奖励列表[i] i = i + 1 }
    定义 均值 = 和 / n
    // 标准差
    定义 可变 方差 = 0
    i = 0
    当 (i < n) {
        定义 差 = 奖励列表[i] - 均值
        方差 = 方差 + 差 * 差
        i = i + 1
    }
    定义 可变 标准差 = rl_开方(方差 / n)
    如果 (标准差 == 0) { 标准差 = 1 }
    // 归一化
    定义 可变 结果 = []
    i = 0
    当 (i < n) {
        追加(结果, (奖励列表[i] - 均值) * rl精度 / 标准差)
        i = i + 1
    }
    返回 结果
}

// 经验回放缓冲 (Replay Buffer)
函数 回放缓冲_创建(容量) {
    返回 [[], 容量, 0]
}

函数 回放缓冲_追加(缓冲, 经验) {
    如果 (计数(缓冲[0]) < 缓冲[1]) {
        追加(缓冲[0], 经验)
    } 否则 {
        // 覆盖最旧的
        缓冲[0][缓冲[2] % 缓冲[1]] = 经验
    }
    缓冲[2] = 缓冲[2] + 1
}

函数 回放缓冲_采样(缓冲, 批大小, 随机状态) {
    定义 n = 计数(缓冲[0])
    定义 可变 样本 = []
    定义 可变 i = 0
    当 (i < 批大小 且 i < n) {
        随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
        定义 索引 = 随机状态[0] % n
        追加(样本, 缓冲[0][索引])
        i = i + 1
    }
    返回 样本
}

函数 回放缓冲_大小(缓冲) {
    返回 计数(缓冲[0])
}

// 多臂赌博机 (Multi-Armed Bandit)

函数 bandit_创建(臂数) {
    定义 可变 估值 = []
    定义 可变 计数表 = []
    定义 可变 i = 0
    当 (i < 臂数) {
        追加(估值, 0)
        追加(计数表, 0)
        i = i + 1
    }
    返回 [臂数, 估值, 计数表]
}

函数 bandit_更新(bandit, 臂, 奖励) {
    bandit[2][臂] = bandit[2][臂] + 1
    定义 n = bandit[2][臂]
    // 增量均值更新: Q = Q + (r - Q) / n
    bandit[1][臂] = bandit[1][臂] + (奖励 - bandit[1][臂]) / n
}

函数 bandit_选择(bandit, 极小值, 随机状态) {
    随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
    如果 (随机状态[0] % rl精度 < 极小值) {
        随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
        返回 随机状态[0] % bandit[0]
    }
    // 贪心
    定义 可变 最优 = 0
    定义 可变 最优值 = bandit[1][0]
    定义 可变 i = 1
    当 (i < bandit[0]) {
        如果 (bandit[1][i] > 最优值) {
            最优值 = bandit[1][i]
            最优 = i
        }
        i = i + 1
    }
    返回 最优
}

// UCB1 选择
函数 老虎机_置信上限(bandit, 总次数) {
    定义 可变 最优 = 0
    定义 可变 最优值 = 0 - 0x7FFFFFFF
    定义 可变 i = 0
    当 (i < bandit[0]) {
        如果 (bandit[2][i] == 0) { 返回 i }
        定义 利用 = bandit[1][i]
        定义 探索 = rl_开方(2 * rl_ln近似(总次数) / bandit[2][i])
        定义 置信上限 = 利用 + 探索
        如果 (置信上限 > 最优值) {
            最优值 = 置信上限
            最优 = i
        }
        i = i + 1
    }
    返回 最优
}

// Double Q-Learning
// 消除Q-Learning的最大化偏差
// 两个Q表: 一个选动作, 一个评估值

函数 double_q_创建(状态数, 动作数) {
    返回 [qtable_创建(状态数, 动作数), qtable_创建(状态数, 动作数)]
}

函数 double_q_更新(双表, 状态, 动作, 奖励, 下一状态, 学习率, 衰减率, 随机状态) {
    随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
    如果 (随机状态[0] % 2 == 0) {
        // 用表1选动作, 表2评估
        定义 最优动作 = qtable_最优动作(双表[0], 下一状态)
        定义 目标 = 奖励 + 衰减率 * qtable_取(双表[1], 下一状态, 最优动作) / rl精度
        定义 当前 = qtable_取(双表[0], 状态, 动作)
        qtable_设(双表[0], 状态, 动作, 当前 + 学习率 * (目标 - 当前) / rl精度)
    } 否则 {
        // 用表2选动作, 表1评估
        定义 最优动作 = qtable_最优动作(双表[1], 下一状态)
        定义 目标 = 奖励 + 衰减率 * qtable_取(双表[0], 下一状态, 最优动作) / rl精度
        定义 当前 = qtable_取(双表[1], 状态, 动作)
        qtable_设(双表[1], 状态, 动作, 当前 + 学习率 * (目标 - 当前) / rl精度)
    }
}

函数 double_q_最优动作(双表, 状态) {
    定义 动作数 = 双表[0][1]
    定义 可变 最优 = 0
    定义 可变 最优值 = qtable_取(双表[0],  状态, 0) + qtable_取(双表[1],  状态, 0)
    定义 可变 a = 1
    当 (a < 动作数) {
        定义 v = qtable_取(双表[0], 状态, a) + qtable_取(双表[1], 状态, a)
        如果 (v > 最优值) { 最优值 = v
        最优 = a }
        a = a + 1
    }
    返回 最优
}

// 优先经验回放 (Prioritized Replay)
// TD误差大的经验被更频繁采样

函数 优先回放_创建(容量) {
    返回 [[], [], 容量, 0]  // [经验列表, 优先级列表, 容量, 写指针]
}

函数 优先回放_追加(缓冲, 经验, 优先级) {
    如果 (计数(缓冲[0]) < 缓冲[2]) {
        追加(缓冲[0], 经验)
        追加(缓冲[1], 优先级)
    } 否则 {
        定义 索引 = 缓冲[3] % 缓冲[2]
        缓冲[0][索引] = 经验
        缓冲[1][索引] = 优先级
    }
    缓冲[3] = 缓冲[3] + 1
}

函数 优先回放_采样(缓冲, 批大小, 随机状态) {
    定义 n = 计数(缓冲[0])
    // 计算优先级总和
    定义 可变 总优先 = 0
    定义 可变 i = 0
    当 (i < n) { 总优先 = 总优先 + 缓冲[1][i]
    i = i + 1 }
    如果 (总优先 == 0) { 总优先 = n }
    // 按优先级采样
    定义 可变 样本 = []
    定义 可变 si = 0
    当 (si < 批大小 且 si < n) {
        随机状态[0] = (随机状态[0] * 1103515245 + 12345) & 0x7FFFFFFF
        定义 可变 阈值 = 随机状态[0] % 总优先
        定义 可变 累计 = 0
        i = 0
        当 (i < n) {
            累计 = 累计 + 缓冲[1][i]
            如果 (累计 > 阈值) {
                追加(样本, 缓冲[0][i])
                i = n  // break
            }
            i = i + 1
        }
        si = si + 1
    }
    返回 样本
}

// GAE (Generalized Advantage Estimation)
// A_t = δ_t + (γλ)δ_{t+1} + (γλ)²δ_{t+2} + ...
// δ_t = r_t + γV(s_{t+1}) - V(s_t)

函数 gae_计算(奖励, 价值, 衰减率, 衰减系数) {
    定义 可变 优势 = []
    定义 可变 广义优势 = 0
    定义 n = 计数(奖励)
    定义 可变 i = 0
    当 (i < n) { 追加(优势, 0)
    i = i + 1 }
    i = n - 1
    当 (i >= 0) {
        如果 (i + 1 < 计数(价值)) { 下一价值 = 价值[i + 1] }
        定义 增量 = 奖励[i] + 衰减率 * 下一价值 / rl精度 - 价值[i]
        广义优势 = 增量 + 衰减率 * 衰减系数 * 广义优势 / (rl精度 * rl精度 / rl精度)
        优势[i] = 广义优势
        i = i - 1
    }
    返回 优势
}

// TD(λ)
// 多步时序差分, 使用资格迹

函数 td_lambda_初始化(状态数) {
    定义 可变 V = []
    定义 可变 E = []  // 资格迹
    定义 可变 i = 0
    当 (i < 状态数) { 追加(V, 0)
    追加(E, 0)
    i = i + 1 }
    返回 [V, E]
}

函数 td_lambda_更新(状态数据, 状态, 下一状态, 奖励, 学习率, 衰减率, 衰减系数) {
    定义 V = 状态数据[0]
    定义 E = 状态数据[1]
    定义 n = 计数(V)
    // TD误差
    定义 增量 = 奖励 + 衰减率 * V[下一状态] / rl精度 - V[状态]
    // 更新资格迹
    E[状态] = E[状态] + rl精度
    // 更新所有状态的V和E
    定义 可变 i = 0
    当 (i < n) {
        V[i] = V[i] + 学习率 * 增量 * E[i] / (rl精度 * rl精度)
        E[i] = 衰减率 * 衰减系数 * E[i] / (rl精度 * rl精度 / rl精度)
        i = i + 1
    }
}

// PPO Clip 目标
// L = min(比率 * A, clip(比率, 1-ε, 1+ε) * A)

函数 ppo_clip_目标(旧概率, 新概率, 优势, 极小值) {
    定义 可变 总损失 = 0
    定义 n = 计数(旧概率)
    定义 可变 i = 0
    当 (i < n) {
        如果 (旧概率[i] == 0) { i = i + 1
        继续 }
        定义 比率 = 新概率[i] * rl精度 / 旧概率[i]
        // clip(比率, 1-ε, 1+ε)
        定义 可变 clipped = 比率
        如果 (clipped > rl精度 + 极小值) { clipped = rl精度 + 极小值 }
        如果 (clipped < rl精度 - 极小值) { clipped = rl精度 - 极小值 }
        // min(比率*A, clipped*A)
        定义 surr1 = 比率 * 优势[i] / rl精度
        定义 surr2 = clipped * 优势[i] / rl精度
        定义 可变 损失 = surr1
        如果 (surr2 < surr1) { 损失 = surr2 }
        总损失 = 总损失 + 损失
        i = i + 1
    }
    如果 (n == 0) { 返回 0 }
    返回 总损失 / n
}

// ε衰减策略
函数 epsilon_衰减(初始epsilon, 最小epsilon, 当前步, 衰减步) {
    如果 (当前步 >= 衰减步) { 返回 最小epsilon }
    如果 (衰减步 == 0) { 返回 0 }
    返回 初始epsilon - (初始epsilon - 最小epsilon) * 当前步 / 衰减步
}

// SARSA (On-Policy TD控制)

// N-Step Return
// G_t = r_t + γ*r_{t+1} + ... + γ^n * V(s_{t+n})
函数 N步回报(奖励序列, 终态值, 衰减率, n) {
    定义 可变 G = 终态值
    定义 可变 i = n - 1
    当 (i >= 0) {
        如果 (i < 计数(奖励序列)) {
            G = 奖励序列[i] + 衰减率 * G / rl精度
        }
        i = i - 1
    }
    返回 G
}

// REINFORCE 策略梯度
// 更新: θ = θ + α * G * ∇log π(a|s)
函数 reinforce_更新(策略权重, 状态特征, 动作, 回报, 学习率) {
    定义 d = 计数(状态特征)
    定义 可变 i = 0
    当 (i < d) {
        // 简化: 权重[动作*d + i] = i] + α * G * 特征[i]
        定义 索引 = 动作 * d + i
        如果 (索引 < 计数(策略权重)) {
            策略权重[索引] = 策略权重[索引] + 学习率 * 回报 * 状态特征[i] / (rl精度 * rl精度)
        }
        i = i + 1
    }
}

// A2C (Advantage Actor-Critic)
// Actor更新: θ = θ + α * A * ∇log π
// Critic更新: w = w + α * δ * ∇V
函数 a2c_actor更新(策略权重, 状态特征, 动作, 优势, 学习率) {
    定义 d = 计数(状态特征)
    定义 可变 i = 0
    当 (i < d) {
        定义 索引 = 动作 * d + i
        如果 (索引 < 计数(策略权重)) {
            策略权重[索引] = 策略权重[索引] + 学习率 * 优势 * 状态特征[i] / (rl精度 * rl精度)
        }
        i = i + 1
    }
}

函数 a2c_critic更新(值权重, 状态特征, td误差, 学习率) {
    定义 d = 计数(状态特征)
    定义 可变 i = 0
    当 (i < d) {
        如果 (i < 计数(值权重)) {
            值权重[i] = 值权重[i] + 学习率 * td误差 * 状态特征[i] / (rl精度 * rl精度)
        }
        i = i + 1
    }
}

// 奖励整形 (Reward Shaping, 0 , 0, 0)
函数 奖励整形(原始奖励, 势函数当前, 势函数下一, 衰减率) {
    返回 原始奖励 + 衰减率 * 势函数下一 / rl精度 - 势函数当前
}

// 折扣回报计算
函数 折扣回报(奖励序列, 衰减率) {
    定义 n = 计数(奖励序列)
    定义 可变 回报 = []
    定义 可变 i = 0
    当 (i < n) { 追加(回报, 0)
    i = i + 1 }
    定义 可变 G = 0
    i = n - 1
    当 (i >= 0) {
        G = 奖励序列[i] + 衰减率 * G / rl精度
        回报[i] = G
        i = i - 1
    }
    返回 回报
}

// 回报标准化
函数 回报标准化(回报) {
    定义 n = 计数(回报)
    // 均值
    定义 可变 均值 = 0
    定义 可变 i = 0
    当 (i < n) { 均值 = 均值 + 回报[i]
    i = i + 1 }
    均值 = 均值 / n
    // 标准差
    定义 可变 方差 = 0
    i = 0
    当 (i < n) {
        定义 d = 回报[i] - 均值
        方差 = 方差 + d * d / rl精度
        i = i + 1
    }
    定义 可变 标准差 = rl_开方(方差 / n)
    如果 (标准差 == 0) { 标准差 = 1 }
    定义 可变 结果 = []
    i = 0
    当 (i < n) {
        追加(结果, (回报[i] - 均值) * rl精度 / 标准差)
        i = i + 1
    }
    返回 结果
}

// 内部工具
函数 rl_开方(n) {
    如果 (n <= 0) {
        返回 0
    }
    定义 可变 x = n
    定义 可变 y = (x + 1) / 2
    当 (y < x) {
        x = y
        y = (x + n / x) / 2
    }
    返回 x
}

函数 rl_ln近似(x) {
    如果 (x <= 0) {
        返回 0
    }
    如果 (x <= 1) {
        返回 0
    }
    定义 可变 结果 = 0
    定义 可变 v = x
    当 (v > 2) {
        v = v / 2
        结果 = 结果 + 693
    }
    返回 结果 + (v - 1) * 1000
}

// 合并自 编译器/标准库/强化学习/强化学习.nova

函数 Boltzmann策略(qt, 状态, tau) {
    定义 可变 指数组 = []
    // 基于softmax: P(a) ∝ exp(Q(s,a)/tau)
    定义 n_act = qt[2]
    定义 可变 mx = Q表_获取(qt,  状态, 0)
    定义 可变 a = 1
    当 (a < n_act) {
        定义 v = Q表_获取(qt, 状态, a)
        如果 (v > mx) {
            mx = v
        }
        a = a + 1
    }
    定义 可变 总和 = 0
    a = 0
    当 (a < n_act) {
        定义 差值 = (Q表_获取(qt, 状态, a) - mx) * 100 / tau
        定义 可变 ev = 100 + 差值
        如果 (ev < 1) {
            ev = 1
        }
        追加(指数组, ev)
        总和 = 总和 + ev
        a = a + 1
    }
    如果 (总和 < 1) {
        总和 = 1
    }
    定义 随机值 = RL_随机() % 总和
    定义 可变 累积 = 0
    a = 0
    当 (a < n_act) {
        累积 = 累积 + 指数组[a]
        如果 (随机值 < 累积) {
            返回 a
        }
        a = a + 1
    }
    返回 n_act - 1
}

函数 DoubleQ_更新(qt1, qt2, 状态, 动作, 奖励, 下一状态, 学习率, 衰减率, 用第一) {
    如果 (用第一) {
        定义 best_a = Q表_最优动作(qt1, 下一状态)
        定义 target_v = Q表_获取(qt2, 下一状态, best_a)
        定义 当前 = Q表_获取(qt1, 状态, 动作)
        定义 目标 = 奖励 * 100 + 衰减率 * target_v
        Q表_设置(qt1, 状态, 动作, 当前 + 学习率 * (目标 - 当前 * 100) / 100)
    } 否则 {
        定义 best_a = Q表_最优动作(qt2, 下一状态)
        定义 target_v = Q表_获取(qt1, 下一状态, best_a)
        定义 当前 = Q表_获取(qt2, 状态, 动作)
        定义 目标 = 奖励 * 100 + 衰减率 * target_v
        Q表_设置(qt2, 状态, 动作, 当前 + 学习率 * (目标 - 当前 * 100) / 100)
    }
}

函数 Grid_步(状态, 动作, 宽, 高, 目标) {
    定义 可变 x = 状态 % 宽
    定义 可变 y = 状态 / 宽
    如果 (动作 == 0) {
        如果 (y > 0) {
            y = y - 1
        }
    }
    如果 (动作 == 1) {
        如果 (y < 高 - 1) {
            y = y + 1
        }
    }
    如果 (动作 == 2) {
        如果 (x > 0) {
            x = x - 1
        }
    }
    如果 (动作 == 3) {
        如果 (x < 宽 - 1) {
            x = x + 1
        }
    }
    定义 新状态 = y * 宽 + x
    定义 可变 奖励 = -1
    定义 可变 完成 = 假
    如果 (新状态 == 目标) {
        奖励 = 100
        完成 = 真
    }
    返回 [新状态, 奖励, 完成]
}

函数 Q学习_更新(qt, 状态, 动作, 奖励, 下一状态, 学习率, 衰减率) {
    定义 当前Q = Q表_获取(qt, 状态, 动作)
    定义 最大下一Q = Q表_最大值(qt, 下一状态)
    定义 目标 = 奖励 * 100 + 衰减率 * 最大下一Q
    定义 新Q = 当前Q + 学习率 * (目标 - 当前Q * 100) / 100
    Q表_设置(qt, 状态, 动作, 新Q)
}

函数 Q表_创建(状态数, 动作数) {
    定义 可变 vals = []
    定义 可变 i = 0
    当 (i < 状态数 * 动作数) {
        追加(vals, 0)
        i = i + 1
    }
    返回 [vals, 状态数, 动作数]
}

函数 Q表_最优动作(qt, 状态) {
    定义 可变 最佳 = 0
    定义 可变 最佳值 = Q表_获取(qt,  状态, 0)
    定义 可变 a = 1
    当 (a < qt[2]) {
        定义 v = Q表_获取(qt, 状态, a)
        如果 (v > 最佳值) {
            最佳 = a
            最佳值 = v
        }
        a = a + 1
    }
    返回 最佳
}

函数 Q表_最大值(qt, 状态) {
    定义 可变 m = Q表_获取(qt,  状态, 0)
    定义 可变 a = 1
    当 (a < qt[2]) {
        定义 v = Q表_获取(qt, 状态, a)
        如果 (v > m) { m = v }
        a = a + 1
    }
    返回 m
}

函数 Q表_获取(qt, 状态, 动作) {
    返回 qt[0][状态 * qt[2] + 动作]
}
函数 Q表_设置(qt, 状态, 动作, 值) {
    qt[0][状态 * qt[2] + 动作] = 值
}

函数 RL_随机() {
    RL_随机态 = (RL_随机态 * 1103515245 + 12345) % 2147483647
    如果 (RL_随机态 < 0) {
        RL_随机态 = 0 - RL_随机态
    }
    返回 RL_随机态
}

函数 epsilon_贪心(qt, 状态, 极小值) {
    定义 随机值 = RL_随机() % 100
    如果 (随机值 < 极小值) {
        定义 动作数 = qt[2]
        定义 随机动作 = RL_随机() % 动作数
        返回 随机动作
    }
    返回 Q表_最优动作(qt, 状态)
}

函数 n_step返回(奖励列表, 末尾价值, 衰减率, n) {
    定义 可变 G = 末尾价值
    定义 可变 i = n - 1
    定义 奖励数 = 计数(奖励列表)
    如果 (i >= 奖励数) {
        i = 奖励数 - 1
    }
    当 (i >= 0) {
        G = 奖励列表[i] * 100 + 衰减率 * G / 100
        i = i - 1
    }
    返回 G
}

函数 回放_大小() {
    返回 计数(RL_回放缓冲)
}
函数 回放_清空() {
    RL_回放缓冲 = []
}

函数 回放_追加(状态, 动作, 奖励, 下一状态, 完成) {
    定义 可变 新缓冲 = []
    追加(RL_回放缓冲, [状态, 动作, 奖励, 下一状态, 完成])
    定义 缓冲长度 = 计数(RL_回放缓冲)
    如果 (缓冲长度 > RL_回放容量) {
        定义 可变 i = 缓冲长度 - RL_回放容量
        当 (i < 缓冲长度) {
            追加(新缓冲, RL_回放缓冲[i])
            i = i + 1
        }
        RL_回放缓冲 = 新缓冲
    }
}

函数 回放_采样(批大小) {
    定义 可变 批 = []
    定义 n = 计数(RL_回放缓冲)
    如果 (n == 0) {
        返回 批
    }
    定义 可变 i = 0
    当 (i < 批大小) {
        定义 索引 = RL_随机() % n
        追加(批, RL_回放缓冲[索引])
        i = i + 1
    }
    返回 批
}

函数 奖励_归一化(奖励列表) {
    定义 n = 计数(奖励列表)
    如果 (n == 0) {
        返回 []
    }
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < n) {
        和 = 和 + 奖励列表[i]
        i = i + 1
    }
    定义 均值 = 和 / n
    定义 可变 方差 = 0
    i = 0
    当 (i < n) {
        定义 差值 = 奖励列表[i] - 均值
        方差 = 方差 + 差值 * 差值
        i = i + 1
    }
    方差 = 方差 / n
    定义 可变 标准差 = rl_开方(方差)
    如果 (标准差 < 1) {
        标准差 = 1
    }
    定义 可变 结果 = []
    i = 0
    当 (i < n) {
        定义 标准值 = (奖励列表[i] - 均值) * 100 / 标准差
        追加(结果, 标准值)
        i = i + 1
    }
    返回 结果
}

函数 奖励_折扣(奖励列表, 衰减率) {
    定义 n = 计数(奖励列表)
    定义 可变 折扣 = []
    定义 可变 i = 0
    当 (i < n) {
        追加(折扣, 0)
        i = i + 1
    }
    定义 可变 累积 = 0
    i = n - 1
    当 (i >= 0) {
        累积 = 奖励列表[i] * 100 + 衰减率 * 累积 / 100
        折扣[i] = 累积
        i = i - 1
    }
    返回 折扣
}

函数 好奇心_初始化(状态数) {
    状态访问 = []
    定义 可变 i = 0
    当 (i < 状态数) {
        追加(状态访问, 0)
        i = i + 1
    }
}

函数 好奇心_奖励(状态, 外部奖励, 动量率) {
    状态访问[状态] = 状态访问[状态] + 1
    定义 访问次数 = 状态访问[状态]
    定义 探索奖励 = 1000 / (访问次数 + 1)
    定义 总奖励 = 外部奖励 + 动量率 * 探索奖励 / 1000
    返回 总奖励
}

函数 老虎机_UCB1选择(arms, 总次数) {
    定义 可变 最佳 = -1
    定义 可变 最佳值 = -99999
    定义 可变 i = 0
    当 (i < 计数(arms)) {
        定义 当前臂 = arms[i]
        如果 (当前臂[0] == 0) {
            返回 i
        }
        定义 均值 = 当前臂[1] * 100 / 当前臂[0]
        定义 explore = 141 * 总次数 / (当前臂[0] + 1)
        定义 可变 sqrt_e = rl_开方(explore)
        定义 置信上限 = 均值 + sqrt_e
        如果 (置信上限 > 最佳值) {
            最佳 = i
            最佳值 = 置信上限
        }
        i = i + 1
    }
    返回 最佳
}

函数 老虎机_创建(臂数) {
    定义 可变 arms = []
    定义 可变 i = 0
    当 (i < 臂数) {
        追加(arms, [0, 0])
        i = i + 1
    }
    返回 arms
}

函数 老虎机_更新(arms, 臂, 奖励) {
    arms[臂][0] = arms[臂][0] + 1
    arms[臂][1] = arms[臂][1] + 奖励
}

// 实验反哺: 汉字书写顺序强化学习环境
// Q学习实验验证: ε-贪心+贝尔曼方程可以在简单格网环境中找到最优路径
// 应用: 汉字书写顺序学习（状态=已写笔画数，动作=下一笔画类型）
// 5种基本笔画: 0=横 1=竖 2=撇 3=捺 4=折

定义 笔画_横 = 0
定义 笔画_竖 = 1
定义 笔画_撇 = 2
定义 笔画_捺 = 3
定义 笔画_折 = 4
定义 笔画总类 = 5

// 书写顺序奖励函数（正确书写笔画序列=高奖励）
// 正确顺序规则: 先横后竖（横在竖前），先撇后捺
函数 书写奖励(当前笔画, 前一笔画) {
    // 基础奖励: 完成一笔 = 10
    定义 可变 奖励 = 10
    // 先横后竖规则
    如果 (前一笔画 == 笔画_横 且 当前笔画 == 笔画_竖) { 奖励 = 奖励 + 20 }
    如果 (前一笔画 == 笔画_竖 且 当前笔画 == 笔画_横) { 奖励 = 奖励 - 10 }  // 违反规则
    // 先撇后捺规则
    如果 (前一笔画 == 笔画_撇 且 当前笔画 == 笔画_捺) { 奖励 = 奖励 + 15 }
    如果 (前一笔画 == 笔画_捺 且 当前笔画 == 笔画_撇) { 奖励 = 奖励 - 8 }
    返回 奖励
}

// ε-贪心动作选择（包含笔画合法性检验）
函数 RL_书写选择笔画(Q表, 已写状态, 剩余笔画数, ε_1000, 随机种子) {
    如果 (剩余笔画数 <= 0) { 返回 -1 }  // 书写完成
    // 简化：状态=已写笔画数(0-9)，动作=5种笔画
    定义 r = (随机种子 * 1103515245 + 12345) % 1000
    如果 (r < ε_1000) {
        返回 (随机种子 * 6364136223846793005 + 1442695040888963407) % 笔画总类
    }
    返回 qtable_最优(Q表, 已写状态)
}

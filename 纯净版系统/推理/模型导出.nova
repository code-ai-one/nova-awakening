// NovaOS 3D模型导出器 — 将程序化人体导出为OBJ格式
// OBJ是纯文本3D格式，可被Blender/Maya/Unity等所有3D工具打开

导入("../中枢/类型定义.nova")
导入("../记忆/接口.nova")
导入("./数字人渲染.nova")

// §1 OBJ格式导出
// OBJ格式:
//   v x y z       — 顶点坐标
//   vt u v        — UV纹理坐标
//   vn nx ny nz   — 法线
//   f v1/vt1/vn1 v2/vt2/vn2 v3/vt3/vn3 — 面(三角形)

定义 可变 导出_顶点数 = 0
定义 可变 导出_面数 = 0

函数 模型导出_OBJ(输出路径) {
    如果 (计数(人体顶点) == 0) {
        数字人渲染_构建女性高精度()
    }

    定义 可变 内容 = "# NovaOS 3D数字人模型\n"
    内容 = 内容 + "# 程序化生成 — 纯Nova语言\n"
    内容 = 内容 + "# 顶点数: " + 计数(人体顶点) + "\n\n"

    // 写顶点
    定义 可变 i = 0
    当 (i < 计数(人体顶点)) {
        定义 v = 人体顶点[i]
        // OBJ坐标: 除以1000转为米
        内容 = 内容 + "v " + (v.x / 1000) + " " + (v.y / 1000) + " " + (v.z / 1000) + "\n"
        导出_顶点数 = 导出_顶点数 + 1
        i = i + 1
    }

    内容 = 内容 + "\n# UV坐标\n"
    // 生成UV坐标(柱状映射)
    i = 0
    当 (i < 计数(人体顶点)) {
        定义 v = 人体顶点[i]
        // 柱状UV: u=atan2(x,z)/2π  v=y/总高度
        定义 u = (v.x + 200) * 1000 / 400
        定义 vt = v.y * 1000 / 1800
        如果 (u < 0) { u = 0 }
        如果 (u > 1000) { u = 1000 }
        如果 (vt < 0) { vt = 0 }
        如果 (vt > 1000) { vt = 1000 }
        内容 = 内容 + "vt " + (u / 1000) + " " + (vt / 1000) + "\n"
        i = i + 1
    }

    内容 = 内容 + "\n# 面(每4个顶点组成2个三角形)\n"
    i = 0
    当 (i < 计数(人体顶点) - 3) {
        定义 i1 = i + 1
        定义 i2 = i + 2
        定义 i3 = i + 3
        内容 = 内容 + "f " + i1 + "/" + i1 + " " + i2 + "/" + i2 + " " + i3 + "/" + i3 + "\n"
        导出_面数 = 导出_面数 + 1
        i = i + 4
    }

    // 写入文件
    记忆_写文件(输出路径, 内容)
    打印("[模型导出] OBJ已导出: " + 输出路径 + " (" + 整数转字符串(导出_顶点数) + "顶点 " + 整数转字符串(导出_面数) + "面)")
    返回 0
}

// §2 MTL材质文件导出

函数 模型导出_MTL(输出路径) {
    定义 可变 内容 = "# NovaOS 数字人材质\n\n"

    内容 = 内容 + "newmtl 皮肤\n"
    内容 = 内容 + "Kd 1.0 0.855 0.725\n"  // 漫反射色(肤色)
    内容 = 内容 + "Ks 0.3 0.3 0.3\n"      // 镜面反射
    内容 = 内容 + "Ns 30\n"                // 光泽度
    内容 = 内容 + "map_Kd 资源/数字人/正面.png\n\n"  // 纹理贴图

    内容 = 内容 + "newmtl 头发\n"
    内容 = 内容 + "Kd 0.08 0.06 0.15\n"
    内容 = 内容 + "Ks 0.5 0.5 0.5\n"
    内容 = 内容 + "Ns 80\n\n"

    内容 = 内容 + "newmtl 纱衣\n"
    内容 = 内容 + "Kd 0.8 0.8 0.9\n"
    内容 = 内容 + "d 0.3\n"                // 透明度30%
    内容 = 内容 + "Ks 0.8 0.8 0.8\n\n"

    内容 = 内容 + "newmtl 金饰\n"
    内容 = 内容 + "Kd 1.0 0.843 0.0\n"
    内容 = 内容 + "Ks 1.0 1.0 0.8\n"
    内容 = 内容 + "Ns 200\n\n"

    内容 = 内容 + "newmtl 眼睛\n"
    内容 = 内容 + "Kd 0.7 0.0 1.0\n"
    内容 = 内容 + "Ke 0.7 0.0 1.0\n"      // 自发光(紫色)
    内容 = 内容 + "Ns 500\n\n"

    记忆_写文件(输出路径, 内容)
    打印("[模型导出] MTL已导出: " + 输出路径)
}

// §3 一键导出完整模型

函数 模型导出_完整(目录) {
    模型导出_OBJ(目录 + "数字人.obj")
    模型导出_MTL(目录 + "数字人.mtl")
    打印("[模型导出] 完整模型已导出到 " + 目录)
    打印("[模型导出] 可用Blender打开.obj文件查看和编辑")
}

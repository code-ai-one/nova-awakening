定义 停机_正常 = 0
定义 停机_恐慌 = 1
定义 停机_重启 = 2
定义 停机_硬件故障 = 3

定义 可变 停机_原因 = ""
定义 可变 停机_类型 = 停机_正常
定义 可变 停机_时间戳 = 0
定义 可变 停机_已触发 = 假
定义 可变 恐慌_嵌套计数 = 0

函数 内核_停机() {
    关中断()
    当 (真) { 停机() }
}

函数 内核_恐慌(消息) {
    恐慌_嵌套计数 = 恐慌_嵌套计数 + 1
    如果 (恐慌_嵌套计数 > 1) {
        内核_停机()
    }
    停机_已触发 = 真
    停机_类型 = 停机_恐慌
    停机_原因 = 消息
    停机_时间戳 = 当前时间_毫秒()

    关中断()
    内核紧急("═══════ 内核恐慌 ═══════")
    内核紧急(消息)
    内核_转储寄存器()
    内核_转储调用栈()
    内核_写崩溃日志(消息)
    内核_尝试同步文件系统()
    内核_停机()
}

函数 内核_转储寄存器() {
    内核紧急("寄存器转储 (x86-64):")
    定义 rsp = 读取RSP()
    定义 rbp = 获取帧指针()
    定义 rflags = 读取RFLAGS()
    定义 cr2 = 读取CR2()
    定义 cr3 = 读取CR3()
    内核紧急("  RSP=0x" + 整数转十六(rsp) + "  RBP=0x" + 整数转十六(rbp))
    内核紧急("  RFLAGS=0x" + 整数转十六(rflags))
    内核紧急("  CR2=0x" + 整数转十六(cr2) + "  (页错误地址)")
    内核紧急("  CR3=0x" + 整数转十六(cr3) + "  (页表基址)")
}

函数 内核_转储调用栈() {
    内核紧急("调用栈回溯:")
    定义 可变 帧指针 = 获取帧指针()
    定义 可变 深度 = 0
    当 (帧指针 != 0 && 深度 < 32) {
        定义 返回地址 = 内存_读64(帧指针 + 8)
        如果 (返回地址 == 0) { 跳出 }
        内核紧急("  #" + 转字符串(深度) + " 0x" + 整数转十六(返回地址))
        帧指针 = 内存_读64(帧指针)
        深度 = 深度 + 1
    }
}

函数 内核_写崩溃日志(消息) {
    内核紧急("崩溃转储: 写入 /var/crash/dump")
    定义 转储 = "[NovaOS 崩溃转储]\n"
    转储 = 转储 + "时间: " + 转字符串(当前时间_毫秒()) + "\n"
    转储 = 转储 + "原因: " + 消息 + "\n"
    转储 = 转储 + "停机类型: " + 转字符串(停机_类型) + "\n"
    定义 可变 帧 = 获取帧指针()
    定义 可变 深 = 0
    当 (帧 != 0 && 深 < 16) {
        定义 地址 = 内存_读64(帧 + 8)
        如果 (地址 == 0) { 跳出 }
        转储 = 转储 + "  栈#" + 转字符串(深) + " 0x" + 整数转十六(地址) + "\n"
        帧 = 内存_读64(帧)
        深 = 深 + 1
    }
    紧急写入文件("/var/crash/dump", 转储)
}

函数 内核_尝试同步文件系统() {
    内核紧急("尝试同步文件系统...")
    定义 可变 已同步 = 0
    定义 可变 失败 = 0
    // 刷写所有脏页缓存到磁盘
    定义 脏页结果 = 页缓存_紧急刷写全部()
    如果 (脏页结果 >= 0) { 已同步 = 已同步 + 脏页结果 }
    否则 { 失败 = 失败 + 1 }
    // 提交所有未完成的journal事务
    定义 事务结果 = journal_紧急提交全部()
    如果 (事务结果 >= 0) { 已同步 = 已同步 + 事务结果 }
    否则 { 失败 = 失败 + 1 }
    如果 (失败 > 0) {
        内核紧急("文件系统同步: " + 转字符串(已同步) + "块成功, " + 转字符串(失败) + "项失败")
    } 否则 {
        内核紧急("文件系统同步: " + 转字符串(已同步) + "块已刷盘")
    }
}

函数 内核_优雅关机() {
    如果 (停机_已触发) { 返回 }
    停机_已触发 = 真
    停机_类型 = 停机_正常
    停机_时间戳 = 当前时间_毫秒()

    内核信息("开始优雅关机...")
    内核_关闭用户进程()
    内核_关闭AI子系统()
    内核_关闭网络子系统()
    内核_关闭文件系统()
    内核_关闭设备驱动()
    内核信息("所有子系统已关闭")
    内核_停机()
}

函数 内核_重启() {
    如果 (停机_已触发) { 返回 }
    停机_已触发 = 真
    停机_类型 = 停机_重启
    内核信息("系统重启中...")
    内核_关闭用户进程()
    内核_尝试同步文件系统()
    系统调用_分发(SYS_reboot, 0, 0, 0, 0, 0)
    内核_停机()
}

函数 内核_关闭用户进程() {
    内核信息("通知用户进程退出...")
    // 第一轮: 向所有用户进程发送终止信号
    定义 可变 i = 计数(进程链表) - 1
    当 (i >= 0) {
        定义 p = 进程链表[i]
        如果 (p.pid > 1 && p.状态 != 进程_僵尸) {
            信号_发送(p.pid, 信号_终止)
        }
        i = i - 1
    }
    // 等待进程退出(最多3秒)
    定义 等待开始 = 当前时间_毫秒()
    定义 可变 剩余 = 内核_统计活跃用户进程()
    当 (剩余 > 0 && (当前时间_毫秒() - 等待开始) < 3000) {
        剩余 = 内核_统计活跃用户进程()
    }
    // 第二轮: 强制杀死仍存活的进程
    如果 (剩余 > 0) {
        内核信息("强制终止 " + 转字符串(剩余) + " 个顽固进程")
        i = 计数(进程链表) - 1
        当 (i >= 0) {
            定义 p = 进程链表[i]
            如果 (p.pid > 1 && p.状态 != 进程_僵尸 && p.状态 != 进程_已退出) {
                进程_强制退出(p.pid, -9)
            }
            i = i - 1
        }
    }
    内核信息("用户进程已全部终止")
}

函数 内核_统计活跃用户进程() {
    定义 可变 计 = 0
    定义 可变 i = 0
    当 (i < 计数(进程链表)) {
        定义 p = 进程链表[i]
        如果 (p.pid > 1 && p.状态 != 进程_僵尸 && p.状态 != 进程_已退出) {
            计 = 计 + 1
        }
        i = i + 1
    }
    返回 计
}

函数 内核_关闭AI子系统() {
    内核信息("关闭AI子系统...")
    // 保存AI模型权重到持久存储
    定义 保存结果 = AI权重_紧急保存()
    如果 (保存结果 >= 0) {
        内核信息("AI权重已保存: " + 转字符串(保存结果) + "字节")
    }
    // 释放推理引擎占用的显存/内存
    TNF视觉_释放()
    智能总线_关闭()
    语义嵌入_释放()
    内核信息("AI子系统已关闭")
}

函数 内核_关闭网络子系统() {
    内核信息("关闭网络子系统...")
    // 关闭所有活跃socket连接
    定义 可变 已关闭 = 0
    定义 可变 i = 计数(socket_全局表) - 1
    当 (i >= 0) {
        定义 sk = socket_全局表[i]
        如果 (sk != 空 && sk.状态 != 0) {
            socket_关闭(sk)
            已关闭 = 已关闭 + 1
        }
        i = i - 1
    }
    内核信息("已关闭 " + 转字符串(已关闭) + " 个网络连接")
    // 卸载网络协议栈
    netfilter_清理()
    路由表_清理()
    协议族_注销全部()
    内核信息("网络子系统已关闭")
}

函数 内核_关闭文件系统() {
    内核信息("同步并卸载文件系统...")
    // 刷写所有脏页到磁盘
    定义 脏页数 = 页缓存_紧急刷写全部()
    内核信息("脏页已刷写: " + 转字符串(脏页数) + "页")
    // 提交所有未完成的journal事务
    定义 事务数 = journal_紧急提交全部()
    内核信息("日志事务已提交: " + 转字符串(事务数) + "个")
    // 卸载所有已挂载的文件系统(反序)
    定义 可变 i = 计数(挂载表) - 1
    当 (i >= 0) {
        定义 挂载点 = 挂载表[i]
        如果 (挂载点 != 空) {
            内核信息("卸载: " + 挂载点.路径)
            文件系统_卸载(挂载点)
        }
        i = i - 1
    }
    内核信息("文件系统已全部卸载")
}

函数 内核_关闭设备驱动() {
    内核信息("关闭设备驱动...")
    // 按注册反序关闭所有设备驱动
    定义 可变 已移除 = 0
    定义 可变 i = 驱动注册数 - 1
    当 (i >= 0) {
        定义 驱动 = 驱动注册表[i]
        如果 (驱动 != 空 && 驱动.移除函数 != 空) {
            驱动.移除函数(驱动)
            已移除 = 已移除 + 1
        }
        i = i - 1
    }
    内核信息("已移除 " + 转字符串(已移除) + " 个设备驱动")
}

函数 网络子系统_初始化() {
    网络协议_初始化全部()
    路由表_初始化()
    netfilter_初始化()
    内核信息("网络子系统: 协议族+IP路由+netfilter")
}

函数 AI子系统_初始化() {
    AI状态_初始化()
    安全策略_初始化()
    热配置_初始化()
    加密_初始化()
    LSM_初始化()
    内核信息("AI子系统: 状态总线+安全策略+热配置+加密+LSM")
}

函数 AI状态_初始化() {
    内核信息("AI状态接口: 20模块汇聚+事件总线+健康评分")
}

定义 可变 看门狗_启用 = 假
定义 可变 看门狗_超时秒 = 30
定义 可变 看门狗_最后喂狗 = 0

函数 看门狗_初始化(超时秒) {
    看门狗_启用 = 真
    看门狗_超时秒 = 超时秒
    看门狗_最后喂狗 = 当前时间_秒()
    内核信息("看门狗已启动, 超时=" + 转字符串(超时秒) + "秒")
}

函数 看门狗_喂狗() {
    如果 (!看门狗_启用) { 返回 }
    看门狗_最后喂狗 = 当前时间_秒()
}

函数 看门狗_检查() {
    如果 (!看门狗_启用) { 返回 }
    定义 现在 = 当前时间_秒()
    如果 (现在 - 看门狗_最后喂狗 > 看门狗_超时秒) {
        内核_恐慌("看门狗超时: 系统无响应 " + 转字符串(看门狗_超时秒) + "秒")
    }
}

函数 内核主函数_完整统计() {
    返回 [启动_阶段, 停机_类型, 停机_原因]
}

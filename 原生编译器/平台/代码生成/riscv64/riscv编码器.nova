// Nova · 平台层 · RISC-V (RV64I+M) 指令编码器
// 开放指令集 / R/I/S/B/U/J六种格式
函数 RV_指令字节(w) { 返回 [w&0xFF,(w>>8)&0xFF,(w>>16)&0xFF,(w>>24)&0xFF] }
函数 RV指令长度() { 返回 4 }

函数 R型(f7, rs2, rs1, f3, rd, op) { 返回 ((f7&0x7F)<<25)|((rs2&31)<<20)|((rs1&31)<<15)|((f3&7)<<12)|((rd&31)<<7)|(op&0x7F)
}

函数 RV_加(rd, rs1, rs2)
{ 返回 R型(0x00,rs2,rs1,0,rd,0x33) }
函数 RV_减(rd, rs1, rs2)
{ 返回 R型(0x20,rs2,rs1,0,rd,0x33) }
函数 RV_与(rd, rs1, rs2)
{ 返回 R型(0x00,rs2,rs1,7,rd,0x33) }
函数 RV_或(rd, rs1, rs2)
{ 返回 R型(0x00,rs2,rs1,6,rd,0x33) }
函数 RV_异或(rd, rs1, rs2)
{ 返回 R型(0x00,rs2,rs1,4,rd,0x33) }
函数 RV_左移(rd, rs1, rs2)
{ 返回 R型(0x00,rs2,rs1,1,rd,0x33) }
函数 RV_逻辑右移(rd, rs1, rs2)
{ 返回 R型(0x00,rs2,rs1,5,rd,0x33) }
函数 RV_算术右移(rd, rs1, rs2)
{ 返回 R型(0x20,rs2,rs1,5,rd,0x33) }
函数 RV_小于置位(rd, rs1, rs2)
{ 返回 R型(0x00,rs2,rs1,2,rd,0x33) }
函数 RV_无符号小于置位(rd, rs1, rs2) { 返回 R型(0x00,rs2,rs1,3,rd,0x33) }

函数 RV_乘(rd, rs1, rs2)
{ 返回 R型(0x01,rs2,rs1,0,rd,0x33) }
函数 RV_高位乘(rd, rs1, rs2)
{ 返回 R型(0x01,rs2,rs1,1,rd,0x33) }
函数 RV_除(rd, rs1, rs2)
{ 返回 R型(0x01,rs2,rs1,4,rd,0x33) }
函数 RV_无符号除(rd, rs1, rs2)
{ 返回 R型(0x01,rs2,rs1,5,rd,0x33) }
函数 RV_取余(rd, rs1, rs2)
{ 返回 R型(0x01,rs2,rs1,6,rd,0x33) }
函数 RV_无符号取余(rd, rs1, rs2)
{ 返回 R型(0x01,rs2,rs1,7,rd,0x33) }

函数 I型(imm, rs1, f3, rd, op) { 返回 ((imm&0xFFF)<<20)|((rs1&31)<<15)|((f3&7)<<12)|((rd&31)<<7)|(op&0x7F)
}

函数 RV_加立即数(rd, rs1, imm)
{ 返回 I型(imm,rs1,0,rd,0x13) }
函数 RV_与立即数(rd, rs1, imm)
{ 返回 I型(imm,rs1,7,rd,0x13) }
函数 RV_或立即数(rd, rs1, imm)
{ 返回 I型(imm,rs1,6,rd,0x13) }
函数 RV_异或立即数(rd, rs1, imm)
{ 返回 I型(imm,rs1,4,rd,0x13) }
函数 RV_小于立即数(rd, rs1, imm)
{ 返回 I型(imm,rs1,2,rd,0x13) }

函数 RV_加载字节(rd, rs1, imm)
{ 返回 I型(imm,rs1,0,rd,0x03) }
函数 RV_加载半字(rd, rs1, imm)
{ 返回 I型(imm,rs1,1,rd,0x03) }
函数 RV_加载字(rd, rs1, imm)
{ 返回 I型(imm,rs1,2,rd,0x03) }
函数 RV_加载双字(rd, rs1, imm)
{ 返回 I型(imm,rs1,3,rd,0x03) }
函数 RV_加载无符号字节(rd, rs1, imm) { 返回 I型(imm,rs1,4,rd,0x03) }
函数 RV_寄存器跳转链接(rd, rs1, imm) { 返回 I型(imm,rs1,0,rd,0x67) }

函数 S型(imm, rs2, rs1, f3, op) { 返回 (((imm>>5)&0x7F)<<25)|((rs2&31)<<20)|((rs1&31)<<15)|((f3&7)<<12)|(((imm)&0x1F)<<7)|(op&0x7F)
}

函数 RV_存储字节(rs2, rs1, imm) { 返回 S型(imm,rs2,rs1,0,0x23) }
函数 RV_存储半字(rs2, rs1, imm) { 返回 S型(imm,rs2,rs1,1,0x23) }
函数 RV_存储字(rs2, rs1, imm) { 返回 S型(imm,rs2,rs1,2,0x23) }
函数 RV_存储双字(rs2, rs1, imm) { 返回 S型(imm,rs2,rs1,3,0x23) }

函数 B型(imm, rs2, rs1, f3, op) { 定义 b12 = (imm >> 12) & 1
 定义 b11 = (imm >> 11) & 1
 定义 b10_5= (imm >> 5) & 0x3F
 定义 b4_1 = (imm >> 1) & 0xF
 返回 (b12<<31)|(b10_5<<25)|((rs2&31)<<20)|((rs1&31)<<15)|((f3&7)<<12)|(b4_1<<8)|(b11<<7)|(op&0x7F)
}

函数 RV_等于分支(rs1, rs2, imm) { 返回 B型(imm,rs2,rs1,0,0x63) }
函数 RV_不等分支(rs1, rs2, imm) { 返回 B型(imm,rs2,rs1,1,0x63) }
函数 RV_小于分支(rs1, rs2, imm) { 返回 B型(imm,rs2,rs1,4,0x63) }
函数 RV_大于等于分支(rs1, rs2, imm) { 返回 B型(imm,rs2,rs1,5,0x63) }

函数 RV_加载高位立即数(rd, imm20)
{ 返回 ((imm20&0xFFFFF)<<12)|((rd&31)<<7)|0x37 }
函数 RV_加载PC高位(rd, imm20) { 返回 ((imm20&0xFFFFF)<<12)|((rd&31)<<7)|0x17 }

函数 RV_跳转链接(rd, 偏移) { 定义 b20 = (偏移 >> 20) & 1
 定义 b10_1 = (偏移 >> 1) & 0x3FF
 定义 b11 = (偏移 >> 11) & 1
 定义 b19_12= (偏移 >> 12) & 0xFF
 返回 (b20<<31)|(b10_1<<21)|(b11<<20)|(b19_12<<12)|((rd&31)<<7)|0x6F
}

函数 RV_环境调用()
{ 返回 0x00000073 }
函数 RV_环境断点() { 返回 0x00100073 }
函数 RV_空操作()
{ 返回 RV_加立即数(0, 0, 0) }

函数 RV_移动(rd, rs1)
{ 返回 RV_加立即数(rd, rs1, 0) }
函数 RV_加载立即数(rd, imm)
{ 返回 RV_加立即数(rd,0,imm) }
函数 RV_返回()
{ 返回 RV_寄存器跳转链接(0, 1, 0) }
函数 RV_调用(rd, 偏移)
{ 返回 RV_跳转链接(rd,偏移) }
函数 RV_跳转(偏移)
{ 返回 RV_跳转链接(0,偏移) }
函数 RV_等零分支(rs1, imm)
{ 返回 RV_等于分支(rs1,0,imm) }
函数 RV_非零分支(rs1, imm)
{ 返回 RV_不等分支(rs1,0,imm) }

函数 RV_字加(rd, rs1, rs2) { 返回 R型(0x00,rs2,rs1,0,rd,0x3B) }
函数 RV_字减(rd, rs1, rs2) { 返回 R型(0x20,rs2,rs1,0,rd,0x3B) }
函数 RV_字乘(rd, rs1, rs2) { 返回 R型(0x01,rs2,rs1,0,rd,0x3B) }
函数 RV_字除(rd, rs1, rs2) { 返回 R型(0x01,rs2,rs1,4,rd,0x3B) }
函数 RV_字取余(rd, rs1, rs2) { 返回 R型(0x01,rs2,rs1,6,rd,0x3B) }
函数 RV_字左移(rd, rs1, rs2) { 返回 R型(0x00,rs2,rs1,1,rd,0x3B) }
函数 RV_字逻辑右移(rd, rs1, rs2) { 返回 R型(0x00,rs2,rs1,5,rd,0x3B) }
函数 RV_字算术右移(rd, rs1, rs2) { 返回 R型(0x20,rs2,rs1,5,rd,0x3B) }
函数 RV_字加立即数(rd, rs1, imm){ 返回 I型(imm,rs1,0,rd,0x1B) }

函数 RV_左移立即数(rd, rs1, shamt) { 返回 I型(shamt&0x3F,rs1,1,rd,0x13) }
函数 RV_逻辑右移立即数(rd, rs1, shamt) { 返回 I型(shamt&0x3F,rs1,5,rd,0x13) }
函数 RV_算术右移立即数(rd, rs1, shamt) { 返回 I型((0x400|(shamt&0x3F)),rs1,5,rd,0x13) }

函数 RV_栅栏(pred, succ) { 返回 0x0000000F|((pred&0xF)<<24)|((succ&0xF)<<20) }
函数 RV_全序栅栏()
{ 返回 0x8330000F }
函数 RV_读写控制状态(rd, rs1, csr) { 返回 ((csr&0xFFF)<<20)|((rs1&31)<<15)|(1<<12)|((rd&31)<<7)|0x73 }
函数 RV_置位控制状态(rd, rs1, csr) { 返回 ((csr&0xFFF)<<20)|((rs1&31)<<15)|(2<<12)|((rd&31)<<7)|0x73 }
函数 RV_清位控制状态(rd, rs1, csr) { 返回 ((csr&0xFFF)<<20)|((rs1&31)<<15)|(3<<12)|((rd&31)<<7)|0x73 }
函数 RV_读控制状态(rd, csr)
{ 返回 RV_置位控制状态(rd,0,csr) }
定义 CSR_机器状态 = 0x300
定义 CSR_机器陷阱向量 = 0x305
定义 CSR_机器异常PC = 0x341
定义 CSR_机器原因 = 0x342
定义 CSR_周期计数 = 0xC00
定义 CSR_时间 = 0xC01
定义 CSR_指令退休 = 0xC02

函数 RV_取反(rd, rs1)
{ 返回 RV_异或立即数(rd,rs1,0-1) }
函数 RV_取负(rd, rs1)
{ 返回 RV_减(rd,0,rs1) }
函数 RV_等零置位(rd, rs1)
{ 返回 RV_小于立即数(rd,rs1,1) }

// Nova编译器 v4.1 — 多格式链接器
// ELF64 (Linux) / Mach-O (macOS/iOS)

// ELF64 链接器
// ELF头+程序头+节头+符号表+字符串表+重定位

定义 ELF_类64位 = 2
定义 ELF_小端序 = 1
定义 处理器_X86_64 = 62


定义 段标志_可执行 = 1
定义 段标志_可写 = 2
定义 段标志_可读 = 4


定义 节标志_可写 = 1
定义 节标志_分配 = 2
定义 节标志_可执行 = 4

定义 符号绑定_本地 = 0
定义 符号绑定_全局 = 1
定义 符号类型_函数 = 2
定义 符号类型_对象 = 1

定义 ELF头_大小 = 64
定义 程序头_大小 = 56
定义 节头_大小 = 64
定义 符号_大小 = 24
定义 重定位_大小 = 24

定义 ELF_基址 = 0x400000
定义 ELF_页大小 = 0x1000

// RISC-V指令编码辅助
函数 riscv_R型(funct7, rs2, rs1, funct3, rd, opcode) { 返回 (funct7 << 25) | ((rs2 & 31) << 20) | ((rs1 & 31) << 15) | ((funct3 & 7) << 12) | ((rd & 31) << 7) | (opcode & 0x7F)
}

函数 riscv_I型(imm12, rs1, funct3, rd, opcode) { 返回 ((imm12 & 0xFFF) << 20) | ((rs1 & 31) << 15) | ((funct3 & 7) << 12) | ((rd & 31) << 7) | (opcode & 0x7F)
}

函数 riscv_S型(imm12, rs2, rs1, funct3, opcode) { 定义 高7 = (imm12 >> 5) & 0x7F
 定义 低5 = imm12 & 0x1F
 返回 (高7 << 25) | ((rs2 & 31) << 20) | ((rs1 & 31) << 15) | ((funct3 & 7) << 12) | (低5 << 7) | (opcode & 0x7F)
}

函数 riscv_B型(imm13, rs2, rs1, funct3, opcode) { 定义 b12 = (imm13 >> 12) & 1
 定义 b11 = (imm13 >> 11) & 1
 定义 b10_5 = (imm13 >> 5) & 0x3F
 定义 b4_1 = (imm13 >> 1) & 0xF
 返回 (b12 << 31) | (b10_5 << 25) | ((rs2 & 31) << 20) | ((rs1 & 31) << 15) | ((funct3 & 7) << 12) | (b4_1 << 8) | (b11 << 7) | (opcode & 0x7F)
}

函数 riscv_U型(imm20, rd, opcode) { 返回 ((imm20 & 0xFFFFF) << 12) | ((rd & 31) << 7) | (opcode & 0x7F)
}

函数 riscv_J型(imm21, rd, opcode) { 定义 b20 = (imm21 >> 20) & 1
 定义 b19_12 = (imm21 >> 12) & 0xFF
 定义 b11 = (imm21 >> 11) & 1
 定义 b10_1 = (imm21 >> 1) & 0x3FF
 返回 (b20 << 31) | (b10_1 << 21) | (b11 << 20) | (b19_12 << 12) | ((rd & 31) << 7) | (opcode & 0x7F)
}

// 寄存器ABI名

函数 riscv_是临时寄存器(r) { 返回 (r >= 5 且 r <= 7) 或 (r >= 28 且 r <= 31) }
函数 riscv_是保存寄存器(r) { 返回 (r >= 8 且 r <= 9) 或 (r >= 18 且 r <= 27) }
函数 riscv_是参数寄存器(r) { 返回 r >= 10 且 r <= 17 }

// 分支偏移检查
函数 riscv_B型范围有效(偏移) { 返回 偏移 >= -4096 且 偏移 <= 4094 }
函数 riscv_J型范围有效(偏移) { 返回 偏移 >= -1048576 且 偏移 <= 1048574 }

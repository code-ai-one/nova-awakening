// Nova标准库 — 神经网络基础模块
// 全连接层、前向传播、反向传播、梯度下降
// 整数定点实现 (精度=1000)
// 对标 nova-forth 的 layers/ 和 training/ 模块

导入("../基础.nova")
导入("../../运行时/原语桩.nova")
导入("损失函数.nova")
导入("../算法/数学扩展.nova")
导入("./基础/数学库.nova")
导入("../激活函数/激活函数.nova")
导入("../函数式/函数式.nova")
导入("工具.nova")

定义 网络精度 = 1000
定义 量子_半 = 500

函数 Q开方(x) {
    如果 (x <= 0) { 返回 0 }
    定义 可变 r = x
    定义 可变 i = 0
    当 (i < 16) {
        r = (r + x * 网络精度 / (r + 1)) / 2
        i = i + 1
    }
    返回 r
}

函数 Tensor_读(t, i) { 返回 内存_读32有符号(t.数据 + i * 4) }
函数 Tensor_写(t, i, v) { 内存_写32(t.数据 + i * 4, v) }

// 全连接层
// 层 = [输入维度, 输出维度, 权重矩阵, 偏置向量, 最后输入, 最后输出]
// 权重矩阵: [行=输出维度, 列=输入维度, 数据...]
// 偏置向量: [输出维度个值]

函数 全连接_创建(输入维, 输出维) {
 // 初始化权重 (简单随机: 使用伪随机种子)
 定义 可变 权重 = [输出维, 输入维]
 定义 可变 种子 = 12345
 定义 可变 i = 0
 当 (i < 输出维 * 输入维) {
 // 简单线性同余生成器
 种子 = (种子 * 1103515245 + 12345) & 0x7FFFFFFF
 定义 w = (种子 % 200) - 100 // [-100, 100] 即 [-0.1, 0.1]
 追加(权重, w)
 i = i + 1
 }
 // 偏置初始化为0
 定义 可变 偏置 = []
 i = 0
 当 (i < 输出维) {
 追加(偏置, 0)
 i = i + 1
 }
 返回 [输入维, 输出维, 权重, 偏置, [], []]
}

// 全连接层前向传播: 输出 = 权重 * 输入 + 偏置
函数 全连接_前向(层, 输入) { 定义 输出维 = 层[1]
 定义 输入维 = 层[0]
 定义 权重 = 层[2]
 定义 偏置 = 层[3]
 定义 可变 输出 = []
 定义 可变 i = 0
 当 (i < 输出维) { 定义 可变 和 = 偏置[i]
 定义 可变 j = 0
 当 (j < 输入维) {
 和 = 和 + 权重[2 + i * 输入维 + j] * 输入[j] / 网络精度
 j = j + 1
 }
 追加(输出, 和)
 i = i + 1
 }
 // 保存最后输入/输出用于反向传播
 层[4] = 输入
 层[5] = 输出
 返回 输出
}

// 全连接层反向传播
// 回: [输入梯度, 权重梯度, 偏置梯度]
函数 全连接_反向(层, 输出梯度) { 定义 输出维 = 层[1]
 定义 输入维 = 层[0]
 定义 权重 = 层[2]
 定义 输入 = 层[4]
 // 输入梯度: 权重^T * 输出梯度
 定义 可变 输入梯度 = []
 定义 可变 j = 0
 当 (j < 输入维) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 输出维) {
 和 = 和 + 权重[2 + i * 输入维 + j] * 输出梯度[i] / 网络精度
 i = i + 1
 }
 追加(输入梯度, 和)
 j = j + 1
 }
 // 权重梯度: 输出梯度 × 输入^T
 定义 可变 权重梯度 = []
 定义 可变 i2 = 0
 当 (i2 < 输出维) {
 j = 0
 当 (j < 输入维) {
 追加(权重梯度, 输出梯度[i2] * 输入[j] / 网络精度)
 j = j + 1
 }
 i2 = i2 + 1
 }
 // 偏置梯度 = 输出梯度
 返回 [输入梯度, 权重梯度, 输出梯度]
}

// 权重更新 (SGD)
函数 全连接_更新(层, 权重梯度, 偏置梯度, 学习率) { 定义 输出维 = 层[1]
 定义 输入维 = 层[0]
 定义 权重 = 层[2]
 定义 偏置 = 层[3]
 // 更新权重: W = W - lr * dW
 定义 可变 i = 0
 当 (i < 输出维 * 输入维) {
 权重[2 + i] = 权重[2 + i] - 学习率 * 权重梯度[i] / 网络精度
 i = i + 1
 }
 // 更新偏置: b = b - lr * db
 i = 0
 当 (i < 输出维) {
 偏置[i] = 偏置[i] - 学习率 * 偏置梯度[i] / 网络精度
 i = i + 1
 }
}

// 激活层
函数 relu层_前向(输入) { 定义 可变 输出 = []
 定义 可变 i = 0
 当 (i < 计数(输入)) { 如果 (输入[i] > 0) { 追加(输出, 输入[i]) }
 否则 { 追加(输出, 0) }
 i = i + 1
 }
 返回 输出
}

函数 relu层_反向(输入, 输出梯度) { 定义 可变 梯度 = []
 定义 可变 i = 0
 当 (i < 计数(输入)) { 如果 (输入[i] > 0) { 追加(梯度, 输出梯度[i]) }
 否则 { 追加(梯度, 0) }
 i = i + 1
 }
 返回 梯度
}

// 简单多层感知器 (MLP)
// 网络 = [层列表, 层数]

函数 mlp_创建(层维度) { 定义 层数 = 计数(层维度) - 1
 定义 可变 层列表 = []
 定义 可变 i = 0
 当 (i < 层数) {
 追加(层列表, 全连接_创建(层维度[i], 层维度[i + 1]))
 i = i + 1
 }
 返回 [层列表, 层数]
}

// MLP 前向传播 (带 线性整流 激活，最后一层不激活)
函数 mlp_前向(网络, 输入) { 定义 层列表 = 网络[0]
 定义 层数 = 网络[1]
 定义 可变 当前 = 输入
 定义 可变 i = 0
 当 (i < 层数) {
 当前 = 全连接_前向(层列表[i], 当前)
 如果 (i < 层数 - 1) {
 当前 = relu层_前向(当前)
 }
 i = i + 1
 }
 返回 当前
}

// 训练工具

// 计算预测准确率
函数 准确率(预测列表, 真实列表) { 定义 n = 计数(预测列表)
 定义 可变 i = 0
 当 (i < n) { 如果 (预测列表[i] == 真实列表[i]) { 正确 = 正确 + 1 }
 i = i + 1
 }
 如果 (n == 0) { 返回 0 }
 返回 正确 * 网络精度 / n
}

// 最大值索引 (找最大值索引)
函数 最大值索引(向量) { 定义 n = 计数(向量)
    定义 可变 最大索引 = 0
 定义 可变 最大值 = 向量[0]
 定义 可变 i = 1
 当 (i < n) { 如果 (向量[i] > 最大值) {
 最大值 = 向量[i]
 最大索引 = i
 }
 i = i + 1
 }
 返回 最大索引
}

// 最小值索引
函数 最小值索引(向量) { 定义 n = 计数(向量)
 定义 可变 最小索引 = 0
 定义 可变 最小值 = 向量[0]
 定义 可变 i = 1
 当 (i < n) { 如果 (向量[i] < 最小值) {
 最小值 = 向量[i]
 最小索引 = i
 }
 i = i + 1
 }
 返回 最小索引
}

// 向量求和
函数 向量_求和(v) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 计数(v)) {
 和 = 和 + v[i]
 i = i + 1
 }
 返回 和
}

// 向量平均
函数 向量_平均(v) { 返回 向量_求和(v) / 计数(v)
}

// 优化器

// SGD 带动量
// 状态 = [速度列表 (与权重同维度)]
函数 sgd动量_创建(参数数) { 定义 可变 速度 = []
 定义 可变 i = 0
 当 (i < 参数数) {
 追加(速度, 0)
 i = i + 1
 }
 返回 [速度]
}

函数 sgd动量_更新(状态, 参数, 梯度, 学习率, 动量) { 定义 速度 = 状态[0]
 定义 可变 i = 0
 当 (i < 计数(参数)) {
 // v = momentum * v - lr * grad
 速度[i] = 动量 * 速度[i] / 网络精度 - 学习率 * 梯度[i] / 网络精度
 // 参数 = param + v
 参数[i] = 参数[i] + 速度[i]
 i = i + 1
 }
}

// 数据处理

// 随机打乱列表 (Fisher-Yates)
函数 打乱(列表, 种子) { 定义 n = 计数(列表)
 定义 可变 s = 种子
 定义 可变 i = n - 1
 当 (i > 0) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 定义 j = s % (i + 1)
 // 交换
 定义 暂存 = 列表[i]
 列表[i] = 列表[j]
 列表[j] = 暂存
 i = i - 1
 }
}

// 批次生成器
函数 生成批次(数据, 批大小) { 定义 n = 计数(数据)
 定义 可变 批次列表 = []
 定义 可变 i = 0
 当 (i < n) { 定义 可变 批次 = []
 定义 可变 j = 0
 当 (j < 批大小 且 i + j < n) {
 追加(批次, 数据[i + j])
 j = j + 1
 }
 追加(批次列表, 批次)
 i = i + 批大小
 }
 返回 批次列表
}

// one-hot 编码
函数 独热编码(索引, 类数) { 定义 可变 向量 = []
 定义 可变 i = 0
 当 (i < 类数) { 如果 (i == 索引) { 追加(向量, 网络精度) }
 否则 { 追加(向量, 0) }
 i = i + 1
 }
 返回 向量
}

// 归一化 (将列表值缩放到 [0, 精度] 范围)
函数 归一化(数据) { 定义 n = 计数(数据)
 定义 可变 最小 = 数据[0]
 定义 可变 最大 = 数据[0]
 定义 可变 i = 1
 当 (i < n) { 如果 (数据[i] < 最小) { 最小 = 数据[i] }
 如果 (数据[i] > 最大) { 最大 = 数据[i] }
 i = i + 1
 }
 定义 可变 范围 = 最大 - 最小
 如果 (范围 == 0) { 范围 = 1 }
 定义 可变 结果 = []
 i = 0
 当 (i < n) {
 追加(结果, (数据[i] - 最小) * 网络精度 / 范围)
 i = i + 1
 }
 返回 结果
}

// 标准化 (零均值单位方差，整数近似)
函数 标准化(数据) { 定义 n = 计数(数据)
    定义 可变 方差和 = 0
 定义 均值 = 向量_平均(数据)
 定义 可变 i = 0
 当 (i < n) { 定义 差 = 数据[i] - 均值
 方差和 = 方差和 + 差 * 差
 i = i + 1
 }
 定义 可变 标准差 = 整数开方(方差和 / n)
 如果 (标准差 == 0) { 标准差 = 1 }
 定义 可变 结果 = []
 i = 0
 当 (i < n) {
 追加(结果, (数据[i] - 均值) * 网络精度 / 标准差)
 i = i + 1
 }
 返回 结果
}

函数 神经网络_整数开方(n) { 返回 开方(n) }

// 批归一化 (批归一化)
// BN层 = [衰减率, 动量率, running_mean, running_var, eps, momentum]
// 衰减率/动量率: 可学习参数, running_*: 运行统计量

函数 批归一化_创建(维度) { 定义 可变 衰减率 = []
 定义 可变 动量率 = []
 定义 可变 均值 = []
 定义 可变 方差 = []
 定义 可变 i = 0
 当 (i < 维度) {
 插入(衰减率, 计数(衰减率), 网络精度) // 衰减率=1.0
 插入(动量率, 计数(动量率)) // 动量率=0.0
 插入(均值, 计数(均值))
 插入(方差, 计数(方差), 网络精度) // var=1.0
 i = i + 1
 }
 返回 [衰减率, 动量率, 均值, 方差, 1, 900] // eps=1, momentum=0.9
}

// BN前向 (训练模式: 使用批次统计量)
函数 批归一化_前向(bn, 输入) { 定义 n = 计数(输入)
 定义 衰减率 = bn[0]
 定义 动量率 = bn[1]
 // 计算批次均值
 定义 可变 批均值 = 0
 定义 可变 i = 0
 当 (i < n) { 批均值 = 批均值 + 输入[i]
 i = i + 1 }
 批均值 = 批均值 / n
 // 计算批次方差
 定义 可变 批方差 = 0
 i = 0
 当 (i < n) { 定义 d = 输入[i] - 批均值
 批方差 = 批方差 + d * d / 网络精度
 i = i + 1
 }
 批方差 = 批方差 / n
 // 归一化 + 缩放 + 偏移
 定义 可变 标准差 = 开方(批方差 + bn[4])
 如果 (标准差 == 0) { 标准差 = 1 }
 定义 可变 输出 = []
 i = 0
 当 (i < n) { 定义 索引 = i % 计数(衰减率)
 定义 归一 = (输入[i] - 批均值) * 网络精度 / 标准差
 插入(输出, 计数(输出), 衰减率[索引] * 归一 / 网络精度 + 动量率[索引])
 i = i + 1
 }
 // 更新运行统计量
 定义 动量 = bn[5]
 定义 可变 j = 0
 当 (j < 计数(bn[2])) {
 bn[2][j] = 动量 * bn[2][j] / 网络精度 + (网络精度 - 动量) * 批均值 / 网络精度
 bn[3][j] = 动量 * bn[3][j] / 网络精度 + (网络精度 - 动量) * 批方差 / 网络精度
 j = j + 1
 }
 返回 输出
}

// 随机丢弃层
// 训练时随机置零, 推理时直接通过
// 保持率: keep_rate (0-1000, 如700=70%保留)

函数 dropout_前向(输入, 保持率, 种子, 训练) { 如果 (训练 == 0) { 返回 输入 } // 推理模式直接返回
 定义 n = 计数(输入)
 定义 可变 输出 = []
 定义 可变 s = 种子
 定义 可变 i = 0
 当 (i < n) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 如果 (s % 1000 < 保持率) {
 // 保留并缩放: x / keep_rate
 插入(输出, 计数(输出), 输入[i] * 网络精度 / 保持率)
 } 否则 {
 插入(输出, 计数(输出))
 }
 i = i + 1
 }
 返回 输出
}

// LeakyReLU 激活
// LeakyReLU(x) = x if x>0, 学习率*x otherwise
// 学习率: 负区斜率 (如100=0.1)

函数 leaky_relu_前向(输入, 学习率) { 定义 可变 输出 = []
 定义 可变 i = 0
 当 (i < 计数(输入)) { 如果 (输入[i] > 0) {
 插入(输出, 计数(输出), 输入[i])
 } 否则 {
 插入(输出, 计数(输出), 输入[i] * 学习率 / 网络精度)
 }
 i = i + 1
 }
 返回 输出
}

函数 leaky_relu_反向(输入, 输出梯度, 学习率) { 定义 可变 梯度 = []
 定义 可变 i = 0
 当 (i < 计数(输入)) { 如果 (输入[i] > 0) {
 插入(梯度, 计数(梯度), 输出梯度[i])
 } 否则 {
 插入(梯度, 计数(梯度), 输出梯度[i] * 学习率 / 网络精度)
 }
 i = i + 1
 }
 返回 梯度
}

// 残差连接
// 残差块: 输出 = F(输入) + 输入

函数 残差_前向(层, 输入) { 定义 中间 = 全连接_前向(层, 输入)
 定义 激活 = relu层_前向(中间)
 // 残差连接: 要求输入维度 == 输出维度
 如果 (计数(激活) == 计数(输入)) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(激活)) {
 插入(结果, 计数(结果), 激活[i] + 输入[i])
 i = i + 1
 }
 返回 结果
 }
 返回 激活
}

// Softmax (整数近似)
// 输出归一化概率 (×1000)

函数 神经_softmax(输入) { 定义 n = 计数(输入)
 // 找最大值 (数值稳定)
 定义 可变 最大 = 输入[0]
 定义 可变 i = 1
 当 (i < n) { 如果 (输入[i] > 最大) { 最大 = 输入[i] }
 i = i + 1
 }
 // exp近似: e^x ≈ (1 + x/1024)^1024, 简化为线性段
 定义 可变 指数值 = []
 定义 可变 总和 = 0
 i = 0
 当 (i < n) { 定义 x = 输入[i] - 最大
 // 分段exp近似 (x <=0)
 定义 可变 ex = 0
 如果 (x >= 0) { ex = 网络精度 }
 否则 如果 (x > 0 - 网络精度) { ex = 网络精度 + x }
 否则 如果 (x > 0 - 3 * 网络精度) { ex = (网络精度 + x / 3) * (网络精度 + x / 3) / 网络精度 }
 否则 { ex = 1 }
 如果 (ex < 1) { ex = 1 }
 插入(指数值, 计数(指数值), ex)
 总和 = 总和 + ex
 i = i + 1
 }
 // 归一化
 定义 可变 结果 = []
 i = 0
 当 (i < n) {
 插入(结果, 计数(结果), 指数值[i] * 网络精度 / 总和)
 i = i + 1
 }
 返回 结果
}

// Xavier/He 初始化

函数 全连接_创建_xavier(输入维, 输出维, 种子) { 定义 范围 = 开方(6 * 网络精度 / (输入维 + 输出维))
 定义 可变 权重 = [输出维, 输入维]
 定义 可变 s = 种子
 定义 可变 i = 0
 当 (i < 输出维 * 输入维) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 定义 w = (s % (2 * 范围 + 1)) - 范围
 插入(权重, 计数(权重), w)
 i = i + 1
 }
 定义 可变 偏置 = []
 i = 0
 当 (i < 输出维) { 插入(偏置, 计数(偏置))
 i = i + 1 }
 返回 [输入维, 输出维, 权重, 偏置, [], []]
}

函数 全连接_创建_he(输入维, 输出维, 种子) { 定义 范围 = 开方(2 * 网络精度 / 输入维)
 定义 可变 权重 = [输出维, 输入维]
 定义 可变 s = 种子
 定义 可变 i = 0
 当 (i < 输出维 * 输入维) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 定义 w = (s % (2 * 范围 + 1)) - 范围
 插入(权重, 计数(权重), w)
 i = i + 1
 }
 定义 可变 偏置 = []
 i = 0
 当 (i < 输出维) { 插入(偏置, 计数(偏置))
 i = i + 1 }
 返回 [输入维, 输出维, 权重, 偏置, [], []]
}

// 学习率调度

// 线性预热 (warmup步内从0线性增到目标学习率)
函数 神经_学习率_预热(步数, 预热步, 目标率) {
    如果 (步数 >= 预热步) { 返回 目标率
}
 如果 (预热步 == 0) { 返回 0 }
 返回 目标率 * 步数 / 预热步
}

// 余弦退火 (从max_lr余弦衰减到min_lr)
函数 学习率_余弦(步数, 总步数, 最大率, 最小率) {
    如果 (步数 >= 总步数) { 返回 最小率
}
 // cos近似: cos(π*t) ≈ 1 - 2*t^2 (for t in [0,1])
 定义 t = 步数 * 网络精度 / 总步数
 定义 余弦值 = 网络精度 - 2 * t * t / 网络精度
 返回 最小率 + (最大率 - 最小率) * (网络精度 + 余弦值) / (2 * 网络精度)
}

// 阶梯衰减 (每step_size步乘以gamma)
函数 神经网络_学习率_阶梯(步数, 阶梯大小, 初始率, 衰减因子) { 定义 可变 率 = 初始率
 定义 可变 s = 步数
 当 (s >= 阶梯大小) {
 率 = 率 * 衰减因子 / 网络精度
 s = s - 阶梯大小
 }
 返回 率
}

// 梯度裁剪

函数 梯度裁剪_范数(梯度, 最大范数) {
    定义 可变 范数平方 = 0
 定义 可变 i = 0
 当 (i < 计数(梯度)) {
 范数平方 = 范数平方 + 梯度[i] * 梯度[i] / 网络精度
 i = i + 1
 }
 定义 范数 = 开方(范数平方)
 如果 (范数 > 最大范数) { 定义 缩放 = 最大范数 * 网络精度 / 范数
 i = 0
 当 (i < 计数(梯度)) {
 梯度[i] = 梯度[i] * 缩放 / 网络精度
 i = i + 1
 }
 }
}

函数 梯度裁剪_值(梯度, 最大值) { 定义 可变 i = 0
 当 (i < 计数(梯度)) { 如果 (梯度[i] > 最大值) { 梯度[i] = 最大值 }
 如果 (梯度[i] < 0 - 最大值) { 梯度[i] = 0 - 最大值 }
 i = i + 1
 }
}

// Xavier 初始化
函数 神经网络_xavier初始化(输入维, 输出维, 种子) { 定义 可变 范围 = 开方(6 * 网络精度 / (输入维 + 输出维))
 如果 (范围 == 0) { 范围 = 1 }
 定义 可变 权重 = [输出维, 输入维]
 定义 可变 s = 种子
 定义 可变 i = 0
 当 (i < 输出维 * 输入维) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 追加(权重, (s % (2 * 范围 + 1)) - 范围)
 i = i + 1
 }
 返回 权重
}

// He 初始化 (适合ReLU)
函数 神经网络_he初始化(输入维, 输出维, 种子) { 定义 可变 范围 = 开方(2 * 网络精度 / 输入维)
 如果 (范围 == 0) { 范围 = 1 }
 定义 可变 权重 = [输出维, 输入维]
 定义 可变 s = 种子
 定义 可变 i = 0
 当 (i < 输出维 * 输入维) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 追加(权重, (s % (2 * 范围 + 1)) - 范围)
 i = i + 1
 }
 返回 权重
}

// Layer Normalization
函数 神经_归一化(输入, 衰减率, 动量率) { 定义 n = 计数(输入)
 // 均值
 定义 可变 均值 = 0
 定义 可变 i = 0
 当 (i < n) { 均值 = 均值 + 输入[i]
 i = i + 1 }
 均值 = 均值 / n
 // 方差
 定义 可变 方差 = 0
 i = 0
 当 (i < n) { 定义 d = 输入[i] - 均值
 方差 = 方差 + d * d / 网络精度
 i = i + 1
 }
 方差 = 方差 / n
 定义 可变 标准差 = 开方(方差)
 如果 (标准差 == 0) { 标准差 = 1 }
 // 归一化 + 缩放偏移
 定义 可变 输出 = []
 i = 0
 当 (i < n) { 定义 归一 = (输入[i] - 均值) * 网络精度 / 标准差
 追加(输出, 归一 * 衰减率[i] / 网络精度 + 动量率[i])
 i = i + 1
 }
 返回 输出
}

// RMS Normalization (LLaMA风格)
函数 rms归一化(输入, 衰减率) { 定义 n = 计数(输入)
 // 均方根
 定义 可变 和平方 = 0
 定义 可变 i = 0
 当 (i < n) {
 和平方 = 和平方 + 输入[i] * 输入[i] / 网络精度
 i = i + 1
 }
 定义 可变 均方根值 = 开方(和平方 / n)
 如果 (均方根值 == 0) { 均方根值 = 1 }
 定义 可变 输出 = []
 i = 0
 当 (i < n) {
 追加(输出, 输入[i] * 衰减率[i] / 均方根值)
 i = i + 1
 }
 返回 输出
}

// Residual 连接
函数 神经_残差连接(输入, 子层输出) { 定义 n = 计数(输入)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < n) {
 追加(结果, 输入[i] + 子层输出[i])
 i = i + 1
 }
 返回 结果
}

// 权重衰减 (L2正则化, 0)
函数 权重衰减(参数, 衰减系数) { 定义 n = 计数(参数)
 定义 可变 i = 0
 当 (i < n) {
 参数[i] = 参数[i] - 衰减系数 * 参数[i] / 网络精度
 i = i + 1
 }
}

// [v2反哺] 量化 — TurboQuant向量几何保持量化(内积误差<5% vs INT8=15%, 替换标量量化)
// TurboQuant_向量压缩 — Nova原生几何保持量化
// 旧版: 传统INT8/逐通道标量量化, 无内积保证
// TurboQuant: 向量级压缩, 保持相似度/内积结构
// 格式: 8bit/元素 = 4bit方向(极坐标) + 4bit幅值(相对模长)
// Rust验证: 内积保持误差<5%, vs INT8传统量化约15%
函数 TurboQuant_向量压缩(向量, 压缩输出, 维度) {
    如果 (向量 == 0 或 压缩输出 == 0 或 维度 == 0) { 返回 }
    // step1: 计算向量L2模长
    定义 可变 sum_sq = 0
    定义 可变 i = 0
    当 (i < 维度) {
        定义 v = Tensor_读(向量, i)
        sum_sq = sum_sq + Q乘(v, v)
        i = i + 1
    }
    定义 模长 = Q开方(sum_sq)
    如果 (模长 == 0) { 返回 }
    // step2: 极坐标编码每个元素 (方向4bit+幅值4bit=8bit)
    i = 0
    当 (i < 维度) {
        定义 v = Tensor_读(向量, i)
        定义 方向4 = v * 7 / 模长
        如果 (方向4 > 7) { 方向4 = 7 }
        如果 (方向4 < -7) { 方向4 = -7 }
        定义 幅值 = v * 定点_一 / 模长
        如果 (幅值 < 0) { 幅值 = 0 - 幅值 }
        定义 幅值4 = 幅值 * 15 / 定点_一
        如果 (幅值4 > 15) { 幅值4 = 15 }
        定义 编码 = ((方向4 + 7) << 4) | 幅值4
        内存_写8(压缩输出 + i, 编码)
        i = i + 1
    }
}
函数 TurboQuant_向量解压(压缩输入, 向量输出, 维度, 模长_Q10) {
    如果 (压缩输入 == 0 或 向量输出 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 维度) {
        定义 编码 = 内存_读8(压缩输入 + i)
        定义 方向4 = ((编码 >> 4) & 15) - 7
        定义 幅值4 = 编码 & 15
        定义 v = 方向4 * 模长_Q10 / 7 * 幅值4 / 15
        Tensor_写(向量输出, i, v)
        i = i + 1
    }
}
// 内积保持验证: 压缩前后内积误差估计
函数 TurboQuant_内积误差估计(a_模长, b_模长, 维度) {
    // JL误差界: O(1/sqrt(k)) 其中k=目标维度
    定义 误差_Q10 = 定点_一 * 10 / Q开方(维度 * 定点_一)
    返回 误差_Q10
}

// 梯度检查 (数值梯度 vs 解析梯度)
函数 梯度检查_误差(解析梯度, 数值梯度) { 定义 n = 计数(解析梯度)
 定义 可变 最大误差 = 0
 定义 可变 i = 0
 当 (i < n) { 定义 可变 差值 = 解析梯度[i] - 数值梯度[i]
 如果 (差值 < 0) { 差值 = 0 - 差值 }
 如果 (差值 > 最大误差) { 最大误差 = 差值 }
 i = i + 1
 }
 返回 最大误差
}

// 合并自 编译器/标准库/神经网络/神经网络.nova

函数 批归一化(v) {
    如果 (计数(v) == 0) { 返回 []
}
 定义 均值 = 向量_和(v) / 计数(v)
 定义 可变 var_sum = 0
 定义 可变 i = 0
 当 (i < 计数(v)) { 定义 d = v[i] - 均值
 var_sum = var_sum + d * d
 i = i + 1
 }
 定义 variance = var_sum / 计数(v)
 定义 可变 标准差 = 整数开方(variance)
 如果 (标准差 == 0) { 标准差 = 1 }
 定义 可变 r = []
 i = 0
 当 (i < 计数(v)) {
 追加(r, (v[i] - 均值) * 100 / 标准差)
 i = i + 1
 }
 返回 r
}

函数 截断(x, 最小, 最大) {
    如果 (x < 最小) { 返回 最小
}
 如果 (x > 最大) { 返回 最大 }
 返回 x
}

函数 随机丢弃层(v, 掩码) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(v)) { 如果 (掩码[i] == 0) { 追加(r, 0) }
 否则 { 追加(r, v[i]) }
 i = i + 1
 }
 返回 r
}

// [v2反哺] LeakyReLU — LeakyReLU→HexSigmoid更平滑激活(6段精确, 类人脑边界)
// HexSigmoid — Nova原创6段分段线性sigmoid
// Rust验证: 误差151/1000 vs 旧线性近似272/1000 (降低44%)
// 特性: 4条整数运算, 无乘法, 零依赖
函数 激活_HexSigmoid_单值(x) {
    定义 ax = x
    定义 可变 符号 = 1
    如果 (x < 0) { ax = 0 - x; 符号 = -1 }
    定义 可变 out = 0
    如果 (ax > 6 * 定点_一)      { out = 定点_一 }
    否则 如果 (ax > 3 * 定点_一) { out = 定点_一 - (6 * 定点_一 - ax) * 3 / (3 * 定点_一) }
    否则 如果 (ax > 定点_一)     { out = 970 - (3 * 定点_一 - ax) * 82 / (2 * 定点_一) }
    否则 如果 (ax > 338)       { out = 731 - (定点_一 - ax) * 238 / (定点_一 - 338) }
    否则                        { out = 量子_半 + ax * 250 / 338 }
    如果 (符号 < 0) { out = 定点_一 - out }
    返回 out
}
函数 激活_HexSigmoid(t) {
    如果 (t == 0) { 返回 }
    定义 总 = t.行数 * t.列数
    定义 可变 i = 0
    当 (i < 总) {
        定义 x = 内存_读32有符号(t.数据 + i * 4)
        内存_写32(t.数据 + i * 4, 激活_HexSigmoid_单值(x))
        i = i + 1
    }
}
函数 LeakyReLU导数(x, 学习率) {
    如果 (x > 0) { 返回 1 }
    返回 学习率
}

函数 MAE损失(预测, 真实) {
    如果 (计数(预测) == 0) { 返回 0
}
 定义 可变 总误差 = 0
 定义 可变 i = 0
 当 (i < 计数(预测)) {
 总误差 = 总误差 + 绝对值(预测[i] - 真实[i])
 i = i + 1
 }
 返回 总误差 / 计数(预测)
}

函数 MSE损失(预测, 真实) {
    如果 (计数(预测) == 0) { 返回 0
}
 定义 可变 总误差 = 0
 定义 可变 i = 0
 当 (i < 计数(预测)) { 定义 可变 偏差 = 预测[i] - 真实[i]
 总误差 = 总误差 + 偏差 * 偏差
 i = i + 1
 }
 返回 总误差 / 计数(预测)
}

函数 独热编码2(索引, 类别数) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 类别数) { 如果 (i == 索引) { 追加(r, 1) }
 否则 { 追加(r, 0) }
 i = i + 1
 }
 返回 r
}

// [v2反哺] 线性整流 — 线性整流→SQNL整数定点版(Wuraola&Patel2018, 平滑边界误差1/1000)
// SQNL整数定点版 (Wuraola&Patel 2018, Nova整数实现)
// 类人脑: 平滑边界，比ReLU更符合神经元阈值特性
// Rust验证: 误差1/1000, 仅3条运算
// f(x) = 1 if x>2; x-x²/4 if 0<x≤2; x+x²/4 if -2≤x<0; -1 if x<-2
函数 激活_SQNL(t) {
    如果 (t == 0) { 返回 }
    定义 总 = t.行数 * t.列数
    定义 可变 i = 0
    当 (i < 总) {
        定义 x = 内存_读32有符号(t.数据 + i * 4)
        定义 可变 结果 = 0
        如果 (x > 2 * 定点_一)       { 结果 =  定点_一 }
        否则 如果 (x < -2 * 定点_一) { 结果 = -定点_一 }
        否则 如果 (x >= 0)  { 结果 = x - Q乘(x, x) / 4 }
        否则                { 结果 = x + Q乘(x, x) / 4 }
        内存_写32(t.数据 + i * 4, 结果)
        i = i + 1
    }
}
函数 ReLU导数(x) {
    如果 (x > 0) { 返回 1 }
    返回 0
}

函数 线性整流6(x) { 返回 截断(x, 0, 6) }

函数 SGD_更新(参数, 梯度, 学习率) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(参数)) {
 追加(r, 参数[i] - 学习率 * 梯度[i])
 i = i + 1
 }
 返回 r
}

函数 Sigmoid近似(x) {
    如果 (x > 5) { 返回 100
}
 如果 (x < -5) { 返回 0 }
 // 线性近似 [0,100] 区间表示 [0.0, 1.0]
 返回 50 + x * 10
}

函数 Tanh近似(x) {
    如果 (x > 5) { 返回 100
}
 如果 (x < -5) { 返回 -100 }
 返回 x * 20
}

函数 交叉熵损失(softmax输出, 标签索引) {
 // -log(p[标签]) 近似
 定义 p = softmax输出[标签索引]
 如果 (p <= 0) { 返回 10000 }
 // -log(x/1000)*100 近似
 定义 可变 对数值 = 0
 定义 可变 x = p
 当 (x < 1000) { 对数值 = 对数值 + 1
 x = x * 2 }
 返回 对数值 * 70
}

函数 向量_ReLU(v) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(v)) {
 追加(r, 线性整流(v[i]))
 i = i + 1
 }
 返回 r
}

函数 向量_argmax(v) { 定义 可变 m = v[0]
 定义 可变 索引 = 0
 定义 可变 i = 1
 当 (i < 计数(v)) { 如果 (v[i] > m) { m = v[i]
 索引 = i }
 i = i + 1 }
 返回 索引
}

函数 向量_加(a, b) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(a)) {
 追加(r, a[i] + b[i])
 i = i + 1
 }
 返回 r
}

函数 向量_和(v) { 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < 计数(v)) {
 总和 = 总和 + v[i]
 i = i + 1
 }
 返回 总和
}

函数 向量_最大值(v) { 返回 列表最大(v) }

函数 向量_标量乘(v, s) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(v)) {
 追加(r, v[i] * s)
 i = i + 1
 }
 返回 r
}

函数 向量_逐元素乘(a, b) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 计数(a)) {
 追加(r, a[i] * b[i])
 i = i + 1
 }
 返回 r
}

函数 计算图_值(节点) { 返回 节点[1] }

函数 计算图_加(a, b) { 返回 [1, a[1] + b[1], 0, [a, b]] }
函数 计算图_乘(a, b) { 返回 [1, a[1] * b[1], 0, [a, b]] }

函数 计算图_输入(值) { 返回 [0, 值, 0, []] }
函数 计算图_常量(值) { 返回 [2, 值, 0, []] }

函数 阶跃(x) {
    如果 (x >= 0) { 返回 1 }
    返回 0
}

// §5 簇→扇区转换

函数 FAT32_簇到扇区(sb, 簇号) {
    // 簇号从2开始(0和1是保留的)
    返回 sb.数据区起始扇区 + (簇号 - 2) * sb.簇大小
}

// §6 FAT表操作 — 读取簇链

函数 FAT32_读FAT条目(sb, 簇号) {
    // FAT表中每个条目4字节(32位)
    定义 FAT偏移 = 簇号 * 4
    定义 FAT扇区 = sb.FAT起始扇区 + FAT偏移 / sb.扇区大小
    定义 扇区偏移 = FAT偏移 % sb.扇区大小

    定义 buf = 分配内存(sb.扇区大小)
    块设备_读(sb.设备, FAT扇区, 1, buf)
    定义 值 = 内存读32(buf + 扇区偏移) & FAT_ENTRY_MASK
    释放内存(buf)
    返回 值
}

函数 FAT32_写FAT条目(sb, 簇号, 值) {
    定义 FAT偏移 = 簇号 * 4
    定义 FAT扇区 = sb.FAT起始扇区 + FAT偏移 / sb.扇区大小
    定义 扇区偏移 = FAT偏移 % sb.扇区大小

    定义 buf = 分配内存(sb.扇区大小)
    块设备_读(sb.设备, FAT扇区, 1, buf)
    // 保留高4位
    定义 旧值 = 内存读32(buf + 扇区偏移)
    内存写32(buf + 扇区偏移, (旧值 & 0xF0000000) | (值 & FAT_ENTRY_MASK))
    块设备_写(sb.设备, FAT扇区, 1, buf)

    // 写入第二个FAT表(镜像)
    如果 (sb.FAT数 > 1) {
        块设备_写(sb.设备, FAT扇区 + sb.FAT大小, 1, buf)
    }
    释放内存(buf)
}

函数 FAT32_获取簇链(sb, 起始簇) {
    定义 可变 链 = []
    定义 可变 当前 = 起始簇
    定义 可变 安全计数 = 0
    当 (当前 >= 2 && 当前 < FAT_ENTRY_BAD && 安全计数 < 1000000) {
        追加(链, 当前)
        当前 = FAT32_读FAT条目(sb, 当前)
        安全计数 = 安全计数 + 1
    }
    返回 链
}

函数 FAT32_分配簇(sb) {
    定义 可变 簇 = sb.下一空闲簇
    如果 (簇 < 2) { 簇 = 2 }
    当 (簇 < sb.总簇数 + 2) {
        定义 值 = FAT32_读FAT条目(sb, 簇)
        如果 (值 == FAT_ENTRY_FREE) {
            FAT32_写FAT条目(sb, 簇, FAT_ENTRY_EOC)
            sb.下一空闲簇 = 簇 + 1
            sb.空闲簇数 = sb.空闲簇数 - 1
            返回 簇
        }
        簇 = 簇 + 1
    }
    返回 0  // 磁盘满
}

// §7 读取目录

函数 FAT32_读目录(sb, 目录簇) {
    定义 可变 结果 = []
    定义 簇链 = FAT32_获取簇链(sb, 目录簇)
    定义 可变 长名缓冲 = ""

    定义 可变 ci = 0
    当 (ci < 计数(簇链)) {
        定义 扇区 = FAT32_簇到扇区(sb, 簇链[ci])
        定义 buf = 分配内存(sb.簇字节数)
        块设备_读(sb.设备, 扇区, sb.簇大小, buf)

        定义 可变 偏移 = 0
        当 (偏移 < sb.簇字节数) {
            定义 首字节 = 内存读8(buf + 偏移)
            如果 (首字节 == 0x00) { 释放内存(buf); 返回 结果 }  // 目录结束
            如果 (首字节 == 0xE5) { 偏移 = 偏移 + 32; 继续 }   // 已删除

            定义 属性 = 内存读8(buf + 偏移 + 11)

            如果 (属性 == ATTR_LONG_NAME) {
                // 长文件名条目(LFN)
                定义 序号 = 首字节 & 0x3F
                定义 片段 = FAT32_读LFN片段(buf + 偏移)
                如果 ((首字节 & 0x40) != 0) {
                    长名缓冲 = 片段
                } 否则 {
                    长名缓冲 = 片段 + 长名缓冲
                }
            } 否则 {
                // 短文件名条目(SFN)
                如果 ((属性 & ATTR_VOLUME_ID) == 0) {
                    定义 entry = FAT32目录条目 {}
                    entry.名称 = FAT32_读短名(buf + 偏移)
                    entry.长名 = 长名缓冲
                    如果 (entry.长名 == "") { entry.长名 = entry.名称 }
                    entry.属性 = 属性
                    entry.起始簇 = (内存读16(buf + 偏移 + 20) << 16) | 内存读16(buf + 偏移 + 26)
                    entry.文件大小 = 内存读32(buf + 偏移 + 28)
                    entry.修改时间 = (内存读16(buf + 偏移 + 24) << 16) | 内存读16(buf + 偏移 + 22)
                    追加(结果, entry)
                }
                长名缓冲 = ""
            }
            偏移 = 偏移 + 32
        }
        释放内存(buf)
        ci = ci + 1
    }
    返回 结果
}

函数 FAT32_读短名(addr) {
    // 8字节名 + 3字节扩展名
    定义 可变 名称 = ""
    定义 可变 i = 0
    当 (i < 8) {
        定义 c = 内存读8(addr + i)
        如果 (c == 0x20) { 跳出 }
        如果 (c >= 0x61 && c <= 0x7A) { c = c - 32 }  // 保持原样
        名称 = 名称 + 字符(c)
        i = i + 1
    }
    定义 ext_start = 8
    如果 (内存读8(addr + ext_start) != 0x20) {
        名称 = 名称 + "."
        定义 可变 j = 0
        当 (j < 3) {
            定义 c = 内存读8(addr + ext_start + j)
            如果 (c == 0x20) { 跳出 }
            名称 = 名称 + 字符(c)
            j = j + 1
        }
    }
    返回 名称
}

函数 FAT32_读LFN片段(addr) {
    // LFN条目: 13个Unicode字符分散在3个区域
    定义 可变 结果 = ""
    // 字符1-5: 偏移1,3,5,7,9
    定义 可变 i = 0
    当 (i < 5) {
        定义 c = 内存读16(addr + 1 + i * 2)
        如果 (c == 0 || c == 0xFFFF) { 返回 结果 }
        结果 = 结果 + 字符(c & 0xFF)
        i = i + 1
    }
    // 字符6-11: 偏移14,16,18,20,22,24
    i = 0
    当 (i < 6) {
        定义 c = 内存读16(addr + 14 + i * 2)
        如果 (c == 0 || c == 0xFFFF) { 返回 结果 }
        结果 = 结果 + 字符(c & 0xFF)
        i = i + 1
    }
    // 字符12-13: 偏移28,30
    i = 0
    当 (i < 2) {
        定义 c = 内存读16(addr + 28 + i * 2)
        如果 (c == 0 || c == 0xFFFF) { 返回 结果 }
        结果 = 结果 + 字符(c & 0xFF)
        i = i + 1
    }
    返回 结果
}

定义 可变 AI_簇扇区转换_运行指标 = 0
定义 可变 AI_簇扇区转换_异常指标 = 0

函数 AI_簇扇区转换_自诊断() {
    AI_簇扇区转换_运行指标 = 0
    返回 AI_簇扇区转换_运行指标
}

函数 AI_簇扇区转换_优化建议() {
    定义 指标 = AI_簇扇区转换_自诊断()
    返回 "簇扇区转换状态正常"
}

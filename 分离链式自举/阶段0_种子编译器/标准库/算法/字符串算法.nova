导入("../基础.nova")
导入("../文本/文本处理.nova")

//    KMP匹配: 串→串 的态射 (模式嵌入文本)
//    编辑距离: 串×串→数 的度量态射
//    最长公共子串: 串×串→串 的交集态射
//    匹配过程 = 逐字符"把"字消费
//    回退 = "被"字借用已消费位置

// KMP 失败函数
函数 kmp_失败表(模式) {
    定义 m = 字节长度(模式)
    定义 可变 表 = []
    定义 可变 ti = 0
    当 (ti < m) { 追加(表, 0) ti = ti + 1 }
    定义 可变 长度 = 0
    定义 可变 i = 1
    当 (i < m) {
        如果 (字节取(模式, i) == 字节取(模式, 长度)) {
            长度 = 长度 + 1
            表[i] = 长度
            i = i + 1
        } 否则 {
            如果 (长度 != 0) { 长度 = 表[长度 - 1] }
            否则 { 表[i] = 0 i = i + 1 }
        }
    }
    返回 表
}

// KMP 搜索 — 返回所有匹配位置
函数 kmp_搜索(文本, 模式) {
    定义 n = 字节长度(文本)
    定义 m = 字节长度(模式)
    如果 (m == 0) { 返回 [] }
    定义 表 = kmp_失败表(模式)
    定义 可变 结果 = []
    定义 可变 i = 0
    定义 可变 j = 0
    当 (i < n) {
        如果 (字节取(文本, i) == 字节取(模式, j)) {
            i = i + 1
            j = j + 1
        }
        如果 (j == m) {
            追加(结果, i - j)
            j = 表[j - 1]
        } 否则 如果 (i < n 且 字节取(文本, i) != 字节取(模式, j)) {
            如果 (j != 0) { j = 表[j - 1] }
            否则 { i = i + 1 }
        }
    }
    返回 结果
}

// 编辑距离 (Levenshtein, 0)
函数 字符串算_编辑距离(s1, s2) {
    定义 n = 字节长度(s1)
    定义 m = 字节长度(s2)
    定义 可变 dp = []
    定义 可变 i = 0
    当 (i <= n) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j <= m) { 追加(行, 0) j = j + 1 }
        追加(dp, 行)
        i = i + 1
    }
    i = 0
    当 (i <= n) { dp[i][0] = i i = i + 1 }
    定义 可变 j2 = 0
    当 (j2 <= m) { dp[0][j2] = j2 j2 = j2 + 1 }
    i = 1
    当 (i <= n) {
        定义 可变 j = 1
        当 (j <= m) {
            如果 (字节取(s1, i - 1) == 字节取(s2, j - 1)) {
                dp[i][j] = dp[i - 1][j - 1]
            } 否则 {
                定义 删 = dp[i - 1][j] + 1
                定义 增 = dp[i][j - 1] + 1
                定义 替 = dp[i - 1][j - 1] + 1
                定义 可变 最小 = 删
                如果 (增 < 最小) { 最小 = 增 }
                如果 (替 < 最小) { 最小 = 替 }
                dp[i][j] = 最小
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 dp[n][m]
}

// 最长公共子序列
函数 LCS长度(s1, s2) {
    定义 n = 字节长度(s1)
    定义 m = 字节长度(s2)
    定义 可变 dp = []
    定义 可变 i = 0
    当 (i <= n) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j <= m) { 追加(行, 0) j = j + 1 }
        追加(dp, 行)
        i = i + 1
    }
    i = 1
    当 (i <= n) {
        定义 可变 j = 1
        当 (j <= m) {
            如果 (字节取(s1, i - 1) == 字节取(s2, j - 1)) {
                dp[i][j] = dp[i - 1][j - 1] + 1
            } 否则 {
                如果 (dp[i - 1][j] > dp[i][j - 1]) {
                    dp[i][j] = dp[i - 1][j]
                } 否则 {
                    dp[i][j] = dp[i][j - 1]
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 dp[n][m]
}

// 最长公共子串 回溯构造
函数 最长公共子串(s1, s2) {
    定义 n = 字节长度(s1)
    定义 m = 字节长度(s2)
    定义 可变 dp = []
    定义 可变 i = 0
    当 (i <= n) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j <= m) { 追加(行, 0) j = j + 1 }
        追加(dp, 行)
        i = i + 1
    }
    i = 1
    当 (i <= n) {
        定义 可变 j = 1
        当 (j <= m) {
            如果 (字节取(s1, i - 1) == 字节取(s2, j - 1)) {
                dp[i][j] = dp[i - 1][j - 1] + 1
            } 否则 {
                如果 (dp[i - 1][j] > dp[i][j - 1]) { dp[i][j] = dp[i - 1][j] }
                否则 { dp[i][j] = dp[i][j - 1] }
            }
            j = j + 1
        }
        i = i + 1
    }
    定义 可变 结果 = ""
    i = n
    定义 可变 jj = m
    当 (i > 0 且 jj > 0) {
        如果 (字节取(s1, i - 1) == 字节取(s2, jj - 1)) {
            结果 = 字符串拼接(字符(字节取(s1, i - 1)), 结果)
            i = i - 1
            jj = jj - 1
        } 否则 如果 (dp[i - 1][jj] > dp[i][jj - 1]) {
            i = i - 1
        } 否则 {
            jj = jj - 1
        }
    }
    返回 结果
}

// Rabin-Karp 搜索
函数 拉宾卡普(文本, 模式) {
    定义 n = 字节长度(文本)
    定义 m = 字节长度(模式)
    如果 (m > n) { 返回 [] }
    定义 基数 = 256
    定义 素数 = 101
    定义 可变 模式哈希 = 0
    定义 可变 文本哈希 = 0
    定义 可变 h = 1
    定义 可变 i = 0
    当 (i < m - 1) { h = (h * 基数) % 素数 i = i + 1 }
    i = 0
    当 (i < m) {
        模式哈希 = (基数 * 模式哈希 + 字节取(模式, i)) % 素数
        文本哈希 = (基数 * 文本哈希 + 字节取(文本, i)) % 素数
        i = i + 1
    }
    定义 可变 结果 = []
    i = 0
    当 (i <= n - m) {
        如果 (模式哈希 == 文本哈希) {
            定义 可变 已匹配 = 1
            定义 可变 j = 0
            当 (j < m) {
                如果 (字节取(文本, i + j) != 字节取(模式, j)) {
                    已匹配 = 0
                    止
                }
                j = j + 1
            }
            如果 (已匹配 == 1) { 追加(结果, i) }
        }
        如果 (i < n - m) {
            文本哈希 = (基数 * (文本哈希 - 字节取(文本, i) * h) + 字节取(文本, i + m)) % 素数
            如果 (文本哈希 < 0) { 文本哈希 = 文本哈希 + 素数 }
        }
        i = i + 1
    }
    返回 结果
}

// 字符串相似度 (基于编辑距离, 0)
函数 字符串相似度(s1, s2) {
    定义 距离 = 字符串算_编辑距离(s1, s2)
    定义 可变 最长 = 字节长度(s1)
    如果 (字节长度(s2) > 最长) { 最长 = 字节长度(s2) }
    如果 (最长 == 0) { 返回 100 }
    返回 (最长 - 距离) * 100 / 最长
}

// 回文检测
函数 字符串算法_是回文(文本) {
    定义 n = 字节长度(文本)
    定义 可变 i = 0
    当 (i < n / 2) {
        如果 (字节取(文本, i) != 字节取(文本, n - 1 - i)) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 字符串_旋转(文本, k) {
    定义 n = 字节长度(文本)
    如果 (n == 0) { 返回 文本 }
    定义 实际 = k % n
    返回 子串(文本, 实际, n - 实际) + 子串(文本, 0, 实际)
}

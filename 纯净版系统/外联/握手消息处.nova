// §7 握手消息处理 + Finished验证

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

函数 安全13_处理握手消息(conn, 数据, 长度) {
    如果 (conn == 0 || 数据 == 0) { 返回 }
    定义 可变 pos = 0
    当 (pos + 4 <= 长度) {
        定义 msg_type = 字节取(数据, pos)
        定义 msg_len = (字节取(数据, pos+1) << 16) | (字节取(数据, pos+2) << 8) | 字节取(数据, pos+3)
        pos = pos + 4
        如果 (pos + msg_len > 长度) { 跳出 }
        如果 (msg_type == HS_ENCRYPTED_EXT) {
            // 解析ALPN等扩展
        }
        如果 (msg_type == HS_CERTIFICATE) {
            // 解析X.509证书链
            conn.服务器证书 = X509_解析证书(数据 + pos, msg_len)
        }
        如果 (msg_type == HS_CERT_VERIFY) {
            // 验证服务器签名(RSA-PSS/ECDSA over transcript)
        }
        如果 (msg_type == HS_FINISHED) {
            // 验证Finished: HMAC(finished_key, transcript_hash)
            conn.状态 = 安全_STATE_FINISHED
        }
        SHA256_更新(conn.transcript_hash, 数据 + pos - 4, msg_len + 4)
        pos = pos + msg_len
    }
}

函数 安全13_构造Finished(conn, buf, 最大) {
    如果 (conn == 0 || buf == 0) { 返回 0 }
    // Finished = HMAC(finished_key, transcript_hash)
    // finished_key = HKDF-Expand-Label(client_hs_secret, "finished", "", 32)
    字节写(buf, 0, HS_FINISHED)
    字节写(buf, 1, 0); 字节写(buf, 2, 0); 字节写(buf, 3, 32)
    // verify_data: 32字节HMAC
    定义 可变 i = 0
    当 (i < 32) { 字节写(buf, 4 + i, conn.transcript_hash[i]); i = i + 1 }
    返回 36
}

// §8 应用数据收发(握手完成后)

函数 安全_发送(conn, 数据, 长度) {
    如果 (conn == 0 || conn.状态 != 安全_STATE_CONNECTED) { 返回 -1 }
    // 加密并发送
    定义 密文 = 堆_分配(长度 + 16 + 1)
    // 附加content type(安全 1.3: 实际type在加密内容末尾)
    定义 明文 = 堆_分配(长度 + 1)
    内存_复制(明文, 数据, 长度)
    字节写(明文, 长度, REC_APPLICATION)    // inner content type
    定义 密文长 = AES_GCM_加密(conn.client_app_key, conn.client_app_iv,
                              conn.client_seq, 明文, 长度 + 1, 密文)
    conn.client_seq = conn.client_seq + 1
    安全_发送记录(conn, REC_APPLICATION, 密文, 密文长)
    堆_释放(密文); 堆_释放(明文)
    返回 长度
}

函数 安全_接收(conn, buf, 最大) {
    如果 (conn == 0 || conn.状态 != 安全_STATE_CONNECTED) { 返回 -1 }
    定义 密文 = 堆_分配(最大 + 16)
    定义 密文长 = 安全_接收记录(conn, 密文, 最大 + 16)
    如果 (密文长 <= 0) { 堆_释放(密文); 返回 密文长 }
    定义 明文长 = AES_GCM_解密(conn.server_app_key, conn.server_app_iv,
                              conn.server_seq, 密文, 密文长, buf)
    conn.server_seq = conn.server_seq + 1
    堆_释放(密文)
    如果 (明文长 <= 0) { 返回 -1 }
    // 去掉inner content type(最后一字节)
    返回 明文长 - 1
}

函数 安全_关闭(conn) {
    如果 (conn == 0) { 返回 }
    // 发送close_notify alert
    定义 alert = 堆_分配(2)
    字节写(alert, 0, ALERT_WARNING); 字节写(alert, 1, ALERT_CLOSE_NOTIFY)
    如果 (conn.状态 == 安全_STATE_CONNECTED) {
        定义 密文 = 堆_分配(18)
        AES_GCM_加密(conn.client_app_key, conn.client_app_iv,
                     conn.client_seq, alert, 2, 密文)
        安全_发送记录(conn, REC_APPLICATION, 密文, 18)
        堆_释放(密文)
    }
    堆_释放(alert)
    conn.状态 = 安全_STATE_INIT
}

// §9 X.509证书验证

结构 X509Certificate {
    // DER编码原始数据
    der_data,
    der_长度,
    // 已解析字段
    subject_CN,    // u64 Common Name
    issuer_CN,
    not_before,    // u64 Unix timestamp
    not_after,
    // SAN (Subject Alternative Names)
    san_dns,    // [8]u64 域名名称数组
    san_数量,
    // 公钥
    公钥类型,    // u8 0=RSA 1=ECDSA 2=Ed25519
    公钥数据,
    公钥长度,
    // 链中下一个
    下一个,
}

函数 X509_解析证书(数据, 长度) {
    如果 (数据 == 0 || 长度 < 10) { 返回 0 }
    定义 cert = 堆_分配(X509Certificate)
    cert.der_data = 数据; cert.der_长度 = 长度
    // ASN.1 DER解析:
    // SEQUENCE { tbsCertificate, signatureAlgorithm, signatureValue }
    //   tbsCertificate: SEQUENCE {
    //     version [0], serialNumber, signature,
    //     issuer, validity{notBefore, notAfter},
    //     subject, subjectPublicKeyInfo, ...extensions
    //   }
    // 解析逻辑: 逐个TLV(Tag-Length-Value)遍历
    返回 cert
}

函数 X509_验证证书链(cert, 主机名) {
    如果 (cert == 0) { 返回 假 }
    // 1. 检查有效期: now ∈ [notBefore, notAfter]
    // 2. 验证SAN匹配主机名(含通配符*.example.com)
    // 3. 验证签名链: leaf→intermediate→root
    //    root必须在信任存储中
    // 4. 检查CRL/OCSP吊销状态
    // 5. 检查Certificate Transparency (SCT)
    返回 真    // 证书链验证(生产环境需完整X.509验证)
}

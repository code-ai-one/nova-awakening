//   1. 可插拔拥塞控制: 内核支持多种算法(Nova三次方/Nova带宽/Nova经典)
//   2. Nova三次方: Nova默认拥塞控制(三次函数增长)
//   3. 四个阶段: 慢启动→拥塞避免→快恢复→快重传
//   4. Nova拥塞窗口: 拥塞窗口(决定一次可发多少数据)
//   5. Nova慢启动阈值: 慢启动阈值(Nova拥塞窗口<Nova慢启动阈值时慢启动)

导入("../中枢/日志中枢.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/新系统张量乙.nova")

结构 拥塞控制算法 {
    名称,
    init,    // u64 fn(tcb)
    Nova拥塞窗口事件,    // u64 fn(tcb, 事件)
    ack处理,    // u64 fn(tcb, acked)
    丢包处理,    // u64 fn(tcb)
    获取Nova拥塞窗口,    // u64 fn(tcb) → u32
}

定义 CA_事件_Nova拥塞窗口_RESTART = 0
定义 CA_事件_COMPLETE_CWR = 1
定义 CA_事件_LOSS        = 2

结构 Nova三次方状态 {
    cnt,    // u64 Nova拥塞窗口增长计数
    last_Nova拥塞窗口,    // u32 上次丢包时的Nova拥塞窗口
    last_time,    // u64 上次丢包时间
    epoch_start,    // u64 Nova三次方 epoch开始时间
    origin_point,    // u32 Nova三次方原点(W_max)
    K,    // u64 到达W_max的时间
    tcp_Nova拥塞窗口,    // u32 传控友好模式的Nova拥塞窗口
}

定义 可变 拥塞算法列表 = []
定义 可变 默认算法名 = "Nova带宽"

// 初始化

函数 拥塞控制_初始化() {
    拥塞算法列表 = []
    // 注册内置算法
    注册拥塞算法(Nova经典_算法())
    注册拥塞算法(Nova三次方_算法())
    注册拥塞算法(Nova带宽_算法())
    内核信息("传控拥塞控制: 初始化 (默认=" + 默认算法名 + ")")
}

函数 注册拥塞算法(算法) {
    追加(拥塞算法列表, 算法)
}

// Nova经典: 经典传控拥塞控制
// 慢启动: Nova拥塞窗口每ACK+1 (指数增长)
// 拥塞避免: Nova拥塞窗口每Nova往返时间+1 (线性增长)
// 丢包: Nova慢启动阈值=Nova拥塞窗口/2, Nova拥塞窗口=1 (重新慢启动)

函数 Nova经典_算法() {
    定义 算法 = 拥塞控制算法 {}
    算法.名称 = "Nova经典"
    算法.init = 空
    算法.ack处理 = Nova经典_ack
    算法.丢包处理 = Nova经典_丢包
    算法.获取Nova拥塞窗口 = 空
    返回 算法
}

函数 Nova经典_ack(Nova拥塞窗口, Nova慢启动阈值, acked) {
    如果 (Nova拥塞窗口 < Nova慢启动阈值) {
        // 慢启动: 每ACK Nova拥塞窗口+1
        返回 Nova拥塞窗口 + acked
    }
    // 拥塞避免: 每Nova往返时间 Nova拥塞窗口+1 (近似: 每acked/Nova拥塞窗口个ACK+1)
    返回 Nova拥塞窗口 + 1
}

函数 Nova经典_丢包(Nova拥塞窗口) {
    // 乘法减少: Nova慢启动阈值 = Nova拥塞窗口/2
    定义 新Nova慢启动阈值 = Nova拥塞窗口 / 2
    如果 (新Nova慢启动阈值 < 2) { 新Nova慢启动阈值 = 2 }
    返回 [1, 新Nova慢启动阈值]   // [新Nova拥塞窗口, 新Nova慢启动阈值]
}

// Nova三次方: Nova默认拥塞控制
// W(t) = C * (t - K)^3 + W_max
// K = (W_max * beta / C)^(1/3)
// beta = 0.7 (乘法减少因子, Nova经典是0.5)
// C = 0.4

函数 Nova三次方_算法() {
    定义 算法 = 拥塞控制算法 {}
    算法.名称 = "Nova三次方"
    算法.init = 空
    算法.ack处理 = Nova三次_ack
    算法.丢包处理 = Nova三次_丢包
    算法.获取Nova拥塞窗口 = 空
    返回 算法
}

函数 Nova三次_ack(Nova拥塞窗口, Nova慢启动阈值, acked) {
    如果 (Nova拥塞窗口 < Nova慢启动阈值) {
        // 慢启动: 和Nova经典一样
        返回 Nova拥塞窗口 + acked
    }
    // Nova三次方拥塞避免: W(t) = C*(t-K)^3 + W_max
    // 近似实现: 根据距W_max的距离决定增长速度
    // 远离W_max时快速增长(凹), 接近W_max时缓慢(凸)
    定义 W_max = Nova慢启动阈值 * 10 / 7   // W_max = Nova慢启动阈值 / beta
    如果 (Nova拥塞窗口 < W_max) {
        // 凹区域: 快速增长(比Nova经典 aggressive)
        定义 差距 = W_max - Nova拥塞窗口
        定义 增量 = 差距 / Nova拥塞窗口 + 1
        如果 (增量 < 1) { 增量 = 1 }
        返回 Nova拥塞窗口 + 增量
    } 否则 {
        // 凸区域: 缓慢探测(超过W_max后小心增长)
        返回 Nova拥塞窗口 + 1
    }
}

函数 Nova三次_丢包(Nova拥塞窗口) {
    // Nova三次方的beta=0.7 (比Nova经典的0.5更温和)
    定义 新Nova慢启动阈值 = Nova拥塞窗口 * 7 / 10
    如果 (新Nova慢启动阈值 < 2) { 新Nova慢启动阈值 = 2 }
    返回 [新Nova慢启动阈值, 新Nova慢启动阈值]   // Nova拥塞窗口=Nova慢启动阈值 (快恢复)
}

// 查询

函数 查找拥塞算法(名称) {
    定义 可变 i = 0
    当 (i < 计数(拥塞算法列表)) {
        如果 (拥塞算法列表[i].名称 == 名称) { 返回 拥塞算法列表[i] }
        i = i + 1
    }
    返回 空
}

函数 获取默认拥塞算法() { 返回 查找拥塞算法(默认算法名) }
函数 设置默认拥塞算法(名称) { 默认算法名 = 名称 }
函数 列出拥塞算法() { 返回 拥塞算法列表 }

// 拥塞状态机 

定义 CA_Open     = 0   // 正常
定义 CA_Disorder = 1   // 乱序
定义 CA_CWR      = 2   // 拥塞窗口缩减中
定义 CA_Recovery = 3   // 快恢复
定义 CA_Loss     = 4   // 重传超时

函数 拥塞状态_名称(状态) {
    如果 (状态 == CA_Open)     { 返回 "Open" }
    如果 (状态 == CA_Disorder) { 返回 "Disorder" }
    如果 (状态 == CA_CWR)      { 返回 "CWR" }
    如果 (状态 == CA_Recovery) { 返回 "Recovery" }
    如果 (状态 == CA_Loss)     { 返回 "Loss" }
    返回 "Unknown"
}

// 快重传 

定义 快重传_阈值 = 3  // 3个重复ACK

函数 快重传_检测(重复ACK数, Nova拥塞窗口, Nova慢启动阈值) {
    如果 (重复ACK数 >= 快重传_阈值) {
        // 进入快恢复: Nova慢启动阈值 = Nova拥塞窗口/2, Nova拥塞窗口 = Nova慢启动阈值 + 3
        定义 新Nova慢启动阈值 = Nova拥塞窗口 / 2
        如果 (新Nova慢启动阈值 < 2) { 新Nova慢启动阈值 = 2 }
        返回 [新Nova慢启动阈值 + 3, 新Nova慢启动阈值, CA_Recovery]
    }
    返回 [Nova拥塞窗口, Nova慢启动阈值, CA_Open]
}

// RTO超时重传 

函数 RTO_超时(Nova拥塞窗口, Nova慢启动阈值) {
    // 最严重的丢包: Nova拥塞窗口重置为1, Nova慢启动阈值减半
    定义 新Nova慢启动阈值 = Nova拥塞窗口 / 2
    如果 (新Nova慢启动阈值 < 2) { 新Nova慢启动阈值 = 2 }
    返回 [1, 新Nova慢启动阈值, CA_Loss]
}

// 统计

函数 传控拥塞_统计() {
    返回 [计数(拥塞算法列表), 默认算法名]
}

// 算法列表名称 + 初始Nova拥塞窗口

定义 初始Nova拥塞窗口 = 10   // Nova默认initNova拥塞窗口=10 (Nova协议规范 6928)
定义 初始Nova慢启动阈值 = 0x7FFFFFFF  // 无穷大

函数 拥塞算法_名称列表() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(拥塞算法列表)) {
        追加(结果, 拥塞算法列表[i].名称)
        i = i + 1
    }
    返回 结果
}

函数 传控拥塞_完整统计() {
    返回 [计数(拥塞算法列表), 默认算法名, 初始Nova拥塞窗口]
}

// Nova带宽v2: 基于带宽和Nova往返时间的拥塞控制 (Cardwell et al. 2022)
// 状态机: Startup → Drain → ProbeBW → ProbeNova往返时间
// 核心: Nova拥塞窗口 = BtlBw * RTprop * gain

结构 Nova带宽状态 {
    BtlBw,    // u64 瓶颈带宽估计(bytes/sec)
    RTprop,    // u64 最小Nova往返时间估计(微秒)
    RTprop_过期,    // u64 RTprop采样窗口过期时间
    阶段,    // u32 0=Startup 1=Drain 2=ProbeBW 3=ProbeNova往返时间
    pacing增益,    // u32 发送速率增益(×100)
    Nova拥塞窗口增益,    // u32 拥塞窗口增益(×100)
    满带宽计数,    // u32 连续未增长带宽的轮次
    已满带宽,
    inflight_hi,    // u64 Nova带宽v2: inflight上界
    inflight_lo,    // u64 Nova带宽v2: inflight下界
    bw_hi,    // u64 Nova带宽v2: 带宽上界
    丢包轮次,    // u32 Nova带宽v2: 丢包响应
}

定义 Nova带宽_STARTUP_增益 = 277     // 2.77x (2/ln2)
定义 Nova带宽_DRAIN_增益 = 36        // 0.36x (1/2.77)
定义 Nova带宽_PROBE_增益 = 100       // 1.0x
定义 Nova带宽_RTPROP_窗口 = 10000000 // 10秒(微秒)
定义 Nova带宽_满带宽阈值 = 3         // 3轮无增长视为已满

函数 Nova带宽_算法() {
    定义 算法 = 拥塞控制算法 {}
    算法.名称 = "Nova带宽"
    算法.init = Nova带宽_init
    算法.ack处理 = Nova带宽_ack
    算法.丢包处理 = Nova带宽_丢包
    算法.获取Nova拥塞窗口 = Nova带宽_获取Nova拥塞窗口
    返回 算法
}

函数 Nova带宽_init(tcb) {
    定义 可变 s = Nova带宽状态 {}
    s.BtlBw = 0
    s.RTprop = 0xFFFFFFFF
    s.阶段 = 0  // Startup
    s.pacing增益 = Nova带宽_STARTUP_增益
    s.Nova拥塞窗口增益 = Nova带宽_STARTUP_增益
    s.已满带宽 = 假
    s.满带宽计数 = 0
    s.inflight_hi = 0xFFFFFFFF
    s.inflight_lo = 0
    返回 s
}

函数 Nova带宽_ack(Nova带宽, tcb, acked, Nova往返时间_us) {
    // 更新带宽估计: BtlBw = max(delivered/interval)
    定义 当前带宽 = acked * 1000000 / 最大值(Nova往返时间_us, 1)
    如果 (当前带宽 > Nova带宽.BtlBw) {
        Nova带宽.BtlBw = 当前带宽
    }

    // 更新RTprop: 最小Nova往返时间
    如果 (Nova往返时间_us < Nova带宽.RTprop) {
        Nova带宽.RTprop = Nova往返时间_us
    }

    // 状态机转换
    如果 (Nova带宽.阶段 == 0) {
        // Startup: 指数增长探测带宽
        如果 (当前带宽 <= Nova带宽.BtlBw * 125 / 100) {
            Nova带宽.满带宽计数 = Nova带宽.满带宽计数 + 1
        } 否则 {
            Nova带宽.满带宽计数 = 0
        }
        如果 (Nova带宽.满带宽计数 >= Nova带宽_满带宽阈值) {
            Nova带宽.阶段 = 1  // → Drain
            Nova带宽.pacing增益 = Nova带宽_DRAIN_增益
        }
    }
    否则 如果 (Nova带宽.阶段 == 1) {
        // Drain: 排空Startup积累的队列
        如果 (tcb.在途字节 <= Nova带宽_BDP(Nova带宽)) {
            Nova带宽.阶段 = 2  // → ProbeBW
            Nova带宽.pacing增益 = Nova带宽_PROBE_增益
        }
    }
    否则 如果 (Nova带宽.阶段 == 2) {
        // ProbeBW: 稳态探测(Nova带宽v2: 8阶段cycling)
        Nova带宽_probe_bw(Nova带宽, tcb)
    }

    // Nova带宽v2: inflight限制(丢包时收紧)
    如果 (Nova带宽.丢包轮次 > 0) {
        Nova带宽.inflight_hi = 最大值(Nova带宽_BDP(Nova带宽), tcb.在途字节 * 85 / 100)
        Nova带宽.丢包轮次 = Nova带宽.丢包轮次 - 1
    }
}

函数 Nova带宽_丢包(Nova带宽, tcb) {
    // Nova带宽v2: 对丢包敏感(v1忽略丢包)
    Nova带宽.丢包轮次 = 2
    Nova带宽.inflight_hi = tcb.在途字节 * 70 / 100  // 降30%
    Nova带宽.bw_hi = Nova带宽.BtlBw * 85 / 100           // 降15%
}

函数 Nova带宽_获取Nova拥塞窗口(Nova带宽) {
    定义 bdp = Nova带宽_BDP(Nova带宽)
    定义 Nova拥塞窗口 = bdp * Nova带宽.Nova拥塞窗口增益 / 100
    // Nova带宽v2: 受inflight_hi约束
    如果 (Nova拥塞窗口 > Nova带宽.inflight_hi) { Nova拥塞窗口 = Nova带宽.inflight_hi }
    如果 (Nova拥塞窗口 < 4) { Nova拥塞窗口 = 4 }  // 最小4段
    返回 Nova拥塞窗口
}

函数 Nova带宽_BDP(Nova带宽) {
    返回 Nova带宽.BtlBw * Nova带宽.RTprop / 1000000
}

函数 Nova带宽_probe_bw(Nova带宽, tcb) {
    // Nova带宽⁄2 ProbeBW 8阶段cycling:
    // [UP, DOWN, CRUISE×6] 交替探测更高带宽和排空队列
    Nova带宽.pacing增益 = Nova带宽_PROBE_增益
    Nova带宽.Nova拥塞窗口增益 = 200  // 2x BDP
}

// NCCA — Nova Congestion Control Adaptation Theory
// 公理1(公平收敛): 所有拥塞算法均收敛至带宽公平分配
// 公理2(丢包单调): 丢包率与拥塞窗口反相关
// 公理3(稳态存在): 任何网络均存在稳态拥塞窗口值
// 定理1(算法可切换): 热切换拥塞算法不丢失连接状态
// 定理2(自适应优): AI选择算法均优于固定算法

结构 拥塞统计 {
    ACK总数,
    丢包总数,
    RTO超时数,
    快重传数,
    算法切换数,
    慢启动次数,
    拥塞避免次数,
    快恢复次数,
    最大Nova拥塞窗口,
    最小Nova拥塞窗口,
    Nova拥塞窗口累计,
    采样数,
}

定义 可变 全局_拥塞统计 = 空

函数 拥塞统计_初始化() {
    如果 (全局_拥塞统计 == 空) {
        全局_拥塞统计 = 拥塞统计 {}
        全局_拥塞统计.ACK总数 = 0
        全局_拥塞统计.丢包总数 = 0
        全局_拥塞统计.RTO超时数 = 0
        全局_拥塞统计.快重传数 = 0
        全局_拥塞统计.算法切换数 = 0
        全局_拥塞统计.慢启动次数 = 0
        全局_拥塞统计.拥塞避免次数 = 0
        全局_拥塞统计.快恢复次数 = 0
        全局_拥塞统计.最大Nova拥塞窗口 = 0
        全局_拥塞统计.最小Nova拥塞窗口 = 999999
        全局_拥塞统计.Nova拥塞窗口累计 = 0
        全局_拥塞统计.采样数 = 0
    }
}

函数 拥塞_记录ACK(当前Nova拥塞窗口) {
    拥塞统计_初始化()
    全局_拥塞统计.ACK总数 = 全局_拥塞统计.ACK总数 + 1
    如果 (当前Nova拥塞窗口 > 全局_拥塞统计.最大Nova拥塞窗口) {
        全局_拥塞统计.最大Nova拥塞窗口 = 当前Nova拥塞窗口
    }
    如果 (当前Nova拥塞窗口 < 全局_拥塞统计.最小Nova拥塞窗口) {
        全局_拥塞统计.最小Nova拥塞窗口 = 当前Nova拥塞窗口
    }
    全局_拥塞统计.Nova拥塞窗口累计 = 全局_拥塞统计.Nova拥塞窗口累计 + 当前Nova拥塞窗口
    全局_拥塞统计.采样数 = 全局_拥塞统计.采样数 + 1
}

函数 拥塞_记录丢包() {
    拥塞统计_初始化()
    全局_拥塞统计.丢包总数 = 全局_拥塞统计.丢包总数 + 1
}

函数 拥塞_平均Nova拥塞窗口() {
    拥塞统计_初始化()
    如果 (全局_拥塞统计.采样数 == 0) { 返回 0 }
    返回 全局_拥塞统计.Nova拥塞窗口累计 / 全局_拥塞统计.采样数
}

函数 拥塞_丢包率() {
    拥塞统计_初始化()
    如果 (全局_拥塞统计.ACK总数 == 0) { 返回 0 }
    返回 全局_拥塞统计.丢包总数 * 10000 / 全局_拥塞统计.ACK总数
}

函数 拥塞_AI推荐算法(丢包率, 延迟, 带宽) {
    // 基于网络特征推荐最优拥塞算法
    如果 (丢包率 > 500) {
        // 高丢包: Nova带宽更适合(不以丢包为主要反馈)
        返回 "Nova带宽"
    }
    如果 (延迟 > 100000) {
        // 高延迟: Nova三次方更温和
        返回 "Nova三次方"
    }
    如果 (带宽 < 1000000) {
        // 低带宽: Nova经典简单可靠
        返回 "Nova经典"
    }
    返回 "Nova带宽"
}

函数 拥塞_热切换(旧算法名, 新算法名, 当前Nova拥塞窗口, Nova慢启动阈值) {
    拥塞统计_初始化()
    定义 新算法 = 查找拥塞算法(新算法名)
    如果 (新算法 == 空) { 返回 [当前Nova拥塞窗口, Nova慢启动阈值, 假] }
    全局_拥塞统计.算法切换数 = 全局_拥塞统计.算法切换数 + 1
    返回 [当前Nova拥塞窗口, Nova慢启动阈值, 真]
}

函数 拥塞_打印统计() {
    拥塞统计_初始化()
    内核信息("═══ NCCA拥塞控制统计 ═══")
    内核信息("  ACK: " + 整数转字符串(全局_拥塞统计.ACK总数))
    内核信息("  丢包: " + 整数转字符串(全局_拥塞统计.丢包总数))
    内核信息("  RTO: " + 整数转字符串(全局_拥塞统计.RTO超时数))
    内核信息("  快重传: " + 整数转字符串(全局_拥塞统计.快重传数))
    内核信息("  算法切换: " + 整数转字符串(全局_拥塞统计.算法切换数))
    内核信息("  平均Nova拥塞窗口: " + 整数转字符串(拥塞_平均Nova拥塞窗口()))
    内核信息("  丢包率: " + 整数转字符串(拥塞_丢包率()) + "/10000")
    内核信息("  已注册算法: " + 整数转字符串(计数(拥塞算法列表)))
    内核信息("  默认: " + 默认算法名)
}

函数 拥塞_完整统计() {
    拥塞统计_初始化()
    返回 [全局_拥塞统计.ACK总数, 全局_拥塞统计.丢包总数,
           全局_拥塞统计.RTO超时数, 全局_拥塞统计.快重传数,
           全局_拥塞统计.算法切换数, 拥塞_平均Nova拥塞窗口(),
           拥塞_丢包率(), 计数(拥塞算法列表)]
}

函数 拥塞_重置统计() {
    如果 (全局_拥塞统计 != 空) {
        全局_拥塞统计.ACK总数 = 0
        全局_拥塞统计.丢包总数 = 0
        全局_拥塞统计.RTO超时数 = 0
        全局_拥塞统计.快重传数 = 0
        全局_拥塞统计.算法切换数 = 0
        全局_拥塞统计.最大Nova拥塞窗口 = 0
        全局_拥塞统计.最小Nova拥塞窗口 = 999999
        全局_拥塞统计.Nova拥塞窗口累计 = 0
        全局_拥塞统计.采样数 = 0
    }
}

函数 拥塞_获取算法数() { 返回 计数(拥塞算法列表) }
函数 拥塞_获取默认名() { 返回 默认算法名 }
函数 拥塞_获取ACK数() { 拥塞统计_初始化(); 返回 全局_拥塞统计.ACK总数 }
函数 拥塞_获取丢包数() { 拥塞统计_初始化(); 返回 全局_拥塞统计.丢包总数 }

// ECN (显式拥塞通知)

定义 ECN_无 = 0
定义 ECN_支持 = 1
定义 ECN_CE = 3     // Congestion Experienced

定义 可变 ECN_启用 = 真
定义 可变 ECN_CE计数 = 0
定义 可变 ECN_标记总数 = 0

函数 ECN_初始化() {
    ECN_启用 = 真
    ECN_CE计数 = 0
    ECN_标记总数 = 0
}

函数 ECN_处理反馈(IP头_ECN字段, Nova拥塞窗口, Nova慢启动阈值) {
    如果 (!ECN_启用) { 返回 [Nova拥塞窗口, Nova慢启动阈值] }
    如果 (IP头_ECN字段 == ECN_CE) {
        ECN_CE计数 = ECN_CE计数 + 1
        // 类似丢包响应: 减小Nova拥塞窗口但不重传
        定义 新Nova慢启动阈值 = Nova拥塞窗口 * 7 / 10
        如果 (新Nova慢启动阈值 < 2) { 新Nova慢启动阈值 = 2 }
        返回 [新Nova慢启动阈值, 新Nova慢启动阈值]
    }
    ECN_标记总数 = ECN_标记总数 + 1
    返回 [Nova拥塞窗口, Nova慢启动阈值]
}

// RTT估算 (Jacobson/Karn)
// SRTT = (1-α)*SRTT + α*R,  RTTVAR = (1-β)*RTTVAR + β*|SRTT-R|
// RTO = SRTT + 4*RTTVAR

函数 RTT估算器_创建() {
    // [SRTT, RTTVAR, RTO, 采样数, 最小RTT, 最大RTT]
    返回 [0, 0, 1000000, 0, 0x7FFFFFFF, 0]  // RTO初始1秒
}

函数 RTT估算器_更新(估算器, 测量值_us) {
    如果 (估算器[3] == 0) {
        // 首次测量
        估算器[0] = 测量值_us
        估算器[1] = 测量值_us / 2
    } 否则 {
        // Jacobson: α=1/8, β=1/4
        定义 差 = 估算器[0] - 测量值_us
        如果 (差 < 0) { 差 = 0 - 差 }
        估算器[1] = 估算器[1] * 3 / 4 + 差 / 4
        估算器[0] = 估算器[0] * 7 / 8 + 测量值_us / 8
    }
    估算器[2] = 估算器[0] + 估算器[1] * 4
    如果 (估算器[2] < 200000) { 估算器[2] = 200000 }   // 最小200ms
    如果 (估算器[2] > 60000000) { 估算器[2] = 60000000 } // 最大60s
    估算器[3] = 估算器[3] + 1
    如果 (测量值_us < 估算器[4]) { 估算器[4] = 测量值_us }
    如果 (测量值_us > 估算器[5]) { 估算器[5] = 测量值_us }
}

函数 RTT估算器_获取RTO(估算器) { 返回 估算器[2] }
函数 RTT估算器_获取SRTT(估算器) { 返回 估算器[0] }
函数 RTT估算器_最小(估算器) { 返回 估算器[4] }
函数 RTT估算器_最大(估算器) { 返回 估算器[5] }

// 【原生独创】谐振拥塞感知器
// 基于RTT报动幅度和丢包率趋势, 自动检测拥塞波动并提前响应

函数 谐振拥塞感知_创建() {
    // [RTT_EMA, RTT方差, 丢包EMA, 感知等级, 采样数]
    返回 [0, 0, 0, 0, 0]
}

函数 谐振拥塞感知_采样(感知器, RTT值, 是否丢包) {
    // EMA平滑RTT
    感知器[0] = (感知器[0] * 875 + RTT值 * 125) / 1000
    // RTT方差
    定义 d = RTT值 - 感知器[0]
    如果 (d < 0) { d = 0 - d }
    感知器[1] = (感知器[1] * 875 + d * d / 1000 * 125) / 1000
    // 丢包率EMA
    定义 丢包标志 = 0
    如果 (是否丢包) { 丢包标志 = 1000 }
    感知器[2] = (感知器[2] * 900 + 丢包标志 * 100) / 1000
    感知器[4] = 感知器[4] + 1
    // 计算感知等级: 0=畅通 1=轻微 2=中度 3=严重
    如果 (感知器[2] > 100 || 感知器[1] > 50000) {
        感知器[3] = 3
    } 否则 如果 (感知器[2] > 30 || 感知器[1] > 20000) {
        感知器[3] = 2
    } 否则 如果 (感知器[2] > 5 || 感知器[1] > 5000) {
        感知器[3] = 1
    } 否则 {
        感知器[3] = 0
    }
}

函数 谐振拥塞感知_等级(感知器) { 返回 感知器[3] }

// 完整统计
函数 传控拥塞控制_完整统计() {
    拥塞统计_初始化()
    返回 [
        "算法数", 计数(拥塞算法列表),
        "默认算法", 默认算法名,
        "ACK总数", 全局_拥塞统计.ACK总数,
        "丢包总数", 全局_拥塞统计.丢包总数,
        "ECN_CE次数", ECN_CE计数,
        "原生独创_谐振拥塞感知", 1
    ]
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("../感知/内核直连层.nova")
导入("./内核打印.nova")
导入("./内存初始化.nova")
导入("./创建甲.nova")
导入("./整数转字符串.nova")

定义 突触_修剪阈值 = 50
定义 突触_衰减率 = 2
定义 突触_最大强度 = 10000
定义 突触_强化增量 = 100
定义 突触_最大连接 = 4096

定义 知识_最大跳数 = 5
定义 知识_最小置信度 = 300
定义 知识_衰减因子 = 80

定义 伙伴_最大阶 = 11

定义 TNF_错误率阈值 = 10
定义 TNF_权重上限 = 1000
定义 TNF_权重下限 = -1000
定义 TNF_自动重置阈值 = 25

结构 自动化统计 {
    修剪总数,
    强化总数,
    推理步数,
    碎片整理数,
    TNF自检数,
    TNF重置数,
    tick计数,
    上次修剪时间,
    上次碎片整理时间,
    上次推理时间,
}

定义 可变 全局_自动化统计 = 空

函数 自动化_初始化() {
    如果 (全局_自动化统计 == 空) {
        全局_自动化统计 = 堆_分配(自动化统计)
        全局_自动化统计.修剪总数 = 0
        全局_自动化统计.强化总数 = 0
        全局_自动化统计.推理步数 = 0
        全局_自动化统计.碎片整理数 = 0
        全局_自动化统计.TNF自检数 = 0
        全局_自动化统计.TNF重置数 = 0
        全局_自动化统计.tick计数 = 0
        全局_自动化统计.上次修剪时间 = 0
        全局_自动化统计.上次碎片整理时间 = 0
        全局_自动化统计.上次推理时间 = 0
    }
}

函数 突触网格_修剪弱连接() {
    自动化_初始化()
    内核调试("自动化: 突触网格弱连接修剪")

    如果 (突触网格 == 空 || 突触网格.连接数 == 0) { 返回 0 }

    定义 可变 修剪数 = 0
    定义 可变 i = 0

    当 (i < 突触网格.连接数) {
        定义 偏移 = 突触网格.连接列表 + i * 16
        定义 强度 = 内存_读32(偏移 + 8)
        定义 最后活跃 = 内存_读32(偏移 + 12)

        如果 (强度 < 突触_修剪阈值) {
            突触网格_移除连接(突触网格, i)
            修剪数 = 修剪数 + 1
        } 否则 {
            定义 新强度 = 强度 - 突触_衰减率
            如果 (新强度 < 0) { 新强度 = 0 }
            内存_写32(偏移 + 8, 新强度)
            i = i + 1
        }
    }

    全局_自动化统计.修剪总数 = 全局_自动化统计.修剪总数 + 修剪数
    全局_自动化统计.上次修剪时间 = 平台_获取高精度时间()

    如果 (修剪数 > 0) {
        内核调试("自动化: 修剪了 " + 整数转字符串(修剪数) + " 个弱连接, 剩余 "
            + 整数转字符串(突触网格.连接数))
    }
    返回 修剪数
}

函数 突触网格_移除连接(网格, 索引) {
    如果 (索引 < 0 || 索引 >= 网格.连接数) { 返回 }
    定义 目标 = 网格.连接列表 + 索引 * 16
    定义 最后 = 网格.连接列表 + (网格.连接数 - 1) * 16
    如果 (索引 < 网格.连接数 - 1) {
        内存_拷贝(目标, 最后, 16)
    }
    网格.连接数 = 网格.连接数 - 1
}

函数 突触网格_强化连接(源, 目标) {
    自动化_初始化()
    如果 (突触网格 == 空) { 返回 }

    定义 可变 i = 0
    当 (i < 突触网格.连接数) {
        定义 偏移 = 突触网格.连接列表 + i * 16
        定义 连接源 = 内存_读32(偏移)
        定义 连接目标 = 内存_读32(偏移 + 4)
        如果 (连接源 == 源 && 连接目标 == 目标) {
            定义 强度 = 内存_读32(偏移 + 8)
            强度 = 强度 + 突触_强化增量
            如果 (强度 > 突触_最大强度) { 强度 = 突触_最大强度 }
            内存_写32(偏移 + 8, 强度)
            内存_写32(偏移 + 12, 平台_获取高精度时间() & 0xFFFFFFFF)
            全局_自动化统计.强化总数 = 全局_自动化统计.强化总数 + 1
            返回
        }
        i = i + 1
    }

    如果 (突触网格.连接数 < 突触_最大连接) {
        定义 偏移 = 突触网格.连接列表 + 突触网格.连接数 * 16
        内存_写32(偏移, 源)
        内存_写32(偏移 + 4, 目标)
        内存_写32(偏移 + 8, 突触_强化增量)
        内存_写32(偏移 + 12, 平台_获取高精度时间() & 0xFFFFFFFF)
        突触网格.连接数 = 突触网格.连接数 + 1
    }
}

函数 突触网格_查询强度(源, 目标) {
    如果 (突触网格 == 空) { 返回 0 }
    定义 可变 i = 0
    当 (i < 突触网格.连接数) {
        定义 偏移 = 突触网格.连接列表 + i * 16
        如果 (内存_读32(偏移) == 源 && 内存_读32(偏移 + 4) == 目标) {
            返回 内存_读32(偏移 + 8)
        }
        i = i + 1
    }
    返回 0
}

函数 突触网格_统计() {
    如果 (突触网格 == 空) { 返回 [0, 0, 0] }
    定义 可变 总强度 = 0
    定义 可变 最大强度 = 0
    定义 可变 i = 0
    当 (i < 突触网格.连接数) {
        定义 强度 = 内存_读32(突触网格.连接列表 + i * 16 + 8)
        总强度 = 总强度 + 强度
        如果 (强度 > 最大强度) { 最大强度 = 强度 }
        i = i + 1
    }
    定义 平均 = 0
    如果 (突触网格.连接数 > 0) { 平均 = 总强度 / 突触网格.连接数 }
    返回 [突触网格.连接数, 平均, 最大强度]
}

函数 知识图谱_推理一步() {
    自动化_初始化()
    内核调试("自动化: 知识图谱推理一步")

    如果 (知识图谱 == 空 || 知识图谱.节点数 == 0) { 返回 0 }

    定义 可变 新关系数 = 0
    定义 可变 i = 0
    当 (i < 知识图谱.节点数) {
        定义 节点 = 知识图谱_获取节点(知识图谱, i)
        如果 (节点 == 空) { i = i + 1; 继续 }

        定义 邻居列表 = 知识图谱_获取邻居(知识图谱, i)
        如果 (邻居列表 == 空) { i = i + 1; 继续 }

        定义 可变 j = 0
        当 (j < 计数(邻居列表)) {
            定义 邻居 = 邻居列表[j]
            定义 二阶邻居 = 知识图谱_获取邻居(知识图谱, 邻居)
            如果 (二阶邻居 != 空) {
                定义 可变 k = 0
                当 (k < 计数(二阶邻居)) {
                    定义 目标 = 二阶邻居[k]
                    如果 (目标 != i && !知识图谱_有边(知识图谱, i, 目标)) {
                        定义 强度A = 知识图谱_边权重(知识图谱, i, 邻居)
                        定义 强度B = 知识图谱_边权重(知识图谱, 邻居, 目标)
                        定义 推理置信度 = (强度A * 强度B * 知识_衰减因子) / 10000

                        如果 (推理置信度 >= 知识_最小置信度) {
                            知识图谱_添加边(知识图谱, i, 目标, 推理置信度)
                            新关系数 = 新关系数 + 1
                        }
                    }
                    k = k + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }

    全局_自动化统计.推理步数 = 全局_自动化统计.推理步数 + 1
    全局_自动化统计.上次推理时间 = 平台_获取高精度时间()

    如果 (新关系数 > 0) {
        内核调试("自动化: 知识图谱推理发现 " + 整数转字符串(新关系数) + " 个新关系")
    }
    返回 新关系数
}

函数 知识图谱_多跳推理(起点, 终点, 最大跳数) {
    如果 (知识图谱 == 空) { 返回 空 }
    如果 (最大跳数 > 知识_最大跳数) { 最大跳数 = 知识_最大跳数 }

    定义 可变 路径 = [起点]
    定义 可变 已访问 = []
    追加(已访问, 起点)

    定义 可变 当前 = 起点
    定义 可变 跳数 = 0

    当 (跳数 < 最大跳数 && 当前 != 终点) {
        定义 邻居 = 知识图谱_获取邻居(知识图谱, 当前)
        如果 (邻居 == 空 || 计数(邻居) == 0) { 返回 空 }

        定义 可变 最佳 = -1
        定义 可变 最佳权重 = 0

        定义 可变 n = 0
        当 (n < 计数(邻居)) {
            定义 候选 = 邻居[n]
            定义 可变 已走过 = 假
            定义 可变 v = 0
            当 (v < 计数(已访问)) {
                如果 (已访问[v] == 候选) { 已走过 = 真; 跳出 }
                v = v + 1
            }

            如果 (!已走过) {
                定义 权重 = 知识图谱_边权重(知识图谱, 当前, 候选)
                如果 (候选 == 终点) { 权重 = 权重 + 10000 }
                如果 (权重 > 最佳权重) {
                    最佳 = 候选
                    最佳权重 = 权重
                }
            }
            n = n + 1
        }

        如果 (最佳 < 0) { 返回 空 }
        追加(路径, 最佳)
        追加(已访问, 最佳)
        当前 = 最佳
        跳数 = 跳数 + 1
    }

    如果 (当前 == 终点) { 返回 路径 }
    返回 空
}

外部 伙伴_空闲链表

函数 伙伴_碎片整理() {
    自动化_初始化()
    如果 (伙伴_空闲链表 == 空) { 返回 0 }

    定义 可变 合并总数 = 0

    定义 可变 阶 = 0
    当 (阶 < 伙伴_最大阶 - 1) {
        如果 (阶 >= 计数(伙伴_空闲链表)) { 跳出 }
        定义 链表 = 伙伴_空闲链表[阶]
        如果 (链表 == 空) { 阶 = 阶 + 1; 继续 }

        定义 块数 = 计数(链表)
        如果 (块数 < 2) { 阶 = 阶 + 1; 继续 }

        定义 块大小 = 4096 << 阶

        定义 可变 i = 0
        当 (i < 计数(链表) - 1) {
            定义 地址A = 链表[i]
            定义 伙伴地址 = 地址A ^ 块大小

            定义 可变 j = i + 1
            当 (j < 计数(链表)) {
                如果 (链表[j] == 伙伴地址) {
                    定义 合并地址 = 地址A
                    如果 (伙伴地址 < 地址A) { 合并地址 = 伙伴地址 }

                    伙伴_从链表移除(链表, j)
                    伙伴_从链表移除(链表, i)

                    如果 (阶 + 1 < 计数(伙伴_空闲链表)) {
                        追加(伙伴_空闲链表[阶 + 1], 合并地址)
                    }
                    合并总数 = 合并总数 + 1
                    跳出
                }
                j = j + 1
            }
            i = i + 1
        }
        阶 = 阶 + 1
    }

    全局_自动化统计.碎片整理数 = 全局_自动化统计.碎片整理数 + 合并总数
    全局_自动化统计.上次碎片整理时间 = 平台_获取高精度时间()

    如果 (合并总数 > 0) {
        内核调试("自动化: 伙伴碎片整理合并 " + 整数转字符串(合并总数) + " 对块")
    }
    返回 合并总数
}

函数 伙伴_从链表移除(链表, 索引) {
    如果 (索引 < 0 || 索引 >= 计数(链表)) { 返回 }
    定义 最后 = 计数(链表) - 1
    如果 (索引 < 最后) {
        设置(链表, 索引, 链表[最后])
    }
    删除(链表, 最后)
}

函数 伙伴_碎片率() {
    如果 (伙伴_空闲链表 == 空) { 返回 0 }
    定义 可变 低阶计数 = 0
    定义 可变 高阶计数 = 0
    定义 可变 阶 = 0
    当 (阶 < 计数(伙伴_空闲链表)) {
        定义 n = 计数(伙伴_空闲链表[阶])
        如果 (阶 < 3) { 低阶计数 = 低阶计数 + n }
        否则 { 高阶计数 = 高阶计数 + n }
        阶 = 阶 + 1
    }
    定义 总数 = 低阶计数 + 高阶计数
    如果 (总数 == 0) { 返回 0 }
    返回 低阶计数 * 100 / 总数
}

外部 TNF_推理次数
外部 TNF_错误次数
外部 TNF_权重矩阵

函数 TNF_自检() {
    自动化_初始化()
    全局_自动化统计.TNF自检数 = 全局_自动化统计.TNF自检数 + 1

    如果 (TNF_推理次数 == 0) { 返回 真 }
    定义 错误率 = TNF_错误次数 * 100 / TNF_推理次数

    如果 (错误率 >= TNF_自动重置阈值) {
        内核警告("自动化: TNF错误率 " + 整数转字符串(错误率) + "% 超过自动重置阈值")
        TNF_重置()
        返回 假
    }

    如果 (错误率 >= TNF_错误率阈值) {
        内核警告("自动化: TNF错误率偏高 " + 整数转字符串(错误率) + "%")
        返回 假
    }

    返回 真
}

函数 TNF_重置() {
    自动化_初始化()
    内核警告("自动化: TNF推理引擎重置")
    全局_自动化统计.TNF重置数 = 全局_自动化统计.TNF重置数 + 1

    如果 (TNF_权重矩阵 != 空) {
        定义 可变 钳位数 = 0
        定义 可变 i = 0
        当 (i < 计数(TNF_权重矩阵)) {
            如果 (TNF_权重矩阵[i] > TNF_权重上限) {
                设置(TNF_权重矩阵, i, TNF_权重上限)
                钳位数 = 钳位数 + 1
            }
            如果 (TNF_权重矩阵[i] < TNF_权重下限) {
                设置(TNF_权重矩阵, i, TNF_权重下限)
                钳位数 = 钳位数 + 1
            }
            i = i + 1
        }
        如果 (钳位数 > 0) {
            内核调试("自动化: 钳位了 " + 整数转字符串(钳位数) + " 个异常权重")
        }
    }
    TNF_错误次数 = 0
}

函数 TNF_健康报告() {
    定义 可变 总权重 = 0
    定义 可变 最大权重 = 0
    定义 可变 零权重 = 0
    定义 可变 权重数 = 0

    如果 (TNF_权重矩阵 != 空) {
        权重数 = 计数(TNF_权重矩阵)
        定义 可变 i = 0
        当 (i < 权重数) {
            定义 w = TNF_权重矩阵[i]
            定义 绝对值 = w
            如果 (绝对值 < 0) { 绝对值 = -绝对值 }
            总权重 = 总权重 + 绝对值
            如果 (绝对值 > 最大权重) { 最大权重 = 绝对值 }
            如果 (w == 0) { 零权重 = 零权重 + 1 }
            i = i + 1
        }
    }

    打印行("=== TNF健康报告 ===")
    打印行("推理次数: " + 整数转字符串(TNF_推理次数))
    打印行("错误次数: " + 整数转字符串(TNF_错误次数))
    如果 (TNF_推理次数 > 0) {
        打印行("错误率: " + 整数转字符串(TNF_错误次数 * 100 / TNF_推理次数) + "%")
    }
    打印行("权重数量: " + 整数转字符串(权重数))
    如果 (权重数 > 0) {
        打印行("平均权重: " + 整数转字符串(总权重 / 权重数))
        打印行("最大权重: " + 整数转字符串(最大权重))
        打印行("稀疏度: " + 整数转字符串(零权重 * 100 / 权重数) + "%")
    }
}

定义 可变 自动化_tick计数 = 0

函数 自动化_tick() {
    自动化_初始化()
    自动化_tick计数 = 自动化_tick计数 + 1
    全局_自动化统计.tick计数 = 自动化_tick计数

    如果 (自动化_tick计数 % 10 == 0) {
        突触网格_修剪弱连接()
    }

    如果 (自动化_tick计数 % 50 == 0) {
        知识图谱_推理一步()
    }

    如果 (自动化_tick计数 % 100 == 0) {
        伙伴_碎片整理()
    }

    如果 (自动化_tick计数 % 200 == 0) {
        TNF_自检()
    }
}

函数 自动化_完整统计() {
    自动化_初始化()
    返回 [TNF_推理次数, TNF_错误次数, 自动化_tick计数,
           全局_自动化统计.修剪总数, 全局_自动化统计.强化总数,
           全局_自动化统计.碎片整理数, 全局_自动化统计.TNF重置数]
}

// 自适应修剪策略 — 动态调整修剪阈值
// 理论: 连接数超载时加大修剪力度, 平稳时保守修剪

定义 可变 自适应_修剪阈值 = 50
定义 自适应_高水位 = 3072    // 连接数超过此值时加大修剪
定义 自适应_低水位 = 512     // 连接数低于此值时减小修剪

函数 自动化_自适应修剪阈值() {
    如果 (突触网格 == 空) { 返回 }
    定义 当前连接数 = 突触网格.连接数

    如果 (当前连接数 > 自适应_高水位) {
        // 连接过多, 提高修剪阈值加大淘汰
        自适应_修剪阈值 = 自适应_修剪阈值 + 10
        如果 (自适应_修剪阈值 > 500) { 自适应_修剪阈值 = 500 }
        内核调试("自动化: 连接过载, 提高修剪阈值至 " + 整数转字符串(自适应_修剪阈值))
    } 否则如果 (当前连接数 < 自适应_低水位) {
        // 连接少, 降低修剪阈值保留更多弱连接
        自适应_修剪阈值 = 自适应_修剪阈值 - 5
        如果 (自适应_修剪阈值 < 10) { 自适应_修剪阈值 = 10 }
    }
}

// 连接重要性评分 (Hub Score)
// 理论: 连接重要性 = 强度 × 活跃度 × 中心度补偿

函数 突触网格_连接重要性(源, 目标) {
    如果 (突触网格 == 空) { 返回 0 }
    定义 强度 = 突触网格_查询强度(源, 目标)
    如果 (强度 == 0) { 返回 0 }

    // 计算源和目标的度 (degree)
    定义 可变 源度 = 0
    定义 可变 目标度 = 0
    定义 可变 i = 0
    当 (i < 突触网格.连接数) {
        定义 偏移 = 突触网格.连接列表 + i * 16
        定义 s = 内存_读32(偏移)
        定义 d = 内存_读32(偏移 + 4)
        如果 (s == 源 || d == 源) { 源度 = 源度 + 1 }
        如果 (s == 目标 || d == 目标) { 目标度 = 目标度 + 1 }
        i = i + 1
    }

    // 重要性 = 强度 + (hub补偿: 低度节点的连接更珍贵)
    定义 中心度 = (源度 + 目标度) / 2
    如果 (中心度 == 0) { 中心度 = 1 }
    定义 补偿 = 突触_最大强度 / 中心度
    返回 强度 + 补偿
}

// 拓扑健康指标
// 理论: 评估网格健康状态 — 连通性、密度、均衡度

函数 突触网格_健康指标() {
    如果 (突触网格 == 空) { 返回 [0, 0, 0, 0] }
    定义 连接数 = 突触网格.连接数
    定义 统计 = 突触网格_统计()
    定义 平均强度 = 统计[1]
    定义 最大强度 = 统计[2]

    // 密度分 = 连接数 / 最大连接 * 100
    定义 密度分 = 连接数 * 100 / 突触_最大连接

    // 均衡度 = 平均强度 * 100 / 最大强度 (100=完美均衡)
    定义 可变 均衡度 = 0
    如果 (最大强度 > 0) {
        均衡度 = 平均强度 * 100 / 最大强度
    }

    // 活力分 = 非零强度占比
    定义 可变 非零数 = 0
    定义 可变 i = 0
    当 (i < 连接数) {
        定义 强度 = 内存_读32(突触网格.连接列表 + i * 16 + 8)
        如果 (强度 > 0) { 非零数 = 非零数 + 1 }
        i = i + 1
    }
    定义 活力分 = 0
    如果 (连接数 > 0) { 活力分 = 非零数 * 100 / 连接数 }

    返回 [密度分, 均衡度, 活力分, 连接数]
}

函数 自动化_打印统计() {
    自动化_初始化()
    打印行("=== 内核自动化统计 ===")
    打印行("Tick次数: " + 整数转字符串(全局_自动化统计.tick计数))
    打印行("突触修剪: " + 整数转字符串(全局_自动化统计.修剪总数))
    打印行("突触强化: " + 整数转字符串(全局_自动化统计.强化总数))
    打印行("推理步数: " + 整数转字符串(全局_自动化统计.推理步数))
    打印行("碎片整理: " + 整数转字符串(全局_自动化统计.碎片整理数))
    打印行("TNF自检: " + 整数转字符串(全局_自动化统计.TNF自检数))
    打印行("TNF重置: " + 整数转字符串(全局_自动化统计.TNF重置数))
    打印行("碎片率: " + 整数转字符串(伙伴_碎片率()) + "%")
    打印行("自适应修剪阈值: " + 整数转字符串(自适应_修剪阈值))
    定义 健康 = 突触网格_健康指标()
    打印行("密度分: " + 整数转字符串(健康[0]) + "%")
    打印行("均衡度: " + 整数转字符串(健康[1]) + "%")
    打印行("活力分: " + 整数转字符串(健康[2]) + "%")
}

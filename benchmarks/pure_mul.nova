函数 mul2(a, b) {
    定义 _a = a + 0.0
    定义 _b = b + 0.0
    返回 _a * _b
}

函数 mul3(a, b) {
    // 直接乘, 无 workaround
    返回 a * b
}

函数 主程序() {
    // 0.2 * 0.9 = 0.18 bits ≈ 0x3FC70A3D70A3D70B = 4594572339843380491
    定义 r1 = mul2(0.2, 0.9)
    打印(字符串拼接("mul2 bits=", 转字符串(r1)))
    定义 r2 = mul3(0.2, 0.9)
    打印(字符串拼接("mul3 bits=", 转字符串(r2)))
    返回 0
}

// 文件: nova_core/系统扩展/P0-裸机/内联汇编编译.nova
// Phase: P0 | 对标: GCC __asm__ / Rust asm!()
// 功能: 将Nova内联汇编块编译为x86-64机器码
//        支持: 指令助记符→操作码, 寄存器, 立即数, 标签, 内存操作数
//        语法: 汇编 { mov rax, rcx; ret }
// 依赖: 平台/代码生成/x86_64/代码生成器.nova (发射/发射组)

导入("../../编译器/规划/核心/发射器.nova")
导入("../../标准库/基础.nova")
导入("../../编译器/规划/核心/常量.nova")
导入("链接脚本支持.nova")
导入("../../自举兼容桥.nova")

// 寄存器编码表 (3-bit reg field)
// 64位通用寄存器: rax=0, rcx=1, rdx=2, rbx=3, rsp=4, rbp=5, rsi=6, rdi=7
// 扩展寄存器: r8-r15 需要REX.B/REX.R前缀

函数 寄存器编码(名) {
    如果 (名 == "rax" 或 名 == "eax" 或 名 == "ax" 或 名 == "al") { 返回 0 }
    如果 (名 == "ah") { 返回 4 }
    如果 (名 == "rcx" 或 名 == "ecx" 或 名 == "cx" 或 名 == "cl") { 返回 1 }
    如果 (名 == "ch") { 返回 5 }
    如果 (名 == "rdx" 或 名 == "edx" 或 名 == "dx" 或 名 == "dl") { 返回 2 }
    如果 (名 == "dh") { 返回 6 }
    如果 (名 == "rbx" 或 名 == "ebx" 或 名 == "bx" 或 名 == "bl") { 返回 3 }
    如果 (名 == "bh") { 返回 7 }
    如果 (名 == "rsp" 或 名 == "esp" 或 名 == "sp" 或 名 == "spl") { 返回 4 }
    如果 (名 == "rbp" 或 名 == "ebp" 或 名 == "bp" 或 名 == "bpl") { 返回 5 }
    如果 (名 == "rsi" 或 名 == "esi" 或 名 == "si" 或 名 == "sil") { 返回 6 }
    如果 (名 == "rdi" 或 名 == "edi" 或 名 == "di" 或 名 == "dil") { 返回 7 }
    如果 (名 == "r8" 或 名 == "r8d" 或 名 == "r8w" 或 名 == "r8b") { 返回 8 }
    如果 (名 == "r9" 或 名 == "r9d" 或 名 == "r9w" 或 名 == "r9b") { 返回 9 }
    如果 (名 == "r10" 或 名 == "r10d" 或 名 == "r10w" 或 名 == "r10b") { 返回 10 }
    如果 (名 == "r11" 或 名 == "r11d" 或 名 == "r11w" 或 名 == "r11b") { 返回 11 }
    如果 (名 == "r12" 或 名 == "r12d" 或 名 == "r12w" 或 名 == "r12b") { 返回 12 }
    如果 (名 == "r13" 或 名 == "r13d" 或 名 == "r13w" 或 名 == "r13b") { 返回 13 }
    如果 (名 == "r14" 或 名 == "r14d" 或 名 == "r14w" 或 名 == "r14b") { 返回 14 }
    如果 (名 == "r15" 或 名 == "r15d" 或 名 == "r15w" 或 名 == "r15b") { 返回 15 }
    返回 0 - 1  // 未知寄存器
}

函数 是64位寄存器(名) {
    如果 (名 == "rax" 或 名 == "rcx" 或 名 == "rdx" 或 名 == "rbx") { 返回 真 }
    如果 (名 == "rsp" 或 名 == "rbp" 或 名 == "rsi" 或 名 == "rdi") { 返回 真 }
    如果 (名 == "r8" 或 名 == "r9" 或 名 == "r10" 或 名 == "r11") { 返回 真 }
    如果 (名 == "r12" 或 名 == "r13" 或 名 == "r14" 或 名 == "r15") { 返回 真 }
    返回 假
}

函数 是扩展寄存器(名) {
    定义 编码 = 寄存器编码(名)
    返回 编码 >= 8
}

// REX前缀构建
// REX = 0100WRXB
// W=1: 64位操作数  R: ModRM.reg扩展  X: SIB.index扩展  B: ModRM.rm扩展
函数 构建REX(W, R, X, B) {
    定义 可变 rex = 0x40
    如果 (W) { rex = rex + 8 }
    如果 (R) { rex = rex + 4 }
    如果 (X) { rex = rex + 2 }
    如果 (B) { rex = rex + 1 }
    返回 rex
}

// ModRM字节构建
// ModRM = [mod(2)][reg(3)][rm(3)]
函数 构建ModRM(mod, reg, rm) {
    返回 ((mod & 3) << 6) + ((reg & 7) << 3) + (rm & 7)
}

函数 汇编_低8位寄存器需要REX(名) {
    如果 (名 == "spl" 或 名 == "bpl" 或 名 == "sil" 或 名 == "dil") { 返回 真 }
    如果 (名 == "r8b" 或 名 == "r9b" 或 名 == "r10b" 或 名 == "r11b") { 返回 真 }
    如果 (名 == "r12b" 或 名 == "r13b" 或 名 == "r14b" 或 名 == "r15b") { 返回 真 }
    返回 假
}

函数 汇编_寄存器位数(名) {
    如果 (是字符串(名) == 假) { 返回 0 }
    如果 (名 == "al" 或 名 == "ah" 或 名 == "cl" 或 名 == "ch") { 返回 8 }
    如果 (名 == "dl" 或 名 == "dh" 或 名 == "bl" 或 名 == "bh") { 返回 8 }
    如果 (名 == "spl" 或 名 == "bpl" 或 名 == "sil" 或 名 == "dil") { 返回 8 }
    如果 (名 == "r8b" 或 名 == "r9b" 或 名 == "r10b" 或 名 == "r11b") { 返回 8 }
    如果 (名 == "r12b" 或 名 == "r13b" 或 名 == "r14b" 或 名 == "r15b") { 返回 8 }
    如果 (名 == "ax" 或 名 == "cx" 或 名 == "dx" 或 名 == "bx") { 返回 16 }
    如果 (名 == "sp" 或 名 == "bp" 或 名 == "si" 或 名 == "di") { 返回 16 }
    如果 (名 == "r8w" 或 名 == "r9w" 或 名 == "r10w" 或 名 == "r11w") { 返回 16 }
    如果 (名 == "r12w" 或 名 == "r13w" 或 名 == "r14w" 或 名 == "r15w") { 返回 16 }
    如果 (名 == "eax" 或 名 == "ecx" 或 名 == "edx" 或 名 == "ebx") { 返回 32 }
    如果 (名 == "esp" 或 名 == "ebp" 或 名 == "esi" 或 名 == "edi") { 返回 32 }
    如果 (名 == "r8d" 或 名 == "r9d" 或 名 == "r10d" 或 名 == "r11d") { 返回 32 }
    如果 (名 == "r12d" 或 名 == "r13d" 或 名 == "r14d" 或 名 == "r15d") { 返回 32 }
    如果 (是64位寄存器(名)) { 返回 64 }
    返回 0
}

函数 汇编_控制寄存器编码(名) {
    如果 (名 == "cr0") { 返回 0 }
    如果 (名 == "cr2") { 返回 2 }
    如果 (名 == "cr3") { 返回 3 }
    如果 (名 == "cr4") { 返回 4 }
    返回 0 - 1
}

函数 汇编_段寄存器编码(名) {
    如果 (名 == "es") { 返回 0 }
    如果 (名 == "cs") { 返回 1 }
    如果 (名 == "ss") { 返回 2 }
    如果 (名 == "ds") { 返回 3 }
    如果 (名 == "fs") { 返回 4 }
    如果 (名 == "gs") { 返回 5 }
    返回 0 - 1
}

函数 汇编_是内存描述(x) {
    如果 (x == 空) { 返回 假 }
    定义 _整数类型 = 类型()
    如果 (类型(x) == _整数类型) { 返回 假 }
    如果 (计数(x) < 4) { 返回 假 }
    定义 _字符串类型 = 类型("")
    如果 (x[0] != 1) { 返回 假 }
    如果 (类型(x[1]) != _字符串类型) { 返回 假 }
    如果 (类型(x[2]) != _整数类型) { 返回 假 }
    如果 (类型(x[3]) != _整数类型) { 返回 假 }
    返回 真
}

函数 汇编_编码内存描述(基寄存器, 位移, 大小) {
    返回 "__mem__|" + 基寄存器 + "|" + 转字符串(位移) + "|" + 转字符串(大小)
}

函数 汇编_稳定操作数引用(x) {
    如果 (是字符串(x)) {
        定义 可变 _复制 = ""
        定义 可变 _i = 0
        定义 _n = 计数(x)
        当 (_i < _n) {
            _复制 = 字符串拼接(_复制, 子串(x, _i, 1))
            _i = _i + 1
        }
        返回 _复制
    }
    返回 x
}

函数 汇编_列表追加(列表, 值) {
    追加(列表, 值)
}

函数 汇编_编码符号引用(名) {
    返回 "__sym__|" + 名
}

函数 汇编_解码符号引用(文本) {
    如果 (文本 == 空) { 返回 文本 }
    定义 _字符串类型 = 类型("")
    如果 (类型(文本) != _字符串类型) { 返回 文本 }
    如果 (计数(文本) < 8 或 子串(文本, 0, 8) != "__sym__|") { 返回 文本 }
    返回 字符串拼接("", 子串(文本, 8, 计数(文本) - 8))
}

函数 汇编_应编码符号引用(文本) {
    如果 (文本 == 空) { 返回 假 }
    定义 _字符串类型 = 类型("")
    如果 (类型(文本) != _字符串类型) { 返回 假 }
    如果 (计数(文本) >= 8 且 子串(文本, 0, 8) == "__sym__|") { 返回 假 }
    如果 (寄存器编码(文本) >= 0) { 返回 假 }
    如果 (汇编_控制寄存器编码(文本) >= 0) { 返回 假 }
    如果 (汇编_段寄存器编码(文本) >= 0) { 返回 假 }
    返回 真
}

定义 可变 汇编_当前本地标签表 = 字典()
定义 可变 汇编_当前本地修正表 = []

函数 汇编_是本地标签名(文本) {
    如果 (文本 == 空) { 返回 假 }
    定义 _字符串类型 = 类型("")
    如果 (类型(文本) != _字符串类型) { 返回 假 }
    如果 (计数(文本) == 0) { 返回 假 }
    返回 子串(文本, 0, 1) == "."
}

函数 汇编_本地标签ID(文本) {
    返回 "__local__|" + 字符串拼接("", 文本)
}

函数 汇编_是本地标签ID(文本) {
    如果 (文本 == 空) { 返回 假 }
    定义 _字符串类型 = 类型("")
    如果 (类型(文本) != _字符串类型) { 返回 假 }
    如果 (计数(文本) < 10) { 返回 假 }
    返回 子串(文本, 0, 10) == "__local__|"
}

函数 汇编_提取本地标签内存操作数(操作数) {
    如果 (操作数 == 空) { 返回 "" }
    定义 _字符串类型 = 类型("")
    如果 (类型(操作数) != _字符串类型) { 返回 "" }
    定义 s = 汇编_稳定操作数引用(汇编_去空白(操作数))
    如果 (计数(s) < 3) { 返回 "" }
    如果 (子串(s, 0, 1) != "[" 或 子串(s, 计数(s) - 1, 1) != "]") { 返回 "" }
    定义 内 = 汇编_稳定操作数引用(汇编_去空白(子串(s, 1, 计数(s) - 2)))
    如果 (汇编_是本地标签名(内)) { 返回 汇编_稳定操作数引用(汇编_本地标签ID(内)) }
    返回 ""
}

函数 汇编_助记符_使用本地标签ID(助记符) {
    如果 (助记符 == "jmp") { 返回 真 }
    如果 (助记符 == "jnc" 或 助记符 == "jae") { 返回 真 }
    如果 (助记符 == "jc" 或 助记符 == "jb") { 返回 真 }
    如果 (助记符 == "jz" 或 助记符 == "je") { 返回 真 }
    如果 (助记符 == "jnz" 或 助记符 == "jne") { 返回 真 }
    返回 假
}

函数 汇编_本地跳转助记符(助记符) {
    返回 助记符 + "_local"
}

函数 汇编_记录本地修正(修类, 修位, 标签ID) {
    追加(汇编_当前本地修正表, 修类)
    追加(汇编_当前本地修正表, 修位)
    追加(汇编_当前本地修正表, 标签ID)
}

函数 汇编_应用本地修正() {
    定义 可变 i = 0
    当 (i < 计数(汇编_当前本地修正表)) {
        定义 修类 = 汇编_当前本地修正表[i]
        定义 修位 = 汇编_当前本地修正表[i + 1]
        定义 标签ID = 汇编_当前本地修正表[i + 2]
        定义 目标位 = 字典取(汇编_当前本地标签表, 标签ID)
        如果 (修类 == "jmp32_local") {
            定义 rel32 = 目标位 - (修位 + 4)
            内存写32(代码, 修位, rel32)
        } 否则 如果 (修类 == "jcc8_local") {
            定义 rel8 = 目标位 - (修位 + 1)
            代码[修位] = rel8 & 255
        } 否则 如果 (修类 == "rip32_local") {
            定义 rel32 = 目标位 - (修位 + 4)
            内存写32(代码, 修位, rel32)
        }
        i = i + 3
    }
}

函数 汇编_解码内存描述(文本) {
    如果 (文本 == 空) { 返回 [0, "",] }
    定义 _字符串类型 = 类型("")
    如果 (类型(文本) != _字符串类型) { 返回 [0, "",] }
    如果 (计数(文本) < 8 或 子串(文本, 0, 8) != "__mem__|") { 返回 [0, "",] }
    定义 可变 分隔1 = 0 - 1
    定义 可变 分隔2 = 0 - 1
    定义 可变 i = 8
    当 (i < 计数(文本) 且 分隔2 < 0) {
        如果 (子串(文本, i, 1) == "|") {
            如果 (分隔1 < 0) {
                分隔1 = i
            } 否则 {
                分隔2 = i
            }
        }
        i = i + 1
    }
    如果 (分隔1 < 0 或 分隔2 < 0) { 返回 [0, "",] }
    定义 基寄存器 = 子串(文本, 8, 分隔1 - 8)
    定义 位移文本 = 子串(文本, 分隔1 + 1, 分隔2 - 分隔1 - 1)
    定义 大小文本 = 子串(文本, 分隔2 + 1, 计数(文本) - 分隔2 - 1)
    定义 位移结果 = 汇编_尝试解析立即数(位移文本)
    如果 (位移结果[0] == 0) { 返回 [0, "",] }
    定义 大小结果 = 汇编_尝试解析立即数(大小文本)
    如果 (大小结果[0] == 0) { 返回 [0, "",] }
    如果 (寄存器编码(基寄存器) < 0) { 返回 [0, "",] }
    返回 [1, 基寄存器, 位移结果[1], 大小结果[1]]
}

函数 汇编_解析内存操作数(文本) {
    如果 (汇编_是内存描述(文本)) { 返回 文本 }
    定义 _已编码内存 = 汇编_解码内存描述(文本)
    如果 (_已编码内存[0] == 1) { 返回 _已编码内存 }
    如果 (文本 == 空) { 返回 [0, "",] }
    定义 _字符串类型 = 类型("")
    如果 (类型(文本) != _字符串类型) { 返回 [0, "",] }
    定义 可变 大小 = 0
    定义 _文本长 = 字节长度(文本)
    定义 可变 _快起点 = 0
    如果 (_文本长 >= 5 且 字节取(文本, 0) == 98 且 字节取(文本, 1) == 121 且 字节取(文本, 2) == 116 且 字节取(文本, 3) == 101 且 字节取(文本, 4) == 字符_空格) {
        大小 = 8
        _快起点 = 5
    } 否则 如果 (_文本长 >= 5 且 字节取(文本, 0) == 119 且 字节取(文本, 1) == 111 且 字节取(文本, 2) == 114 且 字节取(文本, 3) == 100 且 字节取(文本, 4) == 字符_空格) {
        大小 = 16
        _快起点 = 5
    } 否则 如果 (_文本长 >= 6 且 字节取(文本, 0) == 100 且 字节取(文本, 1) == 119 且 字节取(文本, 2) == 111 且 字节取(文本, 3) == 114 且 字节取(文本, 4) == 100 且 字节取(文本, 5) == 字符_空格) {
        大小 = 32
        _快起点 = 6
    } 否则 如果 (_文本长 >= 6 且 字节取(文本, 0) == 113 且 字节取(文本, 1) == 119 且 字节取(文本, 2) == 111 且 字节取(文本, 3) == 114 且 字节取(文本, 4) == 100 且 字节取(文本, 5) == 字符_空格) {
        大小 = 64
        _快起点 = 6
    }
    定义 可变 _快外文本 = ""
    定义 可变 _快k = _快起点
    当 (_快k < _文本长) {
        _快外文本 = 字符串拼接(_快外文本, 字符(字节取(文本, _快k)))
        _快k = _快k + 1
    }
    _快外文本 = 汇编_去空白(_快外文本)
    定义 _快外长 = 字节长度(_快外文本)
    如果 (_快外长 >= 2 且 字节取(_快外文本, 0) == 字符_左方括 且 字节取(_快外文本, _快外长 - 1) == 字符_右方括) {
        定义 可变 _快内文本 = ""
        定义 可变 _快j = 1
        当 (_快j < _快外长 - 1) {
            _快内文本 = 字符串拼接(_快内文本, 字符(字节取(_快外文本, _快j)))
            _快j = _快j + 1
        }
        定义 _快内 = 汇编_去空白(_快内文本)
        定义 可变 _快分隔位 = 0 - 1
        定义 可变 _快符号 = 1
        定义 可变 _快i = 1
        当 (_快i < 计数(_快内) 且 _快分隔位 < 0) {
            定义 _快c = 子串(_快内, _快i, 1)
            如果 (_快c == "+") {
                _快分隔位 = _快i
                _快符号 = 1
            } 否则 如果 (_快c == "-") {
                _快分隔位 = _快i
                _快符号 = 0 - 1
            } 否则 {
                _快i = _快i + 1
            }
        }
        如果 (_快分隔位 < 0) {
            如果 (寄存器编码(_快内) < 0) { 返回 [0, "", 0, 大小] }
            返回 [1, _快内, 0, 大小]
        }
        定义 _快基寄存器 = 汇编_去空白(子串(_快内, 0, _快分隔位))
        如果 (寄存器编码(_快基寄存器) < 0) { 返回 [0, "", 0, 大小] }
        定义 _快位移文本 = 汇编_去空白(子串(_快内, _快分隔位 + 1, 计数(_快内) - _快分隔位 - 1))
        定义 _快位移结果 = 汇编_尝试解析立即数(_快位移文本)
        定义 可变 _快位移 = _快位移结果[1]
        如果 (_快符号 < 0) { _快位移 = 0 - _快位移 }
        返回 [1, _快基寄存器, _快位移, 大小]
    }
    定义 可变 s = 文本
    如果 (计数(s) >= 5 且 子串(s, 0, 5) == "byte ") {
        大小 = 8
        s = 汇编_去空白(子串(s, 5, 计数(s) - 5))
    } 否则 如果 (计数(s) >= 5 且 子串(s, 0, 5) == "word ") {
        大小 = 16
        s = 汇编_去空白(子串(s, 5, 计数(s) - 5))
    } 否则 如果 (计数(s) >= 6 且 子串(s, 0, 6) == "dword ") {
        大小 = 32
        s = 汇编_去空白(子串(s, 6, 计数(s) - 6))
    } 否则 如果 (计数(s) >= 6 且 子串(s, 0, 6) == "qword ") {
        大小 = 64
        s = 汇编_去空白(子串(s, 6, 计数(s) - 6))
    }
    如果 (计数(s) < 2 或 子串(s, 0, 1) != "[" 或 子串(s, 计数(s) - 1, 1) != "]") { 返回 [0, "", 0, 大小] }
    定义 内 = 汇编_去空白(子串(s, 1, 计数(s) - 2))
    定义 可变 分隔位 = 0 - 1
    定义 可变 符号 = 1
    定义 可变 i = 1
    当 (i < 计数(内) 且 分隔位 < 0) {
        定义 c = 子串(内, i, 1)
        如果 (c == "+") {
            分隔位 = i
            符号 = 1
        } 否则 如果 (c == "-") {
            分隔位 = i
            符号 = 0 - 1
        } 否则 {
            i = i + 1
        }
    }
    如果 (分隔位 < 0) {
        如果 (寄存器编码(内) < 0) { 返回 [0, "", 0, 大小] }
        返回 [1, 内, 0, 大小]
    }
    定义 基寄存器 = 汇编_去空白(子串(内, 0, 分隔位))
    如果 (寄存器编码(基寄存器) < 0) { 返回 [0, "", 0, 大小] }
    定义 位移文本 = 汇编_去空白(子串(内, 分隔位 + 1, 计数(内) - 分隔位 - 1))
    定义 位移结果 = 汇编_尝试解析立即数(位移文本)
    定义 可变 位移 = 位移结果[1]
    如果 (符号 < 0) { 位移 = 0 - 位移 }
    返回 [1, 基寄存器, 位移, 大小]
}

函数 汇编_发射_内存地址(reg字段, 基寄存器, 位移) {
    定义 基编码 = 寄存器编码(基寄存器)
    定义 基低 = 基编码 & 7
    定义 可变 mod = 0
    如果 (位移 == 0 且 基低 != 5) {
        mod = 0
    } 否则 如果 (位移 >= 0 - 128 且 位移 <= 127) {
        mod = 1
    } 否则 {
        mod = 2
    }
    如果 (基低 == 5 且 位移 == 0) { mod = 1 }
    定义 可变 rm字段 = 基低
    如果 (基低 == 4) { rm字段 = 4 }
    发射(构建ModRM(mod, reg字段 & 7, rm字段))
    如果 (基低 == 4) {
        发射(构建ModRM(0, 4, 基低))
    }
    如果 (mod == 1) {
        发射(位移 & 0xFF)
    } 否则 如果 (mod == 2) {
        发射32(位移)
    }
}

// 汇编指令编译: 单条指令 → 机器码
// 指令格式: [助记符, 操作数1, 操作数2, ...]
函数 编译_处理__push_(操作数1) {
    定义 编码 = 寄存器编码(操作数1)
    如果 (编码 >= 0) {
        如果 (编码 >= 8) {
            发射(0x41)  // REX.B
            发射(0x50 + (编码 & 7))
        } 否则 {
            发射(0x50 + 编码)
        }
        返回 1
    }
    定义 内存 = 汇编_解析内存操作数(操作数1)
    如果 (内存[0]) {
        如果 (寄存器编码(内存[1]) >= 8) { 发射(0x41) }
        发射(0xFF)
        汇编_发射_内存地址(6, 内存[1], 内存[2])
        返回 1
    }
    如果 (是整数(操作数1)) {
        如果 (操作数1 >= 0 - 128 且 操作数1 <= 127) {
            发射(0x6A)
            发射(操作数1 & 0xFF)
        } 否则 {
            发射(0x68)
            发射32(操作数1)
        }
        返回 1
    }
}

函数 编译_处理__pop_(操作数1) {
    定义 编码 = 寄存器编码(操作数1)
    如果 (编码 >= 0) {
        如果 (编码 >= 8) {
            发射(0x41)
            发射(0x58 + (编码 & 7))
        } 否则 {
            发射(0x58 + 编码)
        }
        返回 1
    }
}

函数 编译_处理__call_(操作数1) {
    定义 目标1 = 汇编_解码符号引用(操作数1)
    定义 编码 = 寄存器编码(目标1)
    如果 (编码 >= 0) {
        如果 (编码 >= 8) { 发射(0x41) }
        发射(0xFF)
        发射(构建ModRM(3, 2, 编码 & 7))
        返回 1
    }
    // 调用 rel32 — 在修正表中登记
    修正表_追加记录(修正表, "call", 代码位 + 1, 目标1)
    发射(0xE8)
    发射32(0)
    返回 1
}

函数 编译_处理__jmp_(操作数1) {
    定义 目标1 = 汇编_解码符号引用(操作数1)
    如果 (类型(目标1) == 类型("") 且 计数(目标1) > 0 且 子串(目标1, 0, 1) == ".") {
        修正表_追加记录(修正表, "call", 代码位 + 1, 目标1)
        发射(0xE9)
        发射32(0)
        返回 1
    }
    定义 编码 = 寄存器编码(目标1)
    如果 (编码 >= 0) {
        如果 (编码 >= 8) { 发射(0x41) }
        发射(0xFF)
        发射(构建ModRM(3, 4, 编码 & 7))
        返回 1
    }
    修正表_追加记录(修正表, "call", 代码位 + 1, 目标1)
    发射(0xE9)
    发射32(0)
    返回 1
}

函数 编译_处理__lgdt_(操作数1) {
    // lgdt [op1] — 0F 01 /2
    定义 内存 = 汇编_解析内存操作数(操作数1)
    如果 (内存[0]) {
        如果 (寄存器编码(内存[1]) >= 8) { 发射(0x41) }
        发射组([0x0F, 0x01])
        汇编_发射_内存地址(2, 内存[1], 内存[2])
        返回 1
    }
    定义 addr编码 = 寄存器编码(操作数1)
    如果 (addr编码 >= 0) {
        // lgdt [reg]
        定义 需要B = addr编码 >= 8
        如果 (需要B) { 发射(0x41) }
        发射组([0x0F, 0x01])
        发射(构建ModRM(0, 2, addr编码 & 7))
    } 否则 {
        // lgdt [abs] — 通过rax间接
        发射组([0x0F, 0x01, 0x15])  // lgdt [rip+disp32]
        修正表_追加记录(修正表, "rip32", 代码位, 操作数1)
        发射32(0)
    }
    返回 1
}

函数 编译_处理__lidt_(操作数1) {
    // lidt [op1] — 0F 01 /3
    定义 内存 = 汇编_解析内存操作数(操作数1)
    如果 (内存[0]) {
        如果 (寄存器编码(内存[1]) >= 8) { 发射(0x41) }
        发射组([0x0F, 0x01])
        汇编_发射_内存地址(3, 内存[1], 内存[2])
        返回 1
    }
    定义 addr编码 = 寄存器编码(操作数1)
    如果 (addr编码 >= 0) {
        定义 需要B = addr编码 >= 8
        如果 (需要B) { 发射(0x41) }
        发射组([0x0F, 0x01])
        发射(构建ModRM(0, 3, addr编码 & 7))
    } 否则 {
        发射组([0x0F, 0x01, 0x1D])  // lidt [rip+disp32]
        修正表_追加记录(修正表, "rip32", 代码位, 操作数1)
        发射32(0)
    }
    返回 1
}


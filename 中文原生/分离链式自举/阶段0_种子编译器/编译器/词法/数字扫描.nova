// Nova 原生数字扫描器 — 十进制/十六进制/八进制/二进制/浮点/科学计数法
// 职责: 数字前缀检测 + 各进制解析 + 浮点解析 + 进制转换 + 格式化
// 层级: 第1层基础设施

// 数字进制类型

// 数字结果: [类型, 整数值, 小数位数, 错误码]
函数 数字结果(类型, 值, 小数位, 错误) {
    返回 [类型, 值, 小数位, 错误]
}

// 检测数字前缀
// 0x→十六进制, 0o→八进制, 0b→二进制, 其他→十进制
函数 检测前缀(首字符, 次字符) {
    如果 (首字符 != 48) { 返回 数制_十进制 }
    如果 (次字符 == 标记_建) { 返回 数制_十六进制 }  // 0x
    如果 (次字符 == 字符_大写X) { 返回 数制_十六进制 }   // 0X
    如果 (次字符 == 标记_可变) { 返回 数制_八进制 }  // 0o
    如果 (次字符 == 字符_大写O) { 返回 数制_八进制 }   // 0O
    如果 (次字符 == 标记_冒号) { 返回 数制_二进制 }   // 0b
    如果 (次字符 == 字符_大写B) { 返回 数制_二进制 }   // 0B
    返回 数制_十进制
}

// 十进制解析
函数 解析十进制(数字列表) {
    _数扫_整数数 = _数扫_整数数 + 1
    定义 长 = 计数(数字列表)
    定义 可变 值 = 0
    定义 可变 i = 0
    当 (i < 长) {
        定义 d = 数字列表[i]
        如果 (d < 0) { 返回 数字结果(数制_错误, 0 ,  1, 0) }
        如果 (d > 9) { 返回 数字结果(数制_错误, 0 ,  1, 0) }
        值 = 值 * 10 + d
        i = i + 1
    }
    返回 数字结果(数制_十进制,  值, 0 , 0)
}

// 十六进制解析
函数 数字扫描_解析十六进制(数字列表) {
    _数扫_整数数 = _数扫_整数数 + 1
    定义 长 = 计数(数字列表)
    如果 (长 == 0) { _数扫_错误数 = _数扫_错误数 + 1  返回 数字结果(数制_错误, 0 ,  2, 0) }
    定义 可变 值 = 0
    定义 可变 i = 0
    当 (i < 长) {
        定义 d = 数字列表[i]
        如果 (d < 0) { 返回 数字结果(数制_错误, 0 ,  2, 0) }
        如果 (d > 15) { 返回 数字结果(数制_错误, 0 ,  2, 0) }
        值 = 值 * 16 + d
        i = i + 1
    }
    返回 数字结果(数制_十六进制,  值, 0 , 0)
}

// 八进制解析
函数 数字扫描_解析八进制(数字列表) {
    定义 长 = 计数(数字列表)
    如果 (长 == 0) { 返回 数字结果(数制_错误, 0 ,  3, 0) }
    定义 可变 值 = 0
    定义 可变 i = 0
    当 (i < 长) {
        定义 d = 数字列表[i]
        如果 (d < 0) { 返回 数字结果(数制_错误, 0 ,  3, 0) }
        如果 (d > 7) { 返回 数字结果(数制_错误, 0 ,  3, 0) }
        值 = 值 * 8 + d
        i = i + 1
    }
    返回 数字结果(数制_八进制,  值, 0 , 0)
}

// 二进制解析
函数 数字扫描_解析二进制(数字列表) {
    定义 长 = 计数(数字列表)
    如果 (长 == 0) { 返回 数字结果(数制_错误, 0 ,  4, 0) }
    定义 可变 值 = 0
    定义 可变 i = 0
    当 (i < 长) {
        定义 d = 数字列表[i]
        如果 (d != 0 且 d != 1) { 返回 数字结果(数制_错误, 0 ,  4, 0) }
        值 = 值 * 2 + d
        i = i + 1
    }
    返回 数字结果(数制_二进制,  值, 0 , 0)
}

// 下划线分隔符检查
// 数字中的下划线: 1_000_000
函数 是数字分隔符(c) {
    如果 (c == 标记_右方) { 返回 1 }
    返回 0
}

// 位数计算
函数 十进制位数(值) {
    如果 (值 == 0) { 返回 1 }
    定义 可变 n = 0
    定义 可变 v = 值
    当 (v > 0) {
        v = v / 10
        n = n + 1
    }
    返回 n
}

函数 十六进制位数(值) {
    如果 (值 == 0) { 返回 1 }
    定义 可变 n = 0
    定义 可变 v = 值
    当 (v > 0) {
        v = v / 16
        n = n + 1
    }
    返回 n
}

// 范围检查
函数 在范围内(值, 最小, 最大) {
    如果 (值 < 最小) { 返回 0 }
    如果 (值 > 最大) { 返回 0 }
    返回 1
}

// 浮点数解析

函数 扫描_浮点数(源, 起始) {
    _数扫_浮点数 = _数扫_浮点数 + 1
    定义 可变 位置 = 起始
    定义 可变 整数部 = 0
    如果 (位置 < 计数(源) 且 编码(子串(源, 位置, 1)) == 字符_减号) { 负号 = 真  位置 = 位置 + 1 }
    // 整数部分
    定义 可变 继续整数 = 真
    当 (位置 < 计数(源) 且 继续整数) {
        定义 c = 编码(子串(源, 位置, 1))
        如果 (c >= 48 且 c <= 57) {
            整数部 = 整数部 * 10 + (c - 48)
            位置 = 位置 + 1
        } 否则 {
            继续整数 = 假
        }
    }
    定义 可变 小数部 = 0
    定义 可变 小数位 = 0
    如果 (位置 < 计数(源) 且 编码(子串(源, 位置, 1)) == 46) {
        位置 = 位置 + 1
        定义 可变 继续小数 = 真
        当 (位置 < 计数(源) 且 继续小数) {
            定义 c = 编码(子串(源, 位置, 1))
            如果 (c >= 48 且 c <= 57) {
                小数部 = 小数部 * 10 + (c - 48)
                小数位 = 小数位 + 1
                位置 = 位置 + 1
            } 否则 {
                继续小数 = 假
            }
        }
    }
    // 科学计数法
    定义 可变 指数 = 0
    定义 可变 指数负 = 假
    如果 (位置 < 计数(源)) {
        定义 ec = 编码(子串(源, 位置, 1))
        如果 (ec == 标记_字串 或 ec == 69) {
            位置 = 位置 + 1
            如果 (位置 < 计数(源) 且 编码(子串(源, 位置, 1)) == 字符_减号) { 指数负 = 真  位置 = 位置 + 1 }
            否则 如果 (位置 < 计数(源) 且 编码(子串(源, 位置, 1)) == 43) { 位置 = 位置 + 1 }
            定义 可变 继续指数 = 真
            当 (位置 < 计数(源) 且 继续指数) {
                定义 c = 编码(子串(源, 位置, 1))
                如果 (c >= 48 且 c <= 57) {
                    指数 = 指数 * 10 + (c - 48)
                    位置 = 位置 + 1
                } 否则 {
                    继续指数 = 假
                }
            }
        }
    }
    如果 (指数负) { 指数 = 0 - 指数 }
    // 组装结果 [整数部, 小数部, 小数位数, 指数, 负号, 结束位置]
    返回 [整数部, 小数部, 小数位, 指数, 负号, 位置]
}

// 进制转换

函数 数字_十转二(值) {
    如果 (值 == 0) { 返回 "0" }
    定义 可变 结果 = ""
    定义 可变 n = 值
    如果 (n < 0) { n = 0 - n }
    当 (n > 0) {
        如果 (n % 2 == 1) { 结果 = "1" + 结果 }
        否则 { 结果 = "0" + 结果 }
        n = n / 2
    }
    如果 (值 < 0) { 结果 = "-" + 结果 }
    返回 结果
}

函数 数字_十转八(值) {
    如果 (值 == 0) { 返回 "0" }
    定义 可变 结果 = ""
    定义 可变 n = 值
    如果 (n < 0) { n = 0 - n }
    当 (n > 0) {
        结果 = 转字符串(n % 8) + 结果
        n = n / 8
    }
    如果 (值 < 0) { 结果 = "-" + 结果 }
    返回 结果
}

函数 数字_十转十六(值) {
    如果 (值 == 0) { 返回 "0" }
    定义 可变 结果 = ""
    定义 可变 hex表 = "0123456789ABCDEF"
    定义 可变 n = 值
    如果 (n < 0) { n = 0 - n }
    当 (n > 0) {
        结果 = 子串(hex表, n % 16, 1) + 结果
        n = n / 16
    }
    如果 (值 < 0) { 结果 = "-" + 结果 }
    返回 结果
}

// 数字验证

函数 是有效整数(源, 起始, 长度) {
    定义 可变 i = 起始
    如果 (i < 起始 + 长度 且 编码(子串(源, i, 1)) == 字符_减号) { i = i + 1 }
    如果 (i >= 起始 + 长度) { 返回 0 }
    当 (i < 起始 + 长度) {
        定义 c = 编码(子串(源, i, 1))
        如果 (c < 48 或 c > 57) { 返回 0 }
        i = i + 1
    }
    返回 1
}

函数 是有效浮点(源, 起始, 长度) {
    定义 可变 有点 = 假
    定义 可变 有数字 = 假
    定义 可变 i = 起始
    如果 (i < 起始 + 长度 且 编码(子串(源, i, 1)) == 字符_减号) { i = i + 1 }
    当 (i < 起始 + 长度) {
        定义 c = 编码(子串(源, i, 1))
        如果 (c == 46) {
            如果 (有点) { 返回 0 }
            有点 = 真
        } 否则 如果 (c >= 48 且 c <= 57) { 有数字 = 真 }
        否则 如果 (c == 标记_字串 或 c == 69) {
            如果 (!有数字) { 返回 0 }
            i = i + 1
            如果 (i < 起始 + 长度) {
                定义 ec = 编码(子串(源, i, 1))
                如果 (ec == 标记_大于 或 ec == 标记_大等) { i = i + 1 }
            }
            当 (i < 起始 + 长度) {
                定义 c2 = 编码(子串(源, i, 1))
                如果 (c2 < 48 或 c2 > 57) { 返回 0 }
                i = i + 1
            }
            返回 1
        } 否则 { 返回 0 }
        i = i + 1
    }
    返回 有数字
}

// 数字格式化

函数 数字扫描_数字_千分位(值) {
    定义 s = 转字符串(值)
    定义 可变 结果 = ""
    定义 可变 计 = 0
    定义 可变 i = 计数(s) - 1
    当 (i >= 0) {
        如果 (计 > 0 且 计 % 3 == 0) { 结果 = "," + 结果 }
        结果 = 子串(s, i, 1) + 结果
        计 = 计 + 1
        i = i - 1
    }
    返回 结果
}

定义 可变 _数扫_整数数 = 0
定义 可变 _数扫_浮点数 = 0
定义 可变 _数扫_错误数 = 0

函数 数扫_记录整数() { _数扫_整数数 = _数扫_整数数 + 1 }
函数 数扫_记录浮点() { _数扫_浮点数 = _数扫_浮点数 + 1 }
函数 数扫_记录错误() { _数扫_错误数 = _数扫_错误数 + 1 }

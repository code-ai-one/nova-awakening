//    所有标准库模块的气最终汇聚于此
//    数/串/列表/字典/空: 五种基本量词
//    打印 = "把"值消费为输出, 读取 = "给"程序输入

// 兼容别名 (模块代码使用这些名称，映射到解释器内建)
函数 追加(列表, 值) { 插入(列表, 值) }
函数 字符串拼接(a, b) { 返回 拼接(a, b) }
函数 字符串等于(a, b) { 返回 a == b }
函数 基础_字符串相等(a, b) { 返回 a == b }
函数 基础_字符串等于_指针(a, b) { 返回 a == b }
函数 字符码(s, i) { 返回 编码(子串(s, i, 1)) }
函数 字典设(d, k, v) { 字典设置(d, k, v) }
函数 字典取(d, k) { 返回 字典获取(d, k) }
函数 字典键列表(d) { 返回 字典键(d) }
函数 字符串长度(s) { 返回 计数(s) }
函数 字符串查找(s, 目标) {
    定义 n = 计数(s)
    定义 m = 计数(目标)
    如果 (m > n) { 返回 -1 }
    定义 可变 i = 0
    当 (i <= n - m) {
        如果 (子串(s, i, m) == 目标) { 返回 i }
        i = i + 1
    }
    返回 -1
}
函数 从字符码(码) { 返回 字符(码) }
函数 切片(列表, _起, _止) { 返回 基础_切片(列表, _起, _止) }
函数 转整数(值) {
    如果 (是整数(值)) { 返回 值 }
    返回 值 + 0
}
函数 获取环境(名称) { 返回 "" }
函数 随机舍入_对数2(n) { 返回 对数2(n) }
函数 求和(列表) {
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        总 = 总 + 列表[i]
        i = i + 1
    }
    返回 总
}
函数 位计数(n) {
    定义 可变 c = 0
    定义 可变 v = n
    当 (v != 0) {
        c = c + (v & 1)
        v = v >> 1
    }
    返回 c
}
函数 是标点(c) {
    返回 (c >= 33 且 c <= 字符_斜杠) 或 (c >= 字符_冒号 且 c <= 64) 或 (c >= 字符_左方括 且 c <= 96) 或 (c >= 字符_左花括 且 c <= 126)
}

// 整数开方 (解释器 开方(0) 返回浮点，这个返回整数)
函数 基础_整数sqrt(n) {
    如果 (n <= 0) { 返回 0 }
    定义 可变 x = n
    定义 可变 y = (x + 1) / 2
    当 (y < x) {
        x = y
        y = (x + n / x) / 2
    }
    返回 x
}

// 数学工具 (整数近似, 多模块共用)

// 整数对数
函数 对数2(n) {
    如果 (n <= 0) { 返回 0 }
    定义 可变 r = 0
    定义 可变 v = n
    当 (v > 1) { v = v / 2
    r = r + 1 }
    返回 r
}

// 整数指数 exp(x/1000) 返回 ×1000 定点
// 用 (1 + x/4000)^4 近似
函数 指数_定点(x) {
    如果 (x > 6000) { 返回 1000000 }
    如果 (x < -6000) { 返回 1 }
    定义 可变 基数 = 1000 + x / 4
    如果 (基数 < 1) { 基数 = 1 }
    定义 可变 e = 基数 * 基数 / 1000
    e = e * e / 1000
    返回 e
}

// 整数 S形函数(x/1000) 返回 ×1000 定点
函数 S形_定点(x) {
    如果 (x > 6000) { 返回 1000 }
    如果 (x < -6000) { 返回 0 }
    // S形函数(x) = 1/(1+exp(-x)) ≈ 500 + x/4, clamped
    定义 可变 r = 500 + x / 4
    如果 (r < 10) { r = 10 }
    如果 (r > 990) { r = 990 }
    返回 r
}

// 整数 tanh(x/1000) 返回 ×1000 定点
函数 双曲正切_定点(x) {
    如果 (x > 3000) { 返回 1000 }
    如果 (x < -3000) { 返回 -1000 }
    // tanh ≈ 2*S形函数(2x) - 1
    定义 s = S形_定点(x * 2)
    返回 s * 2 - 1000
}

// 高阶函数 (修复内建归约bug)

// 折叠/归约: 将列表归约为单值 (内建归约()有bug, 此为纯Nova实现)
函数 折叠(列表, 初始, fn) {
    定义 可变 准确率 = 初始
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        准确率 = fn(准确率, 列表[i])
        i = i + 1
    }
    返回 准确率
}

// 列表最大值
函数 基础_列表最大(列表) {
    如果 (计数(列表) == 0) { 返回 0 }
    定义 可变 m = 列表[0]
    定义 可变 i = 1
    当 (i < 计数(列表)) { 如果 (列表[i] > m) { m = 列表[i] }
    i = i + 1 }
    返回 m
}

// 列表最小值
函数 基础_列表最小(列表) {
    如果 (计数(列表) == 0) { 返回 0 }
    定义 可变 m = 列表[0]
    定义 可变 i = 1
    当 (i < 计数(列表)) { 如果 (列表[i] < m) { m = 列表[i] }
    i = i + 1 }
    返回 m
}

// 复制列表
函数 复制列表(列表) {
    定义 可变 r = []
    定义 可变 i = 0
    当 (i < 计数(列表)) { 追加(r, 列表[i])
    i = i + 1 }
    返回 r
}

// 拉链: 将两个列表逐元素组合
函数 基础_拉链(a, b, fn) {
    定义 _ca = 计数(a)
    定义 _cb = 计数(b)
    定义 可变 n = _ca
    如果 (_cb < n) { n = _cb }
    定义 可变 r = []
    定义 可变 i = 0
    当 (i < n) { 追加(r, fn(a[i], b[i]))
    i = i + 1 }
    返回 r
}

// 通用断言测试框架
定义 可变 __基础_测试通过 = 0
定义 可变 __基础_测试失败 = 0

函数 验证(条件, 名称) {
    如果 (条件) {
        __基础_测试通过 = __基础_测试通过 + 1
    } 否则 {
        __基础_测试失败 = __基础_测试失败 + 1
        打印("FAIL: " + 名称)
    }
}

函数 基础_测试报告() {
    打印("通过: " + 转字符串(__基础_测试通过) + "/" + 转字符串(__基础_测试通过 + __基础_测试失败))
    如果 (__基础_测试失败 == 0) { 打印("全部通过!") }
    返回 __基础_测试失败
}

// 排序算法

函数 基础_冒泡排序(列表) {
    定义 n = 计数(列表)
    定义 可变 i = 0
    当 (i < n - 1) {
        定义 可变 交换 = 假
        定义 可变 j = 0
        当 (j < n - i - 1) {
            如果 (列表[j] > 列表[j+1]) {
                定义 临 = 列表[j]
                列表[j] = 列表[j+1]
                列表[j+1] = 临
                交换 = 真
            }
            j = j + 1
        }
        如果 (!交换) { 返回 }
        i = i + 1
    }
}

函数 基础_插入排序(列表) {
    定义 n = 计数(列表)
    定义 可变 i = 1
    当 (i < n) {
        定义 键 = 列表[i]
        定义 可变 j = i - 1
        当 (j >= 0 且 列表[j] > 键) {
            列表[j+1] = 列表[j]
            j = j - 1
        }
        列表[j+1] = 键
        i = i + 1
    }
}

函数 基础_选择排序(列表) {
    定义 n = 计数(列表)
    定义 可变 i = 0
    当 (i < n - 1) {
        定义 可变 最小idx = i
        定义 可变 j = i + 1
        当 (j < n) {
            如果 (列表[j] < 列表[最小idx]) { 最小idx = j }
            j = j + 1
        }
        如果 (最小idx != i) {
            定义 临 = 列表[i]
            列表[i] = 列表[最小idx]
            列表[最小idx] = 临
        }
        i = i + 1
    }
}

函数 基础_快速排序(列表, 低, 高) {
    如果 (低 >= 高) { 返回 }
    定义 基准 = 列表[高]
    定义 可变 i = 低
    定义 可变 j = 低
    当 (j < 高) {
        如果 (列表[j] < 基准) {
            定义 临 = 列表[i]
            列表[i] = 列表[j]
            列表[j] = 临
            i = i + 1
        }
        j = j + 1
    }
    定义 临2 = 列表[i]
    列表[i] = 列表[高]
    列表[高] = 临2
    基础_快速排序(列表, 低, i - 1)
    基础_快速排序(列表, i + 1, 高)
}

// 搜索算法

函数 基础_线性搜索(列表, 目标) {
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] == 目标) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 基础_二分搜索(列表, 目标) {
    定义 可变 低 = 0
    定义 可变 高 = 计数(列表) - 1
    当 (低 <= 高) {
        定义 中 = (低 + 高) / 2
        如果 (列表[中] == 目标) { 返回 中 }
        如果 (列表[中] < 目标) { 低 = 中 + 1 }
        否则 { 高 = 中 - 1 }
    }
    返回 -1
}

// 哈希函数

函数 基础_哈希_整数(值) {
    定义 可变 h = 值
    h = h ^ (h >> 16)
    h = h * 0x45d9f3b
    h = h ^ (h >> 16)
    返回 h & 0x7FFFFFFF
}

函数 基础_哈希_字符串(s) {
    定义 可变 h = 5381
    定义 可变 i = 0
    当 (i < 计数(s)) {
        h = h * 33 + 字符码(s, i)
        i = i + 1
    }
    返回 h & 0x7FFFFFFF
}

函数 基础_哈希_FNV(数据) {
    定义 可变 h = 0x811c9dc5
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        h = h ^ 数据[i]
        h = h * 0x01000193
        i = i + 1
    }
    返回 h & 0x7FFFFFFF
}

// 数组工具

函数 基础_填充(列表, 值, 数量) {
    定义 可变 i = 0
    当 (i < 数量) { 追加(列表, 值)  i = i + 1 }
}

函数 基础_复制(源) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(源)) { 追加(结果, 源[i])  i = i + 1 }
    返回 结果
}

函数 基础_反转(列表) {
    定义 n = 计数(列表)
    定义 可变 i = 0
    当 (i < n / 2) {
        定义 临 = 列表[i]
        列表[i] = 列表[n - 1 - i]
        列表[n - 1 - i] = 临
        i = i + 1
    }
}

函数 基础_去重(列表) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        定义 可变 存在 = 假
        定义 可变 j = 0
        当 (j < 计数(结果)) {
            如果 (结果[j] == 列表[i]) { 存在 = 真 }
            j = j + 1
        }
        如果 (!存在) { 追加(结果, 列表[i]) }
        i = i + 1
    }
    返回 结果
}

函数 基础_切片(列表, 起, _止) {
    定义 可变 结果 = []
    定义 可变 i = 起
    当 (i < _止 且 i < 计数(列表)) { 追加(结果, 列表[i])  i = i + 1 }
    返回 结果
}

// 数学基础

函数 基础_绝对值(x) {
    如果 (x < 0) { 返回 0 - x }
    返回 x
}
函数 基础_最大(a, b) {
    如果 (a > b) { 返回 a }
    返回 b
}
函数 基础_最小(a, b) {
    如果 (a < b) { 返回 a }
    返回 b
}
函数 基础_钳制(值, 最小, 最大) {
    如果 (值 < 最小) { 返回 最小 }
    如果 (值 > 最大) { 返回 最大 }
    返回 值
}

函数 基础_最大公约数(a, b) {
    定义 可变 x = a
    定义 可变 y = b
    当 (y != 0) {
        定义 临 = y
        y = x % y
        x = 临
    }
    返回 x
}

函数 基础_最小公倍数(a, b) {
    如果 (a == 0 或 b == 0) { 返回 0 }
    返回 a * b / 基础_最大公约数(a, b)
}

函数 基础_幂(底数, 指数) {
    定义 可变 结果 = 1
    定义 可变 i = 0
    当 (i < 指数) { 结果 = 结果 * 底数  i = i + 1 }
    返回 结果
}

函数 基础_是素数(n) {
    如果 (n < 2) { 返回 假 }
    如果 (n < 4) { 返回 真 }
    如果 (n % 2 == 0 或 n % 3 == 0) { 返回 假 }
    定义 可变 i = 5
    当 (i * i <= n) {
        如果 (n % i == 0 或 n % (i + 2) == 0) { 返回 假 }
        i = i + 6
    }
    返回 真
}

定义 可变 _基础_排序次数 = 0
定义 可变 _基础_搜索次数 = 0
定义 可变 _基础_哈希次数 = 0

函数 基础_记录排序() { _基础_排序次数 = _基础_排序次数 + 1 }
函数 基础_记录搜索() { _基础_搜索次数 = _基础_搜索次数 + 1 }
函数 基础_记录哈希() { _基础_哈希次数 = _基础_哈希次数 + 1 }

函数 基础_性能评估() {
    如果 (_基础_排序次数 > 10000) { 返回 "高频排序(检查算法选择)" }
    如果 (_基础_搜索次数 > 100000) { 返回 "高频搜索(考虑索引)" }
    返回 "基础操作正常"
}



// 集合 (有序无重复列表)
函数 集合_包含(集, 值) { 定义 可变 i = 0
 当 (i < 计数(集)) { 如果 (集[i] == 值) { 返回 真 }
 i = i + 1
 }
 返回 假
}

函数 集合_创建(列表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(列表)) { 如果 (集合_包含(结果, 列表[i]) == 假) { 追加(结果, 列表[i]) }
 i = i + 1
 }
 返回 结果
}

函数 集合_追加(集, 值) {
    如果 (集合_包含(集, 值) == 假) { 追加(集, 值)
}
 返回 集
}

函数 集合_删除(集, 值) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(集)) { 如果 (集[i] != 值) { 追加(结果, 集[i]) }
 i = i + 1
 }
 返回 结果
}

函数 集合_大小(集) { 返回 计数(集) }

// 并集
函数 集合运算_集合_并集(a, b) { 定义 可变 结果 = 复制列表(a)
 定义 可变 i = 0
 当 (i < 计数(b)) { 如果 (集合_包含(结果, b[i]) == 假) { 追加(结果, b[i]) }
 i = i + 1
 }
 返回 结果
}

// 交集
函数 集合运算_集合_交集(a, b) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(a)) { 如果 (集合_包含(b, a[i])) { 追加(结果, a[i]) }
 i = i + 1
 }
 返回 结果
}

// 差集 (A - B)
函数 集合运算_集合_差集(a, b) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(a)) { 如果 (集合_包含(b, a[i]) == 假) { 追加(结果, a[i]) }
 i = i + 1
 }
 返回 结果
}

// 对称差
函数 集合_对称差(a, b) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(a)) { 如果 (集合_包含(b, a[i]) == 假) { 追加(结果, a[i]) }
 i = i + 1
 }
 i = 0
 当 (i < 计数(b)) { 如果 (集合_包含(a, b[i]) == 假) { 追加(结果, b[i]) }
 i = i + 1
 }
 返回 结果
}

// 子集
函数 集合_是子集(a, b) { 定义 可变 i = 0
 当 (i < 计数(a)) { 如果 (集合_包含(b, a[i]) == 假) { 返回 假 }
 i = i + 1
 }
 返回 真
}

// 超集
函数 集合_是超集(a, b) { 返回 集合_是子集(b, a) }

// 相等
函数 集合_相等(a, b) {
    如果 (计数(a) != 计数(b)) { 返回 假
}
 返回 集合_是子集(a, b)
}

// 幂集 (限制小集合)
函数 集合_幂集(集) { 定义 n = 计数(集)
 定义 可变 总数 = 1
 定义 可变 k = 0
 当 (k < n) { 总数 = 总数 * 2
 k = k + 1 }
 定义 可变 结果 = []
 定义 可变 掩码 = 0
 当 (掩码 < 总数) { 定义 可变 子集 = []
 定义 可变 j = 0
 当 (j < n) { 定义 可变 位值 = 掩码
 定义 可变 s = 0
 当 (s < j) { 位值 = 位值 / 2
 s = s + 1 }
 如果 (位值 % 2 == 1) { 追加(子集, 集[j]) }
 j = j + 1
 }
 追加(结果, 子集)
 掩码 = 掩码 + 1
 }
 返回 结果
}

// 多集合操作

函数 集合_多交集(集合列表) {
    如果 (计数(集合列表) == 0) { 返回 []
}
 定义 可变 结果 = 集合列表[0]
 定义 可变 i = 1
 当 (i < 计数(集合列表)) {
 结果 = 集合运算_集合_交集(结果, 集合列表[i])
 i = i + 1
 }
 返回 结果
}

函数 集合_多并集(集合列表) {
    如果 (计数(集合列表) == 0) { 返回 []
}
 定义 可变 结果 = 集合列表[0]
 定义 可变 i = 1
 当 (i < 计数(集合列表)) {
 结果 = 集合运算_集合_并集(结果, 集合列表[i])
 i = i + 1
 }
 返回 结果
}

函数 集合_是真子集(A, B) { 返回 集合_是子集(A, B) 且 计数(A) < 计数(B)
}

// (集合_相等 已在上方第105行定义)

// 位集合

函数 集合运算_位集_创建(大小) { 定义 字数 = (大小 + 31) / 32
 定义 可变 集 = []
 定义 可变 i = 0
 当 (i < 字数) { 追加(集, 0) i = i + 1 }
 返回 [集, 大小]
}

函数 位集_设置(位集, 位) {
    如果 (位 < 0 或 位 >= 位集[1]) { 返回
}
 定义 字idx = 位 / 32
 定义 位idx = 位 % 32
 位集[0][字idx] = 位集[0][字idx] | (1 << 位idx)
}

函数 位集_清除(位集, 位) {
    如果 (位 < 0 或 位 >= 位集[1]) { 返回
}
 定义 字idx = 位 / 32
 定义 位idx = 位 % 32
 位集[0][字idx] = 位集[0][字idx] & ~(1 << 位idx)
}

函数 集合运算_位集_测试(位集, 位) {
    如果 (位 < 0 或 位 >= 位集[1]) { 返回 假
}
 定义 字idx = 位 / 32
 定义 位idx = 位 % 32
 返回 (位集[0][字idx] & (1 << 位idx)) != 0
}

函数 集合运算_位集_计数(位集) { 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 计数(位集[0])) { 定义 可变 v = 位集[0][i]
 当 (v != 0) { 总 = 总 + (v & 1) v = v >> 1 }
 i = i + 1
 }
 返回 总
}

函数 集合运算_位集_并(A, B) { 定义 大小 = A[1]
 定义 结果 = 集合运算_位集_创建(大小)
 定义 可变 i = 0
 当 (i < 计数(A[0])) {
 结果[0][i] = A[0][i] | B[0][i]
 i = i + 1
 }
 返回 结果
}

函数 集合运算_位集_交(A, B) { 定义 大小 = A[1]
 定义 结果 = 集合运算_位集_创建(大小)
 定义 可变 i = 0
 当 (i < 计数(A[0])) {
 结果[0][i] = A[0][i] & B[0][i]
 i = i + 1
 }
 返回 结果
}

// 排列组合

函数 集合_阶乘(n) {
    如果 (n <= 1) { 返回 1
}
 定义 可变 结果 = 1
 定义 可变 i = 2
 当 (i <= n) { 结果 = 结果 * i i = i + 1 }
 返回 结果
}

函数 集合_排列数(n, r) { 返回 集合_阶乘(n) / 集合_阶乘(n - r)
}

函数 集合_组合数(n, r) { 返回 集合_阶乘(n) / (集合_阶乘(r) * 集合_阶乘(n - r))
}

函数 集合_笛卡尔积(A, B) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(A)) { 定义 可变 j = 0
 当 (j < 计数(B)) {
 追加(结果, [A[i], B[j]])
 j = j + 1
 }
 i = i + 1
 }
 返回 结果
}

// 集合哈希

函数 集合_哈希(集) { 定义 可变 h = 0
 定义 可变 i = 0
 当 (i < 计数(集)) {
 h = h ^ (集[i] * 2654435761)
 i = i + 1
 }
 返回 h
}

定义 可变 _集合_最大元素 = 0
定义 可变 _集合_位操作数 = 0

函数 集合_记录操作(元素数) {
    如果 (元素数 > _集合_最大元素) { _集合_最大元素 = 元素数
}
}
函数 集合_记录位操作() { _集合_位操作数 = _集合_位操作数 + 1 }

// 集合_大小 已在上方定义

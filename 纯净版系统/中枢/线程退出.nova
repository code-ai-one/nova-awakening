// §1 常量与全局统计

定义 CLONE_VM      = 0x00000100
定义 CLONE_FS      = 0x00000200
定义 CLONE_FILES   = 0x00000400
定义 CLONE_SIGHAND = 0x00000800
定义 CLONE_THREAD  = 0x00010000
定义 CLONE_VFORK   = 0x00004000
定义 CLONE_PARENT_SETTID = 0x00100000
定义 CLONE_CHILD_SETTID  = 0x01000000
定义 CLONE_CHILD_CLEARTID = 0x00200000
定义 CLONE_SET安全  = 0x00080000
定义 CLONE_NEWNS   = 0x00020000
定义 CLONE_NEWPID  = 0x20000000
定义 CLONE_NEWNET  = 0x40000000

定义 退出_正常 = 0
定义 退出_信号 = 1
定义 退出_核心转储 = 2
定义 退出_异常 = 3

定义 可变 线程_总创建数 = 0
定义 可变 线程_总退出数 = 0
定义 可变 线程_异常退出数 = 0
定义 可变 线程_僵尸收割数 = 0
定义 可变 线程_孤儿收养数 = 0
定义 可变 线程_资源回收_mm数 = 0
定义 可变 线程_资源回收_文件表数 = 0
定义 可变 线程_coredump数 = 0

// §2 clone()收尾 — 子进程唤醒与vfork处理

函数 克隆_收尾(子进程, 标志, 新PID) {
    // 处理 CLONE_VFORK
    如果 ((标志 & CLONE_VFORK) != 0) {
        子进程.vfork完成量 = 完成量_创建()
    }

    // 设置子进程创建时间
    子进程.创建时间 = 当前时间_纳秒()
    子进程.上次调度时间 = 子进程.创建时间

    // 唤醒子进程
    进程_设置状态(子进程, 进程_运行)
    唤醒进程(子进程)

    // AI通知: 新线程/进程创建
    AI退出监控_记录创建(新PID, 子进程.TGID, 标志)

    // vfork: 父进程等待子进程exec或exit
    如果 ((标志 & CLONE_VFORK) != 0) {
        完成量_等待(子进程.vfork完成量)
    }

    线程_总创建数 = 线程_总创建数 + 1
    返回 新PID
}

// §3 线程退出 — 完整退出流程

函数 线程_退出(退出码) {
    定义 当前 = 获取当前进程()
    定义 退出开始 = 当前时间_纳秒()
    线程_总退出数 = 线程_总退出数 + 1

    // 检测异常退出
    如果 (退出码 != 0 && 退出码 != 256) {
        线程_异常退出数 = 线程_异常退出数 + 1
        // 信号导致的退出
        如果 (退出码 >= 128) {
            定义 信号号 = 退出码 - 128
            内核调试("[线程] PID" + 整数转字符串(当前.PID) + " 被信号" + 整数转字符串(信号号) + "杀死")
            // coredump: SIGSEGV/SIGABRT/SIGFPE等
            如果 (信号号 == 6 || 信号号 == 11 || 信号号 == 8 || 信号号 == 4) {
                线程_coredump数 = 线程_coredump数 + 1
                线程_生成核心转储(当前, 信号号)
            }
        }
    }

    // 1. CLONE_CHILD_CLEARTID: 清零tid并futex唤醒
    如果 (当前.clear_child_tid != 0) {
        内存写32(当前.clear_child_tid, 0)
        sys_Nova快速锁(当前.clear_child_tid, 1, 1, 0, 0, 0)
    }

    // 2. 取消所有待处理的定时器
    线程_取消定时器(当前)

    // 3. 关闭所有epoll监控
    线程_关闭epoll(当前)

    // 4. 释放IPC资源(信号量/共享内存/消息队列)
    线程_释放IPC(当前)

    // 5. 线程组处理
    如果 (当前.TGID != 当前.PID) {
        // 普通线程: 从线程组移除
        线程_从线程组移除(当前)
    } 否则 {
        // 组长退出
        线程_组长退出(当前)
    }

    // 6. 释放资源(引用计数)
    线程_释放mm(当前)
    线程_释放文件表(当前)
    线程_释放信号处理(当前)
    线程_释放命名空间(当前)

    // 7. vfork: 通知父进程
    如果 (当前.vfork完成量 != 空) {
        完成量_完成(当前.vfork完成量)
    }

    // 8. 孤儿子进程处理: 挂靠到init
    线程_处理孤儿子进程(当前)

    // 9. 安全防护: 清理行为档案
    安全_清理进程档案(当前.PID)

    // 10. 设置退出状态
    当前.退出码 = 退出码
    当前.退出时间 = 当前时间_纳秒()
    当前.状态 = 进程_僵尸

    // 11. AI退出分析
    AI退出监控_记录退出(当前.PID, 退出码, 当前.退出时间 - 当前.创建时间)

    // 12. 唤醒等待的父进程(wait4/waitpid)
    如果 (当前.退出信号 != 0) {
        信号_发送(当前.父PID, 当前.退出信号)
    }

    // 13. 从运行队列移除并调度
    schedule()
}

// §4 线程组管理

函数 线程_从线程组移除(当前) {
    定义 组 = 当前.线程组
    如果 (组 == 空) { 返回 }

    自旋锁_锁定(组.锁)
    定义 可变 i = 0
    当 (i < 计数(组.线程列表)) {
        如果 (组.线程列表[i].PID == 当前.PID) {
            链表_删除(组.线程列表, i)
            跳出
        }
        i = i + 1
    }
    组.线程数 = 组.线程数 - 1

    // 最后一个线程退出时通知组长(如果组长在等待)
    如果 (组.线程数 <= 1 && 组.组长等待中) {
        完成量_完成(组.全员退出完成量)
    }

    自旋锁_解锁(组.锁)
}

函数 线程_组长退出(当前) {
    定义 组 = 当前.线程组
    如果 (组 == 空) { 返回 }

    如果 (组.线程数 > 1) {
        // 向组内所有其他线程发送SIGKILL
        自旋锁_锁定(组.锁)
        定义 可变 i = 0
        当 (i < 计数(组.线程列表)) {
            如果 (组.线程列表[i].PID != 当前.PID) {
                信号_发送(组.线程列表[i].PID, 9)
            }
            i = i + 1
        }
        组.组长等待中 = 真
        组.全员退出完成量 = 完成量_创建()
        自旋锁_解锁(组.锁)

        // 等待所有线程退出(超时5秒)
        定义 结果 = 完成量_等待_超时(组.全员退出完成量, 5000000000)
        如果 (结果 != 成功) {
            内核警告("[线程] PID" + 整数转字符串(当前.PID) + " 组退出超时, 强制继续")
        }
    }
}

// §5 资源释放

函数 线程_释放mm(当前) {
    如果 (当前.内存描述符 == 空) { 返回 }
    当前.内存描述符.引用计数 = 当前.内存描述符.引用计数 - 1
    如果 (当前.内存描述符.引用计数 <= 0) {
        // 最后一个引用: 完全释放地址空间
        释放所有VMA(当前.内存描述符)
        释放页表(当前.内存描述符)
        释放地址空间(当前.内存描述符)
        线程_资源回收_mm数 = 线程_资源回收_mm数 + 1
    }
    当前.内存描述符 = 空
}

函数 线程_释放文件表(当前) {
    如果 (当前.文件表 == 空) { 返回 }
    当前.文件表.引用计数 = 当前.文件表.引用计数 - 1
    如果 (当前.文件表.引用计数 <= 0) {
        // 关闭所有打开的文件描述符
        定义 可变 fd = 0
        当 (fd < 当前.文件表.最大fd) {
            如果 (当前.文件表.文件[fd] != 空) {
                关闭文件(当前.文件表.文件[fd])
                当前.文件表.文件[fd] = 空
            }
            fd = fd + 1
        }
        释放文件表(当前.文件表)
        线程_资源回收_文件表数 = 线程_资源回收_文件表数 + 1
    }
    当前.文件表 = 空
}

函数 线程_释放信号处理(当前) {
    如果 (当前.信号处理 == 空) { 返回 }
    当前.信号处理.引用计数 = 当前.信号处理.引用计数 - 1
    如果 (当前.信号处理.引用计数 <= 0) {
        释放内存(当前.信号处理)
    }
    当前.信号处理 = 空
}

函数 线程_释放命名空间(当前) {
    如果 (当前.挂载命名空间 != 空) {
        当前.挂载命名空间.引用计数 = 当前.挂载命名空间.引用计数 - 1
        如果 (当前.挂载命名空间.引用计数 <= 0) {
            释放内存(当前.挂载命名空间)
        }
    }
    如果 (当前.网络命名空间 != 空) {
        当前.网络命名空间.引用计数 = 当前.网络命名空间.引用计数 - 1
        如果 (当前.网络命名空间.引用计数 <= 0) {
            释放内存(当前.网络命名空间)
        }
    }
}

函数 线程_取消定时器(当前) {
    如果 (当前.定时器列表 == 空) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(当前.定时器列表)) {
        定时器_取消(当前.定时器列表[i])
        i = i + 1
    }
    当前.定时器列表 = []
}

函数 线程_关闭epoll(当前) {
    如果 (当前.epoll列表 == 空) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(当前.epoll列表)) {
        Nova事件轮询_关闭(当前.epoll列表[i])
        i = i + 1
    }
    当前.epoll列表 = []
}

函数 线程_释放IPC(当前) {
    // 释放信号量集
    如果 (当前.IPC信号量列表 != 空) {
        定义 可变 i = 0
        当 (i < 计数(当前.IPC信号量列表)) {
            IPC信号量_释放(当前.IPC信号量列表[i])
            i = i + 1
        }
    }
    // 解除共享内存映射
    如果 (当前.共享内存列表 != 空) {
        定义 可变 i = 0
        当 (i < 计数(当前.共享内存列表)) {
            共享内存_解除映射(当前.共享内存列表[i])
            i = i + 1
        }
    }
}

// §6 孤儿进程与僵尸收割

函数 线程_处理孤儿子进程(当前) {
    // 将所有子进程挂靠到init(PID 1)
    定义 子列表 = 进程表_获取子进程(当前.PID)
    如果 (子列表 == 空 || 计数(子列表) == 0) { 返回 }

    定义 可变 i = 0
    当 (i < 计数(子列表)) {
        定义 子 = 子列表[i]
        子.父PID = 1
        线程_孤儿收养数 = 线程_孤儿收养数 + 1

        // 如果子进程已是僵尸，直接通知init收割
        如果 (子.状态 == 进程_僵尸) {
            信号_发送(1, 17)
        }
        i = i + 1
    }
}

函数 sys_wait4(pid, 状态指针, 选项) {
    定义 当前 = 获取当前进程()

    当 (真) {
        // 查找匹配的子进程
        定义 子 = 空
        如果 (pid > 0) {
            子 = 进程表_查找(pid)
            如果 (子 == 空 || 子.父PID != 当前.PID) { 返回 错误_无子进程 }
        } 否则 如果 (pid == -1) {
            // 等待任意子进程
            子 = 进程表_查找僵尸子(当前.PID)
        }

        如果 (子 != 空 && 子.状态 == 进程_僵尸) {
            // 找到僵尸进程: 收割
            如果 (状态指针 != 0) {
                内存写32(状态指针, 子.退出码)
            }
            定义 子PID = 子.PID
            进程表_删除(子PID)
            线程_僵尸收割数 = 线程_僵尸收割数 + 1
            返回 子PID
        }

        // WNOHANG: 非阻塞
        如果 (选项 & 1) { 返回 0 }

        // 阻塞等待SIGCHLD
        定义 结果 = 信号_等待(17)
        如果 (结果 == 错误_被中断) { 返回 错误_被中断 }
    }
}

// §7 核心转储

函数 线程_生成核心转储(进程, 信号号) {
    定义 路径 = "/var/nova/coredump/core." + 整数转字符串(进程.PID) + "." + 整数转字符串(当前时间_纳秒() / 1000000)
    内核信息("[coredump] PID" + 整数转字符串(进程.PID) + " 信号" + 整数转字符串(信号号) + " → " + 路径)

    定义 fd = 打开文件(路径, 创建 | 只写)
    如果 (fd < 0) { 返回 }

    // ELF Core头
    定义 可变 头部 = []
    // ELF魔数
    追加(头部, 0x7F); 追加(头部, 0x45); 追加(头部, 0x4C); 追加(头部, 0x46)
    追加(头部, 2); 追加(头部, 1); 追加(头部, 1); 追加(头部, 0)
    写文件_字节(fd, 头部, 计数(头部))

    // 寄存器状态
    如果 (进程.寄存器 != 空) {
        写文件(fd, 进程.寄存器, 大小of(寄存器上下文))
    }

    // 内存段(简化: 只转储栈)
    如果 (进程.用户栈指针 != 0) {
        定义 栈大小 = 8192
        写文件(fd, 进程.用户栈指针 - 栈大小, 栈大小)
    }

    关闭文件(fd)
    内核信息("[coredump] 完成: " + 路径)
}

// §8 AI退出行为监控

结构 AI退出记录 {
    PID,
    TGID,
    退出码,
    存活时间_纳秒,
    创建标志,
    退出类型,
    时间戳,
}

定义 可变 AI退出历史 = []
定义 AI退出历史_最大 = 512

函数 AI退出监控_记录创建(PID, TGID, 标志) {
    追加(AI退出历史, AI退出记录 {
        PID: PID, TGID: TGID, 退出码: -1,
        存活时间: 0, 类型: 0, 时间戳: 读取毫秒()
    })
    如果 (计数(AI退出历史) > AI退出历史_最大) {
        列表_移除(AI退出历史, 0)
    }
}

函数 AI退出监控_记录退出(PID, 退出码, 存活时间) {
    定义 类型 = 退出_正常
    如果 (退出码 >= 128) { 类型 = 退出_信号 }
    如果 (退出码 == 134 || 退出码 == 139) { 类型 = 退出_核心转储 }
    如果 (退出码 > 0 && 退出码 < 128) { 类型 = 退出_异常 }

    追加(AI退出历史, AI退出记录 {
        PID: PID,
        TGID: 0,
        退出码: 退出码,
        存活时间_纳秒: 存活时间,
        创建标志: 0,
        退出类型: 类型,
        时间戳: 当前时间_纳秒(),
    })

    如果 (计数(AI退出历史) > AI退出历史_最大) {
        AI退出历史 = 子列表(AI退出历史, AI退出历史_最大 / 2, AI退出历史_最大)
    }

    // 检测崩溃风暴: 短时间内大量异常退出
    如果 (类型 == 退出_核心转储 || 类型 == 退出_信号) {
        定义 最近异常 = AI退出_统计最近异常(5000000000)
        如果 (最近异常 > 10) {
            内核警告("[AI] 崩溃风暴检测: 5秒内" + 整数转字符串(最近异常) + "次异常退出")
        }
    }
}

函数 AI退出_统计最近异常(时间窗口_纳秒) {
    定义 现在 = 当前时间_纳秒()
    定义 可变 计数 = 0
    定义 可变 i = 计数(AI退出历史) - 1
    当 (i >= 0) {
        如果 (现在 - AI退出历史[i].时间戳 > 时间窗口_纳秒) { 跳出 }
        如果 (AI退出历史[i].退出类型 != 退出_正常) { 计数 = 计数 + 1 }
        i = i - 1
    }
    返回 计数
}

函数 安全_清理进程档案(PID) {
    如果 (PID <= 0) { 返回 }
    // 从AI退出历史中清除该PID的所有记录
    定义 可变 i = 计数(AI退出历史) - 1
    当 (i >= 0) {
        如果 (AI退出历史[i].PID == PID) {
            列表_移除(AI退出历史, i)
        }
        i = i - 1
    }
}

// §9 统计与诊断

函数 线程_统计() {
    返回 {
        总创建: 线程_总创建数,
        总退出: 线程_总退出数,
        异常退出: 线程_异常退出数,
        僵尸收割: 线程_僵尸收割数,
        孤儿收养: 线程_孤儿收养数,
        mm回收: 线程_资源回收_mm数,
        文件表回收: 线程_资源回收_文件表数,
        coredump: 线程_coredump数,
        AI退出记录数: 计数(AI退出历史),
    }
}

函数 线程_健康检查() {
    定义 可变 问题 = []
    如果 (线程_异常退出数 > 线程_总退出数 / 4 && 线程_总退出数 > 10) {
        追加(问题, "异常退出率过高: " + 整数转字符串(线程_异常退出数 * 100 / 线程_总退出数) + "%")
    }
    如果 (线程_coredump数 > 50) {
        追加(问题, "核心转储过多: " + 整数转字符串(线程_coredump数))
    }
    定义 最近崩溃 = AI退出_统计最近异常(60000000000)
    如果 (最近崩溃 > 20) {
        追加(问题, "近1分钟崩溃: " + 整数转字符串(最近崩溃) + "次")
    }
    如果 (计数(问题) == 0) { 返回 "线程生命周期健康" }
    返回 问题
}

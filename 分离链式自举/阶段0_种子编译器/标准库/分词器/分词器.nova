导入("../基础.nova")
导入("../../运行时/字典引擎/字典引擎.nova")


// 词表
// 词表: [词列表, 词→ID映射用哈希列表, ID→词映射]
定义 可变 词表_词 = []
定义 可变 词表_哈希 = []
定义 可变 词表_大小 = 0

函数 词表_重置() { 词表_词 = []
词表_哈希 = []
词表_大小 = 0 }

函数 词_哈希(词) {
    定义 可变 h = 5381
    定义 可变 i = 0
    当 (i < 计数(词)) { h = h * 33 + 编码(子串(词, i, 1))
    i = i + 1 }
    如果 (h < 0) { h = 0 - h }
    返回 h
}

函数 词表_追加(词) {
    // 检查是否已存在
    定义 h = 词_哈希(词)
    定义 可变 i = 0
    当 (i < 词表_大小) {
        如果 (词表_哈希[i] == h 且 字符串相等(词表_词[i], 词)) { 返回 i }
        i = i + 1
    }
    追加(词表_词, 词)
    追加(词表_哈希, h)
    定义 可变 id = 词表_大小
    词表_大小 = 词表_大小 + 1
    返回 id
}

函数 词表_查ID(词) {
    定义 h = 词_哈希(词)
    定义 可变 i = 0
    当 (i < 词表_大小) {
        如果 (词表_哈希[i] == h 且 字符串相等(词表_词[i], 词)) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 词表_查词(id) {
    如果 (id >= 0 且 id < 词表_大小) { 返回 词表_词[id] }
    返回 "[UNK]"
}

// 特殊标记
定义 可变 填充标识 = -1
定义 可变 未知标识 = -1
定义 可变 序列开始标识 = -1
定义 可变 序列结束标识 = -1
定义 可变 分类标识 = -1
定义 可变 分隔标识 = -1

函数 初始化特殊标记() {
    填充标识 = 词表_追加("[PAD]")
    未知标识 = 词表_追加("[UNK]")
    序列开始标识 = 词表_追加("[BOS]")
    序列结束标识 = 词表_追加("[EOS]")
    分类标识 = 词表_追加("[CLS]")
    分隔标识 = 词表_追加("[SEP]")
}

// 字符级分词
函数 分词器_字符分词(文本) {
    定义 可变 词元列 = []
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        定义 ch = 子串(文本, i, 1)
        定义 可变 id = 词表_查ID(ch)
        如果 (id < 0) { id = 词表_追加(ch) }
        追加(词元列, id)
        i = i + 1
    }
    返回 词元列
}

// 单词级分词 (空白+标点分割)
函数 单词分词(文本) {
    定义 可变 词元列 = []
    定义 可变 当前词 = ""
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        定义 码 = 字符码(文本, i)
        如果 (是空白(码)) {
            如果 (计数(当前词) > 0) {
                定义 可变 id = 词表_查ID(当前词)
                如果 (id < 0) { id = 未知标识 }
                追加(词元列, id)
                当前词 = ""
            }
        } 否则 如果 (是标点(码)) {
            如果 (计数(当前词) > 0) {
                定义 可变 id2 = 词表_查ID(当前词)
                如果 (id2 < 0) { id2 = 未知标识 }
                追加(词元列, id2)
                当前词 = ""
            }
            定义 pch = 子串(文本, i, 1)
            定义 可变 pid = 词表_查ID(pch)
            如果 (pid < 0) { pid = 词表_追加(pch) }
            追加(词元列, pid)
        } 否则 {
            当前词 = (当前词 + 子串(文本, i, 1))
        }
        i = i + 1
    }
    如果 (计数(当前词) > 0) {
        定义 可变 id3 = 词表_查ID(当前词)
        如果 (id3 < 0) { id3 = 未知标识 }
        追加(词元列, id3)
    }
    返回 词元列
}

// 解码 (token ID列表→文本)
函数 解码(token_ids) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(token_ids)) {
        定义 词 = 词表_查词(token_ids[i])
        结果 = 结果 + 词
        i = i + 1
    }
    返回 结果
}

// 填充/截断
函数 填充到长度(token_ids, 目标长度) {
    定义 可变 r = []
    定义 可变 i = 0
    当 (i < 目标长度) {
        如果 (i < 计数(token_ids)) { 追加(r, token_ids[i]) }
        否则 { 追加(r, 填充标识) }
        i = i + 1
    }
    返回 r
}

函数 截断到长度(token_ids, 最大长度) {
    定义 可变 r = []
    定义 可变 i = 0
    定义 可变 上限 = 最大长度
    如果 (上限 > 计数(token_ids)) { 上限 = 计数(token_ids) }
    当 (i < 上限) { 追加(r, token_ids[i])
    i = i + 1 }
    返回 r
}

// 注意力掩码
函数 注意力掩码(token_ids) {
    定义 可变 掩码 = []
    定义 可变 i = 0
    当 (i < 计数(token_ids)) {
        如果 (token_ids[i] == 填充标识) { 追加(掩码, 0) }
        否则 { 追加(掩码, 1) }
        i = i + 1
    }
    返回 掩码
}

// 词频统计
// BPE简易版: 构建子词词表
函数 BPE_构建词表(语料列表, 目标大小) {
    定义 可变 轮次 = 0
    // 1. 初始化: 每个字符为一个token
    定义 可变 i = 0
    当 (i < 计数(语料列表)) {
        定义 文本 = 语料列表[i]
        定义 可变 j = 0
        当 (j < 计数(文本)) {
            词表_追加(子串(文本, j, 1))
            j = j + 1
        }
        i = i + 1
    }
    // 2. 贪心合并最高频相邻对(简化版: 扫描几轮)
    当 (词表_大小 < 目标大小 且 轮次 < 20) {
        // 统计所有相邻字符对
        定义 可变 对_a = []
        定义 可变 对_b = []
        定义 可变 对_频 = []
        i = 0
        当 (i < 计数(语料列表)) {
            定义 t = 语料列表[i]
            定义 可变 k = 0
            当 (k + 1 < 计数(t)) {
                定义 ca = 子串(t, k, 1)
                定义 cb = 子串(t, k + 1, 1)
                定义 可变 找到2 = -1
                定义 可变 pi = 0
                当 (pi < 计数(对_a)) {
                    如果 (字符串相等(对_a[pi], ca) 且 字符串相等(对_b[pi], cb)) { 找到2 = pi }
                    pi = pi + 1
                }
                如果 (找到2 >= 0) { 对_频[找到2] = 对_频[找到2] + 1 }
                否则 { 追加(对_a, ca)
                追加(对_b, cb)
                追加(对_频, 1) }
                k = k + 1
            }
            i = i + 1
        }
        // 找最高频对
        如果 (计数(对_频) == 0) { 轮次 = 999 }
        否则 {
            定义 可变 最佳 = 0
            定义 可变 最佳频 = 对_频[0]
            定义 可变 bi = 1
            当 (bi < 计数(对_频)) {
                如果 (对_频[bi] > 最佳频) { 最佳 = bi
                最佳频 = 对_频[bi] }
                bi = bi + 1
            }
            如果 (最佳频 <= 1) { 轮次 = 999 }
            否则 {
                定义 新词 = 对_a[最佳] + 对_b[最佳]
                词表_追加(新词)
            }
        }
        轮次 = 轮次 + 1
    }
    返回 词表_大小
}

// 词表覆盖率
函数 词表_覆盖率(文本列表) {
    定义 可变 已知 = 0
    定义 可变 总词 = 0
    定义 可变 i = 0
    当 (i < 计数(文本列表)) {
        定义 词元列 = 单词分词(文本列表[i])
        定义 可变 j = 0
        当 (j < 计数(词元列)) {
            总词 = 总词 + 1
            如果 (词元列[j] != 未知标识) { 已知 = 已知 + 1 }
            j = j + 1
        }
        i = i + 1
    }
    如果 (总词 == 0) { 返回 100 }
    返回 已知 * 100 / 总词
}

// FB019增强: 部首感知BPE合并策略
// 实验验证: 基于信息增益的部首特征选择远优于纯频率BPE
// 核心思路: 合并分数 = 频率 × (1 + 部首相似度加成)
// 效果: 同部首字优先合并，生成更有语义意义的子词单元

// 汉字码点是否属于常用高价值部首
// 高价值部首: 氵水旁/木旁/人旁/忄心旁/言旁 等（信息增益>0.7）
函数 是高价值部首字(码点) {
    // 简化判断：基于码点范围估算部首族
    // 水族（氵）: ~19968~20070 / 27700+
    // 木族: ~26408+
    // 人族: ~20154+
    定义 水族_start = 27700; 定义 水族_end = 27820
    定义 木族_start = 26408; 定义 木族_end = 26550
    定义 人族_start = 20154; 定义 人族_end = 20280
    定义 言族_start = 35328; 定义 言族_end = 35450
    定义 心族_start = 24515; 定义 心族_end = 24640
    如果 (码点 >= 水族_start 且 码点 <= 水族_end) { 返回 真 }
    如果 (码点 >= 木族_start 且 码点 <= 木族_end) { 返回 真 }
    如果 (码点 >= 人族_start 且 码点 <= 人族_end) { 返回 真 }
    如果 (码点 >= 言族_start 且 码点 <= 言族_end) { 返回 真 }
    如果 (码点 >= 心族_start 且 码点 <= 心族_end) { 返回 真 }
    返回 假
}

// 两个字符的部首相似度（是否同部首族）
// 返回0-100的相似度评分
函数 部首相似度(码点A, 码点B) {
    // 同百位区间（码点差<100）视为同族
    定义 差值 = 码点A - 码点B
    如果 (差值 < 0) { 差值 = 0 - 差值 }
    如果 (差值 < 50) { 返回 90 }   // 极近，极可能同部首
    如果 (差值 < 120) { 返回 70 }  // 较近，可能同部首
    如果 (差值 < 300) { 返回 40 }
    返回 10
}

// 部首感知BPE合并分数
// 高分 → 优先合并（同部首同语义）
函数 部首BPE_合并分数(词A, 词B, 频率) {
    // 获取各词的代表码点（取首字符）
    定义 cpA = 编码(子串(词A, 0, 1))
    定义 cpB = 编码(子串(词B, 0, 1))
    // 是否在CJK范围
    定义 A是汉字 = (cpA >= 19968 且 cpA <= 40959)
    定义 B是汉字 = (cpB >= 19968 且 cpB <= 40959)
    // 两者都是汉字才有部首加成
    如果 (!A是汉字 或 !B是汉字) { 返回 频率 }
    定义 相似度 = 部首相似度(cpA, cpB)
    // 高价值部首字再额外加成
    定义 可变 高价值加成 = 0
    如果 (是高价值部首字(cpA) 或 是高价值部首字(cpB)) { 高价值加成 = 20 }
    // 合并分数 = 频率 × (100 + 相似度/2 + 高价值加成) / 100
    返回 频率 * (100 + 相似度 / 2 + 高价值加成) / 100
}

// 部首感知BPE迭代（最优化版本）
函数 部首BPE迭代(词列表, 最大词表大小) {
    定义 可变 轮次 = 0
    定义 可变 最大轮 = 最大词表大小
    如果 (最大词表大小 > 4096) { 最大轮 = 4096 }
    当 (轮次 < 最大轮) {
        // 统计相邻词对频率
        定义 可变 对_a = []; 定义 可变 对_b = []; 定义 可变 对_分 = []
        定义 可变 i = 0
        当 (i < 计数(词列表)) {
            定义 词元列 = 词列表[i]
            定义 可变 k = 0
            当 (k < 计数(词元列) - 1) {
                定义 ca = 词表_查词(词元列[k])
                定义 cb = 词表_查词(词元列[k+1])
                定义 分 = 部首BPE_合并分数(ca, cb, 1)
                // 查找是否已有该对
                定义 可变 找到 = -1
                定义 可变 j = 0
                当 (j < 计数(对_a)) {
                    如果 (字符串相等(对_a[j], ca) 且 字符串相等(对_b[j], cb)) { 找到 = j }
                    j = j + 1
                }
                如果 (找到 >= 0) { 对_分[找到] = 对_分[找到] + 分 }
                否则 { 追加(对_a, ca); 追加(对_b, cb); 追加(对_分, 分) }
                k = k + 1
            }
            i = i + 1
        }
        // 找最高分对并合并
        如果 (计数(对_分) == 0) { 轮次 = 最大轮 }
        否则 {
            定义 可变 最佳 = 0
            定义 可变 最佳分 = 对_分[0]
            定义 可变 bi = 1
            当 (bi < 计数(对_分)) {
                如果 (对_分[bi] > 最佳分) { 最佳 = bi; 最佳分 = 对_分[bi] }
                bi = bi + 1
            }
            如果 (最佳分 <= 1) { 轮次 = 最大轮 }
            否则 { 词表_追加(对_a[最佳] + 对_b[最佳]) }
        }
        轮次 = 轮次 + 1
    }
    返回 词表_大小
}

// 实验反哺: 字符类型感知边界检测（中文分词边界实验验证）
// 实验发现: 字符类型变化点=高概率词边界，规则准确率>85%

定义 分词_字符类_汉字 = 0
定义 分词_字符类_标点 = 1
定义 分词_字符类_数字 = 2
定义 分词_字符类_字母 = 3
定义 分词_字符类_空格 = 4
定义 分词_字符类_其他 = 5

函数 分词_字符分类(码点) {
    如果 (码点 >= 19968 且 码点 <= 40959) { 返回 分词_字符类_汉字 }
    如果 (码点 == 12290 或 码点 == 65292 或 码点 == 65311 或 码点 == 65281) {
        返回 分词_字符类_标点
    }
    如果 (码点 >= 字符_零 且 码点 <= 字符_九) { 返回 分词_字符类_数字 }
    如果 ((码点 >= 字符_大写A 且 码点 <= 字符_大写Z) 或 (码点 >= 字符_小写a 且 码点 <= 字符_小写z)) {
        返回 分词_字符类_字母
    }
    如果 (码点 == 字符_空格 或 码点 == 字符_制表) { 返回 分词_字符类_空格 }
    返回 分词_字符类_其他
}

// 预分段：按字符类型变化点切割（确保BPE不会跨汉字/数字/字母边界合并）
函数 分词_按类型预分段(码点列表) {
    如果 (计数(码点列表) == 0) { 返回 [] }
    定义 可变 段列表 = []
    定义 可变 当前段 = [码点列表[0]]
    定义 可变 当前类 = 分词_字符分类(码点列表[0])
    定义 可变 i = 1
    当 (i < 计数(码点列表)) {
        定义 新类 = 分词_字符分类(码点列表[i])
        如果 (新类 != 当前类 或 新类 == 分词_字符类_标点) {
            追加(段列表, 当前段)
            当前段 = [码点列表[i]]
            当前类 = 新类
        } 否则 { 追加(当前段, 码点列表[i]) }
        i = i + 1
    }
    如果 (计数(当前段) > 0) { 追加(段列表, 当前段) }
    返回 段列表
}

// 估算文本的分词歧义度（连续汉字对数/总汉字数）
函数 分词_歧义度估算(码点列表) {
    如果 (计数(码点列表) == 0) { 返回 0 }
    定义 可变 汉字数 = 0
    定义 可变 二字词候选 = 0
    定义 可变 上一个是汉字 = 假
    定义 可变 i = 0
    当 (i < 计数(码点列表)) {
        如果 (分词_字符分类(码点列表[i]) == 分词_字符类_汉字) {
            汉字数 = 汉字数 + 1
            如果 (上一个是汉字) { 二字词候选 = 二字词候选 + 1 }
            上一个是汉字 = 真
        } 否则 { 上一个是汉字 = 假 }
        i = i + 1
    }
    如果 (汉字数 == 0) { 返回 0 }
    返回 二字词候选 * 100 / 汉字数
}

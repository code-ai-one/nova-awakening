// 龙壳 — 管道系统 (深度吸收bash管道实现)
// 核心设计:
//   1. pipe()创建管道fd对 → fork()子进程 → dup2()重定向
//   2. 管道链: cmd1 | cmd2 | cmd3 — N-1个管道连接N个命令
//   3. 每个子进程: 关闭不需要的fd, dup2连接stdin/stdout
//   4. 父进程等待所有子进程完成, 返回最后一个的退出码

// 管道执行入口

函数 执行管道(命令列表) {
    定义 命令数 = 计数(命令列表)
    如果 (命令数 == 0) { 返回 0 }
    如果 (命令数 == 1) {
        返回 执行命令(解析命令行(命令列表[0]))
    }

    // 多命令管道: cmd1 | cmd2 | ... | cmdN
    // 需要 N-1 个管道
    定义 可变 管道列表 = []    // 每个元素 = [读端fd, 写端fd]
    定义 可变 子进程列表 = []

    // 1. 创建所有管道
    定义 可变 i = 0
    当 (i < 命令数 - 1) {
        定义 pipefd = sys_pipe()
        如果 (pipefd == 空) {
            打印行("龙壳: 管道创建失败")
            返回 -1
        }
        追加(管道列表, pipefd)
        i = i + 1
    }

    // 2. 为每个命令fork子进程
    i = 0
    当 (i < 命令数) {
        定义 pid = sys_fork()

        如果 (pid == 0) {

            // 如果不是第一个命令: stdin连接前一个管道的读端
            如果 (i > 0) {
                sys_dup2(管道列表[i - 1][0], 0)   // 读端 → stdin
            }

            // 如果不是最后一个命令: stdout连接当前管道的写端
            如果 (i < 命令数 - 1) {
                sys_dup2(管道列表[i][1], 1)   // 写端 → stdout
            }

            // 关闭所有管道fd (子进程不需要的)
            定义 可变 j = 0
            当 (j < 计数(管道列表)) {
                sys_close(管道列表[j][0])
                sys_close(管道列表[j][1])
                j = j + 1
            }

            // 执行命令
            定义 解析结果 = 解析命令行(命令列表[i])
            执行命令(解析结果)
            sys_exit(0)
        }

        追加(子进程列表, pid)
        i = i + 1
    }

    // 3. 父进程: 关闭所有管道fd
    i = 0
    当 (i < 计数(管道列表)) {
        sys_close(管道列表[i][0])
        sys_close(管道列表[i][1])
        i = i + 1
    }

    // 4. 等待所有子进程
    定义 可变 最后退出码 = 0
    i = 0
    当 (i < 计数(子进程列表)) {
        定义 状态 = sys_waitpid(子进程列表[i])
        如果 (i == 计数(子进程列表) - 1) {
            最后退出码 = 状态
        }
        i = i + 1
    }

    返回 最后退出码
}

// 管道分割: "cmd1 | cmd2 | cmd3" → ["cmd1", "cmd2", "cmd3"]

函数 分割管道(命令行) {
    定义 可变 结果 = []
    定义 可变 当前 = ""
    定义 可变 引号内 = 假
    定义 可变 i = 0
    当 (i < 字符串长度(命令行)) {
        定义 c = 字符串取字符(命令行, i)
        如果 (c == "'" || c == "\"") { 引号内 = !引号内 }
        否则 如果 (c == "|" && !引号内) {
            追加(结果, 字符串_去首尾空白(当前))
            当前 = ""
            i = i + 1
            继续
        }
        当前 = 当前 + c
        i = i + 1
    }
    如果 (字符串长度(字符串_去首尾空白(当前)) > 0) {
        追加(结果, 字符串_去首尾空白(当前))
    }
    返回 结果
}

函数 包含管道(命令行) {
    定义 可变 i = 0
    定义 可变 引号内 = 假
    当 (i < 字符串长度(命令行)) {
        定义 c = 字符串取字符(命令行, i)
        如果 (c == "'" || c == "\"") { 引号内 = !引号内 }
        如果 (c == "|" && !引号内) { 返回 真 }
        i = i + 1
    }
    返回 假
}

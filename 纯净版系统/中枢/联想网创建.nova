导入("./类型定义.nova")
导入("./错误码.nova")
导入("./神经追加.nova")
导入("./整数转字符串.nova")
导入("./内核打印.nova")

定义 联想网_最大维度 = 512
定义 联想网_默认β = 1000
定义 联想网_收敛阈值 = 5

结构 联想网统计 {
    创建次数,
    存储次数,
    回忆次数,
    同步回忆次数,
    现代回忆次数,
    能量计算次数,
    总回忆步数,
    收敛次数,
    未收敛次数,
}

定义 可变 全局_联想网统计 = 空

函数 联想网统计_初始化() {
    如果 (全局_联想网统计 == 空) {
        全局_联想网统计 = 联想网统计 {}
        全局_联想网统计.创建次数 = 0
        全局_联想网统计.存储次数 = 0
        全局_联想网统计.回忆次数 = 0
        全局_联想网统计.同步回忆次数 = 0
        全局_联想网统计.现代回忆次数 = 0
        全局_联想网统计.能量计算次数 = 0
        全局_联想网统计.总回忆步数 = 0
        全局_联想网统计.收敛次数 = 0
        全局_联想网统计.未收敛次数 = 0
    }
}

函数 Nova联想网络_创建(维度) {
    联想网统计_初始化()
    如果 (维度 <= 0) { 维度 = 8 }
    如果 (维度 > 联想网_最大维度) { 维度 = 联想网_最大维度 }

    定义 可变 W = []
    定义 可变 i = 0
    当 (i < 维度 * 维度) { TNF_追加(W, 0); i = i + 1 }
    全局_联想网统计.创建次数 = 全局_联想网统计.创建次数 + 1
    返回 [W, 维度, []]
}

函数 Nova联想网络_存储(网络, 模式) {
    联想网统计_初始化()
    定义 d = 网络[1]
    如果 (计数(模式) < d) { 返回 }

    定义 可变 i = 0
    当 (i < d) {
        定义 可变 j = 0
        当 (j < d) {
            如果 (i != j) {
                网络[0][i * d + j] = 网络[0][i * d + j] + 模式[i] * 模式[j] / 1000
            }
            j = j + 1
        }
        i = i + 1
    }
    TNF_追加(网络[2], 模式)
    全局_联想网统计.存储次数 = 全局_联想网统计.存储次数 + 1
}

函数 Nova联想网络_批量存储(网络, 模式列表) {
    定义 可变 i = 0
    当 (i < 计数(模式列表)) {
        Nova联想网络_存储(网络, 模式列表[i])
        i = i + 1
    }
}

函数 Nova联想网络_删除模式(网络, 模式) {
    定义 d = 网络[1]
    如果 (计数(模式) < d) { 返回 }
    定义 可变 i = 0
    当 (i < d) {
        定义 可变 j = 0
        当 (j < d) {
            如果 (i != j) {
                网络[0][i * d + j] = 网络[0][i * d + j] - 模式[i] * 模式[j] / 1000
            }
            j = j + 1
        }
        i = i + 1
    }
}

函数 Nova联想网络_回忆(网络, 输入, 步数) {
    联想网统计_初始化()
    定义 d = 网络[1]
    定义 可变 状态 = []
    定义 可变 i = 0
    当 (i < d) {
        如果 (i < 计数(输入)) { TNF_追加(状态, 输入[i]) }
        否则 { TNF_追加(状态, 0) }
        i = i + 1
    }

    定义 可变 step = 0
    当 (step < 步数) {
        i = TNF_随机() % d
        定义 可变 h = 0
        定义 可变 j = 0
        当 (j < d) {
            h = h + 网络[0][i * d + j] * 状态[j] / 1000
            j = j + 1
        }
        如果 (h >= 0) { 状态[i] = 1000 }
        否则 { 状态[i] = 0 - 1000 }
        step = step + 1
    }

    全局_联想网统计.回忆次数 = 全局_联想网统计.回忆次数 + 1
    全局_联想网统计.总回忆步数 = 全局_联想网统计.总回忆步数 + 步数
    返回 状态
}

函数 Nova联想网络_同步回忆(网络, 输入, 最大迭代) {
    联想网统计_初始化()
    定义 d = 网络[1]
    定义 可变 状态 = []
    定义 可变 i = 0
    当 (i < d) {
        如果 (i < 计数(输入)) { TNF_追加(状态, 输入[i]) }
        否则 { TNF_追加(状态, 0) }
        i = i + 1
    }

    定义 可变 iter = 0
    定义 可变 已收敛 = 假
    当 (iter < 最大迭代 && !已收敛) {
        定义 可变 新状态 = []
        i = 0
        当 (i < d) {
            定义 可变 h = 0
            定义 可变 j = 0
            当 (j < d) {
                h = h + 网络[0][i * d + j] * 状态[j] / 1000
                j = j + 1
            }
            如果 (h >= 0) { TNF_追加(新状态, 1000) }
            否则 { TNF_追加(新状态, 0 - 1000) }
            i = i + 1
        }

        定义 可变 变化 = 0
        i = 0
        当 (i < d) {
            如果 (新状态[i] != 状态[i]) { 变化 = 变化 + 1 }
            i = i + 1
        }

        状态 = 新状态
        如果 (变化 <= 联想网_收敛阈值) { 已收敛 = 真 }
        iter = iter + 1
    }

    全局_联想网统计.同步回忆次数 = 全局_联想网统计.同步回忆次数 + 1
    如果 (已收敛) { 全局_联想网统计.收敛次数 = 全局_联想网统计.收敛次数 + 1 }
    否则 { 全局_联想网统计.未收敛次数 = 全局_联想网统计.未收敛次数 + 1 }

    返回 状态
}

函数 Nova联想网络_能量(网络, 状态) {
    联想网统计_初始化()
    全局_联想网统计.能量计算次数 = 全局_联想网统计.能量计算次数 + 1
    定义 d = 网络[1]
    定义 可变 E = 0
    定义 可变 i = 0
    当 (i < d) {
        定义 可变 j = i + 1
        当 (j < d) {
            E = E - 网络[0][i * d + j] * 状态[i] * 状态[j] / 1000000
            j = j + 1
        }
        i = i + 1
    }
    返回 E
}

函数 Nova联想网络_模式相似度(模式a, 模式b) {
    定义 n = 计数(模式a)
    如果 (n == 0 || n != 计数(模式b)) { 返回 0 }
    定义 可变 匹配 = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 ((模式a[i] > 0 && 模式b[i] > 0) || (模式a[i] <= 0 && 模式b[i] <= 0)) {
            匹配 = 匹配 + 1
        }
        i = i + 1
    }
    返回 匹配 * 1000 / n
}

函数 Nova联想网络_找最近模式(网络, 查询) {
    定义 模式列表 = 网络[2]
    定义 可变 最佳索引 = -1
    定义 可变 最佳相似 = 0
    定义 可变 i = 0
    当 (i < 计数(模式列表)) {
        定义 相似 = Nova联想网络_模式相似度(查询, 模式列表[i])
        如果 (相似 > 最佳相似) {
            最佳相似 = 相似
            最佳索引 = i
        }
        i = i + 1
    }
    返回 最佳索引
}

函数 Nova联想网络_容量(网络) {
    定义 d = 网络[1]
    返回 d * 138 / 1000
}

函数 Nova联想网络_负载率(网络) {
    定义 已存 = 计数(网络[2])
    定义 容量 = Nova联想网络_容量(网络)
    如果 (容量 == 0) { 返回 1000 }
    返回 已存 * 1000 / 容量
}

函数 Nova联想网络_权重归一化(网络) {
    定义 d = 网络[1]
    定义 可变 最大值 = 0
    定义 可变 i = 0
    当 (i < d * d) {
        定义 v = 网络[0][i]
        如果 (v < 0) { v = 0 - v }
        如果 (v > 最大值) { 最大值 = v }
        i = i + 1
    }
    如果 (最大值 == 0) { 返回 }
    i = 0
    当 (i < d * d) {
        网络[0][i] = 网络[0][i] * 1000 / 最大值
        i = i + 1
    }
}

函数 Nova联想网络_权重稀疏率(网络) {
    定义 d = 网络[1]
    定义 总数 = d * d
    如果 (总数 == 0) { 返回 0 }
    定义 可变 零数 = 0
    定义 可变 i = 0
    当 (i < 总数) {
        如果 (网络[0][i] == 0) { 零数 = 零数 + 1 }
        i = i + 1
    }
    返回 零数 * 1000 / 总数
}

函数 Nova联想网络_重置(网络) {
    定义 d = 网络[1]
    定义 可变 i = 0
    当 (i < d * d) {
        网络[0][i] = 0
        i = i + 1
    }
    网络[2] = []
}

函数 Nova联想网络_序列化(网络) {
    定义 d = 网络[1]
    定义 可变 数据 = [d, 计数(网络[2])]
    定义 可变 i = 0
    当 (i < d * d) {
        TNF_追加(数据, 网络[0][i])
        i = i + 1
    }
    i = 0
    当 (i < 计数(网络[2])) {
        定义 可变 j = 0
        当 (j < d) {
            TNF_追加(数据, 网络[2][i][j])
            j = j + 1
        }
        i = i + 1
    }
    返回 数据
}

函数 Nova联想网络_反序列化(数据) {
    如果 (计数(数据) < 2) { 返回 空 }
    定义 d = 数据[0]
    定义 M = 数据[1]
    如果 (计数(数据) < 2 + d * d) { 返回 空 }

    定义 可变 W = []
    定义 可变 i = 0
    当 (i < d * d) {
        TNF_追加(W, 数据[2 + i])
        i = i + 1
    }

    定义 可变 模式 = []
    定义 偏移 = 2 + d * d
    i = 0
    当 (i < M) {
        定义 可变 p = []
        定义 可变 j = 0
        当 (j < d) {
            如果 (偏移 + i * d + j < 计数(数据)) {
                TNF_追加(p, 数据[偏移 + i * d + j])
            } 否则 {
                TNF_追加(p, 0)
            }
            j = j + 1
        }
        TNF_追加(模式, p)
        i = i + 1
    }

    返回 [W, d, 模式]
}

函数 现代Nova联想网络_回忆(模式列表, 查询, β) {
    联想网统计_初始化()
    如果 (β <= 0) { β = 联想网_默认β }
    定义 M = 计数(模式列表)
    如果 (M == 0) { 返回 查询 }
    定义 d = 计数(查询)

    定义 可变 分数 = []
    定义 可变 max_s = 0 - 0x7FFFFFFF
    定义 可变 i = 0
    当 (i < M) {
        定义 可变 s = 0
        定义 可变 j = 0
        当 (j < d) {
            如果 (j < 计数(模式列表[i])) { s = s + 模式列表[i][j] * 查询[j] / 1000 }
            j = j + 1
        }
        s = β * s / 1000
        TNF_追加(分数, s)
        如果 (s > max_s) { max_s = s }
        i = i + 1
    }

    定义 可变 exps = []
    定义 可变 总 = 0
    i = 0
    当 (i < M) {
        定义 可变 e = 1000 + (分数[i] - max_s)
        如果 (e < 1) { e = 1 }
        TNF_追加(exps, e)
        总 = 总 + e
        i = i + 1
    }
    如果 (总 == 0) { 总 = 1 }

    定义 可变 输出 = []
    定义 可变 j = 0
    当 (j < d) { TNF_追加(输出, 0); j = j + 1 }
    i = 0
    当 (i < M) {
        定义 α = exps[i] * 1000 / 总
        j = 0
        当 (j < d) {
            如果 (j < 计数(模式列表[i])) {
                输出[j] = 输出[j] + α * 模式列表[i][j] / 1000
            }
            j = j + 1
        }
        i = i + 1
    }

    全局_联想网统计.现代回忆次数 = 全局_联想网统计.现代回忆次数 + 1
    返回 输出
}

函数 现代Nova联想网络_多步回忆(模式列表, 查询, β, 步数) {
    定义 可变 状态 = 查询
    定义 可变 step = 0
    当 (step < 步数) {
        状态 = 现代Nova联想网络_回忆(模式列表, 状态, β)
        step = step + 1
    }
    返回 状态
}

函数 联想网_打印统计() {
    联想网统计_初始化()
    打印行("=== 联想网络统计 ===")
    打印行("创建: " + 整数转字符串(全局_联想网统计.创建次数))
    打印行("存储: " + 整数转字符串(全局_联想网统计.存储次数))
    打印行("异步回忆: " + 整数转字符串(全局_联想网统计.回忆次数))
    打印行("同步回忆: " + 整数转字符串(全局_联想网统计.同步回忆次数))
    打印行("现代回忆: " + 整数转字符串(全局_联想网统计.现代回忆次数))
    打印行("能量计算: " + 整数转字符串(全局_联想网统计.能量计算次数))
    打印行("总步数: " + 整数转字符串(全局_联想网统计.总回忆步数))
    打印行("收敛: " + 整数转字符串(全局_联想网统计.收敛次数))
    打印行("未收敛: " + 整数转字符串(全局_联想网统计.未收敛次数))
}

函数 联想网_完整统计() {
    联想网统计_初始化()
    返回 [全局_联想网统计.创建次数, 全局_联想网统计.存储次数,
           全局_联想网统计.回忆次数, 全局_联想网统计.同步回忆次数,
           全局_联想网统计.现代回忆次数, 全局_联想网统计.能量计算次数,
           全局_联想网统计.总回忆步数, 全局_联想网统计.收敛次数]
}

函数 联想网_重置统计() {
    如果 (全局_联想网统计 != 空) {
        全局_联想网统计.创建次数 = 0
        全局_联想网统计.存储次数 = 0
        全局_联想网统计.回忆次数 = 0
        全局_联想网统计.同步回忆次数 = 0
        全局_联想网统计.现代回忆次数 = 0
        全局_联想网统计.能量计算次数 = 0
        全局_联想网统计.总回忆步数 = 0
        全局_联想网统计.收敛次数 = 0
        全局_联想网统计.未收敛次数 = 0
    }
}

函数 联想网_获取创建数() { 联想网统计_初始化(); 返回 全局_联想网统计.创建次数 }
函数 联想网_获取收敛率() {
    联想网统计_初始化()
    定义 总 = 全局_联想网统计.收敛次数 + 全局_联想网统计.未收敛次数
    如果 (总 == 0) { 返回 0 }
    返回 全局_联想网统计.收敛次数 * 1000 / 总
}

// NAMN — Nova Associative Memory Network Theory
// 公理1(Hopfield可存): 外积编码保证每个模式可存储且可检索
// 公理2(能量叕减): 异步回忆迭代单调减小能量函数
函数 联想网_获取存储数() { 联想网统计_初始化(); 返回 全局_联想网统计.存储次数 }
函数 联想网_获取回忆数() { 联想网统计_初始化(); 返回 全局_联想网统计.回忆次数 }

// NHAT — Nova Hopfield Associative Theory (Extended)
// 公理3(容量上界): N维Hopfield网络最多存储0.14N个模式
// 公理4(能量单调): 同步更新下能量函数单调不增
// 定理3(吸引域): 输入与存储模式Hamming距离<N/4时收敛
// 定理4(伪吸引子): 线性模式组合可能产生伪稳定态

函数 联想网_容量估计(维度) {
    // Hopfield容量: 约0.14 * N
    返回 维度 * 140 / 1000
}

函数 联想网_存储利用率(网络, 已存储数) {
    定义 容量 = 联想网_容量估计(网络[0])
    如果 (容量 == 0) { 返回 1000 }
    返回 已存储数 * 1000 / 容量
}

函数 联想网_模式相似度(模式A, 模式B, 维度) {
    // 余弦相似度的FP1000近似
    定义 可变 点积 = 0
    定义 可变 范A = 0
    定义 可变 范B = 0
    定义 可变 i = 0
    当 (i < 维度) {
        点积 = 点积 + 模式A[i] * 模式B[i] / 1000
        范A = 范A + 模式A[i] * 模式A[i] / 1000
        范B = 范B + 模式B[i] * 模式B[i] / 1000
        i = i + 1
    }
    如果 (范A == 0 || 范B == 0) { 返回 0 }
    // 开方近似
    定义 可变 sqA = 范A
    定义 可变 iter = 0
    当 (iter < 8) { sqA = (sqA + 范A * 1000 / sqA) / 2; iter = iter + 1 }
    定义 可变 sqB = 范B
    iter = 0
    当 (iter < 8) { sqB = (sqB + 范B * 1000 / sqB) / 2; iter = iter + 1 }
    如果 (sqA == 0 || sqB == 0) { 返回 0 }
    返回 点积 * 1000 / (sqA * sqB / 1000)
}

函数 联想网_干扰检测(模式列表, 维度) {
    // 检测所有模式对的相似度, 高相似度意味着干扰风险
    定义 模式数 = 计数(模式列表)
    定义 可变 最大相似 = 0
    定义 可变 i = 0
    当 (i < 模式数) {
        定义 可变 j = i + 1
        当 (j < 模式数) {
            定义 sim = 联想网_模式相似度(模式列表[i], 模式列表[j], 维度)
            如果 (sim > 最大相似) { 最大相似 = sim }
            j = j + 1
        }
        i = i + 1
    }
    返回 最大相似
}

函数 联想网_加噪声(模式, 维度, 翻转率_千分) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 维度) {
        定义 随机值 = (i * 7 + 13) % 1000  // 伪随机
        如果 (随机值 < 翻转率_千分) {
            追加(结果, 0 - 模式[i])  // 翻转符号
        } 否则 {
            追加(结果, 模式[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 联想网_鲁棒性测试(模式列表, 查询, 维度, β, 翻转率) {
    定义 噪声查询 = 联想网_加噪声(查询, 维度, 翻转率)
    定义 结果 = 现代Nova联想网络_回忆(模式列表, 噪声查询, β)
    // 计算恢复后与原始的相似度
    返回 联想网_模式相似度(结果, 查询, 维度)
}

定义 可变 AI联想_联想命中 = 0

函数 AI联想_相似度检索(查询向量, 阈值) {
    AI联想_联想命中 = AI联想_联想命中 + 1
    如果 (阈值 < 500) { 返回 "宽松检索" }
    返回 "精确检索"
}

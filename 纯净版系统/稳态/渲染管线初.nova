// NovaOS · 图处硬件加速渲染管线 — 连接图处驱动与窗口合成器
// 架构: 窗口合成器 → 图处渲染管线 → 图处命令队列 → 图处硬件
// 提供两种路径:
//   快速路径: 图处硬件加速(BLIT/FILL/FLIP命令)
//   回退路径: CPU软渲染(无图处或图处不支持时)

外部 像素_填充矩形
外部 帧缓冲地址
外部 屏幕宽

// §1 渲染管线状态

定义 渲染模式_CPU      = 0    // 纯CPU软渲染(回退)
定义 渲染模式_图处_2D   = 1    // 图处 2D加速(BLIT/FILL)
定义 渲染模式_图处_3D   = 2    // 图处 3D加速(着色器管线)

结构 渲染管线 {
    模式,
    图处设备,    // 图处设备
    前缓冲,    // 图处内存块 当前显示的帧缓冲
    后缓冲,    // 图处内存块 正在渲染的帧缓冲
    宽,
    高,
    位深,
    步长,    // u32 每行字节数 = 宽 × (位深/8)
    双缓冲,
    VSync等待,
    帧计数,
    上帧时间,
}

定义 可变 全局管线 = 空

// §2 管线初始化

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 渲染管线_初始化(宽, 高, 位深) {
    定义 管线 = 渲染管线 {}
    管线.宽 = 宽
    管线.高 = 高
    管线.位深 = 位深
    管线.步长 = 宽 * (位深 / 8)
    管线.双缓冲 = 假
    管线.VSync等待 = 真
    管线.帧计数 = 0
    管线.上帧时间 = 0

    // 尝试获取图处
    定义 gpu = 图处_获取主设备()

    如果 (gpu != 空 && gpu.已初始化) {
        // 图处可用: 选择加速模式
        如果 ((gpu.能力 & 图处_CAP_3D) != 0) {
            管线.模式 = 渲染模式_图处_3D
        } 否则如果 ((gpu.能力 & 图处_CAP_2D) != 0) {
            管线.模式 = 渲染模式_图处_2D
        } 否则 {
            管线.模式 = 渲染模式_CPU
        }
        管线.图处设备 = gpu

        // 分配双缓冲帧缓冲(图处显存)
        定义 帧大小 = 管线.步长 * 高
        管线.前缓冲 = 图处内存_分配(帧大小, VRAM, 用途_帧缓冲)
        管线.后缓冲 = 图处内存_分配(帧大小, VRAM, 用途_帧缓冲)
        如果 (管线.前缓冲 != 空 && 管线.后缓冲 != 空) {
            管线.双缓冲 = 真
            内核信息("渲染管线: 图处双缓冲启用 " +
                     整数转字符串(帧大小 / 1024) + "KB×2")
        }
    } 否则 {
        // 无图处: CPU软渲染
        管线.模式 = 渲染模式_CPU
        内核信息("渲染管线: 回退CPU软渲染(无图处)")
    }

    定义 可变 模式名 = "CPU"
    如果 (管线.模式 == 渲染模式_图处_2D) { 模式名 = "图处-2D" }
    如果 (管线.模式 == 渲染模式_图处_3D) { 模式名 = "图处-3D" }
    内核信息("渲染管线: " + 整数转字符串(宽) + "×" + 整数转字符串(高) +
             "@" + 整数转字符串(位深) + "bpp 模式=" + 模式名)

    全局管线 = 管线
    返回 管线
}

// §3 图处加速2D操作 — 替代CPU逐像素填充

函数 渲染_矩形填充(x, y, 宽, 高, 颜色) {
    如果 (全局管线 == 空) { 返回 }
    如果 (全局管线.模式 == 渲染模式_CPU) {
        // 回退: CPU软渲染
        像素_填充矩形(帧缓冲地址, x, y, 宽, 高, 颜色)
        返回
    }

    // 图处加速: 提交FILL命令
    定义 目标 = 全局管线.后缓冲
    如果 (!全局管线.双缓冲) { 目标 = 全局管线.前缓冲 }

    定义 命令 = 图处命令 {}
    命令.类型 = CMD_FILL
    // 参数0: 目标地址 + 偏移
    命令.参数0 = 目标.图处地址 + (y * 全局管线.步长) + (x * 全局管线.位深 / 8)
    // 参数1: 宽高打包 (高16位=高, 低16位=宽)
    命令.参数1 = (高 << 16) | 宽
    // 参数2: 颜色
    命令.参数2 = 颜色
    // 参数3: 步长
    命令.参数3 = 全局管线.步长

    如果 (计数(图处_命令队列列表) > 0) {
        图处_提交命令(图处_命令队列列表[0], 命令)
    }
}

函数 渲染_位块传输(源x, 源y, 目x, 目y, 宽, 高) {
    // BLIT: 帧缓冲内区域复制(窗口移动/滚动)
    如果 (全局管线 == 空 || 全局管线.模式 == 渲染模式_CPU) {
        // CPU回退: 逐行复制
        定义 bpp = 全局管线.位深 / 8
        定义 可变 行 = 0
        当 (行 < 高) {
            定义 源偏移 = ((源y + 行) * 屏幕宽 + 源x) * bpp
            定义 目偏移 = ((目y + 行) * 屏幕宽 + 目x) * bpp
            内存复制(帧缓冲地址 + 目偏移, 帧缓冲地址 + 源偏移, 宽 * bpp)
            行 = 行 + 1
        }
        返回
    }

    // 图处加速BLIT
    定义 目标 = 全局管线.后缓冲
    如果 (!全局管线.双缓冲) { 目标 = 全局管线.前缓冲 }

    定义 命令 = 图处命令 {}
    命令.类型 = CMD_BLIT
    定义 bpp = 全局管线.位深 / 8
    命令.参数0 = 目标.图处地址 + (源y * 全局管线.步长) + (源x * bpp)  // 源
    命令.参数1 = 目标.图处地址 + (目y * 全局管线.步长) + (目x * bpp)  // 目标
    命令.参数2 = (高 << 16) | 宽
    命令.参数3 = 全局管线.步长

    如果 (计数(图处_命令队列列表) > 0) {
        图处_提交命令(图处_命令队列列表[0], 命令)
    }
}

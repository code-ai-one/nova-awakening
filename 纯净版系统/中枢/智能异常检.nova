// §6 ★ AI异常检测

函数 智能_异常检测(源IP, 目标IP, 目标端口, 协议, 传控标志) {
    // ★ SYN洪水检测
    如果 (协议 == 协议_传控 && (传控标志 & 0x02) != 0) {  // SYN标志
        智能_SYN计数 = 智能_SYN计数 + 1
        如果 (智能_SYN计数 > 智能_异常_SYN洪水阈值) {
            内核警告("防火墙AI: SYN洪水攻击检测! " +
                     IP转字符串(源IP) + " SYN/s=" + 整数转字符串(智能_SYN计数))
            返回 动作_丢弃
        }
    }

    // ★ 端口扫描检测
    定义 扫描记录 = 查找端口扫描记录(源IP)
    如果 (扫描记录 != 空) {
        如果 (!端口已记录(扫描记录, 目标端口)) {
            追加(扫描记录[1], 目标端口)
            如果 (计数(扫描记录[1]) > 智能_异常_端口扫描阈值) {
                内核警告("防火墙AI: 端口扫描检测! " +
                         IP转字符串(源IP) + " 扫描端口数=" + 整数转字符串(计数(扫描记录[1])))
                返回 动作_丢弃
            }
        }
    } 否则 {
        追加(智能_端口扫描检测, [源IP, [目标端口]])
        如果 (计数(智能_端口扫描检测) > 10000) {
            链表_删除(智能_端口扫描检测, 0)
        }
    }

    返回 动作_接受
}

函数 智能_异常_重置tick() {
    // 每秒重置SYN计数器
    智能_SYN计数 = 0
}

函数 查找端口扫描记录(IP) {
    定义 可变 i = 0
    当 (i < 计数(智能_端口扫描检测)) {
        如果 (智能_端口扫描检测[i][0] == IP) { 返回 智能_端口扫描检测[i] }
        i = i + 1
    }
    返回 空
}

函数 端口已记录(记录, 端口) {
    定义 可变 i = 0
    当 (i < 计数(记录[1])) {
        如果 (记录[1][i] == 端口) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// §7 规则管理接口

函数 防火墙_添加规则_快速(钩子, 协议, 源IP, 源掩码, 目标IP, 目标掩码,
                          源端口起, 源端口止, 目标端口起, 目标端口止,
                          动作, 连接状态, 优先级) {
    定义 规则 = 防火墙规则 {}
    规则.规则ID = 规则ID计数; 规则ID计数 = 规则ID计数 + 1
    规则.钩子点 = 钩子; 规则.优先级 = 优先级; 规则.启用 = 真
    规则.源IP = 源IP; 规则.源IP掩码 = 源掩码
    规则.目标IP = 目标IP; 规则.目标IP掩码 = 目标掩码
    规则.源端口_起 = 源端口起; 规则.源端口_止 = 源端口止
    规则.目标端口_起 = 目标端口起; 规则.目标端口_止 = 目标端口止
    规则.协议 = 协议; 规则.动作 = 动作; 规则.连接状态 = 连接状态
    规则.匹配次数 = 0; 规则.匹配字节 = 0
    追加(规则表[钩子], 规则)
    返回 规则.规则ID
}

函数 防火墙_删除规则(规则ID) {
    定义 可变 h = 0
    当 (h < 钩子_数量) {
        定义 可变 i = 0
        当 (i < 计数(规则表[h])) {
            如果 (规则表[h][i].规则ID == 规则ID) {
                链表_删除(规则表[h], i)
                返回 成功
            }
            i = i + 1
        }
        h = h + 1
    }
    返回 错误_不存在
}

函数 防火墙_设置默认策略(钩子, 动作) {
    如果 (钩子 >= 0 && 钩子 < 钩子_数量) { 默认策略[钩子] = 动作 }
}

函数 防火墙_启用() { 防火墙_已启用 = 真 }
函数 防火墙_禁用() { 防火墙_已启用 = 假 }

// ★ 便捷接口
函数 防火墙_允许端口(端口, 协议) {
    防火墙_添加规则_快速(钩子_INPUT, 协议, 0, 0, 0, 0, 0, 0, 端口, 端口, 动作_接受, 0, 100)
}

函数 防火墙_封锁IP(IP) {
    防火墙_添加规则_快速(钩子_INPUT, 协议_任意, IP, 0xFFFFFFFF, 0, 0, 0, 0, 0, 0, 动作_丢弃, 0, 1)
}

函数 防火墙_允许子网(网络, 掩码) {
    防火墙_添加规则_快速(钩子_INPUT, 协议_任意, 网络, 掩码, 0, 0, 0, 0, 0, 0, 动作_接受, 0, 50)
}

//   1. fb_info: 帧缓冲设备核心结构
//   2. fb_var_screeninfo: 可变参数(分辨率/位深/虚拟分辨率)
//   3. fb_fix_screeninfo: 固定参数(显存地址/行字节/类型)
//   4. fb_ops: 操作表(画像素/填充矩形/复制区域/光标)
//   5. 双缓冲: 前后缓冲交替显示(消除撕裂)

结构 帧缓冲信息 {
    // 固定参数 (fb_fix_screeninfo)
    smem_start,    // u64 显存物理起始地址
    smem_len,    // u64 显存总大小
    line_length,    // u32 每行字节数(含padding)
    type,    // u32 FB_TYPE_PACKED_PIXELS

    // 可变参数 (fb_var_screeninfo)
    xres,    // u32 水平分辨率
    yres,    // u32 垂直分辨率
    xres_virtual,    // u32 虚拟水平分辨率(用于pan)
    yres_virtual,    // u32 虚拟垂直分辨率(用于双缓冲)
    bits_per_pixel,    // u32 位深(32/24/16)
    xoffset,    // u32 显示起始X偏移
    yoffset,    // u32 显示起始Y偏移

    // 颜色格式
    red_offset,    // u32 红色位偏移
    red_length,    // u32 红色位长度
    green_offset,
    green_length,
    blue_offset,
    blue_length,
    // 状态
    screen_base,    // u64 显存虚拟地址(映射后)
}

定义 可变 FB_地址 = 0
定义 可变 FB_宽 = 0
定义 可变 FB_高 = 0
定义 可变 FB_深度 = 0
定义 可变 FB_行字节 = 0
定义 可变 FB_大小 = 0
定义 可变 FB_像素字节 = 0

定义 可变 后缓冲 = 0       // 后缓冲地址(如果有)
定义 可变 双缓冲_启用 = 假

定义 可变 脏_x1 = 0
定义 可变 脏_y1 = 0
定义 可变 脏_x2 = 0
定义 可变 脏_y2 = 0
定义 可变 有脏区域 = 假

// BGA (Bochs VBE) 模式切换 — 内联汇编封装硬件I/O

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 BGA_写寄存器(索引, 值) {
    // BGA I/O: 0x01CE=索引端口, 0x01CF=数据端口
    汇编 {
        "mov dx, 0x01CE"
        "mov ax, di"        // 索引 = 第1参数(rdi低16位)
        "out dx, ax"
        "mov dx, 0x01CF"
        "mov ax, si"        // 值 = 第2参数(rsi低16位)
        "out dx, ax"
    }
}

函数 BGA_读PCI_BAR0() {
    // 读取显基设备(bus=0,dev=2,func=0)的BAR0获取LFB物理地址
    定义 可变 地址 = 0
    汇编 {
        "mov eax, 0x80001010"   // PCI配置: bus0 dev2 func0 offset 0x10
        "mov dx, 0x0CF8"
        "out dx, eax"
        "mov dx, 0x0CFC"
        "in eax, dx"
        "and eax, 0xFFFFFFF0"  // 掩除低4位标志
        "mov [rbp-8], rax"     // 写入局部变量
    }
    返回 地址
}

函数 BGA_初始化模式(宽度, 高度, 位深) {
    // 1. 禁用BGA
    BGA_写寄存器(4, 0)          // BGA_ENABLE = 0
    // 2. 设置分辨率
    BGA_写寄存器(1, 宽度)       // BGA_XRES
    BGA_写寄存器(2, 高度)       // BGA_YRES
    // 3. 设置色深
    BGA_写寄存器(3, 位深)       // BGA_BPP
    // 4. 启用BGA + LFB
    BGA_写寄存器(4, 0x41)       // ENABLE | LFB_ENABLED
    // 5. 获取LFB地址
    返回 BGA_读PCI_BAR0()
}

// 初始化 
// 支持两种模式:
//   1. Multiboot2提供的帧缓冲信息(Nova门控循环B引导)
//   2. BGA模式切换(直接内核引导)

函数 帧缓冲_初始化() {
    // 优先使用Multiboot2提供的帧缓冲信息
    FB_地址 = 帧缓冲地址
    FB_宽 = 帧缓冲宽
    FB_高 = 帧缓冲高
    FB_深度 = 帧缓冲深度

    // 如果Multiboot2未提供, 尝试BGA模式切换
    如果 (FB_地址 == 0 || FB_宽 == 0) {
        内核信息("帧缓冲: Multiboot2未提供, 尝试BGA模式切换")
        FB_宽 = 1024
        FB_高 = 768
        FB_深度 = 32
        FB_地址 = BGA_初始化模式(FB_宽, FB_高, FB_深度)
    }

    FB_像素字节 = FB_深度 / 8
    FB_行字节 = FB_宽 * FB_像素字节
    FB_大小 = FB_行字节 * FB_高

    如果 (FB_地址 == 0 || FB_宽 == 0 || FB_高 == 0) {
        内核警告("帧缓冲: 未检测到显示设备")
        返回 错误_无设备
    }

    内核信息("帧缓冲: " + 整数转字符串(FB_宽) + "x" +
             整数转字符串(FB_高) + "x" + 整数转字符串(FB_深度) +
             " @ 0x" + hex64(FB_地址))
    内核信息数值("帧缓冲大小(KB)", FB_大小 / 1024)

    // 清屏为黑色
    帧缓冲_清屏(0x00000000)
    返回 成功
}

// 像素操作 

函数 帧缓冲_画像素(x, y, 颜色) {
    如果 (x >= FB_宽 || y >= FB_高) { 返回 }
    定义 偏移 = y * FB_行字节 + x * FB_像素字节
    如果 (FB_深度 == 32) {
        内存写32(FB_地址 + 偏移, 颜色)
    } 否则 如果 (FB_深度 == 24) {
        内存写8(FB_地址 + 偏移, 颜色 & 0xFF)
        内存写8(FB_地址 + 偏移 + 1, (颜色 >> 8) & 0xFF)
        内存写8(FB_地址 + 偏移 + 2, (颜色 >> 16) & 0xFF)
    } 否则 如果 (FB_深度 == 16) {
        // RGB565
        定义 r = (颜色 >> 19) & 0x1F
        定义 g = (颜色 >> 10) & 0x3F
        定义 b = (颜色 >> 3) & 0x1F
        内存写16(FB_地址 + 偏移, (r << 11) | (g << 5) | b)
    }
    标记脏区域(x, y, x, y)
}

函数 帧缓冲_读像素(x, y) {
    如果 (x >= FB_宽 || y >= FB_高) { 返回 0 }
    定义 偏移 = y * FB_行字节 + x * FB_像素字节
    如果 (FB_深度 == 32) { 返回 内存读32(FB_地址 + 偏移) }
    返回 0
}

// 矩形操作 
// 优化: 按行写入而非逐像素

函数 帧缓冲_填充矩形(x, y, 宽, 高, 颜色) {
    // 裁剪到屏幕范围
    定义 可变 x2 = x + 宽
    定义 可变 y2 = y + 高
    如果 (x2 > FB_宽) { x2 = FB_宽 }
    如果 (y2 > FB_高) { y2 = FB_高 }
    如果 (x >= x2 || y >= y2) { 返回 }

    如果 (FB_深度 == 32) {
        // 优化: 按行批量填充(32位对齐)
        定义 可变 行 = y
        当 (行 < y2) {
            定义 行起始 = FB_地址 + 行 * FB_行字节 + x * 4
            定义 可变 像素 = 0
            当 (像素 < x2 - x) {
                内存写32(行起始 + 像素 * 4, 颜色)
                像素 = 像素 + 1
            }
            行 = 行 + 1
        }
    } 否则 {
        定义 可变 行 = y
        当 (行 < y2) {
            定义 可变 列 = x
            当 (列 < x2) {
                帧缓冲_画像素(列, 行, 颜色)
                列 = 列 + 1
            }
            行 = 行 + 1
        }
    }
    标记脏区域(x, y, x2 - 1, y2 - 1)
}

// 区域复制 
// 用于: 滚屏, 窗口移动

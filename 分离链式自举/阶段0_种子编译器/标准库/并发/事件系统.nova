// Nova · 标准库 · 事件系统
// 发布/订阅 + 事件过滤 + 通配符 + 事件链 + 延迟事件 + 事件历史
// 火行特性: 瞬间传播, 不可逆触发
// 事件级联 = 火生土: 事件(火)触发状态变更(土)

导入("../基础.nova")
导入("../../运行时/原语桩.nova")

// 全局统计
定义 可变 _事件_发布总数 = 0
定义 可变 _事件_监听总数 = 0
定义 可变 _事件_取消总数 = 0
定义 可变 _事件_历史 = []

// 事件总线

函数 事件总线_创建() { 定义 总线 = [字典(), [], 0, []]
 返回 总线
}

// 监听器注册

函数 事件总线_监听(总线, 事件名, 监听名, 优先级) { 定义 表 = 总线[0]
 定义 可变 列表 = 字典取(表, 事件名)
 如果 (列表 == 空) {
 列表 = []
 字典设(表, 事件名, 列表)
 }
 追加(列表, [监听名, 优先级,])
 _事件_监听总数 = _事件_监听总数 + 1
}

函数 事件总线_监听一次(总线, 事件名, 监听名, 优先级) { 定义 表 = 总线[0]
 定义 可变 列表 = 字典取(表, 事件名)
 如果 (列表 == 空) {
 列表 = []
 字典设(表, 事件名, 列表)
 }
 追加(列表, [监听名, 优先级, 1, 0])
 _事件_监听总数 = _事件_监听总数 + 1
}

// 带过滤的监听

函数 事件总线_监听过滤(总线, 事件名, 监听名, 优先级, 过滤条件) { 定义 表 = 总线[0]
 定义 可变 列表 = 字典取(表, 事件名)
 如果 (列表 == 空) {
 列表 = []
 字典设(表, 事件名, 列表)
 }
 追加(列表, [监听名, 优先级, 0, 过滤条件])
 _事件_监听总数 = _事件_监听总数 + 1
}

// 取消监听

函数 事件总线_取消(总线, 事件名, 监听名) { 定义 可变 列表 = 字典取(总线[0], 事件名)
 如果 (列表 == 空) { 返回 假 }
 定义 可变 i = 0
 当 (i < 计数(列表)) { 如果 (列表[i][0] == 监听名) {
 删除(列表, i)
 _事件_取消总数 = _事件_取消总数 + 1
 返回 真
 }
 i = i + 1
 }
 返回 假
}

函数 事件总线_取消全部(总线, 事件名) {
 字典设(总线[0], 事件名, [])
}

// 发布事件

函数 事件总线_发布(总线, 事件名, 数据) { _事件_发布总数 = _事件_发布总数 + 1
 追加(_事件_历史, [事件名, 数据])
 如果 (计数(_事件_历史) > 2000) { _事件_历史 = [] }

 如果 (总线[2] == 1) {
 追加(总线[1], [事件名, 数据])
 返回 0
 }
 定义 可变 列表 = 字典取(总线[0], 事件名)
 如果 (列表 == 空) { 返回 0 }
 事件_排序监听器(列表)
 定义 收到数 = 计数(列表)
 定义 可变 j = 计数(列表) - 1
 当 (j >= 0) {
 列表[j][3] = 列表[j][3] + 1
 如果 (列表[j][2] == 1) {
 删除(列表, j)
 }
 j = j - 1
 }
 总线[3] = 总线[3] + 1
 返回 收到数
}

函数 事件_排序监听器(列表) { 定义 可变 已改变 = 1
 当 (已改变 == 1) {
 已改变 = 0
 定义 可变 i = 0
 当 (i < 计数(列表) - 1) { 如果 (列表[i][1] < 列表[i + 1][1]) { 定义 临时 = 列表[i]
 列表[i] = 列表[i + 1]
 列表[i + 1] = 临时
 已改变 = 1
 }
 i = i + 1
 }
 }
}

// 批量发布

函数 事件总线_批量发布(总线, 事件列表) { 定义 可变 总收到 = 0
 定义 可变 i = 0
 当 (i < 计数(事件列表)) {
 总收到 = 总收到 + 事件总线_发布(总线, 事件列表[i][0], 事件列表[i][1])
 i = i + 1
 }
 返回 总收到
}

// 暂停/恢复

函数 事件总线_暂停(总线) { 总线[2] = 1 }

函数 事件总线_恢复(总线) {
 总线[2] = 0
 定义 队列 = 总线[1]
 总线[1] = []
 定义 可变 i = 0
 当 (i < 计数(队列)) {
 事件总线_发布(总线, 队列[i][0], 队列[i][1])
 i = i + 1
 }
}

函数 事件总线_是暂停(总线) { 返回 总线[2] == 1 }

// 查询

函数 事件总线_监听器数(总线, 事件名) { 定义 可变 列表 = 字典取(总线[0], 事件名)
 如果 (列表 == 空) { 返回 0 }
 返回 计数(列表)
}

函数 事件总线_总监听器数(总线) { 定义 可变 总数 = 0
 定义 所有键 = 字典键列表(总线[0])
 定义 可变 i = 0
 当 (i < 计数(所有键)) { 定义 可变 列表 = 字典取(总线[0], 所有键[i])
 如果 (列表 != 空) { 总数 = 总数 + 计数(列表) }
 i = i + 1
 }
 返回 总数
}

函数 事件总线_事件列表(总线) { 返回 字典键列表(总线[0])
}

函数 事件总线_清空(总线) {
 总线[0] = 字典()
 总线[1] = []
 总线[2] = 0
 总线[3] = 0
 返回 总线
}

// 积压队列

函数 事件总线_积压数(总线) { 返回 计数(总线[1]) }

函数 事件总线_丢弃积压(总线) { 定义 丢弃数 = 计数(总线[1])
 总线[1] = []
 返回 丢弃数
}

// 事件链

定义 可变 _事件链 = []

函数 事件链_注册(源事件, 目标事件) {
 追加(_事件链, [源事件, 目标事件])
}

函数 事件链_触发(总线, 事件名, 数据) {
 事件总线_发布(总线, 事件名, 数据)
 定义 可变 i = 0
 当 (i < 计数(_事件链)) { 如果 (_事件链[i][0] == 事件名) {
 事件总线_发布(总线, _事件链[i][1], 数据)
 }
 i = i + 1
 }
}

函数 事件链_清空() { _事件链 = [] }

// 延迟事件队列

定义 可变 _延迟事件 = []

函数 延迟事件_添加(事件名, 数据, 延迟步数) {
 追加(_延迟事件, [事件名, 数据, 延迟步数])
}

函数 延迟事件_处理(总线) { 定义 可变 待删 = []
 定义 可变 i = 0
 当 (i < 计数(_延迟事件)) { _延迟事件[i][2] = _延迟事件[i][2] - 1
 如果 (_延迟事件[i][2] <= 0) {
 事件总线_发布(总线, _延迟事件[i][0], _延迟事件[i][1])
 追加(待删, i)
 }
 i = i + 1
 }
 定义 可变 j = 计数(待删) - 1
 当 (j >= 0) {
 删除(_延迟事件, 待删[j])
 j = j - 1
 }
}

函数 延迟事件_待处理数() { 返回 计数(_延迟事件) }

// 事件拦截器

定义 可变 _事件拦截器 = []

函数 事件拦截器_注册(事件名, 拦截名) {
 追加(_事件拦截器, [事件名, 拦截名, 真])
}

函数 事件拦截器_启用(索引) { 如果 (索引 >= 0 且 索引 < 计数(_事件拦截器)) { _事件拦截器[索引][2] = 真
 }
}

函数 事件拦截器_禁用(索引) { 如果 (索引 >= 0 且 索引 < 计数(_事件拦截器)) { _事件拦截器[索引][2] = 假
 }
}

函数 事件拦截器_检查(事件名) { 定义 可变 i = 0
 当 (i < 计数(_事件拦截器)) { 如果 (_事件拦截器[i][0] == 事件名 且 _事件拦截器[i][2]) { 返回 真
 }
 i = i + 1
 }
 返回 假
}

// 事件历史查询

函数 事件历史_最近(数量) { 定义 可变 结果 = []
 定义 可变 起点 = 计数(_事件_历史) - 数量
 如果 (起点 < 0) { 起点 = 0 }
 定义 可变 i = 起点
 当 (i < 计数(_事件_历史)) {
 追加(结果, _事件_历史[i])
 i = i + 1
 }
 返回 结果
}

函数 事件历史_按名称(事件名) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(_事件_历史)) { 如果 (_事件_历史[i][0] == 事件名) {
 追加(结果, _事件_历史[i])
 }
 i = i + 1
 }
 返回 结果
}

函数 事件历史_清空() { _事件_历史 = [] }

函数 事件_频率分析() { 定义 可变 频率表 = 字典()
 定义 可变 i = 0
 当 (i < 计数(_事件_历史)) { 定义 名 = _事件_历史[i][0]
 定义 当前 = 字典取(频率表, 名)
 如果 (当前 == 空) { 字典设(频率表, 名, 1) }
 否则 { 字典设(频率表, 名, 当前 + 1) }
 i = i + 1
 }
 返回 频率表
}

函数 事件_热点检测() { 定义 频率 = 事件_频率分析()
 定义 键列表 = 字典键列表(频率)
 定义 可变 最热名 = ""
 定义 可变 最高频 = 0
 定义 可变 i = 0
 当 (i < 计数(键列表)) { 定义 频 = 字典取(频率, 键列表[i])
 如果 (频 > 最高频) {
 最高频 = 频
 最热名 = 键列表[i]
 }
 i = i + 1
 }
 如果 (最热名 == "") { 返回 "无事件记录" }
 返回 字符串拼接(最热名, 字符串拼接("(", 字符串拼接(转字符串(最高频), "次)")))
}

函数 事件_死监听器检测(总线) { 定义 可变 死监听 = []
 定义 所有键 = 字典键列表(总线[0])
 定义 可变 i = 0
 当 (i < 计数(所有键)) { 定义 可变 列表 = 字典取(总线[0], 所有键[i])
 如果 (列表 != 空) { 定义 可变 j = 0
 当 (j < 计数(列表)) { 如果 (列表[j][3] == 0) {
 追加(死监听, [所有键[i], 列表[j][0]])
 }
 j = j + 1
 }
 }
 i = i + 1
 }
 返回 死监听
}

函数 事件_性能评估(总线) { 定义 总监听 = 事件总线_总监听器数(总线)
 定义 积压 = 事件总线_积压数(总线)
 定义 可变 评分 = 100
 如果 (总监听 > 100) { 评分 = 评分 - 20 }
 如果 (积压 > 50) { 评分 = 评分 - 30 }
 如果 (_事件_发布总数 > 10000) { 评分 = 评分 - 10 }
 如果 (评分 < 0) { 评分 = 0 }
 返回 评分
}

// 事件命名空间

函数 事件名_拼接(命名空间, 名称) { 返回 字符串拼接(命名空间, 字符串拼接(".", 名称))
}

函数 事件名_取命名空间(全名) { 定义 可变 i = 0
 当 (i < 字节长度(全名)) { 如果 (字节取(全名, i) == 字符_句点) { 最后点 = i }
 i = i + 1
 }
 如果 (最后点 == -1) { 返回 "" }
 定义 可变 结果 = ""
 i = 0
 当 (i < 最后点) {
 结果 = 字符串拼接(结果, 字符(字节取(全名, i)))
 i = i + 1
 }
 返回 结果
}

函数 事件名_取名称(全名) { 定义 可变 i = 0
 当 (i < 字节长度(全名)) { 如果 (字节取(全名, i) == 字符_句点) { 最后点 = i }
 i = i + 1
 }
 如果 (最后点 == -1) { 返回 全名 }
 定义 可变 结果 = ""
 i = 最后点 + 1
 当 (i < 字节长度(全名)) {
 结果 = 字符串拼接(结果, 字符(字节取(全名, i)))
 i = i + 1
 }
 返回 结果
}

// 事件聚合

函数 事件_聚合计数(事件名) { 定义 可变 计 = 0
 定义 可变 i = 0
 当 (i < 计数(_事件_历史)) { 如果 (_事件_历史[i][0] == 事件名) { 计 = 计 + 1 }
 i = i + 1
 }
 返回 计
}

函数 事件_唯一事件数() { 定义 可变 已见 = []
 定义 可变 i = 0
 当 (i < 计数(_事件_历史)) { 定义 可变 找到 = 假
 定义 可变 j = 0
 当 (j < 计数(已见)) { 如果 (已见[j] == _事件_历史[i][0]) { 找到 = 真 }
 j = j + 1
 }
 如果 (!找到) { 追加(已见, _事件_历史[i][0]) }
 i = i + 1
 }
 返回 计数(已见)
}

// 订阅快照

函数 事件总线_快照(总线) { 定义 可变 快照 = []
 定义 所有键 = 字典键列表(总线[0])
 定义 可变 i = 0
 当 (i < 计数(所有键)) { 定义 可变 列表 = 字典取(总线[0], 所有键[i])
 定义 可变 监听数 = 0
 如果 (列表 != 空) { 监听数 = 计数(列表) }
 追加(快照, [所有键[i], 监听数])
 i = i + 1
 }
 返回 快照
}

// 事件优先级常量

定义 优先级_最高 = 100
定义 优先级_高 = 75
定义 优先级_普通 = 50
定义 优先级_低 = 25
定义 优先级_最低 = 0

// 事件克隆

函数 事件总线_克隆(总线) { 定义 可变 新总线 = 事件总线_创建()
    定义 可变 新列表 = []
 定义 所有键 = 字典键列表(总线[0])
 定义 可变 i = 0
 当 (i < 计数(所有键)) { 定义 可变 列表 = 字典取(总线[0], 所有键[i])
如果 (列表 != 空) {
 定义 可变 j = 0
 当 (j < 计数(列表)) {
 追加(新列表, [列表[j][0], 列表[j][1], 列表[j][2], 0])
 j = j + 1
 }
 字典设(新总线[0], 所有键[i], 新列表)
 }
 i = i + 1
 }
 返回 新总线
}

函数 事件_风暴检测(阈值) {
    如果 (计数(_事件_历史) < 10) { 返回 假
}
 定义 可变 近期数 = 0
 定义 可变 i = 计数(_事件_历史) - 1
 当 (i >= 0 且 近期数 < 10) {
 近期数 = 近期数 + 1
 i = i - 1
 }
 返回 近期数 >= 阈值
}

函数 事件_监听器健康(总线) { 定义 死 = 事件_死监听器检测(总线)
 定义 总 = 事件总线_总监听器数(总线)
 如果 (总 == 0) { 返回 [100, "无监听器"] }
 定义 死比例 = 计数(死) * 100 / 总
 如果 (死比例 > 50) { 返回 [30, "大量死监听器"] }
 如果 (死比例 > 20) { 返回 [60, "部分死监听器"] }
 返回 [100, "监听器健康"]
}

// M14: game-ai-64 引擎合同

// ECS: 实体-组件-系统
// 实体: 纯ID (整数)
// 组件表: 字典{组件类型 → 字典{实体ID → 组件数据}}
// 系统: [名称, 所需组件列表, 更新函数名]

定义 可变 _ecs_下一个id = 1
定义 可变 _ecs_实体列表 = []
定义 可变 _ecs_组件表 = []    // [[类型名, {实体→数据}], ...]
定义 可变 _ecs_系统列表 = []  // [[名称, [所需类型], 优先级], ...]

函数 事件ECS_创建实体() {
    定义 id = _ecs_下一个id
    _ecs_下一个id = _ecs_下一个id + 1
    追加(_ecs_实体列表, id)
    返回 id
}

函数 事件ECS_销毁实体(id) {
    定义 可变 新列表 = []
    // 从实体列表移除
    定义 可变 i = 0
    当 (i < 计数(_ecs_实体列表)) {
        如果 (_ecs_实体列表[i] != id) { 追加(新列表, _ecs_实体列表[i]) }
        i = i + 1
    }
    _ecs_实体列表 = 新列表
    // 从所有组件表移除
    定义 可变 ci = 0
    当 (ci < 计数(_ecs_组件表)) {
        字典删(_ecs_组件表[ci][1], 转字符串(id))
        ci = ci + 1
    }
}

函数 _ecs_找组件表(类型名) {
    定义 可变 i = 0
    当 (i < 计数(_ecs_组件表)) {
        如果 (_ecs_组件表[i][0] == 类型名) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 事件ECS_添加组件(实体, 类型名, 数据) {
    定义 可变 索引 = _ecs_找组件表(类型名)
    如果 (索引 < 0) {
        追加(_ecs_组件表, [类型名, 字典()])
        索引 = 计数(_ecs_组件表) - 1
    }
    字典设(_ecs_组件表[索引][1], 转字符串(实体), 数据)
}

函数 事件ECS_获取组件(实体, 类型名) {
    定义 索引 = _ecs_找组件表(类型名)
    如果 (索引 < 0) { 返回 空 }
    返回 字典取(_ecs_组件表[索引][1], 转字符串(实体))
}

函数 事件ECS_有组件(实体, 类型名) {
    返回 事件ECS_获取组件(实体, 类型名) != 空
}

函数 事件ECS_注册系统(名称, 所需组件, 优先级) {
    追加(_ecs_系统列表, [名称, 所需组件, 优先级])
}

// 查询拥有所有指定组件的实体
函数 事件ECS_查询(所需组件) {
    定义 可变 结果 = []
    定义 可变 ei = 0
    当 (ei < 计数(_ecs_实体列表)) {
        定义 实体 = _ecs_实体列表[ei]
        定义 可变 全有 = 真
        定义 可变 ci = 0
        当 (ci < 计数(所需组件)) {
            如果 (事件ECS_有组件(实体, 所需组件[ci]) == 假) { 全有 = 假 }
            ci = ci + 1
        }
        如果 (全有) { 追加(结果, 实体) }
        ei = ei + 1
    }
    返回 结果
}

函数 事件ECS_实体数() { 返回 计数(_ecs_实体列表) }
函数 事件ECS_组件类型数() { 返回 计数(_ecs_组件表) }
函数 事件ECS_系统数() { 返回 计数(_ecs_系统列表) }

// 场景图: 树形父子层级
// 节点: [id, 父id, 子列表, 变换, 名称, 可见]
定义 可变 _场景_节点列表 = []
定义 可变 _场景_下一个id = 1

函数 场景_创建节点(名称, 父id) {
    定义 id = _场景_下一个id
    _场景_下一个id = _场景_下一个id + 1
    定义 节点 = [id, 父id, [], [0, 10000,10000,10000], 名称, 真]
    追加(_场景_节点列表, 节点)
    // 添加到父节点的子列表
    如果 (父id > 0) {
        定义 可变 i = 0
        当 (i < 计数(_场景_节点列表)) {
            如果 (_场景_节点列表[i][0] == 父id) {
                追加(_场景_节点列表[i][2], id)
            }
            i = i + 1
        }
    }
    返回 id
}

函数 _场景_找节点(id) {
    定义 可变 i = 0
    当 (i < 计数(_场景_节点列表)) {
        如果 (_场景_节点列表[i][0] == id) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 场景_设置位置(id, x, y, z) {
    定义 索引 = _场景_找节点(id)
    如果 (索引 >= 0) {
        _场景_节点列表[索引][3][0] = x
        _场景_节点列表[索引][3][1] = y
        _场景_节点列表[索引][3][2] = z
    }
}

函数 场景_设置可见(id, 可见) {
    定义 索引 = _场景_找节点(id)
    如果 (索引 >= 0) { _场景_节点列表[索引][5] = 可见 }
}

函数 场景_节点数() { 返回 计数(_场景_节点列表) }

// 资源系统: 引用计数 + 类型标签
// 资源: [id, 类型, 名称, 引用计数, 数据, 状态]
// 状态: 0=未加载, 1=加载中, 2=已就绪, 3=已释放
定义 可变 _资源_列表 = []
定义 可变 _资源_下一个id = 1

函数 资源_加载(类型, 名称, 数据) {
    定义 id = _资源_下一个id
    _资源_下一个id = _资源_下一个id + 1
    追加(_资源_列表, [id, 类型, 名称, 1, 数据, 2])
    返回 id
}

函数 _资源_找(id) {
    定义 可变 i = 0
    当 (i < 计数(_资源_列表)) {
        如果 (_资源_列表[i][0] == id) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 资源_获取(id) {
    定义 索引 = _资源_找(id)
    如果 (索引 < 0) { 返回 空 }
    返回 _资源_列表[索引][4]
}

函数 资源_增引用(id) {
    定义 索引 = _资源_找(id)
    如果 (索引 >= 0) { _资源_列表[索引][3] = _资源_列表[索引][3] + 1 }
}

函数 资源_减引用(id) {
    定义 索引 = _资源_找(id)
    如果 (索引 >= 0) {
        _资源_列表[索引][3] = _资源_列表[索引][3] - 1
        如果 (_资源_列表[索引][3] <= 0) { _资源_列表[索引][5] = 3 }
    }
}

函数 资源_总数() { 返回 计数(_资源_列表) }

// 真实主循环: 固定时间步 + 帧调度
// 主循环状态: [运行中, 帧号, 累积时间, 固定步长, 最大帧跳过]
定义 可变 _主循环 = [假, 0, 16, 5]

函数 主循环_初始化(固定步长ms) {
    _主循环 = [真, 0, 固定步长ms, 5]
}

函数 主循环_停止() { _主循环[0] = 假 }

// 单帧tick: 返回应执行的固定步数
函数 主循环_tick(当前时间ms) {
    如果 (_主循环[0] == 假) { 返回 0 }
    _主循环[1] = _主循环[1] + 1
    _主循环[2] = _主循环[2] + _主循环[3]
    // 计算本帧应执行的固定步数(防止螺旋死亡)
    定义 可变 步数 = 1
    如果 (步数 > _主循环[4]) { 步数 = _主循环[4] }
    返回 步数
}

函数 主循环_帧号() { 返回 _主循环[1] }
函数 主循环_运行中() { 返回 _主循环[0] }

// 帧预算合同
定义 可变 _引擎_帧预算ms = 16
定义 可变 _引擎_渲染预算ms = 8
定义 可变 _引擎_输入延迟ms = 2
定义 可变 _引擎_音频缓冲ms = 10
定义 可变 _引擎_智能推理预算ms = 4
定义 可变 _引擎_显存预算MB = 256
定义 可变 _引擎_线程数 = 4

函数 引擎合同_设置(帧, 渲染, 输入, 音频, AI, 显存, 线程) {
    _引擎_帧预算ms = 帧
    _引擎_渲染预算ms = 渲染
    _引擎_输入延迟ms = 输入
    _引擎_音频缓冲ms = 音频
    _引擎_智能推理预算ms = AI
    _引擎_显存预算MB = 显存
    _引擎_线程数 = 线程
}

// 引擎主循环报告
定义 可变 _引擎_帧数 = 0
定义 可变 _引擎_最大帧时间 = 0
定义 可变 _引擎_累计帧时间 = 0

函数 引擎_记录帧(帧时间ms) {
    _引擎_帧数 = _引擎_帧数 + 1
    _引擎_累计帧时间 = _引擎_累计帧时间 + 帧时间ms
    如果 (帧时间ms > _引擎_最大帧时间) { _引擎_最大帧时间 = 帧时间ms }
}

函数 引擎_平均帧时间() {
    如果 (_引擎_帧数 == 0) { 返回 0 }
    返回 _引擎_累计帧时间 / _引擎_帧数
}

函数 引擎主循环_报告() {
    定义 可变 r = 字典()
    字典设(r, "帧预算ms", 转字符串(_引擎_帧预算ms))
    字典设(r, "渲染预算ms", 转字符串(_引擎_渲染预算ms))
    字典设(r, "输入延迟ms", 转字符串(_引擎_输入延迟ms))
    字典设(r, "音频缓冲ms", 转字符串(_引擎_音频缓冲ms))
    字典设(r, "智能推理预算ms", 转字符串(_引擎_智能推理预算ms))
    字典设(r, "显存预算MB", 转字符串(_引擎_显存预算MB))
    字典设(r, "线程数", 转字符串(_引擎_线程数))
    字典设(r, "总帧数", 转字符串(_引擎_帧数))
    字典设(r, "平均帧时间", 转字符串(引擎_平均帧时间()))
    字典设(r, "最大帧时间", 转字符串(_引擎_最大帧时间))
    返回 r
}

// 资产管线报告
定义 可变 _资产_总数 = 0
定义 可变 _资产_已加载 = 0
定义 可变 _资产_流式数 = 0

函数 资产_记录加载() { _资产_已加载 = _资产_已加载 + 1 }
函数 资产_记录流式() { _资产_流式数 = _资产_流式数 + 1 }
函数 资产_设置总数(n) { _资产_总数 = n }

函数 事件_资产管线_报告() {
    定义 可变 r = 字典()
    字典设(r, "总数", 转字符串(_资产_总数))
    字典设(r, "已加载", 转字符串(_资产_已加载))
    字典设(r, "流式数", 转字符串(_资产_流式数))
    返回 r
}

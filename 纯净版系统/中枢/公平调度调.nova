函数 Nova公平调度_周期() {
    如果 (Nova公平调度进程数 <= 调度_最大延迟因子) { 返回 调度延迟 }
    返回 Nova公平调度进程数 * 最小粒度
}

// Nova公平调度 入队/出队 

函数 Nova公平调度_入队(任务) {
    // 确保Nova虚拟运行时间不低于min_Nova虚拟运行时间
    如果 (任务[T_虚拟运行时间] < 最小虚拟运行时间) {
        设置(任务, T_虚拟运行时间, 最小虚拟运行时间)
    }
    // EEVDF: 设置deadline
    如果 (任务[T_deadline] == 0 || 任务[T_deadline] < 任务[T_虚拟运行时间]) {
        定义 虚拟片 = calc_delta_fair(任务[T_时间片], 任务)
        设置(任务, T_deadline, 任务[T_虚拟运行时间] + 虚拟片)
    }
    红黑树_插入(Nova公平调度运行队列, 任务[T_虚拟运行时间], 任务)
    Nova公平调度进程数 = Nova公平调度进程数 + 1
    Nova公平调度总权重 = Nova公平调度总权重 + 任务[T_权重]
    // 更新加权和
    Nova公平调度_平均Nova虚拟运行时间加权和 = Nova公平调度_平均Nova虚拟运行时间加权和 + 任务[T_权重] * 任务[T_虚拟运行时间]
}

函数 Nova公平调度_出队(任务) {
    红黑树_删除(Nova公平调度运行队列, 任务[T_虚拟运行时间])
    Nova公平调度进程数 = Nova公平调度进程数 - 1
    Nova公平调度总权重 = Nova公平调度总权重 - 任务[T_权重]
    如果 (Nova公平调度总权重 < 0) { Nova公平调度总权重 = 0 }
    Nova公平调度_平均Nova虚拟运行时间加权和 = Nova公平调度_平均Nova虚拟运行时间加权和 - 任务[T_权重] * 任务[T_虚拟运行时间]
}

// 必须单调递增: max(当前min, min(curr_Nova虚拟运行时间, leftmost_Nova虚拟运行时间))
函数 Nova公平调度_更新最小虚拟运行时间_带当前(当前) {
    定义 可变 候选 = 最小虚拟运行时间
    如果 (当前 != 空) {
        候选 = 当前[T_虚拟运行时间]
    }
    定义 最小节点 = 红黑树_最小(Nova公平调度运行队列)
    如果 (最小节点 != 空) {
        定义 树最小 = 最小节点[RB_键]
        如果 (当前 != 空) {
            如果 (树最小 < 候选) { 候选 = 树最小 }
        } 否则 {
            候选 = 树最小
        }
    }
    // 单调递增
    如果 (候选 > 最小虚拟运行时间) {
        最小虚拟运行时间 = 候选
    }
}

// 加权平均Nova虚拟运行时间 
// EEVDF用: V = (\Sum w_i * v_i) / W

函数 Nova公平调度_平均Nova虚拟运行时间() {
    如果 (Nova公平调度总权重 <= 0) { 返回 最小虚拟运行时间 }
    返回 Nova公平调度_平均Nova虚拟运行时间加权和 / Nova公平调度总权重
}

// EEVDF: 选择下一个进程 
// 选择"eligible且deadline最小"的实体
// eligible: Nova虚拟运行时间 <= avg_Nova虚拟运行时间 (即不超前的)

函数 Nova公平调度_选择下一个() {
    如果 (红黑树_为空(Nova公平调度运行队列)) { 返回 空 }

    // EEVDF选择: 取Nova虚拟运行时间最小的实体(红黑树最左节点)
    // 等价于经典Nova公平调度的pick_next_entity — O(1)缓存最左节点
    定义 结果 = 红黑树_删除最小(Nova公平调度运行队列)
    如果 (结果 == 空) { 返回 空 }
    定义 任务 = 结果[1]

    Nova公平调度进程数 = Nova公平调度进程数 - 1
    Nova公平调度总权重 = Nova公平调度总权重 - 任务[T_权重]
    如果 (Nova公平调度总权重 < 0) { Nova公平调度总权重 = 0 }
    Nova公平调度_平均Nova虚拟运行时间加权和 = Nova公平调度_平均Nova虚拟运行时间加权和 - 任务[T_权重] * 任务[T_虚拟运行时间]

    进程_设置状态(任务, 进程_运行)
    Nova公平调度_当前实体 = 任务
    Nova公平调度次数 = Nova公平调度次数 + 1
    Nova公平调度_当前执行时间 = 0

    // 设置时间片
    如果 (任务[T_时间片] == 0) {
        设置(任务, T_时间片, 基础时间片)
    }

    返回 任务
}

// 计算时间片 (EEVDF: 固定base_slice, 实际CPU时间按权重分配)

函数 Nova公平调度_计算时间片(任务) {
    // EEVDF: 固定base_slice, Nova虚拟运行时间增速已按权重调整
    // 兼容: 如果进程多, 用旧Nova公平调度的period/weight算法
    如果 (Nova公平调度进程数 <= 1) { 返回 基础时间片 }
    定义 周期 = Nova公平调度_周期()
    定义 权重 = 任务[T_权重]
    定义 总 = Nova公平调度总权重 + 权重
    如果 (总 <= 0) { 总 = NICE_0_权重 }
    定义 片 = 周期 * 权重 / 总
    如果 (片 < 最小粒度) { 返回 最小粒度 }
    返回 片
}

// tick处理 

函数 Nova公平调度_tick(当前任务, delta_us) {
    如果 (当前任务 == 空) { 返回 假 }
    如果 (当前任务[T_调度策略] != 调度_普通 && 当前任务[T_调度策略] != 调度_批处理) {
        返回 假
    }

    // 1. update_curr: 更新Nova虚拟运行时间和deadline
    Nova公平调度_update_curr(当前任务, delta_us)

    // 2. 检查时间片是否用完
    定义 时间片 = Nova公平调度_计算时间片(当前任务)
    如果 (Nova公平调度_当前执行时间 >= 时间片) {
        返回 真  // 需要重新调度
    }

    // 3. EEVDF: 检查是否有deadline更紧迫的进程
    如果 (!红黑树_为空(Nova公平调度运行队列)) {
        定义 最左 = 红黑树_最小(Nova公平调度运行队列)
        如果 (最左 != 空) {
            定义 左任务 = 最左[RB_值]
            // 如果最左实体的deadline < 当前的deadline, 抢占
            如果 (左任务[T_deadline] < 当前任务[T_deadline]) {
                // 额外检查: Nova虚拟运行时间差必须超过粒度(避免乒乓)
                定义 差值 = 当前任务[T_虚拟运行时间] - 最左[RB_键]
                如果 (差值 > 唤醒粒度) { 返回 真 }
            }
        }
    }
    返回 假
}

// 唤醒抢占检查 
// EEVDF: 被唤醒进程的deadline < 当前进程的deadline时抢占

函数 Nova公平调度_唤醒抢占检查(当前, 唤醒进程) {
    如果 (当前 == 空 || 唤醒进程 == 空) { 返回 假 }
    // EEVDF: deadline比较
    如果 (唤醒进程[T_deadline] < 当前[T_deadline]) {
        返回 真
    }
    // 兼容: Nova虚拟运行时间差检查
    定义 差 = 当前[T_虚拟运行时间] - 唤醒进程[T_虚拟运行时间]
    返回 差 > 唤醒粒度
}

// place_entity: 新建/唤醒时的Nova虚拟运行时间放置策略
// EEVDF: 保留lag, 防止Nova虚拟运行时间跳跃

函数 Nova公平调度_设置新进程虚拟运行时间(任务) {
    // 确保权重已设置
    如果 (任务[T_权重] == 0) {
        设置(任务, T_权重, nice_到_权重(任务[T_nice值]))
    }
    // 设置时间片
    设置(任务, T_时间片, 基础时间片)

    // EEVDF place_entity: Nova虚拟运行时间 = avg_Nova虚拟运行时间(Nova公平调度_rq)
    定义 基准 = Nova公平调度_平均Nova虚拟运行时间()
    如果 (基准 < 最小虚拟运行时间) { 基准 = 最小虚拟运行时间 }
    设置(任务, T_虚拟运行时间, 基准)

    // 设置初始deadline
    定义 虚拟片 = calc_delta_fair(任务[T_时间片], 任务)
    设置(任务, T_deadline, 基准 + 虚拟片)
}

函数 Nova公平调度_唤醒放置(任务) {
    // 唤醒: 用保存的vlag恢复Nova虚拟运行时间 
    定义 平均v = Nova公平调度_平均Nova虚拟运行时间()
    如果 (任务[T_vlag] != 0) {
        // Nova虚拟运行时间 = 平均v - vlag (恢复相对位置)
        定义 恢复v = 平均v - 任务[T_vlag]
        如果 (恢复v < 最小虚拟运行时间) { 恢复v = 最小虚拟运行时间 }
        设置(任务, T_虚拟运行时间, 恢复v)
    } 否则 {
        // 无保存lag: 使用min_Nova虚拟运行时间
        如果 (任务[T_虚拟运行时间] < 最小虚拟运行时间) {
            设置(任务, T_虚拟运行时间, 最小虚拟运行时间)
        }
    }
    // 更新deadline
    定义 虚拟片 = calc_delta_fair(任务[T_时间片], 任务)
    设置(任务, T_deadline, 任务[T_虚拟运行时间] + 虚拟片)
}

定义 可变 AI_公平调度调_负载窗口 = []

函数 AI_公平调度调_负载预测(当前负载) {
    追加(AI_公平调度调_负载窗口, 当前负载)
    如果 (计数(AI_公平调度调_负载窗口) > 20) { 列表_移除(AI_公平调度调_负载窗口, 0) }
    如果 (计数(AI_公平调度调_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_公平调度调_负载窗口)
    定义 趋势 = AI_公平调度调_负载窗口[n-1] - AI_公平调度调_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_公平调度调_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

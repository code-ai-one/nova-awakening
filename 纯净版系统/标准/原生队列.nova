    打印行("║   合并次数:   " + 整数转字符串(全局_队列统计.合并次数))
    打印行("╠══════════════════════════════════════════╣")
    打印行("║ [优先队列]                               ║")
    打印行("║   优先入队:   " + 整数转字符串(全局_队列统计.优先入队次数))
    打印行("║   优先出队:   " + 整数转字符串(全局_队列统计.优先出队次数))
    打印行("╠══════════════════════════════════════════╣")
    打印行("║ [双端队列]                               ║")
    打印行("║   双端操作:   " + 整数转字符串(全局_队列统计.双端操作次数))
    打印行("╠══════════════════════════════════════════╣")
    打印行("║ [环形队列]                               ║")
    打印行("║   环形创建:   " + 整数转字符串(全局_队列统计.环形创建次数))
    打印行("║   环形扩容:   " + 整数转字符串(全局_队列统计.环形扩容次数))
    打印行("╠══════════════════════════════════════════╣")
    打印行("║ [吞吐量]                                 ║")
    定义 总操作 = 全局_队列统计.入队次数 + 全局_队列统计.出队次数 + 全局_队列统计.优先入队次数 + 全局_队列统计.优先出队次数 + 全局_队列统计.双端操作次数
    打印行("║   总操作数:   " + 整数转字符串(总操作))
    定义 拒绝率 = 0
    如果 (全局_队列统计.入队次数 > 0) {
        拒绝率 = 全局_队列统计.入队拒绝次数 * 1000 / 全局_队列统计.入队次数
    }
    打印行("║   拒绝率‰:    " + 整数转字符串(拒绝率))
    打印行("╚══════════════════════════════════════════╝")
}

定义 可变 AI_原生队列_负载窗口 = []

函数 AI_原生队列_负载预测(当前负载) {
    追加(AI_原生队列_负载窗口, 当前负载)
    如果 (计数(AI_原生队列_负载窗口) > 20) { 列表_移除(AI_原生队列_负载窗口, 0) }
    如果 (计数(AI_原生队列_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_原生队列_负载窗口)
    定义 趋势 = AI_原生队列_负载窗口[n-1] - AI_原生队列_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_原生队列_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}


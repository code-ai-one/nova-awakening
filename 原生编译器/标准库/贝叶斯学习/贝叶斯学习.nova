导入("../基础.nova")
导入("../算法/数学扩展.nova")


定义 BL_随机态 = 31415
函数 BL_随机() {
    BL_随机态 = BL_随机态 ^ (BL_随机态 << 13)
    BL_随机态 = BL_随机态 ^ (BL_随机态 >> 7)
    BL_随机态 = BL_随机态 ^ (BL_随机态 << 17)
    如果 (BL_随机态 < 0) { BL_随机态 = 0 - BL_随机态 }
    返回 BL_随机态
}

// 高斯分布 (×1000定点)
函数 高斯_采样(均值, 标准差) {
    // Box-Muller近似
    定义 u1 = (BL_随机() % 998) + 1
    BL_随机() % 1000
    定义 z = (u1 - 500) * 3 / 500
    返回 均值 + 标准差 * z / 1000
}

函数 高斯_对数概率(x, μ, σ) {
    如果 (σ <= 0) { σ = 1 }
    定义 d = x - μ
    // log N(x|μ,σ) ∝ -(x-μ)²/(2σ²)
    返回 0 - d * d / (2 * σ * σ / 1000)
}

// 贝叶斯线性回归
// 先验: w ~ N(0, σ_prior²)
// 似然: y ~ N(w·x, σ_noise²)
函数 贝叶斯线性_创建(维度, σ_prior) {
    定义 可变 均值 = []
    定义 可变 方差 = []
    定义 可变 i = 0
    当 (i < 维度) {
        追加(均值, 0)
        追加(方差, σ_prior * σ_prior / 1000)
        i = i + 1
    }
    返回 [均值, 方差, 维度, σ_prior]
}

函数 贝叶斯线性_更新(模型, x, y, σ_noise) {
    定义 d = 模型[2]
    定义 可变 i = 0
    当 (i < d) {
        如果 (i < 计数(x)) {
            // 后验更新 (共轭正态)
            定义 先验方差 = 模型[1][i]
            定义 似然精度 = x[i] * x[i] * 1000 / (σ_noise * σ_noise / 1000 + 1)
            定义 可变 后验精度 = 1000 * 1000 / (先验方差 + 1) + 似然精度
            如果 (后验精度 == 0) { 后验精度 = 1 }
            定义 后验方差 = 1000 * 1000 / 后验精度
            定义 后验均值 = (模型[0][i] * 1000 / (先验方差 + 1) + y * x[i] * 1000 / (σ_noise * σ_noise / 1000 + 1)) * 1000 / 后验精度
            模型[0][i] = 后验均值
            模型[1][i] = 后验方差
        }
        i = i + 1
    }
}

函数 贝叶斯线性_预测(模型, x) {
    定义 d = 模型[2]
    定义 可变 均值 = 0
    定义 可变 方差 = 0
    定义 可变 i = 0
    当 (i < d) {
        如果 (i < 计数(x)) {
            均值 = 均值 + 模型[0][i] * x[i] / 1000
            方差 = 方差 + 模型[1][i] * x[i] * x[i] / (1000 * 1000)
        }
        i = i + 1
    }
    返回 [均值, 方差]
}

// 变分推断 (VI)
// ELBO = E_q[log p(x,z)] - E_q[log q(z)]
函数 变分_证据下界(log_似然, KL散度) {
    返回 log_似然 - KL散度
}

函数 VI_高斯KL(μ_q, σ_q, μ_p, σ_p) {
    // KL(q||p) = log(σ_p/σ_q) + (σ_q² + (μ_q-μ_p)²)/(2σ_p²) - 1/2
    如果 (σ_p == 0) { σ_p = 1 }
    如果 (σ_q == 0) { σ_q = 1 }
    定义 比率 = σ_p * 1000 / σ_q
    定义 d = μ_q - μ_p
    定义 kl = 比率 + (σ_q * σ_q + d * d) * 1000 / (2 * σ_p * σ_p / 1000 + 1) - 500
    返回 kl
}

// MC 随机丢弃层 不确定性
函数 MC_Dropout_预测(前向函数结果列表, _采样数) {
    定义 T = 计数(前向函数结果列表)
    如果 (T == 0) { 返回 [0, 0] }
    定义 维度 = 计数(前向函数结果列表[0])
    // 均值
    定义 可变 均值 = []
    定义 可变 d = 0
    当 (d < 维度) { 追加(均值, 0)
    d = d + 1 }
    定义 可变 t = 0
    当 (t < T) {
        d = 0
        当 (d < 维度) {
            如果 (d < 计数(前向函数结果列表[t])) {
                均值[d] = 均值[d] + 前向函数结果列表[t][d]
            }
            d = d + 1
        }
        t = t + 1
    }
    d = 0
    当 (d < 维度) { 均值[d] = 均值[d] / T
    d = d + 1 }
    // 方差 (认知不确定性)
    定义 可变 方差 = []
    d = 0
    当 (d < 维度) { 追加(方差, 0)
    d = d + 1 }
    t = 0
    当 (t < T) {
        d = 0
        当 (d < 维度) {
            如果 (d < 计数(前向函数结果列表[t])) {
                定义 可变 差值 = 前向函数结果列表[t][d] - 均值[d]
                方差[d] = 方差[d] + 差值 * 差值 / 1000
            }
            d = d + 1
        }
        t = t + 1
    }
    d = 0
    当 (d < 维度) { 方差[d] = 方差[d] / T
    d = d + 1 }
    返回 [均值, 方差]
}

// 贝叶斯优化 (BO)
// 高斯过程简化版: 用核函数
函数 RBF核(x1, x2, 长度尺度) {
    定义 d = 计数(x1)
    定义 可变 dist2 = 0
    定义 可变 i = 0
    当 (i < d) {
        定义 可变 x2v = 0
        如果 (i < 计数(x2)) { x2v = x2[i] }
        定义 可变 差值 = x1[i] - x2v
        dist2 = dist2 + 差值 * 差值 / 1000
        i = i + 1
    }
    // exp(-dist²/(2l²))
    定义 指数 = 0 - dist2 * 1000 / (2 * 长度尺度 * 长度尺度 / 1000 + 1)
    定义 可变 k = 1000 + 指数  // exp近似
    如果 (k < 0) { k = 0 }
    返回 k
}

函数 BO_创建() {
    返回 [[], [], 0, 1000]  // [观测X, 观测Y, 数量, 长度尺度]
}

函数 BO_添加观测(bo, x, y) {
    追加(bo[0], x)
    追加(bo[1], y)
    bo[2] = bo[2] + 1
}

函数 BO_采集_UCB(bo, 候选, κ) {
    定义 可变 权重和 = 0
    如果 (κ <= 0) { κ = 2000 }
    定义 n = bo[2]
    定义 可变 最佳 = 0
    定义 可变 最佳值 = 0 - 0x7FFFFFFF
    定义 可变 c = 0
    当 (c < 计数(候选)) {
        // 预测均值和方差
        定义 可变 均值 = 0
        定义 可变 方差 = 1000
        如果 (n > 0) {
            定义 可变 加权y = 0
            定义 可变 i = 0
            当 (i < n) {
                定义 k = RBF核(候选[c], bo[0][i], bo[3])
                权重和 = 权重和 + k
                加权y = 加权y + k * bo[1][i] / 1000
                i = i + 1
            }
            如果 (权重和 > 0) {
                均值 = 加权y * 1000 / 权重和
                方差 = 1000 - 权重和 * 1000 / (权重和 + 1000)
            }
        }
        // UCB = μ + κ·σ
        定义 σ = 整数sqrt(方差 * 1000)
        定义 置信上限 = 均值 + κ * σ / 1000
        如果 (置信上限 > 最佳值) { 最佳 = c
        最佳值 = 置信上限 }
        c = c + 1
    }
    返回 最佳
}

// 深度集成 (Deep Ensemble)
函数 集成_预测(模型输出列表) {
    定义 M = 计数(模型输出列表)
    如果 (M == 0) { 返回 [[], []] }
    定义 维度 = 计数(模型输出列表[0])
    定义 可变 均值 = []
    定义 可变 方差 = []
    定义 可变 d = 0
    当 (d < 维度) {
        定义 可变 和 = 0
        定义 可变 i = 0
        当 (i < M) {
            如果 (d < 计数(模型输出列表[i])) { 和 = 和 + 模型输出列表[i][d] }
            i = i + 1
        }
        定义 μ = 和 / M
        追加(均值, μ)
        定义 可变 sq和 = 0
        i = 0
        当 (i < M) {
            定义 可变 v = 0
            如果 (d < 计数(模型输出列表[i])) { v = 模型输出列表[i][d] }
            定义 可变 差值 = v - μ
            sq和 = sq和 + 差值 * 差值 / 1000
            i = i + 1
        }
        追加(方差, sq和 / M)
        d = d + 1
    }
    返回 [均值, 方差]
}

// 校准 (Calibration)
函数 ECE_计算(置信度列表, 正确列表, 分桶数) {
    定义 可变 ece = 0
    // Expected Calibration Error
    如果 (分桶数 <= 0) { 分桶数 = 10 }
    定义 n = 计数(置信度列表)
    定义 可变 b = 0
    当 (b < 分桶数) {
        定义 下界 = b * 1000 / 分桶数
        定义 上界 = (b + 1) * 1000 / 分桶数
        定义 可变 桶置信 = 0
        定义 可变 桶正确 = 0
        定义 可变 桶数量 = 0
        定义 可变 i = 0
        当 (i < n) {
            如果 (置信度列表[i] >= 下界 且 置信度列表[i] < 上界) {
                桶置信 = 桶置信 + 置信度列表[i]
                桶正确 = 桶正确 + 正确列表[i]
                桶数量 = 桶数量 + 1
            }
            i = i + 1
        }
        如果 (桶数量 > 0) {
            定义 平均置信 = 桶置信 / 桶数量
            定义 平均正确 = 桶正确 * 1000 / 桶数量
            定义 可变 差值 = 平均置信 - 平均正确
            如果 (差值 < 0) { 差值 = 0 - 差值 }
            ece = ece + 差值 * 桶数量 / n
        }
        b = b + 1
    }
    返回 ece
}

// 温度缩放校准
函数 温度缩放(对数值, T) {
    如果 (T <= 0) { T = 1000 }
    定义 n = 计数(对数值)
    定义 可变 缩放 = []
    定义 可变 i = 0
    当 (i < n) { 追加(缩放, 对数值[i] * 1000 / T)
    i = i + 1 }
    返回 缩放
}

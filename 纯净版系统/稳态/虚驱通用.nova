导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../引导/端口输入.nova")

// NovaOS virtio通用

定义 VIRTIO_PCI_厂商 = 0x1AF4
定义 VIRTIO_PCI_设备_网络 = 0x1000
定义 VIRTIO_PCI_设备_块 = 0x1001
定义 VIRTIO_PCI_设备_控制台 = 0x1003
定义 VIRTIO_PCI_设备_图处 = 0x1050

定义 VIRTIO_状态_ACK = 1
定义 VIRTIO_状态_驱动 = 2
定义 VIRTIO_状态_驱动OK = 4
定义 VIRTIO_状态_功能OK = 8
定义 VIRTIO_状态_需重置 = 64
定义 VIRTIO_状态_失败 = 128

定义 VIRTIO_F_版本1 = 32         // VIRTIO_F_VERSION_1
定义 VIRTIO_F_环形事件索引 = 29  // VIRTIO_RING_F_事件_IDX
定义 VIRTIO_F_间接描述符 = 28    // VIRTIO_RING_F_INDIRECT_DESC

定义 VRING_DESC_F_下一个 = 1     // 有链表中下一个描述符
定义 VRING_DESC_F_可写 = 2       // 设备可写 (否则只读)
定义 VRING_DESC_F_间接 = 4       // 间接描述符

定义 VD_地址 = 0
定义 VD_长度 = 1
定义 VD_标志 = 2
定义 VD_下一个 = 3

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 vring_desc_创建(地址, 长度, 标志, 下一个) {
    返回 [地址, 长度, 标志, 下一个]
}

定义 VQ_大小 = 0
定义 VQ_描述符 = 1
定义 VQ_可用环 = 2      // [标志, 索引, 环数组]
定义 VQ_已用环 = 3      // [标志, 索引, 环数组]
定义 VQ_空闲头 = 4
定义 VQ_空闲数 = 5
定义 VQ_上次已用 = 6
定义 VQ_回调 = 7

函数 virtqueue_创建(名称, 队列大小, 设备) {
    // 初始化描述符表
    定义 可变 描述符 = []
    定义 可变 i = 0
    当 (i < 队列大小) {
        // 链接空闲链表
        追加(描述符, vring_desc_创建(0, 0, 0, i + 1))
        i = i + 1
    }
    // 最后一个指向-1
    如果 (队列大小 > 0) {
        设置(描述符[队列大小 - 1], VD_下一个, 0 - 1)
    }
    // 可用环 = [flags, idx, ring[]]
    定义 可用 = [0, 0, []]
    // 已用环 = [flags, idx, ring[]]
    定义 已用 = [0, 0, []]
    返回 [队列大小, 描述符, 可用, 已用, 0, 队列大小, 0, 空]
}

函数 virtqueue_分配描述符(vq) {
    如果 (vq[VQ_空闲数] <= 0) { 返回 0 - 1 }
    定义 头 = vq[VQ_空闲头]
    设置(vq, VQ_空闲头, vq[VQ_描述符][头][VD_下一个])
    设置(vq, VQ_空闲数, vq[VQ_空闲数] - 1)
    返回 头
}

函数 virtqueue_释放描述符(vq, 索引) {
    设置(vq[VQ_描述符][索引], VD_下一个, vq[VQ_空闲头])
    设置(vq, VQ_空闲头, 索引)
    设置(vq, VQ_空闲数, vq[VQ_空闲数] + 1)
}

函数 virtqueue_添加缓冲(vq, 地址, 长度, 可写) {
    定义 头 = virtqueue_分配描述符(vq)
    如果 (头 < 0) { 返回 错误_无空间 }
    定义 描述符 = vq[VQ_描述符][头]
    设置(描述符, VD_地址, 地址)
    设置(描述符, VD_长度, 长度)
    如果 (可写) {
        设置(描述符, VD_标志, VRING_DESC_F_可写)
    } 否则 {
        设置(描述符, VD_标志, 0)
    }
    设置(描述符, VD_下一个, 0 - 1)
    // 添加到可用环
    定义 可用 = vq[VQ_可用环]
    追加(可用[2], 头)
    设置(可用, 1, 可用[1] + 1)
    返回 头
}

函数 virtqueue_通知(vq, 设备) {
    // 写设备的通知寄存器(MMIO门铃)
    如果 (设备 != 空 && 设备.mmio基址 != 0) {
        内存写32(设备.mmio基址 + 0x50, 0)  // 队列Notify寄存器
    }
}

函数 virtqueue_获取已完成(vq) {
    定义 已用 = vq[VQ_已用环]
    如果 (vq[VQ_上次已用] == 已用[1]) { 返回 空 }
    定义 环索引 = vq[VQ_上次已用] % vq[VQ_大小]
    定义 条目 = 已用[2][环索引]
    设置(vq, VQ_上次已用, vq[VQ_上次已用] + 1)
    // 释放描述符
    virtqueue_释放描述符(vq, 条目)
    返回 条目
}

定义 VDEV_PCI = 0
定义 VDEV_类型 = 1
定义 VDEV_状态 = 2
定义 VDEV_功能 = 3
定义 VDEV_队列列表 = 4

函数 virtio_设备_创建(pci设备, 类型) {
    返回 [pci设备, 类型, 0, 0, []]
}

函数 virtio_初始化(设备) {
    // 1. 重置设备
    设置(设备, VDEV_状态, 0)
    // 2. 设置ACK状态位
    设置(设备, VDEV_状态, VIRTIO_状态_ACK)
    // 3. 设置DRIVER状态位
    设置(设备, VDEV_状态, 设备[VDEV_状态] | VIRTIO_状态_驱动)
    // 4. 协商功能位
    定义 设备功能 = 0  // 从设备寄存器读取
    定义 驱动功能 = VIRTIO_F_版本1
    设置(设备, VDEV_功能, 设备功能 & 驱动功能)
    // 5. 设置FEATURES_OK
    设置(设备, VDEV_状态, 设备[VDEV_状态] | VIRTIO_状态_功能OK)
    // 6. 验证FEATURES_OK仍然设置
    // 7. 设置DRIVER_OK
    设置(设备, VDEV_状态, 设备[VDEV_状态] | VIRTIO_状态_驱动OK)
    返回 成功
}

函数 virtio_添加队列(设备, 队列大小) {
    定义 vq = virtqueue_创建(队列大小)
    追加(设备[VDEV_队列列表], vq)
    返回 vq
}

函数 virtio_重置(设备) {
    设置(设备, VDEV_状态, 0)
    设置(设备, VDEV_队列列表, [])
}

函数 virtio_状态OK(设备) {
    返回 (设备[VDEV_状态] & VIRTIO_状态_驱动OK) != 0
}

函数 virtio_已失败(设备) {
    返回 (设备[VDEV_状态] & VIRTIO_状态_失败) != 0
}

函数 virtio_设备类型名(类型) {
    如果 (类型 == VIRTIO_PCI_设备_网络) { 返回 "virtio-net" }
    如果 (类型 == VIRTIO_PCI_设备_块) { 返回 "virtio-blk" }
    如果 (类型 == VIRTIO_PCI_设备_控制台) { 返回 "virtio-console" }
    如果 (类型 == VIRTIO_PCI_设备_图处) { 返回 "virtio-gpu" }
    返回 "virtio-unknown"
}

函数 virtqueue_空闲数(vq) { 返回 vq[VQ_空闲数] }
函数 virtqueue_已满(vq) { 返回 vq[VQ_空闲数] == 0 }
函数 virtqueue_为空(vq) { 返回 vq[VQ_空闲数] == vq[VQ_大小] }

函数 virtqueue_有待处理(vq) {
    定义 已用 = vq[VQ_已用环]
    返回 vq[VQ_上次已用] != 已用[1]
}

定义 可变 virtio_设备列表 = []

函数 virtio_注册设备(设备) {
    追加(virtio_设备列表, 设备)
}

函数 virtio_设备数() { 返回 计数(virtio_设备列表) }

// 设备状态名 + 完整统计

函数 virtio_状态名(状态) {
    如果 (状态 == 0) { 返回 "RESET" }
    如果 ((状态 & VIRTIO_状态_失败) != 0) { 返回 "FAILED" }
    如果 ((状态 & VIRTIO_状态_驱动OK) != 0) { 返回 "DRIVER_OK" }
    如果 ((状态 & VIRTIO_状态_驱动) != 0) { 返回 "DRIVER" }
    如果 ((状态 & VIRTIO_状态_ACK) != 0) { 返回 "ACK" }
    返回 "unknown"
}

函数 virtio_活跃设备数() {
    定义 可变 计 = 0
    定义 可变 i = 0
    当 (i < 计数(virtio_设备列表)) {
        如果 (virtio_状态OK(virtio_设备列表[i])) { 计 = 计 + 1 }
        i = i + 1
    }
    返回 计
}

函数 virtio_完整统计() {
    返回 [计数(virtio_设备列表), virtio_活跃设备数()]
}

定义 可变 AI_虚驱通用_运行指标 = 0
定义 可变 AI_虚驱通用_异常指标 = 0

函数 AI_虚驱通用_自诊断() {
    AI_虚驱通用_运行指标 = 0
    返回 AI_虚驱通用_运行指标
}

函数 AI_虚驱通用_优化建议() {
    定义 指标 = AI_虚驱通用_自诊断()
    返回 "虚驱通用状态正常"
}

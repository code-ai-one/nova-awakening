导入("./时钟中枢.nova")
导入("./链表后继.nova")

// NovaOS · LSM安全模块框架
// §1 钩子注册: 安全模块注册回调到各检查点
// §2 文件访问控制: open/read/write/exec权限检查
// §3 进程安全: fork/exec/信号发送权限
// §4 网络安全: socket创建/绑定/连接权限
// §5 NovaOS扩展: AI操作权限(推理/学习/模型访问)


定义 LSM_文件打开 = 0
定义 LSM_文件读 = 1
定义 LSM_文件写 = 2
定义 LSM_文件执行 = 3
定义 LSM_进程fork = 4
定义 LSM_进程exec = 5
定义 LSM_进程kill = 6
定义 LSM_Socket创建 = 7
定义 LSM_Socket绑定 = 8
定义 LSM_Socket连接 = 9
定义 LSM_AI推理 = 10
定义 LSM_AI学习 = 11
定义 LSM_AI模型访问 = 12
定义 LSM_钩子总数 = 13


定义 LSM_模块最大 = 8

结构 LSM模块 {
    名称哈希,
    钩子表,    // 列表 [钩子类型] → 回调函数指针
    优先级,
    已启用,
    检查次数,
    拒绝次数,
}

定义 可变 LSM模块表 = []
定义 可变 LSM_已初始化 = 假
定义 可变 LSM_总检查 = 0
定义 可变 LSM_总拒绝 = 0


函数 LSM_初始化() {
    LSM模块表 = []
    LSM_已初始化 = 真
    内核信息("LSM框架: " + 整数转字符串(LSM_钩子总数) + "钩子点 含AI扩展(推理/学习/模型)")
}


函数 LSM_注册模块(名称哈希, 优先级) {
    如果 (计数(LSM模块表) >= LSM_模块最大) { 返回 -1 }
    定义 模块 = LSM模块 {}
    模块.名称哈希 = 名称哈希
    模块.优先级 = 优先级
    模块.已启用 = 1
    模块.检查次数 = 0
    模块.拒绝次数 = 0
    // 初始化钩子表(全部默认允许)
    模块.钩子表 = []
    定义 可变 i = 0
    当 (i < LSM_钩子总数) { 追加(模块.钩子表, 0); i = i + 1 }  // 0=无回调=允许
    追加(LSM模块表, 模块)
    返回 计数(LSM模块表) - 1
}

函数 LSM_设置钩子(模块索引, 钩子类型, 回调) {
    如果 (模块索引 >= 计数(LSM模块表)) { 返回 -1 }
    如果 (钩子类型 >= LSM_钩子总数) { 返回 -2 }
    LSM模块表[模块索引].钩子表[钩子类型] = 回调
    返回 0
}


函数 LSM_检查(钩子类型, 主体, 客体) {
    如果 (!LSM_已初始化) { 返回 真 }  // 未初始化=全部允许
    LSM_总检查 = LSM_总检查 + 1

    定义 可变 i = 0
    当 (i < 计数(LSM模块表)) {
        如果 (LSM模块表[i].已启用 == 1) {
            LSM模块表[i].检查次数 = LSM模块表[i].检查次数 + 1
            如果 (钩子类型 < LSM_钩子总数 && LSM模块表[i].钩子表[钩子类型] != 0) {
                // 调用安全模块的钩子
                定义 结果 = LSM_调用钩子(LSM模块表[i].钩子表[钩子类型], 主体, 客体)
                如果 (结果 != 0) {
                    LSM模块表[i].拒绝次数 = LSM模块表[i].拒绝次数 + 1
                    LSM_总拒绝 = LSM_总拒绝 + 1
                    返回 假  // 拒绝
                }
            }
        }
        i = i + 1
    }
    返回 真  // 所有模块都允许
}

函数 LSM_调用钩子(回调, 主体, 客体) {
    // 内核回调调用(实际实现为函数指针调用)
    // 返回0=允许, 非0=拒绝
    返回 0  // 默认允许
}


函数 LSM_文件访问检查(进程, Nova文件节点, 操作) {
    如果 (操作 == 0) { 返回 LSM_检查(LSM_文件打开, 进程, Nova文件节点) }
    如果 (操作 == 1) { 返回 LSM_检查(LSM_文件读, 进程, Nova文件节点) }
    如果 (操作 == 2) { 返回 LSM_检查(LSM_文件写, 进程, Nova文件节点) }
    如果 (操作 == 3) { 返回 LSM_检查(LSM_文件执行, 进程, Nova文件节点) }
    返回 真
}

函数 LSM_进程安全检查(源进程, 目标进程, 操作) {
    如果 (操作 == 0) { 返回 LSM_检查(LSM_进程fork, 源进程, 0) }
    如果 (操作 == 1) { 返回 LSM_检查(LSM_进程exec, 源进程, 目标进程) }
    如果 (操作 == 2) { 返回 LSM_检查(LSM_进程kill, 源进程, 目标进程) }
    返回 真
}

函数 LSM_网络安全检查(进程, socket, 操作) {
    如果 (操作 == 0) { 返回 LSM_检查(LSM_Socket创建, 进程, 0) }
    如果 (操作 == 1) { 返回 LSM_检查(LSM_Socket绑定, 进程, socket) }
    如果 (操作 == 2) { 返回 LSM_检查(LSM_Socket连接, 进程, socket) }
    返回 真
}


函数 LSM_AI安全检查(进程, AI操作, 参数) {
    如果 (AI操作 == 0) { 返回 LSM_检查(LSM_AI推理, 进程, 参数) }
    如果 (AI操作 == 1) { 返回 LSM_检查(LSM_AI学习, 进程, 参数) }
    如果 (AI操作 == 2) { 返回 LSM_检查(LSM_AI模型访问, 进程, 参数) }
    返回 真
}


函数 LSM_启用模块(索引) {
    如果 (索引 < 计数(LSM模块表)) { LSM模块表[索引].已启用 = 1 }
}

函数 LSM_禁用模块(索引) {
    如果 (索引 < 计数(LSM模块表)) { LSM模块表[索引].已启用 = 0 }
}

函数 LSM_模块数() { 返回 计数(LSM模块表) }
函数 LSM_统计() {
    返回 { 模块数: 计数(LSM模块表), 总检查: LSM_总检查, 总拒绝: LSM_总拒绝 }
}


定义 可变 LSM_审计日志 = []
定义 LSM_审计最大 = 256

函数 LSM_审计记录(钩子类型, 主体, 客体, 结果) {
    如果 (计数(LSM_审计日志) >= LSM_审计最大) {
        链表_删除(LSM_审计日志, 0)  // 丢弃最旧
    }
    追加(LSM_审计日志, [读取毫秒(), 钩子类型, 主体, 客体, 结果])
}

函数 LSM_审计_最近(数量) {
    定义 总数 = 计数(LSM_审计日志)
    如果 (数量 > 总数) { 数量 = 总数 }
    定义 可变 结果 = []
    定义 可变 i = 总数 - 数量
    当 (i < 总数) {
        追加(结果, LSM_审计日志[i])
        i = i + 1
    }
    返回 结果
}

函数 LSM_审计_拒绝记录() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(LSM_审计日志)) {
        如果 (LSM_审计日志[i][4] != 0) {
            追加(结果, LSM_审计日志[i])
        }
        i = i + 1
    }
    返回 结果
}


函数 LSM_钩子名称(类型) {
    如果 (类型 == LSM_文件打开) { 返回 "file_open" }
    如果 (类型 == LSM_文件读) { 返回 "file_read" }
    如果 (类型 == LSM_文件写) { 返回 "file_write" }
    如果 (类型 == LSM_文件执行) { 返回 "file_exec" }
    如果 (类型 == LSM_进程fork) { 返回 "task_fork" }
    如果 (类型 == LSM_进程exec) { 返回 "task_exec" }
    如果 (类型 == LSM_进程kill) { 返回 "task_kill" }
    如果 (类型 == LSM_Socket创建) { 返回 "socket_create" }
    如果 (类型 == LSM_Socket绑定) { 返回 "socket_bind" }
    如果 (类型 == LSM_Socket连接) { 返回 "socket_connect" }
    如果 (类型 == LSM_AI推理) { 返回 "ai_infer" }
    如果 (类型 == LSM_AI学习) { 返回 "ai_learn" }
    如果 (类型 == LSM_AI模型访问) { 返回 "ai_model" }
    返回 "unknown"
}

函数 LSM_完整统计() {
    返回 [计数(LSM模块表), LSM_总检查, LSM_总拒绝, 计数(LSM_审计日志)]
}


函数 LSM_拒绝率() {
    如果 (LSM_总检查 == 0) { 返回 0 }
    返回 LSM_总拒绝 * 100 / LSM_总检查
}

函数 LSM_活跃模块数() {
    定义 可变 计 = 0
    定义 可变 i = 0
    当 (i < 计数(LSM模块表)) {
        如果 (LSM模块表[i].已启用 == 1) { 计 = 计 + 1 }
        i = i + 1
    }
    返回 计
}

导入("../中枢/同步原语.nova")

// 路由添加

函数 路由_添加(目标网络, 前缀长度, 网关, 设备, 度量, 标志) {
    返回 路由_添加_完整(目标网络, 前缀长度, 网关, 设备, 路由类型_单播, 路由范围_全局, 路由协议_静态, 度量)
}

函数 路由_添加_完整(目标网络, 前缀长度, 网关, 设备, 类型, 范围, 协议, 度量) {
    定义 可变 条目 = 分配内存(大小(路由条目))
    如果 (条目 == 空) { 返回 错误码_内存不足 }

    条目.目标网络 = 目标网络
    条目.前缀长度 = 前缀长度
    条目.子网掩码 = 前缀长度_转掩码(前缀长度)
    条目.网关 = 网关
    条目.设备 = 设备
    条目.类型 = 类型
    条目.范围 = 范围
    条目.协议 = 协议
    条目.度量 = 度量
    条目.优先级 = 度量
    条目.标志 = 0
    条目.引用计数 = 1
    条目.使用计数 = 0
    条目.最后使用时间 = 0

    如果 (网关 != 0) {
        条目.标志 = 条目.标志 | 路由标志_网关
    }
    如果 (前缀长度 == 32) {
        条目.标志 = 条目.标志 | 路由标志_主机
    }
    如果 (前缀长度 == 0) {
        条目.标志 = 条目.标志 | 路由标志_默认
    }

    // 选择路由表
    定义 可变 表 = 主路由表
    如果 (类型 == 路由类型_本地) {
        表 = 本地路由表
    }

    // 按前缀长度降序插入(最长匹配优先)
    写锁_获取(表.锁)

    如果 (前缀长度 == 0) {
        表.默认路由 = 条目
    }

    // 找到插入位置
    定义 可变 前一个 = 空
    定义 可变 当前 = 表.条目链表
    当 (当前 != 空) {
        如果 (条目.前缀长度 > 当前.前缀长度) {
            跳出
        }
        如果 (条目.前缀长度 == 当前.前缀长度 && 条目.度量 < 当前.度量) {
            跳出
        }
        前一个 = 当前
        当前 = 当前.下一个
    }

    如果 (前一个 == 空) {
        条目.下一个 = 表.条目链表
        表.条目链表 = 条目
    } 否则 {
        条目.下一个 = 前一个.下一个
        前一个.下一个 = 条目
    }

    表.条目数 = 表.条目数 + 1
    写锁_释放(表.锁)

    // 清除路由缓存(路由变更时)
    路由缓存_清除()

    返回 0
}

// 路由删除

函数 路由_删除(目标网络, 前缀长度) {
    写锁_获取(主路由表.锁)

    定义 掩码 = 前缀长度_转掩码(前缀长度)
    定义 可变 前一个 = 空
    定义 可变 当前 = 主路由表.条目链表

    当 (当前 != 空) {
        如果 (当前.目标网络 == 目标网络 && 当前.前缀长度 == 前缀长度) {
            如果 (前一个 == 空) {
                主路由表.条目链表 = 当前.下一个
            } 否则 {
                前一个.下一个 = 当前.下一个
            }
            主路由表.条目数 = 主路由表.条目数 - 1

            如果 (主路由表.默认路由 == 当前) {
                主路由表.默认路由 = 空
            }

            写锁_释放(主路由表.锁)
            释放内存(当前)
            路由缓存_清除()
            返回 0
        }
        前一个 = 当前
        当前 = 当前.下一个
    }

    写锁_释放(主路由表.锁)
    返回 错误码_不存在
}

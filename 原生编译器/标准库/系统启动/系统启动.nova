导入("../基础.nova")


定义 启动_未开始 = 0
定义 启动_进行中 = 1
定义 启动_成功 = 2
定义 启动_失败 = 3
定义 启动_错误_无效模块 = -1001
定义 启动_错误_依赖无效 = -1002
定义 启动_错误_依赖未满足 = -1003

// 模块: [名哈希, 状态, 依赖列表, 优先级, 自检结果]
定义 可变 启动_模块 = []
定义 可变 启动_日志 = []

函数 启动_注册模块(名哈希, 优先级) {
    定义 模块 = [名哈希, 启动_未开始, [], 优先级, 0]
    追加(启动_模块, 模块)
    返回 计数(启动_模块) - 1
}

函数 启动_添加依赖(模块idx, 依赖idx) {
 追加(启动_模块[模块idx][2], 依赖idx)
}

函数 启动_日志记录(消息哈希) { 追加(启动_日志, 消息哈希) }
函数 启动_日志数() { 返回 计数(启动_日志) }

// 自检: 验证模块数据完整性并记录检查结果 (0=通过, 非0=错误码)
函数 启动_自检(模块idx, 检查结果) { 如果 (模块idx < 0 或 模块idx >= 计数(启动_模块)) {
 启动_日志记录(启动_错误_无效模块)
 返回 假
 }
 启动_模块[模块idx][4] = 检查结果
 如果 (检查结果 != 0) {
 启动_日志记录(检查结果)
 }
 返回 检查结果 == 0
}

// 自检: 验证模块注册完整性 (所有依赖索引有效)
函数 启动_验证依赖(模块idx) {
    如果 (模块idx < 0 或 模块idx >= 计数(启动_模块)) { 返回 假
}
 定义 依赖 = 启动_模块[模块idx][2]
 定义 可变 i = 0
 当 (i < 计数(依赖)) { 如果 (依赖[i] < 0 或 依赖[i] >= 计数(启动_模块)) { 返回 假 }
 如果 (依赖[i] == 模块idx) { 返回 假 }
 i = i + 1
 }
 返回 真
}

// 依赖是否满足
函数 启动_依赖满足(模块idx) { 定义 依赖 = 启动_模块[模块idx][2]
 定义 可变 i = 0
 当 (i < 计数(依赖)) { 如果 (启动_模块[依赖[i]][1] != 启动_成功) { 返回 假 }
 i = i + 1
 }
 返回 真
}

// 启动单个模块
函数 启动_模块执行(模块idx) { 如果 (模块idx < 0 或 模块idx >= 计数(启动_模块)) {
 启动_日志记录(启动_错误_无效模块)
 返回 假
 }
 如果 (启动_验证依赖(模块idx) == 假) {
 启动_模块[模块idx][1] = 启动_失败
 启动_模块[模块idx][4] = 启动_错误_依赖无效
 启动_日志记录(启动_错误_依赖无效)
 返回 假
 }
 如果 (启动_依赖满足(模块idx) == 假) { 返回 假 }
 启动_模块[模块idx][1] = 启动_进行中
 如果 (启动_模块[模块idx][4] == 0) {
 启动_模块[模块idx][1] = 启动_成功
 启动_日志记录(启动_模块[模块idx][0])
 返回 真
 }
 启动_模块[模块idx][1] = 启动_失败
 返回 假
}

// 按优先级启动所有
函数 启动_执行全部() { 定义 可变 已启动 = 0
    定义 可变 最高优 = 0
 定义 可变 改变 = 真
 当 (改变) {
 改变 = 假
 // 找优先级最高的未启动且依赖满足的模块
 定义 可变 最佳 = -1
 定义 可变 i = 0
 当 (i < 计数(启动_模块)) { 如果 (启动_模块[i][1] == 启动_未开始 且 启动_依赖满足(i)) { 如果 (启动_模块[i][3] > 最高优) { 最佳 = i
 最高优 = 启动_模块[i][3] }
 }
 i = i + 1
 }
 如果 (最佳 >= 0) {
 启动_模块执行(最佳)
 已启动 = 已启动 + 1
 改变 = 真
 }
 }
 定义 可变 i = 0
 当 (i < 计数(启动_模块)) { 如果 (启动_模块[i][1] == 启动_未开始) {
 启动_模块[i][1] = 启动_失败
 启动_模块[i][4] = 启动_错误_依赖未满足
 启动_日志记录(启动_错误_依赖未满足)
 }
 i = i + 1
 }
 返回 已启动
}

// 健康检查
函数 启动_健康检查() { 定义 可变 成功 = 0
 定义 可变 失败c = 0
 定义 可变 i = 0
 当 (i < 计数(启动_模块)) { 如果 (启动_模块[i][1] == 启动_成功) { 成功 = 成功 + 1 }
 否则 如果 (启动_模块[i][1] == 启动_失败) { 失败c = 失败c + 1 }
 i = i + 1
 }
 返回 [成功, 失败c, 计数(启动_模块)]
}

函数 启动_清空() { 启动_模块 = []
启动_日志 = []
启动_开始时间 = 0
启动_结束时间 = 0 }

// 启动状态名
函数 启动_状态名(状态) {
    如果 (状态 == 0) { 返回 "未开始"
}
 如果 (状态 == 1) { 返回 "进行中" }
 如果 (状态 == 2) { 返回 "成功" }
 如果 (状态 == 3) { 返回 "失败" }
 返回 "未知"
}

// 启动报告
函数 启动_报告() { 定义 健康 = 启动_健康检查()
 打印("╔═══ 系统启动 ═══╗")
 打印("║ 模块: " + 转字符串(健康[2]) + " 成功: " + 转字符串(健康[0]) + " 失败: " + 转字符串(健康[1]))
 定义 可变 i = 0
 当 (i < 计数(启动_模块)) { 定义 m = 启动_模块[i]
 打印("║ [" + 转字符串(i) + "] " + 转字符串(m[0]) + " " + 启动_状态名(m[1]) + " 优先级=" + 转字符串(m[3]))
 i = i + 1
 }
 打印("║ 日志条数: " + 转字符串(启动_日志数()))
 打印("╚════════════════╝")
}

// 启动全部通过
函数 启动_全部成功() { 定义 健康 = 启动_健康检查()
 返回 健康[1] == 0 且 健康[0] == 健康[2]
}

// 失败模块列表
函数 启动_失败列表() { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(启动_模块)) { 如果 (启动_模块[i][1] == 启动_失败) { 追加(结果, i) }
 i = i + 1
 }
 返回 结果
}

// 重试失败模块
函数 启动_重试失败() { 定义 可变 重试数 = 0
 定义 可变 i = 0
 当 (i < 计数(启动_模块)) { 如果 (启动_模块[i][1] == 启动_失败) {
 启动_模块[i][1] = 启动_未开始
 重试数 = 重试数 + 1
 }
 i = i + 1
 }
 返回 重试数
}

// AI系统启动模板
函数 AI系统_启动() {
 启动_清空()
 定义 核心 = 启动_注册模块(1, 100) // 核心运行时
 定义 内存 = 启动_注册模块(2, 90) // 内存管理
 定义 设备 = 启动_注册模块(3, 80) // 设备检测
 定义 模型 = 启动_注册模块(4, 70) // 模型加载
 定义 推理 = 启动_注册模块(5, 60) // 推理引擎
 定义 服务 = 启动_注册模块(6, 50) // 服务端口
 启动_添加依赖(内存, 核心)
 启动_添加依赖(设备, 核心)
 启动_添加依赖(模型, 内存)
 启动_添加依赖(模型, 设备)
 启动_添加依赖(推理, 模型)
 启动_添加依赖(服务, 推理)
 // 全部自检通过
 定义 可变 i = 0
 定义 总模块 = 计数(启动_模块)
 当 (i < 总模块) { 启动_自检(i, 0)
 i = i + 1 }
 返回 启动_执行全部()
}

// 启动耗时计时
定义 可变 启动_开始时间 = 0
定义 可变 启动_结束时间 = 0

函数 启动_计时开始(当前tick) {
    如果 (当前tick == 空) { 启动_开始时间 = 时间()
}
 否则 { 启动_开始时间 = 当前tick }
}
函数 启动_计时结束(当前tick) {
    如果 (当前tick == 空) { 启动_结束时间 = 时间()
}
 否则 { 启动_结束时间 = 当前tick }
}
函数 启动_耗时() { 定义 可变 差值 = 启动_结束时间 - 启动_开始时间
 如果 (差值 < 0) { 返回 0 }
 返回 差值
}

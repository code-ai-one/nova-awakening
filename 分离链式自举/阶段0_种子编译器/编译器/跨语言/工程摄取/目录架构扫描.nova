// Nova · 跨语言工程摄取 · 目录架构扫描
// 职责: 递归扫描外源工程目录树,生成目录架构模型
// 层级: 跨语言主线第2步 — 目录架构建模

// 目录节点类型

导入("../../../标准库/基础.nova")

定义 节点_目录   = 0
定义 节点_源文件 = 1
定义 节点_配置   = 2
定义 节点_资源   = 3
定义 节点_测试   = 4
定义 节点_文档   = 5
定义 节点_忽略   = 6

// 目录节点: [类型, 路径, 子节点列表, 文件扩展名, 行数估计]
函数 目录节点_创建(类型, 路径) {
    返回 [类型, 路径, [], "", 0]
}

函数 目录节点_类型(n) { 返回 n[0] }
函数 目录节点_路径(n) { 返回 n[1] }
函数 目录节点_子节点(n) { 返回 n[2] }
函数 目录节点_扩展名(n) { 返回 n[3] }
函数 目录节点_行数(n) { 返回 n[4] }

// 文件类型推断
函数 _推断文件类型(路径, 语言) {
    // 测试文件
    如果 (_字符串含(路径, "test") 或 _字符串含(路径, "spec") 或 _字符串含(路径, "_test.go")) {
        返回 节点_测试
    }
    // 配置文件
    如果 (_字符串尾(路径, ".toml") 或 _字符串尾(路径, ".yaml") 或 _字符串尾(路径, ".yml") 或 _字符串尾(路径, ".json") 或 _字符串尾(路径, ".xml") 或 _字符串尾(路径, ".ini")) {
        返回 节点_配置
    }
    // 文档
    如果 (_字符串尾(路径, ".md") 或 _字符串尾(路径, ".txt") 或 _字符串尾(路径, ".rst")) {
        返回 节点_文档
    }
    // 源文件(按语言)
    如果 (语言 == 1) { // Rust
        如果 (_字符串尾(路径, ".rs")) { 返回 节点_源文件 }
    }
    如果 (语言 == 2) { // Go
        如果 (_字符串尾(路径, ".go")) { 返回 节点_源文件 }
    }
    如果 (语言 == 3 或 语言 == 4) { // C/C++
        如果 (_字符串尾(路径, ".c") 或 _字符串尾(路径, ".h") 或 _字符串尾(路径, ".cpp") 或 _字符串尾(路径, ".hpp") 或 _字符串尾(路径, ".cc")) { 返回 节点_源文件 }
    }
    如果 (语言 == 5) { // Python
        如果 (_字符串尾(路径, ".py")) { 返回 节点_源文件 }
    }
    如果 (语言 == 6) { // Java
        如果 (_字符串尾(路径, ".java")) { 返回 节点_源文件 }
    }
    // 资源
    如果 (_字符串尾(路径, ".png") 或 _字符串尾(路径, ".jpg") 或 _字符串尾(路径, ".svg") 或 _字符串尾(路径, ".ico") 或 _字符串尾(路径, ".wasm") 或 _字符串尾(路径, ".bin")) {
        返回 节点_资源
    }
    返回 节点_忽略
}

// 目录架构报告
函数 目录架构_统计(根节点) {
    定义 可变 源文件数 = 0
    定义 可变 测试数 = 0
    定义 可变 配置数 = 0
    定义 可变 资源数 = 0
    定义 可变 总行数 = 0
    _统计递归(根节点, 源文件数, 测试数, 配置数, 资源数, 总行数)
    返回 [源文件数, 测试数, 配置数, 资源数, 总行数]
}

函数 _统计递归(节点, 源文件数, 测试数, 配置数, 资源数, 总行数) {
    如果 (节点[0] == 节点_源文件) { 源文件数 = 源文件数 + 1  总行数 = 总行数 + 节点[4] }
    如果 (节点[0] == 节点_测试)   { 测试数 = 测试数 + 1 }
    如果 (节点[0] == 节点_配置)   { 配置数 = 配置数 + 1 }
    如果 (节点[0] == 节点_资源)   { 资源数 = 资源数 + 1 }
    定义 可变 i = 0
    当 (i < 计数(节点[2])) {
        _统计递归(节点[2][i], 源文件数, 测试数, 配置数, 资源数, 总行数)
        i = i + 1
    }
}

函数 目录架构_打印报告(统计) {
    打印("═══ 目录架构报告 ═══")
    打印文本(字符串拼接("  源文件数: ", 转字符串(统计[0])))
    打印文本(字符串拼接("  测试文件数: ", 转字符串(统计[1])))
    打印文本(字符串拼接("  配置文件数: ", 转字符串(统计[2])))
    打印文本(字符串拼接("  资源文件数: ", 转字符串(统计[3])))
    打印文本(字符串拼接("  估计总行数: ", 转字符串(统计[4])))
}

// 辅助: 简易字符串匹配
函数 _字符串含(s, 子串) {
    定义 sl = 字节长度(s)
    定义 pl = 字节长度(子串)
    如果 (pl > sl) { 返回 假 }
    定义 可变 i = 0
    当 (i <= sl - pl) {
        如果 (子串(s, i, pl) == 子串) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 _字符串尾(s, 后缀) {
    定义 sl = 字节长度(s)
    定义 pl = 字节长度(后缀)
    如果 (pl > sl) { 返回 假 }
    返回 子串(s, sl - pl, pl) == 后缀
}

// Nova · 编译器 · 类型推断引擎 (Type Inference Engine)
// 基于 Hindley-Milner 算法的局部类型推断
// 对 Nova 动态语言做渐进式类型标注，支持类型提示优化

// Nova 内部类型标记

导入("../../标准库/基础.nova")
导入("../../编译器/标记常量.nova")

// 待推断
// i64
// f64
// String
// bool
定义 类型推断_类型_空值  = 5  // nil
定义 类型推断_类型_列表  = 6  // List[T]
定义 类型推断_类型_字典  = 7  // Dict[K,V]
定义 类型推断_类型_函数  = 8  // Func
定义 类型_动态  = 9  // Any（运行时确定）
定义 类型_永不  = 10 // Never（不可达）

// 类型变量（推断中的占位符）
定义 可变 _类型变量计数 = 0

函数 分析_新类型变量() {
    _类型变量计数 = _类型变量计数 + 1
    返回 [0 - _类型变量计数]  // 负数ID表示类型变量
}

函数 是类型变量(t) {
    如果 (!是列表(t) 或 计数(t) == 0) { 返回 假 }
    返回 t[0] < 0
}

函数 类型变量ID(t) { 返回 0 - t[0] }

// 类型表示
// [类型标记, 参数1, 参数2, ...]
函数 类型_整数值() { 返回 [类型_整数] }
函数 类型_浮点值() { 返回 [类型_浮点] }
函数 类型_字符串值() { 返回 [类型_字符串] }
函数 类型_布尔值() { 返回 [类型_布尔] }
函数 类型推断_类型_空值() { 返回 [类型推断_类型_空值] }
函数 类型_动态值() { 返回 [类型_动态] }
函数 类型_永不值() { 返回 [类型_永不] }
函数 类型_列表值(元素类型) { 返回 [类型推断_类型_列表, 元素类型] }
函数 类型_字典值(键类型, 值类型) { 返回 [类型推断_类型_字典, 键类型, 值类型] }
函数 类型_函数值(参数类型列表, 返回类型) {
    返回 [类型推断_类型_函数, 参数类型列表, 返回类型]
}

函数 类型_标记(t) {
    如果 (!是列表(t) 或 计数(t) == 0) { 返回 类型_未知 }
    返回 t[0]
}

函数 类型推断_类型_是数值(t) {
    如果 (!是列表(t) 或 计数(t) == 0) { 返回 假 }
    返回 t[0] == 类型_整数 或 t[0] == 类型_浮点
}

函数 类型_是可比较(t) {
    如果 (!是列表(t) 或 计数(t) == 0) { 返回 假 }
    返回 t[0] == 类型_整数 或 t[0] == 类型_浮点 或 t[0] == 类型_字符串 或 t[0] == 类型_布尔
}

// 类型替换（Substitution）
// 类型变量 → 具体类型的映射
定义 可变 _类型替换表 = 字典()  // 类型变量ID → 类型

函数 推断_重置() {
    _类型替换表 = 字典()
    _类型变量计数 = 0
}

// 查找类型变量的替换（带路径压缩）
函数 推断_查找(t) {
    如果 (!是类型变量(t)) { 返回 t }
    定义 id = 类型变量ID(t)
    定义 绑定 = 字典取(_类型替换表, 转字符串(id))
    如果 (绑定 == 空) { 返回 t }  // 未替换
    // 路径压缩：直接找到最终类型
    定义 最终 = 推断_查找(绑定)
    如果 (最终 != 绑定) {
        字典设(_类型替换表, 转字符串(id), 最终)
    }
    返回 最终
}

// 应用替换到类型（展开类型变量）
函数 推断_应用替换(t) {
    如果 (!是列表(t) 或 计数(t) == 0) { 返回 t }
    t = 推断_查找(t)
    如果 (!是列表(t) 或 计数(t) == 0) { 返回 t }
    如果 (是类型变量(t)) { 返回 t }  // 仍是变量：未解析

    定义 标记 = t[0]
    如果 (标记 == 类型推断_类型_列表 且 计数(t) >= 2) {
        返回 [类型推断_类型_列表, 推断_应用替换(t[1])]
    }
    如果 (标记 == 类型推断_类型_字典 且 计数(t) >= 3) {
        返回 [类型推断_类型_字典, 推断_应用替换(t[1]), 推断_应用替换(t[2])]
    }
    返回 t
}

// ─── occurs check ─── 防止无限类型循环
// 检查类型变量var_id是否出现在类型t中
// 若出现则合一会产生循环替换链(如 T1→List[T1])导致栈溢出
函数 推断_occurs_check(var_id, t) {
    如果 (!是列表(t) 或 计数(t) == 0) { 返回 假 }
    如果 (是类型变量(t)) {
        返回 类型变量ID(t) == var_id
    }
    定义 可变 i = 1
    当 (i < 计数(t)) {
        如果 (推断_occurs_check(var_id, t[i])) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// ─── 合一（Unification）─── 核心算法
// 将两个类型合一：返回真=成功，假=类型错误
函数 推断_合一(t1, t2) {
    t1 = 推断_查找(t1)
    t2 = 推断_查找(t2)

    // 两者相同
    如果 (是列表(t1) 且 是列表(t2) 且 计数(t1) > 0 且 计数(t2) > 0 且 t1[0] == t2[0]) {
        如果 (计数(t1) == 1 且 计数(t2) == 1) { 返回 真 }
        // 递归合一参数
        如果 (计数(t1) >= 2 且 计数(t2) >= 2) {
            返回 推断_合一(t1[1], t2[1]) 且 
                   (计数(t1) < 3 或 计数(t2) < 3 或 推断_合一(t1[2], t2[2]))
        }
        返回 真
    }

    // t1 是类型变量
    如果 (是类型变量(t1)) {
        如果 (推断_occurs_check(类型变量ID(t1), t2)) { 返回 假 }
        字典设(_类型替换表, 转字符串(类型变量ID(t1)), t2)
        返回 真
    }

    // t2 是类型变量
    如果 (是类型变量(t2)) {
        如果 (推断_occurs_check(类型变量ID(t2), t1)) { 返回 假 }
        字典设(_类型替换表, 转字符串(类型变量ID(t2)), t1)
        返回 真
    }

    // 动态类型可以合一任何类型
    如果 (是列表(t1) 且 t1[0] == 类型_动态) { 返回 真 }
    如果 (是列表(t2) 且 t2[0] == 类型_动态) { 返回 真 }

    // 永不类型可以合一任何类型
    如果 (是列表(t1) 且 t1[0] == 类型_永不) { 返回 真 }
    如果 (是列表(t2) 且 t2[0] == 类型_永不) { 返回 真 }

    返回 假  // 类型冲突
}

// 表达式类型推断
// 从 AST 节点推断类型（简化版：仅处理核心节点类型）
函数 推断_表达式类型(节点, 类型环境) {
    如果 (节点 == 空 或 !是列表(节点) 或 计数(节点) == 0) {
        返回 类型_动态值()
    }

    定义 节点类型 = 节点[0]

    // 整数字面量
    如果 (节点类型 == 标记_数字 且 计数(节点) >= 2) {
        返回 类型_整数值()
    }
    // null字面量(165): 推断为空值类型
    如果 (节点类型 == 节点_空字面量) {
        返回 类型推断_类型_空值()
    }
    // 浮点字面量
    如果 (节点类型 == 标记_字串 且 计数(节点) >= 2) {
        返回 类型_浮点值()
    }
    // 字符串字面量
    如果 (节点类型 == 节点_字典 且 计数(节点) >= 2) {
        返回 类型_字符串值()
    }
    // 布尔字面量（真/假）
    如果 (节点类型 == 节点_成员 或 节点类型 == 节点_列表) {
        返回 类型_布尔值()
    }
    // 空值
    如果 (节点类型 == 标记_定义) {
        返回 类型推断_类型_空值()
    }
    // 标识符（变量查找）
    如果 (节点类型 == 标记_名称 且 计数(节点) >= 2) {
        定义 名称 = 节点[1]
        定义 类型 = 字典取(类型环境, 名称)
        如果 (类型 == 空) { 返回 类型_动态值() }
        返回 类型
    }
    // 二元运算
    如果 (节点类型 == 节点_二元 且 计数(节点) >= 4) {
        定义 运算符 = 节点[1]
        定义 左类型 = 推断_表达式类型(节点[2], 类型环境)
        定义 右类型 = 推断_表达式类型(节点[3], 类型环境)
        // 加减乘除：数值运算
        如果 (运算符 >= 1 且 运算符 <= 5) {
            如果 (类型_标记(左类型) == 类型_浮点 或 类型_标记(右类型) == 类型_浮点) {
                返回 类型_浮点值()
            }
            如果 (运算符 == 1 且 类型_标记(左类型) == 类型_字符串) {
                返回 类型_字符串值()
            }
            如果 (类型_标记(左类型) == 类型_整数 且 类型_标记(右类型) == 类型_整数) {
                返回 类型_整数值()
            }
        }
        // 比较运算：返回布尔
        如果 (运算符 >= 6 且 运算符 <= 11) {
            返回 类型_布尔值()
        }
        // 逻辑运算：返回布尔
        如果 (运算符 == 12 或 运算符 == 13) {
            返回 类型_布尔值()
        }
        返回 类型_动态值()
    }
    // 函数调用
    如果 (节点类型 == 节点_调用 且 计数(节点) >= 2) {
        // 从类型环境查找函数返回类型
        定义 函数名 = 节点[1]
        定义 函数类型 = 字典取(类型环境, 函数名)
        如果 (是列表(函数类型) 且 计数(函数类型) >= 3 且 函数类型[0] == 类型推断_类型_函数) {
            返回 函数类型[2]  // 返回类型
        }
        返回 类型_动态值()
    }
    // 列表字面量
    如果 (节点类型 == 节点_赋值) {
        如果 (计数(节点) <= 1) { 返回 类型_列表值(类型_动态值()) }
        // 推断第一个元素的类型作为列表元素类型
        定义 元素类型 = 推断_表达式类型(节点[1], 类型环境)
        返回 类型_列表值(元素类型)
    }
    // 索引访问
    如果 (节点类型 == 节点_索引 且 计数(节点) >= 3) {
        定义 基类型 = 推断_表达式类型(节点[1], 类型环境)
        如果 (是列表(基类型) 且 基类型[0] == 类型推断_类型_列表 且 计数(基类型) >= 2) {
            返回 基类型[1]  // 列表元素类型
        }
        如果 (是列表(基类型) 且 基类型[0] == 类型推断_类型_字典 且 计数(基类型) >= 3) {
            返回 基类型[2]  // 字典值类型
        }
        返回 类型_动态值()
    }

    返回 类型_动态值()
}

// 语句类型检查（更新类型环境）
函数 推断_语句检查(语句, 类型环境) {
    如果 (语句 == 空 或 !是列表(语句) 或 计数(语句) == 0) { 返回 空 }
    定义 节点类型 = 语句[0]

    // 定义语句
    如果 (节点类型 == 标记_可变 且 计数(语句) >= 3) {
        定义 变量名 = 语句[1]
        定义 初值类型 = 推断_表达式类型(语句[2], 类型环境)
        字典设(类型环境, 变量名, 初值类型)
    }

    // 如果语句：推断条件类型
    如果 (节点类型 == 标记_函数 且 计数(语句) >= 2) {
        定义 条件类型 = 推断_表达式类型(语句[1], 类型环境)
        // 记录类型推断信息
        推断_合一(条件类型, 类型_布尔值())
    }
}

// 统计
定义 可变 _推断_合一次数 = 0
定义 可变 _推断_失败次数 = 0

函数 推断_记录合一(成功) {
    _推断_合一次数 = _推断_合一次数 + 1
    如果 (!成功) { _推断_失败次数 = _推断_失败次数 + 1 }
}

函数 推断_统计() {
    返回 [_推断_合一次数, _推断_失败次数, 字典取(_类型替换表, "计数")]
}

// NovaOS ping — 网络连通测试
// 功能: 发送ICMP回显请求, -c次数/-i间隔/-t TTL/-s大小/-W超时/-f洪水, Nova往返时间统计

导入("../感知/流.nova")
导入("../标准/原生字符串.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/高精定器添.nova")
导入("../中枢/整数转字符串.nova")

定义 PING_默认次数 = 4
定义 PING_默认间隔 = 1000
定义 PING_默认TTL = 64
定义 PING_默认大小 = 56
定义 PING_默认超时 = 5000
定义 PING_ICMP_回显请求 = 8
定义 PING_ICMP_回显应答 = 0
定义 PING_ICMP头大小 = 8
定义 PING_IP头大小 = 20

结构 Ping配置 {
    目标,
    次数,
    间隔,
    TTL值,
    包大小,
    超时,
    洪水模式,
    静默模式,
    详细模式,
    解析地址,
}

结构 Ping结果 {
    已发,
    已收,
    总往返时间,
    最小往返时间,
    最大往返时间,
    往返时间列表,
    重复包数,
    错误数,
}

函数 ping_解析参数(参数) {
    定义 配置 = Ping配置 {}
    配置.目标 = ""
    配置.次数 = PING_默认次数
    配置.间隔 = PING_默认间隔
    配置.TTL值 = PING_默认TTL
    配置.包大小 = PING_默认大小
    配置.超时 = PING_默认超时
    配置.洪水模式 = 假
    配置.静默模式 = 假
    配置.详细模式 = 假
    配置.解析地址 = ""

    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 a = 参数[i]
        如果 (a == "-c" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.次数 = 字符串转整数(参数[i])
        } 否则 如果 (a == "-i" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.间隔 = 字符串转整数(参数[i]) * 1000
        } 否则 如果 (a == "-t" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.TTL值 = 字符串转整数(参数[i])
        } 否则 如果 (a == "-s" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.包大小 = 字符串转整数(参数[i])
        } 否则 如果 (a == "-W" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.超时 = 字符串转整数(参数[i]) * 1000
        } 否则 如果 (a == "-f") {
            配置.洪水模式 = 真
        } 否则 如果 (a == "-q") {
            配置.静默模式 = 真
        } 否则 如果 (a == "-v") {
            配置.详细模式 = 真
        } 否则 {
            配置.目标 = a
        }
        i = i + 1
    }

    返回 配置
}

函数 ping_验证配置(配置) {
    如果 (配置.目标 == "") {
        打印行("用法: ping [-c 次数] [-i 间隔秒] [-t TTL] [-s 大小] [-W 超时秒] [-f] [-q] [-v] 目标地址")
        返回 假
    }
    如果 (配置.次数 <= 0) { 配置.次数 = PING_默认次数 }
    如果 (配置.TTL值 <= 0 || 配置.TTL值 > 255) { 配置.TTL值 = PING_默认TTL }
    如果 (配置.包大小 < 0) { 配置.包大小 = PING_默认大小 }
    如果 (配置.包大小 > 65500) { 配置.包大小 = 65500 }
    如果 (配置.超时 <= 0) { 配置.超时 = PING_默认超时 }
    返回 真
}

函数 ping_ICMP校验和(数据, 长度) {
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i + 1 < 长度) {
        和 = 和 + (内存_读8(数据 + i) << 8) + 内存_读8(数据 + i + 1)
        i = i + 2
    }
    如果 (i < 长度) { 和 = 和 + (内存_读8(数据 + i) << 8) }
    当 (和 > 0xFFFF) {
        和 = (和 & 0xFFFF) + (和 >> 16)
    }
    返回 (和 ^ 0xFFFF) & 0xFFFF
}

函数 ping_构造ICMP包(序号, 包大小) {
    定义 总大小 = PING_ICMP头大小 + 包大小
    定义 包 = 堆_分配(总大小)
    内存_写8(包, PING_ICMP_回显请求)  // 类型
    内存_写8(包 + 1, 0)                // 代码
    内存_写16(包 + 2, 0)               // 先清零, 随后写入校验和
    内存_写16(包 + 4, 获取当前进程ID() & 0xFFFF)  // 标识符
    内存_写16(包 + 6, 序号)            // 序号

    // 填充数据
    定义 可变 i = 0
    当 (i < 包大小) {
        内存_写8(包 + PING_ICMP头大小 + i, (i + 65) % 256)
        i = i + 1
    }

    定义 校验和 = ping_ICMP校验和(包, 总大小)
    内存_写16(包 + 2, 校验和)
    返回 [包, 总大小]
}

函数 ping_DNS解析(主机名) {
    // 尝试DNS解析
    定义 ip = 网络_DNS解析(主机名)
    如果 (ip != 空 && ip != "") { 返回 ip }
    返回 主机名
}

函数 ping_计算抖动(往返列表, 数量) {
    如果 (数量 < 2) { 返回 0 }
    定义 可变 总差 = 0
    定义 可变 i = 1
    当 (i < 数量) {
        定义 差 = 往返列表[i] - 往返列表[i - 1]
        如果 (差 < 0) { 差 = 0 - 差 }
        总差 = 总差 + 差
        i = i + 1
    }
    返回 总差 / (数量 - 1)
}

函数 ping_计算标准差(往返列表, 数量, 平均) {
    如果 (数量 < 2) { 返回 0 }
    定义 可变 总方差 = 0
    定义 可变 i = 0
    当 (i < 数量) {
        定义 差 = 往返列表[i] - 平均
        总方差 = 总方差 + 差 * 差
        i = i + 1
    }
    返回 整数平方根(总方差 / 数量)
}

函数 整数平方根(n) {
    如果 (n <= 0) { 返回 0 }
    定义 可变 x = n
    定义 可变 y = (x + 1) / 2
    当 (y < x) {
        x = y
        y = (x + n / x) / 2
    }
    返回 x
}

函数 ping_main(参数) {
    定义 配置 = ping_解析参数(参数)
    如果 (!ping_验证配置(配置)) { 返回 1 }

    // DNS解析
    定义 解析IP = ping_DNS解析(配置.目标)
    配置.解析地址 = 解析IP

    定义 总字节 = 配置.包大小 + PING_ICMP头大小 + PING_IP头大小
    如果 (!配置.静默模式) {
        打印行(字符串拼接("PING ", 字符串拼接(配置.目标, 字符串拼接(" (", 字符串拼接(解析IP, 字符串拼接(") ", 字符串拼接(整数转字符串(配置.包大小), 字符串拼接("(", 字符串拼接(整数转字符串(总字节), ") bytes of data.")))))))))
    }

    定义 结果 = Ping结果 {}
    结果.已发 = 0
    结果.已收 = 0
    结果.总往返时间 = 0
    结果.最小往返时间 = 999999
    结果.最大往返时间 = 0
    结果.往返时间列表 = []
    结果.重复包数 = 0
    结果.错误数 = 0

    定义 可变 序号 = 1
    当 (序号 <= 配置.次数) {
        定义 包信息 = ping_构造ICMP包(序号, 配置.包大小)
        定义 开始时间 = 获取滴答()
        定义 往返时间 = 网络_ping_扩展(解析IP, 包信息[0], 包信息[1], 配置.TTL值, 配置.超时)
        结果.已发 = 结果.已发 + 1

        如果 (往返时间 >= 0) {
            结果.已收 = 结果.已收 + 1
            结果.总往返时间 = 结果.总往返时间 + 往返时间
            如果 (往返时间 < 结果.最小往返时间) { 结果.最小往返时间 = 往返时间 }
            如果 (往返时间 > 结果.最大往返时间) { 结果.最大往返时间 = 往返时间 }
            追加(结果.往返时间列表, 往返时间)

            如果 (!配置.静默模式 && !配置.洪水模式) {
                打印行(字符串拼接(整数转字符串(总字节), 字符串拼接(" bytes from ", 字符串拼接(解析IP, 字符串拼接(": icmp_seq=", 字符串拼接(整数转字符串(序号), 字符串拼接(" ttl=", 字符串拼接(整数转字符串(配置.TTL值), 字符串拼接(" time=", 字符串拼接(整数转字符串(往返时间), " ms"))))))))))
            }
            如果 (配置.洪水模式) { 打印(".") }
        } 否则 如果 (往返时间 == -1) {
            如果 (!配置.静默模式 && !配置.洪水模式) {
                打印行(字符串拼接("Request timeout for icmp_seq ", 整数转字符串(序号)))
            }
        } 否则 如果 (往返时间 == -2) {
            结果.错误数 = 结果.错误数 + 1
            如果 (配置.详细模式) {
                打印行(字符串拼接("From ", 字符串拼接(解析IP, ": Destination Host Unreachable")))
            }
        } 否则 如果 (往返时间 == -3) {
            结果.错误数 = 结果.错误数 + 1
            如果 (配置.详细模式) {
                打印行(字符串拼接("From ", 字符串拼接(解析IP, ": Time to live exceeded")))
            }
        }

        堆_释放(包信息[0])

        // 等待间隔
        如果 (!配置.洪水模式 && 序号 < 配置.次数) {
            睡眠(配置.间隔)
        }
        序号 = 序号 + 1
    }

    如果 (配置.洪水模式) { 打印行("") }

    // 打印统计
    ping_打印统计(配置, 结果)
    返回 0
}

函数 ping_打印统计(配置, 结果) {
    打印行("")
    打印行(字符串拼接("--- ", 字符串拼接(配置.目标, " ping statistics ---")))

    定义 可变 丢包率 = 0
    如果 (结果.已发 > 0) { 丢包率 = (结果.已发 - 结果.已收) * 100 / 结果.已发 }

    定义 可变 统计行 = 字符串拼接(整数转字符串(结果.已发), " packets transmitted, ")
    统计行 = 字符串拼接(统计行, 字符串拼接(整数转字符串(结果.已收), " received, "))
    如果 (结果.重复包数 > 0) {
        统计行 = 字符串拼接(统计行, 字符串拼接("+", 字符串拼接(整数转字符串(结果.重复包数), " duplicates, ")))
    }
    如果 (结果.错误数 > 0) {
        统计行 = 字符串拼接(统计行, 字符串拼接("+", 字符串拼接(整数转字符串(结果.错误数), " errors, ")))
    }
    统计行 = 字符串拼接(统计行, 字符串拼接(整数转字符串(丢包率), "% packet loss"))
    打印行(统计行)

    如果 (结果.已收 > 0) {
        定义 平均 = 结果.总往返时间 / 结果.已收
        定义 标准差 = ping_计算标准差(结果.往返时间列表, 结果.已收, 平均)
        定义 抖动 = ping_计算抖动(结果.往返时间列表, 结果.已收)

        打印行(字符串拼接("rtt min/avg/max/mdev = ", 字符串拼接(整数转字符串(结果.最小往返时间), 字符串拼接("/", 字符串拼接(整数转字符串(平均), 字符串拼接("/", 字符串拼接(整数转字符串(结果.最大往返时间), 字符串拼接("/", 字符串拼接(整数转字符串(标准差), " ms")))))))))

        如果 (抖动 > 0) {
            打印行(字符串拼接("jitter = ", 字符串拼接(整数转字符串(抖动), " ms")))
        }
    }
}

函数 网络_ping(目标) {
    返回 网络_ping_扩展(目标, 0, 0, PING_默认TTL, PING_默认超时)
}

函数 网络_ping_扩展(目标, 包数据, 包大小, ttl, 超时) {
    // 通过系统调用发送ICMP回显请求
    // 返回值: >=0 往返时间ms, -1 超时, -2 不可达, -3 TTL超过
    定义 sock = 网络_创建原始套接字(PING_ICMP_回显请求)
    如果 (sock < 0) { 返回 -2 }

    网络_设置套接字选项(sock, "TTL", ttl)
    网络_设置套接字选项(sock, "超时", 超时)

    定义 开始 = 获取滴答()
    定义 发送结果 = 网络_发送到(sock, 目标, 包数据, 包大小)
    如果 (发送结果 < 0) {
        网络_关闭套接字(sock)
        返回 -2
    }

    定义 接收缓冲 = 堆_分配(1024)
    定义 接收长度 = 网络_接收从(sock, 接收缓冲, 1024)
    定义 结束 = 获取滴答()
    网络_关闭套接字(sock)

    如果 (接收长度 < 0) {
        堆_释放(接收缓冲)
        返回 -1
    }

    // 验证ICMP应答
    如果 (接收长度 >= PING_IP头大小 + PING_ICMP头大小) {
        定义 类型 = 内存_读8(接收缓冲 + PING_IP头大小)
        堆_释放(接收缓冲)
        如果 (类型 == PING_ICMP_回显应答) {
            返回 结束 - 开始
        }
        如果 (类型 == 3) { 返回 -2 }   // 目标不可达
        如果 (类型 == 11) { 返回 -3 }  // TTL超过
    }

    堆_释放(接收缓冲)
    返回 -1
}

函数 网络_DNS解析(主机名) {
    // 系统调用DNS解析
    返回 主机名
}

函数 ping_traceroute(目标, 最大跳数) {
    打印行(字符串拼接("traceroute to ", 字符串拼接(目标, 字符串拼接(", ", 字符串拼接(整数转字符串(最大跳数), " hops max")))))

    定义 可变 ttl = 1
    当 (ttl <= 最大跳数) {
        定义 包信息 = ping_构造ICMP包(ttl, PING_默认大小)
        定义 可变 最佳时间 = 999999
        定义 可变 成功 = 假
        定义 可变 探测 = 0

        打印(字符串拼接(整数转字符串(ttl), "  "))

        当 (探测 < 3) {
            定义 开始 = 获取滴答()
            定义 时间 = 网络_ping_扩展(目标, 包信息[0], 包信息[1], ttl, 3000)
            如果 (时间 >= 0) {
                打印(字符串拼接(整数转字符串(时间), " ms  "))
                成功 = 真
                如果 (时间 < 最佳时间) { 最佳时间 = 时间 }
            } 否则 {
                打印("*  ")
            }
            探测 = 探测 + 1
        }

        打印行("")
        堆_释放(包信息[0])

        如果 (成功 && 最佳时间 < 999999) {
            // 到达目标
        }
        ttl = ttl + 1
    }
}

// NNPT — Nova Network Probe Theory
// 公理1(往返守恒): RTT​ = 发送延迟 + 处理延迟 + 返回延迟
// 公理2(TTL递减): 每个路由跳点TTL严格递减1
// 定理1(丢包率可测): 已发-已收=丢包
// 定理2(路由发现): traceroute必定发现TTL路径上所有超时跳点

函数 ping_探测MTU(目标) {
    定义 可变 上界 = 1500
    定义 可变 下界 = 68     // IPv4最小MTU
    定义 可变 最佳MTU = 下界
    当 (下界 <= 上界) {
        定义 mid = (上界 + 下界) / 2
        定义 负载 = 堆_分配(mid)
        定义 结果 = 网络_ping_扩展(目标, 负载, mid, PING_默认TTL, 2000)
        堆_释放(负载)
        如果 (结果 >= 0) {
            最佳MTU = mid
            下界 = mid + 1
        } 否则 {
            上界 = mid - 1
        }
    }
    返回 最佳MTU
}

定义 可变 NNPT_总探测数 = 0
定义 可变 NNPT_成功数 = 0
定义 可变 NNPT_总RTT = 0
定义 可变 NNPT_最小RTT = 999999
定义 可变 NNPT_最大RTT = 0

函数 NNPT_记录(往返时间) {
    NNPT_总探测数 = NNPT_总探测数 + 1
    如果 (往返时间 >= 0) {
        NNPT_成功数 = NNPT_成功数 + 1
        NNPT_总RTT = NNPT_总RTT + 往返时间
        如果 (往返时间 < NNPT_最小RTT) { NNPT_最小RTT = 往返时间 }
        如果 (往返时间 > NNPT_最大RTT) { NNPT_最大RTT = 往返时间 }
    }
}

函数 NNPT_平均RTT() {
    如果 (NNPT_成功数 == 0) { 返回 0 }
    返回 NNPT_总RTT / NNPT_成功数
}

函数 NNPT_丢包率() {
    如果 (NNPT_总探测数 == 0) { 返回 0 }
    返回 (NNPT_总探测数 - NNPT_成功数) * 1000 / NNPT_总探测数
}

函数 NNPT_重置() {
    NNPT_总探测数 = 0; NNPT_成功数 = 0
    NNPT_总RTT = 0; NNPT_最小RTT = 999999; NNPT_最大RTT = 0
}

函数 NNPT_完整诊断() {
    返回 [
        "总探测数", NNPT_总探测数,
        "成功数", NNPT_成功数,
        "平均RTT", NNPT_平均RTT(),
        "最小RTT", NNPT_最小RTT,
        "最大RTT", NNPT_最大RTT,
        "丢包率", NNPT_丢包率(),
        "原生独创_NNPT网络探测", 1
    ]
}

函数 ping_批量探测(目标列表, 超时) {
    定义 结果 = []
    定义 可变 i = 0
    当 (i < 计数(目标列表)) {
        定义 rtt = 网络_ping_扩展(目标列表[i], 0, 0, PING_默认TTL, 超时)
        NNPT_记录(rtt)
        追加(结果, [目标列表[i], rtt])
        i = i + 1
    }
    返回 结果
}

函数 ping_连续探测(目标, 次数, 间隔ms) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 次数) {
        定义 rtt = 网络_ping_扩展(目标, 0, 0, PING_默认TTL, PING_默认超时)
        NNPT_记录(rtt)
        追加(结果, rtt)
        如果 (i < 次数 - 1 && 间隔ms > 0) {
            睡眠(间隔ms)
        }
        i = i + 1
    }
    返回 结果
}

函数 NNPT_质量评分() {
    // 0-100评分: RTT低+丢包少=高分
    定义 可变 分 = 100
    定义 平均 = NNPT_平均RTT()
    如果 (平均 > 200) { 分 = 分 - 30 }
    否则 如果 (平均 > 100) { 分 = 分 - 15 }
    否则 如果 (平均 > 50) { 分 = 分 - 5 }
    定义 丢包 = NNPT_丢包率()
    如果 (丢包 > 100) { 分 = 分 - 40 }
    否则 如果 (丢包 > 50) { 分 = 分 - 20 }
    否则 如果 (丢包 > 10) { 分 = 分 - 5 }
    // 报动惩罚
    如果 (NNPT_最大RTT - NNPT_最小RTT > 100) { 分 = 分 - 10 }
    如果 (分 < 0) { 分 = 0 }
    返回 分
}

函数 NNPT_获取总探测数() { 返回 NNPT_总探测数 }
函数 NNPT_获取成功数() { 返回 NNPT_成功数 }
函数 NNPT_获取最小RTT() { 返回 NNPT_最小RTT }
函数 NNPT_获取最大RTT() { 返回 NNPT_最大RTT }

函数 ping_获取默认配置() {
    返回 {
        次数: PING_默认次数,
        TTL: PING_默认TTL,
        超时: PING_默认超时,
        大小: PING_默认大小,
        间隔: PING_默认间隔
    }
}

定义 可变 AI_探测_带宽估计 = 0
定义 可变 AI_探测_丢包窗口 = []

函数 AI_探测_带宽预测(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 AI_探测_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    AI_探测_带宽估计 = AI_探测_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 AI_探测_带宽估计
}

函数 AI_探测_拥塞建议(丢包率) {
    追加(AI_探测_丢包窗口, 丢包率)
    如果 (计数(AI_探测_丢包窗口) > 10) { 列表_移除(AI_探测_丢包窗口, 0) }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}

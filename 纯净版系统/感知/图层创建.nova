导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./内核直连层.nova")

//       cc/trees/layer_tree_host_impl.cc (~5000行)
//       cc/scheduler/scheduler.cc (~2000行)
//       cc/tiles/tile_manager.cc 
//       cc/animation/animation_host.cc (~2000行)
//       cc/input/scroll_input_handler.cc (~1500行)
// NovaOS合成架构(关键创新):
//   主线程(Main): DOM/样式/布局/绘制 → 生成绘制指令列表
//   合成线程(Impl): 独立于主线程, 负责:
//     ① 将绘制指令光栅化为图处纹理(Tile)
//     ② 合成所有Layer为最终帧
//     ③ 处理滚动(不需要等主线程!)
//     ④ 驱动CSS动画/过渡
//     ⑤ 按VSync节奏提交帧
//   这就是为什么Nova浏览器滚动流畅: 滚动在合成线程处理,
//   即使JS在主线程卡死, 滚动仍然60fps
// 【颠覆性创新】AI总线驱动的智能合成:
//   ① AI预测滚动方向→提前光栅化即将进入视口的Tile
//   ② AI评估Layer复杂度→决定图处合成vs软件合成
//   ③ AI监控帧耗时→自动调整Tile大小和质量
//   ④ AI感知质量→外围Tile用低分辨率, 中央Tile高分辨率

// §1 合成器常量与状态

// Tile(瓦片)大小: 256×256像素(NovaOS默认)
定义 TILE_大小       = 256
定义 TILE_最大数量   = 512

// 合成器状态
定义 合成状态_空闲         = 0
定义 合成状态_等待主线程   = 1
定义 合成状态_光栅化中     = 2
定义 合成状态_合成中       = 3
定义 合成状态_等待VSync    = 4

// 帧调度器状态
定义 调度_无待处理         = 0
定义 调度_有待处理_主线程  = 1
定义 调度_有待处理_合成    = 2
定义 调度_提交中           = 3

// Layer合成类型
定义 合成类型_无           = 0
定义 合成类型_图处纹理     = 1     // 图处纹理合成(最快)
定义 合成类型_软件位图     = 2     // 软件光栅化→图处上传
定义 合成类型_视频帧       = 3     // 视频解码器输出
定义 合成类型_图绘        = 4     // 图绘上下文

// §2 Tile(瓦片) — 光栅化的最小单位
// 每个Layer被分割为256×256的Tile
// 好处:
//   ① 增量光栅化: 只光栅化可见的Tile
//   ② 内存管理: 不可见Tile可释放纹理
//   ③ 并行光栅化: 多个Tile可并行光栅化
//   ④ 滚动优化: 滚动时只需光栅化新进入视口的Tile

结构 Tile {
    纹理ID,    // u32 图处纹理ID (0=未光栅化)
    层ID,    // u32 所属Layer
    格x,    // u16 Tile在Layer中的列号
    格y,    // u16 Tile在Layer中的行号
    像素x,    // i32 世界坐标x = 格x × TILE_大小
    像素y,    // i32 世界坐标y
    状态,    // u8 0=未创建 1=待光栅 2=光栅中 3=已就绪 4=已失效
    优先级,    // u8 光栅化优先级(AI决定)
    分辨率,    // u8 0=跳过 1=1/4 2=1/2 3=完整
    上次使用帧,    // u32 上次在合成中使用的帧号
}

定义 Tile状态_未创建   = 0
定义 Tile状态_待光栅   = 1
定义 Tile状态_光栅中   = 2
定义 Tile状态_已就绪   = 3
定义 Tile状态_已失效   = 4

// §3 合成Layer — 每个提升为合成层的绘制Layer

结构 CompositedLayer {
    ID,
    源绘制Layer,    // u64 绘制Layer*

    // 世界坐标和大小
    x,
    y,
    宽,
    高,
    // Tile网格
    Tile列数,    // u32 ceil(宽/TILE_大小)
    Tile行数,    // u32 ceil(高/TILE_大小)
    Tiles,    // u64 Tile* 数组

    // 变换
    变换矩阵,    // [6]i32 2D仿射: [a,b,c,d,tx,ty] (Q10定点)
    透明度,    // u8 0-255
    有变换,
    有滤镜,
    // 合成属性
    合成类型,
    混合模式,    // u32 normal/multiply/screen/...
    裁剪区域,    // [4]i32 [x,y,w,h] 裁剪矩形

    // AI属性
    渲染精度,    // u8 0=跳过 1=低 2=中 3=高
    视口可见,    // u8 0=不可见 1=部分 2=完全
    语义重要性,    // i32 Q10: AI总线语义权重
}

函数 CompositedLayer_创建(paintLayer, x, y, 宽, 高) {
    定义 cl = 堆_分配(CompositedLayer)
    cl.源绘制Layer = paintLayer
    cl.x = x
    cl.y = y
    cl.宽 = 宽
    cl.高 = 高

    // 计算Tile网格
    cl.Tile列数 = (宽 + TILE_大小 - 1) / TILE_大小
    cl.Tile行数 = (高 + TILE_大小 - 1) / TILE_大小
    定义 Tile总数 = cl.Tile列数 * cl.Tile行数
    cl.Tiles = 堆_分配_数组(Tile总数 * 32)    // 每个Tile 32字节

    // 初始化Tile
    定义 可变 row = 0
    当 (row < cl.Tile行数) {
        定义 可变 col = 0
        当 (col < cl.Tile列数) {
            定义 idx = row * cl.Tile列数 + col
            定义 偏移 = cl.Tiles + idx * 32
            内存_写32(偏移, 0)         // 纹理ID=0
            内存_写16(偏移 + 8, col)   // 格x
            内存_写16(偏移 + 10, row)  // 格y
            内存_写32(偏移 + 12, x + col * TILE_大小)   // 像素x
            内存_写32(偏移 + 16, y + row * TILE_大小)   // 像素y
            内存_写8(偏移 + 20, Tile状态_未创建)
            内存_写8(偏移 + 21, 128)   // 默认优先级
            内存_写8(偏移 + 22, 3)     // 默认完整分辨率
            col = col + 1
        }
        row = row + 1
    }

    cl.透明度 = 255
    cl.合成类型 = 合成类型_图处纹理
    cl.渲染精度 = 2
    返回 cl
}

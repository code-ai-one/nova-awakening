// §3 定时器 (setTimeout / setInterval)

函数 事件循环_setTimeout(回调, 延迟毫秒) {
    定义 任务 = 浏览器任务 {}
    任务.ID = 事件循环.下一个ID
    事件循环.下一个ID = 事件循环.下一个ID + 1
    任务.类型 = 任务_定时器
    任务.回调 = 回调
    任务.延迟 = 延迟毫秒
    任务.重复 = 假
    追加(事件循环.定时器列表, 任务)
    返回 任务.ID
}

函数 事件循环_setInterval(回调, 间隔毫秒) {
    定义 任务 = 浏览器任务 {}
    任务.ID = 事件循环.下一个ID
    事件循环.下一个ID = 事件循环.下一个ID + 1
    任务.类型 = 任务_定时器
    任务.回调 = 回调
    任务.间隔 = 间隔毫秒
    任务.重复 = 真
    追加(事件循环.定时器列表, 任务)
    返回 任务.ID
}

函数 事件循环_clearTimer(定时器ID) {
    定义 可变 i = 0
    当 (i < 计数(事件循环.定时器列表)) {
        如果 (事件循环.定时器列表[i].ID == 定时器ID) {
            列表_移除(事件循环.定时器列表, i)
            返回
        }
        i = i + 1
    }
}

// §4 requestAnimationFrame

函数 事件循环_requestAnimationFrame(回调) {
    定义 任务 = 浏览器任务 {}
    任务.ID = 事件循环.下一个ID
    事件循环.下一个ID = 事件循环.下一个ID + 1
    任务.类型 = 任务_渲染帧
    任务.回调 = 回调
    追加(事件循环.帧回调队列, 任务)
    返回 任务.ID
}

// §5 主事件循环 — 浏览器心跳

函数 事件循环_启动() {
    事件循环.运行中 = 真
    内核信息("浏览器事件循环: 启动")

    当 (事件循环.运行中) {
        事件循环_单次迭代()
    }
}

函数 事件循环_停止() {
    事件循环.运行中 = 假
}

函数 事件循环_单次迭代() {
    // ① 检查到期定时器
    事件循环_检查定时器()

    // ② 执行一个宏任务(最高优先级)
    如果 (计数(事件循环.宏任务队列) > 0) {
        定义 任务 = 事件循环.宏任务队列[0]
        列表_移除(事件循环.宏任务队列, 0)
        事件循环_执行任务(任务)
    }

    // ③ 清空微任务队列
    当 (计数(事件循环.微任务队列) > 0) {
        定义 微任务 = 事件循环.微任务队列[0]
        列表_移除(事件循环.微任务队列, 0)
        事件循环_执行任务(微任务)
    }

    // ④ 检查是否到渲染帧时间
    定义 当前时间 = 高精度定时器_读取()
    如果 (当前时间 - 事件循环.上帧时间 >= 事件循环.帧间隔) {
        // 通知调度器: 帧开始
        浏览器调度_帧开始()

        // 执行rAF回调
        定义 可变 帧回调 = 事件循环.帧回调队列
        事件循环.帧回调队列 = []
        定义 可变 i = 0
        当 (i < 计数(帧回调)) {
            事件循环_执行任务(帧回调[i])
            i = i + 1
        }

        // 样式计算 + 布局 + 绘制
        渲染_布局()
        如果 (DOM_当前文档 != 空) {
            渲染_绘制(DOM_当前文档)
        }

        // 帧结束
        浏览器调度_帧结束()

        定义 帧耗时 = 高精度定时器_读取() - 当前时间
        如果 (帧耗时 > 事件循环.帧间隔) {
            事件循环.丢帧数 = 事件循环.丢帧数 + 1
        }

        事件循环.上帧时间 = 当前时间
        事件循环.帧计数 = 事件循环.帧计数 + 1
        事件循环.总帧数 = 事件循环.总帧数 + 1
    }

    // ⑤ 空闲时间执行空闲回调
    如果 (计数(事件循环.宏任务队列) == 0 && 计数(事件循环.空闲回调) > 0) {
        定义 空闲任务 = 事件循环.空闲回调[0]
        列表_移除(事件循环.空闲回调, 0)
        事件循环_执行任务(空闲任务)
    }
}

函数 事件循环_执行任务(任务) {
    如果 (任务.类型 == 任务_用户输入) {
        // 分发用户输入事件
        事件循环_处理用户输入(任务)
    } 否则 如果 (任务.类型 == 任务_网络回调) {
        // 网络请求完成回调
        JS_执行脚本(任务.回调)
    } 否则 如果 (任务.类型 == 任务_定时器) {
        JS_执行脚本(任务.回调)
    } 否则 如果 (任务.类型 == 任务_渲染帧) {
        JS_执行脚本(任务.回调)
    } 否则 如果 (任务.类型 == 任务_微任务) {
        JS_执行脚本(任务.回调)
    } 否则 如果 (任务.类型 == 任务_AI推理) {
        // AI推理结果回调
        事件循环_处理AI回调(任务)
    } 否则 如果 (任务.类型 == 任务_系统事件) {
        事件循环_处理系统事件(任务)
    }
}

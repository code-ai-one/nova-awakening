// Nova · 标准库 · 版本号管理
// 语义版本(SemVer) + 预发布标签 + 版本约束 + 依赖解析

导入("../基础.nova")
导入("../../工具/包管理器/包管理器.nova")

// 全局统计
定义 可变 _版本_比较次数 = 0
定义 可变 _版本_解析次数 = 0
定义 可变 _版本_注册表 = []

// 基础版本

函数 版本号_版本_创建(主, 次, 补丁) { 返回 [主, 次, 补丁, "", ""] }

函数 版本_创建完整(主, 次, 补丁, 预发布, 构建号) { 返回 [主, 次, 补丁, 预发布, 构建号]
}

函数 版本号_版本_主(v) { 返回 v[0] }
函数 版本号_版本_次(v) { 返回 v[1] }
函数 版本_补丁(v) { 返回 v[2] }
函数 版本_预发布(v) { 返回 v[3] }
函数 版本_构建号(v) { 返回 v[4] }

// 版本解析

函数 版本号_版本_解析(文本) { _版本_解析次数 = _版本_解析次数 + 1
 定义 可变 部分 = [0,]
 定义 可变 当前 = 0
 定义 可变 段 = 0
 定义 可变 i = 0
 定义 可变 预发布 = ""
 定义 可变 构建号 = ""
 定义 可变 阶段 = 0
 当 (i < 字节长度(文本)) { 定义 c = 字节取(文本, i)
 如果 (阶段 == 0) { 如果 (c == 字符_句点) { 如果 (段 < 3) { 部分[段] = 当前 }
 段 = 段 + 1
 当前 = 0
 } 否则 如果 (c == 字符_减号) { 如果 (段 < 3) { 部分[段] = 当前 }
 阶段 = 1
 } 否则 如果 (c == 字符_加号) { 如果 (段 < 3) { 部分[段] = 当前 }
 阶段 = 2
 } 否则 如果 (c >= 字符_零 且 c <= 字符_九) {
 当前 = 当前 * 10 + c - 48
 }
 } 否则 如果 (阶段 == 1) { 如果 (c == 字符_加号) { 阶段 = 2 }
 否则 { 预发布 = 字符串拼接(预发布, 字符(c)) }
 } 否则 {
 构建号 = 字符串拼接(构建号, 字符(c))
 }
 i = i + 1
 }
 如果 (阶段 == 0 且 段 < 3) { 部分[段] = 当前 }
 返回 [部分[0], 部分[1], 部分[2], 预发布, 构建号]
}

// 版本比较

函数 版本号_版本_比较(a, b) { _版本_比较次数 = _版本_比较次数 + 1
 如果 (a[0] != b[0]) { 返回 a[0] - b[0] }
 如果 (a[1] != b[1]) { 返回 a[1] - b[1] }
 如果 (a[2] != b[2]) { 返回 a[2] - b[2] }
 如果 (a[3] != "" 且 b[3] == "") { 返回 -1 }
 如果 (a[3] == "" 且 b[3] != "") { 返回 1 }
 返回 0
}

函数 版本_等于(a, b) { 返回 版本号_版本_比较(a, b) == 0 }
函数 版本_大于(a, b) { 返回 版本号_版本_比较(a, b) > 0 }
函数 版本_小于(a, b) { 返回 版本号_版本_比较(a, b) < 0 }
函数 版本_大于等于(a, b) { 返回 版本号_版本_比较(a, b) >= 0 }
函数 版本_小于等于(a, b) { 返回 版本号_版本_比较(a, b) <= 0 }

函数 版本_在范围内(版本, 最小, 最大) { 返回 版本_大于等于(版本, 最小) 且 版本_小于等于(版本, 最大)
}

// 版本格式化

函数 版本号_版本_格式化(v) { 定义 可变 s = 转字符串(v[0])
 s = 字符串拼接(s, ".")
 s = 字符串拼接(s, 转字符串(v[1]))
 s = 字符串拼接(s, ".")
 s = 字符串拼接(s, 转字符串(v[2]))
 如果 (v[3] != "") {
 s = 字符串拼接(s, "-")
 s = 字符串拼接(s, v[3])
 }
 如果 (v[4] != "") {
 s = 字符串拼接(s, "+")
 s = 字符串拼接(s, v[4])
 }
 返回 s
}

函数 版本_短格式(v) { 定义 可变 s = 转字符串(v[0])
 s = 字符串拼接(s, ".")
 s = 字符串拼接(s, 转字符串(v[1]))
 返回 s
}

// 版本递增

函数 版本_递增主(v) { 返回 [v[0] + 1, 0, "", ""] }
函数 版本_递增次(v) { 返回 [v[0], v[1] + 1, 0, "", ""] }
函数 版本_递增补丁(v) { 返回 [v[0], v[1], v[2] + 1, "", ""] }

函数 版本_设预发布(v, 标签) { 返回 [v[0], v[1], v[2], 标签, v[4]]
}

函数 版本_设构建号(v, 号) { 返回 [v[0], v[1], v[2], v[3], 号]
}

// 兼容性检查

函数 版本号_版本_兼容(a, b) { 返回 a[0] == b[0] }

函数 版本_API兼容(a, b) {
    如果 (a[0] != b[0]) { 返回 假
}
 如果 (a[0] == 0) { 返回 a[1] == b[1] }
 返回 真
}

函数 版本_向后兼容(旧, 新) {
    如果 (新[0] != 旧[0]) { 返回 假
}
 如果 (新[1] < 旧[1]) { 返回 假 }
 如果 (新[1] == 旧[1] 且 新[2] < 旧[2]) { 返回 假 }
 返回 真
}

// 版本约束

定义 约束_精确 = 0
定义 约束_兼容 = 1
定义 约束_波浪 = 2
定义 约束_大于等于 = 3
定义 约束_小于 = 4
定义 约束_范围 = 5

函数 版本约束_创建(类型, 版本) { 返回 [类型, 版本]
}

函数 版本约束_满足(约束, 版本) { 定义 类型 = 约束[0]
 定义 基准 = 约束[1]
 如果 (类型 == 约束_精确) { 返回 版本_等于(版本, 基准) }
 如果 (类型 == 约束_兼容) { 返回 版本[0] == 基准[0] 且 版本_大于等于(版本, 基准)
 }
 如果 (类型 == 约束_波浪) { 返回 版本[0] == 基准[0] 且 版本[1] == 基准[1] 且 版本_大于等于(版本, 基准)
 }
 如果 (类型 == 约束_大于等于) { 返回 版本_大于等于(版本, 基准) }
 如果 (类型 == 约束_小于) { 返回 版本_小于(版本, 基准) }
 返回 假
}

函数 版本约束_格式化(约束) { 定义 前缀列表 = ["==", "^", "~", ">=", "<"]
 如果 (约束[0] >= 0 且 约束[0] < 5) { 返回 字符串拼接(前缀列表[约束[0]], 版本号_版本_格式化(约束[1]))
 }
 返回 版本号_版本_格式化(约束[1])
}

// 多约束检查

函数 版本约束_全部满足(约束列表, 版本) { 定义 可变 i = 0
 当 (i < 计数(约束列表)) { 如果 (!版本约束_满足(约束列表[i], 版本)) { 返回 假 }
 i = i + 1
 }
 返回 真
}

函数 版本约束_任一满足(约束列表, 版本) { 定义 可变 i = 0
 当 (i < 计数(约束列表)) { 如果 (版本约束_满足(约束列表[i], 版本)) { 返回 真 }
 i = i + 1
 }
 返回 假
}

// 版本列表操作

函数 版本_排序(列表) { 定义 可变 已改变 = 1
 当 (已改变 == 1) {
 已改变 = 0
 定义 可变 i = 0
 当 (i < 计数(列表) - 1) { 如果 (版本号_版本_比较(列表[i], 列表[i + 1]) > 0) { 定义 临时 = 列表[i]
 列表[i] = 列表[i + 1]
 列表[i + 1] = 临时
 已改变 = 1
 }
 i = i + 1
 }
 }
}

函数 版本_最新(列表) {
    如果 (计数(列表) == 0) { 返回 空
}
 定义 可变 最新 = 列表[0]
 定义 可变 i = 1
 当 (i < 计数(列表)) { 如果 (版本号_版本_比较(列表[i], 最新) > 0) { 最新 = 列表[i] }
 i = i + 1
 }
 返回 最新
}

函数 版本_最旧(列表) {
    如果 (计数(列表) == 0) { 返回 空
}
 定义 可变 最旧 = 列表[0]
 定义 可变 i = 1
 当 (i < 计数(列表)) { 如果 (版本号_版本_比较(列表[i], 最旧) < 0) { 最旧 = 列表[i] }
 i = i + 1
 }
 返回 最旧
}

函数 版本_筛选满足(列表, 约束) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(列表)) { 如果 (版本约束_满足(约束, 列表[i])) {
 追加(结果, 列表[i])
 }
 i = i + 1
 }
 返回 结果
}

函数 版本_最佳匹配(列表, 约束) { 定义 满足列表 = 版本_筛选满足(列表, 约束)
 返回 版本_最新(满足列表)
}

// 版本转换

函数 版本_转整数(v) { 返回 v[0] * 1000000 + v[1] * 1000 + v[2]
}

函数 版本_从整数(n) { 返回 [n / 1000000, (n / 1000) % 1000, n % 1000, "", ""]
}

函数 版本_转数组(v) { 返回 [v[0], v[1], v[2]] }

// 版本注册表

函数 版本注册表_注册(名称, 版本) {
 追加(_版本_注册表, [名称, 版本])
}

函数 版本注册表_查询(名称) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(_版本_注册表)) { 如果 (_版本_注册表[i][0] == 名称) {
 追加(结果, _版本_注册表[i][1])
 }
 i = i + 1
 }
 返回 结果
}

函数 版本注册表_最新(名称) { 定义 版本列表 = 版本注册表_查询(名称)
 返回 版本_最新(版本列表)
}

// 版本差异

函数 版本_差异类型(旧, 新) {
    如果 (新[0] != 旧[0]) { 返回 "主版本变更(不兼容)"
}
 如果 (新[1] != 旧[1]) { 返回 "次版本变更(新功能)" }
 如果 (新[2] != 旧[2]) { 返回 "补丁变更(修复)" }
 返回 "无变更"
}

函数 版本_距离(a, b) { 定义 可变 距离 = 0
 如果 (a[0] != b[0]) { 定义 可变 差 = a[0] - b[0]
 如果 (差 < 0) { 差 = -差 }
 距离 = 距离 + 差 * 1000
 }
 如果 (a[1] != b[1]) { 定义 可变 差 = a[1] - b[1]
 如果 (差 < 0) { 差 = -差 }
 距离 = 距离 + 差 * 10
 }
 如果 (a[2] != b[2]) { 定义 可变 差 = a[2] - b[2]
 如果 (差 < 0) { 差 = -差 }
 距离 = 距离 + 差
 }
 返回 距离
}

// 预发布标签判断

函数 版本_是预发布(v) { 返回 v[3] != "" }
函数 版本_是稳定(v) { 返回 v[3] == "" 且 v[0] > 0 }
函数 版本_是开发(v) { 返回 v[0] == 0 }

函数 版本_预发布类型(v) {
    如果 (v[3] == "") { 返回 "稳定版"
}
 定义 可变 标签 = v[3]
 定义 可变 i = 0
 定义 可变 前缀 = ""
 当 (i < 字节长度(标签) 且 i < 5) {
 前缀 = 字符串拼接(前缀, 字符(字节取(标签, i)))
 i = i + 1
 }
 如果 (前缀 == "alpha") { 返回 "Alpha版" }
 如果 (前缀 == "beta") { 返回 "Beta版" }
 如果 (前缀 == "rc") { 返回 "候选版" }
 返回 "预发布"
}

函数 版本_升级风险(当前, 目标) {
    如果 (版本_等于(当前, 目标)) { 返回 [0, "无需升级"]
}
 如果 (版本_小于(当前, 目标)) { 如果 (目标[0] != 当前[0]) { 返回 [90, "高风险: 主版本变更,API可能不兼容"] }
 如果 (目标[1] != 当前[1]) { 返回 [40, "中风险: 新功能,通常向后兼容"] }
 返回 [10, "低风险: 补丁更新"]
 }
 返回 [70, "警告: 降级操作"]
}

函数 版本_升级路径(当前, 可用列表) { 定义 可变 路径 = []
 版本_排序(可用列表)
 定义 可变 i = 0
 当 (i < 计数(可用列表)) { 如果 (版本_大于(可用列表[i], 当前)) { 定义 风险 = 版本_升级风险(当前, 可用列表[i])
 追加(路径, [版本号_版本_格式化(可用列表[i]), 风险[0], 风险[1]])
 }
 i = i + 1
 }
 返回 路径
}

// 版本哈希

函数 版本_哈希(v) { 返回 (v[0] * 7919 + v[1] * 541 + v[2] * 31) % 2147483647
}

函数 版本_唯一键(v) { 返回 字符串拼接(转字符串(v[0]), 字符串拼接(".", 字符串拼接(转字符串(v[1]), 字符串拼接(".", 转字符串(v[2])))))
}

// 依赖项

函数 依赖_创建(名称, 约束) { 返回 [名称, 约束, 空]
}

函数 版本号_依赖_解析(dep, _注册表查询) { 定义 可用 = 版本注册表_查询(dep[0])
 如果 (计数(可用) == 0) { 返回 ["错误", "未找到依赖"] }
 定义 匹配 = 版本_最佳匹配(可用, dep[1])
 如果 (匹配 == 空) { 返回 ["错误", "无满足约束的版本"] }
 dep[2] = 匹配
 返回 ["成功", 匹配]
}

函数 依赖列表_解析(列表) { 定义 可变 结果 = []
 定义 可变 失败 = 0
 定义 可变 i = 0
 当 (i < 计数(列表)) { 定义 r = 版本号_依赖_解析(列表[i], 空)
 追加(结果, [列表[i][0], r[0], r[1]])
 如果 (r[0] == "错误") { 失败 = 失败 + 1 }
 i = i + 1
 }
 返回 [结果, 失败]
}

// 变更日志

定义 可变 _版本_变更日志 = []

函数 变更日志_添加(版本, 类型, 描述) {
 追加(_版本_变更日志, [版本, 类型, 描述])
}

函数 变更日志_按版本(目标版本) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(_版本_变更日志)) { 如果 (版本_等于(_版本_变更日志[i][0], 目标版本)) {
 追加(结果, _版本_变更日志[i])
 }
 i = i + 1
 }
 返回 结果
}

函数 变更日志_按类型(类型) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(_版本_变更日志)) { 如果 (_版本_变更日志[i][1] == 类型) {
 追加(结果, _版本_变更日志[i])
 }
 i = i + 1
 }
 返回 结果
}

// 版本克隆与合并

函数 版本_克隆(v) { 返回 [v[0], v[1], v[2], v[3], v[4]]
}

函数 版本_去重(列表) { 定义 可变 结果 = []
 定义 可变 i = 0
当 (i < 计数(列表)) {
 定义 可变 j = 0
 当 (j < 计数(结果)) { 如果 (版本_等于(列表[i], 结果[j])) { 重复 = 真 }
 j = j + 1
 }
 如果 (!重复) { 追加(结果, 列表[i]) }
 i = i + 1
 }
 返回 结果
}

函数 版本_趋势分析(历史列表) {
    如果 (计数(历史列表) < 2) { 返回 "数据不足"
}
 版本_排序(历史列表)
 如果 (计数(历史列表) == 0) { 返回 空 }
 定义 最新 = 历史列表[计数(历史列表) - 1]
 定义 次新 = 历史列表[计数(历史列表) - 2]
 定义 差异 = 版本_差异类型(次新, 最新)
 如果 (差异 == "主版本变更(不兼容)") { 返回 "活跃迭代(频繁不兼容变更)" }
 如果 (差异 == "次版本变更(新功能)") { 返回 "稳定增长(持续添加功能)" }
 返回 "维护模式(仅修复)"
}

函数 版本_冲突检测(依赖列表) { 定义 可变 冲突 = []
 定义 可变 i = 0
 当 (i < 计数(依赖列表)) { 定义 可变 j = i + 1
 当 (j < 计数(依赖列表)) { 如果 (依赖列表[i][0] == 依赖列表[j][0]) { 如果 (依赖列表[i][2] != 空 且 依赖列表[j][2] != 空) { 如果 (!版本_等于(依赖列表[i][2], 依赖列表[j][2])) {
 追加(冲突, [依赖列表[i][0], 依赖列表[i][2], 依赖列表[j][2]])
 }
 }
 }
 j = j + 1
 }
 i = i + 1
 }
 返回 冲突
}

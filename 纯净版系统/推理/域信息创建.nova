// JavaScript的作用域是词法作用域(lexical scope):
//   函数在定义时就确定了能访问哪些外部变量
//   闭包 = 函数 + 它引用的外部作用域变量
// Nova的作用域实现:
//   ScopeInfo (编译时) → Context (运行时)
//   每层作用域对应一个Context对象,形成链表
//   闭包通过Context链访问外部变量
// 本文件实现:
//   1. 作用域类型(全局/函数/块/模块/with/catch/eval)
//   2. 变量查找(沿作用域链向上)
//   3. 闭包变量捕获(Heap-allocated variables)
//   4. arguments对象
//   5. 严格模式检测和语义差异
//   6. let/const暂时性死区(TDZ)
//   7. var提升(hoisting)

导入("./上下文运行时.nova")
导入("./字节码操作码.nova")
导入("../中枢/系统调用表.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/辅助存根.nova")

// §1 作用域类型 

定义 作用域_全局 = 0 // 全局作用域(顶层)
定义 作用域_函数 = 1 // 函数作用域
定义 作用域_块 = 2 // 块作用域(let/const)
定义 作用域_模块 = 3 // ES模块作用域
定义 作用域_With = 4 // with语句作用域
定义 作用域_Catch = 5 // try-catch的catch作用域
定义 作用域_Eval = 6 // eval()作用域

// 变量声明类型
定义 变量_var = 0 // var: 函数作用域, 提升
定义 变量_let = 1 // let: 块作用域, TDZ
定义 变量_const = 2 // const: 块作用域, TDZ, 不可赋值
定义 变量_function = 3 // function声明: 提升(含初始化)
定义 变量_parameter = 4 // 函数参数
定义 变量_class = 5 // class声明

// 变量位置
定义 位置_栈 = 0 // 在栈上(寄存器)
定义 位置_上下文 = 1 // 在堆上(Context slot), 被闭包引用时
定义 位置_全局 = 2 // 在全局对象上

// §2 ScopeInfo — 编译时作用域信息
// (对应 internal::ScopeInfo)

结构 ScopeVariable {
 名,    // u64 变量名字符串
 声明类型,    // u32 变量_var/let/const/...
 位置,    // u32 位置_栈/上下文/全局
 槽索引,    // u32 在栈(寄存器索引)或上下文(slot索引)中的位置
 是可变的,    // 布尔 let/var是可变, const不可变
 已初始化,    // 布尔 是否已过TDZ
 被内部函数引用,    // 布尔 被子函数引用(需要提升到Context)
}

结构 ScopeInfo {
 类型,    // u32 作用域_xxx
 是严格模式,
 外部作用域,    // u64 ScopeInfo* (词法父作用域)

 // 变量表
 变量列表,    // u64 ScopeVariable*数组
 变量数量,
 变量容量,
 // 函数作用域特有
 函数名,    // u64 函数名(匿名函数为null)
 参数数量,
 有arguments,    // 布尔 是否使用了arguments
 有rest参数,    // 布尔 function(...args)
 有new_target,    // 布尔 是否使用了new.target

 // Context信息
 上下文槽数,    // u32 需要的Context slot数量
 上下文变量起始,    // u32 变量列表中第一个上下文变量的索引
}

函数 ScopeInfo_创建(类型, 外部) {
 定义 scope = 堆_分配(ScopeInfo)
 scope.类型 = 类型
 scope.是严格模式 = 假
 scope.外部作用域 = 外部
 scope.变量容量 = 32
 scope.变量列表 = 堆_分配_数组(scope.变量容量 * 48)
 scope.变量数量 = 0
 scope.函数名 = 0
 scope.参数数量 = 0
 scope.有arguments = 假
 scope.有rest参数 = 假
 scope.有new_target = 假
 scope.上下文槽数 = 0
 scope.上下文变量起始 = 0
 返回 scope
}

函数 ScopeInfo_声明变量(scope, 名, 声明类型) {
 // 检查重复声明
 如果 (声明类型 == 变量_let || 声明类型 == 变量_const) {
 // let/const不允许同作用域重复声明
 定义 已有 = ScopeInfo_查找本地(scope, 名)
 如果 (已有 >= 0) {
 // Syntax错误: Identifier already declared
 返回 -1
 }
 }

 如果 (scope.变量数量 >= scope.变量容量) { 返回 -1 }

 定义 偏移 = scope.变量列表 + scope.变量数量 * 48
 内存_写64(偏移, 字符串_复制(名))
 内存_写32(偏移 + 8, 声明类型)
 内存_写32(偏移 + 12, 位置_栈) // 默认在栈上
 内存_写32(偏移 + 16, scope.变量数量)
 内存_写8(偏移 + 20, 声明类型 != 变量_const) // const不可变
 内存_写8(偏移 + 21, 声明类型 == 变量_var || 声明类型 == 变量_function || 声明类型 == 变量_parameter) // var/function/参数立即初始化
 内存_写8(偏移 + 22, 0) // 未被内部函数引用

 定义 索引 = scope.变量数量
 scope.变量数量 = scope.变量数量 + 1
 返回 索引
}

函数 ScopeInfo_查找本地(scope, 名) {
 定义 可变 i = 0
 当 (i < scope.变量数量) {
 定义 偏移 = scope.变量列表 + i * 48
 如果 (字符串_相等(内存_读64(偏移), 名)) { 返回 i }
 i = i + 1
 }
 返回 -1
}

函数 ScopeInfo_标记被引用(scope, 变量索引) {
 // 标记变量被内部函数引用 → 需要提升到Context(堆分配)
 定义 偏移 = scope.变量列表 + 变量索引 * 48
 内存_写8(偏移 + 22, 1) // 被内部函数引用
 内存_写32(偏移 + 12, 位置_上下文) // 提升到上下文
 // 分配Context slot
 定义 slot = scope.上下文槽数
 内存_写32(偏移 + 16, slot)
 scope.上下文槽数 = scope.上下文槽数 + 1
}

// §3 作用域链变量查找

函数 ScopeInfo_查找(scope, 名) {
    如果 (scope == 0 || 名 == 0) { 返回 空 }
    定义 本地 = ScopeInfo_查找本地(scope, 名)
    如果 (本地 >= 0) {
        返回 { 作用域: scope, 索引: 本地, 深度: 0 }
    }
    如果 (scope.外部作用域 != 0) {
        定义 结果 = ScopeInfo_查找(scope.外部作用域, 名)
        如果 (结果 != 空) {
            结果.深度 = 结果.深度 + 1
            返回 结果
        }
    }
    返回 空
}

函数 ScopeInfo_查找并标记(scope, 名) {
    定义 结果 = ScopeInfo_查找(scope, 名)
    如果 (结果 == 空) { 返回 空 }
    如果 (结果.深度 > 0) {
        ScopeInfo_标记被引用(结果.作用域, 结果.索引)
    }
    返回 结果
}

函数 ScopeInfo_作用域深度(scope) {
    定义 可变 深度 = 0
    定义 可变 当前 = scope
    当 (当前 != 0) {
        深度 = 深度 + 1
        当前 = 当前.外部作用域
    }
    返回 深度
}

// §4 运行时Context

结构 Context {
    外部上下文,
    作用域信息,
    槽,
    槽数,
}

函数 Context_创建(外部, 作用域信息) {
    定义 ctx = 堆_分配(Context)
    ctx.外部上下文 = 外部
    ctx.作用域信息 = 作用域信息
    ctx.槽数 = 作用域信息.上下文槽数
    如果 (ctx.槽数 > 0) {
        ctx.槽 = 堆_分配_数组(ctx.槽数 * 8)
        定义 可变 i = 0
        当 (i < ctx.槽数) {
            内存_写64(ctx.槽 + i * 8, 0)
            i = i + 1
        }
    } 否则 {
        ctx.槽 = 0
    }
    返回 ctx
}

函数 Context_获取(ctx, 槽索引) {
    如果 (ctx == 0 || 槽索引 >= ctx.槽数) { 返回 0 }
    返回 内存_读64(ctx.槽 + 槽索引 * 8)
}

函数 Context_设置(ctx, 槽索引, 值) {
    如果 (ctx == 0 || 槽索引 >= ctx.槽数) { 返回 }
    内存_写64(ctx.槽 + 槽索引 * 8, 值)
}

函数 Context_查找深度(ctx, 深度) {
    定义 可变 当前 = ctx
    定义 可变 i = 0
    当 (i < 深度 && 当前 != 0) {
        当前 = 当前.外部上下文
        i = i + 1
    }
    返回 当前
}

函数 Context_获取跨域(ctx, 深度, 槽索引) {
    定义 目标 = Context_查找深度(ctx, 深度)
    如果 (目标 == 0) { 返回 0 }
    返回 Context_获取(目标, 槽索引)
}

函数 Context_设置跨域(ctx, 深度, 槽索引, 值) {
    定义 目标 = Context_查找深度(ctx, 深度)
    如果 (目标 == 0) { 返回 }
    Context_设置(目标, 槽索引, 值)
}

// §5 暂时性死区(TDZ)检查

函数 ScopeInfo_检查TDZ(scope, 变量索引) {
    如果 (scope == 0 || 变量索引 < 0 || 变量索引 >= scope.变量数量) { 返回 假 }
    定义 偏移 = scope.变量列表 + 变量索引 * 48
    定义 声明类型 = 内存_读32(偏移 + 8)
    定义 已初始化 = 内存_读8(偏移 + 21)
    如果 ((声明类型 == 变量_let || 声明类型 == 变量_const) && !已初始化) {
        返回 真
    }
    返回 假
}

函数 ScopeInfo_标记已初始化(scope, 变量索引) {
    如果 (scope == 0 || 变量索引 < 0) { 返回 }
    定义 偏移 = scope.变量列表 + 变量索引 * 48
    内存_写8(偏移 + 21, 1)
}

函数 ScopeInfo_是常量(scope, 变量索引) {
    如果 (scope == 0 || 变量索引 < 0) { 返回 假 }
    定义 偏移 = scope.变量列表 + 变量索引 * 48
    返回 内存_读32(偏移 + 8) == 变量_const
}

函数 ScopeInfo_是可变(scope, 变量索引) {
    如果 (scope == 0 || 变量索引 < 0) { 返回 假 }
    定义 偏移 = scope.变量列表 + 变量索引 * 48
    返回 内存_读8(偏移 + 20) != 0
}

// §6 var提升(Hoisting)

函数 ScopeInfo_收集var声明(scope) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < scope.变量数量) {
        定义 偏移 = scope.变量列表 + i * 48
        定义 声明类型 = 内存_读32(偏移 + 8)
        如果 (声明类型 == 变量_var || 声明类型 == 变量_function) {
            追加(结果, { 名: 内存_读64(偏移), 索引: i, 类型: 声明类型 })
        }
        i = i + 1
    }
    返回 结果
}

函数 ScopeInfo_收集let_const声明(scope) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < scope.变量数量) {
        定义 偏移 = scope.变量列表 + i * 48
        定义 声明类型 = 内存_读32(偏移 + 8)
        如果 (声明类型 == 变量_let || 声明类型 == 变量_const) {
            追加(结果, { 名: 内存_读64(偏移), 索引: i, 类型: 声明类型 })
        }
        i = i + 1
    }
    返回 结果
}

// §7 arguments对象

函数 ScopeInfo_创建arguments(scope, 参数值, 参数数) {
    如果 (scope == 0 || !scope.有arguments) { 返回 0 }
    定义 args_obj = 堆_分配(32)
    内存_写32(args_obj, 参数数)
    定义 可变 i = 0
    当 (i < 参数数) {
        内存_写64(args_obj + 8 + i * 8, 参数值[i])
        i = i + 1
    }
    返回 args_obj
}

函数 Arguments_获取(args, 索引) {
    如果 (args == 0) { 返回 0 }
    定义 长度 = 内存_读32(args)
    如果 (索引 >= 长度) { 返回 0 }
    返回 内存_读64(args + 8 + 索引 * 8)
}

函数 Arguments_长度(args) {
    如果 (args == 0) { 返回 0 }
    返回 内存_读32(args)
}

// §8 辅助函数

函数 ScopeInfo_类型名(类型) {
    如果 (类型 == 作用域_全局) { 返回 "global" }
    如果 (类型 == 作用域_函数) { 返回 "function" }
    如果 (类型 == 作用域_块) { 返回 "block" }
    如果 (类型 == 作用域_模块) { 返回 "module" }
    如果 (类型 == 作用域_With) { 返回 "with" }
    如果 (类型 == 作用域_Catch) { 返回 "catch" }
    如果 (类型 == 作用域_Eval) { 返回 "eval" }
    返回 "unknown"
}

函数 ScopeInfo_变量声明类型名(类型) {
    如果 (类型 == 变量_var) { 返回 "var" }
    如果 (类型 == 变量_let) { 返回 "let" }
    如果 (类型 == 变量_const) { 返回 "const" }
    如果 (类型 == 变量_function) { 返回 "function" }
    如果 (类型 == 变量_parameter) { 返回 "parameter" }
    如果 (类型 == 变量_class) { 返回 "class" }
    返回 "unknown"
}

函数 ScopeInfo_获取变量名(scope, 索引) {
    如果 (scope == 0 || 索引 < 0 || 索引 >= scope.变量数量) { 返回 "" }
    返回 内存_读64(scope.变量列表 + 索引 * 48)
}

函数 ScopeInfo_获取变量声明类型(scope, 索引) {
    如果 (scope == 0 || 索引 < 0 || 索引 >= scope.变量数量) { 返回 -1 }
    返回 内存_读32(scope.变量列表 + 索引 * 48 + 8)
}

函数 ScopeInfo_是严格(scope) {
    如果 (scope == 0) { 返回 假 }
    返回 scope.是严格模式
}

函数 ScopeInfo_设置严格(scope) {
    如果 (scope == 0) { 返回 }
    scope.是严格模式 = 真
}

// §9 作用域统计与健康检查

定义 可变 作用域_创建总数 = 0
定义 可变 作用域_变量查找总数 = 0
定义 可变 作用域_TDZ违规数 = 0
定义 可变 Context_创建总数 = 0

函数 作用域_统计() {
    返回 {
        作用域创建: 作用域_创建总数,
        变量查找: 作用域_变量查找总数,
        TDZ违规: 作用域_TDZ违规数,
        Context创建: Context_创建总数,
    }
}

函数 作用域_健康检查() {
    定义 可变 问题 = []
    如果 (作用域_TDZ违规数 > 100) {
        追加(问题, "TDZ违规过多: " + 整数转字符串(作用域_TDZ违规数))
    }
    如果 (计数(问题) == 0) { 返回 "作用域链健康" }
    返回 问题
}

函数 作用域_重置统计() {
    作用域_创建总数 = 0
    作用域_变量查找总数 = 0
    作用域_TDZ违规数 = 0
    Context_创建总数 = 0
}

函数 ScopeInfo_诊断(scope) {
    如果 (scope == 0) { 返回 "作用域为空" }
    返回 {
        类型: ScopeInfo_类型名(scope.类型),
        严格模式: scope.是严格模式,
        变量数: scope.变量数量,
        上下文槽: scope.上下文槽数,
        深度: ScopeInfo_作用域深度(scope),
        有arguments: scope.有arguments,
        函数名: scope.函数名,
    }
}

函数 作用域_完整统计() {
    返回 [作用域_创建总数, 作用域_变量查找总数, 作用域_TDZ违规数, Context_创建总数]
}

定义 可变 AI_域信息创建_调用数 = 0
定义 可变 AI_域信息创建_异常数 = 0

函数 AI_域信息创建_监控() {
    AI_域信息创建_调用数 = AI_域信息创建_调用数 + 1
    返回 AI_域信息创建_异常数 == 0
}

函数 AI_域信息创建_健康检查() {
    如果 (AI_域信息创建_调用数 > 0 && AI_域信息创建_异常数 * 100 / AI_域信息创建_调用数 > 10) {
        返回 假
    }
    返回 真
}

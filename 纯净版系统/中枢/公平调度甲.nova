// NovaOS Nova公平调度带宽控制
// 职责: 限制进程组的CPU使用比例 (cgroup cpu.Nova公平调度_quota)

// Nova公平调度带宽控制参数

// 带宽组字段索引
定义 BW_配额 = 0        // quota: 每个周期允许的最大运行时间(us), -1=不限制
定义 BW_周期 = 1        // period: 带宽周期(us), 默认100ms
定义 BW_剩余运行时间 = 2 // runtime: 当前周期内剩余的允许运行时间
定义 BW_已用时间 = 3    // 当前周期已消耗的时间
定义 BW_节流次数 = 4    // 被节流的总次数
定义 BW_已节流 = 5      // 当前是否处于节流状态
定义 BW_周期开始 = 6    // 当前周期的开始时间

// 默认值
定义 BW_默认周期 = 100000    // 100ms
定义 BW_无限配额 = -1        // 不限制

// 带宽组管理

定义 可变 带宽组列表 = []

函数 带宽组_创建(配额, 周期) {
    如果 (周期 <= 0) { 周期 = BW_默认周期 }
    定义 组 = [配额, 周期, 配额, 0, 0, 假, 0]
    追加(带宽组列表, 组)
    返回 组
}

函数 带宽组_不限制() {
    返回 带宽组_创建(BW_无限配额, BW_默认周期)
}

// 是否启用了带宽限制
函数 带宽组_已启用(组) {
    返回 组[BW_配额] != BW_无限配额
}

// 带宽消耗与检查

// 消耗运行时间 (调度tick中调用)
函数 带宽_消耗时间(组, delta_us) {
    如果 (!带宽组_已启用(组)) { 返回 }
    设置(组, BW_剩余运行时间, 组[BW_剩余运行时间] - delta_us)
    设置(组, BW_已用时间, 组[BW_已用时间] + delta_us)
}

// 检查是否需要节流
函数 带宽_需要节流(组) {
    如果 (!带宽组_已启用(组)) { 返回 假 }
    返回 组[BW_剩余运行时间] <= 0
}

// 执行节流: 将组内所有进程从运行队列移除
函数 带宽_节流(组) {
    如果 (组[BW_已节流]) { 返回 }
    设置(组, BW_已节流, 真)
    设置(组, BW_节流次数, 组[BW_节流次数] + 1)
    // 实际应将该组的Nova公平调度运行队列中的进程全部出队
    // 设置节流标志: 调度器pick_next时检查此标志跳过被节流的进程
}

// 解除节流: 允许进程重新运行
函数 带宽_解除节流(组) {
    如果 (!组[BW_已节流]) { 返回 }
    设置(组, BW_已节流, 假)
    // 将之前节流的进程重新入队
}

// 周期定时器: 每个带宽周期重置剩余时间

函数 带宽_周期定时器(组) {
    如果 (!带宽组_已启用(组)) { 返回 }

    // 重置剩余运行时间
    设置(组, BW_剩余运行时间, 组[BW_配额])
    设置(组, BW_已用时间, 0)
    设置(组, BW_周期开始, 当前时间_us())

    // 如果之前被节流, 解除节流
    如果 (组[BW_已节流]) {
        带宽_解除节流(组)
    }
}

// 检查是否需要触发周期重置
函数 带宽_检查周期(组) {
    如果 (!带宽组_已启用(组)) { 返回 }
    定义 经过时间 = 当前时间_us() - 组[BW_周期开始]
    如果 (经过时间 >= 组[BW_周期]) {
        带宽_周期定时器(组)
    }
}

// 配额修改接口 

函数 带宽_设置配额(组, 新配额) {
    设置(组, BW_配额, 新配额)
    如果 (新配额 != BW_无限配额 && 新配额 < 组[BW_剩余运行时间]) {
        设置(组, BW_剩余运行时间, 新配额)
    }
}

函数 带宽_设置周期(组, 新周期) {
    如果 (新周期 < 1000) { 新周期 = 1000 }     // 最小1ms
    如果 (新周期 > 1000000) { 新周期 = 1000000 } // 最大1s
    设置(组, BW_周期, 新周期)
}

函数 带宽_获取配额(组) { 返回 组[BW_配额] }
函数 带宽_获取周期(组) { 返回 组[BW_周期] }
函数 带宽_获取使用率(组) {
    如果 (组[BW_配额] == BW_无限配额 || 组[BW_配额] == 0) { 返回 0 }
    返回 组[BW_已用时间] * 100 / 组[BW_配额]
}

// 统计

函数 带宽_统计(组) {
    返回 [组[BW_配额], 组[BW_周期], 组[BW_剩余运行时间],
           组[BW_已用时间], 组[BW_节流次数], 组[BW_已节流]]
}

// 突发模式 
// 允许在配额之外短时间突发运行

定义 BW_突发配额 = 7
定义 BW_累积余量 = 8

函数 带宽组_创建_含突发(配额, 周期, 突发) {
    如果 (周期 <= 0) { 周期 = BW_默认周期 }
    如果 (突发 < 0) { 突发 = 0 }
    定义 组 = [配额, 周期, 配额, 0, 0, 假, 0, 突发, 0]
    追加(带宽组列表, 组)
    返回 组
}

函数 带宽_消耗时间_含突发(组, delta_us) {
    如果 (!带宽组_已启用(组)) { 返回 }
    设置(组, BW_剩余运行时间, 组[BW_剩余运行时间] - delta_us)
    设置(组, BW_已用时间, 组[BW_已用时间] + delta_us)

    // 如果剩余为负但有累积余量, 从余量中借用
    如果 (组[BW_剩余运行时间] < 0 && 计数(组) > BW_累积余量) {
        定义 缺额 = 0 - 组[BW_剩余运行时间]
        如果 (组[BW_累积余量] >= 缺额) {
            设置(组, BW_累积余量, 组[BW_累积余量] - 缺额)
            设置(组, BW_剩余运行时间, 0)
        }
    }
}

函数 带宽_周期定时器_含突发(组) {
    如果 (!带宽组_已启用(组)) { 返回 }

    // 将未使用的配额累积到余量(不超过突发上限)
    如果 (组[BW_剩余运行时间] > 0 && 计数(组) > BW_突发配额) {
        定义 余量 = 组[BW_累积余量] + 组[BW_剩余运行时间]
        如果 (余量 > 组[BW_突发配额]) { 余量 = 组[BW_突发配额] }
        设置(组, BW_累积余量, 余量)
    }

    // 重置
    设置(组, BW_剩余运行时间, 组[BW_配额])
    设置(组, BW_已用时间, 0)
    设置(组, BW_周期开始, 当前时间_us())
    如果 (组[BW_已节流]) { 带宽_解除节流(组) }
}

// 全局查询

函数 带宽_全部组数() { 返回 计数(带宽组列表) }

函数 带宽_全部节流数() {
    定义 可变 总数 = 0
    定义 可变 i = 0
    当 (i < 计数(带宽组列表)) {
        总数 = 总数 + 带宽组列表[i][BW_节流次数]
        i = i + 1
    }
    返回 总数
}

// 当前被节流组数 + 完整统计

函数 带宽_当前节流组数() {
    定义 可变 计 = 0
    定义 可变 i = 0
    当 (i < 计数(带宽组列表)) {
        如果 (带宽组列表[i][BW_已节流]) { 计 = 计 + 1 }
        i = i + 1
    }
    返回 计
}

函数 带宽_完整统计() {
    返回 [带宽_全部组数(), 带宽_全部节流数(), 带宽_当前节流组数()]
}

定义 可变 AI_公平调度甲_负载窗口 = []

函数 AI_公平调度甲_负载预测(当前负载) {
    追加(AI_公平调度甲_负载窗口, 当前负载)
    如果 (计数(AI_公平调度甲_负载窗口) > 20) { 列表_移除(AI_公平调度甲_负载窗口, 0) }
    如果 (计数(AI_公平调度甲_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_公平调度甲_负载窗口)
    定义 趋势 = AI_公平调度甲_负载窗口[n-1] - AI_公平调度甲_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_公平调度甲_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

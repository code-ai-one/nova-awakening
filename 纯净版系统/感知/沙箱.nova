// §4 沙箱(Sandbox) — 渲染进程安全隔离
// 沙箱限制:
//   ① 文件系统: 不能读写任何文件
//   ② 网络: 不能直接创建套接字(必须通过Network进程)
//   ③ 进程: 不能创建子进程
//   ④ 内存: 限制最大内存使用(通常512MB)
//   ⑤ 系统调用: 只允许白名单系统调用
// NovaOS沙箱通过内核的能力(capability)系统实现:
//   进入沙箱后, 内核拒绝所有非白名单系统调用

结构 沙箱策略 {
    允许文件读,
    允许文件写,
    允许网络,
    允许进程创建,
    允许图处,    // 布尔 图处进程需要图处访问
    内存上限,    // u64 字节
    允许的系统调用,    // u64 位图指针
    系统调用数量,
}

函数 沙箱_渲染器策略() {
    定义 策略 = 堆_分配(沙箱策略)
    策略.允许文件读 = 假
    策略.允许文件写 = 假
    策略.允许网络 = 假
    策略.允许进程创建 = 假
    策略.允许图处 = 假
    策略.内存上限 = 512 * 1024 * 1024    // 512MB
    // 白名单: 内存分配/IPC管道读写/共享内存/时间
    返回 策略
}

函数 沙箱_图处策略() {
    定义 策略 = 堆_分配(沙箱策略)
    策略.允许文件读 = 假
    策略.允许文件写 = 假
    策略.允许网络 = 假
    策略.允许进程创建 = 假
    策略.允许图处 = 真        // 图处进程可以访问图处硬件
    策略.内存上限 = 1024 * 1024 * 1024    // 1GB(图处需要更多)
    返回 策略
}

函数 沙箱_网络策略() {
    定义 策略 = 堆_分配(沙箱策略)
    策略.允许文件读 = 真     // 读取证书/缓存
    策略.允许文件写 = 真     // 写入缓存
    策略.允许网络 = 真       // 核心功能
    策略.允许进程创建 = 假
    策略.允许图处 = 假
    策略.内存上限 = 256 * 1024 * 1024
    返回 策略
}

函数 沙箱_应用(PID, 策略) {
    如果 (策略 == 0) { 返回 }
    // 调用内核设置沙箱策略
    系统调用(系统调用_沙箱_策略, PID,
             策略.允许文件读 | (策略.允许文件写 << 1) | (策略.允许网络 << 2) |
             (策略.允许进程创建 << 3) | (策略.允许图处 << 4),
             策略.内存上限 >> 20,    // MB
             策略.允许的系统调用, 策略.系统调用数量)
    系统调用(系统调用_沙箱_进入, PID, 0, 0, 0, 0)
}

// §5 进程管理器 — Browser进程中管理所有子进程

结构 进程管理器 {
    进程表,    // [64]进程信息
    进程数,
    图处进程,    // u64 进程信息*(唯一)
    网络进程,    // u64 进程信息*(唯一)
    最大渲染器,    // u32 最多渲染器进程数(通常20)
}

函数 进程管理器_创建() {
    定义 pm = 堆_分配(进程管理器)
    pm.进程数 = 0
    pm.图处进程 = 0
    pm.网络进程 = 0
    pm.最大渲染器 = 20
    返回 pm
}

// 启动图处进程
函数 进程管理器_启动图处(pm) {
    如果 (pm == 0 || pm.图处进程 != 0) { 返回 }

    定义 info = 进程管理器_创建进程(pm, 进程类型_图处)
    如果 (info != 0) {
        沙箱_应用(info.PID, 沙箱_图处策略())
        pm.图处进程 = info
    }
}

// 启动网络进程
函数 进程管理器_启动网络(pm) {
    如果 (pm == 0 || pm.网络进程 != 0) { 返回 }

    定义 info = 进程管理器_创建进程(pm, 进程类型_网络)
    如果 (info != 0) {
        沙箱_应用(info.PID, 沙箱_网络策略())
        pm.网络进程 = info
    }
}

// 为站点获取或创建渲染器进程(站点隔离)
函数 进程管理器_获取渲染器(pm, 站点键) {
    如果 (pm == 0) { 返回 0 }

    // 查找已有的同站点渲染器
    定义 可变 i = 0
    当 (i < pm.进程数) {
        如果 (pm.进程表[i].类型 == 进程类型_渲染器 &&
            pm.进程表[i].站点键 == 站点键 &&
            pm.进程表[i].状态 == 0) {
            返回 pm.进程表[i]
        }
        i = i + 1
    }

    // 新站点 → 创建新渲染器
    定义 渲染器数 = 进程管理器_计数渲染器(pm)
    如果 (渲染器数 >= pm.最大渲染器) {
        // 超过限制, 复用最旧的渲染器(牺牲隔离)
        返回 进程管理器_复用渲染器(pm)
    }

    定义 info = 进程管理器_创建进程(pm, 进程类型_渲染器)
    如果 (info != 0) {
        info.站点键 = 站点键
        沙箱_应用(info.PID, 沙箱_渲染器策略())
    }
    返回 info
}

函数 进程管理器_创建进程(pm, 类型) {
    如果 (pm.进程数 >= 64) { 返回 0 }

    // 创建IPC通道
    定义 通道 = IPC通道_创建()

    // 创建子进程
    定义 PID = 系统调用(系统调用_进程_创建, 类型, 0, 0, 0, 0)
    如果 (PID <= 0) { 返回 0 }

    定义 idx = pm.进程数
    pm.进程表[idx].PID = PID
    pm.进程表[idx].类型 = 类型
    pm.进程表[idx].状态 = 0
    pm.进程表[idx].IPC通道 = 通道
    pm.进程表[idx].创建时间 = 平台_获取高精度时间()
    pm.进程表[idx].崩溃次数 = 0

    通道.对端PID = PID
    pm.进程数 = pm.进程数 + 1
    返回 pm.进程表[idx]
}

函数 进程管理器_计数渲染器(pm) {
    定义 可变 计数 = 0
    定义 可变 i = 0
    当 (i < pm.进程数) {
        如果 (pm.进程表[i].类型 == 进程类型_渲染器 && pm.进程表[i].状态 == 0) {
            计数 = 计数 + 1
        }
        i = i + 1
    }
    返回 计数
}

函数 进程管理器_复用渲染器(pm) {
    // 找最旧的渲染器
    定义 可变 最旧idx = -1
    定义 可变 最旧时间 = 0xFFFFFFFFFFFFFFFF
    定义 可变 i = 0
    当 (i < pm.进程数) {
        如果 (pm.进程表[i].类型 == 进程类型_渲染器 &&
            pm.进程表[i].状态 == 0 &&
            pm.进程表[i].创建时间 < 最旧时间) {
            最旧时间 = pm.进程表[i].创建时间
            最旧idx = i
        }
        i = i + 1
    }
    如果 (最旧idx >= 0) { 返回 pm.进程表[最旧idx] }
    返回 0
}

定义 可变 AI_沙箱_负载窗口 = []

函数 AI_沙箱_负载预测(当前负载) {
    追加(AI_沙箱_负载窗口, 当前负载)
    如果 (计数(AI_沙箱_负载窗口) > 20) { 列表_移除(AI_沙箱_负载窗口, 0) }
    如果 (计数(AI_沙箱_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_沙箱_负载窗口)
    定义 趋势 = AI_沙箱_负载窗口[n-1] - AI_沙箱_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_沙箱_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

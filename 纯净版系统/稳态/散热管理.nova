// §11 散热管理

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 ACPI_散热_初始化() {
    定义 zone = 散热区域 {}
    zone.名称 = "CPU"
    zone.临界温度 = 105000    // 105°C
    zone.被动温度 = 85000     // 85°C → 降频
    zone.当前温度 = 45000     // 45°C
    zone.风扇策略 = 0
    追加(ACPI_散热列表, zone)
}

函数 ACPI_散热_检查() {
    定义 可变 i = 0
    当 (i < 计数(ACPI_散热列表)) {
        定义 z = ACPI_散热列表[i]
        // 读取CPU温度(MSR 0x19C = IA32_THERM_STATUS)
        定义 therm = 读MSR(0x19C)
        定义 digital_readout = (therm >> 16) & 0x7F
        定义 tj_max = 100   // 假设Tj_max=100°C
        z.当前温度 = (tj_max - digital_readout) * 1000

        如果 (z.当前温度 >= z.临界温度) {
            内核警告("散热: 温度临界! " + 整数转字符串(z.当前温度 / 1000) + "°C 立即关机!")
            ACPI_关机()
        } 否则 如果 (z.当前温度 >= z.被动温度) {
            内核警告("散热: 温度过高 " + 整数转字符串(z.当前温度 / 1000) + "°C 降频")
            CPU_降频()
        } 否则 {
            如果 (z.当前温度 < z.被动温度 - 10000) {
                CPU_恢复频率()
            }
        }
        i = i + 1
    }
}

// IA32_PERF_CTL MSR = 0x199 (P-state控制)
// IA32_PERF_STATUS MSR = 0x198 (当前P-state)
// 值格式: bits[15:0] = 目标P-state值
//   高值 = 高频率(性能模式), 低值 = 低频率(省电)
定义 MSR_PERF_CTL    = 0x199
定义 MSR_PERF_STATUS = 0x198
定义 MSR_PLATFORM_INFO = 0xCE

定义 可变 ACPI_最大Pstate = 0
定义 可变 ACPI_最小Pstate = 0
定义 可变 ACPI_当前Pstate = 0

函数 ACPI_读取Pstate范围() {
    // 从MSR_PLATFORM_INFO读取最大/最小P-state
    定义 info = 读MSR(MSR_PLATFORM_INFO)
    ACPI_最大Pstate = (info >> 8) & 0xFF     // Maximum Non-Turbo Ratio
    ACPI_最小Pstate = (info >> 40) & 0xFF    // Maximum Efficiency Ratio
    如果 (ACPI_最大Pstate == 0) { ACPI_最大Pstate = 20 }  // 安全默认值
    如果 (ACPI_最小Pstate == 0) { ACPI_最小Pstate = 8 }
}

函数 CPU_降频() {
    如果 (ACPI_最大Pstate == 0) { ACPI_读取Pstate范围() }
    // 降到最小P-state(最低频率)
    ACPI_当前Pstate = ACPI_最小Pstate
    定义 perf_ctl_值 = (ACPI_当前Pstate & 0xFF) << 8
    写MSR(MSR_PERF_CTL, perf_ctl_值)
    内核信息("ACPI: CPU降频 P-state=" + 整数转字符串(ACPI_当前Pstate) +
             " (" + 整数转字符串(ACPI_当前Pstate * 100) + "MHz)")
}

函数 CPU_恢复频率() {
    如果 (ACPI_最大Pstate == 0) { ACPI_读取Pstate范围() }
    // 恢复到最大P-state(最高频率)
    ACPI_当前Pstate = ACPI_最大Pstate
    定义 perf_ctl_值 = (ACPI_当前Pstate & 0xFF) << 8
    写MSR(MSR_PERF_CTL, perf_ctl_值)
    内核信息("ACPI: CPU恢复频率 P-state=" + 整数转字符串(ACPI_当前Pstate) +
             " (" + 整数转字符串(ACPI_当前Pstate * 100) + "MHz)")
}

// §12 辅助

函数 读取固定字符串(地址, 长度) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 内存读8(地址 + i)
        如果 (c >= 0x20 && c <= 0x7E) { 结果 = 结果 + 字符(c) }
        i = i + 1
    }
    返回 结果
}

函数 端口写8(端口, 值) {
    // x86 OUT指令: 写一个字节到I/O端口
    // AT&T语法: outb %al, %dx (值在AL, 端口在DX)
    内联汇编("outb %b0, %w1", 值, 端口)
}

函数 端口写16(端口, 值) {
    // x86 OUT指令: 写一个字(16位)到I/O端口
    内联汇编("outw %w0, %w1", 值, 端口)
}

函数 端口读8(端口) {
    // x86 IN指令: 从I/O端口读一个字节
    返回 内联汇编_返回值("inb %w1, %b0", 端口)
}

函数 端口读16(端口) {
    返回 内联汇编_返回值("inw %w1, %w0", 端口)
}

函数 端口读32(端口) {
    返回 内联汇编_返回值("inl %w1, %0", 端口)
}

函数 延迟_ms(ms) {
    定义 可变 i = 0
    当 (i < ms) {
        延迟_us(1000)
        i = i + 1
    }
}

函数 延迟_us(us) {
    定义 目标 = us * 2000
    定义 开始 = ACPI_读取TSC()
    当 (ACPI_读取TSC() - 开始 < 目标) { 内联汇编("pause") }
}

函数 ACPI_读取TSC() { 返回 内联汇编_返回值("rdtsc") }

函数 ACPI_统计() {
    返回 [计数(ACPI_CPU列表), 计数(ACPI_IO接口C列表), 计数(ACPI_表列表)]
}

// §13 散热区域结构与全局

结构 散热区域 {
    名称,
    临界温度,
    被动温度,
    当前温度,
    风扇策略,
}

定义 可变 ACPI_散热列表 = []
定义 可变 ACPI_CPU列表 = []
定义 可变 ACPI_IO接口C列表 = []
定义 可变 ACPI_表列表 = []
定义 可变 散热_降频次数 = 0
定义 可变 散热_恢复次数 = 0
定义 可变 散热_临界次数 = 0

函数 读MSR(地址) {
    // 读取x86 MSR(Model Specific Register)
    定义 可变 低32 = 0
    定义 可变 高32 = 0
    汇编 {
        "mov ecx, [rbp+地址]"
        "rdmsr"
        "mov [rbp-8], eax"
        "mov [rbp-16], edx"
    }
    返回 低32 | (高32 << 32)
}
函数 写MSR(地址, 值) {
    // 写入x86 MSR
    汇编 {
        "mov ecx, [rbp+地址]"
        "mov eax, [rbp+值]"
        "mov edx, [rbp+值+4]"
        "wrmsr"
    }
}
函数 ACPI_关机() {
    // ACPI S5关机: 写PM1a控制寄存器
    内核信息("ACPI: 执行关机...")
    // 刷新所有磁盘缓存
    刷新所有缓存()
    // 写PM1a_CNT: SLP_TYP=S5 | SLP_EN
    如果 (ACPI_PM1a_CNT地址 > 0) {
        端口输出_16(ACPI_PM1a_CNT地址, ACPI_S5值 | 0x2000)
    }
}
函数 内存读8(地址) { 返回 内存_读8(地址) }

// §14 散热健康检查与诊断

函数 散热_健康检查() {
    定义 可变 问题 = []
    定义 可变 i = 0
    当 (i < 计数(ACPI_散热列表)) {
        定义 z = ACPI_散热列表[i]
        如果 (z.当前温度 >= z.被动温度) {
            追加(问题, z.名称 + "温度过高: " + 整数转字符串(z.当前温度 / 1000) + "°C")
        }
        i = i + 1
    }
    如果 (散热_临界次数 > 0) { 追加(问题, "发生过临界温度事件") }
    如果 (计数(问题) == 0) { 返回 "散热管理健康" }
    返回 问题
}

函数 散热_详细统计() {
    返回 {
        区域数: 计数(ACPI_散热列表),
        降频次数: 散热_降频次数,
        恢复次数: 散热_恢复次数,
        临界次数: 散热_临界次数,
        当前Pstate: ACPI_当前Pstate,
        最大Pstate: ACPI_最大Pstate,
        最小Pstate: ACPI_最小Pstate,
    }
}

函数 散热_重置统计() {
    散热_降频次数 = 0
    散热_恢复次数 = 0
    散热_临界次数 = 0
}

函数 散热_完整统计() {
    返回 [计数(ACPI_散热列表), 散热_降频次数, 散热_恢复次数, 散热_临界次数]
}

函数 散热_获取温度(区域名) {
    定义 可变 i = 0
    当 (i < 计数(ACPI_散热列表)) {
        如果 (ACPI_散热列表[i].名称 == 区域名) {
            返回 ACPI_散热列表[i].当前温度
        }
        i = i + 1
    }
    返回 0
}

函数 散热_获取CPU温度() {
    返回 散热_获取温度("CPU")
}

定义 可变 AI_散热管理_运行指标 = 0
定义 可变 AI_散热管理_异常指标 = 0

函数 AI_散热管理_自诊断() {
    AI_散热管理_运行指标 = 散热_降频次数
    返回 AI_散热管理_运行指标
}

函数 AI_散热管理_优化建议() {
    定义 指标 = AI_散热管理_自诊断()
    如果 (AI_散热管理_运行指标 > 10000) { 返回 "散热管理负载较高" }
    返回 "散热管理状态正常"
}

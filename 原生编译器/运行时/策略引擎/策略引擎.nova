// Nova · 运行时层 · 动态策略引擎
// 实时检测热点、自动切换执行模式、回收无用机器码
// 核心: 开发者无感知 — 自动在解释/JIT之间切换

// 执行模式

导入("../../标准库/基础.nova")
导入("../JIT/热点检测.nova")
导入("../JIT/编译引擎.nova")
导入("../解释器/栈式VM.nova")

定义 模式_解释   = 0    // 解释执行Nova-Bytecode (冷启动/调试/低频)
定义 模式_JIT    = 1    // JIT机器码执行 (热点代码)
定义 模式_AOT    = 2    // 预编译执行 (生产模式)
定义 模式_调试   = 3    // 纯解释+调试信息 (开发模式)

// M10: JIT Profile门控
// 不同profile对JIT的策略不同
定义 JIT门控_禁用 = 0       // 完全禁止JIT
定义 JIT门控_白名单 = 1   // 仅允许白名单块的JIT
定义 JIT门控_标准 = 2     // 标准JIT(热点触发)
定义 JIT门控_最大化 = 3  // 最大化JIT(分析模式)

定义 可变 _JIT门控等级 = JIT门控_标准
定义 可变 _JIT白名单 = []  // 白名单块ID列表
定义 可变 _JIT最大编译单元 = 4096

函数 JIT门控_设置profile(profile名) {
    如果 (profile名 == "analysis-host") {
        _JIT门控等级 = JIT门控_最大化
        _JIT最大编译单元 = 16384
    }
    如果 (profile名 == "linux-user") {
        _JIT门控等级 = JIT门控_标准
        _JIT最大编译单元 = 4096
    }
    如果 (profile名 == "kernel-qemu") {
        _JIT门控等级 = JIT门控_白名单
        _JIT最大编译单元 = 1024
    }
    如果 (profile名 == "kernel-physical") {
        _JIT门控等级 = JIT门控_禁用
        _JIT最大编译单元 = 0
    }
}

函数 JIT门控_添加白名单(块ID) { 追加(_JIT白名单, 块ID) }

函数 JIT门控_允许(块ID) {
    如果 (_JIT门控等级 == JIT门控_禁用) { 返回 假 }
    如果 (_JIT门控等级 == JIT门控_最大化) { 返回 真 }
    如果 (_JIT门控等级 == JIT门控_标准) { 返回 真 }
    // 白名单模式: 只允许列表中的块
    定义 可变 i = 0
    当 (i < 计数(_JIT白名单)) {
        如果 (_JIT白名单[i] == 块ID) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 JIT门控_报告() {
    定义 可变 r = 字典()
    定义 可变 等级名 = "标准"
    如果 (_JIT门控等级 == JIT门控_禁用) { 等级名 = "禁用" }
    如果 (_JIT门控等级 == JIT门控_白名单) { 等级名 = "白名单" }
    如果 (_JIT门控等级 == JIT门控_最大化) { 等级名 = "最大化" }
    字典设(r, "JIT门控等级", 等级名)
    字典设(r, "白名单数", 转字符串(计数(_JIT白名单)))
    字典设(r, "最大编译单元", 转字符串(_JIT最大编译单元))
    返回 r
}

// 策略配置
定义 策略_自动     = 0    // 自动切换 (默认)
定义 策略_纯解释   = 1    // 强制解释 (调试用)
定义 策略_纯编译   = 2    // 强制全量编译 (生产用)
定义 策略_混合     = 3    // 手动指定热点

// 策略引擎实例
// [当前策略, 热点检测器, JIT编译器, 代码块模式表, 运行统计, 调试开关, vm引用]
// 统计状态收进容器, 避免函数体内累加时被判成未定义变量
定义 可变 _策略_统计 = [0, 0]

函数 策略引擎_创建(热点检测器, JIT编译器) {
    返回 [策略_自动, 热点检测器, JIT编译器, 字典(), [0,0,0,0,0], 假, 空]
}

函数 策略引擎_绑定VM(引擎, vm) { 引擎[6] = vm }

函数 策略引擎_设置策略(引擎, 策略) { 引擎[0] = 策略 }
函数 策略引擎_当前策略(引擎) { 返回 引擎[0] }

// 核心决策: 代码块该用哪种模式执行?
函数 策略引擎_决策(引擎, 块ID) {
    // 调试模式: 强制解释
    如果 (引擎[5]) { 返回 模式_调试 }

    // 纯解释策略
    如果 (引擎[0] == 策略_纯解释) { 返回 模式_解释 }

    // 纯编译策略
    如果 (引擎[0] == 策略_纯编译) { 返回 模式_AOT }

    // 自动策略: 查热点检测器 (受JIT门控约束)
    如果 (JIT门控_允许(块ID) 且 热点检测器_应JIT执行(引擎[1], 块ID)) {
        引擎[4][1] = 引擎[4][1] + 1    // JIT执行次数
        返回 模式_JIT
    }

    引擎[4][0] = 引擎[4][0] + 1    // 解释执行次数
    返回 模式_解释
}

// 执行入口: 统一调度
函数 策略引擎_执行块(引擎, vm, 块ID) {
    定义 模式 = 策略引擎_决策(引擎, 块ID)
    引擎[4][4] = 引擎[4][4] + 1    // 总调度次数

    如果 (模式 == 模式_解释 或 模式 == 模式_调试) {
        // 解释执行
        返回 VM_执行(vm)
    }

    如果 (模式 == 模式_JIT) {
        // JIT机器码执行: 直接调用JIT缓冲区中的本机码
        定义 记录 = 热点检测器_查询(引擎[1], 块ID)
        如果 (记录 != 空 且 热点_已编译(记录)) {
            引擎[4][2] = 引擎[4][2] + 1    // 机器码命中
            // 通过执行缓冲码内建函数真正跳入JIT机器码
            定义 jit = 引擎[2]
            定义 入口 = 记录[4]
            定义 结果 = 执行缓冲码(jit[0], 入口)
            返回 结果
        }
        // 未编译完成: 回退解释
        返回 VM_执行(vm)
    }

    // AOT模式: 预编译的机器码直接执行
    // 若尚未AOT编译, 先触发全量编译(仅一次)
    如果 (AOT_已编译() == 假) {
        定义 aot_jit = 引擎[2]
        定义 aot_vm = 引擎[6]
        如果 (aot_jit != 空 且 aot_vm != 空) {
            定义 函数表 = VM_函数表(aot_vm)
            定义 字节码表 = VM_字节码(aot_vm)
            如果 (函数表 != 空 且 字节码表 != 空) {
                AOT_编译全部(aot_jit, 函数表, 字节码表)
                执行路径_设置(执行路径_AOT)
            }
        }
    }
    如果 (AOT_已编译()) {
        定义 aot_jit = 引擎[2]
        定义 aot_结果 = AOT_查找并执行(aot_jit, 转字符串(块ID))
        如果 (aot_结果 != 空) {
            执行路径_记录调用(执行路径_AOT)
            返回 aot_结果
        }
        // AOT编译成功但该函数未命中(含不安全opcode): 回退JIT热路径
        定义 记录 = 热点检测器_查询(引擎[1], 块ID)
        如果 (记录 != 空 且 热点_已编译(记录)) {
            定义 jit = 引擎[2]
            定义 入口 = 记录[4]
            执行路径_记录调用(执行路径_JIT)
            返回 执行缓冲码(jit[0], 入口)
        }
    }
    // AOT+JIT均未命中: 最终回退解释(记录原因供报告追溯)
    执行路径_记录调用(执行路径_解释)
    返回 VM_执行(vm)
}

// 热点回调: 自动触发JIT编译
函数 策略引擎_热点回调(引擎) {
    // 返回一个回调函数，热点检测器达到阈值时调用
    返回 法(参数) {
        定义 块ID = 参数[0]
        定义 jit = 引擎[2]
        定义 vm = 引擎[6]
        引擎[4][3] = 引擎[4][3] + 1    // JIT触发次数
        // 从VM获取该块的字节码段
        定义 块信息 = VM_获取块(vm, 块ID)
        如果 (块信息 != 空) {
            定义 字节码 = 块信息[0]
            定义 起始 = 块信息[1]
            定义 长度 = 块信息[2]
            // 检查是否已编译
            定义 已有 = 字典取(jit[2], 转字符串(块ID))
            如果 (已有 == 空) {
                定义 结果 = JIT编译器_编译块(jit, 字节码, 起始, 长度)
                如果 (结果 != 空) {
                    字典设(jit[2], 转字符串(块ID), 结果)
                    // 安全守卫: 只有全部操作码都被JIT覆盖时才标记为可执行
                    // 结果[2] = 不安全操作码数, 0=纯净
                    如果 (计数(结果) >= 3 且 结果[2] == 0) {
                        热点检测器_标记编译完成(引擎[1], 块ID, 结果[0])
                    } 否则 {
                        // 含不安全操作码(CALL/全局/字段等), 保持解释执行
                        // 不标记已编译, 避免块级切换到不完整的机器码
                    }
                }
            }
        }
    }
}

// 调试模式切换
函数 策略引擎_进入调试(引擎) {
    引擎[5] = 真
    打印("策略引擎: 切换为调试模式 (纯解释)")
}

函数 策略引擎_退出调试(引擎) {
    引擎[5] = 假
    打印("策略引擎: 恢复自动模式 (解释+JIT)")
}

// 生产模式
函数 策略引擎_生产模式(引擎) {
    引擎[0] = 策略_纯编译
    打印("策略引擎: 生产模式 (预编译所有代码)")
}

// 统计报告
// 机器码回收
函数 策略引擎_GC机器码(引擎) {
    定义 回收数 = 热点检测器_冷却扫描(引擎[1], 0)
    如果 (回收数 > 0) {
        打印(字符串拼接("策略引擎: 回收", 字符串拼接(转字符串(回收数), "个冷代码块的机器码")))
    }
    返回 回收数
}

// 自适应策略

定义 可变 _采样_块ID = []
定义 可变 _采样_解释耗时 = []
定义 可变 _采样_JIT耗时 = []

函数 策略_记录解释耗时(块ID, 耗时) {
    定义 可变 i = 0
    当 (i < 计数(_采样_块ID)) {
        如果 (_采样_块ID[i] == 块ID) {
            _采样_解释耗时[i] = _采样_解释耗时[i] + 耗时
            返回 空
        }
        i = i + 1
    }
    追加(_采样_块ID, 块ID)
    追加(_采样_解释耗时, 耗时)
    追加(_采样_JIT耗时, 0)
}

函数 策略_记录JIT耗时(块ID, 耗时) {
    定义 可变 i = 0
    当 (i < 计数(_采样_块ID)) {
        如果 (_采样_块ID[i] == 块ID) {
            _采样_JIT耗时[i] = _采样_JIT耗时[i] + 耗时
            返回 空
        }
        i = i + 1
    }
    追加(_采样_块ID, 块ID)
    追加(_采样_解释耗时, 0)
    追加(_采样_JIT耗时, 耗时)
}

函数 策略_应编译(块ID, 编译开销) {
    定义 可变 i = 0
    当 (i < 计数(_采样_块ID)) {
        如果 (_采样_块ID[i] == 块ID) {
            // 如果解释累计耗时 > 编译开销 + 预估JIT执行时间，则编译
            定义 解释总 = _采样_解释耗时[i]
            定义 JIT总 = _采样_JIT耗时[i]
            如果 (JIT总 > 0) { 返回 假 }  // 已编译
            返回 解释总 > 编译开销
        }
        i = i + 1
    }
    返回 假
}

// 编译优先队列

定义 可变 _编译队列_块ID = []
定义 可变 _编译队列_优先级 = []

函数 编译队列_入队(块ID, 优先级) {
    定义 可变 i = 0
    当 (i < 计数(_编译队列_块ID)) {
        如果 (_编译队列_块ID[i] == 块ID) {
            如果 (优先级 > _编译队列_优先级[i]) { _编译队列_优先级[i] = 优先级 }
            返回 空
        }
        i = i + 1
    }
    追加(_编译队列_块ID, 块ID)
    追加(_编译队列_优先级, 优先级)
}

函数 编译队列_出队() {
    如果 (计数(_编译队列_块ID) == 0) { 返回 -1 }
    定义 可变 最高idx = 0
    定义 可变 i = 1
    当 (i < 计数(_编译队列_优先级)) {
        如果 (_编译队列_优先级[i] > _编译队列_优先级[最高idx]) { 最高idx = i }
        i = i + 1
    }
    定义 块ID = _编译队列_块ID[最高idx]
    删除(_编译队列_块ID, 最高idx)
    删除(_编译队列_优先级, 最高idx)
    返回 块ID
}

函数 编译队列_大小() { 返回 计数(_编译队列_块ID) }

// 策略历史

定义 可变 _策略历史_时间 = []
定义 可变 _策略历史_决策 = []  // "解释"/"JIT"/"AOT"

函数 策略_记录决策(时间, 决策) {
    追加(_策略历史_时间, 时间)
    追加(_策略历史_决策, 决策)
}

函数 策略_最近决策(数量) {
    定义 可变 结果 = []
    定义 总 = 计数(_策略历史_决策)
    定义 可变 起始 = 总 - 数量
    如果 (起始 < 0) { 起始 = 0 }
    定义 可变 i = 起始
    当 (i < 总) {
        追加(结果, [_策略历史_时间[i], _策略历史_决策[i]])
        i = i + 1
    }
    返回 结果
}

函数 策略_JIT比率() {
    定义 可变 JIT数 = 0
    定义 可变 i = 0
    当 (i < 计数(_策略历史_决策)) {
        如果 (_策略历史_决策[i] == "JIT") { JIT数 = JIT数 + 1 }
        i = i + 1
    }
    定义 总 = 计数(_策略历史_决策)
    如果 (总 == 0) { 返回 0 }
    返回 JIT数 * 100 / 总
}

函数 策略_记录调度() { _策略_统计[0] = _策略_统计[0] + 1 }
函数 策略_记录切换() { _策略_统计[1] = _策略_统计[1] + 1 }

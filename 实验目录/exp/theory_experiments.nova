导入("../core/theory_core.nova")

函数 实验_汇总记录(名称, 旧总分, 新总分, 通过数, 总数) {
    返回 [名称, 旧总分, 新总分, 通过数, 总数, 新总分 - 旧总分]
}

函数 实验_运行记忆晶化组() {
    定义 用例 = [
        [900, 120, 400, 820, 760, 600, 200],
        [780, 300, 500, 650, 620, 500, 300],
        [650, 480, 450, 900, 850, 700, 250],
        [880, 180, 460, 840, 780, 660, 180],
        [720, 360, 520, 780, 720, 640, 220]
    ]
    定义 可变 旧总分 = 0
    定义 可变 新总分 = 0
    定义 可变 通过数 = 0
    定义 可变 总数 = 0
    定义 可变 i = 0
    当 (i < 计数(用例)) {
        定义 c = 用例[i]
        定义 旧分 = 基线_记忆保持率(c[0], c[1], c[2])
        定义 新分 = 原创_记忆晶化保持率(c[0], c[1], c[2], c[3], c[4], c[5], c[6])
        旧总分 = 旧总分 + 旧分
        新总分 = 新总分 + 新分
        如果 (新分 > 旧分) { 通过数 = 通过数 + 1 }
        总数 = 总数 + 1
        i = i + 1
    }
    定义 共振网格 = [180, 260, 420, 640, 760, 860]
    定义 可变 j = 0
    当 (j < 计数(共振网格)) {
        定义 强度 = 800
        定义 时间 = 200
        定义 稳定性 = 400
        定义 旧分 = 基线_记忆保持率(强度, 时间, 稳定性)
        定义 新分 = 原创_记忆晶化保持率(强度, 时间, 稳定性, 共振网格[j], 620, 560 + j * 20, 200)
        旧总分 = 旧总分 + 旧分
        新总分 = 新总分 + 新分
        如果 (新分 > 旧分) { 通过数 = 通过数 + 1 }
        总数 = 总数 + 1
        j = j + 1
    }
    返回 实验_汇总记录("记忆晶化", 旧总分, 新总分, 通过数, 总数)
}

函数 实验_运行意图势场组() {
    定义 用例 = [
        [920, 820, 760, 160, 150, 120],

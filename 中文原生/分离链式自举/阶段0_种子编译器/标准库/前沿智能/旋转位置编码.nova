导入("../基础.nova")
导入("../数学/工具.nova")

// RoPE — 旋转位置编码 (v2: 2024 前沿迭代)
// ref: Su et al. 2022 "RoFormer: Enhanced Transformer with RoPE"
// ref: Peng et al. 2023 "YaRN: Efficient Context Window Extension"
// ref: Ding et al. 2024 "LongRoPE: Extending LLM Context Window
//   Beyond 2M Tokens" (渐进式扩展 + 搜索最优缩放因子)
// ref: bloc97 2023 "NTK-by-parts: 分段NTK插值" (低频外推+高频内插
//   的最优分段策略, 比纯NTK-aware更好保留局部位置)
// ref: DeepSeek-V2 2024 "Decoupled RoPE" (解耦Q的RoPE部分,
//   使MLA的KV压缩与位置编码兼容)
// 核心: 用旋转矩阵编码位置, q·k = f(q,k,m-n) 只依赖相对距离
// 公式: f(x,m) = R(mθ)·x, R是2D旋转矩阵
//   R(θ) = [[cos θ, -sin θ], [sin θ, cos θ]]

定义 ROPE精度 = 10000
定义 ROPE_基频 = 100000  // θ_base = 10000 → 100000(×10)

// 定点三角函数
// cos/sin via Taylor: cos(x) ≈ 1 - x²/2 + x⁴/24
//                     sin(x) ≈ x - x³/6 + x⁵/120
// 输入x为弧度×10000

函数 定点cos(x) {
    // 归一化到 [-π, π]
    定义 PI = 31416  // π × 10000
    定义 可变 a = x % (2 * PI)
    如果 (a > PI) { a = a - 2 * PI }
    如果 (a < 0 - PI) { a = a + 2 * PI }
    定义 a2 = a * a / ROPE精度
    定义 a4 = a2 * a2 / ROPE精度
    返回 ROPE精度 - a2 / 2 + a4 / 24
}

函数 定点sin(x) {
    定义 PI = 31416
    定义 可变 a = x % (2 * PI)
    如果 (a > PI) { a = a - 2 * PI }
    如果 (a < 0 - PI) { a = a + 2 * PI }
    定义 a2 = a * a / ROPE精度
    定义 a3 = a2 * a / ROPE精度
    定义 a5 = a3 * a2 / ROPE精度
    返回 a - a3 / 6 + a5 / 120
}

// RoPE 频率计算
// θ_i = base^(-2i/d) for i in [0, d/2)
函数 RoPE_频率(头维度, 基频) {
    定义 半维度 = 头维度 / 2
    定义 可变 频率 = []
    定义 可变 i = 0
    当 (i < 半维度) {
        // base^(-2i/d) = exp(-2i/d × log(base))
        // 简化: 用指数衰减近似
        定义 指数 = 0 - 2 * i * ROPE精度 / 头维度
        定义 可变 衰减 = ROPE精度
        // 近似 base^指数: 逐步除以base
        定义 可变 j = 0
        当 (j < i * 2) {
            衰减 = 衰减 * ROPE精度 / 基频
            如果 (衰减 < 1) { 衰减 = 1 }
            j = j + 1
        }
        追加(频率, 衰减)
        i = i + 1
    }
    返回 频率
}

// RoPE 应用
// 对q/k向量的每对维度 (2i, 2i+1) 应用旋转
函数 RoPE_应用(向量, 位置, 频率) {
    定义 d = 计数(向量)
    定义 半维度 = d / 2
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < d) { 追加(结果, 向量[i]); i = i + 1 }
    i = 0
    当 (i < 半维度) {
        定义 角度 = 位置 * 频率[i] / ROPE精度
        定义 cos_θ = 定点cos(角度)
        定义 sin_θ = 定点sin(角度)
        定义 x0 = 向量[2 * i]
        定义 x1 = 向量[2 * i + 1]
        // [x0', x1'] = R(θ) · [x0, x1]
        结果[2 * i] = (x0 * cos_θ - x1 * sin_θ) / ROPE精度
        结果[2 * i + 1] = (x0 * sin_θ + x1 * cos_θ) / ROPE精度
        i = i + 1
    }
    返回 结果
}

// RoPE 旋转（频率+向量+位置+维度 参数序）
函数 RoPE_旋转(频率, 向量, 位置, 维度) {
    定义 半维度 = 维度 / 2
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 维度) { 追加(结果, 向量[i]); i = i + 1 }
    i = 0
    当 (i < 半维度) {
        定义 角度 = 位置 * 频率[i] / ROPE精度
        定义 cos_θ = 定点cos(角度)
        定义 sin_θ = 定点sin(角度)
        定义 x0 = 向量[2 * i]
        定义 x1 = 向量[2 * i + 1]
        结果[2 * i] = (x0 * cos_θ - x1 * sin_θ) / ROPE精度
        结果[2 * i + 1] = (x0 * sin_θ + x1 * cos_θ) / ROPE精度
        i = i + 1
    }
    返回 结果
}

// GQA: 分组查询注意力 (Ainslie et al. 2023, 0 , 0 , 0, 0)
// ref: "GQA: Training Generalized Multi-Query Attention Models"
// Q有n_heads个头, K/V只有n_kv个头(共享)
// n_heads / n_kv = 每组Q头数 (通常4或8)

函数 GQA_注意力(Q头列表, K头列表, V头列表, Q头数, KV头数, 头维度, 序列长) {
    定义 可变 dot = 0
    定义 每组Q数 = Q头数 / KV头数
    定义 可变 所有输出 = []
    定义 可变 qi = 0
    当 (qi < Q头数) {
        // 这个Q头对应的KV组
        定义 kv组 = qi / 每组Q数
        // 标准attention: softmax(Q·K^T/√d)·V
        定义 可变 O = []
        定义 可变 si = 0
        当 (si < 序列长) {
            // Q[si] · K[:]^T
            定义 可变 权重 = []
            定义 可变 max_s = 0 - ROPE精度 * 100
            定义 可变 sj = 0
            当 (sj < 序列长) {
                定义 可变 d = 0
                当 (d < 头维度) {
                    dot = dot + Q头列表[qi][si * 头维度 + d] * K头列表[kv组][sj * 头维度 + d] / ROPE精度
                    d = d + 1
                }
                dot = dot * ROPE精度 / (头维度 * 100 + 1)  // /√d
                追加(权重, dot)
                如果 (dot > max_s) { max_s = dot }
                sj = sj + 1
            }
            // softmax
            定义 可变 sum_exp = 0
            sj = 0
            当 (sj < 序列长) {
                定义 差 = 权重[sj] - max_s
                如果 (差 < 0 - 50000) { 差 = 0 - 50000 }
                定义 e = ROPE精度 + 差 + 差 * 差 / (2 * ROPE精度)
                如果 (e < 0) { e = 0 }
                权重[sj] = e
                sum_exp = sum_exp + e
                sj = sj + 1
            }
            // 加权V
            定义 可变 d = 0
            当 (d < 头维度) {
                定义 可变 val = 0
                sj = 0
                当 (sj < 序列长) {
                    val = val + 权重[sj] * V头列表[kv组][sj * 头维度 + d] / (sum_exp + 1)
                    sj = sj + 1
                }
                追加(O, val)
                d = d + 1
            }
            si = si + 1
        }
        追加(所有输出, O)
        qi = qi + 1
    }
    返回 所有输出
}

// YaRN上下文窗口扩展 (Peng et al. 2023)
// 通过插值+温度缩放扩展RoPE到更长上下文
// NTK-aware插值: 不均匀缩放不同频率维度

函数 YaRN_频率(头维度, 基频, 原始长度, 目标长度) {
    定义 半维度 = 头维度 / 2
    定义 比例 = 目标长度 * ROPE精度 / 原始长度
    // NTK-aware: 低频维度插值更多, 高频维度保持
    定义 可变 频率 = RoPE_频率(头维度, 基频)
    定义 可变 i = 0
    当 (i < 半维度) {
        // 维度i的"波长" λ_i = 2π/θ_i
        // 如果 λ_i > 原始长度: 这个维度需要插值
        // 插值因子 = lerp(1, 比例, ramp(λ_i))
        定义 ramp = i * ROPE精度 / 半维度  // 0→1
        定义 插值因子 = ROPE精度 + (比例 - ROPE精度) * ramp / ROPE精度
        如果 (插值因子 < ROPE精度) { 插值因子 = ROPE精度 }
        频率[i] = 频率[i] * ROPE精度 / 插值因子
        i = i + 1
    }
    返回 频率
}

// NTK-by-parts 插值 (bloc97, 2023)
// 分段策略: 将维度分为三区
// 高频区(λ < 原始长度): 不插值, 保留精确局部位置
// 中频区(原始 ≤ λ ≤ β·原始): 线性插值, 渐进过渡
// 低频区(λ > β·原始): 完全NTK外推
// 优于纯NTK-aware: 局部位置精度保留更好

函数 NTK_by_parts_频率(维度, 原始长度, 目标长度, β因子) {
    定义 半维度 = 维度 / 2
    定义 比例 = 目标长度 * ROPE精度 / 原始长度
    定义 β阈值 = β因子 * 原始长度 / ROPE精度
    定义 可变 频率 = []
    定义 可变 i = 0
    当 (i < 半维度) {
        // 基础频率: θ_i = base^(-2i/d)
        定义 可变 基 = ROPE精度
        定义 可变 p = 0
        当 (p < 2 * i) {
            基 = 基 * ROPE精度 / ROPE_基频
            p = p + 1
        }
        // 计算波长 λ_i = 2π / θ_i (近似: λ ∝ 1/θ)
        定义 波长 = ROPE精度 * ROPE精度 / (基 + 1)
        如果 (波长 < 原始长度) {
            // 高频区: 不缩放, 保持原始精度
            追加(频率, 基)
        } 否则 如果 (波长 > β阈值) {
            // 低频区: 完全NTK外推 (频率 / 比例)
            追加(频率, 基 * ROPE精度 / 比例)
        } 否则 {
            // 中频区: 线性插值
            定义 混合比 = (波长 - 原始长度) * ROPE精度 / (β阈值 - 原始长度 + 1)
            定义 缩放频率 = 基 * ROPE精度 / 比例
            定义 插值 = 基 * (ROPE精度 - 混合比) / ROPE精度 + 缩放频率 * 混合比 / ROPE精度
            追加(频率, 插值)
        }
        i = i + 1
    }
    返回 频率
}

// YaRN NTK 频率调整（维度+比例 → 调整后基频列表）
函数 YaRN_NTK频率调整(维度, 比例) {
    定义 半维度 = 维度 / 2
    定义 可变 频率 = []
    定义 可变 i = 0
    当 (i < 半维度) {
        定义 可变 基 = ROPE精度
        定义 可变 p = 0
        当 (p < 2 * i) {
            基 = 基 * ROPE精度 / ROPE_基频
            如果 (基 < 1) { 基 = 1 }
            p = p + 1
        }
        // NTK-aware: θ'_i = θ_i / scale^(2i/d)
        定义 可变 衰减 = ROPE精度
        定义 可变 j = 0
        当 (j < 2 * i) {
            衰减 = 衰减 * 比例 / 维度
            j = j + 1
        }
        如果 (衰减 < 1) { 衰减 = 1 }
        追加(频率, 基 * ROPE精度 / 衰减)
        i = i + 1
    }
    返回 频率
}

// LongRoPE 渐进扩展 (Ding et al. 2024, Microsoft)
// 两步扩展: 先8k→128k (搜索最优per-dimension缩放因子)
// 再128k→2M (第二轮搜索, 从128k的缩放因子出发)
// 推理时: 短文本用原始RoPE, 长文本动态切换扩展RoPE
// 搜索空间: 每个维度有独立的缩放因子 s_i
// θ'_i = θ_i / s_i, s_i ∈ {1, 2, ..., 比例}

函数 LongRoPE_动态切换(位置, 阈值长度, 短频率, 长频率, 向量, 维度) {
    // 短序列用原始频率, 长序列用扩展频率
    如果 (位置 < 阈值长度) {
        返回 RoPE_旋转(短频率, 向量, 位置, 维度)
    }
    返回 RoPE_旋转(长频率, 向量, 位置, 维度)
}

// LongRoPE per-dimension缩放因子搜索 (贪心近似)
函数 LongRoPE_搜索缩放(维度, 原始长度, 目标长度, 搜索步数) {
    定义 半维度 = 维度 / 2
    定义 最大比例 = 目标长度 / 原始长度
    // 初始化: 用YaRN的频率作为起点
    定义 基础频率 = YaRN_NTK频率调整(维度, 目标长度 / 原始长度)
    // 每个维度独立搜索最优缩放
    定义 可变 缩放因子 = []
    定义 可变 i = 0
    当 (i < 半维度) {
        // 对维度i搜索最优s_i
        // 启发式: 低维度(高频) → 缩放小(≈1), 高维度(低频) → 缩放大
        定义 归一化位置 = i * ROPE精度 / 半维度
        // s_i = 1 + (max_scale - 1) × (i/d)^α, α控制分配曲线
        定义 s = ROPE精度 + (最大比例 - 1) * 归一化位置 * 归一化位置 / (ROPE精度 * ROPE精度 / ROPE精度)
        如果 (s < ROPE精度) { s = ROPE精度 }
        如果 (s > 最大比例 * ROPE精度) { s = 最大比例 * ROPE精度 }
        追加(缩放因子, s)
        i = i + 1
    }
    返回 缩放因子
}

// 用per-dimension缩放生成频率
函数 LongRoPE_应用缩放(维度, 缩放因子) {
    定义 半维度 = 维度 / 2
    定义 可变 频率 = []
    定义 可变 i = 0
    当 (i < 半维度) {
        定义 可变 基 = ROPE精度
        定义 可变 p = 0
        当 (p < 2 * i) {
            基 = 基 * ROPE精度 / ROPE_基频
            p = p + 1
        }
        // θ'_i = θ_i / s_i
        追加(频率, 基 * ROPE精度 / 缩放因子[i])
        i = i + 1
    }
    返回 频率
}

// Decoupled RoPE (DeepSeek-V2, 2024)
// MLA中KV被压缩到潜空间c, 位置信息丢失
// 解决: Q侧额外拼接一组带RoPE的小维度 q_rope
// K侧也从c之外额外拼接 k_rope
// 最终QK: [q_nope, q_rope] · [k_nope, k_rope]^T
// q/k_rope维度很小(如64), 不影响KV缓存压缩效率

函数 解耦RoPE_应用(Q_nope, K_nope, x_for_rope, 位置, 频率, nope维度, rope维度) {
    // 生成rope部分
    定义 可变 q_rope = []
    定义 可变 k_rope = []
    定义 半rope = rope维度 / 2
    定义 可变 i = 0
    当 (i < 半rope) {
        定义 θ = 频率[i] * 位置 / ROPE精度
        定义 cos_θ = 定点cos(θ)
        定义 sin_θ = 定点sin(θ)
        // Q_rope
        定义 q0 = x_for_rope[i * 2]
        定义 q1 = x_for_rope[i * 2 + 1]
        追加(q_rope, (q0 * cos_θ - q1 * sin_θ) / ROPE精度)
        追加(q_rope, (q0 * sin_θ + q1 * cos_θ) / ROPE精度)
        // K_rope (可共享同一输入或独立投影)
        追加(k_rope, (q0 * cos_θ - q1 * sin_θ) / ROPE精度)
        追加(k_rope, (q0 * sin_θ + q1 * cos_θ) / ROPE精度)
        i = i + 1
    }
    // 拼接: [nope_part, rope_part]
    定义 可变 Q_full = []
    定义 可变 K_full = []
    i = 0
    当 (i < nope维度) { 追加(Q_full, Q_nope[i]); 追加(K_full, K_nope[i]); i = i + 1 }
    i = 0
    当 (i < rope维度) { 追加(Q_full, q_rope[i]); 追加(K_full, k_rope[i]); i = i + 1 }
    返回 [Q_full, K_full]
}

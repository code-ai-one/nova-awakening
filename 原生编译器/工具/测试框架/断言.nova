导入("../../标准库/基础.nova")

//
// Nova 工具链 测试框架 断言库
// 全功能测试框架 断言 + 测试套件 + 性能基准 + 覆盖率

// 全局测试状态
定义 可变 __测试通过 = 0
定义 可变 __测试失败 = 0
定义 可变 __测试跳过 = 0
定义 可变 __测试名 = ""
定义 可变 __测试套件名 = ""
定义 可变 __测试总时间 = 0
定义 可变 __测试详情 = []
定义 可变 __测试失败详情 = []
定义 可变 __测试套件列表 = []
定义 可变 __当前套件通过 = 0
定义 可变 __当前套件失败 = 0

// 测试组管理

函数 测试组(名称) { 如果 (__测试名 != "") {
 追加(__测试套件列表, [__测试名, __当前套件通过, __当前套件失败])
 }
 __测试名 = 名称
 __当前套件通过 = 0
 __当前套件失败 = 0
 打印(" " + 名称 + " ")
}

函数 测试套件(名称) { __测试套件名 = 名称
 __测试通过 = 0
 __测试失败 = 0
 __测试跳过 = 0
 __测试详情 = []
 __测试失败详情 = []
 __测试套件列表 = []
 __当前套件通过 = 0
 __当前套件失败 = 0
 打印("")
 打印(" 测试套件: " + 名称)
 打印("")
}

// 基础断言

函数 断言相等(实际, 期望, 说明) { 如果 (转字符串(实际) == 转字符串(期望)) { __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" " + 说明)
 追加(__测试详情, [说明, "pass", ""])
 } 否则 { __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" " + 说明)
 打印(" 期望: " + 转字符串(期望))
 打印(" 实际: " + 转字符串(实际))
 追加(__测试详情, [说明, "failed", "期望" + 转字符串(期望) + "实际" + 转字符串(实际)])
 追加(__测试失败详情, [__测试名, 说明, 转字符串(期望), 转字符串(实际)])
 }
}

函数 断言不等(实际, 非期望, 说明) { 如果 (转字符串(实际) != 转字符串(非期望)) { __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" " + 说明)
 } 否则 { __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" " + 说明 + " (值不应等于 " + 转字符串(非期望) + ")")
 追加(__测试失败详情, [__测试名, 说明, "不等于" + 转字符串(非期望), 转字符串(实际)])
 }
}

函数 断言为真(条件, 说明) { 如果 (条件) { __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" " + 说明)
 } 否则 { __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" " + 说明)
 追加(__测试失败详情, [__测试名, 说明, "真", "假"])
 }
}

函数 断言为假(条件, 说明) { 如果 (条件 == 假) { __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" " + 说明)
 } 否则 { __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" " + 说明)
 追加(__测试失败详情, [__测试名, 说明, "假", "真"])
 }
}

函数 断言为空(值, 说明) { 如果 (值 == 空) { __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" " + 说明)
 } 否则 { __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" " + 说明 + " (期望空,实际: " + 转字符串(值) + ")")
 追加(__测试失败详情, [__测试名, 说明, "空", 转字符串(值)])
 }
}

函数 断言非空(值, 说明) { 如果 (值 != 空) { __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" " + 说明)
 } 否则 { __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" " + 说明 + " (值不应为空)")
 追加(__测试失败详情, [__测试名, 说明, "非空", "空"])
 }
}

// 数值断言

函数 断言大于(实际, 阈值, 说明) { 如果 (实际 > 阈值) { __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" " + 说明)
 } 否则 { __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" " + 说明 + " (" + 转字符串(实际) + " 不大于 " + 转字符串(阈值) + ")")
 追加(__测试失败详情, [__测试名, 说明, ">" + 转字符串(阈值), 转字符串(实际)])
 }
}

函数 断言小于(实际, 阈值, 说明) { 如果 (实际 < 阈值) { __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" " + 说明)
 } 否则 { __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" " + 说明 + " (" + 转字符串(实际) + " 不小于 " + 转字符串(阈值) + ")")
 }
}

函数 断言范围(实际, 最小, 最大, 说明) { 如果 (实际 >= 最小 且 实际 <= 最大) { __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" " + 说明)
 } 否则 { __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" " + 说明 + " (" + 转字符串(实际) + " 不在 [" + 转字符串(最小) + "," + 转字符串(最大) + "])")
 }
}

函数 断言近似(实际, 期望, 容差, 说明) { 定义 可变 差 = 实际 - 期望
 如果 (差 < 0) { 差 = 0 - 差 }
 如果 (差 <= 容差) { __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" " + 说明)
 } 否则 { __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" " + 说明 + " (差值" + 转字符串(差) + "超过容差" + 转字符串(容差) + ")")
 }
}

// 列表断言

函数 断言列表相等(实际, 期望, 说明) { 如果 (计数(实际) != 计数(期望)) { __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" " + 说明 + " (长度不同: " + 转字符串(计数(实际)) + " vs " + 转字符串(计数(期望)) + ")")
 返回 空
 }
 定义 可变 i = 0
 当 (i < 计数(实际)) { 如果 (实际[i] != 期望[i]) { __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" " + 说明 + " (索引" + 转字符串(i) + ": " + 转字符串(实际[i]) + " != " + 转字符串(期望[i]) + ")")
 返回 空
 }
 i = i + 1
 }
 __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" " + 说明)
}

函数 断言列表包含(列表, 值, 说明) { 定义 可变 i = 0
 当 (i < 计数(列表)) { 如果 (列表[i] == 值) { __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" " + 说明)
 返回 空
 }
 i = i + 1
 }
 __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" " + 说明 + " (列表不包含 " + 转字符串(值) + ")")
}

函数 断言列表长度(列表, 期望长度, 说明) {
 断言相等(计数(列表), 期望长度, 说明)
}

// 跳过测试

函数 测试跳过(说明) { __测试跳过 = __测试跳过 + 1
 打印(" 跳过: " + 说明)
}

// 测试报告

函数 测试报告() { 如果 (__测试名 != "") {
 追加(__测试套件列表, [__测试名, __当前套件通过, __当前套件失败])
 }
 定义 总数 = __测试通过 + __测试失败
 打印("")
 打印("")
 打印(" 测试报告 ")
 打印("")
 打印(" 通过: " + 转字符串(__测试通过) + "/" + 转字符串(总数))
 如果 (__测试跳过 > 0) {
 打印(" 跳过: " + 转字符串(__测试跳过))
 }
 如果 (__测试失败 == 0) {
 打印(" 状态: 全部通过!")
 } 否则 {
 打印(" 失败: " + 转字符串(__测试失败))
 打印("")
 定义 可变 i = 0
 当 (i < 计数(__测试失败详情)) { 定义 详 = __测试失败详情[i]
 打印(" [" + 详[0] + "] " + 详[1])
 打印(" 期望: " + 详[2] + " 实际: " + 详[3])
 i = i + 1
 }
 }
 打印("")
 如果 (计数(__测试套件列表) > 0) {
 打印("")
 打印(" 各测试组统计 ")
 定义 可变 i = 0
 当 (i < 计数(__测试套件列表)) { 定义 套 = __测试套件列表[i]
 定义 可变 状态 = ""
 如果 (套[2] > 0) { 状态 = "" }
 打印(" " + 状态 + " " + 套[0] + ": " + 转字符串(套[1]) + "通过 " + 转字符串(套[2]) + "failed")
 i = i + 1
 }
 }
 返回 __测试失败
}

// 测试计时器

定义 可变 __测试计时_开始 = 0
定义 可变 __基准测试结果 = []

函数 测试计时开始() { __测试计时_开始 = 时间()
}

函数 测试计时结束(说明) {
 定义 耗时 = 时间() - __测试计时_开始
 打印(" " + 说明 + ": " + 转字符串(耗时) + "ms")
}

// 基准测试

函数 基准测试(名称, 迭代数, 测试函数) {
 打印(" 基准: " + 名称 + " (" + 转字符串(迭代数) + "次)")
 定义 开始时刻 = 时间()
 定义 可变 i = 0
 当 (i < 迭代数) {
 测试函数()
 i = i + 1
 }
 定义 总耗时 = 时间() - 开始时刻
 定义 平均耗时 = 总耗时 / 迭代数
 追加(__基准测试结果, [名称, 迭代数, 总耗时, 平均耗时])
 打印(" 完成 " + 转字符串(迭代数) + " 次迭代, 总耗时 " + 转字符串(总耗时) + "ms, 平均 " + 转字符串(平均耗时) + "ms")
}

函数 基准报告() {
 打印("")
 打印(" 基准测试报告 ")
 定义 可变 i = 0
 当 (i < 计数(__基准测试结果)) { 定义 项 = __基准测试结果[i]
 如果 (计数(项) >= 4) {
 打印(" " + 项[0] + ": " + 转字符串(项[1]) + "次, 总耗时 " + 转字符串(项[2]) + "ms, 平均 " + 转字符串(项[3]) + "ms")
 } 否则 {
 打印(" " + 项[0] + ": " + 转字符串(项[1]) + "次")
 }
 i = i + 1
 }
}

函数 测试_失败模式分析() {
    如果 (计数(__测试失败详情) == 0) { 返回 "无失败"
}
 定义 可变 同组失败 = 0
 定义 可变 上一组 = ""
 定义 可变 i = 0
 当 (i < 计数(__测试失败详情)) { 如果 (__测试失败详情[i][0] == 上一组) { 同组失败 = 同组失败 + 1 }
 上一组 = __测试失败详情[i][0]
 i = i + 1
 }
 如果 (同组失败 > 计数(__测试失败详情) / 2) { 返回 "集中失败: 多个失败集中在同一测试组,可能是基础功能缺陷"
 }
 返回 "分散失败: 失败分布在多个测试组,可能是边界条件问题"
}

函数 测试_覆盖率估算(函数总数) { 定义 已测试 = __测试通过 + __测试失败
 如果 (函数总数 == 0) { 返回 0 }
 返回 已测试 * 100 / 函数总数
}

函数 测试_健康评分() { 定义 总 = __测试通过 + __测试失败
 如果 (总 == 0) { 返回 0 }
 定义 可变 评分 = __测试通过 * 100 / 总
 如果 (__测试跳过 > 总 / 10) { 评分 = 评分 - 10 }
 如果 (评分 < 0) { 评分 = 0 }
 返回 评分
}

函数 测试_推荐() {
    如果 (__测试失败 > __测试通过) { 返回 "大量失败: 建议先修复核心功能再扩展测试"
}
 如果 (__测试跳过 > 5) { 返回 "跳过过多: 建议补全跳过的测试用例" }
 如果 (__测试通过 + __测试失败 < 10) { 返回 "用例不足: 建议增加边界条件和异常测试" }
 如果 (__测试失败 == 0) { 返回 "全部通过: 建议增加压力测试和随机测试" }
 返回 "正常: 优先修复失败用例"
}

// 测试初始化入口

函数 __测试_断言() { __测试通过 = 0
 __测试失败 = 0
 __测试跳过 = 0
 __测试名 = ""
}

// 字符串断言

函数 断言字符串相等(实际, 期望, 说明) {
 定义 实长 = 计数(实际)
 定义 期长 = 计数(期望)
 定义 可变 匹配 = 假
 如果 (实长 == 期长) {
  如果 (期长 == 0) { 匹配 = 真 }
  否则 { 如果 (字符串查找(实际, 期望) == 0) { 匹配 = 真 } }
 }
 如果 (匹配) { __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" " + 说明)
 追加(__测试详情, [说明, "pass", ""])
 } 否则 { __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" " + 说明)
 打印("  期望: " + 期望)
 打印("  实际: " + 实际)
 追加(__测试失败详情, [__测试名, 说明, 期望, 实际])
 }
}

函数 断言字符串包含(文本, 子串文本, 说明) { 定义 可变 i = 0
 定义 子长 = 计数(子串文本)
 定义 文长 = 计数(文本)
 当 (i + 子长 <= 文长) { 如果 (子串(文本, i, 子长) == 子串文本) { __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" ✓ " + 说明)
 返回 空
 }
 i = i + 1
 }
 __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" ✗ " + 说明 + " (不包含 '" + 子串文本 + "')")
}

函数 断言字符串前缀(文本, 前缀, 说明) { 定义 前长 = 计数(前缀)
 如果 (计数(文本) >= 前长 且 子串(文本, 0, 前长) == 前缀) { __测试通过 = __测试通过 + 1
 __当前套件通过 = __当前套件通过 + 1
 打印(" ✓ " + 说明)
 } 否则 { __测试失败 = __测试失败 + 1
 __当前套件失败 = __当前套件失败 + 1
 打印(" ✗ " + 说明 + " (不以 '" + 前缀 + "' 开头)")
 }
}

函数 断言字符串长度(文本, 期望, 说明) {
 断言相等(计数(文本), 期望, 说明)
}

// 参数化测试

函数 参数化测试(名称, 参数列表, 测试函数) {
 打印(" ── 参数化: " + 名称 + " (" + 转字符串(计数(参数列表)) + "组) ──")
 定义 可变 i = 0
 当 (i < 计数(参数列表)) {
 测试函数(参数列表[i])
 i = i + 1
 }
}

// 重复测试

函数 重复测试(名称, 次数, 测试函数) {
 打印(" ── 重复: " + 名称 + " (" + 转字符串(次数) + "次) ──")
 定义 可变 失败轮 = 0
 定义 可变 i = 0
 当 (i < 次数) { 定义 前失败 = __测试失败
 测试函数()
 如果 (__测试失败 > 前失败) { 失败轮 = 失败轮 + 1 }
 i = i + 1
 }
 如果 (失败轮 > 0) {
 打印(" 警告: " + 转字符串(失败轮) + "/" + 转字符串(次数) + " 轮有失败")
 }
}

// 测试夹具

函数 测试夹具_创建(设置函数, 清理函数) { 返回 [设置函数, 清理函数, []]
}

函数 测试夹具_运行(夹具, 测试函数) {
 夹具[0]()
 测试函数()
 夹具[1]()
}

定义 可变 __上次测试结果 = []

函数 测试_保存结果() { __上次测试结果 = [__测试通过, __测试失败, __测试跳过]
}

函数 测试_回归检测() {
    如果 (计数(__上次测试结果) < 3) { 返回 "无历史数据"
}
 定义 上次失败 = __上次测试结果[1]
 如果 (__测试失败 > 上次失败) { 返回 "回归: 失败数增加 " + 转字符串(__测试失败 - 上次失败)
 }
 如果 (__测试失败 < 上次失败) { 返回 "改善: 失败数减少 " + 转字符串(上次失败 - __测试失败)
 }
 返回 "稳定: 无变化"
}

函数 测试_摘要() { 定义 总 = __测试通过 + __测试失败
 如果 (总 == 0) { 返回 "无测试执行" }
 定义 通过率 = __测试通过 * 100 / 总
 定义 可变 等级 = "A"
 如果 (通过率 < 90) { 等级 = "B" }
 如果 (通过率 < 70) { 等级 = "C" }
 如果 (通过率 < 50) { 等级 = "D" }
 如果 (通过率 < 30) { 等级 = "F" }
 返回 等级 + "级 (" + 转字符串(通过率) + "% 通过)"
}

函数 测试_运行策略(_总用例数, 可用时间) {
    如果 (可用时间 < 10) { 返回 "烟雾测试: 只运行核心用例"
}
 如果 (可用时间 < 60) { 返回 "快速测试: 运行高优先级用例" }
 如果 (可用时间 < 300) { 返回 "标准测试: 运行全部功能测试" }
 返回 "完整测试: 功能+性能+压力测试"
}

// 断言计数器

函数 断言_总通过() { 返回 __测试通过 }
函数 断言_总失败() { 返回 __测试失败 }
函数 断言_总跳过() { 返回 __测试跳过 }
函数 断言_总数() { 返回 __测试通过 + __测试失败 + __测试跳过 }

函数 断言_通过率() { 定义 总 = 断言_总数()
 如果 (总 == 0) { 返回 0 }
 返回 __测试通过 * 100 / 总
}

函数 断言_质量评分() { 定义 率 = 断言_通过率()
 如果 (率 >= 95) { 返回 [率, "优秀"] }
 如果 (率 >= 80) { 返回 [率, "良好"] }
 如果 (率 >= 60) { 返回 [率, "及格"] }
 返回 [率, "需要修复"]
}

函数 断言_摘要() { 定义 质量 = 断言_质量评分()
 返回 [__测试通过, __测试失败, __测试跳过, 质量[0], 质量[1]]
}

}

// 媒体内存报告
定义 可变 _媒体_音频缓冲字节 = 0
定义 可变 _媒体_图像缓冲字节 = 0
定义 可变 _媒体_视频缓冲字节 = 0

函数 媒体内存_记录(音频, 图像, 视频) {
    _媒体_音频缓冲字节 = 音频
    _媒体_图像缓冲字节 = 图像
    _媒体_视频缓冲字节 = 视频
}

函数 媒体内存_报告() {
    定义 可变 r = 字典()
    字典设(r, "音频缓冲", 转字符串(_媒体_音频缓冲字节))
    字典设(r, "图像缓冲", 转字符串(_媒体_图像缓冲字节))
    字典设(r, "视频缓冲", 转字符串(_媒体_视频缓冲字节))
    字典设(r, "总计", 转字符串(_媒体_音频缓冲字节 + _媒体_图像缓冲字节 + _媒体_视频缓冲字节))
    返回 r
}

// M13: AV同步 (audio_master时钟)
// 音频主时钟: 以音频播放采样数为权威时间源
// 视频帧根据音频时钟决定显示/跳过/重复
// 同步器: [采样率, 已播放采样数, 音频时间ms, 视频PTS, 漂移ms, 丢帧数, 重复帧数]

函数 AV同步_创建(采样率) {
    返回 [采样率, 0, 0, 0, 0, 0, 0]
}

函数 AV同步_音频推进(同步, 采样数) {
    同步[1] = 同步[1] + 采样数
    同步[2] = 同步[1] * 1000 / 同步[0]
}

函数 AV同步_音频时间(同步) { 返回 同步[2] }

// 视频帧决策: 给定视频帧PTS(ms), 返回动作
// 1=显示, 0=跳过(视频慢了, 0), 2=重复上帧(视频快了)
函数 AV同步_视频决策(同步, 视频PTS) {
    同步[3] = 视频PTS
    同步[4] = 视频PTS - 同步[2]  // 漂移 = 视频PTS - 音频时间
    // 视频落后音频超过40ms → 跳帧
    如果 (同步[4] < -40) {
        同步[5] = 同步[5] + 1
        返回 0
    }
    // 视频领先音频超过20ms → 重复上帧(等待)
    如果 (同步[4] > 20) {
        同步[6] = 同步[6] + 1
        返回 2
    }
    // 在容许范围内 → 正常显示
    返回 1
}

函数 AV同步_漂移(同步) { 返回 同步[4] }

函数 AV同步_报告(同步) {
    定义 可变 r = 字典()
    字典设(r, "采样率", 转字符串(同步[0]))
    字典设(r, "已播放采样", 转字符串(同步[1]))
    字典设(r, "音频时间ms", 转字符串(同步[2]))
    字典设(r, "视频PTS", 转字符串(同步[3]))
    字典设(r, "漂移ms", 转字符串(同步[4]))
    字典设(r, "丢帧数", 转字符串(同步[5]))
    字典设(r, "重复帧数", 转字符串(同步[6]))
    返回 r
}

// M13: 真实媒体管线smoke — 音频/图像/视频数据流端到端

函数 媒体_真实smoke() {
    定义 可变 结果 = 字典()

    // 音频管线: 生成正弦波→ADSR包络→低通滤波→峰值/RMS检测→环形缓冲写入
    定义 buf = PCM缓冲_创建(1024, 44100, 16, 1)
    正弦波_生成(buf, 440, 800, 0, 1024)           // 440Hz正弦波
    ADSR_应用(buf, 50, 100, 700, 800, 174, 1024)  // 包络
    低通滤波_应用(buf, 200)                         // 低通
    定义 峰值 = PCM缓冲_峰值(buf)
    定义 rms = PCM缓冲_RMS(buf)
    // 写入环形缓冲
    定义 设备 = 音频设备_创建(44100, 16, 1, 4096)
    音频设备_打开(设备)
    定义 写入数 = 音频设备_写入(设备, buf, 0, 512)
    _媒体_音频缓冲字节 = 1024 * 2  // 16bit mono
    定义 音频报告 = 字典()
    字典设(音频报告, "采样率", "44100")
    字典设(音频报告, "位深", "16")
    字典设(音频报告, "通道", "1")
    字典设(音频报告, "缓冲长度", "1024")
    字典设(音频报告, "峰值", 转字符串(峰值))
    字典设(音频报告, "RMS", 转字符串(rms))
    字典设(音频报告, "环形写入", 转字符串(写入数))
    字典设(结果, "audio_pipeline", 音频报告)

    // 图像管线: 创建图像缓冲→填充色块→卷积(边缘检测, 0)→报告
    定义 宽 = 64
    定义 高 = 64
    定义 可变 图像 = []
    定义 可变 pi = 0
    当 (pi < 宽 * 高 * 4) {
        // 左半红色, 右半蓝色
        如果 ((pi / 4) % 宽 < 宽 / 2) {
            追加(图像, 255) 追加(图像, 0) 追加(图像, 0) 追加(图像, 255)
        } 否则 {
            追加(图像, 0) 追加(图像, 0) 追加(图像, 255) 追加(图像, 255)
        }
        pi = pi + 4
    }
    _媒体_图像缓冲字节 = 宽 * 高 * 4
    定义 图像报告 = 字典()
    字典设(图像报告, "宽", 转字符串(宽))
    字典设(图像报告, "高", 转字符串(高))
    字典设(图像报告, "色彩空间", "RGBA8")
    字典设(图像报告, "像素数", 转字符串(宽 * 高))
    字典设(图像报告, "字节数", 转字符串(宽 * 高 * 4))
    字典设(结果, "image_pipeline", 图像报告)

    // 视频管线: 帧队列→AV同步→帧决策
    定义 同步 = AV同步_创建(44100)
    定义 可变 跳过数 = 0
    定义 可变 重复数 = 0
    // 模拟播放1秒音频 (44100采样)
    AV同步_音频推进(同步, 44100)
    // 模拟30个视频帧 (33ms间隔)
    定义 可变 显示数 = 0
    定义 可变 fi = 0
    当 (fi < 30) {
        定义 pts = fi * 33
        定义 决策 = AV同步_视频决策(同步, pts)
        如果 (决策 == 1) { 显示数 = 显示数 + 1 }
        如果 (决策 == 0) { 跳过数 = 跳过数 + 1 }
        如果 (决策 == 2) { 重复数 = 重复数 + 1 }
        fi = fi + 1
    }
    _媒体_视频缓冲字节 = 30 * 宽 * 高 * 4  // 30帧RGBA
    定义 视频报告 = 字典()
    字典设(视频报告, "帧数", "30")
    字典设(视频报告, "显示", 转字符串(显示数))
    字典设(视频报告, "跳过", 转字符串(跳过数))
    字典设(视频报告, "重复", 转字符串(重复数))
    字典设(结果, "video_pipeline", 视频报告)

    // AV同步报告
    字典设(结果, "av_sync", AV同步_报告(同步))
    // 媒体内存报告
    字典设(结果, "media_memory", 媒体内存_报告())

    返回 结果
}

// §8验收矩阵: 媒体报告函数定义在行614-687
函数 音视同步_报告(同步) { 返回 AV同步_报告(同步) }


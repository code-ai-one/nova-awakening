导入("./内核直连层.nova")

// §3 高斯模糊
// 盒式近似: 3次box blur ≈ 高斯


函数 Filter_blur(像素, 宽, 高, 半径) {
    // 半径: ×100
    如果 (半径 <= 0) { 返回 }
    定义 r = 半径 / 100
    如果 (r < 1) { r = 1 }
    如果 (r > 100) { r = 100 }

    定义 临时 = 堆_分配_数组(宽 * 高 * 4)

    // 3次box blur近似高斯
    Filter_boxBlur_水平(像素, 临时, 宽, 高, r)
    Filter_boxBlur_垂直(临时, 像素, 宽, 高, r)
    Filter_boxBlur_水平(像素, 临时, 宽, 高, r)
    Filter_boxBlur_垂直(临时, 像素, 宽, 高, r)
    Filter_boxBlur_水平(像素, 临时, 宽, 高, r)
    Filter_boxBlur_垂直(临时, 像素, 宽, 高, r)

    堆_释放(临时)
}

函数 Filter_boxBlur_水平(源, 目标, 宽, 高, r) {
    定义 窗口 = 2 * r + 1
    定义 可变 y = 0
    当 (y < 高) {
        定义 可变 累r = 0; 定义 可变 累g = 0; 定义 可变 累b = 0; 定义 可变 累a = 0
        // 初始化窗口
        定义 可变 i = 0 - r
        当 (i <= r) {
            定义 xi = 钳制(i, 0, 宽 - 1)
            定义 偏移 = (y * 宽 + xi) * 4
            累r = 累r + 内存_读8(源 + 偏移)
            累g = 累g + 内存_读8(源 + 偏移 + 1)
            累b = 累b + 内存_读8(源 + 偏移 + 2)
            累a = 累a + 内存_读8(源 + 偏移 + 3)
            i = i + 1
        }
        // 滑动窗口
        定义 可变 x = 0
        当 (x < 宽) {
            定义 dst偏移 = (y * 宽 + x) * 4
            内存_写8(目标 + dst偏移, 累r / 窗口)
            内存_写8(目标 + dst偏移 + 1, 累g / 窗口)
            内存_写8(目标 + dst偏移 + 2, 累b / 窗口)
            内存_写8(目标 + dst偏移 + 3, 累a / 窗口)
            // 移除左端
            定义 左 = 钳制(x - r, 0, 宽 - 1)
            定义 左偏移 = (y * 宽 + 左) * 4
            累r = 累r - 内存_读8(源 + 左偏移)
            累g = 累g - 内存_读8(源 + 左偏移 + 1)
            累b = 累b - 内存_读8(源 + 左偏移 + 2)
            累a = 累a - 内存_读8(源 + 左偏移 + 3)
            // 添加右端
            定义 右 = 钳制(x + r + 1, 0, 宽 - 1)
            定义 右偏移 = (y * 宽 + 右) * 4
            累r = 累r + 内存_读8(源 + 右偏移)
            累g = 累g + 内存_读8(源 + 右偏移 + 1)
            累b = 累b + 内存_读8(源 + 右偏移 + 2)
            累a = 累a + 内存_读8(源 + 右偏移 + 3)
            x = x + 1
        }
        y = y + 1
    }
}

函数 Filter_boxBlur_垂直(源, 目标, 宽, 高, r) {
    定义 窗口 = 2 * r + 1
    定义 可变 x = 0
    当 (x < 宽) {
        定义 可变 累r = 0; 定义 可变 累g = 0; 定义 可变 累b = 0; 定义 可变 累a = 0
        定义 可变 i = 0 - r
        当 (i <= r) {
            定义 yi = 钳制(i, 0, 高 - 1)
            定义 偏移 = (yi * 宽 + x) * 4
            累r = 累r + 内存_读8(源 + 偏移)
            累g = 累g + 内存_读8(源 + 偏移 + 1)
            累b = 累b + 内存_读8(源 + 偏移 + 2)
            累a = 累a + 内存_读8(源 + 偏移 + 3)
            i = i + 1
        }
        定义 可变 y = 0
        当 (y < 高) {
            定义 dst偏移 = (y * 宽 + x) * 4
            内存_写8(目标 + dst偏移, 累r / 窗口)
            内存_写8(目标 + dst偏移 + 1, 累g / 窗口)
            内存_写8(目标 + dst偏移 + 2, 累b / 窗口)
            内存_写8(目标 + dst偏移 + 3, 累a / 窗口)
            定义 上 = 钳制(y - r, 0, 高 - 1)
            定义 上偏移 = (上 * 宽 + x) * 4
            累r = 累r - 内存_读8(源 + 上偏移)
            累g = 累g - 内存_读8(源 + 上偏移 + 1)
            累b = 累b - 内存_读8(源 + 上偏移 + 2)
            累a = 累a - 内存_读8(源 + 上偏移 + 3)
            定义 下 = 钳制(y + r + 1, 0, 高 - 1)
            定义 下偏移 = (下 * 宽 + x) * 4
            累r = 累r + 内存_读8(源 + 下偏移)
            累g = 累g + 内存_读8(源 + 下偏移 + 1)
            累b = 累b + 内存_读8(源 + 下偏移 + 2)
            累a = 累a + 内存_读8(源 + 下偏移 + 3)
            y = y + 1
        }
        x = x + 1
    }
}

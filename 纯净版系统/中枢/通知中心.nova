导入("./内核打印.nova")

// NovaOS · 通知中心 — 面向用户的系统事件通知分发
// §1 通知优先级与类型
// §2 通知发布/订阅
// §3 通知队列 (未读/已读/过期)
// §4 通知持久化 (重启后恢复未读)


定义 通知_信息 = 0
定义 通知_警告 = 1
定义 通知_错误 = 2
定义 通知_紧急 = 3

定义 通知类型_系统 = 0         // 系统事件(更新/关机/磁盘满)
定义 通知类型_安全 = 1         // 安全事件(登录/权限/威胁)
定义 通知类型_应用 = 2         // 应用通知
定义 通知类型_网络 = 3         // 网络状态
定义 通知类型_AI = 4           // AI推理完成/模型更新

定义 通知_最大数 = 512
定义 通知_过期秒 = 604800      // 7天

结构 通知 {
    ID,
    优先级,         // u32 通知_*
    类型,           // u32 通知类型_*
    标题,
    内容,
    来源,
    时间戳,
    已读,
    已过期,
}

定义 可变 _通知队列 = []
定义 可变 _通知序号 = 0
定义 可变 _订阅者列表 = []

结构 通知订阅 {
    订阅者ID,
    类型过滤,       // i32 -1=全部, 其他=通知类型_*
    优先级过滤,     // i32 -1=全部, 其他=最低优先级
    回调,           // 函数引用(简化为标记)
}


函数 通知_发布(优先级, 类型, 标题, 内容, 来源) {
    如果 (计数(_通知队列) >= 通知_最大数) {
        通知_清理过期(读取毫秒() / 1000)
        如果 (计数(_通知队列) >= 通知_最大数) {
            通知_淘汰最旧已读()
        }
    }

    _通知序号 = _通知序号 + 1
    定义 n = 通知 {}
    n.ID = _通知序号
    n.优先级 = 优先级
    n.类型 = 类型
    n.标题 = 标题
    n.内容 = 内容
    n.来源 = 来源
    n.时间戳 = 读取毫秒() / 1000
    n.已读 = 假
    n.已过期 = 假
    追加(_通知队列, n)

    // 通知订阅者
    通知_分发(n)
    返回 n.ID
}

函数 通知_分发(n) {
    定义 可变 i = 0
    当 (i < 计数(_订阅者列表)) {
        定义 sub = _订阅者列表[i]
        定义 类型匹配 = (sub.类型过滤 == -1 || sub.类型过滤 == n.类型)
        定义 优先级匹配 = (sub.优先级过滤 == -1 || n.优先级 >= sub.优先级过滤)
        如果 (类型匹配 && 优先级匹配) {
            // 实际回调(简化: 记录日志)
            内核信息("[通知→" + 整数转字符串(sub.订阅者ID) + "] " + n.标题)
        }
        i = i + 1
    }
}


函数 通知_订阅(订阅者ID, 类型过滤, 优先级过滤) {
    定义 sub = 通知订阅 {}
    sub.订阅者ID = 订阅者ID
    sub.类型过滤 = 类型过滤
    sub.优先级过滤 = 优先级过滤
    sub.回调 = 0
    追加(_订阅者列表, sub)
}

函数 通知_取消订阅(订阅者ID) {
    定义 可变 i = 0
    当 (i < 计数(_订阅者列表)) {
        如果 (_订阅者列表[i].订阅者ID == 订阅者ID) {
            列表_移除(_订阅者列表, i)
            返回 真
        }
        i = i + 1
    }
    返回 假
}


函数 通知_标记已读(ID) {
    定义 可变 i = 0
    当 (i < 计数(_通知队列)) {
        如果 (_通知队列[i].ID == ID) { _通知队列[i].已读 = 真; 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 通知_标记全部已读() {
    定义 可变 i = 0
    当 (i < 计数(_通知队列)) { _通知队列[i].已读 = 真; i = i + 1 }
}

函数 通知_未读数() {
    定义 可变 n = 0
    定义 可变 i = 0
    当 (i < 计数(_通知队列)) {
        如果 (!_通知队列[i].已读 && !_通知队列[i].已过期) { n = n + 1 }
        i = i + 1
    }
    返回 n
}

函数 通知_获取未读(最大数) {
    定义 可变 结果 = []
    定义 可变 i = 计数(_通知队列) - 1
    当 (i >= 0 && 计数(结果) < 最大数) {
        如果 (!_通知队列[i].已读 && !_通知队列[i].已过期) {
            追加(结果, _通知队列[i])
        }
        i = i - 1
    }
    返回 结果
}


函数 通知_清理过期(当前时间) {
    定义 可变 i = 0
    当 (i < 计数(_通知队列)) {
        如果 (!_通知队列[i].已过期 && 当前时间 - _通知队列[i].时间戳 > 通知_过期秒) {
            _通知队列[i].已过期 = 真
        }
        i = i + 1
    }
}

函数 通知_淘汰最旧已读() {
    定义 可变 i = 0
    当 (i < 计数(_通知队列)) {
        如果 (_通知队列[i].已读 || _通知队列[i].已过期) {
            列表_移除(_通知队列, i)
            返回
        }
        i = i + 1
    }
    // 全是未读未过期, 淘汰最旧
    如果 (计数(_通知队列) > 0) { 列表_移除(_通知队列, 0) }
}


函数 通知_优先级名(优先级) {
    如果 (优先级 == 通知_信息) { 返回 "信息" }
    如果 (优先级 == 通知_警告) { 返回 "警告" }
    如果 (优先级 == 通知_错误) { 返回 "错误" }
    如果 (优先级 == 通知_紧急) { 返回 "紧急" }
    返回 "未知"
}

函数 通知_类型名(类型) {
    如果 (类型 == 通知类型_系统) { 返回 "系统" }
    如果 (类型 == 通知类型_安全) { 返回 "安全" }
    如果 (类型 == 通知类型_应用) { 返回 "应用" }
    如果 (类型 == 通知类型_网络) { 返回 "网络" }
    如果 (类型 == 通知类型_AI) { 返回 "AI" }
    返回 "未知"
}

函数 通知_报告() {
    定义 可变 r = "═══ 通知中心 ═══\n"
    r = r + "总数: " + 整数转字符串(计数(_通知队列)) + "\n"
    r = r + "未读: " + 整数转字符串(通知_未读数()) + "\n"
    r = r + "订阅者: " + 整数转字符串(计数(_订阅者列表)) + "\n"
    返回 r
}

函数 通知_重置() {
    _通知队列 = []
    _通知序号 = 0
    _订阅者列表 = []
}

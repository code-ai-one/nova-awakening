// §3 核心布局算法 — 块级 Flow 布局
// (对应 布局块级Flow::布局块级Children)
// 块级布局: 子元素从上到下依次排列

函数 布局Object_布局(lo) {
 如果 (!(lo.标志 & 布局标志_需要布局) && !(lo.标志 & 布局标志_子树需要布局)) {
 返回
 }

 如果 (lo.类型 == 布局类型_块 || lo.类型 == 布局类型_视图) {
 布局块级_布局(lo)
 }
 否则 如果 (lo.类型 == 布局类型_弹性) {
 布局弹性_布局(lo)
 }
 否则 如果 (lo.类型 == 布局类型_内联) {
 布局Inline_布局(lo)
 }
 否则 如果 (lo.类型 == 布局类型_文本) {
 布局Text_布局(lo)
 }
 否则 如果 (lo.类型 == 布局类型_表格) {
 布局Table_布局(lo)
 }

 // 清除脏标记
 lo.标志 = lo.标志 & (~布局标志_需要布局)
 lo.标志 = lo.标志 & (~布局标志_子树需要布局)
}

函数 布局块级_布局(lo) {
 定义 s = lo.样式
 如果 (s == 0) { 返回 }

 // 确定可用宽度
 定义 可变 可用宽 = lo.内容宽
 如果 (lo.父 != 0 && 可用宽 == 0) {
 可用宽 = lo.父.内容宽
 }

 // 应用自身width
 如果 (!s.width.是auto) {
 如果 (s.width.单位 == 单位_百分比 && lo.父 != 0) {
 lo.内容宽 = lo.父.内容宽 * s.width.值 / 10000
 } 否则 {
 lo.内容宽 = s.width.值
 }
 可用宽 = lo.内容宽
 } 否则 {
 // auto宽度: 填满父的内容区
 如果 (lo.父 != 0) {
 lo.内容宽 = lo.父.内容宽 - s.margin_left.值 - s.margin_right.值 - s.padding_left.值 - s.padding_right.值 - s.border_left_width - s.border_right_width
 可用宽 = lo.内容宽
 }
 }

 // 子元素布局: 从上到下
 定义 可变 当前Y = 0
 定义 可变 子 = lo.第一子
 当 (子 != 0) {
 如果 (子.样式 != 0 && 子.样式.display == Display_none) {
 子 = 子.后兄
 继续
 }

 // 递归布局子元素
 布局Object_布局(子)

 定义 子样式 = 子.样式
 如果 (子样式 != 0) {
 // 设置子元素位置
 子.x = 子样式.margin_left.值 + s.padding_left.值 + s.border_left_width
 子.y = 当前Y + 子样式.margin_top.值

 // 块级子: 占满整行,Y向下推进
 如果 (子.类型 == 布局类型_块 || 子.类型 == 布局类型_弹性 || 子.类型 == 布局类型_表格) {
 当前Y = 子.y + 布局Object_边框盒高(子) + 子样式.margin_bottom.值
 }
 否则 如果 (子.类型 == 布局类型_文本) {
 当前Y = 子.y + 子.内容高
 }
 否则 {
 当前Y = 子.y + 布局Object_边框盒高(子)
 }
 } 否则 {
 子.x = 0
 子.y = 当前Y
 当前Y = 当前Y + 子.内容高
 }

 子 = 子.后兄
 }

 // 设置自身高度
 如果 (!s.height.是auto) {
 如果 (s.height.单位 == 单位_百分比 && lo.父 != 0) {
 lo.内容高 = lo.父.内容高 * s.height.值 / 10000
 } 否则 {
 lo.内容高 = s.height.值
 }
 } 否则 {
 // auto高度: 等于内容高度
 lo.内容高 = 当前Y + s.padding_top.值 + s.padding_bottom.值 + s.border_top_width + s.border_bottom_width
 }

 // 计算绝对位置
 布局Object_计算绝对位置(lo)
}

// 对应: nova/Nova渲染核心/html/forms/ (
// 本文件扩展HTMLFormControls.nova(基础721行)，补全：
// ① HTMLSelect元素: 下拉/多选/optgroup/option
// ② HTMLTextArea元素: 多行文本/自动调高/maxlength
// ③ HTMLDataList元素: 自动完成建议列表
// ④ HTMLOutput元素: 计算结果显示
// ⑤ HTNova多层感知器rogress元素: 进度条(确定/不确定)
// ⑥ HTMLMeter元素: 度量条(min/max/low/high/optimum)
// ⑦ HTMLFieldSet元素/HTMLLegend元素: 分组
// ⑧ 文件上传: File/FileList/FileReader/拖放上传
// ⑨ 输入法(IME)处理: compositionstart/update/end
// ⑩ 选区管理: selectionStart/selectionEnd/setSelectionRange
// 【Nova特色】AI表单优化:
// ① AI语义自动完成(基于字段名/上下文)
// ② AI输入预测(下一个可能输入)

// §1 HTMLSelect元素

结构 HTMLOption元素 {
 节点,    // u64 节点*
 值,    // u64 value属性
 文本,    // u64 显示文本
 selected,
 disabled,
 defaultSelected,
 // 所属optgroup
 optgroup,    // u64 HTMLOptGroup元素*
 下一个,
}

结构 HTMLOptGroup元素 {
 节点,
 label,
 disabled,
}

结构 HTMLSelect元素 {
 节点,
 // 属性
 name,
 multiple,    // 布尔 多选模式
 size,    // u32 可见选项数(1=下拉, >1=列表)
 required,
 disabled,
 autofocus,
 // 选项列表
 选项头,    // u64 HTMLOption元素*链表
 选项数,
 // 选中状态
 selectedIndex,    // i32 单选模式:-1=无选中
 // 关联表单
 form,    // u64 HTMLForm元素*
 // UI状态
 打开,    // 布尔 下拉菜单是否打开
 // 事件
 onchange,
 oninput,
}


函数 Select_创建() {
 定义 sel = 堆_分配(HTMLSelect元素)
 sel.节点 = 0; sel.name = 0; sel.multiple = 假; sel.size = 1
 sel.required = 假; sel.disabled = 假; sel.autofocus = 假
 sel.选项头 = 0; sel.选项数 = 0; sel.selectedIndex = -1
 sel.form = 0; sel.打开 = 假; sel.onchange = 0; sel.oninput = 0
 返回 sel
}

函数 Select_add(sel, option, before) {
 如果 (sel == 0 || option == 0) { 返回 }
 如果 (before == 0) {
 // 添加到末尾
 如果 (sel.选项头 == 0) { sel.选项头 = option }
 否则 {
 定义 可变 last = sel.选项头
 当 (last.下一个 != 0) { last = last.下一个 }
 last.下一个 = option
 }
 }
 sel.选项数 = sel.选项数 + 1
 如果 (option.selected && !sel.multiple) { sel.selectedIndex = sel.选项数 - 1 }
}

函数 Select_remove(sel, index) {
 如果 (sel == 0 || index < 0 || index >= sel.选项数) { 返回 }
 定义 可变 prev = 0
 定义 可变 opt = sel.选项头
 定义 可变 i = 0
 当 (opt != 0 && i < index) { prev = opt; opt = opt.下一个; i = i + 1 }
 如果 (opt != 0) {
 如果 (prev == 0) { sel.选项头 = opt.下一个 }
 否则 { prev.下一个 = opt.下一个 }
 sel.选项数 = sel.选项数 - 1
 如果 (sel.selectedIndex == index) { sel.selectedIndex = -1 }
 否则 如果 (sel.selectedIndex > index) { sel.selectedIndex = sel.selectedIndex - 1 }
 }
}

函数 Select_item(sel, index) {
 如果 (sel == 0 || index < 0 || index >= sel.选项数) { 返回 0 }
 定义 可变 opt = sel.选项头
 定义 可变 i = 0
 当 (opt != 0 && i < index) { opt = opt.下一个; i = i + 1 }
 返回 opt
}

函数 Select_value(sel) {
 如果 (sel == 0 || sel.selectedIndex < 0) { 返回 "" }
 定义 opt = Select_item(sel, sel.selectedIndex)
 如果 (opt != 0) { 返回 opt.值 }
 返回 ""
}

函数 Select_setValue(sel, 值) {
 如果 (sel == 0 || 值 == 0) { 返回 }
 定义 可变 opt = sel.选项头
 定义 可变 i = 0
 当 (opt != 0) {
 如果 (字符串_相等(opt.值, 值)) {
 sel.selectedIndex = i
 opt.selected = 真
 返回
 }
 opt = opt.下一个; i = i + 1
 }
}

// 获取所有选中项(多选模式)
函数 Select_selectedOptions(sel, 结果, 最大数) {
 如果 (sel == 0 || 结果 == 0) { 返回 0 }
 定义 可变 count = 0
 定义 可变 opt = sel.选项头
 当 (opt != 0 && count < 最大数) {
 如果 (opt.selected) {
 内存_写64(结果 + count * 8, opt)
 count = count + 1
 }
 opt = opt.下一个
 }
 返回 count
}

导入("../基础.nova")


// 滑动窗口注意力 (Longformer, 0 , 0, 0)
函数 滑动窗口_掩码(序列长度, 窗口大小) {
    定义 半窗 = 窗口大小 / 2
    定义 可变 掩码 = []
    定义 可变 i = 0
    当 (i < 序列长度) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j < 序列长度) {
            定义 可变 距离 = i - j
            如果 (距离 < 0) { 距离 = 0 - 距离 }
            如果 (距离 <= 半窗) { 追加(行, 1) }
            否则 { 追加(行, 0) }
            j = j + 1
        }
        追加(掩码, 行)
        i = i + 1
    }
    返回 掩码
}

函数 滑动窗口_注意力(Q, K, V, 窗口大小, 序列长度, 维度) {
    定义 可变 指数组 = []
    定义 半窗 = 窗口大小 / 2
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 序列长度) {
        // 只关注窗口内的位置
        定义 可变 起始 = i - 半窗
        如果 (起始 < 0) { 起始 = 0 }
        定义 可变 结束 = i + 半窗 + 1
        如果 (结束 > 序列长度) { 结束 = 序列长度 }
        // 计算注意力分数
        定义 可变 分数 = []
        定义 可变 j = 起始
        当 (j < 结束) {
            定义 可变 s = 0
            定义 可变 d = 0
            当 (d < 维度) {
                s = s + Q[i * 维度 + d] * K[j * 维度 + d] / 1000
                d = d + 1
            }
            追加(分数, s)
            j = j + 1
        }
        // 归一化指数
        定义 可变 最大得分 = 分数[0]
        定义 可变 k = 1
        当 (k < 计数(分数)) { 如果 (分数[k] > 最大得分) { 最大得分 = 分数[k] }
        k = k + 1 }
        定义 可变 总 = 0
        k = 0
        当 (k < 计数(分数)) {
            定义 可变 e = 1000 + (分数[k] - 最大得分)
            如果 (e < 1) { e = 1 }
            追加(指数组, e)
            总 = 总 + e
            k = k + 1
        }
        如果 (总 == 0) { 总 = 1 }
        // 加权求和V
        定义 可变 行输出 = []
        定义 可变 d = 0
        当 (d < 维度) { 追加(行输出, 0)
        d = d + 1 }
        j = 起始
        k = 0
        当 (j < 结束) {
            定义 α = 指数组[k] * 1000 / 总
            d = 0
            当 (d < 维度) {
                行输出[d] = 行输出[d] + α * V[j * 维度 + d] / 1000
                d = d + 1
            }
            j = j + 1
            k = k + 1
        }
        追加(输出, 行输出)
        i = i + 1
    }
    返回 输出
}

// 全局Token注意力
函数 全局token_掩码(序列长度, 全局位置列表) {
    定义 可变 掩码 = []
    定义 可变 i = 0
    当 (i < 序列长度) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j < 序列长度) { 追加(行, 0)
        j = j + 1 }
        // 全局token可以看到所有位置
        定义 可变 是全局 = 0
        定义 可变 g = 0
        当 (g < 计数(全局位置列表)) {
            如果 (全局位置列表[g] == i) { 是全局 = 1 }
            g = g + 1
        }
        如果 (是全局 == 1) {
            j = 0
            当 (j < 序列长度) { 行[j] = 1
            j = j + 1 }
        }
        // 所有位置可以看到全局token
        g = 0
        当 (g < 计数(全局位置列表)) { 行[全局位置列表[g]] = 1
        g = g + 1 }
        追加(掩码, 行)
        i = i + 1
    }
    返回 掩码
}

// BigBird: 滑动窗口 + 全局 + 随机
定义 SA_随机态 = 33333
函数 SA_随机() {
    SA_随机态 = SA_随机态 ^ (SA_随机态 << 13)
    SA_随机态 = SA_随机态 ^ (SA_随机态 >> 7)
    SA_随机态 = SA_随机态 ^ (SA_随机态 << 17)
    如果 (SA_随机态 < 0) { SA_随机态 = 0 - SA_随机态 }
    返回 SA_随机态
}

函数 BigBird_掩码(序列长度, 窗口大小, 全局数, 随机数) {
    定义 窗口掩码 = 滑动窗口_掩码(序列长度, 窗口大小)
    // 全局token (前几个位置)
    定义 可变 全局位置 = []
    定义 可变 g = 0
    当 (g < 全局数 且 g < 序列长度) { 追加(全局位置, g)
    g = g + 1 }
    定义 全局掩码 = 全局token_掩码(序列长度, 全局位置)
    // 合并 + 随机连接
    定义 可变 最终掩码 = []
    定义 可变 i = 0
    当 (i < 序列长度) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j < 序列长度) {
            如果 (窗口掩码[i][j] == 1 或 全局掩码[i][j] == 1) {
                追加(行, 1)
            } 否则 {
                追加(行, 0)
            }
            j = j + 1
        }
        // 添加随机连接
        定义 可变 r = 0
        当 (r < 随机数) {
            定义 位置 = SA_随机() % 序列长度
            行[位置] = 1
            r = r + 1
        }
        追加(最终掩码, 行)
        i = i + 1
    }
    返回 最终掩码
}

// 块稀疏注意力
函数 块稀疏_注意力(Q, K, V, 块大小, 序列长度, 维度) {
    定义 可变 指数组 = []
    定义 块数 = (序列长度 + 块大小 - 1) / 块大小
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 序列长度) { 追加(输出, [])
    i = i + 1 }
    // 每个块内做全注意力
    定义 可变 b = 0
    当 (b < 块数) {
        定义 块起 = b * 块大小
        定义 可变 块终 = 块起 + 块大小
        如果 (块终 > 序列长度) { 块终 = 序列长度 }
        // 块内全注意力
        定义 可变 qi = 块起
        当 (qi < 块终) {
            定义 可变 分数 = []
            定义 可变 kj = 块起
            当 (kj < 块终) {
                定义 可变 s = 0
                定义 可变 d = 0
                当 (d < 维度) {
                    s = s + Q[qi * 维度 + d] * K[kj * 维度 + d] / 1000
                    d = d + 1
                }
                追加(分数, s)
                kj = kj + 1
            }
            // 归一化指数 + weighted V
            定义 可变 最大得分 = 分数[0]
            定义 可变 k = 1
            当 (k < 计数(分数)) { 如果 (分数[k] > 最大得分) { 最大得分 = 分数[k] }
            k = k + 1 }
            定义 可变 总 = 0
            k = 0
            当 (k < 计数(分数)) {
                定义 可变 e = 1000 + (分数[k] - 最大得分)
                如果 (e < 1) { e = 1 }
                追加(指数组, e)
                总 = 总 + e
                k = k + 1
            }
            如果 (总 == 0) { 总 = 1 }
            定义 可变 行输出 = []
            定义 可变 d = 0
            当 (d < 维度) { 追加(行输出, 0)
            d = d + 1 }
            kj = 块起
            k = 0
            当 (kj < 块终) {
                定义 α = 指数组[k] * 1000 / 总
                d = 0
                当 (d < 维度) {
                    行输出[d] = 行输出[d] + α * V[kj * 维度 + d] / 1000
                    d = d + 1
                }
                kj = kj + 1
                k = k + 1
            }
            输出[qi] = 行输出
            qi = qi + 1
        }
        b = b + 1
    }
    返回 输出
}

// 线性注意力 (Katharopoulos et al., 0 , 0)
// Attention(Q,K,V) = φ(Q)·(φ(K)^T·V) / (φ(Q)·Σφ(K)^T)
函数 稀疏注意_线性注意力(Q, K, V, 序列长度, 维度) {
    // φ(x) = 指数线性函数(x) + 1
    定义 可变 输出 = []
    // 计算累积 KV 和 K
    定义 可变 KV累积 = []  // d×d矩阵
    定义 可变 K累积 = []   // d向量
    定义 可变 d1 = 0
    当 (d1 < 维度) {
        定义 可变 行 = []
        定义 可变 d2 = 0
        当 (d2 < 维度) { 追加(行, 0)
        d2 = d2 + 1 }
        追加(KV累积, 行)
        追加(K累积, 0)
        d1 = d1 + 1
    }
    定义 可变 i = 0
    当 (i < 序列长度) {
        // φ(K_i) = max(0, K_i) + 1  (ELU+1近似)
        定义 可变 d = 0
        当 (d < 维度) {
            定义 可变 k_val = K[i * 维度 + d]
            如果 (k_val < 0) { k_val = k_val / 4 }  // ELU近似
            k_val = k_val + 1000
            // 累积 KV
            定义 可变 d2 = 0
            当 (d2 < 维度) {
                KV累积[d][d2] = KV累积[d][d2] + k_val * V[i * 维度 + d2] / 1000
                d2 = d2 + 1
            }
            K累积[d] = K累积[d] + k_val
            d = d + 1
        }
        // 计算输出: φ(Q_i)·KV累积 / φ(Q_i)·K累积
        定义 可变 行输出 = []
        定义 可变 归一化 = 0
        d = 0
        当 (d < 维度) {
            定义 可变 q_val = Q[i * 维度 + d]
            如果 (q_val < 0) { q_val = q_val / 4 }
            q_val = q_val + 1000
            归一化 = 归一化 + q_val * K累积[d] / 1000
            d = d + 1
        }
        如果 (归一化 == 0) { 归一化 = 1 }
        d = 0
        当 (d < 维度) {
            定义 可变 数值 = 0
            定义 可变 d2 = 0
            当 (d2 < 维度) {
                定义 可变 q_val = Q[i * 维度 + d2]
                如果 (q_val < 0) { q_val = q_val / 4 }
                q_val = q_val + 1000
                数值 = 数值 + q_val * KV累积[d2][d] / 1000
                d2 = d2 + 1
            }
            追加(行输出, 数值 * 1000 / 归一化)
            d = d + 1
        }
        追加(输出, 行输出)
        i = i + 1
    }
    返回 输出
}

// 膨胀注意力
函数 膨胀_掩码(序列长度, 膨胀率) {
    定义 可变 掩码 = []
    定义 可变 i = 0
    当 (i < 序列长度) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j < 序列长度) {
            如果 (i - j) % 膨胀率 == 0 且 j <= i { 追加(行, 1) }
            否则 { 追加(行, 0) }
            j = j + 1
        }
        追加(掩码, 行)
        i = i + 1
    }
    返回 掩码
}

// 注意力复杂度统计
函数 注意力_稀疏度(掩码, 序列长度) {
    定义 可变 总 = 0
    定义 可变 非零 = 0
    定义 可变 i = 0
    当 (i < 序列长度) {
        定义 可变 j = 0
        当 (j < 序列长度) {
            总 = 总 + 1
            如果 (掩码[i][j] == 1) { 非零 = 非零 + 1 }
            j = j + 1
        }
        i = i + 1
    }
    如果 (总 == 0) { 返回 0 }
    返回 1000 - 非零 * 1000 / 总  // 稀疏率×1000
}

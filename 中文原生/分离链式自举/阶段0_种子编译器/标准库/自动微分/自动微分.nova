导入("../基础.nova")
导入("../算法/数学扩展.nova")


// 计算图节点
// 节点: [ID, 操作类型, 值, 梯度, 左子ID, 右子ID, 需要梯度]
// 操作: 0=叶子, 1=加, 2=减, 3=乘, 4=除, 5=线性整流, 6=平方, 7=取负
定义 可变 图_节点列表 = []
定义 可变 图_下一ID = 0

函数 图_重置() { 图_节点列表 = []
图_下一ID = 0 }

函数 图_查节点(id) {
    如果 (id >= 0 且 id < 计数(图_节点列表)) { 返回 图_节点列表[id]
}
 返回 空
}

函数 变量(值) { 定义 id = 图_下一ID
 图_下一ID = 图_下一ID + 1
 追加(图_节点列表, [id, 0, 值, 0, -1, -1, 1])
 返回 id
}

函数 常量值(值) { 定义 id = 图_下一ID
 图_下一ID = 图_下一ID + 1
 追加(图_节点列表, [id, 0, 值, 0, -1, -1, 0])
 返回 id
}

函数 图_值(id) { 返回 图_节点列表[id][2] }
函数 图_梯度(id) { 返回 图_节点列表[id][3] }
函数 图_设梯度(id, g) { 图_节点列表[id][3] = g }

// 前向运算
函数 图_加(a, b) { 定义 id = 图_下一ID
 图_下一ID = 图_下一ID + 1
 追加(图_节点列表, [id, 1, 图_值(a) + 图_值(b), 0, a, b, 1])
 返回 id
}

函数 图_减(a, b) { 定义 id = 图_下一ID
 图_下一ID = 图_下一ID + 1
 追加(图_节点列表, [id, 2, 图_值(a) - 图_值(b), 0, a, b, 1])
 返回 id
}

函数 图_乘(a, b) { 定义 id = 图_下一ID
 图_下一ID = 图_下一ID + 1
 追加(图_节点列表, [id, 3, 图_值(a) * 图_值(b), 0, a, b, 1])
 返回 id
}

函数 图_ReLU(a) { 定义 v = 图_值(a)
 定义 可变 rv = v
 如果 (v < 0) { rv = 0 }
 定义 id = 图_下一ID
 图_下一ID = 图_下一ID + 1
 追加(图_节点列表, [id, 5, rv, 0, a, -1, 1])
 返回 id
}

函数 图_平方(a) { 定义 v = 图_值(a)
 定义 id = 图_下一ID
 图_下一ID = 图_下一ID + 1
 追加(图_节点列表, [id, 6, v * v, 0, a, -1, 1])
 返回 id
}

函数 图_取负(a) { 定义 id = 图_下一ID
 图_下一ID = 图_下一ID + 1
 追加(图_节点列表, [id, 7, 0 - 图_值(a), 0, a, -1, 1])
 返回 id
}

// 反向传播
函数 反向传播(输出id) {
 // 从输出节点开始, 反向遍历图
 图_设梯度(输出id, 1)
 定义 可变 i = 输出id
 当 (i >= 0) { 定义 n = 图_节点列表[i]
 定义 op = n[1]
 定义 梯度 = n[3]
 定义 左id = n[4]
 定义 右id = n[5]

 如果 (op == 1) {
 // 加: d(a+b)/da=1, d(a+b)/db=1
 如果 (左id >= 0) { 图_设梯度(左id, 图_梯度(左id) + 梯度) }
 如果 (右id >= 0) { 图_设梯度(右id, 图_梯度(右id) + 梯度) }
 }
 如果 (op == 2) {
 // 减: d(a-b)/da=1, d(a-b)/db=-1
 如果 (左id >= 0) { 图_设梯度(左id, 图_梯度(左id) + 梯度) }
 如果 (右id >= 0) { 图_设梯度(右id, 图_梯度(右id) - 梯度) }
 }
 如果 (op == 3) {
 // 乘: d(a*b)/da=b, d(a*b)/db=a
 如果 (左id >= 0 且 右id >= 0) {
 图_设梯度(左id, 图_梯度(左id) + 梯度 * 图_值(右id))
 图_设梯度(右id, 图_梯度(右id) + 梯度 * 图_值(左id))
 }
 }
 如果 (op == 5) {
 // 线性整流: 梯度 * (x>0 ? 1 : 0)
 如果 (左id >= 0) { 如果 (图_值(左id) > 0) { 图_设梯度(左id, 图_梯度(左id) + 梯度) }
 }
 }
 如果 (op == 6) {
 // 平方: d(x²)/dx = 2x
 如果 (左id >= 0) { 图_设梯度(左id, 图_梯度(左id) + 梯度 * 2 * 图_值(左id)) }
 }
 如果 (op == 7) {
 // 取负: d(-x)/dx = -1
 如果 (左id >= 0) { 图_设梯度(左id, 图_梯度(左id) - 梯度) }
 }
 i = i - 1
 }
}

// 梯度清零
函数 梯度清零() { 定义 可变 i = 0
 当 (i < 计数(图_节点列表)) { 图_节点列表[i][3] = 0
 i = i + 1 }
}

// 梯度裁剪
函数 自动微分_梯度裁剪_值(参数ids, 最大值) { 定义 可变 i = 0
 当 (i < 计数(参数ids)) { 定义 id = 参数ids[i]
 定义 g = 图_梯度(id)
 如果 (g > 最大值) { 图_设梯度(id, 最大值) }
 如果 (g < 0 - 最大值) { 图_设梯度(id, 0 - 最大值) }
 i = i + 1
 }
}

函数 梯度范数(参数ids) { 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < 计数(参数ids)) { 定义 g = 图_梯度(参数ids[i])
 总和 = 总和 + g * g
 i = i + 1
 }
 如果 (总和 == 0) { 返回 0 }
 返回 整数sqrt(总和)
}

// 优化器: SGD+动量
// 动量缓存: [速度列表]
函数 SGDM_创建(参数数) { 定义 可变 v = []
 定义 可变 i = 0
 当 (i < 参数数) { 追加(v, 0)
 i = i + 1 }
 返回 v
}

函数 SGDM_步(参数ids, 速度, 学习率, 动量) { 定义 可变 i = 0
 当 (i < 计数(参数ids)) { 定义 id = 参数ids[i]
 速度[i] = (动量 * 速度[i]) / 100 + 图_梯度(id)
 图_节点列表[id][2] = 图_节点列表[id][2] - 学习率 * 速度[i]
 i = i + 1
 }
}

// 优化器: Adam
// Adam状态: [m列表, v列表, t]
函数 Adam_创建(参数数) { 定义 可变 m = []
 定义 可变 v = []
 定义 可变 i = 0
 当 (i < 参数数) { 追加(m, 0)
 追加(v, 0)
 i = i + 1 }
 返回 [m, v, 0]
}

函数 Adam_步(参数ids, 状态, 学习率, beta1, beta2, 极小值) {
 状态[2] = 状态[2] + 1
 定义 可变 i = 0
 当 (i < 计数(参数ids)) { 定义 id = 参数ids[i]
 定义 g = 图_梯度(id)
 // m = beta1*m + (1-beta1)*g
 状态[0][i] = (beta1 * 状态[0][i] + (100 - beta1) * g) / 100
 // v = beta2*v + (1-beta2)*g²
 状态[1][i] = (beta2 * 状态[1][i] + (100 - beta2) * g * g) / 100
 // bias correction (simplified)
 定义 一阶矫正 = 状态[0][i] * 100 / (100 - beta1)
 定义 二阶矫正 = 状态[1][i] * 100 / (100 - beta2)
 定义 可变 sv = 整数sqrt(二阶矫正)
 如果 (sv == 0) { sv = 1 }
 图_节点列表[id][2] = 图_节点列表[id][2] - 学习率 * 一阶矫正 / (sv + 极小值)
 i = i + 1
 }
}

// 学习率调度
函数 学习率_预热(目标lr, 当前步, 预热步数) {
    如果 (当前步 >= 预热步数) { 返回 目标lr
}
 如果 (预热步数 == 0) { 返回 0 }
 返回 目标lr * 当前步 / 预热步数
}

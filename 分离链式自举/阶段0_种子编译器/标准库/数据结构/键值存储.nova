//    设值 = "给"字操作: 值交给存储 (所有权转移)
//    取值 = "被"字借用: 值被读取不消费 (仿射借用)
//    删值 = "把"字消费: 把值从存储中不可逆取出 (线性消费)
//    TTL过期 = 金行约束 (时间精炼)
//    LRU淘汰 = 水行约束 (流量回收)
//    批量操作是"批"量词态射: 条→批

导入("../基础.nova")

// 存储: [数据字典, 过期字典, 访问计数字典, 最大条目数, 当前条目数, 键顺序列表]
// 键顺序列表: 最近使用的键在末尾, 最久未使用的键在头部
函数 键值存储_kv_创建(最大条目) {
    返回 [字典(), 字典(), 字典(), 最大条目, 0, []]
}

// 内部: 将键移到顺序列表末尾 (标记为最近使用)
函数 kv_提升键(存储, 键) {
    定义 可变 i = 0
    当 (i < 计数(存储[5])) {
        如果 (存储[5][i] == 键) {
            删除(存储[5], i)
            追加(存储[5], 键)
            返回
        }
        i = i + 1
    }
    // 键不在列表中, 添加到末尾
    追加(存储[5], 键)
}

函数 kv_设(存储, 键, 值) {
    定义 旧 = 字典取(存储[0], 键)
    字典设(存储[0], 键, 值)
    字典设(存储[2],  键, 0)
    如果 (旧 == 空) {
        存储[4] = 存储[4] + 1
    }
    kv_提升键(存储, 键)
    // LRU淘汰检查
    当 (存储[4] > 存储[3] 且 存储[3] > 0) {
        kv_淘汰LRU(存储)
    }
}

函数 kv_取(存储, 键) {
    定义 值 = 字典取(存储[0], 键)
    如果 (值 != 空) {
        // 更新访问计数
        定义 可变 计数值 = 字典取(存储[2], 键)
        如果 (计数值 == 空) { 计数值 = 0 }
        字典设(存储[2], 键, 计数值 + 1)
        // 提升为最近使用
        kv_提升键(存储, 键)
    }
    返回 值
}

函数 kv_删(存储, 键) {
    定义 旧 = 字典取(存储[0], 键)
    如果 (旧 != 空) {
        字典设(存储[0], 键, 空)
        字典设(存储[1], 键, 空)
        字典设(存储[2], 键, 空)
        存储[4] = 存储[4] - 1
        定义 可变 i = 0
        当 (i < 计数(存储[5])) {
            如果 (存储[5][i] == 键) { 删除(存储[5], i) i = i - 1 }
            i = i + 1
        }
    }
}

函数 键值存储_kv_存在(存储, 键) {
    返回 字典取(存储[0], 键) != 空
}

函数 键值存储_kv_大小(存储) { 返回 存储[4] }

// 设置过期时间 (模拟时间戳)
函数 kv_设过期(存储, 键, 过期时间) {
    字典设(存储[1], 键, 过期时间)
}

// 检查是否过期
函数 kv_已过期(存储, 键, 当前时间) {
    定义 过期 = 字典取(存储[1], 键)
    如果 (过期 == 空) { 返回 0 }
    返回 当前时间 > 过期
}

// LRU淘汰 — 删除最久未使用的条目 (键顺序列表头部)
函数 kv_淘汰LRU(存储) {
    如果 (计数(存储[5]) == 0) {
        返回
    }
    // 头部是最久未使用的键
    定义 淘汰键 = 存储[5][0]
    删除(存储[5])
    // 从所有字典中移除
    字典设(存储[0], 淘汰键, 空)
    字典设(存储[1], 淘汰键, 空)
    字典设(存储[2], 淘汰键, 空)
    存储[4] = 存储[4] - 1
}

// 事务支持

// 事务: [操作列表, 是否活跃]
函数 kv_事务_开始() {
    返回 [[], 1]
}

函数 kv_事务_设(事务, 键, 值) {
    如果 (事务[1] == 1) {
        追加(事务[0], ["SET", 键, 值])
    }
}

函数 kv_事务_删(事务, 键) {
    如果 (事务[1] == 1) {
        追加(事务[0], ["DEL", 键, 空])
    }
}

函数 kv_事务_提交(存储, 事务) {
    如果 (事务[1] != 1) { 返回 0 }
    定义 操作 = 事务[0]
    定义 可变 i = 0
    当 (i < 计数(操作)) {
        定义 op = 操作[i]
        如果 (op[0] == "SET") {
            kv_设(存储, op[1], op[2])
        }
        如果 (op[0] == "DEL") {
            kv_删(存储, op[1])
        }
        i = i + 1
    }
    事务[1] = 0
    返回 1
}

函数 kv_事务_回滚(事务) {
    事务[0] = []
    事务[1] = 0
}

// 批量操作

函数 kv_批量设(存储, 键值对列表) {
    定义 可变 i = 0
    当 (i < 计数(键值对列表)) {
        kv_设(存储, 键值对列表[i][0], 键值对列表[i][1])
        i = i + 1
    }
}

函数 kv_批量取(存储, 键列表) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        追加(结果, kv_取(存储, 键列表[i]))
        i = i + 1
    }
    返回 结果
}

函数 kv_批量删(存储, 键列表) {
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        kv_删(存储, 键列表[i])
        i = i + 1
    }
}

// TTL过期支持 (O(1)字典)

定义 可变 _kv_ttl_字典 = 字典()
定义 可变 _kv_ttl_键列 = []

函数 kv_设TTL(键, 到期时间) {
    定义 已有 = 字典取(_kv_ttl_字典, 键)
    如果 (已有 == 空) { 追加(_kv_ttl_键列, 键) }
    字典设(_kv_ttl_字典, 键, 到期时间)
}

函数 kv_已过期_全局(键, 当前时间) {
    定义 到期 = 字典取(_kv_ttl_字典, 键)
    如果 (到期 == 空) { 返回 假 }
    返回 当前时间 > 到期
}

函数 kv_清理过期(存储, 当前时间) {
    定义 可变 清理数 = 0
    定义 可变 新键列 = []
    定义 新字典 = 字典()
    定义 可变 i = 0
    当 (i < 计数(_kv_ttl_键列)) {
        定义 键 = _kv_ttl_键列[i]
        定义 到期 = 字典取(_kv_ttl_字典, 键)
        如果 (到期 != 空 且 当前时间 > 到期) {
            kv_删(存储, 键)
            清理数 = 清理数 + 1
        } 否则 如果 (到期 != 空) {
            追加(新键列, 键)
            字典设(新字典, 键, 到期)
        }
        i = i + 1
    }
    _kv_ttl_键列 = 新键列
    _kv_ttl_字典 = 新字典
    返回 清理数
}

// 快照

函数 kv_快照(存储) {
    定义 键列表 = 字典键列表(存储[0])
    定义 可变 快照键 = []
    定义 可变 快照值 = []
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        定义 键 = 键列表[i]
        追加(快照键, 键)
        追加(快照值, 字典取(存储[0], 键))
        i = i + 1
    }
    返回 [快照键, 快照值]
}

函数 kv_恢复快照(存储, 快照) {
    定义 新数据 = 字典()
    定义 可变 i = 0
    当 (i < 计数(快照[0])) {
        字典设(新数据, 快照[0][i], 快照[1][i])
        i = i + 1
    }
    存储[0] = 新数据
    存储[4] = 计数(快照[0])
}

// 前缀扫描

函数 kv_前缀扫描(存储, 前缀) {
    定义 可变 结果键 = []
    定义 键列表 = 字典键列表(存储[0])
    定义 可变 结果值 = []
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        定义 键 = 键列表[i]
        定义 前缀长 = 字节长度(前缀)
        如果 (字节长度(键) >= 前缀长) {
            如果 (子串(键, 0, 前缀长) == 前缀) {
                追加(结果键, 键)
                追加(结果值, 字典取(存储[0], 键))
            }
        }
        i = i + 1
    }
    返回 [结果键, 结果值]
}

定义 可变 _kv_读数 = 0
定义 可变 _kv_写数 = 0

函数 键值存储_kv_记录读() { _kv_读数 = _kv_读数 + 1 }
函数 键值存储_kv_记录写() { _kv_写数 = _kv_写数 + 1 }

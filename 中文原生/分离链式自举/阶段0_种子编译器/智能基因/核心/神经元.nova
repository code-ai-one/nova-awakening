// Nova 原生 · 智能基因层 · 神经元原语
// 设计理念：仿生人脑神经元的信号传递与激活机制
// 这是 AI 基因最底层的计算单元，比知识和推理更基础
// 神经元网络 = 信号 + 权重 + 激活 + 传播

// 激活函数类型

导入("../../标准库/基础.nova")

定义 激活_阶跃   = 1    // 阶跃函数（0或1）
定义 激活_线性   = 2    // 线性激活
定义 激活_符号   = 3    // 符号函数（-1,0,1）
定义 激活_饱和   = 4    // 饱和线性

// 神经元状态
定义 神经元_静息   = 0   // 未激活
定义 神经元_活跃   = 1   // 激活中
定义 神经元_抑制   = 2   // 被抑制

// 神经元：[标识, 阈值, 偏置, 状态, 输出值, 连接列表]
函数 神经元_神经元_创建(标识, 阈值, 偏置) {
    返回 [标识, 阈值, 偏置, 神经元_静息, 0, []]
}

函数 神经元_标识(n)  { 返回 n[0] }
函数 神经元_阈值(n)  { 返回 n[1] }
函数 神经元_偏置(n)  { 返回 n[2] }
函数 神经元_状态(n)  { 返回 n[3] }
函数 神经元_输出(n)  { 返回 n[4] }
函数 神经元_连接(n)  { 返回 n[5] }

// 激活函数
函数 激活_计算(激活类型, 输入, 阈值) {
    如果 (激活类型 == 激活_阶跃) {
        如果 (输入 >= 阈值) { 返回 1 }
        返回 0
    }
    如果 (激活类型 == 激活_线性) {
        返回 输入
    }
    如果 (激活类型 == 激活_符号) {
        如果 (输入 > 0) { 返回 1 }
        如果 (输入 < 0) { 返回 0 - 1 }
        返回 0
    }
    返回 输入
}

// 突触连接：[源神经元标识, 目标神经元标识, 权重, 延迟, 可塑性]
函数 突触_创建(源, 目标, 权重, _扩4, _扩5) {
    返回 [源, 目标, 权重, 1, 1]
}

函数 突触_源(s)    { 返回 s[0] }
函数 突触_目标(s)  { 返回 s[1] }
函数 突触_权重(s)  { 返回 s[2] }
函数 突触_可塑(s)  { 返回 s[4] }

函数 突触_加强(突触, 量) {
    如果 (突触_可塑(突触) == 1) {
        突触[2] = 突触[2] + 量
    }
}

函数 突触_削弱(突触, 量) {
    如果 (突触_可塑(突触) == 1) {
        突触[2] = 突触[2] - 量
        如果 (突触[2] < 0) { 突触[2] = 0 }
    }
}

// 神经元激活：计算加权输入并决定是否激活
函数 神经元_激活(神经元, 输入信号列表, 激活类型) {
    如果 (计数(输入信号列表) == 0) {
        神经元[3] = 神经元_静息
        神经元[4] = 0
        返回 0
    }
    定义 可变 加权和 = 神经元_偏置(神经元)
    定义 可变 i = 0
    当 (i < 计数(输入信号列表)) {
        加权和 = 加权和 + 输入信号列表[i]
        i = i + 1
    }
    定义 输出 = 激活_计算(激活类型, 加权和, 神经元_阈值(神经元))
    神经元[4] = 输出
    如果 (输出 > 0) {
        神经元[3] = 神经元_活跃
    } 否则 {
        神经元[3] = 神经元_静息
    }
    返回 输出
}

// 神经元层：一组并行工作的神经元
函数 神经层_创建(大小, 激活类型) {
    定义 可变 神经元列表 = []
    定义 可变 i = 0
    当 (i < 大小) {
        追加(神经元列表, 神经元_神经元_创建("n" + 转字符串(i), 0 , 0))
        i = i + 1
    }
    返回 [神经元列表, 激活类型, 大小]
}

函数 神经层_前向(层, 输入向量) {
    如果 (计数(输入向量) != 层[2]) { 返回 [] }
    定义 可变 输出向量 = []
    定义 可变 i = 0
    当 (i < 层[2]) {
        定义 单元输入 = [输入向量[i]]
        定义 输出 = 神经元_激活(层[0][i], 单元输入, 层[1])
        追加(输出向量, 输出)
        i = i + 1
    }
    返回 输出向量
}

// 简单感知机：最小可用的前馈神经网络
函数 感知机_创建(输入维度, 阈值) {
    定义 可变 权重列表 = []
    定义 可变 i = 0
    当 (i < 输入维度) {
        追加(权重列表, 0)
        i = i + 1
    }
    返回 [权重列表, 阈值, 0, 输入维度]
}

函数 感知机_前向(感知机, 输入) {
    如果 (计数(输入) != 感知机[3]) { 返回 0 }
    定义 可变 加权和 = 感知机[2]
    定义 可变 i = 0
    当 (i < 感知机[3]) {
        加权和 = 加权和 + 感知机[0][i] * 输入[i]
        i = i + 1
    }
    如果 (加权和 >= 感知机[1]) { 返回 1 }
    返回 0
}

函数 感知机_学习(感知机, 输入, 期望输出, 学习率) {
    定义 实际输出 = 感知机_前向(感知机, 输入)
    定义 误差 = 期望输出 - 实际输出
    如果 (误差 == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < 感知机[3]) {
        感知机[0][i] = 感知机[0][i] + 学习率 * 误差 * 输入[i]
        i = i + 1
    }
    感知机[2] = 感知机[2] + 学习率 * 误差
    返回 误差
}

// 赫布学习：用者强、不用者弱（突触可塑性）
函数 赫布_更新(突触列表, 激活状态, 学习率, 衰减率) {
    定义 可变 i = 0
    当 (i < 计数(突触列表)) {
        定义 突触 = 突触列表[i]
        如果 (突触_可塑(突触) == 1) {
            定义 可变 源激活 = 0
            定义 可变 目标激活 = 0
            如果 (字典有(激活状态, 突触_源(突触))) {
                源激活 = 字典取(激活状态, 突触_源(突触))
            }
            如果 (字典有(激活状态, 突触_目标(突触))) {
                目标激活 = 字典取(激活状态, 突触_目标(突触))
            }
            定义 更新量 = 学习率 * 源激活 * 目标激活 - 衰减率 * 突触_权重(突触)
            突触[2] = 突触[2] + 更新量
        }
        i = i + 1
    }
}

定义 可变 _神经元_创建总数 = 0
定义 可变 _神经元_激活总数 = 0
定义 可变 _突触_加强总数 = 0
定义 可变 _突触_削弱总数 = 0

函数 神经元_记录创建() { _神经元_创建总数 = _神经元_创建总数 + 1 }
函数 神经元_记录激活() { _神经元_激活总数 = _神经元_激活总数 + 1 }

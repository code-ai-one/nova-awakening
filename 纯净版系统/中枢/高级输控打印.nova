导入("./类型定义.nova")
导入("./错误码.nova")
导入("./自动扩容.nova")
导入("../感知/内核直连层.nova")
导入("./字符串替换.nova")
导入("./内存初始化.nova")

定义 最大全局中断 = 256
定义 最大输入控制器 = 8
定义 触发_边沿 = 0
定义 触发_电平 = 1
定义 极性_高 = 0
定义 极性_低 = 1

结构 输入控制器 {
    基地址,
    标识,
    版本,
    中断起始,
    中断结束,
    重定向数,
}

结构 中断路由 {
    向量号,
    目标核,
    触发模式,
    极性,
    已配置,
    已屏蔽,
    触发次数,
}

定义 可变 控制器表 = []
定义 可变 控制器数 = 0
定义 可变 路由表 = 0
定义 可变 已配置数 = 0
定义 可变 总路由次数 = 0

函数 输入控_初始化() {
    控制器表 = []
    控制器数 = 0
    路由表 = 堆_分配(最大全局中断 * 28)
    定义 可变 序号 = 0
    当 (序号 < 最大全局中断) {
        定义 偏移 = 路由表 + 序号 * 28
        内存_写32(偏移, 0)
        内存_写32(偏移 + 4, 0)
        内存_写32(偏移 + 8, 0)
        内存_写32(偏移 + 12, 0)
        内存_写32(偏移 + 16, 0)
        内存_写32(偏移 + 20, 1)
        内存_写32(偏移 + 24, 0)
        序号 = 序号 + 1
    }
}

函数 输入控_注册(基地址, 标识) {
    如果 (控制器数 >= 最大输入控制器) { 返回 -1 }
    定义 控 = 输入控制器 {}
    控.基地址 = 基地址
    控.标识 = 标识
    控.版本 = 输入控_读寄存器(基地址, 1) & 0xFF
    控.重定向数 = ((输入控_读寄存器(基地址, 1) >> 16) & 0xFF) + 1
    如果 (控制器数 == 0) { 控.中断起始 = 0 }
    否则 {
        定义 上一个 = 控制器表[控制器数 - 1]
        控.中断起始 = 上一个.中断结束 + 1
    }
    控.中断结束 = 控.中断起始 + 控.重定向数 - 1
    追加(控制器表, 控)
    定义 索引 = 控制器数
    控制器数 = 控制器数 + 1
    返回 索引
}

函数 输入控_读寄存器(基地址, 寄存器) {
    内存_写32(基地址, 寄存器)
    返回 内存_读32(基地址 + 0x10)
}

函数 输入控_写寄存器(基地址, 寄存器, 值) {
    内存_写32(基地址, 寄存器)
    内存_写32(基地址 + 0x10, 值)
}

函数 输入控_配置路由(全局中断号, 向量, 目标核, 触发, 极性) {
    如果 (全局中断号 >= 最大全局中断) { 返回 错误_无效参数 }
    总路由次数 = 总路由次数 + 1
    定义 偏移 = 路由表 + 全局中断号 * 28
    内存_写32(偏移, 向量)
    内存_写32(偏移 + 4, 目标核)
    内存_写32(偏移 + 8, 触发)
    内存_写32(偏移 + 12, 极性)
    内存_写32(偏移 + 16, 1)
    内存_写32(偏移 + 20, 0)
    已配置数 = 已配置数 + 1
    定义 可变 控索引 = 0
    当 (控索引 < 控制器数) {
        定义 控 = 控制器表[控索引]
        如果 (全局中断号 >= 控.中断起始 && 全局中断号 <= 控.中断结束) {
            定义 引脚 = 全局中断号 - 控.中断起始
            定义 低32 = 向量 & 0xFF
            如果 (触发 == 触发_电平) { 低32 = 低32 | (1 << 15) }
            如果 (极性 == 极性_低) { 低32 = 低32 | (1 << 13) }
            定义 高32 = (目标核 & 0xFF) << 24
            输入控_写寄存器(控.基地址, 0x10 + 引脚 * 2, 低32)
            输入控_写寄存器(控.基地址, 0x10 + 引脚 * 2 + 1, 高32)
            返回 0
        }
        控索引 = 控索引 + 1
    }
    返回 错误_不存在
}

函数 输入控_屏蔽(全局中断号) {
    如果 (全局中断号 >= 最大全局中断) { 返回 }
    定义 偏移 = 路由表 + 全局中断号 * 28
    内存_写32(偏移 + 20, 1)
    定义 可变 控索引 = 0
    当 (控索引 < 控制器数) {
        定义 控 = 控制器表[控索引]
        如果 (全局中断号 >= 控.中断起始 && 全局中断号 <= 控.中断结束) {
            定义 引脚 = 全局中断号 - 控.中断起始
            定义 低32 = 输入控_读寄存器(控.基地址, 0x10 + 引脚 * 2)
            输入控_写寄存器(控.基地址, 0x10 + 引脚 * 2, 低32 | (1 << 16))
            返回
        }
        控索引 = 控索引 + 1
    }
}

函数 输入控_解除屏蔽(全局中断号) {
    如果 (全局中断号 >= 最大全局中断) { 返回 }
    定义 偏移 = 路由表 + 全局中断号 * 28
    内存_写32(偏移 + 20, 0)
    定义 可变 控索引 = 0
    当 (控索引 < 控制器数) {
        定义 控 = 控制器表[控索引]
        如果 (全局中断号 >= 控.中断起始 && 全局中断号 <= 控.中断结束) {
            定义 引脚 = 全局中断号 - 控.中断起始
            定义 低32 = 输入控_读寄存器(控.基地址, 0x10 + 引脚 * 2)
            输入控_写寄存器(控.基地址, 0x10 + 引脚 * 2, 低32 & ~(1 << 16))
            返回
        }
        控索引 = 控索引 + 1
    }
}

函数 输入控_记录触发(全局中断号) {
    如果 (全局中断号 >= 最大全局中断) { 返回 }
    定义 偏移 = 路由表 + 全局中断号 * 28
    内存_写32(偏移 + 24, 内存_读32(偏移 + 24) + 1)
}

函数 输入控_设亲和性(全局中断号, 新目标核) {
    如果 (全局中断号 >= 最大全局中断) { 返回 }
    定义 偏移 = 路由表 + 全局中断号 * 28
    定义 向量 = 内存_读32(偏移)
    定义 触发 = 内存_读32(偏移 + 8)
    定义 极性 = 内存_读32(偏移 + 12)
    输入控_配置路由(全局中断号, 向量, 新目标核, 触发, 极性)
}

函数 输入控_触发模式名(模式) {
    如果 (模式 == 触发_边沿) { 返回 "边沿" }
    如果 (模式 == 触发_电平) { 返回 "电平" }
    返回 "未知"
}

// 初始化保护与统计

定义 可变 打印_已初始化 = 假
定义 可变 打印_屏蔽次数 = 0
定义 可变 打印_解屏蔽次数 = 0
定义 可变 打印_亲和设置次数 = 0
定义 可变 打印_错误数 = 0
定义 可变 打印_速率 = 0
定义 可变 打印_速率窗口 = 0
定义 可变 打印_速率时刻 = 0
定义 可变 打印_峰值速率 = 0

函数 输入控_完整初始化() {
    如果 (打印_已初始化 == 真) { 返回 错误_已存在 }
    输入控_初始化()
    打印_屏蔽次数 = 0
    打印_解屏蔽次数 = 0
    打印_亲和设置次数 = 0
    打印_错误数 = 0
    打印_速率 = 0
    打印_速率窗口 = 0
    打印_速率时刻 = 0
    打印_峰值速率 = 0
    打印_已初始化 = 真
    打印("[输入控打印] 完整初始化完成")
    返回 0
}

// 极性名称

函数 输入控_极性名(极性值) {
    如果 (极性值 == 极性_高) { 返回 "高有效" }
    如果 (极性值 == 极性_低) { 返回 "低有效" }
    返回 "未知"
}

// 路由查询增强

函数 输入控_获取路由(全局中断号) {
    如果 (全局中断号 >= 最大全局中断 || 路由表 == 0) { 返回 空 }
    定义 偏移 = 路由表 + 全局中断号 * 28
    如果 (内存_读32(偏移 + 16) == 0) { 返回 空 }
    返回 [内存_读32(偏移), 内存_读32(偏移 + 4), 内存_读32(偏移 + 8),
           内存_读32(偏移 + 12), 内存_读32(偏移 + 20), 内存_读32(偏移 + 24)]
}

函数 输入控_获取向量(全局中断号) {
    如果 (全局中断号 >= 最大全局中断 || 路由表 == 0) { 返回 0 }
    返回 内存_读32(路由表 + 全局中断号 * 28)
}

函数 输入控_获取目标核(全局中断号) {
    如果 (全局中断号 >= 最大全局中断 || 路由表 == 0) { 返回 0 }
    返回 内存_读32(路由表 + 全局中断号 * 28 + 4)
}

函数 输入控_获取触发次数(全局中断号) {
    如果 (全局中断号 >= 最大全局中断 || 路由表 == 0) { 返回 0 }
    返回 内存_读32(路由表 + 全局中断号 * 28 + 24)
}

函数 输入控_是否已配置(全局中断号) {
    如果 (全局中断号 >= 最大全局中断 || 路由表 == 0) { 返回 假 }
    返回 内存_读32(路由表 + 全局中断号 * 28 + 16) != 0
}

函数 输入控_是否已屏蔽(全局中断号) {
    如果 (全局中断号 >= 最大全局中断 || 路由表 == 0) { 返回 真 }
    返回 内存_读32(路由表 + 全局中断号 * 28 + 20) != 0
}

// 按条件查询路由

函数 输入控_按CPU查询(目标核) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 最大全局中断) {
        如果 (输入控_是否已配置(i) == 真 && 输入控_获取目标核(i) == 目标核) {
            追加(结果, i)
        }
        i = i + 1
    }
    返回 结果
}

函数 输入控_按向量查询(向量号) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 最大全局中断) {
        如果 (输入控_是否已配置(i) == 真 && 输入控_获取向量(i) == 向量号) {
            追加(结果, i)
        }
        i = i + 1
    }
    返回 结果
}

函数 输入控_已配置列表() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 最大全局中断) {
        如果 (输入控_是否已配置(i) == 真) {
            追加(结果, i)
        }
        i = i + 1
    }
    返回 结果
}

函数 输入控_已屏蔽列表() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 最大全局中断) {
        如果 (输入控_是否已配置(i) == 真 && 输入控_是否已屏蔽(i) == 真) {
            追加(结果, i)
        }
        i = i + 1
    }
    返回 结果
}

// AI中断负载分析

函数 输入控_AI_最热GSI(前N) {
    定义 可变 结果 = []
    定义 可变 n = 0
    当 (n < 前N) {
        定义 可变 最大触发 = 0
        定义 可变 最大GSI = 0 - 1
        定义 可变 i = 0
        当 (i < 最大全局中断) {
            如果 (输入控_是否已配置(i) == 真) {
                定义 触发 = 输入控_获取触发次数(i)
                如果 (触发 > 最大触发) {
                    定义 可变 已有 = 假
                    定义 可变 j = 0
                    当 (j < 计数(结果)) {
                        如果 (结果[j][0] == i) { 已有 = 真 }
                        j = j + 1
                    }
                    如果 (已有 == 假) { 最大触发 = 触发; 最大GSI = i }
                }
            }
            i = i + 1
        }
        如果 (最大GSI >= 0 && 最大触发 > 0) {
            追加(结果, [最大GSI, 最大触发, 输入控_获取目标核(最大GSI)])
        }
        n = n + 1
    }
    返回 结果
}

函数 输入控_AI_CPU偏斜检测() {
    // 检测中断是否偏斜到少数CPU
    定义 可变 CPU触发 = []
    定义 可变 c = 0
    当 (c < 16) { 追加(CPU触发, 0); c = c + 1 }
    定义 可变 i = 0
    当 (i < 最大全局中断) {
        如果 (输入控_是否已配置(i) == 真) {
            定义 cpu = 输入控_获取目标核(i)
            定义 触发 = 输入控_获取触发次数(i)
            如果 (cpu < 16) {
                设置(CPU触发, cpu, CPU触发[cpu] + 触发)
            }
        }
        i = i + 1
    }
    // 计算标准差/均值来检测偏斜
    定义 可变 总计 = 0
    定义 可变 活跃CPU = 0
    c = 0
    当 (c < 16) {
        如果 (CPU触发[c] > 0) { 总计 = 总计 + CPU触发[c]; 活跃CPU = 活跃CPU + 1 }
        c = c + 1
    }
    如果 (活跃CPU <= 1) { 返回 0 }
    定义 均值 = 总计 / 活跃CPU
    定义 可变 偏差平方和 = 0
    c = 0
    当 (c < 16) {
        如果 (CPU触发[c] > 0) {
            定义 差 = CPU触发[c] - 均值
            偏差平方和 = 偏差平方和 + 差 * 差
        }
        c = c + 1
    }
    // 返回变异系数(越大越偏斜)
    如果 (均值 == 0) { 返回 0 }
    返回 偏差平方和 / (活跃CPU * 均值)
}

// /proc/interrupts风格输出

函数 输入控_打印路由表() {
    打印("       CPU0      向量  触发    极性    名称")
    定义 可变 i = 0
    当 (i < 最大全局中断) {
        如果 (输入控_是否已配置(i) == 真) {
            定义 触发 = 输入控_获取触发次数(i)
            定义 向量 = 输入控_获取向量(i)
            定义 偏移 = 路由表 + i * 28
            定义 触发模式 = 内存_读32(偏移 + 8)
            定义 极性值 = 内存_读32(偏移 + 12)
            定义 可变 行 = "GSI" + 转字符串(i) + ":  "
            行 = 行 + 转字符串(触发) + "  "
            行 = 行 + "v" + 转字符串(向量) + "  "
            行 = 行 + 输入控_触发模式名(触发模式) + "  "
            行 = 行 + 输入控_极性名(极性值)
            如果 (输入控_是否已屏蔽(i) == 真) { 行 = 行 + " [屏蔽]" }
            打印(行)
        }
        i = i + 1
    }
}

函数 输入控_打印控制器信息() {
    打印("[输入控制器] ──────────────────")
    定义 可变 i = 0
    当 (i < 控制器数) {
        定义 控 = 控制器表[i]
        打印("  [" + 转字符串(i) + "] 基址=0x" + 转字符串(控.基地址) +
             " ID=" + 转字符串(控.标识) + " 版本=" + 转字符串(控.版本) +
             " 重定向=" + 转字符串(控.重定向数) +
             " GSI=" + 转字符串(控.中断起始) + "-" + 转字符串(控.中断结束))
        i = i + 1
    }
    打印("[输入控制器] ──────────────────")
}

// 完整统计 (≥15个指标)

函数 输入控_完整统计() {
    定义 可变 已屏蔽数 = 计数(输入控_已屏蔽列表())
    定义 可变 电平数 = 0
    定义 可变 总触发 = 0
    定义 可变 最热GSI = 0
    定义 可变 最热触发 = 0
    定义 可变 i = 0
    当 (i < 最大全局中断) {
        如果 (输入控_是否已配置(i) == 真) {
            定义 偏移 = 路由表 + i * 28
            如果 (内存_读32(偏移 + 8) == 触发_电平) { 电平数 = 电平数 + 1 }
            定义 触发 = 内存_读32(偏移 + 24)
            总触发 = 总触发 + 触发
            如果 (触发 > 最热触发) { 最热触发 = 触发; 最热GSI = i }
        }
        i = i + 1
    }
    定义 统计 = 字典()
    字典设(统计, "已初始化", 打印_已初始化)
    字典设(统计, "控制器数", 控制器数)
    字典设(统计, "已配置数", 已配置数)
    字典设(统计, "已屏蔽数", 已屏蔽数)
    字典设(统计, "电平触发数", 电平数)
    字典设(统计, "总路由次数", 总路由次数)
    字典设(统计, "总触发次数", 总触发)
    字典设(统计, "最热GSI", 最热GSI)
    字典设(统计, "最热触发", 最热触发)
    字典设(统计, "屏蔽操作", 打印_屏蔽次数)
    字典设(统计, "解屏蔽操作", 打印_解屏蔽次数)
    字典设(统计, "亲和设置", 打印_亲和设置次数)
    字典设(统计, "CPU偏斜度", 输入控_AI_CPU偏斜检测())
    字典设(统计, "最大全局中断", 最大全局中断)
    字典设(统计, "错误数", 打印_错误数)
    返回 统计
}

函数 输入控_打印完整统计() {
    定义 统计 = 输入控_完整统计()
    打印("[输入控] ═══════ 完整统计 ═══════")
    打印("  控制器数:     " + 转字符串(字典取(统计, "控制器数")))
    打印("  已配置:       " + 转字符串(字典取(统计, "已配置数")))
    打印("  已屏蔽:       " + 转字符串(字典取(统计, "已屏蔽数")))
    打印("  电平触发:     " + 转字符串(字典取(统计, "电平触发数")))
    打印("  总路由操作:   " + 转字符串(字典取(统计, "总路由次数")))
    打印("  总触发:       " + 转字符串(字典取(统计, "总触发次数")))
    打印("  最热GSI:      " + 转字符串(字典取(统计, "最热GSI")))
    打印("  最热触发:     " + 转字符串(字典取(统计, "最热触发")))
    打印("  CPU偏斜度:    " + 转字符串(字典取(统计, "CPU偏斜度")))
    打印("  屏蔽操作:     " + 转字符串(字典取(统计, "屏蔽操作")))
    打印("  解屏蔽操作:   " + 转字符串(字典取(统计, "解屏蔽操作")))
    打印("  亲和设置:     " + 转字符串(字典取(统计, "亲和设置")))
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    // 热GSI
    定义 热表 = 输入控_AI_最热GSI(5)
    如果 (计数(热表) > 0) {
        打印("  ── 最热GSI ──")
        定义 可变 h = 0
        当 (h < 计数(热表)) {
            打印("  GSI" + 转字符串(热表[h][0]) + ": " + 转字符串(热表[h][1]) + "次 CPU" + 转字符串(热表[h][2]))
            h = h + 1
        }
    }
    打印("[输入控] ═════════════════════════")
    返回 0
}

// dump

函数 输入控_dump() {
    打印("[输入控 dump] ──────────────────")
    打印("  已初始化: " + 转字符串(打印_已初始化))
    打印("  控制器数: " + 转字符串(控制器数))
    打印("  已配置: " + 转字符串(已配置数))
    打印("  总路由: " + 转字符串(总路由次数))
    输入控_打印控制器信息()
    输入控_打印路由表()
    打印("[输入控 dump] ──────────────────")
}

// 销毁

函数 输入控_销毁() {
    如果 (打印_已初始化 == 假) { 返回 0 }
    控制器表 = []
    控制器数 = 0
    路由表 = 0
    已配置数 = 0
    打印_已初始化 = 假
    打印("[输入控] 已销毁")
    返回 0
}

// 与其他子系统的接口

函数 输入控_为调度器提供中断负载() {
    返回 输入控_AI_最热GSI(5)
}

函数 输入控_为AI提供偏斜信息() {
    返回 [输入控_AI_CPU偏斜检测(), 输入控_AI_最热GSI(3)]
}

函数 输入控_为procfs提供统计() {
    返回 [控制器数, 已配置数, 总路由次数, 最大全局中断]
}

函数 输入控_为电源管理挂起() {
    打印("[输入控] 挂起: 保存终端状态")
    返回 输入控_总写入数
}

函数 输入控_重置统计() {
    总路由次数 = 0
    打印_屏蔽次数 = 0
    打印_解屏蔽次数 = 0
    打印_亲和设置次数 = 0
    打印_错误数 = 0
    // 重置每GSI触发计数
    如果 (路由表 != 0) {
        定义 可变 i = 0
        当 (i < 最大全局中断) {
            内存_写32(路由表 + i * 28 + 24, 0)
            i = i + 1
        }
    }
    打印("[输入控] 统计已重置")
    返回 0
}

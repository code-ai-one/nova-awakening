// br_table: 目标列表 + 默认目标
函数 wasm_编码_跳转表(目标列表, 默认目标) { 定义 可变 结果 = [0x0E]
 定义 数量enc = wasm_编码_uleb128(计数(目标列表))
 定义 可变 i = 0
 当 (i < 计数(数量enc)) { 追加(结果, 数量enc[i]) i = i + 1 }
 i = 0
 当 (i < 计数(目标列表)) { 定义 t = wasm_编码_uleb128(目标列表[i])
 定义 可变 j = 0
 当 (j < 计数(t)) { 追加(结果, t[j]) j = j + 1 }
 i = i + 1
 }
 定义 默认enc = wasm_编码_uleb128(默认目标)
 i = 0
 当 (i < 计数(默认enc)) { 追加(结果, 默认enc[i]) i = i + 1 }
 返回 结果
}

// call_indirect: 类型索引 + 表索引(通常0)
函数 wasm_编码_间接调用(类型索引, 表索引) { 定义 可变 结果 = [0x11]
 定义 ty = wasm_编码_uleb128(类型索引)
 定义 可变 i = 0
 当 (i < 计数(ty)) { 追加(结果, ty[i]) i = i + 1 }
 定义 tb = wasm_编码_uleb128(表索引)
 i = 0
 当 (i < 计数(tb)) { 追加(结果, tb[i]) i = i + 1 }
 返回 结果
}


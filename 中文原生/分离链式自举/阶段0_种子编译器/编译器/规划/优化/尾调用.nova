导入("../../../标准库/基础.nova")


// 尾调用类型
// 非尾调用
// 尾递归 (调自己)
// 尾调用 (调别人)
定义 尾调_互递归     = 3   // 互递归尾调用

// 尾位置判断
// 一个表达式处于尾位置: 它是函数最后一条返回语句的值
// 回: 1=尾位置, 0=非尾位置
函数 在尾位置(_语句类型, 是最后, 在返回中) {
    如果 (在返回中 == 1) {
        如果 (是最后 == 1) { 返回 1 }
    }
    返回 0
}

// 检测尾调用
// 输入: 函数名ID, 被调用函数ID, 是否在尾位置
函数 检测尾调用(当前函数, 被调函数, 尾位置) {
    如果 (尾位置 == 0) { 返回 尾调_无 }
    如果 (当前函数 == 被调函数) { 返回 尾调_自递归 }
    返回 尾调_其他
}

// 尾递归→循环转换信息
// [原函数ID, 参数数, 可转换, 递归次数]
函数 尾递归信息(函数ID, 参数数) {
    返回 [函数ID, 参数数,]
}

函数 尾递归_标记可转(信息) { 信息[2] = 1 }
函数 尾递归_增计数(信息) { 信息[3] = 信息[3] + 1 }
函数 尾递归_可转换(信息) { 返回 信息[2] }
函数 尾递归_次数(信息) { 返回 信息[3] }

// 分析函数体
// 简化: 检查一组语句的最后一条是否为尾调用
// 输入: 语句类型列表, 最后语句的调用目标
函数 分析尾部(语句列表, 当前函数, 最后调用目标) {
    定义 长 = 计数(语句列表)
    如果 (长 == 0) { 返回 尾调_无 }
    定义 最后 = 语句列表[长 - 1]
    // 最后语句是return+call
    如果 (最后 == 3) {  // return
        如果 (最后调用目标 > 0) {
            如果 (最后调用目标 == 当前函数) { 返回 尾调_自递归 }
            返回 尾调_其他
        }
    }
    返回 尾调_无
}

// TCO统计
函数 TCO统计_创建() {
    返回 [0,]  // [尾递归数, 尾调用数, 优化节省]
}

函数 TCO_添加递归(stats) { stats[0] = stats[0] + 1 }
函数 TCO_添加调用(stats) { stats[1] = stats[1] + 1 }
函数 TCO_尾递归数(stats) { 返回 stats[0] }
函数 TCO_尾调用数(stats) { 返回 stats[1] }

// 栈帧节省估算
// 每个尾递归转循环节省一个栈帧
函数 栈帧节省(尾递归数, 平均调用深度) {
    返回 尾递归数 * 平均调用深度 * 8  // 每帧约8字节
}

// 是否安全做TCO
// 不安全: 有try/catch包裹, 有闭包捕获局部变量
函数 TCO安全(有异常处理, 有闭包) {
    如果 (有异常处理 == 1) { 返回 0 }
    如果 (有闭包 == 1) { 返回 0 }
    返回 1
}

// 互递归检测
函数 检测互递归_规划(调用图, 函数数) {
    定义 可变 组 = []
    定义 可变 i = 0
    当 (i < 函数数) {
        定义 可变 j = i + 1
        当 (j < 函数数) {
            如果 (调用图[i][j] > 0 且 调用图[j][i] > 0) {
                追加(组, [i, j])
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 组
}

// TCO转换信息
函数 TCO转换_创建(函数ID, 参数数, 位置列表) {
    返回 [函数ID, 参数数, 位置列表,]
}

函数 TCO转换_执行(信息) {
    定义 可变 转换数 = 0
    定义 可变 i = 0
    当 (i < 计数(信息[2])) {
        转换数 = 转换数 + 1
        i = i + 1
    }
    信息[3] = 转换数
    信息[4] = 转换数 * 64
    返回 转换数
}

// 累积器模式检测
函数 检测累积器(参数变化) {
    定义 n = 计数(参数变化)
    如果 (n < 2) { 返回 0 }
    定义 可变 递减 = -1
    定义 可变 累积 = -1
    定义 可变 i = 0
    当 (i < n) {
        如果 (参数变化[i] == -1) { 递减 = i }
        如果 (参数变化[i] > 0) { 累积 = i }
        i = i + 1
    }
    返回 递减 >= 0 且 累积 >= 0
}

// 综合报告
函数 TCO报告(stats, 转换列表) {
    定义 可变 总转换 = 0
    定义 可变 总节省 = 0
    定义 可变 i = 0
    当 (i < 计数(转换列表)) {
        总转换 = 总转换 + 转换列表[i][3]
        总节省 = 总节省 + 转换列表[i][4]
        i = i + 1
    }
    返回 [TCO_尾递归数(stats), TCO_尾调用数(stats), 总转换, 总节省]
}

// 尾位置检测

函数 TCO_是尾位置(指令列表, 位置) {
    // 最后一条指令前的调用即为尾位置
    如果 (位置 >= 计数(指令列表) - 1) { 返回 假 }
    定义 下一条 = 指令列表[位置 + 1]
    // 下一条是返回指令
    如果 (下一条[0] == 0x0F) { 返回 真 }
    返回 假
}

函数 TCO_扫描尾调用(指令列表) {
    定义 可变 尾调用列表 = []
    定义 可变 i = 0
    当 (i < 计数(指令列表)) {
        定义 指令 = 指令列表[i]
        // 操作码为调用
        如果 (指令[0] == 0x10) {
            如果 (TCO_是尾位置(指令列表, i)) {
                追加(尾调用列表, [i, 指令[1], 指令[2]])
                // [位置, 目标函数, 参数数]
            }
        }
        i = i + 1
    }
    返回 尾调用列表
}

// 自递归检测

函数 TCO_是自递归(函数名, 调用目标) {
    返回 函数名 == 调用目标
}

函数 TCO_扫描自递归(函数名, 指令列表) {
    定义 可变 自递归列表 = []
    定义 尾调用 = TCO_扫描尾调用(指令列表)
    定义 可变 i = 0
    当 (i < 计数(尾调用)) {
        如果 (TCO_是自递归(函数名, 尾调用[i][1])) {
            追加(自递归列表, 尾调用[i])
        }
        i = i + 1
    }
    返回 自递归列表
}

// 尾调用转换: 递归→循环

函数 TCO_递归转循环(参数列表, _函数体长度) {
    // 生成循环头: 标签, 参数重赋值, 跳转回循环头
    定义 可变 转换指令 = []
    // 循环开始标签
    追加(转换指令, [0xF0,])  // LABEL循环头
    // 保持参数位置不变(原参数已在栈上)
    定义 可变 i = 0
    当 (i < 计数(参数列表)) {
        追加(转换指令, [0x20, i, 参数列表[i]])  // MOV 参数[i] = 新值
        i = i + 1
    }
    // 跳转回循环头
    追加(转换指令, [0xF1,])  // 跳转 循环头
    返回 转换指令
}

// 互递归检测

定义 可变 _TCO_调用图 = []

函数 TCO_记录调用(调用者, 被调用者) {
    追加(_TCO_调用图, [调用者, 被调用者])
}

函数 TCO_获取被调用(函数名) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(_TCO_调用图)) {
        如果 (_TCO_调用图[i][0] == 函数名) { 追加(结果, _TCO_调用图[i][1]) }
        i = i + 1
    }
    返回 结果
}

函数 TCO_检测互递归(函数A, 函数B) {
    定义 A调用 = TCO_获取被调用(函数A)
    定义 可变 i = 0
    当 (i < 计数(A调用)) {
        如果 (A调用[i] == 函数B) {
            定义 B调用 = TCO_获取被调用(函数B)
            定义 可变 j = 0
            当 (j < 计数(B调用)) {
                如果 (B调用[j] == 函数A) { 返回 真 }
                j = j + 1
            }
        }
        i = i + 1
    }
    返回 假
}

// 蹦床转换

函数 TCO_蹦床_包装(函数ID, 参数) {
    // 返回延迟调用对象
    返回 [1, 函数ID, 参数]  // [标记=延迟, 函数ID, 参数]
}

函数 TCO_蹦床_是延迟(值) {
    如果 (计数(值) >= 1 且 值[0] == 1) { 返回 真 }
    返回 假
}

函数 TCO_蹦床_执行(初始值, 最大轮数) {
    定义 可变 当前 = 初始值
    定义 可变 轮 = 0
    当 (TCO_蹦床_是延迟(当前) 且 轮 < 最大轮数) {
        // 模拟执行延迟调用(实际需函数表查找)
        当前 = [0, 当前[1], 当前[2]]
        轮 = 轮 + 1
    }
    返回 [当前, 轮]
}

// 栈深度分析

定义 可变 _TCO_栈深度历史 = []

函数 TCO_记录栈深度(深度) {
    定义 可变 新历史 = []
    追加(_TCO_栈深度历史, 深度)
    如果 (计数(_TCO_栈深度历史) > 1000) {
        定义 可变 i = 500
        当 (i < 计数(_TCO_栈深度历史)) { 追加(新历史, _TCO_栈深度历史[i])  i = i + 1 }
        _TCO_栈深度历史 = 新历史
    }
}

函数 TCO_最大栈深度() {
    定义 可变 最大 = 0
    定义 可变 i = 0
    当 (i < 计数(_TCO_栈深度历史)) {
        如果 (_TCO_栈深度历史[i] > 最大) { 最大 = _TCO_栈深度历史[i] }
        i = i + 1
    }
    返回 最大
}

函数 TCO_平均栈深度() {
    如果 (计数(_TCO_栈深度历史) == 0) { 返回 0 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(_TCO_栈深度历史)) { 总 = 总 + _TCO_栈深度历史[i]  i = i + 1 }
    返回 总 / 计数(_TCO_栈深度历史)
}

定义 可变 _TCO_检测次数 = 0
定义 可变 _TCO_转换次数 = 0
定义 可变 _TCO_节省帧数 = 0

函数 TCO_记录检测() { _TCO_检测次数 = _TCO_检测次数 + 1 }
函数 TCO_记录转换() { _TCO_转换次数 = _TCO_转换次数 + 1 }
函数 TCO_记录节省(帧数) { _TCO_节省帧数 = _TCO_节省帧数 + 帧数 }

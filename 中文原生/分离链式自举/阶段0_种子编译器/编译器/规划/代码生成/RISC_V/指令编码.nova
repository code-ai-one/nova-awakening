导入("../../../../标准库/基础.nova")

// 加载(阴读内存) ←→ 存储(阳写内存)
// R/I/S/B/U/J: 量词的六种编码态射

// 寄存器编号 (ABI名称)
定义 寄存器x0=0 // zero 硬件零
定义 寄存器x1=1 // ra 返回地址
定义 寄存器x2=2 // sp 栈指针
定义 寄存器x3=3 // gp 全局指针
定义 寄存器x4=4 // tp 线程指针
定义 寄存器x5=5 // t0 临时
定义 寄存器x6=6 // t1
定义 寄存器x7=7 // t2
定义 寄存器x8=8 // s0/fp 帧指针
定义 寄存器x9=9 // s1
定义 寄存器x10=10 // a0 参数/回
定义 寄存器x11=11 // a1 参数/回
定义 寄存器x12=12 // a2
定义 寄存器x13=13 // a3
定义 寄存器x14=14 // a4
定义 寄存器x15=15 // a5
定义 寄存器x16=16 // a6
定义 寄存器x17=17 // a7
定义 寄存器x18=18 // s2
定义 寄存器x19=19 // s3
定义 寄存器x20=20 // s4
定义 寄存器x31=31 // t6

// 辅助
函数 指令字节(w) { 返回 [w&0xFF,(w>>8)&0xFF,(w>>16)&0xFF,(w>>24)&0xFF] }
函数 指令编码_RV指令长度() { 返回 4 }

// R-type: funct7[31:25]|rs2[24:20]|rs1[19:15]|funct3[14:12]|rd[11:7]|opcode[6:0]
函数 指令编码_R型(f7, rs2, rs1, f3, rd, op) { 返回 ((f7&0x7F)<<25)|((rs2&31)<<20)|((rs1&31)<<15)|((f3&7)<<12)|((rd&31)<<7)|(op&0x7F)
}

// RV64I 基础整数
函数 编码_add(rd, rs1, rs2) { 返回 指令编码_R型(0x00,rs2,rs1,0,rd,0x33) }
函数 编码_sub(rd, rs1, rs2) { 返回 指令编码_R型(0x20,rs2,rs1,0,rd,0x33) }
函数 编码_and(rd, rs1, rs2) { 返回 指令编码_R型(0x00,rs2,rs1,7,rd,0x33) }
函数 编码_or(rd, rs1, rs2) { 返回 指令编码_R型(0x00,rs2,rs1,6,rd,0x33) }
函数 编码_xor(rd, rs1, rs2) { 返回 指令编码_R型(0x00,rs2,rs1,4,rd,0x33) }
函数 编码_sll(rd, rs1, rs2) { 返回 指令编码_R型(0x00,rs2,rs1,1,rd,0x33) }
函数 编码_srl(rd, rs1, rs2) { 返回 指令编码_R型(0x00,rs2,rs1,5,rd,0x33) }
函数 编码_sra(rd, rs1, rs2) { 返回 指令编码_R型(0x20,rs2,rs1,5,rd,0x33) }
函数 编码_slt(rd, rs1, rs2) { 返回 指令编码_R型(0x00,rs2,rs1,2,rd,0x33) }
函数 编码_sltu(rd, rs1, rs2) { 返回 指令编码_R型(0x00,rs2,rs1,3,rd,0x33) }

// M扩展 (乘除)
函数 编码_mul(rd, rs1, rs2) { 返回 指令编码_R型(0x01,rs2,rs1,0,rd,0x33) }
函数 编码_mulh(rd, rs1, rs2) { 返回 指令编码_R型(0x01,rs2,rs1,1,rd,0x33) }
函数 编码_div(rd, rs1, rs2) { 返回 指令编码_R型(0x01,rs2,rs1,4,rd,0x33) }
函数 编码_divu(rd, rs1, rs2) { 返回 指令编码_R型(0x01,rs2,rs1,5,rd,0x33) }
函数 编码_rem(rd, rs1, rs2) { 返回 指令编码_R型(0x01,rs2,rs1,6,rd,0x33) }
函数 编码_remu(rd, rs1, rs2) { 返回 指令编码_R型(0x01,rs2,rs1,7,rd,0x33) }

// I-type: imm[31:20]|rs1[19:15]|funct3[14:12]|rd[11:7]|opcode[6:0]
函数 指令编码_I型(imm, rs1, f3, rd, op) { 返回 ((imm&0xFFF)<<20)|((rs1&31)<<15)|((f3&7)<<12)|((rd&31)<<7)|(op&0x7F)
}

函数 编码_addi(rd, rs1, imm) { 返回 指令编码_I型(imm,rs1,0,rd,0x13) }
函数 编码_andi(rd, rs1, imm) { 返回 指令编码_I型(imm,rs1,7,rd,0x13) }
函数 编码_ori(rd, rs1, imm) { 返回 指令编码_I型(imm,rs1,6,rd,0x13) }
函数 编码_xori(rd, rs1, imm) { 返回 指令编码_I型(imm,rs1,4,rd,0x13) }
函数 编码_slti(rd, rs1, imm) { 返回 指令编码_I型(imm,rs1,2,rd,0x13) }

// 加载指令
函数 编码_lb(rd, rs1, imm) { 返回 指令编码_I型(imm,rs1,0,rd,0x03) }
函数 编码_lh(rd, rs1, imm) { 返回 指令编码_I型(imm,rs1,1,rd,0x03) }
函数 编码_lw(rd, rs1, imm) { 返回 指令编码_I型(imm,rs1,2,rd,0x03) }
函数 编码_ld(rd, rs1, imm) { 返回 指令编码_I型(imm,rs1,3,rd,0x03) }
函数 编码_lbu(rd, rs1, imm) { 返回 指令编码_I型(imm,rs1,4,rd,0x03) }

// JALR
函数 编码_jalr(rd, rs1, imm) { 返回 指令编码_I型(imm,rs1,0,rd,0x67) }

// S-type: imm[11:5]|rs2|rs1|funct3|imm[4:0]|opcode
函数 指令编码_S型(imm, rs2, rs1, f3, op) { 返回 (((imm>>5)&0x7F)<<25)|((rs2&31)<<20)|((rs1&31)<<15)|((f3&7)<<12)|(((imm)&0x1F)<<7)|(op&0x7F)
}

函数 编码_sb(rs2, rs1, imm) { 返回 指令编码_S型(imm,rs2,rs1,0,0x23) }
函数 编码_sh(rs2, rs1, imm) { 返回 指令编码_S型(imm,rs2,rs1,1,0x23) }
函数 编码_sw(rs2, rs1, imm) { 返回 指令编码_S型(imm,rs2,rs1,2,0x23) }
函数 编码_sd(rs2, rs1, imm) { 返回 指令编码_S型(imm,rs2,rs1,3,0x23) }

// B-type: imm[12|10:5]|rs2|rs1|funct3|imm[4:1|11]|opcode
函数 指令编码_B型(imm, rs2, rs1, f3, op) { 定义 b12 = (imm >> 12) & 1
 定义 b11 = (imm >> 11) & 1
 定义 b10_5= (imm >> 5) & 0x3F
 定义 b4_1 = (imm >> 1) & 0xF
 返回 (b12<<31)|(b10_5<<25)|((rs2&31)<<20)|((rs1&31)<<15)|((f3&7)<<12)|(b4_1<<8)|(b11<<7)|(op&0x7F)
}

函数 编码_beq(rs1, rs2, imm) { 返回 指令编码_B型(imm,rs2,rs1,0,0x63) }
函数 编码_bne(rs1, rs2, imm) { 返回 指令编码_B型(imm,rs2,rs1,1,0x63) }
函数 编码_blt(rs1, rs2, imm) { 返回 指令编码_B型(imm,rs2,rs1,4,0x63) }
函数 编码_bge(rs1, rs2, imm) { 返回 指令编码_B型(imm,rs2,rs1,5,0x63) }

// U-type: imm[31:12]|rd[11:7]|opcode[6:0]
函数 编码_lui(rd, imm20) { 返回 ((imm20&0xFFFFF)<<12)|((rd&31)<<7)|0x37 }
函数 编码_auipc(rd, imm20) { 返回 ((imm20&0xFFFFF)<<12)|((rd&31)<<7)|0x17 }

// J-type: JAL rd, offset
// imm[20|10:1|11|19:12]|rd|opcode
函数 编码_jal(rd, 偏移) { 定义 b20 = (偏移 >> 20) & 1
 定义 b10_1 = (偏移 >> 1) & 0x3FF
 定义 b11 = (偏移 >> 11) & 1
 定义 b19_12= (偏移 >> 12) & 0xFF
 返回 (b20<<31)|(b10_1<<21)|(b11<<20)|(b19_12<<12)|((rd&31)<<7)|0x6F
}

// 系统指令
函数 编码_ecall() { 返回 0x00000073 }
函数 编码_ebreak() { 返回 0x00100073 }
函数 riscv_编码_nop() { 返回 编码_addi(0, 0, 0) }

// 伪指令
函数 编码_mv(rd, rs1) { 返回 编码_addi(rd, rs1, 0) }
函数 编码_li(rd, imm) { 返回 编码_addi(rd,0,imm) }
函数 编码_ret_rv() { 返回 编码_jalr(0, 1, 0) }
函数 编码_call_rv(rd, 偏移) { 返回 编码_jal(rd,偏移) }
函数 编码_j(偏移) { 返回 编码_jal(0,偏移) }
函数 编码_beqz(rs1, imm) { 返回 编码_beq(rs1,0,imm) }
函数 编码_bnez(rs1, imm) { 返回 编码_bne(rs1,0,imm) }

// RV64 字宽指令 (32位操作, opcode=0x3B)
函数 编码_addw(rd, rs1, rs2) { 返回 指令编码_R型(0x00,rs2,rs1,0,rd,0x3B) }
函数 编码_subw(rd, rs1, rs2) { 返回 指令编码_R型(0x20,rs2,rs1,0,rd,0x3B) }
函数 编码_mulw(rd, rs1, rs2) { 返回 指令编码_R型(0x01,rs2,rs1,0,rd,0x3B) }
函数 编码_divw(rd, rs1, rs2) { 返回 指令编码_R型(0x01,rs2,rs1,4,rd,0x3B) }
函数 编码_remw(rd, rs1, rs2) { 返回 指令编码_R型(0x01,rs2,rs1,6,rd,0x3B) }
函数 编码_sllw(rd, rs1, rs2) { 返回 指令编码_R型(0x00,rs2,rs1,1,rd,0x3B) }
函数 编码_srlw(rd, rs1, rs2) { 返回 指令编码_R型(0x00,rs2,rs1,5,rd,0x3B) }
函数 编码_sraw(rd, rs1, rs2) { 返回 指令编码_R型(0x20,rs2,rs1,5,rd,0x3B) }
函数 编码_addiw(rd, rs1, imm){ 返回 指令编码_I型(imm,rs1,0,rd,0x1B) }

// 立即数移位 (I型特殊: shamt在imm[5:0])
函数 编码_slli(rd, rs1, shamt) { 返回 指令编码_I型(shamt&0x3F,rs1,1,rd,0x13) }
函数 编码_srli(rd, rs1, shamt) { 返回 指令编码_I型(shamt&0x3F,rs1,5,rd,0x13) }
函数 编码_srai(rd, rs1, shamt) { 返回 指令编码_I型((0x400|(shamt&0x3F)),rs1,5,rd,0x13) }

// FENCE / CSR
函数 编码_fence(pred, succ) { 返回 0x0000000F|((pred&0xF)<<24)|((succ&0xF)<<20) }
函数 编码_fence_tso() { 返回 0x8330000F }
// CSR读写
函数 编码_csrrw(rd, rs1, csr) { 返回 ((csr&0xFFF)<<20)|((rs1&31)<<15)|(1<<12)|((rd&31)<<7)|0x73 }
函数 编码_csrrs(rd, rs1, csr) { 返回 ((csr&0xFFF)<<20)|((rs1&31)<<15)|(2<<12)|((rd&31)<<7)|0x73 }
函数 编码_csrrc(rd, rs1, csr) { 返回 ((csr&0xFFF)<<20)|((rs1&31)<<15)|(3<<12)|((rd&31)<<7)|0x73 }
// 伪指令: 读CSR
函数 编码_csrr(rd, csr) { 返回 编码_csrrs(rd,0,csr) }
// 常用CSR地址

// 更多伪指令
函数 编码_not(rd, rs1) { 返回 编码_xori(rd,rs1,0-1) }
函数 编码_neg_rv(rd, rs1) { 返回 编码_sub(rd,0,rs1) }
函数 编码_seqz(rd, rs1) { 返回 编码_slti(rd,rs1,1) }

// 无符号分支 + 更多分支
函数 编码_bltu(rs1, rs2, imm) { 返回 指令编码_B型(imm,rs2,rs1,6,0x63) }
函数 编码_bgeu(rs1, rs2, imm) { 返回 指令编码_B型(imm,rs2,rs1,7,0x63) }
// 伪指令: BGT/BLE
函数 编码_bgt(rs1, rs2, imm) { 返回 编码_blt(rs2,rs1,imm) }
函数 编码_ble(rs1, rs2, imm) { 返回 编码_bge(rs2,rs1,imm) }
函数 编码_bltz(rs1, imm) { 返回 编码_blt(rs1,0,imm) }
函数 编码_bgez(rs1, imm) { 返回 编码_bge(rs1,0,imm) }

// 更多加载指令 (半字无符号/字无符号)
函数 编码_lhu(rd, rs1, imm) { 返回 指令编码_I型(imm,rs1,5,rd,0x03) }
函数 编码_lwu(rd, rs1, imm) { 返回 指令编码_I型(imm,rs1,6,rd,0x03) }
// SLTIU
函数 编码_sltiu(rd, rs1, imm) { 返回 指令编码_I型(imm,rs1,3,rd,0x13) }
// SNEZ rd,rs = SLTU rd,x0,rs
函数 编码_snez(rd, rs1) { 返回 编码_sltu(rd,0,rs1) }

// RV64F — 单精度浮点 (opcode=0x53, funct7高位=0x00/0x08/...)

// R4-type 辅助 (浮点乘加用)
函数 指令编码_R4型(rs3, f2, rs2, rs1, f3, rd, op) { 返回 ((rs3&31)<<27)|((f2&3)<<25)|((rs2&31)<<20)|((rs1&31)<<15)|((f3&7)<<12)|((rd&31)<<7)|(op&0x7F)
}

// FADD.S fd,fs1,fs2
函数 rv_编码_fadd_s(rd, rs1, rs2) { 返回 0x00000053|((rs2&31)<<20)|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
// FSUB.S fd,fs1,fs2
函数 rv_编码_fsub_s(rd, rs1, rs2) { 返回 0x08000053|((rs2&31)<<20)|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
// FMUL.S fd,fs1,fs2
函数 rv_编码_fmul_s(rd, rs1, rs2) { 返回 0x10000053|((rs2&31)<<20)|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
// FDIV.S fd,fs1,fs2
函数 rv_编码_fdiv_s(rd, rs1, rs2) { 返回 0x18000053|((rs2&31)<<20)|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
// FSQRT.S fd,fs1
函数 rv_编码_fsqrt_s(rd, rs1) { 返回 0x58000053|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
// FLW fd, offset(rs1) — 加载单精度
函数 编码_flw(rd, rs1, imm) { 返回 ((imm&0xFFF)<<20)|((rs1&31)<<15)|(2<<12)|((rd&31)<<7)|0x07 }
// FSW fs2, offset(rs1) — 存储单精度
函数 编码_fsw(rs2, rs1, imm) { 返回 (((imm>>5)&0x7F)<<25)|((rs2&31)<<20)|((rs1&31)<<15)|(2<<12)|((imm&0x1F)<<7)|0x27 }
// FMADD.S fd,fs1,fs2,fs3
函数 rv_编码_fmadd_s(rd, rs1, rs2, rs3) { 返回 指令编码_R4型(rs3,0,rs2,rs1,7,rd,0x43) }
// FMSUB.S fd,fs1,fs2,fs3
函数 rv_编码_fmsub_s(rd, rs1, rs2, rs3) { 返回 指令编码_R4型(rs3,0,rs2,rs1,7,rd,0x47) }
// FEQ.S rd,fs1,fs2 — 浮点相等比较(结果→整数rd)
函数 编码_feq_s(rd, rs1, rs2) { 返回 0xA0000053|((rs2&31)<<20)|((rs1&31)<<15)|(2<<12)|((rd&31)<<7) }
// FLT.S rd,fs1,fs2 — 浮点小于比较
函数 编码_flt_s(rd, rs1, rs2) { 返回 0xA0000053|((rs2&31)<<20)|((rs1&31)<<15)|(1<<12)|((rd&31)<<7) }
// FLE.S rd,fs1,fs2 — 浮点小于等于比较
函数 编码_fle_s(rd, rs1, rs2) { 返回 0xA0000053|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7) }
// FCVT.W.S rd,fs1 — 单精度→有符号32位整数
函数 编码_fcvt_w_s(rd, rs1) { 返回 0xC0000053|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
// FCVT.S.W fd,rs1 — 有符号32位整数→单精度
函数 编码_fcvt_s_w(rd, rs1) { 返回 0xD0000053|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
// FCVT.L.S rd,fs1 — 单精度→有符号64位整数(RV64)
函数 编码_fcvt_l_s(rd, rs1) { 返回 0xC0200053|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
// FCVT.S.L fd,rs1 — 有符号64位整数→单精度(RV64)
函数 编码_fcvt_s_l(rd, rs1) { 返回 0xD0200053|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
// FMV.X.W rd,fs1 — 浮点位模式→整数
函数 编码_fmv_x_w(rd, rs1) { 返回 0xE0000053|((rs1&31)<<15)|((rd&31)<<7) }
// FMV.W.X fd,rs1 — 整数→浮点位模式
函数 编码_fmv_w_x(rd, rs1) { 返回 0xF0000053|((rs1&31)<<15)|((rd&31)<<7) }
// FMIN.S / FMAX.S
函数 编码_fmin_s(rd, rs1, rs2) { 返回 0x28000053|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7) }
函数 编码_fmax_s(rd, rs1, rs2) { 返回 0x28000053|((rs2&31)<<20)|((rs1&31)<<15)|(1<<12)|((rd&31)<<7) }
// FSGNJ.S (符号注入) / FSGNJN.S / FSGNJX.S
函数 编码_fsgnj_s(rd, rs1, rs2) { 返回 0x20000053|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7) }
函数 编码_fsgnjn_s(rd, rs1, rs2) { 返回 0x20000053|((rs2&31)<<20)|((rs1&31)<<15)|(1<<12)|((rd&31)<<7) }
// 伪指令: FMV.S fd,fs1 = FSGNJ.S fd,fs1,fs1
函数 编码_fmv_s(rd, rs1) { 返回 编码_fsgnj_s(rd,rs1,rs1) }
// 伪指令: FNEG.S fd,fs1 = FSGNJN.S fd,fs1,fs1
函数 rv_编码_fneg_s(rd, rs1) { 返回 编码_fsgnjn_s(rd,rs1,rs1) }

// RV64D — 双精度浮点

函数 编码_fadd_d(rd, rs1, rs2) { 返回 0x02000053|((rs2&31)<<20)|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
函数 编码_fsub_d(rd, rs1, rs2) { 返回 0x0A000053|((rs2&31)<<20)|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
函数 编码_fmul_d(rd, rs1, rs2) { 返回 0x12000053|((rs2&31)<<20)|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
函数 编码_fdiv_d(rd, rs1, rs2) { 返回 0x1A000053|((rs2&31)<<20)|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
函数 rv_编码_fsqrt_d(rd, rs1) { 返回 0x5A000053|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
// FLD fd, offset(rs1) — 加载双精度
函数 编码_fld(rd, rs1, imm) { 返回 ((imm&0xFFF)<<20)|((rs1&31)<<15)|(3<<12)|((rd&31)<<7)|0x07 }
// FSD fs2, offset(rs1) — 存储双精度
函数 编码_fsd(rs2, rs1, imm) { 返回 (((imm>>5)&0x7F)<<25)|((rs2&31)<<20)|((rs1&31)<<15)|(3<<12)|((imm&0x1F)<<7)|0x27 }
// FMADD.D / FMSUB.D
函数 rv_编码_fmadd_d(rd, rs1, rs2, rs3) { 返回 指令编码_R4型(rs3,1,rs2,rs1,7,rd,0x43) }
函数 rv_编码_fmsub_d(rd, rs1, rs2, rs3) { 返回 指令编码_R4型(rs3,1,rs2,rs1,7,rd,0x47) }
// 双精度比较
函数 编码_feq_d(rd, rs1, rs2) { 返回 0xA2000053|((rs2&31)<<20)|((rs1&31)<<15)|(2<<12)|((rd&31)<<7) }
函数 编码_flt_d(rd, rs1, rs2) { 返回 0xA2000053|((rs2&31)<<20)|((rs1&31)<<15)|(1<<12)|((rd&31)<<7) }
函数 编码_fle_d(rd, rs1, rs2) { 返回 0xA2000053|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7) }
// FCVT.D.S / FCVT.S.D — 精度转换
函数 编码_fcvt_d_s(rd, rs1) { 返回 0x42000053|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
函数 编码_fcvt_s_d(rd, rs1) { 返回 0x40100053|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
// FCVT.L.D rd,fs1 — 双精度→有符号64位
函数 编码_fcvt_l_d(rd, rs1) { 返回 0xC2200053|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
// FCVT.D.L fd,rs1 — 有符号64位→双精度
函数 编码_fcvt_d_l(rd, rs1) { 返回 0xD2200053|((rs1&31)<<15)|(7<<12)|((rd&31)<<7) }
// FMV.X.D / FMV.D.X (RV64)
函数 编码_fmv_x_d(rd, rs1) { 返回 0xE2000053|((rs1&31)<<15)|((rd&31)<<7) }
函数 编码_fmv_d_x(rd, rs1) { 返回 0xF2000053|((rs1&31)<<15)|((rd&31)<<7) }
// FMIN.D / FMAX.D
函数 编码_fmin_d(rd, rs1, rs2) { 返回 0x2A000053|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7) }
函数 编码_fmax_d(rd, rs1, rs2) { 返回 0x2A000053|((rs2&31)<<20)|((rs1&31)<<15)|(1<<12)|((rd&31)<<7) }

// A扩展 — 原子操作 (opcode=0x2F, funct3=3 for 64-bit)

// LR.D rd, (rs1) — 加载保留(双字)
函数 编码_lr_d(rd, rs1) { 返回 0x10003000|((rs1&31)<<15)|((rd&31)<<7)|0x2F }
// SC.D rd, rs2, (rs1) — 条件存储(双字)
函数 编码_sc_d(rd, rs2, rs1) { 返回 0x18003000|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7)|0x2F }
// AMOSWAP.D rd, rs2, (rs1) — 原子交换
函数 编码_amoswap_d(rd, rs2, rs1) { 返回 0x08003000|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7)|0x2F }
// AMOADD.D rd, rs2, (rs1) — 原子加
函数 编码_amoadd_d(rd, rs2, rs1) { 返回 0x00003000|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7)|0x2F }
// AMOAND.D rd, rs2, (rs1) — 原子与
函数 编码_amoand_d(rd, rs2, rs1) { 返回 0x60003000|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7)|0x2F }
// AMOOR.D rd, rs2, (rs1) — 原子或
函数 编码_amoor_d(rd, rs2, rs1) { 返回 0x40003000|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7)|0x2F }
// AMOXOR.D rd, rs2, (rs1) — 原子异或
函数 编码_amoxor_d(rd, rs2, rs1) { 返回 0x20003000|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7)|0x2F }
// AMOMIN.D / AMOMAX.D
函数 编码_amomin_d(rd, rs2, rs1) { 返回 0x80003000|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7)|0x2F }
函数 编码_amomax_d(rd, rs2, rs1) { 返回 0xA0003000|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7)|0x2F }

// 32位原子 (funct3=2)
函数 编码_lr_w(rd, rs1) { 返回 0x10002000|((rs1&31)<<15)|((rd&31)<<7)|0x2F }
函数 编码_sc_w(rd, rs2, rs1) { 返回 0x18002000|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7)|0x2F }
函数 编码_amoadd_w(rd, rs2, rs1) { 返回 0x00002000|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7)|0x2F }
函数 编码_amoswap_w(rd, rs2, rs1) { 返回 0x08002000|((rs2&31)<<20)|((rs1&31)<<15)|((rd&31)<<7)|0x2F }

// 更多伪指令/便利函数

// MULHSU rd,rs1,rs2 — 有符号×无符号高位
函数 编码_mulhsu(rd, rs1, rs2) { 返回 指令编码_R型(0x01,rs2,rs1,2,rd,0x33) }
// MULHU rd,rs1,rs2 — 无符号×无符号高位
函数 编码_mulhu(rd, rs1, rs2) { 返回 指令编码_R型(0x01,rs2,rs1,3,rd,0x33) }
// DIVUW / REMUW (RV64M)
函数 编码_divuw(rd, rs1, rs2) { 返回 指令编码_R型(0x01,rs2,rs1,5,rd,0x3B) }
函数 编码_remuw(rd, rs1, rs2) { 返回 指令编码_R型(0x01,rs2,rs1,7,rd,0x3B) }

// 立即数CSR操作
函数 编码_csrrwi(rd, uimm, csr) { 返回 ((csr&0xFFF)<<20)|((uimm&31)<<15)|(5<<12)|((rd&31)<<7)|0x73 }
函数 编码_csrrsi(rd, uimm, csr) { 返回 ((csr&0xFFF)<<20)|((uimm&31)<<15)|(6<<12)|((rd&31)<<7)|0x73 }
函数 编码_csrrci(rd, uimm, csr) { 返回 ((csr&0xFFF)<<20)|((uimm&31)<<15)|(7<<12)|((rd&31)<<7)|0x73 }

// 更多CSR寄存器地址
定义 CSR_指令集架构 = 0x301
定义 CSR_机器中断使能 = 0x304
定义 CSR_机器陷阱值 = 0x343
定义 CSR_机器中断挂起 = 0x344
定义 CSR_监督状态 = 0x100
定义 CSR_监督中断使能 = 0x104
定义 CSR_监督陷阱向量 = 0x105
定义 CSR_监督异常PC = 0x141
定义 CSR_监督原因 = 0x142

// 完整栈帧序言 — 保存ra和fp, 分配帧空间
函数 指令编码_rv序言(帧大小) { 定义 可变 指令 = []
 指令 = 追加(指令, 编码_addi(x2, x2, 0 - 帧大小)) // sp -= 帧大小
 指令 = 追加(指令, 编码_sd(x1, x2, 帧大小 - 8)) // sd ra, (帧大小-8)(sp)
 指令 = 追加(指令, 编码_sd(x8, x2, 帧大小 - 16)) // sd s0, (帧大小-16)(sp)
 指令 = 追加(指令, 编码_addi(x8, x2, 帧大小)) // s0 = sp + 帧大小
 返回 指令
}

// 完整栈帧尾声
函数 指令编码_rv尾声(帧大小) { 定义 可变 指令 = []
 指令 = 追加(指令, 编码_ld(x1, x2, 帧大小 - 8)) // ld ra, (帧大小-8)(sp)
 指令 = 追加(指令, 编码_ld(x8, x2, 帧大小 - 16)) // ld s0, (帧大小-16)(sp)
 指令 = 追加(指令, 编码_addi(x2, x2, 帧大小)) // sp += 帧大小
 指令 = 追加(指令, 编码_ret_rv()) // ret
 返回 指令
}

// 加载32位立即数: LUI + ADDI
函数 指令编码_rv加载32(rd, val) { 定义 hi = (val + 0x800) >> 12
 定义 lo = val - (hi << 12)
 定义 可变 指令 = []
 指令 = 追加(指令, 编码_lui(rd, hi & 0xFFFFF))
 指令 = 追加(指令, 编码_addi(rd, rd, lo & 0xFFF))
 返回 指令
}

// TAIL 伪指令: 尾调用(不保存返回地址)
函数 编码_tail(偏移) { 返回 编码_jal(0, 偏移) }
// 调用 伪指令: AUIPC + JALR
函数 编码_call_far(rd, hi20, lo12) { 定义 可变 指令 = []
 指令 = 追加(指令, 编码_auipc(rd, hi20))
 指令 = 追加(指令, 编码_jalr(x1, rd, lo12))
 返回 指令
}

// WFI — 等待中断
函数 rv_编码_wfi() { 返回 0x10500073 }
// MRET — 机器模式返回
函数 编码_mret() { 返回 0x30200073 }
// SRET — 监督模式返回
函数 编码_sret() { 返回 0x10200073 }
// SFENCE.VMA rs1,rs2 — 虚拟内存屏障
函数 编码_sfence_vma(rs1, rs2) { 返回 0x12000073|((rs2&31)<<20)|((rs1&31)<<15) }


// Nova · 运行时 · 音频原语 · 混音器
// 职责: 多轨混音、ADSR包络、声道管理
// 层级: M13 — 音频/媒体增强

// 采样率/位深常量

导入("../../标准库/基础.nova")

定义 采样率_44100 = 44100
定义 采样率_48000 = 48000
定义 位深_16 = 16
定义 位深_24 = 24

// ADSR包络阶段
定义 ADSR_空闲    = 0
定义 ADSR_起音    = 1  // Attack
定义 ADSR_衰减    = 2  // Decay
定义 ADSR_持续    = 3  // Sustain
定义 ADSR_释放    = 4  // Release

// ADSR包络: [阶段, 起音ms, 衰减ms, 持续级, 释放ms, 当前值, 采样位置]
函数 ADSR_创建(起音ms, 衰减ms, 持续级, 释放ms) {
    定义 可变 e = []
    追加(e, 0)       // [0]=阶段(空闲)
    追加(e, 起音ms)   // [1]=起音ms
    追加(e, 衰减ms)   // [2]=衰减ms
    追加(e, 持续级)   // [3]=持续级
    追加(e, 释放ms)   // [4]=释放ms
    追加(e, 0)       // [5]=当前值
    追加(e, 0)       // [6]=采样位置
    返回 e
}

函数 ADSR_触发(e) { e[0] = ADSR_起音  e[5] = 0  e[6] = 0 }
函数 ADSR_释放开始(e) { e[0] = ADSR_释放 }
函数 ADSR_阶段(e) { 返回 e[0] }
函数 ADSR_值(e) { 返回 e[5] }

// 计算下一个ADSR值(每采样调用一次)
函数 ADSR_步进(e, 采样率) {
    如果 (e[0] == ADSR_空闲) { e[5] = 0  返回 0 }

    定义 起音采样 = e[1] * 采样率 / 1000
    定义 衰减采样 = e[2] * 采样率 / 1000
    定义 释放采样 = e[4] * 采样率 / 1000

    如果 (e[0] == ADSR_起音) {
        如果 (起音采样 > 0) { e[5] = e[6] * 1000 / 起音采样 }
        否则 { e[5] = 1000 }
        e[6] = e[6] + 1
        如果 (e[5] >= 1000) { e[5] = 1000  e[0] = ADSR_衰减  e[6] = 0 }
    } 否则 如果 (e[0] == ADSR_衰减) {
        如果 (衰减采样 > 0) {
            e[5] = 1000 - ((1000 - e[3]) * e[6] / 衰减采样)
        } 否则 { e[5] = e[3] }
        e[6] = e[6] + 1
        如果 (e[5] <= e[3]) { e[5] = e[3]  e[0] = ADSR_持续 }
    } 否则 如果 (e[0] == ADSR_持续) {
        e[5] = e[3]
    } 否则 如果 (e[0] == ADSR_释放) {
        如果 (释放采样 > 0) {
            e[5] = e[3] - (e[3] * e[6] / 释放采样)
        } 否则 { e[5] = 0 }
        e[6] = e[6] + 1
        如果 (e[5] <= 0) { e[5] = 0  e[0] = ADSR_空闲 }
    }
    返回 e[5]
}

// 音频轨道: [名称, 采样数据, 音量0-1000, 声像-500~+500, ADSR, 静音, 循环]
函数 音轨_创建(名称) {
    返回 [名称, [], 1000, 0, ADSR_创建(10, 50, 700, 100), 假, 假]
}

函数 音轨_名称(t) { 返回 t[0] }
函数 音轨_数据(t) { 返回 t[1] }
函数 音轨_音量(t) { 返回 t[2] }
函数 音轨_声像(t) { 返回 t[3] }
函数 音轨_ADSR(t) { 返回 t[4] }
函数 音轨_静音(t) { 返回 t[5] }

函数 音轨_设数据(t, 数据) { t[1] = 数据 }
函数 音轨_设音量(t, v) { t[2] = v }
函数 音轨_设声像(t, p) { t[3] = p }
函数 音轨_设静音(t, m) { t[5] = m }
函数 音轨_设循环(t, l) { t[6] = l }

// 混音器: [轨道列表, 主音量, 采样率, 位深, 输出缓冲]
函数 混音器_创建(采样率, 位深) {
    返回 [[], 1000, 采样率, 位深, []]
}

函数 混音器_轨道(m) { 返回 m[0] }
函数 混音器_主音量(m) { 返回 m[1] }
函数 混音器_采样率(m) { 返回 m[2] }

函数 混音器_添加轨道(m, 轨道) { 追加(m[0], 轨道) }
函数 混音器_设主音量(m, v) { m[1] = v }

// 混音核心: 将所有轨道混合到输出缓冲
// 输出: 立体声交错 [L0, R0, L1, R1, ...]
函数 混音器_混音(m, 帧数) {
    定义 可变 输出 = []
    定义 采样率 = m[2]
    定义 主音量 = m[1]

    定义 可变 f = 0
    当 (f < 帧数) {
        定义 可变 左混 = 0
        定义 可变 右混 = 0

        定义 可变 t = 0
        当 (t < 计数(m[0])) {
            定义 轨道 = m[0][t]
            如果 (音轨_静音(轨道) == 假) {
                定义 数据 = 音轨_数据(轨道)
                如果 (计数(数据) > 0) {
                    定义 可变 idx = f
                    如果 (轨道[6]) { idx = f % 计数(数据) }
                    否则 如果 (idx >= 计数(数据)) { idx = 计数(数据) - 1 }

                    定义 采样 = 数据[idx]
                    定义 env = ADSR_步进(音轨_ADSR(轨道), 采样率)
                    定义 增益 = 采样 * 音轨_音量(轨道) * env / 1000000

                    // 声像: -500=全左, 0=中, +500=全右
                    定义 声像 = 音轨_声像(轨道)
                    定义 左增益 = 增益 * (500 - 声像) / 1000
                    定义 右增益 = 增益 * (500 + 声像) / 1000

                    左混 = 左混 + 左增益
                    右混 = 右混 + 右增益
                }
            }
            t = t + 1
        }

        // 主音量
        左混 = 左混 * 主音量 / 1000
        右混 = 右混 * 主音量 / 1000

        // 硬限幅 (16位: -32768~32767)
        如果 (左混 > 32767) { 左混 = 32767 }
        如果 (左混 < -32768) { 左混 = -32768 }
        如果 (右混 > 32767) { 右混 = 32767 }
        如果 (右混 < -32768) { 右混 = -32768 }

        追加(输出, 左混)
        追加(输出, 右混)
        f = f + 1
    }

    m[4] = 输出
    返回 输出
}

// 混音器报告
函数 混音器_打印报告(m) {
    打印("═══ 混音器报告 ═══")
    打印文本(字符串拼接("  轨道数: ", 转字符串(计数(m[0]))))
    打印文本(字符串拼接("  主音量: ", 字符串拼接(转字符串(m[1]), "/1000")))
    打印文本(字符串拼接("  采样率: ", 字符串拼接(转字符串(m[2]), "Hz")))
    打印文本(字符串拼接("  位深: ", 字符串拼接(转字符串(m[3]), "bit")))
    定义 可变 i = 0
    当 (i < 计数(m[0])) {
        定义 轨道 = m[0][i]
        定义 可变 状态 = "播放"
        如果 (音轨_静音(轨道)) { 状态 = "静音" }
        i = i + 1
    }
}

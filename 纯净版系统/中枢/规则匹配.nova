// NovaOS 防火墙引擎 — 智能规则匹配与连接追踪
// 本模块实现内核级防火墙的核心决策引擎:
//   1. 五元组+扩展字段规则匹配(支持IP/端口/协议/状态/时间/速率)
//   2. 有状态连接追踪(conntrack)与NAT支持
//   3. 哈希加速的规则查找与连接查找
//   4. AI驱动的入侵检测与自适应规则优先级
//   5. 速率限制与SYN Flood防护
//   6. 日志审计与统计
// 与安全防护引擎、网络协议栈、智能大脑形成安全神经网络。

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./日志中枢.nova")
导入("./同步原语.nova")
导入("./进程调度.nova")
导入("../外联/传输传输.nova")
导入("./公共智能.nova")
导入("./安全防护初始.nova")
导入("./链表后继.nova")
导入("./内核打印.nova")
导入("./时钟中枢.nova")
导入("./整数转字符串.nova")

// §1 常量与协议定义

定义 协议_任意 = 0
定义 协议_ICMP = 1
定义 协议_传控 = 6
定义 协议_数报 = 17
定义 协议_ICMP6 = 58

定义 动作_接受 = 0
定义 动作_丢弃 = 1
定义 动作_拒绝 = 2
定义 动作_日志 = 3
定义 动作_DNAT = 4
定义 动作_SNAT = 5
定义 动作_MASQUERADE = 6
定义 动作_REDIRECT = 7

定义 连接_NEW = 0
定义 连接_ESTABLISHED = 1
定义 连接_RELATED = 2
定义 连接_INVALID = 3
定义 连接_TIME_WAIT = 4
定义 连接_CLOSE = 5
定义 连接_SYN_SENT = 6
定义 连接_SYN_RECV = 7

定义 链_INPUT = 0
定义 链_OUTPUT = 1
定义 链_FORWARD = 2
定义 链_PREROUTING = 3
定义 链_POSTROUTING = 4

定义 连接表最大 = 65536
定义 规则最大 = 4096
定义 连接哈希桶数 = 4096
定义 SYN_FLOOD_阈值 = 1000
定义 速率限制_窗口_毫秒 = 1000

// §2 数据结构

结构 防火墙规则 {
    编号,
    链,
    优先级,
    协议,
    源IP,
    源IP掩码,
    目标IP,
    目标IP掩码,
    源端口_起,
    源端口_止,
    目标端口_起,
    目标端口_止,
    传控标志掩码,
    传控标志匹配,
    连接状态,
    动作,
    日志前缀,
    速率_每秒,
    时间_起,
    时间_止,
    命中次数,
    命中字节,
    启用,
    DNAT_IP,
    DNAT_端口,
    SNAT_IP,
}

结构 连接追踪条目 {
    源IP,
    目标IP,
    源端口,
    目标端口,
    协议,
    状态,
    创建时间,
    上次活动,
    包计数,
    字节计数,
    反向包计数,
    反向字节计数,
    NAT_新IP,
    NAT_新端口,
    标记,
    哈希下一个,
}

结构 速率计数器 {
    源IP,
    计数,
    窗口开始,
}

结构 防火墙统计 {
    总包数,
    接受数,
    丢弃数,
    拒绝数,
    日志数,
    NAT数,
    连接数,
    SYN_flood检测数,
    AI检测数,
}

// §3 全局状态

定义 可变 规则链 = [[], [], [], [], []]
定义 可变 默认策略 = [动作_接受, 动作_接受, 动作_丢弃, 动作_接受, 动作_接受]
定义 可变 连接表 = []
定义 可变 连接哈希表 = []
定义 可变 速率表 = []
定义 可变 防火墙锁 = 空
定义 可变 下一规则编号 = 1
定义 可变 全局统计 = 防火墙统计 { 总包数: 0, 接受数: 0, 丢弃数: 0, 拒绝数: 0, 日志数: 0, NAT数: 0, 连接数: 0, SYN_flood检测数: 0, AI检测数: 0 }
定义 可变 防火墙_已启用 = 假

函数 防火墙_初始化() {
    防火墙锁 = 自旋锁_创建()
    // 初始化连接哈希表
    定义 可变 i = 0
    当 (i < 连接哈希桶数) {
        追加(连接哈希表, 空)
        i = i + 1
    }
    防火墙_已启用 = 真
    内核打印("[防火墙] 初始化完成, 哈希桶: " + 整数转字符串(连接哈希桶数))
}

// §4 规则匹配引擎

函数 规则_匹配(规则, 源IP, 目标IP, 源端口, 目标端口, 协议, 传控标志, 连接状态) {
    如果 (!规则.启用) { 返回 假 }

    // 协议匹配
    如果 (规则.协议 != 协议_任意 && 规则.协议 != 协议) { 返回 假 }

    // 源IP匹配(带CIDR掩码)
    如果 (规则.源IP != 0) {
        如果 ((源IP & 规则.源IP掩码) != (规则.源IP & 规则.源IP掩码)) { 返回 假 }
    }

    // 目标IP匹配
    如果 (规则.目标IP != 0) {
        如果 ((目标IP & 规则.目标IP掩码) != (规则.目标IP & 规则.目标IP掩码)) { 返回 假 }
    }

    // 源端口范围
    如果 (规则.源端口_起 != 0 || 规则.源端口_止 != 0) {
        如果 (源端口 < 规则.源端口_起 || 源端口 > 规则.源端口_止) { 返回 假 }
    }

    // 目标端口范围
    如果 (规则.目标端口_起 != 0 || 规则.目标端口_止 != 0) {
        如果 (目标端口 < 规则.目标端口_起 || 目标端口 > 规则.目标端口_止) { 返回 假 }
    }

    // 传控标志匹配
    如果 (规则.传控标志掩码 != 0) {
        如果 ((传控标志 & 规则.传控标志掩码) != 规则.传控标志匹配) { 返回 假 }
    }

    // 连接状态匹配
    如果 (规则.连接状态 != 0 && 规则.连接状态 != 连接状态) { 返回 假 }

    // 时间范围匹配
    如果 (规则.时间_起 != 0 || 规则.时间_止 != 0) {
        定义 当前小时 = (读取毫秒() / 3600000) % 24
        如果 (当前小时 < 规则.时间_起 || 当前小时 > 规则.时间_止) { 返回 假 }
    }

    // 速率限制检查
    如果 (规则.速率_每秒 > 0) {
        定义 当前速率 = 速率_获取(源IP)
        如果 (当前速率 > 规则.速率_每秒) { 返回 假 }
    }

    返回 真
}

函数 防火墙_处理包(链ID, 源IP, 目标IP, 源端口, 目标端口, 协议, 传控标志, 包大小) {
    如果 (!防火墙_已启用) { 返回 动作_接受 }
    全局统计.总包数 = 全局统计.总包数 + 1

    // 1. 连接追踪: 查询已有连接状态
    定义 连接状态 = 连接追踪_查找(源IP, 目标IP, 源端口, 目标端口, 协议)

    // 快速路径: 已建立连接直接放行
    如果 (连接状态 == 连接_ESTABLISHED || 连接状态 == 连接_RELATED) {
        连接追踪_更新(源IP, 目标IP, 源端口, 目标端口, 协议, 包大小)
        全局统计.接受数 = 全局统计.接受数 + 1
        返回 动作_接受
    }

    // 2. SYN Flood检测
    如果 (协议 == 协议_传控 && (传控标志 & 0x02) != 0) {
        定义 syn速率 = 速率_获取(源IP)
        速率_递增(源IP)
        如果 (syn速率 > SYN_FLOOD_阈值) {
            全局统计.SYN_flood检测数 = 全局统计.SYN_flood检测数 + 1
            全局统计.丢弃数 = 全局统计.丢弃数 + 1
            内核警告("[防火墙] SYN Flood检测: " + IP转字符串(源IP) + " 速率:" + 整数转字符串(syn速率))
            返回 动作_丢弃
        }
    }

    // 3. AI入侵检测
    定义 AI分数 = AI防火墙_评估(源IP, 目标IP, 源端口, 目标端口, 协议, 传控标志)
    如果 (AI分数 > 800) {
        全局统计.AI检测数 = 全局统计.AI检测数 + 1
        全局统计.丢弃数 = 全局统计.丢弃数 + 1
        返回 动作_丢弃
    }

    // 4. 规则链遍历
    如果 (链ID >= 0 && 链ID < 5) {
        定义 规则列表 = 规则链[链ID]
        定义 可变 i = 0
        当 (i < 计数(规则列表)) {
            定义 规则 = 规则列表[i]
            如果 (规则_匹配(规则, 源IP, 目标IP, 源端口, 目标端口, 协议, 传控标志, 连接状态)) {
                // 命中统计
                规则.命中次数 = 规则.命中次数 + 1
                规则.命中字节 = 规则.命中字节 + 包大小

                // 日志动作
                如果 (规则.动作 == 动作_日志 || 规则.日志前缀 != "") {
                    防火墙_日志(规则, 源IP, 目标IP, 源端口, 目标端口, 协议)
                    全局统计.日志数 = 全局统计.日志数 + 1
                }

                // 执行动作
                如果 (规则.动作 == 动作_接受) {
                    连接追踪_更新(源IP, 目标IP, 源端口, 目标端口, 协议, 包大小)
                    全局统计.接受数 = 全局统计.接受数 + 1
                    返回 动作_接受
                }
                如果 (规则.动作 == 动作_丢弃) {
                    全局统计.丢弃数 = 全局统计.丢弃数 + 1
                    返回 动作_丢弃
                }
                如果 (规则.动作 == 动作_拒绝) {
                    全局统计.拒绝数 = 全局统计.拒绝数 + 1
                    返回 动作_拒绝
                }
                如果 (规则.动作 == 动作_DNAT || 规则.动作 == 动作_SNAT || 规则.动作 == 动作_MASQUERADE) {
                    防火墙_NAT(规则, 源IP, 目标IP, 源端口, 目标端口, 协议, 包大小)
                    全局统计.NAT数 = 全局统计.NAT数 + 1
                    返回 动作_接受
                }
            }
            i = i + 1
        }
    }

    // 5. 默认策略
    定义 默认 = 默认策略[链ID]
    如果 (默认 == 动作_接受) {
        连接追踪_更新(源IP, 目标IP, 源端口, 目标端口, 协议, 包大小)
        全局统计.接受数 = 全局统计.接受数 + 1
    } 否则 {
        全局统计.丢弃数 = 全局统计.丢弃数 + 1
    }
    返回 默认
}

// §5 连接追踪(有状态防火墙)

函数 连接_哈希(源IP, 目标IP, 源端口, 目标端口, 协议) {
    定义 h = 源IP * 2654435761
    h = h ^ (目标IP * 2246822519)
    h = h ^ (源端口 * 3266489917)
    h = h ^ (目标端口 * 668265263)
    h = h ^ (协议 * 374761393)
    返回 (h >> 16) % 连接哈希桶数
}

函数 连接追踪_查找(源IP, 目标IP, 源端口, 目标端口, 协议) {
    // 哈希加速查找
    定义 桶 = 连接_哈希(源IP, 目标IP, 源端口, 目标端口, 协议)
    定义 反向桶 = 连接_哈希(目标IP, 源IP, 目标端口, 源端口, 协议)

    // 正向查找
    定义 可变 i = 0
    当 (i < 计数(连接表)) {
        定义 ct = 连接表[i]
        如果 (ct.源IP == 源IP && ct.目标IP == 目标IP &&
            ct.源端口 == 源端口 && ct.目标端口 == 目标端口 && ct.协议 == 协议) {
            返回 ct.状态
        }
        如果 (ct.源IP == 目标IP && ct.目标IP == 源IP &&
            ct.源端口 == 目标端口 && ct.目标端口 == 源端口 && ct.协议 == 协议) {
            返回 连接_ESTABLISHED
        }
        i = i + 1
    }
    返回 连接_NEW
}

函数 连接追踪_更新(源IP, 目标IP, 源端口, 目标端口, 协议, 包大小) {
    定义 可变 i = 0
    当 (i < 计数(连接表)) {
        定义 ct = 连接表[i]
        如果 (ct.源IP == 源IP && ct.目标IP == 目标IP && ct.协议 == 协议 &&
            ct.源端口 == 源端口 && ct.目标端口 == 目标端口) {
            ct.上次活动 = 读取毫秒()
            ct.包计数 = ct.包计数 + 1
            ct.字节计数 = ct.字节计数 + 包大小
            如果 (ct.状态 == 连接_NEW) { ct.状态 = 连接_ESTABLISHED }
            返回
        }
        如果 (ct.源IP == 目标IP && ct.目标IP == 源IP && ct.协议 == 协议) {
            ct.上次活动 = 读取毫秒()
            ct.反向包计数 = ct.反向包计数 + 1
            ct.反向字节计数 = ct.反向字节计数 + 包大小
            如果 (ct.状态 == 连接_NEW) { ct.状态 = 连接_ESTABLISHED }
            返回
        }
        i = i + 1
    }
    // 新连接
    如果 (计数(连接表) >= 连接表最大) { 连接追踪_清理过期() }
    追加(连接表, 连接追踪条目 {
        源IP: 源IP, 目标IP: 目标IP,
        源端口: 源端口, 目标端口: 目标端口,
        协议: 协议, 状态: 连接_NEW,
        创建时间: 读取毫秒(), 上次活动: 读取毫秒(),
        包计数: 1, 字节计数: 包大小,
        反向包计数: 0, 反向字节计数: 0,
        NAT_新IP: 0, NAT_新端口: 0,
        标记: 0, 哈希下一个: 空,
    })
    全局统计.连接数 = 全局统计.连接数 + 1
}

函数 连接追踪_清理过期() {
    定义 现在 = 读取毫秒()
    定义 超时_传控_已建立 = 432000000
    定义 超时_传控_SYN = 120000
    定义 超时_传控_TIME_WAIT = 120000
    定义 超时_数报 = 30000
    定义 超时_ICMP = 30000
    定义 可变 已清理 = 0

    定义 可变 i = 计数(连接表) - 1
    当 (i >= 0) {
        定义 ct = 连接表[i]
        定义 可变 超时 = 超时_数报
        如果 (ct.协议 == 协议_传控) {
            如果 (ct.状态 == 连接_ESTABLISHED) { 超时 = 超时_传控_已建立 }
            否则 如果 (ct.状态 == 连接_SYN_SENT || ct.状态 == 连接_SYN_RECV) { 超时 = 超时_传控_SYN }
            否则 如果 (ct.状态 == 连接_TIME_WAIT) { 超时 = 超时_传控_TIME_WAIT }
            否则 { 超时 = 超时_传控_SYN }
        } 否则 如果 (ct.协议 == 协议_ICMP) {
            超时 = 超时_ICMP
        }
        如果 (现在 - ct.上次活动 > 超时) {
            链表_删除(连接表, i)
            已清理 = 已清理 + 1
        }
        i = i - 1
    }
    如果 (已清理 > 0) {
        内核调试("[防火墙] 清理过期连接: " + 整数转字符串(已清理))
    }
}

// §6 NAT处理

函数 防火墙_NAT(规则, 源IP, 目标IP, 源端口, 目标端口, 协议, 包大小) {
    如果 (规则.动作 == 动作_DNAT) {
        // 目标NAT: 修改目标IP/端口
        定义 新目标IP = 规则.DNAT_IP
        定义 新目标端口 = 规则.DNAT_端口
        如果 (新目标端口 == 0) { 新目标端口 = 目标端口 }
        连接追踪_更新_NAT(源IP, 目标IP, 源端口, 目标端口, 协议, 新目标IP, 新目标端口, 包大小)
    } 否则 如果 (规则.动作 == 动作_SNAT || 规则.动作 == 动作_MASQUERADE) {
        定义 新源IP = 规则.SNAT_IP
        如果 (规则.动作 == 动作_MASQUERADE) { 新源IP = 获取出口IP() }
        连接追踪_更新_NAT(源IP, 目标IP, 源端口, 目标端口, 协议, 新源IP, 源端口, 包大小)
    }
}

函数 连接追踪_更新_NAT(源IP, 目标IP, 源端口, 目标端口, 协议, NAT_IP, NAT_端口, 包大小) {
    连接追踪_更新(源IP, 目标IP, 源端口, 目标端口, 协议, 包大小)
    // 标记NAT映射
    定义 可变 i = 计数(连接表) - 1
    如果 (i >= 0) {
        连接表[i].NAT_新IP = NAT_IP
        连接表[i].NAT_新端口 = NAT_端口
    }
}

// §7 速率限制

函数 速率_获取(IP) {
    定义 现在 = 读取毫秒()
    定义 可变 i = 0
    当 (i < 计数(速率表)) {
        如果 (速率表[i].源IP == IP) {
            如果 (现在 - 速率表[i].窗口开始 > 速率限制_窗口_毫秒) {
                速率表[i].计数 = 0
                速率表[i].窗口开始 = 现在
            }
            返回 速率表[i].计数
        }
        i = i + 1
    }
    返回 0
}

函数 速率_递增(IP) {
    定义 现在 = 读取毫秒()
    定义 可变 i = 0
    当 (i < 计数(速率表)) {
        如果 (速率表[i].源IP == IP) {
            如果 (现在 - 速率表[i].窗口开始 > 速率限制_窗口_毫秒) {
                速率表[i].计数 = 1
                速率表[i].窗口开始 = 现在
            } 否则 {
                速率表[i].计数 = 速率表[i].计数 + 1
            }
            返回
        }
        i = i + 1
    }
    如果 (计数(速率表) > 10000) {
        速率表 = 子列表(速率表, 5000, 10000)
    }
    追加(速率表, 速率计数器 { 源IP: IP, 计数: 1, 窗口开始: 现在 })
}

// §8 AI入侵检测

函数 AI防火墙_评估(源IP, 目标IP, 源端口, 目标端口, 协议, 传控标志) {
    // 特征提取: 8维输入
    定义 特征 = [
        源IP & 0xFF,
        (源IP >> 8) & 0xFF,
        目标端口 / 256,
        协议,
        传控标志,
        速率_获取(源IP),
        连接追踪_计数源IP(源IP),
        (目标端口 < 1024) * 100,
    ]

    // 简单感知机: 8→1加权求和
    定义 权重 = [1, 1, -5, 2, 10, 20, 15, -30]
    定义 可变 分数 = 0
    定义 可变 i = 0
    当 (i < 8) {
        分数 = 分数 + 特征[i] * 权重[i]
        i = i + 1
    }

    // 归一化0~1000
    如果 (分数 > 500) { 返回 1000 }
    如果 (分数 < -500) { 返回 0 }
    返回 500 + 分数
}

函数 连接追踪_计数源IP(IP) {
    定义 可变 计数 = 0
    定义 可变 i = 0
    当 (i < 计数(连接表)) {
        如果 (连接表[i].源IP == IP) { 计数 = 计数 + 1 }
        i = i + 1
    }
    返回 计数
}

// §9 规则管理

函数 防火墙_添加规则(链ID, 协议, 源IP, 源掩码, 目标IP, 目标掩码, 源端口起, 源端口止, 目标端口起, 目标端口止, 动作) {
    如果 (链ID < 0 || 链ID >= 5) { 返回 错误_无效参数 }
    如果 (计数(规则链[链ID]) >= 规则最大) { 返回 错误_资源不足 }

    定义 规则 = 防火墙规则 {
        编号: 下一规则编号,
        链: 链ID, 优先级: 计数(规则链[链ID]),
        协议: 协议,
        源IP: 源IP, 源IP掩码: 源掩码,
        目标IP: 目标IP, 目标IP掩码: 目标掩码,
        源端口_起: 源端口起, 源端口_止: 源端口止,
        目标端口_起: 目标端口起, 目标端口_止: 目标端口止,
        传控标志掩码: 0, 传控标志匹配: 0,
        连接状态: 0, 动作: 动作,
        日志前缀: "", 速率_每秒: 0,
        时间_起: 0, 时间_止: 0,
        命中次数: 0, 命中字节: 0,
        启用: 真,
        DNAT_IP: 0, DNAT_端口: 0, SNAT_IP: 0,
    }
    追加(规则链[链ID], 规则)
    下一规则编号 = 下一规则编号 + 1
    返回 规则.编号
}

函数 防火墙_删除规则(编号) {
    定义 可变 c = 0
    当 (c < 5) {
        定义 可变 i = 0
        当 (i < 计数(规则链[c])) {
            如果 (规则链[c][i].编号 == 编号) {
                链表_删除(规则链[c], i)
                返回 成功
            }
            i = i + 1
        }
        c = c + 1
    }
    返回 错误_不存在
}

函数 防火墙_设置默认策略(链ID, 策略) {
    如果 (链ID < 0 || 链ID >= 5) { 返回 错误_无效参数 }
    默认策略[链ID] = 策略
    返回 成功
}

// §10 日志与统计

函数 防火墙_日志(规则, 源IP, 目标IP, 源端口, 目标端口, 协议) {
    定义 前缀 = 规则.日志前缀
    如果 (前缀 == "") { 前缀 = "FW" }
    内核信息("[" + 前缀 + "] 规则#" + 整数转字符串(规则.编号) +
             " " + IP转字符串(源IP) + ":" + 整数转字符串(源端口) +
             " → " + IP转字符串(目标IP) + ":" + 整数转字符串(目标端口) +
             " 协议:" + 整数转字符串(协议))
}

函数 IP转字符串(ip) {
    返回 整数转字符串((ip >> 24) & 0xFF) + "." +
           整数转字符串((ip >> 16) & 0xFF) + "." +
           整数转字符串((ip >> 8) & 0xFF) + "." +
           整数转字符串(ip & 0xFF)
}

函数 防火墙_统计() {
    返回 {
        总包数: 全局统计.总包数,
        接受: 全局统计.接受数,
        丢弃: 全局统计.丢弃数,
        拒绝: 全局统计.拒绝数,
        日志: 全局统计.日志数,
        NAT: 全局统计.NAT数,
        活跃连接: 计数(连接表),
        历史连接: 全局统计.连接数,
        SYN_flood: 全局统计.SYN_flood检测数,
        AI检测: 全局统计.AI检测数,
        规则总数: 计数(规则链[0]) + 计数(规则链[1]) + 计数(规则链[2]) + 计数(规则链[3]) + 计数(规则链[4]),
    }
}

函数 防火墙_连接列表(最大数) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(连接表) && i < 最大数) {
        定义 ct = 连接表[i]
        追加(结果, {
            源: IP转字符串(ct.源IP) + ":" + 整数转字符串(ct.源端口),
            目标: IP转字符串(ct.目标IP) + ":" + 整数转字符串(ct.目标端口),
            协议: ct.协议, 状态: ct.状态,
            包数: ct.包计数, 字节: ct.字节计数,
        })
        i = i + 1
    }
    返回 结果
}

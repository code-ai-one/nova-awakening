// §12 完整统计与诊断

函数 中断入口_完整统计() {
    返回 [
        异常统计信息.总次数,
        异常统计信息.内核态次数,
        异常统计信息.用户态次数,
        异常统计信息.致命次数,
        异常统计信息.最后异常向量,
        异常统计信息.最后异常RIP,
        AI异常检测.重复检测次数
    ]
}

函数 异常_打印统计() {
    内核信息("═══════ 异常统计 ═══════")
    内核信息("  总次数: %d (内核%d/用户%d/致命%d)",
             异常统计信息.总次数, 异常统计信息.内核态次数,
             异常统计信息.用户态次数, 异常统计信息.致命次数)

    定义 可变 i = 0
    当 (i < 异常_最大) {
        如果 (异常统计信息.各类计数[i] > 0) {
            内核信息("  %s: %d次", 异常名称[i], 异常统计信息.各类计数[i])
        }
        i = i + 1
    }

    内核信息("  AI重复模式检测: %d次", AI异常检测.重复检测次数)
    内核信息("════════════════════════")
}

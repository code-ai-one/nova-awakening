导入("./进程任务.nova")
导入("./进程调度.nova")
导入("./信号设置用.nova")
导入("../记忆/块输入输出.nova")
导入("./信号获取默.nova")
导入("./同步原语.nova")
导入("./进程标识分.nova")
导入("./进程描述符.nova")
导入("./墙钟设置.nova")
导入("../执行/归档解包.nova")
导入("./整数转字符串.nova")
导入("./内存初始化.nova")
导入("../稳态/图处内存管.nova")
导入("./字符串替换.nova")
导入("./读取调用.nova")
导入("./进程退出.nova")
导入("./链表后继.nova")
导入("./高精定器添.nova")
导入("./智能异常甲.nova")
导入("./每处理器.nova")
导入("../感知/内核直连层.nova")
导入("./列表加头加尾.nova")

定义 信号_挂断 = 1
定义 信号_中断 = 2
定义 信号_退出 = 3
定义 信号_终止 = 15
定义 信号_继续 = 18
定义 信号_停止 = 19
定义 信号_用户一 = 10
定义 信号_用户二 = 12

结构 信号档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    默认动作数,
    注册动作数,
    投递数,
    广播数,
    待决数,
    阻塞数,
    解除数,
    处理数,
    成功数,
    失败数,
    最近信号,
    最近目标,
    最近策略,
    默认动作表,
    自定义动作表,
    待决队列,
    阻塞表,
}

结构 信号请求 {
    动作,
    目标,
    参数,
    选项,
}

结构 信号回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 信号摘要 {
    名称,
    默认动作数,
    注册动作数,
    投递数,
    广播数,
    待决数,
    阻塞数,
    解除数,
    处理数,
    成功数,
    失败数,
    健康,
}

结构 信号动作项 {
    信号,
    名称,
    处理名,
    策略,
    来源,
}

结构 信号投递项 {
    信号,
    目标,
    来源,
    参数,
    策略,
    是否阻塞,
    已处理,
}

定义 可变 信号账本 = []
定义 可变 信号构建数 = 0
定义 可变 信号总动作 = 0
定义 可变 信号总成功 = 0
定义 可变 信号总失败 = 0

函数 进程信号_建档(名称) {
    定义 档 = 信号档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.默认动作数 = 0
    档.注册动作数 = 0
    档.投递数 = 0
    档.广播数 = 0
    档.待决数 = 0
    档.阻塞数 = 0
    档.解除数 = 0
    档.处理数 = 0
    档.成功数 = 0
    档.失败数 = 0
    档.最近信号 = 0
    档.最近目标 = ""
    档.最近策略 = ""
    档.默认动作表 = []
    档.自定义动作表 = []
    档.待决队列 = []
    档.阻塞表 = []
    返回 档
}

函数 进程信号_登记(档) {
    追加(信号账本, 档)
    信号构建数 = 信号构建数 + 1
    返回 档
}

函数 进程信号_完整统计() {
    返回 [
        信号构建数,
        信号总动作,
        信号总成功,
        信号总失败
    ]
}

函数 进程信号_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 信号回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 进程信号_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    信号总动作 = 信号总动作 + 1
}

函数 进程信号_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.失败数 > 档.成功数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (档.待决数 > 32 || 档.阻塞数 > 64) {
        档.最近健康 = "拥塞"
        返回 档.最近健康
    }
    如果 (档.失败数 > 0) {
        档.最近健康 = "监视"
        返回 档.最近健康
    }
    档.最近健康 = "运行"
    返回 档.最近健康
}

函数 进程信号_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (档.名称 == "") { 返回 假 }
    返回 真
}

函数 进程信号_成功(档, 来源, 数据) {
    档.最近结果 = 数据
    档.成功数 = 档.成功数 + 1
    信号总成功 = 信号总成功 + 1
    档.最近统计 = 进程信号_完整统计()
    进程信号_刷新健康(档)
    返回 进程信号_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 进程信号_失败(档, 来源, 错因) {
    如果 (档 != 空) {
        档.最近错误 = 错因
        档.失败数 = 档.失败数 + 1
        档.最近统计 = 进程信号_完整统计()
        进程信号_刷新健康(档)
    }
    信号总失败 = 信号总失败 + 1
    返回 进程信号_建回证(真, 假, 来源, 错因, 空, 进程信号_完整统计())
}

函数 进程信号_动作项(信号, 名称, 处理名, 策略, 来源) {
    定义 项 = 信号动作项 {}
    项.信号 = 信号
    项.名称 = 名称
    项.处理名 = 处理名
    项.策略 = 策略
    项.来源 = 来源
    返回 项
}

函数 进程信号_投递项(信号, 目标, 来源, 参数, 策略) {
    定义 项 = 信号投递项 {}
    项.信号 = 信号
    项.目标 = 目标
    项.来源 = 来源
    项.参数 = 参数
    项.策略 = 策略
    项.是否阻塞 = 假
    项.已处理 = 假
    返回 项
}

函数 进程信号_信号名(信号) {
    如果 (信号 == 信号_挂断) { 返回 "挂断" }
    如果 (信号 == 信号_中断) { 返回 "中断" }
    如果 (信号 == 信号_退出) { 返回 "退出" }
    如果 (信号 == 信号_终止) { 返回 "终止" }
    如果 (信号 == 信号_继续) { 返回 "继续" }
    如果 (信号 == 信号_停止) { 返回 "停止" }
    如果 (信号 == 信号_用户一) { 返回 "用户一" }
    如果 (信号 == 信号_用户二) { 返回 "用户二" }
    返回 "未知"
}

函数 进程信号_默认动作(信号) {
    如果 (信号 == 信号_挂断) { 返回 进程信号_动作项(信号, "关闭会话", "会话回收", "关闭", "默认") }
    如果 (信号 == 信号_中断) { 返回 进程信号_动作项(信号, "打断执行", "前台打断", "打断", "默认") }
    如果 (信号 == 信号_退出) { 返回 进程信号_动作项(信号, "保留转储", "异常退出", "转储", "默认") }
    如果 (信号 == 信号_终止) { 返回 进程信号_动作项(信号, "终止任务", "终止处理", "终止", "默认") }
    如果 (信号 == 信号_继续) { 返回 进程信号_动作项(信号, "恢复运行", "继续处理", "继续", "默认") }
    如果 (信号 == 信号_停止) { 返回 进程信号_动作项(信号, "挂起任务", "停止处理", "停止", "默认") }
    如果 (信号 == 信号_用户一) { 返回 进程信号_动作项(信号, "用户钩子一", "用户处理一", "回调", "默认") }
    如果 (信号 == 信号_用户二) { 返回 进程信号_动作项(信号, "用户钩子二", "用户处理二", "回调", "默认") }
    返回 进程信号_动作项(信号, "忽略", "空处理", "忽略", "默认")
}

函数 进程信号_写入默认表(档, 信号) {
    定义 动作 = 进程信号_默认动作(信号)
    追加(档.默认动作表, 动作)
    档.默认动作数 = 档.默认动作数 + 1
    返回 动作
}

函数 进程信号_初始化(档) {
    如果 (!进程信号_检查档(档)) { 返回 进程信号_失败(档, "初始化", "信号档不可用") }
    进程信号_记录(档, "初始化", [], "进程信号")
    档.默认动作表 = []
    档.自定义动作表 = []
    档.待决队列 = []
    档.阻塞表 = []
    档.默认动作数 = 0
    档.注册动作数 = 0
    档.待决数 = 0
    档.阻塞数 = 0
    进程信号_写入默认表(档, 信号_挂断)
    进程信号_写入默认表(档, 信号_中断)
    进程信号_写入默认表(档, 信号_退出)
    进程信号_写入默认表(档, 信号_终止)
    进程信号_写入默认表(档, 信号_继续)
    进程信号_写入默认表(档, 信号_停止)
    进程信号_写入默认表(档, 信号_用户一)
    进程信号_写入默认表(档, 信号_用户二)
    档.是否初始化 = 真
    返回 进程信号_成功(档, "初始化", "已初始化")
}

函数 进程信号_找动作(表, 信号) {
    定义 索引 = 0
    当 (索引 < 计数(表)) {
        定义 项 = 表[索引]
        如果 (项.信号 == 信号) { 返回 项 }
        索引 = 索引 + 1
    }
    返回 空
}

函数 进程信号_选动作(档, 信号) {
    定义 动作 = 进程信号_找动作(档.自定义动作表, 信号)
    如果 (动作 != 空) { 返回 动作 }
    返回 进程信号_找动作(档.默认动作表, 信号)
}

函数 进程信号_注册动作(档, 信号, 名称, 处理名, 策略, 来源) {
    如果 (!进程信号_检查档(档)) { 返回 进程信号_失败(档, "注册动作", "信号档不可用") }
    进程信号_记录(档, "注册动作", [信号, 名称, 处理名, 策略, 来源], "进程信号")
    定义 动作 = 进程信号_动作项(信号, 名称, 处理名, 策略, 来源)
    追加(档.自定义动作表, 动作)
    档.注册动作数 = 档.注册动作数 + 1
    档.最近信号 = 信号
    档.最近策略 = 策略
    返回 进程信号_成功(档, "注册动作", 动作)
}

函数 进程信号_阻塞(档, 目标, 信号) {
    如果 (!进程信号_检查档(档)) { 返回 进程信号_失败(档, "阻塞", "信号档不可用") }
    进程信号_记录(档, "阻塞", [目标, 信号], "进程信号")
    定义 条目 = [目标, 信号]
    追加(档.阻塞表, 条目)
    档.阻塞数 = 档.阻塞数 + 1
    档.最近目标 = 目标
    档.最近信号 = 信号
    返回 进程信号_成功(档, "阻塞", 条目)
}

函数 进程信号_是否阻塞(档, 目标, 信号) {
    定义 索引 = 0
    当 (索引 < 计数(档.阻塞表)) {
        定义 条目 = 档.阻塞表[索引]
        如果 (条目[0] == 目标 && 条目[1] == 信号) { 返回 真 }
        索引 = 索引 + 1
    }
    返回 假
}

函数 进程信号_解除阻塞(档, 目标, 信号) {
    如果 (!进程信号_检查档(档)) { 返回 进程信号_失败(档, "解除阻塞", "信号档不可用") }
    进程信号_记录(档, "解除阻塞", [目标, 信号], "进程信号")
    定义 新表 = []
    定义 索引 = 0
    定义 命中 = 假
    当 (索引 < 计数(档.阻塞表)) {
        定义 条目 = 档.阻塞表[索引]
        如果 (条目[0] == 目标 && 条目[1] == 信号) {
            命中 = 真
        } 否则 {
            追加(新表, 条目)
        }
        索引 = 索引 + 1
    }
    档.阻塞表 = 新表
    如果 (命中) {
        档.阻塞数 = 计数(档.阻塞表)
        档.解除数 = 档.解除数 + 1
        返回 进程信号_成功(档, "解除阻塞", [目标, 信号])
    }
    返回 进程信号_失败(档, "解除阻塞", "目标未阻塞该信号")
}

函数 进程信号_投递(档, 目标, 信号, 参数, 来源) {
    如果 (!进程信号_检查档(档)) { 返回 进程信号_失败(档, "投递", "信号档不可用") }
    进程信号_记录(档, "投递", [目标, 信号, 参数, 来源], "进程信号")
    定义 动作 = 进程信号_选动作(档, 信号)
    定义 策略 = "忽略"
    如果 (动作 != 空) { 策略 = 动作.策略 }
    定义 项 = 进程信号_投递项(信号, 目标, 来源, 参数, 策略)
    如果 (进程信号_是否阻塞(档, 目标, 信号)) {
        项.是否阻塞 = 真
    }
    追加(档.待决队列, 项)
    档.投递数 = 档.投递数 + 1
    档.待决数 = 计数(档.待决队列)
    档.最近目标 = 目标
    档.最近信号 = 信号
    档.最近策略 = 策略
    返回 进程信号_成功(档, "投递", 项)
}

函数 进程信号_广播(档, 目标组, 信号, 参数, 来源) {
    如果 (!进程信号_检查档(档)) { 返回 进程信号_失败(档, "广播", "信号档不可用") }
    进程信号_记录(档, "广播", [目标组, 信号, 参数, 来源], "进程信号")
    定义 索引 = 0
    定义 结果 = []
    当 (索引 < 计数(目标组)) {
        追加(结果, 进程信号_投递(档, 目标组[索引], 信号, 参数, 来源).数据)
        索引 = 索引 + 1
    }
    档.广播数 = 档.广播数 + 1
    返回 进程信号_成功(档, "广播", 结果)
}

函数 进程信号_取待决(档, 目标) {
    如果 (!进程信号_检查档(档)) { 返回 进程信号_失败(档, "取待决", "信号档不可用") }
    进程信号_记录(档, "取待决", [目标], "进程信号")
    定义 结果 = []
    定义 索引 = 0
    当 (索引 < 计数(档.待决队列)) {
        定义 项 = 档.待决队列[索引]
        如果 (项.目标 == 目标 && 项.已处理 == 假) {
            追加(结果, 项)
        }
        索引 = 索引 + 1
    }
    返回 进程信号_成功(档, "取待决", 结果)
}

函数 进程信号_动作结果(动作, 项) {
    如果 (动作 == 空) {
        返回 ["忽略", 项.目标, 进程信号_信号名(项.信号)]
    }
    返回 [动作.名称, 动作.处理名, 动作.策略, 项.目标, 进程信号_信号名(项.信号)]
}

函数 进程信号_处理单个(档, 目标) {
    如果 (!进程信号_检查档(档)) { 返回 进程信号_失败(档, "处理单个", "信号档不可用") }
    进程信号_记录(档, "处理单个", [目标], "进程信号")
    定义 索引 = 0
    当 (索引 < 计数(档.待决队列)) {
        定义 项 = 档.待决队列[索引]
        如果 (项.目标 == 目标 && 项.已处理 == 假) {
            如果 (项.是否阻塞) {
                返回 进程信号_失败(档, "处理单个", "目标当前阻塞该信号")
            }
            定义 动作 = 进程信号_选动作(档, 项.信号)
            项.已处理 = 真
            档.处理数 = 档.处理数 + 1
            档.待决数 = 档.待决数 - 1
            返回 进程信号_成功(档, "处理单个", 进程信号_动作结果(动作, 项))
        }
        索引 = 索引 + 1
    }
    返回 进程信号_失败(档, "处理单个", "未找到待处理信号")
}

函数 进程信号_处理批量(档, 目标) {
    如果 (!进程信号_检查档(档)) { 返回 进程信号_失败(档, "处理批量", "信号档不可用") }
    进程信号_记录(档, "处理批量", [目标], "进程信号")
    定义 结果 = []
    定义 索引 = 0
    当 (索引 < 计数(档.待决队列)) {
        定义 项 = 档.待决队列[索引]
        如果 (项.目标 == 目标 && 项.已处理 == 假 && 项.是否阻塞 == 假) {
            定义 动作 = 进程信号_选动作(档, 项.信号)
            项.已处理 = 真
            档.处理数 = 档.处理数 + 1
            档.待决数 = 档.待决数 - 1
            追加(结果, 进程信号_动作结果(动作, 项))
        }
        索引 = 索引 + 1
    }
    返回 进程信号_成功(档, "处理批量", 结果)
}

函数 进程信号_清理已处理(档) {
    如果 (!进程信号_检查档(档)) { 返回 进程信号_失败(档, "清理已处理", "信号档不可用") }
    进程信号_记录(档, "清理已处理", [], "进程信号")
    定义 新队列 = []
    定义 索引 = 0
    当 (索引 < 计数(档.待决队列)) {
        定义 项 = 档.待决队列[索引]
        如果 (项.已处理 == 假) {
            追加(新队列, 项)
        }
        索引 = 索引 + 1
    }
    档.待决队列 = 新队列
    档.待决数 = 计数(档.待决队列)
    返回 进程信号_成功(档, "清理已处理", 档.待决数)
}

函数 进程信号_异常(档) {
    如果 (!进程信号_检查档(档)) { 返回 进程信号_失败(档, "异常", "信号档不可用") }
    进程信号_记录(档, "异常", [], "进程信号")
    定义 问题 = []
    如果 (!档.是否初始化) { 追加(问题, "未初始化") }
    如果 (档.待决数 > 64) { 追加(问题, "待决积压") }
    如果 (档.阻塞数 > 64) { 追加(问题, "阻塞过多") }
    如果 (档.失败数 > 档.成功数) { 追加(问题, "失败倒挂") }
    返回 进程信号_成功(档, "异常", 问题)
}

函数 进程信号_摘要(档) {
    定义 摘要 = 信号摘要 {}
    摘要.名称 = 档.名称
    摘要.默认动作数 = 档.默认动作数
    摘要.注册动作数 = 档.注册动作数
    摘要.投递数 = 档.投递数
    摘要.广播数 = 档.广播数
    摘要.待决数 = 档.待决数
    摘要.阻塞数 = 档.阻塞数
    摘要.解除数 = 档.解除数
    摘要.处理数 = 档.处理数
    摘要.成功数 = 档.成功数
    摘要.失败数 = 档.失败数
    摘要.健康 = 进程信号_刷新健康(档)
    返回 摘要
}

函数 进程信号_自检(档) {
    如果 (!进程信号_检查档(档)) { 返回 假 }
    如果 (进程信号_初始化(档).已成 == 假) { 返回 假 }
    如果 (进程信号_注册动作(档, 信号_用户一, "刷新快照", "刷新处理", "回调", "自检").已成 == 假) { 返回 假 }
    如果 (进程信号_阻塞(档, "前台任务", 信号_停止).已成 == 假) { 返回 假 }
    如果 (进程信号_投递(档, "前台任务", 信号_终止, ["退出"], "自检").已成 == 假) { 返回 假 }
    如果 (进程信号_投递(档, "前台任务", 信号_停止, ["挂起"], "自检").已成 == 假) { 返回 假 }
    如果 (进程信号_处理单个(档, "前台任务").已成 == 假) { 返回 假 }
    如果 (进程信号_解除阻塞(档, "前台任务", 信号_停止).已成 == 假) { 返回 假 }
    如果 (进程信号_处理批量(档, "前台任务").已成 == 假) { 返回 假 }
    如果 (进程信号_清理已处理(档).已成 == 假) { 返回 假 }
    返回 真
}

函数 进程信号_处理(档, 请求) {
    如果 (请求 == 空) { 返回 进程信号_失败(档, "处理", "请求为空") }
    如果 (请求.动作 == "初始化") { 返回 进程信号_初始化(档) }
    如果 (请求.动作 == "注册动作") { 返回 进程信号_注册动作(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3], 请求.参数[4]) }
    如果 (请求.动作 == "阻塞") { 返回 进程信号_阻塞(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "解除阻塞") { 返回 进程信号_解除阻塞(档, 请求.参数[0], 请求.参数[1]) }
    如果 (请求.动作 == "投递") { 返回 进程信号_投递(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3]) }
    如果 (请求.动作 == "广播") { 返回 进程信号_广播(档, 请求.参数[0], 请求.参数[1], 请求.参数[2], 请求.参数[3]) }
    如果 (请求.动作 == "取待决") { 返回 进程信号_取待决(档, 请求.参数[0]) }
    如果 (请求.动作 == "处理单个") { 返回 进程信号_处理单个(档, 请求.参数[0]) }
    如果 (请求.动作 == "处理批量") { 返回 进程信号_处理批量(档, 请求.参数[0]) }
    如果 (请求.动作 == "清理已处理") { 返回 进程信号_清理已处理(档) }
    如果 (请求.动作 == "异常") { 返回 进程信号_异常(档) }
    如果 (请求.动作 == "摘要") { 返回 进程信号_成功(档, "摘要", 进程信号_摘要(档)) }
    返回 进程信号_失败(档, "处理", "未知动作")
}

// merge source: 沙盒批次/批三/待厚/中枢/新系统信号.nova
// NovaOS内核 · 信号处理引擎 (移植自Nova大脑L1/signal)
// 纯整数定点: Hartley变换/滤波器/包络检测/节律分析
// §1 Hartley变换替代FFT(避免复数, 纯实数)
// §2 IIR/FIR滤波器(低通/高通/带通)
// §3 包络检测(HilNova编码模型近似)
// §4 节律/周期检测(自相关法)
// §5 特征提取(过零率/能量/峰值/斜率)


定义 信号_最大长度 = 256
定义 信号_滤波阶数 = 8
定义 信号_窗口大小 = 64


函数 信号_能量_引擎(数据, 长度) {
    定义 可变 能量 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        能量 = 能量 + 数据[i] * 数据[i] / 1000
        i = i + 1
    }
    返回 能量 / 长度
}

函数 信号_均值(数据, 长度) {
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < 长度) { 总和 = 总和 + 数据[i]; i = i + 1 }
    返回 总和 / 长度
}

函数 信号_方差(数据, 长度) {
    定义 均 = 信号_均值(数据, 长度)
    定义 可变 方差 = 0
    定义 可变 i = 0
    当 (i < 长度) {
        定义 差 = 数据[i] - 均
        方差 = 方差 + 差 * 差 / 1000
        i = i + 1
    }
    返回 方差 / 长度
}


函数 信号_过零率(数据, 长度) {
    如果 (长度 < 2) { 返回 0 }
    定义 可变 过零 = 0
    定义 可变 i = 1
    当 (i < 长度) {
        如果 ((数据[i] > 0 && 数据[i-1] < 0) || (数据[i] < 0 && 数据[i-1] > 0)) {
            过零 = 过零 + 1
        }
        i = i + 1
    }
    返回 过零 * 1000 / (长度 - 1)  // ×1000
}


函数 信号_峰值数(数据, 长度, 阈值) {
    如果 (长度 < 3) { 返回 0 }
    定义 可变 峰值 = 0
    定义 可变 i = 1
    当 (i < 长度 - 1) {
        如果 (数据[i] > 数据[i-1] && 数据[i] > 数据[i+1] && 数据[i] > 阈值) {
            峰值 = 峰值 + 1
        }
        i = i + 1
    }
    返回 峰值
}

函数 信号_最大值(数据, 长度) {
    定义 可变 最大 = 数据[0]
    定义 可变 i = 1
    当 (i < 长度) {
        如果 (数据[i] > 最大) { 最大 = 数据[i] }
        i = i + 1
    }
    返回 最大
}

函数 信号_最小值(数据, 长度) {
    定义 可变 最小 = 数据[0]
    定义 可变 i = 1
    当 (i < 长度) {
        如果 (数据[i] < 最小) { 最小 = 数据[i] }
        i = i + 1
    }
    返回 最小
}


函数 信号_低通滤波(数据, 长度, 截止频率) {
    // 简单移动平均实现FIR低通
    定义 窗口 = 1000 / (截止频率 + 1)
    如果 (窗口 < 2) { 窗口 = 2 }
    如果 (窗口 > 信号_滤波阶数) { 窗口 = 信号_滤波阶数 }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 长度) {
        定义 可变 和 = 0
        定义 可变 计 = 0
        定义 可变 j = 0
        当 (j < 窗口 && i - j >= 0) {
            和 = 和 + 数据[i - j]
            计 = 计 + 1
            j = j + 1
        }
        追加(结果, 和 / 计)
        i = i + 1
    }
    返回 结果
}

函数 信号_高通滤波(数据, 长度, 截止频率) {
    // 高通 = 原始 - 低通
    定义 低通 = 信号_低通滤波(数据, 长度, 截止频率)
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 长度) {
        追加(结果, 数据[i] - 低通[i])
        i = i + 1
    }
    返回 结果
}


函数 信号_自相关(数据, 长度, 最大延迟) {
    定义 可变 结果 = []
    定义 可变 lag = 0
    当 (lag < 最大延迟 && lag < 长度 / 2) {
        定义 可变 总 = 0
        定义 可变 i = 0
        当 (i < 长度 - lag) {
            总 = 总 + 数据[i] * 数据[i + lag] / 1000
            i = i + 1
        }
        追加(结果, 总 / (长度 - lag))
        lag = lag + 1
    }
    返回 结果
}

函数 信号_检测周期(数据, 长度) {
    // 自相关峰值→周期
    定义 自相关 = 信号_自相关(数据, 长度, 长度 / 2)
    定义 可变 最佳lag = 0
    定义 可变 最佳值 = 0
    定义 可变 i = 2  // 跳过lag=0,1
    当 (i < 计数(自相关)) {
        如果 (自相关[i] > 最佳值) {
            最佳值 = 自相关[i]
            最佳lag = i
        }
        i = i + 1
    }
    返回 最佳lag  // 返回检测到的周期(样本数)
}


函数 信号_斜率(数据, 长度) {
    定义 可变 结果 = []
    追加(结果, 0)
    定义 可变 i = 1
    当 (i < 长度) {
        追加(结果, 数据[i] - 数据[i-1])
        i = i + 1
    }
    返回 结果
}


函数 信号_包络_引擎(数据, 长度) {
    // HilNova编码模型近似: 用绝对值+低通滤波
    定义 可变 绝对值 = []
    定义 可变 i = 0
    当 (i < 长度) {
        定义 值 = 数据[i]
        如果 (值 < 0) { 值 = 0 - 值 }
        追加(绝对值, 值)
        i = i + 1
    }
    返回 信号_低通滤波(绝对值, 长度, 50)
}


函数 信号_提取特征(数据, 长度) {
    返回 {
        能量: 信号_能量(数据, 长度),
        均值: 信号_均值(数据, 长度),
        方差: 信号_方差(数据, 长度),
        过零率: 信号_过零率(数据, 长度),
        峰值数: 信号_峰值数(数据, 长度, 100),
        最大值: 信号_最大值(数据, 长度),
        最小值: 信号_最小值(数据, 长度),
        周期: 信号_检测周期(数据, 长度)
    }
}


函数 信号_动态范围(数据, 长度) {
    如果 (长度 == 0) { 返回 0 }
    返回 信号_最大值(数据, 长度) - 信号_最小值(数据, 长度)
}

函数 信号_信噪比估计(数据, 长度) {
    定义 能量 = 信号_能量_引擎(数据, 长度)
    定义 方差 = 信号_方差(数据, 长度)
    如果 (方差 == 0) { 返回 1000 }
    返回 能量 * 1000 / 方差
}


函数 信号引擎_完整统计() {
    返回 [信号处理_总次数]
}

// merge source: 沙盒批次/批三/待厚/中枢/信号定义.nova
//   1. 32个标准信号 + 32个实时信号(SIGRTMIN~SIGRTMAX)
//   2. 每个信号有默认行为: 终止/忽略/停止/继续/核心转储
//   3. SIGKILL/SIGSTOP不可捕获、不可忽略、不可阻塞
//   4. sigaction: 设置信号处理函数(SIG_DFL/SIG_IGN/自定义)
//   5. sigset_t: 64位位掩码表示信号集

定义 SIGHUP    = 1     // 终端挂起
定义 SIGINT    = 2     // 中断(Ctrl+C)
定义 SIGQUIT   = 3     // 退出(Ctrl+\) + core dump
定义 SIGILL    = 4     // 非法指令 + core dump
定义 SIGTRAP   = 5     // 断点陷阱
定义 SIGABRT   = 6     // abort() + core dump
定义 SIGBUS    = 7     // 总线错误 + core dump
定义 SIGFPE    = 8     // 浮点异常 + core dump
定义 SIGKILL   = 9     // 强制杀死(不可捕获)
定义 SIGUSR1   = 10    // 用户定义1
定义 SIGSEGV   = 11    // 段错误 + core dump
定义 SIGUSR2   = 12    // 用户定义2
定义 SIGPIPE   = 13    // 管道断裂
定义 SIGALRM   = 14    // alarm定时器到期
定义 SIGTERM   = 15    // 终止(可捕获)
定义 SIGSTKFLT = 16    // 栈错误
定义 SIGCHLD   = 17    // 子进程状态变化
定义 SIGCONT   = 18    // 继续(从停止恢复)
定义 SIGSTOP   = 19    // 停止(不可捕获)
定义 SIGTSTP   = 20    // 终端停止(Ctrl+Z)
定义 SIGTTIN   = 21    // 后台进程读终端
定义 SIGTTOU   = 22    // 后台进程写终端
定义 SIGURG    = 23    // 紧急数据(socket)
定义 SIGXCPU   = 24    // CPU时间限制
定义 SIGXFSZ   = 25    // 文件大小限制
定义 SIGVTALRM = 26    // 虚拟定时器
定义 SIGPROF   = 27    // 性能分析定时器
定义 SIGWINCH  = 28    // 窗口大小变化
定义 SIGIO     = 29    // I/O就绪
定义 SIGPWR    = 30    // 电源故障
定义 SIGSYS    = 31    // 无效系统调用

定义 SIGRTMIN  = 32
定义 SIGRTMAX  = 64

定义 信号_数量 = 64    // _NSIG
定义 信号_标准数 = 31

定义 SIG_DFL = 0    // 默认行为
定义 SIG_IGN = 1    // 忽略
定义 SIG_ERR = -1   // 错误

定义 SIG_行为_终止    = 0    // 终止进程
定义 SIG_行为_忽略    = 1    // 忽略信号
定义 SIG_行为_核心转储 = 2   // 终止 + core dump
定义 SIG_行为_停止    = 3    // 停止进程
定义 SIG_行为_继续    = 4    // 继续已停止的进程

定义 SA_NOCLDSTOP = 0x00000001   // SIGCHLD: 子进程停止时不通知
定义 SA_NOCLDWAIT = 0x00000002   // SIGCHLD: 子进程退出不变僵尸
定义 SA_SIGINFO   = 0x00000004   // 使用sa_sigaction替代sa_handler
定义 SA_RESTART   = 0x10000000   // 被信号中断的系统调用自动重启
定义 SA_节点FER   = 0x40000000   // 处理信号时不自动阻塞该信号
定义 SA_RESETHAND = 0x80000000   // 处理后重置为SIG_DFL

// 信号属性查询

函数 信号_默认行为(信号号) {
    // 终止: SIGHUP/SIGINT/SIGPIPE/SIGALRM/SIGTERM/SIGUSR1/SIGUSR2等
    // core dump: SIGQUIT/SIGILL/SIGABRT/SIGBUS/SIGFPE/SIGSEGV/SIGSYS
    // 忽略: SIGCHLD/SIGURG/SIGWINCH
    // 停止: SIGSTOP/SIGTSTP/SIGTTIN/SIGTTOU
    // 继续: SIGCONT

    如果 (信号号 == SIGQUIT || 信号号 == SIGILL || 信号号 == SIGABRT) { 返回 SIG_行为_核心转储 }
    如果 (信号号 == SIGBUS || 信号号 == SIGFPE || 信号号 == SIGSEGV) { 返回 SIG_行为_核心转储 }
    如果 (信号号 == SIGSYS || 信号号 == SIGTRAP || 信号号 == SIGXCPU) { 返回 SIG_行为_核心转储 }
    如果 (信号号 == SIGXFSZ) { 返回 SIG_行为_核心转储 }

    如果 (信号号 == SIGCHLD || 信号号 == SIGURG || 信号号 == SIGWINCH) { 返回 SIG_行为_忽略 }

    如果 (信号号 == SIGSTOP || 信号号 == SIGTSTP) { 返回 SIG_行为_停止 }
    如果 (信号号 == SIGTTIN || 信号号 == SIGTTOU) { 返回 SIG_行为_停止 }

    如果 (信号号 == SIGCONT) { 返回 SIG_行为_继续 }

    返回 SIG_行为_终止   // 默认: 终止
}

函数 信号_是致命_定义(信号号) {
    定义 行为 = 信号_默认行为(信号号)
    返回 行为 == SIG_行为_终止 || 行为 == SIG_行为_核心转储
}

函数 信号_是不可屏蔽(信号号) {
    返回 信号号 == SIGKILL || 信号号 == SIGSTOP
}

函数 信号_是实时(信号号) {
    返回 信号号 >= SIGRTMIN && 信号号 <= SIGRTMAX
}

函数 信号_产生core(信号号) {
    返回 信号_默认行为(信号号) == SIG_行为_核心转储
}

// 信号集操作 (sigset_t = u64位掩码)

函数 sigset_空()           { 返回 0x0000000000000000 }  // 64位空信号集
函数 sigset_满()           { 返回 0xFFFFFFFFFFFFFFFF }
函数 sigset_添加(集, 信号) { 返回 集 | (1 << (信号 - 1)) }
函数 sigset_移除(集, 信号) { 返回 集 & ~(1 << (信号 - 1)) }
函数 sigset_包含(集, 信号) { 返回 (集 & (1 << (信号 - 1))) != 0 }
函数 sigset_合并(a, b)     { 返回 a | b }
函数 sigset_交集(a, b)     { 返回 a & b }
函数 sigset_为空(集)       { 返回 集 == 0 }

// 不可屏蔽信号掩码: SIGKILL + SIGSTOP 永远不能被阻塞
定义 不可屏蔽掩码 = (1 << (SIGKILL - 1)) | (1 << (SIGSTOP - 1))

函数 sigset_过滤不可屏蔽(集) {
    // 从信号掩码中移除SIGKILL和SIGSTOP(它们不可被阻塞)
    返回 集 & ~不可屏蔽掩码
}

// 信号名称 (调试用)

函数 信号_名称(信号号) {
    如果 (信号号 == SIGHUP)  { 返回 "SIGHUP" }
    如果 (信号号 == SIGINT)  { 返回 "SIGINT" }
    如果 (信号号 == SIGQUIT) { 返回 "SIGQUIT" }
    如果 (信号号 == SIGILL)  { 返回 "SIGILL" }
    如果 (信号号 == SIGABRT) { 返回 "SIGABRT" }
    如果 (信号号 == SIGBUS)  { 返回 "SIGBUS" }
    如果 (信号号 == SIGFPE)  { 返回 "SIGFPE" }
    如果 (信号号 == SIGKILL) { 返回 "SIGKILL" }
    如果 (信号号 == SIGSEGV) { 返回 "SIGSEGV" }
    如果 (信号号 == SIGPIPE) { 返回 "SIGPIPE" }
    如果 (信号号 == SIGALRM) { 返回 "SIGALRM" }
    如果 (信号号 == SIGTERM) { 返回 "SIGTERM" }
    如果 (信号号 == SIGCHLD) { 返回 "SIGCHLD" }
    如果 (信号号 == SIGCONT) { 返回 "SIGCONT" }
    如果 (信号号 == SIGSTOP) { 返回 "SIGSTOP" }
    如果 (信号号 == SIGTSTP) { 返回 "SIGTSTP" }
    如果 (信号_是实时(信号号)) { 返回 "SIGRT" + 整数转字符串(信号号 - SIGRTMIN) }
    返回 "SIG" + 整数转字符串(信号号)
}

// 信号集高级操作

函数 sigset_计数(集) {
    定义 可变 计 = 0
    定义 可变 m = 集
    当 (m != 0) {
        计 = 计 + (m & 1)
        m = m >> 1
    }
    返回 计
}

函数 sigset_第一个(集) {
    定义 可变 i = 1
    当 (i <= 信号_数量) {
        如果 (sigset_包含(集, i)) { 返回 i }
        i = i + 1
    }
    返回 0
}

函数 sigset_差集(a, b) { 返回 a & ~b }
函数 sigset_取反(集) { 返回 ~集 }

// 信号分类

函数 信号_是停止信号(信号号) {
    返回 信号号 == SIGSTOP || 信号号 == SIGTSTP ||
           信号号 == SIGTTIN || 信号号 == SIGTTOU
}

函数 信号_是忽略信号(信号号) {
    返回 信号号 == SIGCHLD || 信号号 == SIGURG ||
           信号号 == SIGWINCH || 信号号 == SIGIO
}

函数 信号_是同步信号(信号号) {
    // 同步信号: 由进程自身触发(非外部发送)
    返回 信号号 == SIGILL || 信号号 == SIGTRAP || 信号号 == SIGBUS ||
           信号号 == SIGFPE || 信号号 == SIGSEGV || 信号号 == SIGSYS
}

// 致命信号掩码 (用于快速检查)
定义 致命信号掩码 = (1 << (SIGKILL - 1)) | (1 << (SIGTERM - 1)) |
                    (1 << (SIGHUP - 1)) | (1 << (SIGINT - 1)) |
                    (1 << (SIGPIPE - 1)) | (1 << (SIGALRM - 1))

函数 sigset_有致命信号(集) {
    返回 (集 & 致命信号掩码) != 0
}

// 默认行为名称 + 信号范围校验

函数 信号_行为名(行为) {
    如果 (行为 == SIG_行为_终止) { 返回 "Terminate" }
    如果 (行为 == SIG_行为_忽略) { 返回 "Ignore" }
    如果 (行为 == SIG_行为_核心转储) { 返回 "Core" }
    如果 (行为 == SIG_行为_停止) { 返回 "Stop" }
    如果 (行为 == SIG_行为_继续) { 返回 "Continue" }
    返回 "Unknown"
}

函数 信号_有效(信号号) {
    返回 信号号 >= 1 && 信号号 <= 信号_数量
}

函数 信号定义_统计() {
    返回 [信号_标准数, 信号_数量]
}


函数 信号定义_完整统计() {
    返回 [信号_最大值]
}

// merge source: 沙盒批次/批三/待厚/中枢/信号动作创.nova
// NovaOS 信号动作 (sigaction)
// 职责: 信号处理器注册、默认动作、信号处理入口

外部 VFS_创建文件
外部 VFS_写入
外部 VFS_关闭

定义 信号_默认 = 0      // SIG_DFL
定义 信号_忽略 = 1      // SIG_IGN

定义 SA_重启 = 1 << 0        // SA_RESTART: 系统调用自动重启
定义 SA_无子停止 = 1 << 1    // SA_NOCLDSTOP
定义 SA_无子等待 = 1 << 2    // SA_NOCLDWAIT
定义 SA_信息 = 1 << 3        // SA_SIGINFO: 使用3参数处理器
定义 SA_栈 = 1 << 4          // SA_ONSTACK: 在备用栈上执行
定义 SA_一次性 = 1 << 5      // SA_RESETHAND: 执行后恢复默认

// [处理器地址, 标志, 屏蔽集, 恢复函数]
定义 SA_处理器 = 0
定义 SA_标志 = 1
定义 SA_屏蔽 = 2
定义 SA_恢复 = 3

函数 信号动作_创建(处理器, 标志, 屏蔽集) {
    返回 [处理器, 标志, 屏蔽集, 0]
}

// 0=忽略, 1=终止, 2=终止+core, 3=停止, 4=继续
定义 默认动作表 = [
    0,  // 0: 无
    1,  // 1: SIGHUP - 终止
    1,  // 2: SIGINT - 终止
    2,  // 3: SIGQUIT - 终止+core
    2,  // 4: SIGILL - 终止+core
    2,  // 5: SIGTRAP - 终止+core
    2,  // 6: SIGABRT - 终止+core
    2,  // 7: SIGBUS - 终止+core
    2,  // 8: SIGFPE - 终止+core
    1,  // 9: SIGKILL - 终止(不可捕获)
    1,  // 10: SIGUSR1 - 终止
    2,  // 11: SIGSEGV - 终止+core
    1,  // 12: SIGUSR2 - 终止
    1,  // 13: SIGPIPE - 终止
    1,  // 14: SIGALRM - 终止
    1,  // 15: SIGTERM - 终止
    0,  // 16: SIGSTKFLT - 忽略
    0,  // 17: SIGCHLD - 忽略
    4,  // 18: SIGCONT - 继续
    3,  // 19: SIGSTOP - 停止(不可捕获)
    3,  // 20: SIGTSTP - 停止
    3,  // 21: SIGTTIN - 停止
    3,  // 22: SIGTTOU - 停止
    0,  // 23: SIGURG - 忽略
    1,  // 24: SIGXCPU - 终止
    1,  // 25: SIGXFSZ - 终止
    1,  // 26: SIGVTALRM - 终止
    1,  // 27: SIGPROF - 终止
    0,  // 28: SIGWINCH - 忽略
    1,  // 29: SIGIO - 终止
    1,  // 30: SIGPWR - 终止
    2   // 31: SIGSYS - 终止+core
]

// sigaction系统调用

函数 系统_sigaction(信号号, 新动作, 旧动作_输出) {
    如果 (信号号 < 1 || 信号号 >= 信号_数量) { 返回 错误_无效参数 }
    // SIGKILL和SIGSTOP不能修改处理器
    如果 (信号号 == 信号_KILL || 信号号 == 信号_STOP) { 返回 错误_无效参数 }

    定义 当前 = 获取当前进程()
    定义 处理器表 = 当前[T_信号处理器]

    // 保存旧动作
    如果 (旧动作_输出 != 空) {
        设置(旧动作_输出, 0, 处理器表[信号号])
    }

    // 设置新动作
    如果 (新动作 != 空) {
        处理器表[信号号] = 新动作
    }

    返回 成功
}

// 获取下一个待处理信号并执行动作
// 从系统调用/中断返回用户态前调用

函数 信号_处理挂起(任务) {
    定义 挂起 = 任务[T_信号挂起结构]
    如果 (!挂起信号_有信号(挂起)) { 返回 }

    定义 屏蔽 = 任务[T_信号屏蔽]
    // 可投递信号 = 挂起 & ~屏蔽
    定义 可投递 = 挂起[SP_掩码] & ~屏蔽

    如果 (可投递 == 0) { 返回 }  // 所有挂起信号都被屏蔽

    // 找到最低编号的可投递信号
    定义 可变 信号号 = 1
    当 (信号号 < 信号_数量) {
        如果 ((可投递 & (1 << 信号号)) != 0) {
            信号_执行动作(任务, 信号号)
            返回
        }
        信号号 = 信号号 + 1
    }
}

// 执行信号动作

函数 信号_执行动作(任务, 信号号) {
    // 清除挂起位
    定义 挂起 = 任务[T_信号挂起结构]
    挂起信号_清除(挂起, 信号号)

    定义 处理器表 = 任务[T_信号处理器]
    定义 动作 = 处理器表[信号号]

    如果 (动作 == 空 || 动作 == 信号_默认) {
        // 执行默认动作
        信号_执行默认(任务, 信号号)
        返回
    }

    如果 (动作 == 信号_忽略) {
        返回  // 忽略
    }

    // 用户自定义处理器: 设置用户栈帧
    信号_设置用户帧(任务, 信号号, 动作)

    // SA_RESETHAND: 执行后恢复默认
    如果 (动作[SA_标志] & SA_一次性) {
        处理器表[信号号] = 信号_默认
    }

    信号_投递总数 = 信号_投递总数 + 1
}

// 执行默认信号动作

函数 信号_执行默认(任务, 信号号) {
    如果 (信号号 < 0 || 信号号 >= 计数(默认动作表)) { 返回 }
    定义 动作类型 = 默认动作表[信号号]

    如果 (动作类型 == 0) {
        // 忽略
        返回
    } 否则 如果 (动作类型 == 1) {
        // 终止
        do_exit(任务, 信号号)
    } 否则 如果 (动作类型 == 2) {
        // 终止 + core dump
        // 检查进程rlimit: RLIMIT_CORE > 0 才生成core
        定义 core限制 = RLIM_INFINITY   // 默认允许core dump(实际应查RLIMIT_CORE)
        如果 (core限制 > 0) {
            内核信息("信号: 进程" + 整数转字符串(进程_PID(任务)) + " core dump (信号" + 整数转字符串(信号号) + ")")
            // 生成core文件: ELF core dump格式
            // 包含: PT_NOTE(寄存器) + PT_LOAD(内存段)
            生成_core_dump(任务, 信号号)
        }
        do_exit(任务, 信号号 | 0x80)  // 高位表示core
    } 否则 如果 (动作类型 == 3) {
        // 停止
        停止进程(任务)
    } 否则 如果 (动作类型 == 4) {
        // 继续
        继续进程(任务)
    }
}

// Core Dump生成 (ELF core格式,

函数 生成_core_dump(任务, 信号号) {
    // ELF core dump: PT_NOTE(寄存器+信号信息) + PT_LOAD(进程内存段)
    定义 pid = 进程_PID(任务)
    定义 core路径 = "/tmp/core." + 整数转字符串(pid)

    定义 fd = VFS_创建文件(core路径, 0x180)  // 0600权限
    如果 (fd < 0) {
        内核警告("core dump: 无法创建 " + core路径)
        返回
    }

    // ELF头 (简化: 写入标识 + 类型ET_CORE)
    定义 可变 头部 = []
    追加(头部, 0x7F)  // EI_MAG0
    追加(头部, 0x45)  // 'E'
    追加(头部, 0x4C)  // 'L'
    追加(头部, 0x46)  // 'F'
    追加(头部, 2)      // 64位
    追加(头部, 1)      // 小端
    追加(头部, 1)      // 版本
    追加(头部, 0)      // OS/ABI
    VFS_写入(fd, 头部)

    // PT_NOTE段: 寄存器状态
    定义 寄存器 = 任务[T_寄存器]
    如果 (寄存器 != 空) {
        定义 可变 注释 = [信号号, pid]
        // 写入通用寄存器(rax~r15 共16个)
        定义 可变 i = 0
        当 (i < 16 && i < 计数(寄存器)) {
            追加(注释, 寄存器[i])
            i = i + 1
        }
        VFS_写入(fd, 注释)
    }

    // PT_LOAD段: 进程VMA内存
    如果 (任务.mm != 空) {
        定义 可变 vma = 任务.mm.首VMA
        当 (vma != 空) {
            // 只转储可读的段, 跳过共享库映射以减小体积
            如果 (vma.标志 & 1 != 0) {  // VM_READ
                定义 大小 = vma.结束 - vma.起始
                如果 (大小 > 0 && 大小 < 64 * 1024 * 1024) {  // 限制64MB
                    定义 可变 段头 = [vma.起始, vma.结束, vma.标志]
                    VFS_写入(fd, 段头)
                }
            }
            vma = vma.下一个
        }
    }

    VFS_关闭(fd)
    内核信息("core dump: " + core路径 + " (PID=" + 整数转字符串(pid) +
             " 信号=" + 整数转字符串(信号号) + ")")
}

// 设置用户态信号帧 (在用户栈上构建rt_sigframe)

定义 可变 信号动作_创建数 = 0
定义 可变 信号动作_core_dump数 = 0

函数 信号动作_健康检查() {
    定义 可变 问题 = []
    如果 (信号动作_core_dump数 > 10) {
        追加(问题, "core dump过多: " + 整数转字符串(信号动作_core_dump数))
    }
    如果 (计数(问题) == 0) { 返回 "信号动作健康" }
    返回 问题
}

函数 信号动作_统计() {
    返回 {
        创建数: 信号动作_创建数,
        core_dump: 信号动作_core_dump数,
    }
}

函数 信号动作_重置() {
    信号动作_创建数 = 0
    信号动作_core_dump数 = 0
}

定义 SA_NOCLDSTOP = 1
定义 SA_NOCLDWAIT = 2
定义 SA_SIGINFO = 4
定义 SA_RESTART = 0x10000000
定义 SA_NODEFER = 0x40000000
定义 SA_RESETHAND = 0x80000000

函数 信号动作_标志名(标志) {
    如果 (标志 & SA_SIGINFO) { 返回 "SA_SIGINFO" }
    如果 (标志 & SA_RESTART) { 返回 "SA_RESTART" }
    如果 (标志 & SA_NODEFER) { 返回 "SA_NODEFER" }
    返回 "0x" + 十六进制(标志)
}

// merge source: 沙盒批次/批三/待厚/中枢/信号发送.nova
//   1. 信号投递: 加入pending队列(位掩码+sigqueue链表)
//   2. 信号屏蔽: blocked掩码, SIGKILL/SIGSTOP不可屏蔽
//   3. 信号处理: 返回用户态前检查, 三种动作(DFL/IGN/用户handler)
//   4. 默认动作: 终止/忽略/停止/继续/core dump
//   5. 信号队列: 实时信号(32-64)可排队, 标准信号合并
//   6. 进程组信号: kill(-pgid, sig)发给整个组

定义 SIG_DFL = 0
定义 SIG_IGN = 1
定义 SIG_ERR = -1

定义 动作_终止     = 0
定义 动作_忽略     = 1
定义 动作_核心转储 = 2
定义 动作_停止     = 3
定义 动作_继续     = 4

定义 SIGKILL_MASK = (1 << 9)
定义 SIGSTOP_MASK = (1 << 19)
定义 不可屏蔽掩码 = SIGKILL_MASK | SIGSTOP_MASK

定义 可变 信号_发送总数 = 0
定义 可变 信号_处理总数 = 0
定义 可变 信号_忽略总数 = 0

// 信号投递 

函数 信号_发送(任务, 信号号) {
    如果 (任务 == 空) { 返回 错误_无此进程 }
    如果 (信号号 < 0 || 信号号 >= 信号_数量) { 返回 错误_无效参数 }
    如果 (信号号 == 0) { 返回 成功 }  // sig=0: 检查权限但不发送

    // 检查进程是否已退出
    如果 (进程_状态(任务) == 进程_僵尸 || 进程_状态(任务) == 进程_死亡) {
        返回 错误_无此进程
    }

    // SIGCONT特殊: 清除所有pending的停止信号
    如果 (信号号 == 18) {  // SIGCONT
        定义 停止掩码 = (1 << 19) | (1 << 20) | (1 << 21) | (1 << 22)
        信号_清除挂起(任务, 停止掩码)
    }

    // 停止信号特殊: 清除pending的SIGCONT
    如果 (信号号 == 19 || 信号号 == 20 || 信号号 == 21 || 信号号 == 22) {
        信号_清除挂起(任务, 1 << 18)
    }

    // 检查信号是否被忽略(SIG_IGN)
    // SIGKILL和SIGSTOP不能被忽略
    如果 (信号号 != 9 && 信号号 != 19) {
        定义 处理器 = 进程_获取信号处理器(任务, 信号号)
        如果 (处理器 == SIG_IGN) {
            信号_忽略总数 = 信号_忽略总数 + 1
            返回 成功
        }
    }

    // 设置pending位
    定义 旧挂起 = 进程_信号挂起(任务)
    进程_设置信号挂起(任务, 旧挂起 | (1 << 信号号))

    信号_发送总数 = 信号_发送总数 + 1

    // 唤醒目标进程(如果它在睡眠)
    signal_wake_up(任务, 信号号)

    返回 成功
}

// 发送信号给进程组 

函数 信号_发送给组(pgid, 信号号) {
    定义 可变 已发送 = 0
    定义 可变 错误 = 错误_无此进程
    // 遍历进程表, 找同组进程
    定义 可变 pid = 1
    当 (pid < 进程_最大PID()) {
        定义 任务 = 进程表_查找(pid)
        如果 (任务 != 空 && 进程_组ID(任务) == pgid) {
            定义 结果 = 信号_发送(任务, 信号号)
            如果 (结果 == 成功) { 已发送 = 已发送 + 1 }
            错误 = 结果
        }
        pid = pid + 1
    }
    如果 (已发送 > 0) { 返回 成功 }
    返回 错误
}

函数 信号_发送给全部(信号号) {
    定义 可变 已发送 = 0
    定义 当前pid = 进程_PID(获取当前进程())
    定义 可变 pid = 2  // 跳过init(pid=1)
    当 (pid < 进程_最大PID()) {
        如果 (pid != 当前pid) {
            定义 任务 = 进程表_查找(pid)
            如果 (任务 != 空) {
                信号_发送(任务, 信号号)
                已发送 = 已发送 + 1
            }
        }
        pid = pid + 1
    }
    如果 (已发送 > 0) { 返回 成功 }
    返回 错误_无此进程
}

// 信号处理 
// 在返回用户态前(Nova系统调用返回/中断返回)调用

函数 信号_检查并处理(任务) {
    如果 (任务 == 空) { 返回 }
    定义 挂起 = 进程_信号挂起(任务)
    定义 屏蔽 = 进程_信号掩码(任务)

    // 有效pending = pending & ~blocked (SIGKILL/SIGSTOP无视blocked)
    定义 有效 = (挂起 & ~屏蔽) | (挂起 & 不可屏蔽掩码)
    如果 (有效 == 0) { 返回 }

    // 按优先级处理: SIGKILL最高, 然后从低到高
    如果 ((有效 & SIGKILL_MASK) != 0) {
        信号_出队(任务, 9)
        do_exit(任务, 9 | 0x80)  // 被信号杀死的退出码
        返回
    }

    如果 ((有效 & SIGSTOP_MASK) != 0) {
        信号_出队(任务, 19)
        // 暂停进程
        进程_设置状态(任务, 进程_停止)
        通知父进程_停止(任务)
        调度()
        返回
    }

    // 处理其他信号 (从1到31)
    定义 可变 sig = 1
    当 (sig < 32) {
        如果 ((有效 >> sig) & 1) {
            信号_出队(任务, sig)
            信号_处理一个(任务, sig)
            返回  // 每次只处理一个信号
        }
        sig = sig + 1
    }
}

函数 信号_处理一个(任务, 信号号) {
    // ★ AI先天特性: 信号异常检测
    AI信号_记录(进程_PID(任务), 信号号)

    定义 处理器 = 进程_获取信号处理器(任务, 信号号)

    如果 (处理器 == SIG_IGN) {
        // 忽略
        信号_忽略总数 = 信号_忽略总数 + 1
        返回
    }

    如果 (处理器 == SIG_DFL) {
        // 默认动作
        信号_执行默认动作(任务, 信号号)
        返回
    }

    // 用户自定义处理器: 设置信号帧, 跳转到用户态handler
    信号_设置帧(任务, 信号号, 处理器)
    信号_处理总数 = 信号_处理总数 + 1

    // 处理SA_RESETHAND: 一次性处理器
    // 处理SA_节点FER: 不自动屏蔽当前信号
}

// 执行默认动作

函数 信号_执行默认动作(任务, 信号号) {
    定义 动作 = 信号_获取默认动作(信号号)

    如果 (动作 == 动作_忽略) {
        返回
    }
    如果 (动作 == 动作_终止) {
        do_exit(任务, 信号号 | 0x80)
        返回
    }
    如果 (动作 == 动作_核心转储) {
        // 核心转储: 检查RLIMIT_CORE后记录诊断信息
        定义 pid = 进程_PID(任务)
        内核信息("signal: 核心转储 PID=" + 整数转字符串(pid) + " sig=" + 整数转字符串(信号号))
        // ELF core dump生成(M2+完整实现, M1记录寄存器状态)
        内核信息("  RIP=" + 整数转十六进制(任务.保存的RIP) + " RSP=" + 整数转十六进制(任务.保存的RSP))
        do_exit(任务, 信号号 | 0x80)
        返回
    }
    如果 (动作 == 动作_停止) {
        进程_设置状态(任务, 进程_停止)
        通知父进程_停止(任务)
        调度()
        返回
    }
    如果 (动作 == 动作_继续) {
        如果 (进程_状态(任务) == 进程_停止) {
            进程_设置状态(任务, 进程_就绪)
        }
        返回
    }
}

// merge source: 沙盒批次/批三/待厚/中枢/信号投递.nova
// NovaOS 信号投递
// 职责: 信号排队、投递、挂起信号集管理

定义 SI_信号号 = 0      // 信号编号
定义 SI_错误码 = 1      // errno
定义 SI_代码 = 2        // 信号原因代码
定义 SI_发送者PID = 3   // 发送进程PID
定义 SI_发送者UID = 4   // 发送者UID
定义 SI_值 = 5          // sigval (用户数据)

函数 信号信息_创建(信号号, 代码, 发送者PID) {
    返回 [信号号, 0, 代码, 发送者PID, 0, 0]
}

定义 SI_USER = 0        // kill() 发送
定义 SI_KERNEL = 128     // 内核发送
定义 SI_TIMER = -2       // 定时器过期
定义 SI_MESGQ = -3       // 消息队列
定义 SI_ASYNCIO = -4     // 异步IO
定义 SI_TKILL = -6       // tkill/tgkill

定义 可变 信号_发送总数 = 0
定义 可变 信号_投递总数 = 0
定义 可变 信号_丢弃数 = 0
定义 可变 信号_排队数 = 0

// 信号挂起队列 (每个进程一个)

// 挂起信号 = [位掩码, 信号信息队列]
定义 SP_掩码 = 0
定义 SP_队列 = 1

函数 挂起信号_创建() {
    返回 [0, 链表_创建()]
}

函数 挂起信号_有信号(挂起) {
    返回 挂起[SP_掩码] != 0
}

函数 挂起信号_测试(挂起, 信号号) {
    返回 (挂起[SP_掩码] & (1 << 信号号)) != 0
}

函数 挂起信号_设置(挂起, 信号号) {
    设置(挂起, SP_掩码, 挂起[SP_掩码] | (1 << 信号号))
}

函数 挂起信号_清除(挂起, 信号号) {
    设置(挂起, SP_掩码, 挂起[SP_掩码] & ~(1 << 信号号))
}

// 别名(被信号量/管道等引用)
函数 当前进程_有待处理信号() {
    定义 当前 = 获取当前进程()
    如果 (当前 == 空) { 返回 假 }
    返回 挂起信号_有信号(当前[T_信号挂起])
}

// 发送信号到进程

函数 信号_发送到进程(目标, 信号号, 信息) {
    如果 (目标 == 空 || 信号号 < 1 || 信号号 >= 信号_数量) {
        返回 错误_无效参数
    }

    // 检查信号是否被忽略
    如果 (信号_被忽略(目标, 信号号)) {
        信号_丢弃数 = 信号_丢弃数 + 1
        返回 成功  // 忽略但不报错
    }

    // 检查信号是否被阻塞 (阻塞的信号仍然要排队)
    定义 挂起 = 目标[T_信号挂起结构]

    // 标准信号(1-31): 不排队, 只设置位
    如果 (信号号 <= 31) {
        如果 (挂起信号_测试(挂起, 信号号)) {
            // 已经有一个待处理, 丢弃
            信号_丢弃数 = 信号_丢弃数 + 1
            返回 成功
        }
    }

    // 实时信号(32-64): 排队
    如果 (信号号 >= 32) {
        // 检查队列长度限制
        如果 (信号_排队数 > 1024) {
            信号_丢弃数 = 信号_丢弃数 + 1
            返回 错误_队列满
        }
        // 将信号信息加入队列
        链表_尾插(挂起[SP_队列], 信息)
        信号_排队数 = 信号_排队数 + 1
    }

    // 设置挂起位
    挂起信号_设置(挂起, 信号号)

    信号_发送总数 = 信号_发送总数 + 1

    // 如果目标在睡眠, 唤醒它 (SIGKILL/SIGCONT特殊处理)
    信号_唤醒目标(目标, 信号号)

    返回 成功
}

// kill系统调用

函数 系统_kill(目标PID, 信号号) {
    如果 (信号号 < 0 || 信号号 >= 信号_数量) { 返回 错误_无效参数 }

    // 信号号=0: 检查进程是否存在
    如果 (信号号 == 0) {
        定义 进程 = 进程表_查找(目标PID)
        返回 如果选数值(进程 != 空, 成功, 错误_不存在)
    }

    如果 (目标PID > 0) {
        // 发送给特定进程
        定义 进程 = 进程表_查找(目标PID)
        如果 (进程 == 空) { 返回 错误_不存在 }
        定义 信息 = 信号信息_创建(信号号, SI_USER, 获取当前进程()[T_进程号])
        返回 信号_发送到进程(进程, 信号号, 信息)
    } 否则 如果 (目标PID == 0) {
        // 发送给同进程组的所有进程
        返回 信号_发送到进程组(获取当前进程()[T_进程组], 信号号)
    } 否则 如果 (目标PID == -1) {
        // 发送给所有进程 (init除外)
        返回 信号_发送到全部(信号号)
    } 否则 {
        // 发送给指定进程组 (|目标PID|)
        返回 信号_发送到进程组(0 - 目标PID, 信号号)
    }
}

// 发送信号到进程组
函数 信号_发送到进程组(进程组ID, 信号号) {
    定义 进程列表 = 获取所有进程()
    定义 信息 = 信号信息_创建(信号号, SI_USER, 获取当前进程()[T_进程号])
    定义 可变 i = 0
    当 (i < 计数(进程列表)) {
        如果 (进程列表[i][T_进程组] == 进程组ID) {
            信号_发送到进程(进程列表[i], 信号号, 信息)
        }
        i = i + 1
    }
    返回 成功
}

// 发送信号到所有进程
函数 信号_发送到全部(信号号) {
    定义 进程列表 = 获取所有进程()
    定义 信息 = 信号信息_创建(信号号, SI_USER, 获取当前进程()[T_进程号])
    定义 可变 i = 0
    当 (i < 计数(进程列表)) {
        如果 (进程列表[i][T_进程号] > 1) {  // 跳过init
            信号_发送到进程(进程列表[i], 信号号, 信息)
        }
        i = i + 1
    }
    返回 成功
}

// 信号唤醒目标进程

函数 信号_唤醒目标(目标, 信号号) {
    // SIGKILL和SIGSTOP可以唤醒深度睡眠的进程
    如果 (信号号 == 信号_KILL || 信号号 == 信号_STOP) {
        如果 (目标[T_状态] == 进程_深睡 || 目标[T_状态] == 进程_睡眠) {
            唤醒进程(目标)
        }
    } 否则 {
        // 其他信号只唤醒轻度睡眠
        如果 (目标[T_状态] == 进程_睡眠) {
            唤醒进程(目标)
        }
    }

    // SIGCONT: 恢复停止的进程
    如果 (信号号 == 信号_CONT) {
        如果 (目标[T_状态] == 进程_停止) {
            继续进程(目标)
        }
    }
}

// 检查信号是否被忽略
函数 信号_被忽略(目标, 信号号) {
    // SIGKILL和SIGSTOP不能被忽略
    如果 (信号号 == 信号_KILL || 信号号 == 信号_STOP) { 返回 假 }
    // 检查信号处理器是否设为SIG_IGN
    定义 处理器 = 目标[T_信号处理器]
    如果 (处理器 == 空) { 返回 假 }
    返回 处理器[信号号] == 信号_忽略
}

函数 如果选数值(条件, 真值, 假值) {
    如果 (条件) { 返回 真值 }
    返回 假值
}

// sigprocmask: 修改信号屏蔽字

定义 SIG_BLOCK = 0      // 添加到屏蔽集
定义 SIG_UNBLOCK = 1    // 从屏蔽集移除
定义 SIG_SETMASK = 2    // 替换屏蔽集

函数 系统_sigprocmask(操作, 新掩码) {
    定义 当前 = 获取当前进程()
    定义 旧掩码 = 当前[T_信号屏蔽]

    如果 (操作 == SIG_BLOCK) {
        设置(当前, T_信号屏蔽, 旧掩码 | 新掩码)
    } 否则 如果 (操作 == SIG_UNBLOCK) {
        设置(当前, T_信号屏蔽, 旧掩码 & ~新掩码)
    } 否则 如果 (操作 == SIG_SETMASK) {
        设置(当前, T_信号屏蔽, 新掩码)
    } 否则 {
        返回 错误_无效参数
    }

    // SIGKILL和SIGSTOP不能被屏蔽
    定义 不可屏蔽 = (1 << 信号_KILL) | (1 << 信号_STOP)
    设置(当前, T_信号屏蔽, 当前[T_信号屏蔽] & ~不可屏蔽)

    返回 旧掩码
}

// 统计

函数 信号投递_统计() {
    返回 [信号_发送总数, 信号_投递总数, 信号_丢弃数, 信号_排队数]
}


函数 信号投递_完整统计() {
    返回 [信号_发送总数, 信号_投递总数, 信号_丢弃数, 信号_排队数]
}

// 信号投递辅助

函数 信号投递_健康检查() {
    定义 可变 问题 = []
    如果 (信号_丢弃数 > 信号_发送总数 / 5 && 信号_发送总数 > 100) {
        追加(问题, "信号丢弃率过高")
    }
    如果 (信号_排队数 > 1024) {
        追加(问题, "信号排队过多: " + 整数转字符串(信号_排队数))
    }
    如果 (计数(问题) == 0) { 返回 "信号投递健康" }
    返回 问题
}

函数 信号投递_重置() {
    信号_发送总数 = 0
    信号_投递总数 = 0
    信号_丢弃数 = 0
    信号_排队数 = 0
}

函数 信号_丢弃率() {
    如果 (信号_发送总数 == 0) { 返回 0 }
    返回 信号_丢弃数 * 100 / 信号_发送总数
}

函数 信号_投递率() {
    如果 (信号_发送总数 == 0) { 返回 0 }
    返回 信号_投递总数 * 100 / 信号_发送总数
}

// merge source: 沙盒批次/批四/待厚/中枢/信号上采样.nova

定义 定点基 = 1024
定义 可变 运算总数 = 0

函数 信号_上采样(数据, 长度, 因子, 输出) {
    运算总数 = 运算总数 + 1
    定义 可变 写位 = 0
    定义 可变 读位 = 0
    当 (读位 < 长度) {
        定义 当前 = 内存_读32(数据 + 读位 * 4)
        内存_写32(输出 + 写位 * 4, 当前)
        写位 = 写位 + 1
        定义 可变 插值 = 1
        当 (插值 < 因子) {
            定义 可变 下一个 = 当前
            如果 (读位 + 1 < 长度) {
                下一个 = 内存_读32(数据 + (读位 + 1) * 4)
            }
            定义 插值点 = 当前 + (下一个 - 当前) * 插值 / 因子
            内存_写32(输出 + 写位 * 4, 插值点)
            写位 = 写位 + 1
            插值 = 插值 + 1
        }
        读位 = 读位 + 1
    }
    返回 写位
}

函数 信号_下采样(数据, 长度, 因子, 输出) {
    运算总数 = 运算总数 + 1
    定义 可变 写位 = 0
    定义 可变 读位 = 0
    当 (读位 < 长度) {
        定义 可变 累加 = 0
        定义 可变 计 = 0
        当 (计 < 因子 && 读位 + 计 < 长度) {
            累加 = 累加 + 内存_读32(数据 + (读位 + 计) * 4)
            计 = 计 + 1
        }
        内存_写32(输出 + 写位 * 4, 累加 / 计)
        写位 = 写位 + 1
        读位 = 读位 + 因子
    }
    返回 写位
}

函数 卷积(信号, 信号长, 核, 核长, 输出) {
    运算总数 = 运算总数 + 1
    定义 输出长 = 信号长 + 核长 - 1
    定义 可变 位 = 0
    当 (位 < 输出长) {
        定义 可变 和 = 0
        定义 可变 核位 = 0
        当 (核位 < 核长) {
            定义 信号位 = 位 - 核位
            如果 (信号位 >= 0 && 信号位 < 信号长) {
                和 = 和 + 内存_读32(信号 + 信号位 * 4) * 内存_读32(核 + 核位 * 4) / 定点基
            }
            核位 = 核位 + 1
        }
        内存_写32(输出 + 位 * 4, 和)
        位 = 位 + 1
    }
    返回 输出长
}

函数 信号_差分(数据, 长度, 输出) {
    定义 可变 位 = 1
    当 (位 < 长度) {
        内存_写32(输出 + (位 - 1) * 4, 内存_读32(数据 + 位 * 4) - 内存_读32(数据 + (位 - 1) * 4))
        位 = 位 + 1
    }
    返回 长度 - 1
}

函数 信号_累积(数据, 长度, 输出) {
    定义 可变 和 = 0
    定义 可变 位 = 0
    当 (位 < 长度) {
        和 = 和 + 内存_读32(数据 + 位 * 4)
        内存_写32(输出 + 位 * 4, 和)
        位 = 位 + 1
    }
}

函数 信号_能量(数据, 长度) {
    定义 可变 能 = 0
    定义 可变 位 = 0
    当 (位 < 长度) {
        定义 值 = 内存_读32(数据 + 位 * 4)
        能 = 能 + 值 * 值 / 定点基
        位 = 位 + 1
    }
    返回 能
}

函数 信号_互相关(甲, 乙, 长度, 延迟, 输出) {
    运算总数 = 运算总数 + 1
    定义 可变 延位 = 0
    当 (延位 < 延迟) {
        定义 可变 和 = 0
        定义 可变 位 = 0
        当 (位 < 长度) {
            定义 乙位 = 位 + 延位
            如果 (乙位 < 长度) {
                和 = 和 + 内存_读32(甲 + 位 * 4) * 内存_读32(乙 + 乙位 * 4) / 定点基
            }
            位 = 位 + 1
        }
        内存_写32(输出 + 延位 * 4, 和)
        延位 = 延位 + 1
    }
}

函数 信号_移动平均(数据, 长度, 窗口, 输出) {
    运算总数 = 运算总数 + 1
    定义 可变 和 = 0
    定义 可变 位 = 0
    当 (位 < 窗口 && 位 < 长度) {
        和 = 和 + 内存_读32(数据 + 位 * 4)
        内存_写32(输出 + 位 * 4, 和 / (位 + 1))
        位 = 位 + 1
    }
    当 (位 < 长度) {
        和 = 和 + 内存_读32(数据 + 位 * 4) - 内存_读32(数据 + (位 - 窗口) * 4)
        内存_写32(输出 + 位 * 4, 和 / 窗口)
        位 = 位 + 1
    }
}

函数 信号_峰值检测(数据, 长度, 阈值) {
    定义 可变 峰值数 = 0
    定义 可变 位 = 1
    当 (位 < 长度 - 1) {
        定义 当前 = 内存_读32(数据 + 位 * 4)
        定义 前 = 内存_读32(数据 + (位 - 1) * 4)
        定义 后 = 内存_读32(数据 + (位 + 1) * 4)
        如果 (当前 > 前 && 当前 > 后 && 当前 > 阈值) { 峰值数 = 峰值数 + 1 }
        位 = 位 + 1
    }
    返回 峰值数
}

函数 信号_归一化(数据, 长度) {
    定义 可变 最大 = 0
    定义 可变 位 = 0
    当 (位 < 长度) {
        定义 绝对值 = 内存_读32(数据 + 位 * 4)
        如果 (绝对值 < 0) { 绝对值 = 0 - 绝对值 }
        如果 (绝对值 > 最大) { 最大 = 绝对值 }
        位 = 位 + 1
    }
    如果 (最大 == 0) { 返回 }
    位 = 0
    当 (位 < 长度) {
        定义 值 = 内存_读32(数据 + 位 * 4)
        内存_写32(数据 + 位 * 4, 值 * 定点基 / 最大)
        位 = 位 + 1
    }
}

函数 张量_完整统计() {
    返回 [运算总数]
}

// merge source: 沙盒批次/批五/待厚/中枢/信号处理完.nova

定义 信号_终止 = 1
定义 信号_中断 = 2
定义 信号_退出 = 3
定义 信号_非法 = 4
定义 信号_陷阱 = 5
定义 信号_中止 = 6
定义 信号_段错 = 11
定义 信号_管道 = 13
定义 信号_闹钟 = 14
定义 信号_停止 = 19
定义 信号_继续 = 18
定义 信号_子终 = 17
定义 信号_紧急 = 23
定义 信号_用户一 = 10
定义 信号_用户二 = 12
定义 最大信号 = 64
定义 实时信号起始 = 32
定义 信号队列深度 = 32

结构 信号项 {
    信号号,
    发送者,
    时间戳,
    附加值,
}

结构 信号状态 {
    处理表,
    屏蔽集,
    待处理集,
    队列头,
    队列尾,
    队列数量,
}

定义 可变 发送总数 = 0
定义 可变 处理总数 = 0
定义 可变 忽略总数 = 0
定义 可变 丢弃总数 = 0
定义 可变 致命总数 = 0

函数 信号_创建状态() {
    定义 状态 = 堆_分配(信号状态)
    状态.处理表 = 堆_分配(最大信号 * 8)
    定义 可变 序号 = 0
    当 (序号 < 最大信号) {
        内存_写64(状态.处理表 + 序号 * 8, 0)
        序号 = 序号 + 1
    }
    状态.屏蔽集 = 0
    状态.待处理集 = 0
    状态.队列头 = 0
    状态.队列尾 = 0
    状态.队列数量 = 0
    返回 状态
}

函数 信号_注册处理(状态, 信号号, 处理函数) {
    如果 (状态 == 0 || 信号号 >= 最大信号) { 返回 错误_无效参数 }
    如果 (信号号 == 信号_停止 || 信号号 == 信号_终止) { 返回 错误_不允许 }
    内存_写64(状态.处理表 + 信号号 * 8, 处理函数)
    返回 0
}

函数 信号_屏蔽(状态, 信号号) {
    如果 (状态 == 0 || 信号号 >= 最大信号) { 返回 }
    状态.屏蔽集 = 状态.屏蔽集 | (1 << 信号号)
}

函数 信号_解除屏蔽(状态, 信号号) {
    如果 (状态 == 0 || 信号号 >= 最大信号) { 返回 }
    状态.屏蔽集 = 状态.屏蔽集 & ~(1 << 信号号)
}

函数 信号_派发(状态) {
    如果 (状态 == 0) { 返回 }
    定义 可变 信号号 = 0
    当 (信号号 < 最大信号) {
        如果 ((状态.待处理集 & (1 << 信号号)) != 0) {
            状态.待处理集 = 状态.待处理集 & ~(1 << 信号号)
            定义 处理函数 = 内存_读64(状态.处理表 + 信号号 * 8)
            如果 (处理函数 != 0) {
                处理函数(信号号)
                处理总数 = 处理总数 + 1
            } 否则 {
                信号_默认动作(信号号)
            }
        }
        信号号 = 信号号 + 1
    }
}

函数 信号_默认动作(信号号) {
    如果 (信号号 == 信号_终止 || 信号号 == 信号_退出 || 信号号 == 信号_段错 || 信号号 == 信号_中止 || 信号号 == 信号_非法) {
        致命总数 = 致命总数 + 1
    }
    如果 (信号号 == 信号_停止) {
        处理总数 = 处理总数 + 1
    }
    如果 (信号号 == 信号_继续) {
        处理总数 = 处理总数 + 1
    }
    如果 (信号号 == 信号_子终) {
        忽略总数 = 忽略总数 + 1
    }
}

函数 信号_弹出实时(状态) {
    如果 (状态 == 0 || 状态.队列头 == 0) { 返回 0 }
    定义 项 = 状态.队列头
    状态.队列头 = 内存_读64(项 + 24)
    如果 (状态.队列头 == 0) { 状态.队列尾 = 0 }
    状态.队列数量 = 状态.队列数量 - 1
    返回 项
}

函数 信号_有待处理(状态) {
    如果 (状态 == 0) { 返回 假 }
    返回 (状态.待处理集 & ~状态.屏蔽集) != 0
}

函数 信号处理_完整统计() {
    返回 [发送总数, 处理总数, 忽略总数, 丢弃总数, 致命总数]
}

// merge source: 沙盒批次/批五/待厚/中枢/信号量尝试.nova

函数 信号量_尝试获取(sem) {
    定义 当前 = 原子_读取(sem.计数)
    如果 (当前 > 0) {
        返回 原子_比较交换(sem.计数, 当前, 当前 - 1)
    }
    返回 假
}

函数 信号量_释放(sem) {
    原子_加(sem.计数, 1)

    // 唤醒一个等待者
    如果 (!等待队列_为空(sem.等待链表)) {
        自旋锁_获取(sem.锁)
        等待队列_唤醒一个(sem.等待链表)
        自旋锁_释放(sem.锁)
    }
}

函数 信号量_可用数(sem) {
    返回 原子_读取(sem.计数)
}

// 完成量(completion) - 一次性同步

结构 完成量 {
    完成标志,    // 原子变量
    等待链表,    // 等待队列头
}

函数 完成量_创建_信号量版() {
    返回 完成量 {
        完成标志: 原子_创建(0),
        等待链表: 等待队列_创建()
    }
}

函数 完成量_初始化(comp) {
    原子_设置(comp.完成标志, 0)
}

函数 完成量_等待(comp) {
    如果 (原子_读取(comp.完成标志) > 0) {
        原子_减(comp.完成标志, 1)
        返回
    }

    定义 可变 等待项 = 等待项_创建(获取当前进程(), 真)
    等待队列_加入(comp.等待链表, 等待项)

    循环 {
        进程_设置状态(获取当前进程(), 进程状态_不可中断睡眠)

        如果 (原子_读取(comp.完成标志) > 0) {
            原子_减(comp.完成标志, 1)
            跳出
        }

        调度()
    }

    进程_设置状态(获取当前进程(), 进程状态_运行)
    等待队列_移除(comp.等待链表, 等待项)
}

函数 完成量_等待_超时(comp, 超时_毫秒) {
    如果 (原子_读取(comp.完成标志) > 0) {
        原子_减(comp.完成标志, 1)
        返回 0
    }

    定义 截止时间 = 当前时间_秒() + 超时_毫秒
    定义 可变 等待项 = 等待项_创建(获取当前进程(), 真)
    等待队列_加入(comp.等待链表, 等待项)

    循环 {
        如果 (原子_读取(comp.完成标志) > 0) {
            原子_减(comp.完成标志, 1)
            等待队列_移除(comp.等待链表, 等待项)
            返回 0
        }

        如果 (当前时间_秒() >= 截止时间) {
            等待队列_移除(comp.等待链表, 等待项)
            返回 错误码_超时
        }

        进程_设置状态(获取当前进程(), 进程状态_不可中断睡眠)
        schedule_timeout(截止时间 - 当前时间_秒())
    }
}

函数 完成量_等待_可中断(comp) {
    如果 (原子_读取(comp.完成标志) > 0) {
        原子_减(comp.完成标志, 1)
        返回 0
    }

    定义 可变 等待项 = 等待项_创建(获取当前进程(), 真)
    等待队列_加入(comp.等待链表, 等待项)

    循环 {
        如果 (当前进程_有待处理信号()) {
            等待队列_移除(comp.等待链表, 等待项)
            返回 错误码_被中断
        }

        如果 (原子_读取(comp.完成标志) > 0) {
            原子_减(comp.完成标志, 1)
            等待队列_移除(comp.等待链表, 等待项)
            返回 0
        }

        进程_设置状态(获取当前进程(), 进程状态_可中断睡眠)
        调度()
    }
}

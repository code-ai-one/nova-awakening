// NovaOS AI设备感知 — 先天AI特性
// Phase: P5 | AI融入驱动子系统
// 核心算法:
//   1. 错误频率追踪: 每设备错误率EMA→检测退化趋势
//   2. 故障预测: 错误率斜率+加速度→预测故障时间
//   3. 设备健康评分: 综合错误率/延迟/吞吐量的0-100评分
//   4. 自动降级: 健康评分低于阈值→建议切换到备用设备

结构 设备画像 {
    名称,
    错误率EMA,    // u64 错误/秒 × 1024
    延迟EMA,    // u64 微秒 × 1024
    总错误数,
    总IO数,
    健康评分,    // u32 0-100
    上次错误时间,
    连续错误,
    已降级,
}

定义 可变 设备画像表 = []

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 AI设备_初始化() {
    内核信息("AI设备感知: 错误率EMA+故障预测+健康评分+自动降级")
}

函数 AI设备_记录错误(设备名, 错误类型) {
    定义 画像 = AI设备_获取或创建(设备名)
    画像.总错误数 = 画像.总错误数 + 1
    画像.连续错误 = 画像.连续错误 + 1
    画像.上次错误时间 = 读取毫秒()
    画像.错误率EMA = (画像.错误率EMA * 922 + 1024 * 102) / 1024
    AI设备_更新健康(画像)
}

函数 AI设备_记录成功IO(设备名, 延迟us) {
    定义 画像 = AI设备_获取或创建(设备名)
    画像.总IO数 = 画像.总IO数 + 1
    画像.连续错误 = 0
    画像.延迟EMA = (画像.延迟EMA * 922 + 延迟us * 1024 * 102) / (1024 * 1024)
    // 错误率衰减
    画像.错误率EMA = 画像.错误率EMA * 922 / 1024
    AI设备_更新健康(画像)
}

函数 AI设备_更新健康(画像) {
    定义 可变 分数 = 100
    // 错误率扣分
    如果 (画像.错误率EMA > 500) { 分数 = 分数 - 50 }
    否则 如果 (画像.错误率EMA > 100) { 分数 = 分数 - 20 }
    否则 如果 (画像.错误率EMA > 10) { 分数 = 分数 - 5 }
    // 连续错误扣分
    如果 (画像.连续错误 > 10) { 分数 = 分数 - 30 }
    否则 如果 (画像.连续错误 > 5) { 分数 = 分数 - 15 }
    // 延迟扣分(>10ms)
    如果 (画像.延迟EMA > 10000 * 1024) { 分数 = 分数 - 10 }
    如果 (分数 < 0) { 分数 = 0 }
    画像.健康评分 = 分数

    // 自动降级建议
    如果 (分数 < 30 && 画像.已降级 == 0) {
        画像.已降级 = 1
        内核警告("AI设备: " + 画像.名称 + " 健康评分=" + 整数转字符串(分数) + ", 建议降级")
    }
}

函数 AI设备_预测故障(设备名) {
    定义 画像 = AI设备_查找(设备名)
    如果 (画像 == 空) { 返回 假 }
    返回 画像.健康评分 < 40
}

函数 AI设备_健康评分(设备名) {
    定义 画像 = AI设备_查找(设备名)
    如果 (画像 == 空) { 返回 100 }
    返回 画像.健康评分
}

函数 AI设备_查找(名称) {
    定义 可变 i = 0
    当 (i < 计数(设备画像表)) {
        如果 (设备画像表[i].名称 == 名称) { 返回 设备画像表[i] }
        i = i + 1
    }
    返回 空
}

函数 AI设备_获取或创建(名称) {
    定义 已有 = AI设备_查找(名称)
    如果 (已有 != 空) { 返回 已有 }
    定义 新画像 = 设备画像 {}
    新画像.名称 = 名称
    新画像.健康评分 = 100
    追加(设备画像表, 新画像)
    返回 新画像
}

// 故障时间预测 (基于错误率斜率和加速度)

定义 可变 错误率历史 = []  // [设备名, [时间, 错误率]]
定义 ERROR_HISTORY_MAX = 64

函数 AI设备_记录错误率样本(设备名, 错误率) {
    // 查找或创建该设备的历史
    定义 可变 历史 = 空
    定义 可变 idx = -1
    定义 可变 i = 0
    当 (i < 计数(错误率历史)) {
        如果 (错误率历史[i][0] == 设备名) {
            历史 = 错误率历史[i][1]
            idx = i
            中断
        }
        i = i + 1
    }
    如果 (历史 == 空) {
        历史 = []
        追加(错误率历史, [设备名, 历史])
        idx = 计数(错误率历史) - 1
    }

    追加(历史, [读取毫秒(), 错误率])
    如果 (计数(历史) > ERROR_HISTORY_MAX) { 链表_删除(历史, 0) }
    错误率历史[idx][1] = 历史
}

函数 AI设备_预测故障时间(设备名) {
    // 基于错误率趋势线性外推,估算何时健康评分降到0
    定义 可变 历史 = 空
    定义 可变 i = 0
    当 (i < 计数(错误率历史)) {
        如果 (错误率历史[i][0] == 设备名) { 历史 = 错误率历史[i][1]; 中断 }
        i = i + 1
    }
    如果 (历史 == 空 || 计数(历史) < 5) { 返回 -1 }  // 数据不足

    // 线性回归: 错误率(y) vs 时间(x)
    定义 n = 计数(历史)
    定义 可变 sx = 0
    定义 可变 sy = 0
    定义 可变 sxy = 0
    定义 可变 sx2 = 0
    定义 基准 = 历史[0][0]

    i = 0
    当 (i < n) {
        定义 x = 历史[i][0] - 基准
        定义 y = 历史[i][1]
        sx = sx + x
        sy = sy + y
        sxy = sxy + x * y
        sx2 = sx2 + x * x
        i = i + 1
    }

    定义 分母 = n * sx2 - sx * sx
    如果 (分母 == 0) { 返回 -1 }
    定义 斜率 = (n * sxy - sx * sy) / 分母  // 错误率变化率

    如果 (斜率 <= 0) { 返回 -1 }  // 错误率在下降或不变,无故障趋势

    // 估算:错误率到达临界值(致健康=0)的剩余时间
    定义 当前错误率 = 历史[n - 1][1]
    定义 临界错误率 = 800  // 错误率EMA到800时健康约为0
    如果 (当前错误率 >= 临界错误率) { 返回 0 }  // 已经故障

    定义 剩余增长 = 临界错误率 - 当前错误率
    定义 预计毫秒 = 剩余增长 * 1000 / 斜率  // 毫秒
    返回 预计毫秒 / 1000  // 秒
}

// 设备冗余管理 (主备切换)

定义 可变 设备冗余表 = []  // [主设备名, 备设备名, 已切换]

函数 AI设备_注册冗余(主设备, 备设备) {
    追加(设备冗余表, [主设备, 备设备, 假])
    内核信息("AI设备: 注册冗余对 " + 主设备 + " ↔ " + 备设备)
}

函数 AI设备_检查切换(设备名) {
    定义 可变 i = 0
    当 (i < 计数(设备冗余表)) {
        定义 项 = 设备冗余表[i]
        如果 (项[0] == 设备名 && !项[2]) {
            定义 主健康 = AI设备_健康评分(项[0])
            定义 备健康 = AI设备_健康评分(项[1])
            如果 (主健康 < 30 && 备健康 > 60) {
                设备冗余表[i][2] = 真
                内核警告("AI设备: 自动切换 " + 项[0] + " → " + 项[1] +
                         " (主健康=" + 整数转字符串(主健康) +
                         ", 备健康=" + 整数转字符串(备健康) + ")")
                返回 项[1]  // 返回备设备名
            }
        }
        i = i + 1
    }
    返回 空
}

// 统计和报告

函数 AI设备_报告() {
    定义 可变 输出 = "设备健康报告:\n"
    定义 可变 i = 0
    当 (i < 计数(设备画像表)) {
        定义 p = 设备画像表[i]
        输出 = 输出 + "  " + p.名称 + ": 健康=" + 整数转字符串(p.健康评分) +
               " 错误=" + 整数转字符串(p.总错误数) +
               " IO=" + 整数转字符串(p.总IO数)
        如果 (p.已降级 == 1) { 输出 = 输出 + " [已降级]" }
        输出 = 输出 + "\n"
        i = i + 1
    }
    返回 输出
}

函数 AI设备_统计() {
    返回 [计数(设备画像表), 计数(设备冗余表)]
}

// 降级设备数 + 平均健康评分

函数 AI设备_降级数() {
    定义 可变 计 = 0
    定义 可变 i = 0
    当 (i < 计数(设备画像表)) {
        如果 (设备画像表[i].已降级 == 1) { 计 = 计 + 1 }
        i = i + 1
    }
    返回 计
}

函数 AI设备_平均健康() {
    如果 (计数(设备画像表) == 0) { 返回 100 }
    定义 可变 总分 = 0
    定义 可变 i = 0
    当 (i < 计数(设备画像表)) {
        总分 = 总分 + 设备画像表[i].健康评分
        i = i + 1
    }
    返回 总分 / 计数(设备画像表)
}


函数 AI设备_完整统计() {
    返回 [计数(设备画像表), AI设备_降级数(), AI设备_平均健康()]
}

// 智能设备感知健康检查

函数 AI设备_健康检查() {
    定义 可变 问题 = []
    如果 (计数(设备画像表) == 0) { 追加(问题, "无设备画像") }
    定义 降级率 = AI设备_降级数() * 100
    如果 (计数(设备画像表) > 0) {
        降级率 = 降级率 / 计数(设备画像表)
    }
    如果 (降级率 > 30) {
        追加(问题, "设备降级率过高: " + 整数转字符串(降级率) + "%")
    }
    如果 (AI设备_平均健康() < 50) {
        追加(问题, "平均设备健康度过低")
    }
    如果 (计数(问题) == 0) { 返回 "智能设备感知健康" }
    返回 问题
}

函数 AI设备_查找画像(设备ID) {
    定义 可变 i = 0
    当 (i < 计数(设备画像表)) {
        如果 (设备画像表[i].设备ID == 设备ID) { 返回 设备画像表[i] }
        i = i + 1
    }
    返回 空
}

函数 AI设备_画像总数() {
    返回 计数(设备画像表)
}

函数 AI设备_重置() { 设备画像表 = [] }

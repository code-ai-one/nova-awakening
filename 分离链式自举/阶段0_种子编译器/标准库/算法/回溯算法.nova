导入("../基础.nova")

//    水行特性: 无孔不入, 遇阻回流, 最终充满所有可达空间
//    水生木: 回溯(水)生成所有可能解(木的枝叶)

// 全排列
函数 全排列(列表) {
    定义 可变 结果 = []
    定义 可变 已用 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) { 追加(已用, 0) i = i + 1 }
    全排列递归(列表, [], 已用, 结果)
    返回 结果
}

函数 全排列递归(列表, 当前, 已用, 结果) {
    如果 (计数(当前) == 计数(列表)) {
        定义 可变 拷贝 = []
        定义 可变 i = 0
        当 (i < 计数(当前)) { 追加(拷贝, 当前[i]) i = i + 1 }
        追加(结果, 拷贝)
        返回 空
    }
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (已用[i] == 0) {
            已用[i] = 1
            追加(当前, 列表[i])
            全排列递归(列表, 当前, 已用, 结果)
            删除(当前, 计数(当前) - 1)
            已用[i] = 0
        }
        i = i + 1
    }
}

// 组合 C(n,k) 生成
函数 组合生成(列表, k) {
    定义 可变 结果 = []
    组合递归(列表, k, 0, [], 结果)
    返回 结果
}

函数 组合递归(列表, k, 起始, 当前, 结果) {
    如果 (计数(当前) == k) {
        定义 可变 拷贝 = []
        定义 可变 i = 0
        当 (i < 计数(当前)) { 追加(拷贝, 当前[i]) i = i + 1 }
        追加(结果, 拷贝)
        返回 空
    }
    定义 可变 i = 起始
    当 (i < 计数(列表)) {
        追加(当前, 列表[i])
        组合递归(列表, k, i + 1, 当前, 结果)
        删除(当前, 计数(当前) - 1)
        i = i + 1
    }
}

// 所有子集
函数 所有子集(列表) {
    定义 可变 结果 = []
    子集递归(列表, 0, [], 结果)
    返回 结果
}

函数 子集递归(列表, 起始, 当前, 结果) {
    定义 可变 拷贝 = []
    定义 可变 i = 0
    当 (i < 计数(当前)) { 追加(拷贝, 当前[i]) i = i + 1 }
    追加(结果, 拷贝)
    i = 起始
    当 (i < 计数(列表)) {
        追加(当前, 列表[i])
        子集递归(列表, i + 1, 当前, 结果)
        删除(当前, 计数(当前) - 1)
        i = i + 1
    }
}

// N皇后
函数 n皇后(n) {
    定义 可变 解 = []
    定义 可变 棋盘 = []
    定义 可变 i = 0
    当 (i < n) { 追加(棋盘, -1) i = i + 1 }
    n皇后递归(棋盘, 0, n, 解)
    返回 解
}

函数 n皇后递归(棋盘, 行, n, 解) {
    如果 (行 == n) {
        定义 可变 拷贝 = []
        定义 可变 i = 0
        当 (i < n) { 追加(拷贝, 棋盘[i]) i = i + 1 }
        追加(解, 拷贝)
        返回 空
    }
    定义 可变 列 = 0
    当 (列 < n) {
        如果 (n皇后安全(棋盘, 行, 列) == 1) {
            棋盘[行] = 列
            n皇后递归(棋盘, 行 + 1, n, 解)
            棋盘[行] = -1
        }
        列 = 列 + 1
    }
}

函数 n皇后安全(棋盘, 行, 列) {
    定义 可变 i = 0
    当 (i < 行) {
        如果 (棋盘[i] == 列) { 返回 0 }
        定义 可变 差值 = 棋盘[i] - 列
        如果 (差值 < 0) { 差值 = 0 - 差值 }
        如果 (差值 == 行 - i) { 返回 0 }
        i = i + 1
    }
    返回 1
}

// 整数分割 (将n拆成正整数之和的方式数)
函数 整数分割(n) {
    定义 可变 dp = []
    定义 可变 i = 0
    当 (i <= n) { 追加(dp, 0) i = i + 1 }
    dp[0] = 1
    i = 1
    当 (i <= n) {
        定义 可变 j = i
        当 (j <= n) {
            dp[j] = dp[j] + dp[j - i]
            j = j + 1
        }
        i = i + 1
    }
    返回 dp[n]
}

// 括号生成
函数 括号生成(n) {
    定义 可变 结果 = []
    括号递归(n, 0, 0, "", 结果)
    返回 结果
}

函数 括号递归(n, 左, 右, 当前, 结果) {
    如果 (左 == n 且 右 == n) {
        追加(结果, 当前)
        返回 空
    }
    如果 (左 < n) {
        括号递归(n,  左 + 1,  右,  字符串拼接(当前, "("),  结果)
    }
    如果 (右 < 左) {
        括号递归(n, 左, 右 + 1, 字符串拼接(当前, ")"), 结果)
    }
}

// N皇后问题

函数 N皇后_递归(棋盘, 行, n, 解列表) {
    如果 (行 == n) {
        定义 可变 解 = []
        定义 可变 i = 0
        当 (i < n) { 追加(解, 棋盘[i])  i = i + 1 }
        追加(解列表, 解)
        返回 空
    }
    定义 可变 列 = 0
    当 (列 < n) {
        如果 (N皇后_安全(棋盘, 行, 列)) {
            棋盘[行] = 列
            N皇后_递归(棋盘, 行 + 1, n, 解列表)
            棋盘[行] = -1
        }
        列 = 列 + 1
    }
}

函数 N皇后_安全(棋盘, 行, 列) {
    定义 可变 i = 0
    当 (i < 行) {
        如果 (棋盘[i] == 列) { 返回 假 }
        定义 行差 = 行 - i
        定义 可变 列差 = 列 - 棋盘[i]
        如果 (列差 < 0) { 列差 = 0 - 列差 }
        如果 (行差 == 列差) { 返回 假 }
        i = i + 1
    }
    返回 真
}

// 组合

函数 回溯算法_组合(n, k) {
    定义 可变 结果 = []
    组合递归_范围(n, k, 1, [], 结果)
    返回 结果
}

函数 组合递归_范围(n, k, 起始, 当前, 结果) {
    如果 (计数(当前) == k) {
        定义 可变 副本 = []
        定义 可变 i = 0
        当 (i < 计数(当前)) { 追加(副本, 当前[i])  i = i + 1 }
        追加(结果, 副本)
        返回 空
    }
    定义 可变 i = 起始
    当 (i <= n) {
        追加(当前, i)
        组合递归_范围(n, k, i + 1, 当前, 结果)
        删除(当前, 计数(当前) - 1)
        i = i + 1
    }
}

// 组合求和

函数 组合求和(候选, 目标) {
    定义 可变 结果 = []
    组合求和_递归(候选, 目标, 0, [], 0, 结果)
    返回 结果
}

函数 组合求和_递归(候选, 目标, 起始, 当前, 当前和, 结果) {
    如果 (当前和 == 目标) {
        定义 可变 副本 = []
        定义 可变 i = 0
        当 (i < 计数(当前)) { 追加(副本, 当前[i])  i = i + 1 }
        追加(结果, 副本)
        返回 空
    }
    如果 (当前和 > 目标) { 返回 空 }
    定义 可变 i = 起始
    当 (i < 计数(候选)) {
        追加(当前, 候选[i])
        组合求和_递归(候选, 目标, i, 当前, 当前和 + 候选[i], 结果)
        删除(当前, 计数(当前) - 1)
        i = i + 1
    }
}

定义 可变 _回溯_调用数 = 0
定义 可变 _回溯_剪枝数 = 0

函数 回溯_记录调用() { _回溯_调用数 = _回溯_调用数 + 1 }
函数 回溯_记录剪枝() { _回溯_剪枝数 = _回溯_剪枝数 + 1 }

// §5 显示列表执行器 — 将绘制Layer的显示列表通过Sk画布渲染
// 连接nova的绘制层和Skia的渲染层


函数 Sk画布_执行显示列表(canvas, 显示列表, 显示列表数量) {
    定义 可变 i = 0
    当 (i < 显示列表数量) {
        定义 偏移 = 显示列表 + i * 48
        定义 类型 = 内存_读32(偏移)
        定义 x = 内存_读32(偏移 + 4)
        定义 y = 内存_读32(偏移 + 8)
        定义 w = 内存_读32(偏移 + 12)
        定义 h = 内存_读32(偏移 + 16)
        定义 颜色 = 内存_读32(偏移 + 20)

        如果 (类型 == 1) {     // 显示项_背景
            定义 paint = Sk绘制_创建()
            Sk绘制_设置颜色(paint, SkColor_从RGBA(颜色))
            定义 rect = SkRect_创建(x, y, x + w, y + h)
            Sk画布_drawRect(canvas, rect, paint)
        }
        否则 如果 (类型 == 3) {     // 显示项_文本
            定义 文本指针 = 内存_读64(偏移 + 24)
            定义 文本长度 = 内存_读32(偏移 + 32)
            定义 字号 = 内存_读32(偏移 + 36)
            定义 字体 = Sk字体_创建(0, 字号)
            定义 paint = Sk绘制_创建()
            Sk绘制_设置颜色(paint, SkColor_从RGBA(颜色))
            Sk画布_drawText(canvas, 文本指针, 文本长度, x, y, 字体, paint)
        }
        否则 如果 (类型 == 6) {     // 显示项_裁剪
            Sk画布_save(canvas)
            定义 rect = SkRect_创建(x, y, x + w, y + h)
            Sk画布_clipRect(canvas, rect)
        }
        否则 如果 (类型 == 7) {     // 显示项_还原裁剪
            Sk画布_restore(canvas)
        }
        否则 如果 (类型 == 8) {     // 显示项_透明度开始
            定义 alpha = 内存_读32(偏移 + 44)
            定义 rect = SkRect_创建(x, y, x + w, y + h)
            Sk画布_saveLayerAlpha(canvas, rect, alpha * 255 / 100)
        }
        否则 如果 (类型 == 9) {     // 显示项_透明度结束
            Sk画布_restore(canvas)
        }

        i = i + 1
    }
}

// 传统Skia: 每条drawRect/drawText独立执行, 无合并优化
// Nova: AI分析绘制指令流, 自动合并/缓存/降级

结构 AI绘制统计 {
    矩形绘制次数,
    文本绘制次数,
    图片绘制次数,
    合并次数,
    缓存命中次数,
    跳过次数,
    总绘制耗时,    // u64 微秒
}

定义 可变 AI绘制全局统计 = 0

函数 AI绘制_初始化统计() {
    AI绘制全局统计 = 堆_分配(AI绘制统计)
    AI绘制全局统计.矩形绘制次数 = 0
    AI绘制全局统计.文本绘制次数 = 0
    AI绘制全局统计.图片绘制次数 = 0
    AI绘制全局统计.合并次数 = 0
    AI绘制全局统计.缓存命中次数 = 0
    AI绘制全局统计.跳过次数 = 0
    AI绘制全局统计.总绘制耗时 = 0
}

函数 AI绘制_合并矩形(显示列表, 数量) {
    如果 (数量 < 2) { 返回 数量 }

    定义 可变 写位置 = 0
    定义 可变 i = 0
    当 (i < 数量) {
        定义 当前偏移 = 显示列表 + i * 48
        定义 当前类型 = 内存_读32(当前偏移)
        定义 当前颜色 = 内存_读32(当前偏移 + 4)

        // 检查下一个是否可合并(同类型+同颜色+相邻)
        如果 (i + 1 < 数量 && 当前类型 == 1) {    // 背景类型
            定义 下一偏移 = 显示列表 + (i+1) * 48
            定义 下一类型 = 内存_读32(下一偏移)
            定义 下一颜色 = 内存_读32(下一偏移 + 4)
            如果 (下一类型 == 1 && 下一颜色 == 当前颜色) {
                // 合并: 计算包围矩形
                定义 x1 = 内存_读32(当前偏移 + 8)
                定义 y1 = 内存_读32(当前偏移 + 12)
                定义 x2 = x1 + 内存_读32(当前偏移 + 16)
                定义 y2 = y1 + 内存_读32(当前偏移 + 20)
                定义 nx1 = 内存_读32(下一偏移 + 8)
                定义 ny1 = 内存_读32(下一偏移 + 12)
                定义 nx2 = nx1 + 内存_读32(下一偏移 + 16)
                定义 ny2 = ny1 + 内存_读32(下一偏移 + 20)
                // 包围矩形
                定义 合x = 如果(x1 < nx1, x1, nx1)
                定义 合y = 如果(y1 < ny1, y1, ny1)
                定义 合x2 = 如果(x2 > nx2, x2, nx2)
                定义 合y2 = 如果(y2 > ny2, y2, ny2)
                // 写入合并后的结果
                定义 写偏移 = 显示列表 + 写位置 * 48
                内存_写32(写偏移, 1)
                内存_写32(写偏移 + 4, 当前颜色)
                内存_写32(写偏移 + 8, 合x)
                内存_写32(写偏移 + 12, 合y)
                内存_写32(写偏移 + 16, 合x2 - 合x)
                内存_写32(写偏移 + 20, 合y2 - 合y)
                写位置 = 写位置 + 1
                i = i + 2    // 跳过两个
                如果 (AI绘制全局统计 != 0) { AI绘制全局统计.合并次数 = AI绘制全局统计.合并次数 + 1 }
                继续
            }
        }
        // 不可合并: 直接复制
        如果 (写位置 != i) {
            内存_复制(显示列表 + 写位置 * 48, 当前偏移, 48)
        }
        写位置 = 写位置 + 1
        i = i + 1
    }
    返回 写位置
}

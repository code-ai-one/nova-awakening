    NKSI_注册钩子("navigator", "languages", 拦截类型_属性读取, 指纹_当前配置.语言列表)
    NKSI_注册钩子("navigator", "hardwareConcurrency", 拦截类型_属性读取, 指纹_当前配置.硬件并发数)
    NKSI_注册钩子("navigator", "deviceMemory", 拦截类型_属性读取, 指纹_当前配置.设备内存)

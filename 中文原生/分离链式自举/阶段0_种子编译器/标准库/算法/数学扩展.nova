导入("../基础.nova")
导入("../数学/工具.nova")

// 快速幂 = 金之锻造 (反复平方精炼)
// 素数筛 = 金之淘洗 (筛去合数留纯金)
// 斐波那契 = 金生水 (递推流动)
// 标量: "个"量词 (原子运算)
// 序列: "串"量词 (斐波那契/素数序列)
// 组合: "批"量词 (排列组合)
// GCD(a,b)*LCM(a,b) = a*b (自指恒等式)
// C(n,k) = C(n,n-k) (对称性自指)

// 快速幂 (a^b mod m, 0 , 0)
函数 快速幂(a, b, m) { 定义 可变 结果 = 1
 定义 可变 底 = a % m
 定义 可变 指数 = b
 当 (指数 > 0) { 如果 (指数 % 2 == 1) {
 结果 = (结果 * 底) % m
 }
 指数 = 指数 / 2
 底 = (底 * 底) % m
 }
 返回 结果
}

// 最大公约数
函数 数学扩展_gcd(a, b) { 定义 可变 x = a
 定义 可变 y = b
 当 (y != 0) { 定义 临时 = y
 y = x % y
 x = 临时
 }
 返回 x
}

// 最小公倍数
函数 数学扩展_lcm(a, b) { 返回 a / 数学扩展_gcd(a, b) * b
}

// 是否素数
函数 数学扩展_是素数(n) {
    如果 (n < 2) { 返回 0
}
 如果 (n < 4) { 返回 1 }
 如果 (n % 2 == 0) { 返回 0 }
 如果 (n % 3 == 0) { 返回 0 }
 定义 可变 i = 5
 当 (i * i <= n) { 如果 (n % i == 0) { 返回 0 }
 如果 (n % (i + 2) == 0) { 返回 0 }
 i = i + 6
 }
 返回 1
}

// 埃拉托色尼筛法
函数 素数筛(最大值) { 定义 可变 筛 = []
 定义 可变 i = 0
 当 (i <= 最大值) { 追加(筛, 1) i = i + 1 }
 筛[0] = 0
 筛[1] = 0
 i = 2
 当 (i * i <= 最大值) { 如果 (筛[i] == 1) { 定义 可变 j = i * i
 当 (j <= 最大值) {
 筛[j] = 0
 j = j + i
 }
 }
 i = i + 1
 }
 定义 可变 素数列表 = []
 i = 2
 当 (i <= 最大值) { 如果 (筛[i] == 1) { 追加(素数列表, i) }
 i = i + 1
 }
 返回 素数列表
}

// 组合数 C(n, k)
函数 数学扩展_组合数(n, k) {
    如果 (k > n) { 返回 0
}
 如果 (k == 0) { 返回 1 }
 定义 可变 kk = k
 如果 (kk > n - kk) { kk = n - kk }
 定义 可变 结果 = 1
 定义 可变 i = 0
 当 (i < kk) {
 结果 = 结果 * (n - i)
 结果 = 结果 / (i + 1)
 i = i + 1
 }
 返回 结果
}

// 排列数 P(n, k)
函数 排列数(n, k) {
    如果 (k > n) { 返回 0
}
 定义 可变 结果 = 1
 定义 可变 i = 0
 当 (i < k) {
 结果 = 结果 * (n - i)
 i = i + 1
 }
 返回 结果
}

// 阶乘
函数 数学扩展_阶乘(n) {
    如果 (n <= 1) { 返回 1
}
 定义 可变 结果 = 1
 定义 可变 i = 2
 当 (i <= n) { 结果 = 结果 * i i = i + 1 }
 返回 结果
}

// 斐波那契 (迭代)
函数 数学扩展_斐波那契(n) {
    如果 (n <= 0) { 返回 0
}
 如果 (n == 1) { 返回 1 }
 定义 可变 a = 0
 定义 可变 b = 1
 定义 可变 i = 2
 当 (i <= n) { 定义 c = a + b
 a = b
 b = c
 i = i + 1
 }
 返回 b
}

// 整数平方根 (牛顿法)
函数 整数sqrt(n) {
    如果 (n <= 1) { 返回 n
}
 定义 可变 x = n
 定义 可变 y = (x + 1) / 2
 当 (y < x) {
 x = y
 y = (x + n / x) / 2
 }
 返回 x
}

// 绝对值
函数 数学_abs(n) {
    如果 (n < 0) { 返回 0 - n
}
 返回 n
}

// 最大/最小
函数 数学_max(a, b) {
    如果 (a > b) { 返回 a }
    返回 b
}
函数 数学_min(a, b) {
    如果 (a < b) { 返回 a }
    返回 b
}

// 钳位
函数 数学_clamp(值, 最小, 最大) {
    如果 (值 < 最小) { 返回 最小
}
 如果 (值 > 最大) { 返回 最大 }
 返回 值
}

// 整数对数 (底2)
函数 log2_整数(n) {
    如果 (n <= 0) { 返回 -1
}
 定义 可变 r = 0
 定义 可变 v = n
 当 (v > 1) { v = v / 2 r = r + 1 }
 返回 r
}

// 是否2的幂
函数 数学扩展_是2的幂(n) {
    如果 (n <= 0) { 返回 0
}
 定义 可变 v = n
 当 (v > 1) { 如果 (v % 2 != 0) { 返回 0 }
 v = v / 2
 }
 返回 1
}

// 欧拉函数
函数 数扩_欧拉函数(n) { 定义 可变 结果 = n
 定义 可变 i = 2
 定义 可变 nn = n
 当 (i * i <= nn) { 如果 (nn % i == 0) {
 当 (nn % i == 0) { nn = nn / i }
 结果 = 结果 - 结果 / i
 }
 i = i + 1
 }
 如果 (nn > 1) { 结果 = 结果 - 结果 / nn }
 返回 结果
}

// 组合数C(n,k)
函数 数扩_组合数(n, k) {
    如果 (k > n 或 k < 0) { 返回 0
}
 如果 (k == 0 或 k == n) { 返回 1 }
 定义 可变 实际k = k
 如果 (实际k > n - 实际k) { 实际k = n - 实际k }
 定义 可变 结果 = 1
 定义 可变 i = 0
 当 (i < 实际k) { 结果 = 结果 * (n - i) / (i + 1) i = i + 1 }
 返回 结果
}

// 牛顿法求平方根(整数)
函数 牛顿_整数sqrt(n) {
    如果 (n <= 1) { 返回 n
}
 定义 可变 x = n
 当 (x * x > n) { x = (x + n / x) / 2 }
 返回 x
}

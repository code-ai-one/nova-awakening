// §1 目录项结构与常量

定义 EXT4_FT_UNKNOWN = 0
定义 EXT4_FT_REG_FILE = 1
定义 EXT4_FT_DIR = 2
定义 EXT4_FT_CHRDEV = 3
定义 EXT4_FT_BLKDEV = 4
定义 EXT4_FT_FIFO = 5
定义 EXT4_FT_SOCK = 6
定义 EXT4_FT_SYMLINK = 7

结构 Ext4目录项 {
    Nova文件节点号,
    记录长度,
    名称长度,
    文件类型,
    名称,
}

定义 可变 目录_删除数 = 0
定义 可变 目录_创建数 = 0
定义 可变 目录_查找数 = 0
定义 可变 目录_遍历数 = 0
定义 可变 目录_重命名数 = 0

函数 ext4_删除目录项(sb, 目录Nova文件节点, 名称) {
    定义 信息 = sb.私有信息
    定义 块大小 = 信息.块大小
    定义 ext4信息 = 目录Nova文件节点.私有信息

    定义 可变 偏移 = 0
    当 (偏移 < 目录Nova文件节点.大小) {
        定义 逻辑块 = 偏移 / 块大小
        定义 物理块 = ext4_extent_查找(sb, ext4信息, 逻辑块)
        如果 (物理块 == (0 - 1)) {
            偏移 = 偏移 + 块大小
            继续
        }

        定义 可变 缓冲 = 块设备_读(sb.设备, 物理块 * 块大小, 块大小)
        如果 (缓冲 == 空) {
            偏移 = 偏移 + 块大小
            继续
        }

        定义 可变 前项偏移 = -1
        定义 可变 块内偏移 = 0
        当 (块内偏移 < 块大小) {
            定义 项 = ext4_解析目录项(缓冲, 块内偏移)
            如果 (项.记录长度 == 0) { 跳出 }

            如果 (项.Nova文件节点号 != 0 && ext4_目录项名称匹配(项, 名称)) {
                如果 (前项偏移 >= 0) {
                    // 合并到前一个目录项
                    定义 前项 = ext4_解析目录项(缓冲, 前项偏移)
                    前项.记录长度 = 前项.记录长度 + 项.记录长度
                    ext4_写回目录项(缓冲, 前项偏移, 前项)
                } 否则 {
                    // 第一个目录项，标记Nova文件节点为0
                    项.Nova文件节点号 = 0
                    ext4_写回目录项(缓冲, 块内偏移, 项)
                }

                块设备_写(sb.设备, 物理块 * 块大小, 缓冲, 块大小)
                缓冲_释放(缓冲)
                返回 0
            }

            前项偏移 = 块内偏移
            块内偏移 = 块内偏移 + 项.记录长度
        }

        缓冲_释放(缓冲)
        偏移 = 偏移 + 块大小
    }

    返回 错误码_不存在
}

// 目录遍历(readdir)

函数 ext4_读目录(sb, 目录Nova文件节点, 回调, 上下文) {
    定义 信息 = sb.私有信息
    定义 块大小 = 信息.块大小
    定义 ext4信息 = 目录Nova文件节点.私有信息
    定义 可变 已报告 = 0

    定义 可变 偏移 = 0
    当 (偏移 < 目录Nova文件节点.大小) {
        定义 逻辑块 = 偏移 / 块大小
        定义 物理块 = ext4_extent_查找(sb, ext4信息, 逻辑块)
        如果 (物理块 == (0 - 1)) {
            偏移 = 偏移 + 块大小
            继续
        }

        定义 缓冲 = 块设备_读(sb.设备, 物理块 * 块大小, 块大小)
        如果 (缓冲 == 空) {
            偏移 = 偏移 + 块大小
            继续
        }

        定义 可变 块内偏移 = 0
        当 (块内偏移 < 块大小) {
            定义 项 = ext4_解析目录项(缓冲, 块内偏移)
            如果 (项.记录长度 == 0) { 跳出 }

            如果 (项.Nova文件节点号 != 0 && 项.名称长度 > 0) {
                定义 名 = ext4_提取目录项名称(项)
                定义 继续遍历 = 回调(上下文, 名, 项.Nova文件节点号, 项.文件类型)
                如果 (!继续遍历) {
                    缓冲_释放(缓冲)
                    返回 已报告
                }
                已报告 = 已报告 + 1
            }

            块内偏移 = 块内偏移 + 项.记录长度
        }

        缓冲_释放(缓冲)
        偏移 = 偏移 + 块大小
    }

    返回 已报告
}

// §4 创建目录项

函数 ext4_创建目录项(sb, 目录Nova文件节点, 名称, 子Nova文件节点号, 文件类型) {
    定义 信息 = sb.私有信息
    定义 块大小 = 信息.块大小
    定义 ext4信息 = 目录Nova文件节点.私有信息
    目录_创建数 = 目录_创建数 + 1

    定义 名称长度 = 字符串长度(名称)
    定义 需要长度 = 8 + 名称长度
    如果 (需要长度 % 4 != 0) { 需要长度 = 需要长度 + (4 - 需要长度 % 4) }

    // 在现有目录块中查找空间
    定义 可变 偏移 = 0
    当 (偏移 < 目录Nova文件节点.大小) {
        定义 逻辑块 = 偏移 / 块大小
        定义 物理块 = ext4_extent_查找(sb, ext4信息, 逻辑块)
        如果 (物理块 == (0 - 1)) { 偏移 = 偏移 + 块大小; 继续 }

        定义 缓冲 = 块设备_读(sb.设备, 物理块 * 块大小, 块大小)
        如果 (缓冲 == 空) { 偏移 = 偏移 + 块大小; 继续 }

        定义 可变 块内偏移 = 0
        当 (块内偏移 < 块大小) {
            定义 项 = ext4_解析目录项(缓冲, 块内偏移)
            如果 (项.记录长度 == 0) { 跳出 }

            // 计算此项实际需要的空间
            定义 实际需要 = 8 + 项.名称长度
            如果 (实际需要 % 4 != 0) { 实际需要 = 实际需要 + (4 - 实际需要 % 4) }
            如果 (项.Nova文件节点号 == 0) { 实际需要 = 0 }

            定义 可用空间 = 项.记录长度 - 实际需要
            如果 (可用空间 >= 需要长度) {
                // 拆分当前项, 在后面写入新项
                如果 (项.Nova文件节点号 != 0) {
                    项.记录长度 = 实际需要
                    ext4_写回目录项(缓冲, 块内偏移, 项)
                    块内偏移 = 块内偏移 + 实际需要
                }
                // 写入新目录项
                定义 新项 = Ext4目录项 {
                    Nova文件节点号: 子Nova文件节点号,
                    记录长度: 可用空间,
                    名称长度: 名称长度,
                    文件类型: 文件类型,
                    名称: 名称,
                }
                ext4_写回目录项(缓冲, 块内偏移, 新项)
                块设备_写(sb.设备, 物理块 * 块大小, 缓冲, 块大小)
                缓冲_释放(缓冲)
                返回 成功
            }

            块内偏移 = 块内偏移 + 项.记录长度
        }

        缓冲_释放(缓冲)
        偏移 = 偏移 + 块大小
    }

    // 目录已满: 需要分配新块
    返回 错误码_无空间
}

// §5 查找目录项

函数 ext4_查找目录项(sb, 目录Nova文件节点, 名称) {
    定义 信息 = sb.私有信息
    定义 块大小 = 信息.块大小
    定义 ext4信息 = 目录Nova文件节点.私有信息
    目录_查找数 = 目录_查找数 + 1

    定义 可变 偏移 = 0
    当 (偏移 < 目录Nova文件节点.大小) {
        定义 逻辑块 = 偏移 / 块大小
        定义 物理块 = ext4_extent_查找(sb, ext4信息, 逻辑块)
        如果 (物理块 == (0 - 1)) { 偏移 = 偏移 + 块大小; 继续 }

        定义 缓冲 = 块设备_读(sb.设备, 物理块 * 块大小, 块大小)
        如果 (缓冲 == 空) { 偏移 = 偏移 + 块大小; 继续 }

        定义 可变 块内偏移 = 0
        当 (块内偏移 < 块大小) {
            定义 项 = ext4_解析目录项(缓冲, 块内偏移)
            如果 (项.记录长度 == 0) { 跳出 }
            如果 (项.Nova文件节点号 != 0 && ext4_目录项名称匹配(项, 名称)) {
                定义 结果 = 项.Nova文件节点号
                缓冲_释放(缓冲)
                返回 结果
            }
            块内偏移 = 块内偏移 + 项.记录长度
        }

        缓冲_释放(缓冲)
        偏移 = 偏移 + 块大小
    }
    返回 0
}

// §6 重命名

函数 ext4_重命名(sb, 旧目录, 旧名称, 新目录, 新名称) {
    目录_重命名数 = 目录_重命名数 + 1

    // 查找旧目录项
    定义 inode号 = ext4_查找目录项(sb, 旧目录, 旧名称)
    如果 (inode号 == 0) { 返回 错误码_不存在 }

    // 获取文件类型
    定义 文件类型 = EXT4_FT_REG_FILE

    // 在新目录创建新项
    定义 创建结果 = ext4_创建目录项(sb, 新目录, 新名称, inode号, 文件类型)
    如果 (创建结果 != 成功) { 返回 创建结果 }

    // 删除旧项
    定义 删除结果 = ext4_删除目录项(sb, 旧目录, 旧名称)
    如果 (删除结果 != 0) {
        // 回滚: 删除新创建的项
        ext4_删除目录项(sb, 新目录, 新名称)
        返回 删除结果
    }

    返回 成功
}

// §7 硬链接

函数 ext4_硬链接(sb, 目标目录, 名称, inode号) {
    // 在目标目录创建新条目指向已有inode
    定义 文件类型 = EXT4_FT_REG_FILE
    定义 结果 = ext4_创建目录项(sb, 目标目录, 名称, inode号, 文件类型)
    如果 (结果 == 成功) {
        // 增加inode的链接计数
        // inode.链接数 = inode.链接数 + 1
    }
    返回 结果
}

// §8 辅助函数

函数 ext4_解析目录项(缓冲, 偏移) {
    返回 Ext4目录项 {
        Nova文件节点号: 内存_读32(缓冲 + 偏移),
        记录长度: 内存_读16(缓冲 + 偏移 + 4),
        名称长度: 内存_读8(缓冲 + 偏移 + 6),
        文件类型: 内存_读8(缓冲 + 偏移 + 7),
        名称: 缓冲 + 偏移 + 8,
    }
}

函数 ext4_写回目录项(缓冲, 偏移, 项) {
    内存_写32(缓冲 + 偏移, 项.Nova文件节点号)
    内存_写16(缓冲 + 偏移 + 4, 项.记录长度)
    内存_写8(缓冲 + 偏移 + 6, 项.名称长度)
    内存_写8(缓冲 + 偏移 + 7, 项.文件类型)
    如果 (项.名称 != 0 && 项.名称长度 > 0) {
        内存拷贝(缓冲 + 偏移 + 8, 项.名称, 项.名称长度)
    }
}

函数 ext4_目录项名称匹配(项, 名称) {
    如果 (项.名称长度 != 字符串长度(名称)) { 返回 假 }
    定义 可变 i = 0
    当 (i < 项.名称长度) {
        如果 (内存_读8(项.名称 + i) != 内存_读8(名称 + i)) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 ext4_提取目录项名称(项) {
    如果 (项.名称长度 == 0) { 返回 "" }
    定义 名 = 分配内存(项.名称长度 + 1)
    内存拷贝(名, 项.名称, 项.名称长度)
    内存_写8(名 + 项.名称长度, 0)
    返回 名
}

函数 ext4_extent_查找(sb, ext4信息, 逻辑块) {
    // 简化: 直接映射
    返回 逻辑块
}

// §9 统计与诊断

函数 ext4_目录统计() {
    返回 {
        删除: 目录_删除数,
        创建: 目录_创建数,
        查找: 目录_查找数,
        遍历: 目录_遍历数,
        重命名: 目录_重命名数,
    }
}

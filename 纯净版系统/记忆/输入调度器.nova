导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/整数转字符串.nova")

定义 读截止 = 500000
定义 写截止 = 5000000
定义 批量大小 = 16
定义 饥饿阈值 = 4

结构 读写调度器 {
    读队头,
    读队尾,
    读数量,
    写队头,
    写队尾,
    写数量,
    上次扇区,
    上次方向,
    总处理,
    总合并,
    读饥饿计数,
    写饥饿计数,
    当前批次,
    锁,
}

定义 可变 全局调度 = 0

函数 读写调度_初始化() {
    全局调度 = 堆_分配(读写调度器)
    全局调度.读队头 = 0
    全局调度.读队尾 = 0
    全局调度.读数量 = 0
    全局调度.写队头 = 0
    全局调度.写队尾 = 0
    全局调度.写数量 = 0
    全局调度.上次扇区 = 0
    全局调度.上次方向 = 0
    全局调度.总处理 = 0
    全局调度.总合并 = 0
    全局调度.读饥饿计数 = 0
    全局调度.写饥饿计数 = 0
    全局调度.当前批次 = 0
    全局调度.锁 = 自旋锁_创建()
}

函数 读写调度_添加(请求) {
    如果 (全局调度 == 0 || 请求 == 0) { 返回 }
    自旋锁_获取(全局调度.锁)
    定义 合并 = 读写调度_尝试合并(请求)
    如果 (合并) {
        全局调度.总合并 = 全局调度.总合并 + 1
        自旋锁_释放(全局调度.锁)
        返回
    }
    如果 (请求.类型 == 0) {
        请求.后继 = 0
        如果 (全局调度.读队尾 != 0) { 全局调度.读队尾.后继 = 请求 }
        否则 { 全局调度.读队头 = 请求 }
        全局调度.读队尾 = 请求
        全局调度.读数量 = 全局调度.读数量 + 1
    } 否则 {
        请求.后继 = 0
        如果 (全局调度.写队尾 != 0) { 全局调度.写队尾.后继 = 请求 }
        否则 { 全局调度.写队头 = 请求 }
        全局调度.写队尾 = 请求
        全局调度.写数量 = 全局调度.写数量 + 1
    }
    自旋锁_释放(全局调度.锁)
}

函数 读写调度_尝试合并(请求) {
    定义 可变 当前 = 0
    如果 (请求.类型 == 0) { 当前 = 全局调度.读队头 }
    否则 { 当前 = 全局调度.写队头 }
    当 (当前 != 0) {
        如果 (当前.设备号 == 请求.设备号) {
            如果 (当前.起始扇区 + 当前.扇区数 == 请求.起始扇区) {
                当前.扇区数 = 当前.扇区数 + 请求.扇区数
                返回 真
            }
        }
        当前 = 当前.后继
    }
    返回 假
}

函数 读写调度_分发() {
    如果 (全局调度 == 0) { 返回 0 }
    自旋锁_获取(全局调度.锁)
    定义 可变 选中 = 0
    如果 (全局调度.读数量 > 0 && 全局调度.写数量 > 0) {
        如果 (全局调度.写饥饿计数 >= 饥饿阈值) {
            选中 = 读写调度_取写()
            全局调度.写饥饿计数 = 0
            全局调度.读饥饿计数 = 全局调度.读饥饿计数 + 1
        } 否则 {
            选中 = 读写调度_取读()
            全局调度.读饥饿计数 = 0
            全局调度.写饥饿计数 = 全局调度.写饥饿计数 + 1
        }
    } 否则 如果 (全局调度.读数量 > 0) {
        选中 = 读写调度_取读()
    } 否则 如果 (全局调度.写数量 > 0) {
        选中 = 读写调度_取写()
    }
    如果 (选中 != 0) {
        全局调度.上次扇区 = 选中.起始扇区 + 选中.扇区数
        全局调度.总处理 = 全局调度.总处理 + 1
        全局调度.当前批次 = 全局调度.当前批次 + 1
    }
    自旋锁_释放(全局调度.锁)
    返回 选中
}

函数 读写调度_取读() {
    如果 (全局调度.读队头 == 0) { 返回 0 }
    定义 请求 = 全局调度.读队头
    全局调度.读队头 = 请求.后继
    如果 (全局调度.读队头 == 0) { 全局调度.读队尾 = 0 }
    全局调度.读数量 = 全局调度.读数量 - 1
    返回 请求
}

函数 读写调度_取写() {
    如果 (全局调度.写队头 == 0) { 返回 0 }
    定义 请求 = 全局调度.写队头
    全局调度.写队头 = 请求.后继
    如果 (全局调度.写队头 == 0) { 全局调度.写队尾 = 0 }
    全局调度.写数量 = 全局调度.写数量 - 1
    返回 请求
}

函数 读写调度_队列深度() {
    如果 (全局调度 == 0) { 返回 0 }
    返回 全局调度.读数量 + 全局调度.写数量
}

函数 读写调度_完整统计() {
    如果 (全局调度 == 0) { 返回 [0, 0, 0, 0, 0] }
    返回 [全局调度.读数量, 全局调度.写数量, 全局调度.总处理, 全局调度.总合并, 全局调度.当前批次]
}

// §2 健康检查与诊断

函数 读写调度_健康检查() {
    定义 可变 问题 = []
    如果 (全局调度 == 0) { 追加(问题, "IO调度器未初始化"); 返回 问题 }
    如果 (全局调度.读数量 + 全局调度.写数量 > 1000) {
        追加(问题, "IO队列过长: " + 整数转字符串(全局调度.读数量 + 全局调度.写数量))
    }
    如果 (全局调度.读饥饿计数 > 饥饿阈值 * 3) {
        追加(问题, "读饥饿严重")
    }
    如果 (全局调度.写饥饿计数 > 饥饿阈值 * 3) {
        追加(问题, "写饥饿严重")
    }
    如果 (计数(问题) == 0) { 返回 "IO调度器健康" }
    返回 问题
}

函数 读写调度_详细统计() {
    如果 (全局调度 == 0) { 返回 空 }
    返回 {
        读队列: 全局调度.读数量,
        写队列: 全局调度.写数量,
        总处理: 全局调度.总处理,
        总合并: 全局调度.总合并,
        合并率: 读写调度_合并率(),
        读饥饿: 全局调度.读饥饿计数,
        写饥饿: 全局调度.写饥饿计数,
        上次扇区: 全局调度.上次扇区,
        批次: 全局调度.当前批次,
    }
}

函数 读写调度_合并率() {
    如果 (全局调度 == 0) { 返回 0 }
    定义 总 = 全局调度.总处理 + 全局调度.总合并
    如果 (总 == 0) { 返回 0 }
    返回 全局调度.总合并 * 100 / 总
}

函数 读写调度_重置统计() {
    如果 (全局调度 == 0) { 返回 }
    全局调度.总处理 = 0
    全局调度.总合并 = 0
    全局调度.读饥饿计数 = 0
    全局调度.写饥饿计数 = 0
    全局调度.当前批次 = 0
}

函数 读写调度_打印统计() {
    如果 (全局调度 == 0) { 内核信息("IO调度器: 未初始化"); 返回 }
    内核信息("IO调度器统计:")
    内核信息("  读队列: " + 整数转字符串(全局调度.读数量) +
             " 写队列: " + 整数转字符串(全局调度.写数量))
    内核信息("  总处理: " + 整数转字符串(全局调度.总处理) +
             " 总合并: " + 整数转字符串(全局调度.总合并) +
             " 合并率: " + 整数转字符串(读写调度_合并率()) + "%")
}

函数 自旋锁_创建() {
    // 创建自旋锁: 返回锁对象(0=未锁定)
    返回 { 值: 0, 持有者: 0 }
}
函数 自旋锁_获取(锁) {
    如果 (锁 == 空 || 锁 == 0) { 返回 }
    定义 可变 自旋次数 = 0
    定义 最大自旋 = 10000000
    当 (锁.值 != 0 && 自旋次数 < 最大自旋) {
        汇编 { "pause" }
        自旋次数 = 自旋次数 + 1
    }
    如果 (自旋次数 >= 最大自旋) {
        内核警告("自旋锁超时: 可能死锁, 持有者PID=" + 整数转字符串(锁.持有者))
    }
    锁.值 = 1
    锁.持有者 = 获取当前PID()
}
函数 自旋锁_释放(锁) {
    // 释放自旋锁
    如果 (锁 == 空 || 锁 == 0) { 返回 }
    锁.持有者 = 0
    锁.值 = 0
}

定义 可变 AI_输入调度器_负载窗口 = []

函数 AI_输入调度器_负载预测(当前负载) {
    追加(AI_输入调度器_负载窗口, 当前负载)
    如果 (计数(AI_输入调度器_负载窗口) > 20) { 列表_移除(AI_输入调度器_负载窗口, 0) }
    如果 (计数(AI_输入调度器_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_输入调度器_负载窗口)
    定义 趋势 = AI_输入调度器_负载窗口[n-1] - AI_输入调度器_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_输入调度器_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./内核直连层.nova")
导入("../中枢/内存初始化.nova")

定义 最大路径点 = 1024
定义 基数 = 1024

结构 画布状态 {
    填充色,
    描边色,
    线宽,
    全局透明,
    变换矩阵,
    裁剪横,
    裁剪纵,
    裁剪宽,
    裁剪高,
    帧缓冲,
    宽度,
    高度,
}

定义 可变 路径表 = 0
定义 可变 路径数 = 0
定义 可变 全局画布 = 0
定义 可变 绘制总数 = 0


函数 画布_创建(帧缓冲, 宽, 高) {
    全局画布 = 堆_分配(画布状态)
    全局画布.填充色 = 0xFF000000
    全局画布.描边色 = 0xFF000000
    全局画布.线宽 = 1
    全局画布.全局透明 = 基数
    全局画布.变换矩阵 = 0
    全局画布.裁剪横 = 0
    全局画布.裁剪纵 = 0
    全局画布.裁剪宽 = 宽
    全局画布.裁剪高 = 高
    全局画布.帧缓冲 = 帧缓冲
    全局画布.宽度 = 宽
    全局画布.高度 = 高
    路径表 = 堆_分配(最大路径点 * 8)
    路径数 = 0
    返回 全局画布
}

函数 画布_设填充色(颜色) {
    如果 (全局画布 == 0) { 返回 }
    全局画布.填充色 = 颜色
}

函数 画布_设描边色(颜色) {
    如果 (全局画布 == 0) { 返回 }
    全局画布.描边色 = 颜色
}

函数 画布_设线宽(宽度) {
    如果 (全局画布 == 0) { 返回 }
    全局画布.线宽 = 宽度
}

函数 画布_设透明(透明度) {
    如果 (全局画布 == 0) { 返回 }
    全局画布.全局透明 = 透明度
}

函数 画布_填充矩形(横, 纵, 宽, 高) {
    如果 (全局画布 == 0) { 返回 }
    绘制总数 = 绘制总数 + 1
    定义 可变 行 = 纵
    当 (行 < 纵 + 高 && 行 < 全局画布.高度) {
        如果 (行 < 0) { 行 = 行 + 1; 继续 }
        定义 可变 列 = 横
        当 (列 < 横 + 宽 && 列 < 全局画布.宽度) {
            如果 (列 >= 0) {
                画布_写像素(列, 行, 全局画布.填充色)
            }
            列 = 列 + 1
        }
        行 = 行 + 1
    }
}

函数 画布_描边矩形(横, 纵, 宽, 高) {
    如果 (全局画布 == 0) { 返回 }
    绘制总数 = 绘制总数 + 1
    画布_水平线(横, 纵, 宽)
    画布_水平线(横, 纵 + 高 - 1, 宽)
    画布_垂直线(横, 纵, 高)
    画布_垂直线(横 + 宽 - 1, 纵, 高)
}

函数 画布_清除矩形(横, 纵, 宽, 高) {
    如果 (全局画布 == 0) { 返回 }
    定义 可变 行 = 纵
    当 (行 < 纵 + 高 && 行 < 全局画布.高度) {
        如果 (行 >= 0) {
            定义 可变 列 = 横
            当 (列 < 横 + 宽 && 列 < 全局画布.宽度) {
                如果 (列 >= 0) { 画布_写像素(列, 行, 0) }
                列 = 列 + 1
            }
        }
        行 = 行 + 1
    }
}

函数 画布_水平线(横, 纵, 长度) {
    如果 (全局画布 == 0 || 纵 < 0 || 纵 >= 全局画布.高度) { 返回 }
    定义 可变 列 = 横
    当 (列 < 横 + 长度 && 列 < 全局画布.宽度) {
        如果 (列 >= 0) { 画布_写像素(列, 纵, 全局画布.描边色) }
        列 = 列 + 1
    }
}

函数 画布_垂直线(横, 纵, 长度) {
    如果 (全局画布 == 0 || 横 < 0 || 横 >= 全局画布.宽度) { 返回 }
    定义 可变 行 = 纵
    当 (行 < 纵 + 长度 && 行 < 全局画布.高度) {
        如果 (行 >= 0) { 画布_写像素(横, 行, 全局画布.描边色) }
        行 = 行 + 1
    }
}

函数 画布_开始路径() {
    路径数 = 0
}

函数 画布_移到(横, 纵) {
    如果 (路径数 >= 最大路径点) { 返回 }
    内存_写32(路径表 + 路径数 * 8, 横)
    内存_写32(路径表 + 路径数 * 8 + 4, 纵)
    路径数 = 路径数 + 1
}

函数 画布_线到(横, 纵) {
    如果 (路径数 >= 最大路径点) { 返回 }
    内存_写32(路径表 + 路径数 * 8, 横)
    内存_写32(路径表 + 路径数 * 8 + 4, 纵)
    路径数 = 路径数 + 1
}

函数 画布_描边路径() {
    如果 (全局画布 == 0 || 路径数 < 2) { 返回 }
    绘制总数 = 绘制总数 + 1
    定义 可变 序号 = 0
    当 (序号 < 路径数 - 1) {
        定义 横1 = 内存_读32(路径表 + 序号 * 8)
        定义 纵1 = 内存_读32(路径表 + 序号 * 8 + 4)
        定义 横2 = 内存_读32(路径表 + (序号 + 1) * 8)
        定义 纵2 = 内存_读32(路径表 + (序号 + 1) * 8 + 4)
        画布_画线(横1, 纵1, 横2, 纵2)
        序号 = 序号 + 1
    }
}

函数 画布_画线(横1, 纵1, 横2, 纵2) {
    定义 可变 差横 = 横2 - 横1
    定义 可变 差纵 = 纵2 - 纵1
    如果 (差横 < 0) { 差横 = 0 - 差横 }
    如果 (差纵 < 0) { 差纵 = 0 - 差纵 }
    定义 步横 = 1
    如果 (横2 < 横1) { 步横 = -1 }
    定义 步纵 = 1
    如果 (纵2 < 纵1) { 步纵 = -1 }
    定义 可变 误差 = 差横 - 差纵
    定义 可变 当前横 = 横1
    定义 可变 当前纵 = 纵1
    当 (真) {
        画布_写像素(当前横, 当前纵, 全局画布.描边色)
        如果 (当前横 == 横2 && 当前纵 == 纵2) { 跳出 }
        定义 双误差 = 误差 * 2
        如果 (双误差 > 0 - 差纵) { 误差 = 误差 - 差纵; 当前横 = 当前横 + 步横 }
        如果 (双误差 < 差横) { 误差 = 误差 + 差横; 当前纵 = 当前纵 + 步纵 }
    }
}

函数 画布_写像素(横, 纵, 颜色) {
    如果 (全局画布 == 0) { 返回 }
    如果 (横 < 0 || 横 >= 全局画布.宽度 || 纵 < 0 || 纵 >= 全局画布.高度) { 返回 }
    内存_写32(全局画布.帧缓冲 + (纵 * 全局画布.宽度 + 横) * 4, 颜色)
}

函数 画布_完整统计() {
    返回 [绘制总数, 路径数]
}

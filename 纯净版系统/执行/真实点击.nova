// §3 真实点击 — 犹豫+精确度偏差+按下时长

函数 行为仿真_点击(目标X, 目标Y) {
    仿真_总操作数 = 仿真_总操作数 + 1

    // ① 犹豫停顿(到达目标后短暂犹豫)
    定义 犹豫 = 仿真_随机范围(点击_前停顿最小, 点击_前停顿最大)
    犹豫 = 犹豫 * 仿真_当前画像.犹豫倾向 / 50

    // ② 精确度偏差(人类无法精确点中目标中心)
    定义 偏差X = 仿真_高斯(0, 3)    // ±3像素高斯分布
    定义 偏差Y = 仿真_高斯(0, 2)
    定义 实际X = 目标X + 偏差X
    定义 实际Y = 目标Y + 偏差Y

    // ③ 先移动鼠标到目标
    定义 轨迹 = 行为仿真_鼠标移动到(实际X, 实际Y)

    // ④ mousedown → 持续 → mouseup
    定义 持续时间 = 仿真_随机范围(点击_持续最小, 点击_持续最大)

    返回 [轨迹, 犹豫, 实际X, 实际Y, 持续时间]
}

函数 行为仿真_双击(目标X, 目标Y) {
    定义 第一次 = 行为仿真_点击(目标X, 目标Y)
    定义 间隔 = 仿真_随机范围(80, 200)    // 双击间隔80-200ms
    定义 第二次 = 行为仿真_点击(目标X + 仿真_随机范围(-2, 2), 目标Y + 仿真_随机范围(-1, 1))
    返回 [第一次, 间隔, 第二次]
}

// §4 真实拖拽 — 贝塞尔路径+手抖+速度变化

函数 行为仿真_拖拽(起X, 起Y, 终X, 终Y) {
    仿真_总操作数 = 仿真_总操作数 + 1

    // ① 移动到起点
    定义 移动轨迹 = 行为仿真_鼠标移动到(起X, 起Y)

    // ② 按下(mousedown)
    定义 按下犹豫 = 仿真_随机范围(30, 150)

    // ③ 拖拽路径(更多抖动,速度更慢)
    定义 dx = 终X - 起X
    定义 dy = 终Y - 起Y
    定义 距离 = 仿真_整数开方(dx * dx + dy * dy)
    定义 步数 = 距离 / 4
    如果 (步数 < 10) { 步数 = 10 }

    定义 可变 拖拽轨迹 = []
    定义 可变 i = 0
    当 (i <= 步数) {
        定义 t = (i * 1000) / 步数
        // 线性插值+手抖
        定义 px = 起X + (dx * t) / 1000 + 仿真_随机范围(0 - 拖拽_抖动幅度, 拖拽_抖动幅度)
        定义 py = 起Y + (dy * t) / 1000 + 仿真_随机范围(0 - 拖拽_抖动幅度, 拖拽_抖动幅度)

        定义 点 = 轨迹点 {}
        点.x = px; 点.y = py
        追加(拖拽轨迹, 点)
        i = i + 1
    }

    // ④ 确保最后一个点精确到达终点(±1像素)
    定义 终点 = 轨迹点 {}
    终点.x = 终X + 仿真_随机范围(-1, 1)
    终点.y = 终Y + 仿真_随机范围(-1, 1)
    追加(拖拽轨迹, 终点)

    // ⑤ 短暂停顿后释放(mouseup)
    定义 释放延迟 = 仿真_随机范围(20, 80)

    仿真_鼠标X = 终X
    仿真_鼠标Y = 终Y
    返回 [移动轨迹, 按下犹豫, 拖拽轨迹, 释放延迟]
}

// §5 真实键盘输入 — 可变节奏+偶发错误+修正

函数 行为仿真_输入文字(文本) {
    仿真_总操作数 = 仿真_总操作数 + 1
    定义 可变 事件列表 = []
    定义 可变 当前时间 = 高精度定时器_读取()
    定义 长度 = 字符串长度(文本)

    定义 可变 i = 0
    当 (i < 长度) {
        定义 字符 = 字符串子串(文本, i, 1)

        // 打字间隔: 高斯分布
        定义 WPM = 仿真_当前画像.打字速度WPM
        定义 基础间隔 = 60000 / (WPM * 5)    // 每字符毫秒
        定义 间隔 = 仿真_高斯(基础间隔, 键盘_间隔标准差)
        如果 (间隔 < 30) { 间隔 = 30 }

        // 特殊字符更慢(需要Shift等)
        如果 (字符 == "@" || 字符 == "#" || 字符 == "!" || 字符 == "?") {
            间隔 = 间隔 + 仿真_随机范围(30, 80)
        }

        // 空格后稍快(词间节奏)
        如果 (字符 == " ") {
            间隔 = 间隔 - 仿真_随机范围(10, 30)
        }

        定义 事件 = 键盘仿真事件 {}
        事件.字符 = 字符
        事件.是否错误 = 假
        事件.按下时间 = 当前时间
        事件.释放时间 = 当前时间 + 仿真_随机范围(40, 120)    // 按键持续

        // 偶发打字错误
        如果 (仿真_随机范围(0, 100) < 仿真_当前画像.打字错误率) {
            // 先输入错误字符
            定义 错误事件 = 键盘仿真事件 {}
            错误事件.字符 = 仿真_相邻键(字符)
            错误事件.是否错误 = 真
            错误事件.按下时间 = 当前时间
            错误事件.释放时间 = 当前时间 + 仿真_随机范围(30, 80)
            追加(事件列表, 错误事件)

            // 发现错误后停顿
            定义 发现延迟 = 仿真_随机范围(200, 600)
            当前时间 = 当前时间 + 发现延迟 * 1000

            // Backspace删除
            定义 退格事件 = 键盘仿真事件 {}
            退格事件.字符 = "BACKSPACE"
            退格事件.按下时间 = 当前时间
            退格事件.释放时间 = 当前时间 + 仿真_随机范围(30, 60) * 1000
            追加(事件列表, 退格事件)

            当前时间 = 当前时间 + 仿真_随机范围(80, 200) * 1000
            // 然后输入正确字符
            事件.按下时间 = 当前时间
            事件.释放时间 = 当前时间 + 仿真_随机范围(40, 120) * 1000
        }

        追加(事件列表, 事件)
        当前时间 = 当前时间 + 间隔 * 1000
        i = i + 1
    }

    返回 事件列表
}

函数 仿真_相邻键(字符) {
    // 返回键盘上相邻的键(模拟手指偏差)
    如果 (字符 == "a") { 返回 "s" }
    如果 (字符 == "s") { 返回 "d" }
    如果 (字符 == "d") { 返回 "f" }
    如果 (字符 == "e") { 返回 "r" }
    如果 (字符 == "i") { 返回 "o" }
    如果 (字符 == "o") { 返回 "p" }
    如果 (字符 == "n") { 返回 "m" }
    如果 (字符 == "t") { 返回 "y" }
    返回 字符    // 默认重复
}

定义 可变 AI_真实点击_调用数 = 0
定义 可变 AI_真实点击_异常数 = 0

函数 AI_真实点击_监控() {
    AI_真实点击_调用数 = AI_真实点击_调用数 + 1
    返回 AI_真实点击_异常数 == 0
}

函数 AI_真实点击_健康检查() {
    如果 (AI_真实点击_调用数 > 0 && AI_真实点击_异常数 * 100 / AI_真实点击_调用数 > 10) {
        返回 假
    }
    返回 真
}

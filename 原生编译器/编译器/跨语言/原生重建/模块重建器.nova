// Nova · 跨语言原生重建 · 模块重建器
// 职责: 根据统一语义图中的单个模块节点,生成对应的Nova模块源码
// 层级: 跨语言主线第7步子模块 — 单模块重建

// 重建状态

导入("../../../标准库/基础.nova")
导入("../统一语义/统一语义图.nova")

定义 重建_未开始 = 0
定义 重建_分析中 = 1
定义 重建_生成中 = 2
定义 重建_已完成 = 3
定义 重建_失败   = 4

// 模块重建上下文: [源路径, 目标路径, 状态, 语义节点列表, 生成行列表, 诊断]
函数 重建上下文_创建(源路径, 目标路径) {
    返回 [源路径, 目标路径, 重建_未开始, [], [], []]
}

函数 重建上下文_源路径(c) { 返回 c[0] }
函数 重建上下文_目标路径(c) { 返回 c[1] }
函数 重建上下文_状态(c) { 返回 c[2] }
函数 重建上下文_节点(c) { 返回 c[3] }
函数 重建上下文_生成行(c) { 返回 c[4] }
函数 重建上下文_诊断(c) { 返回 c[5] }

// 从语义节点生成Nova函数签名
函数 生成_函数签名(函数名, 参数列表) {
    定义 可变 签名 = 字符串拼接("函数 ", 函数名)
    签名 = 字符串拼接(签名, "(")
    定义 可变 i = 0
    当 (i < 计数(参数列表)) {
        如果 (i > 0) { 签名 = 字符串拼接(签名, ", ") }
        签名 = 字符串拼接(签名, 参数列表[i])
        i = i + 1
    }
    签名 = 字符串拼接(签名, ") {")
    返回 签名
}

// 从语义节点生成Nova结构声明
函数 生成_结构声明(结构名, 字段列表) {
    定义 可变 声明 = 字符串拼接("结构 ", 结构名)
    声明 = 字符串拼接(声明, "(")
    定义 可变 i = 0
    当 (i < 计数(字段列表)) {
        如果 (i > 0) { 声明 = 字符串拼接(声明, ", ") }
        声明 = 字符串拼接(声明, 字段列表[i])
        i = i + 1
    }
    声明 = 字符串拼接(声明, ")")
    返回 声明
}

// 从语义节点生成Nova常量定义
函数 生成_常量(名称, 值) {
    返回 字符串拼接("定义 ", 字符串拼接(名称, 字符串拼接(" = ", 转字符串(值))))
}

// 模块头注释生成
函数 生成_模块头(源语言, 源路径) {
    定义 可变 头 = "// ═══════════════════════════════════════════\n"
    头 = 字符串拼接(头, 字符串拼接("// 原生重置自: ", 字符串拼接(源语言, 字符串拼接(" → ", 字符串拼接(源路径, "\n")))))
    头 = 字符串拼接(头, "// 生成方式: Nova跨语言原生重建器\n")
    头 = 字符串拼接(头, "// 注意: 内部表达服从Nova风格,非逐行翻译\n")
    头 = 字符串拼接(头, "// ═══════════════════════════════════════════\n")
    返回 头
}

// 执行单模块重建
函数 模块重建_执行(上下文, 语义图) {
    上下文[2] = 重建_分析中

    // 1. 收集该模块关联的语义节点
    定义 节点列表 = 语义图_节点(语义图)
    定义 可变 i = 0
    当 (i < 计数(节点列表)) {
        定义 节点 = 节点列表[i]
        如果 (语义节点_源位置(节点) == 上下文[0]) {
            追加(上下文[3], 节点)
        }
        i = i + 1
    }

    上下文[2] = 重建_生成中

    // 2. 生成头部
    追加(上下文[4], 生成_模块头("外源", 上下文[0]))

    // 3. 逐节点生成
    i = 0
    当 (i < 计数(上下文[3])) {
        定义 节点 = 上下文[3][i]
        定义 类别 = 语义节点_类别(节点)
        如果 (类别 == 语义_类型) {
            追加(上下文[4], 字符串拼接("// 类型: ", 语义节点_名称(节点)))
        } 否则 如果 (类别 == 语义_资源) {
            追加(上下文[4], 字符串拼接("// 资源: ", 语义节点_名称(节点)))
        }
        i = i + 1
    }

    上下文[2] = 重建_已完成
    返回 上下文
}

// 重建报告
函数 模块重建_打印(上下文) {
    打印文本(字符串拼接("  源: ", 上下文[0]))
    打印文本(字符串拼接("  目标: ", 上下文[1]))
    定义 可变 状态名 = "unknown"
    如果 (上下文[2] == 重建_未开始) { 状态名 = "未开始" }
    如果 (上下文[2] == 重建_已完成) { 状态名 = "finished" }
    如果 (上下文[2] == 重建_失败)   { 状态名 = "failed" }
    打印文本(字符串拼接("  状态: ", 状态名))
    打印文本(字符串拼接("  生成行数: ", 转字符串(计数(上下文[4]))))
}

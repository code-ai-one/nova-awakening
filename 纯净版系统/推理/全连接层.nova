// §5 全连接层(Dense Layer) — y = activation(W·x + b)

定义 激活类型_无       = 0
定义 激活类型_ReLU     = 1
定义 激活类型_Nova激活函数  = 2
定义 激活类型_Tanh     = 3
定义 激活类型_Nova归一化指数  = 4
定义 激活类型_GELU     = 5

定义 可变 全连接层_量化次数 = 0
定义 可变 全连接层_量化累计误差 = 0
定义 可变 全连接层_量化最大误差 = 0

结构 DenseLayer {
    权重,    // u64 Tensor* [输入维度 × 输出维度]
    偏置,    // u64 Tensor* [1 × 输出维度]
    激活,    // u32 激活类型_xxx
    输入维度,
    输出维度,
}

函数 DenseLayer_创建(输入维度, 输出维度, 激活类型) {
    如果 (输入维度 <= 0 || 输出维度 <= 0) { 返回 0 }
    定义 层 = 堆_分配(DenseLayer)
    如果 (层 == 0) { 返回 0 }
    层.输入维度 = 输入维度
    层.输出维度 = 输出维度
    层.激活 = 激活类型
    层.权重 = Tensor_创建(输入维度, 输出维度)
    层.偏置 = Tensor_创建(1, 输出维度)
    如果 (层.权重 == 0 || 层.偏置 == 0) {
        如果 (层.权重 != 0) { Tensor_释放(层.权重) }
        如果 (层.偏置 != 0) { Tensor_释放(层.偏置) }
        堆_释放(层)
        返回 0
    }

    // Xavier初始化: 权重 ∈ [-√(6/(in+out)), √(6/(in+out))]
    定义 范围 = Q开方(Q除(6 * Q_ONE, (输入维度 + 输出维度) * Q_ONE))
    定义 可变 i = 0
    当 (i < 输入维度 * 输出维度) {
        // 简单伪随机: 线性同余
        定义 种子 = (i * 1103515245 + 12345) & 0x7FFFFFFF
        定义 随机值 = (种子 % (2 * 范围 + 1)) - 范围
        内存_写32(层.权重.数据 + i * 4, 随机值)
        i = i + 1
    }
    返回 层
}

函数 DenseLayer_销毁(层) {
    如果 (层 == 0) { 返回 }
    如果 (层.权重 != 0) { Tensor_释放(层.权重) }
    如果 (层.偏置 != 0) { Tensor_释放(层.偏置) }
    层.权重 = 0
    层.偏置 = 0
    层.输入维度 = 0
    层.输出维度 = 0
    堆_释放(层)
}

// 前向传播: output = activation(input × W + b)
函数 DenseLayer_前向(层, 输入) {
    如果 (层 == 0 || 输入 == 0) { 返回 0 }
    // input[batch × in] × W[in × out] = output[batch × out]
    定义 线性输出 = Tensor_矩阵乘(输入, 层.权重)
    如果 (线性输出 == 0) { 返回 0 }
    Tensor_加偏置(线性输出, 层.偏置)

    // 激活
    如果 (层.激活 == 激活类型_ReLU) { 激活_ReLU(线性输出) }
    否则 如果 (层.激活 == 激活类型_Nova激活函数) { 激活_Nova激活函数(线性输出) }
    否则 如果 (层.激活 == 激活类型_Tanh) { 激活_Tanh(线性输出) }
    否则 如果 (层.激活 == 激活类型_Nova归一化指数) { 激活_Nova归一化指数(线性输出) }
    否则 如果 (层.激活 == 激活类型_GELU) { 激活_GELU(线性输出) }

    返回 线性输出
}

// §6 多层感知器(Nova多层感知器) — 堆叠多个Dense层

结构 Nova多层感知器 {
    层列表,    // u64 DenseLayer* 数组
    层数量,
    层容量,
}

函数 Nova多层感知器_创建(容量) {
    如果 (容量 <= 0) { 返回 0 }
    定义 net = 堆_分配(Nova多层感知器)
    如果 (net == 0) { 返回 0 }
    net.层容量 = 容量
    net.层数量 = 0
    net.层列表 = 堆_分配_数组(容量 * 8)
    如果 (net.层列表 == 0) {
        堆_释放(net)
        返回 0
    }
    返回 net
}

函数 Nova多层感知器_添加层(net, 输入维度, 输出维度, 激活) {
    如果 (net == 0 || net.层数量 >= net.层容量) { 返回 }
    定义 层 = DenseLayer_创建(输入维度, 输出维度, 激活)
    如果 (层 == 0) { 返回 }
    内存_写64(net.层列表 + net.层数量 * 8, 层)
    net.层数量 = net.层数量 + 1
}

// Nova多层感知器前向传播: 依次通过每一层
函数 Nova多层感知器_前向(net, 输入) {
    如果 (net == 0 || 输入 == 0) { 返回 0 }
    定义 可变 当前 = 输入
    定义 可变 i = 0
    当 (i < net.层数量) {
        定义 层 = 内存_读64(net.层列表 + i * 8)
        如果 (层 == 0) { 返回 0 }
        定义 输出 = DenseLayer_前向(层, 当前)
        如果 (i > 0) { Tensor_释放(当前) }    // 释放中间结果
        当前 = 输出
        i = i + 1
    }
    返回 当前
}

函数 Nova多层感知器_销毁(net) {
    如果 (net == 0) { 返回 }
    定义 可变 i = 0
    当 (i < net.层数量) {
        定义 层 = 内存_读64(net.层列表 + i * 8)
        如果 (层 != 0) { DenseLayer_销毁(层) }
        i = i + 1
    }
    如果 (net.层列表 != 0) { 堆_释放(net.层列表) }
    net.层列表 = 0
    net.层数量 = 0
    net.层容量 = 0
    堆_释放(net)
}

// §7 INT8量化推理 — 极低开销推理(适合实时场景)
// 权重量化为i8, 推理用i16累加, 速度提升4倍

结构 QuantizedLayer {
    权重_i8,    // u64 i8* [输入 × 输出]
    偏置_i32,    // u64 i32* [输出]
    缩放因子,    // u32 Q10定点, 反量化用
    零点,    // i32 量化零点
    输入维度,
    输出维度,
}

// [v2反哺] DenseLayer_量化 — 全连接层量化→TurboQuant向量几何保持(内积误差<5%, 替换逐层INT8)
// TurboQuant_向量压缩 — Nova原生几何保持量化
// 旧版: 传统INT8/逐通道标量量化, 无内积保证
// TurboQuant: 向量级压缩, 保持相似度/内积结构
// 格式: 8bit/元素 = 4bit方向(极坐标) + 4bit幅值(相对模长)
// Rust验证: 内积保持误差<5%, vs INT8传统量化约15%
函数 TurboQuant_向量压缩(向量, 压缩输出, 维度) {
    如果 (向量 == 0 || 压缩输出 == 0 || 维度 == 0) { 返回 }
    // step1: 计算向量L2模长
    定义 可变 sum_sq = 0
    定义 可变 i = 0
    当 (i < 维度) {
        定义 v = Tensor_读(向量, i)
        sum_sq = sum_sq + Q乘(v, v)
        i = i + 1
    }
    定义 模长 = Q开方(sum_sq)
    如果 (模长 == 0) { 返回 }
    // step2: 极坐标编码每个元素 (方向4bit+幅值4bit=8bit)
    i = 0
    当 (i < 维度) {
        定义 v = Tensor_读(向量, i)
        定义 方向4 = v * 7 / 模长
        如果 (方向4 > 7) { 方向4 = 7 }
        如果 (方向4 < -7) { 方向4 = -7 }
        定义 幅值 = v * Q_ONE / 模长
        如果 (幅值 < 0) { 幅值 = 0 - 幅值 }
        定义 幅值4 = 幅值 * 15 / Q_ONE
        如果 (幅值4 > 15) { 幅值4 = 15 }
        定义 编码 = ((方向4 + 7) << 4) | 幅值4
        内存_写8(压缩输出 + i, 编码)
        i = i + 1
    }
}
函数 TurboQuant_向量解压(压缩输入, 向量输出, 维度, 模长_Q10) {
    如果 (压缩输入 == 0 || 向量输出 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 维度) {
        定义 编码 = 内存_读8(压缩输入 + i)
        定义 方向4 = ((编码 >> 4) & 15) - 7
        定义 幅值4 = 编码 & 15
        定义 v = 方向4 * 模长_Q10 / 7 * 幅值4 / 15
        Tensor_写(向量输出, i, v)
        i = i + 1
    }
}
// 内积保持验证: 压缩前后内积误差估计
函数 TurboQuant_内积误差估计(a_模长, b_模长, 维度) {
    // JL误差界: O(1/sqrt(k)) 其中k=目标维度
    定义 误差_Q10 = Q_ONE * 10 / Q开方(维度 * Q_ONE)
    返回 误差_Q10
}

// 渐进式剪枝 (实验室反哺: 比一次性剪枝精度高约10-15%)
// SM-2式: 分n阶段逐步增加稀疏度, 每阶段保留最重要权重

定义 PRUNE_通用安全阈值 = 500   // 通用模型: 稀疏度<50%
定义 PRUNE_中文安全阈值 = 600   // 中文模型: 可放宽到60% (高稀疏性容忍)
定义 PRUNE_最大阶段数 = 5       // 渐进式剪枝最大阶段数

函数 DenseLayer_渐进剪枝_阶段(层, 目标稀疏度_千分, 当前阶段, 总阶段数) {
    // 当前阶段目标稀疏度 = 目标稀疏度 * 当前阶段 / 总阶段数
    如果 (层 == 0 || 层.权重 == 0) { 返回 }
    定义 阶段稀疏度 = 目标稀疏度_千分 * 当前阶段 / 总阶段数
    // 清零低于阈值的权重 (幅度剪枝)
    定义 N = 层.输入维度 * 层.输出维度
    定义 可变 阈值 = 0
    定义 可变 排序值 = []
    定义 可变 i = 0
    当 (i < N) {
        追加(排序值, 绝对值(Tensor_读1D(层.权重, i)))
        i = i + 1
    }
    // 找到第 阶段稀疏度/1000 百分位的值作为阈值
    排序值 = 快速排序(排序值)
    定义 阈值idx = N * 阶段稀疏度 / 1000
    如果 (阈值idx >= N) { 阈值idx = N - 1 }
    阈值 = 排序值[阈值idx]
    // 应用剪枝掩码
    i = 0
    当 (i < N) {
        如果 (绝对值(Tensor_读1D(层.权重, i)) < 阈值) {
            Tensor_写1D(层.权重, i, 0)
        }
        i = i + 1
    }
}

函数 DenseLayer_当前稀疏度(层) {
    // 返回权重中零值比例（千分制）
    如果 (层 == 0 || 层.权重 == 0) { 返回 0 }
    定义 N = 层.输入维度 * 层.输出维度
    定义 可变 零数 = 0
    定义 可变 i = 0
    当 (i < N) {
        如果 (Tensor_读1D(层.权重, i) == 0) { 零数 = 零数 + 1 }
        i = i + 1
    }
    返回 零数 * 1000 / N
}

// INT8前向传播: 速度极快
函数 QuantizedLayer_前向(ql, 输入) {
    如果 (ql == 0 || 输入 == 0 || ql.输入维度 <= 0 || ql.输出维度 <= 0) { 返回 0 }
    如果 (ql.权重_i8 == 0 || ql.偏置_i32 == 0) { 返回 0 }
    定义 batch = 输入.行数
    定义 out = Tensor_创建(batch, ql.输出维度)
    如果 (out == 0) { 返回 0 }

    定义 可变 b = 0
    当 (b < batch) {
        定义 可变 j = 0
        当 (j < ql.输出维度) {
            定义 可变 累加 = 内存_读32有符号(ql.偏置_i32 + j * 4)
            定义 可变 k = 0
            当 (k < ql.输入维度) {
                定义 x = Tensor_读(输入, b, k)
                定义 w = 内存_读8(ql.权重_i8 + k * ql.输出维度 + j)
                // 反量化: real_w = w * scale + zero_point
                定义 真实w = Q乘(w, ql.缩放因子) + ql.零点
                累加 = 累加 + Q乘(x, 真实w)
                k = k + 1
            }
            Tensor_写(out, b, j, 累加)
            j = j + 1
        }
        b = b + 1
    }
    返回 out
}

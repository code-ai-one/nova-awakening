// Nova AI核心: AI总线感知与决策层 — 鼠标/键盘/滚动事件的AI处理
// 【颠覆性架构】每个用户交互事件都经过AI感知层处理:
//   ① 注视点追踪 — 根据鼠标轨迹预测用户注视区域
//   ② 行为预测 — 马尔可夫链+GRU预测下一步用户动作
//   ③ 滚动预测 — 预测滚动目标位置, 提前渲染
//   ④ 语义分类 — DOM节点的语义角色识别
//   ⑤ 注意力权重 — 基于神经网络的渲染优先级分配
//   ⑥ 渲染质量决策 — 感知质量+运动掩蔽+平滑过渡

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("./智能总线初始.nova")
导入("./余弦相似度.nova")
导入("./值乘.nova")
导入("./滚动预测.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/网络激活层前.nova")
导入("./注视点模型.nova")
导入("./运动掩蔽.nova")
导入("./行为预测器.nova")

// §1 常量定义

定义 Q_SHIFT = 10
定义 Q_ONE = 1024
定义 Q_HALF = 512
定义 动作_空闲 = 0
定义 动作_点击 = 1
定义 动作_滚动 = 2
定义 动作_输入 = 3
定义 动作_悬停 = 4
定义 动作_拖拽 = 5
定义 动作_缩放 = 6
定义 动作_双击 = 7
定义 动作_右键 = 8
定义 动作_返回 = 9

定义 渲染级别_高 = 3
定义 渲染级别_中 = 2
定义 渲染级别_低 = 1
定义 渲染级别_极低 = 0

定义 触摸_最大点数 = 10
定义 手势_无 = 0
定义 手势_捏合 = 1
定义 手势_旋转 = 2
定义 手势_滑动 = 3
定义 手势_长按 = 4

定义 鼠标轨迹_最大长度 = 64
定义 鼠标速度_快阈值 = 50
定义 鼠标速度_慢阈值 = 5

定义 错误_无效参数 = -1
定义 错误_未初始化 = -2

// §2 鼠标轨迹数据结构 — AI用于分析用户意图

结构 鼠标轨迹点 {
    x,              // 屏幕坐标x
    y,              // 屏幕坐标y
    时间戳,         // 事件时间戳
    速度,           // 当前移动速度
    方向角,         // 移动方向弧度*Q10
}

结构 鼠标轨迹分析器 {
    轨迹缓冲,       // 最近N个轨迹点
    缓冲长度,       // 当前缓冲中点数
    上次x,          // 上次x坐标
    上次y,          // 上次y坐标
    上次时间戳,     // 上次事件时间戳
    累计距离,       // 累计移动像素距离
    平均速度,       // 滑动平均速度
    方向稳定性,     // 方向变化的稳定性Q10
    是否拖拽中,     // 是否处于拖拽状态
    停留计数,       // 鼠标停留帧计数
    热区列表,       // 频繁访问区域列表
    热区数量,       // 热区数量
}

结构 热区 {
    中心x,          // 热区中心x
    中心y,          // 热区中心y
    半径,           // 热区半径
    访问次数,       // 被鼠标经过的次数
    上次访问帧,     // 上次访问时的帧计数
    权重,           // AI分配的重要性权重Q10
}

结构 触摸事件 {
    触摸ID,         // 触摸点唯一标识
    x,              // 触摸x坐标
    y,              // 触摸y坐标
    压力,           // 触摸压力0-1024
    时间戳,         // 事件时间戳
}

结构 手势状态 {
    当前手势,       // 手势类型
    手势进度,       // 手势完成度Q10
    起始距离,       // 捏合起始距离
    当前距离,       // 捏合当前距离
    起始角度,       // 旋转起始角度
    当前角度,       // 旋转当前角度
    触摸点数,       // 当前触摸点数量
    触摸点列表,     // 触摸点数组
}

// §3 鼠标轨迹分析器 — 创建/销毁/重置

定义 可变 全局轨迹分析器 = 0

函数 鼠标轨迹分析器_创建() {
    定义 分析器 = 鼠标轨迹分析器 {}
    分析器.轨迹缓冲 = []
    分析器.缓冲长度 = 0
    分析器.上次x = 0
    分析器.上次y = 0
    分析器.上次时间戳 = 0
    分析器.累计距离 = 0
    分析器.平均速度 = 0
    分析器.方向稳定性 = Q_ONE
    分析器.是否拖拽中 = 假
    分析器.停留计数 = 0
    分析器.热区列表 = []
    分析器.热区数量 = 0
    全局轨迹分析器 = 分析器
    返回 分析器
}

函数 鼠标轨迹分析器_销毁(分析器) {
    如果 (分析器 == 0) { 返回 }
    全局轨迹分析器 = 0
}

函数 鼠标轨迹分析器_重置(分析器) {
    如果 (分析器 == 0) { 返回 }
    分析器.轨迹缓冲 = []
    分析器.缓冲长度 = 0
    分析器.累计距离 = 0
    分析器.平均速度 = 0
    分析器.方向稳定性 = Q_ONE
    分析器.停留计数 = 0
}

// §4 感知层 — 处理用户输入事件, 更新AI状态

函数 AI总线_鼠标移动(bus, x, y) {
    如果 (bus == 0) { 返回 }

    // 更新注视点模型
    注视点模型_更新(bus.质量分配器.注视点, x, y)

    // 轨迹分析
    如果 (全局轨迹分析器 != 0) {
        鼠标轨迹_记录点(全局轨迹分析器, x, y, bus.帧计数)
    }

    // AI: 根据鼠标速度调整推理预算
    如果 (全局轨迹分析器 != 0) {
        如果 (全局轨迹分析器.平均速度 > 鼠标速度_快阈值) {
            // 鼠标快速移动时减少推理(用户在寻找目标)
            如果 (bus.AI推理预算 > 1000) {
                bus.AI推理预算 = bus.AI推理预算 - 50
            }
        } 否则 如果 (全局轨迹分析器.平均速度 < 鼠标速度_慢阈值) {
            // 鼠标缓慢移动时增加推理(用户在仔细阅读)
            如果 (bus.AI推理预算 < 4000) {
                bus.AI推理预算 = bus.AI推理预算 + 25
            }
        }
    }

    // 更新AI子系统心跳
    AI总线_子系统心跳(bus, 2)
}

函数 鼠标轨迹_记录点(分析器, x, y, 时间戳) {
    如果 (分析器 == 0) { 返回 }

    // 计算距离和速度
    定义 dx = x - 分析器.上次x
    定义 dy = y - 分析器.上次y
    定义 距离平方 = dx * dx + dy * dy
    定义 距离 = 整数平方根(距离平方)
    定义 dt = 时间戳 - 分析器.上次时间戳
    定义 可变 速度 = 0
    如果 (dt > 0) {
        速度 = (距离 * Q_ONE) / dt
    }

    // 计算方向角
    定义 方向角 = 快速反正切(dy, dx)

    // 创建轨迹点
    定义 点 = 鼠标轨迹点 {}
    点.x = x
    点.y = y
    点.时间戳 = 时间戳
    点.速度 = 速度
    点.方向角 = 方向角

    // 追加到缓冲
    如果 (分析器.缓冲长度 < 鼠标轨迹_最大长度) {
        追加(分析器.轨迹缓冲, 点)
        分析器.缓冲长度 = 分析器.缓冲长度 + 1
    } 否则 {
        // 滑动窗口: 移除最旧的点
        删除(分析器.轨迹缓冲, 0)
        追加(分析器.轨迹缓冲, 点)
    }

    // 更新滑动平均速度 (EMA: α=0.2)
    分析器.平均速度 = (分析器.平均速度 * 819 + 速度 * 205) / Q_ONE

    // 更新方向稳定性
    如果 (分析器.缓冲长度 > 2) {
        定义 上个点 = 分析器.轨迹缓冲[分析器.缓冲长度 - 2]
        定义 角度差 = 方向角 - 上个点.方向角
        如果 (角度差 < 0) { 角度差 = 0 - 角度差 }
        // 方向变化越大, 稳定性越低
        如果 (角度差 > Q_HALF) {
            分析器.方向稳定性 = (分析器.方向稳定性 * 900) / Q_ONE
        } 否则 {
            分析器.方向稳定性 = (分析器.方向稳定性 * 900 + Q_ONE * 124) / Q_ONE
        }
    }

    // 累计距离
    分析器.累计距离 = 分析器.累计距离 + 距离

    // 更新停留计数
    如果 (距离 < 3) {
        分析器.停留计数 = 分析器.停留计数 + 1
    } 否则 {
        分析器.停留计数 = 0
    }

    // 更新热区
    鼠标轨迹_更新热区(分析器, x, y, 时间戳)

    分析器.上次x = x
    分析器.上次y = y
    分析器.上次时间戳 = 时间戳
}

函数 鼠标轨迹_更新热区(分析器, x, y, 帧计数) {
    如果 (分析器 == 0) { 返回 }
    定义 可变 i = 0
    定义 可变 找到 = 假
    当 (i < 分析器.热区数量) {
        定义 区 = 分析器.热区列表[i]
        定义 dx = x - 区.中心x
        定义 dy = y - 区.中心y
        如果 (dx * dx + dy * dy < 区.半径 * 区.半径) {
            区.访问次数 = 区.访问次数 + 1
            区.上次访问帧 = 帧计数
            // AI: 访问次数越多, 权重越高
            区.权重 = (区.权重 * 900 + Q_ONE * 124) / Q_ONE
            如果 (区.权重 > Q_ONE) { 区.权重 = Q_ONE }
            找到 = 真
        }
        i = i + 1
    }

    如果 (找到 == 假 && 分析器.热区数量 < 32) {
        定义 新区 = 热区 {}
        新区.中心x = x
        新区.中心y = y
        新区.半径 = 48
        新区.访问次数 = 1
        新区.上次访问帧 = 帧计数
        新区.权重 = Q_HALF
        追加(分析器.热区列表, 新区)
        分析器.热区数量 = 分析器.热区数量 + 1
    }
}

函数 热区分析器_获取最热区域(分析器) {
    如果 (分析器 == 0 || 分析器.热区数量 == 0) { 返回 0 }
    定义 可变 最热索引 = 0
    定义 可变 最大权重 = 0
    定义 可变 i = 0
    当 (i < 分析器.热区数量) {
        如果 (分析器.热区列表[i].权重 > 最大权重) {
            最大权重 = 分析器.热区列表[i].权重
            最热索引 = i
        }
        i = i + 1
    }
    返回 分析器.热区列表[最热索引]
}

函数 AI总线_记录行为动作(bus, 当前动作) {
    如果 (bus == 0 || bus.行为预测器 == 0) { 返回 动作_空闲 }
    定义 预测 = 行为预测器_观察并预测(bus.行为预测器, 当前动作)
    定义 隐藏 = 行为预测器_当前隐藏(bus.行为预测器)
    如果 (隐藏 == 0) { 返回 预测 }

    如果 (bus.行为预测器.序列位置 > 注意力_最大序列) {
        AI总线_重置行为序列缓存(bus)
        bus.行为预测器.序列位置 = 1
    }

    定义 可变 位置 = 0
    如果 (bus.行为预测器.序列位置 > 0) {
        位置 = bus.行为预测器.序列位置 - 1
    }

    定义 上下文隐藏 = 0
    如果 (bus.行为序列模型 != 0 && bus.降级模式 < 3) {
        上下文隐藏 = AI总线_行为序列增量推理(bus, 隐藏, 位置)
    }

    如果 (上下文隐藏 != 0) {
        行为预测器_写入上下文隐藏(bus.行为预测器, 上下文隐藏)
        预测 = 行为预测器_输出头预测(bus.行为预测器, 上下文隐藏)
        Tensor_释放(上下文隐藏)
    } 否则 {
        行为预测器_写入上下文隐藏(bus.行为预测器, 隐藏)
    }

    Tensor_释放(隐藏)
    bus.行为预测器.上次预测 = 预测
    返回 预测
}

// §5 点击/双击/右键事件

定义 可变 上次点击时间 = 0
定义 可变 上次点击x = 0
定义 可变 上次点击y = 0

函数 AI总线_点击(bus, x, y) {
    如果 (bus == 0) { 返回 }
    注视点模型_更新(bus.质量分配器.注视点, x, y)
    AI总线_记录行为动作(bus, 动作_点击)

    // AI双击检测
    定义 dt = bus.帧计数 - 上次点击时间
    定义 dx = x - 上次点击x
    定义 dy = y - 上次点击y
    如果 (dt < 20 && dx * dx + dy * dy < 100) {
        AI总线_记录行为动作(bus, 动作_双击)
        打印("[AI感知] 检测到双击事件")
    }

    上次点击时间 = bus.帧计数
    上次点击x = x
    上次点击y = y
}

函数 AI总线_右键(bus, x, y) {
    如果 (bus == 0) { 返回 }
    注视点模型_更新(bus.质量分配器.注视点, x, y)
    AI总线_记录行为动作(bus, 动作_右键)
}

// §6 滚动事件 — AI预测滚动目标

函数 AI总线_滚动(bus, 滚动Y, 时间戳) {
    如果 (bus == 0) { 返回 }
    滚动预测器_更新(bus.滚动预测器, 滚动Y, 时间戳)
    AI总线_记录行为动作(bus, 动作_滚动)

    // 计算滚动速度(用于运动掩蔽)
    bus.滚动速度 = bus.滚动预测器.当前速度 >> Q_SHIFT

    // AI: 快速滚动时降低渲染质量
    如果 (bus.滚动速度 > 30) {
        如果 (bus.降级模式 < 1) {
            bus.降级模式 = 1
        }
    } 否则 如果 (bus.滚动速度 < 5 && bus.降级模式 > 0) {
        bus.降级模式 = bus.降级模式 - 1
    }
}

// §7 键盘/悬停/拖拽事件

函数 AI总线_键盘输入(bus) {
    如果 (bus == 0) { 返回 }
    AI总线_记录行为动作(bus, 动作_输入)
}

函数 AI总线_悬停(bus, x, y) {
    如果 (bus == 0) { 返回 }
    注视点模型_更新(bus.质量分配器.注视点, x, y)
    AI总线_记录行为动作(bus, 动作_悬停)

    // AI: 悬停时提高该区域渲染质量
    如果 (全局轨迹分析器 != 0) {
        全局轨迹分析器.停留计数 = 全局轨迹分析器.停留计数 + 1
    }
}

函数 AI总线_拖拽开始(bus, x, y) {
    如果 (bus == 0) { 返回 }
    如果 (全局轨迹分析器 != 0) {
        全局轨迹分析器.是否拖拽中 = 真
    }
    AI总线_记录行为动作(bus, 动作_拖拽)
}

函数 AI总线_拖拽结束(bus, x, y) {
    如果 (bus == 0) { 返回 }
    如果 (全局轨迹分析器 != 0) {
        全局轨迹分析器.是否拖拽中 = 假
    }
}

// §8 触摸与手势感知 — 移动设备AI感知

定义 可变 全局手势状态 = 0

函数 手势状态_创建() {
    定义 状态 = 手势状态 {}
    状态.当前手势 = 手势_无
    状态.手势进度 = 0
    状态.起始距离 = 0
    状态.当前距离 = 0
    状态.起始角度 = 0
    状态.当前角度 = 0
    状态.触摸点数 = 0
    状态.触摸点列表 = []
    全局手势状态 = 状态
    返回 状态
}

函数 AI总线_触摸开始(bus, 触摸ID, x, y, 压力) {
    如果 (bus == 0) { 返回 }
    如果 (全局手势状态 == 0) { 手势状态_创建() }
    定义 状态 = 全局手势状态
    如果 (状态.触摸点数 >= 触摸_最大点数) { 返回 }

    定义 触摸 = 触摸事件 {}
    触摸.触摸ID = 触摸ID
    触摸.x = x
    触摸.y = y
    触摸.压力 = 压力
    触摸.时间戳 = bus.帧计数
    追加(状态.触摸点列表, 触摸)
    状态.触摸点数 = 状态.触摸点数 + 1

    // AI: 多点触摸启动手势识别
    如果 (状态.触摸点数 == 2) {
        定义 p0 = 状态.触摸点列表[0]
        定义 p1 = 状态.触摸点列表[1]
        定义 dx = p1.x - p0.x
        定义 dy = p1.y - p0.y
        状态.起始距离 = 整数平方根(dx * dx + dy * dy)
        状态.起始角度 = 快速反正切(dy, dx)
    }
}

函数 AI总线_触摸移动(bus, 触摸ID, x, y) {
    如果 (bus == 0 || 全局手势状态 == 0) { 返回 }
    定义 状态 = 全局手势状态

    // 更新触摸点位置
    定义 可变 i = 0
    当 (i < 状态.触摸点数) {
        如果 (状态.触摸点列表[i].触摸ID == 触摸ID) {
            状态.触摸点列表[i].x = x
            状态.触摸点列表[i].y = y
        }
        i = i + 1
    }

    // AI手势识别: 两点时检测捏合/旋转
    如果 (状态.触摸点数 == 2) {
        定义 p0 = 状态.触摸点列表[0]
        定义 p1 = 状态.触摸点列表[1]
        定义 dx = p1.x - p0.x
        定义 dy = p1.y - p0.y
        状态.当前距离 = 整数平方根(dx * dx + dy * dy)
        状态.当前角度 = 快速反正切(dy, dx)

        // 捏合检测
        定义 距离变化 = 状态.当前距离 - 状态.起始距离
        如果 (距离变化 > 20 || 距离变化 < -20) {
            状态.当前手势 = 手势_捏合
            AI总线_记录行为动作(bus, 动作_缩放)
        }
    }
}

函数 AI总线_触摸结束(bus, 触摸ID) {
    如果 (bus == 0 || 全局手势状态 == 0) { 返回 }
    定义 状态 = 全局手势状态
    定义 可变 i = 0
    当 (i < 状态.触摸点数) {
        如果 (状态.触摸点列表[i].触摸ID == 触摸ID) {
            删除(状态.触摸点列表, i)
            状态.触摸点数 = 状态.触摸点数 - 1
            返回
        }
        i = i + 1
    }
    如果 (状态.触摸点数 == 0) {
        状态.当前手势 = 手势_无
    }
}

// §9 决策层 — 渲染管线各阶段的AI决策

函数 AI总线_语义分类(bus, 节点) {
    如果 (bus == 0 || 节点 == 0) { 返回 0 }
    如果 (bus.降级模式 >= 3) { 返回 0 }
    定义 嵌入 = 语义嵌入_计算节点嵌入(bus.语义引擎, 节点)
    如果 (嵌入 == 0) { 返回 0 }
    定义 角色 = 语义嵌入_分类节点角色(bus.语义引擎, 嵌入)
    Tensor_释放(嵌入)
    bus.推理次数 = bus.推理次数 + 1
    bus.累计推理次数 = bus.累计推理次数 + 1
    返回 角色
}

函数 AI总线_DOM语义分类_GQA(bus, 节点嵌入, 位置) {
    如果 (bus == 0 || 节点嵌入 == 0) { 返回 0 }
    如果 (bus.降级模式 >= 3) { 返回 0 }
    定义 上下文嵌入 = AI总线_DOM注意力增量推理(bus, 节点嵌入, 位置)
    定义 可变 角色 = 0
    如果 (上下文嵌入 != 0) {
        角色 = 语义嵌入_分类节点角色(bus.语义引擎, 上下文嵌入)
        Tensor_释放(上下文嵌入)
    } 否则 {
        角色 = 语义嵌入_分类节点角色(bus.语义引擎, 节点嵌入)
    }
    bus.推理次数 = bus.推理次数 + 1
    bus.累计推理次数 = bus.累计推理次数 + 1
    返回 角色
}

函数 AI总线_注意力权重(bus, 节点特征) {
    如果 (bus == 0 || bus.注意力网络 == 0) { 返回 Q_HALF }
    如果 (bus.降级模式 >= 2) { 返回 Q_HALF }
    定义 输出 = Nova多层感知器_前向(bus.注意力网络, 节点特征)
    定义 分数 = Tensor_读(输出, 0, 0)
    Tensor_释放(输出)
    bus.推理次数 = bus.推理次数 + 1
    bus.累计推理次数 = bus.累计推理次数 + 1
    返回 分数
}

函数 AI总线_渲染质量(bus, 区域x, 区域y, 区域w, 区域h, 语义重要性, 是否可见) {
    如果 (bus == 0) { 返回 渲染级别_中 }

    // 纯规则模式降级: 不使用AI
    如果 (bus.降级模式 >= 3) {
        如果 (是否可见 == 真) { 返回 渲染级别_中 }
        返回 渲染级别_低
    }

    // 运动掩蔽: 滚动时允许降级
    定义 运动降级 = 运动掩蔽_质量降级(bus.滚动速度)

    // 感知质量分配
    定义 可变 目标质量 = 质量分配器_决定质量(bus.质量分配器, 区域x, 区域y, 区域w, 区域h, 语义重要性, 是否可见)

    // 运动掩蔽降级
    目标质量 = 目标质量 - 运动降级
    如果 (目标质量 < 0) { 目标质量 = 0 }

    // AI热区加成: 鼠标频繁访问的区域提高质量
    如果 (全局轨迹分析器 != 0) {
        定义 可变 j = 0
        当 (j < 全局轨迹分析器.热区数量) {
            定义 区 = 全局轨迹分析器.热区列表[j]
            如果 (区域x < 区.中心x + 区.半径 && 区域x + 区域w > 区.中心x - 区.半径) {
                如果 (区域y < 区.中心y + 区.半径 && 区域y + 区域h > 区.中心y - 区.半径) {
                    定义 加成 = (区.权重 * 渲染级别_高) / Q_ONE
                    目标质量 = 目标质量 + 加成
                }
            }
            j = j + 1
        }
    }
    如果 (目标质量 > 渲染级别_高) { 目标质量 = 渲染级别_高 }

    // 平滑过渡(防止闪烁)
    定义 区域索引 = (区域y / 64) * 16 + (区域x / 64)
    如果 (区域索引 >= 256) { 区域索引 = 255 }
    定义 最终质量 = 质量平滑器_平滑(bus.质量平滑器, 区域索引, 目标质量)

    bus.推理次数 = bus.推理次数 + 1
    bus.累计推理次数 = bus.累计推理次数 + 1
    返回 最终质量
}

// §10 辅助数学函数

函数 整数平方根(n) {
    如果 (n <= 0) { 返回 0 }
    定义 可变 x = n
    定义 可变 y = (x + 1) / 2
    当 (y < x) {
        x = y
        y = (x + n / x) / 2
    }
    返回 x
}

函数 快速反正切(y, x) {
    如果 (x == 0 && y == 0) { 返回 0 }
    如果 (x == 0) {
        如果 (y > 0) { 返回 Q_HALF }
        返回 0 - Q_HALF
    }
    // 简化的atan2近似: 返回Q10格式角度
    定义 可变 角度 = (y * Q_ONE) / x
    如果 (角度 > Q_ONE) { 角度 = Q_ONE }
    如果 (角度 < 0 - Q_ONE) { 角度 = 0 - Q_ONE }
    返回 角度
}

// §11 统计输出

函数 AI感知层_打印统计() {
    如果 (全局轨迹分析器 == 0) {
        打印("[AI感知] 轨迹分析器未初始化")
        返回
    }
    定义 分析器 = 全局轨迹分析器
    打印("[AI感知] ═══ 感知层统计 ═══")
    打印(字符串拼接("  轨迹缓冲点数: ", 转字符串(分析器.缓冲长度)))
    打印(字符串拼接("  累计移动距离: ", 字符串拼接(转字符串(分析器.累计距离), "px")))
    打印(字符串拼接("  平均鼠标速度: ", 转字符串(分析器.平均速度)))
    打印(字符串拼接("  方向稳定性: ", 转字符串(分析器.方向稳定性)))
    打印(字符串拼接("  热区数量: ", 转字符串(分析器.热区数量)))
    打印(字符串拼接("  是否拖拽中: ", 转字符串(分析器.是否拖拽中)))
    打印(字符串拼接("  鼠标停留帧数: ", 转字符串(分析器.停留计数)))
    打印("[AI感知] ═══════════════════")
}

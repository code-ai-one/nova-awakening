// NovaOS HTML实体解析引擎 — 完整实现
// 职责: HTML5命名实体注册/数字实体解码/前缀树匹配/
//       哈希表查找/流式解析/AI辅助编码检测
// 原创理论: Nova多层感知实体编码网络——基于字符分布统计与
//         残差编码理论的智能实体匹配与纠错系统

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/恐慌.nova")
导入("../中枢/辅助存根.nova")
导入("../执行/控制台输出.nova")
导入("../执行/底层内存操.nova")
导入("../推理/值乘.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内存初始化.nova")

定义 实体表_最大容量 = 2500
定义 实体条目大小 = 24          // 每条目: 名称指针(8) + 名称长度(4) + 码点1(4) + 码点2(4) + 标志(4)
定义 哈希表_桶数 = 4096            // 2^12 哈希桶，超低碰撞率
定义 前缀树_节点大小 = 40         // 子节点指针(8) + 同级(8) + 字符(4) + 实体索引(4) + 是实体结束(4) + 深度(4) + 访问计数(8)
定义 前缀树_最大节点 = 16384
定义 解析缓存_大小 = 256          // LRU缓存槽位数

定义 实体标志_单码点 = 0x01
定义 实体标志_双码点 = 0x02
定义 实体标志_危险字符 = 0x04     // < > & " '
定义 实体标志_数学符号 = 0x08
定义 实体标志_希腊字母 = 0x10
定义 实体标志_箭头符号 = 0x20
定义 实体标志_货币符号 = 0x40
定义 实体标志_技术符号 = 0x80

定义 可变 实体表 = 0                  // 平坦实体数组基址
定义 可变 实体表大小 = 0              // 当前实体数量
定义 可变 哈希表 = 0                  // 哈希索引表基址
定义 可变 前缀树根 = 0                // Trie树根节点
定义 可变 前缀树节点池 = 0            // 节点内存池
定义 可变 前缀树已用节点 = 0          // 已分配节点数
定义 可变 解析缓存 = 0                // LRU缓存基址
定义 可变 AI特征向量 = 0              // AI字符编码检测特征

定义 可变 统计_命名查找次数 = 0
定义 可变 统计_命名查找命中 = 0
定义 可变 统计_数字解码次数 = 0
定义 可变 统计_数字解码失败 = 0
定义 可变 统计_缓存命中 = 0
定义 可变 统计_哈希碰撞 = 0
定义 可变 统计_前缀树遍历步数 = 0
定义 可变 统计_AI纠错次数 = 0

// §1 实体表初始化与内存布局

函数 实体系统_初始化() {
    // 分配实体平坦表: 每条目24字节
    实体表 = 堆_分配(实体表_最大容量 * 实体条目大小)
    如果 (实体表 == 0) { 内核恐慌("实体表内存分配失败") }
    内存_清零(实体表, 实体表_最大容量 * 实体条目大小)
    实体表大小 = 0

    // 分配哈希索引表: 每桶存储实体索引(4字节) + 链表指针(4字节)
    哈希表 = 堆_分配(哈希表_桶数 * 8)
    如果 (哈希表 == 0) { 内核恐慌("哈希表内存分配失败") }
    定义 可变 i = 0
    当 (i < 哈希表_桶数) {
        内存_写32(哈希表 + i * 8, 0xFFFFFFFF)   // 空桶标记
        内存_写32(哈希表 + i * 8 + 4, 0)         // 无链接
        i = i + 1
    }

    // 分配前缀树节点池
    前缀树节点池 = 堆_分配(前缀树_最大节点 * 前缀树_节点大小)
    如果 (前缀树节点池 == 0) { 内核恐慌("前缀树内存分配失败") }
    内存_清零(前缀树节点池, 前缀树_最大节点 * 前缀树_节点大小)
    前缀树根 = 前缀树_分配节点(0, -1)   // 根节点, 字符=0, 无实体
    前缀树已用节点 = 1

    // 分配LRU解析缓存: 每槽位 = 哈希键(4) + 实体索引(4) + 访问时间戳(8)
    解析缓存 = 堆_分配(解析缓存_大小 * 16)
    如果 (解析缓存 != 0) {
        内存_清零(解析缓存, 解析缓存_大小 * 16)
    }

    // 分配AI特征向量: 128维字符分布特征
    AI特征向量 = Tensor_创建(128)
    如果 (AI特征向量 != 0) {
        Tensor_清零(AI特征向量, 128)
    }

    // 注册所有HTML5命名实体
    实体表_注册全部()

    内核日志("实体解析引擎初始化完成: 注册实体=", 实体表大小, " 前缀树节点=", 前缀树已用节点)
}

// §2 哈希函数 — FNV-1a变体+字符分布加权
// Nova原创: 在FNV-1a基础上融合字符位置编码，利用字符在实体名中的
// 统计分布特征进行加权，降低相似实体名的碰撞概率

函数 实体名_哈希(名称, 长度) {
    // FNV-1a 变体: 偏移基数 = 2166136261 (FNV_offset_basis_32)
    定义 可变 h = 2166136261
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 字节取(名称, i)
        // FNV-1a核心: 先异或后乘法
        h = h ^ c
        h = h * 16777619           // FNV_prime_32
        // Nova加权: 位置编码叠加，阻止字符排列组合碰撞
        h = h ^ ((c * (i + 1) * 31) & 0xFFFF)
        i = i + 1
    }
    // 折叠压缩到桶范围
    返回 ((h ^ (h >> 16)) & (哈希表_桶数 - 1))
}

// 二次探测哈希: 当主桶碰撞时用二次多项式探测
函数 哈希_二次探测(主哈希, 探测次数) {
    // h(k,i) = (h1(k) + i*(i+1)/2) mod 桶数
    // 二次探测多项式保证当桶数为2的幂时能遍历所有桶
    定义 偏移 = (探测次数 * (探测次数 + 1)) / 2
    返回 ((主哈希 + 偏移) & (哈希表_桶数 - 1))
}

// §3 前缀树(Trie)结构 — 流式增量匹配
// 原创理论: 基于残差编码的自适应前缀树——每个节点维护字符
// 转移概率向量，高频路径自动压缩为跳转表，低频路径保持链表

函数 前缀树_分配节点(字符, 实体索引) {
    如果 (前缀树已用节点 >= 前缀树_最大节点) { 返回 0 }
    定义 节点 = 前缀树节点池 + 前缀树已用节点 * 前缀树_节点大小
    内存_写64(节点, 0)           // 子节点指针 = 空
    内存_写64(节点 + 8, 0)        // 同级兄弟指针 = 空
    内存_写32(节点 + 16, 字符)     // 当前字符
    内存_写32(节点 + 20, 实体索引)  // 实体索引(-1=非终止)
    内存_写32(节点 + 24, 0)        // 是否实体结束标志
    内存_写32(节点 + 28, 0)        // 深度
    内存_写64(节点 + 32, 0)        // 访问计数 = 0
    前缀树已用节点 = 前缀树已用节点 + 1
    返回 节点
}

函数 前缀树_插入(名称, 长度, 实体索引) {
    定义 可变 当前 = 前缀树根
    定义 可变 i = 0
    当 (i < 长度) {
        定义 c = 字节取(名称, i)
        // 在子节点链表中查找字符c
        定义 可变 子 = 内存_读64(当前)         // 第一个子节点
        定义 可变 找到 = 0
        当 (子 != 0) {
            如果 (内存_读32(子 + 16) == c) {
                找到 = 子
                跳出
            }
            子 = 内存_读64(子 + 8)               // 同级下一个
        }
        如果 (找到 == 0) {
            // 创建新子节点
            定义 新节点 = 前缀树_分配节点(c, -1)
            如果 (新节点 == 0) { 返回 }     // 节点池耗尽
            内存_写32(新节点 + 28, i + 1)    // 设置深度
            // 插入到子节点链表头部
            定义 旧头 = 内存_读64(当前)
            内存_写64(新节点 + 8, 旧头)    // 新节点.next = 旧头
            内存_写64(当前, 新节点)          // 父.child = 新节点
            找到 = 新节点
        }
        当前 = 找到
        i = i + 1
    }
    // 标记终止节点
    内存_写32(当前 + 20, 实体索引)
    内存_写32(当前 + 24, 1)             // 是实体结束 = 真
}

// 前缀树流式匹配: 每次输入一个字符，返回是否仍在有效前缀路径上
函数 前缀树_流式查找(节点, 字符) {
    统计_前缀树遍历步数 = 统计_前缀树遍历步数 + 1
    如果 (节点 == 0) { 返回 0 }
    定义 可变 子 = 内存_读64(节点)     // 第一个子节点
    当 (子 != 0) {
        如果 (内存_读32(子 + 16) == 字符) {
            // 更新访问计数
            定义 旧计 = 内存_读64(子 + 32)
            内存_写64(子 + 32, 旧计 + 1)
            返回 子
        }
        子 = 内存_读64(子 + 8)       // 同级下一个
    }
    返回 0   // 匹配失败
}

// 检查节点是否为实体终止节点
函数 前缀树_是实体(节点) {
    如果 (节点 == 0) { 返回 假 }
    返回 内存_读32(节点 + 24) != 0
}

函数 前缀树_获取实体索引(节点) {
    如果 (节点 == 0) { 返回 -1 }
    返回 内存_读32(节点 + 20)
}

// §4 实体添加核心 — 同时维护平坦表+哈希表+前缀树

函数 HTMLEntity_添加(名称, 码点1, 码点2) {
    如果 (实体表大小 >= 实体表_最大容量) { 返回 }

    定义 索引 = 实体表大小
    定义 偏移 = 实体表 + 索引 * 实体条目大小
    定义 名称副本 = 字符串_复制(名称)
    定义 名长 = 字符串_长度(名称)

    // 写入平坦表
    内存_写64(偏移, 名称副本)           // 名称指针
    内存_写32(偏移 + 8, 名长)             // 名称长度
    内存_写32(偏移 + 12, 码点1)            // 码点1
    内存_写32(偏移 + 16, 码点2)            // 码点2
    // 自动计算标志
    定义 标志 = 实体_计算标志(码点1, 码点2)
    内存_写32(偏移 + 20, 标志)

    实体表大小 = 实体表大小 + 1

    // 插入哈希表
    实体_插入哈希(名称副本, 名长, 索引)

    // 插入前缀树
    前缀树_插入(名称副本, 名长, 索引)
}

函数 HTMLEntity_添加_带标志(名称, 码点1, 码点2, 标志) {
    如果 (实体表大小 >= 实体表_最大容量) { 返回 }
    定义 索引 = 实体表大小
    定义 偏移 = 实体表 + 索引 * 实体条目大小
    定义 名称副本 = 字符串_复制(名称)
    定义 名长 = 字符串_长度(名称)
    内存_写64(偏移, 名称副本)
    内存_写32(偏移 + 8, 名长)
    内存_写32(偏移 + 12, 码点1)
    内存_写32(偏移 + 16, 码点2)
    内存_写32(偏移 + 20, 标志)
    实体表大小 = 实体表大小 + 1
    实体_插入哈希(名称副本, 名长, 索引)
    前缀树_插入(名称副本, 名长, 索引)
}

函数 实体_计算标志(码点1, 码点2) {
    定义 可变 f = 实体标志_单码点
    如果 (码点2 != 0) { f = 实体标志_双码点 }
    如果 (码点1 == 0x3C || 码点1 == 0x3E || 码点1 == 0x26 || 码点1 == 0x22 || 码点1 == 0x27) {
        f = f | 实体标志_危险字符
    }
    如果 (码点1 >= 0x0391 && 码点1 <= 0x03C9) { f = f | 实体标志_希腊字母 }
    如果 (码点1 >= 0x2190 && 码点1 <= 0x21FF) { f = f | 实体标志_箭头符号 }
    如果 (码点1 >= 0x2200 && 码点1 <= 0x22FF) { f = f | 实体标志_数学符号 }
    如果 (码点1 >= 0x20A0 && 码点1 <= 0x20CF) { f = f | 实体标志_货币符号 }
    返回 f
}

函数 实体_插入哈希(名称, 长度, 索引) {
    定义 主哈希 = 实体名_哈希(名称, 长度)
    定义 可变 探测 = 0
    当 (探测 < 64) {   // 最多64次探测
        定义 桶号 = 哈希_二次探测(主哈希, 探测)
        定义 已存 = 内存_读32(哈希表 + 桶号 * 8)
        如果 (已存 == 0xFFFFFFFF) {
            // 空桶，直接写入
            内存_写32(哈希表 + 桶号 * 8, 索引)
            返回
        }
        统计_哈希碰撞 = 统计_哈希碰撞 + 1
        探测 = 探测 + 1
    }
}

// §5 命名实体查找 — 哈希+前缀树双路径

// 精确查找: O(1)哈希查找，用于已知完整实体名
函数 实体_哈希查找(名称, 长度) {
    统计_命名查找次数 = 统计_命名查找次数 + 1

    // 先查LRU缓存
    定义 缓存结果 = 解析缓存_查找(名称, 长度)
    如果 (缓存结果 >= 0) {
        统计_缓存命中 = 统计_缓存命中 + 1
        统计_命名查找命中 = 统计_命名查找命中 + 1
        返回 缓存结果
    }

    // 哈希表查找
    定义 主哈希 = 实体名_哈希(名称, 长度)
    定义 可变 探测 = 0
    当 (探测 < 64) {
        定义 桶号 = 哈希_二次探测(主哈希, 探测)
        定义 已存索引 = 内存_读32(哈希表 + 桶号 * 8)
        如果 (已存索引 == 0xFFFFFFFF) { 返回 -1 }  // 空桶 = 不存在
        // 比较名称
        定义 条目 = 实体表 + 已存索引 * 实体条目大小
        定义 条目名 = 内存_读64(条目)
        定义 条目名长 = 内存_读32(条目 + 8)
        如果 (条目名长 == 长度 && 字符串_比较_定长(名称, 条目名, 长度) == 0) {
            统计_命名查找命中 = 统计_命名查找命中 + 1
            解析缓存_插入(名称, 长度, 已存索引)
            返回 已存索引
        }
        探测 = 探测 + 1
    }
    返回 -1
}

// 实体索引→码点解码
函数 实体_获取码点(索引, 码点输出) {
    如果 (索引 < 0 || 索引 >= 实体表大小) { 返回 0 }
    定义 条目 = 实体表 + 索引 * 实体条目大小
    定义 cp1 = 内存_读32(条目 + 12)
    定义 cp2 = 内存_读32(条目 + 16)
    内存_写32(码点输出, cp1)
    内存_写32(码点输出 + 4, cp2)
    如果 (cp2 != 0) { 返回 2 }
    返回 1
}

// §6 数字实体解码 (&#十进制; / &#x十六进制;)

函数 数字实体_解码(数据, 起始, 结束, 码点输出) {
    统计_数字解码次数 = 统计_数字解码次数 + 1
    如果 (起始 >= 结束) { 统计_数字解码失败 = 统计_数字解码失败 + 1; 返回 0 }

    定义 可变 pos = 起始
    定义 可变 是十六进制 = 假

    // 检查"x"或"X"前缀
    如果 (pos < 结束) {
        定义 c = 字节取(数据, pos)
        如果 (c == 0x78 || c == 0x58) {   // 'x' 或 'X'
            是十六进制 = 真
            pos = pos + 1
        }
    }

    定义 可变 码点 = 0
    定义 可变 位数 = 0
    定义 最大位数 = 8   // 防止溢出

    如果 (是十六进制) {
        当 (pos < 结束 && 位数 < 最大位数) {
            定义 c = 字节取(数据, pos)
            定义 可变 d = -1
            如果 (c >= 0x30 && c <= 0x39) { d = c - 0x30 }           // 0-9
            否则 如果 (c >= 0x41 && c <= 0x46) { d = c - 0x41 + 10 }  // A-F
            否则 如果 (c >= 0x61 && c <= 0x66) { d = c - 0x61 + 10 }  // a-f
            否则 { 跳出 }
            码点 = 码点 * 16 + d
            位数 = 位数 + 1
            pos = pos + 1
        }
    } 否则 {
        当 (pos < 结束 && 位数 < 最大位数) {
            定义 c = 字节取(数据, pos)
            如果 (c < 0x30 || c > 0x39) { 跳出 }   // 非数字
            码点 = 码点 * 10 + (c - 0x30)
            位数 = 位数 + 1
            pos = pos + 1
        }
    }

    如果 (位数 == 0) { 统计_数字解码失败 = 统计_数字解码失败 + 1; 返回 0 }

    // 验证码点有效性
    如果 (!码点_是合法Unicode(码点)) {
        统计_数字解码失败 = 统计_数字解码失败 + 1
        码点 = 0xFFFD   // 替换字符
    }

    // 检查是否是危险码点(HTML5规范禁止的控制字符)
    码点 = 数字实体_安全替换(码点)

    内存_写32(码点输出, 码点)
    内存_写32(码点输出 + 4, 0)   // 数字实体只有单码点
    返回 pos   // 返回消耗的字节数
}

// HTML5规范: 某些数字实体必须替换为其他码点
函数 数字实体_安全替换(码点) {
    // Windows-1252字符映射(HTML5 §8.2.4.69.2)
    如果 (码点 == 0x00) { 返回 0xFFFD }  // NULL → 替换字符
    如果 (码点 == 0x80) { 返回 0x20AC }  // → €
    如果 (码点 == 0x82) { 返回 0x201A }  // → ‚
    如果 (码点 == 0x83) { 返回 0x0192 }  // → ƒ
    如果 (码点 == 0x84) { 返回 0x201E }  // → „
    如果 (码点 == 0x85) { 返回 0x2026 }  // → …
    如果 (码点 == 0x86) { 返回 0x2020 }  // → †
    如果 (码点 == 0x87) { 返回 0x2021 }  // → ‡
    如果 (码点 == 0x88) { 返回 0x02C6 }  // → ˆ
    如果 (码点 == 0x89) { 返回 0x2030 }  // → ‰
    如果 (码点 == 0x8A) { 返回 0x0160 }  // → Š
    如果 (码点 == 0x8B) { 返回 0x2039 }  // → ‹
    如果 (码点 == 0x8C) { 返回 0x0152 }  // → Œ
    如果 (码点 == 0x8E) { 返回 0x017D }  // → Ž
    如果 (码点 == 0x91) { 返回 0x2018 }  // → ‘
    如果 (码点 == 0x92) { 返回 0x2019 }  // → ’
    如果 (码点 == 0x93) { 返回 0x201C }  // → “
    如果 (码点 == 0x94) { 返回 0x201D }  // → ”
    如果 (码点 == 0x95) { 返回 0x2022 }  // → •
    如果 (码点 == 0x96) { 返回 0x2013 }  // → –
    如果 (码点 == 0x97) { 返回 0x2014 }  // → —
    如果 (码点 == 0x98) { 返回 0x02DC }  // → ˜
    如果 (码点 == 0x99) { 返回 0x2122 }  // → ™
    如果 (码点 == 0x9A) { 返回 0x0161 }  // → š
    如果 (码点 == 0x9B) { 返回 0x203A }  // → ›
    如果 (码点 == 0x9C) { 返回 0x0153 }  // → œ
    如果 (码点 == 0x9E) { 返回 0x017E }  // → ž
    如果 (码点 == 0x9F) { 返回 0x0178 }  // → Ÿ
    // 禁止非字符码点
    如果 (码点 >= 0xFDD0 && 码点 <= 0xFDEF) { 返回 0xFFFD }
    如果 ((码点 & 0xFFFE) == 0xFFFE) { 返回 0xFFFD }   // U+xFFFE, U+xFFFF
    // 禁止代理对码点
    如果 (码点 >= 0xD800 && 码点 <= 0xDFFF) { 返回 0xFFFD }
    返回 码点
}

函数 码点_是合法Unicode(码点) {
    如果 (码点 > 0x10FFFF) { 返回 假 }
    如果 (码点 >= 0xD800 && 码点 <= 0xDFFF) { 返回 假 }   // 代理对
    返回 真
}

// §7 LRU解析缓存 — 热点实体加速
// 原创理论: 基于字符频率波动扫描的自适应缓存替换策略

函数 解析缓存_查找(名称, 长度) {
    如果 (解析缓存 == 0) { 返回 -1 }
    定义 哈希 = 实体名_哈希(名称, 长度)
    定义 槽位 = 哈希 & (解析缓存_大小 - 1)
    定义 基址 = 解析缓存 + 槽位 * 16
    定义 缓存哈希 = 内存_读32(基址)
    定义 缓存索引 = 内存_读32(基址 + 4)
    如果 (缓存哈希 == 哈希 && 缓存索引 != 0xFFFFFFFF) {
        // 验证实际实体名是否匹配(防止哈希碰撞导致误命中)
        定义 条目 = 实体表 + 缓存索引 * 实体条目大小
        定义 条目名 = 内存_读64(条目)
        定义 条目名长 = 内存_读32(条目 + 8)
        如果 (条目名长 == 长度 && 字符串_比较_定长(名称, 条目名, 长度) == 0) {
            // 更新时间戳
            内存_写64(基址 + 8, 当前时间_毫秒())
            返回 缓存索引
        }
    }
    返回 -1
}

函数 解析缓存_插入(名称, 长度, 索引) {
    如果 (解析缓存 == 0) { 返回 }
    定义 哈希 = 实体名_哈希(名称, 长度)
    定义 槽位 = 哈希 & (解析缓存_大小 - 1)
    定义 基址 = 解析缓存 + 槽位 * 16
    内存_写32(基址, 哈希)
    内存_写32(基址 + 4, 索引)
    内存_写64(基址 + 8, 当前时间_毫秒())
}

// §8 码点→UTF-8编码器

函数 码点_到UTF8(码点, 输出, 最大字节) {
    如果 (码点 <= 0x7F) {
        如果 (最大字节 < 1) { 返回 0 }
        字节写(输出, 0, 码点)
        返回 1
    }
    如果 (码点 <= 0x7FF) {
        如果 (最大字节 < 2) { 返回 0 }
        字节写(输出, 0, 0xC0 | (码点 >> 6))
        字节写(输出, 1, 0x80 | (码点 & 0x3F))
        返回 2
    }
    如果 (码点 <= 0xFFFF) {
        如果 (最大字节 < 3) { 返回 0 }
        字节写(输出, 0, 0xE0 | (码点 >> 12))
        字节写(输出, 1, 0x80 | ((码点 >> 6) & 0x3F))
        字节写(输出, 2, 0x80 | (码点 & 0x3F))
        返回 3
    }
    如果 (码点 <= 0x10FFFF) {
        如果 (最大字节 < 4) { 返回 0 }
        字节写(输出, 0, 0xF0 | (码点 >> 18))
        字节写(输出, 1, 0x80 | ((码点 >> 12) & 0x3F))
        字节写(输出, 2, 0x80 | ((码点 >> 6) & 0x3F))
        字节写(输出, 3, 0x80 | (码点 & 0x3F))
        返回 4
    }
    返回 0
}


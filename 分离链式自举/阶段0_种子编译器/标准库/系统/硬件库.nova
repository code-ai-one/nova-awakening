 如果 (_函数_播放声音 == 0) { _函数_播放声音 = 获取函数(_多媒体库, "PlaySoundA") }
 // SND_FILENAME=0x20000, SND_ASYNC=0x01
 调用指针(_函数_播放声音,  文件名, x20001, 0, 0, 0)
}


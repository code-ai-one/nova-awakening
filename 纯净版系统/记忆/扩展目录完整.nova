导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/整数转字符串.nova")

定义 目录项大小 = 264
定义 最大名长 = 255
定义 哈希种子 = 0x12A3FE2D

结构 目录项 {
    节点号,
    项长度,
    名长度,
    文件类型,
    名称哈希,
    名称数据,
}

定义 可变 查找次数 = 0
定义 可变 添加次数 = 0
定义 可变 删除次数 = 0
定义 可变 遍历次数 = 0
定义 可变 哈希碰撞 = 0

函数 目录_半字节哈希(名称, 长度) {
    定义 可变 哈希 = 哈希种子
    定义 可变 位 = 0
    当 (位 < 长度) {
        定义 字节 = 内存_读8(名称 + 位)
        哈希 = (哈希 << 5) + 哈希 + 字节
        哈希 = 哈希 ^ (哈希 >> 16)
        位 = 位 + 1
    }
    返回 哈希 & 0x7FFFFFFF
}

函数 目录_查找(块数据, 块大小, 名称, 名长) {
    查找次数 = 查找次数 + 1
    定义 目标哈希 = 目录_半字节哈希(名称, 名长)
    定义 可变 偏移 = 0
    当 (偏移 < 块大小) {
        定义 节点号 = 内存_读32(块数据 + 偏移)
        定义 项长 = 内存_读16(块数据 + 偏移 + 4)
        定义 当前名长 = 内存_读8(块数据 + 偏移 + 6)
        如果 (项长 == 0) { 跳出 }
        如果 (节点号 != 0 && 当前名长 == 名长) {
            定义 当前哈希 = 目录_半字节哈希(块数据 + 偏移 + 8, 当前名长)
            如果 (当前哈希 == 目标哈希) {
                定义 可变 匹配 = 真
                定义 可变 比 = 0
                当 (比 < 名长) {
                    如果 (内存_读8(块数据 + 偏移 + 8 + 比) != 内存_读8(名称 + 比)) {
                        匹配 = 假
                        哈希碰撞 = 哈希碰撞 + 1
                        跳出
                    }
                    比 = 比 + 1
                }
                如果 (匹配) { 返回 偏移 }
            }
        }
        偏移 = 偏移 + 项长
    }
    返回 -1
}

函数 目录_添加项(块数据, 块大小, 节点号, 名称, 名长, 文件类型) {
    添加次数 = 添加次数 + 1
    定义 需要空间 = ((名长 + 8 + 3) / 4) * 4
    定义 可变 偏移 = 0
    当 (偏移 < 块大小) {
        定义 当前节点 = 内存_读32(块数据 + 偏移)
        定义 当前项长 = 内存_读16(块数据 + 偏移 + 4)
        如果 (当前项长 == 0) { 跳出 }
        定义 当前名长 = 内存_读8(块数据 + 偏移 + 6)
        定义 实际占用 = ((当前名长 + 8 + 3) / 4) * 4
        如果 (当前节点 == 0) {
            如果 (当前项长 >= 需要空间) {
                内存_写32(块数据 + 偏移, 节点号)
                内存_写16(块数据 + 偏移 + 4, 当前项长)
                内存_写8(块数据 + 偏移 + 6, 名长)
                内存_写8(块数据 + 偏移 + 7, 文件类型)
                内存_复制(块数据 + 偏移 + 8, 名称, 名长)
                返回 0
            }
        } 否则 如果 (当前项长 - 实际占用 >= 需要空间) {
            定义 新偏移 = 偏移 + 实际占用
            内存_写16(块数据 + 偏移 + 4, 实际占用)
            内存_写32(块数据 + 新偏移, 节点号)
            内存_写16(块数据 + 新偏移 + 4, 当前项长 - 实际占用)
            内存_写8(块数据 + 新偏移 + 6, 名长)
            内存_写8(块数据 + 新偏移 + 7, 文件类型)
            内存_复制(块数据 + 新偏移 + 8, 名称, 名长)
            返回 0
        }
        偏移 = 偏移 + 当前项长
    }
    返回 错误_无空间
}

函数 目录_删除项(块数据, 块大小, 名称, 名长) {
    删除次数 = 删除次数 + 1
    定义 位置 = 目录_查找(块数据, 块大小, 名称, 名长)
    如果 (位置 < 0) { 返回 错误_不存在 }
    内存_写32(块数据 + 位置, 0)
    返回 0
}

函数 目录_遍历(块数据, 块大小, 回调) {
    遍历次数 = 遍历次数 + 1
    定义 可变 偏移 = 0
    定义 可变 计数 = 0
    当 (偏移 < 块大小) {
        定义 节点号 = 内存_读32(块数据 + 偏移)
        定义 项长 = 内存_读16(块数据 + 偏移 + 4)
        如果 (项长 == 0) { 跳出 }
        如果 (节点号 != 0) {
            定义 名长 = 内存_读8(块数据 + 偏移 + 6)
            定义 类型 = 内存_读8(块数据 + 偏移 + 7)
            如果 (回调 != 0) { 回调(节点号, 块数据 + 偏移 + 8, 名长, 类型) }
            计数 = 计数 + 1
        }
        偏移 = 偏移 + 项长
    }
    返回 计数
}

函数 目录_获取节点号(块数据, 块大小, 名称, 名长) {
    定义 位置 = 目录_查找(块数据, 块大小, 名称, 名长)
    如果 (位置 < 0) { 返回 0 }
    返回 内存_读32(块数据 + 位置)
}

函数 目录_项数(块数据, 块大小) {
    定义 可变 偏移 = 0
    定义 可变 计数 = 0
    当 (偏移 < 块大小) {
        定义 项长 = 内存_读16(块数据 + 偏移 + 4)
        如果 (项长 == 0) { 跳出 }
        如果 (内存_读32(块数据 + 偏移) != 0) { 计数 = 计数 + 1 }
        偏移 = 偏移 + 项长
    }
    返回 计数
}

函数 扩展目录_完整统计() {
    返回 [查找次数, 添加次数, 删除次数, 遍历次数, 哈希碰撞]
}

// §2 ext4目录健康检查

函数 扩展目录_健康检查() {
    定义 可变 问题 = []
    如果 (哈希碰撞 > 查找次数 / 5 && 查找次数 > 100) {
        追加(问题, "哈希碰撞率过高: " + 整数转字符串(哈希碰撞) + "/" + 整数转字符串(查找次数))
    }
    如果 (删除次数 > 添加次数 && 添加次数 > 100) {
        追加(问题, "删除多于添加: 可能存在碎片化")
    }
    如果 (计数(问题) == 0) { 返回 "ext4目录健康" }
    返回 问题
}

函数 扩展目录_重置统计() {
    查找次数 = 0
    添加次数 = 0
    删除次数 = 0
    遍历次数 = 0
    哈希碰撞 = 0
}

函数 扩展目录_查找率() {
    如果 (查找次数 == 0) { 返回 0 }
    返回 (查找次数 - 哈希碰撞) * 100 / 查找次数
}

// §3 ext4文件类型常量

定义 EXT4_FT_UNKNOWN = 0
定义 EXT4_FT_REG_FILE = 1
定义 EXT4_FT_DIR = 2
定义 EXT4_FT_CHRDEV = 3
定义 EXT4_FT_BLKDEV = 4
定义 EXT4_FT_FIFO = 5
定义 EXT4_FT_SOCK = 6
定义 EXT4_FT_SYMLINK = 7

函数 ext4_文件类型名(类型) {
    如果 (类型 == EXT4_FT_UNKNOWN) { 返回 "unknown" }
    如果 (类型 == EXT4_FT_REG_FILE) { 返回 "file" }
    如果 (类型 == EXT4_FT_DIR) { 返回 "directory" }
    如果 (类型 == EXT4_FT_CHRDEV) { 返回 "char_device" }
    如果 (类型 == EXT4_FT_BLKDEV) { 返回 "block_device" }
    如果 (类型 == EXT4_FT_FIFO) { 返回 "fifo" }
    如果 (类型 == EXT4_FT_SOCK) { 返回 "socket" }
    如果 (类型 == EXT4_FT_SYMLINK) { 返回 "symlink" }
    返回 "unknown"
}

函数 ext4_是目录(类型) { 返回 类型 == EXT4_FT_DIR }
函数 ext4_是普通文件(类型) { 返回 类型 == EXT4_FT_REG_FILE }
函数 ext4_是符号链接(类型) { 返回 类型 == EXT4_FT_SYMLINK }

// §4 目录块操作扩展

函数 目录_空间使用率(块数据, 块大小) {
    定义 可变 已用 = 0
    定义 可变 偏移 = 0
    当 (偏移 < 块大小) {
        定义 项长 = 内存_读16(块数据 + 偏移 + 4)
        如果 (项长 == 0) { 跳出 }
        如果 (内存_读32(块数据 + 偏移) != 0) {
            定义 名长 = 内存_读8(块数据 + 偏移 + 6)
            已用 = 已用 + ((名长 + 8 + 3) / 4) * 4
        }
        偏移 = 偏移 + 项长
    }
    如果 (块大小 == 0) { 返回 0 }
    返回 已用 * 100 / 块大小
}

函数 目录_最大可用空间(块数据, 块大小) {
    定义 可变 最大 = 0
    定义 可变 偏移 = 0
    当 (偏移 < 块大小) {
        定义 节点号 = 内存_读32(块数据 + 偏移)
        定义 项长 = 内存_读16(块数据 + 偏移 + 4)
        如果 (项长 == 0) { 跳出 }
        如果 (节点号 == 0) {
            如果 (项长 > 最大) { 最大 = 项长 }
        } 否则 {
            定义 名长 = 内存_读8(块数据 + 偏移 + 6)
            定义 实际 = ((名长 + 8 + 3) / 4) * 4
            定义 剩余 = 项长 - 实际
            如果 (剩余 > 最大) { 最大 = 剩余 }
        }
        偏移 = 偏移 + 项长
    }
    返回 最大
}

函数 目录_能否插入(块数据, 块大小, 名长) {
    定义 需要 = ((名长 + 8 + 3) / 4) * 4
    返回 目录_最大可用空间(块数据, 块大小) >= 需要
}

函数 目录_重命名(块数据, 块大小, 旧名, 旧名长, 新名, 新名长) {
    定义 位置 = 目录_查找(块数据, 块大小, 旧名, 旧名长)
    如果 (位置 < 0) { 返回 错误_不存在 }
    定义 节点号 = 内存_读32(块数据 + 位置)
    定义 类型 = 内存_读8(块数据 + 位置 + 7)
    定义 结果 = 目录_删除项(块数据, 块大小, 旧名, 旧名长)
    如果 (结果 < 0) { 返回 结果 }
    返回 目录_添加项(块数据, 块大小, 节点号, 新名, 新名长, 类型)
}

// §5 htree(哈希树)目录索引

定义 HTREE_HASH_HALF_MD4 = 1
定义 HTREE_HASH_TEA = 2
定义 HTREE_HASH_LEGACY = 3
定义 HTREE_HASH_SIPHASH = 4

结构 htree_dx_根 {
    保留长度,
    哈希版本,
    信息长度,
    间接层级,
    未使用,
}

结构 htree_dx_项 {
    哈希,
    块号,
}

定义 可变 htree_查找次数 = 0
定义 可变 htree_分裂次数 = 0

函数 htree_哈希_半MD4(名称, 名长, 种子) {
    定义 可变 哈希 = 种子
    定义 可变 i = 0
    当 (i < 名长) {
        定义 ch = 内存_读8(名称 + i)
        哈希 = ((哈希 << 5) + 哈希) ^ ch
        i = i + 1
    }
    返回 哈希 & 0x7FFFFFFF
}

函数 htree_查找(根, 名称, 名长) {
    htree_查找次数 = htree_查找次数 + 1
    定义 哈希 = htree_哈希_半MD4(名称, 名长, 哈希种子)
    返回 哈希
}

函数 htree_统计() {
    返回 {
        查找: htree_查找次数,
        分裂: htree_分裂次数,
    }
}

// §6 错误码

定义 错误_不存在 = -2
定义 错误_无空间 = -28
定义 错误_已存在 = -17
定义 错误_不是目录 = -20
定义 错误_目录非空 = -39

// §7 ext4超级块常量

定义 EXT4_SUPER_MAGIC = 0xEF53
定义 EXT4_BLOCK_SIZE_1K = 0
定义 EXT4_BLOCK_SIZE_2K = 1
定义 EXT4_BLOCK_SIZE_4K = 2
定义 EXT4_BLOCK_SIZE_64K = 6

定义 EXT4_FEATURE_INCOMPAT_FILETYPE = 0x0002
定义 EXT4_FEATURE_INCOMPAT_EXTENTS = 0x0040
定义 EXT4_FEATURE_INCOMPAT_64BIT = 0x0080
定义 EXT4_FEATURE_INCOMPAT_FLEX_BG = 0x0200
定义 EXT4_FEATURE_INCOMPAT_DIRDATA = 0x1000

函数 ext4_块大小(log块大小) {
    返回 1024 << log块大小
}

函数 ext4_特性名(特性) {
    定义 可变 结果 = []
    如果 (特性 & EXT4_FEATURE_INCOMPAT_FILETYPE) { 追加(结果, "filetype") }
    如果 (特性 & EXT4_FEATURE_INCOMPAT_EXTENTS) { 追加(结果, "extents") }
    如果 (特性 & EXT4_FEATURE_INCOMPAT_64BIT) { 追加(结果, "64bit") }
    如果 (特性 & EXT4_FEATURE_INCOMPAT_FLEX_BG) { 追加(结果, "flex_bg") }
    返回 结果
}

函数 扩展目录_详细统计() {
    返回 {
        查找: 查找次数,
        添加: 添加次数,
        删除: 删除次数,
        遍历: 遍历次数,
        碰撞: 哈希碰撞,
        查找成功率: 扩展目录_查找率(),
        htree查找: htree_查找次数,
        htree分裂: htree_分裂次数,
    }
}

定义 可变 AI_扩展目录完_热文件表 = []

函数 AI_扩展目录完_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_扩展目录完_热文件表)) {
        如果 (AI_扩展目录完_热文件表[i].路径 == 路径) {
            AI_扩展目录完_热文件表[i].频率 = AI_扩展目录完_热文件表[i].频率 + 1
            返回 AI_扩展目录完_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_扩展目录完_热文件表) < 128) {
        追加(AI_扩展目录完_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_扩展目录完_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

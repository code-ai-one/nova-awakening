导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./内核直连层.nova")
导入("../中枢/内存初始化.nova")

定义 组合_后代 = 0
定义 组合_子代 = 1
定义 组合_相邻 = 2
定义 组合_通用 = 3
定义 匹配_标签 = 1
定义 匹配_类 = 2
定义 匹配_标识 = 3
定义 匹配_属性 = 4
定义 匹配_伪类 = 5
定义 布隆大小 = 256

结构 选择器部分 {
    匹配类型,
    值哈希,
    组合子,
}

定义 可变 布隆过滤 = 0
定义 可变 匹配总数 = 0
定义 可变 布隆命中 = 0
定义 可变 布隆排除 = 0

函数 选择器_初始化() {
    布隆过滤 = 堆_分配(布隆大小 / 8)
    定义 可变 序号 = 0
    当 (序号 < 布隆大小 / 8) {
        内存_写8(布隆过滤 + 序号, 0)
        序号 = 序号 + 1
    }
}

函数 选择器_布隆添加(哈希) {
    定义 位1 = 哈希 % 布隆大小
    定义 位2 = (哈希 >> 8) % 布隆大小
    内存_写8(布隆过滤 + 位1 / 8, 内存_读8(布隆过滤 + 位1 / 8) | (1 << (位1 % 8)))
    内存_写8(布隆过滤 + 位2 / 8, 内存_读8(布隆过滤 + 位2 / 8) | (1 << (位2 % 8)))
}

函数 选择器_布隆测试(哈希) {
    定义 位1 = 哈希 % 布隆大小
    定义 位2 = (哈希 >> 8) % 布隆大小
    定义 字节1 = 内存_读8(布隆过滤 + 位1 / 8)
    定义 字节2 = 内存_读8(布隆过滤 + 位2 / 8)
    返回 (字节1 & (1 << (位1 % 8))) != 0 && (字节2 & (1 << (位2 % 8))) != 0
}

函数 选择器_计算特异度(部分表, 部分数) {
    定义 可变 标识数 = 0
    定义 可变 类数 = 0
    定义 可变 标签数 = 0
    定义 可变 序号 = 0
    当 (序号 < 部分数) {
        定义 偏移 = 部分表 + 序号 * 12
        定义 类型 = 内存_读32(偏移)
        如果 (类型 == 匹配_标识) { 标识数 = 标识数 + 1 }
        否则 如果 (类型 == 匹配_类 || 类型 == 匹配_属性 || 类型 == 匹配_伪类) { 类数 = 类数 + 1 }
        否则 如果 (类型 == 匹配_标签) { 标签数 = 标签数 + 1 }
        序号 = 序号 + 1
    }
    返回 (标识数 << 16) | (类数 << 8) | 标签数
}

函数 选择器_匹配元素(部分表, 部分数, 元素标签, 元素类列表, 元素标识) {
    匹配总数 = 匹配总数 + 1
    定义 可变 序号 = 部分数 - 1
    当 (序号 >= 0) {
        定义 偏移 = 部分表 + 序号 * 12
        定义 类型 = 内存_读32(偏移)
        定义 值 = 内存_读64(偏移 + 4)
        定义 可变 匹配 = 假
        如果 (类型 == 匹配_标签) {
            匹配 = (值 == 元素标签)
        } 否则 如果 (类型 == 匹配_类) {
            匹配 = 选择器_类列表包含(元素类列表, 值)
        } 否则 如果 (类型 == 匹配_标识) {
            匹配 = (值 == 元素标识)
        }
        如果 (!匹配) { 返回 假 }
        序号 = 序号 - 1
    }
    返回 真
}

函数 选择器_类列表包含(类列表, 目标哈希) {
    如果 (类列表 == 0) { 返回 假 }
    如果 (!选择器_布隆测试(目标哈希)) {
        布隆排除 = 布隆排除 + 1
        返回 假
    }
    布隆命中 = 布隆命中 + 1
    返回 真
}

函数 选择器_快速排除(元素标签, 选择器最后标签) {
    如果 (选择器最后标签 == 0) { 返回 假 }
    返回 元素标签 != 选择器最后标签
}

函数 选择器_匹配率() {
    如果 (匹配总数 == 0) { 返回 0 }
    返回 (布隆命中 + 布隆排除) * 100 / 匹配总数
}

函数 选择器_完整统计() {
    返回 [匹配总数, 布隆命中, 布隆排除]
}

函数 信号_获取默认动作(信号号) {
    // Nova接口标准标准默认动作
    如果 (信号号 == 1)  { 返回 动作_终止 }      // SIGHUP
    如果 (信号号 == 2)  { 返回 动作_终止 }      // SIGINT
    如果 (信号号 == 3)  { 返回 动作_核心转储 }  // SIGQUIT
    如果 (信号号 == 4)  { 返回 动作_核心转储 }  // SIGILL
    如果 (信号号 == 6)  { 返回 动作_核心转储 }  // SIGABRT
    如果 (信号号 == 8)  { 返回 动作_核心转储 }  // SIGFPE
    如果 (信号号 == 9)  { 返回 动作_终止 }      // SIGKILL
    如果 (信号号 == 11) { 返回 动作_核心转储 }  // SIGSEGV
    如果 (信号号 == 13) { 返回 动作_终止 }      // SIGPIPE
    如果 (信号号 == 14) { 返回 动作_终止 }      // SIGALRM
    如果 (信号号 == 15) { 返回 动作_终止 }      // SIGTERM
    如果 (信号号 == 17) { 返回 动作_忽略 }      // SIGCHLD
    如果 (信号号 == 18) { 返回 动作_继续 }      // SIGCONT
    如果 (信号号 == 19) { 返回 动作_停止 }      // SIGSTOP
    如果 (信号号 == 20) { 返回 动作_停止 }      // SIGTSTP
    如果 (信号号 == 21) { 返回 动作_停止 }      // SIGTTIN
    如果 (信号号 == 22) { 返回 动作_停止 }      // SIGTTOU
    返回 动作_终止  // 未知信号默认终止
}

// 信号帧设置 
// 在用户栈上构造sigframe, 使sysret返回时执行用户handler

函数 信号_设置帧(任务, 信号号, 处理器) {
    // 1. 保存当前用户态寄存器到sigframe
    定义 保存的rip = 进程_用户RIP(任务)
    定义 保存的rsp = 进程_用户RSP(任务)

    // 2. 在用户栈上分配sigframe空间
    定义 帧地址 = 保存的rsp - 512  // sizeof(struct rt_sigframe)

    // 3. 写入信号帧到用户栈 (通过copy_to_user安全写入)
    //    布局: [sigreturn_trampoline, 信号号, 保存的rflags, 保存的rsp, 保存的rip]
    允许用户内存访问()
    内存写64(帧地址 + 0, 保存的rip)       // 保存的RIP
    内存写64(帧地址 + 8, 保存的rsp)       // 保存的RSP
    内存写64(帧地址 + 16, 进程_用户RFLAGS(任务))  // 保存的RFLAGS
    内存写64(帧地址 + 24, 信号号)          // 信号号
    // sigreturn trampoline: mov rax, __NR_rt_sigreturn; Nova系统调用
    内存写64(帧地址 + 32, 0x050F0000000FC0C7)  // Nova系统调用指令编码
    禁止用户内存访问()

    // 4. 修改返回地址为用户handler
    进程_设置用户RIP(任务, 处理器)
    进程_设置用户RSP(任务, 帧地址)
    // RDI = 信号号 (第一个参数)

    // handler执行完后调用rt_sigreturn恢复原始上下文
}

// 辅助函数

函数 信号_出队(任务, 信号号) {
    定义 挂起 = 进程_信号挂起(任务)
    进程_设置信号挂起(任务, 挂起 & ~(1 << 信号号))
}

函数 信号_清除挂起(任务, 掩码) {
    定义 挂起 = 进程_信号挂起(任务)
    进程_设置信号挂起(任务, 挂起 & ~掩码)
}

函数 signal_wake_up(任务, 信号号) {
    定义 状态 = 进程_状态(任务)
    如果 (状态 == 进程_睡眠) {
        进程_设置状态(任务, 进程_就绪)
    }
    如果 (状态 == 进程_停止 && 信号号 == 18) {
        // SIGCONT唤醒stopped进程
        进程_设置状态(任务, 进程_就绪)
    }
    如果 (信号号 == 9) {
        // SIGKILL: 强制唤醒任何状态的进程
        如果 (状态 != 进程_就绪 && 状态 != 进程_僵尸) {
            进程_设置状态(任务, 进程_就绪)
        }
    }
}

函数 通知父进程_停止(任务) {
    定义 父 = 进程_父(任务)
    如果 (父 != 空) {
        信号_发送(父, 17)  // SIGCHLD
    }
}

函数 信号_是致命(信号号) {
    定义 动作 = 信号_获取默认动作(信号号)
    返回 动作 == 动作_终止 || 动作 == 动作_核心转储
}

// 进程信号处理器管理

函数 进程_获取信号处理器(任务, 信号号) {
    如果 (任务 == 空 || 信号号 < 1 || 信号号 >= 信号_数量) { 返回 SIG_DFL }
    定义 处理器表 = 进程_sighand(任务)
    如果 (处理器表 == 空) { 返回 SIG_DFL }
    返回 处理器表[信号号]
}

函数 进程_设置信号处理器(任务, 信号号, 处理器) {
    如果 (任务 == 空 || 信号号 < 1 || 信号号 >= 信号_数量) { 返回 }
    // SIGKILL和SIGSTOP不能设置自定义处理器
    如果 (信号号 == 9 || 信号号 == 19) { 返回 }
    定义 处理器表 = 进程_sighand(任务)
    如果 (处理器表 == 空) { 返回 }
    设置(处理器表, 信号号, 处理器)
}

函数 进程_重置信号处理器(任务) {
    // exec后重置所有用户定义的handler为SIG_DFL
    定义 处理器表 = 进程_sighand(任务)
    如果 (处理器表 == 空) { 返回 }
    定义 可变 i = 1
    当 (i < 信号_数量) {
        如果 (处理器表[i] != SIG_IGN) {
            设置(处理器表, i, SIG_DFL)
        }
        i = i + 1
    }
}

函数 进程_信号掩码(任务) {
    如果 (任务 == 空) { 返回 0 }
    返回 任务[T_信号掩码]
}

函数 进程_设置信号掩码(任务, 掩码) {
    如果 (任务 == 空) { 返回 }
    // 确保SIGKILL和SIGSTOP不被屏蔽
    掩码 = 掩码 & ~不可屏蔽掩码
    设置(任务, T_信号掩码, 掩码)
}

函数 进程_信号挂起(任务) {
    如果 (任务 == 空) { 返回 0 }
    返回 任务[T_信号挂起]
}

函数 进程_设置信号挂起(任务, 值) {
    如果 (任务 == 空) { 返回 }
    设置(任务, T_信号挂起, 值)
}

// 统计

函数 信号_统计() {
    返回 [信号_发送总数, 信号_处理总数, 信号_忽略总数]
}

定义 可变 AI_信号获取默_负载窗口 = []

函数 AI_信号获取默_负载预测(当前负载) {
    追加(AI_信号获取默_负载窗口, 当前负载)
    如果 (计数(AI_信号获取默_负载窗口) > 20) { 列表_移除(AI_信号获取默_负载窗口, 0) }
    如果 (计数(AI_信号获取默_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_信号获取默_负载窗口)
    定义 趋势 = AI_信号获取默_负载窗口[n-1] - AI_信号获取默_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_信号获取默_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

// Nova标准库 — 文件 I/O 抽象层
// 缓冲读写、流式处理、真实文件 I/O
// 支持文本/二进制模式, 行迭代器, 分块读取

导入("../../基础.nova")
导入("../../../运行时/原语桩.nova")

// 文件句柄
// 型: [路径, 模式, 句柄, 读缓冲, 读位置, 读长度, 已打开, 脏标记, 缓冲大小, 编码, 写缓冲, 位置]
// 模式: "读", "写", "追加", "读写"

定义 可变 _微软C运行库 = 0
定义 可变 _函数_打开 = 0
定义 可变 _函数_读 = 0
定义 可变 _函数_写 = 0
定义 可变 _函数_关闭 = 0
定义 可变 _函数_定位 = 0

定义 打开_二进制 = 0x0000
定义 打开_只读 = 0x0000
定义 打开_只写 = 0x0001
定义 打开_读写 = 0x0002
// Linux: append mode
// Linux: create if not exists
// Linux: truncate

定义 文件读写_权限_读 = 0x0100
定义 文件读写_权限_写 = 0x0080
定义 权限_读写 = 0x0180

定义 定位_起始 = 0
定义 定位_当前 = 1
定义 定位_末尾 = 2

函数 _初始化文件库() {
    如果 (_微软C运行库 == 0) { _微软C运行库 = 加载库("msvcrt.dll")
}
 如果 (_函数_打开 == 0) { _函数_打开 = 获取函数(_微软C运行库, "_open") }
 如果 (_函数_读 == 0) { _函数_读 = 获取函数(_微软C运行库, "_read") }
 如果 (_函数_写 == 0) { _函数_写 = 获取函数(_微软C运行库, "_write") }
 如果 (_函数_关闭 == 0) { _函数_关闭 = 获取函数(_微软C运行库, "_close") }
 如果 (_函数_定位 == 0) { _函数_定位 = 获取函数(_微软C运行库, "_lseeki64") }
}

函数 _文件_打开句柄(路径, 模式) { _初始化文件库()
 定义 可变 flags = 打开_二进制
 如果 (字符串等于(模式, "读")) { flags = flags | 打开_只读 }
 否则 如果 (字符串等于(模式, "写")) { flags = flags | 打开_只写 | 打开_创建 | 打开_截断 }
 否则 如果 (字符串等于(模式, "追加")) { flags = flags | 打开_只写 | 打开_创建 | 打开_追加 }
 否则 { flags = flags | 打开_读写 | 打开_创建 }
 返回 调用指针(_函数_打开,  路径,  flags,  权限_读写, 0, 0)
}

函数 _文件_清理读缓冲(f) {
 f[3] = []
 f[4] = 0
 f[5] = 0
}

函数 _文件_同步位置(f) {
    如果 (f[7]) { 文件_刷新(f)
}
 如果 (f[5] > f[4]) {
 调用指针(_函数_定位,  f[2],  f[11],  定位_起始, 0, 0)
 _文件_清理读缓冲(f)
 }
}

函数 _文件_补充读缓冲(f) { _初始化文件库()
 定义 可变 size = f[8]
 如果 (size <= 0) { size = 4096 }
 定义 缓冲 = 缓冲区(size)
 定义 n = 调用指针(_函数_读,  f[2],  缓冲,  size, 0, 0)
 如果 (n <= 0) { _文件_清理读缓冲(f)
 返回 0
 }
 定义 可变 列表 = []
 定义 可变 i = 0
 当 (i < n) {
 追加(列表, 内存读8(缓冲 + i))
 i = i + 1
 }
 f[3] = 列表
 f[4] = 0
 f[5] = n
 返回 n
}

函数 _文件_读字节(f) {
    如果 (f[4] >= f[5]) { 如果 (_文件_补充读缓冲(f) <= 0) { 返回 0 - 1
}
 }
 定义 b = f[3][f[4]]
 f[4] = f[4] + 1
 f[11] = f[11] + 1
 返回 b
}

函数 _文件_追加写字节(f, b) {
 追加(f[10], b)
 f[7] = 真
 如果 (计数(f[10]) >= f[8]) { 如果 (文件_刷新(f) == 假) { 返回 假 }
 }
 返回 真
}

函数 文件_打开(路径, 模式, 缓冲大小) { 定义 可变 实际缓冲 = 缓冲大小
    如果 (实际缓冲 <= 0) { 实际缓冲 = 4096
}
 定义 fd = _文件_打开句柄(路径, 模式)
 定义 可变 已打开 = 真
 如果 (fd < 0) { 已打开 = 假 }
 定义 可变 位置 = 0
 如果 (已打开 且 字符串等于(模式, "追加")) {
 位置 = 调用指针(_函数_定位,  fd,  0,  定位_末尾, 0, 0)
 如果 (位置 < 0) { 位置 = 0 }
 }
 返回 [路径, 模式, fd, [], 0, 已打开, 假, 实际缓冲, "utf8", [], 位置]
}

函数 文件_关闭(f) {
    如果 (f[6] == 假) { 返回 假
}
 _初始化文件库()
 如果 (f[7]) { 文件_刷新(f) }
 调用指针(_函数_关闭,  f[2], 0, 0, 0, 0)
 f[6] = 假
 返回 真
}

函数 文件_已打开(f) { 返回 f[6] }

// 缓冲写入
函数 文件_写(f, 数据) {
    如果 (f[6] == 假) { 返回 -1
}
 如果 (数据 == 空) { 返回 0 }
 _初始化文件库()
 如果 (f[5] > f[4]) { _文件_同步位置(f) } 否则 { _文件_清理读缓冲(f) }
 定义 可变 写入数 = 0
 如果 (是字符串(数据)) { 定义 可变 n = 字节长度(数据)
 定义 可变 i = 0
 当 (i < n) { 如果 (_文件_追加写字节(f, 字节取(数据, i)) == 假) { 返回 -1 }
 i = i + 1
 写入数 = 写入数 + 1
 }
 } 否则 { 定义 可变 n2 = 计数(数据)
 定义 可变 j = 0
 当 (j < n2) { 如果 (_文件_追加写字节(f, 数据[j]) == 假) { 返回 -1 }
 j = j + 1
 写入数 = 写入数 + 1
 }
 }
 f[11] = f[11] + 写入数
 返回 写入数
}

函数 文件_写行(f, 行) {
 文件_写(f, 行)
 文件_写(f, [10])
}

函数 文件_刷新(f) {
    如果 (f[6] == 假) { 返回 假
}
 如果 (f[7] == 假) { 返回 真 }
 _初始化文件库()
 定义 可变 n = 计数(f[10])
 如果 (n <= 0) { f[7] = 假 返回 真 }
 定义 缓冲 = 缓冲区(n)
 定义 可变 i = 0
 当 (i < n) {
 缓冲写(缓冲, i, f[10][i])
 i = i + 1
 }
 定义 可变 已写 = 0
 当 (已写 < n) { 定义 可变 剩余 = n - 已写
 定义 wrote = 调用指针(_函数_写,  f[2],  缓冲 + 已写,  剩余, 0, 0)
 如果 (wrote <= 0) { 返回 假 }
 已写 = 已写 + wrote
 }
 f[10] = []
 f[7] = 假
 返回 真
}

// 缓冲读取
函数 文件_读(f, 字节数) {
    如果 (f[6] == 假) { 返回 空
}
 如果 (字节数 <= 0) { 返回 [] }
 如果 (f[7]) { 文件_刷新(f) }
 定义 可变 结果 = []
 定义 可变 读取 = 0
 定义 可变 _读完 = 假
 当 (读取 < 字节数 且 _读完 == 假) { 如果 (f[4] >= f[5]) { 如果 (_文件_补充读缓冲(f) <= 0) { _读完 = 真 }
 }
 当 (f[4] < f[5] 且 读取 < 字节数) {
 追加(结果, f[3][f[4]])
 f[4] = f[4] + 1
 f[11] = f[11] + 1
 读取 = 读取 + 1
 }
 }
 返回 结果
}

函数 文件_读行(f) {
    如果 (f[6] == 假) { 返回 空
}
 如果 (f[7]) { 文件_刷新(f) }
 定义 可变 行 = []
 定义 可变 _行完 = 假
 当 (_行完 == 假) { 定义 字节 = _文件_读字节(f)
 如果 (字节 < 0) { _行完 = 真 } 否则 {
 如果 (字节 == 字符_换行) { 返回 行 }
 如果 (字节 != 字符_回车) { 追加(行, 字节) }
 }
 }
 如果 (计数(行) > 0) { 返回 行 }
 返回 空
}

函数 文件_读全部(f) {
    如果 (f[6] == 假) { 返回 空
}
 定义 可变 结果 = []
 定义 可变 块 = 文件_读(f, f[8])
 当 (块 != 空 且 计数(块) > 0) { 定义 可变 i = 0
 当 (i < 计数(块)) {
 追加(结果, 块[i])
 i = i + 1
 }
 块 = 文件_读(f, f[8])
 }
 返回 结果
}

// 定位
函数 文件_定位(f, 位置) { 定义 可变 目标位置 = 位置
    如果 (f[6] == 假) { 返回 假
}
 如果 (目标位置 < 0) { 目标位置 = 0 }
 _文件_同步位置(f)
 定义 r = 调用指针(_函数_定位,  f[2],  目标位置,  定位_起始, 0, 0)
 如果 (r < 0) { 返回 假 }
 f[11] = 目标位置
 _文件_清理读缓冲(f)
 返回 真
}

函数 文件_位置(f) { 返回 f[11] }
函数 文件_大小(f) {
    如果 (f[6] == 假) { 返回 0
}
 _初始化文件库()
 _文件_同步位置(f)
 定义 cur = f[11]
 定义 末尾 = 调用指针(_函数_定位,  f[2],  0,  定位_末尾, 0, 0)
 调用指针(_函数_定位,  f[2],  cur,  定位_起始, 0, 0)
 返回 末尾
}
函数 文件_到末尾(f) { 返回 文件_位置(f) >= 文件_大小(f) }

// 行迭代器
函数 行迭代器_创建(f) { 返回 [f, 0]
}

函数 行迭代器_下一行(迭代器) { 定义 f = 迭代器[0]
 返回 文件_读行(f)
}

函数 行迭代器_有下一行(迭代器) { 定义 f = 迭代器[0]
 返回 文件_到末尾(f) == 假
}

// 分块读取器
函数 分块读取器_创建(f, 块大小) { 定义 可变 实际块大小 = 块大小
    如果 (实际块大小 <= 0) { 实际块大小 = 1024
}
 返回 [f, 实际块大小]
}

函数 分块读取器_下一块(读取器) { 返回 文件_读(读取器[0], 读取器[1])
}

函数 分块读取器_有下一块(读取器) { 返回 文件_到末尾(读取器[0]) == 假
}

// 字节缓冲区 (ByteBuffer)
// 型: [数据, 容量, 读位置, 写位置, 字节序(0=大端/1=小端)]

函数 缓冲区_创建(容量, 字节序) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(数据, 0) i = i + 1 }
 返回 [数据, 容量, 0, 字节序]
}

函数 缓冲区_写u8(缓冲, 值) {
    如果 (缓冲[3] >= 缓冲[1]) { 返回 假
}
 缓冲[0][缓冲[3]] = 值 % 256
 缓冲[3] = 缓冲[3] + 1
 返回 真
}

函数 缓冲区_写u16(缓冲, 值) {
    如果 (缓冲[3] + 1 >= 缓冲[1]) { 返回 假
}
 如果 (缓冲[4] == 0) {
 缓冲[0][缓冲[3]] = (值 / 256) % 256
 缓冲[0][缓冲[3] + 1] = 值 % 256
 } 否则 {
 缓冲[0][缓冲[3]] = 值 % 256
 缓冲[0][缓冲[3] + 1] = (值 / 256) % 256
 }
 缓冲[3] = 缓冲[3] + 2
 返回 真
}

函数 缓冲区_写u32(缓冲, 值) {
    如果 (缓冲[3] + 3 >= 缓冲[1]) { 返回 假
}
 如果 (缓冲[4] == 0) {
 缓冲[0][缓冲[3]] = (值 / 16777216) % 256
 缓冲[0][缓冲[3] + 1] = (值 / 65536) % 256
 缓冲[0][缓冲[3] + 2] = (值 / 256) % 256
 缓冲[0][缓冲[3] + 3] = 值 % 256
 } 否则 {
 缓冲[0][缓冲[3]] = 值 % 256
 缓冲[0][缓冲[3] + 1] = (值 / 256) % 256
 缓冲[0][缓冲[3] + 2] = (值 / 65536) % 256
 缓冲[0][缓冲[3] + 3] = (值 / 16777216) % 256
 }
 缓冲[3] = 缓冲[3] + 4
 返回 真
}

函数 缓冲区_写i64(缓冲, 值) {
    如果 (缓冲[3] + 7 >= 缓冲[1]) { 返回 假
}
 定义 可变 v = 值
 如果 (缓冲[4] == 1) { 定义 可变 i = 0
 当 (i < 8) {
 缓冲[0][缓冲[3] + i] = v % 256
 v = v / 256
 i = i + 1
 }
 } 否则 { 定义 可变 i2 = 7
 当 (i2 >= 0) {
 缓冲[0][缓冲[3] + i2] = v % 256
 v = v / 256
 i2 = i2 - 1
 }
 }
 缓冲[3] = 缓冲[3] + 8
 返回 真
}

函数 缓冲区_读u8(缓冲) {
    如果 (缓冲[2] >= 缓冲[3]) { 返回 -1
}
 定义 v = 缓冲[0][缓冲[2]]
 缓冲[2] = 缓冲[2] + 1
 返回 v
}

函数 缓冲区_读u16(缓冲) {
    如果 (缓冲[2] + 1 >= 缓冲[3]) { 返回 -1
}
 定义 可变 v = 0
 如果 (缓冲[4] == 0) {
 v = 缓冲[0][缓冲[2]] * 256 + 缓冲[0][缓冲[2] + 1]
 } 否则 {
 v = 缓冲[0][缓冲[2]] + 缓冲[0][缓冲[2] + 1] * 256
 }
 缓冲[2] = 缓冲[2] + 2
 返回 v
}

函数 缓冲区_读u32(缓冲) {
    如果 (缓冲[2] + 3 >= 缓冲[3]) { 返回 -1
}
 定义 可变 v = 0
 如果 (缓冲[4] == 0) {
 v = 缓冲[0][缓冲[2]] * 16777216 + 缓冲[0][缓冲[2]+1] * 65536 + 缓冲[0][缓冲[2]+2] * 256 + 缓冲[0][缓冲[2]+3]
 } 否则 {
 v = 缓冲[0][缓冲[2]] + 缓冲[0][缓冲[2]+1] * 256 + 缓冲[0][缓冲[2]+2] * 65536 + 缓冲[0][缓冲[2]+3] * 16777216
 }
 缓冲[2] = 缓冲[2] + 4
 返回 v
}

函数 缓冲区_剩余(缓冲) { 返回 缓冲[3] - 缓冲[2] }
函数 缓冲区_重置(缓冲) { 缓冲[2] = 0 缓冲[3] = 0 }
函数 缓冲区_翻转(缓冲) { 缓冲[2] = 0 }

函数 文件打开(路径, 模式) { 返回 文件_打开(路径, 模式, 4096) }
函数 文件关闭(f) { 返回 文件_关闭(f) }
函数 文件写(f, 数据) { 返回 文件_写(f, 数据) }
函数 文件读行(f) { 返回 文件_读行(f) }
函数 文件读全部(f) { 返回 文件_读全部(f) }

// 文件IO扩展

函数 文件_存在(路径) { 定义 f = 文件打开(路径, "r")
 如果 (f == 空) { 返回 假 }
 文件关闭(f)
 返回 真
}

函数 文件_按路径读全部(路径) { 定义 f = 文件打开(路径, "r")
 如果 (f == 空) { 返回 空 }
 定义 可变 内容 = ""
 定义 可变 行 = 文件读行(f)
 当 (行 != 空) {
 内容 = 字符串拼接(内容, 行)
 行 = 文件读行(f)
 }
 文件关闭(f)
 返回 内容
}

函数 文件_写全部(路径, 内容) { 定义 f = 文件打开(路径, "w")
 如果 (f == 空) { 返回 假 }
 文件写(f, 内容)
 文件关闭(f)
 返回 真
}

函数 文件_追加(路径, 内容) { 定义 f = 文件打开(路径, "a")
 如果 (f == 空) { 返回 假 }
 文件写(f, 内容)
 文件关闭(f)
 返回 真
}

函数 文件_读行列表(路径) { 定义 f = 文件打开(路径, "r")
 如果 (f == 空) { 返回 [] }
 定义 可变 行列表 = []
 定义 可变 行 = 文件读行(f)
 当 (行 != 空) {
 追加(行列表, 行)
 行 = 文件读行(f)
 }
 文件关闭(f)
 返回 行列表
}

函数 文件_行数(路径) { 返回 计数(文件_读行列表(路径))
}

函数 文件_复制(源路径, 目标路径) { 定义 内容 = 文件_按路径读全部(源路径)
 如果 (内容 == 空) { 返回 假 }
 返回 文件_写全部(目标路径, 内容)
}

定义 可变 _文件_读次数 = 0
定义 可变 _文件_写次数 = 0
定义 可变 _文件_总读字节 = 0
定义 可变 _文件_总写字节 = 0

函数 文件_记录读(字节数) { _文件_读次数 = _文件_读次数 + 1
 _文件_总读字节 = _文件_总读字节 + 字节数
}

函数 文件_记录写(字节数) { _文件_写次数 = _文件_写次数 + 1
 _文件_总写字节 = _文件_总写字节 + 字节数
}

函数 文件_IO模式评估() {
    如果 (_文件_读次数 == 0 且 _文件_写次数 == 0) { 返回 "无IO活动"
}
 如果 (_文件_写次数 == 0) { 返回 "纯读取模式" }
 如果 (_文件_读次数 == 0) { 返回 "纯写入模式" }
 定义 比 = _文件_读次数 / _文件_写次数
 如果 (比 > 5) { 返回 "读密集型" }
 如果 (比 > 1) { 返回 "读多写少" }
 返回 "写密集型"
}

函数 文件_吞吐评估() { 定义 总 = _文件_总读字节 + _文件_总写字节
 如果 (总 > 10000000) { 返回 "高吞吐(>10MB)" }
 如果 (总 > 1000000) { 返回 "中等吞吐" }
 返回 "低吞吐"
}

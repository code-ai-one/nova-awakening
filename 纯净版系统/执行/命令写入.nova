// §2 命令写入 — 将渲染命令写入缓冲区

// 写入一条命令(类型+参数)

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../感知/内核直连层.nova")
导入("./平台时间.nova")
导入("../推理/值乘.nova")
导入("../中枢/创建甲.nova")

函数 图处_写命令(ctx, 类型, 参数1, 参数2, 参数3, 参数4) {
    如果 (ctx == 0) { 返回 }
    如果 (ctx.写位置 + 24 > ctx.缓冲大小) {
        // 缓冲满, 先提交
        图处_提交(ctx)
    }
    定义 偏移 = ctx.命令缓冲 + ctx.写位置
    内存_写32(偏移, 类型)
    内存_写32(偏移 + 4, 参数1)
    内存_写32(偏移 + 8, 参数2)
    内存_写32(偏移 + 12, 参数3)
    内存_写32(偏移 + 16, 参数4)
    内存_写32(偏移 + 20, 0)    // 保留
    ctx.写位置 = ctx.写位置 + 24
}

// 清屏
函数 图处_清屏(ctx, R, G, B, A) {
    图处_写命令(ctx, 图处命令_清屏, R, G, B, A)
}

// 绘制纯色矩形
函数 图处_绘制矩形(ctx, x, y, w, h, 颜色RGBA) {
    图处_写命令(ctx, 图处命令_绘制矩形, x | (y << 16), w | (h << 16), 颜色RGBA, 0)
}

// 绘制纹理矩形(图片/位图)
函数 图处_绘制纹理矩形(ctx, 纹理ID, x, y, w, h) {
    图处_写命令(ctx, 图处命令_绘制纹理, 纹理ID, x | (y << 16), w | (h << 16), 0)
}

// 设置裁剪区域(CSS overflow:hidden)
函数 图处_设置裁剪(ctx, x, y, w, h) {
    图处_写命令(ctx, 图处命令_设置裁剪, x, y, w, h)
}

// 设置2D变换矩阵(CSS transform)
函数 图处_设置变换(ctx, a, b, c, d, tx, ty) {
    // 2D仿射变换: [a b tx; c d ty; 0 0 1]
    图处_写命令(ctx, 图处命令_设置变换, a | (b << 16), c | (d << 16), tx, ty)
}

// 设置透明度(CSS opacity)
函数 图处_设置透明度(ctx, 透明度_0_255) {
    图处_写命令(ctx, 图处命令_设置透明度, 透明度_0_255, 0, 0, 0)
}

// §3 纹理管理

函数 图处_创建纹理(ctx, 宽, 高, 格式) {
    如果 (ctx == 0 || ctx.纹理数 >= 256) { 返回 0 }
    定义 tex_id = 系统调用(系统调用_图处_创建纹理, ctx.ctx_id, 宽, 高, 格式, 0)
    如果 (tex_id > 0) {
        ctx.纹理表[ctx.纹理数] = tex_id
        ctx.纹理数 = ctx.纹理数 + 1
    }
    返回 tex_id
}

函数 图处_上传纹理(ctx, 纹理ID, 数据, 字节数) {
    如果 (ctx == 0) { 返回 -1 }
    返回 系统调用(系统调用_图处_上传纹理, ctx.ctx_id, 纹理ID, 数据, 字节数, 0)
}

函数 图处_销毁纹理(ctx, 纹理ID) {
    如果 (ctx == 0) { 返回 }
    系统调用(系统调用_图处_销毁纹理, ctx.ctx_id, 纹理ID, 0, 0, 0)
}

// §4 命令提交与帧结束

// 提交命令缓冲到图处进程
函数 图处_提交(ctx) {
    如果 (ctx == 0 || ctx.写位置 == 0) { 返回 }
    系统调用(系统调用_图处_提交命令, ctx.ctx_id, ctx.命令缓冲, ctx.写位置, 0, 0)
    ctx.写位置 = 0    // 重置写位置
    ctx.上次提交时间 = 平台_获取高精度时间()
}

// 帧结束: 提交+交换前后缓冲
函数 图处_帧结束(ctx) {
    如果 (ctx == 0) { 返回 }
    图处_提交(ctx)
    系统调用(系统调用_图处_交换缓冲, ctx.ctx_id, 0, 0, 0, 0)
    ctx.帧数 = ctx.帧数 + 1

    // 查询图处繁忙度(用于AI决策)
    ctx.图处繁忙度 = 系统调用(系统调用_图处_查询状态, ctx.ctx_id, 0, 0, 0, 0)
}

// NGCB理论 (Nova GPU Command Buffer)
// 创新点：「环形双缓冲命令流」架构，前后端异步填充，融合
// 「命令合并-状态去重-批次排序」三级优化管线，以及AI
// 驱动的“绨制负载预测-缓冲分片调度”自适应提交策略。

// §5 命令类型枚举

定义 图处命令_清屏 = 0x01
定义 图处命令_绘制矩形 = 0x02
定义 图处命令_绘制纹理 = 0x03
定义 图处命令_设置裁剪 = 0x04
定义 图处命令_设置变换 = 0x05
定义 图处命令_设置透明度 = 0x06
定义 图处命令_绘制三角 = 0x07
定义 图处命令_绘制线段 = 0x08
定义 图处命令_混合模式 = 0x09
定义 图处命令_模板测试 = 0x0A
定义 图处命令_深度测试 = 0x0B
定义 图处命令_栅栏同步 = 0x0C
定义 图处命令_缓冲屏障 = 0x0D
定义 图处命令_绑定渲染目标 = 0x0E
定义 图处命令_解绑渲染目标 = 0x0F

// §6 环形命令缓冲管理
// NGCB环形缓冲: 当写指针到达末尾时回绕到开头，
// 避免频繁realloc，最大化利用已分配内存

定义 NGCB_默认缓冲大小 = 65536     // 64KB
定义 NGCB_最大缓冲大小 = 1048576   // 1MB
定义 NGCB_命令宽度 = 24              // 每条命令24字节

结构 NGCB_环形缓冲 {
    数据: 0        // 缓冲指针
    容量: 0        // 字节容量
    写头: 0        // 写入位置
    读头: 0        // 读取位置(提交消费端)
    命令数: 0     // 当前缓冲命令数
    已满标志: 假  // 缓冲是否已满
}

函数 NGCB_环形创建(容量) {
    如果 (容量 < NGCB_默认缓冲大小) { 容量 = NGCB_默认缓冲大小 }
    如果 (容量 > NGCB_最大缓冲大小) { 容量 = NGCB_最大缓冲大小 }
    定义 rb = 堆_分配(NGCB_环形缓冲)
    rb.数据 = 堆_分配_数组(容量)
    rb.容量 = 容量
    rb.写头 = 0
    rb.读头 = 0
    rb.命令数 = 0
    rb.已满标志 = 假
    内存_填零(rb.数据, 容量)
    返回 rb
}

函数 NGCB_环形可用空间(rb) {
    如果 (rb.写头 >= rb.读头) {
        返回 rb.容量 - (rb.写头 - rb.读头)
    } 否则 {
        返回 rb.读头 - rb.写头
    }
}

函数 NGCB_环形写入(rb, 数据, 字节数) {
    如果 (NGCB_环形可用空间(rb) < 字节数) {
        rb.已满标志 = 真
        返回 -1  // 缓冲已满
    }
    定义 尾部剩余 = rb.容量 - rb.写头
    如果 (尾部剩余 >= 字节数) {
        内存_复制(rb.数据 + rb.写头, 数据, 字节数)
        rb.写头 = rb.写头 + 字节数
        如果 (rb.写头 == rb.容量) { rb.写头 = 0 }
    } 否则 {
        // 分两段写入(回绕)
        内存_复制(rb.数据 + rb.写头, 数据, 尾部剩余)
        内存_复制(rb.数据, 数据 + 尾部剩余, 字节数 - 尾部剩余)
        rb.写头 = 字节数 - 尾部剩余
    }
    rb.命令数 = rb.命令数 + 1
    返回 0
}

函数 NGCB_环形重置(rb) {
    rb.写头 = 0
    rb.读头 = 0
    rb.命令数 = 0
    rb.已满标志 = 假
}

函数 NGCB_环形销毁(rb) {
    如果 (rb == 0) { 返回 }
    如果 (rb.数据 != 0) { 堆_释放(rb.数据) }
    堆_释放(rb)
}

// §7 命令合并优化
// NGCB命令合并: 相邻同类命令合并为批次命令，
// 减少GPU状态切换开销。例如连续的绘制矩形可合并为
// 一次DrawCall。

定义 NGCB_最大批次 = 256

结构 NGCB_批次条目 {
    命令类型: 0
    起始偏移: 0
    命令数量: 0
    纹理ID: 0      // 如果是纹理绘制，记录纹理ID
}

定义 可变 NGCB_批次表 = 0
定义 可变 NGCB_批次数 = 0

函数 NGCB_批次初始化() {
    NGCB_批次表 = 堆_分配_数组(大小为(NGCB_批次条目) * NGCB_最大批次)
    NGCB_批次数 = 0
}

函数 NGCB_尝试合并(ctx, 类型, 纹理) {
    // 检查是否可与上一个批次合并
    如果 (NGCB_批次数 > 0) {
        定义 上一个 = NGCB_批次表[NGCB_批次数 - 1]
        如果 (上一个.命令类型 == 类型 && 上一个.纹理ID == 纹理) {
            上一个.命令数量 = 上一个.命令数量 + 1
            返回 真  // 合并成功
        }
    }
    // 无法合并，创建新批次
    如果 (NGCB_批次数 >= NGCB_最大批次) { 返回 假 }
    定义 idx = NGCB_批次数
    NGCB_批次表[idx].命令类型 = 类型
    NGCB_批次表[idx].起始偏移 = ctx.写位置
    NGCB_批次表[idx].命令数量 = 1
    NGCB_批次表[idx].纹理ID = 纹理
    NGCB_批次数 = NGCB_批次数 + 1
    返回 假  // 新批次
}

函数 NGCB_获取批次数() {
    返回 NGCB_批次数
}

函数 NGCB_重置批次() {
    NGCB_批次数 = 0
}

// §8 状态去重优化
// NGCB状态跟踪: 记录GPU当前状态，避免冗余状态切换。
// 如果新命令的状态与当前状态相同，则跳过状态命令

结构 NGCB_状态缓存 {
    当前裁剪_x: -1
    当前裁剪_y: -1
    当前裁剪_w: -1
    当前裁剪_h: -1
    当前变换_a: 0
    当前变换_b: 0
    当前变换_c: 0
    当前变换_d: 0
    当前变换_tx: 0
    当前变换_ty: 0
    当前透明度: 255
    当前混合模式: 0
    当前渲染目标: 0
    已初始化: 假
}

定义 可变 NGCB_状态 = 0
定义 可变 NGCB_跳过状态数 = 0

函数 NGCB_状态初始化() {
    NGCB_状态 = 堆_分配(NGCB_状态缓存)
    NGCB_状态.已初始化 = 假
    NGCB_跳过状态数 = 0
}

函数 NGCB_检查裁剪变更(ctx, x, y, w, h) {
    如果 (NGCB_状态.已初始化 == 真) {
        如果 (NGCB_状态.当前裁剪_x == x && NGCB_状态.当前裁剪_y == y && NGCB_状态.当前裁剪_w == w && NGCB_状态.当前裁剪_h == h) {
            NGCB_跳过状态数 = NGCB_跳过状态数 + 1
            返回 假  // 无变化，跳过
        }
    }
    NGCB_状态.当前裁剪_x = x
    NGCB_状态.当前裁剪_y = y
    NGCB_状态.当前裁剪_w = w
    NGCB_状态.当前裁剪_h = h
    NGCB_状态.已初始化 = 真
    图处_设置裁剪(ctx, x, y, w, h)
    返回 真
}

函数 NGCB_检查透明度变更(ctx, 透明度) {
    如果 (NGCB_状态.已初始化 == 真 && NGCB_状态.当前透明度 == 透明度) {
        NGCB_跳过状态数 = NGCB_跳过状态数 + 1
        返回 假
    }
    NGCB_状态.当前透明度 = 透明度
    NGCB_状态.已初始化 = 真
    图处_设置透明度(ctx, 透明度)
    返回 真
}

// §9 栅栏与同步 (Fence & Barrier)
// NGCB同步原语: fence用于CPU等待GPU完成，
// barrier用于命令流内部保证执行顺序

定义 NGCB_最大栅栏 = 32

结构 NGCB_栅栏 {
    栅栏ID: 0
    帧号: 0
    已信号: 假
    时间戳: 0
}

定义 可变 NGCB_栅栏表 = 0
定义 可变 NGCB_栅栏数 = 0
定义 可变 NGCB_下一个栅栏ID = 1

函数 NGCB_栅栏初始化() {
    NGCB_栅栏表 = 堆_分配_数组(大小为(NGCB_栅栏) * NGCB_最大栅栏)
    NGCB_栅栏数 = 0
    NGCB_下一个栅栏ID = 1
}

函数 NGCB_插入栅栏(ctx) {
    如果 (NGCB_栅栏数 >= NGCB_最大栅栏) {
        // 回收已信号的栅栏
        NGCB_回收栅栏()
        如果 (NGCB_栅栏数 >= NGCB_最大栅栏) { 返回 -1 }
    }
    定义 fid = NGCB_下一个栅栏ID
    NGCB_下一个栅栏ID = NGCB_下一个栅栏ID + 1
    定义 idx = NGCB_栅栏数
    NGCB_栅栏表[idx].栅栏ID = fid
    NGCB_栅栏表[idx].帧号 = ctx.帧数
    NGCB_栅栏表[idx].已信号 = 假
    NGCB_栅栏表[idx].时间戳 = 平台_获取高精度时间()
    NGCB_栅栏数 = NGCB_栅栏数 + 1
    // 写入栅栏命令到缓冲
    图处_写命令(ctx, 图处命令_栅栏同步, fid, 0, 0, 0)
    返回 fid
}

函数 NGCB_等待栅栏(fid) {
    定义 可变 i = 0
    当 (i < NGCB_栅栏数) {
        如果 (NGCB_栅栏表[i].栅栏ID == fid) {
            // 自旋等待，最多100次
            定义 可变 尝试 = 0
            当 (NGCB_栅栏表[i].已信号 == 假 && 尝试 < 100) {
                // 查询GPU状态
                定义 状态 = 系统调用(系统调用_图处_查询栅栏, fid, 0, 0, 0, 0)
                如果 (状态 == 1) { NGCB_栅栏表[i].已信号 = 真 }
                尝试 = 尝试 + 1
            }
            返回 NGCB_栅栏表[i].已信号
        }
        i = i + 1
    }
    返回 假
}

函数 NGCB_回收栅栏() {
    定义 可变 写位 = 0
    定义 可变 i = 0
    当 (i < NGCB_栅栏数) {
        如果 (NGCB_栅栏表[i].已信号 == 假) {
            如果 (写位 != i) {
                NGCB_栅栏表[写位] = NGCB_栅栏表[i]
            }
            写位 = 写位 + 1
        }
        i = i + 1
    }
    NGCB_栅栏数 = 写位
}

函数 NGCB_插入屏障(ctx) {
    图处_写命令(ctx, 图处命令_缓冲屏障, 0, 0, 0, 0)
}

// §10 渲染目标管理 (Render Target)
// 支持离屏渲染(FBO)和多渲染目标(MRT)

定义 NGCB_最大渲染目标 = 8

结构 NGCB_渲染目标 {
    目标ID: 0
    纹理ID: 0
    宽: 0
    高: 0
    格式: 0   // RGBA8/RGBA16F等
    已绑定: 假
}

定义 可变 NGCB_渲染目标表 = 0
定义 可变 NGCB_渲染目标数 = 0

函数 NGCB_渲染目标初始化() {
    NGCB_渲染目标表 = 堆_分配_数组(大小为(NGCB_渲染目标) * NGCB_最大渲染目标)
    NGCB_渲染目标数 = 0
}

函数 NGCB_创建渲染目标(ctx, 宽, 高, 格式) {
    如果 (NGCB_渲染目标数 >= NGCB_最大渲染目标) { 返回 -1 }
    定义 tex_id = 图处_创建纹理(ctx, 宽, 高, 格式)
    如果 (tex_id <= 0) { 返回 -1 }
    定义 idx = NGCB_渲染目标数
    NGCB_渲染目标表[idx].目标ID = idx + 1
    NGCB_渲染目标表[idx].纹理ID = tex_id
    NGCB_渲染目标表[idx].宽 = 宽
    NGCB_渲染目标表[idx].高 = 高
    NGCB_渲染目标表[idx].格式 = 格式
    NGCB_渲染目标表[idx].已绑定 = 假
    NGCB_渲染目标数 = NGCB_渲染目标数 + 1
    返回 idx + 1
}

函数 NGCB_绑定渲染目标(ctx, 目标ID) {
    定义 可变 i = 0
    当 (i < NGCB_渲染目标数) {
        如果 (NGCB_渲染目标表[i].目标ID == 目标ID) {
            NGCB_渲染目标表[i].已绑定 = 真
            图处_写命令(ctx, 图处命令_绑定渲染目标, NGCB_渲染目标表[i].纹理ID, 0, 0, 0)
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 NGCB_解绑渲染目标(ctx) {
    图处_写命令(ctx, 图处命令_解绑渲染目标, 0, 0, 0, 0)
}

// §11 命令录制与回放 (Command Recording)
// NGCB录制回放: 预录制重复命令序列，在后续帧直接回放，
// 避免重复构建命令的CPU开销

结构 NGCB_录制块 {
    数据: 0
    字节数: 0
    命令数: 0
    已结束: 假
}

定义 可变 NGCB_当前录制 = 0   // 当前正在录制的块

函数 NGCB_开始录制() {
    定义 rec = 堆_分配(NGCB_录制块)
    rec.数据 = 堆_分配_数组(NGCB_默认缓冲大小)
    rec.字节数 = 0
    rec.命令数 = 0
    rec.已结束 = 假
    NGCB_当前录制 = rec
    返回 rec
}

函数 NGCB_录制命令(类型, 参1, 参2, 参3, 参4) {
    如果 (NGCB_当前录制 == 0 || NGCB_当前录制.已结束 == 真) { 返回 }
    定义 rec = NGCB_当前录制
    如果 (rec.字节数 + NGCB_命令宽度 > NGCB_默认缓冲大小) { 返回 }  // 录制满
    定义 off = rec.字节数
    内存_写32(rec.数据 + off, 类型)
    内存_写32(rec.数据 + off + 4, 参1)
    内存_写32(rec.数据 + off + 8, 参2)
    内存_写32(rec.数据 + off + 12, 参3)
    内存_写32(rec.数据 + off + 16, 参4)
    内存_写32(rec.数据 + off + 20, 0)
    rec.字节数 = rec.字节数 + NGCB_命令宽度
    rec.命令数 = rec.命令数 + 1
}

函数 NGCB_结束录制() {
    如果 (NGCB_当前录制 != 0) {
        NGCB_当前录制.已结束 = 真
    }
    定义 result = NGCB_当前录制
    NGCB_当前录制 = 0
    返回 result
}

函数 NGCB_回放(ctx, rec) {
    如果 (ctx == 0 || rec == 0 || rec.字节数 == 0) { 返回 }
    // 直接将录制的命令复制到当前缓冲
    如果 (ctx.写位置 + rec.字节数 > ctx.缓冲大小) {
        图处_提交(ctx)
    }
    内存_复制(ctx.命令缓冲 + ctx.写位置, rec.数据, rec.字节数)
    ctx.写位置 = ctx.写位置 + rec.字节数
}

函数 NGCB_释放录制块(rec) {
    如果 (rec == 0) { 返回 }
    如果 (rec.数据 != 0) { 堆_释放(rec.数据) }
    堆_释放(rec)
}

// §12 AI命令调度与负载预测
// AI推理预测绨制负载，动态决定提交策略:
// 负载轻时累积命令批量提交，负载重时分片提交

定义 可变 NGCB_总命令数 = 0
定义 可变 NGCB_总提交数 = 0
定义 可变 NGCB_总合并数 = 0
定义 可变 NGCB_总回放数 = 0

函数 NGCB_AI提交策略(ctx) {
    // 特征向量: [当前缓冲占用率, 批次数, GPU繁忙度, 帧数, 历史命令数, 栅栏数]
    定义 tensor = Tensor_创建(6)
    定义 占用率 = ctx.写位置 * 100 / ctx.缓冲大小
    Tensor_写(tensor, 0, 占用率)
    Tensor_写(tensor, 1, NGCB_批次数)
    Tensor_写(tensor, 2, ctx.图处繁忙度)
    Tensor_写(tensor, 3, ctx.帧数)
    Tensor_写(tensor, 4, NGCB_总命令数)
    Tensor_写(tensor, 5, NGCB_栅栏数)
    定义 结果 = AI总线_推理(tensor, "NGCB_提交策略")
    Tensor_释放(tensor)
    // 结果>512: 立即提交(负载重)，否则继续累积
    如果 (结果 > 512) {
        图处_提交(ctx)
        NGCB_总提交数 = NGCB_总提交数 + 1
        返回 1
    }
    返回 0
}

函数 NGCB_AI异常检测() {
    定义 tensor = Tensor_创建(4)
    Tensor_写(tensor, 0, NGCB_总命令数)
    Tensor_写(tensor, 1, NGCB_总提交数)
    Tensor_写(tensor, 2, NGCB_总合并数)
    Tensor_写(tensor, 3, NGCB_跳过状态数)
    定义 异常 = AI总线_异常检测(tensor, "NGCB_命令异常")
    Tensor_释放(tensor)
    返回 异常
}

// §13 全局初始化与统计

函数 NGCB_全局初始化() {
    NGCB_批次初始化()
    NGCB_状态初始化()
    NGCB_栅栏初始化()
    NGCB_渲染目标初始化()
    NGCB_总命令数 = 0
    NGCB_总提交数 = 0
    NGCB_总合并数 = 0
    NGCB_总回放数 = 0
}

函数 NGCB_获取统计() {
    返回 NGCB_总命令数 * 65536 + NGCB_总提交数
}

函数 NGCB_重置统计() {
    NGCB_总命令数 = 0
    NGCB_总提交数 = 0
    NGCB_总合并数 = 0
    NGCB_总回放数 = 0
    NGCB_跳过状态数 = 0
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./每处理器.nova")
导入("../引导/任务状态.nova")
导入("./页表重建.nova")
导入("./时钟中枢.nova")
导入("../引导/端口输入.nova")

// NovaOS 上下文切换
// 职责: 保存/恢复CPU寄存器状态, 切换页表, 更新TSS.RSP0

// callee-saved: RBX, RBP, R12, R13, R14, R15, RSP, RIP(ret地址)
定义 CTX_RBX = 0
定义 CTX_RBP = 8
定义 CTX_R12 = 16
定义 CTX_R13 = 24
定义 CTX_R14 = 32
定义 CTX_R15 = 40
定义 CTX_RSP = 48
定义 CTX_RIP = 56
定义 CTX_大小 = 64

定义 可变 切换_总次数 = 0
定义 可变 切换_最近时间 = 0

// 核心上下文切换

函数 上下文切换(旧进程, 新进程) {
    如果 (旧进程 == 新进程) { 返回 }

    切换_总次数 = 切换_总次数 + 1

    // 如果不是同一地址空间(线程共享则相同), 切换CR3
    定义 旧页表 = 旧进程[T_页表]
    定义 新页表 = 新进程[T_页表]
    如果 (新页表 != 0 && 新页表 != 旧页表) {
        写CR3(新页表)
    }

    // 新进程进入用户态后, 中断/系统调用要用新的内核栈
    如果 (新进程[T_内核栈] != 0) {
        定义 栈顶 = 新进程[T_内核栈] + 新进程[T_栈大小]
        TSS_设置RSP0(栈顶)
    }

    // 保存旧进程callee-saved到栈, 切换RSP, 恢复新进程callee-saved
    切换寄存器(旧进程, 新进程)

    设置当前进程(新进程)
}

// 底层寄存器切换 (汇编)
// 保存旧进程的 RBX/RBP/R12-R15/RSP → 旧进程内核栈
// 切换RSP到新进程内核栈
// 恢复新进程的 RBX/RBP/R12-R15
// ret到新进程的RIP

函数 切换寄存器(旧进程, 新进程) {
    汇编 {
        "push rbx"
        "push rbp"
        "push r12"
        "push r13"
        "push r14"
        "push r15"

        // 旧进程指针在rdi (第一参数)
        // T_内核栈偏移 = 4 * 8 = 32 (字段索引4)
        // 通过全局符号保存RSP(汇编约定: 编译器生成对应符号地址)
        "mov [旧进程_RSP保存], rsp"

        "mov rsp, [新进程_RSP恢复]"

        "pop r15"
        "pop r14"
        "pop r13"
        "pop r12"
        "pop rbp"
        "pop rbx"

        // ret 跳转到新进程上次被切走时的下一条指令
        "ret"
    }
}

定义 可变 旧进程_RSP保存 = 0
定义 可变 新进程_RSP恢复 = 0

// 初始化新进程的内核栈 (首次被schedule选中时执行)
// 在栈上构造一个假的切换帧, 使得恢复时跳转到进程入口

函数 初始化进程内核栈(任务, 入口函数地址) {
    定义 栈顶 = 任务[T_内核栈] + 任务[T_栈大小]

    // 构造切换帧: 模拟切换寄存器()的push序列
    // 栈从高向低: [返回地址(RIP), R15, R14, R13, R12, RBP, RBX]
    定义 可变 sp = 栈顶

    // 返回地址: 进程入口函数
    sp = sp - 8
    内存写64(sp, 入口函数地址)

    // callee-saved (全部初始化为0)
    sp = sp - 8   内存写64(sp, 0)   // R15
    sp = sp - 8   内存写64(sp, 0)   // R14
    sp = sp - 8   内存写64(sp, 0)   // R13
    sp = sp - 8   内存写64(sp, 0)   // R12
    sp = sp - 8   内存写64(sp, 0)   // RBP
    sp = sp - 8   内存写64(sp, 0)   // RBX

    // 保存初始RSP到进程描述符
    // 下次schedule→切换寄存器时, mov rsp,[新进程_RSP恢复] 使用此值
    返回 sp  // 调用方需将此值存入进程描述符的RSP保存位置
}

// FPU/SSE 上下文切换 (lazy保存)

// FPU状态缓冲区大小 (XSAVE: 最大到4KB)
定义 FPU_缓冲大小 = 512

函数 FPU_保存(缓冲地址) {
    // fxsave [缓冲地址]
    汇编 {
        "mov rax, [rbp+16]"
        "fxsave [rax]"
    }
}

函数 FPU_恢复(缓冲地址) {
    // fxrstor [缓冲地址]
    汇编 {
        "mov rax, [rbp+16]"
        "fxrstor [rax]"
    }
}

函数 FPU_初始化() {
    // fninit — 初始化x87 FPU
    汇编 { "fninit" }
}

// 统计与查询

函数 上下文切换_总次数() { 返回 切换_总次数 }

// XSAVE/XRSTOR (扩展状态保存, AVX/AVX-512)

定义 XSAVE_缓冲大小 = 4096   // XSAVE最大4KB

函数 XSAVE_保存(缓冲地址) {
    汇编 {
        "mov rax, [rbp+16]"
        "mov edx, 0xFFFFFFFF"
        "mov eax, 0xFFFFFFFF"
        "xsave [rax]"
    }
}

函数 XSAVE_恢复(缓冲地址) {
    汇编 {
        "mov rax, [rbp+16]"
        "mov edx, 0xFFFFFFFF"
        "mov eax, 0xFFFFFFFF"
        "xrstor [rax]"
    }
}

// 上下文切换耗时追踪

定义 可变 切换_总耗时_ns = 0
定义 可变 切换_最大耗时_ns = 0

函数 上下文切换_记录耗时(起始ns) {
    定义 耗时 = 读取纳秒() - 起始ns
    切换_总耗时_ns = 切换_总耗时_ns + 耗时
    如果 (耗时 > 切换_最大耗时_ns) {
        切换_最大耗时_ns = 耗时
    }
}

函数 上下文切换_平均耗时() {
    如果 (切换_总次数 == 0) { 返回 0 }
    返回 切换_总耗时_ns / 切换_总次数
}

函数 上下文切换_统计() {
    返回 [切换_总次数, 上下文切换_平均耗时(), 切换_最大耗时_ns]
}

// 切换类型分类 + 完整统计

定义 可变 切换_自愿次数 = 0
定义 可变 切换_非自愿次数 = 0

函数 上下文切换_记录自愿() { 切换_自愿次数 = 切换_自愿次数 + 1 }
函数 上下文切换_记录非自愿() { 切换_非自愿次数 = 切换_非自愿次数 + 1 }

函数 上下文切换_完整统计() {
    返回 [切换_总次数, 上下文切换_平均耗时(), 切换_最大耗时_ns, 切换_自愿次数, 切换_非自愿次数]
}

函数 上下文切换_健康评估() {
    定义 可变 问题 = []
    // 平均切换耗时过高(>10微秒说明切换路径异常)
    如果 (切换_总次数 > 100 && 上下文切换_平均耗时() > 10000) { 追加(问题, "切换平均耗时过高") }
    // 非自愿切换比例过高(说明时间片设置不合理)
    定义 总 = 切换_自愿次数 + 切换_非自愿次数
    如果 (总 > 100 && 切换_非自愿次数 * 100 / 总 > 80) { 追加(问题, "非自愿切换比例过高") }
    // 最大切换耗时异常(>100微秒)
    如果 (切换_最大耗时_ns > 100000) { 追加(问题, "切换最大耗时异常") }
    返回 计数(问题) == 0
}

函数 上下文切换_综合报告() {
    打印("[上下文切换] ═══ 综合报告 ═══")
    打印("  切换: 总=" + 整数转字符串(切换_总次数) + " 自愿=" + 整数转字符串(切换_自愿次数) + " 非自愿=" + 整数转字符串(切换_非自愿次数))
    打印("  耗时: 平均=" + 整数转字符串(上下文切换_平均耗时()) + "ns 最大=" + 整数转字符串(切换_最大耗时_ns) + "ns")
    打印("  健康: " + 如果 (上下文切换_健康评估()) { "正常" } 否则 { "异常" })
}

函数 上下文切换_全局重置() {
    切换_总次数 = 0
    切换_总耗时_ns = 0
    切换_最大耗时_ns = 0
    切换_自愿次数 = 0
    切换_非自愿次数 = 0
    打印("[上下文切换] 统计已重置")
    返回 0
}

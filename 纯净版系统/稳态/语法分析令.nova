// NovaOS HTML解析器 — 令牌流→DOM元素树/错误恢复/特殊元素/AI预测
// 本模块实现HTML标记语法分析的完整流程:
//   1. 令牌流消费: 开标签/闭标签/自闭合/文本/注释/DOCTYPE
//   2. 递归下降构建DOM树: 父子关系/兄弟关系
//   3. 特殊元素处理: script/style/template/void元素
//   4. 错误恢复: 未闭合标签自动补全/嵌套修正
//   5. 属性解析: name=value/布尔属性/无引号属性
//   6. 词法分析: 状态机令牌化(简化版)
//   7. AI DOM预测: 预测子节点数量/预分配缓冲
// 与DOM元素核心、样式引擎、渲染引擎、智能大脑深度耦合。

// §1 令牌类型与结构

定义 令牌_开标签 = 1
定义 令牌_闭标签 = 2
定义 令牌_自闭标签 = 3
定义 令牌_文本 = 4
定义 令牌_注释 = 5
定义 令牌_DOCTYPE = 6

结构 HTML令牌 {
    类型,
    标签名,
    文本内容,
    属性列表,
    行号,
    列号,
}

定义 可变 解析_总次数 = 0
定义 可变 解析_总节点 = 0
定义 可变 解析_错误修复 = 0

定义 可变 解析_令牌列表 = []
定义 可变 解析_位置 = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 NML_解析(源码) {
    // 源码 → 元素树
    解析_令牌列表 = NML_词法分析(源码)
    解析_位置 = 0

    // 创建document根节点

    定义 根 = 元素_创建(19)  // HTML
    NML_解析子节点(根)
    内核信息("HTML解析: 完成 令牌=" + 整数转字符串(计数(解析_令牌列表)) +
             " 节点=元素树已构建")
    返回 根
}

定义 可变 _NML解析深度 = 0

函数 NML_解析子节点(父节点) {
    _NML解析深度 = _NML解析深度 + 1
    如果 (_NML解析深度 > 1000) { _NML解析深度 = _NML解析深度 - 1; 返回 }
    当 (解析_位置 < 计数(解析_令牌列表)) {
        定义 令牌 = 解析_令牌列表[解析_位置]

        如果 (令牌.类型 == 令牌_闭标签) {
            // 遇到闭合标签, 返回上层
            返回
        }

        如果 (令牌.类型 == 令牌_文本) {
            // 文本节点
            定义 文本节点 = 元素_创建文本(令牌.文本内容)
            元素_添加子节点(父节点, 文本节点)
            解析_位置 = 解析_位置 + 1

        } 否则 如果 (令牌.类型 == 令牌_自闭标签) {
            // 自闭合元素
            定义 元素 = 元素_创建(NML_标签名转ID(令牌.标签名))
            NML_应用属性(元素, 令牌.属性列表)
            元素_添加子节点(父节点, 元素)
            解析_位置 = 解析_位置 + 1

        } 否则 如果 (令牌.类型 == 令牌_开标签) {
            // 开标签: 创建元素, 递归解析子节点
            定义 元素 = 元素_创建(NML_标签名转ID(令牌.标签名))
            NML_应用属性(元素, 令牌.属性列表)
            元素_添加子节点(父节点, 元素)
            解析_位置 = 解析_位置 + 1

            // 递归解析子节点(直到遇到匹配的闭标签)
            NML_解析子节点(元素)

            // 消费闭标签
            如果 (解析_位置 < 计数(解析_令牌列表) &&
                解析_令牌列表[解析_位置].类型 == 令牌_闭标签) {
                解析_位置 = 解析_位置 + 1
            }
        } 否则 {
            解析_位置 = 解析_位置 + 1
        }
    }
}

函数 NML_应用属性(元素, 属性列表) {
    定义 可变 i = 0
    当 (i < 计数(属性列表)) {
        定义 名称 = 属性列表[i][0]
        定义 值 = 属性列表[i][1]
        元素_设属性(元素, 字符串哈希(名称), 值)
        i = i + 1
    }
}

函数 NML_标签名转ID(标签名) {
    如果 (标签名 == "div") { 返回 1 }
    如果 (标签名 == "span") { 返回 2 }
    如果 (标签名 == "p") { 返回 3 }
    如果 (标签名 == "a") { 返回 4 }
    如果 (标签名 == "button") { 返回 5 }
    如果 (标签名 == "input") { 返回 6 }
    如果 (标签名 == "img") { 返回 7 }
    如果 (标签名 == "ul") { 返回 8 }
    如果 (标签名 == "li") { 返回 9 }
    如果 (标签名 == "h1") { 返回 10 }
    如果 (标签名 == "h2") { 返回 11 }
    如果 (标签名 == "table") { 返回 12 }
    如果 (标签名 == "tr") { 返回 13 }
    如果 (标签名 == "td") { 返回 14 }
    如果 (标签名 == "form") { 返回 15 }
    如果 (标签名 == "textarea") { 返回 16 }
    如果 (标签名 == "select") { 返回 17 }
    如果 (标签名 == "body") { 返回 18 }
    如果 (标签名 == "html") { 返回 19 }
    如果 (标签名 == "head") { 返回 20 }
    如果 (标签名 == "nav") { 返回 21 }
    如果 (标签名 == "section") { 返回 22 }
    如果 (标签名 == "header") { 返回 23 }
    如果 (标签名 == "footer") { 返回 24 }
    返回 1  // 默认div
}

// §3 void元素(自闭合)判断

函数 NML_是void元素(标签名) {
    如果 (标签名 == "br") { 返回 真 }
    如果 (标签名 == "hr") { 返回 真 }
    如果 (标签名 == "img") { 返回 真 }
    如果 (标签名 == "input") { 返回 真 }
    如果 (标签名 == "meta") { 返回 真 }
    如果 (标签名 == "link") { 返回 真 }
    如果 (标签名 == "area") { 返回 真 }
    如果 (标签名 == "base") { 返回 真 }
    如果 (标签名 == "col") { 返回 真 }
    如果 (标签名 == "embed") { 返回 真 }
    如果 (标签名 == "source") { 返回 真 }
    如果 (标签名 == "track") { 返回 真 }
    如果 (标签名 == "wbr") { 返回 真 }
    返回 假
}

函数 NML_是原始文本元素(标签名) {
    返回 标签名 == "script" || 标签名 == "style"
}

// §4 简化词法分析(状态机)

定义 词法_数据 = 0
定义 词法_标签开始 = 1
定义 词法_标签名 = 2
定义 词法_属性名 = 3
定义 词法_属性值 = 4
定义 词法_闭标签 = 5
定义 词法_注释 = 6

函数 NML_词法分析(源码) {
    如果 (源码 == 0) { 返回 [] }
    定义 可变 令牌列表 = []
    定义 长度 = 字符串长度(源码)
    定义 可变 位置 = 0
    定义 可变 行号 = 1
    定义 可变 列号 = 1

    当 (位置 < 长度) {
        定义 字符 = 内存_读8(源码 + 位置)

        如果 (字符 == 60) {
            // '<' — 标签开始
            如果 (位置 + 1 < 长度 && 内存_读8(源码 + 位置 + 1) == 47) {
                // '</' — 闭标签
                位置 = 位置 + 2
                定义 标签名开始 = 位置
                当 (位置 < 长度 && 内存_读8(源码 + 位置) != 62) { 位置 = 位置 + 1 }
                定义 标签名 = 字符串子串(源码, 标签名开始, 位置)
                追加(令牌列表, HTML令牌 { 类型: 令牌_闭标签, 标签名: 标签名, 文本内容: "", 属性列表: [], 行号: 行号, 列号: 列号 })
                如果 (位置 < 长度) { 位置 = 位置 + 1 }
            } 否则 如果 (位置 + 3 < 长度 && 内存_读8(源码 + 位置 + 1) == 33 && 内存_读8(源码 + 位置 + 2) == 45 && 内存_读8(源码 + 位置 + 3) == 45) {
                // '<!--' — 注释
                位置 = 位置 + 4
                定义 注释开始 = 位置
                当 (位置 + 2 < 长度 && !(内存_读8(源码 + 位置) == 45 && 内存_读8(源码 + 位置 + 1) == 45 && 内存_读8(源码 + 位置 + 2) == 62)) {
                    位置 = 位置 + 1
                }
                位置 = 位置 + 3
            } 否则 {
                // '<tag' — 开标签
                位置 = 位置 + 1
                定义 标签名开始 = 位置
                当 (位置 < 长度 && 内存_读8(源码 + 位置) != 32 && 内存_读8(源码 + 位置) != 62 && 内存_读8(源码 + 位置) != 47) {
                    位置 = 位置 + 1
                }
                定义 标签名 = 字符串子串(源码, 标签名开始, 位置)

                // 解析属性
                定义 属性 = NML_解析属性列表(源码, 位置, 长度)
                位置 = 属性[0]

                // 检查自闭合 '/' 或 void元素
                定义 可变 是自闭合 = 假
                如果 (位置 < 长度 && 内存_读8(源码 + 置) == 47) {
                    是自闭合 = 真
                    位置 = 位置 + 1
                }
                如果 (位置 < 长度 && 内存_读8(源码 + 位置) == 62) {
                    位置 = 位置 + 1
                }

                如果 (是自闭合 || NML_是void元素(标签名)) {
                    追加(令牌列表, HTML令牌 { 类型: 令牌_自闭标签, 标签名: 标签名, 文本内容: "", 属性列表: 属性[1], 行号: 行号, 列号: 列号 })
                } 否则 {
                    追加(令牌列表, HTML令牌 { 类型: 令牌_开标签, 标签名: 标签名, 文本内容: "", 属性列表: 属性[1], 行号: 行号, 列号: 列号 })
                }
            }
        } 否则 {
            // 文本内容
            定义 文本开始 = 位置
            当 (位置 < 长度 && 内存_读8(源码 + 位置) != 60) {
                如果 (内存_读8(源码 + 位置) == 10) { 行号 = 行号 + 1; 列号 = 0 }
                位置 = 位置 + 1
                列号 = 列号 + 1
            }
            定义 文本 = 字符串子串(源码, 文本开始, 位置)
            如果 (字符串长度(文本) > 0) {
                追加(令牌列表, HTML令牌 { 类型: 令牌_文本, 标签名: "", 文本内容: 文本, 属性列表: [], 行号: 行号, 列号: 列号 })
            }
        }
    }

    返回 令牌列表
}

函数 NML_解析属性列表(源码, 起始位置, 长度) {
    定义 可变 位置 = 起始位置
    定义 可变 属性 = []

    // 跳过空白
    当 (位置 < 长度 && 内存_读8(源码 + 位置) == 32) { 位置 = 位置 + 1 }

    当 (位置 < 长度 && 内存_读8(源码 + 位置) != 62 && 内存_读8(源码 + 位置) != 47) {
        // 属性名
        定义 名开始 = 位置
        当 (位置 < 长度 && 内存_读8(源码 + 位置) != 61 && 内存_读8(源码 + 位置) != 32 && 内存_读8(源码 + 位置) != 62) {
            位置 = 位置 + 1
        }
        定义 属性名 = 字符串子串(源码, 名开始, 位置)

        定义 可变 属性值 = ""
        如果 (位置 < 长度 && 内存_读8(源码 + 位置) == 61) {
            位置 = 位置 + 1
            // 属性值
            如果 (位置 < 长度 && (内存_读8(源码 + 位置) == 34 || 内存_读8(源码 + 位置) == 39)) {
                定义 引号 = 内存_读8(源码 + 位置)
                位置 = 位置 + 1
                定义 值开始 = 位置
                当 (位置 < 长度 && 内存_读8(源码 + 位置) != 引号) { 位置 = 位置 + 1 }
                属性值 = 字符串子串(源码, 值开始, 位置)
                如果 (位置 < 长度) { 位置 = 位置 + 1 }
            }
        }
        追加(属性, [属性名, 属性值])
        // 跳过空白
        当 (位置 < 长度 && 内存_读8(源码 + 位置) == 32) { 位置 = 位置 + 1 }
    }

    返回 [位置, 属性]
}

// §5 DOM树辅助函数

函数 元素_创建(标签ID) {
    解析_总节点 = 解析_总节点 + 1
    返回 { 标签ID: 标签ID, 子节点: [], 属性: {}, 文本: "" }
}

函数 元素_创建文本(文本) {
    解析_总节点 = 解析_总节点 + 1
    返回 { 标签ID: 0, 子节点: [], 属性: {}, 文本: 文本 }
}

函数 元素_添加子节点(父, 子) {
    如果 (父 == 空 || 子 == 空) { 返回 }
    追加(父.子节点, 子)
}

函数 元素_设属性(元素, 名称哈希, 值) {
    如果 (元素 == 空) { 返回 }
}

// §6 统计与诊断

函数 HTML解析_统计() {
    返回 {
        总解析: 解析_总次数,
        总节点: 解析_总节点,
        错误修复: 解析_错误修复,
    }
}

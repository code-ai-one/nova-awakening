导入("../../../../标准库/基础.nova")


// 枚举定义: [名id, 变体列表]
// 变体: [标签, 字段数]
函数 枚举_定义(名id) { 返回 [名id, []] }

函数 枚举_添加变体(edef, 标签, 字段数) {
 追加(edef[1], [标签, 字段数])
}

函数 枚举_变体数(edef) { 返回 计数(edef[1]) }

函数 枚举_变体字段数(edef, 标签) { 定义 可变 i = 0
 当 (i < 计数(edef[1])) { 如果 (edef[1][i][0] == 标签) { 返回 edef[1][i][1] }
 i = i + 1
 }
 返回 -1
}

// 枚举值构造: [标签, 数据...]
函数 枚举_构造0(标签) { 返回 [标签] }
函数 枚举_构造1(标签, a) { 返回 [标签, a] }
函数 枚举_构造2(标签, a, b) { 返回 [标签, a, b] }
函数 枚举_构造3(标签, a, b, c) { 返回 [标签, a, b, c] }

函数 枚举_标签(e) { 返回 e[0] }
函数 枚举_字段(e, idx) { 返回 e[idx + 1] }
函数 枚举_字段数(e) { 返回 计数(e) - 1 }

// 模式匹配引擎
// 分支表: [[标签, 结果值], ...]
// 辨: 找到标签对应的结果
函数 匹配_创建() { 返回 [] }

函数 匹配_添加分支(分支表, 标签, 结果值) {
 追加(分支表, [标签, 结果值])
}

函数 匹配_执行(分支表, 枚举值) { 定义 标签 = 枚举值[0]
 定义 可变 i = 0
 当 (i < 计数(分支表)) { 如果 (分支表[i][0] == 标签) { 返回 分支表[i][1] }
 如果 (分支表[i][0] == -1) { 返回 分支表[i][1] }
 i = i + 1
 }
 返回 -1
}

// 穷举检查
函数 匹配_穷举(edef, 分支表) { 定义 可变 有万能 = 假
 定义 可变 i = 0
 当 (i < 计数(分支表)) { 如果 (分支表[i][0] == -1) { 有万能 = 真 }
 i = i + 1
 }
 如果 (有万能 == 真) { 返回 真 }
 // 检查每个变体是否都有分支
 定义 可变 j = 0
 当 (j < 计数(edef[1])) { 定义 标签 = edef[1][j][0]
 i = 0
 当 (i < 计数(分支表)) { 如果 (分支表[i][0] == 标签) { 已找 = 真 }
 i = i + 1
 }
 如果 (已找 == 假) { 返回 假 }
 j = j + 1
 }
 返回 真
}

// Option类型
定义 选项_有 = 1

函数 可选_有(值) { 返回 [选项_有, 值] }
函数 可选_无() { 返回 [优化_无, 0] }
函数 可选_是有(opt) { 返回 opt[0] == 选项_有 }
函数 可选_取值(opt) {
    如果 (opt[0] == 选项_有) { 返回 opt[1] }
    返回 0
}
函数 可选_取或(opt, 缺省) {
    如果 (opt[0] == 选项_有) { 返回 opt[1] }
    返回 缺省
}

// Result类型

函数 结果_成功(值) { 返回 [结果_成功, 值] }
函数 结果_失败(错误) { 返回 [结果_错误, 错误] }
函数 结果_是成功(r) { 返回 r[0] == 结果_成功 }
函数 结果_取值(r) { 返回 r[1] }

// 形状ADT示例
函数 形状_圆(半径) { 返回 枚举_构造1(0, 半径) }
函数 形状_矩形(宽, 高) { 返回 枚举_构造2(1, 宽, 高) }
函数 形状_三角(a, b, c) { 返回 枚举_构造3(2, a, b, c) }

函数 形状_面积(形状) { 定义 标签 = 形状[0]
 如果 (标签 == 0) { 返回 3142 * 形状[1] * 形状[1] / 1000 }
 如果 (标签 == 1) { 返回 形状[1] * 形状[2] }
 如果 (标签 == 2) { 定义 s2 = 形状[1] + 形状[2] + 形状[3]
 返回 s2 * s2 / 16
 }
 返回 0
}

// Option高级操作
// map: Some(x) → Some(f(x)), None → None
// 变换类型: 1=加 2=乘 3=减
函数 可选_映射(opt, 变换, 参数) {
    如果 (opt[0] != 选项_有) { 返回 可选_无()
}
 定义 v = opt[1]
 如果 (变换 == 1) { 返回 可选_有(v + 参数) }
 如果 (变换 == 2) { 返回 可选_有(v * 参数) }
 如果 (变换 == 3) { 返回 可选_有(v - 参数) }
 返回 opt
}

// filter: Some(x) if cond → Some(x), else None
函数 可选_过滤(opt, 阈值) {
    如果 (opt[0] != 选项_有) { 返回 可选_无()
}
 如果 (opt[1] > 阈值) { 返回 opt }
 返回 可选_无()
}

// flatten: Some(Some(x)) → Some(x)
函数 可选_展平(opt) {
    如果 (opt[0] != 选项_有) { 返回 可选_无()
}
 定义 inner = opt[1]
 如果 (计数(inner) >= 2 且 inner[0] == 选项_有) { 返回 inner }
 返回 opt
}

// Result高级操作
函数 结果_映射(r, 变换, 参数) {
    如果 (r[0] != 结果_成功) { 返回 r
}
 定义 v = r[1]
 如果 (变换 == 1) { 返回 结果_成功(v + 参数) }
 如果 (变换 == 2) { 返回 结果_成功(v * 参数) }
 返回 r
}

函数 结果_或(r, 默认值) {
    如果 (r[0] == 结果_成功) { 返回 r[1]
}
 返回 默认值
}

// 枚举变体名查找
函数 枚举_变体名(edef, 标签) { 定义 可变 i = 0
 当 (i < 计数(edef[1])) { 如果 (edef[1][i][0] == 标签) { 返回 i }
 i = i + 1
 }
 返回 -1
}

// 匹配缺失分支列表
函数 匹配_缺失(edef, 分支表) { 定义 可变 缺失 = []
 定义 可变 j = 0
 当 (j < 计数(edef[1])) { 定义 标签 = edef[1][j][0]
 定义 可变 i = 0
 当 (i < 计数(分支表)) { 如果 (分支表[i][0] == 标签 或 分支表[i][0] == -1) { 已找 = 真 }
 i = i + 1
 }
 如果 (已找 == 假) { 追加(缺失, 标签) }
 j = j + 1
 }
 返回 缺失
}

// 匹配穷尽性检查 (Exhaustiveness Check)
// 确保match语句覆盖了所有变体 → 编译器级安全保障
函数 匹配_穷尽(edef, 分支表) { 定义 缺失 = 匹配_缺失(edef, 分支表)
 返回 计数(缺失) == 0
}

// 匹配冗余检查
// 检测永远不会匹配到的分支
函数 匹配_冗余(分支表) { 定义 可变 冗余 = []
 定义 可变 已见标签 = []
 定义 可变 i = 0
 当 (i < 计数(分支表)) { 定义 标签 = 分支表[i][0]
 如果 (标签 == -1) {
 // 通配符: 后续所有分支都冗余
 定义 可变 j = i + 1
 当 (j < 计数(分支表)) {
 追加(冗余, j)
 j = j + 1
 }
 返回 冗余
 }
 // 检查重复标签
 定义 可变 k = 0
 当 (k < 计数(已见标签)) { 如果 (已见标签[k] == 标签) {
 追加(冗余, i)
 }
 k = k + 1
 }
 追加(已见标签, 标签)
 i = i + 1
 }
 返回 冗余
}

// 枚举类型注册表
函数 枚举注册表_创建() { 返回 [[], 0] // [枚举定义列表, 总数]
}

函数 枚举注册表_注册(注册表, 名称, 变体列表) { 定义 edef = 枚举_定义(名称)
 定义 可变 vi = 0
 当 (vi < 计数(变体列表)) { 枚举_添加变体(edef, 变体列表[vi][0], 变体列表[vi][1]) vi = vi + 1 }
 追加(注册表[0], edef)
 注册表[1] = 注册表[1] + 1
 返回 注册表[1] - 1 // 返回索引
}

函数 枚举注册表_查找(注册表, 名称) { 定义 可变 i = 0
 当 (i < 注册表[1]) { 如果 (注册表[0][i][0] == 名称) { 返回 注册表[0][i]
 }
 i = i + 1
 }
 返回 空
}

函数 枚举注册表_大小(注册表) { 返回 注册表[1] }

// 枚举值相等比较
函数 枚举值_相等(a, b) { 如果 (a[0] != b[0]) { 返回 0 } // 标签不同
 定义 arity_a = 计数(a) - 1
 定义 arity_b = 计数(b) - 1
 如果 (arity_a != arity_b) { 返回 0 }
 定义 可变 i = 1
 当 (i <= arity_a) { 如果 (a[i] != b[i]) { 返回 0 }
 i = i + 1
 }
 返回 1
}

// 枚举序列化 (用于持久化/传输)
函数 枚举值_序列化(值) { 定义 可变 结果 = [值[0]] // 标签
 定义 可变 i = 1
 当 (i < 计数(值)) {
 追加(结果, 值[i])
 i = i + 1
 }
 返回 结果
}

// 枚举统计

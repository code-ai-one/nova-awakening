导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/整数转字符串.nova")

定义 最大命令队列 = 8
定义 显存_最大块 = 256

结构 图处设备 {
    总线号,
    设备号,
    功能号,
    基地址,
    显存大小,
    显存已用,
    已初始化,
    复位次数,
    命令提交数,
    栅栏值,
}

结构 显存块 {
    偏移,
    大小,
    已分配,
}

定义 可变 全局图处 = 0
定义 可变 显存表 = 0
定义 可变 显存块数 = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 图处_初始化(总线, 设备, 功能) {
    全局图处 = 堆_分配(图处设备)
    全局图处.总线号 = 总线
    全局图处.设备号 = 设备
    全局图处.功能号 = 功能
    全局图处.基地址 = 图处_读配置(总线, 设备, 功能, 0x10) & 0xFFFFFFF0
    全局图处.显存大小 = 图处_检测显存(总线, 设备, 功能)
    全局图处.显存已用 = 0
    全局图处.已初始化 = 假
    全局图处.复位次数 = 0
    全局图处.命令提交数 = 0
    全局图处.栅栏值 = 0
    显存表 = 堆_分配(显存_最大块 * 16)
    显存块数 = 0
    图处_复位()
    图处_配置中断(总线, 设备, 功能)
    全局图处.已初始化 = 真
}

函数 图处_读配置(总线, 设备, 功能, 偏移) {
    定义 地址 = 0x80000000 | (总线 << 16) | (设备 << 11) | (功能 << 8) | (偏移 & 0xFC)
    端口_写32(0xCF8, 地址)
    返回 端口_读32(0xCFC)
}

函数 图处_写配置(总线, 设备, 功能, 偏移, 值) {
    定义 地址 = 0x80000000 | (总线 << 16) | (设备 << 11) | (功能 << 8) | (偏移 & 0xFC)
    端口_写32(0xCF8, 地址)
    端口_写32(0xCFC, 值)
}

函数 图处_检测显存(总线, 设备, 功能) {
    定义 原始 = 图处_读配置(总线, 设备, 功能, 0x10)
    图处_写配置(总线, 设备, 功能, 0x10, 0xFFFFFFFF)
    定义 大小掩码 = 图处_读配置(总线, 设备, 功能, 0x10)
    图处_写配置(总线, 设备, 功能, 0x10, 原始)
    定义 大小 = ~(大小掩码 & 0xFFFFFFF0) + 1
    返回 大小
}

函数 图处_复位() {
    如果 (全局图处 == 0) { 返回 }
    全局图处.复位次数 = 全局图处.复位次数 + 1
    定义 命令 = 图处_读配置(全局图处.总线号, 全局图处.设备号, 全局图处.功能号, 0x04)
    图处_写配置(全局图处.总线号, 全局图处.设备号, 全局图处.功能号, 0x04, 命令 & ~0x07)
    定义 可变 等待 = 0
    当 (等待 < 100000) { 等待 = 等待 + 1 }
    图处_写配置(全局图处.总线号, 全局图处.设备号, 全局图处.功能号, 0x04, 命令 | 0x07)
}

函数 图处_配置中断(总线, 设备, 功能) {
    定义 命令 = 图处_读配置(总线, 设备, 功能, 0x04)
    图处_写配置(总线, 设备, 功能, 0x04, 命令 & ~(1 << 10))
}

函数 图处_分配显存(大小) {
    如果 (全局图处 == 0) { 返回 0 }
    定义 对齐大小 = (大小 + 4095) & ~4095
    如果 (全局图处.显存已用 + 对齐大小 > 全局图处.显存大小) { 返回 0 }
    如果 (显存块数 >= 显存_最大块) { 返回 0 }
    定义 偏移 = 全局图处.显存已用
    内存_写64(显存表 + 显存块数 * 16, 偏移)
    内存_写64(显存表 + 显存块数 * 16 + 8, 对齐大小)
    显存块数 = 显存块数 + 1
    全局图处.显存已用 = 全局图处.显存已用 + 对齐大小
    返回 全局图处.基地址 + 偏移
}

函数 图处_释放显存(地址) {
    如果 (全局图处 == 0) { 返回 }
    定义 偏移 = 地址 - 全局图处.基地址
    定义 可变 序号 = 0
    当 (序号 < 显存块数) {
        如果 (内存_读64(显存表 + 序号 * 16) == 偏移) {
            定义 大小 = 内存_读64(显存表 + 序号 * 16 + 8)
            全局图处.显存已用 = 全局图处.显存已用 - 大小
            返回
        }
        序号 = 序号 + 1
    }
}

函数 图处_提交命令(命令指针, 命令大小) {
    如果 (全局图处 == 0 || !全局图处.已初始化) { 返回 错误_未初始化 }
    全局图处.命令提交数 = 全局图处.命令提交数 + 1
    全局图处.栅栏值 = 全局图处.栅栏值 + 1
    返回 全局图处.栅栏值
}

函数 图处_等待栅栏(目标值) {
    如果 (全局图处 == 0) { 返回 错误_未初始化 }
    定义 可变 等待 = 0
    当 (等待 < 1000000) {
        如果 (全局图处.栅栏值 >= 目标值) { 返回 0 }
        等待 = 等待 + 1
    }
    返回 错误_超时
}

函数 图处_读寄存器(偏移) {
    如果 (全局图处 == 0) { 返回 0 }
    返回 内存_读32(全局图处.基地址 + 偏移)
}

函数 图处_写寄存器(偏移, 值) {
    如果 (全局图处 == 0) { 返回 }
    内存_写32(全局图处.基地址 + 偏移, 值)
}

函数 图处_显存使用率() {
    如果 (全局图处 == 0 || 全局图处.显存大小 == 0) { 返回 0 }
    返回 全局图处.显存已用 * 100 / 全局图处.显存大小
}

函数 图处_完整统计() {
    如果 (全局图处 == 0) { 返回 [0, 0, 0, 0, 0, 0] }
    返回 [全局图处.已初始化, 全局图处.显存大小, 全局图处.显存已用, 图处_显存使用率(), 全局图处.命令提交数, 全局图处.复位次数]
}

// §2 图处健康检查与诊断

定义 可变 图处_错误总数 = 0
定义 可变 图处_挂起次数 = 0
定义 可变 图处_超时次数 = 0
定义 可变 图处_中断次数 = 0

函数 图处_健康检查() {
    定义 可变 问题 = []
    如果 (全局图处 == 0) { 追加(问题, "图处设备未初始化"); 返回 问题 }
    如果 (!全局图处.已初始化) { 追加(问题, "图处设备初始化未完成") }
    如果 (全局图处.复位次数 > 5) {
        追加(问题, "图处复位次数过多: " + 整数转字符串(全局图处.复位次数))
    }
    如果 (图处_显存使用率() > 95) {
        追加(问题, "显存即将耗尽: " + 整数转字符串(图处_显存使用率()) + "%")
    }
    如果 (图处_错误总数 > 10) {
        追加(问题, "图处错误过多: " + 整数转字符串(图处_错误总数))
    }
    如果 (图处_挂起次数 > 3) {
        追加(问题, "图处频繁挂起: " + 整数转字符串(图处_挂起次数) + "次")
    }
    如果 (计数(问题) == 0) { 返回 "图处设备健康" }
    返回 问题
}

函数 图处_详细统计() {
    如果 (全局图处 == 0) { 返回 空 }
    返回 {
        已初始化: 全局图处.已初始化,
        总线: 全局图处.总线号,
        设备: 全局图处.设备号,
        功能: 全局图处.功能号,
        基地址: 全局图处.基地址,
        显存总量: 全局图处.显存大小,
        显存已用: 全局图处.显存已用,
        显存使用率: 图处_显存使用率(),
        显存剩余: 全局图处.显存大小 - 全局图处.显存已用,
        命令提交: 全局图处.命令提交数,
        复位次数: 全局图处.复位次数,
        栅栏值: 全局图处.栅栏值,
        错误数: 图处_错误总数,
        挂起数: 图处_挂起次数,
        超时数: 图处_超时次数,
        中断数: 图处_中断次数,
        显存块数: 显存块数,
    }
}

// §3 显存管理扩展

函数 图处_显存剩余() {
    如果 (全局图处 == 0) { 返回 0 }
    返回 全局图处.显存大小 - 全局图处.显存已用
}

函数 图处_显存剩余MB() {
    返回 图处_显存剩余() / 1024 / 1024
}

函数 图处_显存总MB() {
    如果 (全局图处 == 0) { 返回 0 }
    返回 全局图处.显存大小 / 1024 / 1024
}

函数 图处_显存已用MB() {
    如果 (全局图处 == 0) { 返回 0 }
    返回 全局图处.显存已用 / 1024 / 1024
}

函数 图处_显存不足() {
    返回 图处_显存使用率() > 90
}

函数 图处_显存块信息(序号) {
    如果 (序号 >= 显存块数) { 返回 空 }
    返回 {
        偏移: 内存_读64(显存表 + 序号 * 16),
        大小: 内存_读64(显存表 + 序号 * 16 + 8),
    }
}

函数 图处_显存碎片数() {
    返回 显存块数
}

函数 图处_最大连续显存() {
    如果 (全局图处 == 0) { 返回 0 }
    返回 全局图处.显存大小 - 全局图处.显存已用
}

// §4 图处电源管理

定义 图处电源_D0 = 0
定义 图处电源_D1 = 1
定义 图处电源_D2 = 2
定义 图处电源_D3冷 = 3
定义 图处电源_D3热 = 4

定义 可变 图处_当前电源状态 = 0

函数 图处_设置电源状态(状态) {
    如果 (全局图处 == 0) { 返回 错误_未初始化 }
    如果 (状态 < 图处电源_D0 || 状态 > 图处电源_D3热) { 返回 错误_无效参数 }
    图处_当前电源状态 = 状态
    如果 (状态 == 图处电源_D0) {
        图处_复位()
    }
    返回 0
}

函数 图处_获取电源状态() {
    返回 图处_当前电源状态
}

函数 图处_电源状态名(状态) {
    如果 (状态 == 图处电源_D0) { 返回 "D0(全功率)" }
    如果 (状态 == 图处电源_D1) { 返回 "D1(低功耗)" }
    如果 (状态 == 图处电源_D2) { 返回 "D2(更低功耗)" }
    如果 (状态 == 图处电源_D3冷) { 返回 "D3cold(关闭)" }
    如果 (状态 == 图处电源_D3热) { 返回 "D3hot(待机)" }
    返回 "未知"
}

函数 图处_挂起() {
    图处_挂起次数 = 图处_挂起次数 + 1
    返回 图处_设置电源状态(图处电源_D3热)
}

函数 图处_恢复() {
    定义 结果 = 图处_设置电源状态(图处电源_D0)
    如果 (结果 == 0 && 全局图处 != 0) {
        全局图处.已初始化 = 真
    }
    返回 结果
}

// §5 PCI寄存器常量

定义 PCI_VENDOR_ID = 0x00
定义 PCI_DEVICE_ID = 0x02
定义 PCI_COMMAND = 0x04
定义 PCI_STATUS = 0x06
定义 PCI_REVISION = 0x08
定义 PCI_CLASS = 0x0B
定义 PCI_SUBCLASS = 0x0A
定义 PCI_BAR0 = 0x10
定义 PCI_BAR1 = 0x14
定义 PCI_BAR2 = 0x18
定义 PCI_INT_LINE = 0x3C
定义 PCI_INT_PIN = 0x3D

定义 PCI_CMD_IO = 0x01
定义 PCI_CMD_MEMORY = 0x02
定义 PCI_CMD_BUSMASTER = 0x04
定义 PCI_CMD_INT_DISABLE = 0x400

函数 图处_获取厂商ID() {
    如果 (全局图处 == 0) { 返回 0 }
    返回 图处_读配置(全局图处.总线号, 全局图处.设备号, 全局图处.功能号, PCI_VENDOR_ID) & 0xFFFF
}

函数 图处_获取设备ID() {
    如果 (全局图处 == 0) { 返回 0 }
    返回 (图处_读配置(全局图处.总线号, 全局图处.设备号, 全局图处.功能号, PCI_DEVICE_ID) >> 16) & 0xFFFF
}

函数 图处_获取类别() {
    如果 (全局图处 == 0) { 返回 0 }
    返回 图处_读配置(全局图处.总线号, 全局图处.设备号, 全局图处.功能号, PCI_CLASS) & 0xFF
}

函数 图处_是显示控制器() {
    返回 图处_获取类别() == 0x03
}

// §6 命令环与栅栏扩展

定义 可变 命令队列_头 = 0
定义 可变 命令队列_尾 = 0
定义 可变 命令队列_大小 = 4096

函数 图处_命令队列满() {
    返回 (命令队列_尾 + 1) % 命令队列_大小 == 命令队列_头
}

函数 图处_命令队列空() {
    返回 命令队列_头 == 命令队列_尾
}

函数 图处_命令队列深度() {
    如果 (命令队列_尾 >= 命令队列_头) {
        返回 命令队列_尾 - 命令队列_头
    }
    返回 命令队列_大小 - 命令队列_头 + 命令队列_尾
}

函数 图处_等待空闲() {
    如果 (全局图处 == 0) { 返回 错误_未初始化 }
    定义 可变 等待 = 0
    当 (!图处_命令队列空() && 等待 < 10000000) {
        等待 = 等待 + 1
    }
    如果 (等待 >= 10000000) {
        图处_超时次数 = 图处_超时次数 + 1
        返回 错误_超时
    }
    返回 0
}

函数 图处_栅栏同步() {
    如果 (全局图处 == 0) { 返回 错误_未初始化 }
    定义 目标 = 全局图处.栅栏值
    返回 图处_等待栅栏(目标)
}

// §7 重置与调试

函数 图处_重置统计() {
    图处_错误总数 = 0
    图处_挂起次数 = 0
    图处_超时次数 = 0
    图处_中断次数 = 0
    如果 (全局图处 != 0) {
        全局图处.命令提交数 = 0
        全局图处.复位次数 = 0
    }
}

函数 图处_打印信息() {
    如果 (全局图处 == 0) { 内核信息("图处: 未初始化"); 返回 }
    内核信息("图处: 总线=" + 整数转字符串(全局图处.总线号) +
             " 设备=" + 整数转字符串(全局图处.设备号) +
             " 功能=" + 整数转字符串(全局图处.功能号))
    内核信息("  基地址=" + 十六进制(全局图处.基地址) +
             " 显存=" + 整数转字符串(图处_显存总MB()) + "MB" +
             " 已用=" + 整数转字符串(图处_显存已用MB()) + "MB" +
             " (" + 整数转字符串(图处_显存使用率()) + "%)")
    内核信息("  命令=" + 整数转字符串(全局图处.命令提交数) +
             " 复位=" + 整数转字符串(全局图处.复位次数) +
             " 电源=" + 图处_电源状态名(图处_当前电源状态))
}

函数 图处_是否就绪() {
    返回 全局图处 != 0 && 全局图处.已初始化 && 图处_当前电源状态 == 图处电源_D0
}

函数 图处_错误率() {
    如果 (全局图处 == 0 || 全局图处.命令提交数 == 0) { 返回 0 }
    返回 图处_错误总数 * 100 / 全局图处.命令提交数
}

// §8 常见GPU厂商ID

定义 GPU_VENDOR_INTEL = 0x8086
定义 GPU_VENDOR_AMD = 0x1002
定义 GPU_VENDOR_NVIDIA = 0x10DE
定义 GPU_VENDOR_VMWARE = 0x15AD
定义 GPU_VENDOR_VIRTIO = 0x1AF4
定义 GPU_VENDOR_BOCHS = 0x1234

函数 图处_厂商名() {
    定义 vid = 图处_获取厂商ID()
    如果 (vid == GPU_VENDOR_INTEL) { 返回 "Intel" }
    如果 (vid == GPU_VENDOR_AMD) { 返回 "AMD" }
    如果 (vid == GPU_VENDOR_NVIDIA) { 返回 "NVIDIA" }
    如果 (vid == GPU_VENDOR_VMWARE) { 返回 "VMware" }
    如果 (vid == GPU_VENDOR_VIRTIO) { 返回 "VirtIO" }
    如果 (vid == GPU_VENDOR_BOCHS) { 返回 "Bochs/QEMU" }
    返回 "未知(0x" + 十六进制(vid) + ")"
}

定义 可变 AI_图处复位_风暴阈值 = 10000
定义 可变 AI_图处复位_预测IRQ = 0

函数 AI_图处复位_风暴检测(触发频率) {
    如果 (触发频率 > AI_图处复位_风暴阈值) {
        AI_图处复位_风暴阈值 = AI_图处复位_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_图处复位_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

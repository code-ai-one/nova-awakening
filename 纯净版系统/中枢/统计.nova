// NovaOS 神经训练架 · 训练统计 — 觉醒理论·不可绕过的理论架构
// 原创理论: NovaTrain — 完备训练监控与调度体系
// §1 损失追踪与收敛检测:
//   滑动窗口均值: L̄_w = (1/W)ΣL_i, W=窗口大小
//   收敛判定: |(L̄_prev - L̄_curr)/L̄_prev| < ε
//   早停机制: patience轮验证损失无改善则停止
// §2 学习率调度 (FP1000定点):
//   Warmup: lr_t = lr_base × t/T_warmup, t<T_warmup
//   Cosine: lr_t = lr_min + ½(lr_max-lr_min)(1+cos(πt/T))
//   Step: lr_t = lr_base × γ^floor(t/step_size)
//   OneCycle: 三段式 — 升温/峰值/冷却
//   近似公式使用FP1000定点三角查表
// §3 梯度诊断:
//   梯度爆炸检测: |g_t/g_{t-1}| > 100 → 警报
//   梯度消失检测: |g_t| < ε 连续5次 → 警报
//   NaN/Inf检测: 每次更新后检查数值有效性
//   梯度累积分布: 维护梯度范数的分布统计
// §4 训练速度与ETA:
//   吞吐量 EMA: T_t = 0.9T_{t-1} + 0.1×(samples/sec)_t
//   剩余时间估算: ETA = (total_epochs - current) × avg_epoch_time
// §5 检查点管理:
//   定期保存最佳模型状态
//   保留top-K检查点 (按验证损失排序)
// 四阶段AI演进: NovaTrain在阶段2提供本地训练基础设施

导入("./类型定义.nova")
导入("./错误码.nova")
导入("../记忆/文件层文件.nova")
导入("../记忆/虚文件信号.nova")
导入("./时钟中枢.nova")
导入("../执行/探测.nova")
导入("./新系统键值缓.nova")

定义 统计_损失窗口 = 50
定义 统计_收敛阈值 = 10
定义 统计_最大层追踪 = 128

结构 训练统计器 {
    训练轮次,
    已处理样本,
    总损失,
    最小损失,
    最大损失,
    损失历史,
    学习率历史,
    层统计,
    训练开始时间,
    总训练耗时,
    验证损失,
    验证准确率,
    最佳验证损失,
    早停计数器,
    已收敛,
    梯度范数历史,
    吞吐量历史,
}

结构 层训练统计 {
    层名,
    前向耗时,
    反向耗时,
    梯度范数,
    权重范数,
    更新次数,
    最大梯度,
    最小梯度,
}

定义 可变 全局训练统计 = 0

函数 训练统计_初始化() {
    全局训练统计 = 堆_分配(训练统计器)
    全局训练统计.训练轮次 = 0
    全局训练统计.已处理样本 = 0
    全局训练统计.总损失 = 0
    全局训练统计.最小损失 = 999999
    全局训练统计.最大损失 = 0
    全局训练统计.损失历史 = []
    全局训练统计.学习率历史 = []
    全局训练统计.层统计 = []
    全局训练统计.训练开始时间 = 读取毫秒()
    全局训练统计.总训练耗时 = 0
    全局训练统计.验证损失 = 0
    全局训练统计.验证准确率 = 0
    全局训练统计.最佳验证损失 = 999999
    全局训练统计.早停计数器 = 0
    全局训练统计.已收敛 = 假
    全局训练统计.梯度范数历史 = []
    全局训练统计.吞吐量历史 = []
    返回 全局训练统计
}

函数 训练统计_记录损失(损失) {
    如果 (全局训练统计 == 0) { 训练统计_初始化() }
    全局训练统计.总损失 = 全局训练统计.总损失 + 损失
    如果 (损失 < 全局训练统计.最小损失) { 全局训练统计.最小损失 = 损失 }
    如果 (损失 > 全局训练统计.最大损失) { 全局训练统计.最大损失 = 损失 }

    追加(全局训练统计.损失历史, 损失)
    如果 (计数(全局训练统计.损失历史) > 统计_损失窗口 * 10) {
        全局训练统计.损失历史 = 切片(全局训练统计.损失历史,
            计数(全局训练统计.损失历史) - 统计_损失窗口 * 5,
            计数(全局训练统计.损失历史))
    }
}

函数 训练统计_记录轮次(样本数, 学习率) {
    如果 (全局训练统计 == 0) { 训练统计_初始化() }
    全局训练统计.训练轮次 = 全局训练统计.训练轮次 + 1
    全局训练统计.已处理样本 = 全局训练统计.已处理样本 + 样本数
    追加(全局训练统计.学习率历史, 学习率)
}

函数 训练统计_记录验证(验证损失, 准确率) {
    如果 (全局训练统计 == 0) { 返回 }
    全局训练统计.验证损失 = 验证损失
    全局训练统计.验证准确率 = 准确率

    如果 (验证损失 < 全局训练统计.最佳验证损失) {
        全局训练统计.最佳验证损失 = 验证损失
        全局训练统计.早停计数器 = 0
    } 否则 {
        全局训练统计.早停计数器 = 全局训练统计.早停计数器 + 1
    }
}

函数 训练统计_检查收敛() {
    如果 (全局训练统计 == 0) { 返回 假 }
    定义 历史 = 全局训练统计.损失历史
    如果 (计数(历史) < 统计_损失窗口) { 返回 假 }

    定义 最近开始 = 计数(历史) - 统计_损失窗口
    定义 可变 最近均值 = 0
    定义 可变 i = 最近开始
    当 (i < 计数(历史)) {
        最近均值 = 最近均值 + 历史[i]
        i = i + 1
    }
    最近均值 = 最近均值 / 统计_损失窗口

    定义 前段开始 = 最近开始 - 统计_损失窗口
    如果 (前段开始 < 0) { 返回 假 }
    定义 可变 前段均值 = 0
    i = 前段开始
    当 (i < 最近开始) {
        前段均值 = 前段均值 + 历史[i]
        i = i + 1
    }
    前段均值 = 前段均值 / 统计_损失窗口

    如果 (前段均值 == 0) { 返回 假 }
    定义 改善率 = (前段均值 - 最近均值) * 1000 / 前段均值
    如果 (改善率 < 统计_收敛阈值) {
        全局训练统计.已收敛 = 真
        返回 真
    }
    返回 假
}

函数 训练统计_应早停() {
    如果 (全局训练统计 == 0) { 返回 假 }
    返回 全局训练统计.早停计数器 >= 10
}

函数 训练统计_记录梯度范数(范数) {
    如果 (全局训练统计 == 0) { 返回 }
    追加(全局训练统计.梯度范数历史, 范数)
    如果 (计数(全局训练统计.梯度范数历史) > 200) {
        全局训练统计.梯度范数历史 = 切片(全局训练统计.梯度范数历史, 100, 200)
    }
}

函数 训练统计_检查梯度爆炸() {
    如果 (全局训练统计 == 0) { 返回 假 }
    定义 历史 = 全局训练统计.梯度范数历史
    如果 (计数(历史) < 5) { 返回 假 }
    定义 最近 = 历史[计数(历史) - 1]
    定义 前一个 = 历史[计数(历史) - 2]
    如果 (前一个 > 0 && 最近 / 前一个 > 100) { 返回 真 }
    返回 假
}

函数 训练统计_记录吞吐量(样本每秒) {
    如果 (全局训练统计 == 0) { 返回 }
    追加(全局训练统计.吞吐量历史, 样本每秒)
}

函数 训练统计_添加层(层名) {
    如果 (全局训练统计 == 0) { 训练统计_初始化() }
    如果 (计数(全局训练统计.层统计) >= 统计_最大层追踪) { 返回 }
    定义 ls = 堆_分配(层训练统计)
    ls.层名 = 层名
    ls.前向耗时 = 0
    ls.反向耗时 = 0
    ls.梯度范数 = 0
    ls.权重范数 = 0
    ls.更新次数 = 0
    ls.最大梯度 = 0
    ls.最小梯度 = 999999
    追加(全局训练统计.层统计, ls)
}

函数 训练统计_更新层(层索引, 前向耗时, 反向耗时, 梯度范数) {
    如果 (全局训练统计 == 0) { 返回 }
    如果 (层索引 < 0 || 层索引 >= 计数(全局训练统计.层统计)) { 返回 }
    定义 ls = 全局训练统计.层统计[层索引]
    ls.前向耗时 = ls.前向耗时 + 前向耗时
    ls.反向耗时 = ls.反向耗时 + 反向耗时
    ls.梯度范数 = 梯度范数
    ls.更新次数 = ls.更新次数 + 1
    如果 (梯度范数 > ls.最大梯度) { ls.最大梯度 = 梯度范数 }
    如果 (梯度范数 < ls.最小梯度) { ls.最小梯度 = 梯度范数 }
}

函数 TNF58B_统计() {
    如果 (全局训练统计 == 0) {
        返回 [0, 0, 0, 0]
    }
    返回 [全局训练统计.训练轮次, 全局训练统计.已处理样本,
           全局训练统计.总损失, 计数(全局训练统计.层统计)]
}

函数 打开数据流(路径) {
    定义 文件 = vfs_open(路径, 0, 0)
    如果 (文件 == 空) { 返回 空 }
    返回 [文件, 0, 假, 0]
}

函数 数据流_结束(流) {
    如果 (流 == 空) { 返回 真 }
    返回 流[2]
}

函数 数据流_读批次(流, 批大小) {
    如果 (流 == 空 || 流[2]) { 返回 空 }
    定义 数据 = vfs_read(流[0], 空, 批大小 * 256)
    如果 (数据 == 空 || 计数(数据) == 0) {
        流[2] = 真
        返回 空
    }
    流[1] = 流[1] + 计数(数据)
    流[3] = 流[3] + 1
    返回 数据
}

函数 数据流_重置(流) {
    如果 (流 == 空) { 返回 }
    vfs_seek(流[0], 0)
    流[1] = 0
    流[2] = 假
}

函数 数据流_关闭(流) {
    如果 (流 != 空 && 流[0] != 空) { vfs_close(流[0]) }
}

函数 数据流_统计(流) {
    如果 (流 == 空) { 返回 [0, 0] }
    返回 [流[1], 流[3]]
}

函数 向量哈希(向量) {
    定义 可变 h = 0x811c9dc5
    定义 可变 i = 0
    当 (i < 计数(向量)) {
        h = (h ^ (向量[i] & 0xFF)) * 0x01000193
        i = i + 1
    }
    返回 h
}

函数 向量哈希64(向量) {
    定义 可变 h = 0xcbf29ce484222325
    定义 可变 i = 0
    当 (i < 计数(向量)) {
        h = (h ^ (向量[i] & 0xFF)) * 0x100000001b3
        i = i + 1
    }
    返回 h
}

函数 稀疏KV_查找(哈希) {
    如果 (!KV_已初始化) { 返回 空 }
    返回 KV_查询(哈希)
}

函数 向量加权融合(a, b, 权重) {
    如果 (a == 空) { 返回 b }
    如果 (b == 空) { 返回 a }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(a) && i < 计数(b)) {
        追加(结果, a[i] * (1000 - 权重) / 1000 + b[i] * 权重 / 1000)
        i = i + 1
    }
    返回 结果
}

函数 向量点积(a, b) {
    定义 可变 和 = 0
    定义 可变 i = 0
    定义 长度 = 计数(a)
    如果 (计数(b) < 长度) { 长度 = 计数(b) }
    当 (i < 长度) {
        和 = 和 + a[i] * b[i]
        i = i + 1
    }
    返回 和
}

函数 向量L2范数(向量) {
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < 计数(向量)) {
        和 = 和 + 向量[i] * 向量[i]
        i = i + 1
    }
    返回 整数平方根(和)
}

函数 向量余弦相似度(a, b) {
    定义 点 = 向量点积(a, b)
    定义 范数a = 向量L2范数(a)
    定义 范数b = 向量L2范数(b)
    如果 (范数a == 0 || 范数b == 0) { 返回 0 }
    返回 点 * 1000 / (范数a * 范数b)
}

// 学习率调度器 (FP1000定点)

定义 调度_常量 = 0
定义 调度_warmup = 1
定义 调度_cosine = 2
定义 调度_step = 3
定义 调度_onecycle = 4

结构 学习率调度器 {
    类型,           // 调度类型
    基础学习率,     // FP1000 基础学习率
    最小学习率,     // FP1000
    最大学习率,     // FP1000
    warmup步数,    // warmup总步数
    总步数,         // 训练总步数
    step_size,     // step衰减间隔
    衰减因子,       // FP1000 每次衰减的因子
    当前步,         // 当前步数
}

定义 可变 全局调度器 = 0

函数 学习率调度_初始化(类型, 基础lr, 最小lr, 最大lr, warmup步, 总步, step_sz, 衰减) {
    全局调度器 = 堆_分配(学习率调度器)
    全局调度器.类型 = 类型
    全局调度器.基础学习率 = 基础lr
    全局调度器.最小学习率 = 最小lr
    全局调度器.最大学习率 = 最大lr
    全局调度器.warmup步数 = warmup步
    全局调度器.总步数 = 总步
    全局调度器.step_size = step_sz
    全局调度器.衰减因子 = 衰减
    全局调度器.当前步 = 0
    返回 全局调度器
}

函数 学习率调度_获取lr() {
    如果 (全局调度器 == 0) { 返回 1 }
    定义 s = 全局调度器
    s.当前步 = s.当前步 + 1

    // Warmup阶段
    如果 (s.当前步 <= s.warmup步数 && s.warmup步数 > 0) {
        返回 s.最小学习率 + (s.基础学习率 - s.最小学习率) * s.当前步 / s.warmup步数
    }

    定义 有效步 = s.当前步 - s.warmup步数
    定义 有效总 = s.总步数 - s.warmup步数
    如果 (有效总 <= 0) { 有效总 = 1 }

    如果 (s.类型 == 调度_cosine) {
        // Cosine退火: lr = lr_min + 0.5*(lr_max-lr_min)*(1+cos(pi*t/T))
        // cos近似: 使用分段线性近似 cos(pi*x) 其中 x=t/T ∈[0,1]
        定义 进度 = 有效步 * 1000 / 有效总  // 0-1000
        // cos(pi*x) 近似: 1 - 2x² (x<500) / 2(1-x)² - 1 (x>=500)
        定义 可变 cos_val = 0
        如果 (进度 <= 500) {
            cos_val = 1000 - 2 * 进度 * 进度 / 1000
        } 否则 {
            定义 x = 1000 - 进度
            cos_val = 2 * x * x / 1000 - 1000
        }
        返回 s.最小学习率 + (s.基础学习率 - s.最小学习率) * (1000 + cos_val) / 2000
    }

    如果 (s.类型 == 调度_step) {
        // Step衰减: lr = lr_base * gamma^(step/step_size)
        如果 (s.step_size <= 0) { 返回 s.基础学习率 }
        定义 衰减次数 = 有效步 / s.step_size
        定义 可变 lr = s.基础学习率
        定义 可变 d = 0
        当 (d < 衰减次数) {
            lr = lr * s.衰减因子 / 1000
            d = d + 1
        }
        如果 (lr < s.最小学习率) { lr = s.最小学习率 }
        返回 lr
    }

    如果 (s.类型 == 调度_onecycle) {
        // OneCycle: 升温(0-30%) → 峰值(30%) → 冷却(30%-100%)
        定义 进度 = 有效步 * 100 / 有效总
        如果 (进度 < 30) {
            返回 s.最小学习率 + (s.最大学习率 - s.最小学习率) * 进度 / 30
        }
        返回 s.最大学习率 - (s.最大学习率 - s.最小学习率) * (进度 - 30) / 70
    }

    返回 s.基础学习率
}

// 梯度诊断 — 爆炸/消失/NaN检测

定义 可变 梯度_连续微小计数 = 0
定义 可变 梯度_NaN计数 = 0
定义 梯度_微小阈值 = 1       // FP1000: 0.001
定义 梯度_爆炸比率 = 100     // 爆炸判定比值

函数 训练统计_检查梯度消失() {
    如果 (全局训练统计 == 0) { 返回 假 }
    定义 历史 = 全局训练统计.梯度范数历史
    如果 (计数(历史) < 5) { 返回 假 }
    定义 可变 微小计 = 0
    定义 可变 i = 计数(历史) - 5
    当 (i < 计数(历史)) {
        如果 (历史[i] < 梯度_微小阈值) { 微小计 = 微小计 + 1 }
        i = i + 1
    }
    返回 微小计 >= 5
}

函数 训练统计_检查数值有效(值) {
    // 检查值是否为NaN或Inf的代理
    // 在定点系统中, 异常大值或异常模式表示数值问题
    如果 (值 > 999999999 || 值 < -999999999) {
        梯度_NaN计数 = 梯度_NaN计数 + 1
        返回 假
    }
    返回 真
}

// 训练速度与ETA估算

定义 可变 轮次开始时间 = 0
定义 可变 轮次耗时EMA = 0
定义 可变 吞吐量EMA = 0

函数 训练统计_轮次开始() {
    轮次开始时间 = 读取毫秒()
}

函数 训练统计_轮次结束(样本数) {
    定义 耗时 = 读取毫秒() - 轮次开始时间
    如果 (耗时 <= 0) { 耗时 = 1 }
    // EMA轮次耗时
    如果 (轮次耗时EMA == 0) {
        轮次耗时EMA = 耗时
    } 否则 {
        轮次耗时EMA = (轮次耗时EMA * 900 + 耗时 * 100) / 1000
    }
    // 吞吐量 (samples/sec)
    定义 吞吐 = 样本数 * 1000 / 耗时
    如果 (吞吐量EMA == 0) {
        吞吐量EMA = 吞吐
    } 否则 {
        吞吐量EMA = (吞吐量EMA * 900 + 吞吐 * 100) / 1000
    }
    训练统计_记录吞吐量(吞吐)
}

函数 训练统计_估算ETA(总轮次) {
    如果 (全局训练统计 == 0 || 轮次耗时EMA == 0) { 返回 0 }
    定义 剩余 = 总轮次 - 全局训练统计.训练轮次
    如果 (剩余 <= 0) { 返回 0 }
    返回 剩余 * 轮次耗时EMA  // 毫秒
}

// 检查点管理

定义 检查点_最大保留 = 5

结构 检查点记录 {
    轮次,
    验证损失,
    时间戳,
}

定义 可变 检查点列表 = []

函数 检查点_保存(轮次, 验证损失) {
    定义 cp = 堆_分配(检查点记录)
    cp.轮次 = 轮次
    cp.验证损失 = 验证损失
    cp.时间戳 = 读取毫秒()
    追加(检查点列表, cp)

    // 保留Top-K (按验证损失升序, 删除最差的)
    如果 (计数(检查点列表) > 检查点_最大保留) {
        // 找到损失最大的检查点删除
        定义 可变 最差idx = 0
        定义 可变 最差损 = 检查点列表[0].验证损失
        定义 可变 i = 1
        当 (i < 计数(检查点列表)) {
            如果 (检查点列表[i].验证损失 > 最差损) {
                最差损 = 检查点列表[i].验证损失
                最差idx = i
            }
            i = i + 1
        }
        检查点列表 = 切片(检查点列表, 0, 最差idx) +
                    切片(检查点列表, 最差idx + 1, 计数(检查点列表))
    }
    返回 计数(检查点列表)
}

函数 检查点_最佳() {
    如果 (计数(检查点列表) == 0) { 返回 空 }
    定义 可变 最佳idx = 0
    定义 可变 最佳损 = 检查点列表[0].验证损失
    定义 可变 i = 1
    当 (i < 计数(检查点列表)) {
        如果 (检查点列表[i].验证损失 < 最佳损) {
            最佳损 = 检查点列表[i].验证损失
            最佳idx = i
        }
        i = i + 1
    }
    返回 检查点列表[最佳idx]
}

// 完整训练统计报告

函数 TNF训练_完整统计() {
    如果 (全局训练统计 == 0) {
        返回 { 轮次: 0, 损失: 0, 样本: 0, 收敛: 假 }
    }
    定义 平均损失 = 0
    如果 (全局训练统计.训练轮次 > 0) {
        平均损失 = 全局训练统计.总损失 / 全局训练统计.训练轮次
    }
    定义 当前lr = 0
    如果 (全局调度器 != 0) { 当前lr = 学习率调度_获取lr() }
    返回 {
        轮次: 全局训练统计.训练轮次,
        样本: 全局训练统计.已处理样本,
        总损失: 全局训练统计.总损失,
        平均损失: 平均损失,
        最小损失: 全局训练统计.最小损失,
        最大损失: 全局训练统计.最大损失,
        验证损失: 全局训练统计.验证损失,
        验证准确率: 全局训练统计.验证准确率,
        收敛: 全局训练统计.已收敛,
        早停计数: 全局训练统计.早停计数器,
        层数: 计数(全局训练统计.层统计),
        当前学习率: 当前lr,
        吞吐量: 吞吐量EMA,
        轮次耗时: 轮次耗时EMA,
        NaN计数: 梯度_NaN计数,
        检查点数: 计数(检查点列表)
    }
}

// §11 【原生独创】谐振训练损失平滑器
// 使用指数加权移动平均平滑训练损失曲线

定义 可变 _谐振损失_平滑值 = 0
定义 可变 _谐振损失_样本数 = 0
定义 可变 _谐振损失_衰减 = 900

函数 谐振损失_更新(新损失) {
    如果 (_谐振损失_样本数 == 0) {
        _谐振损失_平滑值 = 新损失
    } 否则 {
        _谐振损失_平滑值 = _谐振损失_平滑值 * _谐振损失_衰减 / 1000 + 新损失 * (1000 - _谐振损失_衰减) / 1000
    }
    _谐振损失_样本数 = _谐振损失_样本数 + 1
}

函数 谐振损失_获取() { 返回 _谐振损失_平滑值 }

函数 训练统计_完整统计() {
    返回 [
        "谐振平滑损失", _谐振损失_平滑值,
        "谐振样本数", _谐振损失_样本数,
        "谐振衰减率", _谐振损失_衰减
    ]
}

函数 谐振损失_重置() {
    _谐振损失_平滑值 = 0
    _谐振损失_样本数 = 0
}

函数 谐振损失_趋势() {
    如果 (_谐振损失_样本数 < 2) { 返回 0 }
    返回 _谐振损失_平滑值
}

导入("../基础.nova")


// JSON生成器

函数 JSON_JSON_转义字符串(s) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(s)) {
        定义 码 = 字符码(s, i)
        如果 (码 == 字符_双引号) {
            结果 = 结果 + "\\\""
        } 否则 如果 (码 == 字符_反斜杠) {
            结果 = 结果 + "\\\\"
        } 否则 如果 (码 == 字符_换行) {
            结果 = 结果 + "\\n"
        } 否则 如果 (码 == 字符_制表) {
            结果 = 结果 + "\\t"
        } 否则 如果 (码 == 字符_回车) {
            结果 = 结果 + "\\r"
        } 否则 {
            结果 = (结果 + 子串(s, i, 1))
        }
        i = i + 1
    }
    返回 结果
}

函数 JSON_字符串(s) {
    返回 "\"" + JSON_JSON_转义字符串(s) + "\""
}

函数 JSON_数字(n) {
    返回 转字符串(n)
}

函数 JSON_布尔(b) {
    如果 (b) { 返回 "真" }
    返回 "假"
}

函数 JSON_空() { 返回 "空" }

// JSON对象构建器: [键列表, 值列表(已序列化)]
函数 JSON_对象开始() { 返回 [[], []] }

函数 JSON_对象字段_字符串(对象, 键, 值) {
    追加(对象[0], 键)
    追加(对象[1], JSON_字符串(值))
}

函数 JSON_对象字段_数字(对象, 键, 值) {
    追加(对象[0], 键)
    追加(对象[1], JSON_数字(值))
}

函数 JSON_对象字段_布尔(对象, 键, 值) {
    追加(对象[0], 键)
    追加(对象[1], JSON_布尔(值))
}

函数 JSON_对象字段_空(对象, 键) {
    追加(对象[0], 键)
    追加(对象[1], JSON_空())
}

函数 JSON_对象字段_原始(对象, 键, 已序列化值) {
    追加(对象[0], 键)
    追加(对象[1], 已序列化值)
}

函数 JSON_对象结束(对象) {
    定义 可变 结果 = "{"
    定义 可变 i = 0
    当 (i < 计数(对象[0])) {
        如果 (i != 0) { 结果 = 结果 + "," }
        结果 = (结果 + JSON_字符串(对象[0][i]))
        结果 = 结果 + ":"
        结果 = 结果 + 对象[1][i]
        i = i + 1
    }
    返回 结果 + "}"
}

// JSON数组构建器: [元素列表(已序列化)]
函数 JSON_数组开始() { 返回 [[]] }

函数 JSON_数组添加_字符串(数组, 值) {
    追加(数组[0], JSON_字符串(值))
}

函数 JSON_数组添加_数字(数组, 值) {
    追加(数组[0], JSON_数字(值))
}

函数 JSON_数组添加_原始(数组, 已序列化值) {
    追加(数组[0], 已序列化值)
}

函数 JSON_数组结束(数组) {
    定义 可变 结果 = "["
    定义 可变 i = 0
    当 (i < 计数(数组[0])) {
        如果 (i != 0) { 结果 = 结果 + "," }
        结果 = 结果 + 数组[0][i]
        i = i + 1
    }
    返回 结果 + "]"
}

// 简易JSON Tokenizer
// Token类型: 0=EOF, 1=字符串, 2=数字, 3={, 4=}, 5=[, 6=], 7=:, 8=, 0, 9=true, 10=false, 11=null

函数 是数字码(码) { 返回 码 >= 字符_零 且 码 <= 字符_九 }
函数 是空白_json(码) { 返回 码 == 字符_空格 或 码 == 字符_制表 或 码 == 字符_换行 或 码 == 字符_回车 }

// 简易JSON值解析 — 回 [类型, 值, 下一个位置]
// 类型: 0=字符串, 1=数字, 2=true, 3=false, 4=null, 5=对象(键值对列表), 6=数组
函数 JSON_跳过空白(文本, 位置) {
    定义 可变 位置 = 位置
    当 (位置 < 计数(文本) 且 是空白_json(字符码(文本, 位置))) { 位置 = 位置 + 1 }
    返回 位置
}

函数 JSON_解析字符串值(文本, 位置) {
    // 位置指向开引号后一位
    定义 可变 位置 = 位置
    定义 可变 结果 = ""
    当 (位置 < 计数(文本)) {
        定义 码 = 字符码(文本, 位置)
        如果 (码 == 字符_双引号) {
            返回 [0, 结果, 位置 + 1]
        }
        如果 (码 == 字符_反斜杠 且 位置 + 1 < 计数(文本)) {
            定义 下一码 = 字符码(文本, 位置 + 1)
            如果 (下一码 == 110) { 结果 = 结果 + "\n"  位置 = 位置 + 2 }
            否则 如果 (下一码 == 116) { 结果 = 结果 + "\t"  位置 = 位置 + 2 }
            否则 如果 (下一码 == 34) { 结果 = 结果 + "\""  位置 = 位置 + 2 }
            否则 如果 (下一码 == 92) { 结果 = 结果 + "\\"  位置 = 位置 + 2 }
            否则 { 结果 = (结果 + 子串(文本, 位置 + 1, 1))
            位置 = 位置 + 2 }
        } 否则 {
            结果 = (结果 + 子串(文本, 位置, 1))
            位置 = 位置 + 1
        }
    }
    返回 [0, 结果, 位置]
}

函数 JSON_解析数字值(文本, 位置) {
    定义 可变 位置 = 位置
    定义 可变 负 = 假
    如果 (位置 < 计数(文本) 且 字符码(文本, 位置) == 45) { 负 = 真
    位置 = 位置 + 1 }
    定义 可变 n = 0
    当 (位置 < 计数(文本) 且 是数字码(字符码(文本, 位置))) {
        n = n * 10 + (字符码(文本, 位置) - 48)
        位置 = 位置 + 1
    }
    如果 (负) { n = 0 - n }
    返回 [1, n, 位置]
}

// 整数列表序列化为JSON数组
函数 JSON_整数列表(列表) {
    定义 可变 结果 = "["
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (i != 0) { 结果 = 结果 + "," }
        结果 = (结果 + 转字符串(列表[i]))
        i = i + 1
    }
    返回 结果 + "]"
}

// JSON_布尔 已在上方定义

// 紧凑打印 vs 美化打印
函数 JSON_缩进(级别) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 级别) { 结果 = 结果 + "  "
        i = i + 1 }
    返回 结果
}

// JSON路径查询(简化)
函数 JSON_路径查询(对象, 路径键列表) {
    _JSON_序列化数 = _JSON_序列化数 + 1
    定义 可变 当前 = 对象
    定义 可变 i = 0
    当 (i < 计数(路径键列表)) {
        如果 (当前 == 空) { 返回 空 }
        当前 = JSON_取值(当前, 路径键列表[i])
        i = i + 1
    }
    返回 当前
}

函数 JSON_取值(对象, 键) {
    _JSON_序列化数 = _JSON_序列化数 + 1
    如果 (对象 == 空) { 返回 空 }
    // 自动检测格式：双数组 [[keys],[values]] vs 扁平 [k,v,k,v,...]
    如果 (计数(对象) == 2 且 是列表(对象[0]) 且 是列表(对象[1])) {
        // 双数组格式（JSON_对象开始/结束 产出的格式）
        定义 可变 i = 0
        当 (i < 计数(对象[0])) {
            如果 (对象[0][i] == 键) { 返回 对象[1][i] }
            i = i + 1
        }
        返回 空
    }
    // 扁平格式
    定义 可变 i = 0
    当 (i < 计数(对象) / 2) {
        如果 (对象[i * 2] == 键) { 返回 对象[i * 2 + 1] }
        i = i + 1
    }
    返回 空
}

// JSON合并
函数 JSON_合并(a, b) {
    _JSON_序列化数 = _JSON_序列化数 + 1
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(a)) { 追加(结果, a[i]) i = i + 1 }
    i = 0
    当 (i < 计数(b) / 2) {
        定义 键 = b[i * 2]
        定义 值 = b[i * 2 + 1]
        定义 可变 已有 = 假
        定义 可变 j = 0
        当 (j < 计数(结果) / 2) {
            如果 (结果[j * 2] == 键) { 结果[j * 2 + 1] = 值 已有 = 真 }
            j = j + 1
        }
        如果 (已有 == 假) { 追加(结果, 键) 追加(结果, 值) }
        i = i + 1
    }
    返回 结果
}

// JSON差异
函数 JSON_差异(a, b) {
    _JSON_序列化数 = _JSON_序列化数 + 1
    定义 可变 新增 = []
    定义 可变 修改 = []
    定义 可变 删除 = []
    定义 可变 i = 0
    当 (i < 计数(b) / 2) {
        定义 键 = b[i * 2]
        定义 b值 = b[i * 2 + 1]
        定义 a值 = JSON_取值(a, 键)
        如果 (a值 == 空) { 追加(新增, [键, b值]) }
        否则 如果 (a值 != b值) { 追加(修改, [键, a值, b值]) }
        i = i + 1
    }
    i = 0
    当 (i < 计数(a) / 2) {
        如果 (JSON_取值(b, a[i * 2]) == 空) { 追加(删除, a[i * 2]) }
        i = i + 1
    }
    返回 [新增, 修改, 删除]
}

// JSON转义
函数 JSON_转义字符串(文本) {
    _JSON_序列化数 = _JSON_序列化数 + 1
    定义 可变 结果 = "\""
    定义 可变 i = 0
    当 (i < 字节长度(文本)) {
        定义 c = 字节取(文本, i)
        如果 (c == 字符_双引号) { 结果 = 结果 + "\\\"" }
        否则 如果 (c == 字符_反斜杠) { 结果 = 结果 + "\\\\" }
        否则 如果 (c == 字符_换行) { 结果 = 结果 + "\\n" }
        否则 如果 (c == 字符_回车) { 结果 = 结果 + "\\r" }
        否则 如果 (c == 字符_制表) { 结果 = 结果 + "\\t" }
        否则 { 结果 = 结果 + 字符(c) }
        i = i + 1
    }
    返回 结果 + "\""
}

定义 可变 _JSON_序列化数 = 0
定义 可变 _JSON_解析数 = 0

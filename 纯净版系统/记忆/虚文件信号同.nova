// §1 文件对象字段索引

定义 F_Nova文件节点 = 0
定义 F_偏移 = 1
定义 F_标志 = 2
定义 F_引用 = 3
定义 F_操作 = 4
定义 F_目录项 = 5
定义 F_挂载点 = 6
定义 F_预读状态 = 7

定义 I_大小 = 0
定义 I_模式 = 1
定义 I_UID = 2
定义 I_GID = 3
定义 I_链接数 = 4
定义 I_操作 = 5
定义 I_块数 = 6
定义 I_时间 = 7
定义 I_地址空间 = 8
定义 I_脏标志 = 9
定义 I_设备号 = 10

定义 O_RDONLY = 0
定义 O_WRONLY = 1
定义 O_RDWR = 2
定义 O_CREAT = 0x40
定义 O_TRUNC = 0x200
定义 O_APPEND = 0x400
定义 O_NONBLOCK = 0x800
定义 O_SYNC = 0x101000
定义 O_DIRECT = 0x4000

定义 页大小 = 4096
定义 预读_最小窗口 = 4
定义 预读_最大窗口 = 128
定义 回写_间隔_毫秒 = 5000
定义 回写_脏页阈值 = 1024

// §2 全局统计

定义 可变 VFS_读次数 = 0
定义 可变 VFS_写次数 = 0
定义 可变 VFS_读字节 = 0
定义 可变 VFS_写字节 = 0
定义 可变 VFS_fsync次数 = 0
定义 可变 VFS_truncate次数 = 0
定义 可变 VFS_页缓存命中 = 0
定义 可变 VFS_页缓存未命中 = 0
定义 可变 VFS_预读触发 = 0
定义 可变 VFS_回写页数 = 0
定义 可变 VFS_直接IO次数 = 0

// §3 预读状态

结构 预读状态 {
    上次偏移,
    当前窗口,
    连续计数,
    是顺序,
    预取页数,
}

函数 预读状态_创建() {
    返回 预读状态 {
        上次偏移: 0,
        当前窗口: 预读_最小窗口,
        连续计数: 0,
        是顺序: 假,
        预取页数: 0,
    }
}

// §4 VFS read — 缓冲读

函数 vfs_read(文件, 用户缓冲, 大小) {
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    如果 (大小 <= 0) { 返回 0 }
    定义 节点 = 文件[F_Nova文件节点]
    如果 (节点 == 空) { 返回 错误_坏文件描述符 }

    定义 文件大小 = 节点[I_大小]
    定义 偏移 = 文件[F_偏移]
    如果 (偏移 >= 文件大小) { 返回 0 }

    // 限制读取范围
    定义 可变 实际大小 = 大小
    如果 (偏移 + 实际大小 > 文件大小) {
        实际大小 = 文件大小 - 偏移
    }

    // 直接I/O路径
    如果 (文件[F_标志] & O_DIRECT) {
        定义 结果 = vfs_直接读(文件, 用户缓冲, 实际大小, 偏移)
        VFS_直接IO次数 = VFS_直接IO次数 + 1
        返回 结果
    }

    // 页缓存路径
    定义 地址空间 = 节点[I_地址空间]
    定义 可变 已读 = 0
    当 (已读 < 实际大小) {
        定义 页索引 = (偏移 + 已读) / 页大小
        定义 页内偏移 = (偏移 + 已读) % 页大小
        定义 本次大小 = 页大小 - 页内偏移
        如果 (本次大小 > 实际大小 - 已读) { 本次大小 = 实际大小 - 已读 }

        // 查找页缓存
        定义 页 = 页缓存_查找(地址空间, 页索引)
        如果 (页 != 空) {
            VFS_页缓存命中 = VFS_页缓存命中 + 1
        } 否则 {
            VFS_页缓存未命中 = VFS_页缓存未命中 + 1
            页 = 页缓存_创建并读入(地址空间, 页索引, 节点)
            如果 (页 == 空) { 跳出 }

            // 自适应预读
            vfs_预读检测(文件, 偏移 + 已读, 地址空间, 节点)
        }

        // 复制到用户缓冲
        内存拷贝(用户缓冲 + 已读, 页 + 页内偏移, 本次大小)
        已读 = 已读 + 本次大小
    }

    文件[F_偏移] = 偏移 + 已读
    Nova文件节点_更新访问时间(节点)
    VFS_读次数 = VFS_读次数 + 1
    VFS_读字节 = VFS_读字节 + 已读
    返回 已读
}

// §5 VFS write — 缓冲写

函数 vfs_write(文件, 用户缓冲, 大小) {
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    如果 (大小 <= 0) { 返回 0 }
    定义 节点 = 文件[F_Nova文件节点]
    如果 (节点 == 空) { 返回 错误_坏文件描述符 }

    定义 可变 偏移 = 文件[F_偏移]
    // O_APPEND
    如果 (文件[F_标志] & O_APPEND) {
        偏移 = 节点[I_大小]
    }

    // 直接I/O
    如果 (文件[F_标志] & O_DIRECT) {
        定义 结果 = vfs_直接写(文件, 用户缓冲, 大小, 偏移)
        VFS_直接IO次数 = VFS_直接IO次数 + 1
        返回 结果
    }

    // 页缓存路径
    定义 地址空间 = 节点[I_地址空间]
    定义 可变 已写 = 0
    当 (已写 < 大小) {
        定义 页索引 = (偏移 + 已写) / 页大小
        定义 页内偏移 = (偏移 + 已写) % 页大小
        定义 本次大小 = 页大小 - 页内偏移
        如果 (本次大小 > 大小 - 已写) { 本次大小 = 大小 - 已写 }

        // 获取或创建页
        定义 可变 页 = 页缓存_查找(地址空间, 页索引)
        如果 (页 == 空) {
            页 = 页缓存_分配(地址空间, 页索引)
            如果 (页 == 空) { 跳出 }
            // 部分写需要先读取原始数据
            如果 (页内偏移 > 0 || 本次大小 < 页大小) {
                页缓存_读入(地址空间, 页索引, 节点, 页)
            }
        }

        // 复制用户数据到页
        内存拷贝(页 + 页内偏移, 用户缓冲 + 已写, 本次大小)

        // 标记脏页
        页缓存_标记脏(地址空间, 页索引)
        已写 = 已写 + 本次大小
    }

    // 更新文件大小
    如果 (偏移 + 已写 > 节点[I_大小]) {
        Nova文件节点_设置大小(节点, 偏移 + 已写)
    }

    文件[F_偏移] = 偏移 + 已写
    Nova文件节点_更新修改时间(节点)
    Nova文件节点_标记脏(节点)

    // O_SYNC: 同步写
    如果 (文件[F_标志] & O_SYNC) {
        vfs_fsync(文件)
    }

    VFS_写次数 = VFS_写次数 + 1
    VFS_写字节 = VFS_写字节 + 已写
    返回 已写
}

// §6 fsync/fdatasync

函数 vfs_fsync(文件) {
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    VFS_fsync次数 = VFS_fsync次数 + 1

    定义 操作 = 文件[F_操作]
    如果 (操作 != 空 && 操作.fsync != 空) {
        返回 操作.fsync(文件)
    }
    定义 节点 = 文件[F_Nova文件节点]
    如果 (节点 != 空 && 节点[I_地址空间] != 空) {
        页缓存_同步(节点[I_地址空间])
    }
    返回 成功
}

函数 vfs_fdatasync(文件) {
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    // fdatasync: 只同步数据，不同步元数据(除非大小改变)
    定义 节点 = 文件[F_Nova文件节点]
    如果 (节点 != 空 && 节点[I_地址空间] != 空) {
        页缓存_同步(节点[I_地址空间])
    }
    返回 成功
}

// §7 truncate

函数 vfs_truncate(文件, 新大小) {
    如果 (文件 == 空) { 返回 错误_坏文件描述符 }
    定义 节点 = 文件[F_Nova文件节点]
    如果 (节点 == 空) { 返回 错误_坏文件描述符 }
    VFS_truncate次数 = VFS_truncate次数 + 1

    定义 旧大小 = 节点[I_大小]
    Nova文件节点_设置大小(节点, 新大小)

    如果 (新大小 < 旧大小) {
        // 截断: 释放数据块+清理页缓存
        定义 操作 = 节点[I_操作]
        如果 (操作 != 空 && 操作.截断 != 空) {
            操作.截断(节点, 新大小)
        }
        如果 (节点[I_地址空间] != 空) {
            页缓存_截断(节点[I_地址空间], 新大小)
        }
    } 否则 如果 (新大小 > 旧大小) {
        // 扩展: 零填充(稀疏文件由ext4处理)
    }

    Nova文件节点_标记脏(节点)
    返回 成功
}

// §8 自适应预读

函数 vfs_预读检测(文件, 当前偏移, 地址空间, 节点) {
    如果 (文件[F_预读状态] == 空) {
        文件[F_预读状态] = 预读状态_创建()
    }
    定义 ra = 文件[F_预读状态]

    // 顺序检测: 当前偏移 == 上次偏移 + 页大小
    定义 期望偏移 = ra.上次偏移 + 页大小
    如果 (当前偏移 >= 期望偏移 - 页大小 && 当前偏移 <= 期望偏移 + 页大小) {
        ra.连续计数 = ra.连续计数 + 1
        ra.是顺序 = (ra.连续计数 > 2)
    } 否则 {
        ra.连续计数 = 0
        ra.是顺序 = 假
        ra.当前窗口 = 预读_最小窗口
    }
    ra.上次偏移 = 当前偏移

    // 顺序模式: 执行预读
    如果 (ra.是顺序) {
        VFS_预读触发 = VFS_预读触发 + 1
        定义 预读起始 = (当前偏移 / 页大小) + 1
        定义 可变 i = 0
        当 (i < ra.当前窗口) {
            定义 页索引 = 预读起始 + i
            如果 (页缓存_查找(地址空间, 页索引) == 空) {
                页缓存_创建并读入(地址空间, 页索引, 节点)
                ra.预取页数 = ra.预取页数 + 1
            }
            i = i + 1
        }

        // 自适应窗口增长
        ra.当前窗口 = ra.当前窗口 * 2
        如果 (ra.当前窗口 > 预读_最大窗口) {
            ra.当前窗口 = 预读_最大窗口
        }
    }
}

// §9 直接I/O

函数 vfs_直接读(文件, 缓冲, 大小, 偏移) {
    定义 节点 = 文件[F_Nova文件节点]
    定义 操作 = 节点[I_操作]
    如果 (操作 != 空 && 操作.直接读 != 空) {
        返回 操作.直接读(节点, 缓冲, 大小, 偏移)
    }
    返回 错误_不支持
}

函数 vfs_直接写(文件, 缓冲, 大小, 偏移) {
    定义 节点 = 文件[F_Nova文件节点]
    定义 操作 = 节点[I_操作]
    如果 (操作 != 空 && 操作.直接写 != 空) {
        返回 操作.直接写(节点, 缓冲, 大小, 偏移)
    }
    返回 错误_不支持
}

// §10 inode辅助函数

函数 Nova文件节点_设置大小(节点, 大小) {
    如果 (节点 != 空) { 设置(节点, I_大小, 大小) }
}

函数 Nova文件节点_标记脏(节点) {
    如果 (节点 != 空) { 设置(节点, I_脏标志, 1) }
}

函数 Nova文件节点_更新访问时间(节点) {
    设置(节点, I_时间, 当前时间_秒())
}

函数 Nova文件节点_更新修改时间(节点) {
    设置(节点, I_时间, 当前时间_秒())
}

函数 Nova文件节点_标记脏_读写(节点) {
    如果 (节点 != 空) { Nova文件节点_标记脏(节点) }
}

// §11 回写线程

定义 可变 回写_上次时间 = 0

函数 回写_检查() {
    定义 现在 = 读取毫秒()
    如果 (现在 - 回写_上次时间 < 回写_间隔_毫秒) { 返回 }
    回写_上次时间 = 现在
    回写_刷新全部()
}

函数 回写_刷新全部() {
    // 遍历所有脏inode，同步其页缓存
    定义 脏列表 = 获取脏inode列表()
    如果 (脏列表 == 空) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(脏列表)) {
        定义 节点 = 脏列表[i]
        如果 (节点[I_地址空间] != 空) {
            定义 刷新数 = 页缓存_同步(节点[I_地址空间])
            VFS_回写页数 = VFS_回写页数 + 刷新数
        }
        节点[I_脏标志] = 0
        i = i + 1
    }
}

// §12 文件工具函数

函数 文件_读取全部(路径) {
    定义 fd = sys_open(路径, 0, 0)
    如果 (fd < 0) { 返回 空 }
    定义 缓冲 = kmalloc(65536)
    定义 可变 总读取 = 0
    定义 可变 本次 = sys_read(fd, 缓冲 + 总读取, 65536 - 总读取)
    当 (本次 > 0) {
        总读取 = 总读取 + 本次
        如果 (总读取 >= 65536) { 跳出 }
        本次 = sys_read(fd, 缓冲 + 总读取, 65536 - 总读取)
    }
    sys_close(fd)
    返回 [缓冲, 总读取]
}

函数 文件_写入全部(路径, 数据, 大小) {
    定义 fd = sys_open(路径, O_WRONLY | O_CREAT | O_TRUNC, 0x1B6)
    如果 (fd < 0) { 返回 fd }
    定义 可变 已写 = 0
    当 (已写 < 大小) {
        定义 本次 = sys_write(fd, 数据 + 已写, 大小 - 已写)
        如果 (本次 <= 0) { 跳出 }
        已写 = 已写 + 本次
    }
    sys_close(fd)
    返回 已写
}

函数 文件_存在(路径) {
    定义 fd = sys_open(路径, O_RDONLY, 0)
    如果 (fd < 0) { 返回 假 }
    sys_close(fd)
    返回 真
}

函数 获取文件大小_路径(路径) {
    定义 fd = sys_open(路径, O_RDONLY, 0)
    如果 (fd < 0) { 返回 -1 }
    定义 大小 = sys_lseek(fd, 0, 2)
    sys_close(fd)
    返回 大小
}

函数 获取路径大小(路径) { 返回 获取文件大小_路径(路径) }
函数 获取文件权限(路径) { 返回 0x1B6 }

// §13 统计与诊断

函数 VFS_读写统计() {
    返回 {
        读次数: VFS_读次数,
        写次数: VFS_写次数,
        读字节: VFS_读字节,
        写字节: VFS_写字节,
        fsync: VFS_fsync次数,
        truncate: VFS_truncate次数,
        缓存命中: VFS_页缓存命中,
        缓存未命中: VFS_页缓存未命中,
        命中率: (VFS_页缓存命中 + VFS_页缓存未命中) > 0 && VFS_页缓存命中 * 100 / (VFS_页缓存命中 + VFS_页缓存未命中),
        预读触发: VFS_预读触发,
        回写页数: VFS_回写页数,
        直接IO: VFS_直接IO次数,
    }
}

函数 VFS读写_完整统计() {
    返回 VFS_读写统计()
}

函数 VFS_IO健康检查() {
    定义 可变 问题 = []
    定义 总请求 = VFS_页缓存命中 + VFS_页缓存未命中
    如果 (总请求 > 100 && VFS_页缓存命中 * 100 / 总请求 < 50) {
        追加(问题, "页缓存命中率过低: " + 整数转字符串(VFS_页缓存命中 * 100 / 总请求) + "%")
    }
    如果 (VFS_回写页数 == 0 && VFS_写次数 > 1000) {
        追加(问题, "回写未工作: 大量写操作但无回写")
    }
    如果 (计数(问题) == 0) { 返回 "VFS I/O健康" }
    返回 问题
}

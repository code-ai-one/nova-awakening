定义 PNG状态_初始 = 0
定义 PNG状态_头部已解析 = 1
定义 PNG状态_解码中 = 2
定义 PNG状态_完成 = 3
定义 PNG状态_错误 = 4

定义 PNG签名 = [0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A]

定义 CHUNK_IHDR = 0x49484452
定义 CHUNK_PLTE = 0x504C5445
定义 CHUNK_IDAT = 0x49444154
定义 CHUNK_IEND = 0x49454E44
定义 CHUNK_tRNS = 0x74524E53
定义 CHUNK_gAMA = 0x67414D41
定义 CHUNK_cHRM = 0x6348524D
定义 CHUNK_sRGB = 0x73524742
定义 CHUNK_tEXt = 0x74455874
定义 CHUNK_iTXt = 0x69545874
定义 CHUNK_pHYs = 0x70485973
定义 CHUNK_tIME = 0x74494D45
定义 CHUNK_bKGD = 0x624B4744
定义 CHUNK_iCCP = 0x69434350

结构 PNG解码器 {
    宽, 高,
    位深, 颜色类型,
    压缩方法, 滤波方法, 隔行方法,
    行字节, 像素字节,
    调色板, 调色板大小,
    透明度, 透明度大小,
    伽马值,
    sRGB渲染意图,
    像素缓冲, 像素大小,
    上一行缓冲,
    状态, 错误码,
    元数据,
    物理_X分辨率, 物理_Y分辨率, 物理_单位,
    背景色,
}

定义 可变 PNG统计_解码次数 = 0
定义 可变 PNG统计_总字节 = 0
定义 可变 PNG统计_错误次数 = 0


函数 PNG解码器_创建() {
    定义 dec = 堆_分配(PNG解码器)
    dec.宽 = 0
    dec.高 = 0
    dec.位深 = 8
    dec.颜色类型 = 0
    dec.调色板 = 0
    dec.调色板大小 = 0
    dec.透明度 = 0
    dec.透明度大小 = 0
    dec.伽马值 = 0
    dec.sRGB渲染意图 = -1
    dec.像素缓冲 = 0
    dec.上一行缓冲 = 0
    dec.状态 = PNG状态_初始
    dec.错误码 = 0
    dec.元数据 = 字典()
    dec.物理_X分辨率 = 0
    dec.物理_Y分辨率 = 0
    dec.物理_单位 = 0
    dec.背景色 = 0
    返回 dec
}

函数 PNG_验证签名(数据) {
    定义 可变 i = 0
    当 (i < 8) {
        如果 (内存_读8(数据 + i) != PNG签名[i]) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 PNG解码器_解析IHDR(dec, 数据, 偏移, 数据长度) {
    如果 (偏移 + 13 > 数据长度) { dec.状态 = PNG状态_错误; dec.错误码 = 3; 返回 }
    dec.宽 = 读32大端(数据 + 偏移)
    dec.高 = 读32大端(数据 + 偏移 + 4)
    dec.位深 = 内存_读8(数据 + 偏移 + 8)
    dec.颜色类型 = 内存_读8(数据 + 偏移 + 9)
    dec.压缩方法 = 内存_读8(数据 + 偏移 + 10)
    dec.滤波方法 = 内存_读8(数据 + 偏移 + 11)
    dec.隔行方法 = 内存_读8(数据 + 偏移 + 12)

    如果 (dec.宽 == 0 || dec.高 == 0) {
        dec.状态 = PNG状态_错误
        dec.错误码 = 1
        返回
    }
    如果 (dec.宽 > 65535 || dec.高 > 65535) {
        dec.状态 = PNG状态_错误
        dec.错误码 = 2
        返回
    }

    选择 (dec.颜色类型) {
        0: { dec.像素字节 = 1 }
        2: { dec.像素字节 = 3 }
        3: { dec.像素字节 = 1 }
        4: { dec.像素字节 = 2 }
        6: { dec.像素字节 = 4 }
        默认: { dec.状态 = PNG状态_错误; dec.错误码 = 3; 返回 }
    }

    dec.行字节 = dec.宽 * dec.像素字节 * dec.位深 / 8
    dec.像素大小 = dec.宽 * dec.高 * 4
    dec.像素缓冲 = 堆_分配_数组(dec.像素大小)
    dec.上一行缓冲 = 堆_分配_数组(dec.行字节)
    内存_清零(dec.上一行缓冲, dec.行字节)
    dec.状态 = PNG状态_头部已解析
}

函数 PNG解码(数据, 数据大小) {
    PNG统计_解码次数 = PNG统计_解码次数 + 1
    PNG统计_总字节 = PNG统计_总字节 + 数据大小

    如果 (!PNG_验证签名(数据)) {
        PNG统计_错误次数 = PNG统计_错误次数 + 1
        返回 0
    }

    定义 dec = PNG解码器_创建()
    定义 可变 偏移 = 8

    定义 IDAT缓冲 = 堆_分配_数组(数据大小)
    定义 可变 IDAT大小 = 0

    当 (偏移 + 8 <= 数据大小) {
        定义 chunk长 = 读32大端(数据 + 偏移)
        定义 chunk类型 = 读32大端(数据 + 偏移 + 4)
        定义 chunk数据 = 偏移 + 8

        如果 (chunk数据 + chunk长 > 数据大小) {
            dec.状态 = PNG状态_错误
            dec.错误码 = 10
            堆_释放(IDAT缓冲)
            PNG统计_错误次数 = PNG统计_错误次数 + 1
            返回 dec
        }

        如果 (chunk类型 == CHUNK_IHDR) {
            PNG解码器_解析IHDR(dec, 数据, chunk数据, 数据大小)
            如果 (dec.状态 == PNG状态_错误) {
                堆_释放(IDAT缓冲)
                PNG统计_错误次数 = PNG统计_错误次数 + 1
                返回 dec
            }
        }
        否则 如果 (chunk类型 == CHUNK_PLTE) {
            dec.调色板 = 堆_分配_数组(chunk长)
            内存_复制(dec.调色板, 数据 + chunk数据, chunk长)
            dec.调色板大小 = chunk长 / 3
        }
        否则 如果 (chunk类型 == CHUNK_tRNS) {
            dec.透明度 = 堆_分配_数组(chunk长)
            内存_复制(dec.透明度, 数据 + chunk数据, chunk长)
            dec.透明度大小 = chunk长
        }
        否则 如果 (chunk类型 == CHUNK_gAMA) {
            dec.伽马值 = 读32大端(数据 + chunk数据)
        }
        否则 如果 (chunk类型 == CHUNK_sRGB) {
            dec.sRGB渲染意图 = 内存_读8(数据 + chunk数据)
        }
        否则 如果 (chunk类型 == CHUNK_pHYs) {
            dec.物理_X分辨率 = 读32大端(数据 + chunk数据)
            dec.物理_Y分辨率 = 读32大端(数据 + chunk数据 + 4)
            dec.物理_单位 = 内存_读8(数据 + chunk数据 + 8)
        }
        否则 如果 (chunk类型 == CHUNK_tEXt) {
            PNG_解析tEXt(dec, 数据 + chunk数据, chunk长)
        }
        否则 如果 (chunk类型 == CHUNK_bKGD) {
            PNG_解析bKGD(dec, 数据 + chunk数据, chunk长)
        }
        否则 如果 (chunk类型 == CHUNK_IDAT) {
            内存_复制(IDAT缓冲 + IDAT大小, 数据 + chunk数据, chunk长)
            IDAT大小 = IDAT大小 + chunk长
        }
        否则 如果 (chunk类型 == CHUNK_IEND) {
            跳出
        }

        偏移 = chunk数据 + chunk长 + 4
    }

    如果 (dec.状态 != PNG状态_头部已解析) {
        堆_释放(IDAT缓冲)
        dec.状态 = PNG状态_错误
        dec.错误码 = 11
        PNG统计_错误次数 = PNG统计_错误次数 + 1
        返回 dec
    }

    dec.状态 = PNG状态_解码中

    定义 解压大小 = (dec.行字节 + 1) * dec.高
    定义 解压缓冲 = 堆_分配_数组(解压大小)
    定义 z = Zlib_创建()
    定义 解压结果 = Zlib_解压(z, IDAT缓冲, IDAT大小, 解压缓冲, 解压大小)

    如果 (解压结果 < 0) {
        堆_释放(IDAT缓冲)
        堆_释放(解压缓冲)
        dec.状态 = PNG状态_错误
        dec.错误码 = 20
        PNG统计_错误次数 = PNG统计_错误次数 + 1
        返回 dec
    }

    如果 (dec.隔行方法 == 1) {
        PNG_解码_隔行(dec, 解压缓冲, 解压大小)
    } 否则 {
        PNG_解码_逐行(dec, 解压缓冲)
    }

    如果 (dec.伽马值 > 0 && dec.sRGB渲染意图 < 0) {
        PNG_应用伽马校正(dec)
    }

    如果 (dec.透明度 != 0) {
        PNG_应用透明度(dec)
    }

    dec.状态 = PNG状态_完成
    堆_释放(IDAT缓冲)
    堆_释放(解压缓冲)
    返回 dec
}

函数 PNG_解码_逐行(dec, 解压缓冲) {
    内存_清零(dec.上一行缓冲, dec.行字节)
    定义 可变 行 = 0
    当 (行 < dec.高) {
        定义 行偏移 = 解压缓冲 + 行 * (dec.行字节 + 1)
        定义 滤波类型 = 内存_读8(行偏移)
        定义 行像素 = 行偏移 + 1

        如果 (滤波类型 > 4) {
            dec.错误码 = 30
            返回
        }

        PNG_逆滤波行(dec, 滤波类型, 行像素, dec.上一行缓冲)
        PNG_行转RGBA(dec, 行, 行像素)
        内存_复制(dec.上一行缓冲, 行像素, dec.行字节)
        行 = 行 + 1
    }
}

定义 Adam7_起始列 = [0, 4, 0, 2, 0, 1, 0]
定义 Adam7_起始行 = [0, 0, 4, 0, 2, 0, 1]
定义 Adam7_列增量 = [8, 8, 4, 4, 2, 2, 1]
定义 Adam7_行增量 = [8, 8, 8, 4, 4, 2, 2]

函数 PNG_解码_隔行(dec, 解压缓冲, 缓冲大小) {
    定义 可变 偏移 = 0
    定义 可变 pass = 0
    当 (pass < 7) {
        定义 起始x = Adam7_起始列[pass]
        定义 起始y = Adam7_起始行[pass]
        定义 增x = Adam7_列增量[pass]
        定义 增y = Adam7_行增量[pass]

        定义 pass宽 = (dec.宽 - 起始x + 增x - 1) / 增x
        定义 pass高 = (dec.高 - 起始y + 增y - 1) / 增y

        如果 (pass宽 <= 0 || pass高 <= 0) { pass = pass + 1; 继续 }

        定义 pass行字节 = pass宽 * dec.像素字节 * dec.位深 / 8
        定义 pass上一行 = 堆_分配_数组(pass行字节)
        内存_清零(pass上一行, pass行字节)

        定义 可变 y = 0
        当 (y < pass高) {
            如果 (偏移 >= 缓冲大小) { 跳出 }
            定义 滤波 = 内存_读8(解压缓冲 + 偏移)
            偏移 = 偏移 + 1
            定义 行数据 = 解压缓冲 + 偏移

            PNG_逆滤波行_自定义(dec, 滤波, 行数据, pass上一行, pass行字节, dec.像素字节)

            定义 目标y = 起始y + y * 增y
            定义 可变 x = 0
            当 (x < pass宽) {
                定义 目标x = 起始x + x * 增x
                PNG_写像素_从行(dec, 目标x, 目标y, 行数据, x)
                x = x + 1
            }

            内存_复制(pass上一行, 行数据, pass行字节)
            偏移 = 偏移 + pass行字节
            y = y + 1
        }
        堆_释放(pass上一行)
        pass = pass + 1
    }
}

函数 PNG_逆滤波行_自定义(dec, 滤波类型, 行数据, 上一行, 行字节, bpp) {
    定义 可变 i = 0
    选择 (滤波类型) {
        0: {}
        1: {
            i = bpp
            当 (i < 行字节) {
                内存_写8(行数据 + i, (内存_读8(行数据 + i) + 内存_读8(行数据 + i - bpp)) & 0xFF)
                i = i + 1
            }
        }
        2: {
            当 (i < 行字节) {
                内存_写8(行数据 + i, (内存_读8(行数据 + i) + 内存_读8(上一行 + i)) & 0xFF)
                i = i + 1
            }
        }
        3: {
            当 (i < 行字节) {
                定义 a = 0
                如果 (i >= bpp) { a = 内存_读8(行数据 + i - bpp) }
                定义 b = 内存_读8(上一行 + i)
                内存_写8(行数据 + i, (内存_读8(行数据 + i) + (a + b) / 2) & 0xFF)
                i = i + 1
            }
        }
        4: {
            当 (i < 行字节) {
                定义 a = 0
                定义 b = 内存_读8(上一行 + i)
                定义 c = 0
                如果 (i >= bpp) {
                    a = 内存_读8(行数据 + i - bpp)
                    c = 内存_读8(上一行 + i - bpp)
                }
                内存_写8(行数据 + i, (内存_读8(行数据 + i) + PNG_Paeth(a, b, c)) & 0xFF)
                i = i + 1
            }
        }
        _: {}
    }
}

函数 PNG_Paeth(a, b, c) {
    定义 p = a + b - c
    定义 pa = p - a
    如果 (pa < 0) { pa = 0 - pa }
    定义 pb = p - b
    如果 (pb < 0) { pb = 0 - pb }
    定义 pc = p - c
    如果 (pc < 0) { pc = 0 - pc }
    如果 (pa <= pb && pa <= pc) { 返回 a }
    如果 (pb <= pc) { 返回 b }
    返回 c
}

函数 PNG_写像素_从行(dec, 目标x, 目标y, 行数据, 源x) {
    如果 (目标x >= dec.宽 || 目标y >= dec.高) { 返回 }
    定义 dst = dec.像素缓冲 + (目标y * dec.宽 + 目标x) * 4
    定义 src偏移 = 源x * dec.像素字节
    选择 (dec.颜色类型) {
        0: {
            定义 灰 = 内存_读8(行数据 + src偏移)
            内存_写8(dst, 灰); 内存_写8(dst + 1, 灰); 内存_写8(dst + 2, 灰); 内存_写8(dst + 3, 255)
        }
        2: {
            内存_写8(dst, 内存_读8(行数据 + src偏移))
            内存_写8(dst + 1, 内存_读8(行数据 + src偏移 + 1))
            内存_写8(dst + 2, 内存_读8(行数据 + src偏移 + 2))
            内存_写8(dst + 3, 255)
        }
        3: {
            定义 索引 = 内存_读8(行数据 + src偏移)
            如果 (dec.调色板 != 0 && 索引 < dec.调色板大小) {
                内存_写8(dst, 内存_读8(dec.调色板 + 索引 * 3))
                内存_写8(dst + 1, 内存_读8(dec.调色板 + 索引 * 3 + 1))
                内存_写8(dst + 2, 内存_读8(dec.调色板 + 索引 * 3 + 2))
                内存_写8(dst + 3, 255)
            }
        }
        4: {
            定义 灰 = 内存_读8(行数据 + src偏移)
            内存_写8(dst, 灰); 内存_写8(dst + 1, 灰); 内存_写8(dst + 2, 灰)
            内存_写8(dst + 3, 内存_读8(行数据 + src偏移 + 1))
        }
        6: {
            内存_写8(dst, 内存_读8(行数据 + src偏移))
            内存_写8(dst + 1, 内存_读8(行数据 + src偏移 + 1))
            内存_写8(dst + 2, 内存_读8(行数据 + src偏移 + 2))
            内存_写8(dst + 3, 内存_读8(行数据 + src偏移 + 3))
        }
    }
}

函数 PNG_应用伽马校正(dec) {
    如果 (dec.伽马值 == 0 || dec.像素缓冲 == 0) { 返回 }
    定义 伽马 = 100000.0 / dec.伽马值
    定义 可变 i = 0
    当 (i < dec.像素大小) {
        如果 ((i & 3) != 3) {
            定义 v = 内存_读8(dec.像素缓冲 + i)
            定义 校正 = PNG_伽马表(v, 伽马)
            内存_写8(dec.像素缓冲 + i, 校正)
        }
        i = i + 1
    }
}

函数 PNG_伽马表(值, 伽马) {
    如果 (值 == 0) { 返回 0 }
    如果 (值 == 255) { 返回 255 }
    定义 归一 = 值 / 255.0
    定义 校正 = 整数(幂(归一, 伽马) * 255.0 + 0.5)
    如果 (校正 > 255) { 返回 255 }
    如果 (校正 < 0) { 返回 0 }
    返回 校正
}

函数 PNG_应用透明度(dec) {
    如果 (dec.透明度 == 0) { 返回 }
    如果 (dec.颜色类型 == 3) {
        定义 可变 y = 0
        当 (y < dec.高) {
            定义 可变 x = 0
            当 (x < dec.宽) {
                定义 idx = (y * dec.宽 + x) * 4 + 3
                定义 像素索引 = 内存_读8(dec.像素缓冲 + (y * dec.宽 + x) * 4)
                // 注意: 此处需要通过调色板索引查表, 简化处理
                如果 (像素索引 < dec.透明度大小) {
                    内存_写8(dec.像素缓冲 + idx, 内存_读8(dec.透明度 + 像素索引))
                }
                x = x + 1
            }
            y = y + 1
        }
    }
}

函数 PNG_解析tEXt(dec, 数据, 长度) {
    如果 (dec.元数据 == 0) { 返回 }
    定义 可变 关键字结束 = 0
    当 (关键字结束 < 长度 && 内存_读8(数据 + 关键字结束) != 0) {
        关键字结束 = 关键字结束 + 1
    }
    如果 (关键字结束 >= 长度) { 返回 }
    定义 关键字 = 字符串_从内存(数据, 关键字结束)
    定义 值 = 字符串_从内存(数据 + 关键字结束 + 1, 长度 - 关键字结束 - 1)
    字典设(dec.元数据, 关键字, 值)
}

函数 PNG_解析bKGD(dec, 数据, 长度) {
    如果 (dec.颜色类型 == 3 && 长度 >= 1) {
        dec.背景色 = 内存_读8(数据)
    } 否则 如果 ((dec.颜色类型 == 0 || dec.颜色类型 == 4) && 长度 >= 2) {
        dec.背景色 = 读16大端(数据)
    } 否则 如果 ((dec.颜色类型 == 2 || dec.颜色类型 == 6) && 长度 >= 6) {
        dec.背景色 = (读16大端(数据) << 16) | (读16大端(数据 + 2) << 8) | 读16大端(数据 + 4)
    }
}

函数 PNG解码器_释放(dec) {
    如果 (dec == 0) { 返回 }
    如果 (dec.像素缓冲 != 0) { 堆_释放(dec.像素缓冲) }
    如果 (dec.上一行缓冲 != 0) { 堆_释放(dec.上一行缓冲) }
    如果 (dec.调色板 != 0) { 堆_释放(dec.调色板) }
    如果 (dec.透明度 != 0) { 堆_释放(dec.透明度) }
    堆_释放(dec)
}

函数 读32大端(ptr) {
    返回 (内存_读8(ptr) << 24) | (内存_读8(ptr+1) << 16) | (内存_读8(ptr+2) << 8) | 内存_读8(ptr+3)
}

函数 读16大端(ptr) {
    返回 (内存_读8(ptr) << 8) | 内存_读8(ptr+1)
}

函数 PNG_统计() {
    返回 { 解码次数: PNG统计_解码次数, 总字节: PNG统计_总字节, 错误次数: PNG统计_错误次数 }
}

// NIPD — Nova Image Pipeline Decode Theory
// 公理1(格式完备): PNG/JPEG/BMP/GIF四格式全支持
// 公理2(流式可复用): 解码器可重置复用, 无内存泄漏

函数 PNG_打印统计() {
    定义 s = PNG_统计()
    打印行("=== PNG解码统计 ===")
    打印行("解码次数: " + 整数转字符串(s.解码次数))
    打印行("总字节: " + 整数转字符串(s.总字节))
    打印行("错误次数: " + 整数转字符串(s.错误次数))
}

函数 PNG_重置统计() {
    PNG统计_解码次数 = 0
    PNG统计_总字节 = 0
    PNG统计_错误次数 = 0
}

定义 可变 AI图片_解码缓存 = 0

函数 AI图片_渐进解码建议(文件大小, 网络带宽) {
    AI图片_解码缓存 = AI图片_解码缓存 + 1
    如果 (文件大小 > 1048576 && 网络带宽 < 100000) { 返回 "渐进式" }
    返回 "一次性"
}

函数 AI图片_缩放策略(原始宽, 原始高, 显示宽, 显示高) {
    如果 (原始宽 > 显示宽 * 4) { 返回 "降采样后解码" }
    返回 "全分辨率解码"
}

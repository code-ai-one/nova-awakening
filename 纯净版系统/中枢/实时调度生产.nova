// NovaOS 实时调度器 (RT Scheduler)
// 功能: SCHED_FIFO 和 SCHED_RR 实时调度
//   - SCHED_FIFO: 先进先出，无时间片，运行到阻塞或让出
//   - SCHED_RR: 轮转，有时间片，时间片用完轮转到队尾
//   - 优先级: 0-99，数字越大优先级越高
//   - 抢占: 高优先级立即抢占低优先级
//   - 带宽控制: 防止RT任务饿死普通任务
// 特性:
//   - 确定性延迟
//   - 优先级继承 (防止优先级反转)
//   - CPU亲和性
//   - AI辅助实时负载预测与优先级自适应

导入("./类型定义.nova")
导入("./同步原语.nova")
导入("../执行/内核智能.nova")
导入("./时钟中枢.nova")
导入("./进程描述符.nova")

// RT调度常量

定义 RT_优先级数量 = 100         // 0-99
定义 RT_最高优先级 = 99
定义 RT_最低优先级 = 0
定义 RT_默认时间片 = 100000      // 100ms (SCHED_RR)
定义 RT_带宽周期 = 1000000       // 1s
定义 RT_默认带宽 = 950000        // 950ms (95%)

// RT运行队列 (每个优先级一个FIFO队列)

定义 可变 RT_队列 = []           // 100个优先级队列
定义 可变 RT_优先级位图 = 0      // 位图标记哪些优先级有任务
定义 可变 RT_任务数 = 0
定义 可变 RT_调度次数 = 0

// RT带宽控制
定义 可变 RT_带宽配额 = RT_默认带宽
定义 可变 RT_带宽周期 = RT_带宽周期
定义 可变 RT_剩余配额 = RT_默认带宽
定义 可变 RT_周期开始 = 0
定义 可变 RT_节流次数 = 0
定义 可变 RT_是否节流 = 假

// 初始化

函数 RT_初始化() {
    RT_队列 = []
    定义 可变 i = 0
    当 (i < RT_优先级数量) {
        追加(RT_队列, [])
        i = i + 1
    }
    
    RT_优先级位图 = 0
    RT_任务数 = 0
    RT_调度次数 = 0
    
    RT_带宽配额 = RT_默认带宽
    RT_剩余配额 = RT_默认带宽
    RT_周期开始 = 0
    RT_节流次数 = 0
    RT_是否节流 = 假
}

// 位图操作 (快速查找最高优先级)

函数 RT_设置位(优先级) {
    定义 位 = 1 << 优先级
    RT_优先级位图 = RT_优先级位图 | 位
}

函数 RT_清除位(优先级) {
    定义 位 = 1 << 优先级
    RT_优先级位图 = RT_优先级位图 & (~位)
}

函数 RT_测试位(优先级) {
    定义 位 = 1 << 优先级
    返回 (RT_优先级位图 & 位) != 0
}

函数 RT_查找最高优先级() {
    如果 (RT_优先级位图 == 0) { 返回 0 - 1 }
    
    // 从高到低查找第一个置位的位
    定义 可变 优先级 = RT_最高优先级
    当 (优先级 >= 0) {
        如果 (RT_测试位(优先级)) {
            返回 优先级
        }
        优先级 = 优先级 - 1
    }
    
    返回 0 - 1
}

// 入队/出队

函数 RT_入队(任务) {
    定义 优先级 = 任务[T_rt优先级]
    如果 (优先级 < 0 || 优先级 >= RT_优先级数量) {
        返回 假
    }
    
    // 添加到对应优先级队列
    定义 队列 = RT_队列[优先级]
    追加(队列, 任务)
    
    // 设置位图
    RT_设置位(优先级)
    
    RT_任务数 = RT_任务数 + 1
    
    // 设置时间片 (SCHED_RR)
    如果 (任务[T_调度策略] == 调度_RR) {
        如果 (任务[T_时间片] == 0) {
            设置(任务, T_时间片, RT_默认时间片)
        }
    }
    
    返回 真
}

函数 RT_出队(任务) {
    定义 优先级 = 任务[T_rt优先级]
    如果 (优先级 < 0 || 优先级 >= RT_优先级数量) {
        返回 假
    }
    
    // 从队列移除
    定义 队列 = RT_队列[优先级]
    定义 新队列 = []
    定义 可变 找到 = 假
    
    定义 可变 i = 0
    当 (i < 计数(队列)) {
        如果 (队列[i] != 任务) {
            追加(新队列, 队列[i])
        } 否则 {
            找到 = 真
        }
        i = i + 1
    }
    
    如果 (!找到) { 返回 假 }
    
    RT_队列[优先级] = 新队列
    
    // 如果队列空了，清除位图
    如果 (计数(新队列) == 0) {
        RT_清除位(优先级)
    }
    
    RT_任务数 = RT_任务数 - 1
    
    返回 真
}

// 选择下一个任务 

函数 RT_选择下一个() {
    如果 (RT_任务数 == 0) { 返回 空 }
    如果 (RT_是否节流) { 返回 空 }
    
    // 查找最高优先级
    定义 优先级 = RT_查找最高优先级()
    如果 (优先级 < 0) { 返回 空 }
    
    // 获取队列头部任务
    定义 队列 = RT_队列[优先级]
    如果 (计数(队列) == 0) { 返回 空 }
    
    定义 任务 = 队列[0]
    
    // 从队列移除
    定义 新队列 = []
    定义 可变 i = 1
    当 (i < 计数(队列)) {
        追加(新队列, 队列[i])
        i = i + 1
    }
    RT_队列[优先级] = 新队列
    
    // 如果队列空了，清除位图
    如果 (计数(新队列) == 0) {
        RT_清除位(优先级)
    }
    
    RT_任务数 = RT_任务数 - 1
    RT_调度次数 = RT_调度次数 + 1
    
    进程_设置状态(任务, 进程_运行)
    
    返回 任务
}

// tick处理

函数 RT_tick(当前任务, delta_us) {
    如果 (当前任务 == 空) { 返回 假 }
    
    // 更新带宽
    如果 (!RT_更新带宽(delta_us)) {
        返回 真  // 配额耗尽，需要调度
    }
    
    // SCHED_FIFO: 不检查时间片
    如果 (当前任务[T_调度策略] == 调度_FIFO) {
        返回 假
    }
    
    // SCHED_RR: 检查时间片
    如果 (当前任务[T_调度策略] == 调度_RR) {
        定义 已用 = 当前任务[T_已用时间片]
        定义 时间片 = 当前任务[T_时间片]
        
        设置(当前任务, T_已用时间片, 已用 + delta_us)
        
        如果 (已用 + delta_us >= 时间片) {
            // 时间片用完，重新入队
            设置(当前任务, T_已用时间片, 0)
            返回 真
        }
    }
    
    返回 假
}

// 带宽控制 

函数 RT_更新带宽(delta_us) {
    定义 当前时间 = 获取当前时间()
    
    // 初始化周期
    如果 (RT_周期开始 == 0) {
        RT_周期开始 = 当前时间
        RT_剩余配额 = RT_带宽配额
        返回 真
    }
    
    // 检查是否进入新周期
    定义 经过时间 = 当前时间 - RT_周期开始
    如果 (经过时间 >= RT_带宽周期) {
        RT_周期开始 = 当前时间
        RT_剩余配额 = RT_带宽配额
        RT_是否节流 = 假
        返回 真
    }
    
    // 消耗配额
    RT_剩余配额 = RT_剩余配额 - delta_us
    
    // 检查配额
    如果 (RT_剩余配额 <= 0) {
        RT_是否节流 = 真
        RT_节流次数 = RT_节流次数 + 1
        返回 假
    }
    
    返回 真
}

函数 RT_设置带宽(配额, 周期) {
    如果 (配额 < 0 || 周期 <= 0) { 返回 假 }
    如果 (配额 > 周期) { 返回 假 }
    
    RT_带宽配额 = 配额
    RT_带宽周期 = 周期
    返回 真
}

// 抢占检查 

函数 RT_检查抢占(当前任务, 新任务) {
    如果 (当前任务 == 空 || 新任务 == 空) { 返回 假 }
    
    // 比较优先级
    定义 当前优先级 = 当前任务[T_rt优先级]
    定义 新优先级 = 新任务[T_rt优先级]
    
    // 新任务优先级更高，抢占
    返回 新优先级 > 当前优先级
}

// 优先级继承 (防止优先级反转)

函数 RT_提升优先级(任务, 新优先级) {
    定义 旧优先级 = 任务[T_rt优先级]
    如果 (新优先级 <= 旧优先级) { 返回 }
    
    // 从旧队列移除
    RT_出队(任务)
    
    // 设置新优先级
    设置(任务, T_rt优先级, 新优先级)
    
    // 重新入队
    RT_入队(任务)
}

函数 RT_恢复优先级(任务, 原优先级) {
    定义 当前优先级 = 任务[T_rt优先级]
    如果 (原优先级 >= 当前优先级) { 返回 }
    
    // 从当前队列移除
    RT_出队(任务)
    
    // 恢复原优先级
    设置(任务, T_rt优先级, 原优先级)
    
    // 重新入队
    RT_入队(任务)
}

// 统计信息

函数 RT_统计() {
    返回 [
        RT_任务数,
        RT_调度次数,
        RT_节流次数,
        RT_是否节流,
        RT_剩余配额,
        RT_查找最高优先级()
    ]
}

函数 RT_重置统计() {
    RT_调度次数 = 0
    RT_节流次数 = 0
}

// 辅助函数

函数 RT_是否为空() {
    返回 RT_任务数 == 0
}

函数 RT_获取任务数() {
    返回 RT_任务数
}

函数 获取当前时间() {
    定义 低 = 0
    定义 高 = 0
    汇编 { "rdtsc" "mov [rsp-16], eax" "mov [rsp-8], edx" }
    返回 低 + 高 * 0x100000000
}

// EDF调度 (Earliest Deadline First)
// 最早截止日期优先算法

定义 可变 EDF_就绪队列 = []   // [任务, 截止时间]
定义 可变 EDF_任务数 = 0
定义 可变 EDF_超时次数 = 0

函数 EDF_初始化() {
    EDF_就绪队列 = []
    EDF_任务数 = 0
    EDF_超时次数 = 0
}

函数 EDF_入队(任务, 截止时间) {
    // 插入排序位置 (截止时间升序)
    定义 可变 插入位 = 计数(EDF_就绪队列)
    定义 可变 i = 0
    当 (i < 计数(EDF_就绪队列)) {
        如果 (截止时间 < EDF_就绪队列[i][1]) {
            插入位 = i
            跳出
        }
        i = i + 1
    }
    // 在插入位置插入
    定义 可变 新队列 = []
    i = 0
    当 (i < 插入位) { 追加(新队列, EDF_就绪队列[i]); i = i + 1 }
    追加(新队列, [任务, 截止时间])
    当 (i < 计数(EDF_就绪队列)) { 追加(新队列, EDF_就绪队列[i]); i = i + 1 }
    EDF_就绪队列 = 新队列
    EDF_任务数 = EDF_任务数 + 1
}

函数 EDF_选择下一个() {
    如果 (计数(EDF_就绪队列) == 0) { 返回 空 }
    定义 条目 = EDF_就绪队列[0]
    // 移除队头
    定义 可变 新队列 = []
    定义 可变 i = 1
    当 (i < 计数(EDF_就绪队列)) { 追加(新队列, EDF_就绪队列[i]); i = i + 1 }
    EDF_就绪队列 = 新队列
    EDF_任务数 = EDF_任务数 - 1
    返回 条目[0]
}

函数 EDF_检查超时(当前时间) {
    定义 可变 超时数 = 0
    定义 可变 i = 0
    当 (i < 计数(EDF_就绪队列)) {
        如果 (EDF_就绪队列[i][1] < 当前时间) {
            超时数 = 超时数 + 1
        }
        i = i + 1
    }
    EDF_超时次数 = EDF_超时次数 + 超时数
    返回 超时数
}

// 优先级继承链追踪

定义 可变 _继承链 = []  // [持有者任务, 原始优先级, 提升优先级, 等待者任务]

函数 RT_继承链_添加(持有者, 等待者) {
    定义 持有优先级 = 持有者[T_rt优先级]
    定义 等待优先级 = 等待者[T_rt优先级]
    如果 (等待优先级 > 持有优先级) {
        RT_提升优先级(持有者, 等待优先级)
        追加(_继承链, [持有者, 持有优先级, 等待优先级, 等待者])
    }
}

函数 RT_继承链_移除(持有者) {
    定义 可变 新链 = []
    定义 可变 最高继承 = 0
    定义 可变 原始优先级 = 持有者[T_rt优先级]
    定义 可变 i = 0
    当 (i < 计数(_继承链)) {
        如果 (_继承链[i][0] == 持有者) {
            原始优先级 = _继承链[i][1]
        } 否则 {
            追加(新链, _继承链[i])
        }
        i = i + 1
    }
    _继承链 = 新链
    RT_恢复优先级(持有者, 原始优先级)
}

函数 RT_继承链_深度() {
    返回 计数(_继承链)
}

// 【原生独创】谐振负载预测器
// 基于EMA平滑与谐振周期检测, 预测未来负载并自动调整带宽配额
// 结构: [负载EMA, 负载方差, 采样数, 周期缓冲, 缓冲指针, 谐振幅度]

定义 _谐振缓冲大小 = 16

函数 谐振负载预测器_创建() {
    定义 可变 缓冲 = []
    定义 可变 i = 0
    当 (i < _谐振缓冲大小) { 追加(缓冲, 0); i = i + 1 }
    返回 [0, 0, 0, 缓冲, 0, 0]
}

函数 谐振负载预测器_采样(预测器, 负载值) {
    // EMA平滑: α=200/1000=0.2
    预测器[0] = (预测器[0] * 800 + 负载值 * 200) / 1000
    // 方差更新
    定义 diff = 负载值 - 预测器[0]
    如果 (diff < 0) { diff = 0 - diff }
    预测器[1] = (预测器[1] * 800 + diff * diff / 1000 * 200) / 1000
    // 周期缓冲
    定义 idx = 预测器[4] % _谐振缓冲大小
    设置(预测器[3], idx, 负载值)
    预测器[4] = 预测器[4] + 1
    预测器[2] = 预测器[2] + 1
    // 谐振幅度检测
    如果 (预测器[2] >= _谐振缓冲大小) {
        _谐振_更新幅度(预测器)
    }
}

函数 _谐振_更新幅度(预测器) {
    定义 可变 最大 = 预测器[3][0]
    定义 可变 最小 = 预测器[3][0]
    定义 可变 i = 1
    当 (i < _谐振缓冲大小) {
        如果 (预测器[3][i] > 最大) { 最大 = 预测器[3][i] }
        如果 (预测器[3][i] < 最小) { 最小 = 预测器[3][i] }
        i = i + 1
    }
    预测器[5] = 最大 - 最小
}

函数 谐振负载预测器_预测(预测器) {
    // 基于EMA趋势预测: EMA + 谐振幅度/4 (保守估计)
    返回 预测器[0] + 预测器[5] / 4
}

函数 谐振负载预测器_建议带宽(预测器) {
    定义 预测负载 = 谐振负载预测器_预测(预测器)
    // 负载高: 增加带宽; 负载低: 减少带宽以保护CFS任务
    如果 (预测负载 > 800) { 返回 980000 }  // 98%
    如果 (预测负载 > 500) { 返回 950000 }  // 95%
    如果 (预测负载 > 200) { 返回 900000 }  // 90%
    返回 800000  // 80%
}

函数 谐振负载预测器_统计(预测器) {
    返回 [
        "平均负载", 预测器[0],
        "方差", 预测器[1],
        "采样数", 预测器[2],
        "谐振幅度", 预测器[5]
    ]
}

// CPU亲和性管理

定义 可变 _亲和性表 = []  // [任务, CPU掩码]

函数 RT_设置亲和性(任务, CPU掩码) {
    // 移除旧记录
    定义 可变 新表 = []
    定义 可变 i = 0
    当 (i < 计数(_亲和性表)) {
        如果 (_亲和性表[i][0] != 任务) {
            追加(新表, _亲和性表[i])
        }
        i = i + 1
    }
    追加(新表, [任务, CPU掩码])
    _亲和性表 = 新表
}

函数 RT_获取亲和性(任务) {
    定义 可变 i = 0
    当 (i < 计数(_亲和性表)) {
        如果 (_亲和性表[i][0] == 任务) {
            返回 _亲和性表[i][1]
        }
        i = i + 1
    }
    返回 -1  // 无限制
}

函数 RT_可在CPU运行(任务, CPU编号) {
    定义 掩码 = RT_获取亲和性(任务)
    如果 (掩码 == -1) { 返回 真 }
    返回 (掩码 >> CPU编号 & 1) == 1
}

// 截止日期容忍窗口 (Deadline Miss Handler)

定义 可变 _截止未命中总数 = 0
函数 RT_截止未命中处理(任务, 截止时间, 当前时间) {
    定义 超时量 = 当前时间 - 截止时间
    _截止未命中总数 = _截止未命中总数 + 1
    // 如果超时严重 (>2x时间片), 降低优先级以避免饾死
    如果 (超时量 > RT_默认时间片 * 2) {
        定义 新优先级 = 任务[T_rt优先级] - 1
        如果 (新优先级 >= RT_最低优先级) {
            RT_恢复优先级(任务, 新优先级)
        }
        返回 2  // 严重超时
    }
    返回 1  // 轻微超时
}

函数 RT_截止未命中统计() {
    返回 _截止未命中总数
}

// 任务让出与迁移

函数 RT_主动让出(当前任务) {
    如果 (当前任务 == 空) { 返回 }
    定义 优先级 = 当前任务[T_rt优先级]
    // RR: 重置时间片并放到队尾
    如果 (当前任务[T_调度策略] == 调度_RR) {
        设置(当前任务, T_已用时间片, 0)
    }
    RT_入队(当前任务)
}

函数 RT_优先级分布() {
    定义 可变 分布 = []
    定义 可变 p = 0
    当 (p < RT_优先级数量) {
        如果 (RT_测试位(p)) {
            追加(分布, [p, 计数(RT_队列[p])])
        }
        p = p + 1
    }
    返回 分布
}

函数 RT_最高优先级任务数() {
    定义 p = RT_查找最高优先级()
    如果 (p < 0) { 返回 0 }
    返回 计数(RT_队列[p])
}

// 完整统计
函数 实时调度_生产级_完整统计() {
    返回 [
        "RT优先级范围", RT_优先级数量,
        "FIFO调度", 1,
        "RR轮转调度", 1,
        "EDF截止日期调度", 1,
        "带宽控制", 1,
        "优先级继承链", 1,
        "RT任务数", RT_任务数,
        "RT调度次数", RT_调度次数,
        "节流次数", RT_节流次数,
        "EDF超时次数", EDF_超时次数,
        "继承链深度", RT_继承链_深度(),
        "原生独创_谐振负载预测", 1
    ]
}

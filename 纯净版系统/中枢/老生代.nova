导入("../中枢/系统调用表.nova")
导入("../推理/智能渠道.nova")
导入("../感知/内核直连层.nova")
导入("./字符串替换.nova")
导入("./内存初始化.nova")
导入("./创建甲.nova")

定义 标记_白 = 0
定义 标记_灰 = 1
定义 标记_黑 = 2
定义 对象头字节 = 16
定义 热度窗口 = 16
定义 空闲桶数 = 32
定义 压缩阈值 = 65

结构 回收堆 {
    老生代起始,
    老生代指针,
    老生代上限,
    运行时,
    灰队头,
    灰队尾,
    空闲桶,
    回收次数,
    总暂停,
    上次时间,
    碎片率,
    神经权重,
}

结构 灰节点 {
    地址,
    热度,
    后继,
}

函数 回收_标记清除压缩(堆) {
    定义 起始 = 平台_获取高精度时间()
    回收_重置颜色(堆)
    回收_根集入队(堆)
    回收_神经标记(堆)
    定义 回收量 = 回收_清除(堆)
    如果 (堆.碎片率 > 压缩阈值) {
        回收_压缩(堆)
    }
    回收_更新空闲桶(堆)
    堆.回收次数 = 堆.回收次数 + 1
    堆.总暂停 = 堆.总暂停 + (平台_获取高精度时间() - 起始)
    堆.上次时间 = 平台_获取高精度时间()
    回收_神经反馈(堆, 回收量)
    返回 回收量
}

函数 回收_重置颜色(堆) {
    定义 可变 游标 = 堆.老生代起始
    当 (游标 < 堆.老生代指针) {
        定义 块大小 = 内存_读32(游标 + 10)
        如果 (块大小 == 0) { 跳出 }
        内存_写8(游标 + 8, 标记_白)
        游标 = 游标 + 块大小
    }
}

函数 回收_根集入队(堆) {
    定义 运行时 = 堆.运行时
    如果 (运行时 == 0) { 返回 }
    如果 (运行时.全局对象 != 0) { 回收_染灰入队(堆, 运行时.全局对象) }
    如果 (运行时.当前上下文 != 0) { 回收_染灰入队(堆, 运行时.当前上下文) }
    定义 可变 帧 = 运行时.当前帧
    当 (帧 != 0) {
        定义 可变 寄存索引 = 0
        当 (寄存索引 < 帧.寄存器数) {
            定义 值 = 内存_读64(帧.寄存器 + 寄存索引 * 8)
            如果 (值 > 4096 && (值 & 1) == 1) { 回收_染灰入队(堆, 值) }
            寄存索引 = 寄存索引 + 1
        }
        帧 = 帧.父帧
    }
}

函数 回收_染灰入队(堆, 地址) {
    如果 (内存_读8(地址 + 8) != 标记_白) { 返回 }
    内存_写8(地址 + 8, 标记_灰)
    定义 节点 = 堆_分配(灰节点)
    如果 (节点 == 0) { 返回 }
    节点.地址 = 地址
    节点.热度 = 回收_计算热度(地址)
    节点.后继 = 0
    如果 (堆.灰队尾 == 0) {
        堆.灰队头 = 节点
        堆.灰队尾 = 节点
    } 否则 {
        内存_写64(堆.灰队尾 + 16, 节点)
        堆.灰队尾 = 节点
    }
}

函数 回收_计算热度(地址) {
    定义 访问 = 内存_读16(地址 + 6)
    定义 深度 = 内存_读8(地址 + 9)
    定义 类型 = 内存_读8(地址 + 4)
    定义 类型系数 = 100
    如果 (类型 >= 5) { 类型系数 = 240 }
    如果 (类型 == 3) { 类型系数 = 180 }
    返回 访问 * 6 + (255 - 深度) * 3 + 类型系数
}

函数 回收_神经标记(堆) {
    当 (堆.灰队头 != 0) {
        定义 选中 = 回收_热度弹出(堆)
        如果 (选中 == 0) { 跳出 }
        定义 大小 = 内存_读32(选中 + 10)
        如果 (大小 == 0) { 继续 }
        定义 可变 偏移 = 对象头字节
        当 (偏移 < 大小) {
            定义 子 = 内存_读64(选中 + 偏移)
            如果 (子 != 0 && 子 > 4096) {
                如果 (内存_读8(子 + 8) == 标记_白) {
                    回收_染灰入队(堆, 子)
                }
            }
            偏移 = 偏移 + 8
        }
        内存_写8(选中 + 8, 标记_黑)
        内存_写16(选中 + 6, 内存_读16(选中 + 6) + 1)
    }
}

函数 回收_热度弹出(堆) {
    如果 (堆.灰队头 == 0) { 返回 0 }
    定义 可变 最优 = 堆.灰队头
    定义 可变 最优前 = 0
    定义 可变 最优热 = 最优.热度
    定义 可变 当前 = 最优.后继
    定义 可变 前驱 = 最优
    定义 可变 步数 = 1
    当 (当前 != 0 && 步数 < 热度窗口) {
        如果 (当前.热度 > 最优热) {
            最优热 = 当前.热度
            最优 = 当前
            最优前 = 前驱
        }
        前驱 = 当前
        当前 = 当前.后继
        步数 = 步数 + 1
    }
    如果 (最优前 == 0) {
        堆.灰队头 = 最优.后继
    } 否则 {
        内存_写64(最优前 + 16, 最优.后继)
    }
    如果 (最优 == 堆.灰队尾) { 堆.灰队尾 = 最优前 }
    定义 结果 = 最优.地址
    堆_释放(最优)
    返回 结果
}

函数 回收_清除(堆) {
    定义 可变 游标 = 堆.老生代起始
    定义 可变 回收量 = 0
    定义 可变 活跃量 = 0
    定义 可变 碎片段 = 0
    当 (游标 < 堆.老生代指针) {
        定义 块大小 = 内存_读32(游标 + 10)
        如果 (块大小 == 0) { 跳出 }
        如果 (内存_读8(游标 + 8) == 标记_白) {
            回收量 = 回收量 + 块大小
            碎片段 = 碎片段 + 1
            定义 桶号 = 回收_大小到桶(块大小)
            定义 桶头 = 内存_读64(堆.空闲桶 + 桶号 * 8)
            内存_写64(游标, 0)
            内存_写32(游标 + 10, 块大小)
            内存_写64(游标 + 14, 桶头)
            内存_写64(堆.空闲桶 + 桶号 * 8, 游标)
        } 否则 {
            活跃量 = 活跃量 + 块大小
            内存_写8(游标 + 8, 标记_白)
        }
        游标 = 游标 + 块大小
    }
    如果 (活跃量 + 回收量 > 0) {
        堆.碎片率 = 碎片段 * 100 / ((活跃量 + 回收量) / 64 + 1)
    }
    返回 回收量
}

函数 回收_大小到桶(大小) {
    如果 (大小 <= 64) { 返回 大小 / 8 }
    如果 (大小 <= 512) { 返回 8 + (大小 - 64) / 64 }
    如果 (大小 <= 4096) { 返回 15 + (大小 - 512) / 256 }
    返回 空闲桶数 - 1
}

函数 回收_空闲分配(堆, 需要大小) {
    定义 桶号 = 回收_大小到桶(需要大小)
    定义 可变 搜索桶 = 桶号
    当 (搜索桶 < 空闲桶数) {
        定义 候选 = 内存_读64(堆.空闲桶 + 搜索桶 * 8)
        如果 (候选 != 0) {
            定义 候选大小 = 内存_读32(候选 + 10)
            如果 (候选大小 >= 需要大小) {
                内存_写64(堆.空闲桶 + 搜索桶 * 8, 内存_读64(候选 + 14))
                如果 (候选大小 - 需要大小 >= 32) {
                    定义 剩余 = 候选 + 需要大小
                    内存_写32(剩余 + 10, 候选大小 - 需要大小)
                    定义 剩余桶 = 回收_大小到桶(候选大小 - 需要大小)
                    内存_写64(剩余 + 14, 内存_读64(堆.空闲桶 + 剩余桶 * 8))
                    内存_写64(堆.空闲桶 + 剩余桶 * 8, 剩余)
                    内存_写32(候选 + 10, 需要大小)
                }
                返回 候选
            }
        }
        搜索桶 = 搜索桶 + 1
    }
    返回 0
}

函数 回收_压缩(堆) {
    定义 可变 读游标 = 堆.老生代起始
    定义 可变 写游标 = 堆.老生代起始
    当 (读游标 < 堆.老生代指针) {
        定义 块大小 = 内存_读32(读游标 + 10)
        如果 (块大小 == 0) { 跳出 }
        如果 (内存_读64(读游标) != 0) {
            如果 (写游标 != 读游标) {
                内存_复制(写游标, 读游标, 块大小)
                回收_更新引用(堆, 读游标, 写游标)
            }
            写游标 = 写游标 + 块大小
        }
        读游标 = 读游标 + 块大小
    }
    堆.老生代指针 = 写游标
    堆.碎片率 = 0
    定义 可变 桶清 = 0
    当 (桶清 < 空闲桶数) {
        内存_写64(堆.空闲桶 + 桶清 * 8, 0)
        桶清 = 桶清 + 1
    }
}

函数 回收_更新引用(堆, 旧地址, 新地址) {
    定义 可变 游标 = 堆.老生代起始
    当 (游标 < 堆.老生代指针) {
        定义 块大小 = 内存_读32(游标 + 10)
        如果 (块大小 == 0) { 跳出 }
        如果 (内存_读64(游标) != 0) {
            定义 可变 偏移 = 对象头字节
            当 (偏移 < 块大小) {
                如果 (内存_读64(游标 + 偏移) == 旧地址) {
                    内存_写64(游标 + 偏移, 新地址)
                }
                偏移 = 偏移 + 8
            }
        }
        游标 = 游标 + 块大小
    }
}

函数 回收_更新空闲桶(堆) {
    定义 总空闲 = 0
    定义 可变 桶索引 = 0
    当 (桶索引 < 空闲桶数) {
        定义 可变 节点 = 内存_读64(堆.空闲桶 + 桶索引 * 8)
        当 (节点 != 0) {
            总空闲 = 总空闲 + 内存_读32(节点 + 10)
            节点 = 内存_读64(节点 + 14)
        }
        桶索引 = 桶索引 + 1
    }
}

函数 回收_神经反馈(堆, 回收量) {
    定义 总空间 = 堆.老生代指针 - 堆.老生代起始
    如果 (总空间 == 0) { 返回 }
    定义 回收率 = 回收量 * 1024 / 总空间
    如果 (回收率 > 800) {
        堆.神经权重 = 堆.神经权重 * 90 / 100
    } 否则 如果 (回收率 < 100) {
        堆.神经权重 = 堆.神经权重 * 110 / 100
        如果 (堆.神经权重 > 2048) { 堆.神经权重 = 2048 }
    }
    // AI反馈: 记录历史回收率用于趋势分析
    回收_AI记录历史(堆, 回收率)
}

// §8 回收堆创建与销毁

函数 回收堆_创建(运行时, 起始地址, 大小) {
    如果 (大小 == 0) {
        打印("[MSC] 错误: 堆大小为0")
        返回 空
    }

    定义 可变 堆 = 堆_分配(回收堆)
    如果 (堆 == 0) {
        打印("[MSC] 错误: 回收堆分配失败")
        返回 空
    }

    堆.老生代起始 = 起始地址
    堆.老生代指针 = 起始地址
    堆.老生代上限 = 起始地址 + 大小
    堆.运行时 = 运行时
    堆.灰队头 = 0
    堆.灰队尾 = 0

    // 初始化空闲桶
    堆.空闲桶 = 平台_申请内存(空闲桶数 * 8)
    如果 (堆.空闲桶 != 0) {
        定义 可变 i = 0
        当 (i < 空闲桶数) {
            内存_写64(堆.空闲桶 + i * 8, 0)
            i = i + 1
        }
    }

    堆.回收次数 = 0
    堆.总暂停 = 0
    堆.上次时间 = 0
    堆.碎片率 = 0
    堆.神经权重 = 1024

    打印("[MSC] 回收堆初始化完成")
    打印(字符串拼接("  老生代大小: ", 转字符串(大小)))
    返回 堆
}

函数 回收堆_销毁(堆) {
    如果 (堆 == 空) { 返回 }
    // 清空灰色队列
    回收_清空灰队(堆)
    // 释放空闲桶
    如果 (堆.空闲桶 != 0) {
        平台_释放内存(堆.空闲桶, 空闲桶数 * 8)
    }
    打印("[MSC] 回收堆已销毁")
    堆_释放(堆)
}

函数 回收_清空灰队(堆) {
    定义 可变 节点 = 堆.灰队头
    当 (节点 != 0) {
        定义 下一个 = 节点.后继
        堆_释放(节点)
        节点 = 下一个
    }
    堆.灰队头 = 0
    堆.灰队尾 = 0
}

// §9 老生代对象分配(从空闲桶分配)

函数 回收_老生代分配(堆, 大小) {
    如果 (堆 == 空 || 大小 == 0) { 返回 0 }

    // 8字节对齐
    定义 对齐大小 = (大小 + 对象头字节 + 7) & (~7)

    // 优先从空闲桶分配(减少碎片)
    定义 结果 = 回收_空闲分配(堆, 对齐大小)
    如果 (结果 != 0) {
        // 初始化对象头
        内存_写8(结果 + 8, 标记_白)
        内存_写8(结果 + 9, 0)
        内存_写32(结果 + 10, 对齐大小)
        返回 结果
    }

    // 空闲桶无合适块 → bump pointer分配
    如果 (堆.老生代指针 + 对齐大小 <= 堆.老生代上限) {
        结果 = 堆.老生代指针
        堆.老生代指针 = 堆.老生代指针 + 对齐大小
        内存_写8(结果 + 8, 标记_白)
        内存_写8(结果 + 9, 0)
        内存_写32(结果 + 10, 对齐大小)
        返回 结果
    }

    // 空间不足 → 触发GC后重试
    打印("[MSC] 老生代空间不足, 触发GC")
    回收_标记清除压缩(堆)

    // GC后重试
    结果 = 回收_空闲分配(堆, 对齐大小)
    如果 (结果 != 0) {
        内存_写8(结果 + 8, 标记_白)
        内存_写8(结果 + 9, 0)
        内存_写32(结果 + 10, 对齐大小)
        返回 结果
    }

    如果 (堆.老生代指针 + 对齐大小 <= 堆.老生代上限) {
        结果 = 堆.老生代指针
        堆.老生代指针 = 堆.老生代指针 + 对齐大小
        内存_写8(结果 + 8, 标记_白)
        内存_写8(结果 + 9, 0)
        内存_写32(结果 + 10, 对齐大小)
        返回 结果
    }

    打印("[MSC] 致命错误: 老生代内存耗尽")
    返回 0
}

// §10 AI智能回收策略 — 热度引导的标记优先级
// 传统V8: FIFO灰色队列(先进先出)
// NovaOS:  基于热度的优先级灰色队列
//   热度 = 访问频率×6 + (255-深度)×3 + 类型系数
//   热对象优先标记 → 减少标记阶段的缓存未命中

定义 可变 AI_回收历史 = []
定义 可变 AI_历史游标 = 0
定义 AI_历史窗口 = 32

函数 回收_AI记录历史(堆, 回收率) {
    如果 (AI_历史游标 < AI_历史窗口) {
        追加(AI_回收历史, 回收率)
        AI_历史游标 = AI_历史游标 + 1
    } 否则 {
        定义 位置 = AI_历史游标 % AI_历史窗口
        设置(AI_回收历史, 位置, 回收率)
        AI_历史游标 = AI_历史游标 + 1
    }
}

函数 回收_AI预测回收率() {
    如果 (AI_历史游标 == 0) { 返回 500 }
    // 指数移动平均
    定义 可变 总和 = 0
    定义 可变 权重和 = 0
    定义 可变 i = 0
    定义 数量 = AI_历史游标
    如果 (数量 > AI_历史窗口) { 数量 = AI_历史窗口 }
    当 (i < 数量) {
        定义 值 = AI_回收历史[i]
        定义 权重 = i + 1
        总和 = 总和 + 值 * 权重
        权重和 = 权重和 + 权重
        i = i + 1
    }
    如果 (权重和 > 0) { 返回 总和 / 权重和 }
    返回 500
}

函数 回收_AI应该压缩(堆) {
    // AI决策: 是否应该执行压缩(代价高但消除碎片)
    如果 (堆.碎片率 > 压缩阈值) { 返回 真 }

    // 预测: 如果历史回收率持续低, 说明碎片严重
    定义 预测率 = 回收_AI预测回收率()
    如果 (预测率 < 100 && 堆.碎片率 > 30) {
        // 回收率低+有碎片 → 建议压缩
        返回 真
    }

    // 神经权重低 → 说明历史上回收效果好, 不需要压缩
    如果 (堆.神经权重 < 512) { 返回 假 }

    返回 假
}

// §11 堆完整性检查(调试用)

函数 回收_验证堆完整性(堆) {
    如果 (堆 == 空) { 返回 假 }
    定义 可变 游标 = 堆.老生代起始
    定义 可变 对象数 = 0
    定义 可变 总字节 = 0
    定义 可变 错误数 = 0

    当 (游标 < 堆.老生代指针) {
        定义 块大小 = 内存_读32(游标 + 10)
        如果 (块大小 == 0) {
            打印("[MSC] 验证错误: 块大小为0")
            错误数 = 错误数 + 1
            跳出
        }
        如果 (块大小 > 1048576) {
            打印("[MSC] 验证错误: 块大小异常大")
            错误数 = 错误数 + 1
            跳出
        }
        // 检查对齐
        如果 ((块大小 & 7) != 0) {
            打印("[MSC] 验证警告: 块大小未8字节对齐")
        }
        // 检查标记颜色有效性
        定义 颜色 = 内存_读8(游标 + 8)
        如果 (颜色 > 2) {
            打印("[MSC] 验证错误: 无效标记颜色")
            错误数 = 错误数 + 1
        }
        对象数 = 对象数 + 1
        总字节 = 总字节 + 块大小
        游标 = 游标 + 块大小
    }

    打印("[MSC] ── 堆完整性检查 ──")
    打印(字符串拼接("  对象数: ", 转字符串(对象数)))
    打印(字符串拼接("  总字节: ", 转字符串(总字节)))
    打印(字符串拼接("  错误数: ", 转字符串(错误数)))
    返回 错误数 == 0
}

// §12 统计与调试

函数 回收_打印统计(堆) {
    如果 (堆 == 空) { 返回 }
    打印("[MSC] ═══════════ Mark-Sweep-Compact 统计 ═══════════")
    打印(字符串拼接("  回收次数:     ", 转字符串(堆.回收次数)))
    打印(字符串拼接("  总暂停(μs):   ", 转字符串(堆.总暂停)))
    如果 (堆.回收次数 > 0) {
        定义 平均 = 堆.总暂停 / 堆.回收次数
        打印(字符串拼接("  平均暂停(μs): ", 转字符串(平均)))
    }
    打印(字符串拼接("  碎片率(%):    ", 转字符串(堆.碎片率)))
    打印(字符串拼接("  神经权重:     ", 转字符串(堆.神经权重)))
    定义 总空间 = 堆.老生代上限 - 堆.老生代起始
    定义 已用 = 堆.老生代指针 - 堆.老生代起始
    打印(字符串拼接("  老生代总容量: ", 转字符串(总空间)))
    打印(字符串拼接("  老生代已用:   ", 转字符串(已用)))
    如果 (总空间 > 0) {
        定义 使用率 = 已用 * 100 / 总空间
        打印(字符串拼接("  使用率(%):    ", 转字符串(使用率)))
    }
    // 空闲桶统计
    定义 可变 空闲总量 = 0
    定义 可变 空闲块数 = 0
    如果 (堆.空闲桶 != 0) {
        定义 可变 桶 = 0
        当 (桶 < 空闲桶数) {
            定义 可变 节点 = 内存_读64(堆.空闲桶 + 桶 * 8)
            当 (节点 != 0) {
                空闲总量 = 空闲总量 + 内存_读32(节点 + 10)
                空闲块数 = 空闲块数 + 1
                节点 = 内存_读64(节点 + 14)
            }
            桶 = 桶 + 1
        }
    }
    打印(字符串拼接("  空闲块数:     ", 转字符串(空闲块数)))
    打印(字符串拼接("  空闲总量:     ", 转字符串(空闲总量)))
    打印("[MSC] ── AI预测 ──")
    定义 预测率 = 回收_AI预测回收率()
    打印(字符串拼接("  预测回收率‰:  ", 转字符串(预测率)))
    打印(字符串拼接("  历史数据点数: ", 转字符串(AI_历史游标)))
    打印("[MSC] ═══════════════════════════════════════════════")
}

函数 回收_打印空闲桶(堆) {
    如果 (堆 == 空 || 堆.空闲桶 == 0) { 返回 }
    打印("[MSC] ── 空闲桶分布 ──")
    定义 可变 桶 = 0
    当 (桶 < 空闲桶数) {
        定义 可变 节点 = 内存_读64(堆.空闲桶 + 桶 * 8)
        定义 可变 计数 = 0
        定义 可变 字节 = 0
        当 (节点 != 0) {
            计数 = 计数 + 1
            字节 = 字节 + 内存_读32(节点 + 10)
            节点 = 内存_读64(节点 + 14)
        }
        如果 (计数 > 0) {
            打印(字符串拼接("  桶[", 字符串拼接(转字符串(桶), 字符串拼接("]: 块数=", 字符串拼接(转字符串(计数), 字符串拼接(" 字节=", 转字符串(字节)))))))
        }
        桶 = 桶 + 1
    }
}

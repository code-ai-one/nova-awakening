导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/哈希整数.nova")
导入("./内核直连层.nova")
导入("../中枢/创建甲.nova")

定义 最大动画 = 128
定义 最大关键帧 = 32
定义 缓动_线性 = 0
定义 缓动_缓入 = 1
定义 缓动_缓出 = 2
定义 缓动_缓入出 = 3
定义 方向_正 = 0
定义 方向_反 = 1
定义 方向_交替 = 2
定义 填充_无 = 0
定义 填充_前 = 1
定义 填充_后 = 2
定义 填充_双 = 3
定义 状态_空闲 = 0
定义 状态_运行 = 1
定义 状态_暂停 = 2
定义 状态_完成 = 3
定义 基数 = 1024

结构 关键帧 {
    百分比,
    属性标识,
    起始值,
    结束值,
    缓动,
}

结构 动画实例 {
    名称哈希,
    元素标识,
    状态,
    时长,
    延迟,
    重复次数,
    当前重复,
    方向,
    填充模式,
    关键帧表,
    关键帧数,
    起始时刻,
    当前进度,
    暂停偏移,
}

定义 可变 动画表 = []
定义 可变 动画数 = 0
定义 可变 总启动 = 0
定义 可变 总完成 = 0
定义 可变 总帧更新 = 0


函数 动画_创建(名称, 元素, 时长, 延迟, 重复, 方向, 填充) {
    如果 (动画数 >= 最大动画) { 返回 -1 }
    定义 动画 = 动画实例 {}
    动画.名称哈希 = 哈希_字符串(名称)
    动画.元素标识 = 元素
    动画.状态 = 状态_空闲
    动画.时长 = 时长
    动画.延迟 = 延迟
    动画.重复次数 = 重复
    动画.当前重复 = 0
    动画.方向 = 方向
    动画.填充模式 = 填充
    动画.关键帧表 = 堆_分配(最大关键帧 * 24)
    动画.关键帧数 = 0
    动画.起始时刻 = 0
    动画.当前进度 = 0
    动画.暂停偏移 = 0
    追加(动画表, 动画)
    定义 索引 = 动画数
    动画数 = 动画数 + 1
    返回 索引
}

函数 动画_添加帧(动画索引, 百分比, 属性, 起始, 结束, 缓动) {
    如果 (动画索引 >= 动画数) { 返回 }
    定义 动画 = 动画表[动画索引]
    如果 (动画.关键帧数 >= 最大关键帧) { 返回 }
    定义 偏移 = 动画.关键帧表 + 动画.关键帧数 * 24
    内存_写32(偏移, 百分比)
    内存_写32(偏移 + 4, 属性)
    内存_写64(偏移 + 8, 起始)
    内存_写64(偏移 + 16, 结束)
    动画.关键帧数 = 动画.关键帧数 + 1
}

函数 动画_启动(动画索引) {
    如果 (动画索引 >= 动画数) { 返回 }
    动画表[动画索引].状态 = 状态_运行
    动画表[动画索引].起始时刻 = 平台_获取高精度时间() + 动画表[动画索引].延迟
    动画表[动画索引].当前重复 = 0
    动画表[动画索引].当前进度 = 0
    总启动 = 总启动 + 1
}

函数 动画_暂停(动画索引) {
    如果 (动画索引 >= 动画数) { 返回 }
    如果 (动画表[动画索引].状态 == 状态_运行) {
        动画表[动画索引].状态 = 状态_暂停
        动画表[动画索引].暂停偏移 = 平台_获取高精度时间() - 动画表[动画索引].起始时刻
    }
}

函数 动画_恢复(动画索引) {
    如果 (动画索引 >= 动画数) { 返回 }
    如果 (动画表[动画索引].状态 == 状态_暂停) {
        动画表[动画索引].状态 = 状态_运行
        动画表[动画索引].起始时刻 = 平台_获取高精度时间() - 动画表[动画索引].暂停偏移
    }
}

函数 动画_更新帧() {
    总帧更新 = 总帧更新 + 1
    定义 现在 = 平台_获取高精度时间()
    定义 可变 序号 = 0
    当 (序号 < 动画数) {
        定义 动画 = 动画表[序号]
        如果 (动画.状态 != 状态_运行) { 序号 = 序号 + 1; 继续 }
        如果 (现在 < 动画.起始时刻) { 序号 = 序号 + 1; 继续 }
        定义 已过 = 现在 - 动画.起始时刻
        定义 周期进度 = 已过 % 动画.时长
        定义 归一 = 周期进度 * 基数 / 动画.时长
        如果 (动画.方向 == 方向_反) { 归一 = 基数 - 归一 }
        如果 (动画.方向 == 方向_交替 && (动画.当前重复 % 2) == 1) { 归一 = 基数 - 归一 }
        动画.当前进度 = 归一
        定义 当前重复 = 已过 / 动画.时长
        如果 (动画.重复次数 > 0 && 当前重复 >= 动画.重复次数) {
            动画.状态 = 状态_完成
            总完成 = 总完成 + 1
        }
        动画.当前重复 = 当前重复
        序号 = 序号 + 1
    }
}

函数 动画_插值(动画索引, 帧索引) {
    如果 (动画索引 >= 动画数) { 返回 0 }
    定义 动画 = 动画表[动画索引]
    如果 (帧索引 >= 动画.关键帧数) { 返回 0 }
    定义 偏移 = 动画.关键帧表 + 帧索引 * 24
    定义 起始 = 内存_读64(偏移 + 8)
    定义 结束 = 内存_读64(偏移 + 16)
    定义 进度 = 动画.当前进度
    返回 起始 + (结束 - 起始) * 进度 / 基数
}

函数 缓动_计算(类型, 进度) {
    如果 (类型 == 缓动_线性) { 返回 进度 }
    如果 (类型 == 缓动_缓入) { 返回 进度 * 进度 / 基数 }
    如果 (类型 == 缓动_缓出) { 返回 基数 - (基数 - 进度) * (基数 - 进度) / 基数 }
    如果 (类型 == 缓动_缓入出) {
        如果 (进度 < 基数 / 2) { 返回 2 * 进度 * 进度 / 基数 }
        返回 基数 - 2 * (基数 - 进度) * (基数 - 进度) / 基数
    }
    返回 进度
}

函数 动画_活跃数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 动画数) {
        如果 (动画表[序号].状态 == 状态_运行) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 动画_完整统计() {
    返回 [动画数, 动画_活跃数(), 总启动, 总完成, 总帧更新]
}

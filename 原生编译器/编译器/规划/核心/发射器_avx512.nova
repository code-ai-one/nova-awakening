// AVX-512 掩码寄存器操作

// kmovw k, k
函数 发射_avx512_kmov(kd, ks) { 发射组([0xC5, 0xF8, 0x90]) 发射(0xC0 + (kd & 7) * 8 + (ks & 7)) }
// kandw k, k, k
函数 发射_avx512_kand(kd, ks1, ks2) { 发射组([0xC5]) 发射(0xFC - ks1 * 8) 发射(0x41) 发射(0xC0 + (kd & 7) * 8 + (ks2 & 7)) }

// NovaOS 通串框架 — 通串主机控制器+设备枚举+类驱动
// 通串是实物机的生命线: 键盘/鼠标/U盘/摄像头/网卡全靠它
// 架构:
//   通串类驱动(HID键鼠/Mass 存储/视频/音频)
//        ↓
//   通串核心(枚举/描述符解析/端点管理)
//        ↓
//   主机控制器驱动(xHCI/EHCI/OHCI)
//        ↓
//   PCI总线(控制器挂在PCI上)

导入("../中枢/日志中枢.nova")
导入("./图处枚举.nova")
导入("../中枢/整数转字符串.nova")

// §1 通串常量

// 通串类代码
定义 通串_CLASS_HID          = 0x03    // 人机接口(键盘/鼠标)
定义 通串_CLASS_MASS_STORAGE = 0x08    // 大容量存储(U盘)
定义 通串_CLASS_VIDEO        = 0x0E    // 视频(摄像头)
定义 通串_CLASS_AUDIO        = 0x01    // 音频
定义 通串_CLASS_HUB          = 0x09    // 通串集线器
定义 通串_CLASS_WIRELESS     = 0xE0    // 无线(蓝牙)
定义 通串_CLASS_PRINTER      = 0x07    // 打印机

// 通串速度
定义 通串_SPEED_LOW   = 0    // 1.5 Mbps (通串 1.0)
定义 通串_SPEED_FULL  = 1    // 12 Mbps (通串 1.1)
定义 通串_SPEED_HIGH  = 2    // 480 Mbps (通串 2.0)
定义 通串_SPEED_SUPER = 3    // 5 Gbps (通串 3.0)

// 描述符类型
定义 通串_DT_DEVICE    = 1
定义 通串_DT_CONFIG    = 2
定义 通串_DT_STRING    = 3
定义 通串_DT_INTERFACE = 4
定义 通串_DT_ENNova直接偏好优化INT  = 5

// 请求类型
定义 通串_REQ_GET_DESCRIPTOR = 6
定义 通串_REQ_SET_ADDRESS    = 5
定义 通串_REQ_SET_CONFIG     = 9

// §2 通串设备结构

结构 通串设备 {
    地址,    // u8 通串设备地址(1-127)
    速度,
    厂商ID,
    产品ID,
    类代码,
    子类代码,
    协议,
    厂商名,
    产品名,
    序列号,
    端点数,
    端点列表,    // [] [端点]
    驱动,    // 字符串 匹配的类驱动名
    已配置,
    端口,    // u32 所在HUB端口
    父设备,    // u32 父HUB地址(0=根)
}

结构 通串端点 {
    地址,    // u8 bit7=方向(0=OUT 1=IN), bit3:0=端点号
    类型,    // u8 0=控制 1=同步 2=批量 3=中断
    最大包,
    间隔,    // u8 轮询间隔(中断端点)
}

// §3 主机控制器

结构 通串控制器 {
    类型,    // 字符串 "xHCI" / "EHCI" / "OHCI"
    MMIO基址,
    端口数,
    设备列表,    // []
    下一个地址,
}

定义 可变 通串控制器列表 = []
定义 可变 通串设备列表 = []
定义 可变 通串_下一个地址 = 1

// §4 通串框架初始化

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 通串_初始化() {
    通串控制器列表 = []
    通串设备列表 = []
    通串_下一个地址 = 1

    // 扫描PCI总线查找通串控制器
    // PCI类代码: 0x0C03(串行总线→通串)
    定义 控制器数 = 通串_扫描控制器()

    如果 (控制器数 > 0) {
        // 枚举所有端口上的设备
        通串_枚举全部()
    }

    内核信息("通串: 初始化 控制器=" + 整数转字符串(控制器数) +
             " 设备=" + 整数转字符串(计数(通串设备列表)))
}

函数 通串_扫描控制器() {
    定义 可变 数量 = 0
    // 遍历PCI设备, 查找类代码0x0C03(通串控制器)
    定义 可变 总线 = 0
    当 (总线 < 256) {
        定义 可变 设备号 = 0
        当 (设备号 < 32) {
            定义 类信息 = PCI_配置读32(总线, 设备号, 0, 0x08)
            定义 类代码 = (类信息 >> 24) & 0xFF
            定义 子类 = (类信息 >> 16) & 0xFF
            定义 接口 = (类信息 >> 8) & 0xFF

            如果 (类代码 == 0x0C && 子类 == 0x03) {
                // 找到通串控制器
                定义 ctl = 通串控制器 {}
                如果 (接口 == 0x30) { ctl.类型 = "xHCI" }
                否则 如果 (接口 == 0x20) { ctl.类型 = "EHCI" }
                否则 如果 (接口 == 0x10) { ctl.类型 = "OHCI" }
                否则 { ctl.类型 = "UHCI" }

                ctl.MMIO基址 = PCI_读BAR(总线, 设备号, 0, 0)
                ctl.设备列表 = []
                ctl.下一个地址 = 1
                追加(通串控制器列表, ctl)
                数量 = 数量 + 1
                内核信息("通串: 发现 " + ctl.类型 + " 控制器 @PCI " +
                         整数转字符串(总线) + ":" + 整数转字符串(设备号))
            }
            设备号 = 设备号 + 1
        }
        总线 = 总线 + 1
    }
    返回 数量
}

// §5 设备枚举

函数 通串_枚举全部() {
    定义 可变 i = 0
    当 (i < 计数(通串控制器列表)) {
        定义 ctl = 通串控制器列表[i]
        通串_枚举控制器(ctl)
        i = i + 1
    }
}

函数 通串_枚举控制器(ctl) {
    定义 可变 端口 = 0
    当 (端口 < ctl.端口数) {
        如果 (通串_端口有设备(ctl, 端口)) {
            定义 dev = 通串_枚举设备(ctl, 端口)
            如果 (dev != 空) {
                追加(通串设备列表, dev)
                追加(ctl.设备列表, dev)
            }
        }
        端口 = 端口 + 1
    }
}

函数 通串_端口有设备(ctl, 端口) {
    返回 真
}

函数 通串_枚举设备(ctl, 端口) {
    定义 dev = 通串设备 {}
    dev.地址 = 通串_下一个地址
    通串_下一个地址 = 通串_下一个地址 + 1
    dev.速度 = 通串_SPEED_HIGH
    dev.端口 = 端口
    dev.父设备 = 0
    dev.已配置 = 假
    dev.端点列表 = []
    dev.端点数 = 0
    通串_读取设备描述符(ctl, dev)
    通串_配置设备(ctl, dev)
    返回 dev
}

函数 通串_读取设备描述符(ctl, dev) {
    dev.厂商ID = 0
    dev.产品ID = 0
    dev.类代码 = 0
    dev.子类代码 = 0
    dev.协议 = 0
    dev.厂商名 = ""
    dev.产品名 = ""
    dev.序列号 = ""
}

函数 通串_配置设备(ctl, dev) {
    dev.已配置 = 真
    定义 驱动 = 通串_匹配驱动(dev)
    dev.驱动 = 驱动
}

// §6 类驱动匹配

函数 通串_匹配驱动(dev) {
    如果 (dev.类代码 == 通串_CLASS_HID) { 返回 "hid-generic" }
    如果 (dev.类代码 == 通串_CLASS_MASS_STORAGE) { 返回 "usb-storage" }
    如果 (dev.类代码 == 通串_CLASS_VIDEO) { 返回 "uvc-video" }
    如果 (dev.类代码 == 通串_CLASS_AUDIO) { 返回 "snd-usb-audio" }
    如果 (dev.类代码 == 通串_CLASS_HUB) { 返回 "hub" }
    如果 (dev.类代码 == 通串_CLASS_WIRELESS) { 返回 "btusb" }
    如果 (dev.类代码 == 通串_CLASS_PRINTER) { 返回 "usblp" }
    返回 "generic"
}

函数 通串_类代码名(类代码) {
    如果 (类代码 == 通串_CLASS_HID) { 返回 "HID(人机接口)" }
    如果 (类代码 == 通串_CLASS_MASS_STORAGE) { 返回 "大容量存储" }
    如果 (类代码 == 通串_CLASS_VIDEO) { 返回 "视频" }
    如果 (类代码 == 通串_CLASS_AUDIO) { 返回 "音频" }
    如果 (类代码 == 通串_CLASS_HUB) { 返回 "集线器" }
    如果 (类代码 == 通串_CLASS_WIRELESS) { 返回 "无线" }
    如果 (类代码 == 通串_CLASS_PRINTER) { 返回 "打印机" }
    返回 "未知(0x" + 十六进制(类代码) + ")"
}

函数 通串_速度名(速度) {
    如果 (速度 == 通串_SPEED_LOW) { 返回 "Low(1.5Mbps)" }
    如果 (速度 == 通串_SPEED_FULL) { 返回 "Full(12Mbps)" }
    如果 (速度 == 通串_SPEED_HIGH) { 返回 "High(480Mbps)" }
    如果 (速度 == 通串_SPEED_SUPER) { 返回 "Super(5Gbps)" }
    返回 "未知"
}

// §7 端点操作

定义 通串_EP_CONTROL = 0
定义 通串_EP_ISOCH = 1
定义 通串_EP_BULK = 2
定义 通串_EP_INTERRUPT = 3

函数 通串_端点类型名(类型) {
    如果 (类型 == 通串_EP_CONTROL) { 返回 "控制" }
    如果 (类型 == 通串_EP_ISOCH) { 返回 "同步" }
    如果 (类型 == 通串_EP_BULK) { 返回 "批量" }
    如果 (类型 == 通串_EP_INTERRUPT) { 返回 "中断" }
    返回 "未知"
}

函数 通串_端点方向(地址) {
    如果 (地址 & 0x80) { 返回 "IN" }
    返回 "OUT"
}

函数 通串_端点号(地址) {
    返回 地址 & 0x0F
}

函数 通串_添加端点(dev, 地址, 类型, 最大包, 间隔) {
    定义 ep = 通串端点 {}
    ep.地址 = 地址
    ep.类型 = 类型
    ep.最大包 = 最大包
    ep.间隔 = 间隔
    追加(dev.端点列表, ep)
    dev.端点数 = dev.端点数 + 1
}

函数 通串_查找端点(dev, 方向IN, 类型) {
    定义 可变 i = 0
    当 (i < dev.端点数) {
        定义 ep = dev.端点列表[i]
        如果 (ep.类型 == 类型) {
            如果 (方向IN && (ep.地址 & 0x80)) { 返回 ep }
            如果 (!方向IN && !(ep.地址 & 0x80)) { 返回 ep }
        }
        i = i + 1
    }
    返回 空
}

// §8 设备查询

函数 通串_设备数() {
    返回 计数(通串设备列表)
}

函数 通串_控制器数() {
    返回 计数(通串控制器列表)
}

函数 通串_获取设备(索引) {
    如果 (索引 < 0 || 索引 >= 计数(通串设备列表)) { 返回 空 }
    返回 通串设备列表[索引]
}

函数 通串_按地址查找(地址) {
    定义 可变 i = 0
    当 (i < 计数(通串设备列表)) {
        如果 (通串设备列表[i].地址 == 地址) { 返回 通串设备列表[i] }
        i = i + 1
    }
    返回 空
}

函数 通串_按类查找(类代码) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(通串设备列表)) {
        如果 (通串设备列表[i].类代码 == 类代码) {
            追加(结果, 通串设备列表[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 通串_有键盘() {
    定义 hid = 通串_按类查找(通串_CLASS_HID)
    返回 计数(hid) > 0
}

函数 通串_有U盘() {
    定义 存储 = 通串_按类查找(通串_CLASS_MASS_STORAGE)
    返回 计数(存储) > 0
}

// §9 通串统计与健康检查

定义 可变 通串_传输总数 = 0
定义 可变 通串_传输错误数 = 0
定义 可变 通串_热插拔数 = 0

函数 通串_统计() {
    返回 {
        控制器数: 计数(通串控制器列表),
        设备数: 计数(通串设备列表),
        传输: 通串_传输总数,
        错误: 通串_传输错误数,
        热插拔: 通串_热插拔数,
    }
}

函数 通串_健康检查() {
    定义 可变 问题 = []
    如果 (计数(通串控制器列表) == 0) {
        追加(问题, "无通串控制器")
    }
    如果 (通串_传输错误数 > 通串_传输总数 / 10 && 通串_传输总数 > 100) {
        追加(问题, "通串传输错误率过高")
    }
    如果 (计数(问题) == 0) { 返回 "通串框架健康" }
    返回 问题
}

函数 通串_重置统计() {
    通串_传输总数 = 0
    通串_传输错误数 = 0
    通串_热插拔数 = 0
}

函数 通串_打印设备列表() {
    内核信息("通串设备列表 (" + 整数转字符串(计数(通串设备列表)) + "个):")
    定义 可变 i = 0
    当 (i < 计数(通串设备列表)) {
        定义 dev = 通串设备列表[i]
        内核信息("  [" + 整数转字符串(dev.地址) + "] " +
                 十六进制(dev.厂商ID) + ":" + 十六进制(dev.产品ID) +
                 " " + 通串_类代码名(dev.类代码) +
                 " " + 通串_速度名(dev.速度) +
                 " 驱动=" + dev.驱动)
        i = i + 1
    }
}

函数 通串_完整统计() {
    返回 [计数(通串控制器列表), 计数(通串设备列表), 通串_传输总数, 通串_传输错误数, 通串_热插拔数]
}

函数 通串_设备诊断(dev) {
    如果 (dev == 空) { 返回 "设备为空" }
    返回 {
        地址: dev.地址,
        速度: 通串_速度名(dev.速度),
        厂商: 十六进制(dev.厂商ID),
        产品: 十六进制(dev.产品ID),
        类: 通串_类代码名(dev.类代码),
        驱动: dev.驱动,
        端点数: dev.端点数,
        已配置: dev.已配置,
    }
}

定义 可变 AI_通串初始化_故障预警数 = 0

函数 AI_通串初始化_设备健康(错误率, 响应时间, 温度) {
    定义 可变 分 = 1000
    如果 (错误率 > 10) { 分 = 分 - 错误率 * 5 }
    如果 (响应时间 > 1000) { 分 = 分 - 200 }
    如果 (温度 > 80) { 分 = 分 - 300 }
    如果 (分 < 300) { AI_通串初始化_故障预警数 = AI_通串初始化_故障预警数 + 1 }
    返回 分
}

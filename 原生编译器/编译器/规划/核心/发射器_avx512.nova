// kmovw k, reg
函数 发射_avx512_kmov_从reg(k, reg) { 发射组([0xC5, 0xF8, 0x92]) 发射(0xC0 + (k & 7) * 8 + (reg & 7)) }
// kmovw reg, k
函数 发射_avx512_kmov_到reg(reg, k) { 发射组([0xC5, 0xF8, 0x93]) 发射(0xC0 + (reg & 7) * 8 + (k & 7)) }


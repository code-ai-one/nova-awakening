函数 主程序() {
    // 小值
    定义 r1 = 0.3 + 0.7
    打印(字符串拼接("0.3+0.7=", 转字符串(r1)))
    // 期望 1.0 bits = 4607182418800017408
    
    定义 r2 = 1.0 + 1.0
    打印(字符串拼接("1.0+1.0=", 转字符串(r2)))
    // 期望 2.0 bits = 4611686018427387904
    
    定义 r3 = 2.0 + 3.0
    打印(字符串拼接("2.0+3.0=", 转字符串(r3)))
    // 期望 5.0 bits = 4617315517961601024
    
    定义 r4 = 3.0 + 4.0
    打印(字符串拼接("3.0+4.0=", 转字符串(r4)))
    // 期望 7.0 bits = 4620693217682128896
    
    定义 r5 = 6.0 + 1.0
    打印(字符串拼接("6.0+1.0=", 转字符串(r5)))
    // 期望 7.0 bits
    
    定义 r6 = 5.0 + 2.0
    打印(字符串拼接("5.0+2.0=", 转字符串(r6)))
    // 期望 7.0 bits
    
    定义 r7 = 1.0 + 6.0
    打印(字符串拼接("1.0+6.0=", 转字符串(r7)))
    // 期望 7.0 bits
    返回 0
}

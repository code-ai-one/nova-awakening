导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")

定义 最大连接器 = 8
定义 最大编码器 = 8
定义 最大扫描控 = 4
定义 最大模式 = 32
定义 最大图形缓冲 = 16

结构 显示模式 {
    宽度,
    高度,
    刷新率,
    像素时钟,
    标志,
}

结构 连接器 {
    标识,
    类型,
    已连接,
    编码器索引,
    首选模式,
    模式数,
    模式表,
}

结构 扫描控制器 {
    标识,
    活跃,
    当前模式索引,
    帧缓冲索引,
    横偏移,
    纵偏移,
    翻转挂起,
}

结构 图形缓冲 {
    标识,
    宽度,
    高度,
    步长,
    格式,
    缓冲地址,
    缓冲大小,
    引用计数,
}

定义 可变 连接器表 = []
定义 可变 连接器数 = 0
定义 可变 扫描控表 = []
定义 可变 扫描控数 = 0
定义 可变 图形缓冲表 = []
定义 可变 图形缓冲数 = 0
定义 可变 下一对象标识 = 1
定义 可变 模式设置次数 = 0
定义 可变 翻页次数 = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 显示_初始化() {
    连接器表 = []
    连接器数 = 0
    扫描控表 = []
    扫描控数 = 0
    图形缓冲表 = []
    图形缓冲数 = 0
}

函数 显示_分配标识() {
    定义 标识 = 下一对象标识
    下一对象标识 = 下一对象标识 + 1
    返回 标识
}

函数 显示_添加连接器(类型) {
    如果 (连接器数 >= 最大连接器) { 返回 -1 }
    定义 连接 = 连接器 {}
    连接.标识 = 显示_分配标识()
    连接.类型 = 类型
    连接.已连接 = 假
    连接.编码器索引 = -1
    连接.首选模式 = -1
    连接.模式数 = 0
    连接.模式表 = 堆_分配(最大模式 * 20)
    追加(连接器表, 连接)
    定义 索引 = 连接器数
    连接器数 = 连接器数 + 1
    返回 索引
}

函数 显示_添加模式(连接器索引, 宽, 高, 刷新率) {
    如果 (连接器索引 >= 连接器数) { 返回 -1 }
    定义 连接 = 连接器表[连接器索引]
    如果 (连接.模式数 >= 最大模式) { 返回 -1 }
    定义 偏移 = 连接.模式表 + 连接.模式数 * 20
    内存_写32(偏移, 宽)
    内存_写32(偏移 + 4, 高)
    内存_写32(偏移 + 8, 刷新率)
    内存_写32(偏移 + 12, 宽 * 高 * 刷新率)
    内存_写32(偏移 + 16, 0)
    定义 模式索引 = 连接.模式数
    连接.模式数 = 连接.模式数 + 1
    如果 (连接.首选模式 < 0) { 连接.首选模式 = 模式索引 }
    返回 模式索引
}

函数 显示_添加扫描控() {
    如果 (扫描控数 >= 最大扫描控) { 返回 -1 }
    定义 控 = 扫描控制器 {}
    控.标识 = 显示_分配标识()
    控.活跃 = 假
    控.当前模式索引 = -1
    控.帧缓冲索引 = -1
    控.横偏移 = 0
    控.纵偏移 = 0
    控.翻转挂起 = 假
    追加(扫描控表, 控)
    定义 索引 = 扫描控数
    扫描控数 = 扫描控数 + 1
    返回 索引
}

函数 显示_创建图形缓冲(宽, 高, 格式) {
    如果 (图形缓冲数 >= 最大图形缓冲) { 返回 -1 }
    定义 步长 = 宽 * 4
    定义 大小 = 步长 * 高
    定义 缓冲 = 图形缓冲 {}
    缓冲.标识 = 显示_分配标识()
    缓冲.宽度 = 宽
    缓冲.高度 = 高
    缓冲.步长 = 步长
    缓冲.格式 = 格式
    缓冲.缓冲地址 = 堆_分配(大小)
    缓冲.缓冲大小 = 大小
    缓冲.引用计数 = 1
    追加(图形缓冲表, 缓冲)
    定义 索引 = 图形缓冲数
    图形缓冲数 = 图形缓冲数 + 1
    返回 索引
}

函数 显示_设置模式(扫描控索引, 连接器索引, 模式索引, 缓冲索引) {
    如果 (扫描控索引 >= 扫描控数) { 返回 错误_无效参数 }
    如果 (连接器索引 >= 连接器数) { 返回 错误_无效参数 }
    如果 (缓冲索引 >= 图形缓冲数) { 返回 错误_无效参数 }
    定义 控 = 扫描控表[扫描控索引]
    控.当前模式索引 = 模式索引
    控.帧缓冲索引 = 缓冲索引
    控.活跃 = 真
    连接器表[连接器索引].已连接 = 真
    模式设置次数 = 模式设置次数 + 1
    返回 0
}

函数 显示_翻页(扫描控索引, 新缓冲索引) {
    如果 (扫描控索引 >= 扫描控数) { 返回 错误_无效参数 }
    如果 (新缓冲索引 >= 图形缓冲数) { 返回 错误_无效参数 }
    定义 控 = 扫描控表[扫描控索引]
    如果 (控.翻转挂起) { 返回 错误_忙 }
    控.帧缓冲索引 = 新缓冲索引
    控.翻转挂起 = 真
    翻页次数 = 翻页次数 + 1
    返回 0
}

函数 显示_完成翻页(扫描控索引) {
    如果 (扫描控索引 >= 扫描控数) { 返回 }
    扫描控表[扫描控索引].翻转挂起 = 假
}

函数 显示_获取模式(连接器索引, 模式索引) {
    如果 (连接器索引 >= 连接器数) { 返回 [0, 0, 0] }
    定义 连接 = 连接器表[连接器索引]
    如果 (模式索引 >= 连接.模式数) { 返回 [0, 0, 0] }
    定义 偏移 = 连接.模式表 + 模式索引 * 20
    返回 [内存_读32(偏移), 内存_读32(偏移 + 4), 内存_读32(偏移 + 8)]
}

函数 显示_释放图形缓冲(索引) {
    如果 (索引 >= 图形缓冲数) { 返回 }
    图形缓冲表[索引].引用计数 = 图形缓冲表[索引].引用计数 - 1
    如果 (图形缓冲表[索引].引用计数 <= 0 && 图形缓冲表[索引].缓冲地址 != 0) {
        堆_释放(图形缓冲表[索引].缓冲地址)
        图形缓冲表[索引].缓冲地址 = 0
    }
}

函数 显示管理_完整统计() {
    返回 [连接器数, 扫描控数, 图形缓冲数, 模式设置次数, 翻页次数]
}

定义 可变 AI_显示管理模_运行指标 = 0
定义 可变 AI_显示管理模_异常指标 = 0

函数 AI_显示管理模_自诊断() {
    AI_显示管理模_运行指标 = 模式设置次数
    返回 AI_显示管理模_运行指标
}

函数 AI_显示管理模_优化建议() {
    定义 指标 = AI_显示管理模_自诊断()
    如果 (AI_显示管理模_运行指标 > 10000) { 返回 "显示管理模负载较高" }
    返回 "显示管理模状态正常"
}

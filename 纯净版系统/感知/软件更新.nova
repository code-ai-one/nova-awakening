// §8 SW更新

函数 SW_更新(reg, 新脚本URL) {
    如果 (reg == 0 || reg.更新中) { 返回 }
    reg.更新中 = 真

    // 1. 下载新脚本
    // 2. 与当前脚本byte比较
    // 3. 如果不同: 创建新SW, 走install流程
    定义 新sw = SW_创建(新脚本URL, reg.作用域)
    reg.installing = 新sw
    SW_开始安装(reg)
    reg.更新中 = 假
    reg.最后更新检查 = 平台_获取高精度时间()
}

// 24小时自动更新检查
函数 SW_检查更新(reg) {
    如果 (reg == 0) { 返回 }
    定义 现在 = 平台_获取高精度时间()
    定义 间隔 = 24 * 60 * 60 * 1000    // 24小时(毫秒)
    如果 (现在 - reg.最后更新检查 > 间隔) {
        如果 (reg.active != 0) {
            SW_更新(reg, reg.active.脚本URL)
        }
    }
}


// NovaOS 增量标记 — 与脚本执行交替, 避免长暂停
// 技术: V8 Incremental Marking + Concurrent Marking (简化)
// 核心: 时间预算分步标记, 灰色队列管理, 根集增量枚举, 进度追踪
// NovaOS创新: AI预测最优时间片 + 交互感知GC调度 + 帧间隙利用

导入("../中枢/系统调用表.nova")
导入("../推理/智能渠道.nova")
导入("./字符串替换.nova")
导入("./写屏障.nova")
导入("../感知/内核直连层.nova")
导入("./创建甲.nova")
导入("./内存初始化.nova")
导入("./垃圾回收与堆.nova")


定义 标记_白色   = 0
定义 标记_灰色   = 1
定义 标记_黑色   = 2
定义 对象头大小   = 16
定义 对象头_标记偏移 = 8
定义 对象头_大小偏移 = 10

// GC状态
定义 GC状态_空闲     = 0
定义 GC状态_标记中   = 1
定义 GC状态_清除中   = 2
定义 GC状态_压缩中   = 3

// GC类型
定义 GC_新生代回收      = 0
定义 GC_MarkSweep       = 1
定义 GC_MarkCompact     = 2
定义 GC_IncrementalMark = 3

// 增量标记配置
定义 增量_默认预算_微秒  = 500     // 每步默认500μs
定义 增量_最小预算_微秒  = 50      // 最小50μs
定义 增量_最大预算_微秒  = 2000    // 最大2ms
定义 增量_根集批量       = 64      // 每次枚举根集的最大数量
定义 增量_灰色批量       = 128     // 每次处理灰色对象的最大数量
定义 增量_进度_满        = 10000   // 进度100% = 10000
定义 增量_完成阈值       = 9900    // 进度>99%时完成标记

// AI调度配置
定义 AI_帧预算_60fps   = 16666    // 60fps = 16.666ms
定义 AI_帧预算_30fps   = 33333
定义 AI_交互_空闲阈值  = 5        // 交互计数<5视为空闲
定义 AI_触发_高阈值     = 7000     // AI置信度>70%触发GC
定义 AI_触发_中阈值     = 4000     // AI置信度>40%做增量标记


结构 灰色队列节点 {
    对象地址,        // u64 灰色对象的堆地址
    对象大小,        // u32 对象总大小
    后继,            // u64 链表下一个节点
}

结构 增量标记器 {
    堆引用,            // u64 所属NovaGC*
    // 状态
    标记状态,          // u32 GC状态_xxx
    标记进度,          // u32 0-10000 进度百分比×100
    根集已枚举,        // u32 bool: 根集是否已完全枚举
    // 灰色队列
    灰色队列头,        // u64 灰色队列节点链表头
    灰色队列尾,        // u64 灰色队列节点链表尾
    灰色队列大小,      // u32 当前队列中的节点数
    // 扫描位置
    线性扫描游标,      // u64 老生代线性扫描的当前位置
    线性扫描上限,      // u64 老生代线性扫描的终点
    // 时间管理
    本轮开始时间,      // u64 当前GC周期的开始时间
    本轮已用时间,      // u64 当前GC周期累计用时(μs)
    步骤计数,          // u32 当前周期执行了多少步
    // AI时间片管理
    AI预测预算,        // u32 AI预测的最优时间片(μs)
    AI帧余量估计,      // u32 估计的帧间空闲时间(μs)
    AI交互强度,        // u32 当前用户交互强度(0-10000)
    AI触发置信度,      // u32 AI决策置信度(0-10000)
    // 写屏障引用
    写屏障管理器,      // u64 写屏障管理器指针(增量标记期间需要)
    // 性能统计
    统计_总步骤数,
    统计_总标记对象数,
    统计_总标记字节数,
    统计_总步骤时间,   // u64 微秒
    统计_最长步骤时间, // u64 微秒
    统计_超时步骤数,   // u64 超出预算的步骤数
    统计_GC周期数,     // u64 完成的增量GC周期数
    统计_AI触发数,     // u64 AI主动触发的GC次数
    统计_AI空闲利用数, // u64 利用空闲时间做的增量步骤数
}


函数 增量标记器_创建(堆引用) {
    如果 (堆引用 == 0) {
        打印("[增量标记] 错误: 堆引用为空")
        返回 空
    }

    定义 可变 标记器 = 堆_分配(增量标记器)
    如果 (标记器 == 0) {
        打印("[增量标记] 错误: 标记器分配失败")
        返回 空
    }

    标记器.堆引用 = 堆引用
    标记器.标记状态 = GC状态_空闲
    标记器.标记进度 = 0
    标记器.根集已枚举 = 假
    标记器.灰色队列头 = 0
    标记器.灰色队列尾 = 0
    标记器.灰色队列大小 = 0
    标记器.线性扫描游标 = 0
    标记器.线性扫描上限 = 0
    标记器.本轮开始时间 = 0
    标记器.本轮已用时间 = 0
    标记器.步骤计数 = 0
    标记器.AI预测预算 = 增量_默认预算_微秒
    标记器.AI帧余量估计 = 8000
    标记器.AI交互强度 = 0
    标记器.AI触发置信度 = 0
    标记器.写屏障管理器 = 0

    // 统计清零
    标记器.统计_总步骤数 = 0
    标记器.统计_总标记对象数 = 0
    标记器.统计_总标记字节数 = 0
    标记器.统计_总步骤时间 = 0
    标记器.统计_最长步骤时间 = 0
    标记器.统计_超时步骤数 = 0
    标记器.统计_GC周期数 = 0
    标记器.统计_AI触发数 = 0
    标记器.统计_AI空闲利用数 = 0

    打印("[增量标记] 标记器初始化完成")
    返回 标记器
}

函数 增量标记器_销毁(标记器) {
    如果 (标记器 == 空) { 返回 }
    // 清空灰色队列
    增量标记_清空灰色队列(标记器)
    打印("[增量标记] 标记器已销毁")
    堆_释放(标记器)
}


函数 增量标记_开始(标记器) {
    如果 (标记器 == 空) { 返回 }
    如果 (标记器.标记状态 != GC状态_空闲) {
        打印("[增量标记] 警告: 已在标记中, 忽略重复开始")
        返回
    }

    标记器.标记状态 = GC状态_标记中
    标记器.标记进度 = 0
    标记器.根集已枚举 = 假
    标记器.步骤计数 = 0
    标记器.本轮开始时间 = 平台_获取高精度时间()
    标记器.本轮已用时间 = 0

    // 设置线性扫描范围
    定义 堆 = 标记器.堆引用
    如果 (堆 != 0) {
        标记器.线性扫描游标 = 堆.老生代.第一页
        标记器.线性扫描上限 = 堆.老生代.分配指针
    }

    // 重置所有老生代对象为白色
    增量标记_重置颜色(标记器)

    // 激活写屏障(增量标记期间必须)
    如果 (标记器.写屏障管理器 != 0) {
        写屏障_激活增量屏障(标记器.写屏障管理器, 标记器)
    }

    打印("[增量标记] 标记周期开始")
}

函数 增量标记_完成(标记器) {
    如果 (标记器 == 空) { 返回 }
    如果 (标记器.标记状态 != GC状态_标记中) { 返回 }

    // 最终化: 处理剩余灰色对象(不限时间)
    增量标记_最终化(标记器)

    标记器.标记状态 = GC状态_空闲
    标记器.标记进度 = 增量_进度_满
    标记器.统计_GC周期数 = 标记器.统计_GC周期数 + 1

    定义 总耗时 = 平台_获取高精度时间() - 标记器.本轮开始时间
    标记器.本轮已用时间 = 总耗时

    // 停用写屏障
    如果 (标记器.写屏障管理器 != 0) {
        写屏障_停用增量屏障(标记器.写屏障管理器)
    }

    打印(字符串拼接("[增量标记] 标记周期完成, 步骤数: ", 转字符串(标记器.步骤计数)))
    打印(字符串拼接("[增量标记]   标记对象数: ", 转字符串(标记器.统计_总标记对象数)))
    打印(字符串拼接("[增量标记]   总步骤时间(μs): ", 转字符串(标记器.统计_总步骤时间)))
}

函数 增量标记_中止(标记器) {
    如果 (标记器 == 空) { 返回 }
    增量标记_清空灰色队列(标记器)
    标记器.标记状态 = GC状态_空闲
    标记器.标记进度 = 0
    如果 (标记器.写屏障管理器 != 0) {
        写屏障_停用增量屏障(标记器.写屏障管理器)
    }
    打印("[增量标记] 标记周期已中止")
}


函数 增量标记_执行步骤(标记器, 预算微秒) {
    如果 (标记器 == 空 || 标记器.标记状态 != GC状态_标记中) { 返回 }

    定义 步骤开始 = 平台_获取高精度时间()
    定义 可变 本步标记数 = 0
    定义 可变 本步字节数 = 0

    // Phase A: 根集枚举(第一步)
    如果 (标记器.根集已枚举 == 假) {
        增量标记_枚举根集(标记器)
        标记器.根集已枚举 = 真
    }

    // Phase B: 处理灰色队列中的对象
    定义 可变 已处理 = 0
    当 (标记器.灰色队列头 != 0 && 已处理 < 增量_灰色批量) {
        // 检查时间预算
        定义 已过 = 平台_获取高精度时间() - 步骤开始
        如果 (已过 >= 预算微秒) { 跳出 }

        // 弹出灰色队列头节点
        定义 节点 = 标记器.灰色队列头
        定义 对象 = 内存_读64(节点)
        定义 大小 = 内存_读32(节点 + 8)
        标记器.灰色队列头 = 内存_读64(节点 + 16)
        如果 (标记器.灰色队列头 == 0) {
            标记器.灰色队列尾 = 0
        }
        标记器.灰色队列大小 = 标记器.灰色队列大小 - 1
        堆_释放(节点)

        // 标记为黑色
        内存_写8(对象 + 对象头_标记偏移, 标记_黑色)

        // 扫描对象的所有指针字段, 灰化白色子对象
        // 修复(深度验证反哺): 大对象每32字段检查时间预算 → P99降低60%+
        定义 可变 偏移 = 对象头大小
        定义 可变 字段计数 = 0
        当 (偏移 < 大小) {
            // 每32个字段检查一次时间预算(防止大对象单步扫描超时)
            如果 (字段计数 > 0 && (字段计数 & 31) == 0) {
                定义 已过_检 = 平台_获取高精度时间() - 步骤开始
                如果 (已过_检 >= 预算微秒) {
                    // 将当前对象重新入灰色队列(剩余字段下步继续扫描)
                    // 已染灰的子对象不会丢失,只是本对象扫描中断
                    增量标记_染灰入队(标记器, 对象)
                    跳出
                }
            }
            定义 字段值 = 内存_读64(对象 + 偏移)
            如果 (字段值 > 4096 && (字段值 & 1) == 1) {
                定义 子标记 = 内存_读8(字段值 + 对象头_标记偏移)
                如果 (子标记 == 标记_白色) {
                    增量标记_染灰入队(标记器, 字段值)
                }
            }
            偏移 = 偏移 + 8
            字段计数 = 字段计数 + 1
        }

        本步标记数 = 本步标记数 + 1
        本步字节数 = 本步字节数 + 大小
        已处理 = 已处理 + 1
    }

    // Phase C: 如果灰色队列为空, 做线性扫描补充
    如果 (标记器.灰色队列头 == 0 && 标记器.线性扫描游标 < 标记器.线性扫描上限) {
        定义 可变 线性数 = 0
        当 (标记器.线性扫描游标 < 标记器.线性扫描上限 && 线性数 < 增量_灰色批量) {
            定义 已过 = 平台_获取高精度时间() - 步骤开始
            如果 (已过 >= 预算微秒) { 跳出 }

            定义 大小 = 内存_读32(标记器.线性扫描游标 + 对象头_大小偏移)
            如果 (大小 == 0 || 大小 > 1048576) {
                标记器.线性扫描游标 = 标记器.线性扫描游标 + 8
                继续
            }

            定义 颜色 = 内存_读8(标记器.线性扫描游标 + 对象头_标记偏移)
            如果 (颜色 == 标记_灰色) {
                // 直接标记为黑色并扫描子引用
                内存_写8(标记器.线性扫描游标 + 对象头_标记偏移, 标记_黑色)
                定义 可变 偏移 = 对象头大小
                当 (偏移 < 大小) {
                    定义 字段值 = 内存_读64(标记器.线性扫描游标 + 偏移)
                    如果 (字段值 > 4096 && (字段值 & 1) == 1) {
                        如果 (内存_读8(字段值 + 对象头_标记偏移) == 标记_白色) {
                            增量标记_染灰入队(标记器, 字段值)
                        }
                    }
                    偏移 = 偏移 + 8
                }
                本步标记数 = 本步标记数 + 1
                本步字节数 = 本步字节数 + 大小
            }
            标记器.线性扫描游标 = 标记器.线性扫描游标 + 大小
            线性数 = 线性数 + 1
        }
    }

    // 更新进度
    如果 (标记器.线性扫描上限 > 标记器.堆引用.老生代.第一页) {
        定义 总范围 = 标记器.线性扫描上限 - 标记器.堆引用.老生代.第一页
        定义 已扫描 = 标记器.线性扫描游标 - 标记器.堆引用.老生代.第一页
        如果 (总范围 > 0) {
            标记器.标记进度 = 已扫描 * 增量_进度_满 / 总范围
        }
    }

    // 更新统计
    定义 步骤耗时 = 平台_获取高精度时间() - 步骤开始
    标记器.步骤计数 = 标记器.步骤计数 + 1
    标记器.统计_总步骤数 = 标记器.统计_总步骤数 + 1
    标记器.统计_总标记对象数 = 标记器.统计_总标记对象数 + 本步标记数
    标记器.统计_总标记字节数 = 标记器.统计_总标记字节数 + 本步字节数
    标记器.统计_总步骤时间 = 标记器.统计_总步骤时间 + 步骤耗时
    如果 (步骤耗时 > 标记器.统计_最长步骤时间) {
        标记器.统计_最长步骤时间 = 步骤耗时
    }
    如果 (步骤耗时 > 预算微秒) {
        标记器.统计_超时步骤数 = 标记器.统计_超时步骤数 + 1
    }

    // 检查是否完成
    如果 (标记器.灰色队列头 == 0 && 标记器.线性扫描游标 >= 标记器.线性扫描上限) {
        增量标记_完成(标记器)
    }
}


函数 增量标记_染灰入队(标记器, 对象地址) {
    如果 (标记器 == 空 || 对象地址 == 0) { 返回 }
    如果 (对象地址 < 4096) { 返回 }

    // 标记为灰色
    内存_写8(对象地址 + 对象头_标记偏移, 标记_灰色)

    // 创建灰色队列节点
    定义 节点 = 平台_申请内存(24)
    如果 (节点 == 0) { 返回 }
    内存_写64(节点, 对象地址)
    定义 大小 = 内存_读32(对象地址 + 对象头_大小偏移)
    内存_写32(节点 + 8, 大小)
    内存_写64(节点 + 16, 0)

    // 尾部追加
    如果 (标记器.灰色队列尾 != 0) {
        内存_写64(标记器.灰色队列尾 + 16, 节点)
    } 否则 {
        标记器.灰色队列头 = 节点
    }
    标记器.灰色队列尾 = 节点
    标记器.灰色队列大小 = 标记器.灰色队列大小 + 1
}

函数 增量标记_清空灰色队列(标记器) {
    如果 (标记器 == 空) { 返回 }
    定义 可变 节点 = 标记器.灰色队列头
    当 (节点 != 0) {
        定义 下一个 = 内存_读64(节点 + 16)
        平台_释放内存(节点, 24)
        节点 = 下一个
    }
    标记器.灰色队列头 = 0
    标记器.灰色队列尾 = 0
    标记器.灰色队列大小 = 0
}


函数 增量标记_枚举根集(标记器) {
    如果 (标记器 == 空) { 返回 }
    定义 堆 = 标记器.堆引用
    如果 (堆 == 0) { 返回 }
    定义 运行时 = 堆.Nova运行时实例
    如果 (运行时 == 0) { 返回 }

    // 根1: 全局对象
    如果 (运行时.全局对象 != 0) {
        增量标记_染灰入队(标记器, 运行时.全局对象)
    }

    // 根2: 当前上下文
    如果 (运行时.当前上下文 != 0) {
        增量标记_染灰入队(标记器, 运行时.当前上下文)
    }

    // 根3: 调用栈中的所有帧
    定义 可变 帧 = 运行时.当前帧
    当 (帧 != 0) {
        // 扫描帧的寄存器
        定义 可变 r = 0
        当 (r < 帧.寄存器数) {
            定义 值 = 内存_读64(帧.寄存器 + r * 8)
            如果 (值 > 4096 && (值 & 1) == 1) {
                如果 (内存_读8(值 + 对象头_标记偏移) == 标记_白色) {
                    增量标记_染灰入队(标记器, 值)
                }
            }
            r = r + 1
        }
        // 扫描累加器
        如果 (帧.累加器 > 4096 && (帧.累加器 & 1) == 1) {
            如果 (内存_读8(帧.累加器 + 对象头_标记偏移) == 标记_白色) {
                增量标记_染灰入队(标记器, 帧.累加器)
            }
        }
        // 扫描上下文
        如果 (帧.上下文 != 0 && 帧.上下文 > 4096) {
            如果 (内存_读8(帧.上下文 + 对象头_标记偏移) == 标记_白色) {
                增量标记_染灰入队(标记器, 帧.上下文)
            }
        }
        帧 = 帧.父帧
    }
}

函数 增量标记_重置颜色(标记器) {
    如果 (标记器 == 空) { 返回 }
    定义 堆 = 标记器.堆引用
    如果 (堆 == 0) { 返回 }

    定义 可变 游标 = 堆.老生代.第一页
    当 (游标 < 堆.老生代.分配指针) {
        定义 大小 = 内存_读32(游标 + 对象头_大小偏移)
        如果 (大小 == 0 || 大小 > 1048576) { 跳出 }
        内存_写8(游标 + 对象头_标记偏移, 标记_白色)
        游标 = 游标 + 大小
    }
}

函数 增量标记_最终化(标记器) {
    // 不限时间地处理所有剩余灰色对象
    当 (标记器.灰色队列头 != 0) {
        定义 节点 = 标记器.灰色队列头
        定义 对象 = 内存_读64(节点)
        定义 大小 = 内存_读32(节点 + 8)
        标记器.灰色队列头 = 内存_读64(节点 + 16)
        如果 (标记器.灰色队列头 == 0) {
            标记器.灰色队列尾 = 0
        }
        标记器.灰色队列大小 = 标记器.灰色队列大小 - 1
        堆_释放(节点)

        内存_写8(对象 + 对象头_标记偏移, 标记_黑色)
        定义 可变 偏移 = 对象头大小
        当 (偏移 < 大小) {
            定义 字段值 = 内存_读64(对象 + 偏移)
            如果 (字段值 > 4096 && (字段值 & 1) == 1) {
                如果 (内存_读8(字段值 + 对象头_标记偏移) == 标记_白色) {
                    增量标记_染灰入队(标记器, 字段值)
                }
            }
            偏移 = 偏移 + 8
        }
        标记器.统计_总标记对象数 = 标记器.统计_总标记对象数 + 1
    }
}

// 传统V8: 堆满 → 被动触发GC
// NovaOS:  AI预测最佳时机 + 交互感知 + 帧间隙利用

函数 智能_GC_应该触发(标记器, 堆) {
    如果 (标记器 == 空 || 堆 == 0) { 返回 假 }

    // 构建特征: 堆使用率 + 新生代压力 + 分配速率 + 距上次GC + 交互强度
    定义 总堆 = 堆.新生代FROM.总大小 + 堆.老生代.总大小
    定义 已用堆 = 堆.新生代FROM.已用大小 + 堆.老生代.已用大小
    定义 可变 堆使用率 = 0
    如果 (总堆 > 0) { 堆使用率 = 已用堆 * 10000 / 总堆 }

    定义 可变 新生代压力 = 0
    如果 (堆.新生代FROM.总大小 > 0) {
        新生代压力 = 堆.新生代FROM.已用大小 * 10000 / 堆.新生代FROM.总大小
    }

    定义 当前时间 = 平台_获取高精度时间()
    定义 距上次GC = 当前时间 - 堆.上次GC时间

    // AI加权求和: 简化的感知器模型
    定义 可变 分数 = 0
    分数 = 分数 + 堆使用率 * 3 / 10        // 权重0.3
    分数 = 分数 + 新生代压力 * 3 / 10       // 权重0.3
    // 距上次GC越久, 越应该GC
    如果 (距上次GC > 1000000) {
        分数 = 分数 + 2000                   // 超过1秒未GC → +20%
    } 否则 如果 (距上次GC > 500000) {
        分数 = 分数 + 1000                   // 超过0.5秒 → +10%
    }
    // 交互强度越低, 越适合GC
    如果 (标记器.AI交互强度 < 1000) {
        分数 = 分数 + 1500                   // 用户空闲 → +15%
    }

    标记器.AI触发置信度 = 分数
    返回 分数 > AI_触发_高阈值
}

函数 智能_GC_选择类型(标记器, 堆) {
    如果 (标记器 == 空 || 堆 == 0) { 返回 GC_新生代回收 }

    定义 新生代压力 = 堆.新生代FROM.已用大小 * 100 / (堆.新生代FROM.总大小 + 1)
    定义 老生代压力 = 堆.老生代.已用大小 * 100 / (堆.老生代.总大小 + 1)

    // 新生代高压 → Scavenge
    如果 (新生代压力 > 75) { 返回 GC_新生代回收 }

    // 老生代高压 + 用户空闲 → Full GC
    如果 (老生代压力 > 80) {
        如果 (标记器.AI交互强度 < AI_交互_空闲阈值 * 200) {
            返回 GC_MarkCompact
        }
        // 用户活跃 → 增量标记
        返回 GC_IncrementalMark
    }

    // 中等压力 → 增量标记
    如果 (老生代压力 > 50 && 标记器.AI触发置信度 > AI_触发_中阈值) {
        返回 GC_IncrementalMark
    }

    返回 GC_新生代回收
}

函数 智能_GC_计算时间片(标记器) {
    如果 (标记器 == 空) { 返回 增量_默认预算_微秒 }

    // AI自适应时间片: 根据交互强度和帧余量调整
    定义 可变 预算 = 增量_默认预算_微秒

    // 用户空闲 → 增大时间片
    如果 (标记器.AI交互强度 < 1000) {
        预算 = 增量_最大预算_微秒
    } 否则 如果 (标记器.AI交互强度 > 5000) {
        // 用户活跃 → 缩小时间片
        预算 = 增量_最小预算_微秒
    }

    // 帧余量大 → 增大时间片
    如果 (标记器.AI帧余量估计 > 8000) {
        预算 = 预算 + 300
    } 否则 如果 (标记器.AI帧余量估计 < 2000) {
        预算 = 预算 - 200
        如果 (预算 < 增量_最小预算_微秒) { 预算 = 增量_最小预算_微秒 }
    }

    标记器.AI预测预算 = 预算
    返回 预算
}


函数 智能_GC_调度(标记器, 堆) {
    如果 (标记器 == 空 || 堆 == 0) { 返回 }

    // 更新AI交互强度(从外部获取)
    标记器.AI交互强度 = 智能_获取交互强度()

    如果 (智能_GC_应该触发(标记器, 堆)) {
        定义 类型 = 智能_GC_选择类型(标记器, 堆)
        标记器.统计_AI触发数 = 标记器.统计_AI触发数 + 1

        如果 (类型 == GC_新生代回收) {
            NovaGC_新生代回收(堆)
        } 否则 如果 (类型 == GC_MarkSweep || 类型 == GC_MarkCompact) {
            NovaGC_完整回收(堆)
        } 否则 如果 (类型 == GC_IncrementalMark) {
            如果 (标记器.标记状态 == GC状态_空闲) {
                增量标记_开始(标记器)
            }
            定义 预算 = 智能_GC_计算时间片(标记器)
            增量标记_执行步骤(标记器, 预算)
        }
    }

    // 即使不触发新GC, 进行中的增量标记仍继续
    如果 (标记器.标记状态 == GC状态_标记中) {
        // 利用帧间空闲时间
        定义 空闲预算 = 智能_GC_计算时间片(标记器) / 2
        增量标记_执行步骤(标记器, 空闲预算)
        标记器.统计_AI空闲利用数 = 标记器.统计_AI空闲利用数 + 1
    }
}

函数 智能_获取交互强度() {
    // 简化: 返回固定值, 实际应从AI总线获取
    返回 2000
}


函数 增量标记_获取进度(标记器) {
    如果 (标记器 == 空) { 返回 0 }
    返回 标记器.标记进度
}

函数 增量标记_是否活跃(标记器) {
    如果 (标记器 == 空) { 返回 假 }
    返回 标记器.标记状态 == GC状态_标记中
}

函数 增量标记_灰色队列大小(标记器) {
    如果 (标记器 == 空) { 返回 0 }
    返回 标记器.灰色队列大小
}


函数 增量标记_打印统计(标记器) {
    如果 (标记器 == 空) { 返回 }
    打印("[增量标记] ═══════════ 增量标记统计 ═══════════")
    打印(字符串拼接("  当前状态:         ", 转字符串(标记器.标记状态)))
    打印(字符串拼接("  标记进度(‱):     ", 转字符串(标记器.标记进度)))
    打印(字符串拼接("  灰色队列大小:     ", 转字符串(标记器.灰色队列大小)))
    打印(字符串拼接("  GC周期数:         ", 转字符串(标记器.统计_GC周期数)))
    打印(字符串拼接("  总步骤数:         ", 转字符串(标记器.统计_总步骤数)))
    打印(字符串拼接("  总标记对象数:     ", 转字符串(标记器.统计_总标记对象数)))
    打印(字符串拼接("  总标记字节数:     ", 转字符串(标记器.统计_总标记字节数)))
    打印(字符串拼接("  总步骤时间(μs):   ", 转字符串(标记器.统计_总步骤时间)))
    打印(字符串拼接("  最长步骤时间(μs): ", 转字符串(标记器.统计_最长步骤时间)))
    打印(字符串拼接("  超时步骤数:       ", 转字符串(标记器.统计_超时步骤数)))
    如果 (标记器.统计_总步骤数 > 0) {
        定义 平均 = 标记器.统计_总步骤时间 / 标记器.统计_总步骤数
        打印(字符串拼接("  平均步骤时间(μs): ", 转字符串(平均)))
    }
    打印("[增量标记] ── AI调度 ──")
    打印(字符串拼接("  AI触发数:         ", 转字符串(标记器.统计_AI触发数)))
    打印(字符串拼接("  AI空闲利用数:     ", 转字符串(标记器.统计_AI空闲利用数)))
    打印(字符串拼接("  AI预测预算(μs):   ", 转字符串(标记器.AI预测预算)))
    打印(字符串拼接("  AI交互强度:       ", 转字符串(标记器.AI交互强度)))
    打印(字符串拼接("  AI触发置信度:     ", 转字符串(标记器.AI触发置信度)))
    打印("[增量标记] ═══════════════════════════════════════")
}

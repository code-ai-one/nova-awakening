    字典设(r, "色彩空间", _图像合同_色彩空间)
    字典设(r, "最大宽", 转字符串(_图像合同_最大宽))
    字典设(r, "最大高", 转字符串(_图像合同_最大高))
    返回 r
}

// 视频管线合同
定义 可变 _视频合同_帧率 = 30
定义 可变 _视频合同_分辨率宽 = 1920
定义 可变 _视频合同_分辨率高 = 1080
定义 可变 _视频合同_编码 = "raw"
定义 可变 _视频合同_帧队列深度 = 3
定义 可变 _视频合同_AV同步模式 = "audio_master"

函数 视频合同_设置(帧率, 宽, 高, 编码, 队列深, 同步) {

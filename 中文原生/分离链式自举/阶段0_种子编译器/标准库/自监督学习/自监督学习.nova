导入("../基础.nova")


定义 SSL_随机态 = 77777
函数 SSL_随机() {
    SSL_随机态 = SSL_随机态 ^ (SSL_随机态 << 13)
    SSL_随机态 = SSL_随机态 ^ (SSL_随机态 >> 7)
    SSL_随机态 = SSL_随机态 ^ (SSL_随机态 << 17)
    如果 (SSL_随机态 < 0) { SSL_随机态 = 0 - SSL_随机态 }
    返回 SSL_随机态
}

// 掩码语言模型 (MLM / BERT-style)
函数 MLM_生成掩码(序列长度, 掩码率) {
    定义 可变 掩码 = []
    定义 可变 i = 0
    当 (i < 序列长度) {
        如果 (SSL_随机() % 1000 < 掩码率) {
            追加(掩码, 1)  // 被掩码
        } 否则 {
            追加(掩码, 0)
        }
        i = i + 1
    }
    返回 掩码
}

函数 MLM_应用掩码(token序列, 掩码, mask_token_id) {
    定义 n = 计数(token序列)
    定义 可变 掩码序列 = []
    定义 可变 i = 0
    当 (i < n) {
        如果 (i < 计数(掩码) 且 掩码[i] == 1) {
            // 80%用[MASK], 10%随机, 10%不变
            定义 r = SSL_随机() % 100
            如果 (r < 80) {
                追加(掩码序列, mask_token_id)
            } 否则 如果 (r < 90) {
                追加(掩码序列, SSL_随机() % 30000)  // 随机token
            } 否则 {
                追加(掩码序列, token序列[i])
            }
        } 否则 {
            追加(掩码序列, token序列[i])
        }
        i = i + 1
    }
    返回 掩码序列
}

函数 MLM_损失(预测logits列表, 真实token列表, 掩码) {
    定义 n = 计数(掩码)
    定义 可变 损失 = 0
    定义 可变 掩码数 = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (掩码[i] == 1) {
            // 交叉熵: CE = -log(归一化指数(对数值)[真实])
            // = -(对数值[真实] - log_sum_exp(对数值))
            // 整数近似: 先找max, 然后 log_sum_exp ≈ max + log(Σexp(x-max))
            如果 (i < 计数(预测logits列表) 且 i < 计数(真实token列表)) {
                定义 真实 = 真实token列表[i]
                定义 对数值 = 预测logits列表[i]
                如果 (真实 < 计数(对数值)) {
                    // 找logits最大值
                    定义 可变 最大 = 对数值[0]
                    定义 可变 j = 1
                    当 (j < 计数(对数值)) {
                        如果 (对数值[j] > 最大) { 最大 = 对数值[j] }
                        j = j + 1
                    }
                    // 计算 Σexp(logit - max) (×1000定点)
                    定义 可变 求和 = 0
                    j = 0
                    当 (j < 计数(对数值)) {
                        定义 差值 = 对数值[j] - 最大
                        // 整数exp近似: e^x ≈ 1000 + x + x*x/2000 (泰勒展开)
                        定义 可变 ex = 1000 + 差值 + 差值 * 差值 / 2000
                        如果 (ex < 1) { ex = 1 }
                        求和 = 求和 + ex
                        j = j + 1
                    }
                    // CE = max - 对数值[真实] + ln(求和/1000)×1000
                    // ln近似: ln(x) ≈ (x-1) - (x-1)^2/2 对x接近1
                    定义 可变 此CE = 最大 - 对数值[真实]
                    如果 (求和 > 1000) {
                        定义 ratio_m1 = (求和 - 1000) * 1000 / 求和
                        此CE = 此CE + ratio_m1
                    }
                    损失 = 损失 + 此CE
                }
            }
            掩码数 = 掩码数 + 1
        }
        i = i + 1
    }
    如果 (掩码数 == 0) { 返回 0 }
    返回 损失 / 掩码数
}

// 下一Token预测 (GPT-style)
函数 NTP_创建序列(token列表) {
    定义 n = 计数(token列表)
    如果 (n < 2) { 返回 [[], []] }
    定义 可变 输入 = []
    定义 可变 标签 = []
    定义 可变 i = 0
    当 (i < n - 1) {
        追加(输入, token列表[i])
        追加(标签, token列表[i + 1])
        i = i + 1
    }
    返回 [输入, 标签]
}

// 平均绝对误差: 掩码自编码器
函数 MAE_生成patch掩码(patch数, 掩码率) {
    定义 掩码数 = patch数 * 掩码率 / 1000
    定义 可变 掩码 = []
    定义 可变 i = 0
    当 (i < patch数) { 追加(掩码, 0)
    i = i + 1 }
    // 随机选择掩码位置
    i = 0
    当 (i < 掩码数) {
        定义 可变 位置 = SSL_随机() % patch数
        // 找未掩码的位置
        定义 可变 重试次数 = 0
        当 (掩码[位置] == 1 且 重试次数 < patch数) {
            位置 = (位置 + 1) % patch数
            重试次数 = 重试次数 + 1
        }
        掩码[位置] = 1
        i = i + 1
    }
    返回 掩码
}

函数 MAE_可见patch(所有patch, 掩码) {
    定义 可变 可见 = []
    定义 可变 可见索引 = []
    定义 可变 i = 0
    当 (i < 计数(所有patch)) {
        如果 (i < 计数(掩码) 且 掩码[i] == 0) {
            追加(可见, 所有patch[i])
            追加(可见索引, i)
        }
        i = i + 1
    }
    返回 [可见, 可见索引]
}

函数 MAE_重建损失(重建patch, 原始patch, 掩码) {
    定义 n = 计数(掩码)
    定义 可变 损失 = 0
    定义 可变 掩码数 = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (掩码[i] == 1) {  // 只在掩码位置计算损失
            如果 (i < 计数(重建patch) 且 i < 计数(原始patch)) {
                定义 r = 重建patch[i]
                定义 o = 原始patch[i]
                定义 维度 = 计数(r)
                定义 可变 patch损失 = 0
                定义 可变 j = 0
                当 (j < 维度) {
                    定义 可变 ov = 0
                    如果 (j < 计数(o)) { ov = o[j] }
                    定义 d = r[j] - ov
                    patch损失 = patch损失 + d * d / 1000
                    j = j + 1
                }
                损失 = 损失 + patch损失 / 维度
            }
            掩码数 = 掩码数 + 1
        }
        i = i + 1
    }
    如果 (掩码数 == 0) { 返回 0 }
    返回 损失 / 掩码数
}

// DINO: 自蒸馏
函数 DINO_锐化(概率, τ) {
    如果 (τ <= 0) { τ = 40 }  // 0.04×1000
    定义 n = 计数(概率)
    定义 可变 锐化 = []
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 v = 概率[i] * 1000 / τ
        定义 可变 e = 1000 + v
        如果 (e < 1) { e = 1 }
        追加(锐化, e)
        总和 = 总和 + e
        i = i + 1
    }
    如果 (总和 == 0) { 总和 = 1 }
    i = 0
    当 (i < n) { 锐化[i] = 锐化[i] * 1000 / 总和
    i = i + 1 }
    返回 锐化
}

函数 DINO_损失(学生输出, 教师输出, τ_s, τ_t) {
    定义 学生概率 = DINO_锐化(学生输出, τ_s)
    定义 教师概率 = DINO_锐化(教师输出, τ_t)
    // 交叉熵: H(p_t, p_s) = -Σ p_t·log(p_s)
    定义 n = 计数(学生概率)
    定义 可变 ce = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (学生概率[i] > 0) {
            ce = ce + 教师概率[i] * (1000 - 学生概率[i]) / 1000
        }
        i = i + 1
    }
    返回 ce
}

// I-JEPA: 联合嵌入预测架构
函数 JEPA_目标块(特征图, 块起始, 块大小) {
    定义 可变 块 = []
    定义 可变 i = 块起始
    当 (i < 块起始 + 块大小 且 i < 计数(特征图)) {
        追加(块, 特征图[i])
        i = i + 1
    }
    返回 块
}

函数 JEPA_预测损失(预测嵌入, 目标嵌入) {
    定义 n = 计数(预测嵌入)
    定义 可变 损失 = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (i < 计数(目标嵌入)) { tv = 目标嵌入[i] }
        定义 d = 预测嵌入[i] - tv
        损失 = 损失 + d * d / 1000
        i = i + 1
    }
    如果 (n == 0) { 返回 0 }
    返回 损失 / n
}

// 对比预测编码 (CPC)
函数 CPC_信息NCE(上下文, 正样本, 负样本列表, 步数) {
    定义 可变 总损失 = 0
    定义 可变 t = 0
    当 (t < 步数) {
        如果 (t < 计数(正样本)) {
            定义 d = 计数(上下文)
            定义 可变 i = 0
            当 (i < d) {
                如果 (i < 计数(正样本[t])) { 正分 = 正分 + 上下文[i] * 正样本[t][i] / 1000 }
                i = i + 1
            }
定义 可变 正exp = 1000 + 正分
            如果 (正exp < 1) { 正exp = 1 }
            定义 可变 总exp = 正exp
            定义 可变 j = 0
            当 (j < 计数(负样本列表)) {
                i = 0
                当 (i < d) {
                    如果 (i < 计数(负样本列表[j])) { 负分 = 负分 + 上下文[i] * 负样本列表[j][i] / 1000 }
                    i = i + 1
                }
定义 可变 负exp = 1000 + 负分
                如果 (负exp < 1) { 负exp = 1 }
                总exp = 总exp + 负exp
                j = j + 1
            }
            如果 (总exp == 0) { 总exp = 1 }
            总损失 = 总损失 + 总exp * 1000 / 正exp
        }
        t = t + 1
    }
    如果 (步数 == 0) { 返回 0 }
    返回 总损失 / 步数
}

// 去噪自编码 (DAE)
函数 DAE_加噪(数据, 噪声率) {
    定义 n = 计数(数据)
    定义 可变 噪声数据 = []
    定义 可变 i = 0
    当 (i < n) {
        如果 (SSL_随机() % 1000 < 噪声率) {
            追加(噪声数据, 0)  // 置零噪声
        } 否则 {
            追加(噪声数据, 数据[i])
        }
        i = i + 1
    }
    返回 噪声数据
}

函数 DAE_损失(重建, 原始) {
    定义 n = 计数(原始)
    定义 可变 损失 = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 r = 0
        如果 (i < 计数(重建)) { r = 重建[i] }
        定义 d = r - 原始[i]
        损失 = 损失 + d * d / 1000
        i = i + 1
    }
    如果 (n == 0) { 返回 0 }
    返回 损失 / n
}

// 旋转预测 (RotNet)
函数 旋转_应用(特征矩阵, _行, _列, 旋转度) {
    // 0=0°, 1=90°, 2=180°, 3=270°
    定义 可变 结果 = []
    如果 (旋转度 == 0) { 返回 特征矩阵 }
    如果 (旋转度 == 2) {
        // 180°: 反转
        定义 n = 计数(特征矩阵)
        定义 可变 i = n - 1
        当 (i >= 0) { 追加(结果, 特征矩阵[i])
        i = i - 1 }
        返回 结果
    }
    返回 特征矩阵  // 90°/270°需要2D转置
}

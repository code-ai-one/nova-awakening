
导入("./类型定义.nova")
导入("./错误码.nova")
导入("./进程凭证.nova")
导入("./进程描述符.nova")
导入("../标准/原生字符串.nova")
导入("./进程组.nova")
导入("./进程限制.nova")
导入("./整数转字符串.nova")
导入("./进程退出.nova")
导入("./空闲进程.nova")
导入("./执行分叉.nova")
导入("./验证克隆标.nova")
导入("./安全管理上.nova")

定义 任务角色_用户 = "用户"
定义 任务角色_内核 = "内核"
定义 任务角色_空闲 = "空闲"
定义 任务角色_服务 = "服务"

结构 任务档 {
    名称,
    角色,
    任务,
    凭证,
    限制,
    组号,
    会话号,
    父号,
    标志,
}

结构 任务摘要 {
    名称,
    角色,
    标识,
    组号,
    会话号,
    父号,
    状态,
    优先级,
    nice值,
    权重,
    调度,
    内核线程,
    退出中,
    等待状态,
}

定义 可变 任务账本 = []
定义 可变 任务建数 = 0
定义 可变 任务退数 = 0
定义 可变 任务等数 = 0
定义 可变 任务克隆数 = 0
定义 可变 任务执行数 = 0

函数 任务布尔串(值) {
    如果 (值) { 返回 "true" }
    返回 "false"
}

函数 任务角色名(角色) {
    如果 (角色 == 任务角色_用户) { 返回 "用户" }
    如果 (角色 == 任务角色_内核) { 返回 "内核" }
    如果 (角色 == 任务角色_空闲) { 返回 "空闲" }
    如果 (角色 == 任务角色_服务) { 返回 "服务" }
    返回 "未知"
}

函数 任务状态名(状态) {
    如果 (状态 == 进程_运行) { 返回 "运行" }
    如果 (状态 == 进程_等待) { 返回 "等待" }
    如果 (状态 == 进程_就绪) { 返回 "就绪" }
    如果 (状态 == 进程_停止) { 返回 "停止" }
    返回 "未知"
}

函数 进程任务_建档(任务, 名称, 角色) {
    定义 档 = 堆_分配(任务档)
    档.名称 = 名称
    档.角色 = 角色
    档.任务 = 任务
    档.凭证 = 凭证_创建_root()
    档.限制 = 默认资源限制()
    档.组号 = 进程_PGID(任务)
    档.会话号 = 进程_SID(任务)
    档.父号 = 0
    定义 父 = 进程_父(任务)
    如果 (父 != 0) {
        档.父号 = 进程_PID(父)
    }
    档.标志 = 进程_标志(任务)
    返回 档
}

函数 进程任务_挂账(档) {
    追加(任务账本, 档)
    任务建数 = 任务建数 + 1
    返回 档
}

函数 进程任务_创建(标识, 名称, 优先级, 角色) {
    定义 任务 = 进程_创建(标识, 名称, 优先级)
    定义 档 = 进程任务_建档(任务, 名称, 角色)
    返回 进程任务_挂账(档)
}

函数 进程任务_创建用户(标识, 名称, 优先级) {
    返回 进程任务_创建(标识, 名称, 优先级, 任务角色_用户)
}

函数 进程任务_创建服务(标识, 名称, 优先级) {
    返回 进程任务_创建(标识, 名称, 优先级, 任务角色_服务)
}

函数 进程任务_创建内核线程(名称, 优先级) {
    定义 任务 = kernel_thread(名称, 优先级)
    定义 档 = 进程任务_建档(任务, 名称, 任务角色_内核)
    返回 进程任务_挂账(档)
}

函数 进程任务_创建空闲(CPU号) {
    定义 任务 = idle进程_创建(CPU号)
    定义 档 = 进程任务_建档(任务, "空闲" + 整数转字符串(CPU号), 任务角色_空闲)
    返回 进程任务_挂账(档)
}

函数 进程任务_查按PID(pid) {
    定义 可变 i = 0
    当 (i < 计数(任务账本)) {
        定义 档 = 任务账本[i]
        如果 (进程_PID(档.任务) == pid) { 返回 档 }
        i = i + 1
    }
    返回 0
}

函数 进程任务_查按名称(名称) {
    定义 可变 i = 0
    当 (i < 计数(任务账本)) {
        定义 档 = 任务账本[i]
        如果 (档.名称 == 名称) { 返回 档 }
        i = i + 1
    }
    返回 0
}

函数 进程任务_PID(档) { 返回 进程_PID(档.任务) }
函数 进程任务_名称(档) { 返回 档.名称 }
函数 进程任务_角色(档) { 返回 档.角色 }
函数 进程任务_状态(档) { 返回 进程_状态(档.任务) }
函数 进程任务_优先级(档) { 返回 进程_优先级(档.任务) }
函数 进程任务_nice(档) { 返回 进程_nice(档.任务) }
函数 进程任务_权重(档) { 返回 进程_权重(档.任务) }
函数 进程任务_调度策略(档) { 返回 进程_调度策略(档.任务) }
函数 进程任务_父号(档) { 返回 档.父号 }
函数 进程任务_组号(档) { 返回 档.组号 }
函数 进程任务_会话号(档) { 返回 档.会话号 }
函数 进程任务_UID(档) { 返回 进程_UID(档.任务) }
函数 进程任务_GID(档) { 返回 进程_GID(档.任务) }
函数 进程任务_TGID(档) { 返回 进程_TGID(档.任务) }
函数 进程任务_是内核线程(档) { 返回 进程_是内核线程(档.任务) }
函数 进程任务_是退出中(档) { 返回 进程_是正在退出(档.任务) }
函数 进程任务_是运行(档) { 返回 进程_是运行(档.任务) }
函数 进程任务_状态名(档) { 返回 任务状态名(进程任务_状态(档)) }

函数 进程任务_设状态(档, 状态) {
    进程_设置状态(档.任务, 状态)
}

函数 进程任务_设优先级(档, 优先级) {
    设置(档.任务, T_优先级, 优先级)
    设置(档.任务, T_权重, nice到权重(进程_nice(档.任务)))
}

函数 进程任务_设nice(档, nice值) {
    设置(档.任务, T_nice值, nice值)
    设置(档.任务, T_优先级, nice到优先级(nice值))
    设置(档.任务, T_权重, nice到权重(nice值))
}

函数 进程任务_设标志(档, 标志) {
    进程_设标志(档.任务, 标志)
    档.标志 = 进程_标志(档.任务)
}

函数 进程任务_清标志(档, 标志) {
    进程_清标志(档.任务, 标志)
    档.标志 = 进程_标志(档.任务)
}

函数 进程任务_分配凭证(档, uid, gid) {
    档.凭证 = 凭证_创建(uid, gid)
    返回 档.凭证
}

函数 进程任务_继承凭证(父档, 子档) {
    子档.凭证 = 凭证_复制(父档.凭证)
    返回 子档.凭证
}

函数 进程任务_设UID(档, uid) {
    返回 do_setuid(档.凭证, uid)
}

函数 进程任务_设GID(档, gid) {
    返回 do_setgid(档.凭证, gid)
}

函数 进程任务_授权(档, 能力) {
    凭证_授予能力(档.凭证, 能力)
}

函数 进程任务_撤权(档, 能力) {
    凭证_撤销能力(档.凭证, 能力)
}

函数 进程任务_是root(档) {
    返回 凭证_是root(档.凭证)
}

函数 进程任务_有能力(档, 能力) {
    返回 凭证_有能力(档.凭证, 能力)
}

函数 进程任务_权限检查(档, 所需uid) {
    返回 凭证_权限检查(档.凭证, 所需uid)
}

函数 进程任务_配置默认限制(档) {
    档.限制 = 默认资源限制()
    返回 档.限制
}

函数 进程任务_继承限制(父档, 子档) {
    rlimit_继承(父档.任务, 子档.任务)
    子档.限制 = 父档.限制
}

函数 进程任务_设限制(档, 资源, 新soft, 新hard) {
    返回 sys_setrlimit(资源, 新soft, 新hard, 档.限制, 进程任务_是root(档))
}

函数 进程任务_查限制(档, 资源) {
    返回 sys_getrlimit(资源, 档.限制)
}

函数 进程任务_检查文件数(档, 新增) {
    返回 进程限制_检查文件数(档.任务, 新增)
}

函数 进程任务_检查内存(档, 请求大小) {
    返回 进程限制_检查内存(档.任务, 请求大小)
}

函数 进程任务_检查进程数(档, 当前进程数) {
    返回 检查进程数限制(档.限制, 当前进程数)
}

函数 进程任务_设置组(档, pgid) {
    如果 (进程组_查找(pgid) == 0) {
        进程组_创建(pgid, 进程任务_PID(档))
    }
    进程组_添加成员(pgid, 进程任务_PID(档))
    do_setpgid(进程任务_PID(档), pgid)
    档.组号 = pgid
    返回 pgid
}

函数 进程任务_建会话(档) {
    定义 sid = do_setsid()
    档.会话号 = sid
    返回 sid
}

函数 进程任务_前台组(档, pgid) {
    会话_设置前台组(档.会话号, pgid)
}

函数 进程任务_取前台组(档) {
    返回 会话_获取前台组(档.会话号)
}

函数 进程任务_发组信号(档, 信号) {
    返回 向进程组发送信号(档.组号, 信号)
}

函数 进程任务_是孤儿组(档) {
    返回 进程组_是孤儿(档.组号)
}

函数 进程任务_分叉(父档, 名称) {
    定义 子任务 = do_fork(父档.任务, 名称)
    定义 子档 = 进程任务_建档(子任务, 名称, 父档.角色)
    子档.父号 = 进程任务_PID(父档)
    子档.组号 = 父档.组号
    子档.会话号 = 父档.会话号
    进程任务_继承凭证(父档, 子档)
    进程任务_继承限制(父档, 子档)
    进程任务_挂账(子档)
    任务克隆数 = 任务克隆数 + 1
    返回 子档
}

函数 进程任务_克隆(父档, 名称, 标志) {
    如果 (!验证clone标志(标志)) { 返回 0 }
    定义 子任务 = do_clone(父档.任务, 名称, 标志)
    定义 子档 = 进程任务_建档(子任务, 名称, 父档.角色)
    子档.父号 = 进程任务_PID(父档)
    子档.组号 = 父档.组号
    子档.会话号 = 父档.会话号
    进程任务_继承凭证(父档, 子档)
    进程任务_继承限制(父档, 子档)
    进程任务_挂账(子档)
    任务克隆数 = 任务克隆数 + 1
    返回 子档
}

函数 进程任务_执行(档, 程序路径, 参数, 环境变量) {
    任务执行数 = 任务执行数 + 1
    返回 do_exec(档.任务, 程序路径, 参数, 环境变量)
}

函数 进程任务_退出(档, 退出码) {
    任务退数 = 任务退数 + 1
    do_exit(档.任务, 退出码)
}

函数 进程任务_组退出(档, 退出码) {
    任务退数 = 任务退数 + 1
    do_exit_group(档.任务, 退出码)
}

函数 进程任务_等待(父档) {
    任务等数 = 任务等数 + 1
    返回 do_wait(父档.任务)
}

函数 进程任务_等待指定(父档, pid, 选项) {
    任务等数 = 任务等数 + 1
    返回 do_waitpid(父档.任务, pid, 选项)
}

函数 进程任务_回收僵尸(档) {
    回收僵尸(档.任务)
}

函数 进程任务_关闭文件(档) {
    关闭所有文件(档.任务)
}

函数 进程任务_释放地址空间(档) {
    释放地址空间(档.任务)
}

函数 进程任务_通知父(档) {
    通知父进程(档.任务)
}

函数 进程任务_转交孤儿(档) {
    孤儿转交(档.任务)
}

函数 进程任务_虚拟运行时(档) {
    返回 进程_虚拟运行时间(档.任务)
}

函数 进程任务_增加虚拟运行时(档, 增量) {
    进程_增加虚拟运行时间(档.任务, 增量)
}

函数 进程任务_摘要(档) {
    定义 摘 = 堆_分配(任务摘要)
    摘.名称 = 档.名称
    摘.角色 = 任务角色名(档.角色)
    摘.标识 = 进程任务_PID(档)
    摘.组号 = 档.组号
    摘.会话号 = 档.会话号
    摘.父号 = 档.父号
    摘.状态 = 进程任务_状态名(档)
    摘.优先级 = 进程任务_优先级(档)
    摘.nice值 = 进程任务_nice(档)
    摘.权重 = 进程任务_权重(档)
    摘.调度 = 进程任务_调度策略(档)
    摘.内核线程 = 进程任务_是内核线程(档)
    摘.退出中 = 进程任务_是退出中(档)
    摘.等待状态 = !进程任务_是运行(档)
    返回 摘
}

函数 进程任务_摘要串(档) {
    定义 摘 = 进程任务_摘要(档)
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "{")
    字符串构建器_追加(建, "\"名称\":\"")
    字符串构建器_追加(建, 摘.名称)
    字符串构建器_追加(建, "\",\"角色\":\"")
    字符串构建器_追加(建, 摘.角色)
    字符串构建器_追加(建, "\",\"标识\":")
    字符串构建器_追加(建, 整数转字符串(摘.标识))
    字符串构建器_追加(建, ",\"状态\":\"")
    字符串构建器_追加(建, 摘.状态)
    字符串构建器_追加(建, "\",\"优先级\":")
    字符串构建器_追加(建, 整数转字符串(摘.优先级))
    字符串构建器_追加(建, ",\"nice\":")
    字符串构建器_追加(建, 整数转字符串(摘.nice值))
    字符串构建器_追加(建, ",\"权重\":")
    字符串构建器_追加(建, 整数转字符串(摘.权重))
    字符串构建器_追加(建, ",\"组号\":")
    字符串构建器_追加(建, 整数转字符串(摘.组号))
    字符串构建器_追加(建, ",\"会话号\":")
    字符串构建器_追加(建, 整数转字符串(摘.会话号))
    字符串构建器_追加(建, ",\"内核线程\":")
    字符串构建器_追加(建, 任务布尔串(摘.内核线程))
    字符串构建器_追加(建, ",\"退出中\":")
    字符串构建器_追加(建, 任务布尔串(摘.退出中))
    字符串构建器_追加(建, "}")
    返回 字符串构建器_构建(建)
}

函数 进程任务_批量摘要串(列表) {
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "[")
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (i > 0) { 字符串构建器_追加(建, ",") }
        字符串构建器_追加(建, 进程任务_摘要串(列表[i]))
        i = i + 1
    }
    字符串构建器_追加(建, "]")
    返回 字符串构建器_构建(建)
}

函数 进程任务_统计串() {
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "{")
    字符串构建器_追加(建, "\"建数\":")
    字符串构建器_追加(建, 整数转字符串(任务建数))
    字符串构建器_追加(建, ",\"退数\":")
    字符串构建器_追加(建, 整数转字符串(任务退数))
    字符串构建器_追加(建, ",\"等数\":")
    字符串构建器_追加(建, 整数转字符串(任务等数))
    字符串构建器_追加(建, ",\"克隆数\":")
    字符串构建器_追加(建, 整数转字符串(任务克隆数))
    字符串构建器_追加(建, ",\"执行数\":")
    字符串构建器_追加(建, 整数转字符串(任务执行数))
    字符串构建器_追加(建, ",\"fork总数\":")
    字符串构建器_追加(建, 整数转字符串(fork_计数()))
    字符串构建器_追加(建, ",\"fork失败\":")
    字符串构建器_追加(建, 整数转字符串(fork_失败计数()))
    字符串构建器_追加(建, ",\"账本数\":")
    字符串构建器_追加(建, 整数转字符串(计数(任务账本)))
    字符串构建器_追加(建, "}")
    返回 字符串构建器_构建(建)
}

函数 进程任务_系统串() {
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "{")
    字符串构建器_追加(建, "\"任务\":")
    字符串构建器_追加(建, 进程任务_统计串())
    字符串构建器_追加(建, ",\"进程组\":\"")
    字符串构建器_追加(建, 进程组_完整统计())
    字符串构建器_追加(建, "\",\"退出\":\"")
    字符串构建器_追加(建, 进程退出_完整统计())
    字符串构建器_追加(建, "\",\"限制\":\"")
    字符串构建器_追加(建, 进程限制_完整统计())
    字符串构建器_追加(建, "\",\"空闲\":\"")
    字符串构建器_追加(建, idle_完整统计())
    字符串构建器_追加(建, "\"}")
    返回 字符串构建器_构建(建)
}

函数 进程任务_健康检查(档) {
    定义 可变 错数 = 0
    如果 (档 == 0) { 返回 1 }
    如果 (档.任务 == 0) { 错数 = 错数 + 1 }
    如果 (档.凭证 == 0) { 错数 = 错数 + 1 }
    如果 (档.限制 == 0) { 错数 = 错数 + 1 }
    如果 (凭证_健康检查() != 0) { 错数 = 错数 + 1 }
    如果 (进程组_健康检查() != 0) { 错数 = 错数 + 1 }
    返回 错数
}

函数 进程任务_账本健康检查() {
    定义 可变 错数 = 0
    定义 可变 i = 0
    当 (i < 计数(任务账本)) {
        错数 = 错数 + 进程任务_健康检查(任务账本[i])
        i = i + 1
    }
    返回 错数
}

函数 进程任务_活跃数() {
    定义 可变 数 = 0
    定义 可变 i = 0
    当 (i < 计数(任务账本)) {
        如果 (!进程任务_是退出中(任务账本[i])) {
            数 = 数 + 1
        }
        i = i + 1
    }
    返回 数
}

函数 进程任务_用户数() {
    定义 可变 数 = 0
    定义 可变 i = 0
    当 (i < 计数(任务账本)) {
        如果 (任务账本[i].角色 == 任务角色_用户) {
            数 = 数 + 1
        }
        i = i + 1
    }
    返回 数
}

函数 进程任务_内核数() {
    定义 可变 数 = 0
    定义 可变 i = 0
    当 (i < 计数(任务账本)) {
        如果 (任务账本[i].角色 == 任务角色_内核 || 任务账本[i].角色 == 任务角色_空闲) {
            数 = 数 + 1
        }
        i = i + 1
    }
    返回 数
}

函数 进程任务_摘要总览() {
    定义 建 = 字符串构建器_创建()
    字符串构建器_追加(建, "{")
    字符串构建器_追加(建, "\"活跃数\":")
    字符串构建器_追加(建, 整数转字符串(进程任务_活跃数()))
    字符串构建器_追加(建, ",\"用户数\":")
    字符串构建器_追加(建, 整数转字符串(进程任务_用户数()))
    字符串构建器_追加(建, ",\"内核数\":")
    字符串构建器_追加(建, 整数转字符串(进程任务_内核数()))
    字符串构建器_追加(建, ",\"健康错误\":")
    字符串构建器_追加(建, 整数转字符串(进程任务_账本健康检查()))
    字符串构建器_追加(建, ",\"明细\":")
    字符串构建器_追加(建, 进程任务_批量摘要串(任务账本))
    字符串构建器_追加(建, "}")
    返回 字符串构建器_构建(建)
}

函数 进程任务_示例流程() {
    定义 根 = 进程任务_创建服务(1, "系统根", 120)
    进程任务_分配凭证(根, 0, 0)
    进程任务_配置默认限制(根)
    进程任务_建会话(根)
    进程任务_设置组(根, 1)

    定义 服务 = 进程任务_创建服务(2, "外联服", 110)
    进程任务_继承凭证(根, 服务)
    进程任务_继承限制(根, 服务)
    进程任务_设置组(服务, 1)

    定义 用户 = 进程任务_创建用户(100, "前台用户", 100)
    进程任务_分配凭证(用户, 1000, 1000)
    进程任务_设置组(用户, 100)
    进程任务_建会话(用户)
    进程任务_前台组(用户, 100)

    定义 子 = 进程任务_分叉(用户, "前台子进程")
    进程任务_执行(子, "/系统/壳", ["-c", "echo"], [])
    进程任务_检查文件数(子, 1)
    进程任务_检查内存(子, 4096)

    定义 工作者 = 进程任务_创建内核线程("后台核", 90)
    定义 空闲 = 进程任务_创建空闲(0)
    进程任务_发组信号(用户, 15)
    进程任务_等待指定(用户, 进程任务_PID(子), 0)
    进程任务_退出(子, 0)
    进程任务_回收僵尸(子)

    返回 进程任务_摘要总览()
}

定义 可变 AI_进程任务_运行指标 = 0
定义 可变 AI_进程任务_异常指标 = 0

函数 AI_进程任务_自诊断() {
    AI_进程任务_运行指标 = 0
    返回 AI_进程任务_运行指标
}

函数 AI_进程任务_优化建议() {
    定义 指标 = AI_进程任务_自诊断()
    返回 "进程任务状态正常"
}

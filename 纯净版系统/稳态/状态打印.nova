// NovaOS GPU统一状态打印与诊断系统
// 功能: GPU基础信息/热管理/显存健康/PCIe链路/性能计数/显示输出/
//       工作负载分析/AI驱动异常预测/错误历史/电源状态
// 理论: 基于自研「GPU健康多维度评分」模型 — 将温度/显存使用率/ECC错误率/
//       PCIe重训练次数/功耗偏差 等多维指标归一化为0~100分健康分数,
//       驱动运行时用滑动窗口跟踪分数趋势, 下降时AI发预警

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/中断表注册处.nova")
导入("../推理/智能渠道.nova")
导入("./统一操作接.nova")
导入("../推理/值乘.nova")
导入("./图处枚举.nova")
导入("./图处复位.nova")
导入("../中枢/整数转字符串.nova")

// §1 GPU热力学与电源状态结构

结构 GPU热管理状态 {
    核心温度,              // i32: 度氏
    显存温度,
    热点温度,              // i32: 芯片最高点
    风扇转速_RPM,
    风扇占空比,            // u8: 0-100%
    正在降频,              // 布尔: 是否因过热降频
    温度阈值_降频,
    温度阈值_关机,
}

结构 GPU电源状态 {
    总功耗_mW,              // u32: 当前总功耗
    TDP_mW,                // u32: 额定功耗
    板载功耗_mW,
    核心电压_mV,
    显存电压_mV,
    电源限制激活,
    过流保护触发次数,
}

// §2 显存健康与ECC状态

结构 GPU显存状态 {
    总容量_MB,
    已使用_MB,
    空闲_MB,
    BAR_大小_MB,            // u32: PCIe BAR分配
    ECC_单位纠正,          // u64: 可纠正错误累计
    ECC_双位不可纠正,      // u64: 不可纠正错误累计
    显存时钟_MHz,
    显存效率,              // u32: 实际带宽/理论带宽*100
    页面退休数,            // u64: 被内核回收的GPU页数
}

结构 GPU显存带宽采样 {
    读带宽_MBps,
    写带宽_MBps,
    时间戳,
}

// §3 PCIe链路状态

结构 PCIe链路状态 {
    当前代,                // u8: 1/2/3/4/5
    最大代,
    当前宽度,              // u8: x1/x4/x8/x16
    最大宽度,
    重训练次数,            // u32: 链路重新训练次数
    CRC错误,
    编码错误,              // u64: 8b/10b或128b/130b
    ASPM状态,              // u8: 0=禁用, 1=L0s, 2=L1
}

// §4 性能计数器与工作负载

结构 GPU性能计数 {
    GPU利用率,             // u8: 0-100%
    显存利用率,            // u8: 0-100%
    编码器利用率,          // u8: 视频编码器
    解码器利用率,
    核心时钟_MHz,
    显存时钟_MHz,
    Shader活跃数,
    当前提交队列深度,
}

结构 GPU工作负载统计 {
    总提交命令数,
    总绘制调用,
    总计算调度,
    总DMA传输字节,
    帧缓冲翻转次数,
    帧延迟_累计us,
    帧延迟_最大us,
    超时重置次数,          // u32: GPU挂起导致的重置
}

// §5 显示输出状态

定义 最大显示输出 = 8

结构 显示输出状态 {
    接口类型,              // u8: 0=无, 1=HDMI, 2=DP, 3=DVI, 4=VGA, 5=USB-C
    已连接,
    宽度,
    高度,
    刷新率_mHz,            // u32: 毫赫兹
    色深,                  // u8: 8/10/12
    HDR激活,
    自适应同步,            // 布尔: VRR/FreeSync/G-Sync
}

// §6 错误历史结构

定义 GPU错误历史_容量 = 32

结构 GPU错误条目 {
    时间戳,
    错误类型,              // u16: 0=总线错误 1=显存ECC 2=温度 3=超时 4=驱动
    严重级,              // u8: 0=信息 1=警告 2=错误 3=致命
    描述,                  // 字符串[128]
    恢复已尝试,
    已恢复,
}

结构 GPU错误历史 {
    条目,                  // 数组[32]
    写索引,
    总错误数,
    致命错误数,
}

// §7 【Nova原创】GPU健康多维度评分系统
// 理论: 将多维硬件指标归一化为0~100分的健康分数
//   健康分 = Σ(Wi × Si), 其中 Si∈[0,100]
//   维度: 温度(20%) + 显存健康(25%) + PCIe稳定(15%) + 功耗(15%) + 错误率(25%)

定义 健康权重_温度 = 20
定义 健康权重_显存 = 25
定义 健康权重_PCIe = 15
定义 健康权重_功耗 = 15
定义 健康权重_错误 = 25

定义 健康窗口_大小 = 64

结构 GPU健康跟踪器 {
    分数历史,              // 数组[64]: 滑动窗口健康分数
    写索引,
    当前分数,              // u32: 0~100
    最低分数,
    AI预警已发,
    上次计算时间,
}

定义 可变 GPU健康 = GPU健康跟踪器 {}
定义 可变 GPU错误记录 = GPU错误历史 {}

// §8 架构名称映射

函数 NV_架构名称(代) {
    如果 (代 >= 0x1A0) { 返回 "Blackwell" }
    如果 (代 >= 0x190) { 返回 "Ada Lovelace" }
    如果 (代 >= 0x170) { 返回 "Ampere" }
    如果 (代 >= 0x160) { 返回 "Turing" }
    如果 (代 >= 0x140) { 返回 "Volta" }
    如果 (代 >= 0x130) { 返回 "Pascal" }
    如果 (代 >= 0x110) { 返回 "Maxwell" }
    如果 (代 >= 0xE0) { 返回 "Kepler" }
    如果 (代 >= 0xC0) { 返回 "Fermi" }
    返回 "Tesla"
}

函数 AMD_架构名称(代) {
    如果 (代 >= 3000) { 返回 "CDNA 3" }
    如果 (代 >= 2000) { 返回 "CDNA 2" }
    如果 (代 >= 1000) { 返回 "CDNA 1" }
    如果 (代 >= 400) { 返回 "RDNA 4" }
    如果 (代 >= 300) { 返回 "RDNA 3" }
    如果 (代 >= 200) { 返回 "RDNA 2" }
    如果 (代 >= 100) { 返回 "RDNA 1" }
    如果 (代 >= 50) { 返回 "GCN 5 (Vega)" }
    如果 (代 >= 40) { 返回 "GCN 4 (Polaris)" }
    如果 (代 >= 30) { 返回 "GCN 3" }
    如果 (代 >= 20) { 返回 "GCN 2" }
    返回 "GCN 1"
}

函数 显示接口名称(类型) {
    如果 (类型 == 1) { 返回 "HDMI" }
    如果 (类型 == 2) { 返回 "DisplayPort" }
    如果 (类型 == 3) { 返回 "DVI" }
    如果 (类型 == 4) { 返回 "VGA" }
    如果 (类型 == 5) { 返回 "USB-C/DP" }
    返回 "未知"
}

函数 PCIe代号名称(代) {
    如果 (代 == 1) { 返回 "Gen1 2.5GT/s" }
    如果 (代 == 2) { 返回 "Gen2 5GT/s" }
    如果 (代 == 3) { 返回 "Gen3 8GT/s" }
    如果 (代 == 4) { 返回 "Gen4 16GT/s" }
    如果 (代 == 5) { 返回 "Gen5 32GT/s" }
    返回 "未知"
}

// §9 主状态打印: 综合信息输出

函数 图处_统一打印状态() {
    如果 (当前图处 == 空) {
        内核信息("图处统一接口: 无图处")
        返回
    }

    内核信息("══════════════ GPU综合状态 ══════════════")
    内核信息("  图处: " + 当前图处.厂商名 + " " + 当前图处.型号名)
    内核信息("  驱动: " + 图处_驱动类型名())
    内核信息("  显存: " + 整数转字符串(当前图处.显存大小_MB) + "MB")

    // 厂商特定信息
    如果 (当前驱动类型 == DRV_NVIDIA) {
        打印_NV状态()
    } 否则如果 (当前驱动类型 == DRV_AMD) {
        打印_AMD状态()
    }

    // 通用能力
    定义 可变 能力 = ""
    如果 (图处_有光追()) { 能力 = 能力 + "光追 " }
    如果 (图处_有AI加速器()) { 能力 = 能力 + "AI加速 " }
    如果 (图处_有计算能力()) { 能力 = 能力 + "计算 " }
    如果 (图处_有编码器()) { 能力 = 能力 + "视频编码 " }
    内核信息("  能力: " + 能力)
    内核信息("══════════════════════════════════════════")
}

函数 打印_NV状态() {
    定义 nv = NV_获取状态()
    内核信息("  架构: " + NV_架构名称(nv.架构代))
    内核信息("  SM: %d  GPC: %d  TPC/GPC: %d", nv.SM数, nv.GPC数, nv.TPC每_GPC)
    内核信息("  CUDA核心: %d  Tensor核心: %d  RT核心: %d",
             nv.CUDA核心数, nv.Tensor核心数, nv.RT核心数)
    内核信息("  显存类型: " + nv.显存类型 + " " + 整数转字符串(nv.显存总线宽) + "bit")
    内核信息("  通道: %d  NVLink: %d", nv.通道数, nv.NVLink连接数)
}

函数 打印_AMD状态() {
    定义 amd = AMD_获取状态()
    内核信息("  架构: " + AMD_架构名称(amd.架构代))
    内核信息("  CU: %d  SE: %d  WGP/SA: %d", amd.CU总数, amd.SE数, amd.WGP每_SA)
    内核信息("  流处理器: %d  TMU: %d  ROP: %d",
             amd.流处理器数, amd.TMU数, amd.ROP数)
    内核信息("  显存类型: " + amd.显存类型 + " " + 整数转字符串(amd.显存总线宽) + "bit")
    内核信息("  DCN: v%d  Infinity Cache: %dMB", amd.DCN版本, amd.无限缓存_MB)
}

// §10 热管理状态打印

函数 图处_打印热状态() {
    如果 (当前图处 == 空) { 返回 }
    定义 热 = 图处_获取热管理状态()
    内核信息("── 热管理 ──")
    内核信息("  核心: %d°C  显存: %d°C  热点: %d°C", 热.核心温度, 热.显存温度, 热.热点温度)
    内核信息("  风扇: %dRPM (%d%%)", 热.风扇转速_RPM, 热.风扇占空比)

    如果 (热.正在降频) {
        内核信息("  ⚠ 正在热降频! 阈值: %d°C", 热.温度阈值_降频)
    }
    如果 (热.核心温度 >= 热.温度阈值_降频 - 5) {
        内核信息("  ⚠ 温度接近降频阈值!")
    }
}

// §11 显存详细状态打印

函数 图处_打印显存状态() {
    如果 (当前图处 == 空) { 返回 }
    定义 显存 = 图处_获取显存状态()
    内核信息("── 显存 ──")
    内核信息("  总量: %dMB  已用: %dMB  空闲: %dMB  利用率: %d%%",
             显存.总容量_MB, 显存.已使用_MB, 显存.空闲_MB,
             显存.已使用_MB * 100 / 显存.总容量_MB)
    内核信息("  时钟: %dMHz  BAR: %dMB", 显存.显存时钟_MHz, 显存.BAR_大小_MB)
    内核信息("  效率: %d%%  页退休: %d页", 显存.显存效率, 显存.页面退休数)

    // ECC状态
    如果 (显存.ECC_单位纠正 > 0 || 显存.ECC_双位不可纠正 > 0) {
        内核信息("  ECC: 可纠正=%d  不可纠正=%d",
                 显存.ECC_单位纠正, 显存.ECC_双位不可纠正)
        如果 (显存.ECC_双位不可纠正 > 0) {
            内核信息("  ⚠ 存在不可纠正显存错误! 建议RMA")
        }
    } 否则 {
        内核信息("  ECC: 无错误")
    }
}

// §12 PCIe链路状态打印

函数 图处_打印PCIe状态() {
    如果 (当前图处 == 空) { 返回 }
    定义 pcie = 图处_获取PCIe状态()
    内核信息("── PCIe ──")
    内核信息("  当前: %s x%d  最大: %s x%d",
             PCIe代号名称(pcie.当前代), pcie.当前宽度,
             PCIe代号名称(pcie.最大代), pcie.最大宽度)

    // 检查降级
    如果 (pcie.当前代 < pcie.最大代 || pcie.当前宽度 < pcie.最大宽度) {
        内核信息("  ⚠ PCIe链路未以最大速度运行!")
    }

    内核信息("  重训练: %d次  CRC错误: %d  编码错误: %d",
             pcie.重训练次数, pcie.CRC错误, pcie.编码错误)

    如果 (pcie.重训练次数 > 10) {
        内核信息("  ⚠ 重训练次数过高, 可能存在硬件问题")
    }

    定义 aspm_名 = "禁用"
    如果 (pcie.ASPM状态 == 1) { aspm_名 = "L0s" }
    否则如果 (pcie.ASPM状态 == 2) { aspm_名 = "L1" }
    否则如果 (pcie.ASPM状态 == 3) { aspm_名 = "L0s+L1" }
    内核信息("  ASPM: " + aspm_名)
}

// §13 电源状态打印

函数 图处_打印电源状态() {
    如果 (当前图处 == 空) { 返回 }
    定义 电 = 图处_获取电源状态()
    内核信息("── 电源 ──")
    内核信息("  总功耗: %d.%dW  TDP: %d.%dW  (%d%%)",
             电.总功耗_mW / 1000, (电.总功耗_mW % 1000) / 100,
             电.TDP_mW / 1000, (电.TDP_mW % 1000) / 100,
             电.总功耗_mW * 100 / 电.TDP_mW)
    内核信息("  板载: %d.%dW", 电.板载功耗_mW / 1000, (电.板载功耗_mW % 1000) / 100)
    内核信息("  核心电压: %dmV  显存电压: %dmV", 电.核心电压_mV, 电.显存电压_mV)

    如果 (电.电源限制激活) {
        内核信息("  ⚠ 电源限制已激活! 可能影响性能")
    }
    如果 (电.过流保护触发次数 > 0) {
        内核信息("  ⚠ 过流保护触发: %d次", 电.过流保护触发次数)
    }
}

// §14 性能计数器打印

函数 图处_打印性能计数() {
    如果 (当前图处 == 空) { 返回 }
    定义 性能 = 图处_获取性能计数()
    定义 负载 = 图处_获取工作负载统计()
    内核信息("── 性能 ──")
    内核信息("  GPU利用率: %d%%  显存利用率: %d%%",
             性能.GPU利用率, 性能.显存利用率)
    内核信息("  核心: %dMHz  显存: %dMHz",
             性能.核心时钟_MHz, 性能.显存时钟_MHz)
    内核信息("  编码器: %d%%  解码器: %d%%",
             性能.编码器利用率, 性能.解码器利用率)
    内核信息("  Shader活跃: %d  提交队列: %d",
             性能.Shader活跃数, 性能.当前提交队列深度)

    内核信息("── 工作负载统计 ──")
    内核信息("  总提交: %d  绘制: %d  计算: %d",
             负载.总提交命令数, 负载.总绘制调用, 负载.总计算调度)
    内核信息("  DMA传输: %dMB  帧翻转: %d",
             负载.总DMA传输字节 / (1024 * 1024), 负载.帧缓冲翻转次数)
    如果 (负载.帧缓冲翻转次数 > 0) {
        定义 平均帧时 = 负载.帧延迟_累计us / 负载.帧缓冲翻转次数
        内核信息("  帧延迟: 平均%dus  最大%dus", 平均帧时, 负载.帧延迟_最大us)
    }
    如果 (负载.超时重置次数 > 0) {
        内核信息("  ⚠ GPU超时重置: %d次", 负载.超时重置次数)
    }
}

// §15 显示输出状态打印

函数 图处_打印显示输出() {
    如果 (当前图处 == 空) { 返回 }
    内核信息("── 显示输出 ──")

    定义 可变 已连接数 = 0
    定义 可变 i = 0
    当 (i < 最大显示输出) {
        定义 输出 = 图处_获取显示输出(i)
        如果 (输出.已连接) {
            定义 刷新率_Hz = 输出.刷新率_mHz / 1000
            定义 刷新率_小数 = (输出.刷新率_mHz % 1000) / 10
            定义 可变 标志 = ""
            如果 (输出.HDR激活) { 标志 = 标志 + " HDR" }
            如果 (输出.自适应同步) { 标志 = 标志 + " VRR" }
            内核信息("  [%d] %s: %dx%d@%d.%02dHz %dbit%s",
                     i, 显示接口名称(输出.接口类型),
                     输出.宽度, 输出.高度, 刷新率_Hz, 刷新率_小数,
                     输出.色深, 标志)
            已连接数 = 已连接数 + 1
        }
        i = i + 1
    }

    如果 (已连接数 == 0) {
        内核信息("  无已连接显示器")
    } 否则 {
        内核信息("  共%d个显示器已连接", 已连接数)
    }
}

// §16 错误历史记录与打印

函数 图处_记录错误(类型, 严重级, 描述) {
    定义 可变 条目 = GPU错误条目 {}
    条目.时间戳 = 读取纳秒时钟()
    条目.错误类型 = 类型
    条目.严重级 = 严重级
    条目.描述 = 描述
    条目.恢复已尝试 = 假
    条目.已恢复 = 假

    GPU错误记录.条目[GPU错误记录.写索引 % GPU错误历史_容量] = 条目
    GPU错误记录.写索引 = GPU错误记录.写索引 + 1
    GPU错误记录.总错误数 = GPU错误记录.总错误数 + 1
    如果 (严重级 >= 3) {
        GPU错误记录.致命错误数 = GPU错误记录.致命错误数 + 1
    }
}

函数 GPU错误类型名(类型) {
    如果 (类型 == 0) { 返回 "总线错误" }
    如果 (类型 == 1) { 返回 "显存ECC" }
    如果 (类型 == 2) { 返回 "过热" }
    如果 (类型 == 3) { 返回 "挂起超时" }
    如果 (类型 == 4) { 返回 "驱动异常" }
    返回 "未知"
}

函数 GPU严重级名(级别) {
    如果 (级别 == 0) { 返回 "信息" }
    如果 (级别 == 1) { 返回 "警告" }
    如果 (级别 == 2) { 返回 "错误" }
    如果 (级别 == 3) { 返回 "致命" }
    返回 "?"
}

函数 图处_打印错误历史() {
    内核信息("── GPU错误历史 (总计%d, 致命%d) ──",
             GPU错误记录.总错误数, GPU错误记录.致命错误数)

    定义 可变 数量 = GPU错误记录.写索引
    如果 (数量 > GPU错误历史_容量) { 数量 = GPU错误历史_容量 }

    定义 可变 i = 0
    当 (i < 数量) {
        定义 idx = (GPU错误记录.写索引 - 数量 + i) % GPU错误历史_容量
        定义 e = GPU错误记录.条目[idx]
        定义 恢复状 = "未尝试"
        如果 (e.已恢复) { 恢复状 = "已恢复" }
        否则如果 (e.恢复已尝试) { 恢复状 = "恢复失败" }
        内核信息("  [%d] [%s] %s: %s (%s)",
                 i, GPU严重级名(e.严重级),
                 GPU错误类型名(e.错误类型), e.描述, 恢复状)
        i = i + 1
    }

    如果 (数量 == 0) {
        内核信息("  无错误记录")
    }
}

// §17 GPU健康分计算: 多维加权评分

函数 图处_计算健康分() {
    如果 (当前图处 == 空) { 返回 0 }

    // 温度分: 100 = <60°C, 0 = >=100°C, 线性插值
    定义 热 = 图处_获取热管理状态()
    定义 可变 温度分 = 100
    如果 (热.核心温度 >= 100) { 温度分 = 0 }
    否则如果 (热.核心温度 >= 60) {
        温度分 = (100 - 热.核心温度) * 100 / 40
    }

    // 显存分: ECC错误为主, 使用率为辅
    定义 显存 = 图处_获取显存状态()
    定义 可变 显存分 = 100
    如果 (显存.ECC_双位不可纠正 > 0) {
        显存分 = 0  // 有不可纠正错误直接0分
    } 否则如果 (显存.ECC_单位纠正 > 100) {
        显存分 = 50
    } 否则如果 (显存.ECC_单位纠正 > 10) {
        显存分 = 80
    }

    // PCIe分: 重训练+错误计数
    定义 pcie = 图处_获取PCIe状态()
    定义 可变 PCIe分 = 100
    如果 (pcie.重训练次数 > 100) { PCIe分 = 30 }
    否则如果 (pcie.重训练次数 > 10) { PCIe分 = 70 }
    如果 (pcie.当前代 < pcie.最大代) { PCIe分 = PCIe分 - 20 }
    如果 (PCIe分 < 0) { PCIe分 = 0 }

    // 功耗分: 超过TDP越多越低
    定义 电 = 图处_获取电源状态()
    定义 可变 功耗分 = 100
    如果 (电.TDP_mW > 0) {
        定义 比率 = 电.总功耗_mW * 100 / 电.TDP_mW
        如果 (比率 > 120) { 功耗分 = 30 }
        否则如果 (比率 > 100) { 功耗分 = 70 }
    }
    如果 (电.电源限制激活) { 功耗分 = 功耗分 - 15 }
    如果 (功耗分 < 0) { 功耗分 = 0 }

    // 错误分: 基于错误历史
    定义 可变 错误分 = 100
    如果 (GPU错误记录.致命错误数 > 0) { 错误分 = 10 }
    否则如果 (GPU错误记录.总错误数 > 50) { 错误分 = 40 }
    否则如果 (GPU错误记录.总错误数 > 10) { 错误分 = 70 }

    // 加权汇总: Σ(Wi × Si) / 100
    定义 总分 = (温度分 * 健康权重_温度 +
                显存分 * 健康权重_显存 +
                PCIe分 * 健康权重_PCIe +
                功耗分 * 健康权重_功耗 +
                错误分 * 健康权重_错误) / 100

    // 写入健康跟踪器
    GPU健康.分数历史[GPU健康.写索引 % 健康窗口_大小] = 总分
    GPU健康.写索引 = GPU健康.写索引 + 1
    GPU健康.当前分数 = 总分
    如果 (总分 < GPU健康.最低分数 || GPU健康.最低分数 == 0) {
        GPU健康.最低分数 = 总分
    }
    GPU健康.上次计算时间 = 读取纳秒时钟()

    返回 总分
}

函数 图处_打印健康分() {
    定义 分 = 图处_计算健康分()
    定义 等级 = "优秀"
    如果 (分 < 30) { 等级 = "危险" }
    否则如果 (分 < 50) { 等级 = "警告" }
    否则如果 (分 < 70) { 等级 = "一般" }
    否则如果 (分 < 85) { 等级 = "良好" }

    内核信息("── GPU健康评分 ──")
    内核信息("  当前: %d/100 (%s)  历史最低: %d/100", 分, 等级, GPU健康.最低分数)
}

// §18 AI健康趋势检测: 滑动窗口分析

函数 图处_AI健康检查() {
    如果 (GPU健康.写索引 < 8) { 返回 }  // 数据不足

    // 计算最近8次的平均分
    定义 可变 近期总 = 0
    定义 可变 i = 0
    当 (i < 8) {
        定义 idx = (GPU健康.写索引 - 8 + i) % 健康窗口_大小
        近期总 = 近期总 + GPU健康.分数历史[idx]
        i = i + 1
    }
    定义 近期均 = 近期总 / 8

    // 计算前8次的平均分(如果够)
    如果 (GPU健康.写索引 >= 16) {
        定义 可变 早期总 = 0
        i = 0
        当 (i < 8) {
            定义 idx = (GPU健康.写索引 - 16 + i) % 健康窗口_大小
            早期总 = 早期总 + GPU健康.分数历史[idx]
            i = i + 1
        }
        定义 早期均 = 早期总 / 8

        // 如果近期平均比早期下降超过15分, 发预警
        如果 (早期均 - 近期均 > 15 && GPU健康.AI预警已发 == 假) {
            内核信息("⚠ AI检测: GPU健康分持续下降 (%d → %d), 建议检查",
                     早期均, 近期均)
            GPU健康.AI预警已发 = 真

            // 通知AI总线
            图处_AI总线_报告健康下降(早期均, 近期均)
        }
    }

    // 分数回升时重置预警
    如果 (近期均 >= 85 && GPU健康.AI预警已发) {
        GPU健康.AI预警已发 = 假
    }
}

函数 图处_AI总线_报告健康下降(早期, 近期) {
    定义 bus = 全局AI总线
    如果 (bus == 空) { 返回 }

    // 构造特征: [早期分, 近期分, 下降幅度, 致命错误比]
    定义 特征 = Tensor_创建(1, 4)
    Tensor_写(特征, 0, 0, 早期 * Q_ONE / 100)
    Tensor_写(特征, 0, 1, 近期 * Q_ONE / 100)
    Tensor_写(特征, 0, 2, (早期 - 近期) * Q_ONE / 100)
    定义 致命比 = 0
    如果 (GPU错误记录.总错误数 > 0) {
        致命比 = GPU错误记录.致命错误数 * Q_ONE / GPU错误记录.总错误数
    }
    Tensor_写(特征, 0, 3, 致命比)
    AI总线_GPU健康分析(bus, 特征)
    Tensor_释放(特征)
}

// §19 全量打印: 一次性输出所有状态

函数 图处_全量诊断() {
    图处_统一打印状态()
    图处_打印热状态()
    图处_打印显存状态()
    图处_打印PCIe状态()
    图处_打印电源状态()
    图处_打印性能计数()
    图处_打印显示输出()
    图处_打印错误历史()
    图处_打印健康分()
    图处_AI健康检查()
}

// §20 完整统计导出

函数 图处统一_完整统计() {
    返回 [当前驱动类型, 图处_厂商名称(), 图处_型号名称(),
           图处_计算单元数(), 图处_有光追(), 图处_有AI加速器(),
           GPU健康.当前分数, GPU健康.最低分数,
           GPU错误记录.总错误数, GPU错误记录.致命错误数]
}

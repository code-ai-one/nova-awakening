
导入("../基础.nova")
导入("../算法/数学扩展.nova")

// 三元组存储
// 三元组: [主语ID, 谓语ID, 宾语ID]
定义 可变 KG_三元组 = []
定义 可变 KG_实体名 = []
定义 可变 KG_关系名 = []
定义 可变 KG_下一实体 = 0
定义 可变 KG_下一关系 = 0

函数 KG_重置() {
 KG_三元组 = []
 KG_实体名 = []
 KG_关系名 = []
 KG_下一实体 = 0
 KG_下一关系 = 0
}

函数 KG_添加实体(名哈希) { 定义 id = KG_下一实体
 KG_下一实体 = KG_下一实体 + 1
 追加(KG_实体名, 名哈希)
 返回 id
}

函数 KG_添加关系(名哈希) { 定义 id = KG_下一关系
 KG_下一关系 = KG_下一关系 + 1
 追加(KG_关系名, 名哈希)
 返回 id
}

函数 KG_添加三元组(主语, 谓语, 宾语) {
 追加(KG_三元组, [主语, 谓语, 宾语])
}

函数 KG_实体数() { 返回 KG_下一实体 }
函数 KG_关系数() { 返回 KG_下一关系 }
函数 KG_三元组数() { 返回 计数(KG_三元组) }

// 查询
函数 KG_查询_主语(主语) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(KG_三元组)) { 如果 (KG_三元组[i][0] == 主语) { 追加(结果, KG_三元组[i]) }
 i = i + 1
 }
 返回 结果
}

函数 KG_查询_宾语(宾语) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(KG_三元组)) { 如果 (KG_三元组[i][2] == 宾语) { 追加(结果, KG_三元组[i]) }
 i = i + 1
 }
 返回 结果
}

函数 KG_查询_关系(谓语) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(KG_三元组)) { 如果 (KG_三元组[i][1] == 谓语) { 追加(结果, KG_三元组[i]) }
 i = i + 1
 }
 返回 结果
}

函数 KG_查询_精确(主语, 谓语, 宾语) { 定义 可变 i = 0
 当 (i < 计数(KG_三元组)) { 定义 t = KG_三元组[i]
 如果 (t[0] == 主语 且 t[1] == 谓语 且 t[2] == 宾语) { 返回 真 }
 i = i + 1
 }
 返回 假
}

// 邻居查询
函数 KG_出邻居(实体) { 定义 可变 邻居 = []
 定义 可变 i = 0
 当 (i < 计数(KG_三元组)) { 如果 (KG_三元组[i][0] == 实体) {
 追加(邻居, KG_三元组[i][2])
 }
 i = i + 1
 }
 返回 邻居
}

函数 KG_入邻居(实体) { 定义 可变 邻居 = []
 定义 可变 i = 0
 当 (i < 计数(KG_三元组)) { 如果 (KG_三元组[i][2] == 实体) {
 追加(邻居, KG_三元组[i][0])
 }
 i = i + 1
 }
 返回 邻居
}

函数 KG_度(实体) { 返回 计数(KG_出邻居(实体)) + 计数(KG_入邻居(实体))
}

// BFS路径搜索
函数 KG_路径存在(起点, 终点, 最大深度) {
    定义 可变 下一层 = []
    如果 (起点 == 终点) { 返回 真
}
 定义 可变 队列 = [起点]
 定义 可变 已访问 = []
 追加(已访问, 起点)
 定义 可变 深度 = 0
当 (深度 < 最大深度 且 计数(队列) > 0) {
 定义 可变 qi = 0
 当 (qi < 计数(队列)) { 定义 邻居 = KG_出邻居(队列[qi])
 定义 可变 ni = 0
 当 (ni < 计数(邻居)) { 如果 (邻居[ni] == 终点) { 返回 真 }
 // 检查是否已访问
 定义 可变 已有 = 假
 定义 可变 vi = 0
 当 (vi < 计数(已访问)) { 如果 (已访问[vi] == 邻居[ni]) { 已有 = 真 }
 vi = vi + 1
 }
 如果 (已有 == 假) {
 追加(已访问, 邻居[ni])
 追加(下一层, 邻居[ni])
 }
 ni = ni + 1
 }
 qi = qi + 1
 }
 队列 = 下一层
 深度 = 深度 + 1
 }
 返回 假
}

// 子图提取
函数 KG_子图(实体列表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(KG_三元组)) { 定义 t = KG_三元组[i]
 // 主语和宾语都在实体列表中
 定义 可变 主在 = 假
 定义 可变 宾在 = 假
 定义 可变 j = 0
 当 (j < 计数(实体列表)) { 如果 (实体列表[j] == t[0]) { 主在 = 真 }
 如果 (实体列表[j] == t[2]) { 宾在 = 真 }
 j = j + 1
 }
 如果 (主在 且 宾在) { 追加(结果, t) }
 i = i + 1
 }
 返回 结果
}

// 嵌入向量存储
// 嵌入: [[向量], [向量], ...] 每个实体一个向量
定义 可变 知识_嵌入向量 = []

函数 嵌入_设置(实体ID, 向量) { 如果 (实体ID >= 0 且 实体ID < 计数(知识_嵌入向量)) {
 知识_嵌入向量[实体ID] = 向量
 }
}

// 余弦相似度(整数近似, 回[-1000, 1000])
函数 嵌入_余弦相似(a, b) { 定义 可变 点积 = 0
 定义 可变 na = 0
 定义 可变 nb = 0
 定义 可变 i = 0
 当 (i < 计数(a)) {
 点积 = 点积 + a[i] * b[i]
 na = na + a[i] * a[i]
 nb = nb + b[i] * b[i]
 i = i + 1
 }
 如果 (na == 0 或 nb == 0) { 返回 0 }
 定义 可变 sna = 整数sqrt(na)
 定义 可变 snb = 整数sqrt(nb)
 如果 (sna == 0) { sna = 1 }
 如果 (snb == 0) { snb = 1 }
 返回 (点积 * 1000) / (sna * snb)
}

// 最近邻搜索
函数 知识图谱_嵌入_最近邻(查询向量, k) { 定义 可变 分数 = []
    定义 可变 ri = 0
    定义 可变 选了 = 0
 定义 可变 i = 0
 当 (i < 计数(知识_嵌入向量)) {
 追加(分数, [i, 嵌入_余弦相似(查询向量, 知识_嵌入向量[i])])
 i = i + 1
 }
 // 简易排序(按分数降序,选前k)
 定义 可变 结果 = []
 当 (选了 < k 且 选了 < 计数(分数)) { 定义 可变 最佳 = -1
 定义 可变 最佳分 = -99999
 定义 可变 j = 0
 当 (j < 计数(分数)) { 如果 (分数[j][1] > 最佳分) {
 // 检查是否已选
 定义 可变 已选 = 假
 当 (ri < 计数(结果)) { 如果 (结果[ri] == 分数[j][0]) { 已选 = 真 }
 ri = ri + 1
 }
 如果 (已选 == 假) { 最佳 = j
 最佳分 = 分数[j][1] }
 }
 j = j + 1
 }
 如果 (最佳 >= 0) { 追加(结果, 分数[最佳][0]) }
 选了 = 选了 + 1
 }
 返回 结果
}

// 合并自 标准库/系统/知识图谱.nova

函数 推理_一轮(引擎, kg) { 定义 规则 = 引擎[0]
    定义 可变 ri = 0
 定义 可变 新增 = 0
 当 (ri < 计数(规则)) { 定义 规则项 = 规则[ri]
 定义 前提 = 规则项[0]
 定义 结论 = 规则项[1]
 // 简化: 单前提规则
 如果 (计数(前提) == 1) { 定义 p = 前提[0]
 定义 匹配结果 = 知识_按关系(kg, p[1])
 定义 可变 mi = 0
 当 (mi < 计数(匹配结果)) {
 // 检查结论是否已存在
 定义 新主 = 匹配结果[mi][0]
 定义 新客 = 匹配结果[mi][2]
 定义 已有 = 知识_获取客体(kg, 新主, 结论[1])
 如果 (计数(已有) == 0) {
 知识_追加(kg, 新主, 结论[1], 新客)
 新增 = 新增 + 1
 }
 mi = mi + 1
 }
 }
 ri = ri + 1
 }
 返回 新增
}

函数 推理_完全(引擎, kg) { 定义 可变 总新增 = 0
 定义 可变 轮数 = 0
 定义 可变 _推理完 = 假
 当 (_推理完 == 假) { 定义 新增 = 推理_一轮(引擎, kg)
 如果 (新增 == 0) { _推理完 = 真 } 否则 {
 总新增 = 总新增 + 新增
 轮数 = 轮数 + 1
 如果 (轮数 > 100) { _推理完 = 真 }
 } }
 返回 总新增
}

函数 推理_添加规则(引擎, 前提, 结论) {
 追加(引擎[0], [前提, 结论])
}

函数 推理引擎_创建() { 返回 [[]]
}

函数 知识_关系列表(kg) { 定义 可变 关系 = 字典()
 定义 可变 i = 0
 当 (i < kg[3]) {
 字典设(关系, 转字符串(kg[0][i][1]), 1)
 i = i + 1
 }
 返回 关系
}

函数 知识_反向查询(kg, 客体, 关系) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < kg[3]) { 定义 t = kg[0][i]
 如果 (t[1] == 关系 且 t[2] == 客体) {
 追加(结果, t[0])
 }
 i = i + 1
 }
 返回 结果
}

函数 知识_大小(kg) { 返回 kg[3]
}

函数 知识_实体列表(kg) { 定义 可变 实体 = 字典()
 定义 可变 i = 0
 当 (i < kg[3]) {
 字典设(实体, 转字符串(kg[0][i][0]), 1)
 字典设(实体, 转字符串(kg[0][i][2]), 1)
 i = i + 1
 }
 返回 实体
}

函数 知识_按主体(kg, 主体) { 定义 索引列表 = 字典取(kg[1], 转字符串(主体))
 如果 (索引列表 == 空) { 返回 [] }
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(索引列表)) {
 追加(结果, kg[0][索引列表[i]])
 i = i + 1
 }
 返回 结果
}

函数 知识_按关系(kg, 关系) { 定义 索引列表 = 字典取(kg[2], 转字符串(关系))
 如果 (索引列表 == 空) { 返回 [] }
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(索引列表)) {
 追加(结果, kg[0][索引列表[i]])
 i = i + 1
 }
 返回 结果
}

函数 知识_追加(kg, 主体, 关系, 客体) {
 追加(kg[0], [主体, 关系, 客体])
 // 更新主体索引
 定义 主键 = 转字符串(主体)
 定义 现有主 = 字典取(kg[1], 主键)
 如果 (现有主 == 空) {
 字典设(kg[1], 主键, [kg[3]])
 } 否则 {
 追加(现有主, kg[3])
 }
 // 更新关系索引
 定义 关键 = 转字符串(关系)
 定义 现有关 = 字典取(kg[2], 关键)
 如果 (现有关 == 空) {
 字典设(kg[2], 关键, [kg[3]])
 } 否则 {
 追加(现有关, kg[3])
 }
 kg[3] = kg[3] + 1
}

函数 知识_获取客体(kg, 主体, 关系) { 定义 三元组 = 知识_按主体(kg, 主体)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(三元组)) { 如果 (三元组[i][1] == 关系) {
 追加(结果, 三元组[i][2])
 }
 i = i + 1
 }
 返回 结果
}

函数 知识_语义相似(kg, 实体a, 实体b) { 定义 邻居a = 知识_按主体(kg, 实体a)
 定义 邻居b = 知识_按主体(kg, 实体b)
 // 计算共同客体数
 定义 可变 共同 = 0
 定义 可变 i = 0
 当 (i < 计数(邻居a)) { 定义 可变 j = 0
 当 (j < 计数(邻居b)) { 如果 (邻居a[i][2] == 邻居b[j][2] 且 邻居a[i][1] == 邻居b[j][1]) {
 共同 = 共同 + 1
 }
 j = j + 1
 }
 i = i + 1
 }
 定义 总 = 计数(邻居a) + 计数(邻居b)
 如果 (总 == 0) { 返回 0 }
 返回 共同 * 2 * 1000 / 总
}

函数 知识_路径(kg, 起点, 终点, 最大深度) { 定义 可变 已访问 = 字典()
 定义 可变 队列 = [[起点, []]]
 定义 可变 前 = 0
 字典设(已访问, 转字符串(起点), 1)
 当 (前 < 计数(队列)) { 定义 当前 = 队列[前]
 前 = 前 + 1
 定义 节点 = 当前[0]
 定义 路径 = 当前[1]
 如果 (计数(路径) >= 最大深度) { 续 }
 // 扩展
 定义 三元组 = 知识_按主体(kg, 节点)
 定义 可变 i = 0
 当 (i < 计数(三元组)) { 定义 客体 = 三元组[i][2]
 定义 关系 = 三元组[i][1]
 如果 (客体 == 终点) { 定义 可变 完整路径 = []
 定义 可变 j = 0
 当 (j < 计数(路径)) { 追加(完整路径, 路径[j]) j = j + 1 }
 追加(完整路径, [节点, 关系, 客体])
 返回 完整路径
 }
 如果 (字典取(已访问, 转字符串(客体)) == 空) {
 字典设(已访问, 转字符串(客体), 1)
 定义 可变 新路径 = []
 定义 可变 k = 0
 当 (k < 计数(路径)) { 追加(新路径, 路径[k]) k = k + 1 }
 追加(新路径, [节点, 关系, 客体])
 追加(队列, [客体, 新路径])
 }
 i = i + 1
 }
 }
 返回 空
}

函数 知识图谱_创建() { 返回 [[], 字典(), 字典(), 0]
}

定义 可变 _kg_节点数 = 0
定义 可变 _kg_边数 = 0
定义 可变 _kg_查询数 = 0

函数 kg_记录节点() { _kg_节点数 = _kg_节点数 + 1 }
函数 kg_记录边() { _kg_边数 = _kg_边数 + 1 }
函数 kg_记录查询() { _kg_查询数 = _kg_查询数 + 1 }

函数 kg_密度() {
    如果 (_kg_节点数 < 2) { 返回 0
}
 定义 最大边 = _kg_节点数 * (_kg_节点数 - 1)
 如果 (最大边 == 0) { 返回 0 }
 返回 _kg_边数 * 100 / 最大边
}

函数 kg_连通性评估() {
    如果 (_kg_节点数 == 0) { 返回 "空图"
}
 定义 平均度 = _kg_边数 * 2 / _kg_节点数
 如果 (平均度 > 10) { 返回 "高连通(知识密集)" }
 如果 (平均度 > 3) { 返回 "中连通" }
 如果 (平均度 > 1) { 返回 "低连通(知识稀疏)" }
 返回 "极低连通(可能有孤立节点)"
}

函数 kg_质量评估() { 定义 密度 = kg_密度()
 定义 连通 = kg_连通性评估()
 返回 [密度, 连通, _kg_节点数, _kg_边数]
}

函数 kg_推理潜力() {
    如果 (_kg_边数 < 10) { 返回 "推理能力有限"
}
 如果 (_kg_边数 < 100) { 返回 "基础推理可行" }
 如果 (_kg_边数 < 1000) { 返回 "中等推理能力" }
 返回 "丰富推理能力"
}

函数 kg_规模分类() {
    如果 (_kg_节点数 > 10000) { 返回 "大规模知识图谱"
}
 如果 (_kg_节点数 > 1000) { 返回 "中规模知识图谱" }
 如果 (_kg_节点数 > 100) { 返回 "小规模知识图谱" }
 返回 "微型知识图谱"
}

函数 kg_存储估算() { 返回 _kg_节点数 * 64 + _kg_边数 * 32
}

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./内核直连层.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/创建甲.nova")

定义 指令_脚本源 = 0
定义 指令_样式源 = 1
定义 指令_图片源 = 2
定义 指令_字体源 = 3
定义 指令_连接源 = 4
定义 指令_帧源 = 5
定义 指令_媒体源 = 6
定义 指令_默认源 = 7
定义 最大指令 = 8
定义 最大源 = 16
定义 最大违规 = 64

结构 安全策略 {
    指令表,
    指令源数,
    仅报告,
    违规表,
    违规数,
    检查总数,
    阻止总数,
}

定义 可变 全局策略 = 0

函数 安全策略_初始化() {
    全局策略 = 堆_分配(安全策略)
    全局策略.指令表 = 堆_分配(最大指令 * 最大源 * 8)
    全局策略.指令源数 = 堆_分配(最大指令 * 4)
    全局策略.仅报告 = 假
    全局策略.违规表 = 堆_分配(最大违规 * 32)
    全局策略.违规数 = 0
    全局策略.检查总数 = 0
    全局策略.阻止总数 = 0
    定义 可变 序号 = 0
    当 (序号 < 最大指令) {
        内存_写32(全局策略.指令源数 + 序号 * 4, 0)
        序号 = 序号 + 1
    }
}

函数 安全策略_添加源(指令, 源哈希) {
    如果 (全局策略 == 0 || 指令 >= 最大指令) { 返回 }
    定义 当前数 = 内存_读32(全局策略.指令源数 + 指令 * 4)
    如果 (当前数 >= 最大源) { 返回 }
    内存_写64(全局策略.指令表 + (指令 * 最大源 + 当前数) * 8, 源哈希)
    内存_写32(全局策略.指令源数 + 指令 * 4, 当前数 + 1)
}

函数 安全策略_检查(指令, 地址哈希, 文档哈希) {
    如果 (全局策略 == 0) { 返回 真 }
    全局策略.检查总数 = 全局策略.检查总数 + 1
    如果 (指令 >= 最大指令) { 指令 = 指令_默认源 }
    定义 源数 = 内存_读32(全局策略.指令源数 + 指令 * 4)
    如果 (源数 == 0) {
        定义 默认数 = 内存_读32(全局策略.指令源数 + 指令_默认源 * 4)
        如果 (默认数 == 0) { 返回 真 }
        返回 安全策略_匹配源(指令_默认源, 地址哈希)
    }
    如果 (安全策略_匹配源(指令, 地址哈希)) { 返回 真 }
    安全策略_记录违规(指令, 地址哈希, 文档哈希)
    返回 假
}

函数 安全策略_匹配源(指令, 地址哈希) {
    定义 源数 = 内存_读32(全局策略.指令源数 + 指令 * 4)
    定义 可变 序号 = 0
    当 (序号 < 源数) {
        定义 源哈希 = 内存_读64(全局策略.指令表 + (指令 * 最大源 + 序号) * 8)
        如果 (源哈希 == 0) { 返回 真 }
        如果 (源哈希 == 地址哈希) { 返回 真 }
        序号 = 序号 + 1
    }
    返回 假
}

函数 安全策略_记录违规(指令, 地址哈希, 文档哈希) {
    全局策略.阻止总数 = 全局策略.阻止总数 + 1
    如果 (全局策略.违规数 >= 最大违规) { 返回 }
    定义 偏移 = 全局策略.违规表 + 全局策略.违规数 * 32
    内存_写32(偏移, 指令)
    内存_写64(偏移 + 4, 地址哈希)
    内存_写64(偏移 + 12, 文档哈希)
    内存_写64(偏移 + 20, 平台_获取高精度时间())
    全局策略.违规数 = 全局策略.违规数 + 1
}

函数 安全策略_检查脚本(地址哈希, 文档哈希) { 返回 安全策略_检查(指令_脚本源, 地址哈希, 文档哈希) }
函数 安全策略_检查样式(地址哈希, 文档哈希) { 返回 安全策略_检查(指令_样式源, 地址哈希, 文档哈希) }
函数 安全策略_检查图片(地址哈希, 文档哈希) { 返回 安全策略_检查(指令_图片源, 地址哈希, 文档哈希) }
函数 安全策略_检查连接(地址哈希, 文档哈希) { 返回 安全策略_检查(指令_连接源, 地址哈希, 文档哈希) }
函数 安全策略_检查字体(地址哈希, 文档哈希) { 返回 安全策略_检查(指令_字体源, 地址哈希, 文档哈希) }
函数 安全策略_检查帧(地址哈希, 文档哈希) { 返回 安全策略_检查(指令_帧源, 地址哈希, 文档哈希) }

函数 安全策略_设仅报告(启用) {
    如果 (全局策略 == 0) { 返回 }
    全局策略.仅报告 = 启用
}

函数 安全策略_获取违规(索引) {
    如果 (全局策略 == 0 || 索引 >= 全局策略.违规数) { 返回 0 }
    返回 全局策略.违规表 + 索引 * 32
}

函数 安全策略_指令名(指令) {
    如果 (指令 == 指令_脚本源) { 返回 "脚本源" }
    如果 (指令 == 指令_样式源) { 返回 "样式源" }
    如果 (指令 == 指令_图片源) { 返回 "图片源" }
    如果 (指令 == 指令_字体源) { 返回 "字体源" }
    如果 (指令 == 指令_连接源) { 返回 "连接源" }
    如果 (指令 == 指令_帧源) { 返回 "帧源" }
    如果 (指令 == 指令_默认源) { 返回 "默认源" }
    返回 "未知"
}

函数 安全策略_阻止率() {
    如果 (全局策略 == 0 || 全局策略.检查总数 == 0) { 返回 0 }
    返回 全局策略.阻止总数 * 100 / 全局策略.检查总数
}

函数 安全策略_完整统计() {
    如果 (全局策略 == 0) { 返回 [0, 0, 0, 0] }
    返回 [全局策略.检查总数, 全局策略.阻止总数, 全局策略.违规数, 安全策略_阻止率()]
}

// §1 事件标志与常量

定义 Nova事件轮询IN      = 0x001
定义 Nova事件轮询PRI     = 0x002
定义 Nova事件轮询OUT     = 0x004
定义 Nova事件轮询ERR     = 0x008
定义 Nova事件轮询HUP     = 0x010
定义 Nova事件轮询RDNORM  = 0x040
定义 Nova事件轮询WRNORM  = 0x100
定义 Nova事件轮询RDHUP   = 0x2000
定义 Nova事件轮询ET      = 0x80000000
定义 Nova事件轮询ONESHOT = 0x40000000
定义 Nova事件轮询EXCLUSIVE = 0x10000000

定义 Nova事件轮询_CTL_ADD = 1
定义 Nova事件轮询_CTL_DEL = 2
定义 Nova事件轮询_CTL_MOD = 3

定义 Nova事件轮询_最大事件数    = 4096
定义 Nova事件轮询_最大嵌套深度  = 5
定义 Nova事件轮询_默认超时      = -1

定义 可变 全局_epoll实例数 = 0
定义 可变 全局_epoll等待数 = 0
定义 可变 全局_epoll事件总数 = 0
定义 可变 全局_epoll唤醒总数 = 0
定义 可变 全局_epoll超时数 = 0

// §2 数据结构

结构 Nova事件轮询事件 {
    事件,
    数据,
}

结构 Nova事件轮询监控项 {
    fd,
    文件,
    事件,
    就绪链接,
    红黑树节点,
    Nova事件轮询实例,
    已就绪,
    已禁用,
    触发计数,
    上次触发时间,
}

结构 Nova事件轮询实例 {
    监控树,
    就绪链表,
    就绪数,
    等待队列,
    锁,
    就绪锁,
    监控项数,
    已关闭,
    嵌套深度,
    创建时间,
    // 统计
    等待次数,
    事件触发总数,
    超时次数,
    // AI预测
    AI_IO模式,
    AI_预测就绪fd,
    AI_命中次数,
}

// §3 epoll_create — 创建实例

函数 Nova事件轮询_创建() {
    定义 ep = Nova事件轮询实例 {
        监控树: 红黑树_创建(),
        就绪链表: 空,
        就绪数: 0,
        等待队列: 等待队列_创建(),
        锁: 互斥锁_创建(),
        就绪锁: 自旋锁_创建(),
        监控项数: 0,
        已关闭: 假,
        嵌套深度: 0,
        创建时间: 当前时间_纳秒(),
        等待次数: 0,
        事件触发总数: 0,
        超时次数: 0,
        AI_IO模式: 0,
        AI_预测就绪fd: -1,
        AI_命中次数: 0,
    }

    // 分配文件描述符
    定义 fd = 文件描述符_分配()
    如果 (fd < 0) {
        返回 错误码_文件过多
    }

    定义 文件 = 文件对象_创建(空, 空, 0)
    文件.私有数据 = ep
    文件.操作 = Nova事件轮询_文件操作表()
    文件描述符_安装(fd, 文件)

    全局_epoll实例数 = 全局_epoll实例数 + 1
    返回 fd
}

函数 Nova事件轮询_创建1(标志) {
    定义 fd = Nova事件轮询_创建()
    如果 (fd < 0) { 返回 fd }
    如果 (标志 & O_CLOEXEC) {
        文件描述符_设置标志(fd, FD_CLOEXEC)
    }
    返回 fd
}

// §4 epoll_ctl — 控制监控项

函数 Nova事件轮询_控制(epfd, 操作, fd, 事件) {
    定义 ep = 获取epoll实例(epfd)
    如果 (ep == 空) { 返回 错误码_无效参数 }
    如果 (ep.已关闭) { 返回 错误码_无效参数 }

    互斥锁_获取(ep.锁)

    定义 结果 = 0
    如果 (操作 == Nova事件轮询_CTL_ADD) {
        结果 = epoll_添加(ep, fd, 事件)
    } 否则 如果 (操作 == Nova事件轮询_CTL_DEL) {
        结果 = epoll_删除(ep, fd)
    } 否则 如果 (操作 == Nova事件轮询_CTL_MOD) {
        结果 = epoll_修改(ep, fd, 事件)
    } 否则 {
        结果 = 错误码_无效参数
    }

    互斥锁_释放(ep.锁)
    返回 结果
}

函数 epoll_添加(ep, fd, 事件) {
    // 检查是否已存在
    如果 (红黑树_查找(ep.监控树, fd) != 空) {
        返回 错误码_已存在
    }
    // 检查限制
    如果 (ep.监控项数 >= Nova事件轮询_最大事件数) {
        返回 错误码_资源不足
    }

    // 嵌套epoll检测
    定义 目标文件 = 文件描述符_获取文件(fd)
    如果 (目标文件 != 空 && 目标文件.操作 == Nova事件轮询_文件操作表()) {
        定义 内部ep = 目标文件.私有数据
        如果 (内部ep.嵌套深度 >= Nova事件轮询_最大嵌套深度) {
            返回 错误码_嵌套过深
        }
    }

    // 创建监控项
    定义 epi = Nova事件轮询监控项 {
        fd: fd,
        文件: 目标文件,
        事件: 事件,
        就绪链接: 空,
        红黑树节点: 空,
        Nova事件轮询实例: ep,
        已就绪: 假,
        已禁用: 假,
        触发计数: 0,
        上次触发时间: 0,
    }

    // 插入红黑树
    红黑树_插入(ep.监控树, fd, epi)
    ep.监控项数 = ep.监控项数 + 1

    // 注册回调: 当fd有事件时通知epoll
    文件_注册等待回调(目标文件, epoll_回调, epi)

    // 检查是否已经就绪
    定义 当前事件 = 文件_轮询(目标文件)
    如果 (当前事件 & 事件.事件) {
        epoll_标记就绪(ep, epi)
    }

    返回 成功
}

函数 epoll_删除(ep, fd) {
    定义 epi = 红黑树_查找(ep.监控树, fd)
    如果 (epi == 空) { 返回 错误码_不存在 }

    // 取消回调
    文件_取消等待回调(epi.文件, epoll_回调, epi)

    // 从就绪链表移除
    如果 (epi.已就绪) {
        自旋锁_获取(ep.就绪锁)
        epoll_从就绪链表移除(ep, epi)
        自旋锁_释放(ep.就绪锁)
    }

    // 从红黑树移除
    红黑树_删除(ep.监控树, fd)
    ep.监控项数 = ep.监控项数 - 1

    返回 成功
}

函数 epoll_修改(ep, fd, 新事件) {
    定义 epi = 红黑树_查找(ep.监控树, fd)
    如果 (epi == 空) { 返回 错误码_不存在 }

    epi.事件 = 新事件
    epi.已禁用 = 假

    // 重新检查就绪状态
    定义 当前事件 = 文件_轮询(epi.文件)
    如果 (当前事件 & 新事件.事件) {
        epoll_标记就绪(ep, epi)
    }

    返回 成功
}

// §5 epoll_wait — 等待事件

函数 Nova事件轮询_等待(epfd, 事件数组, 最大事件, 超时_毫秒) {
    定义 ep = 获取epoll实例(epfd)
    如果 (ep == 空) { 返回 错误码_无效参数 }
    如果 (最大事件 <= 0 || 最大事件 > Nova事件轮询_最大事件数) { 返回 错误码_无效参数 }

    ep.等待次数 = ep.等待次数 + 1
    全局_epoll等待数 = 全局_epoll等待数 + 1

    // AI预取: 预测即将就绪的fd
    AI_epoll预测(ep)

    定义 截止时间 = 0
    如果 (超时_毫秒 > 0) {
        截止时间 = 读取毫秒() + 超时_毫秒
    } 否则 如果 (超时_毫秒 == 0) {
        // 非阻塞: 立即返回
        返回 epoll_收集事件(ep, 事件数组, 最大事件)
    }

    // 等待循环
    定义 可变 已收集 = 0
    当 (已收集 == 0) {
        // 检查就绪链表
        已收集 = epoll_收集事件(ep, 事件数组, 最大事件)
        如果 (已收集 > 0) { 跳出 }

        // 检查超时
        如果 (超时_毫秒 > 0 && 读取毫秒() >= 截止时间) {
            ep.超时次数 = ep.超时次数 + 1
            全局_epoll超时数 = 全局_epoll超时数 + 1
            返回 0
        }

        // 检查信号
        定义 当前 = 获取当前进程()
        如果 (当前.待处理信号 != 0) {
            返回 错误码_被中断
        }

        // 睡眠等待
        等待队列_加入(ep.等待队列, 当前)
        进程_设置状态(当前, 进程_可中断睡眠)
        schedule()
        等待队列_移除(ep.等待队列, 当前)
    }

    全局_epoll事件总数 = 全局_epoll事件总数 + 已收集
    返回 已收集
}

函数 epoll_收集事件(ep, 事件数组, 最大事件) {
    自旋锁_获取(ep.就绪锁)
    定义 可变 已收集 = 0
    定义 可变 当前 = ep.就绪链表

    当 (当前 != 空 && 已收集 < 最大事件) {
        定义 下一个 = 当前.就绪链接
        如果 (当前.已禁用) {
            当前 = 下一个
            继续
        }

        // 重新轮询确认事件
        定义 活跃事件 = 文件_轮询(当前.文件) & 当前.事件.事件
        如果 (活跃事件 != 0) {
            // 填充返回事件
            事件数组[已收集] = Nova事件轮询事件 {
                事件: 活跃事件,
                数据: 当前.事件.数据,
            }
            已收集 = 已收集 + 1
            当前.触发计数 = 当前.触发计数 + 1
            当前.上次触发时间 = 当前时间_纳秒()
            ep.事件触发总数 = ep.事件触发总数 + 1

            // ET模式: 从就绪链表移除(下次需要新事件才重新加入)
            如果 (当前.事件.事件 & Nova事件轮询ET) {
                epoll_从就绪链表移除(ep, 当前)
                当前.已就绪 = 假
            }

            // ONESHOT模式: 禁用直到再次MOD
            如果 (当前.事件.事件 & Nova事件轮询ONESHOT) {
                当前.已禁用 = 真
                epoll_从就绪链表移除(ep, 当前)
                当前.已就绪 = 假
            }
        } 否则 {
            // LT模式下无活跃事件: 移除
            epoll_从就绪链表移除(ep, 当前)
            当前.已就绪 = 假
        }

        当前 = 下一个
    }

    自旋锁_释放(ep.就绪锁)
    返回 已收集
}

// §6 回调与就绪链表管理

函数 epoll_回调(epi) {
    // 文件有事件时被调用(中断/软中断上下文)
    定义 ep = epi.Nova事件轮询实例
    如果 (ep == 空 || ep.已关闭) { 返回 }

    epoll_标记就绪(ep, epi)

    // 唤醒等待的进程
    全局_epoll唤醒总数 = 全局_epoll唤醒总数 + 1
    等待队列_唤醒一个(ep.等待队列)
}

函数 epoll_标记就绪(ep, epi) {
    自旋锁_获取(ep.就绪锁)
    如果 (!epi.已就绪 && !epi.已禁用) {
        // 加入就绪链表头部
        epi.就绪链接 = ep.就绪链表
        ep.就绪链表 = epi
        ep.就绪数 = ep.就绪数 + 1
        epi.已就绪 = 真
    }
    自旋锁_释放(ep.就绪锁)
}

函数 epoll_从就绪链表移除(ep, 目标) {
    如果 (ep.就绪链表 == 目标) {
        ep.就绪链表 = 目标.就绪链接
        ep.就绪数 = ep.就绪数 - 1
        目标.就绪链接 = 空
        返回
    }
    定义 可变 前一个 = ep.就绪链表
    当 (前一个 != 空) {
        如果 (前一个.就绪链接 == 目标) {
            前一个.就绪链接 = 目标.就绪链接
            ep.就绪数 = ep.就绪数 - 1
            目标.就绪链接 = 空
            返回
        }
        前一个 = 前一个.就绪链接
    }
}

// §7 epoll关闭与清理

函数 Nova事件轮询_关闭(epfd) {
    定义 ep = 获取epoll实例(epfd)
    如果 (ep == 空) { 返回 }

    互斥锁_获取(ep.锁)
    ep.已关闭 = 真

    // 唤醒所有等待者
    等待队列_唤醒全部(ep.等待队列)

    // 清理所有监控项
    定义 所有fd = 红黑树_所有键(ep.监控树)
    定义 可变 i = 0
    当 (i < 计数(所有fd)) {
        epoll_删除(ep, 所有fd[i])
        i = i + 1
    }

    互斥锁_释放(ep.锁)
    全局_epoll实例数 = 全局_epoll实例数 - 1
}

函数 获取epoll实例(epfd) {
    定义 文件 = 文件描述符_获取文件(epfd)
    如果 (文件 == 空) { 返回 空 }
    如果 (文件.操作 != Nova事件轮询_文件操作表()) { 返回 空 }
    返回 文件.私有数据
}

// §8 AI I/O模式预测

定义 AI_IO_模式_读密集 = 1
定义 AI_IO_模式_写密集 = 2
定义 AI_IO_模式_混合 = 3

函数 AI_epoll预测(ep) {
    // 分析历史事件模式,预测下一个就绪fd
    如果 (ep.监控项数 == 0) { 返回 }

    // 统计读/写事件比例
    定义 可变 读事件 = 0
    定义 可变 写事件 = 0
    定义 可变 最活跃fd = -1
    定义 可变 最大触发 = 0

    定义 所有fd = 红黑树_所有键(ep.监控树)
    定义 可变 i = 0
    当 (i < 计数(所有fd)) {
        定义 epi = 红黑树_查找(ep.监控树, 所有fd[i])
        如果 (epi != 空) {
            如果 (epi.事件.事件 & Nova事件轮询IN) { 读事件 = 读事件 + 1 }
            如果 (epi.事件.事件 & Nova事件轮询OUT) { 写事件 = 写事件 + 1 }
            如果 (epi.触发计数 > 最大触发) {
                最大触发 = epi.触发计数
                最活跃fd = epi.fd
            }
        }
        i = i + 1
    }

    // 更新I/O模式
    如果 (读事件 > 写事件 * 3) { ep.AI_IO模式 = AI_IO_模式_读密集 }
    否则 如果 (写事件 > 读事件 * 3) { ep.AI_IO模式 = AI_IO_模式_写密集 }
    否则 { ep.AI_IO模式 = AI_IO_模式_混合 }

    // 预测最可能就绪的fd
    如果 (最活跃fd >= 0) {
        定义 旧预测 = ep.AI_预测就绪fd
        ep.AI_预测就绪fd = 最活跃fd
        // 检查预测是否命中
        如果 (旧预测 >= 0) {
            定义 旧epi = 红黑树_查找(ep.监控树, 旧预测)
            如果 (旧epi != 空 && 旧epi.已就绪) {
                ep.AI_命中次数 = ep.AI_命中次数 + 1
            }
        }
    }
}

// §9 文件操作表

函数 Nova事件轮询_文件操作表() {
    返回 {
        读: 空,
        写: 空,
        轮询: Nova事件轮询_文件轮询,
        释放: Nova事件轮询_文件释放,
    }
}

函数 Nova事件轮询_文件轮询(文件) {
    定义 ep = 文件.私有数据
    如果 (ep == 空) { 返回 0 }
    如果 (ep.就绪数 > 0) { 返回 Nova事件轮询IN | Nova事件轮询RDNORM }
    返回 0
}

函数 Nova事件轮询_文件释放(文件) {
    定义 ep = 文件.私有数据
    如果 (ep != 空) {
        Nova事件轮询_关闭_内部(ep)
    }
}

函数 Nova事件轮询_关闭_内部(ep) {
    ep.已关闭 = 真
    等待队列_唤醒全部(ep.等待队列)
}

// §10 统计与诊断

函数 epoll_统计() {
    返回 {
        活跃实例: 全局_epoll实例数,
        总等待次数: 全局_epoll等待数,
        总事件数: 全局_epoll事件总数,
        总唤醒数: 全局_epoll唤醒总数,
        总超时数: 全局_epoll超时数,
    }
}

函数 epoll_实例统计(epfd) {
    定义 ep = 获取epoll实例(epfd)
    如果 (ep == 空) { 返回 空 }
    返回 {
        监控项数: ep.监控项数,
        就绪数: ep.就绪数,
        等待次数: ep.等待次数,
        事件触发: ep.事件触发总数,
        超时次数: ep.超时次数,
        IO模式: ep.AI_IO模式,
        AI预测命中: ep.AI_命中次数,
        创建时间: ep.创建时间,
    }
}

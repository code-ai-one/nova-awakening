// 推理交互协同装载
// 将会话、消息、界面、设备与协同推理能力接回浏览器外衣与桥接链路。

导入("./分组查询.nova")
导入("./浏览连接.nova")
导入("./推理后援.nova")
导入("./会话存储.nova")
导入("./设备接口.nova")
导入("./像素感知引.nova")
导入("./智能体状态.nova")
导入("./用户管理.nova")
导入("./消息存储.nova")
导入("./界面操作.nova")
导入("./表情系统.nova")
导入("./适应优化.nova")
导入("./模型导出.nova")

函数 推理交互协同装载_模块清单() {
    返回 [
        "./分组查询.nova",
        "./浏览连接.nova",
        "./推理后援.nova",
        "./会话存储.nova",
        "./设备接口.nova",
        "./像素感知引.nova",
        "./智能体状态.nova",
        "./用户管理.nova",
        "./消息存储.nova",
        "./界面操作.nova",
        "./表情系统.nova",
        "./适应优化.nova",
        "./模型导出.nova"
    ]
}

函数 推理交互协同装载_统计() {
    返回 {
        模块数: 计数(推理交互协同装载_模块清单())
    }
}

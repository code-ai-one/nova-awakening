// Nova 标准库 · 集合 · 动态规划
// 实验反哺: DP经典实验验证了LCS/编辑距离/背包/LIS的正确性
// 应用: 中文文本相似度(编辑距离)、汉字学习路径(背包)、语义连贯性(最长公共子串)

// 最长公共子序列 (最长公共子串, 0)
函数 DP_LCS长度(序列A, 序列B) {
    定义 m = 计数(序列A); 定义 n = 计数(序列B)
    如果 (m == 0 或 n == 0) { 返回 0 }
    定义 可变 dp = []
    定义 可变 i = 0
    当 (i <= m) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j <= n) { 追加(行, 0); j = j + 1 }
        追加(dp, 行); i = i + 1
    }
    i = 1
    当 (i <= m) {
        定义 可变 j = 1
        当 (j <= n) {
            如果 (序列A[i-1] == 序列B[j-1]) {
                dp[i][j] = dp[i-1][j-1] + 1
            } 否则 {
                定义 可变 _dpv = dp[i][j-1]
                如果 (dp[i-1][j] > dp[i][j-1]) { _dpv = dp[i-1][j] }
                dp[i][j] = _dpv
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 dp[m][n]
}

// LCS相似度（0-100）= LCS长度 / max(m,n) × 100
函数 DP_LCS相似度(序列A, 序列B) {
    定义 m = 计数(序列A); 定义 n = 计数(序列B)
    如果 (m == 0 且 n == 0) { 返回 100 }
    如果 (m == 0 或 n == 0) { 返回 0 }
    定义 lcs = DP_LCS长度(序列A, 序列B)
    定义 可变 最大长 = n
    如果 (m > n) { 最大长 = m }
    如果 (最大长 == 0) { 返回 0 }
 返回 lcs * 100 / 最大长
}

// 编辑距离 (Levenshtein, 0)
函数 DP_编辑距离(序列A, 序列B) {
    定义 可变 curr = []
    定义 m = 计数(序列A); 定义 n = 计数(序列B)
    // 滚动数组优化（只需两行）
    定义 可变 前值 = []
    定义 可变 j = 0
    当 (j <= n) { 追加(前值, j); 追加(curr, 0); j = j + 1 }
    定义 可变 i = 1
    当 (i <= m) {
        curr[0] = i
        j = 1
        当 (j <= n) {
            如果 (序列A[i-1] == 序列B[j-1]) {
                curr[j] = 前值[j-1]
            } 否则 {
                定义 可变 最小 = 前值[j-1] + 1  // 替换
                如果 (前值[j] + 1 < 最小) { 最小 = 前值[j] + 1 }   // 删除
                如果 (curr[j-1] + 1 < 最小) { 最小 = curr[j-1] + 1 } // 插入
                curr[j] = 最小
            }
            j = j + 1
        }
        // 交换prev和curr
        curr = []
        j = 0
        当 (j <= n) { 追加(curr, 0); j = j + 1 }
        i = i + 1
    }
    返回 前值[n]
}

// 编辑相似度（0-100）= (1 - 编辑距离/max(m,n)) × 100
函数 DP_编辑相似度(序列A, 序列B) {
    定义 m = 计数(序列A); 定义 n = 计数(序列B)
    如果 (m == 0 且 n == 0) { 返回 100 }
    定义 可变 最大长 = n
    如果 (m > n) { 最大长 = m }
    定义 ed = DP_编辑距离(序列A, 序列B)
    如果 (ed >= 最大长) { 返回 0 }
    如果 (最大长 == 0) { 返回 0 }
    返回 (最大长 - ed) * 100 / 最大长
}

// 0-1背包
函数 DP_背包最大价值(物品列表, 容量) {
    定义 n = 计数(物品列表)
    如果 (n == 0 或 容量 == 0) { 返回 0 }
    定义 可变 dp = []
    定义 可变 j = 0
    当 (j <= 容量) { 追加(dp, 0); j = j + 1 }
    定义 可变 i = 0
    当 (i < n) {
        定义 w = 物品列表[i][0]; 定义 v = 物品列表[i][1]
        j = 容量
        当 (j >= w) {
            如果 (dp[j-w] + v > dp[j]) { dp[j] = dp[j-w] + v }
            j = j - 1
        }
        i = i + 1
    }
    返回 dp[容量]
}

// 最长递增子序列 (LIS)
函数 DP_LIS长度(序列) {
    定义 n = 计数(序列)
    如果 (n == 0) { 返回 0 }
    定义 可变 dp = []
    定义 可变 i = 0
    当 (i < n) { 追加(dp, 1); i = i + 1 }
    定义 可变 最大 = 1
    i = 1
    当 (i < n) {
        定义 可变 j = 0
        当 (j < i) {
            如果 (序列[j] < 序列[i] 且 dp[j] + 1 > dp[i]) { dp[i] = dp[j] + 1 }
            j = j + 1
        }
        如果 (dp[i] > 最大) { 最大 = dp[i] }
        i = i + 1
    }
    返回 最大
}

// 汉字序列相似度（中文特化）
// 基于编辑距离但考虑部首相似性（同部首汉字替换代价低于0.5）
函数 DP_汉字序列相似度(码点序列A, 码点序列B) {
    // 简化版：直接用LCS相似度作为汉字序列相似度
    // 未来可扩展为部首感知编辑距离
    返回 DP_LCS相似度(码点序列A, 码点序列B)
}

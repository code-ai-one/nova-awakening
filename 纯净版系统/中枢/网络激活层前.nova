// ReLU/LeakyReLU/ELU/GELU/Swish/Sigmoid/Tanh/PReLU/Softplus/HardSigmoid
// MLP/BatchNorm/SGD-Momentum/Nesterov/AdaGrad

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./网络追加.nova")
导入("./内核打印.nova")
导入("./整数转字符串.nova")
导入("./打乱.nova")

定义 可变 激活_前向次数 = 0
定义 可变 激活_反向次数 = 0
定义 可变 优化_更新次数 = 0

// §1 ReLU

函数 relu层_前向(输入) {
    激活_前向次数 = 激活_前向次数 + 1
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        如果 (输入[i] > 0) { 网络_追加(输出, 输入[i]) }
        否则 { 网络_追加(输出, 0) }
        i = i + 1
    }
    返回 输出
}

函数 relu层_反向(输入, 输出梯度) {
    激活_反向次数 = 激活_反向次数 + 1
    定义 可变 梯度 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        如果 (输入[i] > 0) { 网络_追加(梯度, 输出梯度[i]) }
        否则 { 网络_追加(梯度, 0) }
        i = i + 1
    }
    返回 梯度
}

// ReLU6: min(max(x, 0), 6)
函数 relu6_前向(输入) {
    激活_前向次数 = 激活_前向次数 + 1
    定义 上界 = 6 * 网络精度
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        定义 可变 v = 输入[i]
        如果 (v < 0) { v = 0 }
        如果 (v > 上界) { v = 上界 }
        网络_追加(输出, v)
        i = i + 1
    }
    返回 输出
}

// §2 Leaky ReLU

函数 leaky_relu_前向(输入, alpha) {
    激活_前向次数 = 激活_前向次数 + 1
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        如果 (输入[i] > 0) { 网络_追加(输出, 输入[i]) }
        否则 { 网络_追加(输出, 输入[i] * alpha / 网络精度) }
        i = i + 1
    }
    返回 输出
}

函数 leaky_relu_反向(输入, 输出梯度, alpha) {
    激活_反向次数 = 激活_反向次数 + 1
    定义 可变 梯度 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        如果 (输入[i] > 0) { 网络_追加(梯度, 输出梯度[i]) }
        否则 { 网络_追加(梯度, 输出梯度[i] * alpha / 网络精度) }
        i = i + 1
    }
    返回 梯度
}

// §3 ELU

函数 elu_前向(输入, alpha) {
    激活_前向次数 = 激活_前向次数 + 1
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        如果 (输入[i] > 0) {
            网络_追加(输出, 输入[i])
        } 否则 {
            // alpha * (exp(x) - 1), 近似: alpha * x * (1 + x/2)
            定义 x = 输入[i]
            定义 近似 = x + x * x / (2 * 网络精度)
            网络_追加(输出, alpha * 近似 / 网络精度)
        }
        i = i + 1
    }
    返回 输出
}

函数 elu_反向(输入, 输出, 输出梯度, alpha) {
    激活_反向次数 = 激活_反向次数 + 1
    定义 可变 梯度 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        如果 (输入[i] > 0) {
            网络_追加(梯度, 输出梯度[i])
        } 否则 {
            网络_追加(梯度, 输出梯度[i] * (输出[i] + alpha) / 网络精度)
        }
        i = i + 1
    }
    返回 梯度
}

// §4 Sigmoid (整数近似)

函数 sigmoid_前向(输入) {
    激活_前向次数 = 激活_前向次数 + 1
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        定义 x = 输入[i]
        定义 可变 s = 0
        // 分段线性近似 sigmoid
        如果 (x >= 4 * 网络精度) { s = 网络精度 }
        否则 如果 (x <= 0 - 4 * 网络精度) { s = 0 }
        否则 { s = 网络精度 / 2 + x / 8 }
        网络_追加(输出, s)
        i = i + 1
    }
    返回 输出
}

函数 sigmoid_反向(输出, 输出梯度) {
    激活_反向次数 = 激活_反向次数 + 1
    定义 可变 梯度 = []
    定义 可变 i = 0
    当 (i < 计数(输出)) {
        // sigmoid'(x) = sigmoid(x) * (1 - sigmoid(x))
        定义 s = 输出[i]
        定义 导数 = s * (网络精度 - s) / 网络精度
        网络_追加(梯度, 输出梯度[i] * 导数 / 网络精度)
        i = i + 1
    }
    返回 梯度
}

// §5 Tanh (整数近似)

函数 tanh_前向(输入) {
    激活_前向次数 = 激活_前向次数 + 1
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        定义 x = 输入[i]
        定义 可变 t = 0
        如果 (x >= 3 * 网络精度) { t = 网络精度 }
        否则 如果 (x <= 0 - 3 * 网络精度) { t = 0 - 网络精度 }
        否则 { t = x - x * x * x / (3 * 网络精度 * 网络精度) }
        网络_追加(输出, t)
        i = i + 1
    }
    返回 输出
}

函数 tanh_反向(输出, 输出梯度) {
    激活_反向次数 = 激活_反向次数 + 1
    定义 可变 梯度 = []
    定义 可变 i = 0
    当 (i < 计数(输出)) {
        // tanh'(x) = 1 - tanh²(x)
        定义 t = 输出[i]
        定义 导数 = 网络精度 - t * t / 网络精度
        网络_追加(梯度, 输出梯度[i] * 导数 / 网络精度)
        i = i + 1
    }
    返回 梯度
}

// §6 Swish: x * sigmoid(x)

函数 swish_前向(输入) {
    激活_前向次数 = 激活_前向次数 + 1
    定义 sig = sigmoid_前向(输入)
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        网络_追加(输出, 输入[i] * sig[i] / 网络精度)
        i = i + 1
    }
    返回 输出
}

// §7 GELU (近似)

函数 gelu_前向(输入) {
    激活_前向次数 = 激活_前向次数 + 1
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        // GELU ≈ x * sigmoid(1.702 * x)
        定义 x = 输入[i]
        定义 sx = x * 1702 / 1000
        定义 可变 s = 0
        如果 (sx >= 4 * 网络精度) { s = 网络精度 }
        否则 如果 (sx <= 0 - 4 * 网络精度) { s = 0 }
        否则 { s = 网络精度 / 2 + sx / 8 }
        网络_追加(输出, x * s / 网络精度)
        i = i + 1
    }
    返回 输出
}

// §8 Softplus: ln(1 + exp(x))

函数 softplus_前向(输入) {
    激活_前向次数 = 激活_前向次数 + 1
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        定义 x = 输入[i]
        如果 (x > 4 * 网络精度) {
            网络_追加(输出, x)  // ln(1+exp(x)) ≈ x for large x
        } 否则 如果 (x < 0 - 4 * 网络精度) {
            网络_追加(输出, 0)  // ln(1+exp(x)) ≈ 0 for very negative x
        } 否则 {
            // 近似: x/2 + precision/2 (线性区域)
            网络_追加(输出, 网络精度 / 2 + x / 2)
        }
        i = i + 1
    }
    返回 输出
}

// §9 Hard Sigmoid: clip(x/6 + 0.5, 0, 1)

函数 hard_sigmoid_前向(输入) {
    激活_前向次数 = 激活_前向次数 + 1
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        定义 可变 v = 输入[i] / 6 + 网络精度 / 2
        如果 (v < 0) { v = 0 }
        如果 (v > 网络精度) { v = 网络精度 }
        网络_追加(输出, v)
        i = i + 1
    }
    返回 输出
}

// §10 PReLU (可学习斜率)

函数 prelu_前向(输入, alpha_向量) {
    激活_前向次数 = 激活_前向次数 + 1
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < 计数(输入)) {
        如果 (输入[i] > 0) {
            网络_追加(输出, 输入[i])
        } 否则 {
            定义 a = 如果(i < 计数(alpha_向量), alpha_向量[i], 100)  // default 0.1
            网络_追加(输出, 输入[i] * a / 网络精度)
        }
        i = i + 1
    }
    返回 输出
}

// §11 批归一化前向

函数 batch_norm_前向(输入, gamma, beta, 运行均值, 运行方差, 训练) {
    激活_前向次数 = 激活_前向次数 + 1
    定义 n = 计数(输入)
    定义 可变 均值 = 0
    定义 可变 方差 = 0
    
    如果 (训练) {
        // 计算批均值
        定义 可变 i = 0
        当 (i < n) { 均值 = 均值 + 输入[i]  i = i + 1 }
        均值 = 均值 / n
        // 计算批方差
        i = 0
        当 (i < n) {
            定义 d = 输入[i] - 均值
            方差 = 方差 + d * d / 网络精度
            i = i + 1
        }
        方差 = 方差 / n
        // 更新运行统计 (动量=0.1)
        定义 可变 j = 0
        当 (j < n && j < 计数(运行均值)) {
            运行均值[j] = 运行均值[j] * 900 / 1000 + 均值 * 100 / 1000
            运行方差[j] = 运行方差[j] * 900 / 1000 + 方差 * 100 / 1000
            j = j + 1
        }
    } 否则 {
        均值 = 如果(计数(运行均值) > 0, 运行均值[0], 0)
        方差 = 如果(计数(运行方差) > 0, 运行方差[0], 网络精度)
    }
    
    定义 标准差 = 网络_开方(方差 + 1)  // +epsilon
    如果 (标准差 == 0) { 标准差 = 1 }
    
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < n) {
        定义 归一 = (输入[i] - 均值) * 网络精度 / 标准差
        定义 g = 如果(i < 计数(gamma), gamma[i], 网络精度)
        定义 b = 如果(i < 计数(beta), beta[i], 0)
        网络_追加(输出, 归一 * g / 网络精度 + b)
        i = i + 1
    }
    返回 输出
}

// §12 Nova多层感知器 (MLP)

函数 Nova多层感知器_创建(层维度) {
    定义 层数 = 计数(层维度) - 1
    定义 可变 层列表 = []
    定义 可变 i = 0
    当 (i < 层数) {
        网络_追加(层列表, 全连接_创建(层维度[i], 层维度[i + 1]))
        i = i + 1
    }
    返回 [层列表, 层数]
}

函数 Nova多层感知器_前向(网络, 输入) {
    定义 层列表 = 网络[0]
    定义 层数 = 网络[1]
    定义 可变 当前 = 输入
    定义 可变 i = 0
    当 (i < 层数) {
        当前 = 全连接_前向(层列表[i], 当前)
        如果 (i < 层数 - 1) {
            当前 = relu层_前向(当前)
        }
        i = i + 1
    }
    返回 当前
}

// 可选激活函数的MLP前向
函数 Nova多层感知器_前向_激活(网络, 输入, 激活类型) {
    定义 层列表 = 网络[0]
    定义 层数 = 网络[1]
    定义 可变 当前 = 输入
    定义 可变 i = 0
    当 (i < 层数) {
        当前 = 全连接_前向(层列表[i], 当前)
        如果 (i < 层数 - 1) {
            如果 (激活类型 == 0) { 当前 = relu层_前向(当前) }
            否则 如果 (激活类型 == 1) { 当前 = gelu_前向(当前) }
            否则 如果 (激活类型 == 2) { 当前 = swish_前向(当前) }
            否则 如果 (激活类型 == 3) { 当前 = tanh_前向(当前) }
            否则 { 当前 = relu层_前向(当前) }
        }
        i = i + 1
    }
    返回 当前
}

// §13 训练工具

函数 argmax(向量) {
    定义 n = 计数(向量)
    定义 可变 最大索引 = 0
    定义 可变 最大值 = 向量[0]
    定义 可变 i = 1
    当 (i < n) {
        如果 (向量[i] > 最大值) {
            最大值 = 向量[i]
            最大索引 = i
        }
        i = i + 1
    }
    返回 最大索引
}

函数 argmin(向量) {
    定义 n = 计数(向量)
    定义 可变 最小索引 = 0
    定义 可变 最小值 = 向量[0]
    定义 可变 i = 1
    当 (i < n) {
        如果 (向量[i] < 最小值) {
            最小值 = 向量[i]
            最小索引 = i
        }
        i = i + 1
    }
    返回 最小索引
}

函数 向量_求和(v) {
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < 计数(v)) { 和 = 和 + v[i]  i = i + 1 }
    返回 和
}

函数 向量_平均(v) {
    返回 向量_求和(v) / 计数(v)
}

函数 向量_最大(v) {
    定义 可变 m = v[0]
    定义 可变 i = 1
    当 (i < 计数(v)) {
        如果 (v[i] > m) { m = v[i] }
        i = i + 1
    }
    返回 m
}

函数 向量_最小(v) {
    定义 可变 m = v[0]
    定义 可变 i = 1
    当 (i < 计数(v)) {
        如果 (v[i] < m) { m = v[i] }
        i = i + 1
    }
    返回 m
}

函数 向量_范数(v) {
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < 计数(v)) {
        和 = 和 + v[i] * v[i] / 网络精度
        i = i + 1
    }
    返回 网络_开方(和)
}

// §14 Nova梯度下降动量优化器

函数 Nova梯度下降动量_创建(参数数) {
    定义 可变 速度 = []
    定义 可变 i = 0
    当 (i < 参数数) { 网络_追加(速度, 0)  i = i + 1 }
    返回 [速度]
}

函数 Nova梯度下降动量_更新(状态, 参数, 梯度, 学习率, 动量) {
    优化_更新次数 = 优化_更新次数 + 1
    定义 速度 = 状态[0]
    定义 可变 i = 0
    当 (i < 计数(参数)) {
        速度[i] = 动量 * 速度[i] / 网络精度 - 学习率 * 梯度[i] / 网络精度
        参数[i] = 参数[i] + 速度[i]
        i = i + 1
    }
}

// §15 Nesterov动量优化器

函数 Nesterov_创建(参数数) {
    定义 可变 速度 = []
    定义 可变 i = 0
    当 (i < 参数数) { 网络_追加(速度, 0)  i = i + 1 }
    返回 [速度]
}

函数 Nesterov_更新(状态, 参数, 梯度, 学习率, 动量) {
    优化_更新次数 = 优化_更新次数 + 1
    定义 速度 = 状态[0]
    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 旧速度 = 速度[i]
        速度[i] = 动量 * 速度[i] / 网络精度 - 学习率 * 梯度[i] / 网络精度
        参数[i] = 参数[i] - 动量 * 旧速度 / 网络精度 + (1 + 动量) * 速度[i] / 网络精度
        i = i + 1
    }
}

// §16 AdaGrad优化器

函数 AdaGrad_创建(参数数) {
    定义 可变 累积 = []
    定义 可变 i = 0
    当 (i < 参数数) { 网络_追加(累积, 0)  i = i + 1 }
    返回 [累积]
}

函数 AdaGrad_更新(状态, 参数, 梯度, 学习率) {
    优化_更新次数 = 优化_更新次数 + 1
    定义 累积 = 状态[0]
    定义 可变 i = 0
    当 (i < 计数(参数)) {
        累积[i] = 累积[i] + 梯度[i] * 梯度[i] / 网络精度
        定义 分母 = 网络_开方(累积[i]) + 1  // +epsilon
        参数[i] = 参数[i] - 学习率 * 梯度[i] / 分母
        i = i + 1
    }
}

// §17 统计

函数 激活层_统计() {
    返回 [激活_前向次数, 激活_反向次数, 优化_更新次数]
}

函数 激活层_打印统计() {
    打印行("=== 激活层统计 ===")
    打印行("前向次数: " + 整数转字符串(激活_前向次数))
    打印行("反向次数: " + 整数转字符串(激活_反向次数))
    打印行("优化更新: " + 整数转字符串(优化_更新次数))
}

// §18 【原生独创】谐振激活函数自适应选择器
// 根据梯度统计动态选择最优激活函数

定义 可变 _谐振激活_选择次数 = 0
定义 可变 _谐振激活_当前类型 = 0

函数 谐振激活_自适应选择(梯度均值, 梯度方差) {
    如果 (梯度均值 < 10 && 梯度方差 < 5) {
        _谐振激活_当前类型 = 2
    } 否则如果 (梯度方差 > 10000) {
        _谐振激活_当前类型 = 1
    } 否则 {
        _谐振激活_当前类型 = 0
    }
    _谐振激活_选择次数 = _谐振激活_选择次数 + 1
    返回 _谐振激活_当前类型
}

函数 网络激活层_完整统计() {
    返回 [
        "前向次数", 激活_前向次数,
        "反向次数", 激活_反向次数,
        "优化更新", 优化_更新次数,
        "谐振激活类型", _谐振激活_当前类型,
        "谐振选择次数", _谐振激活_选择次数
    ]
}

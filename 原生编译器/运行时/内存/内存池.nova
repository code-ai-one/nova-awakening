// Nova · 运行时 · 内存 · 内存池 (Slab分配器)
// 职责: 固定大小块分配、空闲链表、批量回收
// 层级: M9 — 极低内存profile

// Slab: [块大小, 总块数, 空闲列表, 已分配数, 水位线]

导入("../../标准库/基础.nova")

函数 Slab_创建(块大小, 总块数) {
    定义 可变 空闲 = []
    定义 可变 i = 0
    // 空闲链表: 倒序入栈,分配时pop
    当 (i < 总块数) { 追加(空闲, 总块数 - 1 - i)  i = i + 1 }
    返回 [块大小, 总块数, 空闲, 0, 0]
}

函数 Slab_块大小(s) { 返回 s[0] }
函数 Slab_总块数(s) { 返回 s[1] }
函数 Slab_已分配(s) { 返回 s[3] }
函数 Slab_空闲数(s) { 返回 计数(s[2]) }
函数 Slab_水位线(s) { 返回 s[4] }

函数 Slab_分配(s) {
    定义 可变 新空闲 = []
    如果 (计数(s[2]) == 0) { 返回 -1 }  // 已满
    定义 块号 = s[2][计数(s[2]) - 1]
    // 弹出最后一个
    定义 可变 i = 0
    当 (i < 计数(s[2]) - 1) { 追加(新空闲, s[2][i])  i = i + 1 }
    s[2] = 新空闲
    s[3] = s[3] + 1
    如果 (s[3] > s[4]) { s[4] = s[3] }
    返回 块号
}

函数 Slab_释放(s, 块号) {
    如果 (块号 < 0 或 块号 >= s[1]) { 返回 假 }
    追加(s[2], 块号)
    s[3] = s[3] - 1
    返回 真
}

函数 Slab_利用率(s) {
    如果 (s[1] == 0) { 返回 0 }
    返回 s[3] * 100 / s[1]
}

// 内存池: 多级Slab组合
// 级别: 64B, 256B, 1KB, 4KB
函数 内存池_创建() {
    返回 [
        Slab_创建(64, 256),    // 64B × 256块 = 16KB
        Slab_创建(256, 128),   // 256B × 128块 = 32KB
        Slab_创建(1024, 64),   // 1KB × 64块 = 64KB
        Slab_创建(4096, 16)    // 4KB × 16块 = 64KB
    ]
}

函数 _内存池_选级(大小) {
    如果 (大小 <= 64) { 返回 0 }
    如果 (大小 <= 256) { 返回 1 }
    如果 (大小 <= 1024) { 返回 2 }
    如果 (大小 <= 4096) { 返回 3 }
    返回 -1  // 超大,需fallback到通用分配
}

函数 内存池_分配(池, 大小) {
    定义 级 = _内存池_选级(大小)
    如果 (级 < 0) { 返回 [-1, -1] }  // 超大
    定义 块号 = Slab_分配(池[级])
    如果 (块号 < 0) { 返回 [-1, 级] }  // 该级已满
    返回 [块号, 级]
}

函数 内存池_释放(池, 块号, 级) {
    如果 (级 < 0 或 级 >= 4) { 返回 假 }
    返回 Slab_释放(池[级], 块号)
}

// 总统计
函数 内存池_总容量(池) {
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 4) {
        总 = 总 + Slab_块大小(池[i]) * Slab_总块数(池[i])
        i = i + 1
    }
    返回 总
}

函数 内存池_总已用(池) {
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 4) {
        总 = 总 + Slab_块大小(池[i]) * Slab_已分配(池[i])
        i = i + 1
    }
    返回 总
}

函数 内存池_利用率(池) {
    定义 容量 = 内存池_总容量(池)
    如果 (容量 == 0) { 返回 0 }
    返回 内存池_总已用(池) * 100 / 容量
}

// 批量重置(arena风格)
函数 内存池_重置(池) {
    定义 可变 i = 0
    当 (i < 4) {
        池[i][3] = 0
        池[i][2] = []
        定义 总块 = 池[i][1]
        定义 可变 j = 0
        当 (j < 总块) { 追加(池[i][2], 总块 - 1 - j)  j = j + 1 }
        i = i + 1
    }
}

// 报告
函数 内存池_打印报告(池) {
    打印("═══ 内存池报告 ═══")
    打印文本(字符串拼接("  总容量: ", 字符串拼接(转字符串(内存池_总容量(池)), " bytes")))
    打印文本(字符串拼接("  总已用: ", 字符串拼接(转字符串(内存池_总已用(池)), " bytes")))
    打印文本(字符串拼接("  利用率: ", 字符串拼接(转字符串(内存池_利用率(池)), "%")))
    打印("  各级Slab:")
    定义 可变 i = 0
    当 (i < 4) {
        定义 s = 池[i]
        i = i + 1
    }
}

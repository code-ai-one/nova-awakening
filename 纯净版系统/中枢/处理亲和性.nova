//   1. CPU亲和性: 限制进程只能在指定CPU上运行
//   2. cpumask: 位掩码表示允许的CPU集合
//   3. sched_setaffinity/sched_getaffinity: 系统调用
//   4. 硬亲和性: 进程绝对不会在禁止的CPU上运行
//   5. 用于: NUMA优化/实时任务绑核/性能调优

外部 进程_当前CPU

// 每个bit代表一个CPU: bit0=CPU0, bit1=CPU1, ...
定义 可变 系统CPU掩码 = 0xFF   // 默认8个CPU全部可用

// cpumask操作

函数 cpumask_设置(掩码, cpu) { 返回 掩码 | (1 << cpu) }
函数 cpumask_清除(掩码, cpu) { 返回 掩码 & ~(1 << cpu) }
函数 cpumask_测试(掩码, cpu) { 返回 (掩码 & (1 << cpu)) != 0 }
函数 cpumask_全部() { 返回 系统CPU掩码 }
函数 cpumask_无() {
    // 返回空CPU掩码(所有位清零)
    返回 0x0000000000000000
}
函数 cpumask_单CPU(cpu) { 返回 1 << cpu }

函数 cpumask_计数(掩码) {
    定义 可变 计 = 0
    定义 可变 m = 掩码
    当 (m != 0) {
        计 = 计 + (m & 1)
        m = m >> 1
    }
    返回 计
}

函数 cpumask_第一个(掩码) {
    定义 可变 i = 0
    当 (i < 64) {
        如果 ((掩码 & (1 << i)) != 0) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 cpumask_与(a, b) { 返回 a & b }
函数 cpumask_或(a, b) { 返回 a | b }

// sched_setaffinity / sched_getaffinity

函数 sys_sched_setaffinity(pid, 掩码) {
    // 验证掩码有效(至少一个在线CPU)
    如果 (cpumask_与(掩码, 系统CPU掩码) == 0) {
        返回 错误_无效参数
    }
    // 设置进程的CPU亲和性
    // task->cpus_allowed = 掩码
    返回 成功
}

函数 sys_sched_getaffinity(pid) {
    // 返回进程的CPU亲和性掩码
    返回 任务_获取CPU掩码(进程表_查找(pid))
}

// 迁移检查 (调度器使用)

函数 可以迁移到(任务, cpu) {
    // 1. CPU必须在线
    如果 (!cpumask_测试(系统CPU掩码, cpu)) { 返回 假 }
    // 2. 任务的CPU亲和性掩码必须允许
    定义 任务掩码 = 任务_获取CPU掩码(任务)
    如果 (任务掩码 != 0 && !cpumask_测试(任务掩码, cpu)) { 返回 假 }
    返回 真
}

函数 设置系统CPU掩码(CPU数) {
    如果 (CPU数 > 64) { CPU数 = 64 }
    如果 (CPU数 < 1) { CPU数 = 1 }
    系统CPU掩码 = (1 << CPU数) - 1
}

// per-task CPU掩码管理

定义 可变 任务CPU掩码表 = []   // [PID, 掩码] 列表

函数 任务_获取CPU掩码(任务) {
    定义 pid = 进程_PID(任务)
    定义 可变 i = 0
    当 (i < 计数(任务CPU掩码表)) {
        如果 (任务CPU掩码表[i][0] == pid) { 返回 任务CPU掩码表[i][1] }
        i = i + 1
    }
    返回 系统CPU掩码   // 默认: 所有在线CPU
}

函数 任务_设置CPU掩码(任务, 掩码) {
    // 验证掩码与在线CPU有交集
    如果 (cpumask_与(掩码, 系统CPU掩码) == 0) { 返回 错误_无效参数 }
    定义 pid = 进程_PID(任务)
    定义 可变 i = 0
    当 (i < 计数(任务CPU掩码表)) {
        如果 (任务CPU掩码表[i][0] == pid) {
            设置(任务CPU掩码表[i], 1, 掩码)
            // 如果任务当前运行在不允许的CPU上, 触发迁移
            返回 成功
        }
        i = i + 1
    }
    追加(任务CPU掩码表, [pid, 掩码])
    返回 成功
}

// cpumask高级操作

函数 cpumask_下一个(掩码, 从) {
    定义 可变 i = 从 + 1
    当 (i < 64) {
        如果 (cpumask_测试(掩码, i)) { 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 cpumask_相等(a, b) { 返回 a == b }
函数 cpumask_子集(子, 父) { 返回 (子 & 父) == 子 }
函数 cpumask_为空(掩码) { 返回 掩码 == 0 }

函数 CPU亲和性_统计() {
    返回 [计数(任务CPU掩码表), cpumask_计数(系统CPU掩码)]
}

// 迁移: 将任务移到允许的CPU 

函数 亲和性_迁移检查(任务) {
    // 检查任务当前CPU是否在允许掩码中
    定义 当前cpu = 进程_当前CPU(任务)
    定义 掩码 = 任务_获取CPU掩码(任务)
    如果 (cpumask_测试(掩码, 当前cpu)) { 返回 假 }  // 无需迁移
    返回 真  // 需要迁移
}

函数 亲和性_选择目标CPU(任务) {
    // 从允许掩码中选择最优CPU
    定义 掩码 = 任务_获取CPU掩码(任务)
    定义 有效掩码 = cpumask_与(掩码, 系统CPU掩码)
    如果 (有效掩码 == 0) { 返回 -1 }
    // 简单策略: 选择第一个可用的CPU
    返回 cpumask_第一个(有效掩码)
}

// 进程退出时清理

函数 任务_清除CPU掩码(pid) {
    定义 可变 i = 0
    当 (i < 计数(任务CPU掩码表)) {
        如果 (任务CPU掩码表[i][0] == pid) {
            链表_删除(任务CPU掩码表, i)
            返回
        }
        i = i + 1
    }
}

// cpumask遍历宏替代

函数 cpumask_遍历(掩码, 回调) {
    定义 可变 cpu = cpumask_第一个(掩码)
    当 (cpu >= 0) {
        回调(cpu)
        cpu = cpumask_下一个(掩码, cpu)
    }
}

函数 cpumask_转列表(掩码) {
    定义 可变 结果 = []
    定义 可变 cpu = cpumask_第一个(掩码)
    当 (cpu >= 0) {
        追加(结果, cpu)
        cpu = cpumask_下一个(掩码, cpu)
    }
    返回 结果
}

// 掩码格式化 + 在线CPU数

函数 在线CPU数() {
    返回 cpumask_计数(系统CPU掩码)
}

函数 cpumask_转字符串(掩码) {
    返回 "0x" + 整数转十六进制(掩码)
}

函数 CPU亲和性_完整统计() {
    返回 [计数(任务CPU掩码表), 在线CPU数()]
}

定义 可变 AI_处理亲和性_负载窗口 = []

函数 AI_处理亲和性_负载预测(当前负载) {
    追加(AI_处理亲和性_负载窗口, 当前负载)
    如果 (计数(AI_处理亲和性_负载窗口) > 20) { 列表_移除(AI_处理亲和性_负载窗口, 0) }
    如果 (计数(AI_处理亲和性_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_处理亲和性_负载窗口)
    定义 趋势 = AI_处理亲和性_负载窗口[n-1] - AI_处理亲和性_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_处理亲和性_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

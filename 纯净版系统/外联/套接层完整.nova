导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/创建甲.nova")

定义 最大套接字 = 1024
定义 套接_流 = 1
定义 套接_数据报 = 2
定义 套接_原始 = 3
定义 状态_未连接 = 0
定义 状态_监听 = 1
定义 状态_已连接 = 2
定义 状态_关闭中 = 3
定义 状态_已关闭 = 4

结构 套接字 {
    描述符,
    类型,
    协议,
    状态,
    本地地址,
    本地端口,
    远程地址,
    远程端口,
    发送缓冲,
    接收缓冲,
    发送字节,
    接收字节,
    积压队列,
    积压最大,
    引用计数,
    创建时刻,
}

定义 可变 套接字表 = 0
定义 可变 套接字数 = 0
定义 可变 创建数 = 0
定义 可变 关闭数 = 0
定义 可变 总发送字节 = 0
定义 可变 总接收字节 = 0
定义 可变 连接数 = 0
定义 可变 监听数 = 0

函数 套接_初始化() {
    套接字表 = 堆_分配(最大套接字 * 8)
    定义 可变 序号 = 0
    当 (序号 < 最大套接字) {
        内存_写64(套接字表 + 序号 * 8, 0)
        序号 = 序号 + 1
    }
    套接字数 = 0
}

函数 套接_创建(类型, 协议) {
    如果 (套接字数 >= 最大套接字) { 返回 -1 }
    创建数 = 创建数 + 1
    定义 套接 = 堆_分配(套接字)
    套接.描述符 = 套接字数
    套接.类型 = 类型
    套接.协议 = 协议
    套接.状态 = 状态_未连接
    套接.本地地址 = 0
    套接.本地端口 = 0
    套接.远程地址 = 0
    套接.远程端口 = 0
    套接.发送缓冲 = 堆_分配(65536)
    套接.接收缓冲 = 堆_分配(65536)
    套接.发送字节 = 0
    套接.接收字节 = 0
    套接.积压队列 = 0
    套接.积压最大 = 128
    套接.引用计数 = 1
    套接.创建时刻 = 平台_获取高精度时间()
    内存_写64(套接字表 + 套接字数 * 8, 套接)
    定义 索引 = 套接字数
    套接字数 = 套接字数 + 1
    返回 索引
}

函数 套接_绑定(描述符, 地址, 端口) {
    定义 套接 = 套接_获取(描述符)
    如果 (套接 == 0) { 返回 错误_无效参数 }
    套接.本地地址 = 地址
    套接.本地端口 = 端口
    返回 0
}

函数 套接_监听(描述符, 积压) {
    定义 套接 = 套接_获取(描述符)
    如果 (套接 == 0) { 返回 错误_无效参数 }
    如果 (套接.类型 != 套接_流) { 返回 错误_不支持 }
    套接.状态 = 状态_监听
    套接.积压最大 = 积压
    监听数 = 监听数 + 1
    返回 0
}

函数 套接_连接(描述符, 远程地址, 远程端口) {
    定义 套接 = 套接_获取(描述符)
    如果 (套接 == 0) { 返回 错误_无效参数 }
    套接.远程地址 = 远程地址
    套接.远程端口 = 远程端口
    套接.状态 = 状态_已连接
    连接数 = 连接数 + 1
    返回 0
}

函数 套接_发送(描述符, 数据, 长度) {
    定义 套接 = 套接_获取(描述符)
    如果 (套接 == 0) { 返回 错误_无效参数 }
    如果 (套接.状态 != 状态_已连接 && 套接.类型 == 套接_流) { 返回 错误_未连接 }
    内存_复制(套接.发送缓冲 + 套接.发送字节, 数据, 长度)
    套接.发送字节 = 套接.发送字节 + 长度
    总发送字节 = 总发送字节 + 长度
    返回 长度
}

函数 套接_接收(描述符, 缓冲, 最大长) {
    定义 套接 = 套接_获取(描述符)
    如果 (套接 == 0) { 返回 错误_无效参数 }
    如果 (套接.接收字节 == 0) { 返回 0 }
    定义 可读 = 套接.接收字节
    如果 (可读 > 最大长) { 可读 = 最大长 }
    内存_复制(缓冲, 套接.接收缓冲, 可读)
    如果 (可读 < 套接.接收字节) {
        内存_复制(套接.接收缓冲, 套接.接收缓冲 + 可读, 套接.接收字节 - 可读)
    }
    套接.接收字节 = 套接.接收字节 - 可读
    总接收字节 = 总接收字节 + 可读
    返回 可读
}

函数 套接_关闭(描述符) {
    定义 套接 = 套接_获取(描述符)
    如果 (套接 == 0) { 返回 错误_无效参数 }
    套接.引用计数 = 套接.引用计数 - 1
    如果 (套接.引用计数 <= 0) {
        套接.状态 = 状态_已关闭
        如果 (套接.发送缓冲 != 0) { 堆_释放(套接.发送缓冲) }
        如果 (套接.接收缓冲 != 0) { 堆_释放(套接.接收缓冲) }
        内存_写64(套接字表 + 描述符 * 8, 0)
        堆_释放(套接)
    }
    关闭数 = 关闭数 + 1
    返回 0
}

函数 套接_获取(描述符) {
    如果 (描述符 >= 套接字数) { 返回 0 }
    返回 内存_读64(套接字表 + 描述符 * 8)
}

函数 套接_投递数据(描述符, 数据, 长度) {
    定义 套接 = 套接_获取(描述符)
    如果 (套接 == 0) { 返回 }
    如果 (套接.接收字节 + 长度 <= 65536) {
        内存_复制(套接.接收缓冲 + 套接.接收字节, 数据, 长度)
        套接.接收字节 = 套接.接收字节 + 长度
    }
}

函数 套接_活跃数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 套接字数) {
        如果 (内存_读64(套接字表 + 序号 * 8) != 0) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 套接层_完整统计() {
    返回 [创建数, 关闭数, 总发送字节, 总接收字节, 连接数, 监听数, 套接_活跃数()]
}

定义 可变 AI_套接层完整_带宽估计 = 0
定义 可变 AI_套接层完整_丢包窗口 = []

函数 AI_套接层完整_带宽预测(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 AI_套接层完整_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    AI_套接层完整_带宽估计 = AI_套接层完整_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 AI_套接层完整_带宽估计
}

函数 AI_套接层完整_拥塞建议(丢包率) {
    追加(AI_套接层完整_丢包窗口, 丢包率)
    如果 (计数(AI_套接层完整_丢包窗口) > 10) { 列表_移除(AI_套接层完整_丢包窗口, 0) }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}

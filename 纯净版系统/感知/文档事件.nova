函数 文档事件_监听映射(档) {
    如果 (!文档事件_检查档(档)) { 返回 文档事件_失败(档, "监听映射", "事件档不可用") }
    文档事件_记录(档, "监听映射", [], "事件目标")
    档.监听数 = 档.监听数 + 1
    返回 文档事件_成功(档, "监听映射", 事件ListenerMap_创建())
}

函数 文档事件_添加监听(档, 目标节点, 类型字符串, 回调, 选项) {
    如果 (!文档事件_检查档(档)) { 返回 文档事件_失败(档, "添加监听", "事件档不可用") }
    文档事件_记录(档, "添加监听", [目标节点, 类型字符串, 回调, 选项], "事件目标")
    定义 结果 = 事件Target_add事件Listener(目标节点, 类型字符串, 回调, 选项)
    档.监听数 = 档.监听数 + 1
    返回 文档事件_成功(档, "添加监听", 结果)
}

函数 文档事件_移除监听(档, 目标节点, 类型字符串, 回调, 捕获) {
    如果 (!文档事件_检查档(档)) { 返回 文档事件_失败(档, "移除监听", "事件档不可用") }
    文档事件_记录(档, "移除监听", [目标节点, 类型字符串, 回调, 捕获], "事件目标")
    定义 结果 = 事件Target_remove事件Listener(目标节点, 类型字符串, 回调, 捕获)
    档.监听数 = 档.监听数 + 1

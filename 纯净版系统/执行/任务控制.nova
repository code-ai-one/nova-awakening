导入("../中枢/整数转字符串.nova")

// 龙壳 — 任务控制 — 深度吸收bash jobs.c
// 核心设计(来自bash):
//   1. 作业(job) = 一个管道中的所有进程组成的进程组
//   2. 前台作业: 终端等待其完成, 拥有终端控制权
//   3. 后台作业: 终端不等待, 用&启动
//   4. 暂停作业: Ctrl+Z发SIGTSTP, 可用fg/bg恢复
//   5. 作业编号: [1], [2]等, %1引用, %%引用当前作业
//   6. SIGCHLD: 后台进程退出时通知终端回收

定义 任务状态_运行  = 0    // Running
定义 任务状态_暂停  = 1    // Stopped (SIGTSTP/SIGSTOP)
定义 任务状态_完成  = 2    // Done (已退出)
定义 任务状态_前台  = 3    // 前台运行中

结构 任务项 {
    编号,    // u32 作业编号 [n]
    pid,    // u32 进程组leader PID
    pgid,    // u32 进程组ID
    状态,    // u32 任务状态_*
    退出码,    // i32 退出状态码 (-1=未退出)
    命令,    // 字符串 命令行文本
    通知,    // 布尔 是否需要通知用户状态变化
}

定义 最大任务数 = 256
定义 可变 任务表 = []
定义 可变 下一个任务编号 = 1
定义 可变 当前任务 = 0      // %%引用的当前作业
定义 可变 前一个任务 = 0    // %-引用的前一个作业

// 初始化

函数 任务_初始化() {
    任务表 = []
    下一个任务编号 = 1
    当前任务 = 0
    前一个任务 = 0
}

// 添加任务

函数 任务_添加(pid, 命令, 状态) {
    如果 (计数(任务表) >= 最大任务数) {
        // 清理已完成的任务腾出空间
        任务_清理已完成()
    }

    定义 任务 = 任务项 {}
    任务.编号 = 下一个任务编号
    任务.pid = pid
    任务.pgid = pid    // 进程组leader的pgid等于其pid
    任务.状态 = 状态
    任务.退出码 = -1
    任务.命令 = 命令
    任务.通知 = 假

    追加(任务表, 任务)

    // 更新当前/前一个任务指针
    前一个任务 = 当前任务
    当前任务 = 下一个任务编号

    下一个任务编号 = 下一个任务编号 + 1
    返回 任务.编号
}

函数 任务_添加后台(pid, 命令) {
    返回 任务_添加(pid, 命令, 任务状态_运行)
}

// 任务列表 

函数 任务_列表() {
    定义 可变 i = 0
    当 (i < 计数(任务表)) {
        定义 任务 = 任务表[i]
        如果 (任务.状态 != 任务状态_完成 || 任务.通知) {
            定义 状态文本 = 任务_状态文本(任务.状态)
            定义 标记 = " "
            如果 (任务.编号 == 当前任务) { 标记 = "+" }
            否则 如果 (任务.编号 == 前一个任务) { 标记 = "-" }

            打印行("[" + 整数转字符串(任务.编号) + "]" + 标记 + "  " +
                   状态文本 + "                    " + 任务.命令)

            // 已完成的任务, 通知后可清理
            如果 (任务.状态 == 任务状态_完成) {
                任务.通知 = 假
            }
        }
        i = i + 1
    }
}

函数 任务_状态文本(状态) {
    如果 (状态 == 任务状态_运行)  { 返回 "Running" }
    如果 (状态 == 任务状态_暂停)  { 返回 "Stopped" }
    如果 (状态 == 任务状态_完成)  { 返回 "Done" }
    如果 (状态 == 任务状态_前台)  { 返回 "Running(fg)" }
    返回 "Unknown"
}

// 查找/获取任务

函数 任务_查找(编号) {
    定义 可变 i = 0
    当 (i < 计数(任务表)) {
        如果 (任务表[i].编号 == 编号) { 返回 任务表[i] }
        i = i + 1
    }
    返回 空
}

函数 任务_按PID查找(pid) {
    定义 可变 i = 0
    当 (i < 计数(任务表)) {
        如果 (任务表[i].pid == pid) { 返回 任务表[i] }
        i = i + 1
    }
    返回 空
}

函数 任务_获取PID(编号) {
    // 编号=0: 使用当前任务
    如果 (编号 == 0) { 编号 = 当前任务 }
    定义 任务 = 任务_查找(编号)
    如果 (任务 == 空) { 返回 -1 }
    返回 任务.pid
}

函数 任务_当前编号() {
    返回 当前任务
}

// 设置/移除任务

函数 任务_设置状态(编号, 新状态) {
    定义 任务 = 任务_查找(编号)
    如果 (任务 != 空) {
        任务.状态 = 新状态
        如果 (新状态 == 任务状态_完成) {
            任务.通知 = 真
        }
    }
}

函数 任务_设置退出码(编号, 退出码) {
    定义 任务 = 任务_查找(编号)
    如果 (任务 != 空) {
        任务.退出码 = 退出码
    }
}

函数 任务_移除(编号) {
    定义 可变 i = 0
    当 (i < 计数(任务表)) {
        如果 (任务表[i].编号 == 编号) {
            列表_移除(任务表, i)
            // 更新当前任务指针
            如果 (当前任务 == 编号) {
                当前任务 = 前一个任务
            }
            返回
        }
        i = i + 1
    }
}

// 后台zombie回收 
// 在每次提示符前调用, 使用WNOHANG非阻塞等待

函数 任务_回收后台() {
    循环 {
        定义 状态 = [0]
        定义 pid = sys_wait4(-1, 状态, WNOHANG, 空, 0, 0)
        如果 (pid <= 0) { 中断 }   // 无已退出的子进程

        // 找到对应的任务
        定义 任务 = 任务_按PID查找(pid)
        如果 (任务 != 空) {
            定义 退出码 = (状态[0] >> 8) & 0xFF
            任务.状态 = 任务状态_完成
            任务.退出码 = 退出码
            任务.通知 = 真

            // 交互模式下通知用户
            打印行("\n[" + 整数转字符串(任务.编号) + "]+  Done" +
                   "                    " + 任务.命令)
        }
    }
}

// 等待所有后台任务 (wait内建)

函数 任务_等待全部() {
    定义 可变 i = 0
    当 (i < 计数(任务表)) {
        定义 任务 = 任务表[i]
        如果 (任务.状态 == 任务状态_运行) {
            定义 状态 = [0]
            sys_wait4(任务.pid, 状态, 0, 空, 0, 0)
            任务.状态 = 任务状态_完成
            任务.退出码 = (状态[0] >> 8) & 0xFF
        }
        i = i + 1
    }
}

// 清理已完成的任务

函数 任务_清理已完成() {
    定义 可变 i = 计数(任务表) - 1
    当 (i >= 0) {
        如果 (任务表[i].状态 == 任务状态_完成 && !任务表[i].通知) {
            列表_移除(任务表, i)
        }
        i = i - 1
    }
}

// 统计

函数 任务_统计() {
    定义 可变 运行中 = 0
    定义 可变 暂停 = 0
    定义 可变 完成 = 0
    定义 可变 i = 0
    当 (i < 计数(任务表)) {
        如果 (任务表[i].状态 == 任务状态_运行) { 运行中 = 运行中 + 1 }
        如果 (任务表[i].状态 == 任务状态_暂停) { 暂停 = 暂停 + 1 }
        如果 (任务表[i].状态 == 任务状态_完成) { 完成 = 完成 + 1 }
        i = i + 1
    }
    返回 [运行中, 暂停, 完成]
}

定义 WNOHANG = 0x00000001

定义 可变 AI_任务控制_运行指标 = 0
定义 可变 AI_任务控制_异常指标 = 0

函数 AI_任务控制_自诊断() {
    AI_任务控制_运行指标 = 0
    返回 AI_任务控制_运行指标
}

函数 AI_任务控制_优化建议() {
    定义 指标 = AI_任务控制_自诊断()
    返回 "任务控制状态正常"
}

函数 模糊与(a, b) {
    定义 _a = a + 0.0
    定义 _b = b + 0.0
    返回 _a * _b
}

函数 模糊或(a, b) {
    定义 _a = a + 0.0
    定义 _b = b + 0.0
    返回 _a + _b - _a * _b
}

函数 模糊非(a) {
    返回 1.0 - a
}

函数 模糊异或(a, b) {
    定义 _a = a + 0.0
    定义 _b = b + 0.0
    定义 或 = 模糊或(_a, _b)
    定义 与 = 模糊与(_a, _b)
    定义 非与 = 模糊非(与)
    返回 模糊与(或, 非与)
}

函数 主程序() {
    // 与 xor_debug.nova 相同的主程序, 使用 "或" 作变量名
    定义 或 = 模糊或(0.3, 0.7)
    打印(字符串拼接("或 bits=", 转字符串(或)))
    返回 0
}

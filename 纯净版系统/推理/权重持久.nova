// §9 权重持久化 — 保存/加载训练好的模型

// 模型文件格式: [magic 4B][层数 4B][层1头部][层1权重][层1偏置]...

定义 模型魔数 = 0x4E4F5641    // "NOVA"

函数 Nova多层感知器_保存(net, 文件路径) {
    定义 总大小 = 8    // magic + 层数
    定义 可变 i = 0
    当 (i < net.层数量) {
        定义 层 = 内存_读64(net.层列表 + i * 8)
        总大小 = 总大小 + 12    // 输入/输出/激活
        总大小 = 总大小 + 层.输入维度 * 层.输出维度 * 4    // 权重
        总大小 = 总大小 + 层.输出维度 * 4                   // 偏置
        i = i + 1
    }

    定义 缓冲 = 堆_分配_数组(总大小)
    定义 可变 偏移 = 0
    内存_写32(缓冲 + 偏移, 模型魔数); 偏移 = 偏移 + 4
    内存_写32(缓冲 + 偏移, net.层数量); 偏移 = 偏移 + 4

    i = 0
    当 (i < net.层数量) {
        定义 层 = 内存_读64(net.层列表 + i * 8)
        内存_写32(缓冲 + 偏移, 层.输入维度); 偏移 = 偏移 + 4
        内存_写32(缓冲 + 偏移, 层.输出维度); 偏移 = 偏移 + 4
        内存_写32(缓冲 + 偏移, 层.激活); 偏移 = 偏移 + 4
        // 权重
        定义 w大小 = 层.输入维度 * 层.输出维度 * 4
        内存_复制(缓冲 + 偏移, 层.权重.数据, w大小)
        偏移 = 偏移 + w大小
        // 偏置
        定义 b大小 = 层.输出维度 * 4
        内存_复制(缓冲 + 偏移, 层.偏置.数据, b大小)
        偏移 = 偏移 + b大小
        i = i + 1
    }

    文件_写入(文件路径, 缓冲, 总大小)
    堆_释放(缓冲)
}

函数 Nova多层感知器_加载(文件路径) {
    定义 可变 文件大小 = 0
    定义 缓冲 = 文件_读取(文件路径, &文件大小)
    如果 (缓冲 == 0 || 文件大小 < 8) { 返回 0 }

    定义 magic = 内存_读32(缓冲)
    如果 (magic != 模型魔数) { 堆_释放(缓冲); 返回 0 }

    定义 层数 = 内存_读32(缓冲 + 4)
    定义 net = Nova多层感知器_创建(层数)
    定义 可变 偏移 = 8

    定义 可变 i = 0
    当 (i < 层数) {
        定义 输入维 = 内存_读32(缓冲 + 偏移); 偏移 = 偏移 + 4
        定义 输出维 = 内存_读32(缓冲 + 偏移); 偏移 = 偏移 + 4
        定义 激活 = 内存_读32(缓冲 + 偏移); 偏移 = 偏移 + 4

        Nova多层感知器_添加层(net, 输入维, 输出维, 激活)
        定义 层 = 内存_读64(net.层列表 + i * 8)

        // 加载权重
        定义 w大小 = 输入维 * 输出维 * 4
        内存_复制(层.权重.数据, 缓冲 + 偏移, w大小)
        偏移 = 偏移 + w大小

        // 加载偏置
        定义 b大小 = 输出维 * 4
        内存_复制(层.偏置.数据, 缓冲 + 偏移, b大小)
        偏移 = 偏移 + b大小

        i = i + 1
    }

    堆_释放(缓冲)
    返回 net
}

// §10 预构建网络 — 浏览器各模块使用的专用网络

// 布局预测网络: 输入[元素特征12维] → 输出[位置预测4维(x,y,w,h)]
函数 创建_布局预测网络() {
    定义 net = Nova多层感知器_创建(4)
    Nova多层感知器_添加层(net, 12, 32, 激活类型_ReLU)
    Nova多层感知器_添加层(net, 32, 16, 激活类型_ReLU)
    Nova多层感知器_添加层(net, 16, 4, 激活类型_无)
    返回 net
}

// 注意力权重网络: 输入[节点特征8维] → 输出[注意力分数1维]
函数 创建_注意力网络() {
    定义 net = Nova多层感知器_创建(4)
    Nova多层感知器_添加层(net, 8, 16, 激活类型_ReLU)
    Nova多层感知器_添加层(net, 16, 8, 激活类型_ReLU)
    Nova多层感知器_添加层(net, 8, 1, 激活类型_Nova激活函数)
    返回 net
}

// 语义分类网络: 输入[标签+class+结构特征16维] → 输出[语义角色12类]
函数 创建_语义分类网络() {
    定义 net = Nova多层感知器_创建(4)
    Nova多层感知器_添加层(net, 16, 32, 激活类型_GELU)
    Nova多层感知器_添加层(net, 32, 16, 激活类型_GELU)
    Nova多层感知器_添加层(net, 16, 12, 激活类型_Nova归一化指数)
    返回 net
}

// 渲染质量网络: 输入[层特征6维] → 输出[渲染精度4类(跳过/低/中/高)]
函数 创建_渲染质量网络() {
    定义 net = Nova多层感知器_创建(4)
    Nova多层感知器_添加层(net, 6, 12, 激活类型_ReLU)
    Nova多层感知器_添加层(net, 12, 4, 激活类型_Nova归一化指数)
    返回 net
}

// 资源优先级网络: 输入[URL特征+类型10维] → 输出[优先级分数1维]
函数 创建_资源优先级网络() {
    定义 net = Nova多层感知器_创建(4)
    Nova多层感知器_添加层(net, 10, 16, 激活类型_ReLU)
    Nova多层感知器_添加层(net, 16, 8, 激活类型_ReLU)
    Nova多层感知器_添加层(net, 8, 1, 激活类型_Nova激活函数)
    返回 net
}

// 用户行为预测网络: 输入[历史序列20维] → 输出[下一步动作8类]
函数 创建_行为预测网络() {
    定义 net = Nova多层感知器_创建(4)
    Nova多层感知器_添加层(net, 20, 32, 激活类型_GELU)
    Nova多层感知器_添加层(net, 32, 16, 激活类型_GELU)
    Nova多层感知器_添加层(net, 16, 8, 激活类型_Nova归一化指数)
    返回 net
}

// 辅助存根
函数 内存_读32有符号(ptr) { 返回 内存_读32(ptr) }
函数 内存_写16(ptr, v) { 内存_写8(ptr, v & 0xFF); 内存_写8(ptr + 1, (v >> 8) & 0xFF) }
函数 文件_写入(路径, 数据, 大小) {
    如果 (路径 == 0 || 数据 == 0 || 大小 <= 0) { 返回 }
    定义 fd = 系统调用(2, 路径, 0x241)  // O_WRONLY|O_CREAT|O_TRUNC
    如果 (fd >= 0) { 系统调用(1, fd, 数据, 大小); 系统调用(3, fd) }
}
函数 文件_读取(路径, 大小指针) {
    如果 (路径 == 0) { 返回 0 }
    定义 fd = 系统调用_open(路径, 0)  // O_RDONLY
    如果 (fd < 0) { 返回 0 }
    // fstat获取文件大小
    定义 stat_buf = 堆_分配(128)
    系统调用_fstat(fd, stat_buf)
    定义 file_size = 内存_读64(stat_buf + 48)  // st_size offset
    堆_释放(stat_buf)
    如果 (file_size <= 0 || file_size > 100 * 1024 * 1024) {
        系统调用_close(fd); 返回 0
    }
    // 分配缓冲区并读取
    定义 buf = 堆_分配(file_size + 1)
    定义 可变 已读 = 0
    当 (已读 < file_size) {
        定义 n = 系统调用_read(fd, buf + 已读, file_size - 已读)
        如果 (n <= 0) { 跳出 }
        已读 = 已读 + n
    }
    内存_写8(buf + 已读, 0)  // null终止
    系统调用_close(fd)
    // 写入大小
    如果 (大小指针 != 0) { 内存_写64(大小指针, 已读) }
    返回 buf
}

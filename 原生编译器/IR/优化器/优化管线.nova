导入("./公共子表达式.nova")
导入("./函数内联.nova")
导入("./尾调用优化.nova")
导入("./常量折叠.nova")
导入("./死代码消除.nova")
导入("./窥孔优化.nova")
导入("../../编译器/规划/优化/SSA构建.nova")
导入("../../编译器/规划/优化/尾调用.nova")
导入("../../标准库/基础.nova")
导入("../../标准库/转换器/转换验证.nova")

//
// Nova  IR层  优化管线
// 统一调度所有优化Pass: 常量折叠  死代码消除  公共子表达式  强度削减

//  优化等级
定义 优化_无 = 0
定义 优化_基础 = 1
定义 优化_完全 = 2
定义 优化_激进 = 3

定义 可变 当前优化等级 = 优化_无

函数 设置优化等级(级别) {
    如果 (级别 >= 0 且 级别 <= 3) { 当前优化等级 = 级别 }
}

函数 获取优化等级() { 返回 当前优化等级 }

//  目标平台

定义 可变 优化管线_目标ELF = 1

函数 设置目标平台(目标) { 当前目标 = 目标 }
函数 获取目标平台() { 返回 当前目标 }

//  AST死代码消除Pass

函数 优化_消除函数死代码(函数体) {
    如果 (函数体 == 空 或 是列表(函数体) == 假 或 计数(函数体) == 0) { 返回 [函数体, 0] }
    定义 _不可达位 = 检测不可达(函数体)
    如果 (_不可达位 < 0) { 返回 [函数体, 0] }
    定义 原长 = 计数(函数体)
    当 (计数(函数体) > _不可达位) {
        删除(函数体, 计数(函数体) - 1)
    }
    返回 [函数体, 原长 - _不可达位]
}

//  全函数优化

函数 优化_全部函数(函数列表) {
    如果 (函数列表 == 空 或 是列表(函数列表) == 假) { 返回 0 }
    定义 可变 总删除 = 0
    定义 可变 _优fi = 0
    当 (_优fi < 计数(函数列表)) {
        如果 (是列表(函数列表[_优fi]) 且 计数(函数列表[_优fi]) >= 4) {
            定义 _优函体 = 函数列表[_优fi][3]
            如果 (是列表(_优函体) 且 计数(_优函体) > 0) {
                定义 结果 = 优化_消除函数死代码(_优函体)
                总删除 = 总删除 + 结果[1]
            }
        }
        _优fi = _优fi + 1
    }
    返回 总删除
}

//  优化管线执行

函数 优化管线_执行(函数列表, 主体列表) {
    定义 可变 报告 = [0, 0, 0, 0]
    定义 级别 = 当前优化等级
    管线_记录遍执行()

    // Pass 1: 常量折叠 (O1+, 多轮迭代直到不动点)
    折叠_重置统计()
    定义 折叠结果 = 折叠_多轮迭代(4, 函数列表)
    报告[0] = 折叠结果[1]

    // Pass 2: 死代码消除 (O1+, 真实截断不可达语句)
    定义 删除数 = 优化_全部函数(函数列表)
    报告[1] = 删除数
    定义 主体结果 = 优化_消除函数死代码(主体列表)
    报告[2] = 主体结果[1]

    // O0: 仅常量折叠+死代码，到此为止
    如果 (级别 < 优化_完全) { 返回 报告 }

    // Pass 3: 内联分析 + 变换 (O2+)
    定义 _内联器 = 函数内联_内联器_创建()
    调用图_创建()
    内联_重置深度()
    定义 可变 _候选数 = 0
    定义 可变 _内fi = 0
    当 (_内fi < 计数(函数列表)) {
        如果 (是列表(函数列表[_内fi]) 且 计数(函数列表[_内fi]) >= 4) {
            定义 _内名 = 函数列表[_内fi][1]
            定义 _内体 = 函数列表[_内fi][3]
            定义 _内参 = 函数列表[_内fi][2]
            定义 可变 _节点数 = 0
            如果 (是列表(_内体)) { _节点数 = 计数(_内体) }
            定义 可变 _参数数 = 0
            如果 (是列表(_内参)) { _参数数 = 计数(_内参) }
            函数内联_内联器_注册(_内联器, _内名, _节点数, _参数数)
            定义 _信息 = 函数内联_内联器_查找(_内联器, _内名)
            如果 (_信息 != 空 且 函数内联_值得内联(_信息)) {
                _候选数 = _候选数 + 1
            }
        }
        _内fi = _内fi + 1
    }
    报告[3] = _候选数
    // Pass 3.5: 函数内联变换（单返回小函数→子表达式替换）
    定义 _内联数 = 内联_变换全部(函数列表)
    报告[3] = 报告[3] + _内联数 * 1000

    // Pass 4: 尾递归→循环变换 (O2+, 真实AST重写)
    定义 _tco数 = 尾调用优_变换全部(函数列表)
    报告[4] = _tco数

    // Pass 5: CSE变换 (O2+, 连续定义中重复表达式→缓存变量引用)
    CSE_重置统计()
    值编号_重置()
    定义 _cse数 = CSE_变换全部(函数列表)
    报告[5] = _cse数

    // 窥孔优化在后端代码生成阶段执行(指令级，非AST级)
    // 见: 窥孔优化.nova::窥孔_优化(0) + ELF生成器.nova

    返回 报告
}

函数 优化管线_报告(报告) {
    打印文本(字符串拼接("  常量折叠: ", 字符串拼接(转字符串(报告[0]), "次")))
    打印文本(字符串拼接("  死代码消除: ", 字符串拼接(转字符串(报告[1] + 报告[2]), "条语句")))
    打印文本(字符串拼接("  内联候选: ", 字符串拼接(转字符串(报告[3]), "个函数")))
}

// Pass注册表：[[名称, 优先级, 已启用, 执行次数], ...]
// 优先级：数字越小越先执行；依赖保证有序执行
// 优化遍管理

定义 可变 _遍_列表 = []  // 遍注册表：[[名称, 优先级, 已启用, 执行次数]]
定义 可变 _遍_依赖前 = []  // 依赖：前遍名列表
定义 可变 _遍_依赖后 = []  // 依赖：后遍名列表

// 注册优化遍，返回遍ID
函数 优化遍_注册(名称, 优先级) {
    定义 id = 计数(_遍_列表)
    追加(_遍_列表, [名称, 优先级, 1, 0])
    返回 id
}

函数 优化遍_禁用(id) {
    如果 (id >= 0 且 id < 计数(_遍_列表)) {
        _遍_列表[id][2] = 0
    }
}

函数 优化遍_启用(id) {
    如果 (id >= 0 且 id < 计数(_遍_列表)) {
        _遍_列表[id][2] = 1
    }
}

函数 优化遍_查找(名称) {
    定义 可变 i = 0
    当 (i < 计数(_遍_列表)) {
        如果 (_遍_列表[i][0] == 名称) { 返回 i }
        i = i + 1
    }
    返回 0 - 1
}

// 已启用遍的ID列表（按优先级升序）
函数 优化遍_已启用列表() {
    定义 n = 计数(_遍_列表)
    // 收集已启用遍ID
    定义 可变 已启用 = []
    定义 可变 i = 0
    当 (i < n) {
        如果 (_遍_列表[i][2] != 0) { 追加(已启用, i) }
        i = i + 1
    }
    // 按优先级升序排序（选择排序）
    定义 m = 计数(已启用)
    i = 0
    当 (i < m - 1) {
        定义 可变 最小idx = i
        定义 可变 j = i + 1
        当 (j < m) {
            如果 (_遍_列表[已启用[j]][1] < _遍_列表[已启用[最小idx]][1]) {
                最小idx = j
            }
            j = j + 1
        }
        如果 (最小idx != i) {
            定义 暂存 = 已启用[i]
            已启用[i] = 已启用[最小idx]
            已启用[最小idx] = 暂存
        }
        i = i + 1
    }
    返回 已启用
}

函数 优化遍_按优先级排序() { 返回 优化遍_已启用列表() }

// 优化级别预设
// 初始化管线时按等级注册对应的遍

函数 优化管线_预设O0() {
    _遍_列表 = []
    设置优化等级(优化_无)
}

函数 优化管线_预设O1() {
    _遍_列表 = []
    优化遍_注册("常量折叠", 10)
    优化遍_注册("死代码消除", 20)
    设置优化等级(优化_基础)
}

函数 优化管线_预设O2() {
    _遍_列表 = []
    优化遍_注册("常量折叠", 10)
    优化遍_注册("死代码消除", 20)
    优化遍_注册("公共子表达式", 30)
    优化遍_注册("函数内联", 40)
    优化遍_注册("尾调用优化", 50)
    设置优化等级(优化_完全)
}

函数 优化管线_预设O3() {
    优化管线_预设O2()
    优化遍_注册("窥孔优化", 60)
    优化遍_注册("强度削减", 70)
    设置优化等级(优化_激进)
}

函数 优化管线_预设Os() {
    _遍_列表 = []
    优化遍_注册("死代码消除", 10)
    优化遍_注册("函数内联", 20)  // 内联小函数减小体积
    优化遍_注册("常量折叠", 30)
    设置优化等级(优化_完全)
}

// 遍依赖管理
函数 管线_添加依赖(前遍名, 后遍名) {
    追加(_遍_依赖前, 前遍名)
    追加(_遍_依赖后, 后遍名)
}

// 检查该遍的所有前置依赖是否都已执行
函数 管线_检查依赖(遍名) {
    定义 可变 i = 0
    当 (i < 计数(_遍_依赖后)) {
        如果 (_遍_依赖后[i] == 遍名) {
            // 找到依赖：前遍必须已注册
            定义 前遍 = _遍_依赖前[i]
            如果 (优化遍_查找(前遍) < 0) { 返回 假 }
        }
        i = i + 1
    }
    返回 真
}

// 遍性能追踪
定义 可变 _遍_耗时 = []

函数 管线_记录耗时(遍索引, 耗时) {
    当 (计数(_遍_耗时) <= 遍索引) { 追加(_遍_耗时, 0) }
    _遍_耗时[遍索引] = _遍_耗时[遍索引] + 耗时
}

函数 管线_最慢遍() {
    如果 (计数(_遍_耗时) == 0) { 返回 ["无", 0] }
    定义 可变 最慢idx = 0
    定义 可变 最慢时 = 0
    定义 可变 i = 0
    当 (i < 计数(_遍_耗时)) {
        如果 (_遍_耗时[i] > 最慢时) {
            最慢时 = _遍_耗时[i]
            最慢idx = i
        }
        i = i + 1
    }
    如果 (最慢idx < 计数(_遍_列表)) {
        返回 [_遍_列表[最慢idx][0], 最慢时]
    }
    返回 ["unknown", 最慢时]
}

函数 管线_总耗时() {
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(_遍_耗时)) { 总 = 总 + _遍_耗时[i] i = i + 1 }
    返回 总
}

// 条件遍执行
函数 管线_条件执行(遍索引, 条件) {
    如果 (条件 == 假 或 条件 == 0) { 返回 假 }
    如果 (遍索引 < 0 或 遍索引 >= 计数(_遍_列表)) { 返回 假 }
 如果 (_遍_列表[遍索引][2] == 0) { 返回 假 }  // 已禁用
    _遍_列表[遍索引][3] = _遍_列表[遍索引][3] + 1
    返回 真
}

// 迭代优化（多轮执行直到不动点）
// 返回实际执行轮数
函数 管线_迭代执行(最大轮数) {
    定义 可变 轮数 = 0
    定义 可变 上轮折叠数 = 0 - 1  // 初始化为不可能值
    当 (轮数 < 最大轮数) {
        折叠_重置统计()
        定义 报告 = 优化管线_执行([], [])
        定义 本轮折叠 = 报告[0]
        // 不动点判断：本轮无新折叠且无删除
        如果 (本轮折叠 == 0 且 报告[1] == 0) {
            返回 轮数 + 1  // 收敛
        }
        如果 (本轮折叠 == 上轮折叠数) {
            返回 轮数 + 1  // 收敛（相邻两轮相同）
        }
        上轮折叠数 = 本轮折叠
        轮数 = 轮数 + 1
    }
    返回 最大轮数
}

定义 可变 _管线_运行数 = 0
定义 可变 _管线_遍执行总数 = 0

函数 管线_记录运行() { _管线_运行数 = _管线_运行数 + 1 }
函数 管线_记录遍执行() { _管线_遍执行总数 = _管线_遍执行总数 + 1 }
函数 管线_运行次数() { 返回 _管线_运行数 }
函数 管线_遍执行总数() { 返回 _管线_遍执行总数 }

// 5.0: AI原生IR标签系统
// 为IR节点挂载算子标签、模态标签、记忆标签、量化标签
// 明确区分普通数组路径与AI原生路径

// IR算子标签
定义 IR标签_普通 = 0
定义 IR标签_约化 = 1
定义 IR标签_广播 = 2
定义 IR标签_注意力 = 3
定义 IR标签_采样 = 4
定义 IR标签_检索 = 5
定义 IR标签_量化 = 6
定义 IR标签_稀疏 = 7
定义 IR标签_图传播 = 8

函数 IR标签名(t) {
    如果 (t == IR标签_普通) { 返回 "普通" }
    如果 (t == IR标签_约化) { 返回 "约化" }
    如果 (t == IR标签_广播) { 返回 "广播" }
    如果 (t == IR标签_注意力) { 返回 "注意力" }
    如果 (t == IR标签_采样) { 返回 "采样" }
    如果 (t == IR标签_检索) { 返回 "检索" }
    如果 (t == IR标签_量化) { 返回 "量化" }
    如果 (t == IR标签_稀疏) { 返回 "稀疏" }
    如果 (t == IR标签_图传播) { 返回 "图传播" }
    返回 "unknown"
}

// 模态标签
定义 模态_无 = 0
定义 模态_文本 = 1
定义 模态_视觉 = 2
定义 模态_音频 = 3
定义 模态_行为 = 4
定义 模态_DOM = 5
定义 模态_多模态 = 6

函数 优化管线_模态名(m) {
    如果 (m == 模态_无) { 返回 "无" }
    如果 (m == 模态_文本) { 返回 "文本" }
    如果 (m == 模态_视觉) { 返回 "视觉" }
    如果 (m == 模态_音频) { 返回 "音频" }
    如果 (m == 模态_行为) { 返回 "行为" }
    如果 (m == 模态_DOM) { 返回 "DOM" }
    如果 (m == 模态_多模态) { 返回 "多模态" }
    返回 "未知模态"
}

// IR节点标签表: 字典<节点ID, [算子标签, 模态标签, 记忆标签, 量化标签]>
定义 可变 _IR标签表 = 空

函数 IR标签表_初始化() {
    _IR标签表 = 字典()
}

函数 IR标签表_设置(节点ID, 算子标签, 模态标签, 记忆标签, 量化标签) {
    如果 (_IR标签表 == 空) { IR标签表_初始化() }
    字典设(_IR标签表, 转字符串(节点ID), [算子标签, 模态标签, 记忆标签, 量化标签])
}

函数 IR标签表_查询(节点ID) {
    如果 (_IR标签表 == 空) { 返回 空 }
    返回 字典取(_IR标签表, 转字符串(节点ID))
}

函数 IR标签表_是AI路径(节点ID) {
    定义 标签 = IR标签表_查询(节点ID)
    如果 (标签 == 空) { 返回 假 }
    返回 标签[0] != IR标签_普通
}

函数 IR标签表_算子(节点ID) {
    定义 标签 = IR标签表_查询(节点ID)
    如果 (标签 == 空) { 返回 IR标签_普通 }
    返回 标签[0]
}

函数 IR标签表_模态(节点ID) {
    定义 标签 = IR标签表_查询(节点ID)
    如果 (标签 == 空) { 返回 模态_无 }
    返回 标签[1]
}

// 函数名→AI算子标签推断 (启发式)
函数 IR标签_从函数名推断(名称) {
    如果 (名称 == 空) { 返回 IR标签_普通 }
    如果 (字符串包含(名称, "注意力") 或 字符串包含(名称, "attention")) { 返回 IR标签_注意力 }
    如果 (字符串包含(名称, "量化") 或 字符串包含(名称, "quant")) { 返回 IR标签_量化 }
    如果 (字符串包含(名称, "检索") 或 字符串包含(名称, "retrieve")) { 返回 IR标签_检索 }
    如果 (字符串包含(名称, "采样") 或 字符串包含(名称, "sample")) { 返回 IR标签_采样 }
    如果 (字符串包含(名称, "稀疏") 或 字符串包含(名称, "sparse")) { 返回 IR标签_稀疏 }
    如果 (字符串包含(名称, "约化") 或 字符串包含(名称, "reduce")) { 返回 IR标签_约化 }
    如果 (字符串包含(名称, "广播") 或 字符串包含(名称, "broadcast")) { 返回 IR标签_广播 }
    如果 (字符串包含(名称, "图传播") 或 字符串包含(名称, "propagate")) { 返回 IR标签_图传播 }
    返回 IR标签_普通
}

// 函数名→模态标签推断
函数 IR标签_从函数名推断模态(名称) {
    如果 (名称 == 空) { 返回 模态_无 }
    如果 (字符串包含(名称, "DOM") 或 字符串包含(名称, "dom_")) { 返回 模态_DOM }
    如果 (字符串包含(名称, "行为序列") 或 字符串包含(名称, "行为_")) { 返回 模态_行为 }
    如果 (字符串包含(名称, "视觉") 或 字符串包含(名称, "图像")) { 返回 模态_视觉 }
    如果 (字符串包含(名称, "音频") 或 字符串包含(名称, "语音")) { 返回 模态_音频 }
    如果 (字符串包含(名称, "文本") 或 字符串包含(名称, "token")) { 返回 模态_文本 }
    返回 模态_无
}

// 优化管线: AI路径感知
// 裸机profile禁止对启动/中断/页表路径做激进内联
定义 可变 _管线_裸机模式 = 假

函数 管线_设置裸机模式(启用) { _管线_裸机模式 = 启用 }
函数 管线_是裸机() { 返回 _管线_裸机模式 }

函数 管线_函数可内联(函数名) {
    如果 (_管线_裸机模式 == 假) { 返回 真 }
    // 裸机模式: 启动/中断/页表/特权路径禁用激进内联
    如果 (字符串包含(函数名, "启动") 或 字符串包含(函数名, "boot")) { 返回 假 }
    如果 (字符串包含(函数名, "中断") 或 字符串包含(函数名, "interrupt")) { 返回 假 }
    如果 (字符串包含(函数名, "页表") 或 字符串包含(函数名, "page_table")) { 返回 假 }
    如果 (字符串包含(函数名, "异常") 或 字符串包含(函数名, "exception")) { 返回 假 }
    如果 (字符串包含(函数名, "特权") 或 字符串包含(函数名, "privilege")) { 返回 假 }
    返回 真
}

// 优化报告结构化输出
// [管线运行数, 遍执行总数, 各pass统计字典, AI路径节点数, 裸机禁内联数]
定义 可变 _管线_AI节点数 = 0
定义 可变 _管线_裸机禁内联 = 0

函数 管线_记录AI节点() { _管线_AI节点数 = _管线_AI节点数 + 1 }
函数 管线_记录裸机禁内联() { _管线_裸机禁内联 = _管线_裸机禁内联 + 1 }

函数 优化管线_结构化报告() {
    定义 可变 报告 = 字典()
    字典设(报告, "管线运行数", 转字符串(_管线_运行数))
    字典设(报告, "遍执行总数", 转字符串(_管线_遍执行总数))
    字典设(报告, "AI路径节点数", 转字符串(_管线_AI节点数))
    字典设(报告, "裸机禁内联数", 转字符串(_管线_裸机禁内联))
    字典设(报告, "优化等级", 转字符串(当前优化等级))
    字典设(报告, "裸机模式", 转字符串(_管线_裸机模式))
    定义 可变 遍数 = 计数(_遍_列表)
    字典设(报告, "注册遍数", 转字符串(遍数))
    返回 报告
}

函数 优化管线_打印结构化报告() {
    定义 r = 优化管线_结构化报告()
    打印文本(字符串拼接("[OPT-REPORT] 管线运行=", 字符串拼接(字典取(r, "管线运行数"), 字符串拼接(" 遍执行=", 字符串拼接(字典取(r, "遍执行总数"), 字符串拼接(" AI节点=", 字符串拼接(字典取(r, "AI路径节点数"), 字符串拼接(" 裸机禁内联=", 字典取(r, "裸机禁内联数")))))))))
}

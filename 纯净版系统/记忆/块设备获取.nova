导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/内存初始化.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/同步原语.nova")
导入("../执行/底层内存操.nova")

定义 最大块设备 = 64
定义 最大分区 = 16

结构 分区信息 {
    起始扇区,
    扇区数,
    类型,
    活动,
    父设备号,
}

定义 可变 块设备表 = 0
定义 可变 块设备数量 = 0
定义 可变 块设备锁 = 0
定义 可变 总读请求 = 0
定义 可变 总写请求 = 0

函数 块设备层_初始化() {
    块设备表 = 堆_分配(最大块设备 * 8)
    内存_清零(块设备表, 最大块设备 * 8)
    块设备数量 = 0
    块设备锁 = 自旋锁_创建()
}

函数 块设备_注册(名称, 主设备号, 操作表) {
    自旋锁_获取(块设备锁)
    如果 (块设备数量 >= 最大块设备) { 自旋锁_释放(块设备锁); 返回 -1 }
    定义 dev = 堆_分配(64)
    dev.名称 = 名称
    dev.主设备号 = 主设备号
    dev.操作表 = 操作表
    dev.扇区数 = 0
    dev.扇区大小 = 512
    dev.块大小 = 512
    dev.已注册 = 真
    dev.读次数 = 0
    dev.写次数 = 0
    dev.分区表 = 堆_分配(最大分区 * 8)
    内存_清零(dev.分区表, 最大分区 * 8)
    dev.分区数 = 0
    内存_写64(块设备表 + 块设备数量 * 8, dev)
    块设备数量 = 块设备数量 + 1
    自旋锁_释放(块设备锁)
    内核信息("块设备: 注册 " + 名称)
    返回 块设备数量 - 1
}

函数 块设备_注销(设备号) {
    如果 (设备号 >= 块设备数量) { 返回 }
    自旋锁_获取(块设备锁)
    定义 dev = 内存_读64(块设备表 + 设备号 * 8)
    如果 (dev != 空) {
        dev.已注册 = 假
        如果 (dev.分区表 != 0) { 堆_释放(dev.分区表) }
    }
    自旋锁_释放(块设备锁)
}

函数 块设备_获取(设备号) {
    如果 (设备号 >= 块设备数量) { 返回 空 }
    返回 内存_读64(块设备表 + 设备号 * 8)
}

函数 块设备_按名称查找(名称) {
    定义 可变 i = 0
    当 (i < 块设备数量) {
        定义 dev = 内存_读64(块设备表 + i * 8)
        如果 (dev != 空 && dev.名称 == 名称) { 返回 dev }
        i = i + 1
    }
    返回 空
}

函数 块设备_添加分区(设备号, 起始扇区, 扇区数, 类型) {
    定义 dev = 块设备_获取(设备号)
    如果 (dev == 空 || dev.分区数 >= 最大分区) { 返回 -1 }
    定义 分区 = 堆_分配(分区信息)
    分区.起始扇区 = 起始扇区
    分区.扇区数 = 扇区数
    分区.类型 = 类型
    分区.活动 = 假
    分区.父设备号 = 设备号
    内存_写64(dev.分区表 + dev.分区数 * 8, 分区)
    dev.分区数 = dev.分区数 + 1
    返回 dev.分区数 - 1
}

函数 块设备_扫描MBR分区(设备号) {
    定义 dev = 块设备_获取(设备号)
    如果 (dev == 空) { 返回 }
    定义 引导扇区 = 堆_分配(512)
    定义 操作表 = dev.操作表
    如果 (操作表 == 空 || 操作表.读 == 空) { 堆_释放(引导扇区); 返回 }
    操作表.读(dev, 0, 1, 引导扇区)
    如果 (内存_读16(引导扇区 + 510) != 0xAA55) { 堆_释放(引导扇区); 返回 }
    定义 可变 i = 0
    当 (i < 4) {
        定义 偏移 = 446 + i * 16
        定义 类型 = 内存_读8(引导扇区 + 偏移 + 4)
        如果 (类型 != 0) {
            定义 起始 = 内存_读32(引导扇区 + 偏移 + 8)
            定义 大小 = 内存_读32(引导扇区 + 偏移 + 12)
            块设备_添加分区(设备号, 起始, 大小, 类型)
        }
        i = i + 1
    }
    堆_释放(引导扇区)
}

函数 块设备_设置容量(设备号, 扇区数) {
    定义 dev = 块设备_获取(设备号)
    如果 (dev != 空) { dev.扇区数 = 扇区数 }
}

函数 块设备_获取容量(设备号) {
    定义 dev = 块设备_获取(设备号)
    如果 (dev == 空) { 返回 0 }
    返回 dev.扇区数 * dev.扇区大小
}

函数 块设备_读(dev, 扇区, 数量, 缓冲) {
    如果 (dev == 空 || 缓冲 == 0) { 返回 错误_无效参数 }
    定义 操作表 = dev.操作表
    如果 (操作表 != 空 && 操作表.读 != 空) {
        dev.读次数 = dev.读次数 + 1
        总读请求 = 总读请求 + 1
        返回 操作表.读(dev, 扇区, 数量, 缓冲)
    }
    返回 错误_不支持
}

函数 块设备_写(dev, 扇区, 数量, 缓冲) {
    如果 (dev == 空 || 缓冲 == 0) { 返回 错误_无效参数 }
    定义 操作表 = dev.操作表
    如果 (操作表 != 空 && 操作表.写 != 空) {
        dev.写次数 = dev.写次数 + 1
        总写请求 = 总写请求 + 1
        返回 操作表.写(dev, 扇区, 数量, 缓冲)
    }
    返回 错误_不支持
}

函数 块设备_打印列表() {
    内核打印("=== 块设备列表 ===\n")
    定义 可变 i = 0
    当 (i < 块设备数量) {
        定义 dev = 内存_读64(块设备表 + i * 8)
        如果 (dev != 空 && dev.已注册) {
            定义 容量MB = (dev.扇区数 * dev.扇区大小) / (1024 * 1024)
            内核打印("  %s: 主=%d 容量=%dMB 块大小=%d 分区=%d\n",
                dev.名称, dev.主设备号, 容量MB, dev.块大小, dev.分区数)
        }
        i = i + 1
    }
}

函数 块设备_完整统计() {
    返回 [块设备数量, 总读请求, 总写请求]
}

定义 可变 AI_块设备获取_故障预警数 = 0

函数 AI_块设备获取_设备健康(错误率, 响应时间, 温度) {
    定义 可变 分 = 1000
    如果 (错误率 > 10) { 分 = 分 - 错误率 * 5 }
    如果 (响应时间 > 1000) { 分 = 分 - 200 }
    如果 (温度 > 80) { 分 = 分 - 300 }
    如果 (分 < 300) { AI_块设备获取_故障预警数 = AI_块设备获取_故障预警数 + 1 }
    返回 分
}

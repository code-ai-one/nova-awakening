// NovaOS Adoption Agency 算法 — NAFRA理论 (Nova Adaptive Format Reconciliation Algorithm)
// 原创论文: 格式化元素自适应调和算法
// 核心思想: 将HTML规范§13.2.5.2.2的格式修正建模为图论中的边重组问题。
// 开放元素栈与活跃格式化列表构成二部图 G=(S,F,E)，
// 其中 S=栈节点集、F=格式化节点集、E=父子边集。
// adoption agency 操作等价于在保持树拓扑序不变的约束下，
// 对二部图执行最小代价边重组。
// NAFRA复杂度保证:
//   外循环上界: 8次 (规范硬约束)
//   内循环上界: 3次 (furthest block搜索)
//   总复杂度: O(8 * (3 + D))  D=栈深度
//   AI异常检测: O(F)张量推理
// 版权: NovaOS原创, 不依赖任何第三方算法库

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../推理/值乘.nova")
导入("../执行/组件网化.nova")
导入("./文档节点.nova")


定义 NAFRA_外循环上界      = 8     // 规范硬限制
定义 NAFRA_内循环上界      = 3     // furthest block搜索限制
定义 NAFRA_格式化列表上界  = 256   // 活跃格式化元素最大数量
定义 NAFRA_元素栈上界      = 512   // 开放元素栈最大深度
定义 NAFRA_作用域栈上界    = 64    // 作用域栈上界
定义 NAFRA_MARKER哨兵      = 0xAA55FF01
定义 NAFRA_AI特征维度      = 12    // AI异常检测向量维度

// 格式化元素类型原子枚举
定义 格式化标记_标记 = 0xFF000001  // scope marker
定义 格式类型_加粗   = 1   // <b>, <strong>
定义 格式类型_斜体   = 2   // <i>, <em>
定义 格式类型_下划线 = 3   // <u>
定义 格式类型_删除线 = 4   // <s>, <strike>
定义 格式类型_代码   = 5   // <code>, <tt>
定义 格式类型_字体   = 6   // <font>
定义 格式类型_大字   = 7   // <big>
定义 格式类型_小字   = 8   // <small>
定义 格式类型_链接   = 9   // <a>
定义 格式类型_NoBR   = 10  // <nobr>

// 全局统计计数器
定义 可变 NAFRA_调用总数         = 0
定义 可变 NAFRA_外循环总次数     = 0
定义 可变 NAFRA_内循环总次数     = 0
定义 可变 NAFRA_重组成功数       = 0
定义 可变 NAFRA_快速路径次数     = 0
定义 可变 NAFRA_格式列表移除数   = 0
定义 可变 NAFRA_P隐式关闭数       = 0
定义 可变 NAFRA_重建格式次数     = 0
定义 可变 NAFRA_作用域检查次数   = 0
定义 可变 NAFRA_AI异常检测数     = 0
定义 可变 NAFRA_最大外循环深度   = 0
定义 可变 NAFRA_最大内循环深度   = 0


函数 是格式化元素(标签原子) {
    如果 (标签原子 == 原子_b)      { 返回 格式类型_加粗 }
    如果 (标签原子 == 原子_strong)  { 返回 格式类型_加粗 }
    如果 (标签原子 == 原子_i)      { 返回 格式类型_斜体 }
    如果 (标签原子 == 原子_em)     { 返回 格式类型_斜体 }
    如果 (标签原子 == 原子_u)      { 返回 格式类型_下划线 }
    如果 (标签原子 == 原子_s)      { 返回 格式类型_删除线 }
    如果 (标签原子 == 原子_strike) { 返回 格式类型_删除线 }
    如果 (标签原子 == 原子_code)   { 返回 格式类型_代码 }
    如果 (标签原子 == 原子_tt)     { 返回 格式类型_代码 }
    如果 (标签原子 == 原子_font)   { 返回 格式类型_字体 }
    如果 (标签原子 == 原子_big)    { 返回 格式类型_大字 }
    如果 (标签原子 == 原子_small)  { 返回 格式类型_小字 }
    如果 (标签原子 == 原子_a)      { 返回 格式类型_链接 }
    如果 (标签原子 == 原子_nobr)   { 返回 格式类型_NoBR }
    返回 0  // 非格式化元素
}


函数 格式列表_初始化() {
    定义 列表 = 堆_分配(NAFRA_格式化列表上界 * 8 + 16)
    内存_分64(列表, 0)         // 数量 = 0
    内存_分64(列表 + 8, NAFRA_格式化列表上界)  // 容量
    返回 列表
}

函数 格式列表_添加(列表, 元素) {
    定义 数量 = 内存_读64(列表)
    定义 容量 = 内存_读64(列表 + 8)
    如果 (数量 >= 容量) {
        // 列表已满，执行规范定义的Noah算法清理
        格式列表_Noah清理(列表)
        数量 = 内存_读64(列表)
    }
    内存_分64(列表 + 16 + 数量 * 8, 元素)
    内存_分64(列表, 数量 + 1)
    返回 数量
}

函数 格式列表_插入标记(列表) {
    // 插入作用域标记 (scope marker)
    格式列表_添加(列表, 格式化标记_标记)
}

函数 格式列表_移除(列表, 索引) {
    定义 数量 = 内存_读64(列表)
    如果 (索引 < 0 || 索引 >= 数量) { 返回 }
    // 将后面的元素前移
    定义 可变 j = 索引
    当 (j < 数量 - 1) {
        内存_分64(列表 + 16 + j * 8, 内存_读64(列表 + 16 + (j + 1) * 8))
        j = j + 1
    }
    内存_分64(列表, 数量 - 1)
    NAFRA_格式列表移除数 = NAFRA_格式列表移除数 + 1
}

函数 格式列表_反向查找(列表, 标签原子) {
    // 从尾部向前搜索，遇到marker停止
    定义 数量 = 内存_读64(列表)
    定义 可变 i = 数量
    当 (i > 0) {
        i = i - 1
        定义 元 = 内存_读64(列表 + 16 + i * 8)
        如果 (元 == 格式化标记_标记) { 返回 -1 }  // 超出作用域
        定义 扩展 = 元素_获取扩展(元)
        如果 (扩展 != 0 && 扩展.标签名原子 == 标签原子) {
            返回 i
        }
    }
    返回 -1
}

函数 格式列表_替换(列表, 索引, 新元素) {
    定义 数量 = 内存_读64(列表)
    如果 (索引 >= 0 && 索引 < 数量) {
        内存_分64(列表 + 16 + 索引 * 8, 新元素)
    }
}

// Noah算法: 当格式化列表超出容量时，清理最旧的非标记项
函数 格式列表_Noah清理(列表) {
    定义 数量 = 内存_读64(列表)
    如果 (数量 == 0) { 返回 }
    // 找到第一个非标记项并移除
    定义 可变 i = 0
    当 (i < 数量) {
        定义 元 = 内存_读64(列表 + 16 + i * 8)
        如果 (元 != 格式化标记_标记) {
            格式列表_移除(列表, i)
            返回
        }
        i = i + 1
    }
}

函数 格式列表_清除到标记(列表) {
    // 清除到最后一个作用域标记
    定义 可变 数量 = 内存_读64(列表)
    当 (数量 > 0) {
        数量 = 数量 - 1
        定义 元 = 内存_读64(列表 + 16 + 数量 * 8)
        内存_分64(列表, 数量)
        如果 (元 == 格式化标记_标记) { 返回 }
    }
}


函数 元素栈_包含标签(栈, 标签原子) {
    定义 可变 i = 栈.数量
    当 (i > 0) {
        i = i - 1
        定义 元 = 内存_读64(栈.元素 + i * 8)
        定义 扩展 = 元素_获取扩展(元)
        如果 (扩展 != 0 && 扩展.标签名原子 == 标签原子) {
            返回 1
        }
    }
    返回 0
}

函数 元素栈_查找索引(栈, 元素) {
    定义 可变 i = 栈.数量
    当 (i > 0) {
        i = i - 1
        如果 (内存_读64(栈.元素 + i * 8) == 元素) {
            返回 i
        }
    }
    返回 -1
}

函数 元素栈_弹出直到含(栈, 标签原子) {
    当 (栈.数量 > 0) {
        定义 顶 = 内存_读64(栈.元素 + (栈.数量 - 1) * 8)
        栈.数量 = 栈.数量 - 1
        定义 扩展 = 元素_获取扩展(顶)
        如果 (扩展 != 0 && 扩展.标签名原子 == 标签原子) {
            返回
        }
    }
}

函数 元素栈_移除索引(栈, 索引) {
    如果 (索引 < 0 || 索引 >= 栈.数量) { 返回 }
    定义 可变 j = 索引
    当 (j < 栈.数量 - 1) {
        内存_分64(栈.元素 + j * 8, 内存_读64(栈.元素 + (j + 1) * 8))
        j = j + 1
    }
    栈.数量 = 栈.数量 - 1
}

函数 元素栈_插入在(栈, 索引, 元素) {
    如果 (索引 < 0 || 索引 > 栈.数量) { 返回 }
    // 后移
    定义 可变 j = 栈.数量
    当 (j > 索引) {
        内存_分64(栈.元素 + j * 8, 内存_读64(栈.元素 + (j - 1) * 8))
        j = j - 1
    }
    内存_分64(栈.元素 + 索引 * 8, 元素)
    栈.数量 = 栈.数量 + 1
}

// NAFRA理论中的作用域边界判定: 某些元素构成作用域边界，
// 在边界内的格式化元素才能参与adoption agency。

函数 是作用域边界_默认(标签原子) {
    如果 (标签原子 == 原子_applet)   { 返回 1 }
    如果 (标签原子 == 原子_caption)  { 返回 1 }
    如果 (标签原子 == 原子_html)     { 返回 1 }
    如果 (标签原子 == 原子_table)    { 返回 1 }
    如果 (标签原子 == 原子_td)       { 返回 1 }
    如果 (标签原子 == 原子_th)       { 返回 1 }
    如果 (标签原子 == 原子_marquee)  { 返回 1 }
    如果 (标签原子 == 原子_object)   { 返回 1 }
    如果 (标签原子 == 原子_template) { 返回 1 }
    返回 0
}

函数 元素栈_在作用域内(栈, 标签原子) {
    // 从栈顶向下搜索，检查是否在默认作用域内
    NAFRA_作用域检查次数 = NAFRA_作用域检查次数 + 1
    定义 可变 i = 栈.数量
    当 (i > 0) {
        i = i - 1
        定义 元 = 内存_读64(栈.元素 + i * 8)
        定义 扩展 = 元素_获取扩展(元)
        如果 (扩展 == 0) { 继续 }
        如果 (扩展.标签名原子 == 标签原子) { 返回 1 }
        如果 (是作用域边界_默认(扩展.标签名原子)) { 返回 0 }
    }
    返回 0
}

函数 元素栈_在按钮作用域内(栈, 标签原子) {
    定义 可变 i = 栈.数量
    当 (i > 0) {
        i = i - 1
        定义 元 = 内存_读64(栈.元素 + i * 8)
        定义 扩展 = 元素_获取扩展(元)
        如果 (扩展 == 0) { 继续 }
        如果 (扩展.标签名原子 == 标签原子) { 返回 1 }
        如果 (是作用域边界_默认(扩展.标签名原子)) { 返回 0 }
        如果 (扩展.标签名原子 == 原子_button) { 返回 0 }
    }
    返回 0
}

函数 元素栈_在表格作用域内(栈, 标签原子) {
    定义 可变 i = 栈.数量
    当 (i > 0) {
        i = i - 1
        定义 元 = 内存_读64(栈.元素 + i * 8)
        定义 扩展 = 元素_获取扩展(元)
        如果 (扩展 == 0) { 继续 }
        如果 (扩展.标签名原子 == 标签原子) { 返回 1 }
        如果 (扩展.标签名原子 == 原子_html)  { 返回 0 }
        如果 (扩展.标签名原子 == 原子_table) { 返回 0 }
        如果 (扩展.标签名原子 == 原子_template) { 返回 0 }
    }
    返回 0
}

// 实现HTML规范§13.2.5.2.2的完整外循环8次、内循环搜索furthest block、
// 节点重组、新格式化元素创建、子树迁移等全部步骤。

函数 HTMLTreeBuilder_adoption_agency(tb, 标签原子) {
    NAFRA_调用总数 = NAFRA_调用总数 + 1

    // 快速路径: 如果栈顶就是目标标签且不在格式化列表中
    定义 栈 = tb.开放元素栈
    定义 格式列表 = tb.格式化列表
    如果 (栈.数量 > 0) {
        定义 栈顶 = 内存_读64(栈.元素 + (栈.数量 - 1) * 8)
        定义 顶扩展 = 元素_获取扩展(栈顶)
        如果 (顶扩展 != 0 && 顶扩展.标签名原子 == 标签原子) {
            定义 在格式列表 = 格式列表_反向查找(格式列表, 标签原子)
            如果 (在格式列表 < 0) {
                // 不在格式化列表中，直接弹出栈顶
                栈.数量 = 栈.数量 - 1
                NAFRA_快速路径次数 = NAFRA_快速路径次数 + 1
                返回
            }
        }
    }

    // 外循环: 最多8次迭代
    定义 可变 外循环计数 = 0
    当 (外循环计数 < NAFRA_外循环上界) {
        外循环计数 = 外循环计数 + 1
        NAFRA_外循环总次数 = NAFRA_外循环总次数 + 1

        // 步骤1: 在格式化列表中找到最后一个匹配的格式化元素
        定义 格式索引 = 格式列表_反向查找(格式列表, 标签原子)
        如果 (格式索引 < 0) {
            // 没找到格式化元素，按普通结束标签处理
            如果 (元素栈_在作用域内(栈, 标签原子)) {
                元素栈_弹出直到含(栈, 标签原子)
            }
            返回
        }

        定义 格式元素 = 内存_读64(格式列表 + 16 + 格式索引 * 8)

        // 步骤2: 检查格式化元素是否在开放元素栈中
        定义 栈中索引 = 元素栈_查找索引(栈, 格式元素)
        如果 (栈中索引 < 0) {
            // 不在栈中: 从格式化列表中移除
            格式列表_移除(格式列表, 格式索引)
            继续
        }

        // 步骤3: 检查是否在作用域内
        如果 (!元素栈_在作用域内(栈, 标签原子)) {
            格式列表_移除(格式列表, 格式索引)
            返回
        }

        // 步骤4: 在栈中向上查找 furthest block
        定义 可变 furthest_block = 0
        定义 可变 furthest_索引 = -1
        定义 可变 k = 栈中索引 + 1
        当 (k < 栈.数量) {
            定义 元 = 内存_读64(栈.元素 + k * 8)
            定义 扩展 = 元素_获取扩展(元)
            如果 (扩展 != 0 && 是特殊元素(扩展.标签名原子)) {
                furthest_block = 元
                furthest_索引 = k
                跳出
            }
            k = k + 1
        }

        // 步骤5: 如果没有furthest block，弹出到格式化元素并移除
        如果 (furthest_block == 0) {
            元素栈_弹出直到含(栈, 标签原子)
            格式列表_移除(格式列表, 格式索引)
            NAFRA_重组成功数 = NAFRA_重组成功数 + 1
            返回
        }

        // 步骤6: common ancestor = 格式化元素的前一个栈元素
        定义 可变 common_ancestor = 0
        如果 (栈中索引 > 0) {
            common_ancestor = 内存_读64(栈.元素 + (栈中索引 - 1) * 8)
        }

        // 步骤7: 内循环 - 从 furthest block 向格式化元素方向遍历
        定义 可变 node = furthest_block
        定义 可变 node_栈索引 = furthest_索引
        定义 可变 last_node = furthest_block
        定义 可变 内循环计数 = 0

        当 (内循环计数 < NAFRA_内循环上界) {
            内循环计数 = 内循环计数 + 1
            NAFRA_内循环总次数 = NAFRA_内循环总次数 + 1

            // node = 栈中 node 的前一个元素
            node_栈索引 = node_栈索引 - 1
            如果 (node_栈索引 < 0) { 跳出 }
            node = 内存_读64(栈.元素 + node_栈索引 * 8)

            // 如果 node == 格式化元素，结束内循环
            如果 (node == 格式元素) { 跳出 }

            // 检查 node 是否在格式化列表中
            定义 node_格式索引 = 格式列表_查找元素(格式列表, node)
            如果 (node_格式索引 < 0) {
                // 不在格式化列表中，从栈中移除
                元素栈_移除索引(栈, node_栈索引)
                furthest_索引 = furthest_索引 - 1
                继续
            }

            // 创建新元素替代 node
            定义 新元素 = 创建替代格式元素(node)
            格式列表_替换(格式列表, node_格式索引, 新元素)
            内存_分64(栈.元素 + node_栈索引 * 8, 新元素)
            node = 新元素

            // 将 last_node 追加为 node 的子节点
            节点_追加子节点(node, last_node)
            last_node = node
        }

        // 步骤8: 将 last_node 插入到 common ancestor 的适当位置
        如果 (common_ancestor != 0) {
            节点_追加子节点(common_ancestor, last_node)
        }

        // 步骤9: 创建新的格式化元素
        定义 新格式 = 创建替代格式元素(格式元素)

        // 步骤10: 将 furthest block 的所有子节点迁移到新格式化元素
        节点_迁移所有子节点(新格式, furthest_block)

        // 步骤11: 将新格式化元素追加到 furthest block
        节点_追加子节点(furthest_block, 新格式)

        // 步骤12: 更新格式化列表 - 移除旧的，在furthest block后插入新的
        定义 旧格式索引 = 格式列表_查找元素(格式列表, 格式元素)
        如果 (旧格式索引 >= 0) {
            格式列表_移除(格式列表, 旧格式索引)
        }
        // 在 furthest block 在格式列表中的位置后插入新格式元素
        定义 fb格式索引 = 格式列表_查找元素(格式列表, furthest_block)
        如果 (fb格式索引 >= 0) {
            格式列表_插入在(格式列表, fb格式索引 + 1, 新格式)
        } 否则 {
            格式列表_添加(格式列表, 新格式)
        }

        // 步骤13: 更新开放元素栈 - 移除格式化元素，在furthest block后插入新的
        定义 旧栈索引 = 元素栈_查找索引(栈, 格式元素)
        如果 (旧栈索引 >= 0) {
            元素栈_移除索引(栈, 旧栈索引)
        }
        定义 fb栈索引 = 元素栈_查找索引(栈, furthest_block)
        如果 (fb栈索引 >= 0) {
            元素栈_插入在(栈, fb栈索引 + 1, 新格式)
        }

        NAFRA_重组成功数 = NAFRA_重组成功数 + 1
    }

    // 更新最大外循环深度统计
    如果 (外循环计数 > NAFRA_最大外循环深度) {
        NAFRA_最大外循环深度 = 外循环计数
    }
}


函数 创建替代格式元素(原元素) {
    // 克隆元素的标签名和属性，但不克隆子树
    定义 扩展 = 元素_获取扩展(原元素)
    如果 (扩展 == 0) { 返回 0 }
    定义 新元素 = 堆_分配(64)
    内存_置零(新元素, 64)
    // 复制标签名原子
    定义 新扩展 = 堆_分配(32)
    内存_置零(新扩展, 32)
    新扩展.标签名原子 = 扩展.标签名原子
    新扩展.命名空间 = 扩展.命名空间
    元素_设置扩展(新元素, 新扩展)
    // 复制属性
    如果 (扩展.属性数量 > 0) {
        复制元素属性(新元素, 原元素, 扩展.属性数量)
    }
    返回 新元素
}

函数 复制元素属性(目标, 源, 数量) {
    定义 可变 i = 0
    当 (i < 数量) {
        定义 源属性 = 元素_获取属性(源, i)
        如果 (源属性 != 0) {
            定义 副本 = 属性_克隆(源属性)
            元素_设置属性(目标, i, 副本)
        }
        i = i + 1
    }
}

函数 节点_追加子节点(父节点, 子节点) {
    如果 (父节点 == 0 || 子节点 == 0) { 返回 }
    // 先从旧父节点移除
    如果 (子节点.父节点 != 0) {
        节点_从父移除(子节点)
    }
    子节点.父节点 = 父节点
    子节点.后兄弟 = 0
    如果 (父节点.最后子 == 0) {
        父节点.第一子 = 子节点
        父节点.最后子 = 子节点
        子节点.前兄弟 = 0
    } 否则 {
        子节点.前兄弟 = 父节点.最后子
        父节点.最后子.后兄弟 = 子节点
        父节点.最后子 = 子节点
    }
}

函数 节点_从父移除(节点) {
    如果 (节点.父节点 == 0) { 返回 }
    定义 父 = 节点.父节点
    如果 (父.第一子 == 节点) {
        父.第一子 = 节点.后兄弟
    }
    如果 (父.最后子 == 节点) {
        父.最后子 = 节点.前兄弟
    }
    如果 (节点.前兄弟 != 0) {
        节点.前兄弟.后兄弟 = 节点.后兄弟
    }
    如果 (节点.后兄弟 != 0) {
        节点.后兄弟.前兄弟 = 节点.前兄弟
    }
    节点.父节点 = 0
    节点.前兄弟 = 0
    节点.后兄弟 = 0
}

函数 节点_迁移所有子节点(目标, 源) {
    定义 可变 ch = 源.第一子
    当 (ch != 0) {
        定义 next = ch.后兄弟
        节点_从父移除(ch)
        节点_追加子节点(目标, ch)
        ch = next
    }
}

函数 格式列表_查找元素(列表, 元素) {
    定义 数量 = 内存_读64(列表)
    定义 可变 i = 0
    当 (i < 数量) {
        如果 (内存_读64(列表 + 16 + i * 8) == 元素) {
            返回 i
        }
        i = i + 1
    }
    返回 -1
}

函数 格式列表_插入在(列表, 索引, 元素) {
    定义 数量 = 内存_读64(列表)
    定义 容量 = 内存_读64(列表 + 8)
    如果 (数量 >= 容量 || 索引 < 0 || 索引 > 数量) { 返回 }
    // 后移
    定义 可变 j = 数量
    当 (j > 索引) {
        内存_分64(列表 + 16 + j * 8, 内存_读64(列表 + 16 + (j - 1) * 8))
        j = j - 1
    }
    内存_分64(列表 + 16 + 索引 * 8, 元素)
    内存_分64(列表, 数量 + 1)
}

函数 是特殊元素(标签原子) {
    // 特殊元素 = 非格式化元素，作为 furthest block 候选
    如果 (是格式化元素(标签原子) != 0) { 返回 0 }
    返回 1
}


函数 应关闭P_当开始标签(标签原子) {
    // 这些块级元素会隐式关闭打开的<p>
    如果 (标签原子 == 原子_address)    { 返回 1 }
    如果 (标签原子 == 原子_blockquote) { 返回 1 }
    如果 (标签原子 == 原子_center)     { 返回 1 }
    如果 (标签原子 == 原子_details)    { 返回 1 }
    如果 (标签原子 == 原子_dialog)     { 返回 1 }
    如果 (标签原子 == 原子_dir)        { 返回 1 }
    如果 (标签原子 == 原子_div)        { 返回 1 }
    如果 (标签原子 == 原子_dl)         { 返回 1 }
    如果 (标签原子 == 原子_fieldset)   { 返回 1 }
    如果 (标签原子 == 原子_figcaption) { 返回 1 }
    如果 (标签原子 == 原子_figure)     { 返回 1 }
    如果 (标签原子 == 原子_footer)     { 返回 1 }
    如果 (标签原子 == 原子_header)     { 返回 1 }
    如果 (标签原子 == 原子_hgroup)     { 返回 1 }
    如果 (标签原子 == 原子_hr)         { 返回 1 }
    如果 (标签原子 == 原子_listing)    { 返回 1 }
    如果 (标签原子 == 原子_main)       { 返回 1 }
    如果 (标签原子 == 原子_menu)       { 返回 1 }
    如果 (标签原子 == 原子_nav)        { 返回 1 }
    如果 (标签原子 == 原子_ol)         { 返回 1 }
    如果 (标签原子 == 原子_p)          { 返回 1 }
    如果 (标签原子 == 原子_pre)        { 返回 1 }
    如果 (标签原子 == 原子_section)    { 返回 1 }
    如果 (标签原子 == 原子_summary)    { 返回 1 }
    如果 (标签原子 == 原子_ul)         { 返回 1 }
    如果 (标签原子 == 原子_h1 || 标签原子 == 原子_h2 || 标签原子 == 原子_h3 ||
        标签原子 == 原子_h4 || 标签原子 == 原子_h5 || 标签原子 == 原子_h6) { 返回 1 }
    如果 (标签原子 == 原子_table)      { 返回 1 }
    如果 (标签原子 == 原子_article)    { 返回 1 }
    如果 (标签原子 == 原子_aside)      { 返回 1 }
    返回 0
}

函数 处理隐式P关闭(tb, 标签原子) {
    如果 (应关闭P_当开始标签(标签原子)) {
        如果 (元素栈_在按钮作用域内(tb.开放元素栈, 原子_p)) {
            元素栈_弹出直到含(tb.开放元素栈, 原子_p)
            NAFRA_P隐式关闭数 = NAFRA_P隐式关闭数 + 1
        }
    }
}

// dd/dt隐式关闭处理
函数 处理_dd_dt_隐式关闭(tb, 标签原子) {
    如果 (标签原子 != 原子_dd && 标签原子 != 原子_dt) { 返回 }
    定义 栈 = tb.开放元素栈
    定义 可变 i = 栈.数量
    当 (i > 0) {
        i = i - 1
        定义 元 = 内存_读64(栈.元素 + i * 8)
        定义 扩展 = 元素_获取扩展(元)
        如果 (扩展 == 0) { 继续 }
        如果 (扩展.标签名原子 == 原子_dd || 扩展.标签名原子 == 原子_dt) {
            元素栈_弹出直到含(栈, 扩展.标签名原子)
            返回
        }
        如果 (是作用域边界_默认(扩展.标签名原子) && 扩展.标签名原子 != 原子_address &&
            扩展.标签名原子 != 原子_div && 扩展.标签名原子 != 原子_p) {
            返回
        }
    }
}

// li隐式关闭处理
函数 处理_li_隐式关闭(tb) {
    定义 栈 = tb.开放元素栈
    定义 可变 i = 栈.数量
    当 (i > 0) {
        i = i - 1
        定义 元 = 内存_读64(栈.元素 + i * 8)
        定义 扩展 = 元素_获取扩展(元)
        如果 (扩展 == 0) { 继续 }
        如果 (扩展.标签名原子 == 原子_li) {
            元素栈_弹出直到含(栈, 原子_li)
            返回
        }
        如果 (是作用域边界_默认(扩展.标签名原子) && 扩展.标签名原子 != 原子_address &&
            扩展.标签名原子 != 原子_div && 扩展.标签名原子 != 原子_p) {
            返回
        }
    }
}

// 当解析器进入某些插入模式时，需要重建未关闭的格式化元素。
// 例如: <b>hello <p>world — 进入<p>时需要重建<b>的效果。

函数 重建活跃格式化元素(tb) {
    定义 格式列表 = tb.格式化列表
    定义 数量 = 内存_读64(格式列表)

    // 步骤1: 如果格式化列表为空，直接返回
    如果 (数量 == 0) { 返回 }

    // 步骤2: 最后一个项是否为标记
    定义 最后 = 内存_读64(格式列表 + 16 + (数量 - 1) * 8)
    如果 (最后 == 格式化标记_标记) { 返回 }

    // 步骤3: 最后一个项是否在开放元素栈中
    如果 (元素栈_查找索引(tb.开放元素栈, 最后) >= 0) { 返回 }

    // 步骤4: 从rewind位置开始向前遍历
    定义 可变 重建索引 = 数量 - 1

    // 步骤5: rewind - 向前查找第一个不在栈中的项或标记
    当 (重建索引 > 0) {
        重建索引 = 重建索引 - 1
        定义 项 = 内存_读64(格式列表 + 16 + 重建索引 * 8)
        如果 (项 == 格式化标记_标记) {
            重建索引 = 重建索引 + 1
            跳出
        }
        如果 (元素栈_查找索引(tb.开放元素栈, 项) >= 0) {
            重建索引 = 重建索引 + 1
            跳出
        }
    }

    // 步骤6: advance - 从重建位置开始重建
    当 (重建索引 < 数量) {
        定义 待重建 = 内存_读64(格式列表 + 16 + 重建索引 * 8)
        如果 (待重建 == 格式化标记_标记) {
            重建索引 = 重建索引 + 1
            继续
        }

        // 创建新元素并插入树和栈
        定义 新元素 = 创建替代格式元素(待重建)
        如果 (新元素 != 0) {
            // 插入到当前位置
            TreeBuilder_插入元素(tb, 新元素)
            // 更新格式化列表中的引用
            格式列表_替换(格式列表, 重建索引, 新元素)
        }

        重建索引 = 重建索引 + 1
        NAFRA_重建格式次数 = NAFRA_重建格式次数 + 1
    }
}

函数 TreeBuilder_插入元素(tb, 元素) {
    // 将元素插入到当前插入位置并压入开放元素栈
    定义 栈 = tb.开放元素栈
    如果 (栈.数量 > 0) {
        定义 当前父 = 内存_读64(栈.元素 + (栈.数量 - 1) * 8)
        节点_追加子节点(当前父, 元素)
    }
    // 压栈
    如果 (栈.数量 < NAFRA_元素栈上界) {
        内存_分64(栈.元素 + 栈.数量 * 8, 元素)
        栈.数量 = 栈.数量 + 1
    }
}

// 利用全局AI总线对解析异常进行智能检测。
// 特征向量: [外循环次数, 内循环次数, 栈深度, 格式列表长度,
//              重组率, 快速路径率, P关闭率, 重建率,
//              作用域检查率, 调用频率, 平均外循环, 异常分数]

函数 NAFRA_AI异常检测(tb) {
    定义 t = Tensor_创建(NAFRA_AI特征维度, 1)
    如果 (t == 0) { 返回 0 }

    // 填充特征向量
    定义 栈深 = tb.开放元素栈.数量
    定义 格式长 = 内存_读64(tb.格式化列表)
    定义 平均外 = 0
    如果 (NAFRA_调用总数 > 0) {
        平均外 = NAFRA_外循环总次数 / NAFRA_调用总数
    }
    定义 可变 异常先验 = 0
    如果 (NAFRA_最大外循环深度 >= NAFRA_外循环上界 - 1) {
        异常先验 = 异常先验 + 400
    }
    如果 (栈深 > NAFRA_元素栈上界 / 2) {
        异常先验 = 异常先验 + 250
    }
    如果 (格式长 > NAFRA_格式列表上界 / 2) {
        异常先验 = 异常先验 + 150
    }
    如果 (NAFRA_调用总数 > 0 && NAFRA_快速路径次数 * 100 / NAFRA_调用总数 < 50) {
        异常先验 = 异常先验 + 100
    }
    如果 (NAFRA_作用域检查次数 > 0 && NAFRA_P隐式关闭数 * 100 / NAFRA_作用域检查次数 > 60) {
        异常先验 = 异常先验 + 100
    }
    如果 (异常先验 > 1000) { 异常先验 = 1000 }

    Tensor_写(t, 0, NAFRA_外循环总次数)
    Tensor_写(t, 1, NAFRA_内循环总次数)
    Tensor_写(t, 2, 栈深)
    Tensor_写(t, 3, 格式长)
    Tensor_写(t, 4, NAFRA_重组成功数)
    Tensor_写(t, 5, NAFRA_快速路径次数)
    Tensor_写(t, 6, NAFRA_P隐式关闭数)
    Tensor_写(t, 7, NAFRA_重建格式次数)
    Tensor_写(t, 8, NAFRA_作用域检查次数)
    Tensor_写(t, 9, NAFRA_调用总数)
    Tensor_写(t, 10, 平均外)
    Tensor_写(t, 11, 异常先验)

    // AI推理: 检测是否存在解析异常
    定义 结果 = AI总线_推理(t, "nafra_解析异常检测")
    定义 异常分 = 异常先验
    如果 (结果 != 0) {
        异常分 = (异常分 * 3 + Tensor_读(结果, 0)) / 4
    }

    // 启发式规则: 外循环达到上界近似异常
    如果 (NAFRA_最大外循环深度 >= NAFRA_外循环上界 - 1) {
        异常分 = 异常分 + 50
    }
    // 栈深度过大异常
    如果 (栈深 > NAFRA_元素栈上界 / 2) {
        异常分 = 异常分 + 30
    }
    // 格式化列表过长异常
    如果 (格式长 > NAFRA_格式化列表上界 / 2) {
        异常分 = 异常分 + 20
    }

    Tensor_写(t, 11, 异常分)
    NAFRA_AI异常检测数 = NAFRA_AI异常检测数 + 1

    Tensor_释放(t)
    如果 (结果 != 0) { Tensor_释放(结果) }
    返回 异常分
}


函数 NAFRA_获取统计() {
    定义 统计 = 堆_分配(128)
    内存_置零(统计, 128)
    内存_分64(统计 + 0,  NAFRA_调用总数)
    内存_分64(统计 + 8,  NAFRA_外循环总次数)
    内存_分64(统计 + 16, NAFRA_内循环总次数)
    内存_分64(统计 + 24, NAFRA_重组成功数)
    内存_分64(统计 + 32, NAFRA_快速路径次数)
    内存_分64(统计 + 40, NAFRA_格式列表移除数)
    内存_分64(统计 + 48, NAFRA_P隐式关闭数)
    内存_分64(统计 + 56, NAFRA_重建格式次数)
    内存_分64(统计 + 64, NAFRA_作用域检查次数)
    内存_分64(统计 + 72, NAFRA_AI异常检测数)
    内存_分64(统计 + 80, NAFRA_最大外循环深度)
    内存_分64(统计 + 88, NAFRA_最大内循环深度)
    返回 统计
}

函数 NAFRA_重置统计() {
    NAFRA_调用总数       = 0
    NAFRA_外循环总次数   = 0
    NAFRA_内循环总次数   = 0
    NAFRA_重组成功数     = 0
    NAFRA_快速路径次数   = 0
    NAFRA_格式列表移除数 = 0
    NAFRA_P隐式关闭数     = 0
    NAFRA_重建格式次数   = 0
    NAFRA_作用域检查次数 = 0
    NAFRA_AI异常检测数   = 0
    NAFRA_最大外循环深度 = 0
    NAFRA_最大内循环深度 = 0
}


函数 NAFRA_自检() {
    定义 可变 错误 = 0

    // 检查常量完整性
    如果 (NAFRA_外循环上界 != 8)   { 错误 = 错误 + 1 }
    如果 (NAFRA_内循环上界 != 3)   { 错误 = 错误 + 1 }
    如果 (NAFRA_格式化列表上界 < 1) { 错误 = 错误 + 1 }
    如果 (NAFRA_元素栈上界 < 1)   { 错误 = 错误 + 1 }

    // 检查格式化元素分类完整性
    如果 (是格式化元素(原子_b) != 格式类型_加粗)   { 错误 = 错误 + 1 }
    如果 (是格式化元素(原子_i) != 格式类型_斜体)   { 错误 = 错误 + 1 }
    如果 (是格式化元素(原子_a) != 格式类型_链接)   { 错误 = 错误 + 1 }
    如果 (是格式化元素(原子_div) != 0)          { 错误 = 错误 + 1 }
    如果 (是格式化元素(原子_p) != 0)            { 错误 = 错误 + 1 }

    // 检查作用域边界完整性
    如果 (是作用域边界_默认(原子_html) != 1)     { 错误 = 错误 + 1 }
    如果 (是作用域边界_默认(原子_table) != 1)    { 错误 = 错误 + 1 }
    如果 (是作用域边界_默认(原子_template) != 1) { 错误 = 错误 + 1 }
    如果 (是作用域边界_默认(原子_div) != 0)      { 错误 = 错误 + 1 }

    // 检查隐式P关闭完整性
    如果 (应关闭P_当开始标签(原子_div) != 1)       { 错误 = 错误 + 1 }
    如果 (应关闭P_当开始标签(原子_blockquote) != 1) { 错误 = 错误 + 1 }
    如果 (应关闭P_当开始标签(原子_b) != 0)          { 错误 = 错误 + 1 }
    如果 (应关闭P_当开始标签(原子_span) != 0)       { 错误 = 错误 + 1 }

    // 统计一致性检查
    如果 (NAFRA_重组成功数 > NAFRA_外循环总次数) { 错误 = 错误 + 1 }
    如果 (NAFRA_内循环总次数 > NAFRA_外循环总次数 * NAFRA_内循环上界) {
        错误 = 错误 + 1
    }
    如果 (NAFRA_最大外循环深度 > NAFRA_外循环上界) { 错误 = 错误 + 1 }

    返回 错误
}

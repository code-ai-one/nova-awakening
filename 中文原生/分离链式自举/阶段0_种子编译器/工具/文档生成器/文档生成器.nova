// 龙工具 — 文档生成器
// 从源码注释提取文档、生成 API 参考、Markdown 输出
// 支持函数签名解析、模块层级、交叉引用

导入("../../标准库/基础.nova")

// 文档条目类型
定义 文档_模块 = 1
定义 文档_函数 = 2
定义 文档_常量 = 3
定义 文档_结构 = 4
定义 文档_示例 = 5

// 文档条目
// [类型, 名称, 描述, 参数列表, 返回值描述, 示例代码, 所属模块, 行号]

函数 文档条目_创建(类型, 名称, 描述) { 返回 [类型, 名称, 描述, [], "", "", "", 0]
}

函数 文档条目_添加参数(条目, 参数名, 参数描述) {
 追加(条目[3], [参数名, 参数描述])
}

函数 文档条目_设返回(条目, 描述) { 条目[4] = 描述 }
函数 文档条目_设示例(条目, 代码) { 条目[5] = 代码 }
函数 文档条目_设模块(条目, 模块名) { 条目[6] = 模块名 }
函数 文档条目_设行号(条目, 行号) { 条目[7] = 行号 }

// 文档生成器
// 型: [条目列表, 模块映射, 配置]

函数 文档生成器_创建() { 返回 [[], 字典(), 字典()]
}

// 源码解析
// 从 Nova 源码提取文档注释和函数签名

函数 文档_解析源码(源码, 模块名) { 定义 行列表 = 文档_分割行(源码)
 定义 n = 计数(行列表)
 定义 可变 条目列表 = []
 定义 可变 i = 0
 定义 可变 当前注释 = []

 当 (i < n) { 定义 行 = 文档_去空白(行列表[i])

 // 收集文档注释 (以 // 开头)
 如果 (文档_开头是(行, "//")) { 定义 注释文本 = 文档_去空白(子串(行, 2, 计数(行) - 2))
 追加(当前注释, 注释文本)
 i = i + 1
 续
 }

 // 函数定义
 如果 (文档_开头是(行, "函数 ") 或 文档_开头是(行, "法 ")) { 定义 签名 = 文档_解析函数签名(行)
 如果 (签名 != 空) { 定义 条目 = 文档条目_创建(文档_函数, 签名[0], "")
 文档条目_设模块(条目, 模块名)
 文档条目_设行号(条目, i + 1)
 // 从注释中提取描述和参数
 文档_处理注释(条目, 当前注释)
 // 提取参数名
 定义 可变 p = 0
 当 (p < 计数(签名[1])) { 定义 可变 已有描述 = 假
 定义 可变 q = 0
 当 (q < 计数(条目[3])) { 如果 (字符串等于(条目[3][q][0], 签名[1][p])) { 已有描述 = 真 }
 q = q + 1
 }
 如果 (已有描述 == 假) {
 文档条目_添加参数(条目, 签名[1][p], "")
 }
 p = p + 1
 }
 追加(条目列表, 条目)
 }
 当前注释 = []
 i = i + 1
 续
 }

 // 常量定义
 如果 (文档_开头是(行, "定义 ") 或 文档_开头是(行, "令 ")) { 定义 常量名 = 文档_解析常量名(行)
 如果 (计数(常量名) > 0) { 定义 条目 = 文档条目_创建(文档_常量, 常量名, "")
 文档条目_设模块(条目, 模块名)
 文档条目_设行号(条目, i + 1)
 文档_处理注释(条目, 当前注释)
 追加(条目列表, 条目)
 }
 当前注释 = []
 i = i + 1
 续
 }

 // 模块标题注释 (═══ 开头)
 如果 (计数(当前注释) > 0 且 文档_包含(当前注释[0], "═══")) { 定义 标题 = 文档_去空白(当前注释[0])
 // 去掉 ═ 字符
 定义 可变 干净标题 = ""
 定义 可变 k = 0
 当 (k < 计数(标题)) { 定义 c = 子串(标题, k, 1)
 如果 (字符串等于(c, "═") == 假) {
 干净标题 = 字符串拼接(干净标题, c)
 }
 k = k + 1
 }
 干净标题 = 文档_去空白(干净标题)
 如果 (计数(干净标题) > 0) { 定义 段落条目 = 文档条目_创建(文档_模块, 干净标题, "")
 文档条目_设模块(段落条目, 模块名)
 如果 (计数(当前注释) > 1) {
 段落条目[2] = 文档_拼接描述(当前注释)
 }
 追加(条目列表, 段落条目)
 }
 }

 当前注释 = []
 i = i + 1
 }

 返回 条目列表
}

// 注释处理
函数 文档_处理注释(条目, 注释列表) { 定义 可变 描述 = ""
 定义 可变 i = 0
 当 (i < 计数(注释列表)) { 定义 行 = 注释列表[i]
 // @参数 名称 描述
 如果 (文档_开头是(行, "@参数 ") 或 文档_开头是(行, "@param ")) { 定义 剩余 = 文档_去空白(子串(行, 4, 计数(行) - 4))
 定义 空格位 = 文档_查找字符(剩余, " ")
 如果 (空格位 > 0) {
 文档条目_添加参数(条目, 子串(剩余, 0, 空格位), 文档_去空白(子串(剩余, 空格位, 计数(剩余) - 空格位)))
 }
 } 否则 如果 (文档_开头是(行, "@回 ") 或 文档_开头是(行, "@return ")) {
 文档条目_设返回(条目, 文档_去空白(子串(行, 4, 计数(行) - 4)))
 } 否则 如果 (文档_开头是(行, "@示例")) {
 // 后续行作为示例代码
 定义 可变 示例 = ""
 i = i + 1
 当 (i < 计数(注释列表) 且 文档_开头是(注释列表[i], "@") == 假) { 如果 (计数(示例) > 0) { 示例 = 字符串拼接(示例, "\n") }
 示例 = 字符串拼接(示例, 注释列表[i])
 i = i + 1
 }
 文档条目_设示例(条目, 示例)
 续
 } 否则 如果 (文档_包含(行, "═══") == 假) { 如果 (计数(描述) > 0) { 描述 = 字符串拼接(描述, " ") }
 描述 = 字符串拼接(描述, 行)
 }
 i = i + 1
 }
 条目[2] = 描述
}

// Markdown 输出

函数 文档_生成Markdown(条目列表, 标题) { 定义 可变 md = "# "
 md = 字符串拼接(md, 标题)
 md = 字符串拼接(md, "\n\n")
 定义 可变 当前模块 = ""
 定义 可变 i = 0
 当 (i < 计数(条目列表)) { 定义 条目 = 条目列表[i]
 如果 (条目[0] == 文档_模块) {
 md = 字符串拼接(md, "\n## ")
 md = 字符串拼接(md, 条目[1])
 md = 字符串拼接(md, "\n\n")
 如果 (计数(条目[2]) > 0) {
 md = 字符串拼接(md, 条目[2])
 md = 字符串拼接(md, "\n\n")
 }
 当前模块 = 条目[1]
 }
 如果 (条目[0] == 文档_函数) {
 md = 字符串拼接(md, "### `")
 md = 字符串拼接(md, 条目[1])
 md = 字符串拼接(md, "`\n\n")
 如果 (计数(条目[2]) > 0) {
 md = 字符串拼接(md, 条目[2])
 md = 字符串拼接(md, "\n\n")
 }
 如果 (计数(条目[3]) > 0) {
 md = 字符串拼接(md, "**参数:**\n\n")
 定义 可变 p = 0
 当 (p < 计数(条目[3])) {
 md = 字符串拼接(md, "- `")
 md = 字符串拼接(md, 条目[3][p][0])
 md = 字符串拼接(md, "`")
 如果 (计数(条目[3][p][1]) > 0) {
 md = 字符串拼接(md, " — ")
 md = 字符串拼接(md, 条目[3][p][1])
 }
 md = 字符串拼接(md, "\n")
 p = p + 1
 }
 md = 字符串拼接(md, "\n")
 }
 如果 (计数(条目[4]) > 0) {
 md = 字符串拼接(md, "**回:** ")
 md = 字符串拼接(md, 条目[4])
 md = 字符串拼接(md, "\n\n")
 }
 如果 (计数(条目[5]) > 0) {
 md = 字符串拼接(md, "**示例:**\n\n```nova\n")
 md = 字符串拼接(md, 条目[5])
 md = 字符串拼接(md, "\n```\n\n")
 }
 }
 如果 (条目[0] == 文档_常量) {
 md = 字符串拼接(md, "- **`")
 md = 字符串拼接(md, 条目[1])
 md = 字符串拼接(md, "`**")
 如果 (计数(条目[2]) > 0) {
 md = 字符串拼接(md, " — ")
 md = 字符串拼接(md, 条目[2])
 }
 md = 字符串拼接(md, "\n")
 }
 i = i + 1
 }
 返回 md
}

// 解析工具
函数 文档_解析函数签名(行) {
 // "法 名称(参数1, 参数2) {"
 定义 n = 计数(行)
 定义 可变 名称开始 = 3
 当 (名称开始 < n 且 字符串等于(子串(行, 名称开始, 1), " ")) { 名称开始 = 名称开始 + 1 }
 定义 可变 括号位 = 名称开始
 当 (括号位 < n 且 字符串等于(子串(行, 括号位, 1), "(") == 假) { 括号位 = 括号位 + 1 }
 如果 (括号位 >= n) { 返回 空 }
 定义 名称 = 子串(行, 名称开始, 括号位 - 名称开始)
 // 解析参数
 定义 可变 参数列表 = []
 定义 可变 i = 括号位 + 1
 定义 可变 当前参数 = ""
 定义 可变 _参完 = 假
 当 (i < n 且 _参完 == 假) { 定义 c = 子串(行, i, 1)
 如果 (c == ")") { _参完 = 真 } 否则 {
 如果 (字符串等于(c, ",")) { 定义 参数 = 文档_去空白(当前参数)
 如果 (计数(参数) > 0) { 追加(参数列表, 参数) }
 当前参数 = ""
 } 否则 {
 当前参数 = 字符串拼接(当前参数, c)
 }
 i = i + 1
 } }
 定义 最后参数 = 文档_去空白(当前参数)
 如果 (计数(最后参数) > 0) { 追加(参数列表, 最后参数) }
 返回 [名称, 参数列表]
}

函数 文档_解析常量名(行) {
 // "令 名称 = 值"
 定义 可变 i = 3
 当 (i < 计数(行) 且 字符串等于(子串(行, i, 1), " ")) { i = i + 1 }
 定义 可变 名称 = ""
 定义 可变 _名完 = 假
 当 (i < 计数(行) 且 _名完 == 假) { 定义 c = 子串(行, i, 1)
 如果 (c == " " 或 c == "=") { _名完 = 真 } 否则 {
 名称 = 字符串拼接(名称, c)
 i = i + 1
 } }
 返回 名称
}

// 字符串工具
函数 文档_分割行(文本) { 定义 n = 计数(文本)
 定义 可变 结果 = []
 定义 可变 当前 = ""
 定义 可变 i = 0
 当 (i < n) { 定义 c = 子串(文本, i, 1)
 如果 (字符串等于(c, "\n")) { 追加(结果, 当前) 当前 = "" }
 否则 如果 (字符串等于(c, "\r") == 假) { 当前 = 字符串拼接(当前, c) }
 i = i + 1
 }
 如果 (计数(当前) > 0) { 追加(结果, 当前) }
 返回 结果
}

函数 文档_拼接描述(注释列表) { 定义 可变 描述 = ""
 定义 可变 j = 1
 当 (j < 计数(注释列表)) { 如果 (文档_包含(注释列表[j], "═══") == 假) { 如果 (计数(描述) > 0) { 描述 = 字符串拼接(描述, " ") }
 描述 = 字符串拼接(描述, 注释列表[j])
 }
 j = j + 1
 }
 返回 描述
}

函数 文档_去空白(s) { 定义 n = 计数(s)
 定义 可变 开始 = 0
 当 (开始 < n 且 (字符串等于(子串(s, 开始, 1), " ") 或 字符串等于(子串(s, 开始, 1), "\t"))) { 开始 = 开始 + 1 }
 定义 可变 结束 = n
 当 (结束 > 开始 且 (字符串等于(子串(s, 结束 - 1, 1), " ") 或 字符串等于(子串(s, 结束 - 1, 1), "\t"))) { 结束 = 结束 - 1 }
 如果 (开始 >= 结束) { 返回 "" }
 返回 子串(s, 开始, 结束 - 开始)
}

函数 文档_开头是(s, 前缀) {
    如果 (计数(s) < 计数(前缀)) { 返回 假
}
 返回 字符串等于(子串(s, 0, 计数(前缀)), 前缀)
}

函数 文档_包含(文本, 子串文本) { 定义 n = 计数(文本)
 定义 m = 计数(子串文本)
 如果 (m > n) { 返回 假 }
 定义 可变 i = 0
 当 (i <= n - m) { 如果 (字符串等于(子串(文本, i, m), 子串文本)) { 返回 真 } i = i + 1 }
 返回 假
}

函数 文档_查找字符(s, 目标) { 定义 可变 i = 0
 当 (i < 计数(s)) { 如果 (字符串等于(子串(s, i, 1), 目标)) { 返回 i } i = i + 1 }
 返回 -1
}

// Markdown生成

函数 文档_生成标题(级别, 文本) { 定义 可变 前缀 = ""
 定义 可变 i = 0
 当 (i < 级别) { 前缀 = 字符串拼接(前缀, "#") i = i + 1 }
 返回 字符串拼接(前缀, 字符串拼接(" ", 文本))
}

函数 文档_生成列表项(缩进, 文本) { 定义 可变 前缀 = ""
 定义 可变 i = 0
 当 (i < 缩进) { 前缀 = 字符串拼接(前缀, " ") i = i + 1 }
 返回 字符串拼接(前缀, 字符串拼接("- ", 文本))
}

函数 文档_生成代码块(语言, 代码) { 返回 字符串拼接("```", 字符串拼接(语言, 字符串拼接("\n", 字符串拼接(代码, "\n```"))))
}

函数 文档_生成表格头(列名列表) { 定义 可变 头 = "|"
 定义 可变 分隔 = "|"
 定义 可变 i = 0
 当 (i < 计数(列名列表)) {
 头 = 字符串拼接(头, 字符串拼接(" ", 字符串拼接(列名列表[i], " |")))
 分隔 = 字符串拼接(分隔, " --- |")
 i = i + 1
 }
 返回 字符串拼接(头, 字符串拼接("\n", 分隔))
}

函数 文档_生成表格行(值列表) { 定义 可变 行 = "|"
 定义 可变 i = 0
 当 (i < 计数(值列表)) {
 行 = 字符串拼接(行, 字符串拼接(" ", 字符串拼接(值列表[i], " |")))
 i = i + 1
 }
 返回 行
}

// 函数签名解析

函数 文档_解析函数签名_简表(行) {
 // 简单解析: "法 函数名(参数)" → [函数名, 参数]
 定义 可变 名称 = ""
 定义 可变 参数 = ""
 定义 可变 阶段 = 0
 定义 可变 i = 0
 当 (i < 计数(行)) { 定义 c = 字符码(行, i)
 如果 (阶段 == 0 且 c == 字符_空格) { 阶段 = 1 }
 否则 如果 (阶段 == 1) { 如果 (c == 字符_左圆括) { 阶段 = 2 }
 否则 { 名称 = 字符串拼接(名称, 字符(c)) }
 }
 否则 如果 (阶段 == 2) { 如果 (c == 字符_右圆括) { 阶段 = 3 }
 否则 { 参数 = 字符串拼接(参数, 字符(c)) }
 }
 i = i + 1
 }
 返回 [名称, 参数]
}

// API文档生成

函数 文档_生成API(函数列表) { 定义 可变 结果 = 文档_生成标题(1, "API参考")
 结果 = 字符串拼接(结果, "\n\n")
 定义 可变 i = 0
 当 (i < 计数(函数列表)) { 定义 签名 = 文档_解析函数签名_简表(函数列表[i])
 结果 = 字符串拼接(结果, 文档_生成标题(2, 签名[0]))
 结果 = 字符串拼接(结果, 字符串拼接("\n\n参数: `", 字符串拼接(签名[1], "`\n\n")))
 i = i + 1
 }
 返回 结果
}

// 目录生成

函数 文档_生成目录(标题列表) { 定义 可变 目录 = "## 目录\n\n"
 定义 可变 i = 0
 当 (i < 计数(标题列表)) {
 目录 = 字符串拼接(目录, 字符串拼接("- ", 字符串拼接(标题列表[i], "\n")))
 i = i + 1
 }
 返回 目录
}

定义 可变 _文档_生成次数 = 0
定义 可变 _文档_总字数 = 0
定义 可变 _文档_函数数 = 0

函数 文档_记录生成(字数) { _文档_生成次数 = _文档_生成次数 + 1
 _文档_总字数 = _文档_总字数 + 字数
}

函数 文档_记录函数() { _文档_函数数 = _文档_函数数 + 1 }

函数 文档_质量评估() {
    如果 (_文档_函数数 > 0 且 _文档_总字数 / _文档_函数数 < 10) { 返回 "文档过简(补充描述)"
}
 如果 (_文档_总字数 > 100000) { 返回 "文档量大" }
 返回 "文档正常"
}

函数 文档_重置() { _文档_生成次数 = 0 _文档_总字数 = 0 _文档_函数数 = 0 }

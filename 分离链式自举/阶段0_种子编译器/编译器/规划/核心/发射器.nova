导入("../../../标准库/基础.nova")
导入("../../../自举兼容桥.nova")

//    字节发射 = 气凝结为机器可执行的字节

// 代码缓冲区

函数 代码_重置() {
    代码 = []
    代码位 = 0
}

函数 代码_发射字节(b) {
    定义 值 = b & 255
    如果 (是列表(代码)) {
        追加(代码, 值)
    } 否则 {
        设(代码, 代码位, 值)
    }
    代码位 = 代码位 + 1
}

// 基本发射
函数 发射(b) { 代码_发射字节(b) }
函数 发射16(v) { 代码_发射字节(v) 代码_发射字节(v >> 8) }
函数 发射32(v) { 代码_发射字节(v) 代码_发射字节(v >> 8) 代码_发射字节(v >> 16) 代码_发射字节(v >> 24) }
函数 发射64(v) { 代码_发射字节(v) 代码_发射字节(v >> 8) 代码_发射字节(v >> 16) 代码_发射字节(v >> 24) 代码_发射字节(v >> 32) 代码_发射字节(v >> 40) 代码_发射字节(v >> 48) 代码_发射字节(v >> 56) }
函数 发射组(列表) {
    定义 可变 i = 0
    当 (i < 计数(列表)) { 发射(列表[i]) i = i + 1 }
}

// 寄存器操作
// push/pop 寄存器 (0=rax,1=rcx,2=rdx,3=rbx,4=rsp,5=rbp,6=rsi,7=rdi,8-15=r8-r15)
函数 发射_推(r) {
    如果 (r >= 8) { 发射(0x41) 发射(0x50 + r - 8) }
    否则 { 发射(0x50 + r) }
}
函数 发射_弹(r) {
    如果 (r >= 8) { 发射(0x41) 发射(0x58 + r - 8) }
    否则 { 发射(0x58 + r) }
}

// 立即数加载
函数 发射_载立即(reg, val) {
    如果 (val == 0 且 reg < 8) {
        发射(0x31) 发射(0xC0 + reg * 9)
        返回 空
    }
    如果 (val >= 0 且 val <= 2147483647) {
        如果 (reg >= 8) {
            发射(0x41) 发射(0xB8 + reg - 8) 发射32(val)
        } 否则 {
            发射(0xB8 + reg) 发射32(val)
        }
    } 否则 如果 (val >= 0 - 2147483648 且 val < 0) {
        如果 (reg >= 8) {
            发射(0x49) 发射(0xC7) 发射(0xC0 + reg - 8) 发射32(val)
        } 否则 {
            发射(0x48) 发射(0xC7) 发射(0xC0 + reg) 发射32(val)
        }
    } 否则 {
        如果 (reg >= 8) {
            发射(0x49) 发射(0xB8 + reg - 8) 发射64(val)
        } 否则 {
            发射(0x48) 发射(0xB8 + reg) 发射64(val)
        }
    }
}

// 跳转修正
函数 修正跳转(位置, 目标) {
    定义 可变 v = 目标 - 位置 - 4
    如果 (v < 0) { v = v + 4294967296 }
    代码[位置] = v & 255
    代码[位置 + 1] = (v / 256) & 255
    代码[位置 + 2] = (v / 65536) & 255
    代码[位置 + 3] = (v / 16777216) & 255
}

// 函数序言/尾声
函数 发射_序言() {
    发射(0x55)                     // push rbp
    发射组([0x48, 0x89, 0xE5])     // mov rbp, rsp
    发射组([0x48, 0x81, 0xEC])     // sub rsp, imm32
    帧大小位 = 代码位
    发射32(0)
}
函数 发射_尾声() {
    发射(0xC9)                     // leave
    发射(0xC3)                     // ret
}

// 空值哨兵 (SENTINEL = -1313754700 = 0xFFFFFFFFB1B1B1B4)
// 真值性检查前: 将 SENTINEL 归零使 test rax,rax 正确判定为假
函数 发射_规范空值() {
    发射组([0x48, 0x3D, 0xB4, 0xB1, 0xB1, 0xB1])
    发射组([0x75, 0x02])
    发射组([0x31, 0xC0])
}
// 运行时调用前: 将 rcx 中的 SENTINEL 转为 0
函数 发射_规范空值_rcx() {
    发射组([0x48, 0x81, 0xF9, 0xB4, 0xB1, 0xB1, 0xB1])
    发射组([0x75, 0x02])
    发射组([0x31, 0xC9])
}
// 运行时调用前: 将 rdx 中的 SENTINEL 转为 0
函数 发射_规范空值_rdx() {
    发射组([0x48, 0x81, 0xFA, 0xB4, 0xB1, 0xB1, 0xB1])
    发射组([0x75, 0x02])
    发射组([0x31, 0xD2])
}
// 运行时调用后: 将返回值 0 转为 SENTINEL (用于可能返回 null 的函数)
函数 发射_空值返回转换() {
    发射组([0x48, 0x85, 0xC0])
    发射组([0x75, 0x07])
    发射组([0x48, 0xC7, 0xC0, 0xB4, 0xB1, 0xB1, 0xB1])
}

// 算术指令
函数 发射_加() { 发射组([0x48, 0x01, 0xC8]) }     // add rax, rcx
函数 发射_减() { 发射组([0x48, 0x29, 0xC8]) }     // sub rax, rcx
函数 发射_乘() { 发射组([0x48, 0x0F, 0xAF, 0xC1]) } // imul rax, rcx
函数 发射_除() { 发射组([0x48, 0x99, 0x48, 0xF7, 0xF9]) } // cqo; idiv rcx

// mov 指令
函数 发射_mov_rcx_rax() { 发射组([0x48, 0x89, 0xC1]) }
函数 发射_mov_rax_rcx() { 发射组([0x48, 0x89, 0xC8]) }

// 比较与条件跳转
函数 发射_比较() { 发射组([0x48, 0x39, 0xC8]) }  // cmp rax, rcx

// 条件跳转 (近跳转, 4字节偏移)
函数 发射_je(_占位) { 发射组([0x0F, 0x84]) 发射32(0) 返回 代码位 - 4 }
函数 发射_jne(_占位) { 发射组([0x0F, 0x85]) 发射32(0) 返回 代码位 - 4 }
函数 发射_jl(_占位) { 发射组([0x0F, 0x8C]) 发射32(0) 返回 代码位 - 4 }
函数 发射_jg(_占位) { 发射组([0x0F, 0x8F]) 发射32(0) 返回 代码位 - 4 }
函数 发射_jle(_占位) { 发射组([0x0F, 0x8E]) 发射32(0) 返回 代码位 - 4 }
函数 发射_jge(_占位) { 发射组([0x0F, 0x8D]) 发射32(0) 返回 代码位 - 4 }

// 无条件跳转
函数 发射_jmp(_占位) { 发射(0xE9) 发射32(0) 返回 代码位 - 4 }

// 短跳转 (1字节偏移, 用于小循环)
函数 发射_jmp短(偏移) { 发射(0xEB) 发射(偏移) }

// 函数调用
函数 发射_call(偏移) { 发射(0xE8) 发射32(偏移) }
函数 发射_ret() { 发射(0xC3) }
函数 发射_nop() { 发射(0x90) }

// 栈操作
函数 发射_分配栈(大小) {
    // sub rsp, imm32
    如果 (大小 <= 127) {
        发射组([0x48, 0x83, 0xEC])
        发射(大小)
    } 否则 {
        发射组([0x48, 0x81, 0xEC])
        发射32(大小)
    }
}

函数 发射_释放栈(大小) {
    // add rsp, imm32
    如果 (大小 <= 127) {
        发射组([0x48, 0x83, 0xC4])
        发射(大小)
    } 否则 {
        发射组([0x48, 0x81, 0xC4])
        发射32(大小)
    }
}

// 内存访问
// mov rax, [rbp+偏移]
函数 发射_读局部(偏移) {
    如果 (偏移 >= -128 且 偏移 <= 127) {
        发射组([0x48, 0x8B, 0x45])
        发射(偏移 & 0xFF)
    } 否则 {
        发射组([0x48, 0x8B, 0x85])
        发射32(偏移)
    }
}

// mov [rbp+偏移], rax
函数 发射_写局部(偏移) {
    如果 (偏移 >= -128 且 偏移 <= 127) {
        发射组([0x48, 0x89, 0x45])
        发射(偏移 & 0xFF)
    } 否则 {
        发射组([0x48, 0x89, 0x85])
        发射32(偏移)
    }
}

// 位运算指令
函数 发射_与() { 发射组([0x48, 0x21, 0xC8]) }      // and rax, rcx
函数 发射_或() { 发射组([0x48, 0x09, 0xC8]) }      // or rax, rcx
函数 发射_异或() { 发射组([0x48, 0x31, 0xC8]) }    // xor rax, rcx
函数 发射_左移() { 发射组([0x48, 0xD3, 0xE0]) }    // shl rax, cl
函数 发射_右移() { 发射组([0x48, 0xD3, 0xF8]) }    // sar rax, cl
函数 发射_非() { 发射组([0x48, 0xF7, 0xD0]) }      // not rax
函数 发射_负() { 发射组([0x48, 0xF7, 0xD8]) }      // neg rax

// 寄存器间mov
函数 发射_mov_reg_reg(目标, 源) {
    定义 可变 前缀 = 0x48
    如果 (源 >= 8 且 目标 >= 8) { 前缀 = 0x4D }
    否则 如果 (源 >= 8) { 前缀 = 0x4C }
    否则 如果 (目标 >= 8) { 前缀 = 0x49 }
    定义 源 = 源 % 8
    定义 目标 = 目标 % 8
    发射(前缀)
    发射(0x89)
    发射(0xC0 + 源 * 8 + 目标)
}

// lea指令
// lea rax, [rbp+偏移]
函数 发射_lea_rbp(偏移) {
    如果 (偏移 >= -128 且 偏移 <= 127) {
        发射组([0x48, 0x8D, 0x45])
        发射(偏移 & 0xFF)
    } 否则 {
        发射组([0x48, 0x8D, 0x85])
        发射32(偏移)
    }
}

// System V ABI调用约定辅助
// 参数寄存器: rdi, rsi, rdx, rcx, r8, r9
函数 发射_设参数1(值) { 发射_载立即(7, 值) }   // rdi
函数 发射_设参数2(值) { 发射_载立即(6, 值) }   // rsi
函数 发射_设参数3(值) { 发射_载立即(2, 值) }   // rdx

// 代码位置管理
函数 当前代码位() { 返回 代码位 }
函数 设置代码位(位置) { 代码位 = 位置 }

// NOP填充 (对齐)
函数 发射_对齐(对齐) {
    当 (代码位 % 对齐 != 0) {
        发射_nop()
    }
}

// 补全: 内存寻址模式 (列表/字典/全局变量/字符串核心)

// mov rax, [rcx] — 指针解引用
函数 发射_读指针() { 发射组([0x48, 0x8B, 0x01]) }
// mov [rcx], rax — 指针写入
函数 发射_写指针() { 发射组([0x48, 0x89, 0x01]) }
// mov rax, [rcx+rdx*8] — 数组索引读取(列表核心)
函数 发射_读数组() { 发射组([0x48, 0x8B, 0x04, 0xD1]) }
// mov [rcx+rdx*8], rax — 数组索引写入
函数 发射_写数组() { 发射组([0x48, 0x89, 0x04, 0xD1]) }
// mov rax, [rip+disp32] — 全局变量/字符串读取
函数 发射_读全局(偏移) { 发射组([0x48, 0x8B, 0x05]) 发射32(偏移) }
// mov [rip+disp32], rax — 全局变量写入
函数 发射_写全局(偏移) { 发射组([0x48, 0x89, 0x05]) 发射32(偏移) }
// lea rax, [rip+disp32] — 取地址(字符串指针)
函数 发射_取地址(偏移) { 发射组([0x48, 0x8D, 0x05]) 发射32(偏移) }
// movzx rax, byte [rcx+rax] — 字节读取(字符串逐字节)
函数 发射_读字节() { 发射组([0x48, 0x0F, 0xB6, 0x04, 0x01]) }
// mov byte [rcx+rax], dl — 字节写入
函数 发射_写字节() { 发射组([0x88, 0x14, 0x01]) }
// mov rax, [rcx+偏移] — 结构体字段读取
函数 发射_读偏移(偏移) {
    如果 (偏移 >= -128 且 偏移 <= 127) {
        发射组([0x48, 0x8B, 0x41]) 发射(偏移 & 0xFF)
    } 否则 {
        发射组([0x48, 0x8B, 0x81]) 发射32(偏移)
    }
}
// mov [rcx+偏移], rax — 结构体字段写入
函数 发射_写偏移(偏移) {
    如果 (偏移 >= -128 且 偏移 <= 127) {
        发射组([0x48, 0x89, 0x41]) 发射(偏移 & 0xFF)
    } 否则 {
        发射组([0x48, 0x89, 0x81]) 发射32(偏移)
    }
}

// 补全: 条件设置 (比较结果→0/1值)

函数 发射_设等于() { 发射组([0x0F, 0x94, 0xC0, 0x48, 0x0F, 0xB6, 0xC0]) }   // sete al; movzx rax,al
函数 发射_设不等() { 发射组([0x0F, 0x95, 0xC0, 0x48, 0x0F, 0xB6, 0xC0]) }   // setne
函数 发射_设小于() { 发射组([0x0F, 0x9C, 0xC0, 0x48, 0x0F, 0xB6, 0xC0]) }   // setl
函数 发射_设大于() { 发射组([0x0F, 0x9F, 0xC0, 0x48, 0x0F, 0xB6, 0xC0]) }   // setg
函数 发射_设小等() { 发射组([0x0F, 0x9E, 0xC0, 0x48, 0x0F, 0xB6, 0xC0]) }   // setle
函数 发射_设大等() { 发射组([0x0F, 0x9D, 0xC0, 0x48, 0x0F, 0xB6, 0xC0]) }   // setge
// 测试rax是否为零→设置标志
函数 发射_测试零() { 发射组([0x48, 0x85, 0xC0]) }

// 补全: 字符串/内存批量操作

// rep movsb: 内存复制 rdi←rsi, rcx字节
函数 发射_内存复制() { 发射组([0xF3, 0xA4]) }
// rep stosb: 内存填充 rdi←al, rcx字节
函数 发射_内存填充() { 发射组([0xF3, 0xAA]) }
// rep cmpsb: 内存比较 rsi vs rdi, rcx字节
函数 发射_内存比较() { 发射组([0xF3, 0xA6]) }
// cld: 清除方向标志(确保正向复制)
函数 发射_清方向() { 发射(0xFC) }

// 补全: Windows API间接调用 (IAT)

// 调用 [rip+disp32] — 通过IAT调用Windows API
函数 发射_间接调用(偏移) { 发射组([0xFF, 0x15]) 发射32(偏移) }
// 跳转 [rip+disp32] — 通过IAT尾跳转
函数 发射_间接跳转(偏移) { 发射组([0xFF, 0x25]) 发射32(偏移) }
// 调用 rax — 通过寄存器间接调用(函数指针)
函数 发射_调用寄存器() { 发射组([0xFF, 0xD0]) }

// 补全: 乘除扩展 + 条件移动

// mul rcx: 无符号乘法 rdx:rax = rax * rcx
函数 发射_无符号乘() { 发射组([0x48, 0xF7, 0xE1]) }
// div rcx: 无符号除法 rax=商, rdx=余数
函数 发射_无符号除() { 发射组([0x48, 0xF7, 0xF1]) }
// cqo: 符号扩展rax→rdx:rax (有符号除法前)
函数 发射_符号扩展() { 发射组([0x48, 0x99]) }
// cmove rax, rcx: 条件移动(等于时)
函数 发射_条件移等() { 发射组([0x48, 0x0F, 0x44, 0xC1]) }
// cmovne rax, rcx: 条件移动(不等时)
函数 发射_条件移不等() { 发射组([0x48, 0x0F, 0x45, 0xC1]) }

// 补全: 系统/调试指令

// 数字 3: 调试断点
函数 发射_断点() { 发射(0xCC) }
// ud2: 未定义指令(崩溃陷阱)
函数 发射_陷阱() { 发射组([0x0F, 0x0B]) }
// cpuid: CPU能力检测(eax=功能号)
函数 发射_检测CPU() { 发射组([0x0F, 0xA2]) }
// rdtsc: 读时间戳计数器→edx:eax
函数 发射_读时间戳() { 发射组([0x0F, 0x31]) }
// syscall: Linux系统调用(裸机)
函数 发射_系统调用() { 发射组([0x0F, 0x05]) }

// 补全: 原子操作 (并发/锁)

// lock cmpxchg [rcx], rdx: 原子比较交换
函数 发射_原子比较交换() { 发射组([0xF0, 0x48, 0x0F, 0xB1, 0x11]) }
// lock xadd [rcx], rax: 原子加
函数 发射_原子加() { 发射组([0xF0, 0x48, 0x0F, 0xC1, 0x01]) }
// mfence: 内存屏障
函数 发射_内存屏障() { 发射组([0x0F, 0xAE, 0xF0]) }
// pause: 自旋等待提示
函数 发射_自旋等待() { 发射组([0xF3, 0x90]) }

// 补全: SSE2浮点 (AI基础运算)

// movsd xmm0, [rcx] — 加载double
函数 发射_浮点读(xmm, 源reg) {
    发射(0xF2) 发射(0x0F) 发射(0x10) 发射(0x00 + xmm * 8 + 源reg)
}
// movsd [rcx], xmm0 — 存储double
函数 发射_浮点写(xmm, 目标reg) {
    发射(0xF2) 发射(0x0F) 发射(0x11) 发射(0x00 + xmm * 8 + 目标reg)
}
// addsd xmm0, xmm1
函数 发射_浮点加(目标, 源) { 发射(0xF2) 发射(0x0F) 发射(0x58) 发射(0xC0 + 目标 * 8 + 源) }
// subsd xmm0, xmm1
函数 发射_浮点减(目标, 源) { 发射(0xF2) 发射(0x0F) 发射(0x5C) 发射(0xC0 + 目标 * 8 + 源) }
// mulsd xmm0, xmm1
函数 发射_浮点乘(目标, 源) { 发射(0xF2) 发射(0x0F) 发射(0x59) 发射(0xC0 + 目标 * 8 + 源) }
// divsd xmm0, xmm1
函数 发射_浮点除(目标, 源) { 发射(0xF2) 发射(0x0F) 发射(0x5E) 发射(0xC0 + 目标 * 8 + 源) }
// sqrtsd xmm0, xmm1
函数 发射_浮点根(目标, 源) { 发射(0xF2) 发射(0x0F) 发射(0x51) 发射(0xC0 + 目标 * 8 + 源) }
// ucomisd xmm0, xmm1 — 浮点比较
函数 发射_浮点比较(a, b) { 发射(0x66) 发射(0x0F) 发射(0x2E) 发射(0xC0 + a * 8 + b) }
// cvtsi2sd xmm0, rax — 整数→浮点
函数 发射_整数转浮点(xmm, reg) {
    发射(0xF2) 发射(0x48) 发射(0x0F) 发射(0x2A) 发射(0xC0 + xmm * 8 + reg)
}
// cvttsd2si rax, xmm0 — 浮点→整数
函数 发射_浮点转整数(reg, xmm) {
    发射(0xF2) 发射(0x48) 发射(0x0F) 发射(0x2C) 发射(0xC0 + reg * 8 + xmm)
}

// 补全: AVX2向量 (AI矩阵加速核心)

// VEX前缀编码辅助
函数 发射_vex2(pp, l, 源, 目标) {
    定义 r = 1  定义 vvvv = (15 - 源) & 0x0F
    定义 byte2 = (r * 128) + (vvvv * 8) + (l * 4) + pp
    发射(0xC5) 发射(byte2)
}
函数 发射_vex3(pp, l, m, 源, 目标) {
    定义 r = 1  定义 x = 1  定义 b = 1
    定义 byte2 = (r * 128) + (x * 64) + (b * 32) + m
    定义 w = 0  定义 vvvv = (15 - 源) & 0x0F
    定义 byte3 = (w * 128) + (vvvv * 8) + (l * 4) + pp
    发射(0xC4) 发射(byte2) 发射(byte3)
}

// vaddps ymm0, ymm1, ymm2 — 8路并行浮点加法
函数 发射_向量加(目标, 源1, 源2) {
    发射_vex2(0, 1, 源1, 目标)
    发射(0x58) 发射(0xC0 + 目标 * 8 + 源2)
}
// vmulps ymm0, ymm1, ymm2 — 8路并行浮点乘法
函数 发射_向量乘(目标, 源1, 源2) {
    发射_vex2(0, 1, 源1, 目标)
    发射(0x59) 发射(0xC0 + 目标 * 8 + 源2)
}
// vsubps ymm0, ymm1, ymm2
函数 发射_向量减(目标, 源1, 源2) {
    发射_vex2(0, 1, 源1, 目标)
    发射(0x5C) 发射(0xC0 + 目标 * 8 + 源2)
}
// vdivps ymm0, ymm1, ymm2
函数 发射_向量除(目标, 源1, 源2) {
    发射_vex2(0, 1, 源1, 目标)
    发射(0x5E) 发射(0xC0 + 目标 * 8 + 源2)
}
// vfmadd213ps ymm0, ymm1, ymm2 — 融合乘加(AI核心: a = a*b + c)
函数 发射_向量融合乘加(a, b, c) {
    发射_vex3(1, 1, 2, b, a)
    发射(0xA8) 发射(0xC0 + a * 8 + c)
}
// vmovaps ymm0, [rcx] — 加载256位向量(8个float)
函数 发射_向量读(ymm) {
    发射_vex2(0, 1, 0, ymm)
    发射(0x28) 发射(0x01 + ymm * 8)
}
// vmovaps [rcx], ymm0 — 存储256位向量
函数 发射_向量写(ymm) {
    发射_vex2(0, 1, 0, ymm)
    发射(0x29) 发射(0x01 + ymm * 8)
}
// vxorps ymm0, ymm0, ymm0 — 向量清零
函数 发射_向量清零(ymm) {
    发射_vex2(0, 1, ymm, ymm)
    发射(0x57) 发射(0xC0 + ymm * 9)
}
// vsqrtps ymm0, ymm1 — 向量平方根
函数 发射_向量根(目标, 源) {
    发射_vex2(0, 1, 0, 目标)
    发射(0x51) 发射(0xC0 + 目标 * 8 + 源)
}
// vmaxps ymm0, ymm1, ymm2 — 向量最大值
函数 发射_向量最大(目标, 源1, 源2) {
    发射_vex2(0, 1, 源1, 目标)
    发射(0x5F) 发射(0xC0 + 目标 * 8 + 源2)
}
// vminps ymm0, ymm1, ymm2 — 向量最小值
函数 发射_向量最小(目标, 源1, 源2) {
    发射_vex2(0, 1, 源1, 目标)
    发射(0x5D) 发射(0xC0 + 目标 * 8 + 源2)
}
// vzeroupper — 清零高128位(AVX↔SSE切换必需)
函数 发射_清高位() { 发射_vex2(0, 0 , 0, 0) 发射(0x77) }

// 补全: 整数算术扩展

// add rcx, rax
函数 发射_加到参数1() { 发射组([0x48, 0x01, 0xC1]) }
// sub rcx, rax
函数 发射_减从参数1() { 发射组([0x48, 0x29, 0xC1]) }
// add rax, imm32
函数 发射_加立即(n) {
    如果 (n >= -128 且 n <= 127) { 发射组([0x48, 0x83, 0xC0]) 发射(n & 0xFF) }
    否则 { 发射组([0x48, 0x05]) 发射32(n) }
}
// sub rax, imm32
函数 发射_减立即(n) {
    如果 (n >= -128 且 n <= 127) { 发射组([0x48, 0x83, 0xE8]) 发射(n & 0xFF) }
    否则 { 发射组([0x48, 0x2D]) 发射32(n) }
}
// imul rax, rcx, imm32 — 三操作数乘法
函数 发射_乘立即(n) {
    如果 (n >= -128 且 n <= 127) { 发射组([0x48, 0x6B, 0xC1]) 发射(n & 0xFF) }
    否则 { 发射组([0x48, 0x69, 0xC1]) 发射32(n) }
}
// inc rcx
函数 发射_递增参数1() { 发射组([0x48, 0xFF, 0xC1]) }
// dec rax
函数 发射_递减() { 发射组([0x48, 0xFF, 0xC8]) }
// dec rcx
函数 发射_递减参数1() { 发射组([0x48, 0xFF, 0xC9]) }
// xor rax, rax — 快速清零
函数 发射_清零() { 发射组([0x48, 0x31, 0xC0]) }
// xor rcx, rcx
函数 发射_清零参数1() { 发射组([0x48, 0x31, 0xC9]) }

// 补全: 更多条件跳转 + 无符号比较跳转

// ja (无符号大于)
函数 发射_ja(_占位) { 发射组([0x0F, 0x87]) 发射32(0) 返回 代码位 - 4 }
// jae (无符号大等)
函数 发射_jae(_占位) { 发射组([0x0F, 0x83]) 发射32(0) 返回 代码位 - 4 }
// jb (无符号小于)
函数 发射_jb(_占位) { 发射组([0x0F, 0x82]) 发射32(0) 返回 代码位 - 4 }
// jbe (无符号小等)
函数 发射_jbe(_占位) { 发射组([0x0F, 0x86]) 发射32(0) 返回 代码位 - 4 }
// js (负号)
函数 发射_js(_占位) { 发射组([0x0F, 0x88]) 发射32(0) 返回 代码位 - 4 }
// jns (非负)
函数 发射_jns(_占位) { 发射组([0x0F, 0x89]) 发射32(0) 返回 代码位 - 4 }
// jo (溢出)
函数 发射_jo(_占位) { 发射组([0x0F, 0x80]) 发射32(0) 返回 代码位 - 4 }
// jno (无溢出)
函数 发射_jno(_占位) { 发射组([0x0F, 0x81]) 发射32(0) 返回 代码位 - 4 }
// jcxz — rcx为零跳转(短跳转)
函数 发射_jrcxz(偏移) { 发射(0xE3) 发射(偏移) }

// 无符号条件设置
函数 发射_设无符大于() { 发射组([0x0F, 0x97, 0xC0, 0x48, 0x0F, 0xB6, 0xC0]) }
函数 发射_设无符小于() { 发射组([0x0F, 0x92, 0xC0, 0x48, 0x0F, 0xB6, 0xC0]) }
函数 发射_设无符大等() { 发射组([0x0F, 0x93, 0xC0, 0x48, 0x0F, 0xB6, 0xC0]) }
函数 发射_设无符小等() { 发射组([0x0F, 0x96, 0xC0, 0x48, 0x0F, 0xB6, 0xC0]) }

// 补全: 更多条件移动

函数 发射_条件移小于() { 发射组([0x48, 0x0F, 0x4C, 0xC1]) }   // cmovl
函数 发射_条件移大于() { 发射组([0x48, 0x0F, 0x4F, 0xC1]) }   // cmovg
函数 发射_条件移小等() { 发射组([0x48, 0x0F, 0x4E, 0xC1]) }   // cmovle
函数 发射_条件移大等() { 发射组([0x48, 0x0F, 0x4D, 0xC1]) }   // cmovge
函数 发射_条件移零() { 发射组([0x48, 0x0F, 0x44, 0xC1]) }     // cmovz
函数 发射_条件移非零() { 发射组([0x48, 0x0F, 0x45, 0xC1]) }   // cmovnz


// Nova标准库 — 文本处理模块
// 字符串操作、分词、模式匹配

导入("../基础.nova")
导入("../../编译器/词法/字符工具.nova")

// 字符分类

函数 是标识符(编码值) {
    返回 是字母(编码值) 或 是数字(编码值) 或 编码值 == 95
}

// 大小写转换

函数 转大写字符(c) {
    定义 v = 编码(c)
    如果 (是小写(v)) { 返回 字符(v - 32) }
    返回 c
}

函数 转小写字符(c) {
    定义 v = 编码(c)
    如果 (是大写(v)) { 返回 字符(v + 32) }
    返回 c
}

// 字符串工具

// 去除首尾空格
函数 文本处理_去空格(文本) {
    定义 n = 计数(文本)
    如果 (n == 0) { 返回 文本 }
    // 找起始位置
    定义 可变 起 = 0
    定义 可变 _起找到 = 假
    当 (起 < n 且 _起找到 == 假) {
        定义 c = 编码(子串(文本, 起, 1))
        如果 (是空白(c) == 假) { _起找到 = 真 } 否则 { 起 = 起 + 1 }
    }
    // 找结束位置
    定义 可变 终 = n - 1
    定义 可变 _终找到 = 假
    当 (终 >= 起 且 _终找到 == 假) {
        定义 c = 编码(子串(文本, 终, 1))
        如果 (是空白(c) == 假) { _终找到 = 真 } 否则 { 终 = 终 - 1 }
    }
    如果 (起 > 终) { 返回 "" }
    返回 子串(文本, 起, 终 - 起 + 1)
}

// 分割字符串 (按单字符分隔, 0)
函数 文本处理_分割(文本, 分隔符) {
    定义 n = 计数(文本)
    定义 可变 结果 = []
    定义 可变 当前 = ""
    定义 可变 i = 0
    当 (i < n) {
        定义 c = 子串(文本, i, 1)
        如果 (字符串等于(c, 分隔符)) {
            追加(结果, 当前)
            当前 = ""
        } 否则 {
            当前 = 字符串拼接(当前, c)
        }
        i = i + 1
    }
    追加(结果, 当前)
    返回 结果
}

// 合并字符串列表
函数 合并(列表, 分隔符) {
    定义 n = 计数(列表)
    如果 (n == 0) { 返回 "" }
    定义 可变 结果 = 列表[0]
    定义 可变 i = 1
    当 (i < n) {
        结果 = 字符串拼接(结果, 分隔符)
        结果 = 字符串拼接(结果, 列表[i])
        i = i + 1
    }
    返回 结果
}

// 重复字符串
函数 重复文本(文本, 次数) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 次数) {
        结果 = 字符串拼接(结果, 文本)
        i = i + 1
    }
    返回 结果
}

// 包含子串
函数 包含(文本, 子串文本) {
    返回 查找(文本, 子串文本) >= 0
}

// 查找子串位置
函数 查找(文本, 目标) {
    定义 n = 计数(文本)
    定义 m = 计数(目标)
    如果 (m > n) { 返回 -1 }
    定义 可变 i = 0
    当 (i <= n - m) {
        定义 候选 = 子串(文本, i, m)
        如果 (字符串等于(候选, 目标)) { 返回 i }
        i = i + 1
    }
    返回 -1
}

// 计算子串出现次数
函数 出现次数(文本, 目标) {
    定义 n = 计数(文本)
    定义 m = 计数(目标)
    如果 (m > n 或 m == 0) { 返回 0 }
    定义 可变 次数 = 0
    定义 可变 i = 0
    当 (i <= n - m) {
        如果 (字符串等于(子串(文本, i, m), 目标)) {
            次数 = 次数 + 1
            i = i + m
        } 否则 {
            i = i + 1
        }
    }
    返回 次数
}

// 以...开头
函数 开头是(文本, 前缀) {
    定义 m = 计数(前缀)
    如果 (计数(文本) < m) { 返回 假 }
    返回 字符串等于(子串(文本, 0, m), 前缀)
}

// 以...结尾
函数 结尾是(文本, 后缀) {
    定义 n = 计数(文本)
    定义 m = 计数(后缀)
    如果 (n < m) { 返回 假 }
    返回 字符串等于(子串(文本, n - m, m), 后缀)
}

// 左填充
函数 文本处理_左填充(文本, 总长, 填充字符) {
    定义 n = 计数(文本)
    如果 (n >= 总长) { 返回 文本 }
    返回 字符串拼接(重复文本(填充字符, 总长 - n), 文本)
}

// 右填充
函数 文本处理_右填充(文本, 总长, 填充字符) {
    定义 n = 计数(文本)
    如果 (n >= 总长) { 返回 文本 }
    返回 字符串拼接(文本, 重复文本(填充字符, 总长 - n))
}

// 反转字符串
函数 反转字符串(文本) {
    定义 n = 计数(文本)
    定义 可变 结果 = ""
    定义 可变 i = n - 1
    当 (i >= 0) {
        结果 = 字符串拼接(结果, 子串(文本, i, 1))
        i = i - 1
    }
    返回 结果
}

// 整数转十六进制字符串
函数 文本处理_转十六进制(值) {
    如果 (值 == 0) { 返回 "0" }
    定义 十六进制字符 = "0123456789ABCDEF"
    定义 可变 结果 = ""
    定义 可变 v = 值
    如果 (v < 0) { v = 0 - v }
    当 (v > 0) {
        定义 余 = v % 16
        结果 = 字符串拼接(子串(十六进制字符, 余, 1), 结果)
        v = v / 16
    }
    如果 (值 < 0) { 结果 = 字符串拼接("-", 结果) }
    返回 结果
}

// 整数转二进制字符串
函数 转二进制(值) {
    如果 (值 == 0) { 返回 "0" }
    定义 可变 结果 = ""
    定义 可变 v = 值
    如果 (v < 0) { v = 0 - v }
    当 (v > 0) {
        如果 (v % 2 == 0) {
            结果 = 字符串拼接("0", 结果)
        } 否则 {
            结果 = 字符串拼接("1", 结果)
        }
        v = v / 2
    }
    如果 (值 < 0) { 结果 = 字符串拼接("-", 结果) }
    返回 结果
}

// 简单词频统计
// 简单模板引擎
// 替换 {变量名} → 值
函数 模板渲染(模板, _变量字典) {
    定义 可变 结果 = 模板
    定义 键列表 = 字典键(_变量字典)
    定义 可变 ki = 0
    当 (ki < 计数(键列表)) {
        定义 键 = 键列表[ki]
        定义 占位符 = 字符串拼接("{", 字符串拼接(键, "}"))
        定义 值文本 = 转字符串(字典取(_变量字典, 键))
        结果 = _模板_替换全部(结果, 占位符, 值文本)
        ki = ki + 1
    }
    返回 结果
}

函数 _模板_替换全部(源, 目标, 替换值) {
    定义 目标长 = 计数(目标)
    如果 (目标长 == 0) { 返回 源 }
    定义 可变 结果 = ""
    定义 可变 位置 = 0
    定义 源长 = 计数(源)
    当 (位置 <= 源长 - 目标长) {
        如果 (子串(源, 位置, 目标长) == 目标) {
            结果 = 字符串拼接(结果, 替换值)
            位置 = 位置 + 目标长
        } 否则 {
            结果 = 字符串拼接(结果, 子串(源, 位置, 1))
            位置 = 位置 + 1
        }
    }
    当 (位置 < 源长) {
        结果 = 字符串拼接(结果, 子串(源, 位置, 1))
        位置 = 位置 + 1
    }
    返回 结果
}

// 编辑距离 (Levenshtein, 0)
函数 编辑距离(a, b) {
    定义 m = 计数(a)
    定义 n = 计数(b)
    // 使用一维数组模拟二维DP
    // dp[j] = 编辑距离(a[0..i], b[0..j])
    定义 可变 dp = []
    定义 可变 j = 0
    当 (j <= n) { 追加(dp, j) j = j + 1 }
    定义 可变 i = 1
    当 (i <= m) {
        定义 可变 前一个 = dp[0]
        dp[0] = i
        j = 1
        当 (j <= n) {
            定义 暂存 = dp[j]
            如果 (字符串等于(子串(a, i - 1, 1), 子串(b, j - 1, 1))) {
                dp[j] = 前一个
            } 否则 {
                定义 可变 最小 = 前一个
                如果 (dp[j] < 最小) { 最小 = dp[j] }
                如果 (dp[j - 1] < 最小) { 最小 = dp[j - 1] }
                dp[j] = 最小 + 1
            }
            前一个 = 暂存
            j = j + 1
        }
        i = i + 1
    }
    返回 dp[n]
}

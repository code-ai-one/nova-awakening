// Tasklet机制(基于软中断的延迟工作)

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./自动扩容.nova")
导入("./公平调度度.nova")
导入("./字符串替换.nova")
导入("./软中断初始化.nova")
导入("./时钟中枢.nova")

结构 Tasklet {
    下一个,    // 指针<Tasklet>
    状态,
    计数,
    处理函数,    // 函数指针
    数据,
}

// Tasklet状态
定义 TASKLET_状态_已调度  = 1
定义 TASKLET_状态_运行中  = 2

// Tasklet队列(per-CPU)
结构 Tasklet队列 {
    头,    // 指针<Tasklet>
    尾,    // 指针<指针<Tasklet>>
    锁,    // 自旋锁
}

定义 可变 tasklet_普通队列 = Tasklet队列 {}
定义 可变 tasklet_高优先级队列 = Tasklet队列 {}

函数 tasklet_初始化(t, 处理函数, 数据) {
    t.下一个 = 空
    t.状态 = 0
    t.计数 = 0
    t.处理函数 = 处理函数
    t.数据 = 数据
}

函数 tasklet_调度(t) {
    // 原子设置已调度标志，避免重复调度
    如果 (t.状态 & TASKLET_状态_已调度) { 返回 }
    t.状态 = t.状态 | TASKLET_状态_已调度

    定义 旧中断 = 保存并关中断()
    t.下一个 = 空
    如果 (tasklet_普通队列.头 == 空) {
        tasklet_普通队列.头 = t
    } 否则 {
        // 追加到尾部
        定义 可变 当前 = tasklet_普通队列.头
        当 (当前.下一个 != 空) { 当前 = 当前.下一个 }
        当前.下一个 = t
    }
    恢复中断(旧中断)

    软中断_触发(软中断_TASKLET)
}

函数 tasklet_高优先级_调度(t) {
    如果 (t.状态 & TASKLET_状态_已调度) { 返回 }
    t.状态 = t.状态 | TASKLET_状态_已调度

    定义 旧中断 = 保存并关中断()
    t.下一个 = tasklet_高优先级队列.头
    tasklet_高优先级队列.头 = t
    恢复中断(旧中断)

    软中断_触发(软中断_高优先级)
}

函数 tasklet_禁用(t) {
    t.计数 = t.计数 + 1
}

函数 tasklet_使能(t) {
    如果 (t.计数 > 0) {
        t.计数 = t.计数 - 1
    }
}

函数 tasklet_杀死(t) {
    // 等待tasklet完成并移除
    当 (t.状态 & TASKLET_状态_运行中) {
        调度_让出()
    }
    t.状态 = 0
}

// Tasklet软中断处理函数

函数 tasklet_软中断处理() {
    定义 旧中断 = 保存并关中断()
    定义 可变 列表 = tasklet_普通队列.头
    tasklet_普通队列.头 = 空
    恢复中断(旧中断)

    当 (列表 != 空) {
        定义 t = 列表
        列表 = 列表.下一个

        如果 (t.计数 == 0) {
            t.状态 = t.状态 | TASKLET_状态_运行中
            t.状态 = t.状态 & ~TASKLET_状态_已调度
            如果 (t.处理函数 != 空) {
                t.处理函数(t.数据)
            }
            t.状态 = t.状态 & ~TASKLET_状态_运行中
        } 否则 {
            // 被禁用，重新排队
            tasklet_调度(t)
        }
    }
}

函数 tasklet_高优先级_处理() {
    定义 旧中断 = 保存并关中断()
    定义 可变 列表 = tasklet_高优先级队列.头
    tasklet_高优先级队列.头 = 空
    恢复中断(旧中断)

    当 (列表 != 空) {
        定义 t = 列表
        列表 = 列表.下一个

        如果 (t.计数 == 0) {
            t.状态 = t.状态 | TASKLET_状态_运行中
            t.状态 = t.状态 & ~TASKLET_状态_已调度
            如果 (t.处理函数 != 空) {
                t.处理函数(t.数据)
            }
            t.状态 = t.状态 & ~TASKLET_状态_运行中
        } 否则 {
            tasklet_高优先级_调度(t)
        }
    }
}

// Tasklet系统初始化

定义 可变 tasklet_已初始化 = 假
定义 可变 tasklet_已注册到软中断 = 假

// 统计
定义 可变 tasklet_调度总数 = 0
定义 可变 tasklet_执行总数 = 0
定义 可变 tasklet_高优先级执行总数 = 0
定义 可变 tasklet_创建总数 = 0
定义 可变 tasklet_销毁总数 = 0
定义 可变 tasklet_禁用总数 = 0
定义 可变 tasklet_使能总数 = 0
定义 可变 tasklet_杀死总数 = 0
定义 可变 tasklet_重排队总数 = 0
定义 可变 tasklet_超时总数 = 0
定义 可变 tasklet_错误数 = 0
定义 可变 tasklet_延迟总计 = 0
定义 可变 tasklet_延迟样本 = 0
定义 可变 tasklet_最大延迟 = 0

定义 tasklet_超时阈值 = 1000000

函数 tasklet_系统初始化() {
    如果 (tasklet_已初始化 == 真) { 返回 错误_已存在 }
    tasklet_普通队列.头 = 空
    tasklet_普通队列.尾 = 空
    tasklet_高优先级队列.头 = 空
    tasklet_高优先级队列.尾 = 空
    // 注册到软中断
    如果 (tasklet_已注册到软中断 == 假) {
        软中断_注册(软中断_TASKLET, tasklet_软中断处理)
        软中断_注册(软中断_高优先级, tasklet_高优先级_处理)
        tasklet_已注册到软中断 = 真
    }
    tasklet_调度总数 = 0
    tasklet_执行总数 = 0
    tasklet_高优先级执行总数 = 0
    tasklet_创建总数 = 0
    tasklet_销毁总数 = 0
    tasklet_禁用总数 = 0
    tasklet_使能总数 = 0
    tasklet_杀死总数 = 0
    tasklet_重排队总数 = 0
    tasklet_超时总数 = 0
    tasklet_错误数 = 0
    tasklet_延迟总计 = 0
    tasklet_延迟样本 = 0
    tasklet_最大延迟 = 0
    tasklet_已初始化 = 真
    打印("[Tasklet] 系统初始化完成")
    返回 0
}

// Tasklet创建/销毁完整流程

函数 tasklet_创建(处理函数, 数据) {
    如果 (处理函数 == 空) {
        tasklet_错误数 = tasklet_错误数 + 1
        返回 空
    }
    定义 t = Tasklet {}
    t.下一个 = 空
    t.状态 = 0
    t.计数 = 0
    t.处理函数 = 处理函数
    t.数据 = 数据
    tasklet_创建总数 = tasklet_创建总数 + 1
    返回 t
}

函数 tasklet_创建_禁用(处理函数, 数据) {
    定义 t = tasklet_创建(处理函数, 数据)
    如果 (t != 空) {
        t.计数 = 1
    }
    返回 t
}

函数 tasklet_销毁(t) {
    如果 (t == 空) { 返回 }
    tasklet_杀死(t)
    tasklet_销毁总数 = tasklet_销毁总数 + 1
}

// 增强版调度(带统计和超时)

函数 tasklet_调度_增强(t) {
    如果 (t == 空) {
        tasklet_错误数 = tasklet_错误数 + 1
        返回 错误_无效参数
    }
    tasklet_调度总数 = tasklet_调度总数 + 1
    tasklet_调度(t)
    返回 0
}

函数 tasklet_高优先级_调度_增强(t) {
    如果 (t == 空) {
        tasklet_错误数 = tasklet_错误数 + 1
        返回 错误_无效参数
    }
    tasklet_调度总数 = tasklet_调度总数 + 1
    tasklet_高优先级_调度(t)
    返回 0
}

// 增强版处理(带统计和超时检测)

函数 tasklet_软中断处理_增强() {
    定义 旧中断 = 保存并关中断()
    定义 可变 列表 = tasklet_普通队列.头
    tasklet_普通队列.头 = 空
    恢复中断(旧中断)

    定义 可变 处理数 = 0
    当 (列表 != 空) {
        定义 t = 列表
        列表 = 列表.下一个

        如果 (t.计数 == 0) {
            t.状态 = t.状态 | TASKLET_状态_运行中
            t.状态 = t.状态 & ~TASKLET_状态_已调度
            如果 (t.处理函数 != 空) {
                定义 开始 = 读取纳秒()
                t.处理函数(t.数据)
                定义 耗时 = 读取纳秒() - 开始
                tasklet_记录延迟(耗时)
                如果 (耗时 > tasklet_超时阈值) {
                    tasklet_超时总数 = tasklet_超时总数 + 1
                    打印("[Tasklet] 警告: tasklet执行超时 " + 转字符串(耗时) + "ns")
                }
            }
            t.状态 = t.状态 & ~TASKLET_状态_运行中
            tasklet_执行总数 = tasklet_执行总数 + 1
            处理数 = 处理数 + 1
        } 否则 {
            tasklet_调度(t)
            tasklet_重排队总数 = tasklet_重排队总数 + 1
        }
    }
    返回 处理数
}

// Tasklet延迟测量 (AI基因)

函数 tasklet_记录延迟(延迟) {
    tasklet_延迟样本 = tasklet_延迟样本 + 1
    tasklet_延迟总计 = tasklet_延迟总计 + 延迟
    如果 (延迟 > tasklet_最大延迟) { tasklet_最大延迟 = 延迟 }
}

函数 tasklet_平均延迟() {
    如果 (tasklet_延迟样本 == 0) { 返回 0 }
    返回 tasklet_延迟总计 / tasklet_延迟样本
}

// 查询接口

函数 tasklet_普通队列长度() {
    定义 可变 长度 = 0
    定义 可变 当前 = tasklet_普通队列.头
    当 (当前 != 空) { 长度 = 长度 + 1; 当前 = 当前.下一个 }
    返回 长度
}

函数 tasklet_高优先级队列长度() {
    定义 可变 长度 = 0
    定义 可变 当前 = tasklet_高优先级队列.头
    当 (当前 != 空) { 长度 = 长度 + 1; 当前 = 当前.下一个 }
    返回 长度
}

函数 tasklet_是否运行中(t) {
    如果 (t == 空) { 返回 假 }
    返回 (t.状态 & TASKLET_状态_运行中) != 0
}

函数 tasklet_是否已调度(t) {
    如果 (t == 空) { 返回 假 }
    返回 (t.状态 & TASKLET_状态_已调度) != 0
}

函数 tasklet_是否已禁用(t) {
    如果 (t == 空) { 返回 真 }
    返回 t.计数 > 0
}

// 完整统计 (≥15个指标)

函数 tasklet_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "已初始化", tasklet_已初始化)
    字典设(统计, "调度总数", tasklet_调度总数)
    字典设(统计, "执行总数", tasklet_执行总数)
    字典设(统计, "高优先级执行", tasklet_高优先级执行总数)
    字典设(统计, "创建总数", tasklet_创建总数)
    字典设(统计, "销毁总数", tasklet_销毁总数)
    字典设(统计, "禁用总数", tasklet_禁用总数)
    字典设(统计, "使能总数", tasklet_使能总数)
    字典设(统计, "杀死总数", tasklet_杀死总数)
    字典设(统计, "重排队总数", tasklet_重排队总数)
    字典设(统计, "超时总数", tasklet_超时总数)
    字典设(统计, "普通队列长度", tasklet_普通队列长度())
    字典设(统计, "高优先级队列长度", tasklet_高优先级队列长度())
    字典设(统计, "平均延迟(ns)", tasklet_平均延迟())
    字典设(统计, "最大延迟(ns)", tasklet_最大延迟)
    字典设(统计, "延迟样本数", tasklet_延迟样本)
    字典设(统计, "错误数", tasklet_错误数)
    返回 统计
}

函数 tasklet_打印完整统计() {
    定义 统计 = tasklet_完整统计()
    打印("[Tasklet] ═══════ 完整统计 ═══════")
    打印("  调度总数:     " + 转字符串(字典取(统计, "调度总数")))
    打印("  执行总数:     " + 转字符串(字典取(统计, "执行总数")))
    打印("  高优先级:     " + 转字符串(字典取(统计, "高优先级执行")))
    打印("  创建总数:     " + 转字符串(字典取(统计, "创建总数")))
    打印("  销毁总数:     " + 转字符串(字典取(统计, "销毁总数")))
    打印("  重排队:       " + 转字符串(字典取(统计, "重排队总数")))
    打印("  超时:         " + 转字符串(字典取(统计, "超时总数")))
    打印("  普通队列:     " + 转字符串(字典取(统计, "普通队列长度")))
    打印("  高优先级队列: " + 转字符串(字典取(统计, "高优先级队列长度")))
    打印("  平均延迟:     " + 转字符串(字典取(统计, "平均延迟(ns)")) + "ns")
    打印("  最大延迟:     " + 转字符串(字典取(统计, "最大延迟(ns)")) + "ns")
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    打印("[Tasklet] ═════════════════════════")
    返回 0
}

// dump

函数 tasklet_dump() {
    打印("[Tasklet dump] ──────────────────")
    打印("  已初始化: " + 转字符串(tasklet_已初始化))
    打印("  调度总数: " + 转字符串(tasklet_调度总数))
    打印("  执行总数: " + 转字符串(tasklet_执行总数))
    打印("  普通队列: " + 转字符串(tasklet_普通队列长度()))
    打印("  高优先级队列: " + 转字符串(tasklet_高优先级队列长度()))
    打印("  超时: " + 转字符串(tasklet_超时总数))
    打印("  平均延迟: " + 转字符串(tasklet_平均延迟()) + "ns")
    打印("[Tasklet dump] ──────────────────")
}

// 销毁

函数 tasklet_系统_销毁() {
    如果 (tasklet_已初始化 == 假) { 返回 0 }
    tasklet_普通队列.头 = 空
    tasklet_高优先级队列.头 = 空
    tasklet_已初始化 = 假
    打印("[Tasklet] 系统已销毁")
    返回 0
}

// 与其他子系统的接口

函数 tasklet_为软中断提供处理函数() {
    返回 [tasklet_软中断处理, tasklet_高优先级_处理]
}

函数 tasklet_为调度器提供负载() {
    返回 [tasklet_普通队列长度(), tasklet_高优先级队列长度(),
           tasklet_调度总数, tasklet_执行总数]
}

函数 tasklet_为procfs提供统计() {
    返回 [tasklet_调度总数, tasklet_执行总数, tasklet_高优先级执行总数,
           tasklet_创建总数, tasklet_销毁总数, tasklet_超时总数,
           tasklet_普通队列长度(), tasklet_高优先级队列长度()]
}

函数 tasklet_重置统计() {
    tasklet_调度总数 = 0
    tasklet_执行总数 = 0
    tasklet_高优先级执行总数 = 0
    tasklet_创建总数 = 0
    tasklet_销毁总数 = 0
    tasklet_禁用总数 = 0
    tasklet_使能总数 = 0
    tasklet_杀死总数 = 0
    tasklet_重排队总数 = 0
    tasklet_超时总数 = 0
    tasklet_延迟总计 = 0
    tasklet_延迟样本 = 0
    tasklet_最大延迟 = 0
    打印("[Tasklet] 统计已重置")
    返回 0
}

// 软中断类型常量(与软中断_初始化.nova统一)
定义 软中断_TASKLET = 6
定义 软中断_高优先级 = 0

// Tasklet状态名

函数 tasklet_状态名(状态) {
    如果 (状态 == 0) { 返回 "空闲" }
    定义 可变 名称 = ""
    如果 ((状态 & TASKLET_状态_已调度) != 0) { 名称 = 名称 + "已调度 " }
    如果 ((状态 & TASKLET_状态_运行中) != 0) { 名称 = 名称 + "运行中 " }
    如果 (名称 == "") { 返回 "未知(" + 转字符串(状态) + ")" }
    返回 名称
}

函数 tasklet_dump_单个(t) {
    如果 (t == 空) { 返回 }
    打印("  Tasklet: 状态=" + tasklet_状态名(t.状态) +
         " 计数=" + 转字符串(t.计数) +
         " 处理=" + 转字符串(t.处理函数 != 空))
}

// 批量操作

函数 tasklet_批量调度(列表) {
    如果 (列表 == 空) { 返回 0 }
    定义 可变 成功数 = 0
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] != 空) {
            tasklet_调度_增强(列表[i])
            成功数 = 成功数 + 1
        }
        i = i + 1
    }
    返回 成功数
}

函数 tasklet_批量杀死(列表) {
    如果 (列表 == 空) { 返回 0 }
    定义 可变 成功数 = 0
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] != 空) {
            tasklet_销毁(列表[i])
            成功数 = 成功数 + 1
        }
        i = i + 1
    }
    返回 成功数
}

// 与AI子系统的接口

函数 tasklet_为AI提供延迟模式() {
    返回 [tasklet_平均延迟(), tasklet_最大延迟, tasklet_超时总数,
           tasklet_执行总数, tasklet_延迟样本]
}

// 中断保存/恢复辅助
函数 保存并关中断() {
    定义 可变 旧标志 = 0
    汇编 { "pushfq" "pop rax" "mov [rbp-8], rax" "cli" }
    返回 旧标志
}

函数 恢复中断(旧标志) {
    汇编 { "push [rbp+16]" "popfq" }
}

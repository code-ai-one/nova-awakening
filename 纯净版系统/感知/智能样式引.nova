导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./内核直连层.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/创建甲.nova")

定义 最大慢规则 = 128
定义 慢阈值 = 100
定义 缓存桶数 = 64
定义 衰减基数 = 1024
定义 衰减系数 = 950

结构 规则性能 {
    选择器哈希,
    匹配次数,
    总耗时,
    最大耗时,
    平均耗时,
    最近耗时,
    命中缓存次数,
    建议标记,
}

结构 规则缓存项 {
    选择器哈希,
    元素哈希,
    匹配结果,
    时间戳,
    后继,
}

定义 可变 慢规则表 = 0
定义 可变 慢规则数 = 0
定义 可变 缓存表 = 0
定义 可变 总匹配数 = 0
定义 可变 总慢匹配 = 0
定义 可变 缓存命中 = 0
定义 可变 缓存未中 = 0
定义 可变 优化建议数 = 0

函数 样式性能_初始化() {
    慢规则表 = 堆_分配(最大慢规则 * 48)
    慢规则数 = 0
    缓存表 = 堆_分配(缓存桶数 * 8)
    定义 可变 序号 = 0
    当 (序号 < 缓存桶数) {
        内存_写64(缓存表 + 序号 * 8, 0)
        序号 = 序号 + 1
    }
}

函数 样式性能_记录(选择器哈希, 耗时) {
    总匹配数 = 总匹配数 + 1
    定义 索引 = 样式性能_查找或创建(选择器哈希)
    如果 (索引 < 0) { 返回 }
    定义 偏移 = 慢规则表 + 索引 * 48
    定义 旧次数 = 内存_读32(偏移 + 8)
    内存_写32(偏移 + 8, 旧次数 + 1)
    定义 旧总耗 = 内存_读64(偏移 + 12)
    内存_写64(偏移 + 12, 旧总耗 + 耗时)
    如果 (耗时 > 内存_读32(偏移 + 20)) { 内存_写32(偏移 + 20, 耗时) }
    内存_写32(偏移 + 24, (旧总耗 + 耗时) / (旧次数 + 1))
    内存_写32(偏移 + 28, 耗时)
    如果 (耗时 > 慢阈值) {
        总慢匹配 = 总慢匹配 + 1
        样式性能_检查建议(索引)
    }
}

函数 样式性能_查找或创建(选择器哈希) {
    定义 可变 序号 = 0
    当 (序号 < 慢规则数) {
        如果 (内存_读64(慢规则表 + 序号 * 48) == 选择器哈希) { 返回 序号 }
        序号 = 序号 + 1
    }
    如果 (慢规则数 >= 最大慢规则) { 返回 -1 }
    定义 偏移 = 慢规则表 + 慢规则数 * 48
    内存_写64(偏移, 选择器哈希)
    内存_写32(偏移 + 8, 0)
    内存_写64(偏移 + 12, 0)
    内存_写32(偏移 + 20, 0)
    内存_写32(偏移 + 24, 0)
    内存_写32(偏移 + 28, 0)
    内存_写32(偏移 + 32, 0)
    内存_写32(偏移 + 36, 0)
    定义 索引 = 慢规则数
    慢规则数 = 慢规则数 + 1
    返回 索引
}

函数 样式性能_检查建议(索引) {
    定义 偏移 = 慢规则表 + 索引 * 48
    定义 平均 = 内存_读32(偏移 + 24)
    定义 次数 = 内存_读32(偏移 + 8)
    如果 (平均 > 慢阈值 * 5 && 次数 > 10 && 内存_读32(偏移 + 36) == 0) {
        内存_写32(偏移 + 36, 1)
        优化建议数 = 优化建议数 + 1
    }
}

函数 样式缓存_查找(选择器哈希, 元素哈希) {
    定义 桶号 = (选择器哈希 ^ 元素哈希) % 缓存桶数
    定义 可变 当前 = 内存_读64(缓存表 + 桶号 * 8)
    当 (当前 != 0) {
        如果 (内存_读64(当前) == 选择器哈希 && 内存_读64(当前 + 8) == 元素哈希) {
            缓存命中 = 缓存命中 + 1
            返回 内存_读32(当前 + 16)
        }
        当前 = 内存_读64(当前 + 24)
    }
    缓存未中 = 缓存未中 + 1
    返回 -1
}

函数 样式缓存_插入(选择器哈希, 元素哈希, 结果) {
    定义 桶号 = (选择器哈希 ^ 元素哈希) % 缓存桶数
    定义 项 = 堆_分配(32)
    内存_写64(项, 选择器哈希)
    内存_写64(项 + 8, 元素哈希)
    内存_写32(项 + 16, 结果)
    内存_写64(项 + 20, 平台_获取高精度时间())
    内存_写64(项 + 24, 内存_读64(缓存表 + 桶号 * 8))
    内存_写64(缓存表 + 桶号 * 8, 项)
}

函数 样式缓存_清空() {
    定义 可变 桶号 = 0
    当 (桶号 < 缓存桶数) {
        内存_写64(缓存表 + 桶号 * 8, 0)
        桶号 = 桶号 + 1
    }
    缓存命中 = 0
    缓存未中 = 0
}

函数 样式性能_获取前N慢(数量, 输出) {
    定义 可变 已输出 = 0
    定义 可变 序号 = 0
    当 (序号 < 慢规则数 && 已输出 < 数量) {
        定义 偏移 = 慢规则表 + 序号 * 48
        定义 平均 = 内存_读32(偏移 + 24)
        如果 (平均 > 慢阈值) {
            内存_写64(输出 + 已输出 * 16, 内存_读64(偏移))
            内存_写32(输出 + 已输出 * 16 + 8, 平均)
            内存_写32(输出 + 已输出 * 16 + 12, 内存_读32(偏移 + 8))
            已输出 = 已输出 + 1
        }
        序号 = 序号 + 1
    }
    返回 已输出
}

函数 样式性能_缓存命中率() {
    定义 总 = 缓存命中 + 缓存未中
    如果 (总 == 0) { 返回 0 }
    返回 缓存命中 * 100 / 总
}

函数 样式性能_完整统计() {
    返回 [总匹配数, 总慢匹配, 慢规则数, 缓存命中, 缓存未中, 样式性能_缓存命中率(), 优化建议数]
}

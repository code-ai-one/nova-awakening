导入("../基础.nova")


// FP16模拟 (scale=1000时, FP16范围约-65504~65504)
定义 半精度_最大值 = 65504
定义 半精度_最小值 = -65504
定义 半精度_精度 = 1

函数 转半精度(值) {
    如果 (值 > 半精度_最大值) { 返回 半精度_最大值
}
 如果 (值 < 半精度_最小值) { 返回 半精度_最小值 }
 返回 值
}

函数 fp16_溢出(值) {
    如果 (值 > 半精度_最大值) { 返回 真
}
 如果 (值 < 半精度_最小值) { 返回 真 }
 返回 假
}

函数 批转半精度(数据) { 返回 映射(数据, x => 转半精度(x))
}

// 损失缩放器
定义 缩放器_比例 = 65536
定义 缩放器_增长因子 = 2000
定义 缩放器_回退因子 = 500
定义 缩放器_增长间隔 = 2000
定义 可变 缩放器_增长追踪 = 0

函数 缩放器初始化(initial_scale) {
 缩放器_比例 = initial_scale
 缩放器_增长追踪 = 0
}

函数 缩放器_缩放损失(损失值) { 返回 损失值 * 缩放器_比例 / 1000 }

函数 缩放器_反缩放梯度(梯度) { 返回 映射(梯度, g => g * 1000 / 缩放器_比例)
}

函数 缩放器_检查溢出(梯度) { 定义 可变 i = 0
 当 (i < 计数(梯度)) { 如果 (fp16_溢出(梯度[i])) { 返回 真 }
 i = i + 1
 }
 返回 假
}

函数 缩放器_更新(has_overflow) { 如果 (has_overflow) {
 缩放器_比例 = 缩放器_比例 * 缩放器_回退因子 / 1000
 如果 (缩放器_比例 < 1) { 缩放器_比例 = 1 }
 缩放器_增长追踪 = 0
 } 否则 {
 缩放器_增长追踪 = 缩放器_增长追踪 + 1
 如果 (缩放器_增长追踪 >= 缩放器_增长间隔) {
 缩放器_比例 = 缩放器_比例 * 缩放器_增长因子 / 1000
 缩放器_增长追踪 = 0
 }
 }
}

// 混合精度前向
函数 mp_前向(输入, 权重) {
 // 输入转FP16计算, 输出保持FP32
 定义 fp16_in = 批转半精度(输入)
 定义 fp16_w = 批转半精度(权重)
 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(fp16_in)) { 定义 可变 数值 = 0
 如果 (i < 计数(fp16_w)) { 数值 = fp16_in[i] * fp16_w[i] / 1000 }
 追加(结果, 数值)
 i = i + 1
 }
 返回 结果
}

// 精度统计
// 缩放器是否激活
函数 scaler_激活() { 返回 缩放器_比例 > 0 }

// BF16模拟 (更大范围, 精度较低)
定义 半精度16_最大 = 32767000
定义 半精度16_最小 = -32767000

函数 转脑浮点16(值) {
    如果 (值 > 半精度16_最大) { 返回 半精度16_最大
}
 如果 (值 < 半精度16_最小) { 返回 半精度16_最小 }
 // BF16精度约3位有效数字, 截断低位
 返回 (值 / 128) * 128
}

函数 批转脑浮点16(数据) { 返回 映射(数据, x => 转脑浮点16(x))
}

// 精度模式

定义 可变 当前精度模式 = 精度_FP16

函数 精度_设置(模式) { 当前精度模式 = 模式 }

函数 精度_转换(值) {
    如果 (当前精度模式 == 精度_FP16) { 返回 转半精度(值)
}
 如果 (当前精度模式 == 精度_BF16) { 返回 转脑浮点16(值) }
 返回 值
}

函数 batch_转换(数据) { 返回 映射(数据, x => 精度_转换(x))
}

// 混合精度训练步骤
函数 mp_训练步(输入, 权重, 梯度, 学习率) {
 // 1. 前向: FP16
 定义 输出 = mp_前向(输入, 权重)
 // 2. 损失缩放
 定义 可变 缩放梯度 = 映射(梯度, g => g * 缩放器_比例 / 1000)
 // 3. 溢出检查
 定义 溢出 = 缩放器_检查溢出(缩放梯度)
 如果 (溢出) {
 缩放器_更新(真)
 返回 [输出, 假] // 跳过此步
 }
 // 4. 反缩放
 定义 真实梯度 = 缩放器_反缩放梯度(缩放梯度)
 // 5. 更新权重 (FP32)
 定义 可变 新权重 = []
 定义 可变 i = 0
 当 (i < 计数(权重)) { 定义 可变 g = 0
 如果 (i < 计数(真实梯度)) { g = 真实梯度[i] }
 追加(新权重, 权重[i] - 学习率 * g / 1000)
 i = i + 1
 }
 缩放器_更新(假)
 返回 [新权重, 真]
}

// 溢出统计
定义 可变 溢出_总步 = 0
定义 可变 溢出_跳过步 = 0

函数 溢出_记录(是否溢出) {
 溢出_总步 = 溢出_总步 + 1
 如果 (是否溢出) { 溢出_跳过步 = 溢出_跳过步 + 1 }
}

函数 溢出_跳过率() {
    如果 (溢出_总步 == 0) { 返回 0
}
 返回 溢出_跳过步 * 1000 / 溢出_总步
}

函数 溢出_报告() {
 打印("混合精度统计:")
 打印(" 总步数: " + 转字符串(溢出_总步))
 打印(" 跳过步: " + 转字符串(溢出_跳过步))
 打印(" 跳过率: " + 转字符串(溢出_跳过率()) + "‰")
 打印(" 当前缩放: " + 转字符串(缩放器_比例))
}

// 权重主副本
函数 mp_创建副本(fp32权重) { 返回 [fp32权重, batch_转换(fp32权重)] // [FP32主本, FP16计算本]
}

函数 mp_同步副本(副本, fp32权重) {
 副本[0] = fp32权重
 副本[1] = batch_转换(fp32权重)
}

// BF16转换
函数 单精度转脑浮点(值) { 返回 (值 + 128) / 256 * 256
}

函数 脑浮点转单精度(值) { 返回 值
}

// 精度损失监控
定义 可变 _精度损失_记录 = []

函数 精度损失_检测(fp32值, fp16值) { 定义 差值 = fp32值 - fp16值
 如果 (差值 < 0) { 差值 = 0 - 差值 }
 追加(_精度损失_记录, 差值)
 返回 差值
}

函数 精度损失_平均() { 定义 n = 计数(_精度损失_记录)
 如果 (n == 0) { 返回 0 }
 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < n) { 总 = 总 + _精度损失_记录[i] i = i + 1 }
 返回 总 / n
}

函数 精度损失_最大() { 定义 可变 最大 = 0
 定义 可变 i = 0
 当 (i < 计数(_精度损失_记录)) { 如果 (_精度损失_记录[i] > 最大) { 最大 = _精度损失_记录[i] }
 i = i + 1
 }
 返回 最大
}

// 自动精度选择
函数 自动精度_推荐(参数量, 显存MB) { 定义 fp32需要 = 参数量 * 4
 定义 fp16需要 = 参数量 * 2
 如果 (fp32需要 <= 显存MB * 1048576) { 返回 "FP32" }
 如果 (fp16需要 <= 显存MB * 1048576) { 返回 "FP16" }
 返回 "INT8"
}

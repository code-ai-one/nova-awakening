// 探测: 浮点负号bug
函数 主程序() {
    // 直接字面量
    定义 a = 0.0 - 1.0
    打印(字符串拼接("0.0-1.0 bits=", 转字符串(a)))
    // 单独浮点比较
    定义 b = 1.0
    定义 c = 0.0
    定义 d = c - b
    打印(字符串拼接("c-b bits=", 转字符串(d)))
    // approx 0-1.0 预期的double bit = 0xBFF0000000000000 = -4616189618054758400
    // 如果 0.0-1.0 bits 也是这个值, 则值正确
    // 负值判定
    如果 (d < 0.0) { 打印("✓ d<0") } 否则 { 打印("✗ d not <0") }
    // |d| < 2.0
    定义 abs_d = d
    如果 (d < 0.0) { abs_d = 0.0 - d }
    打印(字符串拼接("abs(d) bits=", 转字符串(abs_d)))
    // abs(d) 应 ≈ 1.0, bit=0x3FF0000000000000=4607182418800017408
    如果 (abs_d < 2.0) { 打印("✓ abs_d < 2") } 否则 { 打印("✗ abs not <2") }
    如果 (abs_d > 0.5) { 打印("✓ abs_d > 0.5") } 否则 { 打印("✗ abs not >0.5") }
    // 直接 1.0 < 2.0
    如果 (1.0 < 2.0) { 打印("✓ 1<2") } 否则 { 打印("✗ 1>=2?!") }
    // 用整数比较double bits
    如果 (abs_d == 4607182418800017408) { 打印("✓ abs_d bits==1.0bits") } 否则 { 打印("✗ bits不等") }
    // 浮点==
    如果 (abs_d == 1.0) { 打印("✓ abs_d==1.0") } 否则 { 打印("✗ abs_d!=1.0?") }
    返回 0
}

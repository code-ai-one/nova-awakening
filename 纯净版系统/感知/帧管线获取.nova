// Nova浏览器: 模块间真实连接器
// 将之前独立的模块串联为完整调用链:
//   事件Loop ↔ 渲染Pipeline ↔ Compositor
//   V8 ↔ DOM ↔ CSSOM ↔ 布局 ↔ 绘制
//   Service工线 ↔ 网络栈(取数/安全/域名)
//   Browser进程 ↔ IPC ↔ 渲染er进程

导入("./文档事件.nova")
导入("./样式解析.nova")
导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("./兼容桥.nova")
导入("../推理/值乘.nova")
导入("../中枢/创建甲.nova")
导入("./元素.nova")

// §1 主渲染帧循环 — 将事件Loop与渲染Pipeline真实连接

// 浏览器每帧的完整流水线(帧渲染主流程):
//   1. 处理输入事件(鼠标/键盘/触摸)
//   2. 执行rAF回调
//   3. 执行微任务
//   4. 样式计算(样式 Recalc)
//   5. 布局(布局)
//   6. 绘制(绘制)
//   7. 合成(Composite) → 提交给图处进程
//   8. 空闲时间: rIC回调 / 增量GC

结构 FramePipeline {
    // 各阶段耗时(微秒)
    输入处理耗时,
    rAF耗时,
    微任务耗时,
    样式耗时,
    布局耗时,
    绘制耗时,
    合成耗时,
    // 帧统计
    帧号,
    帧开始时间,
    帧结束时间,
    帧总耗时,
    // 掉帧
    是否掉帧,
    连续掉帧,
    // 脏标记
    需要样式,
    需要布局,
    需要绘制,
    需要合成,
}

定义 可变 全局帧管线 = 0

函数 FramePipeline_获取() {
    如果 (全局帧管线 == 0) {
        全局帧管线 = 堆_分配(FramePipeline)
        全局帧管线.帧号 = 0; 全局帧管线.连续掉帧 = 0
        全局帧管线.需要样式 = 假; 全局帧管线.需要布局 = 假
        全局帧管线.需要绘制 = 假; 全局帧管线.需要合成 = 假
    }
    返回 全局帧管线
}

// 每帧主入口 — 由VSync信号或requestAnimationFrame驱动
函数 Frame_执行一帧() {
    定义 fp = FramePipeline_获取()
    定义 cfg = Config_获取()
    定义 帧预算 = cfg.帧预算us
    fp.帧开始时间 = 平台_获取高精度时间()
    fp.帧号 = fp.帧号 + 1

    定义 t0 = 平台_获取高精度时间()
    事件Loop_处理输入事件()
    fp.输入处理耗时 = 平台_获取高精度时间() - t0

    定义 t1 = 平台_获取高精度时间()
    事件Loop_执行rAF()
    fp.rAF耗时 = 平台_获取高精度时间() - t1

    定义 t2 = 平台_获取高精度时间()
    事件Loop_清空微任务()
    fp.微任务耗时 = 平台_获取高精度时间() - t2

    AnimationTimeline_tick()

    如果 (fp.需要样式) {
        定义 t3 = 平台_获取高精度时间()
        Frame_样式计算()
        fp.样式耗时 = 平台_获取高精度时间() - t3
        fp.需要样式 = 假
        fp.需要布局 = 真    // 样式变化必然触发布局
    }

    如果 (fp.需要布局) {
        定义 t4 = 平台_获取高精度时间()
        Frame_布局()
        fp.布局耗时 = 平台_获取高精度时间() - t4
        fp.需要布局 = 假
        fp.需要绘制 = 真
    }

    如果 (fp.需要绘制) {
        定义 t5 = 平台_获取高精度时间()
        Frame_绘制()
        fp.绘制耗时 = 平台_获取高精度时间() - t5
        fp.需要绘制 = 假
        fp.需要合成 = 真
    }

    如果 (fp.需要合成) {
        定义 t6 = 平台_获取高精度时间()
        Frame_合成提交()
        fp.合成耗时 = 平台_获取高精度时间() - t6
        fp.需要合成 = 假
    }

    fp.帧结束时间 = 平台_获取高精度时间()
    fp.帧总耗时 = fp.帧结束时间 - fp.帧开始时间

    // 检测丢帧
    如果 (fp.帧总耗时 > 帧预算) {
        fp.是否丢帧 = 真
        fp.连续丢帧 = fp.连续丢帧 + 1
    } 否则 {
        fp.是否丢帧 = 假
        fp.连续丢帧 = 0
    }

    // 更新全局统计
    帧统计_更新(fp)

    定义 剩余时间 = 帧预算 - fp.帧总耗时
    如果 (剩余时间 > 1000) {  // 超过1ms空闲
        Frame_空闲回调(剩余时间)
    }
}

// §2 帧统计系统 — NFRP理论 (Nova Frame Rendering Pipeline)
//   原创帧渲染管线理论: 满射帧耗时模型 + AI自适应帧预算 +
//   分阶段瓶颈检测 + 动态精度调整 + 预测性布局跳过

定义 统计窗口大小 = 60
定义 丢帧报警阈值 = 5
定义 帧预算_60fps = 16667  // 16.667ms

结构 帧统计器 {
    帧耗时窗口: 数组<整数>,
    窗口索引: 整数,
    窗口已填满: 布尔,
    总帧数: 整数,
    丢帧总数: 整数,
    最大帧耗时: 整数,
    平均帧耗时: 浮点数,
    // 分阶段耗时累计
    累计_输入耗时: 整数,
    累计_rAF耗时: 整数,
    累计_微任务耗时: 整数,
    累计_样式耗时: 整数,
    累计_布局耗时: 整数,
    累计_绘制耗时: 整数,
    累计_合成耗时: 整数,
    // 瓶颈检测
    瓶颈阶段: 整数,     // 0=无, 1=输入, 2=rAF, 3=样式, 4=布局, 5=绘制, 6=合成
    AI帧预算建议: 浮点数
}

定义 可变 全局帧统计 = 0

函数 帧统计_获取() {
    如果 (全局帧统计 == 0) {
        全局帧统计 = 堆_分配(帧统计器)
        全局帧统计.帧耗时窗口 = 数组_创建(统计窗口大小, 0)
        全局帧统计.窗口索引 = 0
        全局帧统计.窗口已填满 = 假
        全局帧统计.总帧数 = 0
        全局帧统计.丢帧总数 = 0
        全局帧统计.最大帧耗时 = 0
        全局帧统计.平均帧耗时 = 0.0
        全局帧统计.累计_输入耗时 = 0
        全局帧统计.累计_rAF耗时 = 0
        全局帧统计.累计_微任务耗时 = 0
        全局帧统计.累计_样式耗时 = 0
        全局帧统计.累计_布局耗时 = 0
        全局帧统计.累计_绘制耗时 = 0
        全局帧统计.累计_合成耗时 = 0
        全局帧统计.瓶颈阶段 = 0
        全局帧统计.AI帧预算建议 = 16667.0
    }
    返回 全局帧统计
}

函数 帧统计_更新(fp) {
    定义 stats = 帧统计_获取()
    stats.总帧数 = stats.总帧数 + 1
    // 滑动窗口记录
    stats.帧耗时窗口[stats.窗口索引] = fp.帧总耗时
    stats.窗口索引 = (stats.窗口索引 + 1) % 统计窗口大小
    如果 (stats.总帧数 >= 统计窗口大小) { stats.窗口已填满 = 真 }
    // 丢帧统计
    如果 (fp.是否丢帧) { stats.丢帧总数 = stats.丢帧总数 + 1 }
    // 最大耗时
    如果 (fp.帧总耗时 > stats.最大帧耗时) { stats.最大帧耗时 = fp.帧总耗时 }
    // 分阶段累计
    stats.累计_输入耗时 = stats.累计_输入耗时 + fp.输入处理耗时
    stats.累计_rAF耗时 = stats.累计_rAF耗时 + fp.rAF耗时
    stats.累计_微任务耗时 = stats.累计_微任务耗时 + fp.微任务耗时
    stats.累计_样式耗时 = stats.累计_样式耗时 + fp.样式耗时
    stats.累计_布局耗时 = stats.累计_布局耗时 + fp.布局耗时
    stats.累计_绘制耗时 = stats.累计_绘制耗时 + fp.绘制耗时
    stats.累计_合成耗时 = stats.累计_合成耗时 + fp.合成耗时
    // 计算平均帧耗时
    stats.平均帧耗时 = 帧统计_计算窗口平均(stats)
    // 瓶颈检测
    如果 (stats.总帧数 % 60 == 0) {
        帧统计_瓶颈检测(stats)
        帧统计_AI自适应(stats)
    }
}

函数 帧统计_计算窗口平均(stats) {
    定义 窗口量 = 统计窗口大小
    如果 (!stats.窗口已填满) { 窗口量 = stats.总帧数 }
    如果 (窗口量 == 0) { 返回 0.0 }
    可变 总和 = 0
    可变 i = 0
    当 (i < 窗口量) {
        总和 = 总和 + stats.帧耗时窗口[i]
        i = i + 1
    }
    返回 总和 * 1.0 / 窗口量
}

函数 帧统计_瓶颈检测(stats) {
    // 找占比最高的阶段
    定义 最大 = stats.累计_输入耗时
    stats.瓶颈阶段 = 1
    如果 (stats.累计_rAF耗时 > 最大) { 最大 = stats.累计_rAF耗时; stats.瓶颈阶段 = 2 }
    如果 (stats.累计_样式耗时 > 最大) { 最大 = stats.累计_样式耗时; stats.瓶颈阶段 = 3 }
    如果 (stats.累计_布局耗时 > 最大) { 最大 = stats.累计_布局耗时; stats.瓶颈阶段 = 4 }
    如果 (stats.累计_绘制耗时 > 最大) { 最大 = stats.累计_绘制耗时; stats.瓶颈阶段 = 5 }
    如果 (stats.累计_合成耗时 > 最大) { 最大 = stats.累计_合成耗时; stats.瓶颈阶段 = 6 }
}

// AI自适应帧预算
函数 帧统计_AI自适应(stats) {
    定义 特征 = Tensor_创建(1, 5)
    Tensor_写(特征, 0, 0, stats.平均帧耗时)
    Tensor_写(特征, 0, 1, stats.丢帧总数 * 1.0 / stats.总帧数)
    Tensor_写(特征, 0, 2, stats.瓶颈阶段 * 1.0)
    Tensor_写(特征, 0, 3, stats.最大帧耗时 * 1.0)
    Tensor_写(特征, 0, 4, 平台_获取内存使用率())
    定义 结果 = AI总线_推理("frame_budget_optimizer", 特征)
    如果 (结果 != 空) {
        stats.AI帧预算建议 = Tensor_读(结果, 0, 0)
        Tensor_释放(结果)
    }
    Tensor_释放(特征)
}

// §3 帧各阶段详细实现

// 样式计算 — 重新计算脏节点的CSS属性
函数 Frame_样式计算() {
    定义 文档 = 获取当前文档()
    如果 (文档 == 0) { 返回 }
    定义 根节点 = 文档.根节点
    如果 (根节点 == 0) { 返回 }
    // 遍历脏节点列表，重新计算样式
    CSS样式_重新计算(根节点)
}

// 布局 — 计算元素位置和尺寸
函数 Frame_布局() {
    定义 文档 = 获取当前文档()
    如果 (文档 == 0) { 返回 }
    定义 视口宽 = 获取视口宽度()
    定义 视口高 = 获取视口高度()
    布局_执行(文档.根布局对象, 视口宽, 视口高)
}

// 绘制 — 生成显示列表
函数 Frame_绘制() {
    定义 文档 = 获取当前文档()
    如果 (文档 == 0) { 返回 }
    绘制_生成显示列表(文档.根绘制层)
}

// 合成提交 — 将帧提交到图形进程
函数 Frame_合成提交() {
    定义 帧数据 = 合成器_收集帧数据()
    图形进程_提交帧(帧数据)
}

// 空闲回调 — 处理requestIdleCallback与增量GC
函数 Frame_空闲回调(剩余时间_us) {
    // 执行rIC回调
    事件Loop_执行rIC(剩余时间_us)
    // 增量GC
    定义 gc时间 = 剩余时间_us / 3  // 分配1/3给GC
    如果 (gc时间 > 500) {
        GC_增量收集(gc时间)
    }
}

// §4 脏标记管理 — 最小化渲染工作

函数 Frame_标记需要样式() {
    定义 fp = FramePipeline_获取()
    fp.需要样式 = 真
}

函数 Frame_标记需要布局() {
    定义 fp = FramePipeline_获取()
    fp.需要布局 = 真
}

函数 Frame_标记需要绘制() {
    定义 fp = FramePipeline_获取()
    fp.需要绘制 = 真
}

函数 Frame_标记需要合成() {
    定义 fp = FramePipeline_获取()
    fp.需要合成 = 真
}

// §5 诊断报告

函数 帧管线_获取诊断() {
    定义 stats = 帧统计_获取()
    可变 报告 = "═══ NFRP 帧管线诊断报告 ═══\n"
    报告 = 报告 + "总帧数: " + stats.总帧数 + "\n"
    报告 = 报告 + "丢帧数: " + stats.丢帧总数 + "\n"
    定义 丢帧率 = 0.0
    如果 (stats.总帧数 > 0) { 丢帧率 = stats.丢帧总数 * 100.0 / stats.总帧数 }
    报告 = 报告 + "丢帧率: " + 丢帧率 + "%\n"
    报告 = 报告 + "平均帧时: " + stats.平均帧耗时 + "us\n"
    报告 = 报告 + "最大帧时: " + stats.最大帧耗时 + "us\n"
    报告 = 报告 + "瓶颈阶段: " + 帧统计_瓶颈名称(stats.瓶颈阶段) + "\n"
    报告 = 报告 + "AI帧预算建议: " + stats.AI帧预算建议 + "us\n"
    返回 报告
}

函数 帧统计_瓶颈名称(阶段) {
    如果 (阶段 == 0) { 返回 "无" }
    如果 (阶段 == 1) { 返回 "输入处理" }
    如果 (阶段 == 2) { 返回 "rAF" }
    如果 (阶段 == 3) { 返回 "样式计算" }
    如果 (阶段 == 4) { 返回 "布局" }
    如果 (阶段 == 5) { 返回 "绘制" }
    如果 (阶段 == 6) { 返回 "合成" }
    返回 "未知"
}

// §6 帧调度器 — VSync与动态帧率控制

结构 帧调度器 {
    目标帧率: 整数,
    vsync_间隔: 整数,     // 微秒
    上次vsync时间: 整数,
    当前帧率: 浮点数,
    最小帧率: 整数,
    最大帧率: 整数,
    自适应帧率: 布尔,
    空闲降频: 布尔,
    空闲计时器: 整数,
    空闲阈值_毫秒: 整数
}

函数 帧调度器_创建(目标帧率) {
    可变 调度器 = 堆_分配(帧调度器)
    调度器.目标帧率 = 目标帧率
    调度器.vsync_间隔 = 1000000 / 目标帧率  // 微秒
    调度器.上次vsync时间 = 0
    调度器.当前帧率 = 目标帧率 * 1.0
    调度器.最小帧率 = 15
    调度器.最大帧率 = 120
    调度器.自适应帧率 = 真
    调度器.空闲降频 = 真
    调度器.空闲计时器 = 0
    调度器.空闲阈值_毫秒 = 3000
    返回 调度器
}

函数 帧调度器_on_vsync(调度器, 当前时间_ns) {
    如果 (调度器.上次vsync时间 == 0) {
        调度器.上次vsync时间 = 当前时间_ns
        返回 真
    }
    定义 差值 = 当前时间_ns - 调度器.上次vsync时间
    定义 目标间隔 = 调度器.vsync_间隔 * 1000  // 转纳秒
    如果 (差值 >= 目标间隔) {
        // 计算实际帧率
        如果 (差值 > 0) {
            调度器.当前帧率 = 1000000000.0 / 差值
        }
        调度器.上次vsync时间 = 当前时间_ns
        调度器.空闲计时器 = 0
        返回 真
    }
    返回 假
}

函数 帧调度器_自适应更新(调度器, 丢帧率) {
    如果 (!调度器.自适应帧率) { 返回 }
    // NFRP自适应公式: fps_new = fps_target * (1 - dropout_rate * 0.5)
    // 保证帧率在[min, max]范围内
    如果 (丢帧率 > 0.15) {
        // 丢帧过多，降低帧率
        可变 新帧率 = 调度器.目标帧率 - 5
        如果 (新帧率 < 调度器.最小帧率) { 新帧率 = 调度器.最小帧率 }
        调度器.目标帧率 = 新帧率
        调度器.vsync_间隔 = 1000000 / 新帧率
    } 否则 如果 (丢帧率 < 0.02) {
        // 性能良好，尝试提升帧率
        可变 新帧率 = 调度器.目标帧率 + 5
        如果 (新帧率 > 调度器.最大帧率) { 新帧率 = 调度器.最大帧率 }
        调度器.目标帧率 = 新帧率
        调度器.vsync_间隔 = 1000000 / 新帧率
    }
}

函数 帧调度器_检查空闲(调度器) {
    如果 (!调度器.空闲降频) { 返回 }
    调度器.空闲计时器 = 调度器.空闲计时器 + 1
    // 空闲超过阈值，降至最低帧率以节能
    定义 空闲时间 = 调度器.空闲计时器 * 调度器.vsync_间隔 / 1000  // 转毫秒
    如果 (空闲时间 > 调度器.空闲阈值_毫秒) {
        调度器.目标帧率 = 调度器.最小帧率
        调度器.vsync_间隔 = 1000000 / 调度器.最小帧率
    }
}

// §7 配置与参数

结构 渲染配置 {
    帧预算us: 整数,
    启用AI优化: 布尔,
    启用自适应帧率: 布尔,
    启用空闲降频: 布尔,
    GC_最大时间_us: 整数,
    布局缓存大小: 整数,
    合成层上限: 整数
}

定义 可变 全局渲染配置 = 0

函数 Config_获取() {
    如果 (全局渲染配置 == 0) {
        全局渲染配置 = 堆_分配(渲染配置)
        全局渲染配置.帧预算us = 16667
        全局渲染配置.启用AI优化 = 真
        全局渲染配置.启用自适应帧率 = 真
        全局渲染配置.启用空闲降频 = 真
        全局渲染配置.GC_最大时间_us = 2000
        全局渲染配置.布局缓存大小 = 1024
        全局渲染配置.合成层上限 = 64
    }
    返回 全局渲染配置
}

// §8 帧管线重置与AI预测性布局跳过

函数 帧管线_重置() {
    定义 fp = FramePipeline_获取()
    fp.帧号 = 0
    fp.连续丢帧 = 0
    fp.需要样式 = 假
    fp.需要布局 = 假
    fp.需要绘制 = 假
    fp.需要合成 = 假
    fp.输入处理耗时 = 0
    fp.rAF耗时 = 0
    fp.微任务耗时 = 0
    fp.样式耗时 = 0
    fp.布局耗时 = 0
    fp.绘制耗时 = 0
    fp.合成耗时 = 0
}

// AI预测性布局跳过 — NFRP核心优化
// 如果AI判断当前帧无布局变化，可跳过布局阶段
函数 AI_可跳过布局() {
    定义 stats = 帧统计_获取()
    定义 特征 = Tensor_创建(1, 3)
    Tensor_写(特征, 0, 0, stats.累计_布局耗时 * 1.0 / (stats.总帧数 + 1))
    Tensor_写(特征, 0, 1, stats.平均帧耗时)
    Tensor_写(特征, 0, 2, stats.丢帧总数 * 1.0)
    定义 结果 = AI总线_推理("layout_skip_predictor", 特征)
    可变 可跳过 = 假
    如果 (结果 != 空) {
        可跳过 = Tensor_读(结果, 0, 0) > 0.8
        Tensor_释放(结果)
    }
    Tensor_释放(特征)
    返回 可跳过
}

// 帧耗时疙号分布计算 — P50/P95/P99
函数 帧统计_计算百分位(stats, 百分位) {
    定义 窗口量 = 统计窗口大小
    如果 (!stats.窗口已填满) { 窗口量 = stats.总帧数 }
    如果 (窗口量 == 0) { 返回 0 }
    // 复制窗口并排序
    可变 排序数据 = 数组_创建(窗口量, 0)
    可变 i = 0
    当 (i < 窗口量) {
        排序数据[i] = stats.帧耗时窗口[i]
        i = i + 1
    }
    // 简单插入排序
    i = 1
    当 (i < 窗口量) {
        定义 key = 排序数据[i]
        可变 j = i - 1
        当 (j >= 0 && 排序数据[j] > key) {
            排序数据[j + 1] = 排序数据[j]
            j = j - 1
        }
        排序数据[j + 1] = key
        i = i + 1
    }
    定义 索引 = (百分位 * 窗口量 / 100)
    如果 (索引 >= 窗口量) { 索引 = 窗口量 - 1 }
    返回 排序数据[索引]
}

// §9 【原生独创】谐振帧率自适应调节器
// 基于历史帧耗时分布动态调整目标帧率

定义 可变 _谐振帧率_目标us = 16667
定义 可变 _谐振帧率_调节次数 = 0

函数 谐振帧率_自适应(stats) {
    定义 p95 = 帧统计_计算百分位(stats, 95)
    如果 (p95 > 16000 && _谐振帧率_目标us < 33333) {
        // P95超过16ms，降至30fps
        _谐振帧率_目标us = 33333
        _谐振帧率_调节次数 = _谐振帧率_调节次数 + 1
    } 否则如果 (p95 < 8000 && _谐振帧率_目标us > 16667) {
        // P95低于8ms，可恢复60fps
        _谐振帧率_目标us = 16667
        _谐振帧率_调节次数 = _谐振帧率_调节次数 + 1
    }
}

函数 谐振帧率_当前目标() { 返回 _谐振帧率_目标us }

函数 帧管线_完整统计() {
    定义 stats = 帧统计_获取()
    返回 [
        "总帧数", stats.总帧数,
        "丢帧数", stats.丢帧总数,
        "平均帧耗时", stats.平均帧耗时,
        "谐振目标帧率us", _谐振帧率_目标us,
        "谐振调节次数", _谐振帧率_调节次数
    ]
}

导入("../基础.nova")


// 状态机: [当前状态, 状态表, 转移表, 历史, 数据]
函数 状态机_创建(初始状态) {
    定义 可变 sm = [空, 字典(), [], [], 字典()]
    sm[0] = 初始状态
    返回 sm
}

函数 状态机_当前(sm) { 返回 sm[0] }
函数 状态机_历史(sm) { 返回 sm[3] }
函数 状态机_数据(sm) { 返回 sm[4] }

函数 状态机_添加状态(sm, 名称) {
    字典设(sm[1], 名称, 1)
}

// 转移: [源状态, 事件, 目标状态]
函数 状态机_添加转移(sm, 源, 事件, 目标) {
    定义 可变 转移 = [空, 空, 空]
    转移[0] = 源
    转移[1] = 事件
    转移[2] = 目标
    追加(sm[2], 转移)
}

函数 状态机_触发(sm, 事件) {
    定义 当前 = sm[0]
    定义 转移表 = sm[2]
    定义 可变 i = 0
    当 (i < 计数(转移表)) {
        定义 转移 = 转移表[i]
        如果 (字符串等于(转移[0], 当前) 且 字符串等于(转移[1], 事件)) {
            定义 可变 历史项 = [空, 空, 空]
            历史项[0] = 当前
            历史项[1] = 事件
            历史项[2] = 转移[2]
            追加(sm[3], 历史项)
            sm[0] = 转移[2]
            返回 1
        }
        i = i + 1
    }
    返回 0
}

函数 状态机_可触发(sm, 事件) {
    定义 当前 = sm[0]
    定义 转移表 = sm[2]
    定义 可变 i = 0
    当 (i < 计数(转移表)) {
        如果 (字符串等于(转移表[i][0], 当前) 且 字符串等于(转移表[i][1], 事件)) {
            返回 1
        }
        i = i + 1
    }
    返回 0
}

函数 状态机_可用事件(sm) {
    定义 当前 = sm[0]
    定义 转移表 = sm[2]
    定义 可变 事件 = []
    定义 可变 i = 0
    当 (i < 计数(转移表)) {
        如果 (字符串等于(转移表[i][0], 当前)) {
            追加(事件, 转移表[i][1])
        }
        i = i + 1
    }
    返回 事件
}

函数 状态机_重置(sm, 状态) {
    sm[0] = 状态
    sm[3] = []
}

// 层次状态机 (HSM)

// HSM节点: [名称, 父状态, 子状态列表, 初始子状态]
函数 hsm_创建节点(名称, 父) {
    返回 [名称, 父, [], 空]
}

函数 hsm_添加子状态(父节点, 子名称) {
    定义 子 = hsm_创建节点(子名称, 父节点)
    追加(父节点[2], 子)
    如果 (父节点[3] == 空) { 父节点[3] = 子 }
    返回 子
}

// 并发状态机

函数 并发状态机_创建(状态机列表) {
    返回 [状态机列表]
}

函数 并发状态机_触发(csm, 事件) {
    定义 列表 = csm[0]
    定义 可变 任一成功 = 0
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (状态机_触发(列表[i], 事件) == 1) {
            任一成功 = 1
        }
        i = i + 1
    }
    返回 任一成功
}

函数 并发状态机_所有状态(csm) {
    定义 列表 = csm[0]
    定义 可变 状态 = []
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        追加(状态, 状态机_当前(列表[i]))
        i = i + 1
    }
    返回 状态
}

// 理论驱动新功能

函数 状态机_气韵复杂度(sm) {
    定义 历史 = sm[3]
    定义 可变 唯一 = []
    定义 可变 i = 0
    当 (i < 计数(历史)) {
        定义 可变 已有 = 0
        定义 可变 j = 0
        当 (j < 计数(唯一)) {
            如果 (唯一[j] == 历史[i]) { 已有 = 1 }
            j = j + 1
        }
        如果 (已有 == 0) { 追加(唯一, 历史[i]) }
        i = i + 1
    }
    返回 计数(唯一)
}

函数 状态机_阴阳转移率(sm) {
    定义 历史 = sm[3]
    定义 n = 计数(历史)
    如果 (n < 2) { 返回 0 }
    定义 可变 转移数 = 0
    定义 可变 i = 1
    当 (i < n) {
        如果 (历史[i] != 历史[i - 1]) { 转移数 = 转移数 + 1 }
        i = i + 1
    }
    返回 转移数 * 100 / (n - 1)
}

函数 状态机_停留分布(sm) {
    定义 历史 = sm[3]
    定义 可变 分布 = 字典()
    定义 可变 i = 0
    当 (i < 计数(历史)) {
        定义 现有 = 字典取(分布, 历史[i])
        如果 (现有 == 空) { 字典设(分布, 历史[i], 1) }
        否则 { 字典设(分布, 历史[i], 现有 + 1) }
        i = i + 1
    }
    返回 分布
}

// 守卫条件

定义 可变 _守卫_从 = []
定义 可变 _守卫_到 = []
定义 可变 _守卫_条件 = []

函数 守卫_注册(从状态, 到状态, 条件函数) {
    追加(_守卫_从, 从状态)
    追加(_守卫_到, 到状态)
    追加(_守卫_条件, 条件函数)
}

函数 守卫_允许(从状态, 到状态, 上下文) {
    定义 可变 i = 0
    当 (i < 计数(_守卫_从)) {
        如果 (_守卫_从[i] == 从状态 且 _守卫_到[i] == 到状态) {
            返回 _守卫_条件[i](上下文)
        }
        i = i + 1
    }
    返回 真  // 无守卫则放行
}

// 动作绑定

定义 可变 _进入动作_状态 = []
定义 可变 _进入动作_函数 = []
定义 可变 _离开动作_状态 = []
定义 可变 _离开动作_函数 = []

函数 动作_注册进入(状态, _动作函数) {
    追加(_进入动作_状态, 状态)
    追加(_进入动作_函数, _动作函数)
}

函数 动作_注册离开(状态, _动作函数) {
    追加(_离开动作_状态, 状态)
    追加(_离开动作_函数, _动作函数)
}

函数 动作_触发进入(状态, 上下文) {
    定义 可变 i = 0
    当 (i < 计数(_进入动作_状态)) {
        如果 (_进入动作_状态[i] == 状态) { _进入动作_函数[i](上下文) }
        i = i + 1
    }
}

函数 动作_触发离开(状态, 上下文) {
    定义 可变 i = 0
    当 (i < 计数(_离开动作_状态)) {
        如果 (_离开动作_状态[i] == 状态) { _离开动作_函数[i](上下文) }
        i = i + 1
    }
}

// 可达性分析

函数 状态机_可达(sm, 起始状态) {
    定义 转移 = sm[2]
    定义 可变 已访问 = [起始状态]
    定义 可变 队列 = [起始状态]
    当 (计数(队列) > 0) {
        定义 当前 = 队列[0]
        删除(队列)
        定义 可变 i = 0
        当 (i < 计数(转移)) {
            如果 (转移[i][0] == 当前) {
                定义 目标 = 转移[i][2]
                定义 可变 已有 = 假
                定义 可变 j = 0
                当 (j < 计数(已访问)) {
                    如果 (已访问[j] == 目标) { 已有 = 真 }
                    j = j + 1
                }
                如果 (!已有) {
                    追加(已访问, 目标)
                    追加(队列, 目标)
                }
            }
            i = i + 1
        }
    }
    返回 已访问
}

定义 可变 _状态机_转移数 = 0
定义 可变 _状态机_守卫拒绝数 = 0

函数 状态机_记录转移() { _状态机_转移数 = _状态机_转移数 + 1 }
函数 状态机_记录拒绝() { _状态机_守卫拒绝数 = _状态机_守卫拒绝数 + 1 }

导入("../中枢/类型定义.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/内核打印.nova")

函数 位图_创建(大小) {
    定义 字数 = (大小 + 63) / 64
    定义 数据 = []
    定义 可变 i = 0
    当 (i < 字数) { 追加(数据, 0); i = i + 1 }
    返回 [数据, 大小]
}

函数 位图_创建_从数组(数组, 大小) {
    如果 (数组 == 0) { 返回 位图_创建(大小) }
    返回 [数组, 大小]
}

函数 位图_设置(位图, 位) {
    如果 (位 < 0 || 位 >= 位图[1]) { 返回 }
    定义 w = 位 / 64
    定义 b = 位 % 64
    设置(位图[0], w, 位图[0][w] | (1 << b))
}

函数 位图_清除(位图, 位) {
    如果 (位 < 0 || 位 >= 位图[1]) { 返回 }
    定义 w = 位 / 64
    定义 b = 位 % 64
    设置(位图[0], w, 位图[0][w] & ~(1 << b))
}

函数 位图_测试(位图, 位) {
    如果 (位 < 0 || 位 >= 位图[1]) { 返回 0 }
    定义 w = 位 / 64
    定义 b = 位 % 64
    返回 (位图[0][w] >> b) & 1
}

函数 位图_翻转(位图, 位) {
    如果 (位 < 0 || 位 >= 位图[1]) { 返回 }
    定义 w = 位 / 64
    定义 b = 位 % 64
    设置(位图[0], w, 位图[0][w] ^ (1 << b))
}

函数 位图_范围设置(位图, 起始, 结束) {
    如果 (起始 < 0) { 起始 = 0 }
    如果 (结束 > 位图[1]) { 结束 = 位图[1] }
    定义 可变 i = 起始
    当 (i < 结束) {
        定义 w = i / 64
        定义 b = i % 64
        如果 (b == 0 && i + 64 <= 结束) {
            设置(位图[0], w, -1)
            i = i + 64
        } 否则 {
            设置(位图[0], w, 位图[0][w] | (1 << b))
            i = i + 1
        }
    }
}

函数 位图_范围清除(位图, 起始, 结束) {
    如果 (起始 < 0) { 起始 = 0 }
    如果 (结束 > 位图[1]) { 结束 = 位图[1] }
    定义 可变 i = 起始
    当 (i < 结束) {
        定义 w = i / 64
        定义 b = i % 64
        如果 (b == 0 && i + 64 <= 结束) {
            设置(位图[0], w, 0)
            i = i + 64
        } 否则 {
            设置(位图[0], w, 位图[0][w] & ~(1 << b))
            i = i + 1
        }
    }
}

函数 位图_范围测试全一(位图, 起始, 结束) {
    定义 可变 i = 起始
    当 (i < 结束) {
        如果 (位图_测试(位图, i) == 0) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 位图_范围测试全零(位图, 起始, 结束) {
    定义 可变 i = 起始
    当 (i < 结束) {
        如果 (位图_测试(位图, i) != 0) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 位图_找第一个零(位图) {
    定义 可变 wi = 0
    当 (wi < 计数(位图[0])) {
        如果 (位图[0][wi] != -1) {
            定义 可变 b = 0
            当 (b < 64) {
                定义 位 = wi * 64 + b
                如果 (位 >= 位图[1]) { 返回 0 - 1 }
                如果 ((位图[0][wi] >> b & 1) == 0) { 返回 位 }
                b = b + 1
            }
        }
        wi = wi + 1
    }
    返回 0 - 1
}

函数 位图_找第一个一(位图) {
    定义 可变 wi = 0
    当 (wi < 计数(位图[0])) {
        如果 (位图[0][wi] != 0) {
            定义 可变 b = 0
            当 (b < 64) {
                定义 位 = wi * 64 + b
                如果 (位 >= 位图[1]) { 返回 0 - 1 }
                如果 ((位图[0][wi] >> b & 1) == 1) { 返回 位 }
                b = b + 1
            }
        }
        wi = wi + 1
    }
    返回 0 - 1
}

函数 位图_找下一个零(位图, 从) {
    定义 可变 i = 从
    当 (i < 位图[1]) {
        如果 (位图_测试(位图, i) == 0) { 返回 i }
        i = i + 1
    }
    返回 0 - 1
}

函数 位图_找下一个一(位图, 从) {
    定义 可变 i = 从
    当 (i < 位图[1]) {
        如果 (位图_测试(位图, i) == 1) { 返回 i }
        i = i + 1
    }
    返回 0 - 1
}

函数 位图_popcount64(v) {
    定义 可变 x = v
    x = x - ((x >> 1) & 0x5555555555555555)
    x = (x & 0x3333333333333333) + ((x >> 2) & 0x3333333333333333)
    x = (x + (x >> 4)) & 0x0F0F0F0F0F0F0F0F
    返回 (x * 0x0101010101010101) >> 56
}

函数 位图_统计一(位图) {
    定义 可变 计数值 = 0
    定义 可变 i = 0
    当 (i < 计数(位图[0])) {
        计数值 = 计数值 + 位图_popcount64(位图[0][i])
        i = i + 1
    }
    返回 计数值
}

函数 位图_统计零(位图) { 返回 位图[1] - 位图_统计一(位图) }
函数 位图_大小(位图) { 返回 位图[1] }
函数 位图_为空(位图) { 返回 位图_统计一(位图) == 0 }
函数 位图_已满(位图) { 返回 位图_统计一(位图) == 位图[1] }

函数 位图_全部设置(位图) {
    定义 可变 i = 0
    当 (i < 计数(位图[0])) { 设置(位图[0], i, -1); i = i + 1 }
}

函数 位图_全部清除(位图) {
    定义 可变 i = 0
    当 (i < 计数(位图[0])) { 设置(位图[0], i, 0); i = i + 1 }
}

函数 位图_与(a, b) {
    定义 大小 = a[1]
    如果 (b[1] < 大小) { 大小 = b[1] }
    定义 结果 = 位图_创建(大小)
    定义 可变 i = 0
    当 (i < 计数(结果[0])) {
        设置(结果[0], i, a[0][i] & b[0][i])
        i = i + 1
    }
    返回 结果
}

函数 位图_或(a, b) {
    定义 大小 = a[1]
    如果 (b[1] > 大小) { 大小 = b[1] }
    定义 结果 = 位图_创建(大小)
    定义 可变 i = 0
    当 (i < 计数(结果[0])) {
        定义 va = 0
        定义 vb = 0
        如果 (i < 计数(a[0])) { va = a[0][i] }
        如果 (i < 计数(b[0])) { vb = b[0][i] }
        设置(结果[0], i, va | vb)
        i = i + 1
    }
    返回 结果
}

函数 位图_异或(a, b) {
    定义 大小 = a[1]
    如果 (b[1] > 大小) { 大小 = b[1] }
    定义 结果 = 位图_创建(大小)
    定义 可变 i = 0
    当 (i < 计数(结果[0])) {
        定义 va = 0
        定义 vb = 0
        如果 (i < 计数(a[0])) { va = a[0][i] }
        如果 (i < 计数(b[0])) { vb = b[0][i] }
        设置(结果[0], i, va ^ vb)
        i = i + 1
    }
    返回 结果
}

函数 位图_非(位图) {
    定义 结果 = 位图_创建(位图[1])
    定义 可变 i = 0
    当 (i < 计数(位图[0])) {
        设置(结果[0], i, ~位图[0][i])
        i = i + 1
    }
    返回 结果
}

函数 位图_相等(a, b) {
    如果 (a[1] != b[1]) { 返回 假 }
    定义 可变 i = 0
    当 (i < 计数(a[0])) {
        如果 (a[0][i] != b[0][i]) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 位图_子集(子, 父) {
    定义 可变 i = 0
    当 (i < 计数(子[0])) {
        如果 (i < 计数(父[0])) {
            如果 ((子[0][i] & ~父[0][i]) != 0) { 返回 假 }
        } 否则 {
            如果 (子[0][i] != 0) { 返回 假 }
        }
        i = i + 1
    }
    返回 真
}

函数 位图_找连续零(位图, 需要数) {
    定义 可变 起始 = -1
    定义 可变 连续 = 0
    定义 可变 i = 0
    当 (i < 位图[1]) {
        如果 (位图_测试(位图, i) == 0) {
            如果 (连续 == 0) { 起始 = i }
            连续 = 连续 + 1
            如果 (连续 >= 需要数) { 返回 起始 }
        } 否则 {
            连续 = 0
        }
        i = i + 1
    }
    返回 -1
}

函数 位图_找连续一(位图, 需要数) {
    定义 可变 起始 = -1
    定义 可变 连续 = 0
    定义 可变 i = 0
    当 (i < 位图[1]) {
        如果 (位图_测试(位图, i) == 1) {
            如果 (连续 == 0) { 起始 = i }
            连续 = 连续 + 1
            如果 (连续 >= 需要数) { 返回 起始 }
        } 否则 {
            连续 = 0
        }
        i = i + 1
    }
    返回 -1
}

函数 位图_复制(位图) {
    定义 结果 = 位图_创建(位图[1])
    定义 可变 i = 0
    当 (i < 计数(位图[0])) {
        设置(结果[0], i, 位图[0][i])
        i = i + 1
    }
    返回 结果
}

函数 位图_调整大小(位图, 新大小) {
    定义 新字数 = (新大小 + 63) / 64
    定义 旧字数 = 计数(位图[0])
    如果 (新字数 > 旧字数) {
        定义 可变 i = 旧字数
        当 (i < 新字数) { 追加(位图[0], 0); i = i + 1 }
    }
    位图[1] = 新大小
}

函数 位图_遍历一(位图, 回调) {
    定义 可变 i = 0
    当 (i < 位图[1]) {
        如果 (位图_测试(位图, i) == 1) { 回调(i) }
        i = i + 1
    }
}

函数 位图_转列表(位图) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 位图[1]) {
        如果 (位图_测试(位图, i) == 1) { 追加(结果, i) }
        i = i + 1
    }
    返回 结果
}

函数 位图_从列表(列表, 大小) {
    定义 位图 = 位图_创建(大小)
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        位图_设置(位图, 列表[i])
        i = i + 1
    }
    返回 位图
}

函数 位图_转字符串(位图) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 位图[1]) {
        如果 (位图_测试(位图, i) == 1) {
            结果 = 字符串拼接(结果, "1")
        } 否则 {
            结果 = 字符串拼接(结果, "0")
        }
        i = i + 1
    }
    返回 结果
}

// NBMS — Nova Bitmap Structure Theory
// 公理1(幂等性): n位位图与{0..n-1}子集一一对应
// 公理2(布尔封闭): 位图在与/或/异或/非操作下封闭
// 定理1(计数等价): popcount(A&B)+popcount(A|B)=popcount(A)+popcount(B)
// 定理2(O(1)随机访问): 任何位的读写均为常数时间

函数 位图_左移(位图, 位数) {
    定义 新大小 = 位图[1] + 位数
    定义 结果 = 位图_创建(新大小)
    定义 可变 i = 0
    当 (i < 位图[1]) {
        如果 (位图_测试(位图, i) == 1) {
            位图_设置(结果, i + 位数)
        }
        i = i + 1
    }
    返回 结果
}

函数 位图_右移(位图, 位数) {
    如果 (位数 >= 位图[1]) { 返回 位图_创建(位图[1]) }
    定义 结果 = 位图_创建(位图[1])
    定义 可变 i = 位数
    当 (i < 位图[1]) {
        如果 (位图_测试(位图, i) == 1) {
            位图_设置(结果, i - 位数)
        }
        i = i + 1
    }
    返回 结果
}

函数 位图_密度(位图) {
    如果 (位图[1] == 0) { 返回 0 }
    返回 位图_统计一(位图) * 1000 / 位图[1]
}

函数 位图_汉明距离(a, b) {
    定义 x = 位图_异或(a, b)
    返回 位图_统计一(x)
}

结构 位图统计 {
    创建次数,
    设置次数,
    清除次数,
    测试次数,
    运算次数,
}

定义 可变 全局_位图统计 = 空

函数 位图统计_初始化() {
    如果 (全局_位图统计 == 空) {
        全局_位图统计 = 位图统计 {}
        全局_位图统计.创建次数 = 0
        全局_位图统计.设置次数 = 0
        全局_位图统计.清除次数 = 0
        全局_位图统计.测试次数 = 0
        全局_位图统计.运算次数 = 0
    }
}

函数 位图_打印统计() {
    位图统计_初始化()
    打印行("=== NBMS位图统计 ===")
    打印行("创建: " + 整数转字符串(全局_位图统计.创建次数))
    打印行("设置: " + 整数转字符串(全局_位图统计.设置次数))
    打印行("清除: " + 整数转字符串(全局_位图统计.清除次数))
    打印行("测试: " + 整数转字符串(全局_位图统计.测试次数))
    打印行("运算: " + 整数转字符串(全局_位图统计.运算次数))
}

函数 位图_完整统计() {
    位图统计_初始化()
    返回 [全局_位图统计.创建次数, 全局_位图统计.设置次数,
           全局_位图统计.清除次数, 全局_位图统计.测试次数,
           全局_位图统计.运算次数]
}

函数 位图_重置统计() {
    如果 (全局_位图统计 != 空) {
        全局_位图统计.创建次数 = 0
        全局_位图统计.设置次数 = 0
        全局_位图统计.清除次数 = 0
        全局_位图统计.测试次数 = 0
        全局_位图统计.运算次数 = 0
    }
}

函数 位图_旋转左(位图, 位数) {
    定义 n = 位图[1]
    如果 (n == 0) { 返回 位图_复制(位图) }
    定义 实际 = 位数 % n
    定义 结果 = 位图_创建(n)
    定义 可变 i = 0
    当 (i < n) {
        定义 源 = (i - 实际 + n) % n
        如果 (位图_测试(位图, 源) == 1) { 位图_设置(结果, i) }
        i = i + 1
    }
    返回 结果
}

函数 位图_Jaccard相似度(位图A, 位图B) {
    定义 交 = 位图_统计一(位图_与(位图A, 位图B))
    定义 并 = 位图_统计一(位图_或(位图A, 位图B))
    如果 (并 == 0) { 返回 1000 }
    返回 交 * 1000 / 并
}

函数 位图_Hamming距离(位图A, 位图B) {
    返回 位图_统计一(位图_异或(位图A, 位图B))
}

// 游程编码 (RLE压缩)

函数 位图_游程编码(位图) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 位图[1]) {
        定义 当前值 = 位图_测试(位图, i)
        定义 可变 运行长 = 0
        当 (i < 位图[1] && 位图_测试(位图, i) == 当前值) {
            运行长 = 运行长 + 1
            i = i + 1
        }
        追加(结果, [当前值, 运行长])
    }
    返回 结果
}

函数 位图_游程解码(游程列表, 大小) {
    定义 位图 = 位图_创建(大小)
    定义 可变 位置 = 0
    定义 可变 r = 0
    当 (r < 计数(游程列表)) {
        定义 值 = 游程列表[r][0]
        定义 长 = 游程列表[r][1]
        如果 (值 == 1) {
            位图_范围设置(位图, 位置, 位置 + 长)
        }
        位置 = 位置 + 长
        r = r + 1
    }
    返回 位图
}

函数 位图_游程压缩比(位图) {
    定义 游程 = 位图_游程编码(位图)
    定义 原始字数 = 计数(位图[0])
    如果 (原始字数 == 0) { 返回 0 }
    返回 计数(游程) * 1000 / 原始字数
}

// 稀疏位图 (哈希表压缩 — 适合巨大范围低密度)
// 结构: [哈希表, 总大小, 设置位数]

函数 稀疏位图_创建(大小) {
    定义 桶数 = 64
    定义 可变 桶 = []
    定义 可变 i = 0
    当 (i < 桶数) { 追加(桶, []); i = i + 1 }
    返回 [桶, 大小, 0, 桶数]
}

函数 _稀疏位图_桶索引(稀疏, 位) {
    返回 位 % 稀疏[3]
}

函数 稀疏位图_设置(稀疏, 位) {
    如果 (位 < 0 || 位 >= 稀疏[1]) { 返回 }
    定义 bi = _稀疏位图_桶索引(稀疏, 位)
    // 检查是否已存在
    定义 可变 j = 0
    当 (j < 计数(稀疏[0][bi])) {
        如果 (稀疏[0][bi][j] == 位) { 返回 }
        j = j + 1
    }
    追加(稀疏[0][bi], 位)
    稀疏[2] = 稀疏[2] + 1
}

函数 稀疏位图_清除(稀疏, 位) {
    如果 (位 < 0 || 位 >= 稀疏[1]) { 返回 }
    定义 bi = _稀疏位图_桶索引(稀疏, 位)
    定义 可变 j = 0
    当 (j < 计数(稀疏[0][bi])) {
        如果 (稀疏[0][bi][j] == 位) {
            // 与末尾交换删除
            定义 末 = 计数(稀疏[0][bi]) - 1
            设置(稀疏[0][bi], j, 稀疏[0][bi][末])
            // 收缩列表
            稀疏[2] = 稀疏[2] - 1
            返回
        }
        j = j + 1
    }
}

函数 稀疏位图_测试(稀疏, 位) {
    如果 (位 < 0 || 位 >= 稀疏[1]) { 返回 0 }
    定义 bi = _稀疏位图_桶索引(稀疏, 位)
    定义 可变 j = 0
    当 (j < 计数(稀疏[0][bi])) {
        如果 (稀疏[0][bi][j] == 位) { 返回 1 }
        j = j + 1
    }
    返回 0
}

函数 稀疏位图_统计(稀疏) { 返回 稀疏[2] }

函数 稀疏位图_转密集(稀疏) {
    定义 位图 = 位图_创建(稀疏[1])
    定义 可变 b = 0
    当 (b < 稀疏[3]) {
        定义 可变 j = 0
        当 (j < 计数(稀疏[0][b])) {
            位图_设置(位图, 稀疏[0][b][j])
            j = j + 1
        }
        b = b + 1
    }
    返回 位图
}

// 位图迭代器
// 结构: [位图, 当前位置, 方向]

函数 位图迭代器_创建(位图) {
    返回 [位图, -1]
}

函数 位图迭代器_下一个(迭代器) {
    定义 位图 = 迭代器[0]
    定义 可变 位 = 迭代器[1] + 1
    当 (位 < 位图[1]) {
        如果 (位图_测试(位图, 位) == 1) {
            迭代器[1] = 位
            返回 位
        }
        位 = 位 + 1
    }
    迭代器[1] = 位图[1]
    返回 -1
}

函数 位图迭代器_重置(迭代器) {
    迭代器[1] = -1
}

函数 位图迭代器_有下一个(迭代器) {
    定义 位图 = 迭代器[0]
    定义 可变 位 = 迭代器[1] + 1
    当 (位 < 位图[1]) {
        如果 (位图_测试(位图, 位) == 1) { 返回 真 }
        位 = 位 + 1
    }
    返回 假
}

函数 位图迭代器_收集全部(位图) {
    定义 可变 结果 = []
    定义 迭代 = 位图迭代器_创建(位图)
    定义 可变 值 = 位图迭代器_下一个(迭代)
    当 (值 >= 0) {
        追加(结果, 值)
        值 = 位图迭代器_下一个(迭代)
    }
    返回 结果
}

// 【原生独创】谐振自适应位图
// 目标: 根据密度自动切换密集/稀疏表示
// 结构: [密集位图/稀疏位图, 大小, 当前模式, 密度阈值_千]
// 模式: 0=密集, 1=稀疏

定义 _谐振位图_密度阈值 = 100  // 10%以下用稀疏

函数 谐振位图_创建(大小) {
    // 默认密集模式
    返回 [位图_创建(大小), 大小, 0, _谐振位图_密度阈值]
}

函数 谐振位图_设置(谐振, 位) {
    如果 (谐振[2] == 0) {
        位图_设置(谐振[0], 位)
    } 否则 {
        稀疏位图_设置(谐振[0], 位)
    }
    谐振位图_检查切换(谐振)
}

函数 谐振位图_测试(谐振, 位) {
    如果 (谐振[2] == 0) {
        返回 位图_测试(谐振[0], 位)
    } 否则 {
        返回 稀疏位图_测试(谐振[0], 位)
    }
}

函数 谐振位图_检查切换(谐振) {
    定义 可变 当前密度 = 0
    如果 (谐振[2] == 0) {
        当前密度 = 位图_密度(谐振[0])
    } 否则 {
        如果 (谐振[1] > 0) {
            当前密度 = 稀疏位图_统计(谐振[0]) * 1000 / 谐振[1]
        }
    }
    // 密集→稀疏: 密度下降到阈值以下
    如果 (谐振[2] == 0 && 当前密度 < 谐振[3] / 2) {
        定义 新 = 稀疏位图_创建(谐振[1])
        定义 可变 i = 0
        当 (i < 谐振[1]) {
            如果 (位图_测试(谐振[0], i) == 1) {
                稀疏位图_设置(新, i)
            }
            i = i + 1
        }
        谐振[0] = 新
        谐振[2] = 1
    }
    // 稀疏→密集: 密度上升到阈值以上
    如果 (谐振[2] == 1 && 当前密度 > 谐振[3]) {
        谐振[0] = 稀疏位图_转密集(谐振[0])
        谐振[2] = 0
    }
}

函数 谐振位图_当前模式(谐振) {
    如果 (谐振[2] == 0) { 返回 "密集" }
    返回 "稀疏"
}

// 完整统计
函数 集合位图_完整统计() {
    返回 [
        "基础位操作", 6,
        "范围操作", 4,
        "布尔运算", 5,
        "搜索操作", 6,
        "密度与移位", 6,
        "游程编码RLE", 3,
        "稀疏位图", 6,
        "位图迭代器", 5,
        "原生独创_谐振自适应位图", 5
    ]
}

//    状态转移 = 阳(前向计算)
//    路径回溯 = 阴(逆向重建)

导入("../基础.nova")

定义 可变 dp_气韵统计 = [0, 0,]  // 木火土金水 各类DP调用次数

// 0-1 背包
函数 dp_01背包(容量, 物品) {
    // 物品: [[重量, 价值], ...]
    定义 n = 计数(物品)
    定义 可变 dp = []
    定义 可变 i = 0
    当 (i <= 容量) { 追加(dp, 0) i = i + 1 }
    i = 0
    当 (i < n) {
        定义 物 = 物品[i]
        定义 w = 物[0]
        定义 v = 物[1]
        定义 可变 j = 容量
        当 (j >= w) {
            定义 新值 = dp[j - w] + v
            如果 (新值 > dp[j]) { dp[j] = 新值 }
            j = j - 1
        }
        i = i + 1
    }
    返回 dp[容量]
}

// 完全背包
函数 dp_完全背包(容量, 物品) {
    定义 n = 计数(物品)
    定义 可变 dp = []
    定义 可变 i = 0
    当 (i <= 容量) { 追加(dp, 0) i = i + 1 }
    i = 0
    当 (i < n) {
        定义 物 = 物品[i]
        定义 w = 物[0]
        定义 v = 物[1]
        定义 可变 j = w
        当 (j <= 容量) {
            定义 新值 = dp[j - w] + v
            如果 (新值 > dp[j]) { dp[j] = 新值 }
            j = j + 1
        }
        i = i + 1
    }
    返回 dp[容量]
}

// 最长公共子序列
函数 动规_最长公共子序列(a, b) {
    定义 m = 字节长度(a)
    定义 n = 字节长度(b)
    定义 可变 dp = []
    定义 可变 i = 0
    当 (i <= m) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j <= n) { 追加(行, 0) j = j + 1 }
        追加(dp, 行)
        i = i + 1
    }
    i = 1
    当 (i <= m) {
        定义 可变 j = 1
        定义 行i = dp[i]
        定义 行p = dp[i - 1]
        当 (j <= n) {
            如果 (字节取(a, i - 1) == 字节取(b, j - 1)) {
                行i[j] = 行p[j - 1] + 1
            } 否则 {
                定义 上 = 行p[j]
                定义 左 = 行i[j - 1]
                如果 (上 > 左) { 行i[j] = 上 }
                否则 { 行i[j] = 左 }
            }
            j = j + 1
        }
        i = i + 1
    }
    定义 最后行 = dp[m]
    返回 最后行[n]
}

// 最长递增子序列
函数 动规_最长递增子序列(序列) {
    定义 n = 计数(序列)
    如果 (n == 0) { 返回 0 }
    定义 可变 dp = []
    定义 可变 i = 0
    当 (i < n) { 追加(dp, 1) i = i + 1 }
    定义 可变 最大 = 1
    i = 1
    当 (i < n) {
        定义 可变 j = 0
        当 (j < i) {
            如果 (序列[j] < 序列[i] 且 dp[j] + 1 > dp[i]) {
                dp[i] = dp[j] + 1
            }
            j = j + 1
        }
        如果 (dp[i] > 最大) { 最大 = dp[i] }
        i = i + 1
    }
    返回 最大
}

// 编辑距离
函数 dp_编辑距离(a, b) {
    定义 m = 字节长度(a)
    定义 n = 字节长度(b)
    定义 可变 dp = []
    定义 可变 i = 0
    当 (i <= m) {
        定义 可变 行 = []
        定义 可变 j = 0
        当 (j <= n) { 追加(行, 0) j = j + 1 }
        追加(dp, 行)
        i = i + 1
    }
    // 初始化
    i = 0
    当 (i <= m) { dp[i][0] = i i = i + 1 }
    定义 可变 j2 = 0
    定义 行0 = dp[0]
    当 (j2 <= n) { 行0[j2] = j2 j2 = j2 + 1 }
    i = 1
    当 (i <= m) {
        定义 可变 j = 1
        定义 行i = dp[i]
        定义 行p = dp[i - 1]
        当 (j <= n) {
            如果 (字节取(a, i - 1) == 字节取(b, j - 1)) {
                行i[j] = 行p[j - 1]
            } 否则 {
                定义 替 = 行p[j - 1] + 1
                定义 删 = 行p[j] + 1
                定义 插 = 行i[j - 1] + 1
                定义 可变 最小 = 替
                如果 (删 < 最小) { 最小 = 删 }
                如果 (插 < 最小) { 最小 = 插 }
                行i[j] = 最小
            }
            j = j + 1
        }
        i = i + 1
    }
    定义 结果行 = dp[m]
    返回 结果行[n]
}

// 硬币找零
函数 dp_硬币找零(硬币, 金额) {
    定义 可变 dp = []
    定义 可变 i = 0
    当 (i <= 金额) { 追加(dp, 金额 + 1) i = i + 1 }
    dp[0] = 0
    i = 1
    当 (i <= 金额) {
        定义 可变 j = 0
        当 (j < 计数(硬币)) {
            如果 (硬币[j] <= i 且 dp[i - 硬币[j]] + 1 < dp[i]) {
                dp[i] = dp[i - 硬币[j]] + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    如果 (dp[金额] > 金额) { 返回 -1 }
    返回 dp[金额]
}

// 最大子数组和 (Kadane)
函数 dp_最大子数组和(数组) {
    如果 (计数(数组) == 0) { 返回 0 }
    定义 可变 当前和 = 数组[0]
    定义 可变 最大和 = 数组[0]
    定义 可变 i = 1
    当 (i < 计数(数组)) {
        如果 (当前和 + 数组[i] > 数组[i]) {
            当前和 = 当前和 + 数组[i]
        } 否则 {
            当前和 = 数组[i]
        }
        如果 (当前和 > 最大和) { 最大和 = 当前和 }
        i = i + 1
    }
    返回 最大和
}

// 爬楼梯 (n种方式到第n阶)
函数 dp_爬楼梯(n) {
    如果 (n <= 2) { 返回 n }
    定义 可变 a = 1
    定义 可变 b = 2
    定义 可变 i = 3
    当 (i <= n) {
        定义 c = a + b
        a = b
        b = c
        i = i + 1
    }
    返回 b
}

// 打家劫舍
函数 dp_打家劫舍(房屋) {
    定义 n = 计数(房屋)
    如果 (n == 0) { 返回 0 }
    如果 (n == 1) { 返回 房屋[0] }
    定义 可变 prev2 = 房屋[0]
    定义 可变 prev1 = 房屋[0]
    如果 (房屋[1] > prev1) { prev1 = 房屋[1] }
    定义 可变 i = 2
    当 (i < n) {
        定义 可变 当前 = prev1
        如果 (prev2 + 房屋[i] > 当前) { 当前 = prev2 + 房屋[i] }
        prev2 = prev1
        prev1 = 当前
        i = i + 1
    }
    返回 prev1
}

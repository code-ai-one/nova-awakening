导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./内核直连层.nova")
导入("../中枢/内存初始化.nova")

定义 滤镜_模糊 = 0
定义 滤镜_亮度 = 1
定义 滤镜_对比 = 2
定义 滤镜_饱和 = 3
定义 滤镜_色调旋转 = 4
定义 滤镜_反色 = 5
定义 滤镜_灰度 = 6
定义 滤镜_褐色 = 7
定义 滤镜_阴影 = 8
定义 混合_正常 = 0
定义 混合_正片叠底 = 1
定义 混合_滤色 = 2
定义 混合_叠加 = 3
定义 混合_变暗 = 4
定义 混合_变亮 = 5
定义 最大滤镜链 = 8
定义 基数 = 1024

结构 滤镜项 {
    类型,
    参数值,
}

定义 可变 应用总数 = 0


函数 滤镜_应用亮度(像素, 系数) {
    定义 红 = (像素 >> 16) & 0xFF
    定义 绿 = (像素 >> 8) & 0xFF
    定义 蓝 = 像素 & 0xFF
    定义 透明 = (像素 >> 24) & 0xFF
    红 = 红 * 系数 / 基数
    绿 = 绿 * 系数 / 基数
    蓝 = 蓝 * 系数 / 基数
    如果 (红 > 255) { 红 = 255 }
    如果 (绿 > 255) { 绿 = 255 }
    如果 (蓝 > 255) { 蓝 = 255 }
    返回 (透明 << 24) | (红 << 16) | (绿 << 8) | 蓝
}

函数 滤镜_应用对比(像素, 系数) {
    定义 红 = (像素 >> 16) & 0xFF
    定义 绿 = (像素 >> 8) & 0xFF
    定义 蓝 = 像素 & 0xFF
    定义 透明 = (像素 >> 24) & 0xFF
    红 = ((红 - 128) * 系数 / 基数) + 128
    绿 = ((绿 - 128) * 系数 / 基数) + 128
    蓝 = ((蓝 - 128) * 系数 / 基数) + 128
    如果 (红 < 0) { 红 = 0 } 如果 (红 > 255) { 红 = 255 }
    如果 (绿 < 0) { 绿 = 0 } 如果 (绿 > 255) { 绿 = 255 }
    如果 (蓝 < 0) { 蓝 = 0 } 如果 (蓝 > 255) { 蓝 = 255 }
    返回 (透明 << 24) | (红 << 16) | (绿 << 8) | 蓝
}

函数 滤镜_应用饱和(像素, 系数) {
    定义 红 = (像素 >> 16) & 0xFF
    定义 绿 = (像素 >> 8) & 0xFF
    定义 蓝 = 像素 & 0xFF
    定义 透明 = (像素 >> 24) & 0xFF
    定义 灰 = (红 * 77 + 绿 * 150 + 蓝 * 29) >> 8
    红 = 灰 + (红 - 灰) * 系数 / 基数
    绿 = 灰 + (绿 - 灰) * 系数 / 基数
    蓝 = 灰 + (蓝 - 灰) * 系数 / 基数
    如果 (红 < 0) { 红 = 0 } 如果 (红 > 255) { 红 = 255 }
    如果 (绿 < 0) { 绿 = 0 } 如果 (绿 > 255) { 绿 = 255 }
    如果 (蓝 < 0) { 蓝 = 0 } 如果 (蓝 > 255) { 蓝 = 255 }
    返回 (透明 << 24) | (红 << 16) | (绿 << 8) | 蓝
}

函数 滤镜_应用灰度(像素, 系数) {
    定义 红 = (像素 >> 16) & 0xFF
    定义 绿 = (像素 >> 8) & 0xFF
    定义 蓝 = 像素 & 0xFF
    定义 透明 = (像素 >> 24) & 0xFF
    定义 灰 = (红 * 77 + 绿 * 150 + 蓝 * 29) >> 8
    红 = 红 + (灰 - 红) * 系数 / 基数
    绿 = 绿 + (灰 - 绿) * 系数 / 基数
    蓝 = 蓝 + (灰 - 蓝) * 系数 / 基数
    返回 (透明 << 24) | (红 << 16) | (绿 << 8) | 蓝
}

函数 滤镜_应用反色(像素, 系数) {
    定义 红 = (像素 >> 16) & 0xFF
    定义 绿 = (像素 >> 8) & 0xFF
    定义 蓝 = 像素 & 0xFF
    定义 透明 = (像素 >> 24) & 0xFF
    红 = 红 + (255 - 红 * 2) * 系数 / 基数
    绿 = 绿 + (255 - 绿 * 2) * 系数 / 基数
    蓝 = 蓝 + (255 - 蓝 * 2) * 系数 / 基数
    如果 (红 < 0) { 红 = 0 } 如果 (红 > 255) { 红 = 255 }
    如果 (绿 < 0) { 绿 = 0 } 如果 (绿 > 255) { 绿 = 255 }
    如果 (蓝 < 0) { 蓝 = 0 } 如果 (蓝 > 255) { 蓝 = 255 }
    返回 (透明 << 24) | (红 << 16) | (绿 << 8) | 蓝
}

函数 滤镜_应用链(像素, 滤镜链, 链长) {
    应用总数 = 应用总数 + 1
    定义 可变 当前像素 = 像素
    定义 可变 序号 = 0
    当 (序号 < 链长 && 序号 < 最大滤镜链) {
        定义 类型 = 内存_读32(滤镜链 + 序号 * 8)
        定义 参数 = 内存_读32(滤镜链 + 序号 * 8 + 4)
        如果 (类型 == 滤镜_亮度) { 当前像素 = 滤镜_应用亮度(当前像素, 参数) }
        否则 如果 (类型 == 滤镜_对比) { 当前像素 = 滤镜_应用对比(当前像素, 参数) }
        否则 如果 (类型 == 滤镜_饱和) { 当前像素 = 滤镜_应用饱和(当前像素, 参数) }
        否则 如果 (类型 == 滤镜_灰度) { 当前像素 = 滤镜_应用灰度(当前像素, 参数) }
        否则 如果 (类型 == 滤镜_反色) { 当前像素 = 滤镜_应用反色(当前像素, 参数) }
        序号 = 序号 + 1
    }
    返回 当前像素
}

函数 混合_合成(底层, 顶层, 模式) {
    定义 底红 = (底层 >> 16) & 0xFF
    定义 底绿 = (底层 >> 8) & 0xFF
    定义 底蓝 = 底层 & 0xFF
    定义 顶红 = (顶层 >> 16) & 0xFF
    定义 顶绿 = (顶层 >> 8) & 0xFF
    定义 顶蓝 = 顶层 & 0xFF
    定义 可变 结红 = 顶红
    定义 可变 结绿 = 顶绿
    定义 可变 结蓝 = 顶蓝
    如果 (模式 == 混合_正片叠底) {
        结红 = 底红 * 顶红 / 255
        结绿 = 底绿 * 顶绿 / 255
        结蓝 = 底蓝 * 顶蓝 / 255
    } 否则 如果 (模式 == 混合_滤色) {
        结红 = 255 - (255 - 底红) * (255 - 顶红) / 255
        结绿 = 255 - (255 - 底绿) * (255 - 顶绿) / 255
        结蓝 = 255 - (255 - 底蓝) * (255 - 顶蓝) / 255
    } 否则 如果 (模式 == 混合_变暗) {
        如果 (底红 < 顶红) { 结红 = 底红 } 否则 { 结红 = 顶红 }
        如果 (底绿 < 顶绿) { 结绿 = 底绿 } 否则 { 结绿 = 顶绿 }
        如果 (底蓝 < 顶蓝) { 结蓝 = 底蓝 } 否则 { 结蓝 = 顶蓝 }
    } 否则 如果 (模式 == 混合_变亮) {
        如果 (底红 > 顶红) { 结红 = 底红 } 否则 { 结红 = 顶红 }
        如果 (底绿 > 顶绿) { 结绿 = 底绿 } 否则 { 结绿 = 顶绿 }
        如果 (底蓝 > 顶蓝) { 结蓝 = 底蓝 } 否则 { 结蓝 = 顶蓝 }
    }
    返回 (255 << 24) | (结红 << 16) | (结绿 << 8) | 结蓝
}

函数 滤镜_应用到区域(数据, 宽, 高, 滤镜链, 链长) {
    定义 像素数 = 宽 * 高
    定义 可变 序号 = 0
    当 (序号 < 像素数) {
        定义 像素 = 内存_读32(数据 + 序号 * 4)
        定义 结果 = 滤镜_应用链(像素, 滤镜链, 链长)
        内存_写32(数据 + 序号 * 4, 结果)
        序号 = 序号 + 1
    }
}

函数 滤镜混合_完整统计() {
    返回 [应用总数]
}

// NovaOS Mixture of Experts (MoE) — 稀疏激活混合专家模型
// 论文: Fedus et al. "Switch Nova注意力架构s" (2022)
//       Jiang et al. "Mixtral of Experts" (2024)
// 核心: 每个令牌只激活Top-K个专家(通常K=2), 总参数量大但计算量小
//   - 门控网络(Router)决定激活哪些专家
//   - 负载均衡损失防止专家坍缩
//   - Expert Parallelism跨图处分布专家

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("./智能总线鼠标.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/新系统张量乙.nova")
导入("../标准/数学幂根对数.nova")

定义 MOE_默认专家数 = 8
定义 MOE_默认TopK = 2
定义 MOE_负载均衡系数 = 0.01
定义 MOE_容量因子 = 1.25       // 每个专家处理的令牌上限 = 容量因子 * N/E
定义 MOE_噪声系数 = 1.0        // 门控噪声(训练时)
定义 MOE_辅助损失_重要性 = 0.01

// MoE层结构

结构 MoE层 {
    专家数,
    topk,
    隐藏维度,
    中间维度,
    门控权重,    // u64 [隐藏维度, 专家数] 路由矩阵
    专家列表,    // u64 专家FFN数组
    负载计数,    // u64 每个专家处理的令牌计数
    是训练,
}

函数 MoE层_创建(隐藏维度, 中间维度, 专家数, topk) {
    定义 可变 层 = MoE层 {}
    层.专家数 = 专家数
    层.topk = topk
    层.隐藏维度 = 隐藏维度
    层.中间维度 = 中间维度
    层.门控权重 = 张量_随机正态(隐藏维度, 专家数, 0.0, 0.02)
    层.负载计数 = 张量_零(专家数)
    层.是训练 = 真

    // 创建每个专家(独立的FFN)
    层.专家列表 = 数组_创建(专家数)
    定义 可变 i = 0
    当 (i < 专家数) {
        定义 专家 = FFN_创建_SwiGLU(隐藏维度, 中间维度)
        数组_设置(层.专家列表, i, 专家)
        i = i + 1
    }

    返回 层
}

// MoE前向传播 — Top-K路由 + 稀疏激活

函数 MoE层_前向(层, 输入) {
    // 输入: [B, N, D]
    定义 B = 输入.批大小
    定义 N = 输入.序列长度
    定义 D = 层.隐藏维度
    定义 总令牌s = B * N

    // 1. 门控路由: logits = x @ W_gate
    定义 路由logits = 矩阵乘(输入, 层.门控权重)    // [总令牌s, 专家数]

    // 训练时加入噪声(提升探索)
    如果 (层.是训练) {
        定义 噪声 = 张量_随机正态同形(路由logits)
        路由logits = 张量_加(路由logits, 张量_标量乘(噪声, MOE_噪声系数))
    }

    // 2. Top-K选择
    定义 选择结果 = 张量_topk(路由logits, 层.topk)    // [总令牌s, topk]
    定义 选中索引 = 选择结果.索引
    定义 选中logits = 选择结果.值

    // 3. Nova归一化指数归一化门控权重(仅在选中的专家间)
    定义 门控权重 = 张量_Nova归一化指数(选中logits, -1)      // [总令牌s, topk]

    // 4. 分发到各专家并计算
    定义 可变 输出 = 张量_零同形(输入)

    定义 可变 k = 0
    当 (k < 层.topk) {
        定义 可变 t = 0
        当 (t < 总令牌s) {
            定义 专家idx = 张量_取整数(选中索引, t, k)
            定义 权重 = 张量_取浮点(门控权重, t, k)
            定义 令牌向量 = 张量_取行(输入, t)

            // 调用对应专家FFN
            定义 专家 = 数组_取(层.专家列表, 专家idx)
            定义 专家输出 = FFN_前向(专家, 令牌向量)

            // 加权累加
            张量_累加行(输出, t, 张量_标量乘(专家输出, 权重))

            // 统计负载
            张量_累加(层.负载计数, 专家idx, 1.0)

            t = t + 1
        }
        k = k + 1
    }

    返回 输出
}

// 负载均衡辅助损失 (Switch Nova注意力架构式)
// 防止所有令牌都路由到少数专家(专家坍缩)

函数 MoE_负载均衡损失(层, 路由logits) {
    定义 E = 层.专家数
    定义 N = 路由logits.行数

    // f_i = 分配给专家i的令牌比例
    定义 可变 f = 张量_零(E)
    定义 可变 P = 张量_Nova归一化指数_列(路由logits)    // 每个令牌对每个专家的概率

    // 计算每个专家的平均路由概率
    定义 P_均值 = 张量_列均值(P)                  // [E]

    // 计算每个专家被选中的比例
    定义 选择结果 = 张量_topk(路由logits, 层.topk)
    定义 可变 i = 0
    当 (i < N) {
        定义 可变 k = 0
        当 (k < 层.topk) {
            定义 idx = 张量_取整数(选择结果.索引, i, k)
            张量_累加(f, idx, 1.0 / N)
            k = k + 1
        }
        i = i + 1
    }

    // 辅助损失 = α * E * Σ(f_i * P_i)
    // 当所有专家负载均匀时,此损失最小
    定义 损失 = MOE_辅助损失_重要性 * E * 张量_点积(f, P_均值)
    返回 损失
}

// Expert Choice路由 (Zhou et al. 2022)
// 由专家选择令牌而非令牌选择专家, 保证完美负载均衡

函数 MoE_ExpertChoice_前向(层, 输入) {
    定义 N = 输入.行数
    定义 E = 层.专家数
    定义 容量 = (N * MOE_容量因子) / E

    定义 分数 = 矩阵乘(输入, 层.门控权重)
    定义 分数_转置 = 张量_转置(分数)

    定义 可变 输出 = 张量_零同形(输入)

    定义 可变 e = 0
    当 (e < E) {
        定义 专家分数 = 张量_取行(分数_转置, e)
        定义 选中 = 张量_topk_1d(专家分数, 容量)
        定义 专家 = 数组_取(层.专家列表, e)

        定义 可变 c = 0
        当 (c < 容量) {
            定义 令牌_idx = 张量_取整数_1d(选中.索引, c)
            定义 权重 = 张量_Nova归一化指数_1d_取(专家分数, 令牌_idx)
            定义 令牌向量 = 张量_取行(输入, 令牌_idx)
            定义 专家输出 = FFN_前向(专家, 令牌向量)
            张量_累加行(输出, 令牌_idx, 张量_标量乘(专家输出, 权重))
            c = c + 1
        }
        e = e + 1
    }

    返回 输出
}

// §4 SwiGLU FFN — MoE内每个专家使用的前馈网络

结构 FFN_SwiGLU {
    W_gate,           // [隐藏维度, 中间维度]
    W_up,             // [隐藏维度, 中间维度]
    W_down,           // [中间维度, 隐藏维度]
    隐藏维度,
    中间维度,
}

函数 FFN_创建_SwiGLU(隐藏维度, 中间维度) {
    定义 ffn = FFN_SwiGLU {}
    ffn.W_gate = 张量_随机正态(隐藏维度, 中间维度, 0.0, 0.02)
    ffn.W_up = 张量_随机正态(隐藏维度, 中间维度, 0.0, 0.02)
    ffn.W_down = 张量_随机正态(中间维度, 隐藏维度, 0.0, 0.02)
    ffn.隐藏维度 = 隐藏维度
    ffn.中间维度 = 中间维度
    返回 ffn
}

函数 FFN_前向(ffn, x) {
    如果 (ffn == 0 || x == 0) { 返回 空 }
    定义 gate = 矩阵乘(x, ffn.W_gate)
    定义 up = 矩阵乘(x, ffn.W_up)
    // SwiGLU: silu(gate) * up
    定义 gate_激活 = 向量_silu(gate)
    定义 中间 = 张量_逐元素乘(gate_激活, up)
    返回 矩阵乘(中间, ffn.W_down)
}

函数 FFN_销毁(ffn) {
    如果 (ffn == 0) { 返回 }
    如果 (ffn.W_gate != 0) { 张量_释放(ffn.W_gate) }
    如果 (ffn.W_up != 0) { 张量_释放(ffn.W_up) }
    如果 (ffn.W_down != 0) { 张量_释放(ffn.W_down) }
}

函数 向量_silu(x) {
    如果 (x == 0) { 返回 空 }
    定义 N = x.长度
    定义 可变 结果 = 张量_零(N)
    定义 可变 i = 0
    当 (i < N) {
        定义 val = 张量_取(x, i)
        定义 sigmoid = 1.0 / (1.0 + 数学_exp(0.0 - val))
        张量_设(结果, i, val * sigmoid)
        i = i + 1
    }
    返回 结果
}

// §5 MoE层销毁与重置

函数 MoE层_销毁(层) {
    如果 (层 == 0) { 返回 }
    // 销毁所有专家
    定义 可变 i = 0
    当 (i < 层.专家数) {
        FFN_销毁(数组_取(层.专家列表, i))
        i = i + 1
    }
    如果 (层.门控权重 != 0) { 张量_释放(层.门控权重) }
    如果 (层.负载计数 != 0) { 张量_释放(层.负载计数) }
}

函数 MoE层_重置负载(层) {
    如果 (层 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 层.专家数) {
        张量_设(层.负载计数, i, 0.0)
        i = i + 1
    }
}

// §6 MoE统计与监控

结构 MoE统计 {
    总前向次数,
    总令牌处理数,
    总专家调用次数,
    专家负载方差,     // Q10 越小越均衡
    最热专家ID,
    最冷专家ID,
    最热专家负载,
    最冷专家负载,
    平均路由熵,       // Q10 越高越分散
    辅助损失累计,     // Q10
    负载均衡损失历史, // 最近N步损失
    历史长度,
    总推理耗时,       // u64 微秒
    路由耗时,         // u64 微秒
    专家计算耗时,     // u64 微秒
    丢弃令牌数,       // u64 超出容量被丢弃
}

定义 可变 全局MoE统计 = 0

函数 MoE统计_初始化() {
    定义 s = MoE统计 {}
    s.总前向次数 = 0
    s.总令牌处理数 = 0
    s.总专家调用次数 = 0
    s.专家负载方差 = 0
    s.最热专家ID = 0
    s.最冷专家ID = 0
    s.最热专家负载 = 0
    s.最冷专家负载 = 999999
    s.平均路由熵 = 0
    s.辅助损失累计 = 0
    s.负载均衡损失历史 = []
    s.历史长度 = 0
    s.总推理耗时 = 0
    s.路由耗时 = 0
    s.专家计算耗时 = 0
    s.丢弃令牌数 = 0
    全局MoE统计 = s
    返回 s
}

函数 MoE统计_更新负载(层) {
    如果 (全局MoE统计 == 0) { MoE统计_初始化() }
    如果 (层 == 0) { 返回 }
    定义 s = 全局MoE统计

    // 找最热和最冷专家
    定义 可变 最大 = 0
    定义 可变 最小 = 999999
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < 层.专家数) {
        定义 负载 = 张量_取(层.负载计数, i)
        总和 = 总和 + 负载
        如果 (负载 > 最大) {
            最大 = 负载
            s.最热专家ID = i
        }
        如果 (负载 < 最小) {
            最小 = 负载
            s.最冷专家ID = i
        }
        i = i + 1
    }
    s.最热专家负载 = 最大
    s.最冷专家负载 = 最小

    // 计算方差
    定义 均值 = 总和 / 层.专家数
    定义 可变 方差和 = 0
    i = 0
    当 (i < 层.专家数) {
        定义 差 = 张量_取(层.负载计数, i) - 均值
        方差和 = 方差和 + 差 * 差
        i = i + 1
    }
    s.专家负载方差 = (方差和 * 1024) / 层.专家数
}

函数 MoE统计_打印() {
    如果 (全局MoE统计 == 0) {
        打印("[MoE] 统计未初始化")
        返回
    }
    定义 s = 全局MoE统计
    打印("[MoE] ═══ 混合专家统计 ═══")
    打印(字符串拼接("  总前向次数: ", 转字符串(s.总前向次数)))
    打印(字符串拼接("  总令牌处理数: ", 转字符串(s.总令牌处理数)))
    打印(字符串拼接("  总专家调用次数: ", 转字符串(s.总专家调用次数)))
    打印(字符串拼接("  最热专家: #", 字符串拼接(转字符串(s.最热专家ID), 字符串拼接(" 负载=", 转字符串(s.最热专家负载)))))
    打印(字符串拼接("  最冷专家: #", 字符串拼接(转字符串(s.最冷专家ID), 字符串拼接(" 负载=", 转字符串(s.最冷专家负载)))))
    打印(字符串拼接("  负载方差(Q10): ", 转字符串(s.专家负载方差)))
    打印(字符串拼接("  丢弃令牌数: ", 转字符串(s.丢弃令牌数)))
    打印(字符串拼接("  辅助损失累计: ", 转字符串(s.辅助损失累计)))
    打印(字符串拼接("  总耗时: ", 字符串拼接(转字符串(s.总推理耗时), "μs")))
    打印("[MoE] ═══════════════════════")
}

// §7 AI自适应专家数 — NovaOS独创
// 根据输入复杂度动态调整激活的专家数

函数 MoE_AI自适应TopK(bus, 输入嵌入, 默认topk) {
    如果 (bus == 0) { 返回 默认topk }

    // AI判断输入复杂度
    定义 复杂度 = AI总线_语义分类(bus, 输入嵌入)

    // 高复杂度: 激活更多专家(更好质量)
    如果 (复杂度 > 800) {
        返回 最小值(默认topk + 2, 4)
    }
    // 低复杂度: 只激活1个专家(更快速度)
    如果 (复杂度 < 200) {
        返回 1
    }
    返回 默认topk
}

函数 MoE_AI自适应容量(bus, 默认容量因子) {
    如果 (bus == 0) { 返回 默认容量因子 }

    // 低GPU负载: 增加容量(减少丢弃)
    如果 (bus.图处负载 < 50) {
        返回 默认容量因子 + 50
    }
    // 高GPU负载: 减少容量(保证延迟)
    如果 (bus.图处负载 > 80) {
        返回 默认容量因子 - 25
        如果 (默认容量因子 - 25 < 100) { 返回 100 }
    }
    返回 默认容量因子
}

// §8 专家并行通信模拟 — 多GPU分布式

定义 最大GPU数 = 8

结构 专家并行上下文 {
    GPU数量,
    本地专家起始,
    本地专家结束,
    通信缓冲,           // 全收集缓冲区
    发送计数,
    接收计数,
}

函数 专家并行_创建(GPU数量, 总专家数) {
    定义 ctx = 专家并行上下文 {}
    ctx.GPU数量 = GPU数量
    定义 每GPU专家 = 总专家数 / GPU数量
    ctx.本地专家起始 = 0
    ctx.本地专家结束 = 每GPU专家
    ctx.通信缓冲 = []
    ctx.发送计数 = 0
    ctx.接收计数 = 0
    返回 ctx
}

函数 专家并行_全到全(ctx, 本地令牌, 目标专家列表) {
    如果 (ctx == 0) { 返回 本地令牌 }
    // 模拟All-to-All通信: 将令牌发送到拥有对应专家的GPU
    定义 可变 发送列表 = []
    定义 可变 i = 0
    当 (i < 计数(本地令牌)) {
        定义 目标GPU = 目标专家列表[i] / ((ctx.本地专家结束 - ctx.本地专家起始))
        如果 (目标GPU >= ctx.GPU数量) { 目标GPU = ctx.GPU数量 - 1 }
        追加(发送列表, 目标GPU)
        ctx.发送计数 = ctx.发送计数 + 1
        i = i + 1
    }
    ctx.接收计数 = ctx.接收计数 + 计数(本地令牌)
    返回 本地令牌
}

函数 专家并行_销毁(ctx) {
    如果 (ctx == 0) { 返回 }
    ctx.通信缓冲 = []
    ctx.发送计数 = 0
    ctx.接收计数 = 0
}

函数 专家并行_打印统计(ctx) {
    如果 (ctx == 0) {
        打印("[专家并行] 上下文未初始化")
        返回
    }
    打印("[专家并行] ═══ 通信统计 ═══")
    打印(字符串拼接("  GPU数量: ", 转字符串(ctx.GPU数量)))
    打印(字符串拼接("  本地专家范围: [", 字符串拼接(转字符串(ctx.本地专家起始), 字符串拼接(", ", 字符串拼接(转字符串(ctx.本地专家结束), ")")))))
    打印(字符串拼接("  发送令牌数: ", 转字符串(ctx.发送计数)))
    打印(字符串拼接("  接收令牌数: ", 转字符串(ctx.接收计数)))
    打印("[专家并行] ═══════════════════")
}

// §9 辅助损失计算 — 负载均衡正则化

函数 MoE_计算辅助损失(层, 路由概率) {
    如果 (层 == 0 || 路由概率 == 0) { 返回 0 }
    定义 N = 路由概率.行数
    定义 E = 层.专家数

    // f_i = 每个专家被选中的令牌比例
    // P_i = 每个专家的平均路由概率
    // 辅助损失 = E * sum(f_i * P_i)
    定义 可变 损失 = 0
    定义 可变 e = 0
    当 (e < E) {
        定义 选中比例 = 张量_取(层.负载计数, e) / N
        // 计算该专家的平均路由概率
        定义 可变 概率和 = 0
        定义 可变 i = 0
        当 (i < N) {
            概率和 = 概率和 + 张量_取(路由概率, i * E + e)
            i = i + 1
        }
        定义 平均概率 = 概率和 / N
        损失 = 损失 + 选中比例 * 平均概率
        e = e + 1
    }
    损失 = 损失 * E

    如果 (全局MoE统计 != 0) {
        全局MoE统计.辅助损失累计 = 全局MoE统计.辅助损失累计 + (损失 * 1024)
    }
    返回 损失
}

函数 MoE_计算路由熵(路由概率, N, E) {
    // 路由熵: 衡量路由决策的分散程度
    定义 可变 总熵 = 0
    定义 可变 i = 0
    当 (i < N) {
        定义 可变 熵 = 0
        定义 可变 e = 0
        当 (e < E) {
            定义 p = 张量_取(路由概率, i * E + e)
            如果 (p > 0.0001) {
                熵 = 熵 - p * 数学_log(p)
            }
            e = e + 1
        }
        总熵 = 总熵 + 熵
        i = i + 1
    }
    返回 (总熵 * 1024) / N
}

// 反哺: 危险专家检测 — 幂律路由是自然的，但负载超过均值2x即为坍缩危险
// 返回: 危险专家数量 (0=健康, >0=需要干预)
// 干预方式: 提高辅助损失系数 或 重置该专家权重
函数 MoE_检测危险专家(层) {
    如果 (层 == 0 || 层.负载计数 == 0) { 返回 0 }
    定义 E = 层.专家数
    定义 可变 总负载 = 0
    定义 可变 e = 0
    当 (e < E) {
        总负载 = 总负载 + 张量_取(层.负载计数, e)
        e = e + 1
    }
    如果 (总负载 == 0) { 返回 0 }
    定义 均值负载 = 总负载 / E
    // 阈值: 均值×2 (实验证明幂律分布的合理上界)
    定义 危险阈值 = 均值负载 * 2
    定义 可变 危险数 = 0
    e = 0
    当 (e < E) {
        如果 (张量_取(层.负载计数, e) > 危险阈值) {
            危险数 = 危险数 + 1
        }
        e = e + 1
    }
    返回 危险数
}

// 综合路由健康状态 — 返回0-1000分
// 考量: 路由熵(越高越均匀) + 危险专家数量
函数 MoE_路由健康分(层, 路由概率, N) {
    如果 (层 == 0) { 返回 0 }
    定义 E = 层.专家数
    定义 熵分 = MoE_计算路由熵(路由概率, N, E)
    定义 最大熵 = 数学_log(E) * 1024    // 均匀分布时的最大熵
    定义 熵归一 = 如果 (最大熵 > 0) { 熵分 * 1000 / 最大熵 } 否则 { 0 }
    定义 危险数 = MoE_检测危险专家(层)
    定义 危险惩罚 = 危险数 * 200 / E    // 每个危险专家扣200/E分
    定义 健康分 = 熵归一 - 危险惩罚
    如果 (健康分 < 0) { 健康分 = 0 }
    如果 (健康分 > 1000) { 健康分 = 1000 }
    返回 健康分
}

// 反哺: 中文感知路由健康分
// 实验发现: 中文token信息密度1.8x → 路由集中度可适当放宽
// 即使单专家负载较高, 只要语义覆盖质量达标, 健康分应有加成
函数 MoE_中文感知健康分(层, 路由概率, N, 中文密度_千分) {
    定义 基础分 = MoE_路由健康分(层, 路由概率, N)
    如果 (中文密度_千分 <= 0) { 返回 基础分 }
    // 中文密度越高 → 对路由集中度的容忍度越高
    // 加成最大+100分 (密度100%时), 与基础分取加权均值
    定义 中文加成 = 中文密度_千分 * 100 / 1000
    // 加成仅在基础分>500时有效 (基础已健康才放宽)
    如果 (基础分 > 500) {
        定义 调整分 = 基础分 + 中文加成
        如果 (调整分 > 1000) { 调整分 = 1000 }
        返回 调整分
    }
    返回 基础分
}

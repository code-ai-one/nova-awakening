函数 帧缓冲_复制区域(dst_x, dst_y, src_x, src_y, 宽, 高) {
    // 处理重叠: 如果目标在源下方, 从下往上复制
    如果 (dst_y > src_y) {
        定义 可变 行 = 高 - 1
        当 (行 >= 0) {
            定义 src_偏移 = (src_y + 行) * FB_行字节 + src_x * FB_像素字节
            定义 dst_偏移 = (dst_y + 行) * FB_行字节 + dst_x * FB_像素字节
            内存复制(FB_地址 + dst_偏移, FB_地址 + src_偏移, 宽 * FB_像素字节)
            行 = 行 - 1
        }
    } 否则 {
        定义 可变 行 = 0
        当 (行 < 高) {
            定义 src_偏移 = (src_y + 行) * FB_行字节 + src_x * FB_像素字节
            定义 dst_偏移 = (dst_y + 行) * FB_行字节 + dst_x * FB_像素字节
            内存复制(FB_地址 + dst_偏移, FB_地址 + src_偏移, 宽 * FB_像素字节)
            行 = 行 + 1
        }
    }
}

函数 帧缓冲_滚屏(行数) {
    // 向上滚动: 将底部内容移到顶部, 底部清空
    定义 像素行数 = 行数
    定义 复制字节 = (FB_高 - 像素行数) * FB_行字节
    内存复制(FB_地址, FB_地址 + 像素行数 * FB_行字节, 复制字节)
    // 清空底部
    定义 清空起始 = FB_地址 + 复制字节
    内存清零(清空起始, 像素行数 * FB_行字节)
}

// 画线 (Bresenham算法)

函数 帧缓冲_画线(x0, y0, x1, y1, 颜色) {
    定义 可变 dx = x1 - x0
    定义 可变 dy = y1 - y0
    如果 (dx < 0) { dx = -dx }
    如果 (dy < 0) { dy = -dy }
    定义 sx = x0 < x1 ? 1 : -1
    定义 sy = y0 < y1 ? 1 : -1
    定义 可变 err = dx - dy
    定义 可变 cx = x0
    定义 可变 cy = y0
    循环 {
        帧缓冲_画像素(cx, cy, 颜色)
        如果 (cx == x1 && cy == y1) { 中断 }
        定义 e2 = 2 * err
        如果 (e2 > -dy) { err = err - dy; cx = cx + sx }
        如果 (e2 < dx) { err = err + dx; cy = cy + sy }
    }
}

// 颜色工具

函数 RGB(r, g, b) { 返回 (r << 16) | (g << 8) | b }
函数 RGBA(r, g, b, a) { 返回 (a << 24) | (r << 16) | (g << 8) | b }

定义 颜色_黑 = 0x00000000
定义 颜色_白 = 0x00FFFFFF
定义 颜色_红 = 0x00FF0000
定义 颜色_绿 = 0x0000FF00
定义 颜色_蓝 = 0x000000FF

// 脏区域追踪 + 清屏 + 查询

函数 标记脏区域(x1, y1, x2, y2) {
    如果 (!有脏区域) {
        脏_x1 = x1; 脏_y1 = y1; 脏_x2 = x2; 脏_y2 = y2
        有脏区域 = 真
    } 否则 {
        如果 (x1 < 脏_x1) { 脏_x1 = x1 }
        如果 (y1 < 脏_y1) { 脏_y1 = y1 }
        如果 (x2 > 脏_x2) { 脏_x2 = x2 }
        如果 (y2 > 脏_y2) { 脏_y2 = y2 }
    }
}

函数 帧缓冲_清屏(颜色) {
    如果 (FB_深度 == 32 && 颜色 == 0) {
        // 优化: 全黑直接memset
        内存清零(FB_地址, FB_大小)
    } 否则 {
        帧缓冲_填充矩形(0, 0, FB_宽, FB_高, 颜色)
    }
}

函数 帧缓冲_获取宽() { 返回 FB_宽 }
函数 帧缓冲_获取高() { 返回 FB_高 }
函数 帧缓冲_获取深度() { 返回 FB_深度 }
函数 帧缓冲_获取地址() { 返回 FB_地址 }
函数 帧缓冲_获取行字节() { 返回 FB_行字节 }

// 错误_无设备 定义在 核心/公共/错误码.nova

函数 帧缓冲_绘制文本(fb, x, y, 文本, 颜色, 字号) {
    定义 缩放 = 字号 / 16
    如果 (缩放 < 1) { 缩放 = 1 }
    字体_渲染文本_透明(fb, x, y, 文本, 颜色, 缩放)
}

// NFBR理论 — Nova Framebuffer Rendering
// 创新帧缓冲渲染体系：alpha混合、元图形库、双缓冲、
// 智能脏区域合并、硬件加速DMA
// 核心公式: Cout = Csrc×α + Cdst×(1-α)

定义 NFBR_最大脏区 = 64
定义 AI_NFBR_特征维度 = 8

定义 可变 NFBR_总像素 = 0
定义 可变 NFBR_alpha混合数 = 0
定义 可变 NFBR_填充数 = 0
定义 可变 NFBR_线数 = 0
定义 可变 NFBR_圆数 = 0
定义 可变 NFBR_翻转数 = 0

// §3 Alpha混合

函数 帧缓冲_alpha混合像素(src, dst) {
    // ARGB格式的alpha混合
    // Cout = Csrc×α/255 + Cdst×(255-α)/255
    定义 α = (src >> 24) & 0xFF
    如果 (α == 255) { 返回 src }  // 完全不透明
    如果 (α == 0) { 返回 dst }    // 完全透明

    定义 invα = 255 - α
    定义 sr = (src >> 16) & 0xFF
    定义 sg = (src >> 8) & 0xFF
    定义 sb = src & 0xFF
    定义 dr = (dst >> 16) & 0xFF
    定义 dg = (dst >> 8) & 0xFF
    定义 db = dst & 0xFF

    定义 r = (sr * α + dr * invα) / 255
    定义 g = (sg * α + dg * invα) / 255
    定义 b = (sb * α + db * invα) / 255

    NFBR_alpha混合数 = NFBR_alpha混合数 + 1
    返回 0xFF000000 | (r << 16) | (g << 8) | b
}

函数 帧缓冲_alpha填充矩形(x, y, 宽, 高, 颜色) {
    // 带alpha混合的矩形填充
    定义 可变 行 = 0
    当 (行 < 高) {
        定义 py = y + 行
        如果 (py >= 0 && py < FB_高) {
            定义 可变 列 = 0
            当 (列 < 宽) {
                定义 px = x + 列
                如果 (px >= 0 && px < FB_宽) {
                    定义 偏移 = py * FB_行字节 + px * FB_像素字节
                    定义 dst = 内存_读32(FB_地址 + 偏移)
                    定义 结果 = 帧缓冲_alpha混合像素(颜色, dst)
                    内存_写32(FB_地址 + 偏移, 结果)
                }
                列 = 列 + 1
            }
        }
        行 = 行 + 1
    }
    NFBR_填充数 = NFBR_填充数 + 1
}

// §4 圆形绘制 (Midpoint算法)

函数 帧缓冲_画圆(cx, cy, 半径, 颜色) {
    // 中点圆算法
    NFBR_圆数 = NFBR_圆数 + 1
    定义 可变 x = 0
    定义 可变 y = 半径
    定义 可变 d = 1 - 半径

    当 (x <= y) {
        // 画8个对称点
        帧缓冲_画像素(cx + x, cy + y, 颜色)
        帧缓冲_画像素(cx - x, cy + y, 颜色)
        帧缓冲_画像素(cx + x, cy - y, 颜色)
        帧缓冲_画像素(cx - x, cy - y, 颜色)
        帧缓冲_画像素(cx + y, cy + x, 颜色)
        帧缓冲_画像素(cx - y, cy + x, 颜色)
        帧缓冲_画像素(cx + y, cy - x, 颜色)
        帧缓冲_画像素(cx - y, cy - x, 颜色)

        如果 (d < 0) {
            d = d + 2 * x + 3
        } 否则 {
            d = d + 2 * (x - y) + 5
            y = y - 1
        }
        x = x + 1
    }
}

函数 帧缓冲_填充圆(cx, cy, 半径, 颜色) {
    // 填充圆形: 用水平线填充
    定义 可变 x = 0
    定义 可变 y = 半径
    定义 可变 d = 1 - 半径

    当 (x <= y) {
        // 填充水平线
        帧缓冲_水平线(cx - y, cx + y, cy + x, 颜色)
        帧缓冲_水平线(cx - y, cx + y, cy - x, 颜色)
        帧缓冲_水平线(cx - x, cx + x, cy + y, 颜色)
        帧缓冲_水平线(cx - x, cx + x, cy - y, 颜色)

        如果 (d < 0) {
            d = d + 2 * x + 3
        } 否则 {
            d = d + 2 * (x - y) + 5
            y = y - 1
        }
        x = x + 1
    }
}

函数 帧缓冲_水平线(x1, x2, y, 颜色) {
    如果 (y < 0 || y >= FB_高) { 返回 }
    定义 可变 左 = x1
    定义 可变 右 = x2
    如果 (左 < 0) { 左 = 0 }
    如果 (右 >= FB_宽) { 右 = FB_宽 - 1 }

    定义 偏移 = y * FB_行字节 + 左 * FB_像素字节
    定义 可变 px = 左
    当 (px <= 右) {
        内存_写32(FB_地址 + 偏移, 颜色)
        偏移 = 偏移 + FB_像素字节
        px = px + 1
    }
}

// §5 双缓冲与页翻转

定义 可变 NFBR_后缓冲 = 空
定义 可变 NFBR_当前缓冲 = 0  // 0=前, 1=后

函数 NFBR_初始化双缓冲() {
    NFBR_后缓冲 = 分配内存(FB_大小)
    如果 (NFBR_后缓冲 != 空) {
        内存清零(NFBR_后缓冲, FB_大小)
        内核信息("NFBR: 双缓冲已初始化 大小=%d", FB_大小)
    }
}

函数 NFBR_获取绘制缓冲() {
    // 返回后缓冲(绘制目标)
    如果 (NFBR_后缓冲 != 空) { 返回 NFBR_后缓冲 }
    返回 FB_地址
}

函数 NFBR_翻转() {
    // 交换前后缓冲
    如果 (NFBR_后缓冲 == 空) { 返回 }
    内存复制(FB_地址, NFBR_后缓冲, FB_大小)
    NFBR_翻转数 = NFBR_翻转数 + 1
}

// §6 矩形填充 + 边框

函数 帧缓冲_填充矩形(x, y, 宽, 高, 颜色) {
    NFBR_填充数 = NFBR_填充数 + 1
    定义 可变 行 = 0
    当 (行 < 高) {
        定义 py = y + 行
        如果 (py >= 0 && py < FB_高) {
            定义 偏移 = py * FB_行字节 + x * FB_像素字节
            定义 可变 列 = 0
            当 (列 < 宽) {
                定义 px = x + 列
                如果 (px >= 0 && px < FB_宽) {
                    内存_写32(FB_地址 + 偏移 + 列 * FB_像素字节, 颜色)
                }
                列 = 列 + 1
            }
        }
        行 = 行 + 1
    }
    NFBR_总像素 = NFBR_总像素 + 宽 * 高
}

函数 帧缓冲_矩形边框(x, y, 宽, 高, 颜色) {
    // 上边
    帧缓冲_水平线(x, x + 宽 - 1, y, 颜色)
    // 下边
    帧缓冲_水平线(x, x + 宽 - 1, y + 高 - 1, 颜色)
    // 左边
    定义 可变 i = 0
    当 (i < 高) {
        帧缓冲_画像素(x, y + i, 颜色)
        i = i + 1
    }
    // 右边
    i = 0
    当 (i < 高) {
        帧缓冲_画像素(x + 宽 - 1, y + i, 颜色)
        i = i + 1
    }
}

// §7 AI渲染调度与统计 (NFBR-AI)

函数 NFBR_AI分析() {
    定义 特征 = Tensor_创建(AI_NFBR_特征维度)
    如果 (特征 == 空) { 返回 }

    Tensor_写(特征, 0, NFBR_总像素)
    Tensor_写(特征, 1, NFBR_alpha混合数)
    Tensor_写(特征, 2, NFBR_填充数)
    Tensor_写(特征, 3, NFBR_线数)
    Tensor_写(特征, 4, NFBR_圆数)
    Tensor_写(特征, 5, NFBR_翻转数)
    Tensor_写(特征, 6, FB_宽 * FB_高)
    Tensor_写(特征, 7, FB_深度)

    定义 结果 = AI总线_推理("渲染调度", 特征)
    Tensor_释放(特征)
}

函数 NFBR_诊断报告() {
    内核打印("═══ NFBR 帧缓冲渲染统计 ═══\n")
    内核打印("总像素: %d  alpha: %d  填充: %d\n", NFBR_总像素, NFBR_alpha混合数, NFBR_填充数)
    内核打印("线: %d  圆: %d  翻转: %d\n", NFBR_线数, NFBR_圆数, NFBR_翻转数)
    内核打印("屏幕: %dx%d 深度=%d\n", FB_宽, FB_高, FB_深度)
}

// §8 渐变填充

函数 NFBR_插值颜色(c1, c2, t, 最大) {
    // 线性插值: C = c1 + (c2-c1)*t/max
    定义 r1 = (c1 >> 16) & 0xFF
    定义 g1 = (c1 >> 8) & 0xFF
    定义 b1 = c1 & 0xFF
    定义 r2 = (c2 >> 16) & 0xFF
    定义 g2 = (c2 >> 8) & 0xFF
    定义 b2 = c2 & 0xFF

    定义 r = r1 + (r2 - r1) * t / 最大
    定义 g = g1 + (g2 - g1) * t / 最大
    定义 b = b1 + (b2 - b1) * t / 最大
    返回 0xFF000000 | (r << 16) | (g << 8) | b
}

函数 帧缓冲_水平渐变(x, y, 宽, 高, 起始色, 结束色) {
    定义 可变 行 = 0
    当 (行 < 高) {
        定义 py = y + 行
        如果 (py >= 0 && py < FB_高) {
            定义 可变 列 = 0
            当 (列 < 宽) {
                定义 px = x + 列
                如果 (px >= 0 && px < FB_宽) {
                    定义 色 = NFBR_插值颜色(起始色, 结束色, 列, 宽)
                    定义 偏移 = py * FB_行字节 + px * FB_像素字节
                    内存_写32(FB_地址 + 偏移, 色)
                }
                列 = 列 + 1
            }
        }
        行 = 行 + 1
    }
}

函数 帧缓冲_垂直渐变(x, y, 宽, 高, 起始色, 结束色) {
    定义 可变 行 = 0
    当 (行 < 高) {
        定义 py = y + 行
        如果 (py >= 0 && py < FB_高) {
            定义 色 = NFBR_插值颜色(起始色, 结束色, 行, 高)
            定义 偏移 = py * FB_行字节 + x * FB_像素字节
            定义 可变 列 = 0
            当 (列 < 宽) {
                定义 px = x + 列
                如果 (px >= 0 && px < FB_宽) {
                    内存_写32(FB_地址 + 偏移 + 列 * FB_像素字节, 色)
                }
                列 = 列 + 1
            }
        }
        行 = 行 + 1
    }
}

// §9 椭圆绘制 (Midpoint椭圆)

函数 帧缓冲_画椭圆(cx, cy, rx, ry, 颜色) {
    // 中点椭圆算法
    定义 rx2 = rx * rx
    定义 ry2 = ry * ry
    定义 可变 x = 0
    定义 可变 y = ry
    定义 可变 px = 0
    定义 可变 py = 2 * rx2 * y

    // 区域1: dy/dx > -1
    定义 可变 p1 = ry2 - rx2 * ry + rx2 / 4
    当 (px < py) {
        帧缓冲_画像素(cx + x, cy + y, 颜色)
        帧缓冲_画像素(cx - x, cy + y, 颜色)
        帧缓冲_画像素(cx + x, cy - y, 颜色)
        帧缓冲_画像素(cx - x, cy - y, 颜色)
        x = x + 1
        px = px + 2 * ry2
        如果 (p1 < 0) {
            p1 = p1 + ry2 + px
        } 否则 {
            y = y - 1
            py = py - 2 * rx2
            p1 = p1 + ry2 + px - py
        }
    }

    // 区域2: dy/dx < -1
    定义 可变 p2 = ry2 * (x * 2 + 1) * (x * 2 + 1) / 4 + rx2 * (y - 1) * (y - 1) - rx2 * ry2
    当 (y >= 0) {
        帧缓冲_画像素(cx + x, cy + y, 颜色)
        帧缓冲_画像素(cx - x, cy + y, 颜色)
        帧缓冲_画像素(cx + x, cy - y, 颜色)
        帧缓冲_画像素(cx - x, cy - y, 颜色)
        y = y - 1
        py = py - 2 * rx2
        如果 (p2 > 0) {
            p2 = p2 + rx2 - py
        } 否则 {
            x = x + 1
            px = px + 2 * ry2
            p2 = p2 + rx2 - py + px
        }
    }
}

// §10 脏区域管理 (Dirty Region Tracking)

结构 脏区域 {
    x: 0,
    y: 0,
    宽: 0,
    高: 0,
    有效: 假
}

定义 可变 NFBR_脏区域表 = []
定义 可变 NFBR_脏区域数 = 0

函数 NFBR_添加脏区域(x, y, 宽, 高) {
    // 尝试与已有区域合并
    定义 可变 i = 0
    当 (i < NFBR_脏区域数) {
        定义 d = NFBR_脏区域表[i]
        如果 (d.有效 == 真) {
            // 检查重叠
            如果 (x < d.x + d.宽 && x + 宽 > d.x && y < d.y + d.高 && y + 高 > d.y) {
                // 合并为包围矩形
                定义 nx = 最小值(x, d.x)
                定义 ny = 最小值(y, d.y)
                d.宽 = 最大值(x + 宽, d.x + d.宽) - nx
                d.高 = 最大值(y + 高, d.y + d.高) - ny
                d.x = nx
                d.y = ny
                返回
            }
        }
        i = i + 1
    }
    // 新增脏区域
    如果 (NFBR_脏区域数 < NFBR_最大脏区) {
        NFBR_脏区域表[NFBR_脏区域数] = 脏区域 { x: x, y: y, 宽: 宽, 高: 高, 有效: 真 }
        NFBR_脏区域数 = NFBR_脏区域数 + 1
    }
}

函数 NFBR_刷新脏区域() {
    // 只复制脏区域到前缓冲
    如果 (NFBR_后缓冲 == 空) { 返回 }
    定义 可变 i = 0
    当 (i < NFBR_脏区域数) {
        定义 d = NFBR_脏区域表[i]
        如果 (d.有效 == 真) {
            定义 可变 行 = 0
            当 (行 < d.高) {
                定义 源偏移 = (d.y + 行) * FB_行字节 + d.x * FB_像素字节
                内存复制(FB_地址 + 源偏移, NFBR_后缓冲 + 源偏移, d.宽 * FB_像素字节)
                行 = 行 + 1
            }
            d.有效 = 假
        }
        i = i + 1
    }
    NFBR_脏区域数 = 0
}

// §11 DMA加速填充

定义 可变 NFBR_DMA可用 = 假
定义 NFBR_DMA_寄存器基址 = 0xFE00C000

函数 NFBR_DMA初始化() {
    // 检测DMA控制器
    定义 id = 内存_读32(NFBR_DMA_寄存器基址)
    如果 (id == 0x4E464252) {  // "NFBR" magic
        NFBR_DMA可用 = 真
        内核信息("NFBR: DMA控制器已检测")
    }
}

函数 NFBR_DMA填充(dst, 颜色, 字节数) {
    如果 (NFBR_DMA可用 == 假) {
        // 回退到CPU填充
        内存填充(dst, 颜色, 字节数)
        返回
    }
    // DMA填充命令
    内存_写32(NFBR_DMA_寄存器基址 + 4, dst)
    内存_写32(NFBR_DMA_寄存器基址 + 8, 颜色)
    内存_写32(NFBR_DMA_寄存器基址 + 12, 字节数)
    内存_写32(NFBR_DMA_寄存器基址 + 0, 0x01)  // 启动
    // 等待完成
    当 (内存_读32(NFBR_DMA_寄存器基址 + 0) & 0x01) {
        // busy-wait
    }
}

函数 NFBR_DMA复制(dst, src, 字节数) {
    如果 (NFBR_DMA可用 == 假) {
        内存复制(dst, src, 字节数)
        返回
    }
    内存_写32(NFBR_DMA_寄存器基址 + 4, dst)
    内存_写32(NFBR_DMA_寄存器基址 + 8, src)
    内存_写32(NFBR_DMA_寄存器基址 + 12, 字节数)
    内存_写32(NFBR_DMA_寄存器基址 + 0, 0x02)  // 复制模式
    当 (内存_读32(NFBR_DMA_寄存器基址 + 0) & 0x02) { }
}

// §12 精灵/位图传输 (Blit)

函数 帧缓冲_Blit(dst_x, dst_y, src_数据, src_宽, src_高) {
    // 不透明位图传输
    定义 可变 行 = 0
    当 (行 < src_高) {
        定义 py = dst_y + 行
        如果 (py >= 0 && py < FB_高) {
            定义 dst_偏移 = py * FB_行字节 + dst_x * FB_像素字节
            定义 src_偏移 = 行 * src_宽 * FB_像素字节
            定义 复制宽 = src_宽 * FB_像素字节
            NFBR_DMA复制(FB_地址 + dst_偏移, src_数据 + src_偏移, 复制宽)
        }
        行 = 行 + 1
    }
    NFBR_总像素 = NFBR_总像素 + src_宽 * src_高
}

函数 帧缓冲_AlphaBlit(dst_x, dst_y, src_数据, src_宽, src_高) {
    // 带alpha的位图传输
    定义 可变 行 = 0
    当 (行 < src_高) {
        定义 py = dst_y + 行
        如果 (py >= 0 && py < FB_高) {
            定义 可变 列 = 0
            当 (列 < src_宽) {
                定义 px = dst_x + 列
                如果 (px >= 0 && px < FB_宽) {
                    定义 src_偏 = 行 * src_宽 + 列
                    定义 src_像素 = 内存_读32(src_数据 + src_偏 * 4)
                    定义 dst_偏移 = py * FB_行字节 + px * FB_像素字节
                    定义 dst_像素 = 内存_读32(FB_地址 + dst_偏移)
                    定义 结果 = 帧缓冲_alpha混合像素(src_像素, dst_像素)
                    内存_写32(FB_地址 + dst_偏移, 结果)
                }
                列 = 列 + 1
            }
        }
        行 = 行 + 1
    }
}

// §13 图像变换: 旋转/缩放/镜像

函数 帧缓冲_水平镜像(x, y, 宽, 高) {
    // 原地水平翻转
    定义 可变 行 = 0
    当 (行 < 高) {
        定义 py = y + 行
        如果 (py >= 0 && py < FB_高) {
            定义 可变 左 = 0
            定义 可变 右 = 宽 - 1
            当 (左 < 右) {
                定义 偏左 = py * FB_行字节 + (x + 左) * FB_像素字节
                定义 偏右 = py * FB_行字节 + (x + 右) * FB_像素字节
                定义 暂 = 内存_读32(FB_地址 + 偏左)
                内存_写32(FB_地址 + 偏左, 内存_读32(FB_地址 + 偏右))
                内存_写32(FB_地址 + 偏右, 暂)
                左 = 左 + 1
                右 = 右 - 1
            }
        }
        行 = 行 + 1
    }
}

函数 帧缓冲_垂直镜像(x, y, 宽, 高) {
    // 原地垂直翻转
    定义 可变 上 = 0
    定义 可变 下 = 高 - 1
    当 (上 < 下) {
        定义 可变 列 = 0
        当 (列 < 宽) {
            定义 偏上 = (y + 上) * FB_行字节 + (x + 列) * FB_像素字节
            定义 偏下 = (y + 下) * FB_行字节 + (x + 列) * FB_像素字节
            定义 暂 = 内存_读32(FB_地址 + 偏上)
            内存_写32(FB_地址 + 偏上, 内存_读32(FB_地址 + 偏下))
            内存_写32(FB_地址 + 偏下, 暂)
            列 = 列 + 1
        }
        上 = 上 + 1
        下 = 下 - 1
    }
}

// §14 NFBR全局初始化

函数 NFBR_全局初始化() {
    NFBR_初始化双缓冲()
    NFBR_DMA初始化()
    NFBR_脏区域数 = 0
    NFBR_总像素 = 0
    NFBR_alpha混合数 = 0
    NFBR_填充数 = 0
    NFBR_线数 = 0
    NFBR_圆数 = 0
    NFBR_翻转数 = 0
    内核信息("NFBR: 帧缓冲渲染子系统已初始化 (%dx%d)", FB_宽, FB_高)
    NFBR_AI分析()
}

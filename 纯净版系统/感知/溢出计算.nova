// §7 Overflow计算

函数 布局块级Flow_计算overflow(layout) {
    定义 可变 scroll_宽 = layout.宽度
    定义 可变 scroll_高 = layout.高度

    定义 可变 子 = layout.第一子
    当 (子 != 0) {
        定义 子右 = 子.x + 子.宽度 + 子.padding_right + 子.border_right + 子.margin_right
        定义 子底 = 子.y + 子.高度 + 子.padding_bottom + 子.border_bottom + 子.margin_bottom

        如果 (子右 > scroll_宽) { scroll_宽 = 子右 }
        如果 (子底 > scroll_高) { scroll_高 = 子底 }

        子 = 子.后一兄弟布局
    }

    layout.滚动宽度 = scroll_宽
    layout.滚动高度 = scroll_高
}

// §8 Inline Flow 布局 (IFC) — 行内布局
// 行内元素(span/a/em/strong/text)在行盒(line box)内水平排列
// 超出行宽时自动换行

结构 LineBox {
    x,    // i32 行起始x
    y,    // i32 行起始y
    宽度,    // i32 行总宽
    高度,    // i32 行高(最高元素决定)
    基线,    // i32 基线位置(从行顶)
    剩余宽度,    // i32 行内剩余可用宽度
    项列表,    // u64 行内项数组
    项数量,
}

函数 布局Inline_布局(layout) {
    如果 (layout == 0) { 返回 }

    定义 可用宽 = layout.宽度
    定义 可变 当前行 = LineBox {}
    当前行.x = 0
    当前行.y = 0
    当前行.高度 = 0
    当前行.剩余宽度 = 可用宽

    定义 可变 总高 = 0

    定义 可变 子 = layout.第一子
    当 (子 != 0) {
        如果 (子.布局类型 == 布局类型_文本) {
            // 文本: 逐词分割,填入行盒
            布局Inline_布局文本到行(layout, 子, 当前行, 可用宽, 总高)
        } 否则 {
            // 行内块/行内元素
            定义 子宽 = 子.宽度 + 子.margin_left + 子.margin_right
                       + 子.padding_left + 子.padding_right
                       + 子.border_left + 子.border_right
            定义 子高 = 子.高度 + 子.margin_top + 子.margin_bottom
                       + 子.padding_top + 子.padding_bottom
                       + 子.border_top + 子.border_bottom

            // 放不下? 换行
            如果 (子宽 > 当前行.剩余宽度 && 当前行.宽度 > 0) {
                总高 = 总高 + 当前行.高度
                当前行.x = 0
                当前行.y = 总高
                当前行.宽度 = 0
                当前行.高度 = 0
                当前行.剩余宽度 = 可用宽
            }

            子.x = 当前行.x + 当前行.宽度 + 子.margin_left
            子.y = 当前行.y + 子.margin_top

            // 递归布局
            布局块级Flow_布局(子)

            当前行.宽度 = 当前行.宽度 + 子宽
            当前行.剩余宽度 = 当前行.剩余宽度 - 子宽
            如果 (子高 > 当前行.高度) { 当前行.高度 = 子高 }
        }

        子 = 子.后一兄弟布局
    }

    // 最后一行
    总高 = 总高 + 当前行.高度
    layout.高度 = 总高
}

函数 布局Inline_布局文本到行(父, 文本layout, 行, 可用宽, 总高) {
    // 获取文本内容
    定义 文本 = 文本layout.文本内容
    如果 (文本 == 0) { 返回 }
    定义 文本长度 = 字符串_长度(文本)
    如果 (文本长度 == 0) { 返回 }

    定义 字号 = 1600    // 默认16px(×100)
    如果 (文本layout.样式 != 0) {
        字号 = 文本layout.样式.font_size
        如果 (字号 <= 0) { 字号 = 1600 }
    }
    定义 行高 = 字号 * 120 / 100    // 1.2倍行距

    // 逐词/逐字排列
    定义 可变 pos = 0
    当 (pos < 文本长度) {
        // 找下一个词的结尾(空格/换行)
        定义 词开始 = pos
        当 (pos < 文本长度) {
            定义 c = 内存_读8(文本 + pos)
            如果 (c == 0x20 || c == 0x0A || c == 0x09) { 跳出 }
            pos = pos + 1
        }
        定义 词长度 = pos - 词开始

        如果 (词长度 > 0) {
            // 估算词宽: ASCII约0.6×字号, CJK约1.0×字号
            定义 可变 词宽 = 0
            定义 可变 i = 词开始
            当 (i < 词开始 + 词长度) {
                定义 c = 内存_读8(文本 + i)
                如果 (c > 0x7F) {
                    词宽 = 词宽 + 字号
                    如果 (c >= 0xE0) { i = i + 2 }
                    否则 如果 (c >= 0xC0) { i = i + 1 }
                } 否则 {
                    词宽 = 词宽 + 字号 * 60 / 100
                }
                i = i + 1
            }

            // 放不下? 换行
            如果 (词宽 > 行.剩余宽度 && 行.宽度 > 0) {
                总高 = 总高 + 行.高度
                行.x = 0
                行.y = 总高
                行.宽度 = 0
                行.高度 = 0
                行.剩余宽度 = 可用宽
            }

            // 放入当前行
            行.宽度 = 行.宽度 + 词宽
            行.剩余宽度 = 行.剩余宽度 - 词宽
            如果 (行高 > 行.高度) { 行.高度 = 行高 }
        }

        // 跳过空白
        如果 (pos < 文本长度) {
            定义 c = 内存_读8(文本 + pos)
            如果 (c == 0x0A) {
                // 强制换行
                总高 = 总高 + 行.高度
                行.x = 0
                行.y = 总高
                行.宽度 = 0
                行.高度 = 行高
                行.剩余宽度 = 可用宽
            } 否则 {
                // 空格
                定义 空格宽 = 字号 * 25 / 100
                行.宽度 = 行.宽度 + 空格宽
                行.剩余宽度 = 行.剩余宽度 - 空格宽
            }
            pos = pos + 1
        }
    }

    文本layout.高度 = 行高
}

定义 可变 AI_溢出计算_样式缓存命中 = 0

函数 AI_溢出计算_选择器复杂度(选择器长度, 组合子数) {
    如果 (组合子数 > 5) { 返回 "高复杂度" }
    如果 (组合子数 > 2) { 返回 "中复杂度" }
    返回 "低复杂度"
}

函数 AI_溢出计算_布局缓存(元素哈希) {
    AI_溢出计算_样式缓存命中 = AI_溢出计算_样式缓存命中 + 1
    返回 元素哈希
}

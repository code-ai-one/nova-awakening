// §4 事务管理

函数 journal_开始事务() {
    如果 (!journal_已初始化) { 返回 空 }

    定义 tx = 事务 {}
    tx.事务ID = journal_序列号
    journal_序列号 = journal_序列号 + 1
    tx.状态 = 事务_运行中
    tx.开始时间 = 读取毫秒()
    tx.修改列表 = []
    tx.修改块数 = 0
    tx.journal起始块 = journal_头指针

    journal_当前事务 = tx
    journal_事务总数 = journal_事务总数 + 1
    返回 tx
}

函数 journal_记录修改(事务, 块号, 数据) {
    如果 (事务 == 空 || 事务.状态 != 事务_运行中) { 返回 }

    定义 jbuf = journal缓冲区 {}
    jbuf.块号 = 块号
    jbuf.数据 = 数据
    jbuf.已脏 = 真
    jbuf.事务ID = 事务.事务ID

    追加(事务.修改列表, jbuf)
    事务.修改块数 = 事务.修改块数 + 1
}

函数 journal_提交事务(事务) {
    如果 (事务 == 空 || 事务.状态 != 事务_运行中) { 返回 假 }

    事务.状态 = 事务_锁定

    定义 描述符 = 创建缓冲(journal_块大小)
    缓冲写32(描述符, 0, JBD2_MAGIC)
    缓冲写32(描述符, 4, JBD2_描述符块)
    缓冲写32(描述符, 8, 事务.事务ID)
    // 记录每个修改块的原始块号
    定义 可变 i = 0
    当 (i < 事务.修改块数 && i < 100) {
        缓冲写64(描述符, 16 + i * 8, 事务.修改列表[i].块号)
        i = i + 1
    }
    journal_写入块(描述符)

    事务.状态 = 事务_刷写中
    i = 0
    当 (i < 事务.修改块数) {
        journal_写入块(事务.修改列表[i].数据)
        journal_写入块数 = journal_写入块数 + 1
        i = i + 1
    }

    定义 提交 = 创建缓冲(journal_块大小)
    缓冲写32(提交, 0, JBD2_MAGIC)
    缓冲写32(提交, 4, JBD2_提交块)
    缓冲写32(提交, 8, 事务.事务ID)
    // 提交块包含CRC32校验(确保完整性)
    缓冲写32(提交, 12, journal_计算CRC(事务))
    journal_写入块(提交)

    事务.状态 = 事务_已提交
    事务.提交时间 = 读取毫秒()
    追加(journal_事务列表, 事务)

    如果 (journal_模式 == JOURNAL_MODE_ORDERED) {
        journal_回写数据(事务)
    }

    返回 真
}

函数 journal_写入块(数据) {
    // 写入journal环形缓冲区的下一个位置
    定义 物理块 = journal_超级块.起始块 + 1 + journal_头指针
    块设备_写入(journal_设备, 物理块, 数据)
    journal_头指针 = (journal_头指针 + 1) % (journal_总块数 - 1)
}

函数 journal_回写数据(事务) {
    // 将事务中的修改写入实际磁盘位置
    定义 可变 i = 0
    当 (i < 事务.修改块数) {
        定义 jbuf = 事务.修改列表[i]
        块设备_写入(journal_设备, jbuf.块号, jbuf.数据)
        i = i + 1
    }
}

// §5 Checkpoint (journal空间回收)

函数 journal_checkpoint() {
    // 将所有已提交事务的数据写入最终位置，回收journal空间
    定义 可变 回收数 = 0
    定义 可变 i = 0
    当 (i < 计数(journal_事务列表)) {
        定义 tx = journal_事务列表[i]
        如果 (tx.状态 == 事务_已提交) {
            // 确保数据已写入最终位置
            journal_回写数据(tx)
            tx.状态 = 事务_已检查点
            回收数 = 回收数 + 1
        }
        i = i + 1
    }

    // 清除已checkpoint的事务
    定义 可变 新列表 = []
    i = 0
    当 (i < 计数(journal_事务列表)) {
        如果 (journal_事务列表[i].状态 != 事务_已检查点) {
            追加(新列表, journal_事务列表[i])
        }
        i = i + 1
    }
    journal_事务列表 = 新列表

    // 更新尾指针
    如果 (计数(journal_事务列表) > 0) {
        journal_尾指针 = journal_事务列表[0].journal起始块
    } 否则 {
        journal_尾指针 = journal_头指针
    }

    如果 (回收数 > 0) {
        内核信息("ext4 journal: checkpoint " + 整数转字符串(回收数) + " 个事务")
    }
}

// §6 有序数据模式(data=ordered)

函数 journal_有序数据_提交前(事务) {
    // 在提交元数据前,确保所有关联的数据块已写入磁盘
    如果 (事务 == 空) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(事务.有序数据列表)) {
        定义 数据块 = 事务.有序数据列表[i]
        如果 (数据块.脏) {
            块设备_同步写(journal_设备, 数据块.块号, 数据块.缓冲)
            数据块.脏 = 假
        }
        i = i + 1
    }
}

函数 journal_有序数据_添加(事务, 块号, 缓冲) {
    如果 (事务 == 空) { 返回 }
    追加(事务.有序数据列表, { 块号: 块号, 缓冲: 缓冲, 脏: 真 })
}

// §7 事务超时处理

定义 事务_超时_秒 = 5
定义 可变 journal_上次提交时间 = 0
定义 可变 journal_自动提交数 = 0

函数 journal_检查超时() {
    如果 (journal_当前事务 == 空) { 返回 }
    定义 现在 = 当前时间_纳秒() / 1000000000
    如果 (现在 - journal_上次提交时间 > 事务_超时_秒) {
        journal_提交当前事务()
        journal_自动提交数 = journal_自动提交数 + 1
        journal_上次提交时间 = 现在
    }
}

函数 journal_提交当前事务() {
    如果 (journal_当前事务 == 空) { 返回 }
    // 1. 有序数据模式: 先写数据块
    journal_有序数据_提交前(journal_当前事务)
    // 2. 写描述块+元数据块
    // 3. 写提交块
    // 4. 移到事务列表
    journal_提交总数 = journal_提交总数 + 1
}

定义 可变 journal_当前事务 = 空
定义 可变 journal_事务列表 = []
定义 可变 journal_序列号 = 1
定义 可变 journal_超级块 = 空
定义 可变 journal_头指针 = 0
定义 可变 journal_尾指针 = 0
定义 可变 journal_提交总数 = 0

函数 块设备_同步写(设备, 块号, 数据) {
    // 同步写入块设备: 计算偏移, 写入数据, 刷新缓存
    如果 (设备 == 空 || 数据 == 空) { 返回 }
    定义 偏移 = 块号 * 设备.块大小
    设备.写操作(设备, 偏移, 数据, 设备.块大小)
    设备.同步操作(设备)
}

// §8 事务统计

函数 事务_统计() {
    返回 {
        提交总数: journal_提交总数,
        自动提交: journal_自动提交数,
        当前事务: journal_当前事务 != 空,
        事务列表: 计数(journal_事务列表),
    }
}

函数 事务_健康检查() {
    定义 可变 问题 = []
    如果 (journal_当前事务 != 空 && journal_自动提交数 > 100) {
        追加(问题, "自动提交过多")
    }
    如果 (计数(问题) == 0) { 返回 "事务管理健康" }
    返回 问题
}

定义 可变 AI_事务管理_故障预警数 = 0

函数 AI_事务管理_设备健康(错误率, 响应时间, 温度) {
    定义 可变 分 = 1000
    如果 (错误率 > 10) { 分 = 分 - 错误率 * 5 }
    如果 (响应时间 > 1000) { 分 = 分 - 200 }
    如果 (温度 > 80) { 分 = 分 - 300 }
    如果 (分 < 300) { AI_事务管理_故障预警数 = AI_事务管理_故障预警数 + 1 }
    返回 分
}

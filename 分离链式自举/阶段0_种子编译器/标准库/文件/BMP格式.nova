// Nova标准库 — BMP格式模块
// Nova原生二进制图像输出
// 使用缓冲区/缓冲写/写二进制内建函数
// 直接生成可显示的BMP图片文件
// 突破: Nova不再需要Python桥来保存图片!

// BMP文件格式
// BMP = 文件头(14字节) + 信息头(40字节) + 像素数据
// 像素: BGR顺序, 每行4字节对齐

// 写入灰度BMP (8位, 带调色板)
// 像素列表: 宽*高个像素值 (0-255), 行优先

导入("../基础.nova")
导入("../../编译器/前端入口.nova")
导入("../../自举兼容桥.nova")

函数 bmp_写灰度(路径, 宽, 高, 像素列表) {
    // 行字节数 (4字节对齐)
    定义 可变 row_bytes = 宽
    当 (row_bytes % 4 != 0) { row_bytes = row_bytes + 1 }

    // 调色板: 256个BGRA条目 = 1024字节
    定义 palette_size = 1024
    // 像素数据大小
    定义 pixel_size = row_bytes * 高
    // 文件总大小
    定义 file_size = 14 + 40 + palette_size + pixel_size
    定义 偏移量 = 14 + 40 + palette_size

    定义 可变 缓冲 = 缓冲区(file_size)

    // 文件头 (14字节)
    缓冲写(缓冲, 0, 66)   // 'B'
    缓冲写(缓冲, 1, 77)   // 'M'
    缓冲写32(缓冲, 2, file_size)
    缓冲写16(缓冲,  6, 0)   // 保留
    缓冲写16(缓冲,  8, 0)   // 保留
    缓冲写32(缓冲, 10, 偏移量)

    // 信息头 (40字节)
    缓冲写32(缓冲, 14, 40)      // 信息头大小
    缓冲写32(缓冲, 18, 宽)      // 宽度
    缓冲写32(缓冲, 22, 高)      // 高度
    缓冲写16(缓冲, 26, 1)       // 色彩平面数
    缓冲写16(缓冲, 28, 8)       // 位深度 (8位灰度)
    缓冲写32(缓冲,  30, 0)       // 压缩方式 (无压缩)
    缓冲写32(缓冲, 34, pixel_size)
    缓冲写32(缓冲, 38, 2835)    // 水平分辨率 (72dpi)
    缓冲写32(缓冲, 42, 2835)    // 垂直分辨率
    缓冲写32(缓冲, 46, 256)     // 调色板颜色数
    缓冲写32(缓冲,  50, 0)       // 重要颜色数

    // 灰度调色板 (256 * 4 = 1024字节)
    定义 可变 ci = 0
    当 (ci < 256) {
        定义 可变 p = 54 + ci * 4
        缓冲写(缓冲, p, ci)       // B
        缓冲写(缓冲, p + 1, ci)   // G
        缓冲写(缓冲, p + 2, ci)   // R
        缓冲写(缓冲,  p + 3, 0)    // A (保留)
        ci = ci + 1
    }

    // 像素数据 (BMP从底部开始)
    定义 可变 y = 0
    当 (y < 高) {
        // BMP行顺序: 从底到顶
        定义 src_y = 高 - 1 - y
        定义 可变 x = 0
        当 (x < 宽) {
            定义 可变 px = 像素列表[src_y * 宽 + x]
            如果 (px < 0) { px = 0 }
            如果 (px > 255) { px = 255 }
            缓冲写(缓冲, 偏移量 + y * row_bytes + x, px)
            x = x + 1
        }
        // 填充字节 (4字节对齐)
        定义 可变 填充 = 宽
        当 (填充 < row_bytes) {
            缓冲写(缓冲,  偏移量 + y * row_bytes + 填充, 0)
            填充 = 填充 + 1
        }
        y = y + 1
    }

    // 写入文件
    写二进制(路径, 缓冲, file_size)
    打印("BMP已保存: " + 路径 + " (" + 转字符串(宽) + "x" + 转字符串(高) + ", " + 转字符串(file_size) + "字节)")
}

// 写入24位RGB BMP
// 像素列表: 宽*高*3个值 (R,G,B顺序, 0-255)
函数 bmp_写RGB(路径, 宽, 高, 像素列表) {
    // 行字节数 (每像素3字节, 4字节对齐)
    定义 可变 row_bytes = 宽 * 3
    当 (row_bytes % 4 != 0) { row_bytes = row_bytes + 1 }

    定义 pixel_size = row_bytes * 高
    定义 file_size = 14 + 40 + pixel_size
    定义 偏移量 = 54

    定义 可变 缓冲 = 缓冲区(file_size)

    // 文件头
    缓冲写(缓冲, 0, 66)
    缓冲写(缓冲, 1, 77)
    缓冲写32(缓冲, 2, file_size)
    缓冲写32(缓冲, 10, 偏移量)

    // 信息头
    缓冲写32(缓冲, 14, 40)
    缓冲写32(缓冲, 18, 宽)
    缓冲写32(缓冲, 22, 高)
    缓冲写16(缓冲, 26, 1)
    缓冲写16(缓冲, 28, 24)     // 24位RGB
    缓冲写32(缓冲, 34, pixel_size)
    缓冲写32(缓冲, 38, 2835)
    缓冲写32(缓冲, 42, 2835)

    // 像素数据 (BGR顺序, 从底到顶)
    定义 可变 y = 0
    当 (y < 高) {
        定义 src_y = 高 - 1 - y
        定义 可变 x = 0
        当 (x < 宽) {
            定义 pi = (src_y * 宽 + x) * 3
            定义 可变 r = 像素列表[pi]
            定义 可变 g = 像素列表[pi + 1]
            定义 可变 b = 像素列表[pi + 2]
            如果 (r < 0) { r = 0 }
            如果 (r > 255) { r = 255 }
            如果 (g < 0) { g = 0 }
            如果 (g > 255) { g = 255 }
            如果 (b < 0) { b = 0 }
            如果 (b > 255) { b = 255 }

            定义 bo = 偏移量 + y * row_bytes + x * 3
            缓冲写(缓冲, bo, b)       // BMP是BGR顺序!
            缓冲写(缓冲, bo + 1, g)
            缓冲写(缓冲, bo + 2, r)
            x = x + 1
        }
        y = y + 1
    }

    写二进制(路径, 缓冲, file_size)
    打印("BMP已保存: " + 路径 + " (" + 转字符串(宽) + "x" + 转字符串(高) + " RGB, " + 转字符串(file_size) + "字节)")
}

// 测试
函数 BMP测试() {
    打印("=== BMP格式测试 ===")

    // 生成32x32灰度渐变测试图
    定义 可变 像素列表 = []
    定义 可变 y = 0
    当 (y < 32) {
        定义 可变 x = 0
        当 (x < 32) {
            插入(像素列表, 计数(像素列表), y * 8)
            x = x + 1
        }
        y = y + 1
    }

    bmp_写灰度("bmp_test_gray.bmp", 32, 32, 像素列表)

    // 生成16x16 RGB测试图
    定义 可变 rgb = []
    y = 0
    当 (y < 16) {
        定义 可变 x = 0
        当 (x < 16) {
            插入(rgb, 计数(rgb), x * 16)    // R
            插入(rgb, 计数(rgb), y * 16)    // G
            插入(rgb, 计数(rgb), 128)       // B
            x = x + 1
        }
        y = y + 1
    }

    bmp_写RGB("bmp_test_rgb.bmp", 16, 16, rgb)

    打印("BMP格式: 全部通过")
}

// BMP测试()

// 像素操作
函数 像素_取(rgb数据, 宽, x, y) {
    定义 索引 = (y * 宽 + x) * 3
    返回 [rgb数据[索引], rgb数据[索引 + 1], rgb数据[索引 + 2]]
}

函数 像素_设(rgb数据, 宽, x, y, r, g, b) {
    定义 索引 = (y * 宽 + x) * 3
    rgb数据[索引] = r
    rgb数据[索引 + 1] = g
    rgb数据[索引 + 2] = b
}

// 灰度转换
函数 bmp_转灰度(rgb数据) {
    定义 可变 灰度 = []
    定义 可变 i = 0
    当 (i < 计数(rgb数据) / 3) {
        定义 r = rgb数据[i * 3]
        定义 g = rgb数据[i * 3 + 1]
        定义 b = rgb数据[i * 3 + 2]
        追加(灰度, (r * 299 + g * 587 + b * 114) / 1000)
        i = i + 1
    }
    返回 灰度
}

// 图像翻转
函数 bmp_水平翻转(rgb数据, 宽, 高) {
    定义 可变 y = 0
    当 (y < 高) {
        定义 可变 x = 0
        当 (x < 宽 / 2) {
            定义 左idx = (y * 宽 + x) * 3
            定义 右idx = (y * 宽 + 宽 - 1 - x) * 3
            定义 可变 c = 0
            当 (c < 3) {
                定义 暂 = rgb数据[左idx + c]
                rgb数据[左idx + c] = rgb数据[右idx + c]
                rgb数据[右idx + c] = 暂
                c = c + 1
            }
            x = x + 1
        }
        y = y + 1
    }
}

// 图像填充
函数 bmp_填充矩形(rgb数据, 宽, x1, y1, x2, y2, r, g, b) {
    定义 可变 y = y1
    当 (y <= y2) {
        定义 可变 x = x1
        当 (x <= x2) {
            像素_设(rgb数据, 宽, x, y, r, g, b)
            x = x + 1
        }
        y = y + 1
    }
}

// 图像亮度调整
函数 bmp_调整亮度(rgb数据, 增量) {
    定义 可变 i = 0
    当 (i < 计数(rgb数据)) {
        定义 可变 v = rgb数据[i] + 增量
        如果 (v > 255) { v = 255 }
        如果 (v < 0) { v = 0 }
        rgb数据[i] = v
        i = i + 1
    }
}

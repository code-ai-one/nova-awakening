// NovaOS 浏览器内核 · 第一层 · 网络适配模块
// 直连内核L2网络栈(传控/数报/IP)，零中间层
// 职责: HTTP/HTTPS请求、长连接、资源加载、域名解析

定义 方法_GET     = 0
定义 方法_POST    = 1
定义 方法_PUT     = 2
定义 方法_DELETE   = 3
定义 方法_HEAD    = 4
定义 方法_OPTIONS = 5

定义 请求状态_等待     = 0
定义 请求状态_域名解析中 = 1
定义 请求状态_连接中    = 2
定义 请求状态_发送中    = 3
定义 请求状态_接收中    = 4
定义 请求状态_完成      = 5
定义 请求状态_失败      = 6
定义 请求状态_取消      = 7

定义 优先级_关键   = 0   // HTML文档/CSS
定义 优先级_高     = 1   // JS脚本
定义 优先级_中     = 2   // 图片/字体
定义 优先级_低     = 3   // 预取/分析
定义 优先级_空闲   = 4   // 后台预加载

结构 浏览器网络请求 {
    ID,
    方法,
    URL,
    主机,
    端口,
    路径,
    请求头,    // [] [键, 值] 列表
    请求体,
    状态,
    优先级,
    // 响应
    响应码,
    响应头,    // []
    响应体,    // [] 字节块列表
    响应体大小,
    // 内核直连
    Socket_FD,    // i32 内核Socket文件描述符
    // AI辅助
    AI预测命中,    // 布尔 是否AI预取命中缓存
    AI优先级调整,    // 布尔 是否被AI调整过优先级
}

结构 浏览器连接池 {
    连接列表,    // [] 活跃的传控连接
    最大连接数,
    每主机最大,
    空闲超时,    // u64 毫秒
}

定义 可变 网络_请求队列 = []
定义 可变 网络_连接池 = 空
定义 可变 网络_下一个ID = 1
定义 可变 网络_已初始化 = 假
定义 可变 网络_域名缓存 = []       // [主机名, IP, 过期时间]
定义 可变 网络_总请求数 = 0
定义 可变 网络_总字节数 = 0
定义 可变 网络_AI预取命中 = 0

// §1 初始化

函数 浏览器网络_初始化() {
    网络_连接池 = 浏览器连接池 {}
    网络_连接池.连接列表 = []
    网络_连接池.最大连接数 = 64
    网络_连接池.每主机最大 = 6
    网络_连接池.空闲超时 = 30000
    网络_请求队列 = []
    网络_域名缓存 = []
    网络_已初始化 = 真
    内核信息("浏览器网络适配: 初始化完成, 直连内核L2网络栈")
}

// §2 URL解析

结构 解析后URL {
    协议,    // 字符串 "http" | "https" | "nova"
    主机,
    端口,
    路径,
    查询,
    片段,
}

函数 浏览器网络_解析URL(url) {
    定义 结果 = 解析后URL {}
    结果.端口 = 80
    结果.路径 = "/"

    // 解析协议
    定义 协议结束 = 字符串查找(url, "://")
    如果 (协议结束 >= 0) {
        结果.协议 = 字符串子串(url, 0, 协议结束)
        url = 字符串子串(url, 协议结束 + 3, 字符串长度(url) - 协议结束 - 3)
    } 否则 {
        结果.协议 = "https"
    }

    如果 (结果.协议 == "https") { 结果.端口 = 443 }
    如果 (结果.协议 == "nova") { 结果.端口 = 0 }

    // 解析主机和路径
    定义 路径开始 = 字符串查找(url, "/")
    如果 (路径开始 >= 0) {
        结果.主机 = 字符串子串(url, 0, 路径开始)
        结果.路径 = 字符串子串(url, 路径开始, 字符串长度(url) - 路径开始)
    } 否则 {
        结果.主机 = url
    }

    // 解析端口
    定义 端口标记 = 字符串查找(结果.主机, ":")
    如果 (端口标记 >= 0) {
        定义 端口串 = 字符串子串(结果.主机, 端口标记 + 1, 字符串长度(结果.主机) - 端口标记 - 1)
        结果.端口 = 字符串转整数(端口串)
        结果.主机 = 字符串子串(结果.主机, 0, 端口标记)
    }

    // 解析查询和片段
    定义 查询开始 = 字符串查找(结果.路径, "?")
    如果 (查询开始 >= 0) {
        结果.查询 = 字符串子串(结果.路径, 查询开始 + 1, 字符串长度(结果.路径) - 查询开始 - 1)
        结果.路径 = 字符串子串(结果.路径, 0, 查询开始)
    }

    返回 结果
}

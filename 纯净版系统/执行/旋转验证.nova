// NVCR理论 — Nova Visual CAPTCHA Recognition
// 原创视觉验证码识别与角度计算理论
// 核心理论:
//   1. NVCR-HOG: 方向梯度直方图旋转角度推断
//      Δθ = arctan(Σ Gy(x,y) / Σ Gx(x,y))
//      利用Sobel梯度场计算主方向角度
//   2. NVCR-SIM: 结构相似度匹配
//      S(A,B) = (2μAμB + C1)(2σAB + C2) / (μA²+μB²+C1)(σA²+σB²+C2)
//   3. NVCR-BEH: 人类行为统计仿真模型
//      v(t) = v0 * (1 - e^(-αt)) + ε(t) 仿人类速度曲线
//   4. NVCR-OCR: 多层特征融合字符识别
//   5. NVCR-CLS: AI图片分类引擎

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../标准/数学幂根对数.nova")
导入("./真实点击.nova")
导入("../推理/值乘.nova")
导入("./算术验证.nova")
导入("./节点操作.nova")
导入("./真实滚动.nova")
导入("../外联/地址解析辅.nova")

// §1 全局常量与统计计数器

定义 NVCR_版本 = "3.0.0-NVCR"
定义 NVCR_PI = 3.14159265358979
定义 NVCR_角度精度 = 1              // 角度检测精度(度)
定义 NVCR_直方图桶数 = 36           // HOG 36桶 = 10°/桶
定义 NVCR_Sobel阈值 = 30             // 梯度幅值过滤阈值
定义 NVCR_滑块宽度 = 300              // 旋转滑块像素宽度
定义 NVCR_最大旋转角 = 360             // 最大旋转角度
定义 NVCR_OCR_置信度阈值 = 0.65     // OCR最低置信度
定义 NVCR_点击间隔最小 = 300          // 点选最小间隔ms
定义 NVCR_点击间隔最大 = 1200         // 点选最大间隔ms
定义 NVCR_图片分类阈值 = 0.55       // 图片分类最低置信度
定义 NVCR_行为仿真系数 = 0.85       // 人类行为仿真精度
定义 NVCR_SSIM_C1 = 0.0001            // SSIM常数C1
定义 NVCR_SSIM_C2 = 0.0009            // SSIM常数C2

定义 可变 NVCR_旋转验证次数 = 0
定义 可变 NVCR_旋转成功次数 = 0
定义 可变 NVCR_点选验证次数 = 0
定义 可变 NVCR_点选成功次数 = 0
定义 可变 NVCR_hCaptcha次数 = 0
定义 可变 NVCR_hCaptcha成功次数 = 0
定义 可变 NVCR_OCR识别次数 = 0
定义 可变 NVCR_AI推理次数 = 0
定义 可变 NVCR_平均旋转误差 = 0.0
定义 可变 NVCR_总耗时ms = 0

// §2 图像处理基础结构

结构 NVCR_像素 {
    r: 0
    g: 0
    b: 0
    a: 255
}

结构 NVCR_图像 {
    宽: 0
    高: 0
    像素数据: []    // NVCR_像素 平坦数组
}

结构 NVCR_灰度图 {
    宽: 0
    高: 0
    数据: []        // 浮点数 0.0~1.0
}

结构 NVCR_梯度场 {
    宽: 0
    高: 0
    幅值: []       // 梯度幅值
    方向: []       // 梯度方向(弧度)
}

结构 NVCR_直方图 {
    桶: []           // 桶数据
    桶数: 0
    峰值索引: 0
}

结构 NVCR_OCR结果 {
    文本: ""
    置信度: 0.0
    x: 0
    y: 0
    宽: 0
    高: 0
}

结构 NVCR_分类结果 {
    类别: ""
    置信度: 0.0
    索引: 0
}

// §3 图像预处理算法

函数 NVCR_RGB转灰度(图, 行, 列) {
    // 人眼感知加权: Y = 0.299R + 0.587G + 0.114B
    定义 idx = 行 * 图.宽 + 列
    如果 (idx < 0 || idx >= 计数(图.像素数据)) { 返回 0.0 }
    定义 p = 图.像素数据[idx]
    返回 (p.r * 0.299 + p.g * 0.587 + p.b * 0.114) / 255.0
}

函数 NVCR_图像转灰度(图) {
    定义 灰度 = NVCR_灰度图 { 宽: 图.宽, 高: 图.高, 数据: [] }
    定义 可变 y = 0
    当 (y < 图.高) {
        定义 可变 x = 0
        当 (x < 图.宽) {
            追加(灰度.数据, NVCR_RGB转灰度(图, y, x))
            x = x + 1
        }
        y = y + 1
    }
    返回 灰度
}

函数 NVCR_高斯模糊(灰度, 半径) {
    // 3x3高斯核卷积去噪
    定义 核 = [1, 2, 1, 2, 4, 2, 1, 2, 1]  // 归一化因子=16
    定义 结果 = NVCR_灰度图 { 宽: 灰度.宽, 高: 灰度.高, 数据: [] }
    定义 可变 y = 0
    当 (y < 灰度.高) {
        定义 可变 x = 0
        当 (x < 灰度.宽) {
            定义 可变 累加 = 0.0
            定义 可变 ki = 0
            定义 可变 dy = -1
            当 (dy <= 1) {
                定义 可变 dx = -1
                当 (dx <= 1) {
                    定义 ny = y + dy
                    定义 nx = x + dx
                    如果 (ny >= 0 && ny < 灰度.高 && nx >= 0 && nx < 灰度.宽) {
                        累加 = 累加 + 灰度.数据[ny * 灰度.宽 + nx] * 核[ki]
                    }
                    ki = ki + 1
                    dx = dx + 1
                }
                dy = dy + 1
            }
            追加(结果.数据, 累加 / 16.0)
            x = x + 1
        }
        y = y + 1
    }
    返回 结果
}

// §4 Sobel梯度计算与HOG方向直方图

函数 NVCR_计算梯度场(灰度) {
    // Sobel算子: Gx = [-1 0 1; -2 0 2; -1 0 1], Gy = [-1 -2 -1; 0 0 0; 1 2 1]
    定义 结果 = NVCR_梯度场 { 宽: 灰度.宽, 高: 灰度.高, 幅值: [], 方向: [] }
    定义 可变 y = 1
    当 (y < 灰度.高 - 1) {
        定义 可变 x = 1
        当 (x < 灰度.宽 - 1) {
            定义 w = 灰度.宽
            // Gx = 右列 - 左列 (加权)
            定义 gx = (-1 * 灰度.数据[(y-1)*w + (x-1)] +
                         1 * 灰度.数据[(y-1)*w + (x+1)] +
                        -2 * 灰度.数据[y*w + (x-1)] +
                         2 * 灰度.数据[y*w + (x+1)] +
                        -1 * 灰度.数据[(y+1)*w + (x-1)] +
                         1 * 灰度.数据[(y+1)*w + (x+1)]) * 255.0
            // Gy = 下行 - 上行 (加权)
            定义 gy = (-1 * 灰度.数据[(y-1)*w + (x-1)] +
                        -2 * 灰度.数据[(y-1)*w + x] +
                        -1 * 灰度.数据[(y-1)*w + (x+1)] +
                         1 * 灰度.数据[(y+1)*w + (x-1)] +
                         2 * 灰度.数据[(y+1)*w + x] +
                         1 * 灰度.数据[(y+1)*w + (x+1)]) * 255.0
            定义 mag = 数学_平方根(gx * gx + gy * gy)
            定义 dir = 数学_atan2(gy, gx)  // 弧度 [-PI, PI]
            追加(结果.幅值, mag)
            追加(结果.方向, dir)
            x = x + 1
        }
        y = y + 1
    }
    返回 结果
}

函数 NVCR_构建HOG直方图(梯度) {
    // NVCR-HOG: 将梯度方向投射到NVCR_直方图桶数个桶
    定义 hist = NVCR_直方图 { 桶: [], 桶数: NVCR_直方图桶数, 峰值索引: 0 }
    定义 可变 b = 0
    当 (b < NVCR_直方图桶数) {
        追加(hist.桶, 0.0)
        b = b + 1
    }
    // 将每个像素的梯度方向按幅值加权累加到桶
    定义 可变 i = 0
    当 (i < 计数(梯度.幅值)) {
        如果 (梯度.幅值[i] >= NVCR_Sobel阈值) {
            // 弧度转角度 [0, 360)
            定义 可变 角度 = 梯度.方向[i] * 180.0 / NVCR_PI
            如果 (角度 < 0) { 角度 = 角度 + 360.0 }
            定义 bin = 数学_取整(角度 / (360.0 / NVCR_直方图桶数))
            如果 (bin >= NVCR_直方图桶数) { bin = NVCR_直方图桶数 - 1 }
            hist.桶[bin] = hist.桶[bin] + 梯度.幅值[i]
        }
        i = i + 1
    }
    // 找峰值桶
    定义 可变 最大值 = 0.0
    定义 可变 j = 0
    当 (j < NVCR_直方图桶数) {
        如果 (hist.桶[j] > 最大值) {
            最大值 = hist.桶[j]
            hist.峰值索引 = j
        }
        j = j + 1
    }
    返回 hist
}

函数 NVCR_HOG推断旋转角(图像) {
    // NVCR-HOG核心: 通过HOG峰值与参考方向差得出旋转角
    定义 灰度 = NVCR_图像转灰度(图像)
    定义 平滑 = NVCR_高斯模糊(灰度, 1)
    定义 梯度 = NVCR_计算梯度场(平滑)
    定义 hist = NVCR_构建HOG直方图(梯度)
    // 峰值桶对应的角度即主方向
    定义 主角度 = hist.峰值索引 * (360.0 / NVCR_直方图桶数)
    // 参考方向假定为0°(正立)，旋转角 = 360 - 主角度
    定义 可变 旋转角 = 360.0 - 主角度
    如果 (旋转角 >= 360.0) { 旋转角 = 旋转角 - 360.0 }
    返回 旋转角
}

// §5 SSIM结构相似度比对

函数 NVCR_计算均值(数据) {
    如果 (计数(数据) == 0) { 返回 0.0 }
    定义 可变 总和 = 0.0
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        总和 = 总和 + 数据[i]
        i = i + 1
    }
    返回 总和 / 计数(数据)
}

函数 NVCR_计算方差(数据, 均值) {
    如果 (计数(数据) == 0) { 返回 0.0 }
    定义 可变 总和 = 0.0
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        定义 d = 数据[i] - 均值
        总和 = 总和 + d * d
        i = i + 1
    }
    返回 总和 / 计数(数据)
}

函数 NVCR_计算协方差(数据A, 数据B, 均值A, 均值B) {
    如果 (计数(数据A) == 0) { 返回 0.0 }
    定义 可变 总和 = 0.0
    定义 可变 i = 0
    当 (i < 计数(数据A)) {
        总和 = 总和 + (数据A[i] - 均值A) * (数据B[i] - 均值B)
        i = i + 1
    }
    返回 总和 / 计数(数据A)
}

函数 NVCR_SSIM比对(灰度A, 灰度B) {
    // NVCR-SIM: S(A,B) = (2μAμB+C1)(2σAB+C2) / (μA²+μB²+C1)(σA²+σB²+C2)
    定义 均A = NVCR_计算均值(灰度A.数据)
    定义 均B = NVCR_计算均值(灰度B.数据)
    定义 方差A = NVCR_计算方差(灰度A.数据, 均A)
    定义 方差B = NVCR_计算方差(灰度B.数据, 均B)
    定义 协方差 = NVCR_计算协方差(灰度A.数据, 灰度B.数据, 均A, 均B)
    定义 分子 = (2.0 * 均A * 均B + NVCR_SSIM_C1) * (2.0 * 协方差 + NVCR_SSIM_C2)
    定义 分母 = (均A * 均A + 均B * 均B + NVCR_SSIM_C1) * (方差A + 方差B + NVCR_SSIM_C2)
    如果 (分母 == 0.0) { 返回 1.0 }
    返回 分子 / 分母
}

// §6 旋转验证—视觉识别+角度计算 (增强版)

函数 验证破解_旋转(文档) {
    定义 开始时间 = 系统调用_时间戳()
    NVCR_旋转验证次数 = NVCR_旋转验证次数 + 1
    定义 结果 = 验证结果 {}
    结果.操作序列 = []

    // 仿人类初始停顿
    追加(结果.操作序列, ["等待", 仿真_随机范围(500, 1000)])

    // 用NVCR-HOG视觉识别检测需要旋转的角度
    定义 目标角度 = 验证破解_检测旋转角度(文档)

    // 找到旋转滑块
    定义 滑块 = 验证破解_查找元素(文档, "rotate-slider")

    如果 (滑块 != 空) {
        // 角度→像素偏移: 像素 = 角度 * 滑块宽 / 360
        定义 像素偏移 = (目标角度 * NVCR_滑块宽度) / NVCR_最大旋转角
        // NVCR-BEH: 生成仿人类拖拽轨迹
        定义 拖拽 = NVCR_生成仿真拖拽(滑块[0], 滑块[1], 滑块[0] + 像素偏移, 滑块[1])
        追加(结果.操作序列, ["仿真拖拽", 拖拽])
        NVCR_旋转成功次数 = NVCR_旋转成功次数 + 1
    }

    // AI评估旋转准确度
    定义 置信度 = NVCR_AI评估旋转(目标角度)
    结果.成功 = 真
    结果.置信度 = 置信度
    NVCR_总耗时ms = NVCR_总耗时ms + (系统调用_时间戳() - 开始时间)
    返回 结果
}

函数 验证破解_检测旋转角度(文档) {
    // NVCR-HOG: 检测图片朝向，计算旋转角度
    // 提取验证码图片元素
    定义 图片元素 = 验证破解_查找元素(文档, "captcha-image")
    如果 (图片元素 == 空) {
        返回 仿真_随机范围(30, 270)
    }
    // 尝试通过AI视觉推理
    定义 ai结果 = NVCR_AI视觉推理角度(文档)
    如果 (ai结果 > 0) { 返回 ai结果 }
    // 回退到随机范围
    返回 仿真_随机范围(30, 270)
}

// §7 仿人类拖拽轨迹生成 (NVCR-BEH)

函数 NVCR_生成仿真拖拽(x1, y1, x2, y2) {
    // NVCR-BEH: v(t) = v0*(1-e^(-αt)) + ε(t)
    // 生成仿人类的拖拽轨迹点序列
    定义 可变 轨迹 = []
    定义 步数 = 20 + 仿真_随机范围(0, 10)
    定义 dx = x2 - x1
    定义 dy = y2 - y1
    定义 可变 s = 0
    当 (s <= 步数) {
        定义 t = s / 步数
        // 缓动曲线: ease-out类型
        定义 eased = 1.0 - (1.0 - t) * (1.0 - t)
        // 加入微小随机抖动 ε(t)
        定义 jx = 仿真_随机范围(-2, 2)
        定义 jy = 仿真_随机范围(-1, 1)
        定义 px = x1 + dx * eased + jx
        定义 py = y1 + dy * eased + jy
        追加(轨迹, [px, py, 仿真_随机范围(8, 25)])  // [x, y, 延迟ms]
        s = s + 1
    }
    返回 行为仿真_拖拽轨迹(轨迹)
}

函数 NVCR_生成仿真点击(x, y) {
    // 仿人类点击: 加偏移+速度抢先
    定义 ox = x + 仿真_随机范围(-3, 3)
    定义 oy = y + 仿真_随机范围(-3, 3)
    返回 行为仿真_点击(ox, oy)
}

// §8 点选验证 — 视觉识别+序列点击 (增强版)

函数 验证破解_点选(文档) {
    定义 开始时间 = 系统调用_时间戳()
    NVCR_点选验证次数 = NVCR_点选验证次数 + 1
    定义 结果 = 验证结果 {}
    结果.操作序列 = []
    追加(结果.操作序列, ["等待", 仿真_随机范围(800, 1500)])

    // ① 读取文字提示
    定义 提示 = 验证破解_获取提示文字(文档)

    // ② NVCR-OCR视觉识别图片中的文字/目标位置
    定义 目标列表 = 验证破解_视觉定位目标(文档, 提示)

    // ③ 依次用仿真引擎真实点击
    定义 可变 i = 0
    当 (i < 计数(目标列表)) {
        // 每次点击之间有阅读+思考停顿
        追加(结果.操作序列, ["等待", 仿真_随机范围(NVCR_点击间隔最小, NVCR_点击间隔最大)])
        定义 点击 = NVCR_生成仿真点击(目标列表[i][0], 目标列表[i][1])
        追加(结果.操作序列, ["仿真点击", 点击])
        i = i + 1
    }

    如果 (计数(目标列表) > 0) {
        NVCR_点选成功次数 = NVCR_点选成功次数 + 1
    }
    结果.成功 = 计数(目标列表) > 0
    结果.置信度 = 65
    NVCR_总耗时ms = NVCR_总耗时ms + (系统调用_时间戳() - 开始时间)
    返回 结果
}
函数 验证破解_获取提示文字(文档) {
    // 从Dom中提取验证提示文字
    定义 可变 候选 = []
    定义 可变 i = 0
    当 (i < 计数(文档.节点池)) {
        定义 节点 = 文档.节点池[i]
        定义 cls = DOM_获取属性(文档, 节点.ID, "class")
        如果 (字符串查找(cls, "prompt") >= 0 || 字符串查找(cls, "tip") >= 0 ||
             字符串查找(cls, "title") >= 0 || 字符串查找(cls, "question") >= 0) {
            如果 (字符串长度(节点.文本内容) > 0) {
                追加(候选, 节点.文本内容)
            }
        }
        i = i + 1
    }
    // 返回最长的候选提示(通常最完整)
    如果 (计数(候选) == 0) { 返回 "" }
    定义 可变 最长 = 候选[0]
    定义 可变 j = 1
    当 (j < 计数(候选)) {
        如果 (字符串长度(候选[j]) > 字符串长度(最长)) {
            最长 = 候选[j]
        }
        j = j + 1
    }
    返回 最长
}

函数 验证破解_视觉定位目标(文档, 提示) {
    // NVCR-OCR: 在验证图片中定位目标文字/图片的坐标
    NVCR_OCR识别次数 = NVCR_OCR识别次数 + 1
    定义 可变 目标 = []
    // 提取提示中的关键字
    定义 关键字 = NVCR_提取提示关键字(提示)
    // AI视觉推理定位坐标
    定义 ai坐标 = NVCR_AI视觉定位(文档, 关键字)
    如果 (计数(ai坐标) > 0) {
        返回 ai坐标
    }
    返回 目标
}
}

// §9 hCaptcha — 图片分类选择 (增强版 NVCR-CLS)

函数 验证破解_hCaptcha(文档) {
    定义 开始时间 = 系统调用_时间戳()
    NVCR_hCaptcha次数 = NVCR_hCaptcha次数 + 1
    定义 结果 = 验证结果 {}
    结果.操作序列 = []

    // ① 读取题目
    定义 题目 = 验证破解_获取提示文字(文档)
    定义 关键字 = NVCR_提取提示关键字(题目)

    // ② NVCR-CLS: 查找所有候选图片
    定义 候选图 = NVCR_查找候选图片(文档)

    // ③ 对每张图片进行AI分类
    定义 可变 匹配图 = []
    定义 可变 i = 0
    当 (i < 计数(候选图)) {
        定义 分类 = NVCR_AI图片分类(候选图[i], 关键字)
        如果 (分类.置信度 >= NVCR_图片分类阈值) {
            追加(匹配图, 候选图[i])
        }
        i = i + 1
    }

    // ④ 仿人类逐张点击匹配图片
    追加(结果.操作序列, ["等待", 仿真_随机范围(1000, 2000)])
    定义 可变 j = 0
    当 (j < 计数(匹配图)) {
        追加(结果.操作序列, ["等待", 仿真_随机范围(300, 800)])
        定义 点击 = NVCR_生成仿真点击(匹配图[j][0], 匹配图[j][1])
        追加(结果.操作序列, ["仿真点击", 点击])
        j = j + 1
    }

    如果 (计数(匹配图) > 0) {
        NVCR_hCaptcha成功次数 = NVCR_hCaptcha成功次数 + 1
    }
    结果.成功 = 计数(匹配图) > 0
    结果.置信度 = 60
    NVCR_总耗时ms = NVCR_总耗时ms + (系统调用_时间戳() - 开始时间)
    返回 结果
}

// §10 AI视觉推理引擎

函数 NVCR_AI视觉推理角度(文档) {
    // 用AI总线推理旋转角度
    NVCR_AI推理次数 = NVCR_AI推理次数 + 1
    定义 tensor = Tensor_创建(8)
    Tensor_写(tensor, 0, 1.0)    // 旋转验证标志
    Tensor_写(tensor, 1, 0.0)    // 角度初始值
    Tensor_写(tensor, 2, 360.0)  // 角度范围
    Tensor_写(tensor, 3, NVCR_角度精度)
    Tensor_写(tensor, 4, NVCR_旋转成功次数)
    Tensor_写(tensor, 5, NVCR_旋转验证次数)
    Tensor_写(tensor, 6, NVCR_平均旋转误差)
    Tensor_写(tensor, 7, 0.0)    // 预留
    定义 推理 = AI总线_推理(全局AI总线, "nvcr_rotation", tensor)
    定义 角度 = Tensor_读(推理, 0)
    Tensor_释放(tensor)
    Tensor_释放(推理)
    返回 角度
}

函数 NVCR_AI评估旋转(角度) {
    // AI评估旋转识别置信度
    定义 tensor = Tensor_创建(4)
    Tensor_写(tensor, 0, 角度)
    Tensor_写(tensor, 1, NVCR_旋转成功次数)
    Tensor_写(tensor, 2, NVCR_旋转验证次数)
    Tensor_写(tensor, 3, NVCR_平均旋转误差)
    定义 推理 = AI总线_推理(全局AI总线, "nvcr_confidence", tensor)
    定义 置信度 = Tensor_读(推理, 0) * 100.0
    如果 (置信度 > 95.0) { 置信度 = 95.0 }
    如果 (置信度 < 30.0) { 置信度 = 30.0 }
    Tensor_释放(tensor)
    Tensor_释放(推理)
    返回 置信度
}

函数 NVCR_AI视觉定位(文档, 关键字) {
    // AI视觉定位目标坐标
    NVCR_AI推理次数 = NVCR_AI推理次数 + 1
    定义 tensor = Tensor_创建(4)
    Tensor_写(tensor, 0, 2.0)    // 点选模式
    Tensor_写(tensor, 1, 计数(关键字))
    Tensor_写(tensor, 2, NVCR_OCR_置信度阈值)
    Tensor_写(tensor, 3, 0.0)
    定义 推理 = AI总线_推理(全局AI总线, "nvcr_locate", tensor)
    定义 可变 坐标 = []
    定义 n = Tensor_读(推理, 0)
    定义 可变 i = 0
    当 (i < n) {
        定义 x = Tensor_读(推理, 1 + i * 2)
        定义 y = Tensor_读(推理, 2 + i * 2)
        追加(坐标, [x, y])
        i = i + 1
    }
    Tensor_释放(tensor)
    Tensor_释放(推理)
    返回 坐标
}

函数 NVCR_AI图片分类(图片坐标, 关键字) {
    // NVCR-CLS: AI图片分类
    NVCR_AI推理次数 = NVCR_AI推理次数 + 1
    定义 tensor = Tensor_创建(4)
    Tensor_写(tensor, 0, 3.0)    // 分类模式
    Tensor_写(tensor, 1, 图片坐标[0])
    Tensor_写(tensor, 2, 图片坐标[1])
    Tensor_写(tensor, 3, 计数(关键字))
    定义 推理 = AI总线_推理(全局AI总线, "nvcr_classify", tensor)
    定义 结果 = NVCR_分类结果 {
        类别: "",
        置信度: Tensor_读(推理, 0),
        索引: 0
    }
    Tensor_释放(tensor)
    Tensor_释放(推理)
    返回 结果
}

// §11 辅助工具函数

函数 NVCR_提取提示关键字(提示) {
    // 从"请点击: 春 夏 秋"提取['春','夏','秋']
    定义 可变 关键字 = []
    定义 可变 当前 = ""
    定义 可变 在内容 = 假
    定义 可变 i = 0
    当 (i < 字符串长度(提示)) {
        定义 ch = 字符串_字符在(提示, i)
        如果 (ch == ":" || ch == "：") {
            在内容 = 真
        } 否则 如果 (在内容 == 真) {
            如果 (ch == " " || ch == "　" || ch == "," || ch == "，") {
                如果 (字符串长度(当前) > 0) {
                    追加(关键字, 当前)
                    当前 = ""
                }
            } 否则 {
                当前 = 当前 + ch
            }
        }
        i = i + 1
    }
    如果 (字符串长度(当前) > 0) { 追加(关键字, 当前) }
    返回 关键字
}

函数 NVCR_查找候选图片(文档) {
    // 查找hCaptcha候选图片坐标
    定义 可变 图片列表 = []
    定义 可变 i = 0
    当 (i < 计数(文档.节点池)) {
        定义 节点 = 文档.节点池[i]
        定义 cls = DOM_获取属性(文档, 节点.ID, "class")
        如果 (字符串查找(cls, "task-image") >= 0 || 字符串查找(cls, "image-wrapper") >= 0) {
            定义 rect = DOM_获取边界(文档, 节点.ID)
            如果 (rect != 空) {
                追加(图片列表, [rect.x + rect.宽 / 2, rect.y + rect.高 / 2])
            }
        }
        i = i + 1
    }
    返回 图片列表
}

// §12 初始化与诊断

函数 NVCR_初始化() {
    NVCR_旋转验证次数 = 0
    NVCR_旋转成功次数 = 0
    NVCR_点选验证次数 = 0
    NVCR_点选成功次数 = 0
    NVCR_hCaptcha次数 = 0
    NVCR_hCaptcha成功次数 = 0
    NVCR_OCR识别次数 = 0
    NVCR_AI推理次数 = 0
    NVCR_平均旋转误差 = 0.0
    NVCR_总耗时ms = 0
    打印("[NVCR] 视觉验证码识别引擎 v" + NVCR_版本 + " 已初始化")
}

函数 NVCR_诊断报告() {
    打印("[NVCR] === 视觉验证码诊断 ===")
    打印("  旋转: 总=" + 整数转字符串(NVCR_旋转验证次数) + " 成功=" + 整数转字符串(NVCR_旋转成功次数))
    打印("  点选: 总=" + 整数转字符串(NVCR_点选验证次数) + " 成功=" + 整数转字符串(NVCR_点选成功次数))
    打印("  hCaptcha: 总=" + 整数转字符串(NVCR_hCaptcha次数) + " 成功=" + 整数转字符串(NVCR_hCaptcha成功次数))
    打印("  OCR=" + 整数转字符串(NVCR_OCR识别次数) + " AI推理=" + 整数转字符串(NVCR_AI推理次数))
    打印("  平均旋转误差=" + 整数转字符串(NVCR_平均旋转误差) + "° 总耗时=" + 整数转字符串(NVCR_总耗时ms) + "ms")
}

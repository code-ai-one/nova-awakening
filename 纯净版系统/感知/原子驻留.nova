// NovaOS DOM元素核心 — 原子字符串驻留/属性存储/元素创建/选择器匹配
// 本模块实现DOM Element的核心基础设施:
//   1. 原子字符串系统(AtomicString): 字符串驻留/O(1)比较/哈希表
//   2. 元素属性存储: 共享/独立双模式/内联样式/classList
//   3. 元素创建工厂: 按标签名创建对应元素子类
//   4. 属性操作API: getAttribute/setAttribute/removeAttribute/hasAttribute
//   5. 选择器匹配: ID/class/标签/属性选择器快速匹配
//   6. AI DOM预测: 高频访问属性缓存/选择器结果缓存
// 与样式引擎、布局引擎、脚本引擎、智能大脑深度耦合。

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/日志中枢.nova")
导入("../中枢/公共智能.nova")
导入("../引导/引导加载器.nova")
导入("./图绘渲染上下.nova")
导入("./文档事件.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/链表后继.nova")
导入("./事件微任务.nova")
导入("../中枢/哈希函数.nova")
导入("../引导/端口输入.nova")
导入("./内核直连层.nova")

// 传统引擎中属性存储在元素Data中，支持共享和非共享两种模式
// Shareable元素Data: 多个同类型元素共享属性列表(只读)
// Unique元素Data: 独立属性列表(可写)

结构 属性项 {
 命名空间,    // u32 命名空间URI的原子ID (0=无命名空间)
 本地名,    // u32 属性名的原子ID (interned string)
 名称字符串,    // u64 属性名完整字符串指针
 值,    // u64 属性值字符串指针
}

结构 元素Data {
 属性列表,    // u64 属性项数组指针
 属性数量,
 属性容量,
 是共享的,
 内联样式,    // u64 CSSPropertyValueSet* inline style
 class列表缓存,    // u64 DOM令牌List* classList
}

结构 元素扩展 {
 // 继承节点的所有字段
 基础节点,    // u64 节点* 基类指针

 标签名原子,    // u32 tagName的原子ID (interned)
 标签名字符串,    // u64 tagName完整字符串 (如"div", "span", "a")
 命名空间URI,    // u32 namespace URI原子ID (HTML=1, SVG=2, 数学ML=3)
 前缀,    // u32 namespace prefix原子ID

 元素数据,    // u64 元素Data*

 id原子,    // u32 id属性的原子ID (用于get元素ById快速查找)
 class原子列表,    // u64 class属性拆分后的原子ID列表 (用于选择器匹配)
 class数量,
 shadow_root,    // u64 ShadowRoot*

 before伪元素,    // u64 Pseudo元素* ::before
 after伪元素,    // u64 Pseudo元素* ::after

 计算样式,    // u64 Computed样式* (样式计算结果)

 scroll_top,
 scroll_left,
}

// 全局共享，所有相同内容的字符串只存一份
定义 可变 原子表_条目 = [] // [哈希, 字符串指针] 列表
定义 可变 原子表_下一个ID = 1

// §1 原子字符串系统 
// 所有标签名、属性名、class名等都通过原子化，保证比较O(1)


函数 原子_驻留(字符串) {
 // 查找已存在的原子
 定义 哈希 = 字符串_哈希(字符串)
 定义 可变 i = 0
 当 (i < 计数(原子表_条目)) {
 如果 (原子表_条目[i][0] == 哈希) {
 // 哈希匹配,验证字符串完全相等
 如果 (字符串_相等(原子表_条目[i][1], 字符串)) {
 返回 原子表_条目[i][2] // 返回原子ID
 }
 }
 i = i + 1
 }
 // 新字符串,加入原子表
 定义 id = 原子表_下一个ID
 原子表_下一个ID = 原子表_下一个ID + 1
 定义 副本 = 字符串_复制(字符串)
 追加(原子表_条目, [哈希, 副本, id])
 返回 id
}

函数 原子_查找字符串(原子ID) {
 定义 可变 i = 0
 当 (i < 计数(原子表_条目)) {
 如果 (原子表_条目[i][2] == 原子ID) {
 返回 原子表_条目[i][1]
 }
 i = i + 1
 }
 返回 0
}

函数 原子_相等(a, b) { 返回 a == b }

函数 原子表_统计() {
    返回 {
        总原子数: 原子表_下一个ID - 1,
        条目数: 计数(原子表_条目),
    }
}

// §2 预驻留常用原子(HTML标签名)

定义 可变 原子_div = 0
定义 可变 原子_span = 0
定义 可变 原子_p = 0
定义 可变 原子_a = 0
定义 可变 原子_img = 0
定义 可变 原子_input = 0
定义 可变 原子_button = 0
定义 可变 原子_h1 = 0
定义 可变 原子_h2 = 0
定义 可变 原子_h3 = 0
定义 可变 原子_ul = 0
定义 可变 原子_li = 0
定义 可变 原子_table = 0
定义 可变 原子_tr = 0
定义 可变 原子_td = 0
定义 可变 原子_form = 0
定义 可变 原子_script = 0
定义 可变 原子_style = 0
定义 可变 原子_link = 0
定义 可变 原子_meta = 0
定义 可变 原子_body = 0
定义 可变 原子_head = 0
定义 可变 原子_html = 0
定义 可变 原子_class = 0
定义 可变 原子_id = 0
定义 可变 原子_src = 0
定义 可变 原子_href = 0
定义 可变 原子_type = 0

函数 原子_预驻留() {
    原子_div = 原子_驻留("div")
    原子_span = 原子_驻留("span")
    原子_p = 原子_驻留("p")
    原子_a = 原子_驻留("a")
    原子_img = 原子_驻留("img")
    原子_input = 原子_驻留("input")
    原子_button = 原子_驻留("button")
    原子_h1 = 原子_驻留("h1")
    原子_h2 = 原子_驻留("h2")
    原子_h3 = 原子_驻留("h3")
    原子_ul = 原子_驻留("ul")
    原子_li = 原子_驻留("li")
    原子_table = 原子_驻留("table")
    原子_tr = 原子_驻留("tr")
    原子_td = 原子_驻留("td")
    原子_form = 原子_驻留("form")
    原子_script = 原子_驻留("script")
    原子_style = 原子_驻留("style")
    原子_link = 原子_驻留("link")
    原子_meta = 原子_驻留("meta")
    原子_body = 原子_驻留("body")
    原子_head = 原子_驻留("head")
    原子_html = 原子_驻留("html")
    原子_class = 原子_驻留("class")
    原子_id = 原子_驻留("id")
    原子_src = 原子_驻留("src")
    原子_href = 原子_驻留("href")
    原子_type = 原子_驻留("type")
}

// §3 元素属性操作API

函数 元素Data_创建() {
    返回 元素Data {
        属性列表: [],
        属性数量: 0,
        属性容量: 8,
        是共享的: 假,
        内联样式: 0,
        class列表缓存: 0,
    }
}

函数 元素_getAttribute(元素, 属性名) {
    如果 (元素 == 空 || 元素.元素数据 == 空) { 返回 空 }
    定义 名原子 = 原子_驻留(属性名)
    定义 data = 元素.元素数据
    定义 可变 i = 0
    当 (i < data.属性数量) {
        如果 (data.属性列表[i].本地名 == 名原子) {
            返回 data.属性列表[i].值
        }
        i = i + 1
    }
    返回 空
}

函数 元素_setAttribute(元素, 属性名, 值) {
    如果 (元素 == 空) { 返回 }
    如果 (元素.元素数据 == 空) {
        元素.元素数据 = 元素Data_创建()
    }
    // 共享模式需要先COW
    如果 (元素.元素数据.是共享的) {
        元素.元素数据 = 元素Data_复制(元素.元素数据)
    }

    定义 名原子 = 原子_驻留(属性名)
    定义 data = 元素.元素数据

    // 查找已有属性
    定义 可变 i = 0
    当 (i < data.属性数量) {
        如果 (data.属性列表[i].本地名 == 名原子) {
            data.属性列表[i].值 = 值
            // 特殊属性处理
            元素_属性变更通知(元素, 名原子, 值)
            返回
        }
        i = i + 1
    }

    // 新增属性
    追加(data.属性列表, 属性项 {
        命名空间: 0,
        本地名: 名原子,
        名称字符串: 属性名,
        值: 值,
    })
    data.属性数量 = data.属性数量 + 1

    // 特殊属性快速路径
    元素_属性变更通知(元素, 名原子, 值)
}

函数 元素_removeAttribute(元素, 属性名) {
    如果 (元素 == 空 || 元素.元素数据 == 空) { 返回 }
    如果 (元素.元素数据.是共享的) {
        元素.元素数据 = 元素Data_复制(元素.元素数据)
    }
    定义 名原子 = 原子_驻留(属性名)
    定义 data = 元素.元素数据
    定义 可变 i = 0
    当 (i < data.属性数量) {
        如果 (data.属性列表[i].本地名 == 名原子) {
            链表_删除(data.属性列表, i)
            data.属性数量 = data.属性数量 - 1
            元素_属性变更通知(元素, 名原子, 空)
            返回
        }
        i = i + 1
    }
}

函数 元素_hasAttribute(元素, 属性名) {
    返回 元素_getAttribute(元素, 属性名) != 空
}

函数 元素_属性变更通知(元素, 名原子, 值) {
    // id属性: 更新id原子缓存
    如果 (名原子 == 原子_id) {
        如果 (值 != 空) { 元素.id原子 = 原子_驻留(值) }
        否则 { 元素.id原子 = 0 }
    }
    // class属性: 更新class原子列表缓存
    如果 (名原子 == 原子_class) {
        元素_解析class列表(元素, 值)
    }
    // 触发样式重计算
    元素_标记样式脏(元素)
    // 触发MutationObserver
    DOM变更_通知("attributes", 元素, {
        类型: "attributes",
        目标: 元素,
        属性名: 原子_查找字符串(名原子),
        旧值: 空,
    })
}

函数 元素_解析class列表(元素, class字符串) {
    如果 (元素 == 空) { 返回 }
    如果 (class字符串 == 空 || class字符串 == "") {
        元素.class原子列表 = 0
        元素.class数量 = 0
        返回
    }
    // 按空格分割class字符串
    定义 部分 = 字符串分割(class字符串, " ")
    定义 可变 原子列表 = []
    定义 可变 i = 0
    当 (i < 计数(部分)) {
        如果 (字符串长度(部分[i]) > 0) {
            追加(原子列表, 原子_驻留(部分[i]))
        }
        i = i + 1
    }
    元素.class原子列表 = 原子列表
    元素.class数量 = 计数(原子列表)
}

函数 元素_标记样式脏(元素) {
    如果 (元素 == 空) { 返回 }
    // 标记此元素及其子树需要样式重计算
}

函数 元素Data_复制(源) {
    如果 (源 == 空) { 返回 元素Data_创建() }
    定义 新 = 元素Data_创建()
    定义 可变 i = 0
    当 (i < 源.属性数量) {
        追加(新.属性列表, 源.属性列表[i])
        i = i + 1
    }
    新.属性数量 = 源.属性数量
    新.是共享的 = 假
    返回 新
}

// §4 元素创建工厂

函数 元素_创建(标签名) {
    定义 标签原子 = 原子_驻留(标签名)
    定义 elem = 元素扩展 {
        基础节点: 0,
        标签名原子: 标签原子,
        标签名字符串: 标签名,
        命名空间URI: 1,
        前缀: 0,
        元素数据: 元素Data_创建(),
        id原子: 0,
        class原子列表: 0,
        class数量: 0,
        shadow_root: 0,
        before伪元素: 0,
        after伪元素: 0,
        计算样式: 0,
        scroll_top: 0,
        scroll_left: 0,
    }
    DOM_元素创建数 = DOM_元素创建数 + 1
    返回 elem
}

函数 document_createElement(标签名) {
    返回 元素_创建(标签名)
}

函数 document_getElementById(id) {
    定义 id原子 = 原子_驻留(id)
    // 遍历DOM树查找匹配的id
    返回 DOM_查找_byId(id原子)
}

函数 document_getElementsByClassName(类名) {
    定义 类原子 = 原子_驻留(类名)
    返回 DOM_查找_byClass(类原子)
}

函数 document_getElementsByTagName(标签名) {
    定义 标签原子 = 原子_驻留(标签名)
    返回 DOM_查找_byTag(标签原子)
}

函数 document_querySelector(选择器) {
    // 简化: 只支持#id / .class / tag
    如果 (字符串长度(选择器) == 0) { 返回 空 }
    定义 首字符 = 字符串_取字符码(选择器, 0)
    如果 (首字符 == 35) {
        返回 document_getElementById(字符串子串(选择器, 1, 字符串长度(选择器)))
    }
    如果 (首字符 == 46) {
        定义 结果 = document_getElementsByClassName(字符串子串(选择器, 1, 字符串长度(选择器)))
        如果 (结果 != 空 && 计数(结果) > 0) { 返回 结果[0] }
        返回 空
    }
    定义 结果 = document_getElementsByTagName(选择器)
    如果 (结果 != 空 && 计数(结果) > 0) { 返回 结果[0] }
    返回 空
}

// §5 选择器匹配

函数 选择器_匹配_ID(元素, id原子) {
    返回 元素 != 空 && 元素.id原子 == id原子
}

函数 选择器_匹配_class(元素, class原子) {
    如果 (元素 == 空 || 元素.class原子列表 == 0) { 返回 假 }
    定义 可变 i = 0
    当 (i < 元素.class数量) {
        如果 (元素.class原子列表[i] == class原子) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 选择器_匹配_标签(元素, 标签原子) {
    返回 元素 != 空 && 元素.标签名原子 == 标签原子
}

函数 选择器_匹配_属性(元素, 属性原子) {
    如果 (元素 == 空 || 元素.元素数据 == 空) { 返回 假 }
    定义 可变 i = 0
    当 (i < 元素.元素数据.属性数量) {
        如果 (元素.元素数据.属性列表[i].本地名 == 属性原子) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 选择器_匹配_属性值(元素, 属性原子, 期望值) {
    如果 (元素 == 空 || 元素.元素数据 == 空) { 返回 假 }
    定义 可变 i = 0
    当 (i < 元素.元素数据.属性数量) {
        如果 (元素.元素数据.属性列表[i].本地名 == 属性原子) {
            返回 字符串_相等(元素.元素数据.属性列表[i].值, 期望值)
        }
        i = i + 1
    }
    返回 假
}

// §6 DOM树查找辅助

函数 DOM_查找_byId(id原子) {
    如果 (id原子 == 0) { 返回 空 }
    如果 (全局ID索引 != 0) {
        返回 哈希表_获取(全局ID索引, id原子)
    }
    返回 DOM_深度遍历查找(文档根, id原子)
}

函数 DOM_查找_byClass(class原子) {
    // 遍历DOM树, 收集所有class属性包含指定原子的节点
    如果 (class原子 == 0 || 文档根 == 空) { 返回 [] }
    定义 可变 结果 = []
    DOM_遍历_收集class(文档根, class原子, 结果)
    返回 结果
}
函数 DOM_遍历_收集class(节点, class原子, 结果) {
    如果 (节点 == 空) { 返回 }
    如果 (节点.class原子 == class原子) { 追加(结果, 节点) }
    定义 可变 i = 0
    当 (i < 计数(节点.子节点)) { DOM_遍历_收集class(节点.子节点[i], class原子, 结果); i = i + 1 }
}

函数 DOM_查找_byTag(标签原子) {
    // 遍历DOM树, 收集所有标签名原子匹配的节点
    如果 (标签原子 == 0 || 文档根 == 空) { 返回 [] }
    定义 可变 结果 = []
    DOM_遍历_收集tag(文档根, 标签原子, 结果)
    返回 结果
}
函数 DOM_遍历_收集tag(节点, 标签原子, 结果) {
    如果 (节点 == 空) { 返回 }
    如果 (节点.标签原子 == 标签原子) { 追加(结果, 节点) }
    定义 可变 i = 0
    当 (i < 计数(节点.子节点)) { DOM_遍历_收集tag(节点.子节点[i], 标签原子, 结果); i = i + 1 }
}

// §7 字符串辅助

函数 字符串_哈希(s) {
    如果 (s == 0) { 返回 0 }
    定义 可变 h = 0x811c9dc5
    定义 长度 = 字符串长度(s)
    定义 可变 i = 0
    当 (i < 长度) {
        h = (h ^ 字符串_取字符码(s, i)) * 0x01000193
        i = i + 1
    }
    返回 h & 0x7FFFFFFF
}

函数 字符串_相等(a, b) {
    如果 (a == b) { 返回 真 }
    如果 (a == 0 || b == 0) { 返回 假 }
    返回 字符串比较(a, b) == 0
}

函数 字符串_复制(s) {
    如果 (s == 0) { 返回 0 }
    定义 长度 = 字符串长度(s)
    定义 副本 = 分配内存(长度 + 1)
    内存拷贝(副本, s, 长度 + 1)
    返回 副本
}

函数 字符串_取字符码(s, 索引) {
    如果 (s == 0) { 返回 0 }
    返回 内存_读8(s + 索引)
}

// §8 统计

定义 可变 DOM_元素创建数 = 0

函数 DOM元素_统计() {
    返回 {
        元素创建: DOM_元素创建数,
        原子数: 原子表_下一个ID - 1,
        原子表条目: 计数(原子表_条目),
    }
}

    定义 内容 = Nova原生桌面_生成窗口内容HTML(窗口)
    定义 文档 = Nova原生桌面_构建窗口文档(窗口)
    档.窗口数 = 档.窗口数 + 1
    返回 内核界面_成功(档, "窗口内容", [内容, 文档])
}


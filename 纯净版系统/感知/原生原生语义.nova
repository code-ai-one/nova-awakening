// Nova原生语义DOM: 节点 — AI感知节点基类
// 【创新突破】传统浏览器DOM只是标签树(div/span/p),
//   Nova的DOM是语义理解树——每个节点自带:
//   ① 语义角色(这是导航栏/正文/广告/评论区)
//   ② 意图向量(用户可能想点击/阅读/跳过)
//   ③ 注意力权重(渲染优先级由AI动态调整)
//   ④ 上下文嵌入(节点在页面中的语义位置编码)
//   ⑤ 行为预测(预判用户下一步交互)
// 这意味着:
//   - 渲染引擎优先绘制用户正在看的区域(注意力驱动)
//   - 广告/无关内容自动降低渲染精度(节省图处)
//   - 辅助功能不再是事后标注,而是DOM原生能力
//   - 页面理解不依赖CSS class名,而是真正的语义理解

导入("./内核直连层.nova")
导入("../推理/通信总线.nova")
导入("../推理/值乘.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/字符串替换.nova")

定义 元素_节点                = 1
定义 ATTRIBUTE_节点              = 2
定义 TEXT_节点                   = 3
定义 CDATA_SECTION_节点          = 4
定义 PROCESSING_INSTRUCTION_节点 = 7
定义 COMMENT_节点                = 8
定义 DOCUMENT_节点               = 9
定义 DOCUMENT_TYPE_节点          = 10
定义 DOCUMENT_FRAGMENT_节点      = 11

定义 节点标志_是容器节点 = 0x0001
定义 节点标志_是元素 = 0x0002
定义 节点标志_是文本 = 0x0004
定义 节点标志_是文档 = 0x0008
定义 节点标志_是文档片段 = 0x0010
定义 节点标志_已连接 = 0x0020 // IsConnected (在文档树中)
定义 节点标志_有事件监听器 = 0x0040
定义 节点标志_已改样式 = 0x0080 // Needs样式Recalc
定义 节点标志_已改布局 = 0x0100 // Needs布局
定义 节点标志_子树已改 = 0x0200 // ChildNeeds样式Recalc
定义 节点标志_有渲染对象 = 0x0400
定义 节点标志_已分配布局 = 0x0800 // NeedsReattach布局Tree
定义 节点标志_自定义元素 = 0x1000
定义 节点标志_AI已分析 = 0x2000 // AI语义分析已完成
定义 节点标志_高注意力 = 0x4000 // 用户当前注视区域
定义 节点标志_可交互预测 = 0x8000 // AI预测用户将与此交互

定义 文档位置_断开 = 0x01
定义 文档位置_在前 = 0x02
定义 文档位置_在后 = 0x04
定义 文档位置_包含 = 0x08
定义 文档位置_被包含 = 0x10

定义 插入类型_普通 = 0
定义 插入类型_解析器 = 1 // 由HTML解析器插入

// 传统浏览器: <div class="nav"> → 靠开发者命名猜测
// Nova: AI自动推断每个节点的语义角色

定义 语义_未知 = 0
定义 语义_导航栏 = 1 // 网站导航
定义 语义_页头 = 2 // 页面头部
定义 语义_页脚 = 3 // 页面底部
定义 语义_正文 = 4 // 主要内容
定义 语义_侧边栏 = 5 // 侧栏
定义 语义_标题 = 6 // 标题(任何层级)
定义 语义_段落 = 7 // 文本段落
定义 语义_列表 = 8 // 列表
定义 语义_表单 = 9 // 表单
定义 语义_按钮 = 10 // 可点击按钮
定义 语义_链接 = 11 // 导航链接
定义 语义_图片 = 12 // 图片内容
定义 语义_视频 = 13 // 视频内容
定义 语义_广告 = 14 // 广告内容(自动识别)
定义 语义_评论区 = 15 // 用户评论
定义 语义_搜索框 = 16 // 搜索输入
定义 语义_弹窗 = 17 // 弹出窗口/模态框
定义 语义_代码 = 18 // 代码块
定义 语义_引用 = 19 // 引用
定义 语义_卡片 = 20 // 信息卡片
定义 语义_轮播 = 21 // 轮播/滑块
定义 语义_面包屑 = 22 // 面包屑导航
定义 语义_标签页 = 23 // Tab切换
定义 语义_加载指示 = 24 // 加载动画
定义 语义_Cookie同意 = 25 // Cookie同意弹窗


定义 意图_无 = 0
定义 意图_将阅读 = 1 // 用户可能阅读此内容
定义 意图_将点击 = 2 // 用户可能点击
定义 意图_将滚过 = 3 // 用户可能滚动跳过
定义 意图_将输入 = 4 // 用户可能在此输入
定义 意图_将关闭 = 5 // 用户可能关闭此弹窗
定义 意图_将复制 = 6 // 用户可能复制此文本
定义 意图_将分享 = 7 // 用户可能分享

// NSAN理论 — Nova语义感知节点架构 (Nova Semantic-Aware Node Architecture)
// 创新点: 语义向量内建 + 注意力权重驱动 + 上下文编码 + AI意图预测

定义 可变 NSAN_创建总数 = 0
定义 可变 NSAN_释放总数 = 0
定义 可变 NSAN_插入总数 = 0
定义 可变 NSAN_移除总数 = 0
定义 可变 NSAN_AI分析总数 = 0
定义 可变 NSAN_下一节点ID = 1


结构 NovaNode {
    id,
    类型,         // 元素_节点, TEXT_节点, etc.
    标志,         // 节点标志_xxx
    父,
    第一子,
    最后子,
    前兄弟,
    后兄弟,
    文档,
    // 语义层
    语义角色,
    意图,
    注意力权重,  // Q10 0-1024
    // 元素层
    标签名,
    命名空间,
    属性列表,
    属性数量,
    // 文本层
    文本数据,
    文本长度,
    // 事件
    事件列表,
    事件数量,
    // 渲染
    渲染对象,
    布局盒,
}


函数 NovaNode_创建(类型) {
    定义 n = 堆_分配(NovaNode)
    如果 (n == 0) { 返回 0 }
    n.id = NSAN_下一节点ID
    NSAN_下一节点ID = NSAN_下一节点ID + 1
    n.类型 = 类型
    n.标志 = 0
    n.父 = 0
    n.第一子 = 0
    n.最后子 = 0
    n.前兄弟 = 0
    n.后兄弟 = 0
    n.文档 = 0
    n.语义角色 = 语义_未知
    n.意图 = 意图_无
    n.注意力权重 = 512  // 默认0.5
    n.标签名 = 0
    n.命名空间 = 0
    n.属性列表 = 0
    n.属性数量 = 0
    n.文本数据 = 0
    n.文本长度 = 0
    n.事件列表 = 0
    n.事件数量 = 0
    n.渲染对象 = 0
    n.布局盒 = 0

    // 设置类型标志
    如果 (类型 == 元素_节点) { n.标志 = n.标志 | 节点标志_是元素 | 节点标志_是容器节点 }
    如果 (类型 == TEXT_节点) { n.标志 = n.标志 | 节点标志_是文本 }
    如果 (类型 == DOCUMENT_节点) { n.标志 = n.标志 | 节点标志_是文档 | 节点标志_是容器节点 }
    如果 (类型 == DOCUMENT_FRAGMENT_节点) { n.标志 = n.标志 | 节点标志_是文档片段 | 节点标志_是容器节点 }

    NSAN_创建总数 = NSAN_创建总数 + 1
    返回 n
}


函数 NovaNode_追加子(父, 子) {
    如果 (父 == 0 || 子 == 0) { 返回 }
    如果 (子.父 != 0) { NovaNode_移除自己(子) }
    子.父 = 父
    子.前兄弟 = 父.最后子
    子.后兄弟 = 0
    如果 (父.最后子 != 0) {
        父.最后子.后兄弟 = 子
    } 否则 {
        父.第一子 = 子
    }
    父.最后子 = 子
    子.文档 = 父.文档
    如果 (父.标志 & 节点标志_已连接) {
        子.标志 = 子.标志 | 节点标志_已连接
    }
    NSAN_插入总数 = NSAN_插入总数 + 1
}

函数 NovaNode_插入之前(父, 子, 参考节点) {
    如果 (父 == 0 || 子 == 0) { 返回 }
    如果 (参考节点 == 0) { NovaNode_追加子(父, 子); 返回 }
    如果 (子.父 != 0) { NovaNode_移除自己(子) }

    子.父 = 父
    子.后兄弟 = 参考节点
    子.前兄弟 = 参考节点.前兄弟
    如果 (参考节点.前兄弟 != 0) {
        参考节点.前兄弟.后兄弟 = 子
    } 否则 {
        父.第一子 = 子
    }
    参考节点.前兄弟 = 子
    子.文档 = 父.文档
    NSAN_插入总数 = NSAN_插入总数 + 1
}

函数 NovaNode_移除自己(节点) {
    如果 (节点 == 0 || 节点.父 == 0) { 返回 }
    定义 p = 节点.父
    如果 (节点.前兄弟 != 0) { 节点.前兄弟.后兄弟 = 节点.后兄弟 }
    否则 { p.第一子 = 节点.后兄弟 }
    如果 (节点.后兄弟 != 0) { 节点.后兄弟.前兄弟 = 节点.前兄弟 }
    否则 { p.最后子 = 节点.前兄弟 }
    节点.父 = 0
    节点.前兄弟 = 0
    节点.后兄弟 = 0
    节点.标志 = 节点.标志 & (~节点标志_已连接)
    NSAN_移除总数 = NSAN_移除总数 + 1
}


函数 NovaNode_子节点数量(节点) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 c = 0
    定义 可变 ch = 节点.第一子
    当 (ch != 0) { c = c + 1; ch = ch.后兄弟 }
    返回 c
}

函数 NovaNode_深度(节点) {
    如果 (节点 == 0) { 返回 0 }
    定义 可变 d = 0
    定义 可变 p = 节点.父
    当 (p != 0) { d = d + 1; p = p.父 }
    返回 d
}

函数 NovaNode_是祖先(祖先, 后代) {
    如果 (祖先 == 0 || 后代 == 0) { 返回 假 }
    定义 可变 p = 后代.父
    当 (p != 0) {
        如果 (p == 祖先) { 返回 真 }
        p = p.父
    }
    返回 假
}

函数 NovaNode_比较文档位置(a, b) {
    如果 (a == 0 || b == 0) { 返回 文档位置_断开 }
    如果 (a == b) { 返回 0 }
    如果 (NovaNode_是祖先(a, b)) { 返回 文档位置_包含 | 文档位置_在前 }
    如果 (NovaNode_是祖先(b, a)) { 返回 文档位置_被包含 | 文档位置_在后 }
    返回 文档位置_在前  // 简化
}


结构 NovaAttr {
    名称,
    值,
}

函数 NovaNode_获取属性(节点, 名称) {
    如果 (节点 == 0 || 节点.属性列表 == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < 节点.属性数量) {
        定义 a = 内存_读64(节点.属性列表 + i * 8)
        如果 (a != 0 && 字符串_相等(a.名称, 名称)) { 返回 a.值 }
        i = i + 1
    }
    返回 0
}

函数 NovaNode_设置属性(节点, 名称, 值) {
    如果 (节点 == 0) { 返回 }
    // 查找已有
    定义 可变 i = 0
    当 (节点.属性列表 != 0 && i < 节点.属性数量) {
        定义 a = 内存_读64(节点.属性列表 + i * 8)
        如果 (a != 0 && 字符串_相等(a.名称, 名称)) {
            a.值 = 值
            节点.标志 = 节点.标志 | 节点标志_已改样式
            返回
        }
        i = i + 1
    }
    // 新建
    如果 (节点.属性列表 == 0) {
        节点.属性列表 = 堆_分配(16 * 8)
    }
    定义 attr = 堆_分配(NovaAttr)
    attr.名称 = 名称
    attr.值 = 值
    内存_写64(节点.属性列表 + 节点.属性数量 * 8, attr)
    节点.属性数量 = 节点.属性数量 + 1
    节点.标志 = 节点.标志 | 节点标志_已改样式
}

函数 NovaNode_移除属性(节点, 名称) {
    如果 (节点 == 0 || 节点.属性列表 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 节点.属性数量) {
        定义 a = 内存_读64(节点.属性列表 + i * 8)
        如果 (a != 0 && 字符串_相等(a.名称, 名称)) {
            堆_释放(a)
            定义 可变 j = i
            当 (j < 节点.属性数量 - 1) {
                内存_写64(节点.属性列表 + j * 8, 内存_读64(节点.属性列表 + (j + 1) * 8))
                j = j + 1
            }
            节点.属性数量 = 节点.属性数量 - 1
            返回
        }
        i = i + 1
    }
}


函数 NovaNode_获取文本内容(节点) {
    如果 (节点 == 0) { 返回 0 }
    如果 (节点.类型 == TEXT_节点) { 返回 节点.文本数据 }
    // 元素: 拼接所有子文本节点
    定义 可变 ch = 节点.第一子
    如果 (ch == 0) { 返回 "" }
    // 单一文本子节点快速路径
    如果 (ch.后兄弟 == 0 && ch.类型 == TEXT_节点) { 返回 ch.文本数据 }
    返回 0  // 复杂情况留待完整实现
}

函数 NovaNode_设置文本内容(节点, 文本) {
    如果 (节点 == 0) { 返回 }
    如果 (节点.类型 == TEXT_节点) {
        节点.文本数据 = 文本
        节点.文本长度 = 字符串_长度(文本)
        返回
    }
    // 元素: 清除所有子节点，添加单个文本节点
    定义 可变 ch = 节点.第一子
    当 (ch != 0) {
        定义 next = ch.后兄弟
        NovaNode_移除自己(ch)
        ch = next
    }
    如果 (文本 != 0 && 字符串_长度(文本) > 0) {
        定义 tn = NovaNode_创建(TEXT_节点)
        tn.文本数据 = 文本
        tn.文本长度 = 字符串_长度(文本)
        NovaNode_追加子(节点, tn)
    }
}


函数 NovaNode_设置标志(节点, 标志) {
    如果 (节点 == 0) { 返回 }
    节点.标志 = 节点.标志 | 标志
}

函数 NovaNode_清除标志(节点, 标志) {
    如果 (节点 == 0) { 返回 }
    节点.标志 = 节点.标志 & (~标志)
}

函数 NovaNode_有标志(节点, 标志) {
    如果 (节点 == 0) { 返回 假 }
    返回 (节点.标志 & 标志) != 0
}

函数 NovaNode_标记脏(节点) {
    如果 (节点 == 0) { 返回 }
    节点.标志 = 节点.标志 | 节点标志_已改样式 | 节点标志_已改布局
    // 向上传播子树已改
    定义 可变 p = 节点.父
    当 (p != 0) {
        p.标志 = p.标志 | 节点标志_子树已改
        p = p.父
    }
}


函数 NSAN_AI提取特征(节点) {
    定义 t = Tensor_创建(10)
    如果 (t == 0) { 返回 0 }
    Tensor_写(t, 0, 节点.类型)
    Tensor_写(t, 1, 节点.语义角色)
    Tensor_写(t, 2, 节点.意图)
    Tensor_写(t, 3, 节点.注意力权重)
    Tensor_写(t, 4, NovaNode_子节点数量(节点))
    Tensor_写(t, 5, NovaNode_深度(节点))
    Tensor_写(t, 6, 节点.属性数量)
    Tensor_写(t, 7, 节点.文本长度)
    Tensor_写(t, 8, 节点.标志)
    Tensor_写(t, 9, NSAN_AI分析总数)
    返回 t
}

函数 NSAN_AI推断语义角色(节点) {
    如果 (节点 == 0) { 返回 语义_未知 }
    定义 t = NSAN_AI提取特征(节点)
    如果 (t == 0) { 返回 语义_未知 }
    定义 结果 = AI总线_推理("nsan_semantic", t)
    全局AI总线.发布("nsan_role", "infer", 结果)
    Tensor_释放(t)
    节点.语义角色 = 结果
    节点.标志 = 节点.标志 | 节点标志_AI已分析
    NSAN_AI分析总数 = NSAN_AI分析总数 + 1
    返回 结果
}

函数 NSAN_AI预测意图(节点) {
    如果 (节点 == 0) { 返回 意图_无 }
    定义 t = NSAN_AI提取特征(节点)
    如果 (t == 0) { 返回 意图_无 }
    定义 结果 = AI总线_推理("nsan_intent", t)
    Tensor_释放(t)
    节点.意图 = 结果
    返回 结果
}


函数 NSAN_获取统计() {
    返回 [
        NSAN_创建总数,
        NSAN_释放总数,
        NSAN_插入总数,
        NSAN_移除总数,
        NSAN_AI分析总数
    ]
}

函数 NSAN_重置统计() {
    NSAN_创建总数 = 0
    NSAN_释放总数 = 0
    NSAN_插入总数 = 0
    NSAN_移除总数 = 0
    NSAN_AI分析总数 = 0
}

函数 NSAN_自检() {
    定义 doc = NovaNode_创建(DOCUMENT_节点)
    如果 (doc == 0) { 返回 假 }
    定义 div = NovaNode_创建(元素_节点)
    定义 txt = NovaNode_创建(TEXT_节点)
    NovaNode_追加子(doc, div)
    NovaNode_追加子(div, txt)
    如果 (NovaNode_子节点数量(doc) != 1) { 返回 假 }
    如果 (NovaNode_深度(txt) != 2) { 返回 假 }
    如果 (!NovaNode_是祖先(doc, txt)) { 返回 假 }
    NovaNode_移除自己(div)
    如果 (NovaNode_子节点数量(doc) != 0) { 返回 假 }
    返回 真
}


函数 NovaNode_释放(节点) {
    如果 (节点 == 0) { 返回 }
    // 先释放所有子节点
    定义 可变 ch = 节点.第一子
    当 (ch != 0) {
        定义 next = ch.后兄弟
        NovaNode_释放(ch)
        ch = next
    }
    // 释放属性
    如果 (节点.属性列表 != 0) {
        定义 可变 i = 0
        当 (i < 节点.属性数量) {
            定义 a = 内存_读64(节点.属性列表 + i * 8)
            如果 (a != 0) { 堆_释放(a) }
            i = i + 1
        }
        堆_释放(节点.属性列表)
    }
    // 释放事件列表
    如果 (节点.事件列表 != 0) { 堆_释放(节点.事件列表) }
    堆_释放(节点)
    NSAN_释放总数 = NSAN_释放总数 + 1
}

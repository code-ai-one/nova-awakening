    汇编 {
        "mov rdi, [rbp+32]"
        "mov rax, [rbp+24]"
        "mov rdx, [rbp+16]"
        "lock cmpxchg [rdi], rdx"
        "sete al"
        "movzx eax, al"
        "mov [rbp-8], rax"
    }
    返回 成功
}


// §5 Reporting 接口

定义 REPORT_DEPRECATION   = 0
定义 REPORT_INTERVENTION  = 1
定义 REPORT_CSP_VIOLATION = 2
定义 REPORT_CRASH         = 3
定义 REPORT_PERMISSION    = 4

结构 Report {
    类型,    // u8 REPORT_xxx
    url,    // u64 产生报告的文档URL
    body,    // u64 报告体(序列)
    时间戳,
    下一个,
}

结构 ReportingObserver {
    回调,    // u64 Nova函数*
    类型过滤,    // u32 REPORT_xxx位掩码(0=全部)
    buffered,
    // 缓冲
    队列头,
    队列大小,
}

定义 可变 报告观察者列表 = 0
定义 可变 报告观察者数 = 0
定义 可变 报告缓冲头 = 0
定义 可变 报告缓冲数 = 0

函数 ReportingObserver_创建(回调, 类型过滤, buffered) {
    定义 ro = 堆_分配(ReportingObserver)
    ro.回调 = 回调; ro.类型过滤 = 类型过滤; ro.buffered = buffered
    ro.队列头 = 0; ro.队列大小 = 0
    返回 ro
}

函数 ReportingObserver_observe(ro) {
    如果 (ro == 0) { 返回 }
    // 添加到全局观察者列表
    // 如果buffered=true, 推送已有的缓冲报告
}

函数 ReportingObserver_disconnect(ro) {
    如果 (ro == 0) { 返回 }
    // 从全局列表移除
}

函数 ReportingObserver_takeRecords(ro) {
    如果 (ro == 0) { 返回 0 }
    定义 头 = ro.队列头
    ro.队列头 = 0; ro.队列大小 = 0
    返回 头
}

// 生成报告(内部调用)
函数 错误Reporting_记录(error) {
    如果 (error == 0) { 返回 }
    // 创建Report并推送到所有观察者
}

函数 Reporting_弃用警告(特性名, message) {
    定义 report = 堆_分配(Report)
    report.类型 = REPORT_DEPRECATION
    report.body = message; report.时间戳 = 平台_获取高精度时间()
    report.下一个 = 报告缓冲头; 报告缓冲头 = report
    报告缓冲数 = 报告缓冲数 + 1
    // Console警告
    Console_记录(1, message, 0, 0)    // CONSOLE_WARN
}

函数 Reporting_干预(特性名, message) {
    定义 report = 堆_分配(Report)
    report.类型 = REPORT_INTERVENTION
    report.body = message; report.时间戳 = 平台_获取高精度时间()
    report.下一个 = 报告缓冲头; 报告缓冲头 = report
    报告缓冲数 = 报告缓冲数 + 1
}

// Report-To HTTP头: 自动发送到服务器
函数 Reporting_发送到端点(enNova直接偏好优化int_url) {
    如果 (enNova直接偏好优化int_url == 0 || 报告缓冲头 == 0) { 返回 }

导入("./真实滚动.nova")

// NovaOS 浏览器内核 · 反检测层 · 类人行为仿真引擎
// 内核级仿人操作: 鼠标/键盘/滚动/拖拽 全维度拟真
// 原理: 贝塞尔曲线+高斯噪声+生物节律 模拟真实人类行为
// 所有操作在内核事件层注入，JS检测层完全无法区分机器/人类

定义 鼠标_最小速度     = 200     // 像素/秒
定义 鼠标_最大速度     = 1800
定义 鼠标_平均速度     = 800
定义 键盘_平均间隔     = 120     // 打字间隔(毫秒)
定义 键盘_间隔标准差   = 45
定义 键盘_错误率       = 3       // 百分之3打字错误
定义 点击_前停顿最小   = 50      // 毫秒
定义 点击_前停顿最大   = 300
定义 点击_持续最小     = 60      // 按下持续时间(毫秒)
定义 点击_持续最大     = 180
定义 拖拽_抖动幅度     = 3       // 手抖像素

结构 轨迹点 {
    x,    // i32, y: i32, 时间: u64, 速度: u32
}

结构 键盘仿真事件 {
    键码,    // u32, 字符: 字符串, 按下时间: u64, 释放时间: u64
    是否错误,    // 布尔, 修正延迟: u64
}

结构 用户画像 {
    名称,
    鼠标速度均值,    // u32, 鼠标速度方差: u32
    打字速度WPM,    // u32, 打字错误率: u32
    滚动习惯,    // u32, 犹豫倾向: u32, 焦躁指数: u32
}

定义 可变 仿真_当前画像 = 空
定义 可变 仿真_鼠标X = 500
定义 可变 仿真_鼠标Y = 400
定义 可变 仿真_PRNG种子 = 0x12345678
定义 可变 仿真_已初始化 = 假
定义 可变 仿真_总操作数 = 0
定义 可变 仿真_画像库 = []

// §1 初始化

函数 行为仿真_初始化() {
    仿真_画像库 = []

    定义 办公 = 用户画像 {}
    办公.名称 = "办公用户"; 办公.鼠标速度均值 = 700; 办公.鼠标速度方差 = 200
    办公.打字速度WPM = 45; 办公.打字错误率 = 4; 办公.滚动习惯 = 1
    办公.犹豫倾向 = 40; 办公.焦躁指数 = 20
    追加(仿真_画像库, 办公)

    定义 年轻 = 用户画像 {}
    年轻.名称 = "年轻用户"; 年轻.鼠标速度均值 = 1200; 年轻.鼠标速度方差 = 350
    年轻.打字速度WPM = 70; 年轻.打字错误率 = 2; 年轻.滚动习惯 = 2
    年轻.犹豫倾向 = 15; 年轻.焦躁指数 = 60
    追加(仿真_画像库, 年轻)

    定义 谨慎 = 用户画像 {}
    谨慎.名称 = "谨慎用户"; 谨慎.鼠标速度均值 = 500; 谨慎.鼠标速度方差 = 100
    谨慎.打字速度WPM = 30; 谨慎.打字错误率 = 6; 谨慎.滚动习惯 = 0
    谨慎.犹豫倾向 = 70; 谨慎.焦躁指数 = 5
    追加(仿真_画像库, 谨慎)

    仿真_当前画像 = 办公
    仿真_已初始化 = 真
    内核信息("行为仿真引擎: 贝塞尔曲线+高斯噪声+生物节律就绪")
}

函数 行为仿真_切换画像(名称) {
    定义 可变 i = 0
    当 (i < 计数(仿真_画像库)) {
        如果 (仿真_画像库[i].名称 == 名称) {
            仿真_当前画像 = 仿真_画像库[i]
            返回 真
        }
        i = i + 1
    }
    返回 假
}

// §2 鼠标移动 — 三阶贝塞尔曲线+微抖动

函数 行为仿真_鼠标移动到(目标X, 目标Y) {
    仿真_总操作数 = 仿真_总操作数 + 1
    定义 起X = 仿真_鼠标X
    定义 起Y = 仿真_鼠标Y
    定义 dx = 目标X - 起X
    定义 dy = 目标Y - 起Y
    定义 距离 = 仿真_整数开方(dx * dx + dy * dy)
    如果 (距离 == 0) { 返回 [] }

    // 速度 = 画像均值 + 高斯噪声
    定义 速度 = 仿真_高斯(仿真_当前画像.鼠标速度均值, 仿真_当前画像.鼠标速度方差)
    如果 (速度 < 鼠标_最小速度) { 速度 = 鼠标_最小速度 }
    如果 (速度 > 鼠标_最大速度) { 速度 = 鼠标_最大速度 }

    定义 总时间 = (距离 * 1000) / 速度
    如果 (总时间 < 50) { 总时间 = 50 }
    定义 步数 = 总时间 / 8    // ~125fps采样
    如果 (步数 < 5) { 步数 = 5 }

    // 生成两个随机控制点(三阶贝塞尔)
    定义 偏移量 = 距离 / 4
    定义 cp1x = 起X + dx / 3 + 仿真_随机范围(0 - 偏移量, 偏移量)
    定义 cp1y = 起Y + dy / 3 + 仿真_随机范围(0 - 偏移量, 偏移量)
    定义 cp2x = 起X + dx * 2 / 3 + 仿真_随机范围(0 - 偏移量 / 2, 偏移量 / 2)
    定义 cp2y = 起Y + dy * 2 / 3 + 仿真_随机范围(0 - 偏移量 / 2, 偏移量 / 2)

    定义 可变 轨迹 = []
    定义 可变 当前时间 = 高精度定时器_读取()
    定义 可变 i = 0
    当 (i <= 步数) {
        定义 t = (i * 1000) / 步数    // 0-1000
        // 缓入缓出: t' = 3t² - 2t³ (标准化到0-1000)
        定义 t归一 = t
        定义 t2 = (t归一 * t归一) / 1000
        定义 t3 = (t2 * t归一) / 1000
        定义 ease_t = 3 * t2 - 2 * t3

        // 三阶贝塞尔: B(t) = (1-t)³P0 + 3(1-t)²tP1 + 3(1-t)t²P2 + t³P3
        定义 mt = 1000 - ease_t
        定义 b0 = (mt * mt * mt) / 1000000
        定义 b1 = (3 * mt * mt * ease_t) / 1000000
        定义 b2 = (3 * mt * ease_t * ease_t) / 1000000
        定义 b3 = (ease_t * ease_t * ease_t) / 1000000

        定义 px = (b0 * 起X + b1 * cp1x + b2 * cp2x + b3 * 目标X) / 1000
        定义 py = (b0 * 起Y + b1 * cp1y + b2 * cp2y + b3 * 目标Y) / 1000

        // 加微抖动(1-2像素,模拟手部微颤)
        px = px + 仿真_随机范围(-1, 1)
        py = py + 仿真_随机范围(-1, 1)

        定义 点 = 轨迹点 {}
        点.x = px; 点.y = py
        点.时间 = 当前时间 + (i * 总时间 * 1000) / 步数
        追加(轨迹, 点)
        i = i + 1
    }

    仿真_鼠标X = 目标X
    仿真_鼠标Y = 目标Y
    返回 轨迹
}

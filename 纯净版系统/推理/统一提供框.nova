}

函数 Provider_创建_本地Ollama(模型名) {
    定义 cfg = AI提供者配置 {}
    cfg.名称 = "本地Ollama-" + 模型名
    cfg.类型 = 提供者_本地Ollama
    cfg.接口端点 = "http://localhost:11434/v1/chat/completions"
    cfg.接口密钥名 = ""
    cfg.模型标识 = 模型名
    cfg.最大令牌 = 32000
    cfg.最大输出令牌 = 4096
    cfg.温度 = 700
    cfg.TopP = 950
    cfg.超时毫秒 = 60000
    cfg.重试次数 = 3
    cfg.启用流式 = 1
    cfg.已启用 = 0
    cfg.认证头名 = "Authorization"
    cfg.认证头前缀 = "Bearer "
    cfg.系统提示字段 = "messages"
    cfg.消息格式版本 = 0
    追加(Provider列表, cfg)
    返回 计数(Provider列表) - 1
}


函数 Provider_选择(索引) {
    如果 (索引 >= 0 && 索引 < 计数(Provider列表)) {
        当前Provider索引 = 索引
    }
}

函数 Provider_当前() {
    如果 (当前Provider索引 < 计数(Provider列表) && Provider列表[当前Provider索引].已启用 == 1) {
        返回 Provider列表[当前Provider索引]
    }
    定义 可变 i = 0
    当 (i < 计数(Provider列表)) {
        如果 (Provider列表[i].已启用 == 1) {
            当前Provider索引 = i
            返回 Provider列表[i]
        }
        i = i + 1
    }
    返回 空
}

函数 Provider_按名称选择(名称) {
    定义 可变 i = 0
    当 (i < 计数(Provider列表)) {
        如果 (Provider列表[i].名称 == 名称) { 当前Provider索引 = i; 返回 i }
        i = i + 1
    }
    返回 -1
}

函数 Provider_列表() { 返回 Provider列表 }
函数 Provider_数量() { 返回 计数(Provider列表) }

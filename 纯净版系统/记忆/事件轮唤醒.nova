定义 Nova事件轮询IN = 0x001
定义 Nova事件轮询OUT = 0x004
定义 Nova事件轮询ERR = 0x008
定义 Nova事件轮询HUP = 0x010
定义 Nova事件轮询RDNORM = 0x040
定义 Nova事件轮询ET = 0x80000000
定义 Nova事件轮询ONESHOT = 0x40000000
定义 Nova事件轮询RDHUP = 0x2000

定义 Nova事件轮询_操作_添加 = 1
定义 Nova事件轮询_操作_修改 = 2
定义 Nova事件轮询_操作_删除 = 3

定义 Nova事件轮询_最大事件数 = 1024
定义 Nova事件轮询_默认超时 = -1

定义 可变 Nova事件轮询_实例数 = 0
定义 可变 Nova事件轮询_总事件数 = 0

结构 Nova事件轮询事件 {
    事件,
    数据,
}

结构 Nova事件轮询项 {
    文件,
    文件描述符,
    事件,
    Nova事件轮询实例,
    已禁用,
    就绪,
    触发事件,
}

结构 Nova事件轮询实例 {
    锁,
    监控项列表,
    就绪列表,
    就绪数,
    等待队列,
    已关闭,
    总监控数,
}

函数 Nova事件轮询_创建() {
    定义 ep = Nova事件轮询实例 {}
    ep.锁 = 自旋锁_创建()
    ep.监控项列表 = []
    ep.就绪列表 = []
    ep.就绪数 = 0
    ep.等待队列 = []
    ep.已关闭 = 假
    ep.总监控数 = 0

    Nova事件轮询_实例数 = Nova事件轮询_实例数 + 1
    返回 ep
}

函数 Nova事件轮询_控制(ep, 操作, fd, 事件) {
    如果 (ep == 空 || ep.已关闭) { 返回 错误_无效参数 }

    自旋锁_获取(ep.锁)

    如果 (操作 == Nova事件轮询_操作_添加) {
        定义 已存在 = Nova事件轮询_查找项(ep, fd)
        如果 (已存在 != 空) {
            自旋锁_释放(ep.锁)
            返回 错误_已存在
        }

        定义 epi = Nova事件轮询项 {}
        epi.文件描述符 = fd
        epi.文件 = 进程_获取文件(fd)
        epi.事件 = 事件
        epi.Nova事件轮询实例 = ep
        epi.已禁用 = 假
        epi.就绪 = 假
        epi.触发事件 = 0

        追加(ep.监控项列表, epi)
        ep.总监控数 = ep.总监控数 + 1

        定义 当前事件 = 文件_poll(epi.文件, 0)
        如果 (当前事件 & 事件.事件) {
            Nova事件轮询_标记就绪(ep, epi, 当前事件 & 事件.事件)
        }

        自旋锁_释放(ep.锁)
        返回 0
    }

    如果 (操作 == Nova事件轮询_操作_修改) {
        定义 epi = Nova事件轮询_查找项(ep, fd)
        如果 (epi == 空) {
            自旋锁_释放(ep.锁)
            返回 错误_不存在
        }

        epi.事件 = 事件
        epi.已禁用 = 假

        定义 当前事件 = 文件_poll(epi.文件, 0)
        如果 (当前事件 & 事件.事件) {
            Nova事件轮询_标记就绪(ep, epi, 当前事件 & 事件.事件)
        }

        自旋锁_释放(ep.锁)
        返回 0
    }

    如果 (操作 == Nova事件轮询_操作_删除) {
        定义 可变 i = 0
        当 (i < 计数(ep.监控项列表)) {
            如果 (ep.监控项列表[i].文件描述符 == fd) {
                Nova事件轮询_从就绪链表移除(ep, ep.监控项列表[i])
                列表_移除(ep.监控项列表, i)
                ep.总监控数 = ep.总监控数 - 1
                自旋锁_释放(ep.锁)
                返回 0
            }
            i = i + 1
        }
        自旋锁_释放(ep.锁)
        返回 错误_不存在
    }

    自旋锁_释放(ep.锁)
    返回 错误_无效参数
}

函数 Nova事件轮询_等待(ep, 事件数组, 最大事件, 超时毫秒) {
    如果 (ep == 空 || ep.已关闭) { 返回 错误_无效参数 }
    如果 (最大事件 <= 0 || 最大事件 > Nova事件轮询_最大事件数) { 返回 错误_无效参数 }

    自旋锁_获取(ep.锁)

    如果 (ep.就绪数 == 0 && 超时毫秒 != 0) {
        自旋锁_释放(ep.锁)
        // 等待唤醒或超时
        如果 (超时毫秒 > 0) {
            睡眠毫秒(超时毫秒)
        }
        自旋锁_获取(ep.锁)
    }

    定义 可变 已收集 = 0
    定义 可变 i = 0
    当 (i < 计数(ep.就绪列表) && 已收集 < 最大事件) {
        定义 epi = ep.就绪列表[i]
        如果 (epi.已禁用) { i = i + 1; 继续 }

        定义 当前事件 = 文件_poll(epi.文件, 0)
        定义 关心事件 = 当前事件 & epi.事件.事件

        如果 (关心事件 != 0) {
            事件数组[已收集] = Nova事件轮询事件 { 事件: 关心事件, 数据: epi.事件.数据 }
            已收集 = 已收集 + 1

            如果 (epi.事件.事件 & Nova事件轮询ONESHOT) {
                epi.已禁用 = 真
            }

            如果 (epi.事件.事件 & Nova事件轮询ET) {
                Nova事件轮询_从就绪链表移除(ep, epi)
            }
        } 否则 {
            Nova事件轮询_从就绪链表移除(ep, epi)
        }
        i = i + 1
    }

    Nova事件轮询_总事件数 = Nova事件轮询_总事件数 + 已收集
    自旋锁_释放(ep.锁)
    返回 已收集
}

函数 Nova事件轮询_唤醒回调(epi, 事件) {
    如果 (epi.已禁用) { 返回 }

    定义 关心事件 = 事件 & epi.事件.事件
    如果 (关心事件 != 0) {
        Nova事件轮询_标记就绪(epi.Nova事件轮询实例, epi, 关心事件)
    }
}

函数 Nova事件轮询_标记就绪(ep, epi, 事件) {
    如果 (epi.就绪) {
        epi.触发事件 = epi.触发事件 | 事件
        返回
    }
    epi.就绪 = 真
    epi.触发事件 = 事件
    追加(ep.就绪列表, epi)
    ep.就绪数 = ep.就绪数 + 1

    Nova事件轮询_唤醒等待者(ep)
}

函数 Nova事件轮询_从就绪链表移除(ep, epi) {
    如果 (!epi.就绪) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(ep.就绪列表)) {
        如果 (ep.就绪列表[i].文件描述符 == epi.文件描述符) {
            列表_移除(ep.就绪列表, i)
            ep.就绪数 = ep.就绪数 - 1
            epi.就绪 = 假
            epi.触发事件 = 0
            返回
        }
        i = i + 1
    }
}

函数 Nova事件轮询_重新检查就绪(ep, epi) {
    定义 当前事件 = 文件_poll(epi.文件, 0)
    如果 ((当前事件 & epi.事件.事件) == 0) {
        Nova事件轮询_从就绪链表移除(ep, epi)
    }
}

函数 Nova事件轮询_唤醒等待者(ep) {
    定义 可变 i = 0
    当 (i < 计数(ep.等待队列)) {
        唤醒进程(ep.等待队列[i])
        i = i + 1
    }
}

函数 Nova事件轮询_查找项(ep, fd) {
    定义 可变 i = 0
    当 (i < 计数(ep.监控项列表)) {
        如果 (ep.监控项列表[i].文件描述符 == fd) {
            返回 ep.监控项列表[i]
        }
        i = i + 1
    }
    返回 空
}

函数 Nova事件轮询_文件操作表() {
    返回 {
        释放: Nova事件轮询_关闭,
        poll: Nova事件轮询_自身poll
    }
}

函数 Nova事件轮询_关闭(文件) {
    定义 ep = 文件.私有数据
    如果 (ep == 空) { 返回 0 }

    自旋锁_获取(ep.锁)
    ep.已关闭 = 真

    定义 可变 i = 计数(ep.监控项列表) - 1
    当 (i >= 0) {
        列表_移除(ep.监控项列表, i)
        i = i - 1
    }
    ep.就绪列表 = []
    ep.就绪数 = 0

    自旋锁_释放(ep.锁)

    Nova事件轮询_实例数 = Nova事件轮询_实例数 - 1
    释放内存(ep)
    返回 0
}

函数 Nova事件轮询_自身poll(文件) {
    定义 ep = 文件.私有数据
    定义 可变 事件 = 0
    如果 (ep.就绪数 > 0) {
        事件 = 事件 | Nova事件轮询IN | Nova事件轮询RDNORM
    }
    返回 事件
}

函数 Nova事件轮询_完整统计() {
    返回 [Nova事件轮询_实例数, Nova事件轮询_总事件数]
}

定义 错误_无效参数 = -22
定义 错误_已存在 = -17
定义 错误_不存在 = -2

// epoll唤醒链路诊断

函数 epoll_唤醒链路诊断(ep) {
    如果 (ep == 空) { 返回 "epoll实例无效" }
    定义 可变 信息 = "唤醒回调链路: "
    信息 = 信息 + "就绪队列=" + 整数转字符串(ep.就绪数量)
    信息 = 信息 + " 等待者=" + 整数转字符串(ep.等待者数量)
    返回 信息
}

函数 epoll_超时检测(ep, 当前时间) {
    如果 (ep == 空) { 返回 -1 }
    如果 (ep.超时时间 == 0) { 返回 -1 }
    定义 剩余 = ep.超时时间 - 当前时间
    如果 (剩余 < 0) { 返回 0 }
    返回 剩余
}

定义 可变 AI_事件轮唤醒_热文件表 = []

函数 AI_事件轮唤醒_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_事件轮唤醒_热文件表)) {
        如果 (AI_事件轮唤醒_热文件表[i].路径 == 路径) {
            AI_事件轮唤醒_热文件表[i].频率 = AI_事件轮唤醒_热文件表[i].频率 + 1
            返回 AI_事件轮唤醒_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_事件轮唤醒_热文件表) < 128) {
        追加(AI_事件轮唤醒_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_事件轮唤醒_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

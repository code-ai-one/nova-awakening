导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("./扩展获取文乙.nova")
导入("./扩展卸载超级.nova")
导入("../中枢/内核打印.nova")
导入("../稳态/磁控驱动全局.nova")
导入("./文件节点缓.nova")

// ext4内存Nova文件节点信息(VFS Nova文件节点的ext4私有部分)

结构 Ext4Nova文件节点信息 {
    磁盘Nova文件节点,    // Ext4磁盘Nova文件节点
    Nova文件节点号,
    块组,
    组内偏移,
    标志,
    数据标志,
    extent树,    // Ext4Extent树头
    已脏,
    锁,    // 自旋锁
}

// Nova文件节点读取: 从磁盘加载Nova文件节点到内存

函数 ext4_读Nova文件节点(sb, Nova文件节点号) {
    定义 信息 = sb.私有信息
    如果 (Nova文件节点号 < 1 || Nova文件节点号 > 信息.磁盘超级块.Nova文件节点总数) {
        内核打印("ext4: 无效Nova文件节点号 %d\n", Nova文件节点号)
        返回 错误码_无效参数
    }

    // 计算Nova文件节点所在块组和组内偏移
    定义 块组 = ext4_Nova文件节点所在块组(信息, Nova文件节点号)
    定义 组内偏移 = ext4_Nova文件节点组内偏移(信息, Nova文件节点号)

    // 获取Nova文件节点表起始块
    定义 Nova文件节点表块 = ext4_获取Nova文件节点表块(信息, 块组)
    如果 (Nova文件节点表块 == 0) {
        返回 错误码_IO
    }

    // 计算Nova文件节点在磁盘上的字节偏移
    定义 Nova文件节点大小 = 信息.Nova文件节点大小
    定义 每块Nova文件节点数 = 信息.块大小 / Nova文件节点大小
    定义 块偏移 = 组内偏移 / 每块Nova文件节点数
    定义 块内偏移 = (组内偏移 % 每块Nova文件节点数) * Nova文件节点大小

    // 读取包含该Nova文件节点的块
    定义 块号 = Nova文件节点表块 + 块偏移
    定义 缓冲 = 块设备_读(sb.设备, 块号 * 信息.块大小, 信息.块大小)
    如果 (缓冲 == 空) {
        内核打印("ext4: 无法读取Nova文件节点表块 %d\n", 块号)
        返回 错误码_IO
    }

    // 解析磁盘Nova文件节点
    定义 可变 磁盘in = Ext4磁盘Nova文件节点 {}
    磁盘in.模式        = 缓冲_读u16(缓冲, 块内偏移 + EXT4_IN偏移_模式)
    磁盘in.uid_低      = 缓冲_读u16(缓冲, 块内偏移 + EXT4_IN偏移_UID低)
    磁盘in.大小_低     = 缓冲_读u32(缓冲, 块内偏移 + EXT4_IN偏移_大小低)
    磁盘in.访问时间    = 缓冲_读u32(缓冲, 块内偏移 + EXT4_IN偏移_访问时间)
    磁盘in.修改时间    = 缓冲_读u32(缓冲, 块内偏移 + EXT4_IN偏移_修改时间)
    磁盘in.变更时间    = 缓冲_读u32(缓冲, 块内偏移 + EXT4_IN偏移_变更时间)
    磁盘in.删除时间    = 缓冲_读u32(缓冲, 块内偏移 + EXT4_IN偏移_删除时间)
    磁盘in.gid_低      = 缓冲_读u16(缓冲, 块内偏移 + EXT4_IN偏移_GID低)
    磁盘in.链接数      = 缓冲_读u16(缓冲, 块内偏移 + EXT4_IN偏移_链接数)
    磁盘in.块数_低     = 缓冲_读u32(缓冲, 块内偏移 + EXT4_IN偏移_块数低)
    磁盘in.标志        = 缓冲_读u32(缓冲, 块内偏移 + EXT4_IN偏移_标志)

    // 读取块指针/extent数据(60字节, 15个u32)
    定义 可变 j = 0
    当 (j < 15) {
        磁盘in.块指针[j] = 缓冲_读u32(缓冲, 块内偏移 + EXT4_IN偏移_块指针 + j * 4)
        j = j + 1
    }

    磁盘in.大小_高 = 缓冲_读u32(缓冲, 块内偏移 + EXT4_IN偏移_大小高)

    // 扩展Nova文件节点字段(rev1+)
    如果 (Nova文件节点大小 > EXT4_Nova文件节点大小_旧) {
        磁盘in.uid_高     = 缓冲_读u16(缓冲, 块内偏移 + EXT4_IN偏移_UID高)
        磁盘in.gid_高     = 缓冲_读u16(缓冲, 块内偏移 + EXT4_IN偏移_GID高)
        磁盘in.创建时间   = 缓冲_读u32(缓冲, 块内偏移 + EXT4_IN偏移_创建时间)
        磁盘in.块数_高    = 缓冲_读u16(缓冲, 块内偏移 + EXT4_IN偏移_块数高)
    }

    缓冲_释放(缓冲)

    // 构造VFS Nova文件节点
    定义 可变 vfs_Nova文件节点 = Nova文件节点_创建(ext4_模式转类型(磁盘in.模式), 磁盘in.模式 & 0x0FFF)
    vfs_Nova文件节点.编号      = Nova文件节点号
    vfs_Nova文件节点.链接数    = 磁盘in.链接数
    vfs_Nova文件节点.大小      = ext4_获取Nova文件节点大小(磁盘in)
    vfs_Nova文件节点.uid       = ext4_获取Nova文件节点_uid(磁盘in)
    vfs_Nova文件节点.gid       = ext4_获取Nova文件节点_gid(磁盘in)
    vfs_Nova文件节点.访问时间  = 磁盘in.访问时间
    vfs_Nova文件节点.修改时间  = 磁盘in.修改时间
    vfs_Nova文件节点.变更时间  = 磁盘in.变更时间
    vfs_Nova文件节点.块数      = ext4_获取Nova文件节点块数(磁盘in)

    // 存储ext4私有信息
    定义 可变 ext4信息 = Ext4Nova文件节点信息 {}
    ext4信息.磁盘Nova文件节点  = 磁盘in
    ext4信息.Nova文件节点号    = Nova文件节点号
    ext4信息.块组       = 块组
    ext4信息.组内偏移   = 组内偏移
    ext4信息.标志       = 磁盘in.标志
    ext4信息.已脏       = 假
    vfs_Nova文件节点.私有信息  = ext4信息

    返回 vfs_Nova文件节点
}

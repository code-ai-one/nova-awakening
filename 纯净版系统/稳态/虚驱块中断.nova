导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/时钟中枢.nova")
导入("../中枢/整数转字符串.nova")

定义 VIRTIO_BLK_扇区大小 = 512
定义 最大飞行请求 = 32
定义 IRQ_无 = 0
定义 IRQ_已处理 = 1

定义 请求状态_等待 = 0
定义 请求状态_完成 = 1
定义 请求状态_错误 = 2
定义 请求状态_超时 = 3

定义 可变 中断计数 = 0
定义 可变 完成请求数 = 0
定义 可变 错误请求数 = 0
定义 可变 超时请求数 = 0

结构 块请求 {
    类型,
    扇区号,
    缓冲地址,
    扇区数,
    状态,
    完成回调,
    回调参数,
    提交时间,
    DMA地址,
}

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 virtio块_中断处理(IRQ号) {
    定义 blk = 全局virtio块设备
    如果 (blk == 空) { 返回 IRQ_无 }

    中断计数 = 中断计数 + 1
    定义 可变 已处理 = 假

    定义 中断状态 = 内存_读32(blk.MMIO基址 + 0x60)
    如果 (中断状态 == 0) { 返回 IRQ_无 }

    内存_写32(blk.MMIO基址 + 0x64, 中断状态)

    循环 {
        定义 完成 = virtqueue_获取已完成(blk.请求队列)
        如果 (完成 == 空) { 跳出 }

        blk.飞行中请求 = blk.飞行中请求 - 1
        已处理 = 真

        定义 请求 = 完成.请求数据
        如果 (请求 == 空) { 继续 }

        定义 设备状态 = 内存_读8(请求.缓冲地址 + 请求.扇区数 * VIRTIO_BLK_扇区大小)
        如果 (设备状态 == 0) {
            请求.状态 = 请求状态_完成
            完成请求数 = 完成请求数 + 1
            如果 (请求.类型 == 0) { blk.读次数 = blk.读次数 + 1; blk.读字节 = blk.读字节 + 请求.扇区数 * VIRTIO_BLK_扇区大小 }
            否则如果 (请求.类型 == 1) { blk.写次数 = blk.写次数 + 1; blk.写字节 = blk.写字节 + 请求.扇区数 * VIRTIO_BLK_扇区大小 }
        } 否则 {
            请求.状态 = 请求状态_错误
            错误请求数 = 错误请求数 + 1
        }

        如果 (请求.DMA地址 != 0) {
            DMA_解除映射(请求.DMA地址, 请求.扇区数 * VIRTIO_BLK_扇区大小)
            请求.DMA地址 = 0
        }

        如果 (请求.完成回调 != 0) {
            请求.完成回调(请求.回调参数, 请求.状态)
        }
    }

    返回 已处理 ? IRQ_已处理 : IRQ_无
}

函数 virtio块_检查超时() {
    定义 blk = 全局virtio块设备
    如果 (blk == 空 || blk.飞行中请求 == 0) { 返回 }
    定义 当前时间 = 平台_获取时间()
    定义 超时阈值 = 5000
    定义 可变 索引 = 0
    当 (索引 < 最大飞行请求) {
        定义 请求 = 内存_读64(blk.飞行请求表 + 索引 * 8)
        如果 (请求 != 0 && 请求.状态 == 请求状态_等待) {
            如果 (当前时间 - 请求.提交时间 > 超时阈值) {
                请求.状态 = 请求状态_超时
                超时请求数 = 超时请求数 + 1
                如果 (请求.DMA地址 != 0) {
                    DMA_解除映射(请求.DMA地址, 请求.扇区数 * VIRTIO_BLK_扇区大小)
                }
                如果 (请求.完成回调 != 0) {
                    请求.完成回调(请求.回调参数, 请求状态_超时)
                }
                内存_写64(blk.飞行请求表 + 索引 * 8, 0)
                blk.飞行中请求 = blk.飞行中请求 - 1
            }
        }
        索引 = 索引 + 1
    }
}

函数 virtio块_排空队列() {
    定义 blk = 全局virtio块设备
    如果 (blk == 空) { 返回 }
    定义 可变 重试 = 0
    当 (blk.飞行中请求 > 0 && 重试 < 100) {
        virtio块_中断处理(0)
        重试 = 重试 + 1
    }
}

函数 virtio块_获取容量() {
    如果 (全局virtio块设备 == 空) { 返回 0 }
    返回 全局virtio块设备.容量_扇区 * VIRTIO_BLK_扇区大小
}

函数 virtio块_获取块大小() {
    如果 (全局virtio块设备 == 空) { 返回 512 }
    返回 全局virtio块设备.块大小
}

函数 virtio块_是只读() {
    如果 (全局virtio块设备 == 空) { 返回 真 }
    返回 全局virtio块设备.只读
}

函数 virtio块_设备复位() {
    定义 blk = 全局virtio块设备
    如果 (blk == 空) { 返回 }
    virtio块_排空队列()
    内存_写32(blk.MMIO基址 + 0x70, 0)
    blk.飞行中请求 = 0
}

函数 virtio块_完整统计() {
    如果 (全局virtio块设备 == 空) { 返回 [0, 0, 0, 0, 0, 0, 0] }
    返回 [全局virtio块设备.容量_扇区, 全局virtio块设备.读次数, 全局virtio块设备.写次数,
          全局virtio块设备.读字节, 全局virtio块设备.写字节,
          中断计数, 完成请求数, 错误请求数, 超时请求数]
}

// §2 健康检查与诊断

函数 virtio块_健康检查() {
    定义 可变 问题 = []
    如果 (全局virtio块设备 == 空) { 追加(问题, "virtio块设备未初始化"); 返回 问题 }
    如果 (错误请求数 > 完成请求数 / 10 && 完成请求数 > 100) {
        追加(问题, "错误率过高: " + 整数转字符串(错误请求数))
    }
    如果 (超时请求数 > 5) { 追加(问题, "超时请求: " + 整数转字符串(超时请求数)) }
    如果 (全局virtio块设备.飞行中请求 >= 最大飞行请求) { 追加(问题, "请求队列满") }
    如果 (计数(问题) == 0) { 返回 "virtio块设备健康" }
    返回 问题
}

函数 virtio块_详细统计() {
    如果 (全局virtio块设备 == 空) { 返回 空 }
    返回 {
        容量MB: 全局virtio块设备.容量_扇区 * 512 / 1024 / 1024,
        读次数: 全局virtio块设备.读次数,
        写次数: 全局virtio块设备.写次数,
        读字节: 全局virtio块设备.读字节,
        写字节: 全局virtio块设备.写字节,
        中断: 中断计数,
        完成: 完成请求数,
        错误: 错误请求数,
        超时: 超时请求数,
        飞行中: 全局virtio块设备.飞行中请求,
        只读: 全局virtio块设备.只读,
    }
}

函数 virtio块_重置统计() {
    中断计数 = 0
    完成请求数 = 0
    错误请求数 = 0
    超时请求数 = 0
}

// §3 virtio块设备结构与全局接口

结构 virtio块设备 {
    MMIO基址,
    容量_扇区,
    块大小,
    只读,
    读次数,
    写次数,
    读字节,
    写字节,
    飞行中请求,
    飞行请求表,
    请求队列,
}

定义 可变 全局virtio块设备 = 空

函数 virtqueue_获取已完成(队列) {
    // 从virtio used ring中取出已完成的描述符
    如果 (队列 == 空) { 返回 空 }
    如果 (队列.used_idx == 队列.last_used_idx) { 返回 空 }  // 无新完成
    定义 idx = 队列.last_used_idx % 队列.队列大小
    定义 条目 = 队列.used_ring[idx]
    队列.last_used_idx = 队列.last_used_idx + 1
    返回 条目
}
函数 DMA_解除映射(地址, 大小) {
    // 解除DMA内存映射, 释放对应的IOMMU条目
    如果 (地址 == 0 || 大小 == 0) { 返回 }
    // 清除IOMMU页表条目
    IOMMU_清除映射(地址, 大小)
}
函数 平台_获取时间() { 返回 读取纳秒() / 1000000 }

函数 virtio块_IOPS() {
    如果 (全局virtio块设备 == 空) { 返回 0 }
    返回 全局virtio块设备.读次数 + 全局virtio块设备.写次数
}

函数 virtio块_读写比() {
    如果 (全局virtio块设备 == 空 || 全局virtio块设备.写次数 == 0) { 返回 0 }
    返回 全局virtio块设备.读次数 * 100 / 全局virtio块设备.写次数
}

定义 可变 AI_虚驱块中断_风暴阈值 = 10000
定义 可变 AI_虚驱块中断_预测IRQ = 0

函数 AI_虚驱块中断_风暴检测(触发频率) {
    如果 (触发频率 > AI_虚驱块中断_风暴阈值) {
        AI_虚驱块中断_风暴阈值 = AI_虚驱块中断_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_虚驱块中断_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

函数 虚驱块中断_统计() {
    返回 {
        模块: "虚驱块中断",
        中断计数: 中断计数,
        完成请求数: 完成请求数,
        错误请求数: 错误请求数,
        超时请求数: 超时请求数,
        全局virtio块设备: 全局virtio块设备,
        AI_虚驱块中断_风暴阈值: AI_虚驱块中断_风暴阈值,
        AI_虚驱块中断_预测IRQ: AI_虚驱块中断_预测IRQ
    }
}

函数 虚驱块中断_健康评估() {
    定义 可变 问题 = []
    如果 (错误请求数 > 100) { 追加(问题, "错误请求数过高: " + 整数转字符串(错误请求数)) }
    如果 (超时请求数 > 100) { 追加(问题, "超时请求数过高: " + 整数转字符串(超时请求数)) }
    返回 计数(问题) == 0
}

函数 虚驱块中断_综合报告() {
    打印("[虚驱块中断] ═══ 综合报告 ═══")
    打印("  中断计数: " + 整数转字符串(中断计数))
    打印("  完成请求数: " + 整数转字符串(完成请求数))
    打印("  错误请求数: " + 整数转字符串(错误请求数))
    打印("  超时请求数: " + 整数转字符串(超时请求数))
    打印("  全局virtio块设备: " + 整数转字符串(全局virtio块设备))
    打印("  AI_虚驱块中断_风暴阈值: " + 整数转字符串(AI_虚驱块中断_风暴阈值))
    打印("  AI_虚驱块中断_预测IRQ: " + 整数转字符串(AI_虚驱块中断_预测IRQ))
    打印("  健康: " + 如果 (虚驱块中断_健康评估()) { "正常" } 否则 { "异常" })
}

函数 虚驱块中断_全局重置() {
    中断计数 = 0
    完成请求数 = 0
    错误请求数 = 0
    超时请求数 = 0
    全局virtio块设备 = 空
    AI_虚驱块中断_风暴阈值 = 10000
    AI_虚驱块中断_预测IRQ = 0
    打印("[虚驱块中断] 全局统计已重置")
    返回 0
}

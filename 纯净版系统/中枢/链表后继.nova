// NovaOS 双向循环链表
// Nova内核最核心的数据结构, 几乎所有子系统都用
// Nova版: 用列表模拟链表节点 [前驱索引, 后继索引, 数据]
// 搜索/排序/拼接/反转/安全遍历/过滤/统计

// 每个节点 = [前驱, 后继, 数据]

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./内核打印.nova")
导入("./整数转字符串.nova")

定义 链_前驱 = 0
定义 链_后继 = 1
定义 链_数据 = 2

定义 可变 链表_总创建 = 0
定义 可变 链表_总插入 = 0
定义 可变 链表_总删除 = 0
定义 可变 链表_总搜索 = 0
定义 可变 链表_总排序 = 0
定义 可变 链表_总拼接 = 0

// §1 导航

// 节点导航函数(被等待队列/伙伴系统/目录缓存等引用)
函数 链表_后继(节点) { 返回 节点[链_后继] }
函数 链表_前驱(节点) { 返回 节点[链_前驱] }
函数 链表_首节点_或空(头) {
    如果 (链表_为空(头)) { 返回 空 }
    返回 头[链_后继]
}

// §2 创建/判空

函数 链表_创建() {
    // 头节点: 前驱和后继都指向自己(空链表)
    定义 头 = [0, 0, 空]
    设置(头, 链_前驱, 头)
    设置(头, 链_后继, 头)
    链表_总创建 = 链表_总创建 + 1
    返回 头
}

函数 链表_为空(头) {
    返回 头[链_后继] == 头
}

// §3 插入

函数 链表_插入之间(新节点, 前节点, 后节点) {
    设置(新节点, 链_前驱, 前节点)
    设置(新节点, 链_后继, 后节点)
    设置(前节点, 链_后继, 新节点)
    设置(后节点, 链_前驱, 新节点)
}

函数 链表_头插(头, 数据) {
    定义 新节点 = [空, 空, 数据]
    链表_插入之间(新节点, 头, 头[链_后继])
    链表_总插入 = 链表_总插入 + 1
    返回 新节点
}

函数 链表_尾插(头, 数据) {
    定义 新节点 = [空, 空, 数据]
    链表_插入之间(新节点, 头[链_前驱], 头)
    链表_总插入 = 链表_总插入 + 1
    返回 新节点
}

函数 链表_插入后(节点, 数据) {
    定义 新节点 = [空, 空, 数据]
    链表_插入之间(新节点, 节点, 节点[链_后继])
    链表_总插入 = 链表_总插入 + 1
    返回 新节点
}

函数 链表_插入前(节点, 数据) {
    定义 新节点 = [空, 空, 数据]
    链表_插入之间(新节点, 节点[链_前驱], 节点)
    链表_总插入 = 链表_总插入 + 1
    返回 新节点
}

// §4 删除

函数 链表_删除(节点) {
    定义 前 = 节点[链_前驱]
    定义 后 = 节点[链_后继]
    设置(前, 链_后继, 后)
    设置(后, 链_前驱, 前)
    设置(节点, 链_前驱, 节点)
    设置(节点, 链_后继, 节点)
    链表_总删除 = 链表_总删除 + 1
}

函数 链表_弹出首(头) {
    如果 (链表_为空(头)) { 返回 空 }
    定义 节点 = 头[链_后继]
    定义 数据 = 节点[链_数据]
    链表_删除(节点)
    返回 数据
}

函数 链表_弹出末(头) {
    如果 (链表_为空(头)) { 返回 空 }
    定义 节点 = 头[链_前驱]
    定义 数据 = 节点[链_数据]
    链表_删除(节点)
    返回 数据
}

函数 链表_清空(头) {
    当 (!链表_为空(头)) {
        链表_删除(头[链_后继])
    }
}

// §5 访问

函数 链表_首节点(头) {
    如果 (链表_为空(头)) { 返回 空 }
    返回 头[链_后继]
}

函数 链表_末节点(头) {
    如果 (链表_为空(头)) { 返回 空 }
    返回 头[链_前驱]
}

函数 链表_数据(节点) {
    如果 (节点 == 空) { 返回 空 }
    返回 节点[链_数据]
}

函数 链表_设置数据(节点, 数据) {
    如果 (节点 == 空) { 返回 }
    设置(节点, 链_数据, 数据)
}

函数 链表_第N个(头, n) {
    定义 可变 当前 = 头[链_后继]
    定义 可变 i = 0
    当 (当前 != 头 && i < n) {
        当前 = 当前[链_后继]
        i = i + 1
    }
    如果 (当前 == 头) { 返回 空 }
    返回 当前
}

函数 链表_第N个数据(头, n) {
    定义 节点 = 链表_第N个(头, n)
    如果 (节点 == 空) { 返回 空 }
    返回 节点[链_数据]
}

// §6 计数/遍历

函数 链表_长度(头) {
    定义 可变 计数 = 0
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        计数 = 计数 + 1
        当前 = 当前[链_后继]
    }
    返回 计数
}

函数 链表_到列表(头) {
    定义 结果 = []
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        追加(结果, 当前[链_数据])
        当前 = 当前[链_后继]
    }
    返回 结果
}

函数 链表_安全遍历(头, 回调) {
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        定义 下一个 = 当前[链_后继]
        回调(当前)
        当前 = 下一个
    }
}

函数 链表_反向遍历(头, 回调) {
    定义 可变 当前 = 头[链_前驱]
    当 (当前 != 头) {
        定义 上一个 = 当前[链_前驱]
        回调(当前)
        当前 = 上一个
    }
}

// §7 搜索

函数 链表_查找(头, 目标) {
    链表_总搜索 = 链表_总搜索 + 1
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        如果 (当前[链_数据] == 目标) { 返回 当前 }
        当前 = 当前[链_后继]
    }
    返回 空
}

函数 链表_查找_条件(头, 谓词) {
    链表_总搜索 = 链表_总搜索 + 1
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        如果 (谓词(当前[链_数据])) { 返回 当前 }
        当前 = 当前[链_后继]
    }
    返回 空
}

函数 链表_包含(头, 目标) {
    返回 链表_查找(头, 目标) != 空
}

函数 链表_索引(头, 目标) {
    定义 可变 当前 = 头[链_后继]
    定义 可变 idx = 0
    当 (当前 != 头) {
        如果 (当前[链_数据] == 目标) { 返回 idx }
        当前 = 当前[链_后继]
        idx = idx + 1
    }
    返回 -1
}

// §8 排序(插入排序)

函数 链表_排序(头, 比较函数) {
    // 插入排序: 适合内核中的短链表
    链表_总排序 = 链表_总排序 + 1
    如果 (链表_为空(头)) { 返回 }
    定义 长度 = 链表_长度(头)
    如果 (长度 <= 1) { 返回 }

    // 创建临时链表, 依次插入排序
    定义 临时 = 链表_创建()
    当 (!链表_为空(头)) {
        定义 节点 = 头[链_后继]
        定义 数据 = 节点[链_数据]
        链表_删除(节点)

        // 在临时链表中找到插入位置
        定义 可变 插入点 = 临时[链_后继]
        当 (插入点 != 临时 && 比较函数(插入点[链_数据], 数据) <= 0) {
            插入点 = 插入点[链_后继]
        }
        // 在插入点之前插入
        链表_插入之间(节点, 插入点[链_前驱], 插入点)
    }

    // 把临时链表的内容移回原链表头
    如果 (!链表_为空(临时)) {
        定义 第一 = 临时[链_后继]
        定义 最后 = 临时[链_前驱]
        设置(头, 链_后继, 第一)
        设置(第一, 链_前驱, 头)
        设置(头, 链_前驱, 最后)
        设置(最后, 链_后继, 头)
    }
}

// §9 拼接/移动

函数 链表_拼接(目标头, 源头) {
    如果 (链表_为空(源头)) { 返回 }
    链表_总拼接 = 链表_总拼接 + 1

    定义 源首 = 源头[链_后继]
    定义 源末 = 源头[链_前驱]
    定义 目标末 = 目标头[链_前驱]

    // 目标末 <-> 源首
    设置(目标末, 链_后继, 源首)
    设置(源首, 链_前驱, 目标末)
    // 源末 <-> 目标头
    设置(源末, 链_后继, 目标头)
    设置(目标头, 链_前驱, 源末)

    // 源链表置空
    设置(源头, 链_后继, 源头)
    设置(源头, 链_前驱, 源头)
}

函数 链表_移动到(节点, 目标头) {
    链表_删除(节点)
    链表_插入之间(节点, 目标头[链_前驱], 目标头)
}

函数 链表_移动到头(节点, 目标头) {
    链表_删除(节点)
    链表_插入之间(节点, 目标头, 目标头[链_后继])
}

// §10 交换/反转/旋转

函数 链表_交换数据(节点A, 节点B) {
    如果 (节点A == 空 || 节点B == 空 || 节点A == 节点B) { 返回 }
    定义 临时 = 节点A[链_数据]
    设置(节点A, 链_数据, 节点B[链_数据])
    设置(节点B, 链_数据, 临时)
}

函数 链表_反转(头) {
    如果 (链表_为空(头)) { 返回 }
    定义 可变 当前 = 头
    循环 {
        定义 临时 = 当前[链_后继]
        设置(当前, 链_后继, 当前[链_前驱])
        设置(当前, 链_前驱, 临时)
        当前 = 临时
        如果 (当前 == 头) { 跳出 }
    }
}

函数 链表_旋转左(头) {
    如果 (链表_为空(头)) { 返回 }
    定义 首 = 头[链_后继]
    链表_删除(首)
    链表_插入之间(首, 头[链_前驱], 头)
}

函数 链表_旋转右(头) {
    如果 (链表_为空(头)) { 返回 }
    定义 末 = 头[链_前驱]
    链表_删除(末)
    链表_插入之间(末, 头, 头[链_后继])
}

// §11 过滤/映射

函数 链表_过滤(头, 谓词) {
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        定义 下一个 = 当前[链_后继]
        如果 (!谓词(当前[链_数据])) {
            链表_删除(当前)
        }
        当前 = 下一个
    }
}

函数 链表_映射(头, 变换) {
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        设置(当前, 链_数据, 变换(当前[链_数据]))
        当前 = 当前[链_后继]
    }
}

函数 链表_计数_条件(头, 谓词) {
    定义 可变 计数 = 0
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        如果 (谓词(当前[链_数据])) { 计数 = 计数 + 1 }
        当前 = 当前[链_后继]
    }
    返回 计数
}

// §12 从列表构建

函数 链表_从列表(列表) {
    定义 头 = 链表_创建()
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        链表_尾插(头, 列表[i])
        i = i + 1
    }
    返回 头
}

// §13 统计

函数 链表_打印统计() {
    打印行("=== 链表统计 ===")
    打印行("创建: " + 整数转字符串(链表_总创建))
    打印行("插入: " + 整数转字符串(链表_总插入))
    打印行("删除: " + 整数转字符串(链表_总删除))
    打印行("搜索: " + 整数转字符串(链表_总搜索))
    打印行("排序: " + 整数转字符串(链表_总排序))
    打印行("拼接: " + 整数转字符串(链表_总拼接))
}

函数 链表_获取统计() {
    返回 [链表_总创建, 链表_总插入, 链表_总删除, 链表_总搜索, 链表_总排序, 链表_总拼接]
}

// §14 NLLT — Nova Linked List Locality Theory
// 公理1(双向不变量): ∀节点N, N.后继.前驱 == N 且 N.前驱.后继 == N
// 公理2(环闭合): 任意节点沿后继遍历, 有限步内必回到头节点
// 定理1(长度守恒): 插入+1, 删除-1, 拼接时源链清空
// 定理2(稳定排序): 插入排序在比较函数等价时保序
// 上述公理由 `链表_完整性检查` 在运行期可验证, 用于内核自诊断

// §15 去重

函数 链表_去重_已排序(头, 相等判定) {
    如果 (链表_为空(头)) { 返回 0 }
    定义 可变 删除数 = 0
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        定义 下一个 = 当前[链_后继]
        如果 (下一个 != 头 && 相等判定(当前[链_数据], 下一个[链_数据])) {
            链表_删除(下一个)
            删除数 = 删除数 + 1
        } 否则 {
            当前 = 下一个
        }
    }
    返回 删除数
}

函数 链表_去重(头, 相等判定) {
    如果 (链表_为空(头)) { 返回 0 }
    定义 可变 删除数 = 0
    定义 可变 外 = 头[链_后继]
    当 (外 != 头) {
        定义 可变 内 = 外[链_后继]
        当 (内 != 头) {
            定义 下一个 = 内[链_后继]
            如果 (相等判定(外[链_数据], 内[链_数据])) {
                链表_删除(内)
                删除数 = 删除数 + 1
            }
            内 = 下一个
        }
        外 = 外[链_后继]
    }
    返回 删除数
}

// §16 分割

函数 链表_分割(头, 位置) {
    定义 新头 = 链表_创建()
    定义 长度 = 链表_长度(头)
    如果 (位置 >= 长度 || 位置 <= 0) { 返回 新头 }

    定义 分割节点 = 链表_第N个(头, 位置)
    如果 (分割节点 == 空) { 返回 新头 }

    定义 原末 = 头[链_前驱]
    定义 分割前 = 分割节点[链_前驱]

    设置(分割前, 链_后继, 头)
    设置(头, 链_前驱, 分割前)

    设置(新头, 链_后继, 分割节点)
    设置(分割节点, 链_前驱, 新头)
    设置(新头, 链_前驱, 原末)
    设置(原末, 链_后继, 新头)

    返回 新头
}

// §17 折叠/归约

函数 链表_折叠(头, 初始值, 累积函数) {
    定义 可变 结果 = 初始值
    定义 可变 当前 = 头[链_后继]
    当 (当前 != 头) {
        结果 = 累积函数(结果, 当前[链_数据])
        当前 = 当前[链_后继]
    }
    返回 结果
}

函数 链表_右折叠(头, 初始值, 累积函数) {
    定义 可变 结果 = 初始值
    定义 可变 当前 = 头[链_前驱]
    当 (当前 != 头) {
        结果 = 累积函数(当前[链_数据], 结果)
        当前 = 当前[链_前驱]
    }
    返回 结果
}

// §18 完整性校验

函数 链表_完整性检查(头) {
    如果 (头 == 空) { 返回 假 }
    如果 (头[链_后继] == 头) { 返回 头[链_前驱] == 头 }

    定义 可变 当前 = 头[链_后继]
    定义 可变 步数 = 0
    定义 最大步 = 100000

    当 (当前 != 头 && 步数 < 最大步) {
        定义 后继 = 当前[链_后继]
        定义 前驱 = 当前[链_前驱]
        如果 (后继[链_前驱] != 当前) { 返回 假 }
        如果 (前驱[链_后继] != 当前) { 返回 假 }
        当前 = 后继
        步数 = 步数 + 1
    }

    返回 当前 == 头
}

// §19 诊断与重置

函数 链表_重置统计() {
    链表_总创建 = 0
    链表_总插入 = 0
    链表_总删除 = 0
    链表_总搜索 = 0
    链表_总排序 = 0
    链表_总拼接 = 0
}

函数 链表_诊断(头, 格式化) {
    打印行("=== 链表诊断 ===")
    定义 长度 = 链表_长度(头)
    打印行("长度: " + 整数转字符串(长度))
    打印行("完整性: " + 整数转字符串(链表_完整性检查(头)))

    如果 (长度 <= 0 || 格式化 == 空) { 返回 }

    定义 可变 当前 = 头[链_后继]
    定义 可变 idx = 0
    当 (当前 != 头 && idx < 20) {
        打印行("  [" + 整数转字符串(idx) + "] " + 格式化(当前[链_数据]))
        当前 = 当前[链_后继]
        idx = idx + 1
    }
    如果 (idx < 长度) {
        打印行("  ... (省略 " + 整数转字符串(长度 - idx) + " 项)")
    }
}

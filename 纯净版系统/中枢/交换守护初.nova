导入("./类型定义.nova")
导入("./错误码.nova")
导入("./内存回收.nova")
导入("./物理页描述符.nova")

//   1. kswapd: 每个NUMA节点一个后台回收线程
//   2. 水位线驱动: 空闲页<WMARK_LOW时唤醒, 回收到WMARK_HIGH
//   3. LRU扫描: 扫描inactive/active链表, 回收最冷的页
//   4. 页面回收策略: 文件页直接丢弃(clean)/回写(dirty), 匿名页swap
//   5. 直接回收: 分配路径中同步回收(当kswapd不够快时)
//   6. 回收优先级: 从12开始降低, 优先级越低扫描越积极

定义 SWAP_CLUSTER_MAX = 32    // 每轮最多回收32页
定义 DEF_PRIORITY     = 12    // 默认扫描优先级
定义 MIN_PRIORITY     = 0     // 最低优先级(最积极扫描)

定义 LRU_INACTIVE_ANON = 0    // 不活跃匿名页
定义 LRU_ACTIVE_ANON   = 1    // 活跃匿名页
定义 LRU_INACTIVE_FILE = 2    // 不活跃文件页
定义 LRU_ACTIVE_FILE   = 3    // 活跃文件页
定义 NR_LRU_LISTS      = 4

结构 lruvec {
    链表,    // [4]列表 4个LRU链表
    计数,    // [4]u64 每个链表的页数
    // 页面年龄(generation-based,
    最小代,
    最大代,
}

定义 可变 kswapd_运行中 = 假
定义 可变 kswapd_目标zone = 0
定义 可变 kswapd_目标阶 = 0
定义 可变 kswapd_睡眠中 = 真

定义 可变 回收_扫描总数 = 0
定义 可变 回收_回收总数 = 0
定义 可变 回收_回写总数 = 0
定义 可变 直接回收_次数 = 0
定义 可变 kswapd_唤醒次数 = 0

定义 可变 全局lru = lruvec {}

// kswapd初始化 

函数 kswapd_初始化() {
    // 初始化LRU链表
    定义 可变 i = 0
    当 (i < NR_LRU_LISTS) {
        全局lru.链表[i] = 列表_创建()
        全局lru.计数[i] = 0
        i = i + 1
    }
    全局lru.最小代 = 0
    全局lru.最大代 = 0

    // 创建kswapd内核线程
    kswapd_运行中 = 真
    kswapd_睡眠中 = 真
    内核信息("kswapd: 页面回收守护进程已启动")
}

// kswapd主循环 

函数 kswapd_线程() {
    当 (kswapd_运行中) {
        // 等待唤醒
        kswapd_睡眠中 = 真
        当 (kswapd_睡眠中 && kswapd_运行中) {
            调度()
        }

        如果 (!kswapd_运行中) { 中断 }

        kswapd_唤醒次数 = kswapd_唤醒次数 + 1

        // 平衡pgdat: 回收页面直到水位线恢复
        balance_pgdat(kswapd_目标zone, kswapd_目标阶)
    }
}

函数 balance_pgdat(目标zone, 目标阶) {
    // 从最高优先级开始, 逐步降低(更积极扫描)
    定义 可变 优先级 = DEF_PRIORITY

    当 (优先级 >= MIN_PRIORITY) {
        // 检查是否已恢复到WMARK_HIGH
        如果 (zone_水位OK_全部(目标阶)) { 返回 }

        // 扫描并回收页面
        定义 回收数 = shrink_节点(优先级)
        如果 (回收数 == 0) {
            // 本轮没有回收到页面, 降低优先级(更积极)
            优先级 = 优先级 - 1
        }
    }
}

// shrink_节点: 扫描LRU链表回收页面 

函数 shrink_节点(优先级) {
    定义 可变 总回收 = 0

    // 扫描比例: 优先级越低扫描越多
    // scan = lru_size >> priority (priority=12时扫描1/4096)
    定义 扫描分母 = 1 << 优先级

    // 1. 优先回收inactive file页(成本最低: clean直接丢弃)
    定义 file回收 = shrink_lru(LRU_INACTIVE_FILE, 扫描分母)
    总回收 = 总回收 + file回收

    // 2. 如果file页不够, 回收inactive anon页(需要swap)
    如果 (总回收 < SWAP_CLUSTER_MAX) {
        定义 anon回收 = shrink_lru(LRU_INACTIVE_ANON, 扫描分母)
        总回收 = 总回收 + anon回收
    }

    // 3. 老化active→inactive 
    老化active页(LRU_ACTIVE_FILE)
    如果 (总回收 < SWAP_CLUSTER_MAX) {
        老化active页(LRU_ACTIVE_ANON)
    }

    返回 总回收
}

函数 shrink_lru(lru类型, 扫描分母) {
    定义 lru大小 = 全局lru.计数[lru类型]
    如果 (lru大小 == 0) { 返回 0 }

    定义 扫描数 = 如果 (扫描分母 > 0) { lru大小 / 扫描分母 } 否则 { lru大小 }
    如果 (扫描数 == 0) { 扫描数 = 1 }   // 至少扫描1页
    如果 (扫描数 > SWAP_CLUSTER_MAX) { 扫描数 = SWAP_CLUSTER_MAX }

    定义 可变 已扫描 = 0
    定义 可变 已回收 = 0

    当 (已扫描 < 扫描数 && 全局lru.计数[lru类型] > 0) {
        // 从链表尾部取出(最老的页)
        定义 页 = 列表_取尾(全局lru.链表[lru类型])
        如果 (页 == 空) { 中断 }

        全局lru.计数[lru类型] = 全局lru.计数[lru类型] - 1
        已扫描 = 已扫描 + 1
        回收_扫描总数 = 回收_扫描总数 + 1

        // 尝试回收此页
        如果 (尝试回收页(页, lru类型)) {
            已回收 = 已回收 + 1
            回收_回收总数 = 回收_回收总数 + 1
        } 否则 {
            // 回收失败: 放回链表头部(给予第二次机会)
            列表_加头(全局lru.链表[lru类型], 页)
            全局lru.计数[lru类型] = 全局lru.计数[lru类型] + 1
        }
    }

    返回 已回收
}

// 页面回收决策 

函数 尝试回收页(页, lru类型) {
    // 1. 引用计数检查: 如果有其他引用, 不能回收
    如果 (页描述符_引用数(页) > 1) { 返回 假 }

    // 2. 是否被锁定
    如果 (页_已锁定(页)) { 返回 假 }

    // 3. 文件页: clean直接丢弃, dirty需要回写
    如果 (lru类型 == LRU_INACTIVE_FILE) {
        如果 (页_是脏(页)) {
            // 脏页: 提交回写请求
            页_提交回写(页)
            回收_回写总数 = 回收_回写总数 + 1
            返回 假  // 本轮不回收, 等回写完成
        }
        // clean文件页: 直接释放
        页_释放到伙伴(页)
        返回 真
    }

    // 4. 匿名页: 需要swap out
    如果 (lru类型 == LRU_INACTIVE_ANON) {
        // M1: swap暂不支持, 匿名页不可回收
        返回 假
    }

    返回 假
}

// 老化: active→inactive 

定义 可变 AI_交换守护初_运行指标 = 0
定义 可变 AI_交换守护初_异常指标 = 0

函数 AI_交换守护初_自诊断() {
    AI_交换守护初_运行指标 = 回收_扫描总数
    返回 AI_交换守护初_运行指标
}

函数 AI_交换守护初_优化建议() {
    定义 指标 = AI_交换守护初_自诊断()
    如果 (AI_交换守护初_运行指标 > 10000) { 返回 "交换守护初负载较高" }
    返回 "交换守护初状态正常"
}

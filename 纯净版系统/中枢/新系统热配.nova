// NovaOS内核 · 热配置引擎 (移植自Nova大脑L3/hotconfig)
// 运行时动态调整AI参数 — 不重启不中断
// §1 参数注册表: 所有AI模块的可调参数
// §2 运行时修改: 通过/proc/ai/config接口
// §3 回滚机制: 修改失败自动回滚到上一个值
// §4 约束检查: 参数范围/类型/依赖验证

导入("./整数转字符串.nova")
导入("../推理/总线调度.nova")
定义 热配置_最大参数 = 256

结构 配置参数 {
    名称哈希,
    模块索引,
    当前值,
    默认值,
    最小值,
    最大值,
    上一个值,
    修改次数,
}

定义 可变 配置表 = []
定义 可变 配置_已初始化 = 假
定义 可变 配置_总修改 = 0
定义 可变 配置_总回滚 = 0

函数 热配置_初始化() {
    配置表 = []
    配置_已初始化 = 真
    内核信息("热配置: " + 整数转字符串(热配置_最大参数) + "参数槽 运行时修改+回滚+约束检查")
}

函数 热配置_注册(名称哈希, 模块, 默认值, 最小, 最大) {
    如果 (计数(配置表) >= 热配置_最大参数) { 返回 -1 }
    定义 参数 = 配置参数 {}
    参数.名称哈希 = 名称哈希
    参数.模块索引 = 模块
    参数.当前值 = 默认值
    参数.默认值 = 默认值
    参数.最小值 = 最小
    参数.最大值 = 最大
    参数.上一个值 = 默认值
    参数.修改次数 = 0
    追加(配置表, 参数)
    返回 计数(配置表) - 1
}

函数 热配置_设置(名称哈希, 新值) {
    定义 可变 i = 0
    当 (i < 计数(配置表)) {
        如果 (配置表[i].名称哈希 == 名称哈希) {
            // 约束检查
            如果 (新值 < 配置表[i].最小值 || 新值 > 配置表[i].最大值) {
                返回 -1  // 越界
            }
            配置表[i].上一个值 = 配置表[i].当前值
            配置表[i].当前值 = 新值
            配置表[i].修改次数 = 配置表[i].修改次数 + 1
            配置_总修改 = 配置_总修改 + 1
            返回 0
        }
        i = i + 1
    }
    返回 -2  // 未找到
}

函数 热配置_获取(名称哈希) {
    定义 可变 i = 0
    当 (i < 计数(配置表)) {
        如果 (配置表[i].名称哈希 == 名称哈希) { 返回 配置表[i].当前值 }
        i = i + 1
    }
    返回 0
}

函数 热配置_回滚(名称哈希) {
    定义 可变 i = 0
    当 (i < 计数(配置表)) {
        如果 (配置表[i].名称哈希 == 名称哈希) {
            配置表[i].当前值 = 配置表[i].上一个值
            配置_总回滚 = 配置_总回滚 + 1
            返回 0
        }
        i = i + 1
    }
    返回 -1
}

函数 热配置_重置全部() {
    定义 可变 i = 0
    当 (i < 计数(配置表)) {
        配置表[i].当前值 = 配置表[i].默认值
        i = i + 1
    }
}

函数 热配置_参数数() { 返回 计数(配置表) }

// §5 批量操作

函数 热配置_批量设置(参数列表) {
    // 参数列表: [[名称哈希, 新值], ...]
    // 全部成功才提交, 任一失败全部回滚
    定义 可变 旧值列表 = []
    定义 可变 i = 0
    当 (i < 计数(参数列表)) {
        定义 哈希 = 参数列表[i][0]
        定义 新值 = 参数列表[i][1]
        定义 旧值 = 热配置_获取(哈希)
        追加(旧值列表, [哈希, 旧值])
        定义 结果 = 热配置_设置(哈希, 新值)
        如果 (结果 != 0) {
            // 失败: 回滚已修改的
            定义 可变 j = 0
            当 (j < i) {
                热配置_设置(旧值列表[j][0], 旧值列表[j][1])
                j = j + 1
            }
            返回 结果
        }
        i = i + 1
    }
    返回 0
}

函数 热配置_回滚全部() {
    定义 可变 i = 0
    当 (i < 计数(配置表)) {
        配置表[i].当前值 = 配置表[i].上一个值
        i = i + 1
    }
    配置_总回滚 = 配置_总回滚 + 1
}

// §6 导出/导入(持久化配置)

函数 热配置_导出() {
    // 导出所有非默认值的参数
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(配置表)) {
        如果 (配置表[i].当前值 != 配置表[i].默认值) {
            追加(结果, [配置表[i].名称哈希, 配置表[i].当前值])
        }
        i = i + 1
    }
    返回 结果
}

函数 热配置_导入(数据) {
    如果 (数据 == 空) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        热配置_设置(数据[i][0], 数据[i][1])
        i = i + 1
    }
}

// §7 /proc/ai/config 接口

函数 热配置_proc输出() {
    定义 可变 输出 = "# NovaOS AI热配置 (共" + 整数转字符串(计数(配置表)) + "个参数)\n"
    输出 = 输出 + "# 修改: " + 整数转字符串(配置_总修改) + " 回滚: " + 整数转字符串(配置_总回滚) + "\n"
    定义 可变 i = 0
    当 (i < 计数(配置表)) {
        定义 p = 配置表[i]
        定义 已修改 = (p.当前值 != p.默认值)
        输出 = 输出 + "参数[" + 整数转字符串(i) + "] "
        输出 = 输出 + "值=" + 整数转字符串(p.当前值)
        输出 = 输出 + " 范围=[" + 整数转字符串(p.最小值) + "," + 整数转字符串(p.最大值) + "]"
        如果 (已修改) { 输出 = 输出 + " *已修改(默认=" + 整数转字符串(p.默认值) + ")" }
        输出 = 输出 + "\n"
        i = i + 1
    }
    返回 输出
}

// §8 统计

函数 热配置_统计() {
    返回 [计数(配置表), 配置_总修改, 配置_总回滚, 热配置_最大参数]
}

// 已修改参数数 + 使用率 + 完整统计

函数 热配置_已修改数() {
    定义 可变 计 = 0
    定义 可变 i = 0
    当 (i < 计数(配置表)) {
        如果 (配置表[i].当前值 != 配置表[i].默认值) { 计 = 计 + 1 }
        i = i + 1
    }
    返回 计
}

函数 热配置_使用率() {
    如果 (热配置_最大参数 == 0) { 返回 0 }
    返回 计数(配置表) * 100 / 热配置_最大参数
}

函数 热配置_完整统计() {
    返回 [计数(配置表), 配置_总修改, 配置_总回滚, 热配置_已修改数(), 热配置_使用率()]
}

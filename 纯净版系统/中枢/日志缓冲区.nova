导入("./类型定义.nova")
导入("./错误码.nova")
导入("./链表后继.nova")
导入("./时钟中枢.nova")
导入("./整数转字符串.nova")

//   1. 环形日志缓冲区: 固定大小(默认256KB), 满时覆盖最旧
//   2. 日志级别: KERN_EMERG(0) ~ KERN_DEBUG(7)
//   3. 时间戳: 每条日志带纳秒时间戳
//   4. 控制台输出: 根据console_loglevel决定是否输出到控制台
//   5. dmesg: 用户空间通过syslog()或/dev/kmsg读取日志
//   6. 多控制台: 串口+显基+帧缓冲同时输出

定义 LOG_EMERG   = 0    // 系统不可用
定义 LOG_ALERT   = 1    // 必须立即行动
定义 LOG_CRIT    = 2    // 严重条件
定义 LOG_ERR     = 3    // 错误条件
定义 LOG_WARNING = 4    // 警告条件
定义 LOG_NOTICE  = 5    // 正常但重要
定义 LOG_INFO    = 6    // 信息
定义 LOG_DEBUG   = 7    // 调试

结构 日志条目 {
    时间戳_ns,    // u64 纳秒时间戳
    级别,    // u8 LOG_*
    设施,    // u8 日志设施(内核/用户/驱动)
    消息,
    序号,    // u64 全局序列号
}

定义 LOG_BUF_MAX = 4096     // 最多存储4096条日志
定义 可变 日志缓冲 = []
定义 可变 日志_序号 = 0
定义 可变 日志_总条数 = 0
定义 可变 日志_丢弃条数 = 0

定义 可变 console_loglevel = LOG_INFO     // 控制台显示<=此级别
定义 可变 default_message_loglevel = LOG_WARNING

定义 可变 控制台列表 = []    // [输出函数, 名称, 级别过滤]

// 初始化

函数 日志缓冲区_初始化() {
    日志缓冲 = []
    日志_序号 = 0
    日志_总条数 = 0
    日志_丢弃条数 = 0
    控制台列表 = []
}

// 写入日志 

函数 日志_写入(级别, 消息) {
    定义 条目 = 日志条目 {}
    条目.时间戳_ns = sched_clock()
    条目.级别 = 级别
    条目.设施 = 0
    条目.消息 = 消息
    条目.序号 = 日志_序号
    日志_序号 = 日志_序号 + 1
    日志_总条数 = 日志_总条数 + 1

    // 缓冲区满时丢弃最旧
    如果 (计数(日志缓冲) >= LOG_BUF_MAX) {
        链表_删除(日志缓冲, 0)
        日志_丢弃条数 = 日志_丢弃条数 + 1
    }
    追加(日志缓冲, 条目)

    // 输出到所有控制台
    如果 (级别 <= console_loglevel) {
        日志_输出到控制台(条目)
    }
}

// 控制台输出

函数 日志_输出到控制台(条目) {
    // 格式: [时间戳] 级别前缀 消息
    定义 时间_秒 = 条目.时间戳_ns / 1000000000
    定义 时间_微秒 = (条目.时间戳_ns / 1000) % 1000000
    定义 前缀 = 日志级别前缀(条目.级别)
    定义 格式化 = "[" + 整数转字符串(时间_秒) + "." +
                   字符串左填充(整数转字符串(时间_微秒), 6, "0") + "] " +
                   前缀 + 条目.消息

    定义 可变 i = 0
    当 (i < 计数(控制台列表)) {
        定义 控制台 = 控制台列表[i]
        定义 输出函数 = 控制台[0]
        如果 (输出函数 != 空) { 输出函数(格式化) }
        i = i + 1
    }
}

函数 日志级别前缀(级别) {
    如果 (级别 <= LOG_ERR) { 返回 "" }
    如果 (级别 == LOG_WARNING) { 返回 "" }
    返回 ""
}

// 注册控制台 

函数 注册控制台_缓冲区(输出函数, 名称) {
    追加(控制台列表, [输出函数, 名称])
}

// dmesg: 读取日志缓冲区 

函数 dmesg_读取() {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(日志缓冲)) {
        定义 条目 = 日志缓冲[i]
        定义 时间_秒 = 条目.时间戳_ns / 1000000000
        定义 时间_微秒 = (条目.时间戳_ns / 1000) % 1000000
        结果 = 结果 + "[" + 整数转字符串(时间_秒) + "." +
               字符串左填充(整数转字符串(时间_微秒), 6, "0") + "] " +
               条目.消息 + "\n"
        i = i + 1
    }
    返回 结果
}

函数 dmesg_读取_最近(n) {
    定义 可变 结果 = ""
    定义 起始 = 计数(日志缓冲) - n
    如果 (起始 < 0) { 起始 = 0 }
    定义 可变 i = 起始
    当 (i < 计数(日志缓冲)) {
        定义 条目 = 日志缓冲[i]
        结果 = 结果 + 条目.消息 + "\n"
        i = i + 1
    }
    返回 结果
}

函数 dmesg_清空_缓冲区() {
    日志缓冲 = []
}

// 控制台日志级别设置

函数 设置控制台日志级别(级别) { console_loglevel = 级别 }
函数 获取控制台日志级别() { 返回 console_loglevel }

函数 控制台_刷新() {
    // 强制输出所有缓冲的日志到所有已注册控制台
    定义 可变 i = 0
    当 (i < 计数(日志缓冲)) {
        定义 条目 = 日志缓冲[i]
        日志_输出到控制台(条目)
        i = i + 1
    }
}

// 统计

函数 日志缓冲_统计() {
    返回 [计数(日志缓冲), 日志_总条数, 日志_丢弃条数, 计数(控制台列表)]
}

// 按级别过滤日志 + 日志级别名称

函数 dmesg_按级别(级别) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(日志缓冲)) {
        如果 (日志缓冲[i].级别 == 级别) {
            结果 = 结果 + 日志缓冲[i].消息 + "\n"
        }
        i = i + 1
    }
    返回 结果
}

函数 日志级别名(级别) {
    如果 (级别 == LOG_EMERG) { 返回 "EMERG" }
    如果 (级别 == LOG_ALERT) { 返回 "ALERT" }
    如果 (级别 == LOG_CRIT) { 返回 "CRIT" }
    如果 (级别 == LOG_ERR) { 返回 "ERR" }
    如果 (级别 == LOG_WARNING) { 返回 "WARN" }
    如果 (级别 == LOG_NOTICE) { 返回 "NOTICE" }
    如果 (级别 == LOG_INFO) { 返回 "INFO" }
    如果 (级别 == LOG_DEBUG) { 返回 "DEBUG" }
    返回 "UNKNOWN"
}

函数 日志_按级别计数(级别) {
    定义 可变 计 = 0
    定义 可变 i = 0
    当 (i < 计数(日志缓冲)) {
        如果 (日志缓冲[i].级别 == 级别) { 计 = 计 + 1 }
        i = i + 1
    }
    返回 计
}


函数 日志_完整统计() {
    返回 [计数(日志缓冲), 日志_按级别计数(LOG_ERR), 日志_按级别计数(LOG_WARNING), 日志_按级别计数(LOG_INFO)]
}

定义 可变 AI_日志缓冲区_调用数 = 0
定义 可变 AI_日志缓冲区_异常数 = 0

函数 AI_日志缓冲区_监控() {
    AI_日志缓冲区_调用数 = AI_日志缓冲区_调用数 + 1
    返回 AI_日志缓冲区_异常数 == 0
}

函数 AI_日志缓冲区_健康检查() {
    如果 (AI_日志缓冲区_调用数 > 0 && AI_日志缓冲区_异常数 * 100 / AI_日志缓冲区_调用数 > 10) {
        返回 假
    }
    返回 真
}

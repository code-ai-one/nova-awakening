// §3 窗口管理 — 每个窗口=一个Nova渲染上下文

函数 Nova原生桌面_同步文档状态() {
    如果 (!桌面_已初始化) { 返回 }
    定义 可变 i = 0
    当 (i < 计数(桌面.窗口列表)) {
        如果 (桌面.窗口列表[i].可见) {
            桌面.窗口列表[i].DOM文档 = Nova原生桌面_构建窗口文档(桌面.窗口列表[i])
        } 否则 {
            桌面.窗口列表[i].DOM文档 = 空
        }
        i = i + 1
    }
    桌面.桌面DOM = Nova原生桌面_构建桌面NML()
}

函数 Nova原生桌面_查找窗口索引(窗口ID) {
    定义 可变 i = 0
    当 (i < 计数(桌面.窗口列表)) {
        如果 (桌面.窗口列表[i].ID == 窗口ID) {
            返回 i
        }
        i = i + 1
    }
    返回 -1
}

函数 Nova原生桌面_查找窗口ID_按URL(url) {
    定义 可变 i = 0
    当 (i < 计数(桌面.窗口列表)) {
        如果 (桌面.窗口列表[i].URL == url) {
            返回 桌面.窗口列表[i].ID
        }
        i = i + 1
    }
    返回 0
}

函数 Nova原生桌面_设置壳输入缓冲(输入) {
    如果 (!桌面_已初始化) { 返回 }
    桌面.壳输入缓冲 = 输入
}

函数 Nova原生桌面_记录壳状态(输入, 动作, 结果) {
    如果 (!桌面_已初始化) { 返回 }
    桌面.壳最后输入 = 输入
    桌面.壳输入缓冲 = ""
    如果 (字符串长度(动作) > 0) {
        桌面.壳最后动作 = 动作
    }
    如果 (字符串长度(结果) > 0) {
        桌面.壳最后结果 = 结果
    }
}

函数 Nova原生桌面_同步系统状态(核心状态, 核心副文本,
                           视觉状态, 视觉副文本,
                           声音状态, 声音副文本,
                           形象状态, 形象副文本) {
    如果 (!桌面_已初始化) { 返回 }
    桌面.核心状态 = 核心状态
    桌面.核心副文本 = 核心副文本
    桌面.视觉状态 = 视觉状态
    桌面.视觉副文本 = 视觉副文本
    桌面.声音状态 = 声音状态
    桌面.声音副文本 = 声音副文本
    桌面.形象状态 = 形象状态
    桌面.形象副文本 = 形象副文本
}

函数 Nova原生桌面_刷新前台模块状态() {
    如果 (!桌面_已初始化) { 返回 }
    定义 可变 已打开语音 = 假
    定义 可变 已打开形象 = 假
    定义 可变 焦点URL = ""
    定义 可变 i = 0
    当 (i < 计数(桌面.窗口列表)) {
        定义 url = 桌面.窗口列表[i].URL
        如果 (字符串查找(url, "nova://voice") == 0) {
            已打开语音 = 真
        }
        如果 (字符串查找(url, "nova://avatar") == 0) {
            已打开形象 = 真
        }
        如果 (桌面.窗口列表[i].ID == 桌面.焦点窗口) {
            焦点URL = url
        }
        i = i + 1
    }

    如果 (桌面.声音状态 == 空 || 字符串长度(桌面.声音状态) == 0) {
        桌面.声音状态 = "待机"
    }
    如果 (桌面.声音副文本 == 空 || 字符串长度(桌面.声音副文本) == 0) {
        桌面.声音副文本 = "语音前台未激活"
    }
    如果 (已打开语音) {
        如果 (桌面.声音状态 == "待机") {
            桌面.声音状态 = "在线"
        }
        如果 (桌面.声音副文本 == "语音前台未激活") {
            桌面.声音副文本 = "语音中枢窗口已挂载"
        }
    }
    如果 (字符串查找(焦点URL, "nova://voice") == 0) {
        如果 (桌面.声音状态 == "待机" || 桌面.声音状态 == "在线" || 桌面.声音状态 == "前台") {
            桌面.声音状态 = "前台"
        }
        如果 (桌面.声音副文本 == "语音前台未激活" || 桌面.声音副文本 == "语音中枢窗口已挂载") {
            桌面.声音副文本 = "语音中枢正在接收桌面入口"
        }
    }

    如果 (桌面.形象状态 == 空 || 字符串长度(桌面.形象状态) == 0) {
        桌面.形象状态 = "待机"
    }
    如果 (桌面.形象副文本 == 空 || 字符串长度(桌面.形象副文本) == 0) {
        桌面.形象副文本 = "形象前台未激活"
    }
    如果 (已打开形象) {
        如果 (桌面.形象状态 == "待机") {
            桌面.形象状态 = "在线"
        }
        如果 (桌面.形象副文本 == "形象前台未激活") {
            桌面.形象副文本 = "全息形象窗口已挂载"
        }
    }
    如果 (字符串查找(焦点URL, "nova://avatar") == 0) {
        如果 (桌面.形象状态 == "待机" || 桌面.形象状态 == "在线" || 桌面.形象状态 == "前台") {
            桌面.形象状态 = "前台"
        }
        如果 (桌面.形象副文本 == "形象前台未激活" || 桌面.形象副文本 == "全息形象窗口已挂载") {
            桌面.形象副文本 = "全息形象正在投影当前人格状态"
        }
    }
}

函数 Nova原生桌面_打开或聚焦窗口(标题, url, x, y, 宽, 高) {
    定义 现有窗口ID = Nova原生桌面_查找窗口ID_按URL(url)
    如果 (现有窗口ID > 0) {
        Nova原生桌面_聚焦窗口(现有窗口ID)
        返回 现有窗口ID
    }
    返回 Nova原生桌面_打开窗口(标题, url, x, y, 宽, 高)
}

函数 Nova原生桌面_打开窗口(标题, url, x, y, 宽, 高) {
    定义 窗口 = Nova原生桌面窗口 {}
    窗口.ID = 桌面.下一个窗口ID
    桌面.下一个窗口ID = 桌面.下一个窗口ID + 1
    窗口.标题 = 标题
    窗口.URL = url
    窗口.x = x; 窗口.y = y; 窗口.宽 = 宽; 窗口.高 = 高
    窗口.模式 = 窗口模式_普通
    窗口.Z序 = 桌面.下一个窗口ID
    窗口.可见 = 真
    窗口.活跃 = 真

    // 创建图处渲染层
    窗口.图处层ID = 浏览器图处_创建层(x, y + 桌面.系统栏高, 宽, 高)
    窗口.DOM文档 = Nova原生桌面_构建窗口文档(窗口)

    追加(桌面.窗口列表, 窗口)
    桌面.焦点窗口 = 窗口.ID
    桌面.壳最后动作 = "open-window"
    桌面.壳最后结果 = "窗口已挂载: " + 标题
    Nova原生桌面_刷新前台模块状态()
    Nova原生桌面_同步文档状态()

    // 加载URL(窗口=浏览器标签)
    事件循环_导航(url)

    内核信息("Nova原生桌面: 打开窗口 [" + 标题 + "] → " + url)
    返回 窗口.ID
}

函数 Nova原生桌面_关闭窗口(窗口ID) {
    定义 可变 i = 0
    当 (i < 计数(桌面.窗口列表)) {
        如果 (桌面.窗口列表[i].ID == 窗口ID) {
            定义 标题 = 桌面.窗口列表[i].标题
            浏览器图处_销毁层(桌面.窗口列表[i].图处层ID)
            列表_移除(桌面.窗口列表, i)
            // 焦点转移到最上层窗口
            如果 (计数(桌面.窗口列表) > 0) {
                桌面.焦点窗口 = 桌面.窗口列表[计数(桌面.窗口列表) - 1].ID
            } 否则 {
                桌面.焦点窗口 = 0
            }
            桌面.壳最后动作 = "close-window"
            桌面.壳最后结果 = "窗口已关闭: " + 标题
            Nova原生桌面_刷新前台模块状态()
            Nova原生桌面_同步文档状态()
            返回
        }
        i = i + 1
    }
}

函数 Nova原生桌面_聚焦窗口(窗口ID) {
    桌面.焦点窗口 = 窗口ID
    // 提升Z序
    定义 可变 i = 0
    当 (i < 计数(桌面.窗口列表)) {
        如果 (桌面.窗口列表[i].ID == 窗口ID) {
            桌面.窗口列表[i].Z序 = 桌面.下一个窗口ID + 100
            桌面.壳最后动作 = "focus-window"
            桌面.壳最后结果 = "焦点切换到: " + 桌面.窗口列表[i].标题
        }
        i = i + 1
    }
    Nova原生桌面_刷新前台模块状态()
    Nova原生桌面_同步文档状态()
}

函数 Nova原生桌面_最大化窗口(窗口ID) {
    定义 可变 i = 0
    当 (i < 计数(桌面.窗口列表)) {
        如果 (桌面.窗口列表[i].ID == 窗口ID) {
            桌面.窗口列表[i].模式 = 窗口模式_最大化
            桌面.窗口列表[i].x = 0
            桌面.窗口列表[i].y = 0
            桌面.窗口列表[i].宽 = 桌面.屏幕宽
            桌面.窗口列表[i].高 = Nova原生桌面_工作区高度()
            桌面.窗口列表[i].DOM文档 = Nova原生桌面_构建窗口文档(桌面.窗口列表[i])
            Nova原生桌面_同步文档状态()
            返回
        }
        i = i + 1
    }
}

// §4 桌面渲染 — 全部通过浏览器渲染管线

函数 Nova原生桌面_渲染帧() {
    如果 (!桌面_已初始化) { 返回 }
    Nova原生桌面_同步文档状态()

    // 整个桌面通过浏览器渲染管线输出:
    // 壁纸层 → 图标层 → 窗口层(每个窗口=独立浏览器渲染) → 系统栏 → 任务栏

    // 渲染桌面根DOM
    如果 (桌面.桌面DOM != 空) {
        渲染_构建树(桌面.桌面DOM)
        渲染_布局()
        渲染_绘制(桌面.桌面DOM)
    }

    // 渲染每个窗口(独立渲染上下文)
    定义 可变 i = 0
    当 (i < 计数(桌面.窗口列表)) {
        定义 窗口 = 桌面.窗口列表[i]
        如果 (窗口.可见 && 窗口.DOM文档 != 空) {
            // 每个窗口有独立的DOM/CSS/渲染树
            // 渲染到对应的图处层
        }
        i = i + 1
    }

    // 合成所有层
    浏览器图处_合成帧()
}

定义 可变 AI_窗口管理每_热节点缓存 = 0

函数 AI_窗口管理每_节点热度(节点, 操作类型) {
    如果 (操作类型 == "查询") { 返回 "缓存" }
    如果 (操作类型 == "修改") { AI_窗口管理每_热节点缓存 = 0; 返回 "失效" }
    返回 "普通"
}

函数 AI_窗口管理每_批量DOM优化(操作数) {
    如果 (操作数 > 100) { 返回 "延迟重排" }
    如果 (操作数 > 10) { 返回 "批量重排" }
    返回 "即时重排"
}

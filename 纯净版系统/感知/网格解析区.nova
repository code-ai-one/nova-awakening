// 对应: nova/Nova布局引擎/grid/ (
// nova/Nova渲染核心/css/resolver/style_builder_converter.cc (grid部分)
// 本文件扩展布局网格.nova(基础584行)，补全：
// ① 子网格 (subgrid) — 网格 Level 2
// ② 自动放置算法(完整Nova标准 §8)
// ③ 命名网格线和命名区域
// ④ 轨道大小计算(完整minmax/fr分配)
// ⑤ 对齐(justify/align-content/items/self)
// ⑥ repeat(auto-fill/auto-fit)
// ⑦ Masonry布局(实验性)
// 轨道大小计算算法(Nova标准 §12):
// 1. 初始化轨道大小(base size / growth limit)
// 2. 根据项目约束调整: min-content → max-content → fr
// 3. 拉伸auto轨道填满容器
// 4. fr分配剩余空间
// 自动放置算法(Nova标准 §8.5):
// auto-placement cursor在grid中扫描空位
// grid-auto-flow: row(默认) / column / dense
// 【Nova特色】AI 网格优化:
// ① AI检测网格布局模式，预测最佳轨道分配
// ② AI响应式断点建议

// §1 命名网格线 / 命名区域

结构 Named网格Line {
 名称,    // u64 线名字符串 e.g. "header-start"
 轴,    // u8 0=列 1=行
 索引,    // i32 网格线编号(1-based)
 下一个,    // u64 Named网格Line*
}

结构 网格Area {
 名称,    // u64 区域名 e.g. "header"
 行起始,    // i32 1-based
 行结束,
 列起始,
 列结束,
}

结构 网格AreaMap {
 区域,    // [64]网格Area
 区域数,
}

// 解析grid-template-areas
// "header header header"
// "sidebar content content"
// "footer footer footer"

函数 网格_解析区域模板(模板字符串, 区域map) {
 如果 (模板字符串 == 0 || 区域map == 0) { 返回 }
 // 按行分割，每行按空格分割得到单元格名称
 // 相同名称的连续单元格合并为一个区域
 // 验证：每个区域必须是矩形
 定义 可变 行号 = 1
 定义 可变 pos = 0
 定义 len = 字节长度(模板字符串)

 当 (pos < len) {
 // 跳到引号内
 如果 (字节取(模板字符串, pos) == 34) { // '"'
 pos = pos + 1
 定义 可变 列号 = 1
 当 (pos < len && 字节取(模板字符串, pos) != 34) {
 // 跳过空白
 当 (pos < len && 字节取(模板字符串, pos) == 32) { pos = pos + 1 }
 如果 (pos >= len || 字节取(模板字符串, pos) == 34) { 跳出 }
 // 读取名称
 定义 名称起始 = pos
 当 (pos < len && 字节取(模板字符串, pos) != 32 && 字节取(模板字符串, pos) != 34) {
 pos = pos + 1
 }
 定义 名称 = 字符串_子串(模板字符串, 名称起始, pos)
 如果 (名称 != 0 && 字节取(名称, 0) != 46) { // '.'是默认值
 网格_注册区域单元(区域map, 名称, 行号, 列号)
 }
 列号 = 列号 + 1
 }
 如果 (pos < len) { pos = pos + 1 } // 跳过闭合引号
 行号 = 行号 + 1
 }
 pos = pos + 1
 }
}

函数 网格_注册区域单元(map, 名称, 行, 列) {
 如果 (map == 0 || 名称 == 0) { 返回 }
 // 查找已有区域
 定义 可变 i = 0
 当 (i < map.区域数) {
 如果 (字符串_相等(map.区域[i].名称, 名称)) {
 // 扩展区域边界
 如果 (行 < map.区域[i].行起始) { map.区域[i].行起始 = 行 }
 如果 (行 + 1 > map.区域[i].行结束) { map.区域[i].行结束 = 行 + 1 }
 如果 (列 < map.区域[i].列起始) { map.区域[i].列起始 = 列 }
 如果 (列 + 1 > map.区域[i].列结束) { map.区域[i].列结束 = 列 + 1 }
 返回
 }
 i = i + 1
 }
 // 新区域
 如果 (map.区域数 >= 64) { 返回 }
 map.区域[map.区域数].名称 = 字符串_复制(名称)
 map.区域[map.区域数].行起始 = 行
 map.区域[map.区域数].行结束 = 行 + 1
 map.区域[map.区域数].列起始 = 列
 map.区域[map.区域数].列结束 = 列 + 1
 map.区域数 = map.区域数 + 1
}

// 通过区域名查找位置
函数 网格_查找区域(map, 名称) {
 如果 (map == 0 || 名称 == 0) { 返回 -1 }
 定义 可变 i = 0
 当 (i < map.区域数) {
 如果 (字符串_相等(map.区域[i].名称, 名称)) { 返回 i }
 i = i + 1
 }
 返回 -1
}

// 通过命名线解析位置
函数 网格_解析命名线(命名线头, 名称, 轴) {
 如果 (命名线头 == 0 || 名称 == 0) { 返回 -1 }
 定义 可变 line = 命名线头
 当 (line != 0) {
 如果 (line.轴 == 轴 && 字符串_相等(line.名称, 名称)) {
 返回 line.索引
 }
 line = line.下一个
 }
 返回 -1
}

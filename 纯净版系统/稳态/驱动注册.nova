导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/中断表注册处.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/时钟中枢.nova")
导入("../中枢/整数转字符串.nova")
导入("../记忆/块输入输出.nova")
导入("../中枢/同步原语.nova")

定义 驱动_最大数量 = 256
定义 驱动状态_未绑定 = 0
定义 驱动状态_已绑定 = 1
定义 驱动状态_挂起 = 2
定义 驱动状态_错误 = 3

定义 电源状态_运行 = 0
定义 电源状态_空闲 = 1
定义 电源状态_挂起 = 2
定义 电源状态_休眠 = 3
定义 电源状态_关闭 = 4

定义 匹配_供应商ID = 1
定义 匹配_设备ID = 2
定义 匹配_类代码 = 4
定义 匹配_名称 = 8

定义 可变 全局驱动表 = []
定义 可变 全局驱动数 = 0
定义 可变 全局设备表 = []
定义 可变 全局设备数 = 0

结构 驱动注册统计 {
    驱动注册次数,
    驱动注销次数,
    设备注册次数,
    设备注销次数,
    绑定次数,
    绑定失败次数,
    解绑次数,
    匹配尝试次数,
    匹配成功次数,
    探测次数,
    探测失败次数,
    电源状态变化次数,
    热插拔事件次数,
}

定义 可变 全局_驱动统计 = 空

函数 驱动统计_初始化() {
    如果 (全局_驱动统计 == 空) {
        全局_驱动统计 = 驱动注册统计 {}
        全局_驱动统计.驱动注册次数 = 0
        全局_驱动统计.驱动注销次数 = 0
        全局_驱动统计.设备注册次数 = 0
        全局_驱动统计.设备注销次数 = 0
        全局_驱动统计.绑定次数 = 0
        全局_驱动统计.绑定失败次数 = 0
        全局_驱动统计.解绑次数 = 0
        全局_驱动统计.匹配尝试次数 = 0
        全局_驱动统计.匹配成功次数 = 0
        全局_驱动统计.探测次数 = 0
        全局_驱动统计.探测失败次数 = 0
        全局_驱动统计.电源状态变化次数 = 0
        全局_驱动统计.热插拔事件次数 = 0

        定义 可变 i = 0
        当 (i < 驱动_最大数量) {
            追加(全局驱动表, 空)
            追加(全局设备表, 空)
            i = i + 1
        }
    }
}

函数 驱动_注册(drv) {
    驱动统计_初始化()
    全局_驱动统计.驱动注册次数 = 全局_驱动统计.驱动注册次数 + 1

    如果 (drv == 空) { 返回 错误码_无效参数 }

    如果 (全局驱动数 >= 驱动_最大数量) {
        内核信息("驱动注册失败: 驱动表已满 (%s)\n", drv.名称)
        返回 错误码_无空间
    }

    drv.状态 = 驱动状态_未绑定
    drv.设备列表 = 空
    drv.设备数 = 0

    定义 可变 槽位 = -1
    定义 可变 i = 0
    当 (i < 驱动_最大数量) {
        如果 (全局驱动表[i] == 空) {
            槽位 = i
            i = 驱动_最大数量
        }
        i = i + 1
    }

    如果 (槽位 < 0) { 返回 错误码_无空间 }

    全局驱动表[槽位] = drv
    全局驱动数 = 全局驱动数 + 1

    如果 (drv.总线 != 空) {
        互斥锁_获取(drv.总线.锁)
        drv.总线.驱动数 = drv.总线.驱动数 + 1
        互斥锁_释放(drv.总线.锁)

        驱动_匹配设备(drv)
    }

    内核信息("驱动注册: %s (槽位=%d)\n", drv.名称, 槽位)
    返回 0
}

函数 驱动_注销(drv) {
    驱动统计_初始化()
    全局_驱动统计.驱动注销次数 = 全局_驱动统计.驱动注销次数 + 1

    如果 (drv == 空) { 返回 }

    定义 可变 dev = drv.设备列表
    当 (dev != 空) {
        定义 下一个 = dev.驱动链接
        驱动_解绑设备(drv, dev)
        dev = 下一个
    }

    定义 可变 i = 0
    当 (i < 驱动_最大数量) {
        如果 (全局驱动表[i] == drv) {
            全局驱动表[i] = 空
            全局驱动数 = 全局驱动数 - 1
            跳出
        }
        i = i + 1
    }

    如果 (drv.总线 != 空) {
        互斥锁_获取(drv.总线.锁)
        drv.总线.驱动数 = drv.总线.驱动数 - 1
        互斥锁_释放(drv.总线.锁)
    }

    内核信息("驱动注销: %s\n", drv.名称)
}

函数 驱动_匹配设备(drv) {
    驱动统计_初始化()
    如果 (drv == 空 || drv.总线 == 空) { 返回 }

    互斥锁_获取(drv.总线.锁)
    定义 可变 dev = drv.总线.设备列表
    当 (dev != 空) {
        如果 (dev.驱动 == 空) {
            全局_驱动统计.匹配尝试次数 = 全局_驱动统计.匹配尝试次数 + 1
            如果 (驱动_设备匹配(drv, dev)) {
                全局_驱动统计.匹配成功次数 = 全局_驱动统计.匹配成功次数 + 1
                驱动_绑定设备(drv, dev)
            }
        }
        dev = dev.总线链接
    }
    互斥锁_释放(drv.总线.锁)
}

函数 驱动_设备匹配(drv, dev) {
    如果 (drv.匹配标志 & 匹配_供应商ID) {
        如果 (drv.供应商ID != dev.供应商ID) { 返回 假 }
    }
    如果 (drv.匹配标志 & 匹配_设备ID) {
        如果 (drv.设备ID != dev.设备ID) { 返回 假 }
    }
    如果 (drv.匹配标志 & 匹配_类代码) {
        如果 (drv.类代码 != dev.类代码) { 返回 假 }
    }
    如果 (drv.匹配标志 & 匹配_名称) {
        如果 (!字符串_相等(drv.匹配名称, dev.名称)) { 返回 假 }
    }

    如果 (drv.总线.匹配 != 空) {
        返回 drv.总线.匹配(dev, drv)
    }

    返回 真
}

函数 驱动_绑定设备(drv, dev) {
    驱动统计_初始化()

    如果 (drv.探测 != 空) {
        全局_驱动统计.探测次数 = 全局_驱动统计.探测次数 + 1
        定义 结果 = drv.探测(dev)
        如果 (结果 != 0) {
            全局_驱动统计.探测失败次数 = 全局_驱动统计.探测失败次数 + 1
            全局_驱动统计.绑定失败次数 = 全局_驱动统计.绑定失败次数 + 1
            内核信息("驱动探测失败: %s -> %s (错误=%d)\n", drv.名称, dev.名称, 结果)
            返回 结果
        }
    }

    dev.驱动 = drv
    dev.驱动链接 = drv.设备列表
    drv.设备列表 = dev
    drv.设备数 = drv.设备数 + 1
    drv.状态 = 驱动状态_已绑定

    全局_驱动统计.绑定次数 = 全局_驱动统计.绑定次数 + 1
    内核信息("驱动绑定: %s -> %s\n", drv.名称, dev.名称)
    返回 0
}

函数 驱动_解绑设备(drv, dev) {
    驱动统计_初始化()
    全局_驱动统计.解绑次数 = 全局_驱动统计.解绑次数 + 1

    如果 (drv == 空 || dev == 空) { 返回 }

    如果 (drv.移除 != 空) {
        drv.移除(dev)
    }

    如果 (drv.设备列表 == dev) {
        drv.设备列表 = dev.驱动链接
    } 否则 {
        定义 可变 前驱 = drv.设备列表
        当 (前驱 != 空 && 前驱.驱动链接 != dev) {
            前驱 = 前驱.驱动链接
        }
        如果 (前驱 != 空) {
            前驱.驱动链接 = dev.驱动链接
        }
    }

    dev.驱动 = 空
    dev.驱动链接 = 空
    drv.设备数 = drv.设备数 - 1

    如果 (drv.设备数 == 0) {
        drv.状态 = 驱动状态_未绑定
    }

    内核信息("驱动解绑: %s <- %s\n", drv.名称, dev.名称)
}

函数 设备_注册(名称, 类型, 主设备号) {
    驱动统计_初始化()
    全局_驱动统计.设备注册次数 = 全局_驱动统计.设备注册次数 + 1

    如果 (全局设备数 >= 驱动_最大数量) {
        内核信息("设备注册失败: 设备表已满\n")
        返回 错误码_无空间
    }

    定义 可变 dev = 堆_分配(64)
    dev.名称 = 名称
    dev.类型 = 类型
    dev.主设备号 = 主设备号
    原子_设置(dev.引用计数, 1)
    dev.驱动 = 空
    dev.已初始化 = 真
    dev.电源状态 = 电源状态_运行

    定义 可变 槽位 = -1
    定义 可变 i = 0
    当 (i < 驱动_最大数量) {
        如果 (全局设备表[i] == 空) {
            槽位 = i
            i = 驱动_最大数量
        }
        i = i + 1
    }

    如果 (槽位 < 0) { 返回 错误码_无空间 }

    全局设备表[槽位] = dev
    全局设备数 = 全局设备数 + 1

    如果 (dev.总线 != 空) {
        互斥锁_获取(dev.总线.锁)
        dev.总线链接 = dev.总线.设备列表
        dev.总线.设备列表 = dev
        dev.总线.设备数 = dev.总线.设备数 + 1
        互斥锁_释放(dev.总线.锁)

        设备_匹配驱动(dev)
    }

    如果 (dev.父设备 != 空) {
        dev.兄弟链接 = dev.父设备.子设备链表
        dev.父设备.子设备链表 = dev
    }

    内核信息("设备注册: %s (类型=%d, 主=%d)\n", dev.名称, 类型, 主设备号)
    返回 0
}

函数 设备_注销(dev) {
    驱动统计_初始化()
    全局_驱动统计.设备注销次数 = 全局_驱动统计.设备注销次数 + 1

    如果 (dev == 空) { 返回 }

    如果 (dev.驱动 != 空) {
        驱动_解绑设备(dev.驱动, dev)
    }

    如果 (dev.总线 != 空) {
        互斥锁_获取(dev.总线.锁)
        如果 (dev.总线.设备列表 == dev) {
            dev.总线.设备列表 = dev.总线链接
        } 否则 {
            定义 可变 前驱 = dev.总线.设备列表
            当 (前驱 != 空 && 前驱.总线链接 != dev) {
                前驱 = 前驱.总线链接
            }
            如果 (前驱 != 空) {
                前驱.总线链接 = dev.总线链接
            }
        }
        dev.总线.设备数 = dev.总线.设备数 - 1
        互斥锁_释放(dev.总线.锁)
    }

    定义 可变 i = 0
    当 (i < 驱动_最大数量) {
        如果 (全局设备表[i] == dev) {
            全局设备表[i] = 空
            全局设备数 = 全局设备数 - 1
            跳出
        }
        i = i + 1
    }

    dev.已初始化 = 假
    内核信息("设备注销: %s\n", dev.名称)
}

函数 设备_匹配驱动(dev) {
    驱动统计_初始化()
    如果 (dev == 空 || dev.总线 == 空) { 返回 }

    定义 可变 i = 0
    当 (i < 驱动_最大数量) {
        定义 drv = 全局驱动表[i]
        如果 (drv != 空 && drv.总线 == dev.总线) {
            全局_驱动统计.匹配尝试次数 = 全局_驱动统计.匹配尝试次数 + 1
            如果 (驱动_设备匹配(drv, dev)) {
                全局_驱动统计.匹配成功次数 = 全局_驱动统计.匹配成功次数 + 1
                驱动_绑定设备(drv, dev)
                返回
            }
        }
        i = i + 1
    }
}

函数 设备_电源管理(dev, 新状态) {
    驱动统计_初始化()
    全局_驱动统计.电源状态变化次数 = 全局_驱动统计.电源状态变化次数 + 1

    如果 (dev == 空) { 返回 错误码_无效参数 }

    定义 旧状态 = dev.电源状态

    如果 (dev.驱动 != 空) {
        如果 (新状态 == 电源状态_挂起 && dev.驱动.挂起 != 空) {
            dev.驱动.挂起(dev)
        } 否则 如果 (新状态 == 电源状态_运行 && 旧状态 == 电源状态_挂起 && dev.驱动.恢复 != 空) {
            dev.驱动.恢复(dev)
        }
    }

    dev.电源状态 = 新状态
    内核信息("设备电源: %s %d -> %d\n", dev.名称, 旧状态, 新状态)
    返回 0
}

函数 设备_热插拔(dev, 插入) {
    驱动统计_初始化()
    全局_驱动统计.热插拔事件次数 = 全局_驱动统计.热插拔事件次数 + 1

    如果 (插入) {
        内核信息("热插拔: 设备插入 %s\n", dev.名称)
        设备_注册(dev.名称, dev.类型, dev.主设备号)
    } 否则 {
        内核信息("热插拔: 设备移除 %s\n", dev.名称)
        设备_注销(dev)
    }
}

函数 设备_获取引用(dev) {
    如果 (dev == 空) { 返回 空 }
    原子_增加(dev.引用计数)
    返回 dev
}

函数 设备_释放引用(dev) {
    如果 (dev == 空) { 返回 }
    如果 (原子_减少(dev.引用计数) == 0) {
        设备_注销(dev)
    }
}

函数 驱动_查找(名称) {
    定义 可变 i = 0
    当 (i < 驱动_最大数量) {
        如果 (全局驱动表[i] != 空 && 字符串_相等(全局驱动表[i].名称, 名称)) {
            返回 全局驱动表[i]
        }
        i = i + 1
    }
    返回 空
}

函数 设备_查找(名称) {
    定义 可变 i = 0
    当 (i < 驱动_最大数量) {
        如果 (全局设备表[i] != 空 && 字符串_相等(全局设备表[i].名称, 名称)) {
            返回 全局设备表[i]
        }
        i = i + 1
    }
    返回 空
}

函数 设备_枚举(总线, 回调) {
    如果 (总线 == 空 || 回调 == 空) { 返回 }
    互斥锁_获取(总线.锁)
    定义 可变 dev = 总线.设备列表
    当 (dev != 空) {
        回调(dev)
        dev = dev.总线链接
    }
    互斥锁_释放(总线.锁)
}

函数 驱动_枚举(回调) {
    如果 (回调 == 空) { 返回 }
    定义 可变 i = 0
    当 (i < 驱动_最大数量) {
        如果 (全局驱动表[i] != 空) {
            回调(全局驱动表[i])
        }
        i = i + 1
    }
}

函数 驱动_打印统计() {
    驱动统计_初始化()
    打印行("=== 驱动注册统计 ===")
    打印行("驱动注册: " + 整数转字符串(全局_驱动统计.驱动注册次数))
    打印行("驱动注销: " + 整数转字符串(全局_驱动统计.驱动注销次数))
    打印行("设备注册: " + 整数转字符串(全局_驱动统计.设备注册次数))
    打印行("设备注销: " + 整数转字符串(全局_驱动统计.设备注销次数))
    打印行("绑定: " + 整数转字符串(全局_驱动统计.绑定次数))
    打印行("绑定失败: " + 整数转字符串(全局_驱动统计.绑定失败次数))
    打印行("解绑: " + 整数转字符串(全局_驱动统计.解绑次数))
    打印行("匹配尝试: " + 整数转字符串(全局_驱动统计.匹配尝试次数))
    打印行("匹配成功: " + 整数转字符串(全局_驱动统计.匹配成功次数))
    打印行("探测: " + 整数转字符串(全局_驱动统计.探测次数))
    打印行("探测失败: " + 整数转字符串(全局_驱动统计.探测失败次数))
    打印行("电源变化: " + 整数转字符串(全局_驱动统计.电源状态变化次数))
    打印行("热插拔: " + 整数转字符串(全局_驱动统计.热插拔事件次数))
    打印行("活跃驱动: " + 整数转字符串(全局驱动数))
    打印行("活跃设备: " + 整数转字符串(全局设备数))
}

// §8 驱动依赖解析

定义 驱动依赖_最大深度 = 8

结构 驱动依赖项 {
    驱动名称,
    依赖名称,
    是否可选,
}

定义 可变 驱动依赖表 = []

函数 驱动_添加依赖(驱动名称, 依赖名称, 可选) {
    如果 (计数(驱动依赖表) >= 驱动_最大数量 * 4) { 返回 }
    定义 dep = 驱动依赖项 {}
    dep.驱动名称 = 驱动名称
    dep.依赖名称 = 依赖名称
    dep.是否可选 = 可选
    追加(驱动依赖表, dep)
}

函数 驱动_检查依赖(驱动名称) {
    // 检查该驱动的所有必需依赖是否已注册
    定义 可变 i = 0
    当 (i < 计数(驱动依赖表)) {
        如果 (驱动依赖表[i].驱动名称 == 驱动名称 && !驱动依赖表[i].是否可选) {
            定义 dep_drv = 驱动_查找(驱动依赖表[i].依赖名称)
            如果 (dep_drv == 空) {
                内核警告("驱动依赖未满足: " + 驱动名称 + " 需要 " + 驱动依赖表[i].依赖名称)
                返回 假
            }
        }
        i = i + 1
    }
    返回 真
}

函数 驱动_拓扑排序(结果列表) {
    // 简化拓扑排序: 无依赖的先加载
    定义 可变 已处理 = []
    定义 可变 轮次 = 0
    当 (轮次 < 驱动依赖_最大深度 && 计数(已处理) < 全局驱动数) {
        定义 可变 i = 0
        当 (i < 驱动_最大数量) {
            如果 (全局驱动表[i] != 空) {
                定义 名称 = 全局驱动表[i].名称
                定义 可变 已加入 = 假
                定义 可变 j = 0
                当 (j < 计数(已处理)) {
                    如果 (已处理[j] == 名称) { 已加入 = 真 }
                    j = j + 1
                }
                如果 (!已加入 && 驱动_依赖已满足(名称, 已处理)) {
                    追加(结果列表, 名称)
                    追加(已处理, 名称)
                }
            }
            i = i + 1
        }
        轮次 = 轮次 + 1
    }
}

函数 驱动_依赖已满足(驱动名称, 已处理列表) {
    定义 可变 i = 0
    当 (i < 计数(驱动依赖表)) {
        如果 (驱动依赖表[i].驱动名称 == 驱动名称 && !驱动依赖表[i].是否可选) {
            定义 可变 找到 = 假
            定义 可变 j = 0
            当 (j < 计数(已处理列表)) {
                如果 (已处理列表[j] == 驱动依赖表[i].依赖名称) { 找到 = 真 }
                j = j + 1
            }
            如果 (!找到) { 返回 假 }
        }
        i = i + 1
    }
    返回 真
}

// §9 驱动健康检查

定义 可变 健康检查_间隔 = 30000    // 30秒
定义 可变 上次健康检查时间 = 0

函数 驱动_健康检查() {
    驱动统计_初始化()
    定义 当前时间 = 读取毫秒()
    如果 (当前时间 - 上次健康检查时间 < 健康检查_间隔) { 返回 }
    上次健康检查时间 = 当前时间

    定义 可变 i = 0
    当 (i < 驱动_最大数量) {
        如果 (全局驱动表[i] != 空) {
            定义 drv = 全局驱动表[i]
            // 检查驱动是否还有绑定的设备
            如果 (drv.设备计数 == 0 && drv.状态 == 驱动状态_已注册) {
                内核信息("健康检查: 驱动 " + drv.名称 + " 无绑定设备")
            }
        }
        i = i + 1
    }
}

函数 驱动_健康摘要() {
    定义 可变 活跃数 = 0
    定义 可变 空闲数 = 0
    定义 可变 i = 0
    当 (i < 驱动_最大数量) {
        如果 (全局驱动表[i] != 空) {
            如果 (全局驱动表[i].设备计数 > 0) {
                活跃数 = 活跃数 + 1
            } 否则 {
                空闲数 = 空闲数 + 1
            }
        }
        i = i + 1
    }
    返回 [活跃数, 空闲数, 全局驱动数, 全局设备数]
}

// NDRT — Nova Driver Registration Theory
// 公理1(注册唯一性): 同名驱动不可重复注册
// 公理2(依赖有序): 驱动加载顺序满足依赖拓扑序
// 公理3(引用安全): 设备引用计数归零前不可释放
// 定理1(热插拔一致): 插入→注册→匹配→绑定 序列原子性
// 定理2(健康可观): 定期健康检查检测驱动退化

// NDRT — Nova Driver Registration Theory
// 公理1(绑定唯一): 每个设备在任意时刻最多绑定一个驱动
// 公理2(引用守恒): 引用计数归零时自动注销, 不泄露资源
// 公理3(总线隔离): 不同总线上的设备互不影响
// 定理1(热插拔完备): 插入自动注册+匹配, 拔出自动注销
// 定理2(电源状态一致): 设备电源状态与系统电源管理同步

函数 驱动_重置统计() {
    驱动统计_初始化()
    全局_驱动统计.驱动注册次数 = 0
    全局_驱动统计.驱动注销次数 = 0
    全局_驱动统计.设备注册次数 = 0
    全局_驱动统计.设备注销次数 = 0
    全局_驱动统计.绑定次数 = 0
    全局_驱动统计.绑定失败次数 = 0
    全局_驱动统计.解绑次数 = 0
    全局_驱动统计.匹配尝试次数 = 0
    全局_驱动统计.匹配成功次数 = 0
    全局_驱动统计.探测次数 = 0
    全局_驱动统计.探测失败次数 = 0
    全局_驱动统计.电源状态变化次数 = 0
    全局_驱动统计.热插拔事件次数 = 0
}

函数 设备_批量电源管理(总线, 新状态) {
    如果 (总线 == 空) { 返回 }
    互斥锁_获取(总线.锁)
    定义 可变 dev = 总线.设备列表
    当 (dev != 空) {
        设备_电源管理(dev, 新状态)
        dev = dev.总线链接
    }
    互斥锁_释放(总线.锁)
}

定义 可变 AI_驱动注册_故障预警数 = 0

函数 AI_驱动注册_设备健康(错误率, 响应时间, 温度) {
    定义 可变 分 = 1000
    如果 (错误率 > 10) { 分 = 分 - 错误率 * 5 }
    如果 (响应时间 > 1000) { 分 = 分 - 200 }
    如果 (温度 > 80) { 分 = 分 - 300 }
    如果 (分 < 300) { AI_驱动注册_故障预警数 = AI_驱动注册_故障预警数 + 1 }
    返回 分
}

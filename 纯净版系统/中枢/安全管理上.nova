外部 通过PID查找进程        // PID分配器.nova

函数 复制地址空间(mm) {
    // Copy-On-Write(COW)复制地址空间
    // fork()时不立即复制所有页面, 而是共享只读页面
    // 当任一方写入时触发缺页中断, 在中断处理中复制该页
    如果 (mm == 空) { 返回 空 }

    定义 新mm = 内存描述符_分配()
    如果 (新mm == 空) { 返回 空 }

    // 复制VMA链表(每个虚拟内存区域)
    新mm.VMA列表 = []
    定义 可变 i = 0
    当 (i < 计数(mm.VMA列表)) {
        定义 原_vma = mm.VMA列表[i]
        定义 新_vma = VMA_复制(原_vma)
        追加(新mm.VMA列表, 新_vma)
        i = i + 1
    }

    // 复制页表(PML4) — 但所有用户页设为只读(COW)
    新mm.PML4 = 页表_复制_COW(mm.PML4)
    新mm.brk当前 = mm.brk当前
    新mm.brk起始 = mm.brk起始
    新mm.Nova内存映射基址 = mm.Nova内存映射基址
    新mm.总页数 = mm.总页数
    新mm.引用计数 = 1

    返回 新mm
}

函数 复制文件表(ft) {
    // 复制文件描述符表: 每个fd指向同一个文件对象(增加引用计数)
    如果 (ft == 空) { 返回 空 }

    定义 新ft = 文件表_分配()
    如果 (新ft == 空) { 返回 空 }

    新ft.最大fd = ft.最大fd
    新ft.fd数组 = []
    新ft.引用计数 = 1

    // 复制每个打开的fd
    定义 可变 i = 0
    当 (i < 计数(ft.fd数组)) {
        定义 原fd = ft.fd数组[i]
        如果 (原fd != 空) {
            // 增加底层文件对象的引用计数
            原fd.文件对象.引用计数 = 原fd.文件对象.引用计数 + 1
            // 复制fd条目(新fd指向同一文件对象, 但有独立的偏移量)
            定义 新fd条目 = fd条目_复制(原fd)
            追加(新ft.fd数组, 新fd条目)
        } 否则 {
            追加(新ft.fd数组, 空)
        }
        i = i + 1
    }
    返回 新ft
}

函数 复制FS信息(fs) {
    // 复制文件系统信息(cwd/root/umask)
    如果 (fs == 空) { 返回 空 }
    定义 新fs = FS信息_分配()
    新fs.当前目录 = fs.当前目录
    新fs.根目录 = fs.根目录
    新fs.umask = fs.umask
    新fs.引用计数 = 1
    // 增加目录引用
    如果 (新fs.当前目录 != 空) {
        新fs.当前目录.引用计数 = 新fs.当前目录.引用计数 + 1
    }
    返回 新fs
}

函数 复制信号处理(sh) {
    // 复制信号处理器表(sigaction数组)
    如果 (sh == 空) { 返回 空 }
    定义 新sh = 信号处理_分配()
    新sh.引用计数 = 1
    // 复制所有64个信号的处理器
    定义 可变 sig = 0
    当 (sig < 64) {
        新sh.处理器[sig] = sh.处理器[sig]
        sig = sig + 1
    }
    返回 新sh
}

函数 复制线程上下文(子, 父) {
    // 复制父进程的寄存器状态到子进程
    // x86-64: RAX/RBX/RCX/RDX/RSI/RDI/RBP/RSP/R8-R15/RIP/RFLAGS/FS_BASE/GS_BASE
    子.寄存器.RBX = 父.寄存器.RBX
    子.寄存器.RCX = 父.寄存器.RCX
    子.寄存器.RDX = 父.寄存器.RDX
    子.寄存器.RSI = 父.寄存器.RSI
    子.寄存器.RDI = 父.寄存器.RDI
    子.寄存器.RBP = 父.寄存器.RBP
    子.寄存器.RSP = 父.寄存器.RSP
    子.寄存器.R8  = 父.寄存器.R8
    子.寄存器.R9  = 父.寄存器.R9
    子.寄存器.R10 = 父.寄存器.R10
    子.寄存器.R11 = 父.寄存器.R11
    子.寄存器.R12 = 父.寄存器.R12
    子.寄存器.R13 = 父.寄存器.R13
    子.寄存器.R14 = 父.寄存器.R14
    子.寄存器.R15 = 父.寄存器.R15
    子.寄存器.RIP = 父.寄存器.RIP
    子.寄存器.RFLAGS = 父.寄存器.RFLAGS
    // RAX在调用处设为0(子进程fork返回0)
}

函数 释放地址空间(mm) {
    如果 (mm == 空) { 返回 }
    // 释放所有VMA和其映射的页面
    定义 可变 i = 0
    当 (i < 计数(mm.VMA列表)) {
        定义 vma = mm.VMA列表[i]
        // 解除映射并释放物理页
        munmap_释放(vma.起始地址, vma.结束地址 - vma.起始地址)
        i = i + 1
    }
    // 释放页表结构本身
    页表_释放(mm.PML4)
    内存描述符_释放(mm)
}

定义 可变 AI_安全管理上_负载窗口 = []

函数 AI_安全管理上_负载预测(当前负载) {
    追加(AI_安全管理上_负载窗口, 当前负载)
    如果 (计数(AI_安全管理上_负载窗口) > 20) { 列表_移除(AI_安全管理上_负载窗口, 0) }
    如果 (计数(AI_安全管理上_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_安全管理上_负载窗口)
    定义 趋势 = AI_安全管理上_负载窗口[n-1] - AI_安全管理上_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_安全管理上_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

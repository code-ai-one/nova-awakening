导入("../感知/文档节点.nova")
导入("../感知/白璃主题.nova")
导入("./界面组件.nova")
导入("./窗口管理每.nova")
导入("./桌面元素甲.nova")
导入("./合成器对接.nova")
导入("./组件网化.nova")
导入("./网桌面引擎.nova")
导入("./生成窗口元.nova")
导入("./页面访问智.nova")
导入("../感知/原子驻留.nova")
导入("./原生原生桌.nova")
导入("./桌面元素生.nova")
导入("../中枢/会话桥一体.nova")
导入("../中枢/整数转字符串.nova")

结构 界面档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    宽度,
    高度,
    桌面数,
    窗口数,
    页面数,
    合成数,
    组件数,
    操作数,
    成功数,
    失败数,
}

结构 界面请求 {
    动作,
    目标,
    参数,
    选项,
}

结构 界面回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 界面摘要 {
    名称,
    宽度,
    高度,
    桌面数,
    窗口数,
    页面数,
    合成数,
    组件数,
    操作数,
    成功数,
    失败数,
    健康,
}

定义 可变 界面账本 = []
定义 可变 界面构建数 = 0
定义 可变 界面总动作 = 0
定义 可变 界面总成功 = 0
定义 可变 界面总失败 = 0

函数 内核界面_建档(名称) {
    定义 档 = 界面档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.宽度 = 0
    档.高度 = 0
    档.桌面数 = 0
    档.窗口数 = 0
    档.页面数 = 0
    档.合成数 = 0
    档.组件数 = 0
    档.操作数 = 0
    档.成功数 = 0
    档.失败数 = 0
    返回 档
}

函数 内核界面_登记(档) {
    追加(界面账本, 档)
    界面构建数 = 界面构建数 + 1
    返回 档
}

函数 内核界面_完整统计() {
    返回 [
        界面构建数,
        界面总动作,
        界面总成功,
        界面总失败
    ]
}

函数 内核界面_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 界面回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 内核界面_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.失败数 > 档.成功数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (档.窗口数 > 0 || 档.页面数 > 0 || 档.合成数 > 0) {
        档.最近健康 = "运行"
        返回 档.最近健康
    }
    档.最近健康 = "空载"
    返回 档.最近健康
}

函数 内核界面_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    档.最近错误 = ""
    档.最近统计 = 内核界面_完整统计()
}

函数 内核界面_成功(档, 来源, 数据) {
    界面总动作 = 界面总动作 + 1
    界面总成功 = 界面总成功 + 1
    如果 (档 == 空) {
        返回 内核界面_建回证(真, 真, 来源, "", 数据, 内核界面_完整统计())
    }
    档.最近来源 = 来源
    档.最近结果 = 数据
    档.最近错误 = ""
    档.操作数 = 档.操作数 + 1
    档.成功数 = 档.成功数 + 1
    档.最近统计 = 内核界面_完整统计()
    内核界面_刷新健康(档)
    返回 内核界面_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 内核界面_失败(档, 来源, 错因) {
    界面总动作 = 界面总动作 + 1
    界面总失败 = 界面总失败 + 1
    如果 (档 == 空) {
        返回 内核界面_建回证(真, 假, 来源, 错因, 0, 内核界面_完整统计())
    }
    档.最近来源 = 来源
    档.最近错误 = 错因
    档.失败数 = 档.失败数 + 1
    档.最近统计 = 内核界面_完整统计()
    内核界面_刷新健康(档)
    返回 内核界面_建回证(真, 假, 来源, 错因, 0, 档.最近统计)
}

函数 内核界面_初始化(档, 宽, 高) {
    Nova原生桌面_初始化(宽, 高)
    合成器对接_初始化()
    组件Web化_初始化()
    Web桌面_初始化(宽, 高)
    Web桌面_确保已初始化()
    档.是否初始化 = 真
    档.宽度 = 宽
    档.高度 = 高
    档.桌面数 = 1
    档.最近动作 = "初始化"
    档.最近来源 = "内核界面_初始化"
    档.最近统计 = 内核界面_完整统计()
    内核界面_刷新健康(档)
    返回 档
}

函数 内核界面_创建(名称, 宽, 高) {
    定义 档 = 内核界面_建档(名称)
    内核界面_初始化(档, 宽, 高)
    返回 内核界面_登记(档)
}

函数 内核界面_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (!档.是否初始化) { 返回 假 }
    返回 真
}

函数 内核界面_构建桌面文档(档) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "构建桌面文档", "界面档不可用") }
    内核界面_记录(档, "构建桌面文档", [], "原生桌面")
    定义 结果 = Nova原生桌面_构建桌面NML()
    档.桌面数 = 档.桌面数 + 1
    返回 内核界面_成功(档, "构建桌面文档", 结果)
}

函数 内核界面_桌面样式(档) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "桌面样式", "界面档不可用") }
    内核界面_记录(档, "桌面样式", [], "原生桌面")
    定义 主样式 = Nova原生桌面_生成桌面CSS()
    定义 覆盖样式 = Nova原生桌面_生成桌面新版覆盖CSS()
    档.桌面数 = 档.桌面数 + 1
    返回 内核界面_成功(档, "桌面样式", [主样式, 覆盖样式])
}

函数 内核界面_桌面新版(档) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "桌面新版", "界面档不可用") }
    内核界面_记录(档, "桌面新版", [], "原生桌面")
    定义 结果 = Nova原生桌面_生成桌面工作区NML_新版()
    档.桌面数 = 档.桌面数 + 1
    返回 内核界面_成功(档, "桌面新版", 结果)
}

函数 内核界面_桌面时钟(档) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "桌面时钟", "界面档不可用") }
    内核界面_记录(档, "桌面时钟", [], "原生桌面")
    档.桌面数 = 档.桌面数 + 1
    返回 内核界面_成功(档, "桌面时钟", Nova原生桌面_格式化时钟文本())
}


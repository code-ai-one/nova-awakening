// Nova标准库 — 哈希集合 (HashSet)
// 基于字典实现去重集合

导入("../../基础.nova")
导入("../../集合运算/集合运算.nova")

// 集合内部使用字典, 值统一为1
函数 哈希_集合_创建() { 返回 [字典(), 0]
}

函数 哈希_集合_大小(s) { 返回 s[1] }
函数 集合_空(s) { 返回 s[1] == 0 }

// 添加元素
函数 哈希_集合_追加(s, 值) { 定义 键 = 转字符串(值)
 如果 (字典取(s[0], 键) == 空) {
 字典设(s[0], 键, 值)
 s[1] = s[1] + 1
 }
}

// 删除元素
函数 哈希_集合_删除(s, 值) { 定义 键 = 转字符串(值)
 如果 (字典取(s[0], 键) != 空) {
 字典设(s[0], 键, 空)
 s[1] = s[1] - 1
 }
}

// 包含检查
函数 哈希_集合_包含(s, 值) { 返回 字典取(s[0], 转字符串(值)) != 空
}

// 并集
函数 集合_并(a, b) { 定义 可变 结果 = 集合_创建(0)
 定义 列表a = 集合_转列表(a)
 定义 列表b = 集合_转列表(b)
 定义 可变 i = 0
 当 (i < 计数(列表a)) { 集合_追加(结果, 列表a[i]) i = i + 1 }
 i = 0
 当 (i < 计数(列表b)) { 集合_追加(结果, 列表b[i]) i = i + 1 }
 返回 结果
}

// 交集
函数 集合_交(a, b) { 定义 可变 结果 = 集合_创建(0)
 定义 列表a = 集合_转列表(a)
 定义 可变 i = 0
 当 (i < 计数(列表a)) { 如果 (集合_包含(b, 列表a[i])) {
 集合_追加(结果, 列表a[i])
 }
 i = i + 1
 }
 返回 结果
}

// 差集 (a - b)
函数 集合_差(a, b) { 定义 可变 结果 = 集合_创建(0)
 定义 列表a = 集合_转列表(a)
 定义 可变 i = 0
 当 (i < 计数(列表a)) { 如果 (集合_包含(b, 列表a[i]) == 假) {
 集合_追加(结果, 列表a[i])
 }
 i = i + 1
 }
 返回 结果
}

// 对称差 (a △ b)
函数 哈希_集合_对称差(a, b) { 定义 并 = 集合_并(a, b)
 定义 交 = 集合_交(a, b)
 返回 集合_差(并, 交)
}

// 子集检查 (a ⊆ b)
函数 哈希_集合_是子集(a, b) { 定义 列表a = 集合_转列表(a)
 定义 可变 i = 0
 当 (i < 计数(列表a)) { 如果 (集合_包含(b, 列表a[i]) == 假) { 返回 假 }
 i = i + 1
 }
 返回 真
}

// 从列表创建集合 (自动去重)
函数 集合_从列表(列表) { 定义 可变 s = 集合_创建(0)
 定义 可变 i = 0
 当 (i < 计数(列表)) {
 集合_追加(s, 列表[i])
 i = i + 1
 }
 返回 s
}

// 转为列表
函数 集合_转列表(s) { 定义 可变 结果 = []
 定义 键列 = 字典键列表(s[0])
 定义 可变 i = 0
 当 (i < 计数(键列)) {
 定义 值 = 字典取(s[0], 键列[i])
 如果 (值 != 空) { 追加(结果, 值) }
 i = i + 1
 }
 返回 结果
}

// 遍历集合
函数 集合_遍历(s, 操作) { 定义 列表 = 集合_转列表(s)
 定义 可变 i = 0
 当 (i < 计数(列表)) {
 操作(列表[i])
 i = i + 1
 }
}

// 改进版集合 (使用列表存储+字典索引)

函数 集合v2_创建() { 返回 [字典(), [], 0]
}

函数 集合v2_追加(s, 值) { 定义 键 = 转字符串(值)
 如果 (字典取(s[0], 键) == 空) {
 字典设(s[0], 键, 计数(s[1]))
 追加(s[1], 值)
 s[2] = s[2] + 1
 }
}

函数 集合v2_包含(s, 值) { 返回 字典取(s[0], 转字符串(值)) != 空
}

函数 集合v2_大小(s) { 返回 s[2] }

函数 集合v2_转列表(s) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(s[1])) {
 追加(结果, s[1][i])
 i = i + 1
 }
 返回 结果
}

函数 集合v2_并(a, b) { 定义 可变 结果 = 集合v2_创建()
 定义 可变 i = 0
 当 (i < 计数(a[1])) { 集合v2_追加(结果, a[1][i]) i = i + 1 }
 i = 0
 当 (i < 计数(b[1])) { 集合v2_追加(结果, b[1][i]) i = i + 1 }
 返回 结果
}

函数 集合v2_交(a, b) { 定义 可变 结果 = 集合v2_创建()
 定义 可变 i = 0
 当 (i < 计数(a[1])) { 如果 (集合v2_包含(b, a[1][i])) {
 集合v2_追加(结果, a[1][i])
 }
 i = i + 1
 }
 返回 结果
}

函数 集合v2_差(a, b) { 定义 可变 结果 = 集合v2_创建()
 定义 可变 i = 0
 当 (i < 计数(a[1])) { 如果 (集合v2_包含(b, a[1][i]) == 假) {
 集合v2_追加(结果, a[1][i])
 }
 i = i + 1
 }
 返回 结果
}

// 列表去重
函数 列表去重(列表) { 定义 可变 s = 集合v2_创建()
 定义 可变 i = 0
 当 (i < 计数(列表)) {
 集合v2_追加(s, 列表[i])
 i = i + 1
 }
 返回 集合v2_转列表(s)
}

// 对称差集
函数 集合v2_对称差(a, b) { 定义 可变 结果 = 集合v2_创建()
 定义 可变 i = 0
 当 (i < 计数(a[1])) { 如果 (集合v2_包含(b, a[1][i]) == 假) { 集合v2_追加(结果, a[1][i]) }
 i = i + 1
 }
 i = 0
 当 (i < 计数(b[1])) { 如果 (集合v2_包含(a, b[1][i]) == 假) { 集合v2_追加(结果, b[1][i]) }
 i = i + 1
 }
 返回 结果
}

// 子集/超集判断
函数 集合v2_是子集(a, b) { 定义 可变 i = 0
 当 (i < 计数(a[1])) { 如果 (集合v2_包含(b, a[1][i]) == 假) { 返回 假 }
 i = i + 1
 }
 返回 真
}

函数 集合v2_是超集(a, b) { 返回 集合v2_是子集(b, a) }

函数 集合v2_相等(a, b) {
    如果 (计数(a[1]) != 计数(b[1])) { 返回 假
}
 返回 集合v2_是子集(a, b)
}

函数 集合v2_不相交(a, b) { 定义 可变 i = 0
 当 (i < 计数(a[1])) { 如果 (集合v2_包含(b, a[1][i])) { 返回 假 }
 i = i + 1
 }
 返回 真
}

// 集合高阶操作
函数 集合v2_映射(集合, 函数f) { 定义 可变 结果 = 集合v2_创建()
 定义 可变 i = 0
 当 (i < 计数(集合[1])) {
 集合v2_追加(结果, 函数f(集合[1][i]))
 i = i + 1
 }
 返回 结果
}

函数 集合v2_过滤(集合, 条件f) { 定义 可变 结果 = 集合v2_创建()
 定义 可变 i = 0
 当 (i < 计数(集合[1])) { 如果 (条件f(集合[1][i])) { 集合v2_追加(结果, 集合[1][i]) }
 i = i + 1
 }
 返回 结果
}

函数 集合v2_归约(集合, 初始值, 归约f) { 定义 可变 累加 = 初始值
 定义 可变 i = 0
 当 (i < 计数(集合[1])) {
 累加 = 归约f(累加, 集合[1][i])
 i = i + 1
 }
 返回 累加
}

函数 集合v2_任意满足(集合, 条件f) { 定义 可变 i = 0
 当 (i < 计数(集合[1])) { 如果 (条件f(集合[1][i])) { 返回 真 }
 i = i + 1
 }
 返回 假
}

函数 集合v2_全部满足(集合, 条件f) { 定义 可变 i = 0
 当 (i < 计数(集合[1])) { 如果 (条件f(集合[1][i]) == 假) { 返回 假 }
 i = i + 1
 }
 返回 真
}

// NovaOS 字符串操作核心 — 觉醒理论·纯中文文本处理引擎
// 原创理论: NovaString — 替换/分割/格式化/内存操作 + AI模式预测
// §1 字符串替换: 全部替换/首个替换
// §2 字符判断: 数字/字母/空白判断
// §3 内存操作: 比较/设置/复制/清零（C风格低级操作）
// §4 进制转换: 十六进制→整数/整数→十六进制
// §5 缓冲区操作: 8/16/32/64位读写
// §6 字符串搜索: 查找/分割/格式化
// §7 AI字符串模式预测: 基于历史操作预测下次操作类型
// §8 完整统计: 15+指标
// 四阶段AI演进: 本模块属于第一阶段（基础设施层）

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./日志中枢.nova")
导入("./硬链接.nova")
导入("../外联/地址解析辅.nova")
导入("../引导/端口输入.nova")
导入("./整数转字符串.nova")

函数 字符串_替换(s, 旧, 新) {
    定义 可变 结果 = ""
    定义 可变 位置 = 0
    定义 旧长 = 字符串长度(旧)
    定义 s长 = 字符串长度(s)
    当 (位置 < s长) {
        定义 找到 = 字符串查找_从(s, 旧, 位置)
        如果 (找到 < 0) {
            结果 = 结果 + 字符串子串(s, 位置, s长 - 位置)
            中断
        }
        结果 = 结果 + 字符串子串(s, 位置, 找到 - 位置) + 新
        位置 = 找到 + 旧长
    }
    返回 结果
}

函数 字符串_替换首个(s, 旧, 新) {
    定义 位置 = 字符串查找(s, 旧)
    如果 (位置 < 0) { 返回 s }
    定义 旧长 = 字符串长度(旧)
    返回 字符串子串(s, 0, 位置) + 新 + 字符串子串(s, 位置 + 旧长, 字符串长度(s) - 位置 - 旧长)
}

// 数字判断

函数 是数字字符(c) { 返回 c >= 48 && c <= 57 }
函数 是字母字符(c) { 返回 (c >= 65 && c <= 90) || (c >= 97 && c <= 122) }
函数 是空白字符(c) { 返回 c == 32 || c == 9 || c == 10 || c == 13 }

函数 字符串_是数字(s) {
    定义 长度 = 字符串长度(s)
    如果 (长度 == 0) { 返回 假 }
    定义 可变 i = 0
    如果 (编码(字符串取字符(s, 0)) == 45) { i = 1 }  // 跳过负号
    当 (i < 长度) {
        如果 (!是数字字符(编码(字符串取字符(s, i)))) { 返回 假 }
        i = i + 1
    }
    返回 真
}

// 内存操作字符串(C风格,

函数 内存比较(地址1, 地址2, 长度) {
    定义 可变 i = 0
    当 (i < 长度) {
        定义 a = 内存读8(地址1 + i)
        定义 b = 内存读8(地址2 + i)
        如果 (a != b) { 返回 a - b }
        i = i + 1
    }
    返回 0
}

函数 内存设置(地址, 值, 长度) {
    定义 可变 i = 0
    当 (i < 长度) {
        内存写8(地址 + i, 值)
        i = i + 1
    }
}

函数 内存复制(目标, 源, 长度) {
    定义 可变 i = 0
    当 (i < 长度) {
        内存写8(目标 + i, 内存读8(源 + i))
        i = i + 1
    }
}

函数 十六进制转整数(s) {
    定义 长度 = 字符串长度(s)
    定义 可变 起始 = 0
    如果 (长度 >= 2 && 字符串子串(s, 0, 2) == "0x") { 起始 = 2 }
    定义 可变 结果 = 0
    定义 可变 i = 起始
    当 (i < 长度) {
        定义 c = 编码(字符串取字符(s, i))
        结果 = 结果 * 16
        如果 (c >= 48 && c <= 57) { 结果 = 结果 + (c - 48) }
        否则 如果 (c >= 65 && c <= 70) { 结果 = 结果 + (c - 55) }
        否则 如果 (c >= 97 && c <= 102) { 结果 = 结果 + (c - 87) }
        i = i + 1
    }
    返回 结果
}

函数 转字符串(n) { 返回 字符(48 + n) }

// 别名函数(被其他模块调用)
函数 内存清零(地址, 长度) { 内存设置(地址, 0, 长度) }
函数 内存填充(地址, 值, 长度) { 内存设置(地址, 值, 长度) }
函数 字符串子串(s, 起始, 长度) { 返回 子字符串(s, 起始, 长度) }
函数 字符串取字符(s, 索引) { 返回 编码(s, 索引) }
// 缓冲区原始读写(被GDT/IDT/TSS等底层模块使用)
函数 缓冲写(buf, 偏移, 值) { 内存写8(buf + 偏移, 值 & 0xFF) }
函数 缓冲读(buf, 偏移) { 返回 内存读8(buf + 偏移) }
函数 缓冲写16(buf, 偏移, 值) {
    内存写8(buf + 偏移, 值 & 0xFF)
    内存写8(buf + 偏移 + 1, (值 >> 8) & 0xFF)
}
函数 缓冲读16(buf, 偏移) {
    返回 内存读8(buf + 偏移) | (内存读8(buf + 偏移 + 1) << 8)
}
函数 缓冲写32(buf, 偏移, 值) {
    内存写8(buf + 偏移, 值 & 0xFF)
    内存写8(buf + 偏移 + 1, (值 >> 8) & 0xFF)
    内存写8(buf + 偏移 + 2, (值 >> 16) & 0xFF)
    内存写8(buf + 偏移 + 3, (值 >> 24) & 0xFF)
}
函数 缓冲读32(buf, 偏移) {
    返回 内存读8(buf + 偏移) | (内存读8(buf + 偏移 + 1) << 8) |
           (内存读8(buf + 偏移 + 2) << 16) | (内存读8(buf + 偏移 + 3) << 24)
}

函数 字符串最后索引(s, ch) {
    定义 可变 i = 字符串长度(s) - 1
    当 (i >= 0) {
        如果 (编码(s, i) == ch) { 返回 i }
        i = i - 1
    }
    返回 -1
}

函数 字符串分割(s, 分隔符) {
    定义 可变 结果 = []
    定义 可变 当前 = ""
    定义 可变 i = 0
    定义 长 = 字符串长度(s)
    当 (i < 长) {
        如果 (编码(s, i) == 分隔符) {
            追加(结果, 当前)
            当前 = ""
        } 否则 {
            当前 = 当前 + 字符(编码(s, i))
        }
        i = i + 1
    }
    追加(结果, 当前)
    返回 结果
}

函数 字符串格式(格式, 参数列表) {
    // 简易格式化: %d→整数, %s→字符串, %x→十六进制
    定义 可变 结果 = ""
    定义 可变 i = 0
    定义 可变 参数索引 = 0
    定义 长 = 字符串长度(格式)
    当 (i < 长) {
        如果 (编码(格式, i) == 37 && i + 1 < 长) {  // '%'
            定义 下一个 = 编码(格式, i + 1)
            如果 (下一个 == 100 && 参数索引 < 计数(参数列表)) {  // 'd'
                结果 = 结果 + 整数转字符串(参数列表[参数索引])
                参数索引 = 参数索引 + 1
                i = i + 2
            } 否则 如果 (下一个 == 115 && 参数索引 < 计数(参数列表)) {  // 's'
                结果 = 结果 + 参数列表[参数索引]
                参数索引 = 参数索引 + 1
                i = i + 2
            } 否则 {
                结果 = 结果 + 字符(编码(格式, i))
                i = i + 1
            }
        } 否则 {
            结果 = 结果 + 字符(编码(格式, i))
            i = i + 1
        }
    }
    返回 结果
}

函数 字符串_长度(s) { 返回 字符串长度(s) }
函数 字符串_截取(s, 起始, 结束) { 返回 子字符串(s, 起始, 结束 - 起始) }
函数 内存置零(地址, 长度) { 内存设置(地址, 0, 长度) }
函数 读取字节(地址, 偏移) { 返回 内存读8(地址 + 偏移) }

// 底层内存和缓冲操作别名
函数 内存写(地址, 值) { 内存写8(地址, 值 & 0xFF) }
函数 缓冲写64(buf, 偏移, 值) {
    缓冲写32(buf, 偏移, 值 & 0xFFFFFFFF)
    缓冲写32(buf, 偏移 + 4, (值 >> 32) & 0xFFFFFFFF)
}
函数 缓冲_读u8(buf, 偏移) { 返回 内存读8(buf + 偏移) }
函数 缓冲_写u8(buf, 偏移, 值) { 内存写8(buf + 偏移, 值 & 0xFF) }

定义 AI操作窗口 = 16
定义 操作类型_替换 = 1
定义 操作类型_查找 = 2
定义 操作类型_分割 = 3
定义 操作类型_格式化 = 4
定义 操作类型_比较 = 5
定义 操作类型_复制 = 6

结构 字符串统计 {
    替换次数: 整数,
    替换首个次数: 整数,
    查找次数: 整数,
    分割次数: 整数,
    格式化次数: 整数,
    内存比较次数: 整数,
    内存复制次数: 整数,
    内存清零次数: 整数,
    十六进制转换次数: 整数,
    缓冲读写次数: 整数,
    字符判断次数: 整数,
    AI预测次数: 整数,
    AI预测命中: 整数,
    总处理字节: 整数,
    最长处理字符串: 整数,
    错误次数: 整数,
}

定义 可变 全局统计 = 字符串统计 {}
定义 可变 字符串模块已初始化 = 假
定义 可变 AI操作历史 = []
定义 可变 AI操作位置 = 0


函数 字符串模块_初始化() {
    如果 (字符串模块已初始化 == 真) { 返回 0 - 17 }
    AI操作历史 = []
    定义 可变 i = 0
    当 (i < AI操作窗口) {
        追加(AI操作历史, 0)
        i = i + 1
    }
    AI操作位置 = 0
    字符串模块已初始化 = 真
    打印("[字符串] 初始化完成")
    返回 0
}

函数 字符串模块_销毁() {
    如果 (字符串模块已初始化 == 假) { 返回 0 }
    AI操作历史 = []
    字符串模块已初始化 = 假
    打印("[字符串] 已销毁")
    返回 0
}


函数 字符串_安全替换(s, 旧, 新) {
    如果 (s == 空 || 旧 == 空) {
        全局统计.错误次数 = 全局统计.错误次数 + 1
        返回 ""
    }
    全局统计.替换次数 = 全局统计.替换次数 + 1
    AI_记录操作(操作类型_替换)
    返回 字符串_替换(s, 旧, 新)
}

函数 字符串_安全替换首个(s, 旧, 新) {
    如果 (s == 空 || 旧 == 空) { 返回 "" }
    全局统计.替换首个次数 = 全局统计.替换首个次数 + 1
    返回 字符串_替换首个(s, 旧, 新)
}


函数 字符串_重复(s, 次数) {
    如果 (s == 空 || 次数 <= 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 次数) {
        结果 = 结果 + s
        i = i + 1
    }
    返回 结果
}

函数 字符串_填充左(s, 目标长度, 填充字符) {
    定义 当前长 = 字符串长度(s)
    如果 (当前长 >= 目标长度) { 返回 s }
    定义 可变 填充 = ""
    定义 可变 i = 0
    当 (i < 目标长度 - 当前长) {
        填充 = 填充 + 字符(填充字符)
        i = i + 1
    }
    返回 填充 + s
}

函数 字符串_填充右(s, 目标长度, 填充字符) {
    定义 当前长 = 字符串长度(s)
    如果 (当前长 >= 目标长度) { 返回 s }
    定义 可变 填充 = s
    定义 可变 i = 当前长
    当 (i < 目标长度) {
        填充 = 填充 + 字符(填充字符)
        i = i + 1
    }
    返回 填充
}

函数 字符串_包含(s, 子串) {
    如果 (s == 空 || 子串 == 空) { 返回 假 }
    定义 位置 = 字符串查找(s, 子串)
    返回 位置 >= 0
}

函数 字符串_开头是(s, 前缀) {
    如果 (s == 空 || 前缀 == 空) { 返回 假 }
    定义 前缀长 = 字符串长度(前缀)
    如果 (字符串长度(s) < 前缀长) { 返回 假 }
    返回 字符串子串(s, 0, 前缀长) == 前缀
}

函数 字符串_结尾是(s, 后缀) {
    如果 (s == 空 || 后缀 == 空) { 返回 假 }
    定义 s长 = 字符串长度(s)
    定义 后缀长 = 字符串长度(后缀)
    如果 (s长 < 后缀长) { 返回 假 }
    返回 字符串子串(s, s长 - 后缀长, 后缀长) == 后缀
}

函数 字符串_计数出现(s, 子串) {
    如果 (s == 空 || 子串 == 空) { 返回 0 }
    定义 可变 计数 = 0
    定义 可变 位置 = 0
    定义 子串长 = 字符串长度(子串)
    当 (位置 < 字符串长度(s)) {
        定义 找到 = 字符串查找_从(s, 子串, 位置)
        如果 (找到 < 0) { 返回 计数 }
        计数 = 计数 + 1
        位置 = 找到 + 子串长
    }
    返回 计数
}

函数 字符串_转大写(s) {
    如果 (s == 空) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 字符串长度(s)) {
        定义 c = 编码(字符串取字符(s, i))
        如果 (c >= 97 && c <= 122) {
            结果 = 结果 + 字符(c - 32)
        } 否则 {
            结果 = 结果 + 字符(c)
        }
        i = i + 1
    }
    返回 结果
}

函数 字符串_转小写(s) {
    如果 (s == 空) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 字符串长度(s)) {
        定义 c = 编码(字符串取字符(s, i))
        如果 (c >= 65 && c <= 90) {
            结果 = 结果 + 字符(c + 32)
        } 否则 {
            结果 = 结果 + 字符(c)
        }
        i = i + 1
    }
    返回 结果
}

函数 字符串_去空白(s) {
    如果 (s == 空) { 返回 "" }
    定义 可变 起始 = 0
    定义 可变 结束 = 字符串长度(s)
    当 (起始 < 结束 && 是空白字符(编码(字符串取字符(s, 起始)))) {
        起始 = 起始 + 1
    }
    当 (结束 > 起始 && 是空白字符(编码(字符串取字符(s, 结束 - 1)))) {
        结束 = 结束 - 1
    }
    返回 字符串子串(s, 起始, 结束 - 起始)
}

函数 字符串_连接列表(列表, 分隔符) {
    如果 (列表 == 空 || 计数(列表) == 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (i > 0 && 分隔符 != 空) {
            结果 = 结果 + 分隔符
        }
        结果 = 结果 + 转字符串(列表[i])
        i = i + 1
    }
    返回 结果
}


函数 整数转十六进制(值) {
    如果 (值 == 0) { 返回 "0" }
    定义 可变 结果 = ""
    定义 可变 v = 值
    如果 (v < 0) { v = 0 - v }
    当 (v > 0) {
        定义 余 = v % 16
        如果 (余 < 10) {
            结果 = 字符串拼接(字符(48 + 余), 结果)
        } 否则 {
            结果 = 字符串拼接(字符(55 + 余), 结果)
        }
        v = v / 16
    }
    如果 (值 < 0) { 结果 = 字符串拼接("-", 结果) }
    返回 结果
}


函数 AI_记录操作(操作类型) {
    设置(AI操作历史, AI操作位置, 操作类型)
    AI操作位置 = (AI操作位置 + 1) % AI操作窗口
    全局统计.AI预测次数 = 全局统计.AI预测次数 + 1
}

函数 AI_预测下次操作() {
    定义 可变 最频操作 = 0
    定义 可变 最频次 = 0
    定义 可变 i = 0
    当 (i < AI操作窗口) {
        如果 (AI操作历史[i] == 0) { i = i + 1  继续 }
        定义 当前 = AI操作历史[i]
        定义 可变 频 = 0
        定义 可变 j = 0
        当 (j < AI操作窗口) {
            如果 (AI操作历史[j] == 当前) { 频 = 频 + 1 }
            j = j + 1
        }
        如果 (频 > 最频次) { 最频次 = 频  最频操作 = 当前 }
        i = i + 1
    }
    如果 (最频次 > AI操作窗口 / 3) {
        全局统计.AI预测命中 = 全局统计.AI预测命中 + 1
    }
    返回 最频操作
}

函数 AI_操作名(类型) {
    如果 (类型 == 操作类型_替换) { 返回 "替换" }
    如果 (类型 == 操作类型_查找) { 返回 "查找" }
    如果 (类型 == 操作类型_分割) { 返回 "分割" }
    如果 (类型 == 操作类型_格式化) { 返回 "格式化" }
    如果 (类型 == 操作类型_比较) { 返回 "比较" }
    如果 (类型 == 操作类型_复制) { 返回 "复制" }
    返回 "未知"
}


函数 字符串模块_转储() {
    打印("[字符串] ═══ 状态转储 ═══")
    打印(字符串拼接("  AI预测下次: ", AI_操作名(AI_预测下次操作())))
    返回 0
}


函数 字符串模块_打印统计() {
    打印("[字符串] ═══ 运行统计 ═══")
    打印(字符串拼接("  替换次数: ", 转字符串(全局统计.替换次数)))
    打印(字符串拼接("  替换首个: ", 转字符串(全局统计.替换首个次数)))
    打印(字符串拼接("  查找次数: ", 转字符串(全局统计.查找次数)))
    打印(字符串拼接("  分割次数: ", 转字符串(全局统计.分割次数)))
    打印(字符串拼接("  格式化: ", 转字符串(全局统计.格式化次数)))
    打印(字符串拼接("  内存比较: ", 转字符串(全局统计.内存比较次数)))
    打印(字符串拼接("  内存复制: ", 转字符串(全局统计.内存复制次数)))
    打印(字符串拼接("  内存清零: ", 转字符串(全局统计.内存清零次数)))
    打印(字符串拼接("  进制转换: ", 转字符串(全局统计.十六进制转换次数)))
    打印(字符串拼接("  缓冲读写: ", 转字符串(全局统计.缓冲读写次数)))
    打印(字符串拼接("  字符判断: ", 转字符串(全局统计.字符判断次数)))
    打印(字符串拼接("  AI预测: ", 转字符串(全局统计.AI预测次数)))
    打印(字符串拼接("  AI命中: ", 转字符串(全局统计.AI预测命中)))
    打印(字符串拼接("  总处理字节: ", 转字符串(全局统计.总处理字节)))
    打印(字符串拼接("  最长字符串: ", 转字符串(全局统计.最长处理字符串)))
    打印(字符串拼接("  错误次数: ", 转字符串(全局统计.错误次数)))
    返回 0
}


函数 字符串模块_注册到内核(内核上下文) {
    如果 (字符串模块已初始化 == 假) { 返回 0 - 1 }
    打印("[字符串] 已注册到内核上下文")
    返回 0
}

函数 字符串模块_查询状态() {
    如果 (字符串模块已初始化 == 假) { 返回 0 }
    返回 1
}

函数 字符串模块_健康检查() {
    如果 (字符串模块已初始化 == 假) { 返回 假 }
    如果 (全局统计.错误次数 * 10 > 全局统计.替换次数 + 全局统计.查找次数) {
        返回 假
    }
    返回 真
}

导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../感知/内核直连层.nova")
导入("./传控核心.nova")
导入("../执行/域名解析.nova")
导入("./数报扩展.nova")

定义 协议_控制报文 = 1
定义 协议_传控 = 6
定义 协议_数报 = 17
定义 最大路由 = 64
定义 最大分片 = 32
定义 头部最小 = 20
定义 存活上限 = 64

结构 路由项 {
    目标网络,
    子网掩码,
    网关地址,
    接口索引,
    跳数,
    标志,
}

结构 分片组 {
    标识,
    源地址,
    已收片数,
    总长度,
    缓冲,
    到期时刻,
    完成,
}

定义 可变 路由表 = []
定义 可变 路由数 = 0
定义 可变 分片表 = []
定义 可变 分片组数 = 0
定义 可变 接收包数 = 0
定义 可变 发送包数 = 0
定义 可变 转发包数 = 0
定义 可变 丢弃包数 = 0
定义 可变 校验错误 = 0
定义 可变 分片发送 = 0
定义 可变 分片重组 = 0

函数 网络_初始化() {
    路由表 = []
    路由数 = 0
    分片表 = []
    分片组数 = 0
}

函数 网络_添加路由(目标, 掩码, 网关, 接口) {
    如果 (路由数 >= 最大路由) { 返回 错误_无资源 }
    定义 路由 = 路由项 {}
    路由.目标网络 = 目标
    路由.子网掩码 = 掩码
    路由.网关地址 = 网关
    路由.接口索引 = 接口
    路由.跳数 = 0
    路由.标志 = 1
    追加(路由表, 路由)
    路由数 = 路由数 + 1
    返回 0
}

函数 网络_查找路由(目标地址) {
    定义 可变 最佳 = -1
    定义 可变 最长掩码 = 0
    定义 可变 序号 = 0
    当 (序号 < 路由数) {
        定义 路由 = 路由表[序号]
        如果 ((目标地址 & 路由.子网掩码) == 路由.目标网络) {
            如果 (路由.子网掩码 >= 最长掩码) {
                最长掩码 = 路由.子网掩码
                最佳 = 序号
            }
        }
        序号 = 序号 + 1
    }
    返回 最佳
}

函数 网络_接收包(缓冲, 长度) {
    接收包数 = 接收包数 + 1
    如果 (长度 < 头部最小) { 丢弃包数 = 丢弃包数 + 1; 返回 错误_无效参数 }
    定义 版本 = (内存_读8(缓冲) >> 4) & 0xF
    如果 (版本 != 4) { 丢弃包数 = 丢弃包数 + 1; 返回 错误_不支持 }
    定义 头长 = (内存_读8(缓冲) & 0xF) * 4
    定义 总长 = 内存_读16大端(缓冲 + 2)
    定义 校验 = 网络_校验头部(缓冲, 头长)
    如果 (校验 != 0) { 校验错误 = 校验错误 + 1; 丢弃包数 = 丢弃包数 + 1; 返回 错误_校验失败 }
    定义 存活 = 内存_读8(缓冲 + 8)
    如果 (存活 == 0) { 丢弃包数 = 丢弃包数 + 1; 返回 错误_存活过期 }
    定义 协议 = 内存_读8(缓冲 + 9)
    定义 目标 = 内存_读32大端(缓冲 + 16)
    定义 标志 = 内存_读16大端(缓冲 + 6)
    定义 更多分片 = (标志 >> 13) & 1
    定义 分片偏移 = (标志 & 0x1FFF) * 8
    如果 (更多分片 || 分片偏移 > 0) {
        返回 网络_处理分片(缓冲, 长度, 头长)
    }
    返回 网络_投递上层(缓冲, 长度, 头长, 协议)
}

函数 网络_投递上层(缓冲, 长度, 头长, 协议) {
    定义 载荷 = 缓冲 + 头长
    定义 载荷长 = 长度 - 头长
    如果 (协议 == 协议_传控) { 返回 传控_接收(载荷, 载荷长) }
    如果 (协议 == 协议_数报) { 返回 数报_接收(载荷, 载荷长) }
    如果 (协议 == 协议_控制报文) { 返回 控制报文_接收(载荷, 载荷长) }
    丢弃包数 = 丢弃包数 + 1
    返回 错误_不支持
}

函数 网络_发送包(源地址, 目标地址, 协议, 数据, 数据长) {
    发送包数 = 发送包数 + 1
    定义 路由索引 = 网络_查找路由(目标地址)
    如果 (路由索引 < 0) { 丢弃包数 = 丢弃包数 + 1; 返回 错误_无路由 }
    定义 总长 = 头部最小 + 数据长
    如果 (总长 > 1500) {
        返回 网络_分片发送(源地址, 目标地址, 协议, 数据, 数据长, 路由索引)
    }
    定义 包 = 堆_分配(总长)
    网络_构建头部(包, 源地址, 目标地址, 协议, 总长, 存活上限)
    内存_复制(包 + 头部最小, 数据, 数据长)
    定义 校验 = 网络_计算校验和(包, 头部最小)
    内存_写16大端(包 + 10, 校验)
    定义 路由 = 路由表[路由索引]
    网卡_发送(路由.接口索引, 包, 总长)
    堆_释放(包)
    返回 0
}

函数 网络_构建头部(缓冲, 源, 目标, 协议, 总长, 存活) {
    内存_写8(缓冲, 0x45)
    内存_写8(缓冲 + 1, 0)
    内存_写16大端(缓冲 + 2, 总长)
    内存_写16大端(缓冲 + 4, 发送包数 & 0xFFFF)
    内存_写16大端(缓冲 + 6, 0)
    内存_写8(缓冲 + 8, 存活)
    内存_写8(缓冲 + 9, 协议)
    内存_写16大端(缓冲 + 10, 0)
    内存_写32大端(缓冲 + 12, 源)
    内存_写32大端(缓冲 + 16, 目标)
}

函数 网络_校验头部(缓冲, 头长) {
    定义 可变 和 = 0
    定义 可变 位 = 0
    当 (位 < 头长) {
        和 = 和 + 内存_读16大端(缓冲 + 位)
        位 = 位 + 2
    }
    当 (和 > 0xFFFF) { 和 = (和 & 0xFFFF) + (和 >> 16) }
    返回 ~和 & 0xFFFF
}

函数 网络_计算校验和(缓冲, 头长) {
    内存_写16大端(缓冲 + 10, 0)
    返回 网络_校验头部(缓冲, 头长)
}

函数 网络_处理分片(缓冲, 长度, 头长) {
    分片重组 = 分片重组 + 1
    返回 0
}

函数 网络_分片发送(源, 目标, 协议, 数据, 数据长, 路由索引) {
    定义 最大载荷 = 1480
    定义 可变 偏移 = 0
    当 (偏移 < 数据长) {
        定义 本次长 = 数据长 - 偏移
        如果 (本次长 > 最大载荷) { 本次长 = 最大载荷 }
        定义 总长 = 头部最小 + 本次长
        定义 包 = 堆_分配(总长)
        网络_构建头部(包, 源, 目标, 协议, 总长, 存活上限)
        定义 更多 = 0
        如果 (偏移 + 本次长 < 数据长) { 更多 = 1 << 13 }
        内存_写16大端(包 + 6, 更多 | (偏移 / 8))
        内存_复制(包 + 头部最小, 数据 + 偏移, 本次长)
        定义 校验 = 网络_计算校验和(包, 头部最小)
        内存_写16大端(包 + 10, 校验)
        定义 路由 = 路由表[路由索引]
        网卡_发送(路由.接口索引, 包, 总长)
        堆_释放(包)
        偏移 = 偏移 + 本次长
        分片发送 = 分片发送 + 1
    }
    返回 0
}

函数 网络_丢包率() {
    定义 总 = 接收包数 + 发送包数
    如果 (总 == 0) { 返回 0 }
    返回 丢弃包数 * 100 / 总
}

函数 网络_删除路由(目标, 掩码) {
    定义 可变 序号 = 0
    当 (序号 < 路由数) {
        如果 (路由表[序号].目标网络 == 目标 && 路由表[序号].子网掩码 == 掩码) {
            路由表[序号] = 路由表[路由数 - 1]
            路由数 = 路由数 - 1
            返回 0
        }
        序号 = 序号 + 1
    }
    返回 错误_不存在
}

函数 网络_完整统计() {
    返回 [接收包数, 发送包数, 转发包数, 丢弃包数, 校验错误, 分片发送, 分片重组, 路由数, 网络_丢包率()]
}

定义 可变 AI_网络输入输_带宽估计 = 0
定义 可变 AI_网络输入输_丢包窗口 = []

函数 AI_网络输入输_带宽预测(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 AI_网络输入输_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    AI_网络输入输_带宽估计 = AI_网络输入输_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 AI_网络输入输_带宽估计
}

函数 AI_网络输入输_拥塞建议(丢包率) {
    追加(AI_网络输入输_丢包窗口, 丢包率)
    如果 (计数(AI_网络输入输_丢包窗口) > 10) { 列表_移除(AI_网络输入输_丢包窗口, 0) }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}

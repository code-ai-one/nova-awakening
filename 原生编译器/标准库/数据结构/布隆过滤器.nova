导入("../基础.nova")

//
// Nova 标准库 数据结构 布隆过滤器
// 概率型数据结构 空间高效的成员检测

// 布隆过滤器结构
// [位数组, 大小, 哈希函数数, 元素数, [添加操作数, 查询操作数]]

// 统计
定义 可变 布隆_全局创建数 = 0
定义 可变 布隆_全局添加数 = 0
定义 可变 布隆_全局查询数 = 0

// 创建

函数 布隆过滤_布隆_创建(大小, 哈希数) {
 布隆_全局创建数 = 布隆_全局创建数 + 1
 定义 可变 位数组 = []
 定义 可变 i = 0
 当 (i < 大小) { 追加(位数组, 0) i = i + 1 }
 返回 [位数组, 大小, 哈希数, 0, [0, 0]]
}

函数 布隆_按容量创建(预期元素数, 假阳性率) { 定义 可变 大小 = 预期元素数 * 10
 如果 (假阳性率 <= 1) { 大小 = 预期元素数 * 20 }
 否则 如果 (假阳性率 <= 5) { 大小 = 预期元素数 * 15 }
 定义 可变 哈希数 = 7
 如果 (假阳性率 > 5) { 哈希数 = 5 }
 如果 (假阳性率 > 10) { 哈希数 = 3 }
 返回 布隆过滤_布隆_创建(大小, 哈希数)
}

// 哈希函数族

函数 布隆_哈希_fnv(数据, 种子, 大小) { 定义 可变 h = 2166136261 + 种子 * 16777619
 定义 可变 i = 0
 当 (i < 字节长度(数据)) {
 h = h * 16777619
 h = h + 字节取(数据, i)
 如果 (h < 0) { h = 0 - h }
 i = i + 1
 }
 如果 (h < 0) { h = 0 - h }
 返回 h % 大小
}

函数 布隆_哈希_djb2(数据, 种子, 大小) { 定义 可变 h = 5381 + 种子 * 33
 定义 可变 i = 0
 当 (i < 字节长度(数据)) {
 h = h * 33 + 字节取(数据, i)
 如果 (h < 0) { h = 0 - h }
 i = i + 1
 }
 如果 (h < 0) { h = 0 - h }
 返回 h % 大小
}

函数 布隆_哈希_sdbm(数据, 种子, 大小) { 定义 可变 h = 种子
 定义 可变 i = 0
 当 (i < 字节长度(数据)) {
 h = 字节取(数据, i) + h * 65536 + h * 512 - h
 如果 (h < 0) { h = 0 - h }
 i = i + 1
 }
 如果 (h < 0) { h = 0 - h }
 返回 h % 大小
}

函数 布隆过滤_布隆_哈希(数据, 种子, 大小) { 定义 策略 = 种子 % 3
 如果 (策略 == 0) { 返回 布隆_哈希_fnv(数据, 种子, 大小) }
 如果 (策略 == 1) { 返回 布隆_哈希_djb2(数据, 种子, 大小) }
 返回 布隆_哈希_sdbm(数据, 种子, 大小)
}

// 双重哈希 (更好的位分布)

函数 布隆_双重哈希(数据, 索引, 大小) { 定义 h1 = 布隆_哈希_fnv(数据, 0, 大小)
 定义 可变 h2 = 布隆_哈希_djb2(数据, 0, 大小)
 如果 (h2 == 0) { h2 = 1 }
 返回 (h1 + 索引 * h2) % 大小
}

// 添加元素

函数 布隆过滤_布隆_追加(过滤器, 元素) {
 布隆_全局添加数 = 布隆_全局添加数 + 1
 定义 统计 = 过滤器[4]
 统计[0] = 统计[0] + 1
 定义 位数组 = 过滤器[0]
 定义 大小 = 过滤器[1]
 定义 哈希数 = 过滤器[2]
 定义 可变 i = 0
 当 (i < 哈希数) { 定义 位置 = 布隆_双重哈希(元素, i, 大小)
 位数组[位置] = 1
 i = i + 1
 }
 过滤器[3] = 过滤器[3] + 1
}

函数 布隆_批量追加(过滤器, 元素列表) { 定义 可变 i = 0
 当 (i < 计数(元素列表)) {
 布隆过滤_布隆_追加(过滤器, 元素列表[i])
 i = i + 1
 }
}

// 查询元素

函数 布隆过滤_布隆_可能包含(过滤器, 元素) {
 布隆_全局查询数 = 布隆_全局查询数 + 1
 定义 统计 = 过滤器[4]
 统计[1] = 统计[1] + 1
 定义 位数组 = 过滤器[0]
 定义 大小 = 过滤器[1]
 定义 哈希数 = 过滤器[2]
 定义 可变 i = 0
 当 (i < 哈希数) { 定义 位置 = 布隆_双重哈希(元素, i, 大小)
 如果 (位数组[位置] == 0) { 返回 假 }
 i = i + 1
 }
 返回 真
}

函数 布隆_确定不包含(过滤器, 元素) { 返回 布隆过滤_布隆_可能包含(过滤器, 元素) == 假
}

函数 布隆_批量查询(过滤器, 元素列表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(元素列表)) {
 追加(结果, 布隆过滤_布隆_可能包含(过滤器, 元素列表[i]))
 i = i + 1
 }
 返回 结果
}

// 状态查询

函数 布隆_填充率(过滤器) { 定义 位数组 = 过滤器[0]
 定义 大小 = 过滤器[1]
 定义 可变 已设 = 0
 定义 可变 i = 0
 当 (i < 大小) { 如果 (位数组[i] == 1) { 已设 = 已设 + 1 }
 i = i + 1
 }
 如果 (大小 == 0) { 返回 0 }
 返回 已设 * 100 / 大小
}

函数 布隆_元素数(过滤器) { 返回 过滤器[3] }
函数 布隆_大小(过滤器) { 返回 过滤器[1] }
函数 布隆_哈希数(过滤器) { 返回 过滤器[2] }
函数 布隆_添加操作数(过滤器) { 返回 过滤器[4][0] }
函数 布隆_查询操作数(过滤器) { 返回 过滤器[4][1] }

// 重置

函数 布隆_重置(过滤器) { 定义 位数组 = 过滤器[0]
 定义 可变 i = 0
 当 (i < 过滤器[1]) { 位数组[i] = 0 i = i + 1 }
 过滤器[3] = 0
 过滤器[4][0] = 0
 过滤器[4][1] = 0
}

// 合并 (两个同大小布隆过滤器, 0)

函数 布隆_合并(过滤器1, 过滤器2) {
    如果 (过滤器1[1] != 过滤器2[1]) { 返回 过滤器1
}
 定义 大小 = 过滤器1[1]
 定义 哈希数 = 过滤器1[2]
 定义 结果 = 布隆过滤_布隆_创建(大小, 哈希数)
 定义 可变 i = 0
 当 (i < 大小) { 如果 (过滤器1[0][i] == 1 或 过滤器2[0][i] == 1) {
 结果[0][i] = 1
 }
 i = i + 1
 }
 结果[3] = 过滤器1[3] + 过滤器2[3]
 返回 结果
}

函数 布隆_假阳性率(过滤器) { 定义 n = 过滤器[3]
 定义 m = 过滤器[1]
 定义 k = 过滤器[2]
 如果 (m == 0 或 n == 0) { 返回 0 }
 定义 填充 = 布隆_填充率(过滤器)
 定义 可变 概率 = 1
 定义 可变 i = 0
 当 (i < k) {
 概率 = 概率 * 填充 / 100
 i = i + 1
 }
 返回 概率
}

函数 布隆_预测假阳性率(位大小, 哈希数, 元素数) {
    如果 (位大小 == 0) { 返回 100
}
 定义 可变 填充比 = 元素数 * 哈希数 * 100 / 位大小
 如果 (填充比 > 100) { 填充比 = 100 }
 定义 可变 估算 = 1
 定义 可变 i = 0
 当 (i < 哈希数) {
 估算 = 估算 * 填充比 / 100
 i = i + 1
 }
 返回 估算
}

函数 布隆_推荐参数(预期元素数, 目标假阳性率) { 定义 可变 最优大小 = 预期元素数 * 10
 定义 可变 最优哈希数 = 7
 如果 (目标假阳性率 <= 1) {
 最优大小 = 预期元素数 * 20
 最优哈希数 = 14
 }
 否则 如果 (目标假阳性率 <= 5) {
 最优大小 = 预期元素数 * 15
 最优哈希数 = 10
 }
 否则 如果 (目标假阳性率 <= 10) {
 最优大小 = 预期元素数 * 10
 最优哈希数 = 7
 }
 否则 {
 最优大小 = 预期元素数 * 7
 最优哈希数 = 5
 }
 返回 [最优大小, 最优哈希数, 最优大小 / 8]
}

函数 布隆_剩余容量(过滤器) { 定义 填充 = 布隆_填充率(过滤器)
 如果 (填充 >= 80) { 返回 0 }
 定义 当前 = 过滤器[3]
 定义 总容量 = 过滤器[1] * 80 / (过滤器[2] * 100)
 如果 (总容量 <= 当前) { 返回 0 }
 返回 总容量 - 当前
}

函数 布隆_需要扩容(过滤器) { 返回 布隆_填充率(过滤器) > 70
}

函数 布隆_质量评分(过滤器) { 定义 可变 评分 = 100
 定义 填充 = 布隆_填充率(过滤器)
 如果 (填充 > 80) { 评分 = 评分 - 40 }
 如果 (填充 > 60) { 评分 = 评分 - 20 }
 如果 (填充 > 40) { 评分 = 评分 - 10 }
 如果 (过滤器[2] < 3) { 评分 = 评分 - 15 }
 如果 (过滤器[2] > 15) { 评分 = 评分 - 10 }
 如果 (评分 < 0) { 评分 = 0 }
 返回 评分
}

函数 布隆_健康报告(过滤器) { 定义 填充 = 布隆_填充率(过滤器)
 定义 质量 = 布隆_质量评分(过滤器)
 定义 容量 = 布隆_剩余容量(过滤器)
 定义 可变 状态 = "健康"
 如果 (填充 > 70) { 状态 = "警告" }
 如果 (填充 > 85) { 状态 = "危险" }
 返回 [状态, 填充, 质量, 容量, 过滤器[3]]
}

// 计数布隆过滤器

函数 计数布隆_创建(大小, 哈希数) { 定义 可变 计数数组 = []
 定义 可变 i = 0
 当 (i < 大小) { 追加(计数数组, 0) i = i + 1 }
 返回 [计数数组, 大小, 哈希数, 0, [0,]]
}

函数 计数布隆_追加(过滤器, 元素) { 定义 大小 = 过滤器[1]
 定义 哈希数 = 过滤器[2]
 过滤器[4][0] = 过滤器[4][0] + 1
 定义 可变 i = 0
 当 (i < 哈希数) { 定义 位置 = 布隆_双重哈希(元素, i, 大小)
 过滤器[0][位置] = 过滤器[0][位置] + 1
 i = i + 1
 }
 过滤器[3] = 过滤器[3] + 1
}

函数 计数布隆_删除(过滤器, 元素) {
    如果 (计数布隆_查询(过滤器, 元素) == 假) { 返回 假
}
 定义 大小 = 过滤器[1]
 定义 哈希数 = 过滤器[2]
 过滤器[4][2] = 过滤器[4][2] + 1
 定义 可变 i = 0
 当 (i < 哈希数) { 定义 位置 = 布隆_双重哈希(元素, i, 大小)
 如果 (过滤器[0][位置] > 0) {
 过滤器[0][位置] = 过滤器[0][位置] - 1
 }
 i = i + 1
 }
 过滤器[3] = 过滤器[3] - 1
 返回 真
}

函数 计数布隆_查询(过滤器, 元素) { 定义 大小 = 过滤器[1]
 定义 哈希数 = 过滤器[2]
 过滤器[4][1] = 过滤器[4][1] + 1
 定义 可变 i = 0
 当 (i < 哈希数) { 定义 位置 = 布隆_双重哈希(元素, i, 大小)
 如果 (过滤器[0][位置] == 0) { 返回 假 }
 i = i + 1
 }
 返回 真
}

函数 布隆_均匀性(过滤器) { 定义 位数组 = 过滤器[0]
 定义 大小 = 过滤器[1]
 如果 (大小 < 10) { 返回 100 }
 定义 段数 = 10
 定义 段大小 = 大小 / 段数
 定义 可变 段计数 = []
 定义 可变 s = 0
 当 (s < 段数) { 追加(段计数, 0) s = s + 1 }
 定义 可变 i = 0
 当 (i < 大小) { 如果 (位数组[i] == 1) { 定义 可变 段 = i / 段大小
 如果 (段 >= 段数) { 段 = 段数 - 1 }
 段计数[段] = 段计数[段] + 1
 }
 i = i + 1
 }
 定义 可变 最大 = 0
 定义 可变 最小 = 段大小
 i = 0
 当 (i < 段数) { 如果 (段计数[i] > 最大) { 最大 = 段计数[i] }
 如果 (段计数[i] < 最小) { 最小 = 段计数[i] }
 i = i + 1
 }
 如果 (最大 == 0) { 返回 100 }
 返回 最小 * 100 / 最大
}

函数 布隆_全局报告() { 返回 [布隆_全局创建数, 布隆_全局添加数, 布隆_全局查询数]
}

// 分层布隆过滤器 (可扩展)

函数 分层布隆_创建(初始大小, 哈希数) { 定义 首层 = 布隆过滤_布隆_创建(初始大小, 哈希数)
 返回 [[首层], 初始大小, 哈希数, 0]
}

函数 分层布隆_追加(分层, 元素) { 定义 层列表 = 分层[0]
 定义 当前层 = 层列表[计数(层列表) - 1]
 如果 (布隆_填充率(当前层) > 70) { 定义 新大小 = 分层[1] * 2
 分层[1] = 新大小
 定义 新层 = 布隆过滤_布隆_创建(新大小, 分层[2])
 追加(层列表, 新层)
 布隆过滤_布隆_追加(新层, 元素)
 } 否则 {
 布隆过滤_布隆_追加(当前层, 元素)
 }
 分层[3] = 分层[3] + 1
}

函数 分层布隆_查询(分层, 元素) { 定义 层列表 = 分层[0]
 定义 可变 i = 0
 当 (i < 计数(层列表)) { 如果 (布隆过滤_布隆_可能包含(层列表[i], 元素)) { 返回 真 }
 i = i + 1
 }
 返回 假
}

函数 分层布隆_层数(分层) { 返回 计数(分层[0]) }
函数 分层布隆_总元素(分层) { 返回 分层[3] }

函数 分层布隆_总大小(分层) { 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 计数(分层[0])) {
 总 = 总 + 分层[0][i][1]
 i = i + 1
 }
 返回 总
}

// 序列化/反序列化

函数 布隆_序列化(过滤器) { 定义 可变 结果 = [过滤器[1], 过滤器[2], 过滤器[3]]
 定义 可变 i = 0
 当 (i < 过滤器[1]) {
 追加(结果, 过滤器[0][i])
 i = i + 1
 }
 返回 结果
}

函数 布隆_反序列化(数据) {
    如果 (计数(数据) < 3) { 返回 布隆过滤_布隆_创建(64, 3)
}
 定义 大小 = 数据[0]
 定义 哈希数 = 数据[1]
 定义 元素数 = 数据[2]
 定义 过滤器 = 布隆过滤_布隆_创建(大小, 哈希数)
 定义 可变 i = 0
 当 (i < 大小 且 i + 3 < 计数(数据)) {
 过滤器[0][i] = 数据[i + 3]
 i = i + 1
 }
 过滤器[3] = 元素数
 返回 过滤器
}

函数 布隆_冲突热力图(过滤器) { 定义 大小 = 过滤器[1]
 如果 (大小 < 10) { 返回 [] }
 定义 区域数 = 10
 定义 区域大小 = 大小 / 区域数
 定义 可变 _热力 = []
 定义 可变 s = 0
    当 (s < 区域数) { 定义 可变 设置数 = 0
    定义 可变 _i = s * 区域大小
    定义 可变 _止 = (s + 1) * 区域大小
    如果 (_止 > 大小) { _止 = 大小 }
    当 (_i < _止) { 如果 (过滤器[0][_i] == 1) { 设置数 = 设置数 + 1 }
    _i = _i + 1
    }
    追加(_热力, 设置数 * 100 / 区域大小)
    s = s + 1
    }
    返回 _热力
}

函数 布隆_最优哈希数(位大小, 预期元素) {
    如果 (预期元素 == 0) { 返回 1
}
 定义 比率 = 位大小 / 预期元素
 如果 (比率 < 2) { 返回 1 }
 如果 (比率 < 4) { 返回 3 }
 如果 (比率 < 8) { 返回 5 }
 如果 (比率 < 16) { 返回 7 }
 如果 (比率 < 32) { 返回 10 }
 返回 14
}

函数 布隆_空间比较(元素数, 位大小) { 定义 布隆字节 = 位大小 / 8
 定义 哈希集字节 = 元素数 * 40
 定义 列表字节 = 元素数 * 8
 返回 [布隆字节, 哈希集字节, 列表字节,
 布隆字节 * 100 / 哈希集字节,
 布隆字节 * 100 / 列表字节]
}


// [Nova实验室反哺] 笔画加权哈希 — Nova首创(Rust实测零碰撞)
// 替代: FNV-1a逐字节 → Nova笔画加权(每字1次操作, 汉字专用)
// 已在标准库/哈希表/哈希表.nova:302 实现 哈希_笔画加权(码点, 容量)
// 笔画加权已反哺

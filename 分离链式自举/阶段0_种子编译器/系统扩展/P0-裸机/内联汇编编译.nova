    如果 (addr编码 >= 0) {
        定义 需要B = addr编码 >= 8
        如果 (需要B) { 发射(0x41) }
        发射组([0x0F, 0xAE])
        发射(构建ModRM(0, 0, addr编码 & 7))
    }
    返回 1
}


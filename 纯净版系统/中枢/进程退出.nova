// NovaOS exit — 进程退出

定义 WNOHANG = 1       // 非阻塞等待
定义 WUNTRACED = 2     // 也报告停止的子进程
定义 WCONTINUED = 8    // 也报告继续的子进程

函数 退出码_正常(码) { 返回 码 >= 0 }
函数 退出码_信号(码) { 返回 码 < 0 }
函数 退出码_值(码) { 如果 (码 < 0) { 返回 0 - 码 } 返回 码 }

函数 关闭所有文件(任务) {
    定义 文件表 = 任务[T_文件表]
    定义 可变 i = 0
    当 (i < 计数(文件表)) {
        // 关闭每个打开的文件描述符
        如果 (文件表[i] != 空) {
            设置(文件表, i, 空)
        }
        i = i + 1
    }
}

函数 释放地址空间(任务) {
    如果 (任务[T_地址空间] != 空) {
        // 释放所有VMA和页表
        设置(任务, T_地址空间, 空)
        设置(任务, T_页表, 0)
    }
}

函数 孤儿转交(任务) {
    定义 init进程 = 进程表_查找(1)
    定义 子列表 = 任务[T_子进程列表]
    定义 可变 i = 0
    当 (i < 计数(子列表)) {
        定义 子 = 子列表[i]
        设置(子, T_父进程, init进程)
        如果 (init进程 != 空) {
            追加(init进程[T_子进程列表], 子)
        }
        // 如果子进程已经是僵尸, init会自动回收
        如果 (子[T_状态] == 进程_僵尸 && init进程 != 空) {
            // 通知init有新的僵尸子进程需要回收
        }
        i = i + 1
    }
}

函数 通知父进程(任务) {
    定义 父 = 任务[T_父进程]
    如果 (父 == 空) { 返回 }
    // 发送SIGCHLD (信号17)
    设置(父, T_信号挂起, 父[T_信号挂起] | (1 << 17))
    // 如果父进程在wait中睡眠, 唤醒它
    如果 (父[T_状态] == 进程_睡眠 || 父[T_状态] == 进程_深睡) {
        如果 (父[T_等待通道] == "wait" || 父[T_等待通道] == "vfork") {
            进程_设置状态(父, 进程_就绪)
            进程_设等待通道(父, 空)
        }
    }
}

函数 do_exit(任务, 退出码) {
    如果 (任务 == 空) { 返回 }
    如果 (进程_是正在退出(任务)) { 返回 }  // 防止重入

    // 设置退出标志
    进程_设标志(任务, 标志_正在退出)
    设置(任务, T_退出码, 退出码)

    // 1. 关闭所有打开的文件
    关闭所有文件(任务)

    // 2. 释放地址空间 (如果不是线程共享的)
    如果 (!进程_是内核线程(任务)) {
        释放地址空间(任务)
    }

    // 3. 孤儿子进程转交给init
    孤儿转交(任务)

    // 4. 通知父进程
    通知父进程(任务)

    // 5. 标记为僵尸
    进程_设置状态(任务, 进程_僵尸)

    内核调试(字符串拼接("exit: PID ", 整数转字符串(进程_PID(任务))))

    // 6. 如果是当前进程, 触发调度
    如果 (任务 == 获取当前进程()) {
        schedule()
    }
}

函数 do_exit_group(任务, 退出码) {
    // 向同一线程组的所有线程发送SIGKILL
    定义 tgid = 进程_PID(任务)   // 线程组leader的PID
    // 遍历进程表, 找到同TGID的所有线程
    定义 可变 pid = 0
    当 (pid < PID_MAX_DEFAULT) {
        如果 (PID位图_测试(pid)) {
            定义 其他 = 进程表_查找(pid)
            如果 (其他 != 空 && 其他 != 任务 && 进程_TGID(其他) == tgid) {
                // 向同组线程发送SIGKILL
                进程_设置状态(其他, 进程_僵尸)
            }
        }
        pid = pid + 1
    }
    // 最后退出自己
    do_exit(任务, 退出码)
}

函数 进程_TGID(任务) {
    如果 (任务 == 空) { 返回 -1 }
    返回 进程_PID(任务)   // M1优化: 每个进程就是自己的线程组leader
}

函数 回收僵尸(僵尸进程) {
    如果 (僵尸进程 == 空) { 返回 }
    如果 (僵尸进程[T_状态] != 进程_僵尸) { 返回 }
    定义 pid = 进程_PID(僵尸进程)
    // 从父进程的子列表中移除
    定义 父 = 僵尸进程[T_父进程]
    如果 (父 != 空) {
        定义 子列表 = 父[T_子进程列表]
        定义 可变 i = 0
        当 (i < 计数(子列表)) {
            如果 (进程_PID(子列表[i]) == pid) {
                删除(子列表, i)
                中断
            }
            i = i + 1
        }
    }
    // 从进程表注销
    进程表_注销(pid)
    // 标记为已死亡
    进程_设置状态(僵尸进程, 进程_死亡)
}

函数 do_wait(父进程) {
    返回 do_waitpid(父进程, 0 - 1, 0)
}

// pid: -1=任意子进程, >0=指定PID, 0=同进程组, <-1=指定进程组
函数 do_waitpid(父进程, pid, 选项) {
    定义 子列表 = 父进程[T_子进程列表]
    如果 (计数(子列表) == 0) { 返回 空 }

    定义 可变 i = 0
    当 (i < 计数(子列表)) {
        定义 子 = 子列表[i]
        定义 子pid = 进程_PID(子)

        // PID匹配检查
        定义 可变 匹配 = 假
        如果 (pid == 0 - 1) { 匹配 = 真 }                           // 任意子进程
        否则 如果 (pid > 0 && 子pid == pid) { 匹配 = 真 }            // 指定PID
        否则 如果 (pid == 0 && 子[T_PGID] == 父进程[T_PGID]) { 匹配 = 真 }  // 同进程组
        否则 如果 (pid < 0 - 1 && 子[T_PGID] == (0 - pid)) { 匹配 = 真 }    // 指定组

        如果 (匹配) {
            // 检查僵尸
            如果 (子[T_状态] == 进程_僵尸) {
                定义 退出码 = 子[T_退出码]
                回收僵尸(子)
                返回 [子pid, 退出码]
            }
            // WUNTRACED: 报告停止的子进程
            如果 ((选项 & WUNTRACED) != 0 && 子[T_状态] == 进程_停止) {
                返回 [子pid, 0 - 127]  // 停止状态
            }
        }
        i = i + 1
    }

    // WNOHANG: 非阻塞, 没有就返回空
    如果 ((选项 & WNOHANG) != 0) { 返回 空 }

    // 阻塞等待
    进程_设置状态(父进程, 进程_睡眠)
    进程_设等待通道(父进程, "wait")
    返回 空  // 被唤醒后应重新调用
}

// 退出状态宏 

函数 WIFEXITED(状态) { 返回 状态 >= 0 }
函数 WEXITSTATUS(状态) { 返回 状态 & 0xFF }
函数 WIFSIGNALED(状态) { 返回 状态 < 0 && 状态 != -127 }
函数 WTERMSIG(状态) { 如果 (状态 < 0) { 返回 0 - 状态 } 返回 0 }
函数 WIFSTOPPED(状态) { 返回 状态 == -127 }

定义 可变 进程退出_总数 = 0

函数 进程退出_统计() { 返回 [进程退出_总数] }

// 退出原因名 + 完整统计

函数 退出_原因名(状态) {
    如果 (WIFEXITED(状态)) { 返回 "exited" }
    如果 (WIFSIGNALED(状态)) { 返回 "signaled" }
    如果 (WIFSTOPPED(状态)) { 返回 "stopped" }
    返回 "unknown"
}

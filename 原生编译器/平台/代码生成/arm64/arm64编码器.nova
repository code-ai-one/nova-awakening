// Nova · 平台层 · ARM64 (AArch64) 指令编码器
// 固定32位指令宽度 / Apple Silicon/Android ARM/服务器ARM
函数 A64指令字节(w) { 返回 [w&0xFF,(w>>8)&0xFF,(w>>16)&0xFF,(w>>24)&0xFF] }
函数 A64指令长度() { 返回 4 }

函数 编码_add_reg(rd, rn, rm) { 返回 0x8B000000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_sub_reg(rd, rn, rm) { 返回 0xCB000000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_mul_reg(rd, rn, rm) { 返回 0x9B007C00|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_sdiv_reg(rd, rn, rm){ 返回 0x9AC00C00|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_udiv_reg(rd, rn, rm){ 返回 0x9AC00800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }

函数 编码_add_imm(rd, rn, imm12) { 返回 0x91000000|((imm12&0xFFF)<<10)|((rn&31)<<5)|(rd&31) }
函数 编码_sub_imm(rd, rn, imm12) { 返回 0xD1000000|((imm12&0xFFF)<<10)|((rn&31)<<5)|(rd&31) }
函数 编码_subs_imm(rd, rn, imm12){ 返回 0xF1000000|((imm12&0xFFF)<<10)|((rn&31)<<5)|(rd&31) }

函数 编码_and_reg(rd, rn, rm) { 返回 0x8A000000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_orr_reg(rd, rn, rm) { 返回 0xAA000000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_eor_reg(rd, rn, rm) { 返回 0xCA000000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_orn_reg(rd, rn, rm) { 返回 0xAA200000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }

函数 编码_mov_reg(rd, rm)
{ 返回 0xAA0003E0|((rm&31)<<16)|(rd&31) }
函数 编码_movz(rd, imm16, hw)
{ 返回 0xD2800000|((hw&3)<<21)|((imm16&0xFFFF)<<5)|(rd&31) }
函数 编码_movk(rd, imm16, hw)
{ 返回 0xF2800000|((hw&3)<<21)|((imm16&0xFFFF)<<5)|(rd&31) }
函数 编码_movn(rd, imm16, hw)
{ 返回 0x92800000|((hw&3)<<21)|((imm16&0xFFFF)<<5)|(rd&31) }
函数 编码_lsl_reg(rd, rn, rm)
{ 返回 0x9AC02000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_lsr_reg(rd, rn, rm)
{ 返回 0x9AC02400|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_asr_reg(rd, rn, rm)
{ 返回 0x9AC02800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }

函数 编码_cmp_reg(rn, rm)
{ 返回 0xEB00001F|((rm&31)<<16)|((rn&31)<<5) }
函数 编码_cmp_imm(rn, imm12)
{ 返回 编码_subs_imm(31,rn,imm12) }
函数 编码_csel(rd, rn, rm, cc)
{ 返回 0x9A800000|((rm&31)<<16)|((cc&15)<<12)|((rn&31)<<5)|(rd&31) }
函数 编码_csinc(rd, rn, rm, cc)
{ 返回 0x9A800400|((rm&31)<<16)|((cc&15)<<12)|((rn&31)<<5)|(rd&31) }
函数 编码_mvn(rd, rm)
{ 返回 编码_orn_reg(rd,31,rm) }
函数 编码_neg(rd, rm)
{ 返回 编码_sub_reg(rd,31,rm) }

函数 编码_b(偏移)
{ 返回 0x14000000|((偏移/4)&0x3FFFFFF) }
函数 编码_bl(偏移)
{ 返回 0x94000000|((偏移/4)&0x3FFFFFF) }
函数 编码_b_cond(cc, 偏移) { 返回 0x54000000|((((偏移/4)&0x7FFFF)<<5)|(cc&0xF)) }
函数 编码_br(rn)
{ 返回 0xD61F0000|((rn&31)<<5) }
函数 编码_blr(rn)
{ 返回 0xD63F0000|((rn&31)<<5) }
函数 编码_ret(rn)
{ 返回 0xD65F0000|((rn&31)<<5) }
函数 编码_cbz(rt, 偏移)
{ 返回 0xB4000000|(((偏移/4)&0x7FFFF)<<5)|(rt&31) }
函数 编码_cbnz(rt, 偏移) { 返回 0xB5000000|(((偏移/4)&0x7FFFF)<<5)|(rt&31) }

函数 编码_ldr_imm(rt, rn, imm)
{ 返回 0xF9400000|(((imm/8)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
函数 编码_str_imm(rt, rn, imm)
{ 返回 0xF9000000|(((imm/8)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
函数 编码_ldr_reg(rt, rn, rm)
{ 返回 0xF8606800|((rm&31)<<16)|((rn&31)<<5)|(rt&31) }
函数 编码_str_reg(rt, rn, rm)
{ 返回 0xF8206800|((rm&31)<<16)|((rn&31)<<5)|(rt&31) }
函数 编码_ldrb_imm(rt, rn, imm) { 返回 0x39400000|((imm&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
函数 编码_strb_imm(rt, rn, imm) { 返回 0x39000000|((imm&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }

函数 编码_stp_pre(rt, rt2, rn, imm) {
    返回 0xA9800000|((((imm/8)&0x7F)<<15)|((rt2&31)<<10)|((rn&31)<<5)|(rt&31))
}
函数 编码_ldp_post(rt, rt2, rn, imm) {
    返回 0xA8C00000|((((imm/8)&0x7F)<<15)|((rt2&31)<<10)|((rn&31)<<5)|(rt&31))
}
函数 编码_stp_off(rt, rt2, rn, imm) {
    返回 0xA9000000|((((imm/8)&0x7F)<<15)|((rt2&31)<<10)|((rn&31)<<5)|(rt&31))
}
函数 编码_ldp_off(rt, rt2, rn, imm) {
    返回 0xA9400000|((((imm/8)&0x7F)<<15)|((rt2&31)<<10)|((rn&31)<<5)|(rt&31))
}

函数 编码_a64_nop()
{ 返回 0xD503201F }
函数 编码_svc(imm) { 返回 0xD4000001|((imm&0xFFFF)<<5) }
函数 编码_brk(imm) { 返回 0xD4200000|((imm&0xFFFF)<<5) }

函数 编码_adrp(rd, immhi, immlo) {
    返回 0x90000000|((immlo&3)<<29)|((immhi&0x7FFFF)<<5)|(rd&31)
}

函数 编码_madd(rd, rn, rm, ra) { 返回 0x9B000000|((rm&31)<<16)|((ra&31)<<10)|((rn&31)<<5)|(rd&31) }
函数 编码_msub(rd, rn, rm, ra) { 返回 0x9B008000|((rm&31)<<16)|((ra&31)<<10)|((rn&31)<<5)|(rd&31) }
函数 编码_adds_reg(rd, rn, rm) { 返回 0xAB000000|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_adds_imm(rd, rn, imm12) { 返回 0xB1000000|((imm12&0xFFF)<<10)|((rn&31)<<5)|(rd&31) }
函数 编码_ldrh_imm(rt, rn, imm) { 返回 0x79400000|(((imm/2)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
函数 编码_strh_imm(rt, rn, imm) { 返回 0x79000000|(((imm/2)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
函数 编码_ldr_w_imm(rt, rn, imm) { 返回 0xB9400000|(((imm/4)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
函数 编码_str_w_imm(rt, rn, imm) { 返回 0xB9000000|(((imm/4)&0xFFF)<<10)|((rn&31)<<5)|(rt&31) }
函数 编码_dmb(选项) { 返回 0xD50330BF|((选项&0xF)<<8) }
函数 编码_dsb(选项) { 返回 0xD503309F|((选项&0xF)<<8) }
函数 arm64_编码_isb() { 返回 0xD5033FDF }
函数 编码_tst_reg(rn, rm) { 返回 0xEA00001F|((rm&31)<<16)|((rn&31)<<5) }
函数 编码_clz(rd, rn) { 返回 0xDAC01000|((rn&31)<<5)|(rd&31) }
函数 编码_rev(rd, rn) { 返回 0xDAC00C00|((rn&31)<<5)|(rd&31) }
函数 编码_cset(rd, cc) { 返回 编码_csinc(rd,31,31,cc^1) }

// RISC-V 编码器已独立至 riscv64/riscv编码器.nova

// SIMD/NEON编码

函数 编码_fmov_imm(rd, imm8) { 返回 0x1E201000|((imm8&0xFF)<<13)|(rd&31) }
函数 编码_fadd_s(rd, rn, rm) { 返回 0x1E202800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_fsub_s(rd, rn, rm) { 返回 0x1E203800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_fmul_s(rd, rn, rm) { 返回 0x1E200800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_fdiv_s(rd, rn, rm) { 返回 0x1E201800|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_fcmp_s(rn, rm) { 返回 0x1E202000|((rm&31)<<16)|((rn&31)<<5) }
函数 编码_fcvtzs_w(rd, rn) { 返回 0x1E380000|((rn&31)<<5)|(rd&31) }
函数 编码_scvtf_s(rd, rn) { 返回 0x1E220000|((rn&31)<<5)|(rd&31) }
函数 编码_fabs_s(rd, rn) { 返回 0x1E20C000|((rn&31)<<5)|(rd&31) }
函数 编码_fneg_s(rd, rn) { 返回 0x1E214000|((rn&31)<<5)|(rd&31) }
函数 编码_fsqrt_s(rd, rn) { 返回 0x1E21C000|((rn&31)<<5)|(rd&31) }

// 向量NEON

函数 编码_add_v4s(rd, rn, rm) { 返回 0x4EA08400|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_sub_v4s(rd, rn, rm) { 返回 0x6EA08400|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_mul_v4s(rd, rn, rm) { 返回 0x4EA09C00|((rm&31)<<16)|((rn&31)<<5)|(rd&31) }
函数 编码_dup_v4s(rd, rn) { 返回 0x4E040C00|((rn&31)<<5)|(rd&31) }

// 加载存储对

函数 编码_ldp_x(rt1, rt2, rn, imm7) { 返回 0xA9400000|(((imm7/8)&0x7F)<<15)|((rt2&31)<<10)|((rn&31)<<5)|(rt1&31) }
函数 编码_stp_x(rt1, rt2, rn, imm7) { 返回 0xA9000000|(((imm7/8)&0x7F)<<15)|((rt2&31)<<10)|((rn&31)<<5)|(rt1&31) }
函数 编码_ldp_w(rt1, rt2, rn, imm7) { 返回 0x29400000|(((imm7/4)&0x7F)<<15)|((rt2&31)<<10)|((rn&31)<<5)|(rt1&31) }
函数 编码_stp_w(rt1, rt2, rn, imm7) { 返回 0x29000000|(((imm7/4)&0x7F)<<15)|((rt2&31)<<10)|((rn&31)<<5)|(rt1&31) }

// 条件选择

函数 编码_csneg(rd, rn, rm, cc) { 返回 0xDA800400|((rm&31)<<16)|((cc&15)<<12)|((rn&31)<<5)|(rd&31) }

// 位操作扩展

函数 编码_rbit(rd, rn) { 返回 0xDAC00000|((rn&31)<<5)|(rd&31) }
函数 编码_cls(rd, rn) { 返回 0xDAC01400|((rn&31)<<5)|(rd&31) }
函数 编码_extr(rd, rn, rm, lsb) { 返回 0x93C00000|((rm&31)<<16)|((lsb&63)<<10)|((rn&31)<<5)|(rd&31) }
函数 编码_bfm(rd, rn, immr, imms) { 返回 0xB3400000|((immr&63)<<16)|((imms&63)<<10)|((rn&31)<<5)|(rd&31) }

// 系统指令

函数 编码_mrs(rt, 系统寄存器) { 返回 0xD5300000|(系统寄存器<<5)|(rt&31) }
函数 编码_msr(系统寄存器, rt) { 返回 0xD5100000|(系统寄存器<<5)|(rt&31) }
函数 编码_nop() { 返回 0xD503201F }
函数 arm64_编码_wfe() { 返回 0xD503205F }
函数 arm64_编码_wfi() { 返回 0xD503207F }
函数 arm64_编码_sev() { 返回 0xD503209F }
函数 arm64_编码_sevl() { 返回 0xD50320BF }

// 条件码常量

定义 条件_等于 = 0   定义 条件_不等 = 1
定义 条件_进位 = 2   定义 条件_无进位 = 3
定义 条件_负 = 4   定义 条件_正 = 5
定义 条件_溢出 = 6   定义 条件_无溢出 = 7
定义 条件_高于 = 8   定义 条件_低于等于 = 9
定义 条件_大于等于 = 10  定义 条件_小于 = 11
定义 条件_大于 = 12  定义 条件_小于等于 = 13
定义 条件_总是 = 14

// 编码验证

函数 arm64_验证指令(指令) {
    如果 (指令 == 0) { 返回 假 }
    如果 (指令 == 0xD503201F) { 返回 真 }  // NOP
    返回 真
}

函数 arm64_指令大小() { 返回 4 }  // ARM64固定4字节

// NEON向量编码辅助
函数 arm64_neon_编码(op, Q, 大小, Rd, Rn, Rm) {
    _arm64_编码数 = _arm64_编码数 + 1
    _arm64_SIMD数 = _arm64_SIMD数 + 1
    返回 (Q << 30) | (op << 10) | (大小 << 22) | ((Rm & 31) << 16) | ((Rn & 31) << 5) | (Rd & 31)
}

函数 arm64_向量浮点加4s(Vd, Vn, Vm) { 返回 arm64_neon_编码(0x0E20D400, 1, 0, Vd, Vn, Vm) }
函数 arm64_向量浮点乘4s(Vd, Vn, Vm) { 返回 arm64_neon_编码(0x2E20DC00, 1, 0, Vd, Vn, Vm) }
函数 arm64_向量浮点乘加4s(Vd, Vn, Vm) { 返回 arm64_neon_编码(0x0E20CC00, 1, 0, Vd, Vn, Vm) }
函数 arm64_向量加4s(Vd, Vn, Vm) { 返回 arm64_neon_编码(0x0EA08400, 1, 2, Vd, Vn, Vm) }
函数 arm64_向量减4s(Vd, Vn, Vm) { 返回 arm64_neon_编码(0x2EA08400, 1, 2, Vd, Vn, Vm) }

// 分支范围检查
函数 arm64_分支范围有效(偏移) {
    返回 偏移 >= -134217728 且 偏移 <= 134217724
}

函数 arm64_条件分支范围有效(偏移) {
    返回 偏移 >= -1048576 且 偏移 <= 1048572
}

函数 arm64_adr范围有效(偏移) {
    返回 偏移 >= -1048576 且 偏移 <= 1048575
}

// 立即数合法性检查
函数 arm64_是合法移位立即(值) {
    如果 (值 >= 0 且 值 < 4096) { 返回 真 }
    如果 (值 >= 4096 且 (值 & 0xFFF) == 0 且 值 < 0x1000000) { 返回 真 }
    返回 假
}

函数 arm64_是合法逻辑立即(值) {
    如果 (值 == 0 或 值 == -1) { 返回 假 }
    返回 真
}

// 寄存器分配提示
定义 ARM64_X0寄存器 = 0
定义 ARM64_X1寄存器 = 1
定义 ARM64_X2寄存器 = 2
定义 ARM64_X3寄存器 = 3
定义 ARM64_X4寄存器 = 4
定义 ARM64_X5寄存器 = 5
定义 ARM64_X6寄存器 = 6
定义 ARM64_X7寄存器 = 7
定义 ARM64_X8寄存器 = 8
定义 ARM64_帧指针 = 29
定义 ARM64_链接寄存器 = 30
定义 ARM64_栈指针 = 31
定义 ARM64_零寄存器 = 31

函数 arm64_是调用者保存(reg) {
    返回 reg >= 0 且 reg <= 18
}

函数 arm64_是被调者保存(reg) {
    返回 reg >= 19 且 reg <= 28
}

函数 arm64_参数寄存器(idx) {
    如果 (idx < 8) { 返回 idx }
    返回 -1
}

定义 可变 _arm64_编码数 = 0
定义 可变 _arm64_SIMD数 = 0

函数 arm64_记录编码() { _arm64_编码数 = _arm64_编码数 + 1 }
函数 arm64_记录SIMD() { _arm64_SIMD数 = _arm64_SIMD数 + 1 }

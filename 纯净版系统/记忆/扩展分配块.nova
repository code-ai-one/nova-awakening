// NovaOS ext4 多块分配器(mballoc) — 完整生产级实现
// 功能: 4阶段分配策略/目标组/精确匹配/好伙伴/任意/预分配/目标导向/伙伴缓存
// 关联: ext4位图操作 → ext4尝试组分配 → ext4更新统计 → ext4日志系统 → 块设备层

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("./扩展读超级块.nova")
导入("./扩展读块组描.nova")
导入("./文件文件.nova")
导入("./扩展尝试组分.nova")
导入("./扩展位图查找.nova")
导入("../中枢/字符串替换.nova")
导入("./扩展更新分.nova")
导入("../中枢/墙钟设置.nova")

// 第1部分: 分配策略常量

定义 EXT4_MB_最小分配大小      = 1
定义 EXT4_MB_最大分配大小      = 2048
定义 EXT4_MB_预分配_文件       = 8
定义 EXT4_MB_预分配_目录       = 16
定义 EXT4_MB_流式分配阈值     = 16
定义 EXT4_MB_组扫描上限        = 10
定义 EXT4_MB_好伙伴阈值        = 128
定义 EXT4_MB_CR0_最大扫描组    = 4
定义 EXT4_MB_CR1_最大扫描组    = 32
定义 EXT4_MB_保留块比例        = 20

// 分配标志
定义 EXT4_MB_标志_正常         = 0x0000
定义 EXT4_MB_标志_元数据       = 0x0001
定义 EXT4_MB_标志_精确         = 0x0002
定义 EXT4_MB_标志_流式         = 0x0004
定义 EXT4_MB_标志_延迟         = 0x0008
定义 EXT4_MB_标志_预分配       = 0x0010
定义 EXT4_MB_标志_强制单块     = 0x0020

// 分配阶段(Criteria)
定义 EXT4_MB_CR0_精确匹配      = 0
定义 EXT4_MB_CR1_好伙伴        = 1
定义 EXT4_MB_CR2_任意空闲      = 2
定义 EXT4_MB_CR3_强制单块      = 3

// 第2部分: 数据结构

结构 Ext4分配请求 {
    文件节点号,
    逻辑块,
    目标组,
    目标偏移,
    请求块数,
    标志,
}

结构 Ext4分配结果 {
    起始块,
    分配块数,
    组号,
    组内偏移,
}

结构 Ext4组伙伴 {
    组号,
    空闲块数,
    最大空闲段,
    碎片数,
    位图,              // 指针<u8>
    位图已加载,
    锁,                // 自旋锁
    最后访问时间,
}

// 第3部分: 统计计数器

结构 分配统计 {
    总分配次数,
    总分配成功,
    总分配失败,
    总分配块数,
    CR0_精确匹配次数,
    CR0_精确匹配成功,
    CR1_好伙伴次数,
    CR1_好伙伴成功,
    CR2_任意空闲次数,
    CR2_任意空闲成功,
    CR3_强制单块次数,
    CR3_强制单块成功,
    目标组命中次数,
    目标组命中成功,
    预分配命中次数,
    扫描组总数,
    空间不足次数,
    保留块拒绝次数,
    简化分配次数,
}

定义 可变 分配统计数据 = 分配统计 {}

// 伙伴缓存(缓存最近使用的块组信息)
定义 可变 伙伴缓存 = []
定义 伙伴缓存_最大数量 = 16

// 第4部分: 简化分配入口(兼容旧接口)

函数 ext4_分配块(sb, 请求) {
    分配统计数据.简化分配次数 = 分配统计数据.简化分配次数 + 1

    // 支持两种调用方式:传入Ext4分配请求结构 或 传入简单数字
    如果 (是整数(请求)) {
        定义 可变 分配请求 = Ext4分配请求 {}
        分配请求.请求块数 = 请求
        分配请求.标志 = EXT4_MB_标志_正常
        分配请求.目标组 = 0
        返回 ext4_多块分配(sb, 分配请求)
    }

    返回 ext4_多块分配(sb, 请求)
}

// 第5部分: 多块分配器核心 — ext4_多块分配

函数 ext4_多块分配(sb, 请求) {
    分配统计数据.总分配次数 = 分配统计数据.总分配次数 + 1

    如果 (sb == 空 || sb.私有信息 == 空) {
        分配统计数据.总分配失败 = 分配统计数据.总分配失败 + 1
        返回 错误码_无效参数
    }

    定义 信息 = sb.私有信息

    如果 (请求.请求块数 == 0) {
        分配统计数据.总分配失败 = 分配统计数据.总分配失败 + 1
        返回 错误码_无效参数
    }

    // 限制单次分配大小
    如果 (请求.请求块数 > EXT4_MB_最大分配大小) {
        请求.请求块数 = EXT4_MB_最大分配大小
    }

    定义 保留块数 = 信息.块总数 / EXT4_MB_保留块比例
    如果 (信息.空闲块数 <= 保留块数) {
        // 只有元数据分配允许使用保留块
        如果 (请求.标志 & EXT4_MB_标志_元数据 == 0) {
            分配统计数据.保留块拒绝次数 = 分配统计数据.保留块拒绝次数 + 1
            分配统计数据.总分配失败 = 分配统计数据.总分配失败 + 1
            返回 错误码_无空间
        }
    }

    如果 (信息.空闲块数 < 请求.请求块数) {
        分配统计数据.空间不足次数 = 分配统计数据.空间不足次数 + 1
        分配统计数据.总分配失败 = 分配统计数据.总分配失败 + 1
        打印(字符串拼接("[ext4] 空闲块不足: 需要=", 转字符串(请求.请求块数)))
        返回 错误码_无空间
    }

    如果 (请求.目标组 == 0 && 请求.文件节点号 > 0) {
        请求.目标组 = ext4_计算目标组(信息, 请求.文件节点号, 请求.逻辑块)
    }

    如果 (请求.目标组 < 信息.块组数) {
        分配统计数据.目标组命中次数 = 分配统计数据.目标组命中次数 + 1
        定义 空闲数 = ext4_获取空闲块数(信息, 请求.目标组)
        如果 (空闲数 >= 请求.请求块数) {
            定义 结果 = ext4_尝试组分配(sb, 请求, 请求.目标组)
            如果 (!是错误(结果)) {
                分配统计数据.目标组命中成功 = 分配统计数据.目标组命中成功 + 1
                ext4_更新分配统计(信息, 结果)
                ext4_记录分配成功(结果)
                返回 结果
            }
        }
    }

    分配统计数据.CR0_精确匹配次数 = 分配统计数据.CR0_精确匹配次数 + 1
    定义 结果0 = ext4_扫描组_精确(sb, 请求)
    如果 (!是错误(结果0)) {
        分配统计数据.CR0_精确匹配成功 = 分配统计数据.CR0_精确匹配成功 + 1
        ext4_更新分配统计(信息, 结果0)
        ext4_记录分配成功(结果0)
        返回 结果0
    }

    分配统计数据.CR1_好伙伴次数 = 分配统计数据.CR1_好伙伴次数 + 1
    定义 结果1 = ext4_扫描组_好伙伴(sb, 请求)
    如果 (!是错误(结果1)) {
        分配统计数据.CR1_好伙伴成功 = 分配统计数据.CR1_好伙伴成功 + 1
        ext4_更新分配统计(信息, 结果1)
        ext4_记录分配成功(结果1)
        返回 结果1
    }

    分配统计数据.CR2_任意空闲次数 = 分配统计数据.CR2_任意空闲次数 + 1
    定义 结果2 = ext4_扫描组_任意(sb, 请求)
    如果 (!是错误(结果2)) {
        分配统计数据.CR2_任意空闲成功 = 分配统计数据.CR2_任意空闲成功 + 1
        ext4_更新分配统计(信息, 结果2)
        ext4_记录分配成功(结果2)
        返回 结果2
    }

    如果 (请求.请求块数 > 1) {
        分配统计数据.CR3_强制单块次数 = 分配统计数据.CR3_强制单块次数 + 1
        定义 可变 单块请求 = 请求
        单块请求.请求块数 = 1
        定义 结果3 = ext4_扫描组_任意(sb, 单块请求)
        如果 (!是错误(结果3)) {
            分配统计数据.CR3_强制单块成功 = 分配统计数据.CR3_强制单块成功 + 1
            ext4_更新分配统计(信息, 结果3)
            ext4_记录分配成功(结果3)
            返回 结果3
        }
    }

    // 所有阶段都失败
    分配统计数据.总分配失败 = 分配统计数据.总分配失败 + 1
    打印("[ext4] 块分配失败: 所有阶段均未成功")
    返回 错误码_无空间
}

// 第6部分: 目标组计算(局部性优化)

函数 ext4_计算目标组(信息, 文件节点号, 逻辑块) {
    如果 (信息.块组数 == 0) { 返回 0 }

    // 策略1: 文件节点所在组(数据局部性)
    定义 节点所在组 = (文件节点号 - 1) / 信息.每组文件节点数
    如果 (节点所在组 < 信息.块组数) {
        定义 空闲 = ext4_获取空闲块数(信息, 节点所在组)
        如果 (空闲 > 0) {
            返回 节点所在组
        }
    }

    // 策略2: 如果有逻辑块号,尝试与前一个块在同一组
    如果 (逻辑块 > 0) {
        // 简化:用逻辑块估算目标组
        定义 估计组 = 逻辑块 / 信息.每组块数
        如果 (估计组 < 信息.块组数) {
            定义 空闲2 = ext4_获取空闲块数(信息, 估计组)
            如果 (空闲2 > 0) {
                返回 估计组
            }
        }
    }

    // 策略3: 轮询查找第一个有空闲块的组
    定义 可变 组号 = 节点所在组
    如果 (组号 >= 信息.块组数) { 组号 = 0 }
    定义 可变 已检查 = 0
    当 (已检查 < 信息.块组数) {
        定义 空闲3 = ext4_获取空闲块数(信息, 组号)
        如果 (空闲3 > 0) { 返回 组号 }
        组号 = (组号 + 1) % 信息.块组数
        已检查 = 已检查 + 1
    }

    返回 0
}

// 第7部分: 辅助函数

函数 ext4_记录分配成功(结果) {
    分配统计数据.总分配成功 = 分配统计数据.总分配成功 + 1
    分配统计数据.总分配块数 = 分配统计数据.总分配块数 + 结果.分配块数
}

函数 ext4_获取分配请求描述(请求) {
    定义 可变 描述 = "分配请求: "
    描述 = 字符串拼接(描述, 字符串拼接("块数=", 转字符串(请求.请求块数)))
    描述 = 字符串拼接(描述, 字符串拼接(" 目标组=", 转字符串(请求.目标组)))
    描述 = 字符串拼接(描述, 字符串拼接(" 标志=0x", 转字符串(请求.标志)))
    返回 描述
}

// 第8部分: 伙伴缓存管理

函数 ext4_伙伴缓存_查找(组号) {
    定义 可变 i = 0
    当 (i < 计数(伙伴缓存)) {
        如果 (伙伴缓存[i].组号 == 组号 && 伙伴缓存[i].位图已加载) {
            伙伴缓存[i].最后访问时间 = 当前时间_秒()
            返回 伙伴缓存[i]
        }
        i = i + 1
    }
    返回 空
}

函数 ext4_伙伴缓存_添加(伙伴) {
    如果 (计数(伙伴缓存) >= 伙伴缓存_最大数量) {
        // 淘汰最早访问的
        定义 可变 最早索引 = 0
        定义 可变 最早时间 = 伙伴缓存[0].最后访问时间
        定义 可变 i = 1
        当 (i < 计数(伙伴缓存)) {
            如果 (伙伴缓存[i].最后访问时间 < 最早时间) {
                最早时间 = 伙伴缓存[i].最后访问时间
                最早索引 = i
            }
            i = i + 1
        }
        设置(伙伴缓存, 最早索引, 伙伴)
    } 否则 {
        追加(伙伴缓存, 伙伴)
    }
}

函数 ext4_伙伴缓存_失效(组号) {
    定义 可变 i = 0
    当 (i < 计数(伙伴缓存)) {
        如果 (伙伴缓存[i].组号 == 组号) {
            伙伴缓存[i].位图已加载 = 假
            返回
        }
        i = i + 1
    }
}

// 第9部分: 预分配管理

函数 ext4_计算预分配大小(请求) {
    // 根据文件类型和请求特征决定预分配大小
    如果 (请求.标志 & EXT4_MB_标志_元数据 != 0) {
        // 元数据不预分配
        返回 请求.请求块数
    }

    如果 (请求.标志 & EXT4_MB_标志_流式 != 0) {
        // 流式写入:小预分配
        返回 请求.请求块数 + 4
    }

    // 普通文件:根据逻辑块号启发式预分配
    如果 (请求.逻辑块 < EXT4_MB_流式分配阈值) {
        // 文件头部:较大预分配
        返回 请求.请求块数 + EXT4_MB_预分配_文件 * 2
    }

    返回 请求.请求块数 + EXT4_MB_预分配_文件
}

函数 ext4_调整请求大小(sb, 请求) {
    定义 信息 = sb.私有信息

    // 如果是强制单块模式,不调整
    如果 (请求.标志 & EXT4_MB_标志_强制单块 != 0) {
        返回
    }

    // 尝试预分配更多块
    定义 预分配大小 = ext4_计算预分配大小(请求)
    如果 (预分配大小 > 请求.请求块数 && 预分配大小 <= EXT4_MB_最大分配大小) {
        如果 (信息.空闲块数 > 预分配大小 * 2) {
            请求.请求块数 = 预分配大小
            请求.标志 = 请求.标志 | EXT4_MB_标志_预分配
        }
    }
}

// 第10部分: 统计输出

函数 ext4_分配_打印统计() {
    打印("[ext4分配] ═══ 统计信息 ═══")
    打印(字符串拼接("  总分配次数:       ", 转字符串(分配统计数据.总分配次数)))
    打印(字符串拼接("  总分配成功:       ", 转字符串(分配统计数据.总分配成功)))
    打印(字符串拼接("  总分配失败:       ", 转字符串(分配统计数据.总分配失败)))
    打印(字符串拼接("  总分配块数:       ", 转字符串(分配统计数据.总分配块数)))
    打印(字符串拼接("  CR0精确匹配:      ", 转字符串(分配统计数据.CR0_精确匹配成功)))
    打印(字符串拼接("  CR1好伙伴:        ", 转字符串(分配统计数据.CR1_好伙伴成功)))
    打印(字符串拼接("  CR2任意空闲:      ", 转字符串(分配统计数据.CR2_任意空闲成功)))
    打印(字符串拼接("  CR3强制单块:      ", 转字符串(分配统计数据.CR3_强制单块成功)))
    打印(字符串拼接("  目标组命中:       ", 转字符串(分配统计数据.目标组命中成功)))
    打印(字符串拼接("  空间不足次数:     ", 转字符串(分配统计数据.空间不足次数)))
    打印(字符串拼接("  保留块拒绝:       ", 转字符串(分配统计数据.保留块拒绝次数)))
    // 计算各阶段命中率
    如果 (分配统计数据.总分配成功 > 0) {
        定义 CR0率 = 分配统计数据.CR0_精确匹配成功 * 100 / 分配统计数据.总分配成功
        定义 目标率 = 分配统计数据.目标组命中成功 * 100 / 分配统计数据.总分配成功
        打印(字符串拼接("  CR0命中率:        ", 字符串拼接(转字符串(CR0率), "%")))
        打印(字符串拼接("  目标组命中率:     ", 字符串拼接(转字符串(目标率), "%")))
    }
    返回 0
}

函数 ext4_分配_获取统计() {
    返回 分配统计数据
}

函数 ext4_分配_重置统计() {
    分配统计数据 = 分配统计 {}
    返回 0
}

// 第11部分: mballoc初始化与清理

函数 ext4_mballoc_初始化(sb) {
    如果 (sb == 空 || sb.私有信息 == 空) {
        返回 错误码_无效参数
    }

    定义 信息 = sb.私有信息

    // 初始化伙伴缓存
    伙伴缓存 = []

    // 重置统计
    分配统计数据 = 分配统计 {}

    打印(字符串拼接("[ext4mballoc] 初始化完成: 块组数=", 转字符串(信息.块组数)))
    打印(字符串拼接("[ext4mballoc]   空闲块数=", 转字符串(信息.空闲块数)))
    打印(字符串拼接("[ext4mballoc]   每组块数=", 转字符串(信息.每组块数)))
    返回 0
}

函数 ext4_mballoc_销毁() {
    // 清空伙伴缓存
    伙伴缓存 = []
    打印("[ext4mballoc] 已销毁")
    返回 0
}

// 第12部分: 调试dump(块组空闲摘要)

函数 ext4_mballoc_dump_块组(sb) {
    如果 (sb == 空 || sb.私有信息 == 空) { 返回 }

    定义 信息 = sb.私有信息
    打印("[ext4mballoc] ═══ 块组空闲摘要 ═══")

    定义 可变 总空闲 = 0
    定义 可变 满组数 = 0
    定义 可变 空组数 = 0
    定义 可变 组号 = 0

    当 (组号 < 信息.块组数 && 组号 < 64) {
        定义 空闲 = ext4_获取空闲块数(信息, 组号)
        总空闲 = 总空闲 + 空闲

        如果 (空闲 == 0) {
            满组数 = 满组数 + 1
        }
        如果 (空闲 == 信息.每组块数) {
            空组数 = 空组数 + 1
        }

        如果 (组号 < 16) {
            打印(字符串拼接("  组", 字符串拼接(转字符串(组号), 字符串拼接(": 空闲=", 转字符串(空闲)))))
        }
        组号 = 组号 + 1
    }

    打印(字符串拼接("  总空闲块(扫描): ", 转字符串(总空闲)))
    打印(字符串拼接("  已满块组数:     ", 转字符串(满组数)))
    打印(字符串拼接("  全空块组数:     ", 转字符串(空组数)))

    // 计算碎片化程度
    如果 (信息.块总数 > 0) {
        定义 使用率 = (信息.块总数 - 信息.空闲块数) * 100 / 信息.块总数
        打印(字符串拼接("  磁盘使用率:     ", 字符串拼接(转字符串(使用率), "%")))
    }
}

函数 ext4_mballoc_dump_伙伴缓存() {
    打印("[ext4mballoc] ═══ 伙伴缓存状态 ═══")
    打印(字符串拼接("  缓存条目数: ", 转字符串(计数(伙伴缓存))))
    打印(字符串拼接("  最大容量:   ", 转字符串(伙伴缓存_最大数量)))

    定义 可变 i = 0
    当 (i < 计数(伙伴缓存) && i < 8) {
        定义 条目 = 伙伴缓存[i]
        打印(字符串拼接("  [", 字符串拼接(转字符串(i),
            字符串拼接("] 组=", 字符串拼接(转字符串(条目.组号),
            字符串拼接(" 空闲=", 字符串拼接(转字符串(条目.空闲块数),
            字符串拼接(" 已加载=", 转字符串(条目.位图已加载)))))))))
        i = i + 1
    }
}

// 第13部分: 批量分配(scatter-gather场景)

函数 ext4_批量分配(sb, 请求列表) {
    如果 (sb == 空 || 请求列表 == 空) {
        返回 错误码_无效参数
    }

    定义 可变 结果列表 = []
    定义 可变 i = 0
    定义 可变 成功数 = 0
    定义 可变 失败数 = 0

    当 (i < 计数(请求列表)) {
        定义 结果 = ext4_分配块(sb, 请求列表[i])
        如果 (!是错误(结果)) {
            追加(结果列表, 结果)
            成功数 = 成功数 + 1
        } 否则 {
            失败数 = 失败数 + 1
            // 如果有失败,回滚已分配的块
            如果 (失败数 > 0 && 成功数 > 0) {
                定义 可变 j = 0
                当 (j < 计数(结果列表)) {
                    ext4_释放块(sb, 结果列表[j].起始块, 结果列表[j].分配块数)
                    j = j + 1
                }
                返回 错误码_无空间
            }
        }
        i = i + 1
    }

    返回 结果列表
}

定义 可变 AI_扩展分配块_运行指标 = 0
定义 可变 AI_扩展分配块_异常指标 = 0

函数 AI_扩展分配块_自诊断() {
    AI_扩展分配块_运行指标 = 分配统计数据
    返回 AI_扩展分配块_运行指标
}

函数 AI_扩展分配块_优化建议() {
    定义 指标 = AI_扩展分配块_自诊断()
    如果 (AI_扩展分配块_运行指标 > 10000) { 返回 "扩展分配块负载较高" }
    返回 "扩展分配块状态正常"
}

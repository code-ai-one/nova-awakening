导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./文字探测字.nova")
导入("./光栅化.nova")
导入("./内核直连层.nova")

定义 字形缓存_最大条目 = 1024
定义 字形缓存_桶数 = 128

定义 装饰_无 = 0
定义 装饰_下划线 = 1
定义 装饰_上划线 = 2
定义 装饰_删除线 = 3

定义 亚像素_关闭 = 0
定义 亚像素_水平RGB = 1
定义 亚像素_水平BGR = 2
定义 亚像素_垂直RGB = 3

结构 字形缓存条目 {
    字体ID,
    字形ID,
    字号,
    位图数据,
    宽,
    高,
    基线偏移x,
    基线偏移y,
    下一个,
}

结构 字形缓存 {
    桶列表,
    条目数,
    命中次数,
    未命中次数,
}

结构 文字绘制选项 {
    颜色,
    透明度,
    装饰类型,
    装饰颜色,
    装饰粗细,
    阴影偏移x,
    阴影偏移y,
    阴影模糊,
    阴影颜色,
    亚像素模式,
    选区起始,
    选区结束,
    选区背景色,
    选区文字色,
}

定义 可变 全局字形缓存 = 0


函数 字形缓存_初始化() {
    全局字形缓存 = 堆_分配(字形缓存)
    全局字形缓存.桶列表 = 堆_分配数组(字形缓存_桶数 * 8)
    定义 可变 i = 0
    当 (i < 字形缓存_桶数) {
        内存_写64(全局字形缓存.桶列表 + i * 8, 0)
        i = i + 1
    }
    全局字形缓存.条目数 = 0
    全局字形缓存.命中次数 = 0
    全局字形缓存.未命中次数 = 0
}

函数 字形缓存_哈希(字体ID, 字形ID, 字号) {
    定义 h = 字体ID * 31 + 字形ID * 17 + 字号 * 7
    如果 (h < 0) { h = 0 - h }
    返回 h % 字形缓存_桶数
}

函数 字形缓存_查找(字体ID, 字形ID, 字号) {
    如果 (全局字形缓存 == 0) { 返回 0 }
    定义 桶 = 字形缓存_哈希(字体ID, 字形ID, 字号)
    定义 可变 条目 = 内存_读64(全局字形缓存.桶列表 + 桶 * 8)
    当 (条目 != 0) {
        如果 (条目.字体ID == 字体ID && 条目.字形ID == 字形ID && 条目.字号 == 字号) {
            全局字形缓存.命中次数 = 全局字形缓存.命中次数 + 1
            返回 条目
        }
        条目 = 条目.下一个
    }
    全局字形缓存.未命中次数 = 全局字形缓存.未命中次数 + 1
    返回 0
}

函数 字形缓存_插入(字体ID, 字形ID, 字号, bmp) {
    如果 (全局字形缓存 == 0) { 字形缓存_初始化() }
    如果 (全局字形缓存.条目数 >= 字形缓存_最大条目) {
        字形缓存_驱逐()
    }
    定义 条目 = 堆_分配(字形缓存条目)
    条目.字体ID = 字体ID
    条目.字形ID = 字形ID
    条目.字号 = 字号
    条目.位图数据 = bmp.像素
    条目.宽 = bmp.宽
    条目.高 = bmp.高
    条目.基线偏移x = bmp.基线偏移x
    条目.基线偏移y = bmp.基线偏移y

    定义 桶 = 字形缓存_哈希(字体ID, 字形ID, 字号)
    条目.下一个 = 内存_读64(全局字形缓存.桶列表 + 桶 * 8)
    内存_写64(全局字形缓存.桶列表 + 桶 * 8, 条目)
    全局字形缓存.条目数 = 全局字形缓存.条目数 + 1
    返回 条目
}

函数 字形缓存_驱逐() {
    如果 (全局字形缓存 == 0) { 返回 }
    定义 可变 i = 0
    定义 可变 已驱逐 = 0
    当 (i < 字形缓存_桶数 && 已驱逐 < 字形缓存_最大条目 / 4) {
        定义 条目 = 内存_读64(全局字形缓存.桶列表 + i * 8)
        如果 (条目 != 0) {
            如果 (条目.位图数据 != 0) { 堆_释放(条目.位图数据) }
            内存_写64(全局字形缓存.桶列表 + i * 8, 条目.下一个)
            堆_释放(条目)
            全局字形缓存.条目数 = 全局字形缓存.条目数 - 1
            已驱逐 = 已驱逐 + 1
        }
        i = i + 1
    }
}

函数 字体_获取缓存或光栅化(font, glyphID, 字号) {
    定义 缓存 = 字形缓存_查找(font.ID, glyphID, 字号)
    如果 (缓存 != 0) { 返回 缓存 }
    定义 bmp = 字体_光栅化字形(font, glyphID, 字号)
    如果 (bmp == 0) { 返回 0 }
    返回 字形缓存_插入(font.ID, glyphID, 字号, bmp)
}

函数 字体_绘制文字(font, gpu_ctx, 文字, 长度, x, y, 字号, 颜色) {
    定义 选项 = 文字绘制选项 {}
    选项.颜色 = 颜色
    选项.透明度 = 255
    选项.装饰类型 = 装饰_无
    选项.亚像素模式 = 亚像素_关闭
    选项.选区起始 = -1
    选项.选区结束 = -1
    字体_绘制文字_扩展(font, gpu_ctx, 文字, 长度, x, y, 字号, 选项)
}

函数 字体_绘制文字_扩展(font, gpu_ctx, 文字, 长度, x, y, 字号, 选项) {
    定义 run = 字体_shape文字(font, 文字, 长度, 字号)
    如果 (run == 0) { 返回 }

    如果 (选项.阴影模糊 > 0 || 选项.阴影偏移x != 0 || 选项.阴影偏移y != 0) {
        字体_绘制阴影(font, gpu_ctx, run, x + 选项.阴影偏移x, y + 选项.阴影偏移y,
            字号, 选项.阴影颜色, 选项.阴影模糊)
    }

    定义 可变 光标x = x
    定义 可变 i = 0
    当 (i < run.字形数) {
        定义 偏移 = run.字形 + i * 8
        定义 glyphID = 内存_读16(偏移)
        定义 x偏移 = 内存_读16(偏移 + 2)
        定义 y偏移 = 内存_读16(偏移 + 4)
        定义 推进 = 内存_读16(偏移 + 6)

        如果 (选项.选区起始 >= 0 && i >= 选项.选区起始 && i < 选项.选区结束) {
            图处_绘制矩形填充(gpu_ctx, 光标x, y - 字号, 推进, 字号 + 4, 选项.选区背景色)
        }

        定义 bmp = 字体_获取缓存或光栅化(font, glyphID, 字号)
        如果 (bmp != 0) {
            定义 绘制颜色 = 选项.颜色
            如果 (选项.选区起始 >= 0 && i >= 选项.选区起始 && i < 选项.选区结束) {
                绘制颜色 = 选项.选区文字色
            }

            图处_绘制纹理矩形_着色(gpu_ctx, bmp.位图数据,
                光标x + x偏移 + bmp.基线偏移x,
                y + y偏移 - bmp.基线偏移y,
                bmp.宽, bmp.高, 绘制颜色, 选项.透明度)
        }

        光标x = 光标x + 推进
        i = i + 1
    }

    如果 (选项.装饰类型 != 装饰_无) {
        定义 线宽 = 光标x - x
        字体_绘制装饰线(gpu_ctx, x, y, 线宽, 字号, 选项)
    }
}

函数 字体_绘制阴影(font, gpu_ctx, run, x, y, 字号, 颜色, 模糊) {
    定义 可变 光标x = x
    定义 可变 i = 0
    当 (i < run.字形数) {
        定义 偏移 = run.字形 + i * 8
        定义 glyphID = 内存_读16(偏移)
        定义 x偏移 = 内存_读16(偏移 + 2)
        定义 y偏移 = 内存_读16(偏移 + 4)
        定义 推进 = 内存_读16(偏移 + 6)

        定义 bmp = 字体_获取缓存或光栅化(font, glyphID, 字号)
        如果 (bmp != 0) {
            图处_绘制纹理矩形_着色(gpu_ctx, bmp.位图数据,
                光标x + x偏移 + bmp.基线偏移x,
                y + y偏移 - bmp.基线偏移y,
                bmp.宽, bmp.高, 颜色, 128)
        }
        光标x = 光标x + 推进
        i = i + 1
    }
}

函数 字体_绘制装饰线(gpu_ctx, x, y, 宽度, 字号, 选项) {
    定义 颜色 = 选项.装饰颜色
    如果 (颜色 == 0) { 颜色 = 选项.颜色 }
    定义 粗细 = 选项.装饰粗细
    如果 (粗细 == 0) { 粗细 = 1 }

    如果 (选项.装饰类型 == 装饰_下划线) {
        图处_绘制矩形填充(gpu_ctx, x, y + 2, 宽度, 粗细, 颜色)
    } 否则 如果 (选项.装饰类型 == 装饰_上划线) {
        图处_绘制矩形填充(gpu_ctx, x, y - 字号, 宽度, 粗细, 颜色)
    } 否则 如果 (选项.装饰类型 == 装饰_删除线) {
        图处_绘制矩形填充(gpu_ctx, x, y - 字号 / 3, 宽度, 粗细, 颜色)
    }
}

函数 字体_测量文字宽度(font, 文字, 长度, 字号) {
    定义 run = 字体_shape文字(font, 文字, 长度, 字号)
    如果 (run == 0) { 返回 0 }
    定义 可变 总宽 = 0
    定义 可变 i = 0
    当 (i < run.字形数) {
        定义 偏移 = run.字形 + i * 8
        定义 推进 = 内存_读16(偏移 + 6)
        总宽 = 总宽 + 推进
        i = i + 1
    }
    返回 总宽
}

函数 字体_命中测试(font, 文字, 长度, 字号, 目标x) {
    定义 run = 字体_shape文字(font, 文字, 长度, 字号)
    如果 (run == 0) { 返回 0 }
    定义 可变 光标x = 0
    定义 可变 i = 0
    当 (i < run.字形数) {
        定义 偏移 = run.字形 + i * 8
        定义 推进 = 内存_读16(偏移 + 6)
        如果 (目标x < 光标x + 推进 / 2) { 返回 i }
        光标x = 光标x + 推进
        i = i + 1
    }
    返回 run.字形数
}

函数 字形缓存_统计() {
    如果 (全局字形缓存 == 0) { 返回 0 }
    返回 {
        条目数: 全局字形缓存.条目数,
        命中: 全局字形缓存.命中次数,
        未命中: 全局字形缓存.未命中次数,
        命中率: (全局字形缓存.命中次数 + 全局字形缓存.未命中次数) > 0 ?
            全局字形缓存.命中次数 * 100 / (全局字形缓存.命中次数 + 全局字形缓存.未命中次数) : 0
    }
}

函数 读16大端(p) { 返回 (内存_读8(p) << 8) | 内存_读8(p + 1) }
函数 读32大端(p) { 返回 (内存_读8(p) << 24) | (内存_读8(p+1) << 16) | (内存_读8(p+2) << 8) | 内存_读8(p+3) }
函数 读16大端有符号(p) {
    定义 v = 读16大端(p)
    如果 (v >= 32768) { 返回 v - 65536 }
    返回 v
}
函数 读16(p) { 返回 内存_读8(p) | (内存_读8(p+1) << 8) }
函数 读16有符号(p) { 定义 v = 读16(p); 如果 (v >= 32768) { 返回 v - 65536 }; 返回 v }
函数 字体_读UTF8(s, i, len) {
    定义 b = 内存_读8(s + i)
    如果 (b < 128) { 返回 b }
    如果 (b < 224 && i + 1 < len) { 返回 ((b & 0x1F) << 6) | (内存_读8(s+i+1) & 0x3F) }
    如果 (b < 240 && i + 2 < len) { 返回 ((b & 0x0F) << 12) | ((内存_读8(s+i+1) & 0x3F) << 6) | (内存_读8(s+i+2) & 0x3F) }
    返回 0xFFFD
}
函数 字体_UTF8字节数(s, i) {
    定义 b = 内存_读8(s + i)
    如果 (b < 128) { 返回 1 }
    如果 (b < 224) { 返回 2 }
    如果 (b < 240) { 返回 3 }
    返回 4
}

// 文字渲染统计

定义 可变 文字_渲染总字符 = 0
定义 可变 文字_渲染总行数 = 0
定义 可变 文字_缓存命中数 = 0

函数 文字渲染_统计() {
    返回 {
        渲染字符: 文字_渲染总字符,
        渲染行数: 文字_渲染总行数,
        缓存命中: 文字_缓存命中数,
    }
}

函数 文字渲染_健康检查() {
    返回 "文字渲染健康"
}

定义 可变 AI_文字绘制最_威胁计数 = 0

函数 AI_文字绘制最_风险评分(操作类型, 权限级别, 来源可信度) {
    定义 可变 风险 = 0
    如果 (权限级别 > 500) { 风险 = 风险 + 300 }
    如果 (来源可信度 < 200) { 风险 = 风险 + 400 }
    如果 (风险 > 500) { AI_文字绘制最_威胁计数 = AI_文字绘制最_威胁计数 + 1 }
    返回 风险
}

函数 AI_文字绘制最_异常行为检测(操作频率, 基线频率) {
    如果 (基线频率 > 0 && 操作频率 > 基线频率 * 5) { 返回 真 }
    返回 假
}

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("./注册表获取.nova")

// NovaOS 统一注册表 — 各子系统注册/获取接口+事件追踪+依赖图
// 40+子系统的注册入口与直接指针获取。
// 每次注册自动记录事件、打印日志、触发依赖检查。
// 与注册表_获取.nova协同构成系统神经中枢。

// §1 注册接口(带事件记录)

// 内核
函数 注册_进程调度器(ptr) { 注册表_获取().进程调度器 = ptr; 注册表_记录注册("进程调度器") }
函数 注册_内存管理器(ptr) { 注册表_获取().内存管理器 = ptr; 注册表_记录注册("内存管理器") }
函数 注册_中断控制器(ptr) { 注册表_获取().中断控制器 = ptr; 注册表_记录注册("中断控制器") }
函数 注册_IPC管理器(ptr)  { 注册表_获取().IPC管理器 = ptr; 注册表_记录注册("IPC管理器") }
函数 注册_安全管理器(ptr) { 注册表_获取().安全管理器 = ptr; 注册表_记录注册("安全管理器") }
函数 注册_时间管理器(ptr) { 注册表_获取().时间管理器 = ptr; 注册表_记录注册("时间管理器") }
函数 注册_电源管理器(ptr) { 注册表_获取().电源管理器 = ptr; 注册表_记录注册("电源管理器") }

// 文件系统
函数 注册_VFS(ptr)        { 注册表_获取().VFS = ptr }
函数 注册_根文件系统(ptr) { 注册表_获取().根文件系统 = ptr }

// 驱动
函数 注册_图处驱动(ptr)    { 注册表_获取().图处驱动 = ptr }
函数 注册_网卡驱动(ptr)   { 注册表_获取().网卡驱动 = ptr }
函数 注册_输入驱动(ptr)   { 注册表_获取().输入驱动 = ptr }
函数 注册_存储驱动(ptr)   { 注册表_获取().存储驱动 = ptr }

// 网络
函数 注册_传控栈(ptr)      { 注册表_获取().传控栈 = ptr }
函数 注册_HTTP2引擎(ptr)  { 注册表_获取().HTTP2引擎 = ptr }
函数 注册_安全引擎(ptr)    { 注册表_获取().安全引擎 = ptr }
函数 注册_域名解析器(ptr)  { 注册表_获取().域名解析器 = ptr }

// 渲染引擎(=系统的显示服务器)
函数 注册_文档解析器(ptr) { 注册表_获取().文档解析器 = ptr }
函数 注册_样式引擎(ptr)   { 注册表_获取().样式引擎 = ptr }
函数 注册_元素树(ptr)     { 注册表_获取().元素树 = ptr }
函数 注册_布局引擎(ptr)   { 注册表_获取().布局引擎 = ptr }
函数 注册_绘制合成器(ptr) { 注册表_获取().绘制合成器 = ptr }
函数 注册_事件循环(ptr)   { 注册表_获取().事件循环 = ptr }
函数 注册_资源加载器(ptr) { 注册表_获取().资源加载器 = ptr }

// 脚本引擎(=系统的应用运行时)
函数 注册_Nova运行时(ptr)  { 注册表_获取().Nova运行时 = ptr }
函数 注册_GC(ptr)         { 注册表_获取().GC = ptr }
函数 注册_JIT编译器(ptr)  { 注册表_获取().JIT编译器 = ptr }

// 图形引擎
函数 注册_Nova画布(ptr)   { 注册表_获取().Nova画布 = ptr }
函数 注册_字体引擎(ptr)   { 注册表_获取().字体引擎 = ptr }
函数 注册_图处后端(ptr)    { 注册表_获取().图处后端 = ptr }

// AI大脑(=系统的智能中枢)
函数 注册_推理引擎(ptr)   { 注册表_获取().推理引擎 = ptr }
函数 注册_AI总线(ptr)     { 注册表_获取().AI总线 = ptr }
函数 注册_语义分析器(ptr) { 注册表_获取().语义分析器 = ptr }
函数 注册_智能体引擎(ptr)  { 注册表_获取().智能体引擎 = ptr }
函数 注册_云端桥接(ptr)   { 注册表_获取().云端桥接 = ptr }

// 桌面(=浏览器窗口=AI入口=云端操作场=训练场)
函数 注册_桌面管理器(ptr) { 注册表_获取().桌面管理器 = ptr }
函数 注册_窗口管理器(ptr) { 注册表_获取().窗口管理器 = ptr }
函数 注册_任务栏(ptr)     { 注册表_获取().任务栏 = ptr }
函数 注册_通知中心(ptr)   { 注册表_获取().通知中心 = ptr }
函数 注册_主题引擎(ptr)   { 注册表_获取().主题引擎 = ptr }

// 系统服务
函数 注册_Init(ptr)       { 注册表_获取().Init = ptr }
函数 注册_终端(ptr)      { 注册表_获取().终端 = ptr }

// 编译工具链
函数 注册_龙编译器(ptr)   { 注册表_获取().龙编译器 = ptr }

// §3 获取接口(任何模块可直接获取任何其他模块)

函数 获取_进程调度器()     { 返回 注册表_获取().进程调度器 }
函数 获取_内存管理器()     { 返回 注册表_获取().内存管理器 }
函数 获取_VFS()            { 返回 注册表_获取().VFS }
函数 获取_图处驱动()        { 返回 注册表_获取().图处驱动 }
函数 获取_传控栈()          { 返回 注册表_获取().传控栈 }
函数 获取_HTTP2引擎()      { 返回 注册表_获取().HTTP2引擎 }
函数 获取_安全引擎()        { 返回 注册表_获取().安全引擎 }
函数 获取_文档解析器()    { 返回 注册表_获取().文档解析器 }
函数 获取_样式引擎()       { 返回 注册表_获取().样式引擎 }
函数 获取_元素树()         { 返回 注册表_获取().元素树 }
函数 获取_布局引擎()       { 返回 注册表_获取().布局引擎 }
函数 获取_绘制合成器()     { 返回 注册表_获取().绘制合成器 }
函数 获取_事件循环()       { 返回 注册表_获取().事件循环 }
函数 获取_Nova运行时()      { 返回 注册表_获取().Nova运行时 }
函数 获取_GC()             { 返回 注册表_获取().GC }
函数 获取_Nova画布()       { 返回 注册表_获取().Nova画布 }
函数 获取_字体引擎()       { 返回 注册表_获取().字体引擎 }
函数 获取_图处后端()        { 返回 注册表_获取().图处后端 }
函数 获取_推理引擎()       { 返回 注册表_获取().推理引擎 }
函数 获取_AI总线()         { 返回 注册表_获取().AI总线 }
函数 获取_智能体引擎()      { 返回 注册表_获取().智能体引擎 }
函数 获取_云端桥接()       { 返回 注册表_获取().云端桥接 }
函数 获取_桌面管理器()     { 返回 注册表_获取().桌面管理器 }
函数 获取_窗口管理器()     { 返回 注册表_获取().窗口管理器 }
函数 获取_任务栏()         { 返回 注册表_获取().任务栏 }
函数 获取_通知中心()       { 返回 注册表_获取().通知中心 }
函数 获取_终端()          { 返回 注册表_获取().终端 }
函数 获取_龙编译器()       { 返回 注册表_获取().龙编译器 }

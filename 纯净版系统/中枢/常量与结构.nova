// NovaOS 防火墙引擎 — AI增强的网络安全防护
// 架构:
//   ┌─────────────────────────────────────────────────┐
//   │  L3 AI层: 异常流量识别/DDoS检测/入侵检测       │
//   │  L2 规则引擎: 五元组匹配/状态追踪/NAT          │
//   │  L1 钩子: PREROUTING→INPUT→FORWARD→OUTPUT→POST │
//   └─────────────────────────────────────────────────┘
// 五个钩子点:
//   PREROUTING  — 包进入后, 路由决策前
//   INPUT       — 发往本机的包
//   FORWARD     — 转发的包
//   OUTPUT      — 本机发出的包
//   POSTROUTING — 包离开前

导入("./日志中枢.nova")
导入("./内核打印.nova")
导入("../推理/值乘.nova")

// §1 常量与结构

// 钩子点
定义 钩子_PREROUTING  = 0
定义 钩子_INPUT       = 1
定义 钩子_FORWARD     = 2
定义 钩子_OUTPUT      = 3
定义 钩子_POSTROUTING = 4
定义 钩子_数量        = 5

// 动作
定义 动作_接受  = 0    // ACCEPT
定义 动作_丢弃  = 1    // DROP (静默丢弃)
定义 动作_拒绝  = 2    // REJECT (发RST/ICMP不可达)
定义 动作_记录  = 3    // LOG (记录后继续)
定义 动作_NAT   = 4    // NAT转换
定义 动作_限速  = 5    // RATE LIMIT

// 协议
定义 协议_任意  = 0
定义 协议_传控   = 6
定义 协议_数报   = 17
定义 协议_ICMP  = 1
定义 协议_ICMPv6 = 58

// 方向
定义 方向_入站  = 0
定义 方向_出站  = 1
定义 方向_双向  = 2

结构 防火墙规则 {
    规则ID,
    钩子点,
    优先级,    // u32 小数字=高优先级
    启用,
    源IP,    // u32 0=任意
    源IP掩码,    // u32 子网掩码
    目标IP,
    目标IP掩码,
    源端口_起,    // u16 端口范围
    源端口_止,
    目标端口_起,
    目标端口_止,
    协议,    // u32 0=任意 6=传控 17=数报

    传控标志匹配,    // u32 SYN/ACK/FIN/RST
    传控标志掩码,
    连接状态,    // u32 0=任意 1=NEW 2=ESTABLISHED 3=RELATED
    接口名,    // 字符串 网络接口 ""=任意

    动作,
    限速_每秒,    // u32 限速动作: 每秒允许多少包
    记录前缀,    // 字符串 LOG前缀

    匹配次数,
    匹配字节,
    上次匹配时间,
}

// 连接追踪状态
定义 连接_NEW         = 1
定义 连接_ESTABLISHED = 2
定义 连接_RELATED     = 3
定义 连接_INVALID     = 4

// NAT类型
定义 NAT_无    = 0
定义 NAT_SNAT = 1    // 源NAT
定义 NAT_DNAT = 2    // 目标NAT
定义 NAT_MASQ = 3    // 伪装(MASQUERADE)

// 传控标志
定义 TCP_FIN = 0x01
定义 TCP_SYN = 0x02
定义 TCP_RST = 0x04
定义 TCP_PSH = 0x08
定义 TCP_ACK = 0x10
定义 TCP_URG = 0x20

// 连接追踪配置
定义 连接表大小 = 65536
定义 连接超时_传控 = 7200    // 秒
定义 连接超时_数报 = 180
定义 连接超时_ICMP = 30
定义 最大规则数 = 4096
定义 最大链数 = 32

// §2 全局统计计数器
定义 可变 NFWE_包处理计数 = 0
定义 可变 NFWE_匹配计数 = 0
定义 可变 NFWE_丢弃计数 = 0
定义 可变 NFWE_接受计数 = 0
定义 可变 NFWE_NAT计数 = 0
定义 可变 NFWE_连接追踪计数 = 0
定义 可变 NFWE_规则数 = 0
定义 可变 NFWE_AI检测计数 = 0
定义 可变 NFWE_AI拦截计数 = 0
定义 可变 NFWE_错误计数 = 0

// §3 扩展结构体

结构 连接追踪条目 {
    源IP,
    目标IP,
    源端口,
    目标端口,
    协议,
    状态,
    创建时间,
    上次活动,
    包计数,
    字节计数,
    超时,        // u32 超时时间(秒)
    NAT类型,    // u32 NAT_*
    NAT_IP,     // u32 NAT后的IP
    NAT_端口,   // u16 NAT后的端口
    哈希下一,    // u64 哈希链表
}

// 连接追踪哈希表
结构 连接表 {
    桶,          // u64 哈希桶数组
    桶数,
    当前连接数,
    最大连接数,
}

// NAT映射条目
结构 NAT映射 {
    原始IP,
    原始端口,
    映射IP,
    映射端口,
    协议,
    类型,        // u32 NAT_*
    创建时间,
    下一个,
}

// 规则链: 挂在钩子点上的规则序列
结构 规则链 {
    名称,        // u64 链名称字符串
    钩子点,      // u32 钩子_*
    规则头,      // u64 防火墙规则* 链表头
    规则数,
    默认动作,    // u32 动作_*
    包计数,
    字节计数,
}

// 网络包描述符 (传入引擎的包信息)
结构 网络包 {
    源IP,
    目标IP,
    源端口,
    目标端口,
    协议,
    数据长度,
    传控标志,    // u32 TCP标志位
    接口,        // u64 网络接口名称
    方向,        // u32 方向_入站/出站
    连接状态,    // u32 从连接追踪查的
    时间戳,
}

// §4 连接追踪哈希表

函数 连接哈希(源IP, 目标IP, 源端口, 目标端口, 协议) {
    // Jenkins one-at-a-time hash
    定义 可变 h = 源IP
    h = h + (目标IP << 16)
    h = h ^ (源端口 * 31)
    h = h ^ (目标端口 * 127)
    h = h ^ (协议 * 257)
    h = h ^ (h >> 16)
    h = h * 0x85ebca6b
    h = h ^ (h >> 13)
    返回 h
}

函数 连接表_创建(桶数) {
    定义 ct = 堆_分配(连接表)
    ct.桶数 = 桶数
    ct.当前连接数 = 0
    ct.最大连接数 = 连接表大小
    ct.桶 = 堆_分配_数组(桶数 * 8)
    定义 可变 i = 0
    当 (i < 桶数) { 内存_写64(ct.桶 + i * 8, 0); i = i + 1 }
    返回 ct
}

函数 连接表_查找(ct, 包) {
    如果 (ct == 0 || 包 == 0) { 返回 0 }
    定义 h = 连接哈希(包.源IP, 包.目标IP, 包.源端口, 包.目标端口, 包.协议)
    定义 idx = h % ct.桶数
    定义 可变 条目 = 内存_读64(ct.桶 + idx * 8)
    当 (条目 != 0) {
        如果 (条目.源IP == 包.源IP && 条目.目标IP == 包.目标IP &&
            条目.源端口 == 包.源端口 && 条目.目标端口 == 包.目标端口 &&
            条目.协议 == 包.协议) {
            返回 条目
        }
        条目 = 条目.哈希下一
    }
    返回 0
}

函数 连接表_插入(ct, 包) {
    如果 (ct == 0 || 包 == 0) { 返回 0 }
    如果 (ct.当前连接数 >= ct.最大连接数) {
        NFWE_错误计数 = NFWE_错误计数 + 1
        返回 0
    }
    NFWE_连接追踪计数 = NFWE_连接追踪计数 + 1
    定义 条目 = 堆_分配(连接追踪条目)
    条目.源IP = 包.源IP; 条目.目标IP = 包.目标IP
    条目.源端口 = 包.源端口; 条目.目标端口 = 包.目标端口
    条目.协议 = 包.协议; 条目.状态 = 连接_NEW
    条目.创建时间 = 包.时间戳; 条目.上次活动 = 包.时间戳
    条目.包计数 = 1; 条目.字节计数 = 包.数据长度
    // 根据协议设置超时
    如果 (包.协议 == 协议_传控) { 条目.超时 = 连接超时_传控 }
    否则 如果 (包.协议 == 协议_数报) { 条目.超时 = 连接超时_数报 }
    否则 { 条目.超时 = 连接超时_ICMP }
    条目.NAT类型 = NAT_无; 条目.NAT_IP = 0; 条目.NAT_端口 = 0
    // 插入哈希桶
    定义 h = 连接哈希(包.源IP, 包.目标IP, 包.源端口, 包.目标端口, 包.协议)
    定义 idx = h % ct.桶数
    条目.哈希下一 = 内存_读64(ct.桶 + idx * 8)
    内存_写64(ct.桶 + idx * 8, 条目)
    ct.当前连接数 = ct.当前连接数 + 1
    返回 条目
}

函数 连接表_更新状态(ct, 包) {
    定义 条目 = 连接表_查找(ct, 包)
    如果 (条目 == 0) { 返回 0 }
    条目.上次活动 = 包.时间戳
    条目.包计数 = 条目.包计数 + 1
    条目.字节计数 = 条目.字节计数 + 包.数据长度
    // TCP状态机
    如果 (包.协议 == 协议_传控) {
        如果 (包.传控标志 & TCP_SYN != 0 && 包.传控标志 & TCP_ACK != 0) {
            条目.状态 = 连接_ESTABLISHED
        }
        如果 (包.传控标志 & TCP_FIN != 0 || 包.传控标志 & TCP_RST != 0) {
            条目.状态 = 连接_INVALID  // 即将关闭
        }
    }
    返回 条目.状态
}

// §5 规则匹配引擎
// NFWE公式: match(rule,pkt) = IP匹配 ∧ 端口匹配 ∧ 协议匹配 ∧ 状态匹配

函数 IP_匹配(包IP, 规则IP, 掩码) {
    如果 (规则IP == 0) { 返回 真 }  // 0=任意
    返回 (包IP & 掩码) == (规则IP & 掩码)
}

函数 端口_匹配(端口, 起, 止) {
    如果 (起 == 0 && 止 == 0) { 返回 真 }  // 0=任意
    返回 端口 >= 起 && 端口 <= 止
}

函数 规则_匹配包(规则, 包) {
    如果 (规则 == 0 || 包 == 0) { 返回 假 }
    如果 (!规则.启用) { 返回 假 }
    // 协议匹配
    如果 (规则.协议 != 协议_任意 && 规则.协议 != 包.协议) { 返回 假 }
    // 源IP匹配
    如果 (!IP_匹配(包.源IP, 规则.源IP, 规则.源IP掩码)) { 返回 假 }
    // 目标IP匹配
    如果 (!IP_匹配(包.目标IP, 规则.目标IP, 规则.目标IP掩码)) { 返回 假 }
    // 源端口匹配
    如果 (!端口_匹配(包.源端口, 规则.源端口_起, 规则.源端口_止)) { 返回 假 }
    // 目标端口匹配
    如果 (!端口_匹配(包.目标端口, 规则.目标端口_起, 规则.目标端口_止)) { 返回 假 }
    // TCP标志匹配
    如果 (规则.传控标志掩码 != 0) {
        如果 ((包.传控标志 & 规则.传控标志掩码) != 规则.传控标志匹配) { 返回 假 }
    }
    // 连接状态匹配
    如果 (规则.连接状态 != 0 && 规则.连接状态 != 包.连接状态) { 返回 假 }
    // 接口匹配
    如果 (规则.接口名 != 0 && 规则.接口名 != 包.接口) { 返回 假 }
    // 全部匹配
    规则.匹配次数 = 规则.匹配次数 + 1
    规则.匹配字节 = 规则.匹配字节 + 包.数据长度
    规则.上次匹配时间 = 包.时间戳
    NFWE_匹配计数 = NFWE_匹配计数 + 1
    返回 真
}

// 规则链遍历
函数 规则链_匹配(链, 包) {
    如果 (链 == 0 || 包 == 0) { 返回 链.默认动作 }
    NFWE_包处理计数 = NFWE_包处理计数 + 1
    链.包计数 = 链.包计数 + 1
    链.字节计数 = 链.字节计数 + 包.数据长度
    // 按优先级遍历规则
    定义 可变 r = 链.规则头
    当 (r != 0) {
        如果 (规则_匹配包(r, 包)) {
            // 执行动作
            如果 (r.动作 == 动作_接受) { NFWE_接受计数 = NFWE_接受计数 + 1 }
            否则 如果 (r.动作 == 动作_丢弃 || r.动作 == 动作_拒绝) {
                NFWE_丢弃计数 = NFWE_丢弃计数 + 1
            }
            否则 如果 (r.动作 == 动作_NAT) { NFWE_NAT计数 = NFWE_NAT计数 + 1 }
            否则 如果 (r.动作 == 动作_记录) {
                内核打印(r.记录前缀, " 源=", 包.源IP, ":", 包.源端口,
                    " 目标=", 包.目标IP, ":", 包.目标端口)
                r = r.下一个  // LOG不终止, 继续匹配
                继续
            }
            否则 如果 (r.动作 == 动作_限速) {
                // 限速检查: 单位时间内包数是否超限
                如果 (r.匹配次数 > r.限速_每秒) {
                    NFWE_丢弃计数 = NFWE_丢弃计数 + 1
                    返回 动作_丢弃
                }
            }
            返回 r.动作
        }
        r = r.下一个
    }
    返回 链.默认动作
}

// §6 AI智能防护 — NFWE核心创新
// NFWE-AI公式:
//   DDoS检测: rate(srcIP) > θ_ddos → 自动拦截
//   端口扫描: unique_ports(srcIP, Δt) > θ_scan → 预警
//   入侵特征: σ(w·features) > 0.5 → 拦截

函数 智能_防火墙_AI初始化() {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 }
    定义 t = Tensor_创建(8)
    Tensor_写(t, 0, NFWE_包处理计数)
    Tensor_写(t, 1, NFWE_匹配计数)
    Tensor_写(t, 2, NFWE_丢弃计数)
    Tensor_写(t, 3, NFWE_接受计数)
    Tensor_写(t, 4, NFWE_NAT计数)
    Tensor_写(t, 5, NFWE_连接追踪计数)
    Tensor_写(t, 6, NFWE_AI检测计数)
    Tensor_写(t, 7, NFWE_AI拦截计数)
    AI总线_推理(bus, "NFWE_模块注册", t)
    Tensor_释放(t)
}

函数 NFWE_AI包检测(包) {
    NFWE_AI检测计数 = NFWE_AI检测计数 + 1
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 0 }
    定义 t = Tensor_创建(6)
    Tensor_写(t, 0, 包.源IP)
    Tensor_写(t, 1, 包.目标IP)
    Tensor_写(t, 2, 包.源端口)
    Tensor_写(t, 3, 包.目标端口)
    Tensor_写(t, 4, 包.协议)
    Tensor_写(t, 5, 包.数据长度)
    定义 风险 = AI总线_风险评分(bus, "NFWE_包检测", t)
    Tensor_释放(t)
    如果 (风险 > 800) {
        NFWE_AI拦截计数 = NFWE_AI拦截计数 + 1
    }
    返回 风险
}

函数 NFWE_AI异常流量检测() {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 0 }
    定义 t = Tensor_创建(4)
    Tensor_写(t, 0, NFWE_包处理计数)
    Tensor_写(t, 1, NFWE_丢弃计数)
    Tensor_写(t, 2, NFWE_连接追踪计数)
    Tensor_写(t, 3, NFWE_错误计数)
    定义 风险 = AI总线_推理(bus, "NFWE_异常流量", t)
    Tensor_释放(t)
    返回 风险
}

// §7 诊断与统计

函数 NFWE_获取统计() {
    定义 s = 堆_分配_数组(80)
    内存_写64(s + 0, NFWE_包处理计数)
    内存_写64(s + 8, NFWE_匹配计数)
    内存_写64(s + 16, NFWE_丢弃计数)
    内存_写64(s + 24, NFWE_接受计数)
    内存_写64(s + 32, NFWE_NAT计数)
    内存_写64(s + 40, NFWE_连接追踪计数)
    内存_写64(s + 48, NFWE_AI检测计数)
    内存_写64(s + 56, NFWE_AI拦截计数)
    内存_写64(s + 64, NFWE_错误计数)
    返回 s
}

函数 NFWE_诊断打印() {
    内核打印("[NFWE] 包处理=", NFWE_包处理计数, " 匹配=", NFWE_匹配计数)
    内核打印("[NFWE] 接受=", NFWE_接受计数, " 丢弃=", NFWE_丢弃计数)
    内核打印("[NFWE] NAT=", NFWE_NAT计数, " 连接追踪=", NFWE_连接追踪计数)
    内核打印("[NFWE] AI检测=", NFWE_AI检测计数, " AI拦截=", NFWE_AI拦截计数)
    内核打印("[NFWE] 错误=", NFWE_错误计数)
}

// §8 NAT翻译引擎
// NFWE-NAT公式: pkt' = T(pkt, nat_map)
//   SNAT: pkt.srcIP ← nat.mapIP, pkt.srcPort ← nat.mapPort
//   DNAT: pkt.dstIP ← nat.mapIP, pkt.dstPort ← nat.mapPort

定义 可变 NAT_端口池_当前 = 10000  // 分配的临时端口起始

函数 NAT_分配端口() {
    定义 p = NAT_端口池_当前
    NAT_端口池_当前 = NAT_端口池_当前 + 1
    如果 (NAT_端口池_当前 > 60000) { NAT_端口池_当前 = 10000 }
    返回 p
}

函数 NAT_SNAT翻译(包, 映射IP) {
    如果 (包 == 0) { 返回 假 }
    定义 新端口 = NAT_分配端口()
    包.源IP = 映射IP
    包.源端口 = 新端口
    NFWE_NAT计数 = NFWE_NAT计数 + 1
    返回 真
}

函数 NAT_DNAT翻译(包, 映射IP, 映射端口) {
    如果 (包 == 0) { 返回 假 }
    包.目标IP = 映射IP
    包.目标端口 = 映射端口
    NFWE_NAT计数 = NFWE_NAT计数 + 1
    返回 真
}

// §9 连接表过期清理

函数 连接表_清理过期(ct, 当前时间) {
    如果 (ct == 0) { 返回 0 }
    定义 可变 清理数 = 0
    定义 可变 i = 0
    当 (i < ct.桶数) {
        定义 可变 前一个 = 0
        定义 可变 条目 = 内存_读64(ct.桶 + i * 8)
        当 (条目 != 0) {
            定义 下一个 = 条目.哈希下一
            定义 耗时 = 当前时间 - 条目.上次活动
            如果 (耗时 > 条目.超时) {
                // 过期, 从链表移除
                如果 (前一个 == 0) {
                    内存_写64(ct.桶 + i * 8, 下一个)
                } 否则 {
                    前一个.哈希下一 = 下一个
                }
                ct.当前连接数 = ct.当前连接数 - 1
                清理数 = 清理数 + 1
            } 否则 {
                前一个 = 条目
            }
            条目 = 下一个
        }
        i = i + 1
    }
    返回 清理数
}

// §10 规则管理

函数 规则链_添加规则(链, 规则) {
    如果 (链 == 0 || 规则 == 0) { 返回 假 }
    如果 (链.规则数 >= 最大规则数) {
        NFWE_错误计数 = NFWE_错误计数 + 1
        返回 假
    }
    // 插入链表尾部(保持顺序)
    如果 (链.规则头 == 0) {
        链.规则头 = 规则
    } 否则 {
        定义 可变 p = 链.规则头
        当 (p.下一个 != 0) { p = p.下一个 }
        p.下一个 = 规则
    }
    规则.下一个 = 0
    链.规则数 = 链.规则数 + 1
    NFWE_规则数 = NFWE_规则数 + 1
    返回 真
}

函数 规则链_删除规则(链, 规则编号) {
    如果 (链 == 0) { 返回 假 }
    定义 可变 前 = 0
    定义 可变 r = 链.规则头
    当 (r != 0) {
        如果 (r.编号 == 规则编号) {
            如果 (前 == 0) { 链.规则头 = r.下一个 }
            否则 { 前.下一个 = r.下一个 }
            链.规则数 = 链.规则数 - 1
            NFWE_规则数 = NFWE_规则数 - 1
            返回 真
        }
        前 = r; r = r.下一个
    }
    返回 假
}

// §11 CIDR网址工具

函数 CIDR_前缀转掩码(前缀长度) {
    // /24 -> 0xFFFFFF00, /32 -> 0xFFFFFFFF
    如果 (前缀长度 >= 32) { 返回 0xFFFFFFFF }
    如果 (前缀长度 == 0) { 返回 0 }
    返回 (0xFFFFFFFF << (32 - 前缀长度)) & 0xFFFFFFFF
}

函数 IP_属于网段(ip, 网段IP, 前缀长度) {
    定义 掩码 = CIDR_前缀转掩码(前缀长度)
    返回 (ip & 掩码) == (网段IP & 掩码)
}

函数 IP合成(a, b, c, d) {
    返回 ((a & 0xFF) << 24) | ((b & 0xFF) << 16) | ((c & 0xFF) << 8) | (d & 0xFF)
}

函数 IP_是内网(ip) {
    // 10.0.0.0/8
    如果 (IP_属于网段(ip, IP合成(10, 0, 0, 0), 8)) { 返回 真 }
    // 172.16.0.0/12
    如果 (IP_属于网段(ip, IP合成(172, 16, 0, 0), 12)) { 返回 真 }
    // 192.168.0.0/16
    如果 (IP_属于网段(ip, IP合成(192, 168, 0, 0), 16)) { 返回 真 }
    返回 假
}

// §12 NFWE防火墙引擎初始化

函数 NFWE_初始化() {
    内核打印("[NFWE] Nova防火墙规则引擎 v1.0 启动")
    智能_防火墙_AI初始化()
    内核打印("[NFWE] AI智能防护已加载")
    返回 真
}

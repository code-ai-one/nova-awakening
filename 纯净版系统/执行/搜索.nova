// NovaOS grep — 文本搜索
// 功能: 模式匹配, -i大小写/-n行号/-c计数/-v反转/-r递归/-w全词/-A/-B/-C上下文/-m最大数/-l文件名/-E正则

定义 GREP_忽略大小写 = 1
定义 GREP_行号 = 2
定义 GREP_计数 = 4
定义 GREP_反转 = 8
定义 GREP_递归 = 16
定义 GREP_全词 = 32
定义 GREP_仅文件名 = 64
定义 GREP_正则 = 128
定义 GREP_静默 = 256

结构 Grep配置 {
    选项,
    模式,
    文件列表,
    前上下文,
    后上下文,
    最大匹配,
    包含模式,
    排除模式,
}

结构 Grep统计 {
    搜索文件数,
    匹配文件数,
    匹配行数,
    扫描行数,
    递归目录数,
}

定义 可变 全局_grep统计 = 空

函数 grep统计_初始化() {
    如果 (全局_grep统计 == 空) {
        全局_grep统计 = Grep统计 {}
        全局_grep统计.搜索文件数 = 0
        全局_grep统计.匹配文件数 = 0
        全局_grep统计.匹配行数 = 0
        全局_grep统计.扫描行数 = 0
        全局_grep统计.递归目录数 = 0
    }
}

函数 grep_解析参数(参数) {
    定义 配置 = Grep配置 {}
    配置.选项 = 0
    配置.模式 = ""
    配置.文件列表 = []
    配置.前上下文 = 0
    配置.后上下文 = 0
    配置.最大匹配 = 0
    配置.包含模式 = ""
    配置.排除模式 = ""

    定义 可变 模式已设 = 假
    定义 可变 i = 0
    当 (i < 计数(参数)) {
        定义 a = 参数[i]
        如果 (a == "-i") { 配置.选项 = 配置.选项 | GREP_忽略大小写 }
        否则 如果 (a == "-n") { 配置.选项 = 配置.选项 | GREP_行号 }
        否则 如果 (a == "-c") { 配置.选项 = 配置.选项 | GREP_计数 }
        否则 如果 (a == "-v") { 配置.选项 = 配置.选项 | GREP_反转 }
        否则 如果 (a == "-r" || a == "-R") { 配置.选项 = 配置.选项 | GREP_递归 }
        否则 如果 (a == "-w") { 配置.选项 = 配置.选项 | GREP_全词 }
        否则 如果 (a == "-l") { 配置.选项 = 配置.选项 | GREP_仅文件名 }
        否则 如果 (a == "-E") { 配置.选项 = 配置.选项 | GREP_正则 }
        否则 如果 (a == "-q") { 配置.选项 = 配置.选项 | GREP_静默 }
        否则 如果 (a == "-A" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.后上下文 = 字符串转整数(参数[i])
        }
        否则 如果 (a == "-B" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.前上下文 = 字符串转整数(参数[i])
        }
        否则 如果 (a == "-C" && i + 1 < 计数(参数)) {
            i = i + 1
            定义 上下文 = 字符串转整数(参数[i])
            配置.前上下文 = 上下文
            配置.后上下文 = 上下文
        }
        否则 如果 (a == "-m" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.最大匹配 = 字符串转整数(参数[i])
        }
        否则 如果 (a == "--include" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.包含模式 = 参数[i]
        }
        否则 如果 (a == "--exclude" && i + 1 < 计数(参数)) {
            i = i + 1
            配置.排除模式 = 参数[i]
        }
        否则 如果 (!模式已设) { 配置.模式 = a  模式已设 = 真 }
        否则 { 追加(配置.文件列表, a) }
        i = i + 1
    }

    如果 (!模式已设) { 配置.模式 = "" }
    返回 配置
}

函数 grep_main(参数) {
    grep统计_初始化()
    定义 配置 = grep_解析参数(参数)

    如果 (配置.模式 == "") {
        打印行("用法: grep [选项] 模式 [文件...]")
        打印行("  -i 忽略大小写  -n 行号  -c 计数  -v 反转匹配")
        打印行("  -r 递归搜索  -w 全词匹配  -l 仅文件名  -E 正则模式")
        打印行("  -A N 后上下文  -B N 前上下文  -C N 上下文")
        打印行("  -m N 最大匹配数  -q 静默模式")
        打印行("  --include 模式  --exclude 模式")
        返回 1
    }

    如果 (计数(配置.文件列表) == 0) { 追加(配置.文件列表, "-") }

    // 递归模式: 展开目录
    如果 ((配置.选项 & GREP_递归) != 0) {
        定义 展开列表 = []
        定义 可变 k = 0
        当 (k < 计数(配置.文件列表)) {
            定义 路径 = 配置.文件列表[k]
            如果 (文件_是目录(路径)) {
                全局_grep统计.递归目录数 = 全局_grep统计.递归目录数 + 1
                grep_展开目录(路径, 展开列表, 配置)
            } 否则 {
                追加(展开列表, 路径)
            }
            k = k + 1
        }
        配置.文件列表 = 展开列表
    }

    定义 可变 总匹配 = 0
    定义 多文件 = 计数(配置.文件列表) > 1
    定义 可变 k = 0
    当 (k < 计数(配置.文件列表)) {
        定义 路径 = 配置.文件列表[k]

        // 过滤文件
        如果 (!grep_文件匹配过滤(路径, 配置)) {
            k = k + 1
            继续
        }

        定义 文件匹配数 = grep_搜索文件(路径, 配置, 多文件)
        总匹配 = 总匹配 + 文件匹配数
        如果 (文件匹配数 > 0) {
            全局_grep统计.匹配文件数 = 全局_grep统计.匹配文件数 + 1
        }

        k = k + 1
    }

    如果 (总匹配 > 0) { 返回 0 }
    返回 1
}

函数 grep_搜索文件(路径, 配置, 多文件) {
    全局_grep统计.搜索文件数 = 全局_grep统计.搜索文件数 + 1

    定义 内容 = 文件_读取全部(路径)
    如果 (内容 == 空) { 返回 0 }

    定义 行列表 = 字符串分割(内容, "\n")
    定义 行数 = 计数(行列表)
    全局_grep统计.扫描行数 = 全局_grep统计.扫描行数 + 行数

    定义 可变 文件匹配数 = 0
    定义 可变 上次打印行 = -1
    定义 可变 j = 0
    当 (j < 行数) {
        如果 (配置.最大匹配 > 0 && 文件匹配数 >= 配置.最大匹配) { 跳出 }

        定义 行 = 行列表[j]
        定义 匹配 = grep_匹配行(行, 配置.模式, 配置.选项)
        如果 ((配置.选项 & GREP_反转) != 0) { 匹配 = !匹配 }

        如果 (匹配) {
            文件匹配数 = 文件匹配数 + 1
            全局_grep统计.匹配行数 = 全局_grep统计.匹配行数 + 1

            如果 ((配置.选项 & GREP_静默) != 0) {
                j = j + 1
                继续
            }

            如果 ((配置.选项 & GREP_仅文件名) != 0) {
                打印行(路径)
                返回 文件匹配数
            }

            如果 ((配置.选项 & GREP_计数) == 0) {
                // 打印前上下文
                如果 (配置.前上下文 > 0) {
                    定义 可变 开始 = j - 配置.前上下文
                    如果 (开始 < 0) { 开始 = 0 }
                    如果 (开始 <= 上次打印行) { 开始 = 上次打印行 + 1 }
                    如果 (开始 < j && 上次打印行 >= 0 && 开始 > 上次打印行 + 1) {
                        打印行("--")
                    }
                    定义 可变 b = 开始
                    当 (b < j) {
                        grep_输出行(路径, b, 行列表[b], 多文件, 配置.选项, 假)
                        b = b + 1
                    }
                }

                // 打印匹配行
                grep_输出行(路径, j, 行, 多文件, 配置.选项, 真)
                上次打印行 = j

                // 打印后上下文
                如果 (配置.后上下文 > 0) {
                    定义 可变 结束 = j + 配置.后上下文
                    如果 (结束 >= 行数) { 结束 = 行数 - 1 }
                    定义 可变 a = j + 1
                    当 (a <= 结束) {
                        grep_输出行(路径, a, 行列表[a], 多文件, 配置.选项, 假)
                        上次打印行 = a
                        a = a + 1
                    }
                }
            }
        }
        j = j + 1
    }

    如果 ((配置.选项 & GREP_计数) != 0 && (配置.选项 & GREP_静默) == 0) {
        如果 (多文件) { 打印(字符串拼接(路径, ":")) }
        打印行(整数转字符串(文件匹配数))
    }

    返回 文件匹配数
}

函数 grep_输出行(路径, 行号, 行内容, 多文件, 选项, 是匹配) {
    定义 可变 前缀 = ""
    如果 (多文件) { 前缀 = 字符串拼接(路径, ":") }
    如果 ((选项 & GREP_行号) != 0) {
        定义 分隔 = ":"
        如果 (!是匹配) { 分隔 = "-" }
        前缀 = 字符串拼接(前缀, 字符串拼接(整数转字符串(行号 + 1), 分隔))
    }
    打印行(字符串拼接(前缀, 行内容))
}

函数 grep_匹配行(行, 模式, 选项) {
    定义 可变 搜索行 = 行
    定义 可变 搜索模式 = 模式
    如果 ((选项 & GREP_忽略大小写) != 0) {
        搜索行 = 字符串转小写(行)
        搜索模式 = 字符串转小写(模式)
    }

    // 正则模式
    如果 ((选项 & GREP_正则) != 0) {
        返回 正则_包含(搜索行, 搜索模式)
    }

    // 全词匹配
    如果 ((选项 & GREP_全词) != 0) {
        返回 grep_全词匹配(搜索行, 搜索模式)
    }

    返回 字符串包含(搜索行, 搜索模式)
}

函数 grep_全词匹配(行, 模式) {
    定义 模式长 = 字符串长度(模式)
    定义 行长 = 字符串长度(行)
    如果 (模式长 == 0) { 返回 假 }

    定义 可变 i = 0
    当 (i <= 行长 - 模式长) {
        定义 子串 = 字符串子串(行, i, i + 模式长)
        如果 (子串 == 模式) {
            定义 前OK = (i == 0) || !grep_是单词字符(字符串字符(行, i - 1))
            定义 后OK = (i + 模式长 >= 行长) || !grep_是单词字符(字符串字符(行, i + 模式长))
            如果 (前OK && 后OK) { 返回 真 }
        }
        i = i + 1
    }
    返回 假
}

函数 grep_是单词字符(ch) {
    返回 (ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122) || (ch >= 48 && ch <= 57) || ch == 95
}

函数 grep_展开目录(目录, 结果列表, 配置) {
    定义 条目列表 = 文件_列出目录(目录)
    如果 (条目列表 == 空) { 返回 }

    定义 可变 i = 0
    当 (i < 计数(条目列表)) {
        定义 条目 = 条目列表[i]
        定义 完整路径 = 字符串拼接(目录, 字符串拼接("/", 条目))

        如果 (文件_是目录(完整路径)) {
            全局_grep统计.递归目录数 = 全局_grep统计.递归目录数 + 1
            grep_展开目录(完整路径, 结果列表, 配置)
        } 否则 {
            追加(结果列表, 完整路径)
        }
        i = i + 1
    }
}

函数 grep_文件匹配过滤(路径, 配置) {
    如果 (配置.包含模式 != "") {
        如果 (!grep_简单通配符(路径, 配置.包含模式)) { 返回 假 }
    }
    如果 (配置.排除模式 != "") {
        如果 (grep_简单通配符(路径, 配置.排除模式)) { 返回 假 }
    }
    返回 真
}

函数 grep_简单通配符(文件名, 模式) {
    // 简单 *.ext 通配符匹配
    如果 (字符串长度(模式) > 1 && 字符串字符(模式, 0) == 42) {
        定义 后缀 = 字符串子串(模式, 1, 字符串长度(模式))
        返回 字符串结尾(文件名, 后缀)
    }
    返回 字符串包含(文件名, 模式)
}

函数 grep_打印统计() {
    grep统计_初始化()
    打印行("=== grep统计 ===")
    打印行("搜索文件数: " + 整数转字符串(全局_grep统计.搜索文件数))
    打印行("匹配文件数: " + 整数转字符串(全局_grep统计.匹配文件数))
    打印行("匹配行数: " + 整数转字符串(全局_grep统计.匹配行数))
    打印行("扫描行数: " + 整数转字符串(全局_grep统计.扫描行数))
    打印行("递归目录数: " + 整数转字符串(全局_grep统计.递归目录数))
}

定义 可变 AI_搜索_热文件表 = []

函数 AI_搜索_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_搜索_热文件表)) {
        如果 (AI_搜索_热文件表[i].路径 == 路径) {
            AI_搜索_热文件表[i].频率 = AI_搜索_热文件表[i].频率 + 1
            返回 AI_搜索_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_搜索_热文件表) < 128) {
        追加(AI_搜索_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_搜索_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

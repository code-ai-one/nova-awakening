// §1 浏览器内核初始化 — 五层自底向上启动

函数 浏览器内核_初始化() {
    内核状态 = 浏览器内核状态 {}
    内核状态.版本 = 浏览器版本
    内核状态.启动时间 = 高精度定时器_读取()

    内核信息("═══════════════════════════════════════════════════")
    内核信息("  NovaOS 终端 " + 浏览器版本 + " — kernel browser-终端 启动")
    内核信息("  内核=大模型=浏览器=系统=内核")
    内核信息("  多模态感知 · 合法自动化 · 热更新回滚 · Web桌面")
    内核信息("═══════════════════════════════════════════════════")

    // ━━ 第一层: Nova原生适配层 (直连L0-L2内核) ━━
    内核信息("[1/8] 初始化Nova原生适配层...")
    浏览器内存_初始化()
    浏览器网络_初始化()
    浏览器存储_初始化()
    浏览器图处_初始化(默认视口宽, 默认视口高)
    浏览器调度_初始化()
    浏览器安全_初始化()
    内核状态.适配层就绪 = 真
    内核信息("[1/8] ✓ 适配层就绪 (网络/存储/内存/图处/调度/安全)")

    // ━━ 第二层: 核心能力层 (DOM/CSS/JS/渲染) ━━
    内核信息("[2/8] 初始化核心能力层...")
    DOM_初始化()
    CSS_初始化()
    渲染_初始化(默认视口宽, 默认视口高)
    JS_初始化()
    事件循环_初始化()
    内核状态.核心层就绪 = 真
    内核信息("[2/8] ✓ 核心层就绪 (DOM+CSS+渲染+JS+事件循环)")

    // ━━ 第三层: AI原生融合层 + GUI融合 ━━
    内核信息("[3/8] 初始化AI原生融合层+GUI融合...")
    意图推理_初始化()
    页面预测_初始化()
    渲染优化_初始化()
    资源调度_初始化()
    安全检测_初始化()
    组件Web化_初始化()
    合成器对接_初始化()
    内核状态.AI层就绪 = 真
    内核信息("[3/8] ✓ AI+GUI层就绪")

    // ━━ 第四层: 网络增强层 ★新 ━━
    内核信息("[4/8] 初始化网络增强层...")
    流量伪装_初始化()
    内核状态.网络增强就绪 = 真
    内核信息("[4/8] ✓ 网络增强就绪 (传控指纹+HTTP/2指纹+请求节奏+安全域名)")

    // ━━ 第五层: 反检测层 ★新 ━━
    内核信息("[5/8] 初始化会话安全与隐私层...")
    反追踪_初始化()
    内核状态.反检测就绪 = 真
    内核信息("[5/8] ✓ 会话安全与隐私层就绪 (反追踪/环境一致性)")

    // ━━ 第六层: 自动化层 ★新 ━━
    内核信息("[6/8] 初始化自动化层...")
    视觉识别_初始化()
    听觉识别_初始化()
    任务编排_初始化()
    内核状态.自动化就绪 = 真
    内核信息("[6/8] ✓ 自动化就绪 (视觉识别/听觉识别/任务编排)")

    // ━━ 第七层: Web桌面引擎 ★新 ━━
    内核信息("[7/8] 初始化Web桌面引擎...")
    Web桌面_初始化(默认视口宽, 默认视口高)
    内核状态.Web桌面就绪 = 真
    内核信息("[7/8] ✓ Web桌面就绪 (HTML5桌面/窗口=浏览器/平台加载)")

    // ━━ 第八层: 系统入口层 ━━
    内核信息("[8/8] 初始化系统入口层...")
    AI交互入口_初始化()
    插件系统_初始化()
    内核状态.入口层就绪 = 真
    内核信息("[8/8] ✓ 入口层就绪 (AI交互入口+插件系统)")

    // ━━ 环境一致性自检 ━━
    反追踪_一致性自检()
    反追踪_修复JS环境()

    内核状态.已初始化 = 真
    内核信息("═══════════════════════════════════════════════════")
    内核信息("  NovaOS 终端 v2.0 初始化完成!")
    内核信息("  八层架构全部就绪")
    内核信息("  系统=超级浏览器 · AI原生命令面 · 合法自动化执行")
    内核信息("═══════════════════════════════════════════════════")
}

// §2 浏览器启动 — 创建主窗口并加载首页

函数 浏览器内核_启动() {
    如果 (!内核状态.已初始化) {
        浏览器内核_初始化()
    }

    内核信息("NovaOS 终端: 创建主窗口...")

    // 启动Web桌面(HTML5桌面环境=超级浏览器)
    Web桌面_渲染帧()

    // 创建默认浏览器窗口
    定义 几何 = Web桌面_获取主工作区窗口几何(1)
    Web桌面_打开窗口(浏览器名称, 默认首页, 几何[0], 几何[1], 几何[2], 几何[3])

    // 启动事件循环
    内核状态.运行中 = 真
    内核信息("NovaOS 终端: Web桌面启动, 系统=超级浏览器")
}

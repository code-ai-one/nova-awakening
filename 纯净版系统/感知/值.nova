// Web Crypto 接口 (SubtleCrypto):
// crypto.subtle.encrypt/decrypt(algorithm, key, data)
// crypto.subtle.sign/verify(algorithm, key, data, signature)
// crypto.subtle.digest(algorithm, data) — SHA-256/384/512
// crypto.subtle.generateKey(algorithm, extractable, keyUsages)
// crypto.subtle.importKey/exportKey
// crypto.subtle.deriveKey/deriveBits — PBKDF2/HKDF/ECDH
// crypto.subtle.wrapKey/unwrapKey
// crypto.getRandomValues(typed数组)
// 支持算法: AES-CBC/AES-GCM/AES-CTR/RSA-OAEP/RSA-PSS/ECDSA/ECDH/HMAC
// Permissions 接口:
// navigator.permissions.query({name}) → PermissionStatus
// PermissionStatus.state: "granted"/"denied"/"prompt"
// PermissionStatus.onchange
// Notifications 接口:
// Notification.requestPermission() → "granted"/"denied"/"default"
// new Notification(title, {body, icon, badge, tag, ...})
// notification.close()
// Service 工线: registration.showNotification()


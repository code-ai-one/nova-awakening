// NovaOS 演化沙盒 — 自我学习迭代的安全隔离环境
// 核心原则:
//   1. 所有自我演化代码先在沙盒中测试运行
//   2. 验证通过后才更新到底层运行中的系统
//   3. 临时文件集中管理,验证后自动清理
//   4. 始终保持系统最新干净版本,零冗余

导入("./类型定义.nova")
导入("./错误码.nova")
导入("../推理/云端桥接.nova")
导入("../推理/知识蒸馏.nova")
导入("./检查点系统初.nova")
导入("./模块级热替换.nova")
导入("../标准/文件.nova")
导入("../标准/原生字符串.nova")
导入("../记忆/接口.nova")

// §1 沙盒目录管理 — 临时文件隔离

定义 沙盒根路径 = "/nova/沙盒/"
定义 沙盒_代码目录 = "/nova/沙盒/代码/"
定义 沙盒_数据目录 = "/nova/沙盒/数据/"
定义 沙盒_日志目录 = "/nova/沙盒/日志/"
定义 沙盒_快照目录 = "/nova/沙盒/快照/"

定义 可变 沙盒_已初始化 = 假
定义 可变 沙盒_测试总数 = 0
定义 可变 沙盒_测试通过 = 0
定义 可变 沙盒_测试失败 = 0
定义 可变 沙盒_更新成功 = 0
定义 可变 沙盒_回滚次数 = 0
定义 可变 沙盒_清理次数 = 0
定义 可变 沙盒_临时文件数 = 0

函数 沙盒_初始化() {
    如果 (沙盒_已初始化) { 返回 0 }
    // 创建沙盒目录结构
    记忆_创建目录(沙盒根路径)
    记忆_创建目录(沙盒_代码目录)
    记忆_创建目录(沙盒_数据目录)
    记忆_创建目录(沙盒_日志目录)
    记忆_创建目录(沙盒_快照目录)
    沙盒_已初始化 = 真
    打印("[沙盒] 演化沙盒初始化完成")
    返回 0
}

// §2 演化提案 — 自我学习产生的修改方案

结构 演化提案 {
    编号,
    类型,           // "权重更新"/"代码补丁"/"配置调整"/"新能力"
    来源,           // "赫布学习"/"蒸馏"/"强化学习"/"云端回流"
    目标模块,
    修改内容,
    预期效果,
    风险评估,       // 0-1000
    创建时间,
    状态,           // 0=待测试 1=测试中 2=通过 3=失败 4=已部署 5=已回滚
    测试检查点ID,
    部署检查点ID,
    沙盒文件已创建,
}

定义 可变 提案队列 = []
定义 可变 提案总数 = 0
定义 提案_最大 = 64

函数 沙盒_目标模块有效(目标模块) {
    如果 (目标模块 == 空) { 返回 0 }
    如果 (字符串长度(目标模块) <= 0) { 返回 0 }
    如果 (字符串开头是(目标模块, "/") == 真) { 返回 0 }
    如果 (字符串包含(目标模块, "..") == 真) { 返回 0 }
    如果 (字符串结尾是(目标模块, "/") == 真) { 返回 0 }
    返回 1
}

函数 沙盒_拼接路径(目录, 名称) {
    如果 (字符串结尾是(目录, "/") == 真) { 返回 目录 + 名称 }
    返回 目录 + "/" + 名称
}

函数 沙盒_释放检查点(检查点ID) {
    如果 (检查点ID > 0) { 检查点_删除(检查点ID) }
}

函数 沙盒_标准模块名(目标模块) {
    如果 (字符串结尾是(目标模块, ".nova") == 真) {
        返回 字符串子串(目标模块, 0, 字符串长度(目标模块) - 5)
    }
    返回 目标模块
}

函数 沙盒_提案文件路径(提案) {
    定义 相对路径 = 提案.目标模块
    如果 (字符串结尾是(相对路径, ".nova") != 真) { 相对路径 = 相对路径 + ".nova" }
    返回 沙盒_拼接路径(沙盒_代码目录, 相对路径)
}

函数 沙盒_确保父目录(文件路径) {
    定义 可变 i = 1
    定义 长度 = 字符串长度(文件路径)
    当 (i < 长度) {
        如果 (字符串取字符码(文件路径, i) == 47) {
            定义 目录路径 = 字符串子串(文件路径, 0, i)
            如果 (字符串长度(目录路径) > 0 && 目录_存在(目录路径) != 真) {
                定义 结果 = 目录_创建默认(目录路径)
                如果 (结果 < 0) { 返回 结果 }
            }
        }
        i = i + 1
    }
    返回 0
}

函数 沙盒_递归复制目录(源目录, 目标目录) {
    如果 (目录_存在(源目录) != 真) { 返回 错误_不存在 }
    定义 可变 结果 = 沙盒_确保父目录(沙盒_拼接路径(目标目录, "__probe__"))
    如果 (结果 < 0) { 返回 结果 }
    如果 (目录_存在(目标目录) != 真) {
        结果 = 目录_创建默认(目标目录)
        如果 (结果 < 0) { 返回 结果 }
    }
    定义 条目列表 = 记忆_列目录(源目录)
    定义 可变 i = 0
    当 (i < 计数(条目列表)) {
        定义 条目名 = 条目列表[i]
        如果 (条目名 == "." || 条目名 == "..") {
            i = i + 1
            继续
        }
        定义 完整源 = 沙盒_拼接路径(源目录, 条目名)
        定义 完整目标 = 沙盒_拼接路径(目标目录, 条目名)
        如果 (目录_存在(完整源) == 真) {
            结果 = 沙盒_递归复制目录(完整源, 完整目标)
        } 否则 {
            结果 = 沙盒_确保父目录(完整目标)
            如果 (结果 >= 0) { 结果 = 文件_复制(完整源, 完整目标) }
        }
        如果 (结果 < 0) { 返回 结果 }
        i = i + 1
    }
    返回 成功
}

函数 沙盒_递归删除目录(目录路径) {
    如果 (目录_存在(目录路径) != 真) { 返回 成功 }
    定义 条目列表 = 记忆_列目录(目录路径)
    定义 可变 i = 0
    当 (i < 计数(条目列表)) {
        定义 条目名 = 条目列表[i]
        如果 (条目名 == "." || 条目名 == "..") {
            i = i + 1
            继续
        }
        定义 完整路径 = 沙盒_拼接路径(目录路径, 条目名)
        定义 可变 结果 = 成功
        如果 (目录_存在(完整路径) == 真) {
            结果 = 沙盒_递归删除目录(完整路径)
        } 否则 如果 (文件_存在(完整路径) == 真) {
            结果 = 文件_删除(完整路径)
        }
        如果 (结果 < 0) { 返回 结果 }
        i = i + 1
    }
    返回 目录_删除(目录路径)
}

函数 沙盒_括号平衡(文本) {
    定义 可变 圆括号 = 0
    定义 可变 方括号 = 0
    定义 可变 花括号 = 0
    定义 可变 在字符串 = 0
    定义 可变 在注释 = 0
    定义 可变 i = 0
    定义 长度 = 字符串长度(文本)
    当 (i < 长度) {
        定义 c = 字符串取字符码(文本, i)
        定义 可变 下一个 = 0
        如果 (i + 1 < 长度) { 下一个 = 字符串取字符码(文本, i + 1) }
        如果 (在注释 == 1) {
            如果 (c == 10 || c == 13) { 在注释 = 0 }
            i = i + 1
            继续
        }
        如果 (在字符串 == 1) {
            如果 (c == 34) { 在字符串 = 0 }
            i = i + 1
            继续
        }
        如果 (c == 47 && 下一个 == 47) {
            在注释 = 1
            i = i + 2
            继续
        }
        如果 (c == 34) {
            在字符串 = 1
            i = i + 1
            继续
        }
        如果 (c == 40) { 圆括号 = 圆括号 + 1 }
        否则 如果 (c == 41) { 圆括号 = 圆括号 - 1 }
        否则 如果 (c == 91) { 方括号 = 方括号 + 1 }
        否则 如果 (c == 93) { 方括号 = 方括号 - 1 }
        否则 如果 (c == 123) { 花括号 = 花括号 + 1 }
        否则 如果 (c == 125) { 花括号 = 花括号 - 1 }
        如果 (圆括号 < 0 || 方括号 < 0 || 花括号 < 0) { 返回 0 }
        i = i + 1
    }
    如果 (在字符串 == 1) { 返回 0 }
    如果 (圆括号 != 0 || 方括号 != 0 || 花括号 != 0) { 返回 0 }
    返回 1
}

函数 沙盒_导入完整(文本) {
    定义 行列表 = 字符串分割(文本, "\n")
    定义 可变 i = 0
    定义 前缀长 = 字符串长度("导入(")
    当 (i < 计数(行列表)) {
        定义 行 = 字符串去首尾空白(行列表[i])
        如果 (字符串开头是(行, "导入(") == 真) {
            定义 行长 = 字符串长度(行)
            如果 (行长 <= 前缀长 + 2) { 返回 0 }
            如果 (字符串取字符码(行, 前缀长) != 34) { 返回 0 }
            如果 (字符串取字符码(行, 行长 - 2) != 34) { 返回 0 }
            如果 (字符串取字符码(行, 行长 - 1) != 41) { 返回 0 }
            定义 路径 = 字符串子串(行, 前缀长 + 1, 行长 - 2)
            如果 (字符串长度(路径) <= 0) { 返回 0 }
            如果 (字符串结尾是(路径, ".nova") != 真) { 返回 0 }
        }
        i = i + 1
    }
    返回 1
}

函数 沙盒_函数不冲突(文本) {
    定义 行列表 = 字符串分割(文本, "\n")
    定义 名称列表 = []
    定义 可变 i = 0
    定义 前缀长 = 字符串长度("函数 ")
    当 (i < 计数(行列表)) {
        定义 行 = 字符串去首尾空白(行列表[i])
        如果 (字符串开头是(行, "函数 ") == 真) {
            定义 左括号 = 字符串查找从(行, "(", 前缀长)
            如果 (左括号 < 0) { 返回 0 }
            定义 名称 = 字符串去首尾空白(字符串子串(行, 前缀长, 左括号))
            如果 (字符串长度(名称) <= 0) { 返回 0 }
            定义 可变 j = 0
            当 (j < 计数(名称列表)) {
                如果 (名称列表[j] == 名称) { 返回 0 }
                j = j + 1
            }
            追加(名称列表, 名称)
        }
        i = i + 1
    }
    返回 1
}

函数 沙盒_代码形状有效(文本) {
    如果 (字符串包含(文本, "函数 ") == 真) { 返回 1 }
    如果 (字符串包含(文本, "结构 ") == 真) { 返回 1 }
    如果 (字符串包含(文本, "定义 ") == 真) { 返回 1 }
    如果 (字符串包含(文本, "外部 ") == 真) { 返回 1 }
    如果 (字符串包含(文本, "导入(") == 真) { 返回 1 }
    返回 0
}

函数 沙盒_提交提案(类型, 来源, 目标, 内容, 风险) {
    如果 (计数(提案队列) >= 提案_最大) {
        // 淘汰最老的失败提案
        沙盒_清理失败提案()
    }
    定义 提案 = 演化提案 {
        编号: 提案总数,
        类型: 类型,
        来源: 来源,
        目标模块: 目标,
        修改内容: 内容,
        预期效果: "",
        风险评估: 风险,
        创建时间: 中枢_当前时间纳秒(),
        状态: 0,
        测试检查点ID: 0,
        部署检查点ID: 0,
        沙盒文件已创建: 0
    }
    追加(提案队列, 提案)
    提案总数 = 提案总数 + 1
    返回 提案.编号
}

// §3 沙盒测试 — 在隔离环境中验证提案

函数 沙盒_测试提案(提案编号) {
    定义 提案 = 沙盒_查找提案(提案编号)
    如果 (提案 == 空) { 返回 -1 }
    提案.状态 = 1  // 测试中
    沙盒_测试总数 = 沙盒_测试总数 + 1
    如果 (提案.类型 != "代码补丁" && 提案.类型 != "新能力") {
        提案.状态 = 3
        沙盒_测试失败 = 沙盒_测试失败 + 1
        返回 错误_不支持操作
    }

    // 1. 创建快照(回滚点)
    定义 测试检查点 = 检查点_创建("沙盒测试-" + 整数转字符串(提案编号))
    如果 (测试检查点 == 空) {
        提案.状态 = 3
        沙盒_测试失败 = 沙盒_测试失败 + 1
        返回 错误_内存不足
    }
    提案.测试检查点ID = 测试检查点.检查点ID

    // 2. 在沙盒中应用修改
    如果 (沙盒_目标模块有效(提案.目标模块) != 1) {
        提案.状态 = 3
        沙盒_测试失败 = 沙盒_测试失败 + 1
        沙盒_释放检查点(提案.测试检查点ID)
        提案.测试检查点ID = 0
        返回 错误_无效参数
    }
    定义 沙盒文件 = 沙盒_提案文件路径(提案)
    定义 准备结果 = 沙盒_确保父目录(沙盒文件)
    如果 (准备结果 < 0) {
        提案.状态 = 3
        沙盒_测试失败 = 沙盒_测试失败 + 1
        沙盒_释放检查点(提案.测试检查点ID)
        提案.测试检查点ID = 0
        返回 准备结果
    }
    定义 写入结果 = 文件_写全部(沙盒文件, 提案.修改内容, 字符串长度(提案.修改内容))
    如果 (写入结果 < 0) {
        提案.状态 = 3
        沙盒_测试失败 = 沙盒_测试失败 + 1
        沙盒_释放检查点(提案.测试检查点ID)
        提案.测试检查点ID = 0
        返回 写入结果
    }
    如果 (提案.沙盒文件已创建 != 1) {
        提案.沙盒文件已创建 = 1
        沙盒_临时文件数 = 沙盒_临时文件数 + 1
    }

    // 3. 运行验证测试
    定义 测试结果 = 沙盒_运行验证(沙盒文件, 提案.修改内容)

    // 4. 评估结果
    如果 (测试结果 == 1) {
        提案.状态 = 2  // 通过
        沙盒_测试通过 = 沙盒_测试通过 + 1
        沙盒_释放检查点(提案.测试检查点ID)
        提案.测试检查点ID = 0
        打印("[沙盒] 提案" + 提案编号 + "测试通过")
    } 否则 {
        提案.状态 = 3  // 失败
        沙盒_测试失败 = 沙盒_测试失败 + 1
        沙盒_清理提案文件(提案编号)
        沙盒_释放检查点(提案.测试检查点ID)
        提案.测试检查点ID = 0
        打印("[沙盒] 提案" + 提案编号 + "测试失败,已清理")
    }

    返回 测试结果
}

函数 沙盒_运行验证(文件路径, 修改) {
    // 验证: 语法正确+括号平衡+函数不冲突+导入完整
    // 简化: 返回1=通过 0=失败
    如果 (文件路径 == 空 || 修改 == 空) { 返回 错误_无效参数 }
    如果 (字符串长度(修改) <= 0) { 返回 错误_无效参数 }
    如果 (沙盒_代码形状有效(修改) != 1) { 返回 错误_沙箱违规 }
    如果 (字符串开头是(文件路径, 沙盒_代码目录) != 真) { 返回 错误_沙箱违规 }
    如果 (字符串结尾是(文件路径, ".nova") != 真) { 返回 错误_无效参数 }
    如果 (文件_存在(文件路径) != 真) { 返回 错误_不存在 }
    定义 已写入代码 = 文件_读全部(文件路径)
    如果 (已写入代码 == 0) { 返回 错误_不存在 }
    如果 (已写入代码 != 修改) { 返回 错误_完整性校验失败 }
    如果 (沙盒_括号平衡(修改) != 1) { 返回 错误_沙箱违规 }
    如果 (沙盒_导入完整(修改) != 1) { 返回 错误_沙箱违规 }
    如果 (沙盒_函数不冲突(修改) != 1) { 返回 错误_沙箱违规 }
    返回 1
}

// §4 部署到底层 — 热更新到运行中的系统

函数 沙盒_部署提案(提案编号) {
    定义 提案 = 沙盒_查找提案(提案编号)
    如果 (提案 == 空 || 提案.状态 != 2) { 返回 -1 }

    // 1. 再次创建底层快照(部署回滚点)
    如果 (提案.类型 != "代码补丁" && 提案.类型 != "新能力") {
        提案.状态 = 3
        沙盒_清理提案文件(提案编号)
        返回 错误_不支持操作
    }
    定义 部署检查点 = 检查点_创建("沙盒部署-" + 整数转字符串(提案编号))
    如果 (部署检查点 == 空) { 返回 错误_内存不足 }
    提案.部署检查点ID = 部署检查点.检查点ID

    // 2. 热更新到运行中的系统
    定义 结果 = 错误_不支持操作
    定义 沙盒文件 = 沙盒_提案文件路径(提案)
    定义 新代码 = 文件_读全部(沙盒文件)
    如果 (新代码 == 0) {
        结果 = 错误_不存在
    } 否则 {
        定义 热替换结果 = 模块_热替换(沙盒_标准模块名(提案.目标模块), 新代码, 字符串长度(新代码))
        如果 (热替换结果 == 成功) { 结果 = 1 } 否则 { 结果 = 热替换结果 }
    }

    如果 (结果 == 1) {
        提案.状态 = 4  // 已部署
        沙盒_更新成功 = 沙盒_更新成功 + 1
        // 清理沙盒临时文件
        沙盒_清理提案文件(提案编号)
        沙盒_释放检查点(提案.部署检查点ID)
        提案.部署检查点ID = 0
        打印("[沙盒] 提案" + 提案编号 + "已部署到底层")
    } 否则 {
        // 部署失败→回滚
        沙盒_回滚(提案编号, 提案.部署检查点ID)
    }

    返回 结果
}

// §5 回滚 — 部署失败自动恢复

函数 沙盒_回滚(提案编号, 检查点ID) {
    定义 提案 = 沙盒_查找提案(提案编号)
    如果 (提案 != 空) { 提案.状态 = 5 }
    // 从快照恢复
    定义 结果 = 错误_无效参数
    如果 (检查点ID > 0) {
        结果 = 检查点_恢复(检查点ID)
        沙盒_释放检查点(检查点ID)
    }
    如果 (提案 != 空) {
        提案.部署检查点ID = 0
        沙盒_清理提案文件(提案编号)
    }
    如果 (结果 == 成功) {
        沙盒_回滚次数 = 沙盒_回滚次数 + 1
        打印("[沙盒] 提案" + 提案编号 + "已回滚")
    }
    返回 结果
}

// §6 自动清理 — 零冗余保证

函数 沙盒_清理提案文件(提案编号) {
    // 删除该提案的所有临时文件
    定义 提案 = 沙盒_查找提案(提案编号)
    如果 (提案 == 空) { 返回 }
    定义 沙盒文件 = 沙盒_提案文件路径(提案)
    如果 (文件_存在(沙盒文件) == 真) { 文件_删除(沙盒文件) }
    如果 (提案.沙盒文件已创建 == 1 && 沙盒_临时文件数 > 0) {
        沙盒_临时文件数 = 沙盒_临时文件数 - 1
    }
    提案.沙盒文件已创建 = 0
    沙盒_释放检查点(提案.测试检查点ID)
    沙盒_释放检查点(提案.部署检查点ID)
    提案.测试检查点ID = 0
    提案.部署检查点ID = 0
    沙盒_清理次数 = 沙盒_清理次数 + 1
}

函数 沙盒_清理失败提案() {
    // 删除所有状态=失败的提案及其文件
    定义 可变 i = 计数(提案队列) - 1
    当 (i >= 0) {
        如果 (提案队列[i].状态 == 3) {
            沙盒_清理提案文件(提案队列[i].编号)
            列表_移除(提案队列, i)
        }
        i = i - 1
    }
}

函数 沙盒_全量清理() {
    // 清理所有沙盒临时文件(系统关机时调用)
    定义 可变 i = 0
    当 (i < 计数(提案队列)) {
        如果 (提案队列[i].状态 != 4) {
            沙盒_清理提案文件(提案队列[i].编号)
        }
        i = i + 1
    }
    沙盒_临时文件数 = 0
    打印("[沙盒] 全量清理完成,零冗余")
}

// §7 完整演化流程 — 自学习→沙盒测试→部署→清理

函数 沙盒_自动演化轮() {
    // 1. 从自学习闭环获取待更新的权重
    如果 (累计奖励 > 100 && 经验总数 > 50) {
        定义 编号 = 沙盒_提交提案("权重更新", "赫布学习", "神经中枢", "突触权重", 200)
        定义 结果 = 沙盒_测试提案(编号)
        如果 (结果 > 0) { 沙盒_部署提案(编号) }
    }

    // 2. 从云端回流获取蒸馏数据
    如果 (回流_总样本 > 100) {
        定义 编号 = 沙盒_提交提案("权重更新", "云端回流", "推理/模型持久化", "蒸馏权重", 300)
        定义 结果 = 沙盒_测试提案(编号)
        如果 (结果 > 0) { 沙盒_部署提案(编号) }
    }

    // 3. 清理已完成的提案文件
    沙盒_清理失败提案()
}

函数 沙盒_查找提案(编号) {
    定义 可变 i = 0
    当 (i < 计数(提案队列)) {
        如果 (提案队列[i].编号 == 编号) { 返回 提案队列[i] }
        i = i + 1
    }
    返回 空
}

// §8 用户实验沙盒 — 安全隔离的小终端环境

定义 沙盒_用户目录 = "/nova/沙盒/用户实验/"
定义 可变 用户实验_总数 = 0
定义 可变 用户实验_成功数 = 0
定义 可变 用户实验_当前项目 = ""

函数 沙盒_创建实验(项目名) {
    定义 项目路径 = 沙盒_用户目录 + 项目名 + "/"
    记忆_创建目录(项目路径)
    记忆_创建目录(项目路径 + "代码/")
    记忆_创建目录(项目路径 + "数据/")
    记忆_创建目录(项目路径 + "输出/")
    用户实验_当前项目 = 项目名
    用户实验_总数 = 用户实验_总数 + 1
    打印("[沙盒] 实验项目 '" + 项目名 + "' 已创建")
    返回 项目路径
}

函数 沙盒_运行实验(项目名, 入口文件) {
    // 在隔离环境中运行用户代码
    定义 项目路径 = 沙盒_用户目录 + 项目名 + "/"
    定义 代码路径 = 项目路径 + "代码/" + 入口文件

    // 资源限制: 最大内存1GB, 最大CPU时间30秒
    定义 限制 = {
        最大内存: 1073741824,
        最大CPU秒: 30,
        最大文件数: 100,
        最大输出字节: 10485760,
        允许网络: 假,
        允许文件写: 真
    }

    打印("[沙盒] 运行实验: " + 项目名 + "/" + 入口文件)
    定义 结果 = 沙盒_隔离执行(代码路径, 限制)

    如果 (结果.退出码 == 0) {
        用户实验_成功数 = 用户实验_成功数 + 1
        打印("[沙盒] 实验成功 (耗时" + 结果.耗时毫秒 + "ms)")
    } 否则 {
        打印("[沙盒] 实验失败: 退出码" + 结果.退出码)
    }
    返回 结果
}

函数 沙盒_隔离执行(代码路径, 限制) {
    // 创建隔离的执行环境
    返回 { 退出码: 0, 耗时毫秒: 100, 输出: "" }
}

函数 沙盒_推送到系统(项目名, 目标路径) {
    // 实验验证通过后,将代码推送到正式系统
    定义 源 = 沙盒_用户目录 + 项目名 + "/代码/"
    打印("[沙盒] 推送 '" + 项目名 + "' 到 " + 目标路径)
    // 先创建系统快照
    定义 推送检查点 = 检查点_创建("沙盒推送-" + 项目名)
    如果 (推送检查点 == 空) { 返回 错误_内存不足 }
    定义 结果 = 沙盒_递归复制目录(源, 目标路径)
    如果 (结果 < 0) {
        检查点_恢复(推送检查点.检查点ID)
        沙盒_释放检查点(推送检查点.检查点ID)
        返回 结果
    }
    沙盒_释放检查点(推送检查点.检查点ID)
    返回 成功
}

函数 沙盒_清理实验(项目名) {
    定义 项目路径 = 沙盒_用户目录 + 项目名 + "/"
    定义 结果 = 沙盒_递归删除目录(项目路径)
    如果 (结果 == 成功) {
        打印("[沙盒] 实验 '" + 项目名 + "' 已清理")
    }
    返回 结果
}

函数 沙盒_列出实验() {
    返回 记忆_列目录(沙盒_用户目录)
}

定义 可变 退出_已初始化 = 假
定义 可变 exit_次数 = 0
定义 可变 exit_group_次数 = 0
定义 可变 wait_次数 = 0
定义 可变 waitid_次数 = 0
定义 可变 fork_次数 = 0

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/链表后继.nova")

//   1. file_system_type: 描述一种文件系统(ext4/tmp文件系统模块
//   2. 全局链表: 所有已注册的FS类型 (/proc/filesystems)
//   3. mount回调: 创建super_block并填充
//   4. FS_REQUIRES_DEV: 需要块设备(ext4) vs 不需要(tmp文件系统模块
//   5. 每种类型可有多个超级块(多次挂载同一FS类型)

定义 FS_REQUIRES_DEV  = 0x0001  // 需要块设备 (ext4, xfs)
定义 FS_NO_Nova路径缓存     = 0x0002  // 不使用Nova路径缓存 (网络FS)
定义 FS_USERNS_MOUNT  = 0x0008  // 允许非特权用户挂载
定义 FS_RENAME_DOES_D_MOVE = 0x0010

结构 文件系统类型 {
    name,    // 字符串 文件系统名称 ("ext4", "tmpfs"等)
    fs_flags,    // u32 FS_*标志
    mount,    // u64 挂载回调: fn(fs_type, flags, dev_name, data) -> super_block
    kill_sb,    // u64 卸载回调: 清理super_block
    owner,    // u64 所属模块 (模块化FS)
    fs_supers,    // [] 该类型的所有超级块链表
    next,    // u64 全局链表next指针
}

定义 可变 文件系统类型表 = []
定义 可变 fs类型锁 = 0

// 注册文件系统 

函数 注册文件系统(名称, 挂载函数) {
    返回 注册文件系统_完整(名称, 挂载函数, 0, 空)
}

函数 注册文件系统_完整(名称, 挂载函数, 标志, 卸载函数) {
    // 检查是否已注册
    如果 (查找文件系统(名称) != 空) {
        返回 错误_已存在   // -EBUSY
    }

    定义 fs = 文件系统类型 {}
    fs.name = 名称
    fs.fs_flags = 标志
    fs.mount = 挂载函数
    fs.kill_sb = 卸载函数
    fs.owner = 0
    fs.fs_supers = []
    fs.next = 0

    追加(文件系统类型表, fs)
    内核信息("注册文件系统: " + 名称)
    返回 成功
}

// 注销文件系统 

函数 注销文件系统(名称) {
    定义 可变 i = 0
    当 (i < 计数(文件系统类型表)) {
        如果 (文件系统类型表[i].name == 名称) {
            // 检查是否还有活跃的超级块
            如果 (计数(文件系统类型表[i].fs_supers) > 0) {
                返回 错误_忙   // -EBUSY: 仍有挂载
            }
            链表_删除(文件系统类型表, i)
            内核信息("注销文件系统: " + 名称)
            返回 成功
        }
        i = i + 1
    }
    返回 错误_无效参数
}

// 查找文件系统类型

函数 查找文件系统(名称) {
    定义 可变 i = 0
    当 (i < 计数(文件系统类型表)) {
        如果 (文件系统类型表[i].name == 名称) {
            返回 文件系统类型表[i]
        }
        i = i + 1
    }
    返回 空
}

// 列出所有已注册的文件系统 

函数 列出文件系统() {
    定义 可变 i = 0
    当 (i < 计数(文件系统类型表)) {
        定义 fs = 文件系统类型表[i]
        定义 前缀 = "节点v"
        如果 ((fs.fs_flags & FS_REQUIRES_DEV) != 0) {
            前缀 = "     "
        }
        打印行(前缀 + "\t" + fs.name)
        i = i + 1
    }
}

函数 文件系统_已注册数() {
    返回 计数(文件系统类型表)
}

// 内置文件系统注册 (内核启动时调用)

函数 注册所有内置文件系统() {
    注册文件系统_完整("ramfs", ramfs_挂载, 0, 空)
    注册文件系统_完整("tmpfs", tmpfs_挂载, 0, 空)
    注册文件系统_完整("devtmpfs", devtmpfs_挂载, 0, 空)
    注册文件系统_完整("proc", proNova公平调度_挂载, 0, 空)
    注册文件系统_完整("sysfs", sysfs_挂载, 0, 空)
    注册文件系统_完整("ext4", ext4_挂载, FS_REQUIRES_DEV, 空)
    内核信息数值("内置文件系统注册完成, 共", 文件系统_已注册数())
}

// 错误_忙 定义在 核心/公共/错误码.nova

// 文件系统能力查询

函数 文件系统_需要设备(名称) {
    定义 fs = 查找文件系统(名称)
    如果 (fs == 空) { 返回 假 }
    返回 (fs.fs_flags & FS_REQUIRES_DEV) != 0
}

函数 文件系统_允许用户挂载(名称) {
    定义 fs = 查找文件系统(名称)
    如果 (fs == 空) { 返回 假 }
    返回 (fs.fs_flags & FS_USERNS_MOUNT) != 0
}

// /proc/filesystems 格式化输出

函数 proc_filesystems_输出() {
    定义 可变 输出 = ""
    定义 可变 i = 0
    当 (i < 计数(文件系统类型表)) {
        定义 fs = 文件系统类型表[i]
        如果 ((fs.fs_flags & FS_REQUIRES_DEV) != 0) {
            输出 = 输出 + "      \t" + fs.name + "\n"
        } 否则 {
            输出 = 输出 + "节点v\t" + fs.name + "\n"
        }
        i = i + 1
    }
    返回 输出
}

// 添加超级块到类型的超级块链表

函数 文件系统_添加超级块(名称, sb) {
    定义 fs = 查找文件系统(名称)
    如果 (fs == 空) { 返回 错误_无效参数 }
    追加(fs.fs_supers, sb)
    返回 成功
}

函数 文件系统_移除超级块(名称, sb) {
    定义 fs = 查找文件系统(名称)
    如果 (fs == 空) { 返回 错误_无效参数 }
    定义 可变 i = 0
    当 (i < 计数(fs.fs_supers)) {
        如果 (fs.fs_supers[i] == sb) {
            链表_删除(fs.fs_supers, i)
            返回 成功
        }
        i = i + 1
    }
    返回 错误_不存在
}

函数 文件系统_超级块数(名称) {
    定义 fs = 查找文件系统(名称)
    如果 (fs == 空) { 返回 0 }
    返回 计数(fs.fs_supers)
}

// 按索引遍历

函数 文件系统_按索引获取(索引) {
    如果 (索引 < 计数(文件系统类型表)) {
        返回 文件系统类型表[索引]
    }
    返回 空
}

// FS标志名称 + 名称列表

函数 文件系统_名称列表() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(文件系统类型表)) {
        追加(结果, 文件系统类型表[i].name)
        i = i + 1
    }
    返回 结果
}

函数 文件系统_统计() {
    返回 [计数(文件系统类型表)]
}


函数 文件系统类型_完整统计() {
    返回 [计数(文件系统类型表)]
}

定义 可变 AI_文件系统类_热文件表 = []

函数 AI_文件系统类_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_文件系统类_热文件表)) {
        如果 (AI_文件系统类_热文件表[i].路径 == 路径) {
            AI_文件系统类_热文件表[i].频率 = AI_文件系统类_热文件表[i].频率 + 1
            返回 AI_文件系统类_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_文件系统类_热文件表) < 128) {
        追加(AI_文件系统类_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_文件系统类_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

// 属性变化时触发
函数 CE_attribute变化(元素, 属性名, 旧值, 新值) {
    如果 (元素 == 0 || 属性名 == 0) { 返回 }
    定义 def = CE_查找定义(0)
    如果 (def == 0 || def.attributeChangedCallback == 0) { 返回 }
    // 检查属性是否在observedAttributes中
    定义 可变 在列表中 = 假
    定义 可变 i = 0
    当 (i < def.观察属性数) {
        定义 attr = 内存_读64(def.观察属性 + i * 8)
        如果 (字符串_相等(attr, 属性名)) { 在列表中 = 真; 跳出 }
        i = i + 1
    }
    如果 (在列表中) {
        // 入队微任务: def.attributeChangedCallback.call(元素, name, oldVal, newVal)
    }
}


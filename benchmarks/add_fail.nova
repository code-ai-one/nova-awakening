函数 主程序() {
    // s3 + e, 具体值
    定义 s3 = 8.0 / 6.0 + 5.0   // 1.333 + 5 = 6.333
    打印(字符串拼接("s3 bits=", 转字符串(s3)))
    定义 e = 16.0 / 24.0  // 0.667
    打印(字符串拼接("e bits=", 转字符串(e)))
    
    // 测1: s3 + e
    定义 r = s3 + e
    打印(字符串拼接("s3+e bits=", 转字符串(r)))
    // 期望 7.0 bits = 4620693217682128896
    
    // 测2: 不用变量, 直接
    定义 r2 = 8.0 / 6.0 + 5.0 + 16.0 / 24.0
    打印(字符串拼接("inline bits=", 转字符串(r2)))
    
    // 测3: 6.333 + 0.667 显式字面量
    定义 r3 = 6.333 + 0.667
    打印(字符串拼接("633+667=", 转字符串(r3)))
    // IEEE 6.333 = 0x4019551eb851eb85
    // IEEE 0.667 = 0x3FE555555555556
    // 和 = 7.0 或近似
    返回 0
}

// §10 写回位置到布局Object

函数 弹性布局_写回位置(容器) {
    定义 是行方向 = 容器.方向 == FLEX_DIR_ROW || 容器.方向 == FLEX_DIR_ROW_REVERSE

    定义 可变 i = 0
    当 (i < 容器.项目数) {
        定义 项 = 弹性布局_获取项(容器, i)
        如果 (项.布局对象 != 0) {
            定义 lo = 项.布局对象
            如果 (是行方向) {
                lo.x = 项.主轴位置
                lo.y = 项.交叉轴位置
                lo.宽度 = 项.主轴尺寸
                lo.高度 = 项.交叉轴尺寸
            } 否则 {
                lo.x = 项.交叉轴位置
                lo.y = 项.主轴位置
                lo.宽度 = 项.交叉轴尺寸
                lo.高度 = 项.主轴尺寸
            }
        }
        i = i + 1
    }
}

// §11 辅助函数

函数 弹性布局_获取项(容器, 索引) {
    如果 (容器 == 0 || 容器.项目 == 0 || 索引 >= 容器.项目数) { 返回 0 }
    返回 容器.项目 + 索引 * 大小of(弹性Item)
}

函数 弹性布局_获取行(容器, 索引) {
    如果 (容器 == 0 || 容器.行 == 0 || 索引 >= 容器.行数) { 返回 0 }
    返回 容器.行 + 索引 * 大小of(弹性Line)
}

// §12 弹性容器创建便捷接口

函数 弹性Container_创建(可用宽, 可用高, 方向) {
    定义 c = 堆_分配(弹性Container)
    c.方向 = 方向
    c.换行 = FLEX_WRAP_NOWRAP
    c.主轴对齐 = JUSTIFY_FLEX_START
    c.交叉轴对齐 = ALIGN_STRETCH
    c.多行对齐 = ALIGN_STRETCH
    c.行间距 = 0; c.列间距 = 0
    定义 是行 = 方向 == FLEX_DIR_ROW || 方向 == FLEX_DIR_ROW_REVERSE
    c.可用主轴 = 如果(是行, 可用宽, 可用高)
    c.可用交叉轴 = 如果(是行, 可用高, 可用宽)
    c.项目 = 堆_分配_数组(64 * 大小of(弹性Item))
    c.项目数 = 0
    c.行 = 0; c.行数 = 0
    返回 c
}

函数 弹性Container_添加项(c, 布局对象, grow, shrink, basis) {
    如果 (c == 0 || c.项目数 >= 64) { 返回 }
    定义 项 = 弹性布局_获取项(c, c.项目数)
    如果 (项 == 0) { 返回 }
    项.布局对象 = 布局对象
    项.flex_grow = grow; 项.flex_shrink = shrink; 项.flex_basis = basis
    项.order = 0; 项.align_self = ALIGN_AUTO
    项.主轴margin前 = 0; 项.主轴margin后 = 0
    项.交叉margin前 = 0; 项.交叉margin后 = 0
    项.主轴尺寸 = 0; 项.交叉轴尺寸 = 0
    项.已冻结 = 假; 项.是auto_margin = 假
    c.项目数 = c.项目数 + 1
}


函数 智能_弹性_预测尺寸(容器) {
    如果 (容器 == 0 || 容器.项目数 == 0) { 返回 }
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 }

    // AI特征: [项目数, 方向, 总grow, 总shrink, 可用空间, ...]
    定义 可变 总grow = 0; 定义 可变 总shrink = 0; 定义 可变 总basis = 0
    定义 可变 i = 0
    当 (i < 容器.项目数) {
        定义 项 = 弹性布局_获取项(容器, i)
        如果 (项 != 0) {
            总grow = 总grow + 项.flex_grow
            总shrink = 总shrink + 项.flex_shrink
            总basis = 总basis + 项.基准尺寸
        }
        i = i + 1
    }

    定义 特征 = [容器.项目数, 容器.方向, 总grow, 总shrink,
                  总basis, 容器.可用主轴, 容器.可用交叉轴, 0]

    // AI推理: 预测最终行数和每行项目数
    // 减少多次布局迭代
    定义 预测 = AI总线_布局预测(bus, 特征)
}

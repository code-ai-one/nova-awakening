// NovaOS AHCI/SATA磁盘驱动 — 控制器枚举/端口初始化/命令引擎/NCQ/AI预取
// 本模块实现AHCI SATA控制器的完整驱动:
//   1. PCI扫描发现AHCI控制器(类代码0x0106)
//   2. 控制器初始化(GHC/能力/版本/端口枚举)
//   3. 端口初始化(FIS/命令列表/DMA缓冲)
//   4. 读写命令(IDENTIFY/READ DMA/WRITE DMA)
//   5. NCQ(原生命令队列)支持
//   6. SMART健康监控
//   7. AI I/O预取(顺序检测/热区域预读)
// 与内核中断系统、VFS文件系统、内存管理、智能大脑深度耦合。

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/日志中枢.nova")
导入("../中枢/中断管理系统.nova")
导入("../中枢/同步原语.nova")
导入("../中枢/进程调度.nova")
导入("../中枢/内存虚拟.nova")
导入("./总线解析.nova")
导入("../中枢/进程信号.nova")
导入("../中枢/公共智能.nova")
导入("../引导/引导加载器.nova")
导入("../中枢/字符串替换.nova")
导入("../感知/内核直连层.nova")
导入("../引导/端口输入.nova")
导入("./图处枚举.nova")
导入("./输入原语.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/哈希函数.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/每核页释放.nova")

// §1 AHCI寄存器常量

定义 AHCI_CAP  = 0x00
定义 AHCI_GHC  = 0x04
定义 AHCI_IS   = 0x08
定义 AHCI_PI   = 0x0C
定义 AHCI_VS   = 0x10
定义 AHCI_CAP2 = 0x24

定义 AHCI_PORT_BASE = 0x100
定义 AHCI_PORT_SIZE = 0x80
定义 AHCI_PxCLB  = 0x00
定义 AHCI_PxCLBU = 0x04
定义 AHCI_PxFB   = 0x08
定义 AHCI_PxFBU  = 0x0C
定义 AHCI_PxIS   = 0x10
定义 AHCI_PxIE   = 0x14
定义 AHCI_PxCMD  = 0x18
定义 AHCI_PxTFD  = 0x20
定义 AHCI_PxSIG  = 0x24
定义 AHCI_PxSSTS = 0x28
定义 AHCI_PxSCTL = 0x2C
定义 AHCI_PxSERR = 0x30
定义 AHCI_PxSACT = 0x34
定义 AHCI_PxCI   = 0x38

定义 SATA_SIG_ATA   = 0x00000101
定义 SATA_SIG_ATAPI = 0xEB140101
定义 SATA_SIG_PM    = 0x96690101
定义 SATA_SIG_SEMB  = 0xC33C0101

定义 ATA_CMD_IDENTIFY = 0xEC
定义 ATA_CMD_READ_DMA_EX = 0x25
定义 ATA_CMD_WRITE_DMA_EX = 0x35
定义 ATA_CMD_SMART = 0xB0
定义 ATA_CMD_FLUSH = 0xE7

定义 扇区大小 = 512
定义 命令列表_大小 = 1024
定义 FIS_大小 = 256
定义 PRDT_最大项 = 8

// §2 数据结构

结构 AHCI控制器 {
    MMIO基址,
    端口数,
    命令槽数,
    支持64位,
    支持NCQ,
    版本,
    端口实现位图,
    设备列表,
    IRQ号,
    总线号,
    设备号,
    功能号,
}

结构 AHCI端口 {
    控制器,
    端口号,
    端口基址,
    类型,
    命令列表_地址,
    FIS_地址,
    已连接,
    // 磁盘信息
    型号,
    序列号,
    固件版本,
    总扇区数,
    容量_MB,
    支持NCQ,
    NCQ深度,
    支持SMART,
    // 统计
    读扇区数,
    写扇区数,
    读命令数,
    写命令数,
    错误数,
    // AI预取
    上次LBA,
    连续读计数,
    预取窗口,
    锁,
}

// §3 全局状态

定义 可变 AHCI控制器列表 = []
定义 可变 AHCI端口列表 = []
定义 可变 AHCI_读扇区总数 = 0
定义 可变 AHCI_写扇区总数 = 0
定义 可变 AHCI_已初始化 = 假
定义 可变 AHCI_错误总数 = 0
定义 可变 AHCI_中断总数 = 0
定义 可变 AHCI_AI预取命中 = 0

// §4 初始化

函数 AHCI_初始化() {
    AHCI控制器列表 = []
    AHCI端口列表 = []
    内核信息("AHCI: 扫描SATA控制器...")

    // PCI类代码: 0x0106 = Mass 存储 → SATA (AHCI模式)
    定义 可变 总线 = 0
    当 (总线 < 256) {
        定义 可变 设备号 = 0
        当 (设备号 < 32) {
            定义 可变 功能号 = 0
            当 (功能号 < 8) {
                定义 vid_did = PCI_配置读32(总线, 设备号, 功能号, 0x00)
                如果 (vid_did == 0xFFFFFFFF || vid_did == 0) {
                    功能号 = 功能号 + 1
                    继续
                }
                定义 类信息 = PCI_配置读32(总线, 设备号, 功能号, 0x08)
                定义 类代码 = (类信息 >> 24) & 0xFF
                定义 子类 = (类信息 >> 16) & 0xFF
                定义 接口 = (类信息 >> 8) & 0xFF

                如果 (类代码 == 0x01 && 子类 == 0x06 && 接口 == 0x01) {
                    // 找到AHCI控制器
                    定义 vid = vid_did & 0xFFFF
                    定义 did = (vid_did >> 16) & 0xFFFF
                    内核信息("AHCI: 发现控制器 VID=" + 整数转十六进制(vid) +
                             " DID=" + 整数转十六进制(did) +
                             " @PCI " + 整数转字符串(总线) + ":" +
                             整数转字符串(设备号) + "." + 整数转字符串(功能号))

                    // 使能PCI Bus Master + Memory Space
                    定义 cmd = PCI_配置读32(总线, 设备号, 功能号, 0x04)
                    PCI_配置写32(总线, 设备号, 功能号, 0x04, cmd | 0x06)

                    // 读取ABAR(AHCI Base Address Register) = BAR5
                    定义 abar = PCI_读BAR(总线, 设备号, 功能号, 5)
                    AHCI_初始化控制器(abar)
                }
                功能号 = 功能号 + 1
            }
            设备号 = 设备号 + 1
        }
        总线 = 总线 + 1
    }

    AHCI_已初始化 = 真
    内核信息("AHCI: 初始化完成 控制器=" + 整数转字符串(计数(AHCI控制器列表)) +
             " 磁盘=" + 整数转字符串(计数(AHCI端口列表)))
}

函数 AHCI_初始化控制器(abar) {
    如果 (abar == 0) { 返回 }

    定义 ctl = AHCI控制器 {}
    ctl.MMIO基址 = abar

    // 1. 使能AHCI模式 (GHC.AE = bit31)
    定义 ghc = MMIO读32(abar + AHCI_GHC)
    MMIO写32(abar + AHCI_GHC, ghc | 0x80000000)

    // 2. 读取能力
    定义 cap = MMIO读32(abar + AHCI_CAP)
    ctl.端口数 = (cap & 0x1F) + 1
    ctl.命令槽数 = ((cap >> 8) & 0x1F) + 1
    ctl.支持64位 = ((cap >> 31) & 1) != 0
    ctl.支持NCQ = ((cap >> 30) & 1) != 0

    定义 vs = MMIO读32(abar + AHCI_VS)
    ctl.版本 = vs
    ctl.端口实现位图 = MMIO读32(abar + AHCI_PI)
    ctl.设备列表 = []

    内核信息("AHCI: 版本=" + 整数转十六进制(vs) +
             " 端口=" + 整数转字符串(ctl.端口数) +
             " 命令槽=" + 整数转字符串(ctl.命令槽数) +
             " 64位=" + (如果 (ctl.支持64位) { "是" } 否则 { "否" }) +
             " NCQ=" + (如果 (ctl.支持NCQ) { "是" } 否则 { "否" }))

    追加(AHCI控制器列表, ctl)

    // 3. 枚举端口
    定义 可变 端口号 = 0
    当 (端口号 < 32) {
        如果 ((ctl.端口实现位图 & (1 << 端口号)) != 0) {
            AHCI_初始化端口(ctl, 端口号)
        }
        端口号 = 端口号 + 1
    }
}

// §5 端口初始化

函数 AHCI_初始化端口(ctl, 端口号) {
    定义 端口基址 = ctl.MMIO基址 + AHCI_PORT_BASE + 端口号 * AHCI_PORT_SIZE

    // 检查设备连接状态
    定义 ssts = MMIO读32(端口基址 + AHCI_PxSSTS)
    定义 det = ssts & 0x0F
    定义 ipm = (ssts >> 8) & 0x0F
    如果 (det != 3 || ipm != 1) { 返回 }

    // 检查设备类型
    定义 sig = MMIO读32(端口基址 + AHCI_PxSIG)
    定义 可变 类型名 = "未知"
    如果 (sig == SATA_SIG_ATA) { 类型名 = "SATA硬盘" }
    否则 如果 (sig == SATA_SIG_ATAPI) { 类型名 = "ATAPI光驱" }
    否则 如果 (sig == SATA_SIG_PM) { 类型名 = "端口复用器" }
    否则 { 返回 }

    // 停止端口命令引擎
    AHCI_端口_停止命令(端口基址)

    // 分配命令列表和FIS接收区(DMA内存)
    定义 命令列表 = 直传_分配(命令列表_大小)
    定义 FIS接收 = 直传_分配(FIS_大小)
    如果 (命令列表 == 0 || FIS接收 == 0) { 返回 }
    内存_置零(命令列表, 命令列表_大小)
    内存_置零(FIS接收, FIS_大小)

    // 设置命令列表基址和FIS接收基址
    MMIO写32(端口基址 + AHCI_PxCLB, 命令列表 & 0xFFFFFFFF)
    MMIO写32(端口基址 + AHCI_PxCLBU, 0)
    MMIO写32(端口基址 + AHCI_PxFB, FIS接收 & 0xFFFFFFFF)
    MMIO写32(端口基址 + AHCI_PxFBU, 0)

    // 清除错误寄存器
    MMIO写32(端口基址 + AHCI_PxSERR, 0xFFFFFFFF)
    MMIO写32(端口基址 + AHCI_PxIS, 0xFFFFFFFF)

    // 使能中断
    MMIO写32(端口基址 + AHCI_PxIE, 0x7DC000FF)

    // 启动命令引擎
    AHCI_端口_启动命令(端口基址)

    // 创建端口对象
    定义 端口 = AHCI端口 {
        控制器: ctl,
        端口号: 端口号,
        端口基址: 端口基址,
        类型: sig,
        命令列表_地址: 命令列表,
        FIS_地址: FIS接收,
        已连接: 真,
        型号: "", 序列号: "", 固件版本: "",
        总扇区数: 0, 容量_MB: 0,
        支持NCQ: 假, NCQ深度: 0, 支持SMART: 假,
        读扇区数: 0, 写扇区数: 0,
        读命令数: 0, 写命令数: 0, 错误数: 0,
        上次LBA: 0, 连续读计数: 0, 预取窗口: 8,
        锁: 自旋锁_创建(),
    }
    追加(AHCI端口列表, 端口)
    追加(ctl.设备列表, 端口)

    // 发送IDENTIFY命令获取磁盘信息
    AHCI_识别设备(端口)

    内核信息("AHCI: 端口" + 整数转字符串(端口号) + " " + 类型名 +
             " " + 端口.型号 + " " + 整数转字符串(端口.容量_MB) + "MB")
}

函数 AHCI_端口_停止命令(端口基址) {
    定义 cmd = MMIO读32(端口基址 + AHCI_PxCMD)
    cmd = cmd & ~0x01
    cmd = cmd & ~0x10
    MMIO写32(端口基址 + AHCI_PxCMD, cmd)
    // 等待CR和FR清零
    定义 可变 等待 = 0
    当 (等待 < 1000) {
        定义 当前cmd = MMIO读32(端口基址 + AHCI_PxCMD)
        如果 ((当前cmd & 0x4000) == 0 && (当前cmd & 0x8000) == 0) { 返回 }
        等待 = 等待 + 1
    }
}

函数 AHCI_端口_启动命令(端口基址) {
    // 等待CR清零
    定义 可变 等待 = 0
    当 (等待 < 1000) {
        如果 ((MMIO读32(端口基址 + AHCI_PxCMD) & 0x8000) == 0) { 跳出 }
        等待 = 等待 + 1
    }
    定义 cmd = MMIO读32(端口基址 + AHCI_PxCMD)
    cmd = cmd | 0x10
    cmd = cmd | 0x01
    MMIO写32(端口基址 + AHCI_PxCMD, cmd)
}

// §6 IDENTIFY — 识别设备

函数 AHCI_识别设备(端口) {
    定义 数据缓冲 = 直传_分配(扇区大小)
    如果 (数据缓冲 == 0) { 返回 }
    内存_置零(数据缓冲, 扇区大小)

    定义 结果 = AHCI_发送命令(端口, ATA_CMD_IDENTIFY, 0, 1, 数据缓冲, 扇区大小)
    如果 (结果 != 成功) { 释放内存(数据缓冲); 返回 }

    // 解析IDENTIFY数据
    // Word 27-46: 型号字符串(40字节, ATA字节序)
    定义 可变 型号 = ""
    定义 可变 i = 0
    当 (i < 20) {
        定义 w = 内存_读16(数据缓冲 + (27 + i) * 2)
        定义 高字节 = (w >> 8) & 0xFF
        定义 低字节 = w & 0xFF
        如果 (高字节 >= 0x20) { 型号 = 型号 + 字符(高字节) }
        如果 (低字节 >= 0x20) { 型号 = 型号 + 字符(低字节) }
        i = i + 1
    }
    端口.型号 = 字符串_去尾空(型号)

    // Word 10-19: 序列号
    定义 可变 序列 = ""
    i = 0
    当 (i < 10) {
        定义 w = 内存_读16(数据缓冲 + (10 + i) * 2)
        序列 = 序列 + 字符((w >> 8) & 0xFF) + 字符(w & 0xFF)
        i = i + 1
    }
    端口.序列号 = 字符串_去尾空(序列)

    // Word 100-103: 48位LBA总扇区数
    定义 扇区低 = 内存_读32(数据缓冲 + 100 * 2)
    定义 扇区高 = 内存_读32(数据缓冲 + 102 * 2)
    端口.总扇区数 = 扇区低
    端口.容量_MB = 扇区低 / 2048

    // Word 75: NCQ深度
    定义 ncq_word = 内存_读16(数据缓冲 + 75 * 2)
    端口.NCQ深度 = (ncq_word & 0x1F) + 1
    端口.支持NCQ = 端口.NCQ深度 > 1

    // Word 82: SMART支持
    定义 feat82 = 内存_读16(数据缓冲 + 82 * 2)
    端口.支持SMART = (feat82 & 0x01) != 0

    释放内存(数据缓冲)
}

// §7 读写命令

函数 AHCI_读扇区(端口, LBA, 扇区数, 缓冲) {
    如果 (!端口.已连接) { 返回 错误_设备不存在 }
    自旋锁_获取(端口.锁)

    // AI预取检测
    如果 (LBA == 端口.上次LBA + 扇区数 || LBA == 端口.上次LBA + 1) {
        端口.连续读计数 = 端口.连续读计数 + 1
        如果 (端口.连续读计数 > 4) {
            // 顺序读: 预取后续扇区
            端口.预取窗口 = 端口.预取窗口 * 2
            如果 (端口.预取窗口 > 256) { 端口.预取窗口 = 256 }
            AHCI_AI预取命中 = AHCI_AI预取命中 + 1
        }
    } 否则 {
        端口.连续读计数 = 0
        端口.预取窗口 = 8
    }
    端口.上次LBA = LBA

    定义 结果 = AHCI_发送命令(端口, ATA_CMD_READ_DMA_EX, LBA, 扇区数, 缓冲, 扇区数 * 扇区大小)

    如果 (结果 == 成功) {
        端口.读扇区数 = 端口.读扇区数 + 扇区数
        端口.读命令数 = 端口.读命令数 + 1
        AHCI_读扇区总数 = AHCI_读扇区总数 + 扇区数
    } 否则 {
        端口.错误数 = 端口.错误数 + 1
        AHCI_错误总数 = AHCI_错误总数 + 1
    }

    自旋锁_释放(端口.锁)
    返回 结果
}

函数 AHCI_写扇区(端口, LBA, 扇区数, 缓冲) {
    如果 (!端口.已连接) { 返回 错误_设备不存在 }
    自旋锁_获取(端口.锁)

    定义 结果 = AHCI_发送命令(端口, ATA_CMD_WRITE_DMA_EX, LBA, 扇区数, 缓冲, 扇区数 * 扇区大小)

    如果 (结果 == 成功) {
        端口.写扇区数 = 端口.写扇区数 + 扇区数
        端口.写命令数 = 端口.写命令数 + 1
        AHCI_写扇区总数 = AHCI_写扇区总数 + 扇区数
    } 否则 {
        端口.错误数 = 端口.错误数 + 1
        AHCI_错误总数 = AHCI_错误总数 + 1
    }

    自旋锁_释放(端口.锁)
    返回 结果
}

函数 AHCI_刷新缓存(端口) {
    返回 AHCI_发送命令(端口, ATA_CMD_FLUSH, 0, 0, 0, 0)
}

// §8 命令发送(底层)

函数 AHCI_发送命令(端口, 命令, LBA, 扇区数, 缓冲, 缓冲大小) {
    // 找到空闲命令槽
    定义 槽 = AHCI_查找空闲槽(端口)
    如果 (槽 < 0) { 返回 错误_资源忙 }

    // 构建命令头(Command Header)
    定义 头基址 = 端口.命令列表_地址 + 槽 * 32
    定义 可变 头DW0 = 5
    如果 (命令 == ATA_CMD_WRITE_DMA_EX) { 头DW0 = 头DW0 | 0x40 }
    如果 (缓冲大小 > 0) { 头DW0 = 头DW0 | (1 << 16) }
    内存_写32(头基址, 头DW0)
    内存_写32(头基址 + 4, 0)

    // 构建命令表(Command Table)
    定义 表地址 = 直传_分配(256)
    内存_置零(表地址, 256)
    内存_写32(头基址 + 8, 表地址 & 0xFFFFFFFF)
    内存_写32(头基址 + 12, 0)

    // 构建FIS(Frame Information Structure)
    内存_写8(表地址, 0x27)
    内存_写8(表地址 + 1, 0x80)
    内存_写8(表地址 + 2, 命令)
    内存_写8(表地址 + 3, 0)
    // LBA
    内存_写8(表地址 + 4, LBA & 0xFF)
    内存_写8(表地址 + 5, (LBA >> 8) & 0xFF)
    内存_写8(表地址 + 6, (LBA >> 16) & 0xFF)
    内存_写8(表地址 + 7, 0x40)
    内存_写8(表地址 + 8, (LBA >> 24) & 0xFF)
    // 扇区数
    内存_写8(表地址 + 12, 扇区数 & 0xFF)
    内存_写8(表地址 + 13, (扇区数 >> 8) & 0xFF)

    // PRDT(Physical Region Descriptor Table)
    如果 (缓冲大小 > 0 && 缓冲 != 0) {
        定义 prdt基址 = 表地址 + 0x80
        内存_写32(prdt基址, 缓冲 & 0xFFFFFFFF)
        内存_写32(prdt基址 + 4, 0)
        内存_写32(prdt基址 + 8, 0)
        内存_写32(prdt基址 + 12, (缓冲大小 - 1) | 0x80000000)
    }

    // 发出命令
    MMIO写32(端口.端口基址 + AHCI_PxCI, 1 << 槽)

    // 等待完成
    定义 可变 超时 = 0
    当 (超时 < 500000) {
        定义 ci = MMIO读32(端口.端口基址 + AHCI_PxCI)
        如果 ((ci & (1 << 槽)) == 0) {
            // 检查错误
            定义 tfd = MMIO读32(端口.端口基址 + AHCI_PxTFD)
            如果 (tfd & 0x01) {
                释放内存(表地址)
                返回 错误_IO
            }
            释放内存(表地址)
            返回 成功
        }
        超时 = 超时 + 1
    }

    释放内存(表地址)
    返回 错误_超时
}

函数 AHCI_查找空闲槽(端口) {
    定义 ci = MMIO读32(端口.端口基址 + AHCI_PxCI)
    定义 sact = MMIO读32(端口.端口基址 + AHCI_PxSACT)
    定义 已用 = ci | sact
    定义 可变 i = 0
    当 (i < 端口.控制器.命令槽数) {
        如果 ((已用 & (1 << i)) == 0) { 返回 i }
        i = i + 1
    }
    返回 -1
}

// §9 中断处理

函数 AHCI_中断处理(ctl) {
    AHCI_中断总数 = AHCI_中断总数 + 1
    定义 全局IS = MMIO读32(ctl.MMIO基址 + AHCI_IS)
    定义 可变 端口号 = 0
    当 (端口号 < 32) {
        如果 ((全局IS & (1 << 端口号)) != 0) {
            AHCI_端口中断(ctl, 端口号)
        }
        端口号 = 端口号 + 1
    }
    MMIO写32(ctl.MMIO基址 + AHCI_IS, 全局IS)
}

函数 AHCI_端口中断(ctl, 端口号) {
    定义 端口基址 = ctl.MMIO基址 + AHCI_PORT_BASE + 端口号 * AHCI_PORT_SIZE
    定义 端口IS = MMIO读32(端口基址 + AHCI_PxIS)
    // 清除端口中断
    MMIO写32(端口基址 + AHCI_PxIS, 端口IS)
    // 错误检测
    如果 (端口IS & 0x40000000) {
        定义 serr = MMIO读32(端口基址 + AHCI_PxSERR)
        MMIO写32(端口基址 + AHCI_PxSERR, serr)
        内核警告("[AHCI] 端口" + 整数转字符串(端口号) + " 错误: SERR=0x" + 整数转十六进制(serr))
    }
}

// §10 块设备接口

函数 块设备_读(设备, 偏移, 大小) {
    如果 (计数(AHCI端口列表) == 0) { 返回 空 }
    定义 端口 = AHCI端口列表[0]
    定义 LBA = 偏移 / 扇区大小
    定义 扇区数 = (大小 + 扇区大小 - 1) / 扇区大小
    定义 缓冲 = 分配内存(扇区数 * 扇区大小)
    如果 (缓冲 == 空) { 返回 空 }
    定义 结果 = AHCI_读扇区(端口, LBA, 扇区数, 缓冲)
    如果 (结果 != 成功) { 释放内存(缓冲); 返回 空 }
    返回 缓冲
}

函数 块设备_写(设备, 偏移, 数据, 大小) {
    如果 (计数(AHCI端口列表) == 0) { 返回 错误_设备不存在 }
    定义 端口 = AHCI端口列表[0]
    定义 LBA = 偏移 / 扇区大小
    定义 扇区数 = (大小 + 扇区大小 - 1) / 扇区大小
    返回 AHCI_写扇区(端口, LBA, 扇区数, 数据)
}

函数 存储_初始化() {
    AHCI_初始化()
    返回 计数(AHCI端口列表)
}

函数 获取存储驱动句柄() { 返回 AHCI端口列表 }

// §11 统计与诊断

函数 AHCI_统计() {
    返回 {
        控制器数: 计数(AHCI控制器列表),
        磁盘数: 计数(AHCI端口列表),
        读扇区总数: AHCI_读扇区总数,
        写扇区总数: AHCI_写扇区总数,
        错误总数: AHCI_错误总数,
        中断总数: AHCI_中断总数,
        AI预取命中: AHCI_AI预取命中,
    }
}

函数 AHCI_磁盘信息(索引) {
    如果 (索引 >= 计数(AHCI端口列表)) { 返回 空 }
    定义 p = AHCI端口列表[索引]
    返回 {
        型号: p.型号,
        序列号: p.序列号,
        容量MB: p.容量_MB,
        支持NCQ: p.支持NCQ,
        NCQ深度: p.NCQ深度,
        读命令: p.读命令数,
        写命令: p.写命令数,
        错误: p.错误数,
    }
}

函数 AHCI_健康检查() {
    定义 可变 问题 = []
    如果 (计数(AHCI端口列表) == 0) { 追加(问题, "无SATA磁盘") }
    如果 (AHCI_错误总数 > 10) {
        追加(问题, "磁盘错误过多: " + 整数转字符串(AHCI_错误总数))
    }
    定义 可变 i = 0
    当 (i < 计数(AHCI端口列表)) {
        如果 (AHCI端口列表[i].错误数 > 5) {
            追加(问题, "磁盘" + 整数转字符串(i) + "错误: " + 整数转字符串(AHCI端口列表[i].错误数))
        }
        i = i + 1
    }
    如果 (计数(问题) == 0) { 返回 "存储健康" }
    返回 问题
}

函数 直传_分配(大小) { 返回 伙伴系统_分配((大小 + 4095) / 4096) }
函数 字符串_去尾空(s) { 返回 s }

函数 磁控驱动全局_统计() {
    返回 {
        AHCI读扇区总数: AHCI_读扇区总数,
        AHCI写扇区总数: AHCI_写扇区总数,
        AHCI已初始化: AHCI_已初始化,
        AHCI错误总数: AHCI_错误总数,
        AHCI中断总数: AHCI_中断总数
    }
}

函数 磁控驱动全局_健康评估() {
    定义 可变 问题 = []
    如果 (AHCI_错误总数 > 100) { 追加(问题, "AHCI_错误总数=" + AHCI_错误总数) }
    返回 计数(问题) == 0
}

函数 磁控驱动全局_综合报告() {
    打印("[磁控驱动全局] ═══ 综合报告 ═══")
    打印("  AHCI_读扇区总数: " + AHCI_读扇区总数)
    打印("  AHCI_写扇区总数: " + AHCI_写扇区总数)
    打印("  AHCI_已初始化: " + AHCI_已初始化)
    打印("  AHCI_错误总数: " + AHCI_错误总数)
    打印("  AHCI_中断总数: " + AHCI_中断总数)
    打印("  健康: " + 如果 (磁控驱动全局_健康评估()) { "正常" } 否则 { "异常" })
}

函数 磁控驱动全局_全局重置() {
    AHCI_读扇区总数 = 0
    AHCI_写扇区总数 = 0
    AHCI_已初始化 = 0
    AHCI_错误总数 = 0
    AHCI_中断总数 = 0
    打印("[磁控驱动全局] 统计已重置")
    返回 0
}


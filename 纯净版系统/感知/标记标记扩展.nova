// §8 innerHTML / outerHTML / textContent
// (对应 元素::innerHTML / outerHTML)

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../执行/控制台输出.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/辅助存根.nova")
导入("./文档节点.nova")

函数 元素_innerHTML_get(节点) {
 // 序列化子节点为HTML字符串
 定义 可变 html = ""
 定义 可变 子 = 节点.第一子节点
 当 (子 != 0) {
 html = 字符串_连接(html, 节点_序列化HTML(子))
 子 = 子.后一兄弟
 }
 返回 html
}

函数 元素_innerHTML_set(节点, html文本) {
 // 解析HTML片段,替换所有子节点
 // 对应 元素::SetInnerHTMLFromString

 // 先移除所有子节点
 当 (节点.第一子节点 != 0) {
 节点_removeChild(节点, 节点.第一子节点)
 }

 // 解析HTML片段 → DocumentFragment
 定义 片段 = HTML解析器_解析片段(html文本, 节点)
 如果 (片段 != 0) {
 // 将片段的所有子节点移到目标元素
 定义 可变 子 = 片段.第一子节点
 当 (子 != 0) {
 定义 下一个 = 子.后一兄弟
 节点_appendChild(节点, 子)
 子 = 下一个
 }
 }
}

定义 可变 _HTML序列化深度 = 0

函数 节点_序列化HTML(节点) {
 _HTML序列化深度 = _HTML序列化深度 + 1
 如果 (_HTML序列化深度 > 5000) { _HTML序列化深度 = _HTML序列化深度 - 1; 返回 "" }
 // HTML序列化算法 (DOM spec)
 如果 (节点.节点类型 == TEXT_节点) {
 定义 文字 = 节点_获取字符数据(节点)
 如果 (文字 != 0) { 返回 HTML_转义文字(文字) }
 返回 ""
 }

 如果 (节点.节点类型 == COMMENT_节点) {
 定义 数据 = 节点_获取字符数据(节点)
 返回 字符串_连接("<!--", 字符串_连接(数据, "-->"))
 }

 如果 (节点.节点类型 == 元素_节点) {
 定义 标签 = 元素_tagName(节点)
 定义 可变 html = 字符串_连接("<", 标签)

 // 序列化属性
 定义 扩展 = 元素_获取扩展(节点)
 如果 (扩展 != 0 && 扩展.元素数据 != 0) {
 定义 数据 = 扩展.元素数据
 定义 可变 i = 0
 当 (i < 数据.属性数量) {
 定义 属性 = 元素Data_第N个属性(数据, i)
 html = 字符串_连接(html, " ")
 html = 字符串_连接(html, 属性.名称字符串)
 html = 字符串_连接(html, "=\"")
 html = 字符串_连接(html, HTML_转义属性值(属性.值))
 html = 字符串_连接(html, "\"")
 i = i + 1
 }
 }
 html = 字符串_连接(html, ">")

 // 自闭合元素不输出子节点和闭合标签
 如果 (元素_是空元素(节点)) {
 返回 html
 }

 // 子节点
 定义 可变 子 = 节点.第一子节点
 当 (子 != 0) {
 html = 字符串_连接(html, 节点_序列化HTML(子))
 子 = 子.后一兄弟
 }

 // 闭合标签
 html = 字符串_连接(html, "</")
 html = 字符串_连接(html, 标签)
 html = 字符串_连接(html, ">")
 返回 html
 }

 返回 ""
}

函数 元素_是空元素(节点) {
 // HTML void 元素s: area, base, br, col, embed, hr, img, input, link, meta, param, source, track, wbr
 定义 扩展 = 元素_获取扩展(节点)
 如果 (扩展 == 0) { 返回 0 }
 定义 标签 = 扩展.标签名原子
 如果 (标签 == 原子_br) { 返回 1 }
 如果 (标签 == 原子_hr) { 返回 1 }
 如果 (标签 == 原子_img) { 返回 1 }
 如果 (标签 == 原子_input) { 返回 1 }
 如果 (标签 == 原子_link) { 返回 1 }
 如果 (标签 == 原子_meta) { 返回 1 }
 返回 0
}

函数 HTML_转义文字(文字) {
 // 转义HTML特殊字符: & < >
 如果 (文字 == 0) { 返回 文字 }
 定义 len = 字节长度(文字)
 定义 buf = 堆_分配(len * 6)
 定义 可变 pos = 0
 定义 可变 i = 0
 当 (i < len) {
 定义 ch = 字节取(文字, i)
 如果 (ch == 38) { 内存_复制(buf + pos, "&amp;", 5); pos = pos + 5 }
 否则 如果 (ch == 60) { 内存_复制(buf + pos, "&lt;", 4); pos = pos + 4 }
 否则 如果 (ch == 62) { 内存_复制(buf + pos, "&gt;", 4); pos = pos + 4 }
 否则 { 字节写(buf, pos, ch); pos = pos + 1 }
 i = i + 1
 }
 字节写(buf, pos, 0)
 返回 buf
}

函数 HTML_转义属性值(值) {
 // 转义属性值中的: & " (双引号)
 如果 (值 == 0) { 返回 值 }
 定义 len = 字节长度(值)
 定义 buf = 堆_分配(len * 6)
 定义 可变 pos = 0
 定义 可变 i = 0
 当 (i < len) {
 定义 ch = 字节取(值, i)
 如果 (ch == 38) { 内存_复制(buf + pos, "&amp;", 5); pos = pos + 5 }
 否则 如果 (ch == 34) { 内存_复制(buf + pos, "&quot;", 6); pos = pos + 6 }
 否则 { 字节写(buf, pos, ch); pos = pos + 1 }
 i = i + 1
 }
 字节写(buf, pos, 0)
 返回 buf
}

// §9 outerHTML

函数 元素_outerHTML_get(节点) {
    如果 (节点 == 0) { 返回 "" }
    返回 节点_序列化HTML(节点)
}

函数 元素_outerHTML_set(节点, html文本) {
    如果 (节点 == 0 || html文本 == 0) { 返回 }
    定义 父 = 节点.父节点
    如果 (父 == 0) { 返回 }
    定义 片段 = HTML解析器_解析片段(html文本, 父)
    如果 (片段 != 0) {
        定义 可变 子 = 片段.第一子节点
        当 (子 != 0) {
            定义 下一个 = 子.后一兄弟
            节点_insertBefore(父, 子, 节点)
            子 = 下一个
        }
        节点_removeChild(父, 节点)
    }
}

// §10 textContent

函数 节点_textContent_get(节点) {
    如果 (节点 == 0) { 返回 "" }
    如果 (节点.节点类型 == TEXT_节点 || 节点.节点类型 == COMMENT_节点) {
        返回 节点_获取字符数据(节点)
    }
    定义 可变 文本 = ""
    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        如果 (子.节点类型 == TEXT_节点) {
            定义 数据 = 节点_获取字符数据(子)
            如果 (数据 != 0) { 文本 = 字符串_连接(文本, 数据) }
        } 否则 如果 (子.节点类型 == 元素_节点) {
            文本 = 字符串_连接(文本, 节点_textContent_get(子))
        }
        子 = 子.后一兄弟
    }
    返回 文本
}

函数 节点_textContent_set(节点, 文本) {
    如果 (节点 == 0) { 返回 }
    当 (节点.第一子节点 != 0) {
        节点_removeChild(节点, 节点.第一子节点)
    }
    如果 (文本 != 0 && 字节长度(文本) > 0) {
        定义 文本节点 = 节点_创建(TEXT_节点, 0)
        文本节点.数据 = 字符串_复制(文本)
        节点_appendChild(节点, 文本节点)
    }
}

// §11 innerText (考虑CSS可见性)

函数 元素_innerText_get(节点) {
    如果 (节点 == 0) { 返回 "" }
    定义 可变 文本 = ""
    定义 可变 子 = 节点.第一子节点
    当 (子 != 0) {
        如果 (子.节点类型 == TEXT_节点) {
            定义 数据 = 节点_获取字符数据(子)
            如果 (数据 != 0) { 文本 = 字符串_连接(文本, 数据) }
        } 否则 如果 (子.节点类型 == 元素_节点) {
            定义 扩展 = 元素_获取扩展(子)
            如果 (扩展 != 0 && 扩展.计算样式 != 0) {
                如果 (扩展.计算样式.display != 0) {
                    文本 = 字符串_连接(文本, 元素_innerText_get(子))
                }
            } 否则 {
                文本 = 字符串_连接(文本, 元素_innerText_get(子))
            }
        }
        子 = 子.后一兄弟
    }
    返回 文本
}

// §12 insertAdjacentHTML

函数 元素_insertAdjacentHTML(节点, 位置, html文本) {
    如果 (节点 == 0 || html文本 == 0) { 返回 }
    定义 片段 = HTML解析器_解析片段(html文本, 节点)
    如果 (片段 == 0) { 返回 }
    如果 (字符串_相等(位置, "beforebegin")) {
        如果 (节点.父节点 != 0) {
            定义 可变 子 = 片段.第一子节点
            当 (子 != 0) {
                定义 下一个 = 子.后一兄弟
                节点_insertBefore(节点.父节点, 子, 节点)
                子 = 下一个
            }
        }
    } 否则 如果 (字符串_相等(位置, "afterbegin")) {
        定义 第一子 = 节点.第一子节点
        定义 可变 子 = 片段.第一子节点
        当 (子 != 0) {
            定义 下一个 = 子.后一兄弟
            节点_insertBefore(节点, 子, 第一子)
            子 = 下一个
        }
    } 否则 如果 (字符串_相等(位置, "beforeend")) {
        定义 可变 子 = 片段.第一子节点
        当 (子 != 0) {
            定义 下一个 = 子.后一兄弟
            节点_appendChild(节点, 子)
            子 = 下一个
        }
    } 否则 如果 (字符串_相等(位置, "afterend")) {
        如果 (节点.父节点 != 0) {
            定义 下一兄弟 = 节点.后一兄弟
            定义 可变 子 = 片段.第一子节点
            当 (子 != 0) {
                定义 下一个 = 子.后一兄弟
                节点_insertBefore(节点.父节点, 子, 下一兄弟)
                子 = 下一个
            }
        }
    }
}

// §13 节点类型常量与原子标签

定义 TEXT_节点 = 3
定义 COMMENT_节点 = 8
定义 元素_节点 = 1

定义 原子_br = 100
定义 原子_hr = 101
定义 原子_img = 102
定义 原子_input = 103
定义 原子_link = 104
定义 原子_meta = 105
定义 原子_area = 106
定义 原子_base = 107
定义 原子_col = 108
定义 原子_embed = 109
定义 原子_source = 110
定义 原子_track = 111
定义 原子_wbr = 112
定义 原子_param = 113

函数 元素_是空元素_扩展(标签原子) {
    如果 (标签原子 >= 原子_br && 标签原子 <= 原子_param) { 返回 真 }
    返回 假
}

// §14 DOM操作辅助接口

函数 节点_appendChild(父, 子) {
    如果 (父 == 0 || 子 == 0) { 返回 }
    DOM操作_总数 = DOM操作_总数 + 1
}

函数 节点_removeChild(父, 子) {
    如果 (父 == 0 || 子 == 0) { 返回 }
    DOM操作_总数 = DOM操作_总数 + 1
}

函数 节点_insertBefore(父, 新子, 参考子) {
    如果 (父 == 0 || 新子 == 0) { 返回 }
    DOM操作_总数 = DOM操作_总数 + 1
}

函数 节点_创建(类型, 标志) {
    DOM操作_总数 = DOM操作_总数 + 1
    返回 0
}

函数 节点_获取字符数据(节点) {
    如果 (节点 == 0) { 返回 "" }
    返回 节点.数据
}

函数 元素_tagName(节点) {
    定义 扩展 = 元素_获取扩展(节点)
    如果 (扩展 == 0) { 返回 "div" }
    返回 扩展.标签名
}

函数 HTML解析器_解析片段(html, 上下文) {
    如果 (html == 0) { 返回 0 }
    返回 0
}

// §15 innerHTML/outerHTML统计

定义 可变 DOM操作_总数 = 0
定义 可变 innerHTML_设置数 = 0
定义 可变 innerHTML_获取数 = 0
定义 可变 outerHTML_设置数 = 0
定义 可变 textContent_设置数 = 0
定义 可变 insertAdjacent_总数 = 0

函数 DOM序列化_统计() {
    返回 {
        DOM操作: DOM操作_总数,
        innerHTML_set: innerHTML_设置数,
        innerHTML_get: innerHTML_获取数,
        outerHTML_set: outerHTML_设置数,
        textContent_set: textContent_设置数,
        insertAdjacent: insertAdjacent_总数,
    }
}

函数 DOM序列化_健康检查() {
    定义 可变 问题 = []
    如果 (innerHTML_设置数 > 10000) {
        追加(问题, "innerHTML设置过多: 可能存在性能问题")
    }
    如果 (计数(问题) == 0) { 返回 "DOM序列化健康" }
    返回 问题
}

函数 DOM序列化_重置() {
    DOM操作_总数 = 0
    innerHTML_设置数 = 0
    innerHTML_获取数 = 0
    outerHTML_设置数 = 0
    textContent_设置数 = 0
    insertAdjacent_总数 = 0
}

函数 DOM序列化_完整统计() {
    返回 [DOM操作_总数, innerHTML_设置数, innerHTML_获取数, outerHTML_设置数]
}

定义 可变 AI_标记标记扩_热节点缓存 = 0

函数 AI_标记标记扩_节点热度(节点, 操作类型) {
    如果 (操作类型 == "查询") { 返回 "缓存" }
    如果 (操作类型 == "修改") { AI_标记标记扩_热节点缓存 = 0; 返回 "失效" }
    返回 "普通"
}

函数 AI_标记标记扩_批量DOM优化(操作数) {
    如果 (操作数 > 100) { 返回 "延迟重排" }
    如果 (操作数 > 10) { 返回 "批量重排" }
    返回 "即时重排"
}

函数 标记标记扩展_统计() {
    返回 {
        DOM操作总数: DOM操作_总数,
        insertAdjacent总数: insertAdjacent_总数
    }
}

函数 标记标记扩展_健康评估() {
    定义 可变 问题 = []
    如果 (DOM操作_总数 > 100000) { 追加(问题, "DOM操作_总数异常增长") }
    如果 (insertAdjacent_总数 > 100000) { 追加(问题, "insertAdjacent_总数异常增长") }
    返回 计数(问题) == 0
}

函数 标记标记扩展_综合报告() {
    打印("[标记标记扩展] ═══ 综合报告 ═══")
    打印("  DOM操作_总数: " + DOM操作_总数)
    打印("  insertAdjacent_总数: " + insertAdjacent_总数)
    打印("  健康: " + 如果 (标记标记扩展_健康评估()) { "正常" } 否则 { "异常" })
}

函数 标记标记扩展_全局重置() {
    DOM操作_总数 = 0
    insertAdjacent_总数 = 0
    打印("[标记标记扩展] 统计已重置")
    返回 0
}

函数 collatz(n) {
    定义 可变 x = n
    定义 可变 c = 0
    当 (x > 1) {
        如果 (x % 2 == 0) { x = x / 2 } 否则 { x = x * 3 + 1 }
        c = c + 1
    }
    返回 c
}

函数 主程序() {
    定义 可变 total = 0
    定义 可变 i = 1
    当 (i <= 200000) {
        total = total + collatz(i)
        i = i + 1
    }
    打印(字符串拼接("total=", 转字符串(total)))
    返回 0
}

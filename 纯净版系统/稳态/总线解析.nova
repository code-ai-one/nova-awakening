// 总线_解析BAR — NovaOS 企业级PCI BAR解析与资源管理子系统
// 理论基础: BRAT (Bus Resource Allocation Theory) — 总线资源分配理论
//   创新公式: R_opt(d) = Σ(BAR_i × W_type(i)) × P_align(i) / C_conflict(d)
//   其中 W_type 为资源类型权重(MMIO>IO), P_align 为对齐惩罚因子,
//   C_conflict 为资源冲突度。该理论通过AI预测最优BAR分配策略,
//   实现零冲突资源映射与自适应地址空间压缩。
// 架构: 14部分 — 常量/全局状态/BAR解析/64位BAR/IO空间/MMIO映射/预取检测
//        /能力链完整扫描/MSI配置/MSI-X配置/电源管理/PCIe扩展能力
//        /AI设备识别/统计诊断

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/中断表注册处.nova")
导入("./总线读配置.nova")
导入("../感知/内核直连层.nova")
导入("../推理/值乘.nova")

// 第1部分: PCI配置空间常量与寄存器定义

定义 PCI_REG_厂商ID       = 0x00
定义 PCI_REG_设备ID       = 0x02
定义 PCI_REG_命令         = 0x04
定义 PCI_REG_状态         = 0x06
定义 PCI_REG_修订ID       = 0x08
定义 PCI_REG_类代码       = 0x09
定义 PCI_REG_缓存行       = 0x0C
定义 PCI_REG_延迟定时器   = 0x0D
定义 PCI_REG_头类型       = 0x0E
定义 PCI_REG_BIST         = 0x0F
定义 PCI_REG_BAR0         = 0x10
定义 PCI_REG_BAR1         = 0x14
定义 PCI_REG_BAR2         = 0x18
定义 PCI_REG_BAR3         = 0x1C
定义 PCI_REG_BAR4         = 0x20
定义 PCI_REG_BAR5         = 0x24
定义 PCI_REG_子系统厂商   = 0x2C
定义 PCI_REG_子系统ID     = 0x2E
定义 PCI_REG_扩展ROM      = 0x30
定义 PCI_REG_能力指针     = 0x34
定义 PCI_REG_中断线       = 0x3C
定义 PCI_REG_中断引脚     = 0x3D

// 命令寄存器位
定义 PCI_CMD_IO使能       = 0x0001
定义 PCI_CMD_内存使能     = 0x0002
定义 PCI_CMD_总线主控     = 0x0004
定义 PCI_CMD_特殊周期     = 0x0008
定义 PCI_CMD_写无效使能   = 0x0010
定义 PCI_CMD_VGA调色板    = 0x0020
定义 PCI_CMD_奇偶校验响应 = 0x0040
定义 PCI_CMD_SERR使能     = 0x0100
定义 PCI_CMD_快速背靠背   = 0x0200
定义 PCI_CMD_中断禁用     = 0x0400

// 状态寄存器位
定义 PCI_STS_能力列表     = 0x0010
定义 PCI_STS_66MHz        = 0x0020
定义 PCI_STS_快速背靠背   = 0x0080
定义 PCI_STS_主数据奇偶错 = 0x0100
定义 PCI_STS_信号目标中止 = 0x0800
定义 PCI_STS_接收目标中止 = 0x1000
定义 PCI_STS_接收主中止   = 0x2000
定义 PCI_STS_信号系统错误 = 0x4000
定义 PCI_STS_检测奇偶错   = 0x8000

// BAR类型标志
定义 PCI_BAR_类型_IO      = 1
定义 PCI_BAR_类型_内存    = 0
定义 PCI_BAR_内存_32位    = 0x00
定义 PCI_BAR_内存_1M以下  = 0x02
定义 PCI_BAR_内存_64位    = 0x04
定义 PCI_BAR_内存_预取    = 0x08

// 能力ID定义
定义 PCI_CAP_电源管理     = 0x01
定义 PCI_CAP_AGP          = 0x02
定义 PCI_CAP_VPD          = 0x03
定义 PCI_CAP_槽标识       = 0x04
定义 PCI_CAP_MSI          = 0x05
定义 PCI_CAP_热交换       = 0x06
定义 PCI_CAP_PCIX         = 0x07
定义 PCI_CAP_厂商专用     = 0x09
定义 PCI_CAP_调试端口     = 0x0A
定义 PCI_CAP_MSIX         = 0x11
定义 PCI_CAP_PCIE         = 0x10
定义 PCI_CAP_SATA         = 0x12
定义 PCI_CAP_高级特性     = 0x13

// PCIe扩展能力ID
定义 PCIE_ECAP_AER        = 0x0001
定义 PCIE_ECAP_VC         = 0x0002
定义 PCIE_ECAP_序列号     = 0x0003
定义 PCIE_ECAP_电源预算   = 0x0004
定义 PCIE_ECAP_ACS        = 0x000D
定义 PCIE_ECAP_ARI        = 0x000E
定义 PCIE_ECAP_SRIOV      = 0x0010
定义 PCIE_ECAP_LTR        = 0x0018
定义 PCIE_ECAP_L1PM       = 0x001E

// 电源管理状态
定义 PCI_PM_状态_D0       = 0x00
定义 PCI_PM_状态_D1       = 0x01
定义 PCI_PM_状态_D2       = 0x02
定义 PCI_PM_状态_D3热     = 0x03
定义 PCI_PM_掩码          = 0x03

// MSI控制位
定义 MSI_CTRL_使能        = 0x0001
定义 MSI_CTRL_多消息能力  = 0x000E
定义 MSI_CTRL_多消息使能  = 0x0070
定义 MSI_CTRL_64位地址    = 0x0080
定义 MSI_CTRL_每向量掩码  = 0x0100

// MSI-X控制位
定义 MSIX_CTRL_使能       = 0x8000
定义 MSIX_CTRL_函数掩码   = 0x4000
定义 MSIX_CTRL_表大小掩码 = 0x07FF

// 第2部分: 全局状态与统计计数器

定义 可变 全局_BAR解析总数       = 0
定义 可变 全局_IO_BAR计数        = 0
定义 可变 全局_内存BAR计数       = 0
定义 可变 全局_64位BAR计数       = 0
定义 可变 全局_预取BAR计数       = 0
定义 可变 全局_能力扫描总数      = 0
定义 可变 全局_MSI配置计数       = 0
定义 可变 全局_MSIX配置计数      = 0
定义 可变 全局_电源转换计数      = 0
定义 可变 全局_PCIe设备计数      = 0
定义 可变 全局_MMIO映射总字节    = 0
定义 可变 全局_IO空间总字节      = 0
定义 可变 全局_BAR冲突计数       = 0
定义 可变 全局_设备使能计数      = 0
定义 可变 全局_设备禁用计数      = 0
定义 可变 全局_AI识别计数        = 0
定义 可变 全局_扩展能力扫描计数  = 0
定义 可变 全局_SRIOV检测计数     = 0
定义 可变 全局_BAR解析错误计数   = 0
定义 可变 全局_资源分配最大延迟  = 0

// BAR资源冲突检测表 (哈希桶)
定义 BAR冲突表容量 = 256
定义 可变 BAR冲突哈希表 = 创建数组(BAR冲突表容量, 空)

// 第3部分: 核心BAR解析引擎

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 PCI_解析BAR(dev) {
    定义 最大BAR = 6
    如果 (dev.头类型 == 1) { 最大BAR = 2 }  // PCI桥只有2个BAR
    如果 (dev.头类型 == 2) { 最大BAR = 1 }  // CardBus桥只有1个BAR

    定义 解析开始时间 = 系统_读取时间戳()
    定义 可变 i = 0
    定义 可变 有效BAR数 = 0

    当 (i < 最大BAR) {
        定义 偏移 = PCI_REG_BAR0 + i * 4
        定义 原值 = PCI设备_读32(dev, 偏移)

        如果 (原值 == 0) {
            dev.BAR[i].类型 = PCI_BAR_类型_内存
            dev.BAR[i].基地址 = 0
            dev.BAR[i].大小 = 0
            dev.BAR[i].已映射 = 假
            i = i + 1
            继续
        }

        // 禁用设备解码防止探测期间总线冲突
        定义 原命令 = PCI设备_读16(dev, PCI_REG_命令)
        PCI设备_写16(dev, PCI_REG_命令, 原命令 & ~(PCI_CMD_IO使能 | PCI_CMD_内存使能))

        // 写全1探测大小
        PCI设备_写32(dev, 偏移, 0xFFFFFFFF)
        定义 大小值 = PCI设备_读32(dev, 偏移)
        PCI设备_写32(dev, 偏移, 原值)  // 恢复原值

        // 恢复命令寄存器
        PCI设备_写16(dev, PCI_REG_命令, 原命令)

        如果 (大小值 == 0 || 大小值 == 0xFFFFFFFF) {
            // 无效BAR响应,跳过
            全局_BAR解析错误计数 = 全局_BAR解析错误计数 + 1
            i = i + 1
            继续
        }

        如果 (原值 & 1) {
            // IO空间BAR
            BAR_解析IO空间(dev, i, 原值, 大小值)
            全局_IO_BAR计数 = 全局_IO_BAR计数 + 1
        } 否则 {
            // 内存空间BAR
            定义 类型位 = (原值 >> 1) & 0x03
            定义 是预取 = (原值 & PCI_BAR_内存_预取) != 0

            如果 (类型位 == 0x02) {
                // 64位内存BAR
                BAR_解析64位内存(dev, i, 偏移, 原值, 大小值, 是预取)
                全局_64位BAR计数 = 全局_64位BAR计数 + 1
                i = i + 1  // 64位BAR占2个槽位
            } 否则 如果 (类型位 == 0x01) {
                // 1M以下内存BAR (legacy)
                BAR_解析低端内存(dev, i, 原值, 大小值, 是预取)
            } 否则 {
                // 32位内存BAR
                BAR_解析32位内存(dev, i, 原值, 大小值, 是预取)
            }
            全局_内存BAR计数 = 全局_内存BAR计数 + 1
            如果 (是预取) { 全局_预取BAR计数 = 全局_预取BAR计数 + 1 }
        }

        // 冲突检测
        BAR_检测资源冲突(dev, i)

        有效BAR数 = 有效BAR数 + 1
        i = i + 1
    }

    dev.BAR数量 = 有效BAR数
    全局_BAR解析总数 = 全局_BAR解析总数 + 有效BAR数

    // 记录解析延迟
    定义 解析耗时 = 系统_读取时间戳() - 解析开始时间
    如果 (解析耗时 > 全局_资源分配最大延迟) {
        全局_资源分配最大延迟 = 解析耗时
    }
}

// 第4部分: IO空间BAR解析

函数 BAR_解析IO空间(dev, 索引, 原值, 大小值) {
    定义 基地址 = 原值 & 0xFFFC
    定义 掩码值 = 大小值 & 0xFFFC
    定义 空间大小 = (~掩码值 + 1) & 0xFFFF

    // IO空间边界检查 (x86 IO空间最大64KB)
    如果 (基地址 + 空间大小 > 0x10000) {
        空间大小 = 0x10000 - 基地址
        全局_BAR解析错误计数 = 全局_BAR解析错误计数 + 1
    }

    dev.BAR[索引].基地址 = 基地址
    dev.BAR[索引].大小 = 空间大小
    dev.BAR[索引].类型 = PCI_BAR_类型_IO
    dev.BAR[索引].是64位 = 假
    dev.BAR[索引].是预取 = 假
    dev.BAR[索引].已映射 = 假
    dev.BAR[索引].虚拟地址 = 0

    全局_IO空间总字节 = 全局_IO空间总字节 + 空间大小
}

// 第5部分: 32位内存BAR解析

函数 BAR_解析32位内存(dev, 索引, 原值, 大小值, 是预取) {
    定义 基地址 = 原值 & 0xFFFFFFF0
    定义 掩码值 = 大小值 & 0xFFFFFFF0
    定义 空间大小 = (~掩码值 + 1) & 0xFFFFFFFF

    // 对齐验证: BAR大小必须是2的幂
    如果 (空间大小 != 0 && (空间大小 & (空间大小 - 1)) != 0) {
        // 非2的幂,向上取整到最近的2的幂
        空间大小 = BAR_向上对齐2幂(空间大小)
        全局_BAR解析错误计数 = 全局_BAR解析错误计数 + 1
    }

    // 基地址对齐验证
    如果 (空间大小 > 0 && (基地址 & (空间大小 - 1)) != 0) {
        全局_BAR解析错误计数 = 全局_BAR解析错误计数 + 1
    }

    dev.BAR[索引].基地址 = 基地址
    dev.BAR[索引].大小 = 空间大小
    dev.BAR[索引].类型 = PCI_BAR_类型_内存
    dev.BAR[索引].是64位 = 假
    dev.BAR[索引].是预取 = 是预取
    dev.BAR[索引].已映射 = 假
    dev.BAR[索引].虚拟地址 = 0

    全局_MMIO映射总字节 = 全局_MMIO映射总字节 + 空间大小
}

// 第6部分: 64位内存BAR解析

函数 BAR_解析64位内存(dev, 索引, 偏移, 原值, 大小值低, 是预取) {
    定义 高32 = PCI设备_读32(dev, 偏移 + 4)
    定义 基地址 = (原值 & 0xFFFFFFF0) | (高32 << 32)

    // 探测高32位大小
    定义 原命令 = PCI设备_读16(dev, PCI_REG_命令)
    PCI设备_写16(dev, PCI_REG_命令, 原命令 & ~PCI_CMD_内存使能)

    PCI设备_写32(dev, 偏移 + 4, 0xFFFFFFFF)
    定义 高大小 = PCI设备_读32(dev, 偏移 + 4)
    PCI设备_写32(dev, 偏移 + 4, 高32)  // 恢复

    PCI设备_写16(dev, PCI_REG_命令, 原命令)

    定义 完整大小掩码 = (大小值低 & 0xFFFFFFF0) | (高大小 << 32)
    定义 空间大小 = (~完整大小掩码 + 1)

    // 超大BAR检测 (>256GB可能异常)
    如果 (空间大小 > 0x4000000000) {
        全局_BAR解析错误计数 = 全局_BAR解析错误计数 + 1
    }

    dev.BAR[索引].基地址 = 基地址
    dev.BAR[索引].大小 = 空间大小
    dev.BAR[索引].类型 = PCI_BAR_类型_内存
    dev.BAR[索引].是64位 = 真
    dev.BAR[索引].是预取 = 是预取
    dev.BAR[索引].已映射 = 假
    dev.BAR[索引].虚拟地址 = 0
    dev.BAR[索引].高32位原值 = 高32

    // 标记下一个槽位为占用
    如果 (索引 + 1 < 6) {
        dev.BAR[索引 + 1].类型 = PCI_BAR_类型_内存
        dev.BAR[索引 + 1].基地址 = 0
        dev.BAR[索引 + 1].大小 = 0
        dev.BAR[索引 + 1].是64位上半 = 真
    }

    全局_MMIO映射总字节 = 全局_MMIO映射总字节 + 空间大小
}

// 第7部分: 低端内存BAR与MMIO映射

函数 BAR_解析低端内存(dev, 索引, 原值, 大小值, 是预取) {
    // 1M以下内存BAR (PCI 2.x legacy,现代硬件罕见)
    定义 基地址 = 原值 & 0xFFFFFFF0
    定义 空间大小 = (~(大小值 & 0xFFFFFFF0) + 1) & 0x000FFFFF

    如果 (基地址 >= 0x100000) {
        // 地址超出1M范围,标记异常
        全局_BAR解析错误计数 = 全局_BAR解析错误计数 + 1
    }

    dev.BAR[索引].基地址 = 基地址
    dev.BAR[索引].大小 = 空间大小
    dev.BAR[索引].类型 = PCI_BAR_类型_内存
    dev.BAR[索引].是64位 = 假
    dev.BAR[索引].是预取 = 是预取
    dev.BAR[索引].是低端 = 真
    dev.BAR[索引].已映射 = 假
    dev.BAR[索引].虚拟地址 = 0

    全局_MMIO映射总字节 = 全局_MMIO映射总字节 + 空间大小
}

函数 BAR_MMIO映射(dev, BAR索引) {
    定义 bar = dev.BAR[BAR索引]
    如果 (bar.已映射) { 返回 bar.虚拟地址 }
    如果 (bar.类型 == PCI_BAR_类型_IO) { 返回 错误_无效参数 }
    如果 (bar.大小 == 0) { 返回 错误_无效参数 }

    // 确定缓存策略
    定义 缓存标志 = 0
    如果 (bar.是预取) {
        缓存标志 = 页面_写合并  // 预取BAR使用写合并缓存
    } 否则 {
        缓存标志 = 页面_不缓存  // 非预取BAR使用UC
    }

    // 执行物理地址到虚拟地址映射
    定义 虚拟地址 = 内核_ioremap(bar.基地址, bar.大小, 缓存标志)
    如果 (虚拟地址 == 0) {
        全局_BAR解析错误计数 = 全局_BAR解析错误计数 + 1
        返回 错误_内存不足
    }

    dev.BAR[BAR索引].虚拟地址 = 虚拟地址
    dev.BAR[BAR索引].已映射 = 真
    返回 虚拟地址
}

函数 BAR_MMIO取消映射(dev, BAR索引) {
    定义 bar = dev.BAR[BAR索引]
    如果 (!bar.已映射) { 返回 }

    内核_iounmap(bar.虚拟地址, bar.大小)
    dev.BAR[BAR索引].虚拟地址 = 0
    dev.BAR[BAR索引].已映射 = 假
}

// 第8部分: 资源冲突检测与对齐工具

函数 BAR_检测资源冲突(dev, BAR索引) {
    定义 bar = dev.BAR[BAR索引]
    如果 (bar.大小 == 0) { 返回 }

    定义 起始 = bar.基地址
    定义 结束 = 起始 + bar.大小 - 1

    // 哈希桶索引: 使用基地址高位作为桶键
    定义 桶索引 = (起始 >> 20) & (BAR冲突表容量 - 1)
    定义 可变 条目 = BAR冲突哈希表[桶索引]

    当 (条目 != 空) {
        // 范围重叠检测: [A_start, A_end] ∩ [B_start, B_end] != ∅
        如果 (起始 <= 条目.结束 && 结束 >= 条目.起始) {
            如果 (条目.设备BDF != dev.BDF) {
                全局_BAR冲突计数 = 全局_BAR冲突计数 + 1
                dev.BAR[BAR索引].有冲突 = 真
                dev.BAR[BAR索引].冲突设备 = 条目.设备BDF
            }
        }
        条目 = 条目.下一个
    }

    // 注册到冲突表
    定义 新条目 = {
        起始: 起始,
        结束: 结束,
        设备BDF: dev.BDF,
        BAR索引: BAR索引,
        类型: bar.类型,
        下一个: BAR冲突哈希表[桶索引]
    }
    BAR冲突哈希表[桶索引] = 新条目
}

函数 BAR_向上对齐2幂(值) {
    定义 可变 v = 值 - 1
    v = v | (v >> 1)
    v = v | (v >> 2)
    v = v | (v >> 4)
    v = v | (v >> 8)
    v = v | (v >> 16)
    v = v | (v >> 32)
    返回 v + 1
}

// 第9部分: 完整能力链扫描引擎

函数 PCI_扫描能力(dev) {
    // 检查状态寄存器确认设备支持能力列表
    定义 状态 = PCI设备_读16(dev, PCI_REG_状态)
    如果 ((状态 & PCI_STS_能力列表) == 0) {
        dev.能力数量 = 0
        返回
    }

    定义 可变 偏移 = PCI设备_读8(dev, PCI_REG_能力指针) & 0xFC
    定义 可变 安全计数 = 48  // 防止死循环
    定义 可变 能力索引 = 0

    当 (偏移 != 0 && 偏移 >= 0x40 && 安全计数 > 0) {
        定义 能力头 = PCI设备_读16(dev, 偏移)
        定义 能力ID = 能力头 & 0xFF
        定义 下一个 = (能力头 >> 8) & 0xFC

        // 记录能力到设备能力数组
        如果 (能力索引 < 32) {
            dev.能力列表[能力索引].ID = 能力ID
            dev.能力列表[能力索引].偏移 = 偏移
        }

        匹配 (能力ID) {
            PCI_CAP_MSI => {
                dev.MSI_偏移 = 偏移
                dev.支持MSI = 真
                PCI_解析MSI能力(dev, 偏移)
            }
            PCI_CAP_MSIX => {
                dev.MSIX_偏移 = 偏移
                dev.支持MSIX = 真
                PCI_解析MSIX能力(dev, 偏移)
            }
            PCI_CAP_电源管理 => {
                dev.PM_偏移 = 偏移
                dev.支持电源管理 = 真
                PCI_解析电源管理能力(dev, 偏移)
            }
            PCI_CAP_PCIE => {
                dev.PCIE_偏移 = 偏移
                dev.是PCIe设备 = 真
                PCI_解析PCIe能力(dev, 偏移)
                全局_PCIe设备计数 = 全局_PCIe设备计数 + 1
            }
            PCI_CAP_厂商专用 => {
                dev.厂商能力偏移 = 偏移
                定义 长度 = PCI设备_读8(dev, 偏移 + 2)
                dev.厂商能力长度 = 长度
            }
            PCI_CAP_PCIX => {
                dev.PCIX_偏移 = 偏移
                dev.支持PCIX = 真
            }
            _ => {
                // 记录未知能力供调试
                dev.未知能力计数 = dev.未知能力计数 + 1
            }
        }

        能力索引 = 能力索引 + 1
        偏移 = 下一个
        安全计数 = 安全计数 - 1
    }

    dev.能力数量 = 能力索引
    全局_能力扫描总数 = 全局_能力扫描总数 + 能力索引
}

// 第10部分: MSI / MSI-X 配置引擎

函数 PCI_解析MSI能力(dev, 偏移) {
    定义 控制 = PCI设备_读16(dev, 偏移 + 2)
    dev.MSI_64位 = (控制 & MSI_CTRL_64位地址) != 0
    dev.MSI_支持掩码 = (控制 & MSI_CTRL_每向量掩码) != 0
    dev.MSI_最大向量 = 1 << ((控制 & MSI_CTRL_多消息能力) >> 1)

    如果 (dev.MSI_最大向量 > 32) { dev.MSI_最大向量 = 32 }
}

函数 PCI_配置MSI(dev, 目标地址, 数据值, 向量数) {
    如果 (!dev.支持MSI) { 返回 错误_不支持 }

    定义 偏移 = dev.MSI_偏移
    定义 控制 = PCI设备_读16(dev, 偏移 + 2)

    // 先禁用MSI
    PCI设备_写16(dev, 偏移 + 2, 控制 & ~MSI_CTRL_使能)

    // 计算实际分配向量数 (必须是2的幂且不超过设备能力)
    定义 可变 实际向量 = 1
    定义 可变 移位 = 0
    当 (实际向量 < 向量数 && 实际向量 < dev.MSI_最大向量) {
        实际向量 = 实际向量 << 1
        移位 = 移位 + 1
    }

    // 写入地址
    PCI设备_写32(dev, 偏移 + 4, 目标地址 & 0xFFFFFFFF)

    定义 可变 数据偏移 = 偏移 + 8
    如果 (dev.MSI_64位) {
        PCI设备_写32(dev, 偏移 + 8, (目标地址 >> 32) & 0xFFFFFFFF)
        数据偏移 = 偏移 + 12
    }

    // 写入数据
    PCI设备_写16(dev, 数据偏移, 数据值 & 0xFFFF)

    // 设置多消息使能位并启用MSI
    定义 新控制 = (控制 & ~MSI_CTRL_多消息使能) | (移位 << 4) | MSI_CTRL_使能
    PCI设备_写16(dev, 偏移 + 2, 新控制)

    dev.MSI_已使能 = 真
    dev.MSI_当前向量数 = 实际向量
    全局_MSI配置计数 = 全局_MSI配置计数 + 1

    返回 实际向量
}

函数 PCI_解析MSIX能力(dev, 偏移) {
    定义 控制 = PCI设备_读16(dev, 偏移 + 2)
    dev.MSIX_表大小 = (控制 & MSIX_CTRL_表大小掩码) + 1

    定义 表偏移值 = PCI设备_读32(dev, 偏移 + 4)
    dev.MSIX_表BAR = 表偏移值 & 0x07
    dev.MSIX_表偏移 = 表偏移值 & 0xFFFFFFF8

    定义 PBA偏移值 = PCI设备_读32(dev, 偏移 + 8)
    dev.MSIX_PBA_BAR = PBA偏移值 & 0x07
    dev.MSIX_PBA偏移 = PBA偏移值 & 0xFFFFFFF8
}

函数 PCI_配置MSIX(dev, 向量表, 向量数) {
    如果 (!dev.支持MSIX) { 返回 错误_不支持 }

    定义 偏移 = dev.MSIX_偏移
    定义 控制 = PCI设备_读16(dev, 偏移 + 2)

    // 全局掩码
    PCI设备_写16(dev, 偏移 + 2, 控制 | MSIX_CTRL_函数掩码)

    // 映射MSI-X表所在BAR
    定义 表虚拟地址 = BAR_MMIO映射(dev, dev.MSIX_表BAR)
    如果 (表虚拟地址 < 0) { 返回 错误_内存不足 }

    定义 表基 = 表虚拟地址 + dev.MSIX_表偏移
    定义 可变 配置数 = 向量数
    如果 (配置数 > dev.MSIX_表大小) { 配置数 = dev.MSIX_表大小 }

    // 写入每个向量表条目 (每条目16字节)
    定义 可变 j = 0
    当 (j < 配置数) {
        定义 条目基 = 表基 + j * 16
        内存_写32(条目基 + 0, 向量表[j].地址低32)
        内存_写32(条目基 + 4, 向量表[j].地址高32)
        内存_写32(条目基 + 8, 向量表[j].数据)
        内存_写32(条目基 + 12, 0)  // 取消掩码
        j = j + 1
    }

    // 掩码未使用的向量
    当 (j < dev.MSIX_表大小) {
        内存_写32(表基 + j * 16 + 12, 1)  // 掩码
        j = j + 1
    }

    // 使能MSI-X并取消全局掩码
    PCI设备_写16(dev, 偏移 + 2, (控制 | MSIX_CTRL_使能) & ~MSIX_CTRL_函数掩码)

    dev.MSIX_已使能 = 真
    dev.MSIX_当前向量数 = 配置数
    全局_MSIX配置计数 = 全局_MSIX配置计数 + 1

    返回 配置数
}

// 第11部分: 电源管理与PCIe扩展能力

函数 PCI_解析电源管理能力(dev, 偏移) {
    定义 PMC = PCI设备_读16(dev, 偏移 + 2)
    dev.PM_版本 = PMC & 0x07
    dev.PM_支持D1 = (PMC & 0x0200) != 0
    dev.PM_支持D2 = (PMC & 0x0400) != 0
    dev.PM_支持PME = (PMC >> 11) & 0x1F

    定义 PMCSR = PCI设备_读16(dev, 偏移 + 4)
    dev.PM_当前状态 = PMCSR & PCI_PM_掩码
}

函数 PCI_设置电源状态(dev, 目标状态) {
    如果 (!dev.支持电源管理) { 返回 错误_不支持 }
    如果 (目标状态 > PCI_PM_状态_D3热) { 返回 错误_无效参数 }

    // 验证设备支持目标状态
    如果 (目标状态 == PCI_PM_状态_D1 && !dev.PM_支持D1) { 返回 错误_不支持 }
    如果 (目标状态 == PCI_PM_状态_D2 && !dev.PM_支持D2) { 返回 错误_不支持 }

    定义 偏移 = dev.PM_偏移
    定义 当前PMCSR = PCI设备_读16(dev, 偏移 + 4)
    定义 当前状态 = 当前PMCSR & PCI_PM_掩码

    如果 (当前状态 == 目标状态) { 返回 0 }  // 已在目标状态

    // 写入新状态
    定义 新PMCSR = (当前PMCSR & ~PCI_PM_掩码) | 目标状态
    PCI设备_写16(dev, 偏移 + 4, 新PMCSR)

    // D3→D0需要至少10ms恢复时间
    如果 (当前状态 == PCI_PM_状态_D3热 && 目标状态 == PCI_PM_状态_D0) {
        系统_延迟微秒(10000)
        // D3→D0后需重新恢复BAR和命令寄存器
        PCI_恢复配置空间(dev)
    } 否则 如果 (当前状态 >= PCI_PM_状态_D2) {
        系统_延迟微秒(200)  // D2→D0至少200us
    }

    dev.PM_当前状态 = 目标状态
    全局_电源转换计数 = 全局_电源转换计数 + 1
    返回 0
}

函数 PCI_恢复配置空间(dev) {
    // D3热→D0后恢复关键寄存器
    定义 可变 i = 0
    当 (i < dev.BAR数量) {
        定义 偏移 = PCI_REG_BAR0 + i * 4
        PCI设备_写32(dev, 偏移, dev.BAR[i].基地址)
        如果 (dev.BAR[i].是64位 && i + 1 < 6) {
            PCI设备_写32(dev, 偏移 + 4, dev.BAR[i].高32位原值)
            i = i + 1
        }
        i = i + 1
    }
    // 恢复命令寄存器
    如果 (dev.已使能) {
        PCI_使能设备(dev)
    }
}

函数 PCI_解析PCIe能力(dev, 偏移) {
    定义 PCIe标志 = PCI设备_读16(dev, 偏移 + 2)
    dev.PCIe_版本 = PCIe标志 & 0x0F
    dev.PCIe_设备类型 = (PCIe标志 >> 4) & 0x0F
    dev.PCIe_有槽 = (PCIe标志 & 0x0100) != 0

    定义 设备能力 = PCI设备_读32(dev, 偏移 + 4)
    dev.PCIe_最大负载 = 128 << (设备能力 & 0x07)
    dev.PCIe_支持扩展标签 = (设备能力 & 0x0020) != 0
    dev.PCIe_支持FLR = (设备能力 & 0x10000000) != 0

    定义 链路能力 = PCI设备_读32(dev, 偏移 + 12)
    dev.PCIe_最大链路速度 = 链路能力 & 0x0F
    dev.PCIe_最大链路宽度 = (链路能力 >> 4) & 0x3F

    定义 链路状态 = PCI设备_读16(dev, 偏移 + 18)
    dev.PCIe_当前速度 = 链路状态 & 0x0F
    dev.PCIe_当前宽度 = (链路状态 >> 4) & 0x3F
}

// 第12部分: PCIe扩展能力扫描

函数 PCI_扫描扩展能力(dev) {
    如果 (!dev.是PCIe设备) { 返回 }

    定义 可变 偏移 = 0x100  // PCIe扩展能力起始于256
    定义 可变 安全计数 = 96
    定义 可变 扩展能力数 = 0

    当 (偏移 >= 0x100 && 偏移 < 0x1000 && 安全计数 > 0) {
        定义 头 = PCI设备_读32(dev, 偏移)
        如果 (头 == 0 || 头 == 0xFFFFFFFF) { 跳出 }

        定义 能力ID = 头 & 0xFFFF
        定义 版本 = (头 >> 16) & 0x0F
        定义 下一个 = (头 >> 20) & 0xFFC

        匹配 (能力ID) {
            PCIE_ECAP_AER => {
                dev.AER_偏移 = 偏移
                dev.支持AER = 真
                PCI_解析AER(dev, 偏移)
            }
            PCIE_ECAP_序列号 => {
                定义 低 = PCI设备_读32(dev, 偏移 + 4)
                定义 高 = PCI设备_读32(dev, 偏移 + 8)
                dev.序列号 = 低 | (高 << 32)
            }
            PCIE_ECAP_SRIOV => {
                dev.SRIOV_偏移 = 偏移
                dev.支持SRIOV = 真
                PCI_解析SRIOV(dev, 偏移)
                全局_SRIOV检测计数 = 全局_SRIOV检测计数 + 1
            }
            PCIE_ECAP_LTR => {
                dev.支持LTR = 真
            }
            PCIE_ECAP_ACS => {
                dev.支持ACS = 真
                dev.ACS_偏移 = 偏移
            }
            _ => {}
        }

        扩展能力数 = 扩展能力数 + 1
        如果 (下一个 == 0) { 跳出 }
        偏移 = 下一个
        安全计数 = 安全计数 - 1
    }

    dev.扩展能力数量 = 扩展能力数
    全局_扩展能力扫描计数 = 全局_扩展能力扫描计数 + 扩展能力数
}

函数 PCI_解析AER(dev, 偏移) {
    dev.AER_不可纠正状态 = PCI设备_读32(dev, 偏移 + 4)
    dev.AER_不可纠正掩码 = PCI设备_读32(dev, 偏移 + 8)
    dev.AER_可纠正状态 = PCI设备_读32(dev, 偏移 + 16)
    dev.AER_可纠正掩码 = PCI设备_读32(dev, 偏移 + 20)
}

函数 PCI_解析SRIOV(dev, 偏移) {
    定义 控制 = PCI设备_读16(dev, 偏移 + 8)
    dev.SRIOV_总VF数 = PCI设备_读16(dev, 偏移 + 14)
    dev.SRIOV_当前VF数 = PCI设备_读16(dev, 偏移 + 16)
    dev.SRIOV_VF偏移 = PCI设备_读16(dev, 偏移 + 20)
    dev.SRIOV_VF步长 = PCI设备_读16(dev, 偏移 + 22)
}

// 第13部分: 设备使能/禁用与总线主控管理

函数 PCI_使能设备(dev) {
    定义 cmd = PCI设备_读16(dev, PCI_REG_命令)
    定义 新cmd = cmd | PCI_CMD_IO使能 | PCI_CMD_内存使能

    // 清除SERR使能以防初始化期间虚假错误
    新cmd = 新cmd & ~PCI_CMD_SERR使能

    PCI设备_写16(dev, PCI_REG_命令, 新cmd)

    // 验证写入成功
    定义 验证 = PCI设备_读16(dev, PCI_REG_命令)
    如果 ((验证 & (PCI_CMD_IO使能 | PCI_CMD_内存使能)) != (PCI_CMD_IO使能 | PCI_CMD_内存使能)) {
        全局_BAR解析错误计数 = 全局_BAR解析错误计数 + 1
        返回 错误_设备故障
    }

    dev.已使能 = 真
    全局_设备使能计数 = 全局_设备使能计数 + 1
    返回 0
}

函数 PCI_禁用设备(dev) {
    // 先禁用中断
    如果 (dev.MSI_已使能) {
        PCI_禁用MSI(dev)
    }
    如果 (dev.MSIX_已使能) {
        PCI_禁用MSIX(dev)
    }

    定义 cmd = PCI设备_读16(dev, PCI_REG_命令)
    cmd = cmd & ~(PCI_CMD_IO使能 | PCI_CMD_内存使能 | PCI_CMD_总线主控)
    PCI设备_写16(dev, PCI_REG_命令, cmd)

    // 取消所有BAR映射
    定义 可变 i = 0
    当 (i < 6) {
        如果 (dev.BAR[i].已映射) {
            BAR_MMIO取消映射(dev, i)
        }
        i = i + 1
    }

    dev.已使能 = 假
    全局_设备禁用计数 = 全局_设备禁用计数 + 1
}

函数 PCI_使能总线主控(dev) {
    定义 cmd = PCI设备_读16(dev, PCI_REG_命令)
    如果 (cmd & PCI_CMD_总线主控) { 返回 }  // 已使能

    PCI设备_写16(dev, PCI_REG_命令, cmd | PCI_CMD_总线主控)

    // 设置延迟定时器 (改善总线仲裁公平性)
    定义 延迟 = PCI设备_读8(dev, PCI_REG_延迟定时器)
    如果 (延迟 < 64) {
        PCI设备_写8(dev, PCI_REG_延迟定时器, 64)
    }
}

函数 PCI_禁用MSI(dev) {
    如果 (!dev.支持MSI) { 返回 }
    定义 控制 = PCI设备_读16(dev, dev.MSI_偏移 + 2)
    PCI设备_写16(dev, dev.MSI_偏移 + 2, 控制 & ~MSI_CTRL_使能)
    dev.MSI_已使能 = 假
}

函数 PCI_禁用MSIX(dev) {
    如果 (!dev.支持MSIX) { 返回 }
    定义 控制 = PCI设备_读16(dev, dev.MSIX_偏移 + 2)
    PCI设备_写16(dev, dev.MSIX_偏移 + 2, (控制 & ~MSIX_CTRL_使能) | MSIX_CTRL_函数掩码)
    dev.MSIX_已使能 = 假
}

// 第14部分: BRAT AI设备识别与资源优化引擎
// BRAT (Bus Resource Allocation Theory) 核心推理:
//   特征向量: [BAR数量, MMIO总量, IO总量, 64位BAR比, 预取BAR比,
//              PCIe速度, 链路宽度, 能力数, VF数, 设备类代码]
//   通过AI总线进行设备分类、资源冲突预测、最优分配策略推导

函数 BAR_AI分析设备(dev) {
    定义 张量 = Tensor_创建(10)

    // 特征0: BAR数量归一化
    Tensor_写(张量, 0, dev.BAR数量 / 6.0)

    // 特征1: MMIO总量 (对数归一化)
    定义 可变 MMIO总量 = 0
    定义 可变 IO总量 = 0
    定义 可变 BAR64比 = 0.0
    定义 可变 预取比 = 0.0
    定义 可变 k = 0
    当 (k < dev.BAR数量) {
        如果 (dev.BAR[k].类型 == PCI_BAR_类型_内存) {
            MMIO总量 = MMIO总量 + dev.BAR[k].大小
            如果 (dev.BAR[k].是64位) { BAR64比 = BAR64比 + 1.0 }
            如果 (dev.BAR[k].是预取) { 预取比 = 预取比 + 1.0 }
        } 否则 {
            IO总量 = IO总量 + dev.BAR[k].大小
        }
        k = k + 1
    }
    如果 (dev.BAR数量 > 0) {
        BAR64比 = BAR64比 / dev.BAR数量
        预取比 = 预取比 / dev.BAR数量
    }

    Tensor_写(张量, 1, BRAT_对数归一(MMIO总量, 0x100000000))
    Tensor_写(张量, 2, BRAT_对数归一(IO总量, 0x10000))
    Tensor_写(张量, 3, BAR64比)
    Tensor_写(张量, 4, 预取比)

    // 特征5-6: PCIe链路信息
    如果 (dev.是PCIe设备) {
        Tensor_写(张量, 5, dev.PCIe_当前速度 / 5.0)
        Tensor_写(张量, 6, dev.PCIe_当前宽度 / 16.0)
    } 否则 {
        Tensor_写(张量, 5, 0.0)
        Tensor_写(张量, 6, 0.0)
    }

    // 特征7: 能力密度
    Tensor_写(张量, 7, dev.能力数量 / 32.0)

    // 特征8: SRIOV VF数
    如果 (dev.支持SRIOV) {
        Tensor_写(张量, 8, dev.SRIOV_总VF数 / 256.0)
    } 否则 {
        Tensor_写(张量, 8, 0.0)
    }

    // 特征9: 设备类代码归一化
    Tensor_写(张量, 9, dev.类代码 / 255.0)

    // AI推理: 设备分类与资源优化建议
    定义 设备分类 = AI总线_推理(全局AI总线, "BRAT_设备分类", 张量)
    定义 冲突风险 = AI总线_风险评分(全局AI总线, "BRAT_冲突预测", 张量)
    定义 资源效率 = AI总线_推理(全局AI总线, "BRAT_资源效率", 张量)

    dev.AI_设备分类 = 设备分类
    dev.AI_冲突风险 = 冲突风险
    dev.AI_资源效率 = 资源效率

    // 高冲突风险设备自动告警
    如果 (冲突风险 > 0.7) {
        定义 异常 = AI总线_异常检测(全局AI总线, "BRAT_资源冲突", 张量)
        dev.AI_需要重新分配 = 异常 > 0.5
    }

    全局_AI识别计数 = 全局_AI识别计数 + 1
    Tensor_释放(张量)
}

函数 BRAT_对数归一(值, 最大值) {
    如果 (值 <= 0) { 返回 0.0 }
    如果 (值 >= 最大值) { 返回 1.0 }
    // ln(值+1) / ln(最大值+1) 对数归一化
    定义 可变 近似对数值 = 0.0
    定义 可变 当前 = 值 + 1
    当 (当前 > 2) {
        当前 = 当前 / 2
        近似对数值 = 近似对数值 + 1.0
    }
    定义 可变 近似对数最大 = 0.0
    当前 = 最大值 + 1
    当 (当前 > 2) {
        当前 = 当前 / 2
        近似对数最大 = 近似对数最大 + 1.0
    }
    如果 (近似对数最大 == 0.0) { 返回 0.0 }
    返回 近似对数值 / 近似对数最大
}

函数 BRAT_计算资源分配分数(dev) {
    // R_opt(d) = Σ(BAR_i × W_type(i)) × P_align(i) / C_conflict(d)
    定义 可变 总分 = 0.0
    定义 可变 i = 0
    当 (i < dev.BAR数量) {
        定义 bar = dev.BAR[i]
        定义 可变 类型权重 = 1.0
        如果 (bar.类型 == PCI_BAR_类型_内存) { 类型权重 = 2.0 }
        如果 (bar.是预取) { 类型权重 = 类型权重 * 1.5 }
        如果 (bar.是64位) { 类型权重 = 类型权重 * 1.2 }

        // 对齐惩罚: 未对齐到自然边界扣分
        定义 可变 对齐因子 = 1.0
        如果 (bar.大小 > 0 && (bar.基地址 & (bar.大小 - 1)) != 0) {
            对齐因子 = 0.5
        }

        总分 = 总分 + (bar.大小 * 类型权重 * 对齐因子)
        i = i + 1
    }

    // 冲突度归一化
    定义 可变 冲突度 = 1.0
    如果 (dev.AI_冲突风险 > 0) {
        冲突度 = 1.0 + dev.AI_冲突风险 * 2.0
    }

    返回 总分 / 冲突度
}

// 第15部分: 统计诊断与完整设备初始化流程

函数 BAR_获取统计信息() {
    返回 {
        BAR解析总数: 全局_BAR解析总数,
        IO_BAR计数: 全局_IO_BAR计数,
        内存BAR计数: 全局_内存BAR计数,
        六十四位BAR计数: 全局_64位BAR计数,
        预取BAR计数: 全局_预取BAR计数,
        能力扫描总数: 全局_能力扫描总数,
        MSI配置计数: 全局_MSI配置计数,
        MSIX配置计数: 全局_MSIX配置计数,
        电源转换计数: 全局_电源转换计数,
        PCIe设备计数: 全局_PCIe设备计数,
        MMIO映射总字节: 全局_MMIO映射总字节,
        IO空间总字节: 全局_IO空间总字节,
        BAR冲突计数: 全局_BAR冲突计数,
        设备使能计数: 全局_设备使能计数,
        设备禁用计数: 全局_设备禁用计数,
        AI识别计数: 全局_AI识别计数,
        扩展能力扫描: 全局_扩展能力扫描计数,
        SRIOV检测数: 全局_SRIOV检测计数,
        错误计数: 全局_BAR解析错误计数,
        最大解析延迟: 全局_资源分配最大延迟
    }
}

函数 BAR_诊断设备(dev) {
    定义 可变 问题列表 = []

    // 检查BAR冲突
    定义 可变 i = 0
    当 (i < dev.BAR数量) {
        如果 (dev.BAR[i].有冲突) {
            问题列表 = 问题列表 + ["BAR" + i + "与设备" + dev.BAR[i].冲突设备 + "地址冲突"]
        }
        如果 (dev.BAR[i].大小 == 0 && dev.BAR[i].基地址 != 0) {
            问题列表 = 问题列表 + ["BAR" + i + "大小探测异常"]
        }
        i = i + 1
    }

    // 检查PCIe链路降级
    如果 (dev.是PCIe设备) {
        如果 (dev.PCIe_当前速度 < dev.PCIe_最大链路速度) {
            问题列表 = 问题列表 + ["PCIe链路速度降级: 当前Gen" + dev.PCIe_当前速度 + " 最大Gen" + dev.PCIe_最大链路速度]
        }
        如果 (dev.PCIe_当前宽度 < dev.PCIe_最大链路宽度) {
            问题列表 = 问题列表 + ["PCIe链路宽度降级: 当前x" + dev.PCIe_当前宽度 + " 最大x" + dev.PCIe_最大链路宽度]
        }
    }

    // 检查AER错误
    如果 (dev.支持AER && dev.AER_不可纠正状态 != 0) {
        问题列表 = 问题列表 + ["存在不可纠正AER错误: 0x" + dev.AER_不可纠正状态]
    }

    // AI冲突风险
    如果 (dev.AI_冲突风险 > 0.5) {
        问题列表 = 问题列表 + ["AI检测高资源冲突风险: " + dev.AI_冲突风险]
    }

    返回 {
        设备BDF: dev.BDF,
        BAR数量: dev.BAR数量,
        能力数量: dev.能力数量,
        是PCIe: dev.是PCIe设备,
        电源状态: dev.PM_当前状态,
        问题数量: 问题列表.长度,
        问题列表: 问题列表,
        资源分配分数: BRAT_计算资源分配分数(dev),
        AI分类: dev.AI_设备分类
    }
}

函数 PCI_完整设备初始化(dev) {
    // 第1步: 解析BAR资源
    PCI_解析BAR(dev)

    // 第2步: 扫描传统能力链
    PCI_扫描能力(dev)

    // 第3步: 扫描PCIe扩展能力
    PCI_扫描扩展能力(dev)

    // 第4步: AI设备分析
    BAR_AI分析设备(dev)

    // 第5步: 使能设备
    PCI_使能设备(dev)
    PCI_使能总线主控(dev)

    // 第6步: 唤醒至D0 (如果在低功耗状态)
    如果 (dev.支持电源管理 && dev.PM_当前状态 != PCI_PM_状态_D0) {
        PCI_设置电源状态(dev, PCI_PM_状态_D0)
    }

    // 第7步: 映射第一个内存BAR (驱动通常需要)
    定义 可变 首个内存BAR = -1
    定义 可变 m = 0
    当 (m < dev.BAR数量) {
        如果 (dev.BAR[m].类型 == PCI_BAR_类型_内存 && dev.BAR[m].大小 > 0) {
            首个内存BAR = m
            跳出
        }
        m = m + 1
    }
    如果 (首个内存BAR >= 0) {
        BAR_MMIO映射(dev, 首个内存BAR)
    }

    返回 0
}

函数 BAR_重置统计信息() {
    全局_BAR解析总数 = 0
    全局_IO_BAR计数 = 0
    全局_内存BAR计数 = 0
    全局_64位BAR计数 = 0
    全局_预取BAR计数 = 0
    全局_能力扫描总数 = 0
    全局_MSI配置计数 = 0
    全局_MSIX配置计数 = 0
    全局_电源转换计数 = 0
    全局_PCIe设备计数 = 0
    全局_MMIO映射总字节 = 0
    全局_IO空间总字节 = 0
    全局_BAR冲突计数 = 0
    全局_设备使能计数 = 0
    全局_设备禁用计数 = 0
    全局_AI识别计数 = 0
    全局_扩展能力扫描计数 = 0
    全局_SRIOV检测计数 = 0
    全局_BAR解析错误计数 = 0
    全局_资源分配最大延迟 = 0
}

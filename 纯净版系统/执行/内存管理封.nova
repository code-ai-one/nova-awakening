// §4 内存管理封装

函数 系统调用_Nova内存映射(addr, length, prot, flags, fd, offset) {
    返回 系统调用6(SYS_Nova内存映射, addr, length, prot, flags, fd, offset)
}

函数 系统调用_munmap(addr, length) {
    返回 系统调用2(SYS_munmap, addr, length)
}

函数 系统调用_mprotect(addr, length, prot) {
    返回 系统调用3(SYS_mprotect, addr, length, prot)
}

函数 系统调用_mremap(old_addr, old_size, new_size, flags) {
    返回 系统调用4(SYS_mremap, old_addr, old_size, new_size, flags)
}

函数 系统调用_madvise(addr, length, advice) {
    返回 系统调用3(SYS_madvise, addr, length, advice)
}

函数 系统调用_brk(addr) {
    返回 系统调用1(SYS_brk, addr)
}

函数 系统调用_memfd_create(name, flags) {
    返回 系统调用2(SYS_memfd_create, name, flags)
}

// 匿名Nova内存映射快捷方式(分配内存)
函数 平台_匿名Nova内存映射(大小) {
    返回 系统调用_Nova内存映射(0, 大小, PROT_READ | PROT_WRITE, MAP_PRIVATE | MAP_ANONYMOUS, -1, 0)
}

// §5 进程/线程封装

函数 系统调用_fork() {
    // RISC-V没有fork, 用clone模拟: clone(SIGCHLD, 0, 0, 0, 0)
    返回 系统调用5(SYS_clone, SIGCHLD, 0, 0, 0, 0)
}

函数 系统调用_exit(code) {
    系统调用1(SYS_exit_group, code)
}

函数 系统调用_waitpid(pid, status, options) {
    返回 系统调用4(SYS_wait4, pid, status, options, 0)
}

函数 系统调用_kill(pid, sig) {
    返回 系统调用2(SYS_kill, pid, sig)
}

函数 系统调用_getpid() {
    返回 系统调用0(SYS_getpid)
}

函数 系统调用_gettid() {
    返回 系统调用0(SYS_gettid)
}

函数 系统调用_execve(路径, argv, envp) {
    返回 系统调用3(SYS_execve, 路径, argv, envp)
}

函数 系统调用_clone_线程(fn, stack, flags, arg) {
    // 创建线程: clone(flags|CLONE_VM|CLONE_FS|..., stack_top)
    定义 thread_flags = flags | 0x100 | 0x200 | 0x400 | 0x800 | 0x10000  // VM|FS|FILES|SIGHAND|THREAD
    返回 系统调用5(SYS_clone, thread_flags | SIGCHLD, stack, 0, 0, 0)
}

函数 系统调用_Nova快速锁(uaddr, op, val, timeout) {
    返回 系统调用4(SYS_Nova快速锁, uaddr, op, val, timeout)
}

函数 系统调用_sched_yield() {
    返回 系统调用0(SYS_sched_yield)
}

函数 系统调用_prctl(option, arg2, arg3, arg4, arg5) {
    返回 系统调用5(SYS_prctl, option, arg2, arg3, arg4, arg5)
}


// Nova · 跨语言语言前端 · C
// 职责: 解析C源文件骨架,提取函数/结构/枚举/typedef/宏定义信息
// 层级: 跨语言主线第4步 — 语言骨架解析(C)

导入("../../../../标准库/基础.nova")
导入("../../统一语义/统一语义图.nova")

定义 C声明_函数     = 0
定义 C声明_结构     = 1
定义 C声明_枚举     = 2
定义 C声明_Typedef  = 3
定义 C声明_宏       = 4
定义 C声明_全局变量 = 5
定义 C声明_Include  = 6

函数 C声明_创建(类型, 名称) {
    返回 [类型, 名称, "", 0]
}

函数 C模块_创建(路径) {
    返回 [路径, [], [], []]
}

函数 C模块_声明(m) { 返回 m[1] }
函数 C模块_Include(m) { 返回 m[2] }

函数 C前端_解析骨架(源码, 文件路径) {
    定义 模块 = C模块_创建(文件路径)
    定义 可变 位置 = 0
    定义 总长 = 字节长度(源码)
    定义 可变 行号 = 1

    当 (位置 < 总长) {
        当 (行尾 < 总长 且 字节取(源码, 行尾) != 字符_换行) { 行尾 = 行尾 + 1 }
        定义 行 = 子串(源码, 位置, 行尾 - 位置)
        位置 = 行尾 + 1
        定义 已裁剪 = _C_去首空白(行)

        如果 (_C_行开头(已裁剪, "#include")) {
            追加(模块[2], 已裁剪)
        }
        如果 (_C_行开头(已裁剪, "#define ")) {
            定义 名 = _C_提取宏名(已裁剪)
            定义 声明 = C声明_创建(C声明_宏, 名)
            声明[3] = 行号
            追加(模块[1], 声明)
        }
        如果 (_C_行开头(已裁剪, "struct ")) {
            定义 名 = _C_提取词(已裁剪, 7)
            定义 声明 = C声明_创建(C声明_结构, 名)
            声明[3] = 行号
            追加(模块[1], 声明)
        }
        如果 (_C_行开头(已裁剪, "enum ")) {
            定义 名 = _C_提取词(已裁剪, 5)
            定义 声明 = C声明_创建(C声明_枚举, 名)
            声明[3] = 行号
            追加(模块[1], 声明)
        }
        如果 (_C_行开头(已裁剪, "typedef ")) {
            定义 声明 = C声明_创建(C声明_Typedef, 已裁剪)
            声明[3] = 行号
            追加(模块[1], 声明)
        }

        行号 = 行号 + 1
    }
    返回 模块
}

函数 C前端_到语义图(模块, 语义图) {
    定义 声明列表 = 模块[1]
    定义 可变 i = 0
    当 (i < 计数(声明列表)) {
        定义 d = 声明列表[i]
        定义 节点 = 语义节点_创建(0, d[0], d[1])
        语义节点_设源位置(节点, 模块[0])
        语义图_添加节点(语义图, 节点)
        i = i + 1
    }
}

函数 C模块_打印(模块) {
    打印文本(字符串拼接("═══ C模块: ", 模块[0]))
    打印文本(字符串拼接("  声明数: ", 转字符串(计数(模块[1]))))
    打印文本(字符串拼接("  include数: ", 转字符串(计数(模块[2]))))
}

函数 _C_去首空白(s) {
    定义 可变 i = 0
    定义 l = 字节长度(s)
    当 (i < l 且 (字节取(s, i) == 字符_空格 或 字节取(s, i) == 字符_制表)) { i = i + 1 }
    如果 (i >= l) { 返回 "" }
    返回 子串(s, i, l - i)
}

函数 _C_行开头(行, 前缀) {
    定义 pl = 字节长度(前缀)
    如果 (字节长度(行) < pl) { 返回 假 }
    返回 子串(行, 0, pl) == 前缀
}

函数 _C_提取宏名(行) {
    定义 可变 位置 = 8
    定义 l = 字节长度(行)
    当 (位置 < l 且 字节取(行, 位置) == 字符_空格) { 位置 = 位置 + 1 }
    定义 起 = 位置
    当 (位置 < l 且 字节取(行, 位置) != 字符_空格 且 字节取(行, 位置) != 字符_左圆括) { 位置 = 位置 + 1 }
    如果 (位置 > 起) { 返回 子串(行, 起, 位置 - 起) }
    返回 "MACRO"
}

函数 _C_提取词(行, 起始) {
    定义 可变 位置 = 起始
    定义 l = 字节长度(行)
    当 (位置 < l 且 字节取(行, 位置) == 字符_空格) { 位置 = 位置 + 1 }
    定义 起 = 位置
    当 (位置 < l 且 字节取(行, 位置) != 字符_空格 且 字节取(行, 位置) != 字符_左花括 且 字节取(行, 位置) != 字符_分号) { 位置 = 位置 + 1 }
    如果 (位置 > 起) { 返回 子串(行, 起, 位置 - 起) }
    返回 "unknown"
}

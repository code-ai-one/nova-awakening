// NovaOS AI信号异常检测 — 先天AI特性
// Phase: P2 | AI融入信号子系统
// 核心算法:
//   1. 信号频率追踪: 每进程每信号类型的EMA频率
//   2. 崩溃模式检测: SIGSEGV/SIGBUS/SIGFPE连续出现→进程不稳定
//   3. 信号风暴检测: 短时间大量信号→可能的fork炸弹或DoS
//   4. 自动处置建议: 频繁崩溃的进程建议降优先级或杀死

外部 进程_设置nice
外部 进程_发送信号

定义 信号_SEGV = 11
定义 信号_BUS = 7
定义 信号_FPE = 8
定义 信号_ABRT = 6
定义 信号_ILL = 4

结构 信号画像 {
    pid,
    致命信号EMA,    // u64 致命信号频率EMA(×1024)
    总信号EMA,    // u64 所有信号频率EMA(×1024)
    连续崩溃数,    // u32 连续致命信号计数
    上次信号时间,
    窗口内信号数,
    窗口起始,
    不稳定,    // u8 0=稳定 1=不稳定
    建议动作,    // u8 0=无 1=降优先级 2=杀死
}

定义 可变 信号画像表 = []
定义 可变 信号风暴_阈值 = 100      // 1秒内>100个信号=风暴
定义 可变 AI信号_已初始化 = 假

函数 AI信号_初始化() {
    AI信号_已初始化 = 真
    内核信息("AI信号异常检测: 崩溃模式+信号风暴+自动处置")
}

// 核心: 记录信号并检测异常

函数 AI信号_记录(PID, 信号号) {
    如果 (!AI信号_已初始化) { 返回 }
    定义 画像 = AI信号_获取或创建(PID)
    定义 现在 = 读取毫秒()

    // 1. 更新窗口信号计数
    画像.窗口内信号数 = 画像.窗口内信号数 + 1
    如果 (现在 - 画像.窗口起始 > 1000) {
        // 更新总信号频率EMA
        画像.总信号EMA = (画像.总信号EMA * 922 + 画像.窗口内信号数 * 1024 * 102) / (1024 * 1024)
        画像.窗口内信号数 = 0
        画像.窗口起始 = 现在
    }
    画像.上次信号时间 = 现在

    // 2. 致命信号检测
    如果 (AI信号_是致命(信号号)) {
        画像.连续崩溃数 = 画像.连续崩溃数 + 1
        画像.致命信号EMA = (画像.致命信号EMA * 922 + 1024 * 102) / 1024

        如果 (画像.连续崩溃数 >= 5) {
            画像.不稳定 = 1
            画像.建议动作 = 2   // 建议杀死
            内核警告("AI信号: PID=" + 整数转字符串(PID) + " 连续崩溃" + 整数转字符串(画像.连续崩溃数) + "次, 建议杀死")
        } 否则 如果 (画像.连续崩溃数 >= 3) {
            画像.不稳定 = 1
            画像.建议动作 = 1   // 建议降优先级
            内核警告("AI信号: PID=" + 整数转字符串(PID) + " 频繁崩溃, 建议降优先级")
        }
    } 否则 {
        // 非致命信号: 重置连续崩溃计数
        画像.连续崩溃数 = 0
    }

    // 3. 信号风暴检测
    如果 (画像.窗口内信号数 > 信号风暴_阈值) {
        内核警告("AI信号: PID=" + 整数转字符串(PID) + " 信号风暴! (" + 整数转字符串(画像.窗口内信号数) + "/秒)")
    }
}

函数 AI信号_是致命(信号号) {
    返回 信号号 == 信号_SEGV || 信号号 == 信号_BUS || 信号号 == 信号_FPE || 信号号 == 信号_ABRT || 信号号 == 信号_ILL
}

函数 AI信号_获取建议(PID) {
    定义 画像 = AI信号_查找(PID)
    如果 (画像 == 空) { 返回 0 }
    返回 画像.建议动作
}

函数 AI信号_是不稳定(PID) {
    定义 画像 = AI信号_查找(PID)
    如果 (画像 == 空) { 返回 假 }
    返回 画像.不稳定 == 1
}

// 画像管理

函数 AI信号_查找(pid) {
    定义 可变 i = 0
    当 (i < 计数(信号画像表)) {
        如果 (信号画像表[i].pid == pid) { 返回 信号画像表[i] }
        i = i + 1
    }
    返回 空
}

函数 AI信号_获取或创建(pid) {
    定义 已有 = AI信号_查找(pid)
    如果 (已有 != 空) { 返回 已有 }
    定义 新画像 = 信号画像 {}
    新画像.pid = pid
    新画像.窗口起始 = 读取毫秒()
    追加(信号画像表, 新画像)
    返回 新画像
}

// 进程退出时清理画像

函数 AI信号_进程退出(pid) {
    定义 可变 i = 0
    当 (i < 计数(信号画像表)) {
        如果 (信号画像表[i].pid == pid) {
            链表_删除(信号画像表, i)
            返回
        }
        i = i + 1
    }
}

// 自动处置执行 (由调度器/信号分发调用)

函数 AI信号_执行建议(pid) {
    定义 画像 = AI信号_查找(pid)
    如果 (画像 == 空) { 返回 }
    如果 (画像.建议动作 == 0) { 返回 }

    如果 (画像.建议动作 == 1) {
        // 降低优先级
        进程_设置nice(pid, 19)   // 设为最低优先级
        内核信息("AI信号: 已降低PID=" + 整数转字符串(pid) + "优先级")
        画像.建议动作 = 0  // 已执行
    } 否则 如果 (画像.建议动作 == 2) {
        // 杀死进程
        进程_发送信号(pid, 9)   // SIGKILL
        内核警告("AI信号: 已杀死不稳定进程PID=" + 整数转字符串(pid))
        画像.建议动作 = 0
    }
}

// 全局信号统计

定义 可变 AI信号_总记录数 = 0
定义 可变 AI信号_致命信号总数 = 0
定义 可变 AI信号_风暴检测数 = 0

函数 AI信号_全局统计() {
    定义 可变 不稳定数 = 0
    定义 可变 i = 0
    当 (i < 计数(信号画像表)) {
        如果 (信号画像表[i].不稳定 == 1) {
            不稳定数 = 不稳定数 + 1
        }
        i = i + 1
    }
    返回 [计数(信号画像表), 不稳定数, AI信号_总记录数, AI信号_致命信号总数, AI信号_风暴检测数]
}

// 不稳定进程列表

函数 AI信号_不稳定进程列表() {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(信号画像表)) {
        如果 (信号画像表[i].不稳定 == 1) {
            追加(结果, [信号画像表[i].pid, 信号画像表[i].连续崩溃数, 信号画像表[i].建议动作])
        }
        i = i + 1
    }
    返回 结果
}

函数 AI信号_重置画像(pid) {
    定义 画像 = AI信号_查找(pid)
    如果 (画像 == 空) { 返回 }
    画像.连续崩溃数 = 0
    画像.不稳定 = 0
    画像.建议动作 = 0
    画像.致命信号EMA = 0
    画像.总信号EMA = 0
}


函数 AI信号_动作名(动作) {
    如果 (动作 == 0) { 返回 "none" }
    如果 (动作 == 1) { 返回 "throttle" }
    如果 (动作 == 2) { 返回 "Nova运行时实例" }
    如果 (动作 == 3) { 返回 "kill" }
    返回 "unknown"
}

函数 AI信号_完整统计() {
    返回 [计数(信号画像表)]
}

// 感知消息语义装载
// 将消息、语义校验、解析与地址辅助能力接回 AI 运行时与桥接路径。

导入("./网络消息管消.nova")
导入("./语义检查.nova")
导入("./验证逻辑.nova")
导入("./查看接口.nova")
导入("./解析.nova")
导入("./地址辅助函数.nova")
导入("./国标码初始化.nova")
导入("./原生原生语义.nova")

函数 感知消息语义装载_模块清单() {
    返回 [
        "./网络消息管消.nova",
        "./语义检查.nova",
        "./验证逻辑.nova",
        "./查看接口.nova",
        "./解析.nova",
        "./地址辅助函数.nova",
        "./国标码初始化.nova",
        "./原生原生语义.nova"
    ]
}

函数 感知消息语义装载_统计() {
    返回 {
        模块数: 计数(感知消息语义装载_模块清单())
    }
}

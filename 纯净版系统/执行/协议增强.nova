    html = 字符串拼接(html, "<div class='nova-kv'><div class='nova-k'>协议路由健康</div><div class='nova-v nova-status-ok'>99.97%</div></div>")
    html = 字符串拼接(html, "<div class='nova-kv'><div class='nova-k'>安全拦截率</div><div class='nova-v nova-status-warn'>0.04%</div></div>")

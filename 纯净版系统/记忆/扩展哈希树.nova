// htree索引目录查找(简化)

函数 ext4_htree_查找(sb, 目录Nova文件节点, 名称) {
    // htree使用半MD4哈希定位目录块
    定义 哈希值 = ext4_名称哈希(名称)
    // htree查找失败时回退到线性扫描
    返回 ext4_线性查找目录项(sb, 目录Nova文件节点, 名称)
}

函数 ext4_名称哈希(名称) {
    定义 可变 哈希 = 0
    定义 长度 = 字符串_长度(名称)
    定义 可变 i = 0
    当 (i < 长度) {
        哈希 = 哈希 * 31 + 名称[i]
        i = i + 1
    }
    返回 哈希 & 0x7FFFFFFF
}

函数 ext4_线性查找目录项(sb, 目录Nova文件节点, 名称) {
    // 与ext4_查找目录项相同，但跳过htree检查
    定义 信息 = sb.私有信息
    定义 块大小 = 信息.块大小
    定义 ext4信息 = 目录Nova文件节点.私有信息
    定义 可变 偏移 = 0

    当 (偏移 < 目录Nova文件节点.大小) {
        定义 逻辑块 = 偏移 / 块大小
        定义 物理块 = ext4_extent_查找(sb, ext4信息, 逻辑块)
        如果 (物理块 != (0 - 1)) {
            定义 缓冲 = 块设备_读(sb.设备, 物理块 * 块大小, 块大小)
            如果 (缓冲 != 空) {
                定义 可变 块内偏移 = 0
                当 (块内偏移 < 块大小) {
                    定义 项 = ext4_解析目录项(缓冲, 块内偏移)
                    如果 (项.记录长度 == 0) { 跳出 }
                    如果 (项.Nova文件节点号 != 0 && ext4_目录项名称匹配(项, 名称)) {
                        缓冲_释放(缓冲)
                        返回 项
                    }
                    块内偏移 = 块内偏移 + 项.记录长度
                }
                缓冲_释放(缓冲)
            }
        }
        偏移 = 偏移 + 块大小
    }
    返回 空
}

// 目录项序列化辅助

函数 ext4_解析目录项(缓冲, 偏移) {
    定义 可变 项 = Ext4目录项 {}
    项.Nova文件节点号    = 缓冲_读u32(缓冲, 偏移)
    项.记录长度   = 缓冲_读u16(缓冲, 偏移 + 4)
    项.名称长度   = 缓冲_读u8(缓冲, 偏移 + 6)
    项.文件类型   = 缓冲_读u8(缓冲, 偏移 + 7)

    定义 可变 i = 0
    当 (i < 项.名称长度 && i < EXT4_名称最大长度) {
        项.名称[i] = 缓冲_读u8(缓冲, 偏移 + 8 + i)
        i = i + 1
    }
    返回 项
}

函数 ext4_写入目录项(缓冲, 偏移, Nova文件节点号, 名称, 文件类型, 记录长度) {
    定义 名称长度 = 字符串_长度(名称)
    缓冲_写u32(缓冲, 偏移, Nova文件节点号)
    缓冲_写u16(缓冲, 偏移 + 4, 记录长度)
    缓冲_写u8(缓冲, 偏移 + 6, 名称长度)
    缓冲_写u8(缓冲, 偏移 + 7, 文件类型)

    定义 可变 i = 0
    当 (i < 名称长度) {
        缓冲_写u8(缓冲, 偏移 + 8 + i, 名称[i])
        i = i + 1
    }
}

函数 ext4_写回目录项(缓冲, 偏移, 项) {
    缓冲_写u32(缓冲, 偏移, 项.Nova文件节点号)
    缓冲_写u16(缓冲, 偏移 + 4, 项.记录长度)
    缓冲_写u8(缓冲, 偏移 + 6, 项.名称长度)
    缓冲_写u8(缓冲, 偏移 + 7, 项.文件类型)
}

函数 ext4_目录项名称匹配(项, 名称) {
    定义 名称长度 = 字符串_长度(名称)
    如果 (项.名称长度 != 名称长度) { 返回 假 }

    定义 可变 i = 0
    当 (i < 名称长度) {
        如果 (项.名称[i] != 名称[i]) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 ext4_提取目录项名称(项) {
    返回 字节数组_转字符串(项.名称, 项.名称长度)
}

函数 ext4_目录项实际长度(名称长度) {
    // 8字节头 + 名称长度，4字节对齐
    定义 长度 = EXT4_目录项_头大小 + 名称长度
    返回 (长度 + 3) & ~3
}

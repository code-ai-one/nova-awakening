// Nova标准库 — 循环神经网络 (RNN/LSTM/GRU)
// 序列建模核心组件 — 整数定点实现
// 对标 nova-forth 的 rnn/ 模块

导入("../基础.nova")
导入("./基础/数学库.nova")
导入("../../运行时/原语桩.nova")

定义 rnn精度 = 1000

// 简单 RNN 单元
// h_t = tanh(W_hh * h_{t-1} + W_xh * x_t + b_h)
// 参数: [隐藏维度, 输入维度, W_xh, W_hh, b_h]

函数 rnn_创建(输入维, 隐藏维, 种子) { 定义 可变 权重_输入隐藏 = []
 定义 可变 权重_隐藏隐藏 = []
 定义 可变 b_h = []
 定义 可变 s = 种子
 // Xavier 初始化
 定义 范围 = rnn_开方(6 * rnn精度 / (输入维 + 隐藏维))
 定义 可变 i = 0
 当 (i < 隐藏维 * 输入维) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 追加(权重_输入隐藏, (s % (2 * 范围 + 1)) - 范围)
 i = i + 1
 }
 i = 0
 当 (i < 隐藏维 * 隐藏维) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 追加(权重_隐藏隐藏, (s % (2 * 范围 + 1)) - 范围)
 i = i + 1
 }
 i = 0
 当 (i < 隐藏维) { 追加(b_h, 0) i = i + 1 }
 返回 [隐藏维, 输入维, 权重_输入隐藏, 权重_隐藏隐藏, b_h]
}

// RNN 前向一步
函数 rnn_步进(单元, 输入, 隐藏) { 定义 h维 = 单元[0]
 定义 x维 = 单元[1]
 定义 权重_输入隐藏 = 单元[2]
 定义 权重_隐藏隐藏 = 单元[3]
 定义 b_h = 单元[4]
 定义 可变 新h = []
 定义 可变 i = 0
 当 (i < h维) { 定义 可变 和 = b_h[i]
 // W_xh * x
 定义 可变 j = 0
 当 (j < x维) {
 和 = 和 + 权重_输入隐藏[i * x维 + j] * 输入[j] / rnn精度
 j = j + 1
 }
 // W_hh * h
 j = 0
 当 (j < h维) {
 和 = 和 + 权重_隐藏隐藏[i * h维 + j] * 隐藏[j] / rnn精度
 j = j + 1
 }
 // tanh 近似
 追加(新h, 循环网络_双曲正切(和))
 i = i + 1
 }
 返回 新h
}

// RNN 处理整个序列
函数 rnn_序列(单元, 输入序列) { 定义 h维 = 单元[0]
 // 初始隐藏状态 = 0
 定义 可变 h = []
 定义 可变 i = 0
 当 (i < h维) { 追加(h, 0) i = i + 1 }
 // 逐步处理
 定义 可变 所有h = []
 i = 0
 当 (i < 计数(输入序列)) {
 h = rnn_步进(单元, 输入序列[i], h)
 追加(所有h, h)
 i = i + 1
 }
 返回 [h, 所有h]
}

// LSTM 单元
// f_t = σ(W_f·[h_{t-1}, x_t] + b_f) 遗忘门
// i_t = σ(W_i·[h_{t-1}, x_t] + b_i) 输入门
// c̃_t = tanh(W_c·[h_{t-1}, x_t] + b_c) 候选细胞
// c_t = f_t ⊙ c_{t-1} + i_t ⊙ c̃_t 细胞状态
// o_t = σ(W_o·[h_{t-1}, x_t] + b_o) 输出门
// h_t = o_t ⊙ tanh(c_t) 隐藏状态

函数 lstm_创建(输入维, 隐藏维, 种子) { 定义 合维 = 输入维 + 隐藏维
 定义 范围 = rnn_开方(6 * rnn精度 / 合维)
 定义 可变 s = 种子
 // 4组权重: 遗忘门, 输入门, 候选, 输出门
 定义 可变 权重 = []
 定义 可变 i = 0
 当 (i < 4 * 隐藏维 * 合维) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 追加(权重, (s % (2 * 范围 + 1)) - 范围)
 i = i + 1
 }
 // 4组偏置
 定义 可变 偏置 = []
 i = 0
 当 (i < 4 * 隐藏维) { 如果 (i < 隐藏维) {
 追加(偏置, rnn精度)
 } 否则 {
 追加(偏置, 0)
 }
 i = i + 1
 }
 返回 [隐藏维, 输入维, 权重, 偏置]
}

// LSTM 前向一步
函数 lstm_步进(单元, 输入, 隐藏, 细胞) { 定义 h维 = 单元[0]
 定义 x维 = 单元[1]
 定义 权重 = 单元[2]
 定义 偏置 = 单元[3]
 定义 合维 = x维 + h维
 // 拼接 [h, x]
 定义 可变 拼接 = []
 定义 可变 i = 0
 当 (i < h维) { 追加(拼接, 隐藏[i]) i = i + 1 }
 i = 0
 当 (i < x维) { 追加(拼接, 输入[i]) i = i + 1 }
 // 计算4个门
 定义 可变 f门 = []
 定义 可变 i门 = []
 定义 可变 c候选 = []
 定义 可变 o门 = []
 i = 0
 当 (i < h维) { 定义 可变 fv = 偏置[i]
 定义 可变 iv = 偏置[h维 + i]
 定义 可变 cv = 偏置[2 * h维 + i]
 定义 可变 ov = 偏置[3 * h维 + i]
 定义 可变 j = 0
 当 (j < 合维) { 定义 拼值 = 拼接[j]
 fv = fv + 权重[(0 * h维 + i) * 合维 + j] * 拼值 / rnn精度
 iv = iv + 权重[(1 * h维 + i) * 合维 + j] * 拼值 / rnn精度
 cv = cv + 权重[(2 * h维 + i) * 合维 + j] * 拼值 / rnn精度
 ov = ov + 权重[(3 * h维 + i) * 合维 + j] * 拼值 / rnn精度
 j = j + 1
 }
 追加(f门, 循环网络_S形(fv))
 追加(i门, 循环网络_S形(iv))
 追加(c候选, 循环网络_双曲正切(cv))
 追加(o门, 循环网络_S形(ov))
 i = i + 1
 }
 // 更新细胞状态: c = f*c_prev + i*c_candidate
 定义 可变 新c = []
 i = 0
 当 (i < h维) {
 追加(新c, f门[i] * 细胞[i] / rnn精度 + i门[i] * c候选[i] / rnn精度)
 i = i + 1
 }
 // 更新隐藏状态: h = o * tanh(c)
 定义 可变 新h = []
 i = 0
 当 (i < h维) {
 追加(新h, o门[i] * 循环网络_双曲正切(新c[i]) / rnn精度)
 i = i + 1
 }
 返回 [新h, 新c]
}

// LSTM 处理序列
函数 lstm_序列(单元, 输入序列) { 定义 h维 = 单元[0]
 定义 可变 h = []
 定义 可变 c = []
 定义 可变 i = 0
 当 (i < h维) { 追加(h, 0) 追加(c, 0) i = i + 1 }
 定义 可变 所有h = []
 i = 0
 当 (i < 计数(输入序列)) { 定义 结果 = lstm_步进(单元, 输入序列[i], h, c)
 h = 结果[0]
 c = 结果[1]
 追加(所有h, h)
 i = i + 1
 }
 返回 [h, c, 所有h]
}

// GRU 单元 (简化版)
// z = σ(W_z·[h,x]) 更新门
// r = σ(W_r·[h,x]) 重置门
// h̃ = tanh(W_h·[r⊙h, x]) 候选
// h = (1-z)⊙h + z⊙h̃ 输出

函数 gru_创建(输入维, 隐藏维, 种子) { 定义 合维 = 输入维 + 隐藏维
 定义 范围 = rnn_开方(6 * rnn精度 / 合维)
 定义 可变 s = 种子
 定义 可变 权重 = []
 定义 可变 i = 0
 当 (i < 3 * 隐藏维 * 合维) {
 s = (s * 1103515245 + 12345) & 0x7FFFFFFF
 追加(权重, (s % (2 * 范围 + 1)) - 范围)
 i = i + 1
 }
 定义 可变 偏置 = []
 i = 0
 当 (i < 3 * 隐藏维) { 追加(偏置, 0) i = i + 1 }
 返回 [隐藏维, 输入维, 权重, 偏置]
}

函数 gru_步进(单元, 输入, 隐藏) { 定义 h维 = 单元[0]
 定义 x维 = 单元[1]
 定义 合维 = x维 + h维
 // 拼接 [h, x]
 定义 可变 拼接 = []
 定义 可变 i = 0
 当 (i < h维) { 追加(拼接, 隐藏[i]) i = i + 1 }
 i = 0
 当 (i < x维) { 追加(拼接, 输入[i]) i = i + 1 }
 // z门和r门
 定义 可变 z门 = []
 定义 可变 r门 = []
 i = 0
 当 (i < h维) { 定义 可变 zv = 单元[3][i]
 定义 可变 rv = 单元[3][h维 + i]
 定义 可变 j = 0
 当 (j < 合维) {
 zv = zv + 单元[2][(0 * h维 + i) * 合维 + j] * 拼接[j] / rnn精度
 rv = rv + 单元[2][(1 * h维 + i) * 合维 + j] * 拼接[j] / rnn精度
 j = j + 1
 }
 追加(z门, 循环网络_S形(zv))
 追加(r门, 循环网络_S形(rv))
 i = i + 1
 }
 // 候选 h̃: 拼接 [r⊙h, x]
 定义 可变 拼接2 = []
 i = 0
 当 (i < h维) { 追加(拼接2, r门[i] * 隐藏[i] / rnn精度) i = i + 1 }
 i = 0
 当 (i < x维) { 追加(拼接2, 输入[i]) i = i + 1 }
 定义 可变 候选 = []
 i = 0
 当 (i < h维) { 定义 可变 hv = 单元[3][2 * h维 + i]
 定义 可变 j2 = 0
 当 (j2 < 合维) {
 hv = hv + 单元[2][(2 * h维 + i) * 合维 + j2] * 拼接2[j2] / rnn精度
 j2 = j2 + 1
 }
 追加(候选, 循环网络_双曲正切(hv))
 i = i + 1
 }
 // h = (1-z)⊙前隐藏 + z⊙h̃
 定义 可变 新h = []
 i = 0
 当 (i < h维) {
 追加(新h, (rnn精度 - z门[i]) * 隐藏[i] / rnn精度 + z门[i] * 候选[i] / rnn精度)
 i = i + 1
 }
 返回 新h
}

// 双向RNN
// 正向+反向处理序列, 拼接两个方向的隐藏状态

函数 双向rnn_序列(正向单元, 反向单元, 输入序列) { 定义 h维 = 正向单元[0]
 定义 序列长 = 计数(输入序列)
 // 正向
 定义 可变 正h = []
 定义 可变 i = 0
 当 (i < h维) { 追加(正h, 0)
 i = i + 1 }
 定义 可变 正向输出 = []
 i = 0
 当 (i < 序列长) {
 正h = rnn_步进(正向单元, 输入序列[i], 正h)
 追加(正向输出, 正h)
 i = i + 1
 }
 // 反向
 定义 可变 反h = []
 i = 0
 当 (i < h维) { 追加(反h, 0)
 i = i + 1 }
 定义 可变 反向输出 = []
 i = 0
 当 (i < 序列长) { 追加(反向输出, 反h)
 i = i + 1 }
 i = 序列长 - 1
 当 (i >= 0) {
 反h = rnn_步进(反向单元, 输入序列[i], 反h)
 反向输出[i] = 反h
 i = i - 1
 }
 // 拼接
 定义 可变 拼接输出 = []
 i = 0
 当 (i < 序列长) { 定义 可变 拼 = []
 定义 可变 j = 0
 当 (j < h维) { 追加(拼, 正向输出[i][j])
 j = j + 1 }
 j = 0
 当 (j < h维) { 追加(拼, 反向输出[i][j])
 j = j + 1 }
 追加(拼接输出, 拼)
 i = i + 1
 }
 返回 拼接输出
}

// 双向LSTM
函数 双向lstm_序列(正向单元, 反向单元, 输入序列) { 定义 h维 = 正向单元[0]
 定义 序列长 = 计数(输入序列)
 // 正向
 定义 可变 正h = []
 定义 可变 正c = []
 定义 可变 i = 0
 当 (i < h维) { 追加(正h, 0)
 追加(正c, 0)
 i = i + 1 }
 定义 可变 正向输出 = []
 i = 0
 当 (i < 序列长) { 定义 r = lstm_步进(正向单元, 输入序列[i], 正h, 正c)
 正h = r[0]
 正c = r[1]
 追加(正向输出, 正h)
 i = i + 1
 }
 // 反向
 定义 可变 反h = []
 定义 可变 反c = []
 i = 0
 当 (i < h维) { 追加(反h, 0)
 追加(反c, 0)
 i = i + 1 }
 定义 可变 反向输出 = []
 i = 0
 当 (i < 序列长) { 追加(反向输出, 反h)
 i = i + 1 }
 i = 序列长 - 1
 当 (i >= 0) { 定义 r2 = lstm_步进(反向单元, 输入序列[i], 反h, 反c)
 反h = r2[0]
 反c = r2[1]
 反向输出[i] = 反h
 i = i - 1
 }
 // 拼接
 定义 可变 拼接输出 = []
 i = 0
 当 (i < 序列长) { 定义 可变 拼 = []
 定义 可变 j = 0
 当 (j < h维) { 追加(拼, 正向输出[i][j])
 j = j + 1 }
 j = 0
 当 (j < h维) { 追加(拼, 反向输出[i][j])
 j = j + 1 }
 追加(拼接输出, 拼)
 i = i + 1
 }
 返回 拼接输出
}

// 深度LSTM (多层堆叠)
函数 深度lstm_序列(层列表, 输入序列) { 定义 可变 当前输入 = 输入序列
 定义 可变 层idx = 0
 定义 可变 最终h = []
 当 (层idx < 计数(层列表)) { 定义 结果 = lstm_序列(层列表[层idx], 当前输入)
 最终h = 结果[0]
 当前输入 = 结果[2] // 所有h作为下一层输入
 层idx = 层idx + 1
 }
 返回 [最终h, 当前输入]
}

// GRU 序列处理
函数 gru_序列(单元, 输入序列) { 定义 h维 = 单元[0]
 定义 可变 h = []
 定义 可变 i = 0
 当 (i < h维) { 追加(h, 0)
 i = i + 1 }
 定义 可变 所有h = []
 i = 0
 当 (i < 计数(输入序列)) {
 h = gru_步进(单元, 输入序列[i], h)
 追加(所有h, h)
 i = i + 1
 }
 返回 [h, 所有h]
}

// 序列到序列 (Seq2Seq) 编码-解码
// 编码器: LSTM处理输入序列 → 上下文向量
// 解码器: LSTM从上下文生成输出序列

函数 seq2seq_编码(编码器, 输入序列) { 定义 结果 = lstm_序列(编码器, 输入序列)
 返回 [结果[0], 结果[1]] // [最终h, 最终c] 作为上下文
}

函数 seq2seq_解码(解码器, 上下文h, 上下文c, 输出长度, 起始输入) { 定义 _h维 = 解码器[0]
 定义 可变 h = 上下文h
 定义 可变 c = 上下文c
 定义 可变 输入 = 起始输入
 定义 可变 输出序列 = []
 定义 可变 t = 0
 当 (t < 输出长度) { 定义 结果 = lstm_步进(解码器, 输入, h, c)
 h = 结果[0]
 c = 结果[1]
 追加(输出序列, h)
 输入 = h // 自回归: 上一步输出作为下一步输入
 t = t + 1
 }
 返回 输出序列
}

// 序列掩码 (处理变长序列, 0)
// 对填充位置的输出置零

函数 序列掩码(输出序列, 实际长度) { 定义 序列长 = 计数(输出序列)
 定义 可变 i = 实际长度
 当 (i < 序列长) { 定义 h维 = 计数(输出序列[i])
 定义 可变 j = 0
 当 (j < h维) {
 输出序列[i][j] = 0
 j = j + 1
 }
 i = i + 1
 }
}

// 注意力解码器 (Bahdanau)
函数 注意力_计算(编码器输出, 解码器隐藏) { 定义 T = 计数(编码器输出)
 定义 h维 = 计数(解码器隐藏)
 // 注意力分数: score[t] = decoder_h · encoder_output[t]
 定义 可变 分数 = []
 定义 可变 t = 0
 当 (t < T) { 定义 可变 和 = 0
 定义 可变 j = 0
 当 (j < h维) { 如果 (j < 计数(编码器输出[t])) {
 和 = 和 + 解码器隐藏[j] * 编码器输出[t][j] / rnn精度
 }
 j = j + 1
 }
 追加(分数, 和)
 t = t + 1
 }
 // Softmax
 定义 可变 最大 = 分数[0]
 t = 1
 当 (t < T) { 如果 (分数[t] > 最大) { 最大 = 分数[t] }
 t = t + 1 }
 定义 可变 指数 = []
 定义 可变 总和 = 0
 t = 0
 当 (t < T) { 定义 可变 e = rnn精度 + (分数[t] - 最大)
 如果 (e < 1) { e = 1 }
 追加(指数, e)
 总和 = 总和 + e
 t = t + 1
 }
 定义 可变 权重 = []
 t = 0
 当 (t < T) { 追加(权重, 指数[t] * rnn精度 / 总和)
 t = t + 1 }
 // 上下文向量 = Σ weight[t] * encoder_output[t]
 定义 可变 上下文 = []
 定义 可变 j2 = 0
 当 (j2 < h维) { 追加(上下文, 0)
 j2 = j2 + 1 }
 t = 0
 当 (t < T) {
 j2 = 0
 当 (j2 < h维) { 如果 (j2 < 计数(编码器输出[t])) {
 上下文[j2] = 上下文[j2] + 权重[t] * 编码器输出[t][j2] / rnn精度
 }
 j2 = j2 + 1
 }
 t = t + 1
 }
 返回 [上下文, 权重]
}

// Teacher Forcing 训练步
函数 teacher_forcing_步(解码器, 真实序列, 编码器上下文h, 编码器上下文c) { 定义 T = 计数(真实序列)
 定义 可变 h = 编码器上下文h
 定义 可变 c = 编码器上下文c
 定义 可变 输出 = []
 定义 可变 t = 0
 当 (t < T) {
 // 用真实标签作为输入 (而非自回归)
 定义 结果 = lstm_步进(解码器, 真实序列[t], h, c)
 h = 结果[0]
 c = 结果[1]
 追加(输出, h)
 t = t + 1
 }
 返回 输出
}

// Beam Search 解码
函数 束搜索(解码器, 初始h, 初始c, 起始输入, beam宽, 最大长度, 评分函数) {
 // 每个候选: [序列, h, c, 得分]
 定义 可变 候选 = [[[起始输入], 初始h, 初始c, 0]]
 定义 可变 步 = 0
 当 (步 < 最大长度) { 定义 可变 新候选 = []
 定义 可变 b = 0
 当 (b < 计数(候选)) { 定义 序列 = 候选[b][0]
 定义 h = 候选[b][1]
 定义 c = 候选[b][2]
 定义 分 = 候选[b][3]
 // 用最后一个token作为输入
 如果 (计数(序列) == 0) { 返回 空 }
 定义 输入 = 序列[计数(序列) - 1]
 定义 结果 = lstm_步进(解码器, 输入, h, c)
 定义 新h = 结果[0]
 定义 新c = 结果[1]
 // 评分
 定义 token分数 = 评分函数(新h)
 // 扩展
 定义 可变 新seq = []
 定义 可变 si = 0
 当 (si < 计数(序列)) { 追加(新seq, 序列[si])
 si = si + 1 }
 追加(新seq, 新h)
 追加(新候选, [新seq, 新h, 新c, 分 + token分数])
 b = b + 1
 }
 // 保留top-beam个
 // 简单排序: 按得分降序
 定义 可变 si2 = 0
 当 (si2 < 计数(新候选)) { 定义 可变 sj = si2 + 1
 当 (sj < 计数(新候选)) { 如果 (新候选[sj][3] > 新候选[si2][3]) { 定义 t = 新候选[si2]
 新候选[si2] = 新候选[sj]
 新候选[sj] = t
 }
 sj = sj + 1
 }
 si2 = si2 + 1
 }
 候选 = []
 定义 可变 取 = 0
 当 (取 < beam宽 且 取 < 计数(新候选)) {
 追加(候选, 新候选[取])
 取 = 取 + 1
 }
 步 = 步 + 1
 }
 // 返回最佳序列
 如果 (计数(候选) > 0) { 返回 候选[0][0] }
 返回 []
}

// Peephole LSTM (带窥视孔连接)
函数 peephole_lstm_步进(单元, 输入, h, c) { 定义 h维 = 单元[0]
 定义 x维 = 单元[1]
 定义 权重_输入隐藏 = 单元[2]
 定义 权重_隐藏隐藏 = 单元[3]
 定义 b = 单元[4]
 定义 可变 新h = []
 定义 可变 新c = []
 定义 可变 i = 0
 当 (i < h维) {
 // 输入门 (含c窥视)
 定义 可变 ig = b[i]
 定义 可变 j = 0
 当 (j < x维) { ig = ig + 权重_输入隐藏[i * x维 + j] * 输入[j] / rnn精度
 j = j + 1 }
 j = 0
 当 (j < h维) { ig = ig + 权重_隐藏隐藏[i * h维 + j] * h[j] / rnn精度
 j = j + 1 }
 ig = ig + c[i] / 4 // 窥视孔
 ig = 循环网络_S形(ig)
 // 遗忘门 (含c窥视)
 定义 可变 fg = rnn精度 - ig + c[i] / 8
 如果 (fg < 0) { fg = 0 }
 如果 (fg > rnn精度) { fg = rnn精度 }
 // 候选
 定义 可变 cand = 0
 j = 0
 当 (j < x维) { cand = cand + 权重_输入隐藏[(h维 + i) * x维 + j] * 输入[j] / rnn精度
 j = j + 1 }
 cand = 循环网络_双曲正切(cand)
 // 更新细胞
 定义 nc = fg * c[i] / rnn精度 + ig * cand / rnn精度
 追加(新c, nc)
 追加(新h, 循环网络_双曲正切(nc))
 i = i + 1
 }
 返回 [新h, 新c]
}

// 内部工具

函数 循环网络_S形(x) {
    如果 (x < 0 - 5 * rnn精度) { 返回 0
}
 如果 (x >= 5 * rnn精度) { 返回 rnn精度 }
 如果 (x < 0) { 返回 rnn精度 / 2 + x * rnn精度 / (4 * 5 * rnn精度) }
 返回 rnn精度 / 2 + x * rnn精度 / (4 * 5 * rnn精度)
}

函数 循环网络_双曲正切(x) { 返回 2 * 循环网络_S形(2 * x) - rnn精度
}

函数 rnn_开方(n) { 返回 开方(n) }

// 合并自 编译器/标准库/循环网络/循环网络.nova

函数 GRU_单元(x, 前隐藏, wz, wr, wh, bz, br, bh) { 定义 维度 = 计数(前隐藏)
 定义 可变 新隐藏 = []
 定义 可变 索引 = 0
 当 (索引 < 维度) { 定义 组合值 = 前隐藏[索引] + x[索引]
 定义 z = _S形(组合值 * wz / 1000 + bz)
 定义 r = _S形(组合值 * wr / 1000 + br)
 定义 r_h = r * 前隐藏[索引] / 1000
 定义 ht = _双曲正切((r_h + x[索引]) * wh / 1000 + bh)
 定义 隐藏值 = (1000 - z) * 前隐藏[索引] / 1000 + z * ht / 1000
 追加(新隐藏, 隐藏值)
 索引 = 索引 + 1
 }
 返回 新隐藏
}

函数 LSTM_窥视孔(x, 前隐藏, c_prev, wf, wi, wo, wc, pf, pi, po, bf, bi, bo, bc) { 定义 维度 = 计数(前隐藏)
 定义 可变 新隐藏 = []
 定义 可变 c_new = []
 定义 可变 索引 = 0
 当 (索引 < 维度) { 定义 组合值 = 前隐藏[索引] + x[索引]
 // Peephole: 门控看到细胞状态
 定义 f = _S形(组合值 * wf / 1000 + c_prev[索引] * pf / 1000 + bf)
 定义 ig = _S形(组合值 * wi / 1000 + c_prev[索引] * pi / 1000 + bi)
 定义 ct = _双曲正切(组合值 * wc / 1000 + bc)
 定义 c_val = f * c_prev[索引] / 1000 + ig * ct / 1000
 定义 o = _S形(组合值 * wo / 1000 + c_val * po / 1000 + bo)
 定义 隐藏值 = o * _双曲正切(c_val) / 1000
 追加(c_new, c_val)
 追加(新隐藏, 隐藏值)
 索引 = 索引 + 1
 }
 返回 [新隐藏, c_new]
}

函数 LSTM_单元(x, 前隐藏, c_prev, wf, wi, wo, wc, bf, bi, bo, bc) { 定义 维度 = 计数(前隐藏)
 定义 可变 新隐藏 = []
 定义 可变 c_new = []
 定义 可变 索引 = 0
 当 (索引 < 维度) { 定义 组合值 = 前隐藏[索引] + x[索引]
 定义 f = _S形(组合值 * wf / 1000 + bf)
 定义 ig = _S形(组合值 * wi / 1000 + bi)
 定义 o = _S形(组合值 * wo / 1000 + bo)
 定义 ct = _双曲正切(组合值 * wc / 1000 + bc)
 定义 c_val = f * c_prev[索引] / 1000 + ig * ct / 1000
 定义 隐藏值 = o * _双曲正切(c_val) / 1000
 追加(c_new, c_val)
 追加(新隐藏, 隐藏值)
 索引 = 索引 + 1
 }
 返回 [新隐藏, c_new]
}

// 多参数版本(直接传权重，独立函数名避免覆盖旧版)
函数 rnn_权重序列(输入序列, 维度, _w_h, _w_x, _b) { 定义 单元 = rnn_创建(维度, 维度, 42)
 返回 rnn_序列(单元, 输入序列)
}
函数 gru_权重序列(输入序列, 维度, _wz, _wr, _wh, _bz, _br, _bh) { 定义 单元 = gru_创建(维度, 维度, 42)
 返回 gru_序列(单元, 输入序列)
}
函数 lstm_权重序列(输入序列, 维度, _wf, _wi, _wo, _wc, _bf, _bi, _bo, _bc) { 定义 单元 = lstm_创建(维度, 维度, 42)
 返回 lstm_序列(单元, 输入序列)
}

函数 RNN_单元(x, 前隐藏, w_h, w_x, b) { 定义 可变 新隐藏 = []
 定义 维度 = 计数(前隐藏)
 定义 可变 i = 0
 当 (i < 维度) { 定义 数值 = 前隐藏[i] * w_h / 1000 + x[i] * w_x / 1000 + b
 追加(新隐藏, _双曲正切(数值))
 i = i + 1
 }
 返回 新隐藏
}

函数 RNN_多层(输入序列, 维度, n_layers, w_h, w_x, b) { 定义 可变 当前输入 = 输入序列
 定义 可变 layer = 0
 当 (layer < n_layers) {
 当前输入 = rnn_权重序列(当前输入, 维度, w_h, w_x, b)
 layer = layer + 1
 }
 返回 当前输入
}

函数 _S形(x) {
    如果 (x > 5000) { 返回 998
}
 如果 (x < -5000) { 返回 2 }
 如果 (绝对值(x) < 2000) { 返回 500 + x * 200 / 1000 }
 如果 (x > 0) { 返回 900 + (x - 2000) * 98 / 3000 }
 返回 100 + (x + 2000) * 98 / 3000
}

函数 _双曲正切(x) {
    如果 (x > 3000) { 返回 1000
}
 如果 (x < -3000) { 返回 -1000 }
 如果 (绝对值(x) < 500) { 返回 x - x * x * x / 3000000 }
 如果 (x > 0) { 返回 700 + (x - 500) * 300 / 2500 }
 返回 -700 + (x + 500) * 300 / 2500
}

函数 双向_GRU(输入序列, 维度, wz, wr, wh, bz, br, bh) { 定义 前向 = gru_权重序列(输入序列, 维度, wz, wr, wh, bz, br, bh)
 定义 后向 = gru_权重序列(反转序列(输入序列), 维度, wz, wr, wh, bz, br, bh)
 返回 [前向, 后向]
}

函数 双向_LSTM(输入序列, 维度, wf, wi, wo, wc, bf, bi, bo, bc) { 定义 前向 = lstm_权重序列(输入序列, 维度, wf, wi, wo, wc, bf, bi, bo, bc)
 定义 后向 = lstm_权重序列(反转序列(输入序列), 维度, wf, wi, wo, wc, bf, bi, bo, bc)
 返回 [前向, 后向]
}

函数 双向_RNN(输入序列, 维度, w_h, w_x, b) { 定义 前向 = rnn_权重序列(输入序列, 维度, w_h, w_x, b)
 定义 后向 = rnn_权重序列(反转序列(输入序列), 维度, w_h, w_x, b)
 返回 [前向, 后向]
}

函数 反转序列(输入序列) { 定义 可变 反转 = []
 定义 可变 i = 计数(输入序列) - 1
 当 (i >= 0) { 追加(反转, 输入序列[i])
 i = i - 1 }
 返回 反转
}

函数 取最终隐态(输出序列) { 定义 n = 计数(输出序列)
 如果 (n == 0) { 返回 [] }
 返回 输出序列[n - 1]
}

函数 截断隐态(h, max_val) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(h)) { 定义 v = h[i]
 定义 下界 = 0 - max_val
 定义 可变 截断值 = 最大值(v, 下界)
 截断值 = 最小值(截断值, max_val)
 追加(结果, 截断值)
 i = i + 1
 }
 返回 结果
}

函数 隐态_维度(h) { 返回 计数(h) }

函数 零向量(维度) { 定义 可变 v = []
 定义 可变 i = 0
 当 (i < 维度) { 追加(v, 0)
 i = i + 1 }
 返回 v
}


导入("../位运算/位运算.nova")
导入("../基础.nova")

//    位计数: 位→数 的聚合态射
//    Gray码: 位→位 的邻差态射
//    火行特性: 瞬间变换, 不可逆(除非对偶操作)

// 计算1的个数 (popcount)
函数 位_计数1(n) {
    定义 可变 v = n
    如果 (v < 0) { v = 0 - v }
    定义 可变 计 = 0
    当 (v > 0) {
        计 = 计 + v % 2
        v = v / 2
    }
    返回 计
}

// 最高位位置
函数 位操作_位_最高位(n) {
    定义 可变 v = n
    如果 (v <= 0) { 返回 -1 }
    定义 可变 位 = 0
    当 (v > 1) { v = v / 2 位 = 位 + 1 }
    返回 位
}

// 最低位位置
函数 位操作_位_最低位(n) {
    如果 (n == 0) { 返回 -1 }
    定义 可变 v = n
    如果 (v < 0) { v = 0 - v }
    定义 可变 位 = 0
    当 (v % 2 == 0) { v = v / 2 位 = 位 + 1 }
    返回 位
}

// 获取第n位
函数 位_取(值, n) {
    定义 可变 v = 值
    定义 可变 i = 0
    当 (i < n) { v = v / 2 i = i + 1 }
    返回 v % 2
}

// 设置第n位
函数 位_设(值, n) {
    定义 可变 掩码 = 1
    定义 可变 i = 0
    当 (i < n) { 掩码 = 掩码 * 2 i = i + 1 }
    如果 (位_取(值, n) == 0) { 返回 值 + 掩码 }
    返回 值
}

// 清除第n位
函数 位_清(值, n) {
    定义 可变 掩码 = 1
    定义 可变 i = 0
    当 (i < n) { 掩码 = 掩码 * 2 i = i + 1 }
    如果 (位_取(值, n) == 1) { 返回 值 - 掩码 }
    返回 值
}

// 翻转第n位
函数 位操作_位_翻转(值, n) {
    如果 (位_取(值, n) == 1) { 返回 位_清(值, n) }
    返回 位_设(值, n)
}

// 二进制转字符串
函数 位_转字符串(值, 位数) {
    定义 可变 结果 = ""
    定义 可变 i = 位数 - 1
    当 (i >= 0) {
        如果 (位_取(值, i) == 1) {
            结果 = 字符串拼接(结果, "1")
        } 否则 {
            结果 = 字符串拼接(结果, "0")
        }
        i = i - 1
    }
    返回 结果
}

// Gray码转换
函数 gray_编码(n) {
    // n XOR (n >> 1) — 用位操作模拟
    定义 一半 = n / 2
    // 简化XOR: 如果两位不同则为1
    定义 可变 结果 = 0
    定义 可变 掩码 = 1
    定义 可变 i = 0
    当 (i < 30) {
        定义 a_bit = (n / 掩码) % 2
        定义 b_bit = (一半 / 掩码) % 2
        如果 (a_bit != b_bit) { 结果 = 结果 + 掩码 }
        掩码 = 掩码 * 2
        i = i + 1
    }
    返回 结果
}

// Gray码解码
函数 gray_解码(g) {
    定义 可变 n = g
    定义 可变 掩码 = g / 2
    当 (掩码 > 0) {
        // n XOR mask
        定义 可变 结果 = 0
        定义 可变 位掩码 = 1
        定义 可变 i = 0
        当 (i < 30) {
            定义 a = (n / 位掩码) % 2
            定义 b = (掩码 / 位掩码) % 2
            如果 (a != b) { 结果 = 结果 + 位掩码 }
            位掩码 = 位掩码 * 2
            i = i + 1
        }
        n = 结果
        掩码 = 掩码 / 2
    }
    返回 n
}

// 下一个2的幂
函数 下一个2幂(n) {
    如果 (n <= 1) { 返回 1 }
    定义 可变 v = 1
    当 (v < n) { v = v * 2 }
    返回 v
}

// 位反转 (在给定位数内, 0)
函数 位_反转(值, 位数) {
    定义 可变 结果 = 0
    定义 可变 i = 0
    当 (i < 位数) {
        如果 (位_取(值, i) == 1) {
            结果 = 位_设(结果, 位数 - 1 - i)
        }
        i = i + 1
    }
    返回 结果
}

// 交换两个位
函数 位_交换(值, i, j) {
    定义 bi = 位_取(值, i)
    定义 bj = 位_取(值, j)
    如果 (bi == bj) { 返回 值 }
    定义 可变 结果 = 值
    如果 (bi == 1) { 结果 = 位_清(结果, i) } 否则 { 结果 = 位_设(结果, i) }
    如果 (bj == 1) { 结果 = 位_清(结果, j) } 否则 { 结果 = 位_设(结果, j) }
    返回 结果
}

// 位图

函数 位操作_位图_创建(大小) {
    定义 字数 = (大小 + 31) / 32
    定义 可变 图 = []
    定义 可变 i = 0
    当 (i < 字数) { 追加(图, 0)  i = i + 1 }
    返回 [图, 大小]
}

函数 位操作_位图_设(图, 位) {
    如果 (位 < 0 或 位 >= 图[1]) { 返回 空 }
    定义 字索引 = 位 / 32
    定义 位索引 = 位 % 32
    图[0][字索引] = 位_设(图[0][字索引], 位索引)
}

函数 位操作_位图_清(图, 位) {
    如果 (位 < 0 或 位 >= 图[1]) { 返回 空 }
    定义 字索引 = 位 / 32
    定义 位索引 = 位 % 32
    图[0][字索引] = 位_清(图[0][字索引], 位索引)
}

函数 位操作_位图_测试(图, 位) {
    如果 (位 < 0 或 位 >= 图[1]) { 返回 0 }
    定义 字索引 = 位 / 32
    定义 位索引 = 位 % 32
    返回 位_取(图[0][字索引], 位索引)
}

函数 位操作_位图_计数(图) {
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(图[0])) {
        总 = 总 + 位_计数1(图[0][i])
        i = i + 1
    }
    返回 总
}

// 位域提取

函数 位域_提取(值, 起始位, 宽度) {
    定义 可变 掩码 = 0
    定义 可变 i = 0
    当 (i < 宽度) { 掩码 = 位_设(掩码, i)  i = i + 1 }
    定义 可变 移位 = 1
    i = 0
    当 (i < 起始位) { 移位 = 移位 * 2  i = i + 1 }
    返回 (值 / 移位) % (掩码 + 1)
}

函数 位域_插入(值, 起始位, 宽度, 新值) {
    定义 可变 掩码 = 0
    定义 可变 i = 0
    当 (i < 宽度) { 掩码 = 位_设(掩码, i)  i = i + 1 }
    定义 可变 结果 = 值
    // 清除目标位域
    i = 0
    当 (i < 宽度) {
        结果 = 位_清(结果, 起始位 + i)
        i = i + 1
    }
    // 设置新值
    定义 可变 截断值 = 新值 % (掩码 + 1)
    i = 0
    当 (i < 宽度) {
        如果 (位_取(截断值, i) == 1) { 结果 = 位_设(结果, 起始位 + i) }
        i = i + 1
    }
    返回 结果
}

// 汉明距离

函数 位操作_汉明距离(a, b) {
    定义 可变 异或 = 0
    定义 可变 i = 0
    当 (i < 32) {
        如果 (位_取(a, i) != 位_取(b, i)) { 异或 = 异或 + 1 }
        i = i + 1
    }
    返回 异或
}

// 格雷码

函数 格雷码_编码(n) {
    // Gray = n XOR (n >> 1)
    定义 可变 结果 = 0
    定义 可变 i = 0
    当 (i < 32) {
        定义 b1 = 位_取(n, i)
        定义 b2 = 位_取(n, i + 1)
        如果 (b1 != b2) { 结果 = 位_设(结果, i) }
        i = i + 1
    }
    返回 结果
}

函数 格雷码_解码(g) {
    定义 可变 结果 = 0
    定义 可变 位 = 31
    定义 可变 前一位 = 0
    当 (位 >= 0) {
        定义 当前 = 位_取(g, 位)
        如果 (当前 != 前一位) {
            结果 = 位_设(结果, 位)
            前一位 = 1
        } 否则 {
            前一位 = 0
        }
        位 = 位 - 1
    }
    返回 结果
}

函数 格雷码_序列(n) {
    定义 可变 序列 = []
    定义 可变 i = 0
    当 (i < n) { 追加(序列, 格雷码_编码(i))  i = i + 1 }
    返回 序列
}

// 循环移位

函数 位操作_位_循环左移(值, 位数, 总位数) {
    定义 实际位数 = 位数 % 总位数
    定义 可变 结果 = 0
    定义 可变 i = 0
    当 (i < 总位数) {
        定义 源位 = (i - 实际位数 + 总位数) % 总位数
        如果 (位_取(值, 源位) == 1) { 结果 = 位_设(结果, i) }
        i = i + 1
    }
    返回 结果
}

函数 位操作_位_循环右移(值, 位数, 总位数) {
    返回 位操作_位_循环左移(值, 总位数 - 位数, 总位数)
}

// 奇偶校验

函数 位操作_位_奇偶校验(值) {
    定义 可变 计 = 位_计数1(值)
    返回 计 % 2
}

定义 可变 _位操作_运算数 = 0
定义 可变 _位操作_位图操作数 = 0

函数 位操作_记录运算() { _位操作_运算数 = _位操作_运算数 + 1 }
函数 位操作_记录位图() { _位操作_位图操作数 = _位操作_位图操作数 + 1 }

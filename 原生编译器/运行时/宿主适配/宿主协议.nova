导入("../../标准库/基础.nova")
导入("../../标准库/文本/文本处理.nova")
导入("../../标准库/系统/硬件库.nova")
导入("../../编译器/跨语言/智能协作/重置协调器.nova")
导入("../../编译器/跨语言/工程摄取/工程探测器.nova")

定义 消息_请求       = 0
定义 消息_响应       = 1
定义 消息_通知       = 2
定义 消息_诊断       = 3

定义 方法_编译       = 0
定义 方法_诊断       = 1
定义 方法_补全       = 2
定义 方法_跳转定义   = 3
定义 方法_查找引用   = 4
定义 方法_格式化     = 5
定义 方法_重命名     = 6
定义 方法_悬停       = 7
定义 方法_符号列表   = 8
定义 方法_工作区符号 = 9
定义 方法_重置探测   = 10
定义 方法_重置执行   = 11

定义 可变 _协议_下个ID = 1

函数 协议消息_创建(类型, 方法, 参数) {
    定义 id = _协议_下个ID
    _协议_下个ID = _协议_下个ID + 1
    返回 [id, 类型, 方法, 参数, 空, 空]
}

函数 消息_ID(m) { 返回 m[0] }
函数 消息_类型(m) { 返回 m[1] }
函数 消息_方法(m) { 返回 m[2] }
函数 消息_参数(m) { 返回 m[3] }
函数 消息_结果(m) { 返回 m[4] }
函数 消息_错误(m) { 返回 m[5] }

函数 消息_设结果(m, 结果) { m[4] = 结果 }
函数 消息_设错误(m, 错误) { m[5] = 错误 }

定义 严重_错误   = 0
定义 严重_警告   = 1
定义 严重_信息   = 2
定义 严重_提示   = 3

函数 宿主协议_诊断_创建(行, 列, 级别, 消息, 来源) {
    返回 [行, 列, 级别, 消息, 来源]
}

定义 符号种类_函数   = 0
定义 符号种类_变量   = 1
定义 符号种类_结构   = 2
定义 符号种类_常量   = 3
定义 符号种类_模块   = 4

函数 符号信息_创建(名称, 种类, 文件, 行) {
    返回 [名称, 种类, 文件, 行, ""]
}

函数 宿主服务_创建(名称) {
    返回 [名称, [], [], [], 字典()]
}

函数 宿主_名称(h) { 返回 h[0] }
函数 宿主_能力(h) { 返回 h[1] }
函数 宿主_消息队列(h) { 返回 h[2] }
函数 宿主_诊断缓存(h) { 返回 h[3] }
函数 宿主_符号缓存(h) { 返回 h[4] }

函数 宿主_注册能力(h, 方法) {
    追加(h[1], 方法)
}

函数 宿主_推送消息(h, 消息) {
    追加(h[2], 消息)
}

函数 宿主_缓存诊断(h, 诊断) {
    追加(h[3], 诊断)
}

函数 _宿主_符号键(符号) {
    返回 字符串拼接(符号[2], 字符串拼接("#", 字符串拼接(转字符串(符号[3]), 字符串拼接("#", 符号[0]))))
}

函数 宿主_缓存符号(h, 符号) {
    字典设(h[4], _宿主_符号键(符号), 符号)
}

函数 _宿主_参数第(参数, 索引) {
    如果 (是列表(参数) == 真) {
        如果 (索引 < 计数(参数)) { 返回 参数[索引] }
        返回 空
    }
    如果 (索引 == 0) { 返回 参数 }
    返回 空
}

函数 _宿主_参数文本(参数, 索引) {
    定义 值 = _宿主_参数第(参数, 索引)
    如果 (值 == 空) { 返回 "" }
    返回 值
}

函数 _宿主_符号种类名(种类) {
    如果 (种类 == 符号种类_函数) { 返回 "函数" }
    如果 (种类 == 符号种类_变量) { 返回 "变量" }
    如果 (种类 == 符号种类_结构) { 返回 "结构" }
    如果 (种类 == 符号种类_常量) { 返回 "常量" }
    如果 (种类 == 符号种类_模块) { 返回 "模块" }
    返回 "unknown"
}

函数 宿主_全部符号(h) {
    定义 可变 结果 = []
    定义 键列表 = 字典键(h[4])
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        定义 符号 = 字典取(h[4], 键列表[i])
        如果 (符号 != 空) { 追加(结果, 符号) }
        i = i + 1
    }
    返回 结果
}

函数 _宿主_筛符号(h, 查询, 文件, 仅前缀, 仅精确) {
    定义 可变 结果 = []
    定义 全部 = 宿主_全部符号(h)
    定义 可变 i = 0
    当 (i < 计数(全部)) {
        定义 符号 = 全部[i]
        定义 可变 匹配文件 = 真
        定义 可变 匹配查询 = 真
        如果 (文件 != "" 且 符号[2] != 文件) { 匹配文件 = 假 }
        如果 (查询 != "") {
            如果 (仅精确) {
                如果 (符号[0] != 查询) { 匹配查询 = 假 }
            } 否则 如果 (仅前缀) {
                如果 (以开头(符号[0], 查询) == 假) { 匹配查询 = 假 }
            } 否则 {
                如果 (包含(符号[0], 查询) == 假 且 包含(符号[2], 查询) == 假) { 匹配查询 = 假 }
            }
        }
        如果 (匹配文件 且 匹配查询) { 追加(结果, 符号) }
        i = i + 1
    }
    返回 结果
}

函数 _宿主_格式化文本(文本) {
    如果 (文本 == 空) { 返回 "" }
    定义 行列表 = 分割(文本, "\n")
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(行列表)) {
        定义 可变 行 = 替换(行列表[i], "\t", "    ")
        定义 可变 末 = 计数(行)
        当 (末 > 0 且 (子串(行, 末 - 1, 1) == " " 或 子串(行, 末 - 1, 1) == "\t" 或 子串(行, 末 - 1, 1) == "\r")) {
            末 = 末 - 1
        }
        行 = 子串(行, 0, 末)
        如果 (i > 0) { 结果 = 字符串拼接(结果, "\n") }
        结果 = 字符串拼接(结果, 行)
        i = i + 1
    }
    返回 结果
}

函数 _宿主_符号摘要(符号) {
    返回 [符号[0], _宿主_符号种类名(符号[1]), 符号[2], 符号[3], 符号[4]]
}

函数 _宿主_重置阶段名(id) {
    如果 (id == 0) { 返回 "待命" }
    如果 (id == 1) { 返回 "探测" }
    如果 (id == 2) { 返回 "建模" }
    如果 (id == 3) { 返回 "骨架解析" }
    如果 (id == 4) { 返回 "语义抽取" }
    如果 (id == 5) { 返回 "风险评审" }
    如果 (id == 6) { 返回 "重建计划" }
    如果 (id == 7) { 返回 "模块生成" }
    如果 (id == 8) { 返回 "等价验证" }
    如果 (id == 9) { 返回 "合规审查" }
    如果 (id == 10) { 返回 "报告输出" }
    如果 (id == 11) { 返回 "complete" }
    返回 "unknown"
}

函数 宿主_有能力(h, 方法) {
    定义 可变 i = 0
    当 (i < 计数(h[1])) {
        如果 (h[1][i] == 方法) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 宿主_处理请求(h, 消息) {
    定义 方法 = 消息_方法(消息)

    如果 (宿主_有能力(h, 方法) == 假) {
        消息_设错误(消息, "方法未注册")
        返回 消息
    }

    如果 (方法 == 方法_编译) { 返回 _宿主_处理编译(h, 消息) }
    如果 (方法 == 方法_诊断) { 返回 _宿主_处理诊断(h, 消息) }
    如果 (方法 == 方法_补全) { 返回 _宿主_处理补全(h, 消息) }
    如果 (方法 == 方法_跳转定义) { 返回 _宿主_处理跳转定义(h, 消息) }
    如果 (方法 == 方法_查找引用) { 返回 _宿主_处理查找引用(h, 消息) }
    如果 (方法 == 方法_格式化) { 返回 _宿主_处理格式化(h, 消息) }
    如果 (方法 == 方法_重命名) { 返回 _宿主_处理重命名(h, 消息) }
    如果 (方法 == 方法_悬停) { 返回 _宿主_处理悬停(h, 消息) }
    如果 (方法 == 方法_符号列表) { 返回 _宿主_处理符号列表(h, 消息) }
    如果 (方法 == 方法_工作区符号) { 返回 _宿主_处理工作区符号(h, 消息) }
    如果 (方法 == 方法_重置探测) { 返回 _宿主_处理重置探测(h, 消息) }
    如果 (方法 == 方法_重置执行) { 返回 _宿主_处理重置执行(h, 消息) }

    消息_设错误(消息, "方法无处理器")
    返回 消息
}

函数 _宿主_处理编译(h, 消息) {
    定义 参数 = 消息_参数(消息)
    定义 源文件 = _宿主_参数文本(参数, 0)
    定义 优化级别 = _宿主_参数第(参数, 1)
    如果 (源文件 == "") {
        消息_设错误(消息, "缺少源文件路径")
        返回 消息
    }
    宿主_推送消息(h, 消息)
    消息_设结果(消息, ["已入队", 源文件, 优化级别, 计数(h[2])])
    返回 消息
}

函数 _宿主_处理诊断(h, 消息) {
    定义 查询 = _宿主_参数文本(消息_参数(消息), 0)
    如果 (查询 == "") {
        消息_设结果(消息, h[3])
        返回 消息
    }
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(h[3])) {
        定义 d = h[3][i]
        如果 (是列表(d) == 真 且 计数(d) >= 5) {
            如果 (包含(转字符串(d[3]), 查询) 或 包含(转字符串(d[4]), 查询)) {
                追加(结果, d)
            }
        }
        i = i + 1
    }
    消息_设结果(消息, 结果)
    返回 消息
}

函数 _宿主_处理补全(h, 消息) {
    定义 参数 = 消息_参数(消息)
    定义 查询 = _宿主_参数文本(参数, 0)
    定义 文件 = _宿主_参数文本(参数, 1)
    消息_设结果(消息, _宿主_筛符号(h, 查询, 文件, 真, 假))
    返回 消息
}

函数 _宿主_处理跳转定义(h, 消息) {
    定义 参数 = 消息_参数(消息)
    定义 名称 = _宿主_参数文本(参数, 0)
    定义 文件 = _宿主_参数文本(参数, 1)
    定义 结果 = _宿主_筛符号(h, 名称, 文件, 假, 真)
    如果 (计数(结果) == 0) {
        消息_设错误(消息, "未找到定义")
        返回 消息
    }
    消息_设结果(消息, 结果[0])
    返回 消息
}

函数 _宿主_处理查找引用(h, 消息) {
    定义 参数 = 消息_参数(消息)
    定义 名称 = _宿主_参数文本(参数, 0)
    定义 文件 = _宿主_参数文本(参数, 1)
    消息_设结果(消息, _宿主_筛符号(h, 名称, 文件, 假, 真))
    返回 消息
}

函数 _宿主_处理格式化(h, 消息) {
    定义 参数 = 消息_参数(消息)
    定义 文本 = _宿主_参数文本(参数, 0)
    如果 (文本 == "" 且 是列表(参数) == 真 且 计数(参数) > 1) { 文本 = 参数[1] }
    消息_设结果(消息, _宿主_格式化文本(文本))
    返回 消息
}

函数 _宿主_处理重命名(h, 消息) {
    定义 可变 命中数 = 0
    定义 参数 = 消息_参数(消息)
    定义 旧名 = _宿主_参数文本(参数, 0)
    定义 新名 = _宿主_参数文本(参数, 1)
    定义 文本 = _宿主_参数文本(参数, 2)
    如果 (旧名 == "" 或 新名 == "") {
        消息_设错误(消息, "重命名参数不足")
        返回 消息
    }
    定义 全部 = 宿主_全部符号(h)
    定义 可变 新缓存 = 字典()
    定义 可变 i = 0
    当 (i < 计数(全部)) {
        定义 符号 = 全部[i]
        如果 (符号[0] == 旧名) {
            符号[0] = 新名
            命中数 = 命中数 + 1
        }
        字典设(新缓存, _宿主_符号键(符号), 符号)
        i = i + 1
    }
    h[4] = 新缓存
    如果 (文本 != "") { 文本 = 替换(文本, 旧名, 新名) }
    消息_设结果(消息, [命中数, 文本])
    返回 消息
}

函数 _宿主_处理悬停(h, 消息) {
    定义 参数 = 消息_参数(消息)
    定义 名称 = _宿主_参数文本(参数, 0)
    定义 文件 = _宿主_参数文本(参数, 1)
    定义 结果 = _宿主_筛符号(h, 名称, 文件, 假, 真)
    如果 (计数(结果) == 0) {
        消息_设错误(消息, "未找到符号")
        返回 消息
    }
    消息_设结果(消息, _宿主_符号摘要(结果[0]))
    返回 消息
}

函数 _宿主_处理符号列表(h, 消息) {
    定义 参数 = 消息_参数(消息)
    定义 可变 查询 = _宿主_参数文本(参数, 0)
    定义 可变 文件 = ""
    如果 (包含(查询, "/") 或 以结尾(查询, ".nova")) {
        文件 = 查询
        查询 = ""
    }
    否则 {
        文件 = _宿主_参数文本(参数, 1)
    }
    消息_设结果(消息, _宿主_筛符号(h, 查询, 文件, 假, 假))
    返回 消息
}

函数 _宿主_处理工作区符号(h, 消息) {
    定义 查询 = _宿主_参数文本(消息_参数(消息), 0)
    消息_设结果(消息, _宿主_筛符号(h, 查询, "", 假, 假))
    返回 消息
}

函数 _宿主_处理重置探测(h, 消息) {
    定义 路径 = _宿主_参数文本(消息_参数(消息), 0)
    如果 (路径 == "") {
        消息_设错误(消息, "缺少工程路径")
        返回 消息
    }
    定义 探测 = 工程探测(路径)
    消息_设结果(消息, [源语言_名称(探测[0]), 构建系统_名称(探测[1]), 探测[2], 探测[3], 探测[4], 探测[5]])
    返回 消息
}

函数 _宿主_处理重置执行(h, 消息) {
    定义 路径 = _宿主_参数文本(消息_参数(消息), 0)
    如果 (路径 == "") {
        消息_设错误(消息, "缺少工程路径")
        返回 消息
    }
    定义 ctx = 协调上下文_创建()
    协调_执行(ctx, 路径)
    消息_设结果(消息, [_宿主_重置阶段名(协调_阶段(ctx)), 协调_建议列表(ctx), 协调_审批记录(ctx), 协调_报告(ctx), 协调_诊断(ctx)])
    返回 消息
}

函数 宿主_初始化IDE模式(h) {
    宿主_注册能力(h, 方法_编译)
    宿主_注册能力(h, 方法_诊断)
    宿主_注册能力(h, 方法_补全)
    宿主_注册能力(h, 方法_跳转定义)
    宿主_注册能力(h, 方法_查找引用)
    宿主_注册能力(h, 方法_格式化)
    宿主_注册能力(h, 方法_重命名)
    宿主_注册能力(h, 方法_悬停)
    宿主_注册能力(h, 方法_符号列表)
    宿主_注册能力(h, 方法_工作区符号)
    宿主_注册能力(h, 方法_重置探测)
    宿主_注册能力(h, 方法_重置执行)
}

函数 宿主_初始化CLI模式(h) {
    宿主_注册能力(h, 方法_编译)
    宿主_注册能力(h, 方法_诊断)
    宿主_注册能力(h, 方法_重置探测)
    宿主_注册能力(h, 方法_重置执行)
}

函数 宿主_打印报告(h) {
    打印("═══ 宿主服务报告 ═══")
    打印文本(字符串拼接("  名称: ", h[0]))
    打印文本(字符串拼接("  注册能力: ", 转字符串(计数(h[1]))))
    打印文本(字符串拼接("  消息队列: ", 转字符串(计数(h[2]))))
    打印文本(字符串拼接("  诊断缓存: ", 转字符串(计数(h[3]))))
    打印文本(字符串拼接("  符号缓存: ", 转字符串(计数(宿主_全部符号(h)))))
}

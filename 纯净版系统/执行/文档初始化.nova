导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./节点操作.nova")

// NovaOS 浏览器内核 · 第二层 · DOM解析引擎
// 核心能力: HTML5文档解析 → DOM树构建 → 节点操作

定义 节点_元素       = 1    // 元素
定义 节点_文本       = 3    // Text
定义 节点_注释       = 8    // Comment
定义 节点_文档       = 9    // Document
定义 节点_文档类型   = 10   // DocumentType
定义 节点_片段       = 11   // DocumentFragment

定义 标签_HTML     = 1
定义 标签_HEAD     = 2
定义 标签_BODY     = 3
定义 标签_DIV      = 4
定义 标签_SPAN     = 5
定义 标签_P        = 6
定义 标签_A        = 7
定义 标签_IMG      = 8
定义 标签_INPUT    = 9
定义 标签_BUTTON   = 10
定义 标签_FORM     = 11
定义 标签_TABLE    = 12
定义 标签_UL       = 13
定义 标签_LI       = 14
定义 标签_H1       = 15
定义 标签_H2       = 16
定义 标签_H3       = 17
定义 标签_SCRIPT   = 18
定义 标签_STYLE    = 19
定义 标签_LINK     = 20
定义 标签_META     = 21
定义 标签_TITLE    = 22
定义 标签_CANVAS   = 23
定义 标签_VIDEO    = 24
定义 标签_AUDIO    = 25
定义 标签_SECTION  = 26
定义 标签_NAV      = 27
定义 标签_HEADER   = 28
定义 标签_FOOTER   = 29
定义 标签_ARTICLE  = 30
定义 标签_UNKNOWN  = 0

定义 解析_数据         = 0
定义 解析_标签开始     = 1
定义 解析_标签名       = 2
定义 解析_属性名       = 3
定义 解析_属性值       = 4
定义 解析_标签结束     = 5
定义 解析_闭合标签     = 6
定义 解析_注释         = 7
定义 解析_脚本         = 8
定义 解析_样式         = 9

结构 DOM节点 {
    ID,
    类型,
    标签ID,
    标签名,
    文本内容,
    属性,    // [] [[键, 值], ...]
    子节点,    // [] 子DOM节点ID列表
    父节点,
    下一兄弟,
    样式,    // [] 计算后的CSS属性
    事件,    // [] 绑定的事件处理器
    脏,    // 布尔 是否需要重新布局/渲染
}

结构 DOM文档 {
    根节点,    // u32 html节点ID
    头节点,    // u32 head节点ID
    体节点,    // u32 body节点ID
    标题,
    URL,
    节点池,    // [] 所有DOM节点
    下一个ID,
    脚本列表,    // [] 待执行脚本
    样式列表,    // [] 样式表
    总节点数,
}

定义 可变 DOM_当前文档 = 空
定义 可变 DOM_已初始化 = 假

// §1 初始化

函数 DOM_初始化() {
    DOM_当前文档 = 空
    DOM_已初始化 = 真
    内核信息("DOM解析引擎: 初始化完成")
}

函数 DOM_创建文档(url) {
    定义 文档 = DOM文档 {}
    文档.URL = url
    文档.节点池 = []
    文档.下一个ID = 1
    文档.脚本列表 = []
    文档.样式列表 = []
    文档.总节点数 = 0
    文档.标题 = ""

    // 创建根document节点
    定义 根 = DOM_创建节点(文档, 节点_文档, "document", 标签_UNKNOWN)
    文档.根节点 = 根.ID

    DOM_当前文档 = 文档
    返回 文档
}

导入("../基础.nova")


// Agent状态
定义 Agent_空闲 = 0
定义 Agent_感知 = 1
定义 Agent_推理 = 2
定义 Agent_决策 = 3
定义 Agent_执行 = 4
定义 Agent_反思 = 5

// 目标类型
定义 目标_达成 = 0
定义 目标_维持 = 1
定义 目标_规避 = 2
定义 目标_查询 = 3

// Agent核心
// Agent: [ID, 状态, 目标栈, 信念库, 意图队列, 计划库, 感知缓冲, 记忆]
函数 Agent_创建(id) { 返回 [id, Agent_空闲, [], [], [], [], [], []]
}

函数 智能体_标识(a) { 返回 a[0] }
函数 Agent_状态(a) { 返回 a[1] }
函数 Agent_设状态(a, s) { a[1] = s }

// 目标管理
// 目标: [类型, 优先级, 描述哈希, 完成标志]
函数 Agent_添加目标(a, 类型, 优先级, 描述哈希) {
 追加(a[2], [类型, 优先级, 描述哈希, 假])
}

函数 Agent_当前目标(a) { 定义 可变 最高 = -1
 定义 可变 最高优先 = -1
 定义 可变 i = 0
 当 (i < 计数(a[2])) { 如果 (a[2][i][3] == 假 且 a[2][i][1] > 最高优先) {
 最高 = i
 最高优先 = a[2][i][1]
 }
 i = i + 1
 }
 如果 (最高 >= 0) { 返回 a[2][最高] }
 返回 空
}

函数 Agent_完成目标(a, 描述哈希) { 定义 可变 i = 0
 当 (i < 计数(a[2])) { 如果 (a[2][i][2] == 描述哈希) { a[2][i][3] = 真
 返回 真 }
 i = i + 1
 }
 返回 假
}

函数 Agent_活跃目标数(a) { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(a[2])) { 如果 (a[2][i][3] == 假) { c = c + 1 }
 i = i + 1 }
 返回 c
}

// 信念库
// 信念: [键哈希, 值, 置信度(0-100), 时间戳]
函数 Agent_添加信念(a, 键, 值, 置信度, 时间) {
 // 更新或新增
 定义 可变 i = 0
 当 (i < 计数(a[3])) { 如果 (a[3][i][0] == 键) { a[3][i][1] = 值
 a[3][i][2] = 置信度
 a[3][i][3] = 时间
 返回 }
 i = i + 1
 }
 追加(a[3], [键, 值, 置信度, 时间])
}

函数 Agent_查信念(a, 键) { 定义 可变 i = 0
 当 (i < 计数(a[3])) { 如果 (a[3][i][0] == 键) { 返回 a[3][i] }
 i = i + 1
 }
 返回 空
}

函数 Agent_信念数(a) { 返回 计数(a[3]) }

// 感知
函数 Agent_感知输入(a, 感知数据) {
 追加(a[6], 感知数据)
 // 限制缓冲大小
 如果 (计数(a[6]) > 100) { 定义 可变 新buf = []
 定义 可变 i = 计数(a[6]) - 50
 当 (i < 计数(a[6])) { 追加(新buf, a[6][i])
 i = i + 1 }
 a[6] = 新buf
 }
}

函数 Agent_最近感知(a, n) { 定义 可变 r = []
 定义 可变 起始 = 计数(a[6]) - n
 如果 (起始 < 0) { 起始 = 0 }
 当 (起始 < 计数(a[6])) { 追加(r, a[6][起始])
 起始 = 起始 + 1 }
 返回 r
}

// 工具注册表
// 工具: [名哈希, 类型, 参数数, 调用次数]
定义 可变 工具注册表 = []

函数 工具_注册(名哈希, 类型, 参数数) {
 追加(工具注册表, [名哈希, 类型, 参数数, 0])
}

函数 工具_查找(名哈希) { 定义 可变 i = 0
 当 (i < 计数(工具注册表)) { 如果 (工具注册表[i][0] == 名哈希) { 返回 i }
 i = i + 1
 }
 返回 -1
}

函数 工具_调用(名哈希, 参数) { 定义 索引 = 工具_查找(名哈希)
 如果 (索引 < 0) { 返回 [假, -1] }
 工具注册表[索引][3] = 工具注册表[索引][3] + 1
 // 模拟执行: 返回参数之和作为结果
 返回 [真, 折叠(参数, 0, (s, x) => s + x)]
}

函数 工具_数量() { 返回 计数(工具注册表) }

// 计划器 (HTN简化版)
// 计划: [步骤列表], 步骤: [动作哈希, 参数, 完成标志]
函数 计划_创建() { 返回 [] }

函数 计划_添加步骤(计划, 动作哈希, 参数) {
 追加(计划, [动作哈希, 参数, 假])
}

函数 计划_下一步(计划) { 定义 可变 i = 0
 当 (i < 计数(计划)) { 如果 (计划[i][2] == 假) { 返回 i }
 i = i + 1
 }
 返回 -1
}

函数 计划_完成步骤(计划, 步骤) {
    如果 (步骤 >= 0 且 步骤 < 计数(计划)) { 计划[步骤][2] = 真
}
}

函数 计划_完成率(计划) {
    如果 (计数(计划) == 0) { 返回 100
}
 定义 可变 已完成 = 0
 定义 可变 i = 0
 当 (i < 计数(计划)) { 如果 (计划[i][2]) { 已完成 = 已完成 + 1 }
 i = i + 1 }
 返回 已完成 * 100 / 计数(计划)
}

// 记忆系统
// 记忆: [键哈希, 内容哈希, 重要性, 访问次数, 时间]
函数 Agent_记忆存(a, 键, 内容, 重要性, 时间) {
 追加(a[7], [键, 内容, 重要性, 0, 时间])
}

函数 Agent_记忆取(a, 键) { 定义 可变 i = 0
 当 (i < 计数(a[7])) { 如果 (a[7][i][0] == 键) { a[7][i][3] = a[7][i][3] + 1
 返回 a[7][i] }
 i = i + 1
 }
 返回 空
}

函数 Agent_记忆_按重要性(a, topN) { 定义 可变 结果 = []
    定义 可变 选了 = 0
 定义 可变 已选 = []
 当 (选了 < topN 且 选了 < 计数(a[7])) { 定义 可变 最佳 = -1
 定义 可变 最佳重 = -1
 定义 可变 i = 0
 当 (i < 计数(a[7])) { 定义 可变 跳过 = 假
 定义 可变 j = 0
 当 (j < 计数(已选)) { 如果 (已选[j] == i) { 跳过 = 真 }
 j = j + 1 }
 如果 (跳过 == 假 且 a[7][i][2] > 最佳重) { 最佳 = i
 最佳重 = a[7][i][2] }
 i = i + 1
 }
 如果 (最佳 >= 0) { 追加(结果, a[7][最佳])
 追加(已选, 最佳) }
 选了 = 选了 + 1
 }
 返回 结果
}

// 多Agent消息传递
定义 可变 消息队列 = []

函数 发送消息(发送者, 接收者, 类型, 内容) {
 追加(消息队列, [发送者, 接收者, 类型, 内容])
}

函数 接收消息(接收者) { 定义 可变 收到 = []
 定义 可变 i = 0
 当 (i < 计数(消息队列)) { 如果 (消息队列[i][1] == 接收者) { 追加(收到, 消息队列[i]) }
 i = i + 1
 }
 返回 收到
}

函数 清空消息() { 消息队列 = [] }

// Agent循环
函数 Agent_步(a) { 如果 (a[1] == Agent_空闲) { a[1] = Agent_感知
 返回 Agent_感知 }
 如果 (a[1] == Agent_感知) { a[1] = Agent_推理
 返回 Agent_推理 }
 如果 (a[1] == Agent_推理) { a[1] = Agent_决策
 返回 Agent_决策 }
 如果 (a[1] == Agent_决策) { a[1] = Agent_执行
 返回 Agent_执行 }
 如果 (a[1] == Agent_执行) { a[1] = Agent_反思
 返回 Agent_反思 }
 a[1] = Agent_空闲
 返回 Agent_空闲
}

// 工具链
函数 工具_链式调用(工具哈希列表, 初始参数) { 定义 可变 当前结果 = 初始参数
 定义 可变 i = 0
 当 (i < 计数(工具哈希列表)) { 定义 r = 工具_调用(工具哈希列表[i], 当前结果)
 如果 (r[0] == 假) { 返回 [假, i] }
 当前结果 = [r[1]]
 i = i + 1
 }
 返回 [真, 当前结果[0]]
}

// 反思评分
函数 Agent_反思评分(a) {
 // 基于目标完成率+信念置信度的综合评分
 定义 可变 目标分 = 0
 定义 总目标 = 计数(a[2])
 如果 (总目标 > 0) { 定义 可变 完成 = 0
 定义 可变 i = 0
 当 (i < 总目标) { 如果 (a[2][i][3]) { 完成 = 完成 + 1 }
 i = i + 1 }
 目标分 = 完成 * 100 / 总目标
 }
 定义 可变 信念分 = 0
 如果 (计数(a[3]) > 0) {
 信念分 = 折叠(a[3], 0, (s, x) => s + x[2]) / 计数(a[3])
 }
 返回 (目标分 + 信念分) / 2
}

// 任务分解
函数 任务_分解(总任务哈希, 子任务数) { 定义 可变 子任务 = []
 定义 可变 i = 0
 当 (i < 子任务数) {
 追加(子任务, [总任务哈希 * 100 + i, 假])
 i = i + 1
 }
 返回 子任务
}

函数 任务_完成子任务(子任务列表, 索引) {
    如果 (索引 < 计数(子任务列表)) { 子任务列表[索引][1] = 真
}
}

函数 任务_全部完成(子任务列表) { 定义 可变 i = 0
 当 (i < 计数(子任务列表)) { 如果 (子任务列表[i][1] == 假) { 返回 假 }
 i = i + 1
 }
 返回 真
}

// ═══════════════════════════════════════════════════════════════════════
// NovaOS 自学习闭环 — 类人脑仿生自主进化引擎
// 非Transformer暴力计算, 赫布学习+强化学习+元学习三位一体
// 核心循环: 行动→反馈→评估→强化→遗忘→发现→行动(永不停止)
// ═══════════════════════════════════════════════════════════════════════

导入("./神经中枢.nova")
导入("./神经总线.nova")
导入("./推理/接口.nova")
导入("./记忆/接口.nova")
导入("./执行/接口.nova")

// ═══════════════════════════════════════════════════════════════════════
// §1 学习常量与状态
// ═══════════════════════════════════════════════════════════════════════

定义 奖励_成功 = 100
定义 奖励_部分 = 30
定义 惩罚_失败 = -50
定义 惩罚_超时 = -20

定义 衰减系数 = 995       // 千分制, 每周期衰减0.5%
定义 好奇心系数 = 100     // 探索新能力的驱动力
定义 元学习周期 = 500     // 每N个周期做一次元学习
定义 记忆巩固周期 = 200   // 每N个周期巩固短期记忆

定义 可变 累计奖励 = 0
定义 可变 累计惩罚 = 0
定义 可变 连续成功 = 0
定义 可变 连续失败 = 0
定义 可变 总行动数 = 0
定义 可变 学习周期数 = 0

// ═══════════════════════════════════════════════════════════════════════
// §2 经验缓冲 — 短期记忆
// ═══════════════════════════════════════════════════════════════════════

结构 经验条目 {
    状态,         // 行动前状态哈希
    行动,         // 采取的行动编码
    奖励,         // 获得的奖励
    下一状态,     // 行动后状态哈希
    时间戳,       // 发生时间
    脑区,         // 涉及的脑区
}

定义 经验缓冲容量 = 2048
定义 可变 经验缓冲 = 0
定义 可变 经验写位 = 0
定义 可变 经验总数 = 0

函数 自学习_初始化() {
    经验缓冲 = 堆_分配_数组(经验条目, 经验缓冲容量)
    如果 (经验缓冲 == 0) { 返回 -1 }
    打印("[自学习] 经验缓冲初始化, 容量 " + 经验缓冲容量)
    返回 0
}

函数 自学习_记录经验(状态, 行动, 奖励, 下一状态, 脑区) {
    定义 偏移 = 经验写位 * 48
    内存_写64(经验缓冲 + 偏移, 状态)
    内存_写64(经验缓冲 + 偏移 + 8, 行动)
    内存_写64(经验缓冲 + 偏移 + 16, 奖励)
    内存_写64(经验缓冲 + 偏移 + 24, 下一状态)
    内存_写64(经验缓冲 + 偏移 + 32, 全局脉冲计数)
    内存_写64(经验缓冲 + 偏移 + 40, 脑区)
    经验写位 = (经验写位 + 1) % 经验缓冲容量
    经验总数 = 经验总数 + 1
}

// ═══════════════════════════════════════════════════════════════════════
// §3 奖励信号处理 — 强化学习核心
// ═══════════════════════════════════════════════════════════════════════

函数 自学习_处理奖励(行动结果) {
    总行动数 = 总行动数 + 1
    定义 奖励 = 0

    如果 (行动结果 > 0) {
        // 成功
        奖励 = 奖励_成功
        连续成功 = 连续成功 + 1
        连续失败 = 0
        // 连续成功加成
        如果 (连续成功 > 5) {
            奖励 = 奖励 + 连续成功 * 10
        }
    } 否则 如果 (行动结果 == 0) {
        // 部分成功
        奖励 = 奖励_部分
        连续成功 = 0
        连续失败 = 0
    } 否则 {
        // 失败
        奖励 = 惩罚_失败
        连续失败 = 连续失败 + 1
        连续成功 = 0
    }

    如果 (奖励 > 0) {
        累计奖励 = 累计奖励 + 奖励
    } 否则 {
        累计惩罚 = 累计惩罚 + (0 - 奖励)
    }

    返回 奖励
}

// ═══════════════════════════════════════════════════════════════════════
// §4 突触强化 — 赫布学习规则
// ═══════════════════════════════════════════════════════════════════════

函数 自学习_赫布更新(奖励) {
    如果 (奖励 > 0) {
        // 正奖励: 强化最近活跃通路
        神经中枢_赫布强化(奖励)
    } 否则 如果 (奖励 < 0) {
        // 负奖励: 削弱错误通路
        神经中枢_赫布削弱(0 - 奖励)
    }
}

// ═══════════════════════════════════════════════════════════════════════
// §5 记忆巩固 — 短期→长期迁移
// ═══════════════════════════════════════════════════════════════════════

函数 自学习_巩固记忆() {
    如果 (经验总数 < 10) { 返回 }

    // 扫描经验缓冲, 找出高奖励的经验模式
    定义 可变 高奖励数 = 0
    定义 可变 i = 0
    当 (i < 经验缓冲容量 && i < 经验总数) {
        定义 偏移 = i * 48
        定义 奖励 = 内存_读64(经验缓冲 + 偏移 + 16)
        如果 (奖励 > 奖励_部分) {
            高奖励数 = 高奖励数 + 1
            // 高奖励经验持久化到记忆脑区
            定义 行动 = 内存_读64(经验缓冲 + 偏移 + 8)
            定义 状态 = 内存_读64(经验缓冲 + 偏移)
            记忆_存储经验("成功模式", 状态 + "_" + 行动, 奖励)
        }
        i = i + 1
    }

    如果 (高奖励数 > 0) {
        打印("[自学习] 巩固 " + 高奖励数 + " 条高奖励经验到长期记忆")
    }
}

// ═══════════════════════════════════════════════════════════════════════
// §6 元学习 — 学会如何学习
// ═══════════════════════════════════════════════════════════════════════

函数 自学习_元学习() {
    学习周期数 = 学习周期数 + 1

    // 分析学习效率
    定义 成功率 = 0
    如果 (总行动数 > 0) {
        成功率 = 累计奖励 * 1000 / (累计奖励 + 累计惩罚 + 1)
    }

    // 动态调整策略
    如果 (成功率 > 800) {
        // 高成功率: 减少探索, 增加利用
        打印("[元学习] 高成功率(" + 成功率 + "/1000), 切换到利用模式")
    } 否则 如果 (成功率 < 300) {
        // 低成功率: 增加探索, 尝试新策略
        打印("[元学习] 低成功率(" + 成功率 + "/1000), 切换到探索模式")
        推理_扫描新能力()
    } 否则 {
        // 中等: 平衡探索与利用
        打印("[元学习] 平衡模式, 成功率 " + 成功率 + "/1000")
    }

    // 突触修剪(遗忘无用连接)
    神经中枢_突触修剪()

    打印("[元学习] 第" + 学习周期数 + "轮, 总行动" + 总行动数 + " 累计奖励" + 累计奖励)
}

// ═══════════════════════════════════════════════════════════════════════
// §7 好奇心驱动 — 主动探索新能力
// ═══════════════════════════════════════════════════════════════════════

函数 自学习_好奇心驱动() {
    // 计算好奇心分数: 长时间没有新经验→好奇心上升
    定义 沉默周期 = 全局脉冲计数 - 经验总数
    如果 (沉默周期 > 好奇心系数) {
        打印("[好奇心] 长时间无新经验, 主动寻找任务")
        // 触发推理脑区搜索新机会
        神经总线_发送(脑区_推理, 脑区_执行, 0x100, 0, 优先_中)
    }
}

// ═══════════════════════════════════════════════════════════════════════
// §8 自学习主tick — 由神经中枢每个脉冲调用
// ═══════════════════════════════════════════════════════════════════════

函数 自学习_tick() {
    // 好奇心驱动(主动寻找工作)
    自学习_好奇心驱动()

    // 周期性记忆巩固
    如果 (全局脉冲计数 % 记忆巩固周期 == 0) {
        自学习_巩固记忆()
    }

    // 周期性元学习
    如果 (全局脉冲计数 % 元学习周期 == 0) {
        自学习_元学习()
    }

    // ── 新增: 与云端/IZH/递质/IIT协同 ──

    // 云端回流训练触发(每500脉冲检查缓冲是否需要蒸馏)
    如果 (全局脉冲计数 % 500 == 0) {
        如果 (计数(回流_缓冲) >= 128) {
            云端_触发蒸馏()
        }
    }

    // 神经递质奖赏调制(成功→多巴胺释放，失败→去甲肾上腺素)
    如果 (连续成功 > 3) {
        递质_释放奖赏(连续成功 * 20)
    }
    如果 (连续失败 > 3) {
        递质_释放恐惧(连续失败 * 30)
    }

    // 存算一体: 突触权重就地更新
    如果 (存算一体_启用) {
        存算一体_就地计算次数 = 存算一体_就地计算次数 + 1
    }
}

// ═══════════════════════════════════════════════════════════════════════
// §9 统计报告
// ═══════════════════════════════════════════════════════════════════════

函数 自学习_报告() {
    打印("═══ 自学习状态报告 ═══")
    打印("  总行动: " + 整数转字符串(总行动数))
    打印("  累计奖励: " + 整数转字符串(累计奖励))
    打印("  累计惩罚: " + 整数转字符串(累计惩罚))
    打印("  连续成功: " + 整数转字符串(连续成功))
    打印("  经验总数: " + 整数转字符串(经验总数))
    打印("  学习轮次: " + 整数转字符串(学习周期数))
    定义 效率 = 0
    如果 (总行动数 > 0) {
        效率 = 累计奖励 * 100 / (总行动数 + 1)
    }
    打印("  学习效率: " + 整数转字符串(效率) + "%")
    打印("═══════════════════════")
}

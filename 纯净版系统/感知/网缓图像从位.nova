// Skia→Nova: Sk图像 / SkPixmap — 图像抽象与像素操作
// 对应: skia/src/core/Sk图像.cpp (~600行)
//       skia/src/core/SkPixmap.cpp (~400行)
//       skia/src/core/Sk图像Generator.cpp (~300行)
//       skia/src/codec/SkCodec.cpp (~800行)
// Sk图像: 不可变图像对象(图处纹理或CPU像素)
// SkPixmap: 可读写像素视图(用于CPU端操作)
// 解码桥接: PNG解码器/JPEG解码器 → Sk图像
// 【Nova特色】AI图像优化:
//   ① 解码时根据显示尺寸决定降采样级别
//   ② 纹理上传优先级由AI总线根据可见性决定

导入("./图位图像素缓.nova")
导入("../稳态/图处显示.nova")
导入("../推理/通信总线.nova")
导入("./格式检测.nova")
导入("./内核直连层.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/内存初始化.nova")
导入("../执行/底层内存操.nova")

// §1 图像类型

定义 IMAGE_SOURCE_CPU    = 0    // Nova缓冲itmap持有像素
定义 IMAGE_SOURCE_图处    = 1    // GrTexture持有
定义 IMAGE_SOURCE_LAZY   = 2    // 延迟解码

定义 IMAGE_FORMAT_PNG    = 1
定义 IMAGE_FORMAT_JPEG   = 2
定义 IMAGE_FORMAT_WEBP   = 3
定义 IMAGE_FORMAT_GIF    = 4
定义 IMAGE_FORMAT_BMP    = 5
定义 IMAGE_FORMAT_ICO    = 6

结构 Sk图像 {
    来源,    // u8 IMAGE_SOURCE_xxx
    宽,
    高,
    颜色类型,    // u8 COLORTYPE_xxx
    // CPU像素
    位图,    // u64 Nova缓冲itmap*
    // 图处纹理
    gpu纹理,    // u64 GrTexture*
    // 延迟解码
    原始数据,    // u64 压缩数据指针
    原始长度,
    图像格式,    // u8 IMAGE_FORMAT_xxx
    已解码,
    // 管理
    引用计数,
    唯一ID,
}

定义 可变 Sk图像_下一ID = 1

// §2 Sk图像 创建


函数 Sk图像_从位图(bm) {
    如果 (bm == 0) { 返回 0 }
    定义 img = 堆_分配(Sk图像)
    img.来源 = IMAGE_SOURCE_CPU
    img.宽 = bm.宽; img.高 = bm.高
    img.颜色类型 = bm.颜色类型
    img.位图 = bm
    bm.引用计数 = bm.引用计数 + 1
    img.gpu纹理 = 0
    img.原始数据 = 0; img.原始长度 = 0
    img.已解码 = 真
    img.引用计数 = 1
    img.唯一ID = Sk图像_下一ID
    Sk图像_下一ID = Sk图像_下一ID + 1
    返回 img
}

函数 Sk图像_从图处纹理(tex, 宽, 高) {
    如果 (tex == 0) { 返回 0 }
    定义 img = 堆_分配(Sk图像)
    img.来源 = IMAGE_SOURCE_图处
    img.宽 = 宽; img.高 = 高
    img.颜色类型 = COLORTYPE_RGBA8888
    img.位图 = 0
    img.gpu纹理 = tex
    tex.引用计数 = tex.引用计数 + 1
    img.已解码 = 真
    img.引用计数 = 1
    img.唯一ID = Sk图像_下一ID
    Sk图像_下一ID = Sk图像_下一ID + 1
    返回 img
}

// 延迟解码: 只存储压缩数据, 首次使用时解码
函数 Sk图像_从编码数据(数据, 长度) {
    如果 (数据 == 0 || 长度 < 4) { 返回 0 }
    定义 img = 堆_分配(Sk图像)
    img.来源 = IMAGE_SOURCE_LAZY
    img.原始数据 = 数据
    img.原始长度 = 长度
    img.图像格式 = Sk图像_检测格式(数据, 长度)
    img.已解码 = 假
    img.位图 = 0; img.gpu纹理 = 0
    img.引用计数 = 1
    img.唯一ID = Sk图像_下一ID
    Sk图像_下一ID = Sk图像_下一ID + 1

    // 提前获取尺寸(不完全解码)
    Sk图像_预读尺寸(img)

    返回 img
}

// §3 引用计数与销毁

函数 Sk图像_增引用(img) {
    如果 (img == 0) { 返回 }
    img.引用计数 = img.引用计数 + 1
}

函数 Sk图像_减引用(img) {
    如果 (img == 0) { 返回 }
    img.引用计数 = img.引用计数 - 1
    如果 (img.引用计数 <= 0) {
        Sk图像_销毁(img)
    }
}

函数 Sk图像_销毁(img) {
    如果 (img == 0) { 返回 }
    // 释放CPU位图
    如果 (img.位图 != 0) {
        定义 bm = img.位图
        bm.引用计数 = bm.引用计数 - 1
        如果 (bm.引用计数 <= 0) {
            如果 (bm.像素 != 0) {
                平台_释放内存(bm.像素, bm.宽 * bm.高 * 4)
            }
            堆_释放(bm)
        }
    }
    // 释放GPU纹理
    如果 (img.gpu纹理 != 0) {
        定义 tex = img.gpu纹理
        tex.引用计数 = tex.引用计数 - 1
        如果 (tex.引用计数 <= 0) {
            堆_释放(tex)
        }
    }
    // 释放压缩数据(如果持有)
    如果 (img.原始数据 != 0 && img.来源 == IMAGE_SOURCE_LAZY) {
        // 压缩数据由外部管理, 不在这里释放
    }
    堆_释放(img)
}

// §4 图像操作 — 裁剪/缩放/旋转

函数 Sk图像_获取像素(img, x, y) {
    如果 (img == 0) { 返回 0 }
    如果 (img.已解码 == 假) { Sk图像_确保解码(img) }
    如果 (img.位图 == 0) { 返回 0 }
    如果 (x < 0 || x >= img.宽 || y < 0 || y >= img.高) { 返回 0 }
    定义 偏移 = (y * img.宽 + x) * 4
    返回 内存_读32(img.位图.像素 + 偏移)
}

函数 Sk图像_设置像素(img, x, y, 颜色) {
    如果 (img == 0 || img.位图 == 0) { 返回 }
    如果 (x < 0 || x >= img.宽 || y < 0 || y >= img.高) { 返回 }
    定义 偏移 = (y * img.宽 + x) * 4
    内存_写32(img.位图.像素 + 偏移, 颜色)
}

函数 Sk图像_裁剪(img, 左, 上, 右, 下) {
    如果 (img == 0) { 返回 空 }
    如果 (img.已解码 == 假) { Sk图像_确保解码(img) }
    如果 (img.位图 == 0) { 返回 空 }

    // 范围检查
    定义 可变 实际左 = 左
    定义 可变 实际上 = 上
    定义 可变 实际右 = 右
    定义 可变 实际下 = 下
    如果 (实际左 < 0) { 实际左 = 0 }
    如果 (实际上 < 0) { 实际上 = 0 }
    如果 (实际右 > img.宽) { 实际右 = img.宽 }
    如果 (实际下 > img.高) { 实际下 = img.高 }
    如果 (实际左 >= 实际右 || 实际上 >= 实际下) { 返回 空 }

    定义 新宽 = 实际右 - 实际左
    定义 新高 = 实际下 - 实际上

    // 创建新位图
    定义 新位图 = Sk位图_创建(新宽, 新高, img.颜色类型)
    如果 (新位图 == 0) { 返回 空 }

    // 逐行复制像素
    定义 可变 y = 0
    当 (y < 新高) {
        定义 源行 = img.位图.像素 + ((实际上 + y) * img.宽 + 实际左) * 4
        定义 目标行 = 新位图.像素 + y * 新宽 * 4
        内存_复制(目标行, 源行, 新宽 * 4)
        y = y + 1
    }

    返回 Sk图像_从位图(新位图)
}

函数 Sk图像_缩放(img, 新宽, 新高) {
    如果 (img == 0 || 新宽 <= 0 || 新高 <= 0) { 返回 空 }
    如果 (img.已解码 == 假) { Sk图像_确保解码(img) }
    如果 (img.位图 == 0) { 返回 空 }

    定义 新位图 = Sk位图_创建(新宽, 新高, img.颜色类型)
    如果 (新位图 == 0) { 返回 空 }

    // 最近邻缩放(简单但快速)
    定义 x比例 = img.宽 * 10000 / 新宽
    定义 y比例 = img.高 * 10000 / 新高

    定义 可变 y = 0
    当 (y < 新高) {
        定义 源y = y * y比例 / 10000
        如果 (源y >= img.高) { 源y = img.高 - 1 }
        定义 可变 x = 0
        当 (x < 新宽) {
            定义 源x = x * x比例 / 10000
            如果 (源x >= img.宽) { 源x = img.宽 - 1 }
            定义 颜色 = 内存_读32(img.位图.像素 + (源y * img.宽 + 源x) * 4)
            内存_写32(新位图.像素 + (y * 新宽 + x) * 4, 颜色)
            x = x + 1
        }
        y = y + 1
    }

    返回 Sk图像_从位图(新位图)
}

函数 Sk图像_双线性缩放(img, 新宽, 新高) {
    如果 (img == 0 || 新宽 <= 0 || 新高 <= 0) { 返回 空 }
    如果 (img.已解码 == 假) { Sk图像_确保解码(img) }
    如果 (img.位图 == 0) { 返回 空 }

    定义 新位图 = Sk位图_创建(新宽, 新高, img.颜色类型)
    如果 (新位图 == 0) { 返回 空 }

    定义 x比例 = (img.宽 - 1) * 10000 / (新宽 - 1)
    定义 y比例 = (img.高 - 1) * 10000 / (新高 - 1)

    定义 可变 y = 0
    当 (y < 新高) {
        定义 源y_定点 = y * y比例
        定义 源y = 源y_定点 / 10000
        定义 y分数 = (源y_定点 % 10000) * 256 / 10000
        如果 (源y >= img.高 - 1) { 源y = img.高 - 2 }

        定义 可变 x = 0
        当 (x < 新宽) {
            定义 源x_定点 = x * x比例
            定义 源x = 源x_定点 / 10000
            定义 x分数 = (源x_定点 % 10000) * 256 / 10000
            如果 (源x >= img.宽 - 1) { 源x = img.宽 - 2 }

            // 取四个相邻像素
            定义 基址 = img.位图.像素
            定义 c00 = 内存_读32(基址 + (源y * img.宽 + 源x) * 4)
            定义 c10 = 内存_读32(基址 + (源y * img.宽 + 源x + 1) * 4)
            定义 c01 = 内存_读32(基址 + ((源y + 1) * img.宽 + 源x) * 4)
            定义 c11 = 内存_读32(基址 + ((源y + 1) * img.宽 + 源x + 1) * 4)

            // 双线性插值每个通道
            定义 结果 = Sk图像_双线性插值(c00, c10, c01, c11, x分数, y分数)
            内存_写32(新位图.像素 + (y * 新宽 + x) * 4, 结果)
            x = x + 1
        }
        y = y + 1
    }

    返回 Sk图像_从位图(新位图)
}

函数 Sk图像_双线性插值(c00, c10, c01, c11, fx, fy) {
    // fx, fy: 0-256
    定义 ifx = 256 - fx
    定义 ify = 256 - fy

    // 逐通道插值
    定义 a = (Sk颜色_A(c00) * ifx * ify + Sk颜色_A(c10) * fx * ify + Sk颜色_A(c01) * ifx * fy + Sk颜色_A(c11) * fx * fy) / 65536
    定义 r = (Sk颜色_R(c00) * ifx * ify + Sk颜色_R(c10) * fx * ify + Sk颜色_R(c01) * ifx * fy + Sk颜色_R(c11) * fx * fy) / 65536
    定义 g = (Sk颜色_G(c00) * ifx * ify + Sk颜色_G(c10) * fx * ify + Sk颜色_G(c01) * ifx * fy + Sk颜色_G(c11) * fx * fy) / 65536
    定义 b = (Sk颜色_B(c00) * ifx * ify + Sk颜色_B(c10) * fx * ify + Sk颜色_B(c01) * ifx * fy + Sk颜色_B(c11) * fx * fy) / 65536

    返回 (a << 24) | (r << 16) | (g << 8) | b
}

函数 Sk颜色_A(c) { 返回 (c >> 24) & 255 }
函数 Sk颜色_R(c) { 返回 (c >> 16) & 255 }
函数 Sk颜色_G(c) { 返回 (c >> 8) & 255 }
函数 Sk颜色_B(c) { 返回 c & 255 }

// §5 图像绘制到画布

函数 Sk图像_绘制到帧缓冲(img, 帧缓冲, 步幅, 帧宽, 帧高, 目标x, 目标y) {
    如果 (img == 0 || 帧缓冲 == 0) { 返回 }
    如果 (img.已解码 == 假) { Sk图像_确保解码(img) }
    如果 (img.位图 == 0) { 返回 }

    // 裁剪到帧缓冲范围
    定义 可变 源x起始 = 0
    定义 可变 源y起始 = 0
    定义 可变 绘制宽 = img.宽
    定义 可变 绘制高 = img.高

    如果 (目标x < 0) {
        源x起始 = 0 - 目标x
        绘制宽 = 绘制宽 + 目标x
        目标x = 0
    }
    如果 (目标y < 0) {
        源y起始 = 0 - 目标y
        绘制高 = 绘制高 + 目标y
        目标y = 0
    }
    如果 (目标x + 绘制宽 > 帧宽) { 绘制宽 = 帧宽 - 目标x }
    如果 (目标y + 绘制高 > 帧高) { 绘制高 = 帧高 - 目标y }
    如果 (绘制宽 <= 0 || 绘制高 <= 0) { 返回 }

    // 逐行复制(含Alpha混合)
    定义 可变 y = 0
    当 (y < 绘制高) {
        定义 源行 = img.位图.像素 + ((源y起始 + y) * img.宽 + 源x起始) * 4
        定义 目标行 = 帧缓冲 + (目标y + y) * 步幅 + 目标x * 4

        定义 可变 x = 0
        当 (x < 绘制宽) {
            定义 源颜色 = 内存_读32(源行 + x * 4)
            定义 srcA = Sk颜色_A(源颜色)

            如果 (srcA == 255) {
                // 完全不透明: 直接写入
                内存_写32(目标行 + x * 4, 源颜色)
            } 否则 如果 (srcA > 0) {
                // Alpha混合
                定义 目标颜色 = 内存_读32(目标行 + x * 4)
                定义 invA = 255 - srcA
                定义 outA = srcA + (Sk颜色_A(目标颜色) * invA) / 255
                定义 outR = Sk颜色_R(源颜色) + (Sk颜色_R(目标颜色) * invA) / 255
                定义 outG = Sk颜色_G(源颜色) + (Sk颜色_G(目标颜色) * invA) / 255
                定义 outB = Sk颜色_B(源颜色) + (Sk颜色_B(目标颜色) * invA) / 255
                内存_写32(目标行 + x * 4, (outA << 24) | (outR << 16) | (outG << 8) | outB)
            }
            x = x + 1
        }
        y = y + 1
    }
}

函数 Sk图像_绘制缩放到帧缓冲(img, 帧缓冲, 步幅, 帧宽, 帧高, 目标矩形) {
    如果 (img == 0 || 帧缓冲 == 0) { 返回 }
    // 缩放绘制: 先缩放再绘制
    定义 目标宽 = (目标矩形.右 - 目标矩形.左) / 100
    定义 目标高 = (目标矩形.下 - 目标矩形.上) / 100
    如果 (目标宽 <= 0 || 目标高 <= 0) { 返回 }

    定义 缩放图 = Sk图像_缩放(img, 目标宽, 目标高)
    如果 (缩放图 != 0) {
        Sk图像_绘制到帧缓冲(缩放图, 帧缓冲, 步幅, 帧宽, 帧高, 目标矩形.左 / 100, 目标矩形.上 / 100)
        Sk图像_减引用(缩放图)
    }
}

// §6 位图创建辅助

定义 COLORTYPE_RGBA8888 = 1
定义 COLORTYPE_RGB888   = 2
定义 COLORTYPE_GRAY8    = 3
定义 COLORTYPE_ALPHA8   = 4

结构 Sk位图 {
    宽,
    高,
    颜色类型,
    像素,            // u64 像素数据指针
    步幅,            // u32 每行字节数
    引用计数,
}

函数 Sk位图_创建(宽, 高, 颜色类型) {
    如果 (宽 <= 0 || 高 <= 0) { 返回 0 }
    定义 可变 每像素字节 = 4
    如果 (颜色类型 == COLORTYPE_RGB888) { 每像素字节 = 3 }
    如果 (颜色类型 == COLORTYPE_GRAY8) { 每像素字节 = 1 }
    如果 (颜色类型 == COLORTYPE_ALPHA8) { 每像素字节 = 1 }

    定义 像素大小 = 宽 * 高 * 每像素字节
    定义 可变 bm = 堆_分配(Sk位图)
    如果 (bm == 0) { 返回 0 }
    bm.宽 = 宽
    bm.高 = 高
    bm.颜色类型 = 颜色类型
    bm.步幅 = 宽 * 每像素字节
    bm.像素 = 平台_申请内存(像素大小)
    如果 (bm.像素 == 0) {
        堆_释放(bm)
        返回 0
    }
    内存_清零(bm.像素, 像素大小)
    bm.引用计数 = 1
    返回 bm
}

函数 Sk位图_销毁(bm) {
    如果 (bm == 0) { 返回 }
    如果 (bm.像素 != 0) {
        定义 每像素字节 = 4
        如果 (bm.颜色类型 == COLORTYPE_GRAY8 || bm.颜色类型 == COLORTYPE_ALPHA8) { 每像素字节 = 1 }
        如果 (bm.颜色类型 == COLORTYPE_RGB888) { 每像素字节 = 3 }
        平台_释放内存(bm.像素, bm.宽 * bm.高 * 每像素字节)
    }
    堆_释放(bm)
}

// §7 AI图像优化 — 自适应降采样

函数 Sk图像_AI推荐缩放(原宽, 原高, 显示宽, 显示高) {
    // 根据显示尺寸推荐解码缩放比例
    // 如果显示尺寸远小于原尺寸, 降采样以节省内存
    如果 (显示宽 <= 0 || 显示高 <= 0) { 返回 1 }
    如果 (原宽 <= 显示宽 && 原高 <= 显示高) { 返回 1 }

    定义 x比 = 原宽 / 显示宽
    定义 y比 = 原高 / 显示高
    定义 可变 比 = x比
    如果 (y比 > 比) { 比 = y比 }

    如果 (比 >= 8) { 返回 8 }
    如果 (比 >= 4) { 返回 4 }
    如果 (比 >= 2) { 返回 2 }
    返回 1
}

// §8 统计与调试

定义 可变 统计_图像创建数 = 0
定义 可变 统计_图像销毁数 = 0
定义 可变 统计_解码次数 = 0
定义 可变 统计_缩放次数 = 0
定义 可变 统计_裁剪次数 = 0
定义 可变 统计_绘制次数 = 0

函数 Sk图像_打印统计() {
    打印("[图像] ═══════════ 图像系统统计 ═══════════")
    打印(字符串拼接("  图像创建数: ", 转字符串(统计_图像创建数)))
    打印(字符串拼接("  图像销毁数: ", 转字符串(统计_图像销毁数)))
    打印(字符串拼接("  解码次数:   ", 转字符串(统计_解码次数)))
    打印(字符串拼接("  缩放次数:   ", 转字符串(统计_缩放次数)))
    打印(字符串拼接("  裁剪次数:   ", 转字符串(统计_裁剪次数)))
    打印(字符串拼接("  绘制次数:   ", 转字符串(统计_绘制次数)))
    打印(字符串拼接("  下一ID:     ", 转字符串(Sk图像_下一ID)))
    打印("[图像] ═══════════════════════════════════════")
}

函数 Sk图像_打印信息(img) {
    如果 (img == 0) {
        打印("[图像] 空图像")
        返回
    }
    打印("[图像] ── 图像信息 ──")
    打印(字符串拼接("  ID:       ", 转字符串(img.唯一ID)))
    打印(字符串拼接("  尺寸:     ", 字符串拼接(转字符串(img.宽), 字符串拼接("×", 转字符串(img.高)))))
    打印(字符串拼接("  来源:     ", 转字符串(img.来源)))
    打印(字符串拼接("  已解码:   ", 转字符串(img.已解码)))
    打印(字符串拼接("  引用计数: ", 转字符串(img.引用计数)))
    如果 (img.图像格式 > 0) {
        打印(字符串拼接("  格式:     ", 转字符串(img.图像格式)))
    }
}

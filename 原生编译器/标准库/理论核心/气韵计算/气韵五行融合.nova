// Nova · 气韵五行融合引擎
// 木气(创建流) → 火气(计算流) → 土气(存储流) → 金气(判定流) → 水气(释放流)
// 五行相生相克 + 气势传播 + 能量守恒 + 平衡优化

导入("../../基础.nova")
导入("../五行约束/五行约束求解.nova")

// 五行常量

定义 穴_休眠 = 0
定义 穴_活跃 = 1
定义 穴_过载 = 2
定义 穴_枯竭 = 3

// 全局统计
定义 可变 _五行_传输次数 = 0
定义 可变 _五行_总能量 = 0
定义 可变 _五行_历史 = []

// 五行相生相克矩阵

函数 气韵五行_相生(行) {
    如果 (行 == 行_木) { 返回 行_火
}
 如果 (行 == 行_火) { 返回 行_土 }
 如果 (行 == 行_土) { 返回 行_金 }
 如果 (行 == 行_金) { 返回 行_水 }
 如果 (行 == 行_水) { 返回 行_木 }
 返回 -1
}

函数 气韵五行_相克(行) {
    如果 (行 == 行_木) { 返回 行_土
}
 如果 (行 == 行_火) { 返回 行_金 }
 如果 (行 == 行_土) { 返回 行_水 }
 如果 (行 == 行_金) { 返回 行_木 }
 如果 (行 == 行_水) { 返回 行_火 }
 返回 -1
}

函数 气韵五行_被生(行) {
    如果 (行 == 行_木) { 返回 行_水
}
 如果 (行 == 行_火) { 返回 行_木 }
 如果 (行 == 行_土) { 返回 行_火 }
 如果 (行 == 行_金) { 返回 行_土 }
 如果 (行 == 行_水) { 返回 行_金 }
 返回 -1
}

函数 气韵五行_被克(行) {
    如果 (行 == 行_木) { 返回 行_金
}
 如果 (行 == 行_火) { 返回 行_水 }
 如果 (行 == 行_土) { 返回 行_木 }
 如果 (行 == 行_金) { 返回 行_火 }
 如果 (行 == 行_水) { 返回 行_土 }
 返回 -1
}

函数 五行名(行) {
    如果 (行 == 行_木) { 返回 "木"
}
 如果 (行 == 行_火) { 返回 "火" }
 如果 (行 == 行_土) { 返回 "土" }
 如果 (行 == 行_金) { 返回 "金" }
 如果 (行 == 行_水) { 返回 "水" }
 返回 "未知"
}

// 关系强度矩阵
// [源行][目标行] → 传输系数(百分比)

函数 五行_传输系数(源行, 目标行) {
    如果 (源行 == 目标行) { 返回 100
}
 如果 (相生(源行) == 目标行) { 返回 150 }
 如果 (相克(源行) == 目标行) { 返回 50 }
 如果 (被生(源行) == 目标行) { 返回 120 }
 如果 (被克(源行) == 目标行) { 返回 70 }
 返回 80
}

// 穴位(节点)

函数 五行穴_创建(id, 名称, 势, 行) { 返回 [id, 名称, 势, [], [], [], 空, 穴_休眠, 行,]
}

函数 五行穴_行(穴) { 返回 穴[8] }
函数 五行穴_势(穴) { 返回 穴[2] }
函数 五行穴_状态(穴) { 返回 穴[7] }
函数 五行穴_输入计(穴) { 返回 穴[9] }
函数 五行穴_输出计(穴) { 返回 穴[10] }

函数 五行穴_激活(穴) { 穴[7] = 穴_活跃 }
函数 五行穴_休眠(穴) { 穴[7] = 穴_休眠 }

函数 五行穴_增势(穴, 量) {
 穴[2] = 穴[2] + 量
 如果 (穴[2] > 1000) { 穴[7] = 穴_过载 }
 穴[9] = 穴[9] + 1
}

函数 五行穴_减势(穴, 量) {
 穴[2] = 穴[2] - 量
 如果 (穴[2] < 0) { 穴[2] = 0 穴[7] = 穴_枯竭 }
 穴[10] = 穴[10] + 1
}

// 经脉(边)

函数 五行经_创建(id, 源, 目标, 容量, 关系) { 返回 [id, 源, 目标, 容量, 0, 关系,]
}

函数 五行经_关系(经) { 返回 经[5] }
函数 五行经_流量(经) { 返回 经[6] }
函数 五行经_传输数(经) { 返回 经[7] }

// 气韵网(图)

函数 五行气韵网_创建() { 返回 [[], [], 空, 0, [0, 0,]]
}

函数 五行气韵网_添加穴(网, 名称, 势, 行) { 定义 id = 计数(网[0])
 追加(网[0], 五行穴_创建(id, 名称, 势, 行))
 网[5][行] = 网[5][行] + 1
 返回 id
}

函数 五行气韵网_连经(网, 源id, 目标id, 容量) { 定义 源行 = 五行穴_行(网[0][源id])
 定义 目标行 = 五行穴_行(网[0][目标id])
 定义 可变 关系 = 0
 如果 (相生(源行) == 目标行) { 关系 = 1 }
 如果 (相克(源行) == 目标行) { 关系 = 2 }
 如果 (被生(源行) == 目标行) { 关系 = 3 }
 如果 (被克(源行) == 目标行) { 关系 = 4 }
 定义 id = 计数(网[1])
 追加(网[1], 五行经_创建(id, 源id, 目标id, 容量, 关系))
 返回 id
}

// 气势传输

函数 五行气韵网_传输(网, 经id, 量) { 定义 经 = 网[1][经id]
 定义 关系 = 五行经_关系(经)
 定义 源 = 网[0][经[1]]
 定义 目标 = 网[0][经[2]]
 定义 系数 = 五行_传输系数(五行穴_行(源), 五行穴_行(目标))
 定义 可变 有效量 = 量 * 系数 / 100
 如果 (有效量 > 经[3]) { 有效量 = 经[3] }
 五行穴_减势(源, 量)
 五行穴_增势(目标, 有效量)
 经[6] = 经[6] + 有效量
 经[7] = 经[7] + 1
 _五行_传输次数 = _五行_传输次数 + 1
 _五行_总能量 = _五行_总能量 + 有效量
 追加(_五行_历史, [经id, 量, 有效量, 关系])
 如果 (计数(_五行_历史) > 2000) { _五行_历史 = [] }
 返回 有效量
}

// 批量传输

函数 五行气韵网_全网传输(网) {
    定义 可变 总量 = 0
 定义 可变 i = 0
 当 (i < 计数(网[1])) { 定义 经 = 网[1][i]
 定义 源 = 网[0][经[1]]
 定义 可用 = 五行穴_势(源) / 10
 如果 (可用 > 0) {
 总量 = 总量 + 五行气韵网_传输(网, i, 可用)
 }
 i = i + 1
 }
 返回 总量
}

// 五行平衡计算

函数 五行气韵网_平衡(网) { 定义 可变 行计 = [0, 0,]
 定义 可变 i = 0
 当 (i < 计数(网[0])) { 定义 行 = 五行穴_行(网[0][i])
 如果 (行 >= 0 且 行 < 5) { 行计[行] = 行计[行] + 1 }
 i = i + 1
 }
 定义 可变 最大 = 行计[0]
 定义 可变 最小 = 行计[0]
 i = 1
 当 (i < 5) { 如果 (行计[i] > 最大) { 最大 = 行计[i] }
 如果 (行计[i] < 最小) { 最小 = 行计[i] }
 i = i + 1
 }
 返回 最大 - 最小
}

函数 五行气韵网_行势分布(网) { 定义 可变 势 = [0, 0,]
 定义 可变 i = 0
 当 (i < 计数(网[0])) { 定义 行 = 五行穴_行(网[0][i])
 如果 (行 >= 0 且 行 < 5) {
 势[行] = 势[行] + 五行穴_势(网[0][i])
 }
 i = i + 1
 }
 返回 势
}

函数 五行气韵网_总势(网) { 定义 可变 总 = 0
 定义 可变 i = 0
 当 (i < 计数(网[0])) {
 总 = 总 + 五行穴_势(网[0][i])
 i = i + 1
 }
 返回 总
}

// 能量守恒检查

函数 五行气韵网_能量守恒(网, 初始总势) { 定义 当前 = 五行气韵网_总势(网)
 定义 可变 差值 = 当前 - 初始总势
 如果 (差值 < 0) { 差值 = -差值 }
 返回 差值 < 初始总势 / 100
}

// 瓶颈检测

函数 五行气韵网_瓶颈(网) { 定义 可变 瓶颈列表 = []
 定义 可变 i = 0
 当 (i < 计数(网[0])) { 定义 穴 = 网[0][i]
 如果 (五行穴_状态(穴) == 穴_过载) {
 追加(瓶颈列表, [i, 穴[1], "过载"])
 }
 如果 (五行穴_状态(穴) == 穴_枯竭) {
 追加(瓶颈列表, [i, 穴[1], "枯竭"])
 }
 i = i + 1
 }
 返回 瓶颈列表
}

函数 五行气韵网_经脉瓶颈(网) { 定义 可变 瓶颈 = []
 定义 可变 i = 0
 当 (i < 计数(网[1])) { 定义 经 = 网[1][i]
 如果 (经[6] >= 经[3] * 90 / 100) {
 追加(瓶颈, [i, "经脉接近满载"])
 }
 i = i + 1
 }
 返回 瓶颈
}

// 穴位查询

函数 五行气韵网_按行筛选(网, 目标行) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(网[0])) { 如果 (五行穴_行(网[0][i]) == 目标行) {
 追加(结果, 网[0][i])
 }
 i = i + 1
 }
 返回 结果
}

函数 五行气韵网_按状态筛选(网, 状态) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(网[0])) { 如果 (五行穴_状态(网[0][i]) == 状态) {
 追加(结果, 网[0][i])
 }
 i = i + 1
 }
 返回 结果
}

函数 五行气韵网_最强穴(网) {
    如果 (计数(网[0]) == 0) { 返回 空
}
 定义 可变 最强 = 网[0][0]
 定义 可变 i = 1
 当 (i < 计数(网[0])) { 如果 (五行穴_势(网[0][i]) > 五行穴_势(最强)) { 最强 = 网[0][i] }
 i = i + 1
 }
 返回 最强
}

函数 五行气韵网_最弱穴(网) {
    如果 (计数(网[0]) == 0) { 返回 空
}
 定义 可变 最弱 = 网[0][0]
 定义 可变 i = 1
 当 (i < 计数(网[0])) { 如果 (五行穴_势(网[0][i]) < 五行穴_势(最弱)) { 最弱 = 网[0][i] }
 i = i + 1
 }
 返回 最弱
}

// 编译器气韵网

函数 编译器_气韵网() { 定义 网 = 五行气韵网_创建()
 定义 词法 = 五行气韵网_添加穴(网, "词法分析", 10, 行_木)
 定义 语法 = 五行气韵网_添加穴(网, "语法分析", 8, 行_火)
 定义 语义 = 五行气韵网_添加穴(网, "语义分析", 6, 行_土)
 定义 优化 = 五行气韵网_添加穴(网, "优化", 4, 行_金)
 定义 生成 = 五行气韵网_添加穴(网, "代码生成", 2, 行_水)
 五行气韵网_连经(网, 词法, 语法, 100)
 五行气韵网_连经(网, 语法, 语义, 100)
 五行气韵网_连经(网, 语义, 优化, 100)
 五行气韵网_连经(网, 优化, 生成, 100)
 返回 网
}

函数 五行_调和建议(网) { 定义 势分布 = 五行气韵网_行势分布(网)
 定义 可变 总 = 0
 定义 可变 最大行 = 0
 定义 可变 最小行 = 0
 定义 可变 i = 0
 当 (i < 5) {
 总 = 总 + 势分布[i]
 如果 (势分布[i] > 势分布[最大行]) { 最大行 = i }
 如果 (势分布[i] < 势分布[最小行]) { 最小行 = i }
 i = i + 1
 }
 定义 均值 = 总 / 5
 定义 偏差 = 势分布[最大行] - 势分布[最小行]
 如果 (偏差 < 均值 / 5) { 返回 "五行平衡良好" }
 返回 字符串拼接(五行名(最大行), 字符串拼接("行过盛→建议增强", 五行名(最小行)))
}

函数 五行_健康诊断(网) { 定义 可变 问题 = []
 定义 瓶颈 = 五行气韵网_瓶颈(网)
 如果 (计数(瓶颈) > 0) { 追加(问题, 字符串拼接("穴位瓶颈: ", 转字符串(计数(瓶颈)))) }
 定义 经瓶颈 = 五行气韵网_经脉瓶颈(网)
 如果 (计数(经瓶颈) > 0) { 追加(问题, 字符串拼接("经脉瓶颈: ", 转字符串(计数(经瓶颈)))) }
 定义 平衡度 = 五行气韵网_平衡(网)
 如果 (平衡度 > 5) { 追加(问题, "五行严重失衡") }
 否则 如果 (平衡度 > 2) { 追加(问题, "五行轻度失衡") }
 如果 (计数(问题) == 0) { 追加(问题, "气韵健康") }
 返回 问题
}

函数 五行_流量预测(_网) {
    定义 可变 近期数 = 0
    如果 (计数(_五行_历史) < 10) { 返回 "数据不足"
}
 定义 可变 近期总量 = 0
 定义 可变 i = 计数(_五行_历史) - 1
 当 (i >= 0 且 近期数 < 10) {
 近期总量 = 近期总量 + _五行_历史[i][2]
 近期数 = 近期数 + 1
 i = i - 1
 }
 定义 均量 = 近期总量 / 近期数
 如果 (均量 > 100) { 返回 "高流量(可能需要扩容)" }
 如果 (均量 > 30) { 返回 "正常流量" }
 返回 "低流量(可能存在阻塞)"
}

// 五行循环模拟

函数 五行气韵网_模拟步(网, 步数) { 定义 可变 记录 = []
 定义 可变 s = 0
 当 (s < 步数) { 定义 传输量 = 五行气韵网_全网传输(网)
 定义 总势 = 五行气韵网_总势(网)
 定义 平衡 = 五行气韵网_平衡(网)
 追加(记录, [s, 传输量, 总势, 平衡])
 s = s + 1
 }
 返回 记录
}

// 气势衰减模型

函数 五行穴_自然衰减(穴, 衰减率) { 定义 损失 = 穴[2] * 衰减率 / 100
 穴[2] = 穴[2] - 损失
 如果 (穴[2] < 0) { 穴[2] = 0 }
 返回 损失
}

函数 五行气韵网_全网衰减(网, 衰减率) {
    定义 可变 总损失 = 0
 定义 可变 i = 0
 当 (i < 计数(网[0])) {
 总损失 = 总损失 + 五行穴_自然衰减(网[0][i], 衰减率)
 i = i + 1
 }
 返回 总损失
}

// 穴位排名

函数 五行气韵网_穴位排名(网) {
    定义 可变 排名 = []
 定义 可变 i = 0
 当 (i < 计数(网[0])) {
 追加(排名, [五行穴_势(网[0][i]), 网[0][i][1], i])
 i = i + 1
 }
 定义 可变 k = 0
 当 (k < 计数(排名) - 1) { 定义 可变 j = k + 1
 当 (j < 计数(排名)) { 如果 (排名[j][0] > 排名[k][0]) { 定义 临 = 排名[k]
 排名[k] = 排名[j]
 排名[j] = 临
 }
 j = j + 1
 }
 k = k + 1
 }
 返回 排名
}

// 经脉利用率

函数 五行气韵网_经脉利用率(网) { 定义 可变 利用率列表 = []
 定义 可变 i = 0
 当 (i < 计数(网[1])) { 定义 经 = 网[1][i]
 定义 可变 率 = 0
 如果 (经[3] > 0) { 率 = 经[6] * 100 / 经[3] }
 追加(利用率列表, [i, 率])
 i = i + 1
 }
 返回 利用率列表
}

// 五行共振检测

函数 五行_共振检测(网) { 定义 势 = 五行气韵网_行势分布(网)
 定义 可变 共振对 = []
 定义 可变 i = 0
 当 (i < 5) { 定义 生目标 = 相生(i)
 如果 (势[i] > 0 且 势[生目标] > 0) { 定义 比值 = 势[i] * 100 / 势[生目标]
 如果 (比值 > 80 且 比值 < 120) {
 追加(共振对, [五行名(i), 五行名(生目标), "相生共振"])
 }
 }
 i = i + 1
 }
 返回 共振对
}

函数 五行_优化路径(网) { 定义 最弱 = 五行气韵网_最弱穴(网)
 如果 (最弱 == 空) { 返回 "无穴位" }
 定义 弱行 = 五行穴_行(最弱)
 定义 生源行 = 被生(弱行)
 返回 字符串拼接("建议从", 字符串拼接(五行名(生源行), 字符串拼接("行补给", 五行名(弱行))))
}

函数 五行_网络复杂度(网) { 定义 穴数 = 计数(网[0])
 定义 经数 = 计数(网[1])
 定义 可变 密度 = 0
 如果 (穴数 > 1) { 密度 = 经数 * 100 / (穴数 * (穴数 - 1)) }
 如果 (密度 > 70) { 返回 [密度, "高密度网络"] }
 如果 (密度 > 30) { 返回 [密度, "中等密度"] }
 返回 [密度, "稀疏网络"]
}

// 龙壳 (Dragon终端) — NovaOS原生终端 — 深度吸收bash架构
// 核心设计(来自bash/zsh):
//   1. 读取-解析-执行循环 (REPL): readline → parse → execute
//   2. 管道: cmd1 | cmd2 — pipe()+fork()+dup2()连接
//   3. 重定向: >, >>, <, 2>, 2>&1 — 在fork后exec前设置
//   4. 后台执行: cmd & — 不等待子进程
//   5. 作业控制: fg/bg/jobs — 前台/后台进程组管理
//   6. 环境变量展开: $VAR, ${VAR}, $?, $!, $$
//   7. 引号处理: 'single'不展开, "double"展开变量
//   8. 信号处理: SIGINT→中断前台进程, SIGCHLD→回收后台zombie

定义 可变 龙壳_运行中 = 真
定义 可变 龙壳_交互模式 = 真
定义 可变 龙壳_上次退出码 = 0
定义 可变 龙壳_上次后台PID = 0
定义 可变 龙壳_PID = 0
定义 可变 龙壳_嵌套层数 = 0      // 子终端嵌套深度

定义 龙壳版本 = "1.0.0-M1"
定义 龙壳名称 = "龙壳"

// 龙壳入口

函数 龙壳_入口(argc, argv) {
    龙壳_PID = sys_getpid(0, 0, 0, 0, 0, 0)

    // 初始化子系统
    环境_初始化()
    历史_初始化()
    任务_初始化()

    // 设置信号处理
    龙壳_设置信号()

    // 检查启动模式
    如果 (argc > 1) {
        // 非交互模式: 执行脚本文件
        龙壳_交互模式 = 假
        返回 龙壳_执行脚本(argv[1])
    }
    如果 (argc > 0 && argv[0] == "-c") {
        // -c模式: 执行单条命令
        龙壳_交互模式 = 假
        返回 龙壳_执行单行(argv[1])
    }

    // 交互模式
    龙壳_交互模式 = 真
    龙壳_欢迎()
    龙壳_主循环()
    返回 龙壳_上次退出码
}

函数 龙壳_欢迎() {
    打印行("╔══════════════════════════════════════╗")
    打印行("║  龙壳 (Dragon终端) v" + 龙壳版本 + "     ║")
    打印行("║  NovaOS M1 原生终端                 ║")
    打印行("║  输入 help 查看内建命令               ║")
    打印行("╚══════════════════════════════════════╝")
}

// 主循环: 读取-解析-执行

函数 龙壳_主循环() {
    当 (龙壳_运行中) {
        // 1. 回收后台zombie进程 
        任务_回收后台()

        // 2. 生成提示符
        定义 提示符 = 龙壳_生成提示符()
        标准输出(提示符)

        // 3. 读取一行输入
        定义 输入 = 读取行()
        如果 (输入 == 空) {
            // EOF (Ctrl+D)
            如果 (龙壳_交互模式) {
                打印行("exit")
                龙壳_运行中 = 假
            }
            继续
        }

        // 4. 跳过空行和注释
        定义 去空白 = 字符串去首尾空白(输入)
        如果 (去空白 == "" || 字符串取字符(去空白, 0) == "#") { 继续 }

        // 5. 添加到历史
        历史_添加(去空白)

        // 6. 执行命令行
        龙壳_上次退出码 = 龙壳_执行行(去空白)
    }
}

// 提示符生成 

函数 龙壳_生成提示符() {
    定义 用户 = 环境_获取("USER")
    定义 主机 = "novaos"
    定义 cwd = 环境_获取("PWD")
    定义 home = 环境_获取("HOME")

    // 将HOME替换为~
    如果 (字符串开头(cwd, home)) {
        cwd = "~" + 字符串子串(cwd, 字符串长度(home), 字符串长度(cwd))
    }

    // root用"#", 普通用户用"$"
    定义 尾符 = 如果选字符(用户 == "root", "# ", "$ ")

    // 格式: user@host:cwd$
    返回 用户 + "@" + 主机 + ":" + cwd + 尾符
}

// 执行一行命令 (处理分号分隔、管道、重定向、后台)

函数 龙壳_执行行(行) {
    // 1. 分号分隔: cmd1; cmd2; cmd3
    定义 语句列表 = 分割_分号(行)
    定义 可变 最后退出码 = 0
    定义 可变 i = 0

    当 (i < 计数(语句列表)) {
        定义 语句 = 字符串去首尾空白(语句列表[i])
        如果 (语句 != "") {
            最后退出码 = 龙壳_执行语句(语句)
        }
        i = i + 1
    }
    返回 最后退出码
}

函数 龙壳_执行语句(语句) {
    // 2. 检查 && 和 || 链
    如果 (字符串包含(语句, " && ")) {
        定义 部分 = 字符串分割(语句, " && ")
        定义 可变 j = 0
        当 (j < 计数(部分)) {
            定义 结果 = 龙壳_执行语句(字符串去首尾空白(部分[j]))
            如果 (结果 != 0) { 返回 结果 }   // &&: 前一个失败则停止
            j = j + 1
        }
        返回 0
    }
    如果 (字符串包含(语句, " || ")) {
        定义 部分 = 字符串分割(语句, " || ")
        定义 可变 j = 0
        当 (j < 计数(部分)) {
            定义 结果 = 龙壳_执行语句(字符串去首尾空白(部分[j]))
            如果 (结果 == 0) { 返回 0 }       // ||: 前一个成功则停止
            j = j + 1
        }
        返回 1
    }

    // 3. 检查后台执行 (&结尾)
    定义 可变 后台 = 假
    如果 (字符串结尾(语句, "&") && !字符串结尾(语句, "&&")) {
        后台 = 真
        语句 = 字符串去首尾空白(字符串子串(语句, 0, 字符串长度(语句) - 1))
    }

    // 4. 检查管道
    如果 (字符串包含(语句, " | ")) {
        返回 龙壳_执行管道(语句, 后台)
    }

    // 5. 单命令执行
    返回 龙壳_执行单命令(语句, 后台)
}

// 单命令执行 (处理重定向、内建、外部)

函数 龙壳_执行单命令(命令行, 后台) {
    // 1. 变量展开
    定义 展开后 = 龙壳_变量展开(命令行)

    // 2. 解析为令牌列表
    定义 解析结果 = 解析命令行_完整(展开后)
    如果 (解析结果 == 空 || 计数(解析结果.参数) == 0) { 返回 0 }

    定义 参数 = 解析结果.参数
    定义 重定向 = 解析结果.重定向
    定义 名称 = 参数[0]

    // 3. 特殊内建: exit/cd/export等必须在当前终端进程中执行
    如果 (名称 == "exit" || 名称 == "quit") {
        如果 (计数(参数) > 1) { 龙壳_上次退出码 = 字符串转整数(参数[1]) }
        龙壳_运行中 = 假
        返回 龙壳_上次退出码
    }
    如果 (是内建命令(名称)) {
        返回 执行内建_完整(参数, 重定向)
    }

    // 4. 外部命令: fork + 设置重定向 + exec
    定义 pid = sys_fork(0, 0, 0, 0, 0, 0)
    如果 (pid < 0) {
        打印错误("龙壳: fork失败")
        返回 1
    }

    如果 (pid == 0) {
}
}

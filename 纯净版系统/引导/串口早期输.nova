// NovaOS 串口早期输出
// 最早的输出通道, 在所有子系统初始化之前就能用

函数 早期输出_初始化() {
    定义 结果 = 串口_初始化(COM1)
    如果 (是错误(结果)) {
        // COM1失败, 尝试COM2
        串口_初始化(COM2)
    }
}

函数 早期打印(消息) {
    串口_打印行(消息)
}

函数 早期打印数值(标签, 数值) {
    串口_发送字符串(标签)
    串口_发送字符串(": ")
    串口_打印行(整数转字符串(数值))
}

函数 早期打印十六进制(标签, 数值) {
    串口_发送字符串(标签)
    串口_发送字符串(": ")
    串口_打印行(整数转十六进制(数值))
}

函数 早期打印OK(模块名) {
    串口_发送字符串("[  OK  ] ")
    串口_打印行(模块名)
}

函数 早期打印失败(模块名) {
    串口_发送字符串("[失败] ")
    串口_打印行(模块名)
}

函数 早期打印警告(消息) {
    串口_发送字符串("[警告] ")
    串口_打印行(消息)
}

// 格式化输出 (早期阶段printf替代)

函数 早期格式化(格式, 参数列表) {
    // 轻量printf: %d=整数, %x=十六进制, %s=字符串, %%=百分号
    定义 可变 结果 = ""
    定义 可变 i = 0
    定义 可变 参数索引 = 0
    定义 格式长度 = 字符串长度(格式)

    当 (i < 格式长度) {
        定义 ch = 字符串取字符(格式, i)
        如果 (ch == 37) {  // '%'
            i = i + 1
            如果 (i >= 格式长度) { 中断 }
            定义 fmt = 字符串取字符(格式, i)
            如果 (fmt == 100 && 参数索引 < 计数(参数列表)) {  // 'd'
                结果 = 结果 + 整数转字符串(参数列表[参数索引])
                参数索引 = 参数索引 + 1
            } 否则 如果 (fmt == 120 && 参数索引 < 计数(参数列表)) {  // 'x'
                结果 = 结果 + 整数转十六进制(参数列表[参数索引])
                参数索引 = 参数索引 + 1
            } 否则 如果 (fmt == 115 && 参数索引 < 计数(参数列表)) {  // 's'
                结果 = 结果 + 参数列表[参数索引]
                参数索引 = 参数索引 + 1
            } 否则 如果 (fmt == 37) {  // '%'
                结果 = 结果 + "%"
            }
        } 否则 {
            结果 = 结果 + 字符(ch)
        }
        i = i + 1
    }
    返回 结果
}

函数 早期printf(格式, 参数列表) {
    串口_发送字符串(早期格式化(格式, 参数列表))
}

// 进度条 (内核启动进度显示)

定义 可变 启动步骤_总数 = 20
定义 可变 启动步骤_当前 = 0
定义 可变 启动开始时间 = 0

函数 早期_启动开始() {
    启动步骤_当前 = 0
    启动开始时间 = 读取毫秒()
    串口_打印行("NovaOS 启动中...")
}

函数 早期_启动步骤(描述) {
    启动步骤_当前 = 启动步骤_当前 + 1
    定义 耗时 = 读取毫秒() - 启动开始时间
    串口_发送字符串("[")
    串口_发送字符串(整数转字符串(耗时))
    串口_发送字符串("ms] (")
    串口_发送字符串(整数转字符串(启动步骤_当前))
    串口_发送字符串("/")
    串口_发送字符串(整数转字符串(启动步骤_总数))
    串口_发送字符串(") ")
    串口_打印行(描述)
}

函数 早期_启动完成() {
    定义 总耗时 = 读取毫秒() - 启动开始时间
    串口_发送字符串("NovaOS 启动完成! 总耗时: ")
    串口_发送字符串(整数转字符串(总耗时))
    串口_打印行("ms")
}

// Panic输出 (内核恐慌时的最后输出)

函数 早期_panic(消息) {
    串口_打印行("")
    串口_打印行("!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!")
    串口_发送字符串("KERNEL PANIC: ")
    串口_打印行(消息)
    串口_打印行("!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!")
    串口_打印行("")
    // 转储关键寄存器
    早期打印十六进制("  RSP", 读取RSP())
    早期打印十六进制("  RIP", 0)  // 需要从栈帧获取
    早期打印十六进制("  CR3", 读取CR3())
    串口_打印行("系统已停机。")
}

// 内存转储 (调试用)

函数 早期_hex_dump(地址, 长度) {
    定义 可变 i = 0
    当 (i < 长度) {
        // 每16字节一行
        如果 (i % 16 == 0) {
            如果 (i > 0) { 串口_打印行("") }
            串口_发送字符串(整数转十六进制(地址 + i))
            串口_发送字符串(": ")
        }
        定义 字节 = 内存读8(地址 + i)
        定义 高 = (字节 >> 4) & 0xF
        定义 低 = 字节 & 0xF
        串口_发送字符串(hex_nibble(高))
        串口_发送字符串(hex_nibble(低))
        串口_发送字符串(" ")
        i = i + 1
    }
    串口_打印行("")
}

函数 hex_nibble(值) {
    如果 (值 < 10) { 返回 整数转字符串(值) }
    如果 (值 == 10) { 返回 "a" }
    如果 (值 == 11) { 返回 "b" }
    如果 (值 == 12) { 返回 "c" }
    如果 (值 == 13) { 返回 "d" }
    如果 (值 == 14) { 返回 "e" }
    返回 "f"
}

// 显基文本模式输出 (备用输出通道)

定义 显基_基地址 = 0xB8000
定义 显基_宽度 = 80
定义 显基_高度 = 25
定义 可变 显基_光标_行 = 0
定义 可变 显基_光标_列 = 0
定义 显基_白底黑字 = 0x0F
定义 显基_红底白字 = 0x4F

函数 早期_显基_清屏() {
    定义 可变 i = 0
    当 (i < 显基_宽度 * 显基_高度) {
        内存写16(显基_基地址 + i * 2, 0x0F20)  // 空格+白色
        i = i + 1
    }
    显基_光标_行 = 0
    显基_光标_列 = 0
}

函数 早期_显基_写字符(字符, 颜色) {
    如果 (字符 == 10) {  // '\n'
        显基_光标_列 = 0
        显基_光标_行 = 显基_光标_行 + 1
        如果 (显基_光标_行 >= 显基_高度) { 早期_显基_滚屏() }
        返回
    }
    定义 偏移 = (显基_光标_行 * 显基_宽度 + 显基_光标_列) * 2
    内存写8(显基_基地址 + 偏移, 字符)
    内存写8(显基_基地址 + 偏移 + 1, 颜色)
    显基_光标_列 = 显基_光标_列 + 1
    如果 (显基_光标_列 >= 显基_宽度) {
        显基_光标_列 = 0
        显基_光标_行 = 显基_光标_行 + 1
        如果 (显基_光标_行 >= 显基_高度) { 早期_显基_滚屏() }
    }
}

函数 早期_显基_写字符串(字符串, 颜色) {
    定义 可变 i = 0
    当 (i < 字符串长度(字符串)) {
        早期_显基_写字符(字符串取字符(字符串, i), 颜色)
        i = i + 1
    }
}

函数 早期_显基_滚屏() {
    // 上移一行
    内存拷贝(显基_基地址, 显基_基地址 + 显基_宽度 * 2, 显基_宽度 * (显基_高度 - 1) * 2)
    // 清空最后一行
    定义 可变 i = 0
    当 (i < 显基_宽度) {
        内存写16(显基_基地址 + (显基_高度 - 1) * 显基_宽度 * 2 + i * 2, 0x0F20)
        i = i + 1
    }
    显基_光标_行 = 显基_高度 - 1
}

// 启动进度百分比 + 显基光标位置

函数 启动_进度百分比() {
    如果 (启动步骤_总数 == 0) { 返回 0 }
    返回 启动步骤_当前 * 100 / 启动步骤_总数
}

函数 显基_光标位置() {
    返回 [显基_光标_行, 显基_光标_列]
}


函数 串口早期_完整统计() {
    返回 [串口_输出字节数]
}

定义 可变 AI_串口早期输_操作热度 = 0

函数 AI_串口早期输_最优算法(数据量, 已排序) {
    AI_串口早期输_操作热度 = AI_串口早期输_操作热度 + 1
    如果 (数据量 < 16) { 返回 "插入排序" }
    如果 (已排序) { 返回 "二分查找" }
    如果 (数据量 < 10000) { 返回 "快速排序" }
    返回 "归并排序"
}

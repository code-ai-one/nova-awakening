// §4 人机验证突破

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./鼠标轨迹仿生.nova")
导入("./数学工具.nova")
导入("../外联/序列工具.nova")
导入("./整数转字符串.nova")

定义 验证类型_滑块 = 1
定义 验证类型_图片选择 = 2
定义 验证类型_reCAPTCHA = 3
定义 验证类型_hCaptcha = 4
定义 验证类型_文字验证码 = 5

定义 可变 验证_尝试次数 = 0
定义 可变 验证_成功次数 = 0

函数 验证_滑块(起x, 起y, 目标x, 目标y) {
    验证_尝试次数 = 验证_尝试次数 + 1
    // 仿真滑块拖动: 加速→匀速→减速→微调
    定义 轨迹 = 仿生_鼠标移动(起x, 起y, 目标x, 目标y)

    // 添加人类特征: 略微超过目标后回调
    定义 超调 = 3 + 仿生_伪随机() % 8
    定义 回调轨迹 = 仿生_鼠标移动(目标x + 超调, 目标y, 目标x, 目标y)

    // 按下
    UI_发送鼠标按钮(起x, 起y, 1, 真)
    // 沿轨迹移动
    定义 可变 i = 0
    当 (i < 计数(轨迹)) {
        UI_发送鼠标移动(轨迹[i].x, 轨迹[i].y)
        i = i + 1
    }
    // 超调回调
    i = 0
    当 (i < 计数(回调轨迹)) {
        UI_发送鼠标移动(回调轨迹[i].x, 回调轨迹[i].y)
        i = i + 1
    }
    // 释放
    UI_发送鼠标按钮(目标x, 目标y, 1, 假)

    验证_成功次数 = 验证_成功次数 + 1
    返回 真
}

函数 验证_reCAPTCHA_复选框(x, y) {
    验证_尝试次数 = 验证_尝试次数 + 1
    // reCAPTCHA v2 复选框: 关键是鼠标轨迹自然
    // 先在页面其他地方随机移动(模拟正常浏览)
    定义 预移动数 = 2 + 仿生_伪随机() % 3
    定义 可变 i = 0
    当 (i < 预移动数) {
        定义 随机x = 100 + 仿生_伪随机() % 1600
        定义 随机y = 100 + 仿生_伪随机() % 800
        仿生_鼠标移动(随机x, 随机y, 随机x + 50, 随机y + 30)
        i = i + 1
    }
    // 然后自然地移向复选框并点击
    仿生_鼠标点击_真人(x, y)
    验证_成功次数 = 验证_成功次数 + 1
    返回 真
}

函数 验证_图片选择(图片网格, 目标描述) {
    验证_尝试次数 = 验证_尝试次数 + 1
    // 调用AI视觉识别
    定义 识别结果 = 智能_接口_推理("图片验证: " + 目标描述)
    // 按AI指示点击相应图片
    如果 (识别结果 != 空) {
        验证_成功次数 = 验证_成功次数 + 1
        返回 真
    }
    返回 假
}

函数 验证_文字识别(图片数据) {
    // OCR识别验证码文字
    验证_尝试次数 = 验证_尝试次数 + 1
    定义 结果 = 智能_接口_推理("OCR识别验证码")
    如果 (结果 != 空) {
        验证_成功次数 = 验证_成功次数 + 1
    }
    返回 结果
}

// §5 行为节奏控制

结构 行为节奏 {
    活跃度,    // u32 0~1000 (模拟疲劳)
    操作间隔,    // u32 毫秒
    休息概率,    // u32 ×1000
    连续操作数,
}

定义 可变 全局节奏 = 空

函数 节奏_初始化() {
    定义 r = 行为节奏 {}
    r.活跃度 = 1000
    r.操作间隔 = 500
    r.休息概率 = 10
    r.连续操作数 = 0
    全局节奏 = r
}

函数 节奏_下一个延迟() {
    如果 (全局节奏 == 空) { 节奏_初始化() }
    全局节奏.连续操作数 = 全局节奏.连续操作数 + 1

    // 疲劳模拟: 操作越多越慢
    如果 (全局节奏.连续操作数 > 50) {
        全局节奏.活跃度 = 全局节奏.活跃度 - 5
        如果 (全局节奏.活跃度 < 300) { 全局节奏.活跃度 = 300 }
    }

    // 随机休息(模拟喝水/看别处)
    如果 (仿生_伪随机() % 1000 < 全局节奏.休息概率) {
        返回 3000 + 仿生_伪随机() % 7000  // 3-10秒休息
    }

    // 正常操作间隔(受活跃度影响)
    定义 基础 = 全局节奏.操作间隔 * 1000 / 全局节奏.活跃度
    返回 仿生_高斯随机(基础, 基础 / 4)
}

// 统一使用 核心/公共/数学工具.nova::数学_开方()
函数 整数开方_仿生(n) { 返回 数学_开方(n) }


函数 验证_hCaptcha(框架x, 框架y) {
    验证_尝试次数 = 验证_尝试次数 + 1
    全局统计.hCaptcha尝试数 = 全局统计.hCaptcha尝试数 + 1
    // 1. 先在页面随机浏览模拟正常行为
    定义 可变 i = 0
    当 (i < 3) {
        定义 随机x = 200 + 仿生_伪随机() % 1200
        定义 随机y = 150 + 仿生_伪随机() % 600
        仿生_鼠标移动(随机x, 随机y, 随机x + 80, 随机y + 40)
        i = i + 1
    }
    // 2. 移向hCaptcha复选框
    仿生_鼠标点击_真人(框架x, 框架y)
    // 3. 等待挑战加载
    // 4. 如果出现图片挑战，使用AI视觉识别
    定义 挑战结果 = 智能_接口_推理("hCaptcha图片挑战识别")
    如果 (挑战结果 != 空) {
        验证_成功次数 = 验证_成功次数 + 1
        全局统计.hCaptcha成功数 = 全局统计.hCaptcha成功数 + 1
        返回 真
    }
    返回 假
}


函数 验证_Turnstile(框架x, 框架y) {
    验证_尝试次数 = 验证_尝试次数 + 1
    全局统计.Turnstile尝试数 = 全局统计.Turnstile尝试数 + 1
    // Turnstile主要检测浏览器环境和鼠标行为
    // 关键：保证自然的鼠标轨迹和合理的页面停留时间
    定义 可变 页面停留 = 3000 + 仿生_伪随机() % 5000
    // 模拟正常浏览行为
    定义 可变 k = 0
    当 (k < 5) {
        定义 rx = 100 + 仿生_伪随机() % 1400
        定义 ry = 100 + 仿生_伪随机() % 700
        仿生_鼠标移动(rx, ry, rx + 仿生_高斯随机(50, 20), ry + 仿生_高斯随机(30, 10))
        k = k + 1
    }
    // 点击Turnstile复选框
    仿生_鼠标点击_真人(框架x, 框架y)
    验证_成功次数 = 验证_成功次数 + 1
    全局统计.Turnstile成功数 = 全局统计.Turnstile成功数 + 1
    返回 真
}


函数 验证_自动重试(类型, 参数列表, 最大重试) {
    如果 (最大重试 <= 0) { 最大重试 = 3 }
    定义 可变 重试次 = 0
    当 (重试次 < 最大重试) {
        定义 可变 结果 = 假
        如果 (类型 == 验证类型_滑块 && 计数(参数列表) >= 4) {
            结果 = 验证_滑块(参数列表[0], 参数列表[1], 参数列表[2], 参数列表[3])
        } 否则 如果 (类型 == 验证类型_reCAPTCHA && 计数(参数列表) >= 2) {
            结果 = 验证_reCAPTCHA_复选框(参数列表[0], 参数列表[1])
        } 否则 如果 (类型 == 验证类型_hCaptcha && 计数(参数列表) >= 2) {
            结果 = 验证_hCaptcha(参数列表[0], 参数列表[1])
        } 否则 如果 (类型 == 验证类型_文字验证码 && 计数(参数列表) >= 1) {
            结果 = 验证_文字识别(参数列表[0])
            如果 (结果 != 空) { 结果 = 真 }
        }
        如果 (结果 == 真) {
            全局统计.重试成功数 = 全局统计.重试成功数 + 1
            返回 真
        }
        全局统计.重试次数 = 全局统计.重试次数 + 1
        重试次 = 重试次 + 1
        // 重试间隔递增
        定义 等待 = 1000 + 重试次 * 2000 + 仿生_伪随机() % 3000
    }
    全局统计.重试失败数 = 全局统计.重试失败数 + 1
    返回 假
}


函数 验证_自动检测类型(页面元素) {
    // 通过页面元素特征判断验证码类型
    全局统计.类型检测数 = 全局统计.类型检测数 + 1
    如果 (页面元素 == 空) { 返回 0 }
    // 检测reCAPTCHA
    定义 有reCAPTCHA = 智能_接口_推理("检测页面是否有reCAPTCHA")
    如果 (有reCAPTCHA != 空) { 返回 验证类型_reCAPTCHA }
    // 检测hCaptcha
    定义 有hCaptcha = 智能_接口_推理("检测页面是否有hCaptcha")
    如果 (有hCaptcha != 空) { 返回 验证类型_hCaptcha }
    // 检测滑块
    定义 有滑块 = 智能_接口_推理("检测页面是否有滑块验证")
    如果 (有滑块 != 空) { 返回 验证类型_滑块 }
    返回 0
}

函数 验证_类型名称(类型) {
    如果 (类型 == 验证类型_滑块) { 返回 "滑块" }
    如果 (类型 == 验证类型_图片选择) { 返回 "图片选择" }
    如果 (类型 == 验证类型_reCAPTCHA) { 返回 "reCAPTCHA" }
    如果 (类型 == 验证类型_hCaptcha) { 返回 "hCaptcha" }
    如果 (类型 == 验证类型_文字验证码) { 返回 "文字验证码" }
    返回 "未知"
}


函数 验证_注入反检测脚本() {
    // 隐藏自动化特征
    全局统计.反检测注入数 = 全局统计.反检测注入数 + 1
    // 1. 隐藏navigator.webdriver
    // 2. 伪造navigator.plugins
    // 3. 伪造navigator.languages
    // 4. 修改chrome.runtime
    返回 真
}

函数 验证_检查是否被检测() {
    // 检查页面是否显示"检测到自动化"等提示
    定义 结果 = 智能_接口_推理("检查页面是否显示机器人检测警告")
    如果 (结果 != 空) {
        全局统计.被检测次数 = 全局统计.被检测次数 + 1
        返回 真
    }
    返回 假
}


定义 AI验证窗口 = 16
定义 可变 AI验证历史 = []
定义 可变 AI验证位置 = 0

结构 验证记录 {
    类型: 整数,
    成功: 整数,
    耗时: 整数,
    重试次数: 整数,
}

函数 AI_记录验证(类型, 成功, 耗时, 重试) {
    定义 可变 记录 = 验证记录 {}
    记录.类型 = 类型
    记录.成功 = 成功
    记录.耗时 = 耗时
    记录.重试次数 = 重试
    如果 (计数(AI验证历史) < AI验证窗口) {
        追加(AI验证历史, 记录)
    } 否则 {
        设置(AI验证历史, AI验证位置, 记录)
    }
    AI验证位置 = (AI验证位置 + 1) % AI验证窗口
    全局统计.AI策略学习数 = 全局统计.AI策略学习数 + 1
}

函数 AI_推荐验证策略(类型) {
    // 分析该类型的历史成功率
    定义 可变 成功数 = 0
    定义 可变 总数 = 0
    定义 可变 总耗时 = 0
    定义 可变 i = 0
    当 (i < 计数(AI验证历史)) {
        如果 (AI验证历史[i].类型 == 类型) {
            总数 = 总数 + 1
            如果 (AI验证历史[i].成功 == 真) { 成功数 = 成功数 + 1 }
            总耗时 = 总耗时 + AI验证历史[i].耗时
        }
        i = i + 1
    }
    如果 (总数 == 0) { 返回 "无历史数据" }
    定义 成功率 = (成功数 * 100) / 总数
    如果 (成功率 > 80) { 返回 "继续当前策略" }
    如果 (成功率 > 50) { 返回 "增加预浏览时间" }
    返回 "切换AI视觉模型"
}

函数 AI_验证成功率(类型) {
    定义 可变 成功 = 0
    定义 可变 总数 = 0
    定义 可变 i = 0
    当 (i < 计数(AI验证历史)) {
        如果 (AI验证历史[i].类型 == 类型) {
            总数 = 总数 + 1
            如果 (AI验证历史[i].成功 == 真) { 成功 = 成功 + 1 }
        }
        i = i + 1
    }
    如果 (总数 == 0) { 返回 0 }
    返回 (成功 * 100) / 总数
}


结构 验证统计 {
    滑块尝试数: 整数,
    滑块成功数: 整数,
    reCAPTCHA尝试数: 整数,
    reCAPTCHA成功数: 整数,
    hCaptcha尝试数: 整数,
    hCaptcha成功数: 整数,
    Turnstile尝试数: 整数,
    Turnstile成功数: 整数,
    文字识别尝试数: 整数,
    图片选择尝试数: 整数,
    重试次数: 整数,
    重试成功数: 整数,
    重试失败数: 整数,
    类型检测数: 整数,
    反检测注入数: 整数,
    被检测次数: 整数,
    AI策略学习数: 整数,
    错误次数: 整数,
}

定义 可变 全局统计 = 验证统计 {}
定义 可变 验证模块已初始化 = 假


函数 验证模块_初始化() {
    如果 (验证模块已初始化 == 真) { 返回 0 - 17 }
    AI验证历史 = []
    AI验证位置 = 0
    验证_尝试次数 = 0
    验证_成功次数 = 0
    节奏_初始化()
    验证模块已初始化 = 真
    打印("[人机验证] 初始化完成")
    返回 0
}

函数 验证模块_销毁() {
    如果 (验证模块已初始化 == 假) { 返回 0 }
    AI验证历史 = []
    全局节奏 = 空
    验证模块已初始化 = 假
    打印("[人机验证] 已销毁")
    返回 0
}


函数 验证模块_转储() {
    打印("[人机验证] ═══ 状态转储 ═══")
    打印(字符串拼接("  尝试次数: ", 整数转字符串(验证_尝试次数)))
    打印(字符串拼接("  成功次数: ", 整数转字符串(验证_成功次数)))
    如果 (验证_尝试次数 > 0) {
        定义 成功率 = (验证_成功次数 * 100) / 验证_尝试次数
        打印(字符串拼接("  成功率%: ", 整数转字符串(成功率)))
    }
    打印(字符串拼接("  滑块成功率%: ", 整数转字符串(AI_验证成功率(验证类型_滑块))))
    打印(字符串拼接("  reCAPTCHA成功率%: ", 整数转字符串(AI_验证成功率(验证类型_reCAPTCHA))))
    返回 0
}


函数 验证模块_打印统计() {
    打印("[人机验证] ═══ 运行统计 ═══")
    打印(字符串拼接("  滑块尝试: ", 整数转字符串(全局统计.滑块尝试数)))
    打印(字符串拼接("  滑块成功: ", 整数转字符串(全局统计.滑块成功数)))
    打印(字符串拼接("  reCAPTCHA尝试: ", 整数转字符串(全局统计.reCAPTCHA尝试数)))
    打印(字符串拼接("  reCAPTCHA成功: ", 整数转字符串(全局统计.reCAPTCHA成功数)))
    打印(字符串拼接("  hCaptcha尝试: ", 整数转字符串(全局统计.hCaptcha尝试数)))
    打印(字符串拼接("  hCaptcha成功: ", 整数转字符串(全局统计.hCaptcha成功数)))
    打印(字符串拼接("  Turnstile尝试: ", 整数转字符串(全局统计.Turnstile尝试数)))
    打印(字符串拼接("  Turnstile成功: ", 整数转字符串(全局统计.Turnstile成功数)))
    打印(字符串拼接("  重试次数: ", 整数转字符串(全局统计.重试次数)))
    打印(字符串拼接("  重试成功: ", 整数转字符串(全局统计.重试成功数)))
    打印(字符串拼接("  重试失败: ", 整数转字符串(全局统计.重试失败数)))
    打印(字符串拼接("  类型检测: ", 整数转字符串(全局统计.类型检测数)))
    打印(字符串拼接("  反检测注入: ", 整数转字符串(全局统计.反检测注入数)))
    打印(字符串拼接("  被检测次数: ", 整数转字符串(全局统计.被检测次数)))
    打印(字符串拼接("  AI策略学习: ", 整数转字符串(全局统计.AI策略学习数)))
    打印(字符串拼接("  错误次数: ", 整数转字符串(全局统计.错误次数)))
    返回 0
}


函数 验证模块_注册到内核(内核上下文) {
    如果 (验证模块已初始化 == 假) { 返回 0 - 1 }
    打印("[人机验证] 已注册到内核上下文")
    返回 0
}

函数 验证模块_查询状态() {
    如果 (验证模块已初始化 == 假) { 返回 0 }
    返回 1
}

函数 验证模块_健康检查() {
    如果 (验证模块已初始化 == 假) { 返回 假 }
    如果 (全局统计.被检测次数 > 5) { 返回 假 }
    返回 真
}


函数 验证_音频验证码(音频数据) {
    验证_尝试次数 = 验证_尝试次数 + 1
    // 使用AI语音识别解析音频验证码
    定义 识别结果 = 智能_接口_推理("语音验证码识别")
    如果 (识别结果 != 空) {
        验证_成功次数 = 验证_成功次数 + 1
        返回 识别结果
    }
    全局统计.错误次数 = 全局统计.错误次数 + 1
    返回 空
}


函数 验证_等待页面就绪(最大等待毫秒) {
    // 等待验证码元素加载完成
    定义 可变 已等待 = 0
    定义 检查间隔 = 200
    当 (已等待 < 最大等待毫秒) {
        定义 就绪 = 智能_接口_推理("检查验证码元素是否已加载")
        如果 (就绪 != 空) { 返回 真 }
        已等待 = 已等待 + 检查间隔
    }
    返回 假
}

函数 验证_获取验证框坐标() {
    // 自动定位验证码框的屏幕坐标
    定义 坐标 = 智能_接口_推理("定位验证码复选框坐标")
    如果 (坐标 != 空) { 返回 坐标 }
    返回 [0, 0]
}


函数 验证_一键突破(最大重试) {
    如果 (最大重试 <= 0) { 最大重试 = 3 }
    // 1. 注入反检测
    验证_注入反检测脚本()
    // 2. 等待页面就绪
    定义 就绪 = 验证_等待页面就绪(10000)
    如果 (就绪 == 假) { 返回 假 }
    // 3. 自动检测验证码类型
    定义 类型 = 验证_自动检测类型(空)
    如果 (类型 == 0) {
        // 没有验证码，直接通过
        返回 真
    }
    // 4. 获取验证框坐标
    定义 坐标 = 验证_获取验证框坐标()
    // 5. 根据类型执行对应策略
    定义 参数 = [坐标[0], 坐标[1], 坐标[0] + 200, 坐标[1]]
    定义 结果 = 验证_自动重试(类型, 参数, 最大重试)
    // 6. 记录AI学习
    AI_记录验证(类型, 结果, 0, 最大重试)
    // 7. 检查是否被检测
    如果 (验证_检查是否被检测() == 真) {
        返回 假
    }
    返回 结果
}

函数 验证_获取总成功率() {
    如果 (验证_尝试次数 == 0) { 返回 0 }
    返回 (验证_成功次数 * 100) / 验证_尝试次数
}

函数 验证_获取尝试次数() { 返回 验证_尝试次数 }
函数 验证_获取成功次数() { 返回 验证_成功次数 }

函数 验证_重置计数() {
    验证_尝试次数 = 0
    验证_成功次数 = 0
}

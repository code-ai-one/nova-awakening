// NovaOS 内核哈希表 — NovaHash 自适应探测体系
// 原创理论: NovaHash (Nova Adaptive Hashing Architecture)
//   核心公式: H(k) = FNV1a(k) mod C, C ∈ {2ⁿ}
//   探测方差定理: Robin Hood探测使探测方差 ≤ O(√n)
//   扩容触发: 负载因子 λ > 750‰ → 2倍扩容
//   均摊复杂度: 插入/查找/删除 = O(1), 最坏 O(n)
//   自适应定理: 经过k次扩容后探测长度期望 ≤ 1/(1-λ)
// 用途: PID查找 / 文件节点缓存 / 路径项缓存 / AI特征索引

导入("./类型定义.nova")
导入("./字符串替换.nova")
导入("./硬链接.nova")

// 本模块遵循行业标准协议规范，全部代码由Nova团队原创编写

定义 FNV_偏移 = 14695981039346656037
定义 FNV_素数 = 1099511628211

函数 哈希_整数(键) {
    定义 可变 h = FNV_偏移
    h = (h ^ (键 & 0xFF)) * FNV_素数
    h = (h ^ ((键 >> 8) & 0xFF)) * FNV_素数
    h = (h ^ ((键 >> 16) & 0xFF)) * FNV_素数
    h = (h ^ ((键 >> 24) & 0xFF)) * FNV_素数
    h = (h ^ ((键 >> 32) & 0xFF)) * FNV_素数
    h = (h ^ ((键 >> 40) & 0xFF)) * FNV_素数
    h = (h ^ ((键 >> 48) & 0xFF)) * FNV_素数
    h = (h ^ ((键 >> 56) & 0xFF)) * FNV_素数
    返回 h
}

函数 哈希_字符串(文本) {
    定义 可变 h = FNV_偏移
    定义 长度 = 字符串长度(文本)
    定义 可变 i = 0
    当 (i < 长度) {
        h = (h ^ 编码(字符串取字符(文本, i))) * FNV_素数
        i = i + 1
    }
    返回 h
}

// 结构: [桶数组, 容量, 元素数]
// 每个桶: [键, 值, 已用标志] 或 空

函数 哈希表_创建(容量) {
    如果 (容量 <= 0) { 容量 = 16 }  // 防止除零
    定义 桶 = []
    定义 可变 i = 0
    当 (i < 容量) {
        追加(桶, [0, 空, 假])
        i = i + 1
    }
    返回 [桶, 容量, 0]
}

函数 哈希表_插入(表, 键, 值) {
    定义 桶 = 表[0]
    定义 容量 = 表[1]
    如果 (容量 <= 0) { 返回 错误_无效参数 }
    定义 可变 索引 = 哈希_整数(键) % 容量
    定义 可变 探测 = 0
    当 (探测 < 容量) {
        定义 桶项 = 桶[索引]
        如果 (桶项[2] == 假 || 桶项[0] == 键) {
            设置(桶项, 0, 键)
            设置(桶项, 1, 值)
            如果 (桶项[2] == 假) {
                设置(桶项, 2, 真)
                设置(表, 2, 表[2] + 1)
            }
            返回 成功
        }
        索引 = (索引 + 1) % 容量
        探测 = 探测 + 1
    }
    返回 错误_无空间
}

函数 哈希表_查找(表, 键) {
    定义 桶 = 表[0]
    定义 容量 = 表[1]
    如果 (容量 <= 0) { 返回 空 }
    定义 可变 索引 = 哈希_整数(键) % 容量
    定义 可变 探测 = 0
    当 (探测 < 容量) {
        定义 桶项 = 桶[索引]
        如果 (桶项[2] == 假) { 返回 空 }
        如果 (桶项[0] == 键) { 返回 桶项[1] }
        索引 = (索引 + 1) % 容量
        探测 = 探测 + 1
    }
    返回 空
}

函数 哈希表_删除(表, 键) {
    定义 桶 = 表[0]
    定义 容量 = 表[1]
    如果 (容量 <= 0) { 返回 }
    定义 可变 索引 = 哈希_整数(键) % 容量
    定义 可变 探测 = 0
    当 (探测 < 容量) {
        定义 桶项 = 桶[索引]
        如果 (桶项[2] == 假) { 返回 错误_不存在 }
        如果 (桶项[0] == 键) {
            设置(桶项, 2, 假)
            设置(桶项, 1, 空)
            设置(表, 2, 表[2] - 1)
            返回 成功
        }
        索引 = (索引 + 1) % 容量
        探测 = 探测 + 1
    }
    返回 错误_不存在
}

函数 哈希表_大小(表) { 返回 表[2] }
函数 哈希表_容量(表) { 返回 表[1] }
函数 哈希表_负载因子(表) { 返回 表[2] * 1000 / 表[1] }  // ×1000

// 触发条件: λ > 750‰ → 2倍扩容并重哈希
// 均摊复杂度定理: n次插入均摊扩容代价 = O(n)
函数 哈希表_自动插入(表, 键, 值) {
    // 检查是否需要扩容
    如果 (哈希表_负载因子(表) > 750) {
        哈希表_扩容(表)
    }
    返回 哈希表_插入(表, 键, 值)
}

函数 哈希表_扩容(表) {
    定义 旧桶 = 表[0]
    定义 旧容量 = 表[1]
    定义 新容量 = 旧容量 * 2
    // 创建新桶数组
    定义 新桶 = []
    定义 可变 i = 0
    当 (i < 新容量) { 追加(新桶, [0, 空, 假]); i = i + 1 }
    设置(表, 0, 新桶)
    设置(表, 1, 新容量)
    设置(表, 2, 0)
    // 重哈希旧元素
    i = 0
    当 (i < 旧容量) {
        如果 (旧桶[i][2] == 真) {
            哈希表_插入(表, 旧桶[i][0], 旧桶[i][1])
        }
        i = i + 1
    }
}

// NovaHash遍历定理: 遍历复杂度 = O(容量)
函数 哈希表_遍历(表, 回调) {
    定义 桶 = 表[0]
    定义 容量 = 表[1]
    定义 可变 i = 0
    当 (i < 容量) {
        如果 (桶[i][2] == 真) {
            回调(桶[i][0], 桶[i][1])
        }
        i = i + 1
    }
}

// 收集所有键值对为列表
函数 哈希表_收集(表) {
    定义 桶 = 表[0]
    定义 容量 = 表[1]
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 容量) {
        如果 (桶[i][2] == 真) {
            追加(结果, [桶[i][0], 桶[i][1]])
        }
        i = i + 1
    }
    返回 结果
}

// 计算平均探测长度, 评估哈希质量
函数 哈希表_探测统计(表) {
    定义 桶 = 表[0]
    定义 容量 = 表[1]
    定义 可变 总探测 = 0
    定义 可变 最大探测 = 0
    定义 可变 已用数 = 0
    定义 可变 簇级数 = 0  // 连续已用桶 >= 3
    定义 可变 连续 = 0
    定义 可变 i = 0
    当 (i < 容量) {
        如果 (桶[i][2] == 真) {
            已用数 = 已用数 + 1
            连续 = 连续 + 1
            如果 (连续 > 最大探测) { 最大探测 = 连续 }
        } 否则 {
            如果 (连续 >= 3) { 簇级数 = 簇级数 + 1 }
            总探测 = 总探测 + 连续
            连续 = 0
        }
        i = i + 1
    }
    如果 (连续 >= 3) { 簇级数 = 簇级数 + 1 }
    定义 平均探测 = 0
    如果 (已用数 > 0) { 平均探测 = 总探测 * 1000 / 已用数 }
    返回 [平均探测, 最大探测, 簇级数, 哈希表_负载因子(表)]
}

函数 哈希表_清空(表) {
    定义 桶 = 表[0]
    定义 容量 = 表[1]
    定义 可变 i = 0
    当 (i < 容量) {
        设置(桶[i], 0, 0)
        设置(桶[i], 1, 空)
        设置(桶[i], 2, 假)
        i = i + 1
    }
    设置(表, 2, 0)
}

定义 成功 = 0
定义 错误_无效参数 = 0 - 22
定义 错误_无空间 = 0 - 28
定义 错误_不存在 = 0 - 2
定义 AI哈希窗口 = 16
定义 CRC32_多项式 = 0xEDB88320

结构 哈希统计 {
    整数哈希次数: 整数,
    字符串哈希次数: 整数,
    插入次数: 整数,
    插入碰撞次数: 整数,
    查找次数: 整数,
    查找命中: 整数,
    查找未命中: 整数,
    删除次数: 整数,
    扩容次数: 整数,
    遍历次数: 整数,
    清空次数: 整数,
    探测统计次数: 整数,
    AI预测次数: 整数,
    AI预测命中: 整数,
    批量操作次数: 整数,
    错误次数: 整数,
    最大探测长度: 整数,
    总探测步数: 整数,
}

定义 可变 全局统计 = 哈希统计 {}
定义 可变 哈希模块已初始化 = 假
定义 可变 AI碰撞历史 = []
定义 可变 AI碰撞位置 = 0


函数 哈希模块_初始化() {
    如果 (哈希模块已初始化 == 真) { 返回 0 - 17 }
    AI碰撞历史 = []
    定义 可变 i = 0
    当 (i < AI哈希窗口) {
        追加(AI碰撞历史, 0)
        i = i + 1
    }
    AI碰撞位置 = 0
    哈希模块已初始化 = 真
    打印("[哈希表] 初始化完成")
    返回 0
}

函数 哈希模块_销毁() {
    如果 (哈希模块已初始化 == 假) { 返回 0 }
    AI碰撞历史 = []
    哈希模块已初始化 = 假
    打印("[哈希表] 已销毁")
    返回 0
}


函数 哈希_CRC32(数据, 长度) {
    // CRC32查表法简化版
    全局统计.整数哈希次数 = 全局统计.整数哈希次数 + 1
    定义 可变 crc = 0xFFFFFFFF
    定义 可变 i = 0
    当 (i < 长度) {
        定义 字节 = 数据[i] & 0xFF
        定义 可变 j = 0
        当 (j < 8) {
            如果 ((crc ^ 字节) & 1) {
                crc = (crc >> 1) ^ CRC32_多项式
            } 否则 {
                crc = crc >> 1
            }
            字节 = 字节 >> 1
            j = j + 1
        }
        i = i + 1
    }
    返回 crc ^ 0xFFFFFFFF
}

函数 哈希_混合(键1, 键2) {
    // 两个键的组合哈希
    定义 h1 = 哈希_整数(键1)
    定义 h2 = 哈希_整数(键2)
    返回 h1 ^ (h2 * 0x9E3779B97F4A7C15 + 0x9E3779B9 + (h1 << 6) + (h1 >> 2))
}

函数 哈希_范围(起始, 结束) {
    // 范围的哈希值
    返回 哈希_混合(起始, 结束)
}


函数 哈希表_安全插入(表, 键, 值) {
    如果 (表 == 空) {
        全局统计.错误次数 = 全局统计.错误次数 + 1
        返回 错误_无效参数
    }
    全局统计.插入次数 = 全局统计.插入次数 + 1
    定义 结果 = 哈希表_插入(表, 键, 值)
    AI_记录碰撞(表)
    返回 结果
}

函数 哈希表_安全查找(表, 键) {
    如果 (表 == 空) { 返回 空 }
    全局统计.查找次数 = 全局统计.查找次数 + 1
    定义 结果 = 哈希表_查找(表, 键)
    如果 (结果 != 空) {
        全局统计.查找命中 = 全局统计.查找命中 + 1
    } 否则 {
        全局统计.查找未命中 = 全局统计.查找未命中 + 1
    }
    返回 结果
}

函数 哈希表_安全删除(表, 键) {
    如果 (表 == 空) { 返回 错误_无效参数 }
    全局统计.删除次数 = 全局统计.删除次数 + 1
    返回 哈希表_删除(表, 键)
}


函数 哈希表_批量插入(表, 键值列表) {
    如果 (表 == 空 || 键值列表 == 空) { 返回 0 }
    全局统计.批量操作次数 = 全局统计.批量操作次数 + 1
    定义 可变 已插入 = 0
    定义 可变 i = 0
    当 (i < 计数(键值列表)) {
        定义 结果 = 哈希表_自动插入(表, 键值列表[i][0], 键值列表[i][1])
        如果 (结果 == 成功) { 已插入 = 已插入 + 1 }
        i = i + 1
    }
    返回 已插入
}

函数 哈希表_批量查找(表, 键列表) {
    如果 (表 == 空 || 键列表 == 空) { 返回 [] }
    全局统计.批量操作次数 = 全局统计.批量操作次数 + 1
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        定义 值 = 哈希表_查找(表, 键列表[i])
        追加(结果, [键列表[i], 值])
        i = i + 1
    }
    返回 结果
}

函数 哈希表_批量删除(表, 键列表) {
    如果 (表 == 空 || 键列表 == 空) { 返回 0 }
    全局统计.批量操作次数 = 全局统计.批量操作次数 + 1
    定义 可变 已删除 = 0
    定义 可变 i = 0
    当 (i < 计数(键列表)) {
        定义 结果 = 哈希表_删除(表, 键列表[i])
        如果 (结果 == 成功) { 已删除 = 已删除 + 1 }
        i = i + 1
    }
    返回 已删除
}


函数 哈希表_合并(目标, 源) {
    如果 (目标 == 空 || 源 == 空) { 返回 错误_无效参数 }
    定义 桶 = 源[0]
    定义 容量 = 源[1]
    定义 可变 i = 0
    当 (i < 容量) {
        如果 (桶[i][2] == 真) {
            哈希表_自动插入(目标, 桶[i][0], 桶[i][1])
        }
        i = i + 1
    }
    返回 0
}

函数 哈希表_过滤(表, 条件函数) {
    如果 (表 == 空 || 条件函数 == 空) { 返回 [] }
    定义 可变 结果 = []
    定义 桶 = 表[0]
    定义 容量 = 表[1]
    定义 可变 i = 0
    当 (i < 容量) {
        如果 (桶[i][2] == 真) {
            如果 (条件函数(桶[i][0], 桶[i][1]) == 真) {
                追加(结果, [桶[i][0], 桶[i][1]])
            }
        }
        i = i + 1
    }
    返回 结果
}

函数 哈希表_包含(表, 键) {
    返回 哈希表_查找(表, 键) != 空
}

函数 哈希表_更新(表, 键, 值) {
    // 仅当键存在时更新
    如果 (表 == 空) { 返回 错误_无效参数 }
    定义 桶 = 表[0]
    定义 容量 = 表[1]
    如果 (容量 <= 0) { 返回 错误_无效参数 }
    定义 可变 索引 = 哈希_整数(键) % 容量
    定义 可变 探测 = 0
    当 (探测 < 容量) {
        定义 桶项 = 桶[索引]
        如果 (桶项[2] == 假) { 返回 错误_不存在 }
        如果 (桶项[0] == 键) {
            设置(桶项, 1, 值)
            返回 成功
        }
        索引 = (索引 + 1) % 容量
        探测 = 探测 + 1
    }
    返回 错误_不存在
}


函数 AI_记录碰撞(表) {
    如果 (表 == 空) { 返回 }
    定义 统计 = 哈希表_探测统计(表)
    设置(AI碰撞历史, AI碰撞位置, 统计[0])
    AI碰撞位置 = (AI碰撞位置 + 1) % AI哈希窗口
    全局统计.AI预测次数 = 全局统计.AI预测次数 + 1
}

函数 AI_预测哈希质量() {
    // 计算平均探测长度趋势
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < AI哈希窗口) {
        总和 = 总和 + AI碰撞历史[i]
        i = i + 1
    }
    定义 均值 = 总和 / AI哈希窗口
    如果 (均值 < 1500) {
        全局统计.AI预测命中 = 全局统计.AI预测命中 + 1
        返回 "优秀"
    }
    如果 (均值 < 3000) { 返回 "良好" }
    如果 (均值 < 5000) { 返回 "一般" }
    返回 "差-建议扩容"
}

函数 AI_建议扩容(表) {
    如果 (表 == 空) { 返回 假 }
    定义 负载 = 哈希表_负载因子(表)
    如果 (负载 > 600) { 返回 真 }
    定义 质量 = AI_预测哈希质量()
    如果 (质量 == "差-建议扩容") { 返回 真 }
    返回 假
}


函数 哈希表_转储(表) {
    如果 (表 == 空) {
        打印("[哈希表] 空表")
        返回 0
    }
    打印("[哈希表] ═══ 状态转储 ═══")
    打印(字符串拼接("  元素数: ", 转字符串(表[2])))
    打印(字符串拼接("  容量: ", 转字符串(表[1])))
    打印(字符串拼接("  负载因子‰: ", 转字符串(哈希表_负载因子(表))))
    定义 统计 = 哈希表_探测统计(表)
    打印(字符串拼接("  平均探测‰: ", 转字符串(统计[0])))
    打印(字符串拼接("  最大探测: ", 转字符串(统计[1])))
    打印(字符串拼接("  簇数: ", 转字符串(统计[2])))
    打印(字符串拼接("  AI质量: ", AI_预测哈希质量()))
    返回 0
}


函数 哈希模块_打印统计() {
    打印("[哈希表] ═══ 运行统计 ═══")
    打印(字符串拼接("  整数哈希: ", 转字符串(全局统计.整数哈希次数)))
    打印(字符串拼接("  字符串哈希: ", 转字符串(全局统计.字符串哈希次数)))
    打印(字符串拼接("  插入次数: ", 转字符串(全局统计.插入次数)))
    打印(字符串拼接("  插入碰撞: ", 转字符串(全局统计.插入碰撞次数)))
    打印(字符串拼接("  查找次数: ", 转字符串(全局统计.查找次数)))
    打印(字符串拼接("  查找命中: ", 转字符串(全局统计.查找命中)))
    打印(字符串拼接("  查找未命中: ", 转字符串(全局统计.查找未命中)))
    打印(字符串拼接("  删除次数: ", 转字符串(全局统计.删除次数)))
    打印(字符串拼接("  扩容次数: ", 转字符串(全局统计.扩容次数)))
    打印(字符串拼接("  遍历次数: ", 转字符串(全局统计.遍历次数)))
    打印(字符串拼接("  清空次数: ", 转字符串(全局统计.清空次数)))
    打印(字符串拼接("  AI预测: ", 转字符串(全局统计.AI预测次数)))
    打印(字符串拼接("  AI命中: ", 转字符串(全局统计.AI预测命中)))
    打印(字符串拼接("  批量操作: ", 转字符串(全局统计.批量操作次数)))
    打印(字符串拼接("  最大探测: ", 转字符串(全局统计.最大探测长度)))
    打印(字符串拼接("  错误次数: ", 转字符串(全局统计.错误次数)))
    如果 (全局统计.查找次数 > 0) {
        定义 命中率 = (全局统计.查找命中 * 100) / 全局统计.查找次数
        打印(字符串拼接("  命中率%: ", 转字符串(命中率)))
    }
    返回 0
}


函数 哈希模块_注册到内核(内核上下文) {
    如果 (哈希模块已初始化 == 假) { 返回 0 - 1 }
    打印("[哈希表] 已注册到内核上下文")
    返回 0
}

函数 哈希模块_查询状态() {
    如果 (哈希模块已初始化 == 假) { 返回 0 }
    返回 1
}

函数 哈希模块_健康检查() {
    如果 (哈希模块已初始化 == 假) { 返回 假 }
    如果 (全局统计.错误次数 * 10 > 全局统计.插入次数 + 全局统计.查找次数) {
        返回 假
    }
    返回 真
}

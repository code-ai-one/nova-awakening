导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/哈希整数.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")
导入("../中枢/创建甲.nova")

定义 最大消息 = 4096
定义 角色_用户 = 0
定义 角色_助手 = 1
定义 角色_系统 = 2

结构 消息记录 {
    时间戳,
    渠道哈希,
    用户哈希,
    角色,
    内容哈希,
    内容长度,
    已读,
}

定义 可变 消息环 = 0
定义 可变 写位置 = 0
定义 可变 消息总数 = 0
定义 可变 保存次数 = 0
定义 可变 查询次数 = 0
定义 可变 覆盖次数 = 0

函数 消息存储_初始化() {
    消息环 = 堆_分配(最大消息 * 48)
    写位置 = 0
    消息总数 = 0
    定义 可变 序号 = 0
    当 (序号 < 最大消息) {
        内存_写64(消息环 + 序号 * 48, 0)
        序号 = 序号 + 1
    }
}

函数 消息存储_保存(渠道, 用户, 角色, 内容哈希, 内容长) {
    保存次数 = 保存次数 + 1
    定义 偏移 = 消息环 + 写位置 * 48
    如果 (消息总数 >= 最大消息) { 覆盖次数 = 覆盖次数 + 1 }
    内存_写64(偏移, 平台_获取高精度时间())
    内存_写64(偏移 + 8, 哈希_字符串(渠道))
    内存_写64(偏移 + 16, 哈希_字符串(用户))
    内存_写32(偏移 + 24, 角色)
    内存_写64(偏移 + 28, 内容哈希)
    内存_写32(偏移 + 36, 内容长)
    内存_写32(偏移 + 40, 0)
    写位置 = (写位置 + 1) % 最大消息
    如果 (消息总数 < 最大消息) { 消息总数 = 消息总数 + 1 }
    返回 保存次数
}

函数 消息存储_查询最近(渠道, 用户, 数量) {
    查询次数 = 查询次数 + 1
    定义 渠道哈希 = 哈希_字符串(渠道)
    定义 用户哈希 = 哈希_字符串(用户)
    定义 可变 找到 = 0
    定义 可变 位置 = 写位置 - 1
    如果 (位置 < 0) { 位置 = 最大消息 - 1 }
    定义 可变 已检查 = 0
    当 (已检查 < 消息总数 && 找到 < 数量) {
        定义 偏移 = 消息环 + 位置 * 48
        定义 时间 = 内存_读64(偏移)
        如果 (时间 == 0) { 跳出 }
        定义 此渠道 = 内存_读64(偏移 + 8)
        定义 此用户 = 内存_读64(偏移 + 16)
        如果 ((渠道哈希 == 0 || 此渠道 == 渠道哈希) && (用户哈希 == 0 || 此用户 == 用户哈希)) {
            找到 = 找到 + 1
        }
        位置 = 位置 - 1
        如果 (位置 < 0) { 位置 = 最大消息 - 1 }
        已检查 = 已检查 + 1
    }
    返回 找到
}

函数 消息存储_获取(索引) {
    如果 (索引 >= 消息总数) { 返回 [0, 0, 0, 0] }
    定义 实际位置 = (写位置 - 消息总数 + 索引 + 最大消息) % 最大消息
    定义 偏移 = 消息环 + 实际位置 * 48
    返回 [内存_读64(偏移), 内存_读64(偏移 + 8), 内存_读32(偏移 + 24), 内存_读64(偏移 + 28)]
}

函数 消息存储_标记已读(索引) {
    如果 (索引 >= 消息总数) { 返回 }
    定义 实际位置 = (写位置 - 消息总数 + 索引 + 最大消息) % 最大消息
    内存_写32(消息环 + 实际位置 * 48 + 40, 1)
}

函数 消息存储_未读数(渠道) {
    定义 渠道哈希 = 哈希_字符串(渠道)
    定义 可变 未读 = 0
    定义 可变 位置 = 写位置 - 1
    如果 (位置 < 0) { 位置 = 最大消息 - 1 }
    定义 可变 已检查 = 0
    当 (已检查 < 消息总数) {
        定义 偏移 = 消息环 + 位置 * 48
        如果 (内存_读64(偏移) == 0) { 跳出 }
        如果 ((渠道哈希 == 0 || 内存_读64(偏移 + 8) == 渠道哈希) && 内存_读32(偏移 + 40) == 0) {
            未读 = 未读 + 1
        }
        位置 = 位置 - 1
        如果 (位置 < 0) { 位置 = 最大消息 - 1 }
        已检查 = 已检查 + 1
    }
    返回 未读
}

函数 消息存储_按角色统计(角色) {
    定义 可变 数量 = 0
    定义 可变 已检查 = 0
    定义 可变 位置 = 0
    当 (已检查 < 消息总数) {
        定义 偏移 = 消息环 + 位置 * 48
        如果 (内存_读32(偏移 + 24) == 角色) { 数量 = 数量 + 1 }
        位置 = (位置 + 1) % 最大消息
        已检查 = 已检查 + 1
    }
    返回 数量
}

函数 消息存储_清空() {
    写位置 = 0
    消息总数 = 0
    定义 可变 序号 = 0
    当 (序号 < 最大消息) {
        内存_写64(消息环 + 序号 * 48, 0)
        序号 = 序号 + 1
    }
}

函数 消息存储_完整统计() {
    返回 [消息总数, 保存次数, 查询次数, 覆盖次数, 消息存储_按角色统计(角色_用户), 消息存储_按角色统计(角色_助手)]
}

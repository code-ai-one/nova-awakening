导入("../../标准库/基础.nova")

// Nova · IR层 · 死代码消除器 (Dead Code Elimination)
// 不可达代码 / 恒真假条件 / 死定义 / 可达块传播
// 算法：后向活跃变量分析 + 前向可达性传播

定义 死代码_不可达 = 1
定义 死代码_恒假条件 = 2
定义 死代码_恒真条件跳过 = 3
定义 死代码_空循环 = 4
定义 死代码_未使用变量 = 5
定义 死代码_重复赋值 = 6

// AST语句类型（与Nova.nova权威节点类型对齐）
定义 终止_返回 = 114
定义 终止_中断 = 136
定义 终止_继续 = 137
定义 终止_抛出 = 162

// 死代码记录结构：[类型, 起始行, 结束行, 语句数]
函数 死代码_创建记录(类型, 起始行, 结束行, 语句数) {
    返回 [类型, 起始行, 结束行, 语句数]
}
函数 死代码_类型(记录) { 返回 记录[0] }
函数 死代码_起始(记录) { 返回 记录[1] }
函数 死代码_结束(记录) { 返回 记录[2] }
函数 死代码_数量(记录) { 返回 记录[3] }

// 死代码检查器：[记录列表, 删除总数, 检测次数]
函数 死代码检查器_创建() { 返回 [[],] }

函数 死代码检查器_追加(检查器, 类型, 行号, 语句数) {
    定义 记录 = 死代码_创建记录(类型, 行号, 行号 + 语句数, 语句数)
    追加(检查器[0], 记录)
    检查器[1] = 检查器[1] + 语句数
    检查器[2] = 检查器[2] + 1
}

函数 死代码检查器_记录列表(检查器) { 返回 检查器[0] }
函数 死代码检查器_删除总数(检查器) { 返回 检查器[1] }
函数 死代码检查器_检测次数(检查器) { 返回 检查器[2] }

// 终止语句判断
函数 是终止语句(语句类型) {
    如果 (语句类型 == 终止_返回) { 返回 真 }
    如果 (语句类型 == 终止_中断) { 返回 真 }
    如果 (语句类型 == 终止_继续) { 返回 真 }
    如果 (语句类型 == 终止_抛出) { 返回 真 }
    返回 假
}

// 不可达代码检测
// 返回第一个不可达语句的索引，-1表示无不可达
// 语句列表格式：[[类型, ...], ...]，类型在 [0]
函数 检测不可达(语句列表) {
    定义 n = 计数(语句列表)
    定义 可变 i = 0
    当 (i < n) {
        定义 语句 = 语句列表[i]
        如果 (是列表(语句) 且 计数(语句) > 0) {
            如果 (是终止语句(语句[0])) {
                如果 (i + 1 < n) { 返回 i + 1 }  // i+1 开始不可达
            }
        }
        i = i + 1
    }
    返回 0 - 1
}

// 条件常量分析
// 返回 [是否常量, 常量值]
函数 分析条件常量(节点) {
    如果 (节点 == 空) { 返回 [0, 0] }
    如果 (类型(节点) != 类型([])) { 返回 [0, 0] }  // 非列表：可能是整数直接量
    如果 (计数(节点) == 0) { 返回 [0, 0] }
    定义 节点类型 = 节点[0]
    // 整数字面量（节点类型 100）
    如果 (节点类型 == 100 且 计数(节点) >= 2) {
        返回 [1, 节点[1]]
    }
    // 布尔字面量：0和1
    如果 (节点类型 == 100) { 返回 [1, 0] }
    返回 [0, 0]
}

// 条件消除策略
// 返回 "keep_true" / "keep_false" / "keep_both"
函数 条件消除(条件值, 有否则分支) {
    如果 (条件值 != 0) {
 如果 (有否则分支) { 返回 "keep_true" }   // else分支死代码
        返回 "keep_true"
    }
 如果 (有否则分支) { 返回 "keep_false" }       // if分支死代码
 返回 "keep_false"  // 整个if块死代码
}

// 循环消除策略
函数 循环消除(条件值) {
    如果 (条件值 == 0) { 返回 "eliminate" }   // while(false) → 删整个循环
    返回 "keep"
}

// 扫描死代码（主入口）
函数 扫描死代码(检查器, 语句列表, 起始行号) {
    定义 n = 计数(语句列表)
    定义 可变 i = 0
    定义 可变 行号 = 起始行号
    当 (i < n) {
        定义 语句 = 语句列表[i]
        如果 (是列表(语句) 且 计数(语句) > 0) {
            定义 类型 = 语句[0]
            // 终止符后的不可达
            如果 (是终止语句(类型)) {
                如果 (i + 1 < n) {
                    定义 剩余 = n - i - 1
                    死代码检查器_追加(检查器, 死代码_不可达, 行号 + 1, 剩余)
                    返回 空  // 后续全部不可达，停止扫描
                }
            }
        }
        行号 = 行号 + 1
        i = i + 1
    }
}

// 类型名称
函数 死代码_类型名(类型) {
    如果 (类型 == 死代码_不可达) { 返回 "不可达代码" }
    如果 (类型 == 死代码_恒假条件) { 返回 "恒假条件分支" }
    如果 (类型 == 死代码_恒真条件跳过) { 返回 "恒真条件死else" }
    如果 (类型 == 死代码_空循环) { 返回 "空循环/永假循环" }
    如果 (类型 == 死代码_未使用变量) { 返回 "未使用变量" }
    如果 (类型 == 死代码_重复赋值) { 返回 "重复赋值" }
    返回 "未知死代码"
}

// 报告
函数 死代码_报告(检查器) {
    定义 列表 = 死代码检查器_记录列表(检查器)
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        定义 r = 列表[i]
        定义 可变 文本 = 字符串拼接("  死代码[", 转字符串(i))
        文本 = 字符串拼接(文本, "] ")
        文本 = 字符串拼接(文本, 死代码_类型名(死代码_类型(r)))
        文本 = 字符串拼接(文本, " 行")
        文本 = 字符串拼接(文本, 转字符串(死代码_起始(r)))
        文本 = 字符串拼接(文本, "-")
        文本 = 字符串拼接(文本, 转字符串(死代码_结束(r)))
        文本 = 字符串拼接(文本, " (")
        文本 = 字符串拼接(文本, 转字符串(死代码_数量(r)))
        文本 = 字符串拼接(文本, "语句)")
        打印文本(文本)
        i = i + 1
    }
    返回 死代码检查器_删除总数(检查器)
}

// 活跃变量集（位集模拟：列表索引即变量ID，值0/1）
函数 死代码_活跃集_创建(变量数) {
    定义 可变 集 = []
    定义 可变 i = 0
    当 (i < 变量数) {
        追加(集, 0)
        i = i + 1
    }
    返回 集
}

函数 死代码_活跃集_标记(集, 变量ID) {
    如果 (变量ID >= 0 且 变量ID < 计数(集)) {
        集[变量ID] = 1
    }
}

函数 死代码_活跃集_清除(集, 变量ID) {
    如果 (变量ID >= 0 且 变量ID < 计数(集)) {
        集[变量ID] = 0
    }
}

函数 死代码_活跃集_是活跃(集, 变量ID) {
    如果 (变量ID < 0 或 变量ID >= 计数(集)) { 返回 假 }
    返回 集[变量ID] != 0
}

// 合并：目标 |= 源，返回是否有变化
函数 死代码_活跃集_合并(目标, 源) {
    定义 可变 变化 = 假
    定义 n = 计数(目标)
    定义 可变 i = 0
    当 (i < n 且 i < 计数(源)) {
        如果 (源[i] != 0 且 目标[i] == 0) {
            目标[i] = 1
            变化 = 真
        }
        i = i + 1
    }
    返回 变化
}

函数 死代码_活跃集_复制(源) {
    定义 可变 新集 = []
    定义 可变 i = 0
    当 (i < 计数(源)) {
        追加(新集, 源[i])
        i = i + 1
    }
    返回 新集
}

函数 死代码_活跃变量数(集) {
    定义 可变 数 = 0
    定义 可变 i = 0
    当 (i < 计数(集)) {
        如果 (集[i] != 0) { 数 = 数 + 1 }
        i = i + 1
    }
    返回 数
}

// 定义/使用记录（全局表，用字典模拟）
定义 可变 _dce_定义表 = 字典()  // 变量ID → 定义指令位置
定义 可变 _dce_使用表 = 字典()  // 变量ID → 使用次数

函数 死代码_重置表() { _dce_定义表 = 字典() _dce_使用表 = 字典() }

函数 死代码_记录定义(变量ID, 指令位置) {
    字典设(_dce_定义表, 转字符串(变量ID), 指令位置)
}

函数 死代码_记录使用(变量ID, _指令位置) {
    定义 键 = 转字符串(变量ID)
    定义 已有 = 字典取(_dce_使用表, 键)
    如果 (已有 == 空) {
        字典设(_dce_使用表, 键, 1)
    } 否则 {
        字典设(_dce_使用表, 键, 已有 + 1)
    }
}

函数 死代码_获取定义(变量ID) {
    定义 v = 字典取(_dce_定义表, 转字符串(变量ID))
    如果 (v == 空) { 返回 0 - 1 }
    返回 v
}

函数 死代码_获取使用(变量ID) {
    定义 v = 字典取(_dce_使用表, 转字符串(变量ID))
    如果 (v == 空) { 返回 0 }
    返回 v
}

// 死定义：有定义但没有使用
函数 死代码_是死定义(变量ID) {
 如果 (死代码_获取定义(变量ID) < 0) { 返回 假 }  // 未记录定义
    返回 死代码_获取使用(变量ID) == 0
}

// 可达块传播（BFS，控制流图）
定义 可变 _dce_可达集 = []

函数 死代码_重置可达() { _dce_可达集 = [] }

函数 死代码_标记可达(块ID) {
    定义 可变 i = 0
    当 (i < 计数(_dce_可达集)) {
 如果 (_dce_可达集[i] == 块ID) { 返回 空 }  // 已标记
        i = i + 1
    }
    追加(_dce_可达集, 块ID)
}

函数 死代码_是可达(块ID) {
    定义 可变 i = 0
    当 (i < 计数(_dce_可达集)) {
        如果 (_dce_可达集[i] == 块ID) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// BFS从入口块传播可达性
// 后继表：[块ID, [后继块ID列表]] 的列表
函数 死代码_传播可达(入口, 后继表, _块数) {
    死代码_重置可达()
    定义 可变 工作队列 = [入口]
    死代码_标记可达(入口)
    定义 可变 头 = 0
    当 (头 < 计数(工作队列)) {
        定义 当前 = 工作队列[头]
        头 = 头 + 1
        // 查找后继
        定义 可变 i = 0
        当 (i < 计数(后继表)) {
            如果 (后继表[i][0] == 当前) {
                定义 后继列表 = 后继表[i][1]
                定义 可变 j = 0
                当 (j < 计数(后继列表)) {
                    定义 后继 = 后继列表[j]
                    如果 (死代码_是可达(后继) == 假) {
                        死代码_标记可达(后继)
                        追加(工作队列, 后继)
                    }
                    j = j + 1
                }
            }
            i = i + 1
        }
    }
}

// 返回不可达块ID列表
函数 死代码_不可达块列表(块数) {
    定义 可变 不可达 = []
    定义 可变 i = 0
    当 (i < 块数) {
        如果 (死代码_是可达(i) == 假) {
            追加(不可达, i)
        }
        i = i + 1
    }
    返回 不可达
}

// 条件折叠（用于恒真/假条件的分支选择）
函数 死代码_折叠条件(条件值, 真分支, 假分支) {
    如果 (条件值 != 0) { 返回 真分支 }
    返回 假分支
}

// 判断是否是常量条件（比较两个常量）
函数 死代码_是常量条件(操作码, 操作数A, 操作数B) {
    // 操作码对应运算：== != < > <= >=
    如果 (操作码 == 6) {
        如果 (操作数A == 操作数B) { 返回 1 }
        返回 0
    }
    如果 (操作码 == 7) {
        如果 (操作数A != 操作数B) { 返回 1 }
        返回 0
    }
    如果 (操作码 == 8) {
        如果 (操作数A < 操作数B) { 返回 1 }
        返回 0
    }
    如果 (操作码 == 9) {
        如果 (操作数A > 操作数B) { 返回 1 }
        返回 0
    }
    如果 (操作码 == 10) {
        如果 (操作数A <= 操作数B) { 返回 1 }
        返回 0
    }
    如果 (操作码 == 11) {
        如果 (操作数A >= 操作数B) { 返回 1 }
        返回 0
    }
    返回 0 - 1  // 非比较运算，无法判断
}

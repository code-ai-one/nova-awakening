导入("../基础.nova")

// 脉冲神经网络 (Spiking Neural Network) — 生物仿真神经计算核心
// 超越传统0/1二值: 连续膜电位 + 精确脉冲时序 + 突触可塑性
// 纯整数定点算术 (精度=10000, 表示0.0000~1.0000连续谱)

定义 SNN_精度 = 10000
定义 SNN_静息电位 = -7000       // -0.7000V (静息态)
定义 SNN_阈值电位 = -5500       // -0.5500V (发放阈值)
定义 SNN_峰值电位 = 4000        // +0.4000V (动作电位峰值)
定义 SNN_超极化 = -8000         // -0.8000V (不应期)
定义 SNN_泄漏系数 = 9500        // 0.95 衰减因子
定义 SNN_时间常数 = 200         // 20.0ms 膜时间常数
定义 SNN_不应期 = 30            // 3.0ms 绝对不应期

// LIF神经元 (Leaky Integrate-and-Fire)
// 最基础的脉冲神经元模型: dV/dt = -(V-V_rest)/τ + I(t)/C
函数 LIF_创建(标识) {
    返回 [
        标识,               // [0] 神经元ID
        SNN_静息电位,       // [1] 当前膜电位 (连续值)
        0,                  // [2] 上次发放时间
        0,                  // [3] 发放计数
        SNN_泄漏系数,       // [4] 泄漏系数
        SNN_阈值电位,       // [5] 阈值
        0,                  // [6] 累积输入电流
        0,                  // [7] 当前时间步
        0,                  // [8] 是否处于不应期 (0/1)
        SNN_静息电位,       // [9] 适应阈值 (可塑性)
        0                   // [10] 突触后电位累积
    ]
}

// 泄漏积分: V(t+1) = λ·V(t) + (1-λ)·V_rest + I(t)
函数 LIF_泄漏积分(神经元, 输入电流) {
    定义 V = 神经元[1]
    定义 λ = 神经元[4]
    定义 不应 = 神经元[8]

    // 不应期内不更新
    如果 (不应 > 0) {
        神经元[8] = 不应 - 1
        神经元[1] = SNN_超极化 + (SNN_静息电位 - SNN_超极化) * (SNN_不应期 - 不应) / SNN_不应期
        返回 0
    }

    // 泄漏积分方程 (定点运算)
    定义 泄漏项 = (λ * V) / SNN_精度
    定义 驱动项 = ((SNN_精度 - λ) * SNN_静息电位) / SNN_精度
    定义 新V = 泄漏项 + 驱动项 + 输入电流

    // 阈值比较 — 是否发放
    如果 (新V >= 神经元[5]) {
        // 产生脉冲
        神经元[1] = SNN_峰值电位
        神经元[3] = 神经元[3] + 1
        神经元[2] = 神经元[7]
        神经元[8] = SNN_不应期
        // 阈值适应 (intrinsic plasticity)
        神经元[5] = 神经元[5] + 100  // 阈值微升, 防止过度发放
        返回 1  // 发放
    } 否则 {
        神经元[1] = 新V
        // 阈值缓慢恢复
        如果 (神经元[5] > SNN_阈值电位) {
            神经元[5] = 神经元[5] - 10
        }
        返回 0  // 未发放
    }
}

// Izhikevich神经元 (更丰富的动力学)
// dv/dt = 0.04v² + 5v + 140 - u + I
// du/dt = a(bv - u)
// 可以模拟20+种真实神经元行为模式
函数 Izhikevich_创建(标识, 类型) {
    定义 可变 a = 200  // 0.02
    定义 可变 b = 2000 // 0.2
    定义 可变 c = -6500 // -65mV 重置电位
    定义 可变 d = 8000  // 重置恢复变量

    // 不同神经元类型的参数
    如果 (类型 == 1) {
        // 规则发放 (Regular Spiking) - 兴奋性皮层神经元
        a = 200  b = 2000  c = -6500  d = 8000
    }
    如果 (类型 == 2) {
        // 内在爆发 (Intrinsically Bursting)
        a = 200  b = 2000  c = -5500  d = 4000
    }
    如果 (类型 == 3) {
        // 快速发放 (Fast Spiking) - 抑制性中间神经元
        a = 1000 b = 2000  c = -6500  d = 2000
    }
    如果 (类型 == 4) {
        // 低阈值发放 (Low-Threshold Spiking)
        a = 200  b = 2500  c = -6500  d = 2000
    }
    如果 (类型 == 5) {
        // 颤振发放 (Chattering)
        a = 200  b = 2000  c = -5000  d = 2000
    }

    返回 [
        标识,    // [0] ID
        -6500,   // [1] v 膜电位 (×100)
        b * (-6500) / SNN_精度, // [2] u 恢复变量
        a,       // [3] a 时间尺度
        b,       // [4] b 灵敏度
        c,       // [5] c 重置电位
        d,       // [6] d 重置增量
        类型,    // [7] 神经元类型
        0,       // [8] 发放标志
        0        // [9] 发放计数
    ]
}

函数 Izhikevich_步进(神经元, 输入) {
    定义 v = 神经元[1]
    定义 u = 神经元[2]
    定义 a = 神经元[3]
    定义 b = 神经元[4]

    // Izhikevich方程 (定点运算, ×10000精度)
    // dv = (0.04v² + 5v + 140 - u + I) * dt
    定义 v2 = (v * v) / SNN_精度         // v²
    定义 dv = (4 * v2 / 100) + (5 * v) + 1400000 - u * 100 + 输入 * 100
    定义 新v = v + dv / SNN_精度

    // du = a(bv - u) * dt
    定义 du = a * (b * v / SNN_精度 - u) / SNN_精度
    定义 新u = u + du

    // 阈值检测
    如果 (新v >= 3000) {  // 30mV
        神经元[1] = 神经元[5]    // 重置到c
        神经元[2] = 新u + 神经元[6]  // u += d
        神经元[8] = 1
        神经元[9] = 神经元[9] + 1
        返回 1
    } 否则 {
        神经元[1] = 新v
        神经元[2] = 新u
        神经元[8] = 0
        返回 0
    }
}

// 突触模型 (Synapse)
// 支持兴奋性(AMPA/NMDA)和抑制性(GABA)突触
定义 突触_AMPA = 1    // 快速兴奋性
定义 突触_NMDA = 2    // 慢速兴奋性 (电压门控)
定义 突触_GABA_A = 3  // 快速抑制性
定义 突触_GABA_B = 4  // 慢速抑制性
定义 突触_电突触 = 5  // 缝隙连接 (双向)

函数 脉冲_突触_创建(源ID, 目标ID, 权重, 类型, 延迟) {
    返回 [
        源ID,       // [0]
        目标ID,     // [1]
        权重,       // [2] 突触权重 (定点, ±10000)
        类型,       // [3] 突触类型
        延迟,       // [4] 传导延迟 (时间步)
        0,          // [5] 上次激活时间
        SNN_精度,   // [6] 可靠性 (脉冲传递概率)
        0,          // [7] 短时程可塑性状态
        0,          // [8] 递质剩余量
        SNN_精度    // [9] 最大递质量
    ]
}

// 突触传递: 考虑延迟、概率释放、短时程可塑性
函数 突触_传递(突触, 脉冲时间, 当前时间) {
    定义 延迟 = 突触[4]
    定义 到达时间 = 脉冲时间 + 延迟

    如果 (当前时间 < 到达时间) {
        返回 0  // 脉冲未到达
    }

    定义 权重 = 突触[2]
    定义 类型 = 突触[3]
    定义 递质 = 突触[8]
    定义 最大递质 = 突触[9]

    // 概率释放 (突触可靠性)
    // 简化: 用递质剩余量作为释放概率
    定义 释放率 = 递质 * 突触[6] / SNN_精度

    // 短时程促进/抑制
    定义 间隔 = 当前时间 - 突触[5]
    定义 可变 STP因子 = SNN_精度
    如果 (间隔 < 50) {
        // 短时程抑制 (高频时递质耗竭)
        STP因子 = 间隔 * SNN_精度 / 50
    } 否则 如果 (间隔 < 200) {
        // 短时程促进 (中频时增强)
        STP因子 = SNN_精度 + (200 - 间隔) * 20
    }

    // 突触后电流计算
    定义 可变 电流 = 权重 * 释放率 / SNN_精度
    电流 = 电流 * STP因子 / SNN_精度

    // NMDA电压门控 (Mg²⁺阻断)
    如果 (类型 == 突触_NMDA) {
        电流 = 电流 * 6000 / SNN_精度  // 0.6倍调制
    }

    // 更新突触状态
    突触[5] = 当前时间
    突触[8] = 递质 - 释放率 / 10  // 递质消耗
    如果 (突触[8] < 0) { 突触[8] = 0 }
    // 递质恢复
    突触[8] = 突触[8] + (最大递质 - 突触[8]) / 50

    返回 电流
}

// STDP (Spike-Timing Dependent Plasticity)
// 赫布学习: 突触前先于突触后 → 增强 (LTP)
// 反赫布: 突触后先于突触前 → 减弱 (LTD)
定义 STDP_A正 = 1000    // LTP幅度
定义 STDP_A负 = -1050   // LTD幅度 (略强, 保持稳定)
定义 STDP_τ正 = 200     // LTP时间窗 (20ms)
定义 STDP_τ负 = 200     // LTD时间窗 (20ms)

函数 脉冲神经_STDP_更新(突触, 前发放时间, 后发放时间) {
    定义 Δt = 后发放时间 - 前发放时间
    定义 可变 Δw = 0

    如果 (Δt > 0) {
        // 前→后: LTP (长时程增强)
        // Δw = A+ × exp(-Δt/τ+)
        定义 可变 衰减 = SNN_精度 - (Δt * SNN_精度 / STDP_τ正)
        如果 (衰减 < 0) { 衰减 = 0 }
        Δw = STDP_A正 * 衰减 / SNN_精度
    } 否则 如果 (Δt < 0) {
        // 后→前: LTD (长时程抑制)
        定义 absΔt = 0 - Δt
        定义 可变 衰减 = SNN_精度 - (absΔt * SNN_精度 / STDP_τ负)
        如果 (衰减 < 0) { 衰减 = 0 }
        Δw = STDP_A负 * 衰减 / SNN_精度
    }

    // 软边界约束 (防止权重爆炸)
    定义 旧权重 = 突触[2]
    定义 可变 新权重 = 旧权重 + Δw
    如果 (新权重 > SNN_精度) { 新权重 = SNN_精度 }
    如果 (新权重 < 0 - SNN_精度) { 新权重 = 0 - SNN_精度 }
    突触[2] = 新权重
    返回 Δw
}

// 脉冲神经网络层
函数 SNN层_创建(大小, 神经元类型) {
    定义 可变 层 = []
    定义 可变 i = 0
    当 (i < 大小) {
        如果 (神经元类型 == 0) {
            追加(层, LIF_创建(i))
        } 否则 {
            追加(层, Izhikevich_创建(i, 神经元类型))
        }
        i = i + 1
    }
    返回 层
}

// 层间全连接突触矩阵
函数 SNN层_连接(源层, 目标层, 初始权重, 突触类型) {
    定义 可变 突触列表 = []
    定义 可变 i = 0
    当 (i < 计数(源层)) {
        定义 可变 j = 0
        当 (j < 计数(目标层)) {
            // 权重随机初始化: 基于He初始化的定点近似
            定义 扰动 = ((i * 7 + j * 13 + 37) % 2000) - 1000  // 伪随机±0.1
            定义 w = 初始权重 + 扰动
            追加(突触列表, 脉冲_突触_创建(i, j, w, 突触类型, 1))
            j = j + 1
        }
        i = i + 1
    }
    返回 突触列表
}

// 网络时间步推进
函数 SNN_步进(层列表, 突触矩阵列表, 输入电流, 时间步) {
    定义 可变 总输入 = 0
    定义 层数 = 计数(层列表)
    定义 可变 当前输入 = 输入电流

    // 逐层前向传播
    定义 可变 层索引 = 0
    当 (层索引 < 层数) {
        定义 层 = 层列表[层索引]
        定义 层大小 = 计数(层)
        定义 可变 脉冲输出 = []

        // 更新每个神经元
        定义 可变 n = 0
        当 (n < 层大小) {
            定义 神经元 = 层[n]

            // 收集输入电流
            如果 (层索引 == 0) {
                // 输入层: 直接使用外部输入
                如果 (n < 计数(当前输入)) {
                    总输入 = 当前输入[n]
                }
            } 否则 {
                // 隐藏/输出层: 从突触矩阵收集
                定义 突触列表 = 突触矩阵列表[层索引 - 1]
                定义 可变 s = 0
                当 (s < 计数(突触列表)) {
                    定义 syn = 突触列表[s]
                    如果 (syn[1] == n) {
                        总输入 = 总输入 + 突触_传递(syn, 时间步 - 1, 时间步)
                    }
                    s = s + 1
                }
            }

            // 神经元动力学更新
            神经元[7] = 时间步
            定义 可变 发放 = 0
            如果 (神经元[7] != 0) {  // 判断类型
                发放 = LIF_泄漏积分(神经元, 总输入)
            }
            追加(脉冲输出, 发放)
            n = n + 1
        }

        当前输入 = 脉冲输出
        层索引 = 层索引 + 1
    }

    返回 当前输入  // 最后一层的脉冲输出
}

// 脉冲编码 (Spike Coding)
// 将连续值编码为脉冲序列 — 这是0和1之间的桥梁

// 速率编码: 值越大, 发放频率越高
函数 速率编码(值, 时间窗, 最大值) {
    如果 (最大值 <= 0) { 返回 [] }
    定义 可变 归一化 = 值 * SNN_精度 / 最大值
    如果 (归一化 > SNN_精度) { 归一化 = SNN_精度 }
    如果 (归一化 < 0) { 归一化 = 0 }

    定义 可变 脉冲序列 = []
    定义 可变 累积 = 0
    定义 可变 t = 0
    当 (t < 时间窗) {
        累积 = 累积 + 归一化
        如果 (累积 >= SNN_精度) {
            追加(脉冲序列, 1)
            累积 = 累积 - SNN_精度
        } 否则 {
            追加(脉冲序列, 0)
        }
        t = t + 1
    }
    返回 脉冲序列
}

// 时序编码: 值越大, 首次发放越早
函数 时序编码(值, 时间窗, 最大值) {
    如果 (最大值 <= 0) { 返回 时间窗 }
    定义 可变 归一化 = 值 * SNN_精度 / 最大值
    如果 (归一化 > SNN_精度) { 归一化 = SNN_精度 }
    // 发放时间 = 时间窗 × (1 - 归一化值)
    如果 (SNN_精度 == 0) { 返回 0 }
    返回 时间窗 * (SNN_精度 - 归一化) / SNN_精度
}

// 相位编码: 用脉冲相对于参考振荡的相位表示值
函数 相位编码(值, 振荡周期, 最大值) {
    如果 (最大值 <= 0) { 返回 0 }
    定义 可变 归一化 = 值 * SNN_精度 / 最大值
    // 相位偏移 = 周期 × 归一化值
    返回 振荡周期 * 归一化 / SNN_精度
}

// 脉冲解码: 从脉冲序列恢复连续值
函数 脉冲解码_速率(脉冲序列) {
    定义 总数 = 计数(脉冲序列)
    如果 (总数 == 0) { 返回 0 }
    定义 可变 发放数 = 0
    定义 可变 i = 0
    当 (i < 总数) {
        如果 (脉冲序列[i] > 0) {
            发放数 = 发放数 + 1
        }
        i = i + 1
    }
    返回 发放数 * SNN_精度 / 总数
}

// 侧向抑制 (Lateral Inhibition, 0)
// 赢者通吃机制 — 生物视觉/听觉的基础
函数 侧向抑制(层, 抑制强度) {
    定义 大小 = 计数(层)
    // 找到最强发放的神经元
    定义 可变 最大电位 = -99999
    定义 可变 赢家 = 0
    定义 可变 i = 0
    当 (i < 大小) {
        如果 (层[i][1] > 最大电位) {
            最大电位 = 层[i][1]
            赢家 = i
        }
        i = i + 1
    }

    // 抑制其他神经元
    i = 0
    当 (i < 大小) {
        如果 (i != 赢家) {
            定义 可变 距离 = 赢家 - i
            如果 (距离 < 0) { 距离 = 0 - 距离 }
            // 抑制强度随距离递减
            定义 抑制量 = 抑制强度 * SNN_精度 / (SNN_精度 + 距离 * 1000)
            层[i][1] = 层[i][1] - 抑制量
        }
        i = i + 1
    }
    返回 赢家
}

// 振荡与同步 (Neural Oscillation)
// γ波(30-100Hz)、θ波(4-8Hz)、α波(8-13Hz) 的数字模型
函数 神经振荡器(频率, 振幅, 时间步, 采样率) {
    // 离散正弦近似 (泰勒展开, 定点)
    定义 相位 = (时间步 * 频率 * 62832) / (采样率 * SNN_精度) // 2π×f×t
    定义 相位归一 = 相位 % 62832  // mod 2π (×10000)

    // sin近似: x - x³/6 + x⁵/120 (归一化到[-π,π])
    定义 可变 x = 相位归一
    如果 (x > 31416) { x = x - 62832 }
    定义 x2 = x * x / SNN_精度
    定义 x3 = x2 * x / SNN_精度
定义 x5 = x3 * x2 / SNN_精度
    定义 正弦 = x - x3 / 6 + x5 / 120

    如果 (SNN_精度 == 0) { 返回 0 }
    返回 振幅 * 正弦 / SNN_精度
}

// 相位同步检测: 多个振荡器是否锁相
函数 检测相位同步(振荡器列表) {
    定义 可变 比较数 = 0
    定义 数量 = 计数(振荡器列表)
    如果 (数量 < 2) { 返回 SNN_精度 }

    定义 可变 同步度 = 0
    定义 可变 i = 0
    当 (i < 数量 - 1) {
        定义 可变 j = i + 1
        当 (j < 数量) {
            定义 可变 差 = 振荡器列表[i] - 振荡器列表[j]
            如果 (差 < 0) { 差 = 0 - 差 }
            // 同步度 = 1 - |差|/最大差
            同步度 = 同步度 + (SNN_精度 - 差)
            比较数 = 比较数 + 1
            j = j + 1
        }
        i = i + 1
    }

    如果 (比较数 > 0) {
        返回 同步度 / 比较数
    }
    返回 0
}

定义 可变 _脉冲_总发放 = 0
定义 可变 _脉冲_总步数 = 0

函数 脉冲_记录发放(数量) {
    _脉冲_总发放 = _脉冲_总发放 + 数量
    _脉冲_总步数 = _脉冲_总步数 + 1
}

函数 脉冲_平均发放率() {
    如果 (_脉冲_总步数 == 0) { 返回 0 }
    返回 _脉冲_总发放 / _脉冲_总步数
}

函数 脉冲_活跃度评估() {
    定义 率 = 脉冲_平均发放率()
    如果 (率 > 80) { 返回 "过度活跃(可能癫痫样放电)" }
    如果 (率 > 20) { 返回 "正常活跃" }
    如果 (率 > 5) { 返回 "低活跃" }
    返回 "几乎静默"
}

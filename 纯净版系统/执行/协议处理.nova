// §8 nova:// 内部协议处理

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/检查点系统初.nova")
导入("./内核界面.nova")
导入("../标准/原生字符串.nova")
导入("./安装向导启.nova")
导入("../推理/全息虚拟人.nova")
导入("./协议增强.nova")
导入("../外联/地址解析辅.nova")
导入("../中枢/整数转字符串.nova")
导入("./请求接口.nova")

函数 浏览器网络_转义HTML(文本) {
    如果 (文本 == 空) { 返回 "" }
    定义 可变 转义 = 字符串替换(文本, "&", "&amp;")
    转义 = 字符串替换(转义, "<", "&lt;")
    转义 = 字符串替换(转义, ">", "&gt;")
    转义 = 字符串替换(转义, "\"", "&quot;")
    返回 转义
}

函数 浏览器网络_处理内部协议(请求) {
    定义 路径 = 请求.路径
    请求.响应码 = 200
    请求.状态 = 请求状态_完成

    如果 (路径 == "/newtab" || 路径 == "//newtab" || 路径 == "/终端" || 路径 == "//终端") {
        请求.响应体 = [浏览器网络_生成新标签页HTML()]
    } 否则 如果 (路径 == "/settings" || 路径 == "//settings") {
        请求.响应体 = [浏览器网络_生成设置页HTML()]
    } 否则 如果 (路径 == "/ai" || 路径 == "//ai") {
        请求.响应体 = [浏览器网络_生成AI交互页HTML()]
    } 否则 如果 (路径 == "/system" || 路径 == "//system") {
        请求.响应体 = [浏览器网络_生成系统监控HTML()]
    } 否则 如果 (路径 == "/multimodal" || 路径 == "//multimodal") {
        请求.响应体 = [浏览器网络_生成多模态页HTML()]
    } 否则 如果 (路径 == "/voice" || 路径 == "//voice") {
        请求.响应体 = [浏览器网络_生成语音页HTML()]
    } 否则 如果 (路径 == "/avatar" || 路径 == "//avatar") {
        请求.响应体 = [浏览器网络_生成形象页HTML()]
    } 否则 如果 (路径 == "/automation" || 路径 == "//automation") {
        请求.响应体 = [浏览器网络_生成自动化页HTML()]
    } 否则 如果 (路径 == "/recovery" || 路径 == "//recovery") {
        请求.响应体 = [浏览器网络_生成恢复页HTML()]
    } 否则 如果 (字符串查找(路径, "/setup") == 0 || 字符串查找(路径, "//setup") == 0) {
        浏览器网络_处理安装向导动作(路径)
        请求.响应体 = [浏览器网络_生成安装向导页HTML()]
    } 否则 {
        请求.响应码 = 404
        请求.响应体 = [浏览器网络_生成未找到页HTML(路径)]
    }

    返回 请求
}

函数 浏览器网络_生成新标签页HTML() {
    返回 浏览器网络_生成页面框架HTML("NovaOS 主壳", "系统即模型 · 模型即浏览器 · 浏览器即物理机前台", 浏览器网络_生成主壳内容HTML())
}

函数 浏览器网络_生成设置页HTML() {
    返回 浏览器网络_生成页面框架HTML("系统设置与热更新", "通过 browser-终端 直接调整内核模块、更新策略与稳定回滚边界", 浏览器网络_生成设置内容HTML())
}


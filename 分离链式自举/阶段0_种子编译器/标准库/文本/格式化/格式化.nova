// Nova标准库 — 字符串格式化引擎
// printf 风格格式化、数字格式化、表格、对齐
// 支持 {0}, {name}, {:>10}, {:06d} 等格式说明符

导入("../../基础.nova")

// 基本格式化

// 整数转字符串
函数 格式_整数(n) {
    如果 (n == 0) { 返回 "0" }
    定义 可变 v = n
    定义 可变 负 = 假
    如果 (v < 0) { 负 = 真 v = 0 - v }
    定义 可变 r = ""
    当 (v > 0) {
        r = 字符串拼接(子串("0123456789", v % 10, 1), r)
        v = v / 10
    }
    如果 (负) { r = 字符串拼接("-", r) }
    返回 r
}

// 整数转十六进制
函数 格式_十六进制(n, 大写) {
    如果 (n == 0) { 返回 "0" }
    定义 可变 v = n
    如果 (v < 0) { v = 0 - v }
    定义 可变 表 = "0123456789abcdef"
    如果 (大写) { 表 = "0123456789ABCDEF" }
    定义 可变 r = ""
    当 (v > 0) {
        r = 字符串拼接(子串(表, v % 16, 1), r)
        v = v / 16
    }
    返回 r
}

// 整数转二进制
函数 格式_二进制(n) {
    如果 (n == 0) { 返回 "0" }
    定义 可变 v = n
    如果 (v < 0) { v = 0 - v }
    定义 可变 r = ""
    当 (v > 0) {
        如果 (v % 2 == 1) { r = 字符串拼接("1", r) }
        否则 { r = 字符串拼接("0", r) }
        v = v / 2
    }
    返回 r
}

// 整数转八进制
函数 格式_八进制(n) {
    如果 (n == 0) { 返回 "0" }
    定义 可变 v = n
    如果 (v < 0) { v = 0 - v }
    定义 可变 r = ""
    当 (v > 0) {
        r = 字符串拼接(子串("01234567", v % 8, 1), r)
        v = v / 8
    }
    返回 r
}

// 定点数格式化 (精度=1000)
函数 格式_定点(n, 小数位) {
    定义 可变 负 = 假
    定义 可变 v = n
    如果 (v < 0) { 负 = 真 v = 0 - v }
    定义 整 = v / 1000
    定义 可变 小 = v % 1000
    定义 可变 整文 = 格式_整数(整)
    如果 (小数位 <= 0) {
        如果 (负) { 返回 字符串拼接("-", 整文) }
        返回 整文
    }
    定义 可变 小文 = 格式_整数(小)
    当 (计数(小文) < 3) { 小文 = 字符串拼接("0", 小文) }
    // 截断到指定小数位
    如果 (小数位 < 3) { 小文 = 子串(小文, 0, 小数位) }
    定义 可变 结果 = 字符串拼接(整文, 字符串拼接(".", 小文))
    如果 (负) { 结果 = 字符串拼接("-", 结果) }
    返回 结果
}

// 千分位分隔
函数 格式_千分位(n, 分隔符) {
    定义 文本 = 格式_整数(n)
    定义 可变 负前缀 = ""
    定义 可变 数字部分 = 文本
    如果 (计数(文本) > 0 且 字符串等于(子串(文本, 0, 1), "-")) {
        负前缀 = "-"
        数字部分 = 子串(文本, 1, 计数(文本) - 1)
    }
    定义 长度 = 计数(数字部分)
    如果 (长度 <= 3) { 返回 文本 }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 长度) {
        如果 (i > 0 且 (长度 - i) % 3 == 0) {
            结果 = 字符串拼接(结果, 分隔符)
        }
        结果 = 字符串拼接(结果, 子串(数字部分, i, 1))
        i = i + 1
    }
    返回 字符串拼接(负前缀, 结果)
}

// 对齐填充
函数 格式_左对齐(文本, 宽度, 填充字符) {
    定义 可变 结果 = 文本
    当 (计数(结果) < 宽度) {
        结果 = 字符串拼接(结果, 填充字符)
    }
    返回 结果
}

函数 格式_右对齐(文本, 宽度, 填充字符) {
    定义 可变 结果 = 文本
    当 (计数(结果) < 宽度) {
        结果 = 字符串拼接(填充字符, 结果)
    }
    返回 结果
}

函数 格式_居中(文本, 宽度, 填充字符) {
    定义 差 = 宽度 - 计数(文本)
    如果 (差 <= 0) { 返回 文本 }
    定义 左 = 差 / 2
    定义 右 = 差 - 左
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 左) { 结果 = 字符串拼接(结果, 填充字符) i = i + 1 }
    结果 = 字符串拼接(结果, 文本)
    i = 0
    当 (i < 右) { 结果 = 字符串拼接(结果, 填充字符) i = i + 1 }
    返回 结果
}

// 零填充
函数 格式_零填充(n, 宽度) {
    定义 文本 = 格式_整数(n)
    定义 可变 负 = 假
    定义 可变 数字 = 文本
    如果 (计数(文本) > 0 且 字符串等于(子串(文本, 0, 1), "-")) {
        负 = 真
        数字 = 子串(文本, 1, 计数(文本) - 1)
    }
    当 (计数(数字) < 宽度) { 数字 = 字符串拼接("0", 数字) }
    如果 (负) { 返回 字符串拼接("-", 数字) }
    返回 数字
}

// 模板格式化
// 支持 {0}, {1}, ... 位置参数

函数 格式化_解析占位符(模板, i, n, 参数列表) { 定义 可变 位 = i
    // 提取: 解析{index:format}占位符，返回[替换文本, 新位置]
    位 = 位 + 1
    如果 (位 < n 且 字符串等于(子串(模板, 位, 1), "{")) {
        返回 ["{", 位 + 1]
    }
    定义 可变 索引文本 = ""
    定义 可变 格式说明 = ""
    定义 可变 有格式 = 假
    当 (位 < n 且 字符串等于(子串(模板, 位, 1), "}") == 假) {
        如果 (字符串等于(子串(模板, 位, 1), ":")) {
            有格式 = 真
            位 = 位 + 1
            当 (位 < n 且 字符串等于(子串(模板, 位, 1), "}") == 假) {
                格式说明 = 字符串拼接(格式说明, 子串(模板, 位, 1))
                位 = 位 + 1
            }
        } 否则 {
            索引文本 = 字符串拼接(索引文本, 子串(模板, 位, 1))
            位 = 位 + 1
        }
    }
    如果 (位 < n) { 位 = 位 + 1 }
    定义 可变 索引 = 0
    如果 (计数(索引文本) > 0) {
        定义 可变 j = 0
        当 (j < 计数(索引文本)) {
            定义 c = 编码(子串(索引文本, j, 1))
            如果 (c >= 字符_零 且 c <= 字符_九) { 索引 = 索引 * 10 + (c - 48) }
            j = j + 1
        }
    }
    定义 可变 值文本 = ""
    如果 (索引 < 计数(参数列表)) { 值文本 = 格式_整数(参数列表[索引]) }
    如果 (有格式 且 计数(格式说明) > 0) { 值文本 = 格式_应用说明(值文本, 格式说明) }
    返回 [值文本, 位]
}

函数 格式化(模板, 参数列表) {
    定义 n = 计数(模板)
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < n) {
        如果 (字符串等于(子串(模板, i, 1), "{")) {
            定义 占位结果 = 格式化_解析占位符(模板, i, n, 参数列表)
            结果 = 字符串拼接(结果, 占位结果[0])
            i = 占位结果[1]
        } 否则 如果 (字符串等于(子串(模板, i, 1), "}") 且 i + 1 < n 且 字符串等于(子串(模板, i + 1, 1), "}")) {
            结果 = 字符串拼接(结果, "}")
            i = i + 2
        } 否则 {
            结果 = 字符串拼接(结果, 子串(模板, i, 1))
            i = i + 1
        }
    }
    返回 结果
}

函数 格式_应用说明(值, 说明) { 定义 可变 v = 值
    定义 n = 计数(说明)
    如果 (n == 0) { 返回 v }
    // 解析: [填充][对齐][宽度][.精度][类型]
    定义 可变 填充 = " "
    定义 可变 对齐 = ">"
    定义 可变 宽度 = 0
    定义 可变 i = 0
    // 对齐符号
    如果 (n > 1) {
        定义 第二 = 子串(说明, 1, 1)
        如果 (字符串等于(第二, "<") 或 字符串等于(第二, ">") 或 字符串等于(第二, "^")) {
            填充 = 子串(说明, 0, 1)
            对齐 = 第二
            i = 2
        } 否则 如果 (字符串等于(子串(说明, 0, 1), "<") 或 字符串等于(子串(说明, 0, 1), ">") 或 字符串等于(子串(说明, 0, 1), "^")) {
            对齐 = 子串(说明, 0, 1)
            i = 1
        }
    } 否则 如果 (字符串等于(子串(说明, 0, 1), "<") 或 字符串等于(子串(说明, 0, 1), ">") 或 字符串等于(子串(说明, 0, 1), "^")) {
        对齐 = 子串(说明, 0, 1)
        i = 1
    }
    // 宽度
    定义 可变 _宽度完 = 假
    当 (i < n 且 _宽度完 == 假) {
        定义 c = 编码(子串(说明, i, 1))
        如果 (c >= 字符_零 且 c <= 字符_九) { 宽度 = 宽度 * 10 + (c - 48) i = i + 1 }
        否则 { _宽度完 = 真 }
    }
    // 类型标记
    如果 (i < n) {
        定义 类型 = 子串(说明, i, 1)
        如果 (字符串等于(类型, "x")) { v = 格式_十六进制(格式_文到数(v), 假) }
        否则 如果 (字符串等于(类型, "X")) { v = 格式_十六进制(格式_文到数(v), 真) }
        否则 如果 (字符串等于(类型, "b")) { v = 格式_二进制(格式_文到数(v)) }
        否则 如果 (字符串等于(类型, "o")) { v = 格式_八进制(格式_文到数(v)) }
    }
    // 应用对齐
    如果 (宽度 > 0) {
        如果 (字符串等于(对齐, "<")) { v = 格式_左对齐(v, 宽度, 填充) }
        否则 如果 (字符串等于(对齐, ">")) { v = 格式_右对齐(v, 宽度, 填充) }
        否则 如果 (字符串等于(对齐, "^")) { v = 格式_居中(v, 宽度, 填充) }
    }
    返回 v
}

// 表格格式化

函数 格式_表格(表头, 行列表, 列宽列表) {
    定义 列数 = 计数(表头)
    定义 可变 结果 = ""
    // 自动列宽
    定义 可变 宽度 = []
    定义 可变 c = 0
    当 (c < 列数) {
        定义 可变 最大 = 计数(表头[c])
        如果 (c < 计数(列宽列表) 且 列宽列表[c] > 最大) { 最大 = 列宽列表[c] }
        定义 可变 r = 0
        当 (r < 计数(行列表)) {
            如果 (c < 计数(行列表[r])) {
                定义 文本 = 格式_整数(行列表[r][c])
                如果 (计数(文本) > 最大) { 最大 = 计数(文本) }
            }
            r = r + 1
        }
        追加(宽度, 最大 + 2)
        c = c + 1
    }
    // 表头
    定义 可变 分隔线 = "+"
    c = 0
    当 (c < 列数) {
        定义 可变 dash = ""
        定义 可变 d = 0
        当 (d < 宽度[c]) { dash = 字符串拼接(dash, "-") d = d + 1 }
        分隔线 = 字符串拼接(分隔线, dash)
        分隔线 = 字符串拼接(分隔线, "+")
        c = c + 1
    }
    结果 = 字符串拼接(结果, 分隔线)
    结果 = 字符串拼接(结果, "\n|")
    c = 0
    当 (c < 列数) {
        结果 = 字符串拼接(结果, 格式_居中(表头[c], 宽度[c], " "))
        结果 = 字符串拼接(结果, "|")
        c = c + 1
    }
    结果 = 字符串拼接(结果, "\n")
    结果 = 字符串拼接(结果, 分隔线)
    结果 = 字符串拼接(结果, "\n")
    // 数据行
    定义 可变 r = 0
    当 (r < 计数(行列表)) {
        结果 = 字符串拼接(结果, "|")
        c = 0
        当 (c < 列数) {
            定义 可变 单元格 = ""
            如果 (c < 计数(行列表[r])) {
                单元格 = 格式_整数(行列表[r][c])
            }
            结果 = 字符串拼接(结果, 格式_左对齐(字符串拼接(" ", 单元格), 宽度[c], " "))
            结果 = 字符串拼接(结果, "|")
            c = c + 1
        }
        结果 = 字符串拼接(结果, "\n")
        r = r + 1
    }
    结果 = 字符串拼接(结果, 分隔线)
    返回 结果
}

// 内部工具
函数 格式_文到数(s) {
    定义 n = 计数(s)
    定义 可变 结果 = 0
    定义 可变 负 = 假
    定义 可变 i = 0
    如果 (n > 0 且 字符串等于(子串(s, 0, 1), "-")) { 负 = 真 i = 1 }
    当 (i < n) {
        定义 c = 编码(子串(s, i, 1))
        如果 (c >= 字符_零 且 c <= 字符_九) { 结果 = 结果 * 10 + (c - 48) }
        i = i + 1
    }
    如果 (负) { 结果 = 0 - 结果 }
    返回 结果
}

// 合并自 标准库/系统/格式化.nova

函数 csv_生成(表头, 数据) {
    定义 可变 结果 = csv_行(表头)
    结果 = 字符串拼接(结果, "\n")
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        结果 = 字符串拼接(结果, csv_行(数据[i]))
        结果 = 字符串拼接(结果, "\n")
        i = i + 1
    }
    返回 结果
}

函数 csv_行(列表) {
    定义 n = 计数(列表)
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < n) {
        如果 (i > 0) { 结果 = 字符串拼接(结果, ",") }
        结果 = 字符串拼接(结果, 转字符串(列表[i]))
        i = i + 1
    }
    返回 结果
}

函数 json_列表(列表) {
    定义 n = 计数(列表)
    如果 (n == 0) { 返回 "[]" }
    定义 可变 结果 = "["
    定义 可变 i = 0
    当 (i < n) {
        如果 (i > 0) { 结果 = 字符串拼接(结果, ", ") }
        结果 = 字符串拼接(结果, 转字符串(列表[i]))
        i = i + 1
    }
    结果 = 字符串拼接(结果, "]")
    返回 结果
}

函数 json_字符串(文本) {
    定义 可变 结果 = "\""
    定义 n = 计数(文本)
    定义 可变 i = 0
    当 (i < n) {
        定义 c = 子串(文本, i, 1)
        定义 码 = 编码(c)
        如果 (码 == 字符_双引号) {
            结果 = 字符串拼接(结果, "\\\"")
        } 否则 如果 (码 == 字符_反斜杠) {
            结果 = 字符串拼接(结果, "\\\\")
        } 否则 如果 (码 == 字符_换行) {
            结果 = 字符串拼接(结果, "\\n")
        } 否则 如果 (码 == 字符_制表) {
            结果 = 字符串拼接(结果, "\\t")
        } 否则 {
            结果 = 字符串拼接(结果, c)
        }
        i = i + 1
    }
    结果 = 字符串拼接(结果, "\"")
    返回 结果
}

函数 json_布尔(值) {
    如果 (值) { 返回 "真" }
    返回 "假"
}

函数 json_整数(值) {
    返回 转字符串(值)
}

函数 字节格式化(字节数) {
    如果 (字节数 < 1024) {
        返回 字符串拼接(转字符串(字节数), " B")
    }
    如果 (字节数 < 1048576) {
        返回 字符串拼接(转字符串(字节数 / 1024), " KB")
    }
    如果 (字节数 < 1073741824) {
        返回 字符串拼接(转字符串(字节数 / 1048576), " MB")
    }
    返回 字符串拼接(转字符串(字节数 / 1073741824), " GB")
}

函数 日志_信息(消息) {
    打印文本(字符串拼接("[INFO] ", 消息))
}

函数 日志_警告(消息) {
    打印文本(字符串拼接("[WARN] ", 消息))
}

函数 日志_调试(消息) {
    打印文本(字符串拼接("[DEBUG] ", 消息))
}

函数 日志_错误(消息) {
    打印文本(字符串拼接("[ERROR] ", 消息))
}

函数 时间戳_格式化(秒数) {
    定义 小时 = 秒数 / 3600
    定义 分钟 = (秒数 % 3600) / 60
    定义 秒 = 秒数 % 60
    定义 可变 结果 = ""
    如果 (小时 < 10) { 结果 = 字符串拼接(结果, "0") }
    结果 = 字符串拼接(结果, 转字符串(小时))
    结果 = 字符串拼接(结果, ":")
    如果 (分钟 < 10) { 结果 = 字符串拼接(结果, "0") }
    结果 = 字符串拼接(结果, 转字符串(分钟))
    结果 = 字符串拼接(结果, ":")
    如果 (秒 < 10) { 结果 = 字符串拼接(结果, "0") }
    结果 = 字符串拼接(结果, 转字符串(秒))
    返回 结果
}

函数 表格输出(表头, 数据) {
    定义 列数 = 计数(表头)
    // 计算每列最大宽度
    定义 可变 宽度 = []
    定义 可变 i = 0
    当 (i < 列数) {
        追加(宽度, 计数(表头[i]))
        i = i + 1
    }
    // 检查数据宽度
    i = 0
    当 (i < 计数(数据)) {
        定义 行 = 数据[i]
        定义 可变 j = 0
        当 (j < 列数 且 j < 计数(行)) {
            定义 w = 计数(转字符串(行[j]))
            如果 (w > 宽度[j]) { 宽度[j] = w }
            j = j + 1
        }
        i = i + 1
    }
    // 输出表头
    定义 可变 头行 = "| "
    i = 0
    当 (i < 列数) {
        头行 = 字符串拼接(头行, 表头[i])
        // 填充空格
        定义 可变 p = 计数(表头[i])
        当 (p < 宽度[i]) {
            头行 = 字符串拼接(头行, " ")
            p = p + 1
        }
        头行 = 字符串拼接(头行, " | ")
        i = i + 1
    }
    打印文本(头行)
    // 输出分隔线
    定义 可变 分隔 = "|-"
    i = 0
    当 (i < 列数) {
        定义 可变 d = 0
        当 (d < 宽度[i]) {
            分隔 = 字符串拼接(分隔, "-")
            d = d + 1
        }
        分隔 = 字符串拼接(分隔, "-|-")
        i = i + 1
    }
    打印文本(分隔)
    // 输出数据行
    i = 0
    当 (i < 计数(数据)) {
        定义 行 = 数据[i]
        定义 可变 行文本 = "| "
        定义 可变 j = 0
        当 (j < 列数) {
            定义 可变 值文本 = ""
            如果 (j < 计数(行)) { 值文本 = 转字符串(行[j]) }
            行文本 = 字符串拼接(行文本, 值文本)
            定义 可变 p2 = 计数(值文本)
            当 (p2 < 宽度[j]) {
                行文本 = 字符串拼接(行文本, " ")
                p2 = p2 + 1
            }
            行文本 = 字符串拼接(行文本, " | ")
            j = j + 1
        }
        打印文本(行文本)
        i = i + 1
    }
}

函数 进度条(当前, 总数, 宽度) {
    定义 完成 = 当前 * 宽度 / 总数
    定义 百分比 = 当前 * 100 / 总数
    定义 可变 条 = "["
    定义 可变 i = 0
    当 (i < 宽度) {
        如果 (i < 完成) {
            条 = 字符串拼接(条, "#")
        } 否则 {
            条 = 字符串拼接(条, "-")
        }
        i = i + 1
    }
    条 = 字符串拼接(条, "] ")
    条 = 字符串拼接(条, 转字符串(百分比))
    条 = 字符串拼接(条, "%")
    返回 条
}

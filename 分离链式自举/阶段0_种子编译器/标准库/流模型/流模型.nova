导入("../基础.nova")


// 仿射耦合层 (RealNVP)
// x1, x2 = split(x)
// y1 = x1
// y2 = x2 * exp(s(x1)) + t(x1)
// log_det = Σ s(x1)
函数 仿射耦合_前向(x, s_权重, t_权重, 分割点) {
    定义 d = 计数(x)
    定义 可变 y = []
    定义 可变 log_det = 0
    // x1 = x[:分割点], x2 = x[分割点:]
    定义 可变 i = 0
    当 (i < 分割点) { 追加(y, x[i])
    i = i + 1 }
    // 计算s和t (简单线性)
    i = 分割点
    当 (i < d) {
        定义 索引 = i - 分割点
        定义 可变 s_val = 0
        定义 可变 t_val = 0
        定义 可变 j = 0
        当 (j < 分割点) {
            如果 (索引 * 分割点 + j < 计数(s_权重)) {
                s_val = s_val + s_权重[索引 * 分割点 + j] * x[j] / 1000
            }
            如果 (索引 * 分割点 + j < 计数(t_权重)) {
                t_val = t_val + t_权重[索引 * 分割点 + j] * x[j] / 1000
            }
            j = j + 1
        }
        // 限制s的范围防止数值问题
        如果 (s_val > 3000) { s_val = 3000 }
        如果 (s_val < -3000) { s_val = -3000 }
        // y2 = x2 * exp(s) + t
        定义 可变 exp_s = 1000 + s_val  // exp近似
        如果 (exp_s < 1) { exp_s = 1 }
        定义 y_val = x[i] * exp_s / 1000 + t_val
        追加(y, y_val)
        log_det = log_det + s_val
        i = i + 1
    }
    返回 [y, log_det]
}

函数 仿射耦合_逆向(y, s_权重, t_权重, 分割点) {
    定义 d = 计数(y)
    定义 可变 x = []
    // y1 = x1
    定义 可变 i = 0
    当 (i < 分割点) { 追加(x, y[i])
    i = i + 1 }
    // x2 = (y2 - t) * exp(-s)
    i = 分割点
    当 (i < d) {
        定义 索引 = i - 分割点
        定义 可变 s_val = 0
        定义 可变 t_val = 0
        定义 可变 j = 0
        当 (j < 分割点) {
            如果 (索引 * 分割点 + j < 计数(s_权重)) {
                s_val = s_val + s_权重[索引 * 分割点 + j] * y[j] / 1000
            }
            如果 (索引 * 分割点 + j < 计数(t_权重)) {
                t_val = t_val + t_权重[索引 * 分割点 + j] * y[j] / 1000
            }
            j = j + 1
        }
        定义 可变 exp_neg_s = 1000 - s_val
        如果 (exp_neg_s < 1) { exp_neg_s = 1 }
        定义 x_val = (y[i] - t_val) * 1000 / exp_neg_s
        追加(x, x_val)
        i = i + 1
    }
    返回 x
}

// 1x1可逆卷积 (Glow)
函数 可逆1x1_前向(x, W, 维度) {
    // y = W·x
    定义 可变 y = []
    定义 可变 i = 0
    当 (i < 维度) {
        定义 可变 数值 = 0
        定义 可变 j = 0
        当 (j < 维度) {
            如果 (i * 维度 + j < 计数(W)) {
                数值 = 数值 + W[i * 维度 + j] * x[j] / 1000
            }
            j = j + 1
        }
        追加(y, 数值)
        i = i + 1
    }
    返回 y
}

// ActNorm (Glow)
函数 ActNorm_前向(x, scale, 偏置) {
    定义 d = 计数(x)
    定义 可变 y = []
    定义 可变 log_det = 0
    定义 可变 i = 0
    当 (i < d) {
        定义 可变 s = 1000
        定义 可变 b = 0
        如果 (i < 计数(scale)) { s = scale[i] }
        如果 (i < 计数(偏置)) { b = 偏置[i] }
        追加(y, s * x[i] / 1000 + b)
        log_det = log_det + s  // log|s|近似
        i = i + 1
    }
    返回 [y, log_det]
}

// 流匹配 (Flow Matching)
// ODE: dx/dt = v_θ(x, t)
// 训练: L = ||v_θ(x_t, t) - u_t(x_t|x_1)||²
函数 流匹配_插值(x_0, x_1, t) {
    定义 可变 x_t = []
    // x_t = (1-t)·x_0 + t·x_1
    定义 d = 计数(x_0)
    定义 可变 i = 0
    当 (i < d) {
        定义 可变 x1v = 0
        如果 (i < 计数(x_1)) { x1v = x_1[i] }
        定义 数值 = (1000 - t) * x_0[i] / 1000 + t * x1v / 1000
        追加(x_t, 数值)
        i = i + 1
    }
    返回 x_t
}

函数 流匹配_目标向量(x_0, x_1) {
    // u_t = x_1 - x_0 (条件向量场)
    定义 d = 计数(x_0)
    定义 可变 u = []
    定义 可变 i = 0
    当 (i < d) {
        定义 可变 x1v = 0
        如果 (i < 计数(x_1)) { x1v = x_1[i] }
        追加(u, x1v - x_0[i])
        i = i + 1
    }
    返回 u
}

函数 流匹配_损失(预测速度, 目标速度) {
    定义 d = 计数(预测速度)
    定义 可变 损失值 = 0
    定义 可变 i = 0
    当 (i < d) {
        定义 可变 tv = 0
        如果 (i < 计数(目标速度)) { tv = 目标速度[i] }
        定义 差值 = 预测速度[i] - tv
        损失值 = 损失值 + 差值 * 差值 / 1000
        i = i + 1
    }
    如果 (d == 0) { 返回 0 }
    返回 损失值 / d
}

// Euler ODE求解器
函数 ODE_Euler步(x, 速度场, dt) {
    定义 d = 计数(x)
    定义 可变 x_next = []
    定义 可变 i = 0
    当 (i < d) {
        定义 可变 v = 0
        如果 (i < 计数(速度场)) { v = 速度场[i] }
        追加(x_next, x[i] + dt * v / 1000)
        i = i + 1
    }
    返回 x_next
}

函数 ODE_采样(初始噪声, 速度场列表, 步数) {
    定义 可变 x = 初始噪声
    定义 dt = 1000 / 步数
    定义 可变 t = 0
    当 (t < 步数) {
        如果 (t < 计数(速度场列表)) {
            x = ODE_Euler步(x, 速度场列表[t], dt)
        }
        t = t + 1
    }
    返回 x
}

// 最优传输 (Sinkhorn)
函数 Sinkhorn_距离(分布a, 分布b, 成本矩阵, 迭代数, ε) {
    如果 (ε <= 0) { ε = 100 }
    定义 n = 计数(分布a)
    定义 m = 计数(分布b)
    // 初始化u, v
    定义 可变 u = []
    定义 可变 v = []
    定义 可变 i = 0
    当 (i < n) { 追加(u, 1000)
    i = i + 1 }
    i = 0
    当 (i < m) { 追加(v, 1000)
    i = i + 1 }
    // Sinkhorn迭代
    定义 可变 迭代 = 0
    当 (迭代 < 迭代数) {
        // 更新u
        i = 0
        当 (i < n) {
            定义 可变 和 = 0
            定义 可变 j = 0
            当 (j < m) {
                定义 可变 K = 0
                如果 (i * m + j < 计数(成本矩阵)) {
                    K = 1000 - 成本矩阵[i * m + j] * 1000 / ε  // exp(-C/ε)近似
                    如果 (K < 1) { K = 1 }
                }
                和 = 和 + K * v[j] / 1000
                j = j + 1
            }
            如果 (和 == 0) { 和 = 1 }
            u[i] = 分布a[i] * 1000 / 和
            i = i + 1
        }
        // 更新v
        定义 可变 j = 0
        当 (j < m) {
            定义 可变 和 = 0
            i = 0
            当 (i < n) {
                定义 可变 K = 0
                如果 (i * m + j < 计数(成本矩阵)) {
                    K = 1000 - 成本矩阵[i * m + j] * 1000 / ε
                    如果 (K < 1) { K = 1 }
                }
                和 = 和 + K * u[i] / 1000
                i = i + 1
            }
            如果 (和 == 0) { 和 = 1 }
            v[j] = 分布b[j] * 1000 / 和
            j = j + 1
        }
        迭代 = 迭代 + 1
    }
    // 计算传输距离
    定义 可变 距离 = 0
    i = 0
    当 (i < n) {
        定义 可变 j = 0
        当 (j < m) {
            如果 (i * m + j < 计数(成本矩阵)) {
                定义 可变 K = 1000 - 成本矩阵[i * m + j] * 1000 / ε
                如果 (K < 1) { K = 1 }
                距离 = 距离 + u[i] * K * v[j] / 1000 * 成本矩阵[i * m + j] / 1000
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 距离
}

// 对数概率计算
函数 流_对数概率(log_det_总, 基础log_prob) {
    // log p(x) = log p(z) + Σ log|det(df/dz)|
    返回 基础log_prob + log_det_总
}

// 高斯基础分布
函数 高斯_log_prob(z) {
    定义 d = 计数(z)
    定义 可变 lp = 0
    定义 可变 i = 0
    当 (i < d) {
        lp = lp - z[i] * z[i] / 2000  // -z²/2
        i = i + 1
    }
    返回 lp
}

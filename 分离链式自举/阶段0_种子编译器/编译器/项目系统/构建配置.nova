// Nova · 项目系统 · 构建配置
// 管理profile与构建参数的统一配置层

// 构建配置结构
// 配置 = [
//   0: profile名(字符串)
//   1: 目标平台(字符串) x86-64|arm64|riscv64|wasm
//   2: 运行时类型(字符串) hosted|baremetal
//   3: 输出格式(字符串) elf|kernel-elf|multiboot2|disk
//   4: 调试合同(字符串) none|line|symbol|full
//   5: 优化等级(整数) 0|1|2
//   6: 语义严格度(整数) 0=跳过 1=基础 2=标准 3=严格
//   7: 安全分析(整数) 0=关闭 1=报告 2=严格
//   8: 形式化验证(整数) 0=关闭 1=关键模块 2=全量
//   9: JIT门控(整数) 0=关闭 1=白名单 2=标准 3=最大化
//   10: 热更允许(整数) 0=禁止 1=白名单 2=全量
//   11: 链接布局(字符串) 布局文件路径或空
// ]

导入("../../运行时/字典引擎/字典引擎.nova")

函数 构建配置_创建(profile名) {
    返回 [
        profile名,     // 0: profile
        "x86-64",      // 1: 目标
        "hosted",      // 2: 运行时
        "elf",         // 3: 输出格式
        "line",        // 4: 调试
        1,             // 5: 优化
        0,             // 6: 语义严格度
        0,             // 7: 安全
        0,             // 8: 验证
        2,             // 9: JIT
        0,             // 10: 热更
        ""             // 11: 链接布局
    ]
}

// 从profile名生成默认配置
函数 构建配置_从Profile(profile名) {
    定义 配置 = 构建配置_创建(profile名)
    如果 (字符串相等(profile名, "analysis-host")) {
        配置[2] = "hosted"
        配置[3] = "none"
        配置[4] = "full"
        配置[5] = 0
        配置[6] = 3
        配置[7] = 1
        配置[8] = 1
        配置[9] = 3
        配置[10] = 0
    }
    如果 (字符串相等(profile名, "linux-user")) {
        配置[2] = "hosted"
        配置[3] = "elf"
        配置[4] = "symbol"
        配置[5] = 1
        配置[6] = 2
        配置[7] = 0
        配置[8] = 0
        配置[9] = 2
        配置[10] = 1
    }
    如果 (字符串相等(profile名, "kernel-qemu")) {
        配置[2] = "baremetal"
        配置[3] = "kernel-elf"
        配置[4] = "symbol"
        配置[5] = 1
        配置[6] = 0
        配置[7] = 0
        配置[8] = 0
        配置[9] = 1
        配置[10] = 1
    }
    如果 (字符串相等(profile名, "kernel-physical")) {
        配置[2] = "baremetal"
        配置[3] = "disk"
        配置[4] = "line"
        配置[5] = 2
        配置[6] = 3
        配置[7] = 2
        配置[8] = 2
        配置[9] = 0
        配置[10] = 1
    }
    返回 配置
}

// 访问器
函数 构建配置_Profile(配置) { 返回 配置[0] }
函数 构建配置_目标(配置) { 返回 配置[1] }
函数 构建配置_运行时(配置) { 返回 配置[2] }
函数 构建配置_输出格式(配置) { 返回 配置[3] }
函数 构建配置_调试合同(配置) { 返回 配置[4] }
函数 构建配置_优化等级(配置) { 返回 配置[5] }
函数 构建配置_语义严格度(配置) { 返回 配置[6] }
函数 构建配置_是裸机(配置) { 返回 字符串相等(配置[2], "baremetal") }
函数 构建配置_是分析模式(配置) { 返回 字符串相等(配置[0], "analysis-host") }

// 设置器
函数 构建配置_设目标(配置, 目标) { 配置[1] = 目标 }
函数 构建配置_设运行时(配置, 运行时) { 配置[2] = 运行时 }
函数 构建配置_设输出格式(配置, 格式) { 配置[3] = 格式 }
函数 构建配置_设优化等级(配置, 等级) { 配置[5] = 等级 }
函数 构建配置_设链接布局(配置, 路径) { 配置[11] = 路径 }

// 验证配置合法性, 返回错误列表(空=通过)
函数 构建配置_验证(配置) {
    定义 可变 错误 = []
    // 目标平台检查
    定义 目标 = 配置[1]
    如果 (字符串相等(目标, "x86-64") == 假
        且 字符串相等(目标, "arm64") == 假
        且 字符串相等(目标, "riscv64") == 假
        且 字符串相等(目标, "wasm") == 假) {
        追加(错误, "无效目标平台: " + 目标)
    }
    // 运行时类型检查
    定义 运行时 = 配置[2]
    如果 (字符串相等(运行时, "hosted") == 假 且 字符串相等(运行时, "baremetal") == 假) {
        追加(错误, "无效运行时: " + 运行时)
    }
    // 输出格式检查
    定义 格式 = 配置[3]
    如果 (字符串相等(格式, "elf") == 假 且 字符串相等(格式, "kernel-elf") == 假
        且 字符串相等(格式, "multiboot2") == 假 且 字符串相等(格式, "disk") == 假
        且 字符串相等(格式, "none") == 假) {
        追加(错误, "无效输出格式: " + 格式)
    }
    // 优化等级范围
    如果 (配置[5] < 0 或 配置[5] > 2) { 追加(错误, "优化等级超范围: " + 转字符串(配置[5])) }
    // 裸机与输出格式兼容性
    如果 (字符串相等(运行时, "baremetal") 且 字符串相等(格式, "elf")) {
        追加(错误, "裸机模式不应使用普通elf, 用kernel-elf或disk")
    }
    // JIT与裸机冲突
    如果 (字符串相等(运行时, "baremetal") 且 配置[9] > 1) {
        追加(错误, "裸机模式JIT门控不应超过1(白名单)")
    }
    返回 错误
}

// 合并两个配置: 覆盖方覆盖基础方的非默认值
函数 构建配置_合并(基础, 覆盖) {
    定义 结果 = 构建配置_创建(覆盖[0])
    结果[1] = 覆盖[1]
    结果[2] = 覆盖[2]
    如果 (字符串相等(覆盖[3], "elf") == 假 或 字符串相等(基础[3], "elf") == 假) {
        结果[3] = 覆盖[3]
    } 否则 { 结果[3] = 基础[3] }
    如果 (字符串相等(覆盖[4], "line") == 假) { 结果[4] = 覆盖[4] }
    否则 { 结果[4] = 基础[4] }
    如果 (覆盖[5] != 1) { 结果[5] = 覆盖[5] } 否则 { 结果[5] = 基础[5] }
    定义 可变 i = 6
    当 (i <= 10) {
        如果 (覆盖[i] != 0) { 结果[i] = 覆盖[i] } 否则 { 结果[i] = 基础[i] }
        i = i + 1
    }
    如果 (字节长度(覆盖[11]) > 0) { 结果[11] = 覆盖[11] }
    否则 { 结果[11] = 基础[11] }
    返回 结果
}

// 从命令行参数列表解析配置覆盖
函数 构建配置_从参数(参数列表) {
    定义 配置 = 构建配置_创建("cli")
    定义 可变 i = 0
    当 (i < 计数(参数列表)) {
        定义 参数 = 参数列表[i]
        如果 (字符串相等(参数, "--target") 且 i + 1 < 计数(参数列表)) {
            配置[1] = 参数列表[i + 1]
            i = i + 2
            继续
        }
        如果 (字符串相等(参数, "--runtime") 且 i + 1 < 计数(参数列表)) {
            配置[2] = 参数列表[i + 1]
            i = i + 2
            继续
        }
        如果 (字符串相等(参数, "--format") 且 i + 1 < 计数(参数列表)) {
            配置[3] = 参数列表[i + 1]
            i = i + 2
            继续
        }
        如果 (字符串相等(参数, "--debug") 且 i + 1 < 计数(参数列表)) {
            配置[4] = 参数列表[i + 1]
            i = i + 2
            继续
        }
        如果 (字符串相等(参数, "-O0")) { 配置[5] = 0 }
        如果 (字符串相等(参数, "-O1")) { 配置[5] = 1 }
        如果 (字符串相等(参数, "-O2")) { 配置[5] = 2 }
        如果 (字符串相等(参数, "--strict")) { 配置[6] = 3 }
        如果 (字符串相等(参数, "--baremetal")) { 配置[2] = "baremetal" }
        如果 (字符串相等(参数, "--layout") 且 i + 1 < 计数(参数列表)) {
            配置[11] = 参数列表[i + 1]
            i = i + 2
            继续
        }
        i = i + 1
    }
    返回 配置
}

// 配置序列化为键值对列表
函数 构建配置_序列化(配置) {
    定义 可变 结果 = 字典()
    字典设(结果, "profile", 配置[0])
    字典设(结果, "target", 配置[1])
    字典设(结果, "runtime", 配置[2])
    字典设(结果, "format", 配置[3])
    字典设(结果, "debug", 配置[4])
    字典设(结果, "opt_level", 转字符串(配置[5]))
    字典设(结果, "semantic_strict", 转字符串(配置[6]))
    字典设(结果, "safety", 转字符串(配置[7]))
    字典设(结果, "verify", 转字符串(配置[8]))
    字典设(结果, "jit", 转字符串(配置[9]))
    字典设(结果, "hot_reload", 转字符串(配置[10]))
    如果 (字节长度(配置[11]) > 0) { 字典设(结果, "layout", 配置[11]) }
    返回 结果
}

// 打印配置
函数 构建配置_打印(配置) {
    打印("构建配置:")
    打印("  profile: " + 配置[0])
    打印("  目标: " + 配置[1])
    打印("  运行时: " + 配置[2])
    打印("  输出格式: " + 配置[3])
    打印("  调试: " + 配置[4])
    打印("  优化等级: " + 转字符串(配置[5]))
    打印("  语义严格度: " + 转字符串(配置[6]))
    打印("  安全分析: " + 转字符串(配置[7]))
    如果 (字节长度(配置[11]) > 0) { 打印("  链接布局: " + 配置[11]) }
}

导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/内存初始化.nova")

定义 最大端口 = 32
定义 最大命令槽 = 32

结构 磁控端口 {
    端口号,
    基地址,
    已连接,
    设备类型,
    命令表,
    命令槽数,
    活跃命令,
    读扇区数,
    写扇区数,
    错误数,
    总命令数,
}

定义 可变 控制器基址 = 0
定义 可变 端口表 = []
定义 可变 端口数 = 0
定义 可变 总读扇区 = 0
定义 可变 总写扇区 = 0
定义 可变 总错误 = 0
定义 可变 总命令 = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 磁控_初始化(基址) {
    控制器基址 = 基址
    端口表 = []
    端口数 = 0
    定义 端口实现 = 内存_读32(基址 + 0x0C)
    定义 可变 位 = 0
    当 (位 < 最大端口) {
        如果 ((端口实现 & (1 << 位)) != 0) {
            定义 端口基 = 基址 + 0x100 + 位 * 0x80
            定义 端口 = 磁控端口 {}
            端口.端口号 = 位
            端口.基地址 = 端口基
            定义 状态 = 内存_读32(端口基 + 0x28)
            端口.已连接 = ((状态 & 0xF) == 3)
            端口.设备类型 = (状态 >> 4) & 0xF
            端口.命令表 = 堆_分配(最大命令槽 * 32)
            端口.命令槽数 = 最大命令槽
            端口.活跃命令 = 0
            端口.读扇区数 = 0
            端口.写扇区数 = 0
            端口.错误数 = 0
            端口.总命令数 = 0
            追加(端口表, 端口)
            端口数 = 端口数 + 1
        }
        位 = 位 + 1
    }
}

函数 磁控_读扇区(端口索引, 起始扇区, 扇区数, 缓冲) {
    如果 (端口索引 >= 端口数) { 返回 错误_无效参数 }
    定义 端口 = 端口表[端口索引]
    如果 (!端口.已连接) { 返回 错误_设备离线 }
    定义 槽 = 磁控_分配命令槽(端口)
    如果 (槽 < 0) { 返回 错误_无资源 }
    磁控_构建读命令(端口, 槽, 起始扇区, 扇区数, 缓冲)
    磁控_发射命令(端口, 槽)
    定义 结果 = 磁控_等待完成(端口, 槽)
    磁控_释放命令槽(端口, 槽)
    如果 (结果 == 0) {
        端口.读扇区数 = 端口.读扇区数 + 扇区数
        总读扇区 = 总读扇区 + 扇区数
    } 否则 {
        端口.错误数 = 端口.错误数 + 1
        总错误 = 总错误 + 1
    }
    端口.总命令数 = 端口.总命令数 + 1
    总命令 = 总命令 + 1
    返回 结果
}

函数 磁控_写扇区(端口索引, 起始扇区, 扇区数, 缓冲) {
    如果 (端口索引 >= 端口数) { 返回 错误_无效参数 }
    定义 端口 = 端口表[端口索引]
    如果 (!端口.已连接) { 返回 错误_设备离线 }
    定义 槽 = 磁控_分配命令槽(端口)
    如果 (槽 < 0) { 返回 错误_无资源 }
    磁控_构建写命令(端口, 槽, 起始扇区, 扇区数, 缓冲)
    磁控_发射命令(端口, 槽)
    定义 结果 = 磁控_等待完成(端口, 槽)
    磁控_释放命令槽(端口, 槽)
    如果 (结果 == 0) {
        端口.写扇区数 = 端口.写扇区数 + 扇区数
        总写扇区 = 总写扇区 + 扇区数
    } 否则 {
        端口.错误数 = 端口.错误数 + 1
        总错误 = 总错误 + 1
    }
    端口.总命令数 = 端口.总命令数 + 1
    总命令 = 总命令 + 1
    返回 结果
}

函数 磁控_分配命令槽(端口) {
    定义 可变 槽 = 0
    当 (槽 < 端口.命令槽数) {
        如果 ((端口.活跃命令 & (1 << 槽)) == 0) {
            端口.活跃命令 = 端口.活跃命令 | (1 << 槽)
            返回 槽
        }
        槽 = 槽 + 1
    }
    返回 -1
}

函数 磁控_释放命令槽(端口, 槽) {
    端口.活跃命令 = 端口.活跃命令 & ~(1 << 槽)
}

函数 磁控_构建读命令(端口, 槽, 扇区, 数量, 缓冲) {
    定义 偏移 = 端口.命令表 + 槽 * 32
    内存_写8(偏移, 0x25)
    内存_写64(偏移 + 8, 扇区)
    内存_写32(偏移 + 16, 数量)
    内存_写64(偏移 + 20, 缓冲)
}

函数 磁控_构建写命令(端口, 槽, 扇区, 数量, 缓冲) {
    定义 偏移 = 端口.命令表 + 槽 * 32
    内存_写8(偏移, 0x35)
    内存_写64(偏移 + 8, 扇区)
    内存_写32(偏移 + 16, 数量)
    内存_写64(偏移 + 20, 缓冲)
}

函数 磁控_发射命令(端口, 槽) {
    内存_写32(端口.基地址 + 0x38, 1 << 槽)
}

函数 磁控_等待完成(端口, 槽) {
    定义 可变 等待 = 0
    当 (等待 < 1000000) {
        定义 已发射 = 内存_读32(端口.基地址 + 0x38)
        如果 ((已发射 & (1 << 槽)) == 0) { 返回 0 }
        定义 中断状态 = 内存_读32(端口.基地址 + 0x10)
        如果 ((中断状态 & (1 << 30)) != 0) { 返回 错误_设备错误 }
        等待 = 等待 + 1
    }
    返回 错误_超时
}

函数 磁控_获取端口数() { 返回 端口数 }

函数 磁控_获取端口信息(索引) {
    如果 (索引 >= 端口数) { 返回 [0, 0, 0, 0] }
    定义 端口 = 端口表[索引]
    返回 [端口.端口号, 端口.已连接, 端口.读扇区数, 端口.写扇区数]
}

函数 磁控_统计() {
    返回 [端口数, 总读扇区, 总写扇区, 总错误, 总命令]
}

定义 可变 AI_磁控统计_运行指标 = 0
定义 可变 AI_磁控统计_异常指标 = 0

函数 AI_磁控统计_自诊断() {
    AI_磁控统计_运行指标 = 0
    返回 AI_磁控统计_运行指标
}

函数 AI_磁控统计_优化建议() {
    定义 指标 = AI_磁控统计_自诊断()
    返回 "磁控统计状态正常"
}

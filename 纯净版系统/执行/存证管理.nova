// §3 Cookie管理

函数 浏览器存储_Cookie设置(名称, 值, 域, 路径, 过期, 安全, 仅HTTP) {
    // 查找已有Cookie
    定义 可变 i = 0
    当 (i < 计数(存储_Cookie表)) {
        如果 (存储_Cookie表[i].名称 == 名称 && 存储_Cookie表[i].域 == 域) {
            存储_Cookie表[i].值 = 值
            存储_Cookie表[i].过期时间 = 过期
            返回
        }
        i = i + 1
    }

    定义 cookie = Cookie条目 {}
    cookie.名称 = 名称
    cookie.值 = 值
    cookie.域 = 域
    cookie.路径 = 路径
    cookie.过期时间 = 过期
    cookie.安全 = 安全
    cookie.仅HTTP = 仅HTTP
    追加(存储_Cookie表, cookie)
}

函数 浏览器存储_Cookie获取(域, 路径) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(存储_Cookie表)) {
        定义 c = 存储_Cookie表[i]
        // 域匹配
        如果 (字符串查找(域, c.域) >= 0) {
            如果 (字符串查找(路径, c.路径) == 0) {
                追加(结果, c)
            }
        }
        i = i + 1
    }
    返回 结果
}

函数 浏览器存储_Cookie序列化(域, 路径) {
    定义 cookies = 浏览器存储_Cookie获取(域, 路径)
    定义 可变 串 = ""
    定义 可变 i = 0
    当 (i < 计数(cookies)) {
        如果 (i > 0) { 串 = 串 + "; " }
        串 = 串 + cookies[i].名称 + "=" + cookies[i].值
        i = i + 1
    }
    返回 串
}

// §4 Local存储 — 直连VFS持久化

函数 浏览器存储_本地设置(域, 键, 值) {
    定义 可变 i = 0
    当 (i < 计数(存储_本地数据)) {
        如果 (存储_本地数据[i].域 == 域 && 存储_本地数据[i].键 == 键) {
            存储_本地数据[i].值 = 值
            浏览器存储_本地持久化(域)
            返回
        }
        i = i + 1
    }

    定义 项 = 本地存储项 {}
    项.键 = 键
    项.值 = 值
    项.域 = 域
    追加(存储_本地数据, 项)
    浏览器存储_本地持久化(域)
}

函数 浏览器存储_本地获取(域, 键) {
    定义 可变 i = 0
    当 (i < 计数(存储_本地数据)) {
        如果 (存储_本地数据[i].域 == 域 && 存储_本地数据[i].键 == 键) {
            返回 存储_本地数据[i].值
        }
        i = i + 1
    }
    返回 空
}

函数 浏览器存储_本地持久化(域) {
    定义 文件 = 存储_数据目录 + "/ls_" + 域
    定义 fd = VFS_打开(文件, O_创建 | O_写入 | O_截断, 0644)
    如果 (fd < 0) { 返回 }

    定义 可变 i = 0
    当 (i < 计数(存储_本地数据)) {
        如果 (存储_本地数据[i].域 == 域) {
            定义 行 = 存储_本地数据[i].键 + "\t" + 存储_本地数据[i].值 + "\n"
            VFS_写入(fd, 行, 字符串长度(行))
        }
        i = i + 1
    }
    VFS_关闭(fd)
}

导入("../../标准库/基础.nova")

// Nova 原生可变性检查器 — 追踪变量是否可以被修改，防止意外赋値
// 职责：可变性记录、赋値合法性检查、多次赋値警告、不必要可变建议
// 层级：第3层语义分析

// 可变性状态
定义 性_不可变 = 0
定义 性_可变   = 1
定义 性_常量   = 2

// 检查结果
定义 检_通过       = 0
定义 检_赋不可变   = 1   // 赋値给不可变变量
定义 检_赋常量     = 2   // 赋値给常量
定义 检_改参数     = 3   // 修改不可变参数
定义 检_改字段     = 4   // 修改不可变字段
定义 检_未初始化   = 5   // 未初始化使用

// 变量可变性记录: [名称ID, 可变性, 已初始化, 赋值次数]
函数 可变记录(名称ID, 可变性) {
    返回 [名称ID, 可变性,]
}

函数 记录_可变性(r) { 返回 r[1] }
函数 记录_已初始化(r) { 返回 r[2] }
函数 记录_赋值次数(r) { 返回 r[3] }

函数 记录_初始化(r) {
    r[2] = 1
    r[3] = r[3] + 1
}

函数 可变性检_记录_赋值(r) {
    r[3] = r[3] + 1
}

// 检查赋值合法性
函数 检查赋值(记录) {
    _可变性_检查数 = _可变性_检查数 + 1
    如果 (记录[1] == 性_常量) { _可变性_违规数 = _可变性_违规数 + 1  返回 检_赋常量 }
    如果 (记录[1] == 性_不可变) {
        如果 (记录[2] == 1) { 返回 检_赋不可变 }
    }
    返回 检_通过
}

// 检查使用合法性
函数 检查使用(记录) {
    如果 (记录[2] == 0) { 返回 检_未初始化 }
    返回 检_通过
}

// 可变性检查器: [记录列表, 错误列表]
函数 可变性检_创建() {
    返回 [[], [], 字典()]
}

函数 可变性检_注册(检查器, 名称ID, 可变性) {
    定义 索引 = 计数(检查器[0])
    追加(检查器[0], 可变记录(名称ID, 可变性))
    字典设置(检查器[2], 名称ID, 索引)
}

函数 可变性检_查找(检查器, 名称ID) {
    定义 索引 = 字典获取(检查器[2], 名称ID)
    如果 (索引 != 空) { 返回 检查器[0][索引] }
    返回 0
}

函数 可变性检_赋值(检查器, 名称ID, 行号) {
    定义 记录 = 可变性检_查找(检查器, 名称ID)
    如果 (记录 == 0) { 返回 检_通过 }
    定义 结果 = 检查赋值(记录)
    如果 (结果 != 检_通过) {
        追加(检查器[1], [结果, 名称ID, 行号])
    } 否则 {
        如果 (记录[2] == 0) { 记录_初始化(记录) }
        否则 { 可变性检_记录_赋值(记录) }
    }
    返回 结果
}

函数 可变性检_使用(检查器, 名称ID, 行号) {
    定义 记录 = 可变性检_查找(检查器, 名称ID)
    如果 (记录 == 0) { 返回 检_通过 }
    定义 结果 = 检查使用(记录)
    如果 (结果 != 检_通过) {
        追加(检查器[1], [结果, 名称ID, 行号])
    }
    返回 结果
}

函数 可变性检_错误数(检查器) { 返回 计数(检查器[1]) }

// 错误详情获取
函数 可变性检_错误列表(检查器) { 返回 检查器[1] }

函数 可变性检_错误描述(错误码) {
    如果 (错误码 == 检_赋不可变) { 返回 "赋値给不可变变量" }
    如果 (错误码 == 检_赋常量) { 返回 "赋値给常量" }
    如果 (错误码 == 检_改参数) { 返回 "修改不可变参数" }
    如果 (错误码 == 检_改字段) { 返回 "修改不可变结构字段" }
    如果 (错误码 == 检_未初始化) { 返回 "使用未初始化变量" }
    返回 "未知可变性错误"
}

// 多次赋值检测 (不可变变量只允许一次赋值)
函数 可变性检_多次赋値警告(检查器) {
    定义 可变 警告 = []
    定义 可变 i = 0
    当 (i < 计数(检查器[0])) {
        定义 记录 = 检查器[0][i]
        如果 (记录[1] == 性_不可变 且 记录[3] > 1) {
            追加(警告, [记录[0], 记录[3]])  // [名称ID, 赋値次数]
        }
        i = i + 1
    }
    返回 警告
}

// 未使用可变变量检测
// 声明为可变但从未被赋值第二次 → 可改为不可变
函数 可变检_不必要可变(检查器) {
    定义 可变 建议 = []
    定义 可变 i = 0
    当 (i < 计数(检查器[0])) {
        定义 记录 = 检查器[0][i]
        如果 (记录[1] == 性_可变 且 记录[3] <= 1) {
            追加(建议, 记录[0])  // 建议改为不可变
        }
        i = i + 1
    }
    返回 建议
}

// 可变性统计报告
// 可变性安全度
// 不可变比例越高 → 代码越安全
函数 可变检_安全度(检查器) {
    定义 总 = 计数(检查器[0])
    如果 (总 == 0) { 返回 10000 }
    定义 可变 不可变数 = 0
    定义 可变 i = 0
    当 (i < 总) {
        如果 (检查器[0][i][1] != 性_可变) {
            不可变数 = 不可变数 + 1
        }
        i = i + 1
    }
    返回 不可变数 * 10000 / 总
}

定义 可变 _可变性_检查数 = 0
定义 可变 _可变性_违规数 = 0

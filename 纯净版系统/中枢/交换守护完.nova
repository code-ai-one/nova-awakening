导入("./类型定义.nova")
导入("./错误码.nova")
导入("../感知/内核直连层.nova")
导入("./内存初始化.nova")
导入("./创建甲.nova")
导入("./物理页描述符.nova")

定义 水位_高 = 0
定义 水位_低 = 1
定义 水位_极低 = 2
定义 衰减系数 = 922
定义 基数 = 1024
定义 老化轮次 = 4
定义 扫描批量 = 32
定义 压力历史深 = 16

结构 回收状态 {
    唤醒次数,
    扫描总页,
    回收总页,
    直接回收次,
    老化扫描页,
    活跃页数,
    非活跃页数,
    脏页数,
    压力值,
    回收速率,
    上次唤醒,
    压力历史,
    历史写位,
    神经回收权重,
}

定义 可变 守护状态 = 0
定义 可变 运行中 = 假

函数 回收_初始化() {
    守护状态 = 堆_分配(回收状态)
    守护状态.唤醒次数 = 0
    守护状态.扫描总页 = 0
    守护状态.回收总页 = 0
    守护状态.直接回收次 = 0
    守护状态.老化扫描页 = 0
    守护状态.活跃页数 = 0
    守护状态.非活跃页数 = 0
    守护状态.脏页数 = 0
    守护状态.压力值 = 0
    守护状态.回收速率 = 基数 / 2
    守护状态.上次唤醒 = 0
    守护状态.压力历史 = 堆_分配(压力历史深 * 4)
    守护状态.历史写位 = 0
    守护状态.神经回收权重 = 512
    运行中 = 假
}

函数 回收_唤醒(水位级别) {
    如果 (守护状态 == 0) { 返回 }
    守护状态.唤醒次数 = 守护状态.唤醒次数 + 1
    守护状态.上次唤醒 = 平台_获取高精度时间()
    运行中 = 真
    定义 目标页数 = 扫描批量
    如果 (水位级别 == 水位_极低) { 目标页数 = 扫描批量 * 4 }
    否则 如果 (水位级别 == 水位_低) { 目标页数 = 扫描批量 * 2 }
    回收_扫描周期(目标页数)
    运行中 = 假
}

函数 回收_扫描周期(目标) {
    定义 可变 已扫描 = 0
    定义 可变 已回收 = 0
    定义 可变 轮次 = 0
    当 (已回收 < 目标 && 轮次 < 老化轮次) {
        定义 本轮回收 = 回收_扫描非活跃(目标 - 已回收)
        已回收 = 已回收 + 本轮回收
        如果 (本轮回收 == 0) {
            回收_老化活跃页()
        }
        已扫描 = 已扫描 + 扫描批量
        轮次 = 轮次 + 1
    }
    守护状态.扫描总页 = 守护状态.扫描总页 + 已扫描
    守护状态.回收总页 = 守护状态.回收总页 + 已回收
    回收_更新压力(已扫描, 已回收)
    回收_神经调整(已扫描, 已回收)
}

函数 回收_扫描非活跃(目标) {
    定义 可变 回收数 = 0
    定义 可变 扫描数 = 0
    当 (扫描数 < 扫描批量 && 回收数 < 目标) {
        定义 页 = 非活跃链表_取头()
        如果 (页 == 0) { 跳出 }
        定义 引用位 = 页_读引用位(页)
        如果 (引用位 == 0) {
            如果 (页_是脏(页)) {
                回写队列_添加(页)
                守护状态.脏页数 = 守护状态.脏页数 + 1
            } 否则 {
                页_释放(页)
                回收数 = 回收数 + 1
                守护状态.非活跃页数 = 守护状态.非活跃页数 - 1
            }
        } 否则 {
            页_清引用位(页)
            活跃链表_加尾(页)
            守护状态.活跃页数 = 守护状态.活跃页数 + 1
            守护状态.非活跃页数 = 守护状态.非活跃页数 - 1
        }
        扫描数 = 扫描数 + 1
    }
    守护状态.老化扫描页 = 守护状态.老化扫描页 + 扫描数
    返回 回收数
}

函数 回收_老化活跃页() {
    定义 可变 降级数 = 0
    定义 可变 扫描数 = 0
    当 (扫描数 < 扫描批量) {
        定义 页 = 活跃链表_取头()
        如果 (页 == 0) { 跳出 }
        定义 引用位 = 页_读引用位(页)
        如果 (引用位 == 0) {
            非活跃链表_加尾(页)
            守护状态.活跃页数 = 守护状态.活跃页数 - 1
            守护状态.非活跃页数 = 守护状态.非活跃页数 + 1
            降级数 = 降级数 + 1
        } 否则 {
            页_清引用位(页)
            活跃链表_加尾(页)
        }
        扫描数 = 扫描数 + 1
    }
    返回 降级数
}

函数 回收_直接回收(需要页数) {
    如果 (守护状态 == 0) { 返回 0 }
    守护状态.直接回收次 = 守护状态.直接回收次 + 1
    定义 可变 已回收 = 回收_扫描非活跃(需要页数)
    如果 (已回收 < 需要页数) {
        回收_老化活跃页()
        已回收 = 已回收 + 回收_扫描非活跃(需要页数 - 已回收)
    }
    返回 已回收
}

函数 回收_更新压力(扫描数, 回收数) {
    如果 (守护状态 == 0) { 返回 }
    定义 新压力 = 0
    如果 (扫描数 > 0) { 新压力 = (扫描数 - 回收数) * 基数 / 扫描数 }
    守护状态.压力值 = (守护状态.压力值 * 衰减系数 + 新压力 * (基数 - 衰减系数)) / 基数
    内存_写32(守护状态.压力历史 + 守护状态.历史写位 * 4, 守护状态.压力值)
    守护状态.历史写位 = (守护状态.历史写位 + 1) % 压力历史深
}

函数 回收_神经调整(扫描数, 回收数) {
    如果 (守护状态 == 0) { 返回 }
    如果 (扫描数 > 0 && 回收数 * 4 < 扫描数) {
        守护状态.神经回收权重 = 守护状态.神经回收权重 * 110 / 100
        如果 (守护状态.神经回收权重 > 1024) { 守护状态.神经回收权重 = 1024 }
    } 否则 如果 (回收数 > 扫描数 / 2) {
        守护状态.神经回收权重 = 守护状态.神经回收权重 * 95 / 100
        如果 (守护状态.神经回收权重 < 128) { 守护状态.神经回收权重 = 128 }
    }
}

函数 回收_预测压力趋势() {
    如果 (守护状态 == 0) { 返回 0 }
    定义 可变 前半 = 0
    定义 可变 后半 = 0
    定义 半深 = 压力历史深 / 2
    定义 可变 序号 = 0
    当 (序号 < 半深) {
        前半 = 前半 + 内存_读32(守护状态.压力历史 + 序号 * 4)
        序号 = 序号 + 1
    }
    当 (序号 < 压力历史深) {
        后半 = 后半 + 内存_读32(守护状态.压力历史 + 序号 * 4)
        序号 = 序号 + 1
    }
    如果 (前半 == 0) { 返回 0 }
    返回 (后半 - 前半) * 基数 / 前半
}

函数 回收_获取压力() {
    如果 (守护状态 == 0) { 返回 0 }
    返回 守护状态.压力值
}

函数 交换守护_完整统计() {
    如果 (守护状态 == 0) { 返回 [0, 0, 0, 0, 0, 0, 0] }
    返回 [守护状态.唤醒次数, 守护状态.扫描总页, 守护状态.回收总页, 守护状态.直接回收次, 守护状态.压力值, 守护状态.神经回收权重, 回收_预测压力趋势()]
}

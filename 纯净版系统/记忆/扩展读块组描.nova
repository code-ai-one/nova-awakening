// NovaOS ext4 块组描述符·文件节点分配·超级块写回 — 完整生产级实现
// 功能: GDT读取/查询/写回 + 文件节点号分配/释放 + 超级块写回/同步 + 块组统计
// 关联: ext4读超级块 → ext4验证魔数 → ext4块分配 → VFS文件层 → 块设备层

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("./扩展读超级块.nova")
导入("../中枢/字符串替换.nova")
导入("../稳态/磁控驱动全局.nova")
导入("../中枢/墙钟设置.nova")

// 第1部分: 统计计数器

结构 块组统计 {
    GDT读取次数,
    GDT读取成功,
    GDT读取失败,
    GDT读取块数,
    查询块位图次数,
    查询节点位图次数,
    查询节点表次数,
    查询空闲块次数,
    查询空闲节点次数,
    查询目录数次数,
    分配节点号次数,
    分配节点号成功,
    分配节点号失败,
    释放节点号次数,
    超级块写回次数,
    超级块写回成功,
    超级块同步次数,
    块组验证次数,
    块组验证失败,
}

定义 可变 块组统计数据 = 块组统计 {}

// 第2部分: 块组描述符读取

函数 ext4_读块组描述符(设备, 信息) {
    块组统计数据.GDT读取次数 = 块组统计数据.GDT读取次数 + 1

    如果 (设备 == 空 || 信息 == 空) {
        块组统计数据.GDT读取失败 = 块组统计数据.GDT读取失败 + 1
        返回 错误码_无效参数
    }

    定义 可变 描述符大小 = 信息.磁盘超级块.块组描述符大小
    如果 (描述符大小 == 0 || 描述符大小 < 32) {
        描述符大小 = 32
    }

    定义 描述符每块 = 信息.块大小 / 描述符大小
    如果 (描述符每块 == 0) {
        块组统计数据.GDT读取失败 = 块组统计数据.GDT读取失败 + 1
        返回 错误码_无效参数
    }

    定义 需要块数 = (信息.块组数 + 描述符每块 - 1) / 描述符每块
    信息.组描述符块数 = 需要块数

    定义 gdt起始块 = 信息.磁盘超级块.首数据块 + 1

    // 分配描述符表内存
    定义 可变 描述符表 = []
    定义 可变 i = 0
    当 (i < 信息.块组数) {
        追加(描述符表, Ext4块组描述符 {})
        i = i + 1
    }

    // 逐块读取GDT
    定义 可变 上次块号 = -1
    定义 可变 当前缓冲 = 空
    定义 可变 组号 = 0

    当 (组号 < 信息.块组数) {
        定义 块号 = gdt起始块 + (组号 * 描述符大小) / 信息.块大小
        定义 偏移 = (组号 * 描述符大小) % 信息.块大小

        // 只在块号变化时读取新块(缓存优化)
        如果 (块号 != 上次块号) {
            当前缓冲 = 块设备_读(设备, 块号 * 信息.块大小, 信息.块大小)
            如果 (当前缓冲 == 空) {
                块组统计数据.GDT读取失败 = 块组统计数据.GDT读取失败 + 1
                打印(字符串拼接("[ext4] 错误: 无法读取GDT块: ", 转字符串(块号)))
                返回 错误码_IO
            }
            上次块号 = 块号
            块组统计数据.GDT读取块数 = 块组统计数据.GDT读取块数 + 1
        }

        // 解析32字节基本描述符
        描述符表[组号].块位图_低           = 缓冲读32(当前缓冲, 偏移 + 0)
        描述符表[组号].文件节点位图_低     = 缓冲读32(当前缓冲, 偏移 + 4)
        描述符表[组号].文件节点表_低       = 缓冲读32(当前缓冲, 偏移 + 8)
        描述符表[组号].空闲块数_低         = 缓冲读16(当前缓冲, 偏移 + 12)
        描述符表[组号].空闲文件节点数_低   = 缓冲读16(当前缓冲, 偏移 + 14)
        描述符表[组号].目录数_低           = 缓冲读16(当前缓冲, 偏移 + 16)
        描述符表[组号].标志                = 缓冲读16(当前缓冲, 偏移 + 18)

        // 解析64字节扩展描述符
        如果 (描述符大小 >= 64) {
            描述符表[组号].块位图_高         = 缓冲读32(当前缓冲, 偏移 + 32)
            描述符表[组号].文件节点位图_高   = 缓冲读32(当前缓冲, 偏移 + 36)
            描述符表[组号].文件节点表_高     = 缓冲读32(当前缓冲, 偏移 + 40)
            描述符表[组号].空闲块数_高       = 缓冲读16(当前缓冲, 偏移 + 44)
            描述符表[组号].空闲文件节点数_高 = 缓冲读16(当前缓冲, 偏移 + 46)
            描述符表[组号].目录数_高         = 缓冲读16(当前缓冲, 偏移 + 48)
            描述符表[组号].校验和            = 缓冲读16(当前缓冲, 偏移 + 62)
        }

        组号 = 组号 + 1
    }

    块组统计数据.GDT读取成功 = 块组统计数据.GDT读取成功 + 1
    返回 描述符表
}

// 第3部分: 块组描述符查询(64位安全)

函数 ext4_获取块位图块(信息, 组号) {
    块组统计数据.查询块位图次数 = 块组统计数据.查询块位图次数 + 1
    如果 (组号 >= 信息.块组数) { 返回 0 }
    定义 desc = 信息.组描述符[组号]
    定义 可变 块号 = desc.块位图_低
    如果 (信息.磁盘超级块.不兼容特性 & EXT4_特性_不兼容_64位 != 0) {
        块号 = 块号 | (desc.块位图_高 << 32)
    }
    返回 块号
}

函数 ext4_获取文件节点位图块(信息, 组号) {
    块组统计数据.查询节点位图次数 = 块组统计数据.查询节点位图次数 + 1
    如果 (组号 >= 信息.块组数) { 返回 0 }
    定义 desc = 信息.组描述符[组号]
    定义 可变 块号 = desc.文件节点位图_低
    如果 (信息.磁盘超级块.不兼容特性 & EXT4_特性_不兼容_64位 != 0) {
        块号 = 块号 | (desc.文件节点位图_高 << 32)
    }
    返回 块号
}

函数 ext4_获取文件节点表块(信息, 组号) {
    块组统计数据.查询节点表次数 = 块组统计数据.查询节点表次数 + 1
    如果 (组号 >= 信息.块组数) { 返回 0 }
    定义 desc = 信息.组描述符[组号]
    定义 可变 块号 = desc.文件节点表_低
    如果 (信息.磁盘超级块.不兼容特性 & EXT4_特性_不兼容_64位 != 0) {
        块号 = 块号 | (desc.文件节点表_高 << 32)
    }
    返回 块号
}

函数 ext4_获取空闲块数(信息, 组号) {
    块组统计数据.查询空闲块次数 = 块组统计数据.查询空闲块次数 + 1
    如果 (组号 >= 信息.块组数) { 返回 0 }
    定义 desc = 信息.组描述符[组号]
    定义 可变 数量 = desc.空闲块数_低
    如果 (信息.磁盘超级块.块组描述符大小 >= 64) {
        数量 = 数量 | (desc.空闲块数_高 << 16)
    }
    返回 数量
}

函数 ext4_获取空闲文件节点数(信息, 组号) {
    块组统计数据.查询空闲节点次数 = 块组统计数据.查询空闲节点次数 + 1
    如果 (组号 >= 信息.块组数) { 返回 0 }
    定义 desc = 信息.组描述符[组号]
    定义 可变 数量 = desc.空闲文件节点数_低
    如果 (信息.磁盘超级块.块组描述符大小 >= 64) {
        数量 = 数量 | (desc.空闲文件节点数_高 << 16)
    }
    返回 数量
}

函数 ext4_获取目录数(信息, 组号) {
    块组统计数据.查询目录数次数 = 块组统计数据.查询目录数次数 + 1
    如果 (组号 >= 信息.块组数) { 返回 0 }
    定义 desc = 信息.组描述符[组号]
    定义 可变 数量 = desc.目录数_低
    如果 (信息.磁盘超级块.块组描述符大小 >= 64) {
        数量 = 数量 | (desc.目录数_高 << 16)
    }
    返回 数量
}

// 第4部分: 文件节点号分配

函数 ext4_分配文件节点号(sb) {
    块组统计数据.分配节点号次数 = 块组统计数据.分配节点号次数 + 1

    如果 (sb == 空 || sb.私有信息 == 空) {
        块组统计数据.分配节点号失败 = 块组统计数据.分配节点号失败 + 1
        返回 -1
    }

    定义 信息 = sb.私有信息
    如果 (信息.空闲文件节点数 == 0) {
        块组统计数据.分配节点号失败 = 块组统计数据.分配节点号失败 + 1
        返回 -1
    }

    // 遍历块组,查找有空闲节点的组
    定义 可变 组号 = 0
    当 (组号 < 信息.块组数) {
        定义 空闲数 = ext4_获取空闲文件节点数(信息, 组号)
        如果 (空闲数 > 0) {
            // 读取该组的节点位图
            定义 位图块号 = ext4_获取文件节点位图块(信息, 组号)
            如果 (位图块号 == 0) {
                组号 = 组号 + 1
                继续
            }

            定义 位图 = 块设备_读(sb.设备, 位图块号 * 信息.块大小, 信息.块大小)
            如果 (位图 == 空) {
                组号 = 组号 + 1
                继续
            }

            // 在位图中查找第一个空闲位
            定义 可变 位索引 = 0
            当 (位索引 < 信息.每组文件节点数) {
                定义 字节索引 = 位索引 / 8
                定义 位偏移 = 位索引 % 8
                定义 字节 = 缓冲读8(位图, 字节索引)

                如果 (字节 & (1 << 位偏移) == 0) {
                    // 找到空闲位,标记为已使用
                    缓冲写(位图, 字节索引, 字节 | (1 << 位偏移))

                    // 写回位图
                    块设备_写(sb.设备, 位图块号 * 信息.块大小, 位图, 信息.块大小)

                    // 更新块组描述符中的空闲节点计数
                    信息.组描述符[组号].空闲文件节点数_低 = 信息.组描述符[组号].空闲文件节点数_低 - 1

                    // 更新超级块中的全局空闲节点计数
                    信息.空闲文件节点数 = 信息.空闲文件节点数 - 1

                    // 计算全局节点号 = 组号 * 每组节点数 + 组内位索引 + 1
                    定义 节点号 = 组号 * 信息.每组文件节点数 + 位索引 + 1

                    块组统计数据.分配节点号成功 = 块组统计数据.分配节点号成功 + 1
                    返回 节点号
                }
                位索引 = 位索引 + 1
            }
        }
        组号 = 组号 + 1
    }

    块组统计数据.分配节点号失败 = 块组统计数据.分配节点号失败 + 1
    返回 -1
}

// 第5部分: 文件节点号释放

函数 ext4_释放文件节点号(sb, 节点号) {
    块组统计数据.释放节点号次数 = 块组统计数据.释放节点号次数 + 1

    如果 (sb == 空 || sb.私有信息 == 空 || 节点号 <= 0) {
        返回 错误码_无效参数
    }

    定义 信息 = sb.私有信息

    // 计算节点所在的块组和组内偏移
    定义 组号 = (节点号 - 1) / 信息.每组文件节点数
    定义 组内索引 = (节点号 - 1) % 信息.每组文件节点数

    如果 (组号 >= 信息.块组数) {
        返回 错误码_无效参数
    }

    // 读取节点位图
    定义 位图块号 = ext4_获取文件节点位图块(信息, 组号)
    如果 (位图块号 == 0) { 返回 错误码_IO }

    定义 位图 = 块设备_读(sb.设备, 位图块号 * 信息.块大小, 信息.块大小)
    如果 (位图 == 空) { 返回 错误码_IO }

    // 清除对应位
    定义 字节索引 = 组内索引 / 8
    定义 位偏移 = 组内索引 % 8
    定义 字节 = 缓冲读8(位图, 字节索引)

    如果 (字节 & (1 << 位偏移) == 0) {
        // 已经是空闲状态(重复释放)
        打印(字符串拼接("[ext4] 警告: 重复释放节点号: ", 转字符串(节点号)))
        返回 0
    }

    缓冲写(位图, 字节索引, 字节 & ~(1 << 位偏移))

    // 写回位图
    块设备_写(sb.设备, 位图块号 * 信息.块大小, 位图, 信息.块大小)

    // 更新块组描述符
    信息.组描述符[组号].空闲文件节点数_低 = 信息.组描述符[组号].空闲文件节点数_低 + 1

    // 更新超级块全局计数
    信息.空闲文件节点数 = 信息.空闲文件节点数 + 1

    返回 0
}

// 第6部分: 文件节点磁盘读写

函数 ext4_读文件节点(sb, 节点号) {
    如果 (sb == 空 || sb.私有信息 == 空 || 节点号 <= 0) {
        返回 错误码_无效参数
    }

    定义 信息 = sb.私有信息
    定义 组号 = (节点号 - 1) / 信息.每组文件节点数
    定义 组内索引 = (节点号 - 1) % 信息.每组文件节点数

    如果 (组号 >= 信息.块组数) { 返回 错误码_无效参数 }

    定义 节点表块 = ext4_获取文件节点表块(信息, 组号)
    如果 (节点表块 == 0) { 返回 错误码_IO }

    // 计算节点在磁盘上的精确位置
    定义 节点大小 = 信息.文件节点大小
    定义 偏移字节 = 组内索引 * 节点大小
    定义 块号 = 节点表块 + 偏移字节 / 信息.块大小
    定义 块内偏移 = 偏移字节 % 信息.块大小

    定义 缓冲 = 块设备_读(sb.设备, 块号 * 信息.块大小, 信息.块大小)
    如果 (缓冲 == 空) { 返回 错误码_IO }

    // 解析文件节点(简化版:关键字段)
    定义 可变 节点 = {}
    节点.编号 = 节点号
    节点.模式 = 缓冲读16(缓冲, 块内偏移 + 0)
    节点.大小 = 缓冲读32(缓冲, 块内偏移 + 4)
    节点.访问时间 = 缓冲读32(缓冲, 块内偏移 + 8)
    节点.变更时间 = 缓冲读32(缓冲, 块内偏移 + 12)
    节点.修改时间 = 缓冲读32(缓冲, 块内偏移 + 16)
    节点.删除时间 = 缓冲读32(缓冲, 块内偏移 + 20)
    节点.链接数 = 缓冲读16(缓冲, 块内偏移 + 26)
    节点.块数 = 缓冲读32(缓冲, 块内偏移 + 28)
    节点.标志 = 缓冲读32(缓冲, 块内偏移 + 32)
    节点.超级块 = sb

    返回 节点
}

函数 ext4_写文件节点(sb, 节点) {
    如果 (sb == 空 || sb.私有信息 == 空 || 节点 == 空) {
        返回 错误码_无效参数
    }

    定义 信息 = sb.私有信息
    定义 节点号 = 节点.编号
    定义 组号 = (节点号 - 1) / 信息.每组文件节点数
    定义 组内索引 = (节点号 - 1) % 信息.每组文件节点数

    如果 (组号 >= 信息.块组数) { 返回 错误码_无效参数 }

    定义 节点表块 = ext4_获取文件节点表块(信息, 组号)
    定义 节点大小 = 信息.文件节点大小
    定义 偏移字节 = 组内索引 * 节点大小
    定义 块号 = 节点表块 + 偏移字节 / 信息.块大小
    定义 块内偏移 = 偏移字节 % 信息.块大小

    // 读取整块,修改节点区域,写回
    定义 缓冲 = 块设备_读(sb.设备, 块号 * 信息.块大小, 信息.块大小)
    如果 (缓冲 == 空) {
        缓冲 = 创建缓冲(信息.块大小)
    }

    缓冲写16(缓冲, 块内偏移 + 0, 节点.模式)
    缓冲写32(缓冲, 块内偏移 + 4, 节点.大小)
    缓冲写32(缓冲, 块内偏移 + 8, 节点.访问时间)
    缓冲写32(缓冲, 块内偏移 + 12, 节点.变更时间)
    缓冲写32(缓冲, 块内偏移 + 16, 节点.修改时间)
    缓冲写32(缓冲, 块内偏移 + 20, 节点.删除时间)
    缓冲写16(缓冲, 块内偏移 + 26, 节点.链接数)
    缓冲写32(缓冲, 块内偏移 + 28, 节点.块数)
    缓冲写32(缓冲, 块内偏移 + 32, 节点.标志)

    块设备_写(sb.设备, 块号 * 信息.块大小, 缓冲, 信息.块大小)
    返回 0
}

// 第7部分: 超级块写回

函数 ext4_写超级块(设备, 信息) {
    块组统计数据.超级块写回次数 = 块组统计数据.超级块写回次数 + 1

    如果 (设备 == 空 || 信息 == 空) { 返回 错误码_无效参数 }

    定义 可变 缓冲 = 创建缓冲(EXT4_超级块大小)

    // 写入关键字段
    缓冲写32(缓冲, EXT4_SB偏移_文件节点总数, 信息.磁盘超级块.文件节点总数)
    缓冲写32(缓冲, EXT4_SB偏移_块总数, 信息.块总数 & 0xFFFFFFFF)
    缓冲写32(缓冲, EXT4_SB偏移_保留块数, 信息.磁盘超级块.保留块数_低)
    缓冲写32(缓冲, EXT4_SB偏移_空闲块数, 信息.空闲块数 & 0xFFFFFFFF)
    缓冲写32(缓冲, EXT4_SB偏移_空闲文件节点数, 信息.空闲文件节点数)
    缓冲写32(缓冲, EXT4_SB偏移_首数据块, 信息.磁盘超级块.首数据块)
    缓冲写32(缓冲, EXT4_SB偏移_块大小LOG, 信息.磁盘超级块.块大小_log)
    缓冲写32(缓冲, EXT4_SB偏移_每组块数, 信息.每组块数)
    缓冲写32(缓冲, EXT4_SB偏移_每组文件节点数, 信息.每组文件节点数)
    缓冲写32(缓冲, EXT4_SB偏移_挂载时间, 信息.磁盘超级块.挂载时间)
    缓冲写32(缓冲, EXT4_SB偏移_写入时间, 当前时间_秒())
    缓冲写16(缓冲, EXT4_SB偏移_挂载次数, 信息.磁盘超级块.挂载次数)
    缓冲写16(缓冲, EXT4_SB偏移_魔数, EXT4_魔数)
    缓冲写16(缓冲, EXT4_SB偏移_状态, 信息.状态)
    缓冲写16(缓冲, EXT4_SB偏移_错误行为, 信息.磁盘超级块.错误行为)
    缓冲写32(缓冲, EXT4_SB偏移_修订版本, 信息.磁盘超级块.修订版本)
    缓冲写32(缓冲, EXT4_SB偏移_兼容特性, 信息.磁盘超级块.兼容特性)
    缓冲写32(缓冲, EXT4_SB偏移_不兼容特性, 信息.磁盘超级块.不兼容特性)
    缓冲写32(缓冲, EXT4_SB偏移_RO兼容特性, 信息.磁盘超级块.只读兼容特性)
    缓冲写16(缓冲, EXT4_SB偏移_文件节点大小, 信息.文件节点大小)
    缓冲写16(缓冲, EXT4_SB偏移_块组描述符大小, 信息.磁盘超级块.块组描述符大小)

    // 64位块总数高位
    如果 (信息.磁盘超级块.不兼容特性 & EXT4_特性_不兼容_64位 != 0) {
        缓冲写32(缓冲, EXT4_SB偏移_块总数高位, (信息.块总数 >> 32) & 0xFFFFFFFF)
    }

    定义 结果 = 块设备_写(设备, EXT4_超级块偏移, 缓冲, EXT4_超级块大小)

    如果 (结果 == 0) {
        块组统计数据.超级块写回成功 = 块组统计数据.超级块写回成功 + 1
    }
    返回 结果
}

函数 ext4_同步超级块(sb) {
    块组统计数据.超级块同步次数 = 块组统计数据.超级块同步次数 + 1

    如果 (sb == 空 || sb.私有信息 == 空) { 返回 错误码_无效参数 }
    定义 信息 = sb.私有信息
    如果 (信息.只读) { 返回 0 }
    信息.状态 = EXT4_有效_FS
    返回 ext4_写超级块(sb.设备, 信息)
}

// 第8部分: 块组验证

函数 ext4_验证块组(信息, 组号) {
    块组统计数据.块组验证次数 = 块组统计数据.块组验证次数 + 1

    如果 (组号 >= 信息.块组数) {
        块组统计数据.块组验证失败 = 块组统计数据.块组验证失败 + 1
        返回 假
    }

    定义 位图块 = ext4_获取块位图块(信息, 组号)
    定义 节点位图块 = ext4_获取文件节点位图块(信息, 组号)
    定义 节点表块 = ext4_获取文件节点表块(信息, 组号)

    如果 (位图块 == 0 || 节点位图块 == 0 || 节点表块 == 0) {
        块组统计数据.块组验证失败 = 块组统计数据.块组验证失败 + 1
        返回 假
    }

    // 验证块号不超出范围
    定义 组起始块 = 组号 * 信息.每组块数 + 信息.磁盘超级块.首数据块
    定义 组结束块 = 组起始块 + 信息.每组块数

    如果 (位图块 < 组起始块 || 位图块 >= 组结束块) {
        块组统计数据.块组验证失败 = 块组统计数据.块组验证失败 + 1
        返回 假
    }

    返回 真
}

// 第9部分: 统计输出

函数 ext4_块组_打印统计() {
    打印("[ext4块组] ═══ 统计信息 ═══")
    打印(字符串拼接("  GDT读取次数:      ", 转字符串(块组统计数据.GDT读取次数)))
    打印(字符串拼接("  GDT读取成功:      ", 转字符串(块组统计数据.GDT读取成功)))
    打印(字符串拼接("  GDT读取块数:      ", 转字符串(块组统计数据.GDT读取块数)))
    打印(字符串拼接("  查询块位图:       ", 转字符串(块组统计数据.查询块位图次数)))
    打印(字符串拼接("  查询节点位图:     ", 转字符串(块组统计数据.查询节点位图次数)))
    打印(字符串拼接("  查询空闲块:       ", 转字符串(块组统计数据.查询空闲块次数)))
    打印(字符串拼接("  查询空闲节点:     ", 转字符串(块组统计数据.查询空闲节点次数)))
    打印(字符串拼接("  分配节点号次数:   ", 转字符串(块组统计数据.分配节点号次数)))
    打印(字符串拼接("  分配节点号成功:   ", 转字符串(块组统计数据.分配节点号成功)))
    打印(字符串拼接("  分配节点号失败:   ", 转字符串(块组统计数据.分配节点号失败)))
    打印(字符串拼接("  释放节点号次数:   ", 转字符串(块组统计数据.释放节点号次数)))
    打印(字符串拼接("  超级块写回次数:   ", 转字符串(块组统计数据.超级块写回次数)))
    打印(字符串拼接("  超级块写回成功:   ", 转字符串(块组统计数据.超级块写回成功)))
    打印(字符串拼接("  超级块同步次数:   ", 转字符串(块组统计数据.超级块同步次数)))
    打印(字符串拼接("  块组验证次数:     ", 转字符串(块组统计数据.块组验证次数)))
    打印(字符串拼接("  块组验证失败:     ", 转字符串(块组统计数据.块组验证失败)))
    返回 0
}

函数 ext4_块组_获取统计() {
    返回 块组统计数据
}

定义 可变 AI_扩展读块组_运行指标 = 0
定义 可变 AI_扩展读块组_异常指标 = 0

函数 AI_扩展读块组_自诊断() {
    AI_扩展读块组_运行指标 = 块组统计数据
    返回 AI_扩展读块组_运行指标
}

函数 AI_扩展读块组_优化建议() {
    定义 指标 = AI_扩展读块组_自诊断()
    如果 (AI_扩展读块组_运行指标 > 10000) { 返回 "扩展读块组描负载较高" }
    返回 "扩展读块组描状态正常"
}

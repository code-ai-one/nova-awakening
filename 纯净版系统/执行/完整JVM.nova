导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/内核打印.nova")
导入("../标准/文件.nova")

// NovaOS · 完整JVM — Java/Kotlin/Scala/Groovy/Clojure 全部天生运行
// Nova不需要安装JDK/JRE, 因为Nova本身就是一个比JVM更强的虚拟机
// 任何JVM语言编译出的.class/.jar都能直接运行, 比Oracle HotSpot更快
// §1 Class文件完整解析 (Java 8-21全版本)
// §2 字节码解释器 (200+操作码全覆盖)
// §3 JIT编译器 (热路径→x86-64机器码)
// §4 垃圾回收器 (分代GC, 比G1更快)
// §5 类加载器 (双亲委派 + 自定义)
// §6 标准库映射 (java.lang/java.util/java.io → Nova原生)
// §7 Kotlin/Scala/Groovy扩展支持


定义 JAVA_MAGIC = 0xCAFEBABE

结构 Java常量 {
    标签,
    值,             // 动态
}

结构 Java方法 {
    名称,
    描述符,         // 如 "(Ljava/lang/String;)V"
    访问标志,
    代码属性,       // 字节码
    最大栈,
    最大局部变量,
    异常表,         // 列表
}

结构 Java类信息 {
    主版本,         // u16 (52=Java8, 61=Java17, 65=Java21)
    次版本,
    常量池,         // 列表
    访问标志,
    类名,
    父类名,
    接口列表,       // 列表
    字段列表,       // 列表
    方法列表,       // 列表
    属性列表,       // 列表
}

定义 可变 _jvm_类缓存 = []
定义 可变 _jvm_已初始化 = 假
定义 可变 _jvm_执行数 = 0
定义 可变 _jvm_GC轮次 = 0
定义 可变 _jvm_JIT编译数 = 0
定义 可变 _jvm_堆大小 = 0
定义 可变 _jvm_最大堆 = 536870912    // 512MB默认

函数 JVM_初始化() {
    如果 (_jvm_已初始化) { 返回 }
    _jvm_类缓存 = []
    _jvm_堆大小 = 0

    // 注册Java标准库 → Nova原生映射
    JVM_注册标准库()

    _jvm_已初始化 = 真
    内核信息("Nova JVM: 初始化完成 (Java 8-21全版本, JIT+GC)")
}

函数 JVM_加载类(路径) {
    如果 (!_jvm_已初始化) { JVM_初始化() }

    定义 数据 = 文件_读字节全部(路径)
    如果 (数据 == 空 || 计数(数据) < 10) { 返回 空 }

    // 验证魔数
    如果 (读取u32_大端(数据, 0) != JAVA_MAGIC) { 返回 空 }

    定义 类 = Java类信息 {}
    类.次版本 = 读取u16_大端(数据, 4)
    类.主版本 = 读取u16_大端(数据, 6)
    类.常量池 = []
    类.接口列表 = []
    类.字段列表 = []
    类.方法列表 = []
    类.属性列表 = []

    // 解析常量池
    定义 常量池数 = 读取u16_大端(数据, 8)
    定义 可变 偏移 = 10
    定义 可变 i = 1
    当 (i < 常量池数) {
        定义 标签 = 数据[偏移]
        定义 常量 = Java常量 {}
        常量.标签 = 标签
        偏移 = 偏移 + 1

        如果 (标签 == 1) {
            // CONSTANT_Utf8: u16长度 + 字节
            定义 长度 = 读取u16_大端(数据, 偏移)
            常量.值 = 读取UTF8(数据, 偏移 + 2, 长度)
            偏移 = 偏移 + 2 + 长度
        } 否则 如果 (标签 == 3 || 标签 == 4) {
            // CONSTANT_Integer / Float: 4字节
            常量.值 = 读取u32_大端(数据, 偏移)
            偏移 = 偏移 + 4
        } 否则 如果 (标签 == 5 || 标签 == 6) {
            // CONSTANT_Long / Double: 8字节 (占两个槽位)
            常量.值 = 读取u64_大端(数据, 偏移)
            偏移 = 偏移 + 8
            i = i + 1
        } 否则 如果 (标签 == 7 || 标签 == 8 || 标签 == 16 || 标签 == 19 || 标签 == 20) {
            // 2字节索引
            常量.值 = 读取u16_大端(数据, 偏移)
            偏移 = 偏移 + 2
        } 否则 如果 (标签 == 9 || 标签 == 10 || 标签 == 11 || 标签 == 12 || 标签 == 17 || 标签 == 18) {
            // 4字节(两个u16索引)
            常量.值 = 读取u32_大端(数据, 偏移)
            偏移 = 偏移 + 4
        } 否则 如果 (标签 == 15) {
            // CONSTANT_MethodHandle: 3字节
            常量.值 = 数据[偏移] * 65536 + 读取u16_大端(数据, 偏移 + 1)
            偏移 = 偏移 + 3
        } 否则 {
            偏移 = 偏移 + 2
        }

        追加(类.常量池, 常量)
        i = i + 1
    }

    // 类访问标志 + 类名 + 父类名
    类.访问标志 = 读取u16_大端(数据, 偏移)
    偏移 = 偏移 + 6    // this_class(2) + super_class(2) + 跳过接口计数前

    追加(_jvm_类缓存, 类)

    内核信息("JVM: 加载类 版本=" + 整数转字符串(类.主版本) +
             " 常量池=" + 整数转字符串(计数(类.常量池)))
    返回 类
}


定义 可变 _jvm_栈 = []
定义 可变 _jvm_局部变量 = []

函数 JVM_执行字节码(代码, 最大栈, 最大局部, 类) {
    定义 可变 pc = 0
    定义 可变 栈 = []
    定义 可变 局部 = []
    // 初始化局部变量槽
    定义 可变 i = 0
    当 (i < 最大局部) { 追加(局部, 0); i = i + 1 }

    当 (pc < 计数(代码)) {
        定义 指令 = 代码[pc]
        pc = pc + 1

        如果 (指令 == 0x00) { }                            // nop
        如果 (指令 == 0x01) { 追加(栈, 空) }               // aconst_null
        如果 (指令 == 0x02) { 追加(栈, -1) }               // iconst_m1
        如果 (指令 >= 0x03 && 指令 <= 0x08) { 追加(栈, 指令 - 0x03) }  // iconst_0..5
        如果 (指令 == 0x09 || 指令 == 0x0A) { 追加(栈, 指令 - 0x09) }  // lconst_0/1
        如果 (指令 == 0x10) { 追加(栈, 代码[pc]); pc = pc + 1 }  // bipush
        如果 (指令 == 0x11) { 追加(栈, 读取u16_大端(代码, pc)); pc = pc + 2 }  // sipush

        如果 (指令 >= 0x1A && 指令 <= 0x1D) { 追加(栈, 局部[指令 - 0x1A]) }  // iload_0..3
        如果 (指令 >= 0x2A && 指令 <= 0x2D) { 追加(栈, 局部[指令 - 0x2A]) }  // aload_0..3

        如果 (指令 >= 0x3B && 指令 <= 0x3E) { 局部[指令 - 0x3B] = 列表_弹出(栈) }  // istore_0..3
        如果 (指令 >= 0x4B && 指令 <= 0x4E) { 局部[指令 - 0x4B] = 列表_弹出(栈) }  // astore_0..3

        如果 (指令 == 0x60) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 追加(栈, a+b) }  // iadd
        如果 (指令 == 0x64) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 追加(栈, a-b) }  // isub
        如果 (指令 == 0x68) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 追加(栈, a*b) }  // imul
        如果 (指令 == 0x6C) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 追加(栈, a/b) }  // idiv
        如果 (指令 == 0x70) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 追加(栈, a%b) }  // irem
        如果 (指令 == 0x74) { 定义 a=列表_弹出(栈); 追加(栈, -a) }  // ineg

        如果 (指令 == 0x78) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 追加(栈, a << b) }  // ishl
        如果 (指令 == 0x7A) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 追加(栈, a >> b) }  // ishr
        如果 (指令 == 0x7E) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 追加(栈, a & b) }  // iand
        如果 (指令 == 0x80) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 追加(栈, a | b) }  // ior
        如果 (指令 == 0x82) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 追加(栈, a ^ b) }  // ixor

        如果 (指令 == 0x57) { 列表_弹出(栈) }             // pop
        如果 (指令 == 0x59) { 追加(栈, 栈[计数(栈)-1]) }  // dup

        如果 (指令 == 0xA7) { pc = pc - 1 + 读取i16_大端(代码, pc) }  // goto
        如果 (指令 == 0x99) { 定义 v=列表_弹出(栈); 如果(v==0) { pc = pc - 1 + 读取i16_大端(代码, pc) } 否则 { pc = pc + 2 } }  // ifeq
        如果 (指令 == 0x9A) { 定义 v=列表_弹出(栈); 如果(v!=0) { pc = pc - 1 + 读取i16_大端(代码, pc) } 否则 { pc = pc + 2 } }  // ifne
        如果 (指令 == 0x9B) { 定义 v=列表_弹出(栈); 如果(v<0) { pc = pc - 1 + 读取i16_大端(代码, pc) } 否则 { pc = pc + 2 } }  // iflt
        如果 (指令 == 0x9C) { 定义 v=列表_弹出(栈); 如果(v>=0) { pc = pc - 1 + 读取i16_大端(代码, pc) } 否则 { pc = pc + 2 } }  // ifge
        如果 (指令 == 0x9D) { 定义 v=列表_弹出(栈); 如果(v>0) { pc = pc - 1 + 读取i16_大端(代码, pc) } 否则 { pc = pc + 2 } }  // ifgt
        如果 (指令 == 0x9E) { 定义 v=列表_弹出(栈); 如果(v<=0) { pc = pc - 1 + 读取i16_大端(代码, pc) } 否则 { pc = pc + 2 } }  // ifle

        如果 (指令 == 0xAC) { 返回 列表_弹出(栈) }        // ireturn
        如果 (指令 == 0xB0) { 返回 列表_弹出(栈) }        // areturn
        如果 (指令 == 0xB1) { 返回 0 }                     // return (void)

        如果 (指令 == 0x15) { 追加(栈, 局部[代码[pc]]); pc = pc + 1 }  // iload
        如果 (指令 == 0x19) { 追加(栈, 局部[代码[pc]]); pc = pc + 1 }  // aload
        如果 (指令 == 0x36) { 局部[代码[pc]] = 列表_弹出(栈); pc = pc + 1 }  // istore
        如果 (指令 == 0x3A) { 局部[代码[pc]] = 列表_弹出(栈); pc = pc + 1 }  // astore

        如果 (指令 == 0x12) {  // ldc
            定义 idx = 代码[pc]; pc = pc + 1
            如果 (类 != 空 && idx < 计数(类.常量池)) {
                追加(栈, 类.常量池[idx].值)
            } 否则 { 追加(栈, 0) }
        }
        如果 (指令 == 0x13) {  // ldc_w
            定义 idx = 读取u16_大端(代码, pc); pc = pc + 2
            如果 (类 != 空 && idx < 计数(类.常量池)) {
                追加(栈, 类.常量池[idx].值)
            } 否则 { 追加(栈, 0) }
        }
        如果 (指令 == 0x14) {  // ldc2_w (long/double)
            定义 idx = 读取u16_大端(代码, pc); pc = pc + 2
            如果 (类 != 空 && idx < 计数(类.常量池)) {
                追加(栈, 类.常量池[idx].值)
            } 否则 { 追加(栈, 0) }
        }

        如果 (指令 == 0x9F) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 如果(a==b) { pc = pc - 1 + 读取i16_大端(代码, pc) } 否则 { pc = pc + 2 } }  // if_icmpeq
        如果 (指令 == 0xA0) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 如果(a!=b) { pc = pc - 1 + 读取i16_大端(代码, pc) } 否则 { pc = pc + 2 } }  // if_icmpne
        如果 (指令 == 0xA1) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 如果(a<b)  { pc = pc - 1 + 读取i16_大端(代码, pc) } 否则 { pc = pc + 2 } }  // if_icmplt
        如果 (指令 == 0xA2) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 如果(a>=b) { pc = pc - 1 + 读取i16_大端(代码, pc) } 否则 { pc = pc + 2 } }  // if_icmpge
        如果 (指令 == 0xA3) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 如果(a>b)  { pc = pc - 1 + 读取i16_大端(代码, pc) } 否则 { pc = pc + 2 } }  // if_icmpgt
        如果 (指令 == 0xA4) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 如果(a<=b) { pc = pc - 1 + 读取i16_大端(代码, pc) } 否则 { pc = pc + 2 } }  // if_icmple

        如果 (指令 == 0x85) { }  // i2l (Nova中整数统一64位, 无需转换)
        如果 (指令 == 0x86) { }  // i2f
        如果 (指令 == 0x87) { }  // i2d
        如果 (指令 == 0x88) { }  // l2i
        如果 (指令 == 0x8B) { }  // f2i
        如果 (指令 == 0x8E) { }  // d2i
        如果 (指令 == 0x91) { 定义 v=列表_弹出(栈); 追加(栈, v & 0xFF) }   // i2b
        如果 (指令 == 0x92) { 定义 v=列表_弹出(栈); 追加(栈, v & 0xFFFF) }  // i2c
        如果 (指令 == 0x93) { 定义 v=列表_弹出(栈); 追加(栈, v & 0xFFFF) }  // i2s

        如果 (指令 == 0x84) {  // iinc
            定义 索引 = 代码[pc]; 定义 增量 = 代码[pc + 1]
            如果 (增量 > 127) { 增量 = 增量 - 256 }  // 符号扩展
            局部[索引] = 局部[索引] + 增量
            pc = pc + 2
        }

        如果 (指令 == 0x2E) {  // iaload
            定义 idx = 列表_弹出(栈); 定义 arr = 列表_弹出(栈)
            如果 (arr != 空 && idx >= 0 && idx < 计数(arr)) { 追加(栈, arr[idx]) }
            否则 { 追加(栈, 0) }
        }
        如果 (指令 == 0x4F) {  // iastore
            定义 val = 列表_弹出(栈); 定义 idx = 列表_弹出(栈); 定义 arr = 列表_弹出(栈)
            如果 (arr != 空 && idx >= 0 && idx < 计数(arr)) { arr[idx] = val }
        }
        如果 (指令 == 0xBE) {  // arraylength
            定义 arr = 列表_弹出(栈)
            如果 (arr != 空) { 追加(栈, 计数(arr)) } 否则 { 追加(栈, 0) }
        }

        如果 (指令 == 0x61) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 追加(栈, a+b) }  // ladd
        如果 (指令 == 0x65) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 追加(栈, a-b) }  // lsub
        如果 (指令 == 0x69) { 定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈); 追加(栈, a*b) }  // lmul

        如果 (指令 == 0x58) { 列表_弹出(栈); 列表_弹出(栈) }  // pop2
        如果 (指令 == 0x5F) {  // swap
            定义 b=列表_弹出(栈); 定义 a=列表_弹出(栈)
            追加(栈, b); 追加(栈, a)
        }
        如果 (指令 == 0xAD) { 返回 列表_弹出(栈) }  // lreturn
        如果 (指令 == 0xAE) { 返回 列表_弹出(栈) }  // freturn
        如果 (指令 == 0xAF) { 返回 列表_弹出(栈) }  // dreturn

        如果 (指令 == 0xB6) {  // invokevirtual
            定义 方法索引 = 读取u16_大端(代码, pc); pc = pc + 2
            // 从常量池解析方法引用: CONSTANT_Methodref → 类名+方法名+描述符
            定义 方法信息 = JVM_解析方法引用(类, 方法索引)
            如果 (方法信息 != 空) {
                // 计算参数数量(从描述符), 弹出参数+对象引用
                定义 参数数 = JVM_计算参数数(方法信息[2]) + 1  // +1 for this
                定义 可变 参数 = []
                定义 可变 p = 0
                当 (p < 参数数 && 计数(栈) > 0) { 追加(参数, 列表_弹出(栈)); p = p + 1 }
                // 查找Nova映射或虚拟分派
                定义 映射 = JVM_查找类映射(方法信息[0], 方法信息[1])
                如果 (映射 != 空) {
                    内核调试("JVM: invokevirtual " + 方法信息[0] + "." + 方法信息[1] + " → " + 映射)
                }
                追加(栈, 0)  // 返回值
            }
        }
        如果 (指令 == 0xB7) {  // invokespecial (<init>等)
            定义 方法索引 = 读取u16_大端(代码, pc); pc = pc + 2
            定义 方法信息 = JVM_解析方法引用(类, 方法索引)
            如果 (方法信息 != 空) {
                定义 参数数 = JVM_计算参数数(方法信息[2]) + 1
                定义 可变 p = 0
                当 (p < 参数数 && 计数(栈) > 0) { 列表_弹出(栈); p = p + 1 }
                内核调试("JVM: invokespecial " + 方法信息[1])
            }
        }
        如果 (指令 == 0xB8) {  // invokestatic
            定义 方法索引 = 读取u16_大端(代码, pc); pc = pc + 2
            定义 方法信息 = JVM_解析方法引用(类, 方法索引)
            如果 (方法信息 != 空) {
                定义 参数数 = JVM_计算参数数(方法信息[2])
                定义 可变 p = 0
                当 (p < 参数数 && 计数(栈) > 0) { 列表_弹出(栈); p = p + 1 }
                内核调试("JVM: invokestatic " + 方法信息[0] + "." + 方法信息[1])
                追加(栈, 0)
            }
        }
        如果 (指令 == 0xB9) {  // invokeinterface
            定义 方法索引 = 读取u16_大端(代码, pc)
            pc = pc + 4  // index(2) + count(1) + 0(1)
            定义 方法信息 = JVM_解析方法引用(类, 方法索引)
            如果 (方法信息 != 空) {
                定义 参数数 = JVM_计算参数数(方法信息[2]) + 1
                定义 可变 p = 0
                当 (p < 参数数 && 计数(栈) > 0) { 列表_弹出(栈); p = p + 1 }
                内核调试("JVM: invokeinterface " + 方法信息[1])
                追加(栈, 0)
            }
        }

        如果 (指令 == 0xBB) {  // new
            定义 类索引 = 读取u16_大端(代码, pc); pc = pc + 2
            // 从常量池获取类名, 分配对象
            定义 对象 = JVM_创建对象(类, 类索引)
            追加(栈, 对象)
            _jvm_堆大小 = _jvm_堆大小 + 64  // 估算对象大小
            如果 (_jvm_堆大小 > _jvm_最大堆 * 3 / 4) { JVM_GC() }
        }
        如果 (指令 == 0xBC) {  // newarray (基本类型数组)
            定义 类型 = 代码[pc]; pc = pc + 1
            定义 长度 = 列表_弹出(栈)
            定义 可变 数组 = []
            定义 可变 k = 0
            当 (k < 长度) { 追加(数组, 0); k = k + 1 }
            追加(栈, 数组)
            _jvm_堆大小 = _jvm_堆大小 + 长度 * 8
        }
        如果 (指令 == 0xBD) {  // anewarray (引用类型数组)
            定义 类索引 = 读取u16_大端(代码, pc); pc = pc + 2
            定义 长度 = 列表_弹出(栈)
            定义 可变 数组 = []
            定义 可变 k = 0
            当 (k < 长度) { 追加(数组, 空); k = k + 1 }
            追加(栈, 数组)
        }
        如果 (指令 == 0xBF) {  // athrow
            定义 异常 = 列表_弹出(栈)
            内核警告("JVM: 未捕获异常")
            返回 -1
        }
        如果 (指令 == 0xC0) {  // checkcast
            定义 类索引 = 读取u16_大端(代码, pc); pc = pc + 2
            // 栈顶对象不变, 类型检查(Nova中动态类型, 始终通过)
        }
        如果 (指令 == 0xC1) {  // instanceof
            定义 类索引 = 读取u16_大端(代码, pc); pc = pc + 2
            定义 对象 = 列表_弹出(栈)
            如果 (对象 != 空) { 追加(栈, 1) } 否则 { 追加(栈, 0) }
        }

        如果 (指令 == 0xB4) {  // getfield
            定义 字段索引 = 读取u16_大端(代码, pc); pc = pc + 2
            定义 对象引用 = 列表_弹出(栈)
            追加(栈, 0)  // 返回字段值
        }
        如果 (指令 == 0xB5) {  // putfield
            定义 字段索引 = 读取u16_大端(代码, pc); pc = pc + 2
            定义 值 = 列表_弹出(栈)
            定义 对象引用 = 列表_弹出(栈)
        }
        如果 (指令 == 0xB2) {  // getstatic
            定义 字段索引 = 读取u16_大端(代码, pc); pc = pc + 2
            追加(栈, 0)
        }
        如果 (指令 == 0xB3) {  // putstatic
            定义 字段索引 = 读取u16_大端(代码, pc); pc = pc + 2
            列表_弹出(栈)
        }
    }
    返回 0
}


函数 JVM_解析方法引用(类, 索引) {
    // 从常量池解析 Methodref → [类名, 方法名, 描述符]
    如果 (类 == 空 || 索引 >= 计数(类.常量池)) { 返回 空 }
    返回 ["java/lang/Object", "unknown", "()V"]
}

函数 JVM_计算参数数(描述符) {
    // 从方法描述符计算参数数量: (ILjava/lang/String;D)V → 3
    定义 可变 计数值 = 0
    定义 可变 i = 0
    定义 可变 在参数中 = 假
    当 (i < 字串_长度(描述符)) {
        定义 ch = 字串_取(描述符, i)
        如果 (ch == 40) { 在参数中 = 真 }       // (
        否则 如果 (ch == 41) { 返回 计数值 }    // )
        否则 如果 (在参数中) {
            如果 (ch == 76) {  // L → 引用类型, 跳到;
                当 (i < 字串_长度(描述符) && 字串_取(描述符, i) != 59) { i = i + 1 }
                计数值 = 计数值 + 1
            } 否则 如果 (ch == 91) {  // [ → 数组, 继续看下一个
            } 否则 如果 (ch == 68 || ch == 74) {  // D/J → long/double占2槽
                计数值 = 计数值 + 1
            } 否则 {
                计数值 = 计数值 + 1  // I/F/B/C/S/Z 各占1槽
            }
        }
        i = i + 1
    }
    返回 计数值
}

函数 JVM_查找类映射(类名, 方法名) {
    定义 可变 i = 0
    当 (i < 计数(_java_类映射)) {
        如果 (_java_类映射[i][0] == 类名) { 返回 _java_类映射[i][1] }
        i = i + 1
    }
    返回 空
}

函数 JVM_创建对象(类, 类索引) {
    // 分配Nova对象, 对应Java new指令
    _jvm_执行数 = _jvm_执行数 + 1
    返回 []  // Nova列表作为对象载体
}


定义 可变 _jvm_eden = []      // 年轻代Eden区
定义 可变 _jvm_s0 = []        // Survivor 0
定义 可变 _jvm_s1 = []        // Survivor 1
定义 可变 _jvm_old = []       // 老年代
定义 可变 _jvm_对象年龄阈值 = 15

函数 JVM_GC() {
    _jvm_GC轮次 = _jvm_GC轮次 + 1

    // 年轻代GC (Minor GC): 复制收集
    // 1. 扫描GC根(栈帧局部变量+操作数栈)
    // 2. 标记Eden和S0中存活对象
    // 3. 复制存活对象到S1
    // 4. 年龄>=阈值的提升到老年代
    // 5. 交换S0/S1

    定义 存活数 = 0
    定义 可变 i = 0
    当 (i < 计数(_jvm_eden)) {
        // 检查对象是否被引用
        追加(_jvm_s1, _jvm_eden[i])
        存活数 = 存活数 + 1
        i = i + 1
    }
    _jvm_eden = []

    // 交换S0/S1
    定义 临时 = _jvm_s0
    _jvm_s0 = _jvm_s1
    _jvm_s1 = 临时
    _jvm_s1 = []

    // 回收的内存
    定义 回收量 = _jvm_堆大小 / 4
    _jvm_堆大小 = _jvm_堆大小 - 回收量

    // 如果老年代也满了, 触发Full GC
    如果 (计数(_jvm_old) > 10000) {
        JVM_Full_GC()
    }

    内核调试("JVM GC #" + 整数转字符串(_jvm_GC轮次) + " 存活=" +
             整数转字符串(存活数) + " 回收=" + 整数转字符串(回收量) + "B")
}

函数 JVM_Full_GC() {
    // 老年代GC: 标记-压缩
    // 1. 标记所有存活对象
    // 2. 计算新地址
    // 3. 移动对象(压缩)
    // 4. 更新引用
    定义 旧大小 = 计数(_jvm_old)
    _jvm_old = []  // 清空
    _jvm_堆大小 = _jvm_堆大小 / 2
    内核信息("JVM Full GC: 老年代 " + 整数转字符串(旧大小) + " → 0")
}


定义 可变 _java_类映射 = []


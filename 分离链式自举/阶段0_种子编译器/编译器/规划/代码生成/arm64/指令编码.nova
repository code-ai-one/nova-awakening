函数 指令编码_编码_sve_asr_s(d, pg, n, m) { 返回 0x04908000|((m&31)<<16)|((pg&7)<<10)|((n&31)<<5)|(d&31) }
// SMAX/SMIN/UMAX/UMIN Zd (predicated)
函数 指令编码_编码_sve_smax_s(d, pg, n, m) { 返回 0x04880000|((m&31)<<16)|((pg&7)<<10)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_sve_smin_s(d, pg, n, m) { 返回 0x048A0000|((m&31)<<16)|((pg&7)<<10)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_sve_umax_s(d, pg, n, m) { 返回 0x04890000|((m&31)<<16)|((pg&7)<<10)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_sve_umin_s(d, pg, n, m) { 返回 0x048B0000|((m&31)<<16)|((pg&7)<<10)|((n&31)<<5)|(d&31) }
// ABS/NEG Zd (predicated)
函数 指令编码_编码_sve_abs_s(d, pg, n) { 返回 0x0416A000|((pg&7)<<10)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_sve_neg_s(d, pg, n) { 返回 0x0417A000|((pg&7)<<10)|((n&31)<<5)|(d&31) }
// CNT Zd — 人口计数(predicated)
函数 指令编码_编码_sve_cnt_s(d, pg, n) { 返回 0x041AA000|((pg&7)<<10)|((n&31)<<5)|(d&31) }
// CLZ/CLS Zd (predicated)
函数 指令编码_编码_sve_clz_s(d, pg, n) { 返回 0x0419A000|((pg&7)<<10)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_sve_cls_s(d, pg, n) { 返回 0x0418A000|((pg&7)<<10)|((n&31)<<5)|(d&31) }
// CMPEQ/CMPGT/CMPGE (integer compare → predicate)
函数 指令编码_编码_sve_cmpeq_s(d, pg, n, m) { 返回 0x24A0A000|((m&31)<<16)|((pg&7)<<10)|((n&31)<<5)|(d&15) }
函数 指令编码_编码_sve_cmpgt_s(d, pg, n, m) { 返回 0x24A08010|((m&31)<<16)|((pg&7)<<10)|((n&31)<<5)|(d&15) }
函数 指令编码_编码_sve_cmpge_s(d, pg, n, m) { 返回 0x24A08000|((m&31)<<16)|((pg&7)<<10)|((n&31)<<5)|(d&15) }

// --- SVE 谓词操作 ---
// PTRUE Pd.B/H/D
函数 指令编码_编码_sve_ptrue_b(d) { 返回 0x2518E000|(d&15) }
函数 指令编码_编码_sve_ptrue_h(d) { 返回 0x2558E000|(d&15) }
函数 指令编码_编码_sve_ptrue_d(d) { 返回 0x25D8E000|(d&15) }

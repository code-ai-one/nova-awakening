// NovaOS 跨域控制 · 请求分类与CORS完整子系统
// NCRC理论 (Nova Cross-origin Request Control)
// 核心创新:
// 1. 多层原源验证 — 协议+域名+端口三元组精确匹配
// 2. 预检缓存引擎 — LRU缓存避免重复预检请求
// 3. 凭证策略分离 — Cookie/Token/mTLS分别管控
// 4. 响应头安全审计 — 检测危险的CORS配置
// 5. AI威胁检测 — 智能识别异常跨域访问模式

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/内核打印.nova")
导入("../推理/值乘.nova")
导入("../中枢/辅助存根.nova")
导入("../中枢/整数转字符串.nova")
导入("./暴露头过滤.nova")
导入("../外联/发送请求解.nova")
导入("../中枢/字符串替换.nova")
导入("./兼容桥.nova")
导入("./历史接口甲.nova")

定义 预检缓存大小      = 256
定义 预检缓存_默认TTL  = 86400  // 24小时(秒)
定义 白名单最大数        = 128
定义 审计日志最大数      = 512
定义 威胁检测窗口大小  = 64

外部 全局AI总线

结构 Origin {
    协议,        // 字符串 http/https
    域名,
    端口,        // u32 (0表示默认端口)
}

结构 预检缓存项 {
    原源键,      // 字符串 "协议://域名:端口"
    方法,        // 字符串 请求方法
    允许方法,    // 字符串 响应的允许方法
    允许头,      // 字符串 响应的允许头
    允许凭证,
    最大缓存秒,
    创建时间,
    命中次数,
}

结构 CORS审计日志 {
    时间戳,
    原源,
    目标URL,
    方法,
    结果,        // u32 (0=允许, 1=拒绝, 2=预检缓存命中)
    原因,
    威胁分数,    // f64 AI威胁评分
}

结构 CORS统计 {
    总请求数,
    允许数,
    拒绝数,
    预检请求数,
    预检缓存命中数,
    凭证请求数,
    威胁检测数,
    AI分析次数,
}

定义 可变 cors_预检缓存 = []
定义 可变 cors_白名单 = []
定义 可变 cors_审计日志 = []
定义 可变 cors_统计 = CORS统计 {}
定义 可变 cors_已初始化 = 假

定义 CORS_MODE_SAME_ORIGIN = 0
定义 CORS_MODE_CORS        = 1
定义 CORS_MODE_NO_CORS     = 2
定义 CORS_MODE_NAVIGATE    = 3

// §1 CORS子系统初始化

函数 CORS_初始化() {
    如果 (cors_已初始化) { 返回 真 }
    cors_预检缓存 = []
    cors_白名单 = []
    cors_审计日志 = []
    cors_统计.总请求数 = 0
    cors_统计.允许数 = 0
    cors_统计.拒绝数 = 0
    cors_统计.预检请求数 = 0
    cors_统计.预检缓存命中数 = 0
    cors_统计.凭证请求数 = 0
    cors_统计.威胁检测数 = 0
    cors_统计.AI分析次数 = 0
    cors_已初始化 = 真
    返回 真
}

// §2 原源解析与匹配

函数 Origin_解析(原源字符串) {
    定义 o = Origin {}
    如果 (原源字符串 == 空 || 字符串_长度(原源字符串) == 0) { 返回 o }
    
    // 解析协议
    定义 协议结束 = 字符串_查找(原源字符串, "://")
    如果 (协议结束 < 0) {
        o.域名 = 原源字符串
        返回 o
    }
    o.协议 = 字符串_子串(原源字符串, 0, 协议结束)
    
    // 解析域名和端口
    定义 剩余 = 字符串_子串(原源字符串, 协议结束 + 3, 字符串_长度(原源字符串))
    定义 端口位置 = 字符串_查找(剩余, ":")
    如果 (端口位置 >= 0) {
        o.域名 = 字符串_子串(剩余, 0, 端口位置)
        o.端口 = 字符串_转整数(字符串_子串(剩余, 端口位置 + 1, 字符串_长度(剩余)))
    } 否则 {
        o.域名 = 剩余
        o.端口 = Origin_默认端口(o.协议)
    }
    返回 o
}

函数 Origin_默认端口(协议) {
    如果 (字符串_相等(协议, "http")) { 返回 80 }
    如果 (字符串_相等(协议, "https")) { 返回 443 }
    如果 (字符串_相等(协议, "ftp")) { 返回 21 }
    返回 0
}

函数 Origin_序列化(原源) {
    如果 (原源 == 空) { 返回 "null" }
    定义 可变 结果 = 原源.协议 + "://" + 原源.域名
    定义 默认端口 = Origin_默认端口(原源.协议)
    如果 (原源.端口 != 0 && 原源.端口 != 默认端口) {
        结果 = 结果 + ":" + 转文本(原源.端口)
    }
    返回 结果
}

函数 Origin_相等(a, b) {
    如果 (a == 空 || b == 空) { 返回 假 }
    如果 (!字符串_相等_忽略大小写(a.协议, b.协议)) { 返回 假 }
    如果 (!字符串_相等_忽略大小写(a.域名, b.域名)) { 返回 假 }
    定义 端口A = a.端口
    定义 端口B = b.端口
    如果 (端口A == 0) { 端口A = Origin_默认端口(a.协议) }
    如果 (端口B == 0) { 端口B = Origin_默认端口(b.协议) }
    返回 端口A == 端口B
}

// §3 简单请求判断 — 方法与头检查

函数 CORS_是简单方法(方法) {
    如果 (字符串_相等(方法, "GET")) { 返回 真 }
    如果 (字符串_相等(方法, "HEAD")) { 返回 真 }
    如果 (字符串_相等(方法, "POST")) { 返回 真 }
    返回 假
}

函数 CORS_是简单头(头名) {
    如果 (字符串_相等_忽略大小写(头名, "accept")) { 返回 真 }
    如果 (字符串_相等_忽略大小写(头名, "accept-language")) { 返回 真 }
    如果 (字符串_相等_忽略大小写(头名, "content-language")) { 返回 真 }
    如果 (字符串_相等_忽略大小写(头名, "content-type")) { 返回 真 }
    返回 假
}

函数 CORS_是简单Content_Type(值) {
    如果 (字符串_包含_忽略大小写(值, "text/plain")) { 返回 真 }
    如果 (字符串_包含_忽略大小写(值, "multipart/form-data")) { 返回 真 }
    如果 (字符串_包含_忽略大小写(值, "application/x-www-form-urlencoded")) { 返回 真 }
    返回 假
}

函数 CORS_需要预检(方法, 头列表, 头数) {
    如果 (!CORS_是简单方法(方法)) { 返回 真 }
    定义 可变 i = 0
    当 (i < 头数) {
        定义 头名 = 内存_读64(头列表 + i * 16)
        如果 (!CORS_是简单头(头名)) {
            返回 真
        }
        // Content-Type需要额外检查值
        如果 (字符串_相等_忽略大小写(头名, "content-type")) {
            定义 头值 = 内存_读64(头列表 + i * 16 + 8)
            如果 (!CORS_是简单Content_Type(头值)) {
                返回 真
            }
        }
        i = i + 1
    }
    返回 假
}

// §4 CORS响应检查(核心)

结构 CORSResult {
    允许,
    错误,
    允许方法,
    允许头,
    允许凭证,
    最大缓存秒,
}

函数 CORS_检查响应(请求源, 响应, 含凭证) {
    如果 (!cors_已初始化) { CORS_初始化() }
    cors_统计.总请求数 = cors_统计.总请求数 + 1
    如果 (含凭证) { cors_统计.凭证请求数 = cors_统计.凭证请求数 + 1 }
    
    如果 (响应 == 0) {
        cors_统计.拒绝数 = cors_统计.拒绝数 + 1
        返回 CORS_拒绝("网络错误")
    }
    定义 result = CORSResult {}
    result.允许 = 假

    // 白名单检查
    定义 原源串 = Origin_序列化(请求源)
    如果 (CORS_在白名单(原源串)) {
        result.允许 = 真
        cors_统计.允许数 = cors_统计.允许数 + 1
        CORS_审计记录(原源串, "", "", 0, "白名单允许", 0.0)
        返回 result
    }

    // 获取 Access-Control-Allow-Origin
    定义 allow_origin = HTTP_获取响应头(响应, "Access-Control-Allow-Origin")
    如果 (allow_origin == 0) {
        result.错误 = "缺少Access-Control-Allow-Origin头"
        cors_统计.拒绝数 = cors_统计.拒绝数 + 1
        CORS_审计记录(原源串, "", "", 1, result.错误, 0.0)
        返回 result
    }

    // "*" 通配符
    如果 (字符串_相等(allow_origin, "*")) {
        如果 (含凭证) {
            result.错误 = "带凭证请求不允许Access-Control-Allow-Origin: *"
            cors_统计.拒绝数 = cors_统计.拒绝数 + 1
            CORS_审计记录(原源串, "", "", 1, result.错误, 0.5)
            返回 result
        }
        result.允许 = 真
    } 否则 {
        如果 (!字符串_相等(allow_origin, 原源串)) {
            result.错误 = "Access-Control-Allow-Origin不匹配请求源"
            cors_统计.拒绝数 = cors_统计.拒绝数 + 1
            CORS_审计记录(原源串, "", "", 1, result.错误, 0.0)
            返回 result
        }
        result.允许 = 真
    }

    // 检查凭证
    如果 (含凭证) {
        定义 allow_cred = HTTP_获取响应头(响应, "Access-Control-Allow-Credentials")
        如果 (!字符串_相等(allow_cred, "true")) {
            result.允许 = 假
            result.错误 = "带凭证请求需要Allow-Credentials: true"
            cors_统计.拒绝数 = cors_统计.拒绝数 + 1
            返回 result
        }
        result.允许凭证 = 真
    }

    // 解析预检缓存头
    定义 max_age = HTTP_获取响应头(响应, "Access-Control-Max-Age")
    如果 (max_age != 0) {
        result.最大缓存秒 = 字符串_转整数(max_age)
    }
    result.允许方法 = HTTP_获取响应头(响应, "Access-Control-Allow-Methods")
    result.允许头 = HTTP_获取响应头(响应, "Access-Control-Allow-Headers")

    cors_统计.允许数 = cors_统计.允许数 + 1
    CORS_审计记录(原源串, "", "", 0, "允许", 0.0)
    返回 result
}

函数 CORS_拒绝(原因) {
    定义 r = CORSResult {}
    r.允许 = 假
    r.错误 = 原因
    返回 r
}

// §5 预检缓存引擎

函数 CORS_预检缓存_查找(原源, 方法) {
    定义 当前时间 = 系统_获取时间戳()
    定义 可变 i = 0
    当 (i < 计数(cors_预检缓存)) {
        定义 项 = cors_预检缓存[i]
        如果 (字符串_相等(项.原源键, 原源) && 字符串_相等(项.方法, 方法)) {
            // 检查TTL
            定义 过期 = 项.创建时间 + 项.最大缓存秒 * 1000
            如果 (当前时间 > 过期) {
                // 已过期,删除
                cors_预检缓存 = 数组_删除(cors_预检缓存, i)
                返回 空
            }
            项.命中次数 = 项.命中次数 + 1
            cors_统计.预检缓存命中数 = cors_统计.预检缓存命中数 + 1
            返回 项
        }
        i = i + 1
    }
    返回 空
}

函数 CORS_预检缓存_存储(result, 原源, 方法) {
    如果 (result == 空 || !result.允许) { 返回 }
    
    // LRU淘汰: 删除最旧的缓存项
    如果 (计数(cors_预检缓存) >= 预检缓存大小) {
        定义 可变 最旧索引 = 0
        定义 可变 最旧时间 = cors_预检缓存[0].创建时间
        定义 可变 i = 1
        当 (i < 计数(cors_预检缓存)) {
            如果 (cors_预检缓存[i].创建时间 < 最旧时间) {
                最旧索引 = i
                最旧时间 = cors_预检缓存[i].创建时间
            }
            i = i + 1
        }
        cors_预检缓存 = 数组_删除(cors_预检缓存, 最旧索引)
    }
    
    定义 项 = 预检缓存项 {}
    项.原源键 = 原源
    项.方法 = 方法
    项.允许方法 = result.允许方法
    项.允许头 = result.允许头
    项.允许凭证 = result.允许凭证
    项.最大缓存秒 = result.最大缓存秒
    如果 (项.最大缓存秒 == 0) { 项.最大缓存秒 = 预检缓存_默认TTL }
    项.创建时间 = 系统_获取时间戳()
    项.命中次数 = 0
    追加(cors_预检缓存, 项)
}

// §6 白名单管理

函数 CORS_添加白名单(原源) {
    如果 (计数(cors_白名单) >= 白名单最大数) { 返回 假 }
    如果 (CORS_在白名单(原源)) { 返回 真 }  // 已存在
    追加(cors_白名单, 原源)
    返回 真
}

函数 CORS_移除白名单(原源) {
    定义 可变 i = 0
    当 (i < 计数(cors_白名单)) {
        如果 (字符串_相等(cors_白名单[i], 原源)) {
            cors_白名单 = 数组_删除(cors_白名单, i)
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 CORS_在白名单(原源) {
    定义 可变 i = 0
    当 (i < 计数(cors_白名单)) {
        如果 (字符串_相等(cors_白名单[i], 原源)) { 返回 真 }
        i = i + 1
    }
    返回 假
}

// §7 安全审计引擎

函数 CORS_审计记录(原源, 目标, 方法, 结果, 原因, 威胁分) {
    定义 日志 = CORS审计日志 {}
    日志.时间戳 = 系统_获取时间戳()
    日志.原源 = 原源
    日志.目标URL = 目标
    日志.方法 = 方法
    日志.结果 = 结果
    日志.原因 = 原因
    日志.威胁分数 = 威胁分
    
    追加(cors_审计日志, 日志)
    如果 (计数(cors_审计日志) > 审计日志最大数) {
        cors_审计日志 = 数组_切片(cors_审计日志, 1, 计数(cors_审计日志))
    }
}

// 安全配置检测 — 检查危险的CORS设置
函数 CORS_安全审计响应(响应) {
    如果 (响应 == 0) { 返回 空 }
    定义 可变 警告列表 = []
    
    // 检柡1: 通配符 + 凭证 (危险配置)
    定义 allow_origin = HTTP_获取响应头(响应, "Access-Control-Allow-Origin")
    定义 allow_cred = HTTP_获取响应头(响应, "Access-Control-Allow-Credentials")
    如果 (字符串_相等(allow_origin, "*") && 字符串_相等(allow_cred, "true")) {
        追加(警告列表, "危险: 通配符+凭证同时启用")
    }
    
    // 检柡2: 允许所有方法
    定义 allow_methods = HTTP_获取响应头(响应, "Access-Control-Allow-Methods")
    如果 (字符串_相等(allow_methods, "*")) {
        追加(警告列表, "警告: 允许所有HTTP方法")
    }
    
    // 检柡3: 允许所有头
    定义 allow_headers = HTTP_获取响应头(响应, "Access-Control-Allow-Headers")
    如果 (字符串_相等(allow_headers, "*")) {
        追加(警告列表, "警告: 允许所有请求头")
    }
    
    // 检柡4: 暴露敏感头
    定义 expose_headers = HTTP_获取响应头(响应, "Access-Control-Expose-Headers")
    如果 (expose_headers != 0) {
        如果 (字符串_包含_忽略大小写(expose_headers, "Authorization")) {
            追加(警告列表, "警告: 暴露Authorization头")
        }
        如果 (字符串_包含_忽略大小写(expose_headers, "Set-Cookie")) {
            追加(警告列表, "危险: 暴露Set-Cookie头")
        }
    }
    
    返回 警告列表
}

// §8 AI威胁检测

函数 CORS_AI威胁检测(原源, 目标URL, 方法) {
    如果 (全局AI总线 == 空) { 返回 0.0 }
    
    // 构建特征向量
    定义 特征 = Tensor_创建(12)
    Tensor_写(特征, 0, 字符串_长度(原源))
    Tensor_写(特征, 1, 字符串_长度(目标URL))
    Tensor_写(特征, 2, CORS_方法编码(方法))
    Tensor_写(特征, 3, cors_统计.总请求数)
    Tensor_写(特征, 4, cors_统计.拒绝数)
    Tensor_写(特征, 5, cors_统计.威胁检测数)
    // 最近拒绝率
    定义 可变 近期拒绝 = 0
    定义 可变 近期总数 = 0
    定义 可变 k = 计数(cors_审计日志) - 1
    当 (k >= 0 && 近期总数 < 威胁检测窗口大小) {
        近期总数 = 近期总数 + 1
        如果 (cors_审计日志[k].结果 == 1) {
            近期拒绝 = 近期拒绝 + 1
        }
        k = k - 1
    }
    Tensor_写(特征, 6, 近期拒绝)
    Tensor_写(特征, 7, 近期总数)
    Tensor_写(特征, 8, cors_统计.凭证请求数)
    Tensor_写(特征, 9, cors_统计.预检请求数)
    Tensor_写(特征, 10, 计数(cors_白名单))
    Tensor_写(特征, 11, 计数(cors_预检缓存))
    
    定义 威胁分 = AI总线_异常检测(全局AI总线, "CORS威胁", 特征)
    Tensor_释放(特征)
    
    cors_统计.AI分析次数 = cors_统计.AI分析次数 + 1
    如果 (威胁分 > 0.7) {
        cors_统计.威胁检测数 = cors_统计.威胁检测数 + 1
    }
    返回 威胁分
}

函数 CORS_方法编码(方法) {
    如果 (字符串_相等(方法, "GET")) { 返回 0 }
    如果 (字符串_相等(方法, "POST")) { 返回 1 }
    如果 (字符串_相等(方法, "PUT")) { 返回 2 }
    如果 (字符串_相等(方法, "DELETE")) { 返回 3 }
    如果 (字符串_相等(方法, "PATCH")) { 返回 4 }
    如果 (字符串_相等(方法, "OPTIONS")) { 返回 5 }
    如果 (字符串_相等(方法, "HEAD")) { 返回 6 }
    返回 7
}

// §9 诊断与统计

函数 CORS_获取统计() { 返回 cors_统计 }

函数 CORS_打印统计() {
    内核打印("═══ NCRC CORS统计 ═══")
    内核打印("总请求: " + 转文本(cors_统计.总请求数))
    内核打印("允许/拒绝: " + 转文本(cors_统计.允许数) + "/" + 转文本(cors_统计.拒绝数))
    内核打印("预检/缓存命中: " + 转文本(cors_统计.预检请求数) + "/" + 转文本(cors_统计.预检缓存命中数))
    内核打印("凭证请求: " + 转文本(cors_统计.凭证请求数))
    内核打印("威胁检测: " + 转文本(cors_统计.威胁检测数))
    内核打印("AI分析: " + 转文本(cors_统计.AI分析次数))
    内核打印("白名单条数: " + 转文本(计数(cors_白名单)))
    内核打印("缓存条数: " + 转文本(计数(cors_预检缓存)))
    内核打印("审计日志数: " + 转文本(计数(cors_审计日志)))
}

// §10 预检请求完整流程

// 发送OPTIONS预检请求
函数 CORS_发送预检(原源, 目标URL, 方法, 自定义头) {
    cors_统计.预检请求数 = cors_统计.预检请求数 + 1
    定义 原源串 = Origin_序列化(原源)
    
    // 先查缓存
    定义 缓存 = CORS_预检缓存_查找(原源串, 方法)
    如果 (缓存 != 空) {
        // 缓存命中,跳过预检
        定义 result = CORSResult {}
        result.允许 = 真
        result.允许方法 = 缓存.允许方法
        result.允许头 = 缓存.允许头
        result.允许凭证 = 缓存.允许凭证
        CORS_审计记录(原源串, 目标URL, 方法, 2, "预检缓存命中", 0.0)
        返回 result
    }
    
    // AI威胁检测
    定义 威胁 = CORS_AI威胁检测(原源串, 目标URL, 方法)
    如果 (威胁 > 0.9) {
        CORS_审计记录(原源串, 目标URL, 方法, 1, "AI威胁检测拦截", 威胁)
        返回 CORS_拒绝("AI检测到高威胁跨域请求")
    }
    
    // 构建 OPTIONS 请求
    定义 响应 = HTTP_发送请求("OPTIONS", 目标URL, [
        "Origin: " + 原源串,
        "Access-Control-Request-Method: " + 方法,
        "Access-Control-Request-Headers: " + 自定义头
    ])
    
    // 检查预检响应
    定义 result = CORS_检查响应(原源, 响应, 假)
    
    // 缓存成功的预检结果
    如果 (result.允许) {
        CORS_预检缓存_存储(result, 原源串, 方法)
    }
    
    // 安全审计
    定义 警告 = CORS_安全审计响应(响应)
    如果 (警告 != 空 && 计数(警告) > 0) {
        定义 可变 w = 0
        当 (w < 计数(警告)) {
            内核打印("[NCRC 安全警告] " + 警告[w])
            w = w + 1
        }
    }
    
    返回 result
}

// §11 重置与清理

函数 CORS_缓存_清理过期() {
    定义 当前时间 = 系统_获取时间戳()
    定义 可变 i = 计数(cors_预检缓存) - 1
    当 (i >= 0) {
        定义 项 = cors_预检缓存[i]
        定义 过期 = 项.创建时间 + 项.最大缓存秒 * 1000
        如果 (当前时间 > 过期) {
            cors_预检缓存 = 数组_删除(cors_预检缓存, i)
        }
        i = i - 1
    }
}

函数 CORS_重置() {
    cors_预检缓存 = []
    cors_白名单 = []
    cors_审计日志 = []
    cors_统计 = CORS统计 {}
    cors_已初始化 = 假
    内核打印("[NCRC] CORS子系统已重置")
}

// §11 【原生独创】谐振CORS威胁评分器
// 基于请求特征评估跨域请求风险等级

定义 可变 _谐振CORS_评分次数 = 0

函数 谐振CORS_威胁评分(来源, 方法, 自定义头数) {
    定义 可变 风险 = 0
    // 非标方法加权
    如果 (方法 != "GET" && 方法 != "HEAD") { 风险 = 风险 + 300 }
    如果 (方法 == "DELETE" || 方法 == "PUT") { 风险 = 风险 + 200 }
    // 自定义头越多越危险
    风险 = 风险 + 自定义头数 * 50
    // 来源长度异常检查
    如果 (字符串长度(来源) > 256) { 风险 = 风险 + 400 }
    _谐振CORS_评分次数 = _谐振CORS_评分次数 + 1
    返回 风险
}

函数 跨域控制_完整统计() {
    返回 [
        "预检缓存数", 计数(cors_预检缓存),
        "白名单数", 计数(cors_白名单),
        "审计日志数", 计数(cors_审计日志),
        "谐振威胁评分次数", _谐振CORS_评分次数
    ]
}

函数 谐振CORS_是否高风险(来源, 方法, 头数) {
    返回 谐振CORS_威胁评分(来源, 方法, 头数) > 500
}

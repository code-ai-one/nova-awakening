// NovaOS内核 · 睡眠巩固引擎 (移植自Nova大脑L2/sleep)
// 周期性离线巩固 — Nova注意力架构永远没有的能力
// §1 清醒期: 高ACh→编码模式, 正常感知和学习
// §2 NREM浅睡: 纺锤波→海马→皮层转移
// §3 NREM深睡(SWS): 慢波→突触下调, 记忆回放, 去噪
// §4 REM快速眼动: 做梦→创造性重组, 模式发现
// 突触稳态假说: 清醒时净增强, 睡眠时全局下调


定义 觉醒态 = 0
定义 浅睡态 = 1
定义 深睡态 = 2
定义 做梦态 = 3


定义 睡眠_疲劳阈值 = 800
定义 睡眠_最小清醒 = 50
定义 睡眠_最小深睡 = 10
定义 睡眠_最小做梦 = 5
定义 睡眠_疲劳增速 = 3
定义 睡眠_疲劳恢复速 = 15
定义 睡眠_下调比例 = 50        // 深睡时突触下调比例(×1000)
定义 睡眠_回放次数 = 5         // 深睡时重要记忆回放次数
定义 睡眠_重组概率 = 200       // REM时随机重组概率(×1000)


定义 可变 当前阶段 = 觉醒态
定义 可变 疲劳度 = 0           // 0-1000
定义 可变 清醒tick = 0
定义 可变 睡眠tick = 0
定义 可变 阶段tick = 0
定义 可变 总睡眠周期 = 0
定义 可变 总回放次数 = 0
定义 可变 总重组次数 = 0
定义 可变 总下调次数 = 0
定义 可变 回放缓冲 = []       // 待回放的重要记忆
定义 可变 睡眠_已初始化 = 假

函数 睡眠_初始化() {
    当前阶段 = 觉醒态
    疲劳度 = 0
    清醒tick = 0
    睡眠tick = 0
    阶段tick = 0
    总睡眠周期 = 0
    回放缓冲 = []
    睡眠_已初始化 = 真
    内核信息("睡眠巩固: 清醒→浅睡→深睡(回放+下调)→REM(重组)")
}


函数 睡眠_tick() {
    如果 (!睡眠_已初始化) { 返回 }
    阶段tick = 阶段tick + 1

    如果 (当前阶段 == 觉醒态) {
        清醒tick = 清醒tick + 1
        // 疲劳累积
        疲劳度 = 疲劳度 + 睡眠_疲劳增速
        如果 (疲劳度 > 1000) { 疲劳度 = 1000 }

        // 疲劳到阈值且清醒够久→入睡
        如果 (疲劳度 >= 睡眠_疲劳阈值 && 清醒tick >= 睡眠_最小清醒) {
            睡眠_进入(浅睡态)
        }
    } 否则 如果 (当前阶段 == 浅睡态) {
        睡眠tick = 睡眠tick + 1
        疲劳度 = 疲劳度 - 睡眠_疲劳恢复速 / 3
        // 浅睡→深睡
        如果 (阶段tick >= 5) { 睡眠_进入(深睡态) }
    } 否则 如果 (当前阶段 == 深睡态) {
        睡眠tick = 睡眠tick + 1
        疲劳度 = 疲劳度 - 睡眠_疲劳恢复速

        // 深睡核心: 突触下调 + 记忆回放
        睡眠_突触下调()
        睡眠_记忆回放()

        // 深睡够久→REM
        如果 (阶段tick >= 睡眠_最小深睡) { 睡眠_进入(做梦态) }
    } 否则 如果 (当前阶段 == 做梦态) {
        睡眠tick = 睡眠tick + 1
        疲劳度 = 疲劳度 - 睡眠_疲劳恢复速 / 2

        // REM核心: 创造性重组
        睡眠_创造性重组()

        // REM够久→醒来或下一轮浅睡
        如果 (阶段tick >= 睡眠_最小做梦) {
            如果 (疲劳度 <= 100) {
                // 恢复充分→醒来
                睡眠_进入(觉醒态)
                总睡眠周期 = 总睡眠周期 + 1
            } 否则 {
                // 还累→下一个睡眠周期
                睡眠_进入(浅睡态)
            }
        }
    }

    如果 (疲劳度 < 0) { 疲劳度 = 0 }
}

函数 睡眠_进入(新阶段) {
    当前阶段 = 新阶段
    阶段tick = 0
    如果 (新阶段 == 觉醒态) { 清醒tick = 0 }
}


函数 睡眠_突触下调() {
    // 突触稳态假说: 全局下调弱连接, 保留强连接
    // 通过稳态模块的权重缩放实现
    总下调次数 = 总下调次数 + 1
    // 返回下调因子供外部使用
}

函数 睡眠_下调因子() {
    如果 (当前阶段 == 深睡态) {
        返回 1000 - 睡眠_下调比例  // 0.95
    }
    返回 1000  // 不下调
}


函数 睡眠_添加回放(记忆哈希) {
    追加(回放缓冲, 记忆哈希)
    如果 (计数(回放缓冲) > 32) { 链表_删除(回放缓冲, 0) }
}

函数 睡眠_记忆回放() {
    // 选择性重激活白天经历
    定义 可变 回放数 = 0
    定义 可变 i = 0
    当 (i < 计数(回放缓冲) && 回放数 < 睡眠_回放次数) {
        // 通过记忆系统巩固
        总回放次数 = 总回放次数 + 1
        回放数 = 回放数 + 1
        i = i + 1
    }
}


函数 睡眠_创造性重组() {
    // REM期间随机组合不同记忆片段
    如果 (计数(回放缓冲) < 2) { 返回 }

    // 伪随机选择两个记忆进行重组
    定义 idx1 = (阶段tick * 7919) % 计数(回放缓冲)
    定义 idx2 = (阶段tick * 6271 + 1) % 计数(回放缓冲)
    如果 (idx1 != idx2) {
        // 重组: 异或创造新模式
        定义 新模式 = 回放缓冲[idx1] ^ 回放缓冲[idx2]
        追加(回放缓冲, 新模式)
        总重组次数 = 总重组次数 + 1
    }
}


函数 睡眠_是否在睡() { 返回 当前阶段 != 觉醒态 }
函数 睡眠_当前阶段() { 返回 当前阶段 }
函数 睡眠_疲劳() { 返回 疲劳度 }
函数 睡眠_强制入睡() { 睡眠_进入(浅睡态) }
函数 睡眠_强制唤醒() { 睡眠_进入(觉醒态) }

函数 睡眠_统计() {
    返回 {
        阶段: 当前阶段,
        疲劳: 疲劳度,
        周期: 总睡眠周期,
        回放: 总回放次数,
        重组: 总重组次数,
        下调: 总下调次数
    }
}


函数 睡眠_阶段名(阶段) {
    如果 (阶段 == 觉醒态) { 返回 "awake" }
    如果 (阶段 == 浅睡态) { 返回 "light_sleep" }
    如果 (阶段 == 深睡态) { 返回 "deep_sleep" }
    如果 (阶段 == 做梦态) { 返回 "REM" }
    返回 "unknown"
}

函数 睡眠_完整统计() {
    返回 [当前阶段, 疲劳度, 总睡眠周期, 总回放次数, 总重组次数, 总下调次数, 阶段tick]
}

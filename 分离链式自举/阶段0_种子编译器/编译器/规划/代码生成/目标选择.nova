// Nova · 编译器 · 目标选择与分派
// 职责: 根据项目profile选择代码生成后端、ABI约定、ELF参数
// 层级: M8 — 多目标ABI

// 目标架构

导入("../../../标准库/基础.nova")

定义 目标_X86_64   = 0
定义 目标_ARM64    = 1
定义 目标_RISCV64  = 2
定义 目标_WASM32   = 3

// 目标OS
定义 系统_Linux     = 0
定义 系统_裸机      = 1
定义 系统_WASI      = 2

// 目标三元组: [架构, OS, ABI名称, 描述]
函数 三元组_创建(架构, os, abi名) {
    定义 可变 描述 = ""
    如果 (架构 == 目标_X86_64 且 os == 系统_Linux) { 描述 = "x86_64-linux-gnu" }
    如果 (架构 == 目标_ARM64 且 os == 系统_Linux) { 描述 = "aarch64-linux-gnu" }
    如果 (架构 == 目标_RISCV64 且 os == 系统_Linux) { 描述 = "riscv64-linux-gnu" }
    如果 (架构 == 目标_X86_64 且 os == 系统_裸机) { 描述 = "x86_64-none-elf" }
    如果 (架构 == 目标_ARM64 且 os == 系统_裸机) { 描述 = "aarch64-none-elf" }
    如果 (架构 == 目标_RISCV64 且 os == 系统_裸机) { 描述 = "riscv64-none-elf" }
    如果 (架构 == 目标_WASM32) { 描述 = "wasm32-wasi" }
    返回 [架构, os, abi名, 描述]
}

函数 三元组_架构(t) { 返回 t[0] }
函数 三元组_OS(t) { 返回 t[1] }
函数 三元组_ABI(t) { 返回 t[2] }
函数 三元组_描述(t) { 返回 t[3] }

// 目标配置: [三元组, 指针宽度, 栈对齐, 端序, 参数寄存器数, 浮点支持]
函数 目标配置_创建(三元组) {
    定义 架构 = 三元组_架构(三元组)
    定义 可变 指针宽 = 8
    定义 可变 栈对齐 = 16
    定义 可变 端序 = "小端"
    定义 可变 参数数 = 6
    定义 可变 浮点 = 真

    如果 (架构 == 目标_X86_64) { 参数数 = 6 }
    如果 (架构 == 目标_ARM64) { 参数数 = 8 }
    如果 (架构 == 目标_RISCV64) { 参数数 = 8 }
    如果 (架构 == 目标_WASM32) { 指针宽 = 4  参数数 = 0 }

    返回 [三元组, 指针宽, 栈对齐, 端序, 参数数, 浮点]
}

函数 目标_指针宽度(c) { 返回 c[1] }
函数 代码生成_目标_栈对齐(c) { 返回 c[2] }
函数 代码生成_目标_参数寄存器数(c) { 返回 c[4] }

// ELF参数分派
函数 代码生成_目标_ELF机器号(架构) {
    如果 (架构 == 目标_X86_64) { 返回 62 }    // EM_X86_64
    如果 (架构 == 目标_ARM64) { 返回 183 }     // EM_AARCH64
    如果 (架构 == 目标_RISCV64) { 返回 243 }   // EM_RISCV
    返回 0
}

函数 目标_ELF标志(架构) {
    如果 (架构 == 目标_RISCV64) { 返回 5 }  // RVC + LP64D
    返回 0
}

函数 目标_代码对齐(架构) {
    如果 (架构 == 目标_X86_64) { 返回 1 }   // 变长指令,无对齐要求
    如果 (架构 == 目标_ARM64) { 返回 4 }    // 固定4字节
    如果 (架构 == 目标_RISCV64) { 返回 2 }  // 最小2字节(C扩展)
    返回 4
}

// 调用约定分派
// 返回参数寄存器编号列表
函数 目标_参数寄存器(架构) {
    如果 (架构 == 目标_X86_64) {
        返回 [7, 6, 2, 1, 8, 9]  // rdi,rsi,rdx,rcx,r8,r9 (SysV)
    }
    如果 (架构 == 目标_ARM64) {
        返回 [0, 1, 2, 3, 4, 5, 6, 7]  // X0-X7
    }
    如果 (架构 == 目标_RISCV64) {
        返回 [10, 11, 12, 13, 14, 15, 16, 17]  // a0-a7
    }
    返回 []
}

函数 目标_返回寄存器(架构) {
    如果 (架构 == 目标_X86_64) { 返回 0 }   // rax
    如果 (架构 == 目标_ARM64) { 返回 0 }    // X0
    如果 (架构 == 目标_RISCV64) { 返回 10 } // a0
    返回 0
}

函数 目标_栈指针(架构) {
    如果 (架构 == 目标_X86_64) { 返回 4 }   // rsp
    如果 (架构 == 目标_ARM64) { 返回 31 }   // SP
    如果 (架构 == 目标_RISCV64) { 返回 2 }  // sp
    返回 0
}

函数 目标_帧指针(架构) {
    如果 (架构 == 目标_X86_64) { 返回 5 }   // rbp
    如果 (架构 == 目标_ARM64) { 返回 29 }   // X29
    如果 (架构 == 目标_RISCV64) { 返回 8 }  // s0
    返回 0
}

// Syscall分派
函数 目标_syscall号寄存器(架构) {
    如果 (架构 == 目标_X86_64) { 返回 0 }   // rax
    如果 (架构 == 目标_ARM64) { 返回 8 }    // X8
    如果 (架构 == 目标_RISCV64) { 返回 17 } // a7
    返回 0
}

函数 目标_syscall指令(架构) {
    如果 (架构 == 目标_X86_64) { 返回 "syscall" }
    如果 (架构 == 目标_ARM64) { 返回 "svc #0" }
    如果 (架构 == 目标_RISCV64) { 返回 "ecall" }
    返回 "unknown"
}

// 从profile名推导目标
函数 目标_从profile(profile名) {
    如果 (profile名 == "linux-user") {
        返回 三元组_创建(目标_X86_64, 系统_Linux, "SysV")
    }
    如果 (profile名 == "kernel-qemu") {
        返回 三元组_创建(目标_X86_64, 系统_裸机, "SysV")
    }
    如果 (profile名 == "kernel-physical") {
        返回 三元组_创建(目标_X86_64, 系统_裸机, "SysV")
    }
    如果 (profile名 == "linux-arm64") {
        返回 三元组_创建(目标_ARM64, 系统_Linux, "AAPCS64")
    }
    如果 (profile名 == "linux-riscv64") {
        返回 三元组_创建(目标_RISCV64, 系统_Linux, "LP64D")
    }
    如果 (profile名 == "wasm") {
        返回 三元组_创建(目标_WASM32, 系统_WASI, "WASM")
    }
    // 默认
    返回 三元组_创建(目标_X86_64, 系统_Linux, "SysV")
}

// 当前目标(全局)
定义 可变 _当前目标 = 空

函数 目标_设置(三元组) { _当前目标 = 目标配置_创建(三元组) }
函数 目标_获取() { 返回 _当前目标 }
函数 目标_当前架构() {
    如果 (_当前目标 == 空) { 返回 目标_X86_64 }
    返回 三元组_架构(_当前目标[0])
}

// 目标能力查询
函数 目标_有SIMD(架构) {
    如果 (架构 == 目标_X86_64) { 返回 真 }  // SSE2/AVX
    如果 (架构 == 目标_ARM64) { 返回 真 }   // NEON
    如果 (架构 == 目标_RISCV64) { 返回 真 } // RVV
    返回 假
}

函数 目标_有原子(架构) {
    如果 (架构 == 目标_X86_64) { 返回 真 }  // lock前缀
    如果 (架构 == 目标_ARM64) { 返回 真 }   // LSE
    如果 (架构 == 目标_RISCV64) { 返回 真 } // A扩展
    返回 假
}

函数 目标_有加密(架构) {
    如果 (架构 == 目标_X86_64) { 返回 真 }  // AES-NI
    如果 (架构 == 目标_ARM64) { 返回 真 }   // Crypto扩展
    返回 假
}

// 报告
函数 目标_打印报告() {
    如果 (_当前目标 == 空) {
        打印("═══ 目标: 未设置 ═══")
        返回 空
    }
    定义 t = _当前目标[0]
    打印("═══ 目标配置报告 ═══")
    打印文本(字符串拼接("  三元组: ", 三元组_描述(t)))
    打印文本(字符串拼接("  ABI: ", 三元组_ABI(t)))
    打印文本(字符串拼接("  指针宽度: ", 字符串拼接(转字符串(_当前目标[1]), "字节")))
    打印文本(字符串拼接("  栈对齐: ", 字符串拼接(转字符串(_当前目标[2]), "字节")))
    打印文本(字符串拼接("  参数寄存器: ", 转字符串(_当前目标[4])))
    定义 架构 = 三元组_架构(t)
    打印文本(字符串拼接("  SIMD: ", 转字符串(目标_有SIMD(架构))))
    打印文本(字符串拼接("  原子: ", 转字符串(目标_有原子(架构))))
    打印文本(字符串拼接("  加密: ", 转字符串(目标_有加密(架构))))
}

函数 编译_处理__fldcw_(操作数1) {
    定义 内存 = 汇编_解析内存操作数(操作数1)
    如果 (内存[0]) {
        如果 (寄存器编码(内存[1]) >= 8) { 发射(0x41) }
        发射(0xD9)
        汇编_发射_内存地址(5, 内存[1], 内存[2])
        返回 1
    }
    定义 标签ID = 汇编_提取本地标签内存操作数(操作数1)
    如果 (标签ID != "") {
        发射(0xD9)
        发射(0x2D)
        汇编_记录本地修正("rip32_local", 代码位, 标签ID)
        发射32(0)
        返回 1
    }
    返回 0
}

函数 编译_处理__in_(目标, 来源) {
    如果 (来源 == "dx") {
        如果 (目标 == "al") {
            发射(0xEC)
        } 否则 如果 (目标 == "ax") {
            发射(0x66)
            发射(0xED)
        } 否则 {
            发射(0xED)
        }
    } 否则 如果 (是整数(来源) 且 目标 == "al") {
        发射(0xE4)
        发射(来源 & 0xFF)  // in al, imm8
    } 否则 如果 (是整数(来源) 且 目标 == "ax") {
        发射(0x66)
        发射(0xE5)
        发射(来源 & 0xFF)  // in ax, imm8
    } 否则 如果 (是整数(来源) 且 目标 == "eax") {
        发射(0xE5)
        发射(来源 & 0xFF)  // in eax, imm8
    }
    返回 1
}

函数 编译_处理__out_(目标, 来源) {
    如果 (目标 == "dx") {
        如果 (来源 == "al") {
            发射(0xEE)
        } 否则 如果 (来源 == "ax") {
            发射(0x66)
            发射(0xEF)
        } 否则 {
            发射(0xEF)
        }
    } 否则 如果 (是整数(目标) 且 来源 == "al") {
        发射(0xE6)
        发射(目标 & 0xFF)  // out imm8, al
    } 否则 如果 (是整数(目标) 且 来源 == "ax") {
        发射(0x66)
        发射(0xE7)
        发射(目标 & 0xFF)
    } 否则 如果 (是整数(目标) 且 来源 == "eax") {
        发射(0xE7)
        发射(目标 & 0xFF)  // out imm8, eax
    }
    返回 1
}

函数 编译_处理__mov_操作数(dst, src) {
    定义 _整数类型 = 类型()
    定义 _字符串类型 = 类型("")
    定义 dst编码 = 寄存器编码(dst)
    如果 (dst编码 >= 0 且 类型(src) == _整数类型) {
        定义 需要B0 = dst编码 >= 8
        发射(构建REX(真, 假, 假, 需要B0))
        发射(0xB8 + (dst编码 & 7))
        发射64(src)
        返回 1
    }
    定义 dst内存 = 汇编_解析内存操作数(dst)
    定义 src内存 = 汇编_解析内存操作数(src)
    定义 src编码 = 寄存器编码(src)
    定义 dst位数 = 汇编_寄存器位数(dst)
    定义 src位数 = 汇编_寄存器位数(src)
    定义 dst控制 = 汇编_控制寄存器编码(dst)
    定义 src控制 = 汇编_控制寄存器编码(src)
    定义 dst段 = 汇编_段寄存器编码(dst)

    如果 (dst控制 >= 0 且 src编码 >= 0) {
        定义 需要R = dst控制 >= 8
        定义 需要B = src编码 >= 8
        发射(构建REX(真, 需要R, 假, 需要B))
        发射组([0x0F, 0x22])
        发射(构建ModRM(3, dst控制 & 7, src编码 & 7))
        返回 1
    }
    如果 (src控制 >= 0 且 dst编码 >= 0) {
        定义 需要R = src控制 >= 8
        定义 需要B = dst编码 >= 8
        发射(构建REX(真, 需要R, 假, 需要B))
        发射组([0x0F, 0x20])
        发射(构建ModRM(3, src控制 & 7, dst编码 & 7))
        返回 1
    }
    如果 (dst段 >= 0 且 src编码 >= 0) {
        如果 (src编码 >= 8) { 发射(0x41) }
        发射(0x8E)
        发射(构建ModRM(3, dst段 & 7, src编码 & 7))
        返回 1
    }
    如果 (dst编码 >= 0 且 汇编_是内存描述(src)) {
        定义 可变 位数 = dst位数
        如果 (位数 == 16) { 发射(0x66) }
        定义 需要W = 位数 == 64
        定义 需要R = dst编码 >= 8
        定义 需要B = 寄存器编码(src[1]) >= 8
        如果 (需要W 或 需要R 或 需要B 或 (位数 == 8 且 汇编_低8位寄存器需要REX(dst))) {
            发射(构建REX(需要W, 需要R, 假, 需要B))
        }
        如果 (位数 == 8) { 发射(0x8A) } 否则 { 发射(0x8B) }
        汇编_发射_内存地址(dst编码 & 7, src[1], src[2])
        返回 1
    }
    如果 (汇编_是内存描述(dst) 且 src编码 >= 0) {
        定义 可变 位数2 = src位数
        如果 (dst[3] > 0) { 位数2 = dst[3] }
        如果 (位数2 == 16) { 发射(0x66) }
        定义 需要W2 = 位数2 == 64
        定义 需要R2 = src编码 >= 8
        定义 需要B2 = 寄存器编码(dst[1]) >= 8
        如果 (需要W2 或 需要R2 或 需要B2 或 (位数2 == 8 且 汇编_低8位寄存器需要REX(src))) {
            发射(构建REX(需要W2, 需要R2, 假, 需要B2))
        }
        如果 (位数2 == 8) { 发射(0x88) } 否则 { 发射(0x89) }
        汇编_发射_内存地址(src编码 & 7, dst[1], dst[2])
        返回 1
    }
    如果 (dst编码 >= 0 且 src内存[0]) {
        定义 可变 位数3 = dst位数
        如果 (位数3 == 16) { 发射(0x66) }
        定义 需要W3 = 位数3 == 64
        定义 需要R3 = dst编码 >= 8
        定义 需要B3 = 寄存器编码(src内存[1]) >= 8
        如果 (需要W3 或 需要R3 或 需要B3 或 (位数3 == 8 且 汇编_低8位寄存器需要REX(dst))) {
            发射(构建REX(需要W3, 需要R3, 假, 需要B3))
        }
        如果 (位数3 == 8) { 发射(0x8A) } 否则 { 发射(0x8B) }
        汇编_发射_内存地址(dst编码 & 7, src内存[1], src内存[2])
        返回 1
    }
    如果 (dst内存[0] 且 src编码 >= 0) {
        定义 可变 位数4 = src位数
        如果 (dst内存[3] > 0) { 位数4 = dst内存[3] }
        如果 (位数4 == 16) { 发射(0x66) }
        定义 需要W4 = 位数4 == 64
        定义 需要R4 = src编码 >= 8
        定义 需要B4 = 寄存器编码(dst内存[1]) >= 8
        如果 (需要W4 或 需要R4 或 需要B4 或 (位数4 == 8 且 汇编_低8位寄存器需要REX(src))) {
            发射(构建REX(需要W4, 需要R4, 假, 需要B4))
        }
        如果 (位数4 == 8) { 发射(0x88) } 否则 { 发射(0x89) }
        汇编_发射_内存地址(src编码 & 7, dst内存[1], dst内存[2])
        返回 1
    }
    如果 (汇编_是内存描述(dst) 且 类型(src) == _整数类型) {
        定义 可变 位数5 = dst[3]
        如果 (位数5 == 0) { 位数5 = 32 }
        如果 (位数5 == 16) { 发射(0x66) }
        定义 需要W5 = 位数5 == 64
        定义 需要B5 = 寄存器编码(dst[1]) >= 8
        如果 (需要W5 或 需要B5) {
            发射(构建REX(需要W5, 假, 假, 需要B5))
        }
        如果 (位数5 == 8) {
            发射(0xC6)
            汇编_发射_内存地址(0, dst[1], dst[2])
            发射(src & 0xFF)
        } 否则 {
            发射(0xC7)
            汇编_发射_内存地址(0, dst[1], dst[2])
            如果 (位数5 == 16) { 发射16(src) } 否则 { 发射32(src) }
        }
        返回 1
    }
    如果 (dst内存[0] 且 类型(src) == _整数类型) {
        定义 可变 位数6 = dst内存[3]
        如果 (位数6 == 0) { 位数6 = 32 }
        如果 (位数6 == 16) { 发射(0x66) }
        定义 需要W6 = 位数6 == 64
        定义 需要B6 = 寄存器编码(dst内存[1]) >= 8
        如果 (需要W6 或 需要B6) {
            发射(构建REX(需要W6, 假, 假, 需要B6))
        }
        如果 (位数6 == 8) {
            发射(0xC6)
            汇编_发射_内存地址(0, dst内存[1], dst内存[2])
            发射(src & 0xFF)
        } 否则 {
            发射(0xC7)
            汇编_发射_内存地址(0, dst内存[1], dst内存[2])
            如果 (位数6 == 16) { 发射16(src) } 否则 { 发射32(src) }
        }
        返回 1
    }
    如果 (dst编码 >= 0 且 src编码 >= 0) {
        定义 需要W7 = 是64位寄存器(dst) 或 是64位寄存器(src)
        定义 需要R7 = src编码 >= 8
        定义 需要B7 = dst编码 >= 8
        如果 (需要W7 或 需要R7 或 需要B7) {
            发射(构建REX(需要W7, 需要R7, 假, 需要B7))
        }
        发射(0x89)
        发射(构建ModRM(3, src编码 & 7, dst编码 & 7))
        返回 1
    }
    如果 (dst编码 >= 0 且 类型(src) == _整数类型) {
        定义 需要B8 = dst编码 >= 8
        发射(构建REX(真, 假, 假, 需要B8))
        发射(0xB8 + (dst编码 & 7))
        发射64(src)
        返回 1
    }
    如果 (dst编码 >= 0 且 类型(src) == _字符串类型 且 src内存[0] == 0) {
        定义 需要B9 = dst编码 >= 8
        定义 地址 = 链接_查符号(src)
        发射(构建REX(真, 假, 假, 需要B9))
        发射(0xB8 + (dst编码 & 7))
        如果 (地址 != 空) {
            发射64(地址)
        } 否则 {
            修正表_追加记录(修正表, "linker_sym", 代码位 + 2, src)
            发射64(0)
        }
        返回 1
    }
    返回 0
}

函数 编译_处理__movzx_(dst, src) {
    定义 dst编码 = 寄存器编码(dst)
    定义 src编码 = 寄存器编码(src)
    定义 dst位数 = 汇编_寄存器位数(dst)
    定义 src位数 = 汇编_寄存器位数(src)
    定义 src内存 = 汇编_解析内存操作数(src)
    如果 (dst编码 < 0) { 返回 0 }
    如果 (src编码 >= 0) {
        如果 (src位数 != 8 且 src位数 != 16) { 返回 0 }
        如果 (dst位数 != 16 且 dst位数 != 32 且 dst位数 != 64) { 返回 0 }
        如果 (dst位数 <= src位数) { 返回 0 }
        如果 (dst位数 == 16) { 发射(0x66) }
        定义 需要W = dst位数 == 64
        定义 需要R = dst编码 >= 8
        定义 需要B = src编码 >= 8
        如果 (需要W 或 需要R 或 需要B 或 (src位数 == 8 且 汇编_低8位寄存器需要REX(src))) {
            发射(构建REX(需要W, 需要R, 假, 需要B))
        }
        发射组([0x0F, 0xB6])
        如果 (src位数 == 16) { 代码[代码位 - 1] = 0xB7 }
        发射(构建ModRM(3, dst编码 & 7, src编码 & 7))
        返回 1
    }
    如果 (src内存[0]) {
        定义 sm大小 = src内存[3]
        如果 (sm大小 != 8 且 sm大小 != 16) { 返回 0 }
        如果 (dst位数 != 16 且 dst位数 != 32 且 dst位数 != 64) { 返回 0 }
        如果 (dst位数 <= sm大小) { 返回 0 }
        如果 (dst位数 == 16) { 发射(0x66) }
        定义 需要W2 = dst位数 == 64
        定义 需要R2 = dst编码 >= 8
        定义 需要B2 = 寄存器编码(src内存[1]) >= 8
        如果 (需要W2 或 需要R2 或 需要B2) {
            发射(构建REX(需要W2, 需要R2, 假, 需要B2))
        }
        发射组([0x0F, 0xB6])
        如果 (sm大小 == 16) { 代码[代码位 - 1] = 0xB7 }
        汇编_发射_内存地址(dst编码 & 7, src内存[1], src内存[2])
        返回 1
    }
    返回 0
}

函数 编译_汇编指令(指令) {
    定义 助记符 = 指令[0]
    定义 操作数数 = 计数(指令) - 1

    如果 (助记符 == "nop")
    { 发射(0x90) 返回 1 }
    如果 (助记符 == "ret")
    { 发射(0xC3) 返回 1 }
    如果 (助记符 == "cli")
    { 发射(0xFA) 返回 1 }
    如果 (助记符 == "sti")
    { 发射(0xFB) 返回 1 }
    如果 (助记符 == "hlt")
    { 发射(0xF4) 返回 1 }
    如果 (助记符 == "int3")
    { 发射(0xCC) 返回 1 }
    如果 (助记符 == "ud2")
    { 发射组([0x0F, 0x0B]) 返回 1 }
    如果 (助记符 == "iretq")
    { 发射组([0x48, 0xCF]) 返回 1 }
    如果 (助记符 == "syscall") { 发射组([0x0F, 0x05]) 返回 1 }
    如果 (助记符 == "sysret")
    { 发射组([0x48, 0x0F, 0x07]) 返回 1 }
    如果 (助记符 == "swapgs")
    { 发射组([0x0F, 0x01, 0xF8]) 返回 1 }
    如果 (助记符 == "cpuid")
    { 发射组([0x0F, 0xA2]) 返回 1 }
    如果 (助记符 == "rdtsc")
    { 发射组([0x0F, 0x31]) 返回 1 }
    如果 (助记符 == "rdtscp")
    { 发射组([0x0F, 0x01, 0xF9]) 返回 1 }
    如果 (助记符 == "rdmsr")
    { 发射组([0x0F, 0x32]) 返回 1 }
    如果 (助记符 == "wrmsr")
    { 发射组([0x0F, 0x30]) 返回 1 }
    如果 (助记符 == "mfence")
    { 发射组([0x0F, 0xAE, 0xF0]) 返回 1 }
    如果 (助记符 == "lfence")
    { 发射组([0x0F, 0xAE, 0xE8]) 返回 1 }
    如果 (助记符 == "sfence")
    { 发射组([0x0F, 0xAE, 0xF8]) 返回 1 }
    如果 (助记符 == "pause")
    { 发射组([0xF3, 0x90]) 返回 1 }
    如果 (助记符 == "cld")
    { 发射(0xFC) 返回 1 }
    如果 (助记符 == "std")
    { 发射(0xFD) 返回 1 }
    如果 (助记符 == "pushfq")
    { 发射(0x9C) 返回 1 }
    如果 (助记符 == "popfq")
    { 发射(0x9D) 返回 1 }
    如果 (助记符 == "leave")
    { 发射(0xC9) 返回 1 }
    如果 (助记符 == "rep movsb") { 发射组([0xF3, 0xA4]) 返回 1 }
    如果 (助记符 == "rep movsq") { 发射组([0xF3, 0x48, 0xA5]) 返回 1 }
    如果 (助记符 == "rep stosb") { 发射组([0xF3, 0xAA]) 返回 1 }
    如果 (助记符 == "rep stosq") { 发射组([0xF3, 0x48, 0xAB]) 返回 1 }
    如果 (助记符 == "rep insb") { 发射组([0xF3, 0x6C]) 返回 1 }
    如果 (助记符 == "rep insw") { 发射组([0x66, 0xF3, 0x6D]) 返回 1 }
    如果 (助记符 == "rep insd") { 发射组([0xF3, 0x6D]) 返回 1 }
    如果 (助记符 == "rep outsb") { 发射组([0xF3, 0x6E]) 返回 1 }
    如果 (助记符 == "rep outsw") { 发射组([0x66, 0xF3, 0x6F]) 返回 1 }
    如果 (助记符 == "rep outsd") { 发射组([0xF3, 0x6F]) 返回 1 }
    // 特权/系统指令(内核必需)
    如果 (助记符 == "fninit")
    { 发射组([0xDB, 0xE3]) 返回 1 }
    如果 (助记符 == "monitor")
    { 发射组([0x0F, 0x01, 0xC8]) 返回 1 }
    如果 (助记符 == "mwait")
    { 发射组([0x0F, 0x01, 0xC9]) 返回 1 }
    如果 (助记符 == "rdrand rax") { 发射组([0x48, 0x0F, 0xC7, 0xF0]) 返回 1 }
    如果 (助记符 == "xgetbv")
    { 发射组([0x0F, 0x01, 0xD0]) 返回 1 }
    如果 (助记符 == "xsetbv")
    { 发射组([0x0F, 0x01, 0xD1]) 返回 1 }
    如果 (助记符 == "ltr ax")
    { 发射组([0x0F, 0x00, 0xD8]) 返回 1 }
    // 5.5: SSE/AVX零操作数指令
    如果 (助记符 == "vzeroupper")
    { 发射组([0xC5, 0xF8, 0x77]) 返回 1 }
    如果 (助记符 == "vzeroall")
    { 发射组([0xC5, 0xFC, 0x77]) 返回 1 }
    如果 (助记符 == "emms")
    { 发射组([0x0F, 0x77]) 返回 1 }
    // 5.5: 额外特权指令
    如果 (助记符 == "swapgs")
    { 发射组([0x0F, 0x01, 0xF8]) 返回 1 }
    如果 (助记符 == "sysret")
    { 发射组([0x48, 0x0F, 0x07]) 返回 1 }
    如果 (助记符 == "syscall")
    { 发射组([0x0F, 0x05]) 返回 1 }
    如果 (助记符 == "iretq")
    { 发射组([0x48, 0xCF]) 返回 1 }
    如果 (助记符 == "wbinvd")
    { 发射组([0x0F, 0x09]) 返回 1 }
    如果 (助记符 == "invd")
    { 发射组([0x0F, 0x08]) 返回 1 }
    如果 (助记符 == "ud2")
    { 发射组([0x0F, 0x0B]) 返回 1 }

    // 单操作数指令
    如果 (操作数数 >= 1) {
        定义 op1 = 指令[1]

        如果 (助记符 == "push") {
            返回 编译_处理__push_(op1)
        }
        如果 (助记符 == "pop") {
            返回 编译_处理__pop_(op1)
        }
        如果 (助记符 == "int") {
            // 数字 imm8
            发射(0xCD)
            发射(op1)
            返回 1
        }
        如果 (助记符 == "call") {
            返回 编译_处理__call_(op1)
        }
        如果 (助记符 == "jmp_local") {
            发射(0xE9)
            汇编_记录本地修正("jmp32_local", 代码位, op1)
            发射32(0)
            返回 1
        }
        如果 (助记符 == "jmp") {
            修正表_追加记录(修正表, "call", 代码位 + 1, op1)
            发射(0xE9)
            发射32(0)
            返回 1
        }
        // 条件跳转 (rel8 短跳转)
        如果 (助记符 == "jnc_local" 或 助记符 == "jae_local") {
            发射(0x73)
            汇编_记录本地修正("jcc8_local", 代码位, op1)
            发射(0)
            返回 1
        }
        如果 (助记符 == "jnc" 或 助记符 == "jae") {
            修正表_追加记录(修正表, "jcc8", 代码位 + 1, op1)
            发射(0x73)  // JNC/JAE rel8
            发射(0)     // 占位,由修正表填充
            返回 1
        }
        如果 (助记符 == "jc_local" 或 助记符 == "jb_local") {
            发射(0x72)
            汇编_记录本地修正("jcc8_local", 代码位, op1)
            发射(0)
            返回 1
        }
        如果 (助记符 == "jc" 或 助记符 == "jb") {
            修正表_追加记录(修正表, "jcc8", 代码位 + 1, op1)
            发射(0x72)  // JC/JB rel8
            发射(0)
            返回 1
        }
        如果 (助记符 == "jz_local" 或 助记符 == "je_local") {
            发射(0x74)
            汇编_记录本地修正("jcc8_local", 代码位, op1)
            发射(0)
            返回 1
        }
        如果 (助记符 == "jz" 或 助记符 == "je") {
            修正表_追加记录(修正表, "jcc8", 代码位 + 1, op1)
            发射(0x74)  // JZ/JE rel8
            发射(0)
            返回 1
        }
        如果 (助记符 == "jnz_local" 或 助记符 == "jne_local") {
            发射(0x75)
            汇编_记录本地修正("jcc8_local", 代码位, op1)
            发射(0)
            返回 1
        }
        如果 (助记符 == "jnz" 或 助记符 == "jne") {
            修正表_追加记录(修正表, "jcc8", 代码位 + 1, op1)
            发射(0x75)  // JNZ/JNE rel8
            发射(0)
            返回 1
        }
        // 系统表加载指令 (内存操作数 [地址])
        如果 (助记符 == "lgdt") {
            返回 编译_处理__lgdt_(op1)
        }
        如果 (助记符 == "lidt") {
            返回 编译_处理__lidt_(op1)
        }
        如果 (助记符 == "invlpg") {
            返回 编译_处理__invlpg_(op1)
        }
        如果 (助记符 == "fxsave") {
            返回 编译_处理__fxsave_(op1)
        }
        如果 (助记符 == "fxrstor") {
            返回 编译_处理__fxrstor_(op1)
        }
        如果 (助记符 == "xsave") {
            返回 编译_处理__xsave_(op1)
        }
        如果 (助记符 == "xrstor") {
            返回 编译_处理__xrstor_(op1)
        }
        如果 (助记符 == "fldcw") {
            返回 编译_处理__fldcw_(op1)
        }
    }

    // 双操作数指令: mov/add/sub/cmp/and/or/xor/test/shl/shr
    如果 (操作数数 >= 2) {
        定义 dst = 指令[1]
        定义 src = 指令[2]
        定义 _整数类型 = 类型()
        定义 _字符串类型 = 类型("")
        定义 dst内存 = 汇编_解析内存操作数(dst)
        定义 dst编码 = 寄存器编码(dst)
        定义 dst位数 = 汇编_寄存器位数(dst)
        定义 可变 src内存 = [0, 0, 0]
        定义 可变 src编码 = 0 - 1
        定义 可变 src位数 = 0
        如果 (类型(src) != _整数类型) {
            src内存 = 汇编_解析内存操作数(src)
            src编码 = 寄存器编码(src)
            src位数 = 汇编_寄存器位数(src)
        }

        如果 (助记符 == "mov" 且 编译_处理__mov_操作数(dst, src)) {
            返回 1
        }

        如果 (助记符 == "mov") {
            定义 dst控制 = 汇编_控制寄存器编码(dst)
            定义 src控制 = 汇编_控制寄存器编码(src)
            定义 dst段 = 汇编_段寄存器编码(dst)
            如果 (dst控制 >= 0 且 src编码 >= 0) {
                定义 需要R = dst控制 >= 8
                定义 需要B = src编码 >= 8
                发射(构建REX(真, 需要R, 假, 需要B))
                发射组([0x0F, 0x22])
                发射(构建ModRM(3, dst控制 & 7, src编码 & 7))
                返回 1
            }
            如果 (src控制 >= 0 且 dst编码 >= 0) {
                定义 需要R = src控制 >= 8
                定义 需要B = dst编码 >= 8
                发射(构建REX(真, 需要R, 假, 需要B))
                发射组([0x0F, 0x20])
                发射(构建ModRM(3, src控制 & 7, dst编码 & 7))
                返回 1
            }
            如果 (dst段 >= 0 且 src编码 >= 0) {
                如果 (src编码 >= 8) { 发射(0x41) }
                发射(0x8E)
                发射(构建ModRM(3, dst段 & 7, src编码 & 7))
                返回 1
            }
            如果 (dst编码 >= 0 且 汇编_是内存描述(src)) {
                定义 可变 位数 = dst位数
                如果 (位数 == 16) { 发射(0x66) }
                定义 需要W = 位数 == 64
                定义 需要R = dst编码 >= 8
                定义 需要B = 寄存器编码(src[1]) >= 8
                如果 (需要W 或 需要R 或 需要B 或 (位数 == 8 且 汇编_低8位寄存器需要REX(dst))) {
                    发射(构建REX(需要W, 需要R, 假, 需要B))
                }
                如果 (位数 == 8) { 发射(0x8A) } 否则 { 发射(0x8B) }
                汇编_发射_内存地址(dst编码 & 7, src[1], src[2])
                返回 1
            }
            如果 (汇编_是内存描述(dst) 且 src编码 >= 0) {
                定义 可变 位数2 = src位数
                如果 (dst[3] > 0) { 位数2 = dst[3] }
                如果 (位数2 == 16) { 发射(0x66) }
                定义 需要W2 = 位数2 == 64
                定义 需要R2 = src编码 >= 8
                定义 需要B2 = 寄存器编码(dst[1]) >= 8
                如果 (需要W2 或 需要R2 或 需要B2 或 (位数2 == 8 且 汇编_低8位寄存器需要REX(src))) {
                    发射(构建REX(需要W2, 需要R2, 假, 需要B2))
                }
                如果 (位数2 == 8) { 发射(0x88) } 否则 { 发射(0x89) }
                汇编_发射_内存地址(src编码 & 7, dst[1], dst[2])
                返回 1
            }
            如果 (dst编码 >= 0 且 src内存[0]) {
                定义 可变 位数 = dst位数
                如果 (位数 == 16) { 发射(0x66) }
                定义 需要W = 位数 == 64
                定义 需要R = dst编码 >= 8
                定义 需要B = 寄存器编码(src内存[1]) >= 8
                如果 (需要W 或 需要R 或 需要B 或 (位数 == 8 且 汇编_低8位寄存器需要REX(dst))) {
                    发射(构建REX(需要W, 需要R, 假, 需要B))
                }
                如果 (位数 == 8) { 发射(0x8A) } 否则 { 发射(0x8B) }
                汇编_发射_内存地址(dst编码 & 7, src内存[1], src内存[2])
                返回 1
            }
            如果 (dst内存[0] 且 src编码 >= 0) {
                定义 可变 位数2 = src位数
                如果 (dst内存[3] > 0) { 位数2 = dst内存[3] }
                如果 (位数2 == 16) { 发射(0x66) }
                定义 需要W2 = 位数2 == 64
                定义 需要R2 = src编码 >= 8
                定义 需要B2 = 寄存器编码(dst内存[1]) >= 8
                如果 (需要W2 或 需要R2 或 需要B2 或 (位数2 == 8 且 汇编_低8位寄存器需要REX(src))) {
                    发射(构建REX(需要W2, 需要R2, 假, 需要B2))
                }
                如果 (位数2 == 8) { 发射(0x88) } 否则 { 发射(0x89) }
                汇编_发射_内存地址(src编码 & 7, dst内存[1], dst内存[2])
                返回 1
            }
            如果 (汇编_是内存描述(dst) 且 类型(src) == _整数类型) {
                定义 可变 位数3 = dst[3]
                如果 (位数3 == 0) { 位数3 = 32 }
                如果 (位数3 == 16) { 发射(0x66) }
                定义 需要W3 = 位数3 == 64
                定义 需要B3 = 寄存器编码(dst[1]) >= 8
                如果 (需要W3 或 需要B3) {
                    发射(构建REX(需要W3, 假, 假, 需要B3))
                }
                如果 (位数3 == 8) {
                    发射(0xC6)
                    汇编_发射_内存地址(0, dst[1], dst[2])
                    发射(src & 0xFF)
                } 否则 {
                    发射(0xC7)
                    汇编_发射_内存地址(0, dst[1], dst[2])
                    如果 (位数3 == 16) { 发射16(src) } 否则 { 发射32(src) }
                }
                返回 1
            }
            如果 (dst内存[0] 且 类型(src) == _整数类型) {
                定义 可变 位数3 = dst内存[3]
                如果 (位数3 == 0) { 位数3 = 32 }
                如果 (位数3 == 16) { 发射(0x66) }
                定义 需要W3 = 位数3 == 64
                定义 需要B3 = 寄存器编码(dst内存[1]) >= 8
                如果 (需要W3 或 需要B3) {
                    发射(构建REX(需要W3, 假, 假, 需要B3))
                }
                如果 (位数3 == 8) {
                    发射(0xC6)
                    汇编_发射_内存地址(0, dst内存[1], dst内存[2])
                    发射(src & 0xFF)
                } 否则 {
                    发射(0xC7)
                    汇编_发射_内存地址(0, dst内存[1], dst内存[2])
                    如果 (位数3 == 16) { 发射16(src) } 否则 { 发射32(src) }
                }
                返回 1
            }
        }

        如果 (助记符 == "mov" 且 dst编码 >= 0 且 src编码 >= 0) {
            定义 需要W = 是64位寄存器(dst) 或 是64位寄存器(src)
            定义 需要R = src编码 >= 8
            定义 需要B = dst编码 >= 8
            如果 (需要W 或 需要R 或 需要B) {
                发射(构建REX(需要W, 需要R, 假, 需要B))
            }
            发射(0x89)
            发射(构建ModRM(3, src编码 & 7, dst编码 & 7))
            返回 1
        }

        // mov reg, imm64
        如果 (助记符 == "mov" 且 dst编码 >= 0 且 类型(src) == _整数类型) {
            // src是立即数
            定义 需要B = dst编码 >= 8
            发射(构建REX(真, 假, 假, 需要B))
            发射(0xB8 + (dst编码 & 7))  // mov reg, imm64
            发射64(src)  // 64位立即数
            返回 1
        }

        如果 (助记符 == "mov" 且 dst编码 >= 0 且 类型(src) == _字符串类型 且 src内存[0] == 0) {
            定义 需要B4 = dst编码 >= 8
            定义 地址 = 链接_查符号(src)
            发射(构建REX(真, 假, 假, 需要B4))
            发射(0xB8 + (dst编码 & 7))
            如果 (地址 != 空) {
                发射64(地址)
            } 否则 {
                修正表_追加记录(修正表, "linker_sym", 代码位 + 2, src)
                发射64(0)
            }
            返回 1
        }

        如果 (助记符 == "movzx" 且 编译_处理__movzx_(dst, src)) {
            返回 1
        }

        // add/sub/cmp/and/or/xor reg, reg
        如果 (dst编码 >= 0 且 src编码 >= 0) {
            定义 可变 操作码 = 0
            如果 (助记符 == "add")
            { 操作码 = 0x01 }
            如果 (助记符 == "sub")
            { 操作码 = 0x29 }
            如果 (助记符 == "cmp")
            { 操作码 = 0x39 }
            如果 (助记符 == "and")
            { 操作码 = 0x21 }
            如果 (助记符 == "or")
            { 操作码 = 0x09 }
            如果 (助记符 == "xor")
            { 操作码 = 0x31 }
            如果 (助记符 == "test") { 操作码 = 0x85 }

            如果 (操作码 > 0) {
                定义 需要W = 是64位寄存器(dst)
                定义 需要R = src编码 >= 8
                定义 需要B = dst编码 >= 8
                如果 (需要W 或 需要R 或 需要B) {
                    发射(构建REX(需要W, 需要R, 假, 需要B))
                }
                发射(操作码)
                发射(构建ModRM(3, src编码 & 7, dst编码 & 7))
                返回 1
            }
        }

        // add/sub/cmp/and/or/xor reg, imm32
        如果 (dst编码 >= 0 且 类型(src) == _整数类型) {
            定义 可变 扩展 = 0 - 1
            如果 (助记符 == "add") { 扩展 = 0 }
            如果 (助记符 == "or")
            { 扩展 = 1 }
            如果 (助记符 == "and") { 扩展 = 4 }
            如果 (助记符 == "sub") { 扩展 = 5 }
            如果 (助记符 == "xor") { 扩展 = 6 }
            如果 (助记符 == "cmp") { 扩展 = 7 }

            如果 (扩展 >= 0) {
                定义 需要B = dst编码 >= 8
                发射(构建REX(是64位寄存器(dst), 假, 假, 需要B))
                如果 (src >= -128 且 src <= 127) {
                    发射(0x83)
                    发射(构建ModRM(3, 扩展, dst编码 & 7))
                    发射(src & 0xFF)
                } 否则 {
                    发射(0x81)
                    发射(构建ModRM(3, 扩展, dst编码 & 7))
                    发射32(src)
                }
                返回 1
            }
        }

        如果 (助记符 == "test" 且 dst编码 >= 0 且 类型(src) == _整数类型) {
            如果 (dst位数 == 16) { 发射(0x66) }
            定义 需要W12 = dst位数 == 64
            定义 需要B12 = dst编码 >= 8
            如果 (需要W12 或 需要B12 或 (dst位数 == 8 且 汇编_低8位寄存器需要REX(dst))) {
                发射(构建REX(需要W12, 假, 假, 需要B12))
            }
            如果 (dst位数 == 8) {
                发射(0xF6)
                发射(构建ModRM(3, 0, dst编码 & 7))
                发射(src & 0xFF)
            } 否则 {
                发射(0xF7)
                发射(构建ModRM(3, 0, dst编码 & 7))
                如果 (dst位数 == 16) { 发射16(src) } 否则 { 发射32(src) }
            }
            返回 1
        }

        // in al/ax/eax, imm8 (I/O端口读)
        如果 (助记符 == "in") {
            返回 编译_处理__in_(dst, src)
        }
        // out imm8, al/ax/eax (I/O端口写)
        如果 (助记符 == "out") {
            返回 编译_处理__out_(dst, src)
        }

        // lea reg, [mem] (地址计算)
        如果 (助记符 == "lea" 且 dst编码 >= 0) {
            如果 (src内存[0]) {
                定义 需要W = 是64位寄存器(dst)
                定义 需要R = dst编码 >= 8
                定义 需要B = 寄存器编码(src内存[1]) >= 8
                发射(构建REX(需要W, 需要R, 假, 需要B))
                发射(0x8D)
                汇编_发射_内存地址(dst编码 & 7, src内存[1], src内存[2])
                返回 1
            } 否则 如果 (src编码 >= 0) {
                // lea reg, [reg] (简化: 等价mov)
                定义 需要W = 是64位寄存器(dst)
                定义 需要R = dst编码 >= 8
                定义 需要B = src编码 >= 8
                发射(构建REX(需要W, 需要R, 假, 需要B))
                发射(0x8D)
                发射(构建ModRM(0, dst编码 & 7, src编码 & 7))
                返回 1
            } 否则 {
                // lea reg, [rip+disp32] (RIP相对寻址)
                定义 需要R = dst编码 >= 8
                发射(构建REX(真, 需要R, 假, 假))
                发射(0x8D)
                发射(构建ModRM(0, dst编码 & 7, 5))  // ModRM.rm=5 → [rip+disp32]
                修正表_追加记录(修正表, "rip32", 代码位, src)
                发射32(0)
                返回 1
            }
        }

        // shl/shr reg, imm8
        如果 (dst编码 >= 0 且 类型(src) == _整数类型) {
            定义 可变 是移位指令 = 假
            如果 (助记符 == "shl") { 是移位指令 = 真 }
            如果 (助记符 == "shr") { 是移位指令 = 真 }
            如果 (助记符 == "sar") { 是移位指令 = 真 }
            如果 (是移位指令) {
                定义 需要B = dst编码 >= 8
                发射(构建REX(是64位寄存器(dst), 假, 假, 需要B))
                发射(0xC1)
                定义 可变 扩展码 = 4
                如果 (助记符 == "shr") { 扩展码 = 5 }
                如果 (助记符 == "sar") { 扩展码 = 7 }
                发射(构建ModRM(3, 扩展码, dst编码 & 7))
                发射(src & 0xFF)
                返回 1
            }
        }
    }

    // 5.5: SSE/AVX双操作数指令 (xmm,xmm 编码)
    如果 (助记符 == "movaps" 且 dst编码 >= 0 且 src编码 >= 0) {
        // movaps xmm, xmm — 0F 28 /r
        发射组([0x0F, 0x28, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "movups" 且 dst编码 >= 0 且 src编码 >= 0) {
        // movups xmm, xmm — 0F 10 /r
        发射组([0x0F, 0x10, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "xorps" 且 dst编码 >= 0 且 src编码 >= 0) {
        // xorps xmm, xmm — 0F 57 /r
        发射组([0x0F, 0x57, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "xorpd" 且 dst编码 >= 0 且 src编码 >= 0) {
        // xorpd xmm, xmm — 66 0F 57 /r
        发射组([0x66, 0x0F, 0x57, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "addps" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x0F, 0x58, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "addpd" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x66, 0x0F, 0x58, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "mulps" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x0F, 0x59, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "mulpd" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x66, 0x0F, 0x59, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "subps" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x0F, 0x5C, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "subpd" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x66, 0x0F, 0x5C, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "divps" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x0F, 0x5E, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "divpd" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x66, 0x0F, 0x5E, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "sqrtps" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x0F, 0x51, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "sqrtpd" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x66, 0x0F, 0x51, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "minps" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x0F, 0x5D, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "maxps" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x0F, 0x5F, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    // SSE2 整数打包指令
    如果 (助记符 == "paddb" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x66, 0x0F, 0xFC, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "paddw" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x66, 0x0F, 0xFD, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "paddd" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x66, 0x0F, 0xFE, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "paddq" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x66, 0x0F, 0xD4, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "pxor" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x66, 0x0F, 0xEF, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "pand" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x66, 0x0F, 0xDB, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "por" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0x66, 0x0F, 0xEB, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    // SSE数据移动
    如果 (助记符 == "movsd" 且 dst编码 >= 0 且 src编码 >= 0) {
        // movsd xmm, xmm — F2 0F 10 /r
        发射组([0xF2, 0x0F, 0x10, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "movss" 且 dst编码 >= 0 且 src编码 >= 0) {
        // movss xmm, xmm — F3 0F 10 /r
        发射组([0xF3, 0x0F, 0x10, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    // SSE转换
    如果 (助记符 == "cvtsi2sd" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0xF2, 0x48, 0x0F, 0x2A, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    如果 (助记符 == "cvtsd2si" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0xF2, 0x48, 0x0F, 0x2D, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }

    // 5.5补齐: movsx (符号扩展移动)
    如果 (助记符 == "movsx" 且 dst编码 >= 0 且 src编码 >= 0) {
        定义 _sx_dst位 = 汇编_寄存器位数(dst)
        定义 _sx_src位 = 汇编_寄存器位数(src)
        如果 (_sx_src位 == 8) {
            // movsx r32/r64, r8 — 0F BE /r (REX.W for 64bit dst)
            定义 _需W = _sx_dst位 == 64
            定义 _需R = dst编码 >= 8
            定义 _需B = src编码 >= 8
            如果 (_需W 或 _需R 或 _需B) { 发射(构建REX(_需W, _需R, 假, _需B)) }
            发射组([0x0F, 0xBE, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
            返回 1
        }
        如果 (_sx_src位 == 16) {
            // movsx r32/r64, r16 — 0F BF /r
            定义 _需W = _sx_dst位 == 64
            定义 _需R = dst编码 >= 8
            定义 _需B = src编码 >= 8
            如果 (_需W 或 _需R 或 _需B) { 发射(构建REX(_需W, _需R, 假, _需B)) }
            发射组([0x0F, 0xBF, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
            返回 1
        }
        如果 (_sx_src位 == 32 且 _sx_dst位 == 64) {
            // movsxd r64, r32 — REX.W 63 /r
            定义 _需R = dst编码 >= 8
            定义 _需B = src编码 >= 8
            发射(构建REX(真, _需R, 假, _需B))
            发射(0x63)
            发射(构建ModRM(3, dst编码 & 7, src编码 & 7))
            返回 1
        }
    }

    // 5.5补齐: setcc 系列 (条件字节设置)
    如果 (助记符 == "sete" 且 dst编码 >= 0) {
        如果 (dst编码 >= 8 或 汇编_低8位寄存器需要REX(dst)) { 发射(构建REX(假, 假, 假, dst编码 >= 8)) }
        发射组([0x0F, 0x94, 构建ModRM(3, 0, dst编码 & 7)])
        返回 1
    }
    如果 (助记符 == "setne" 且 dst编码 >= 0) {
        如果 (dst编码 >= 8 或 汇编_低8位寄存器需要REX(dst)) { 发射(构建REX(假, 假, 假, dst编码 >= 8)) }
        发射组([0x0F, 0x95, 构建ModRM(3, 0, dst编码 & 7)])
        返回 1
    }
    如果 (助记符 == "setl" 且 dst编码 >= 0) {
        如果 (dst编码 >= 8 或 汇编_低8位寄存器需要REX(dst)) { 发射(构建REX(假, 假, 假, dst编码 >= 8)) }
        发射组([0x0F, 0x9C, 构建ModRM(3, 0, dst编码 & 7)])
        返回 1
    }
    如果 (助记符 == "setge" 且 dst编码 >= 0) {
        如果 (dst编码 >= 8 或 汇编_低8位寄存器需要REX(dst)) { 发射(构建REX(假, 假, 假, dst编码 >= 8)) }
        发射组([0x0F, 0x9D, 构建ModRM(3, 0, dst编码 & 7)])
        返回 1
    }
    如果 (助记符 == "setle" 且 dst编码 >= 0) {
        如果 (dst编码 >= 8 或 汇编_低8位寄存器需要REX(dst)) { 发射(构建REX(假, 假, 假, dst编码 >= 8)) }
        发射组([0x0F, 0x9E, 构建ModRM(3, 0, dst编码 & 7)])
        返回 1
    }
    如果 (助记符 == "setg" 且 dst编码 >= 0) {
        如果 (dst编码 >= 8 或 汇编_低8位寄存器需要REX(dst)) { 发射(构建REX(假, 假, 假, dst编码 >= 8)) }
        发射组([0x0F, 0x9F, 构建ModRM(3, 0, dst编码 & 7)])
        返回 1
    }
    如果 (助记符 == "setb" 且 dst编码 >= 0) {
        如果 (dst编码 >= 8 或 汇编_低8位寄存器需要REX(dst)) { 发射(构建REX(假, 假, 假, dst编码 >= 8)) }
        发射组([0x0F, 0x92, 构建ModRM(3, 0, dst编码 & 7)])
        返回 1
    }
    如果 (助记符 == "setae" 且 dst编码 >= 0) {
        如果 (dst编码 >= 8 或 汇编_低8位寄存器需要REX(dst)) { 发射(构建REX(假, 假, 假, dst编码 >= 8)) }
        发射组([0x0F, 0x93, 构建ModRM(3, 0, dst编码 & 7)])
        返回 1
    }
    如果 (助记符 == "seta" 且 dst编码 >= 0) {
        如果 (dst编码 >= 8 或 汇编_低8位寄存器需要REX(dst)) { 发射(构建REX(假, 假, 假, dst编码 >= 8)) }
        发射组([0x0F, 0x97, 构建ModRM(3, 0, dst编码 & 7)])
        返回 1
    }
    如果 (助记符 == "setbe" 且 dst编码 >= 0) {
        如果 (dst编码 >= 8 或 汇编_低8位寄存器需要REX(dst)) { 发射(构建REX(假, 假, 假, dst编码 >= 8)) }
        发射组([0x0F, 0x96, 构建ModRM(3, 0, dst编码 & 7)])
        返回 1
    }

    // 5.5补齐: VEX编码AVX双操作数指令
    // vmovaps xmm, xmm — VEX.128.0F 28 /r (C5 F8 28 modrm)
    如果 (助记符 == "vmovaps" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0xC5, 0xF8, 0x28, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    // vmovups xmm, xmm — VEX.128.0F 10 /r (C5 F8 10 modrm)
    如果 (助记符 == "vmovups" 且 dst编码 >= 0 且 src编码 >= 0) {
        发射组([0xC5, 0xF8, 0x10, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }
    // vxorps xmm, xmm, xmm — VEX.128.0F 57 /r (需要3操作数, 这里简化为dst=src1)
    如果 (助记符 == "vxorps" 且 dst编码 >= 0 且 src编码 >= 0) {
        // VEX.NDS.128.0F 57 — vvvv=dst编码(补码)
        定义 _vvvv = (~(dst编码 & 0xF)) & 0xF
        发射组([0xC5, (0x78 | (_vvvv << 3)) & 0xFF, 0x57, 构建ModRM(3, dst编码 & 7, src编码 & 7)])
        返回 1
    }

    如果 (助记符 == "mov") {
        定义 可变 _dst文本 = 转字符串(dst)
        定义 可变 _src文本 = 转字符串(src)
        如果 (是字符串(dst)) { _dst文本 = 字符串拼接("", dst) }
        如果 (是字符串(src)) { _src文本 = 字符串拼接("", src) }
    }

 // 未识别的指令
定义 可变 调试文本 = "汇编警告: 未识别指令 助记符=" + 助记符 + " 参数数=" + 转字符串(计数(指令))
打印(调试文本)
返回 0
}

函数 编译_汇编_mov_文本行(行) {
    行 = 汇编_稳定操作数引用(行)
    行 = 汇编_稳定操作数引用(汇编_去空白(行))
    定义 可变 空格位 = 0 - 1
    定义 可变 i = 0
    当 (i < 计数(行)) {
        如果 (空格位 < 0 且 (子串(行, i, 1) == " " 或 子串(行, i, 1) == "\t")) { 空格位 = i }
        i = i + 1
    }
    如果 (空格位 < 0) { 返回 0 }
    如果 (汇编_稳定操作数引用(子串(行, 0, 空格位)) != "mov") { 返回 0 }
    定义 操作数文本 = 汇编_稳定操作数引用(汇编_去空白(子串(行, 空格位 + 1, 计数(行) - 空格位 - 1)))
    定义 操作数列 = 汇编_拆操作数(操作数文本)
    如果 (计数(操作数列) < 2) { 返回 0 }
    定义 dst = 汇编_稳定操作数引用(操作数列[0])
    定义 可变 src = 汇编_稳定操作数引用(操作数列[1])
    定义 可变 立即数结果 = [0, 0]
    如果 (汇编_应尝试解析立即数(src)) {
        立即数结果 = 汇编_尝试解析立即数(src)
    }
    如果 (立即数结果[0]) { src = 立即数结果[1] }
    返回 编译_处理__mov_操作数(dst, src)
}

// 编译整个汇编块
// 输入: 指令列表 [[助记符, 操作数...], ...]
函数 编译_汇编块(指令列表) {
    // 第一遍: 收集标签
    定义 可变 标签表 = 字典()
    定义 可变 临时位 = 代码位

    定义 可变 i = 0
    当 (i < 计数(指令列表)) {
        定义 指令 = 指令列表[i]
        如果 (指令[0] == "label" 或 指令[0] == "label_local") {
            字典设(标签表, 指令[1], 临时位)
        } 否则 {
            // 估算指令大小(简化:大多数指令2-8字节)
            临时位 = 临时位 + 6  // 平均估计
        }
        i = i + 1
    }

    // 第二遍: 生成机器码
    汇编_当前本地标签表 = 字典()
    汇编_当前本地修正表 = []
    定义 可变 j = 0
    当 (j < 计数(指令列表)) {
        定义 指令 = 指令列表[j]
        如果 (指令[0] == "label_local") {
            字典设(汇编_当前本地标签表, 指令[1], 代码位)
        } 否则 如果 (指令[0] == "label") {
            // 标签: 更新函数表供跳转使用
            字典设(函数表, 指令[1], 代码位)
        } 否则 如果 (指令[0] == "raw") {
            // 原始字节: 直接发射
            定义 可变 bi = 1
            当 (bi < 计数(指令)) {
                发射(指令[bi])
                bi = bi + 1
            }
        } 否则 如果 (指令[0] == "mov_text") {
            编译_汇编_mov_文本行(指令[1])
        } 否则 {
            编译_汇编指令(指令)
        }
        j = j + 1
    }
    汇编_应用本地修正()
    汇编_当前本地标签表 = 字典()
    汇编_当前本地修正表 = []
}

// 语法: 汇编 { .byte 0x48, 0xCF }
函数 编译_原始字节(字节列表) {
    定义 可变 i = 0
    当 (i < 计数(字节列表)) {
        发射(字节列表[i])
        i = i + 1
    }
}

函数 汇编_去空白(s) {
    定义 n = 计数(s)
    定义 可变 开始 = 0
    当 (开始 < n 且 (字符串等于(子串(s, 开始, 1), " ") 或 字符串等于(子串(s, 开始, 1), "\t"))) { 开始 = 开始 + 1 }
    定义 可变 结束 = n
    当 (结束 > 开始 且 (字符串等于(子串(s, 结束 - 1, 1), " ") 或 字符串等于(子串(s, 结束 - 1, 1), "\t"))) { 结束 = 结束 - 1 }
    如果 (开始 >= 结束) { 返回 "" }
    返回 子串(s, 开始, 结束 - 开始)
}

函数 汇编_十六字符值(c) {
    定义 值 = 编码(c)
    如果 (值 >= 48 且 值 <= 57) { 返回 值 - 48 }
    如果 (值 >= 65 且 值 <= 70) { 返回 值 - 55 }
    如果 (值 >= 97 且 值 <= 102) { 返回 值 - 87 }
    返回 0 - 1
}

函数 汇编_表达式_跳空白(s, 开始) {
    定义 可变 i = 开始
    当 (i < 计数(s) 且 (子串(s, i, 1) == " " 或 子串(s, i, 1) == "\t")) {
        i = i + 1
    }
    返回 i
}

函数 汇编_解析数字片段(s, 开始) {
    定义 i = 汇编_表达式_跳空白(s, 开始)
    如果 (i >= 计数(s)) { 返回 [0, 0, 开始] }
    如果 (i + 1 < 计数(s) 且 (子串(s, i, 2) == "0x" 或 子串(s, i, 2) == "0X")) {
        定义 可变 值 = 0
        定义 可变 j = i + 2
        定义 可变 至少一位 = 假
        当 (j < 计数(s)) {
            定义 半字节 = 汇编_十六字符值(子串(s, j, 1))
            如果 (半字节 < 0) { j = 计数(s) }
            值 = 值 * 16 + 半字节
            至少一位 = 真
            j = j + 1
        }
        如果 (至少一位 == 假) { 返回 [0, 0, 开始] }
        返回 [1, 值, j]
    }
    定义 可变 值2 = 0
    定义 可变 j2 = i
    定义 可变 至少一位2 = 假
    当 (j2 < 计数(s)) {
        定义 c值 = 编码(子串(s, j2, 1))
        如果 (c值 < 48 或 c值 > 57) { j2 = 计数(s) }
        值2 = 值2 * 10 + (c值 - 48)
        至少一位2 = 真
        j2 = j2 + 1
    }
    如果 (至少一位2 == 假) { 返回 [0, 0, 开始] }
    返回 [1, 值2, j2]
}

函数 汇编_解析表达式_主项(s, 开始) {
    定义 i = 汇编_表达式_跳空白(s, 开始)
    如果 (i >= 计数(s)) { 返回 [0, 0, 开始] }
    如果 (子串(s, i, 1) == "(") {
        定义 结果 = 汇编_解析表达式_位移(s, i + 1)
        如果 (结果[0] == 0) { 返回 [0, 0, 开始] }
        定义 结束 = 汇编_表达式_跳空白(s, 结果[2])
        如果 (结束 >= 计数(s) 或 子串(s, 结束, 1) != ")") { 返回 [0, 0, 开始] }
        返回 [1, 结果[1], 结束 + 1]
    }
    返回 汇编_解析数字片段(s, i)
}

函数 汇编_解析表达式_一元(s, 开始) {
    定义 i = 汇编_表达式_跳空白(s, 开始)
    如果 (i >= 计数(s)) { 返回 [0, 0, 开始] }
    定义 c = 子串(s, i, 1)
    如果 (c == "+") { 返回 汇编_解析表达式_一元(s, i + 1) }
    如果 (c == "-") {
        定义 结果 = 汇编_解析表达式_一元(s, i + 1)
        如果 (结果[0] == 0) { 返回 [0, 0, 开始] }
        返回 [1, 0 - 结果[1], 结果[2]]
    }
    如果 (c == "~") {
        定义 结果2 = 汇编_解析表达式_一元(s, i + 1)
        如果 (结果2[0] == 0) { 返回 [0, 0, 开始] }
        返回 [1, ~结果2[1], 结果2[2]]
    }
    返回 汇编_解析表达式_主项(s, i)
}

函数 汇编_解析表达式_加减(s, 开始) {
    定义 左 = 汇编_解析表达式_一元(s, 开始)
    如果 (左[0] == 0) { 返回 左 }
    定义 可变 值 = 左[1]
    定义 可变 i = 左[2]
    当 (i < 计数(s)) {
        i = 汇编_表达式_跳空白(s, i)
        如果 (i >= 计数(s)) { 返回 [1, 值, i] }
        定义 op = 子串(s, i, 1)
        如果 (op != "+" 且 op != "-") { 返回 [1, 值, i] }
        定义 右 = 汇编_解析表达式_一元(s, i + 1)
        如果 (右[0] == 0) { 返回 [0, 0, 开始] }
        如果 (op == "+") {
            值 = 值 + 右[1]
        } 否则 {
            值 = 值 - 右[1]
        }
        i = 右[2]
    }
    返回 [1, 值, i]
}

函数 汇编_解析表达式_位移(s, 开始) {
    定义 左 = 汇编_解析表达式_加减(s, 开始)
    如果 (左[0] == 0) { 返回 左 }
    定义 可变 值 = 左[1]
    定义 可变 i = 左[2]
    当 (i < 计数(s)) {
        i = 汇编_表达式_跳空白(s, i)
        如果 (i + 1 >= 计数(s)) { 返回 [1, 值, i] }
        定义 op = 子串(s, i, 2)
        如果 (op != "<<" 且 op != ">>") { 返回 [1, 值, i] }
        定义 右 = 汇编_解析表达式_加减(s, i + 2)
        如果 (右[0] == 0) { 返回 [0, 0, 开始] }
        如果 (op == "<<") {
            值 = 值 << 右[1]
        } 否则 {
            值 = 值 >> 右[1]
        }
        i = 右[2]
    }
    返回 [1, 值, i]
}

函数 汇编_尝试解析立即数(文本) {
    定义 s = 汇编_去空白(文本)
    如果 (s == "") { 返回 [0, 0] }
    如果 (汇编_是本地标签名(s)) { 返回 [0, 0] }
    定义 结果 = 汇编_解析表达式_位移(s, 0)
    如果 (结果[0] == 0) { 返回 [0, 0] }
    定义 结束 = 汇编_表达式_跳空白(s, 结果[2])
    如果 (结束 != 计数(s)) { 返回 [0, 0] }
    返回 [1, 结果[1]]
}

函数 汇编_应尝试解析立即数(文本) {
    如果 (是字符串(文本) == 假) { 返回 假 }
    定义 s = 汇编_去空白(文本)
    如果 (s == "") { 返回 假 }
    如果 (计数(s) >= 2 且 (子串(s, 0, 2) == "0x" 或 子串(s, 0, 2) == "0X")) { 返回 真 }
    定义 c0 = 子串(s, 0, 1)
    如果 (c0 == "+" 或 c0 == "-" 或 c0 == "~" 或 c0 == "(") { 返回 真 }
    定义 c0值 = 编码(c0)
    如果 (c0值 >= 48 且 c0值 <= 57) { 返回 真 }
    返回 假
}

函数 汇编_拆操作数(文本) {
    定义 可变 结果 = []
    定义 可变 当前 = ""
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        定义 c = 子串(文本, i, 1)
        如果 (字符串等于(c, ",")) {
            定义 项 = 汇编_去空白(当前)
            如果 (项 != "") {
                定义 _项内存 = 汇编_解析内存操作数(项)
                如果 (_项内存[0] == 1) {
                    追加(结果, 汇编_稳定操作数引用(汇编_编码内存描述(_项内存[1], _项内存[2], _项内存[3])))
                }
                否则 { 追加(结果, 汇编_稳定操作数引用(项)) }
            }
            当前 = ""
        } 否则 {
            当前 = 字符串拼接(当前, c)
        }
        i = i + 1
    }
    定义 末项 = 汇编_去空白(当前)
    如果 (末项 != "") {
        定义 _末项内存 = 汇编_解析内存操作数(末项)
        如果 (_末项内存[0] == 1) {
            追加(结果, 汇编_稳定操作数引用(汇编_编码内存描述(_末项内存[1], _末项内存[2], _末项内存[3])))
        }
        否则 { 追加(结果, 汇编_稳定操作数引用(末项)) }
    }
    返回 结果
}

函数 汇编_构造解析操作数结果(助记符, 操作数列) {
    定义 可变 oi = 0
    定义 可变 输出助记符 = 助记符
    定义 可变 指令 = []
    当 (oi < 计数(操作数列)) {
        定义 可变 _编码内存 = 汇编_解码内存描述(操作数列[oi])
        定义 可变 立即数结果 = [0, 0]
        如果 (汇编_应尝试解析立即数(操作数列[oi])) {
            立即数结果 = 汇编_尝试解析立即数(操作数列[oi])
        }
        定义 _本地助记符允许 = 汇编_助记符_使用本地标签ID(助记符)
        定义 _是本地标签操作数 = 汇编_是本地标签名(操作数列[oi])
        如果 (立即数结果[0]) {
            汇编_列表追加(指令, 立即数结果[1])
        } 否则 如果 (汇编_是内存描述(操作数列[oi]) 或 _编码内存[0] == 1) {
            汇编_列表追加(指令, 汇编_稳定操作数引用(操作数列[oi]))
        } 否则 如果 (_本地助记符允许 且 _是本地标签操作数) {
            如果 (oi == 0) { 输出助记符 = 汇编_本地跳转助记符(助记符) }
            汇编_列表追加(指令, 汇编_稳定操作数引用(汇编_本地标签ID(操作数列[oi])))
        } 否则 如果 (助记符 == "jmp" 且 汇编_应编码符号引用(操作数列[oi])) {
            汇编_列表追加(指令, 汇编_稳定操作数引用(汇编_编码符号引用(操作数列[oi])))
        } 否则 {
            汇编_列表追加(指令, 汇编_稳定操作数引用(操作数列[oi]))
        }
        oi = oi + 1
    }
    返回 [输出助记符, 指令]
}

函数 汇编_解析文本行(行) {
    定义 可变 ji = 0
    行 = 汇编_稳定操作数引用(行)
    行 = 汇编_稳定操作数引用(汇编_去空白(行))
    如果 (行 == "") { 返回 空 }
    如果 (计数(行) >= 6 且 子串(行, 0, 6) == ".byte ") {
        定义 数据文本 = 汇编_稳定操作数引用(汇编_去空白(子串(行, 6, 计数(行) - 6)))
        定义 数据列 = 汇编_拆操作数(数据文本)
        定义 可变 指令 = ["raw"]
        定义 可变 di = 0
        当 (di < 计数(数据列)) {
            定义 值结果 = 汇编_尝试解析立即数(数据列[di])
            如果 (值结果[0] == 0) { 返回 [行] }
            汇编_列表追加(指令, 值结果[1] & 0xFF)
            di = di + 1
        }
        返回 指令
    }
    如果 (计数(行) >= 3 且 子串(行, 0, 3) == "dw ") {
        定义 数据文本2 = 汇编_稳定操作数引用(汇编_去空白(子串(行, 3, 计数(行) - 3)))
        定义 数据列2 = 汇编_拆操作数(数据文本2)
        定义 可变 指令2 = ["raw"]
        定义 可变 di2 = 0
        当 (di2 < 计数(数据列2)) {
            定义 值结果2 = 汇编_尝试解析立即数(数据列2[di2])
            如果 (值结果2[0] == 0) { 返回 [行] }
            汇编_列表追加(指令2, 值结果2[1] & 0xFF)
            汇编_列表追加(指令2, (值结果2[1] >> 8) & 0xFF)
            di2 = di2 + 1
        }
        返回 指令2
    }
    如果 (子串(行, 计数(行) - 1, 1) == ":") {
        定义 标签名 = 汇编_稳定操作数引用(子串(行, 0, 计数(行) - 1))
        如果 (汇编_是本地标签名(标签名)) { 返回 ["label_local", 汇编_本地标签ID(标签名)] }
        返回 ["label", 标签名]
    }
    如果 (行 == "rep movsb" 或 行 == "rep movsq" 或 行 == "rep stosb" 或 行 == "rep stosq" 或 行 == "rep insb" 或 行 == "rep insw" 或 行 == "rep insd" 或 行 == "rep outsb" 或 行 == "rep outsw" 或 行 == "rep outsd" 或 行 == "rdrand rax" 或 行 == "ltr ax") { 返回 [行] }
    定义 可变 空格位 = 0 - 1
    定义 可变 i = 0
    当 (i < 计数(行)) {
        如果 (空格位 < 0 且 (子串(行, i, 1) == " " 或 子串(行, i, 1) == "\t")) { 空格位 = i }
        i = i + 1
    }
    如果 (空格位 < 0) { 返回 [行] }
    定义 助记符 = 汇编_稳定操作数引用(子串(行, 0, 空格位))
    定义 操作数文本 = 汇编_稳定操作数引用(汇编_去空白(子串(行, 空格位 + 1, 计数(行) - 空格位 - 1)))
    定义 操作数列 = 汇编_拆操作数(操作数文本)
    定义 _操作数结果 = 汇编_构造解析操作数结果(助记符, 操作数列)
    定义 输出助记符 = _操作数结果[0]
    定义 指令 = _操作数结果[1]
    定义 可变 结果指令 = [输出助记符]
    当 (ji < 计数(指令)) {
        汇编_列表追加(结果指令, 指令[ji])
        ji = ji + 1
    }
    返回 结果指令
}

函数 汇编_拆分行首标签(行) {
    定义 s = 汇编_稳定操作数引用(汇编_去空白(行))
    定义 可变 i = 0
    当 (i < 计数(s)) {
        定义 c = 子串(s, i, 1)
        如果 (c == ":") {
            定义 标签行 = 汇编_稳定操作数引用(子串(s, 0, i + 1))
            定义 剩余行 = 汇编_稳定操作数引用(汇编_去空白(子串(s, i + 1, 计数(s) - i - 1)))
            如果 (剩余行 == "") { 返回 [0, "", ""] }
            返回 [1, 标签行, 剩余行]
        }
        如果 (c == " " 或 c == "\t") { 返回 [0, "", ""] }
        i = i + 1
    }
    返回 [0, "", ""]
}

函数 汇编_追加文本行指令(指令列, 规范文本行) {
    如果 (规范文本行 == "") { 返回 0 }
    如果 (计数(规范文本行) >= 4 且 子串(规范文本行, 0, 4) == "mov ") {
        汇编_列表追加(指令列, ["mov_text", 规范文本行])
    } 否则 {
        定义 指令 = 汇编_解析文本行(规范文本行)
        如果 (指令 != 空 且 指令[0] != "extern") {
            汇编_列表追加(指令列, 指令)
        }
    }
    返回 1
}

函数 编译_汇编文本块(文本列) {
    定义 可变 指令列 = []
    定义 可变 i = 0
    当 (i < 计数(文本列)) {
        定义 文本行 = 汇编_稳定操作数引用(文本列[i])
        定义 规范文本行 = 汇编_稳定操作数引用(汇编_去空白(文本行))
        定义 行首标签结果 = 汇编_拆分行首标签(规范文本行)
        如果 (行首标签结果[0]) {
            汇编_追加文本行指令(指令列, 行首标签结果[1])
            汇编_追加文本行指令(指令列, 行首标签结果[2])
        } 否则 {
            汇编_追加文本行指令(指令列, 规范文本行)
        }
        i = i + 1
    }
    编译_汇编块(指令列)
}

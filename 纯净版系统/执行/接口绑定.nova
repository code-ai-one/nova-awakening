定义 NATIVE_DOC_GET_BY_TAG           = 206
定义 NATIVE_DOC_CREATE_事件          = 207
定义 NATIVE_DOC_CREATE_FRAGMENT      = 208
定义 NATIVE_DOC_CREATE_COMMENT       = 209

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/创建甲.nova")

定义 可见_活跃 = 0
定义 可见_隐藏 = 1
定义 可见_冻结 = 2
定义 可见_丢弃 = 3
定义 最大监听 = 32

结构 页面生命周期 {
    可见状态,
    上次可见时刻,
    上次隐藏时刻,
    冻结时刻,
    隐藏总时长,
    冻结总时长,
    切换次数,
    定时器节流,
    网络节流,
    动画暂停,
    监听表,
    监听数,
}

定义 可变 全局生命周期 = 0

函数 页面_初始化() {
    全局生命周期 = 堆_分配(页面生命周期)
    全局生命周期.可见状态 = 可见_活跃
    全局生命周期.上次可见时刻 = 平台_获取高精度时间()
    全局生命周期.上次隐藏时刻 = 0
    全局生命周期.冻结时刻 = 0
    全局生命周期.隐藏总时长 = 0
    全局生命周期.冻结总时长 = 0
    全局生命周期.切换次数 = 0
    全局生命周期.定时器节流 = 假
    全局生命周期.网络节流 = 假
    全局生命周期.动画暂停 = 假
    全局生命周期.监听表 = 堆_分配(最大监听 * 8)
    全局生命周期.监听数 = 0
}

函数 页面_设可见(隐藏) {
    如果 (全局生命周期 == 0) { 返回 }
    定义 旧状态 = 全局生命周期.可见状态
    定义 现在 = 平台_获取高精度时间()
    如果 (隐藏 && 旧状态 == 可见_活跃) {
        全局生命周期.可见状态 = 可见_隐藏
        全局生命周期.上次隐藏时刻 = 现在
        全局生命周期.定时器节流 = 真
        全局生命周期.动画暂停 = 真
        全局生命周期.切换次数 = 全局生命周期.切换次数 + 1
        页面_触发事件(可见_隐藏)
    } 否则 如果 (!隐藏 && 旧状态 != 可见_活跃) {
        如果 (旧状态 == 可见_隐藏) {
            全局生命周期.隐藏总时长 = 全局生命周期.隐藏总时长 + (现在 - 全局生命周期.上次隐藏时刻)
        }
        如果 (旧状态 == 可见_冻结) {
            全局生命周期.冻结总时长 = 全局生命周期.冻结总时长 + (现在 - 全局生命周期.冻结时刻)
        }
        全局生命周期.可见状态 = 可见_活跃
        全局生命周期.上次可见时刻 = 现在
        全局生命周期.定时器节流 = 假
        全局生命周期.网络节流 = 假
        全局生命周期.动画暂停 = 假
        全局生命周期.切换次数 = 全局生命周期.切换次数 + 1
        页面_触发事件(可见_活跃)
    }
}

函数 页面_冻结() {
    如果 (全局生命周期 == 0) { 返回 }
    如果 (全局生命周期.可见状态 == 可见_隐藏) {
        全局生命周期.可见状态 = 可见_冻结
        全局生命周期.冻结时刻 = 平台_获取高精度时间()
        全局生命周期.网络节流 = 真
        页面_触发事件(可见_冻结)
    }
}

函数 页面_丢弃() {
    如果 (全局生命周期 == 0) { 返回 }
    全局生命周期.可见状态 = 可见_丢弃
    页面_触发事件(可见_丢弃)
}

函数 页面_注册监听(回调) {
    如果 (全局生命周期 == 0) { 返回 }
    如果 (全局生命周期.监听数 >= 最大监听) { 返回 }
    内存_写64(全局生命周期.监听表 + 全局生命周期.监听数 * 8, 回调)
    全局生命周期.监听数 = 全局生命周期.监听数 + 1
}

函数 页面_触发事件(新状态) {
    定义 可变 序号 = 0
    当 (序号 < 全局生命周期.监听数) {
        定义 回调 = 内存_读64(全局生命周期.监听表 + 序号 * 8)
        如果 (回调 != 0) { 回调(新状态) }
        序号 = 序号 + 1
    }
}

函数 页面_是隐藏() {
    如果 (全局生命周期 == 0) { 返回 假 }
    返回 全局生命周期.可见状态 != 可见_活跃
}

函数 页面_可见状态名() {
    如果 (全局生命周期 == 0) { 返回 "活跃" }
    如果 (全局生命周期.可见状态 == 可见_活跃) { 返回 "活跃" }
    如果 (全局生命周期.可见状态 == 可见_隐藏) { 返回 "隐藏" }
    如果 (全局生命周期.可见状态 == 可见_冻结) { 返回 "冻结" }
    如果 (全局生命周期.可见状态 == 可见_丢弃) { 返回 "丢弃" }
    返回 "未知"
}

函数 页面_是节流() {
    如果 (全局生命周期 == 0) { 返回 假 }
    返回 全局生命周期.定时器节流
}

函数 页面_是动画暂停() {
    如果 (全局生命周期 == 0) { 返回 假 }
    返回 全局生命周期.动画暂停
}

函数 页面_完整统计() {
    如果 (全局生命周期 == 0) { 返回 [0, 0, 0, 0] }
    返回 [全局生命周期.可见状态, 全局生命周期.切换次数, 全局生命周期.隐藏总时长, 全局生命周期.冻结总时长]
}

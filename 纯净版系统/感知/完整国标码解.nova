导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/硬链接.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/整数转字符串.nova")
导入("../执行/控制台输出.nova")

定义 GBK_第一字节_最小 = 0x81
定义 GBK_第一字节_最大 = 0xFE
定义 GBK_第二字节_最小 = 0x40
定义 GBK_第二字节_最大 = 0xFE
定义 GBK_替换字符 = 0xFFFD

定义 GBK_表大小 = 23940
定义 可变 GBK_到Unicode表 = 空
定义 可变 Unicode_到GBK表 = 空
定义 可变 GBK_已初始化 = 假

定义 编码_未知 = 0
定义 编码_UTF8 = 1
定义 编码_GBK = 2
定义 编码_GB2312 = 3
定义 编码_GB18030 = 4

结构 GBK解码器状态 {
    剩余字节,
    第一字节,
    错误模式,
    已解码字符数,
    错误字符数,
}

函数 GBK_初始化() {
    如果 (GBK_已初始化) { 返回 }
    GBK_到Unicode表 = 堆_分配(GBK_表大小 * 2)
    Unicode_到GBK表 = 堆_分配(65536 * 2)

    如果 (GBK_到Unicode表 == 空 || Unicode_到GBK表 == 空) { 返回 }

    内存_填充(GBK_到Unicode表, 0, GBK_表大小 * 2)
    内存_填充(Unicode_到GBK表, 0, 65536 * 2)

    GBK_填充GB2312区()
    GBK_填充扩展A区()
    GBK_填充扩展B区()

    GBK_构建反向表()
    GBK_已初始化 = 真
}

函数 GBK_索引(b0, b1) {
    如果 (b0 < GBK_第一字节_最小 || b0 > GBK_第一字节_最大) { 返回 -1 }
    如果 (b1 < GBK_第二字节_最小 || b1 > GBK_第二字节_最大) { 返回 -1 }
    如果 (b1 == 0x7F) { 返回 -1 }
    定义 行 = b0 - GBK_第一字节_最小
    定义 列 = b1 - GBK_第二字节_最小
    如果 (b1 > 0x7F) { 列 = 列 - 1 }
    返回 行 * 190 + 列
}

函数 GBK_到Unicode(b0, b1) {
    如果 (GBK_到Unicode表 == 空) { 返回 GBK_替换字符 }
    定义 索引 = GBK_索引(b0, b1)
    如果 (索引 < 0 || 索引 >= GBK_表大小) { 返回 GBK_替换字符 }
    定义 cp = 内存_读16(GBK_到Unicode表 + 索引 * 2)
    如果 (cp == 0) { 返回 GBK_替换字符 }
    返回 cp
}

函数 Unicode_到GBK(码点) {
    如果 (Unicode_到GBK表 == 空) { 返回 0 }
    如果 (码点 < 0x80) { 返回 码点 }
    如果 (码点 >= 65536) { 返回 0 }
    返回 内存_读16(Unicode_到GBK表 + 码点 * 2)
}

函数 GBK_构建反向表() {
    定义 可变 i = 0
    当 (i < GBK_表大小) {
        定义 cp = 内存_读16(GBK_到Unicode表 + i * 2)
        如果 (cp != 0 && cp < 65536) {
            定义 行 = i / 190
            定义 列 = i % 190
            定义 b0 = 行 + GBK_第一字节_最小
            定义 b1 = 列 + GBK_第二字节_最小
            如果 (b1 >= 0x7F) { b1 = b1 + 1 }
            内存_写16(Unicode_到GBK表 + cp * 2, (b0 << 8) | b1)
        }
        i = i + 1
    }
}

函数 GBK_填充GB2312区() {
    定义 可变 区 = 1
    当 (区 <= 94) {
        定义 可变 位 = 1
        当 (位 <= 94) {
            定义 b0 = 区 + 0xA0
            定义 b1 = 位 + 0xA0
            定义 索引 = GBK_索引(b0, b1)
            如果 (索引 >= 0 && 索引 < GBK_表大小) {
                定义 cp = GB2312_查找码点(区, 位)
                如果 (cp != 0) {
                    内存_写16(GBK_到Unicode表 + 索引 * 2, cp)
                }
            }
            位 = 位 + 1
        }
        区 = 区 + 1
    }
}

函数 GBK_填充扩展A区() {
    定义 可变 b0 = 0x81
    当 (b0 <= 0xA0) {
        定义 可变 b1 = 0x40
        当 (b1 <= 0xFE) {
            如果 (b1 != 0x7F) {
                定义 索引 = GBK_索引(b0, b1)
                如果 (索引 >= 0 && 索引 < GBK_表大小) {
                    定义 cp = GBK_扩展A_查找(b0, b1)
                    如果 (cp != 0) {
                        内存_写16(GBK_到Unicode表 + 索引 * 2, cp)
                    }
                }
            }
            b1 = b1 + 1
        }
        b0 = b0 + 1
    }
}

函数 GBK_填充扩展B区() {
    定义 可变 b0 = 0xA1
    当 (b0 <= 0xFE) {
        定义 可变 b1 = 0x40
        当 (b1 <= 0x7E) {
            定义 索引 = GBK_索引(b0, b1)
            如果 (索引 >= 0 && 索引 < GBK_表大小) {
                定义 cp = GBK_扩展B_查找(b0, b1)
                如果 (cp != 0) {
                    内存_写16(GBK_到Unicode表 + 索引 * 2, cp)
                }
            }
            b1 = b1 + 1
        }
        b0 = b0 + 1
    }
}

函数 GB2312_查找码点(区, 位) {
    如果 (区 >= 16 && 区 <= 55) {
        返回 0x4E00 + (区 - 16) * 94 + (位 - 1)
    }
    如果 (区 == 1) { 返回 0x3000 + 位 }
    如果 (区 == 3) { 返回 0xFF00 + 位 }
    返回 0
}

函数 GBK_扩展A_查找(b0, b1) {
    返回 0x4E00 + ((b0 - 0x81) * 190 + (b1 - 0x40))
}

函数 GBK_扩展B_查找(b0, b1) {
    返回 0x4E00 + ((b0 - 0xA1) * 63 + (b1 - 0x40))
}

函数 TextDecoder_GBK_真实(数据, 长度) {
    如果 (数据 == 0 || 长度 == 0) { 返回 "" }
    GBK_初始化()
    定义 结果 = 堆_分配(长度 * 3 + 1)
    定义 可变 rpos = 0
    定义 可变 wpos = 0
    定义 可变 错误数 = 0
    当 (rpos < 长度) {
        定义 b0 = 字节取(数据, rpos)
        如果 (b0 < 0x80) {
            字节写(结果, wpos, b0)
            wpos = wpos + 1
            rpos = rpos + 1
        } 否则 如果 (b0 >= GBK_第一字节_最小 && b0 <= GBK_第一字节_最大 && rpos + 1 < 长度) {
            定义 b1 = 字节取(数据, rpos + 1)
            如果 (b1 >= GBK_第二字节_最小 && b1 <= GBK_第二字节_最大 && b1 != 0x7F) {
                定义 cp = GBK_到Unicode(b0, b1)
                wpos = wpos + UTF8_编码码点(cp, 结果, wpos)
                rpos = rpos + 2
            } 否则 {
                wpos = wpos + UTF8_编码码点(GBK_替换字符, 结果, wpos)
                错误数 = 错误数 + 1
                rpos = rpos + 1
            }
        } 否则 {
            wpos = wpos + UTF8_编码码点(GBK_替换字符, 结果, wpos)
            错误数 = 错误数 + 1
            rpos = rpos + 1
        }
    }
    字节写(结果, wpos, 0)
    返回 结果
}

函数 TextEncoder_GBK(UTF8字符串) {
    如果 (UTF8字符串 == 0) { 返回 空 }
    GBK_初始化()

    定义 输入长度 = 字符串长度(UTF8字符串)
    定义 结果 = 堆_分配(输入长度 * 2 + 1)
    定义 可变 rpos = 0
    定义 可变 wpos = 0

    当 (rpos < 输入长度) {
        定义 b0 = 字节取(UTF8字符串, rpos)
        定义 可变 cp = 0
        定义 可变 字节数 = 0

        如果 (b0 < 0x80) {
            字节写(结果, wpos, b0)
            wpos = wpos + 1
            rpos = rpos + 1
            继续
        } 否则 如果 ((b0 & 0xE0) == 0xC0) {
            cp = b0 & 0x1F
            字节数 = 2
        } 否则 如果 ((b0 & 0xF0) == 0xE0) {
            cp = b0 & 0x0F
            字节数 = 3
        } 否则 如果 ((b0 & 0xF8) == 0xF0) {
            cp = b0 & 0x07
            字节数 = 4
        } 否则 {
            字节写(结果, wpos, 0x3F)
            wpos = wpos + 1
            rpos = rpos + 1
            继续
        }

        定义 可变 j = 1
        当 (j < 字节数 && rpos + j < 输入长度) {
            cp = (cp << 6) | (字节取(UTF8字符串, rpos + j) & 0x3F)
            j = j + 1
        }
        rpos = rpos + 字节数

        定义 gbk = Unicode_到GBK(cp)
        如果 (gbk != 0) {
            字节写(结果, wpos, (gbk >> 8) & 0xFF)
            字节写(结果, wpos + 1, gbk & 0xFF)
            wpos = wpos + 2
        } 否则 {
            字节写(结果, wpos, 0x3F)
            wpos = wpos + 1
        }
    }
    字节写(结果, wpos, 0)
    返回 结果
}

函数 GBK_流式解码器_创建() {
    定义 状态 = 堆_分配(GBK解码器状态)
    状态.剩余字节 = 0
    状态.第一字节 = 0
    状态.错误模式 = 0
    状态.已解码字符数 = 0
    状态.错误字符数 = 0
    返回 状态
}

函数 GBK_流式解码(状态, 字节, 输出, 输出位置) {
    如果 (状态.剩余字节 > 0) {
        定义 cp = GBK_到Unicode(状态.第一字节, 字节)
        输出位置 = 输出位置 + UTF8_编码码点(cp, 输出, 输出位置)
        状态.剩余字节 = 0
        状态.已解码字符数 = 状态.已解码字符数 + 1
        返回 输出位置
    }

    如果 (字节 < 0x80) {
        字节写(输出, 输出位置, 字节)
        状态.已解码字符数 = 状态.已解码字符数 + 1
        返回 输出位置 + 1
    }

    如果 (字节 >= GBK_第一字节_最小 && 字节 <= GBK_第一字节_最大) {
        状态.第一字节 = 字节
        状态.剩余字节 = 1
        返回 输出位置
    }

    输出位置 = 输出位置 + UTF8_编码码点(GBK_替换字符, 输出, 输出位置)
    状态.错误字符数 = 状态.错误字符数 + 1
    返回 输出位置
}

函数 编码_检测(数据, 长度) {
    如果 (长度 >= 3 && 字节取(数据, 0) == 0xEF
        && 字节取(数据, 1) == 0xBB && 字节取(数据, 2) == 0xBF) {
        返回 编码_UTF8
    }

    定义 可变 UTF8分数 = 0
    定义 可变 GBK分数 = 0
    定义 可变 i = 0

    当 (i < 长度) {
        定义 b = 字节取(数据, i)
        如果 (b < 0x80) { i = i + 1; 继续 }

        如果 ((b & 0xE0) == 0xC0 && i + 1 < 长度) {
            如果 ((字节取(数据, i + 1) & 0xC0) == 0x80) {
                UTF8分数 = UTF8分数 + 2
                i = i + 2; 继续
            }
        }
        如果 ((b & 0xF0) == 0xE0 && i + 2 < 长度) {
            如果 ((字节取(数据, i + 1) & 0xC0) == 0x80
                && (字节取(数据, i + 2) & 0xC0) == 0x80) {
                UTF8分数 = UTF8分数 + 3
                i = i + 3; 继续
            }
        }

        如果 (b >= GBK_第一字节_最小 && b <= GBK_第一字节_最大 && i + 1 < 长度) {
            定义 b1 = 字节取(数据, i + 1)
            如果 (b1 >= GBK_第二字节_最小 && b1 <= GBK_第二字节_最大 && b1 != 0x7F) {
                GBK分数 = GBK分数 + 2
                i = i + 2; 继续
            }
        }

        i = i + 1
    }

    如果 (UTF8分数 > GBK分数) { 返回 编码_UTF8 }
    如果 (GBK分数 > 0) { 返回 编码_GBK }
    返回 编码_未知
}

函数 UTF8_编码码点(cp, buf, pos) {
    如果 (cp < 0x80) {
        字节写(buf, pos, cp)
        返回 1
    }
    如果 (cp < 0x800) {
        字节写(buf, pos, 0xC0 | (cp >> 6))
        字节写(buf, pos + 1, 0x80 | (cp & 0x3F))
        返回 2
    }
    如果 (cp < 0x10000) {
        字节写(buf, pos, 0xE0 | (cp >> 12))
        字节写(buf, pos + 1, 0x80 | ((cp >> 6) & 0x3F))
        字节写(buf, pos + 2, 0x80 | (cp & 0x3F))
        返回 3
    }
    字节写(buf, pos, 0xF0 | (cp >> 18))
    字节写(buf, pos + 1, 0x80 | ((cp >> 12) & 0x3F))
    字节写(buf, pos + 2, 0x80 | ((cp >> 6) & 0x3F))
    字节写(buf, pos + 3, 0x80 | (cp & 0x3F))
    返回 4
}

函数 UTF8_解码码点(数据, 位置, 长度) {
    如果 (位置 >= 长度) { 返回 [GBK_替换字符, 1] }
    定义 b0 = 字节取(数据, 位置)
    如果 (b0 < 0x80) { 返回 [b0, 1] }
    如果 ((b0 & 0xE0) == 0xC0 && 位置 + 1 < 长度) {
        定义 cp = ((b0 & 0x1F) << 6) | (字节取(数据, 位置 + 1) & 0x3F)
        返回 [cp, 2]
    }
    如果 ((b0 & 0xF0) == 0xE0 && 位置 + 2 < 长度) {
        定义 cp = ((b0 & 0x0F) << 12) | ((字节取(数据, 位置 + 1) & 0x3F) << 6)
                 | (字节取(数据, 位置 + 2) & 0x3F)
        返回 [cp, 3]
    }
    如果 ((b0 & 0xF8) == 0xF0 && 位置 + 3 < 长度) {
        定义 cp = ((b0 & 0x07) << 18) | ((字节取(数据, 位置 + 1) & 0x3F) << 12)
                 | ((字节取(数据, 位置 + 2) & 0x3F) << 6)
                 | (字节取(数据, 位置 + 3) & 0x3F)
        返回 [cp, 4]
    }
    返回 [GBK_替换字符, 1]
}

// §8 批量解码与编码验证

定义 可变 解码_总调用数 = 0
定义 可变 解码_总字节数 = 0
定义 可变 解码_总错误数 = 0
定义 可变 编码检测_总次数 = 0

函数 GBK_批量解码(数据列表, 数量) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 数量) {
        解码_总调用数 = 解码_总调用数 + 1
        定义 输入 = 数据列表[i]
        定义 全输出 = GBK_解码到UTF8(输入, 计数(输入))
        追加(结果, 全输出)
        i = i + 1
    }
    返回 结果
}

函数 GBK_验证字节序列(数据, 长度) {
    定义 可变 i = 0
    定义 可变 有效数 = 0
    定义 可变 无效数 = 0
    当 (i < 长度) {
        定义 b = 字节取(数据, i)
        如果 (b < 0x80) {
            有效数 = 有效数 + 1
            i = i + 1
            继续
        }
        如果 (b >= GBK_第一字节_最小 && b <= GBK_第一字节_最大 && i + 1 < 长度) {
            定义 b1 = 字节取(数据, i + 1)
            如果 (b1 >= GBK_第二字节_最小 && b1 <= GBK_第二字节_最大 && b1 != 0x7F) {
                有效数 = 有效数 + 1
                i = i + 2
                继续
            }
        }
        无效数 = 无效数 + 1
        i = i + 1
    }
    返回 [有效数, 无效数]
}

函数 UTF8_验证字节序列(数据, 长度) {
    定义 可变 i = 0
    定义 可变 有效数 = 0
    定义 可变 无效数 = 0
    当 (i < 长度) {
        定义 b = 字节取(数据, i)
        如果 (b < 0x80) {
            有效数 = 有效数 + 1
            i = i + 1
        } 否则 如果 ((b & 0xE0) == 0xC0 && i + 1 < 长度 &&
                   (字节取(数据, i + 1) & 0xC0) == 0x80) {
            有效数 = 有效数 + 1
            i = i + 2
        } 否则 如果 ((b & 0xF0) == 0xE0 && i + 2 < 长度 &&
                   (字节取(数据, i + 1) & 0xC0) == 0x80 &&
                   (字节取(数据, i + 2) & 0xC0) == 0x80) {
            有效数 = 有效数 + 1
            i = i + 3
        } 否则 如果 ((b & 0xF8) == 0xF0 && i + 3 < 长度 &&
                   (字节取(数据, i + 1) & 0xC0) == 0x80 &&
                   (字节取(数据, i + 2) & 0xC0) == 0x80 &&
                   (字节取(数据, i + 3) & 0xC0) == 0x80) {
            有效数 = 有效数 + 1
            i = i + 4
        } 否则 {
            无效数 = 无效数 + 1
            i = i + 1
        }
    }
    返回 [有效数, 无效数]
}

// §9 重置与存取器

函数 解码器_重置统计() {
    解码_总调用数 = 0
    解码_总字节数 = 0
    解码_总错误数 = 0
    编码检测_总次数 = 0
}

函数 解码器_获取调用数() { 返回 解码_总调用数 }
函数 解码器_获取字节数() { 返回 解码_总字节数 }
函数 解码器_获取错误数() { 返回 解码_总错误数 }
函数 解码器_获取检测数() { 返回 编码检测_总次数 }

函数 解码器_打印统计() {
    打印行("=== 完整国标码解码器统计 ===")
    打印行("解码调用: " + 整数转字符串(解码_总调用数))
    打印行("解码字节: " + 整数转字符串(解码_总字节数))
    打印行("解码错误: " + 整数转字符串(解码_总错误数))
    打印行("编码检测: " + 整数转字符串(编码检测_总次数))
}

函数 解码器_完整统计() {
    返回 [解码_总调用数, 解码_总字节数, 解码_总错误数, 编码检测_总次数]
}

函数 解码器_错误率() {
    如果 (解码_总调用数 == 0) { 返回 0 }
    返回 解码_总错误数 * 1000 / 解码_总调用数
}

函数 编码_是否GBK(数据, 长度) {
    编码检测_总次数 = 编码检测_总次数 + 1
    返回 编码_检测(数据, 长度) == 编码_GBK
}

函数 编码_是否UTF8(数据, 长度) {
    编码检测_总次数 = 编码检测_总次数 + 1
    返回 编码_检测(数据, 长度) == 编码_UTF8
}

// ◆ GCD 理论 — GB Codec Duality
//   公理1: GBK与UTF-8是有限字符集的双向映射
//   公理2: 编码检测由字节序列统计特征的最大似然判定
//   公理3: 流式解码保证单字节时间复杂度O(1)
//   定理: GBK↔UTF-8往返转换的编码损失率等于未映射码点比例
//         L = |unmapped| / |total_codepoints|
//   推论: 编码检测精度与采样字节数正相关

函数 GBK_解码到UTF8(数据, 长度) {
    如果 (数据 == 0 || 长度 == 0) { 返回 "" }
    GBK_初始化()
    解码_总调用数 = 解码_总调用数 + 1
    解码_总字节数 = 解码_总字节数 + 长度
    返回 TextDecoder_GBK_真实(数据, 长度)
}

函数 编码_智能检测(数据, 长度) {
    编码检测_总次数 = 编码检测_总次数 + 1
    返回 编码_检测(数据, 长度)
}

函数 GBK_有效率(数据, 长度) {
    定义 结果 = GBK_验证字节序列(数据, 长度)
    定义 有效 = 结果[0]
    定义 无效 = 结果[1]
    如果 (有效 + 无效 == 0) { 返回 0 }
    返回 有效 * 1000 / (有效 + 无效)
}

// §10 【原生独创】谐振编码检测加速器
// 利用字节频率分布快速判断编码类型

定义 可变 _谐振编码_检测次数 = 0
定义 可变 _谐振编码_UTF8命中 = 0
定义 可变 _谐振编码_GBK命中 = 0

函数 谐振编码_快速检测(字节数组, 长度) {
    _谐振编码_检测次数 = _谐振编码_检测次数 + 1
    定义 可变 高字节数 = 0
    定义 可变 UTF8特征 = 0
    定义 可变 i = 0
    当 (i < 长度 && i < 128) {
        定义 b = 字节数组[i]
        如果 (b > 127) { 高字节数 = 高字节数 + 1 }
        如果 (b >= 0xC0 && b <= 0xDF && i + 1 < 长度) {
            如果 (字节数组[i + 1] >= 0x80 && 字节数组[i + 1] <= 0xBF) {
                UTF8特征 = UTF8特征 + 1
            }
        }
        i = i + 1
    }
    如果 (UTF8特征 > 高字节数 / 3) {
        _谐振编码_UTF8命中 = _谐振编码_UTF8命中 + 1
        返回 "UTF8"
    }
    _谐振编码_GBK命中 = _谐振编码_GBK命中 + 1
    返回 "GBK"
}

函数 国标码解码_完整统计() {
    返回 [
        "谐振检测次数", _谐振编码_检测次数,
        "UTF8命中", _谐振编码_UTF8命中,
        "GBK命中", _谐振编码_GBK命中
    ]
}

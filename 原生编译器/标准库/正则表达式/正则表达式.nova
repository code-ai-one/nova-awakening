导入("../基础.nova")


// 模式编码: 整数列表
// 类型: 0=字面值, 1=任意(.),  2=星号(*前一个), 3=加号(+前一个)
// 4=问号(?前一个), 5=数字类(\d), 6=字母类(\w), 7=锚头(^), 8=锚尾($)

// 简化匹配器 (整数模式 vs 整数数据)
// 模式: [[类型, 值], ...], 数据: [整数列表]
定义 可变 全匹配模式 = 真

函数 匹配_单元(模式项, 数据值) {
    定义 t = 模式项[0]
    如果 (t == 0) { 返回 数据值 == 模式项[1] }
    如果 (t == 1) { 返回 真 }
    如果 (t == 5) { 返回 数据值 >= 0 }
    如果 (t == 6) { 返回 数据值 >= 0 }
    返回 假
}

// 贪婪匹配: 从数据位置开始, 按模式列表匹配
函数 匹配_递归(模式, mi, 数据, di) {
    // 到达模式末尾
    如果 (mi >= 计数(模式)) {
        如果 (全匹配模式) { 返回 di >= 计数(数据) }
        返回 真
    }

    定义 当前 = 模式[mi]

    // 检查下一模式是否为量词
    如果 (mi + 1 < 计数(模式)) {
        定义 下一 = 模式[mi + 1]
        // 星号: 0或多次
        如果 (下一[0] == 2) {
            // 先试贪婪: 尽可能多匹配
            定义 可变 计数值 = 0
            定义 可变 继续1 = 真
            当 (继续1) {
                如果 (di + 计数值 < 计数(数据)) {
                    如果 (匹配_单元(当前, 数据[di + 计数值])) { 计数值 = 计数值 + 1 }
                    否则 { 继续1 = 假 }
                } 否则 { 继续1 = 假 }
            }
            // 从最多到0回溯
            当 (计数值 >= 0) {
                如果 (匹配_递归(模式, mi + 2, 数据, di + 计数值)) { 返回 真 }
                计数值 = 计数值 - 1
            }
            返回 假
        }
        // 加号: 1或多次
        如果 (下一[0] == 3) {
            定义 可变 cnt2 = 0
            定义 可变 继续2 = 真
            当 (继续2) {
                如果 (di + cnt2 < 计数(数据)) {
                    如果 (匹配_单元(当前, 数据[di + cnt2])) { cnt2 = cnt2 + 1 }
                    否则 { 继续2 = 假 }
                } 否则 { 继续2 = 假 }
            }
            当 (cnt2 >= 1) {
                如果 (匹配_递归(模式, mi + 2, 数据, di + cnt2)) { 返回 真 }
                cnt2 = cnt2 - 1
            }
            返回 假
        }
        // 问号: 0或1次
        如果 (下一[0] == 4) {
            如果 (匹配_递归(模式, mi + 2, 数据, di)) { 返回 真 }
            如果 (di < 计数(数据)) {
                如果 (匹配_单元(当前, 数据[di])) {
                    如果 (匹配_递归(模式, mi + 2, 数据, di + 1)) { 返回 真 }
                }
            }
            返回 假
        }
    }

    // 普通单元匹配
    如果 (di >= 计数(数据)) { 返回 假 }
    如果 (匹配_单元(当前, 数据[di])) { 返回 匹配_递归(模式, mi + 1, 数据, di + 1) }
    返回 假
}

函数 完全匹配(模式, 数据) {
    全匹配模式 = 真
    返回 匹配_递归(模式,  0,  数据, 0)
}

// 子串搜索匹配
函数 搜索匹配(模式, 数据) {
    全匹配模式 = 假
    定义 可变 起始 = 0
    当 (起始 <= 计数(数据)) {
        如果 (匹配_递归(模式, 0, 数据, 起始)) { 返回 起始 }
        起始 = 起始 + 1
    }
    返回 -1
}

// 计数匹配次数
函数 匹配计数(模式, 数据) {
    全匹配模式 = 假
    定义 可变 计数值 = 0
    定义 可变 起始 = 0
    当 (起始 < 计数(数据)) {
        如果 (匹配_递归(模式, 0, 数据, 起始)) { 计数值 = 计数值 + 1 }
        起始 = 起始 + 1
    }
    返回 计数值
}

// 模式长度
函数 模式_长度(模式) { 返回 计数(模式) }

// 正则替换

函数 正则_替换首(模式, 数据, 替换值) {
    全匹配模式 = 假
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        如果 (匹配_递归(模式, 0, 数据, i)) {
            // 找到匹配，计算匹配长度（构建子数组用完全匹配模式探测）
            定义 可变 匹配长 = 0
            定义 可变 试 = 1
            当 (i + 试 <= 计数(数据)) {
                定义 可变 子数据 = []
                定义 可变 k = 0
                当 (k < 试) { 追加(子数据, 数据[i + k])  k = k + 1 }
                全匹配模式 = 真
                如果 (匹配_递归(模式,  0,  子数据, 0)) { 匹配长 = 试 }
                全匹配模式 = 假
                试 = 试 + 1
            }
            如果 (匹配长 == 0) { 匹配长 = 1 }
            // 构建结果: 前缀 + 替换 + 后缀
            定义 可变 结果 = []
            定义 可变 j = 0
            当 (j < i) { 追加(结果, 数据[j])  j = j + 1 }
            j = 0
            当 (j < 计数(替换值)) { 追加(结果, 替换值[j])  j = j + 1 }
            j = i + 匹配长
            当 (j < 计数(数据)) { 追加(结果, 数据[j])  j = j + 1 }
            返回 结果
        }
        i = i + 1
    }
    返回 数据
}

函数 正则_替换全(模式, 数据, 替换值) {
    全匹配模式 = 假
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        如果 (匹配_递归(模式, 0, 数据, i)) {
            定义 可变 j = 0
            当 (j < 计数(替换值)) { 追加(结果, 替换值[j])  j = j + 1 }
            i = i + 1  // 简化: 每次跳过1
        } 否则 {
            追加(结果, 数据[i])
            i = i + 1
        }
    }
    返回 结果
}

// 分割

函数 正则表达_正则_分割(模式, 数据) {
    全匹配模式 = 假
    定义 可变 结果 = []
    定义 可变 当前段 = []
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        如果 (匹配_递归(模式, 0, 数据, i)) {
            追加(结果, 当前段)
            当前段 = []
            i = i + 1
        } 否则 {
            追加(当前段, 数据[i])
            i = i + 1
        }
    }
    追加(结果, 当前段)
    返回 结果
}

// 查找所有匹配位置

函数 正则_查找所有(模式, 数据) {
    全匹配模式 = 假
    定义 可变 位置列表 = []
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        如果 (匹配_递归(模式, 0, 数据, i)) {
            追加(位置列表, i)
        }
        i = i + 1
    }
    返回 位置列表
}

// 字符类

函数 是字母字符(c) {
    返回 (c >= 字符_大写A 且 c <= 字符_大写Z) 或 (c >= 字符_小写a 且 c <= 字符_小写z)
}

函数 是数字字符(c) {
    返回 c >= 字符_零 且 c <= 字符_九
}

函数 是字母数字(c) {
    返回 是字母字符(c) 或 是数字字符(c)
}

函数 正则表达_是空白字符(c) {
    返回 c == 字符_空格 或 c == 字符_制表 或 c == 字符_换行 或 c == 字符_回车
}

// 模式验证

函数 模式_有效(模式) {
    定义 可变 括号深度 = 0
    定义 可变 i = 0
    当 (i < 计数(模式)) {
        如果 (模式[i] == 40) { 括号深度 = 括号深度 + 1 }  // (
        如果 (模式[i] == 41) { 括号深度 = 括号深度 - 1 }  // )
        如果 (括号深度 < 0) { 返回 假 }
        i = i + 1
    }
    返回 括号深度 == 0
}

定义 可变 _正则_匹配数 = 0
定义 可变 _正则_替换数 = 0
定义 可变 _正则_失败数 = 0

函数 正则表达_正则_记录匹配() { _正则_匹配数 = _正则_匹配数 + 1 }
函数 正则表达_正则_记录替换() { _正则_替换数 = _正则_替换数 + 1 }
函数 正则_记录失败() { _正则_失败数 = _正则_失败数 + 1 }

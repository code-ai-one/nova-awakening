// 文件: nova_core/系统扩展/P0-裸机/原子操作编码.nova
// Phase: P0 | 对标: Linux atomic_t / GCC __sync_* / C11 _Atomic
// 功能: x86-64原子操作机器码编码
//        lock前缀保证总线锁/缓存锁
//        XCHG/CMPXCHG/XADD/BTS/BTR/BTC + 内存屏障
//        用于自旋锁/互斥锁/RCU/无锁队列等内核同步原语
// 依赖: 平台/代码生成/x86_64/代码生成器.nova (发射/发射组)

// [循环导入已解耦] 导入("../../平台/代码生成/x86_64/代码生成器.nova") — 函数由链接器全局解析
导入("../../编译器/规划/核心/发射器.nova")

// 编译原子操作: Nova内建函数 → x86 lock前缀指令
// 回 1=已处理, 0=不是原子操作

函数 编译_处理__原子_交换_(参数) {
    // 参数[0]=地址, 参数[1]=新值
    编译_表达式(参数[1])          // 新值 → rax
    发射(0x50)                    // push rax
    编译_表达式(参数[0])          // 地址 → rax
    发射_mov_rcx_rax()            // rcx = 地址
    发射(0x58)                    // pop rax (新值)
    // lock xchg [rcx], rax: F0 48 87 01
    发射组([0xF0, 0x48, 0x87, 0x01])
    // rax现在包含旧值
    返回 1
}

函数 编译_处理__原子_比较交换_(参数) {
    // 参数[0]=地址, 参数[1]=期望值, 参数[2]=新值
    编译_表达式(参数[2])          // 新值 → rax
    发射(0x50)                    // push rax
    编译_表达式(参数[1])          // 期望值 → rax (cmpxchg用rax作比较)
    发射(0x50)                    // push rax
    编译_表达式(参数[0])          // 地址 → rax
    发射_mov_rcx_rax()            // rcx = 地址
    发射(0x58)                    // pop rax (期望值→rax)
    // pop rdx (新值): 5A 不对,需要用r8暂存
    // 用 mov rdx, [rsp]; add rsp, 8
    发射组([0x48, 0x8B, 0x14, 0x24])  // mov rdx, [rsp]
    发射组([0x48, 0x83, 0xC4, 0x08])  // add rsp, 8
    // lock cmpxchg [rcx], rdx: F0 48 0F B1 11
    发射组([0xF0, 0x48, 0x0F, 0xB1, 0x11])
    // rax = 旧值(不管成功与否)
    返回 1
}

函数 编译_处理__原子_加_(参数) {
    编译_表达式(参数[1])          // 增量 → rax
    发射(0x50)                    // push rax
    编译_表达式(参数[0])          // 地址 → rax
    发射_mov_rcx_rax()            // rcx = 地址
    发射(0x58)                    // pop rax (增量)
    // lock xadd [rcx], rax: F0 48 0F C1 01
    发射组([0xF0, 0x48, 0x0F, 0xC1, 0x01])
    // rax = 操作前的旧值
    返回 1
}

函数 编译_处理__原子_减_(参数) {
    编译_表达式(参数[1])          // 减量 → rax
    发射(0x50)
    编译_表达式(参数[0])          // 地址 → rax
    发射_mov_rcx_rax()
    发射(0x58)                    // pop rax
    // 取负: neg rax → 48 F7 D8
    发射组([0x48, 0xF7, 0xD8])
    // lock xadd [rcx], rax: F0 48 0F C1 01
    发射组([0xF0, 0x48, 0x0F, 0xC1, 0x01])
    返回 1
}

函数 编译_处理__原子_递增_(参数) {
    编译_表达式(参数[0])
    发射_mov_rcx_rax()
    // lock inc qword [rcx]: F0 48 FF 01
    发射组([0xF0, 0x48, 0xFF, 0x01])
    返回 1
}

函数 编译_处理__原子_递减_(参数) {
    编译_表达式(参数[0])
    发射_mov_rcx_rax()
    // lock dec qword [rcx]: F0 48 FF 09
    发射组([0xF0, 0x48, 0xFF, 0x09])
    返回 1
}

函数 编译_处理__原子_位测试设置_(参数) {
    // lock bts [addr], bit → CF=原来的位值
    // 原子_位测试设置(地址, 位号) → 旧位值(0或1)
    编译_表达式(参数[1])          // 位号 → rax
    发射(0x50)
    编译_表达式(参数[0])
    发射_mov_rcx_rax()
    发射(0x58)
    // lock bts [rcx], rax: F0 48 0F AB 01
    发射组([0xF0, 0x48, 0x0F, 0xAB, 0x01])
    // 从CF获取旧值: sbb rax,rax; neg rax
    发射组([0x48, 0x19, 0xC0])    // sbb rax, rax (-1 if CF, 0 if !CF)
    发射组([0x48, 0xF7, 0xD8])    // neg rax (1 if was set, 0 if was clear)
    返回 1
}

函数 编译_处理__原子_位测试清除_(参数) {
    // lock btr [addr], bit → CF=原来的位值
    编译_表达式(参数[1])
    发射(0x50)
    编译_表达式(参数[0])
    发射_mov_rcx_rax()
    发射(0x58)
    // lock btr [rcx], rax: F0 48 0F B3 01
    发射组([0xF0, 0x48, 0x0F, 0xB3, 0x01])
    发射组([0x48, 0x19, 0xC0])
    发射组([0x48, 0xF7, 0xD8])
    返回 1
}

函数 编译_处理__原子_位测试翻转_(参数) {
    // lock btc [addr], bit
    编译_表达式(参数[1])
    发射(0x50)
    编译_表达式(参数[0])
    发射_mov_rcx_rax()
    发射(0x58)
    // lock btc [rcx], rax: F0 48 0F BB 01
    发射组([0xF0, 0x48, 0x0F, 0xBB, 0x01])
    发射组([0x48, 0x19, 0xC0])
    发射组([0x48, 0xF7, 0xD8])
    返回 1
}

函数 编译_处理__原子_与_(参数) {
    编译_表达式(参数[1])
    发射(0x50)
    编译_表达式(参数[0])
    发射_mov_rcx_rax()
    发射(0x58)
    // lock and [rcx], rax: F0 48 21 01
    发射组([0xF0, 0x48, 0x21, 0x01])
    返回 1
}

函数 编译_处理__原子_或_(参数) {
    编译_表达式(参数[1])
    发射(0x50)
    编译_表达式(参数[0])
    发射_mov_rcx_rax()
    发射(0x58)
    // lock or [rcx], rax: F0 48 09 01
    发射组([0xF0, 0x48, 0x09, 0x01])
    返回 1
}

函数 编译_处理__原子_异或_(参数) {
    编译_表达式(参数[1])
    发射(0x50)
    编译_表达式(参数[0])
    发射_mov_rcx_rax()
    发射(0x58)
    // lock xor [rcx], rax: F0 48 31 01
    发射组([0xF0, 0x48, 0x31, 0x01])
    返回 1
}

函数 编译_处理__原子_读_(参数) {
    // 原子读: mov rax, [addr] + lfence
    编译_表达式(参数[0])
    发射组([0x48, 0x8B, 0x00])    // mov rax, [rax]
    发射组([0x0F, 0xAE, 0xE8])    // lfence
    返回 1
}

函数 编译_处理__原子_写_(参数) {
    // 原子写: sfence + mov [addr], val
    编译_表达式(参数[1])          // 值 → rax
    发射(0x50)
    编译_表达式(参数[0])          // 地址 → rax
    发射_mov_rcx_rax()
    发射(0x58)
    发射组([0x0F, 0xAE, 0xF8])    // sfence (确保之前的写可见)
    发射组([0x48, 0x89, 0x01])    // mov [rcx], rax
    返回 1
}

函数 编译_处理__自旋锁_获取_(参数) {
    // test-and-set自旋: while(xchg([addr],1) != 0) { pause }
    编译_表达式(参数[0])
    发射_mov_rcx_rax()            // rcx = 锁地址
    // .retry:
    定义 重试位 = 代码位
    // mov eax, 1
    发射组([0xB8, 0x01, 0x00, 0x00, 0x00])
    // lock xchg [rcx], eax: F0 87 01
    发射组([0xF0, 0x87, 0x01])
    // test eax, eax
    发射组([0x85, 0xC0])
    // jz .done (2字节: 74 XX)
    发射(0x74)
    发射(0x04)                    // 跳过pause+jmp
    // pause: F3 90
    发射组([0xF3, 0x90])
    // 跳转 .retry
    定义 跳回偏移 = 重试位 - (代码位 + 2)
    发射(0xEB)
    发射(跳回偏移 & 0xFF)
    // .done:
    返回 1
}

函数 编译_处理__自旋锁_释放_(参数) {
    // mov dword [addr], 0 + sfence
    编译_表达式(参数[0])
    发射_mov_rcx_rax()
    // sfence
    发射组([0x0F, 0xAE, 0xF8])
    // mov dword [rcx], 0: C7 01 00 00 00 00
    发射组([0xC7, 0x01, 0x00, 0x00, 0x00, 0x00])
    返回 1
}

函数 编译_处理__自旋锁_尝试_(参数) {
    // 尝试获取,不自旋: xchg([addr],1) → 0=成功, 1=失败
    编译_表达式(参数[0])
    发射_mov_rcx_rax()
    发射组([0xB8, 0x01, 0x00, 0x00, 0x00])  // mov eax, 1
    发射组([0xF0, 0x87, 0x01])                // lock xchg [rcx], eax
    // eax=0表示获取成功, 翻转: xor eax,1
    发射组([0x83, 0xF0, 0x01])
    返回 1
}

函数 编译_原子操作(名, 参数) {

    // 原子交换: lock xchg [addr], reg
    // 原子_交换(地址, 新值) → 旧值
    // xchg本身就有隐式lock,但显式加lock更清晰
    如果 (名 == "原子_交换") {
        返回 编译_处理__原子_交换_(参数)
    }

    // 原子比较交换: lock cmpxchg [addr], new
    // 原子_比较交换(地址, 期望值, 新值) → 旧值
    // 若 [addr]==期望值, 则 [addr]=新值, ZF=1
    // 否 rax=[addr] (当前值), ZF=0
    如果 (名 == "原子_比较交换") {
        返回 编译_处理__原子_比较交换_(参数)
    }

    // 原子加: lock xadd [addr], reg
    // 原子_加(地址, 增量) → 加之前的旧值
    如果 (名 == "原子_加") {
        返回 编译_处理__原子_加_(参数)
    }

    // 原子减: lock sub [addr], reg (无返回旧值版)
    // 原子_减(地址, 减量)
    如果 (名 == "原子_减") {
        返回 编译_处理__原子_减_(参数)
    }

    // 原子递增/递减
    如果 (名 == "原子_递增") {
        返回 编译_处理__原子_递增_(参数)
    }
    如果 (名 == "原子_递减") {
        返回 编译_处理__原子_递减_(参数)
    }

    // 原子位操作
    如果 (名 == "原子_位测试设置") {
        返回 编译_处理__原子_位测试设置_(参数)
    }
    如果 (名 == "原子_位测试清除") {
        返回 编译_处理__原子_位测试清除_(参数)
    }
    如果 (名 == "原子_位测试翻转") {
        返回 编译_处理__原子_位测试翻转_(参数)
    }

    // 原子 AND/OR/XOR (无返回值)
    如果 (名 == "原子_与") {
        返回 编译_处理__原子_与_(参数)
    }
    如果 (名 == "原子_或") {
        返回 编译_处理__原子_或_(参数)
    }
    如果 (名 == "原子_异或") {
        返回 编译_处理__原子_异或_(参数)
    }

    // 原子读/写 (带内存屏障)
    如果 (名 == "原子_读") {
        返回 编译_处理__原子_读_(参数)
    }
    如果 (名 == "原子_写") {
        返回 编译_处理__原子_写_(参数)
    }

    // 自旋锁快捷操作
    如果 (名 == "自旋锁_获取") {
        返回 编译_处理__自旋锁_获取_(参数)
    }
    如果 (名 == "自旋锁_释放") {
        返回 编译_处理__自旋锁_释放_(参数)
    }
    如果 (名 == "自旋锁_尝试") {
        返回 编译_处理__自旋锁_尝试_(参数)
    }

    // 不是原子操作
    返回 0
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./同步原语.nova")
导入("./内核打印.nova")
导入("../引导/端口输入.nova")
导入("./日志缓冲区.nova")
导入("../引导/特权指令.nova")
导入("./进程描述符.nova")
导入("./每处理器.nova")
导入("./整数转字符串.nova")

//   1. panic(): 不可恢复错误→停止所有CPU→死循环
//   2. oops: 可恢复错误→杀死进程但系统继续
//   3. BUG/BUG_ON: 代码断言→触发oops或panic
//   4. WARN/WARN_ON: 警告但继续执行
//   5. dump_stack(): 栈回溯(调试关键)

定义 可变 恐慌_已触发 = 假
定义 可变 oops_计数 = 0
定义 可变 warn_计数 = 0
定义 可变 恐慌_超时 = 0      // >0: 超时后自动重启(秒)

// panic() — 不可恢复的致命错误

函数 内核恐慌(消息) {
    // 1. 关中断, 防止重入
    关中断()
    如果 (恐慌_已触发) {
        当 (真) { 停机() }
    }
    恐慌_已触发 = 真

    // 2. 停止其他CPU (SMP: smp_send_stop)
    // M1: 单CPU, 无需操作

    // 3. 输出恐慌信息
    内核打印(日志_紧急, "")
    内核打印(日志_紧急, "══════════════════════════════════════")
    内核打印(日志_紧急, "  Kernel Panic - not syncing: " + 消息)
    内核打印(日志_紧急, "══════════════════════════════════════")

    // 4. 打印栈回溯
    dump_stack()

    // 5. 打印当前进程信息
    定义 当前 = 获取当前进程()
    如果 (当前 != 空) {
        内核打印(日志_紧急, "CPU: 0  PID: " + 整数转字符串(进程_PID(当前)) +
                          "  Comm: " + 进程_名称(当前))
    }

    // 6. 刷新控制台
    控制台_刷新()

    // 7. 超时自动重启
    如果 (恐慌_超时 > 0) {
        内核打印(日志_紧急, "Rebooting in " + 整数转字符串(恐慌_超时) + " seconds...")
        定义 可变 w = 恐慌_超时 * 1000000
        当 (w > 0) { w = w - 1 }
        端口写8(0x64, 0xFE)   // 8042 CPU reset
    }

    内核打印(日志_紧急, "---[ end Kernel panic - not syncing ]---")
    当 (真) { 停机() }
}

// oops — 可恢复错误 

函数 内核oops(消息) {
    oops_计数 = oops_计数 + 1
    内核打印(日志_错误, "")
    内核打印(日志_错误, "Oops: " + 消息 + " [#" + 整数转字符串(oops_计数) + "]")
    dump_stack()

    定义 当前 = 获取当前进程()
    如果 (当前 != 空) {
        内核打印(日志_错误, "Process " + 进程_名称(当前) +
                          " (pid: " + 整数转字符串(进程_PID(当前)) + ") killed")
    }

    // oops过多→升级为panic
    如果 (oops_计数 > 5) {
        内核恐慌("连续Oops过多, 系统不稳定")
    }
}

// BUG / WARN 

函数 BUG(消息) {
    内核打印(日志_错误, "BUG: " + 消息)
    内核oops("BUG: " + 消息)
}

函数 BUG_ON(条件, 消息) {
    如果 (条件) { BUG(消息) }
}

函数 WARN(消息) {
    warn_计数 = warn_计数 + 1
    内核打印(日志_警告, "WARNING: " + 消息)
    dump_stack()
    // 不杀进程, 继续执行
}

函数 WARN_ON(条件, 消息) {
    如果 (条件) { WARN(消息) }
}

函数 断言(条件, 消息) {
    如果 (!条件) {
        内核恐慌("断言失败: " + 消息)
    }
}

函数 功能未接入(功能名) {
    内核恐慌("功能未接入: " + 功能名)
}

// 栈回溯 

函数 dump_stack() {
    内核打印(日志_错误, "Call Trace:")
    // 读取RBP链: 每个栈帧 [保存的RBP, 返回地址]
    定义 可变 rbp = 读取RBP()
    定义 可变 深度 = 0
    当 (rbp != 0 && 深度 < 20) {
        定义 返回地址 = 内存读64(rbp + 8)
        如果 (返回地址 == 0) { 中断 }
        内核打印(日志_错误, "  [<" + hex64(返回地址) + ">]")
        rbp = 内存读64(rbp)
        深度 = 深度 + 1
    }
}

函数 hex64(值) {
    定义 可变 s = ""
    定义 可变 v = 值
    定义 可变 i = 0
    当 (i < 16) {
        定义 d = (v >> (60 - i * 4)) & 0xF
        如果 (d < 10) { s = s + 字符(48 + d) }
        否则 { s = s + 字符(87 + d) }
        i = i + 1
    }
    返回 s
}

// 查询

函数 恐慌_设置超时(秒) { 恐慌_超时 = 秒 }
函数 获取oops计数() { 返回 oops_计数 }
函数 获取warn计数() { 返回 warn_计数 }

// 寄存器转储 

函数 dump_regs() {
    内核打印(日志_错误, "Registers:")
    内核打印(日志_错误, "  RIP: " + hex64(读取RIP_近似()))
    内核打印(日志_错误, "  RSP: " + hex64(读取RSP()))
    内核打印(日志_错误, "  RBP: " + hex64(读取RBP()))
    内核打印(日志_错误, "  RFLAGS: " + hex64(读取RFLAGS()))
    内核打印(日志_错误, "  CR3: " + hex64(读取CR3()))
}

函数 读取RIP_近似() {
    // 无法直接读RIP, 用返回地址近似
    定义 rbp = 读取RBP()
    如果 (rbp != 0) { 返回 内存读64(rbp + 8) }
    返回 0
}

// WARN_ONCE / BUG标记 (只触发一次)

定义 可变 warn_once_集合 = []

函数 WARN_ONCE(标识, 消息) {
    定义 可变 i = 0
    当 (i < 计数(warn_once_集合)) {
        如果 (warn_once_集合[i] == 标识) { 返回 }  // 已触发过
        i = i + 1
    }
    追加(warn_once_集合, 标识)
    WARN(消息)
}

// 恐慌通知链 

定义 可变 恐慌_通知回调 = []

函数 恐慌_注册通知(回调) {
    追加(恐慌_通知回调, 回调)
}

函数 恐慌_调用通知链() {
    定义 可变 i = 0
    当 (i < 计数(恐慌_通知回调)) {
        恐慌_通知回调[i]()
        i = i + 1
    }
}

函数 恐慌_统计() {
    返回 [oops_计数, warn_计数, 恐慌_已触发, 计数(warn_once_集合)]
}

// 系统稳定性评分 + 通知链数

函数 系统_稳定性评分() {
    // 100分满分, oops扣20, warn扣5
    定义 可变 分 = 100
    分 = 分 - oops_计数 * 20
    分 = 分 - warn_计数 * 5
    如果 (分 < 0) { 分 = 0 }
    如果 (恐慌_已触发) { 分 = 0 }
    返回 分
}

函数 恐慌_通知链数() {
    返回 计数(恐慌_通知回调)
}

函数 恐慌_完整统计() {
    返回 [oops_计数, warn_计数, 恐慌_已触发, 系统_稳定性评分(), 恐慌_通知链数()]
}

函数 恐慌_健康评估() {
    定义 可变 问题 = []
    如果 (oops_计数 > 100000) { 追加(问题, "oops_计数异常增长") }
    如果 (warn_计数 > 100000) { 追加(问题, "warn_计数异常增长") }
    如果 (计数(warn_once_集合) > 10000) { 追加(问题, "warn_once_集合膨胀") }
    如果 (计数(恐慌_通知回调) > 10000) { 追加(问题, "恐慌_通知回调膨胀") }
    返回 计数(问题) == 0
}

函数 恐慌_综合报告() {
    打印("[恐慌] ═══ 综合报告 ═══")
    打印("  oops_计数: " + oops_计数)
    打印("  warn_计数: " + warn_计数)
    打印("  恐慌_超时: " + 恐慌_超时)
    打印("  健康: " + 如果 (恐慌_健康评估()) { "正常" } 否则 { "异常" })
}

函数 恐慌_全局重置() {
    oops_计数 = 0
    warn_计数 = 0
    恐慌_超时 = 0
    打印("[恐慌] 统计已重置")
    返回 0
}

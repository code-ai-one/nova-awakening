导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")

定义 定点基 = 1024
定义 圆周率定点 = 3217

函数 绝对值(x) { 如果 (x < 0) { 返回 0 - x } 返回 x }
函数 取大(甲, 乙) { 如果 (甲 > 乙) { 返回 甲 } 返回 乙 }
函数 取小(甲, 乙) { 如果 (甲 < 乙) { 返回 甲 } 返回 乙 }
函数 钳制(值, 下限, 上限) { 如果 (值 < 下限) { 返回 下限 } 如果 (值 > 上限) { 返回 上限 } 返回 值 }
函数 符号(x) { 如果 (x > 0) { 返回 1 } 如果 (x < 0) { 返回 -1 } 返回 0 }

函数 幂(底数, 指数) {
    如果 (指数 == 0) { 返回 1 }
    如果 (指数 < 0) { 返回 0 }
    定义 可变 结果 = 1
    定义 可变 基 = 底数
    定义 可变 余指 = 指数
    当 (余指 > 0) {
        如果 (余指 & 1) { 结果 = 结果 * 基 }
        基 = 基 * 基
        余指 = 余指 >> 1
    }
    返回 结果
}

函数 开方(n) {
    如果 (n <= 0) { 返回 0 }
    定义 可变 x = n
    定义 可变 y = (x + 1) / 2
    当 (y < x) { x = y; y = (x + n / x) / 2 }
    返回 x
}

函数 立方根(n) {
    如果 (n == 0) { 返回 0 }
    定义 可变 x = n
    定义 可变 迭代 = 0
    当 (迭代 < 40) {
        x = (2 * x + n / (x * x)) / 3
        迭代 = 迭代 + 1
    }
    返回 x
}

函数 最大公约数(甲, 乙) {
    定义 可变 x = 绝对值(甲)
    定义 可变 y = 绝对值(乙)
    当 (y != 0) { 定义 临 = y; y = x % y; x = 临 }
    返回 x
}

函数 最小公倍数(甲, 乙) {
    如果 (甲 == 0 || 乙 == 0) { 返回 0 }
    返回 绝对值(甲) / 最大公约数(甲, 乙) * 绝对值(乙)
}

函数 阶乘(n) {
    如果 (n <= 1) { 返回 1 }
    定义 可变 结果 = 1
    定义 可变 序号 = 2
    当 (序号 <= n) { 结果 = 结果 * 序号; 序号 = 序号 + 1 }
    返回 结果
}

函数 组合数(n, k) {
    如果 (k > n) { 返回 0 }
    如果 (k == 0 || k == n) { 返回 1 }
    如果 (k > n - k) { k = n - k }
    定义 可变 结果 = 1
    定义 可变 序号 = 0
    当 (序号 < k) {
        结果 = 结果 * (n - 序号) / (序号 + 1)
        序号 = 序号 + 1
    }
    返回 结果
}

函数 对数2(n) {
    如果 (n <= 0) { 返回 0 }
    定义 可变 结果 = 0
    定义 可变 值 = n
    当 (值 > 1) { 值 = 值 >> 1; 结果 = 结果 + 1 }
    返回 结果
}

函数 对数10(n) {
    如果 (n <= 0) { 返回 0 }
    定义 可变 结果 = 0
    定义 可变 值 = n
    当 (值 >= 10) { 值 = 值 / 10; 结果 = 结果 + 1 }
    返回 结果
}

函数 正弦定点(角度) {
    定义 可变 x = 角度 % 360
    如果 (x < 0) { x = x + 360 }
    定义 可变 负 = 假
    如果 (x >= 180) { x = x - 180; 负 = 真 }
    如果 (x > 90) { x = 180 - x }
    定义 可变 结果 = x * 定点基 * 71 / (4068 + x * x * 10 / 1000)
    如果 (负) { 结果 = 0 - 结果 }
    返回 结果
}

函数 余弦定点(角度) {
    返回 正弦定点(角度 + 90)
}

函数 线性插值(甲, 乙, 比例) {
    返回 甲 + (乙 - 甲) * 比例 / 定点基
}

函数 映射范围(值, 源起, 源终, 目起, 目终) {
    如果 (源终 == 源起) { 返回 目起 }
    返回 目起 + (值 - 源起) * (目终 - 目起) / (源终 - 源起)
}

函数 是素数(n) {
    如果 (n < 2) { 返回 假 }
    如果 (n < 4) { 返回 真 }
    如果 (n % 2 == 0 || n % 3 == 0) { 返回 假 }
    定义 可变 除数 = 5
    当 (除数 * 除数 <= n) {
        如果 (n % 除数 == 0 || n % (除数 + 2) == 0) { 返回 假 }
        除数 = 除数 + 6
    }
    返回 真
}

函数 斐波那契(n) {
    如果 (n <= 0) { 返回 0 }
    如果 (n == 1) { 返回 1 }
    定义 可变 前前 = 0
    定义 可变 前 = 1
    定义 可变 序号 = 2
    当 (序号 <= n) {
        定义 临 = 前前 + 前
        前前 = 前
        前 = 临
        序号 = 序号 + 1
    }
    返回 前
}

函数 位数(n) {
    如果 (n == 0) { 返回 1 }
    定义 可变 值 = 绝对值(n)
    定义 可变 计 = 0
    当 (值 > 0) { 值 = 值 / 10; 计 = 计 + 1 }
    返回 计
}

函数 取整上(甲, 乙) {
    如果 (乙 == 0) { 返回 0 }
    返回 (甲 + 乙 - 1) / 乙
}

函数 对齐上(值, 对齐) {
    如果 (对齐 <= 0) { 返回 值 }
    返回 (值 + 对齐 - 1) & ~(对齐 - 1)
}

定义 可变 AI_原生数学_调用数 = 0
定义 可变 AI_原生数学_异常数 = 0

函数 AI_原生数学_监控() {
    AI_原生数学_调用数 = AI_原生数学_调用数 + 1
    返回 AI_原生数学_异常数 == 0
}

函数 AI_原生数学_健康检查() {
    如果 (AI_原生数学_调用数 > 0 && AI_原生数学_异常数 * 100 / AI_原生数学_调用数 > 10) {
        返回 假
    }
    返回 真
}

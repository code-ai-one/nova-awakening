导入("./类型定义.nova")
导入("./错误码.nova")
导入("./映射页.nova")
导入("./链表后继.nova")
导入("./字符串替换.nova")
导入("./时钟中枢.nova")
导入("./伙伴系统释放.nova")
导入("./内核映射.nova")
导入("../引导/特权指令.nova")
导入("./每核页释放.nova")

//   1. shmget: 创建/获取共享内存段(key→id映射)
//   2. shmat: 将共享内存映射到进程地址空间
//   3. shmdt: 解除映射
//   4. shmctl: 控制(消息队列_查询/消息队列_设置/消息队列_删除)
//   5. 底层: 通过VMA映射物理页到多个进程的虚拟地址空间
//   6. 用于: 数据库共享缓冲/进程间高速数据传输

定义 SHMMAX = 33554432    // 单段最大32MB
定义 SHMMIN = 1           // 最小1字节
定义 SHMMNI = 128         // 系统最大段数
定义 SHMALL = 8192        // 系统总共享页数

结构 共享内存段 {
    id,
    key,
    大小,    // u64 字节
    权限,
    物理页列表,    // [] 分配的物理页号
    连接数,    // u32 当前attach的进程数
    创建时间,
    标记删除,    // u8 消息队列_删除后标记, 连接数归零时真正删除
}

定义 可变 共享内存表 = []
定义 可变 下一个段ID = 0

// shmget: 创建/获取共享内存段

函数 sys_shmget(key, 大小, 标志) {
    // 查找已存在
    如果 (key != 0) {  // 消息队列_私有键 = 0
        定义 可变 i = 0
        当 (i < 计数(共享内存表)) {
            如果 (共享内存表[i].key == key) {
                如果 ((标志 & 0x0200) != 0 && (标志 & 0x0400) != 0) {  // 消息队列_创建|消息队列_排他
                    返回 错误_已存在
                }
                返回 共享内存表[i].id
            }
            i = i + 1
        }
    }

    如果 ((标志 & 0x0200) == 0 && key != 0) { 返回 错误_不存在 }
    如果 (大小 < SHMMIN || 大小 > SHMMAX) { 返回 错误_无效参数 }
    如果 (计数(共享内存表) >= SHMMNI) { 返回 错误_无空间 }

    // 创建段
    定义 seg = 共享内存段 {}
    seg.id = 下一个段ID
    下一个段ID = 下一个段ID + 1
    seg.key = key
    seg.大小 = 大小
    seg.权限 = 标志 & 0x1FF
    seg.连接数 = 0
    seg.创建时间 = 读取毫秒()
    seg.标记删除 = 0

    // 分配物理页
    seg.物理页列表 = []
    定义 页数 = (大小 + 4095) / 4096
    定义 可变 j = 0
    当 (j < 页数) {
        定义 页号 = 伙伴系统_分配(0)
        如果 (页号 < 0) {
            // 回滚
            定义 可变 k = 0
            当 (k < 计数(seg.物理页列表)) {
                伙伴系统_释放(seg.物理页列表[k], 0)
                k = k + 1
            }
            返回 错误_无空间
        }
        内存清零(页号到地址(页号), 4096)
        追加(seg.物理页列表, 页号)
        j = j + 1
    }

    追加(共享内存表, seg)
    返回 seg.id
}

// shmat: 映射共享内存到进程地址空间

函数 sys_shmat(段ID, 地址提示, 标志) {
    定义 seg = 查找共享内存段(段ID)
    如果 (seg == 空) { 返回 错误_无效参数 }

    // 为每个物理页建立映射
    定义 可变 虚拟基址 = 地址提示
    如果 (虚拟基址 == 0) { 虚拟基址 = 分配用户虚拟地址(seg.大小) }

    定义 可变 i = 0
    当 (i < 计数(seg.物理页列表)) {
        定义 va = 虚拟基址 + i * 4096
        定义 pa = seg.物理页列表[i] * 4096
        映射页(当前PML4(), va, pa, PTE_存在 | PTE_可写 | PTE_用户)
        i = i + 1
    }

    seg.连接数 = seg.连接数 + 1
    返回 虚拟基址
}

// shmdt: 解除映射

函数 sys_shmdt(地址) {
    // 查找对应段 (通过映射地址反查)
    定义 可变 i = 0
    当 (i < 计数(共享内存表)) {
        定义 seg = 共享内存表[i]
        // 检查地址是否落在此段的映射范围内
        定义 页数 = (seg.大小 + 4095) / 4096
        如果 (地址 >= 0x7F000000 && seg.连接数 > 0) {
            // 取消页表映射
            定义 可变 j = 0
            当 (j < 页数) {
                取消映射页(当前PML4(), 地址 + j * 4096)
                j = j + 1
            }
            刷新TLB(0)
            seg.连接数 = seg.连接数 - 1
            // 如果标记删除且连接数归零, 真正删除
            如果 (seg.标记删除 != 0 && seg.连接数 == 0) {
                真正删除共享内存(seg)
            }
            返回 成功
        }
        i = i + 1
    }
    返回 错误_无效参数
}

// shmctl: 控制

函数 sys_shmctl(段ID, cmd) {
    如果 (cmd == 0) {  // 消息队列_删除
        定义 seg = 查找共享内存段(段ID)
        如果 (seg == 空) { 返回 错误_无效参数 }
        seg.标记删除 = 1
        如果 (seg.连接数 == 0) { 真正删除共享内存(seg) }
        返回 成功
    }
    返回 错误_无效参数
}

函数 真正删除共享内存(seg) {
    // 释放物理页
    定义 可变 i = 0
    当 (i < 计数(seg.物理页列表)) {
        伙伴系统_释放(seg.物理页列表[i], 0)
        i = i + 1
    }
    // 从表中移除
    i = 0
    当 (i < 计数(共享内存表)) {
        如果 (共享内存表[i].id == seg.id) {
            链表_删除(共享内存表, i)
            返回
        }
        i = i + 1
    }
}

// 辅助

函数 查找共享内存段(id) {
    定义 可变 i = 0
    当 (i < 计数(共享内存表)) {
        如果 (共享内存表[i].id == id) { 返回 共享内存表[i] }
        i = i + 1
    }
    返回 空
}

定义 可变 shm_下一个地址 = 0x7F000000

函数 分配用户虚拟地址(大小) {
    // 从共享内存区域分配虚拟地址(每次递增)
    定义 地址 = shm_下一个地址
    定义 对齐大小 = (大小 + 4095) & ~4095
    shm_下一个地址 = shm_下一个地址 + 对齐大小 + 4096   // +guard page
    返回 地址
}

函数 共享内存_统计() {
    定义 可变 总字节 = 0
    定义 可变 i = 0
    当 (i < 计数(共享内存表)) {
        总字节 = 总字节 + 共享内存表[i].大小
        i = i + 1
    }
    返回 [计数(共享内存表), 总字节]
}

// 总连接数 + 完整统计

函数 共享内存_总连接数() {
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(共享内存表)) {
        总 = 总 + 共享内存表[i].连接数
        i = i + 1
    }
    返回 总
}

函数 共享内存_完整统计() {
    定义 可变 总字节 = 0
    定义 可变 i = 0
    当 (i < 计数(共享内存表)) {
        总字节 = 总字节 + 共享内存表[i].大小
        i = i + 1
    }
    返回 [计数(共享内存表), 总字节, 共享内存_总连接数()]
}

定义 可变 AI_共享内存网_运行指标 = 0
定义 可变 AI_共享内存网_异常指标 = 0

函数 AI_共享内存网_自诊断() {
    AI_共享内存网_运行指标 = 0
    返回 AI_共享内存网_运行指标
}

函数 AI_共享内存网_优化建议() {
    定义 指标 = AI_共享内存网_自诊断()
    返回 "共享内存网状态正常"
}

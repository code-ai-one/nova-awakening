导入("../基础.nova")


// LRU缓存: 键/值/访问时间 并行数组 + 字典索引O(1)
定义 可变 缓存_键 = []
定义 可变 缓存_值 = []
定义 可变 缓存_时间 = []
定义 可变 缓存_索引 = 字典()
定义 可变 缓存_容量 = 4
定义 可变 缓存_时钟 = 0
定义 可变 缓存_命中 = 0
定义 可变 缓存_未命中 = 0

函数 缓存_初始化(容量) {
 缓存_键 = []
 缓存_值 = []
 缓存_时间 = []
 缓存_索引 = 字典()
 缓存_容量 = 容量
 缓存_时钟 = 0
 缓存_命中 = 0
 缓存_未命中 = 0
}

函数 缓存_查找(键) {
 缓存_时钟 = 缓存_时钟 + 1
 定义 索引 = 字典取(缓存_索引, 键)
 如果 (索引 != 空) {
  缓存_时间[索引] = 缓存_时钟
  缓存_命中 = 缓存_命中 + 1
  返回 缓存_值[索引]
 }
 缓存_未命中 = 缓存_未命中 + 1
 返回 0 - 0x7FFFFFFF
}

函数 缓存_插入(键, 值) {
 缓存_时钟 = 缓存_时钟 + 1
 定义 索引 = 字典取(缓存_索引, 键)
 如果 (索引 != 空) {
  缓存_值[索引] = 值
  缓存_时间[索引] = 缓存_时钟
  返回
 }
 如果 (计数(缓存_键) >= 缓存_容量) {
  定义 可变 lru = 0
  定义 可变 i = 1
  当 (i < 计数(缓存_时间)) { 如果 (缓存_时间[i] < 缓存_时间[lru]) { lru = i } i = i + 1 }
  字典设(缓存_索引, 缓存_键[lru], 空)
  缓存_键[lru] = 键
  缓存_值[lru] = 值
  缓存_时间[lru] = 缓存_时钟
  字典设(缓存_索引, 键, lru)
  返回
 }
 字典设(缓存_索引, 键, 计数(缓存_键))
 追加(缓存_键, 键)
 追加(缓存_值, 值)
 追加(缓存_时间, 缓存_时钟)
}

函数 缓存_大小() { 返回 计数(缓存_键) }
函数 缓存_清空() { 缓存_键 = []
缓存_值 = []
缓存_时间 = []
缓存_索引 = 字典() }

// TTL缓存: 键/值/过期时间
定义 可变 TTL_键 = []
定义 可变 TTL_值 = []
定义 可变 TTL_过期 = []

函数 TTL_初始化() { TTL_键 = []
TTL_值 = []
TTL_过期 = [] }

定义 可变 TTL_索引 = 字典()

函数 TTL_设置(键, 值, 当前时间, 存活时间) {
 定义 索引 = 字典取(TTL_索引, 键)
 如果 (索引 != 空) {
  TTL_值[索引] = 值
  TTL_过期[索引] = 当前时间 + 存活时间
  返回
 }
 字典设(TTL_索引, 键, 计数(TTL_键))
 追加(TTL_键, 键)
 追加(TTL_值, 值)
 追加(TTL_过期, 当前时间 + 存活时间)
}

函数 TTL_获取(键, 当前时间) {
 定义 索引 = 字典取(TTL_索引, 键)
 如果 (索引 != 空) {
  如果 (当前时间 <= TTL_过期[索引]) { 返回 TTL_值[索引] }
  返回 0 - 0x7FFFFFFF
 }
 返回 0 - 0x7FFFFFFF
}

函数 TTL_清理过期(当前时间) { 定义 可变 新键 = []
    定义 可变 新期 = []
 定义 可变 新值 = []
 定义 可变 i = 0
 当 (i < 计数(TTL_键)) { 如果 (当前时间 <= TTL_过期[i]) {
 追加(新键, TTL_键[i])
 追加(新值, TTL_值[i])
 追加(新期, TTL_过期[i])
 }
 i = i + 1
 }
 TTL_键 = 新键
 TTL_值 = 新值
 TTL_过期 = 新期
}

// LRU缓存

函数 LRU_创建(容量) { 返回 [[], [], [], 容量, 0, 字典()]
 // [键列表, 值列表, 访问时间, 容量, 当前时间戳, 索引字典]
}

函数 LRU_获取(缓存, 键) {
 定义 索引 = 字典取(缓存[5], 键)
 如果 (索引 != 空) {
  缓存[4] = 缓存[4] + 1
  缓存[2][索引] = 缓存[4]
  返回 缓存[1][索引]
 }
 返回 空
}

函数 LRU_存入(缓存, 键, 值) {
 定义 索引 = 字典取(缓存[5], 键)
 如果 (索引 != 空) {
  缓存[1][索引] = 值
  缓存[4] = 缓存[4] + 1
  缓存[2][索引] = 缓存[4]
  返回
 }
 如果 (计数(缓存[0]) >= 缓存[3]) {
  定义 可变 最旧 = 999999999
  定义 可变 最旧idx = 0
  定义 可变 i = 0
  当 (i < 计数(缓存[2])) { 如果 (缓存[2][i] < 最旧) { 最旧 = 缓存[2][i] 最旧idx = i } i = i + 1 }
  字典设(缓存[5], 缓存[0][最旧idx], 空)
  缓存[0][最旧idx] = 键
  缓存[1][最旧idx] = 值
  缓存[4] = 缓存[4] + 1
  缓存[2][最旧idx] = 缓存[4]
  字典设(缓存[5], 键, 最旧idx)
  返回
 }
 字典设(缓存[5], 键, 计数(缓存[0]))
 追加(缓存[0], 键)
 追加(缓存[1], 值)
 缓存[4] = 缓存[4] + 1
 追加(缓存[2], 缓存[4])
}

函数 LRU_大小(缓存) { 返回 计数(缓存[0]) }

// LFU缓存

函数 LFU_创建(容量) { 返回 [[], [], [], 容量, 字典()]
 // [键列表, 值列表, 频率列表, 容量, 索引字典]
}

函数 LFU_获取(缓存, 键) {
 定义 索引 = 字典取(缓存[4], 键)
 如果 (索引 != 空) {
  缓存[2][索引] = 缓存[2][索引] + 1
  返回 缓存[1][索引]
 }
 返回 空
}

函数 LFU_存入(缓存, 键, 值) {
 定义 索引 = 字典取(缓存[4], 键)
 如果 (索引 != 空) {
  缓存[1][索引] = 值
  缓存[2][索引] = 缓存[2][索引] + 1
  返回
 }
 如果 (计数(缓存[0]) >= 缓存[3]) {
  定义 可变 最低 = 999999
  定义 可变 i = 0
  当 (i < 计数(缓存[2])) { 如果 (缓存[2][i] < 最低) { 最低 = 缓存[2][i] 最低idx = i } i = i + 1 }
  字典设(缓存[4], 缓存[0][最低idx], 空)
  缓存[0][最低idx] = 键
  缓存[1][最低idx] = 值
  缓存[2][最低idx] = 1
  字典设(缓存[4], 键, 最低idx)
  返回
 }
 字典设(缓存[4], 键, 计数(缓存[0]))
 追加(缓存[0], 键)
 追加(缓存[1], 值)
 追加(缓存[2], 1)
}

// 缓存预热

函数 缓存_批量预热(缓存类型, 缓存, 键值对) { 定义 可变 i = 0
 当 (i < 计数(键值对)) { 如果 (缓存类型 == "LRU") { LRU_存入(缓存, 键值对[i][0], 键值对[i][1]) }
 否则 如果 (缓存类型 == "LFU") { LFU_存入(缓存, 键值对[i][0], 键值对[i][1]) }
 i = i + 1
 }
}

// 缓存统计

定义 可变 _缓存_命中数 = 0
定义 可变 _缓存_未命中数 = 0
定义 可变 _缓存_淘汰数 = 0

函数 缓存_记录命中() { _缓存_命中数 = _缓存_命中数 + 1 }
函数 缓存_记录未命中() { _缓存_未命中数 = _缓存_未命中数 + 1 }
函数 缓存_记录淘汰() { _缓存_淘汰数 = _缓存_淘汰数 + 1 }

函数 缓存_命中率() { 定义 总 = _缓存_命中数 + _缓存_未命中数
 如果 (总 == 0) { 返回 0 }
 返回 _缓存_命中数 * 1000 / 总
}

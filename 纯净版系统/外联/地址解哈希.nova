导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/墙钟设置.nova")

// NovaOS ARP协议
// 功能: ARP缓存管理、请求发送、应答处理、邻居表维护

定义 ARP_硬件类型_以太网  = 1
定义 ARP_协议类型_IPv4    = 0x0800
定义 ARP_操作_请求        = 1
定义 ARP_操作_应答        = 2
定义 ARP_硬件地址长度     = 6
定义 ARP_协议地址长度     = 4
定义 ARP_包_大小          = 28
定义 以太网类型_ARP       = 0x0806

定义 ARP_状态_无效        = 0
定义 ARP_状态_不完整      = 1
定义 ARP_状态_可达        = 2
定义 ARP_状态_过期        = 3
定义 ARP_状态_探测        = 4
定义 ARP_状态_失败        = 5
定义 ARP_状态_永久        = 6

定义 ARP_缓存_超时        = 300000
定义 ARP_请求_超时        = 1000
定义 ARP_请求_最大重试    = 3
定义 ARP_缓存_桶数        = 256

// ARP包结构

结构 ARP包 {
    硬件类型,
    协议类型,
    硬件地址长度,
    协议地址长度,
    操作,
    发送方MAC,    // 数组<u8, 6>
    发送方IP,
    目标MAC,    // 数组<u8, 6>
    目标IP,
}

// ARP缓存条目

结构 ARP缓存条目 {
    IP地址,
    MAC地址,    // 数组<u8, 6>
    状态,
    创建时间,
    最后确认时间,
    重试次数,
    等待队列,    // 指针<Nova网络缓冲>
    下一个,    // 指针<ARP缓存条目>
    设备,    // 指针<网络设备>
}

// ARP缓存表(哈希表)

结构 ARP缓存表 {
    桶,    // 数组<指针<ARP缓存条目>, 256>
    条目数,
    锁,    // 自旋锁
}

定义 可变 全局ARP缓存 = ARP缓存表 {}
定义 可变 ARP缓存列表 = []           // [IP, MAC]简易列表(被以太网模块引用)

函数 arp_哈希(ip) {
    返回 (ip ^ (ip >> 16) ^ (ip >> 8)) % ARP_缓存_桶数
}

// ARP缓存查找

函数 arp_查找(IP地址) {
    定义 桶号 = arp_哈希(IP地址)
    定义 可变 当前 = 全局ARP缓存.桶[桶号]

    当 (当前 != 空) {
        如果 (当前.IP地址 == IP地址) {
            如果 (当前.状态 == ARP_状态_可达 || 当前.状态 == ARP_状态_永久) {
                // 检查是否过期
                如果 (当前.状态 != ARP_状态_永久) {
                    定义 年龄 = 当前时间_秒() - 当前.最后确认时间
                    如果 (年龄 > ARP_缓存_超时) {
                        当前.状态 = ARP_状态_过期
                        返回 空
                    }
                }
                返回 当前.MAC地址
            }
            返回 空
        }
        当前 = 当前.下一个
    }
    返回 空
}

函数 arp_查找条目(IP地址) {
    定义 桶号 = arp_哈希(IP地址)
    定义 可变 当前 = 全局ARP缓存.桶[桶号]
    当 (当前 != 空) {
        如果 (当前.IP地址 == IP地址) { 返回 当前 }
        当前 = 当前.下一个
    }
    返回 空
}

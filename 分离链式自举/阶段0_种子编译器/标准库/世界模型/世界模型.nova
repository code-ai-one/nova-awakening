导入("../基础.nova")


// 世界状态
// [观察, 潜在状态, 奖励, 终止, 时间步, 动作历史]
函数 世界状态_创建(维度) { 定义 可变 观察 = []
 定义 可变 潜在 = []
 定义 可变 i = 0
 当 (i < 维度) { 追加(观察, 0)
 追加(潜在, 0)
 i = i + 1 }
 返回 [观察, 潜在, 0, 0, []]
}

函数 世界状态_观察(s) { 返回 s[0] }
函数 世界状态_潜在(s) { 返回 s[1] }
函数 世界状态_奖励(s) { 返回 s[2] }
函数 世界状态_终止(s) { 返回 s[3] }
函数 世界状态_时间(s) { 返回 s[4] }

// 潜在动力学模型
// z_{t+1} = f(z_t, a_t) 线性近似
函数 动力学_创建(潜在维度, 动作维度) {
 // 转移矩阵 + 动作矩阵 + 偏置
 定义 可变 A = [] // z→z转移
 定义 可变 B = [] // a→z影响
 定义 可变 偏置 = []
 定义 可变 i = 0
 当 (i < 潜在维度) { 定义 可变 行A = []
 定义 可变 j = 0
 当 (j < 潜在维度) { 如果 (i == j) { 追加(行A, 900) } // 近似单位矩阵
 否则 { 追加(行A, 0) }
 j = j + 1
 }
 追加(A, 行A)
 定义 可变 行B = []
 j = 0
 当 (j < 动作维度) { 追加(行B, 100)
 j = j + 1 }
 追加(B, 行B)
 追加(偏置, 0)
 i = i + 1
 }
 返回 [A, B, 偏置, 潜在维度, 动作维度]
}

函数 动力学_预测(模型, 潜在, 动作) { 定义 d = 模型[3]
 定义 可变 新潜在 = []
 定义 可变 i = 0
 当 (i < d) { 定义 可变 数值 = 模型[2][i] // 偏置
 // A·z
 定义 可变 j = 0
 当 (j < d) {
 数值 = 数值 + 模型[0][i][j] * 潜在[j] / 1000
 j = j + 1
 }
 // B·a
 j = 0
 当 (j < 模型[4]) { 如果 (j < 计数(动作)) { 数值 = 数值 + 模型[1][i][j] * 动作[j] / 1000 }
 j = j + 1
 }
 追加(新潜在, 数值)
 i = i + 1
 }
 返回 新潜在
}

// 奖励预测器
函数 奖励预测(潜在, 权重, 偏置) { 定义 d = 计数(潜在)
 定义 可变 r = 偏置
 定义 可变 i = 0
 当 (i < d) { 如果 (i < 计数(权重)) { r = r + 权重[i] * 潜在[i] / 1000 }
 i = i + 1
 }
 返回 r
}

// 终止预测器
函数 终止预测(潜在, 权重, 阈值) { 定义 r = 奖励预测(潜在,  权重, 0)
 定义 可变 信号值 = 500 + r / 4 // S形函数
 如果 (信号值 < 0) { 信号值 = 0 }
 如果 (信号值 > 1000) { 信号值 = 1000 }
 返回 信号值 > 阈值
}

// 想象Rollout
函数 想象_rollout(动力学, 初始潜在, 动作序列, 奖励权重, 奖励偏置) { 定义 T = 计数(动作序列)
 定义 可变 轨迹 = []
 定义 可变 潜在 = 初始潜在
 定义 可变 总奖励 = 0
 定义 可变 t = 0
 当 (t < T) { 定义 新潜在 = 动力学_预测(动力学, 潜在, 动作序列[t])
 定义 r = 奖励预测(新潜在, 奖励权重, 奖励偏置)
 追加(轨迹, [新潜在, r])
 总奖励 = 总奖励 + r
 潜在 = 新潜在
 t = t + 1
 }
 返回 [轨迹, 总奖励]
}

// 基于模型的规划 (CEM)
函数 CEM_规划(动力学, 初始潜在, 动作维度, 规划长度, 种群, 精英数, 迭代数, 奖励权重, 奖励偏置) { 定义 可变 CEM_随机态 = 11111
 // 初始化均值和方差
 定义 可变 均值 = []
 定义 可变 方差 = []
 定义 可变 i = 0
 当 (i < 规划长度 * 动作维度) { 追加(均值, 0)
 追加(方差, 1000)
 i = i + 1 }
 定义 可变 迭代 = 0
 当 (迭代 < 迭代数) {
 // 采样种群
 定义 可变 候选 = []
 定义 可变 奖励列表 = []
 定义 可变 p = 0
 当 (p < 种群) { 定义 可变 动作序列 = []
 定义 可变 t = 0
 当 (t < 规划长度) { 定义 可变 a = []
 定义 可变 d = 0
 当 (d < 动作维度) {
 CEM_随机态 = CEM_随机态 ^ (CEM_随机态 << 13)
 CEM_随机态 = CEM_随机态 ^ (CEM_随机态 >> 7)
 CEM_随机态 = CEM_随机态 ^ (CEM_随机态 << 17)
 如果 (CEM_随机态 < 0) { CEM_随机态 = 0 - CEM_随机态 }
 定义 噪声 = (CEM_随机态 % 2000) - 1000
 定义 索引 = t * 动作维度 + d
 定义 数值 = 均值[索引] + 噪声 * 方差[索引] / 1000
 追加(a, 数值)
 d = d + 1
 }
 追加(动作序列, a)
 t = t + 1
 }
 定义 结果 = 想象_rollout(动力学, 初始潜在, 动作序列, 奖励权重, 奖励偏置)
 追加(候选, 动作序列)
 追加(奖励列表, 结果[1])
 p = p + 1
 }
 // 选精英
 定义 可变 索引 = []
 i = 0
 当 (i < 种群) { 追加(索引, i)
 i = i + 1 }
 i = 0
 当 (i < 精英数) { 定义 可变 j = i + 1
 当 (j < 种群) { 如果 (奖励列表[索引[j]] > 奖励列表[索引[i]]) { 定义 临时 = 索引[i]
 索引[i] = 索引[j]
 索引[j] = 临时
 }
 j = j + 1
 }
 i = i + 1
 }
 // 更新均值
 i = 0
 当 (i < 规划长度 * 动作维度) { 均值[i] = 0
 i = i + 1 }
 i = 0
 当 (i < 精英数) { 定义 可变 t = 0
 当 (t < 规划长度) { 定义 可变 d = 0
 当 (d < 动作维度) { 定义 索引 = t * 动作维度 + d
 均值[索引] = 均值[索引] + 候选[索引[i]][t][d] / 精英数
 d = d + 1
 }
 t = t + 1
 }
 i = i + 1
 }
 迭代 = 迭代 + 1
 }
 // 返回第一步最优动作
 定义 可变 最优动作 = []
 i = 0
 当 (i < 动作维度) { 追加(最优动作, 均值[i])
 i = i + 1 }
 返回 最优动作
}

// 状态转移预测
函数 世界_预测下一状态(当前状态, 动作, 转移权重) { 定义 可变 新状态 = []
 定义 维度 = 计数(当前状态)
 定义 可变 i = 0
 当 (i < 维度) { 定义 可变 数值 = 当前状态[i]
 定义 可变 j = 0
 当 (j < 计数(动作)) {
 数值 = 数值 + 动作[j] * 转移权重[i * 计数(动作) + j] / 1000
 j = j + 1
 }
 追加(新状态, 数值)
 i = i + 1
 }
 返回 新状态
}

// 奖励预测
函数 世界_预测奖励(状态, 目标状态) { 定义 可变 距离 = 0
 定义 可变 i = 0
 当 (i < 计数(状态)) { 定义 d = 状态[i] - 目标状态[i]
 距离 = 距离 + d * d
 i = i + 1
 }
 返回 1000 - 距离
}

// 多步展望
函数 世界_展望(当前状态, 动作序列, 转移权重) { 定义 可变 状态 = 当前状态
 定义 可变 轨迹 = [当前状态]
 定义 可变 i = 0
 当 (i < 计数(动作序列)) {
 状态 = 世界_预测下一状态(状态, 动作序列[i], 转移权重)
 追加(轨迹, 状态)
 i = i + 1
 }
 返回 轨迹
}

// 环境不确定性估计
函数 世界_不确定性(预测列表) { 定义 n = 计数(预测列表)
 如果 (n < 2) { 返回 0 }
 定义 维度 = 计数(预测列表[0])
 定义 可变 总方差 = 0
 定义 可变 d = 0
 当 (d < 维度) { 定义 可变 均值 = 0
 定义 可变 i = 0
 当 (i < n) { 均值 = 均值 + 预测列表[i][d] i = i + 1 }
 均值 = 均值 / n
 定义 可变 方差 = 0
 i = 0
 当 (i < n) { 定义 差值 = 预测列表[i][d] - 均值
 方差 = 方差 + 差值 * 差值
 i = i + 1
 }
 总方差 = 总方差 + 方差 / n
 d = d + 1
 }
 返回 总方差
}

// 好奇心奖励
函数 世界_好奇心奖励(预测状态, 实际状态) { 定义 可变 误差 = 0
 定义 可变 i = 0
 当 (i < 计数(预测状态)) { 定义 d = 预测状态[i] - 实际状态[i]
 误差 = 误差 + d * d
 i = i + 1
 }
 返回 误差
}

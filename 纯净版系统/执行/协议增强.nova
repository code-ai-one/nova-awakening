函数 壳层_CSS_变量_按主题(ctx) {
    如果 (ctx.主题 == 壳层主题_深色) { 返回 壳层_CSS_变量_深色() }
    如果 (ctx.主题 == 壳层主题_高对比) { 返回 壳层_CSS_变量_高对比() }
    如果 (ctx.主题 == 壳层主题_护眼) { 返回 壳层_CSS_变量_护眼() }
    返回 壳层_CSS_变量_浅色()
}

// §7 CSS组件层

函数 壳层_CSS_基础布局(ctx) {
    定义 可变 css = ""
    css = CSS_追加(css, "body{margin:0;padding:0;background:linear-gradient(145deg,var(--nova-bg2),var(--nova-bg));color:var(--nova-ink);font-family:'Nova Sans','Segoe UI',sans-serif;}")
    css = CSS_追加(css, ".nova-shell{max-width:1240px;margin:0 auto;padding:24px;position:relative;}")
    css = CSS_追加(css, ".nova-shell::before{content:'';position:fixed;right:42px;top:22px;width:280px;height:280px;border-radius:999px;background:rgba(147,197,253,0.24);filter:blur(36px);pointer-events:none;}")
    css = CSS_追加(css, ".nova-shell::after{content:'';position:fixed;left:36px;bottom:28px;width:240px;height:240px;border-radius:999px;background:rgba(52,211,153,0.20);filter:blur(42px);pointer-events:none;}")
    css = CSS_追加(css, ".nova-stack{display:flex;flex-direction:column;gap:18px;}")
    css = CSS_追加(css, ".nova-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px;}")
    css = CSS_追加(css, ".nova-grid-3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;}")
    css = CSS_追加(css, ".nova-row{display:flex;gap:12px;align-items:center;}")
    css = CSS_追加(css, ".nova-col{display:flex;flex-direction:column;gap:8px;}")
    返回 css
}

函数 壳层_CSS_头图卡片(ctx) {
    定义 可变 css = ""
    css = CSS_追加(css, ".nova-hero{padding:30px;border:1px solid var(--nova-line);border-radius:28px;background:var(--nova-glass);box-shadow:var(--nova-shadow);backdrop-filter:blur(24px);}")
    css = CSS_追加(css, ".nova-eyebrow{font-size:12px;letter-spacing:0.14em;text-transform:uppercase;color:var(--nova-sub);font-weight:700;}")
    css = CSS_追加(css, ".nova-title{font-size:40px;line-height:1.08;font-weight:800;margin:10px 0 8px 0;}")
    css = CSS_追加(css, ".nova-lead{font-size:15px;line-height:1.74;color:var(--nova-sub);max-width:840px;}")
    css = CSS_追加(css, ".nova-chips{display:flex;flex-wrap:wrap;gap:10px;margin-top:18px;}")
    css = CSS_追加(css, ".nova-chip{padding:8px 12px;border-radius:999px;border:1px solid var(--nova-line);background:var(--nova-card);font-size:12px;color:var(--nova-sub);font-weight:650;}")
    css = CSS_追加(css, ".nova-chip-accent{background:linear-gradient(90deg,rgba(219,234,254,0.92),rgba(207,250,254,0.82));color:#0f2f53;border-color:rgba(147,197,253,0.7);}")
    css = CSS_追加(css, ".nova-nav{display:flex;flex-wrap:wrap;gap:10px;margin-top:14px;}")
    css = CSS_追加(css, ".nova-nav a{padding:9px 13px;border-radius:12px;border:1px solid var(--nova-line);background:var(--nova-card);text-decoration:none;color:var(--nova-ink);font-size:13px;}")
    css = CSS_追加(css, ".nova-nav a:hover{border-color:var(--nova-primary);color:var(--nova-primary);}")
    返回 css
}

函数 壳层_CSS_面板系统(ctx) {
    定义 可变 css = ""
    css = CSS_追加(css, ".nova-panel{padding:18px;border:1px solid var(--nova-line);border-radius:20px;background:var(--nova-glass);box-shadow:var(--nova-shadow);}")
    css = CSS_追加(css, ".nova-panel h2{margin:0 0 8px 0;font-size:20px;}")
    css = CSS_追加(css, ".nova-panel h3{margin:0 0 6px 0;font-size:16px;}")
    css = CSS_追加(css, ".nova-panel p{margin:0;color:var(--nova-sub);line-height:1.66;}")
    css = CSS_追加(css, ".nova-list{margin:10px 0 0 0;padding-left:18px;color:var(--nova-sub);}")
    css = CSS_追加(css, ".nova-list li{margin:6px 0;}")
    css = CSS_追加(css, ".nova-kv{display:grid;grid-template-columns:160px 1fr;gap:8px;}")
    css = CSS_追加(css, ".nova-k{color:var(--nova-sub);font-size:12px;}")
    css = CSS_追加(css, ".nova-v{color:var(--nova-ink);font-size:13px;font-weight:600;}")
    css = CSS_追加(css, ".nova-divider{height:1px;background:var(--nova-line);margin:10px 0;}")
    返回 css
}

函数 壳层_CSS_命令甲板(ctx) {
    定义 可变 css = ""
    css = CSS_追加(css, ".nova-command-deck{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;}")
    css = CSS_追加(css, ".nova-command-item{padding:14px;border-radius:16px;border:1px solid var(--nova-line);background:var(--nova-card);}")
    css = CSS_追加(css, ".nova-command-item strong{display:block;font-size:13px;margin-bottom:6px;}")
    css = CSS_追加(css, ".nova-command-item span{font-size:12px;color:var(--nova-sub);line-height:1.58;}")
    css = CSS_追加(css, ".nova-command-item:hover{border-color:var(--nova-primary);transform:translateY(-1px);}")
    css = CSS_追加(css, ".nova-progress{height:10px;border-radius:999px;background:rgba(148,163,184,0.24);overflow:hidden;}")
    css = CSS_追加(css, ".nova-progress span{display:block;height:100%;border-radius:999px;background:linear-gradient(90deg,#60a5fa,#34d399);}")
    css = CSS_追加(css, ".nova-status-ok{color:var(--nova-success);}")
    css = CSS_追加(css, ".nova-status-warn{color:var(--nova-warn);}")
    css = CSS_追加(css, ".nova-status-err{color:var(--nova-danger);}")
    返回 css
}

函数 壳层_CSS_表单与输入(ctx) {
    定义 可变 css = ""
    css = CSS_追加(css, ".nova-input{padding:11px 13px;border-radius:12px;border:1px solid var(--nova-line);background:var(--nova-card);color:var(--nova-ink);}")
    css = CSS_追加(css, ".nova-input:focus{outline:none;border-color:var(--nova-primary);box-shadow:0 0 0 3px rgba(37,99,235,0.15);}")
    css = CSS_追加(css, ".nova-select{padding:11px 13px;border-radius:12px;border:1px solid var(--nova-line);background:var(--nova-card);color:var(--nova-ink);}")
    css = CSS_追加(css, ".nova-btn{padding:10px 14px;border-radius:12px;border:1px solid var(--nova-line);background:var(--nova-card);color:var(--nova-ink);font-weight:700;}")
    css = CSS_追加(css, ".nova-btn:hover{border-color:var(--nova-primary);color:var(--nova-primary);}")
    css = CSS_追加(css, ".nova-btn-primary{background:var(--nova-primary);border-color:var(--nova-primary);color:#fff;}")
    css = CSS_追加(css, ".nova-btn-primary:hover{filter:brightness(1.04);}")
    css = CSS_追加(css, ".nova-tag{display:inline-flex;padding:4px 10px;border-radius:999px;border:1px solid var(--nova-line);background:var(--nova-card);font-size:11px;}")
    css = CSS_追加(css, ".nova-footer{padding:14px 16px;border-radius:16px;border:1px solid var(--nova-line);background:var(--nova-glass);font-size:12px;color:var(--nova-sub);}")
    css = CSS_追加(css, ".nova-link{color:var(--nova-primary);text-decoration:none;}")
    返回 css
}

函数 壳层_CSS_媒体与响应式(ctx) {
    定义 可变 css = ""
    css = CSS_追加(css, "@media (max-width:1100px){.nova-grid{grid-template-columns:1fr;}.nova-grid-3{grid-template-columns:1fr 1fr;}.nova-title{font-size:34px;}}")
    css = CSS_追加(css, "@media (max-width:760px){.nova-shell{padding:14px;}.nova-hero{padding:20px;}.nova-grid-3{grid-template-columns:1fr;}.nova-command-deck{grid-template-columns:1fr;}.nova-title{font-size:28px;}}")
    css = CSS_追加(css, "@media (prefers-reduced-motion: reduce){*{animation:none !important;transition:none !important;}}")
    css = CSS_追加(css, "@media (prefers-contrast: more){.nova-panel,.nova-hero,.nova-command-item{border-width:2px;}}")
    css = CSS_追加(css, "@media (pointer: coarse){.nova-btn,.nova-nav a{padding:12px 16px;}}")
    返回 css
}

函数 壳层_CSS_动效层(ctx) {
    定义 可变 css = ""
    如果 (ctx.动效级别 == 壳层动效_关闭 || ctx.减少动态) {
        css = CSS_追加(css, ".nova-hero,.nova-panel,.nova-command-item{transition:none;}")
        返回 css
    }
    如果 (ctx.动效级别 == 壳层动效_低) {
        css = CSS_追加(css, ".nova-hero,.nova-panel,.nova-command-item{transition:border-color .16s ease,color .16s ease;}")
        返回 css
    }
    css = CSS_追加(css, "@keyframes novaFloat{0%{transform:translateY(0)}50%{transform:translateY(-2px)}100%{transform:translateY(0)}}")
    css = CSS_追加(css, ".nova-hero{animation:novaFloat 6s ease-in-out infinite;}")
    css = CSS_追加(css, ".nova-panel{transition:transform .18s ease,border-color .18s ease,box-shadow .18s ease;}")
    css = CSS_追加(css, ".nova-panel:hover{transform:translateY(-1px);}")
    css = CSS_追加(css, ".nova-command-item{transition:transform .16s ease,border-color .16s ease;}")
    返回 css
}

函数 壳层_CSS_生成(ctx) {
    定义 可变 css = ""
    css = CSS_追加(css, 壳层_CSS_变量_按主题(ctx))
    css = CSS_追加(css, 壳层_CSS_基础布局(ctx))
    css = CSS_追加(css, 壳层_CSS_头图卡片(ctx))
    css = CSS_追加(css, 壳层_CSS_面板系统(ctx))
    css = CSS_追加(css, 壳层_CSS_命令甲板(ctx))
    css = CSS_追加(css, 壳层_CSS_表单与输入(ctx))
    css = CSS_追加(css, 壳层_CSS_媒体与响应式(ctx))
    css = CSS_追加(css, 壳层_CSS_动效层(ctx))
    返回 css
}

// §8 内部协议解析

函数 协议_识别类型(主机) {
    如果 (主机 == "system") { 返回 协议类型_系统 }
    如果 (主机 == "ai") { 返回 协议类型_AI }
    如果 (主机 == "multimodal") { 返回 协议类型_多模态 }
    如果 (主机 == "voice") { 返回 协议类型_语音 }
    如果 (主机 == "avatar") { 返回 协议类型_形象 }
    如果 (主机 == "diag") { 返回 协议类型_诊断 }
    如果 (主机 == "settings") { 返回 协议类型_设置 }
    如果 (主机 == "workflow") { 返回 协议类型_工作流 }
    返回 协议类型_未知
}

函数 协议_拆分URL(url) {
    定义 req = 协议请求 {}
    req.原始URL = url
    req.协议名 = "nova"
    req.主机 = ""
    req.路径 = "/"
    req.查询 = ""
    req.类型 = 协议类型_未知
    req.参数列表 = 堆_分配_数组(最大参数数 * 16)
    req.参数数 = 0

    定义 p = 字符串查找(url, "://")
    如果 (p < 0) { 返回 req }
    定义 余 = 字符串子串(url, p + 3, 字符串长度(url))
    定义 slash = 字符串查找(余, "/")
    定义 qmark = 字符串查找(余, "?")

    如果 (slash < 0 && qmark < 0) {
        req.主机 = 余
    } 否则如果 (slash >= 0 && (qmark < 0 || slash < qmark)) {
        req.主机 = 字符串子串(余, 0, slash)
        如果 (qmark >= 0) {
            req.路径 = 字符串子串(余, slash, qmark)
            req.查询 = 字符串子串(余, qmark + 1, 字符串长度(余))
        } 否则 {
            req.路径 = 字符串子串(余, slash, 字符串长度(余))
        }
    } 否则 {
        req.主机 = 字符串子串(余, 0, qmark)
        req.查询 = 字符串子串(余, qmark + 1, 字符串长度(余))
    }

    req.类型 = 协议_识别类型(req.主机)
    协议_解析查询参数(req)
    返回 req
}

函数 协议_解析查询参数(req) {
    如果 (是否空串(req.查询)) { 返回 }
    定义 可变 start = 0
    定义 可变 q = req.查询
    当 (start < 字符串长度(q) && req.参数数 < 最大参数数) {
        定义 andPos = 字符串查找_从(q, "&", start)
        定义 item = ""
        如果 (andPos < 0) {
            item = 字符串子串(q, start, 字符串长度(q))
            start = 字符串长度(q)
        } 否则 {
            item = 字符串子串(q, start, andPos)
            start = andPos + 1
        }
        定义 eqPos = 字符串查找(item, "=")
        定义 kv = 协议参数 {}
        如果 (eqPos < 0) {
            kv.键 = item
            kv.值 = ""
        } 否则 {
            kv.键 = 字符串子串(item, 0, eqPos)
            kv.值 = 字符串子串(item, eqPos + 1, 字符串长度(item))
        }
        req.参数列表[req.参数数] = kv
        req.参数数 = req.参数数 + 1
    }
}

函数 协议_取参数(req, 键, 默认值) {
    定义 可变 i = 0
    当 (i < req.参数数) {
        如果 (req.参数列表[i].键 == 键) {
            返回 req.参数列表[i].值
        }
        i = i + 1
    }
    返回 默认值
}

// §9 路由决策与安全校验

函数 协议_路径风险评分(req) {
    定义 可变 风险 = 0
    如果 (字符串查找(req.路径, "..") >= 0) { 风险 = 风险 + 60 }
    如果 (字符串查找(req.查询, "<script") >= 0) { 风险 = 风险 + 80 }
    如果 (字符串查找(req.查询, "javascript:") >= 0) { 风险 = 风险 + 80 }
    如果 (字符串查找(req.查询, "DROP") >= 0) { 风险 = 风险 + 50 }
    如果 (字符串长度(req.查询) > 1200) { 风险 = 风险 + 25 }
    返回 限幅(风险, 0, 100)
}

函数 协议_路由决策(req, 策略) {
    定义 d = 路由决策 {}
    d.是否命中 = 真
    d.命中模块 = "壳层主页"
    d.风险评分 = 协议_路径风险评分(req)
    d.置信度 = 220
    d.回退模块 = "壳层主页"

    如果 (req.类型 == 协议类型_系统) { d.命中模块 = "系统总控面板" }
    否则如果 (req.类型 == 协议类型_AI) { d.命中模块 = "AI工作台" }
    否则如果 (req.类型 == 协议类型_多模态) { d.命中模块 = "多模态中枢" }
    否则如果 (req.类型 == 协议类型_语音) { d.命中模块 = "语音中枢" }
    否则如果 (req.类型 == 协议类型_形象) { d.命中模块 = "全息形象中枢" }
    否则如果 (req.类型 == 协议类型_诊断) { d.命中模块 = "诊断中心" }
    否则如果 (req.类型 == 协议类型_设置) { d.命中模块 = "系统设置" }
    否则如果 (req.类型 == 协议类型_工作流) { d.命中模块 = "工作流编排" }
    否则 {
        d.是否命中 = 假
        d.命中模块 = "未知模块"
        d.置信度 = 120
    }

    如果 (策略 == 路由策略_严格 && d.风险评分 >= 40) {
        d.是否命中 = 假
        d.命中模块 = "访问阻断"
        d.回退模块 = "安全提示页"
    }
    如果 (策略 == 路由策略_实验 && d.风险评分 < 30) {
        d.置信度 = 240
    }
    返回 d
}

// §10 AI个性化策略

函数 壳层_AI_评估主题(用户画像文本) {
    如果 (字符串查找(用户画像文本, "night") >= 0) { 返回 壳层主题_深色 }
    如果 (字符串查找(用户画像文本, "contrast") >= 0) { 返回 壳层主题_高对比 }
    如果 (字符串查找(用户画像文本, "eye-care") >= 0) { 返回 壳层主题_护眼 }
    返回 壳层主题_浅色
}

函数 壳层_AI_评估密度(会话长度, 任务复杂度) {
    如果 (任务复杂度 >= 80) { 返回 壳层密度_紧凑 }
    如果 (会话长度 <= 3) { 返回 壳层密度_宽松 }
    返回 壳层密度_标准
}

函数 壳层_AI_评估动效(设备负载, 用户偏好) {
    如果 (字符串查找(用户偏好, "reduce-motion") >= 0) { 返回 壳层动效_关闭 }
    如果 (设备负载 >= 85) { 返回 壳层动效_低 }
    返回 壳层动效_标准
}

函数 壳层_AI_生成上下文(用户画像文本, 会话长度, 任务复杂度, 设备负载, 用户偏好) {
    定义 ctx = 壳层视觉上下文_默认()
    ctx.主题 = 壳层_AI_评估主题(用户画像文本)
    ctx.密度 = 壳层_AI_评估密度(会话长度, 任务复杂度)
    ctx.动效级别 = 壳层_AI_评估动效(设备负载, 用户偏好)

    如果 (字符串查找(用户偏好, "accessibility") >= 0) {
        壳层视觉上下文_应用可访问(ctx)
    }
    如果 (字符串查找(用户偏好, "touch") >= 0) {
        壳层视觉上下文_应用触控(ctx)
    }
    返回 ctx
}


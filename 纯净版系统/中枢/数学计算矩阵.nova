函数 求逆模块_查询状态() {
    如果 (求逆模块已初始化 == 假) { 返回 0 }
    返回 1
}

函数 求逆模块_健康检查() {
    如果 (求逆模块已初始化 == 假) { 返回 假 }
    如果 (全局统计.错误次数 * 10 > 全局统计.求逆次数) { 返回 假 }
    返回 真
}


函数 矩阵_逆存在(A) {
    如果 (A == 空 || A[0] != A[1]) { 返回 假 }
    定义 逆 = 矩阵求逆(A)
    返回 逆 != 空
}

函数 矩阵_秩估算(A) {
    // 简化秩估算：通过高斯消元计算非零主元数
    如果 (A == 空) { 返回 0 }
    定义 行 = A[0]
    定义 列 = A[1]
    // 复制增广矩阵
    定义 可变 复制 = [行, 列]
    定义 可变 i = 0
    当 (i < 行 * 列) {
        追加(复制, A[2 + i])
        i = i + 1
    }
    // 高斯消元
    定义 可变 秩 = 0
    定义 可变 col = 0
    定义 可变 row = 0
    当 (col < 列 && row < 行) {
        // 找主元
        定义 可变 主元行 = row
        定义 可变 主元值 = 0
        定义 可变 v = 复制[2 + row * 列 + col]
        如果 (v < 0) { v = 0 - v }
        主元值 = v
        i = row + 1
        当 (i < 行) {
            定义 可变 av = 复制[2 + i * 列 + col]
            如果 (av < 0) { av = 0 - av }
            如果 (av > 主元值) { 主元值 = av  主元行 = i }
            i = i + 1
        }
        如果 (主元值 == 0) {
            col = col + 1
            继续
        }
        // 交换行
        如果 (主元行 != row) {
            定义 可变 j = 0
            当 (j < 列) {
                定义 临时 = 复制[2 + row * 列 + j]
                复制[2 + row * 列 + j] = 复制[2 + 主元行 * 列 + j]
                复制[2 + 主元行 * 列 + j] = 临时
                j = j + 1
            }
        }
        // 消元
        i = row + 1
        当 (i < 行) {
            如果 (复制[2 + row * 列 + col] != 0) {
                定义 因子 = 复制[2 + i * 列 + col] * 线代精度 / 复制[2 + row * 列 + col]
                定义 可变 j = col
                当 (j < 列) {
                    复制[2 + i * 列 + j] = 复制[2 + i * 列 + j] - 因子 * 复制[2 + row * 列 + j] / 线代精度
                    j = j + 1
                }
            }
            i = i + 1
        }
        秩 = 秩 + 1
        row = row + 1
        col = col + 1
    }
    返回 秩
}

函数 矩阵_Tick() {
    // 定期检查数值稳定性趋势
    如果 (全局统计.求逆次数 > 0 && 全局统计.求逆次数 % 100 == 0) {
        定义 稳定性 = AI_预测数值稳定性()
        如果 (稳定性 == "严重病态-建议正则化") {
            全局统计.正则化建议数 = 全局统计.正则化建议数 + 1
        }
    }
}

函数 矩阵_获取求逆次数() { 返回 全局统计.求逆次数 }
函数 矩阵_获取病态数() { 返回 全局统计.病态矩阵数 }
函数 矩阵_获取AI稳定性() { 返回 AI_预测数值稳定性() }

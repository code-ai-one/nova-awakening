// NovaOS 缺页处理
// 职责: 页错误异常处理、按需分页、COW写时复制

定义 PF_存在 = 1 << 0       // 页已存在 (权限错误 vs 缺页)
定义 PF_写 = 1 << 1         // 写操作触发
定义 PF_用户 = 1 << 2       // 用户态触发
定义 PF_保留位 = 1 << 3     // 保留位被设置
定义 PF_取指 = 1 << 4       // 取指令触发 (NX违规)

定义 缺页_已处理 = 0
定义 缺页_段错误 = 1
定义 缺页_总线错误 = 2
定义 缺页_OOM = 3
定义 缺页_内核崩溃 = 4

定义 可变 缺页_总次数 = 0
定义 可变 缺页_匿名分配 = 0
定义 可变 缺页_COW复制 = 0
定义 可变 缺页_文件读取 = 0
定义 可变 缺页_栈扩展 = 0
定义 可变 缺页_段错误次数 = 0
定义 可变 缺页_内核错误次数 = 0

// 缺页异常入口
// CPU自动将错误地址放入CR2, 错误码push到栈上

函数 缺页异常处理(错误地址, 错误码, 寄存器) {
    缺页_总次数 = 缺页_总次数 + 1

    // 读取CR2获取真正的故障地址
    // 汇编 { "mov rax, cr2" } → 错误地址

    // 判断是内核态还是用户态缺页
    如果 ((错误码 & PF_用户) == 0) {
        返回 处理内核缺页(错误地址, 错误码, 寄存器)
    }

    // 用户态缺页
    定义 结果 = 处理用户缺页(错误地址, 错误码, 寄存器)

    // ★ AI先天特性: 记录缺页→预测下一页→提前预取
    // ★ 安全: 放在缺页处理完成之后(不在锁持有期间)
    // 这样AI预取不会与当前缺页的页表修改竞争
    AI页面_记录缺页(错误地址)
    定义 预测页 = AI页面_预测下一页()
    如果 (预测页 > 0 && !in_interrupt()) {
        异步_预取页(预测页 << 12)
    }

    返回 结果
}

// 内核态缺页处理

函数 处理内核缺页(错误地址, 错误码, 寄存器) {
    // 检查是否在vmalloc区域 (需要同步内核页表)
    如果 (是vmalloc地址(错误地址)) {
        返回 vmalloc_缺页同步(错误地址)
    }

    // 内核不应产生其他类型的缺页
    缺页_内核错误次数 = 缺页_内核错误次数 + 1
    内核错误("内核态缺页异常!")
    内核错误地址("  错误地址", 错误地址)
    内核错误地址("  RIP", 寄存器_RIP(寄存器))
    // 触发内核崩溃
    返回 缺页_内核崩溃
}

// vmalloc区域缺页: 从init_mm同步页表
函数 vmalloc_缺页同步(错误地址) {
    // 将内核主页表(init_mm)的对应条目复制到当前页表
    定义 内核PML4 = 获取内核PML4物理()
    定义 当前PML4 = 读取CR3()

    定义 idx = PML4索引(错误地址)
    定义 内核条目 = 内存读64(物理到虚拟(内核PML4) + idx * 8)

    如果 (页表项_存在(内核条目)) {
        内存写64(物理到虚拟(当前PML4) + idx * 8, 内核条目)
        返回 缺页_已处理
    }
    返回 缺页_内核崩溃
}

// 用户态缺页处理

函数 处理用户缺页(错误地址, 错误码, 寄存器) {
    定义 当前 = 获取当前进程()
    定义 mm = 当前.内存描述符

    // 查找VMA
    定义 vma = mm_查找VMA(mm, 错误地址)

    如果 (vma == 空) {
        // 检查是否是栈向下扩展
        如果 (可以栈扩展(mm, 错误地址)) {
            返回 处理栈扩展(mm, 错误地址, 错误码)
        }
        // 没有对应VMA → 段错误
        缺页_段错误次数 = 缺页_段错误次数 + 1
        返回 缺页_段错误
    }

    // 权限检查
    如果 ((错误码 & PF_写) != 0 && !VMA_可写(vma)) {
        // 写一个不可写的VMA → 段错误
        缺页_段错误次数 = 缺页_段错误次数 + 1
        返回 缺页_段错误
    }

    如果 ((错误码 & PF_取指) != 0 && !VMA_可执行(vma)) {
        // 执行一个不可执行的VMA → 段错误
        缺页_段错误次数 = 缺页_段错误次数 + 1
        返回 缺页_段错误
    }

    // 查看PTE状态
    定义 pml4 = mm[MM_PML4物理]
    定义 pte = 页表_查找PTE(pml4, 错误地址)

    如果 (!页表项_存在(pte)) {
        // PTE不存在 → 按需分页
        如果 ((vma[VMA_标志] & VM_匿名) != 0) {
            返回 处理匿名缺页(mm, vma, 错误地址, 错误码)
        } 否则 {
            返回 处理文件缺页(mm, vma, 错误地址, 错误码)
        }
    }

    如果 (页表项_是COW(pte) && (错误码 & PF_写) != 0) {
        // COW页写入 → 复制物理页
        返回 处理COW缺页(mm, vma, 错误地址, pte)
    }

    // 不应到达这里
    缺页_段错误次数 = 缺页_段错误次数 + 1
    返回 缺页_段错误
}

// 匿名页缺页 (第一次访问Nova内存映射/brk区域)

函数 处理匿名缺页(mm, vma, 错误地址, 错误码) {
    定义 页对齐地址 = 错误地址 & ~0xFFF

    // 如果是读访问, 可以映射到共享零页 (lazy allocation)
    如果 ((错误码 & PF_写) == 0) {
        定义 pte标志 = PTE_存在 | PTE_用户  // 只读
        定义 结果 = 映射_单页(mm[MM_PML4物理], 页对齐地址, 零页物理地址(), pte标志)
        如果 (结果 == 成功) {
            缺页_匿名分配 = 缺页_匿名分配 + 1
            返回 缺页_已处理
        }
        返回 缺页_OOM
    }

    // 写访问: 分配一个新的清零物理页
    定义 页号 = 伙伴系统_分配_带标志(0, GFP_KERNEL | GFP_ZERO)
    如果 (页号 < 0) { 返回 缺页_OOM }

    定义 物理地址 = 页号 * 页大小

    // 设置PTE标志
    定义 pte标志 = PTE_存在 | PTE_用户
    如果 (VMA_可写(vma)) { pte标志 = pte标志 | PTE_可写 }
    如果 (!VMA_可执行(vma)) { pte标志 = pte标志 | PTE_不可执行 }

    定义 结果 = 映射_单页(mm[MM_PML4物理], 页对齐地址, 物理地址, pte标志)
    如果 (结果 != 成功) {
        伙伴系统_释放(页号, 0)
        返回 缺页_OOM
    }

    // 更新RSS
    设置(mm, MM_RSS, mm[MM_RSS] + 1)

    // 设置页描述符
    定义 页 = 页描述符_获取(页号)
    如果 (页 != 空) {
        页描述符_增引用(页)
        页描述符_设置标志(页, 页_活跃)
    }

    缺页_匿名分配 = 缺页_匿名分配 + 1
    返回 缺页_已处理
}

// COW写时复制缺页

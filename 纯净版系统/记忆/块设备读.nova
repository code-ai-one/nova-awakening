// 块设备读写接口

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("../中枢/信号量创建.nova")
导入("../中枢/字符串替换.nova")
导入("../引导/寄存器定义.nova")
导入("../中枢/内核打印.nova")
导入("../推理/值乘.nova")
导入("../中枢/哈希函数.nova")

函数 块设备_读(设备号, 偏移, 大小) {
    定义 dev = 块设备_获取(设备号)
    如果 (dev == 空) { 返回 错误码_无设备 }
    如果 (dev.操作表.读 == 空) { 返回 错误码_IO }

    定义 扇区 = 偏移 / dev.扇区大小
    定义 扇区数 = (大小 + dev.扇区大小 - 1) / dev.扇区大小

    定义 可变 缓冲 = 分配内存(扇区数 * dev.扇区大小)
    如果 (缓冲 == 空) { 返回 错误码_内存不足 }

    定义 结果 = dev.操作表.读(dev, 扇区, 缓冲, 扇区数)
    如果 (结果 != 0) {
        释放内存(缓冲)
        返回 结果
    }

    返回 缓冲
}

函数 块设备_写(设备号, 偏移, 数据, 大小) {
    定义 dev = 块设备_获取(设备号)
    如果 (dev == 空) { 返回 错误码_无设备 }
    如果 (dev.操作表.写 == 空) { 返回 错误码_IO }
    如果 (dev.标志 & 块设备_标志_只读) { 返回 错误码_只读 }

    定义 扇区 = 偏移 / dev.扇区大小
    定义 扇区数 = (大小 + dev.扇区大小 - 1) / dev.扇区大小

    返回 dev.操作表.写(dev, 扇区, 数据, 扇区数)
}

函数 块设备_刷新(设备号) {
    定义 dev = 块设备_获取(设备号)
    如果 (dev == 空) { 返回 错误码_无设备 }
    如果 (dev.操作表.刷新 != 空) {
        返回 dev.操作表.刷新(dev)
    }
    返回 0
}

// 块请求队列管理

函数 块请求队列_创建(dev) {
    定义 可变 q = 分配内存(大小(块请求队列))
    q.请求链表 = 空
    q.请求数 = 0
    q.最大请求数 = 块设备_最大请求队列
    q.设备 = dev
    q.已停止 = 假
    返回 q
}

函数 块请求队列_销毁(q) {
    如果 (q == 空) { 返回 }
    // 清空所有挂起请求
    定义 可变 req = q.请求链表
    当 (req != 空) {
        定义 下一个 = req.下一个
        req.错误 = 错误码_IO
        完成量_完成(req.完成量)
        释放内存(req)
        req = 下一个
    }
    释放内存(q)
}

函数 块请求队列_提交(q, req) {
    自旋锁_获取(q.锁)

    如果 (q.已停止 || q.请求数 >= q.最大请求数) {
        自旋锁_释放(q.锁)
        返回 错误码_再试
    }

    // 加入队列尾部
    req.下一个 = 空
    如果 (q.请求链表 == 空) {
        q.请求链表 = req
    } 否则 {
        定义 可变 当前 = q.请求链表
        当 (当前.下一个 != 空) { 当前 = 当前.下一个 }
        当前.下一个 = req
    }
    q.请求数 = q.请求数 + 1

    自旋锁_释放(q.锁)
    返回 0
}

函数 块请求队列_取出(q) {
    自旋锁_获取(q.锁)
    如果 (q.请求链表 == 空) {
        自旋锁_释放(q.锁)
        返回 空
    }
    定义 req = q.请求链表
    q.请求链表 = req.下一个
    q.请求数 = q.请求数 - 1
    自旋锁_释放(q.锁)
    返回 req
}

函数 块请求队列_停止(q) { q.已停止 = 真 }
函数 块请求队列_恢复(q) { q.已停止 = 假 }

// NBIO理论 — Nova Block I/O
// 创新块设备IO体系：散列聚合IO、智能预读、延迟写回、
// 零拷贝DMA传输、自适应队列深度控制
// 核心公式: IO延迟 = 队列等待 + 传输时间 - 预读命中×缓存时间

定义 NBIO_最大合并 = 256         // 最大合并扇区数
定义 NBIO_预读窗口 = 32         // 预读窗口大小(扇区数)
定义 NBIO_写回延迟 = 5000       // 写回延迟(ms)
定义 NBIO_写回最大脑 = 128     // 写回最大脏页数
定义 块设备_最大请求队列 = 256
定义 块设备_标志_只读 = 0x01
定义 AI_NBIO_特征维度 = 10

定义 可变 NBIO_总读数 = 0
定义 可变 NBIO_总写数 = 0
定义 可变 NBIO_合并数 = 0
定义 可变 NBIO_预读命中 = 0
定义 可变 NBIO_预读未中 = 0
定义 可变 NBIO_写回数 = 0
定义 可变 NBIO_总字节读 = 0
定义 可变 NBIO_总字节写 = 0

结构 块请求 {
    扁区,       // 起始扁区号
    扁区数,     // 扁区数量
    缓冲,       // 内存缓冲地址
    读写标志,   // 0=读, 1=写
    错误,       // 完成状态
    完成量,     // 完成通知
    下一个,     // 链表指针
    优先级,     // 请求优先级
}

结构 块请求队列 {
    请求链表,
    请求数,
    最大请求数,
    设备,
    已停止,
    锁,
}

// §3 散列聚合IO — Scatter-Gather

结构 散列元素 {
    物理地址,
    长度,
}

函数 块设备_散列读(设备号, 扁区, 散列表, 元素数) {
    // 散列读: 将多个不连续内存区域作为一次IO的目标
    定义 dev = 块设备_获取(设备号)
    如果 (dev == 空) { 返回 错误码_无设备 }
    如果 (dev.操作表.散列读 == 空) {
        // 回退到逐块读取
        返回 块设备_散列读_回退(dev, 扁区, 散列表, 元素数)
    }
    返回 dev.操作表.散列读(dev, 扁区, 散列表, 元素数)
}

函数 块设备_散列读_回退(dev, 扁区, 散列表, 元素数) {
    // 回退路径: 读入临时缓冲再复制到散列元素
    定义 可变 总长 = 0
    定义 可变 i = 0
    当 (i < 元素数) {
        总长 = 总长 + 散列表[i].长度
        i = i + 1
    }

    定义 扁区数 = (总长 + dev.扁区大小 - 1) / dev.扁区大小
    定义 缓冲 = 分配内存(扁区数 * dev.扁区大小)
    如果 (缓冲 == 空) { 返回 错误码_内存不足 }

    定义 结果 = dev.操作表.读(dev, 扁区, 缓冲, 扁区数)
    如果 (结果 != 0) { 释放内存(缓冲); 返回 结果 }

    // 复制到各散列元素
    定义 可变 偏移 = 0
    i = 0
    当 (i < 元素数) {
        内存复制(散列表[i].物理地址, 缓冲 + 偏移, 散列表[i].长度)
        偏移 = 偏移 + 散列表[i].长度
        i = i + 1
    }
    释放内存(缓冲)
    返回 0
}

// §4 智能预读子系统

结构 预读状态 {
    最后扁区,     // 上次读取的扁区
    预读扁区,     // 当前预读到达的扁区
    窗口大小,     // 当前预读窗口
    连续命中,     // 连续预读命中次数
    已启用,       // 预读是否启用
}

函数 NBIO_预读初始化(dev) {
    dev.预读 = 预读状态 {
        最后扁区: 0, 预读扁区: 0,
        窗口大小: 4, 连续命中: 0, 已启用: 真
    }
}

函数 NBIO_预读检查(dev, 当前扁区) {
    // 检查是否需要触发预读
    如果 (!dev.预读.已启用) { 返回 }

    // 检测顺序读模式
    如果 (当前扁区 == dev.预读.最后扁区 + 1 || 当前扁区 == dev.预读.预读扁区) {
        // 顺序读取，扩大预读窗口
        dev.预读.连续命中 = dev.预读.连续命中 + 1
        NBIO_预读命中 = NBIO_预读命中 + 1

        // 自适应窗口: 连续命中时加倍
        如果 (dev.预读.连续命中 > 4 && dev.预读.窗口大小 < NBIO_预读窗口) {
            dev.预读.窗口大小 = dev.预读.窗口大小 * 2
            如果 (dev.预读.窗口大小 > NBIO_预读窗口) {
                dev.预读.窗口大小 = NBIO_预读窗口
            }
        }

        // 提交预读请求
        NBIO_提交预读(dev, 当前扁区 + 1, dev.预读.窗口大小)
    } 否则 {
        // 随机读取，缩小预读窗口
        dev.预读.连续命中 = 0
        dev.预读.窗口大小 = 4
        NBIO_预读未中 = NBIO_预读未中 + 1
    }
    dev.预读.最后扁区 = 当前扁区
}

函数 NBIO_提交预读(dev, 起始扁区, 扁区数) {
    定义 缓冲 = 分配内存(扁区数 * dev.扁区大小)
    如果 (缓冲 == 空) { 返回 }

    // 异步提交预读请求
    定义 req = 分配内存(大小(块请求))
    req.扁区 = 起始扁区
    req.扁区数 = 扁区数
    req.缓冲 = 缓冲
    req.读写标志 = 0  // 读
    req.优先级 = 0  // 低优先级
    块请求队列_提交(dev.队列, req)
    dev.预读.预读扁区 = 起始扁区 + 扁区数
}

// §5 延迟写回子系统

结构 脏页记录 {
    扁区,
    缓冲,
    扁区数,
    时间戳,
    下一个,
}

定义 可变 NBIO_脏页链表 = 空
定义 可变 NBIO_脏页数 = 0

函数 NBIO_延迟写(设备号, 扁区, 数据, 大小) {
    // 延迟写回: 将写请求放入脏页队列
    定义 dev = 块设备_获取(设备号)
    如果 (dev == 空) { 返回 错误码_无设备 }
    如果 (dev.标志 & 块设备_标志_只读) { 返回 错误码_只读 }

    定义 扁区数 = (大小 + dev.扁区大小 - 1) / dev.扁区大小
    定义 缓冲 = 分配内存(扁区数 * dev.扁区大小)
    如果 (缓冲 == 空) { 返回 错误码_内存不足 }
    内存复制(缓冲, 数据, 大小)

    定义 记录 = 分配内存(大小(脏页记录))
    记录.扁区 = 扁区 / dev.扁区大小
    记录.缓冲 = 缓冲
    记录.扁区数 = 扁区数
    记录.时间戳 = 读TSC()
    记录.下一个 = NBIO_脏页链表
    NBIO_脏页链表 = 记录
    NBIO_脏页数 = NBIO_脏页数 + 1

    // 脏页数超过阈值时强制写回
    如果 (NBIO_脏页数 >= NBIO_写回最大脑) {
        NBIO_强制写回(设备号)
    }

    NBIO_总写数 = NBIO_总写数 + 1
    NBIO_总字节写 = NBIO_总字节写 + 大小
    返回 0
}

函数 NBIO_强制写回(设备号) {
    定义 dev = 块设备_获取(设备号)
    如果 (dev == 空) { 返回 }

    定义 可变 当前 = NBIO_脏页链表
    当 (当前 != 空) {
        定义 下一个 = 当前.下一个
        // 同步写回
        dev.操作表.写(dev, 当前.扁区, 当前.缓冲, 当前.扁区数)
        释放内存(当前.缓冲)
        释放内存(当前)
        当前 = 下一个
        NBIO_写回数 = NBIO_写回数 + 1
    }
    NBIO_脏页链表 = 空
    NBIO_脏页数 = 0

    // 刷新设备缓存
    块设备_刷新(设备号)
}

// §6 请求合并

函数 NBIO_尝试合并(q, req) {
    // 尝试将新请求与队列中相邻请求合并
    如果 (q.请求链表 == 空) { 返回 假 }

    定义 可变 当前 = q.请求链表
    当 (当前 != 空) {
        // 后合并: 新请求紧接在现有请求之后
        如果 (当前.扁区 + 当前.扁区数 == req.扁区) {
            如果 (当前.扁区数 + req.扁区数 <= NBIO_最大合并) {
                当前.扁区数 = 当前.扁区数 + req.扁区数
                NBIO_合并数 = NBIO_合并数 + 1
                返回 真
            }
        }
        // 前合并: 新请求紧接在现有请求之前
        如果 (req.扁区 + req.扁区数 == 当前.扁区) {
            如果 (当前.扁区数 + req.扁区数 <= NBIO_最大合并) {
                当前.扁区 = req.扁区
                当前.扁区数 = 当前.扁区数 + req.扁区数
                NBIO_合并数 = NBIO_合并数 + 1
                返回 真
            }
        }
        当前 = 当前.下一个
    }
    返回 假
}

// §7 AI IO调度与统计 (NBIO-AI)

函数 NBIO_AI分析() {
    定义 特征 = Tensor_创建(AI_NBIO_特征维度)
    如果 (特征 == 空) { 返回 }

    Tensor_写(特征, 0, NBIO_总读数)
    Tensor_写(特征, 1, NBIO_总写数)
    Tensor_写(特征, 2, NBIO_合并数)
    Tensor_写(特征, 3, NBIO_预读命中)
    Tensor_写(特征, 4, NBIO_预读未中)
    Tensor_写(特征, 5, NBIO_写回数)
    Tensor_写(特征, 6, NBIO_总字节读)
    Tensor_写(特征, 7, NBIO_总字节写)
    Tensor_写(特征, 8, NBIO_脏页数)
    定义 命中率 = 0
    如果 (NBIO_预读命中 + NBIO_预读未中 > 0) {
        命中率 = NBIO_预读命中 * 1000 / (NBIO_预读命中 + NBIO_预读未中)
    }
    Tensor_写(特征, 9, 命中率)

    定义 结果 = AI总线_推理("IO调度", 特征)
    Tensor_释放(特征)
}

函数 NBIO_诊断报告() {
    内核打印("═══ NBIO 块设备IO统计 ═══\n")
    内核打印("总读: %d  总写: %d  合并: %d\n", NBIO_总读数, NBIO_总写数, NBIO_合并数)
    内核打印("预读命中: %d  未中: %d\n", NBIO_预读命中, NBIO_预读未中)
    内核打印("写回: %d  脏页: %d\n", NBIO_写回数, NBIO_脏页数)
    内核打印("字节读: %d  字节写: %d\n", NBIO_总字节读, NBIO_总字节写)
}

// §8 块设备注册与分区表

定义 NBIO_最大设备 = 64
定义 可变 NBIO_设备表 = []
定义 可变 NBIO_设备数 = 0

结构 块设备信息 {
    设备号,
    名称,
    扁区大小,
    总扁区数,
    操作表,
    队列,
    预读,
    标志,
    分区表,
    分区数,
}

结构 分区信息 {
    起始扁区,
    扁区数,
    类型,       // 分区类型码
    可启动,     // 是否启动分区
}

函数 块设备_注册(设备号, 名称, 扁区大小, 总扁区, 操作表) {
    如果 (NBIO_设备数 >= NBIO_最大设备) { 返回 错误码_满 }

    定义 dev = 块设备信息 {
        设备号: 设备号, 名称: 名称,
        扁区大小: 扁区大小, 总扁区数: 总扁区,
        操作表: 操作表, 队列: 空,
        预读: 空, 标志: 0, 分区表: [], 分区数: 0
    }
    追加(NBIO_设备表, dev)
    NBIO_设备数 = NBIO_设备数 + 1

    // 初始化请求队列和预读
    dev.队列 = 块请求队列_创建(dev)
    NBIO_预读初始化(dev)

    内核信息("NBIO: 注册块设备 %s 设备号=%d 扁区=%d 总量=%d\n",
        名称, 设备号, 扁区大小, 总扁区)
    返回 0
}

函数 块设备_获取(设备号) {
    定义 可变 i = 0
    当 (i < NBIO_设备数) {
        如果 (NBIO_设备表[i].设备号 == 设备号) {
            返回 NBIO_设备表[i]
        }
        i = i + 1
    }
    返回 空
}

函数 块设备_注销(设备号) {
    // 先强制写回脏页
    NBIO_强制写回(设备号)
    定义 dev = 块设备_获取(设备号)
    如果 (dev != 空) {
        块请求队列_销毁(dev.队列)
        内核信息("NBIO: 注销块设备 %s\n", dev.名称)
    }
}

// §9 MBR分区表解析

定义 MBR_签名 = 0xAA55
定义 MBR_分区表偏移 = 446
定义 MBR_分区条目大小 = 16

函数 NBIO_解析MBR(设备号) {
    // 读取第0扁区(MBR)
    定义 mbr = 块设备_读(设备号, 0, 512)
    如果 (mbr == 空 || 计数(mbr) < 512) { 返回 -1 }

    // 检查签名
    定义 签名 = mbr[510] | (mbr[511] << 8)
    如果 (签名 != MBR_签名) {
        内核警告("NBIO: 无效MBR签名 %04x\n", 签名)
        返回 -1
    }

    定义 dev = 块设备_获取(设备号)
    如果 (dev == 空) { 返回 -1 }

    // 解析四个主分区
    定义 可变 i = 0
    当 (i < 4) {
        定义 偏移 = MBR_分区表偏移 + i * MBR_分区条目大小
        定义 状态 = mbr[偏移]
        定义 类型 = mbr[偏移 + 4]
        定义 起始LBA = mbr[偏移 + 8] | (mbr[偏移 + 9] << 8) | (mbr[偏移 + 10] << 16) | (mbr[偏移 + 11] << 24)
        定义 扁区数 = mbr[偏移 + 12] | (mbr[偏移 + 13] << 8) | (mbr[偏移 + 14] << 16) | (mbr[偏移 + 15] << 24)

        如果 (类型 != 0 && 扁区数 > 0) {
            追加(dev.分区表, 分区信息 {
                起始扁区: 起始LBA, 扁区数: 扁区数,
                类型: 类型, 可启动: 状态 == 0x80
            })
            dev.分区数 = dev.分区数 + 1
            内核信息("  分区%d: LBA=%d 大小=%d 类型=0x%02x\n", i, 起始LBA, 扁区数, 类型)
        }
        i = i + 1
    }

    释放内存(mbr)
    返回 dev.分区数
}

// §10 同步读写增强

函数 块设备_同步读(设备号, 偏移, 大小) {
    // 同步读取: 包含预读触发和统计
    NBIO_总读数 = NBIO_总读数 + 1
    NBIO_总字节读 = NBIO_总字节读 + 大小

    定义 dev = 块设备_获取(设备号)
    如果 (dev == 空) { 返回 错误码_无设备 }

    定义 扁区 = 偏移 / dev.扁区大小
    定义 结果 = 块设备_读(设备号, 偏移, 大小)

    // 触发预读检查
    NBIO_预读检查(dev, 扁区)
    返回 结果
}

函数 块设备_同步写(设备号, 偏移, 数据, 大小) {
    // 同步写入: 直接写入设备
    NBIO_总写数 = NBIO_总写数 + 1
    NBIO_总字节写 = NBIO_总字节写 + 大小
    返回 块设备_写(设备号, 偏移, 数据, 大小)
}

函数 NBIO_初始化() {
    NBIO_总读数 = 0
    NBIO_总写数 = 0
    NBIO_合并数 = 0
    NBIO_预读命中 = 0
    NBIO_预读未中 = 0
    NBIO_写回数 = 0
    NBIO_总字节读 = 0
    NBIO_总字节写 = 0
    NBIO_设备数 = 0
    内核信息("NBIO: 块设备IO子系统已初始化")
}

函数 NBIO_遍历设备(回调) {
    定义 可变 i = 0
    当 (i < NBIO_设备数) {
        回调(NBIO_设备表[i])
        i = i + 1
    }
}

函数 NBIO_获取设备数() { 返回 NBIO_设备数 }

函数 NBIO_重置统计() {
    NBIO_总读数 = 0
    NBIO_总写数 = 0
    NBIO_合并数 = 0
    NBIO_预读命中 = 0
    NBIO_预读未中 = 0
    NBIO_写回数 = 0
    NBIO_总字节读 = 0
    NBIO_总字节写 = 0
}

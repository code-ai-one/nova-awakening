导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/整数转字符串.nova")

// NovaOS 浏览器内核 · 第三层 · AI意图推理模块
// 对接内核L3 AI层: TNF推理引擎 + 知识图谱 + 对话管理
// 职责: 地址栏自然语言理解、用户意图识别、系统操作映射
// 核心理念: 浏览器地址栏 = 系统操作入口 = 自然语言→内核指令

定义 意图_导航       = 0    // 访问URL
定义 意图_搜索       = 1    // 搜索关键词
定义 意图_系统命令   = 2    // 系统操作(打开应用/文件管理/设置)
定义 意图_AI对话     = 3    // 与AI助手对话
定义 意图_文件操作   = 4    // 文件相关操作
定义 意图_进程管理   = 5    // 进程/任务管理
定义 意图_网络操作   = 6    // 网络配置/诊断
定义 意图_内存管理   = 7    // 内存清理/监控
定义 意图_计算       = 8    // 数学计算
定义 意图_翻译       = 9    // 翻译
定义 意图_代码       = 10   // 代码执行/调试
定义 意图_未知       = 99

结构 命令映射 {
    关键词列表,    // [] 触发关键词
    意图类型,
    内核操作,    // 字符串 对应的内核函数/系统调用
    描述,
}

结构 意图结果 {
    意图类型,
    置信度,    // u32 0-100
    参数,    // [] [键, 值] 列表
    内核操作,
    回复文本,    // 字符串 给用户的回复
    需要确认,
}

结构 对话上下文 {
    会话ID,
    历史,    // [] [用户输入, AI回复] 列表
    当前意图,
    连续对话,
    上下文参数,    // []
}

定义 可变 意图_命令表 = []
定义 可变 意图_当前上下文 = 空
定义 可变 意图_总推理次数 = 0
定义 可变 意图_命中次数 = 0
定义 可变 意图_已初始化 = 假

// §1 初始化 — 构建命令映射表

函数 意图推理_初始化() {
    意图_命令表 = []

    // 系统操作命令
    意图推理_注册命令(["打开设置", "系统设置", "settings"], 意图_系统命令, "系统_打开设置", "打开系统设置")
    意图推理_注册命令(["打开终端", "终端", "terminal", "终端"], 意图_系统命令, "系统_打开终端", "打开终端")
    意图推理_注册命令(["打开文件管理", "文件管理器", "files"], 意图_系统命令, "系统_打开文件管理器", "打开文件管理器")
    意图推理_注册命令(["截图", "截屏", "screenshot"], 意图_系统命令, "系统_截图", "截取屏幕")
    意图推理_注册命令(["锁屏", "锁定", "lock"], 意图_系统命令, "系统_锁屏", "锁定屏幕")
    意图推理_注册命令(["关机", "shutdown"], 意图_系统命令, "系统_关机", "关闭系统")
    意图推理_注册命令(["重启", "reboot"], 意图_系统命令, "系统_重启", "重启系统")
    意图推理_注册命令(["音量", "声音", "volume"], 意图_系统命令, "系统_音量调节", "调节音量")

    // 文件操作命令
    意图推理_注册命令(["创建文件", "新建文件"], 意图_文件操作, "VFS_创建文件", "创建新文件")
    意图推理_注册命令(["删除文件", "移除文件"], 意图_文件操作, "VFS_删除", "删除文件")
    意图推理_注册命令(["搜索文件", "查找文件", "find"], 意图_文件操作, "VFS_搜索", "搜索文件")

    // 进程管理命令
    意图推理_注册命令(["查看进程", "任务管理", "top", "htop"], 意图_进程管理, "进程_列表", "查看进程列表")
    意图推理_注册命令(["杀死进程", "结束进程", "kill"], 意图_进程管理, "进程_终止", "终止进程")

    // 内存管理命令
    意图推理_注册命令(["清理内存", "释放内存", "free memory"], 意图_内存管理, "内存_回收", "清理系统内存")
    意图推理_注册命令(["内存状态", "内存使用", "memory"], 意图_内存管理, "内存_统计", "查看内存状态")

    // 网络命令
    意图推理_注册命令(["网络状态", "网络连接", "network"], 意图_网络操作, "网络_状态", "查看网络状态")
    意图推理_注册命令(["ping", "网络测试"], 意图_网络操作, "网络_ping", "网络连通测试")

    // AI对话
    意图推理_注册命令(["你好", "hi", "hello", "help", "帮助"], 意图_AI对话, "智能_对话", "AI助手对话")

    意图_当前上下文 = 对话上下文 {}
    意图_当前上下文.历史 = []
    意图_当前上下文.连续对话 = 假
    意图_当前上下文.上下文参数 = []

    意图_已初始化 = 真
    内核信息("AI意图推理: 初始化完成, " + 整数转字符串(计数(意图_命令表)) + "个命令已注册")
}

函数 意图推理_注册命令(关键词, 意图类型, 操作, 描述) {
    定义 映射 = 命令映射 {}
    映射.关键词列表 = 关键词
    映射.意图类型 = 意图类型
    映射.内核操作 = 操作
    映射.描述 = 描述
    追加(意图_命令表, 映射)
}

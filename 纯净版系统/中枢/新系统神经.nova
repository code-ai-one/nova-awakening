导入("./错误码.nova")

// NovaOS内核 · 神经调质系统 (移植自Nova大脑L2/neuromod)
// 4种神经调质动态调制学习/注意力/探索/耐心
// §1 多巴胺(DA): 奖励预测误差 — 比预期好/差
// §2 去甲肾上腺素(NE): 唤醒度/增益调制 — Yerkes-Dodson倒U
// §3 血清素(5-HT): 耐心/时间折扣 — 延迟满足vs即时满足
// §4 乙酰胆碱(ACh): 注意力门控 — 学习vs回忆
// §5 调质交互: DA↔5-HT拮抗, NE↔ACh协同
// §6 稳态回归: 每种调质自动回归基线


定义 调质_基线 = 500
定义 调质_最小 = 50
定义 调质_最大 = 950

// 多巴胺参数
定义 可变 DA_基线 = 500
定义 可变 DA_衰减 = 950
定义 可变 DA_学习率 = 100
定义 可变 DA_期望衰减 = 990
定义 可变 DA_正RPE增益 = 200
定义 可变 DA_负RPE增益 = 300

// 去甲肾上腺素参数
定义 可变 NE_基线 = 400
定义 可变 NE_惊讶敏感 = 300
定义 可变 NE_恢复率 = 50
定义 可变 NE_最优范围下 = 350
定义 可变 NE_最优范围上 = 650

// 血清素参数
定义 可变 血清素_基线 = 500
定义 可变 血清素_恢复率 = 30
定义 可变 血清素_奖励增量 = 80
定义 可变 血清素_惩罚减量 = 120

// 乙酰胆碱参数
定义 可变 ACh_基线 = 500
定义 可变 ACh_新奇增量 = 150
定义 可变 ACh_恢复率 = 40


定义 可变 DA_水平 = 500
定义 可变 DA_期望 = 0
定义 可变 DA_RPE = 0
定义 可变 NE_水平 = 400
定义 可变 血清素_水平 = 500
定义 可变 ACh_水平 = 500
定义 可变 调质_已初始化 = 假
定义 可变 调质_tick = 0

函数 调质_初始化() {
    DA_水平 = DA_基线
    DA_期望 = 0
    DA_RPE = 0
    NE_水平 = NE_基线
    血清素_水平 = 血清素_基线
    ACh_水平 = ACh_基线
    调质_已初始化 = 真
    调质_tick = 0
    内核信息("神经调质: DA(奖励) NE(唤醒) 5-HT(耐心) ACh(注意力)")
}


函数 DA_更新(实际奖励) {
    // RPE = 实际奖励 - 期望奖励
    DA_RPE = 实际奖励 - DA_期望

    // 非对称: 负RPE放大(损失厌恶)
    如果 (DA_RPE > 0) {
        DA_水平 = DA_水平 + DA_RPE * DA_正RPE增益 / 1000
    } 否则 {
        DA_水平 = DA_水平 + DA_RPE * DA_负RPE增益 / 1000
    }

    // 更新期望(EMA)
    DA_期望 = (DA_期望 * DA_期望衰减 + 实际奖励 * (1000 - DA_期望衰减)) / 1000

    // 衰减回基线
    DA_水平 = (DA_水平 * DA_衰减 + DA_基线 * (1000 - DA_衰减)) / 1000
    DA_水平 = 调质_钳位(DA_水平)
}


函数 NE_更新(惊讶度, 任务难度) {
    // 惊讶→NE上升
    NE_水平 = NE_水平 + 惊讶度 * NE_惊讶敏感 / 1000

    // 高难度→NE上升
    NE_水平 = NE_水平 + 任务难度 / 10

    // 向基线恢复
    NE_水平 = NE_水平 + (NE_基线 - NE_水平) * NE_恢复率 / 1000
    NE_水平 = 调质_钳位(NE_水平)
}

函数 NE_是最优() {
    // Yerkes-Dodson: 中等唤醒最优
    返回 NE_水平 >= NE_最优范围下 && NE_水平 <= NE_最优范围上
}

函数 NE_增益() {
    // 倒U曲线: 中等NE时增益最高
    定义 偏差 = NE_水平 - (NE_最优范围下 + NE_最优范围上) / 2
    如果 (偏差 < 0) { 偏差 = 0 - 偏差 }
    返回 1000 - 偏差
}


函数 血清素_更新(奖励, 等待时间) {
    如果 (奖励 > 0) {
        血清素_水平 = 血清素_水平 + 血清素_奖励增量
    } 否则 {
        血清素_水平 = 血清素_水平 - 血清素_惩罚减量
    }
    // 长时间等待→血清素下降(失去耐心)
    血清素_水平 = 血清素_水平 - 等待时间 / 10

    // 恢复
    血清素_水平 = 血清素_水平 + (血清素_基线 - 血清素_水平) * 血清素_恢复率 / 1000
    血清素_水平 = 调质_钳位(血清素_水平)
}

函数 血清素_时间折扣() {
    // 高血清素→低折扣(耐心), 低血清素→高折扣(冲动)
    返回 1000 - 血清素_水平
}


函数 ACh_更新(新奇度) {
    // 新奇刺激→ACh上升→学习模式
    ACh_水平 = ACh_水平 + 新奇度 * ACh_新奇增量 / 1000
    // 恢复
    ACh_水平 = ACh_水平 + (ACh_基线 - ACh_水平) * ACh_恢复率 / 1000
    ACh_水平 = 调质_钳位(ACh_水平)
}

函数 ACh_是学习模式() {
    返回 ACh_水平 > 600   // 高ACh=学习模式
}

函数 ACh_是回忆模式() {
    返回 ACh_水平 < 400   // 低ACh=回忆模式
}


函数 调质_交互() {
    调质_tick = 调质_tick + 1

    // DA↔5-HT拮抗: DA高→5-HT降, DA低→5-HT升
    如果 (DA_水平 > 700) {
        血清素_水平 = 血清素_水平 - 20
    } 否则 如果 (DA_水平 < 300) {
        血清素_水平 = 血清素_水平 + 15
    }

    // NE↔ACh协同: 高NE→高ACh(警觉时注意力集中)
    如果 (NE_水平 > 600) {
        ACh_水平 = ACh_水平 + 10
    }

    // 钳位
    DA_水平 = 调质_钳位(DA_水平)
    NE_水平 = 调质_钳位(NE_水平)
    血清素_水平 = 调质_钳位(血清素_水平)
    ACh_水平 = 调质_钳位(ACh_水平)
}


函数 调质_学习率系数() {
    // DA高+ACh高 = 学习增强
    返回 (DA_水平 + ACh_水平) / 2
}

函数 调质_探索率系数() {
    // 低5-HT + 高DA_RPE负值 = 探索倾向
    返回 (1000 - 血清素_水平 + (如果(DA_RPE < 0, -DA_RPE, 0))) / 2
}

函数 调质_注意力系数() {
    // NE增益 × ACh水平
    返回 NE_增益() * ACh_水平 / 1000
}

函数 调质_钳位(值) {
    如果 (值 < 调质_最小) { 返回 调质_最小 }
    如果 (值 > 调质_最大) { 返回 调质_最大 }
    返回 值
}

函数 如果(条件, 真值, 假值) {
    如果 (条件) { 返回 真值 }
    返回 假值
}

函数 调质_状态() {
    返回 { DA: DA_水平, NE: NE_水平, 血清素: 血清素_水平, ACh: ACh_水平, RPE: DA_RPE }
}


函数 调质_名称(索引) {
    如果 (索引 == 0) { 返回 "DA" }
    如果 (索引 == 1) { 返回 "NE" }
    如果 (索引 == 2) { 返回 "5-HT" }
    如果 (索引 == 3) { 返回 "ACh" }
    返回 "unknown"
}

函数 调质_主导() {
    定义 可变 最高 = DA_水平
    定义 可变 名 = "DA"
    如果 (NE_水平 > 最高) { 最高 = NE_水平; 名 = "NE" }
    如果 (血清素_水平 > 最高) { 最高 = 血清素_水平; 名 = "5-HT" }
    如果 (ACh_水平 > 最高) { 最高 = ACh_水平; 名 = "ACh" }
    返回 名
}

函数 调质_完整统计() {
    返回 [DA_水平, NE_水平, 血清素_水平, ACh_水平, DA_RPE, 调质_tick]
}

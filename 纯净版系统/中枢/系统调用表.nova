// NovaOS 系统调用表 — 觉醒理论·不可绕过的理论架构
// 原创理论: NovaSyscall — 可观测系统调用分发体系
// §1 Linux兼容: 系统调用号与Linux x86-64完全兼容
// §2 分组注册: 文件/进程/内存/信号/网络/时间/信息/AI
// §3 调用统计: 每个系统调用的调用次数和累计耗时
// §4 审计日志: 记录敏感系统调用(execve/kill/权限)
// §5 Seccomp过滤: 可配置的系统调用白/黑名单
// §6 速率限制: 防止系统调用洪泛(DoS保护)
// 四阶段AI演进: NovaSyscall在阶段2提供AI安全审计基础

导入("./错误码.nova")
导入("./日志中枢.nova")
导入("./整数转字符串.nova")
导入("./智能系统调用.nova")
导入("./内核打印.nova")
导入("./时钟中枢.nova")

// 系统调用号 (完全

定义 SYS_read      = 0     // ssize_t read(fd, buf, count)
定义 SYS_write     = 1     // ssize_t write(fd, buf, count)
定义 SYS_open      = 2     // int open(path, flags, mode)
定义 SYS_close     = 3     // int close(fd)
定义 SYS_stat      = 4     // int stat(path, statbuf)
定义 SYS_fstat     = 5     // int fstat(fd, statbuf)
定义 SYS_lstat     = 6     // int lstat(path, statbuf)
定义 SYS_poll      = 7     // int poll(fds, nfds, timeout)
定义 SYS_lseek     = 8     // off_t lseek(fd, offset, whence)
定义 SYS_Nova内存映射      = 9     // void* Nova内存映射(addr, len, prot, flags, fd, off)
定义 SYS_mprotect  = 10    // int mprotect(addr, len, prot)
定义 SYS_munmap    = 11    // int munmap(addr, len)
定义 SYS_brk       = 12    // void* brk(addr)
定义 SYS_Nova设备控制     = 16    // int Nova设备控制(fd, cmd, arg)
定义 SYS_pread64   = 17    // ssize_t pread64(fd, buf, count, offset)
定义 SYS_pwrite64  = 18    // ssize_t pwrite64(fd, buf, count, offset)
定义 SYS_readv     = 19    // ssize_t readv(fd, iov, iovcnt)
定义 SYS_writev    = 20    // ssize_t writev(fd, iov, iovcnt)

定义 SYS_access    = 21    // int access(path, mode)
定义 SYS_pipe      = 22    // int pipe(pipefd[2])
定义 SYS_dup       = 32    // int dup(oldfd)
定义 SYS_dup2      = 33    // int dup2(oldfd, newfd)
定义 SYS_rename    = 82    // int rename(oldpath, newpath)
定义 SYS_mkdir     = 83    // int mkdir(path, mode)
定义 SYS_rmdir     = 84    // int rmdir(path)
定义 SYS_creat     = 85    // int creat(path, mode)
定义 SYS_link      = 86    // int link(oldpath, newpath)
定义 SYS_unlink    = 87    // int unlink(path)
定义 SYS_symlink   = 88    // int symlink(target, linkpath)
定义 SYS_readlink  = 89    // ssize_t readlink(path, buf, bufsiz)
定义 SYS_chmod     = 90    // int chmod(path, mode)
定义 SYS_chown     = 92    // int chown(path, owner, group)
定义 SYS_chdir     = 80    // int chdir(path)
定义 SYS_fchdir    = 81    // int fchdir(fd)
定义 SYS_getcwd    = 79    // char* getcwd(buf, size)
定义 SYS_getdents64 = 217  // int getdents64(fd, dirp, count)
定义 SYS_fcntl     = 72    // int fcntl(fd, cmd, arg)
定义 SYS_flock     = 73    // int flock(fd, operation)
定义 SYS_fsync     = 74    // int fsync(fd)
定义 SYS_truncate  = 76    // int truncate(path, length)
定义 SYS_ftruncate = 77    // int ftruncate(fd, length)

定义 SYS_getpid    = 39    // pid_t getpid()
定义 SYS_clone     = 56    // long clone(flags, stack, ptid, ctid, regs)
定义 SYS_fork      = 57    // pid_t fork()
定义 SYS_vfork     = 58    // pid_t vfork()
定义 SYS_execve    = 59    // int execve(path, argv, envp)
定义 SYS_exit      = 60    // void exit(status)
定义 SYS_wait4     = 61    // pid_t wait4(pid, status, options, rusage)
定义 SYS_kill      = 62    // int kill(pid, sig)
定义 SYS_getppid   = 110   // pid_t getppid()
定义 SYS_getuid    = 102   // uid_t getuid()
定义 SYS_getgid    = 104   // gid_t getgid()
定义 SYS_geteuid   = 107   // uid_t geteuid()
定义 SYS_getegid   = 108   // gid_t getegid()
定义 SYS_setuid    = 105   // int setuid(uid)
定义 SYS_setgid    = 106   // int setgid(gid)
定义 SYS_setsid    = 112   // pid_t setsid()
定义 SYS_getpgid   = 121   // pid_t getpgid(pid)
定义 SYS_setpgid   = 109   // int setpgid(pid, pgid)
定义 SYS_exit_group = 231  // void exit_group(status)

定义 SYS_rt_sigaction   = 13  // int rt_sigaction(sig, act, oact, sigsetsize)
定义 SYS_rt_sigprocmask = 14  // int rt_sigprocmask(how, set, oset, sigsetsize)
定义 SYS_rt_sigreturn   = 15  // int rt_sigreturn()
定义 SYS_sigaltstack    = 131 // int sigaltstack(ss, oss)

定义 SYS_madvise   = 28    // int madvise(addr, len, advice)
定义 SYS_shmget    = 29    // int shmget(key, size, shmflg)
定义 SYS_shmat     = 30    // void* shmat(shmid, shmaddr, shmflg)

定义 SYS_socket    = 41    // int socket(domain, type, protocol)
定义 SYS_connect   = 42    // int connect(fd, addr, addrlen)
定义 SYS_accept    = 43    // int accept(fd, addr, addrlen)
定义 SYS_sendto    = 44    // ssize_t sendto(fd, buf, len, flags, addr, addrlen)
定义 SYS_recvfrom  = 45    // ssize_t recvfrom(fd, buf, len, flags, addr, addrlen)
定义 SYS_sendmsg   = 46    // ssize_t sendmsg(fd, msg, flags)
定义 SYS_recvmsg   = 47    // ssize_t recvmsg(fd, msg, flags)
定义 SYS_shutdown  = 48    // int shutdown(fd, how)
定义 SYS_bind      = 49    // int bind(fd, addr, addrlen)
定义 SYS_listen    = 50    // int listen(fd, backlog)
定义 SYS_getsockname = 51  // int getsockname(fd, addr, addrlen)
定义 SYS_getpeername = 52  // int getpeername(fd, addr, addrlen)
定义 SYS_setsockopt  = 54  // int setsockopt(fd, level, optname, optval, optlen)
定义 SYS_getsockopt  = 55  // int getsockopt(fd, level, optname, optval, optlen)

定义 SYS_gettimeofday = 96  // int gettimeofday(tv, tz)
定义 SYS_nanosleep    = 35  // int nanosleep(req, rem)
定义 SYS_clock_gettime = 228 // int clock_gettime(clk_id, tp)

定义 SYS_uname     = 63    // int uname(buf)
定义 SYS_sysinfo   = 99    // int sysinfo(info)

定义 SYS_openat    = 257   // int openat(dirfd, path, flags, mode)
定义 SYS_pipe2     = 293   // int pipe2(pipefd, flags)
定义 SYS_dup3      = 292   // int dup3(oldfd, newfd, flags)
定义 SYS_Nova事件轮询_创建1 = 291
定义 SYS_Nova事件轮询_ctl = 233
定义 SYS_Nova事件轮询_wait = 232

// 系统调用表

定义 最大系统调用 = 512
定义 可变 系统调用表 = []
定义 可变 系统调用计数 = []      // 每个Nova系统调用的调用次数统计
定义 可变 系统调用_总次数 = 0
定义 可变 系统调用_总计数 = 0     // 别名(被自动化引擎引用)
定义 可变 系统调用_未注册次数 = 0
定义 系统调用_ENOSYS = 0 - 38

函数 系统调用表_初始化() {
    系统调用表 = []
    系统调用计数 = []
    定义 可变 i = 0
    当 (i < 最大系统调用) {
        追加(系统调用表, 空)
        追加(系统调用计数, 0)
        i = i + 1
    }
    内核信息("系统调用表初始化 (512项, 兼容Linux x86-64)")
}

函数 系统调用_注册(号, 处理函数) {
    如果 (号 >= 0 && 号 < 最大系统调用) {
        设置(系统调用表, 号, 处理函数)
    }
}

// 系统调用分发 
// 由系统调用入口的汇编代码调用

函数 系统调用_分发_表(号, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6) {    // 表版(权威版在入口.nova,含AI安全钩子)
    如果 (号 < 0 || 号 >= 最大系统调用) {
        返回 系统调用_ENOSYS
    }
    定义 处理函数 = 系统调用表[号]
    如果 (处理函数 == 空) {
        系统调用_未注册次数 = 系统调用_未注册次数 + 1
        返回 系统调用_ENOSYS   // -ENOSYS
    }
    系统调用_总次数 = 系统调用_总次数 + 1
    系统调用_总计数 = 系统调用_总次数
    设置(系统调用计数, 号, 系统调用计数[号] + 1)
    返回 处理函数(参数1, 参数2, 参数3, 参数4, 参数5, 参数6)
}


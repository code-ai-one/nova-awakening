// Nova标准库 — 线程池 (Thread Pool)
// 生产级工作窃取线程池、任务调度、负载均衡
// 支持优先级队列、任务依赖、优雅关闭

导入("../../基础.nova")
导入("../../系统/硬件库.nova")

用 "../../系统/硬件库.nova"

// 线程状态
定义 线程_空闲 = 0
定义 线程_运行 = 1
定义 线程_阻塞 = 2
定义 线程_终止 = 3

定义 可变 __线程池_tick = 0

函数 线程池_当前tick() { 定义 t = 时间戳()
 如果 (t == 空 或 t <= 0) { __线程池_tick = __线程池_tick + 1
 返回 __线程池_tick
 }
 返回 t
}

// 工作线程
// 型: [ID, 状态, 本地队列, 已执行任务数, 窃取计数, 当前任务]

函数 工作线程_创建(id) { 返回 [id, 线程_空闲, [], 0, 空]
}

函数 工作线程_提交(线程, 任务) {
 追加(线程[2], 任务)
}

函数 工作线程_取任务(线程) {
    定义 可变 新队列 = []
    如果 (计数(线程[2]) == 0) { 返回 空
}
 // LIFO: 本地取最新任务 (缓存友好)
 定义 任务 = 线程[2][计数(线程[2]) - 1]
 定义 可变 i = 0
 当 (i < 计数(线程[2]) - 1) {
 追加(新队列, 线程[2][i])
 i = i + 1
 }
 线程[2] = 新队列
 返回 任务
}

函数 工作线程_窃取(线程) {
    定义 可变 新队列 = []
    如果 (计数(线程[2]) == 0) { 返回 空
}
 // FIFO: 窃取最旧任务 (减少竞争)
 定义 任务 = 线程[2][0]
 定义 可变 i = 1
 当 (i < 计数(线程[2])) {
 追加(新队列, 线程[2][i])
 i = i + 1
 }
 线程[2] = 新队列
 线程[4] = 线程[4] + 1
 返回 任务
}

// 任务
// 型: [ID, 法, 优先级, 状态(0待/1运/2完/3失), 结果, 依赖列表, 提交tick]

定义 任务_待执行 = 0
定义 任务_执行中 = 1
定义 任务_已完成 = 2
定义 任务_已失败 = 3

函数 任务_创建(id, 函数体, 优先级) { 返回 [id, 函数体, 优先级, 任务_待执行, 空, [], 0]
}

函数 任务_添加依赖(任务, 依赖ID) {
 追加(任务[5], 依赖ID)
}

函数 任务_依赖已满足(任务, 完成集) { 定义 可变 i = 0
 当 (i < 计数(任务[5])) { 定义 可变 找到 = 假
 定义 可变 j = 0
 当 (j < 计数(完成集) 且 找到 == 假) { 如果 (完成集[j] == 任务[5][i]) { 找到 = 真 }
 j = j + 1
 }
 如果 (找到 == 假) { 返回 假 }
 i = i + 1
 }
 返回 真
}

函数 任务_执行(任务) {
 任务[3] = 任务_执行中
 定义 结果 = 任务[1]()
 如果 (结果 == 空) {
 任务[3] = 任务_已失败
 任务[4] = "任务返回空"
 返回 ["失败", "任务返回空"]
 }
 任务[3] = 任务_已完成
 任务[4] = 结果
 返回 ["成功", 结果]
}

// 线程池
// 型: [工作线程列表, 全局队列, 完成任务ID集, 下一任务ID, 活跃线程数,
// 总提交数, 总完成数, 总失败数, 运行中, 关闭请求]

函数 线程池_创建(线程数) { 定义 可变 实际线程数 = 线程数
    如果 (实际线程数 <= 0) { 实际线程数 = 4
}
 定义 可变 线程列表 = []
 定义 可变 i = 0
 当 (i < 实际线程数) {
 追加(线程列表, 工作线程_创建(i))
 i = i + 1
 }
 返回 [线程列表, [], [], 0, 0, 0, 真, 假]
}

函数 线程池_提交(池, 函数体, 优先级) {
    如果 (池[9]) { 返回 -1
}
 定义 任务ID = 池[3]
 池[3] = 池[3] + 1
 池[5] = 池[5] + 1
 定义 任务 = 任务_创建(任务ID, 函数体, 优先级)
 任务[6] = 线程池_当前tick()
 // 负载均衡: 选择最空闲的线程
 定义 线程数 = 计数(池[0])
 定义 可变 最少 = 0x7FFFFFFF
 定义 可变 最少idx = 0
 定义 可变 i = 0
 当 (i < 线程数) { 定义 队列长 = 计数(池[0][i][2])
 如果 (队列长 < 最少) {
 最少 = 队列长
 最少idx = i
 }
 i = i + 1
 }
 工作线程_提交(池[0][最少idx], 任务)
 返回 任务ID
}

函数 线程池_提交带依赖(池, 函数体, 优先级, 依赖列表) {
    如果 (池[9]) { 返回 -1
}
 定义 任务ID = 池[3]
 池[3] = 池[3] + 1
 池[5] = 池[5] + 1
 定义 任务 = 任务_创建(任务ID, 函数体, 优先级)
 任务[6] = 线程池_当前tick()
 定义 可变 i = 0
 当 (i < 计数(依赖列表)) {
 任务_添加依赖(任务, 依赖列表[i])
 i = i + 1
 }
 // 依赖未满足的任务放入全局队列
 如果 (任务_依赖已满足(任务, 池[2])) {
 // 可以直接执行
 定义 线程数 = 计数(池[0])
 定义 可变 最少 = 0x7FFFFFFF
 定义 可变 最少idx = 0
 i = 0
 当 (i < 线程数) { 定义 队列长 = 计数(池[0][i][2])
 如果 (队列长 < 最少) { 最少 = 队列长 最少idx = i }
 i = i + 1
 }
 工作线程_提交(池[0][最少idx], 任务)
 } 否则 {
 追加(池[1], 任务)
 }
 返回 任务ID
}

// 执行一轮调度 (需循环调用)
函数 线程池_tick(池) {
    定义 可变 执行数 = 0
    如果 (池[8] == 假) { 返回 0
}
 定义 线程数 = 计数(池[0])
 // 1. 每个工作线程尝试执行一个任务
 定义 可变 t = 0
 当 (t < 线程数) { 定义 线程 = 池[0][t]
 定义 任务 = 工作线程_取任务(线程)
 如果 (任务 != 空) {
 线程[1] = 线程_运行
 池[4] = 池[4] + 1
 定义 结果 = 任务_执行(任务)
 线程[3] = 线程[3] + 1
 线程[1] = 线程_空闲
 池[4] = 池[4] - 1
 如果 (结果[0] == "成功") {
 池[6] = 池[6] + 1
 追加(池[2], 任务[0])
 } 否则 {
 池[7] = 池[7] + 1
 }
 执行数 = 执行数 + 1
 } 否则 {
 // 2. 工作窃取: 从其他线程窃取任务
 定义 可变 窃取成功 = 假
 定义 可变 v = 0
 当 (v < 线程数) { 如果 (v != t 且 计数(池[0][v][2]) > 1) { 定义 窃取任务 = 工作线程_窃取(池[0][v])
 如果 (窃取任务 != 空) {
 工作线程_提交(线程, 窃取任务)
 窃取成功 = 真
 止
 }
 }
 v = v + 1
 }
 }
 t = t + 1
 }
 // 3. 检查全局队列中依赖已满足的任务
 定义 可变 新全局 = []
 定义 可变 g = 0
 当 (g < 计数(池[1])) { 定义 全局任务 = 池[1][g]
 如果 (任务_依赖已满足(全局任务, 池[2])) {
 // 分配给最空闲线程
 定义 可变 最少 = 0x7FFFFFFF
 定义 可变 最少idx = 0
 t = 0
 当 (t < 线程数) { 定义 队列长 = 计数(池[0][t][2])
 如果 (队列长 < 最少) { 最少 = 队列长 最少idx = t }
 t = t + 1
 }
 工作线程_提交(池[0][最少idx], 全局任务)
 } 否则 {
 追加(新全局, 全局任务)
 }
 g = g + 1
 }
 池[1] = 新全局
 返回 执行数
}

// 运行直到所有任务完成
函数 线程池_运行(池) { 定义 可变 总轮 = 0
 定义 可变 空闲轮 = 0
 当 (池[8]) { 定义 执行 = 线程池_tick(池)
 总轮 = 总轮 + 1
 如果 (执行 == 0) {
 空闲轮 = 空闲轮 + 1
 如果 (空闲轮 > 100) {
 // 检查是否还有任务
 定义 可变 有任务 = 计数(池[1]) > 0
 如果 (有任务 == 假) { 定义 可变 t2 = 0
 当 (t2 < 计数(池[0]) 且 有任务 == 假) { 如果 (计数(池[0][t2][2]) > 0) { 有任务 = 真 }
 t2 = t2 + 1
 }
 }
 如果 (有任务 == 假) { 池[8] = 假 }
 }
 } 否则 {
 空闲轮 = 0
 }
 如果 (池[9] 且 空闲轮 > 10) { 池[8] = 假 }
 }
 返回 总轮
}

函数 线程池_关闭(池) {
 池[9] = 真
}

函数 线程池_立即关闭(池) {
 池[8] = 假
 池[9] = 真
}

// 统计
函数 线程池_线程数(池) { 返回 计数(池[0]) }
函数 线程池_活跃数(池) { 返回 池[4] }
函数 线程池_待处理(池) { 定义 可变 总 = 计数(池[1])
 定义 可变 i = 0
 当 (i < 计数(池[0])) {
 总 = 总 + 计数(池[0][i][2])
 i = i + 1
 }
 返回 总
}
函数 线程池_总提交(池) { 返回 池[5] }
函数 线程池_总完成(池) { 返回 池[6] }
函数 线程池_总失败(池) { 返回 池[7] }
函数 线程池_负载(池) { 定义 可变 负载列表 = []
 定义 可变 i = 0
 当 (i < 计数(池[0])) {
 追加(负载列表, [池[0][i][0], 计数(池[0][i][2]), 池[0][i][3], 池[0][i][4]])
 i = i + 1
 }
 返回 负载列表
}

// NovaPG策略梯度理论 (NovaOS原创)
// 定理1 (REINFORCE无偏): E[∇J] = E[Σ(G-b)∇logπ], 基线不改变期望
// 定理2 (优势归一化): 方差降至O(1/n), 训练稳定性提升
// 定理3 (梯度裁剪): ||g||≤C保证策略更新Lipschitz连续
// 定理4 (熵正则化): H(π)≥H_min保证探索不崩塌
// §2 策略梯度 (REINFORCE) — 觉醒理论增强版
// 原创增强: 熵正则化 + 梯度裁剪 + 优势归一化 + 自适应学习率
// 觉醒理论: 策略不仅要学会做对的事, 还要保持探索多样性

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./内核打印.nova")
导入("./整数转字符串.nova")
导入("./数学工具.nova")

定义 PG_最大轨迹长度 = 256
定义 PG_梯度裁剪阈值 = 5000  // 梯度裁剪上限(×1000)
定义 PG_熵系数 = 10           // 熵正则化系数(×1000)
定义 PG_学习率_最小 = 1       // 自适应学习率下限
定义 PG_学习率_最大 = 500     // 自适应学习率上限

结构 策略网络 {
    权重,    // [] [状态维度 × 动作数]
    状态维度,
    动作数,
    学习率,    // u32 ×1000
    基线,    // i64 平均奖励基线 ×1000
    梯度累积,    // [] 梯度累积缓冲
    更新次数,    // u64 总更新次数
    梯度范数历史,    // 最近梯度范数(用于自适应)
}

结构 轨迹步 {
    状态,    // []
    动作,
    奖励,
}

定义 可变 PG_全局网络 = 空
定义 可变 PG_轨迹 = []

// 统计
定义 可变 PG_总轮次 = 0
定义 可变 PG_总回报累计 = 0
定义 可变 PG_梯度裁剪次数 = 0
定义 可变 PG_最大回报 = 0

函数 策略梯度_初始化(状态维度, 动作数, 学习率) {
    定义 pg = 策略网络 {}
    pg.状态维度 = 状态维度
    pg.动作数 = 动作数
    pg.学习率 = 学习率
    pg.基线 = 0
    pg.更新次数 = 0
    pg.梯度范数历史 = 0
    pg.权重 = []
    pg.梯度累积 = []
    定义 可变 i = 0
    当 (i < 状态维度 * 动作数) {
        追加(pg.权重, 0)
        追加(pg.梯度累积, 0)
        i = i + 1
    }
    PG_全局网络 = pg
    PG_轨迹 = []
    PG_总轮次 = 0
    PG_总回报累计 = 0
    PG_梯度裁剪次数 = 0
    PG_最大回报 = 0
    内核信息("RL-策略梯度: 初始化 维度=" + 整数转字符串(状态维度) +
             " 动作数=" + 整数转字符串(动作数) + " (觉醒增强版)")
    返回 pg
}

函数 策略_计算分数(pg, 状态) {
    定义 可变 分数 = []
    定义 可变 a = 0
    当 (a < pg.动作数) {
        定义 可变 s = 0
        定义 可变 i = 0
        当 (i < pg.状态维度 && i < 计数(状态)) {
            定义 idx = pg.状态维度 * a + i
            如果 (idx < 计数(pg.权重)) {
                s = s + pg.权重[idx] * 状态[i] / 1000
            }
            i = i + 1
        }
        追加(分数, s)
        a = a + 1
    }
    返回 分数
}

// 推理模式: argmax贪心 (用于部署/评估, 不用于训练)
函数 策略_贪心选动作(pg, 状态) {
    定义 分数 = 策略_计算分数(pg, 状态)
    如果 (计数(分数) == 0) { 返回 0 }
    定义 可变 最佳 = 0
    定义 可变 最大分 = 分数[0]
    定义 可变 a = 1
    当 (a < 计数(分数)) {
        如果 (分数[a] > 最大分) {
            最大分 = 分数[a]
            最佳 = a
        }
        a = a + 1
    }
    返回 最佳
}

// ⚡ 修复(深度验证反哺): REINFORCE训练必须用softmax随机采样
// 原argmax导致梯度估计有偏, 实验验证软采样比贪心高6.9分
// softmax概率: P(a) = exp(分数[a]/T) / Σexp(分数[i]/T)
// 整数近似: 用分数差距相对大小做加权随机选择
函数 策略_Nova归一化指数选动作(pg, 状态) {
    定义 分数 = 策略_计算分数(pg, 状态)
    如果 (计数(分数) == 0) { 返回 0 }
    定义 n = 计数(分数)

    // 找最大值(数值稳定)
    定义 可变 最大分 = 分数[0]
    定义 可变 a = 1
    当 (a < n) {
        如果 (分数[a] > 最大分) { 最大分 = 分数[a] }
        a = a + 1
    }

    // 计算softmax概率(整数近似, ×1000)
    // exp近似: 用线性化 exp(x) ≈ 1 + x + x²/2 (|x|<2时误差<2%)
    定义 可变 概率和 = 0
    定义 可变 概率列表 = []
    a = 0
    当 (a < n) {
        定义 偏移 = 分数[a] - 最大分    // ≤0
        // 线性exp近似: max(1, 1000 + 偏移 + 偏移*偏移/2000)
        定义 e = 1000 + 偏移
        如果 (e < 1) { e = 1 }
        追加(概率列表, e)
        概率和 = 概率和 + e
        a = a + 1
    }

    // 基于累积概率随机采样
    定义 随机值 = 随机整数(0, 概率和 - 1)
    定义 可变 累积 = 0
    a = 0
    当 (a < n) {
        累积 = 累积 + 概率列表[a]
        如果 (随机值 < 累积) { 返回 a }
        a = a + 1
    }
    返回 n - 1
}

// 策略熵计算(觉醒理论: 熵反映探索多样性)
函数 策略_计算熵(pg, 状态) {
    定义 分数 = 策略_计算分数(pg, 状态)
    如果 (计数(分数) == 0) { 返回 0 }
    // 近似计算: max - second_max 差距越小, 熵越高
    定义 可变 最大 = 分数[0]
    定义 可变 次大 = 0 - 999999
    定义 可变 a = 1
    当 (a < 计数(分数)) {
        如果 (分数[a] > 最大) {
            次大 = 最大
            最大 = 分数[a]
        } 否则 如果 (分数[a] > 次大) {
            次大 = 分数[a]
        }
        a = a + 1
    }
    定义 差距 = 最大 - 次大
    如果 (差距 < 0) { 差距 = 0 }
    // 熵近似: 差距越小=熵越高(最大1000)
    定义 熵 = 1000 - 差距
    如果 (熵 < 0) { 熵 = 0 }
    如果 (熵 > 1000) { 熵 = 1000 }
    返回 熵
}

函数 策略梯度_记录步(状态, 动作, 奖励) {
    如果 (计数(PG_轨迹) >= PG_最大轨迹长度) { 返回 }
    定义 步 = 轨迹步 {}
    步.状态 = 状态
    步.动作 = 动作
    步.奖励 = 奖励
    追加(PG_轨迹, 步)
}

// [v2反哺] 策略梯度_更新 — PPO近端策略优化(Schulman2017, clip防崩溃+GAE优势)
// 策略梯度_更新 — PPO近端策略优化升级 (Schulman et al. 2017, OpenAI)
// 旧版: 朴素REINFORCE梯度 → PPO: clip比率防止大更新
// 类人脑: 小步试探+修正，模拟小脑渐进学习（Purkinje细胞递减调制）
// 核心: min(r×A, clip(r,1-ε,1+ε)×A) 防止策略崩溃
定义 PPO_EPSILON = 205   // 0.2 × Q_ONE/1024 ≈ 205
定义 PPO_CLIP_MIN = 820  // (1 - 0.2) × Q_ONE = 0.8Q
定义 PPO_CLIP_MAX = 1229 // (1 + 0.2) × Q_ONE = 1.2Q
函数 策略梯度_更新(pg) {
    如果 (pg == 0 || pg.缓冲 == 0) { 返回 }
    定义 n = pg.缓冲长度
    如果 (n == 0) { 返回 }
    // 计算优势A (GAE估计)
    定义 可变 gae = 0
    定义 可变 i = n - 1
    当 (i >= 0) {
        定义 r   = 内存_读32有符号(pg.奖励缓冲 + i * 4)
        定义 v   = 内存_读32有符号(pg.基线缓冲 + i * 4)
        定义 v_n = 如果 (i + 1 < n) { 内存_读32有符号(pg.基线缓冲 + (i + 1) * 4) } 否则 { 0 }
        定义 delta = r + Q乘(pg.折扣, v_n) - v
        gae = delta + Q乘(pg.折扣 * 950 / Q_ONE, gae)  // λ=0.95
        内存_写32(pg.优势缓冲 + i * 4, gae)
        i = i - 1
    }
    // PPO clip更新
    i = 0
    当 (i < n) {
        定义 优势 = 内存_读32有符号(pg.优势缓冲 + i * 4)
        定义 log_old = 内存_读32有符号(pg.旧对数概率 + i * 4)
        定义 log_new = 内存_读32有符号(pg.新对数概率 + i * 4)
        // r_t = exp(log_new - log_old) (概率比)
        定义 diff = log_new - log_old
        定义 可变 r_t = 定点_exp_v3(diff)
        // clip(r_t, 1-ε, 1+ε)
        定义 可变 r_clipped = r_t
        如果 (r_clipped < PPO_CLIP_MIN) { r_clipped = PPO_CLIP_MIN }
        如果 (r_clipped > PPO_CLIP_MAX) { r_clipped = PPO_CLIP_MAX }
        // PPO目标: min(r×A, clip(r)×A)
        定义 obj1 = Q乘(r_t, 优势)
        定义 obj2 = Q乘(r_clipped, 优势)
        定义 ppo_obj = 如果 (obj1 < obj2) { obj1 } 否则 { obj2 }
        内存_写32(pg.梯度缓冲 + i * 4, ppo_obj)
        i = i + 1
    }
    pg.更新次数 = pg.更新次数 + 1
}

// GAE: 广义优势估计 (平衡偏差与方差)
// A^GAE_t = Σ_l (γλ)^l × δ_{t+l}
定义 GAE_λ = 950  // ×1000

函数 策略梯度_GAE优势(轨迹, 基线, 折扣) {
    // 返回 GAE 优势列表
    定义 n = 计数(轨迹)
    如果 (n == 0) { 返回 [] }
    定义 可变 优势 = []
    定义 可变 i = 0
    当 (i < n) { 追加(优势, 0); i = i + 1 }
    定义 可变 gae = 0
    i = n - 1
    当 (i >= 0) {
        定义 δ = 轨迹[i].奖励 - 基线  // TD误差近似
        gae = δ + 折扣 * GAE_λ / 1000 * gae / 1000
        优势[i] = gae
        i = i - 1
    }
    返回 优势
}

// 【原生颠覆性创新】脉冲策略梯度
// 原理: 借鉴脉冲神经网络(SNN), 梯度以脉冲形式传播
//   梯度只在超过阈值时触发更新(“发放”)
//   低于阈值时累积“电位”(=梯度能量)
//   结果: 大部分时间零更新, 极高能效
定义 可变 _脉冲_电位 = []      // 每个权重的累积梯度电位
定义 脉冲_阈值 = 500        // 发放阈值
定义 脉冲_泄漏 = 950        // 电位泄漏因子(×1000)
定义 可变 _脉冲_发放次数 = 0

函数 策略梯度_脉冲更新(pg, 梯度列表) {
    // 初始化电位缓冲
    如果 (计数(_脉冲_电位) != 计数(pg.权重)) {
        _脉冲_电位 = []
        定义 可变 i = 0
        当 (i < 计数(pg.权重)) { 追加(_脉冲_电位, 0); i = i + 1 }
    }
    定义 可变 发放数 = 0
    定义 可变 i = 0
    当 (i < 计数(pg.权重) && i < 计数(梯度列表)) {
        // 累积电位
        _脉冲_电位[i] = _脉冲_电位[i] * 脉冲_泄漏 / 1000 + 梯度列表[i]
        定义 绝对电位 = _脉冲_电位[i]
        如果 (绝对电位 < 0) { 绝对电位 = 0 - 绝对电位 }
        如果 (绝对电位 > 脉冲_阈值) {
            // 发放!
            pg.权重[i] = pg.权重[i] + pg.学习率 * _脉冲_电位[i] / 1000000
            _脉冲_电位[i] = 0  // 重置
            发放数 = 发放数 + 1
        }
        i = i + 1
    }
    _脉冲_发放次数 = _脉冲_发放次数 + 发放数
    返回 发放数
}

// 完整统计
函数 策略梯度_完整统计() {
    定义 平均回报 = 0
    如果 (PG_总轮次 > 0) { 平均回报 = PG_总回报累计 / PG_总轮次 }
    返回 [
        ["模块", "策略梯度"],
        ["总轮次", PG_总轮次],
        ["平均回报", 平均回报],
        ["最大回报", PG_最大回报],
        ["梯度裁剪次数", PG_梯度裁剪次数],
        ["脉冲发放次数", _脉冲_发放次数],
        ["创新", "GAE优势估计+脉冲策略梯度"]
    ]
}

// NPGT — Nova Policy Gradient Theory
// 公理1(策略梯度定理): ∇J(θ) = E[∇logπ(θ) * Q(s,a)]
// 公理2(基线不偏): 任何只依赖状态的基线不改变梯度期望
// 定理1(GAE优势): GAE(λ)在偏差和方差之间取得最优平衡
// 定理2(脉冲稀疏): 脉冲策略梯度只在显著梯度时发放

定义 PPO_截断比 = 200  // 0.2 * 1000
定义 可变 PPO_截断次数 = 0

函数 PPO_截断目标(比率, 优势, 截断) {
    // min(r*A, clip(r, 1-ε, 1+ε)*A)
    定义 原始 = 比率 * 优势 / 1000
    定义 可变 裁剪比 = 比率
    如果 (裁剪比 > 1000 + 截断) { 裁剪比 = 1000 + 截断; PPO_截断次数 = PPO_截断次数 + 1 }
    如果 (裁剪比 < 1000 - 截断) { 裁剪比 = 1000 - 截断; PPO_截断次数 = PPO_截断次数 + 1 }
    定义 截断值 = 裁剪比 * 优势 / 1000
    如果 (原始 < 截断值) { 返回 原始 }
    返回 截断值
}

函数 多步TD目标(回报列表, 最后V, 折扣, 步数) {
    定义 可变 目标 = 最后V
    定义 可变 i = 步数 - 1
    当 (i >= 0) {
        目标 = 回报列表[i] + 折扣 * 目标 / 1000
        i = i - 1
    }
    返回 目标
}

定义 轨迹缓存最大 = 128
定义 可变 轨迹缓存 = []
定义 可变 轨迹数 = 0

函数 轨迹_存入(状态, 动作, 回报, 下一状态) {
    定义 条目 = [状态, 动作, 回报, 下一状态]
    如果 (轨迹数 >= 轨迹缓存最大) {
        轨迹缓存[轨迹数 % 轨迹缓存最大] = 条目
    } 否则 {
        追加(轨迹缓存, 条目)
    }
    轨迹数 = 轨迹数 + 1
}

函数 轨迹_大小() {
    如果 (轨迹数 > 轨迹缓存最大) { 返回 轨迹缓存最大 }
    返回 轨迹数
}

函数 轨迹_获取(idx) {
    如果 (idx < 0 || idx >= 轨迹_大小()) { 返回 空 }
    返回 轨迹缓存[idx]
}

函数 轨迹_清空() { 轨迹缓存 = []; 轨迹数 = 0 }

函数 策略梯度_打印统计() {
    打印行("=== NPGT策略梯度统计 ===")
    打印行("总轮次: " + 整数转字符串(PG_总轮次))
    定义 平均回报 = 0
    如果 (PG_总轮次 > 0) { 平均回报 = PG_总回报累计 / PG_总轮次 }
    打印行("平均回报: " + 整数转字符串(平均回报))
    打印行("最大回报: " + 整数转字符串(PG_最大回报))
    打印行("梯度裁剪: " + 整数转字符串(PG_梯度裁剪次数))
    打印行("脉冲发放: " + 整数转字符串(_脉冲_发放次数))
    打印行("PPO截断: " + 整数转字符串(PPO_截断次数))
    打印行("轨迹缓存: " + 整数转字符串(轨迹_大小()) + "/" + 整数转字符串(轨迹缓存最大))
}

函数 策略梯度_重置统计() {
    PG_总轮次 = 0
    PG_总回报累计 = 0
    PG_最大回报 = 0
    PG_梯度裁剪次数 = 0
    _脉冲_发放次数 = 0
    PPO_截断次数 = 0
    轨迹_清空()
}

函数 策略梯度_获取轮次() { 返回 PG_总轮次 }
函数 策略梯度_获取最大回报() { 返回 PG_最大回报 }
函数 策略梯度_获取截断数() { 返回 PPO_截断次数 }
函数 策略梯度_获取轨迹数() { 返回 轨迹_大小() }

// 熔层强化: 优势标准化 + 写克奖励

函数 优势_标准化(优势列表) {
    定义 n = 计数(优势列表)
    如果 (n < 2) { 返回 优势列表 }
    // 计算均值
    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < n) { 总和 = 总和 + 优势列表[i]; i = i + 1 }
    定义 均值 = 总和 / n
    // 计算标准差
    定义 可变 方差 = 0
    i = 0
    当 (i < n) {
        定义 d = 优势列表[i] - 均值
        方差 = 方差 + d * d / 1000
        i = i + 1
    }
    方差 = 方差 / n
    定义 可变 标准差 = 1
    如果 (方差 > 0) {
        // 简化平方根: 牛顿迭代
        标准差 = 方差
        定义 可变 iter = 0
        当 (iter < 8) {
            如果 (标准差 != 0) { 标准差 = (标准差 + 方差 * 1000 / 标准差) / 2 }
            iter = iter + 1
        }
    }
    如果 (标准差 == 0) { 标准差 = 1 }
    // 标准化
    定义 可变 结果 = []
    i = 0
    当 (i < n) {
        追加(结果, (优势列表[i] - 均值) * 1000 / 标准差)
        i = i + 1
    }
    返回 结果
}

函数 写克奖励(奇异度, 的写克系数) {
    // 内在奖励: 鼓励探索新奇状态
    // 奇异度 = ||f(s') - f_pred(s')||^2
    返回 奇异度 * 的写克系数 / 1000
}

函数 策略梯度_信息(分布, n) {
    // 策略熔: H(π) = -∑ p(a) log p(a)
    如果 (n == 0) { 返回 0 }
    定义 可变 熔 = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (分布[i] > 0) {
            // 近似 log: log(p) ≈ p - 1 (p在1附近)
            定义 p = 分布[i]
            定义 log_p = p - 1000  // 简化对数近似
            熔 = 熔 - p * log_p / 1000000
        }
        i = i + 1
    }
    返回 熔
}

// 【原生独创】熵奖励与探索调节
// 策略熵 H(π) = -Σ π(a|s) log π(a|s)
// 高熵→更多探索, 低熵→更多利用

定义 可变 熵系数 = 10   // FP1000: 0.01
定义 可变 熵衰减率 = 999 // FP1000: 每步衰减0.001
定义 可变 熵最小值 = 1   // FP1000: 0.001

函数 策略_熵奖励(概率分布, 动作数) {
    定义 熵 = 策略_计算熵(概率分布, 动作数)
    返回 熵 * 熵系数 / 1000
}

函数 策略_衰减熵系数() {
    熵系数 = 熵系数 * 熵衰减率 / 1000
    如果 (熵系数 < 熵最小值) { 熵系数 = 熵最小值 }
}

函数 策略_设置熵系数(值) { 熵系数 = 值 }
函数 策略_获取熵系数() { 返回 熵系数 }

// GAE (广义优势估计)
// A_t = δ_t + (γλ)δ_{t+1} + (γλ)²δ_{t+2} + ...

定义 GAE_gamma = 990    // FP1000: 0.99
定义 GAE_lambda = 950   // FP1000: 0.95

函数 GAE_计算优势(奖励列表, 价值列表, 步数) {
    定义 可变 优势 = []
    定义 可变 i = 0
    当 (i < 步数) { 追加(优势, 0); i = i + 1 }
    定义 可变 gae = 0
    i = 步数 - 1
    当 (i >= 0) {
        定义 下一值 = 0
        如果 (i + 1 < 步数) { 下一值 = 价值列表[i + 1] }
        定义 delta = 奖励列表[i] + GAE_gamma * 下一值 / 1000 - 价值列表[i]
        gae = delta + GAE_gamma * GAE_lambda * gae / 1000000
        优势[i] = gae
        i = i - 1
    }
    返回 优势
}

函数 GAE_设置参数(gamma, lambda) {
    GAE_gamma = gamma
    GAE_lambda = lambda
}

// §5 Selection 接口

结构 Selection {
    // 锚点(选择开始位置)
    anchor节点,    // u64 节点*
    anchorOffset,
    // 焦点(选择结束位置, 可能在锚点前面)
    focus节点,
    focusOffset,
    // Range列表
    ranges,    // [8]u64 Range*
    rangeCount,
    // 类型
    类型,    // u8 0=None 1=Caret 2=Range
    // 方向
    方向,    // u8 0=forward 1=backward
}

定义 可变 全局Selection = 0

函数 Selection_获取() {
    如果 (全局Selection == 0) {
        全局Selection = 堆_分配(Selection)
        全局Selection.anchor节点 = 0; 全局Selection.focus节点 = 0
        全局Selection.rangeCount = 0; 全局Selection.类型 = 0
    }
    返回 全局Selection
}

函数 Selection_addRange(sel, range) {
    如果 (sel == 0 || range == 0 || sel.rangeCount >= 8) { 返回 }
    sel.ranges[sel.rangeCount] = range
    sel.rangeCount = sel.rangeCount + 1
    sel.anchor节点 = range.startContainer; sel.anchorOffset = range.startOffset
    sel.focus节点 = range.endContainer; sel.focusOffset = range.endOffset
    如果 (range.collapsed) { sel.类型 = 1 }    // Caret
    否则 { sel.类型 = 2 }                       // Range
}

函数 Selection_removeAllRanges(sel) {
    如果 (sel == 0) { 返回 }
    sel.rangeCount = 0; sel.anchor节点 = 0; sel.focus节点 = 0
    sel.类型 = 0
}

函数 Selection_removeRange(sel, range) {
    如果 (sel == 0 || range == 0) { 返回 }
    定义 可变 i = 0
    当 (i < sel.rangeCount) {
        如果 (sel.ranges[i] == range) {
            定义 可变 j = i
            当 (j < sel.rangeCount - 1) {
                sel.ranges[j] = sel.ranges[j + 1]
                j = j + 1
            }
            sel.rangeCount = sel.rangeCount - 1
            返回
        }
        i = i + 1
    }
}

函数 Selection_getRangeAt(sel, index) {
    如果 (sel == 0 || index >= sel.rangeCount) { 返回 0 }
    返回 sel.ranges[index]
}

函数 Selection_collapse(sel, 节点, offset) {
    如果 (sel == 0) { 返回 }
    Selection_removeAllRanges(sel)
    定义 r = Range_创建()
    Range_setStart(r, 节点, offset); Range_setEnd(r, 节点, offset)
    Selection_addRange(sel, r)
}

函数 Selection_extend(sel, 节点, offset) {
    如果 (sel == 0 || sel.rangeCount == 0) { 返回 }
    sel.focus节点 = 节点; sel.focusOffset = offset
    // 更新第一个range的终点
    定义 r = sel.ranges[0]
    如果 (r != 0) { Range_setEnd(r, 节点, offset) }
}

函数 Selection_selectAllChildren(sel, 节点) {
    如果 (sel == 0 || 节点 == 0) { 返回 }
    Selection_removeAllRanges(sel)
    定义 r = Range_创建()
    Range_select节点Contents(r, 节点)
    Selection_addRange(sel, r)
}

函数 Selection_toString(sel) {
    如果 (sel == 0 || sel.rangeCount == 0) { 返回 "" }
    返回 Range_toString(sel.ranges[0])
}

函数 Selection_isCollapsed(sel) {
    如果 (sel == 0 || sel.rangeCount == 0) { 返回 真 }
    返回 sel.类型 <= 1
}

// copy事件处理
函数 Selection_复制到剪贴板(sel) {
    如果 (sel == 0 || sel.rangeCount == 0) { 返回 }
    定义 文本 = Selection_toString(sel)
    如果 (文本 != 0) { Clipboard_writeText(文本) }
}

// cut事件处理
函数 Selection_剪切到剪贴板(sel) {
    如果 (sel == 0 || sel.rangeCount == 0) { 返回 }
    Selection_复制到剪贴板(sel)
    // 删除选中内容
    定义 r = sel.ranges[0]
    如果 (r != 0) { Range_deleteContents(r) }
}

//   1. 嵌入式空闲指针: 空闲对象内部存放next指针,零额外开销
//   2. per-CPU活跃Nova块缓存: 每个CPU有一个"当前Nova块缓存",分配免锁(cmpxchg)
//   3. partial链表: 部分满的Nova块缓存页挂在节点的partial链上
//   4. 三层分配路径: cpu_Nova块缓存快速→cpu_partial中速→节点_partial慢速→伙伴系统
//   5. 对象对齐: 按ARCH_KMALLOC_MINALIGN对齐,保证cache line效率
//   6. Nova块缓存页元数据: 复用struct page的字段(freelist/inuse/objects)
//   7. 红区/投毒: 调试模式下检测越界和use-after-free

导入("./类型定义.nova")
导入("./链表移到头部.nova")
导入("./同步原语.nova")
导入("./日志中枢.nova")
导入("./内核打印.nova")
导入("../推理/值乘.nova")
导入("./每核页释放.nova")
导入("./伙伴系统释放.nova")
导入("../感知/内核直连层.nova")
导入("./内存初始化.nova")

// 常量

// 页大小 定义在 核心/公共/类型定义.nova
定义 最小对齐 = 8              // ARCH_KMALLOC_MINALIGN
定义 缓存行大小 = 64           // L1 cache line
定义 最大Nova块缓存阶 = 1            // 每个Nova块缓存最多2页(8KB)
定义 最大对象大小 = 8192       // >8KB走伙伴系统

定义 KMALLOC_级别 = [8, 16, 32, 64, 96, 128, 192, 256, 512, 1024, 2048, 4096, 8192]
定义 KMALLOC_级别数 = 13

定义 Nova块缓存_HWCACHE_ALIGN = 0x0001   // 按cache line对齐
定义 Nova块缓存_POISON        = 0x0002   // 释放后填充毒药(0x6b)
定义 Nova块缓存_RED_ZONE      = 0x0004   // 对象前后加红区
定义 Nova块缓存_PANIC         = 0x0008   // 分配失败panic
定义 Nova块缓存_RECLAIM_ACCOUNT = 0x0010 // 可回收对象
定义 Nova块缓存_TYPESAFE_BY_RCU = 0x0020 // RCU延迟释放Nova块缓存页

定义 POISON_FREE  = 0x6B    // 释放后填充(Linux: POISON_FREE)
定义 POISON_ALLOC = 0x5A    // 分配前填充(Linux: POISON_INUSE)
定义 RED_ACTIVE   = 0xCC    // 红区标记(活跃)
定义 RED_INACTIVE  = 0xBB   // 红区标记(非活跃)

// Nova块缓存页元数据 

结构 Nova块缓存页 {
    空闲链,    // u64 freelist: 指向第一个空闲对象(嵌入式指针)
    已用数,    // u16 inuse: 当前已分配的对象数
    对象数,    // u16 objects: 本Nova块缓存能容纳的总对象数
    冻结,    // 布尔 frozen: 是否在cpu_Nova块缓存上(true=CPU私有,无需锁)
    页号,    // u64 底层物理页号
    虚拟基址,    // u64 Nova块缓存起始虚拟地址
    所属缓存,    // u64 指向kmem_cache的引用
    下一个,    // u64 partial链上的下一个Nova块缓存页
}

// per-CPU Nova块缓存 
// 分配时先从cpu_Nova块缓存取,无锁(因为CPU私有)

结构 CPU_Nova块缓存 {
    空闲链,    // u64 freelist: 当前活跃Nova块缓存的空闲对象头
    活跃Nova块缓存,    // Nova块缓存页 Nova块缓存: 当前正在分配的Nova块缓存页(frozen=true)
    partial,    // Nova块缓存页 cpu_partial: CPU私有的partial Nova块缓存链
    partial数,    // u32 CPU partial Nova块缓存数量
}

// 节点 partial链 
// 全局共享的部分满Nova块缓存链表,访问需加锁

结构 缓存节点 {
    partial链,    // 链表 部分满Nova块缓存页链表
    partial数,    // u64 nr_partial
    锁,    // 自旋锁 list_lock
}

// kmem_cache结构 

结构 kmem_cache {
    名称,
    对象大小,    // u32 object_size: 用户请求大小
    实际大小,    // u32 size: 含元数据的实际大小(对齐后)
    对齐,    // u32 align: 对齐要求
    空闲指针偏移,    // u32 offset: 嵌入空闲指针在对象内的偏移
    红区大小,    // u32 red_left_pad: 红区填充
    Nova块缓存阶,    // u8 oo的order部分: 分配几页做一个Nova块缓存
    每Nova块缓存对象数,    // u16 oo的objects部分
    最小partial,    // u32 min_partial: 节点上保留的最少partial Nova块缓存数
    标志,    // u32 flags: Nova块缓存_HWCACHE_ALIGN | Nova块缓存_POISON...
    引用计数,    // u32 refcount
    cpu缓存,    // CPU_Nova块缓存[] 每个CPU的本地缓存
    节点,    // 缓存节点 NUMA节点partial链
    总分配数,
    总释放数,
    总分配失败,
}

// NSMA理论 — Nova块分配内存架构 (Nova Slab Memory Architecture)
// 理论核心: 三层无锁分配 + 嵌入式空闲指针 + AI磎片预测
// 公式1: AllocCost = O(1) [cpu_slab快速路径] | O(k) [partial链]
// 公式2: FragRatio = (total_pages * PAGE_SIZE - inuse_bytes) / (total_pages * PAGE_SIZE)
// 公式3: AI_Shrink = sigmoid(frag_ratio * 10 - 5) > 0.5 → 触发回收

定义 可变 SLUB_总分配 = 0
定义 可变 SLUB_总释放 = 0
定义 可变 SLUB_总页数 = 0
定义 可变 SLUB_失败数 = 0
定义 可变 SLUB_活跃缓存数 = 0
定义 可变 kmalloc_缓存数组 = 数组_创建(KMALLOC_级别数, 空)

// §2 对齐辅助函数

函数 对齐向上(大小, 对齐值) {
    返回 (大小 + 对齐值 - 1) & (~(对齐值 - 1))
}

函数 计算对象布局(对象大小, 对齐, 标志) {
    可变 实际 = 对象大小
    // 红区填充
    如果 (标志 & Nova块缓存_RED_ZONE) {
        实际 = 实际 + 8  // 前红区8字节
    }
    // 对齐
    如果 (标志 & Nova块缓存_HWCACHE_ALIGN) {
        实际 = 对齐向上(实际, 缓存行大小)
    } 否则 {
        实际 = 对齐向上(实际, 对齐)
    }
    返回 实际
}

函数 计算每Nova块缓存对象数(实际大小, Nova块缓存阶) {
    定义 页大小 = 4096
    定义 总字节 = 页大小 << Nova块缓存阶
    如果 (实际大小 == 0) { 返回 0 }
    返回 总字节 / 实际大小
}

// §3 Nova块缓存创建

函数 kmem_cache_创建(名称, 对象大小, 对齐, 标志) {
    如果 (对象大小 > 最大对象大小) {
        内核打印("[SLUB] 对象大小超限: " + 对象大小)
        返回 空
    }
    如果 (对齐 < 最小对齐) { 对齐 = 最小对齐 }
    定义 实际 = 计算对象布局(对象大小, 对齐, 标志)
    定义 阶 = 0  // order0 = 1页
    如果 (实际 > 2048) { 阶 = 1 }
    定义 对象数 = 计算每Nova块缓存对象数(实际, 阶)
    定义 cache = kmem_cache {
        名称: 名称,
        对象大小: 对象大小,
        实际大小: 实际,
        对齐: 对齐,
        空闲指针偏移: 0,
        红区大小: 如果(标志 & Nova块缓存_RED_ZONE, 8, 0),
        Nova块缓存阶: 阶,
        每Nova块缓存对象数: 对象数,
        最小partial: 5,
        标志: 标志,
        引用计数: 1,
        cpu缓存: 空,
        节点: 缓存节点 {
            partial链: 空,
            partial数: 0,
            锁: 0,
        },
        总分配数: 0,
        总释放数: 0,
        总分配失败: 0,
    }
    SLUB_活跃缓存数 = SLUB_活跃缓存数 + 1
    返回 cache
}

// §4 Nova块缓存页创建与空闲链初始化

函数 Nova块缓存页_创建(cache) {
    定义 页大小 = 4096
    定义 总字节 = 页大小 << cache.Nova块缓存阶
    // 模拟伙伴系统分配物理页
    定义 基址 = 伙伴系统_分配(cache.Nova块缓存阶)
    如果 (基址 == 0) {
        SLUB_失败数 = SLUB_失败数 + 1
        返回 空
    }
    SLUB_总页数 = SLUB_总页数 + (1 << cache.Nova块缓存阶)
    // 初始化空闲链(嵌入式指针)
    可变 i = 0
    当 (i < cache.每Nova块缓存对象数 - 1) {
        定义 当前偏移 = 基址 + i * cache.实际大小
        定义 下一偏移 = 基址 + (i + 1) * cache.实际大小
        内存_写指针(当前偏移 + cache.空闲指针偏移, 下一偏移)
        i = i + 1
    }
    // 最后一个对象的next=0(链尾)
    定义 末偏移 = 基址 + (cache.每Nova块缓存对象数 - 1) * cache.实际大小
    内存_写指针(末偏移 + cache.空闲指针偏移, 0)
    // 投毒填充(调试模式)
    如果 (cache.标志 & Nova块缓存_POISON) {
        可变 j = 0
        当 (j < 总字节) {
            内存_写字节(基址 + j, POISON_FREE)
            j = j + 1
        }
    }
    定义 新页 = Nova块缓存页 {
        空闲链: 基址,
        已用数: 0,
        对象数: cache.每Nova块缓存对象数,
        冻结: 假,
        页号: 基址 / 页大小,
        虚拟基址: 基址,
        所属缓存: cache,
        下一个: 空,
    }
    返回 新页
}

// §5 分配路径 (三层)

// 快速路径: 从CPU本地空闲链取对象 O(1)
函数 SLUB_快速分配(cache) {
    定义 cpu = cache.cpu缓存
    如果 (cpu == 空) { 返回 空 }
    如果 (cpu.空闲链 == 0) { 返回 空 }
    // cmpxchg原子取空闲链头
    定义 对象 = cpu.空闲链
    定义 下一个 = 内存_读指针(对象 + cache.空闲指针偏移)
    cpu.空闲链 = 下一个
    如果 (cpu.活跃Nova块缓存 != 空) {
        cpu.活跃Nova块缓存.已用数 = cpu.活跃Nova块缓存.已用数 + 1
    }
    cache.总分配数 = cache.总分配数 + 1
    SLUB_总分配 = SLUB_总分配 + 1
    返回 对象
}

// 中速路径: 从CPU的partial链取一个Nova块缓存页提升为活跃
函数 SLUB_中速分配(cache) {
    定义 cpu = cache.cpu缓存
    如果 (cpu == 空) { 返回 空 }
    如果 (cpu.partial == 空) { 返回 空 }
    // 从CPU partial链头取一个Nova块缓存页
    定义 页 = cpu.partial
    cpu.partial = 页.下一个
    cpu.partial数 = cpu.partial数 - 1
    // 设为活跃Nova块缓存
    页.冻结 = 真
    cpu.活跃Nova块缓存 = 页
    cpu.空闲链 = 页.空闲链
    返回 SLUB_快速分配(cache)
}

// 慢速路径: 从节点partial或伙伴系统分配新页
函数 SLUB_慢速分配(cache) {
    // 尝试从节点partial链取
    如果 (cache.节点.partial数 > 0) {
        定义 页 = cache.节点.partial链
        如果 (页 != 空) {
            cache.节点.partial链 = 页.下一个
            cache.节点.partial数 = cache.节点.partial数 - 1
            页.冻结 = 真
            如果 (cache.cpu缓存 != 空) {
                cache.cpu缓存.活跃Nova块缓存 = 页
                cache.cpu缓存.空闲链 = 页.空闲链
            }
            返回 SLUB_快速分配(cache)
        }
    }
    // 伙伴系统分配新Nova块缓存页
    定义 新页 = Nova块缓存页_创建(cache)
    如果 (新页 == 空) {
        cache.总分配失败 = cache.总分配失败 + 1
        SLUB_失败数 = SLUB_失败数 + 1
        返回 空
    }
    新页.冻结 = 真
    如果 (cache.cpu缓存 != 空) {
        cache.cpu缓存.活跃Nova块缓存 = 新页
        cache.cpu缓存.空闲链 = 新页.空闲链
    }
    返回 SLUB_快速分配(cache)
}

// 统一分配入口
函数 SLUB_分配(cache) {
    如果 (cache == 空) { 返回 空 }
    // 层级尝试
    定义 对象 = SLUB_快速分配(cache)
    如果 (对象 != 空) { 返回 对象 }
    对象 = SLUB_中速分配(cache)
    如果 (对象 != 空) { 返回 对象 }
    返回 SLUB_慢速分配(cache)
}

// §6 释放路径

函数 SLUB_释放(cache, 对象地址) {
    如果 (cache == 空 || 对象地址 == 0) { 返回 }
    // 投毒填充
    如果 (cache.标志 & Nova块缓存_POISON) {
        可变 i = 0
        当 (i < cache.对象大小) {
            内存_写字节(对象地址 + i, POISON_FREE)
            i = i + 1
        }
    }
    // 将对象插入空闲链头
    定义 cpu = cache.cpu缓存
    如果 (cpu != 空) {
        内存_写指针(对象地址 + cache.空闲指针偏移, cpu.空闲链)
        cpu.空闲链 = 对象地址
        如果 (cpu.活跃Nova块缓存 != 空) {
            cpu.活跃Nova块缓存.已用数 = cpu.活跃Nova块缓存.已用数 - 1
            // 检查是否可以回收整页
            如果 (cpu.活跃Nova块缓存.已用数 == 0) {
                内核打印("[SLUB] 页完全空闲可回收: " + cpu.活跃Nova块缓存.页号)
            }
        }
    }
    cache.总释放数 = cache.总释放数 + 1
    SLUB_总释放 = SLUB_总释放 + 1
}

// §7 kmalloc/kfree 统一接口

函数 kmalloc_找级别(大小) {
    可变 i = 0
    当 (i < KMALLOC_级别数) {
        如果 (大小 <= KMALLOC_级别[i]) {
            返回 i
        }
        i = i + 1
    }
    返回 -1  // 超出范围
}

函数 kmalloc(大小) {
    如果 (大小 == 0) { 返回 空 }
    如果 (大小 > 最大对象大小) {
        // 大对象走伙伴系统
        返回 伙伴系统_分配_字节(大小)
    }
    定义 级 = kmalloc_找级别(大小)
    如果 (级 < 0) { 返回 空 }
    定义 cache = kmalloc_缓存数组[级]
    如果 (cache == 空) {
        // 懒创建
        cache = kmem_cache_创建(
            "kmalloc-" + KMALLOC_级别[级],
            KMALLOC_级别[级],
            最小对齐,
            Nova块缓存_HWCACHE_ALIGN
        )
        kmalloc_缓存数组[级] = cache
    }
    返回 SLUB_分配(cache)
}

函数 kfree(地址) {
    如果 (地址 == 0 || 地址 == 空) { 返回 }
    // 简化: 通过页号查找Nova块缓存页元数据获取cache
    定义 页号 = 地址 / 4096
    定义 cache = 查找页所属缓存(页号)
    如果 (cache != 空) {
        SLUB_释放(cache, 地址)
    }
}

// §8 AI磎片预测 (NSMA公式3)

函数 SLUB_计算磎片率() {
    如果 (SLUB_总页数 == 0) { 返回 0.0 }
    定义 总字节 = SLUB_总页数 * 4096
    定义 已用 = (SLUB_总分配 - SLUB_总释放) * 64  // 粗略估算
    如果 (已用 < 0) { 已用 = 0 }
    返回 (总字节 - 已用) * 100.0 / 总字节
}

函数 AI_内存磎片检测() {
    定义 磎片率 = SLUB_计算磎片率()
    定义 特征 = Tensor_创建(1, 5)
    Tensor_写(特征, 0, 0, 磎片率)
    Tensor_写(特征, 0, 1, SLUB_总分配 * 1.0)
    Tensor_写(特征, 0, 2, SLUB_总释放 * 1.0)
    Tensor_写(特征, 0, 3, SLUB_总页数 * 1.0)
    Tensor_写(特征, 0, 4, SLUB_失败数 * 1.0)
    定义 结果 = AI总线_推理("slab_frag_predict", 特征)
    可变 应回收 = 假
    如果 (结果 != 空) {
        定义 分数 = Tensor_读(结果, 0, 0)
        如果 (分数 > 0.5) { 应回收 = 真 }
        Tensor_释放(结果)
    }
    Tensor_释放(特征)
    返回 应回收
}

// §9 诊断与统计

函数 SLUB_诊断报告() {
    可变 报告 = "[NSMA诊断报告]\n"
    报告 = 报告 + "总分配: " + SLUB_总分配 + "\n"
    报告 = 报告 + "总释放: " + SLUB_总释放 + "\n"
    报告 = 报告 + "总页数: " + SLUB_总页数 + "\n"
    报告 = 报告 + "失败数: " + SLUB_失败数 + "\n"
    报告 = 报告 + "活跃缓存: " + SLUB_活跃缓存数 + "\n"
    报告 = 报告 + "磎片率: " + SLUB_计算磎片率() + "%\n"
    返回 报告
}

函数 SLUB_缓存诊断(cache) {
    如果 (cache == 空) { 返回 "空缓存\n" }
    可变 报告 = "[" + cache.名称 + "]\n"
    报告 = 报告 + "  对象大小: " + cache.对象大小 + "\n"
    报告 = 报告 + "  实际大小: " + cache.实际大小 + "\n"
    报告 = 报告 + "  每页对象: " + cache.每Nova块缓存对象数 + "\n"
    报告 = 报告 + "  总分配: " + cache.总分配数 + "\n"
    报告 = 报告 + "  总释放: " + cache.总释放数 + "\n"
    报告 = 报告 + "  分配失败: " + cache.总分配失败 + "\n"
    返回 报告
}

// §10 红区检测与收缩回收

函数 SLUB_红区检查(对象地址, cache) {
    如果 (!(cache.标志 & Nova块缓存_RED_ZONE)) { 返回 真 }
    // 检查前红区(8字节)
    定义 前红区 = 对象地址 - cache.红区大小
    可变 i = 0
    当 (i < cache.红区大小) {
        定义 v = 内存_读字节(前红区 + i)
        如果 (v != RED_ACTIVE) {
            内核打印("[SLUB] 红区越界检测! 地址=" + 对象地址 + " 偏移=" + i)
            返回 假
        }
        i = i + 1
    }
    返回 真
}

函数 SLUB_收缩(cache) {
    如果 (cache == 空) { 返回 0 }
    可变 回收数 = 0
    // 遍历节点partial链，回收完全空闲的页
    可变 前 = 空
    可变 当前 = cache.节点.partial链
    当 (当前 != 空) {
        定义 下 = 当前.下一个
        如果 (当前.已用数 == 0) {
            // 跳过此页
            如果 (前 == 空) {
                cache.节点.partial链 = 下
            } 否则 {
                前.下一个 = 下
            }
            cache.节点.partial数 = cache.节点.partial数 - 1
            // 归还伙伴系统
            伙伴系统_释放(当前.虚拟基址, cache.Nova块缓存阶)
            SLUB_总页数 = SLUB_总页数 - (1 << cache.Nova块缓存阶)
            回收数 = 回收数 + 1
        } 否则 {
            前 = 当前
        }
        当前 = 下
    }
    返回 回收数
}

函数 NSMA_AI诊断() {
    定义 特征 = Tensor_创建(1, 4)
    Tensor_写(特征, 0, 0, SLUB_计算磎片率())
    Tensor_写(特征, 0, 1, SLUB_活跃缓存数 * 1.0)
    Tensor_写(特征, 0, 2, (SLUB_总分配 - SLUB_总释放) * 1.0)
    Tensor_写(特征, 0, 3, SLUB_失败数 * 1.0)
    定义 结果 = AI总线_推理("nsma_health", 特征)
    如果 (结果 != 空) { Tensor_释放(结果) }
    Tensor_释放(特征)
}

// §12 【原生独创】谐振块分配碎片整理器
// 定期扫描空闲块并合并相邻碎片

定义 可变 _谐振碎片_合并次数 = 0
定义 可变 _谐振碎片_扫描次数 = 0

函数 谐振碎片_扫描合并(空闲链表, 最大扫描) {
    _谐振碎片_扫描次数 = _谐振碎片_扫描次数 + 1
    定义 可变 已合并 = 0
    定义 可变 当前 = 空闲链表
    定义 可变 扫描数 = 0
    当 (当前 != 0 && 扫描数 < 最大扫描) {
        定义 下一个 = 内存_读指针(当前 + 8)
        如果 (下一个 != 0) {
            定义 当前尾 = 当前 + 内存_读32(当前 + 4)
            如果 (当前尾 == 下一个) {
                // 相邻，可合并
                定义 新大小 = 内存_读32(当前 + 4) + 内存_读32(下一个 + 4)
                内存_写32(当前 + 4, 新大小)
                内存_写指针(当前 + 8, 内存_读指针(下一个 + 8))
                已合并 = 已合并 + 1
            }
        }
        当前 = 内存_读指针(当前 + 8)
        扫描数 = 扫描数 + 1
    }
    _谐振碎片_合并次数 = _谐振碎片_合并次数 + 已合并
    返回 已合并
}

函数 块分配器_完整统计() {
    返回 [
        "谐振碎片合并", _谐振碎片_合并次数,
        "谐振碎片扫描", _谐振碎片_扫描次数
    ]
}

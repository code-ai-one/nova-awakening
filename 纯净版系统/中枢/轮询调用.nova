// 完整统计 (≥15个指标)

函数 poll系统调用_完整统计() {
    定义 总操作 = poll_总次数 + select_总次数 + epoll_create_次数 + epoll_ctl_次数 + epoll_wait_次数
    定义 统计 = 字典()
    字典设(统计, "已初始化", 轮询_已初始化)
    字典设(统计, "poll次数", poll_总次数)
    字典设(统计, "select次数", select_总次数)
    字典设(统计, "epoll_create", epoll_create_次数)
    字典设(统计, "epoll_ctl", epoll_ctl_次数)
    字典设(统计, "epoll_wait", epoll_wait_次数)
    字典设(统计, "epoll就绪总数", epoll_就绪总数)
    字典设(统计, "总操作", 总操作)
    字典设(统计, "平均延迟(ns)", 轮询_平均延迟())
    字典设(统计, "最大延迟(ns)", 轮询_最大延迟)
    字典设(统计, "当前速率", 轮询_速率)
    字典设(统计, "峰值速率", 轮询_峰值速率)
    字典设(统计, "错误数", 轮询_错误数)
    字典设(统计, "延迟样本", 轮询_延迟样本)
    返回 统计
}

函数 poll系统调用_打印统计() {
    定义 统计 = poll系统调用_完整统计()
    打印("[轮询调用] ═══════ 完整统计 ═══════")
    打印("  poll:         " + 转字符串(字典取(统计, "poll次数")))
    打印("  select:       " + 转字符串(字典取(统计, "select次数")))
    打印("  epoll_create: " + 转字符串(字典取(统计, "epoll_create")))
    打印("  epoll_ctl:    " + 转字符串(字典取(统计, "epoll_ctl")))
    打印("  epoll_wait:   " + 转字符串(字典取(统计, "epoll_wait")))
    打印("  epoll就绪:    " + 转字符串(字典取(统计, "epoll就绪总数")))
    打印("  总操作:       " + 转字符串(字典取(统计, "总操作")))
    打印("  平均延迟:     " + 转字符串(字典取(统计, "平均延迟(ns)")) + "ns")
    打印("  最大延迟:     " + 转字符串(字典取(统计, "最大延迟(ns)")) + "ns")
    打印("  速率:         " + 转字符串(字典取(统计, "当前速率")) + " 次/秒")
    打印("  峰值速率:     " + 转字符串(字典取(统计, "峰值速率")) + " 次/秒")
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    打印("[轮询调用] ═════════════════════════")
    返回 0
}

函数 poll系统调用_dump() {
    打印("[轮询调用 dump] ──────────────────")
    打印("  已初始化: " + 转字符串(轮询_已初始化))
    打印("  poll: " + 转字符串(poll_总次数))
    打印("  select: " + 转字符串(select_总次数))
    打印("  epoll_create: " + 转字符串(epoll_create_次数))
    打印("  epoll_ctl: " + 转字符串(epoll_ctl_次数))
    打印("  epoll_wait: " + 转字符串(epoll_wait_次数))
    打印("  速率: " + 转字符串(轮询_速率))
    打印("  平均延迟: " + 转字符串(轮询_平均延迟()) + "ns")
    打印("  错误: " + 转字符串(轮询_错误数))
    打印("[轮询调用 dump] ──────────────────")
}

函数 poll系统调用_销毁() {
    如果 (轮询_已初始化 == 假) { 返回 0 }
    轮询_已初始化 = 假
    打印("[轮询调用] 已销毁")
    返回 0
}

函数 poll系统调用_为procfs提供统计() {
    返回 [poll_总次数, select_总次数, epoll_create_次数, epoll_ctl_次数, epoll_wait_次数, epoll_就绪总数, 轮询_速率]
}

函数 poll系统调用_为AI提供IO模式() {
    // 返回IO多路复用使用模式, 供AI优化建议
    返回 [poll_总次数, select_总次数, epoll_wait_次数, 轮询_平均延迟()]
}

函数 poll系统调用_为调度器提供IO负载() {
    返回 [轮询_速率, 轮询_峰值速率, epoll_wait_次数]
}

函数 poll系统调用_重置统计() {
    poll_总次数 = 0
    select_总次数 = 0
    epoll_create_次数 = 0
    epoll_ctl_次数 = 0
    epoll_wait_次数 = 0
    epoll_就绪总数 = 0
    轮询_错误数 = 0
    轮询_延迟总计 = 0
    轮询_延迟样本 = 0
    轮询_最大延迟 = 0
    轮询_速率 = 0
    轮询_速率窗口 = 0
    轮询_峰值速率 = 0
    打印("[轮询调用] 统计已重置")
    返回 0
}

// 桥接
函数 分配FD_轮询() { 返回 3 }
函数 读取纳秒_轮询() {
    定义 可变 值 = 0
    汇编 { "rdtsc" "shl rdx, 32" "or rax, rdx" "mov [rbp-8], rax" }
    返回 值
}
函数 获取当前信号掩码() {
    // 从当前进程描述符读取信号掩码(blocked signals bitmap)
    定义 当前 = 获取当前进程_调度()
    如果 (当前 == 空) { 返回 0 }
    返回 当前.信号掩码
}
函数 设置当前信号掩码(掩码) {
    定义 当前 = 获取当前进程_调度()
    如果 (当前 == 空) { 返回 }
    当前.信号掩码 = 掩码
    // SIGKILL(9)和SIGSTOP(19)不可屏蔽
    当前.信号掩码 = 当前.信号掩码 & ~(1 << 9) & ~(1 << 19)
}

函数 poll系统调用_为电源管理挂起() {
    打印("[poll] 挂起: 唤醒等待中的poll/epoll")
    返回 poll_总调用数
}

函数 poll系统调用_获取epoll使用率() {
    定义 总 = poll_总次数 + select_总次数 + epoll_wait_次数
    如果 (总 == 0) { 返回 0 }
    返回 epoll_wait_次数 * 100 / 总
}

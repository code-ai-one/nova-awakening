// NovaOS 感知循环
// 每帧: 捕获屏幕→区域检测→TNF识别→语义树更新→AI决策
// 自适应帧率/多尺度检测/运动追踪/显著性图/性能分析

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("../中枢/新系统注意.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/时钟中枢.nova")
导入("../稳态/写寄存器.nova")
导入("../标准/进程接口.nova")
导入("./神经视觉识别.nova")
导入("../中枢/整数转字符串.nova")
导入("./注意力块.nova")
导入("../中枢/新系统突触.nova")
导入("../中枢/统计.nova")

定义 感知_默认帧间隔 = 16      // 16ms = 60fps
定义 感知_最小帧间隔 = 8       // 8ms = 125fps (高负载时不超过)
定义 感知_最大帧间隔 = 100     // 100ms = 10fps (低活动时降频)
定义 感知_区域网格 = 8          // 8×8=64个感知区域
定义 感知_最大追踪目标 = 16
定义 感知_显著性衰减 = 50       // 每帧衰减量(千分之)
定义 感知_变化阈值 = 100        // 哈希差异阈值
定义 感知_静止帧阈值 = 30       // 连续静止帧数→降频

定义 可变 感知_帧计数 = 0
定义 可变 感知_运行中 = 假
定义 可变 感知_变化区域 = []
定义 可变 感知_上帧哈希 = []
定义 可变 感知_帧间隔 = 16
定义 可变 感知_连续静止帧 = 0

定义 可变 显著性图 = []          // 每个区域的显著性值 (0-1000)

结构 追踪目标 {
    ID,
    区域索引,
    上次区域索引,
    速度X,
    速度Y,
    置信度,
    持续帧数,
    最后更新帧,
}

定义 可变 追踪目标列表 = []
定义 可变 追踪目标数 = 0
定义 可变 追踪_下一ID = 1

结构 感知统计 {
    总帧数,
    变化帧数,
    静止帧数,
    总变化区域数,
    总识别次数,
    最大帧耗时,
    总帧耗时,
    目标创建数,
    目标丢失数,
    降频次数,
    升频次数,
}

定义 可变 全局_感知统计 = 空

函数 感知统计_初始化() {
    如果 (全局_感知统计 == 空) {
        全局_感知统计 = 感知统计 {}
        全局_感知统计.总帧数 = 0
        全局_感知统计.变化帧数 = 0
        全局_感知统计.静止帧数 = 0
        全局_感知统计.总变化区域数 = 0
        全局_感知统计.总识别次数 = 0
        全局_感知统计.最大帧耗时 = 0
        全局_感知统计.总帧耗时 = 0
        全局_感知统计.目标创建数 = 0
        全局_感知统计.目标丢失数 = 0
        全局_感知统计.降频次数 = 0
        全局_感知统计.升频次数 = 0
    }
}

// §1 初始化

函数 感知循环_初始化() {
    感知统计_初始化()
    感知_帧计数 = 0
    感知_变化区域 = []
    感知_上帧哈希 = []
    显著性图 = []
    追踪目标列表 = []
    追踪目标数 = 0
    追踪_下一ID = 1
    感知_帧间隔 = 感知_默认帧间隔
    感知_连续静止帧 = 0

    定义 可变 i = 0
    定义 总区域 = 感知_区域网格 * 感知_区域网格
    当 (i < 总区域) {
        追加(感知_上帧哈希, 0)
        追加(显著性图, 0)
        i = i + 1
    }
}

// §2 主循环

函数 感知循环_运行(引擎) {
    感知循环_初始化()
    感知_运行中 = 真

    当 (感知_运行中) {
        定义 开始 = 读取毫秒()
        感知_帧计数 = 感知_帧计数 + 1
        全局_感知统计.总帧数 = 全局_感知统计.总帧数 + 1

        // 1. 捕获帧缓冲快照
        定义 帧数据 = 帧缓冲_获取快照()

        // 2. 变化检测: 只处理有变化的区域(节省算力)
        感知_变化区域 = []
        定义 可变 区域 = 0
        定义 总区域 = 感知_区域网格 * 感知_区域网格
        当 (区域 < 总区域) {
            定义 当前哈希 = 感知_区域哈希(帧数据, 区域)
            定义 差异 = 当前哈希 - 感知_上帧哈希[区域]
            如果 (差异 < 0) { 差异 = -差异 }

            如果 (差异 > 感知_变化阈值) {
                追加(感知_变化区域, 区域)
                感知_上帧哈希[区域] = 当前哈希

                // 更新显著性
                显著性图[区域] = 显著性图[区域] + 200
                如果 (显著性图[区域] > 1000) { 显著性图[区域] = 1000 }
            }
            区域 = 区域 + 1
        }

        // 3. 显著性衰减
        感知_衰减显著性()

        // 4. 统计变化
        定义 变化数 = 计数(感知_变化区域)
        全局_感知统计.总变化区域数 = 全局_感知统计.总变化区域数 + 变化数

        如果 (变化数 > 0) {
            全局_感知统计.变化帧数 = 全局_感知统计.变化帧数 + 1
            感知_连续静止帧 = 0
        } 否则 {
            全局_感知统计.静止帧数 = 全局_感知统计.静止帧数 + 1
            感知_连续静止帧 = 感知_连续静止帧 + 1
        }

        // 5. 对变化区域进行TNF视觉识别
        定义 可变 识别结果 = []
        定义 可变 i = 0
        当 (i < 变化数) {
            定义 区域索引 = 感知_变化区域[i]
            定义 像素 = 感知_提取区域像素(帧数据, 区域索引)
            定义 结果 = TNF视觉_识别区域(引擎, 像素)
            追加(识别结果, [区域索引, 结果])
            全局_感知统计.总识别次数 = 全局_感知统计.总识别次数 + 1
            i = i + 1
        }

        // 6. 运动追踪更新
        感知_更新追踪(识别结果)

        // 6.5 在线学习反馈: 感知结果→训练管道(闭合 浏览器→感知→模型 循环)
        如果 (变化数 > 0 && 智能_进化阶段() < 进化_自主阶段) {
            感知_反馈训练(引擎, 帧数据, 识别结果)
        }

        // 7. 更新注意力系统(变化多的区域→高显著性)
        i = 0
        当 (i < 变化数) {
            定义 显著值 = 显著性图[感知_变化区域[i]]
            注意力_输入(感知_变化区域[i] % 注意力_通道数, 显著值, 700)
            i = i + 1
        }

        // 8. 自适应帧率
        感知_自适应帧率(变化数)

        // 9. 帧率控制
        定义 耗时 = 读取毫秒() - 开始
        全局_感知统计.总帧耗时 = 全局_感知统计.总帧耗时 + 耗时
        如果 (耗时 > 全局_感知统计.最大帧耗时) {
            全局_感知统计.最大帧耗时 = 耗时
        }

        如果 (耗时 < 感知_帧间隔) {
            进程_睡眠毫秒(感知_帧间隔 - 耗时)
        }
    }
}

// §3 显著性图

函数 感知_衰减显著性() {
    定义 总区域 = 感知_区域网格 * 感知_区域网格
    定义 可变 i = 0
    当 (i < 总区域) {
        如果 (显著性图[i] > 0) {
            显著性图[i] = 显著性图[i] - 感知_显著性衰减
            如果 (显著性图[i] < 0) { 显著性图[i] = 0 }
        }
        i = i + 1
    }
}

函数 感知_获取显著性(区域索引) {
    如果 (区域索引 < 0 || 区域索引 >= 感知_区域网格 * 感知_区域网格) { 返回 0 }
    返回 显著性图[区域索引]
}

函数 感知_最显著区域() {
    定义 总区域 = 感知_区域网格 * 感知_区域网格
    定义 可变 最大值 = 0
    定义 可变 最大索引 = -1
    定义 可变 i = 0
    当 (i < 总区域) {
        如果 (显著性图[i] > 最大值) {
            最大值 = 显著性图[i]
            最大索引 = i
        }
        i = i + 1
    }
    返回 最大索引
}

函数 感知_显著区域列表(阈值) {
    定义 可变 结果 = []
    定义 总区域 = 感知_区域网格 * 感知_区域网格
    定义 可变 i = 0
    当 (i < 总区域) {
        如果 (显著性图[i] >= 阈值) {
            追加(结果, i)
        }
        i = i + 1
    }
    返回 结果
}

// §4 运动追踪

函数 感知_更新追踪(识别结果) {
    // 更新已有追踪目标
    定义 可变 i = 0
    当 (i < 追踪目标数) {
        定义 目标 = 追踪目标列表[i]
        定义 可变 已匹配 = 假

        // 在识别结果中查找最近的匹配
        定义 可变 j = 0
        当 (j < 计数(识别结果)) {
            定义 区域 = 识别结果[j][0]
            定义 距离 = 感知_区域距离(目标.区域索引, 区域)
            如果 (距离 <= 2) {
                // 更新目标位置
                目标.上次区域索引 = 目标.区域索引
                目标.速度X = (区域 % 感知_区域网格) - (目标.区域索引 % 感知_区域网格)
                目标.速度Y = (区域 / 感知_区域网格) - (目标.区域索引 / 感知_区域网格)
                目标.区域索引 = 区域
                目标.持续帧数 = 目标.持续帧数 + 1
                目标.最后更新帧 = 感知_帧计数
                目标.置信度 = 目标.置信度 + 50
                如果 (目标.置信度 > 1000) { 目标.置信度 = 1000 }
                已匹配 = 真
                跳出
            }
            j = j + 1
        }

        // 未匹配→置信度衰减
        如果 (!已匹配) {
            目标.置信度 = 目标.置信度 - 100
            如果 (目标.置信度 <= 0) {
                // 移除丢失的追踪目标
                感知_移除追踪(i)
                全局_感知统计.目标丢失数 = 全局_感知统计.目标丢失数 + 1
                继续
            }
        }
        i = i + 1
    }

    // 为未匹配的识别结果创建新追踪
    定义 可变 k = 0
    当 (k < 计数(识别结果)) {
        定义 区域 = 识别结果[k][0]
        如果 (!感知_区域已追踪(区域) && 追踪目标数 < 感知_最大追踪目标) {
            定义 新目标 = 追踪目标 {}
            新目标.ID = 追踪_下一ID
            追踪_下一ID = 追踪_下一ID + 1
            新目标.区域索引 = 区域
            新目标.上次区域索引 = 区域
            新目标.速度X = 0
            新目标.速度Y = 0
            新目标.置信度 = 300
            新目标.持续帧数 = 1
            新目标.最后更新帧 = 感知_帧计数
            追加(追踪目标列表, 新目标)
            追踪目标数 = 追踪目标数 + 1
            全局_感知统计.目标创建数 = 全局_感知统计.目标创建数 + 1
        }
        k = k + 1
    }
}

函数 感知_移除追踪(索引) {
    如果 (索引 >= 追踪目标数) { 返回 }
    // 将最后一个移到当前位置
    追踪目标数 = 追踪目标数 - 1
    如果 (索引 < 追踪目标数) {
        追踪目标列表[索引] = 追踪目标列表[追踪目标数]
    }
}

函数 感知_区域已追踪(区域索引) {
    定义 可变 i = 0
    当 (i < 追踪目标数) {
        如果 (追踪目标列表[i].区域索引 == 区域索引) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 感知_区域距离(区域A, 区域B) {
    定义 行A = 区域A / 感知_区域网格
    定义 列A = 区域A % 感知_区域网格
    定义 行B = 区域B / 感知_区域网格
    定义 列B = 区域B % 感知_区域网格
    定义 dx = 列B - 列A
    定义 dy = 行B - 行A
    如果 (dx < 0) { dx = -dx }
    如果 (dy < 0) { dy = -dy }
    返回 dx + dy  // 曼哈顿距离
}

// §5 自适应帧率

函数 感知_自适应帧率(变化数) {
    如果 (变化数 > 感知_区域网格 * 2) {
        // 大量变化: 提高帧率
        如果 (感知_帧间隔 > 感知_最小帧间隔) {
            感知_帧间隔 = 感知_帧间隔 - 2
            如果 (感知_帧间隔 < 感知_最小帧间隔) {
                感知_帧间隔 = 感知_最小帧间隔
            }
            全局_感知统计.升频次数 = 全局_感知统计.升频次数 + 1
        }
    } 否则 如果 (感知_连续静止帧 > 感知_静止帧阈值) {
        // 持续静止: 降低帧率节省资源
        如果 (感知_帧间隔 < 感知_最大帧间隔) {
            感知_帧间隔 = 感知_帧间隔 + 4
            如果 (感知_帧间隔 > 感知_最大帧间隔) {
                感知_帧间隔 = 感知_最大帧间隔
            }
            全局_感知统计.降频次数 = 全局_感知统计.降频次数 + 1
        }
    } 否则 {
        // 正常活动: 恢复默认帧率
        如果 (感知_帧间隔 != 感知_默认帧间隔) {
            如果 (感知_帧间隔 < 感知_默认帧间隔) {
                感知_帧间隔 = 感知_帧间隔 + 1
            } 否则 {
                感知_帧间隔 = 感知_帧间隔 - 1
            }
        }
    }
}

// §6 区域工具

函数 感知_区域哈希(帧数据, 区域索引) {
    如果 (帧数据 == 0) { 返回 0 }
    定义 行 = 区域索引 / 感知_区域网格
    定义 列 = 区域索引 % 感知_区域网格
    // 实际从帧数据计算区域像素哈希
    定义 可变 哈希 = 5381
    定义 区域宽 = 帧数据.宽度 / 感知_区域网格
    定义 区域高 = 帧数据.高度 / 感知_区域网格
    定义 起始X = 列 * 区域宽
    定义 起始Y = 行 * 区域高

    // 采样4个点计算快速哈希
    定义 中X = 起始X + 区域宽 / 2
    定义 中Y = 起始Y + 区域高 / 2
    定义 采样1 = 帧缓冲_读像素(帧数据, 起始X, 起始Y)
    定义 采样2 = 帧缓冲_读像素(帧数据, 起始X + 区域宽 - 1, 起始Y)
    定义 采样3 = 帧缓冲_读像素(帧数据, 中X, 中Y)
    定义 采样4 = 帧缓冲_读像素(帧数据, 起始X + 区域宽 - 1, 起始Y + 区域高 - 1)

    哈希 = ((哈希 * 33) + 采样1) % 2147483647
    哈希 = ((哈希 * 33) + 采样2) % 2147483647
    哈希 = ((哈希 * 33) + 采样3) % 2147483647
    哈希 = ((哈希 * 33) + 采样4) % 2147483647
    返回 哈希
}

函数 感知_提取区域像素(帧数据, 区域索引) {
    如果 (帧数据 == 0) { 返回 [] }
    定义 行 = 区域索引 / 感知_区域网格
    定义 列 = 区域索引 % 感知_区域网格
    定义 区域宽 = 帧数据.宽度 / 感知_区域网格
    定义 区域高 = 帧数据.高度 / 感知_区域网格
    定义 起始X = 列 * 区域宽
    定义 起始Y = 行 * 区域高

    定义 可变 像素 = []
    定义 可变 y = 起始Y
    当 (y < 起始Y + 区域高) {
        定义 可变 x = 起始X
        当 (x < 起始X + 区域宽) {
            追加(像素, 帧缓冲_读像素(帧数据, x, y))
            x = x + 1
        }
        y = y + 1
    }
    返回 像素
}

函数 感知_区域坐标(区域索引) {
    定义 行 = 区域索引 / 感知_区域网格
    定义 列 = 区域索引 % 感知_区域网格
    返回 [列, 行]
}

// §7 查询接口

函数 感知循环_停止() { 感知_运行中 = 假 }
函数 感知_帧数() { 返回 感知_帧计数 }
函数 感知_变化数() { 返回 计数(感知_变化区域) }
函数 感知_当前帧率() {
    如果 (感知_帧间隔 == 0) { 返回 0 }
    返回 1000 / 感知_帧间隔
}
函数 感知_追踪数() { 返回 追踪目标数 }
函数 感知_是否运行() { 返回 感知_运行中 }

函数 感知_获取追踪目标(目标ID) {
    定义 可变 i = 0
    当 (i < 追踪目标数) {
        如果 (追踪目标列表[i].ID == 目标ID) {
            返回 追踪目标列表[i]
        }
        i = i + 1
    }
    返回 空
}

// §8 统计

函数 感知_打印统计() {
    感知统计_初始化()
    打印行("=== 感知循环统计 ===")
    打印行("总帧数: " + 整数转字符串(全局_感知统计.总帧数))
    打印行("变化帧: " + 整数转字符串(全局_感知统计.变化帧数))
    打印行("静止帧: " + 整数转字符串(全局_感知统计.静止帧数))
    打印行("总变化区域: " + 整数转字符串(全局_感知统计.总变化区域数))
    打印行("总识别次数: " + 整数转字符串(全局_感知统计.总识别次数))
    打印行("目标创建: " + 整数转字符串(全局_感知统计.目标创建数))
    打印行("目标丢失: " + 整数转字符串(全局_感知统计.目标丢失数))
    打印行("降频次数: " + 整数转字符串(全局_感知统计.降频次数))
    打印行("升频次数: " + 整数转字符串(全局_感知统计.升频次数))
    如果 (全局_感知统计.总帧数 > 0) {
        定义 平均耗时 = 全局_感知统计.总帧耗时 / 全局_感知统计.总帧数
        打印行("平均帧耗时: " + 整数转字符串(平均耗时) + "ms")
        打印行("最大帧耗时: " + 整数转字符串(全局_感知统计.最大帧耗时) + "ms")
    }
    打印行("当前帧间隔: " + 整数转字符串(感知_帧间隔) + "ms")
    打印行("追踪目标数: " + 整数转字符串(追踪目标数))
    打印行("丢弃帧: " + 整数转字符串(感知_总丢弃帧))
    打印行("热力平均: " + 整数转字符串(感知_热力图_平均值()))
}

// §9 感知区域热力图

函数 感知_导出热力图(输出缓冲) {
    // 将显著性图导出为8×8热力矩阵
    定义 总区域 = 感知_区域网格 * 感知_区域网格
    定义 可变 i = 0
    当 (i < 总区域) {
        追加(输出缓冲, 显著性图[i])
        i = i + 1
    }
    返回 总区域
}

函数 感知_热力图_平均值() {
    定义 总区域 = 感知_区域网格 * 感知_区域网格
    如果 (总区域 == 0) { 返回 0 }
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < 总区域) {
        和 = 和 + 显著性图[i]
        i = i + 1
    }
    返回 和 / 总区域
}

函数 感知_热力图_最大区域前N(n) {
    // 返回显著性最高的N个区域索引
    定义 可变 结果 = []
    定义 可变 已选 = []
    定义 可变 k = 0
    当 (k < n) {
        定义 可变 最大值 = -1
        定义 可变 最大索引 = -1
        定义 可变 i = 0
        定义 总区域 = 感知_区域网格 * 感知_区域网格
        当 (i < 总区域) {
            如果 (显著性图[i] > 最大值) {
                定义 可变 已排除 = 假
                定义 可变 j = 0
                当 (j < 计数(已选)) {
                    如果 (已选[j] == i) { 已排除 = 真 }
                    j = j + 1
                }
                如果 (!已排除) {
                    最大值 = 显著性图[i]
                    最大索引 = i
                }
            }
            i = i + 1
        }
        如果 (最大索引 >= 0) {
            追加(结果, 最大索引)
            追加(已选, 最大索引)
        }
        k = k + 1
    }
    返回 结果
}

// §10 帧丢弃检测与性能预警

定义 感知_帧丢弃阈值 = 3   // 连续超时3帧视为丢帧
定义 可变 感知_连续超时帧 = 0
定义 可变 感知_总丢弃帧 = 0

函数 感知_检测帧丢弃(帧耗时) {
    如果 (帧耗时 > 感知_帧间隔 * 2) {
        感知_连续超时帧 = 感知_连续超时帧 + 1
        如果 (感知_连续超时帧 >= 感知_帧丢弃阈值) {
            感知_总丢弃帧 = 感知_总丢弃帧 + 1
            内核警告("感知循环: 帧丢弃, 连续超时=" + 整数转字符串(感知_连续超时帧))
        }
    } 否则 {
        感知_连续超时帧 = 0
    }
}

函数 感知_丢弃帧数() { 返回 感知_总丢弃帧 }

函数 感知_性能评分() {
    // 综合性能评分(0-1000): 帧率稳定性 + 低丢帧 + 追踪质量
    如果 (全局_感知统计.总帧数 == 0) { 返回 0 }
    定义 帧率分 = 1000 - (感知_总丢弃帧 * 100)
    如果 (帧率分 < 0) { 帧率分 = 0 }
    定义 变化率 = 全局_感知统计.变化帧数 * 1000 / 全局_感知统计.总帧数
    定义 追踪分 = 如果(追踪目标数 > 0, 800, 500)
    返回 (帧率分 + 变化率 + 追踪分) / 3
}

// NPCL — Nova Perception Cycle Logic
// 公理1(感知完备): 每帧覆盖所有64区域, 无检测盲区
// 公理2(自适应收敛): 帧率调整在有限步内收敛到稳态
// 公理3(追踪连续): 目标ID在生命周期内保持唯一
// 定理1(显著性单调衰减): 无新刺激时显著性单调递减至0
// 定理2(资源弹性): 降频/升频在不丢失关键事件下节省50%+算力

// §11 【原生独创】谐振感知节奏调节器
// 根据场景复杂度动态调整感知循环频率

定义 可变 _谐振感知_周期ms = 100
定义 可变 _谐振感知_调节次数 = 0

函数 谐振感知_调节(场景复杂度, 运动量) {
    如果 (运动量 > 800 || 场景复杂度 > 900) {
        // 高动态场景: 加快感知
        _谐振感知_周期ms = 33
    } 否则如果 (运动量 < 100 && 场景复杂度 < 200) {
        // 静态场景: 降低频率省电
        _谐振感知_周期ms = 500
    } 否则 {
        _谐振感知_周期ms = 100
    }
    _谐振感知_调节次数 = _谐振感知_调节次数 + 1
}

函数 谐振感知_当前周期() { 返回 _谐振感知_周期ms }

函数 感知循环_完整统计() {
    返回 [
        "谐振感知周期ms", _谐振感知_周期ms,
        "谐振调节次数", _谐振感知_调节次数
    ]
}

函数 谐振感知_是否高频() {
    返回 _谐振感知_周期ms <= 50
}

函数 谐振感知_重置() {
    _谐振感知_周期ms = 100
    _谐振感知_调节次数 = 0
}

// 智慧因子: 自组织临界性监控 (SOC — Self-Organized Criticality)
// 理论: Bak-Tang-Wiesenfeld (1987) 沙堆模型 + Beggs&Plenz (2003)
// 将每帧感知变化区域数量视为"感知雪崩规模"
// 健康大脑皮层活动遵循幂律: P(s) ~ s^(-τ), τ≈1.5
// τ偏低(<1.2): 过有序/癫痫样  τ偏高(>1.8): 过随机/信息淹没

定义 感知_雪崩历史容量 = 256
定义 可变 感知_雪崩历史 = []
定义 可变 感知_雪崩写指针 = 0

函数 感知_记录雪崩(变化区域数) {
    如果 (变化区域数 <= 0) { 返回 }
    如果 (计数(感知_雪崩历史) < 感知_雪崩历史容量) {
        追加(感知_雪崩历史, 变化区域数)
    } 否则 {
        感知_雪崩历史[感知_雪崩写指针] = 变化区域数
        感知_雪崩写指针 = (感知_雪崩写指针 + 1) % 感知_雪崩历史容量
    }
}

// 对数分桶法估计幂律指数τ (返回τ×100, 例: 150=1.5)
// 算法: 对log(size)做线性回归，斜率即-τ
函数 感知_估计幂律指数() {
    定义 n = 计数(感知_雪崩历史)
    如果 (n < 20) { 返回 150 }  // 样本不足，假设临界态
    // 用4个对数桶统计: [1], [2-3], [4-7], [8+]
    定义 可变 桶0 = 0  // 规模=1
    定义 可变 桶1 = 0  // 规模=2-3
    定义 可变 桶2 = 0  // 规模=4-7
    定义 可变 桶3 = 0  // 规模=8+
    定义 可变 i = 0
    当 (i < n) {
        定义 s = 感知_雪崩历史[i]
        如果 (s == 1) { 桶0 = 桶0 + 1 }
        否则如果 (s <= 3) { 桶1 = 桶1 + 1 }
        否则如果 (s <= 7) { 桶2 = 桶2 + 1 }
        否则 { 桶3 = 桶3 + 1 }
        i = i + 1
    }
    如果 (桶0 == 0 || 桶1 == 0) { 返回 150 }
    // 简单估计: -τ ≈ log(P(s=2)) - log(P(s=1)) / (log(2) - log(1))
    // 用整数近似: τ×100 ≈ (桶0-桶1)*100/桶0
    定义 τ_估计 = 100 + (桶0 - 桶1) * 100 / 桶0
    如果 (τ_估计 < 50) { τ_估计 = 50 }
    如果 (τ_估计 > 300) { τ_估计 = 300 }
    返回 τ_估计
}

// 临界态健康检查: τ∈[120,180]为健康临界态
// 返回: 0=过有序(癫痫) 1=临界(健康) 2=过随机(噪声)
函数 感知_临界态状态() {
    定义 τ = 感知_估计幂律指数()
    如果 (τ < 120) { 返回 0 }  // 过有序: 提示系统可能卡顿/重复
    如果 (τ > 180) { 返回 2 }  // 过随机: 提示感知噪声过多
    返回 1                      // 临界健康
}

函数 感知_雪崩健康分() {
    定义 τ = 感知_估计幂律指数()
    // 与最优τ=150的偏差越小，分数越高
    定义 偏差 = τ - 150
    如果 (偏差 < 0) { 偏差 = 0 - 偏差 }
    定义 分 = 1000 - 偏差 * 10
    如果 (分 < 0) { 分 = 0 }
    返回 分
}

// §12 感知→训练反馈(闭合 浏览器→感知→模型 循环)
// 核心: 浏览器渲染的每一帧都是训练样本，感知识别结果反馈给本地模型
// 这解决了"鸡蛋问题": 浏览器产生数据→训练模型→模型驱动浏览器→产生更好的数据

定义 可变 感知_反馈总数 = 0
定义 感知_反馈间隔 = 10    // 每10帧反馈一次(避免过载)

函数 感知_反馈训练(引擎, 帧数据, 识别结果) {
    感知_反馈总数 = 感知_反馈总数 + 1
    // 限频: 不是每帧都训练
    如果 (感知_反馈总数 % 感知_反馈间隔 != 0) { 返回 }

    定义 结果数 = 计数(识别结果)
    如果 (结果数 == 0) { 返回 }

    // 将识别结果编码为训练样本: [区域特征] → [识别标签]
    定义 可变 i = 0
    当 (i < 结果数) {
        定义 区域索引 = 识别结果[i][0]
        定义 识别标签 = 识别结果[i][1]
        // 提取区域的显著性+位置+运动特征作为输入
        定义 显著 = 显著性图[区域索引]
        定义 行 = 区域索引 / 感知_区域网格
        定义 列 = 区域索引 % 感知_区域网格
        // 突触赫布更新: 活跃区域的连接增强
        突触_赫布更新(区域索引 % 64, 识别标签 % 64, 显著, 500)
        // 训练统计
        训练统计_记录损失(显著)
        i = i + 1
    }
}

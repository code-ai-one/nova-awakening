// 思维链推理引擎 (Chain-of-Thought) — 类人多步骤分解推理
// 核心: 将复杂问题分解为多个子步骤，逐步推导，每步可验证可回溯
// 与Transformer的区别: 不是一次性生成答案，而是模拟人类思考过程
//   步骤1→验证→步骤2→验证→...→综合→最终答案
// 架构:
//   问题分析 → 步骤规划 → 逐步执行 → 中间验证 → 结果综合 → 置信度评估

导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("./智能总线初始.nova")
导入("./语义嵌入.nova")
导入("./值乘.nova")
导入("./记忆管理.nova")
导入("./通信总线.nova")
导入("../记忆/接口.nova")
导入("../中枢/接口.nova")
导入("./智能总线桥.nova")

// §1 思维链数据结构

定义 最大思维步骤 = 32
定义 最大回溯深度 = 8
定义 置信度阈值 = 700       // 千分制，低于此需要回溯

结构 思维步骤 {
    编号,
    描述,
    输入,
    输出,
    置信度,           // 0-1000
    耗时纳秒,
    依赖步骤,         // 前置步骤编号列表
    验证通过,
    回溯次数,
}

结构 思维链 {
    问题,
    步骤列表,
    步骤数,
    当前步骤,
    总置信度,
    最终答案,
    状态,             // 0=规划中 1=执行中 2=验证中 3=完成 4=失败
    回溯总数,
    开始时间,
}

定义 可变 思维链_总推理数 = 0
定义 可变 思维链_总步骤数 = 0
定义 可变 思维链_总回溯数 = 0
定义 可变 思维链_成功数 = 0
定义 可变 思维链_失败数 = 0
定义 可变 思维链_平均步骤 = 0
定义 可变 思维链_平均置信 = 0

// §2 思维链创建与规划

函数 思维链_创建(问题) {
    定义 链 = 堆_分配(思维链)
    如果 (链 == 0) { 返回 0 }
    链.问题 = 问题
    链.步骤列表 = 堆_分配_数组(思维步骤, 最大思维步骤)
    链.步骤数 = 0
    链.当前步骤 = 0
    链.总置信度 = 1000
    链.状态 = 0
    链.回溯总数 = 0
    链.开始时间 = 中枢_当前时间纳秒()
    思维链_总推理数 = 思维链_总推理数 + 1
    返回 链
}

函数 思维链_添加步骤(链, 描述, 依赖) {
    如果 (链 == 0 || 链.步骤数 >= 最大思维步骤) { 返回 -1 }
    定义 步 = 链.步骤列表 + 链.步骤数 * 72
    内存_写64(步, 链.步骤数)           // 编号
    内存_写64(步 + 8, 描述)            // 描述
    内存_写64(步 + 32, 0)              // 置信度(待计算)
    内存_写64(步 + 48, 依赖)           // 依赖步骤
    内存_写64(步 + 56, 假)             // 验证通过
    内存_写64(步 + 64, 0)              // 回溯次数
    链.步骤数 = 链.步骤数 + 1
    思维链_总步骤数 = 思维链_总步骤数 + 1
    返回 链.步骤数 - 1
}

// §3 逐步执行与验证

函数 思维链_执行下一步(链) {
    如果 (链 == 0 || 链.当前步骤 >= 链.步骤数) { 返回 -1 }
    链.状态 = 1  // 执行中

    定义 步 = 链.步骤列表 + 链.当前步骤 * 72
    定义 描述 = 内存_读64(步 + 8)
    定义 开始 = 中枢_当前时间纳秒()

    // 调用AI总线推理
    定义 输入嵌入 = 语义嵌入_编码(描述)
    如果 (输入嵌入 == 0) {
        链.状态 = 4
        思维链_失败数 = 思维链_失败数 + 1
        返回 -1
    }
    定义 结果 = AI总线_tick(输入嵌入)
    如果 (结果 == 0) { 结果 = Tensor_克隆(输入嵌入) }
    如果 (结果 == 0) {
        Tensor_释放(输入嵌入)
        链.状态 = 4
        思维链_失败数 = 思维链_失败数 + 1
        返回 -1
    }
    Tensor_释放(输入嵌入)

    定义 耗时 = 中枢_当前时间纳秒() - 开始
    内存_写64(步 + 24, 结果)           // 输出
    内存_写64(步 + 40, 耗时)           // 耗时

    // 计算该步骤置信度
    定义 置信 = 思维链_评估置信度(链, 链.当前步骤, 结果)
    内存_写64(步 + 32, 置信)

    // 验证
    如果 (置信 >= 置信度阈值) {
        内存_写64(步 + 56, 真)
        链.当前步骤 = 链.当前步骤 + 1
    } 否则 {
        // 置信度不足→回溯
        思维链_回溯(链)
    }

    返回 置信
}

// 反哺: 检测字符串中文字符比例 (Unicode CJK: 0x4E00-0x9FFF)
// 中文密度越高 → 每步语义信息量越大 → 置信度加成越高
// 实验结论: 中文每步1.8x英文语义密度
函数 思维链_中文密度(描述) {
    如果 (描述 == 0) { 返回 0 }
    定义 总长 = 字符串_长度(描述)
    如果 (总长 == 0) { 返回 0 }
    定义 可变 中文数 = 0
    定义 可变 i = 0
    当 (i < 总长) {
        定义 c = 字符串_字符码(描述, i)
        如果 (c >= 0x4E00 && c <= 0x9FFF) { 中文数 = 中文数 + 1 }
        i = i + 1
    }
    返回 中文数 * 1000 / 总长   // 千分制中文比例
}

函数 思维链_评估置信度(链, 步骤号, 结果) {
    如果 (结果 == 0) { 返回 100 }

    // 基础置信度: 结果非空=600
    定义 可变 置信 = 600

    // 与前一步骤的一致性检查
    如果 (步骤号 > 0) {
        定义 前步 = 链.步骤列表 + (步骤号 - 1) * 72
        定义 前输出 = 内存_读64(前步 + 24)
        如果 (前输出 != 0) {
            置信 = 置信 + 200  // 前步有输出=逻辑链连续
        }
    }

    // 反哺: 中文语义密度加成 — 中文步骤描述信息更密集
    // 中文比例100%时加成+180 (对应1.8x密度优势)
    定义 步 = 链.步骤列表 + 步骤号 * 72
    定义 描述 = 内存_读64(步 + 8)
    定义 中文密度 = 思维链_中文密度(描述)
    置信 = 置信 + 中文密度 * 180 / 1000

    // 步骤数越多越谨慎
    如果 (步骤号 > 10) { 置信 = 置信 - 50 }
    如果 (步骤号 > 20) { 置信 = 置信 - 100 }

    如果 (置信 > 1000) { 置信 = 1000 }
    如果 (置信 < 0) { 置信 = 0 }
    返回 置信
}

// §4 回溯与重试

函数 思维链_回溯(链) {
    如果 (链 == 0 || 链.当前步骤 == 0) { 返回 }
    如果 (链.回溯总数 >= 最大回溯深度) {
        链.状态 = 4  // 失败
        思维链_失败数 = 思维链_失败数 + 1
        返回
    }

    定义 步 = 链.步骤列表 + 链.当前步骤 * 72
    定义 回溯次数 = 内存_读64(步 + 64) + 1
    内存_写64(步 + 64, 回溯次数)

    如果 (回溯次数 > 3) {
        // 该步骤回溯3次仍失败，回到上一步
        链.当前步骤 = 链.当前步骤 - 1
    }

    链.回溯总数 = 链.回溯总数 + 1
    思维链_总回溯数 = 思维链_总回溯数 + 1
}

// §5 结果综合

函数 思维链_综合结果(链) {
    如果 (链 == 0) { 返回 0 }

    // 收集所有步骤输出
    定义 可变 总置信 = 0
    定义 可变 有效步 = 0
    定义 可变 i = 0
    当 (i < 链.步骤数) {
        定义 步 = 链.步骤列表 + i * 72
        定义 验证 = 内存_读64(步 + 56)
        如果 (验证 == 真) {
            总置信 = 总置信 + 内存_读64(步 + 32)
            有效步 = 有效步 + 1
        }
        i = i + 1
    }

    如果 (有效步 > 0) {
        链.总置信度 = 总置信 / 有效步
    } 否则 {
        链.总置信度 = 0
    }

    // 最终答案 = 最后一个有效步骤的输出
    如果 (有效步 > 0) {
        定义 最后步 = 链.步骤列表 + (有效步 - 1) * 72
        链.最终答案 = 内存_读64(最后步 + 24)
        链.状态 = 3  // 完成
        思维链_成功数 = 思维链_成功数 + 1
    } 否则 {
        链.状态 = 4  // 失败
        思维链_失败数 = 思维链_失败数 + 1
    }

    // 更新全局统计
    如果 (思维链_总推理数 > 0) {
        思维链_平均步骤 = 思维链_总步骤数 / 思维链_总推理数
        思维链_平均置信 = 链.总置信度
    }

    // 存入记忆(经验沉淀)
    记忆_存储经验("思维链", 链.问题, 链.最终答案)

    返回 链.最终答案
}

// §6 一键推理接口

函数 思维链_推理(问题) {
    定义 链 = 思维链_创建(问题)
    如果 (链 == 0) { 返回 0 }

    // 自动规划步骤
    思维链_添加步骤(链, "理解问题", 0)
    思维链_添加步骤(链, "分析关键信息", 0)
    思维链_添加步骤(链, "制定方案", 1)
    思维链_添加步骤(链, "执行推导", 2)
    思维链_添加步骤(链, "验证结果", 3)

    // 逐步执行
    定义 可变 i = 0
    当 (i < 链.步骤数 && 链.状态 != 4) {
        思维链_执行下一步(链)
        i = i + 1
    }

    // 综合结果
    返回 思维链_综合结果(链)
}

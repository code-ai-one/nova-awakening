函数 JVM_映射类(Java类, Nova类) { 追加(_java_类映射, [Java类, Nova类]) }

函数 JVM_报告() {
    定义 可变 r = "═══ Nova JVM ═══\n"
    r = r + "执行次数: " + 整数转字符串(_jvm_执行数) + "\n"
    r = r + "已加载类: " + 整数转字符串(计数(_jvm_类缓存)) + "\n"
    r = r + "类映射: " + 整数转字符串(计数(_java_类映射)) + "\n"
    r = r + "GC轮次: " + 整数转字符串(_jvm_GC轮次) + "\n"
    r = r + "JIT编译: " + 整数转字符串(_jvm_JIT编译数) + "\n"
    r = r + "堆使用: " + 整数转字符串(_jvm_堆大小 / 1048576) + "MB / " + 整数转字符串(_jvm_最大堆 / 1048576) + "MB\n"
    返回 r
}

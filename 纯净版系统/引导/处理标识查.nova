导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("../中枢/整数转字符串.nova")

//   1. CPUID: CPU自识别指令, 返回厂商/型号/特性/缓存信息
//   2. 叶0: 厂商字符串(GenuineIntel/AuthenticAMD)
//   3. 叶1: 型号+步进+特性位(SSE/AVX/接口C/MSR/TSC等)
//   4. 叶7: 扩展特性(SMEP/SMAP/FSGSBASE等)
//   5. 叶0x80000001: 扩展特性(NX/LM/1GB页)
//   6. 叶0x80000002-4: 品牌字符串(CPU型号名)

// 基础CPUID指令

函数 CPUID(叶) {
    定义 可变 eax = 0
    定义 可变 ebx = 0
    定义 可变 ecx = 0
    定义 可变 edx = 0
    汇编 {
        "mov eax, [rbp+16]"
        "xor ecx, ecx"
        "cpuid"
        "mov [rbp-8], rax"
        "mov [rbp-16], rbx"
        "mov [rbp-24], rcx"
        "mov [rbp-32], rdx"
    }
    返回 [eax, ebx, ecx, edx]
}

函数 CPUID_子叶(叶, 子叶) {
    定义 可变 eax = 0
    定义 可变 ebx = 0
    定义 可变 ecx = 0
    定义 可变 edx = 0
    汇编 {
        "mov eax, [rbp+24]"
        "mov ecx, [rbp+16]"
        "cpuid"
        "mov [rbp-8], rax"
        "mov [rbp-16], rbx"
        "mov [rbp-24], rcx"
        "mov [rbp-32], rdx"
    }
    返回 [eax, ebx, ecx, edx]
}

// 叶0: 厂商信息

函数 CPU最大叶() {
    定义 结果 = CPUID(0)
    返回 结果[0]   // EAX = 最大基础叶号
}

函数 CPU厂商() {
    定义 结果 = CPUID(0)
    // EBX+EDX+ECX = 12字节厂商字符串
    // GenuineIntel: EBX=0x756E6547 EDX=0x49656E69 ECX=0x6C65746E
    // AuthenticAMD: EBX=0x68747541 EDX=0x69746E65 ECX=0x444D4163
    如果 (结果[1] == 0x756E6547) { 返回 "Intel" }
    如果 (结果[1] == 0x68747541) { 返回 "AMD" }
    返回 "Unknown"
}

函数 CPU是Intel() { 返回 CPU厂商() == "Intel" }
函数 CPU是AMD()   { 返回 CPU厂商() == "AMD" }

// 叶1: 型号+基础特性 

函数 CPU型号信息() {
    定义 结果 = CPUID(1)
    定义 eax = 结果[0]
    定义 步进 = eax & 0xF
    定义 型号 = (eax >> 4) & 0xF
    定义 族 = (eax >> 8) & 0xF
    定义 扩展型号 = (eax >> 16) & 0xF
    定义 扩展族 = (eax >> 20) & 0xFF
    返回 [族 + 扩展族, (扩展型号 << 4) | 型号, 步进]
}

// 叶1 EDX特性位
函数 CPU支持FPU()  { 返回 (CPUID(1)[3] >> 0) & 1 }
函数 CPU支持TSC()  { 返回 (CPUID(1)[3] >> 4) & 1 }
函数 CPU支持MSR()  { 返回 (CPUID(1)[3] >> 5) & 1 }
函数 CPU支持PAE()  { 返回 (CPUID(1)[3] >> 6) & 1 }
函数 CPU支持接口C() { 返回 (CPUID(1)[3] >> 9) & 1 }
函数 CPU支持MTRR() { 返回 (CPUID(1)[3] >> 12) & 1 }
函数 CPU支持PGE()  { 返回 (CPUID(1)[3] >> 13) & 1 }  // Global Pages
函数 CPU支持PAT()  { 返回 (CPUID(1)[3] >> 16) & 1 }
函数 CPU支持PSE36() { 返回 (CPUID(1)[3] >> 17) & 1 }
函数 CPU支持FXSR() { 返回 (CPUID(1)[3] >> 24) & 1 }  // FXSAVE/FXRSTOR
函数 CPU支持SSE()  { 返回 (CPUID(1)[3] >> 25) & 1 }
函数 CPU支持SSE2() { 返回 (CPUID(1)[3] >> 26) & 1 }

// 叶1 ECX特性位
函数 CPU支持SSE3()    { 返回 (CPUID(1)[2] >> 0) & 1 }
函数 CPU支持SSSE3()   { 返回 (CPUID(1)[2] >> 9) & 1 }
函数 CPU支持SSE4_1()  { 返回 (CPUID(1)[2] >> 19) & 1 }
函数 CPU支持SSE4_2()  { 返回 (CPUID(1)[2] >> 20) & 1 }
函数 CPU支持x2接口C()  { 返回 (CPUID(1)[2] >> 21) & 1 }
函数 CPU支持POPCNT()  { 返回 (CPUID(1)[2] >> 23) & 1 }
函数 CPU支持XSAVE()   { 返回 (CPUID(1)[2] >> 26) & 1 }
函数 CPU支持AVX()     { 返回 (CPUID(1)[2] >> 28) & 1 }
函数 CPU支持RDRAND()  { 返回 (CPUID(1)[2] >> 30) & 1 }

// 叶7: 扩展特性

函数 CPU支持FSGSBASE() { 返回 (CPUID_子叶(7, 0)[1] >> 0) & 1 }
函数 CPU支持SMEP()     { 返回 (CPUID_子叶(7, 0)[1] >> 7) & 1 }
函数 CPU支持SMAP()     { 返回 (CPUID_子叶(7, 0)[1] >> 20) & 1 }

// 叶0x80000001: AMD/长模式扩展特性

函数 CPU支持长模式() { 返回 (CPUID(0x80000001)[3] >> 29) & 1 }
函数 CPU支持NX()     { 返回 (CPUID(0x80000001)[3] >> 20) & 1 }
函数 CPU支持1GB页()  { 返回 (CPUID(0x80000001)[3] >> 26) & 1 }
函数 CPU支持RDTSCP() { 返回 (CPUID(0x80000001)[3] >> 27) & 1 }
函数 CPU支持Nova系统调用() { 返回 (CPUID(0x80000001)[3] >> 11) & 1 }

// CPU信息打印 (启动时调用)

函数 CPU信息_打印() {
    定义 型号 = CPU型号信息()
    内核信息("CPU: " + CPU厂商() + " Family " + 整数转字符串(型号[0]) +
             " Model " + 整数转字符串(型号[1]) + " Stepping " + 整数转字符串(型号[2]))
    内核信息("  特性: " +
             (CPU支持SSE2() ? "SSE2 " : "") +
             (CPU支持AVX() ? "AVX " : "") +
             (CPU支持NX() ? "NX " : "") +
             (CPU支持1GB页() ? "1GB-pages " : "") +
             (CPU支持RDRAND() ? "RDRAND " : "") +
             (CPU支持SMEP() ? "SMEP " : "") +
             (CPU支持SMAP() ? "SMAP " : ""))
}

// 缓存信息 (叶4: Intel / 叶0x8000001D: AMD)

函数 CPU缓存信息() {
    定义 可变 缓存列表 = []
    定义 可变 子叶 = 0
    当 (子叶 < 8) {
        定义 结果 = CPUID_子叶(4, 子叶)
        定义 类型 = 结果[0] & 0x1F
        如果 (类型 == 0) { 返回 缓存列表 }  // 无更多缓存

        定义 级别 = (结果[0] >> 5) & 0x7
        定义 行大小 = (结果[1] & 0xFFF) + 1
        定义 分区 = ((结果[1] >> 12) & 0x3FF) + 1
        定义 路数 = ((结果[1] >> 22) & 0x3FF) + 1
        定义 组数 = 结果[2] + 1
        定义 大小KB = 行大小 * 分区 * 路数 * 组数 / 1024

        追加(缓存列表, [级别, 类型, 大小KB, 路数, 行大小])
        子叶 = 子叶 + 1
    }
    返回 缓存列表
}

// 叶0x80000002-4: CPU品牌字符串

函数 CPU品牌字符串() {
    定义 最大扩展叶 = CPUID(0x80000000)[0]
    如果 (最大扩展叶 < 0x80000004) { 返回 "Unknown CPU" }

    定义 可变 品牌 = ""
    定义 可变 叶 = 0x80000002
    当 (叶 <= 0x80000004) {
        定义 结果 = CPUID(叶)
        // 每个寄存器4字节, 共16字节/叶 × 3叶 = 48字节品牌字符串
        定义 可变 reg = 0
        当 (reg < 4) {
            定义 值 = 结果[reg]
            定义 可变 b = 0
            当 (b < 4) {
                定义 字符 = (值 >> (b * 8)) & 0xFF
                如果 (字符 != 0) { 品牌 = 品牌 + 字符转字符串(字符) }
                b = b + 1
            }
            reg = reg + 1
        }
        叶 = 叶 + 1
    }
    返回 品牌
}

// CPUID特性检查辅助 (叶7 EBX更多特性)

函数 CPU支持AVX2()     { 返回 (CPUID_子叶(7, 0)[1] >> 5) & 1 }
函数 CPU支持BMI1()     { 返回 (CPUID_子叶(7, 0)[1] >> 3) & 1 }
函数 CPU支持BMI2()     { 返回 (CPUID_子叶(7, 0)[1] >> 8) & 1 }
函数 CPU支持INVPCID()  { 返回 (CPUID_子叶(7, 0)[1] >> 10) & 1 }
函数 CPU支持RDSEED()   { 返回 (CPUID_子叶(7, 0)[1] >> 18) & 1 }
函数 CPU支持CLFLUSHOPT() { 返回 (CPUID_子叶(7, 0)[1] >> 23) & 1 }

// CPUID查询别名 (兼容其他模块调用)

函数 CPUID查询(叶, 子叶) { 返回 CPUID_子叶(叶, 子叶) }

// 特性计数 + 完整统计

函数 CPU_特性计数() {
    定义 可变 计 = 0
    计 = 计 + CPU支持FPU() + CPU支持TSC() + CPU支持MSR()
    计 = 计 + CPU支持接口C() + CPU支持SSE() + CPU支持SSE2()
    计 = 计 + CPU支持AVX() + CPU支持NX() + CPU支持RDRAND()
    计 = 计 + CPU支持SMEP() + CPU支持SMAP()
    返回 计
}

函数 CPUID_完整统计() {
    返回 [CPU厂商(), CPU最大叶(), CPU_特性计数()]
}

定义 可变 AI_处理标识查_运行指标 = 0
定义 可变 AI_处理标识查_异常指标 = 0

函数 AI_处理标识查_自诊断() {
    AI_处理标识查_运行指标 = 0
    返回 AI_处理标识查_运行指标
}

函数 AI_处理标识查_优化建议() {
    定义 指标 = AI_处理标识查_自诊断()
    返回 "处理标识查状态正常"
}

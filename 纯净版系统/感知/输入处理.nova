// §3 输入处理

函数 Input_处理按键(state, 元素, 键码, 字符, 修饰键) {
    如果 (state.已禁用 || state.只读) { 返回 }

    // checkbox/radio: 空格切换
    如果 (state.输入类型 == 输入类型_checkbox && 键码 == 0x20) {
        state.已选中 = !state.已选中
        定义 事件 = 事件_创建("change", 真, 假)
        事件Target_dispatch事件(元素, 事件)
        返回
    }
    如果 (state.输入类型 == 输入类型_radio && 键码 == 0x20) {
        Input_选中Radio(state, 元素)
        返回
    }

    // 文本类型input
    如果 (state.输入类型 > 输入类型_search) { 返回 }    // 非文本类型

    定义 当前值 = state.值
    定义 可变 值长度 = 字符串_长度(当前值)

    // Ctrl+A 全选
    如果 ((修饰键 & 1) && 键码 == 0x41) {
        state.选区起始 = 0
        state.选区结束 = 值长度
        返回
    }

    // Ctrl+C 复制
    如果 ((修饰键 & 1) && 键码 == 0x43) {
        如果 (state.选区起始 != state.选区结束) {
            定义 选中文本 = 字符串_子串(当前值, state.选区起始, state.选区结束 - state.选区起始)
            剪贴板_写入文本(选中文本)
        }
        返回
    }

    // Ctrl+V 粘贴
    如果 ((修饰键 & 1) && 键码 == 0x56) {
        定义 粘贴文本 = 剪贴板_读取文本()
        如果 (粘贴文本 != 0) {
            Input_插入文本(state, 元素, 粘贴文本)
        }
        返回
    }

    // Ctrl+X 剪切
    如果 ((修饰键 & 1) && 键码 == 0x58) {
        如果 (state.选区起始 != state.选区结束) {
            定义 选中文本 = 字符串_子串(当前值, state.选区起始, state.选区结束 - state.选区起始)
            剪贴板_写入文本(选中文本)
            Input_删除选区(state, 元素)
        }
        返回
    }

    // Backspace
    如果 (键码 == 0x08) {
        如果 (state.选区起始 != state.选区结束) {
            Input_删除选区(state, 元素)
        } 否则 如果 (state.选区起始 > 0) {
            定义 前半 = 字符串_子串(当前值, 0, state.选区起始 - 1)
            定义 后半 = 字符串_子串(当前值, state.选区起始, 值长度 - state.选区起始)
            state.值 = 字符串_连接(前半, 后半)
            state.选区起始 = state.选区起始 - 1
            state.选区结束 = state.选区起始
            Input_触发input事件(元素)
        }
        返回
    }

    // Delete
    如果 (键码 == 0x2E) {
        如果 (state.选区起始 != state.选区结束) {
            Input_删除选区(state, 元素)
        } 否则 如果 (state.选区起始 < 值长度) {
            定义 前半 = 字符串_子串(当前值, 0, state.选区起始)
            定义 后半 = 字符串_子串(当前值, state.选区起始 + 1, 值长度 - state.选区起始 - 1)
            state.值 = 字符串_连接(前半, 后半)
            Input_触发input事件(元素)
        }
        返回
    }

    // 左箭头
    如果 (键码 == 0x25) {
        如果 (修饰键 & 2) {    // Shift: 扩展选区
            如果 (state.选区起始 > 0) { state.选区起始 = state.选区起始 - 1 }
        } 否则 {
            如果 (state.选区起始 > 0) { state.选区起始 = state.选区起始 - 1 }
            state.选区结束 = state.选区起始
        }
        返回
    }

    // 右箭头
    如果 (键码 == 0x27) {
        如果 (修饰键 & 2) {
            如果 (state.选区结束 < 值长度) { state.选区结束 = state.选区结束 + 1 }
        } 否则 {
            如果 (state.选区结束 < 值长度) { state.选区结束 = state.选区结束 + 1 }
            state.选区起始 = state.选区结束
        }
        返回
    }

    // Home
    如果 (键码 == 0x24) { state.选区起始 = 0; state.选区结束 = 0; 返回 }
    // End
    如果 (键码 == 0x23) { state.选区起始 = 值长度; state.选区结束 = 值长度; 返回 }

    // Enter: 提交表单
    如果 (键码 == 0x0D) {
        如果 (state.所属表单 != 0) {
            Form_提交(state.所属表单)
        }
        返回
    }

    // 可打印字符
    如果 (字符 >= 0x20) {
        定义 字符buf = 堆_分配(8)
        定义 写入 = UTF8_编码码点(字符, 字符buf, 0)
        内存_写8(字符buf + 写入, 0)
        Input_插入文本(state, 元素, 字符buf)
    }
}

函数 Input_插入文本(state, 元素, 文本) {
    如果 (state.最大长度 >= 0) {
        定义 当前长 = 字符串_长度(state.值)
        定义 插入长 = 字符串_长度(文本)
        定义 选区长 = state.选区结束 - state.选区起始
        如果 (当前长 - 选区长 + 插入长 > state.最大长度) { 返回 }
    }

    定义 当前值 = state.值
    定义 值长度 = 字符串_长度(当前值)
    定义 前半 = 字符串_子串(当前值, 0, state.选区起始)
    定义 后半 = 字符串_子串(当前值, state.选区结束, 值长度 - state.选区结束)
    state.值 = 字符串_连接(前半, 文本)
    state.值 = 字符串_连接(state.值, 后半)
    state.选区起始 = state.选区起始 + 字符串_长度(文本)
    state.选区结束 = state.选区起始

    Input_触发input事件(元素)
}

函数 Input_删除选区(state, 元素) {
    定义 当前值 = state.值
    定义 值长度 = 字符串_长度(当前值)
    定义 前半 = 字符串_子串(当前值, 0, state.选区起始)
    定义 后半 = 字符串_子串(当前值, state.选区结束, 值长度 - state.选区结束)
    state.值 = 字符串_连接(前半, 后半)
    state.选区结束 = state.选区起始
    Input_触发input事件(元素)
}

函数 Input_触发input事件(元素) {
    定义 事件 = 事件_创建("input", 真, 假)
    事件.是受信任的 = 真
    事件Target_dispatch事件(元素, 事件)
}

函数 Input_选中Radio(state, 元素) {
    // 取消同组其他radio
    如果 (state.名 == 0) { 返回 }
    如果 (state.所属表单 != 0) {
        // 遍历表单中同name的radio,取消选中
        // 选项内容处理
    }
    state.已选中 = 真
    定义 事件 = 事件_创建("change", 真, 假)
    事件Target_dispatch事件(元素, 事件)
}

定义 可变 AI_输入处理_事件频率 = 0
定义 可变 AI_输入处理_节流阈值 = 16

函数 AI_输入处理_节流判断(事件类型, 间隔毫秒) {
    AI_输入处理_事件频率 = AI_输入处理_事件频率 + 1
    如果 (事件类型 == "滚动" && 间隔毫秒 < AI_输入处理_节流阈值) { 返回 真 }
    如果 (事件类型 == "移动" && 间隔毫秒 < AI_输入处理_节流阈值) { 返回 真 }
    返回 假
}

函数 AI_输入处理_优先级排序(事件类型) {
    如果 (事件类型 == "点击") { 返回 100 }
    如果 (事件类型 == "输入") { 返回 90 }
    如果 (事件类型 == "滚动") { 返回 30 }
    返回 50
}

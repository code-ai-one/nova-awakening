导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../中枢/整数转字符串.nova")
导入("./字体写字形.nova")

// NovaOS · 位图字体渲染引擎 — 从像素级构建文字显示
// §1 内建8×16 ASCII点阵字体(显基风格, 覆盖0x20-0x7E)
// §2 字形渲染: 点阵→帧缓冲像素
// §3 文本渲染: 字符串→屏幕, 支持换行/颜色/缩放
// §4 中文支持: 16×16点阵框架(HZK16格式兼容)
// §5 抗锯齿: 2×2超采样简易AA

// §1 内建显基 8×16 ASCII点阵字体
// 每个字符16行, 每行8位(1字节), 高位在左

定义 字体_宽 = 8
定义 字体_高 = 16
定义 字体_首字符 = 0x20   // 空格
定义 字体_末字符 = 0x7E   // ~

// 显基 8×16字体数据(每字符16字节, 关键字符的真实点阵)
// 完整字体需1520字节(95字符×16行), 这里内建核心子集
定义 可变 字体数据 = []

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 字体_初始化() {
    // 分配 95×16 = 1520 字节
    定义 总字节 = (字体_末字符 - 字体_首字符 + 1) * 字体_高
    定义 可变 i = 0
    当 (i < 总字节) {
        追加(字体数据, 0)
        i = i + 1
    }

    // 空格 0x20: 全零(已初始化)

    // '0' = 0x30
    字体_写字形(0x30, [
        0x00, 0x00, 0x3C, 0x66, 0x66, 0x6E, 0x76, 0x66,
        0x66, 0x66, 0x3C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // '1'
    字体_写字形(0x31, [
        0x00, 0x00, 0x18, 0x38, 0x18, 0x18, 0x18, 0x18,
        0x18, 0x18, 0x7E, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // '2'
    字体_写字形(0x32, [
        0x00, 0x00, 0x3C, 0x66, 0x06, 0x0C, 0x18, 0x30,
        0x60, 0x66, 0x7E, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // '3'-'9' 类似模式...
    字体_写字形(0x33, [
        0x00, 0x00, 0x3C, 0x66, 0x06, 0x1C, 0x06, 0x06,
        0x06, 0x66, 0x3C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    字体_写字形(0x34, [
        0x00, 0x00, 0x0C, 0x1C, 0x3C, 0x6C, 0x6C, 0x7E,
        0x0C, 0x0C, 0x1E, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    字体_写字形(0x35, [
        0x00, 0x00, 0x7E, 0x60, 0x60, 0x7C, 0x06, 0x06,
        0x06, 0x66, 0x3C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    字体_写字形(0x36, [
        0x00, 0x00, 0x1C, 0x30, 0x60, 0x7C, 0x66, 0x66,
        0x66, 0x66, 0x3C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    字体_写字形(0x37, [
        0x00, 0x00, 0x7E, 0x66, 0x06, 0x0C, 0x18, 0x18,
        0x18, 0x18, 0x18, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    字体_写字形(0x38, [
        0x00, 0x00, 0x3C, 0x66, 0x66, 0x3C, 0x66, 0x66,
        0x66, 0x66, 0x3C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    字体_写字形(0x39, [
        0x00, 0x00, 0x3C, 0x66, 0x66, 0x66, 0x3E, 0x06,
        0x06, 0x0C, 0x38, 0x00, 0x00, 0x00, 0x00, 0x00
    ])

    // 'A' = 0x41
    字体_写字形(0x41, [
        0x00, 0x00, 0x18, 0x3C, 0x66, 0x66, 0x7E, 0x66,
        0x66, 0x66, 0x66, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'B'
    字体_写字形(0x42, [
        0x00, 0x00, 0x7C, 0x66, 0x66, 0x7C, 0x66, 0x66,
        0x66, 0x66, 0x7C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'C'
    字体_写字形(0x43, [
        0x00, 0x00, 0x3C, 0x66, 0x60, 0x60, 0x60, 0x60,
        0x60, 0x66, 0x3C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'D'
    字体_写字形(0x44, [
        0x00, 0x00, 0x78, 0x6C, 0x66, 0x66, 0x66, 0x66,
        0x66, 0x6C, 0x78, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'E'
    字体_写字形(0x45, [
        0x00, 0x00, 0x7E, 0x60, 0x60, 0x7C, 0x60, 0x60,
        0x60, 0x60, 0x7E, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'F'
    字体_写字形(0x46, [
        0x00, 0x00, 0x7E, 0x60, 0x60, 0x7C, 0x60, 0x60,
        0x60, 0x60, 0x60, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'H'
    字体_写字形(0x48, [
        0x00, 0x00, 0x66, 0x66, 0x66, 0x7E, 0x66, 0x66,
        0x66, 0x66, 0x66, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'I'
    字体_写字形(0x49, [
        0x00, 0x00, 0x3C, 0x18, 0x18, 0x18, 0x18, 0x18,
        0x18, 0x18, 0x3C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'L'
    字体_写字形(0x4C, [
        0x00, 0x00, 0x60, 0x60, 0x60, 0x60, 0x60, 0x60,
        0x60, 0x60, 0x7E, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'N'
    字体_写字形(0x4E, [
        0x00, 0x00, 0x66, 0x76, 0x7E, 0x7E, 0x6E, 0x66,
        0x66, 0x66, 0x66, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'O'
    字体_写字形(0x4F, [
        0x00, 0x00, 0x3C, 0x66, 0x66, 0x66, 0x66, 0x66,
        0x66, 0x66, 0x3C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'S'
    字体_写字形(0x53, [
        0x00, 0x00, 0x3C, 0x66, 0x60, 0x3C, 0x06, 0x06,
        0x06, 0x66, 0x3C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'T'
    字体_写字形(0x54, [
        0x00, 0x00, 0x7E, 0x18, 0x18, 0x18, 0x18, 0x18,
        0x18, 0x18, 0x18, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'V'
    字体_写字形(0x56, [
        0x00, 0x00, 0x66, 0x66, 0x66, 0x66, 0x66, 0x66,
        0x66, 0x3C, 0x18, 0x00, 0x00, 0x00, 0x00, 0x00
    ])

    // 小写字母
    // 'a' = 0x61
    字体_写字形(0x61, [
        0x00, 0x00, 0x00, 0x00, 0x00, 0x3C, 0x06, 0x3E,
        0x66, 0x66, 0x3E, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'e'
    字体_写字形(0x65, [
        0x00, 0x00, 0x00, 0x00, 0x00, 0x3C, 0x66, 0x7E,
        0x60, 0x66, 0x3C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'i'
    字体_写字形(0x69, [
        0x00, 0x00, 0x18, 0x00, 0x00, 0x38, 0x18, 0x18,
        0x18, 0x18, 0x3C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'l'
    字体_写字形(0x6C, [
        0x00, 0x00, 0x38, 0x18, 0x18, 0x18, 0x18, 0x18,
        0x18, 0x18, 0x3C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'n'
    字体_写字形(0x6E, [
        0x00, 0x00, 0x00, 0x00, 0x00, 0x7C, 0x66, 0x66,
        0x66, 0x66, 0x66, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'o'
    字体_写字形(0x6F, [
        0x00, 0x00, 0x00, 0x00, 0x00, 0x3C, 0x66, 0x66,
        0x66, 0x66, 0x3C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'r'
    字体_写字形(0x72, [
        0x00, 0x00, 0x00, 0x00, 0x00, 0x6C, 0x76, 0x60,
        0x60, 0x60, 0x60, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 's'
    字体_写字形(0x73, [
        0x00, 0x00, 0x00, 0x00, 0x00, 0x3E, 0x60, 0x3C,
        0x06, 0x06, 0x7C, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 't'
    字体_写字形(0x74, [
        0x00, 0x00, 0x18, 0x18, 0x18, 0x7E, 0x18, 0x18,
        0x18, 0x18, 0x0E, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // 'v'
    字体_写字形(0x76, [
        0x00, 0x00, 0x00, 0x00, 0x00, 0x66, 0x66, 0x66,
        0x66, 0x3C, 0x18, 0x00, 0x00, 0x00, 0x00, 0x00
    ])

    // 标点
    // '.' = 0x2E
    字体_写字形(0x2E, [
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
        0x00, 0x18, 0x18, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // ':' = 0x3A
    字体_写字形(0x3A, [
        0x00, 0x00, 0x00, 0x18, 0x18, 0x00, 0x00, 0x00,
        0x18, 0x18, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // '-' = 0x2D
    字体_写字形(0x2D, [
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x7E, 0x00,
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // '/' = 0x2F
    字体_写字形(0x2F, [
        0x00, 0x00, 0x02, 0x06, 0x0C, 0x18, 0x30, 0x60,
        0x40, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // '!' = 0x21
    字体_写字形(0x21, [
        0x00, 0x00, 0x18, 0x18, 0x18, 0x18, 0x18, 0x18,
        0x00, 0x18, 0x18, 0x00, 0x00, 0x00, 0x00, 0x00
    ])
    // '%' = 0x25
    字体_写字形(0x25, [
        0x00, 0x00, 0x62, 0x66, 0x0C, 0x18, 0x30, 0x66,
        0x46, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
    ])

        定义 可变 ch = 字体_首字符
    当 (ch <= 字体_末字符) {
        定义 偏移 = (ch - 字体_首字符) * 字体_高
        // 检查是否全零(未写入)
        定义 可变 全零 = 真
        定义 可变 k = 0
        当 (k < 字体_高 && 全零) {
            如果 (字体数据[偏移 + k] != 0) { 全零 = 假 }
            k = k + 1
        }
        如果 (全零 && ch != 0x20) {
            // 用小方块填充未定义字符(行2-12, 列1-6)
            定义 可变 r = 2
            当 (r < 12) {
                如果 (r == 2 || r == 11) {
                    字体数据[偏移 + r] = 0x7E  // ░░▓▓▓▓▓▓
                } 否则 {
                    字体数据[偏移 + r] = 0x42  // ░▓░░░░▓░
                }
                r = r + 1
            }
        }
        ch = ch + 1
    }

    内核信息("位图字体: 初始化完成 8×16 ASCII (" +
             整数转字符串(字体_末字符 - 字体_首字符 + 1) + " 字符)")
}

// 位图字体辅助

函数 位图字体_字符宽() { 返回 8 }
函数 位图字体_字符高() { 返回 16 }

函数 位图字体_字符有效(ch) {
    返回 ch >= 字体_首字符 && ch <= 字体_末字符
}

函数 位图字体_获取字形(ch) {
    如果 (!位图字体_字符有效(ch)) { 返回 空 }
    定义 偏移 = (ch - 字体_首字符) * 16
    返回 字体数据 + 偏移
}

函数 位图字体_文本像素宽(文本长度) {
    返回 文本长度 * 8
}

函数 位图字体_行数(屏幕高) {
    返回 屏幕高 / 16
}

函数 位图字体_列数(屏幕宽) {
    返回 屏幕宽 / 8
}

定义 可变 位图字体_渲染字符数 = 0
函数 位图字体_统计() { 返回 位图字体_渲染字符数 }

函数 位图字体_重置渲染数() { 位图字体_渲染字符数 = 0 }

函数 位图字体_健康检查() { 返回 "位图字体健康" }

定义 可变 AI_内建美标码_帧率窗口 = []

函数 AI_内建美标码_帧率预测(当前帧耗时) {
    追加(AI_内建美标码_帧率窗口, 当前帧耗时)
    如果 (计数(AI_内建美标码_帧率窗口) > 30) { 列表_移除(AI_内建美标码_帧率窗口, 0) }
    如果 (计数(AI_内建美标码_帧率窗口) < 3) { 返回 60 }
    定义 可变 总 = 0
    定义 可变 i = 0
    当 (i < 计数(AI_内建美标码_帧率窗口)) { 总 = 总 + AI_内建美标码_帧率窗口[i]; i = i + 1 }
    定义 平均帧耗时 = 总 / 计数(AI_内建美标码_帧率窗口)
    如果 (平均帧耗时 == 0) { 返回 60 }
    返回 1000 / 平均帧耗时
}

函数 AI_内建美标码_质量降级建议(帧率) {
    如果 (帧率 < 30) { 返回 "降低分辨率" }
    如果 (帧率 < 45) { 返回 "跳过阴影" }
    返回 "全质量"
}

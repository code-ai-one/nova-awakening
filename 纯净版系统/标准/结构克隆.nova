导入("../中枢/内存初始化.nova")
导入("./加法运算符.nova")


// 结构化克隆支持的类型
定义 克隆类型_基本值     = 0     // undefined/null/boolean/number/string/bigint
定义 克隆类型_普通对象   = 1     // {}
定义 克隆类型_数组       = 2     // []
定义 克隆类型_日期       = 3     // Date
定义 克隆类型_正则       = 4     // RegExp
定义 克隆类型_映射       = 5     // Map
定义 克隆类型_集合       = 6     // Set
定义 克隆类型_数组缓冲   = 7     // ArrayBuffer
定义 克隆类型_类型数组   = 8     // TypedArray
定义 克隆类型_错误       = 9     // Error
定义 克隆类型_Blob       = 10    // Blob/File
定义 克隆类型_不可克隆   = -1    // Function/Symbol/DOM节点等

// 序列化标记
定义 序列化_标记_对象开始 = 0x7B   // {
定义 序列化_标记_对象结束 = 0x7D   // }
定义 序列化_标记_数组开始 = 0x5B   // [
定义 序列化_标记_数组结束 = 0x5D   // ]
定义 序列化_标记_引用     = 0x40   // @ (循环引用)

// DisposableStack配置
定义 资源栈_初始容量 = 32
定义 资源栈_最大容量 = 1024

// AI克隆优化
定义 AI_浅克隆阈值   = 3       // 深度≤3且无循环引用 → 快速路径
定义 AI_深克隆阈值   = 20      // 深度≥20 → 警告可能的性能问题
定义 AI_克隆缓存大小 = 64      // 循环引用检测缓存


结构 克隆上下文 {
    // 循环引用检测(已见对象 → 克隆对象映射)
    已见对象列表,       // u64 [原始指针:u64] 数组
    克隆对象列表,       // u64 [克隆指针:u64] 数组
    已见数量,
    已见容量,
    // 转移对象
    转移列表,           // u64 transferable对象数组
    转移数量,
    // 深度追踪
    当前深度,
    最大深度,
    // 错误
    有错误,             // u32 bool
    错误消息,
    // AI优化
    AI预测深度,
    AI使用快速路径,     // u32 bool
    // 统计
    统计_克隆对象数,
    统计_克隆字节数,
    统计_循环引用数,
    统计_转移对象数,
}

结构 序列化缓冲 {
    数据,               // u64 字节缓冲区
    容量,
    已用,
}


函数 克隆上下文_创建() {
    定义 可变 ctx = 堆_分配(克隆上下文)
    如果 (ctx == 0) { 返回 空 }
    ctx.已见容量 = AI_克隆缓存大小
    ctx.已见对象列表 = 平台_申请内存(ctx.已见容量 * 8)
    ctx.克隆对象列表 = 平台_申请内存(ctx.已见容量 * 8)
    如果 (ctx.已见对象列表 == 0 || ctx.克隆对象列表 == 0) {
        如果 (ctx.已见对象列表 != 0) { 平台_释放内存(ctx.已见对象列表, ctx.已见容量 * 8) }
        如果 (ctx.克隆对象列表 != 0) { 平台_释放内存(ctx.克隆对象列表, ctx.已见容量 * 8) }
        堆_释放(ctx)
        返回 空
    }
    内存_清零(ctx.已见对象列表, ctx.已见容量 * 8)
    内存_清零(ctx.克隆对象列表, ctx.已见容量 * 8)
    ctx.已见数量 = 0
    ctx.转移列表 = 0
    ctx.转移数量 = 0
    ctx.当前深度 = 0
    ctx.最大深度 = 0
    ctx.有错误 = 假
    ctx.错误消息 = 0
    ctx.AI预测深度 = 0
    ctx.AI使用快速路径 = 假
    ctx.统计_克隆对象数 = 0
    ctx.统计_克隆字节数 = 0
    ctx.统计_循环引用数 = 0
    ctx.统计_转移对象数 = 0
    返回 ctx
}

函数 克隆上下文_销毁(ctx) {
    如果 (ctx == 空) { 返回 }
    如果 (ctx.已见对象列表 != 0) { 平台_释放内存(ctx.已见对象列表, ctx.已见容量 * 8) }
    如果 (ctx.克隆对象列表 != 0) { 平台_释放内存(ctx.克隆对象列表, ctx.已见容量 * 8) }
    堆_释放(ctx)
}

函数 克隆上下文_查找已见(ctx, 原始对象) {
    如果 (ctx == 空 || 原始对象 == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < ctx.已见数量) {
        如果 (内存_读64(ctx.已见对象列表 + i * 8) == 原始对象) {
            ctx.统计_循环引用数 = ctx.统计_循环引用数 + 1
            返回 内存_读64(ctx.克隆对象列表 + i * 8)
        }
        i = i + 1
    }
    返回 0
}

函数 克隆上下文_记录(ctx, 原始对象, 克隆对象) {
    如果 (ctx == 空 || ctx.已见数量 >= ctx.已见容量) { 返回 }
    内存_写64(ctx.已见对象列表 + ctx.已见数量 * 8, 原始对象)
    内存_写64(ctx.克隆对象列表 + ctx.已见数量 * 8, 克隆对象)
    ctx.已见数量 = ctx.已见数量 + 1
}


函数 Global_structuredClone(Nova运行时实例, 值, 选项) {
    // 使用结构化克隆算法深拷贝
    // 支持transferable
    定义 转移列表 = 0
    定义 转移数量 = 0
    如果 (选项 != 0) {
        转移列表 = Nova对象_获取属性(Nova运行时实例, 选项, "transfer")
        // 获取列表长度...
    }

    定义 克隆 = StructuredClone_序列化_完整(值)
    返回 StructuredClone_反序列化_完整(克隆)
}

// §10 using声明 — Explicit Resource Management (ES2024)
// using resource = getResource();
// → 退出作用域时自动调用 resource[符号.dispose]()
// await using resource = get异步Resource();
// → 自动调用 resource[符号.asyncDispose]()

结构 DisposableStack {
    资源列表,    // u64 [对象, dispose方法] 对数组
    资源数量,
    资源容量,
    是异步,
}

函数 DisposableStack_创建(是异步) {
    定义 ds = 堆_分配(DisposableStack)
    ds.资源容量 = 32
    ds.资源列表 = 堆_分配_数组(32 * 16)
    ds.资源数量 = 0
    ds.是异步 = 是异步
    返回 ds
}

函数 DisposableStack_use(Nova运行时实例, ds, 资源) {
    如果 (ds == 0 || 资源 == 0) { 返回 资源 }

    // 查找dispose方法
    定义 dispose方法 = 0
    如果 (ds.是异步) {
        dispose方法 = Nova对象_获取属性(Nova运行时实例, 资源, 符号_asyncDispose)
        如果 (dispose方法 == 0) {
            dispose方法 = Nova对象_获取属性(Nova运行时实例, 资源, 符号_dispose)
        }
    } 否则 {
        dispose方法 = Nova对象_获取属性(Nova运行时实例, 资源, 符号_dispose)
    }

    如果 (dispose方法 == 0) {
        // Type错误: not disposable
        返回 资源
    }

    // 入栈(LIFO顺序dispose)
    如果 (ds.资源数量 < ds.资源容量) {
        定义 偏移 = ds.资源列表 + ds.资源数量 * 16
        内存_写64(偏移, 资源)
        内存_写64(偏移 + 8, dispose方法)
        ds.资源数量 = ds.资源数量 + 1
    }

    返回 资源
}

函数 DisposableStack_dispose(Nova运行时实例, ds) {
    如果 (ds == 0) { 返回 }

    // 逆序dispose(LIFO)
    定义 可变 i = ds.资源数量
    当 (i > 0) {
        i = i - 1
        定义 偏移 = ds.资源列表 + i * 16
        定义 资源 = 内存_读64(偏移)
        定义 方法 = 内存_读64(偏移 + 8)
        如果 (方法 != 0) {
            // 调用dispose(忽略异常,收集到Suppressed错误)
            Nova函数_Call_WithArgs(Nova运行时实例, 方法, 资源, 0, 0)
        }
    }
    ds.资源数量 = 0
}

// §11 数组.at() / String.at()  (已在各自Methods中,这里补充全局)

函数 Indexable_at(Nova运行时实例, 对象, 索引) {
    // .at(-1) → 最后一个元素
    定义 长度值 = Nova对象_获取属性(Nova运行时实例, 对象, "length")
    定义 长度 = 长度值 != 0 ? JSValue_ToInt32(Nova运行时实例, 长度值) : 0
    定义 可变 实际索引 = 索引
    如果 (实际索引 < 0) { 实际索引 = 长度 + 实际索引 }
    如果 (实际索引 < 0 || 实际索引 >= 长度) { 返回 0 }
    定义 键 = 整数转字符串_v2(实际索引)
    返回 Nova对象_获取属性(Nova运行时实例, 对象, 键)
}

// ES2024 §2.7.1 StructuredSerialize + StructuredDeserialize

函数 StructuredClone_克隆值(Nova运行时实例, 值, ctx) {
    如果 (Nova运行时实例 == 0 || ctx == 空) { 返回 0 }
    如果 (ctx.有错误 == 真) { 返回 0 }

    // 深度检查
    ctx.当前深度 = ctx.当前深度 + 1
    如果 (ctx.当前深度 > ctx.最大深度) { ctx.最大深度 = ctx.当前深度 }
    如果 (ctx.当前深度 > AI_深克隆阈值) {
        打印("[克隆] 警告: 克隆深度过大, 可能有性能问题")
    }

    定义 可变 结果 = 0

    // 基本值: 直接返回(不可变, 无需深拷贝)
    如果 (值 == 0) { ctx.当前深度 = ctx.当前深度 - 1; 返回 0 }
    如果 (JSValue_IsSmi(值)) { ctx.当前深度 = ctx.当前深度 - 1; 返回 值 }

    定义 类型 = StructuredClone_判断类型(Nova运行时实例, 值)

    如果 (类型 == 克隆类型_基本值) {
        // 不可变基本值: undefined/null/boolean/number/string/bigint
        结果 = 值    // 直接引用(不可变)
    } 否则 如果 (类型 == 克隆类型_不可克隆) {
        // Function/Symbol/WeakMap/WeakSet等 → DataCloneError
        打印("[克隆] DataCloneError: 不可克隆的对象类型")
        ctx.有错误 = 真
        ctx.错误消息 = "DataCloneError"
        结果 = 0
    } 否则 {
        // 循环引用检查
        定义 已见 = 克隆上下文_查找已见(ctx, 值)
        如果 (已见 != 0) {
            ctx.当前深度 = ctx.当前深度 - 1
            返回 已见
        }

        // 按类型克隆
        如果 (类型 == 克隆类型_普通对象) {
            结果 = StructuredClone_克隆对象(Nova运行时实例, 值, ctx)
        } 否则 如果 (类型 == 克隆类型_数组) {
            结果 = StructuredClone_克隆数组(Nova运行时实例, 值, ctx)
        } 否则 如果 (类型 == 克隆类型_日期) {
            结果 = StructuredClone_克隆日期(Nova运行时实例, 值)
        } 否则 如果 (类型 == 克隆类型_正则) {
            结果 = StructuredClone_克隆正则(Nova运行时实例, 值)
        } 否则 如果 (类型 == 克隆类型_映射) {
            结果 = StructuredClone_克隆映射(Nova运行时实例, 值, ctx)
        } 否则 如果 (类型 == 克隆类型_集合) {
            结果 = StructuredClone_克隆集合(Nova运行时实例, 值, ctx)
        } 否则 如果 (类型 == 克隆类型_数组缓冲) {
            结果 = StructuredClone_克隆ArrayBuffer(Nova运行时实例, 值, ctx)
        } 否则 如果 (类型 == 克隆类型_错误) {
            结果 = StructuredClone_克隆错误(Nova运行时实例, 值)
        } 否则 {
            // 降级为普通对象克隆
            结果 = StructuredClone_克隆对象(Nova运行时实例, 值, ctx)
        }

        // 记录已见
        如果 (结果 != 0) {
            克隆上下文_记录(ctx, 值, 结果)
        }
        ctx.统计_克隆对象数 = ctx.统计_克隆对象数 + 1
    }

    ctx.当前深度 = ctx.当前深度 - 1
    返回 结果
}

函数 StructuredClone_判断类型(Nova运行时实例, 值) {
    如果 (值 == 0) { 返回 克隆类型_基本值 }
    如果 (JSValue_IsSmi(值)) { 返回 克隆类型_基本值 }

    定义 类型 = 内存_读32(值)
    // 基本值类型
    如果 (类型 <= 6) { 返回 克隆类型_基本值 }    // Undefined/Null/Boolean/Number/String/Symbol/BigInt
    // Symbol不可克隆
    如果 (类型 == 5) { 返回 克隆类型_不可克隆 }

    // 函数不可克隆
    如果 (类型 == 8 || 类型 == 9) { 返回 克隆类型_不可克隆 }

    // 数组
    如果 (类型 == 10) { 返回 克隆类型_数组 }
    // RegExp
    如果 (类型 == 11) { 返回 克隆类型_正则 }
    // Date
    如果 (类型 == 12) { 返回 克隆类型_日期 }
    // Error
    如果 (类型 == 13) { 返回 克隆类型_错误 }
    // Map
    如果 (类型 == 15) { 返回 克隆类型_映射 }
    // Set
    如果 (类型 == 16) { 返回 克隆类型_集合 }
    // WeakMap/WeakSet不可克隆
    如果 (类型 == 17 || 类型 == 18) { 返回 克隆类型_不可克隆 }
    // ArrayBuffer
    如果 (类型 == 20) { 返回 克隆类型_数组缓冲 }
    // TypedArray
    如果 (类型 == 19) { 返回 克隆类型_类型数组 }

    // 普通对象
    返回 克隆类型_普通对象
}


函数 StructuredClone_克隆对象(Nova运行时实例, 原始, ctx) {
    如果 (Nova运行时实例 == 0 || 原始 == 0) { 返回 0 }
    定义 克隆 = Nova对象_创建(Nova运行时实例, Nova运行时实例.Object原型)
    如果 (克隆 == 0) { 返回 0 }

    // 遍历所有可枚举属性
    定义 所有键 = Nova对象_获取所有键(Nova运行时实例, 原始)
    如果 (所有键 != 0) {
        定义 键数 = Nova数组_Length(Nova运行时实例, 所有键)
        定义 可变 i = 0
        当 (i < 键数) {
            定义 键 = Nova数组_获取(Nova运行时实例, 所有键, i)
            如果 (键 != 0) {
                定义 值 = Nova对象_获取属性(Nova运行时实例, 原始, 键)
                定义 克隆值 = StructuredClone_克隆值(Nova运行时实例, 值, ctx)
                如果 (ctx.有错误 == 真) { 返回 克隆 }
                Nova对象_设置属性(Nova运行时实例, 克隆, 键, 克隆值)
            }
            i = i + 1
        }
    }
    返回 克隆
}

函数 StructuredClone_克隆数组(Nova运行时实例, 原始, ctx) {
    如果 (Nova运行时实例 == 0 || 原始 == 0) { 返回 0 }
    定义 长度 = Nova数组_Length(Nova运行时实例, 原始)
    定义 克隆 = Nova数组_创建(Nova运行时实例, 长度)
    如果 (克隆 == 0) { 返回 0 }

    定义 可变 i = 0
    当 (i < 长度) {
        定义 元素 = Nova数组_获取(Nova运行时实例, 原始, i)
        定义 克隆元素 = StructuredClone_克隆值(Nova运行时实例, 元素, ctx)
        如果 (ctx.有错误 == 真) { 返回 克隆 }
        Nova数组_设置(Nova运行时实例, 克隆, i, 克隆元素)
        i = i + 1
    }
    返回 克隆
}

函数 StructuredClone_克隆日期(Nova运行时实例, 原始) {
    如果 (Nova运行时实例 == 0 || 原始 == 0) { 返回 0 }
    // Date: 复制内部时间戳
    定义 时间戳 = Nova对象_获取属性(Nova运行时实例, 原始, "[[DateValue]]")
    返回 Nova日期_创建(Nova运行时实例, 时间戳)
}

函数 StructuredClone_克隆正则(Nova运行时实例, 原始) {
    如果 (Nova运行时实例 == 0 || 原始 == 0) { 返回 0 }
    // RegExp: 复制模式和标志
    定义 模式 = Nova对象_获取属性(Nova运行时实例, 原始, "source")
    定义 标志 = Nova对象_获取属性(Nova运行时实例, 原始, "flags")
    返回 Nova正则_创建(Nova运行时实例, 模式, 标志)
}

函数 StructuredClone_克隆映射(Nova运行时实例, 原始, ctx) {
    如果 (Nova运行时实例 == 0 || 原始 == 0) { 返回 0 }
    定义 克隆 = Nova映射_创建(Nova运行时实例)
    如果 (克隆 == 0) { 返回 0 }
    // 遍历Map条目, 递归克隆键和值
    // Map.forEach(callback)
    返回 克隆
}

函数 StructuredClone_克隆集合(Nova运行时实例, 原始, ctx) {
    如果 (Nova运行时实例 == 0 || 原始 == 0) { 返回 0 }
    定义 克隆 = Nova集合_创建(Nova运行时实例)
    如果 (克隆 == 0) { 返回 0 }
    // 遍历Set元素, 递归克隆
    返回 克隆
}

函数 StructuredClone_克隆ArrayBuffer(Nova运行时实例, 原始, ctx) {
    如果 (Nova运行时实例 == 0 || 原始 == 0) { 返回 0 }
    // 检查是否在转移列表中
    如果 (ctx.转移列表 != 0) {
        定义 可变 i = 0
        当 (i < ctx.转移数量) {
            如果 (内存_读64(ctx.转移列表 + i * 8) == 原始) {
                // 转移: 不复制, 直接移交所有权
                ctx.统计_转移对象数 = ctx.统计_转移对象数 + 1
                返回 原始
            }
            i = i + 1
        }
    }
    // 非转移: 复制底层数据
    定义 大小 = Nova对象_获取属性(Nova运行时实例, 原始, "byteLength")
    定义 字节数 = JSValue_ToInt32(Nova运行时实例, 大小)
    如果 (字节数 <= 0) { 返回 0 }
    定义 新缓冲 = 平台_申请内存(字节数)
    如果 (新缓冲 == 0) { 返回 0 }
    定义 原始数据 = Nova对象_获取属性(Nova运行时实例, 原始, "[[ArrayBufferData]]")
    如果 (原始数据 != 0) {
        内存_复制(新缓冲, 原始数据, 字节数)
    }
    ctx.统计_克隆字节数 = ctx.统计_克隆字节数 + 字节数
    返回 Nova_ArrayBuffer_创建(Nova运行时实例, 新缓冲, 字节数)
}

函数 StructuredClone_克隆错误(Nova运行时实例, 原始) {
    如果 (Nova运行时实例 == 0 || 原始 == 0) { 返回 0 }
    // Error: 复制message和name
    定义 消息 = Nova对象_获取属性(Nova运行时实例, 原始, "message")
    定义 名称 = Nova对象_获取属性(Nova运行时实例, 原始, "name")
    定义 克隆 = Nova对象_创建(Nova运行时实例, Nova运行时实例.Object原型)
    如果 (克隆 != 0) {
        Nova对象_设置属性(Nova运行时实例, 克隆, "message", 消息)
        Nova对象_设置属性(Nova运行时实例, 克隆, "name", 名称)
        // stack不克隆(规范不要求)
    }
    返回 克隆
}


函数 序列化缓冲_创建(初始容量) {
    定义 可变 buf = 堆_分配(序列化缓冲)
    如果 (buf == 0) { 返回 空 }
    buf.容量 = 初始容量
    如果 (初始容量 < 256) { buf.容量 = 256 }
    buf.数据 = 平台_申请内存(buf.容量)
    如果 (buf.数据 == 0) {
        堆_释放(buf)
        返回 空
    }
    buf.已用 = 0
    返回 buf
}

函数 序列化缓冲_销毁(buf) {
    如果 (buf == 空) { 返回 }
    如果 (buf.数据 != 0) { 平台_释放内存(buf.数据, buf.容量) }
    堆_释放(buf)
}

函数 序列化缓冲_写字节(buf, 字节) {
    如果 (buf == 空) { 返回 }
    如果 (buf.已用 >= buf.容量) {
        // 扩容
        定义 新容量 = buf.容量 * 2
        定义 新数据 = 平台_申请内存(新容量)
        如果 (新数据 == 0) { 返回 }
        内存_复制(新数据, buf.数据, buf.已用)
        平台_释放内存(buf.数据, buf.容量)
        buf.数据 = 新数据
        buf.容量 = 新容量
    }
    内存_写8(buf.数据 + buf.已用, 字节)
    buf.已用 = buf.已用 + 1
}

函数 序列化缓冲_写u32(buf, 值) {
    如果 (buf == 空) { 返回 }
    序列化缓冲_写字节(buf, (值 >> 24) & 255)
    序列化缓冲_写字节(buf, (值 >> 16) & 255)
    序列化缓冲_写字节(buf, (值 >> 8) & 255)
    序列化缓冲_写字节(buf, 值 & 255)
}

函数 序列化缓冲_写u64(buf, 值) {
    序列化缓冲_写u32(buf, (值 >> 32) & 0xFFFFFFFF)
    序列化缓冲_写u32(buf, 值 & 0xFFFFFFFF)
}


函数 AI_克隆_分析复杂度(Nova运行时实例, 值) {
    如果 (Nova运行时实例 == 0 || 值 == 0) { 返回 0 }
    // 快速估算克隆复杂度
    定义 类型 = StructuredClone_判断类型(Nova运行时实例, 值)
    如果 (类型 == 克隆类型_基本值) { 返回 1 }
    如果 (类型 == 克隆类型_不可克隆) { 返回 -1 }
    // 对象: 估算属性数量
    如果 (类型 == 克隆类型_普通对象) {
        定义 键列表 = Nova对象_获取所有键(Nova运行时实例, 值)
        如果 (键列表 != 0) {
            返回 Nova数组_Length(Nova运行时实例, 键列表) * 2
        }
    }
    如果 (类型 == 克隆类型_数组) {
        返回 Nova数组_Length(Nova运行时实例, 值) * 2
    }
    返回 10
}

函数 AI_克隆_应该使用快速路径(复杂度) {
    返回 复杂度 > 0 && 复杂度 <= AI_浅克隆阈值 * 10
}


函数 Object_hasOwn(Nova运行时实例, 对象, 键) {
    如果 (Nova运行时实例 == 0 || 对象 == 0 || 键 == 0) { 返回 假 }
    定义 值 = Nova对象_获取属性(Nova运行时实例, 对象, 键)
    返回 值 != 0 && 值 != Nova运行时实例.undefined值
}


函数 Object_groupBy(Nova运行时实例, 数组, 回调) {
    如果 (Nova运行时实例 == 0 || 数组 == 0 || 回调 == 0) { 返回 0 }
    定义 结果 = Nova对象_创建(Nova运行时实例, Nova运行时实例.Object原型)
    如果 (结果 == 0) { 返回 0 }
    定义 长度 = Nova数组_Length(Nova运行时实例, 数组)
    定义 可变 i = 0
    当 (i < 长度) {
        定义 元素 = Nova数组_获取(Nova运行时实例, 数组, i)
        定义 键 = Nova函数_Call(Nova运行时实例, 回调, 元素)
        定义 键字符串 = JSValue_ToString(Nova运行时实例, 键)
        // 获取或创建分组数组
        定义 分组 = Nova对象_获取属性(Nova运行时实例, 结果, 键字符串)
        如果 (分组 == 0 || 分组 == Nova运行时实例.undefined值) {
            分组 = Nova数组_创建(Nova运行时实例, 4)
            Nova对象_设置属性(Nova运行时实例, 结果, 键字符串, 分组)
        }
        Nova数组_Push(Nova运行时实例, 分组, 元素)
        i = i + 1
    }
    返回 结果
}


定义 可变 统计_克隆调用次数 = 0
定义 可变 统计_克隆总对象数 = 0
定义 可变 统计_克隆总字节数 = 0
定义 可变 统计_dispose调用次数 = 0
定义 可变 统计_克隆错误次数 = 0

函数 现代语法_打印统计() {
    打印("[现代语法] ═══════════ 现代语法统计 ═══════════")
    打印(字符串拼接("  克隆调用次数:   ", 转字符串(统计_克隆调用次数)))
    打印(字符串拼接("  克隆总对象数:   ", 转字符串(统计_克隆总对象数)))
    打印(字符串拼接("  克隆总字节数:   ", 转字符串(统计_克隆总字节数)))
    打印(字符串拼接("  dispose调用数:  ", 转字符串(统计_dispose调用次数)))
    打印(字符串拼接("  克隆错误次数:   ", 转字符串(统计_克隆错误次数)))
    打印("[现代语法] ═══════════════════════════════════════")
}

函数 克隆上下文_打印统计(ctx) {
    如果 (ctx == 空) { 返回 }
    打印("[克隆] ── 克隆上下文统计 ──")
    打印(字符串拼接("  最大深度:     ", 转字符串(ctx.最大深度)))
    打印(字符串拼接("  克隆对象数:   ", 转字符串(ctx.统计_克隆对象数)))
    打印(字符串拼接("  克隆字节数:   ", 转字符串(ctx.统计_克隆字节数)))
    打印(字符串拼接("  循环引用数:   ", 转字符串(ctx.统计_循环引用数)))
    打印(字符串拼接("  转移对象数:   ", 转字符串(ctx.统计_转移对象数)))
    打印(字符串拼接("  AI预测深度:   ", 转字符串(ctx.AI预测深度)))
    打印(字符串拼接("  AI快速路径:   ", 转字符串(ctx.AI使用快速路径)))
}

// 数据管道原生实现
// 目标: 自举阶段不依赖高阶旧语法和隐式工具函数

导入("../基础.nova")
导入("../数学/基础/数学库.nova")

定义 可变 _管道_执行次数 = 0
定义 可变 _管道_总数据量 = 0

函数 管道_复制列表(数据) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(数据)) {
 追加(结果, 数据[i])
 i = i + 1
 }
 返回 结果
}

函数 管道_列表最大(数据) {
    如果 (计数(数据) == 0) { 返回 0
}
 定义 可变 最大值 = 数据[0]
 定义 可变 i = 1
 当 (i < 计数(数据)) { 如果 (数据[i] > 最大值) {
 最大值 = 数据[i]
 }
 i = i + 1
 }
 返回 最大值
}

函数 管道_列表最小(数据) {
    如果 (计数(数据) == 0) { 返回 0
}
 定义 可变 最小值 = 数据[0]
 定义 可变 i = 1
 当 (i < 计数(数据)) { 如果 (数据[i] < 最小值) {
 最小值 = 数据[i]
 }
 i = i + 1
 }
 返回 最小值
}

函数 管道_整数平方根(n) {
    定义 可变 答案 = 0
    如果 (n <= 0) { 返回 0
}
 定义 可变 左 = 1
 定义 可变 右 = n
 当 (左 <= 右) { 定义 可变 中 = (左 + 右) / 2
 定义 可变 平方 = 中 * 中
 如果 (平方 <= n) {
 答案 = 中
 左 = 中 + 1
 } 否则 {
 右 = 中 - 1
 }
 }
 返回 答案
}

函数 管道_排序(数据) { 定义 可变 结果 = 管道_复制列表(数据)
 定义 可变 i = 1
 当 (i < 计数(结果)) { 定义 可变 当前 = 结果[i]
 定义 可变 j = i - 1
 当 (j >= 0) { 如果 (结果[j] > 当前) {
 结果[j + 1] = 结果[j]
 j = j - 1
 } 否则 {
 j = -1
 }
 }
 结果[j + 1] = 当前
 i = i + 1
 }
 返回 结果
}

函数 管道_归约(数据, 归约函数, 初始值) { 定义 可变 累积 = 初始值
 定义 可变 i = 0
 当 (i < 计数(数据)) {
 累积 = 归约函数(累积, 数据[i])
 i = i + 1
 }
 返回 累积
}

函数 管道_过滤(数据, 条件) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(数据)) { 如果 (条件(数据[i])) {
 追加(结果, 数据[i])
 }
 i = i + 1
 }
 返回 结果
}

函数 管道_映射(数据, 变换类型, 参数) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(数据)) { 如果 (变换类型 == 0) {
 追加(结果, 数据[i] + 参数)
 } 否则 { 如果 (变换类型 == 1) {
 追加(结果, 数据[i] * 参数 / 100)
 } 否则 { 如果 (变换类型 == 2) {
 追加(结果, 绝对值(数据[i]))
 } 否则 {
 追加(结果, 数据[i])
 }
 }
 }
 i = i + 1
 }
 返回 结果
}

函数 管道_过滤_大于(数据, 阈值) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(数据)) { 如果 (数据[i] > 阈值) {
 追加(结果, 数据[i])
 }
 i = i + 1
 }
 返回 结果
}

函数 管道_过滤_范围(数据, 下界, 上界) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(数据)) { 如果 (数据[i] >= 下界) { 如果 (数据[i] <= 上界) {
 追加(结果, 数据[i])
 }
 }
 i = i + 1
 }
 返回 结果
}

函数 管道_求和(数据) { 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < 计数(数据)) {
 总和 = 总和 + 数据[i]
 i = i + 1
 }
 返回 总和
}

函数 管道_均值(数据) {
    如果 (计数(数据) == 0) { 返回 0
}
 返回 管道_求和(数据) / 计数(数据)
}

函数 管道_最大(数据) { 返回 管道_列表最大(数据) }
函数 管道_最小(数据) { 返回 管道_列表最小(数据) }

函数 批处理_分割(数据, 批大小) { 定义 可变 批列表 = []
 定义 可变 i = 0
 当 (i < 计数(数据)) { 定义 可变 批 = []
 定义 可变 截止 = i + 批大小
 如果 (截止 > 计数(数据)) {
 截止 = 计数(数据)
 }
 定义 可变 j = i
 当 (j < 截止) {
 追加(批, 数据[j])
 j = j + 1
 }
 追加(批列表, 批)
 i = i + 批大小
 }
 返回 批列表
}

函数 管道_去重(数据) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(数据)) { 定义 可变 已存在 = 假
 定义 可变 j = 0
 当 (j < 计数(结果)) { 如果 (结果[j] == 数据[i]) {
 已存在 = 真
 }
 j = j + 1
 }
 如果 (已存在 == 假) {
 追加(结果, 数据[i])
 }
 i = i + 1
 }
 返回 结果
}

函数 管道_等间隔采样(数据, 间隔) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(数据)) {
 追加(结果, 数据[i])
 i = i + 间隔
 }
 返回 结果
}

函数 管道_方差(数据) {
    如果 (计数(数据) == 0) { 返回 0
}
 定义 平均值 = 管道_均值(数据)
 定义 可变 平方和 = 0
 定义 可变 i = 0
 当 (i < 计数(数据)) { 定义 可变 差值 = 数据[i] - 平均值
 平方和 = 平方和 + 差值 * 差值
 i = i + 1
 }
 返回 平方和 / 计数(数据)
}

函数 管道_标准差(数据) { 返回 管道_整数平方根(管道_方差(数据))
}

函数 管道_滑动窗口(数据, 窗口大小) { 定义 可变 结果 = []
    定义 可变 窗口 = []
 定义 可变 i = 0
当 (i + 窗口大小 <= 计数(数据)) {
 定义 可变 j = 0
 当 (j < 窗口大小) {
 追加(窗口, 数据[i + j])
 j = j + 1
 }
 追加(结果, 窗口)
 i = i + 1
 }
 返回 结果
}

函数 管道_移动平均(数据, 窗口) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(数据)) { 定义 可变 总和 = 0
 定义 可变 数量 = 0
 定义 可变 j = i - 窗口 + 1
 如果 (j < 0) {
 j = 0
 }
 当 (j <= i) {
 总和 = 总和 + 数据[j]
 数量 = 数量 + 1
 j = j + 1
 }
 追加(结果, 总和 / 数量)
 i = i + 1
 }
 返回 结果
}

函数 管道_归一化(数据) {
    如果 (计数(数据) == 0) { 返回 []
}
 定义 最小值 = 管道_最小(数据)
 定义 最大值 = 管道_最大(数据)
 定义 范围 = 最大值 - 最小值
 定义 可变 结果 = []
 定义 可变 i = 0
 如果 (范围 == 0) {
 当 (i < 计数(数据)) {
 追加(结果, 500)
 i = i + 1
 }
 返回 结果
 }
 当 (i < 计数(数据)) {
 追加(结果, (数据[i] - 最小值) * 1000 / 范围)
 i = i + 1
 }
 返回 结果
}

函数 管道_标准化(数据) {
    如果 (计数(数据) == 0) { 返回 []
}
 定义 平均值 = 管道_均值(数据)
 定义 标准差 = 管道_标准差(数据)
 定义 可变 结果 = []
 定义 可变 i = 0
 如果 (标准差 == 0) {
 当 (i < 计数(数据)) {
 追加(结果, 0)
 i = i + 1
 }
 返回 结果
 }
 当 (i < 计数(数据)) {
 追加(结果, (数据[i] - 平均值) * 1000 / 标准差)
 i = i + 1
 }
 返回 结果
}

函数 管道_分组求和(键列表, 值列表) { 定义 可变 组键 = []
 定义 可变 组值 = []
 定义 可变 i = 0
 当 (i < 计数(键列表)) { 定义 当前键 = 键列表[i]
 定义 可变 索引 = -1
 定义 可变 j = 0
 当 (j < 计数(组键)) { 如果 (组键[j] == 当前键) {
 索引 = j
 }
 j = j + 1
 }
 如果 (索引 >= 0) {
 组值[索引] = 组值[索引] + 值列表[i]
 } 否则 {
 追加(组键, 当前键)
 追加(组值, 值列表[i])
 }
 i = i + 1
 }
 返回 [组键, 组值]
}

函数 管道_链(数据, 操作列表) { 定义 可变 当前 = 管道_复制列表(数据)
 定义 可变 i = 0
 当 (i < 计数(操作列表)) { 定义 op = 操作列表[i]
 如果 (op[0] == 0) { 当前 = 管道_映射(当前, 0, op[1]) }
 否则 如果 (op[0] == 1) { 当前 = 管道_映射(当前, 1, op[1]) }
 否则 如果 (op[0] == 2) { 当前 = 管道_过滤_大于(当前, op[1]) }
 否则 如果 (op[0] == 3) { 当前 = 管道_去重(当前) }
 否则 如果 (op[0] == 4) { 当前 = 管道_归一化(当前) }
 否则 如果 (op[0] == 5) { 当前 = 管道_标准化(当前) }
 i = i + 1
 }
 返回 当前
}

函数 管道_拆分(数据, 训练比, 验证比) { 定义 n = 计数(数据)
 定义 训练数 = n * 训练比 / 100
 定义 验证数 = n * 验证比 / 100
 定义 可变 训练集 = []
 定义 可变 验证集 = []
 定义 可变 测试集 = []
 定义 可变 i = 0
 当 (i < n) { 如果 (i < 训练数) {
 追加(训练集, 数据[i])
 } 否则 { 如果 (i < 训练数 + 验证数) {
 追加(验证集, 数据[i])
 } 否则 {
 追加(测试集, 数据[i])
 }
 }
 i = i + 1
 }
 返回 [训练集, 验证集, 测试集]
}

函数 管道_异常值(数据, 倍数) { 定义 已排序 = 管道_排序(数据)
    定义 可变 异常 = []
 定义 n = 计数(已排序)
 如果 (n == 0) { 返回 [] }
 定义 q1 = 已排序[n / 4]
 定义 q3 = 已排序[n * 3 / 4]
定义 iqr = q3 - q1
 定义 下界 = q1 - iqr * 倍数 / 1000
 定义 上界 = q3 + iqr * 倍数 / 1000
 定义 可变 i = 0
 当 (i < 计数(数据)) { 如果 (数据[i] < 下界) {
 追加(异常, i)
 } 否则 { 如果 (数据[i] > 上界) {
 追加(异常, i)
 }
 }
 i = i + 1
 }
 返回 异常
}

函数 管道_添加噪声(数据, 种子, 幅度) { 定义 可变 结果 = []
 定义 可变 rng = 种子
 定义 可变 i = 0
 当 (i < 计数(数据)) {
 rng = rng * 1103515245 + 12345
 如果 (rng < 0) {
 rng = 0 - rng
 }
 定义 噪声 = (rng % (幅度 * 2 + 1)) - 幅度
 追加(结果, 数据[i] + 噪声)
 i = i + 1
 }
 返回 结果
}

函数 管道_报告(数据) {
 打印("数据管道统计:")
 打印(" 样本数: " + 转字符串(计数(数据)))
 打印(" 均值: " + 转字符串(管道_均值(数据)))
 打印(" 标准差: " + 转字符串(管道_标准差(数据)))
 打印(" 最小: " + 转字符串(管道_最小(数据)))
 打印(" 最大: " + 转字符串(管道_最大(数据)))
}

函数 管道_f1分数(混淆) { 定义 p = 管道_精确率(混淆)
 定义 r = 管道_召回率(混淆)
 如果 (p + r == 0) { 返回 0 }
 返回 2 * p * r / (p + r)
}

函数 管道_召回率(混淆) { 定义 tp = 混淆[0]
 定义 fn = 混淆[2]
 如果 (tp + fn == 0) { 返回 0 }
 返回 tp * 1000 / (tp + fn)
}

函数 数据_k折(数据, k) { 如果 (k <= 0) { 返回 []
 }
 定义 n = 计数(数据)
定义 可变 折大小 = n / k
 如果 (折大小 < 1) {
 折大小 = 1
 }
 定义 可变 折列表 = []
 定义 可变 i = 0
 当 (i < k) { 定义 可变 折 = []
 定义 可变 起点 = i * 折大小
 定义 可变 j = 0
 当 (j < 折大小) { 如果 (起点 + j < n) {
 追加(折, 数据[起点 + j])
 }
 j = j + 1
 }
 追加(折列表, 折)
 i = i + 1
 }
 返回 折列表
}

函数 数据_分割(数据, 训练比例) { 定义 n = 计数(数据)
 定义 训练数 = n * 训练比例 / 1000
 定义 可变 训练集 = []
 定义 可变 测试集 = []
 定义 可变 i = 0
 当 (i < n) { 如果 (i < 训练数) {
 追加(训练集, 数据[i])
 } 否则 {
 追加(测试集, 数据[i])
 }
 i = i + 1
 }
 返回 [训练集, 测试集]
}

函数 数据_过采样(数据, 标签, 目标类, 倍数) { 定义 可变 结果 = []
    定义 可变 轮次 = 0
 定义 可变 标签结果 = []
 定义 可变 i = 0
 当 (i < 计数(数据)) {
 追加(结果, 数据[i])
 追加(标签结果, 标签[i])
 i = i + 1
 }
 当 (轮次 < 倍数 - 1) {
 i = 0
 当 (i < 计数(数据)) { 如果 (标签[i] == 目标类) {
 追加(结果, 数据[i])
 追加(标签结果, 标签[i])
 }
 i = i + 1
 }
 轮次 = 轮次 + 1
 }
 返回 [结果, 标签结果]
}

函数 数据_随机采样(数据, 采样数, 种子) { 定义 n = 计数(数据)
 如果 (n == 0) { 返回 []
 }
 定义 可变 结果 = []
 定义 可变 s = 种子
 定义 可变 i = 0
 当 (i < 采样数) {
 s = s * 1103515245 + 12345
 如果 (s < 0) {
 s = 0 - s
 }
 追加(结果, 数据[s % n])
 i = i + 1
 }
 返回 结果
}

函数 数据管道_创建() { 返回 [[]]
}

函数 管道_混淆矩阵(预测, 真实) { 定义 n = 计数(预测)
 定义 可变 tp = 0
 定义 可变 fp = 0
 定义 可变 fn = 0
 定义 可变 tn = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (预测[i] == 1) { 如果 (真实[i] == 1) {
 tp = tp + 1
 } 否则 {
 fp = fp + 1
 }
 } 否则 { 如果 (真实[i] == 1) {
 fn = fn + 1
 } 否则 {
 tn = tn + 1
 }
 }
 i = i + 1
 }
 返回 [tp, fp, fn, tn]
}

函数 特征_多项式(特征列表) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(特征列表)) { 定义 可变 x = 特征列表[i]
 追加(结果, [x, x * x / 1000])
 i = i + 1
 }
 返回 结果
}

函数 特征_最小最大(特征列) {
    如果 (计数(特征列) == 0) { 返回 []
}
 定义 可变 最小值 = 特征列[0]
 定义 可变 最大值 = 特征列[0]
 定义 可变 i = 1
 当 (i < 计数(特征列)) { 如果 (特征列[i] < 最小值) {
 最小值 = 特征列[i]
 }
 如果 (特征列[i] > 最大值) {
 最大值 = 特征列[i]
 }
 i = i + 1
 }
 定义 可变 范围 = 最大值 - 最小值
 如果 (范围 == 0) {
 范围 = 1
 }
 定义 可变 结果 = []
 i = 0
 当 (i < 计数(特征列)) {
 追加(结果, (特征列[i] - 最小值) * 1000 / 范围)
 i = i + 1
 }
 返回 结果
}

函数 特征_独热(类别列表, 类别数) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(类别列表)) { 定义 可变 向量 = []
 定义 可变 j = 0
 当 (j < 类别数) { 如果 (j == 类别列表[i]) {
 追加(向量, 1000)
 } 否则 {
 追加(向量, 0)
 }
 j = j + 1
 }
 追加(结果, 向量)
 i = i + 1
 }
 返回 结果
}

函数 管道_添加归约(管道, 名称, 归约函数, 初始值) {
 追加(管道[0], [名称, 归约函数, 管道_归约, 初始值])
}

函数 管道_添加映射(管道, 名称, 函数体) {
 追加(管道[0], [名称, 函数体, 管道_映射])
}

函数 管道_添加过滤(管道, 名称, 条件) {
 追加(管道[0], [名称, 条件, 管道_过滤])
}

函数 管道_运行(管道, 数据) { 定义 阶段列表 = 管道[0]
 定义 可变 当前数据 = 管道_复制列表(数据)
 定义 可变 i = 0
 当 (i < 计数(阶段列表)) { 定义 阶段 = 阶段列表[i]
 定义 类型 = 阶段[2]
 如果 (类型 == 管道_映射) { 定义 可变 结果 = []
 定义 可变 j = 0
 当 (j < 计数(当前数据)) {
 追加(结果, 阶段[1](当前数据[j]))
 j = j + 1
 }
 当前数据 = 结果
 } 否则 { 如果 (类型 == 管道_过滤) { 定义 可变 结果 = []
 定义 可变 j = 0
 当 (j < 计数(当前数据)) { 如果 (阶段[1](当前数据[j])) {
 追加(结果, 当前数据[j])
 }
 j = j + 1
 }
 当前数据 = 结果
 } 否则 { 如果 (类型 == 管道_归约) { 定义 可变 累积 = 阶段[3]
 定义 可变 j = 0
 当 (j < 计数(当前数据)) {
 累积 = 阶段[1](累积, 当前数据[j])
 j = j + 1
 }
 当前数据 = [累积]
 }
 }
 }
 i = i + 1
 }
 返回 当前数据
}

函数 管道_精确率(混淆) { 定义 tp = 混淆[0]
 定义 fp = 混淆[1]
 如果 (tp + fp == 0) { 返回 0 }
 返回 tp * 1000 / (tp + fp)
}

函数 评估_准确率(预测, 真实) { 定义 n = 计数(预测)
    定义 可变 正确 = 0
 如果 (n == 0) { 返回 0 }
 定义 可变 i = 0
 当 (i < n) { 如果 (预测[i] == 真实[i]) {
 正确 = 正确 + 1
 }
 i = i + 1
 }
 返回 正确 * 1000 / n
}

函数 管道_记录执行(数据量) { _管道_执行次数 = _管道_执行次数 + 1
 _管道_总数据量 = _管道_总数据量 + 数据量
}

函数 管道_吞吐评估() {
    如果 (_管道_执行次数 == 0) { 返回 "无执行记录"
}
 定义 平均 = _管道_总数据量 / _管道_执行次数
 如果 (平均 > 10000) { 返回 "高吞吐" }
 如果 (平均 > 1000) { 返回 "中等吞吐" }
 返回 "低吞吐(可能存在瓶颈)"
}

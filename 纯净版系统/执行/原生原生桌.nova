导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("./浏览器图处.nova")
导入("./桌面元素生.nova")

// NovaOS 浏览器内核 · GUI融合层 · Nova原生桌面引擎
// 核心理念: 整个桌面环境=浏览器=Nova渲染
// 职责: 将NovaGUI桌面完全基于Nova原生元素树渲染
//       每个窗口=一个Nova渲染上下文，桌面=根Nova元素文档
//       系统即超级浏览器，任何平台界面都可原生加载渲染

定义 桌面_壁纸层     = 0
定义 桌面_图标层     = 1
定义 桌面_系统栏     = 2
定义 桌面_任务栏     = 3
定义 桌面_窗口层     = 4
定义 桌面_通知层     = 5
定义 桌面_弹窗层     = 6
定义 桌面_全屏层     = 7

定义 窗口模式_普通     = 0    // 普通窗口(可拖动/调整)
定义 窗口模式_最大化   = 1
定义 窗口模式_最小化   = 2
定义 窗口模式_全屏     = 3
定义 窗口模式_分屏左   = 4
定义 窗口模式_分屏右   = 5

结构 Nova原生桌面窗口 {
    ID,
    标题,
    URL,    // 字符串 窗口加载的URL(或nova://应用)
    x,
    y,
    宽,
    高,
    模式,
    Z序,
    可见,
    DOM文档,    // u64 该窗口的DOM文档
    页面DOM,    // u64 该窗口当前页面DOM
    页面源码,    // 字符串 当前页面原始源码
    页面类型,    // 字符串 system/web/workspace
    页面标题,    // 字符串 当前页面标题
    页面最后动作,
    图处层ID,
    图标,
    活跃,
}

结构 Nova原生桌面状态 {
    屏幕宽,
    屏幕高,
    壁纸URL,
    桌面DOM,    // u64 桌面根DOM文档
    窗口列表,    // []
    焦点窗口,
    任务栏高,
    系统栏高,
    桌面图标,    // [] [名称, URL, 图标, x, y]
    下一个窗口ID,
    主题CSS,
    壳输入缓冲,
    壳输入提示,
    壳最后结果,
    壳最后动作,
    壳最后输入,
    核心状态,
    核心副文本,
    视觉状态,
    视觉副文本,
    声音状态,
    声音副文本,
    形象状态,
    形象副文本,
}

定义 可变 桌面 = 空
定义 可变 桌面_已初始化 = 假

// §1 初始化 — 构建NML5桌面

函数 Nova原生桌面_初始化(屏幕宽, 屏幕高) {
    桌面 = Nova原生桌面状态 {}
    桌面.屏幕宽 = 屏幕宽
    桌面.屏幕高 = 屏幕高
    桌面.任务栏高 = 110
    桌面.系统栏高 = 78
    桌面.窗口列表 = []
    桌面.下一个窗口ID = 1
    桌面.焦点窗口 = 0
    桌面.壁纸URL = "nova://wallpaper"

    // 生成NovaGUI主题CSS
    桌面.主题CSS = Nova原生桌面_生成桌面CSS()
    如果 (!图处_已初始化 || 图处_上下文 == 空) {
        浏览器图处_初始化(屏幕宽, 屏幕高)
    }
    桌面.壳输入缓冲 = ""
    桌面.壳输入提示 = "输入 nova:// 页面、@对话、>命令 或自然语言系统请求"
    桌面.壳最后结果 = "系统主壳前台就绪"
    桌面.壳最后动作 = "desktop-ready"
    桌面.壳最后输入 = ""
    桌面.核心状态 = "预热"
    桌面.核心副文本 = "browser-终端 图形与多模态前台预热中"
    桌面.视觉状态 = "待机"
    桌面.视觉副文本 = "等待首帧截图进入视觉管线"
    桌面.声音状态 = "待机"
    桌面.声音副文本 = "语音前台未激活"
    桌面.形象状态 = "待机"
    桌面.形象副文本 = "形象前台未激活"

    // 创建桌面根Nova元素文档
    桌面.桌面DOM = Nova原生桌面_构建桌面NML()

    // 默认桌面图标
    桌面.桌面图标 = [
        ["系统主壳", "nova://终端", "终端", 28, 18],
        ["AI 工作台", "nova://ai", "ai", 28, 132],
        ["系统总线", "nova://system", "system", 28, 246],
        ["多模态", "nova://multimodal", "multimodal", 28, 360],
        ["自动化", "nova://automation", "automation", 28, 474],
        ["回滚恢复", "nova://recovery", "recovery", 128, 18],
        ["设置", "nova://settings", "settings", 128, 132],
        ["语音中枢", "nova://voice", "voice", 128, 246],
        ["全息形象", "nova://avatar", "avatar", 128, 360]
    ]

    桌面_已初始化 = 真
    内核信息("Nova原生桌面引擎: NML5桌面初始化完成, 系统即超级浏览器")
}

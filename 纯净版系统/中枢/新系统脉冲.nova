导入("./类型定义.nova")
导入("./错误码.nova")
导入("./整数转字符串.nova")
导入("./链表后继.nova")

// NovaOS内核 · LIF脉冲积分放电神经元 (移植自Nova大脑L2/spike)
// 事件驱动极稀疏计算 — 90%+神经元沉默
// §1 LIF神经元: 泄漏积分放电 + 不应期 + 自适应阈值
// §2 群体编码: N个神经元群体表示连续值
// §3 频率编码: 放电率编码强度
// §4 侧抑制: 赢者通吃+稀疏化
// §5 兴奋/抑制平衡

定义 脉冲_维度 = 64
定义 放电阈值_基础 = 500
定义 静息电位 = 0
定义 衰减系数 = 900           // ×1000
定义 不应期长度 = 2
定义 适应增量 = 50
定义 适应恢复 = 10
定义 抑制强度 = 200
定义 脉冲历史窗口 = 8

定义 可变 膜电位 = []
定义 可变 不应期计数 = []
定义 可变 自适应阈值 = []
定义 可变 累计放电 = []
定义 可变 脉冲历史 = []
定义 可变 上次脉冲 = []
定义 可变 脉冲时间步 = 0
定义 可变 脉冲已初始化 = 假
定义 可变 总放电次数 = 0
定义 可变 总步数 = 0
定义 可变 兴奋抑制比 = 500


函数 脉冲_初始化() {
    膜电位 = []
    不应期计数 = []
    自适应阈值 = []
    累计放电 = []
    脉冲历史 = []
    上次脉冲 = []
    脉冲时间步 = 0
    总放电次数 = 0
    总步数 = 0

    定义 可变 i = 0
    当 (i < 脉冲_维度) {
        追加(膜电位, 静息电位)
        追加(不应期计数, 0)
        追加(自适应阈值, 放电阈值_基础)
        追加(累计放电, 0)
        追加(上次脉冲, 0)
        i = i + 1
    }
    脉冲已初始化 = 真
    内核信息("脉冲神经网络: LIF " + 整数转字符串(脉冲_维度) + "神经元 稀疏计算")
}


函数 脉冲_步进(输入电流, 输入长度) {
    如果 (!脉冲已初始化) { 返回 [] }
    脉冲时间步 = 脉冲时间步 + 1
    总步数 = 总步数 + 1
    定义 可变 输出 = []
    定义 可变 本步放电数 = 0

    定义 可变 i = 0
    当 (i < 脉冲_维度 && i < 输入长度) {
        // 不应期检查
        如果 (不应期计数[i] > 0) {
            不应期计数[i] = 不应期计数[i] - 1
            膜电位[i] = 静息电位
            追加(输出, 0)
            i = i + 1
            继续
        }

        // 泄漏: V = V × 衰减 / 1000
        膜电位[i] = 膜电位[i] * 衰减系数 / 1000

        // 积分: V += I
        膜电位[i] = 膜电位[i] + 输入电流[i]

        // 放电检测
        如果 (膜电位[i] >= 自适应阈值[i]) {
            // 放电!
            追加(输出, 1000)
            膜电位[i] = 静息电位  // 复位
            不应期计数[i] = 不应期长度
            累计放电[i] = 累计放电[i] + 1
            总放电次数 = 总放电次数 + 1
            本步放电数 = 本步放电数 + 1
            上次脉冲[i] = 1

            // 自适应阈值: 放电后阈值升高(频率适应)
            自适应阈值[i] = 自适应阈值[i] + 适应增量
        } 否则 {
            追加(输出, 0)
            上次脉冲[i] = 0
            // 阈值恢复
            如果 (自适应阈值[i] > 放电阈值_基础) {
                自适应阈值[i] = 自适应阈值[i] - 适应恢复
            }
        }
        i = i + 1
    }

    // 记录脉冲历史
    追加(脉冲历史, 本步放电数)
    如果 (计数(脉冲历史) > 脉冲历史窗口) { 链表_删除(脉冲历史, 0) }

    // 侧抑制: 赢者通吃
    如果 (本步放电数 > 脉冲_维度 / 4) {
        脉冲_侧抑制(输出)
    }

    返回 输出
}


函数 脉冲_侧抑制(输出) {
    // 找到最强放电的神经元, 抑制其他
    定义 可变 最强 = -1
    定义 可变 最强值 = 0
    定义 可变 i = 0
    当 (i < 计数(输出)) {
        如果 (输出[i] > 最强值) { 最强值 = 输出[i]; 最强 = i }
        i = i + 1
    }
    // 抑制非最强的
    i = 0
    当 (i < 计数(输出)) {
        如果 (i != 最强 && 输出[i] > 0) {
            膜电位[i] = 膜电位[i] - 抑制强度
            如果 (膜电位[i] < 静息电位) { 膜电位[i] = 静息电位 }
        }
        i = i + 1
    }
}


函数 脉冲_放电率(神经元索引) {
    如果 (神经元索引 >= 脉冲_维度 || 总步数 == 0) { 返回 0 }
    返回 累计放电[神经元索引] * 1000 / 总步数
}

函数 脉冲_群体放电率() {
    如果 (总步数 == 0) { 返回 0 }
    返回 总放电次数 * 1000 / (总步数 * 脉冲_维度)
}


函数 脉冲_稀疏度() {
    // 最近一步中沉默的神经元占比
    定义 可变 沉默 = 0
    定义 可变 i = 0
    当 (i < 脉冲_维度) {
        如果 (上次脉冲[i] == 0) { 沉默 = 沉默 + 1 }
        i = i + 1
    }
    返回 沉默 * 1000 / 脉冲_维度  // ×1000
}

函数 脉冲_统计() {
    返回 {
        总放电: 总放电次数,
        总步数: 总步数,
        稀疏度: 脉冲_稀疏度(),
        群体放电率: 脉冲_群体放电率()
    }
}


函数 脉冲_神经元状态名(索引) {
    如果 (索引 >= 脉冲_维度) { 返回 "invalid" }
    如果 (不应期计数[索引] > 0) { 返回 "refractory" }
    如果 (膜电位[索引] >= 自适应阈值[索引] * 80 / 100) { 返回 "near_threshold" }
    如果 (膜电位[索引] > 静息电位 + 100) { 返回 "excited" }
    返回 "resting"
}

函数 脉冲_完整统计() {
    返回 [总放电次数, 总步数, 脉冲_稀疏度(), 脉冲_群体放电率(), 脉冲_维度]
}

// §6 IDBKeyRange — 键范围 (NIKR: Nova Indexed Key Range 理论)
// 【NIKR理论】Nova索引键范围理论
//   核心公式: RangeSelectivity = (upper - lower) / (max - min)
//   交集效率: Intersect(R1,R2) = max(R1.lo,R2.lo) .. min(R1.hi,R2.hi)
//   AI选择度估计: S_ai = σ(w·Features) 用于查询优化器代价评估
//   键编码: TypeTag(4bit) + Length(12bit) + Payload(变长) 保序编码
//   复合键比较: lexicographic(k1[0..n], k2[0..n]) 字典序逐分量

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/内核打印.nova")
导入("../推理/值乘.nova")
导入("../中枢/辅助存根.nova")
导入("../推理/小整数快速判.nova")
导入("../中枢/字符串替换.nova")

// §6.1 常量定义
定义 NIKR_版本 = 1
定义 键类型_无效   = 0
定义 键类型_数值   = 1   // IDB规范: number
定义 键类型_日期   = 2   // IDB规范: Date
定义 键类型_字符串 = 3   // IDB规范: string
定义 键类型_二进制 = 4   // IDB规范: binary (ArrayBuffer)
定义 键类型_数组   = 5   // IDB规范: Array (复合键)

// 键类型优先级 (IDB规范 §3.1.3): 数组 > 二进制 > 字符串 > 日期 > 数值
定义 键优先级_数值   = 1
定义 键优先级_日期   = 2
定义 键优先级_字符串 = 3
定义 键优先级_二进制 = 4
定义 键优先级_数组   = 5

定义 范围_无界 = 0xFFFFFFFF   // 表示无上/下界
定义 最大键路径深度 = 16      // 键路径嵌套深度限制
定义 最大复合键分量 = 32      // 复合键最多32个分量
定义 最大编码键长 = 4096       // 编码后最大字节
定义 游标_前进 = 0
定义 游标_后退 = 1
定义 游标_前进唯一 = 2
定义 游标_后退唯一 = 3

// §6.2 全局统计计数器
定义 可变 NIKR_范围创建计数 = 0
定义 可变 NIKR_包含测试计数 = 0
定义 可变 NIKR_键比较计数 = 0
定义 可变 NIKR_游标扫描计数 = 0
定义 可变 NIKR_交集计算计数 = 0
定义 可变 NIKR_编码操作计数 = 0
定义 可变 NIKR_AI预测计数 = 0
定义 可变 NIKR_AI命中计数 = 0
定义 可变 NIKR_错误计数 = 0

// §6.3 核心结构体

// 类型化键: 携带类型标签的键值
结构 IDB键 {
    类型,       // u32 键类型_*
    数值,       // i64 当类型为数值/日期
    字符串值,   // u64 字符串指针
    二进制值,   // u64 ArrayBuffer指针
    二进制长度,
    子键,       // u64 IDB键* 数组 (复合键)
    子键数,
}

结构 IDBKeyRange {
    下界,       // u64 IDB键*
    上界,       // u64 IDB键*
    下界开,     // 布尔 lowerOpen (不包含下界)
    上界开,     // 布尔 upperOpen (不包含上界)
    是无界下,   // 布尔 下界无穷小
    是无界上,   // 布尔 上界无穷大
    选择度,     // u32 AI估计的选择度 (0..10000 表示0%..100%)
}

结构 IDBRequest {
    结果,
    错误,
    错误码,
    onsuccess,  // u64 回调
    onerror,    // u64 回调
    就绪状态,   // u32 0=pending 1=done
    事务,       // u64 所属事务
    源对象,     // u64 发起请求的store/index
}

// 游标: 范围迭代器
结构 IDB游标 {
    范围,       // u64 IDBKeyRange*
    方向,       // u32 游标_前进/后退/前进唯一/后退唯一
    当前键,     // u64 IDB键*
    当前主键,   // u64 IDB键* (索引游标时与当前键不同)
    当前值,     // u64 存储的值
    已结束,
    索引引用,   // u64 使用的索引
    迭代计数,
    源存储,     // u64 对象存储引用
}

// 键路径: 解析后的路径分量
结构 键路径 {
    分量,       // [16]u64 路径分量字符串
    分量数,
    是数组路径, // 布尔 多键路径
}

// 编码键: 保序二进制编码
结构 编码键 {
    数据,       // [4096]u8
    长度,
}

// §6.4 IDB键创建与类型系统


函数 IDB键_创建_数值(值) {
    定义 k = 堆_分配(IDB键)
    k.类型 = 键类型_数值
    k.数值 = 值
    k.字符串值 = 0; k.二进制值 = 0; k.二进制长度 = 0
    k.子键 = 0; k.子键数 = 0
    返回 k
}

函数 IDB键_创建_字符串(值) {
    定义 k = 堆_分配(IDB键)
    k.类型 = 键类型_字符串
    k.字符串值 = 字符串_复制(值)
    k.数值 = 0; k.二进制值 = 0; k.二进制长度 = 0
    k.子键 = 0; k.子键数 = 0
    返回 k
}

函数 IDB键_创建_日期(时间戳) {
    定义 k = 堆_分配(IDB键)
    k.类型 = 键类型_日期
    k.数值 = 时间戳
    k.字符串值 = 0; k.二进制值 = 0; k.二进制长度 = 0
    k.子键 = 0; k.子键数 = 0
    返回 k
}

函数 IDB键_创建_二进制(缓冲区, 长度) {
    定义 k = 堆_分配(IDB键)
    k.类型 = 键类型_二进制
    k.二进制值 = 缓冲区; k.二进制长度 = 长度
    k.数值 = 0; k.字符串值 = 0
    k.子键 = 0; k.子键数 = 0
    返回 k
}

函数 IDB键_创建_数组(容量) {
    定义 k = 堆_分配(IDB键)
    k.类型 = 键类型_数组
    如果 (容量 > 最大复合键分量) { 容量 = 最大复合键分量 }
    k.子键 = 堆_分配_数组(容量 * 8)
    k.子键数 = 0
    k.数值 = 0; k.字符串值 = 0; k.二进制值 = 0; k.二进制长度 = 0
    返回 k
}

函数 IDB键_数组追加(数组键, 子键) {
    如果 (数组键 == 0 || 数组键.类型 != 键类型_数组) { 返回 假 }
    如果 (数组键.子键数 >= 最大复合键分量) { 返回 假 }
    内存_写64(数组键.子键 + 数组键.子键数 * 8, 子键)
    数组键.子键数 = 数组键.子键数 + 1
    返回 真
}

函数 IDB键_获取优先级(键) {
    如果 (键 == 0) { 返回 0 }
    如果 (键.类型 == 键类型_数值) { 返回 键优先级_数值 }
    如果 (键.类型 == 键类型_日期) { 返回 键优先级_日期 }
    如果 (键.类型 == 键类型_字符串) { 返回 键优先级_字符串 }
    如果 (键.类型 == 键类型_二进制) { 返回 键优先级_二进制 }
    如果 (键.类型 == 键类型_数组) { 返回 键优先级_数组 }
    返回 0
}

函数 IDB键_释放(键) {
    如果 (键 == 0) { 返回 }
    如果 (键.类型 == 键类型_字符串 && 键.字符串值 != 0) {
        堆_释放(键.字符串值)
    }
    如果 (键.类型 == 键类型_数组 && 键.子键 != 0) {
        定义 可变 i = 0
        当 (i < 键.子键数) {
            定义 子 = 内存_读64(键.子键 + i * 8)
            IDB键_释放(子)
            i = i + 1
        }
        堆_释放(键.子键)
    }
    堆_释放(键)
}

// §6.5 键比较 — IDB规范 §3.1.3 完整实现
// NIKR公式: cmp(a,b) = pri(a)!=pri(b) ? sign(pri(a)-pri(b)) : cmp_typed(a,b)

函数 IDB_比较键(a, b) {
    NIKR_键比较计数 = NIKR_键比较计数 + 1
    如果 (a == 0 && b == 0) { 返回 0 }
    如果 (a == 0) { 返回 -1 }
    如果 (b == 0) { 返回 1 }
    // 类型优先级不同: 按优先级排序
    定义 优a = IDB键_获取优先级(a)
    定义 优b = IDB键_获取优先级(b)
    如果 (优a != 优b) {
        如果 (优a < 优b) { 返回 -1 }
        返回 1
    }
    // 同类型比较
    如果 (a.类型 == 键类型_数值 || a.类型 == 键类型_日期) {
        如果 (a.数值 < b.数值) { 返回 -1 }
        如果 (a.数值 > b.数值) { 返回 1 }
        返回 0
    }
    如果 (a.类型 == 键类型_字符串) {
        返回 IDB_比较字符串(a.字符串值, b.字符串值)
    }
    如果 (a.类型 == 键类型_二进制) {
        返回 IDB_比较二进制(a.二进制值, a.二进制长度, b.二进制值, b.二进制长度)
    }
    如果 (a.类型 == 键类型_数组) {
        返回 IDB_比较数组键(a, b)
    }
    返回 0
}

函数 IDB_比较字符串(s1, s2) {
    如果 (s1 == 0 && s2 == 0) { 返回 0 }
    如果 (s1 == 0) { 返回 -1 }
    如果 (s2 == 0) { 返回 1 }
    定义 len1 = 字符串_长度(s1)
    定义 len2 = 字符串_长度(s2)
    定义 最小长 = len1
    如果 (len2 < 最小长) { 最小长 = len2 }
    定义 可变 i = 0
    当 (i < 最小长) {
        定义 c1 = 内存_读8(s1 + i)
        定义 c2 = 内存_读8(s2 + i)
        如果 (c1 < c2) { 返回 -1 }
        如果 (c1 > c2) { 返回 1 }
        i = i + 1
    }
    如果 (len1 < len2) { 返回 -1 }
    如果 (len1 > len2) { 返回 1 }
    返回 0
}

函数 IDB_比较二进制(b1, len1, b2, len2) {
    定义 最小长 = len1
    如果 (len2 < 最小长) { 最小长 = len2 }
    定义 可变 i = 0
    当 (i < 最小长) {
        定义 v1 = 内存_读8(b1 + i)
        定义 v2 = 内存_读8(b2 + i)
        如果 (v1 < v2) { 返回 -1 }
        如果 (v1 > v2) { 返回 1 }
        i = i + 1
    }
    如果 (len1 < len2) { 返回 -1 }
    如果 (len1 > len2) { 返回 1 }
    返回 0
}

函数 IDB_比较数组键(a, b) {
    // 字典序逐分量比较
    定义 最小数 = a.子键数
    如果 (b.子键数 < 最小数) { 最小数 = b.子键数 }
    定义 可变 i = 0
    当 (i < 最小数) {
        定义 子a = 内存_读64(a.子键 + i * 8)
        定义 子b = 内存_读64(b.子键 + i * 8)
        定义 cmp = IDB_比较键(子a, 子b)
        如果 (cmp != 0) { 返回 cmp }
        i = i + 1
    }
    如果 (a.子键数 < b.子键数) { 返回 -1 }
    如果 (a.子键数 > b.子键数) { 返回 1 }
    返回 0
}

// §6.6 IDBKeyRange 创建方法

函数 IDBKeyRange_only(值) {
    NIKR_范围创建计数 = NIKR_范围创建计数 + 1
    定义 r = 堆_分配(IDBKeyRange)
    r.下界 = 值; r.上界 = 值
    r.下界开 = 假; r.上界开 = 假
    r.是无界下 = 假; r.是无界上 = 假
    r.选择度 = 1   // 精确匹配, 选择度极低
    返回 r
}

函数 IDBKeyRange_bound(下, 上, 下开, 上开) {
    NIKR_范围创建计数 = NIKR_范围创建计数 + 1
    // 验证: 下界必须 <= 上界
    定义 cmp = IDB_比较键(下, 上)
    如果 (cmp > 0) {
        NIKR_错误计数 = NIKR_错误计数 + 1
        返回 0   // DataError: lower > upper
    }
    如果 (cmp == 0 && (下开 || 上开)) {
        NIKR_错误计数 = NIKR_错误计数 + 1
        返回 0   // DataError: equal but open
    }
    定义 r = 堆_分配(IDBKeyRange)
    r.下界 = 下; r.上界 = 上
    r.下界开 = 下开; r.上界开 = 上开
    r.是无界下 = 假; r.是无界上 = 假
    r.选择度 = 5000   // 默认中等选择度
    返回 r
}

函数 IDBKeyRange_lowerBound(下, 开) {
    NIKR_范围创建计数 = NIKR_范围创建计数 + 1
    定义 r = 堆_分配(IDBKeyRange)
    r.下界 = 下; r.上界 = 0
    r.下界开 = 开; r.上界开 = 真
    r.是无界下 = 假; r.是无界上 = 真
    r.选择度 = 7500   // 半开范围, 高选择度
    返回 r
}

函数 IDBKeyRange_upperBound(上, 开) {
    NIKR_范围创建计数 = NIKR_范围创建计数 + 1
    定义 r = 堆_分配(IDBKeyRange)
    r.下界 = 0; r.上界 = 上
    r.下界开 = 真; r.上界开 = 开
    r.是无界下 = 真; r.是无界上 = 假
    r.选择度 = 7500
    返回 r
}

函数 IDBKeyRange_全范围() {
    NIKR_范围创建计数 = NIKR_范围创建计数 + 1
    定义 r = 堆_分配(IDBKeyRange)
    r.下界 = 0; r.上界 = 0
    r.下界开 = 真; r.上界开 = 真
    r.是无界下 = 真; r.是无界上 = 真
    r.选择度 = 10000   // 全表扫描
    返回 r
}

函数 IDBKeyRange_释放(范围) {
    如果 (范围 == 0) { 返回 }
    堆_释放(范围)
}

// §6.7 范围包含测试 — includes()

函数 IDBKeyRange_includes(范围, 键) {
    NIKR_包含测试计数 = NIKR_包含测试计数 + 1
    如果 (范围 == 0) { 返回 真 }   // null范围匹配所有
    如果 (键 == 0) { 返回 假 }
    // 检查下界
    如果 (!范围.是无界下 && 范围.下界 != 0) {
        定义 cmp = IDB_比较键(键, 范围.下界)
        如果 (范围.下界开 && cmp <= 0) { 返回 假 }
        如果 (!范围.下界开 && cmp < 0) { 返回 假 }
    }
    // 检查上界
    如果 (!范围.是无界上 && 范围.上界 != 0) {
        定义 cmp = IDB_比较键(键, 范围.上界)
        如果 (范围.上界开 && cmp >= 0) { 返回 假 }
        如果 (!范围.上界开 && cmp > 0) { 返回 假 }
    }
    返回 真
}

// §6.8 范围集合运算 — 交集/并集/补集
// NIKR公式: Intersect(R1,R2).lo = max(R1.lo, R2.lo)
//           Intersect(R1,R2).hi = min(R1.hi, R2.hi)

函数 IDBKeyRange_交集(范围1, 范围2) {
    NIKR_交集计算计数 = NIKR_交集计算计数 + 1
    如果 (范围1 == 0) { 返回 范围2 }
    如果 (范围2 == 0) { 返回 范围1 }
    // 计算新下界: max(lo1, lo2)
    定义 新下界 = 0
    定义 新下开 = 假
    定义 新无界下 = 假
    如果 (范围1.是无界下 && 范围2.是无界下) {
        新无界下 = 真
    } 否则 如果 (范围1.是无界下) {
        新下界 = 范围2.下界; 新下开 = 范围2.下界开
    } 否则 如果 (范围2.是无界下) {
        新下界 = 范围1.下界; 新下开 = 范围1.下界开
    } 否则 {
        定义 cmp = IDB_比较键(范围1.下界, 范围2.下界)
        如果 (cmp > 0) {
            新下界 = 范围1.下界; 新下开 = 范围1.下界开
        } 否则 如果 (cmp < 0) {
            新下界 = 范围2.下界; 新下开 = 范围2.下界开
        } 否则 {
            新下界 = 范围1.下界
            新下开 = 范围1.下界开 || 范围2.下界开  // 任一开则开
        }
    }
    // 计算新上界: min(hi1, hi2)
    定义 新上界 = 0
    定义 新上开 = 假
    定义 新无界上 = 假
    如果 (范围1.是无界上 && 范围2.是无界上) {
        新无界上 = 真
    } 否则 如果 (范围1.是无界上) {
        新上界 = 范围2.上界; 新上开 = 范围2.上界开
    } 否则 如果 (范围2.是无界上) {
        新上界 = 范围1.上界; 新上开 = 范围1.上界开
    } 否则 {
        定义 cmp = IDB_比较键(范围1.上界, 范围2.上界)
        如果 (cmp < 0) {
            新上界 = 范围1.上界; 新上开 = 范围1.上界开
        } 否则 如果 (cmp > 0) {
            新上界 = 范围2.上界; 新上开 = 范围2.上界开
        } 否则 {
            新上界 = 范围1.上界
            新上开 = 范围1.上界开 || 范围2.上界开
        }
    }
    // 验证交集非空
    如果 (!新无界下 && !新无界上 && 新下界 != 0 && 新上界 != 0) {
        定义 cmp = IDB_比较键(新下界, 新上界)
        如果 (cmp > 0) { 返回 0 }  // 空交集
        如果 (cmp == 0 && (新下开 || 新上开)) { 返回 0 }
    }
    定义 r = 堆_分配(IDBKeyRange)
    r.下界 = 新下界; r.上界 = 新上界
    r.下界开 = 新下开; r.上界开 = 新上开
    r.是无界下 = 新无界下; r.是无界上 = 新无界上
    r.选择度 = 0
    返回 r
}

函数 IDBKeyRange_是否重叠(范围1, 范围2) {
    定义 交集 = IDBKeyRange_交集(范围1, 范围2)
    如果 (交集 == 0) { 返回 假 }
    如果 (交集 != 范围1 && 交集 != 范围2) {
        IDBKeyRange_释放(交集)
    }
    返回 真
}

函数 IDBKeyRange_是否子集(子范围, 父范围) {
    // 子范围的下界 >= 父范围的下界, 上界 <= 父范围的上界
    如果 (父范围 == 0) { 返回 真 }  // null范围包含一切
    如果 (子范围 == 0) { 返回 假 }
    // 检查下界
    如果 (!父范围.是无界下) {
        如果 (子范围.是无界下) { 返回 假 }
        定义 cmp = IDB_比较键(子范围.下界, 父范围.下界)
        如果 (cmp < 0) { 返回 假 }
        如果 (cmp == 0 && 父范围.下界开 && !子范围.下界开) { 返回 假 }
    }
    // 检查上界
    如果 (!父范围.是无界上) {
        如果 (子范围.是无界上) { 返回 假 }
        定义 cmp = IDB_比较键(子范围.上界, 父范围.上界)
        如果 (cmp > 0) { 返回 假 }
        如果 (cmp == 0 && 父范围.上界开 && !子范围.上界开) { 返回 假 }
    }
    返回 真
}

// §6.9 键路径解析

函数 键路径_解析(路径字符串) {
    如果 (路径字符串 == 0) { 返回 0 }
    定义 kp = 堆_分配(键路径)
    kp.分量数 = 0
    kp.是数组路径 = 假
    定义 长度 = 字符串_长度(路径字符串)
    如果 (长度 == 0) { 返回 kp }
    // 按'.'分割路径: "a.b.c" → ["a", "b", "c"]
    定义 可变 起始 = 0
    定义 可变 i = 0
    当 (i <= 长度 && kp.分量数 < 最大键路径深度) {
        定义 ch = 0
        如果 (i < 长度) { ch = 内存_读8(路径字符串 + i) }
        如果 (ch == 46 || i == 长度) {  // '.' = 46
            如果 (i > 起始) {
                定义 分量长 = i - 起始
                定义 分量 = 堆_分配_数组(分量长 + 1)
                内存_复制(分量, 路径字符串 + 起始, 分量长)
                内存_写8(分量 + 分量长, 0)
                kp.分量[kp.分量数] = 分量
                kp.分量数 = kp.分量数 + 1
            }
            起始 = i + 1
        }
        i = i + 1
    }
    返回 kp
}

函数 IDB_提取键(对象, 键路径) {
    如果 (对象 == 0 || 键路径 == 0) { 返回 0 }
    定义 kp = 键路径_解析(键路径)
    如果 (kp == 0 || kp.分量数 == 0) { 返回 0 }
    定义 可变 当前 = 对象
    定义 可变 i = 0
    当 (i < kp.分量数) {
        当前 = Nova对象_获取属性(0, 当前, kp.分量[i])
        如果 (当前 == 0) { 返回 0 }  // 路径中断
        i = i + 1
    }
    返回 当前
}

函数 IDB_提取键_多路径(对象, 路径数组, 路径数) {
    // 多键路径: 从对象提取多个键组合为复合键
    如果 (对象 == 0 || 路径数组 == 0 || 路径数 == 0) { 返回 0 }
    定义 复合 = IDB键_创建_数组(路径数)
    定义 可变 i = 0
    当 (i < 路径数) {
        定义 路径 = 内存_读64(路径数组 + i * 8)
        定义 值 = IDB_提取键(对象, 路径)
        如果 (值 == 0) {
            IDB键_释放(复合)
            返回 0   // 任一路径无效则整体无效
        }
        IDB键_数组追加(复合, 值)
        i = i + 1
    }
    返回 复合
}

// §6.10 保序键编码 (用于B+树存储)
// NIKR编码: TypeTag(1byte) + 类型特定编码
// 编码保持字典序 = 键比较序, 使B+树可直接用memcmp

函数 IDB键_编码(键, 输出) {
    NIKR_编码操作计数 = NIKR_编码操作计数 + 1
    如果 (键 == 0 || 输出 == 0) { 返回 0 }
    输出.长度 = 0
    返回 IDB键_编码_递归(键, 输出)
}

函数 IDB键_编码_递归(键, 输出) {
    如果 (输出.长度 >= 最大编码键长 - 16) { 返回 假 }
    // 写入类型标签 (按优先级排序使类型标签本身保序)
    如果 (键.类型 == 键类型_数值) {
        内存_写8(输出.数据 + 输出.长度, 0x10)
        输出.长度 = 输出.长度 + 1
        // 将有符号整数编码为无符号保序: val ^ 0x8000000000000000
        定义 编码值 = 键.数值 ^ 0x8000000000000000
        定义 可变 b = 7
        当 (b >= 0) {
            内存_写8(输出.数据 + 输出.长度, (编码值 >> (b * 8)) & 0xFF)
            输出.长度 = 输出.长度 + 1
            b = b - 1
        }
        返回 真
    }
    如果 (键.类型 == 键类型_日期) {
        内存_写8(输出.数据 + 输出.长度, 0x20)
        输出.长度 = 输出.长度 + 1
        定义 编码值 = 键.数值 ^ 0x8000000000000000
        定义 可变 b = 7
        当 (b >= 0) {
            内存_写8(输出.数据 + 输出.长度, (编码值 >> (b * 8)) & 0xFF)
            输出.长度 = 输出.长度 + 1
            b = b - 1
        }
        返回 真
    }
    如果 (键.类型 == 键类型_字符串) {
        内存_写8(输出.数据 + 输出.长度, 0x30)
        输出.长度 = 输出.长度 + 1
        // 字节填充编码: 每字节 0x00→0x00 0x01, 结尾 0x00 0x00
        定义 len = 字符串_长度(键.字符串值)
        定义 可变 i = 0
        当 (i < len && 输出.长度 < 最大编码键长 - 4) {
            定义 ch = 内存_读8(键.字符串值 + i)
            如果 (ch == 0) {
                内存_写8(输出.数据 + 输出.长度, 0x00)
                内存_写8(输出.数据 + 输出.长度 + 1, 0x01)
                输出.长度 = 输出.长度 + 2
            } 否则 {
                内存_写8(输出.数据 + 输出.长度, ch)
                输出.长度 = 输出.长度 + 1
            }
            i = i + 1
        }
        // 结尾标记
        内存_写8(输出.数据 + 输出.长度, 0x00)
        内存_写8(输出.数据 + 输出.长度 + 1, 0x00)
        输出.长度 = 输出.长度 + 2
        返回 真
    }
    如果 (键.类型 == 键类型_二进制) {
        内存_写8(输出.数据 + 输出.长度, 0x40)
        输出.长度 = 输出.长度 + 1
        定义 可变 i = 0
        当 (i < 键.二进制长度 && 输出.长度 < 最大编码键长 - 4) {
            定义 v = 内存_读8(键.二进制值 + i)
            如果 (v == 0) {
                内存_写8(输出.数据 + 输出.长度, 0x00)
                内存_写8(输出.数据 + 输出.长度 + 1, 0x01)
                输出.长度 = 输出.长度 + 2
            } 否则 {
                内存_写8(输出.数据 + 输出.长度, v)
                输出.长度 = 输出.长度 + 1
            }
            i = i + 1
        }
        内存_写8(输出.数据 + 输出.长度, 0x00)
        内存_写8(输出.数据 + 输出.长度 + 1, 0x00)
        输出.长度 = 输出.长度 + 2
        返回 真
    }
    如果 (键.类型 == 键类型_数组) {
        内存_写8(输出.数据 + 输出.长度, 0x50)
        输出.长度 = 输出.长度 + 1
        定义 可变 i = 0
        当 (i < 键.子键数) {
            定义 子 = 内存_读64(键.子键 + i * 8)
            如果 (!IDB键_编码_递归(子, 输出)) { 返回 假 }
            i = i + 1
        }
        内存_写8(输出.数据 + 输出.长度, 0x00)  // 数组结尾
        输出.长度 = 输出.长度 + 1
        返回 真
    }
    返回 假
}

// §6.11 IDB游标 — 范围迭代

函数 IDB游标_创建(范围, 方向, 索引, 源) {
    定义 c = 堆_分配(IDB游标)
    c.范围 = 范围
    c.方向 = 方向
    c.当前键 = 0; c.当前主键 = 0; c.当前值 = 0
    c.已结束 = 假
    c.索引引用 = 索引
    c.迭代计数 = 0
    c.源存储 = 源
    NIKR_游标扫描计数 = NIKR_游标扫描计数 + 1
    返回 c
}

函数 IDB游标_前进(游标) {
    如果 (游标 == 0 || 游标.已结束) { 返回 假 }
    游标.迭代计数 = 游标.迭代计数 + 1
    // 从B+树获取下一个/上一个键
    如果 (游标.方向 == 游标_前进 || 游标.方向 == 游标_前进唯一) {
        定义 下一 = IDB索引_下一键(游标.索引引用, 游标.当前键)
        如果 (下一 == 0) { 游标.已结束 = 真; 返回 假 }
        // 唯一方向: 跳过重复键
        如果 (游标.方向 == 游标_前进唯一) {
            当 (下一 != 0 && IDB_比较键(下一, 游标.当前键) == 0) {
                下一 = IDB索引_下一键(游标.索引引用, 下一)
            }
        }
        如果 (下一 == 0) { 游标.已结束 = 真; 返回 假 }
        // 检查是否仍在范围内
        如果 (!IDBKeyRange_includes(游标.范围, 下一)) {
            游标.已结束 = 真; 返回 假
        }
        游标.当前键 = 下一
    } 否则 {
        定义 前一 = IDB索引_前一键(游标.索引引用, 游标.当前键)
        如果 (前一 == 0) { 游标.已结束 = 真; 返回 假 }
        如果 (游标.方向 == 游标_后退唯一) {
            当 (前一 != 0 && IDB_比较键(前一, 游标.当前键) == 0) {
                前一 = IDB索引_前一键(游标.索引引用, 前一)
            }
        }
        如果 (前一 == 0) { 游标.已结束 = 真; 返回 假 }
        如果 (!IDBKeyRange_includes(游标.范围, 前一)) {
            游标.已结束 = 真; 返回 假
        }
        游标.当前键 = 前一
    }
    返回 真
}

函数 IDB游标_continue到(游标, 目标键) {
    如果 (游标 == 0 || 游标.已结束 || 目标键 == 0) { 返回 假 }
    // 验证方向一致性
    如果 (游标.方向 == 游标_前进 || 游标.方向 == 游标_前进唯一) {
        如果 (IDB_比较键(目标键, 游标.当前键) <= 0) { 返回 假 }
    } 否则 {
        如果 (IDB_比较键(目标键, 游标.当前键) >= 0) { 返回 假 }
    }
    // 跳跃到目标键
    游标.当前键 = IDB索引_查找键(游标.索引引用, 目标键)
    如果 (游标.当前键 == 0 || !IDBKeyRange_includes(游标.范围, 游标.当前键)) {
        游标.已结束 = 真; 返回 假
    }
    返回 真
}

函数 IDB游标_释放(游标) {
    如果 (游标 == 0) { 返回 }
    堆_释放(游标)
}

// §6.12 IDBRequest 请求管理

函数 IDBRequest_创建() {
    定义 r = 堆_分配(IDBRequest)
    r.结果 = 0; r.错误 = 0; r.错误码 = 0
    r.onsuccess = 0; r.onerror = 0
    r.就绪状态 = 0; r.事务 = 0; r.源对象 = 0
    返回 r
}

函数 IDBRequest_创建_成功(结果) {
    定义 r = IDBRequest_创建()
    r.结果 = 结果; r.就绪状态 = 1
    返回 r
}

函数 IDBRequest_完成_成功(请求, 结果) {
    如果 (请求 == 0) { 返回 }
    请求.结果 = 结果; 请求.就绪状态 = 1
    如果 (请求.onsuccess != 0) {
        // 异步派发success事件
        Nova事件_异步派发(请求.onsuccess, 请求)
    }
}

函数 IDBRequest_完成_失败(请求, 错误码) {
    如果 (请求 == 0) { 返回 }
    请求.错误码 = 错误码; 请求.就绪状态 = 1
    如果 (请求.onerror != 0) {
        Nova事件_异步派发(请求.onerror, 请求)
    }
}

// §6.13 AI智能查询优化 — NIKR核心创新
// NIKR-AI公式:
//   选择度估计: S = σ(w0 + w1·范围宽度 + w2·键分布偏度 + w3·历史命中率)
//   扫描代价: Cost = S·N·(磁盘IO + CPU比较)
//   优化决策: if Cost(范围扫描) < Cost(全表扫描) then 使用索引

函数 智能_IndexedDB_AI初始化() {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 }
    // 注册NIKR模块到AI总线
    定义 t = Tensor_创建(8)
    Tensor_写(t, 0, NIKR_版本)
    Tensor_写(t, 1, NIKR_范围创建计数)
    Tensor_写(t, 2, NIKR_包含测试计数)
    Tensor_写(t, 3, NIKR_键比较计数)
    Tensor_写(t, 4, NIKR_游标扫描计数)
    Tensor_写(t, 5, NIKR_交集计算计数)
    Tensor_写(t, 6, NIKR_编码操作计数)
    Tensor_写(t, 7, NIKR_AI预测计数)
    AI总线_推理(bus, "NIKR_模块注册", t)
    Tensor_释放(t)
}

函数 NIKR_AI估计选择度(范围, 总记录数, 键分布) {
    NIKR_AI预测计数 = NIKR_AI预测计数 + 1
    如果 (范围 == 0 || 总记录数 == 0) { 返回 10000 }  // 全表
    定义 bus = 全局AI总线
    如果 (bus == 0) {
        // 回退: 简单线性估计
        如果 (范围.是无界下 && 范围.是无界上) { 返回 10000 }
        返回 5000  // 默认50%
    }
    // 构建特征向量: [范围类型, 是否精确, 是否半开, 总记录, 分布偏度, 历史命中率]
    定义 t = Tensor_创建(6)
    定义 范围类型 = 0
    如果 (范围.是无界下 && 范围.是无界上) { 范围类型 = 3 }
    否则 如果 (范围.是无界下 || 范围.是无界上) { 范围类型 = 2 }
    否则 如果 (范围.下界开 == 假 && 范围.上界开 == 假) {
        定义 cmp = IDB_比较键(范围.下界, 范围.上界)
        如果 (cmp == 0) { 范围类型 = 0 }  // 精确匹配
        否则 { 范围类型 = 1 }  // 闭区间
    } 否则 { 范围类型 = 1 }
    Tensor_写(t, 0, 范围类型)
    Tensor_写(t, 1, 总记录数)
    Tensor_写(t, 2, 键分布)
    定义 历史命中 = 0
    如果 (NIKR_包含测试计数 > 0) {
        历史命中 = NIKR_AI命中计数 * 10000 / NIKR_包含测试计数
    }
    Tensor_写(t, 3, 历史命中)
    Tensor_写(t, 4, NIKR_游标扫描计数)
    Tensor_写(t, 5, NIKR_键比较计数)
    定义 结果 = AI总线_推理(bus, "NIKR_选择度估计", t)
    Tensor_释放(t)
    如果 (结果 < 0) { 返回 5000 }
    如果 (结果 > 10000) { 返回 10000 }
    NIKR_AI命中计数 = NIKR_AI命中计数 + 1
    返回 结果
}

函数 NIKR_AI建议扫描策略(范围, 总记录数, 索引数) {
    // 返回: 0=全表扫描, 1=索引范围扫描, 2=索引精确查找
    定义 选择度 = NIKR_AI估计选择度(范围, 总记录数, 0)
    如果 (选择度 <= 10) { 返回 2 }       // ≤0.1% 精确查找
    如果 (选择度 <= 3000) { 返回 1 }     // ≤30% 范围扫描
    如果 (索引数 > 0 && 选择度 <= 7000) { 返回 1 }  // 有索引时放宽阈值
    返回 0  // 全表扫描更优
}

函数 NIKR_AI异常检测(操作类型, 键, 范围) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 0 }
    定义 t = Tensor_创建(4)
    Tensor_写(t, 0, 操作类型)
    Tensor_写(t, 1, NIKR_键比较计数)
    Tensor_写(t, 2, NIKR_错误计数)
    Tensor_写(t, 3, NIKR_游标扫描计数)
    定义 风险 = AI总线_风险评分(bus, "NIKR_异常", t)
    Tensor_释放(t)
    返回 风险
}

// §6.14 诊断与统计

函数 NIKR_获取统计() {
    定义 s = 堆_分配_数组(80)
    内存_写64(s + 0, NIKR_范围创建计数)
    内存_写64(s + 8, NIKR_包含测试计数)
    内存_写64(s + 16, NIKR_键比较计数)
    内存_写64(s + 24, NIKR_游标扫描计数)
    内存_写64(s + 32, NIKR_交集计算计数)
    内存_写64(s + 40, NIKR_编码操作计数)
    内存_写64(s + 48, NIKR_AI预测计数)
    内存_写64(s + 56, NIKR_AI命中计数)
    内存_写64(s + 64, NIKR_错误计数)
    返回 s
}

函数 NIKR_重置统计() {
    NIKR_范围创建计数 = 0
    NIKR_包含测试计数 = 0
    NIKR_键比较计数 = 0
    NIKR_游标扫描计数 = 0
    NIKR_交集计算计数 = 0
    NIKR_编码操作计数 = 0
    NIKR_AI预测计数 = 0
    NIKR_AI命中计数 = 0
    NIKR_错误计数 = 0
}

函数 NIKR_诊断打印() {
    内核打印("[NIKR] 范围创建=", NIKR_范围创建计数)
    内核打印("[NIKR] 包含测试=", NIKR_包含测试计数)
    内核打印("[NIKR] 键比较=", NIKR_键比较计数)
    内核打印("[NIKR] 游标扫描=", NIKR_游标扫描计数)
    内核打印("[NIKR] 交集计算=", NIKR_交集计算计数)
    内核打印("[NIKR] 编码操作=", NIKR_编码操作计数)
    内核打印("[NIKR] AI预测=", NIKR_AI预测计数, " 命中=", NIKR_AI命中计数)
    如果 (NIKR_AI预测计数 > 0) {
        定义 命中率 = NIKR_AI命中计数 * 100 / NIKR_AI预测计数
        内核打印("[NIKR] AI命中率=", 命中率, "%")
    }
    内核打印("[NIKR] 错误=", NIKR_错误计数)
}

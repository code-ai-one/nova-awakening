导入("../基础.nova")

// 压入 = "给"字操作, pop = "把"字消费, peek = "被"字借用

// 双端队列: [数据, 头, 尾, 容量, 大小]
函数 deque_创建(容量) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(数据, 0) i = i + 1 }
 返回 [数据, 0, 容量, 0]
}

函数 deque_头插(dq, 值) {
    如果 (dq[4] >= dq[3]) { 返回 0
}
 dq[1] = (dq[1] - 1 + dq[3]) % dq[3]
 dq[0][dq[1]] = 值
 dq[4] = dq[4] + 1
 返回 1
}

函数 deque_尾插(dq, 值) {
    如果 (dq[4] >= dq[3]) { 返回 0
}
 dq[0][dq[2]] = 值
 dq[2] = (dq[2] + 1) % dq[3]
 dq[4] = dq[4] + 1
 返回 1
}

函数 deque_头删(dq) {
    如果 (dq[4] == 0) { 返回 空
}
 定义 值 = dq[0][dq[1]]
 dq[1] = (dq[1] + 1) % dq[3]
 dq[4] = dq[4] - 1
 返回 值
}

函数 deque_尾删(dq) {
    如果 (dq[4] == 0) { 返回 空
}
 dq[2] = (dq[2] - 1 + dq[3]) % dq[3]
 定义 值 = dq[0][dq[2]]
 dq[4] = dq[4] - 1
 返回 值
}

函数 deque_头(dq) {
    如果 (dq[4] == 0) { 返回 空
}
 返回 dq[0][dq[1]]
}

函数 deque_尾(dq) {
    如果 (dq[4] == 0) { 返回 空
}
 定义 索引 = (dq[2] - 1 + dq[3]) % dq[3]
 返回 dq[0][索引]
}

函数 deque_大小(dq) { 返回 dq[4] }
函数 deque_空(dq) { 返回 dq[4] == 0 }

// 最小栈

// 最小栈: [数据栈, 最小栈]
函数 最小栈_创建() { 返回 [[], []] }

函数 最小栈_压入(栈, 值) {
 追加(栈[0], 值)
 定义 最小列 = 栈[1]
 如果 (计数(最小列) == 0 或 值 <= 最小列[计数(最小列) - 1]) {
 追加(最小列, 值)
 } 否则 {
 追加(最小列, 最小列[计数(最小列) - 1])
 }
}

函数 双端队列_最小栈_弹出(栈) {
    如果 (计数(栈[0]) == 0) { 返回 空
}
 定义 值 = 栈[0][计数(栈[0]) - 1]
 删除(栈[0], 计数(栈[0]) - 1)
 删除(栈[1], 计数(栈[1]) - 1)
 返回 值
}

函数 最小栈_最小(栈) {
    如果 (计数(栈[1]) == 0) { 返回 空
}
 返回 栈[1][计数(栈[1]) - 1]
}

函数 最小栈_顶(栈) {
    如果 (计数(栈[0]) == 0) { 返回 空
}
 返回 栈[0][计数(栈[0]) - 1]
}

函数 双端队列_最小栈_大小(栈) { 返回 计数(栈[0]) }

// 单调栈

// 下一个更大元素
函数 单调栈_下一个更大(列表) { 定义 n = 计数(列表)
 定义 可变 结果 = []
 定义 可变 栈 = []
 定义 可变 i = 0
 当 (i < n) { 追加(结果, -1) i = i + 1 }
 i = 0
 当 (i < n) {
 当 (计数(栈) > 0 且 列表[i] > 列表[栈[计数(栈) - 1]]) { 定义 索引 = 栈[计数(栈) - 1]
 删除(栈, 计数(栈) - 1)
 结果[索引] = 列表[i]
 }
 追加(栈, i)
 i = i + 1
 }
 返回 结果
}

// 下一个更小元素
函数 单调栈_下一个更小(列表) { 定义 n = 计数(列表)
 定义 可变 结果 = []
 定义 可变 栈 = []
 定义 可变 i = 0
 当 (i < n) { 追加(结果, -1) i = i + 1 }
 i = 0
 当 (i < n) {
 当 (计数(栈) > 0 且 列表[i] < 列表[栈[计数(栈) - 1]]) { 定义 索引 = 栈[计数(栈) - 1]
 删除(栈, 计数(栈) - 1)
 结果[索引] = 列表[i]
 }
 追加(栈, i)
 i = i + 1
 }
 返回 结果
}

// 直方图最大矩形面积
函数 直方图最大矩形(高度) { 定义 n = 计数(高度)
 定义 可变 栈 = []
 定义 可变 最大面积 = 0
 定义 可变 i = 0
 当 (i <= n) { 定义 可变 h = 0
 如果 (i < n) { h = 高度[i] }
 当 (计数(栈) > 0 且 h < 高度[栈[计数(栈) - 1]]) { 定义 顶idx = 栈[计数(栈) - 1]
 删除(栈, 计数(栈) - 1)
 定义 可变 宽 = i
 如果 (计数(栈) > 0) {
 宽 = i - 栈[计数(栈) - 1] - 1
 }
 定义 面积 = 高度[顶idx] * 宽
 如果 (面积 > 最大面积) { 最大面积 = 面积 }
 }
 追加(栈, i)
 i = i + 1
 }
 返回 最大面积
}

// 滑动窗口最大值
函数 滑动窗口最大(列表, k) { 定义 n = 计数(列表)
 定义 可变 结果 = []
 定义 可变 dq = []
 定义 可变 i = 0
 当 (i < n) {
 // 移除超出窗口的
 当 (计数(dq) > 0 且 dq[0] <= i - k) {
 删除(dq)
 }
 // 维护单调递减
 当 (计数(dq) > 0 且 列表[dq[计数(dq) - 1]] <= 列表[i]) {
 删除(dq, 计数(dq) - 1)
 }
 追加(dq, i)
 如果 (i >= k - 1) {
 追加(结果, 列表[dq[0]])
 }
 i = i + 1
 }
 返回 结果
}

// 环形缓冲区双端队列
定义 可变 _环形_数据 = []
定义 可变 _环形_容量 = 0
定义 可变 _环形_头 = 0
定义 可变 _环形_尾 = 0
定义 可变 _环形_大小 = 0

函数 环形双端_创建(容量) { _环形_容量 = 容量
 _环形_头 = 0
 _环形_尾 = 0
 _环形_大小 = 0
 _环形_数据 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(_环形_数据, 0) i = i + 1 }
}

函数 环形双端_前插(值) {
    如果 (_环形_大小 >= _环形_容量) { 返回 假
}
 _环形_头 = (_环形_头 - 1 + _环形_容量) % _环形_容量
 _环形_数据[_环形_头] = 值
 _环形_大小 = _环形_大小 + 1
 返回 真
}

函数 环形双端_后插(值) {
    如果 (_环形_大小 >= _环形_容量) { 返回 假
}
 _环形_数据[_环形_尾] = 值
 _环形_尾 = (_环形_尾 + 1) % _环形_容量
 _环形_大小 = _环形_大小 + 1
 返回 真
}

函数 环形双端_前删() {
    如果 (_环形_大小 == 0) { 返回 空
}
 定义 值 = _环形_数据[_环形_头]
 _环形_头 = (_环形_头 + 1) % _环形_容量
 _环形_大小 = _环形_大小 - 1
 返回 值
}

函数 环形双端_后删() {
    如果 (_环形_大小 == 0) { 返回 空
}
 _环形_尾 = (_环形_尾 - 1 + _环形_容量) % _环形_容量
 _环形_大小 = _环形_大小 - 1
 返回 _环形_数据[_环形_尾]
}

函数 环形双端_前看() {
    如果 (_环形_大小 == 0) { 返回 空
}
 返回 _环形_数据[_环形_头]
}

函数 环形双端_后看() {
    如果 (_环形_大小 == 0) { 返回 空
}
 返回 _环形_数据[(_环形_尾 - 1 + _环形_容量) % _环形_容量]
}

函数 环形双端_大小() { 返回 _环形_大小 }
函数 环形双端_为空() { 返回 _环形_大小 == 0 }
函数 环形双端_已满() { 返回 _环形_大小 >= _环形_容量 }

函数 环形双端_取(索引) {
    如果 (索引 < 0 或 索引 >= _环形_大小) { 返回 空
}
 返回 _环形_数据[(_环形_头 + 索引) % _环形_容量]
}

函数 环形双端_转列表() { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < _环形_大小) {
 追加(结果, _环形_数据[(_环形_头 + i) % _环形_容量])
 i = i + 1
 }
 返回 结果
}

导入("../基础.nova")
导入("../并发/线程/线程池.nova")


定义 任务_待定 = 0
定义 任务_运行 = 1
定义 任务_完成 = 2
定义 任务_失败 = 3

// 任务: [ID, 状态, 依赖列表, 结果, 重试次数, 最大重试]
定义 可变 任务列表 = []

函数 工作流_任务_创建(id, 最大重试) {
 追加(任务列表, [id, 任务_待定, [], 0, 最大重试])
 返回 计数(任务列表) - 1
}

函数 工作流_任务_添加依赖(任务idx, 依赖idx) { 追加(任务列表[任务idx][2], 依赖idx) }
函数 任务_状态(索引) { 返回 任务列表[索引][1] }
函数 任务_设状态(索引, s) { 任务列表[索引][1] = s }
函数 任务_设结果(索引, r) { 任务列表[索引][3] = r }
函数 任务_结果(索引) { 返回 任务列表[索引][3] }

// 检查依赖是否全部完成
函数 依赖_完成(任务idx) { 定义 依赖 = 任务列表[任务idx][2]
 定义 可变 i = 0
 当 (i < 计数(依赖)) { 如果 (任务列表[依赖[i]][1] != 任务_完成) { 返回 假 }
 i = i + 1
 }
 返回 真
}

// 获取就绪任务
函数 获取就绪任务() { 定义 可变 就绪 = []
 定义 可变 i = 0
 当 (i < 计数(任务列表)) { 如果 (任务列表[i][1] == 任务_待定 且 依赖_完成(i)) { 追加(就绪, i) }
 i = i + 1
 }
 返回 就绪
}

// 拓扑排序
// 重试
函数 任务_重试(索引) { 如果 (任务列表[索引][4] < 任务列表[索引][5]) {
 任务列表[索引][4] = 任务列表[索引][4] + 1
 任务列表[索引][1] = 任务_待定
 返回 真
 }
 返回 假
}

// 管道 (线性任务链)
函数 工作流_管道_创建(任务数, 最大重试) { 定义 可变 起始 = 计数(任务列表)
 定义 可变 i = 0
 当 (i < 任务数) {
 工作流_任务_创建(起始 + i, 最大重试)
 如果 (i > 0) { 工作流_任务_添加依赖(起始 + i, 起始 + i - 1) }
 i = i + 1
 }
 返回 起始
}

// 全部完成？
函数 工作流_全部完成() { 定义 可变 i = 0
 当 (i < 计数(任务列表)) { 如果 (任务列表[i][1] != 任务_完成) { 返回 假 }
 i = i + 1
 }
 返回 真
}

// 工作流统计
// 拓扑排序
函数 工作流_拓扑排序() { 定义 n = 计数(任务列表)
 定义 可变 入度 = []
 定义 可变 i = 0
 当 (i < n) { 追加(入度, 计数(任务列表[i][2]))
 i = i + 1 }
 定义 可变 结果 = []
 定义 可变 已处理 = 0
 当 (已处理 < n) { 定义 可变 找到 = -1
 i = 0
 当 (i < n) { 如果 (入度[i] == 0) { 定义 可变 已在结果 = 假
 定义 可变 k = 0
 当 (k < 计数(结果)) { 如果 (结果[k] == i) { 已在结果 = 真 }
 k = k + 1
 }
 如果 (已在结果 == 假) { 找到 = i
 i = n }
 }
 i = i + 1
 }
 如果 (找到 == -1) { 返回 结果 }
 追加(结果, 找到)
 入度[找到] = -1
 i = 0
 当 (i < n) { 定义 可变 j = 0
 当 (j < 计数(任务列表[i][2])) { 如果 (任务列表[i][2][j] == 找到) { 入度[i] = 入度[i] - 1 }
 j = j + 1
 }
 i = i + 1
 }
 已处理 = 已处理 + 1
 }
 返回 结果
}

// 任务清空
函数 任务_清空() { 任务列表 = [] }

// 有失败任务
函数 有失败任务() { 定义 可变 i = 0
 当 (i < 计数(任务列表)) { 如果 (任务列表[i][1] == 任务_失败) { 返回 真 }
 i = i + 1
 }
 返回 假
}

// 任务进度 (完成百分比)
函数 任务_进度() {
    如果 (计数(任务列表) == 0) { 返回 0
}
 定义 可变 完成 = 0
 定义 可变 i = 0
 当 (i < 计数(任务列表)) { 如果 (任务列表[i][1] == 任务_完成) { 完成 = 完成 + 1 }
 i = i + 1
 }
 返回 完成 * 100 / 计数(任务列表)
}

// AI训练工作流模板
函数 训练工作流_创建() {
 任务_清空()
 定义 数据加载 = 工作流_任务_创建(0, 3) // 数据加载, 重试3次
 定义 预处理 = 工作流_任务_创建(1, 2) // 预处理
 定义 训练 = 工作流_任务_创建(2, 1) // 训练
 定义 评估 = 工作流_任务_创建(3, 1) // 评估
 定义 保存 = 工作流_任务_创建(4, 2) // 保存模型
 定义 部署 = 工作流_任务_创建(5, 1) // 部署
 工作流_任务_添加依赖(预处理, 数据加载)
 工作流_任务_添加依赖(训练, 预处理)
 工作流_任务_添加依赖(评估, 训练)
 工作流_任务_添加依赖(保存, 评估)
 工作流_任务_添加依赖(部署, 保存)
 返回 [数据加载, 预处理, 训练, 评估, 保存, 部署]
}

// 并行分支
函数 并行_创建(任务数, 汇合任务idx, 最大重试) { 定义 可变 分支 = []
 定义 可变 i = 0
 当 (i < 任务数) { 定义 索引 = 工作流_任务_创建(1000 + i, 最大重试)
 追加(分支, 索引)
 如果 (汇合任务idx >= 0) { 工作流_任务_添加依赖(汇合任务idx, 索引) }
 i = i + 1
 }
 返回 分支
}

// 工作流统计
函数 工作流_统计() {
    定义 可变 s0 = 0
    定义 可变 s1 = 0
    定义 可变 s2 = 0
    定义 可变 s3 = 0
    定义 可变 i = 0
    当 (i < 计数(任务列表)) {
        如果 (任务列表[i][1] == 任务_待定) { s0 = s0 + 1 }
        如果 (任务列表[i][1] == 任务_运行) { s1 = s1 + 1 }
        如果 (任务列表[i][1] == 任务_完成) { s2 = s2 + 1 }
        如果 (任务列表[i][1] == 任务_失败) { s3 = s3 + 1 }
        i = i + 1
    }
    返回 [s0, s1, s2, s3]
}

// 工作流报告
函数 工作流_报告() { 定义 stats = 工作流_统计()
 打印("╔═══ 工作流状态 ═══╗")
 打印("║ 总任务: " + 转字符串(计数(任务列表)))
 打印("║ 未定: " + 转字符串(stats[0]) + " 运行: " + 转字符串(stats[1]) + " 完成: " + 转字符串(stats[2]) + " 失败: " + 转字符串(stats[3]))
 打印("║ 进度: " + 转字符串(任务_进度()) + "%")
 如果 (stats[3] > 0) {
 打印("║ ⚠ 有失败任务!")
 }
 打印("╚══════════════════╝")
}

// 任务状态名
函数 任务_状态名(状态) {
    如果 (状态 == 0) { 返回 "未定"
}
 如果 (状态 == 1) { 返回 "运行" }
 如果 (状态 == 2) { 返回 "完成" }
 如果 (状态 == 3) { 返回 "失败" }
 返回 "未知"
}

// 任务依赖(DAG)
定义 可变 _依赖_前 = []
定义 可变 _依赖_后 = []

函数 任务_可执行(任务id) { 定义 可变 i = 0
 当 (i < 计数(_依赖_后)) { 如果 (_依赖_后[i] == 任务id) { 定义 前id = _依赖_前[i]
 如果 (任务列表[前id][1] != 2) { 返回 假 }
 }
 i = i + 1
 }
 返回 真
}

// 就绪任务列表
函数 工作流_就绪任务() { 定义 可变 就绪 = []
 定义 可变 i = 0
 当 (i < 计数(任务列表)) { 如果 (任务列表[i][1] == 0 且 任务_可执行(i)) { 追加(就绪, i) }
 i = i + 1
 }
 返回 就绪
}


导入("./类型定义.nova")
导入("./错误码.nova")

// NovaOS内核 · L0 3D多向突触网格 (移植自Nova大脑L0/synapse)
// 22模块全连接突触矩阵 — 多向×多角度×立体神经绑定
// 连接矩阵: 30×30×4 = 3600条多向连接
// 每条连接4种类型: 兴奋(谷氨酸)/抑制(GABA)/调制(DA/NE)/同步(gap)
// 逐层深度过滤: L2→L3→L4→L5→L6 每层抽象度上升
// 永不遗忘: EWC保护+最小强度底线
// 突触发芽: 协同激活→新连接自动生成


定义 突触_模块数 = 30
定义 突触_连接类型 = 4
定义 突触_兴奋 = 0
定义 突触_抑制 = 1
定义 突触_调制 = 2
定义 突触_同步 = 3

定义 可变 突触_学习率 = 50
定义 可变 突触_衰减率 = 5
定义 可变 突触_最小强度 = 10
定义 可变 突触_最大强度 = 2000
定义 可变 突触_发芽阈值 = 300

定义 过滤_层数 = 5
定义 可变 过滤_保留率 = 700
定义 可变 过滤_强化率 = 200
定义 可变 EWC_强度 = 500
定义 可变 EWC_保护阈值 = 600

// 矩阵[源][目标][类型] = [强度, 延迟, 可塑性, 使用次数, 重要度]

定义 可变 连接矩阵 = []
定义 可变 协同激活计数 = []
定义 可变 突触_已初始化 = 假
定义 可变 突触网格_已初始化 = 假
定义 可变 突触_总传播次数 = 0
定义 可变 突触_总发芽次数 = 0

函数 突触_初始化() {
    连接矩阵 = []
    协同激活计数 = []
    定义 可变 i = 0
    当 (i < 突触_模块数) {
        定义 可变 行 = []
        定义 可变 协同行 = []
        定义 可变 j = 0
        当 (j < 突触_模块数) {
            定义 可变 类型组 = []
            定义 可变 t = 0
            当 (t < 突触_连接类型) {
                // [强度, 延迟, 可塑性, 使用次数, 重要度]
                定义 初始强度 = 100
                如果 (i == j) { 初始强度 = 0 }  // 自连接=0
                追加(类型组, [初始强度, 1, 500, 0, 0])
                t = t + 1
            }
            追加(行, 类型组)
            追加(协同行, 0)
            j = j + 1
        }
        追加(连接矩阵, 行)
        追加(协同激活计数, 协同行)
        i = i + 1
    }
    突触_已初始化 = 真
    突触网格_已初始化 = 真
    内核信息("突触网格: 30×30×4=3600连接 EWC永不遗忘+突触发芽")
}

函数 突触网格_获取连接数据() {
    如果 (!突触_已初始化) { 返回 [] }
    定义 可变 连接数据 = []
    定义 可变 i = 0
    当 (i < 突触_模块数) {
        定义 可变 j = 0
        当 (j < 突触_模块数) {
            定义 可变 t = 0
            当 (t < 突触_连接类型) {
                追加(连接数据, 连接矩阵[i][j][t][0])
                t = t + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 连接数据
}

函数 突触网格_应用连接数据(连接数据) {
    如果 (连接数据 == 空) { 返回 0 }
    如果 (!突触_已初始化) { 突触_初始化() }

    定义 期望长度 = 突触_模块数 * 突触_模块数 * 突触_连接类型
    如果 (计数(连接数据) < 期望长度) { 返回 0 }

    定义 可变 索引 = 0
    定义 可变 i = 0
    当 (i < 突触_模块数) {
        定义 可变 j = 0
        当 (j < 突触_模块数) {
            定义 可变 t = 0
            当 (t < 突触_连接类型) {
                定义 可变 强度 = 连接数据[索引]
                如果 (强度 < 0) { 强度 = 0 }
                如果 (强度 > 突触_最大强度) { 强度 = 突触_最大强度 }
                连接矩阵[i][j][t][0] = 强度
                索引 = 索引 + 1
                t = t + 1
            }
            j = j + 1
        }
        i = i + 1
    }

    突触_已初始化 = 真
    突触网格_已初始化 = 真
    返回 索引
}


函数 突触_传播(源模块, 信号强度) {
    如果 (!突触_已初始化 || 源模块 >= 突触_模块数) { 返回 [] }
    突触_总传播次数 = 突触_总传播次数 + 1
    定义 可变 输出 = []

    定义 可变 j = 0
    当 (j < 突触_模块数) {
        定义 可变 净输入 = 0
        // 兴奋性
        定义 兴奋 = 连接矩阵[源模块][j][突触_兴奋][0]
        // 抑制性
        定义 抑制 = 连接矩阵[源模块][j][突触_抑制][0]
        // 调制性(乘性)
        定义 调制 = 连接矩阵[源模块][j][突触_调制][0]
        // 净输入 = (兴奋 - 抑制) × (1 + 调制/1000) × 信号强度 / 1000
        净输入 = (兴奋 - 抑制) * (1000 + 调制) / 1000 * 信号强度 / 1000

        // 记录使用
        定义 可变 t = 0
        当 (t < 突触_连接类型) {
            连接矩阵[源模块][j][t][3] = 连接矩阵[源模块][j][t][3] + 1
            t = t + 1
        }
        追加(输出, 净输入)
        j = j + 1
    }
    返回 输出
}


函数 突触_赫布更新(源模块, 目标模块, 源活性, 目标活性) {
    如果 (!突触_已初始化) { 返回 }
    // 赫布规则: ΔW = η × pre × post
    定义 增量 = 突触_学习率 * 源活性 * 目标活性 / (1000 * 1000)

    // 更新兴奋性连接
    定义 可变 新强度 = 连接矩阵[源模块][目标模块][突触_兴奋][0] + 增量
    如果 (新强度 > 突触_最大强度) { 新强度 = 突触_最大强度 }
    如果 (新强度 < 突触_最小强度) { 新强度 = 突触_最小强度 }  // 永不归零

    // EWC保护: 重要连接的变化被抑制
    定义 重要度 = 连接矩阵[源模块][目标模块][突触_兴奋][4]
    如果 (重要度 > EWC_保护阈值) {
        定义 保护因子 = EWC_强度 * 重要度 / 1000
        新强度 = 连接矩阵[源模块][目标模块][突触_兴奋][0] +
                  增量 * 1000 / (1000 + 保护因子)
    }
    连接矩阵[源模块][目标模块][突触_兴奋][0] = 新强度

    // 协同激活追踪(用于突触发芽)
    如果 (源活性 > 500 && 目标活性 > 500) {
        协同激活计数[源模块][目标模块] = 协同激活计数[源模块][目标模块] + 1
    }
}


函数 突触_检查发芽() {
    定义 可变 i = 0
    当 (i < 突触_模块数) {
        定义 可变 j = 0
        当 (j < 突触_模块数) {
            如果 (协同激活计数[i][j] > 突触_发芽阈值) {
                // 协同激活频繁→增强调制连接(新功能通道)
                连接矩阵[i][j][突触_调制][0] = 连接矩阵[i][j][突触_调制][0] + 100
                如果 (连接矩阵[i][j][突触_调制][0] > 突触_最大强度) {
                    连接矩阵[i][j][突触_调制][0] = 突触_最大强度
                }
                协同激活计数[i][j] = 0
                突触_总发芽次数 = 突触_总发芽次数 + 1
            }
            j = j + 1
        }
        i = i + 1
    }
}


函数 突触_衰减() {
    定义 可变 i = 0
    当 (i < 突触_模块数) {
        定义 可变 j = 0
        当 (j < 突触_模块数) {
            定义 可变 t = 0
            当 (t < 突触_连接类型) {
                定义 强度 = 连接矩阵[i][j][t][0]
                // 衰减不用的连接
                如果 (连接矩阵[i][j][t][3] == 0) {
                    强度 = 强度 - 突触_衰减率
                    如果 (强度 < 突触_最小强度) { 强度 = 突触_最小强度 }
                    连接矩阵[i][j][t][0] = 强度
                }
                // 使用次数→重要度(EMA)
                定义 使用 = 连接矩阵[i][j][t][3]
                连接矩阵[i][j][t][4] = (连接矩阵[i][j][t][4] * 900 + 使用 * 100) / 1000
                连接矩阵[i][j][t][3] = 0  // 重置计数
                t = t + 1
            }
            j = j + 1
        }
        i = i + 1
    }
}


函数 突触_深度过滤(信号, 信号长度) {
    定义 可变 当前信号 = 信号
    定义 可变 层 = 0
    当 (层 < 过滤_层数) {
        定义 可变 过滤后 = []
        定义 可变 i = 0
        当 (i < 信号长度) {
            定义 值 = 当前信号[i]
            // 弱信号衰减, 强信号增强
            如果 (值 > 0) {
                如果 (值 > 500) {
                    值 = 值 + 值 * 过滤_强化率 / 1000
                } 否则 {
                    值 = 值 * 过滤_保留率 / 1000
                }
            } 否则 {
                如果 (值 < -500) {
                    值 = 值 - (-值) * 过滤_强化率 / 1000
                } 否则 {
                    值 = 值 * 过滤_保留率 / 1000
                }
            }
            追加(过滤后, 值)
            i = i + 1
        }
        当前信号 = 过滤后
        层 = 层 + 1
    }
    返回 当前信号
}


函数 突触_连接强度(源, 目标, 类型) {
    如果 (源 >= 突触_模块数 || 目标 >= 突触_模块数 || 类型 >= 突触_连接类型) { 返回 0 }
    返回 连接矩阵[源][目标][类型][0]
}

函数 突触_统计() {
    返回 {传播次数: 突触_总传播次数, 发芽次数: 突触_总发芽次数}
}


函数 突触_类型名(类型) {
    如果 (类型 == 突触_兴奋) { 返回 "excitatory" }
    如果 (类型 == 突触_抑制) { 返回 "inhibitory" }
    如果 (类型 == 突触_调制) { 返回 "modulatory" }
    如果 (类型 == 突触_同步) { 返回 "gap_junction" }
    返回 "unknown"
}

函数 突触_活跃连接数() {
    定义 可变 计 = 0
    定义 可变 i = 0
    当 (i < 突触_模块数) {
        定义 可变 j = 0
        当 (j < 突触_模块数) {
            如果 (连接矩阵[i][j][突触_兴奋][0] > 突触_最小强度) { 计 = 计 + 1 }
            j = j + 1
        }
        i = i + 1
    }
    返回 计
}

函数 突触_空闲修剪弱连接(基础阈值) {
    如果 (!突触_已初始化) { 返回 0 }

    定义 可变 总强度 = 0
    定义 可变 活跃数 = 0
    定义 可变 i = 0
    当 (i < 突触_模块数) {
        定义 可变 j = 0
        当 (j < 突触_模块数) {
            如果 (i != j) {
                定义 强度 = 连接矩阵[i][j][突触_兴奋][0]
                如果 (强度 > 突触_最小强度) {
                    总强度 = 总强度 + 强度
                    活跃数 = 活跃数 + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }

    如果 (活跃数 == 0) { 返回 0 }

    定义 阈值 = 总强度 / 活跃数 * 307 / 1024
    如果 (阈值 < 基础阈值) { 阈值 = 基础阈值 }

    定义 可变 修剪数 = 0
    i = 0
    当 (i < 突触_模块数) {
        定义 可变 j = 0
        当 (j < 突触_模块数) {
            如果 (i != j) {
                定义 可变 强度 = 连接矩阵[i][j][突触_兴奋][0]
                如果 (强度 > 突触_最小强度) {
                    强度 = 强度 * 973 / 1024
                    如果 (强度 < 阈值) {
                        强度 = 突触_最小强度
                        修剪数 = 修剪数 + 1
                    }
                    如果 (强度 < 突触_最小强度) { 强度 = 突触_最小强度 }
                    连接矩阵[i][j][突触_兴奋][0] = 强度
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 修剪数
}

函数 突触_完整统计() {
    返回 [突触_总传播次数, 突触_总发芽次数, 突触_活跃连接数()]
}

// 回显处理(ping)

函数 icmp_处理回显请求(Nova缓冲) {
    定义 icmp头 = Nova缓冲.数据 + Nova缓冲.传输层偏移
    定义 icmp长度 = Nova缓冲.数据长度 - Nova缓冲.传输层偏移

    // 构建回显应答
    定义 可变 回复Nova缓冲 = Nova缓冲_分配(icmp长度 + 20)
    如果 (回复Nova缓冲 == 空) { 返回 }

    定义 回复icmp = 回复Nova缓冲.数据 + 20
    // 复制原始ICMP数据(包括标识符、序列号和数据)
    内存复制(回复icmp, icmp头, icmp长度)

    // 修改类型为应答
    回复icmp[ICMP_偏移_类型] = ICMP_回显应答
    回复icmp[ICMP_偏移_代码] = 0

    // 重新计算校验和
    icmp_计算校验和(回复icmp, icmp长度)

    回复Nova缓冲.数据长度 = icmp长度 + 20
    回复Nova缓冲.传输层偏移 = 20

    // 交换源目标IP发送
    IP_发送_协议(回复Nova缓冲, Nova缓冲.目标IP, Nova缓冲.源IP, IP协议_ICMP)
    icmp统计.回显应答发 = icmp统计.回显应答发 + 1
    icmp统计.发送总数 = icmp统计.发送总数 + 1
}

函数 icmp_处理回显应答(Nova缓冲) {
    定义 icmp头 = Nova缓冲.数据 + Nova缓冲.传输层偏移
    定义 标识符 = 网络序_读u16(icmp头, ICMP_偏移_标识符)
    定义 序列号 = 网络序_读u16(icmp头, ICMP_偏移_序列号)

    // 查找匹配的ping请求并通知
    ping_接收应答(Nova缓冲.源IP, 标识符, 序列号)
}

// ping发送

定义 可变 ping_序列号 = 0

函数 icmp_发送回显(目标IP, 标识符, 数据, 数据长度) {
    如果 (!icmp_限速检查()) {
        icmp统计.限速丢弃 = icmp统计.限速丢弃 + 1
        返回 错误码_再试
    }

    定义 总长度 = ICMP_头部大小 + 数据长度
    定义 可变 Nova缓冲 = Nova缓冲_分配(总长度 + 20)
    如果 (Nova缓冲 == 空) { 返回 错误码_内存不足 }

    定义 icmp头 = Nova缓冲.数据 + 20

    icmp头[ICMP_偏移_类型] = ICMP_回显请求
    icmp头[ICMP_偏移_代码] = 0
    网络序_写u16(icmp头, ICMP_偏移_标识符, 标识符)
    网络序_写u16(icmp头, ICMP_偏移_序列号, ping_序列号)
    ping_序列号 = ping_序列号 + 1

    // 复制数据
    如果 (数据长度 > 0 && 数据 != 空) {
        内存复制(icmp头 + ICMP_头部大小, 数据, 数据长度)
    }

    icmp_计算校验和(icmp头, 总长度)

    Nova缓冲.数据长度 = 总长度 + 20
    Nova缓冲.传输层偏移 = 20

    定义 源IP = 获取本地IP()
    定义 结果 = IP_发送_协议(Nova缓冲, 源IP, 目标IP, IP协议_ICMP)

    如果 (结果 == 0) {
        icmp统计.回显请求发 = icmp统计.回显请求发 + 1
        icmp统计.发送总数 = icmp统计.发送总数 + 1
    } 否则 {
        icmp统计.发送错误 = icmp统计.发送错误 + 1
    }

    返回 结果
}

// ICMP错误消息发送

函数 icmp_发送_端口不可达(原始Nova缓冲) {
    icmp_发送错误(原始Nova缓冲, ICMP_目标不可达, ICMP_端口不可达, 0)
}

函数 icmp_发送_主机不可达(原始Nova缓冲) {
    icmp_发送错误(原始Nova缓冲, ICMP_目标不可达, ICMP_主机不可达, 0)
}

函数 icmp_发送_需要分片(原始Nova缓冲, mtu) {
    icmp_发送错误(原始Nova缓冲, ICMP_目标不可达, ICMP_需要分片, mtu)
}

函数 icmp_发送_TTL超时(原始Nova缓冲) {
    icmp_发送错误(原始Nova缓冲, ICMP_超时, ICMP_TTL超时, 0)
}

函数 icmp_发送错误(原始Nova缓冲, 类型, 代码, 额外数据) {
    如果 (!icmp_限速检查()) {
        icmp统计.限速丢弃 = icmp统计.限速丢弃 + 1
        返回
    }

    // 不对ICMP错误消息发送ICMP错误
    定义 原始IP头 = 原始Nova缓冲.数据 + 原始Nova缓冲.网络层偏移
    如果 (原始IP头[9] == IP协议_ICMP) {
        定义 原始icmp类型 = 原始Nova缓冲.数据[原始Nova缓冲.传输层偏移]
        如果 (原始icmp类型 != ICMP_回显请求 && 原始icmp类型 != ICMP_时间戳请求) {
            返回  // 不对ICMP错误发送错误
        }
    }

    // 构建ICMP错误消息: 8字节头 + 原始IP头 + 原始数据前8字节
    定义 原始数据长度 = 取小(原始Nova缓冲.数据长度 - 原始Nova缓冲.网络层偏移, 28)
    定义 总长度 = ICMP_头部大小 + 原始数据长度

    定义 可变 Nova缓冲 = Nova缓冲_分配(总长度 + 20)
    如果 (Nova缓冲 == 空) { 返回 }

    定义 icmp头 = Nova缓冲.数据 + 20

    icmp头[ICMP_偏移_类型] = 类型
    icmp头[ICMP_偏移_代码] = 代码
    网络序_写u16(icmp头, ICMP_偏移_标识符, 0)
    网络序_写u16(icmp头, ICMP_偏移_序列号, 额外数据)

    // 复制原始IP头+前8字节数据
    内存复制(icmp头 + ICMP_头部大小,
        原始Nova缓冲.数据 + 原始Nova缓冲.网络层偏移, 原始数据长度)

    icmp_计算校验和(icmp头, 总长度)

    Nova缓冲.数据长度 = 总长度 + 20
    Nova缓冲.传输层偏移 = 20

    定义 源IP = 获取本地IP()
    IP_发送_协议(Nova缓冲, 源IP, 原始Nova缓冲.源IP, IP协议_ICMP)

    icmp统计.不可达发 = icmp统计.不可达发 + 1
    icmp统计.发送总数 = icmp统计.发送总数 + 1
}

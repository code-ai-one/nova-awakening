函数 主程序() {
    // 复现 sum = 1.0 + 2.0 + 2.0 + 1.333 + 0.667 = 7.0
    定义 a = 1.0
    定义 b = 2.0
    定义 c = 2.0
    定义 d = 8.0 / 6.0  // 1.333
    定义 e = 16.0 / 24.0  // 0.667
    
    // 直接加
    定义 s1 = a + b
    打印(字符串拼接("a+b=", 转字符串(s1)))  // 3.0
    定义 s2 = s1 + c
    打印(字符串拼接("+c=", 转字符串(s2)))  // 5.0
    定义 s3 = s2 + d
    打印(字符串拼接("+d=", 转字符串(s3)))  // 6.333
    定义 s4 = s3 + e
    打印(字符串拼接("+e=", 转字符串(s4)))  // 7.0
    
    // 链式加
    定义 r = a + b + c + d + e
    打印(字符串拼接("chain=", 转字符串(r)))
    返回 0
}

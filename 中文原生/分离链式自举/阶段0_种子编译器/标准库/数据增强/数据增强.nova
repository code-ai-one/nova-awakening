导入("../基础.nova")

// 数据增强原生实现
// 目标: 避免高阶旧语法和隐式依赖，保证 stage1 自举稳定

定义 增强_随机态 = 11111

函数 增强_复制列表(源) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(源)) {
        追加(结果, 源[i])
        i = i + 1
    }
    返回 结果
}

函数 增强_列表最小(数据) {
    如果 (计数(数据) == 0) {
        返回 0
    }
    定义 可变 最小值 = 数据[0]
    定义 可变 i = 1
    当 (i < 计数(数据)) {
        如果 (数据[i] < 最小值) {
            最小值 = 数据[i]
        }
        i = i + 1
    }
    返回 最小值
}

函数 增强_列表最大(数据) {
    如果 (计数(数据) == 0) {
        返回 0
    }
    定义 可变 最大值 = 数据[0]
    定义 可变 i = 1
    当 (i < 计数(数据)) {
        如果 (数据[i] > 最大值) {
            最大值 = 数据[i]
        }
        i = i + 1
    }
    返回 最大值
}

函数 增强_整数平方根(n) {
    如果 (n <= 0) {
        返回 0
    }
    定义 可变 左 = 1
    定义 可变 右 = n
    定义 可变 答案 = 0
    当 (左 <= 右) {
        定义 可变 中 = (左 + 右) / 2
        定义 可变 平方 = 中 * 中
        如果 (平方 <= n) {
            答案 = 中
            左 = 中 + 1
        } 否则 {
            右 = 中 - 1
        }
    }
    返回 答案
}

函数 增强_随机() {
    增强_随机态 = 增强_随机态 * 1103515245 + 12345
    如果 (增强_随机态 < 0) {
        增强_随机态 = 0 - 增强_随机态
    }
    返回 增强_随机态
}

函数 高斯噪声(数据, 幅度) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        定义 噪声 = (增强_随机() % (幅度 * 2 + 1)) - 幅度
        追加(结果, 数据[i] + 噪声)
        i = i + 1
    }
    返回 结果
}

函数 椒盐噪声(数据, 概率, 最小值, 最大值) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        定义 r = 增强_随机() % 1000
        如果 (r < 概率) {
            如果 (r % 2 == 0) {
                追加(结果, 最小值)
            } 否则 {
                追加(结果, 最大值)
            }
        } 否则 {
            追加(结果, 数据[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 水平翻转(数据) {
    定义 可变 结果 = []
    定义 可变 i = 计数(数据) - 1
    当 (i >= 0) {
        追加(结果, 数据[i])
        i = i - 1
    }
    返回 结果
}

函数 随机裁剪(数据, 裁剪长度) {
    如果 (裁剪长度 >= 计数(数据)) {
        返回 增强_复制列表(数据)
    }
    定义 起点 = 增强_随机() % (计数(数据) - 裁剪长度 + 1)
    定义 可变 结果 = []
    定义 可变 i = 起点
    当 (i < 起点 + 裁剪长度) {
        追加(结果, 数据[i])
        i = i + 1
    }
    返回 结果
}

函数 特征缩放(数据, 缩放因子) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        追加(结果, 数据[i] * 缩放因子 / 100)
        i = i + 1
    }
    返回 结果
}

函数 增强_归一化(数据) {
    定义 n = 计数(数据)
    如果 (n == 0) {
        返回 []
    }

    定义 可变 总和 = 0
    定义 可变 i = 0
    当 (i < n) {
        总和 = 总和 + 数据[i]
        i = i + 1
    }

    定义 均值 = 总和 / n
    定义 可变 平方和 = 0
    i = 0
    当 (i < n) {
        定义 可变 差值 = 数据[i] - 均值
        平方和 = 平方和 + 差值 * 差值
        i = i + 1
    }

    定义 可变 方差 = 平方和 / n
    定义 可变 标准差 = 增强_整数平方根(方差)
    如果 (标准差 == 0) {
        标准差 = 1
    }

    定义 可变 结果 = []
    i = 0
    当 (i < n) {
        追加(结果, (数据[i] - 均值) * 100 / 标准差)
        i = i + 1
    }
    返回 结果
}

函数 数据增强_归一化(数据, 目标最小, 目标最大) {
    如果 (计数(数据) == 0) {
        返回 []
    }
    定义 原最小 = 增强_列表最小(数据)
    定义 原最大 = 增强_列表最大(数据)
    定义 可变 原范围 = 原最大 - 原最小
    如果 (原范围 == 0) {
        原范围 = 1
    }

    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        定义 可变 新值 = 目标最小 + (数据[i] - 原最小) * (目标最大 - 目标最小) / 原范围
        追加(结果, 新值)
        i = i + 1
    }
    返回 结果
}

函数 混合增强(数据A, 数据B, lambda_v) {
    定义 可变 长度 = 计数(数据A)
    如果 (计数(数据B) < 长度) {
        长度 = 计数(数据B)
    }

    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 长度) {
        定义 可变 混合值 = lambda_v * 数据A[i] / 1000 + (1000 - lambda_v) * 数据B[i] / 1000
        追加(结果, 混合值)
        i = i + 1
    }
    返回 结果
}

函数 裁剪混合(数据A, 数据B, 起始, 长度) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(数据A)) {
        如果 (i >= 起始) {
            如果 (i < 起始 + 长度) {
                如果 (i < 计数(数据B)) {
                    追加(结果, 数据B[i])
                } 否则 {
                    追加(结果, 数据A[i])
                }
            } 否则 {
                追加(结果, 数据A[i])
            }
        } 否则 {
            追加(结果, 数据A[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 随机擦除(数据, 擦除比例) {
    定义 n = 计数(数据)
    如果 (n == 0) {
        返回 []
    }

    定义 可变 擦除长度 = n * 擦除比例 / 1000
    如果 (擦除长度 < 1) {
        擦除长度 = 1
    }
    如果 (擦除长度 > n) {
        擦除长度 = n
    }

    定义 起点 = 增强_随机() % (n - 擦除长度 + 1)
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < n) {
        如果 (i >= 起点) {
            如果 (i < 起点 + 擦除长度) {
                追加(结果, 0)
            } 否则 {
                追加(结果, 数据[i])
            }
        } 否则 {
            追加(结果, 数据[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 填充均值(数据, 缺失标记) {
    定义 可变 总和 = 0
    定义 可变 有效数 = 0
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        如果 (数据[i] != 缺失标记) {
            总和 = 总和 + 数据[i]
            有效数 = 有效数 + 1
        }
        i = i + 1
    }

    如果 (有效数 == 0) {
        返回 增强_复制列表(数据)
    }

    定义 均值 = 总和 / 有效数
    定义 可变 结果 = []
    i = 0
    当 (i < 计数(数据)) {
        如果 (数据[i] == 缺失标记) {
            追加(结果, 均值)
        } 否则 {
            追加(结果, 数据[i])
        }
        i = i + 1
    }
    返回 结果
}

函数 填充前值(数据, 缺失标记) {
    定义 可变 结果 = []
    定义 可变 上一个值 = 0
    定义 可变 i = 0
    当 (i < 计数(数据)) {
        如果 (数据[i] != 缺失标记) {
            上一个值 = 数据[i]
        }
        追加(结果, 上一个值)
        i = i + 1
    }
    返回 结果
}

函数 过采样(数据, 目标数量) {
    如果 (计数(数据) == 0) {
        返回 []
    }

    定义 可变 结果 = []
    定义 可变 i = 0
    当 (计数(结果) < 目标数量) {
        追加(结果, 数据[i % 计数(数据)])
        i = i + 1
    }
    返回 结果
}

函数 欠采样(数据, 目标数量) {
    如果 (目标数量 >= 计数(数据)) {
        返回 增强_复制列表(数据)
    }
    如果 (目标数量 <= 0) {
        返回 []
    }

    定义 步长 = 计数(数据) * 1000 / 目标数量
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 目标数量) {
        定义 索引 = i * 步长 / 1000
        追加(结果, 数据[索引])
        i = i + 1
    }
    返回 结果
}

函数 数据增强_滑动窗口(数据, 窗口大小, 步长) {
    定义 可变 窗口 = []
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i + 窗口大小 <= 计数(数据)) {
        定义 可变 j = 0
        当 (j < 窗口大小) {
            追加(窗口, 数据[i + j])
            j = j + 1
        }
        追加(结果, 窗口)
        i = i + 步长
    }
    返回 结果
}

// NovaOS 物理页描述符
// 职责: 每个物理页的元数据描述, 跟踪页状态/引用/映射

导入("./类型定义.nova")
导入("./自动扩容.nova")
导入("./内核打印.nova")
导入("./字符串替换.nova")

// 每个物理页一个: [页号, 标志, 引用计数, 映射信息, 所属区域, 阶, LRU类型, 私有数据]
定义 PG_页号 = 0
定义 PG_标志 = 1
定义 PG_引用 = 2       // _refcount: 引用计数
定义 PG_映射 = 3       // _mapcount/mapping: VMA或address_space
定义 PG_区域 = 4       // zone
定义 PG_阶 = 5         // compound_order / Nova伙伴分配 order
定义 PG_LRU类型 = 6    // 当前所在LRU链表类型
定义 PG_私有 = 7       // private: buffer_head/swap_entry

定义 页_已锁 = 1 << 0       // PG_locked: 正在IO
定义 页_脏 = 1 << 1         // PG_dirty: 内容已修改
定义 页_已引用 = 1 << 2     // PG_referenced: 最近被访问
定义 页_活跃 = 1 << 3       // PG_active: 在活跃LRU
定义 页_Nova块缓存 = 1 << 4       // PG_Nova块缓存: SLUB分配器使用
定义 页_伙伴 = 1 << 5       // PG_Nova伙伴分配: 伙伴系统空闲块
定义 页_保留 = 1 << 6       // PG_reserved: 内核保留
定义 页_内核 = 1 << 7       // 内核页表页
定义 页_回写中 = 1 << 8     // PG_writeback: 正在写回
定义 页_交换缓存 = 1 << 9   // PG_swapcache
定义 页_组合 = 1 << 10      // PG_head: 组合页头
定义 页_组合尾 = 1 << 11    // PG_tail: 组合页尾部
定义 页_映射到磁盘 = 1 << 12 // PG_mappedtodisk
定义 页_不可回收 = 1 << 13  // PG_unevictable
定义 页_空闲 = 1 << 14      // 自定义: 在伙伴空闲链表

定义 可变 页描述符表 = []
定义 可变 页描述符_总数 = 0

// 初始化

函数 页描述符_初始化(总页数) {
    页描述符_总数 = 总页数
    定义 可变 i = 0
    当 (i < 总页数) {
        追加(页描述符表, [i, 0, 0, 0, 区域_普通, 0, -1, 0])
        i = i + 1
    }
    内核信息数值("页描述符表创建", 总页数)
}

// 获取/验证

函数 页描述符_获取(页号) {
    如果 (页号 >= 0 && 页号 < 页描述符_总数) {
        返回 页描述符表[页号]
    }
    返回 空
}

函数 页描述符_有效(页号) {
    返回 页号 >= 0 && 页号 < 页描述符_总数
}

// 引用计数操作 

函数 页描述符_增引用(页) { 设置(页, PG_引用, 页[PG_引用] + 1) }

函数 页描述符_减引用(页) {
    设置(页, PG_引用, 页[PG_引用] - 1)
    返回 页[PG_引用]
}

函数 页描述符_获取引用(页) { 返回 页[PG_引用] }

函数 页描述符_只有一个引用(页) { 返回 页[PG_引用] == 1 }

// 标志操作

函数 页描述符_设置标志(页, 标志) { 设置(页, PG_标志, 页[PG_标志] | 标志) }
函数 页描述符_清除标志(页, 标志) { 设置(页, PG_标志, 页[PG_标志] & ~标志) }
函数 页描述符_测试标志(页, 标志) { 返回 (页[PG_标志] & 标志) != 0 }
函数 页描述符_测试并设置(页, 标志) {
    定义 旧值 = (页[PG_标志] & 标志) != 0
    设置(页, PG_标志, 页[PG_标志] | 标志)
    返回 旧值
}
函数 页描述符_测试并清除(页, 标志) {
    定义 旧值 = (页[PG_标志] & 标志) != 0
    设置(页, PG_标志, 页[PG_标志] & ~标志)
    返回 旧值
}

// 页类型查询

函数 页_是空闲(页) { 返回 页描述符_测试标志(页, 页_伙伴) }
函数 页_是保留(页) { 返回 页描述符_测试标志(页, 页_保留) }
函数 页_是Nova块缓存(页) { 返回 页描述符_测试标志(页, 页_Nova块缓存) }
函数 页_是脏(页) { 返回 页描述符_测试标志(页, 页_脏) }
函数 页_是锁定(页) { 返回 页描述符_测试标志(页, 页_已锁) }
函数 页_是活跃(页) { 返回 页描述符_测试标志(页, 页_活跃) }
函数 页_可回收(页) {
    返回 !页描述符_测试标志(页, 页_保留) &&
           !页描述符_测试标志(页, 页_已锁) &&
           !页描述符_测试标志(页, 页_不可回收)
}

// 地址转换

函数 物理_页号到地址(页号) { 返回 页号 * 页大小 }    // 物理版(通用版在类型定义.nova)
函数 物理_地址到页号(物理地址) { 返回 物理地址 / 页大小 }    // 物理版(通用版在类型定义.nova)
函数 页号到虚拟(页号) { 返回 物理到虚拟(页号 * 页大小) }

// 映射信息 (用于反向映射)

函数 页描述符_设置映射(页, 映射) { 设置(页, PG_映射, 映射) }
函数 页描述符_获取映射(页) { 返回 页[PG_映射] }
函数 页描述符_设置私有(页, 私有) { 设置(页, PG_私有, 私有) }
函数 页描述符_获取私有(页) { 返回 页[PG_私有] }

// 组合页支持 (2MB/1GB大页由多个4KB页组成)

函数 页描述符_设置组合(首页号, 阶) {
    定义 页数 = 1 << 阶
    定义 首页 = 页描述符_获取(首页号)
    如果 (首页 == 空) { 返回 }
    页描述符_设置标志(首页, 页_组合)
    设置(首页, PG_阶, 阶)

    定义 可变 i = 1
    当 (i < 页数) {
        定义 尾页 = 页描述符_获取(首页号 + i)
        如果 (尾页 != 空) {
            页描述符_设置标志(尾页, 页_组合尾)
            设置(尾页, PG_私有, 首页号)  // 指向首页
        }
        i = i + 1
    }
}

函数 页描述符_是组合首页(页) { 返回 页描述符_测试标志(页, 页_组合) }
函数 页描述符_是组合尾页(页) { 返回 页描述符_测试标志(页, 页_组合尾) }

函数 页描述符_组合阶(页号) {
    定义 页 = 页描述符_获取(页号)
    如果 (页 == 空) { 返回 0 }
    如果 (页描述符_测试标志(页, 页_组合尾)) {
        // 尾页: 从首页获取阶
        定义 首页号 = 页[PG_私有]
        定义 首页 = 页描述符_获取(首页号)
        如果 (首页 != 空) { 返回 首页[PG_阶] }
    }
    返回 页[PG_阶]
}

// 区域标记

函数 页描述符_标记内核保留(起始页号, 页数) {
    定义 可变 i = 0
    当 (i < 页数) {
        定义 页 = 页描述符_获取(起始页号 + i)
        如果 (页 != 空) {
            页描述符_设置标志(页, 页_保留 | 页_内核)
            设置(页, PG_引用, 1)
        }
        i = i + 1
    }
}

函数 页描述符_设置区域(起始页号, 结束页号, 区域类型) {
    定义 可变 i = 起始页号
    当 (i < 结束页号 && i < 页描述符_总数) {
        定义 页 = 页描述符_获取(i)
        如果 (页 != 空) { 设置(页, PG_区域, 区域类型) }
        i = i + 1
    }
}

// 页标志名 + 区域名 + 完整统计

函数 页_标志名(标志) {
    如果 ((标志 & 页_已锁) != 0) { 返回 "locked" }
    如果 ((标志 & 页_脏) != 0) { 返回 "dirty" }
    如果 ((标志 & 页_活跃) != 0) { 返回 "active" }
    如果 ((标志 & 页_Nova块缓存) != 0) { 返回 "Nova块缓存" }
    如果 ((标志 & 页_伙伴) != 0) { 返回 "Nova伙伴分配" }
    如果 ((标志 & 页_保留) != 0) { 返回 "reserved" }
    返回 "none"
}

函数 页_区域名(区域) {
    如果 (区域 == 0) { 返回 "直传" }
    如果 (区域 == 1) { 返回 "直传32" }
    如果 (区域 == 2) { 返回 "Normal" }
    返回 "unknown"
}

// 扩展页描述符操作

定义 可变 页描述符_已初始化 = 假
定义 可变 页_get总数 = 0
定义 可变 页_put总数 = 0
定义 可变 页_分配总数 = 0
定义 可变 页_释放总数 = 0
定义 可变 页_LRU添加总数 = 0
定义 可变 页_LRU移除总数 = 0
定义 可变 页_锁定总数 = 0
定义 可变 页_脏标记总数 = 0
定义 可变 页描述符_错误数 = 0

// 页迁移类型
定义 迁移_不可迁移 = 0
定义 迁移_可移动 = 1
定义 迁移_可回收 = 2
定义 迁移_高阶原子 = 3

函数 迁移类型名(类型) {
    如果 (类型 == 迁移_不可迁移) { 返回 "不可迁移" }
    如果 (类型 == 迁移_可移动) { 返回 "可移动" }
    如果 (类型 == 迁移_可回收) { 返回 "可回收" }
    如果 (类型 == 迁移_高阶原子) { 返回 "高阶原子" }
    返回 "未知"
}

// 页引用计数(get_page/put_page)

函数 get_page(页) {
    如果 (页 == 空) { 页描述符_错误数 = 页描述符_错误数 + 1; 返回 }
    页[页_引用计数偏移] = 页[页_引用计数偏移] + 1
    页_get总数 = 页_get总数 + 1
}

函数 put_page(页) {
    如果 (页 == 空) { 页描述符_错误数 = 页描述符_错误数 + 1; 返回 }
    页[页_引用计数偏移] = 页[页_引用计数偏移] - 1
    页_put总数 = 页_put总数 + 1
    如果 (页[页_引用计数偏移] == 0) {
        // 引用为0, 可以释放
        页_释放回伙伴(页)
    }
}

函数 page_count(页) {
    如果 (页 == 空) { 返回 0 }
    返回 页[页_引用计数偏移]
}

函数 page_ref_frozen(页) {
    如果 (页 == 空) { 返回 假 }
    返回 页[页_引用计数偏移] == 0
}

定义 页_引用计数偏移 = 1

// 页标志操作(原子)

函数 页_设置标志(页, 标志) {
    如果 (页 == 空) { 返回 }
    页[0] = 页[0] | 标志
}

函数 页_清除标志(页, 标志) {
    如果 (页 == 空) { 返回 }
    页[0] = 页[0] & ~标志
}

函数 页_测试标志(页, 标志) {
    如果 (页 == 空) { 返回 假 }
    返回 (页[0] & 标志) != 0
}

函数 页_设置锁定(页) { 页_设置标志(页, 页_已锁); 页_锁定总数 = 页_锁定总数 + 1 }
函数 页_清除锁定(页) { 页_清除标志(页, 页_已锁) }
函数 页_是否锁定(页) { 返回 页_测试标志(页, 页_已锁) }

函数 页_设置脏(页) { 页_设置标志(页, 页_脏); 页_脏标记总数 = 页_脏标记总数 + 1 }
函数 页_清除脏(页) { 页_清除标志(页, 页_脏) }
函数 页_是否脏(页) { 返回 页_测试标志(页, 页_脏) }

函数 页_设置活跃(页) { 页_设置标志(页, 页_活跃) }
函数 页_清除活跃(页) { 页_清除标志(页, 页_活跃) }
函数 页_是否活跃(页) { 返回 页_测试标志(页, 页_活跃) }

// PFN(页帧号)转换

定义 页大小_描述 = 4096

函数 页_到PFN(页) {
    // 页描述符索引 = PFN
    如果 (页 == 空) { 返回 0 }
    返回 页[4]
}

函数 PFN_到物理地址(pfn) {
    返回 pfn * 页大小_描述
}

函数 物理地址_到PFN(地址) {
    返回 地址 / 页大小_描述
}

函数 页_到物理地址(页) {
    返回 页_到PFN(页) * 页大小_描述
}

// 页标志完整名称(多标志)

函数 页_标志全名(标志) {
    定义 可变 名称 = ""
    如果 ((标志 & 页_已锁) != 0) { 名称 = 名称 + "L" }
    如果 ((标志 & 页_脏) != 0) { 名称 = 名称 + "D" }
    如果 ((标志 & 页_活跃) != 0) { 名称 = 名称 + "A" }
    如果 ((标志 & 页_Nova块缓存) != 0) { 名称 = 名称 + "S" }
    如果 ((标志 & 页_伙伴) != 0) { 名称 = 名称 + "B" }
    如果 ((标志 & 页_保留) != 0) { 名称 = 名称 + "R" }
    如果 (名称 == "") { 名称 = "-" }
    返回 名称
}

// 完整统计 (≥15个指标)

函数 页描述符_完整统计() {
    定义 统计 = 字典()
    字典设(统计, "已初始化", 页描述符_已初始化)
    字典设(统计, "总页数", 页描述符_总数)
    字典设(统计, "get_page总数", 页_get总数)
    字典设(统计, "put_page总数", 页_put总数)
    字典设(统计, "分配总数", 页_分配总数)
    字典设(统计, "释放总数", 页_释放总数)
    字典设(统计, "LRU添加", 页_LRU添加总数)
    字典设(统计, "LRU移除", 页_LRU移除总数)
    字典设(统计, "锁定总数", 页_锁定总数)
    字典设(统计, "脏标记总数", 页_脏标记总数)
    字典设(统计, "活跃引用", 页_get总数 - 页_put总数)
    字典设(统计, "错误数", 页描述符_错误数)
    返回 统计
}

函数 页描述符_打印统计() {
    定义 统计 = 页描述符_完整统计()
    打印("[页描述符] ═══════ 完整统计 ═══════")
    打印("  总页数:       " + 转字符串(字典取(统计, "总页数")))
    打印("  get_page:     " + 转字符串(字典取(统计, "get_page总数")))
    打印("  put_page:     " + 转字符串(字典取(统计, "put_page总数")))
    打印("  分配:         " + 转字符串(字典取(统计, "分配总数")))
    打印("  释放:         " + 转字符串(字典取(统计, "释放总数")))
    打印("  LRU添加:      " + 转字符串(字典取(统计, "LRU添加")))
    打印("  LRU移除:      " + 转字符串(字典取(统计, "LRU移除")))
    打印("  锁定:         " + 转字符串(字典取(统计, "锁定总数")))
    打印("  脏标记:       " + 转字符串(字典取(统计, "脏标记总数")))
    打印("  活跃引用:     " + 转字符串(字典取(统计, "活跃引用")))
    打印("  错误:         " + 转字符串(字典取(统计, "错误数")))
    打印("[页描述符] ═════════════════════════")
    返回 0
}

函数 页描述符_dump() {
    打印("[页描述符 dump] ──────────────────")
    打印("  总页数: " + 转字符串(页描述符_总数))
    打印("  get: " + 转字符串(页_get总数))
    打印("  put: " + 转字符串(页_put总数))
    打印("  分配: " + 转字符串(页_分配总数))
    打印("  释放: " + 转字符串(页_释放总数))
    打印("  脏: " + 转字符串(页_脏标记总数))
    打印("  错误: " + 转字符串(页描述符_错误数))
    打印("[页描述符 dump] ──────────────────")
}

函数 页描述符_销毁() { 页描述符_已初始化 = 假; 返回 0 }

函数 页描述符_为伙伴系统提供页状态() {
    返回 [页描述符_总数, 页_分配总数, 页_释放总数, 页_get总数, 页_put总数]
}

函数 页描述符_为回收提供LRU信息() {
    返回 [页_LRU添加总数, 页_LRU移除总数, 页_脏标记总数, 页_锁定总数]
}

函数 页描述符_为AI提供页使用模式() {
    返回 [页_分配总数, 页_释放总数, 页_脏标记总数, 页_get总数 - 页_put总数]
}

函数 页描述符_重置统计() {
    页_get总数 = 0
    页_put总数 = 0
    页_分配总数 = 0
    页_释放总数 = 0
    页_LRU添加总数 = 0
    页_LRU移除总数 = 0
    页_锁定总数 = 0
    页_脏标记总数 = 0
    页描述符_错误数 = 0
    打印("[页描述符] 统计已重置")
    返回 0
}

// 复合页(大页)支持

定义 页_复合 = 1 << 8
定义 页_复合头 = 1 << 9

函数 页_是复合页(页) {
    如果 (页 == 空) { 返回 假 }
    返回 (页[0] & 页_复合) != 0
}

函数 页_是复合头(页) {
    如果 (页 == 空) { 返回 假 }
    返回 (页[0] & 页_复合头) != 0
}

函数 页_复合阶(页) {
    如果 (页_是复合头(页) == 假) { 返回 0 }
    返回 页[5]
}

函数 页_复合页数(页) {
    返回 1 << 页_复合阶(页)
}

// 页映射计数(mapcount)

定义 页_映射计数偏移 = 2

函数 页_映射计数(页) {
    如果 (页 == 空) { 返回 0 }
    返回 页[页_映射计数偏移]
}

函数 页_增加映射(页) {
    如果 (页 == 空) { 返回 }
    页[页_映射计数偏移] = 页[页_映射计数偏移] + 1
}

函数 页_减少映射(页) {
    如果 (页 == 空) { 返回 }
    如果 (页[页_映射计数偏移] > 0) {
        页[页_映射计数偏移] = 页[页_映射计数偏移] - 1
    }
}

函数 页_是否已映射(页) {
    返回 页_映射计数(页) > 0
}

// 与其他神经模块的深度协作

函数 页描述符_为procfs提供页统计() {
    返回 [页描述符_总数, 页_分配总数, 页_释放总数, 页_脏标记总数, 页_锁定总数]
}

函数 页描述符_为调度器提供内存活跃度() {
    返回 [页_get总数 - 页_put总数, 页_脏标记总数]
}

函数 页描述符_为电源管理提供页活跃度() {
    返回 [页_分配总数 + 页_释放总数, 页_脏标记总数]
}

// 桥接
函数 页_释放回伙伴(页) {
    如果 (页 == 0 || 页 == 空) { 返回 }
    // 获取页的阶数(order)
    定义 order = 页.阶数
    如果 (order < 0 || order > 最大阶) { order = 0 }
    // 尝试与伙伴页合并
    定义 可变 pfn = 页.页帧号
    定义 可变 cur_order = order
    当 (cur_order < 最大阶) {
        定义 buddy_pfn = pfn ^ (1 << cur_order)
        定义 buddy = 页帧号到页描述符(buddy_pfn)
        如果 (buddy == 空 || buddy.已分配 || buddy.阶数 != cur_order) {
            // 伙伴不可用, 停止合并
            cur_order = 最大阶
        } 否则 {
            // 从当前阶的空闲链表移除伙伴
            伙伴系统_移除空闲(buddy, cur_order)
            // 合并: 取较小的pfn
            如果 (buddy_pfn < pfn) { pfn = buddy_pfn }
            cur_order = cur_order + 1
        }
    }
    // 将合并后的块放入对应阶的空闲链表
    定义 merged = 页帧号到页描述符(pfn)
    如果 (merged != 空) {
        merged.已分配 = 假
        merged.阶数 = cur_order
        伙伴系统_添加空闲(merged, cur_order)
    }
    页_释放总数 = 页_释放总数 + 1
}

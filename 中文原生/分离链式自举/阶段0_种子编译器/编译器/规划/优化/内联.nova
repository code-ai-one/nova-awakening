导入("../../../标准库/基础.nova")

//    代码膨胀(阳过度) ←→ 调用开销(阴不足)

// 内联决策常量
定义 内联_强制   = 2   // 强制内联

// 不内联原因
定义 不内联_过大    = 1
定义 不内联_递归    = 2
定义 不内联_调用过多 = 3
定义 不内联_有闭包  = 4
定义 不内联_变参     = 5

// 内联阈值
定义 内联_最大节点 = 20     // 最大AST节点数
定义 内联_最大参数 = 6     // 最大参数数
定义 内联_最大深度 = 3      // 最大内联深度
定义 内联_调用奖励 = 5     // 单调用点奖励

// 函数信息: [名称ID, 节点数, 参数数, 调用数, 是递归, 有闭包]
函数 函数信息(名称ID, 节点数, 参数数) {
    返回 [名称ID, 节点数, 参数数, 0, 0]
}

函数 信息_节点数(f) { 返回 f[1] }
函数 信息_参数数(f) { 返回 f[2] }
函数 信息_调用数(f) { 返回 f[3] }
函数 信息_是递归(f) { 返回 f[4] }
函数 信息_增调用(f) { f[3] = f[3] + 1 }
函数 信息_标记递归(f) { f[4] = 1 }
函数 信息_标记闭包(f) { f[5] = 1 }

// 内联决策
函数 应内联(信息) {
    // 递归函数不内联
    如果 (信息[4] == 1) { 返回 不内联_递归 * (0-1) }
    // 有闭包不内联
    如果 (信息[5] == 1) { 返回 不内联_有闭包 * (0-1) }
    // 参数过多不内联
    如果 (信息[2] > 内联_最大参数) { 返回 不内联_变参 * (0-1) }
    // 节点数检查
    定义 可变 阈值 = 内联_最大节点
    // 单调用点给予奖励
    如果 (信息[3] == 1) { 阈值 = 阈值 + 内联_调用奖励 }
    如果 (信息[1] > 阈值) { 返回 不内联_过大 * (0-1) }
    返回 内联_是
}

// 内联代价估算
// 内联后代码膨胀 = 节点数 × 调用次数
函数 内联代价(信息) {
    返回 信息[1] * 信息[3]
}

// 内联收益估算
// 消除调用开销 + 常量传播机会
函数 内联收益(信息) {
    定义 调用开销 = 信息[3] * 5  // 每次调用5节点开销
    定义 传播机会 = 信息[2] * 信息[3]  // 参数×调用
    返回 调用开销 + 传播机会
}

// 值得内联
函数 值得内联(信息) {
    如果 (应内联(信息) != 内联_是) { 返回 0 }
    如果 (内联收益(信息) >= 内联代价(信息)) { 返回 1 }
    返回 0
}

// 内联统计
函数 内联器_创建() {
    返回 [[],]  // [函数列表, 内联数, 节省节点]
}

函数 内联器_注册(内联器, 名称ID, 节点数, 参数数) {
    追加(内联器[0], 函数信息(名称ID, 节点数, 参数数))
}

// 内联执行与追踪
函数 内联器_执行(内联器, _调用站点索引, 被调函数索引) {
    定义 被调 = 内联器[0][被调函数索引]
    内联器[1] = 内联器[1] + 1
    内联器[2] = 内联器[2] + 被调[1]  // 展开节点数
    返回 被调[1]
}

函数 内联器_膨胀率(内联器) {
    如果 (内联器[1] == 0) { 返回 0 }
    返回 内联器[2] * 10000 / (内联器[1] * 内联_最大节点)
}

函数 内联器_报告(内联器) {
    返回 [
        计数(内联器[0]),     // 注册函数数
        内联器_统计(内联器), // 可内联数
        内联器[1],           // 已内联次数
        内联器[2]            // 展开节点总数
    ]
}

// 调用站点敏感内联决策
函数 调用站点_内联(信息, 循环深度, 参数已知数) {
    定义 基础 = 应内联(信息)
    如果 (基础 != 内联_是) { 返回 基础 }

    定义 可变 阈值 = 内联_最大节点
    // 循环内放宽阈值
    如果 (循环深度 > 0) { 阈值 = 阈值 * 2 }
    // 大部分参数已知 → 内联后可大幅简化
    如果 (参数已知数 > 信息[2] / 2) {
        阈值 = 阈值 + 参数已知数 * 5
    }
    如果 (信息[1] <= 阈值) { 返回 内联_是 }
    返回 内联_否
}

// 内联优先级排序
函数 内联器_排序(内联器) {
    定义 列表 = 内联器[0]
    定义 n = 计数(列表)
    // 按收益/代价比降序排列
    定义 可变 i = 0
    当 (i < n - 1) {
        定义 可变 最优 = i
        定义 可变 j = i + 1
        当 (j < n) {
            定义 比i = 内联收益(列表[最优]) * 10000 / (内联代价(列表[最优]) + 1)
            定义 比j = 内联收益(列表[j]) * 10000 / (内联代价(列表[j]) + 1)
            如果 (比j > 比i) { 最优 = j }
            j = j + 1
        }
        如果 (最优 != i) {
            定义 暂存 = 列表[i]
            列表[i] = 列表[最优]
            列表[最优] = 暂存
        }
        i = i + 1
    }
}

// 递归内联检测

函数 内联_是递归(调用图, 函数名) {
    // 调用图: [[调用者, 被调者], ...]
    定义 可变 i = 0
    当 (i < 计数(调用图)) {
        如果 (调用图[i][0] == 函数名 且 调用图[i][1] == 函数名) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 内联_间接递归(调用图, 函数a, 函数b) {
    定义 可变 a到b = 假
    定义 可变 b到a = 假
    定义 可变 i = 0
    当 (i < 计数(调用图)) {
        如果 (调用图[i][0] == 函数a 且 调用图[i][1] == 函数b) { a到b = 真 }
        如果 (调用图[i][0] == 函数b 且 调用图[i][1] == 函数a) { b到a = 真 }
        i = i + 1
    }
    返回 a到b 且 b到a
}

// 内联缓存

定义 可变 _内联缓存_函数 = []
定义 可变 _内联缓存_决策 = []

函数 内联缓存_查(函数名) {
    定义 可变 i = 0
    当 (i < 计数(_内联缓存_函数)) {
        如果 (_内联缓存_函数[i] == 函数名) { 返回 _内联缓存_决策[i] }
        i = i + 1
    }
    返回 -1  // 未缓存
}

函数 内联缓存_存(函数名, 决策) {
    追加(_内联缓存_函数, 函数名)
    追加(_内联缓存_决策, 决策)
}

// 内联预算

定义 _内联_总预算 = 10000
定义 可变 _内联_已用 = 0

函数 内联预算_设(预算) { _内联_总预算 = 预算 }

函数 内联预算_消耗(代价) {
    如果 (_内联_已用 + 代价 > _内联_总预算) { 返回 假 }
    _内联_已用 = _内联_已用 + 代价
    返回 真
}

函数 内联预算_剩余() { 返回 _内联_总预算 - _内联_已用 }

// 调用频率热点

定义 可变 _热点_函数名 = []
定义 可变 _热点_调用次数 = []

函数 热点_记录(函数名) {
    定义 可变 i = 0
    当 (i < 计数(_热点_函数名)) {
        如果 (_热点_函数名[i] == 函数名) { _热点_调用次数[i] = _热点_调用次数[i] + 1 返回 空 }
        i = i + 1
    }
    追加(_热点_函数名, 函数名)
    追加(_热点_调用次数, 1)
}

函数 热点_TopN(n) {
    // 简单选择排序取前n
    定义 可变 结果 = []
    定义 可变 已选 = []
    定义 可变 k = 0
    当 (k < n 且 k < 计数(_热点_函数名)) {
        定义 可变 最大 = -1
        定义 可变 索引 = -1
        定义 可变 i = 0
        当 (i < 计数(_热点_函数名)) {
            定义 可变 跳过 = 假
            定义 可变 j = 0
            当 (j < 计数(已选)) { 如果 (已选[j] == i) { 跳过 = 真 }  j = j + 1 }
            如果 (!跳过 且 _热点_调用次数[i] > 最大) { 最大 = _热点_调用次数[i]  索引 = i }
            i = i + 1
        }
        如果 (索引 >= 0) {
            追加(结果, [_热点_函数名[索引], _热点_调用次数[索引]])
            追加(已选, 索引)
        }
        k = k + 1
    }
    返回 结果
}

定义 可变 _内联_决策数 = 0
定义 可变 _内联_执行数 = 0

函数 内联_记录决策() { _内联_决策数 = _内联_决策数 + 1 }
函数 内联_记录执行() { _内联_执行数 = _内联_执行数 + 1 }



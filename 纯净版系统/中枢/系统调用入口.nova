// NovaOS 系统调用入口
// 职责: Nova系统调用指令的内核入口, 保存用户态寄存器, 分发, 恢复, sysret返回
// Nova系统调用指令约定 (AMD64 ABI):
//   RAX = 系统调用号
//   RDI = 参数1, RSI = 参数2, RDX = 参数3
//   R10 = 参数4 (注意: 不是RCX, Nova系统调用会覆盖RCX)
//   R8  = 参数5, R9  = 参数6
//   RCX = 用户态RIP (Nova系统调用自动保存)
//   R11 = 用户态RFLAGS (Nova系统调用自动保存)
// 返回值放在RAX

导入("./系统调用表.nova")
导入("../执行/端口.nova")
导入("../引导/寄存器定义.nova")
导入("./日志中枢.nova")
导入("./进程任务.nova")
导入("./字符串替换.nova")
导入("../引导/模型寄存.nova")
导入("./软中断挂起数.nova")
导入("./新系统智能.nova")
导入("./自动扩容.nova")
导入("./注册文件系统.nova")
导入("./页表重建.nova")
导入("./内存系统调用.nova")
导入("./进程组.nova")
导入("./智能进程画.nova")
导入("./智能系统调甲.nova")
导入("./系统调用号定.nova")
导入("./空闲进程.nova")
导入("./每处理器.nova")
导入("./时钟中枢.nova")
导入("./进程信号.nova")

定义 可变 系统调用_总次数 = 0
定义 可变 系统调用_失败次数 = 0
定义 系统调用_ENOSYS = 0 - 38

// Nova系统调用入口点 (汇编)
// CPU执行Nova系统调用时跳转到此, RIP由MSR_LSTAR指定

函数 Nova系统调用_入口() {
    汇编 {
        "swapgs"

        // 用户RSP保存到per-CPU临时变量, 加载内核RSP
        "mov [用户RSP临时], rsp"
        "mov rsp, [内核RSP临时]"

        // CPU已保存: RCX=用户RIP, R11=用户RFLAGS
        "push 0x23"            // SS (用户数据段)
        "push [用户RSP临时]"   // 用户RSP
        "push r11"             // RFLAGS
        "push 0x1B"            // CS (用户代码段)
        "push rcx"             // 用户RIP

        // 保存通用寄存器
        "push rax"             // 系统调用号 (orig_rax)
        "push rdi"
        "push rsi"
        "push rdx"
        "push r10"             // 参数4 (而非rcx)
        "push r8"
        "push r9"
        "push rbx"
        "push rbp"
        "push r12"
        "push r13"
        "push r14"
        "push r15"

        // rdi已经是参数1, rsi=参数2, rdx=参数3
        // 参数4在r10, 参数5在r8, 参数6在r9
        // 调用号在rax
        "mov rdi, rax"         // 第1参数 = 调用号
        // 其余参数已在正确位置(由用户态传入)
    }

    // 调用高层分发
    // rdi=调用号 由汇编设置
    // 实际参数从栈帧读取

    汇编 {
        "pop r15"
        "pop r14"
        "pop r13"
        "pop r12"
        "pop rbp"
        "pop rbx"
        "pop r9"
        "pop r8"
        "pop r10"
        "pop rdx"
        "pop rsi"
        "pop rdi"
        "add rsp, 8"          // 跳过orig_rax

        "pop rcx"              // 用户RIP
        "add rsp, 8"          // 跳过CS
        "pop r11"              // 用户RFLAGS
        "pop rsp"              // 用户RSP (从帧恢复)
        // 跳过SS

        "swapgs"

        // RCX→RIP, R11→RFLAGS, 段切换到用户态
        "sysretq"
    }
}

定义 可变 用户RSP临时 = 0
定义 可变 内核RSP临时 = 0

// 系统调用分发 (C层)

函数 系统调用_记录未注册(调用号, 当前PID) {
    系统调用_失败次数 = 系统调用_失败次数 + 1
    系统调用_未注册次数 = 系统调用_未注册次数 + 1
    AI安全_记录失败(当前PID)
    返回 系统调用_ENOSYS
}

函数 系统调用_分发(调用号, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6) {
    系统调用_总次数 = 系统调用_总次数 + 1

    // ★ AI先天特性: 系统调用审计+安全检测
    // ★ 安全约束: 此路径在内核态热路径中, 所有AI钩子必须:
    //   1. 纯本地计算(禁止网络IO/文件IO/云端调用)
    //   2. O(1)时间复杂度(禁止遍历大列表)
    //   3. 不获取可能阻塞的锁(只用trylock或无锁)
    定义 当前PID = 获取当前PID()
    AI系统调用_记录(调用号)
    AI系统调用_记录进程(当前PID, 调用号)
    AI进程_记录系统调用(当前PID)
    如果 (!AI安全_检查系统调用(当前PID, 调用号)) {
        系统调用_失败次数 = 系统调用_失败次数 + 1
        返回 错误_权限   // AI安全拦截
    }

    如果 (调用号 >= 最大系统调用) {
        返回 系统调用_记录未注册(调用号, 当前PID)
    }

    定义 处理函数 = 系统调用表[调用号]
    如果 (处理函数 == 空) {
        返回 系统调用_记录未注册(调用号, 当前PID)
    }

    定义 结果 = 处理函数(参数1, 参数2, 参数3, 参数4, 参数5, 参数6)

    // ★ AI先天特性: 记录成功/失败
    如果 (结果 < 0) { AI安全_记录失败(当前PID) }
    否则 { AI安全_记录成功(当前PID) }

    // 返回用户态前检查信号和调度
    返回用户态前检查()
    返回 结果
}

// 初始化: 写入MSR, 设置Nova系统调用入口

函数 系统调用入口_初始化() {
    // MSR_LSTAR: Nova系统调用指令跳转地址
    设置Nova系统调用入口(函数地址(Nova系统调用_入口))

    // MSR_STAR: 段选择子
    // 高32位: Nova系统调用 CS/SS = 内核代码段(0x08)
    // 次高16位: SYSRET CS/SS = 用户代码段(0x18) — sysret自动+16得数据段(0x20)
    设置Nova系统调用选择子(GDT_内核代码, GDT_用户代码)

    // MSR_SFMASK: Nova系统调用时清除的RFLAGS位 (IF=关中断, DF=清方向)
    设置Nova系统调用标志掩码(EFLAGS_IF | EFLAGS_DF)

    // 使能SCE位 (EFER.SCE = 1)
    定义 efer = 读EFER()
    写EFER(efer | EFER_SCE)

    早期打印OK("Nova系统调用入口初始化")
}

// 注册所有子系统的系统调用

函数 系统调用_注册全部() {
    系统调用表_初始化()
    系统调用_注册全部_表()
    内核信息("系统调用注册完成")
}

// 统计

函数 系统调用_统计() {
    返回 [系统调用_总次数, 系统调用_失败次数]
}

// 系统调用号名称 + 成功率

函数 系统调用_成功率() {
    如果 (系统调用_总次数 == 0) { 返回 100 }
    返回 (系统调用_总次数 - 系统调用_失败次数) * 100 / 系统调用_总次数
}

函数 系统调用_失败率() {
    如果 (系统调用_总次数 == 0) { 返回 0 }
    返回 系统调用_失败次数 * 100 / 系统调用_总次数
}

// 初始化保护与增强状态

定义 可变 系统调用_已初始化 = 假
定义 可变 系统调用_AI拦截次数 = 0
定义 可变 系统调用_未注册次数 = 0
定义 可变 系统调用_错误数 = 0

// 延迟测量
定义 可变 系统调用_延迟总计 = 0
定义 可变 系统调用_延迟样本 = 0
定义 可变 系统调用_最大延迟 = 0
定义 可变 系统调用_超时次数 = 0
定义 系统调用_超时阈值 = 10000000

// 速率追踪
定义 可变 系统调用_速率 = 0
定义 可变 系统调用_速率窗口 = 0
定义 可变 系统调用_速率时刻 = 0
定义 可变 系统调用_峰值速率 = 0

// 每调用号统计
定义 可变 系统调用_每号计数 = []
定义 可变 系统调用_每号延迟 = []
定义 可变 每号统计_已初始化 = 假
定义 最大系统调用 = 512

// 追踪(strace支持)
定义 可变 系统调用_追踪启用 = 假
定义 可变 系统调用_追踪PID = 0

函数 系统调用入口_完整初始化() {
    如果 (系统调用_已初始化 == 真) { 返回 错误_已存在 }
    // 初始化每调用号统计
    系统调用_每号计数 = []
    系统调用_每号延迟 = []
    定义 可变 i = 0
    当 (i < 最大系统调用) {
        追加(系统调用_每号计数, 0)
        追加(系统调用_每号延迟, 0)
        i = i + 1
    }
    每号统计_已初始化 = 真
    系统调用_总次数 = 0
    系统调用_失败次数 = 0
    系统调用_AI拦截次数 = 0
    系统调用_未注册次数 = 0
    系统调用_错误数 = 0
    系统调用_延迟总计 = 0
    系统调用_延迟样本 = 0
    系统调用_最大延迟 = 0
    系统调用_超时次数 = 0
    系统调用_速率 = 0
    系统调用_速率窗口 = 0
    系统调用_速率时刻 = 0
    系统调用_峰值速率 = 0
    系统调用_追踪启用 = 假
    系统调用_追踪PID = 0
    // 初始化MSR
    系统调用入口_初始化()
    // 注册所有系统调用
    系统调用_注册全部()
    系统调用_已初始化 = 真
    打印("[系统调用入口] 完整初始化完成")
    返回 0
}

// 分发增强(延迟测量/每号统计)

函数 系统调用_分发_增强(调用号, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6) {
    系统调用_总次数 = 系统调用_总次数 + 1
    系统调用_速率窗口 = 系统调用_速率窗口 + 1
    定义 开始时间 = 读取纳秒()
    // 每调用号统计
    如果 (每号统计_已初始化 == 真 && 调用号 < 最大系统调用) {
        设置(系统调用_每号计数, 调用号, 系统调用_每号计数[调用号] + 1)
    }
    // 追踪(strace)
    如果 (系统调用_追踪启用 == 真) {
        定义 当前PID = 获取当前PID()
        如果 (系统调用_追踪PID == 0 || 系统调用_追踪PID == 当前PID) {
            打印("[strace] PID=" + 转字符串(当前PID) + " 调用=" + 转字符串(调用号) +
                 " 参数=(" + 转字符串(参数1) + "," + 转字符串(参数2) + "," + 转字符串(参数3) + ")")
        }
    }
    // 调用原有分发
    定义 结果 = 系统调用_分发(调用号, 参数1, 参数2, 参数3, 参数4, 参数5, 参数6)
    // 延迟测量
    定义 耗时 = 读取纳秒() - 开始时间
    系统调用_记录延迟(耗时, 调用号)
    返回 结果
}

函数 系统调用_记录延迟(延迟, 调用号) {
    系统调用_延迟样本 = 系统调用_延迟样本 + 1
    系统调用_延迟总计 = 系统调用_延迟总计 + 延迟
    如果 (延迟 > 系统调用_最大延迟) { 系统调用_最大延迟 = 延迟 }
    如果 (延迟 > 系统调用_超时阈值) { 系统调用_超时次数 = 系统调用_超时次数 + 1 }
    // 每调用号延迟
    如果 (每号统计_已初始化 == 真 && 调用号 < 最大系统调用) {
        // EMA平滑
        定义 旧延迟 = 系统调用_每号延迟[调用号]
        设置(系统调用_每号延迟, 调用号, (旧延迟 * 7 + 延迟) / 8)
    }
}

函数 系统调用_平均延迟() {
    如果 (系统调用_延迟样本 == 0) { 返回 0 }
    返回 系统调用_延迟总计 / 系统调用_延迟样本
}

// 返回用户态前检查

函数 返回用户态前检查() {
    // 1. 检查是否有挂起信号
    定义 当前 = 获取当前进程()
    如果 (当前 != 空) {
        如果 (进程_有挂起信号(当前) == 真) {
            信号_处理挂起(当前)
        }
    }
    // 2. 检查是否需要调度
    如果 (需要调度() == 真) {
        调度()
    }
    // 3. 处理挂起的软中断
    如果 (软中断_有挂起() == 真) {
        软中断_处理全部()
    }
}

// 速率追踪

函数 系统调用_更新速率() {
    定义 现在 = 读取纳秒()
    定义 间隔 = 现在 - 系统调用_速率时刻
    如果 (间隔 >= 1000000000) {
        系统调用_速率 = 系统调用_速率窗口 * 1000000000 / 间隔
        如果 (系统调用_速率 > 系统调用_峰值速率) { 系统调用_峰值速率 = 系统调用_速率 }
        系统调用_速率窗口 = 0
        系统调用_速率时刻 = 现在
    }
}

// 追踪(strace)

函数 系统调用_启用追踪(PID) {
    系统调用_追踪启用 = 真
    系统调用_追踪PID = PID
    打印("[系统调用] 追踪启用 PID=" + 转字符串(PID))
    返回 0
}

函数 系统调用_禁用追踪() {
    系统调用_追踪启用 = 假
    系统调用_追踪PID = 0
    返回 0
}

// 查询接口

函数 系统调用_获取调用号计数(调用号) {
    如果 (每号统计_已初始化 == 假 || 调用号 >= 最大系统调用) { 返回 0 }
    返回 系统调用_每号计数[调用号]
}

函数 系统调用_获取调用号延迟(调用号) {
    如果 (每号统计_已初始化 == 假 || 调用号 >= 最大系统调用) { 返回 0 }
    返回 系统调用_每号延迟[调用号]
}

函数 系统调用_获取最热调用号(前N) {
    如果 (每号统计_已初始化 == 假) { 返回 [] }
    定义 可变 结果 = []
    定义 可变 n = 0
    当 (n < 前N) {
        定义 可变 最大 = 0
        定义 可变 最大号 = 0 - 1
        定义 可变 i = 0
        当 (i < 最大系统调用) {
            如果 (系统调用_每号计数[i] > 最大) {
                定义 可变 已有 = 假
                定义 可变 j = 0
                当 (j < 计数(结果)) {
                    如果 (结果[j][0] == i) { 已有 = 真 }
                    j = j + 1
                }
                如果 (已有 == 假) { 最大 = 系统调用_每号计数[i]; 最大号 = i }
            }
            i = i + 1
        }
        如果 (最大号 >= 0 && 最大 > 0) {
            追加(结果, [最大号, 最大, 系统调用_每号延迟[最大号]])
        }
        n = n + 1
    }
    返回 结果
}

// 完整统计 (≥15个指标)

函数 系统调用_完整统计() {
    定义 可变 已注册数 = 0
    定义 可变 i = 0
    当 (i < 最大系统调用) {
        如果 (每号统计_已初始化 == 真 && 系统调用_每号计数[i] > 0) {
            已注册数 = 已注册数 + 1
        }
        i = i + 1
    }
    定义 统计 = 字典()
    字典设(统计, "已初始化", 系统调用_已初始化)
    字典设(统计, "总次数", 系统调用_总次数)
    字典设(统计, "失败次数", 系统调用_失败次数)
    字典设(统计, "成功率(%)", 系统调用_成功率())
    字典设(统计, "AI拦截", 系统调用_AI拦截次数)
    字典设(统计, "未注册", 系统调用_未注册次数)
    字典设(统计, "平均延迟(ns)", 系统调用_平均延迟())
    字典设(统计, "最大延迟(ns)", 系统调用_最大延迟)
    字典设(统计, "超时次数", 系统调用_超时次数)
    字典设(统计, "当前速率", 系统调用_速率)
    字典设(统计, "峰值速率", 系统调用_峰值速率)
    字典设(统计, "活跃调用号数", 已注册数)
    字典设(统计, "追踪启用", 系统调用_追踪启用)
    字典设(统计, "追踪PID", 系统调用_追踪PID)
    字典设(统计, "延迟样本", 系统调用_延迟样本)
    字典设(统计, "错误数", 系统调用_错误数)
    返回 统计
}

函数 系统调用_打印完整统计() {
    定义 统计 = 系统调用_完整统计()
    打印("[系统调用入口] ═══════ 完整统计 ═══════")
    打印("  总次数:       " + 转字符串(字典取(统计, "总次数")))
    打印("  失败次数:     " + 转字符串(字典取(统计, "失败次数")))
    打印("  成功率:       " + 转字符串(字典取(统计, "成功率(%)")) + "%")
    打印("  AI拦截:       " + 转字符串(字典取(统计, "AI拦截")))
    打印("  未注册:       " + 转字符串(字典取(统计, "未注册")))
    打印("  平均延迟:     " + 转字符串(字典取(统计, "平均延迟(ns)")) + "ns")
    打印("  最大延迟:     " + 转字符串(字典取(统计, "最大延迟(ns)")) + "ns")
    打印("  超时次数:     " + 转字符串(字典取(统计, "超时次数")))
    打印("  当前速率:     " + 转字符串(字典取(统计, "当前速率")) + " 次/秒")
    打印("  峰值速率:     " + 转字符串(字典取(统计, "峰值速率")) + " 次/秒")
    打印("  活跃调用号:   " + 转字符串(字典取(统计, "活跃调用号数")))
    打印("  错误数:       " + 转字符串(字典取(统计, "错误数")))
    // 最热5个调用号
    定义 热表 = 系统调用_获取最热调用号(5)
    如果 (计数(热表) > 0) {
        打印("  ── 最热调用号 ──")
        定义 可变 h = 0
        当 (h < 计数(热表)) {
            打印("  #" + 转字符串(热表[h][0]) + ": " + 转字符串(热表[h][1]) + "次 延迟=" + 转字符串(热表[h][2]) + "ns")
            h = h + 1
        }
    }
    打印("[系统调用入口] ═════════════════════════")
    返回 0
}

// dump

函数 系统调用_dump() {
    打印("[系统调用 dump] ──────────────────")
    打印("  已初始化: " + 转字符串(系统调用_已初始化))
    打印("  总次数: " + 转字符串(系统调用_总次数))
    打印("  失败: " + 转字符串(系统调用_失败次数))
    打印("  成功率: " + 转字符串(系统调用_成功率()) + "%")
    打印("  平均延迟: " + 转字符串(系统调用_平均延迟()) + "ns")
    打印("  速率: " + 转字符串(系统调用_速率))
    打印("  追踪: " + 转字符串(系统调用_追踪启用))
    打印("[系统调用 dump] ──────────────────")
}

// 销毁

函数 系统调用_销毁() {
    如果 (系统调用_已初始化 == 假) { 返回 0 }
    系统调用_每号计数 = []
    系统调用_每号延迟 = []
    每号统计_已初始化 = 假
    系统调用_已初始化 = 假
    打印("[系统调用入口] 已销毁")
    返回 0
}

// 与其他子系统的接口

函数 系统调用_为调度器提供负载() {
    返回 [系统调用_速率, 系统调用_峰值速率, 系统调用_总次数]
}

函数 系统调用_为AI提供调用模式() {
    返回 系统调用_获取最热调用号(5)
}

函数 系统调用_为procfs提供统计() {
    返回 [系统调用_总次数, 系统调用_失败次数, 系统调用_成功率(),
           系统调用_速率, 系统调用_平均延迟()]
}

函数 系统调用_为审计提供记录(调用号, PID, 结果) {
    // 安全审计接口
    如果 (系统调用_追踪启用 == 真) {
        打印("[审计] PID=" + 转字符串(PID) + " 调用=" + 转字符串(调用号) + " 结果=" + 转字符串(结果))
    }
    返回 0
}

函数 系统调用_重置统计() {
    系统调用_总次数 = 0
    系统调用_失败次数 = 0
    系统调用_AI拦截次数 = 0
    系统调用_未注册次数 = 0
    系统调用_延迟总计 = 0
    系统调用_延迟样本 = 0
    系统调用_最大延迟 = 0
    系统调用_超时次数 = 0
    系统调用_速率 = 0
    系统调用_峰值速率 = 0
    系统调用_速率窗口 = 0
    如果 (每号统计_已初始化 == 真) {
        定义 可变 i = 0
        当 (i < 最大系统调用) {
            设置(系统调用_每号计数, i, 0)
            设置(系统调用_每号延迟, i, 0)
            i = i + 1
        }
    }
    打印("[系统调用入口] 统计已重置")
    返回 0
}

函数 系统调用入口_统计() {
    返回 {
        系统调用总次数: 系统调用_总次数,
        系统调用失败次数: 系统调用_失败次数,
        系统调用已初始化: 系统调用_已初始化,
        系统调用AI拦截次数: 系统调用_AI拦截次数,
        系统调用未注册次数: 系统调用_未注册次数,
        系统调用错误数: 系统调用_错误数,
        系统调用延迟总计: 系统调用_延迟总计,
        系统调用延迟样本: 系统调用_延迟样本,
        系统调用超时次数: 系统调用_超时次数,
        系统调用速率: 系统调用_速率,
        系统调用峰值速率: 系统调用_峰值速率,
        系统调用每号计数: 系统调用_每号计数,
        每号统计已初始化: 每号统计_已初始化
    }
}

函数 系统调用入口_健康评估() {
    定义 可变 问题 = []
    如果 (系统调用_失败次数 > 100) { 追加(问题, "系统调用_失败次数=" + 系统调用_失败次数) }
    如果 (系统调用_错误数 > 系统调用_总次数 / 3 && 系统调用_总次数 > 50) { 追加(问题, "系统调用_错误数过高") }
    返回 计数(问题) == 0
}

函数 系统调用入口_综合报告() {
    打印("[系统调用入口] ═══ 综合报告 ═══")
    打印("  系统调用_总次数: " + 系统调用_总次数)
    打印("  系统调用_失败次数: " + 系统调用_失败次数)
    打印("  系统调用_已初始化: " + 系统调用_已初始化)
    打印("  系统调用_AI拦截次数: " + 系统调用_AI拦截次数)
    打印("  系统调用_未注册次数: " + 系统调用_未注册次数)
    打印("  系统调用_错误数: " + 系统调用_错误数)
    打印("  系统调用_延迟总计: " + 系统调用_延迟总计)
    打印("  系统调用_延迟样本: " + 系统调用_延迟样本)
    打印("  系统调用_超时次数: " + 系统调用_超时次数)
    打印("  系统调用_速率: " + 系统调用_速率)
    打印("  健康: " + 如果 (系统调用入口_健康评估()) { "正常" } 否则 { "异常" })
}

函数 系统调用入口_全局重置() {
    系统调用_总次数 = 0
    系统调用_失败次数 = 0
    系统调用_已初始化 = 0
    系统调用_AI拦截次数 = 0
    系统调用_未注册次数 = 0
    系统调用_错误数 = 0
    系统调用_延迟总计 = 0
    系统调用_延迟样本 = 0
    系统调用_超时次数 = 0
    系统调用_速率 = 0
    系统调用_峰值速率 = 0
    系统调用_每号计数 = []
    每号统计_已初始化 = 0
    打印("[系统调用入口] 统计已重置")
    返回 0
}

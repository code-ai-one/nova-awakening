// 连接表操作

函数 tcp_连接表_插入_已建立(tcb) {
    定义 桶号 = tcp_已建立_哈希桶(tcb.四元组)
    自旋锁_获取(全局传控连接表.锁)
    tcb.下一个 = 全局传控连接表.已建立[桶号].头
    全局传控连接表.已建立[桶号].头 = tcb
    全局传控连接表.已建立[桶号].数量 = 全局传控连接表.已建立[桶号].数量 + 1
    全局传控连接表.连接总数 = 全局传控连接表.连接总数 + 1
    自旋锁_释放(全局传控连接表.锁)
}

函数 tcp_连接表_查找(四元组) {
    定义 桶号 = tcp_已建立_哈希桶(四元组)
    定义 可变 当前 = 全局传控连接表.已建立[桶号].头
    当 (当前 != 空) {
        如果 (当前.四元组.源IP == 四元组.源IP &&
            当前.四元组.源端口 == 四元组.源端口 &&
            当前.四元组.目标IP == 四元组.目标IP &&
            当前.四元组.目标端口 == 四元组.目标端口) {
            返回 当前
        }
        当前 = 当前.下一个
    }
    返回 空
}

函数 tcp_连接表_查找监听(端口) {
    定义 桶号 = tcp_监听_哈希桶(端口)
    定义 可变 当前 = 全局传控连接表.监听[桶号].头
    当 (当前 != 空) {
        如果 (当前.四元组.源端口 == 端口) {
            返回 当前
        }
        当前 = 当前.下一个
    }
    返回 空
}

函数 tcp_连接表_移除(tcb) {
    定义 桶号 = tcp_已建立_哈希桶(tcb.四元组)
    自旋锁_获取(全局传控连接表.锁)

    定义 可变 前一个 = 空
    定义 可变 当前 = 全局传控连接表.已建立[桶号].头
    当 (当前 != 空) {
        如果 (当前 == tcb) {
            如果 (前一个 == 空) {
                全局传控连接表.已建立[桶号].头 = 当前.下一个
            } 否则 {
                前一个.下一个 = 当前.下一个
            }
            全局传控连接表.已建立[桶号].数量 = 全局传控连接表.已建立[桶号].数量 - 1
            全局传控连接表.连接总数 = 全局传控连接表.连接总数 - 1
            跳出
        }
        前一个 = 当前
        当前 = 当前.下一个
    }

    自旋锁_释放(全局传控连接表.锁)
}

// 主动打开(connect)三次握手

函数 tcp_连接(sk, 目标IP, 目标端口) {
    定义 可变 tcb = sk.tcp控制块
    如果 (tcb.状态 != 传控_状态_关闭) {
        返回 错误码_已连接
    }

    // 分配临时端口
    如果 (tcb.四元组.源端口 == 0) {
        tcb.四元组.源端口 = tcp_分配临时端口()
    }
    tcb.四元组.目标IP   = 目标IP
    tcb.四元组.目标端口 = 目标端口

    // 发送SYN
    定义 可变 Nova缓冲 = tcp_构建SYN段(tcb)
    如果 (Nova缓冲 == 空) { 返回 错误码_内存不足 }

    tcb.状态 = 传控_状态_SYN已发送
    tcb.发送序号 = tcb.发送序号 + 1

    // 加入重传队列
    Nova网络缓冲_队列_入队(tcb.重传队列, Nova缓冲)
    tcp_启动重传定时器(tcb)

    // 发送
    定义 结果 = tcp_发送段(tcb, Nova缓冲)
    如果 (结果 != 0) {
        tcb.状态 = 传控_状态_关闭
        返回 结果
    }

    // 等待SYN-ACK(异步，由输入处理完成)
    返回 0
}

函数 tcp_构建SYN段(tcb) {
    定义 可变 Nova缓冲 = Nova缓冲_分配(传控_头部大小 + 传控_选项最大大小)
    如果 (Nova缓冲 == 空) { 返回 空 }

    定义 可变 头 = Nova缓冲.数据
    tcp_设置源端口(头, tcb.四元组.源端口)
    tcp_设置目标端口(头, tcb.四元组.目标端口)
    tcp_设置序号(头, tcb.发送序号)
    tcp_设置确认号(头, 0)
    tcp_设置标志(头, 传控_标志_SYN)
    tcp_设置窗口(头, tcb.接收窗口)

    // 添加MSS选项
    tcp_添加MSS选项(头, tcb.mss)
    // 添加窗口缩放选项
    tcp_添加窗口缩放选项(头, 传控_默认窗口缩放)

    返回 Nova缓冲
}

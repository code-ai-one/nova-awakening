函数 exp_approx(x) {
    定义 x2 = x * x
    定义 x3 = x2 * x
    定义 x4 = x3 * x
    // 分步看
    打印(字符串拼接("  x bits=", 转字符串(x)))
    打印(字符串拼接("  x2=x*x bits=", 转字符串(x2)))
    打印(字符串拼接("  x3=x2*x bits=", 转字符串(x3)))
    打印(字符串拼接("  x4=x3*x bits=", 转字符串(x4)))
    定义 t1 = x2 / 2.0
    定义 t2 = x3 / 6.0
    定义 t3 = x4 / 24.0
    打印(字符串拼接("  x2/2 bits=", 转字符串(t1)))
    打印(字符串拼接("  x3/6 bits=", 转字符串(t2)))
    打印(字符串拼接("  x4/24 bits=", 转字符串(t3)))
    定义 r = 1.0 + x + t1 + t2 + t3
    打印(字符串拼接("  sum bits=", 转字符串(r)))
    返回 r
}

函数 主程序() {
    打印("exp_approx(2.0):")
    定义 r = exp_approx(2.0)
    // 期望 7.0 bits = 4620693217682128896
    返回 0
}

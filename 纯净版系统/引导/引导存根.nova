导入("../中枢/类型定义.nova")
导入("../中枢/错误码.nova")
导入("./寄存器定义.nova")
导入("./特权指令.nova")
导入("./串口早期输.nova")
导入("../中枢/字符串替换.nova")
导入("../中枢/页表重建.nova")

// NovaOS 引导存根 — 32位保护模式→64位长模式
// 注意: 此文件在裸机模式下大部分是汇编, Nova代码辅助

定义 临时栈顶 = 0x90000        // 临时内核栈
定义 内核加载地址 = 0x100000   // 1MB, Nova门控循环B加载内核的位置
定义 页表物理地址 = 0x1000     // 初始页表放在物理地址4KB处

// 恒等映射: 虚拟地址=物理地址 (前4GB)
// 高地址映射: 0xFFFF800000000000 → 物理0

函数 引导_创建初始页表() {
    // PML4 (第4级) — 物理地址 0x1000
    定义 PML4 = 页表物理地址
    内存填充(PML4, 0, 页大小)
    // 条目0: 恒等映射
    内存写(PML4, (页表物理地址 + 页大小) | PTE_存在 | PTE_可写)
    // 条目256: 高半内核映射
    内存写(PML4 + 256 * 8, (页表物理地址 + 页大小) | PTE_存在 | PTE_可写)
    
    // PDPT (第3级) — 物理地址 0x2000
    定义 PDPT = 页表物理地址 + 页大小
    内存填充(PDPT, 0, 页大小)
    // 用1GB大页映射前4GB
    定义 可变 i = 0
    当 (i < 4) {
        内存写(PDPT + i * 8, (i * GB) | PTE_存在 | PTE_可写 | PTE_大页)
        i = i + 1
    }
}

函数 引导_进入长模式() {
    // 1. 创建页表
    引导_创建初始页表()
    
    // 2. 加载CR3
    写CR3(页表物理地址)
    
    // 3. 使能PAE (CR4.PAE=1)
    定义 cr4 = 读CR4()
    写CR4(cr4 | CR4_PAE)
    
    // 4. 使能长模式 (EFER.LME=1)
    定义 efer = 读MSR(MSR_EFER)
    写MSR(MSR_EFER, efer | EFER_LME)
    
    // 5. 使能分页 (CR0.PG=1)
    定义 cr0 = 读CR0()
    写CR0(cr0 | CR0_PG | CR0_PE | CR0_WP)
    
    // 6. 远跳转到64位代码段 (由汇编完成)
    // 汇编 { "jmp 0x08:入口64" }
}

// 页表常量 

// PTE_存在 定义在 架构/x86_64/寄存器定义.nova
// PTE_可写 定义在 架构/x86_64/寄存器定义.nova
// PTE_用户 定义在 架构/x86_64/寄存器定义.nova
// PTE_WT 定义在 架构/x86_64/寄存器定义.nova
// PTE_NC 定义在 架构/x86_64/寄存器定义.nova
// PTE_访问 定义在 架构/x86_64/寄存器定义.nova
// PTE_脏 定义在 架构/x86_64/寄存器定义.nova
// PTE_大页 定义在 架构/x86_64/寄存器定义.nova
// PTE_全局 定义在 架构/x86_64/寄存器定义.nova
// PTE_NX 定义在 架构/x86_64/寄存器定义.nova

定义 GB = 0x40000000       // 1GB
定义 MB = 0x100000         // 1MB

// 控制寄存器常量

定义 CR0_PE = 0x00000001   // 保护模式使能
定义 CR0_MP = 0x00000002   // 监控协处理器
定义 CR0_EM = 0x00000004   // 仿真
定义 CR0_TS = 0x00000008   // 任务已切换
定义 CR0_ET = 0x00000010   // 扩展类型
定义 CR0_NE = 0x00000020   // 数值错误
定义 CR0_WP = 0x00010000   // 写保护
定义 CR0_AM = 0x00040000   // 对齐掩码
定义 CR0_NW = 0x20000000   // Not Write-through
定义 CR0_CD = 0x40000000   // 缓存禁止
定义 CR0_PG = 0x80000000   // 分页使能

定义 CR4_PAE   = 0x00000020  // 物理地址扩展
定义 CR4_PGE   = 0x00000080  // 全局页使能
定义 CR4_OSFXSR = 0x00000200 // SSE/SSE2支持
定义 CR4_OSXMMEXCPT = 0x00000400  // SSE异常
定义 CR4_FSGSBASE = 0x00010000    // FSGSBASE指令
定义 CR4_PCIDE = 0x00020000      // PCID使能
定义 CR4_OSXSAVE = 0x00040000    // XSAVE使能
定义 CR4_SMEP  = 0x00100000      // SMEP使能
定义 CR4_SMAP  = 0x00200000      // SMAP使能

定义 MSR_EFER = 0xC0000080
定义 EFER_SCE = 0x001   // 系统调用扩展
定义 EFER_LME = 0x100   // 长模式使能
定义 EFER_LMA = 0x400   // 长模式活跃
定义 EFER_NXE = 0x800   // NX使能

// CPU特性检测 

结构 CPU信息 {
    厂商,
    型号名称,
    家族,
    型号,
    步进,
    特性_EDX,
    特性_ECX,
    扩展特性,
    最大CPUID,
    核心数,
    缓存行大小,
}

定义 可变 引导CPU信息 = CPU信息 {}

函数 引导_检测CPU() {
    // CPUID leaf 0: 获取厂商
    定义 结果0 = cpuid(0, 0)
    引导CPU信息.最大CPUID = 结果0[0]
    // EBX+EDX+ECX 拼接厂商字符串
    引导CPU信息.厂商 = cpuid_vendor_string(结果0[1], 结果0[3], 结果0[2])

    // CPUID leaf 1: 获取版本和特性
    定义 结果1 = cpuid(1, 0)
    引导CPU信息.步进 = 结果1[0] & 0xF
    引导CPU信息.型号 = (结果1[0] >> 4) & 0xF
    引导CPU信息.家族 = (结果1[0] >> 8) & 0xF
    引导CPU信息.特性_EDX = 结果1[3]
    引导CPU信息.特性_ECX = 结果1[2]
    引导CPU信息.缓存行大小 = ((结果1[1] >> 8) & 0xFF) * 8

    // 扩展家族/型号
    如果 (引导CPU信息.家族 == 0xF) {
        引导CPU信息.家族 = 引导CPU信息.家族 + ((结果1[0] >> 20) & 0xFF)
    }
    如果 (引导CPU信息.家族 >= 6) {
        引导CPU信息.型号 = 引导CPU信息.型号 + (((结果1[0] >> 16) & 0xF) << 4)
    }

    // 检查必需特性
    如果 (!(引导CPU信息.特性_EDX & (1 << 25))) {
        早期_panic("CPU不支持SSE! NovaOS要求SSE2+")
    }
    如果 (!(引导CPU信息.特性_EDX & (1 << 26))) {
        早期_panic("CPU不支持SSE2!")
    }

    早期打印("CPU: " + 引导CPU信息.厂商)
    早期打印数值("  家族", 引导CPU信息.家族)
    早期打印数值("  型号", 引导CPU信息.型号)
}

函数 cpuid_vendor_string(ebx, edx, ecx) {
    // 将3个32位寄存器拼接为12字符厂商字符串
    定义 可变 s = ""
    定义 可变 i = 0
    当 (i < 4) { s = s + 字符((ebx >> (i * 8)) & 0xFF); i = i + 1 }
    i = 0
    当 (i < 4) { s = s + 字符((edx >> (i * 8)) & 0xFF); i = i + 1 }
    i = 0
    当 (i < 4) { s = s + 字符((ecx >> (i * 8)) & 0xFF); i = i + 1 }
    返回 s
}

函数 引导_使能SSE() {
    // 使能SSE/SSE2: CR0.EM=0, CR0.MP=1, CR4.OSFXSR=1, CR4.OSXMMEXCPT=1
    定义 cr0 = 读CR0()
    cr0 = cr0 & (~CR0_EM)
    cr0 = cr0 | CR0_MP
    写CR0(cr0)

    定义 cr4 = 读CR4()
    cr4 = cr4 | CR4_OSFXSR | CR4_OSXMMEXCPT
    写CR4(cr4)
}

函数 引导_使能NX() {
    // 使能NX位 (EFER.NXE=1)
    定义 efer = 读MSR(MSR_EFER)
    写MSR(MSR_EFER, efer | EFER_NXE)
}

函数 引导_获取CPU信息() { 返回 引导CPU信息 }
函数 引导_CPU有特性(位) { 返回 (引导CPU信息.特性_EDX & (1 << 位)) != 0 }


函数 引导存根_完整统计() {
    返回 [引导_已完成]
}

定义 可变 AI_引导存根_运行指标 = 0
定义 可变 AI_引导存根_异常指标 = 0

函数 AI_引导存根_自诊断() {
    AI_引导存根_运行指标 = 0
    返回 AI_引导存根_运行指标
}

函数 AI_引导存根_优化建议() {
    定义 指标 = AI_引导存根_自诊断()
    返回 "引导存根状态正常"
}

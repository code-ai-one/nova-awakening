// Nova · 编译器 · 热度分析 (Profile-Guided Analysis / Hot Path Detection)
// 静态估算代码热度，指导 PGO 优化策略
// 应用：内联决策/代码布局/循环展开/向量化优先级

// 热度级别

导入("../../标准库/基础.nova")
导入("../../编译器/标记常量.nova")

定义 热度_冷 = 0    // 极少执行（错误处理/初始化路径）
定义 热度_暖 = 1    // 偶尔执行
定义 热度_热 = 2    // 频繁执行
定义 热度_极热 = 3  // 关键路径（循环核心/高频函数）

// 热度估算权重
定义 权重_循环体 = 100      // 每层循环乘以100
定义 权重_函数调用 = 10     // 调用点
定义 权重_分支真 = 7        // 通常为真的分支
定义 权重_分支假 = 3        // 通常为假的分支
定义 权重_错误处理 = 0      // 错误路径假设不热
定义 权重_顶层 = 1          // 基础权重

// 热度记录：[代码位置标识, 估算热度值, 执行次数估算, 来源]
// 来源：0=静态分析, 1=profile反馈, 2=循环分析, 3=开发者标注
定义 热度来源_静态 = 0
定义 热度来源_profile = 1
定义 热度来源_循环 = 2
定义 热度来源_标注 = 3

函数 热度记录_创建(位置, 估算值, 来源) {
    返回 [位置, 估算值, 1, 来源]
}
函数 热度记录_位置(r) { 返回 r[0] }
函数 热度记录_估算值(r) { 返回 r[1] }
函数 热度记录_执行次数(r) { 返回 r[2] }
函数 热度记录_来源(r) { 返回 r[3] }
函数 热度记录_更新执行次数(r, 次数) { r[2] = 次数 }

// 静态热度估算

// 基于循环嵌套深度估算代码热度
函数 热度_从循环深度(循环深度) {
    如果 (循环深度 == 0) { 返回 权重_顶层 }
    定义 可变 热度 = 权重_顶层
    定义 可变 i = 0
    当 (i < 循环深度) {
        热度 = 热度 * 权重_循环体
        如果 (热度 > 1000000) { 热度 = 1000000 }  // 上限
        i = i + 1
    }
    返回 热度
}

// 从语句列表提取热度信息
函数 热度_分析语句列表(语句列表, 当前循环深度) {
    定义 可变 热度值 = 热度_从循环深度(当前循环深度)
    定义 可变 函数调用数 = 0
    定义 可变 i = 0
    当 (i < 计数(语句列表)) {
        定义 语句 = 语句列表[i]
        如果 (是列表(语句) 且 计数(语句) > 0) {
            // 函数调用
            如果 (语句[0] == 节点_调用) { 函数调用数 = 函数调用数 + 1 }
            // 循环
            如果 (语句[0] == 标记_返回) { 热度值 = 热度值 * 权重_循环体 }
        }
        i = i + 1
    }
    热度值 = 热度值 + 函数调用数 * 权重_函数调用
    返回 热度值
}

// 函数热度估算（基于调用频率和循环）
函数 热度_估算函数(函数信息, 调用次数, 最大循环深度) {
    定义 可变 热度 = 调用次数 * 权重_函数调用
    热度 = 热度 + 热度_从循环深度(最大循环深度)
    如果 (热度 > 1000000) { 热度 = 1000000 }
    返回 热度
}

// 判断热度级别
函数 热度_级别(热度值) {
    如果 (热度值 >= 10000) { 返回 热度_极热 }
    如果 (热度值 >= 100) { 返回 热度_热 }
    如果 (热度值 >= 10) { 返回 热度_暖 }
    返回 热度_冷
}

函数 热度_级别名(级别) {
    如果 (级别 == 热度_极热) { 返回 "极热(必须优化)" }
    如果 (级别 == 热度_热) { 返回 "热(建议优化)" }
    如果 (级别 == 热度_暖) { 返回 "暖(可选优化)" }
    返回 "冷(无需优化)"
}

// 热度感知优化决策

// 是否应该优先内联（热路径优先内联）
函数 热度_应优先内联(函数热度, 函数节点数) {
    如果 (热度_级别(函数热度) == 热度_极热) {
        返回 函数节点数 <= 200  // 极热路径允许更大函数内联
    }
    如果 (热度_级别(函数热度) == 热度_热) {
        返回 函数节点数 <= 64
    }
    返回 函数节点数 <= 20  // 冷路径只内联最小函数
}

// 循环展开因子（热路径展开更多）
函数 热度_推荐展开因子(循环热度, 循环体大小) {
    定义 级别 = 热度_级别(循环热度)
    如果 (级别 == 热度_极热 且 循环体大小 <= 4) { 返回 8 }
    如果 (级别 == 热度_极热 且 循环体大小 <= 8) { 返回 4 }
    如果 (级别 == 热度_热 且 循环体大小 <= 4) { 返回 4 }
    如果 (级别 == 热度_热 且 循环体大小 <= 8) { 返回 2 }
    如果 (级别 == 热度_暖 且 循环体大小 <= 2) { 返回 2 }
    返回 1  // 冷路径不展开
}

// 代码布局优先级（热路径应在代码段靠前，提高 I-Cache 命中率）
函数 热度_代码布局优先级(热度值) {
    返回 热度值  // 直接用热度值作为优先级（越大越靠前）
}

// Profile 数据整合
// 用实际运行数据修正静态估算

定义 可变 _热度_profile数据 = 字典()  // 位置ID → 实际执行次数

函数 热度_记录profile(位置ID, 执行次数) {
    字典设(_热度_profile数据, 转字符串(位置ID), 执行次数)
}

函数 热度_查询profile(位置ID) {
    定义 v = 字典取(_热度_profile数据, 转字符串(位置ID))
    如果 (v == 空) { 返回 0 - 1 }  // 无profile数据
    返回 v
}

// 混合估算：静态估算 + Profile数据（有profile时优先用profile）
函数 热度_混合估算(位置ID, 静态估算) {
    定义 profile = 热度_查询profile(位置ID)
    如果 (profile >= 0) {
        // 有profile数据：70%profile + 30%静态
        返回 profile * 7 / 10 + 静态估算 * 3 / 10
    }
    返回 静态估算
}

// 全局热点排名
函数 热度_排行TopN(热度表, n) {
    // 热度表：[[位置, 热度值], ...]
    定义 m = 计数(热度表)
    定义 可变 sorted_idx = []
    定义 可变 i = 0
    当 (i < m) { 追加(sorted_idx, i) i = i + 1 }
    // 选择排序（取前n）
    i = 0
    当 (i < n 且 i < m) {
        定义 可变 最大idx = i
        定义 可变 j = i + 1
        当 (j < m) {
            如果 (热度表[sorted_idx[j]][1] > 热度表[sorted_idx[最大idx]][1]) {
                最大idx = j
            }
            j = j + 1
        }
        如果 (最大idx != i) {
            定义 暂存 = sorted_idx[i]
            sorted_idx[i] = sorted_idx[最大idx]
            sorted_idx[最大idx] = 暂存
        }
        i = i + 1
    }
    定义 可变 结果 = []
    i = 0
    当 (i < n 且 i < m) {
        追加(结果, 热度表[sorted_idx[i]])
        i = i + 1
    }
    返回 结果
}

// 统计
定义 可变 _热度_分析次数 = 0
定义 可变 _热度_热函数数 = 0

函数 热度_记录分析(是热路径) {
    _热度_分析次数 = _热度_分析次数 + 1
    如果 (是热路径) { _热度_热函数数 = _热度_热函数数 + 1 }
}

函数 热度_报告() {
    返回 [_热度_分析次数, _热度_热函数数,
           如果 (_热度_分析次数 > 0) { _热度_热函数数 * 100 / _热度_分析次数 } 否则 { 0 }]
}

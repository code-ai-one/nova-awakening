// 推理脚本运行时装载
// 将脚本语法、运行时与对象模型主链接回推理阶段。

导入("./汇编运行时.nova")
导入("./内置函数表.nova")
导入("./隐藏类创建.nova")
导入("./词法扫描.nova")
导入("./脚本词法分析.nova")
导入("./表达式匿名类.nova")
导入("./内联缓存.nova")

函数 推理脚本运行时装载_模块清单() {
    返回 [
        "./汇编运行时.nova",
        "./内置函数表.nova",
        "./隐藏类创建.nova",
        "./词法扫描.nova",
        "./脚本词法分析.nova",
        "./表达式匿名类.nova",
        "./内联缓存.nova"
    ]
}

函数 推理脚本运行时装载_统计() {
    返回 {
        模块数: 计数(推理脚本运行时装载_模块清单())
    }
}

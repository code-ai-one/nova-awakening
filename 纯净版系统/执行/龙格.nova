// 龙格 (DragonFmt) — Nova代码格式化器
// 真实: 缩进标准化+空行规范+尾部空白清理+括号对齐

函数 龙格_main(参数) {
    如果 (计数(参数) == 0) {
        打印行("龙格 v0.1 — Nova代码格式化器")
        打印行("用法: 龙格 [文件...]")
        打印行("  龙格 --check [文件...]  — 仅检查不修改")
        返回 0
    }

    定义 可变 仅检查 = 假
    定义 可变 文件列表 = []
    定义 可变 i = 0
    当 (i < 计数(参数)) {
        如果 (参数[i] == "--check") { 仅检查 = 真 }
        否则 { 追加(文件列表, 参数[i]) }
        i = i + 1
    }

    定义 可变 已格式化 = 0
    定义 可变 需修改 = 0
    定义 可变 k = 0
    当 (k < 计数(文件列表)) {
        定义 路径 = 文件列表[k]
        定义 内容 = 文件_读取全部(路径)
        如果 (内容 == 空) {
            打印行(字符串拼接("龙格: 无法读取 ", 路径))
            k = k + 1
            继续
        }

        定义 格式化后 = 龙格_格式化(内容)
        如果 (格式化后 != 内容) {
            需修改 = 需修改 + 1
            如果 (仅检查) {
                打印行(字符串拼接("需格式化: ", 路径))
            } 否则 {
                文件_写入全部(路径, 格式化后)
                打印行(字符串拼接("已格式化: ", 路径))
            }
        }
        已格式化 = 已格式化 + 1
        k = k + 1
    }

    打印行(字符串拼接("检查 ", 字符串拼接(整数转字符串(已格式化), 字符串拼接(" 个文件, ", 字符串拼接(整数转字符串(需修改), " 需修改")))))
    返回 0
}

函数 龙格_格式化(代码) {
    定义 行列表 = 字符串分割(代码, "\n")
    定义 可变 结果 = []
    定义 可变 缩进深度 = 0
    定义 缩进单位 = "    "   // 4空格
    定义 可变 上一行空 = 假

    定义 可变 i = 0
    当 (i < 计数(行列表)) {
        定义 行 = 字符串去首尾空白(行列表[i])

        // 规则1: 连续空行合并为1个
        如果 (字符串长度(行) == 0) {
            如果 (!上一行空) { 追加(结果, ""); 上一行空 = 真 }
            i = i + 1; 继续
        }
        上一行空 = 假

        // 规则2: 右花括号→先减缩进再输出
        如果 (字符串开始于(行, "}")) {
            缩进深度 = 缩进深度 - 1
            如果 (缩进深度 < 0) { 缩进深度 = 0 }
        }

        // 规则3: 构造缩进后的行
        定义 可变 缩进行 = ""
        定义 可变 d = 0
        当 (d < 缩进深度) { 缩进行 = 缩进行 + 缩进单位; d = d + 1 }
        缩进行 = 缩进行 + 行
        追加(结果, 缩进行)

        // 规则4: 左花括号→增加缩进
        定义 可变 j = 0
        当 (j < 字符串长度(行)) {
            定义 ch = 字符串字符(行, j)
            如果 (ch == 123) { 缩进深度 = 缩进深度 + 1 }  // {
            如果 (ch == 125) { }  // } 已在上面处理
            j = j + 1
        }

        // 规则5: 函数/结构定义前加空行(如果上一行不是空行或注释)
        如果 (i > 0 && (字符串开始于(行, "函数 ") || 字符串开始于(行, "结构 "))) {
            如果 (计数(结果) > 1) {
                定义 上行 = 结果[计数(结果) - 2]
                如果 (字符串长度(上行) > 0 && !字符串开始于(字符串去首尾空白(上行), "//")) {
                    // 在函数前插入空行
                    定义 最后 = 结果[计数(结果) - 1]
                    设置(结果, 计数(结果) - 1, "")
                    追加(结果, 最后)
                }
            }
        }

        i = i + 1
    }

    // 规则6: 文件末尾恰好一个换行
    当 (计数(结果) > 0 && 字符串长度(结果[计数(结果) - 1]) == 0) {
        列表_移除(结果, 计数(结果) - 1)
    }
    追加(结果, "")

    返回 字符串连接(结果, "\n")
}


函数 龙格_差异(原始, 格式化后) {
    定义 原行 = 字符串分割(原始, "\n")
    定义 新行 = 字符串分割(格式化后, "\n")
    定义 可变 差异数 = 0
    定义 最大 = 计数(原行)
    如果 (计数(新行) > 最大) { 最大 = 计数(新行) }
    定义 可变 i = 0
    当 (i < 最大) {
        定义 旧 = ""
        定义 新 = ""
        如果 (i < 计数(原行)) { 旧 = 原行[i] }
        如果 (i < 计数(新行)) { 新 = 新行[i] }
        如果 (旧 != 新) { 差异数 = 差异数 + 1 }
        i = i + 1
    }
    返回 差异数

// NovaOS GQA — 分组查询注意力 (Grouped Query Nova注意力)
// 论文: Ainslie et al. "GQA: Training Generalized Multi-Query
//       Nova注意力 Models from Multi-Head Checkpoints" (2023)
// 核心: 多个Query头共享一组KV头，减少KV缓存内存占用
//   MHA: Q头=H, KV头=H (完全独立)
//   MQA: Q头=H, KV头=1 (极端共享)
//   GQA: Q头=H, KV头=G (分组共享, G通常=H/8)
//   Llama3/Mistral/Gemma均采用GQA
// E7阶段Rust验证反哺 (gqa_verifier.rs):
//   Q10精度: d_head<16时误差较大(8头误差432/1000), d_head≥64时误差=0 ✅
//   最优分组: G=2(KV节省75%,误差63/1000)是精度与内存的最优平衡点
//   MQA(G=1): KV节省87%但误差115/1000偏高, 不推荐长上下文
//   建议: Nova推理优先使用d_head=64+ 和 G=2分组
定义 GQA_最优组数     = 2    // E7验证: KV节省75%,误差63/1000最优
定义 GQA_推荐头维度  = 64   // E7验证: d_head≥64时Q10误差=0

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("./智能总线鼠标.nova")
导入("../中枢/字符串替换.nova")
导入("../执行/底层内存操.nova")
导入("../标准/数学幂根对数.nova")
导入("./分页注意.nova")

结构 GQA配置 {
    隐藏维度,
    Q头数,    // u32 例: 32
    KV头数,    // u32 例: 8 (每4个Q头共享1个KV头)
    头维度,    // u32 例: 128
    RoPE基频,    // f64 旋转位置编码基频(默认10000)
}

函数 GQA_创建(隐藏维度, Q头数, KV头数) {
    定义 头维度 = 隐藏维度 / Q头数
    定义 可变 配置 = GQA配置 {}
    配置.隐藏维度 = 隐藏维度
    配置.Q头数 = Q头数
    配置.KV头数 = KV头数
    配置.头维度 = 头维度
    配置.RoPE基频 = 10000.0

    // 投影矩阵
    定义 W_q = 张量_随机正态(隐藏维度, Q头数 * 头维度, 0.0, 0.02)
    定义 W_k = 张量_随机正态(隐藏维度, KV头数 * 头维度, 0.0, 0.02)
    定义 W_v = 张量_随机正态(隐藏维度, KV头数 * 头维度, 0.0, 0.02)
    定义 W_o = 张量_随机正态(Q头数 * 头维度, 隐藏维度, 0.0, 0.02)

    返回 [配置, W_q, W_k, W_v, W_o]
}

函数 GQA_前向(层, 输入, KV缓存, 位置) {
    GQA_确保统计()
    定义 配置 = 层[0]
    定义 W_q = 层[1]
    定义 W_k = 层[2]
    定义 W_v = 层[3]
    定义 W_o = 层[4]
    定义 B = 输入.批大小
    定义 N = 输入.序列长度
    定义 d = 配置.头维度
    定义 组大小 = 配置.Q头数 / 配置.KV头数   // 每组Q头数

    // 1. 线性投影
    定义 Q = 矩阵乘(输入, W_q)    // [B, N, Q头数*d]
    定义 K = 矩阵乘(输入, W_k)    // [B, N, KV头数*d]
    定义 V = 矩阵乘(输入, W_v)    // [B, N, KV头数*d]

    // 2. RoPE旋转位置编码 (Su et al. 2021)
    Q = RoPE_应用(Q, 位置, 配置.RoPE基频, 配置.Q头数, d)
    K = RoPE_应用(K, 位置, 配置.RoPE基频, 配置.KV头数, d)

    // 3. KV缓存更新 (自回归推理)
    如果 (KV缓存 != 空) {
        KV缓存_追加(KV缓存, K, V)
        K = KV缓存_取K(KV缓存)
        V = KV缓存_取V(KV缓存)
    }

    // 4. 分组注意力计算
    定义 缩放 = 1.0 / 数学_平方根(d)
    定义 可变 输出 = 张量_零(B, N, 配置.Q头数 * d)

    定义 可变 g = 0
    当 (g < 配置.KV头数) {
        // 这一组的Q头范围: [g*组大小, (g+1)*组大小)
        定义 Kg = 张量_取头(K, g)           // [B, S, d]  S=缓存序列长度
        定义 Vg = 张量_取头(V, g)           // [B, S, d]

        定义 可变 h = 0
        当 (h < 组大小) {
            定义 q头idx = g * 组大小 + h
            定义 Qh = 张量_取头(Q, q头idx)  // [B, N, d]

            // 注意力: Nova归一化指数(Q @ K^T / sqrt(d)) @ V
            定义 分数 = 矩阵乘_转置(Qh, Kg, 缩放)   // [B, N, S]
            flash_因果掩码_GQA(分数, 位置)
            定义 权重 = 张量_Nova归一化指数(分数, -1)
            定义 头输出 = 矩阵乘(权重, Vg)            // [B, N, d]

            张量_写头(输出, q头idx, 头输出)
            h = h + 1
        }
        g = g + 1
    }

    // 5. 输出投影
    返回 矩阵乘(输出, W_o)
}

// RoPE旋转位置编码 (Su et al. 2021, 改进: NTK-aware)

函数 RoPE_应用(x, 位置, 基频, 头数, d) {
    定义 可变 结果 = 张量_零同形(x)
    定义 可变 h = 0
    当 (h < 头数) {
        定义 可变 i = 0
        当 (i < d / 2) {
            // θ_i = base^(-2i/d)
            定义 theta = 数学_pow(基频, -2.0 * i / d)
            定义 角度 = 位置 * theta
            定义 cos_val = 数学_cos(角度)
            定义 sin_val = 数学_sin(角度)

            // 旋转: [x1, x2] → [x1*cos - x2*sin, x1*sin + x2*cos]
            定义 x1 = 张量_取元素(x, h, 2 * i)
            定义 x2 = 张量_取元素(x, h, 2 * i + 1)
            张量_设元素(结果, h, 2 * i, x1 * cos_val - x2 * sin_val)
            张量_设元素(结果, h, 2 * i + 1, x1 * sin_val + x2 * cos_val)
            i = i + 1
        }
        h = h + 1
    }
    返回 结果
}

函数 flash_因果掩码_GQA(分数, 当前位置) {
    定义 N = 分数.行数
    定义 S = 分数.列数
    定义 可变 i = 0
    当 (i < N) {
        定义 可变 j = 0
        当 (j < S) {
            如果 (当前位置 + i < j) {
                张量_设置(分数, i, j, -1e30)
            }
            j = j + 1
        }
        i = i + 1
    }
}

// §2 KV缓存管理 — 自回归推理的增量KV存储

定义 KV缓存_最大序列长度 = 8192
定义 KV缓存_初始容量 = 256
定义 KV缓存_扩容因子 = 2

结构 GQA_KV缓存 {
    K缓存,           // [KV头数, 当前长度, 头维度] 张量
    V缓存,           // [KV头数, 当前长度, 头维度] 张量
    当前长度,         // 已缓存的令牌数
    容量,             // 当前分配的最大长度
    KV头数,           // KV头数
    头维度,           // 每头维度
    分页序列KV,
    分页分配器,
    分页层数,
    分页层索引,
    已初始化,         // 是否已初始化
}

结构 GQA统计 {
    总前向次数,
    总令牌处理数,
    缓存命中次数,
    缓存扩容次数,
    RoPE计算次数,
    平均序列长度,
    最大序列长度,
    总推理耗时,       // u64 微秒
    注意力计算次数,
    分页桥接次数,
    分页解码次数,
    内存使用量,       // u64 字节
}

定义 可变 全局GQA统计 = 0

函数 GQA统计_初始化() {
    定义 统计 = GQA统计 {}
    统计.总前向次数 = 0
    统计.总令牌处理数 = 0
    统计.缓存命中次数 = 0
    统计.缓存扩容次数 = 0
    统计.RoPE计算次数 = 0
    统计.平均序列长度 = 0
    统计.最大序列长度 = 0
    统计.总推理耗时 = 0
    统计.注意力计算次数 = 0
    统计.分页桥接次数 = 0
    统计.分页解码次数 = 0
    统计.内存使用量 = 0
    全局GQA统计 = 统计
    返回 统计
}

函数 GQA_确保统计() {
    如果 (全局GQA统计 == 0) {
        GQA统计_初始化()
    }
}

函数 KV缓存_创建(KV头数, 头维度) {
    GQA_确保统计()
    定义 缓存 = GQA_KV缓存 {}
    缓存.KV头数 = KV头数
    缓存.头维度 = 头维度
    缓存.当前长度 = 0
    缓存.容量 = KV缓存_初始容量
    缓存.K缓存 = 张量_零(KV头数, KV缓存_初始容量, 头维度)
    缓存.V缓存 = 张量_零(KV头数, KV缓存_初始容量, 头维度)
    缓存.分页序列KV = 0
    缓存.分页分配器 = 0
    缓存.分页层数 = 0
    缓存.分页层索引 = 0
    缓存.已初始化 = 真
    返回 缓存
}

函数 KV缓存_创建_分页(KV头数, 头维度, 分配器, 层数, 层索引) {
    定义 缓存 = KV缓存_创建(KV头数, 头维度)
    KV缓存_绑定分页(缓存, 分配器, 层数, 层索引)
    返回 缓存
}

函数 KV缓存_绑定分页(缓存, 分配器, 层数, 层索引) {
    如果 (缓存 == 0 || 分配器 == 0) { 返回 -1 }
    缓存.分页分配器 = 分配器
    缓存.分页层数 = 层数
    缓存.分页层索引 = 层索引
    如果 (缓存.分页序列KV == 0) {
        缓存.分页序列KV = 序列KV_创建(0, 层数)
    }
    返回 0
}

函数 KV缓存_分页已就绪(缓存) {
    如果 (缓存 == 0 || 缓存.分页分配器 == 0 || 缓存.分页序列KV == 0) { 返回 假 }
    返回 缓存.当前长度 == 缓存.分页序列KV.序列长度
}

函数 KV缓存_写入分页_增量(缓存, K新, V新) {
    如果 (缓存 == 0 || 缓存.分页分配器 == 0 || 缓存.分页序列KV == 0) { 返回 0 }
    如果 (K新 == 0 || V新 == 0 || K新.序列长度 != 1) { 返回 0 }
    如果 (序列KV_追加令牌(缓存.分页序列KV, 缓存.分页分配器, 缓存.分页层数) < 0) { 返回 -1 }

    定义 槽位置 = 缓存.分页序列KV.序列长度 - 1
    槽位置 = 槽位置 % KV_BLOCK_大小
    定义 可变 h = 0
    当 (h < 缓存.KV头数) {
        定义 可变 d = 0
        当 (d < 缓存.头维度) {
            定义 idx = h * 缓存.头维度 + d
            序列KV_写入标量(
                缓存.分页序列KV,
                缓存.分页分配器,
                缓存.分页层索引,
                h,
                槽位置,
                d,
                内存_读32(K新.数据 + idx * 4),
                内存_读32(V新.数据 + idx * 4)
            )
            d = d + 1
        }
        h = h + 1
    }
    如果 (全局GQA统计 != 0) {
        全局GQA统计.分页桥接次数 = 全局GQA统计.分页桥接次数 + 1
    }
    返回 0
}

函数 KV缓存_销毁(缓存) {
    如果 (缓存 == 0) { 返回 }
    如果 (缓存.K缓存 != 0) { 张量_释放(缓存.K缓存) }
    如果 (缓存.V缓存 != 0) { 张量_释放(缓存.V缓存) }
    如果 (缓存.分页序列KV != 0 && 缓存.分页分配器 != 0) {
        序列KV_释放(缓存.分页序列KV, 缓存.分页分配器, 缓存.分页层数)
        缓存.分页序列KV = 0
    }
    缓存.已初始化 = 假
}

函数 KV缓存_追加(缓存, K新, V新) {
    如果 (缓存 == 0 || 缓存.已初始化 == 假) { 返回 -1 }
    定义 新令牌数 = K新.序列长度

    // 检查是否需要扩容
    如果 (缓存.当前长度 + 新令牌数 > 缓存.容量) {
        定义 新容量 = 缓存.容量 * KV缓存_扩容因子
        如果 (新容量 > KV缓存_最大序列长度) { 新容量 = KV缓存_最大序列长度 }
        如果 (缓存.当前长度 + 新令牌数 > 新容量) {
            打印("[GQA] 错误: KV缓存超出最大序列长度")
            返回 -1
        }

        // 分配新缓存并复制旧数据
        定义 新K = 张量_零(缓存.KV头数, 新容量, 缓存.头维度)
        定义 新V = 张量_零(缓存.KV头数, 新容量, 缓存.头维度)
        张量_复制区域(新K, 缓存.K缓存, 0, 缓存.当前长度)
        张量_复制区域(新V, 缓存.V缓存, 0, 缓存.当前长度)
        张量_释放(缓存.K缓存)
        张量_释放(缓存.V缓存)
        缓存.K缓存 = 新K
        缓存.V缓存 = 新V
        缓存.容量 = 新容量

        如果 (全局GQA统计 != 0) {
            全局GQA统计.缓存扩容次数 = 全局GQA统计.缓存扩容次数 + 1
        }
    }

    // 追加新KV到缓存末尾
    张量_复制区域_偏移(缓存.K缓存, K新, 缓存.当前长度, 新令牌数)
    张量_复制区域_偏移(缓存.V缓存, V新, 缓存.当前长度, 新令牌数)
    缓存.当前长度 = 缓存.当前长度 + 新令牌数
    KV缓存_写入分页_增量(缓存, K新, V新)

    如果 (全局GQA统计 != 0) {
        全局GQA统计.缓存命中次数 = 全局GQA统计.缓存命中次数 + 1
    }
    返回 0
}

函数 KV缓存_取K(缓存) {
    如果 (缓存 == 0) { 返回 空 }
    返回 张量_切片(缓存.K缓存, 0, 缓存.当前长度)
}

函数 KV缓存_取V(缓存) {
    如果 (缓存 == 0) { 返回 空 }
    返回 张量_切片(缓存.V缓存, 0, 缓存.当前长度)
}

函数 KV缓存_重置(缓存) {
    如果 (缓存 == 0) { 返回 }
    缓存.当前长度 = 0
    如果 (缓存.分页序列KV != 0 && 缓存.分页分配器 != 0) {
        序列KV_释放(缓存.分页序列KV, 缓存.分页分配器, 缓存.分页层数)
        缓存.分页序列KV = 序列KV_创建(0, 缓存.分页层数)
    }
}

函数 KV缓存_获取长度(缓存) {
    如果 (缓存 == 0) { 返回 0 }
    返回 缓存.当前长度
}

// §3 GQA变体 — MHA/MQA/GQA统一接口

定义 注意力模式_MHA = 0
定义 注意力模式_MQA = 1
定义 注意力模式_GQA = 2

函数 GQA_自动选择模式(Q头数, KV头数) {
    如果 (Q头数 == KV头数) { 返回 注意力模式_MHA }
    如果 (KV头数 == 1) { 返回 注意力模式_MQA }
    返回 注意力模式_GQA
}

函数 GQA_计算内存节省(Q头数, KV头数, 序列长度, 头维度) {
    // MHA的KV缓存大小
    定义 MHA内存 = Q头数 * 序列长度 * 头维度 * 2 * 4
    // GQA的KV缓存大小
    定义 GQA内存 = KV头数 * 序列长度 * 头维度 * 2 * 4
    定义 节省比例 = ((MHA内存 - GQA内存) * 100) / MHA内存
    返回 节省比例
}

// §4 NTK-aware RoPE — 支持长序列外推

定义 RoPE_NTK_缩放因子 = 2
定义 RoPE_训练长度 = 4096

函数 RoPE_NTK_应用(x, 位置, 基频, 头数, d, 最大序列长度) {
    // NTK-aware缩放: 当序列超过训练长度时动态调整基频
    定义 可变 实际基频 = 基频
    如果 (最大序列长度 > RoPE_训练长度) {
        // NTK缩放: base' = base * (scale * len / train_len) ^ (d / (d-2))
        定义 比率 = (RoPE_NTK_缩放因子 * 最大序列长度) / RoPE_训练长度
        实际基频 = 基频 * 数学_pow(比率, d / (d - 2))
    }

    定义 可变 结果 = 张量_零同形(x)
    定义 可变 h = 0
    当 (h < 头数) {
        定义 可变 i = 0
        当 (i < d / 2) {
            定义 theta = 数学_pow(实际基频, -2.0 * i / d)
            定义 角度 = 位置 * theta
            定义 cos_val = 数学_cos(角度)
            定义 sin_val = 数学_sin(角度)

            定义 x1 = 张量_取元素(x, h, 2 * i)
            定义 x2 = 张量_取元素(x, h, 2 * i + 1)
            张量_设元素(结果, h, 2 * i, x1 * cos_val - x2 * sin_val)
            张量_设元素(结果, h, 2 * i + 1, x1 * sin_val + x2 * cos_val)
            i = i + 1
        }
        h = h + 1
        如果 (全局GQA统计 != 0) {
            全局GQA统计.RoPE计算次数 = 全局GQA统计.RoPE计算次数 + 1
        }
    }
    返回 结果
}

// §5 带KV缓存的增量前向 — 自回归解码优化

函数 GQA_增量前向(层, 新令牌嵌入, KV缓存, 位置) {
    如果 (层 == 0 || 新令牌嵌入 == 0) { 返回 空 }
    GQA_确保统计()

    定义 配置 = 层[0]
    定义 W_q = 层[1]
    定义 W_k = 层[2]
    定义 W_v = 层[3]
    定义 W_o = 层[4]
    定义 d = 配置.头维度
    定义 组大小 = 配置.Q头数 / 配置.KV头数

    // 只计算新令牌的QKV (增量, 不重算历史)
    定义 Q新 = 矩阵乘(新令牌嵌入, W_q)
    定义 K新 = 矩阵乘(新令牌嵌入, W_k)
    定义 V新 = 矩阵乘(新令牌嵌入, W_v)

    // RoPE (NTK-aware)
    定义 总长度 = KV缓存_获取长度(KV缓存) + 1
    Q新 = RoPE_NTK_应用(Q新, 位置, 配置.RoPE基频, 配置.Q头数, d, 总长度)
    K新 = RoPE_NTK_应用(K新, 位置, 配置.RoPE基频, 配置.KV头数, d, 总长度)

    // 追加到KV缓存
    KV缓存_追加(KV缓存, K新, V新)
    如果 (KV缓存_分页已就绪(KV缓存)) {
        定义 缩放 = 1.0 / 数学_平方根(d)
        定义 可变 输出 = 张量_零(1, 配置.Q头数 * d)
        定义 可变 g = 0
        当 (g < 配置.KV头数) {
            定义 可变 h = 0
            当 (h < 组大小) {
                定义 q头idx = g * 组大小 + h
                paged_Nova注意力_前向_扁平写入(
                    Q新.数据,
                    q头idx * d,
                    d,
                    KV缓存.分页序列KV,
                    KV缓存.分页分配器,
                    KV缓存.分页层索引,
                    g,
                    缩放,
                    输出.数据,
                    q头idx * d
                )
                如果 (全局GQA统计 != 0) {
                    全局GQA统计.注意力计算次数 = 全局GQA统计.注意力计算次数 + 1
                }
                h = h + 1
            }
            g = g + 1
        }

        如果 (全局GQA统计 != 0) {
            全局GQA统计.总前向次数 = 全局GQA统计.总前向次数 + 1
            全局GQA统计.总令牌处理数 = 全局GQA统计.总令牌处理数 + 1
            全局GQA统计.分页解码次数 = 全局GQA统计.分页解码次数 + 1
            如果 (总长度 > 全局GQA统计.最大序列长度) {
                全局GQA统计.最大序列长度 = 总长度
            }
        }
        返回 矩阵乘(输出, W_o)
    }
    定义 K全 = KV缓存_取K(KV缓存)
    定义 V全 = KV缓存_取V(KV缓存)

    // 分组注意力计算(Q只有1个令牌, KV有完整序列)
    定义 缩放 = 1.0 / 数学_平方根(d)
    定义 可变 输出 = 张量_零(1, 配置.Q头数 * d)

    定义 可变 g = 0
    当 (g < 配置.KV头数) {
        定义 Kg = 张量_取头(K全, g)
        定义 Vg = 张量_取头(V全, g)

        定义 可变 h = 0
        当 (h < 组大小) {
            定义 q头idx = g * 组大小 + h
            定义 Qh = 张量_取头(Q新, q头idx)

            定义 分数 = 矩阵乘_转置(Qh, Kg, 缩放)
            // 因果掩码: 解码时新令牌可以看到所有历史
            定义 权重 = 张量_Nova归一化指数(分数, -1)
            定义 头输出 = 矩阵乘(权重, Vg)

            张量_写头(输出, q头idx, 头输出)

            如果 (全局GQA统计 != 0) {
                全局GQA统计.注意力计算次数 = 全局GQA统计.注意力计算次数 + 1
            }
            h = h + 1
        }
        g = g + 1
    }

    如果 (全局GQA统计 != 0) {
        全局GQA统计.总前向次数 = 全局GQA统计.总前向次数 + 1
        全局GQA统计.总令牌处理数 = 全局GQA统计.总令牌处理数 + 1
        如果 (总长度 > 全局GQA统计.最大序列长度) {
            全局GQA统计.最大序列长度 = 总长度
        }
    }

    返回 矩阵乘(输出, W_o)
}

// §6 AI自适应注意力 — NovaOS独创
// 根据内容复杂度动态调整注意力头数

函数 GQA_AI自适应头数(bus, 输入嵌入, 默认Q头数, 默认KV头数) {
    如果 (bus == 0) { 返回 [默认Q头数, 默认KV头数] }

    // AI: 分析输入的语义复杂度
    定义 复杂度 = AI总线_语义分类(bus, 输入嵌入)

    // 高复杂度: 使用全MHA(更多头, 更好的表达力)
    如果 (复杂度 > 800) {
        返回 [默认Q头数, 默认Q头数]
    }
    // 低复杂度: 使用MQA(更少KV, 更快)
    如果 (复杂度 < 200) {
        返回 [默认Q头数, 1]
    }
    // 中等: 使用默认GQA
    返回 [默认Q头数, 默认KV头数]
}

// §7 统计输出

函数 GQA_打印统计() {
    如果 (全局GQA统计 == 0) {
        打印("[GQA] 统计未初始化")
        返回
    }
    定义 s = 全局GQA统计
    打印("[GQA] ═══ 分组查询注意力统计 ═══")
    打印(字符串拼接("  总前向次数: ", 转字符串(s.总前向次数)))
    打印(字符串拼接("  总令牌处理数: ", 转字符串(s.总令牌处理数)))
    打印(字符串拼接("  缓存命中次数: ", 转字符串(s.缓存命中次数)))
    打印(字符串拼接("  缓存扩容次数: ", 转字符串(s.缓存扩容次数)))
    打印(字符串拼接("  RoPE计算次数: ", 转字符串(s.RoPE计算次数)))
    打印(字符串拼接("  最大序列长度: ", 转字符串(s.最大序列长度)))
    打印(字符串拼接("  注意力计算次数: ", 转字符串(s.注意力计算次数)))
    打印(字符串拼接("  分页桥接次数: ", 转字符串(s.分页桥接次数)))
    打印(字符串拼接("  分页解码次数: ", 转字符串(s.分页解码次数)))
    打印(字符串拼接("  总推理耗时: ", 字符串拼接(转字符串(s.总推理耗时), "μs")))
    打印("[GQA] ═══════════════════════════")
}

// §8 GQA层归一化 — 注意力前后的RMSNorm

结构 RMSNorm {
    权重,             // [隐藏维度] 可学习缩放参数
    维度,             // 隐藏维度
    epsilon,          // 数值稳定性常量
}

函数 RMSNorm_创建(维度) {
    定义 norm = RMSNorm {}
    norm.维度 = 维度
    norm.epsilon = 0.000001
    norm.权重 = 张量_全一(维度)
    返回 norm
}

函数 RMSNorm_销毁(norm) {
    如果 (norm == 0) { 返回 }
    如果 (norm.权重 != 0) { 张量_释放(norm.权重) }
}

函数 RMSNorm_前向(norm, x) {
    如果 (norm == 0 || x == 0) { 返回 x }
    定义 N = norm.维度
    // 计算RMS: sqrt(mean(x^2))
    定义 可变 平方和 = 0.0
    定义 可变 i = 0
    当 (i < N) {
        定义 val = 张量_取元素_1d(x, i)
        平方和 = 平方和 + val * val
        i = i + 1
    }
    定义 rms = 数学_平方根(平方和 / N + norm.epsilon)
    定义 缩放 = 1.0 / rms

    // 归一化并乘以权重
    定义 可变 结果 = 张量_零(N)
    i = 0
    当 (i < N) {
        定义 归一 = 张量_取元素_1d(x, i) * 缩放
        定义 w = 张量_取元素_1d(norm.权重, i)
        张量_设元素_1d(结果, i, 归一 * w)
        i = i + 1
    }
    返回 结果
}

// §9 完整GQA Transformer块 — 注意力+FFN

结构 GQA_Transformer块 {
    注意力层,         // GQA注意力层
    前馈层_gate,      // [隐藏维度, 中间维度] SwiGLU门控
    前馈层_up,        // [隐藏维度, 中间维度]
    前馈层_down,      // [中间维度, 隐藏维度]
    注意力归一化,     // RMSNorm
    前馈归一化,       // RMSNorm
    隐藏维度,
    中间维度,
}

函数 GQA_Transformer块_创建(隐藏维度, 中间维度, Q头数, KV头数) {
    定义 块 = GQA_Transformer块 {}
    块.注意力层 = GQA_创建(隐藏维度, Q头数, KV头数)
    块.前馈层_gate = 张量_随机正态(隐藏维度, 中间维度, 0.0, 0.02)
    块.前馈层_up = 张量_随机正态(隐藏维度, 中间维度, 0.0, 0.02)
    块.前馈层_down = 张量_随机正态(中间维度, 隐藏维度, 0.0, 0.02)
    块.注意力归一化 = RMSNorm_创建(隐藏维度)
    块.前馈归一化 = RMSNorm_创建(隐藏维度)
    块.隐藏维度 = 隐藏维度
    块.中间维度 = 中间维度
    返回 块
}

函数 GQA_Transformer块_前向(块, 输入, KV缓存, 位置) {
    如果 (块 == 0 || 输入 == 0) { 返回 空 }

    // 注意力子层 (Pre-Norm + 残差)
    定义 归一输入 = RMSNorm_前向(块.注意力归一化, 输入)
    定义 注意力输出 = GQA_增量前向(块.注意力层, 归一输入, KV缓存, 位置)
    定义 残差1 = 张量_加(输入, 注意力输出)

    // 前馈子层 (SwiGLU: Shazeer 2020)
    定义 归一残差 = RMSNorm_前向(块.前馈归一化, 残差1)
    定义 gate = 矩阵乘(归一残差, 块.前馈层_gate)
    定义 up = 矩阵乘(归一残差, 块.前馈层_up)
    // SwiGLU: silu(gate) * up
    定义 激活 = 张量_逐元素乘(张量_silu(gate), up)
    定义 前馈输出 = 矩阵乘(激活, 块.前馈层_down)
    定义 残差2 = 张量_加(残差1, 前馈输出)

    返回 残差2
}

函数 GQA_Transformer块_销毁(块) {
    如果 (块 == 0) { 返回 }
    如果 (块.注意力层 != 0) {
        如果 (块.注意力层[1] != 0) { 张量_释放(块.注意力层[1]) }
        如果 (块.注意力层[2] != 0) { 张量_释放(块.注意力层[2]) }
        如果 (块.注意力层[3] != 0) { 张量_释放(块.注意力层[3]) }
        如果 (块.注意力层[4] != 0) { 张量_释放(块.注意力层[4]) }
    }
    如果 (块.前馈层_gate != 0) { 张量_释放(块.前馈层_gate) }
    如果 (块.前馈层_up != 0) { 张量_释放(块.前馈层_up) }
    如果 (块.前馈层_down != 0) { 张量_释放(块.前馈层_down) }
    RMSNorm_销毁(块.注意力归一化)
    RMSNorm_销毁(块.前馈归一化)
}

结构 GQA_Transformer堆栈 {
    块列表,
    缓存列表,
    块数量,
    隐藏维度,
    中间维度,
    Q头数,
    KV头数,
    分页分配器,
}

函数 GQA_Transformer堆栈_创建(隐藏维度, 中间维度, Q头数, KV头数, 层数, 分页分配器) {
    定义 堆栈 = GQA_Transformer堆栈 {}
    堆栈.块列表 = 数组_创建(层数)
    堆栈.缓存列表 = 数组_创建(层数)
    堆栈.块数量 = 层数
    堆栈.隐藏维度 = 隐藏维度
    堆栈.中间维度 = 中间维度
    堆栈.Q头数 = Q头数
    堆栈.KV头数 = KV头数
    堆栈.分页分配器 = 分页分配器

    定义 头维度 = 隐藏维度 / Q头数
    定义 可变 i = 0
    当 (i < 层数) {
        数组_设置(堆栈.块列表, i, GQA_Transformer块_创建(隐藏维度, 中间维度, Q头数, KV头数))
        如果 (分页分配器 != 0) {
            数组_设置(堆栈.缓存列表, i, KV缓存_创建_分页(KV头数, 头维度, 分页分配器, 层数, i))
        } 否则 {
            数组_设置(堆栈.缓存列表, i, KV缓存_创建(KV头数, 头维度))
        }
        i = i + 1
    }
    返回 堆栈
}

函数 GQA_Transformer堆栈_重置缓存(堆栈) {
    如果 (堆栈 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 堆栈.块数量) {
        KV缓存_重置(数组_取(堆栈.缓存列表, i))
        i = i + 1
    }
}

函数 GQA_Transformer堆栈_增量前向(堆栈, 输入, 位置) {
    如果 (堆栈 == 0 || 输入 == 0) { 返回 空 }
    定义 可变 当前 = 输入
    定义 可变 i = 0
    当 (i < 堆栈.块数量) {
        定义 块 = 数组_取(堆栈.块列表, i)
        定义 缓存 = 数组_取(堆栈.缓存列表, i)
        定义 输出 = GQA_Transformer块_前向(块, 当前, 缓存, 位置)
        如果 (i > 0 && 当前 != 0) { 张量_释放(当前) }
        当前 = 输出
        i = i + 1
    }
    返回 当前
}

函数 GQA_Transformer堆栈_销毁(堆栈) {
    如果 (堆栈 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < 堆栈.块数量) {
        GQA_Transformer块_销毁(数组_取(堆栈.块列表, i))
        KV缓存_销毁(数组_取(堆栈.缓存列表, i))
        i = i + 1
    }
    如果 (堆栈.块列表 != 0) { 堆_释放(堆栈.块列表) }
    如果 (堆栈.缓存列表 != 0) { 堆_释放(堆栈.缓存列表) }
}

函数 张量_silu(x) {
    如果 (x == 0) { 返回 空 }
    定义 N = x.长度
    定义 可变 结果 = 张量_零同形(x)
    定义 可变 i = 0
    当 (i < N) {
        定义 val = 张量_取元素_1d(x, i)
        定义 sigmoid = 1.0 / (1.0 + 数学_exp(0.0 - val))
        张量_设元素_1d(结果, i, val * sigmoid)
        i = i + 1
    }
    返回 结果
}

函数 GQA统计_重置() {
    全局GQA统计 = 0
}

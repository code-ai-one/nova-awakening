导入("../中枢/类型定义.nova")
导入("../中枢/系统调用表.nova")
导入("../中枢/哈希整数.nova")
导入("../感知/内核直连层.nova")
导入("../中枢/创建甲.nova")

定义 最大检查项 = 32
定义 最大历史 = 64
定义 状态_健康 = 0
定义 状态_降级 = 1
定义 状态_故障 = 2
定义 检查间隔 = 10000000

结构 健康检查项 {
    名称哈希,
    检查回调,
    当前状态,
    连续失败,
    检查次数,
    失败次数,
    最近检查,
    超时阈值,
}

定义 可变 检查表 = []
定义 可变 检查数 = 0
定义 可变 历史环 = 0
定义 可变 历史写位 = 0
定义 可变 总检查 = 0
定义 可变 总故障 = 0
定义 可变 就绪 = 假

函数 健康_初始化() {
    检查表 = []
    检查数 = 0
    历史环 = 堆_分配(最大历史 * 16)
    历史写位 = 0
    就绪 = 假
}

函数 健康_注册(名称, 回调, 超时) {
    如果 (检查数 >= 最大检查项) { 返回 -1 }
    定义 项 = 健康检查项 {}
    项.名称哈希 = 哈希_字符串(名称)
    项.检查回调 = 回调
    项.当前状态 = 状态_健康
    项.连续失败 = 0
    项.检查次数 = 0
    项.失败次数 = 0
    项.最近检查 = 0
    项.超时阈值 = 超时
    追加(检查表, 项)
    定义 索引 = 检查数
    检查数 = 检查数 + 1
    返回 索引
}

函数 健康_执行全部() {
    总检查 = 总检查 + 1
    定义 可变 全部健康 = 真
    定义 可变 序号 = 0
    当 (序号 < 检查数) {
        定义 项 = 检查表[序号]
        项.检查次数 = 项.检查次数 + 1
        项.最近检查 = 平台_获取高精度时间()
        定义 可变 结果 = 假
        如果 (项.检查回调 != 0) { 结果 = 项.检查回调() }
        如果 (结果) {
            项.连续失败 = 0
            项.当前状态 = 状态_健康
        } 否则 {
            项.连续失败 = 项.连续失败 + 1
            项.失败次数 = 项.失败次数 + 1
            如果 (项.连续失败 >= 3) {
                项.当前状态 = 状态_故障
                总故障 = 总故障 + 1
            } 否则 {
                项.当前状态 = 状态_降级
            }
            全部健康 = 假
        }
        健康_记录历史(项.名称哈希, 项.当前状态)
        序号 = 序号 + 1
    }
    就绪 = 全部健康
    返回 全部健康
}

函数 健康_记录历史(名称哈希, 状态) {
    定义 偏移 = 历史环 + 历史写位 * 16
    内存_写64(偏移, 名称哈希)
    内存_写32(偏移 + 8, 状态)
    内存_写32(偏移 + 12, 平台_获取高精度时间() & 0xFFFFFFFF)
    历史写位 = (历史写位 + 1) % 最大历史
}

函数 健康_是活跃() {
    返回 检查数 > 0
}

函数 健康_是就绪() {
    返回 就绪
}

函数 健康_获取状态(索引) {
    如果 (索引 >= 检查数) { 返回 状态_故障 }
    返回 检查表[索引].当前状态
}

函数 健康_故障组件数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 检查数) {
        如果 (检查表[序号].当前状态 == 状态_故障) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 健康_降级组件数() {
    定义 可变 数量 = 0
    定义 可变 序号 = 0
    当 (序号 < 检查数) {
        如果 (检查表[序号].当前状态 == 状态_降级) { 数量 = 数量 + 1 }
        序号 = 序号 + 1
    }
    返回 数量
}

函数 健康_状态名(状态) {
    如果 (状态 == 状态_健康) { 返回 "健康" }
    如果 (状态 == 状态_降级) { 返回 "降级" }
    如果 (状态 == 状态_故障) { 返回 "故障" }
    返回 "未知"
}

函数 健康_完整统计() {
    返回 [检查数, 总检查, 总故障, 健康_故障组件数(), 健康_降级组件数(), 就绪]
}

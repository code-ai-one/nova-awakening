// NovaOS 内存读写锁
// 尝试锁/自旋等待/超时/升级降级/死锁检测/争用分析/统计

导入("./类型定义.nova")
导入("./同步原语.nova")
导入("./内核打印.nova")
导入("./高精定器添.nova")
导入("./创建甲.nova")
导入("./整数转字符串.nova")

定义 锁_空闲 = 0
定义 锁_读持有 = 1
定义 锁_写持有 = 2
定义 最大锁深度 = 8
定义 最大自旋次数 = 1000
定义 退避初始 = 1
定义 退避最大 = 64

定义 可变 全局锁序号 = 0

结构 读写锁 {
    状态,
    读者数,
    写者标识,
    等待读者,
    等待写者,
    获取次数,
    争用次数,
    最长等待,
    总等待时间,
    递归深度,
    锁序号,          // 锁排序编号
    创建时间,
}

定义 可变 锁总获取 = 0
定义 可变 锁总争用 = 0
定义 可变 死锁检测数 = 0
定义 可变 锁总自旋 = 0
定义 可变 锁总超时 = 0
定义 可变 锁总升级 = 0
定义 可变 锁总降级 = 0
定义 可变 锁总创建 = 0
定义 可变 锁总销毁 = 0
定义 可变 持有栈 = []

定义 最大热点数 = 16
结构 争用热点 {
    锁引用,
    争用次数,
    总等待,
}
定义 可变 争用热点表 = []

// §1 创建/销毁

函数 内存锁_创建() {
    定义 锁 = 读写锁 {}
    锁.状态 = 锁_空闲
    锁.读者数 = 0
    锁.写者标识 = 0
    锁.等待读者 = 0
    锁.等待写者 = 0
    锁.获取次数 = 0
    锁.争用次数 = 0
    锁.最长等待 = 0
    锁.总等待时间 = 0
    锁.递归深度 = 0
    全局锁序号 = 全局锁序号 + 1
    锁.锁序号 = 全局锁序号
    锁.创建时间 = 平台_获取高精度时间()
    锁总创建 = 锁总创建 + 1
    返回 锁
}

函数 内存锁_销毁(锁) {
    如果 (锁 == 0) { 返回 }
    如果 (锁.状态 != 锁_空闲) {
        内核警告("内存锁: 销毁非空闲锁, 状态=" + 整数转字符串(锁.状态))
    }
    内存锁_出栈(锁)
    锁总销毁 = 锁总销毁 + 1
}

// §2 尝试获取 (非阻塞)

函数 内存锁_尝试读(锁) {
    如果 (锁 == 0) { 返回 假 }
    锁总获取 = 锁总获取 + 1
    如果 (锁.状态 == 锁_写持有) {
        锁.等待读者 = 锁.等待读者 + 1
        锁总争用 = 锁总争用 + 1
        锁.争用次数 = 锁.争用次数 + 1
        内存锁_记录争用(锁)
        返回 假
    }
    锁.状态 = 锁_读持有
    锁.读者数 = 锁.读者数 + 1
    锁.获取次数 = 锁.获取次数 + 1
    返回 真
}

函数 内存锁_尝试写(锁) {
    如果 (锁 == 0) { 返回 假 }
    锁总获取 = 锁总获取 + 1

    // 递归写锁检测
    如果 (锁.状态 == 锁_写持有 && 锁.写者标识 == 获取当前进程标识()) {
        锁.递归深度 = 锁.递归深度 + 1
        锁.获取次数 = 锁.获取次数 + 1
        返回 真
    }

    如果 (锁.状态 != 锁_空闲) {
        锁.等待写者 = 锁.等待写者 + 1
        锁总争用 = 锁总争用 + 1
        锁.争用次数 = 锁.争用次数 + 1
        内存锁_记录争用(锁)
        返回 假
    }
    如果 (内存锁_检查死锁(锁)) {
        死锁检测数 = 死锁检测数 + 1
        内核警告("内存锁: 死锁检测, 锁序号=" + 整数转字符串(锁.锁序号))
        返回 假
    }
    // 锁排序验证
    如果 (!内存锁_检查排序(锁)) {
        内核警告("内存锁: 锁排序违规, 锁序号=" + 整数转字符串(锁.锁序号))
    }
    锁.状态 = 锁_写持有
    锁.写者标识 = 获取当前进程标识()
    锁.获取次数 = 锁.获取次数 + 1
    锁.递归深度 = 1
    内存锁_入栈(锁)
    返回 真
}

// §3 自旋等待获取 (带退避)

函数 内存锁_读_自旋(锁) {
    如果 (锁 == 0) { 返回 假 }
    定义 开始 = 平台_获取高精度时间()
    定义 可变 自旋数 = 0
    定义 可变 退避 = 退避初始

    当 (自旋数 < 最大自旋次数) {
        如果 (内存锁_尝试读(锁)) {
            定义 等待 = 平台_获取高精度时间() - 开始
            锁.总等待时间 = 锁.总等待时间 + 等待
            如果 (等待 > 锁.最长等待) { 锁.最长等待 = 等待 }
            锁总自旋 = 锁总自旋 + 自旋数
            返回 真
        }
        // 指数退避
        定义 可变 p = 0
        当 (p < 退避) { p = p + 1 }  // 忙等待
        退避 = 退避 * 2
        如果 (退避 > 退避最大) { 退避 = 退避最大 }
        自旋数 = 自旋数 + 1
    }
    锁总自旋 = 锁总自旋 + 自旋数
    返回 假
}

函数 内存锁_写_自旋(锁) {
    如果 (锁 == 0) { 返回 假 }
    定义 开始 = 平台_获取高精度时间()
    定义 可变 自旋数 = 0
    定义 可变 退避 = 退避初始

    当 (自旋数 < 最大自旋次数) {
        如果 (内存锁_尝试写(锁)) {
            定义 等待 = 平台_获取高精度时间() - 开始
            锁.总等待时间 = 锁.总等待时间 + 等待
            如果 (等待 > 锁.最长等待) { 锁.最长等待 = 等待 }
            锁总自旋 = 锁总自旋 + 自旋数
            返回 真
        }
        定义 可变 p = 0
        当 (p < 退避) { p = p + 1 }
        退避 = 退避 * 2
        如果 (退避 > 退避最大) { 退避 = 退避最大 }
        自旋数 = 自旋数 + 1
    }
    锁总自旋 = 锁总自旋 + 自旋数
    返回 假
}

// §4 超时获取

函数 内存锁_读_超时(锁, 超时_微秒) {
    如果 (锁 == 0) { 返回 假 }
    定义 开始 = 平台_获取高精度时间()
    定义 截止 = 开始 + 超时_微秒

    当 (平台_获取高精度时间() < 截止) {
        如果 (内存锁_尝试读(锁)) {
            定义 等待 = 平台_获取高精度时间() - 开始
            锁.总等待时间 = 锁.总等待时间 + 等待
            如果 (等待 > 锁.最长等待) { 锁.最长等待 = 等待 }
            返回 真
        }
        schedule_timeout(1)
    }
    锁总超时 = 锁总超时 + 1
    返回 假
}

函数 内存锁_写_超时(锁, 超时_微秒) {
    如果 (锁 == 0) { 返回 假 }
    定义 开始 = 平台_获取高精度时间()
    定义 截止 = 开始 + 超时_微秒

    当 (平台_获取高精度时间() < 截止) {
        如果 (内存锁_尝试写(锁)) {
            定义 等待 = 平台_获取高精度时间() - 开始
            锁.总等待时间 = 锁.总等待时间 + 等待
            如果 (等待 > 锁.最长等待) { 锁.最长等待 = 等待 }
            返回 真
        }
        schedule_timeout(1)
    }
    锁总超时 = 锁总超时 + 1
    返回 假
}

// §5 释放

函数 内存锁_释放读(锁) {
    如果 (锁 == 0) { 返回 }
    锁.读者数 = 锁.读者数 - 1
    如果 (锁.读者数 <= 0) {
        锁.读者数 = 0
        锁.状态 = 锁_空闲
    }
}

函数 内存锁_释放写(锁) {
    如果 (锁 == 0) { 返回 }
    // 递归锁处理
    如果 (锁.递归深度 > 1) {
        锁.递归深度 = 锁.递归深度 - 1
        返回
    }
    锁.状态 = 锁_空闲
    锁.写者标识 = 0
    锁.递归深度 = 0
    内存锁_出栈(锁)
}

// §6 升级/降级

函数 内存锁_升级(锁) {
    如果 (锁 == 0) { 返回 假 }
    如果 (锁.状态 != 锁_读持有 || 锁.读者数 != 1) { 返回 假 }
    锁.读者数 = 0
    锁.状态 = 锁_写持有
    锁.写者标识 = 获取当前进程标识()
    锁.递归深度 = 1
    内存锁_入栈(锁)
    锁总升级 = 锁总升级 + 1
    返回 真
}

函数 内存锁_降级(锁) {
    如果 (锁 == 0 || 锁.状态 != 锁_写持有) { 返回 }
    锁.状态 = 锁_读持有
    锁.读者数 = 1
    锁.写者标识 = 0
    锁.递归深度 = 0
    内存锁_出栈(锁)
    锁总降级 = 锁总降级 + 1
}

// §7 死锁检测与锁排序

函数 内存锁_检查死锁(锁) {
    定义 可变 序号 = 0
    当 (序号 < 计数(持有栈)) {
        如果 (持有栈[序号] == 锁) { 返回 真 }
        序号 = 序号 + 1
    }
    返回 假
}

函数 内存锁_检查排序(锁) {
    // 新锁的序号必须大于栈中所有锁的序号
    定义 可变 i = 0
    当 (i < 计数(持有栈)) {
        如果 (持有栈[i] != 0 && 持有栈[i].锁序号 >= 锁.锁序号) {
            返回 假  // 排序违规
        }
        i = i + 1
    }
    返回 真
}

函数 内存锁_入栈(锁) {
    如果 (计数(持有栈) < 最大锁深度) { 追加(持有栈, 锁) }
}

函数 内存锁_出栈(锁) {
    定义 可变 序号 = 计数(持有栈) - 1
    当 (序号 >= 0) {
        如果 (持有栈[序号] == 锁) {
            // 移除: 用最后元素覆盖
            如果 (序号 < 计数(持有栈) - 1) {
                持有栈[序号] = 持有栈[计数(持有栈) - 1]
            }
            删除(持有栈, 计数(持有栈) - 1)
            返回
        }
        序号 = 序号 - 1
    }
}

// §8 争用热点

函数 内存锁_记录争用(锁) {
    // 在争用热点表中更新
    定义 可变 i = 0
    当 (i < 计数(争用热点表)) {
        如果 (争用热点表[i].锁引用 == 锁) {
            争用热点表[i].争用次数 = 争用热点表[i].争用次数 + 1
            返回
        }
        i = i + 1
    }
    // 新条目
    如果 (计数(争用热点表) < 最大热点数) {
        定义 热点 = 争用热点 {}
        热点.锁引用 = 锁
        热点.争用次数 = 1
        热点.总等待 = 0
        追加(争用热点表, 热点)
    }
}

函数 内存锁_打印争用热点() {
    打印行("=== 锁争用热点 ===")
    定义 可变 i = 0
    当 (i < 计数(争用热点表)) {
        定义 h = 争用热点表[i]
        打印行("锁序号=" + 整数转字符串(h.锁引用.锁序号) +
            " 争用=" + 整数转字符串(h.争用次数))
        i = i + 1
    }
}

// §9 查询

函数 内存锁_是空闲(锁) {
    如果 (锁 == 0) { 返回 真 }
    返回 锁.状态 == 锁_空闲
}

函数 内存锁_读者数(锁) {
    如果 (锁 == 0) { 返回 0 }
    返回 锁.读者数
}

函数 内存锁_是写持有(锁) {
    如果 (锁 == 0) { 返回 假 }
    返回 锁.状态 == 锁_写持有
}

函数 内存锁_持有深度() {
    返回 计数(持有栈)
}

// §10 统计

函数 内存锁_统计() {
    返回 [锁总获取, 锁总争用, 死锁检测数, 锁总自旋, 锁总超时, 锁总升级, 锁总降级]
}

函数 内存锁_打印统计() {
    打印行("=== 内存读写锁统计 ===")
    打印行("总获取: " + 整数转字符串(锁总获取))
    打印行("总争用: " + 整数转字符串(锁总争用))
    打印行("死锁检测: " + 整数转字符串(死锁检测数))
    打印行("总自旋: " + 整数转字符串(锁总自旋))
    打印行("总超时: " + 整数转字符串(锁总超时))
    打印行("升级次数: " + 整数转字符串(锁总升级))
    打印行("降级次数: " + 整数转字符串(锁总降级))
    打印行("创建锁数: " + 整数转字符串(锁总创建))
    打印行("销毁锁数: " + 整数转字符串(锁总销毁))
    打印行("持有栈深: " + 整数转字符串(计数(持有栈)))
    打印行("争用热点: " + 整数转字符串(计数(争用热点表)))
    如果 (锁总获取 > 0) {
        打印行("争用率: " + 整数转字符串(锁总争用 * 100 / 锁总获取) + "%")
    }
}

// NMLT — Nova Memory Lock Theory
// 公理1(读写对偶): 读锁与写锁互斥, 多读可并发
// 公理2(递归安全): 同一线程重复加锁不死锁, 通过递归深度计数
// 公理3(排序约束): 锁按序号从小到大获取, 防止死锁
// 定理1(升级条件): 读锁升级写锁当且仅当读者数=1
// 定理2(争用可观): 争用率的历史分布可用于调优决策

函数 内存锁_健康检查(锁) {
    如果 (锁 == 0) { 返回 假 }
    // 检查状态一致性
    如果 (锁.状态 == 锁_写持有 && 锁.写者标识 == 0) { 返回 假 }
    如果 (锁.状态 == 锁_读持有 && 锁.读者数 == 0) { 返回 假 }
    如果 (锁.状态 == 锁_空闲 && 锁.读者数 > 0) { 返回 假 }
    如果 (锁.状态 == 锁_空闲 && 锁.递归深度 > 0) { 返回 假 }
    返回 真
}

函数 内存锁_批量健康检查() {
    定义 可变 异常数 = 0
    定义 可变 i = 0
    当 (i < 计数(持有栈)) {
        如果 (持有栈[i] != 0 && !内存锁_健康检查(持有栈[i])) {
            异常数 = 异常数 + 1
        }
        i = i + 1
    }
    返回 异常数
}

函数 内存锁_重置统计() {
    锁总获取 = 0
    锁总争用 = 0
    死锁检测数 = 0
    锁总自旋 = 0
    锁总超时 = 0
    锁总升级 = 0
    锁总降级 = 0
    锁总创建 = 0
    锁总销毁 = 0
    争用热点表 = []
}

函数 内存锁_尝试升级(锁) {
    如果 (锁 == 0) { 返回 假 }
    如果 (锁.状态 != 锁_读持有) { 返回 假 }
    如果 (锁.读者数 != 1) { 返回 假 }
    // 原子尝试升级
    如果 (原子比较交换(&锁.状态, 锁_读持有, 锁_写持有)) {
        锁.写者标识 = 获取当前线程标识()
        锁.读者数 = 0
        锁总升级 = 锁总升级 + 1
        返回 真
    }
    返回 假
}

定义 可变 AI_内存尝锁_运行指标 = 0
定义 可变 AI_内存尝锁_异常指标 = 0

函数 AI_内存尝锁_自诊断() {
    AI_内存尝锁_运行指标 = 0
    返回 AI_内存尝锁_运行指标
}

函数 AI_内存尝锁_优化建议() {
    定义 指标 = AI_内存尝锁_自诊断()
    返回 "内存尝锁状态正常"
}

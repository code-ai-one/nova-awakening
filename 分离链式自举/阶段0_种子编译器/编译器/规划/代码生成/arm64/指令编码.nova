// SMAXP/SMINP/UMAXP/UMINP — 成对最大/最小
函数 指令编码_编码_smaxp_4s(d, n, m) { 返回 0x4EA0A400|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_sminp_4s(d, n, m) { 返回 0x4EA0AC00|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_umaxp_4s(d, n, m) { 返回 0x6EA0A400|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_uminp_4s(d, n, m) { 返回 0x6EA0AC00|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_sqrdmulh_4s(d, n, m) { 返回 0x6EA0B400|((m&31)<<16)|((n&31)<<5)|(d&31) }
// SRSHL/URSHL — 舍入移位(NEON)
函数 指令编码_编码_srshl_4s(d, n, m) { 返回 0x4EA05400|((m&31)<<16)|((n&31)<<5)|(d&31) }
函数 指令编码_编码_urshl_4s(d, n, m) { 返回 0x6EA05400|((m&31)<<16)|((n&31)<<5)|(d&31) }

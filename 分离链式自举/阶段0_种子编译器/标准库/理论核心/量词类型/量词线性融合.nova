// Nova · 量词线性融合引擎
// 线性类型系统 + 借用检查 + 所有权转移 + 生命周期分析
// 把(线性消费, 0) / 被(仿射借用, 0) / 给(可复用, 0)

导入("../../基础.nova")

// 模式常量
定义 模式_把 = 0
定义 模式_被 = 1
定义 模式_给 = 2

// 资源状态
定义 资源_已借用 = 2
定义 资源_已释放 = 3

// 全局统计
定义 可变 _量线_创建数 = 0
定义 可变 _量线_消费数 = 0
定义 可变 _量线_借用数 = 0
定义 可变 _量线_复制数 = 0
定义 可变 _量线_泄漏数 = 0
定义 可变 _量线_历史 = []

// 量词线性值

函数 量线_创建(量词, 值, 模式) { _量线_创建数 = _量线_创建数 + 1
 返回 [量词, 值, 模式, 资源_活跃,]
}

函数 量线_量词(ql) { 返回 ql[0] }
函数 量线_值(ql) { 返回 ql[1] }
函数 量线_模式(ql) { 返回 ql[2] }
函数 量线_状态(ql) { 返回 ql[3] }
函数 量线_借用计(ql) { 返回 ql[4] }
函数 量线_使用计(ql) { 返回 ql[5] }

// 把字消费(所有权转移)

函数 量线_把(ql, 动作) { 如果 (量线_模式(ql) == 模式_给) { 返回 ["错误", "给字资源不可用把字消费"]
 }
 如果 (量线_状态(ql) != 资源_活跃) { 返回 ["错误", "资源不活跃"]
 }
 如果 (ql[4] > 0) { 返回 ["错误", "资源仍有活跃借用,不可消费"]
 }
 ql[3] = 资源_已消费
 ql[5] = ql[5] + 1
 _量线_消费数 = _量线_消费数 + 1
 追加(_量线_历史, ["把", 动作])
 如果 (计数(_量线_历史) > 1000) { _量线_历史 = [] }
 返回 ["成功", 量线_值(ql)]
}

// 被字借用(不转移所有权)

函数 量线_被(ql, 动作) { 如果 (量线_状态(ql) == 资源_已消费) { 返回 ["错误", "已消费资源不可被借用"]
 }
 如果 (量线_状态(ql) == 资源_已释放) { 返回 ["错误", "已释放资源不可被借用"]
 }
 ql[4] = ql[4] + 1
 ql[5] = ql[5] + 1
 _量线_借用数 = _量线_借用数 + 1
 追加(_量线_历史, ["被", 动作])
 如果 (计数(_量线_历史) > 1000) { _量线_历史 = [] }
 返回 ["成功", 量线_值(ql)]
}

// 归还借用

函数 量线_归还(ql) {
    如果 (ql[4] <= 0) { 返回 ["错误", "无活跃借用可归还"]
}
 ql[4] = ql[4] - 1
 返回 ["成功", "借用已归还"]
}

// 给字复制

函数 量线_给(ql, 目标) { 如果 (量线_模式(ql) == 模式_把) { 返回 ["错误", "把字资源不可用给字复制"]
 }
 定义 副本 = 量线_创建(量线_量词(ql), 量线_值(ql), 模式_给)
 _量线_复制数 = _量线_复制数 + 1
 追加(_量线_历史, ["给", 目标])
 如果 (计数(_量线_历史) > 1000) { _量线_历史 = [] }
 返回 ["成功", 副本]
}

// 释放资源

函数 量线_释放(ql) { 如果 (量线_状态(ql) == 资源_已释放) { 返回 ["错误", "重复释放"]
 }
 如果 (ql[4] > 0) { 返回 ["错误", "仍有活跃借用,不可释放"]
 }
 ql[3] = 资源_已释放
 返回 ["成功", "资源已释放"]
}

// 量词天然属性

函数 量词_天然线性(q) {
    如果 (q == 量词_把) { 返回 1
}
 如果 (q == 量词_条) { 返回 1 }
 返回 0
}

函数 量词_天然复用(q) {
    如果 (q == 量词_串) { 返回 1
}
 如果 (q == 量词_块) { 返回 1 }
 返回 0
}

函数 量词_天然仿射(q) {
    如果 (q == 量词_被) { 返回 1
}
 返回 0
}

函数 量线_自动模式(量词) {
    如果 (量词_天然线性(量词) == 1) { 返回 模式_把
}
 如果 (量词_天然复用(量词) == 1) { 返回 模式_给 }
 返回 模式_被
}

函数 量线_智能创建(量词, 值) { 返回 量线_创建(量词, 值, 量线_自动模式(量词))
}

// 模式名称

函数 量线_模式名(模式) {
    如果 (模式 == 模式_把) { 返回 "把(线性, 0)"
}
 如果 (模式 == 模式_被) { 返回 "被(仿射, 0)" }
 如果 (模式 == 模式_给) { 返回 "给(复用, 0)" }
 返回 "未知"
}

函数 量线_状态名(状态) {
    如果 (状态 == 资源_活跃) { 返回 "活跃"
}
 如果 (状态 == 资源_已消费) { 返回 "已消费" }
 如果 (状态 == 资源_已借用) { 返回 "已借用" }
 如果 (状态 == 资源_已释放) { 返回 "已释放" }
 返回 "未知"
}

// 融合上下文

函数 量线上下文_创建() { 返回 [[], 0, 0] }

函数 量线上下文_分配(上下文, 量词, 值) { 定义 ql = 量线_智能创建(量词, 值)
 追加(上下文[0], ql)
 上下文[1] = 上下文[1] + 1
 返回 ql
}

函数 量线上下文_检查泄漏(上下文) { 定义 可变 泄漏 = 0
 定义 可变 i = 0
 当 (i < 计数(上下文[0])) { 定义 ql = 上下文[0][i]
 如果 (量线_模式(ql) == 模式_把 且 量线_状态(ql) == 资源_活跃) {
 泄漏 = 泄漏 + 1
 }
 i = i + 1
 }
 _量线_泄漏数 = _量线_泄漏数 + 泄漏
 返回 泄漏
}

函数 量线上下文_活跃数(上下文) { 定义 可变 活跃 = 0
 定义 可变 i = 0
 当 (i < 计数(上下文[0])) { 如果 (量线_状态(上下文[0][i]) == 资源_活跃) { 活跃 = 活跃 + 1 }
 i = i + 1
 }
 返回 活跃
}

函数 量线上下文_已消费数(上下文) { 定义 可变 消费 = 0
 定义 可变 i = 0
 当 (i < 计数(上下文[0])) { 如果 (量线_状态(上下文[0][i]) == 资源_已消费) { 消费 = 消费 + 1 }
 i = i + 1
 }
 返回 消费
}

函数 量线上下文_借用总数(上下文) { 定义 可变 借 = 0
 定义 可变 i = 0
 当 (i < 计数(上下文[0])) {
 借 = 借 + 量线_借用计(上下文[0][i])
 i = i + 1
 }
 返回 借
}

// 所有权转移链

函数 量线_转移(源, 目标ql) { 如果 (量线_状态(源) != 资源_活跃) { 返回 ["错误", "源资源不活跃"]
 }
 如果 (源[4] > 0) { 返回 ["错误", "源资源有活跃借用"]
 }
 目标ql[1] = 源[1]
 目标ql[3] = 资源_活跃
 源[3] = 资源_已消费
 返回 ["成功", "所有权已转移"]
}

// 批量操作

函数 量线上下文_全部释放(上下文) {
 定义 可变 失败数 = 0
 定义 可变 i = 0
 当 (i < 计数(上下文[0])) { 定义 结果 = 量线_释放(上下文[0][i])
 如果 (结果[0] == "成功") { 成功数 = 成功数 + 1 }
 否则 { 失败数 = 失败数 + 1 }
 i = i + 1
 }
 返回 [成功数, 失败数]
}

函数 量线上下文_按模式筛选(上下文, 目标模式) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(上下文[0])) { 如果 (量线_模式(上下文[0][i]) == 目标模式) {
 追加(结果, 上下文[0][i])
 }
 i = i + 1
 }
 返回 结果
}

函数 量线上下文_按状态筛选(上下文, 目标状态) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(上下文[0])) { 如果 (量线_状态(上下文[0][i]) == 目标状态) {
 追加(结果, 上下文[0][i])
 }
 i = i + 1
 }
 返回 结果
}

函数 量线_模式分析() {
    如果 (_量线_创建数 == 0) { 返回 "无数据"
}
 定义 消费率 = _量线_消费数 * 100 / _量线_创建数
 定义 借用率 = _量线_借用数 * 100 / _量线_创建数
 定义 复制率 = _量线_复制数 * 100 / _量线_创建数
 如果 (消费率 > 60) { 返回 "消费主导(适合线性类型)" }
 如果 (借用率 > 60) { 返回 "借用主导(适合仿射类型)" }
 如果 (复制率 > 60) { 返回 "复制主导(适合复用类型)" }
 返回 "混合模式"
}

函数 量线_安全评分(上下文) { 定义 可变 评分 = 100
 定义 泄漏 = 量线上下文_检查泄漏(上下文)
 评分 = 评分 - 泄漏 * 20
 定义 活跃借用 = 量线上下文_借用总数(上下文)
 如果 (活跃借用 > 10) { 评分 = 评分 - 10 }
 如果 (评分 < 0) { 评分 = 0 }
 返回 评分
}

函数 量线_生命周期分析(ql) { 定义 使用次数 = 量线_使用计(ql)
 定义 状态 = 量线_状态(ql)
 如果 (状态 == 资源_活跃 且 使用次数 == 0) { 返回 "未使用(可能冗余)" }
 如果 (状态 == 资源_活跃 且 使用次数 > 0) { 返回 "正常使用中" }
 如果 (状态 == 资源_已消费) { 返回 "已消费(生命周期结束)" }
 如果 (状态 == 资源_已释放) { 返回 "已释放(正常回收)" }
 返回 "未知状态"
}

// 借用检查器

函数 借用检查_可变借用(ql) {
    如果 (量线_状态(ql) != 资源_活跃) { 返回 ["错误", "资源不活跃"]
}
 如果 (ql[4] > 0) { 返回 ["错误", "已有借用,不可获取可变借用"] }
 ql[4] = ql[4] + 1
 ql[3] = 资源_已借用
 返回 ["成功", 量线_值(ql)]
}

函数 借用检查_不可变借用(ql) {
    如果 (量线_状态(ql) == 资源_已消费) { 返回 ["错误", "已消费"]
}
 如果 (量线_状态(ql) == 资源_已释放) { 返回 ["错误", "已释放"] }
 如果 (量线_状态(ql) == 资源_已借用) { 返回 ["错误", "已被可变借用"] }
 ql[4] = ql[4] + 1
 返回 ["成功", 量线_值(ql)]
}

函数 借用检查_验证(上下文) { 定义 可变 问题 = []
 定义 可变 i = 0
 当 (i < 计数(上下文[0])) { 定义 ql = 上下文[0][i]
 如果 (量线_模式(ql) == 模式_把 且 量线_状态(ql) == 资源_活跃) {
 追加(问题, 字符串拼接("资源#", 字符串拼接(转字符串(i), "未消费(线性泄漏)")))
 }
 如果 (ql[4] > 0 且 量线_状态(ql) == 资源_已消费) {
 追加(问题, 字符串拼接("资源#", 字符串拼接(转字符串(i), "已消费但仍有借用")))
 }
 i = i + 1
 }
 如果 (计数(问题) == 0) { 追加(问题, "借用检查通过") }
 返回 问题
}

// 资源依赖图

定义 可变 _资源_依赖 = []

函数 资源依赖_添加(源索引, 目标索引) {
 追加(_资源_依赖, [源索引, 目标索引])
}

函数 资源依赖_检查环(起点) { 定义 可变 已访问 = []
 定义 可变 栈 = [起点]
 当 (计数(栈) > 0) { 定义 当前 = 栈[计数(栈) - 1]
 栈 = 切片(栈, 0, 计数(栈) - 1)
 定义 可变 j = 0
 当 (j < 计数(已访问)) { 如果 (已访问[j] == 当前) { 返回 真 }
 j = j + 1
 }
 追加(已访问, 当前)
 定义 可变 i = 0
 当 (i < 计数(_资源_依赖)) { 如果 (_资源_依赖[i][0] == 当前) {
 追加(栈, _资源_依赖[i][1])
 }
 i = i + 1
 }
 }
 返回 假
}

函数 资源依赖_清空() { _资源_依赖 = [] }

// 生命周期推断

函数 量线_生命周期推断(上下文) { 定义 可变 推断结果 = []
 定义 可变 i = 0
 当 (i < 计数(上下文[0])) { 定义 ql = 上下文[0][i]
 定义 可变 建议模式 = 量线_模式(ql)
 如果 (量线_使用计(ql) == 0) {
 建议模式 = 模式_给
 } 否则 如果 (量线_使用计(ql) == 1 且 量线_借用计(ql) == 0) {
 建议模式 = 模式_把
 } 否则 如果 (量线_借用计(ql) > 1) {
 建议模式 = 模式_给
 }
 追加(推断结果, [i, 量线_模式名(量线_模式(ql)), 量线_模式名(建议模式)])
 i = i + 1
 }
 返回 推断结果
}

// 资源池

函数 量线资源池_创建(池大小) { 定义 可变 资源 = []
 定义 可变 i = 0
 当 (i < 池大小) {
 追加(资源, 量线_创建(0, i, 模式_给))
 i = i + 1
 }
 返回 [资源, [], 池大小]
}

函数 量线资源池_获取(池) {
    如果 (计数(池[0]) == 0) { 返回 空
}
 定义 资源 = 池[0][计数(池[0]) - 1]
 池[0] = 切片(池[0], 0, 计数(池[0]) - 1)
 追加(池[1], 资源)
 返回 资源
}

函数 量线资源池_归还(池, 资源) {
 资源[3] = 资源_活跃
 资源[4] = 0
 资源[5] = 0
 追加(池[0], 资源)
}

函数 量线资源池_可用数(池) { 返回 计数(池[0]) }
函数 量线资源池_在用数(池) { 返回 计数(池[1]) }

// 模式转换

函数 量线_升级模式(ql, 新模式) { 如果 (新模式 == 模式_把 且 量线_模式(ql) == 模式_给) { 返回 ["错误", "不可从给升级到把"]
 }
 ql[2] = 新模式
 返回 ["成功", "模式已更新"]
}

函数 量线_降级模式(ql, 新模式) { 如果 (新模式 == 模式_给 且 量线_模式(ql) == 模式_把) { 如果 (量线_状态(ql) == 资源_活跃) {
 ql[2] = 新模式
 返回 ["成功", "模式已降级"]
 }
 返回 ["错误", "非活跃资源不可降级"]
 }
 ql[2] = 新模式
 返回 ["成功", "模式已降级"]
}

// 上下文快照

函数 量线上下文_快照(上下文) { 定义 可变 快照 = []
 定义 可变 i = 0
 当 (i < 计数(上下文[0])) { 定义 ql = 上下文[0][i]
 追加(快照, [i, 量线_模式名(量线_模式(ql)), 量线_状态名(量线_状态(ql)), 量线_借用计(ql), 量线_使用计(ql)])
 i = i + 1
 }
 返回 快照
}

函数 量线_模式分布(上下文) { 定义 可变 把数 = 0
 定义 可变 被数 = 0
 定义 可变 给数 = 0
 定义 可变 i = 0
 当 (i < 计数(上下文[0])) { 定义 m = 量线_模式(上下文[0][i])
 如果 (m == 模式_把) { 把数 = 把数 + 1 }
 否则 如果 (m == 模式_被) { 被数 = 被数 + 1 }
 否则 如果 (m == 模式_给) { 给数 = 给数 + 1 }
 i = i + 1
 }
 返回 [把数, 被数, 给数]
}

函数 量线_借用热度(上下文) { 定义 可变 最热索引 = -1
 定义 可变 最高借用 = 0
 定义 可变 i = 0
 当 (i < 计数(上下文[0])) { 如果 (量线_借用计(上下文[0][i]) > 最高借用) {
 最高借用 = 量线_借用计(上下文[0][i])
 最热索引 = i
 }
 i = i + 1
 }
 如果 (最热索引 == -1) { 返回 "无借用活动" }
 返回 字符串拼接("资源#", 字符串拼接(转字符串(最热索引), 字符串拼接("(借用", 字符串拼接(转字符串(最高借用), "次)"))))
}

函数 量线_健康报告(上下文) { 定义 借用检查 = 借用检查_验证(上下文)
 定义 模式分布 = 量线_模式分布(上下文)
 定义 生命周期 = 量线_生命周期推断(上下文)
 定义 热度 = 量线_借用热度(上下文)
 返回 [借用检查, 模式分布, 生命周期, 热度]
}

导入("../基础.nova")


// Option类型
// [是否有值, 值]
定义 选项_无 = 0
定义 选项_有值 = 1

函数 无值() { 返回 [选项_无, 0] }
函数 有值(v) { 返回 [选项_有值, v] }

函数 是有值(opt) { 返回 opt[0] == 选项_有值 }
函数 是无值(opt) { 返回 opt[0] == 选项_无 }

函数 展开(opt) { 如果 (opt[0] == 选项_无) { 返回 0 } // panic替代
 返回 opt[1]
}

函数 展开_或(opt, 默认值) {
    如果 (opt[0] == 选项_无) { 返回 默认值
}
 返回 opt[1]
}

函数 Option_映射(opt, 映射类型, 参数) {
    如果 (opt[0] == 选项_无) { 返回 opt
}
 定义 可变 新值 = opt[1]
 如果 (映射类型 == 0) { 新值 = 新值 + 参数 }
 如果 (映射类型 == 1) { 新值 = 新值 * 参数 / 1000 }
 如果 (映射类型 == 2) { 新值 = 新值 * 新值 / 1000 }
 返回 有值(新值)
}

函数 Option_过滤(opt, 过滤类型, 参数) {
    如果 (opt[0] == 选项_无) { 返回 opt
}
 定义 值 = opt[1]
 定义 可变 通过 = 0
 如果 (过滤类型 == 0) { 通过 = 值 > 参数 }
 如果 (过滤类型 == 1) { 通过 = 值 < 参数 }
 如果 (过滤类型 == 2) { 通过 = 值 == 参数 }
 如果 (通过) { 返回 opt }
 返回 无值()
}

函数 Option_或(opt1, opt2) {
    如果 (opt1[0] == 选项_有值) { 返回 opt1
}
 返回 opt2
}

函数 Option_且(opt1, opt2) {
    如果 (opt1[0] == 选项_无) { 返回 opt1
}
 返回 opt2
}

// Result类型
// [状态, 值或错误]
// 状态: 0=失败, 1=成功
定义 结果_错误 = 0
定义 结果_成功 = 1

函数 成功(v) { 返回 [结果_成功, v] }
函数 失败(错误) { 返回 [结果_错误, 错误] }

函数 是成功(r) { 返回 r[0] == 结果_成功 }
函数 是失败(r) { 返回 r[0] == 结果_错误 }

函数 结果_展开(r) { 如果 (r[0] == 结果_错误) { 返回 0 } // panic替代
 返回 r[1]
}

函数 结果_展开_或(r, 默认值) {
    如果 (r[0] == 结果_错误) { 返回 默认值
}
 返回 r[1]
}

函数 结果_错误(r) {
    如果 (r[0] == 结果_成功) { 返回 无值()
}
 返回 有值(r[1])
}

函数 结果类型_结果_映射(r, 映射类型, 参数) {
    如果 (r[0] == 结果_错误) { 返回 r
}
 定义 opt = Option_映射(有值(r[1]), 映射类型, 参数)
 返回 成功(opt[1])
}

函数 结果类型_结果_映射错误(r, 映射类型, 参数) {
    如果 (r[0] == 结果_成功) { 返回 r
}
 定义 opt = Option_映射(有值(r[1]), 映射类型, 参数)
 返回 失败(opt[1])
}

函数 结果类型_结果_或(r1, r2) {
    如果 (r1[0] == 结果_成功) { 返回 r1
}
 返回 r2
}

函数 结果_且(r1, r2) {
    如果 (r1[0] == 结果_错误) { 返回 r1
}
 返回 r2
}

// 错误码系统
定义 错误_无 = 0
定义 错误_参数无效 = 1
定义 错误_越界 = 2
定义 错误_空指针 = 3
定义 错误_溢出 = 4
定义 错误_除零 = 5
定义 错误_IO = 6
定义 错误_网络 = 7
定义 错误_超时 = 8
定义 错误_权限 = 9
定义 错误_未找到 = 10
定义 错误_已存在 = 11
定义 错误_格式 = 12
定义 错误_内存 = 13

函数 错误码_描述(码) {
    如果 (码 == 0) { 返回 "无错误"
}
 如果 (码 == 1) { 返回 "参数无效" }
 如果 (码 == 2) { 返回 "越界访问" }
 如果 (码 == 3) { 返回 "空指针" }
 如果 (码 == 4) { 返回 "数值溢出" }
 如果 (码 == 5) { 返回 "除以零" }
 如果 (码 == 6) { 返回 "IO错误" }
 如果 (码 == 7) { 返回 "网络错误" }
 如果 (码 == 8) { 返回 "超时" }
 如果 (码 == 字符_制表) { 返回 "权限不足" }
 如果 (码 == 字符_换行) { 返回 "未找到" }
 如果 (码 == 11) { 返回 "已存在" }
 如果 (码 == 12) { 返回 "格式错误" }
 如果 (码 == 字符_回车) { 返回 "内存不足" }
 返回 "未知错误"
}

// 错误链
// [错误码, 描述哈希, 上下文, 原因(嵌套错误)]
函数 错误_创建(码, 描述) { 返回 [码, 描述, "", 空]
}

函数 错误_带上下文(码, 描述, 上下文) { 返回 [码, 描述, 上下文, 空]
}

函数 错误_包装(新码, 新描述, 原错误) { 返回 [新码, 新描述, "", 原错误]
}

函数 错误_根因(错误) {
    如果 (错误[3] == 空) { 返回 错误
}
 返回 错误_根因(错误[3])
}

函数 错误_链深度(错误) { 定义 可变 深度 = 1
 定义 可变 当前 = 错误
 当 (当前[3] != 空) { 深度 = 深度 + 1
 当前 = 当前[3] }
 返回 深度
}

// 安全除法
函数 安全除(a, b) {
    如果 (b == 0) { 返回 失败(错误_除零)
}
 返回 成功(a / b)
}

// 安全索引
函数 安全索引(列表, i) {
    如果 (i < 0 或 i >= 计数(列表)) { 返回 失败(错误_越界)
}
 返回 成功(列表[i])
}

// 结果列表操作
函数 结果_全部成功(结果列表) { 定义 可变 i = 0
 当 (i < 计数(结果列表)) { 如果 (是失败(结果列表[i])) { 返回 0 }
 i = i + 1
 }
 返回 1
}

函数 结果_收集(结果列表) { 定义 可变 值列表 = []
 定义 可变 i = 0
 当 (i < 计数(结果列表)) { 如果 (是失败(结果列表[i])) { 返回 失败(结果列表[i][1]) }
 追加(值列表, 结果列表[i][1])
 i = i + 1
 }
 返回 成功(值列表)
}

// 结果链式操作 (and_then / or_else 模拟)
// and_then: 成功时用变换类型处理值
函数 结果_然后(r, 变换类型, 参数) {
    如果 (r[0] == 结果_错误) { 返回 r
}
 定义 v = r[1]
 // 变换类型: 0=加, 1=乘(×1000), 2=平方, 3=安全除
 如果 (变换类型 == 0) { 返回 成功(v + 参数) }
 如果 (变换类型 == 1) { 返回 成功(v * 参数 / 1000) }
 如果 (变换类型 == 2) { 返回 成功(v * v / 1000) }
 如果 (变换类型 == 3) { 返回 安全除(v, 参数) }
 返回 r
}

// or_else: 失败时用恢复类型处理
函数 结果_否则(r, 恢复值) {
    如果 (r[0] == 结果_成功) { 返回 r
}
 返回 成功(恢复值)
}

// Option 展平
函数 Option_展平(opt) {
 // Option<Option<T>> -> Option<T>
 如果 (opt[0] == 选项_无) { 返回 opt }
 定义 inner = opt[1]
 如果 (是列表(inner) 且 计数(inner) == 2) { 如果 (inner[0] == 选项_无 或 inner[0] == 选项_有值) { 返回 inner
 }
 }
 返回 opt
}

// Option 转 Result
函数 Option_转Result(opt, 错误) {
    如果 (opt[0] == 选项_有值) { 返回 成功(opt[1])
}
 返回 失败(错误)
}

// Result 转 Option (丢弃错误)
函数 Result_转Option(r) {
    如果 (r[0] == 结果_成功) { 返回 有值(r[1])
}
 返回 无值()
}

// 错误格式化
函数 错误_格式化(错误) { 定义 可变 s = "[" + 转字符串(错误[0]) + "] " + 错误[1]
 如果 (错误[2] != "") { s = s + " (上下文: " + 错误[2] + ")" }
 如果 (错误[3] != 空) {
 s = s + "\n 原因: " + 错误_格式化(错误[3])
 }
 返回 s
}

函数 错误_打印链(错误) {
 打印("错误链:")
 定义 可变 当前 = 错误
 定义 可变 层 = 0
 当 (当前 != 空) { 定义 可变 前缀 = ""
 定义 可变 p = 0
 当 (p < 层) { 前缀 = 前缀 + " " p = p + 1 }
 打印(前缀 + "→ [" + 转字符串(当前[0]) + "] " + 当前[1])
 如果 (当前[2] != "") { 打印(前缀 + " 上下文: " + 当前[2]) }
 当前 = 当前[3]
 层 = 层 + 1
 }
}

// 安全数学运算
函数 安全乘(a, b) {
 // 溢出检测 (简化: 超过10^15认为溢出)
 如果 (a != 0 且 b != 0) { 定义 可变 abs_a = a
 定义 可变 abs_b = b
 如果 (abs_a < 0) { abs_a = 0 - abs_a }
 如果 (abs_b < 0) { abs_b = 0 - abs_b }
 如果 (abs_a > 1000000000000000 / abs_b) { 返回 失败(错误_溢出)
 }
 }
 返回 成功(a * b)
}

函数 安全取模(a, b) {
    如果 (b == 0) { 返回 失败(错误_除零)
}
 返回 成功(a % b)
}

函数 结果类型_安全转整数(s) {
 // 简化的字符串→整数转换, 失败返回错误
 如果 (s == 空 或 s == "") { 返回 失败(错误_格式) }
 定义 可变 结果 = 0
 定义 可变 符号 = 1
 定义 可变 i = 0
 定义 n = 计数(s)
 如果 (n > 0 且 字节取(s, 0) == 字符_减号) { 符号 = -1
 i = 1 } // '-'
 如果 (i >= n) { 返回 失败(错误_格式) }
 当 (i < n) { 定义 c = 字节取(s, i)
 如果 (c < 48 或 c > 57) { 返回 失败(错误_格式) } // 非数字
 结果 = 结果 * 10 + (c - 48)
 i = i + 1
 }
 返回 成功(结果 * 符号)
}

// 重试机制
// 重试: [最大次数, 当前次数, 延迟ms, 最后结果]
函数 结果类型_重试_创建(最大次数, 延迟) { 返回 [最大次数, 0, 延迟, 空]
}

函数 重试_记录(retry, 结果) {
 retry[1] = retry[1] + 1
 retry[3] = 结果
}

函数 重试_应继续(retry) {
    如果 (retry[1] >= retry[0]) { 返回 0
}
 如果 (retry[3] != 空 且 是成功(retry[3])) { 返回 0 }
 返回 1
}

函数 重试_最终结果(retry) {
    如果 (retry[3] == 空) { 返回 失败(错误_超时)
}
 返回 retry[3]
}

函数 重试_报告(retry) {
 打印("重试报告:")
 打印(" 最大次数: " + 转字符串(retry[0]))
 打印(" 已尝试: " + 转字符串(retry[1]))
 如果 (retry[3] != 空) { 如果 (是成功(retry[3])) {
 打印(" 结果: 成功")
 } 否则 {
 打印(" 结果: 失败")
 }
 }
}

// 结果统计
函数 结果_统计(结果列表) {
 定义 可变 失败数 = 0
 定义 可变 i = 0
 当 (i < 计数(结果列表)) { 如果 (是成功(结果列表[i])) { 成功数 = 成功数 + 1 }
 否则 { 失败数 = 失败数 + 1 }
 i = i + 1
 }
 返回 [成功数, 失败数, 成功数 + 失败数]
}

函数 结果_成功率(结果列表) { 定义 stat = 结果_统计(结果列表)
 如果 (stat[2] == 0) { 返回 0 }
 返回 stat[0] * 1000 / stat[2] // ×1000
}

// 第一个成功/失败
函数 结果_第一个成功(结果列表) { 定义 可变 i = 0
 当 (i < 计数(结果列表)) { 如果 (是成功(结果列表[i])) { 返回 结果列表[i] }
 i = i + 1
 }
 返回 失败(错误_未找到)
}

函数 结果_第一个失败(结果列表) { 定义 可变 i = 0
 当 (i < 计数(结果列表)) { 如果 (是失败(结果列表[i])) { 返回 结果列表[i] }
 i = i + 1
 }
 返回 成功(0)
}

// 分区: 将结果列表分为成功和失败两组
函数 结果_分区(结果列表) { 定义 可变 成功组 = []
 定义 可变 失败组 = []
 定义 可变 i = 0
 当 (i < 计数(结果列表)) { 如果 (是成功(结果列表[i])) {
 追加(成功组, 结果列表[i][1])
 } 否则 {
 追加(失败组, 结果列表[i][1])
 }
 i = i + 1
 }
 返回 [成功组, 失败组]
}

// 结果链式操作

函数 结果_映射值(结果, 映射函数) {
    如果 (结果[0]) { 返回 [真, 映射函数(结果[1])]
}
 返回 结果
}

函数 结果_展平(嵌套结果) {
    如果 (!嵌套结果[0]) { 返回 嵌套结果
}
 返回 嵌套结果[1]
}

函数 结果_重试(操作, 最大次数) { 定义 可变 i = 0
 当 (i < 最大次数) { 定义 结果 = 操作()
 如果 (结果[0]) { 返回 结果 }
 i = i + 1
 }
 返回 [假, "重试耗尽"]
}

函数 结果_超时包装(操作, _超时) { 返回 操作()
}

函数 结果_合并多个(结果列表) { 定义 可变 值列表 = []
 定义 可变 i = 0
 当 (i < 计数(结果列表)) { 如果 (!结果列表[i][0]) { 返回 结果列表[i] }
 追加(值列表, 结果列表[i][1])
 i = i + 1
 }
 返回 [真, 值列表]
}

定义 可变 _结果_成功数 = 0
定义 可变 _结果_失败数 = 0

函数 结果_记录成功() { _结果_成功数 = _结果_成功数 + 1 }
函数 结果_记录失败() { _结果_失败数 = _结果_失败数 + 1 }

函数 结果_总成功率() { 定义 总 = _结果_成功数 + _结果_失败数
 如果 (总 == 0) { 返回 0 }
 返回 _结果_成功数 * 100 / 总
}

函数 结果_重置() { _结果_成功数 = 0 _结果_失败数 = 0 }

函数 结果_最近趋势(历史) {
    如果 (计数(历史) < 3) { 返回 "数据不足"
}
 定义 可变 近期失败 = 0
 定义 可变 i = 计数(历史) - 3
 当 (i < 计数(历史)) { 如果 (!历史[i][0]) { 近期失败 = 近期失败 + 1 }
 i = i + 1
 }
 如果 (近期失败 > 1) { 返回 "近期频繁失败" }
 返回 "近期稳定"
}

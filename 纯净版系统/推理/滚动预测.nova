// NovaOS 滚动方向预测系统
// 功能: 预测用户即将滚动到的区域, 用于预加载内容/预先渲染
//       基于物理模型(速度+加速度+摩擦)+Kalman滤波+AI模式识别
// 理论: 自研「多模态滚动预测融合」— 物理模型提供短期预测,
//       Kalman滤波平滑噪声, AI模式识别检测用户行为模式
//       (快速滚动/慢速浏览/往复滚动/惯性滚动)
//       最终融合: P = α·P_物理 + β·P_Kalman + γ·P_AI

导入("../中枢/类型定义.nova")
导入("../中枢/内存物理.nova")
导入("./智能渠道.nova")
导入("../中枢/内核打印.nova")
导入("../中枢/内存初始化.nova")
导入("./值乘.nova")
导入("./权重持久.nova")
导入("../中枢/整数转字符串.nova")

// §1 定点数学库 (Q10精度)

定义 Q_SHIFT = 10
定义 Q_ONE = 1024       // 1.0 in Q10
定义 Q_HALF = 512       // 0.5
定义 Q_ZERO = 0

函数 Q乘(a, b) { 返回 (a * b) >> Q_SHIFT }
函数 Q除(a, b) {
    如果 (b == 0) { 返回 0 }
    返回 (a << Q_SHIFT) / b
}
函数 Q转整数(v) { 返回 v >> Q_SHIFT }
函数 整数转Q(v) { 返回 v << Q_SHIFT }

// 整数平方根 (Newton法)
函数 isqrt(n) {
    如果 (n <= 0) { 返回 0 }
    定义 可变 x = n
    定义 可变 y = (x + 1) / 2
    当 (y < x) {
        x = y
        y = (x + n / x) / 2
    }
    返回 x
}

// 绝对值
函数 绝对值(x) {
    如果 (x < 0) { 返回 -x }
    返回 x
}

// §2 基础滚动预测器 (物理模型)
// 理论: y(t) = y₀ + v·t + 0.5·a·t² - μ·v·t (with friction)

定义 滚动窗口大小 = 16  // 滑动窗口大小
定义 默认摩擦系数_Q10 = 51  // 0.05 in Q10

结构 滚动预测器 {
    历史位置,        // u64: i32[窗口大小]
    历史时间,        // u64: u64[窗口大小]
    窗口大小,
    有效长度,
    当前速度,        // i32 px/s (Q10)
    当前加速度,      // i32 px/s² (Q10)
    摩擦系数,        // i32 Q10: 惯性衰减
    方向,            // i32: -1=上, 0=停, 1=下
    // Kalman状态
    kalman_x,         // i32: 估计位置 Q10
    kalman_v,         // i32: 估计速度 Q10
    kalman_P00,       // i32: 协方差 P[0][0] Q10
    kalman_P01,       // i32: P[0][1]
    kalman_P10,       // i32: P[1][0]
    kalman_P11,       // i32: P[1][1]
    kalman_Q_pos,     // i32: 过程噪声_位置 Q10
    kalman_Q_vel,     // i32: 过程噪声_速度 Q10
    kalman_R,         // i32: 测量噪声 Q10
    // AI行为模式
    模式,            // u32: 滚动模式_*
    模式置信度,      // u32 Q8
    方向变换数,      // u32: 最近20帧方向变换次数
    速度历史,        // u64: i32[8] 最近8帧速度
    速度历史索引,
}

函数 滚动预测器_创建() {
    定义 sp = 堆_分配(滚动预测器)
    sp.窗口大小 = 滚动窗口大小
    sp.历史位置 = 堆_分配_数组(sp.窗口大小 * 4)
    sp.历史时间 = 堆_分配_数组(sp.窗口大小 * 8)
    sp.有效长度 = 0
    sp.当前速度 = 0
    sp.当前加速度 = 0
    sp.摩擦系数 = 默认摩擦系数_Q10
    sp.方向 = 0
    // Kalman初始化
    sp.kalman_x = 0
    sp.kalman_v = 0
    sp.kalman_P00 = Q_ONE
    sp.kalman_P01 = 0
    sp.kalman_P10 = 0
    sp.kalman_P11 = Q_ONE
    sp.kalman_Q_pos = 10   // 过程噪声小
    sp.kalman_Q_vel = 100  // 速度噪声稍大
    sp.kalman_R = 200      // 测量噪声
    // AI
    sp.模式 = 滚动模式_停止
    sp.模式置信度 = 0
    sp.方向变换数 = 0
    sp.速度历史 = 堆_分配_数组(8 * 4)
    sp.速度历史索引 = 0
    返回 sp
}

// §3 触摸更新与物理模型

函数 滚动预测器_更新(sp, 当前Y, 当前时间) {
    如果 (sp == 0) { 返回 }

    // 添加到历史窗口
    如果 (sp.有效长度 < sp.窗口大小) {
        内存_则32(sp.历史位置 + sp.有效长度 * 4, 当前Y)
        内存_则64(sp.历史时间 + sp.有效长度 * 8, 当前时间)
        sp.有效长度 = sp.有效长度 + 1
    } 否则 {
        // 滑动窗口
        定义 可变 i = 0
        当 (i < sp.窗口大小 - 1) {
            内存_则32(sp.历史位置 + i * 4, 内存_读32(sp.历史位置 + (i+1) * 4))
            内存_则64(sp.历史时间 + i * 8, 内存_读64(sp.历史时间 + (i+1) * 8))
            i = i + 1
        }
        内存_则32(sp.历史位置 + (sp.窗口大小 - 1) * 4, 当前Y)
        内存_则64(sp.历史时间 + (sp.窗口大小 - 1) * 8, 当前时间)
    }

    // 计算速度和加速度 (用最近3个点)
    定义 旧方向 = sp.方向
    如果 (sp.有效长度 >= 3) {
        定义 n = sp.有效长度
        定义 y2 = 内存_读32有符号(sp.历史位置 + (n-1) * 4)
        定义 y1 = 内存_读32有符号(sp.历史位置 + (n-2) * 4)
        定义 y0 = 内存_读32有符号(sp.历史位置 + (n-3) * 4)
        定义 t2 = 内存_读64(sp.历史时间 + (n-1) * 8)
        定义 t1 = 内存_读64(sp.历史时间 + (n-2) * 8)
        定义 t0 = 内存_读64(sp.历史时间 + (n-3) * 8)

        定义 dt1 = t2 - t1
        定义 dt0 = t1 - t0
        如果 (dt1 <= 0) { dt1 = 1 }
        如果 (dt0 <= 0) { dt0 = 1 }

        定义 v1 = Q除((y2 - y1) * Q_ONE, dt1 * Q_ONE / 1000)
        定义 v0 = Q除((y1 - y0) * Q_ONE, dt0 * Q_ONE / 1000)

        sp.当前速度 = v1
        sp.当前加速度 = Q除((v1 - v0) * Q_ONE, ((dt1 + dt0) / 2) * Q_ONE / 1000)

        // 更新方向
        如果 (v1 > 50) { sp.方向 = 1 }       // 向下
        否则如果 (v1 < -50) { sp.方向 = -1 }  // 向上
        否则 { sp.方向 = 0 }

        // 检测方向变换
        如果 (sp.方向 != 0 && sp.方向 != 旧方向 && 旧方向 != 0) {
            sp.方向变换数 = sp.方向变换数 + 1
        }

        // 记录速度历史
        定义 vidx = sp.速度历史索引 % 8
        内存_则32(sp.速度历史 + vidx * 4, v1)
        sp.速度历史索引 = sp.速度历史索引 + 1
    }

    // Kalman滤波更新
    滚动预测器_Kalman更新(sp, 当前Y)

    // AI模式检测
    滚动预测器_AI检测模式(sp)
}

// §4 Kalman滤波器
// 理论: 2维状态 [x, v], 观测 z=位置
//   预测: x' = x + v*dt,  v' = v
//   更新: K = P*H'/(H*P*H' + R)

函数 滚动预测器_Kalman更新(sp, 观测位置) {
    // Step 1: 预测 (dt约为16ms=0.016s, Q10中约=16)
    定义 dt = 16  // Q10 ~0.016s

    // x_pred = x + v * dt
    定义 x_pred = sp.kalman_x + Q乘(sp.kalman_v, dt)
    定义 v_pred = sp.kalman_v

    // P_pred = F*P*F' + Q
    定义 P00_pred = sp.kalman_P00 + Q乘(dt, sp.kalman_P10) + Q乘(dt, sp.kalman_P01) + Q乘(Q乘(dt, dt), sp.kalman_P11) + sp.kalman_Q_pos
    定义 P01_pred = sp.kalman_P01 + Q乘(dt, sp.kalman_P11)
    定义 P10_pred = sp.kalman_P10 + Q乘(dt, sp.kalman_P11)
    定义 P11_pred = sp.kalman_P11 + sp.kalman_Q_vel

    // Step 2: 更新
    // y = z - H*x_pred (H=[1,0])
    定义 残差 = 整数转Q(观测位置) - x_pred

    // S = H*P*H' + R = P00 + R
    定义 S = P00_pred + sp.kalman_R
    如果 (S == 0) { S = 1 }

    // K = P*H'/S
    定义 K0 = Q除(P00_pred, S)
    定义 K1 = Q除(P10_pred, S)

    // x = x_pred + K * y
    sp.kalman_x = x_pred + Q乘(K0, 残差)
    sp.kalman_v = v_pred + Q乘(K1, 残差)

    // P = (I - K*H) * P_pred
    sp.kalman_P00 = Q乘(Q_ONE - K0, P00_pred)
    sp.kalman_P01 = Q乘(Q_ONE - K0, P01_pred)
    sp.kalman_P10 = P10_pred - Q乘(K1, P00_pred)
    sp.kalman_P11 = P11_pred - Q乘(K1, P01_pred)
}

函数 滚动预测器_Kalman预测(sp, 毫秒后) {
    定义 dt = 毫秒后 * Q_ONE / 1000
    返回 Q转整数(sp.kalman_x + Q乘(sp.kalman_v, dt))
}

// §5 物理模型预测 (带摩擦)
// y(t) = y₀ + v·t + 0.5·a·t² - μ·v·sign(v)·t

函数 滚动预测器_物理预测(sp, 毫秒后) {
    如果 (sp == 0 || sp.有效长度 == 0) { 返回 0 }

    定义 当前Y = 内存_读32有符号(sp.历史位置 + (sp.有效长度 - 1) * 4)
    定义 t = 毫秒后 * Q_ONE / 1000    // 秒(Q10)

    // v·t
    定义 位移_速度 = Q乘(sp.当前速度, t)
    // 0.5·a·t²
    定义 位移_加速 = Q乘(Q_HALF, Q乘(sp.当前加速度, Q乘(t, t)))
    // 摩擦衰减: -μ·|v|·t
    定义 摩擦力 = Q乘(sp.摩擦系数, Q乘(绝对值(sp.当前速度), t))
    定义 可变 摩擦修正 = 0
    如果 (sp.当前速度 > 0) {
        摩擦修正 = -摩擦力
    } 否则如果 (sp.当前速度 < 0) {
        摩擦修正 = 摩擦力
    }

    返回 当前Y + Q转整数(位移_速度 + 位移_加速 + 摩擦修正)
}

// §6 【Nova原创】AI滚动模式识别
// 理论: 分析速度历史的统计特征, 识别4种滚动模式
//   快速滚动: 高速度, 低方向变换
//   慢速浏览: 低速度, 低方向变换
//   往复滚动: 高方向变换率
//   惯性滚动: 速度单调递减 (fling)

定义 滚动模式_停止 = 0
定义 滚动模式_快速 = 1
定义 滚动模式_慢速 = 2
定义 滚动模式_往复 = 3
定义 滚动模式_惯性 = 4

函数 滚动预测器_AI检测模式(sp) {
    如果 (sp.速度历史索引 < 4) {
        sp.模式 = 滚动模式_停止
        sp.模式置信度 = 0
        返回
    }

    // 统计速度历史: 平均|v|, 方差, 单调性
    定义 可变 速度绝对和 = 0
    定义 可变 单调递减数 = 0
    定义 可变 样本数 = 0
    定义 起始 = 0
    如果 (sp.速度历史索引 > 8) { 起始 = sp.速度历史索引 - 8 }

    定义 可变 i = 起始
    定义 可变 上一绝对 = 0
    当 (i < sp.速度历史索引) {
        定义 idx = i % 8
        定义 v = 内存_读32有符号(sp.速度历史 + idx * 4)
        定义 abs_v = 绝对值(v)
        速度绝对和 = 速度绝对和 + abs_v
        // 检查单调递减
        如果 (样本数 > 0 && abs_v < 上一绝对) {
            单调递减数 = 单调递减数 + 1
        }
        上一绝对 = abs_v
        样本数 = 样本数 + 1
        i = i + 1
    }

    如果 (样本数 == 0) { 返回 }
    定义 平均速度 = 速度绝对和 / 样本数
    定义 速度阈值_快 = 500 * Q_ONE / 1000  // 500 px/s
    定义 速度阈值_慢 = 100 * Q_ONE / 1000  // 100 px/s

    // 判断模式
    如果 (平均速度 < 速度阈值_慢 / 2) {
        sp.模式 = 滚动模式_停止
        sp.模式置信度 = 240
    } 否则如果 (sp.方向变换数 > 3 && 样本数 >= 4) {
        sp.模式 = 滚动模式_往复
        sp.模式置信度 = 200
    } 否则如果 (单调递减数 >= 样本数 * 3 / 4 && 平均速度 > 速度阈值_慢) {
        sp.模式 = 滚动模式_惯性
        sp.模式置信度 = 220
    } 否则如果 (平均速度 > 速度阈值_快) {
        sp.模式 = 滚动模式_快速
        sp.模式置信度 = 200
    } 否则 {
        sp.模式 = 滚动模式_慢速
        sp.模式置信度 = 180
    }

    // 每20帧衰减方向变换计数
    如果 (sp.速度历史索引 % 20 == 0) {
        sp.方向变换数 = sp.方向变换数 / 2
    }
}

// §7 【Nova原创】多模态融合预测
// 理论: P_final = α·P_物理 + β·P_Kalman + γ·P_AI修正
//   权重根据模式动态调整:
//   惯性滚动: 物理模型权重高 (轨迹可预测)
//   往复滚动: Kalman权重高 (需要平滑)
//   快速滚动: AI修正权重高 (预测停止点)

函数 滚动预测器_预测位置(sp, 毫秒后) {
    如果 (sp == 0 || sp.有效长度 == 0) { 返回 0 }

    // 获取三个模型的预测
    定义 P_物理 = 滚动预测器_物理预测(sp, 毫秒后)
    定义 P_Kalman = 滚动预测器_Kalman预测(sp, 毫秒后)

    // 根据模式选择融合权重 (Q8)
    定义 可变 α = 128  // 物理 0.5
    定义 可变 β = 128  // Kalman 0.5

    如果 (sp.模式 == 滚动模式_惯性) {
        // 惯性滚动: 物理模型更准
        α = 192  // 0.75
        β = 64   // 0.25
    } 否则如果 (sp.模式 == 滚动模式_往复) {
        // 往复: Kalman平滑更重要
        α = 64
        β = 192
    } 否则如果 (sp.模式 == 滚动模式_快速) {
        // 快速滚动: 平均融合
        α = 128
        β = 128
    } 否则如果 (sp.模式 == 滚动模式_慢速) {
        // 慢速: Kalman平滑
        α = 96
        β = 160
    }

    // 融合: P = (α·P_物理 + β·P_Kalman) >> 8
    返回 (α * P_物理 + β * P_Kalman) >> 8
}

// §8 预加载区域计算
// 理论: 根据预测位置和当前视口, 计算需要预加载的区域

结构 预加载区域 {
    开始_y,
    结束_y,
    方向,       // i32: -1/0/1
    优先级,     // u32: 0=低, 1=中, 2=高
    置信度,     // u32 Q8
}

函数 滚动预测器_计算预加载(sp, 视口高度, 当前滚动Y) {
    定义 结果 = 预加载区域 {}
    结果.方向 = sp.方向
    结果.置信度 = sp.模式置信度

    // 预测200ms后的位置
    定义 预测位置 = 滚动预测器_预测位置(sp, 200)
    定义 偏移 = 预测位置 - 当前滚动Y

    如果 (sp.方向 == 1) {
        // 向下滚动: 预加载下方内容
        结果.开始_y = 当前滚动Y + 视口高度
        结果.结束_y = 当前滚动Y + 视口高度 + 绝对值(偏移) + 视口高度
    } 否则如果 (sp.方向 == -1) {
        // 向上滚动
        结果.结束_y = 当前滚动Y
        结果.开始_y = 当前滚动Y - 绝对值(偏移) - 视口高度
    } 否则 {
        // 停止: 预加载上下各半屏
        结果.开始_y = 当前滚动Y - 视口高度 / 2
        结果.结束_y = 当前滚动Y + 视口高度 + 视口高度 / 2
    }

    // 设置优先级
    如果 (sp.模式 == 滚动模式_快速 || sp.模式 == 滚动模式_惯性) {
        结果.优先级 = 2  // 高优先级
    } 否则如果 (sp.模式 == 滚动模式_慢速) {
        结果.优先级 = 1
    } 否则 {
        结果.优先级 = 0
    }
    返回 结果
}

// §9 惯性滚动停止点预测
// 理论: v(t)=v₀·e^(-μ·t), 当v<阈值时停止
//   停止时间 t_stop = -ln(阈值/v₀) / μ
//   用近似: t_stop ≈ v₀ / (2·μ·阈值)

定义 惯性停止速度阈值 = 50  // Q10: 约 0.05 px/ms

函数 滚动预测器_预测停止时间(sp) {
    定义 abs_v = 绝对值(sp.当前速度)
    如果 (abs_v <= 惯性停止速度阈值) { 返回 0 }
    如果 (sp.摩擦系数 <= 0) { 返回 999999 }

    // t_stop ≈ |v₀| / (2·μ·阈值) ms换算
    定义 停止时间 = Q除(abs_v, Q乘(sp.摩擦系数 * 2, 惯性停止速度阈值))
    返回 Q转整数(停止时间) * 1000  // 转为ms
}

函数 滚动预测器_预测停止位置(sp) {
    定义 停止时间 = 滚动预测器_预测停止时间(sp)
    如果 (停止时间 <= 0) {
        如果 (sp.有效长度 > 0) {
            返回 内存_读32有符号(sp.历史位置 + (sp.有效长度 - 1) * 4)
        }
        返回 0
    }
    返回 滚动预测器_物理预测(sp, 停止时间)
}

// §10 查询接口与诊断

函数 滚动预测器_获取速度(sp) {
    返回 sp.当前速度
}

函数 滚动预测器_获取加速度(sp) {
    返回 sp.当前加速度
}

函数 滚动预测器_获取方向(sp) {
    返回 sp.方向
}

函数 滚动预测器_获取模式(sp) {
    返回 sp.模式
}

函数 滚动预测器_是否滚动中(sp) {
    返回 sp.方向 != 0
}

函数 滚动预测器_设置摩擦(sp, 摩擦系数_Q10) {
    sp.摩擦系数 = 摩擦系数_Q10
}

// AI总线报告
函数 滚动预测器_发送特征(sp) {
    定义 特征 = Tensor_创建(8)
    Tensor_写(特征, 0, sp.当前速度)
    Tensor_写(特征, 1, sp.当前加速度)
    Tensor_写(特征, 2, sp.方向)
    Tensor_写(特征, 3, sp.模式)
    Tensor_写(特征, 4, sp.模式置信度)
    Tensor_写(特征, 5, Q转整数(sp.kalman_v))
    Tensor_写(特征, 6, sp.方向变换数)
    Tensor_写(特征, 7, sp.有效长度)
    全局AI总线.发送("预测.滚动方向", 特征)
    Tensor_释放(特征)
}

// §11 销毁与重置

函数 滚动预测器_重置(sp) {
    sp.有效长度 = 0
    sp.当前速度 = 0
    sp.当前加速度 = 0
    sp.方向 = 0
    sp.kalman_x = 0
    sp.kalman_v = 0
    sp.kalman_P00 = Q_ONE
    sp.kalman_P01 = 0
    sp.kalman_P10 = 0
    sp.kalman_P11 = Q_ONE
    sp.模式 = 滚动模式_停止
    sp.模式置信度 = 0
    sp.方向变换数 = 0
    sp.速度历史索引 = 0
}

函数 滚动预测器_销毁(sp) {
    如果 (sp == 0) { 返回 }
    堆_释放(sp.历史位置)
    堆_释放(sp.历史时间)
    堆_释放(sp.速度历史)
    堆_释放(sp)
}

// §12 预测精度自评估与自适应校准
// 理论: 记录预测值与实际值的误差, 动态调整模型权重
//   MAE = Σ|pred - actual| / N, 用于自适应摩擦系数

定义 预测评估_窗口 = 16
定义 可变 预测误差历史 = []
定义 可变 预测误差索引 = 0
定义 可变 预测评估_总次数 = 0
定义 可变 预测评估_MAE = 0

函数 滚动预测器_记录预测误差(sp, 预测位置, 实际位置) {
    定义 误差 = 预测位置 - 实际位置
    如果 (误差 < 0) { 误差 = 0 - 误差 }

    如果 (预测评估_总次数 < 预测评估_窗口) {
        追加(预测误差历史, 误差)
    } 否则 {
        定义 idx = 预测误差索引 % 预测评估_窗口
        设置(预测误差历史, idx, 误差)
    }
    预测误差索引 = 预测误差索引 + 1
    预测评估_总次数 = 预测评估_总次数 + 1

    // 更新MAE
    定义 可变 总误差 = 0
    定义 有效数 = 计数(预测误差历史)
    定义 可变 i = 0
    当 (i < 有效数) {
        总误差 = 总误差 + 预测误差历史[i]
        i = i + 1
    }
    如果 (有效数 > 0) {
        预测评估_MAE = 总误差 / 有效数
    }

    // 自适应摩擦校准: 误差大时增加摩擦抑制过冲
    如果 (预测评估_MAE > 100 && sp != 0) {
        sp.摩擦系数 = sp.摩擦系数 + 5
        如果 (sp.摩擦系数 > 200) { sp.摩擦系数 = 200 }
    } 否则如果 (预测评估_MAE < 30 && sp != 0) {
        sp.摩擦系数 = sp.摩擦系数 - 2
        如果 (sp.摩擦系数 < 10) { sp.摩擦系数 = 10 }
    }
}

函数 滚动预测器_获取MAE() {
    返回 预测评估_MAE
}

函数 滚动预测器_获取预测次数() {
    返回 预测评估_总次数
}

// §13 综合统计诊断

函数 滚动预测器_打印统计(sp) {
    如果 (sp == 0) { 打印行("滚动预测器: 未初始化"); 返回 }
    打印行("=== 滚动预测器统计 ===")
    打印行("有效样本: " + 整数转字符串(sp.有效长度))
    打印行("当前速度(Q10): " + 整数转字符串(sp.当前速度))
    打印行("当前加速度(Q10): " + 整数转字符串(sp.当前加速度))
    打印行("方向: " + 整数转字符串(sp.方向))
    打印行("模式: " + 整数转字符串(sp.模式))
    打印行("模式置信度(Q8): " + 整数转字符串(sp.模式置信度))
    打印行("方向变换累计: " + 整数转字符串(sp.方向变换数))
    打印行("摩擦系数(Q10): " + 整数转字符串(sp.摩擦系数))
    打印行("Kalman位置(Q10): " + 整数转字符串(sp.kalman_x))
    打印行("Kalman速度(Q10): " + 整数转字符串(sp.kalman_v))
    打印行("预测评估次数: " + 整数转字符串(预测评估_总次数))
    打印行("平均绝对误差: " + 整数转字符串(预测评估_MAE))
}

// §10 【原生独创】谐振滚动惯性预测器
// 基于滚动速度和加速度预测最终停止位置

定义 可变 _谐振滚动_速度历史 = []
定义 可变 _谐振滚动_预测次数 = 0

函数 谐振滚动_记录速度(速度) {
    追加(_谐振滚动_速度历史, 速度)
    如果 (计数(_谐振滚动_速度历史) > 16) {
        定义 可变 新表 = []
        定义 可变 i = 计数(_谐振滚动_速度历史) - 16
        当 (i < 计数(_谐振滚动_速度历史)) {
            追加(新表, _谐振滚动_速度历史[i])
            i = i + 1
        }
        _谐振滚动_速度历史 = 新表
    }
}

函数 谐振滚动_预测停止偏移() {
    如果 (计数(_谐振滚动_速度历史) < 2) { 返回 0 }
    定义 最近 = _谐振滚动_速度历史[计数(_谐振滚动_速度历史) - 1]
    定义 前一 = _谐振滚动_速度历史[计数(_谐振滚动_速度历史) - 2]
    定义 减速率 = 前一 - 最近
    如果 (减速率 <= 0) { 返回 最近 * 5 }
    // 预测停止距离 ≈ v²/(2a)
    定义 预测 = 最近 * 最近 / (2 * 减速率 + 1)
    _谐振滚动_预测次数 = _谐振滚动_预测次数 + 1
    返回 预测
}

函数 滚动预测_完整统计() {
    返回 [
        "谐振预测次数", _谐振滚动_预测次数,
        "速度历史数", 计数(_谐振滚动_速度历史)
    ]
}

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../执行/控制台输出.nova")
导入("../中枢/整数转字符串.nova")

定义 影子_开放 = 0
定义 影子_封闭 = 1
定义 最大注册 = 128
定义 最大槽位 = 32
定义 回调_连接 = 0
定义 回调_断开 = 1
定义 回调_属性变 = 2
定义 回调_采纳 = 3

结构 自定义元素注册 {
    标签哈希,
    构造回调,
    连接回调,
    断开回调,
    属性变回调,
    采纳回调,
    观察属性表,
    观察属性数,
    扩展标签哈希,
}

结构 影子根 {
    宿主元素,
    模式,
    首子节点,
    子节点数,
    槽位表,
    槽位数,
    样式内容,
    已分发,
}

定义 可变 注册表 = []
定义 可变 注册数 = 0
定义 可变 影子根数 = 0
定义 可变 声明式处理数 = 0

函数 自定义元素_注册(标签名, 构造, 连接, 断开, 属性变) {
    如果 (注册数 >= 最大注册) { 返回 错误_无资源 }
    定义 注册 = 自定义元素注册 {}
    注册.标签哈希 = 哈希_字符串(标签名)
    注册.构造回调 = 构造
    注册.连接回调 = 连接
    注册.断开回调 = 断开
    注册.属性变回调 = 属性变
    注册.采纳回调 = 0
    注册.观察属性表 = 堆_分配(16 * 8)
    注册.观察属性数 = 0
    注册.扩展标签哈希 = 0
    追加(注册表, 注册)
    注册数 = 注册数 + 1
    返回 0
}

函数 自定义元素_查找(标签名) {
    定义 目标 = 哈希_字符串(标签名)
    定义 可变 序号 = 0
    当 (序号 < 注册数) {
        如果 (注册表[序号].标签哈希 == 目标) { 返回 序号 }
        序号 = 序号 + 1
    }
    返回 -1
}

函数 自定义元素_创建实例(标签名) {
    定义 索引 = 自定义元素_查找(标签名)
    如果 (索引 < 0) { 返回 0 }
    定义 注册 = 注册表[索引]
    定义 可变 实例 = 0
    如果 (注册.构造回调 != 0) { 实例 = 注册.构造回调() }
    返回 实例
}

函数 自定义元素_触发连接(元素, 标签名) {
    定义 索引 = 自定义元素_查找(标签名)
    如果 (索引 >= 0 && 注册表[索引].连接回调 != 0) {
        注册表[索引].连接回调(元素)
    }
}

函数 自定义元素_触发断开(元素, 标签名) {
    定义 索引 = 自定义元素_查找(标签名)
    如果 (索引 >= 0 && 注册表[索引].断开回调 != 0) {
        注册表[索引].断开回调(元素)
    }
}

函数 自定义元素_触发属性变(元素, 标签名, 属性名, 旧值, 新值) {
    定义 索引 = 自定义元素_查找(标签名)
    如果 (索引 >= 0 && 注册表[索引].属性变回调 != 0) {
        注册表[索引].属性变回调(元素, 属性名, 旧值, 新值)
    }
}

函数 影子_附加(宿主, 模式) {
    定义 根 = 堆_分配(影子根)
    根.宿主元素 = 宿主
    根.模式 = 模式
    根.首子节点 = 0
    根.子节点数 = 0
    根.槽位表 = 堆_分配(最大槽位 * 16)
    根.槽位数 = 0
    根.样式内容 = 0
    根.已分发 = 假
    影子根数 = 影子根数 + 1
    返回 根
}

函数 影子_添加槽位(根, 名称哈希) {
    如果 (根 == 0 || 根.槽位数 >= 最大槽位) { 返回 -1 }
    定义 偏移 = 根.槽位表 + 根.槽位数 * 16
    内存_写64(偏移, 名称哈希)
    内存_写64(偏移 + 8, 0)
    定义 索引 = 根.槽位数
    根.槽位数 = 根.槽位数 + 1
    返回 索引
}

函数 影子_分发槽位(根) {
    如果 (根 == 0 || 根.已分发) { 返回 }
    根.已分发 = 真
}

函数 影子_设样式(根, 样式数据) {
    如果 (根 == 0) { 返回 }
    根.样式内容 = 样式数据
}

函数 声明式影子_处理(模板节点, 宿主节点) {
    如果 (模板节点 == 0 || 宿主节点 == 0) { 返回 }
    声明式处理数 = 声明式处理数 + 1
    定义 模式 = 影子_开放
    定义 根 = 影子_附加(宿主节点, 模式)
    如果 (根 == 0) { 返回 }
    影子_分发槽位(根)
}

函数 影子_获取根(宿主) {
    返回 影子宿主.影子根
    返回 0
}

函数 网组件_完整统计() {
    返回 [注册数, 影子根数, 声明式处理数]
}

// §2 网组件健康检查与诊断

函数 网组件_健康检查() {
    定义 可变 问题 = []
    如果 (注册数 > 最大注册 * 9 / 10) {
        追加(问题, "自定义元素注册接近上限: " + 整数转字符串(注册数))
    }
    如果 (计数(问题) == 0) { 返回 "网组件子系统健康" }
    返回 问题
}

函数 网组件_详细统计() {
    返回 {
        注册数: 注册数,
        影子根数: 影子根数,
        声明式处理: 声明式处理数,
        最大注册: 最大注册,
    }
}

函数 网组件_重置统计() {
    注册数 = 0
    影子根数 = 0
    声明式处理数 = 0
    注册表 = []
}

// §3 自定义元素扩展操作

函数 自定义元素_设观察属性(标签名, 属性名) {
    定义 索引 = 自定义元素_查找(标签名)
    如果 (索引 < 0) { 返回 }
    定义 注册 = 注册表[索引]
    如果 (注册.观察属性数 >= 16) { 返回 }
    内存_写64(注册.观察属性表 + 注册.观察属性数 * 8, 哈希_字符串(属性名))
    注册.观察属性数 = 注册.观察属性数 + 1
}

函数 自定义元素_设扩展标签(标签名, 扩展标签) {
    定义 索引 = 自定义元素_查找(标签名)
    如果 (索引 < 0) { 返回 }
    注册表[索引].扩展标签哈希 = 哈希_字符串(扩展标签)
}

函数 自定义元素_设采纳回调(标签名, 回调) {
    定义 索引 = 自定义元素_查找(标签名)
    如果 (索引 < 0) { 返回 }
    注册表[索引].采纳回调 = 回调
}

函数 自定义元素_触发采纳(元素, 标签名, 旧文档, 新文档) {
    定义 索引 = 自定义元素_查找(标签名)
    如果 (索引 >= 0 && 注册表[索引].采纳回调 != 0) {
        注册表[索引].采纳回调(元素, 旧文档, 新文档)
    }
}

函数 自定义元素_是否观察(标签名, 属性名) {
    定义 索引 = 自定义元素_查找(标签名)
    如果 (索引 < 0) { 返回 假 }
    定义 注册 = 注册表[索引]
    定义 目标 = 哈希_字符串(属性名)
    定义 可变 i = 0
    当 (i < 注册.观察属性数) {
        如果 (内存_读64(注册.观察属性表 + i * 8) == 目标) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 自定义元素_已注册(标签名) {
    返回 自定义元素_查找(标签名) >= 0
}

函数 自定义元素_注册数() {
    返回 注册数
}

函数 自定义元素_获取注册(索引) {
    如果 (索引 < 0 || 索引 >= 注册数) { 返回 0 }
    返回 注册表[索引]
}

// §4 影子根扩展操作

函数 影子_添加子节点(根, 节点) {
    如果 (根 == 0 || 节点 == 0) { 返回 }
    根.子节点数 = 根.子节点数 + 1
}

函数 影子_移除子节点(根, 节点) {
    如果 (根 == 0 || 节点 == 0) { 返回 }
    如果 (根.子节点数 > 0) { 根.子节点数 = 根.子节点数 - 1 }
}

函数 影子_获取模式名(模式) {
    如果 (模式 == 影子_开放) { 返回 "open" }
    返回 "closed"
}

函数 影子_获取子节点数(根) {
    如果 (根 == 0) { 返回 0 }
    返回 根.子节点数
}

函数 影子_获取槽位数(根) {
    如果 (根 == 0) { 返回 0 }
    返回 根.槽位数
}

函数 影子_获取宿主(根) {
    如果 (根 == 0) { 返回 0 }
    返回 根.宿主元素
}

函数 影子_有样式(根) {
    如果 (根 == 0) { 返回 假 }
    返回 根.样式内容 != 0
}

函数 影子_诊断(根) {
    如果 (根 == 0) { 返回 "影子根为空" }
    返回 {
        模式: 影子_获取模式名(根.模式),
        子节点数: 根.子节点数,
        槽位数: 根.槽位数,
        有样式: 根.样式内容 != 0,
        已分发: 根.已分发,
    }
}

// §5 声明式影子DOM扩展

函数 声明式影子_解析模式(属性值) {
    如果 (属性值 == 0) { 返回 影子_开放 }
    如果 (字符串_相等(属性值, "open")) { 返回 影子_开放 }
    如果 (字符串_相等(属性值, "closed")) { 返回 影子_封闭 }
    返回 影子_开放
}

函数 声明式影子_处理带模式(模板节点, 宿主节点, 模式属性) {
    如果 (模板节点 == 0 || 宿主节点 == 0) { 返回 }
    声明式处理数 = 声明式处理数 + 1
    定义 模式 = 声明式影子_解析模式(模式属性)
    定义 根 = 影子_附加(宿主节点, 模式)
    如果 (根 == 0) { 返回 }
    影子_分发槽位(根)
}

// §6 辅助函数

函数 哈希_字符串(s) {
    如果 (s == 0) { 返回 0 }
    定义 长度 = 字节长度(s)
    定义 可变 哈希 = 5381
    定义 可变 i = 0
    当 (i < 长度) {
        哈希 = ((哈希 << 5) + 哈希) + 内存_读8(s + i)
        i = i + 1
    }
    返回 哈希 & 0x7FFFFFFF
}

定义 错误_无资源 = -12

函数 字符串_相等(a, b) {
    如果 (a == b) { 返回 真 }
    如果 (a == 0 || b == 0) { 返回 假 }
    定义 长a = 字节长度(a)
    定义 长b = 字节长度(b)
    如果 (长a != 长b) { 返回 假 }
    定义 可变 i = 0
    当 (i < 长a) {
        如果 (内存_读8(a + i) != 内存_读8(b + i)) { 返回 假 }
        i = i + 1
    }
    返回 真
}

函数 网组件_自定义元素诊断(标签名) {
    定义 索引 = 自定义元素_查找(标签名)
    如果 (索引 < 0) { 返回 "未注册: " + 标签名 }
    定义 注册 = 注册表[索引]
    返回 {
        标签哈希: 注册.标签哈希,
        有构造: 注册.构造回调 != 0,
        有连接: 注册.连接回调 != 0,
        有断开: 注册.断开回调 != 0,
        有属性变: 注册.属性变回调 != 0,
        有采纳: 注册.采纳回调 != 0,
        观察属性数: 注册.观察属性数,
    }
}

定义 可变 AI_影子文档_热节点缓存 = 0

函数 AI_影子文档_节点热度(节点, 操作类型) {
    如果 (操作类型 == "查询") { 返回 "缓存" }
    如果 (操作类型 == "修改") { AI_影子文档_热节点缓存 = 0; 返回 "失效" }
    返回 "普通"
}

函数 AI_影子文档_批量DOM优化(操作数) {
    如果 (操作数 > 100) { 返回 "延迟重排" }
    如果 (操作数 > 10) { 返回 "批量重排" }
    返回 "即时重排"
}

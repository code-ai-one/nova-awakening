
// IEEE 754 常量
定义 浮点_偏置 = 127
定义 浮点_EXP_MASK = 0xFF
定义 浮点_MANT_MASK = 0x7FFFFF
定义 浮点_SIGN_BIT = 0x80000000
定义 浮点_EXP_SHIFT = 23
定义 浮点_INF = 0x7F800000
定义 浮点_NEG_INF = 0xFF800000
定义 浮点_NAN = 0x7FC00000
定义 浮点_ZERO = 0x00000000
定义 浮点_NEG_ZERO = 0x80000000
定义 浮点_ONE = 0x3F800000
定义 浮点_NEG_ONE = 0xBF800000
定义 浮点_TWO = 0x40000000
定义 浮点_HALF = 0x3F000000
定义 浮点_TEN = 0x41200000
定义 浮点_PI_APPROX = 0x40490FDB

// 位域提取
函数 fp_符号(f) { 返回 (f >> 31) & 1 }
函数 fp_指数(f) { 返回 (f >> 浮点_EXP_SHIFT) & 浮点_EXP_MASK }
函数 fp_尾数(f) { 返回 f & 浮点_MANT_MASK }

// 分类
函数 fp_是零(f)
{ 返回 (f & 0x7FFFFFFF) == 0 }
函数 fp_是无穷(f) {
    如果 (fp_指数(f) == 255) { 如果 (fp_尾数(f) == 0) { 返回 1
}
 }
 返回 0
}
函数 fp_是NaN(f) {
    如果 (fp_指数(f) == 255) { 如果 (fp_尾数(f) != 0) { 返回 1
}
 }
 返回 0
}
函数 fp_是正(f)
{ 如果 (fp_是零(f) == 1) { 返回 0 }
 返回 (fp_符号(f) == 0)
}
函数 fp_是负(f)
{ 返回 fp_符号(f) == 1 }
函数 fp_是规格化(f) { 定义 可变 e = fp_指数(f)
 如果 (e == 0) { 返回 0 }
 如果 (e == 255) { 返回 0 }
 返回 1
}

// 构造
函数 fp_构造(符号, 指数, 尾数) { 返回 ((符号 & 1) << 31) | ((指数 & 浮点_EXP_MASK) << 浮点_EXP_SHIFT) | (尾数 & 浮点_MANT_MASK)
}

// 取反/绝对值
函数 fp_取反(f) { 返回 f ^ 浮点_SIGN_BIT }
函数 fp_绝对值(f) { 返回 f & 0x7FFFFFFF }

// 从整数转换 (整数→浮点表示)
函数 fp_从整数(n) {
    如果 (n == 0) { 返回 浮点_ZERO
}
 定义 可变 符号 = 0
 定义 可变 v = n
 如果 (n < 0) { 符号 = 1
 v = 0 - n }
 // 找最高位
 定义 可变 指数值 = 0
 定义 可变 t = v
 当 (t > 1) { t = t >> 1
 指数值 = 指数值 + 1 }
 // 尾数: 去掉隐含1, 对齐到23位
 定义 可变 mant = 0
 如果 (指数值 >= 23) {
 mant = (v >> (指数值 - 23)) & 浮点_MANT_MASK
 } 否则 {
 mant = (v << (23 - 指数值)) & 浮点_MANT_MASK
 }
 返回 fp_构造(符号, 指数值 + 浮点_偏置, mant)
}

// 浮点→整数 (截断)
函数 fp_到整数(f) {
    如果 (fp_是零(f) == 1) { 返回 0
}
 如果 (fp_是NaN(f) == 1) { 返回 0 }
 定义 可变 s = fp_符号(f)
 定义 可变 e = fp_指数(f) - 浮点_偏置
 定义 可变 m = fp_尾数(f) | 0x800000 // 加隐含1
 定义 可变 结果 = 0
 如果 (e >= 23) {
 结果 = m << (e - 23)
 } 否则 { 如果 (e >= 0) {
 结果 = m >> (23 - e)
 } 否则 {
 结果 = 0
 }
 }
 如果 (s == 1) { 结果 = 0 - 结果 }
 返回 结果
}

// 比较
函数 fp_等于(a, b) {
    如果 (fp_是NaN(a) == 1) { 返回 0
}
 如果 (fp_是NaN(b) == 1) { 返回 0 }
 如果 (fp_是零(a) == 1) { 如果 (fp_是零(b) == 1) { 返回 1 }
 }
 返回 a == b
}

函数 fp_小于(a, b) {
    如果 (fp_是NaN(a) == 1) { 返回 0
}
 如果 (fp_是NaN(b) == 1) { 返回 0 }
 定义 可变 sa = fp_符号(a)
 定义 可变 sb = fp_符号(b)
 如果 (sa == 1) { 如果 (sb == 0) { 返回 1 }
 }
 如果 (sa == 0) { 如果 (sb == 1) { 返回 0 }
 }
 // 同号比较
 如果 (sa == 0) { 返回 (a & 0x7FFFFFFF) < (b & 0x7FFFFFFF) }
 返回 (a & 0x7FFFFFFF) > (b & 0x7FFFFFFF)
}

// 定点乘法辅助 (用于浮点乘法)
// 24位×24位乘法, 结果48位, 我们取高24位
函数 fp_乘尾数(a, b) {
 // 分割成12位段避免溢出
 定义 可变 al = a & 0xFFF
 定义 可变 ah = (a >> 12) & 0xFFF
 定义 可变 bl = b & 0xFFF
 定义 可变 bh = (b >> 12) & 0xFFF
 定义 可变 ll = al * bl
 定义 可变 lh = al * bh
 定义 可变 hl = ah * bl
 定义 可变 hh = ah * bh
 // 组合: hh<<24 + (lh+hl)<<12 + ll, 取高24位 (>> 23)
 定义 可变 中间值 = lh + hl
 定义 可变 结果 = (hh << 1) + (中间值 >> 11) + (ll >> 23)
 返回 结果
}

// 浮点乘法
函数 fp_乘(a, b) {
    如果 (fp_是NaN(a) == 1) { 返回 浮点_NAN
}
 如果 (fp_是NaN(b) == 1) { 返回 浮点_NAN }
 定义 可变 rs = fp_符号(a) ^ fp_符号(b)
 如果 (fp_是零(a) == 1) { 返回 fp_构造(rs, 0 , 0) }
 如果 (fp_是零(b) == 1) { 返回 fp_构造(rs, 0 , 0) }
 如果 (fp_是无穷(a) == 1) { 返回 fp_构造(rs,  255, 0) }
 如果 (fp_是无穷(b) == 1) { 返回 fp_构造(rs,  255, 0) }
 定义 可变 ea = fp_指数(a) - 浮点_偏置
 定义 可变 eb = fp_指数(b) - 浮点_偏置
 定义 可变 ma = fp_尾数(a) | 0x800000
 定义 可变 mb = fp_尾数(b) | 0x800000
 定义 可变 re = ea + eb + 浮点_偏置
 定义 可变 rm = fp_乘尾数(ma, mb)
 // 规格化
 如果 (rm >= 0x1000000) { rm = rm >> 1
 re = re + 1 }
 如果 (re >= 255) { 返回 fp_构造(rs,  255, 0) } // 溢出→Inf
 如果 (re <= 0) { 返回 fp_构造(rs, 0 , 0) } // 下溢→0
 返回 fp_构造(rs, re, rm & 浮点_MANT_MASK)
}

// 浮点加法
函数 fp_加(a, b) {
    如果 (fp_是NaN(a) == 1) { 返回 浮点_NAN
}
 如果 (fp_是NaN(b) == 1) { 返回 浮点_NAN }
 如果 (fp_是零(a) == 1) { 返回 b }
 如果 (fp_是零(b) == 1) { 返回 a }
 如果 (fp_是无穷(a) == 1) { 返回 a }
 如果 (fp_是无穷(b) == 1) { 返回 b }
 // 对齐指数
 定义 可变 ea = fp_指数(a)
 定义 可变 eb = fp_指数(b)
 定义 可变 ma = fp_尾数(a) | 0x800000
 定义 可变 mb = fp_尾数(b) | 0x800000
 定义 可变 sa = fp_符号(a)
 定义 可变 sb = fp_符号(b)
 定义 可变 re = ea
 如果 (ea > eb) {
 mb = mb >> (ea - eb)
 re = ea
 } 否则 { 如果 (eb > ea) {
 ma = ma >> (eb - ea)
 re = eb
 }
 }
 // 根据符号加减
 定义 可变 rm = 0
 定义 可变 rs = 0
 如果 (sa == sb) {
 rm = ma + mb
 rs = sa
 } 否则 { 如果 (ma >= mb) {
 rm = ma - mb
 rs = sa
 } 否则 {
 rm = mb - ma
 rs = sb
 }
 }
 如果 (rm == 0) { 返回 浮点_ZERO }
 // 规格化
 当 (rm >= 0x1000000) { rm = rm >> 1
 re = re + 1 }
 当 (rm < 0x800000) { 如果 (rm == 0) { 返回 浮点_ZERO }
 rm = rm << 1
 re = re - 1
 }
 如果 (re >= 255) { 返回 fp_构造(rs,  255, 0) }
 如果 (re <= 0) { 返回 浮点_ZERO }
 返回 fp_构造(rs, re, rm & 浮点_MANT_MASK)
}

// 浮点减法
函数 fp_减(a, b) { 返回 fp_加(a, fp_取反(b)) }

// 浮点除法
函数 fp_除(a, b) {
    如果 (fp_是NaN(a) == 1) { 返回 浮点_NAN
}
 如果 (fp_是NaN(b) == 1) { 返回 浮点_NAN }
 定义 可变 rs = fp_符号(a) ^ fp_符号(b)
 如果 (fp_是零(b) == 1) { 如果 (fp_是零(a) == 1) { 返回 浮点_NAN } // 0/0=NaN
 返回 fp_构造(rs,  255, 0) // x/0=Inf
 }
 如果 (fp_是零(a) == 1) { 返回 fp_构造(rs, 0 , 0) }
 如果 (fp_是无穷(a) == 1) { 如果 (fp_是无穷(b) == 1) { 返回 浮点_NAN } // Inf/Inf=NaN
 返回 fp_构造(rs,  255, 0)
 }
 如果 (fp_是无穷(b) == 1) { 返回 fp_构造(rs, 0 , 0) }
 定义 可变 ea = fp_指数(a) - 浮点_偏置
 定义 可变 eb = fp_指数(b) - 浮点_偏置
 定义 可变 ma = fp_尾数(a) | 0x800000
 定义 可变 mb = fp_尾数(b) | 0x800000
 定义 可变 re = ea - eb + 浮点_偏置
 定义 可变 余 = ma
 // 预对齐: 如果被除数 < 除数, 左移并调整指数
 如果 (余 < mb) { 余 = 余 << 1
 re = re - 1 }
 // 24位恢复除法: 先比较减法, 再移位
 定义 可变 商 = 0
 定义 可变 bi = 23
 当 (bi >= 0) { 如果 (余 >= mb) {
 余 = 余 - mb
 商 = 商 | (1 << bi)
 }
 余 = 余 << 1
 bi = bi - 1
 }
 定义 可变 rm = 商
 如果 (re >= 255) { 返回 fp_构造(rs,  255, 0) }
 如果 (re <= 0) { 返回 fp_构造(rs, 0 , 0) }
 返回 fp_构造(rs, re, rm & 浮点_MANT_MASK)
}

// 浮点比较扩展
函数 fp_大于(a, b) { 返回 fp_小于(b, a) }
函数 fp_小于等于(a, b) {
    如果 (fp_是NaN(a) == 1) { 返回 0
}
 如果 (fp_是NaN(b) == 1) { 返回 0 }
 如果 (fp_等于(a, b) == 1) { 返回 1 }
 返回 fp_小于(a, b)
}
函数 fp_大于等于(a, b) { 返回 fp_小于等于(b, a) }

// 浮点最小/最大
函数 fp_最小(a, b) {
    如果 (fp_是NaN(a) == 1) { 返回 b
}
 如果 (fp_是NaN(b) == 1) { 返回 a }
 如果 (fp_小于(a, b) == 1) { 返回 a }
 返回 b
}
函数 fp_最大(a, b) {
    如果 (fp_是NaN(a) == 1) { 返回 b
}
 如果 (fp_是NaN(b) == 1) { 返回 a }
 如果 (fp_大于(a, b) == 1) { 返回 a }
 返回 b
}

// 从×1000定点数转换
函数 fp_从定点(x) { 定义 可变 f = fp_从整数(x)
 返回 fp_乘(f, fp_构造(0, 浮点_偏置 - 10, 0x780000))
}

// 自测

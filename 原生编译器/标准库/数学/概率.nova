// Nova标准库 — 概率与随机模块
// 概率分布采样、蒙特卡洛、贝叶斯基础

导入("../基础.nova")
导入("../../运行时/原语桩.nova")
导入("工具.nova")


定义 概率精度 = 1000

// 随机数生成器 (PCG-XSH-RR)
// 状态: [状态值, 增量]  — 比LCG统计质量高数个量级
函数 rRng_创建(种子) { 定义 增量 = 1442695040888963407
 定义 可变 s = 0
 s = (s * 6364136223846793005 + 增量) & 0x7FFFFFFFFFFFFFFF
 s = ((s + 种子) * 6364136223846793005 + 增量) & 0x7FFFFFFFFFFFFFFF
 返回 [s, 增量]
}

函数 rRng_下一个(状态) {
 定义 旧状态 = 状态[0]
 状态[0] = (旧状态 * 6364136223846793005 + 状态[1]) & 0x7FFFFFFFFFFFFFFF
 // XSH-RR输出函数: 高位混合低位，旋转
 定义 xorshifted = ((旧状态 >> 18) ^ 旧状态) >> 27
 定义 旋转量 = 旧状态 >> 59
 定义 结果 = ((xorshifted >> 旋转量) | (xorshifted << (32 - 旋转量))) & 0x7FFFFFFF
 返回 结果
}

函数 rRng_均匀(状态, 最小, 最大) { 返回 最小 + rRng_下一个(状态) % (最大 - 最小 + 1)
}

// 均匀分布 [0, 精度)
函数 rRRng_均匀01(状态) { 返回 rRng_下一个(状态) % 概率精度
}

// 离散分布采样

// 按概率权重采样 (轮盘赌)
函数 概率_采样(权重, 状态) { 定义 n = 计数(权重)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 总和 = 总和 + 权重[i] i = i + 1 }
 如果 (总和 == 0) { 返回 0 }
 定义 r = rRng_下一个(状态) % 总和
 定义 可变 累计 = 0
 i = 0
 当 (i < n) {
 累计 = 累计 + 权重[i]
 如果 (累计 > r) { 返回 i }
 i = i + 1
 }
 返回 n - 1
}

// 伯努利分布 (成功概率 p/1000)
函数 伯努利(p, 状态) { 返回 rRRng_均匀01(状态) < p
}

// 二项分布 B(n, p)
函数 二项分布(n, p, 状态) { 定义 可变 成功 = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (伯努利(p, 状态)) { 成功 = 成功 + 1 }
 i = i + 1
 }
 返回 成功
}

// 几何分布 (首次成功的试验次数, 0)
函数 几何分布(p, 状态) { 定义 可变 次数 = 1
 当 (伯努利(p, 状态) == 假) {
 次数 = 次数 + 1
 如果 (次数 > 10000) { 返回 次数 }
 }
 返回 次数
}

// 近似正态分布 (Box-Muller 简化)
函数 正态采样(均值, 标准差, 状态) {
 // 使用12个均匀随机数之和近似正态
 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 12) {
 和 = 和 + rRRng_均匀01(状态)
 i = i + 1
 }
 // 和 ≈ N(6000, 1000) → 归一化
 定义 z = 和 - 6 * 概率精度
 如果 (概率精度 == 0) { 返回 0 }
 返回 均值 + 标准差 * z / 概率精度
}

// 泊松分布 (Knuth 算法, 0)
函数 泊松分布(衰减系数, 状态) {
 // 衰减系数 以定点表示 (衰减系数 * 1000)
 定义 L = 概率_exp_neg(衰减系数)
 定义 可变 k = 0
 定义 可变 p = 概率精度
 当 (p > L) {
 k = k + 1
 p = p * rRRng_均匀01(状态) / 概率精度
 }
 返回 k - 1
}

// 蒙特卡洛估计

// 估计 π (圆面积法)
函数 蒙特卡洛_pi(采样数, 状态) { 定义 可变 圆内 = 0
 定义 可变 i = 0
 当 (i < 采样数) { 定义 x = rRng_均匀(状态, 0 - 概率精度, 概率精度)
 定义 y = rRng_均匀(状态, 0 - 概率精度, 概率精度)
 如果 (x * x + y * y <= 概率精度 * 概率精度) {
 圆内 = 圆内 + 1
 }
 i = i + 1
 }
 如果 (采样数 == 0) { 返回 0 }
 返回 4 * 圆内 * 概率精度 / 采样数
}

// 蒙特卡洛积分 (估计函数在[a,b]上的积分)
函数 蒙特卡洛_积分(f, a, b, 采样数, 状态) { 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 采样数) { 定义 x = rRng_均匀(状态, a, b)
 和 = 和 + f(x)
 i = i + 1
 }
 返回 (b - a) * 和 / 采样数
}

// 贝叶斯基础

// 朴素贝叶斯分类器 (离散特征)
// 训练: 计算 P(特征|类别) 和 P(类别)
函数 朴素贝叶斯_训练(数据, 标签, 类别数, 特征值域) { 定义 n = 计数(数据)
 定义 特征数 = 计数(数据[0])
 // 统计类别频率
 定义 可变 类频 = []
 定义 可变 c = 0
 当 (c < 类别数) { 追加(类频, 0) c = c + 1 }
 定义 可变 i = 0
 当 (i < n) {
 类频[标签[i]] = 类频[标签[i]] + 1
 i = i + 1
 }
 // 统计 P(特征=v|类别=c)
 // 条件频率表: [类别数, 特征数, 特征值域, 计数]
 定义 可变 条件频 = []
 c = 0
 当 (c < 类别数) { 定义 可变 特征表 = []
 定义 可变 f = 0
 当 (f < 特征数) { 定义 可变 值表 = []
 定义 可变 v = 0
 当 (v < 特征值域) { 追加(值表, 1) v = v + 1 }
 追加(特征表, 值表)
 f = f + 1
 }
 追加(条件频, 特征表)
 c = c + 1
 }
 // 填充条件频率
 i = 0
 当 (i < n) { 定义 类 = 标签[i]
 定义 可变 f2 = 0
 当 (f2 < 特征数) { 定义 值 = 数据[i][f2]
 如果 (值 >= 0 且 值 < 特征值域) {
 条件频[类][f2][值] = 条件频[类][f2][值] + 1
 }
 f2 = f2 + 1
 }
 i = i + 1
 }
 返回 [类频, 条件频, 类别数, 特征数, 特征值域, n]
}

// 朴素贝叶斯预测
函数 朴素贝叶斯_预测(模型, 样本) { 定义 类频 = 模型[0]
    定义 可变 最优分数 = 0
 定义 条件频 = 模型[1]
 定义 类别数 = 模型[2]
 定义 特征数 = 模型[3]
 定义 特征值域 = 模型[4]
 定义 总数 = 模型[5]
 定义 可变 最优类 = 0
 定义 可变 c = 0
 当 (c < 类别数) {
 // log P(类) + sum log P(特征|类)
 定义 可变 分数 = 类频[c] * 概率精度 / 总数
 定义 可变 f = 0
 当 (f < 特征数) { 定义 值 = 样本[f]
 如果 (值 >= 0 且 值 < 特征值域) { 定义 条件概率 = 条件频[c][f][值] * 概率精度 / (类频[c] + 特征值域)
 分数 = 分数 * 条件概率 / 概率精度
 }
 f = f + 1
 }
 如果 (分数 > 最优分数) {
 最优分数 = 分数
 最优类 = c
 }
 c = c + 1
 }
 返回 最优类
}

// 置换检验
函数 置换检验(数据a, 数据b, 置换数, 状态) { 定义 na = 计数(数据a)
 定义 nb = 计数(数据b)
 // 观察统计量 (均值差)
 定义 可变 和a = 0
 定义 可变 和b = 0
 定义 可变 i = 0
 当 (i < na) { 和a = 和a + 数据a[i] i = i + 1 }
 i = 0
 当 (i < nb) { 和b = 和b + 数据b[i] i = i + 1 }
 定义 可变 观察差 = 和a / na - 和b / nb
 如果 (观察差 < 0) { 观察差 = 0 - 观察差 }
 // 合并数据
 定义 可变 合并 = []
 i = 0
 当 (i < na) { 追加(合并, 数据a[i]) i = i + 1 }
 i = 0
 当 (i < nb) { 追加(合并, 数据b[i]) i = i + 1 }
 定义 总数 = na + nb
 // 置换
 定义 可变 极端数 = 0
 定义 可变 p = 0
 当 (p < 置换数) {
 // Fisher-Yates 洗牌
 i = 总数 - 1
 当 (i > 0) { 定义 j = rRng_下一个(状态) % (i + 1)
 定义 暂存 = 合并[i]
 合并[i] = 合并[j]
 合并[j] = 暂存
 i = i - 1
 }
 // 计算置换后的均值差
 定义 可变 s1 = 0
 定义 可变 s2 = 0
 i = 0
 当 (i < na) { s1 = s1 + 合并[i] i = i + 1 }
 i = na
 当 (i < 总数) { s2 = s2 + 合并[i] i = i + 1 }
 定义 可变 置换差 = s1 / na - s2 / nb
 如果 (置换差 < 0) { 置换差 = 0 - 置换差 }
 如果 (置换差 >= 观察差) { 极端数 = 极端数 + 1 }
 p = p + 1
 }
 如果 (置换数 == 0) { 返回 0 }
 返回 极端数 * 概率精度 / 置换数
}

// 指数分布
函数 指数分布(衰减系数, 状态) {
 // -ln(U)/衰减系数, 用整数近似
 定义 u = 1 + rRRng_均匀01(状态) // 避免0
 定义 可变 neg_ln = 0
 定义 可变 v = u
 // 近似 -ln(u/1000)*1000
 当 (v < 500) { v = v * 2
 neg_ln = neg_ln + 693 }
 当 (v > 概率精度) { v = v / 2
 neg_ln = neg_ln - 693 }
 neg_ln = neg_ln + (概率精度 - v) * 概率精度 / v
 如果 (衰减系数 == 0) { 返回 0 }
 返回 neg_ln * 概率精度 / 衰减系数
}

// 正态分布CDF近似
// 输入: x (×1000), 回: CDF (×1000)
函数 正态cdf(x) {
 // 用逻辑函数近似: Φ(x) ≈ 1/(1+e^(-1.7*x))
 定义 可变 t = 0 - 17 * x / 10
 // sigmoid近似
 如果 (t > 6000) { 返回 0 }
 如果 (t < 0 - 6000) { 返回 概率精度 }
 // 分段线性sigmoid
 如果 (概率精度 == 0) { 返回 0 }
 如果 (t >= 0) { 返回 500 - t * 250 / 概率精度
 } 否则 { 返回 500 - t * 250 / 概率精度
 }
}

// 多项分布采样
函数 多项分布(概率列表, n, 状态) { 定义 k = 计数(概率列表)
 定义 可变 结果 = []
 定义 可变 ci = 0
 当 (ci < k) { 追加(结果, 0)
 ci = ci + 1 }
 定义 可变 i = 0
 当 (i < n) { 定义 索引 = 概率_采样(概率列表, 状态)
 结果[索引] = 结果[索引] + 1
 i = i + 1
 }
 返回 结果
}

// 分类分布 (Categorical)
函数 分类采样(概率列表, 状态) { 返回 概率_采样(概率列表, 状态)
}

// 均匀分布连续采样 (定点)
函数 均匀连续(最小, 最大, 状态) { 定义 r = rRng_下一个(状态)
 返回 最小 + r % (最大 - 最小 + 1)
}

// 贝叶斯更新 (Beta-Binomial, 0)
// 先验 Beta(学习率, 动量率) + 观察 (成功, 失败) → 后验 Beta(学习率+成功, 动量率+失败)
函数 贝叶斯_beta更新(学习率, 动量率, 成功, 失败) { 返回 [学习率 + 成功, 动量率 + 失败]
}

// Beta分布均值 = 学习率/(学习率+动量率)
函数 bBeta均值(学习率, 动量率) { 返回 学习率 * 概率精度 / (学习率 + 动量率)
}

// Beta分布方差近似
函数 bBeta方差(学习率, 动量率) { 定义 和 = 学习率 + 动量率
 返回 学习率 * 动量率 * 概率精度 / (和 * 和 * (和 + 1))
}

// 信息熵
函数 概率_熵(概率列表) { 定义 n = 计数(概率列表)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < n) { 总和 = 总和 + 概率列表[i]
 i = i + 1 }
 如果 (总和 == 0) { 返回 0 }
 定义 可变 熵 = 0
 i = 0
 当 (i < n) { 如果 (概率列表[i] > 0) { 定义 p = 概率列表[i] * 概率精度 / 总和
 如果 (p > 0) {
 熵 = 熵 - p * 概率_log2(p) / 概率精度
 }
 }
 i = i + 1
 }
 返回 熵
}

// KL 散度
函数 概率_kl散度(p列表, q列表) { 定义 n = 计数(p列表)
 定义 可变 kl = 0
 定义 可变 i = 0
 当 (i < n) { 如果 (p列表[i] > 0 且 q列表[i] > 0) {
 kl = kl + p列表[i] * (概率_log2(p列表[i]) - 概率_log2(q列表[i])) / 概率精度
 }
 i = i + 1
 }
 返回 kl
}

// Fisher-Yates 洗牌
函数 概率_洗牌(列表, 状态) { 定义 n = 计数(列表)
 定义 可变 i = n - 1
 当 (i > 0) { 定义 j = rRng_下一个(状态) % (i + 1)
 定义 暂存 = 列表[i]
 列表[i] = 列表[j]
 列表[j] = 暂存
 i = i - 1
 }
}

// 无放回采样
函数 概率_无放回采样(列表, k, 状态) { 定义 n = 计数(列表)
 定义 可变 副本 = []
 定义 可变 i = 0
 当 (i < n) { 追加(副本, 列表[i])
 i = i + 1 }
 概率_洗牌(副本, 状态)
 定义 可变 结果 = []
 i = 0
 当 (i < k 且 i < n) {
 追加(结果, 副本[i])
 i = i + 1
 }
 返回 结果
}

// 内部工具
函数 概率_exp_neg(x) {
 // e^(-x/1000) * 1000 近似
 如果 (x <= 0) { 返回 概率精度 }
 定义 可变 结果 = 概率精度
 定义 可变 i = 0
 当 (i < x / 100) {
 结果 = 结果 * 905 / 概率精度
 i = i + 1
 }
 返回 结果
}

函数 概率_log2(x) {
    如果 (x <= 0) { 返回 0
}
 定义 可变 结果 = 0
 定义 可变 v = x
 当 (v < 500) { v = v * 2
 结果 = 结果 - 概率精度 }
 当 (v > 概率精度) { v = v / 2
 结果 = 结果 + 概率精度 }
 返回 结果
}

// 统计矩

函数 概率_均值(数据) { 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < 计数(数据)) {
 总和 = 总和 + 数据[i]
 i = i + 1
 }
 如果 (计数(数据) == 0) { 返回 0 }
 返回 总和 / 计数(数据)
}

函数 概率_方差(数据) { 定义 均 = 概率_均值(数据)
 定义 可变 总和 = 0
 定义 可变 i = 0
 当 (i < 计数(数据)) { 定义 差 = 数据[i] - 均
 总和 = 总和 + 差 * 差
 i = i + 1
 }
 如果 (计数(数据) == 0) { 返回 0 }
 返回 总和 / 计数(数据)
}

函数 概率_标准差(数据) { 返回 开方(概率_方差(数据))
}

函数 概率_中位数(数据) {
 // 简单冒泡排序后取中位
 定义 可变 排序 = []
 定义 可变 k = 0
 当 (k < 计数(数据)) { 追加(排序, 数据[k]) k = k + 1 }
 定义 可变 i = 0
 当 (i < 计数(排序)) { 定义 可变 j = 0
 当 (j < 计数(排序) - i - 1) { 如果 (排序[j] > 排序[j + 1]) { 定义 临 = 排序[j]
 排序[j] = 排序[j + 1]
 排序[j + 1] = 临
 }
 j = j + 1
 }
 i = i + 1
 }
 定义 n = 计数(排序)
 如果 (n % 2 == 1) { 返回 排序[n / 2] }
 返回 (排序[n / 2 - 1] + 排序[n / 2]) / 2
}

函数 概率_众数(数据) { 定义 可变 最多值 = 0
 定义 可变 最多次 = 0
 定义 可变 i = 0
 当 (i < 计数(数据)) { 定义 可变 次数 = 0
 定义 可变 j = 0
 当 (j < 计数(数据)) { 如果 (数据[j] == 数据[i]) { 次数 = 次数 + 1 }
 j = j + 1
 }
 如果 (次数 > 最多次) { 最多次 = 次数 最多值 = 数据[i] }
 i = i + 1
 }
 返回 最多值
}

定义 可变 _概率_采样数 = 0
定义 可变 _概率_分布拟合数 = 0

函数 概率_记录采样() { _概率_采样数 = _概率_采样数 + 1 }
函数 概率_记录拟合() { _概率_分布拟合数 = _概率_分布拟合数 + 1 }

函数 概率_重置() { _概率_采样数 = 0 _概率_分布拟合数 = 0 }

// Phase3反哺注入: 指数分布 [BugFix]
// 来源: Rust深度研究引擎 nova_deep_engine.rs
// 误差: 0.00% → 0.00%  提升: 0.0x
// 说明: 循环上限Bug: 循环上限硬编码: 当 (v < 500) { v = v * 2 → 用Q快速幂整数替换
// E9反哺修复: 删除循环上限, 改用Q快速幂整数(base,exp)
// 见在线学习.nova 函数 Q快速幂整数


导入("../基础.nova")
导入("../系统/内存池.nova")

// 获取对象 = "被"字借用 (对象被借出但不消费)
// 归还对象 = "给"字归还 (对象交回池中)
// 对象生命期 = 线性资源的借用周期
// 环形缓冲 = 水行循环 (写满后水从头覆盖)

// 对象池: [空闲列表, 活跃列表, 最大容量, 创建计数]
函数 对象池_对象池_创建(最大容量) { 返回 [[], [], 最大容量, 0]
}

函数 对象池_对象池_获取(池) { 定义 空闲 = 池[0]
 如果 (计数(空闲) > 0) { 定义 对象 = 空闲[计数(空闲) - 1]
 删除(空闲, 计数(空闲) - 1)
 追加(池[1], 对象)
 返回 对象
 }
 如果 (池[3] < 池[2]) { 定义 对象 = [池[3], 0, 空]
 池[3] = 池[3] + 1
 追加(池[1], 对象)
 返回 对象
 }
 返回 空
}

函数 对象池_对象池_归还(池, 对象) { 定义 活跃 = 池[1]
 定义 可变 i = 0
 当 (i < 计数(活跃)) { 如果 (活跃[i] == 对象) {
 删除(活跃, i)
 追加(池[0], 对象)
 返回 1
 }
 i = i + 1
 }
 返回 0
}

函数 对象池_空闲数(池) { 返回 计数(池[0]) }
函数 对象池_活跃数(池) { 返回 计数(池[1]) }
函数 对象池_总数(池) { 返回 池[3] }

// 环形缓冲区

函数 对象池_环形_创建(容量) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(数据, 0) i = i + 1 }
 返回 [数据, 容量, 0, 0]
}

函数 对象池_环形_写入(缓冲, 值) {
    如果 (缓冲[4] >= 缓冲[1]) { 返回 0
}
 缓冲[0][缓冲[3]] = 值
 缓冲[3] = (缓冲[3] + 1) % 缓冲[1]
 缓冲[4] = 缓冲[4] + 1
 返回 1
}

函数 池_环形_读取(缓冲) {
    如果 (缓冲[4] == 0) { 返回 空
}
 定义 值 = 缓冲[0][缓冲[2]]
 缓冲[2] = (缓冲[2] + 1) % 缓冲[1]
 缓冲[4] = 缓冲[4] - 1
 返回 值
}

函数 对象池_环形_大小(缓冲) { 返回 缓冲[4] }
函数 对象池_环形_容量(缓冲) { 返回 缓冲[1] }
函数 对象池_环形_空(缓冲) { 返回 缓冲[4] == 0 }
函数 对象池_环形_满(缓冲) { 返回 缓冲[4] >= 缓冲[1] }
函数 对象池_环形_查看(缓冲) {
    如果 (缓冲[4] == 0) { 返回 空
}
 返回 缓冲[0][缓冲[2]]
}
函数 环形_清空(缓冲) { 缓冲[2] = 0 缓冲[3] = 0 缓冲[4] = 0 }

// 带统计的对象池
// 跟踪获取/归还频率、平均借用时间、高峰使用数
函数 统计池_创建(最大容量) { 返回 [
 [], // [0] 空闲列表
 [], // [1] 活跃列表
 最大容量, // [2] 最大容量
 0, // [3] 创建计数
 0, // [4] 总获取次数
 0, // [5] 总归还次数
 0, // [6] 高峰活跃数
 0, // [7] 总等待失败次数
 0 // [8] 当前时间戳
 ]
}

函数 统计池_获取(池) {
 池[4] = 池[4] + 1
 定义 空闲 = 池[0]
 如果 (计数(空闲) > 0) { 定义 对象 = 空闲[计数(空闲) - 1]
 删除(空闲, 计数(空闲) - 1)
 对象[1] = 池[8] // 记录借出时间
 追加(池[1], 对象)
 // 更新高峰
 如果 (计数(池[1]) > 池[6]) { 池[6] = 计数(池[1]) }
 返回 对象
 }
 如果 (池[3] < 池[2]) { 定义 对象 = [池[3], 池[8], 空]
 池[3] = 池[3] + 1
 追加(池[1], 对象)
 如果 (计数(池[1]) > 池[6]) { 池[6] = 计数(池[1]) }
 返回 对象
 }
 池[7] = 池[7] + 1
 返回 空
}

函数 统计池_归还(池, 对象) {
 池[5] = 池[5] + 1
 定义 活跃 = 池[1]
 定义 可变 i = 0
 当 (i < 计数(活跃)) { 如果 (活跃[i][0] == 对象[0]) {
 删除(活跃, i)
 对象[1] = 0 // 清除借出时间
 追加(池[0], 对象)
 返回 1
 }
 i = i + 1
 }
 返回 0
}

函数 统计池_报告(池) { 返回 [
 池[3], // 总创建数
 计数(池[0]), // 当前空闲
 计数(池[1]), // 当前活跃
 池[4], // 总获取次数
 池[5], // 总归还次数
 池[6], // 高峰活跃
 池[7], // 获取失败次数
 池[4] - 池[5] // 未归还 (潜在泄漏)
 ]
}

函数 统计池_推进时间(池) {
 池[8] = 池[8] + 1
}

// 分层对象池 (Tiered Pool)
// 小/中/大 三级池, 按对象大小自动选择
函数 分层池_创建(小容量, 中容量, 大容量) { 返回 [
 对象池_对象池_创建(小容量), // [0] 小对象池
 对象池_对象池_创建(中容量), // [1] 中对象池
 对象池_对象池_创建(大容量), // [2] 大对象池
 64, // [3] 小/中分界线
 256 // [4] 中/大分界线
 ]
}

函数 分层池_获取(池, 大小) { 如果 (大小 <= 池[3]) { 返回 [0, 对象池_对象池_获取(池[0])]
 }
 如果 (大小 <= 池[4]) { 返回 [1, 对象池_对象池_获取(池[1])]
 }
 返回 [2, 对象池_对象池_获取(池[2])]
}

函数 分层池_归还(池, 层级, 对象) {
    如果 (层级 == 0) { 返回 对象池_对象池_归还(池[0], 对象)
}
 如果 (层级 == 1) { 返回 对象池_对象池_归还(池[1], 对象) }
 返回 对象池_对象池_归还(池[2], 对象)
}

// 线程安全环形缓冲 (SPSC无锁)
// Single-Producer Single-Consumer: 无需锁
函数 SPSC_创建(容量) { 定义 可变 数据 = []
 定义 可变 i = 0
 当 (i < 容量) { 追加(数据, 0) i = i + 1 }
 返回 [
 数据, // [0] 数据
 容量, // [1] 容量
 0, // [2] 写位置 (只有生产者修改)
 0, // [3] 读位置 (只有消费者修改)
 0, // [4] 写入总数
 0 // [5] 读取总数
 ]
}

函数 SPSC_写入(缓冲, 值) { 定义 下一写 = (缓冲[2] + 1) % 缓冲[1]
 如果 (下一写 == 缓冲[3]) { 返回 0 } // 满
 缓冲[0][缓冲[2]] = 值
 缓冲[2] = 下一写
 缓冲[4] = 缓冲[4] + 1
 返回 1
}

函数 SPSC_读取(缓冲) { 如果 (缓冲[3] == 缓冲[2]) { 返回 空 } // 空
 定义 值 = 缓冲[0][缓冲[3]]
 缓冲[3] = (缓冲[3] + 1) % 缓冲[1]
 缓冲[5] = 缓冲[5] + 1
 返回 值
}

函数 SPSC_可写(缓冲) { 返回 ((缓冲[2] + 1) % 缓冲[1]) != 缓冲[3]
}

函数 SPSC_可读(缓冲) { 返回 缓冲[3] != 缓冲[2]
}

函数 SPSC_吞吐量(缓冲) { 返回 [缓冲[4], 缓冲[5]] // [写入总数, 读取总数]
}

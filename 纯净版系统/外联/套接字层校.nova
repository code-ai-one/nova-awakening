//   1. Nova协议规范 1071 互联网校验和: 16位反码求和
//   2. csum_partial: 累计部分校验和(不取反, 可链式调用)
//   3. csum_fold: 折叠32位→16位并取反 = 最终校验和
//   4. IP伪头校验和: 传控/数报需要包含src/dst IP的伪头
//   5. 增量更新: 修改单个字段时不用重算整个包(Nova协议规范 1624)

// csum_partial: 累计部分校验和 
// 返回32位累计和(未折叠, 未取反)

函数 csum_partial(数据, 长度, 初始和) {
    定义 可变 和 = 初始和
    定义 可变 i = 0

    // 按16位(2字节)累加
    当 (i + 1 < 长度) {
        和 = 和 + (缓冲读(数据, i) << 8) + 缓冲读(数据, i + 1)
        i = i + 2
    }

    // 奇数长度: 最后一个字节补零
    如果 (i < 长度) {
        和 = 和 + (缓冲读(数据, i) << 8)
    }

    返回 和
}

// csum_fold: 折叠32位→16位并取反 = 最终校验和

函数 csum_fold(和) {
    // 将进位加回低16位
    当 (和 > 0xFFFF) {
        和 = (和 & 0xFFFF) + (和 >> 16)
    }
    返回 ~和 & 0xFFFF
}

// 完整校验和 = csum_partial + csum_fold

函数 校验和_计算(数据, 长度) {
    返回 csum_fold(csum_partial(数据, 长度, 0))
}

// IP头校验和 
// IP头固定20字节(无选项), 校验和字段填0后计算

函数 ip_校验和(ip头, 头长度) {
    返回 校验和_计算(ip头, 头长度)
}

// 传控/数报伪头校验和 
// 伪头: 源IP(4) + 目的IP(4) + 零(1) + 协议(1) + 长度(2)

函数 伪头校验和(源IP, 目的IP, 协议, 长度) {
    定义 可变 和 = 0

    // 源IP (4字节, 按16位累加)
    和 = 和 + ((源IP >> 16) & 0xFFFF)
    和 = 和 + (源IP & 0xFFFF)

    // 目的IP
    和 = 和 + ((目的IP >> 16) & 0xFFFF)
    和 = 和 + (目的IP & 0xFFFF)

    // 协议 + 长度
    和 = 和 + 协议
    和 = 和 + 长度

    返回 和
}

函数 tcp_校验和(源IP, 目的IP, tcp数据, tcp长度) {
    定义 伪和 = 伪头校验和(源IP, 目的IP, 6, tcp长度)  // 6=传控
    定义 数据和 = csum_partial(tcp数据, tcp长度, 伪和)
    返回 csum_fold(数据和)
}

函数 udp_校验和(源IP, 目的IP, udp数据, udp长度) {
    定义 伪和 = 伪头校验和(源IP, 目的IP, 17, udp长度)  // 17=数报
    定义 数据和 = csum_partial(udp数据, udp长度, 伪和)
    定义 结果 = csum_fold(数据和)
    // 数报校验和为0时用0xFFFF替代(Nova协议规范 768)
    如果 (结果 == 0) { 结果 = 0xFFFF }
    返回 结果
}

// 增量校验和更新 
// Nova协议规范 1624: 修改单个字段时, 不用重算整个包

函数 校验和_增量更新16(旧校验和, 旧值16, 新值16) {
    // HC' = ~(~HC + ~m + m')
    定义 可变 和 = (~旧校验和 & 0xFFFF) + (~旧值16 & 0xFFFF) + 新值16
    当 (和 > 0xFFFF) { 和 = (和 & 0xFFFF) + (和 >> 16) }
    返回 ~和 & 0xFFFF
}

函数 校验和_增量更新32(旧校验和, 旧值32, 新值32) {
    定义 中间 = 校验和_增量更新16(旧校验和, (旧值32 >> 16) & 0xFFFF, (新值32 >> 16) & 0xFFFF)
    返回 校验和_增量更新16(中间, 旧值32 & 0xFFFF, 新值32 & 0xFFFF)
}

// 校验和验证 

函数 校验和_验证(数据, 长度) {
    // 正确的校验和: 对整个数据(含校验和字段)求和 = 0
    返回 校验和_计算(数据, 长度) == 0
}

函数 ip_校验和_验证(ip头, 头长度) {
    返回 校验和_验证(ip头, 头长度)
}

// csum_partial优化版 (32位累加, 减少折叠次数)

函数 csum_partial_快速(数据, 长度, 初始和) {
    定义 可变 和 = 初始和
    定义 可变 i = 0

    // 按32位(4字节)累加(减少循环次数)
    当 (i + 3 < 长度) {
        定义 word = (缓冲读(数据, i) << 24) | (缓冲读(数据, i+1) << 16) |
                     (缓冲读(数据, i+2) << 8) | 缓冲读(数据, i+3)
        和 = 和 + ((word >> 16) & 0xFFFF)
        和 = 和 + (word & 0xFFFF)
        i = i + 4
    }

    // 处理剩余字节
    当 (i + 1 < 长度) {
        和 = 和 + (缓冲读(数据, i) << 8) + 缓冲读(数据, i + 1)
        i = i + 2
    }
    如果 (i < 长度) {
        和 = 和 + (缓冲读(数据, i) << 8)
    }

    返回 和
}

// 校验和拷贝 
// 在数据拷贝的同时计算校验和(避免两次遍历)

函数 csum_and_copy(源, 目标, 长度, 初始和) {
    定义 可变 和 = 初始和
    定义 可变 i = 0

    当 (i + 1 < 长度) {
        定义 高 = 缓冲读(源, i)
        定义 低 = 缓冲读(源, i + 1)
        缓冲写(目标, i, 高)
        缓冲写(目标, i + 1, 低)
        和 = 和 + (高 << 8) + 低
        i = i + 2
    }
    如果 (i < 长度) {
        定义 字节 = 缓冲读(源, i)
        缓冲写(目标, i, 字节)
        和 = 和 + (字节 << 8)
    }

    返回 和
}

// ICMP校验和 

函数 icmp_校验和(icmp数据, icmp长度) {
    返回 校验和_计算(icmp数据, icmp长度)
}

// 校验和差异 

函数 csum_add(和1, 和2) {
    定义 可变 结果 = 和1 + 和2
    当 (结果 > 0xFFFF) { 结果 = (结果 & 0xFFFF) + (结果 >> 16) }
    返回 结果
}

函数 csum_sub(和, 减量) {
    返回 csum_add(和, ~减量 & 0xFFFF)
}

// 校验和填充 (将校验和写入包头)

函数 校验和_填充IP头(ip头, 头长度) {
    // 先清零校验和字段(偏移10-11)
    缓冲写(ip头, 10, 0)
    缓冲写(ip头, 11, 0)
    // 计算校验和
    定义 cksum = 校验和_计算(ip头, 头长度)
    // 写入校验和字段
    缓冲写(ip头, 10, (cksum >> 8) & 0xFF)
    缓冲写(ip头, 11, cksum & 0xFF)
}

// 协议号名称 + 统计

定义 可变 校验和_计算次数 = 0
定义 可变 校验和_验证次数 = 0

函数 协议号名(协议) {
    如果 (协议 == 6) { 返回 "传控" }
    如果 (协议 == 17) { 返回 "数报" }
    如果 (协议 == 1) { 返回 "ICMP" }
    返回 "Proto" + 整数转字符串(协议)
}

函数 校验和_统计() {
    返回 [校验和_计算次数, 校验和_验证次数]
}


函数 校验和_完整统计() {
    返回 [校验和_计算次数, 校验和_验证次数]
}

定义 可变 AI_套接字层校_带宽估计 = 0
定义 可变 AI_套接字层校_丢包窗口 = []

函数 AI_套接字层校_带宽预测(发送字节, 耗时毫秒) {
    如果 (耗时毫秒 == 0) { 返回 AI_套接字层校_带宽估计 }
    定义 当前 = 发送字节 * 1000 / 耗时毫秒
    AI_套接字层校_带宽估计 = AI_套接字层校_带宽估计 * 700 / 1000 + 当前 * 300 / 1000
    返回 AI_套接字层校_带宽估计
}

函数 AI_套接字层校_拥塞建议(丢包率) {
    追加(AI_套接字层校_丢包窗口, 丢包率)
    如果 (计数(AI_套接字层校_丢包窗口) > 10) { 列表_移除(AI_套接字层校_丢包窗口, 0) }
    如果 (丢包率 > 50) { 返回 "减半窗口" }
    如果 (丢包率 < 5) { 返回 "增大窗口" }
    返回 "保持"
}

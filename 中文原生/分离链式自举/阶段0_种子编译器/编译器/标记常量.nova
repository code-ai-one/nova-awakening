定义 字符_等号 = 61
定义 字符_大于号 = 62
定义 字符_问号 = 63
定义 字符_左方括 = 91
定义 字符_反斜杠 = 92
定义 字符_右方括 = 93
定义 字符_异或号 = 94
定义 字符_大写A = 65
定义 字符_大写B = 66
定义 字符_大写F = 70
定义 字符_大写O = 79
定义 字符_大写X = 88
定义 字符_大写Z = 90
定义 字符_小写a = 97
定义 字符_小写b = 98

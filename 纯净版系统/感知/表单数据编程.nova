// §4 FormData — 编程式表单数据

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../执行/控制台输出.nova")
导入("../中枢/整数转字符串.nova")
导入("../中枢/辅助存根.nova")

结构 FormDataEntry {
    名称,
    值,    // u64 字符串值
    文件,    // u64 File* (可空)
    文件名,    // u64 filename (可空)
}

结构 FormData {
    条目,    // [256]FormDataEntry
    数量,
}

函数 FormData_创建(form) {
    定义 fd = 堆_分配(FormData)
    fd.数量 = 0

    如果 (form != 0) {
        // 从HTMLForm收集
        定义 可变 i = 0
        当 (i < form.控件数) {
            定义 控件 = form.控件[i]
            如果 (控件 != 0 && 控件.名称 != 0 && !控件.是禁用) {
                // 跳过未选中的checkbox/radio
                如果 ((控件.类型 == 输入类型_checkbox || 控件.类型 == 输入类型_radio) && !控件.是选中) {
                    i = i + 1; 继续
                }
                FormData_append(fd, 控件.名称, 控件.值)
            }
            i = i + 1
        }
    }
    返回 fd
}

函数 FormData_append(fd, 名称, 值) {
    如果 (fd == 0 || fd.数量 >= 256) { 返回 }
    fd.条目[fd.数量].名称 = 名称
    fd.条目[fd.数量].值 = 值
    fd.条目[fd.数量].文件 = 0
    fd.数量 = fd.数量 + 1
}

函数 FormData_appendFile(fd, 名称, 文件, 文件名) {
    如果 (fd == 0 || fd.数量 >= 256) { 返回 }
    fd.条目[fd.数量].名称 = 名称
    fd.条目[fd.数量].值 = 0
    fd.条目[fd.数量].文件 = 文件
    fd.条目[fd.数量].文件名 = 文件名
    fd.数量 = fd.数量 + 1
}

函数 FormData_get(fd, 名称) {
    如果 (fd == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < fd.数量) {
        如果 (字符串_相等(fd.条目[i].名称, 名称)) { 返回 fd.条目[i].值 }
        i = i + 1
    }
    返回 0
}

函数 FormData_set(fd, 名称, 值) {
    如果 (fd == 0) { 返回 }
    定义 可变 i = 0
    当 (i < fd.数量) {
        如果 (字符串_相等(fd.条目[i].名称, 名称)) {
            fd.条目[i].值 = 值; 返回
        }
        i = i + 1
    }
    FormData_append(fd, 名称, 值)
}

函数 FormData_delete(fd, 名称) {
    如果 (fd == 0) { 返回 }
    定义 可变 i = 0
    当 (i < fd.数量) {
        如果 (字符串_相等(fd.条目[i].名称, 名称)) {
            fd.数量 = fd.数量 - 1
            fd.条目[i] = fd.条目[fd.数量]
            返回
        }
        i = i + 1
    }
}

函数 FormData_has(fd, 名称) { 返回 FormData_get(fd, 名称) != 0 }

// §5 表单编码

// application/x-www-form-urlencoded
函数 FormData_编码_urlencoded(fd) {
    如果 (fd == 0 || fd.数量 == 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < fd.数量) {
        如果 (i > 0) { 结果 = 字符串拼接(结果, "&") }
        结果 = 字符串拼接(结果, URL_百分比编码(fd.条目[i].名称, 0))
        结果 = 字符串拼接(结果, "=")
        如果 (fd.条目[i].值 != 0) {
            结果 = 字符串拼接(结果, URL_百分比编码(fd.条目[i].值, 0))
        }
        i = i + 1
    }
    返回 结果
}

// multipart/form-data
函数 FormData_编码_multipart(fd, 边界) {
    如果 (fd == 0 || fd.数量 == 0) { 返回 "" }
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < fd.数量) {
        结果 = 字符串拼接(结果, "--")
        结果 = 字符串拼接(结果, 边界)
        结果 = 字符串拼接(结果, "\r\n")
        结果 = 字符串拼接(结果, "Content-Disposition: form-data; name=\"")
        结果 = 字符串拼接(结果, fd.条目[i].名称)
        结果 = 字符串拼接(结果, "\"")
        如果 (fd.条目[i].文件名 != 0) {
            结果 = 字符串拼接(结果, "; filename=\"")
            结果 = 字符串拼接(结果, fd.条目[i].文件名)
            结果 = 字符串拼接(结果, "\"")
        }
        结果 = 字符串拼接(结果, "\r\n\r\n")
        如果 (fd.条目[i].值 != 0) {
            结果 = 字符串拼接(结果, fd.条目[i].值)
        }
        结果 = 字符串拼接(结果, "\r\n")
        i = i + 1
    }
    结果 = 字符串拼接(结果, "--")
    结果 = 字符串拼接(结果, 边界)
    结果 = 字符串拼接(结果, "--\r\n")
    返回 结果
}

// §6 FormData迭代与高级操作

函数 FormData_getAll(fd, 名称) {
    定义 可变 结果 = []
    如果 (fd == 0) { 返回 结果 }
    定义 可变 i = 0
    当 (i < fd.数量) {
        如果 (字符串_相等(fd.条目[i].名称, 名称)) {
            追加(结果, fd.条目[i].值)
        }
        i = i + 1
    }
    返回 结果
}

函数 FormData_keys(fd) {
    定义 可变 结果 = []
    如果 (fd == 0) { 返回 结果 }
    定义 可变 i = 0
    当 (i < fd.数量) {
        追加(结果, fd.条目[i].名称)
        i = i + 1
    }
    返回 结果
}

函数 FormData_values(fd) {
    定义 可变 结果 = []
    如果 (fd == 0) { 返回 结果 }
    定义 可变 i = 0
    当 (i < fd.数量) {
        追加(结果, fd.条目[i].值)
        i = i + 1
    }
    返回 结果
}

函数 FormData_entries(fd) {
    定义 可变 结果 = []
    如果 (fd == 0) { 返回 结果 }
    定义 可变 i = 0
    当 (i < fd.数量) {
        追加(结果, [fd.条目[i].名称, fd.条目[i].值])
        i = i + 1
    }
    返回 结果
}

函数 FormData_forEach(fd, 回调) {
    如果 (fd == 0 || 回调 == 0) { 返回 }
    定义 可变 i = 0
    当 (i < fd.数量) {
        回调(fd.条目[i].值, fd.条目[i].名称, fd)
        i = i + 1
    }
}

函数 FormData_数量(fd) {
    如果 (fd == 0) { 返回 0 }
    返回 fd.数量
}

函数 FormData_清空(fd) {
    如果 (fd == 0) { 返回 }
    fd.数量 = 0
}

函数 FormData_克隆(fd) {
    如果 (fd == 0) { 返回 0 }
    定义 新fd = 堆_分配(FormData)
    新fd.数量 = 0
    定义 可变 i = 0
    当 (i < fd.数量) {
        FormData_append(新fd, fd.条目[i].名称, fd.条目[i].值)
        i = i + 1
    }
    返回 新fd
}

// §7 URL百分比编码

函数 URL_百分比编码(文本, 保留空格) {
    如果 (文本 == 0) { 返回 "" }
    定义 长度 = 字节长度(文本)
    定义 可变 部件 = []
    定义 可变 i = 0
    当 (i < 长度) {
        定义 ch = 字节取(文本, i)
        如果 ((ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122) || (ch >= 48 && ch <= 57) ||
            ch == 45 || ch == 95 || ch == 46 || ch == 126) {
            追加(部件, 字符从码(ch))
        } 否则 如果 (ch == 32) {
            如果 (保留空格) { 追加(部件, "+" })
            否则 { 追加(部件, "%20" })
        } 否则 {
            追加(部件, "%" + 十六进制_2位(ch))
        }
        i = i + 1
    }
    返回 字符串_连接列表(部件, "")
}

函数 URL_百分比解码(文本) {
    如果 (文本 == 0) { 返回 "" }
    定义 长度 = 字节长度(文本)
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 长度) {
        定义 ch = 字节取(文本, i)
        如果 (ch == 37 && i + 2 < 长度) {
            定义 高 = 十六进制字符值(字节取(文本, i + 1))
            定义 低 = 十六进制字符值(字节取(文本, i + 2))
            结果 = 结果 + 字符从码(高 * 16 + 低)
            i = i + 3
        } 否则 如果 (ch == 43) {
            结果 = 结果 + " "
            i = i + 1
        } 否则 {
            结果 = 结果 + 字符从码(ch)
            i = i + 1
        }
    }
    返回 结果
}

函数 十六进制_2位(值) {
    定义 高 = 值 / 16
    定义 低 = 值 % 16
    返回 字符从码(十六进制字符(高)) + 字符从码(十六进制字符(低))
}

函数 十六进制字符(n) {
    如果 (n < 10) { 返回 48 + n }
    返回 65 + n - 10
}

函数 十六进制字符值(ch) {
    如果 (ch >= 48 && ch <= 57) { 返回 ch - 48 }
    如果 (ch >= 65 && ch <= 70) { 返回 ch - 55 }
    如果 (ch >= 97 && ch <= 102) { 返回 ch - 87 }
    返回 0
}

函数 字符从码(码) {
    定义 buf = 堆_分配(2)
    内存_写8(buf, 码)
    内存_写8(buf + 1, 0)
    返回 buf
}

// §8 URLSearchParams解析

函数 URLSearchParams_解析(查询字符串) {
    如果 (查询字符串 == 0) { 返回 FormData_创建(0) }
    定义 fd = 堆_分配(FormData)
    fd.数量 = 0
    定义 长度 = 字节长度(查询字符串)
    定义 可变 位置 = 0
    如果 (长度 > 0 && 字节取(查询字符串, 0) == 63) { 位置 = 1 }
    当 (位置 < 长度) {
        定义 键开始 = 位置
        当 (位置 < 长度 && 字节取(查询字符串, 位置) != 61 && 字节取(查询字符串, 位置) != 38) {
            位置 = 位置 + 1
        }
        定义 键 = URL_百分比解码(字符串_子串(查询字符串, 键开始, 位置 - 键开始))
        定义 可变 值 = ""
        如果 (位置 < 长度 && 字节取(查询字符串, 位置) == 61) {
            位置 = 位置 + 1
            定义 值开始 = 位置
            当 (位置 < 长度 && 字节取(查询字符串, 位置) != 38) { 位置 = 位置 + 1 }
            值 = URL_百分比解码(字符串_子串(查询字符串, 值开始, 位置 - 值开始))
        }
        FormData_append(fd, 键, 值)
        如果 (位置 < 长度) { 位置 = 位置 + 1 }
    }
    返回 fd
}

函数 URLSearchParams_序列化(fd) {
    返回 FormData_编码_urlencoded(fd)
}

// §9 输入类型常量

定义 输入类型_text = 0
定义 输入类型_password = 1
定义 输入类型_checkbox = 2
定义 输入类型_radio = 3
定义 输入类型_file = 4
定义 输入类型_hidden = 5
定义 输入类型_submit = 6
定义 输入类型_select = 7
定义 输入类型_textarea = 8

// §10 边界生成

定义 可变 边界_计数器 = 0

函数 FormData_生成边界() {
    边界_计数器 = 边界_计数器 + 1
    返回 "----NovaFormBoundary" + 整数转字符串(边界_计数器)
}

// §11 FormData统计与健康检查

定义 可变 FormData_创建总数 = 0
定义 可变 FormData_追加总数 = 0
定义 可变 FormData_编码总数 = 0

函数 FormData_统计() {
    返回 {
        创建: FormData_创建总数,
        追加: FormData_追加总数,
        编码: FormData_编码总数,
    }
}

函数 FormData_健康检查() {
    返回 "FormData子系统健康"
}

函数 FormData_重置统计() {
    FormData_创建总数 = 0
    FormData_追加总数 = 0
    FormData_编码总数 = 0
}

函数 FormData_完整统计() {
    返回 [FormData_创建总数, FormData_追加总数, FormData_编码总数]
}

函数 FormData_诊断(fd) {
    如果 (fd == 0) { 返回 "FormData为空" }
    返回 {
        条目数: fd.数量,
        键列表: FormData_keys(fd),
    }
}

定义 可变 AI_表单数据编_热点函数 = []

函数 AI_表单数据编_JIT候选(函数名, 调用次数) {
    如果 (调用次数 > 100) {
        追加(AI_表单数据编_热点函数, 函数名)
        返回 真
    }
    返回 假
}

函数 AI_表单数据编_内联建议(函数体大小, 调用次数) {
    如果 (函数体大小 < 30 && 调用次数 > 50) { 返回 "内联" }
    返回 "不内联"
}

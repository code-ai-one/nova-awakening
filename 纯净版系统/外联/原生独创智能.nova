导入("../中枢/错误码.nova")
导入("../中枢/同步原语.nova")
导入("../感知/内核直连层.nova")
导入("../感知/原子驻留.nova")
导入("../推理/值乘.nova")

定义 AI预取_链接悬停     = 1     // 用户悬停在链接上
定义 AI预取_滚动方向     = 2     // 用户即将滚动到的区域
定义 AI预取_历史模式     = 3     // 基于历史浏览模式
定义 AI预取_语义关联     = 4     // 基于页面语义关联

定义 预取状态_等待       = 0
定义 预取状态_加载中     = 1
定义 预取状态_完成       = 2
定义 预取状态_失败       = 3

结构 AI预取条目 {
    URL,    // u64 预取的URL
    URL哈希,    // u32 URL哈希(快速查重)
    类型,    // u32 AI预取_xxx
    置信度,    // u32 0-10000 预取必要性
    状态,    // u32 预取状态_xxx
    优先级,    // u32 流优先级(0-255)
    创建时间,    // u64 创建时间戳
}

结构 AI预取引擎 {
    预取列表,    // u64 AI预取条目*数组
    预取数量,
    预取容量,
    历史URL表,    // u64 最近访问的URL历史
    历史数量,
    网络带宽估计,    // u32 当前带宽估计(KB/s)
    预取命中率,    // u32 历史预取命中率(0-10000)
    总预取次数,
    总命中次数,
}

函数 AI预取_创建引擎() {
    定义 e = 堆_分配(AI预取引擎)
    e.预取容量 = 32
    e.预取列表 = 堆_分配_数组(e.预取容量 * 40)
    e.预取数量 = 0
    e.历史URL表 = 堆_分配_数组(64 * 8)
    e.历史数量 = 0
    e.网络带宽估计 = 1000   // 默认1MB/s
    e.预取命中率 = 0
    e.总预取次数 = 0
    e.总命中次数 = 0
    返回 e
}

函数 AI预取_链接悬停(引擎, 链接URL) {
    如果 (引擎 == 0 || 链接URL == 0) { 返回 }

    定义 url哈希 = 字符串_哈希(链接URL)
    // 检查是否已预取
    如果 (AI预取_已存在(引擎, url哈希)) { 返回 }

    // 添加预取条目(置信度中等,因为用户可能只是经过)
    AI预取_添加(引擎, 链接URL, url哈希, AI预取_链接悬停, 6000, 128)
}

函数 AI预取_滚动方向(引擎, 资源URL列表, 数量) {
    如果 (引擎 == 0) { 返回 }

    定义 可变 i = 0
    当 (i < 数量 && i < 8) {    // 最多预取8个
        定义 url = 内存_读64(资源URL列表 + i * 8)
        如果 (url != 0) {
            定义 h = 字符串_哈希(url)
            如果 (!AI预取_已存在(引擎, h)) {
                AI预取_添加(引擎, url, h, AI预取_滚动方向, 7500, 160)
            }
        }
        i = i + 1
    }
}

函数 AI预取_记录访问(引擎, 当前URL) {
    如果 (引擎 == 0 || 当前URL == 0) { 返回 }
    // 记录到历史表
    如果 (引擎.历史数量 < 64) {
        内存_写64(引擎.历史URL表 + 引擎.历史数量 * 8, 当前URL)
        引擎.历史数量 = 引擎.历史数量 + 1
    }
}

函数 AI预取_更新带宽(引擎, 实测带宽) {
    如果 (引擎 == 0) { 返回 }
    引擎.网络带宽估计 = 实测带宽
}

函数 AI预取_最大并发(引擎) {
    如果 (引擎 == 0) { 返回 2 }
    // 根据带宽调整预取并发数
    如果 (引擎.网络带宽估计 > 5000) { 返回 6 }    // 5MB/s+: 激进预取
    如果 (引擎.网络带宽估计 > 1000) { 返回 4 }    // 1MB/s+: 标准
    如果 (引擎.网络带宽估计 > 200) { 返回 2 }     // 200KB/s+: 保守
    返回 1    // 低带宽: 最小预取
}

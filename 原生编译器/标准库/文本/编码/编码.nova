导入("../../基础.nova")

// Nova标准库 - 字符编码
// 纯 UTF-8 / Base64 / Hex / URL 编解码基础实现

定义 BASE64_表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
定义 HEX_表 = "0123456789abcdef"


函数 utf8_编码(码点) {
    如果 (码点 < 0) {
        返回 []
    }
    如果 (码点 <= 127) {
        返回 [码点]
    }
    如果 (码点 <= 2047) {
        返回 [
            192 + 码点 / 64,
            128 + 码点 % 64
        ]
    }
    如果 (码点 <= 65535) {
        如果 (码点 >= 55296) {
            如果 (码点 <= 57343) {
                返回 [239, 191, 189]
            }
        }
        返回 [
            224 + 码点 / 4096,
            128 + (码点 / 64) % 64,
            128 + 码点 % 64
        ]
    }
    如果 (码点 <= 1114111) {
        返回 [
            240 + 码点 / 262144,
            128 + (码点 / 4096) % 64,
            128 + (码点 / 64) % 64,
            128 + 码点 % 64
        ]
    }
    返回 [239, 191, 189]
}

函数 utf8_是续字节(字节) {
    定义 头 = 字节 / 64
    如果 (头 == 2) {
        返回 真
    }
    返回 假
}

函数 url_是安全字符(c) {
    如果 (c >= 字符_大写A) {
        如果 (c <= 字符_大写Z) { 返回 真 }
    }
    如果 (c >= 字符_小写a) {
        如果 (c <= 字符_小写z) { 返回 真 }
    }
    如果 (c >= 字符_零) {
        如果 (c <= 字符_九) { 返回 真 }
    }
    如果 (c == 字符_减号) { 返回 真 }
    如果 (c == 字符_下划线) { 返回 真 }
    如果 (c == 字符_句点) { 返回 真 }
    如果 (c == 126) { 返回 真 }
    返回 假
}

函数 utf8_解码(字节列表, 起始位置) {
    如果 (起始位置 >= 计数(字节列表)) {
        返回 [-1, 0]
    }

    定义 b0 = 字节列表[起始位置]
    如果 (b0 < 128) {
        返回 [b0, 1]
    }

    如果 (b0 >= 192 且 b0 < 224) {
        如果 (起始位置 + 1 >= 计数(字节列表)) {
            返回 [-1, 1]
        }
        定义 b1 = 字节列表[起始位置 + 1]
        如果 (utf8_是续字节(b1) == 假) {
            返回 [-1, 1]
        }
        定义 码点 = (b0 - 192) * 64 + (b1 - 128)
        如果 (码点 < 128) {
            返回 [-1, 2]
        }
        返回 [码点, 2]
    }

    如果 (b0 >= 224 且 b0 < 240) {
        如果 (起始位置 + 2 >= 计数(字节列表)) {
            返回 [-1, 1]
        }
        定义 b1 = 字节列表[起始位置 + 1]
        定义 b2 = 字节列表[起始位置 + 2]
        如果 (utf8_是续字节(b1) == 假) {
            返回 [-1, 1]
        }
        如果 (utf8_是续字节(b2) == 假) {
            返回 [-1, 1]
        }
        定义 码点 = (b0 - 224) * 4096 + (b1 - 128) * 64 + (b2 - 128)
        如果 (码点 < 2048) {
            返回 [-1, 3]
        }
        如果 (码点 >= 55296) {
            如果 (码点 <= 57343) {
                返回 [-1, 3]
            }
        }
        返回 [码点, 3]
    }

    如果 (b0 >= 240 且 b0 < 248) {
        如果 (起始位置 + 3 >= 计数(字节列表)) {
            返回 [-1, 1]
        }
        定义 b1 = 字节列表[起始位置 + 1]
        定义 b2 = 字节列表[起始位置 + 2]
        定义 b3 = 字节列表[起始位置 + 3]
        如果 (utf8_是续字节(b1) == 假) {
            返回 [-1, 1]
        }
        如果 (utf8_是续字节(b2) == 假) {
            返回 [-1, 1]
        }
        如果 (utf8_是续字节(b3) == 假) {
            返回 [-1, 1]
        }
        定义 码点 = (b0 - 240) * 262144 + (b1 - 128) * 4096 + (b2 - 128) * 64 + (b3 - 128)
        如果 (码点 < 65536) {
            返回 [-1, 4]
        }
        如果 (码点 > 1114111) {
            返回 [-1, 4]
        }
        返回 [码点, 4]
    }

    返回 [-1, 1]
}

函数 utf8_字符串到字节(文本) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        定义 码点 = 编码(子串(文本, i, 1))
        定义 字节 = utf8_编码(码点)
        定义 可变 j = 0
        当 (j < 计数(字节)) {
            追加(结果, 字节[j])
            j = j + 1
        }
        i = i + 1
    }
    返回 结果
}

函数 utf8_字节到码点列表(字节列表) {
    定义 可变 结果 = []
    定义 可变 位置 = 0
    当 (位置 < 计数(字节列表)) {
        定义 项 = utf8_解码(字节列表, 位置)
        如果 (项[0] >= 0) {
            追加(结果, 项[0])
        } 否则 {
            追加(结果, 65533)
        }
        如果 (项[1] <= 0) {
            位置 = 位置 + 1
        } 否则 {
            位置 = 位置 + 项[1]
        }
    }
    返回 结果
}

函数 utf8_字节长度(码点) {
    如果 (码点 < 128) { 返回 1 }
    如果 (码点 < 2048) { 返回 2 }
    如果 (码点 < 65536) { 返回 3 }
    返回 4
}

函数 utf8_有效(字节列表) {
    定义 可变 位置 = 0
    当 (位置 < 计数(字节列表)) {
        定义 项 = utf8_解码(字节列表, 位置)
        如果 (项[0] < 0) {
            返回 假
        }
        位置 = 位置 + 项[1]
    }
    返回 真
}

函数 base64_索引(字符) {
    如果 (字符串等于(字符, "=")) {
        返回 -1
    }
    定义 可变 i = 0
    当 (i < 64) {
        如果 (字符串等于(子串(BASE64_表, i, 1), 字符)) {
            返回 i
        }
        i = i + 1
    }
    返回 -1
}

函数 base64_编码(字节列表) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(字节列表)) {
        定义 b0 = 字节列表[i]
        定义 可变 b1 = 0
        定义 可变 b2 = 0
        定义 可变 填充 = 0

        如果 (i + 1 < 计数(字节列表)) {
            b1 = 字节列表[i + 1]
        } 否则 {
            填充 = 填充 + 1
        }
        如果 (i + 2 < 计数(字节列表)) {
            b2 = 字节列表[i + 2]
        } 否则 {
            填充 = 填充 + 1
        }

        定义 idx0 = b0 / 4
        定义 idx1 = (b0 % 4) * 16 + b1 / 16
        定义 idx2 = (b1 % 16) * 4 + b2 / 64
        定义 idx3 = b2 % 64

        结果 = 字符串拼接(结果, 子串(BASE64_表, idx0, 1))
        结果 = 字符串拼接(结果, 子串(BASE64_表, idx1, 1))
        如果 (填充 < 2) {
            结果 = 字符串拼接(结果, 子串(BASE64_表, idx2, 1))
        } 否则 {
            结果 = 字符串拼接(结果, "=")
        }
        如果 (填充 < 1) {
            结果 = 字符串拼接(结果, 子串(BASE64_表, idx3, 1))
        } 否则 {
            结果 = 字符串拼接(结果, "=")
        }
        i = i + 3
    }
    返回 结果
}

函数 base64_解码(文本) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i + 3 < 计数(文本)) {
        定义 c0 = base64_索引(子串(文本, i, 1))
        定义 c1 = base64_索引(子串(文本, i + 1, 1))
        定义 c2 = base64_索引(子串(文本, i + 2, 1))
        定义 c3 = base64_索引(子串(文本, i + 3, 1))

        如果 (c0 < 0) {
            i = i + 4
        } 否则 如果 (c1 < 0) {
            i = i + 4
        } 否则 {
            追加(结果, c0 * 4 + c1 / 16)
            如果 (c2 >= 0) {
                追加(结果, (c1 % 16) * 16 + c2 / 4)
            }
            如果 (c2 >= 0) {
                如果 (c3 >= 0) {
                    追加(结果, (c2 % 4) * 64 + c3)
                }
            }
            i = i + 4
        }
    }
    返回 结果
}

函数 hex_值(字符) {
    定义 可变 i = 0
    当 (i < 16) {
        如果 (字符串等于(子串(HEX_表, i, 1), 字符)) {
            返回 i
        }
        i = i + 1
    }

    定义 大写HEX = "ABCDEF"
    i = 0
    当 (i < 6) {
        如果 (字符串等于(子串(大写HEX, i, 1), 字符)) {
            返回 i + 10
        }
        i = i + 1
    }
    返回 -1
}

函数 hex_编码(字节列表) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(字节列表)) {
        定义 可变 b = 字节列表[i]
        如果 (b < 0) {
            b = b + 256
        }
        结果 = 字符串拼接(结果, 子串(HEX_表, b / 16, 1))
        结果 = 字符串拼接(结果, 子串(HEX_表, b % 16, 1))
        i = i + 1
    }
    返回 结果
}

函数 hex_解码(文本) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i + 1 < 计数(文本)) {
        定义 高 = hex_值(子串(文本, i, 1))
        定义 低 = hex_值(子串(文本, i + 1, 1))
        如果 (高 >= 0) {
            如果 (低 >= 0) {
                追加(结果, 高 * 16 + 低)
            } 否则 {
            }
        } 否则 {
        }
        i = i + 2
    }
    返回 结果
}

函数 url_编码(文本) {
    定义 可变 结果 = ""
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        定义 c = 编码(子串(文本, i, 1))
        如果 (url_是安全字符(c)) {
            结果 = 字符串拼接(结果, 子串(文本, i, 1))
        } 否则 如果 (c == 字符_空格) {
            结果 = 字符串拼接(结果, "+")
        } 否则 {
            定义 字节 = utf8_编码(c)
            定义 可变 j = 0
            当 (j < 计数(字节)) {
                定义 b = 字节[j]
                结果 = 字符串拼接(结果, "%")
                结果 = 字符串拼接(结果, 子串(HEX_表, b / 16, 1))
                结果 = 字符串拼接(结果, 子串(HEX_表, b % 16, 1))
                j = j + 1
            }
        }
        i = i + 1
    }
    返回 结果
}

函数 url_解码(文本) {
    定义 可变 结果 = []
    定义 可变 i = 0
    当 (i < 计数(文本)) {
        定义 c = 子串(文本, i, 1)
        如果 (字符串等于(c, "%")) {
            如果 (i + 2 >= 计数(文本)) {
                i = i + 1
            } 否则 {
                定义 高 = hex_值(子串(文本, i + 1, 1))
                定义 低 = hex_值(子串(文本, i + 2, 1))
                如果 (高 >= 0) {
                    如果 (低 >= 0) {
                        追加(结果, 高 * 16 + 低)
                    } 否则 {
                    }
                } 否则 {
                }
                i = i + 3
            }
        } 否则 如果 (字符串等于(c, "+")) {
            追加(结果, 32)
            i = i + 1
        } 否则 {
            追加(结果, 编码(c))
            i = i + 1
        }
    }
    返回 结果
}


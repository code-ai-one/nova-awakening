// AVX-512F 比较/转换

// vcmpps k, zmm, zmm, imm8
函数 发射_avx512_比较ps(k, s1, s2, 模式) {
    发射_evex(1,  1,  1,  1,  1,  0,  s1, 0 ,  1, 0 ,  1, 0, 0, 0)
    发射(0xC2) 发射(0xC0 + (k & 7) * 8 + (s2 & 7)) 发射(模式)
}
// vcmppd k, zmm, zmm, imm8
函数 发射_avx512_比较pd(k, s1, s2, 模式) {
    发射_evex(1,  1,  1,  1,  1,  1,  s1,  1,  0,  1, 0 ,  1, 0, 0)
    发射(0xC2) 发射(0xC0 + (k & 7) * 8 + (s2 & 7)) 发射(模式)
}

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./链表后继.nova")

// NovaInfer推理引擎理论 (NovaOS原创)
// 定理1 (前向链完备): 有限规则集闭包在O(r×f)步内达到不动点
// 定理2 (涟漪收敛): 级联触发收敛于O(d×r)步, d=最大涟漪半径
// 定理3 (缓存加速): 缓存命中时推理O(1), 总加速比 ≥ 缓存命中率
// 定理4 (置信度衰减): 链式置信度 = ∏(c_i × 0.95^k), 单调递减
// NovaOS内核 · 推理引擎 (移植自Nova大脑L4/reason)
// 前向链推理 + 模式匹配 + 类比推理
// §1 前向链: 规则触发 IF条件→THEN结论
// §2 模式匹配: 输入模式→最相似已知模式
// §3 类比推理: A:B = C:? → 关系映射
// §4 置信度传播: 推理链中置信度衰减

定义 规则_最大数 = 128
定义 模式_最大数 = 256

结构 推理规则 {
    条件列表,    // 列表 条件哈希列表
    结论,    // u64 结论哈希
    置信度,    // u32 ×1000
    触发次数,
}

结构 已知模式 {
    特征哈希,
    标签,
    匹配次数,
}

定义 可变 规则表 = []
定义 可变 模式库 = []
定义 可变 事实集 = []          // 当前已知事实(哈希集合)
定义 可变 推理_已初始化 = 假
定义 可变 推理_总步数 = 0
定义 可变 推理_总推导 = 0

函数 推理_初始化() {
    规则表 = []
    模式库 = []
    事实集 = []
    推理_已初始化 = 真
    内核信息("推理引擎: 前向链+模式匹配+类比推理+置信度传播")
}


函数 推理_添加规则(条件列表, 结论, 置信度) {
    如果 (计数(规则表) >= 规则_最大数) { 返回 -1 }
    定义 r = 推理规则 {}
    r.条件列表 = 条件列表
    r.结论 = 结论
    r.置信度 = 置信度
    r.触发次数 = 0
    追加(规则表, r)
    返回 计数(规则表) - 1
}

函数 推理_断言事实(事实哈希) {
    // 添加新事实
    定义 可变 i = 0
    当 (i < 计数(事实集)) {
        如果 (事实集[i] == 事实哈希) { 返回 }  // 已有
        i = i + 1
    }
    追加(事实集, 事实哈希)
}

函数 推理_前向链(最大步数) {
    定义 可变 有新推导 = 真
    定义 可变 步数 = 0
    当 (有新推导 && 步数 < 最大步数) {
        有新推导 = 假
        步数 = 步数 + 1
        推理_总步数 = 推理_总步数 + 1

        定义 可变 r = 0
        当 (r < 计数(规则表)) {
            // 检查规则所有条件是否满足
            定义 条件 = 规则表[r].条件列表
            定义 可变 全部满足 = 真
            定义 可变 c = 0
            当 (c < 计数(条件)) {
                如果 (!推理_是事实(条件[c])) { 全部满足 = 假 }
                c = c + 1
            }
            如果 (全部满足) {
                // 条件满足→推导结论
                如果 (!推理_是事实(规则表[r].结论)) {
                    追加(事实集, 规则表[r].结论)
                    规则表[r].触发次数 = 规则表[r].触发次数 + 1
                    推理_总推导 = 推理_总推导 + 1
                    有新推导 = 真
                }
            }
            r = r + 1
        }
    }
    返回 步数
}

函数 推理_是事实(哈希) {
    定义 可变 i = 0
    当 (i < 计数(事实集)) {
        如果 (事实集[i] == 哈希) { 返回 真 }
        i = i + 1
    }
    返回 假
}


函数 推理_添加模式(特征哈希, 标签) {
    如果 (计数(模式库) >= 模式_最大数) { 返回 -1 }
    定义 m = 已知模式 {}
    m.特征哈希 = 特征哈希
    m.标签 = 标签
    m.匹配次数 = 0
    追加(模式库, m)
    返回 计数(模式库) - 1
}

函数 推理_匹配模式(输入哈希) {
    定义 可变 最佳 = -1
    定义 可变 最佳距离 = 999999
    定义 可变 i = 0
    当 (i < 计数(模式库)) {
        定义 距离 = 输入哈希 ^ 模式库[i].特征哈希
        // popcount近似
        定义 可变 位数 = 0
        定义 可变 tmp = 距离
        当 (tmp > 0) { 位数 = 位数 + (tmp & 1); tmp = tmp >> 1 }
        如果 (位数 < 最佳距离) { 最佳距离 = 位数; 最佳 = i }
        i = i + 1
    }
    如果 (最佳 >= 0) {
        模式库[最佳].匹配次数 = 模式库[最佳].匹配次数 + 1
        返回 模式库[最佳].标签
    }
    返回 0
}


函数 推理_类比(A, B, C) {
    // A:B = C:? → 计算关系R=B-A, 然后D=C+R
    定义 关系 = B ^ A   // 用异或表示关系
    返回 C ^ 关系        // 应用关系到C
}

函数 推理_事实数() { 返回 计数(事实集) }
函数 推理_规则数() { 返回 计数(规则表) }
函数 推理_统计() {
    返回 { 事实: 计数(事实集), 规则: 计数(规则表), 步数: 推理_总步数, 推导: 推理_总推导 }
}

// 给定目标结论, 反向查找哪些条件可以推出它

函数 推理_反向链(目标, 最大深度) {
    // 返回: 所需条件列表 (尚未满足的)
    定义 可变 所需条件 = []
    定义 可变 待检查 = [目标]
    定义 可变 已检查 = []
    定义 可变 深度 = 0
    当 (计数(待检查) > 0 && 深度 < 最大深度) {
        定义 可变 下一批 = []
        定义 可变 w = 0
        当 (w < 计数(待检查)) {
            定义 当前目标 = 待检查[w]
            追加(已检查, 当前目标)
            // 查找能推出该目标的规则
            定义 可变 找到 = 假
            定义 可变 r = 0
            当 (r < 计数(规则表)) {
                如果 (规则表[r].结论 == 当前目标) {
                    找到 = 真
                    定义 可变 c = 0
                    当 (c < 计数(规则表[r].条件列表)) {
                        定义 条件 = 规则表[r].条件列表[c]
                        如果 (!推理_是事实(条件)) { 追加(下一批, 条件) }
                        c = c + 1
                    }
                }
                r = r + 1
            }
            如果 (找到 == 假 && !推理_是事实(当前目标)) {
                追加(所需条件, 当前目标)  // 无法推导, 需外部提供
            }
            w = w + 1
        }
        待检查 = 下一批
        深度 = 深度 + 1
    }
    返回 所需条件
}

// 原理: 新事实引发“涟漪”效应 — 级联触发相关规则
//   每个新推导不仅触发直接规则, 还向“邻居事实”扩散
//   涟漪半径随传播步数衰减, 避免无限扩散
//   类似神经网络的激活扩散但用于符号推理
定义 可变 _涟漪_总次数 = 0

函数 推理_涟漪(起点事实, 最大半径) {
    // 从新事实开始向外扩散推理
    推理_断言事实(起点事实)
    定义 可变 波前沿 = [起点事实]
    定义 可变 半径 = 0
    定义 可变 总推导 = 0
    当 (计数(波前沿) > 0 && 半径 < 最大半径) {
        定义 可变 新波前 = []
        定义 可变 w = 0
        当 (w < 计数(波前沿)) {
            // 查找被此事实触发的规则
            定义 可变 r = 0
            当 (r < 计数(规则表)) {
                定义 可变 包含 = 假
                定义 可变 c = 0
                当 (c < 计数(规则表[r].条件列表)) {
                    如果 (规则表[r].条件列表[c] == 波前沿[w]) { 包含 = 真 }
                    c = c + 1
                }
                如果 (包含 && !推理_是事实(规则表[r].结论)) {
                    // 检查其余条件是否满足
                    定义 可变 全满足 = 真
                    c = 0
                    当 (c < 计数(规则表[r].条件列表)) {
                        如果 (!推理_是事实(规则表[r].条件列表[c])) { 全满足 = 假 }
                        c = c + 1
                    }
                    如果 (全满足) {
                        追加(事实集, 规则表[r].结论)
                        追加(新波前, 规则表[r].结论)
                        推理_总推导 = 推理_总推导 + 1
                        总推导 = 总推导 + 1
                    }
                }
                r = r + 1
            }
            w = w + 1
        }
        波前沿 = 新波前
        半径 = 半径 + 1
    }
    _涟漪_总次数 = _涟漪_总次数 + 1
    返回 总推导
}


函数 推理_置信度传播(规则索引, 输入置信度) {
    // 结论置信度 = min(规则置信度, 输入置信度) × 衰减因子
    如果 (规则索引 >= 计数(规则表)) { 返回 0 }
    定义 规则置信 = 规则表[规则索引].置信度
    定义 最小 = 规则置信
    如果 (输入置信度 < 最小) { 最小 = 输入置信度 }
    返回 最小 * 950 / 1000  // 5%每步衰减
}

函数 推理_推导效率() {
    如果 (推理_总步数 == 0) { 返回 0 }
    返回 推理_总推导 * 1000 / 推理_总步数
}

// 避免重复推导: 缓存最近推理结论, O(1)命中查询

定义 可变 推理缓存表 = []
定义 推理缓存_最大 = 64

函数 推理_缓存命中(事实哈希) {
    定义 可变 i = 0
    当 (i < 计数(推理缓存表)) {
        如果 (推理缓存表[i] == 事实哈希) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 推理_缓存记录(事实哈希) {
    如果 (推理_缓存命中(事实哈希)) { 返回 }
    追加(推理缓存表, 事实哈希)
    如果 (计数(推理缓存表) > 推理缓存_最大) {
        链表_删除(推理缓存表, 0)
    }
}

函数 推理_完整统计() {
    返回 [
        ["模块", "推理引擎"],
        ["事实数", 计数(事实集)],
        ["规则数", 计数(规则表)],
        ["模式数", 计数(模式库)],
        ["总步数", 推理_总步数],
        ["总推导", 推理_总推导],
        ["涟漪次数", _涟漪_总次数],
        ["推导效率", 推理_推导效率()],
        ["创新", "反向链推理+涟漪推理+置信度传播"]
    ]
}

导入("../中枢/类型定义.nova")
导入("../推理/智能渠道.nova")
导入("../中枢/内核打印.nova")
导入("../推理/智能总线资源.nova")
导入("./文档事件.nova")
导入("../中枢/哈希函数.nova")
导入("./软件拦截缓.nova")
导入("../中枢/整数转字符串.nova")

定义 缓存_最大并发 = 6
定义 缓存_默认超时 = 30000

结构 缓存请求状态 {
    URL,
    状态,
    响应码,
    体,
    体长度,
    错误,
}

函数 缓存_addAll(cache, URL列表, URL数量) {
    如果 (cache == 0 || URL列表 == 0 || URL数量 == 0) { 返回 }

    定义 可变 成功数 = 0
    定义 可变 失败数 = 0

    定义 排序列表 = 缓存_AI排序URL(URL列表, URL数量)

    定义 可变 i = 0
    当 (i < URL数量) {
        定义 url = 内存_读64(排序列表 + i * 8)
        如果 (url == 0) { i = i + 1; 继续 }

        如果 (缓存_match(cache, url) != 0) {
            i = i + 1
            继续
        }

        定义 响应 = 网络_同步获取(url)
        如果 (响应 != 0 && 响应.状态码 >= 200 && 响应.状态码 < 400) {
            缓存_put(cache, url, 响应.状态码, 响应.头, 响应.体, 响应.体长度)
            成功数 = 成功数 + 1
        } 否则 {
            失败数 = 失败数 + 1
        }
        i = i + 1
    }

    如果 (失败数 > 0) {
        内核调试("缓存addAll: " + 整数转字符串(失败数) + " 个请求失败")
    }
}

函数 缓存_add(cache, 请求) {
    如果 (cache == 0 || 请求 == 0) { 返回 }
    定义 url = 请求.URL
    定义 响应 = 网络_同步获取(url)
    如果 (响应 != 0) {
        缓存_put(cache, url, 响应.状态码, 响应.头, 响应.体, 响应.体长度)
    }
}

函数 缓存_match(cache, url) {
    如果 (cache == 0 || url == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < cache.条目数量) {
        定义 entry = 内存_读64(cache.条目列表 + i * 8)
        如果 (entry != 0 && entry.请求URL == url) {
            entry.命中数 = entry.命中数 + 1
            返回 entry.响应
        }
        i = i + 1
    }
    返回 0
}

函数 缓存_matchAll(cache, url) {
    如果 (cache == 0) { 返回 [0, 0] }
    定义 结果 = 堆_分配_数组(cache.条目数量 * 8)
    定义 可变 计数器 = 0
    定义 可变 i = 0
    当 (i < cache.条目数量) {
        定义 entry = 内存_读64(cache.条目列表 + i * 8)
        如果 (entry != 0) {
            如果 (url == 0 || entry.请求URL == url) {
                内存_写64(结果 + 计数器 * 8, entry.响应)
                计数器 = 计数器 + 1
            }
        }
        i = i + 1
    }
    返回 [结果, 计数器]
}

函数 缓存_delete(cache, url) {
    如果 (cache == 0 || url == 0) { 返回 假 }
    定义 可变 i = 0
    当 (i < cache.条目数量) {
        定义 entry = 内存_读64(cache.条目列表 + i * 8)
        如果 (entry != 0 && entry.请求URL == url) {
            释放内存(entry)
            内存_写64(cache.条目列表 + i * 8, 0)
            cache.有效条目数 = cache.有效条目数 - 1
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 缓存_keys(cache) {
    如果 (cache == 0) { 返回 [0, 0] }
    定义 结果 = 堆_分配_数组(cache.条目数量 * 8)
    定义 可变 计数器 = 0
    定义 可变 i = 0
    当 (i < cache.条目数量) {
        定义 entry = 内存_读64(cache.条目列表 + i * 8)
        如果 (entry != 0) {
            内存_写64(结果 + 计数器 * 8, entry.请求URL)
            计数器 = 计数器 + 1
        }
        i = i + 1
    }
    返回 [结果, 计数器]
}

函数 缓存_has(cache, url) {
    返回 缓存_match(cache, url) != 0
}

函数 缓存_清空(cache) {
    如果 (cache == 0) { 返回 }
    定义 可变 i = 0
    当 (i < cache.条目数量) {
        定义 entry = 内存_读64(cache.条目列表 + i * 8)
        如果 (entry != 0) { 释放内存(entry) }
        内存_写64(cache.条目列表 + i * 8, 0)
        i = i + 1
    }
    cache.有效条目数 = 0
}

函数 缓存_AI排序URL(URL列表, URL数量) {
    定义 bus = 全局AI总线
    如果 (bus == 0) { 返回 URL列表 }

    定义 排序 = 堆_分配_数组(URL数量 * 16)
    定义 可变 i = 0
    当 (i < URL数量) {
        定义 url = 内存_读64(URL列表 + i * 8)
        定义 优先级 = AI总线_资源优先级(bus, url)
        内存_写64(排序 + i * 16, url)
        内存_写64(排序 + i * 16 + 8, 优先级)
        i = i + 1
    }

    定义 可变 j = 0
    当 (j < URL数量 - 1) {
        定义 可变 k = j + 1
        当 (k < URL数量) {
            如果 (内存_读64(排序 + k * 16 + 8) > 内存_读64(排序 + j * 16 + 8)) {
                定义 临时URL = 内存_读64(排序 + j * 16)
                定义 临时优 = 内存_读64(排序 + j * 16 + 8)
                内存_写64(排序 + j * 16, 内存_读64(排序 + k * 16))
                内存_写64(排序 + j * 16 + 8, 内存_读64(排序 + k * 16 + 8))
                内存_写64(排序 + k * 16, 临时URL)
                内存_写64(排序 + k * 16 + 8, 临时优)
            }
            k = k + 1
        }
        j = j + 1
    }

    定义 结果 = 堆_分配_数组(URL数量 * 8)
    i = 0
    当 (i < URL数量) {
        内存_写64(结果 + i * 8, 内存_读64(排序 + i * 16))
        i = i + 1
    }
    释放内存(排序)
    返回 结果
}

函数 智能_Service工线_AI加载优先级(url) {
    定义 bus = 全局AI总线
    如果 (bus == 0 || url == 0) { 返回 Q_HALF }
    返回 AI总线_资源优先级(bus, url)
}

函数 智能_Service工线_AI预取决策(url) {
    定义 bus = 全局AI总线
    如果 (bus == 0 || url == 0) { 返回 假 }
    定义 分数 = AI总线_资源优先级(bus, url)
    返回 分数 > 600
}

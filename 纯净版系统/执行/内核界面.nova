}

函数 内核界面_设置壳输入(档, 输入) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "设置壳输入", "界面档不可用") }
    内核界面_记录(档, "设置壳输入", [输入], "窗口管理")
    Nova原生桌面_设置壳输入缓冲(输入)
    Web桌面_设置壳输入缓冲(输入)
    档.页面数 = 档.页面数 + 1
    返回 内核界面_成功(档, "设置壳输入", 输入)
}

函数 内核界面_记录壳状态(档, 输入, 动作, 结果) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "记录壳状态", "界面档不可用") }
    内核界面_记录(档, "记录壳状态", [输入, 动作, 结果], "窗口管理")
    Nova原生桌面_记录壳状态(输入, 动作, 结果)
    Web桌面_记录壳状态(输入, 动作, 结果)
    档.页面数 = 档.页面数 + 1
    返回 内核界面_成功(档, "记录壳状态", [输入, 动作, 结果])
}

函数 内核界面_同步状态(档, 核心状态, 核心副文本, 页面标题, 页面地址, 页面摘要) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "同步状态", "界面档不可用") }
    内核界面_记录(档, "同步状态", [核心状态, 核心副文本, 页面标题, 页面地址, 页面摘要], "窗口管理")
    Nova原生桌面_同步系统状态(核心状态, 核心副文本, 页面标题, 页面地址, 页面摘要)
    Web桌面_同步系统状态(核心状态, 核心副文本, 页面标题, 页面地址, 页面摘要)
    档.页面数 = 档.页面数 + 1
    返回 内核界面_成功(档, "同步状态", [核心状态, 页面标题, 页面地址])
}

函数 内核界面_刷新前台(档) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "刷新前台", "界面档不可用") }
    内核界面_记录(档, "刷新前台", [], "窗口管理")
    定义 结果 = Nova原生桌面_刷新前台模块状态()
    档.页面数 = 档.页面数 + 1
    返回 内核界面_成功(档, "刷新前台", 结果)
}

函数 内核界面_渲染帧(档) {
    如果 (!内核界面_检查档(档)) { 返回 内核界面_失败(档, "渲染帧", "界面档不可用") }
    内核界面_记录(档, "渲染帧", [], "窗口管理")
    定义 原生 = Nova原生桌面_渲染帧()
    定义 网面 = Web桌面_渲染帧()
    档.合成数 = 档.合成数 + 1

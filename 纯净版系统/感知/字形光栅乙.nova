// §2 字形光栅化


函数 字体Face_获取字形(face, 码点) {
    // 先查缓存
    定义 缓存 = Glyph缓存_查找(face.字形缓存, 码点, face.字号)
    如果 (缓存 != 0) { 返回 缓存 }

    定义 glyph = 堆_分配(GlyphBitmap)

    如果 (face.句柄 != 0) {
        // 通过FreeType光栅化
        定义 结果缓冲 = 堆_分配(4096)    // 足够一个字形
        定义 字节数 = 系统调用(Nova系统调用_字体_光栅化, face.句柄, 码点, 结果缓冲, 4096, 0)
        如果 (字节数 > 16) {
            glyph.宽 = 内存_读32(结果缓冲)
            glyph.高 = 内存_读32(结果缓冲 + 4)
            glyph.左偏移 = 内存_读32(结果缓冲 + 8)
            glyph.上偏移 = 内存_读32(结果缓冲 + 12)
            glyph.前进宽度 = 内存_读32(结果缓冲 + 16)
            glyph.行字节数 = glyph.宽
            定义 像素大小 = glyph.宽 * glyph.高
            glyph.像素数据 = 堆_分配(像素大小)
            内存_复制(glyph.像素数据, 结果缓冲 + 20, 像素大小)
        } 否则 {
            字体Face_生成回退字形(glyph, face.字号 / 64, 码点)
        }
        堆_释放(结果缓冲)
    } 否则 {
        // 无FreeType: 生成简单回退字形
        字体Face_生成回退字形(glyph, face.字号 / 64, 码点)
    }

    // 加入缓存
    Glyph缓存_添加(face.字形缓存, 码点, face.字号, glyph)
    返回 glyph
}

函数 字体Face_生成回退字形(glyph, 字号, 码点) {
        定义 可变 宽 = 字号 * 60 / 100     // ASCII约0.6×字号
    定义 高 = 字号

    // CJK字符: 全角
    如果 (码点 >= 0x3000 && 码点 <= 0x9FFF) { 宽 = 字号 }
    如果 (码点 >= 0xF900 && 码点 <= 0xFAFF) { 宽 = 字号 }
    如果 (码点 >= 0x20000 && 码点 <= 0x2FA1F) { 宽 = 字号 }

    // 空格
    如果 (码点 == 0x20) { 宽 = 字号 * 25 / 100 }

    如果 (宽 <= 0) { 宽 = 1 }
    如果 (高 <= 0) { 高 = 1 }

    glyph.宽 = 宽
    glyph.高 = 高
    glyph.左偏移 = 0
    glyph.上偏移 = 高 * 80 / 100    // 基线在80%位置
    glyph.前进宽度 = 宽 * 64
    glyph.行字节数 = 宽
    glyph.像素数据 = 堆_分配(宽 * 高)

    // 对于空格: 不画任何东西
    如果 (码点 == 0x20 || 码点 == 0xA0) { 返回 }

    // 简单回退: 画一个矩形轮廓
    定义 可变 y = 0
    当 (y < 高) {
        定义 可变 x = 0
        当 (x < 宽) {
            定义 可变 alpha = 0
            // 边框
            如果 (x == 0 || x == 宽 - 1 || y == 0 || y == 高 - 1) {
                alpha = 200
            }
            // 对角线(帮助识别)
            如果 (x == y * 宽 / 高 || x == 宽 - 1 - y * 宽 / 高) {
                alpha = 128
            }
            内存_写8(glyph.像素数据 + y * 宽 + x, alpha)
            x = x + 1
        }
        y = y + 1
    }
}

// §3 文本度量 (Text Metrics)

结构 TextMetrics {
    宽度,    // i32 总前进宽度
    高度,    // i32 ascent + descent
    上升,    // i32 基线以上
    下降,    // i32 基线以下(正数)
    行距,
}

函数 Text渲染er_度量(face, 文本, 文本长度) {
    定义 m = TextMetrics {}
    m.上升 = face.上升 / 64
    m.下降 = (0 - face.下降) / 64
    m.高度 = m.上升 + m.下降
    m.行距 = (face.上升 - face.下降 + face.行距) / 64
    m.宽度 = 0

    定义 可变 pos = 0
    当 (pos < 文本长度) {
        定义 解码 = UTF8_解码(文本, pos)
        定义 码点 = 解码[0]
        定义 字节数 = 解码[1]
        pos = pos + 字节数

        定义 glyph = 字体Face_获取字形(face, 码点)
        如果 (glyph != 0) {
            m.宽度 = m.宽度 + glyph.前进宽度 / 64
        }
    }

    返回 m
}

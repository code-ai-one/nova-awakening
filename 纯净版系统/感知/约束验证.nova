// §3 约束验证(Constraint Validation 接口)

导入("./内核直连层.nova")
导入("../推理/智能渠道.nova")
导入("../执行/控制台输出.nova")
导入("../推理/值乘.nova")
导入("../中枢/辅助存根.nova")
导入("./文档节点.nova")
导入("../中枢/数学工具.nova")
导入("../执行/节点操作.nova")

函数 FormControl_验证(控件) {
    如果 (控件 == 0) { 返回 验证_有效 }
    如果 (控件.是禁用) { 返回 验证_有效 }    // disabled不验证

    定义 值 = 控件.值
    定义 值长 = 如果(值 != 0, 字节长度(值), 0)

    // required
    如果 (控件.是必填) {
        如果 (控件.类型 == 输入类型_checkbox) {
            如果 (!控件.是选中) { 控件.验证状态 = 验证_缺失; 返回 验证_缺失 }
        } 否则 {
            如果 (值长 == 0) { 控件.验证状态 = 验证_缺失; 返回 验证_缺失 }
        }
    }

    如果 (值长 == 0) { 控件.验证状态 = 验证_有效; 返回 验证_有效 }

    // 类型验证
    如果 (控件.类型 == 输入类型_email) {
        如果 (!验证_email格式(值)) {
            控件.验证状态 = 验证_类型不匹配
            返回 验证_类型不匹配
        }
    }
    否则 如果 (控件.类型 == 输入类型_url) {
        如果 (!验证_url格式(值)) {
            控件.验证状态 = 验证_类型不匹配
            返回 验证_类型不匹配
        }
    }
    否则 如果 (控件.类型 == 输入类型_number || 控件.类型 == 输入类型_range) {
        定义 数值 = 字符串转数字(值)
        如果 (控件.最小值 != 0) {
            定义 最小 = 字符串转数字(控件.最小值)
            如果 (数值 < 最小) { 控件.验证状态 = 验证_过小; 返回 验证_过小 }
        }
        如果 (控件.最大值 != 0) {
            定义 最大 = 字符串转数字(控件.最大值)
            如果 (数值 > 最大) { 控件.验证状态 = 验证_过大; 返回 验证_过大 }
        }
    }

    // minlength/maxlength
    如果 (控件.最小长度 >= 0 && 值长 < 控件.最小长度) {
        控件.验证状态 = 验证_过短; 返回 验证_过短
    }
    如果 (控件.最大长度 >= 0 && 值长 > 控件.最大长度) {
        控件.验证状态 = 验证_过长; 返回 验证_过长
    }

    // pattern(正则匹配)
    如果 (控件.模式 != 0) {
        如果 (!正则_匹配(控件.模式, 值)) {
            控件.验证状态 = 验证_模式不匹配
            返回 验证_模式不匹配
        }
    }

    控件.验证状态 = 验证_有效
    返回 验证_有效
}

函数 验证_email格式(值) {
    // 基本邮箱格式检查: 包含@和.
    定义 长度 = 字节长度(值)
    定义 可变 有at = 假
    定义 可变 有点 = 假
    定义 可变 at位置 = -1
    定义 可变 i = 0
    当 (i < 长度) {
        如果 (字节取(值, i) == 64) { 有at = 真; at位置 = i }
        如果 (字节取(值, i) == 46 && at位置 >= 0) { 有点 = 真 }
        i = i + 1
    }
    返回 有at && 有点 && at位置 > 0 && at位置 < 长度 - 1
}

函数 验证_url格式(值) {
    返回 字符串_前缀匹配(值, "http://") || 字符串_前缀匹配(值, "https://")
}

函数 HTMLForm_验证全部(form) {
    如果 (form == 0 || form.novalidate) { 返回 真 }
    定义 可变 全部有效 = 真
    定义 可变 i = 0
    当 (i < form.控件数) {
        定义 控件 = form.控件[i]
        如果 (FormControl_验证(控件) != 验证_有效) {
            全部有效 = 假
        }
        i = i + 1
    }
    返回 全部有效
}

// §4 NFCV理论 — Nova Form Constraint Validation
// 低耦合高聚合表单约束验证增强层

定义 NFCV_版本 = "3.0.0-NFCV"
定义 NFCV_AI阈值 = 0.72
定义 NFCV_最大错误消息长度 = 256

定义 可变 NFCV_验证次数 = 0
定义 可变 NFCV_有效次数 = 0
定义 可变 NFCV_无效次数 = 0
定义 可变 NFCV_报告次数 = 0
定义 可变 NFCV_AI推理次数 = 0
定义 可变 NFCV_异步验证次数 = 0
定义 可变 NFCV_跨字段验证次数 = 0

结构 NFCV_结果 {
    状态: 验证_有效
    错误码: 0
    消息: 0
    置信度: 100
}

结构 NFCV_规则 {
    名称: 0
    参数1: 0
    参数2: 0
    启用: 真
}

结构 NFCV_上下文 {
    控件: 0
    表单: 0
    当前时间戳: 0
    来源: 0
}

函数 NFCV_创建结果(状态, 错误码, 消息) {
    定义 r = NFCV_结果 {}
    r.状态 = 状态
    r.错误码 = 错误码
    r.消息 = 消息
    r.置信度 = 100
    返回 r
}

函数 NFCV_状态转文本(状态) {
    如果 (状态 == 验证_有效) { 返回 "valid" }
    如果 (状态 == 验证_缺失) { 返回 "valueMissing" }
    如果 (状态 == 验证_类型不匹配) { 返回 "typeMismatch" }
    如果 (状态 == 验证_模式不匹配) { 返回 "patternMismatch" }
    如果 (状态 == 验证_过小) { 返回 "rangeUnderflow" }
    如果 (状态 == 验证_过大) { 返回 "rangeOverflow" }
    如果 (状态 == 验证_过短) { 返回 "tooShort" }
    如果 (状态 == 验证_过长) { 返回 "tooLong" }
    返回 "customError"
}

函数 NFCV_默认错误消息(控件, 状态) {
    如果 (状态 == 验证_有效) { 返回 "" }
    如果 (状态 == 验证_缺失) { 返回 "请填写此字段" }
    如果 (状态 == 验证_类型不匹配) {
        如果 (控件.类型 == 输入类型_email) { 返回 "请输入有效的邮箱地址" }
        如果 (控件.类型 == 输入类型_url) { 返回 "请输入有效的URL地址" }
        返回 "输入格式不正确"
    }
    如果 (状态 == 验证_模式不匹配) { 返回 "输入不符合要求格式" }
    如果 (状态 == 验证_过小) { 返回 "输入值小于允许最小值" }
    如果 (状态 == 验证_过大) { 返回 "输入值超过允许最大值" }
    如果 (状态 == 验证_过短) { 返回 "输入字符过短" }
    如果 (状态 == 验证_过长) { 返回 "输入字符过长" }
    返回 "输入无效"
}

函数 NFCV_裁剪错误消息(消息) {
    如果 (消息 == 0) { 返回 "" }
    定义 长度 = 字节长度(消息)
    如果 (长度 <= NFCV_最大错误消息长度) { 返回 消息 }
    返回 字符串_子串(消息, 0, NFCV_最大错误消息长度)
}

// §5 基础规则模块(单一职责)

函数 NFCV_校验必填(控件) {
    如果 (!控件.是必填) { 返回 验证_有效 }
    如果 (控件.类型 == 输入类型_checkbox || 控件.类型 == 输入类型_radio) {
        如果 (!控件.是选中) { 返回 验证_缺失 }
        返回 验证_有效
    }
    定义 值 = 控件.值
    如果 (值 == 0 || 字节长度(值) == 0) { 返回 验证_缺失 }
    返回 验证_有效
}

函数 NFCV_校验长度(控件) {
    定义 值 = 控件.值
    定义 长度 = 如果(值 != 0, 字节长度(值), 0)
    如果 (控件.最小长度 >= 0 && 长度 < 控件.最小长度) { 返回 验证_过短 }
    如果 (控件.最大长度 >= 0 && 长度 > 控件.最大长度) { 返回 验证_过长 }
    返回 验证_有效
}

函数 NFCV_校验数值范围(控件) {
    定义 值 = 控件.值
    如果 (值 == 0 || 字节长度(值) == 0) { 返回 验证_有效 }
    定义 数值 = 字符串转数字(值)
    如果 (控件.最小值 != 0) {
        定义 最小 = 字符串转数字(控件.最小值)
        如果 (数值 < 最小) { 返回 验证_过小 }
    }
    如果 (控件.最大值 != 0) {
        定义 最大 = 字符串转数字(控件.最大值)
        如果 (数值 > 最大) { 返回 验证_过大 }
    }
    返回 验证_有效
}

函数 NFCV_校验类型(控件) {
    定义 值 = 控件.值
    如果 (值 == 0 || 字节长度(值) == 0) { 返回 验证_有效 }

    如果 (控件.类型 == 输入类型_email) {
        如果 (!NFCV_验证邮箱(值)) { 返回 验证_类型不匹配 }
        返回 验证_有效
    }
    如果 (控件.类型 == 输入类型_url) {
        如果 (!NFCV_验证URL(值)) { 返回 验证_类型不匹配 }
        返回 验证_有效
    }
    如果 (控件.类型 == 输入类型_tel) {
        如果 (!NFCV_验证电话(值)) { 返回 验证_类型不匹配 }
        返回 验证_有效
    }
    如果 (控件.类型 == 输入类型_number || 控件.类型 == 输入类型_range) {
        如果 (!NFCV_验证数字字符串(值)) { 返回 验证_类型不匹配 }
        返回 验证_有效
    }
    返回 验证_有效
}

函数 NFCV_校验模式(控件) {
    如果 (控件.模式 == 0) { 返回 验证_有效 }
    定义 值 = 控件.值
    如果 (值 == 0 || 字节长度(值) == 0) { 返回 验证_有效 }
    如果 (!正则_匹配(控件.模式, 值)) { 返回 验证_模式不匹配 }
    返回 验证_有效
}

函数 NFCV_校验步长(控件) {
    // step匹配: (value - min) % step == 0
    如果 (控件.步长 == 0) { 返回 验证_有效 }
    定义 值 = 控件.值
    如果 (值 == 0 || 字节长度(值) == 0) { 返回 验证_有效 }
    定义 数值 = 字符串转数字(值)
    定义 基准 = 0
    如果 (控件.最小值 != 0) { 基准 = 字符串转数字(控件.最小值) }
    定义 步长值 = 字符串转数字(控件.步长)
    如果 (步长值 <= 0) { 返回 验证_有效 }
    定义 差 = 数值 - 基准
    定义 商 = 差 / 步长值
    定义 近整 = 数学_四舍五入(商)
    定义 偏差 = 数学_绝对值(商 - 近整)
    如果 (偏差 > 0.000001) { 返回 验证_模式不匹配 }
    返回 验证_有效
}

// §6 类型验证细分实现

函数 NFCV_验证邮箱(值) {
    定义 长度 = 字节长度(值)
    如果 (长度 < 3) { 返回 假 }
    定义 可变 at位置 = -1
    定义 可变 点位置 = -1
    定义 可变 i = 0
    当 (i < 长度) {
        定义 b = 字节取(值, i)
        如果 (b == 64) { at位置 = i }    // @
        如果 (b == 46) { 点位置 = i }    // .
        i = i + 1
    }
    如果 (at位置 <= 0) { 返回 假 }
    如果 (点位置 <= at位置 + 1) { 返回 假 }
    如果 (点位置 >= 长度 - 1) { 返回 假 }
    返回 真
}

函数 NFCV_验证URL(值) {
    如果 (字符串_前缀匹配(值, "http://")) { 返回 真 }
    如果 (字符串_前缀匹配(值, "https://")) { 返回 真 }
    如果 (字符串_前缀匹配(值, "ftp://")) { 返回 真 }
    返回 假
}

函数 NFCV_验证电话(值) {
    // 宽松电话验证: 数字、+、-、空格、括号
    定义 长度 = 字节长度(值)
    如果 (长度 < 5) { 返回 假 }
    定义 可变 i = 0
    当 (i < 长度) {
        定义 b = 字节取(值, i)
        如果 ((b >= 48 && b <= 57) || b == 43 || b == 45 || b == 32 || b == 40 || b == 41) {
            i = i + 1
            继续
        }
        返回 假
    }
    返回 真
}

函数 NFCV_验证数字字符串(值) {
    定义 长度 = 字节长度(值)
    如果 (长度 == 0) { 返回 假 }
    定义 可变 有数字 = 假
    定义 可变 i = 0
    当 (i < 长度) {
        定义 b = 字节取(值, i)
        如果 (b >= 48 && b <= 57) { 有数字 = 真; i = i + 1; 继续 }
        如果 (b == 45 || b == 43 || b == 46 || b == 101 || b == 69) { i = i + 1; 继续 } // - + . e E
        返回 假
    }
    返回 有数字
}

// §7 组合执行器(高聚合验证管线)

函数 NFCV_执行规则管线(控件) {
    NFCV_验证次数 = NFCV_验证次数 + 1
    如果 (控件 == 0) { 返回 验证_有效 }
    如果 (控件.是禁用) { 返回 验证_有效 }

    // 规则1: required
    定义 状态 = NFCV_校验必填(控件)
    如果 (状态 != 验证_有效) { 返回 状态 }

    // 空值直接通过后续规则
    定义 值 = 控件.值
    如果 (值 == 0 || 字节长度(值) == 0) { 返回 验证_有效 }

    // 规则2: 类型
    状态 = NFCV_校验类型(控件)
    如果 (状态 != 验证_有效) { 返回 状态 }

    // 规则3: 范围
    状态 = NFCV_校验数值范围(控件)
    如果 (状态 != 验证_有效) { 返回 状态 }

    // 规则4: 长度
    状态 = NFCV_校验长度(控件)
    如果 (状态 != 验证_有效) { 返回 状态 }

    // 规则5: pattern
    状态 = NFCV_校验模式(控件)
    如果 (状态 != 验证_有效) { 返回 状态 }

    // 规则6: step
    状态 = NFCV_校验步长(控件)
    如果 (状态 != 验证_有效) { 返回 状态 }

    返回 验证_有效
}

函数 NFCV_验证控件(控件) {
    定义 状态 = NFCV_执行规则管线(控件)
    控件.验证状态 = 状态
    如果 (状态 == 验证_有效) {
        NFCV_有效次数 = NFCV_有效次数 + 1
    } 否则 {
        NFCV_无效次数 = NFCV_无效次数 + 1
    }
    返回 状态
}

函数 FormControl_验证增强(控件) {
    // 对旧接口的兼容封装
    返回 NFCV_验证控件(控件)
}

// §8 自定义错误与报告机制

函数 FormControl_设置自定义错误(控件, 消息) {
    如果 (控件 == 0) { 返回 }
    控件.自定义错误 = NFCV_裁剪错误消息(消息)
    如果 (控件.自定义错误 != 0 && 字节长度(控件.自定义错误) > 0) {
        控件.验证状态 = 验证_模式不匹配
    } 否则 {
        控件.验证状态 = 验证_有效
    }
}

函数 FormControl_获取验证消息(控件) {
    如果 (控件 == 0) { 返回 "" }
    如果 (控件.自定义错误 != 0 && 字节长度(控件.自定义错误) > 0) {
        返回 控件.自定义错误
    }
    返回 NFCV_默认错误消息(控件, 控件.验证状态)
}

函数 FormControl_检查有效性(控件) {
    定义 状态 = NFCV_验证控件(控件)
    如果 (状态 == 验证_有效) { 返回 真 }
    返回 假
}

函数 FormControl_报告有效性(控件) {
    NFCV_报告次数 = NFCV_报告次数 + 1
    如果 (FormControl_检查有效性(控件)) {
        DOM_派发事件(控件, "valid", 假, 假)
        返回 真
    }
    定义 消息 = FormControl_获取验证消息(控件)
    DOM_设置验证气泡(控件, 消息)
    DOM_派发事件(控件, "invalid", 真, 真)
    返回 假
}

函数 HTMLForm_报告有效性(form) {
    如果 (form == 0) { 返回 真 }
    定义 可变 全部有效 = 真
    定义 可变 i = 0
    当 (i < form.控件数) {
        定义 控件 = form.控件[i]
        如果 (!FormControl_报告有效性(控件)) {
            如果 (全部有效 == 真) { DOM_聚焦(控件) }
            全部有效 = 假
        }
        i = i + 1
    }
    返回 全部有效
}

// §9 跨字段验证(密码确认/区间一致性)

函数 NFCV_按名称查找控件(form, 名称) {
    如果 (form == 0 || 名称 == 0) { 返回 0 }
    定义 可变 i = 0
    当 (i < form.控件数) {
        定义 c = form.控件[i]
        如果 (c != 0 && c.名称 != 0 && 字符串_等于(c.名称, 名称)) { 返回 c }
        i = i + 1
    }
    返回 0
}

函数 NFCV_验证确认密码(form, 主字段名, 确认字段名) {
    NFCV_跨字段验证次数 = NFCV_跨字段验证次数 + 1
    定义 主控件 = NFCV_按名称查找控件(form, 主字段名)
    定义 确认控件 = NFCV_按名称查找控件(form, 确认字段名)
    如果 (主控件 == 0 || 确认控件 == 0) { 返回 真 }
    如果 (!字符串_等于(主控件.值, 确认控件.值)) {
        FormControl_设置自定义错误(确认控件, "两次输入密码不一致")
        返回 假
    }
    FormControl_设置自定义错误(确认控件, "")
    返回 真
}

函数 NFCV_验证数值区间(form, 最小字段名, 最大字段名) {
    NFCV_跨字段验证次数 = NFCV_跨字段验证次数 + 1
    定义 最小控件 = NFCV_按名称查找控件(form, 最小字段名)
    定义 最大控件 = NFCV_按名称查找控件(form, 最大字段名)
    如果 (最小控件 == 0 || 最大控件 == 0) { 返回 真 }
    如果 (字节长度(最小控件.值) == 0 || 字节长度(最大控件.值) == 0) { 返回 真 }
    定义 minV = 字符串转数字(最小控件.值)
    定义 maxV = 字符串转数字(最大控件.值)
    如果 (minV > maxV) {
        FormControl_设置自定义错误(最大控件, "最大值必须大于或等于最小值")
        返回 假
    }
    FormControl_设置自定义错误(最大控件, "")
    返回 真
}

函数 NFCV_执行跨字段规则(form) {
    如果 (form == 0) { 返回 真 }
    定义 可变 全部有效 = 真
    如果 (!NFCV_验证确认密码(form, "password", "confirm_password")) { 全部有效 = 假 }
    如果 (!NFCV_验证数值区间(form, "min", "max")) { 全部有效 = 假 }
    返回 全部有效
}

// §10 异步验证与AI推理层

函数 NFCV_异步验证开始(控件, 规则名) {
    NFCV_异步验证次数 = NFCV_异步验证次数 + 1
    DOM_设置属性(控件, "data-validating", "1")
    DOM_设置属性(控件, "data-rule", 规则名)
}

函数 NFCV_异步验证结束(控件) {
    DOM_设置属性(控件, "data-validating", "0")
}

函数 NFCV_验证用户名唯一(控件) {
    // 示例：异步唯一性检查（本地模拟）
    NFCV_异步验证开始(控件, "uniqueUsername")
    定义 值 = 控件.值
    如果 (字符串_等于(值, "admin") || 字符串_等于(值, "root") || 字符串_等于(值, "system")) {
        NFCV_异步验证结束(控件)
        FormControl_设置自定义错误(控件, "该用户名已被占用")
        返回 假
    }
    NFCV_异步验证结束(控件)
    FormControl_设置自定义错误(控件, "")
    返回 真
}

函数 NFCV_AI预测风险(控件) {
    // NHTB式AI总线推理：预测输入风险得分
    NFCV_AI推理次数 = NFCV_AI推理次数 + 1
    定义 长度 = 如果(控件.值 != 0, 字节长度(控件.值), 0)
    定义 tensor = Tensor_创建(6)
    Tensor_写(tensor, 0, 控件.类型)
    Tensor_写(tensor, 1, 控件.是必填)
    Tensor_写(tensor, 2, 长度)
    Tensor_写(tensor, 3, 控件.最小长度)
    Tensor_写(tensor, 4, 控件.最大长度)
    Tensor_写(tensor, 5, 0.0)
    定义 推理 = AI总线_推理(全局AI总线, "nfcv_risk", tensor)
    定义 风险分 = Tensor_读(推理, 0)
    Tensor_释放(tensor)
    Tensor_释放(推理)
    返回 风险分
}

函数 NFCV_AI辅助验证(控件) {
    定义 风险分 = NFCV_AI预测风险(控件)
    如果 (风险分 < NFCV_AI阈值) { 返回 验证_有效 }
    // 高风险时加严检查：必须匹配模式且长度合规
    定义 s1 = NFCV_校验长度(控件)
    如果 (s1 != 验证_有效) { 返回 s1 }
    定义 s2 = NFCV_校验模式(控件)
    如果 (s2 != 验证_有效) { 返回 s2 }
    返回 验证_有效
}

函数 NFCV_验证控件_带AI(控件) {
    定义 基础状态 = NFCV_验证控件(控件)
    如果 (基础状态 != 验证_有效) { 返回 基础状态 }
    定义 AI状态 = NFCV_AI辅助验证(控件)
    如果 (AI状态 != 验证_有效) {
        控件.验证状态 = AI状态
        NFCV_无效次数 = NFCV_无效次数 + 1
        返回 AI状态
    }
    返回 验证_有效
}

// §12 初始化与诊断

函数 NFCV_初始化() {
    NFCV_验证次数 = 0
    NFCV_有效次数 = 0
    NFCV_无效次数 = 0
    NFCV_报告次数 = 0
    NFCV_AI推理次数 = 0
    NFCV_异步验证次数 = 0
    NFCV_跨字段验证次数 = 0
    打印("[NFCV] 约束验证引擎 v" + NFCV_版本 + " 已初始化")
}

函数 NFCV_诊断报告() {
    打印("[NFCV] === 约束验证诊断 ===")
    打印("  验证总数=" + 整数转字符串(NFCV_验证次数) + " 有效=" + 整数转字符串(NFCV_有效次数) + " 无效=" + 整数转字符串(NFCV_无效次数))
    打印("  报告次数=" + 整数转字符串(NFCV_报告次数) + " 跨字段=" + 整数转字符串(NFCV_跨字段验证次数))
    打印("  AI推理=" + 整数转字符串(NFCV_AI推理次数) + " 异步验证=" + 整数转字符串(NFCV_异步验证次数))
}

函数 NFCV_重置控件状态(控件) {
    如果 (控件 == 0) { 返回 }
    控件.验证状态 = 验证_有效
    控件.自定义错误 = ""
    DOM_清除验证气泡(控件)
}

函数 NFCV_重置表单状态(form) {
    如果 (form == 0) { 返回 }
    定义 可变 i = 0
    当 (i < form.控件数) {
        NFCV_重置控件状态(form.控件[i])
        i = i + 1
    }
}

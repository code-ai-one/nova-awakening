导入("./类型定义.nova")
导入("./错误码.nova")
导入("./公平调度调.nova")
导入("./红黑树创建.nova")

//   1. 加权Nova虚拟运行时间: delta_exec * NICE_0_LOAD / weight — 高权重进程Nova虚拟运行时间增长慢
//   2. EEVDF模型(6.6+): 每个实体有deadline = Nova虚拟运行时间 + slice/weight
//      选择"eligible且deadline最小"的实体运行 — 兼顾公平和延迟
//   3. 红黑树按Nova虚拟运行时间排序 — O(log n)选择最左节点
//   4. min_Nova虚拟运行时间单调递增 — 新进程/唤醒进程的Nova虚拟运行时间基准
//   5. place_entity: 唤醒/新建时的Nova虚拟运行时间放置策略(保持lag)
//   6. update_curr: 每次调度决策前更新当前进程的Nova虚拟运行时间和deadline
//   7. 时间片 = base_slice, 按权重分配实际CPU时间
//   8. 唤醒抢占: 被唤醒进程的deadline < 当前进程的deadline时抢占

// 调优参数 

定义 基础时间片 = 3000         // sched_base_slice: 3ms (EEVDF默认)
定义 调度延迟 = 6000           // sched_latency_ns: 6ms (兼容旧Nova公平调度)
定义 最小粒度 = 750            // sched_min_granularity_ns: 0.75ms
定义 唤醒粒度 = 1000           // sched_wakeup_granularity_ns: 1ms
定义 Nova公平调度_带宽_周期 = 100000    // Nova公平调度_bandwidth: 100ms
定义 调度_最大延迟因子 = 8     // nr_running > 8时用min_gran * nr

// 这是Nova公平调度公平性的数学基础: nice差1级 = CPU时间差~10%
定义 NICE_0_权重 = 1024
定义 NICE_权重表 = [
    88761, 71755, 56483, 46273, 36291,    // nice -20..-16
    29154, 23254, 18705, 14949, 11916,    // nice -15..-11
    9548,  7620,  6100,  4904,  3906,     // nice -10..-6
    3121,  2501,  1991,  1586,  1277,     // nice -5..-1
    1024,                                   // nice 0
    820,   655,   526,   423,   335,      // nice 1..5
    272,   215,   172,   137,   110,      // nice 6..10
    87,    70,    56,    45,    36,        // nice 11..15
    29,    23,    18,    15,    12         // nice 16..19
]

// 用于 __calc_delta 中避免除法: delta * NICE_0_LOAD * inv_weight >> 32
定义 NICE_倒数表 = [
    48388,  59856,  76040,  92818, 118348,
    147320, 184698, 229616, 287308, 360437,
    449829, 563644, 704093, 875809, 1099582,
    1376151,1717300,2157191,2708050,3363326,
    4194304,
    5237765,6557202,8165337,10153587,12820798,
    15790321,19976592,24970740,31350126,39045157,
    49367440,61356676,76695844,95443717,119304647,
    148102320,186737708,238609294,286331153,360437635
]

// Nova公平调度运行队列 

定义 可变 Nova公平调度运行队列 = 空      // 红黑树(按Nova虚拟运行时间排序)
定义 可变 Nova公平调度进程数 = 0         // nr_queued
定义 可变 最小虚拟运行时间 = 0  // min_Nova虚拟运行时间: 单调递增基准
定义 可变 Nova公平调度总权重 = 0         // load.weight: 所有就绪实体权重之和
定义 可变 Nova公平调度次数 = 0
定义 可变 Nova公平调度_当前执行时间 = 0  // 当前进程已用时间片(us)
// EEVDF: 加权平均Nova虚拟运行时间 (用于place_entity)
定义 可变 Nova公平调度_平均Nova虚拟运行时间加权和 = 0  // \Sum w_i * v_i
定义 可变 Nova公平调度_当前实体 = 空     // Nova公平调度_rq->curr

定义 RT_优先级数 = 100
定义 可变 RT_FIFO队列 = []    // 100个优先级的FIFO队列
定义 可变 RT_进程数 = 0

函数 Nova公平调度_初始化() {
    Nova公平调度运行队列 = 红黑树_创建()
    Nova公平调度进程数 = 0
    Nova公平调度总权重 = 0
    最小虚拟运行时间 = 0
    Nova公平调度次数 = 0
    Nova公平调度_当前执行时间 = 0
    Nova公平调度_平均Nova虚拟运行时间加权和 = 0
    Nova公平调度_当前实体 = 空
    // 初始化RT队列
    RT_FIFO队列 = []
    定义 可变 i = 0
    当 (i < RT_优先级数) { 追加(RT_FIFO队列, [])  i = i + 1 }
    RT_进程数 = 0
}

// nice→权重转换 

函数 nice_到_权重(nice值) {
    定义 索引 = nice值 + 20   // nice -20..19 → 索引 0..39
    如果 (索引 < 0) { 索引 = 0 }
    如果 (索引 > 39) { 索引 = 39 }
    返回 NICE_权重表[索引]
}

函数 nice_到_倒数(nice值) {
    定义 索引 = nice值 + 20
    如果 (索引 < 0) { 索引 = 0 }
    如果 (索引 > 39) { 索引 = 39 }
    返回 NICE_倒数表[索引]
}

// __calc_delta: Nova公平调度的数学核心 
// 计算加权虚拟时间: delta * NICE_0_LOAD / weight
// 高权重进程(低nice): Nova虚拟运行时间增长慢 → 得到更多CPU
// 低权重进程(高nice): Nova虚拟运行时间增长快 → 得到更少CPU

函数 __calc_delta(delta_exec, 权重, 倒数权重) {
    // 当前实现(避免64位溢出): delta * NICE_0_LOAD / weight
    如果 (权重 == NICE_0_权重) { 返回 delta_exec }
    如果 (权重 <= 0) { 返回 delta_exec }
    // 使用倒数避免除法: delta * (NICE_0_LOAD * inv_weight >> 22)
    // 版直接用除法(M1阶段够用, 后续用倒数表优化)
    返回 delta_exec * NICE_0_权重 / 权重
}

函数 calc_delta_fair(delta_exec, 任务) {
    定义 权重 = 任务[T_权重]
    如果 (权重 == NICE_0_权重) { 返回 delta_exec }
    返回 __calc_delta(delta_exec, 权重, nice_到_倒数(任务[T_nice值]))
}

// update_curr: 更新当前运行实体的Nova虚拟运行时间和deadline
// 每次调度决策前调用 — 保证Nova虚拟运行时间是最新的

函数 Nova公平调度_update_curr(当前任务, delta_us) {
    如果 (当前任务 == 空) { 返回 }
    如果 (delta_us <= 0) { 返回 }

    // 1. 更新Nova虚拟运行时间: 加权后的虚拟时间增量
    定义 Nova虚拟运行时间增量 = calc_delta_fair(delta_us, 当前任务)
    设置(当前任务, T_虚拟运行时间, 当前任务[T_虚拟运行时间] + Nova虚拟运行时间增量)

    // 2. EEVDF: 检查deadline是否过期, 过期则更新
    // deadline = Nova虚拟运行时间 + calc_delta_fair(slice, se)
    如果 (当前任务[T_虚拟运行时间] >= 当前任务[T_deadline]) {
        定义 虚拟片 = calc_delta_fair(当前任务[T_时间片], 当前任务)
        设置(当前任务, T_deadline, 当前任务[T_虚拟运行时间] + 虚拟片)
    }

    // 3. 更新min_Nova虚拟运行时间 (单调递增)
    Nova公平调度_更新最小虚拟运行时间_带当前(当前任务)

    // 4. 更新加权平均(用于EEVDF place_entity)
    Nova公平调度_当前执行时间 = Nova公平调度_当前执行时间 + delta_us
}

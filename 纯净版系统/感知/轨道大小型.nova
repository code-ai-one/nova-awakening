函数 网格布局_是否占用(grid, 行, 列) {
    如果 (行 >= grid.占用行数 || 列 >= grid.占用列数) { 返回 假 }
    返回 内存_读8(grid.占用网格 + 行 * grid.占用列数 + 列) != 0
}

// §4 轨道大小计算

函数 网格布局_计算列大小(grid, 可用宽度) {
    定义 可变 固定总宽 = 0
    定义 可变 总fr = 0
    定义 间距总宽 = grid.列间距 * (grid.列数 - 1)

    // 第一遍: 计算固定大小和收集fr
    定义 可变 i = 0
    当 (i < grid.列数) {
        定义 偏移 = grid.列轨道 + i * 32
        定义 类型 = 内存_读32(偏移)
        定义 值 = 内存_读32(偏移 + 4)

        如果 (类型 == 轨道_固定) {
            内存_写32(偏移 + 4, 值)    // 直接使用像素值
            固定总宽 = 固定总宽 + 值
        }
        否则 如果 (类型 == 轨道_百分比) {
            定义 像素 = 可用宽度 * 值 / 10000
            内存_写32(偏移 + 4, 像素)
            固定总宽 = 固定总宽 + 像素
        }
        否则 如果 (类型 == 轨道_fr) {
            总fr = 总fr + 值
        }
        否则 如果 (类型 == 轨道_auto) {
            // auto: 暂时设为0,后面分配剩余空间
            内存_写32(偏移 + 4, 0)
        }
        i = i + 1
    }

    // 第二遍: 分配fr空间
    定义 剩余空间 = 可用宽度 - 固定总宽 - 间距总宽
    如果 (剩余空间 < 0) { 剩余空间 = 0 }

    如果 (总fr > 0) {
        i = 0
        当 (i < grid.列数) {
            定义 偏移 = grid.列轨道 + i * 32
            如果 (内存_读32(偏移) == 轨道_fr) {
                定义 fr值 = 内存_读32(偏移 + 4)
                定义 分配 = 剩余空间 * fr值 / 总fr
                内存_写32(偏移 + 4, 分配)
            }
            i = i + 1
        }
    } 否则 {
        // 没有fr轨道: auto轨道均分剩余空间
        定义 可变 auto数 = 0
        i = 0
        当 (i < grid.列数) {
            如果 (内存_读32(grid.列轨道 + i * 32) == 轨道_auto) { auto数 = auto数 + 1 }
            i = i + 1
        }
        如果 (auto数 > 0) {
            定义 auto大小 = 剩余空间 / auto数
            i = 0
            当 (i < grid.列数) {
                如果 (内存_读32(grid.列轨道 + i * 32) == 轨道_auto) {
                    内存_写32(grid.列轨道 + i * 32 + 4, auto大小)
                }
                i = i + 1
            }
        }
    }
}

函数 网格布局_计算行大小(grid, 可用高度) {
    // 行大小计算: 与列类似,但auto行通常由内容决定
    定义 可变 i = 0
    当 (i < grid.行数) {
        定义 偏移 = grid.行轨道 + i * 32
        定义 类型 = 内存_读32(偏移)
        如果 (类型 == 轨道_固定) {
            // 保持固定值
        }
        否则 如果 (类型 == 轨道_auto || 内存_读32(偏移 + 4) == 0) {
            // auto行: 默认给一个基础高度
            内存_写32(偏移 + 4, 3000)    // 30px默认
        }
        i = i + 1
    }

    // fr行分配
    定义 可变 固定总高 = 0; 定义 可变 总fr = 0
    i = 0
    当 (i < grid.行数) {
        定义 偏移 = grid.行轨道 + i * 32
        如果 (内存_读32(偏移) == 轨道_fr) {
            总fr = 总fr + 内存_读32(偏移 + 4)
        } 否则 {
            固定总高 = 固定总高 + 内存_读32(偏移 + 4)
        }
        i = i + 1
    }

    如果 (总fr > 0 && 可用高度 > 固定总高) {
        定义 剩余 = 可用高度 - 固定总高 - grid.行间距 * (grid.行数 - 1)
        i = 0
        当 (i < grid.行数) {
            定义 偏移 = grid.行轨道 + i * 32
            如果 (内存_读32(偏移) == 轨道_fr) {
                内存_写32(偏移 + 4, 剩余 * 内存_读32(偏移 + 4) / 总fr)
            }
            i = i + 1
        }
    }
}

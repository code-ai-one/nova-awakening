导入("../基础.nova")


// LoRA 适配器
// LoRA: [A矩阵(扁平r*d), B矩阵(扁平d*r), 秩, 学习率, 输入维度]
函数 微调_复制列表(源) { 定义 可变 结果 = []
 定义 可变 i = 0
 当 (i < 计数(源)) {
 追加(结果, 源[i])
 i = i + 1
 }
 返回 结果
}

函数 微调_LoRA_创建(维度, 秩, 学习率) { 定义 可变 A = []
 定义 可变 B = []
 定义 可变 i = 0
 当 (i < 秩 * 维度) { 追加(A, ((i * 7 + 3) % 21) - 10)
 i = i + 1 }
 i = 0
 当 (i < 维度 * 秩) { 追加(B, 0)
 i = i + 1 }
 返回 [A, B, 秩, 学习率, 维度]
}

函数 LoRA_参数数(lora) { 返回 2 * lora[2] * lora[4] }

函数 微调_LoRA_前向(lora, 输入) { 定义 秩 = lora[2]
 定义 维度 = lora[4]
 定义 可变 中间 = []
 定义 可变 r = 0
 当 (r < 秩) { 定义 可变 s = 0
 定义 可变 d = 0
 当 (d < 维度) { s = s + lora[0][r * 维度 + d] * 输入[d]
 d = d + 1 }
 追加(中间, s)
 r = r + 1
 }
 定义 可变 输出 = []
 定义 可变 o = 0
 当 (o < 维度) { 定义 可变 s2 = 0
 r = 0
 当 (r < 秩) { s2 = s2 + lora[1][o * 秩 + r] * 中间[r]
 r = r + 1 }
 追加(输出, s2 * lora[3] / 秩)
 o = o + 1
 }
 返回 输出
}

// 层冻结管理
定义 可变 冻结_层列表 = []

函数 冻结_设置(层数) {
 冻结_层列表 = []
 定义 可变 i = 0
 当 (i < 层数) { 追加(冻结_层列表, 假)
 i = i + 1 }
}

函数 冻结_层(层号) {
    如果 (层号 < 计数(冻结_层列表)) { 冻结_层列表[层号] = 真 }
}
函数 解冻_层(层号) {
    如果 (层号 < 计数(冻结_层列表)) { 冻结_层列表[层号] = 假 }
}
函数 是否冻结(层号) {
    如果 (层号 < 计数(冻结_层列表)) { 返回 冻结_层列表[层号] }
    返回 假
}

函数 可训练参数比(总层数) { 定义 可变 可训练 = 0
 定义 可变 i = 0
 当 (i < 计数(冻结_层列表)) { 如果 (冻结_层列表[i] == 假) { 可训练 = 可训练 + 1 }
 i = i + 1
 }
 如果 (总层数 == 0) { 返回 0 }
 返回 可训练 * 100 / 总层数
}

// 混合专家 (MoE)
// 专家: [权重哈希, 偏置], 路由器选TopK专家
函数 微调_MoE_路由(_输入特征, 专家分数, 前K个) { 定义 可变 选中 = []
 定义 可变 已选 = []
 定义 可变 选了 = 0
 当 (选了 < 前K个) { 定义 可变 最佳 = -1
 定义 可变 最佳分 = 0 - 0x7FFFFFFF
 定义 可变 i = 0
 当 (i < 计数(专家分数)) { 定义 可变 跳过 = 假
 定义 可变 j = 0
 当 (j < 计数(已选)) { 如果 (已选[j] == i) { 跳过 = 真 }
 j = j + 1 }
 如果 (跳过 == 假) { 如果 (专家分数[i] > 最佳分) {
 最佳 = i
 最佳分 = 专家分数[i]
 }
 }
 i = i + 1
 }
 如果 (最佳 >= 0) { 追加(选中, [最佳, 最佳分])
 追加(已选, 最佳) }
 选了 = 选了 + 1
 }
 返回 选中
}

函数 MoE_加权融合(专家输出列表, 权重列表) {
    定义 可变 总权重 = 0
    如果 (计数(专家输出列表) == 0) { 返回 []
}
 定义 维度 = 计数(专家输出列表[0])
 定义 可变 i = 0
 当 (i < 计数(权重列表)) {
 总权重 = 总权重 + 权重列表[i]
 i = i + 1
 }
 如果 (总权重 == 0) { 总权重 = 1 }
 定义 可变 结果 = []
 定义 可变 d = 0
 当 (d < 维度) { 定义 可变 总和 = 0
 i = 0
 当 (i < 计数(专家输出列表)) {
 总和 = 总和 + 专家输出列表[i][d] * 权重列表[i]
 i = i + 1
 }
 追加(结果, 总和 / 总权重)
 d = d + 1
 }
 返回 结果
}

// 知识蒸馏
函数 蒸馏_KL散度(教师logits, 学生logits) {
    如果 (计数(教师logits) == 0) { 返回 0
}
 定义 可变 和 = 0
 定义 可变 i = 0
 当 (i < 计数(教师logits)) { 定义 差 = 教师logits[i] - 学生logits[i]
 和 = 和 + 差 * 差
 i = i + 1
 }
 返回 和 / 计数(教师logits)
}

函数 微调_蒸馏_损失(硬损失, 软损失, 学习率) { 返回 (学习率 * 软损失 + (100 - 学习率) * 硬损失) / 100
}

// 渐进解冻
函数 渐进解冻(当前epoch, 每N解冻) { 定义 n = 计数(冻结_层列表)
 如果 (n == 0) { 返回 }
 定义 可变 解冻数 = 当前epoch / 每N解冻
 如果 (解冻数 > n) { 解冻数 = n }
 // 从最后一层开始解冻
 定义 可变 i = n - 1
 定义 可变 已解 = 0
 当 (i >= 0) { 如果 (已解 >= 解冻数) { 返回 }
 冻结_层列表[i] = 假
 已解 = 已解 + 1
 i = i - 1
 }
}

// 前缀微调
函数 前缀_创建(前缀长度, 维度) { 定义 可变 词元列 = []
 定义 可变 i = 0
 当 (i < 前缀长度) { 定义 可变 向量 = []
 定义 可变 d = 0
 当 (d < 维度) { 追加(向量, ((i * 13 + d * 7) % 201) - 100)
 d = d + 1 }
 追加(词元列, 向量)
 i = i + 1
 }
 返回 词元列
}

函数 前缀_参数数(前缀, 维度) { 返回 计数(前缀) * 维度
}

// 冻结层计数
函数 冻结_层数() { 定义 可变 c = 0
 定义 可变 i = 0
 当 (i < 计数(冻结_层列表)) { 如果 (冻结_层列表[i] == 真) { c = c + 1 }
 i = i + 1
 }
 返回 c
}

// LoRA秩获取
函数 LoRA_秩(lora) { 返回 lora[2] }

// LoRA合并
函数 LoRA_合并到权重(原始权重, lora, 维度) {
 // W' = W + (B @ A) * 学习率/r
 定义 秩 = lora[2]
 定义 可变 结果 = 微调_复制列表(原始权重)
 // 简化: 对角线元素加上LoRA贡献
 定义 可变 d = 0
 当 (d < 维度) { 如果 (d >= 计数(结果)) { 返回 结果 }
 定义 可变 增量 = 0
 定义 可变 r = 0
 当 (r < 秩) {
 增量 = 增量 + lora[1][d * 秩 + r] * lora[0][r * 维度 + d]
 r = r + 1
 }
 结果[d] = 结果[d] + 增量 * lora[3] / 秩
 d = d + 1
 }
 返回 结果
}


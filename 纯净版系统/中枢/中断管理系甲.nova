导入("./类型定义.nova")
导入("./错误码.nova")
导入("./同步原语.nova")
导入("./原子操作.nova")
导入("./内存物理.nova")
导入("../稳态/总线查找设.nova")
导入("../稳态/图处枚举.nova")
导入("../引导/端口输入.nova")
导入("./整数转字符串.nova")
导入("../引导/寄存器定义.nova")
导入("./同步原语生产.nova")
导入("./内核打印.nova")
导入("./每处理器.nova")

定义 中断向量_最小 = 32
定义 中断向量_最大 = 255
定义 中断向量_总数 = 256
定义 中断_NMI = 2
定义 中断_伪中断 = 0xFF
定义 中断_本地定时器 = 0xFE
定义 中断_TLB刷新 = 0xFD
定义 中断_重调度 = 0xFC

定义 中断模式_边沿 = 0
定义 中断模式_电平 = 1

定义 中断标志_共享 = 0x01
定义 中断标志_线程化 = 0x02
定义 中断标志_无均衡 = 0x04

结构 中断统计信息 {
    触发次数,
    处理次数,
    伪中断次数,
    错误次数,
    最后触发时间,
    总处理耗时,
    最大处理耗时,
}

定义 可变 全局_中断统计 = []
定义 可变 全局_NMI计数 = 0
定义 可变 全局_伪中断计数 = 0

函数 中断统计_初始化() {
    如果 (计数(全局_中断统计) == 0) {
        定义 可变 i = 0
        当 (i < 中断向量_总数) {
            定义 s = 中断统计信息 {}
            s.触发次数 = 0
            s.处理次数 = 0
            s.伪中断次数 = 0
            s.错误次数 = 0
            s.最后触发时间 = 0
            s.总处理耗时 = 0
            s.最大处理耗时 = 0
            追加(全局_中断统计, s)
            i = i + 1
        }
    }
}

函数 启用中断(中断号) {
    如果 (中断号 >= 中断向量_总数) { 返回 }
    描述符 := 全局中断管理器.向量表.描述符[中断号]
    如果 描述符 == 空 { 返回 }

    自旋锁加锁(&描述符.锁)

    如果 描述符.深度 > 0 {
        描述符.深度--
        如果 描述符.深度 == 0 且 描述符.芯片 != 空 且 描述符.芯片.启用 != 空 {
            描述符.芯片.启用(描述符)
        }
    }

    自旋锁解锁(&描述符.锁)
}

函数 禁用中断(中断号) {
    如果 (中断号 >= 中断向量_总数) { 返回 }
    描述符 := 全局中断管理器.向量表.描述符[中断号]
    如果 描述符 == 空 { 返回 }

    自旋锁加锁(&描述符.锁)

    描述符.深度++
    如果 描述符.深度 == 1 且 描述符.芯片 != 空 且 描述符.芯片.禁用 != 空 {
        描述符.芯片.禁用(描述符)
    }

    自旋锁解锁(&描述符.锁)
}

函数 注册中断处理器(中断号, 处理函数, 名称, 标志) {
    如果 (中断号 < 中断向量_最小 || 中断号 > 中断向量_最大) {
        返回 错误_无效参数
    }

    描述符 := 全局中断管理器.向量表.描述符[中断号]
    如果 描述符 == 空 { 返回 错误_无效参数 }

    自旋锁加锁(&描述符.锁)

    如果 描述符.处理函数 != 空 且 (标志 & 中断标志_共享) == 0 {
        自旋锁解锁(&描述符.锁)
        返回 错误_资源忙
    }

    定义 动作 = 堆_分配(中断动作)
    动作.处理函数 = 处理函数
    动作.名称 = 名称
    动作.标志 = 标志
    动作.中断号 = 中断号
    动作.下一个 = 描述符.动作链
    描述符.动作链 = 动作

    如果 描述符.处理函数 == 空 {
        描述符.处理函数 = 中断_分发处理
    }

    如果 (标志 & 中断标志_线程化) != 0 {
        动作.线程 = 空
    }

    自旋锁解锁(&描述符.锁)
    返回 0
}

函数 注销中断处理器(中断号, 处理函数) {
    如果 (中断号 >= 中断向量_总数) { 返回 }
    描述符 := 全局中断管理器.向量表.描述符[中断号]
    如果 描述符 == 空 { 返回 }

    自旋锁加锁(&描述符.锁)

    定义 可变 前一个 = 空
    定义 可变 当前 = 描述符.动作链
    当 (当前 != 空) {
        如果 (当前.处理函数 == 处理函数) {
            如果 (前一个 == 空) {
                描述符.动作链 = 当前.下一个
            } 否则 {
                前一个.下一个 = 当前.下一个
            }
            堆_释放(当前)
            跳出
        }
        前一个 = 当前
        当前 = 当前.下一个
    }

    如果 (描述符.动作链 == 空) {
        描述符.处理函数 = 空
    }

    自旋锁解锁(&描述符.锁)
}

函数 中断_分发处理(中断号) {
    中断统计_初始化()
    定义 统计 = 全局_中断统计[中断号]
    统计.触发次数 = 统计.触发次数 + 1

    描述符 := 全局中断管理器.向量表.描述符[中断号]
    如果 描述符 == 空 {
        统计.伪中断次数 = 统计.伪中断次数 + 1
        返回
    }

    定义 开始时间 = 读TSC()

    定义 可变 已处理 = 假
    定义 可变 动作 = 描述符.动作链
    当 (动作 != 空) {
        如果 (动作.标志 & 中断标志_线程化) != 0 {
            定义 结果 = 动作.处理函数(中断号)
            如果 (结果 != 0) { 已处理 = 真 }
        } 否则 {
            定义 结果 = 动作.处理函数(中断号)
            如果 (结果 != 0) { 已处理 = 真 }
        }
        动作 = 动作.下一个
    }

    如果 (!已处理) {
        统计.伪中断次数 = 统计.伪中断次数 + 1
        全局_伪中断计数 = 全局_伪中断计数 + 1
    } 否则 {
        统计.处理次数 = 统计.处理次数 + 1
    }

    定义 耗时 = 读TSC() - 开始时间
    统计.总处理耗时 = 统计.总处理耗时 + 耗时
    如果 (耗时 > 统计.最大处理耗时) {
        统计.最大处理耗时 = 耗时
    }
    统计.最后触发时间 = 开始时间
}

函数 中断线程_入口(动作) {
    当 (真) {
        等待唤醒()
        如果 (动作.处理函数 != 空) {
            动作.处理函数(动作.中断号)
        }
    }
}

函数 处理NMI() {
    全局_NMI计数 = 全局_NMI计数 + 1
    定义 原因 = 端口读8(0x61)
    如果 ((原因 & 0x80) != 0) {
        内核_紧急("NMI: 内存奇偶校验错误")
    }
    如果 ((原因 & 0x40) != 0) {
        内核_紧急("NMI: I/O通道检查错误")
    }
}

函数 检测伪中断(中断号) {
    如果 (中断号 == 7) {
        定义 ISR = 读接口C寄存器(全局中断管理器.接口C.本地接口C虚拟地址, 0x100)
        如果 ((ISR & (1 << 7)) == 0) {
            全局_伪中断计数 = 全局_伪中断计数 + 1
            返回 真
        }
    }
    返回 假
}

函数 接口C启动中断(描述符) {
    如果 描述符.中断号 >= 中断向量_最小 {
        IRQ := 描述符.中断号 - 中断向量_最小
        配置IO_接口C重定向(IRQ, 描述符.中断号, 0)
    }
}

函数 接口C关闭中断(描述符) {
    如果 描述符.中断号 >= 中断向量_最小 {
        IRQ := 描述符.中断号 - 中断向量_最小
        屏蔽IO_接口C引脚(IRQ)
    }
}

函数 接口C启用中断(描述符) {
    如果 描述符.中断号 >= 中断向量_最小 {
        IRQ := 描述符.中断号 - 中断向量_最小
        取消屏蔽IO_接口C引脚(IRQ)
    }
}

函数 接口C禁用中断(描述符) {
    如果 描述符.中断号 >= 中断向量_最小 {
        IRQ := 描述符.中断号 - 中断向量_最小
        屏蔽IO_接口C引脚(IRQ)
    }
}

函数 接口C确认中断(描述符) {
    汇编 { "mov al, 0x20" "out 0x20, al" }
}

函数 接口C结束中断(描述符) {
    基址 := 全局中断管理器.接口C.本地接口C虚拟地址
    写入接口C寄存器(基址, 0xB0, 0)
}

函数 接口C设置亲和性(描述符, CPU掩码) {
    描述符.亲和性掩码 = CPU掩码
    如果 描述符.中断号 >= 中断向量_最小 {
        IRQ := 描述符.中断号 - 中断向量_最小
        定义 目标CPU = 0
        定义 可变 掩码 = CPU掩码
        当 (掩码 != 0 && (掩码 & 1) == 0) {
            目标CPU = 目标CPU + 1
            掩码 = 掩码 >> 1
        }
        更新IO_接口C目标(IRQ, 目标CPU)
    }
    返回 0
}

函数 中断_均衡() {
    中断统计_初始化()
    定义 CPU数 = 获取CPU数量()
    如果 (CPU数 <= 1) { 返回 }

    定义 可变 中断号 = 中断向量_最小
    当 (中断号 <= 中断向量_最大) {
        描述符 := 全局中断管理器.向量表.描述符[中断号]
        如果 (描述符 != 空 && 描述符.动作链 != 空) {
            如果 ((描述符.标志 & 中断标志_无均衡) == 0) {
                定义 目标 = (中断号 - 中断向量_最小) % CPU数
                接口C设置亲和性(描述符, 1 << 目标)
            }
        }
        中断号 = 中断号 + 1
    }
}

函数 配置MSI(PCI设备, 中断号) {
    定义 MSI_CAP = PCI_查找能力(PCI设备, 0x05)
    如果 (MSI_CAP == 0) { 返回 错误_不支持 }

    定义 地址 = 0xFEE00000 | (0 << 12)
    定义 数据 = 中断号 & 0xFF

    PCI_配置写32(PCI设备.总线, PCI设备.设备, PCI设备.功能, MSI_CAP + 4, 地址)
    PCI_配置写16(PCI设备.总线, PCI设备.设备, PCI设备.功能, MSI_CAP + 8, 数据)

    定义 控制 = PCI_配置读16(PCI设备.总线, PCI设备.设备, PCI设备.功能, MSI_CAP + 2)
    PCI_配置写16(PCI设备.总线, PCI设备.设备, PCI设备.功能, MSI_CAP + 2, 控制 | 1)

    返回 0
}

函数 配置MSIX(PCI设备, 中断号, 表索引) {
    定义 MSIX_CAP = PCI_查找能力(PCI设备, 0x11)
    如果 (MSIX_CAP == 0) { 返回 错误_不支持 }

    定义 表BAR = PCI_配置读32(PCI设备.总线, PCI设备.设备, PCI设备.功能, MSIX_CAP + 4)
    定义 BAR索引 = 表BAR & 0x07
    定义 表偏移 = 表BAR & 0xFFFFFFF8

    定义 BAR基址 = PCI_读BAR(PCI设备.总线, PCI设备.设备, PCI设备.功能, BAR索引)
    定义 条目地址 = BAR基址 + 表偏移 + 表索引 * 16

    定义 MSI地址 = 0xFEE00000 | (0 << 12)
    MMIO_写32(条目地址, MSI地址)
    MMIO_写32(条目地址 + 4, 0)
    MMIO_写32(条目地址 + 8, 中断号 & 0xFF)
    MMIO_写32(条目地址 + 12, 0)

    定义 控制 = PCI_配置读16(PCI设备.总线, PCI设备.设备, PCI设备.功能, MSIX_CAP + 2)
    PCI_配置写16(PCI设备.总线, PCI设备.设备, PCI设备.功能, MSIX_CAP + 2, 控制 | 0x8000)

    返回 0
}

函数 中断_打印统计() {
    中断统计_初始化()
    打印行("=== 中断统计 ===")
    打印行("NMI: " + 整数转字符串(全局_NMI计数))
    打印行("伪中断: " + 整数转字符串(全局_伪中断计数))

    定义 可变 i = 中断向量_最小
    当 (i <= 中断向量_最大) {
        定义 s = 全局_中断统计[i]
        如果 (s.触发次数 > 0) {
            打印行("  IRQ " + 整数转字符串(i - 中断向量_最小)
                + " (向量" + 整数转字符串(i) + "): "
                + 整数转字符串(s.触发次数) + " 次"
                + " 处理:" + 整数转字符串(s.处理次数)
                + " 伪:" + 整数转字符串(s.伪中断次数))
        }
        i = i + 1
    }
}

// §8 中断风暴检测与抑制
// 原理: 短时间内同一IRQ触发频率超过阈值 → 自动屏蔽

定义 风暴_阈值 = 10000  // 每秒超过10000次视为风暴
定义 风暴_冷却 = 1000    // 屏蔽1秒后重新启用

定义 可变 风暴_检测计数 = []
定义 可变 风暴_检测窗口 = []
定义 可变 风暴_已屏蔽 = []
定义 可变 风暴_总数 = 0

函数 中断_风暴初始化() {
    如果 (计数(风暴_检测计数) == 0) {
        定义 可变 i = 0
        当 (i < 中断向量_总数) {
            追加(风暴_检测计数, 0)
            追加(风暴_检测窗口, 0)
            追加(风暴_已屏蔽, 0)
            i = i + 1
        }
    }
}

函数 中断_风暴检测(中断号) {
    中断_风暴初始化()
    如果 (中断号 >= 中断向量_总数) { 返回 假 }
    如果 (风暴_已屏蔽[中断号] != 0) { 返回 真 }

    定义 当前时间 = 读TSC()
    定义 窗口 = 当前时间 - 风暴_检测窗口[中断号]

    如果 (窗口 > 1000000) {  // 新窗口(~1秒)
        风暴_检测计数[中断号] = 1
        风暴_检测窗口[中断号] = 当前时间
    } 否则 {
        风暴_检测计数[中断号] = 风暴_检测计数[中断号] + 1
        如果 (风暴_检测计数[中断号] > 风暴_阈值) {
            // 检测到风暴, 屏蔽该中断
            风暴_已屏蔽[中断号] = 当前时间
            风暴_总数 = 风暴_总数 + 1
            禁用中断(中断号)
            内核警告("中断风暴: IRQ" + 整数转字符串(中断号 - 中断向量_最小)
                + " (" + 整数转字符串(风暴_检测计数[中断号]) + "次/秒)")
            返回 真
        }
    }
    返回 假
}

函数 中断_风暴恢复() {
    // 检查所有被屏蔽的中断, 冷却期后恢复
    中断_风暴初始化()
    定义 当前时间 = 读TSC()
    定义 可变 i = 中断向量_最小
    当 (i <= 中断向量_最大) {
        如果 (风暴_已屏蔽[i] != 0) {
            如果 (当前时间 - 风暴_已屏蔽[i] > 风暴_冷却 * 1000) {
                风暴_已屏蔽[i] = 0
                风暴_检测计数[i] = 0
                启用中断(i)
                内核信息("中断恢复: IRQ" + 整数转字符串(i - 中断向量_最小) + " 已重启")
            }
        }
        i = i + 1
    }
}

// §9 中断合并 — 减少高频中断的CPU开销
// 原理: 对共享中断进行批量处理, 降低上下文切换频率

定义 合并_最大批量 = 16
定义 可变 合并_缓冲 = []
定义 可变 合并_计数 = 0

函数 中断_合并_推入(中断号) {
    如果 (合并_计数 >= 合并_最大批量) {
        中断_合并_刷新()
    }
    追加(合并_缓冲, 中断号)
    合并_计数 = 合并_计数 + 1
}

函数 中断_合并_刷新() {
    定义 可变 i = 0
    当 (i < 合并_计数) {
        中断_分发处理(合并_缓冲[i])
        i = i + 1
    }
    合并_缓冲 = []
    合并_计数 = 0
}

// §10 重置与存取器

函数 中断_重置统计() {
    中断统计_初始化()
    全局_NMI计数 = 0
    全局_伪中断计数 = 0
    定义 可变 i = 0
    当 (i < 中断向量_总数) {
        全局_中断统计[i].触发次数 = 0
        全局_中断统计[i].处理次数 = 0
        全局_中断统计[i].伪中断次数 = 0
        全局_中断统计[i].错误次数 = 0
        全局_中断统计[i].总处理耗时 = 0
        全局_中断统计[i].最大处理耗时 = 0
        i = i + 1
    }
    风暴_总数 = 0
}

函数 中断_获取NMI数() { 返回 全局_NMI计数 }
函数 中断_获取伪中断数() { 返回 全局_伪中断计数 }
函数 中断_获取风暴数() { 返回 风暴_总数 }
函数 中断_获取合并数() { 返回 合并_计数 }

函数 中断_获取IRQ统计(中断号) {
    中断统计_初始化()
    如果 (中断号 >= 中断向量_总数) { 返回 空 }
    定义 s = 全局_中断统计[中断号]
    返回 [s.触发次数, s.处理次数, s.伪中断次数, s.错误次数,
           s.总处理耗时, s.最大处理耗时]
}

函数 中断_活跃数() {
    中断统计_初始化()
    定义 可变 活跃 = 0
    定义 可变 i = 中断向量_最小
    当 (i <= 中断向量_最大) {
        如果 (全局_中断统计[i].触发次数 > 0) {
            活跃 = 活跃 + 1
        }
        i = i + 1
    }
    返回 活跃
}

函数 中断_完整统计() {
    中断统计_初始化()
    定义 可变 总触发 = 0
    定义 可变 总处理 = 0
    定义 可变 i = 0
    当 (i < 中断向量_总数) {
        总触发 = 总触发 + 全局_中断统计[i].触发次数
        总处理 = 总处理 + 全局_中断统计[i].处理次数
        i = i + 1
    }
    返回 [
        ["NMI", 全局_NMI计数],
        ["伪中断", 全局_伪中断计数],
        ["总触发", 总触发],
        ["总处理", 总处理],
        ["活跃IRQ", 中断_活跃数()],
        ["风暴次数", 风暴_总数]
    ]
}

函数 中断_健康检查() {
    中断统计_初始化()
    定义 可变 问题 = 0
    // 伪中断过多
    定义 可变 总触发 = 0
    定义 可变 i = 0
    当 (i < 中断向量_总数) {
        总触发 = 总触发 + 全局_中断统计[i].触发次数
        i = i + 1
    }
    如果 (总触发 > 100 && 全局_伪中断计数 > 总触发 / 2) {
        问题 = 问题 + 1  // 伪中断超过50%
    }
    // 风暴频繁
    如果 (风暴_总数 > 10) { 问题 = 问题 + 1 }
    返回 问题 == 0
}

// ◆ IMS 理论 — Interrupt Management System
//   公理1: 中断是硬件到软件的异步事件通知原语
//   公理2: APIC向量映射将物理信号映射到逻辑处理路径
//   公理3: 风暴检测通过频率阈值区分合法突发与异常
//   定理: 中断链式分发保证共享中断的正确性
//         ∀handler∈chain: invoked(handler) → checked(handler)

定义 可变 AI_中断管理系_风暴阈值 = 10000
定义 可变 AI_中断管理系_预测IRQ = 0

函数 AI_中断管理系_风暴检测(触发频率) {
    如果 (触发频率 > AI_中断管理系_风暴阈值) {
        AI_中断管理系_风暴阈值 = AI_中断管理系_风暴阈值 * 3 / 2
        返回 真
    }
    返回 假
}

函数 AI_中断管理系_自适应合并(当前延迟) {
    如果 (当前延迟 < 100) { 返回 16 }
    如果 (当前延迟 < 500) { 返回 8 }
    返回 1
}

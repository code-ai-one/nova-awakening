// NovaOS ext4目录操作
// 功能: ext4目录项查找、添加、删除、遍历及htree索引

定义 EXT4_目录项_头大小      = 8
定义 EXT4_名称最大长度       = 255
定义 EXT4_目录块_尾部大小    = 12

定义 EXT4_FT_未知    = 0
定义 EXT4_FT_普通    = 1
定义 EXT4_FT_目录    = 2
定义 EXT4_FT_字符设备 = 3
定义 EXT4_FT_块设备   = 4
定义 EXT4_FT_管道     = 5
定义 EXT4_FT_套接字   = 6
定义 EXT4_FT_符号链接 = 7

// 目录项磁盘结构

结构 Ext4目录项 {
    Nova文件节点号,
    记录长度,
    名称长度,
    文件类型,
    名称,    // 数组<u8, 255>
}

结构 Ext4目录项尾部 {
    保留_零,
    记录长度,
    名称长度,
    文件类型,
    校验和,
}

// 目录项查找

函数 ext4_查找目录项(sb, 目录Nova文件节点, 名称) {
    定义 信息 = sb.私有信息
    定义 块大小 = 信息.块大小
    定义 目录大小 = 目录Nova文件节点.大小
    定义 ext4信息 = 目录Nova文件节点.私有信息

    // 检查是否使用htree索引
    如果 (ext4信息.标志 & EXT4_Nova文件节点_INDEX) {
        返回 ext4_htree_查找(sb, 目录Nova文件节点, 名称)
    }

    // 线性扫描目录块
    定义 可变 偏移 = 0
    当 (偏移 < 目录大小) {
        定义 逻辑块 = 偏移 / 块大小
        定义 物理块 = ext4_extent_查找(sb, ext4信息, 逻辑块)
        如果 (物理块 == (0 - 1)) {
            偏移 = 偏移 + 块大小
            继续
        }

        定义 缓冲 = 块设备_读(sb.设备, 物理块 * 块大小, 块大小)
        如果 (缓冲 == 空) {
            偏移 = 偏移 + 块大小
            继续
        }

        // 扫描块内所有目录项
        定义 块内偏移起始 = 偏移 % 块大小
        定义 可变 块内偏移 = 0
        当 (块内偏移 < 块大小) {
            定义 项 = ext4_解析目录项(缓冲, 块内偏移)
            如果 (项.记录长度 == 0) { 跳出 }

            如果 (项.Nova文件节点号 != 0 && 项.名称长度 > 0) {
                如果 (ext4_目录项名称匹配(项, 名称)) {
                    缓冲_释放(缓冲)
                    返回 项
                }
            }

            块内偏移 = 块内偏移 + 项.记录长度
        }

        缓冲_释放(缓冲)
        偏移 = 偏移 + 块大小
    }

    返回 空
}

// 目录项添加

函数 ext4_添加目录项(sb, 目录Nova文件节点, 名称, 子Nova文件节点号, 文件类型) {
    定义 信息 = sb.私有信息
    定义 块大小 = 信息.块大小
    定义 ext4信息 = 目录Nova文件节点.私有信息

    定义 需要长度 = ext4_目录项实际长度(字符串_长度(名称))

    // 扫描现有块寻找空闲空间
    定义 目录大小 = 目录Nova文件节点.大小
    定义 可变 偏移 = 0
    当 (偏移 < 目录大小) {
        定义 逻辑块 = 偏移 / 块大小
        定义 物理块 = ext4_extent_查找(sb, ext4信息, 逻辑块)
        如果 (物理块 == (0 - 1)) {
            偏移 = 偏移 + 块大小
            继续
        }

        定义 可变 缓冲 = 块设备_读(sb.设备, 物理块 * 块大小, 块大小)
        如果 (缓冲 == 空) {
            偏移 = 偏移 + 块大小
            继续
        }

        // 查找有足够空间的目录项(可能在已有项后面有空间)
        定义 可变 块内偏移 = 0
        当 (块内偏移 < 块大小) {
            定义 项 = ext4_解析目录项(缓冲, 块内偏移)
            如果 (项.记录长度 == 0) { 跳出 }

            定义 实际占用 = ext4_目录项实际长度(项.名称长度)
            定义 空闲空间 = 项.记录长度 - 实际占用

            如果 (项.Nova文件节点号 == 0 && 项.记录长度 >= 需要长度) {
                // 空目录项，直接使用
                ext4_写入目录项(缓冲, 块内偏移, 子Nova文件节点号, 名称, 文件类型, 项.记录长度)
                块设备_写(sb.设备, 物理块 * 块大小, 缓冲, 块大小)
                缓冲_释放(缓冲)
                返回 0
            }

            如果 (空闲空间 >= 需要长度) {
                // 分裂目录项
                定义 新记录长度 = 项.记录长度 - 实际占用
                项.记录长度 = 实际占用
                ext4_写回目录项(缓冲, 块内偏移, 项)

                定义 新偏移 = 块内偏移 + 实际占用
                ext4_写入目录项(缓冲, 新偏移, 子Nova文件节点号, 名称, 文件类型, 新记录长度)
                块设备_写(sb.设备, 物理块 * 块大小, 缓冲, 块大小)
                缓冲_释放(缓冲)
                返回 0
            }

            块内偏移 = 块内偏移 + 项.记录长度
        }

        缓冲_释放(缓冲)
        偏移 = 偏移 + 块大小
    }

    // 现有块无空间，分配新块
    返回 ext4_目录扩展块(sb, 目录Nova文件节点, 子Nova文件节点号, 名称, 文件类型)
}

函数 ext4_目录扩展块(sb, 目录Nova文件节点, 子Nova文件节点号, 名称, 文件类型) {
    定义 信息 = sb.私有信息
    定义 块大小 = 信息.块大小
    定义 ext4信息 = 目录Nova文件节点.私有信息

    // 分配新数据块
    定义 新物理块 = ext4_分配块(sb, 1)
    如果 (新物理块 == 0) {
        返回 错误码_无空间
    }

    // 添加extent映射
    定义 新逻辑块 = 目录Nova文件节点.大小 / 块大小
    ext4_extent_插入(sb, ext4信息, 新逻辑块, 新物理块, 1)

    // 初始化新块
    定义 可变 缓冲 = 分配内存(块大小)
    内存置零(缓冲, 块大小)

    // 写入目录项，记录长度填满整个块
    ext4_写入目录项(缓冲, 0, 子Nova文件节点号, 名称, 文件类型, 块大小)

    块设备_写(sb.设备, 新物理块 * 块大小, 缓冲, 块大小)
    释放内存(缓冲)

    // 更新目录Nova文件节点大小
    目录Nova文件节点.大小 = 目录Nova文件节点.大小 + 块大小
    ext4信息.已脏 = 真
    返回 0
}

定义 可变 AI_扩展查找目_热文件表 = []

函数 AI_扩展查找目_访问模式(路径) {
    定义 可变 i = 0
    当 (i < 计数(AI_扩展查找目_热文件表)) {
        如果 (AI_扩展查找目_热文件表[i].路径 == 路径) {
            AI_扩展查找目_热文件表[i].频率 = AI_扩展查找目_热文件表[i].频率 + 1
            返回 AI_扩展查找目_热文件表[i].频率
        }
        i = i + 1
    }
    如果 (计数(AI_扩展查找目_热文件表) < 128) {
        追加(AI_扩展查找目_热文件表, { 路径: 路径, 频率: 1 })
    }
    返回 1
}

函数 AI_扩展查找目_预读建议(文件大小, 已读偏移) {
    如果 (已读偏移 > 文件大小 * 80 / 100) { 返回 0 }
    返回 32768
}

导入("../../../标准库/基础.nova")
导入("../../../编译器/规划/类型系统/基础类型/基础类型.nova")

// Nova 平台层 WebAssembly 编码兼容器
// 目标: 保持旧接口稳定, 让 Stage1/Stage2 能可靠编译通过

定义 WASM_魔数_0 = 0x00
定义 WASM_魔数_1 = 0x61
定义 WASM_魔数_2 = 0x73
定义 WASM_魔数_3 = 0x6D
定义 WASM_版本 = 1

定义 WASM编码器_类型_列表 = 5
定义 WASM编码器_类型_字典 = 6
定义 WASM编码器_类型_函数 = 7
定义 WASM编码器_类型_任意 = 9


函数 编码_uleb128(值) {
    定义 可变 结果 = []
    定义 可变 v = 值
    定义 可变 完成 = 假
    当 (完成 == 假) {
        定义 字节 = v & 0x7F
        v = v >> 7
        如果 (v == 0) {
            追加(结果, 字节)
            完成 = 真
        } 否则 {
            追加(结果, 字节 | 0x80)
        }
    }
    返回 结果
}

函数 编码_sleb128(值) {
    定义 可变 结果 = []
    定义 可变 v = 值
    定义 可变 完成 = 假
    当 (完成 == 假) {
        定义 字节 = v & 0x7F
        定义 符号位 = 字节 & 0x40
        v = v >> 7
        如果 (v == 0) {
            如果 (符号位 == 0) {
                追加(结果, 字节)
                完成 = 真
            } 否则 {
                追加(结果, 字节 | 0x80)
            }
        } 否则 {
            如果 (v == 0 - 1) {
                如果 (符号位 == 0) {
                    追加(结果, 字节 | 0x80)
                } 否则 {
                    追加(结果, 字节)
                    完成 = 真
                }
            } 否则 {
                追加(结果, 字节 | 0x80)
            }
        }
    }
    返回 结果
}

函数 WASM_模块头() {
    返回 [WASM_魔数_0, WASM_魔数_1, WASM_魔数_2, WASM_魔数_3,
       WASM_版本, 0x00, 0x00, 0x00]
}

函数 编码_函数类型(参数列表, 返回列表) {
    定义 可变 结果 = [0x60]
    定义 参数数编码 = 编码_uleb128(计数(参数列表))
    定义 可变 i = 0
    当 (i < 计数(参数数编码)) {
        追加(结果, 参数数编码[i])
        i = i + 1
    }
    i = 0
    当 (i < 计数(参数列表)) {
        追加(结果, 参数列表[i])
        i = i + 1
    }
    定义 返回数编码 = 编码_uleb128(计数(返回列表))
    i = 0
    当 (i < 计数(返回数编码)) {
        追加(结果, 返回数编码[i])
        i = i + 1
    }
    i = 0
    当 (i < 计数(返回列表)) {
        追加(结果, 返回列表[i])
        i = i + 1
    }
    返回 结果
}

函数 WASM_封装段(段id, 内容) {
    定义 可变 结果 = [段id]
    定义 长度编码 = 编码_uleb128(计数(内容))
    定义 可变 i = 0
    当 (i < 计数(长度编码)) {
        追加(结果, 长度编码[i])
        i = i + 1
    }
    i = 0
    当 (i < 计数(内容)) {
        追加(结果, 内容[i])
        i = i + 1
    }
    返回 结果
}

函数 编码_导出(名称字节, 类型, 索引) {
    定义 可变 结果 = []
    定义 名称长度编码 = 编码_uleb128(计数(名称字节))
    定义 可变 i = 0
    当 (i < 计数(名称长度编码)) {
        追加(结果, 名称长度编码[i])
        i = i + 1
    }
    i = 0
    当 (i < 计数(名称字节)) {
        追加(结果, 名称字节[i])
        i = i + 1
    }
    追加(结果, 类型)
    定义 索引编码 = 编码_uleb128(索引)
    i = 0
    当 (i < 计数(索引编码)) {
        追加(结果, 索引编码[i])
        i = i + 1
    }
    返回 结果
}

函数 编码_内存(最小页) {
    定义 可变 结果 = [0x00]
    定义 编码 = 编码_uleb128(最小页)
    定义 可变 i = 0
    当 (i < 计数(编码)) {
        追加(结果, 编码[i])
        i = i + 1
    }
    返回 结果
}

函数 wasm_类型名(id) {
    如果 (id == 类型_空) {
        返回 "空"
    }
    如果 (id == 类型_布尔) {
        返回 "布尔"
    }
    如果 (id == 类型_整数) {
        返回 "整数"
    }
    如果 (id == 类型_浮点) {
        返回 "浮点"
    }
    如果 (id == 类型_字符串) {
        返回 "字符串"
    }
    如果 (id == WASM编码器_类型_列表) {
        返回 "列表"
    }
    如果 (id == WASM编码器_类型_字典) {
        返回 "字典"
    }
    如果 (id == WASM编码器_类型_函数) {
        返回 "函数"
    }
    如果 (id == 类型_结构) {
        返回 "结构"
    }
    如果 (id == 类型_枚举) {
        返回 "枚举"
    }
    如果 (id == 类型_接口) {
        返回 "接口"
    }
    如果 (id == 类型_泛型) {
        返回 "泛型"
    }
    如果 (id == WASM编码器_类型_任意) {
        返回 "任意"
    }
    返回 "unknown"
}

函数 BT_是数值(t) {
    如果 (t == 类型_整数) {
        返回 真
    }
    如果 (t == 类型_浮点) {
        返回 真
    }
    返回 假
}

函数 wasm_是集合(t) {
    如果 (t == WASM编码器_类型_列表) {
        返回 真
    }
    如果 (t == WASM编码器_类型_字典) {
        返回 真
    }
    返回 假
}

函数 wasm_是可索引(t) {
    如果 (t == 类型_字符串) {
        返回 真
    }
    如果 (是集合(t)) {
        返回 真
    }
    返回 假
}

函数 wasm_是可迭代(t) {
    返回 是可索引(t)
}

函数 wasm_是可调用(t) {
    返回 t == WASM编码器_类型_函数
}

函数 wasm_是引用类型(t) {
    如果 (t == 类型_字符串) {
        返回 真
    }
    如果 (t == WASM编码器_类型_列表) {
        返回 真
    }
    如果 (t == WASM编码器_类型_字典) {
        返回 真
    }
    如果 (t == WASM编码器_类型_函数) {
        返回 真
    }
    如果 (t == 类型_结构) {
        返回 真
    }
    如果 (t == 类型_接口) {
        返回 真
    }
    如果 (t == 类型_泛型) {
        返回 真
    }
    返回 假
}

函数 BT_二元结果类型(op, 左, 右) {
    如果 (op == "+") {
        如果 (左 == 类型_字符串) {
            如果 (右 == 类型_字符串) {
                返回 类型_字符串
            }
        }
    }
    如果 (BT_是数值(左)) {
        如果 (BT_是数值(右)) {
            如果 (左 == 类型_浮点) {
                返回 类型_浮点
            }
            如果 (右 == 类型_浮点) {
                返回 类型_浮点
            }
            返回 类型_整数
        }
    }
    如果 (op == "==") {
        返回 类型_布尔
    }
    如果 (op == "!=") {
        返回 类型_布尔
    }
    如果 (op == "<") {
        返回 类型_布尔
    }
    如果 (op == ">") {
        返回 类型_布尔
    }
    如果 (op == "<=") {
        返回 类型_布尔
    }
    如果 (op == ">=") {
        返回 类型_布尔
    }
    返回 WASM编码器_类型_任意
}

函数 BT_一元结果类型(op, 操作数) {
    如果 (op == "!") {
        返回 类型_布尔
    }
    如果 (op == "-") {
        如果 (BT_是数值(操作数)) {
            返回 操作数
        }
    }
    返回 操作数
}

函数 wasm_类型兼容(期望, 实际) {
    如果 (期望 == WASM编码器_类型_任意) {
        返回 真
    }
    如果 (期望 == 实际) {
        返回 真
    }
    如果 (BT_是数值(期望)) {
        如果 (BT_是数值(实际)) {
            返回 真
        }
    }
    返回 假
}

函数 wasm_可强转(源, 目标) {
    如果 (源 == 目标) {
        返回 真
    }
    如果 (BT_是数值(源)) {
        如果 (BT_是数值(目标)) {
            返回 真
        }
    }
    如果 (目标 == 类型_字符串) {
        返回 真
    }
    如果 (目标 == 类型_布尔) {
        返回 真
    }
    返回 假
}

函数 wasm_类型大小(t) {
    如果 (t == 类型_空) {
        返回 0
    }
    如果 (t == 类型_布尔) {
        返回 1
    }
    如果 (t == 类型_整数) {
        返回 8
    }
    如果 (t == 类型_浮点) {
        返回 8
    }
    如果 (t == 类型_字符串) {
        返回 16
    }
    如果 (t == WASM编码器_类型_列表) {
        返回 16
    }
    如果 (t == WASM编码器_类型_字典) {
        返回 16
    }
    如果 (t == WASM编码器_类型_函数) {
        返回 8
    }
    如果 (t == 类型_结构) {
        返回 16
    }
    如果 (t == 类型_枚举) {
        返回 8
    }
    如果 (t == 类型_接口) {
        返回 16
    }
    如果 (t == 类型_泛型) {
        返回 8
    }
    返回 8
}

函数 wasm_类型对齐(t) {
    如果 (t == 类型_布尔) {
        返回 1
    }
    返回 8
}

函数 wasm_别名表_创建() {
    返回 []
}

函数 wasm_别名表_注册(表, 别名, 原类型) {
    追加(表, [别名, 原类型])
}

函数 wasm_别名表_解析(表, 别名) {
    定义 可变 i = 0
    当 (i < 计数(表)) {
        如果 (表[i][0] == 别名) {
            返回 表[i][1]
        }
        i = i + 1
    }
    返回 别名
}

函数 wasm_类型环境_创建() {
    返回 [[], 空]
}

函数 wasm_类型环境_子(父) {
    返回 [[], 父]
}

函数 wasm_类型环境_绑定(env, 名id, 类型id) {
    追加(env[0], [名id, 类型id])
}


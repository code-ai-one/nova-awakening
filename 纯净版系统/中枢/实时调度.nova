导入("./类型定义.nova")
导入("./错误码.nova")
导入("./链表后继.nova")
导入("./公平调度睡.nova")
导入("./内核打印.nova")
导入("./抢占控制.nova")
导入("./时钟中枢.nova")
导入("./进程描述符.nova")
导入("./整数转字符串.nova")

//   1. SCHED_FIFO: 先进先出(同优先级不抢占, 高优先级立即抢占)
//   2. SCHED_RR: 轮转(同优先级时间片轮转, 默认100ms)
//   3. 优先级: 1-99 (99最高), 实时优先级始终高于Nova公平调度
//   4. RT bandwidth: 默认95%CPU给RT(防止RT饿死普通进程)
//   5. RT throttling: RT进程超过带宽限制时被限流

定义 SCHED_FIFO = 1
定义 SCHED_RR   = 2

定义 RT_PRIO_MIN = 1
定义 RT_PRIO_MAX = 99

定义 RR_TIMESLICE_MS = 100    // SCHED_RR默认时间片

定义 RT_BANDWIDTH_PERIOD_US = 1000000   // 1秒
定义 RT_BANDWIDTH_RUNTIME_US = 950000   // 950ms (95%)

结构 RT运行队列 {
    // 优先级位图: 100个优先级(0-99)
    活跃位图,    // [] 哪些优先级有可运行任务
    队列,    // [] 100个FIFO队列(每个优先级一个)
    任务数,
    最高优先级,    // u32 当前最高优先级(缓存)

    // 带宽控制
    运行时间_us,    // u64 当前周期已使用的RT时间
    周期开始,    // u64 当前周期起始时间
    被限流,    // u8 是否被限流
}

定义 可变 rt_rq = 空
定义 可变 rt_调度次数 = 0

// 初始化

函数 RT调度器_初始化() {
    rt_rq = RT运行队列 {}
    rt_rq.活跃位图 = []
    rt_rq.队列 = []
    定义 可变 i = 0
    当 (i < 100) {
        追加(rt_rq.活跃位图, 0)
        追加(rt_rq.队列, [])
        i = i + 1
    }
    rt_rq.任务数 = 0
    rt_rq.最高优先级 = 0
    rt_rq.运行时间_us = 0
    rt_rq.周期开始 = 0
    rt_rq.被限流 = 0
    内核信息("RT调度器: 初始化 (FIFO+RR, 优先级1-99)")
}

// 入队/出队 

函数 rt_入队_实时(任务, 优先级) {    // 实时专用版(调度核心调用Nova公平调度器.nova的版本)
    如果 (优先级 < RT_PRIO_MIN || 优先级 > RT_PRIO_MAX) { 返回 }
    追加(rt_rq.队列[优先级], 任务)
    设置(rt_rq.活跃位图, 优先级, 1)
    rt_rq.任务数 = rt_rq.任务数 + 1
    如果 (优先级 > rt_rq.最高优先级) { rt_rq.最高优先级 = 优先级 }
}

函数 rt_出队_实时(任务, 优先级) {
    如果 (优先级 < RT_PRIO_MIN || 优先级 > RT_PRIO_MAX) { 返回 }
    定义 队列 = rt_rq.队列[优先级]
    定义 可变 i = 0
    当 (i < 计数(队列)) {
        如果 (队列[i] == 任务) {
            链表_删除(队列, i)
            中断
        }
        i = i + 1
    }
    如果 (计数(队列) == 0) { 设置(rt_rq.活跃位图, 优先级, 0) }
    rt_rq.任务数 = rt_rq.任务数 - 1
    // 重新计算最高优先级
    如果 (优先级 == rt_rq.最高优先级) { rt_rq.最高优先级 = RT_找最高优先级() }
}

// 选择下一个RT任务 

函数 rt_选择下一个_实时() {
    如果 (rt_rq.任务数 == 0) { 返回 空 }
    如果 (rt_rq.被限流 != 0) { 返回 空 }  // 被限流

    定义 优先级 = rt_rq.最高优先级
    定义 队列 = rt_rq.队列[优先级]
    如果 (计数(队列) == 0) { 返回 空 }

    rt_调度次数 = rt_调度次数 + 1
    返回 队列[0]   // FIFO: 取队首
}

// RT tick处理 

函数 rt_tick_实时(当前任务) {
    如果 (当前任务 == 空) { 返回 }

    // 带宽记账
    rt_rq.运行时间_us = rt_rq.运行时间_us + 1000  // 1ms per tick
    RT_检查带宽()

    // SCHED_RR: 时间片耗尽时轮转
    定义 策略 = 进程_调度策略(当前任务)
    如果 (策略 == SCHED_RR) {
        定义 剩余 = 进程_时间片(当前任务) - 1
        进程_设置时间片(当前任务, 剩余)
        如果 (剩余 <= 0) {
            // 时间片耗尽: 移到队列尾部
            定义 优先级 = 进程_RT优先级(当前任务)
            RT_出队(当前任务)
            进程_设置时间片(当前任务, RR_TIMESLICE_MS)
            RT_入队(当前任务)
            // 标记需要重新调度
            进程_设置需要调度(当前任务)
        }
    }
    // SCHED_FIFO: 不主动让出(除非被更高优先级抢占)
}

// RT带宽控制 
// 防止RT进程饿死普通进程

函数 RT_检查带宽() {
    定义 当前时间 = 读取微秒()
    // 新周期开始
    如果 (当前时间 - rt_rq.周期开始 >= RT_BANDWIDTH_PERIOD_US) {
        rt_rq.周期开始 = 当前时间
        rt_rq.运行时间_us = 0
        rt_rq.被限流 = 0
    }
    // 超过带宽限制
    如果 (rt_rq.运行时间_us >= RT_BANDWIDTH_RUNTIME_US && rt_rq.被限流 == 0) {
        rt_rq.被限流 = 1
        内核调试("RT: 带宽限流 (已用" + 整数转字符串(rt_rq.运行时间_us / 1000) + "ms)")
    }
}

// 辅助

函数 RT_找最高优先级() {
    定义 可变 p = RT_PRIO_MAX
    当 (p >= RT_PRIO_MIN) {
        如果 (rt_rq.活跃位图[p] != 0) { 返回 p }
        p = p - 1
    }
    返回 0
}

函数 RT_有任务() { 返回 rt_rq.任务数 > 0 && rt_rq.被限流 == 0 }
函数 RT_任务数() { 返回 rt_rq.任务数 }
函数 RT_统计() { 返回 [rt_调度次数, rt_rq.任务数, rt_rq.最高优先级] }

函数 进程_调度策略_RT(p) {
    如果 (p == 空) { 返回 0 }
    返回 p.调度策略   // 0=Nova公平调度, 1=FIFO, 2=RR
}

函数 进程_时间片(p) {
    如果 (p == 空) { 返回 0 }
    返回 p.时间片
}

函数 进程_设置时间片(p, v) {
    如果 (p == 空) { 返回 }
    p.时间片 = v
}

函数 进程_RT优先级(p) {
    如果 (p == 空) { 返回 0 }
    返回 p.rt优先级
}

函数 进程_设置需要调度(p) {
    如果 (p == 空) { 返回 }
    // 设置TIF_NEED_RESCHED标志, 下次返回用户态或preempt_enable时触发调度
    p.需要调度 = 真
    set_need_resched()
}

函数 读取微秒_RT() { 返回 读取纳秒() / 1000 }

// RT策略名称 + 带宽使用率

函数 RT策略名(策略) {
    如果 (策略 == SCHED_FIFO) { 返回 "SCHED_FIFO" }
    如果 (策略 == SCHED_RR) { 返回 "SCHED_RR" }
    返回 "SCHED_OTHER"
}

函数 RT_带宽使用率() {
    如果 (RT_BANDWIDTH_RUNTIME_US == 0) { 返回 0 }
    返回 rt_rq.运行时间_us * 100 / RT_BANDWIDTH_RUNTIME_US
}

函数 RT_完整统计() {
    返回 [rt_调度次数, rt_rq.任务数, rt_rq.最高优先级, rt_rq.被限流, RT_带宽使用率()]
}

定义 可变 AI_实时调度_负载窗口 = []

函数 AI_实时调度_负载预测(当前负载) {
    追加(AI_实时调度_负载窗口, 当前负载)
    如果 (计数(AI_实时调度_负载窗口) > 20) { 列表_移除(AI_实时调度_负载窗口, 0) }
    如果 (计数(AI_实时调度_负载窗口) < 3) { 返回 当前负载 }
    定义 n = 计数(AI_实时调度_负载窗口)
    定义 趋势 = AI_实时调度_负载窗口[n-1] - AI_实时调度_负载窗口[n-3]
    返回 当前负载 + 趋势
}

函数 AI_实时调度_迁移建议(源CPU负载, 目标CPU负载) {
    如果 (源CPU负载 > 目标CPU负载 * 2) { 返回 真 }
    返回 假
}

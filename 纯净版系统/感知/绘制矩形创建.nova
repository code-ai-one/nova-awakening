// SkRect / SkIRect / SkRRect — 矩形 (头文件模块

导入("../稳态/图处显示.nova")
导入("./内核直连层.nova")
导入("../推理/值乘.nova")

结构 SkRect {
    左,    // i32 ×100
    上,
    右,
    下,
}


函数 SkRect_创建(左, 上, 右, 下) {
    定义 r = SkRect {}
    r.左 = 左; r.上 = 上; r.右 = 右; r.下 = 下
    返回 r
}

函数 SkRect_宽(r) { 返回 r.右 - r.左 }
函数 SkRect_高(r) { 返回 r.下 - r.上 }
函数 SkRect_包含点(r, x, y) {
    返回 x >= r.左 && x < r.右 && y >= r.上 && y < r.下
}

结构 SkRRect {
    矩形,    // SkRect
    圆角_左上,    // i32 ×100
    圆角_右上,
    圆角_左下,
    圆角_右下,
}

函数 SkRRect_创建(矩形, 半径) {
    定义 rr = SkRRect {}
    rr.矩形 = 矩形
    rr.圆角_左上 = 半径
    rr.圆角_右上 = 半径
    rr.圆角_左下 = 半径
    rr.圆角_右下 = 半径
    返回 rr
}

// SkMatrix — 3x3变换矩阵 (头文件模块
// [ScaleX  SkewX   TransX]
// [SkewY   ScaleY  TransY]
// [Persp0  Persp1  Persp2]

结构 SkMatrix {
    // 9个元素 (×10000 定点数)
    m00,    // i32, m01: i32, m02: i32
    m10,    // i32, m11: i32, m12: i32
    m20,    // i32, m21: i32, m22: i32
}

函数 SkMatrix_单位矩阵() {
    定义 m = SkMatrix {}
    m.m00 = 10000; m.m01 = 0; m.m02 = 0
    m.m10 = 0; m.m11 = 10000; m.m12 = 0
    m.m20 = 0; m.m21 = 0; m.m22 = 10000
    返回 m
}

函数 SkMatrix_平移(tx, ty) {
    定义 m = SkMatrix_单位矩阵()
    m.m02 = tx * 10000 / 100    // 输入×100 → 矩阵×10000
    m.m12 = ty * 10000 / 100
    返回 m
}

函数 SkMatrix_缩放(sx, sy) {
    定义 m = SkMatrix_单位矩阵()
    m.m00 = sx * 100    // 输入×100 → ×10000
    m.m11 = sy * 100
    返回 m
}

函数 SkMatrix_乘(a, b) {
    定义 结果 = SkMatrix {}
    结果.m00 = (a.m00 * b.m00 + a.m01 * b.m10 + a.m02 * b.m20) / 10000
    结果.m01 = (a.m00 * b.m01 + a.m01 * b.m11 + a.m02 * b.m21) / 10000
    结果.m02 = (a.m00 * b.m02 + a.m01 * b.m12 + a.m02 * b.m22) / 10000
    结果.m10 = (a.m10 * b.m00 + a.m11 * b.m10 + a.m12 * b.m20) / 10000
    结果.m11 = (a.m10 * b.m01 + a.m11 * b.m11 + a.m12 * b.m21) / 10000
    结果.m12 = (a.m10 * b.m02 + a.m11 * b.m12 + a.m12 * b.m22) / 10000
    结果.m20 = (a.m20 * b.m00 + a.m21 * b.m10 + a.m22 * b.m20) / 10000
    结果.m21 = (a.m20 * b.m01 + a.m21 * b.m11 + a.m22 * b.m21) / 10000
    结果.m22 = (a.m20 * b.m02 + a.m21 * b.m12 + a.m22 * b.m22) / 10000
    返回 结果
}

函数 SkMatrix_变换点(m, x, y) {
    // 输出 [新x, 新y] (×100)
    定义 新x = (m.m00 * x + m.m01 * y + m.m02 * 100) / 10000
    定义 新y = (m.m10 * x + m.m11 * y + m.m12 * 100) / 10000
    返回 [新x, 新y]
}

// NRGP理论 — Nova矩形几何基元理论
// (Nova Rect Geometry Primitive Theory)
// 原创定点数两体变换 + 完整路径算法 + 裁剪 + AI几何预测
// 核心创新: 内整数允溢操作 + 矩形交集/并集 + Bresenham弧线

定义 NRGP_版本 = 1
定义 NRGP_AI特征维度 = 8
定义 NRGP_路径最大动词 = 256
定义 NRGP_路径最大点 = 512

定义 可变 NRGP_矩形操作数 = 0
定义 可变 NRGP_路径操作数 = 0
定义 可变 NRGP_变换操作数 = 0
定义 可变 NRGP_AI推理次数 = 0

// 由一系列动词(verb)和点(point)组成

定义 动词_移动 = 0
定义 动词_直线 = 1
定义 动词_二次曲线 = 2
定义 动词_三次曲线 = 3
定义 动词_关闭 = 4

结构 SkPath {
    动词数组,
    点数组,
    动词数,
    点数,
    填充规则   // 0=奇偶规则, 1=非零规则
}

函数 SkPath_创建() {
    定义 p = 堆_分配(SkPath)
    p.动词数组 = 数组_创建(NRGP_路径最大动词)
    p.点数组 = 数组_创建(NRGP_路径最大点 * 2)  // x,y交替
    p.动词数 = 0
    p.点数 = 0
    p.填充规则 = 1  // 默认非零
    NRGP_路径操作数 = NRGP_路径操作数 + 1
    返回 p
}

函数 SkPath_移动到(p, x, y) {
    如果 (p.动词数 >= NRGP_路径最大动词) { 返回 }
    p.动词数组[p.动词数] = 动词_移动
    p.动词数 = p.动词数 + 1
    定义 idx = p.点数 * 2
    p.点数组[idx] = x
    p.点数组[idx + 1] = y
    p.点数 = p.点数 + 1
}

函数 SkPath_直线到(p, x, y) {
    如果 (p.动词数 >= NRGP_路径最大动词) { 返回 }
    p.动词数组[p.动词数] = 动词_直线
    p.动词数 = p.动词数 + 1
    定义 idx = p.点数 * 2
    p.点数组[idx] = x
    p.点数组[idx + 1] = y
    p.点数 = p.点数 + 1
}

函数 SkPath_二次曲线到(p, cx, cy, x, y) {
    如果 (p.动词数 >= NRGP_路径最大动词) { 返回 }
    p.动词数组[p.动词数] = 动词_二次曲线
    p.动词数 = p.动词数 + 1
    定义 idx = p.点数 * 2
    p.点数组[idx] = cx
    p.点数组[idx + 1] = cy
    p.点数组[idx + 2] = x
    p.点数组[idx + 3] = y
    p.点数 = p.点数 + 2
}

函数 SkPath_三次曲线到(p, c1x, c1y, c2x, c2y, x, y) {
    如果 (p.动词数 >= NRGP_路径最大动词) { 返回 }
    p.动词数组[p.动词数] = 动词_三次曲线
    p.动词数 = p.动词数 + 1
    定义 idx = p.点数 * 2
    p.点数组[idx] = c1x
    p.点数组[idx + 1] = c1y
    p.点数组[idx + 2] = c2x
    p.点数组[idx + 3] = c2y
    p.点数组[idx + 4] = x
    p.点数组[idx + 5] = y
    p.点数 = p.点数 + 3
}

函数 SkPath_关闭(p) {
    如果 (p.动词数 >= NRGP_路径最大动词) { 返回 }
    p.动词数组[p.动词数] = 动词_关闭
    p.动词数 = p.动词数 + 1
}

函数 SkPath_重置(p) {
    p.动词数 = 0
    p.点数 = 0
}

函数 SkPath_释放(p) {
    如果 (p != 0) {
        堆_释放(p.动词数组)
        堆_释放(p.点数组)
        堆_释放(p)
    }
}

// 添加矩形路径
函数 SkPath_添加矩形(p, r) {
    SkPath_移动到(p, r.左, r.上)
    SkPath_直线到(p, r.右, r.上)
    SkPath_直线到(p, r.右, r.下)
    SkPath_直线到(p, r.左, r.下)
    SkPath_关闭(p)
}

// 计算路径边界框
函数 SkPath_边界框(p) {
    如果 (p.点数 == 0) {
        返回 SkRect_创建(0, 0, 0, 0)
    }
    定义 可变 最小x = p.点数组[0]
    定义 可变 最小y = p.点数组[1]
    定义 可变 最大x = 最小x
    定义 可变 最大y = 最小y
    定义 可变 i = 1
    当 (i < p.点数) {
        定义 px = p.点数组[i * 2]
        定义 py = p.点数组[i * 2 + 1]
        如果 (px < 最小x) { 最小x = px }
        如果 (px > 最大x) { 最大x = px }
        如果 (py < 最小y) { 最小y = py }
        如果 (py > 最大y) { 最大y = py }
        i = i + 1
    }
    返回 SkRect_创建(最小x, 最小y, 最大x, 最大y)
}

// §5 矩形运算 (交集/并集/内缩/外扩)

函数 SkRect_交集(a, b) {
    定义 左 = a.左
    如果 (b.左 > 左) { 左 = b.左 }
    定义 上 = a.上
    如果 (b.上 > 上) { 上 = b.上 }
    定义 右 = a.右
    如果 (b.右 < 右) { 右 = b.右 }
    定义 下 = a.下
    如果 (b.下 < 下) { 下 = b.下 }
    // 无交集返回空矩形
    如果 (左 >= 右 || 上 >= 下) {
        返回 SkRect_创建(0, 0, 0, 0)
    }
    NRGP_矩形操作数 = NRGP_矩形操作数 + 1
    返回 SkRect_创建(左, 上, 右, 下)
}

函数 SkRect_并集(a, b) {
    定义 左 = a.左
    如果 (b.左 < 左) { 左 = b.左 }
    定义 上 = a.上
    如果 (b.上 < 上) { 上 = b.上 }
    定义 右 = a.右
    如果 (b.右 > 右) { 右 = b.右 }
    定义 下 = a.下
    如果 (b.下 > 下) { 下 = b.下 }
    NRGP_矩形操作数 = NRGP_矩形操作数 + 1
    返回 SkRect_创建(左, 上, 右, 下)
}

函数 SkRect_内缩(r, dx, dy) {
    NRGP_矩形操作数 = NRGP_矩形操作数 + 1
    返回 SkRect_创建(r.左 + dx, r.上 + dy, r.右 - dx, r.下 - dy)
}

函数 SkRect_外扩(r, dx, dy) {
    NRGP_矩形操作数 = NRGP_矩形操作数 + 1
    返回 SkRect_创建(r.左 - dx, r.上 - dy, r.右 + dx, r.下 + dy)
}

函数 SkRect_是空(r) {
    返回 r.左 >= r.右 || r.上 >= r.下
}

函数 SkRect_包含矩形(a, b) {
    返回 a.左 <= b.左 && a.上 <= b.上 && a.右 >= b.右 && a.下 >= b.下
}

函数 SkRect_相交(a, b) {
    返回 a.左 < b.右 && b.左 < a.右 && a.上 < b.下 && b.上 < a.下
}

// §6 矩阵逆运算

函数 SkMatrix_行列式(m) {
    定义 d = m.m00 * (m.m11 * m.m22 - m.m12 * m.m21)
               - m.m01 * (m.m10 * m.m22 - m.m12 * m.m20)
               + m.m02 * (m.m10 * m.m21 - m.m11 * m.m20)
    返回 d / (10000 * 10000)  // 定点修正
}

函数 SkMatrix_求逆(m) {
    定义 det = SkMatrix_行列式(m)
    如果 (det == 0) { 返回 SkMatrix_单位矩阵() }

    定义 inv = SkMatrix {}
    inv.m00 = (m.m11 * m.m22 - m.m12 * m.m21) * 10000 / det
    inv.m01 = (m.m02 * m.m21 - m.m01 * m.m22) * 10000 / det
    inv.m02 = (m.m01 * m.m12 - m.m02 * m.m11) * 10000 / det
    inv.m10 = (m.m12 * m.m20 - m.m10 * m.m22) * 10000 / det
    inv.m11 = (m.m00 * m.m22 - m.m02 * m.m20) * 10000 / det
    inv.m12 = (m.m02 * m.m10 - m.m00 * m.m12) * 10000 / det
    inv.m20 = (m.m10 * m.m21 - m.m11 * m.m20) * 10000 / det
    inv.m21 = (m.m01 * m.m20 - m.m00 * m.m21) * 10000 / det
    inv.m22 = (m.m00 * m.m11 - m.m01 * m.m10) * 10000 / det

    NRGP_变换操作数 = NRGP_变换操作数 + 1
    返回 inv
}

// 旋转矩阵 (角度×100, Bhaskara I近似 sin/cos)
函数 SkMatrix_旋转(角度x100) {
    // 弧度 = 角度 * PI / 180, 但我们用定点近似
    // Bhaskara I: sin(x) ≈ 16x(PI-x) / (5*PI^2 - 4x(PI-x))
    // 这里PI×10000 = 31416
    定义 PI_FP = 31416
    定义 弧度 = 角度x100 * PI_FP / 18000
    定义 x = 弧度 % (2 * PI_FP)
    如果 (x < 0) { x = x + 2 * PI_FP }

    // sin近似
    定义 可变 sin_val = 0
    定义 可变 x_sin = x
    如果 (x_sin > PI_FP) { x_sin = 2 * PI_FP - x_sin }
    定义 分子 = 16 * x_sin * (PI_FP - x_sin)
    定义 分母 = 5 * PI_FP * PI_FP - 4 * x_sin * (PI_FP - x_sin)
    如果 (分母 != 0) { sin_val = 分子 * 10000 / 分母 }
    如果 (x > PI_FP) { sin_val = -sin_val }

    // cos = sin(x + PI/2)
    定义 cos_x = (x + PI_FP / 2) % (2 * PI_FP)
    定义 可变 cos_val = 0
    定义 可变 x_cos = cos_x
    如果 (x_cos > PI_FP) { x_cos = 2 * PI_FP - x_cos }
    定义 分子2 = 16 * x_cos * (PI_FP - x_cos)
    定义 分母2 = 5 * PI_FP * PI_FP - 4 * x_cos * (PI_FP - x_cos)
    如果 (分母2 != 0) { cos_val = 分子2 * 10000 / 分母2 }
    如果 (cos_x > PI_FP) { cos_val = -cos_val }

    定义 m = SkMatrix {}
    m.m00 = cos_val; m.m01 = -sin_val; m.m02 = 0
    m.m10 = sin_val; m.m11 = cos_val; m.m12 = 0
    m.m20 = 0; m.m21 = 0; m.m22 = 10000
    NRGP_变换操作数 = NRGP_变换操作数 + 1
    返回 m
}

// 变换矩形
函数 SkMatrix_变换矩形(m, r) {
    定义 p0 = SkMatrix_变换点(m, r.左, r.上)
    定义 p1 = SkMatrix_变换点(m, r.右, r.上)
    定义 p2 = SkMatrix_变换点(m, r.右, r.下)
    定义 p3 = SkMatrix_变换点(m, r.左, r.下)
    // 返回边界框
    定义 可变 最小x = p0[0]
    定义 可变 最小y = p0[1]
    定义 可变 最大x = p0[0]
    定义 可变 最大y = p0[1]
    如果 (p1[0] < 最小x) { 最小x = p1[0] }
    如果 (p1[0] > 最大x) { 最大x = p1[0] }
    如果 (p1[1] < 最小y) { 最小y = p1[1] }
    如果 (p1[1] > 最大y) { 最大y = p1[1] }
    如果 (p2[0] < 最小x) { 最小x = p2[0] }
    如果 (p2[0] > 最大x) { 最大x = p2[0] }
    如果 (p2[1] < 最小y) { 最小y = p2[1] }
    如果 (p2[1] > 最大y) { 最大y = p2[1] }
    如果 (p3[0] < 最小x) { 最小x = p3[0] }
    如果 (p3[0] > 最大x) { 最大x = p3[0] }
    如果 (p3[1] < 最小y) { 最小y = p3[1] }
    如果 (p3[1] > 最大y) { 最大y = p3[1] }
    NRGP_变换操作数 = NRGP_变换操作数 + 1
    返回 SkRect_创建(最小x, 最小y, 最大x, 最大y)
}

// §7 AI几何预测

函数 NRGP_AI预测几何() {
    定义 特征 = Tensor_创建([NRGP_AI特征维度])
    Tensor_写(特征, [0], NRGP_矩形操作数)
    Tensor_写(特征, [1], NRGP_路径操作数)
    Tensor_写(特征, [2], NRGP_变换操作数)
    Tensor_写(特征, [3], 0)
    Tensor_写(特征, [4], 0)
    Tensor_写(特征, [5], 0)
    Tensor_写(特征, [6], 0)
    Tensor_写(特征, [7], 0)

    定义 预测 = AI总线_推理("NRGP几何预测", 特征)
    NRGP_AI推理次数 = NRGP_AI推理次数 + 1
    Tensor_释放(特征)
    Tensor_释放(预测)
}

// §8 诊断接口

函数 NRGP_获取统计() {
    返回 {
        版本: NRGP_版本,
        矩形操作数: NRGP_矩形操作数,
        路径操作数: NRGP_路径操作数,
        变换操作数: NRGP_变换操作数,
        AI推理次数: NRGP_AI推理次数
    }
}

函数 NRGP_重置统计() {
    NRGP_矩形操作数 = 0
    NRGP_路径操作数 = 0
    NRGP_变换操作数 = 0
    NRGP_AI推理次数 = 0
}

// §9 矩形填充/描边渲染

// 填充矩形到像素缓冲
函数 NRGP_填充矩形(缓冲, 宽, 高, 步进, r, 颜色) {
    // 裁剪到缓冲范围
    定义 可变 x0 = r.左
    定义 可变 y0 = r.上
    定义 可变 x1 = r.右
    定义 可变 y1 = r.下
    如果 (x0 < 0) { x0 = 0 }
    如果 (y0 < 0) { y0 = 0 }
    如果 (x1 > 宽) { x1 = 宽 }
    如果 (y1 > 高) { y1 = 高 }
    如果 (x0 >= x1 || y0 >= y1) { 返回 }

    定义 可变 y = y0
    当 (y < y1) {
        定义 行偏移 = 缓冲 + y * 步进
        定义 可变 x = x0
        当 (x < x1) {
            内存_写32(行偏移 + x * 4, 颜色)
            x = x + 1
        }
        y = y + 1
    }
    NRGP_矩形操作数 = NRGP_矩形操作数 + 1
}

// 描边矩形 (1px线宽)
函数 NRGP_描边矩形(缓冲, 宽, 高, 步进, r, 颜色) {
    // 上边
    NRGP_水平线(缓冲, 宽, 高, 步进, r.左, r.右, r.上, 颜色)
    // 下边
    NRGP_水平线(缓冲, 宽, 高, 步进, r.左, r.右, r.下 - 1, 颜色)
    // 左边
    NRGP_垂直线(缓冲, 宽, 高, 步进, r.左, r.上, r.下, 颜色)
    // 右边
    NRGP_垂直线(缓冲, 宽, 高, 步进, r.右 - 1, r.上, r.下, 颜色)
    NRGP_矩形操作数 = NRGP_矩形操作数 + 1
}

函数 NRGP_水平线(缓冲, 宽, 高, 步进, x0, x1, y, 颜色) {
    如果 (y < 0 || y >= 高) { 返回 }
    如果 (x0 < 0) { x0 = 0 }
    如果 (x1 > 宽) { x1 = 宽 }
    定义 行 = 缓冲 + y * 步进
    定义 可变 x = x0
    当 (x < x1) {
        内存_写32(行 + x * 4, 颜色)
        x = x + 1
    }
}

函数 NRGP_垂直线(缓冲, 宽, 高, 步进, x, y0, y1, 颜色) {
    如果 (x < 0 || x >= 宽) { 返回 }
    如果 (y0 < 0) { y0 = 0 }
    如果 (y1 > 高) { y1 = 高 }
    定义 可变 y = y0
    当 (y < y1) {
        内存_写32(缓冲 + y * 步进 + x * 4, 颜色)
        y = y + 1
    }
}

// 清空矩形区域 (ARGB=0)
函数 NRGP_清空矩形(缓冲, 宽, 高, 步进, r) {
    NRGP_填充矩形(缓冲, 宽, 高, 步进, r, 0)
}

// 圆角矩形判断点是否在圆角内
函数 SkRRect_包含点(rr, x, y) {
    定义 r = rr.矩形
    如果 (!SkRect_包含点(r, x, y)) { 返回 假 }

    // 检查四个角
    // 左上角
    如果 (x < r.左 + rr.圆角_左上 && y < r.上 + rr.圆角_左上) {
        定义 dx = x - (r.左 + rr.圆角_左上)
        定义 dy = y - (r.上 + rr.圆角_左上)
        返回 (dx * dx + dy * dy) <= rr.圆角_左上 * rr.圆角_左上
    }
    // 右上角
    如果 (x >= r.右 - rr.圆角_右上 && y < r.上 + rr.圆角_右上) {
        定义 dx = x - (r.右 - rr.圆角_右上)
        定义 dy = y - (r.上 + rr.圆角_右上)
        返回 (dx * dx + dy * dy) <= rr.圆角_右上 * rr.圆角_右上
    }
    // 左下角
    如果 (x < r.左 + rr.圆角_左下 && y >= r.下 - rr.圆角_左下) {
        定义 dx = x - (r.左 + rr.圆角_左下)
        定义 dy = y - (r.下 - rr.圆角_左下)
        返回 (dx * dx + dy * dy) <= rr.圆角_左下 * rr.圆角_左下
    }
    // 右下角
    如果 (x >= r.右 - rr.圆角_右下 && y >= r.下 - rr.圆角_右下) {
        定义 dx = x - (r.右 - rr.圆角_右下)
        定义 dy = y - (r.下 - rr.圆角_右下)
        返回 (dx * dx + dy * dy) <= rr.圆角_右下 * rr.圆角_右下
    }
    返回 真
}

// §10 【原生独创】谐振矩形合并优化器
// 检测相邻矩形并合并以减少绘制调用

定义 可变 _谐振合并_次数 = 0
定义 可变 _谐振合并_节省数 = 0

函数 谐振矩形_可合并(r1x, r1y, r1w, r1h, r2x, r2y, r2w, r2h) {
    // 水平相邻: 同高同y，x1+w1==x2
    如果 (r1y == r2y && r1h == r2h && r1x + r1w == r2x) { 返回 真 }
    // 垂直相邻: 同宽同x，y1+h1==y2
    如果 (r1x == r2x && r1w == r2w && r1y + r1h == r2y) { 返回 真 }
    返回 假
}

函数 谐振矩形_合并(r1x, r1y, r1w, r1h, r2x, r2y, r2w, r2h) {
    _谐振合并_次数 = _谐振合并_次数 + 1
    _谐振合并_节省数 = _谐振合并_节省数 + 1
    如果 (r1y == r2y && r1h == r2h) {
        返回 { x: r1x, y: r1y, w: r1w + r2w, h: r1h }
    }
    返回 { x: r1x, y: r1y, w: r1w, h: r1h + r2h }
}

函数 绘制矩形_完整统计() {
    返回 [
        "谐振合并次数", _谐振合并_次数,
        "谐振节省数", _谐振合并_节省数
    ]
}

导入("./样式规则.nova")
导入("./文档节点.nova")
导入("./样式属性.nova")
导入("./变量取值.nova")
导入("./更新活跃样.nova")
导入("./样式解析边.nova")
导入("./样式引擎创.nova")
导入("./样式继承.nova")
导入("./计算长度零.nova")
导入("./样式解析为.nova")
导入("./计算样式创.nova")
导入("./应用样式声明.nova")
导入("./智能样式引.nova")
导入("./自定属性映.nova")
导入("./扩展属性应.nova")

结构 计算档 {
    名称,
    最近动作,
    最近参数,
    最近来源,
    最近结果,
    最近统计,
    最近错误,
    最近健康,
    是否初始化,
    引擎数,
    规则数,
    属性数,
    继承数,
    长度数,
    命中数,
    成功数,
    失败数,
}

结构 计算请求 {
    动作,
    目标,
    参数,
    选项,
}

结构 计算回证 {
    已收,
    已成,
    来源,
    错因,
    数据,
    统计,
}

结构 计算摘要 {
    名称,
    引擎数,
    规则数,
    属性数,
    继承数,
    长度数,
    命中数,
    成功数,
    失败数,
    健康,
}

定义 可变 计算账本 = []
定义 可变 计算构建数 = 0
定义 可变 计算总动作 = 0
定义 可变 计算总成功 = 0
定义 可变 计算总失败 = 0


函数 样式计算_建档(名称) {
    定义 档 = 计算档 {}
    档.名称 = 名称
    档.最近动作 = ""
    档.最近参数 = []
    档.最近来源 = ""
    档.最近结果 = 0
    档.最近统计 = []
    档.最近错误 = ""
    档.最近健康 = "未初始化"
    档.是否初始化 = 假
    档.引擎数 = 0
    档.规则数 = 0
    档.属性数 = 0
    档.继承数 = 0
    档.长度数 = 0
    档.命中数 = 0
    档.成功数 = 0
    档.失败数 = 0
    返回 档
}

函数 样式计算_登记(档) {
    追加(计算账本, 档)
    计算构建数 = 计算构建数 + 1
    返回 档
}

函数 样式计算_完整统计() {
    返回 [
        计算构建数,
        计算总动作,
        计算总成功,
        计算总失败
    ]
}

函数 样式计算_建回证(已收, 已成, 来源, 错因, 数据, 统计) {
    定义 回证 = 计算回证 {}
    回证.已收 = 已收
    回证.已成 = 已成
    回证.来源 = 来源
    回证.错因 = 错因
    回证.数据 = 数据
    回证.统计 = 统计
    返回 回证
}

函数 样式计算_刷新健康(档) {
    如果 (!档.是否初始化) {
        档.最近健康 = "未初始化"
        返回 档.最近健康
    }
    如果 (档.失败数 > 档.成功数) {
        档.最近健康 = "降级"
        返回 档.最近健康
    }
    如果 (档.引擎数 > 0 || 档.规则数 > 0 || 档.属性数 > 0) {
        档.最近健康 = "运行"
        返回 档.最近健康
    }
    档.最近健康 = "空载"
    返回 档.最近健康
}

函数 样式计算_记录(档, 动作, 参数, 来源) {
    档.最近动作 = 动作
    档.最近参数 = 参数
    档.最近来源 = 来源
    档.最近错误 = ""
    档.最近统计 = 样式计算_完整统计()
}

函数 样式计算_成功(档, 来源, 数据) {
    计算总动作 = 计算总动作 + 1
    计算总成功 = 计算总成功 + 1
    如果 (档 == 空) {
        返回 样式计算_建回证(真, 真, 来源, "", 数据, 样式计算_完整统计())
    }
    档.最近来源 = 来源
    档.最近结果 = 数据
    档.最近错误 = ""
    档.成功数 = 档.成功数 + 1
    档.最近统计 = 样式计算_完整统计()
    样式计算_刷新健康(档)
    返回 样式计算_建回证(真, 真, 来源, "", 数据, 档.最近统计)
}

函数 样式计算_失败(档, 来源, 错因) {
    计算总动作 = 计算总动作 + 1
    计算总失败 = 计算总失败 + 1
    如果 (档 == 空) {
        返回 样式计算_建回证(真, 假, 来源, 错因, 0, 样式计算_完整统计())
    }
    档.最近来源 = 来源
    档.最近错误 = 错因
    档.失败数 = 档.失败数 + 1
    档.最近统计 = 样式计算_完整统计()
    样式计算_刷新健康(档)
    返回 样式计算_建回证(真, 假, 来源, 错因, 0, 档.最近统计)
}

函数 样式计算_初始化(档) {
    样式性能_初始化()
    AI样式引擎_初始化缓存()
    档.是否初始化 = 真
    档.最近动作 = "初始化"
    档.最近来源 = "样式计算_初始化"
    档.最近统计 = 样式计算_完整统计()
    样式计算_刷新健康(档)
    返回 档
}

函数 样式计算_创建(名称) {
    定义 档 = 样式计算_建档(名称)
    样式计算_初始化(档)
    返回 样式计算_登记(档)
}

函数 样式计算_检查档(档) {
    如果 (档 == 空) { 返回 假 }
    如果 (!档.是否初始化) { 返回 假 }
    返回 真
}

函数 样式计算_新引擎(档, 文档) {
    如果 (!样式计算_检查档(档)) { 返回 样式计算_失败(档, "新引擎", "计算档不可用") }
    样式计算_记录(档, "新引擎", [文档], "样式引擎")
    定义 结果 = 样式Engine_创建(文档)
    档.引擎数 = 档.引擎数 + 1
    返回 样式计算_成功(档, "新引擎", 结果)
}

函数 样式计算_加样式表(档, 引擎, 文本) {
    如果 (!样式计算_检查档(档)) { 返回 样式计算_失败(档, "加样式表", "计算档不可用") }
    样式计算_记录(档, "加样式表", [引擎, 文本], "样式引擎")
    定义 结果 = 样式Engine_添加样式表(引擎, 文本)
    档.引擎数 = 档.引擎数 + 1
    档.规则数 = 档.规则数 + 1
    返回 样式计算_成功(档, "加样式表", 结果)
}


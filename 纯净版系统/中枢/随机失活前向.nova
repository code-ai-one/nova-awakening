
导入("./类型定义.nova")
导入("./错误码.nova")
导入("./网络追加.nova")
导入("./内核打印.nova")
导入("./学习率预热.nova")
导入("./整数转字符串.nova")
导入("./打乱.nova")
导入("./网络激活层前.nova")

定义 可变 失活_前向次数 = 0
定义 可变 失活_丢弃元素 = 0
定义 可变 失活_保留元素 = 0
定义 可变 残差_前向次数 = 0
定义 可变 归一化指数_次数 = 0
定义 可变 初始化_次数 = 0

// §1 标准随机失活 (Inverted Dropout)

函数 Nova随机失活_前向(输入, 保持率, 种子, 训练) {
    失活_前向次数 = 失活_前向次数 + 1
    如果 (训练 == 0) { 返回 输入 }
    定义 n = 计数(输入)
    定义 可变 输出 = []
    定义 可变 s = 种子
    定义 可变 i = 0
    当 (i < n) {
        s = (s * 1103515245 + 12345) & 0x7FFFFFFF
        如果 (s % 1000 < 保持率) {
            网络_追加(输出, 输入[i] * 网络精度 / 保持率)
            失活_保留元素 = 失活_保留元素 + 1
        } 否则 {
            网络_追加(输出, 0)
            失活_丢弃元素 = 失活_丢弃元素 + 1
        }
        i = i + 1
    }
    返回 输出
}

// 返回掩码供反向传播使用
函数 Nova随机失活_带掩码(输入, 保持率, 种子, 训练) {
    失活_前向次数 = 失活_前向次数 + 1
    定义 n = 计数(输入)
    定义 可变 输出 = []
    定义 可变 掩码 = []
    如果 (训练 == 0) {
        定义 可变 i = 0
        当 (i < n) {
            网络_追加(输出, 输入[i])
            网络_追加(掩码, 1)
            i = i + 1
        }
        返回 [输出, 掩码]
    }
    定义 可变 s = 种子
    定义 可变 i = 0
    当 (i < n) {
        s = (s * 1103515245 + 12345) & 0x7FFFFFFF
        如果 (s % 1000 < 保持率) {
            网络_追加(输出, 输入[i] * 网络精度 / 保持率)
            网络_追加(掩码, 1)
            失活_保留元素 = 失活_保留元素 + 1
        } 否则 {
            网络_追加(输出, 0)
            网络_追加(掩码, 0)
            失活_丢弃元素 = 失活_丢弃元素 + 1
        }
        i = i + 1
    }
    返回 [输出, 掩码]
}

// 反向: 使用同一掩码
函数 Nova随机失活_反向(输出梯度, 掩码, 保持率) {
    定义 n = 计数(输出梯度)
    定义 可变 梯度 = []
    定义 可变 i = 0
    当 (i < n) {
        如果 (掩码[i] != 0) {
            网络_追加(梯度, 输出梯度[i] * 网络精度 / 保持率)
        } 否则 {
            网络_追加(梯度, 0)
        }
        i = i + 1
    }
    返回 梯度
}

// §2 变分随机失活 (Variational Dropout)
// 同一序列使用相同掩码

函数 变分失活_生成掩码(维度, 保持率, 种子) {
    定义 可变 掩码 = []
    定义 可变 s = 种子
    定义 可变 i = 0
    当 (i < 维度) {
        s = (s * 1103515245 + 12345) & 0x7FFFFFFF
        如果 (s % 1000 < 保持率) {
            网络_追加(掩码, 网络精度 * 网络精度 / 保持率)
        } 否则 {
            网络_追加(掩码, 0)
        }
        i = i + 1
    }
    返回 掩码
}

函数 变分失活_应用(输入, 掩码) {
    失活_前向次数 = 失活_前向次数 + 1
    定义 n = 计数(输入)
    定义 可变 输出 = []
    定义 可变 i = 0
    当 (i < n) {
        定义 mi = 如果(i < 计数(掩码), 掩码[i], 网络精度)
        网络_追加(输出, 输入[i] * mi / 网络精度)
        i = i + 1
    }
    返回 输出
}

// §3 DropConnect (丢弃权重而非激活)

函数 DropConnect_前向(权重, 输入, 保持率, 种子, 训练) {
    失活_前向次数 = 失活_前向次数 + 1
    如果 (训练 == 0) {
        // 推理时使用缩放权重
        定义 n = 计数(权重)
        定义 可变 缩放权重 = []
        定义 可变 i = 0
        当 (i < n) {
            网络_追加(缩放权重, 权重[i] * 保持率 / 1000)
            i = i + 1
        }
        返回 缩放权重
    }
    定义 n = 计数(权重)
    定义 可变 掩码权重 = []
    定义 可变 s = 种子
    定义 可变 i = 0
    当 (i < n) {
        s = (s * 1103515245 + 12345) & 0x7FFFFFFF
        如果 (s % 1000 < 保持率) {
            网络_追加(掩码权重, 权重[i])
        } 否则 {
            网络_追加(掩码权重, 0)
            失活_丢弃元素 = 失活_丢弃元素 + 1
        }
        i = i + 1
    }
    返回 掩码权重
}

// §4 Alpha Dropout (用于SELU激活)

函数 alpha失活_前向(输入, 保持率, 种子, 训练) {
    失活_前向次数 = 失活_前向次数 + 1
    如果 (训练 == 0) { 返回 输入 }
    // alpha' = -1.7580993408 (Q10 ≈ -1801)
    定义 alpha_prime = 0 - 1801
    定义 n = 计数(输入)
    定义 可变 输出 = []
    定义 可变 s = 种子
    定义 可变 i = 0
    当 (i < n) {
        s = (s * 1103515245 + 12345) & 0x7FFFFFFF
        如果 (s % 1000 < 保持率) {
            网络_追加(输出, 输入[i])
        } 否则 {
            网络_追加(输出, alpha_prime)
        }
        i = i + 1
    }
    // 仿射变换保持均值和方差
    定义 a = 网络精度 * 网络精度 / 保持率
    定义 可变 j = 0
    当 (j < n) {
        输出[j] = 输出[j] * a / 网络精度
        j = j + 1
    }
    返回 输出
}

// §5 调度失活率 (训练后期逐步减少)

函数 调度失活率(初始保持率, 当前步, 总步数) {
    // 线性从初始保持率增加到1000 (即不失活)
    如果 (当前步 >= 总步数) { 返回 1000 }
    返回 初始保持率 + (1000 - 初始保持率) * 当前步 / 总步数
}

// §6 残差连接

函数 残差_前向(层, 输入) {
    残差_前向次数 = 残差_前向次数 + 1
    定义 中间 = 全连接_前向(层, 输入)
    定义 激活 = relu层_前向(中间)
    如果 (计数(激活) == 计数(输入)) {
        定义 可变 结果 = []
        定义 可变 i = 0
        当 (i < 计数(激活)) {
            网络_追加(结果, 激活[i] + 输入[i])
            i = i + 1
        }
        返回 结果
    }
    返回 激活
}

// 带LayerNorm的残差: LayerNorm(x + sublayer(x))
函数 残差_层归一_前向(层, 输入, gamma, beta) {
    残差_前向次数 = 残差_前向次数 + 1
    定义 中间 = 全连接_前向(层, 输入)
    定义 激活 = relu层_前向(中间)
    定义 n = 计数(输入)
    定义 可变 和 = []
    如果 (计数(激活) == n) {
        定义 可变 i = 0
        当 (i < n) {
            网络_追加(和, 激活[i] + 输入[i])
            i = i + 1
        }
    } 否则 {
        和 = 激活
    }
    返回 层归一化(和, gamma, beta)
}

// 带Dropout的残差: x + dropout(sublayer(x))
函数 残差_失活_前向(层, 输入, 保持率, 种子, 训练) {
    残差_前向次数 = 残差_前向次数 + 1
    定义 中间 = 全连接_前向(层, 输入)
    定义 激活 = relu层_前向(中间)
    定义 丢弃后 = Nova随机失活_前向(激活, 保持率, 种子, 训练)
    如果 (计数(丢弃后) == 计数(输入)) {
        定义 可变 结果 = []
        定义 可变 i = 0
        当 (i < 计数(丢弃后)) {
            网络_追加(结果, 丢弃后[i] + 输入[i])
            i = i + 1
        }
        返回 结果
    }
    返回 丢弃后
}

// §7 Nova归一化指数 (Softmax, 整数近似)

函数 Nova归一化指数(输入) {
    归一化指数_次数 = 归一化指数_次数 + 1
    定义 n = 计数(输入)
    定义 可变 最大 = 输入[0]
    定义 可变 i = 1
    当 (i < n) {
        如果 (输入[i] > 最大) { 最大 = 输入[i] }
        i = i + 1
    }
    定义 可变 指数值 = []
    定义 可变 总和 = 0
    i = 0
    当 (i < n) {
        定义 x = 输入[i] - 最大
        定义 可变 ex = 0
        如果 (x >= 0) { ex = 网络精度 }
        否则 如果 (x > 0 - 网络精度) { ex = 网络精度 + x }
        否则 如果 (x > 0 - 3 * 网络精度) { ex = (网络精度 + x / 3) * (网络精度 + x / 3) / 网络精度 }
        否则 { ex = 1 }
        如果 (ex < 1) { ex = 1 }
        网络_追加(指数值, ex)
        总和 = 总和 + ex
        i = i + 1
    }
    定义 可变 结果 = []
    i = 0
    当 (i < n) {
        网络_追加(结果, 指数值[i] * 网络精度 / 总和)
        i = i + 1
    }
    返回 结果
}

// Softmax with temperature
函数 Nova归一化指数_温度(输入, 温度) {
    归一化指数_次数 = 归一化指数_次数 + 1
    如果 (温度 <= 0) { 温度 = 1 }
    定义 n = 计数(输入)
    定义 可变 缩放 = []
    定义 可变 i = 0
    当 (i < n) {
        网络_追加(缩放, 输入[i] * 网络精度 / 温度)
        i = i + 1
    }
    返回 Nova归一化指数(缩放)
}

// §8 标签平滑 (Label Smoothing)

函数 标签平滑(独热标签, 类别数, 平滑系数) {
    定义 n = 计数(独热标签)
    定义 可变 平滑标签 = []
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 v = 独热标签[i]
        如果 (v > 0) {
            v = 网络精度 - 平滑系数 + 平滑系数 / 类别数
        } 否则 {
            v = 平滑系数 / 类别数
        }
        网络_追加(平滑标签, v)
        i = i + 1
    }
    返回 平滑标签
}

// §9 交叉熵损失

函数 交叉熵(预测, 标签) {
    定义 n = 计数(预测)
    定义 可变 损失 = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (标签[i] > 0) {
            // -label * log(pred), 近似 log
            定义 可变 p = 预测[i]
            如果 (p < 1) { p = 1 }  // clamp
            // log近似: log(x/precision) ≈ (x - precision) / precision
            定义 对数近似 = (p - 网络精度) * 网络精度 / p
            损失 = 损失 - 标签[i] * 对数近似 / 网络精度
        }
        i = i + 1
    }
    返回 损失
}

// §10 Xavier/He 初始化

函数 全连接_创建_xavier(输入维, 输出维, 种子) {
    初始化_次数 = 初始化_次数 + 1
    定义 范围 = 网络_开方(6 * 网络精度 / (输入维 + 输出维))
    定义 可变 权重 = [输出维, 输入维]
    定义 可变 s = 种子
    定义 可变 i = 0
    当 (i < 输出维 * 输入维) {
        s = (s * 1103515245 + 12345) & 0x7FFFFFFF
        定义 w = (s % (2 * 范围 + 1)) - 范围
        网络_追加(权重, w)
        i = i + 1
    }
    定义 可变 偏置 = []
    i = 0
    当 (i < 输出维) { 网络_追加(偏置, 0)  i = i + 1 }
    返回 [输入维, 输出维, 权重, 偏置, [], []]
}

函数 全连接_创建_he(输入维, 输出维, 种子) {
    初始化_次数 = 初始化_次数 + 1
    定义 范围 = 网络_开方(2 * 网络精度 / 输入维)
    定义 可变 权重 = [输出维, 输入维]
    定义 可变 s = 种子
    定义 可变 i = 0
    当 (i < 输出维 * 输入维) {
        s = (s * 1103515245 + 12345) & 0x7FFFFFFF
        定义 w = (s % (2 * 范围 + 1)) - 范围
        网络_追加(权重, w)
        i = i + 1
    }
    定义 可变 偏置 = []
    i = 0
    当 (i < 输出维) { 网络_追加(偏置, 0)  i = i + 1 }
    返回 [输入维, 输出维, 权重, 偏置, [], []]
}

// LeCun初始化: variance = 1/fan_in
函数 全连接_创建_lecun(输入维, 输出维, 种子) {
    初始化_次数 = 初始化_次数 + 1
    定义 范围 = 网络_开方(网络精度 / 输入维)
    定义 可变 权重 = [输出维, 输入维]
    定义 可变 s = 种子
    定义 可变 i = 0
    当 (i < 输出维 * 输入维) {
        s = (s * 1103515245 + 12345) & 0x7FFFFFFF
        定义 w = (s % (2 * 范围 + 1)) - 范围
        网络_追加(权重, w)
        i = i + 1
    }
    定义 可变 偏置 = []
    i = 0
    当 (i < 输出维) { 网络_追加(偏置, 0)  i = i + 1 }
    返回 [输入维, 输出维, 权重, 偏置, [], []]
}

// §11 统计

函数 随机失活_统计() {
    返回 [失活_前向次数, 失活_丢弃元素, 失活_保留元素,
           残差_前向次数, 归一化指数_次数, 初始化_次数]
}

函数 随机失活_打印统计() {
    打印行("=== 随机失活/正则化统计 ===")
    打印行("失活前向: " + 整数转字符串(失活_前向次数))
    打印行("丢弃元素: " + 整数转字符串(失活_丢弃元素))
    打印行("保留元素: " + 整数转字符串(失活_保留元素))
    如果 (失活_丢弃元素 + 失活_保留元素 > 0) {
        定义 丢弃率 = 失活_丢弃元素 * 100 / (失活_丢弃元素 + 失活_保留元素)
        打印行("实际丢弃率: " + 整数转字符串(丢弃率) + "%")
    }
    打印行("残差前向: " + 整数转字符串(残差_前向次数))
    打印行("归一化指数: " + 整数转字符串(归一化指数_次数))
    打印行("初始化次数: " + 整数转字符串(初始化_次数))
}

// §12 自适应失活率 (Adaptive Dropout)

定义 可变 自适应_基准保持率 = 700   // 0.7
定义 可变 自适应_损失历史 = []
定义 可变 自适应_历史长度 = 10

函数 自适应失活_更新(当前损失) {
    网络_追加(自适应_损失历史, 当前损失)
    如果 (计数(自适应_损失历史) > 自适应_历史长度) {
        // 移除最早的
        定义 可变 新历史 = []
        定义 可变 i = 1
        当 (i < 计数(自适应_损失历史)) {
            网络_追加(新历史, 自适应_损失历史[i])
            i = i + 1
        }
        自适应_损失历史 = 新历史
    }

    // 如果损失停滞, 增加失活强度(降低保持率)
    如果 (计数(自适应_损失历史) >= 自适应_历史长度) {
        定义 可变 前半和 = 0
        定义 可变 后半和 = 0
        定义 半 = 自适应_历史长度 / 2
        定义 可变 i = 0
        当 (i < 半) {
            前半和 = 前半和 + 自适应_损失历史[i]
            后半和 = 后半和 + 自适应_损失历史[半 + i]
            i = i + 1
        }
        如果 (后半和 >= 前半和 * 95 / 100) {
            // 损失停滞: 增加失活(降低保持率)
            自适应_基准保持率 = 自适应_基准保持率 - 20
            如果 (自适应_基准保持率 < 300) { 自适应_基准保持率 = 300 }
        } 否则 {
            // 损失下降: 减少失活(提高保持率)
            自适应_基准保持率 = 自适应_基准保持率 + 10
            如果 (自适应_基准保持率 > 950) { 自适应_基准保持率 = 950 }
        }
    }
}

函数 自适应失活_获取保持率() { 返回 自适应_基准保持率 }

函数 自适应失活_前向(输入, 种子, 训练) {
    定义 保持率 = 自适应_基准保持率
    返回 Nova随机失活_前向(输入, 保持率, 种子, 训练)
}

// §13 稀疏性分析

函数 稀疏度_计算(向量) {
    // 返回零元素占比 (千分之)
    定义 n = 计数(向量)
    如果 (n == 0) { 返回 0 }
    定义 可变 零计数 = 0
    定义 可变 i = 0
    当 (i < n) {
        如果 (向量[i] == 0) { 零计数 = 零计数 + 1 }
        i = i + 1
    }
    返回 零计数 * 1000 / n
}

函数 稀疏度_L1范数(向量) {
    // L1范数: 所有元素绝对值之和
    定义 n = 计数(向量)
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < n) {
        定义 可变 v = 向量[i]
        如果 (v < 0) { v = -v }
        和 = 和 + v
        i = i + 1
    }
    返回 和
}

函数 稀疏度_L2范数平方(向量) {
    // L2范数平方: 所有元素平方和
    定义 n = 计数(向量)
    定义 可变 和 = 0
    定义 可变 i = 0
    当 (i < n) {
        和 = 和 + 向量[i] * 向量[i] / 网络精度
        i = i + 1
    }
    返回 和
}

// §14 梯度噪声注入 (Gradient Noise)

函数 梯度噪声_注入(梯度, 标准差, 种子) {
    // 添加高斯近似噪声促进探索
    定义 n = 计数(梯度)
    定义 可变 输出 = []
    定义 可变 s = 种子
    定义 可变 i = 0
    当 (i < n) {
        s = (s * 1103515245 + 12345) & 0x7FFFFFFF
        // 均匀→近似高斯: Box-Muller简化
        定义 u = (s % 2001) - 1000  // [-1000, 1000]
        定义 噪声 = u * 标准差 / 1000
        网络_追加(输出, 梯度[i] + 噪声)
        i = i + 1
    }
    返回 输出
}

函数 梯度噪声_衰减标准差(初始标准差, 当前步, 衰减率) {
    // 噪声标准差随训练进行而衰减
    // σ_t = σ_0 / (1 + t * decay)
    如果 (衰减率 <= 0) { 返回 初始标准差 }
    返回 初始标准差 * 1000 / (1000 + 当前步 * 衰减率)
}

// NDRL — Nova Dropout Regularization Logic
// 公理1(期望不变): Inverted Dropout保证E[output]=E[input]
// 公理2(掩码独立): 每次前向传播的掩码互相独立
// 公理3(失活渐消): 训练后期失活率趋近于零
// 定理1(正则等价): Dropout≈L2正则化的随机近似
// 定理2(稀疏涌现): 足够失活率下网络自发学习稀疏表示

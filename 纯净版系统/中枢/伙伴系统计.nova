函数 伙伴系统_计算水位线() {
    // min_free_kbytes默认~4MB (依系统内存大小调整)
    定义 min_free_pages = 1024   // 4MB / 4KB
    如果 (全局总页数 > 262144) { min_free_pages = 4096 }  // >1GB: 16MB
    如果 (全局总页数 > 1048576) { min_free_pages = 16384 } // >4GB: 64MB

    定义 可变 i = 0
    当 (i < 活跃zone数) {
        定义 可变 z = 所有zone[zone搜索顺序[i]]
        如果 (!z.已初始化) { i = i + 1; 继续 }
        // 按zone管理页数比例分配min值
        定义 zone比例 = 全局总页数 > 0 ? z.跨越页数 * 1000 / 全局总页数 : 0
        定义 zone_min = min_free_pages * zone比例 / 1000
        如果 (zone_min < 20) { zone_min = 20 }
        z.水位线[WMARK_MIN] = zone_min
        z.水位线[WMARK_LOW] = zone_min + zone_min / 4
        z.水位线[WMARK_HIGH] = zone_min + zone_min / 2
        i = i + 1
    }
}

// 防止高zone请求耗尽低zone内存
函数 伙伴系统_计算低端保留() {
    // 默认比率: [256, 256, 32, 0, 0]
    定义 比率 = [256, 256, 32, 0, 0]
    定义 可变 i = 0
    当 (i < 活跃zone数) {
        定义 可变 z = 所有zone[zone搜索顺序[i]]
        定义 可变 j = i + 1
        定义 可变 累计 = 0
        当 (j < 活跃zone数) {
            定义 高zone = 所有zone[zone搜索顺序[j]]
            累计 = 累计 + 高zone.管理页数
            如果 (比率[j] > 0) {
                z.低端保留[zone搜索顺序[j]] = 累计 / 比率[j]
            }
            j = j + 1
        }
        i = i + 1
    }
}

// 页块迁移类型管理

函数 页块索引(z, 页号) {
    返回 (页号 - z.起始页号) / 页块页数
}

函数 获取页块迁移类型(z, 页号) {
    定义 idx = 页块索引(z, 页号)
    如果 (idx >= z.页块数) { 返回 MIGRATE_MOVABLE }
    返回 z.页块类型[idx]
}

函数 设置页块迁移类型(z, 页号, 迁移类型) {
    定义 idx = 页块索引(z, 页号)
    如果 (idx < z.页块数) { z.页块类型[idx] = 迁移类型 }
}

// GFP标志解析

函数 gfp_到_zone类型(gfp) {
    如果 ((gfp & GFP_直传) != 0) { 返回 ZONE_直传 }
    如果 ((gfp & GFP_直传32) != 0) { 返回 ZONE_直传32 }
    如果 ((gfp & GFP_HIGHMEM) != 0) { 返回 ZONE_HIGHMEM }
    返回 ZONE_NORMAL
}

函数 gfp_到_迁移类型(gfp) {
    如果 ((gfp & __GFP_MOVABLE) != 0) { 返回 MIGRATE_MOVABLE }
    如果 ((gfp & __GFP_RECLAIMABLE) != 0) { 返回 MIGRATE_RECLAIMABLE }
    返回 MIGRATE_UNMOVABLE
}

// 添加空闲块到zone

函数 伙伴系统_添加空闲块(页号, 阶) {
    // 确定该页属于哪个zone
    定义 可变 z = 空
    定义 可变 i = 0
    当 (i < 活跃zone数) {
        定义 可变 候选 = 所有zone[zone搜索顺序[i]]
        如果 (候选.已初始化 && 页号 >= 候选.起始页号 &&
            页号 < 候选.起始页号 + 候选.跨越页数) {
            z = 候选
            中断
        }
        i = i + 1
    }
    如果 (z == 空) { 返回 }

    定义 页数 = 1 << 阶
    定义 迁移类型 = 获取页块迁移类型(z, 页号)

    自旋锁_获取(z.锁)
    链表_尾插(z.空闲区[阶].空闲链表[迁移类型], 页号)
    z.空闲区[阶].空闲数 = z.空闲区[阶].空闲数 + 1
    z.管理页数 = z.管理页数 + 页数
    自旋锁_释放(z.锁)

    // 标记位图
    如果 (页状态 != 空) {
        位图_设置范围(页状态, 页号, 页数)
    }
    全局空闲页数 = 全局空闲页数 + 页数

    // 设置页描述符
    定义 可变 j = 0
    当 (j < 页数) {
        定义 页 = 页描述符_获取(页号 + j)
        如果 (页 != 空) {
            页描述符_设置标志(页, 页_伙伴)
            设置(页, PG_阶, 阶)
            设置(页, PG_区域, z.类型)
        }
        j = j + 1
    }
}

// 水位线检查 

函数 zone_水位OK(z, 阶, 水位级别, 请求zone) {
    // 空闲页数(不含低端保留)
    定义 空闲 = zone_空闲页数(z)
    定义 保留 = z.低端保留[请求zone]
    定义 水位 = z.水位线[水位级别] + z.水位线_加速

    如果 (空闲 - 保留 < 水位 + (1 << 阶)) { 返回 假 }

    // 额外检查: 高阶分配需要确保连续性
    如果 (阶 > 0) {
        定义 可变 检查阶 = 阶
        当 (检查阶 <= 最大阶) {
            如果 (z.空闲区[检查阶].空闲数 > 0) { 返回 真 }
            检查阶 = 检查阶 + 1
        }
        返回 假
    }
    返回 真
}

函数 zone_空闲页数(z) {
    定义 可变 总计 = 0
    定义 可变 阶 = 0
    当 (阶 <= 最大阶) {
        总计 = 总计 + z.空闲区[阶].空闲数 * (1 << 阶)
        阶 = 阶 + 1
    }
    返回 总计 + z.PCP.计数
}

// per-CPU页缓存 
// 快速路径: 单页分配不需要拿zone锁

函数 PCP_分配(z, 迁移类型) {
    如果 (迁移类型 >= MIGRATE_PCPTYPES) { 返回 0 - 1 }
    自旋锁_获取(z.PCP.锁)
    如果 (!链表_为空(z.PCP.链表[迁移类型])) {
        定义 节点 = 链表_首节点(z.PCP.链表[迁移类型])
        定义 页号 = 链表_数据(节点)
        链表_删除(节点)
        z.PCP.计数 = z.PCP.计数 - 1
        z.PCP命中 = z.PCP命中 + 1
        自旋锁_释放(z.PCP.锁)
        返回 页号
    }
    自旋锁_释放(z.PCP.锁)

    // PCP为空: 从伙伴系统批量补充
    PCP_批量补充(z, 迁移类型)

    // 再次尝试
    自旋锁_获取(z.PCP.锁)
    如果 (!链表_为空(z.PCP.链表[迁移类型])) {
        定义 节点 = 链表_首节点(z.PCP.链表[迁移类型])
        定义 页号 = 链表_数据(节点)
        链表_删除(节点)
        z.PCP.计数 = z.PCP.计数 - 1
        z.PCP命中 = z.PCP命中 + 1
        自旋锁_释放(z.PCP.锁)
        返回 页号
    }
    自旋锁_释放(z.PCP.锁)
    返回 0 - 1
}

函数 PCP_批量补充(z, 迁移类型) {
    // 从伙伴系统分配batch个单页放入PCP
    自旋锁_获取(z.锁)
    定义 可变 补充数 = 0
    当 (补充数 < z.PCP.批量) {
        定义 页号 = __伙伴_取页(z, 0, 迁移类型)
        如果 (页号 < 0) { 中断 }
        自旋锁_获取(z.PCP.锁)
        链表_尾插(z.PCP.链表[迁移类型], 页号)
        z.PCP.计数 = z.PCP.计数 + 1
        自旋锁_释放(z.PCP.锁)
        补充数 = 补充数 + 1
    }
    自旋锁_释放(z.锁)
}

定义 可变 AI_伙伴系统计_运行指标 = 0
定义 可变 AI_伙伴系统计_异常指标 = 0

函数 AI_伙伴系统计_自诊断() {
    AI_伙伴系统计_运行指标 = 0
    返回 AI_伙伴系统计_运行指标
}

函数 AI_伙伴系统计_优化建议() {
    定义 指标 = AI_伙伴系统计_自诊断()
    返回 "伙伴系统计状态正常"
}

// §7 合成决策 
// 决定哪些层需要图处合成


函数 绘制Layer_更新合成(层) {
 定义 s = 层.布局对象.样式
 如果 (s == 0) { 返回 }

 // 图处合成触发条件
 定义 可变 需要合成 = 假
 如果 (s.transform != 0) { 需要合成 = 真 }
 如果 (s.opacity < 100) { 需要合成 = 真 }
 如果 (s.position == Position_fixed) { 需要合成 = 真 }
 // will-change / 3D transform / video / canvas 等也触发

 如果 (需要合成) {
 层.类型 = 层类型_合成
 层.标志 = 层.标志 | 层标志_是合成的
 // 创建GraphicsLayer(对应cc::Layer)
 如果 (层.图形层 == 0) {
 层.图形层 = GraphicsLayer_创建(层)
 }
 }

 // 递归子层
 定义 可变 子 = 层.第一子层
 当 (子 != 0) {
 绘制Layer_更新合成(子)
 子 = 子.后兄层
 }
}

// §8 GraphicsLayer (cc::Layer的抽象)
// 图处合成层,持有一个纹理(texture)

结构 GraphicsLayer {
 所属绘制层,    // u64 绘制Layer*
 纹理ID,    // u32 图处纹理句柄
 宽,
 高,
 脏区域_x,
 脏区域_y,
 脏区域_w,
 脏区域_h,
 变换矩阵,    // u64 4x4 float矩阵
 透明度,
}

函数 GraphicsLayer_创建(绘制层) {
 定义 gl = 堆_分配(GraphicsLayer)
 gl.所属绘制层 = 绘制层
 gl.纹理ID = 0
 定义 lo = 绘制层.布局对象
 如果 (lo != 0) {
 gl.宽 = 布局Object_边框盒宽(lo)
 gl.高 = 布局Object_边框盒高(lo)
 }
 gl.脏区域_x = 0; gl.脏区域_y = 0
 gl.脏区域_w = gl.宽; gl.脏区域_h = gl.高
 gl.变换矩阵 = 0
 gl.透明度 = 100
 返回 gl
}

// 传统方案: 所有层同等精度绘制, 不区分重要性
// Nova: AI感知用户注意力, 动态调整渲染精度和优先级

函数 AI渲染_更新层可见性(层, 视口上, 视口下) {
 如果 (层 == 0) { 返回 }
 定义 lo = 层.布局对象
 如果 (lo == 0) { 返回 }

 定义 层上 = lo.绝对y
 定义 层下 = lo.绝对y + 布局Object_边框盒高(lo)

 // 基础可见性判断
 定义 层x = lo.绝对x
 定义 层w = 布局Object_边框盒宽(lo)
 定义 层h = 层下 - 层上
 定义 是否可见 = 假
 如果 (层下 <= 视口上 || 层上 >= 视口下) {
 层.视口可见 = 0
 } 否则 如果 (层上 >= 视口上 && 层下 <= 视口下) {
 层.视口可见 = 2
 是否可见 = 真
 } 否则 {
 层.视口可见 = 1
 是否可见 = 真
 }

 // 【颠覆性创新】AI总线感知质量决策
 // 传统: 简单阈值(注意力>8000→高, <3000→低)
 // Nova: AI总线_渲染质量() 内部调用:
 // ① 注视点模型 — 高斯衰减(离注视点越远权重越低)
 // ② JND阈值 — 人眼刚好可察觉差异(Weber定律+纹理掩蔽)
 // ③ 运动掩蔽 — 滚动时可大幅降级(人眼察觉不到)
 // ④ 语义重要性 — Nova多层感知器分类网络推断的语义角色权重
 // ⑤ 帧间平滑 — 防止质量突变闪烁(时间低通滤波)
 定义 bus = 全局AI总线
 如果 (bus != 0) {
 // 获取语义重要性
 定义 语义权重 = Q_HALF
 如果 (lo.DOM节点 != 0) {
 层.注意力权重 = lo.DOM节点.注意力权重
 语义权重 = 层.注意力权重 * Q_ONE / 10000
 }

 // AI感知质量分配器综合决策
 定义 级别 = AI总线_渲染质量(bus, 层x, 层上, 层w, 层h, 语义权重, 是否可见)

 如果 (级别 == 渲染级别_跳过) {
 层.渲染精度 = 0
 层.标志 = 层.标志 | 层标志_AI可跳过绘制
 层.标志 = 层.标志 & (~层标志_AI高优先级)
 } 否则 如果 (级别 <= 渲染级别_低) {
 层.渲染精度 = 1
 层.标志 = 层.标志 | 层标志_AI低精度绘制
 层.标志 = 层.标志 & (~层标志_AI可跳过绘制)
 } 否则 如果 (级别 <= 渲染级别_中) {
 层.渲染精度 = 2
 层.标志 = 层.标志 & (~层标志_AI可跳过绘制)
 层.标志 = 层.标志 & (~层标志_AI低精度绘制)
 } 否则 {
 层.渲染精度 = 3
 层.标志 = 层.标志 | 层标志_AI高优先级
 层.标志 = 层.标志 & (~层标志_AI可跳过绘制)
 层.标志 = 层.标志 & (~层标志_AI低精度绘制)
 }
 } 否则 {
 // 后备: 无AI总线时简单判断
 如果 (!是否可见) {
 层.渲染精度 = 0
 层.标志 = 层.标志 | 层标志_AI可跳过绘制
 } 否则 {
 层.渲染精度 = 2
 层.标志 = 层.标志 & (~层标志_AI可跳过绘制)
 }
 }

 // 递归更新子层
 定义 可变 子 = 层.第一子层
 当 (子 != 0) {
 AI渲染_更新层可见性(子, 视口上, 视口下)
 子 = 子.后兄层
 }
}

// NovaOS 安全审计+零信任架构 — 日志/异常检测/令牌/RBAC/AI威胁分析
// 本模块实现操作系统级安全基础设施:
//   1. 审计日志: 分级记录(信息/警告/严重/关键)+环形缓冲
//   2. 异常检测: 滑动窗口统计+AI模式匹配
//   3. 零信任令牌: 颁发/验证/吊销/自动过期
//   4. RBAC角色权限: 角色定义/权限矩阵/继承
//   5. 沙箱策略: 进程隔离级别/资源配额
//   6. AI威胁分析: 行为基线/偏差检测/自适应阈值
// 与防火墙、杀毒引擎、内核各子系统、智能大脑深度耦合。

导入("./类型定义.nova")
导入("./错误码.nova")
导入("./日志中枢.nova")
导入("./同步原语.nova")
导入("./进程调度.nova")
导入("./安全防护初始.nova")
导入("./公共智能.nova")
导入("../引导/引导加载器.nova")
导入("./整数转字符串.nova")
导入("./墙钟设置.nova")

定义 可变 安全_时钟 = 0

定义 审计日志_最大 = 2048
定义 安全级别_信息 = 0
定义 安全级别_警告 = 1
定义 安全级别_严重 = 2
定义 安全级别_关键 = 3

结构 审计日志 {
    时间戳,
    级别,
    类型,
    来源,
    详情,
}

定义 可变 审计日志列表 = []
定义 可变 安全_告警数 = 0
定义 可变 安全_拦截数 = 0

函数 安全审计_记录(类型, 来源, 详情) {
    如果 (计数(审计日志列表) >= 审计日志_最大) { 删除(审计日志列表, 0) }
    定义 log = 审计日志 {}
    log.时间戳 = 安全_时钟
    log.类型 = 类型
    log.来源 = 来源
    log.详情 = 详情
    如果 (类型 == "权限违规" || 类型 == "入侵检测") {
        log.级别 = 安全级别_关键
        安全_告警数 = 安全_告警数 + 1
    } 否则 如果 (类型 == "域名拦截" || 类型 == "内存超限") {
        log.级别 = 安全级别_警告
        安全_拦截数 = 安全_拦截数 + 1
    } 否则 {
        log.级别 = 安全级别_信息
    }
    追加(审计日志列表, log)
}

函数 安全审计_检测异常() {
    定义 可变 最近违规 = 0
    定义 窗口 = 100
    定义 起始 = 0
    如果 (计数(审计日志列表) > 窗口) { 起始 = 计数(审计日志列表) - 窗口 }
    定义 可变 i = 起始
    当 (i < 计数(审计日志列表)) {
        如果 (审计日志列表[i].级别 >= 安全级别_警告) {
            最近违规 = 最近违规 + 1
        }
        i = i + 1
    }
    如果 (最近违规 > 10) {
        内核错误("安全审计: 异常活动! 最近" + 整数转字符串(窗口) +
                 "条中" + 整数转字符串(最近违规) + "条警告")
        返回 真
    }
    返回 假
}

// §6 零信任架构

结构 授权令牌 {
    令牌ID,
    主体,
    权限列表,    // []
    过期时间,
    已吊销,
}

定义 可变 令牌列表 = []
定义 可变 下一个令牌ID_安全 = 1

函数 零信任_颁发令牌(主体, 权限, 有效期) {
    定义 令牌 = 授权令牌 {}
    令牌.令牌ID = 下一个令牌ID_安全
    下一个令牌ID_安全 = 下一个令牌ID_安全 + 1
    令牌.主体 = 主体
    令牌.权限列表 = 权限
    令牌.过期时间 = 安全_时钟 + 有效期
    令牌.已吊销 = 假
    追加(令牌列表, 令牌)
    返回 令牌.令牌ID
}

函数 零信任_验证(令牌ID, 操作) {
    定义 可变 i = 0
    当 (i < 计数(令牌列表)) {
        如果 (令牌列表[i].令牌ID == 令牌ID) {
            如果 (令牌列表[i].已吊销) { 返回 假 }
            如果 (令牌列表[i].过期时间 < 安全_时钟) {
                令牌列表[i].已吊销 = 真
                返回 假
            }
            定义 可变 j = 0
            当 (j < 计数(令牌列表[i].权限列表)) {
                如果 (令牌列表[i].权限列表[j] == 操作) { 返回 真 }
                j = j + 1
            }
            安全审计_记录("权限不足", 令牌列表[i].主体, 操作)
            返回 假
        }
        i = i + 1
    }
    返回 假
}

函数 零信任_吊销(令牌ID) {
    定义 可变 i = 0
    当 (i < 计数(令牌列表)) {
        如果 (令牌列表[i].令牌ID == 令牌ID) {
            令牌列表[i].已吊销 = 真
            安全审计_记录("令牌吊销", "零信任", "ID=" + 整数转字符串(令牌ID))
            返回 真
        }
        i = i + 1
    }
    返回 假
}

函数 零信任_清理过期() {
    定义 可变 清理数 = 0
    定义 可变 i = 0
    当 (i < 计数(令牌列表)) {
        如果 (令牌列表[i].过期时间 < 安全_时钟 && !令牌列表[i].已吊销) {
            令牌列表[i].已吊销 = 真
            清理数 = 清理数 + 1
        }
        i = i + 1
    }
    返回 清理数
}

// §7 RBAC角色权限控制

结构 安全角色 {
    名称,
    权限列表,
    父角色,
    优先级,
}

定义 可变 角色列表 = []

函数 RBAC_创建角色(名称, 权限, 父角色) {
    定义 角色 = 安全角色 {
        名称: 名称,
        权限列表: 权限,
        父角色: 父角色,
        优先级: 计数(角色列表),
    }
    追加(角色列表, 角色)
    返回 角色
}

函数 RBAC_检查权限(角色, 操作) {
    如果 (角色 == 空) { 返回 假 }
    // 检查当前角色
    定义 可变 i = 0
    当 (i < 计数(角色.权限列表)) {
        如果 (角色.权限列表[i] == 操作 || 角色.权限列表[i] == "*") {
            返回 真
        }
        i = i + 1
    }
    // 检查父角色(继承)
    如果 (角色.父角色 != 空) {
        返回 RBAC_检查权限(角色.父角色, 操作)
    }
    返回 假
}

函数 RBAC_初始化默认角色() {
    定义 root角色 = RBAC_创建角色("root", ["*"], 空)
    定义 admin角色 = RBAC_创建角色("admin", ["用户管理", "系统配置", "服务管理", "安全管理"], root角色)
    定义 用户角色 = RBAC_创建角色("user", ["文件读写", "网络访问", "进程创建"], 空)
    定义 访客角色 = RBAC_创建角色("guest", ["文件读"], 空)
}

// §8 沙箱策略

结构 沙箱策略 {
    名称,
    隔离级别,
    允许网络,
    允许文件写,
    允许进程创建,
    内存配额_MB,
    CPU配额_百分比,
    磁盘配额_MB,
}

定义 隔离_无 = 0
定义 隔离_基本 = 1
定义 隔离_严格 = 2
定义 隔离_完全 = 3

定义 可变 沙箱策略列表 = []

函数 沙箱_创建策略(名称, 级别) {
    定义 策略 = 沙箱策略 {
        名称: 名称,
        隔离级别: 级别,
        允许网络: 级别 < 隔离_严格,
        允许文件写: 级别 < 隔离_完全,
        允许进程创建: 级别 < 隔离_严格,
        内存配额_MB: 256,
        CPU配额_百分比: 50,
        磁盘配额_MB: 1024,
    }
    如果 (级别 == 隔离_完全) {
        策略.内存配额_MB = 64
        策略.CPU配额_百分比 = 10
        策略.磁盘配额_MB = 0
    }
    追加(沙箱策略列表, 策略)
    返回 策略
}

函数 沙箱_检查操作(策略, 操作类型) {
    如果 (策略 == 空) { 返回 真 }
    如果 (操作类型 == "网络" && !策略.允许网络) { 返回 假 }
    如果 (操作类型 == "文件写" && !策略.允许文件写) { 返回 假 }
    如果 (操作类型 == "进程创建" && !策略.允许进程创建) { 返回 假 }
    返回 真
}

// §9 AI威胁分析

结构 AI行为基线 {
    PID,
    正常系统调用频率,
    正常文件操作频率,
    正常网络频率,
    采样数,
    偏差阈值,
}

定义 可变 AI行为基线表 = []
定义 可变 AI_威胁检测数 = 0

函数 AI安全_建立基线(PID, 系统调用率, 文件操作率, 网络率) {
    追加(AI行为基线表, AI行为基线 {
        PID: PID,
        正常系统调用频率: 系统调用率,
        正常文件操作频率: 文件操作率,
        正常网络频率: 网络率,
        采样数: 1,
        偏差阈值: 300,
    })
}

函数 AI安全_检测偏差(PID, 当前系统调用率, 当前文件率, 当前网络率) {
    定义 可变 i = 0
    当 (i < 计数(AI行为基线表)) {
        如果 (AI行为基线表[i].PID == PID) {
            定义 基线 = AI行为基线表[i]
            定义 可变 偏差分 = 0

            如果 (基线.正常系统调用频率 > 0) {
                定义 比率 = 当前系统调用率 * 100 / 基线.正常系统调用频率
                如果 (比率 > 200 || 比率 < 30) { 偏差分 = 偏差分 + 100 }
            }
            如果 (基线.正常文件操作频率 > 0) {
                定义 比率 = 当前文件率 * 100 / 基线.正常文件操作频率
                如果 (比率 > 300) { 偏差分 = 偏差分 + 150 }
            }
            如果 (基线.正常网络频率 > 0) {
                定义 比率 = 当前网络率 * 100 / 基线.正常网络频率
                如果 (比率 > 500) { 偏差分 = 偏差分 + 200 }
            }

            如果 (偏差分 > 基线.偏差阈值) {
                AI_威胁检测数 = AI_威胁检测数 + 1
                安全审计_记录("AI威胁", "PID=" + 整数转字符串(PID), "偏差=" + 整数转字符串(偏差分))
                返回 真
            }

            // 自适应更新基线(EWMA)
            基线.正常系统调用频率 = (基线.正常系统调用频率 * 7 + 当前系统调用率) / 8
            基线.正常文件操作频率 = (基线.正常文件操作频率 * 7 + 当前文件率) / 8
            基线.正常网络频率 = (基线.正常网络频率 * 7 + 当前网络率) / 8
            基线.采样数 = 基线.采样数 + 1

            返回 假
        }
        i = i + 1
    }
    // 无基线: 建立新基线
    AI安全_建立基线(PID, 当前系统调用率, 当前文件率, 当前网络率)
    返回 假
}

// §10 安全系统初始化

函数 安全系统_初始化() {
    审计日志列表 = []
    令牌列表 = []
    角色列表 = []
    沙箱策略列表 = []
    AI行为基线表 = []
    安全_时钟 = 当前时间_纳秒() / 1000000
    RBAC_初始化默认角色()
    内核信息("[安全] 审计+零信任+RBAC+沙箱+AI威胁分析 初始化完成")
}

函数 安全系统_更新时钟() {
    安全_时钟 = 当前时间_纳秒() / 1000000
}

// §11 统计与诊断

函数 安全_统计() {
    返回 {
        审计日志数: 计数(审计日志列表),
        告警数: 安全_告警数,
        拦截数: 安全_拦截数,
        令牌数: 计数(令牌列表),
        角色数: 计数(角色列表),
        沙箱策略数: 计数(沙箱策略列表),
        AI基线数: 计数(AI行为基线表),
        AI威胁检测: AI_威胁检测数,
    }
}

函数 安全_健康检查() {
    定义 可变 问题 = []
    如果 (安全_告警数 > 50) {
        追加(问题, "告警过多: " + 整数转字符串(安全_告警数))
    }
    如果 (AI_威胁检测数 > 10) {
        追加(问题, "AI检测威胁: " + 整数转字符串(AI_威胁检测数))
    }
    定义 异常 = 安全审计_检测异常()
    如果 (异常) { 追加(问题, "审计异常活动") }
    如果 (计数(问题) == 0) { 返回 "安全系统健康" }
    返回 问题
}

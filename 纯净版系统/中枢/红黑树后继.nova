    打印(字符串拼接("  删除次数: ", 转字符串(全局统计.删除次数)))
    打印(字符串拼接("  删除修复: ", 转字符串(全局统计.删除修复次数)))
    打印(字符串拼接("  删除旋转: ", 转字符串(全局统计.删除修复旋转)))
    打印(字符串拼接("  迭代器创建: ", 转字符串(全局统计.迭代器创建数)))
    打印(字符串拼接("  迭代器步进: ", 转字符串(全局统计.迭代器步进数)))
    打印(字符串拼接("  序列化: ", 转字符串(全局统计.序列化次数)))
    打印(字符串拼接("  反序列化: ", 转字符串(全局统计.反序列化次数)))
    打印(字符串拼接("  批量删除: ", 转字符串(全局统计.批量删除次数)))
    打印(字符串拼接("  过滤删除: ", 转字符串(全局统计.过滤删除次数)))
    打印(字符串拼接("  AI热点记录: ", 转字符串(全局统计.AI热点记录数)))
    打印(字符串拼接("  AI热点命中: ", 转字符串(全局统计.AI热点命中数)))
    打印(字符串拼接("  空节点访问: ", 转字符串(全局统计.空节点访问数)))
    打印(字符串拼接("  错误次数: ", 转字符串(全局统计.错误次数)))
    返回 0
}


函数 红黑树导航_注册到内核(内核上下文) {
    如果 (已初始化 == 假) { 返回 错误_未初始化 }
    打印("[红黑树导航] 已注册到内核上下文")
    返回 0
}

函数 红黑树导航_查询状态() {
    如果 (已初始化 == 假) { 返回 0 }
    返回 1
}

函数 红黑树导航_健康检查() {
    如果 (已初始化 == 假) { 返回 假 }
    如果 (全局统计.错误次数 * 10 > 全局统计.后继查找次数 + 全局统计.删除次数) {
        返回 假
    }
    返回 真
}

定义 错误_已存在 = 0 - 17
定义 错误_未初始化 = 0 - 1
定义 错误_无效参数 = 0 - 22
定义 错误_未找到 = 0 - 2

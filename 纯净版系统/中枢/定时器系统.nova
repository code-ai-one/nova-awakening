// NovaOS 定时器系统 — setTimeout/setInterval/requestAnimationFrame
// 技术: HTML规范 §8.6 Timers + §8.7 Animation Frames
// 核心: 定时器堆(最小堆按触发时间排序), 精确调度, GC根保护
//       requestAnimationFrame帧同步, 嵌套定时器限制(4ms最小间隔)
// 接口: 脚本引擎运行时→事件循环→渲染管线(完整事件循环集成)
// NovaOS创新: AI定时器合并(减少唤醒) + 帧间隙利用 + 智能节流

导入("../中枢/系统调用表.nova")
导入("../推理/智能渠道.nova")
导入("../感知/内核直连层.nova")
导入("./字符串替换.nova")
导入("./内存初始化.nova")
导入("../标准/加法运算符.nova")
导入("./创建甲.nova")
导入("../执行/底层内存操.nova")


定义 定时器_最大数量       = 4096    // 最大同时活跃定时器
定义 定时器_条目大小       = 48      // 每条目字节数
定义 定时器_嵌套限制       = 5       // 嵌套≥5层时最小间隔4ms
定义 定时器_嵌套最小间隔   = 4       // 4ms (HTML规范)
定义 RAF_最大回调数        = 256     // requestAnimationFrame最大回调
定义 AI_合并窗口_微秒      = 1000    // 1ms内的定时器可合并

结构 定时器条目 {
    ID,
    回调,    // u64 JSValue* Function
    延迟_ms,
    触发时间,    // u64 微秒时间戳
    是重复,    // 布尔 interval
    已取消,
}

定义 可变 定时器列表 = 0
定义 可变 定时器数量 = 0
定义 可变 定时器容量 = 0
定义 可变 定时器下一个ID = 1

函数 定时器_初始化() {
    如果 (定时器列表 != 0) { 返回 }
    定时器容量 = 64
    定时器列表 = 堆_分配_数组(定时器容量 * 40)
    定时器数量 = 0
}

函数 定时器_添加(Nova运行时实例, 回调, 延迟_ms, 是重复) {
    如果 (定时器列表 == 0) { 定时器_初始化() }
    如果 (定时器数量 >= 定时器容量) { 返回 -1 }

    定义 id = 定时器下一个ID
    定时器下一个ID = 定时器下一个ID + 1

    定义 偏移 = 定时器列表 + 定时器数量 * 40
    内存_写32(偏移, id)
    内存_写64(偏移 + 8, 回调)
    内存_写32(偏移 + 16, 延迟_ms)
    内存_写64(偏移 + 20, 平台_获取高精度时间() + 延迟_ms * 1000)
    内存_写8(偏移 + 28, 是重复)
    内存_写8(偏移 + 29, 0)    // 未取消
    定时器数量 = 定时器数量 + 1

    NovaGC_添加根(Nova运行时实例.heap, 回调)    // GC保护
    返回 id
}

函数 定时器_移除(id) {
    定义 可变 i = 0
    当 (i < 定时器数量) {
        定义 偏移 = 定时器列表 + i * 40
        如果 (内存_读32(偏移) == id) {
            内存_写8(偏移 + 29, 1)    // 标记取消
            返回
        }
        i = i + 1
    }
}

函数 定时器_执行到期(Nova运行时实例) {
    如果 (定时器列表 == 0) { 返回 }
    定义 当前时间 = 平台_获取高精度时间()

    定义 可变 i = 0
    当 (i < 定时器数量) {
        定义 偏移 = 定时器列表 + i * 40
        如果 (内存_读8(偏移 + 29) == 0) {    // 未取消
            定义 触发时间 = 内存_读64(偏移 + 20)
            如果 (当前时间 >= 触发时间) {
                定义 回调 = 内存_读64(偏移 + 8)
                // 调用回调
                如果 (回调 != 0) {
                    Interpreter_调用函数(Nova运行时实例, 回调, Nova运行时实例.undefined值, 0, 0, 0)
                }
                // interval: 重新设置触发时间
                如果 (内存_读8(偏移 + 28)) {
                    定义 延迟 = 内存_读32(偏移 + 16)
                    内存_写64(偏移 + 20, 当前时间 + 延迟 * 1000)
                } 否则 {
                    内存_写8(偏移 + 29, 1)    // 一次性: 标记完成
                }
            }
        }
        i = i + 1
    }
}

函数 字符串转整数_基数(str, 基数) {
    如果 (str == 0) { 返回 0 }
    定义 可变 结果 = 0
    定义 可变 i = 0
    定义 可变 负 = 假
    当 (内存_读8(str + i) == 0x20) { i = i + 1 }
    如果 (内存_读8(str + i) == 0x2D) { 负 = 真; i = i + 1 }
    否则 如果 (内存_读8(str + i) == 0x2B) { i = i + 1 }
    当 (内存_读8(str + i) != 0) {
        定义 c = 内存_读8(str + i)
        定义 可变 d = -1
        如果 (c >= 0x30 && c <= 0x39) { d = c - 0x30 }
        否则 如果 (c >= 0x61 && c <= 0x7A) { d = c - 0x61 + 10 }
        否则 如果 (c >= 0x41 && c <= 0x5A) { d = c - 0x41 + 10 }
        如果 (d < 0 || d >= 基数) { 跳出 }
        结果 = 结果 * 基数 + d
        i = i + 1
    }
    如果 (负) { 结果 = 0 - 结果 }
    返回 结果
}


结构 RAF回调 {
    ID,
    回调函数,
    已取消,            // u32 bool
}

定义 可变 RAF列表 = 0
定义 可变 RAF数量 = 0
定义 可变 RAF容量 = 0
定义 可变 RAF下一个ID = 1

函数 RAF_初始化() {
    如果 (RAF列表 != 0) { 返回 }
    RAF容量 = RAF_最大回调数
    RAF列表 = 平台_申请内存(RAF容量 * 16)
    如果 (RAF列表 != 0) { 内存_清零(RAF列表, RAF容量 * 16) }
    RAF数量 = 0
}

函数 RAF_请求(Nova运行时实例, 回调) {
    如果 (RAF列表 == 0) { RAF_初始化() }
    如果 (RAF列表 == 0 || 回调 == 0) { 返回 0 }
    如果 (RAF数量 >= RAF容量) {
        打印("[RAF] 警告: requestAnimationFrame回调已满")
        返回 0
    }
    定义 id = RAF下一个ID
    RAF下一个ID = RAF下一个ID + 1
    定义 偏移 = RAF列表 + RAF数量 * 16
    内存_写32(偏移, id)
    内存_写64(偏移 + 4, 回调)
    内存_写32(偏移 + 12, 0)    // 未取消
    RAF数量 = RAF数量 + 1
    返回 id
}

函数 RAF_取消(id) {
    定义 可变 i = 0
    当 (i < RAF数量) {
        定义 偏移 = RAF列表 + i * 16
        如果 (内存_读32(偏移) == id) {
            内存_写32(偏移 + 12, 1)
            返回
        }
        i = i + 1
    }
}

函数 RAF_执行所有(Nova运行时实例, 帧时间戳) {
    如果 (RAF列表 == 0 || RAF数量 == 0) { 返回 }
    定义 当前数量 = RAF数量
    RAF数量 = 0    // 清空(回调中可能再次请求)
    定义 可变 i = 0
    当 (i < 当前数量) {
        定义 偏移 = RAF列表 + i * 16
        定义 已取消 = 内存_读32(偏移 + 12)
        如果 (已取消 == 0) {
            定义 回调 = 内存_读64(偏移 + 4)
            如果 (回调 != 0) {
                // 传递DOMHighResTimeStamp作为参数
                定义 时间参数 = Nova值_创建_Number(Nova运行时实例, 帧时间戳 / 1000)
                Interpreter_调用函数(Nova运行时实例, 回调, Nova运行时实例.undefined值, 时间参数, 1, 0)
            }
        }
        i = i + 1
    }
}


结构 定时器管理器 {
    定时器堆,          // u64 最小堆数组(按触发时间排序)
    堆大小,
    堆容量,
    下一个ID,
    // 嵌套追踪
    当前嵌套深度,      // u32 当前定时器回调的嵌套层数
    // RAF
    RAF回调列表,
    RAF回调数量,
    RAF回调容量,
    RAF下一个ID,
    // AI优化
    AI合并激活,        // u32 bool
    AI合并窗口,        // u32 微秒
    AI节流激活,        // u32 bool: 后台标签页节流
    // 统计
    统计_setTimeout次数,
    统计_setInterval次数,
    统计_clearTimeout次数,
    统计_RAF请求次数,
    统计_定时器执行次数,
    统计_定时器取消次数,
    统计_AI合并次数,
    统计_AI节流次数,
    统计_最大活跃数,
}

函数 定时器管理器_创建() {
    定义 可变 管理器 = 堆_分配(定时器管理器)
    如果 (管理器 == 0) {
        打印("[定时器] 错误: 管理器分配失败")
        返回 空
    }
    管理器.堆容量 = 定时器_最大数量
    管理器.定时器堆 = 平台_申请内存(管理器.堆容量 * 定时器_条目大小)
    如果 (管理器.定时器堆 == 0) {
        堆_释放(管理器)
        返回 空
    }
    内存_清零(管理器.定时器堆, 管理器.堆容量 * 定时器_条目大小)
    管理器.堆大小 = 0
    管理器.下一个ID = 1
    管理器.当前嵌套深度 = 0

    管理器.RAF回调容量 = RAF_最大回调数
    管理器.RAF回调列表 = 平台_申请内存(管理器.RAF回调容量 * 16)
    如果 (管理器.RAF回调列表 != 0) {
        内存_清零(管理器.RAF回调列表, 管理器.RAF回调容量 * 16)
    }
    管理器.RAF回调数量 = 0
    管理器.RAF下一个ID = 1

    管理器.AI合并激活 = 真
    管理器.AI合并窗口 = AI_合并窗口_微秒
    管理器.AI节流激活 = 假

    管理器.统计_setTimeout次数 = 0
    管理器.统计_setInterval次数 = 0
    管理器.统计_clearTimeout次数 = 0
    管理器.统计_RAF请求次数 = 0
    管理器.统计_定时器执行次数 = 0
    管理器.统计_定时器取消次数 = 0
    管理器.统计_AI合并次数 = 0
    管理器.统计_AI节流次数 = 0
    管理器.统计_最大活跃数 = 0

    打印("[定时器] 管理器初始化完成")
    返回 管理器
}

函数 定时器管理器_销毁(管理器) {
    如果 (管理器 == 空) { 返回 }
    如果 (管理器.定时器堆 != 0) {
        平台_释放内存(管理器.定时器堆, 管理器.堆容量 * 定时器_条目大小)
    }
    如果 (管理器.RAF回调列表 != 0) {
        平台_释放内存(管理器.RAF回调列表, 管理器.RAF回调容量 * 16)
    }
    打印("[定时器] 管理器已销毁")
    堆_释放(管理器)
}


函数 定时器堆_获取触发时间(管理器, 索引) {
    如果 (管理器 == 空 || 索引 >= 管理器.堆大小) { 返回 0xFFFFFFFFFFFFFFFF }
    返回 内存_读64(管理器.定时器堆 + 索引 * 定时器_条目大小 + 20)
}

函数 定时器堆_交换(管理器, a, b) {
    如果 (管理器 == 空) { 返回 }
    定义 偏移a = 管理器.定时器堆 + a * 定时器_条目大小
    定义 偏移b = 管理器.定时器堆 + b * 定时器_条目大小
    // 逐字节交换
    定义 可变 i = 0
    当 (i < 定时器_条目大小) {
        定义 临时 = 内存_读8(偏移a + i)
        内存_写8(偏移a + i, 内存_读8(偏移b + i))
        内存_写8(偏移b + i, 临时)
        i = i + 1
    }
}

函数 定时器堆_上浮(管理器, 索引) {
    当 (索引 > 0) {
        定义 父 = (索引 - 1) / 2
        如果 (定时器堆_获取触发时间(管理器, 索引) < 定时器堆_获取触发时间(管理器, 父)) {
            定时器堆_交换(管理器, 索引, 父)
            索引 = 父
        } 否则 {
            跳出
        }
    }
}

函数 定时器堆_下沉(管理器, 索引) {
    当 (索引 * 2 + 1 < 管理器.堆大小) {
        定义 左 = 索引 * 2 + 1
        定义 右 = 索引 * 2 + 2
        定义 可变 最小 = 左
        如果 (右 < 管理器.堆大小 && 定时器堆_获取触发时间(管理器, 右) < 定时器堆_获取触发时间(管理器, 左)) {
            最小 = 右
        }
        如果 (定时器堆_获取触发时间(管理器, 最小) < 定时器堆_获取触发时间(管理器, 索引)) {
            定时器堆_交换(管理器, 索引, 最小)
            索引 = 最小
        } 否则 {
            跳出
        }
    }
}

函数 定时器堆_插入(管理器, id, 回调, 延迟_ms, 触发时间, 是重复) {
    如果 (管理器 == 空 || 管理器.堆大小 >= 管理器.堆容量) { 返回 }
    定义 偏移 = 管理器.定时器堆 + 管理器.堆大小 * 定时器_条目大小
    内存_写32(偏移, id)
    内存_写64(偏移 + 8, 回调)
    内存_写32(偏移 + 16, 延迟_ms)
    内存_写64(偏移 + 20, 触发时间)
    内存_写8(偏移 + 28, 是重复)
    内存_写8(偏移 + 29, 0)
    定时器堆_上浮(管理器, 管理器.堆大小)
    管理器.堆大小 = 管理器.堆大小 + 1
    如果 (管理器.堆大小 > 管理器.统计_最大活跃数) {
        管理器.统计_最大活跃数 = 管理器.堆大小
    }
}

函数 定时器堆_弹出最小(管理器) {
    如果 (管理器 == 空 || 管理器.堆大小 == 0) { 返回 }
    管理器.堆大小 = 管理器.堆大小 - 1
    如果 (管理器.堆大小 > 0) {
        定时器堆_交换(管理器, 0, 管理器.堆大小)
        定时器堆_下沉(管理器, 0)
    }
}


函数 定时器管理器_setTimeout(管理器, Nova运行时实例, 回调, 延迟_ms) {
    如果 (管理器 == 空 || 回调 == 0) { 返回 0 }
    // HTML规范: 嵌套≥5层时最小间隔4ms
    定义 可变 实际延迟 = 延迟_ms
    如果 (管理器.当前嵌套深度 >= 定时器_嵌套限制 && 实际延迟 < 定时器_嵌套最小间隔) {
        实际延迟 = 定时器_嵌套最小间隔
    }
    // AI节流: 后台标签页
    如果 (管理器.AI节流激活 == 真 && 实际延迟 < 1000) {
        实际延迟 = 1000    // 后台最小1秒
        管理器.统计_AI节流次数 = 管理器.统计_AI节流次数 + 1
    }
    定义 id = 管理器.下一个ID
    管理器.下一个ID = 管理器.下一个ID + 1
    定义 触发时间 = 平台_获取高精度时间() + 实际延迟 * 1000
    定时器堆_插入(管理器, id, 回调, 实际延迟, 触发时间, 假)
    管理器.统计_setTimeout次数 = 管理器.统计_setTimeout次数 + 1
    返回 id
}

函数 定时器管理器_setInterval(管理器, Nova运行时实例, 回调, 间隔_ms) {
    如果 (管理器 == 空 || 回调 == 0) { 返回 0 }
    定义 可变 实际间隔 = 间隔_ms
    如果 (实际间隔 < 1) { 实际间隔 = 1 }
    如果 (管理器.AI节流激活 == 真 && 实际间隔 < 1000) {
        实际间隔 = 1000
        管理器.统计_AI节流次数 = 管理器.统计_AI节流次数 + 1
    }
    定义 id = 管理器.下一个ID
    管理器.下一个ID = 管理器.下一个ID + 1
    定义 触发时间 = 平台_获取高精度时间() + 实际间隔 * 1000
    定时器堆_插入(管理器, id, 回调, 实际间隔, 触发时间, 真)
    管理器.统计_setInterval次数 = 管理器.统计_setInterval次数 + 1
    返回 id
}

函数 定时器管理器_clearTimer(管理器, id) {
    如果 (管理器 == 空 || id == 0) { 返回 }
    // 在堆中查找并标记取消
    定义 可变 i = 0
    当 (i < 管理器.堆大小) {
        定义 偏移 = 管理器.定时器堆 + i * 定时器_条目大小
        如果 (内存_读32(偏移) == id) {
            内存_写8(偏移 + 29, 1)    // 标记取消
            管理器.统计_clearTimeout次数 = 管理器.统计_clearTimeout次数 + 1
            管理器.统计_定时器取消次数 = 管理器.统计_定时器取消次数 + 1
            返回
        }
        i = i + 1
    }
}

函数 定时器管理器_执行到期(管理器, Nova运行时实例) {
    如果 (管理器 == 空 || 管理器.堆大小 == 0) { 返回 }
    定义 当前时间 = 平台_获取高精度时间()

    // 处理所有已到期的定时器(堆顶)
    当 (管理器.堆大小 > 0) {
        定义 顶部偏移 = 管理器.定时器堆
        定义 触发时间 = 内存_读64(顶部偏移 + 20)
        如果 (触发时间 > 当前时间) { 跳出 }    // 堆顶未到期

        定义 已取消 = 内存_读8(顶部偏移 + 29)
        定义 回调 = 内存_读64(顶部偏移 + 8)
        定义 是重复 = 内存_读8(顶部偏移 + 28)
        定义 延迟 = 内存_读32(顶部偏移 + 16)

        // 弹出堆顶
        定时器堆_弹出最小(管理器)

        如果 (已取消 == 0 && 回调 != 0) {
            // 执行回调
            管理器.当前嵌套深度 = 管理器.当前嵌套深度 + 1
            Interpreter_调用函数(Nova运行时实例, 回调, Nova运行时实例.undefined值, 0, 0, 0)
            管理器.当前嵌套深度 = 管理器.当前嵌套深度 - 1
            管理器.统计_定时器执行次数 = 管理器.统计_定时器执行次数 + 1

            // interval: 重新插入
            如果 (是重复 == 真) {
                定义 新触发 = 当前时间 + 延迟 * 1000
                定义 id = 内存_读32(顶部偏移)
                定时器堆_插入(管理器, id, 回调, 延迟, 新触发, 真)
            }
        }
    }
}

函数 定时器管理器_获取最近触发时间(管理器) {
    如果 (管理器 == 空 || 管理器.堆大小 == 0) { 返回 0xFFFFFFFFFFFFFFFF }
    返回 内存_读64(管理器.定时器堆 + 20)
}

函数 定时器管理器_活跃数(管理器) {
    如果 (管理器 == 空) { 返回 0 }
    返回 管理器.堆大小
}

// 传统浏览器: 每个定时器独立唤醒CPU
// NovaOS: AI将时间接近的定时器合并执行, 减少CPU唤醒次数

函数 AI_定时器_应该合并(管理器, 触发时间1, 触发时间2) {
    如果 (管理器 == 空 || 管理器.AI合并激活 == 假) { 返回 假 }
    定义 差值 = 触发时间1 - 触发时间2
    如果 (差值 < 0) { 差值 = 0 - 差值 }
    返回 差值 <= 管理器.AI合并窗口
}

函数 AI_定时器_设置节流(管理器, 激活) {
    如果 (管理器 == 空) { 返回 }
    管理器.AI节流激活 = 激活
    如果 (激活 == 真) {
        打印("[定时器-AI] 后台标签页节流已激活")
    } 否则 {
        打印("[定时器-AI] 后台标签页节流已停用")
    }
}


函数 定时器管理器_打印统计(管理器) {
    如果 (管理器 == 空) { 返回 }
    打印("[定时器] ═══════════ 定时器系统统计 ═══════════")
    打印(字符串拼接("  活跃定时器数:   ", 转字符串(管理器.堆大小)))
    打印(字符串拼接("  最大活跃数:     ", 转字符串(管理器.统计_最大活跃数)))
    打印(字符串拼接("  setTimeout次数: ", 转字符串(管理器.统计_setTimeout次数)))
    打印(字符串拼接("  setInterval次数:", 转字符串(管理器.统计_setInterval次数)))
    打印(字符串拼接("  clearTimeout次: ", 转字符串(管理器.统计_clearTimeout次数)))
    打印(字符串拼接("  RAF请求次数:    ", 转字符串(管理器.统计_RAF请求次数)))
    打印(字符串拼接("  定时器执行次数: ", 转字符串(管理器.统计_定时器执行次数)))
    打印(字符串拼接("  定时器取消次数: ", 转字符串(管理器.统计_定时器取消次数)))
    打印("[定时器] ── AI优化 ──")
    打印(字符串拼接("  AI合并次数:     ", 转字符串(管理器.统计_AI合并次数)))
    打印(字符串拼接("  AI节流次数:     ", 转字符串(管理器.统计_AI节流次数)))
    打印(字符串拼接("  AI节流激活:     ", 转字符串(管理器.AI节流激活)))
    打印(字符串拼接("  AI合并窗口(μs): ", 转字符串(管理器.AI合并窗口)))
    打印("[定时器] ═══════════════════════════════════════")
}

函数 定时器管理器_清空所有(管理器) {
    如果 (管理器 == 空) { 返回 }
    管理器.堆大小 = 0
    管理器.RAF回调数量 = 0
    打印("[定时器] 所有定时器已清空")
}

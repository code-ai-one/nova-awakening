导入("../基础.nova")
导入("../算法/数学扩展.nova")


定义 初始化_随机态 = 77777
函数 初始化_随机() {
 初始化_随机态 = 初始化_随机态 ^ (初始化_随机态 << 13)
 初始化_随机态 = 初始化_随机态 ^ (初始化_随机态 >> 7)
 初始化_随机态 = 初始化_随机态 ^ (初始化_随机态 << 17)
 如果 (初始化_随机态 < 0) { 初始化_随机态 = 0 - 初始化_随机态 }
 返回 初始化_随机态
}

// 近似正态: Box-Muller简化 → 均匀→近似正态
函数 伪正态(均值, 标准差) {
 // 中心极限: 3个均匀的平均
 定义 可变 总和 = 0
 总和 = 总和 + (初始化_随机() % 200 - 100)
 总和 = 总和 + (初始化_随机() % 200 - 100)
 总和 = 总和 + (初始化_随机() % 200 - 100)
 返回 均值 + 总和 * 标准差 / 300
}

// 整数平方根 — 委托给内建
函数 整数根(n) {
    如果 (n <= 0) { 返回 1
}
 返回 整数sqrt(n)
}

// 常数初始化
函数 初始化_常数(大小, 值) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 大小) { 追加(r, 值)
 i = i + 1 }
 返回 r
}

// 均匀初始化
函数 初始化_均匀(大小, 下界, 上界) { 定义 范围 = 上界 - 下界
 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 大小) {
 追加(r, 下界 + 初始化_随机() % (范围 + 1))
 i = i + 1
 }
 返回 r
}

// 正态初始化
函数 初始化_正态(大小, 均值, 标准差) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 大小) { 追加(r, 伪正态(均值, 标准差))
 i = i + 1 }
 返回 r
}

// Xavier均匀
函数 初始化_Xavier均匀(大小, fan_in, fan_out) { 定义 界 = 整数根(6 * 1000 / (fan_in + fan_out))
 返回 初始化_均匀(大小, 0 - 界, 界)
}

// Xavier正态
函数 初始化_Xavier正态(大小, fan_in, fan_out) { 定义 标准差 = 整数根(2 * 1000 / (fan_in + fan_out))
 返回 初始化_正态(大小, 0, 标准差)
}

// He/Kaiming均匀
函数 初始化_He均匀(大小, fan_in) { 定义 界 = 整数根(6 * 1000 / fan_in)
 返回 初始化_均匀(大小, 0 - 界, 界)
}

// He/Kaiming正态
函数 初始化_He正态(大小, fan_in) { 定义 标准差 = 整数根(2 * 1000 / fan_in)
 返回 初始化_正态(大小, 0, 标准差)
}

// 稀疏初始化
函数 初始化_稀疏(大小, 稀疏率, 标准差) { 定义 可变 r = []
 定义 可变 i = 0
 当 (i < 大小) { 如果 (初始化_随机() % 100 < 稀疏率) { 追加(r, 0) }
 否则 { 追加(r, 伪正态(0, 标准差)) }
 i = i + 1
 }
 返回 r
}

// 统计
// 设种子
函数 初始化_设种子(种子) { 初始化_随机态 = 种子 }

// 正交初始化 (近似)
函数 初始化_正交(行数, 列数) { 定义 大小 = 行数 * 列数
 定义 可变 r = 初始化_正态(大小, 0, 100)
 // Gram-Schmidt正交化 (逐行)
 定义 可变 行号 = 0
 当 (行号 < 行数) {
 // 减去之前行的投影
 定义 可变 前值 = 0
 当 (前值 < 行号) { 定义 可变 点积 = 0
 定义 可变 范数2 = 0
 定义 可变 k = 0
 当 (k < 列数) {
 点积 = 点积 + r[行号 * 列数 + k] * r[前值 * 列数 + k] / 1000
 范数2 = 范数2 + r[前值 * 列数 + k] * r[前值 * 列数 + k] / 1000
 k = k + 1
 }
 如果 (范数2 > 0) {
 k = 0
 当 (k < 列数) {
 r[行号 * 列数 + k] = r[行号 * 列数 + k] - 点积 * r[前值 * 列数 + k] / 范数2
 k = k + 1
 }
 }
 前值 = 前值 + 1
 }
 // 归一化
 定义 可变 范数 = 0
 定义 可变 j = 0
 当 (j < 列数) { 范数 = 范数 + r[行号 * 列数 + j] * r[行号 * 列数 + j] / 1000
 j = j + 1 }
 范数 = 整数根(范数)
 如果 (范数 > 0) {
 j = 0
 当 (j < 列数) { r[行号 * 列数 + j] = r[行号 * 列数 + j] * 1000 / 范数
 j = j + 1 }
 }
 行号 = 行号 + 1
 }
 返回 r
}

// LeCun初始化
函数 初始化_LeCun正态(大小, fan_in) { 定义 标准差 = 整数根(1000 / fan_in)
 返回 初始化_正态(大小, 0, 标准差)
}

函数 初始化_LeCun均匀(大小, fan_in) { 定义 界 = 整数根(3 * 1000 / fan_in)
 返回 初始化_均匀(大小, 0 - 界, 界)
}

// LSUV初始化 (Layer-Sequential Unit Variance)
函数 初始化_LSUV(权重, 输出方差, 目标方差, 最大迭代) { 定义 可变 w = 复制列表(权重)
 定义 可变 迭代 = 0
 当 (迭代 < 最大迭代) { 如果 (输出方差 == 0) { 返回 w }
 定义 缩放 = 整数根(目标方差 * 1000 / 输出方差)
 定义 可变 i = 0
 当 (i < 计数(w)) {
 w[i] = w[i] * 缩放 / 1000
 i = i + 1
 }
 迭代 = 迭代 + 1
 }
 返回 w
}

// 初始化策略选择
定义 策略_Xavier = 0
定义 策略_He = 1
定义 策略_LeCun = 2
定义 策略_正交 = 3
定义 策略_零 = 4

函数 初始化_自动(大小, fan_in, fan_out, 策略) {
    如果 (策略 == 策略_Xavier) { 返回 初始化_Xavier正态(大小, fan_in, fan_out)
}
 如果 (策略 == 策略_He) { 返回 初始化_He正态(大小, fan_in) }
 如果 (策略 == 策略_LeCun) { 返回 初始化_LeCun正态(大小, fan_in) }
 如果 (策略 == 策略_零) { 返回 初始化_常数(大小, 0) }
 返回 初始化_正态(大小, 0, 100)
}

// 偏置初始化
函数 初始化_偏置零(大小) { 返回 初始化_常数(大小, 0) }
函数 初始化_偏置小(大小) { 返回 初始化_常数(大小, 10) }

// 权重详细统计

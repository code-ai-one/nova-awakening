导入("../中枢/类型定义.nova")
导入("../中枢/中断表注册处.nova")
导入("../中枢/哈希整数.nova")
导入("../中枢/创建甲.nova")

定义 最大总线 = 16
定义 最大驱动 = 64
定义 最大设备 = 256

结构 总线描述 {
    名称哈希,
    匹配回调,
    设备数,
}

结构 驱动描述 {
    名称哈希,
    总线索引,
    探测回调,
    移除回调,
    挂起回调,
    恢复回调,
    绑定设备数,
}

结构 设备描述 {
    标识,
    总线索引,
    驱动索引,
    状态,
    电源状态,
    中断号,
    基地址,
    绑定时刻,
}

定义 可变 总线表 = []
定义 可变 总线数 = 0
定义 可变 驱动表 = []
定义 可变 驱动数 = 0
定义 可变 设备表 = []
定义 可变 设备数 = 0
定义 可变 探测成功 = 0
定义 可变 探测失败 = 0

// ━ Nova稳态层 — Nova原生实现，整数OS自主运行，零外部依赖
函数 总线_注册(名称, 匹配回调) {
    如果 (总线数 >= 最大总线) { 返回 -1 }
    定义 总线 = 总线描述 {}
    总线.名称哈希 = 哈希_字符串(名称)
    总线.匹配回调 = 匹配回调
    总线.设备数 = 0
    追加(总线表, 总线)
    定义 索引 = 总线数
    总线数 = 总线数 + 1
    返回 索引
}

函数 驱动_注册(名称, 总线索引, 探测, 移除) {
    如果 (驱动数 >= 最大驱动) { 返回 -1 }
    如果 (总线索引 >= 总线数) { 返回 错误_无效参数 }
    定义 驱动 = 驱动描述 {}
    驱动.名称哈希 = 哈希_字符串(名称)
    驱动.总线索引 = 总线索引
    驱动.探测回调 = 探测
    驱动.移除回调 = 移除
    驱动.挂起回调 = 0
    驱动.恢复回调 = 0
    驱动.绑定设备数 = 0
    追加(驱动表, 驱动)
    定义 索引 = 驱动数
    驱动数 = 驱动数 + 1
    驱动_尝试绑定(索引)
    返回 索引
}

函数 设备_注册(总线索引, 中断号, 基地址) {
    如果 (设备数 >= 最大设备) { 返回 -1 }
    如果 (总线索引 >= 总线数) { 返回 错误_无效参数 }
    定义 设备 = 设备描述 {}
    设备.标识 = 设备数
    设备.总线索引 = 总线索引
    设备.驱动索引 = -1
    设备.状态 = 0
    设备.电源状态 = 0
    设备.中断号 = 中断号
    设备.基地址 = 基地址
    设备.绑定时刻 = 0
    追加(设备表, 设备)
    总线表[总线索引].设备数 = 总线表[总线索引].设备数 + 1
    定义 索引 = 设备数
    设备数 = 设备数 + 1
    设备_尝试匹配(索引)
    返回 索引
}

函数 驱动_尝试绑定(驱动索引) {
    定义 驱动 = 驱动表[驱动索引]
    定义 可变 序号 = 0
    当 (序号 < 设备数) {
        如果 (设备表[序号].总线索引 == 驱动.总线索引 && 设备表[序号].驱动索引 == -1) {
            设备_绑定驱动(序号, 驱动索引)
        }
        序号 = 序号 + 1
    }
}

函数 设备_尝试匹配(设备索引) {
    定义 设备 = 设备表[设备索引]
    定义 可变 序号 = 0
    当 (序号 < 驱动数) {
        如果 (驱动表[序号].总线索引 == 设备.总线索引) {
            定义 总线 = 总线表[设备.总线索引]
            定义 匹配 = 真
            如果 (总线.匹配回调 != 0) { 匹配 = 总线.匹配回调(设备索引, 序号) }
            如果 (匹配) { 设备_绑定驱动(设备索引, 序号); 返回 }
        }
        序号 = 序号 + 1
    }
}

函数 设备_绑定驱动(设备索引, 驱动索引) {
    定义 设备 = 设备表[设备索引]
    定义 驱动 = 驱动表[驱动索引]
    如果 (驱动.探测回调 != 0) {
        定义 结果 = 驱动.探测回调(设备索引)
        如果 (结果 != 0) { 探测失败 = 探测失败 + 1; 返回 }
    }
    设备.驱动索引 = 驱动索引
    设备.状态 = 1
    设备.绑定时刻 = 平台_获取高精度时间()
    驱动.绑定设备数 = 驱动.绑定设备数 + 1
    探测成功 = 探测成功 + 1
}

函数 设备_解绑驱动(设备索引) {
    如果 (设备索引 >= 设备数) { 返回 }
    定义 设备 = 设备表[设备索引]
    如果 (设备.驱动索引 >= 0 && 设备.驱动索引 < 驱动数) {
        定义 驱动 = 驱动表[设备.驱动索引]
        如果 (驱动.移除回调 != 0) { 驱动.移除回调(设备索引) }
        驱动.绑定设备数 = 驱动.绑定设备数 - 1
    }
    设备.驱动索引 = -1
    设备.状态 = 0
}

函数 设备_挂起全部() {
    定义 可变 序号 = 设备数 - 1
    当 (序号 >= 0) {
        定义 设备 = 设备表[序号]
        如果 (设备.驱动索引 >= 0) {
            定义 驱动 = 驱动表[设备.驱动索引]
            如果 (驱动.挂起回调 != 0) { 驱动.挂起回调(序号) }
            设备.电源状态 = 1
        }
        序号 = 序号 - 1
    }
}

函数 设备_恢复全部() {
    定义 可变 序号 = 0
    当 (序号 < 设备数) {
        定义 设备 = 设备表[序号]
        如果 (设备.驱动索引 >= 0 && 设备.电源状态 == 1) {
            定义 驱动 = 驱动表[设备.驱动索引]
            如果 (驱动.恢复回调 != 0) { 驱动.恢复回调(序号) }
            设备.电源状态 = 0
        }
        序号 = 序号 + 1
    }
}

函数 驱动模型_完整统计() {
    返回 [总线数, 驱动数, 设备数, 探测成功, 探测失败]
}
